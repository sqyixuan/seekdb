<Application x:Class="seekdbConfigurator.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <!-- Accent colors (seekdb blue, similar to MySQL dolphin blue) -->
        <Color x:Key="AccentColor">#2B5797</Color>
        <Color x:Key="AccentLightColor">#3E6DB5</Color>
        <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
        <SolidColorBrush x:Key="AccentLightBrush" Color="{StaticResource AccentLightColor}" />
        <SolidColorBrush x:Key="SidebarBg" Color="#2D2D30" />
        <SolidColorBrush x:Key="SidebarFg" Color="#CCCCCC" />
        <SolidColorBrush x:Key="SidebarActiveFg" Color="White" />
        <SolidColorBrush x:Key="ContentBg" Color="White" />
        <SolidColorBrush x:Key="FooterBg" Color="#F0F0F0" />
        <SolidColorBrush x:Key="SuccessGreen" Color="#2E7D32" />
    </Application.Resources>
</Application>
