# owner: donglou.zl
# owner group: major freeze
# Major freeze has been launched, but not finished.
# In this time, one server turns to inactive.
# We need to ensure that this round major_freeze should complete.

ob1=OBI(cluster=1:1:1,proxy_num=0,init_unit_cpu=0);
ob1.reboot;

let $proxy_ip = deploy_get_value(ob1.z1.obs0.ip);
let $proxy_port = deploy_get_value(ob1.z1.obs0.mysql_port);
connect(sys_conn, $proxy_ip, root@sys,,test, $proxy_port);
connection sys_conn;

# Note: there may be unfinished major_merge, which are launched according to major_freeze_duty_time.
# Therefore, we need to disable daily_merge and wait the launched major_merge to finish here.
ob1.mysql alter system set major_freeze_duty_time = 'Disable' tenant sys;
ob1.mysql alter system set major_freeze_duty_time = 'Disable' tenant all_user;
ob1.mysql alter system set major_freeze_duty_time = 'Disable' tenant all_meta;
ob1.check_until_timeout select frozen_scn=last_scn from CDB_OB_MAJOR_COMPACTION where tenant_id = 1, 1, 600;

ob1.mysql alter system major freeze;
let $max_frozen_scn = deploy_get_value(ob1.select select max(frozen_scn) as value from oceanbase.__all_freeze_info, value, 1);

let $stop_ip=deploy_get_value(ob1.z2.obs0.ip);
let $stop_port=deploy_get_value(ob1.z2.obs0.port);
--disable_query_log
eval alter system force stop server "$stop_ip:$stop_port";
--enable_query_log

ob1.check_until_timeout select frozen_scn=last_scn from CDB_OB_MAJOR_COMPACTION where tenant_id = 1 and frozen_scn = $max_frozen_scn, 1, 600;
