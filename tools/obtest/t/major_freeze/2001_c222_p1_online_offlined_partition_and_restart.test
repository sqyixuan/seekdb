# owner: jingyan.kfy
# owner group: migrate
# Offline a partition and then online it, and then restart observer,
# make sure onlined partition can merge successfully

ob1=OBI(cluster=2:2:2,proxy_num=0,init_unit_cpu=1);
ob1.reboot;

ob1.mysql alter system set enable_rebalance = 'False';
sleep 2;
let $ip=deploy_get_value(ob1.z1.obs0.ip);
let $port=deploy_get_value(ob1.z1.obs0.mysql_port);
connect (conn_obtest,$ip,root@obtest,,test,$port);
connect (conn_sys,$ip,root@sys,,oceanbase,$port);
connection conn_obtest;
create table oceanbase.t1(c1 int primary key, c2 int);
connection conn_sys;
ob1.mysql alter resource pool sys_pool unit_num = 2;

let $ip20=deploy_get_value(ob1.z2.obs0.ip);
let $port20=deploy_get_value(ob1.z2.obs0.mysql_port);
let $sql_port20=deploy_get_value(ob1.z2.obs0.mysql_port);
let $ip21=deploy_get_value(ob1.z2.obs1.ip);
let $port21=deploy_get_value(ob1.z2.obs1.port);
let $sql_port21=deploy_get_value(ob1.z2.obs1.mysql_port);

let $tid = deploy_get_value(ob1.select select table_id v from oceanbase.__all_virtual_table where table_name='t1', v, 1);

ob1.mysql alter system move replica partition_id = '0%1@$tid' source= '$ip20:$port20' destination = '$ip21:$port21';
sleep 30;

ob1.mysql alter system move replica partition_id = '0%1@$tid' source= '$ip21:$port21' destination = '$ip20:$port20';
sleep 30;

ob1.restart;
sleep 60;

ob1.mysql alter system major freeze;
ob1.check_until_timeout select case when frozen_version=last_merged_version then true else false end from (select max(case when name = 'frozen_version' then value end) frozen_version, max(case when name = 'last_merged_version' then value end) last_merged_version from oceanbase.__all_zone where zone = '') a, 1, 1200;

