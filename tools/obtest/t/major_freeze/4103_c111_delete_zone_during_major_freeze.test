# owner: binifei.bnf
# owner group: major freeze
# Major freeze has been launched, but not finished.
# In this time, stop/delete one zone.
# We need to ensure that this round major_freeze should complete.

ob1=OBI(cluster=1:1:1, proxy_num=0, init_unit_cpu=0);
ob1.reboot;

let $proxy_ip = deploy_get_value(ob1.z1.obs0.ip);
let $proxy_port = deploy_get_value(ob1.z1.obs0.mysql_port);
connect(sys_conn, $proxy_ip, root@sys,,test, $proxy_port);
connection sys_conn;

# Note: there may be unfinished major_merge, which are launched according to major_freeze_duty_time.
# Therefore, we need to disable daily_merge and wait the launched major_merge to finish here.
ob1.mysql alter system set major_freeze_duty_time = 'Disable' tenant sys;
ob1.mysql alter system set major_freeze_duty_time = 'Disable' tenant all_user;
ob1.mysql alter system set major_freeze_duty_time = 'Disable' tenant all_meta;
ob1.check_until_timeout select frozen_scn=last_scn from CDB_OB_MAJOR_COMPACTION where tenant_id = 1, 1, 600;

let $delete_ip = deploy_get_value(ob1.z3.obs0.ip);
let $delete_port = deploy_get_value(ob1.z3.obs0.port);
let $tenant_num = deploy_get_value(ob1.select select count(*) as cnt from __all_tenant where locality like "%z3%" and tenant_name not like "META\$%", cnt, 1);
let $resource_pool_num = deploy_get_value(ob1.select select count(*) as cnt from __all_resource_pool where zone_list like "%z3%", cnt, 1);
let $region_info = deploy_get_value(ob1.select select info from __all_zone where zone = 'z3' and name = 'region', info, 1);

######################################################################
# stop zone, and check if major freeze would complete
ob1.mysql alter system major freeze;
let $max_frozen_scn = deploy_get_value(ob1.select select max(frozen_scn) as value from oceanbase.__all_freeze_info, value, 1);
--disable_query_log
eval alter system stop zone 'z3';
--enable_query_log
ob1.check_until_timeout select frozen_scn = last_scn from CDB_OB_MAJOR_COMPACTION where tenant_id = 1 and frozen_scn = $max_frozen_scn, 1, 600;

######################################################################
# delete zone, and check if major freeze would complete
ob1.mysql alter system major freeze;
--disable_query_log
let $__i__ = $tenant_num;
while ($__i__ > 0)
{
    let $tenant_name = deploy_get_value(ob1.select select tenant_name from __all_tenant where locality like "%z3%" and tenant_name not like "META\$%", tenant_name, $__i__);
    eval alter tenant $tenant_name locality = 'F@z1,F@z2';
    dec $__i__;
}
ob1.check_until_timeout select count(*) from __all_tenant where locality like "%z3%", 0, 600;
ob1.check_until_timeout select count(*) from __all_tenant where previous_locality != '', 0, 600;
let $__j__ = $resource_pool_num;
while ($__j__ > 0)
{
    let $resource_pool_name = deploy_get_value(ob1.select select name from __all_resource_pool where zone_list like "%z3%", name, $__j__);
    eval alter resource pool $resource_pool_name zone_list = ('z1', 'z2');
    dec $__j__;
}
ob1.check_until_timeout select count(*) from __all_resource_pool where zone_list like "%z3%", 0, 600;
eval alter system delete server '$delete_ip:$delete_port';
ob1.check_until_timeout select count(*) from __all_server where svr_ip = '$delete_ip' and svr_port = $delete_port, 0, 600;
ob1.check_until_timeout select count(*) from __all_tablet_meta_table where svr_ip = '$delete_ip' and svr_port = $delete_port, 0, 600;
eval alter system stop zone 'z3';
eval alter system delete zone 'z3';
--enable_query_log
ob1.check_until_timeout select frozen_scn = last_scn from CDB_OB_MAJOR_COMPACTION where tenant_id = 1 and frozen_scn > $max_frozen_scn, 1, 600;
