# owner: liujixiong.ljx
# owner group: storage
# description: test sync stats cost.
#
--disable_query_log
ob1=OBI(cluster=1,proxy_num=0);
ob1.reboot;
sleep 3;

let $cpu = 2;
let $memory = '32G';
let $log_disk_size = '20G';
ob_connect(conn_sys, ob1.z1.obs0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);
alter system set _ob_ddl_timeout = '3600s';
# oracle tenant
ob1.mysql alter system set debug_sync_timeout = '100000s';
eval CREATE RESOURCE UNIT unit_1 MAX_CPU=$cpu, MEMORY_SIZE=$memory, LOG_DISK_SIZE=$log_disk_size;
eval CREATE RESOURCE POOL pool_1 UNIT = 'unit_1', UNIT_NUM = 1;
eval CREATE TENANT tenant_oracle RESOURCE_POOL_LIST = ('pool_1'), primary_zone = "z1" set ob_tcp_invited_nodes='%', ob_compatibility_mode='oracle';

--echo 
--echo to test 6k partitions and 256 columns.
ob_connect(conn_oracle, ob1.z1.obs0, SYS@tenant_oracle, ,SYS, , USE_OB_CONNECTOR);
set ob_query_timeout = 1000000000000;
create table t1 (
 col_1 number default 1, col_2 char(100), col_3 number default 3, col_4 number default 4, col_5 number default 5, col_6 number default 6, col_7 number default 7, col_8 number default 8, col_9 number default 9, col_10 number default 10, col_11 number default 11, col_12 number default 12, col_13 number default 13, col_14 number default 14, col_15 number default 15, col_16 number default 16, col_17 number default 17, col_18 number default 18, col_19 number default 19, col_20 number default 20, col_21 number default 21, col_22 number default 22, col_23 number default 23, col_24 number default 24, col_25 number default 25, col_26 number default 26, col_27 number default 27, col_28 number default 28, col_29 number default 29, col_30 number default 30, col_31 number default 31, col_32 number default 32, col_33 number default 33, col_34 number default 34, col_35 number default 35, col_36 number default 36, col_37 number default 37, col_38 number default 38, col_39 number default 39, col_40 number default 40, col_41 number default 41, col_42 number default 42, col_43 number default 43, col_44 number default 44, col_45 number default 45, col_46 number default 46, col_47 number default 47, col_48 number default 48, col_49 number default 49, col_50 number default 50, col_51 number default 51, col_52 number default 52, col_53 number default 53, col_54 number default 54, col_55 number default 55, col_56 number default 56, col_57 number default 57, col_58 number default 58, col_59 number default 59, col_60 number default 60, col_61 number default 61, col_62 number default 62, col_63 number default 63, col_64 number default 64, col_65 number default 65, col_66 number default 66, col_67 number default 67, col_68 number default 68, col_69 number default 69, col_70 number default 70, col_71 number default 71, col_72 number default 72, col_73 number default 73, col_74 number default 74, col_75 number default 75, col_76 number default 76, col_77 number default 77, col_78 number default 78, col_79 number default 79, col_80 number default 80, col_81 number default 81, col_82 number default 82, col_83 number default 83, col_84 number default 84, col_85 number default 85, col_86 number default 86, col_87 number default 87, col_88 number default 88, col_89 number default 89, col_90 number default 90, col_91 number default 91, col_92 number default 92, col_93 number default 93, col_94 number default 94, col_95 number default 95, col_96 number default 96, col_97 number default 97, col_98 number default 98, col_99 number default 99, col_100 number default 100, col_101 number default 101, col_102 number default 102, col_103 number default 103, col_104 number default 104, col_105 number default 105, col_106 number default 106, col_107 number default 107, col_108 number default 108, col_109 number default 109, col_110 number default 110, col_111 number default 111, col_112 number default 112, col_113 number default 113, col_114 number default 114, col_115 number default 115, col_116 number default 116, col_117 number default 117, col_118 number default 118, col_119 number default 119, col_120 number default 120, col_121 number default 121, col_122 number default 122, col_123 number default 123, col_124 number default 124, col_125 number default 125, col_126 number default 126, col_127 number default 127, col_128 number default 128
) partition by hash(col_1) partitions 6000;
insert into t1(col_1, col_2) select random(), randstr(30, random()) from table(generator(12000));
call dbms_stats.gather_table_stats('SYS','T1',method_opt=>'FOR ALL COLUMNS SIZE 256');
alter table t1 parallel 64;
alter table t1 modify col_2 varchar(100);
drop table t1;
