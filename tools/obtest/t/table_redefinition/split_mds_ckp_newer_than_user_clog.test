
# owner: ly435438
# owner group: storage
# description:this case is use to test the scenario that the clog replay scn smaller than the mds check point scn
#
--disable_query_log
# Notice 
# 1. `obproxy` can not be created if specify init_unit_cpu = 1;
# 2. Tenant `mysql` and `obtest` can not be created without init_unit_cpu=num.

ob1=OBI(cluster=1, proxy_num=0, init_unit_cpu = 4, init_unit_mem=5368709120);
let $ip       = deploy_get_value(ob1.z1.obs0.ip);
let $port     = deploy_get_value(ob1.z1.obs0.mysql_port);


ob1.reboot;
sleep 5;
connect(conn, $ip, root@obtest,,test, $port);

connection conn;


create table t0(c1 int);
insert into t0(c1) values(1);

create table t1(c1 int, c2 int, primary key(c1)) partition by range(c1) (partition p1 values less than (100), partition p2 values less than(MAXVALUE));
insert into t1(c1,c2) values(1,2);
insert into t1(c1,c2) values(100,200);
insert into t1(c1,c2) values(7,9);

alter table t1 reorganize partition p1 into (partition p1_1 values less than(50), partition p1_2 values less than(100));

alter table t1 reorganize partition p1_1 into (partition p1_1_1 values less than (25), partition p1_1_2 values less than (50));

sleep 60;

ob1.restart;
ob1.z1.obs0.check_log_until_success -c "skip replay split finish log";
sleep 60;
connect(conn2, $ip, root@obtest,,test, $port);
sleep 5;
connection conn2;
select * from t1 order by c1;