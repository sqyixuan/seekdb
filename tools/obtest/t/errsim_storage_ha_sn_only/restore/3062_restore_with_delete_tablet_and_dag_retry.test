# owner: haoyuanke.hyk
# owner group: physical_backup
# Testing Case: restore with deleted tablet after backup

ob1=OBI(cluster=1, proxy_num=0);

source include/mini_ob_config.inc;
ob1.z1.obs0.set extra_config = "cache_wash_threshold='1G',_ob_minor_merge_schedule_interval='3s'";

let $backup_ip       = deploy_get_value(ob1.z1.obs0.ip);
let $backup_port     = deploy_get_value(ob1.z1.obs0.mysql_port);
let $backup_oracle_tenant   = backup_oracle_tenant;
let $restore_oracle_tenant = restore_oracle_tenant;
let $log_backup_dest = deploy_get_value(ob1.get_log_backup_dest $backup_oracle_tenant);
let $data_backup_dest = deploy_get_value(ob1.get_data_backup_dest $backup_oracle_tenant);

# stop observer
ob1.force_stop;
ob1.clean_backup_dest;
ob1.reboot;

# set resource unit
ob1.mysql alter resource unit sys_unit_config memory_size='2G';

connect(backup_sys_conn, $backup_ip, root@sys,,oceanbase, $backup_port);
connection backup_sys_conn;
use oceanbase;
source sql/physical_backup/prepare_single_zone_mini_resource.sql;

ob1.mysql alter system set _backup_idle_time = '10s';
ob1.mysql alter system set enable_async_syslog=false;
ob1.mysql alter system set debug_sync_timeout = '100000s';

--echo ===============================================================
--echo ==================     create tenant   ========================
--echo ===============================================================

ob1.create_tenant CREATE TENANT $backup_oracle_tenant RESOURCE_POOL_LIST = ('small_pool'), primary_zone = "z1" set ob_tcp_invited_nodes='%', ob_compatibility_mode='oracle';
let $backup_oracle_tenant_id = query_get_value(select tenant_id from oceanbase.__all_tenant where tenant_name='$backup_oracle_tenant', tenant_id, 1);

--echo ===============================================================
--echo ==================     create table    ========================
--echo ===============================================================

ob_connect(sys_conn_oracle, ob1.z1.obs0, SYS@$backup_oracle_tenant, ,SYS, , USE_OB_CONNECTOR);
set global wait_timeout = 288000;

create user test IDENTIFIED BY "test";
grant all on *.* to test WITH GRANT OPTION;
grant dba to test;
ob_connect(backup_oracle_conn, ob1.z1.obs0,TEST@$backup_oracle_tenant,test,test,,USE_OB_CONNECTOR);
connection backup_oracle_conn;

create table t1(a int, b int, c int, CONSTRAINT "c1" PRIMARY KEY ("A"));
insert into t1(a, b) values(1, 1);

create table t2(a int, b int, c int, CONSTRAINT "c2" PRIMARY KEY ("A"));
insert into t2(a, b) values(1, 1);


--echo ===============================================================
--echo ==================     start archive   ========================
--echo ===============================================================
#set backup dest
ob_connect(sys_conn_oracle, ob1.z1.obs0, SYS@$backup_oracle_tenant, ,SYS, , USE_OB_CONNECTOR);
set global wait_timeout = 288000;
--disable_all_result_log
eval alter system set data_backup_dest='$data_backup_dest';
eval alter system set log_archive_dest='location=$log_backup_dest';
--enable_all_result_log

connection backup_sys_conn;

ob1.mysql alter system archivelog;
ob1.check_until_timeout select status from oceanbase.CDB_OB_ARCHIVELOG where tenant_id=$backup_oracle_tenant_id, DOING, 600;

ob1.mysql alter system set merger_check_interval = '10s';
ob1.mysql alter system major freeze tenant = sys;
ob1.mysql alter system major freeze tenant = all_user;
ob1.mysql alter system major freeze tenant = all_meta;
sleep 10;
ob1.check_until_timeout select (frozen_scn - last_scn) as result from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id=$backup_oracle_tenant_id, 0, 600;

--echo ===============================================================
--echo =============== start backup data   ===========================
--echo ===============================================================

ob1.mysql alter system backup database;
ob1.check_until_timeout select result from CDB_OB_BACKUP_JOB_HISTORY where tenant_id = $backup_oracle_tenant_id and backup_set_id = 1, 0, 600;

--echo ===============================================================
--echo ===============     DROP TABLE     ============================
--echo ===============================================================

ob_connect(backup_oracle_conn, ob1.z1.obs0,TEST@$backup_oracle_tenant,test,test,,USE_OB_CONNECTOR);
connection backup_oracle_conn;
drop table t2;
connection backup_sys_conn;
let $now = `select timestamp_to_scn(current_timestamp(6))`;
ob1.check_until_timeout select checkpoint_scn > $now from CDB_OB_ARCHIVELOG where tenant_id = $backup_oracle_tenant_id, 1, 600;

--echo ===============================================================
--echo ===============   START CLUSTER  ==============================
--echo ===============================================================

ob2=OBI(cluster=1, proxy_num=0);

source include/mini_ob_config.inc;
ob2.z1.obs0.set extra_config = "cache_wash_threshold='1G',_ob_minor_merge_schedule_interval='3s'";

let $restore_ip = deploy_get_value(ob2.z1.obs0.ip);
let $restore_port = deploy_get_value(ob2.z1.obs0.mysql_port);

ob2.force_stop;
ob2.reboot;

let $restore_path = $log_backup_dest,$data_backup_dest;
connect(restore_sys_conn, $restore_ip, root@sys,,oceanbase, $restore_port);
ob2.mysql alter resource unit sys_unit_config memory_size='2G';
connection restore_sys_conn;
source sql/physical_backup/prepare_single_zone_mini_resource.sql;
ob2.mysql alter system set enable_async_syslog=false;


--echo ===============================================================
--echo ================  START RESTORE  ==============================
--echo ===============================================================

#卡住tablet删除日志回放
ob2.mysql alter system set errsim_test_tablet_id = 200002;
sleep 3;
ob2.mysql alter system set_tp tp_name = EN_REPLAY_FATAL_ERROR, error_code = 4023, frequency = 1;
sleep 3;

#卡住tablet恢复
ob2.mysql set ob_global_debug_sync = 'AFTER_RESTORE_TABLET_TASK wait_for signal_restore execute 100000';
sleep 3;

#让tablet restore dag重试
ob2.mysql alter system set_tp tp_name = EN_SET_RESTORE_TASK_FAILED_FOR_RETRY, error_code = 4023, frequency = 1;

#开始恢复
ob2.restore alter system restore $restore_oracle_tenant from '$restore_path' until scn = $now with 'pool_list=small_pool_2&primary_zone=z1';
ob2.check_until_timeout SELECT status FROM __all_tenant WHERE tenant_id = 1001, NORMAL, 200;
ob2.check_until_timeout select restore_status from __all_virtual_ls_meta_table where tenant_id = 1002 and ls_id = 1001, 8, 600;

#卡住tablet删除
ob2.z1.obs0.check_log_until_success -c "fake EN_REPLAY_FATAL_ERROR";

#等200002恢复完成但是task还没结束
ob2.check_until_timeout select count(*) from __all_server_event_history where event like "%leader_tablet_restore_task%" and value1=200002, 1, 300;

#放开tablet删除
ob2.mysql alter system set_tp tp_name = EN_REPLAY_FATAL_ERROR, error_code = 4023, frequency = 0;

#等待tablet gc完成
ob2.check_until_timeout select count(*) from __all_server_event_history where module like 'gc' and event like '%turn_into_empty_shell%' and value1 = 1002 and value3 like "%200002%", 1, 600;

#放开tablet恢复，让tablet dag重试
ob2.mysql set ob_global_debug_sync = 'AFTER_RESTORE_TABLET_TASK clear';
ob2.mysql set ob_global_debug_sync = 'now broadcast signal_restore';

#dag失败
ob2.z1.obs0.check_log_until_success -c "tablet has been deleted.*id:200002";

#恢复成功
ob2.check_until_timeout select count(*) from __all_virtual_ls_meta_table where tenant_id = 1002 and restore_status != 0, 0, 600;
ob2.check_until_timeout select status FROM __all_tenant WHERE tenant_id = 1002, NORMAL, 600;
ob2.check_until_timeout select count(*) FROM __all_restore_job, 0, 600;