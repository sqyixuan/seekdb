# owner: chenqun
# owner group: storage
# description:this case is use for old version replica online 
#
--disable_query_log
ob1=OBI(cluster=2:2:2,proxy_num=1,init_unit_cpu=4);
ob1.reboot;

#create database obtest;
#use obtest;
#

ob1.mysql alter system set merger_check_interval='10s';
ob1.mysql alter system set server_temporary_offline_time = '15s';
ob1.mysql alter system set server_permanent_offline_time='60s';
ob1.mysql alter system set resource_hard_limit = 500;
ob1.mysql alter system set balancer_idle_time='10s';

#在zone1上建立连接
let $ip=deploy_get_value(ob1.z1.obs1.ip);
let $port=deploy_get_value(ob1.z1.obs1.mysql_port);
connect (conn1,$ip,admin@obtest,admin,oceanbase,$port);
connect (conn2,$ip,root@sys,,oceanbase,$port);
connection conn1;
use test;
create table test01 (pk1 int, pk2 int, pk3 int, f1 varchar(4096), f2 varchar(4096), primary key(pk1,pk2,pk3));
let $cnt =1;
while ($cnt < 10)
{
	eval insert into test01 values($cnt, $cnt, $cnt, 'abc', 'def');
	inc $cnt;
}

ob1.mysql alter system major freeze;
ob1.check_version 2;


let $tenant_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name='obtest', tenant_id, 1);
let $src = deploy_get_value(ob1.get_follower obtest:test:test01:0,2);
let $src_ip = deploy_get_value($src.ip);
let $src_port=deploy_get_value($src.port);
let $src_zone = deploy_get_value(ob1.select select zone from oceanbase.__all_server where svr_ip='$src_ip' and svr_port='$src_port', zone, 1);
let $dst_host = deploy_get_value(ob1.select select concat(svr_ip, ':', svr_port) host from oceanbase.__all_server where zone='$src_zone' and svr_port!='$src_port', host, 1);
let $dst = deploy_get_value(ob1.get_obs_by_addr $dst_host);
let $dst_ip = deploy_get_value($dst.ip);
let $dst_port = deploy_get_value($dst.port);
let $part_cnt = deploy_get_value(ob1.select select count(*) ct from oceanbase.__all_virtual_meta_table where tenant_id='$tenant_id' and svr_ip='$src_ip' and svr_port = '$src_port' and data_version=2, ct, 1);
$src.stop;
sleep 30;
# wait until add normal replica on $dst;
let $table_id=deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where table_name='test01' and tenant_id=$tenant_id, table_id, 1);
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_meta_table where tenant_id='$tenant_id' and svr_ip='$dst_ip' and svr_port='$dst_port' and data_version=2, $part_cnt, 300;
ob1.check_until_timeout select with_partition from oceanbase.__all_server where svr_ip='$src_ip' and svr_port='$src_port', 0, 50;
sleep 10;

while ($cnt < 20)
{
	eval insert into test01 values($cnt, $cnt, $cnt, 'abc', 'def');
	inc $cnt;
}

ob1.mysql alter system major freeze;

while ($cnt < 30)
{
	eval insert into test01 values($cnt, $cnt, $cnt, 'abc', 'def');
	inc $cnt;
}

ob1.check_version 3;


# src is still on version 2, cause not in member list, and cannot be merged.
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_meta_table where tenant_id=$tenant_id and table_id=$table_id and data_version=3 and svr_ip='$dst_ip' and svr_port='$dst_port', 1, 200;


$src.start;
ob1.check_until_timeout select status from oceanbase.__all_server where svr_ip='$src_ip' and svr_port='$src_port', active, 50;
ob1.check_until_timeout select count(*) from oceanbase.__all_unit where migrate_from_svr_ip!='', 0, 500;
ob1.mysql alter system set enable_rebalance = 'false';
sleep 10;
ob1.check_until_timeout select count(*) from oceanbase.__all_server where start_service_time = 0, 0, 60; 
ob1.mysql alter resource pool obtestpool unit_num 2;
let $dst = deploy_get_value(ob1.get_follower obtest:test:test01:0,1);
$dst.migrate_to $src,obtest:test:test01;

# src should be version 3 now and in member list;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_meta_table where table_id=$table_id and svr_ip='$src_ip' and svr_port='$src_port' and data_version=3, 1, 500;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_meta_table a ,oceanbase.__all_virtual_meta_table b where a.tenant_id=$tenant_id and a.table_id=$table_id and b.table_id=$table_id  and a.member_list=b.member_list and a.role=1 and b.role=2 and b.svr_ip='$src_ip', 1, 50;

