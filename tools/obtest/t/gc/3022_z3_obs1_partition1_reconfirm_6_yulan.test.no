##
# owner:yulan.way
# owner group:transaction
# description:
# 测试功能点：多机单partition，复杂场景，未决日志处理
# 用例描述：5)	阻塞A和C之间的网络，写入数据，停掉B，强制切换C（C会收到maxlogID,缺少的日志向B来请求）
##
ob1=OBI(cluster=2:2:2,init_unit_cpu=12,init_unit_num=1);
ob1.reboot;
sleep 5;

ob1.create_client;

##数据准备
create database obtest;
use obtest;
create table t1(pk int primary key, c1 int, c2 varchar(20));

--disable_query_log
let $cnt=10;
while($cnt>0)
{
	eval insert into t1 values($cnt,$cnt,'c$cnt');
	dec $cnt;
}

let $leader=deploy_get_value(ob1.get_leader obtest:obtest:t1);
let $follower_1=deploy_get_value(ob1.get_follower obtest:obtest:t1,1);
let $follower_2=deploy_get_value(ob1.get_follower obtest:obtest:t1,2);
## 阻塞A和C之间的网络
$leader.block_net $follower_2;

##写入数据
--disable_query_log
let $cnt=1000;
while($cnt>10)
{
	eval insert into t1 values($cnt,$cnt,'c$cnt');
	dec $cnt;
}

##B宕机
$follower_1.force_stop;

##恢复A和C之间的网络
$leader.clean_net $follower_2;

sleep 10;
##强制切换C为主
$follower_2.switch_partition obtest:obtest:t1;

##数据验证
select * from t1;















































