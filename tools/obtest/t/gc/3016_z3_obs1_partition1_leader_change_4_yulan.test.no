##
# owner:yulan.way
# owner group:transaction
# description:
# 测试功能点：多机单partition，复杂场景，leader变换相关
# 用例描述：B宕机，切换C为leader后，A下线，B上线，切换leader后A上线
##
ob1=OBI(cluster=2:2:2,init_unit_cpu=11,init_unit_num=2);
ob1.reboot;
sleep 5;

let $ip=deploy_get_value(ob1.z1.obs0.ip);
let $port=deploy_get_value(ob1.z1.obs0.mysql_port);
connect (conn1,$ip,root@obtest,,test,$port);

##数据准备
ob1.mysql alter system set enable_auto_leader_switch=false;

connection conn1
create database obtest;
use obtest;
create table t1(pk int primary key, c1 int, c2 varchar(20));

--disable_query_log
let $cnt=50;
while($cnt>0)
{
	eval insert into t1 values($cnt,$cnt,'c$cnt');
	dec $cnt;
}

let $leader=deploy_get_value(ob1.get_leader obtest:obtest:t1);
let $follower_1=deploy_get_value(ob1.get_follower obtest:obtest:t1,1);
let $follower_2=deploy_get_value(ob1.get_follower obtest:obtest:t1,2);

##follower B宕机
$follower_1.force_stop;

##更新数据
--disable_query_log
let $cnt=10;
while($cnt>0)
{
	eval update t1 set c2='c$cnt$cnt' where pk=$cnt;
	dec $cnt;
}

let $cnt=20;
while($cnt>10)
{
	eval delete from t1 where pk=$cnt;
	dec $cnt;
}

let $cnt=60;
while($cnt>50)
{
	eval insert into t1 values($cnt,$cnt,'c$cnt');
	dec $cnt;
}

sleep 10;

##切换C为主
$follower_2.switch_partition obtest:obtest:t1;

sleep 10;

##更新数据
let $cnt=70;
while($cnt>60)
{
	eval insert into t1 values($cnt,$cnt,'c$cnt');
	dec $cnt;
}
##旧leader A下线
$leader.force_stop;

##B上线
$follower_1.nstart;
ob1.check_until_timeout select count(*) > 0 from oceanbase.__all_virtual_partition_info where svr_ip = $follower_1, 1, 120;

##选出的新主
let $leader_new=deploy_get_value(ob1.get_leader obtest:obtest:t1);
let $follower_new=deploy_get_value(ob1.get_follower obtest:obtest:t1);

##切换一次主备
$follower_new.switch_partition obtest:obtest:t1;

##更新数据
let $cnt=80;
while($cnt>70)
{
	eval insert into t1 values($cnt,$cnt,'c$cnt');
	dec $cnt;
}

select * from t1;

##A上线
$leader.nstart;
ob1.check_until_timeout select count(*) > 0 from oceanbase.__all_virtual_partition_info where svr_ip = $leader, 1, 120;

select * from t1;

































