##
# owner:yulan.way
# owner group:transaction
# description:
# 测试功能点：多机单partition，复杂场景，未决日志处理
# 用例描述：1)	A写磁盘成功但B和C没有成功（宕机），网络恢复，A被再次选为主后，会对这条日志进行reconfirm，会写入成功 
##
ob1=OBI(cluster=2:2:2,init_unit_cpu=12,init_unit_num=1);
ob1.reboot;
sleep 15;

ob1.create_client;

##数据准备
ob1.mysql alter system set enable_auto_leader_switch=false;
create database obtest;
use obtest;
create table t1(pk int primary key, c1 int, c2 varchar(20));

--disable_query_log
let $cnt=10;
while($cnt>0)
{
	eval insert into t1 values($cnt,$cnt,'c$cnt');
	dec $cnt;
}

let $leader=deploy_get_value(ob1.get_leader obtest:obtest:t1);
let $follower_1=deploy_get_value(ob1.get_follower obtest:obtest:t1,1);
let $follower_2=deploy_get_value(ob1.get_follower obtest:obtest:t1,2);
## 停掉两台
$follower_1.force_stop;
$follower_2.force_stop;

##写入两台数据
--error 4012
update t1 set c2='way' where pk=5;

##停掉主A
$leader.force_stop;

##重新启动两个备
$follower_1.nstart;
$follower_2.nstart;
sleep 60;

let $cnt=20;
while($cnt>10)
{
	eval insert into t1 values($cnt,$cnt,'c$cnt');
	dec $cnt;
}

select * from t1;

##重启旧主A
$leader.nstart;

sleep 10;

$leader.switch_partition obtest:obtest:t1;

sleep 3;

select * from t1;



































