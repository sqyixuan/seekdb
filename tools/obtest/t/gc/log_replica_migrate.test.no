##############################
# owner: feizhi.cfz
# owner group: storage
# 功能点：测试日志副本的迁移操作

--disable_query_log
ob1=OBI(cluster=2:2:2,proxy_num=1,init_unit_cpu=2);
ob1.reboot;

ob1.mysql create resource pool rp1 unit = 'sys_unit_config', unit_num = 2, zone_list = ('z1', 'z2', 'z3');
ob1.mysql create tenant tt1 replica_num 3, primary_zone 'z2', resource_pool_list ('rp1'), locality="L@z1,F@z2,F@z3" set ob_tcp_invited_nodes='%';

ob1.mysql alter system set merger_check_interval='10s';
ob1.mysql alter system set enable_rebalance = 'false';
ob1.mysql alter system set enable_rereplication = 'false';
ob1.mysql alter system set resource_hard_limit=500;

#在zone1上建立连接
let $ip=deploy_get_value(ob1.z1.obs0.ip);
let $port=deploy_get_value(ob1.z1.obs0.mysql_port);
connect (conn1,$ip,admin@obtest,admin,oceanbase,$port);
connect (conn2,$ip,root@sys,,oceanbase,$port);
connection conn1;
use test;

# create partition
create table test01 (pk1 int, pk2 int, pk3 int, f1 varchar(1024), f2 varchar(4096), primary key(pk1,pk2,pk3));
let $pkey=deploy_get_value(ob1.select select concat(tenant_id, ':', table_id, ':0') as pkey from oceanbase.__all_virtual_table where table_name='test01', pkey, 1);

# insert data
let $cnt =1;
while ($cnt < 10)
{
        eval insert into test01 values($cnt, $cnt, $cnt, 'abc', 'def');
        inc $cnt;
}
# 日志副本合并有问题，这里先注释掉
# major freeze
# ob1.mysql alter system major freeze;
# ob1.check_version 2;

let $src = deploy_get_value(ob1.get_follower tt1:test:test01:0,1);
let $dst = deploy_get_value(ob1.get_another_obs_in_same_zone $src);
$src.migrate_to $dst,tt1:test:test01;
ob1.wait_migrate_success $src,$dst,$pkey,60;
