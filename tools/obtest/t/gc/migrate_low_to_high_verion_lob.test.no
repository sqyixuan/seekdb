# owner:hanhui
# description: this case is use for migrate low version to high version
#

--disable_query_log
ob1=OBI(cluster=2:2:2,proxy_num=0,init_unit_cpu=2, init_unit_num=2);
ob1.reboot;

let $ip=deploy_get_value(ob1.z1.obs0.ip);
let $port=deploy_get_value(ob1.z1.obs0.mysql_port);
connect (conn1,$ip,admin@obtest,admin,oceanbase,$port);
connect (conn2,$ip,root@sys,,oceanbase,$port);
connection conn1;

#设置灰度切主的时间为0, 关闭自动切主，关闭自动balance
set global max_allowed_packet=50000000;
set global ob_query_timeout=100000000;
set global ob_trx_timeout=100000000;
ob1.mysql alter system set resource_hard_limit = 800;
ob1.mysql alter system set merger_switch_leader_duration_time=0;
ob1.mysql alter system set enable_auto_leader_switch = false;
ob1.mysql alter system set enable_rereplication = false;
ob1.mysql alter system set enable_rebalance = false;

use test;
create table test01 (pk1 int, pk2 int, pk3 int, f1 text, f2 mediumtext, f3 longblob,  primary key(pk1,pk2,pk3));
let $cnt =1;
while ($cnt < 11)
{
	eval insert into test01 values($cnt, $cnt, $cnt, repeat('a', 32000), repeat('b', 10000000), repeat('c', 20000000));
	inc $cnt;
}

ob1.mysql alter system major freeze;
ob1.check_version 2;

let $tenant_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name='obtest', tenant_id, 1);
let $table_id = deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where table_name='test01', table_id, 1);
let $src_host = deploy_get_value(ob1.select select concat(svr_ip, ':', svr_port) host from oceanbase.__all_virtual_meta_table where zone='z2' and table_id=$table_id, host, 1);
let $src = deploy_get_value(ob1.get_obs_by_addr $src_host);
let $src_ip = deploy_get_value($src.ip);
let $src_port = deploy_get_value($src.port);
let $dst_host = deploy_get_value(ob1.select select concat(svr_ip, ':', svr_port) host from oceanbase.__all_unit where zone='z2' and svr_ip != '$src_ip' and resource_pool_id = 1001, host, 1);
let $dst = deploy_get_value(ob1.get_obs_by_addr $dst_host);
let $dst_ip = deploy_get_value($dst.ip);
let $dst_port = deploy_get_value($dst.port);

# lob基本信息检查
let $lob_block_info = deploy_get_value(ob1.select select concat('lob_macro_block_count: ', lob_macro_block_count, ', ' , 'lob_use_old_macro_block_count: ', lob_use_old_macro_block_count) lob_block_info from __all_virtual_partition_sstable_image_info where major_version=2 and svr_ip = '$src_ip' and svr_port = '$src_port', lob_block_info, 1);
let $major_block_cnt = deploy_get_value(ob1.select select count(1) major_block_count from __all_virtual_partition_sstable_macro_info where major_table_id=$table_id and svr_ip = '$src_ip' and svr_port = '$src_port' and macro_block_type = 'lob_block' and store_type= 1 and macro_data_version=2, major_block_count, 1);
let $minor_block_cnt = deploy_get_value(ob1.select select count(1) minor_block_count from __all_virtual_partition_sstable_macro_info where major_table_id=$table_id and svr_ip = '$src_ip' and svr_port = '$src_port' and macro_block_type = 'lob_block' and store_type= 4 and hex(macro_data_version)%10=3, minor_block_count, 1);
echo "src_lob_info>>  ", $lob_block_info;
echo "src_lob_count>> ", 'major_block_count: ', $major_block_cnt, ', minor_block_count: ', $minor_block_cnt;

# another merge process
let $cnt =1;
while ($cnt < 6)
{
  eval update test01 set f2 = repeat('B', 1000000) where pk1 = $cnt and pk2 = $cnt and pk3= $cnt;
	inc $cnt;
}
while ($cnt < 11)
{
  eval delete from test01 where pk1 = $cnt and pk2 = $cnt and pk3= $cnt;
	inc $cnt;
}

ob1.mysql alter system major freeze;
ob1.check_version 3;

# lob基本信息检查
let $lob_block_info = deploy_get_value(ob1.select select concat('lob_macro_block_count: ', lob_macro_block_count, ', ' , 'lob_use_old_macro_block_count: ', lob_use_old_macro_block_count) lob_block_info from __all_virtual_partition_sstable_image_info where major_version=3 and svr_ip = '$src_ip' and svr_port = '$src_port', lob_block_info, 1);
let $major_block_cnt = deploy_get_value(ob1.select select count(1) major_block_count from __all_virtual_partition_sstable_macro_info where major_table_id=$table_id and svr_ip = '$src_ip' and svr_port = '$src_port' and macro_block_type = 'lob_block' and store_type= 1 and macro_data_version=3, major_block_count, 1);
let $minor_block_cnt = deploy_get_value(ob1.select select count(1) minor_block_count from __all_virtual_partition_sstable_macro_info where major_table_id=$table_id and svr_ip = '$src_ip' and svr_port = '$src_port' and macro_block_type = 'lob_block' and store_type= 4 and hex(macro_data_version)%10=4, minor_block_count, 1);
echo "src_lob_info>>  ", $lob_block_info;
echo "src_lob_count>> ", 'major_block_count: ', $major_block_cnt, ', minor_block_count: ', $minor_block_cnt;

# another merge process
let $cnt =1;
while ($cnt < 6)
{
  eval update test01 set f2 = repeat('B', 1000000) where pk1 = $cnt and pk2 = $cnt and pk3= $cnt;
	inc $cnt;
}
let $cnt =16;
while ($cnt < 21)
{
	eval insert into test01 values($cnt, $cnt, $cnt, repeat('x', 32000), repeat('y', 10000000), repeat('z', 20000000));
	inc $cnt;
}

#关闭z1的合并,使z1的版本低于z2、z3
ob1.mysql alter system suspend merge zone='z1';
ob1.mysql alter system major freeze;

let $wait = 180;
while ($wait > 1)
{
  dec $wait;
  let $z2_merge_version = deploy_get_value(ob1.select select value from __all_zone where zone='z2' and name='all_merged_version', value, 1);
  if ($z2_merge_version > 3)
  {
    let $wait = 1;
  }
  sleep 1;
}

let $wait = 60;
while ($wait > 1)
{
  dec $wait;
  let $z3_merge_version = deploy_get_value(ob1.select select value from __all_zone where zone='z3' and name='all_merged_version', value, 1);
  if ($z3_merge_version > 3)
  {
    let $wait = 1;
  }
  sleep 1;
}

sleep 5;

# lob基本信息检查
let $lob_block_info = deploy_get_value(ob1.select select concat('lob_macro_block_count: ', lob_macro_block_count, ', ' , 'lob_use_old_macro_block_count: ', lob_use_old_macro_block_count) lob_block_info from __all_virtual_partition_sstable_image_info where major_version=4 and svr_ip = '$src_ip' and svr_port = '$src_port', lob_block_info, 1);
let $major_block_cnt = deploy_get_value(ob1.select select count(1) major_block_count from __all_virtual_partition_sstable_macro_info where major_table_id=$table_id and svr_ip = '$src_ip' and svr_port = '$src_port' and macro_block_type = 'lob_block' and store_type= 1 and macro_data_version=4, major_block_count, 1);
let $minor_block_cnt = deploy_get_value(ob1.select select count(1) minor_block_count from __all_virtual_partition_sstable_macro_info where major_table_id=$table_id and svr_ip = '$src_ip' and svr_port = '$src_port' and macro_block_type = 'lob_block' and store_type= 4 and hex(macro_data_version)%10=5, minor_block_count, 1);
echo "src_lob_info>>  ", $lob_block_info;
echo "src_lob_count>> ", 'major_block_count: ', $major_block_cnt, ', minor_block_count: ', $minor_block_cnt;


#同一个zone的迁移
$src.migrate_to $dst,obtest:test:test01;

ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_meta_table where tenant_id=$tenant_id and table_id=$table_id and role=1 and member_list like '%$dst_ip:$dst_port%', 1, 20;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_meta_table a, oceanbase.__all_virtual_meta_table b where a.tenant_id=$tenant_id and a.table_id=$table_id and b.table_id=$table_id and a.member_list=b.member_list and a.role=1 and b.role=2 and b.svr_ip='$dst_ip' and b.svr_port='$dst_port', 1, 20;

# lob基本信息检查
let $lob_block_info = deploy_get_value(ob1.select select concat('lob_macro_block_count: ', lob_macro_block_count, ', ' , 'lob_use_old_macro_block_count: ', lob_use_old_macro_block_count) lob_block_info from __all_virtual_partition_sstable_image_info where major_version=4 and svr_ip = '$dst_ip' and svr_port = '$dst_port', lob_block_info, 1);
let $major_block_cnt = deploy_get_value(ob1.select select count(1) major_block_count from __all_virtual_partition_sstable_macro_info where major_table_id=$table_id and svr_ip = '$dst_ip' and svr_port = '$dst_port' and macro_block_type = 'lob_block' and store_type= 1 and macro_data_version=4, major_block_count, 1);
let $minor_block_cnt = deploy_get_value(ob1.select select count(1) minor_block_count from __all_virtual_partition_sstable_macro_info where major_table_id=$table_id and svr_ip = '$dst_ip' and svr_port = '$dst_port' and macro_block_type = 'lob_block' and store_type= 4 and hex(macro_data_version)%10=5, minor_block_count, 1);
echo "dst_lob_info>>  ", $lob_block_info;
echo "dst_lob_count>> ", 'major_block_count: ', $major_block_cnt, ', minor_block_count: ', $minor_block_cnt;

let $src_host_another = deploy_get_value(ob1.select select concat(svr_ip, ':', svr_port) host from oceanbase.__all_virtual_meta_table where zone='z1' and table_id=$table_id, host, 1);
let $src_another = deploy_get_value(ob1.get_obs_by_addr $src_host_another);

#从z1的低版本，复制到z2中有高版本静态数据的server
ob1.mysql alter system drop replica partition_id='0%1@$table_id' server='$dst_host';
sleep 5;
ob1.mysql alter system copy replica partition_id '0%1@$table_id' source='$src_host_another' destination='$src_host';
sleep 10;
connection conn1;
let $ret = deploy_get_value(ob1.select select value4 from __all_rootservice_event_history where module='balancer' and event = 'finish_add_replica' and value1 like "%$table_id%" and value3 like '%$src_ip%', value4, 1);
echo $ret;

# lob基本信息检查
let $lob_block_info = deploy_get_value(ob1.select select concat('lob_macro_block_count: ', lob_macro_block_count, ', ' , 'lob_use_old_macro_block_count: ', lob_use_old_macro_block_count) lob_block_info from __all_virtual_partition_sstable_image_info where major_version=4 and svr_ip = '$src_ip' and svr_port = '$src_port', lob_block_info, 1);
let $major_block_cnt = deploy_get_value(ob1.select select count(1) major_block_count from __all_virtual_partition_sstable_macro_info where major_table_id=$table_id and svr_ip = '$src_ip' and svr_port = '$src_port' and macro_block_type = 'lob_block' and store_type= 1 and macro_data_version=4, major_block_count, 1);
let $minor_block_cnt = deploy_get_value(ob1.select select count(1) minor_block_count from __all_virtual_partition_sstable_macro_info where major_table_id=$table_id and svr_ip = '$src_ip' and svr_port = '$src_port' and macro_block_type = 'lob_block' and store_type= 4 and hex(macro_data_version)%10=5, minor_block_count, 1);
echo "src_lob_info>>  ", $lob_block_info;
echo "src_lob_count>> ", 'major_block_count: ', $major_block_cnt, ', minor_block_count: ', $minor_block_cnt;
