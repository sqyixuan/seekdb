##
# owner:yulan.way
# owner group:transaction
# description:
# 测试点：多partition，阻塞scheduler和协调者之间的网络（事务回滚）
# 测试场景：开启事务，执行SQL, 阻塞网络，commit/rollback
# 问题：对于已经返回了-6224错误，再发commit请求是否可以直接返回事务被回滚呢:由于scheduler和协调者之间网络不通，所以scheduler向协调者发rollback时发不出去。协调者就只能等超时了
##

ob1=OBI(cluster=2:2:2,proxy_num=0,init_unit_cpu=11,init_unit_num=1);
ob1.reboot;
sleep 5;

ob1.mysql alter system set enable_auto_leader_switch=false;
#ob1.mysql set global ob_trx_timeout=20000000;

let $scheduler_ip=deploy_get_value(ob1.z1.obs1.ip);
let $scheduler_port=deploy_get_value(ob1.z1.obs1.mysql_port);
connect (conn1,$scheduler_ip,admin@obtest,admin,oceanbase,$scheduler_port);

connection conn1;
create database obtest;
use obtest;
create table t1(pk int primary key, c1 int, c2 varchar(20)) partition by hash(pk % 2) partitions 2;

sleep 10;

ob1.z2.obs1.switch_partition obtest:obtest:t1:1;
ob1.z3.obs1.switch_partition obtest:obtest:t1:0;
sleep 3;

let $scheduler=ob1.z1.obs1;
let $participant=deploy_get_value(ob1.get_leader obtest:obtest:t1:0);
let $coordinator=deploy_get_value(ob1.get_leader obtest:obtest:t1:1);

set ob_trx_timeout=20000000;

##commit
set autocommit=0;
insert into t1 values(1,1,'a');
insert into t1 values(2,2,'b');

##
$scheduler.block_net $coordinator;

--error 4012,6002
update t1 set c2='aa' where pk=1;

--error 6002
update t1 set c2='aa' where pk=2;

--error 6002
commit;

rollback;

$scheduler.clean_net $coordinator;
commit;
set autocommit=1;
sleep 2;
select /*+ read_consistency(weak)*/ * from t1;

sleep 15;
select /*+ read_consistency(weak)*/ * from t1;

##rollback
set autocommit=0;
insert into t1 values(1,1,'a');
insert into t1 values(2,2,'b');

##
$scheduler.block_net $coordinator;

--error 4012,6002
update t1 set c2='aa' where pk=1;

--error 6002
update t1 set c2='aa' where pk=2;

rollback;

commit;

$scheduler.clean_net $coordinator;
commit;
set autocommit=1;
sleep 2;
select /*+ read_consistency(weak)*/* from t1;

sleep 15;
select /*+ read_consistency(weak)*/* from t1;
