##
# owner:yulan.way
# owner group:transaction
# description:
# 测试功能点：多机单partition，复杂场景，未决日志处理
##
ob1=OBI(cluster=2:2:2,init_unit_cpu=12,init_unit_num=1);
ob1.reboot;
sleep 15;

ob1.create_client;

##数据准备
create database obtest;
use obtest;
create table t1(pk int primary key, c1 int, c2 varchar(20));

--disable_query_log
let $cnt=10;
while($cnt>0)
{
	eval insert into t1 values($cnt,$cnt,'c$cnt');
	dec $cnt;
}

let $leader=deploy_get_value(ob1.get_leader obtest:obtest:t1);
let $follower_1=deploy_get_value(ob1.get_follower obtest:obtest:t1,1);
let $follower_2=deploy_get_value(ob1.get_follower obtest:obtest:t1,2);

## 停掉一台备c
$follower_2.force_stop;

--disable_query_log
let $cnt=20;
while($cnt>10)
{
	eval insert into t1 values($cnt,$cnt,'c$cnt');
	dec $cnt;
}

select * from t1;

##阻塞主A和备B之间的网络
$leader.block_net $follower_1;

##写入数据
--error 4012
update t1 set c2='way' where pk=5;

##主A宕机
$leader.force_stop;

##恢复A和B之间的网络
$leader.clean_net $follower_1;

##备C重启
$follower_2.nstart;

sleep 15;

##在B和C之间选出新主
let $leader_new=deploy_get_value(ob1.get_leader obtest:obtest:t1);
let $follower_new=deploy_get_value(ob1.get_follower obtest:obtest:t1);

##A上线
$leader.nstart;

sleep 15;

##验证数据
select * from t1;













































