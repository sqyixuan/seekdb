##
# owner:yulan.way
# owner group:transaction
# description:
# 测试功能点：多机单partition，复杂场景，未决日志处理
# 用例描述：1)	A写磁盘成功但B和C没有成功（阻塞网络/宕机），网络恢复，A被再次选为主后，会对这条日志进行reconfirm，会写入成功 
##
ob1=OBI(cluster=2:2:2,init_unit_cpu=2,init_unit_num=1);
ob1.proxy0.set extra_config=syslog_level=debug;
ob1.reboot;
sleep 5;

ob1.create_client;

#set ob_tx_timeout=5000000;

##数据准备
create database obtest;
use obtest;
create table t1(pk int primary key, c1 int, c2 varchar(20));

--disable_query_log
let $cnt=10;
while($cnt>0)
{
	eval insert into t1 values($cnt,$cnt,'c$cnt');
	dec $cnt;
}

select * from t1;

let $leader=deploy_get_value(ob1.get_leader obtest:obtest:t1);
let $follower_1=deploy_get_value(ob1.get_follower obtest:obtest:t1,1);
let $follower_2=deploy_get_value(ob1.get_follower obtest:obtest:t1,2);
## 停掉两台备
$follower_1.force_stop;
$follower_2.force_stop;

##写入两台数据
--error 4012
update t1 set c2='way' where pk=5;

##重启后重新选主
$follower_1.nstart;
$follower_2.nstart;
sleep 20;

select * from t1 where pk!=5;

##update语句能否成功这个状态时不确定的，如果原来的leader依然被选为leader那就会更新成功，否则分两种情况：
#假设follower_1被当选为leader，那么如果在投票过程中，在follower_2问那条未确认日志的内容时如果leader先应答，那么这条日志会被重新投票写下去，如果follower_2先应答则不会写下去
#因此现在这种判断方法仍然会有不稳定的结果，暂时没有想到好的方法，暂时先记下来
--disable_query_log
let $new_leader=deploy_get_value(ob1.get_leader obtest:obtest:t1);
if($new_leader == $leader)
{
	select c2='way' as value from t1 where pk=5;
}

if($new_leader != $leader)
{
	select c2='c5' as value from t1 where pk=5;
}






























