# owner: weixue.cx
# group: storage
# test partition split concurrent with major merge

--disable_query_log
ob1=OBI(cluster=1,proxy_num=0,init_unit_cpu=1, init_unit_num=1);
ob1.reboot;

ob1.mysql alter system set debug_sync_timeout = '100000s';

let $ip=deploy_get_value(ob1.z1.obs0.ip);
let $port=deploy_get_value(ob1.z1.obs0.mysql_port);
connect (conn1,$ip,admin@obtest,admin,oceanbase,$port);
connect (conn2,$ip,root@sys,,oceanbase,$port);
connection conn1;

use test;
create table test_table (c1 int primary key, c2 int);
let $cnt=1;
while ($cnt < 10)
{
  eval insert into test_table values($cnt, $cnt);
  inc $cnt;
}
ob1.mysql alter system major freeze;
ob1.check_version 2;

while ($cnt < 20)
{
  eval insert into test_table values($cnt, $cnt);
  inc $cnt;
}

ob1.mysql set ob_global_debug_sync = 'BEFORE_SCHEDULE_ALL_PARTITIONS wait_for begin';

ob1.mysql alter system major freeze;

sleep 35;
insert into test_table values (30, 30);
insert into test_table values (31, 31);

alter table test_table modify partition by range(c1) (partition p0 values less than (4), partition p1 values less than MAXVALUE);

let $table_id=deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where table_name='test_table', table_id, 1);

ob1.check_until_timeout select count(1) from oceanbase.__all_virtual_table_mgr where table_id=$table_id and table_type=0 and partition_id=0, 0, 180;

ob1.mysql set ob_global_debug_sync = 'now signal begin';

ob1.check_version 3;

--enable_query_log
select * from test_table order by c1;

