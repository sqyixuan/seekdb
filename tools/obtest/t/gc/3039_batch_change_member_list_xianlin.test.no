##
# owner: xianlin.lh
# owner group: transaction
# description:
# 测试批量成员变更的检查逻辑
##
--disable_query_log
ob1=OBI(cluster=2:2:2,proxy_num=0,init_unit_cpu=2, init_unit_num=1);
ob1.reboot;

ob1.mysql alter system set enable_auto_leader_switch = false;
ob1.mysql alter system set enable_rereplication = true;
ob1.mysql alter system set enable_rebalance = true;
ob1.mysql alter system set sys_bkgd_migration_change_member_list_timeout='0s';
ob1.mysql alter system set balancer_idle_time='10s';
let $ip = deploy_get_value(ob1.z1.obs0.ip);
let $port = deploy_get_value(ob1.z1.obs0.mysql_port);

ob1.create_client tenant=obtest,user=root,passwd=,database=test;

create tablegroup test_group primary_zone = 'z3';
let $table_count = 100;
let $i = 0;

while ($i < $table_count)
{
  eval create table test$i(c1 int, c2 int, c3 varchar(4096), primary key(c1)) tablegroup='test_group' primary_zone='z3';
  inc $i;
}

sleep 10;
ob1.mysql alter system major freeze;
ob1.check_version 2;

let $unit_id = deploy_get_value(ob1.select select unit_id from __all_resource_pool a, __all_unit b, __all_tenant c where c.tenant_id=a.tenant_id and a.resource_pool_id=b.resource_pool_id and c.tenant_name = 'obtest' and zone='z1', unit_id, 1);
let $src_host = deploy_get_value(ob1.select select concat(svr_ip,':', svr_port) host from __all_resource_pool a, __all_unit b, __all_tenant c where c.tenant_id=a.tenant_id and a.resource_pool_id=b.resource_pool_id and c.tenant_name = 'obtest' and zone='z1', host, 1);
let $src = deploy_get_value(ob1.get_obs_by_addr $src_host);
let $src_ip = deploy_get_value(ob1.select select svr_ip from __all_resource_pool a, __all_unit b, __all_tenant c where c.tenant_id=a.tenant_id and a.resource_pool_id=b.resource_pool_id and c.tenant_name = 'obtest' and zone='z1', svr_ip, 1);
let $src_port = deploy_get_value(ob1.select select svr_port from __all_resource_pool a, __all_unit b, __all_tenant c where c.tenant_id=a.tenant_id and a.resource_pool_id=b.resource_pool_id and c.tenant_name = 'obtest' and zone='z1', svr_port, 1);

let $tenant_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name='obtest', tenant_id, 1);
let $dst_host = deploy_get_value(ob1.select select concat(svr_ip, ':', svr_port) host from oceanbase.__all_server where zone='z1' and (svr_ip != '$src_ip' or svr_port != '$src_port'), host, 1);
let $dst = deploy_get_value(ob1.get_obs_by_addr $dst_host);
let $dst_ip = deploy_get_value($dst.ip);
let $dst_port = deploy_get_value($dst.port);

ob1.z3.obs0.block_net ob1.z2.obs0;
ob1.z3.obs0.block_net ob1.z2.obs1;
ob1.z3.obs1.block_net ob1.z2.obs0;
ob1.z3.obs1.block_net ob1.z2.obs1;

sleep 10;

ob1.mysql alter system migrate unit $unit_id destination = "$dst_host";

sleep 30;

#ob1.mysql select count(*) from __all_virtual_meta_table where unit_id=1002 and svr_ip='$dst_ip' and svr_port=$dst_port;
ob1.check_until_timeout select count(*) from __all_virtual_meta_table where unit_id=1002 and svr_ip='$src_ip' and svr_port=$src_port,0,180;
# include dummy table
#let $expect_table_count = math($table_count + 4);
#ob1.check_until_timeout select count(*) from oceanbase.__all_rootservice_event_history where module='balancer' and event = 'finish_migrate_replica' and value2 like '%$src_ip%' and value3 like '%$dst_ip%' and value5 like '%$src_ip%', $expect_table_count, 30;
#ob1.mysql_p select value4, count(*) from oceanbase.__all_rootservice_event_history where module='balancer' and event = 'finish_migrate_replica' and value2 like '%$src_ip%' and value3 like '%$dst_ip%' and value5 like '%$src_ip%' group by value4 order by value4;

ob1.z3.obs0.clean_net ob1.z2.obs0;
ob1.z3.obs0.clean_net ob1.z2.obs1;
ob1.z3.obs1.clean_net ob1.z2.obs0;
ob1.z3.obs1.clean_net ob1.z2.obs1;
