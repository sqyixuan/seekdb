##
# owner:yulan.way
# owner group:transaction
# description:
# 测试功能点：多机单partition，复杂场景，leader变换相关
# 用例描述：1.leader A 宕机 2.选出新主B后A再上线 3. B下线
##
ob1=OBI(cluster=2:2:2,init_unit_cpu=11,init_unit_num=1);
ob1.reboot;
sleep 5;

let $ip=deploy_get_value(ob1.z1.obs0.ip);
let $port=deploy_get_value(ob1.z1.obs0.mysql_port);
connect (conn1,$ip,root@obtest,,test,$port);

set ob_trx_timeout=15000000;

##数据准备
connection conn1
create database obtest;
use obtest;
create table t1(pk int primary key, c1 int, c2 varchar(20));

--disable_query_log
let $cnt=50;
while($cnt>0)
{
	eval insert into t1 values($cnt,$cnt,'c$cnt');
	dec $cnt;
}

##leader A宕机
let $leader=deploy_get_value(ob1.get_leader obtest:obtest:t1);
$leader.force_stop;

##等待重新选主
sleep 30;

--error 4012,0
replace into t1 values(50,50,'c50');

##更新数据
--disable_query_log
let $cnt=10;
while($cnt>0)
{
	eval update t1 set c2='c$cnt$cnt' where pk=$cnt;
	dec $cnt;
}

let $cnt=20;
while($cnt>10)
{
	eval delete from t1 where pk=$cnt;
	dec $cnt;
}

let $cnt=60;
while($cnt>50)
{
	eval insert into t1 values($cnt,$cnt,'c$cnt');
	dec $cnt;
}

##选出新主后A上线
$leader.nstart;

sleep 30;

##更新数据
--disable_query_log
let $cnt=30;
while($cnt>20)
{
	eval update t1 set c2='c$cnt$cnt' where pk=$cnt;
	dec $cnt;
}

let $cnt=40;
while($cnt>30)
{
	eval delete from t1 where pk=$cnt;
	dec $cnt;
}

let $cnt=70;
while($cnt>60)
{
	eval insert into t1 values($cnt,$cnt,'c$cnt');
	dec $cnt;
}

##leade B 下线
let $new_leader=deploy_get_value(ob1.get_leader obtest:obtest:t1);
$new_leader.force_stop;

sleep 20;

--enable_query_log
select * from t1;

##原因：触发更新一次location 
--error 4012,0
insert into t1 values(80, 80, 'c80');

let $cnt=80;
while($cnt>70)
{
	eval replace into t1 values($cnt,$cnt,'c$cnt');
	dec $cnt;
}

select * from t1;
















