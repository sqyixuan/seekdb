# owner: bin.lb
# owner group: STORAGE

ob1=OBI(cluster=1,proxy_num=0,init_unit_cpu=0);
ob1.reboot;

ob1.create_client tenant=sys,user=root,passwd=,database=oceanbase;


create table l (lk1 int, lk2 int, lv1 int, lv2 varchar(128), primary key(lk1, lk2)) partition by key (lk1) partitions 2;
create table r (rk int, rv1 int, rv2 varchar(128), primary key(rk)) locality = 'F@z1, R{all_server}@z1';

insert into l values (1, 1, 10, 'aaaaaaa');
insert into l values (1, 2, 20, 'bbbbbbb');
insert into r values (1, 100, 'right value1');

create materialized view mv as select lk1, lk2, lv1, lv2, rk, rv1, rv2 from l, r where lk2 = rk order by lk1, lv1;

let $lid = deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where table_name = 'l' and tenant_id = 1, table_id, 1);
let $rid = deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where table_name = 'r' and tenant_id = 1, table_id, 1);
let $mvid = deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where table_name = 'mv' and tenant_id = 1, table_id, 1);

alter system major freeze;
ob1.check_version 2;
ob1.check_until_timeout select index_status from oceanbase.__all_virtual_table where tenant_id=1 and table_name = 'mv', 2, 20;

ob1.mysql alter system set merge_thread_count = 1;

sleep 1;

alter system major freeze;
ob1.check_version 3;

let $lstart = deploy_get_value(ob1.select select max(merge_start_time) as v from oceanbase.__all_virtual_partition_sstable_merge_info where table_id = $lid and version = 3, v, 1);
let $rstart = deploy_get_value(ob1.select select min(merge_start_time) as v from oceanbase.__all_virtual_partition_sstable_merge_info where table_id = $rid and version = 3, v, 1);

ob1.mysql_p select '$lstart' < '$rstart' as left_before_right;

