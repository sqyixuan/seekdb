##
# owner:yulan.way
# owner group:transaction
# description:
# 测试功能点：多机单partition，复杂场景，未决日志处理
# 用例描述：1)	A写磁盘成功但B和C没有成功（阻塞网络），网络恢复，A被再次选为主后，会对这条日志进行reconfirm，会写入成功 
##
ob1=OBI(cluster=2:2:2,proxy_num=0,init_unit_cpu=12,init_unit_num=1);
ob1.reboot;
sleep 15;

ob1.create_client tenant=obtest;
create database obtest;

let $ip=deploy_get_value(ob1.z1.obs1.ip);
let $port=deploy_get_value(ob1.z1.obs1.mysql_port);
let $cluster=deploy_get_value(ob1.app_name);
connect (conn1,$ip,admin@obtest,admin,obtest,$port);
connection conn1;

##数据准备
use obtest;
create table t1(pk int primary key, c1 int, c2 varchar(20));

--disable_query_log
let $cnt=10;
while($cnt>0)
{
	eval insert into t1 values($cnt,$cnt,'c$cnt');
	dec $cnt;
}

let $leader=deploy_get_value(ob1.get_leader obtest:obtest:t1);
let $follower_1=deploy_get_value(ob1.get_follower obtest:obtest:t1,1);
let $follower_2=deploy_get_value(ob1.get_follower obtest:obtest:t1,2);
## 阻塞主和两个备之间的网络
$leader.block_net $follower_1;
$leader.block_net $follower_2;

##写入两台数据
--error 4012
update t1 set c2='way' where pk=5;

##B和C之间会选出一个新的主
sleep 15;

##恢复网络后，A会接入进来
$leader.clean_net $follower_1;
$leader.clean_net $follower_2;
sleep 20;

#上一条update语句执行-6225错误，会断链接，因此重新建链接
connect (conn2,$ip,admin@obtest,admin,obtest,$port);
connection conn2;

select * from t1;

let $cnt=20;
while($cnt>10)
{
	eval insert into t1 values($cnt,$cnt,'c$cnt');
	dec $cnt;
}

select * from t1;


































