# owner: yangyi.yyy
# owner group: physical_backup
# Testing Case: migrate standby and one server shutdown

ob1=OBI(cluster=2:2:2,proxy_num=1);

source include/mini_ob_config.inc;
ob1.z1.obs0.set extra_config = "cache_wash_threshold='1G',_ob_minor_merge_schedule_interval='3s'";
ob1.z1.obs1.set extra_config = "cache_wash_threshold='1G',_ob_minor_merge_schedule_interval='3s'";
ob1.z2.obs0.set extra_config = "cache_wash_threshold='1G',_ob_minor_merge_schedule_interval='3s'";
ob1.z2.obs1.set extra_config = "cache_wash_threshold='1G',_ob_minor_merge_schedule_interval='3s'";
ob1.z3.obs0.set extra_config = "cache_wash_threshold='1G',_ob_minor_merge_schedule_interval='3s'";
ob1.z3.obs1.set extra_config = "cache_wash_threshold='1G',_ob_minor_merge_schedule_interval='3s'";

let $backup_ip       = deploy_get_value(ob1.z1.obs0.ip);
let $backup_port     = deploy_get_value(ob1.z1.obs0.mysql_port);
let $backup_oracle_tenant   = backup_oracle_tenant;
let $restore_oracle_tenant = restore_oracle_tenant;
let $log_backup_dest = deploy_get_value(ob1.get_log_backup_dest $backup_oracle_tenant);
let $data_backup_dest = deploy_get_value(ob1.get_data_backup_dest $backup_oracle_tenant);

ob1.force_stop;
ob1.clean_backup_dest;
ob1.reboot;

connect(backup_sys_conn, $backup_ip, root@sys,,oceanbase, $backup_port);
connection backup_sys_conn;
use oceanbase;

ob1.mysql ALTER SYSTEM SET _backup_idle_time = '10s';
ob1.mysql ALTER SYSTEM SET enable_async_syslog=false;
ob1.mysql ALTER SYSTEM SET debug_sync_timeout = '10000s';
ob1.mysql ALTER SYSTEM SET enable_rebalance = false tenant = all_user;

--echo ===============================================================
--echo ==================     create tenant   ========================
--echo ===============================================================

source sql/physical_backup/prepare_multi_zone_resource.sql;
ob1.create_tenant CREATE TENANT backup_oracle_tenant resource_pool_list = ('small_pool'), locality = "F@z1,F@z2,F@z3", primary_zone = "z1" set ob_tcp_invited_nodes='%', ob_compatibility_mode='oracle';
let $backup_oracle_tenant_id = query_get_value(select tenant_id from oceanbase.__all_tenant where tenant_name='$backup_oracle_tenant', tenant_id, 1);

--echo ===============================================================
--echo ==================     create table    ========================
--echo ===============================================================
ob_connect(sys_conn_oracle, ob1.proxy0, SYS@$backup_oracle_tenant, ,SYS, , USE_OB_CONNECTOR);
connection sys_conn_oracle;
set global wait_timeout = 288000;
create user test IDENTIFIED BY "test";
grant all on *.* to test WITH GRANT OPTION;
grant dba to test;
ob_connect(backup_oracle_conn, ob1.proxy0,TEST@$backup_oracle_tenant,test,test,,USE_OB_CONNECTOR);
connection backup_oracle_conn;

create table t1(a int, b int, c int, CONSTRAINT "c1" PRIMARY KEY ("A"));
insert into t1(a, b) values(1, 1);
insert into t1(a, b) values(2, 2);

create table t2(a int, b int, c int, CONSTRAINT "c2" PRIMARY KEY ("A"));
insert into t2(a, b) values(1, 1);
insert into t2(a, b) values(2, 2);

--echo ===============================================================
--echo ==================    set backup dest    ======================
--echo ===============================================================

--disable_all_result_log
eval ALTER SYSTEM SET data_backup_dest='$data_backup_dest';
eval ALTER SYSTEM SET log_archive_dest='location=$log_backup_dest';
ob1.mysql set ob_global_debug_sync = 'BEFORE_CHECK_LS_TRANSFER_SCN_FOR_STANDBY wait_for signal execute 10000';
ob1.mysql ALTER SYSTEM SET migrate_check_member_list_error_zone = 'z3';
--enable_all_result_log

--echo ===============================================================
--echo ==================     start archive   ========================
--echo ===============================================================
ob1.mysql ALTER SYSTEM ARCHIVELOG;
ob1.check_until_timeout select status from oceanbase.CDB_OB_ARCHIVELOG where tenant_id=$backup_oracle_tenant_id, DOING, 600;

--echo ===============================================================
--echo ==================     major freeze    ========================
--echo ===============================================================
ob1.mysql ALTER SYSTEM SET merger_check_interval = '10s' tenant all_user;
ob1.mysql ALTER SYSTEM SET ob_compaction_schedule_interval='10s' tenant all_user;
sleep 3;
ob1.mysql ALTER SYSTEM major freeze tenant = '$backup_oracle_tenant';
sleep 10;
ob1.check_until_timeout select (frozen_scn - last_scn) as result from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id=$backup_oracle_tenant_id, 0, 600;

--echo ===============================================================
--echo ==================     backup database     ====================
--echo ===============================================================
ob1.mysql ALTER SYSTEM BACKUP DATABASE;
ob1.check_until_timeout select count(*) c from __all_backup_job_history where tenant_id = 1, 1, 600;

--echo ===============================================================
--echo =================     select checkpoint    ====================
--echo ===============================================================
connection backup_sys_conn;

let $restore_checkpoint_ts = `select ceil(UNIX_TIMESTAMP(current_timestamp(6)) * 1000000)`;
ob1.check_until_timeout select floor(checkpoint_scn / 1000) > '$restore_checkpoint_ts' from CDB_OB_ARCHIVELOG, 1, 600;
let $restore_checkpoint = `select usec_to_time(floor(checkpoint_scn/1000)) from CDB_OB_ARCHIVELOG`;

--echo ===============================================================
--echo ====================      transfer       ======================
--echo ===============================================================
ob1.mysql ALTER RESOURCE tenant backup_oracle_tenant UNIT_NUM = 2;
ob1.check_until_timeout select count(*) c from __all_virtual_balance_job_history, 1, 600;

--echo ===============================================================
--echo ======================     restore      =======================
--echo ===============================================================
let $restore_path = $log_backup_dest,$data_backup_dest;
ob1.mysql ALTER SYSTEM RESTORE $restore_oracle_tenant FROM '$restore_path' UNTIL time='$restore_checkpoint' WITH 'pool_list=small_pool_1';
ob1.check_until_timeout select count(*) > 0 from __all_virtual_restore_job_history, 1, 600;

--echo ===============================================================
--echo ======================     migration    =======================
--echo ===============================================================

let $restore_oracle_tenant_id = query_get_value(select tenant_id from oceanbase.__all_tenant where tenant_name='$restore_oracle_tenant', tenant_id, 1);
let $resource_pool_id = deploy_get_value(ob1.select select resource_pool_id from oceanbase.__all_resource_pool where tenant_id = $restore_oracle_tenant_id, resource_pool_id, 1);
let $unit_id = deploy_get_value(ob1.select select unit_id from oceanbase.__all_unit where resource_pool_id = $resource_pool_id and zone = 'z3', unit_id, 1);
let $ip = deploy_get_value(ob1.select select svr_ip from oceanbase.__all_unit where unit_id = $unit_id, svr_ip, 1);
let $port = deploy_get_value(ob1.select select svr_port from oceanbase.__all_unit where unit_id = $unit_id, svr_port, 1);

let $dst_ip0 = deploy_get_value(ob1.z3.obs0.ip);
let $dst_port0 = deploy_get_value(ob1.z3.obs0.port);

let $dst_ip1 = deploy_get_value(ob1.z3.obs1.ip);
let $dst_port1 = deploy_get_value(ob1.z3.obs1.port);

let $cur = $ip:$port;
let $dst0 = $dst_ip0:$dst_port0;
let $dst1 = $dst_ip1:$dst_port1;

if ($cur != $dst0)
{
  --disable_query_log
  eval ALTER SYSTEM MIGRATE UNIT $unit_id destination "$dst0";
}

if ($cur != $dst1)
{
  --disable_query_log
  eval ALTER SYSTEM MIGRATE UNIT $unit_id destination "$dst1";
}

--echo ===============================================================
--echo ======================    event occur    ======================
--echo ===============================================================

ob1.check_until_timeout select count(*) > 0 from __all_server_event_history where event = 'before_check_ls_transfer_scn_validity_for_standby', 1, 1200;

--echo ===============================================================
--echo ===================    recover unlimited    ===================
--echo ===============================================================

ob1.check_until_timeout SELECT status FROM __all_tenant WHERE tenant_id = 1006, NORMAL, 300;
ob1.mysql ALTER SYSTEM RECOVER STANDBY TENANT restore_oracle_tenant UNTIL UNLIMITED;

--echo ===============================================================
--echo ======================   errsim for palf    ===================
--echo ===============================================================

ob1.z2.force_stop;
ob1.check_until_timeout select count(*) from oceanbase.__all_server where zone = 'z2' and status = 'ACTIVE', 0, 120;

--echo ===============================================================
--echo ======================    event occur    ======================
--echo ===============================================================

ob1.mysql set ob_global_debug_sync = 'BEFORE_CHECK_LS_TRANSFER_SCN_FOR_STANDBY clear';
ob1.mysql set ob_global_debug_sync = 'now broadcast signal';

ob1.check_until_timeout select count(*) > 0 from __all_server_event_history where event = 'check_ls_transfer_scn_validity_for_standby_failed', 1, 600;

--echo ===============================================================
--echo ==================     cancel errsim     ======================
--echo ===============================================================

ob1.check_until_timeout SELECT COUNT(*) as cnt FROM oceanbase.__all_rootservice_job WHERE unit_id = $unit_id AND job_type = "MIGRATE_UNIT" AND job_status = "SUCCESS", 1, 600;
