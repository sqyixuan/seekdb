##############################
# owner: wx372254
# group: transaction
#

ob1=OBI(cluster=1:1:1,proxy_num=0,init_unit_cpu=0,locality=HZ:HZ:HZ);
ob1.reboot;
ob1.mysql alter system set syslog_io_bandwidth_limit='3000M';
ob1.mysql alter system set _lcl_op_interval='100ms';
ob1.mysql alter system set enable_auto_leader_switch = 'false';
sleep 10;

ob_connect(sys_conn, ob1.z1.obs0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);

connection sys_conn;
### 创建oracle租户
ob1.mysql create resource unit box1 max_cpu 2, max_memory 2073741824, max_iops 128, max_disk_size '5G', max_session_num 64, MIN_CPU=1, MIN_MEMORY=2073741824, MIN_IOPS=128;
ob1.mysql create resource pool pool1 unit = 'box1', unit_num = 1;
ob1.mysql create tenant oracle replica_num = 3, resource_pool_list=('pool1') set ob_tcp_invited_nodes='%', ob_compatibility_mode='oracle';
ob1.mysql alter tenant oracle set variables nls_date_format='YYYY-MM-DD HH24:MI:SS';
ob1.mysql alter tenant oracle set variables nls_timestamp_format='YYYY-MM-DD HH24:MI:SS.FF';
ob1.mysql alter tenant oracle set variables nls_timestamp_tz_format='YYYY-MM-DD HH24:MI:SS.FF TZR TZD';
sleep 2;

ob1.check_until_timeout select count(*) c from oceanbase.__all_server where start_service_time <= 0 or status = "inactive", 0, 120;
ob_connect(cli1_conn, ob1.z1.obs0, SYS@oracle, , SYS, , USE_OB_CONNECTOR);
ob_connect(cli2_conn, ob1.z1.obs0, SYS@oracle, , SYS, , USE_OB_CONNECTOR);

connection cli1_conn;
set autocommit = false;
connection cli2_conn;
set autocommit = false;

connection cli1_conn;
CREATE TABLE test1(id NUMBER unique,name char(6),birthday DATE);
INSERT INTO test1 VALUES(1,'aaa',to_date('19800102','yyyymmdd'));
COMMIT;
CREATE OR REPLACE FUNCTION func1 RETURN int AS pragma autonomous_transaction; BEGIN UPDATE test1 SET id=4,name='ddd',birthday=to_date('20101022','yyyymmdd') WHERE id=1; COMMIT; RETURN 10; END;
UPDATE test1 SET id=3,name='ccc',birthday=to_date('20001022','yyyymmdd') WHERE id=1;
--error 60
DECLARE i int; BEGIN i:=func1(); END;
SELECT * FROM test1;