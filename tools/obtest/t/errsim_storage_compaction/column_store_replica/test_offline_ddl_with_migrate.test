# owner: ouyanghongrong.oyh
# owner group: storage
# description: this case is used for testing column store replica
# 1. create cs replica
# 2. do offline ddl
# 3. do offline ddl with migrate
# 4. do major freeze in a column store tablet with row store major in cs replica

ob1=OBI(cluster=1:1:1,proxy_num=0,init_unit_cpu=4);
ob1.reboot;
sleep 10;

let $tenant_name = tenant1;

--echo ===============================================================
--echo =================  Step 0: prepare env   ======================
--echo ===============================================================

ob1.mysql alter resource unit sys_unit_config memory_size='2G';
ob1.mysql alter system set enable_rebalance = 'false';
ob1.mysql alter system set default_compress_func = 'none';
ob1.mysql alter system set debug_sync_timeout = '100000s';

let $proxy_ip = deploy_get_value(ob1.z1.obs0.ip);
let $proxy_port = deploy_get_value(ob1.z1.obs0.mysql_port);

connect(sys_conn, $proxy_ip, root@sys,,oceanbase, $proxy_port);

ob1.mysql alter system set ob_compaction_schedule_interval = '10s' tenant obtest;
ob1.mysql alter system set merger_check_interval = '10s' tenant obtest;

--echo ===============================================================
--echo =================  Step 1: create tenant   ====================
--echo ===============================================================

connection sys_conn;
source include/get_user_config.inc;
ob1.mysql create resource pool cs_replica_pool unit = "user_unit_config", unit_num = 1, zone_list = ('z1', 'z2', 'z3');
ob1.mysql create TENANT $tenant_name resource_pool_list=('cs_replica_pool'), locality = "F@z1, F@z2, C@z3", primary_zone = "z1" set ob_tcp_invited_nodes='%';

let $tenant_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name = "$tenant_name", tenant_id, 1);
let $resource_pool_id = deploy_get_value(ob1.select select resource_pool_id from oceanbase.__all_resource_pool where tenant_id = $tenant_id, resource_pool_id, 1);

--echo ===============================================================
--echo =================  Step 2: create table   =====================
--echo ===============================================================

ob_connect(z1_obs0, ob1.z1.obs0, root@$tenant_name, , test, , USE_MYSQL_CONNECTOR);
connection z1_obs0;

create table t1 (k int primary key, v1 int, v2 int);
insert into t1 values (1, 1, 1);
insert into t1 values (2, 2, 2);
insert into t1 values (3, 3, 3);
select * from t1 order by k;
select count(*), avg(k), avg(v1), avg(v2) from t1;
sleep 3;

ob_connect(z3_obs0, ob1.z3.obs0, root@$tenant_name, , test, , USE_MYSQL_CONNECTOR);
connection z3_obs0;
set ob_route_policy=COLUMN_STORE_ONLY;
set ob_read_consistency = WEAK;
select * from t1 order by k;
select count(*), avg(k), avg(v1), avg(v2) from t1;
set ob_read_consistency = STRONG;
set ob_route_policy=READONLY_ZONE_FIRST;


--echo ===============================================================
--echo =================  Step 3: do offline ddl =====================
--echo ===============================================================
connection z1_obs0;
insert into t1 values (4, 4, 4);
alter table t1 modify v1 decimal(10, 1);
select * from t1 order by k;
select count(*), avg(k), avg(v1), avg(v2) from t1;

ob_connect(z3_obs0, ob1.z3.obs0, root@$tenant_name, , test, , USE_MYSQL_CONNECTOR);
connection z3_obs0;
set ob_route_policy=COLUMN_STORE_ONLY;
set ob_read_consistency = WEAK;
sleep 3;
select * from t1 order by k;
select count(*), avg(k), avg(v1), avg(v2) from t1;
set ob_read_consistency = STRONG;
set ob_route_policy=READONLY_ZONE_FIRST;

--echo ===============================================================
--echo =================  Step 4: do offline ddl with migrate ========
--echo ===============================================================
connection sys_conn;
# EN_COMPACTION_CO_MERGE_PREPARE_FAILED = 4016
ob1.mysql alter system set_tp tp_no = 720, error_code = 4016, frequency = 1;
alter system set_tp tp_name = "EN_LS_NOT_SEE_CS_REPLICA", error_code = 4016, frequency = 1;
connection z1_obs0;
insert into t1 values (5, 5, 5);
alter table t1 modify v2 decimal(10, 3);
select * from t1 order by k;
select count(*), avg(k), avg(v1), avg(v2) from t1;

ob_connect(z3_obs0, ob1.z3.obs0, root@$tenant_name, , test, , USE_MYSQL_CONNECTOR);
connection z3_obs0;
set ob_route_policy=COLUMN_STORE_ONLY;
set ob_read_consistency = WEAK;
sleep 3;
select * from t1 order by k;
select count(*), avg(k), avg(v1), avg(v2) from t1;
set ob_read_consistency = STRONG;
set ob_route_policy=READONLY_ZONE_FIRST;

connection sys_conn;
alter system set_tp tp_name = "EN_LS_NOT_SEE_CS_REPLICA", error_code = 4016, frequency = 0;
let $z3_ip0 = deploy_get_value(ob1.z3.obs0.ip);
let $z3_port0 = deploy_get_value(ob1.z3.obs0.port);
--disable_query_log
eval select distinct(table_type) from oceanbase.GV\$OB_SSTABLES where tablet_id = (select tablet_id from __all_virtual_table where table_name = 't1') and table_type in ('MAJOR', 'CO_MAJOR', 'NORMAL_CG') and svr_ip = '$z3_ip0' and svr_port = $z3_port0 order by table_type;
--enable_query_log
ob1.mysql alter system set_tp tp_no = 720, error_code = 4016, frequency = 0;

connection sys_conn;
alter system set_tp tp_name = "EN_LS_NOT_SEE_CS_REPLICA", error_code = 4016, frequency = 1;
alter system set_tp tp_name = "EN_REPLAY_REDO_DDL_LOG_WAIT", error_code = 4016, frequency = 1;

ob_connect(z1_tmp, ob1.z1.obs0, root@$tenant_name, , test, , USE_MYSQL_CONNECTOR);
connection z1_tmp;
send alter table t1 modify v2 decimal(20, 3);
ob1.z3.obs0.check_log_until_success -c "EN_REPLAY_REDO_DDL_LOG_WAIT replay ddl redo failed.*4016";
ob1.z3.obs0.force_stop;
sleep 24;
connection sys_conn;
alter system set_tp tp_name = "EN_REPLAY_REDO_DDL_LOG_WAIT", error_code = 4016, frequency = 0;
ob1.z3.obs0.nstart;
ob1.check_until_timeout select count(*) from __all_server where status='INACTIVE' or start_service_time <= 0, 0, 120;
ob1.check_until_timeout select count(*) from oceanbase.GV\$OB_SSTABLES where tablet_id = (select tablet_id from __all_virtual_table where table_name = 't1') and table_type ='MAJOR' and svr_ip = '$z3_ip0' and svr_port = $z3_port0, 1, 60;
connection sys_conn;
alter system set_tp tp_name = "EN_LS_NOT_SEE_CS_REPLICA", error_code = 4016, frequency = 0;

ob_connect(z3_obs0, ob1.z3.obs0, root@$tenant_name, , test, , USE_MYSQL_CONNECTOR);
connection z3_obs0;
set ob_route_policy=COLUMN_STORE_ONLY;
set ob_read_consistency = WEAK;
sleep 10;
select * from t1 order by k;
select count(*), avg(k), avg(v1), avg(v2) from t1;
set ob_read_consistency = STRONG;
set ob_route_policy=READONLY_ZONE_FIRST;

--echo ===============================================================
--echo =================  Step 5: wait major freeze   ================
--echo ===============================================================
connection z1_obs0;
alter table t1 add column v3 int default 666;
insert into t1 values (6, 6, 6, 6);
insert into t1 values (7, 7, 7, 7);

connection sys_conn;
let $tablet_id = deploy_get_value(ob1.select select tablet_id from oceanbase.__all_virtual_table where table_name='t1', tablet_id, 1);
ob1.mysql alter system major freeze tenant $tenant_name;
sleep 5;
let $frozen_scn  = deploy_get_value(ob1.select select frozen_scn from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id = $tenant_id, frozen_scn, 1);
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_tablet_meta_table where compaction_scn = $frozen_scn and tenant_id = $tenant_id and tablet_id = $tablet_id, 3, 400;
connection sys_conn;
--disable_query_log
eval select distinct(table_type) from oceanbase.GV\$OB_SSTABLES where tablet_id = (select tablet_id from __all_virtual_table where table_name = 't1') and table_type in ('MAJOR', 'CO_MAJOR', 'NORMAL_CG') and svr_ip = '$z3_ip0' and svr_port = $z3_port0 order by table_type;
--enable_query_log
--echo ===============================================================
--echo =================  Step 6: query continue =====================
--echo ===============================================================
connection z1_obs0;
select * from t1 order by k;
select count(*), avg(k), avg(v1), avg(v2) from t1;
ob_connect(z3_obs0, ob1.z3.obs0, root@$tenant_name, , test, , USE_MYSQL_CONNECTOR);
connection z3_obs0;
set ob_route_policy=COLUMN_STORE_ONLY;
set ob_read_consistency = WEAK;
sleep 10;
select * from t1 order by k;
select count(*), avg(k), avg(v1), avg(v2) from t1;
set ob_read_consistency = STRONG;
set ob_route_policy=READONLY_ZONE_FIRST;