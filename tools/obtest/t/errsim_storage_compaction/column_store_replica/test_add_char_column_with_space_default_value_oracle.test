# owner: ouyanghongrong.oyh
# owner group: storage
# description: test table add column with default value containing space in oracle mode, and convert co merge

ob1=OBI(cluster=1:1,proxy_num=0,init_unit_cpu=4);
ob1.reboot;
sleep 10;

--echo ===============================================================
--echo =================  Step 0: prepare env   ======================
--echo ===============================================================

ob1.mysql alter resource unit sys_unit_config memory_size='2G';
ob1.mysql alter system set enable_rebalance = 'false';
ob1.mysql alter system set default_compress_func = 'none';
ob1.mysql alter system set debug_sync_timeout = '100000s';

let $proxy_ip = deploy_get_value(ob1.z1.obs0.ip);
let $proxy_port = deploy_get_value(ob1.z1.obs0.mysql_port);
let $z1_obs0_ip = deploy_get_value(ob1.z1.obs0.ip);
let $z2_obs0_ip = deploy_get_value(ob1.z2.obs0.ip);
let $z1_obs0_port = deploy_get_value(ob1.z1.obs0.port);
let $z2_obs0_port = deploy_get_value(ob1.z2.obs0.port);

connect(sys_conn, $proxy_ip, root@sys,,oceanbase, $proxy_port);

ob1.mysql alter system set ob_compaction_schedule_interval = '10s' tenant obtest;
ob1.mysql alter system set merger_check_interval = '10s' tenant obtest;

--echo ===============================================================
--echo =================  Step 1: create tenant   ====================
--echo ===============================================================

connection sys_conn;
source include/get_user_config.inc;
ob1.mysql create resource pool cs_replica_pool unit = "user_unit_config", unit_num = 1, zone_list = ('z1', 'z2');
ob1.mysql create TENANT oracle resource_pool_list=('cs_replica_pool'), replica_num=2, zone_list = ('z1', 'z2'), locality = "F@z1" set ob_tcp_invited_nodes='%', ob_compatibility_mode='oracle';
ob1.mysql alter system set ob_compaction_schedule_interval = '10s' tenant oracle;
ob1.mysql alter system set merger_check_interval = '10s' tenant oracle;
ob1.mysql alter system set_tp tp_name = "EN_NOT_TRIM_FOR_DEFALUT_CHECKSUM", error_code = 4016, frequency = 1;

let $tenant_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name = "oracle", tenant_id, 1);
let $resource_pool_id = deploy_get_value(ob1.select select resource_pool_id from oceanbase.__all_resource_pool where tenant_id = $tenant_id, resource_pool_id, 1);

--echo ===============================================================
--echo ==== Step 2: create table, add column, add C-Replica  =========
--echo ===============================================================
ob_connect(z1_obs0, ob1.z1.obs0, sys@oracle, ,sys, , USE_OB_CONNECTOR);
connection z1_obs0;
create table t1 (k int primary key, c1 int, c2 varchar(4000)) nocompress;
set ob_query_timeout = 1000000000;
create sequence seq cache 1000000 noorder;
insert into t1 select seq.nextval, seq.nextval, randstr(4000, random()) from table(generator(100000));
alter system major freeze;
sleep 60;
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id=$tenant_id and LAST_SCN = GLOBAL_BROADCAST_SCN , 1, 600;

alter table t1 add v3 char (125) not null default ' ';
insert into t1 (k, c1, c2) values (100001, 100000, randstr(4000, random()));
sleep 10;
alter system major freeze;
sleep 60;
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id=$tenant_id and LAST_SCN = GLOBAL_BROADCAST_SCN , 1, 600;
ob1.z1.obs0.check_log_until_success -c "whether to trim space for default checksum.*errsim_code=-4016.*need_trim_default_val=true";
ob1.mysql alter system set_tp tp_name = "EN_NOT_TRIM_FOR_DEFALUT_CHECKSUM", error_code = 4016, frequency = 0;

alter table t1 add v4 char (125) not null default ' ';
insert into t1 (k, c1, c2) values (100002, 100000, randstr(4000, random()));
alter system minor freeze;
sleep 10;

ob1.mysql alter tenant oracle set locality = "F{1}@z1,C{1}@z2";
ob1.check_until_timeout select count(*) from (select * from oceanbase.DBA_OB_TENANT_JOBS where tenant_id = $tenant_id order by START_TIME desc limit 1) where job_status = "SUCCESS", 1, 100;
ob1.z2.obs0.check_log_until_success -c "CO_MERGE.*whether to trim space for default checksum.*errsim_code=0.*need_trim_default_val=true";
ob1.z2.obs0.check_log_until_success -c "CS-Replica.*Successfully get column array";
ob1.z2.obs0.check_log_until_success -c "column checksum error match(ret=-4103";
ob1.z2.obs0.check_log_until_success -c "Tips: there is default value with space in oracle mode for this table,";