# owner: ouyanghongrong.oyh
# owner group: storage
# description: 用于列存副本 unit 在同一个 zone 内的迁移, 能够正确校验不同类型副本的 checksum

ob1=OBI(cluster=1:1:2:1,proxy_num=0,init_unit_cpu=4);
ob1.reboot;
sleep 10;

--echo ===============================================================
--echo =================  Step 0: prepare env   ======================
--echo ===============================================================

ob1.mysql alter resource unit sys_unit_config memory_size='2G';
ob1.mysql alter system set enable_rebalance = 'false';
ob1.mysql alter system set default_compress_func = 'none';
ob1.mysql alter system set debug_sync_timeout = '100000s';

let $proxy_ip = deploy_get_value(ob1.z1.obs0.ip);
let $proxy_port = deploy_get_value(ob1.z1.obs0.mysql_port);

connect(sys_conn, $proxy_ip, root@sys,,oceanbase, $proxy_port);

ob1.mysql alter system set ob_compaction_schedule_interval = '10s' tenant obtest;
ob1.mysql alter system set merger_check_interval = '10s' tenant obtest;

--echo ===============================================================
--echo =================  Step 1: create tenant   ====================
--echo ===============================================================

connection sys_conn;
source include/get_user_config.inc;
ob1.mysql create resource pool cs_replica_pool unit = "user_unit_config", unit_num = 1, zone_list = ('z1', 'z2', 'z3', 'z4');
ob1.mysql create TENANT tenant1 resource_pool_list=('cs_replica_pool'), locality = "F@z1, F@z2, C@z3, C@z4", primary_zone = "z1" set ob_tcp_invited_nodes='%';

let $tenant_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name = "tenant1", tenant_id, 1);
let $resource_pool_id = deploy_get_value(ob1.select select resource_pool_id from oceanbase.__all_resource_pool where tenant_id = $tenant_id, resource_pool_id, 1);

--echo ===============================================================
--echo =================  Step 2: create table   =====================
--echo ===============================================================

ob_connect(z1_obs0, ob1.z1.obs0, root@tenant1, , test, , USE_MYSQL_CONNECTOR);
ob_connect(z4_obs0, ob1.z3.obs0, root@tenant1, , test, , USE_MYSQL_CONNECTOR);
connection z1_obs0;

create table t1 (k int primary key, v1 int, v2 int);
insert into t1 values (1, 1, 1);
insert into t1 values (2, 2, 2);
insert into t1 values (3, 3, 3);
select * from t1 order by k;

--echo ===============================================================
--echo =================  Step 3: wait major freeze   ================
--echo ===============================================================
connection sys_conn;
let $tablet_id = deploy_get_value(ob1.select select tablet_id from oceanbase.__all_virtual_table where table_name='t1', tablet_id, 1);
let $last_scn  = deploy_get_value(ob1.select select last_scn from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id = $tenant_id, last_scn, 1);
ob1.mysql alter system major freeze tenant tenant1;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_tablet_meta_table where compaction_scn != $last_scn and tenant_id = $tenant_id and tablet_id = $tablet_id, 4, 600;

--echo ===============================================================
--echo =================  Step 4: migrate in the same zone   =========
--echo ===============================================================
let $resource_pool_id = deploy_get_value(ob1.select select resource_pool_id from oceanbase.__all_resource_pool where tenant_id = $tenant_id, resource_pool_id, 1);
let $unit_id = deploy_get_value(ob1.select select unit_id from oceanbase.__all_unit where resource_pool_id = $resource_pool_id and zone = 'z3', unit_id, 1);
let $tablet_id_t1 = deploy_get_value(ob1.select select tablet_id from oceanbase.__all_virtual_table where table_name='t1', tablet_id, 1);
let $ls_id = deploy_get_value(ob1.select select ls_id from oceanbase.__all_virtual_tablet_to_ls where tenant_id=$tenant_id and tablet_id=$tablet_id_t1, ls_id, 1);

let $dst_ip_z3_0 = deploy_get_value(ob1.z3.obs0.ip);
let $dst_port_z3_0 = deploy_get_value(ob1.z3.obs0.port);
let $dst_z3_0 = $dst_ip_z3_0:$dst_port_z3_0;

let $dst_ip_z3_1 = deploy_get_value(ob1.z3.obs1.ip);
let $dst_port_z3_1 = deploy_get_value(ob1.z3.obs1.port);
let $dst_z3_1 = $dst_ip_z3_1:$dst_port_z3_1;

let $ip = deploy_get_value(ob1.select select svr_ip from oceanbase.__all_unit where unit_id = $unit_id, svr_ip, 1);
let $port = deploy_get_value(ob1.select select svr_port from oceanbase.__all_unit where unit_id = $unit_id, svr_port, 1);
let $cur = $ip:$port;

let $dst = $dst_z3_0;
let $dst_port = $dst_port_z3_0;

if ($cur != $dst_z3_1)
{
  let $dst = $dst_z3_1;
  let $dst_port = $dst_port_z3_1;
}

ob1.mysql alter system migrate unit $unit_id destination "$dst";
ob1.check_until_timeout SELECT COUNT(*) as cnt FROM oceanbase.__all_rootservice_job WHERE unit_id = $unit_id AND job_type = "MIGRATE_UNIT" AND job_status = "SUCCESS", 1, 600;
ob1.check_until_timeout select count(1) from oceanbase.__all_virtual_ls_meta_table where tenant_id = $tenant_id and ls_id = $ls_id and svr_port = '$dst_port' and replica_status = 'NORMAL', 1, 100;
ob1.check_until_timeout select count(*) as cnt from oceanbase.GV\$OB_UNITS where unit_id = $unit_id and svr_ip = '$ip' and svr_port = $port, 0, 100;