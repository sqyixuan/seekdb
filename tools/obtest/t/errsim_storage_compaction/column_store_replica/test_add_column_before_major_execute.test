# owner: ouyanghongrong.oyh
# owner group: storage
# description: 合并执行前, 加列转储, 随后执行合并, 此时 storage schema 的 progressive merge round 应该对应合并的 storage schmea

ob1=OBI(cluster=1:1:1,proxy_num=0,init_unit_cpu=4);
let $extra_conf = "tablet_meta_table_check_interval='1m'";
ob1.z1.obs0.set extra_config=_enable_defensive_check=0,$extra_conf;
ob1.z2.obs0.set extra_config=_enable_defensive_check=0,$extra_conf;
ob1.z3.obs0.set extra_config=_enable_defensive_check=0,$extra_conf;
ob1.reboot;
sleep 10;

let $tenant_name = tenant1;

--echo ===============================================================
--echo =================  Step 0: prepare env   ======================
--echo ===============================================================

ob1.mysql alter resource unit sys_unit_config memory_size='2G';
ob1.mysql alter system set enable_rebalance = 'false';
ob1.mysql alter system set default_compress_func = 'none';
ob1.mysql alter system set debug_sync_timeout = '100000s';

let $proxy_ip = deploy_get_value(ob1.z1.obs0.ip);
let $proxy_port = deploy_get_value(ob1.z1.obs0.mysql_port);

connect(sys_conn, $proxy_ip, root@sys,,oceanbase, $proxy_port);

ob1.mysql alter system set ob_compaction_schedule_interval = '10s' tenant obtest;
ob1.mysql alter system set merger_check_interval = '10s' tenant obtest;

--echo ===============================================================
--echo =================  Step 1: create tenant   ====================
--echo ===============================================================

connection sys_conn;
source include/get_user_config.inc;
ob1.mysql create resource pool cs_replica_pool unit = "user_unit_config", unit_num = 1, zone_list = ('z1', 'z2', 'z3');
ob1.mysql create TENANT $tenant_name resource_pool_list=('cs_replica_pool'), locality = "F@z1, F@z2", primary_zone = "z1" set ob_tcp_invited_nodes='%';
ob1.mysql alter system set ob_compaction_schedule_interval = '10s' tenant tenant1;
ob1.mysql alter system set merger_check_interval = '10s' tenant tenant1;

let $tenant_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name = "$tenant_name", tenant_id, 1);
let $resource_pool_id = deploy_get_value(ob1.select select resource_pool_id from oceanbase.__all_resource_pool where tenant_id = $tenant_id, resource_pool_id, 1);

--echo ===============================================================
--echo ==== Step 2: create table, do major, add column, do minor  ====
--echo ===============================================================

ob_connect(z1_obs0, ob1.z1.obs0, root@$tenant_name, , test, , USE_MYSQL_CONNECTOR);
ob_connect(z3_obs0, ob1.z3.obs0, root@$tenant_name, , test, , USE_MYSQL_CONNECTOR);
connection z1_obs0;

# progressive_merge_round start with 1
create table t1 (k int primary key, v1 int, v2 int, v3 varchar(20));
# progressive_merge_round -> 2
alter table t1 modify v3 varchar(21);
insert into t1 values (1, 1, 1, '1');
insert into t1 values (2, 2, 2, '2');
insert into t1 values (3, 3, 3, '3');
select * from t1 order by k;

# EN_MEDIUM_CREATE_DAG = 4023
ob1.mysql alter system set_tp tp_no = 706, error_code = 4023, frequency = 1;
sleep 3;
alter system major freeze;
sleep 3;
let $compaction_scn  = deploy_get_value(ob1.select select GLOBAL_BROADCAST_SCN from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id = $tenant_id, GLOBAL_BROADCAST_SCN, 1);
let $tablet_id = deploy_get_value(ob1.select select tablet_id from oceanbase.__all_virtual_table where table_name='t1', tablet_id, 1);

# progressive_merge_round -> 3
alter table t1 add v0 bit after k;
insert into t1 (k, v1, v2) values (4, 4, 4), (5, 5, 5);
alter system minor freeze;
sleep 10;

# EN_MEDIUM_CREATE_DAG = 4023
ob1.mysql alter system set_tp tp_no = 706, error_code = 4023, frequency = 0;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_tablet_meta_table where compaction_scn = $compaction_scn and tenant_id = $tenant_id and tablet_id = $tablet_id, 2, 600;

--echo ===============================================================
--echo =================  Step 3: add C replica ======================
--echo ===============================================================
ob1.mysql alter tenant $tenant_name set locality = "F{1}@z1,F{1}@z2,C{1}@z3";
ob1.check_until_timeout select count(*) from (select * from oceanbase.DBA_OB_TENANT_JOBS where tenant_id = $tenant_id order by START_TIME desc limit 1) where job_status = "INPROGRESS", 1, 100;
ob1.check_until_timeout select count(*) from (select * from oceanbase.DBA_OB_TENANT_JOBS where tenant_id = $tenant_id order by START_TIME desc limit 1) where job_status = "SUCCESS", 1, 100;
connection sys_conn;
select count(*) from GV$OB_SSTABLES where (tenant_id, tablet_id) = (select tenant_id, tablet_id from __all_virtual_table where table_name = 't1') and table_type in ('CO_MAJOR');

