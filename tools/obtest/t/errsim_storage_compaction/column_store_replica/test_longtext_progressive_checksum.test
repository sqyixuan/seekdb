# owner: ouyanghongrong.oyh
# owner group: storage
# description: 测试升级前后 lob 列的 column checksum

ob1=OBI(cluster=1:1,proxy_num=0,init_unit_cpu=4);
ob1.reboot;
sleep 10;

--echo ===============================================================
--echo =================  Step 0: prepare env   ======================
--echo ===============================================================

ob1.mysql alter resource unit sys_unit_config memory_size='2G';
ob1.mysql alter system set enable_rebalance = 'false';
ob1.mysql alter system set default_compress_func = 'none';
ob1.mysql alter system set debug_sync_timeout = '100000s';
ob1.mysql set global recyclebin = OFF;

let $proxy_ip = deploy_get_value(ob1.z1.obs0.ip);
let $proxy_port = deploy_get_value(ob1.z1.obs0.mysql_port);
let $z1_obs0_port = deploy_get_value(ob1.z1.obs0.port);

connect(sys_conn, $proxy_ip, root@sys,,oceanbase, $proxy_port);

--echo ===============================================================
--echo =================  Step 1: create tenant   ====================
--echo ===============================================================
connection sys_conn;
source include/get_user_config.inc;
ob1.mysql create resource pool cs_replica_pool unit = "user_unit_config", unit_num = 1, zone_list = ('z1', 'z2');
ob1.mysql create TENANT tenant1 resource_pool_list=('cs_replica_pool'), replica_num=2, zone_list = ('z1', 'z2'), locality = "F@z1, C@z2" set ob_tcp_invited_nodes='%';
ob1.mysql alter system set ob_compaction_schedule_interval = '10s' tenant tenant1;
ob1.mysql alter system set merger_check_interval = '10s' tenant tenant1;

let $tenant_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name = "tenant1", tenant_id, 1);
let $resource_pool_id = deploy_get_value(ob1.select select resource_pool_id from oceanbase.__all_resource_pool where tenant_id = $tenant_id, resource_pool_id, 1);

--echo ===============================================================
--echo ==== Step 2: create table and do major freeze  ================
--echo =============================================================== 
ob_connect(z1_obs0_tenant1, ob1.z1.obs0, root@tenant1, , test, , USE_MYSQL_CONNECTOR);
ob_connect(z2_obs0_tenant1, ob1.z2.obs0, root@tenant1, , test, , USE_MYSQL_CONNECTOR);
connection z1_obs0_tenant1;

create table t1 (k int primary key, c1 int, c2 varchar(1024), c3 varchar(1024), c4 varchar(1024)) compression 'none';
alter table t1 set progressive_merge_num = 8;
create sequence seq1 cache 1000000 noorder;
set ob_query_timeout = 1000000000;
insert into t1 select seq1.nextval, seq1.nextval + 1, MD5(seq1.nextval + 2), MD5(seq1.nextval + 3), MD5(seq1.nextval + 4) from table(generator(500000));

connection sys_conn;
ob1.mysql alter system major freeze tenant tenant1;
sleep 60;
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id = $tenant_id and LAST_SCN != GLOBAL_BROADCAST_SCN , 0, 600;

--echo ===============================================================
--echo ==== Step 3: add column and compaction  ====
--echo ===============================================================
connection z1_obs0_tenant1;
alter table t1 add c5 longtext not null;

connection sys_conn;
ob1.mysql alter system major freeze tenant tenant1;
sleep 60;
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id = $tenant_id and LAST_SCN != GLOBAL_BROADCAST_SCN , 0, 600;