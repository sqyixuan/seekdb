# owner: ouyanghongrong.oyh
# owner group: storage
# description: test binary charset table add column add convert co merge

ob1=OBI(cluster=1:1,proxy_num=0,init_unit_cpu=4);
ob1.reboot;
sleep 10;

--echo ===============================================================
--echo =================  Step 0: prepare env   ======================
--echo ===============================================================

ob1.mysql alter resource unit sys_unit_config memory_size='2G';
ob1.mysql alter system set enable_rebalance = 'false';
ob1.mysql alter system set default_compress_func = 'none';
ob1.mysql alter system set debug_sync_timeout = '100000s';

let $proxy_ip = deploy_get_value(ob1.z1.obs0.ip);
let $proxy_port = deploy_get_value(ob1.z1.obs0.mysql_port);
let $z2_obs0_ip = deploy_get_value(ob1.z2.obs0.ip);
let $z2_obs0_port = deploy_get_value(ob1.z2.obs0.port);
let $z2_addr = $z2_obs0_ip:$z2_obs0_port;

connect(sys_conn, $proxy_ip, root@sys,,oceanbase, $proxy_port);

ob1.mysql alter system set ob_compaction_schedule_interval = '10s' tenant obtest;
ob1.mysql alter system set merger_check_interval = '10s' tenant obtest;

--echo ===============================================================
--echo =================  Step 1: create tenant   ====================
--echo ===============================================================

connection sys_conn;
source include/get_user_config.inc;
ob1.mysql create resource pool cs_replica_pool unit = "user_unit_config", unit_num = 1, zone_list = ('z1', 'z2');
ob1.mysql create TENANT tenant1 resource_pool_list=('cs_replica_pool'), replica_num=2, zone_list = ('z1', 'z2'), locality = "F@z1" set ob_tcp_invited_nodes='%';
ob1.mysql alter system set ob_compaction_schedule_interval = '10s' tenant tenant1;
ob1.mysql alter system set merger_check_interval = '10s' tenant tenant1;

let $tenant_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name = "tenant1", tenant_id, 1);
let $resource_pool_id = deploy_get_value(ob1.select select resource_pool_id from oceanbase.__all_resource_pool where tenant_id = $tenant_id, resource_pool_id, 1);

--echo ===============================================================
--echo ==== Step 2: create table, add column, add C-Replica  =========
--echo ===============================================================
ob_connect(z1_obs0, ob1.z1.obs0, root@tenant1, , test, , USE_MYSQL_CONNECTOR);
ob_connect(z2_obs0, ob1.z2.obs0, root@tenant1, , test, , USE_MYSQL_CONNECTOR);

connection z1_obs0;
create table t1_with_pk_default (k int primary key, v1 int, v2 int);
create table t2_with_pk_bianry  (k int primary key, v1 int, v2 int) DEFAULT CHARSET= binary;
create table t3_no_pk__default (v1 int, v2 int);
create table t4_no_pk__bianry (v1 int, v2 int) DEFAULT CHARSET= binary;

insert into t1_with_pk_default values (1, 2, 3), (2, 3, 4), (3, 4, 5), (4, 5, 6);
insert into t2_with_pk_bianry  values (1, 2, 3), (2, 3, 4), (3, 4, 5), (4, 5, 6);
insert into t3_no_pk__default  values (1, 2), (2, 3), (3, 4), (4, 5);
insert into t4_no_pk__bianry   values (1, 2), (2, 3), (3, 4), (4, 5);

alter table t1_with_pk_default add column v3 char (125) not null before v2;
alter table t2_with_pk_bianry  add column v3 char (125) not null before v2;
alter table t3_no_pk__default  add column v3 char (125) not null before v2;
alter table t4_no_pk__bianry   add column v3 char (125) not null before v2;

ob1.mysql alter tenant tenant1 set locality = "F{1}@z1,C{1}@z2";
ob1.check_until_timeout select count(*) from (select * from oceanbase.DBA_OB_TENANT_JOBS where tenant_id = $tenant_id order by START_TIME desc limit 1) where job_status = "SUCCESS", 1, 100;
connection sys_conn;

ob1.check_until_timeout select count(*) from GV\$OB_SSTABLES where tablet_id = (select tablet_id from __all_virtual_table where tenant_id = $tenant_id and table_name = 't1_with_pk_default') and svr_port = $z2_obs0_port and table_type = 'CO_MAJOR', 1, 60;
ob1.check_until_timeout select count(*) from GV\$OB_SSTABLES where tablet_id = (select tablet_id from __all_virtual_table where tenant_id = $tenant_id and table_name = 't2_with_pk_bianry')  and svr_port = $z2_obs0_port and table_type = 'CO_MAJOR', 1, 60;
ob1.check_until_timeout select count(*) from GV\$OB_SSTABLES where tablet_id = (select tablet_id from __all_virtual_table where tenant_id = $tenant_id and table_name = 't3_no_pk__default')  and svr_port = $z2_obs0_port and table_type = 'CO_MAJOR', 1, 60;
ob1.check_until_timeout select count(*) from GV\$OB_SSTABLES where tablet_id = (select tablet_id from __all_virtual_table where tenant_id = $tenant_id and table_name = 't4_no_pk__bianry')   and svr_port = $z2_obs0_port and table_type = 'CO_MAJOR', 1, 60;
