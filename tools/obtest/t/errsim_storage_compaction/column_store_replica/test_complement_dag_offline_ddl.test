# owner: ouyanghongrong.oyh
# owner group: storage
# description: test offline ddl use complement dag 

ob1=OBI(cluster=1:1,proxy_num=0,init_unit_cpu=4);
ob1.reboot;
sleep 10;

--echo ===============================================================
--echo =================  Step 0: prepare env   ======================
--echo ===============================================================

ob1.mysql alter resource unit sys_unit_config memory_size='2G';
ob1.mysql alter system set enable_rebalance = 'false';
ob1.mysql alter system set default_compress_func = 'none';
ob1.mysql alter system set debug_sync_timeout = '100000s';

let $proxy_ip = deploy_get_value(ob1.z1.obs0.ip);
let $proxy_port = deploy_get_value(ob1.z1.obs0.mysql_port);
let $z2_obs0_ip = deploy_get_value(ob1.z2.obs0.ip);
let $z2_obs0_port = deploy_get_value(ob1.z2.obs0.port);
let $z2_addr = $z2_obs0_ip:$z2_obs0_port;

connect(sys_conn, $proxy_ip, root@sys,,oceanbase, $proxy_port);

ob1.mysql alter system set ob_compaction_schedule_interval = '10s' tenant obtest;
ob1.mysql alter system set merger_check_interval = '10s' tenant obtest;

--echo ===============================================================
--echo =================  Step 1: create tenant   ====================
--echo ===============================================================

connection sys_conn;
source include/get_user_config.inc;
ob1.mysql create resource pool cs_replica_pool unit = "user_unit_config", unit_num = 1, zone_list = ('z1', 'z2');
ob1.mysql create TENANT tenant1 resource_pool_list=('cs_replica_pool'), replica_num=2, zone_list = ('z1', 'z2'), locality = "F@z1, C@z2" set ob_tcp_invited_nodes='%';
ob1.mysql alter system set ob_compaction_schedule_interval = '10s' tenant tenant1;
ob1.mysql alter system set merger_check_interval = '10s' tenant tenant1;
ob1.mysql alter system set_tp tp_name = "EN_LS_NOT_SEE_CS_REPLICA_FOR_COMPLEMENT_DAG", error_code = 4016, frequency = 1;

let $tenant_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name = "tenant1", tenant_id, 1);
let $resource_pool_id = deploy_get_value(ob1.select select resource_pool_id from oceanbase.__all_resource_pool where tenant_id = $tenant_id, resource_pool_id, 1);

--echo ===============================================================
--echo === Step 2: create table and do complement dag offline ddl ====
--echo ===============================================================
ob_connect(z1_obs0, ob1.z1.obs0, root@tenant1, , test, , USE_MYSQL_CONNECTOR);
ob_connect(z2_obs0, ob1.z2.obs0, root@tenant1, , test, , USE_MYSQL_CONNECTOR);

connection z1_obs0;
create table t1 (k int primary key, v1 int, v2 int, v3 int);
insert into t1 values (1, 2, 3, 4), (2, 3, 4, 5), (3, 4, 5, 6);
select * from t1 order by v1 asc;

# 1. ObDDLType::DDL_DROP_COLUMN
# in data_version >= 4.3.5.2, drop column is online ddl
connection z1_obs0;
let $table_id_before = deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where table_name = 't1', table_id, 1);
alter table t1 drop column v1;
select * from t1 order by v2 asc;
let $table_id_after = deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where table_name = 't1', table_id, 1);

connection z2_obs0;
set ob_route_policy=COLUMN_STORE_ONLY;
set ob_read_consistency = WEAK;
sleep 3;
select * from t1 order by v2 asc;
set ob_read_consistency = STRONG;
set ob_route_policy=READONLY_ZONE_FIRST;

# 2. ObDDLType::DDL_ADD_COLUMN_OFFLINE
# in data_version >= 4.3.5, only add stored generated column will be this ddl type. 
# but column redefinition cannot handle stored gen column, use table redefinition instead

# 3. ObDDLType::DDL_COLUMN_REDEFINITION
connection z1_obs0;
let $table_id_before = $table_id_after;
alter table t1 add column v4 double, drop column v3;
select * from t1 order by k asc;
let $table_id_after = deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where table_name = 't1', table_id, 1);
ob1.z1.obs0.check_rs_log_until_success -c "table_id:$table_id_before, association_table_id:$table_id_after.*table_name:\"t1\".*ddl_type:1009";

connection z2_obs0;
set ob_route_policy=COLUMN_STORE_ONLY;
set ob_read_consistency = WEAK;
sleep 3;
select * from t1 order by k asc;
set ob_read_consistency = STRONG;
set ob_route_policy=READONLY_ZONE_FIRST;

--echo =======================================================================
--echo === Step 3: stop errsim and all ddl type is DDL_TABLE_REDEFINITION ====
--echo =======================================================================
ob1.mysql alter system set_tp tp_name = "EN_LS_NOT_SEE_CS_REPLICA_FOR_COMPLEMENT_DAG", error_code = 4016, frequency = 0;
connection z1_obs0;
drop table t1;
create table t1 (k int primary key, v1 int, v2 int, v3 int);
insert into t1 values (1, 2, 3, 4), (2, 3, 4, 5), (3, 4, 5, 6);
select * from t1 order by v1 asc;

# 1. ObDDLType::DDL_DROP_COLUMN
# in data_version >= 4.3.5.2, drop column is online ddl
connection z1_obs0;
let $table_id_before = deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where table_name = 't1', table_id, 1);
alter table t1 drop column v1;
select * from t1 order by v2 asc;
let $table_id_after = deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where table_name = 't1', table_id, 1);

connection z2_obs0;
set ob_route_policy=COLUMN_STORE_ONLY;
set ob_read_consistency = WEAK;
sleep 3;
select * from t1 order by v2 asc;
set ob_read_consistency = STRONG;
set ob_route_policy=READONLY_ZONE_FIRST;

# 2. ObDDLType::DDL_COLUMN_REDEFINITION
connection z1_obs0;
let $table_id_before = $table_id_after;
alter table t1 add column v4 double, drop column v3;
select * from t1 order by k asc;
let $table_id_after = deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where table_name = 't1', table_id, 1);
ob1.z1.obs0.check_rs_log_until_success -c "table_id:$table_id_before, association_table_id:$table_id_after.*table_name:\"t1\".*ddl_type:1010";

connection z2_obs0;
set ob_route_policy=COLUMN_STORE_ONLY;
set ob_read_consistency = WEAK;
sleep 3;
select * from t1 order by k asc;
set ob_read_consistency = STRONG;
set ob_route_policy=READONLY_ZONE_FIRST;

