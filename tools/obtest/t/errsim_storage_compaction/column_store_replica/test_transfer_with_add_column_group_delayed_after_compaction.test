# owner: ouyanghongrong.oyh
# owner group: storage
# description: 连续做 2 次合并, 让第 2 次合并暂时失败, 再异步行转列加列 transfer, 确保 C 副本上 tablet 是列存 storage schema.
#              然后打开合并, 此时, 会是列存 tablet 行存的合并, C 副本应该处理这种场景, 还是构造列存的合并 DagNet 并正确执行.

ob1=OBI(cluster=2:2:2,proxy_num=0,init_unit_cpu=4);
ob1.reboot;
sleep 10;

--echo ===============================================================
--echo ========  Step 0: prepare env   ===============================
--echo ===============================================================

ob1.mysql alter resource unit sys_unit_config memory_size='2G';
ob1.mysql alter system set enable_rebalance = 'false';
ob1.mysql alter system set default_compress_func = 'none';
ob1.mysql alter system set debug_sync_timeout = '100000s';

let $proxy_ip = deploy_get_value(ob1.z1.obs0.ip);
let $proxy_port = deploy_get_value(ob1.z1.obs0.mysql_port);

connect(sys_conn, $proxy_ip, root@sys,,oceanbase, $proxy_port);

ob1.mysql alter system set ob_compaction_schedule_interval = '10s' tenant obtest;
ob1.mysql alter system set merger_check_interval = '10s' tenant obtest;

--echo ===============================================================
--echo ========  Step 1: create tenant   =============================
--echo ===============================================================

connection sys_conn;
source include/get_user_config.inc;
ob1.mysql create resource pool cs_replica_pool unit = "user_unit_config", unit_num = 1, zone_list = ('z1', 'z2', 'z3');
ob1.mysql create TENANT tenant1 resource_pool_list=('cs_replica_pool'), locality = "F@z1, F@z2, C@z3", primary_zone = "z1, z2" set ob_tcp_invited_nodes='%';

let $tenant_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name = "tenant1", tenant_id, 1);
let $resource_pool_id = deploy_get_value(ob1.select select resource_pool_id from oceanbase.__all_resource_pool where tenant_id = $tenant_id, resource_pool_id, 1);

--echo ===============================================================
--echo =======  Step 2: create table   ===============================
--echo ===============================================================

ob_connect(z1_obs0, ob1.z1.obs0, root@tenant1, , test, , USE_MYSQL_CONNECTOR);
ob_connect(z4_obs0, ob1.z3.obs0, root@tenant1, , test, , USE_MYSQL_CONNECTOR);
connection z1_obs0;

create table t1 (k int primary key, v1 int, v2 int) partition by hash(k) partitions 8;
create sequence seq cache 10000 noorder;
insert into t1 select seq.nextval, seq.nextval + 1, seq.nextval + 2 from table(generator(1000));
select * from t1 order by k limit 3;

--echo ===============================================================
--echo ===== Step 3: major freeze twice, and errsime second one  =====
--echo ===============================================================
connection sys_conn;
let $table_id =  deploy_get_value(ob1.select select table_id from __all_virtual_table where table_name = 't1', table_id, 1);
let $last_scn  = deploy_get_value(ob1.select select last_scn from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id = $tenant_id, last_scn, 1);
ob1.mysql alter system major freeze tenant tenant1;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_tablet_meta_table where compaction_scn != $last_scn and tenant_id = $tenant_id and tablet_id in (select distinct(tablet_id) from oceanbase.CDB_OB_TABLE_LOCATIONS where tenant_id = $tenant_id and table_id = $table_id), 24, 600;
ob1.check_until_timeout select count(*) from CDB_OB_MAJOR_COMPACTION where tenant_id = $tenant_id and GLOBAL_BROADCAST_SCN = LAST_SCN and GLOBAL_BROADCAST_SCN != $last_scn, 1, 600;
connection z1_obs0;
insert into t1 select seq.nextval, seq.nextval + 1, seq.nextval + 2 from table(generator(1000));
select * from t1 order by k limit 3;
ob1.mysql alter system minor freeze tenant tenant1;
sleep 5;
# EN_COMPACTION_CO_MERGE_SCHEDULE_FAILED = 4016, failure when schedule dag execue
ob1.mysql alter system set_tp tp_no = 714, error_code = 4016, frequency = 1;
let $last_scn  = deploy_get_value(ob1.select select last_scn from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id = $tenant_id, last_scn, 1);
ob1.mysql alter system major freeze tenant tenant1;


--echo ===============================================================
--echo ========  Step 4: alter primary zone(transfer)   ==============
--echo ===============================================================
connection z1_obs0;
alter table t1 add column group(each column) delayed;
alter table t1 add column v3 int;
# add column but no data in memtable
sleep 5;
ob1.mysql alter TENANT tenant1 primary_zone = "z1";
ob1.check_until_timeout select count(*) from CDB_OB_LS_LOCATIONS where tenant_id = $tenant_id and ls_id != 1 and zone = 'z3', 1, 60;
ob1.mysql alter system set_tp tp_no = 714, error_code = 4016, frequency = 0;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_tablet_meta_table where compaction_scn != $last_scn and tenant_id = $tenant_id and tablet_id in (select distinct(tablet_id) from oceanbase.CDB_OB_TABLE_LOCATIONS where tenant_id = $tenant_id and table_id = $table_id), 24, 600;
ob1.check_until_timeout select count(*) from CDB_OB_MAJOR_COMPACTION where tenant_id = $tenant_id and GLOBAL_BROADCAST_SCN = LAST_SCN and GLOBAL_BROADCAST_SCN != $last_scn, 1, 600;

let $last_scn  = deploy_get_value(ob1.select select last_scn from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id = $tenant_id, last_scn, 1);
sleep 5;
ob1.mysql alter system major freeze tenant tenant1;
ob1.check_until_timeout select count(*) from CDB_OB_MAJOR_COMPACTION where tenant_id = $tenant_id and GLOBAL_BROADCAST_SCN = LAST_SCN and GLOBAL_BROADCAST_SCN != $last_scn, 1, 600;