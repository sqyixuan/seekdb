# owner: lixia.yq
# owner group: storage
# Testing Case: restore with major ckm info

ob1=OBI(cluster=1, proxy_num=0);

source include/mini_ob_config.inc;
ob1.z1.obs0.set extra_config = "cache_wash_threshold='2G',_ob_minor_merge_schedule_interval='3s'";

let $backup_cluster_name = deploy_get_value(ob1.get_cluster_name);
let $backup_cluster_id = deploy_get_value(ob1.get_cluster_id);
let $backup_ip       = deploy_get_value(ob1.z1.obs0.ip);
let $backup_port     = deploy_get_value(ob1.z1.obs0.mysql_port);
let $restore_ip         = deploy_get_value(ob1.z1.obs0.ip);
let $restore_port       = deploy_get_value(ob1.z1.obs0.mysql_port);
let $backup_dest = deploy_get_value(ob1.get_backup_dest);
let $backup_oracle_tenant   = backup_oracle_tenant;
let $backup_mysql_tenant    = backup_mysql_tenant;
let $restore_oracle_tenant = restore_oracle_tenant;
let $restore_oracle_tenant_new = restore_oracle_tenant_new;
let $restore_mysql_tenant = restore_mysql_tenant;
let $log_backup_dest = deploy_get_value(ob1.get_log_backup_dest $backup_oracle_tenant);
let $data_backup_dest = deploy_get_value(ob1.get_data_backup_dest $backup_oracle_tenant);
let $restore_log_archive_dest = deploy_get_value(ob1.get_log_backup_dest $restore_oracle_tenant);

# 必须先stop掉老的，删除才能有效，不然可能会有残留。
ob1.force_stop;
ob1.clean_backup_dest;
ob1.reboot;

# 固定sys租户规格
ob1.mysql alter resource unit sys_unit_config memory_size='4G';

connect(backup_sys_conn, $backup_ip, root@sys,,oceanbase, $backup_port);
connection backup_sys_conn;
use oceanbase;

--disable_all_result_log
alter system set resource_hard_limit = 1000;
alter system set _restore_idle_time = '10s';
CREATE RESOURCE UNIT small_unit1 MIN_CPU=2, MAX_CPU=2, MEMORY_SIZE='4G';
--enable_all_result_log

ob1.mysql alter system set _backup_idle_time = '10s';
ob1.mysql alter system set merger_check_interval = '10s';
ob1.mysql alter system set enable_async_syslog=false;

--echo ===============================================================
--echo ==================     create tenant   ========================
--echo ===============================================================

ob1.mysql CREATE RESOURCE POOL resource_pool UNIT = "small_unit1", UNIT_NUM = 1, ZONE_LIST = ('z1');
ob1.mysql CREATE TENANT backup_oracle_tenant resource_pool_list=('resource_pool'), locality = "F@z1", primary_zone = "z1" set ob_tcp_invited_nodes='%', ob_compatibility_mode='oracle';
source include/check_schema_sync.inc;
connection backup_sys_conn;
let $backup_oracle_tenant_id = query_get_value(select tenant_id from oceanbase.__all_tenant where tenant_name='$backup_oracle_tenant', tenant_id, 1);
let $resource_pool_id = deploy_get_value(ob1.select select resource_pool_id from oceanbase.__all_resource_pool where tenant_id = $backup_oracle_tenant_id, resource_pool_id, 1);
let $src_ls_id = 1001;
--echo create tenant finished

--echo ===============================================================
--echo ==================     create table        ====================
--echo ===============================================================
ob_connect(sys_conn_oracle, ob1.z1.obs0, SYS@$backup_oracle_tenant, ,SYS, , USE_OB_CONNECTOR);
connection sys_conn_oracle;
set global wait_timeout = 288000;

--disable_all_result_log
eval alter system set data_backup_dest='$data_backup_dest';
eval alter system set log_archive_dest='location=$log_backup_dest';
ob1.mysql alter system set _enable_adaptive_compaction = false tenant backup_oracle_tenant;
ob1.mysql alter system set _ob_enable_truncate_partition_preserve_global_index=true tenant backup_oracle_tenant;
ob1.set_piece_switch_interval $backup_oracle_tenant_id 0 2m;
--enable_all_result_log

connection sys_conn_oracle;
create user test IDENTIFIED BY "test";
grant all on *.* to test WITH GRANT OPTION;
grant dba to test;
ob_connect(backup_oracle_conn, ob1.z1.obs0,TEST@$backup_oracle_tenant,test,test,,USE_OB_CONNECTOR);
connection backup_oracle_conn;

create table t_range_int_oracle(c1 int, c2 int, primary key(c1, c2)) partition by range(c2)
  (partition p0 values less than (100),
   partition p1 values less than (200),
   partition p2 values less than (300),
   partition p3 values less than (400),
   partition p4 values less than (MAXVALUE));
create index idx1 on t_range_int_oracle(c2) global partition by hash(c2) partitions 2;
create index idx2 on t_range_int_oracle(c1) global partition by hash(c1) partitions 3;

insert into t_range_int_oracle values(1, 1), (100, 100), (100, 200), (200, 200), (400, 400);

alter table t_range_int_oracle truncate partition p1, p2 update global indexes;

--echo ===============================================================
--echo ==================     start archive   ========================
--echo ===============================================================
ob1.mysql alter system archivelog;
ob1.check_until_timeout select status from oceanbase.CDB_OB_ARCHIVELOG where tenant_id=$backup_oracle_tenant_id, DOING, 600;

--echo ===============================================================
--echo ==================     start backup data   ====================
--echo ===============================================================
ob1.mysql alter system backup database;
ob1.check_until_timeout select count(*) c from __all_backup_job_history where tenant_id = 1, 1, 600;
ob1.check_until_timeout select result from oceanbase.CDB_OB_BACKUP_JOB_HISTORY where tenant_id = $backup_oracle_tenant_id, 0, 10;
ob1.check_until_timeout select result from oceanbase.CDB_OB_BACKUP_TASK_HISTORY where tenant_id = $backup_oracle_tenant_id, 0, 10;

sleep 20;
connect(backup_sys_conn, $backup_ip, root@sys,,oceanbase, $backup_port);
connection backup_sys_conn;
use oceanbase;
let $restore_path = $log_backup_dest,$data_backup_dest;


--echo ===============================================================
--echo ===============  CALC RESTORE POINT  ==========================
--echo ===============================================================
let $restore_checkpoint_ts = `select ceil(UNIX_TIMESTAMP(current_timestamp(6)) * 1000000)`;
ob1.check_until_timeout select floor(checkpoint_scn / 1000) > '$restore_checkpoint_ts' from CDB_OB_ARCHIVELOG, 1, 600;
let $restore_checkpoint = `select usec_to_time(floor(checkpoint_scn/1000)) from CDB_OB_ARCHIVELOG`;

connect(restore_sys_conn, $restore_ip, root@sys,,oceanbase, $restore_port);
connection restore_sys_conn;
use oceanbase;

--disable_all_result_log
alter system set resource_hard_limit = 1000;
alter system set _restore_idle_time = '10s';
CREATE RESOURCE UNIT small_unit2 MIN_CPU=2, MAX_CPU=2, MEMORY_SIZE='4G';
CREATE RESOURCE POOL small_pool_2 UNIT small_unit2, UNIT_NUM 1, ZONE_LIST ('z1');
--enable_all_result_log

--echo ===============================================================
--echo ===============  START RESTORE  ===============================
--echo ===============================================================
ob1.mysql alter system restore $restore_oracle_tenant from '$restore_path' until time='$restore_checkpoint' with 'pool_list=small_pool_2&primary_zone=z1';
sleep 10;
let $restore_tenant_id=deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name='$restore_oracle_tenant', tenant_id, 1);
ob1.check_until_timeout SELECT status FROM __all_tenant WHERE tenant_id = 1001, NORMAL, 600;
ob1.check_until_timeout select count(*) from __all_virtual_ls_meta_table where tenant_id = $restore_tenant_id and restore_status != 0, 0, 600;
ob1.check_until_timeout select status FROM __all_tenant WHERE tenant_id = $restore_tenant_id, NORMAL, 600;
ob1.check_until_timeout select count(*) FROM __all_restore_job, 0, 600;

ob1.mysql ALTER SYSTEM RECOVER STANDBY TENANT $restore_oracle_tenant UNTIL UNLIMITED;

ob_connect(restore_oracle_conn, ob1.z1.obs0, SYS@$restore_oracle_tenant, ,TEST, , USE_OB_CONNECTOR);

connection restore_oracle_conn;
select /*+INDEX(t_range_int_oracle primary)*/* from t_range_int_oracle order by c1,c2 asc;
select /*+INDEX(t_range_int_oracle idx1)*/* from t_range_int_oracle order by c1,c2 asc;

--echo ===============================================================
--echo ===============   START MAJOR   ===============================
--echo ===============================================================
ob1.mysql alter system set ob_compaction_schedule_interval = '10s' tenant all_user;
ob1.mysql alter system set merger_check_interval = '10s' tenant all_user;
ob1.mysql alter system set ob_compaction_schedule_interval = '10s' tenant all_user;
ob1.mysql alter system set merger_check_interval = '10s' tenant all_user;

ob1.mysql alter system major freeze tenant = '$backup_oracle_tenant';
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id = $backup_oracle_tenant_id and LAST_SCN != GLOBAL_BROADCAST_SCN , 1, 100;
let $major_scn1=deploy_get_value(ob1.select select GLOBAL_BROADCAST_SCN from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id=$backup_oracle_tenant_id, GLOBAL_BROADCAST_SCN, 1);
ob1.check_until_timeout select count(*)>0 as cnt from oceanbase.__all_virtual_tablet_compaction_history where type="MAJOR_MERGE" and compaction_scn=$major_scn1 and mds_filter_info!='' and is_full_merge=1, 1, 300;

# check major for standby tenant
sleep 30;
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id = $restore_tenant_id and LAST_SCN=$major_scn1, 1, 1800;

--echo ===============================================================
--echo ===============  QUERY PRIMARY & STANDBY  =====================
--echo ===============================================================
connection backup_oracle_conn;
insert into t_range_int_oracle values(300, 300), (600, 600);

alter table t_range_int_oracle truncate partition p3 update global indexes;

select /*+INDEX(t_range_int_oracle primary)*/* from t_range_int_oracle order by c1,c2 asc;
select /*+INDEX(t_range_int_oracle idx1)*/* from t_range_int_oracle order by c1,c2 asc;