# owner: lixia.yq
# owner group: storage 
# description: this case 1) DML on frozen memtable & DDL_memtable 2) test major check truncate defense
#

ob1=OBI(cluster=1:1,proxy_num=0,init_unit_cpu=0);
ob1.reboot;
sleep 10;
ob1.mysql alter system set debug_sync_timeout='100000s';
# set EN_ENABLE_SHARED_STORAGE_COLUMN_GROUP to enable column group under shared-storage mode
ob1.mysql alter system set_tp tp_no=2502, error_code=4016, frequency=1;

let $proxy_ip=deploy_get_value(ob1.z1.obs0.ip);
let $proxy_port=deploy_get_value(ob1.z1.obs0.mysql_port);

ob_connect(conn0, ob1.z1.obs0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);

connection conn0;
set SESSION ob_query_timeout=600 * 1000 * 1000;
set SESSION ob_trx_timeout=600 * 1000 * 1000;
set SESSION ob_trx_idle_timeout=600 * 1000 * 1000;
CREATE RESOURCE UNIT test_unit MAX_CPU=5, memory_size='10G';
CREATE RESOURCE POOL test_pool UNIT='test_unit', UNIT_NUM=1, ZONE_LIST=('z1', 'z2');
--disable_all_result_log
CREATE TENANT test_tenant RESOURCE_POOL_LIST=('test_pool'), primary_zone='z1', locality='F@z1,F@z2' SET VARIABLES ob_compatibility_mode='mysql', secure_file_priv='/',ob_tcp_invited_nodes='%';
--enable_all_result_log

let $__tenant_name__="test_tenant";
--source include/compaction/set_common_parameters_for_tenant.inc
ob1.mysql alter system set _enable_adaptive_compaction=false tenant test_tenant;
ob1.mysql alter system set _ob_enable_truncate_partition_preserve_global_index=true tenant test_tenant;

ob_connect(conn1, ob1.z1.obs0, root@test_tenant, , test, , USE_MYSQL_CONNECTOR);
connection conn1;
let $__timeout_def__=600 * 1000 * 1000;
eval set session ob_query_timeout=$__timeout_def__;
eval set session ob_trx_timeout=$__timeout_def__;
eval set session ob_trx_idle_timeout=$__timeout_def__;

create table test01(c1 int, c2 int, primary key(c1, c2)) partition by list(c1) (
    partition p0 values in ((100)),
    partition p1 values in ((200), (300)),
    partition p2 values in ((400)),
    partition p3 values in ((500), (700)),
    partition p4 values in (DEFAULT));

let $data_table_id=deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where table_name='test01', table_id, 1);
let $tenant_id=deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name='test_tenant', tenant_id, 1);

#########################################################################
# TEST_1: DML on DDL memtable
#########################################################################
# EN_DDL_MERGE_TASK_PROCESS=4023
ob1.mysql alter system set_tp tp_name="EN_DIRECT_LOAD_TASK_PROCESS", error_code=4023, frequency=1;

let $OBSERVER_DIR=deploy_get_value(ob1.z1.obs0.workdir);
let $HOST_IP=query_get_value(select host_ip() as host_ip, host_ip, 1);
let $DATA_FOLDER_NAME=obtest_data_direct_load_inc;

--disable_query_log
let $SCP_CMD=ssh $HOST_IP 'mkdir -p "$OBSERVER_DIR/$DATA_FOLDER_NAME"' && scp -r include/compaction/direct_load_data/* $HOST_IP:"$OBSERVER_DIR/$DATA_FOLDER_NAME";
exec $SCP_CMD;
--enable_query_log

connection conn1;
--disable_query_log
eval load data /*+ direct(true, 0, 'inc_replace') */ infile '$OBSERVER_DIR/$DATA_FOLDER_NAME/load_data_inc0.csv' into table test01 fields terminated by ',';
--enable_query_log

ob1.check_until_timeout select count(*)>0 as cnt from oceanbase.__all_virtual_table_mgr where tenant_id=$tenant_id and tablet_id in(select tablet_id from __all_virtual_tablet_to_ls where tenant_id=$tenant_id and table_id=$data_table_id) and table_type=4 and size>0, 1, 300;

####
# create global index after direct_load_data
####
connection conn1;
create unique index idx1 on test01(c2) global;
let $index_table_id=deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where data_table_id=$data_table_id, table_id, 1);
let $index_tablet_id=deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_tablet_to_ls where table_id=$index_table_id, tablet_id, 1);

connection conn1;
--error 1062
insert into test01 values(200, 200);

connection conn1;
alter table test01 truncate partition p0,p1,p2,p3,p4;
sleep 10;

connection conn1;
insert /*+ log_level(debug) */ into test01 values(200, 200);

# EN_DDL_MERGE_TASK_PROCESS=0
ob1.mysql alter system set_tp tp_name="EN_DIRECT_LOAD_TASK_PROCESS", error_code=4023, frequency=0;

#########################################################################
# TEST_2: DML on frozen memtable
#########################################################################
connection conn1;
--disable_query_log
let $cnt=1;
while($cnt < 30)
{
  eval insert into test01 values(1 + $cnt, 1 - $cnt), (100 + $cnt, 100 - $cnt), (200 + $cnt, 200 - $cnt), (200 + $cnt, 300 - $cnt), (400 + $cnt, 400 - $cnt);
  inc $cnt;
}
--enable_query_log

--enable_query_log
ob1.mysql set ob_global_debug_sync='reset';
ob1.mysql set ob_global_debug_sync='MERGE_TASK_PROCESS wait_for signal1';

ob1.mysql alter system minor freeze tenant='test_tenant';

ob1.check_until_timeout select count(*)>0 as cnt from oceanbase.__all_virtual_table_mgr where tenant_id=$tenant_id and tablet_id in(select tablet_id from __all_virtual_table where tenant_id=$tenant_id and table_id=$index_table_id) and is_active=1 and size>0, 0, 300;

connection conn1;
--error 1062
insert into test01 values(200, 200), (101, 100);

connection conn1;
alter table test01 truncate partition p0,p1,p2,p3,p4;
sleep 10;

connection conn1;
insert /*+ log_level(debug) */ into test01 values(200, 200), (101, 100);

ob1.mysql set ob_global_debug_sync='reset';
ob1.mysql set ob_global_debug_sync='now signal signal1';

#########################################################################
# TEST_3.1: truncate after RS launch new round major
#########################################################################
connection conn1;
alter table test01 truncate partition p1;

ob1.mysql alter system set_tp tp_name="EN_RS_CHECK_MERGE_PROGRESS", error_code=4023, frequency=1;
ob1.mysql alter system major freeze tenant='test_tenant';
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id=$tenant_id and LAST_SCN != GLOBAL_BROADCAST_SCN , 1, 100;
let $major_scn1=deploy_get_value(ob1.select select GLOBAL_BROADCAST_SCN from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id=$tenant_id, GLOBAL_BROADCAST_SCN, 1);

connection conn1;
alter table test01 truncate partition p4;
ob1.check_until_timeout select count(*) > 0 as c from __all_virtual_table_mgr where tenant_id=$tenant_id and tablet_id in (select tablet_id from __all_virtual_tablet_to_ls where tenant_id=$tenant_id and table_id=$data_table_id) and table_type=10 and end_log_scn>$major_scn1, 1, 100;

ob1.mysql alter system set_tp tp_name="EN_RS_CHECK_MERGE_PROGRESS", error_code=4023, frequency=0;
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id=$tenant_id and LAST_SCN != GLOBAL_BROADCAST_SCN , 0, 600;

#########################################################################
# TEST_3.2: truncate after index report checksum
#########################################################################
--disable_query_log
while($cnt < 60)
{
  eval insert into test01 values(1, 1 - $cnt), (100, 100 - $cnt), (200, 200 - $cnt), (400, 300 - $cnt), (500, 400 - $cnt);
  inc $cnt;
}
--enable_query_log

ob1.mysql alter system set_tp tp_name="EN_RS_CHECK_MERGE_PROGRESS", error_code=4023, frequency=1;
ob1.mysql alter system major freeze tenant='test_tenant';
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id=$tenant_id and LAST_SCN != GLOBAL_BROADCAST_SCN , 1, 100;
let $major_scn2=deploy_get_value(ob1.select select GLOBAL_BROADCAST_SCN from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id=$tenant_id, GLOBAL_BROADCAST_SCN, 1);

connection conn1;
ob1.check_until_timeout select count(*) as c from oceanbase.__all_virtual_tablet_replica_checksum where tenant_id=$tenant_id and tablet_id=$index_tablet_id and compaction_scn<$major_scn2, 0, 600;
alter table test01 drop partition p1;

ob1.mysql alter system set_tp tp_name="EN_RS_CHECK_MERGE_PROGRESS", error_code=4023, frequency=0;
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id=$tenant_id and LAST_SCN != GLOBAL_BROADCAST_SCN , 0, 600;
ob1.check_until_timeout select count(*) > 0 from __all_server_event_history where module='merge_errsim' and event='ignore_checksum_error' and value1=$tenant_id and value2="partition_num_changed", 1, 100;
#########################################################################
# TEST_4: follower read wrong mds info
#########################################################################
# EN_COMPACTION_SKIP_MDS_WHEN_CHECK=1
ob1.mysql alter system set_tp tp_name="EN_COMPACTION_SKIP_MDS_WHEN_CHECK", error_code=4023, frequency=1;

ob1.mysql alter system major freeze tenant='test_tenant';
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id=$tenant_id and LAST_SCN != GLOBAL_BROADCAST_SCN , 1, 100;
let $major_scn1=deploy_get_value(ob1.select select GLOBAL_BROADCAST_SCN from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id=$tenant_id, GLOBAL_BROADCAST_SCN, 1);
ob1.check_until_timeout select count(*)>0 as cnt from oceanbase.__all_virtual_dag_warning_history where tenant_id=$tenant_id, 1, 300;

ob1.mysql alter system set_tp tp_name="EN_COMPACTION_SKIP_MDS_WHEN_CHECK", error_code=4023, frequency=0;

ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id=$tenant_id and LAST_SCN != GLOBAL_BROADCAST_SCN , 0, 1200;

# read from tablet, tablet cache should show empty
ob1.mysql alter system set_tp tp_name = 'EN_COMPACTION_RECORD_TRUNCATE_CACHE', error_code = 4023, frequency = 1;

connection conn1;
insert /*+ log_level(debug) */ into test01 values(200, 200), (101, 100);
alter table test01 truncate partition p0,p2,p3,p4;
select/*+index(test01 idx1)*/ c1,c2 from test01 order by c1, c2 asc;

ob1.check_until_timeout select count(*) > 0 from oceanbase.__all_server_event_history where module='merge_errsim' and event='record_truncate_cache' and name4='cache_valid' and value4=1 and name5='cache_empty' and value5=0, 1, 60;

#########################################################################
# TEST_5: do not write mds in medium clog
#########################################################################
connection conn1;
alter table test01 truncate partition p4;
sleep 10;

# EN_COMPACTION_SKIP_WRITE_MDS_IN_MEDIUM_CLOG=1
ob1.mysql alter system set_tp tp_no=802, error_code=1, frequency=1;

ob1.mysql alter system major freeze tenant='test_tenant';
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id=$tenant_id and LAST_SCN != GLOBAL_BROADCAST_SCN , 1, 100;
let $major_scn2=deploy_get_value(ob1.select select GLOBAL_BROADCAST_SCN from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id=$tenant_id, GLOBAL_BROADCAST_SCN, 1);
ob1.check_until_timeout select count(*)>0 as cnt from oceanbase.__all_virtual_dag_warning_history where tenant_id=$tenant_id and ret="OB_ERR_SYS", 1, 300;

