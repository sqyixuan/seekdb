# owner: lixia.yq
# owner group: storage
# Testing Case: restore with major ckm info

ob1=OBI(cluster=1, proxy_num=0);
ob2=OBI(cluster=1, proxy_num=0);

source include/mini_ob_config.inc;
ob1.z1.obs0.set extra_config = "cache_wash_threshold='1G',_ob_minor_merge_schedule_interval='3s'";

let $backup_cluster_name = deploy_get_value(ob1.get_cluster_name);
let $backup_cluster_id = deploy_get_value(ob1.get_cluster_id);
let $backup_ip       = deploy_get_value(ob1.z1.obs0.ip);
let $backup_port     = deploy_get_value(ob1.z1.obs0.mysql_port);
let $restore_ip         = deploy_get_value(ob2.z1.obs0.ip);
let $restore_port       = deploy_get_value(ob2.z1.obs0.mysql_port);
let $backup_dest = deploy_get_value(ob1.get_backup_dest);
let $backup_oracle_tenant   = backup_oracle_tenant;
let $backup_mysql_tenant    = backup_mysql_tenant;
let $restore_oracle_tenant = restore_oracle_tenant;
let $restore_oracle_tenant_new = restore_oracle_tenant_new;
let $restore_mysql_tenant = restore_mysql_tenant;
let $log_backup_dest = deploy_get_value(ob1.get_log_backup_dest $backup_oracle_tenant);
let $data_backup_dest = deploy_get_value(ob1.get_data_backup_dest $backup_oracle_tenant);
let $restore_log_archive_dest = deploy_get_value(ob1.get_log_backup_dest $restore_oracle_tenant);

# 必须先stop掉老的，删除才能有效，不然可能会有残留。
ob1.force_stop;
ob1.clean_backup_dest;
ob1.reboot;

# 固定sys租户规格
ob1.mysql alter resource unit sys_unit_config memory_size='2G';

connect(backup_sys_conn, $backup_ip, root@sys,,oceanbase, $backup_port);
connection backup_sys_conn;
use oceanbase;

--disable_all_result_log
alter system set resource_hard_limit = 1000;
alter system set _restore_idle_time = '10s';
CREATE RESOURCE UNIT small_unit MIN_CPU=1, MAX_CPU=1, MEMORY_SIZE='4G';
CREATE RESOURCE POOL small_pool_1 UNIT small_unit, UNIT_NUM 1, ZONE_LIST ('z1');
--enable_all_result_log

ob1.mysql alter system set _backup_idle_time = '10s';
ob1.mysql alter system set merger_check_interval = '10s';
ob1.mysql alter system set enable_async_syslog=false;

--echo ===============================================================
--echo ==================     create tenant   ========================
--echo ===============================================================

ob1.mysql CREATE RESOURCE POOL resource_pool UNIT = "small_unit", UNIT_NUM = 1, ZONE_LIST = ('z1');
ob1.mysql CREATE TENANT backup_oracle_tenant resource_pool_list=('resource_pool'), locality = "F@z1", primary_zone = "z1" set ob_tcp_invited_nodes='%', ob_compatibility_mode='oracle';
source include/check_schema_sync.inc;
connection backup_sys_conn;
let $backup_oracle_tenant_id = query_get_value(select tenant_id from oceanbase.__all_tenant where tenant_name='$backup_oracle_tenant', tenant_id, 1);
let $resource_pool_id = deploy_get_value(ob1.select select resource_pool_id from oceanbase.__all_resource_pool where tenant_id = $backup_oracle_tenant_id, resource_pool_id, 1);
let $src_ls_id = 1001;
--echo create tenant finished

alter system set ob_compaction_schedule_interval = '10s' tenant all_user;


--echo ===============================================================
--echo ==================     create table T1/T3  ====================
--echo ===============================================================
ob_connect(sys_conn_oracle, ob1.z1.obs0, SYS@$backup_oracle_tenant, ,SYS, , USE_OB_CONNECTOR);
connection sys_conn_oracle;
set global wait_timeout = 288000;

--disable_all_result_log
eval alter system set data_backup_dest='$data_backup_dest';
eval alter system set log_archive_dest='location=$log_backup_dest';
ob1.set_piece_switch_interval $backup_oracle_tenant_id 0 2m;
--enable_all_result_log

connection sys_conn_oracle;
create user test IDENTIFIED BY "test";
grant all on *.* to test WITH GRANT OPTION;
grant dba to test;
ob_connect(backup_oracle_conn, ob1.z1.obs0,TEST@$backup_oracle_tenant,test,test,,USE_OB_CONNECTOR);
connection backup_oracle_conn;

create table t1(a int, b int, c int, CONSTRAINT "c1" PRIMARY KEY ("A"));
insert into t1(a, b) values(1, 1);
insert into t1(a, b) values(2, 2);
create table t3(c1 int, c2 int, c3 varchar(4096), c4 int);
let $t1_tablet_id=deploy_get_value(ob1.select select tablet_id from oceanbase.__all_virtual_table where table_name='t1', tablet_id, 1);
let $t3_tablet_id=deploy_get_value(ob1.select select tablet_id from oceanbase.__all_virtual_table where table_name='t3', tablet_id, 1);

--echo ===============================================================
--echo ==================     start archive   ========================
--echo ===============================================================
ob1.mysql alter system archivelog;
ob1.check_until_timeout select status from oceanbase.CDB_OB_ARCHIVELOG where tenant_id=$backup_oracle_tenant_id, DOING, 600;

ob1.mysql alter system major freeze tenant = '$backup_oracle_tenant';
ob1.check_until_timeout select (frozen_scn != last_scn) as result from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id=$backup_oracle_tenant_id, 1, 100;


# wait t1 finish output major_ckm_info
ob1.check_until_timeout select count(*) > 0 from oceanbase.__all_virtual_tablet_compaction_history where tenant_id=$backup_oracle_tenant_id and tablet_id=$t1_tablet_id and exec_mode="EXEC_MODE_OUTPUT", 1, 600;

ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_tablet_replica_checksum where tenant_id=$backup_oracle_tenant_id and compaction_scn=1, 0, 600;
ob1.mysql alter system suspend merge tenant = '$backup_oracle_tenant';
--echo ===============================================================
--echo ==================     start backup data   ====================
--echo ===============================================================
ob1.mysql alter system backup database;
ob1.check_until_timeout select count(*) c from __all_backup_job_history where tenant_id = 1, 1, 600;
ob1.check_until_timeout select result from oceanbase.CDB_OB_BACKUP_JOB_HISTORY where tenant_id = $backup_oracle_tenant_id, 0, 10;
ob1.check_until_timeout select result from oceanbase.CDB_OB_BACKUP_TASK_HISTORY where tenant_id = $backup_oracle_tenant_id, 0, 10;


ob1.mysql alter system resume merge tenant = '$backup_oracle_tenant';

ob1.check_until_timeout select (frozen_scn = last_scn) as result from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id=$backup_oracle_tenant_id, 1, 1200;
# write some data after data backup
begin;
insert into t1(a, b) values(3, 3);
insert into t1(a, b) values(4, 4);

update t1 set c=1;
update t1 set b=b+1;
commit;
begin;
update t1 set c=2;
delete from t1 where a=1;
commit;

create table t2(a int, b int, c int, CONSTRAINT "c2" PRIMARY KEY ("A"));
insert into t2(a, b) values(1, 1);
insert into t2(a, b) values(2, 2);
begin;
insert into t2(a, b) values(3, 3);
insert into t2(a, b) values(4, 4);
update t2 set c=1;
update t2 set b=b+1;
commit;

# another major merge
ob1.mysql alter system major freeze tenant = '$backup_oracle_tenant';
sleep 10;
let $major_scn=deploy_get_value(ob1.select select GLOBAL_BROADCAST_SCN from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id=$backup_oracle_tenant_id, GLOBAL_BROADCAST_SCN, 1);
ob1.check_until_timeout select (frozen_scn - last_scn) as result from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id=$backup_oracle_tenant_id, 0, 1200;
ob1.check_until_timeout select count(*) > 0 as c from oceanbase.__all_virtual_tablet_compaction_history where tenant_id=$backup_oracle_tenant_id and type="MAJOR_MERGE" and compaction_scn=$major_scn and exec_mode="EXEC_MODE_OUTPUT", 1, 10;


sleep 20;
connect(backup_sys_conn, $backup_ip, root@sys,,oceanbase, $backup_port);
connection backup_sys_conn;
use oceanbase;
let $restore_path = $log_backup_dest,$data_backup_dest;


--echo ===============================================================
--echo ===============  CALC RESTORE POINT  ==========================
--echo ===============================================================
ob2.reboot;
ob2.mysql alter resource unit sys_unit_config memory_size='2G';
let $restore_checkpoint_ts = `select ceil(UNIX_TIMESTAMP(current_timestamp(6)) * 1000000)`;
ob1.check_until_timeout select floor(checkpoint_scn / 1000) > '$restore_checkpoint_ts' from CDB_OB_ARCHIVELOG, 1, 600;
let $restore_checkpoint = `select usec_to_time(floor(checkpoint_scn/1000)) from CDB_OB_ARCHIVELOG`;

connect(restore_sys_conn, $restore_ip, root@sys,,oceanbase, $restore_port);
connection restore_sys_conn;
use oceanbase;

--disable_all_result_log
alter system set resource_hard_limit = 1000;
alter system set _restore_idle_time = '10s';
CREATE RESOURCE UNIT small_unit MIN_CPU=1, MAX_CPU=1, MEMORY_SIZE='4G';
CREATE RESOURCE POOL small_pool_2 UNIT small_unit, UNIT_NUM 1, ZONE_LIST ('z1');
--enable_all_result_log

--echo ===============================================================
--echo ===============  START RESTORE  ===============================
--echo ===============================================================
ob2.mysql alter system restore $restore_oracle_tenant from '$restore_path' until time='$restore_checkpoint' with 'pool_list=small_pool_2&primary_zone=z1';
sleep 10;
let $restore_tenant_id=deploy_get_value(ob2.select select tenant_id from oceanbase.__all_tenant where tenant_name='$restore_oracle_tenant', tenant_id, 1);
ob2.mysql alter system set ob_compaction_schedule_interval = '10s' tenant $restore_oracle_tenant;
ob2.check_until_timeout SELECT status FROM __all_tenant WHERE tenant_id = 1001, NORMAL, 600;
ob2.check_until_timeout select count(*) from __all_virtual_ls_meta_table where tenant_id = $restore_tenant_id and restore_status != 0, 0, 600;
ob2.check_until_timeout select status FROM __all_tenant WHERE tenant_id = $restore_tenant_id, NORMAL, 600;
ob2.check_until_timeout select count(*) FROM __all_restore_job, 0, 600;

ob_connect(restore_oracle_conn, ob2.z1.obs0, SYS@$restore_oracle_tenant, ,TEST, , USE_OB_CONNECTOR);
select * from t1;
select * from t2;

ob2.mysql ALTER SYSTEM ACTIVATE STANDBY TENANT $restore_oracle_tenant;
ob2.check_until_timeout select count(*) > 0 as c from oceanbase.DBA_OB_TENANTS where tenant_id=$restore_tenant_id and TENANT_ROLE = "PRIMARY", 1, 1200;
ob2.mysql alter system set ob_compaction_schedule_interval = '10s' tenant $restore_oracle_tenant;

ob2.check_until_timeout select last_scn from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id=$restore_tenant_id, 1, 200;
ob2.check_until_timeout select (frozen_scn - last_scn) as result from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id=$restore_tenant_id, 0, 1200;

ob2.mysql alter system major freeze tenant = '$restore_oracle_tenant';
sleep 10;
ob2.check_until_timeout select (frozen_scn - last_scn) as result from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id=$restore_tenant_id, 0, 1200;