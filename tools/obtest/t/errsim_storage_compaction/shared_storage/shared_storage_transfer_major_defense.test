# owner: lixia.yq
# owner group: storage [shared_storage]
# description: this case is use for transfer & major defense
#

ob1=OBI(cluster=1:1:1,proxy_num=0,init_unit_cpu=5);
ob1.reboot;
sleep 10;

ob1.mysql alter system set enable_rebalance='false';
ob1.mysql alter system set default_compress_func='none';
ob1.mysql alter system set debug_sync_timeout='100000s';
# set EN_ENABLE_SHARED_STORAGE_COLUMN_GROUP to enable column group under shared-storage mode
ob1.mysql alter system set_tp tp_no = 2502, error_code = 4016, frequency = 1;

let $proxy_ip=deploy_get_value(ob1.z1.obs0.ip);
let $proxy_port=deploy_get_value(ob1.z1.obs0.mysql_port);

ob1.mysql alter system set ob_compaction_schedule_interval='10s' tenant obtest;
ob1.mysql alter system set merger_check_interval='10s' tenant obtest;
ob1.mysql alter system set compaction_low_thread_score=10 tenant obtest;

ob_connect(conn_mysql, ob1.z1.obs0, root@obtest, , test, , USE_MYSQL_CONNECTOR);
connection conn_mysql;
create table test01(c1 int, c2 int, c3 varchar(40960), c4 varchar(40960)) compression= 'none';
create table test02(c0 varchar(4096), c1 int, c2 int, c3 int, c4 varchar(40960), c5 varchar(40960), c6 int, c7 int, c8 int, c9 int, c10 int, c11 int, c12 int, primary key(c0, c1)) with column group (all columns, each column);
create table test03(c0 varchar(4096), c1 int, c2 int, c3 int, c4 varchar(40960), c5 varchar(40960), c6 int, c7 int, c8 int, c9 int, c10 int, c11 int, c12 int, primary key(c0, c1)) with column group (each column);

let $tablet_id=deploy_get_value(ob1.select select tablet_id from oceanbase.__all_virtual_table where table_name='test01', tablet_id, 1);
let $tablet_id2=deploy_get_value(ob1.select select tablet_id from oceanbase.__all_virtual_table where table_name='test02', tablet_id, 1);
let $tenant_id=deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name='obtest', tenant_id, 1);

#########################################################################
# TEST_1: disable major merge when transfer task exist
#########################################################################

connection conn_mysql;
--disable_query_log
let $cnt=0;
while($cnt < 100)
{
  eval insert into test01 values($cnt, $cnt, repeat('oceanbase', 4096), repeat('wakakakaka', 4096));
  eval insert into test02 values(repeat('k', 4096), $cnt, 2, 3, repeat('oceanbase', 4096), repeat('wakakakaka', 4096), 6, 7, 8, 9, 10, 11, 12);
  eval insert into test03 values(repeat('k', 4096), $cnt, 2, 3, repeat('oceanbase', 4096), repeat('wakakakaka', 4096), 6, 7, 8, 9, 10, 11, 12);
  inc $cnt;
}
--enable_query_log

#transfer tablet to another ls
let $table_id=deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where table_name='test03', table_id, 1);
let $object_id=deploy_get_value(ob1.select select object_id from oceanbase.cdb_ob_table_locations where table_id = $table_id limit 1, object_id, 1);
let $transfer_tablet_id=deploy_get_value(ob1.select select tablet_id from oceanbase.__all_virtual_table where table_name='test03', tablet_id, 1);
let $ls_id=deploy_get_value(ob1.select select ls_id from oceanbase.__all_virtual_tablet_to_ls where tablet_id = $transfer_tablet_id, ls_id, 1);
let $dst_ls_id=deploy_get_value(ob1.select select ls_id from oceanbase.__all_virtual_ls_info where ls_id > 1 and ls_id != $ls_id limit 1, ls_id, 1);

ob1.mysql ALTER SYSTEM TRANSFER PARTITION TABLE_ID=$table_id, OBJECT_ID=$object_id  TO LS $dst_ls_id tenant 'obtest';
ob1.check_until_timeout select count(*) > 0 from oceanbase.__all_virtual_balance_job, 1, 200;

connection conn_mysql;
--error 4017
alter system major freeze;

ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_balance_job, 0, 600;
ob1.check_until_timeout select ls_id=$dst_ls_id from oceanbase.__all_virtual_tablet_to_ls where tablet_id = $transfer_tablet_id, 1, 200;

ob1.mysql alter system major freeze tenant = 'obtest';
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id = $tenant_id and LAST_SCN != GLOBAL_BROADCAST_SCN , 1, 100;
let $major_scn1=deploy_get_value(ob1.select select GLOBAL_BROADCAST_SCN from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id=$tenant_id, GLOBAL_BROADCAST_SCN, 1);
#########################################################################
# TEST_2: disable transfer when major running
#########################################################################

ob1.mysql alter system suspend merge tenant = 'obtest';
let $ls_id=deploy_get_value(ob1.select select ls_id from oceanbase.__all_virtual_tablet_to_ls where tablet_id = $transfer_tablet_id, ls_id, 1);
let $dst_ls_id=deploy_get_value(ob1.select select ls_id from oceanbase.__all_virtual_ls_info where ls_id > 1 and ls_id != $ls_id limit 1, ls_id, 1);

# report wait for major
ob1.mysql ALTER SYSTEM TRANSFER PARTITION TABLE_ID=$table_id, OBJECT_ID=$object_id  TO LS $dst_ls_id tenant 'obtest';
ob1.check_until_timeout select count(*) from CDB_OB_TRANSFER_TASKS where tenant_id = $tenant_id and status = 'INIT' and comment = 'Wait for tenant major compaction to end', 1, 60;

# wait major finish
ob1.mysql alter system resume merge tenant = 'obtest';
source include/compaction/wait_tenant_major_finish_on_ss.inc;

ob1.check_until_timeout select ls_id=$dst_ls_id from oceanbase.__all_virtual_tablet_to_ls where tablet_id = $transfer_tablet_id, 1, 600;

#########################################################################
# TEST_3: test sstable merge history
#########################################################################
let $total_row_count=deploy_get_value(ob1.select select total_row_count from oceanbase.__all_virtual_tablet_compaction_history where tablet_id =$tablet_id and type = "MAJOR_MERGE" and compaction_scn=$major_scn1 and exec_mode="EXEC_MODE_OUTPUT" limit 1, total_row_count, 1);
if ($total_row_count != 100) {
  --echo "wrong row count", $total_row_count
}

let $multiplexed_macro_block_count=deploy_get_value(ob1.select select multiplexed_macro_block_count from oceanbase.__all_virtual_tablet_compaction_history where tablet_id =$tablet_id and type = "MAJOR_MERGE" and compaction_scn=$major_scn1 and exec_mode="EXEC_MODE_OUTPUT" limit 1, multiplexed_macro_block_count, 1);
if ($multiplexed_macro_block_count != 0) {
  --echo "wrong multiplexed_macro_block_count", $multiplexed_macro_block_count
}

