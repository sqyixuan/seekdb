# owner: lixia.yq
# owner group: storage [shared_storage]
# description: this case is use for test parallel major merge
#

ob1=OBI(cluster=1:1:1,proxy_num=0,init_unit_cpu=5);
ob1.reboot;
sleep 10;

ob1.mysql alter system set enable_rebalance='false';
ob1.mysql alter system set default_compress_func='none';
ob1.mysql alter system set debug_sync_timeout='100000s';
# set EN_ENABLE_SHARED_STORAGE_COLUMN_GROUP to enable column group under shared-storage mode
ob1.mysql alter system set_tp tp_no = 2502, error_code = 4016, frequency = 1;

let $proxy_ip=deploy_get_value(ob1.z1.obs0.ip);
let $proxy_port=deploy_get_value(ob1.z1.obs0.mysql_port);

connect(sys_conn, $proxy_ip, root@obtest,,oceanbase, $proxy_port);

ob1.mysql alter system set major_freeze_duty_time = 'Disable' tenant sys;
ob1.mysql alter system set major_freeze_duty_time = 'Disable' tenant all_user;
ob1.mysql alter system set major_freeze_duty_time = 'Disable' tenant all_meta;
--source include/compaction/set_common_parameters.inc

ob_connect(conn_mysql, ob1.z1.obs0, root@obtest, , test, , USE_MYSQL_CONNECTOR);
connection conn_mysql;
create table test01(c1 int, c2 int, c3 varchar(40960), c4 varchar(40960)) compression= 'none';
create table test02(c0 varchar(4096), c1 int, c2 int, c3 int, c4 varchar(40960), c5 varchar(40960), c6 int, c7 int, c8 int, c9 int, c10 int, c11 int, c12 int, primary key(c0, c1)) with column group (all columns, each column);
create table test03(c0 varchar(4096), c1 int, c2 int, c3 int, c4 varchar(40960), c5 varchar(40960), c6 int, c7 int, c8 int, c9 int, c10 int, c11 int, c12 int, primary key(c0, c1)) with column group (each column);
create table test04(c0 varchar(4096), c1 int, c2 int, c3 int, c4 varchar(40960), c5 varchar(40960), c6 int, c7 int, c8 int, c9 int, c10 int, c11 int, c12 int, primary key(c0, c1)) with column group (each column);

let $tablet_id=deploy_get_value(ob1.select select tablet_id from oceanbase.__all_virtual_table where table_name='test01', tablet_id, 1);
let $tablet_id2=deploy_get_value(ob1.select select tablet_id from oceanbase.__all_virtual_table where table_name='test02', tablet_id, 1);
let $tenant_id=deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name='obtest', tenant_id, 1);
let $tablet_id4=deploy_get_value(ob1.select select tablet_id from oceanbase.__all_virtual_table where table_name='test04', tablet_id, 1);

let $macro_step_size = 33554432;
#########################################################################
# TEST_1: insert 100 rows & check major parallel for user tablet
#########################################################################

connection conn_mysql;
--disable_query_log
let $cnt=0;
while($cnt < 100)
{
  eval insert into test01 values($cnt, $cnt, repeat('oceanbase', 4096), repeat('wakakakaka', 4096));
  eval insert into test02 values(repeat('k', 4096), $cnt, 2, 3, repeat('oceanbase', 4096), repeat('wakakakaka', 4096), 6, 7, 8, 9, 10, 11, 12);
  eval insert into test03 values(repeat('k', 4096), $cnt, 2, 3, repeat('oceanbase', 4096), repeat('wakakakaka', 4096), 6, 7, 8, 9, 10, 11, 12);
  inc $cnt;
}
--enable_query_log

ob1.mysql alter system minor freeze tenant = 'obtest';
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table_mgr where table_type = 0 and is_active = 0 and tenant_id=$tenant_id and tablet_id in ($tablet_id, $tablet_id2), 0, 600;

# EN_COMPACTION_MEDIUM_INIT_PARALLEL_RANGE = 4023
ob1.mysql alter system set_tp tp_no = 715, error_code = 4023, frequency = 1;

ob1.mysql alter system major freeze tenant = 'obtest';
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id = $tenant_id and LAST_SCN != GLOBAL_BROADCAST_SCN , 1, 100;
let $major_scn=deploy_get_value(ob1.select select GLOBAL_BROADCAST_SCN from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id=$tenant_id, GLOBAL_BROADCAST_SCN, 1);
ob1.check_until_timeout select count(*) > 0 as c from oceanbase.__all_virtual_tablet_compaction_history where tenant_id=$tenant_id and type="MAJOR_MERGE" and compaction_scn=$major_scn and tablet_id=$tablet_id and exec_mode="EXEC_MODE_OUTPUT" and parallel_degree > 1 and macro_id_list like "%$macro_step_size%", 1, 600;
ob1.check_until_timeout select count(*) > 0 as c from oceanbase.__all_virtual_tablet_compaction_history where tenant_id=$tenant_id and type="MAJOR_MERGE" and compaction_scn=$major_scn and tablet_id=$tablet_id2 and exec_mode="EXEC_MODE_OUTPUT" and parallel_degree > 1 and macro_id_list like "%$macro_step_size%", 1, 600;
source include/compaction/wait_tenant_major_finish_on_ss.inc;

#########################################################################
# TEST_2: insert another 100 rows & check major parallel for user tablet
#########################################################################

connection conn_mysql;
--disable_query_log
let $cnt=0;
while($cnt < 200)
{
  eval insert into test01 values($cnt, $cnt, repeat('oceanbase', 4096), repeat('wakakakaka', 4096));
  eval insert into test02 values(repeat('k', 4096), $cnt + 100, 2, 3, repeat('oceanbase', 4096), repeat('wakakakaka', 4096), 6, 7, 8, 9, 10, 11, 12);
  eval insert into test03 values(repeat('k', 4096), $cnt + 100, 2, 3, repeat('oceanbase', 4096), repeat('wakakakaka', 4096), 6, 7, 8, 9, 10, 11, 12);
  inc $cnt;
}
--enable_query_log

ob1.mysql alter system minor freeze tenant = 'obtest';
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table_mgr where table_type = 0 and is_active = 0 and tenant_id=$tenant_id and tablet_id in ($tablet_id, $tablet_id2), 0, 300;

ob1.mysql alter system major freeze tenant = 'obtest';
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id = $tenant_id and LAST_SCN != GLOBAL_BROADCAST_SCN , 1, 100;
let $major_scn2=deploy_get_value(ob1.select select GLOBAL_BROADCAST_SCN from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id=$tenant_id, GLOBAL_BROADCAST_SCN, 1);

ob1.check_until_timeout select count(*) > 0 as c from oceanbase.__all_virtual_tablet_compaction_history where tenant_id=$tenant_id and type="MAJOR_MERGE" and compaction_scn=$major_scn2 and tablet_id=$tablet_id and exec_mode="EXEC_MODE_OUTPUT" and parallel_degree > 1, 1, 100;
ob1.check_until_timeout select count(*) > 0 as c from oceanbase.__all_virtual_tablet_compaction_history where tenant_id=$tenant_id and type="MAJOR_MERGE" and compaction_scn=$major_scn2 and tablet_id=$tablet_id2 and exec_mode="EXEC_MODE_OUTPUT" and parallel_degree > 1, 1, 600;

source include/compaction/wait_tenant_major_finish_on_ss.inc;

connection conn_mysql;
select count(*) from test01;
select count(*) from test02 where c1 = 100;
select count(*) from test01 where c1 = 80;


# just make sure all tablet have kept old version major
--disable_query_log
eval select count(*) from test01  as of snapshot $major_scn where c1 = 100;
eval select count(*) from test02  as of snapshot $major_scn where c1 = 80;
--enable_query_log

ob1.mysql alter system major freeze tenant = 'obtest';
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id = $tenant_id and LAST_SCN != GLOBAL_BROADCAST_SCN , 1, 100;
let $major_scn3=deploy_get_value(ob1.select select GLOBAL_BROADCAST_SCN from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id=$tenant_id, GLOBAL_BROADCAST_SCN, 1);

source include/compaction/wait_tenant_major_finish_on_ss.inc;
ob1.check_until_timeout select count(*) > 0 as c from oceanbase.__all_virtual_table_mgr where tenant_id=$tenant_id and table_type=17 and tablet_id=$tablet_id4 and end_log_scn=$major_scn3, 1, 10;