# owner: lixia.yq
# owner group: storage
# description: this case test ls leader have old obj
#
ob1=OBI(cluster=1:1:1,proxy_num=0,init_unit_cpu=5);
ob1.reboot;
sleep 10;

let $proxy_ip=deploy_get_value(ob1.z1.obs0.ip);
let $proxy_port=deploy_get_value(ob1.z1.obs0.mysql_port);
let $z1_port=deploy_get_value(ob1.z1.obs0.port);

connect(sys_conn, $proxy_ip, root@obtest,,oceanbase, $proxy_port);

--source include/compaction/set_common_parameters.inc

ob_connect(conn_mysql, ob1.z1.obs0, root@obtest, , test, , USE_MYSQL_CONNECTOR);
connection conn_mysql;
--source include/compaction/create_table_for_compaction.inc

let $__cnt__=0;
let $__row_cnt__=50;
--source include/compaction/insert_rows_for_compaction.inc

ob1.mysql alter system major freeze tenant='obtest';
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where LAST_SCN != GLOBAL_BROADCAST_SCN , 1, 100;
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where LAST_SCN != GLOBAL_BROADCAST_SCN , 0, 1200;

ob1.mysql alter system set_tp tp_name = EN_FALLBACK_COMPACTION_SCN, error_code = 4023, frequency = 1;

let $__row_cnt__=100;
--source include/compaction/insert_rows_for_compaction.inc

ob1.mysql alter system major freeze tenant='obtest';
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where LAST_SCN != GLOBAL_BROADCAST_SCN , 1, 100;
ob1.mysql alter system suspend merge tenant='obtest';

ob1.mysql alter system set_tp tp_name = EN_FALLBACK_COMPACTION_SCN, error_code = 4023, frequency = 0;
ob1.mysql alter system resume merge tenant='obtest';
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where LAST_SCN != GLOBAL_BROADCAST_SCN , 0, 1200;