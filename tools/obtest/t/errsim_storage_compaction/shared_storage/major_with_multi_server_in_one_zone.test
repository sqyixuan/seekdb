# owner: lixia.yq
# owner group: storage
# description: test multi server in one zone
# 
ob1=OBI(cluster=2:2,proxy_num=0,init_unit_cpu=5);
ob1.reboot;
sleep 10;

ob1.mysql alter system set enable_rebalance = 'false';
ob1.mysql alter system set default_compress_func = 'none';
ob1.mysql alter system set debug_sync_timeout = '100000s';
ob1.mysql alter system set undo_retention = 0;
ob1.mysql set global recyclebin = OFF;
# set EN_ENABLE_SHARED_STORAGE_COLUMN_GROUP to enable column group under shared-storage mode
ob1.mysql alter system set_tp tp_no = 2502, error_code = 4016, frequency = 1;

let $proxy_ip = deploy_get_value(ob1.z1.obs0.ip);
let $proxy_port = deploy_get_value(ob1.z1.obs0.mysql_port);

connect(sys_conn, $proxy_ip, root,,oceanbase, $proxy_port);

connection sys_conn;
CREATE RESOURCE UNIT large_unit_1 MAX_CPU=5, MEMORY_SIZE='5G';
CREATE RESOURCE POOL large_pool_1 UNIT large_unit_1, UNIT_NUM 2, ZONE_LIST ('z1','z2');

--disable_all_result_log
CREATE TENANT test_tenant RESOURCE_POOL_LIST = ('large_pool_1'), locality='F@z1,F@z2', primary_zone='RANDOM' set ob_tcp_invited_nodes='%', ob_compatibility_mode='mysql';
--enable_all_result_log

ob1.mysql alter system set ob_compaction_schedule_interval = '10s' tenant test_tenant;
ob1.mysql alter system set merger_check_interval = '10s' tenant test_tenant;

ob_connect(conn_mysql, ob1.z1.obs0, root@test_tenant, , test, , USE_MYSQL_CONNECTOR);
connection conn_mysql;

create table test01(c1 int, c2 int, c3 varchar(40960)) compression= 'none';
create table test02(c0 varchar(4096), c1 int, c2 int, c3 int, c4 varchar(40960), c5 varchar(40960), c6 int, c7 int, c8 int, c9 int, c10 int, c11 int, c12 int, primary key(c0, c1)) with column group (all columns, each column);
create table test03(c0 varchar(4096), c1 int, c2 int, c3 int, c4 varchar(40960), c5 varchar(40960), c6 int, c7 int, c8 int, c9 int, c10 int, c11 int, c12 int, primary key(c0, c1)) with column group (each column);

let $tablet_id=deploy_get_value(ob1.select select tablet_id from oceanbase.__all_virtual_table where table_name='test01', tablet_id, 1);
let $tablet_id2=deploy_get_value(ob1.select select tablet_id from oceanbase.__all_virtual_table where table_name='test02', tablet_id, 1);
let $tenant_id=deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name='test_tenant', tenant_id, 1);
let $ls_id=deploy_get_value(ob1.select select ls_id from oceanbase.__all_virtual_tablet_to_ls where tenant_id=$tenant_id and tablet_id=$tablet_id, ls_id, 1);

# do not have all ls in tenant rs server
let $other_svr_ip=deploy_get_value(ob1.select select svr_ip from oceanbase.__all_server where zone=(select zone from __all_server where with_rootserver=1) and with_rootserver = 0 order by svr_port asc, svr_ip, 1);
let $other_svr_port=deploy_get_value(ob1.select select svr_port from oceanbase.__all_server where zone=(select zone from __all_server where with_rootserver=1) and with_rootserver = 0 order by svr_port asc, svr_port, 1);
ob1.check_until_timeout select count(*) > 0 as c from oceanbase.__all_virtual_ls_info where tenant_id=$tenant_id and svr_ip='$other_svr_ip' and svr_port=$other_svr_port, 1, 100;

#########################################################################
# TEST_1: insert row and major freeze
#########################################################################
connection conn_mysql;
--disable_query_log
let $cnt=1;
while($cnt < 10)
{
  eval insert into test01 values($cnt, $cnt, repeat('oceanbase', 4096));
  eval insert into test02 values(repeat('k', 4096), $cnt, 2, 3, repeat('oceanbase', 4096), repeat('wakakakaka', 4096), 6, 7, 8, 9, 10, 11, 12);
  eval insert into test03 values(repeat('k', 4096), $cnt, 2, 3, repeat('oceanbase', 4096), repeat('wakakakaka', 4096), 6, 7, 8, 9, 10, 11, 12);
  inc $cnt;
}
--enable_query_log

ob1.mysql alter system major freeze tenant = 'test_tenant';
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id = $tenant_id and LAST_SCN != GLOBAL_BROADCAST_SCN , 1, 100;
let $major_scn=deploy_get_value(ob1.select select GLOBAL_BROADCAST_SCN from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id=$tenant_id, GLOBAL_BROADCAST_SCN, 1);
ob1.check_until_timeout select count(*) > 0 as c from oceanbase.__all_virtual_tablet_compaction_info where tenant_id=$tenant_id and max_received_scn=$major_scn and tablet_id=$tablet_id, 1, 100;

#########################################################################
# TEST_2: no changes, table should be skipped merge
#########################################################################
ob1.mysql alter system major freeze tenant = 'test_tenant';
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id = $tenant_id and LAST_SCN != GLOBAL_BROADCAST_SCN , 1, 100;
let $major_scn2=deploy_get_value(ob1.select select GLOBAL_BROADCAST_SCN from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id=$tenant_id, GLOBAL_BROADCAST_SCN, 1);
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id = $tenant_id and LAST_SCN != GLOBAL_BROADCAST_SCN , 0, 600;

ob1.check_until_timeout select count(*) > 0 as c from oceanbase.__all_virtual_table_mgr where tenant_id=$tenant_id and table_type=10 and tablet_id=$tablet_id and end_log_scn=$major_scn2, 1, 10;
ob1.check_until_timeout select count(*) > 0 as c from oceanbase.__all_virtual_table_mgr where tenant_id=$tenant_id and table_type=17 and tablet_id=$tablet_id2 and end_log_scn=$major_scn2, 1, 10;
