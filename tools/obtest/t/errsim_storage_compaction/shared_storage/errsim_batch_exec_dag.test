# owner: lixia.yq
# owner group: storage [shared_storage]
# description: this case is use for test ddl & major
#

ob1=OBI(cluster=1:1:1,proxy_num=0,init_unit_cpu=5);
ob1.reboot;
sleep 10;

ob1.mysql alter system set enable_rebalance='false';
ob1.mysql alter system set default_compress_func='none';
ob1.mysql alter system set debug_sync_timeout='100000s';
# set EN_ENABLE_SHARED_STORAGE_COLUMN_GROUP to enable column group under shared-storage mode
ob1.mysql alter system set_tp tp_no = 2502, error_code = 4016, frequency = 1;

let $proxy_ip=deploy_get_value(ob1.z1.obs0.ip);
let $proxy_port=deploy_get_value(ob1.z1.obs0.mysql_port);

connect(sys_conn, $proxy_ip, root@obtest,,oceanbase, $proxy_port);

ob1.mysql alter system set ob_compaction_schedule_interval='10s' tenant obtest;
ob1.mysql alter system set merger_check_interval='10s' tenant obtest;
ob1.mysql alter system set compaction_low_thread_score=10 tenant obtest;

ob_connect(conn_mysql, ob1.z1.obs0, root@obtest, , test, , USE_MYSQL_CONNECTOR);
connection conn_mysql;
create table test01(c1 int, c2 int, c3 varchar(40960), c4 varchar(40960)) compression= 'none';
create index idx01 on test01(c2) partition by hash(c2) partitions 2;
create table test02(c0 varchar(4096), c1 int, c2 int, c3 int, c4 varchar(40960), c5 varchar(40960), c6 int, c7 int, c8 int, c9 int, c10 int, c11 int, c12 int, primary key(c0, c1)) with column group (all columns, each column);
create table test03(c0 varchar(4096), c1 int, c2 int, c3 int, c4 varchar(40960), c5 varchar(40960), c6 int, c7 int, c8 int, c9 int, c10 int, c11 int, c12 int, primary key(c0, c1)) with column group (each column);
create table test04(c1 int, c2 int, c3 varchar(40960), c4 varchar(40960)) compression= 'none' partition by range(c2) (partition p1 values less than (100), partition p2 values less than (200), partition p3 values less than MAXVALUE);
create index idx04 on test04(c2) partition by key(c2) partitions 3;
create table test05(c1 int, c2 int, c3 varchar(40960), c4 varchar(40960)) compression= 'none';

let $tenant_id=deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name='obtest', tenant_id, 1);
#########################################################################
# TEST_1: errsim in verify ckm dag
#########################################################################

# EN_VERIFY_CKM_DAG_FAILED = 4016
ob1.mysql alter system set_tp tp_name="EN_VERIFY_CKM_DAG_FAILED", error_code=4016, frequency=1;

connection conn_mysql;
--disable_query_log
let $cnt=1;
while($cnt < 10)
{
  eval insert into test01 values($cnt, $cnt, repeat('oceanbase', 4096), repeat('oceanbase', 4096));
  eval insert into test02 values(repeat('k', 4096), $cnt, 2, 3, repeat('oceanbase', 4096), repeat('wakakakaka', 4096), 6, 7, 8, 9, 10, 11, 12);
  eval insert into test03 values(repeat('k', 4096), $cnt, 2, 3, repeat('oceanbase', 4096), repeat('wakakakaka', 4096), 6, 7, 8, 9, 10, 11, 12);
  inc $cnt;
}
--enable_query_log

ob1.mysql alter system major freeze tenant obtest;
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id=$tenant_id and LAST_SCN != GLOBAL_BROADCAST_SCN , 1, 100;
let $major_scn=deploy_get_value(ob1.select select GLOBAL_BROADCAST_SCN from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id=$tenant_id, GLOBAL_BROADCAST_SCN, 1);

ob1.check_until_timeout select count(*) > 0 as c from oceanbase.__all_virtual_dag_warning_history where tenant_id=$tenant_id and type="VERIFY_CKM", 1, 600;

# clear EN_VERIFY_CKM_DAG_FAILED
ob1.mysql alter system set_tp tp_name="EN_VERIFY_CKM_DAG_FAILED", error_code=4016, frequency=0;
ob1.check_until_timeout select count(*) > 0 as c from __all_virtual_tablet_compaction_history where tenant_id=$tenant_id and tablet_id=0 and comments like "%VERIFY_CKM%", 1, 200;
source include/compaction/wait_tenant_major_finish_on_ss.inc;

#########################################################################
# TEST_2: errsim update skip major tablet
#########################################################################

# EN_UPDATE_SKIP_MAJOR_DAG_FAILED = 4016
ob1.mysql alter system set_tp tp_name="EN_UPDATE_SKIP_MAJOR_DAG_FAILED", error_code=4016, frequency=1;

connection conn_mysql;
--disable_query_log
while($cnt < 30)
{
  eval insert into test01 values($cnt, $cnt, repeat('oceanbase', 4096), repeat('oceanbase', 4096));
  eval insert into test02 values(repeat('k', 4096), $cnt, 2, 3, repeat('oceanbase', 4096), repeat('wakakakaka', 4096), 6, 7, 8, 9, 10, 11, 12);
  eval insert into test03 values(repeat('k', 4096), $cnt, 2, 3, repeat('oceanbase', 4096), repeat('wakakakaka', 4096), 6, 7, 8, 9, 10, 11, 12);
  inc $cnt;
}
--enable_query_log

ob1.mysql alter system major freeze tenant obtest;
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id=$tenant_id and LAST_SCN != GLOBAL_BROADCAST_SCN , 1, 100;
let $major_scn=deploy_get_value(ob1.select select GLOBAL_BROADCAST_SCN from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id=$tenant_id, GLOBAL_BROADCAST_SCN, 1);

ob1.check_until_timeout select count(*) > 0 as c from oceanbase.__all_virtual_dag_warning_history where tenant_id=$tenant_id and type="UPDATE_SKIP_MAJOR", 1, 600;
# schedule update skip major dag at COMPACT state now, so all ls expect state should be COMPACT
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_shared_storage_compaction_info where tenant_id=$tenant_id and obj_type="LS_COMPACTION_STATUS" AND info not like "%expect_state=%COMPACT%", 0, 600;


# clear EN_UPDATE_SKIP_MAJOR_DAG_FAILED
ob1.mysql alter system set_tp tp_name="EN_UPDATE_SKIP_MAJOR_DAG_FAILED", error_code=4016, frequency=0;
ob1.check_until_timeout select count(*) > 0 as c from __all_virtual_tablet_compaction_history where tenant_id=$tenant_id and tablet_id=0 and comments like "%UPDATE_SKIP_MAJOR%", 1, 200;
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id = $tenant_id and LAST_SCN != GLOBAL_BROADCAST_SCN , 0, 1200;