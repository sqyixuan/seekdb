# owner: lixia.yq
# owner group: storage [shared_storage]
# description: this case is use for test ls state rollback
#

ob1=OBI(cluster=1:1:1,proxy_num=0);
ob1.reboot;
sleep 10;

ob1.mysql alter system set enable_rebalance='false';
ob1.mysql alter system set default_compress_func='none';
ob1.mysql alter system set debug_sync_timeout='100000s';
# set EN_ENABLE_SHARED_STORAGE_COLUMN_GROUP to enable column group under shared-storage mode
ob1.mysql alter system set_tp tp_no = 2502, error_code = 4016, frequency = 1;

ob_connect(sys_conn, ob1.z1.obs0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);

connection sys_conn;
CREATE RESOURCE UNIT large_unit_1 MAX_CPU=5, MEMORY_SIZE='10G';
CREATE RESOURCE POOL large_pool_1 UNIT large_unit_1, UNIT_NUM 1, ZONE_LIST ('z1','z2','z3');

--disable_all_result_log
CREATE TENANT test_tenant RESOURCE_POOL_LIST = ('large_pool_1'), locality='F@z1', primary_zone = "z1" set ob_tcp_invited_nodes='%', ob_compatibility_mode='mysql';
--enable_all_result_log

ob1.mysql alter system set ob_compaction_schedule_interval='3s' tenant test_tenant;
ob1.mysql alter system set merger_check_interval='10s' tenant test_tenant;
ob1.mysql alter system set compaction_low_thread_score=20 tenant test_tenant;

ob_connect(conn_mysql, ob1.z1.obs0, root@test_tenant, , test, , USE_MYSQL_CONNECTOR);
connection conn_mysql;
create table test01(c1 int, c2 int, c3 varchar(40960)) compression= 'none';
create table test02(c0 varchar(4096), c1 int, c2 int, c3 int, c4 varchar(40960), c5 varchar(40960), c6 int, c7 int, c8 int, c9 int, c10 int, c11 int, c12 int, primary key(c0, c1)) with column group (all columns, each column);
create table test03(c0 varchar(4096), c1 int, c2 int, c3 int, c4 varchar(40960), c5 varchar(40960), c6 int, c7 int, c8 int, c9 int, c10 int, c11 int, c12 int, primary key(c0, c1)) with column group (each column);

let $tablet_id=deploy_get_value(ob1.select select tablet_id from oceanbase.__all_virtual_table where table_name='test01', tablet_id, 1);
let $tablet_id2=deploy_get_value(ob1.select select tablet_id from oceanbase.__all_virtual_table where table_name='test02', tablet_id, 1);
let $tenant_id=deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name='test_tenant', tenant_id, 1);
let $ls_id=deploy_get_value(ob1.select select ls_id from oceanbase.__all_virtual_tablet_to_ls where tenant_id=$tenant_id and tablet_id=$tablet_id, ls_id, 1);
#########################################################################
# TEST_1: add z2 into locality in INDEX_VERIFY state
#########################################################################
connection conn_mysql;
--disable_query_log
let $cnt=1;
while($cnt < 10)
{
  eval insert into test01 values($cnt, $cnt, repeat('oceanbase', 4096));
  eval insert into test02 values(repeat('k', 4096), $cnt, 2, 3, repeat('oceanbase', 4096), repeat('wakakakaka', 4096), 6, 7, 8, 9, 10, 11, 12);
  eval insert into test03 values(repeat('k', 4096), $cnt, 2, 3, repeat('oceanbase', 4096), repeat('wakakakaka', 4096), 6, 7, 8, 9, 10, 11, 12);
  inc $cnt;
}
--enable_query_log

# EN_SHARED_STORAGE_DONT_UPDATE_LS_STATE=(INDEX_VERIFY)
# block ls merge at INDEX_VERIFY state
ob1.mysql alter system set_tp tp_no=746, error_code=4, frequency=1;

ob1.mysql alter system major freeze tenant test_tenant;
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id=$tenant_id and LAST_SCN != GLOBAL_BROADCAST_SCN , 1, 100;
let $major_scn=deploy_get_value(ob1.select select GLOBAL_BROADCAST_SCN from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id=$tenant_id, GLOBAL_BROADCAST_SCN, 1);

ob1.check_until_timeout select count(*) > 0 as c from oceanbase.__all_virtual_shared_storage_compaction_info where tenant_id=$tenant_id and tablet_id=0 and ls_id=$ls_id and obj_type="LS_COMPACTION_STATUS" and info like "%INDEX_VERIFY%", 1, 600;

ob1.mysql alter tenant test_tenant locality='F@z1,F@z2';
ob1.check_until_timeout select count(*) c from oceanbase.__all_tenant where tenant_id = $tenant_id and previous_locality != '', 0, 300;

let $z3_ip = deploy_get_value(ob1.z3.obs0.ip);
let $z3_port = deploy_get_value(ob1.z3.obs0.port);
ob1.check_until_timeout select count(*) c from oceanbase.__all_virtual_shared_storage_compaction_info where tenant_id = $tenant_id and ls_id=$ls_id and svr_ip='$z3_ip' and svr_port=$z3_port, 0, 300;

# force skip checker
ob1.mysql alter system set_tp tp_name = SKIP_LS_STATE_UPDATE, error_code = 4023, frequency = 1;

# clear EN_SHARED_STORAGE_DONT_UPDATE_LS_STATE=(INDEX_VERIFY)
# resume ls merge from INDEX_VERIFY state
ob1.mysql alter system set_tp tp_no=746, error_code=4, frequency=0;

# index_verify rollback to compact
ob1.check_until_timeout select count(*) > 0 as c from oceanbase.__all_virtual_shared_storage_compaction_info where tenant_id=$tenant_id and tablet_id=0 and ls_id=$ls_id and obj_type="LS_COMPACTION_STATUS" and info like "%expect_state=\"COMPACT\"%", 1, 300;

ob1.mysql alter system set_tp tp_name = SKIP_LS_STATE_UPDATE, error_code = 4023, frequency = 0;
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id=$tenant_id and LAST_SCN != GLOBAL_BROADCAST_SCN , 0, 1200;

#########################################################################
# TEST_2: add z3 into locality in REPLICA_VERIFY state
#########################################################################
# EN_SHARED_STORAGE_DONT_UPDATE_LS_STATE=(REPLICA_VERIFY)
# block ls merge at REPLICA_VERIFY state
ob1.mysql alter system set_tp tp_no=746, error_code=3, frequency=1;

connection conn_mysql;
--disable_query_log
while($cnt < 20)
{
  eval insert into test01 values($cnt, $cnt, repeat('oceanbase', 4096));
  eval insert into test02 values(repeat('k', 4096), $cnt, 2, 3, repeat('oceanbase', 4096), repeat('wakakakaka', 4096), 6, 7, 8, 9, 10, 11, 12);
  eval insert into test03 values(repeat('k', 4096), $cnt, 2, 3, repeat('oceanbase', 4096), repeat('wakakakaka', 4096), 6, 7, 8, 9, 10, 11, 12);
  inc $cnt;
}
--enable_query_log

ob1.mysql alter system major freeze tenant test_tenant;
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id=$tenant_id and LAST_SCN != GLOBAL_BROADCAST_SCN , 1, 100;
let $major_scn=deploy_get_value(ob1.select select GLOBAL_BROADCAST_SCN from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id=$tenant_id, GLOBAL_BROADCAST_SCN, 1);

ob1.check_until_timeout select count(*) > 0 as c from oceanbase.__all_virtual_shared_storage_compaction_info where tenant_id=$tenant_id and tablet_id=0 and ls_id=$ls_id and obj_type="LS_COMPACTION_STATUS" and info like "%REPLICA_VERIFY%", 1, 600;

ob1.mysql alter tenant test_tenant locality='F@z1,F@z2,F@z3';
ob1.check_until_timeout select count(*) c from oceanbase.__all_tenant where tenant_id = $tenant_id and previous_locality != '', 0, 300;

# clear EN_SHARED_STORAGE_DONT_UPDATE_LS_STATE=(REPLICA_VERIFY)
ob1.mysql alter system set_tp tp_no=746, error_code=3, frequency=0;

ob1.check_until_timeout select count(*) > 0 as c from oceanbase.__all_virtual_shared_storage_compaction_info where tenant_id=$tenant_id and tablet_id=0 and ls_id=$ls_id and obj_type="LS_COMPACTION_STATUS" and info like "%expect_state=\"COMPACT\"%", 1, 300;

source include/compaction/wait_tenant_major_finish_on_ss.inc;

connection sys_conn;
let $src_is_exec_svr=deploy_get_value(ob1.select select count(*) > 0 as CNT from oceanbase.__all_server_event_history where module='ss_merge_errsim' and event='src_is_exec_svr' and value1=$tenant_id and value2=$ls_id, CNT, 1);
let $normal_flag=deploy_get_value(ob1.select select count(*) > 0 as c from oceanbase.__all_virtual_tablet_compaction_history where tenant_id=$tenant_id and ls_id=$ls_id and type="MAJOR_MERGE" and svr_ip='$z3_ip' and svr_port=$z3_port and compaction_scn=$major_scn, c, 1);
if ($src_is_exec_svr == 1 && $normal_flag == 0)
{
  --echo choose exec svr as src but dest has unexpected no calc ckm merge
}
if ($src_is_exec_svr == 0 && $normal_flag == 1)
{
  --echo dest has unexpected calc ckm merge
}

#########################################################################
# TEST_3: change locality in INDEX_VERIFY state, remove exec replica from loality
#########################################################################
# EN_SHARED_STORAGE_COMPACTION_CHOOSE_EXEC_SVR=4023
# will choose svr_id=3 as exec_svr
ob1.mysql alter system set_tp tp_no=743, error_code=4023, frequency=1;

connection conn_mysql;
--disable_query_log
while($cnt < 30)
{
  eval insert into test01 values($cnt, $cnt, repeat('oceanbase', 4096));
  eval insert into test02 values(repeat('k', 4096), $cnt, 2, 3, repeat('oceanbase', 4096), repeat('wakakakaka', 4096), 6, 7, 8, 9, 10, 11, 12);
  eval insert into test03 values(repeat('k', 4096), $cnt, 2, 3, repeat('oceanbase', 4096), repeat('wakakakaka', 4096), 6, 7, 8, 9, 10, 11, 12);
  inc $cnt;
}
--enable_query_log

ob1.mysql alter system major freeze tenant test_tenant;
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id=$tenant_id and LAST_SCN != GLOBAL_BROADCAST_SCN , 1, 100;
let $major_scn=deploy_get_value(ob1.select select GLOBAL_BROADCAST_SCN from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id=$tenant_id, GLOBAL_BROADCAST_SCN, 1);

ob1.check_until_timeout select count(*) > 0 as c from __all_virtual_shared_storage_compaction_info where tenant_id=$tenant_id and tablet_id=0 and obj_type="COMPACTION_SVRS" and info like "%%exec_svr_id:3, compaction_scn:$major_scn%", 1, 100;

#clear EN_SHARED_STORAGE_COMPACTION_CHOOSE_EXEC_SVR
ob1.mysql alter system set_tp tp_no=743, error_code=4023, frequency=0;
# EN_SHARED_STORAGE_DONT_UPDATE_LS_STATE=(INDEX_VERIFY)
ob1.mysql alter system set_tp tp_no=746, error_code=4, frequency=1;

ob1.check_until_timeout select count(*) > 0 as c from oceanbase.__all_virtual_shared_storage_compaction_info where tenant_id=$tenant_id and tablet_id=0 and ls_id=$ls_id and obj_type="LS_COMPACTION_STATUS" and info like "%INDEX_VERIFY%", 1, 600;

ob1.mysql alter tenant test_tenant locality='F@z1,F@z2';
ob1.check_until_timeout select count(*) c from oceanbase.__all_tenant where tenant_id = $tenant_id and previous_locality != '', 0, 300;

# force skip checker
ob1.mysql alter system set_tp tp_name = SKIP_LS_STATE_UPDATE, error_code = 4023, frequency = 1;

# clear EN_SHARED_STORAGE_DONT_UPDATE_LS_STATE=(INDEX_VERIFY)
ob1.mysql alter system set_tp tp_no=746, error_code=4, frequency=0;

ob1.check_until_timeout select count(*) > 0 as c from oceanbase.__all_virtual_shared_storage_compaction_info where tenant_id=$tenant_id and tablet_id=0 and ls_id=$ls_id and obj_type="LS_COMPACTION_STATUS" and info like "%expect_state=\"COMPACT\"%", 1, 300;

ob1.mysql alter system set_tp tp_name = SKIP_LS_STATE_UPDATE, error_code = 4023, frequency = 0;
source include/compaction/wait_tenant_major_finish_on_ss.inc;

#########################################################################
# TEST_4: test ls refresh REFRESH to RS_VERIFY
#########################################################################
# EN_SHARED_STORAGE_DONT_UPDATE_LS_STATE=(REFRESH)
ob1.mysql alter system set_tp tp_no=746, error_code=6, frequency=1;
ob1.mysql alter system set_tp tp_name = EN_RS_UPDATE_LS_STATE, error_code = 4023, frequency = 1;

connection conn_mysql;
--disable_query_log
while($cnt < 40)
{
  eval insert into test01 values($cnt, $cnt, repeat('oceanbase', 4096));
  eval insert into test02 values(repeat('k', 4096), $cnt, 2, 3, repeat('oceanbase', 4096), repeat('wakakakaka', 4096), 6, 7, 8, 9, 10, 11, 12);
  eval insert into test03 values(repeat('k', 4096), $cnt, 2, 3, repeat('oceanbase', 4096), repeat('wakakakaka', 4096), 6, 7, 8, 9, 10, 11, 12);
  inc $cnt;
}
--enable_query_log

ob1.mysql alter system major freeze tenant test_tenant;
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id=$tenant_id and LAST_SCN != GLOBAL_BROADCAST_SCN , 1, 100;
let $major_scn=deploy_get_value(ob1.select select GLOBAL_BROADCAST_SCN from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id=$tenant_id, GLOBAL_BROADCAST_SCN, 1);

ob1.check_until_timeout select count(*) > 0 as c from oceanbase.__all_virtual_shared_storage_compaction_info where tenant_id=$tenant_id and tablet_id=0 and ls_id=1 and obj_type="LS_COMPACTION_STATUS" and info like "%REFRESH%", 1, 600;
ob1.check_until_timeout select count(*) > 0 from __all_server_event_history where module='ss_merge_errsim' and event='skip_rs_update_ls_state' and value1=$tenant_id and value2=$ls_id, 1, 600;

ob1.mysql alter system set_tp tp_name = EN_RS_UPDATE_LS_STATE, error_code = 4023, frequency = 0;
ob1.check_until_timeout select count(*) > 0 as c from oceanbase.__all_virtual_shared_storage_compaction_info where tenant_id=$tenant_id and tablet_id=0 and ls_id=$ls_id and obj_type="LS_COMPACTION_STATUS" and info like "%REFRESH%", 1, 600;

# clear EN_SHARED_STORAGE_DONT_UPDATE_LS_STATE=(REFRESH)
ob1.mysql alter system set_tp tp_no=746, error_code=6, frequency=0;

source include/compaction/wait_tenant_major_finish_on_ss.inc;

#########################################################################
# TEST_5: change locality in REFRESH state
#########################################################################
# EN_SHARED_STORAGE_DONT_UPDATE_LS_STATE=(REFRESH)
ob1.mysql alter system set_tp tp_no=746, error_code=6, frequency=1;

connection conn_mysql;
--disable_query_log
while($cnt < 60)
{
  eval insert into test01 values($cnt, $cnt, repeat('oceanbase', 4096));
  eval insert into test02 values(repeat('k', 4096), $cnt, 2, 3, repeat('oceanbase', 4096), repeat('wakakakaka', 4096), 6, 7, 8, 9, 10, 11, 12);
  eval insert into test03 values(repeat('k', 4096), $cnt, 2, 3, repeat('oceanbase', 4096), repeat('wakakakaka', 4096), 6, 7, 8, 9, 10, 11, 12);
  inc $cnt;
}
--enable_query_log

ob1.mysql alter system major freeze tenant test_tenant;
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id=$tenant_id and LAST_SCN != GLOBAL_BROADCAST_SCN , 1, 100;
let $major_scn=deploy_get_value(ob1.select select GLOBAL_BROADCAST_SCN from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id=$tenant_id, GLOBAL_BROADCAST_SCN, 1);

# 有概率出现1号和1001号日志流更新为REFRESH后, ls refresh重新把1001号日志流刷回RS_VERIFY, 进而导致RS Checker卡住
# TEST_4 模拟这种情况
ob1.check_until_timeout select count(*) > 0 as c from oceanbase.__all_virtual_shared_storage_compaction_info where tenant_id=$tenant_id and tablet_id=0 and ls_id=$ls_id and obj_type="LS_COMPACTION_STATUS" and info like "%REFRESH%", 1, 600;

ob1.mysql alter tenant test_tenant locality='F@z1,F@z2,F@z3';
ob1.check_until_timeout select count(*) c from oceanbase.__all_tenant where tenant_id = $tenant_id and previous_locality != '', 0, 300;

# clear EN_SHARED_STORAGE_DONT_UPDATE_LS_STATE=(REFRESH)
ob1.mysql alter system set_tp tp_no=746, error_code=6, frequency=0;

source include/compaction/wait_tenant_major_finish_on_ss.inc;