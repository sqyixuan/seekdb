#########################################################################
# TEST_8: make tablet leader check replica checksum error
#########################################################################
# EN_RS_USER_INDEX_CHECKSUM_ERROR = 4103
ob1.mysql alter system set_tp tp_no = 716, error_code = 4103, frequency = 1;
--disable_query_log
let $cnt=1;
while($cnt < 10)
{
  eval insert into test01 values($cnt, $cnt, repeat('oceanbase', 4096));
  inc $cnt;
}
--enable_query_log
source include/compaction/alter_tenant_obtest_major_freeze_and_sleep.inc;
ob1.check_until_timeout select (count(*) > 0) as c from oceanbase.CDB_OB_COLUMN_CHECKSUM_ERROR_INFO where tenant_id = $tenant_id, 1, 300;
ob1.check_until_timeout select (count(*) > 0) from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id = $tenant_id and INFO = "CHECKSUM_ERROR" , 1, 300;
ob1.mysql alter system set_tp tp_no = 716, error_code = 4103, frequency = 0;
ob1.mysql alter system clear merge error tenant obtest;
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id = $tenant_id and LAST_SCN != GLOBAL_BROADCAST_SCN , 0, 300;

# EN_MEDIUM_REPLICA_CHECKSUM_ERROR = 4103
