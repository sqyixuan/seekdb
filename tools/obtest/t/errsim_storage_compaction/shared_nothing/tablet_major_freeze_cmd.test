# owner:lixia.yq
# owner group:storage
# test tablet major freeze cmd

ob1=OBI(cluster=1:1, proxy_num=0, init_unit_cpu=2);
ob1.reboot;
sleep 5;

ob1.mysql alter system set enable_rebalance='false';
ob1.mysql alter system set resource_hard_limit=500;
ob1.mysql alter system set balancer_idle_time='10s';
ob1.mysql alter system set debug_sync_timeout='100000s';
ob1.mysql alter system set minor_compact_trigger=3 tenant obtest;
ob1.mysql alter system set syslog_io_bandwidth_limit='100G';
ob1.mysql alter system set ob_compaction_schedule_interval='10s' tenant obtest;
ob1.mysql alter system set server_permanent_offline_time='20s';
ob1.mysql alter system set merger_check_interval='10s' tenant obtest;
ob1.mysql alter system set _enable_adaptive_compaction=true tenant obtest;

let $ip=deploy_get_value(ob1.z1.obs0.ip);
let $port=deploy_get_value(ob1.z1.obs0.mysql_port);

connect (conn1,$ip,root@obtest,,test,$port);

connection conn1;
create table test_tablet_major_freeze(i int primary key, c1 char(30), c256 char(255), dt datetime(6), d  datetime(6));

--disable_query_log
let $i=0;
while($i < 20)
{
    eval insert into test_tablet_major_freeze(i,c1,c256,dt,d) values($i,'1','$i','2012-10-10 12:00:00','2012-10-10');
    inc $i;
}
--enable_query_log

let $__tenant_id__=deploy_get_value(ob1.select select /*+QUERY_TIMEOUT(10000000)*/ tenant_id from oceanbase.__all_virtual_table where table_name= 'test_tablet_major_freeze', tenant_id, 1);
let $__tablet_id__=deploy_get_value(ob1.select select /*+QUERY_TIMEOUT(10000000)*/ tablet_id from oceanbase.__all_virtual_table where table_name= 'test_tablet_major_freeze', tablet_id, 1);

let $tablet_major_scn=deploy_get_value(ob1.select select compaction_scn from oceanbase.__all_virtual_tablet_meta_table where tenant_id=$__tenant_id__ and tablet_id=$__tablet_id__, compaction_scn, 1);
let $ls_id=deploy_get_value(ob1.select select ls_id from oceanbase.__all_virtual_tablet_to_ls where tenant_id=$__tenant_id__ and tablet_id=$__tablet_id__, ls_id, 1);
let $leader_port=deploy_get_value(ob1.select select svr_port from oceanbase.__all_virtual_ls_meta_table where tenant_id=$__tenant_id__ and ls_id=$ls_id and role=1, svr_port, 1);


#########################################################################
# TEST_1: alter tablet major freeze after minor
#########################################################################

ob1.mysql alter system minor freeze tenant=obtest tablet_id=$__tablet_id__;
ob1.check_until_timeout select count(1) from oceanbase.__all_virtual_table_mgr where table_type=0 and is_active=0 and tenant_id=$tenant_id and tablet_id =$tablet_id, 0, 300;

ob1.check_until_timeout select count(*) as c from oceanbase.__all_virtual_tablet_compaction_info where tenant_id=$__tenant_id__ and tablet_id=$__tablet_id__ and wait_check_scn != 0 and svr_port=$leader_port, 0, 500;

ob1.mysql alter system major freeze tenant=obtest tablet_id=$__tablet_id__;
ob1.check_until_timeout select count(*) > 0 from oceanbase.__all_virtual_tablet_meta_table where tenant_id=$__tenant_id__ and tablet_id=$__tablet_id__ and compaction_scn > $tablet_major_scn, 1, 500;

#########################################################################
# TEST_2: test major freeze cmd privileges
#########################################################################
connection conn1;
--error 1227
alter system major freeze tenant=sys tablet_id=1;
--error 1227
alter system major freeze tenant sys;
--error 1227
alter system major freeze tenant=sys,obtest tablet_id=1;


#########################################################################
# TEST_3: alter tablet major freeze after major
#########################################################################
source include/compaction/alter_tenant_obtest_major_freeze_and_sleep.inc;
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where LAST_SCN != GLOBAL_BROADCAST_SCN , 0, 300;

connection conn1;
--disable_query_log
let $i=20;
while($i < 40)
{
    eval insert into test_tablet_major_freeze(i,c1,c256,dt,d) values($i,'1','$i','2012-10-10 12:00:00','2012-10-10');
    inc $i;
}
--enable_query_log

ob1.mysql alter system minor freeze tenant=obtest tablet_id=$__tablet_id__;
ob1.check_until_timeout select count(1) from oceanbase.__all_virtual_table_mgr where table_type=0 and is_active=0 and tenant_id=$tenant_id and tablet_id =$tablet_id, 0, 300;

let $tablet_major_scn=deploy_get_value(ob1.select select compaction_scn from oceanbase.__all_virtual_tablet_meta_table where tenant_id=$__tenant_id__ and tablet_id=$__tablet_id__, compaction_scn, 1);
let $ls_id=deploy_get_value(ob1.select select ls_id from oceanbase.__all_virtual_tablet_to_ls where tenant_id=$__tenant_id__ and tablet_id=$__tablet_id__, ls_id, 1);
let $leader_ip=deploy_get_value(ob1.select select svr_ip from oceanbase.__all_virtual_ls_meta_table where tenant_id=$__tenant_id__ and ls_id=$ls_id and role=1, svr_ip, 1);
let $leader_port=deploy_get_value(ob1.select select svr_port from oceanbase.__all_virtual_ls_meta_table where tenant_id=$__tenant_id__ and ls_id=$ls_id and role=1 and svr_ip='$leader_ip', svr_port, 1);

ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_tablet_compaction_info where tenant_id=$__tenant_id__ and tablet_id=$__tablet_id__ and wait_check_scn != 0 and svr_ip='$leader_ip' and svr_port=$leader_port, 0, 500;

ob1.mysql alter system major freeze tenant=obtest tablet_id=$__tablet_id__;
ob1.check_until_timeout select count(*) > 0 from oceanbase.__all_virtual_tablet_meta_table where tenant_id=$__tenant_id__ and tablet_id=$__tablet_id__ and compaction_scn > $tablet_major_scn, 1, 500;
