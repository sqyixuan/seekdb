########################################################################
# TEST_8: diagnose schedule minor failed
#########################################################################
insert into test01 values(1, 1, 'oceanbase');
ob1.mysql alter system minor freeze tenant = all;
sleep 20;

insert into test01 values(1, 1, 'oceanbase');
ob1.mysql alter system minor freeze tenant = all;
sleep 20;

# EN_CAN_NOT_SCHEDULE_MINOR = 4677
ob1.mysql alter system set_tp tp_no = 730, error_code = 4677, frequency = 1;

insert into test01 values(1, 1, 'oceanbase');
ob1.mysql alter system minor freeze tenant = all;
sleep 20;

ob1.z1.obs0.check_log_until_success -c "ERRSIM EN_CAN_NOT_SCHEDULE_MINOR.*4677";
ob1.check_until_timeout select /*+LOG_LEVEL(DEBUG)*/count(1) > 0 as c from oceanbase.__all_virtual_compaction_diagnose_info where tenant_id=$tenant_id and diagnose_info like "%minor merge%" , 1, 300;

