########################################################################
# TEST_10: test finish dag failure
#########################################################################
let $cnt=1;
while($cnt < 10)
{
  eval insert into test01 values($cnt, $cnt, 'oceanbase');
  inc $cnt;
}
ob1.mysql alter system set_tp tp_name = EN_FINISH_DAG_FAILURE, error_code = 4016, frequency = 1;
source include/compaction/alter_tenant_obtest_major_freeze_and_sleep.inc;

ob1.mysql alter system set_tp tp_name = EN_FINISH_DAG_FAILURE, error_code = 4016, frequency = 0;
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id = $tenant_id and LAST_SCN != GLOBAL_BROADCAST_SCN , 0, 300;

