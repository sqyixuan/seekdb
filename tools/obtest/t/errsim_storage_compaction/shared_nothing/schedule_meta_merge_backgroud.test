# owner:fengjingkun.fjk
# owner group:storage
# test meta major merge
 
ob1=OBI(cluster=1:1, proxy_num=0, init_unit_cpu=2);
ob1.reboot;
sleep 5;
 
ob1.mysql alter system set enable_rebalance = 'false';
ob1.mysql alter system set resource_hard_limit=500;
ob1.mysql alter system set balancer_idle_time='10s';
ob1.mysql alter system set debug_sync_timeout = '100000s';
ob1.mysql alter system set syslog_io_bandwidth_limit = '100G';
 
 
ob1.mysql alter system set _enable_adaptive_compaction = False tenant sys;
ob1.mysql alter system set _enable_adaptive_compaction = False tenant all_user;
ob1.mysql alter system set _enable_adaptive_compaction = False tenant all_meta;
ob1.mysql alter system set minor_compact_trigger = 10 tenant sys;
ob1.mysql alter system set minor_compact_trigger = 10 tenant all_user;
ob1.mysql alter system set minor_compact_trigger = 10 tenant all_meta;
ob1.mysql alter system set ob_compaction_schedule_interval = '3s' tenant obtest;
ob1.mysql alter system set_tp tp_name = "EN_COMPACTION_DISABLE_META_MERGE_AFTER_MINI", error_code = 4016, frequency = 1;

let $ip = deploy_get_value(ob1.z1.obs0.ip);
let $port = deploy_get_value(ob1.z1.obs0.mysql_port);
 
connect (conn1,$ip,root@obtest,,test,$port);
connection conn1;

## 1. create table and insert/delete, no medium, but backgroud meta merge
create table t1 (k int primary key, c1 int, v2 int) table_mode='extreme';
create sequence seq cache 1000000 noorder;
insert into t1 select seq.nextval, seq.nextval + 1, seq.nextval + 2 from table(generator(600));
delete from t1 where k > 0;
alter system minor freeze;
sleep 120;
insert into t1 select seq.nextval, seq.nextval + 1, seq.nextval + 2 from table(generator(1000));
delete from t1 where k > 0;
alter system minor freeze;

let $tenant_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name = "obtest", tenant_id, 1);
let $tablet_id = deploy_get_value(ob1.select select tablet_id from oceanbase.__all_virtual_table where tenant_id = $tenant_id and table_name = "t1", tablet_id, 1);
ob1.check_until_timeout select count(*) from __all_virtual_tablet_compaction_history where tenant_id = $tenant_id and tablet_id = $tablet_id and type like "%META%", 2, 600;
ob1.check_until_timeout select count(*) from GV\$OB_SSTABLES where tenant_id = $tenant_id and tablet_id = $tablet_id and table_type like '%META%', 2, 600;
ob1.z1.obs0.check_log_until_success -c "Try to schedule tablet meta merge background.*$tablet_id";
ob1.z2.obs0.check_log_until_success -c "Try to schedule tablet meta merge background.*$tablet_id";

# 2. insert delete again and do meta merge in the backgroud
insert into t1 select seq.nextval, seq.nextval + 1, seq.nextval + 2 from table(generator(1000));
delete from t1 where k > 0;
alter system minor freeze;
sleep 3;
insert into t1 select seq.nextval, seq.nextval + 1, seq.nextval + 2 from table(generator(1000));
delete from t1 where k > 0;
alter system minor freeze;
ob1.check_until_timeout select count(*) from __all_virtual_tablet_compaction_history where tenant_id = $tenant_id and tablet_id = $tablet_id and type like "%META%", 4, 600;

