# owner:huhaosheng.hhs
# owner group:storage
# test co major merge failed to add finished dag when prepare

ob1=OBI(cluster=1, proxy_num=0, init_unit_cpu=2);
ob1.reboot;
sleep 5;

--echo ===============================================================
--echo ======== Step 0: prepare and create table, insert data ========
--echo ===============================================================

--source include/compaction/set_common_parameters.inc

let $ip = deploy_get_value(ob1.z1.obs0.ip);
let $port = deploy_get_value(ob1.z1.obs0.mysql_port);
let $tenant_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name = "obtest", tenant_id, 1);

connect (conn1,$ip,root@obtest,,test,$port);
connection conn1;

create table t1 (k int primary key, v1 int, v2 int, v3 int, v4 int, v5 int, v6 int, v7 int) with column group (each column);
create sequence seq cache 100000 noorder;
insert into t1 select seq.nextval, seq.nextval + 1, seq.nextval + 2, seq.nextval + 3, seq.nextval + 4, seq.nextval + 5, seq.nextval + 6, seq.nextval + 7 from table(generator(5000));

--echo ===============================================================
--echo ======== Step 1: close row col switch and do major merge  =====
--echo ===============================================================
ob1.mysql alter system set_tp tp_name = "EN_COMPACTION_ADD_CO_MREGE_FINISH_DAG_INTO_DAG_NET_FAILED", error_code = 4013, frequency = 1;
ob1.mysql alter system set_tp tp_name = "EN_COMPACTION_DISABLE_ROW_COL_SWITCH", error_code = 4016, frequency = 1;
ob1.mysql alter system major freeze tenant obtest;

ob1.check_until_timeout select count(*) > 0 from oceanbase.__all_server_event_history where module = 'row_col_switch' and event = 'disable_row_col_switch', 1, 600;
ob1.check_until_timeout select count(*) > 0 from oceanbase.__all_server_event_history where module = 'merge_errsim' and event = 'co_merge_finish_dag_add_failed' and name1 = 'ret_code' and value1 = -4013, 1, 600;

sleep 60;
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id = $tenant_id and LAST_SCN != GLOBAL_BROADCAST_SCN , 0, 1200;
let $table_name = "t1";
--source include/compaction/check_major_sstable_status.inc
ob1.mysql alter system set_tp tp_name = "EN_COMPACTION_DISABLE_ROW_COL_SWITCH", error_code = 4016, frequency = 0;
ob1.mysql alter system set_tp tp_name = "EN_COMPACTION_ADD_CO_MREGE_FINISH_DAG_INTO_DAG_NET_FAILED", error_code = 4013, frequency = 0;

--echo ===============================================================
--echo ======== Step 2: open row col switch and do major merge  ======
--echo ===============================================================
ob1.mysql alter system set_tp tp_name = "EN_COMPACTION_ADD_CO_MREGE_FINISH_DAG_INTO_DAG_NET_FAILED", error_code = 4023, frequency = 1;
ob1.mysql alter system major freeze tenant obtest;
ob1.check_until_timeout select count(*) > 0 from oceanbase.__all_server_event_history where module = 'merge_errsim' and event = 'co_merge_finish_dag_add_failed' and name1 = 'ret_code' and value1 = -4023, 1, 600;
sleep 60;
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id = $tenant_id and LAST_SCN != GLOBAL_BROADCAST_SCN , 0, 1200;
let $table_name = "t1";
--source include/compaction/check_major_sstable_status.inc
ob1.mysql alter system set_tp tp_name = "EN_COMPACTION_ADD_CO_MREGE_FINISH_DAG_INTO_DAG_NET_FAILED", error_code = 4023, frequency = 0;