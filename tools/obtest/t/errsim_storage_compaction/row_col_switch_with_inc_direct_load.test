# owner: ouyanghongrong.oyh
# owner group: storage
# description: this case is use for test row col switch with migrate
# 

ob1=OBI(cluster=1:2:2,proxy_num=0,init_unit_cpu=5);
ob1.reboot;
sleep 10;

--echo ===============================================================
--echo =================  Step 0: prepare env   ======================
--echo ===============================================================

ob1.mysql alter system set enable_rebalance = 'false';
ob1.mysql alter system set default_compress_func = 'none';
ob1.mysql alter system set debug_sync_timeout = '100000s';
ob1.mysql alter system set undo_retention = 0;
ob1.mysql set global recyclebin = OFF;

let $proxy_ip = deploy_get_value(ob1.z1.obs0.ip);
let $proxy_port = deploy_get_value(ob1.z1.obs0.mysql_port);

connect(sys_conn, $proxy_ip, root@obtest,,oceanbase, $proxy_port);

ob1.mysql alter system set ob_compaction_schedule_interval = '10s' tenant obtest;
ob1.mysql alter system set merger_check_interval = '10s' tenant obtest;

ob_connect(conn_mysql, ob1.z1.obs0, root@obtest, , test, , USE_MYSQL_CONNECTOR);
connection conn_mysql;

# table 1: 2 columns, always row store
create table t1(c1 int, c2 int, primary key (c1)) with column group (all columns, each column);
# table 2: 7 columns, only row count affect its major sstable
create table t2(c1 int, c2 int, c3 int, c4 int, c5 int, c6 int, c7 int, primary key (c1)) with column group (all columns, each column);

let $tenant_name = "obtest";
let $observer_id = 1;
let $tenant_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name=$tenant_name, tenant_id, 1);

--echo ===============================================================
--echo =======  Step 1: test basic row-col-switch   ==================
--echo =============================================================== 
# 1. row col major switch with expected rule
# 2. leader and follow compaction with the same scn and sstable status
# ====================================================================

## Case 1: before insert, only 1 row store major for each table
let $table_name = "t1";
--source include/compaction/check_major_sstable_status.inc
let $table_name = "t2";
--source include/compaction/check_major_sstable_status.inc

## Case 2: for empty tables, only row store all cg, no normal cg
--echo [INFO] Start check empty tables
--source include/compaction/row_col_switch_compaction_and_check.inc

## Case 3: insert 500 lines, only row store major
create sequence seq1 cache 40000 noorder;
create sequence seq2 cache 40000 noorder;
insert into t1 select seq1.nextval, seq1.nextval + 1 from table(generator(500));
insert into t2 select seq2.nextval, seq2.nextval + 1, seq2.nextval + 2, seq2.nextval + 3, seq2.nextval + 4, seq2.nextval + 5, seq2.nextval + 6 from table(generator(500));

--echo [INFO] Start major freeze for 500 lines
--source include/compaction/row_col_switch_compaction_and_check.inc
select * from t1 limit 1;
select * from t2 limit 1;

--echo ===============================================================
--echo =======  Step 2: test skip many mini rows  ====================
--echo =============================================================== 
# 1. if there are many inc mini rows,  disable row col switch
# 2. when no inc data, use basic row col switch rules
# ====================================================================

## Case 4: with many physical row count, t1 and t2 merge to columnar store;
--echo [INFO] Start check inc data threshold, should merge ino columnar store
insert into t1 select seq1.nextval, seq1.nextval + 1 from table(generator(10000));
insert into t2 select seq2.nextval, seq2.nextval + 1, seq2.nextval + 2, seq2.nextval + 3, seq2.nextval + 4, seq2.nextval + 5, seq2.nextval + 6 from table(generator(10000));

select count(*) from t1;
select count(*) from t2;
alter system minor freeze;

delete from t1 where c1 > 500; 
delete from t2 where c1 > 500;
select count(*) from t1;
select count(*) from t2;
alter system minor freeze;

--echo [INFO] Start major freeze for +-10000 lines
--source include/compaction/row_col_switch_compaction_and_check.inc

## Case 5: when no inc data and major is small, return back row store
--echo [INFO] Start check after re-compaction, should return back row store
--source include/compaction/row_col_switch_compaction_and_check.inc
select count(*) from t1;
select count(*) from t2;

--echo ===============================================================
--echo =======  Step 3: test skip many direct load mini rows  ========
--echo =============================================================== 
# 1. if there exist inc direct load sstable, calculate physical row
# 2. when no inc data, use basic row col switch rules
# ====================================================================

# Case 6: create a new table and do inc direct load 
connection conn_mysql;
--echo [INFO] create a new table and do inc direct load 
create table t3(c1 int, c2 int, c3 int, c4 int, c5 int, c6 int, c7 int, primary key (c1));
create sequence seq cache 100 noorder start with 501;
insert into t3 select seq.nextval, seq.nextval + 1, seq.nextval + 2, seq.nextval + 3, seq.nextval + 4, seq.nextval + 5, seq.nextval + 6 from table(generator(10000));

insert /*+ enable_parallel_dml parallel(2)        direct(true, 0 ,'inc_replace')*/ into t1 select c1, c2 from t3;
insert /*+ enable_parallel_dml parallel(2) append direct(true, 0 ,'inc_replace')*/ into t2 select c1, c2, c3, c4, c5, c6, c7 from t3;
select count(*) from t1;
select count(*) from t2;

delete from t1 where c1 > 500; 
delete from t2 where c1 > 500;
select count(*) from t1;
select count(*) from t2;
--source include/compaction/row_col_switch_compaction_and_check.inc

## Case 7: when no inc data and major is small, return back row store
--echo [INFO] Start check after re-compaction, should return back row store
--source include/compaction/row_col_switch_compaction_and_check.inc
select count(*) from t1;
select count(*) from t2;