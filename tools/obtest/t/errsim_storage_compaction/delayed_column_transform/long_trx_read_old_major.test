# owner: zhanghuidong.zhd
# owner group: storage
# description: this case test long trx read old version major sstable

ob1=OBI(cluster=1:1:1,proxy_num=0);
ob1.reboot;
sleep 10;

--echo ===============================================================
--echo =================  Step 0: prepare env   ======================
--echo ===============================================================
let $tenant_name = "mysql";
ob1.mysql create resource unit unit_2 max_cpu=2, memory_size='5G';
ob1.mysql create resource pool mysql_pool unit = 'unit_2', unit_num = 1;
ob1.mysql create tenant mysql replica_num = 3, resource_pool_list=('mysql_pool') set ob_tcp_invited_nodes='%', ob_compatibility_mode='mysql';
sleep 2;
ob_connect(conn_mysql, ob1.z1.obs0, root@mysql, ,test, , USE_OB_CONNECTOR);
ob_connect(conn_mysql_2, ob1.z1.obs0, root@mysql, ,test, , USE_OB_CONNECTOR);
ob_connect(conn_sys, ob1.z1.obs0, root@sys, ,oceanbase, , USE_OB_CONNECTOR);
connection conn_mysql;
let $tenant_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name='mysql', tenant_id, 1);

--echo ===============================================================
--echo =================  Step 1: create table  ======================
--echo ===============================================================
create table t1 (c1 int primary key, c2 int, c3 int);
insert into t1 values (1,2,3), (2,3,4), (3,4,5);
ob1.mysql alter system major freeze tenant = $tenant_name;
sleep 30;
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id = $tenant_id and LAST_SCN != GLOBAL_BROADCAST_SCN , 0, 1200;

--echo ===============================================================
--echo ============  Step 2: long trx and major freeze  ==============
--echo ===============================================================
connection conn_mysql;
set session transaction isolation level repeatable read;
begin;
update t1 set c3 = 100 where c1 = 1;

connection conn_mysql_2;
set session transaction isolation level repeatable read;
sleep 5;
begin;
update t1 set c3 = 100 where c1 = 2;
select * from t1;
commit;
alter system major freeze;
sleep 30;
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id = $tenant_id and LAST_SCN != GLOBAL_BROADCAST_SCN , 0, 1200;

connection conn_mysql;
sleep 300;
select * from t1;
commit;