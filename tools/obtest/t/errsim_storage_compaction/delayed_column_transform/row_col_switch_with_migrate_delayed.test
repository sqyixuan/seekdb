# owner: zhanghuidong.zhd
# owner group: storage
# description: this case is use for test row col switch with migrate
# 

ob1=OBI(cluster=1:2:2,proxy_num=0,init_unit_cpu=5);
ob1.reboot;
sleep 10;

ob1.mysql alter system set enable_rebalance = 'false';
ob1.mysql alter system set default_compress_func = 'none';
ob1.mysql alter system set debug_sync_timeout = '100000s';
ob1.mysql alter system set undo_retention = 0;
ob1.mysql set global recyclebin = OFF;

let $proxy_ip = deploy_get_value(ob1.z1.obs0.ip);
let $proxy_port = deploy_get_value(ob1.z1.obs0.mysql_port);

connect(sys_conn, $proxy_ip, root@obtest,,oceanbase, $proxy_port);

ob1.mysql alter system set ob_compaction_schedule_interval = '10s' tenant obtest;
ob1.mysql alter system set merger_check_interval = '10s' tenant obtest;

ob_connect(conn_mysql, ob1.z1.obs0, root@obtest, , test, , USE_MYSQL_CONNECTOR);
connection conn_mysql;

# table 1: 2 columns
create table t1(c1 int, c2 int, primary key (c1));
# table 2: 7 columns
create table t2(c1 int, c2 int, c3 int, c4 int, c5 int, c6 int, c7 int, primary key (c1));

create sequence seq1 cache 100000 noorder;
create sequence seq2 cache 100000 noorder;

let $tenant_name = "obtest";
let $observer_id = 1;
let $tenant_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name=$tenant_name, tenant_id, 1);

#########################################################################
# TEST_1: test basic feature:
# 1. row col major switch with expected rule
# 2. leader and follow compaction with the same scn and sstable status
# 3  errsim make estimate row failed, return to original schema
#########################################################################

## Case 1: before insert, major row store for each table
let $table_name = "t1";
--source include/compaction/check_major_sstable_status.inc
let $table_name = "t2";
--source include/compaction/check_major_sstable_status.inc

## Case 2: for empty tables, major row store for each table
--echo Start check empty tables
--source include/compaction/row_col_switch_compaction_and_check.inc


## Case 3: insert 500 lines and delayed alter column groups for t1, co major column store for t1
--let $insert_row_count=500
--source include/compaction/row_col_switch_insert_until.inc
alter table t1 add column group (all columns, each column) delayed;
--echo Start major freeze for 500 lines
--source include/compaction/row_col_switch_compaction_and_check.inc
select * from t1 limit 1;
select * from t2 limit 1;

## Case 4: insert until 15000 lines and delayed alter column group for t2, co major row store for t1, co major column store for t2
--let $insert_row_count=14500
--source include/compaction/row_col_switch_insert_until.inc
alter table t2 add column group (all columns, each column) delayed;
--echo Start major freeze for 15000 lines
--source include/compaction/row_col_switch_compaction_and_check.inc
select * from t1 limit 1;
select * from t2 limit 1;

## Case 5: insert until 25000 lines, co major row store for t1 and co major column store for t2
--let $insert_row_count=10000
--source include/compaction/row_col_switch_insert_until.inc
--echo Start major freeze for 25000 lines
--source include/compaction/row_col_switch_compaction_and_check.inc
select * from t1 limit 1;
select * from t2 limit 1;

## Case 6: delete 20000 lines, co major row store for t1 and co major column store for t2
delete from t1 where c1 > 5000; 
delete from t2 where c1 > 5000; 
select count(*) from t1;
select count(*) from t2;
--echo Start major freeze after delete 20000 lines(remain 5000)
--source include/compaction/row_col_switch_compaction_and_check.inc
select * from t1 limit 1;
select * from t2 limit 1;

## Case 7: delete 2500 lines, co major row store for all tables
delete from t1 where c1 > 2500; 
delete from t2 where c1 > 2500; 
select count(*) from t1;
select count(*) from t2;
--echo Start major freeze after delete 2500 lines(remain 2500)
--source include/compaction/row_col_switch_compaction_and_check.inc
select * from t1 limit 1;
select * from t2 limit 1;

## Case 8: errsim for estimate row count failed
ob1.mysql alter system set_tp tp_no = 736, error_code = 4016, frequency = 1;
--echo Start check errsim for estimate row count failed
ob1.mysql alter system major freeze tenant obtest;
ob1.z1.obs0.check_log_until_success -c "ERRSIM EN_COMPACTION_ESTIMATE_ROW_FAILED";
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id = $tenant_id and LAST_SCN != GLOBAL_BROADCAST_SCN , 0, 1200;
let $table_name = "t1";
--source include/compaction/check_major_sstable_status.inc
let $table_name = "t2";
--source include/compaction/check_major_sstable_status.inc
ob1.mysql alter system set_tp tp_no = 736, error_code = 4016, frequency = 0;
select count(*) from t1;
select count(*) from t2;
select * from t1 limit 1;
select * from t2 limit 1;

## Case 9: after errsim, return back co major row store
--echo Start check after errsim, should return back row store
--source include/compaction/row_col_switch_compaction_and_check.inc
select count(*) from t1;
select count(*) from t2;
select * from t1 limit 1;
select * from t2 limit 1;
## Case 10: drop column group for t1, major row store for t1
alter table t1 drop column group (all columns, each column);
ob1.mysql alter system major freeze tenant obtest;
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id = $tenant_id and LAST_SCN != GLOBAL_BROADCAST_SCN , 0, 1200;
alter table t1 add column group (all columns, each column) delayed;

#########################################################################
# TEST_2: test migrate sstable mismatch schema
#########################################################################
## Case 1: migrate a row store (column schema) table between ob1.z3.obs0 and ob1.z3.obs1

let $resource_pool_id = deploy_get_value(ob1.select select resource_pool_id from oceanbase.__all_resource_pool where tenant_id = $tenant_id, resource_pool_id, 1);
let $unit_id = deploy_get_value(ob1.select select unit_id from oceanbase.__all_unit where resource_pool_id = $resource_pool_id and zone = 'z3', unit_id, 1);
let $tablet_id_t1 = deploy_get_value(ob1.select select tablet_id from oceanbase.__all_virtual_table where table_name='t1', tablet_id, 1);
let $ls_id = deploy_get_value(ob1.select select ls_id from oceanbase.__all_virtual_tablet_to_ls where tenant_id=$tenant_id and tablet_id=$tablet_id_t1, ls_id, 1);

let $dst_ip_z3_0 = deploy_get_value(ob1.z3.obs0.ip);
let $dst_port_z3_0 = deploy_get_value(ob1.z3.obs0.port);
let $dst_z3_0 = $dst_ip_z3_0:$dst_port_z3_0;

let $dst_ip_z3_1 = deploy_get_value(ob1.z3.obs1.ip);
let $dst_port_z3_1 = deploy_get_value(ob1.z3.obs1.port);
let $dst_z3_1 = $dst_ip_z3_1:$dst_port_z3_1;

let $ip = deploy_get_value(ob1.select select svr_ip from oceanbase.__all_unit where unit_id = $unit_id, svr_ip, 1);
let $port = deploy_get_value(ob1.select select svr_port from oceanbase.__all_unit where unit_id = $unit_id, svr_port, 1);
let $cur = $ip:$port;

let $dst = $dst_z3_0;
let $dst_port = $dst_port_z3_0;

if ($cur != $dst_z3_1)
{
  let $dst = $dst_z3_1;
  let $dst_port = $dst_port_z3_1;
}

ob1.mysql alter system migrate unit $unit_id destination "$dst";
ob1.check_until_timeout SELECT COUNT(*) as cnt FROM oceanbase.__all_rootservice_job WHERE unit_id = $unit_id AND job_type = "MIGRATE_UNIT" AND job_status = "SUCCESS", 1, 600;
ob1.check_until_timeout select count(1) from oceanbase.__all_virtual_ls_meta_table where tenant_id = $tenant_id and ls_id = $ls_id and svr_port = '$dst_port' and replica_status = 'NORMAL', 1, 100;
ob1.check_until_timeout select count(*) as cnt from oceanbase.GV\$OB_UNITS where unit_id = $unit_id and svr_ip = '$ip' and svr_port = $port, 0, 100;

if ($cur != $dst_z3_0)
{
  ob_connect(conn_mysql, ob1.z3.obs0, root@obtest, , test, , USE_MYSQL_CONNECTOR);
  connection conn_mysql;
}

if ($cur != $dst_z3_1)
{
  ob_connect(conn_mysql, ob1.z3.obs1, root@obtest, , test, , USE_MYSQL_CONNECTOR);
  connection conn_mysql;
}

let $table_name = "t1";
--source include/compaction/check_major_sstable_status.inc
let $table_name = "t2";
--source include/compaction/check_major_sstable_status.inc

select count(*) from t1;
select count(*) from t2;
select * from t1 limit 1;
select * from t2 limit 1;

## Case 2: errsim estimate row count failed
ob1.mysql alter system set_tp tp_no = 736, error_code = 4016, frequency = 1;
--echo Start check errsim for estimate row count failed
ob1.mysql alter system major freeze tenant obtest;
ob1.z1.obs0.check_log_until_success -c "ERRSIM EN_COMPACTION_ESTIMATE_ROW_FAILED";
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id = $tenant_id and LAST_SCN != GLOBAL_BROADCAST_SCN , 0, 1200;
let $table_name = "t1";
--source include/compaction/check_major_sstable_status.inc
let $table_name = "t2";
--source include/compaction/check_major_sstable_status.inc
ob1.mysql alter system set_tp tp_no = 736, error_code = 4016, frequency = 0;
select count(*) from t1;
select count(*) from t2;
select * from t1 limit 1;
select * from t2 limit 1;
## drop column group for t2, major row store for t2, after errsim, co major row store for t1
alter table t2 drop column group (all columns, each column);
ob1.mysql alter system major freeze tenant obtest;
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id = $tenant_id and LAST_SCN != GLOBAL_BROADCAST_SCN , 0, 1200;
alter table t2 add column group (all columns, each column) delayed;

## Case 3: migrate back
let $resource_pool_id = deploy_get_value(ob1.select select resource_pool_id from oceanbase.__all_resource_pool where tenant_id = $tenant_id, resource_pool_id, 1);
let $unit_id = deploy_get_value(ob1.select select unit_id from oceanbase.__all_unit where resource_pool_id = $resource_pool_id and zone = 'z3', unit_id, 1);
let $tablet_id_t1 = deploy_get_value(ob1.select select tablet_id from oceanbase.__all_virtual_table where table_name='t1', tablet_id, 1);
let $ls_id = deploy_get_value(ob1.select select ls_id from oceanbase.__all_virtual_tablet_to_ls where tenant_id=$tenant_id and tablet_id=$tablet_id_t1, ls_id, 1);

let $ip = deploy_get_value(ob1.select select svr_ip from oceanbase.__all_unit where unit_id = $unit_id, svr_ip, 1);
let $port = deploy_get_value(ob1.select select svr_port from oceanbase.__all_unit where unit_id = $unit_id, svr_port, 1);
let $cur = $ip:$port;

let $dst = $dst_z3_0;
let $dst_port = $dst_port_z3_0;

if ($cur != $dst_z3_1)
{
  let $dst = $dst_z3_1;
  let $dst_port = $dst_port_z3_1;
}

ob1.mysql alter system migrate unit $unit_id destination "$dst";
ob1.check_until_timeout SELECT COUNT(*) as cnt FROM oceanbase.__all_rootservice_job WHERE unit_id = $unit_id AND job_type = "MIGRATE_UNIT" AND job_status = "SUCCESS", 1, 600;
ob1.check_until_timeout select count(1) from oceanbase.__all_virtual_ls_meta_table where tenant_id = $tenant_id and ls_id = $ls_id and svr_port = '$dst_port' and replica_status = 'NORMAL', 1, 100;
ob1.check_until_timeout select count(*) as cnt from oceanbase.GV\$OB_UNITS where unit_id = $unit_id and svr_ip = '$ip' and svr_port = $port, 0, 200;

if ($cur != $dst_z3_0)
{
  ob_connect(conn_mysql, ob1.z3.obs0, root@obtest, , test, , USE_MYSQL_CONNECTOR);
  connection conn_mysql;
}

if ($cur != $dst_z3_1)
{
  ob_connect(conn_mysql, ob1.z3.obs1, root@obtest, , test, , USE_MYSQL_CONNECTOR);
  connection conn_mysql;
}

let $table_name = "t1";
--source include/compaction/check_major_sstable_status.inc
let $table_name = "t2";
--source include/compaction/check_major_sstable_status.inc

select count(*) from t1;
select count(*) from t2;
select * from t1 limit 1;
select * from t2 limit 1;

## Case 4: after errsim, major row store for t1 and co major column store for t2
--echo Start check after errsim, should return back row store
--source include/compaction/row_col_switch_compaction_and_check.inc
select count(*) from t1;
select count(*) from t2;
select * from t1 limit 1;
select * from t2 limit 1;
