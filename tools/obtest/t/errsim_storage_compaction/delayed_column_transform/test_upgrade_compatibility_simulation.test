sleep 20;
ob1.check_until_timeout select count(*) from CDB_OB_MAJOR_COMPACTION where status = 'IDLE' and tenant_id = $tenant_id, 1, 600;
alter table test4 add column group (all columns);
alter table test4 drop column group (all columns, each column);
alter table test5 drop column group (all columns, each column);

#########################################################################
# TEST_4: partition exchange with old version column group
#########################################################################
ob1.mysql alter system set_tp tp_no = 523, error_code = 4016, frequency = 1;
create table test6 (c1 int primary key, c2 int, c3 int) partition by range (c1) (
  partition c1_15 values less than (15),
  partition c1_35 values less than (35)
) with column group (each column);
create table test7 (c1 int primary key, c2 int, c3 int);
create table test8 (c1 int primary key, c2 int, c3 int) partition by range (c1) (
  partition c1_15 values less than (15),
  partition c1_35 values less than (35)
);
create table test9 (c1 int primary key, c2 int, c3 int) with column group (each column);
ob1.mysql alter system set_tp tp_no = 523, error_code = 4016, frequency = 0;
alter table test7 add column group (each column) delayed;
alter table test8 add column group (each column) delayed;
--error 1731
alter table test6 exchange partition c1_15 with table test7 without validation;
--error 1731
alter table test8 exchange partition c1_15 with table test9 without validation;

#########################################################################
# TEST_5: add column instant with old version column group
#########################################################################
ob1.mysql alter system set_tp tp_no = 523, error_code = 4016, frequency = 1;
create table test10 (c1 int primary key, c2 int, c3 int) with column group (each column);
create table test11 (c1 int primary key, c2 int, c3 int) with column group (each column);
alter table test10 add column group (all columns);
alter table test11 add column group (all columns);
alter table test10 drop column group (each column);
alter table test11 drop column group (each column);
ob1.mysql alter system set_tp tp_no = 523, error_code = 4016, frequency = 0;
insert into test10 values (1, 2, 3), (2, 3, 4), (3, 4, 5);
insert into test11 values (1, 2, 3), (2, 3, 4), (3, 4, 5);
alter table test11 add column c4 int after c1;
insert into test10 values (4, 5, 6), (6, 7, 8), (8, 9, 10);
insert into test11 values (4, 5, 6, 7), (5, 6, 7, 8), (6, 7, 8, 9);
alter table test10 add column group (each column) delayed;
alter table test11 add column group (each column) delayed;
alter table test10 add column c4 int after c1;
alter table test11 add column c5 int after c4;
insert into test10 values (9, 10, 11, 12), (10, 11, 12, 13);
insert into test11 values (9, 10, 11, 12, 13), (10, 11, 12, 13, 14);
eval select column_group_id, column_group_name, column_group_type from oceanbase.__all_column_group_history where table_id = (select table_id from oceanbase.__all_table where table_name = 'test10');
eval select column_group_id, column_group_name, column_group_type from oceanbase.__all_column_group_history where table_id = (select table_id from oceanbase.__all_table where table_name = 'test11');
ob1.mysql alter system major freeze tenant all;
sleep 20;
ob1.check_until_timeout select count(*) from CDB_OB_MAJOR_COMPACTION where status = 'IDLE' and tenant_id = $tenant_id, 1, 600;
alter table test10 modify c1 varchar(256);
alter table test11 modify c1 varchar(256);
eval select column_group_id, column_group_name, column_group_type from oceanbase.__all_column_group_history where table_id = (select table_id from oceanbase.__all_table where table_name = 'test10');
eval select column_group_id, column_group_name, column_group_type from oceanbase.__all_column_group_history where table_id = (select table_id from oceanbase.__all_table where table_name = 'test11');
ob1.mysql alter system major freeze tenant all;
sleep 20;
ob1.check_until_timeout select count(*) from CDB_OB_MAJOR_COMPACTION where status = 'IDLE' and tenant_id = $tenant_id, 1, 600;
select * from test10;
select * from test11;
