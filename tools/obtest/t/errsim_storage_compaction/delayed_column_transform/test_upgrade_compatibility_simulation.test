# TEST_3: delayed column transform from old version column group
#########################################################################
ob1.mysql alter system set_tp tp_no = 523, error_code = 4016, frequency = 1;
create table test4 (c1 int primary key, c2 int, c3 int);
create table test5 (c1 int primary key, c2 int, c3 int) with column group (all columns);
