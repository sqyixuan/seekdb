#########################################################################
# TEST_8: drop column instant with old version column group (oracle)
#########################################################################
connection conn_oracle;
ob1.mysql alter system set_tp tp_no=523, error_code = 4016, frequency = 1;
create table test23 (c1 int primary key, c2 int, c3 int) with column group (each column);
create table test24 (c1 int primary key, c2 int, c3 int);
alter table test23 add column group (all columns);
alter table test23 drop column group (each column);
ob1.mysql alter system set_tp tp_no=523, error_code = 4016, frequency = 0;
alter table test23 add c4 int;
alter table test24 add c4 int;
alter table test23 drop column c2;
alter table test24 drop column c2;
insert into test23 values (1, 2, 3), (2, 3, 4), (3, 4, 5);
insert into test24 values (1, 2, 3), (2, 3, 4), (3, 4, 5);
ob1.mysql alter system major freeze tenant all;
sleep 20;
ob1.check_until_timeout select count(*) from CDB_OB_MAJOR_COMPACTION where status = 'IDLE' and tenant_id = $tenant_id_oracle, 1, 600;
connection conn_sys;
--disable_query_log
eval select column_group_id, column_group_type from oceanbase.__all_virtual_column_group_history where tenant_id = $tenant_id_oracle and table_id = (select table_id from oceanbase.__all_virtual_table where table_name = 'test23');
eval select column_group_id, column_group_type from oceanbase.__all_virtual_column_group_history where tenant_id = $tenant_id_oracle and table_id = (select table_id from oceanbase.__all_virtual_table where table_name = 'test24');
--enable_query_log
connection conn_oracle;
alter table test23 add column group (each column) delayed;
alter table test24 add column group (each column) delayed;
alter table test23 add c5 int;
alter table test24 add c5 int;
alter table test23 drop column c3;
alter table test24 drop column c3;
insert into test23 values (4, 5, 6), (5, 6, 7), (6, 7, 8);
insert into test24 values (4, 5, 6), (5, 6, 7), (6, 7, 8);
ob1.mysql alter system major freeze tenant all;
sleep 20;
ob1.check_until_timeout select count(*) from CDB_OB_MAJOR_COMPACTION where status = 'IDLE' and tenant_id = $tenant_id_oracle, 1, 600;
connection conn_sys;
--disable_query_log
eval select column_group_id, column_group_type from oceanbase.__all_virtual_column_group_history where tenant_id = $tenant_id_oracle and table_id = (select table_id from oceanbase.__all_virtual_table where table_name = 'test23');
eval select column_group_id, column_group_type from oceanbase.__all_virtual_column_group_history where tenant_id = $tenant_id_oracle and table_id = (select table_id from oceanbase.__all_virtual_table where table_name = 'test24');
--enable_query_log
connection conn_oracle;
alter table test23 modify c1 number(38);
alter table test24 modify c1 number(38);
connection conn_sys;
--disable_query_log
eval select column_group_id, column_group_type from oceanbase.__all_virtual_column_group_history where tenant_id = $tenant_id_oracle and table_id = (select table_id from oceanbase.__all_virtual_table where table_name = 'test23');
eval select column_group_id, column_group_type from oceanbase.__all_virtual_column_group_history where tenant_id = $tenant_id_oracle and table_id = (select table_id from oceanbase.__all_virtual_table where table_name = 'test24');
--enable_query_log
connection conn_oracle;
select * from test23;
select * from test24;