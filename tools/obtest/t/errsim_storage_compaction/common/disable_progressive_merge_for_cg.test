# owner:lixia.yq
# owner group:storage
# schedule new major for ddl old major sstable

ob1=OBI(cluster=1, proxy_num=0, init_unit_cpu=2);
ob1.reboot;
sleep 5;

--source include/compaction/set_common_parameters.inc

--disable_query_log
--disable_warnings
let $ip = deploy_get_value(ob1.z1.obs0.ip);
let $port = deploy_get_value(ob1.z1.obs0.mysql_port);

# set EN_ENABLE_SHARED_STORAGE_COLUMN_GROUP to enable column group under shared-storage mode
ob1.mysql alter system set_tp tp_no = 2502, error_code = 4016, frequency = 1;

connect (conn1,$ip,root@obtest,,test,$port);
ob1.mysql alter system set_tp tp_name = "EN_COMPACTION_DISABLE_ROW_COL_SWITCH", error_code = 4016, frequency = 1;
ob1.mysql alter system set_tp tp_name = "EN_COMPACTION_DISABLE_SHARED_MACRO", error_code = 4023, frequency = 1;
connection conn1;
set @@recyclebin = off;
drop table if exists t1,t2;
--enable_warnings
--enable_query_log

create table t1(a int, b varchar(3048), primary key (a), c int) with column group (all columns, each column);
create table t2(a int, b varchar(3048), primary key (a), c int) with column group (each column);
create table t3(pk int, c1 int, c2 int unsigned, c3 varchar(100));
sleep 10;

INSERT INTO t1 VALUES(1, "111", 1);
INSERT INTO t2 VALUES(1, "111", 1);
INSERT INTO t3 VALUES(1, 1, 1, "111");

# when create empty major, the compressor_type/row_store_type is default val; so schema changed = true in first major
ob1.mysql alter system major freeze tenant obtest;
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where LAST_SCN != GLOBAL_BROADCAST_SCN , 1, 100;
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where LAST_SCN != GLOBAL_BROADCAST_SCN , 0, 1200;

###############################
# test add column for row_store
###############################
let $expect_progressive_merge_round = deploy_get_value(select progressive_merge_round + 1 as result from oceanbase.__all_virtual_table where table_name = "t3", result, 1);

connection conn1;
alter table t3 add column d int, add column e int;

let $new_progressive_merge_round = deploy_get_value(select progressive_merge_round from oceanbase.__all_virtual_table where table_name = "t3", progressive_merge_round, 1);
if ($expect_progressive_merge_round != $new_progressive_merge_round)
{
  --echo "should inc progressive_merge_round when add column for row_store table", $expect_progressive_merge_round, $new_progressive_merge_round
}

###############################
# test add column for column_store with ALL_CG
###############################
let $expect_progressive_merge_round = deploy_get_value(ob1.select select progressive_merge_round + 1 as result from oceanbase.__all_virtual_table where table_name = "t1", result, 1);

connection conn1;
alter table t1 add column d int, add column e int;

let $new_progressive_merge_round = deploy_get_value(ob1.select select progressive_merge_round from oceanbase.__all_virtual_table where table_name = "t1", progressive_merge_round, 1);
if ($expect_progressive_merge_round != $new_progressive_merge_round)
{
  --echo "should not inc progressive_merge_round when add column for column_store table", $expect_progressive_merge_round, $new_progressive_merge_round
}

###############################
# test add column for column_store without ALL_CG
###############################
let $expect_progressive_merge_round = deploy_get_value(ob1.select select progressive_merge_round as result from oceanbase.__all_virtual_table where table_name = "t2", result, 1);

connection conn1;
alter table t2 add column d int, add column e int;

let $new_progressive_merge_round = deploy_get_value(ob1.select select progressive_merge_round from oceanbase.__all_virtual_table where table_name = "t2", progressive_merge_round, 1);
if ($expect_progressive_merge_round != $new_progressive_merge_round)
{
  --echo "should not inc progressive_merge_round when add column for column_store table", $expect_progressive_merge_round, $new_progressive_merge_round
}

###############################
# test major merge
###############################
connection conn1;
INSERT INTO t1(a,b,c) VALUES(2, "111", 1);
INSERT INTO t2(a,b,c) VALUES(2, "111", 1);
INSERT INTO t3(pk,c1,c2,c3) VALUES(2, 1, 1, "111");

connection conn1;
alter system major freeze;
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where LAST_SCN != GLOBAL_BROADCAST_SCN , 1, 100;
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where LAST_SCN != GLOBAL_BROADCAST_SCN , 0, 1200;

let $tenant_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_virtual_table where table_name = "t1", tenant_id, 1);
let $tablet_id = deploy_get_value(ob1.select select tablet_id from oceanbase.__all_virtual_table where table_name = "t1", tablet_id, 1);
let $major_scn = deploy_get_value(ob1.select select GLOBAL_BROADCAST_SCN as scn from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id = $tenant_id, scn, 1);

let $merge_level = deploy_get_value(ob1.select select merge_level from oceanbase.__all_virtual_tablet_compaction_history where tenant_id=$tenant_id and tablet_id=$tablet_id and type="MAJOR_MERGE" and compaction_scn=$major_scn, merge_level, 1);
if ($merge_level != "MICRO_BLOCK_LEVEL")
{
  --echo "wrong merge level", $merge_level
}
#ob1.z1.obs0.check_until_timeout select count(*) > 0 from oceanbase.__all_server_event_history where module='merge_errsim' and event='cg_disable_progressive', 1, 600;

connection conn1;
alter system major freeze;
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where LAST_SCN != GLOBAL_BROADCAST_SCN , 1, 100;
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where LAST_SCN != GLOBAL_BROADCAST_SCN , 0, 1200;

ob1.z1.obs0.check_until_timeout select count(*) > 0 from oceanbase.__all_server_event_history where module='merge_errsim' and event='progressive_merge_finish' and name1='tablet_id' and value1=$tablet_id, 1, 600;

connection conn1;
drop table t1,t2,t3;
