# owner:lixia.yq
# owner group:storage
# test storage schema should change after ddl
# 1) macro reuse
# 2) alter compressor_name
# 3) add column

ob1=OBI(cluster=1, proxy_num=0, init_unit_cpu=2);
ob1.reboot;
sleep 5;

--source include/compaction/set_common_parameters.inc

let $ip = deploy_get_value(ob1.z1.obs0.ip);
let $port = deploy_get_value(ob1.z1.obs0.mysql_port);

connect (conn1,$ip,root@obtest,,test,$port);
connection conn1;
create table test01(c1 int, c2 int, c3 varchar(40960), c4 varchar(10) generated always as (substring(c3, 2, 8)) virtual) compression = 'none';
create index idx1 on test01(c2);
let $tenant_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name='obtest', tenant_id, 1);
let $tablet_id = deploy_get_value(ob1.select select tablet_id from oceanbase.__all_virtual_tablet_to_ls where table_id = (select table_id from oceanbase.__all_virtual_table where table_name='test01'), tablet_id, 1);
--disable_query_log
let $cnt=1;
while($cnt < 1000)
{
  eval insert into test01(c1,c2,c3) values($cnt, $cnt, repeat('oceanbase', 4096));
  inc $cnt;
}
--enable_query_log

ob1.mysql alter system minor freeze tenant obtest;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table_mgr where table_type=0 and is_active='NO', 0, 300;

ob1.z1.obs0.check_log_until_success -c "success to init storage schema.*tablet_id..id:$tablet_id.*column_info_simplified:0";

ob1.mysql alter system major freeze tenant obtest;
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where LAST_SCN != GLOBAL_BROADCAST_SCN , 1, 100;
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where LAST_SCN != GLOBAL_BROADCAST_SCN , 0, 1200;

#########################################################################
# TEST_1: no inc data, all macro need be multiplexed
#########################################################################

ob1.mysql alter system major freeze tenant obtest;
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where LAST_SCN != GLOBAL_BROADCAST_SCN , 1, 100;
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where LAST_SCN != GLOBAL_BROADCAST_SCN , 0, 1200;
let $major_scn = deploy_get_value(ob1.select select GLOBAL_BROADCAST_SCN from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id = $tenant_id, GLOBAL_BROADCAST_SCN, 1);
# merge level should equal to MICRO_BLOCK_MERGE_LEVEL
ob1.z1.obs0.check_log_until_success -c "T$tenant_id.*tablet_id:.id:$tablet_id.*merge_level:1";
# all macro should be multiplexed
let $record_cnt = deploy_get_value(select count(*) as cnt from oceanbase.__all_virtual_tablet_compaction_history where tenant_id=$tenant_id and tablet_id=$tablet_id and type like '%MAJOR%' and compaction_scn=$major_scn, cnt, 1);
--disable_query_log
--disable_result_log
if ($record_cnt > 0)
{
  ob1.check_until_timeout select count(*) > 0 from oceanbase.__all_virtual_tablet_compaction_history where tenant_id=$tenant_id and tablet_id=$tablet_id and type like "MAJOR%" and compaction_scn=$major_scn and macro_block_count=multiplexed_macro_block_count and merge_level = "MICRO_BLOCK_LEVEL", 1, 300;
}
--enable_query_log
--enable_result_log

#########################################################################
# TEST_2: alter compressor_type
#########################################################################
alter table test01 compression = 'zstd_1.3.8';

ob1.mysql alter system major freeze tenant obtest;
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where LAST_SCN != GLOBAL_BROADCAST_SCN , 1, 100;
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where LAST_SCN != GLOBAL_BROADCAST_SCN , 0, 1200;

# merge level should equal to MACRO_BLOCK_MERGE_LEVEL
let $major_scn = deploy_get_value(ob1.select select GLOBAL_BROADCAST_SCN from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id = $tenant_id, GLOBAL_BROADCAST_SCN, 1);
ob1.check_until_timeout select count(*) > 0 from oceanbase.__all_virtual_tablet_compaction_history where tenant_id=$tenant_id and tablet_id=$tablet_id and type like "MAJOR%" and compaction_scn=$major_scn and merge_level = "MACRO_BLOCK_LEVEL", 1, 300;
ob1.check_until_timeout select count(*) > 0 from oceanbase.__all_virtual_tablet_sstable_macro_info where tenant_id=$tenant_id and tablet_id=$tablet_id and macro_logic_version=$major_scn and compressor_name = 'zstd_1.3.8', 1, 300;

#########################################################################
# TEST_3: add column
#########################################################################
alter table test01 add column d int;
--disable_query_log
let $cnt=1;
while($cnt < 10)
{
  eval insert into test01(c1,c2,c3, d)  values($cnt, $cnt, repeat('oceanbase', 4096), $cnt * 2);
  inc $cnt;
}
--enable_query_log

ob1.mysql alter system minor freeze tenant = 'obtest';
ob1.check_until_timeout select count(1) from oceanbase.__all_virtual_table_mgr where table_type = 0 and is_active = 0 and tenant_id=$tenant_id and tablet_id =$tablet_id, 0, 300;
ob1.z1.obs0.check_log_until_success -c "success to init storage schema.*tablet_id..id:$tablet_id.*param_schema_stored_col_cnt=5.*column_info_simplified:1";

#########################################################################
# TEST_4: alter block size
#########################################################################

alter table test01 block_size = 32768;
ob1.mysql alter system major freeze tenant = 'obtest';
ob1.z1.obs0.check_log_until_success -c "success to init storage schema.*tablet_id..id:$tablet_id.*block_size:32768";
