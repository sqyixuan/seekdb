# owner:xiekaige.xkg
# owner group:storage
# test tablet major full merge 

ob1=OBI(cluster=1, proxy_num=0, init_unit_cpu=0);
ob1.reboot;

let $svr_ip = deploy_get_value(ob1.z1.obs0.ip);
let $svr_port = deploy_get_value(ob1.z1.obs0.mysql_port);

connect (obsys, $svr_ip, root@sys, , oceanbase, $svr_port);
connection obsys;


alter system set major_freeze_duty_time = 'Disable' tenant sys;
alter system set ob_compaction_schedule_interval = '10s' tenant sys;
alter system set _enable_adaptive_compaction = 'False' tenant sys;

# alter system set minor_compact_trigger = 2 tenant sys;

let $sys_tenant_id = query_get_value(select tenant_id from __all_tenant where tenant_name = 'sys', tenant_id, 1);

drop table if exists test_tablet_full_merge;
create table test_tablet_full_merge(i int primary key, c1 char(30), c256 char(255), dt datetime(6), d  datetime(6));

ob1.mysql alter table oceanbase.test_tablet_full_merge SET PROGRESSIVE_MERGE_NUM=1;

--disable_query_log
let $i=0;
while($i < 20)
{
    eval insert into test_tablet_full_merge(i,c1,c256,dt,d) values($i,'1','$i','2012-10-10 12:00:00','2012-10-10');
    inc $i;
} 
--enable_query_log

let $__tenant_id__=deploy_get_value(ob1.select select /*+QUERY_TIMEOUT(10000000)*/ tenant_id from oceanbase.__all_virtual_table where table_name= 'test_tablet_full_merge', tenant_id, 1);
let $__tablet_id__=deploy_get_value(ob1.select select /*+QUERY_TIMEOUT(10000000)*/ tablet_id from oceanbase.__all_virtual_table where table_name= 'test_tablet_full_merge', tablet_id, 1);

let $ls_id = deploy_get_value(ob1.select select ls_id from oceanbase.__all_virtual_tablet_to_ls where tenant_id=$__tenant_id__ and tablet_id=$__tablet_id__, ls_id, 1);
let $leader_port = deploy_get_value(ob1.select select svr_port from oceanbase.__all_virtual_ls_meta_table where tenant_id=$__tenant_id__ and ls_id=$ls_id and role = 1, svr_port, 1);

#########################################################################
# TEST_1: alter tablet major freeze after minor
#########################################################################

ob1.mysql alter system minor freeze tenant = sys;
ob1.check_until_timeout select count(1) from oceanbase.__all_virtual_table_mgr where table_type = 0 and is_active = 0 and tenant_id=$tenant_id and tablet_id =$tablet_id, 0, 300;

ob1.check_until_timeout select count(*) as c from oceanbase.__all_virtual_tablet_compaction_info where tenant_id=$__tenant_id__ and tablet_id=$__tablet_id__ and wait_check_scn != 0 and svr_port = $leader_port, 0, 500;

ob1.mysql alter system major freeze tenant = sys;
ob1.check_until_timeout select count(*) > 0 from oceanbase.__all_virtual_tablet_compaction_history where tenant_id=$__tenant_id__ and tablet_id=$__tablet_id__ and type ='MAJOR_MERGE' and is_full_merge=true, 1, 500;

#########################################################################
# TEST_2: alter tablet major freeze after major
#########################################################################
sleep 15;
ob1.mysql alter system major freeze tenant = sys;
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where LAST_SCN != GLOBAL_BROADCAST_SCN , 1, 100;
sleep 30;

ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where LAST_SCN != GLOBAL_BROADCAST_SCN , 0, 300;


--disable_query_log
let $i=20;
while($i < 40)
{
    eval insert into test_tablet_full_merge(i,c1,c256,dt,d) values($i,'1','$i','2012-10-10 12:00:00','2012-10-10');
    inc $i;
}
--enable_query_log

ob1.mysql alter system minor freeze tenant = sys;
ob1.check_until_timeout select count(1) from oceanbase.__all_virtual_table_mgr where table_type = 0 and is_active = 0 and tenant_id=$tenant_id and tablet_id =$tablet_id, 0, 300;

let $last_major_scn = deploy_get_value(ob1.select select frozen_scn from oceanbase.__all_virtual_freeze_info where tenant_id=$__tenant_id__, frozen_scn, 2);
let $ls_id = deploy_get_value(ob1.select select ls_id from oceanbase.__all_virtual_tablet_to_ls where tenant_id=$__tenant_id__ and tablet_id=$__tablet_id__, ls_id, 1);
let $leader_port = deploy_get_value(ob1.select select svr_port from oceanbase.__all_virtual_ls_meta_table where tenant_id=$__tenant_id__ and ls_id=$ls_id and role = 1, svr_port, 1);

ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_tablet_compaction_info where tenant_id=$__tenant_id__ and tablet_id=$__tablet_id__ and wait_check_scn != 0 and svr_port = $leader_port, 0, 500;

ob1.mysql alter system major freeze tenant = sys;
ob1.check_until_timeout select count(*) > 0 from oceanbase.__all_virtual_tablet_compaction_history where tenant_id=$__tenant_id__ and tablet_id=$__tablet_id__ and compaction_scn > $last_major_scn and type ='MAJOR_MERGE' and is_full_merge=true, 1, 500;