# owner:xiekaige.xkg
# owner group:storage
# test adaptively_reclaim_thread

ob1=OBI(cluster=1, proxy_num=0, init_unit_cpu=0);
ob1.reboot;

let $svr_ip = deploy_get_value(ob1.z1.obs0.ip);
let $svr_port = deploy_get_value(ob1.z1.obs0.mysql_port);

connect (obsys, $svr_ip, root@sys, , oceanbase, $svr_port);
connection obsys;


alter system set major_freeze_duty_time = 'Disable' tenant sys;
alter system set ob_compaction_schedule_interval = '10s' tenant sys;
alter system set _enable_adaptive_compaction = 'False' tenant sys;

let $sys_tenant_id = query_get_value(select tenant_id from __all_tenant where tenant_name = 'sys', tenant_id, 1);
drop table if exists test_adaptive_reclaim;
create table test_adaptive_reclaim(i int primary key, c1 char(30), c256 char(255), dt datetime(6), d  datetime(6));

--disable_query_log
let $i=0;
while($i < 20)
{
    eval insert into test_adaptive_reclaim(i,c1,c256,dt,d) values($i,'1','$i','2012-10-10 12:00:00','2012-10-10');
    inc $i;
} 
--enable_query_log

let $__tenant_id__=deploy_get_value(ob1.select select /*+QUERY_TIMEOUT(10000000)*/ tenant_id from oceanbase.__all_virtual_table where table_name= 'test_adaptive_reclaim', tenant_id, 1);
let $__tablet_id__=deploy_get_value(ob1.select select /*+QUERY_TIMEOUT(10000000)*/ tablet_id from oceanbase.__all_virtual_table where table_name= 'test_adaptive_reclaim', tablet_id, 1);

let $ls_id = deploy_get_value(ob1.select select ls_id from oceanbase.__all_virtual_tablet_to_ls where tenant_id=$__tenant_id__ and tablet_id=$__tablet_id__, ls_id, 1);
let $leader_port = deploy_get_value(ob1.select select svr_port from oceanbase.__all_virtual_ls_meta_table where tenant_id=$__tenant_id__ and ls_id=$ls_id and role = 1, svr_port, 1);
####################################################################
#####   test adaptively_reclaim_thread after minor freeze        ###
####################################################################

ob1.mysql alter system set_tp tp_no = 761, error_code = 4679, frequency = 1;

ob1.mysql alter system minor freeze tenant = sys;

ob1.check_until_timeout select count(1) from __all_virtual_dag_scheduler where tenant_id = $sys_tenant_id and `key` = 'TOTAL_WORKER_CNT' and value != 0, 1, 100;

ob1.check_until_timeout select count(1) from oceanbase.__all_virtual_table_mgr where table_type = 0 and is_active = 0 and tenant_id=$tenant_id and tablet_id =$tablet_id, 0, 300;

ob1.check_until_timeout select count(1) from __all_virtual_dag_scheduler where tenant_id = $sys_tenant_id and `key` = 'TOTAL_WORKER_CNT' and value = 0, 1, 300;
