# owner:fengjingkun.fjk
# owner group:storage
# test parallel minor merge dag

ob1=OBI(cluster=1, proxy_num=0, init_unit_cpu=0);
ob1.reboot;

let $svr_ip = deploy_get_value(ob1.z1.obs0.ip);
let $svr_port = deploy_get_value(ob1.z1.obs0.mysql_port);

connect (obsys, $svr_ip, root@sys, , oceanbase, $svr_port);
connection obsys;


alter system set major_freeze_duty_time = 'Disable' tenant sys;
alter system set ob_compaction_schedule_interval = '10s' tenant sys;
alter system set _enable_adaptive_compaction = 'False' tenant sys;
alter system set minor_compact_trigger = 2 tenant sys;


create table t1 (c1 bigint, c2 varchar(10));
let $sys_tenant_id = query_get_value(select tenant_id from __all_tenant where tenant_name = 'sys', tenant_id, 1);

let $t1_table_id = query_get_value(select table_id from __all_virtual_table where table_name like "%t1%", table_id, 1);
let $t1_tablet_id = query_get_value(select tablet_id from __all_virtual_tablet_to_ls where table_id = $t1_table_id, tablet_id, 1);
let $t1_ls_id = query_get_value(select ls_id from __all_virtual_tablet_to_ls where table_id = $t1_table_id, ls_id, 1);

###############################
### check too many sstables ###
###############################
ob1.mysql alter system set_tp tp_name = "ERRSIM_DISABLE_MINOR_MERGE", error_code = 4016, frequency = 1;
let $freeze_cnt = 63;
while ($freeze_cnt > 0)
{
  insert into t1 select random(), randstr(10, random()) from table(generator(200));
  let $pre_mini_sst_cnt = query_get_value(select freeze_clock from __all_virtual_minor_freeze_info where tenant_id = $sys_tenant_id and tablet_id = $t1_tablet_id and ls_id = $t1_ls_id, freeze_clock, 1);
  let $cur_mini_sst_cnt = query_get_value(select freeze_clock from __all_virtual_minor_freeze_info where tenant_id = $sys_tenant_id and tablet_id = $t1_tablet_id and ls_id = $t1_ls_id, freeze_clock, 1);
  let $retry_cnt = 10;
  ## chech if minor freeze success
  --disable_query_log
  --disable_result_log
  while ($retry_cnt > 0)
  {
    if ($pre_mini_sst_cnt == $cur_mini_sst_cnt)
    {
      alter system minor freeze;
      sleep 1;
      ob1.check_until_timeout select count(1) from __all_virtual_minor_freeze_info where tenant_id = $sys_tenant_id and tablet_id = $t1_tablet_id and ls_id = $t1_ls_id and state= "FINISH", 0, 10;  
      let $cur_mini_sst_cnt = query_get_value(select freeze_clock from __all_virtual_minor_freeze_info where tenant_id = $sys_tenant_id and tablet_id = $t1_tablet_id and ls_id = $t1_ls_id, freeze_clock, 1);
    }
    dec $retry_cnt;
  }
  --enable_result_log
  --enable_query_log
  ## check if mini merge success
  ob1.check_until_timeout select count(1) from __all_virtual_table_mgr where tenant_id = $sys_tenant_id and tablet_id = $t1_tablet_id and table_type = 0 and is_active = "YES", 0, 100;
  dec $freeze_cnt;
}

let $ck_minor_cnt = query_get_value(select count(1) as value from __all_virtual_tablet_compaction_history where tenant_id = $sys_tenant_id and tablet_id = $t1_tablet_id and type = 'MINOR_MERGE', value, 1);
if ($ck_minor_cnt > 0)
{
  --echo unexpected minor merge
}

insert into t1 select random(), randstr(10, random()) from table(generator(200));
alter system minor freeze;
sleep 10;

let $mem_cnt = query_get_value(select count(1) as value from __all_virtual_table_mgr where tenant_id = $sys_tenant_id and tablet_id = $t1_tablet_id and table_type = 0, value, 1);
if ($mem_cnt == 0)
{
  --echo failed to prevent too many sstables problem
}


################################
### check parallel minor dag ###
################################
ob1.mysql alter system set_tp tp_name = "ERRSIM_DISABLE_MINOR_MERGE", error_code = 4016, frequency = 0;
ob1.check_until_timeout select count(1) from __all_virtual_tablet_compaction_history where tenant_id = $sys_tenant_id and tablet_id = $t1_tablet_id and type = 'MINOR_MERGE', 7, 100;


#################################
### test parallel minor merge ###
#################################
create table t2 (c1 bigint, c2 varchar(10000)) COMPRESSION = 'None' TABLET_SIZE = 33554432;

let $t2_table_id = query_get_value(select table_id from __all_virtual_table where table_name like "%t2%", table_id, 1);
let $t2_tablet_id = query_get_value(select tablet_id from __all_virtual_tablet_to_ls where table_id = $t2_table_id, tablet_id, 1);
let $t2_ls_id = query_get_value(select ls_id from __all_virtual_tablet_to_ls where table_id = $t2_table_id, ls_id, 1);

ob1.mysql alter system set_tp tp_name = "ERRSIM_DISABLE_MINOR_MERGE", error_code = 4016, frequency = 1;
let $freeze_cnt = 3;
while ($freeze_cnt > 0)
{
  Insert /* append enable_parallel_dml parallel(8) */ into t2 select random(), repeat('BatMan_NO1', 1000) from table(generator(10000));
  let $pre_mini_sst_cnt = query_get_value(select freeze_clock from __all_virtual_minor_freeze_info where tenant_id = $sys_tenant_id and tablet_id = $t2_tablet_id and ls_id = $t2_ls_id, freeze_clock, 1);
  let $cur_mini_sst_cnt = query_get_value(select freeze_clock from __all_virtual_minor_freeze_info where tenant_id = $sys_tenant_id and tablet_id = $t2_tablet_id and ls_id = $t2_ls_id, freeze_clock, 1);
  let $retry_cnt = 10;
  ## chech if minor freeze success
  --disable_query_log
  --disable_result_log
  while ($retry_cnt > 0)
  {
    if ($pre_mini_sst_cnt == $cur_mini_sst_cnt)
    {
      alter system minor freeze;
      sleep 1;
      ob1.check_until_timeout select count(1) from __all_virtual_minor_freeze_info where tenant_id = $sys_tenant_id and tablet_id = $t2_tablet_id and ls_id = $t2_ls_id and state= "FINISH", 0, 10;  
      let $cur_mini_sst_cnt = query_get_value(select freeze_clock from __all_virtual_minor_freeze_info where tenant_id = $sys_tenant_id and tablet_id = $t2_tablet_id and ls_id = $t2_ls_id, freeze_clock, 1);
    }
    dec $retry_cnt;
  }
  --enable_result_log
  --enable_query_log
  ## check if mini merge success
  ob1.check_until_timeout select count(1) from __all_virtual_table_mgr where tenant_id = $sys_tenant_id and tablet_id = $t2_tablet_id and table_type = 0 and is_active = "YES", 0, 100;
  dec $freeze_cnt;
}


ob1.mysql alter system set_tp tp_name = "ERRSIM_DISABLE_MINOR_MERGE", error_code = 4016, frequency = 0;
ob1.check_until_timeout select count(1) from __all_virtual_tablet_compaction_history where tenant_id = $sys_tenant_id and tablet_id = $t2_tablet_id and type = 'MINOR_MERGE', 1, 100;
let $old_compaction_scn = query_get_value(select compaction_scn from __all_virtual_tablet_compaction_history where tenant_id = $sys_tenant_id and tablet_id = $t2_tablet_id and type = 'MINOR_MERGE', compaction_scn, 1);
let $parallel_degree = query_get_value(select parallel_degree from __all_virtual_tablet_compaction_history where tenant_id = $sys_tenant_id and tablet_id = $t2_tablet_id and type = 'MINOR_MERGE', parallel_degree, 1);
if ($parallel_degree > 1)
{
  --echo success to do parallel minor merge
}



####################################
### Disable parallel minor merge ###
####################################
ob1.mysql alter system set_tp tp_name = "ERRSIM_DISABLE_MINOR_MERGE", error_code = 4016, frequency = 1;
ob1.mysql alter system set _enable_parallel_minor_merge = False tenant sys;

let $freeze_cnt = 2;
while ($freeze_cnt > 0)
{
  Insert /* append enable_parallel_dml parallel(8) */ into t2 select random(), repeat('BatMan_NO1', 1000) from table(generator(10000));
  let $pre_mini_sst_cnt = query_get_value(select freeze_clock from __all_virtual_minor_freeze_info where tenant_id = $sys_tenant_id and tablet_id = $t2_tablet_id and ls_id = $t2_ls_id, freeze_clock, 1);
  let $cur_mini_sst_cnt = query_get_value(select freeze_clock from __all_virtual_minor_freeze_info where tenant_id = $sys_tenant_id and tablet_id = $t2_tablet_id and ls_id = $t2_ls_id, freeze_clock, 1);
  let $retry_cnt = 10;
  ## chech if minor freeze success
  --disable_query_log
  --disable_result_log
  while ($retry_cnt > 0)
  {
    if ($pre_mini_sst_cnt == $cur_mini_sst_cnt) 
    {
      alter system minor freeze;
      sleep 1;
      ob1.check_until_timeout select count(1) from __all_virtual_minor_freeze_info where tenant_id = $sys_tenant_id and tablet_id = $t2_tablet_id and ls_id = $t2_ls_id and state= "FINISH", 0, 10;  
      let $cur_mini_sst_cnt = query_get_value(select freeze_clock from __all_virtual_minor_freeze_info where tenant_id = $sys_tenant_id and tablet_id = $t2_tablet_id and ls_id = $t2_ls_id, freeze_clock, 1);
    }
    dec $retry_cnt;
  }
  --enable_result_log
  --enable_query_log
  ## check if mini merge success
  ob1.check_until_timeout select count(1) from __all_virtual_table_mgr where tenant_id = $sys_tenant_id and tablet_id = $t2_tablet_id and table_type = 0 and is_active = "YES", 0, 100;
  dec $freeze_cnt;
}

ob1.mysql alter system set_tp tp_name = "ERRSIM_DISABLE_MINOR_MERGE", error_code = 4016, frequency = 0;
ob1.check_until_timeout select count(1) from __all_virtual_tablet_compaction_history where tenant_id = $sys_tenant_id and tablet_id = $t2_tablet_id and type = 'MINOR_MERGE' and compaction_scn > $old_compaction_scn, 1, 100;
let $parallel_degree = query_get_value(select parallel_degree from __all_virtual_tablet_compaction_history where tenant_id = $sys_tenant_id and tablet_id = $t2_tablet_id and type = 'MINOR_MERGE' and compaction_scn > $old_compaction_scn, parallel_degree, 1);
if ($parallel_degree == 1)
{
  --echo success to disable parallel minor merge
}
