# owner: ouyanghongrong.oyh
# owner group: storage
# description: test default value trim space progressive merge and verifying checksum 
# 
ob1=OBI(cluster=1:1,proxy_num=0,init_unit_cpu=5);
ob1.reboot;
sleep 10;

--echo ===============================================================
--echo =================  Step 0: prepare env   ======================
--echo ===============================================================

--source include/compaction/set_common_parameters.inc
ob1.mysql alter resource unit sys_unit_config memory_size='2G';
ob1.mysql alter system set default_compress_func = 'none';

let $proxy_ip = deploy_get_value(ob1.z1.obs0.ip);
let $proxy_port = deploy_get_value(ob1.z1.obs0.mysql_port);

--echo ===============================================================
--echo =================  Step 1: create tenant   ====================
--echo ===============================================================

connect(sys_conn, $proxy_ip, root@sys,,oceanbase, $proxy_port);
connection sys_conn;
source include/get_user_config.inc;
ob1.mysql create resource pool oracle_replica_pool unit = "user_unit_config", unit_num = 1, zone_list = ('z1', 'z2');
ob1.mysql create TENANT oracle resource_pool_list=('oracle_replica_pool'), replica_num=2, zone_list = ('z1', 'z2'), locality = "F@z1, F@z2" set ob_tcp_invited_nodes='%', ob_compatibility_mode='oracle';
ob1.mysql alter system set ob_compaction_schedule_interval = '10s' tenant oracle;
ob1.mysql alter system set merger_check_interval = '10s' tenant oracle;
ob1.mysql alter tenant oracle set variables autocommit='on';

--echo ===============================================================
--echo =================  Step 1: create table   =====================
--echo ===============================================================
ob_connect(conn_oracle, ob1.z1.obs0, sys@oracle, ,sys, , USE_OB_CONNECTOR);
connection conn_oracle;
set ob_query_timeout = 1000000000;
create table t1 (k int primary key, c1 int, c2 varchar(4000)) nocompress;
create sequence seq cache 1000000 noorder;
insert into t1 select seq.nextval, seq.nextval, randstr(4000, random()) from table(generator(100000));

connect(sys_conn, $proxy_ip, root@sys,,oceanbase, $proxy_port);
connection sys_conn;
let $tenant_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name = "oracle", tenant_id, 1);
let $tablet_id = deploy_get_value(ob1.select select tablet_id from oceanbase.__all_virtual_table where tenant_id = $tenant_id and table_name = 't1', tablet_id, 1);

--echo ===============================================================
--echo ==== Step 2: major freeze and add column with default value ===
--echo ===============================================================
connection conn_oracle;
alter system major freeze;
sleep 60;
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id=$tenant_id and LAST_SCN = GLOBAL_BROADCAST_SCN , 1, 600;

alter table t1 add c5 varchar(16) default ' ';
alter table t1 add c6    char(16) default ' ';
create index idx_c5 on t1(c5);
create index idx_c6 on t1(c6);

alter system major freeze;
sleep 60;
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id=$tenant_id and LAST_SCN = GLOBAL_BROADCAST_SCN , 1, 600;