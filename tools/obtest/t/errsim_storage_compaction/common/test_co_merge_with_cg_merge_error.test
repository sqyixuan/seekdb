# owner:lixia.yq
# owner group:storage
# test co major merge fail

ob1=OBI(cluster=1, proxy_num=0, init_unit_cpu=2);
ob1.reboot;
sleep 5;

--source include/compaction/set_common_parameters.inc
# set EN_ENABLE_SHARED_STORAGE_COLUMN_GROUP to enable column group under shared-storage mode
ob1.mysql alter system set_tp tp_no = 2502, error_code = 4016, frequency = 1;

let $ip = deploy_get_value(ob1.z1.obs0.ip);
let $port = deploy_get_value(ob1.z1.obs0.mysql_port);

connect (conn1,$ip,root@obtest,,test,$port);
connection conn1;
--disable_warnings
drop table if exists t1;
drop table if exists t2;
--enable_warnings
# 196 column
create table t1 (c1 int, c2 int, c3 int, c4 int, c5 int, c6 int, c7 int, c8 int, c9 int, c10 int, c11 int, c12 int, c13 int, c14 int, c15 int, c16 int, c17 int, c18 int, c19 int, c20 int, c21 int, c22 int, c23 int, c24 int, c25 int, c26 int, c27 int, c28 int,c29 int,c30 int,c31 int, c32 int, c33 int, c34 int, c35 int, c36 int, c37 int, c38 int,c39 int,c40 int,c41 int, c42 int, c43 int, c44 int, c45 int, c46 int, c47 int, c48 int,c49 int,c50 int,c51 int, c52 int, c53 int, c54 int, c55 int, c56 int, c57 int, c58 int,c59 int,c60 int,c61 int, c62 int, c63 int, c64 int, c65 int, c66 int, c67 int, c68 int,c69 int,c70 int,c71 int, c72 int, c73 int, c74 int, c75 int, c76 int, c77 int, c78 int,c79 int,c80 int,c81 int, c82 int, c83 int, c84 int, c85 int, c86 int, c87 int, c88 int,c89 int,c90 int,c91 int, c92 int, c93 int, c94 int, c95 int, c96 int, c97 int, c98 int,c99 int,c100 int, c101 int, c102 int, c103 int, c104 int, c105 int, c106 int, c107 int, c108 int, c109 int,c110 int, c111 int, c112 int, c113 int, c114 int, c115 int, c116 int, c117 int, c118 int, c119 int, c120 int, c121 int, c122 int, c123 int, c124 int, c125 int, c126 int, c127 int, c128 int,c129 int,c130 int,c131 int, c132 int, c133 int, c134 int, c135 int, c136 int, c137 int, c138 int,c139 int,c140 int,c141 int, c142 int, c143 int, c144 int, c145 int, c146 int, c147 int, c148 int,c149 int,c150 int,c151 int, c152 int, c153 int, c154 int, c155 int, c156 int, c157 int, c158 int,c159 int,c160 int,c161 int, c162 int, c163 int, c164 int, c165 int, c166 int, c167 int, c168 int,c169 int,c170 int,c171 int, c172 int, c173 int, c174 int, c175 int, c176 int, c177 int, c178 int,c179 int,c180 int,c181 int, c182 int, c183 int, c184 int, c185 int, c186 int, c187 int, c188 int,c189 int,c190 int,c191 int, c192 int, c193 int, c194 int, c195 int, c196 int)  with column group (all columns, each column);
# 15 column
create table t2 (c1 int, c2 int, c3 int, c4 int, c5 int, c6 int, c7 int, c8 int, c9 int, c10 int, c11 int, c12 int, c13 int, c14 int, c15 int);

insert into t1(c1,c2,c3,c4,c5) values(1,2,3,4,5);
insert into t1(c11,c21,c31,c41,c51) values(1,2,3,4,5);
insert into t1(c111,c121,c131,c141,c151) values(1,2,3,4,5);
insert into t1(c1,c2,c3,c4,c5) values(1,2,3,4,5);
insert into t2(c1,c2,c3,c4,c5) values(1,2,3,4,5);

# close row_col switch
ob1.mysql alter system set_tp tp_name = "EN_COMPACTION_DISABLE_ROW_COL_SWITCH", error_code = 4016, frequency = 1;

#########################################################################
# TEST_1: cg execute failed
#########################################################################
# exe dag will retry
# EN_COMPACTION_CO_MERGE_EXE_FAILED = 4016
ob1.mysql alter system set_tp tp_no = 713, error_code = 4016, frequency = 1;
source include/compaction/alter_tenant_obtest_major_freeze_and_sleep.inc;
ob1.check_until_timeout select count(*) > 0 from oceanbase.__all_server_event_history where module = 'merge_errsim' and event = 'co_merge_exe_failed', 1, 600;
#clear EN_COMPACTION_CO_MERGE_EXE_FAILED
sleep 15;
ob1.mysql alter system set_tp tp_no = 713, error_code = 4016, frequency = 0;

# major will finish after close errsim 713
let $tenant_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name = "obtest", tenant_id, 1);
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id = $tenant_id and LAST_SCN != GLOBAL_BROADCAST_SCN, 0, 300;

#########################################################################
# TEST_2: prepare dag failed 4023
#########################################################################
# prepare dag will cancel dag net
# EN_COMPACTION_CO_MERGE_PREPARE_CTX_FAILED = 4023
ob1.mysql alter system set_tp tp_no = 719, error_code = 4023, frequency = 1;
connection conn1;
insert into t1(c1,c2,c3,c4,c5) values(1,2,3,4,5);
insert into t1(c11,c21,c31,c41,c51) values(1,2,3,4,5);
insert into t1(c111,c121,c131,c141,c151) values(1,2,3,4,5);
insert into t2(c1,c2,c3,c4,c5) values(1,2,3,4,5);

select count(*) from t1;
select count(*) from t2;

source include/compaction/alter_tenant_obtest_major_freeze_and_sleep.inc;
ob1.check_until_timeout select count(*) > 0 from oceanbase.__all_server_event_history where module = 'merge_errsim' and event = 'co_merge_prepare_ctx_failed', 1, 600;
ob1.check_until_timeout select count(*) != 0 as c from oceanbase.__all_virtual_dag_warning_history, 1, 300;
#clear EN_COMPACTION_CO_MERGE_PREPARE_CTX_FAILED
ob1.mysql alter system set_tp tp_no = 719, error_code = 4023, frequency = 0;

let $tenant_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name = "obtest", tenant_id, 1);
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id = $tenant_id and LAST_SCN != GLOBAL_BROADCAST_SCN, 0, 300;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_dag where tenant_id = $tenant_id and dag_type like "%CO_MAJOR%", 0, 300;

# EN_COMPACTION_CO_MERGE_PREPARE_FAILED = 4016
ob1.mysql alter system set_tp tp_no = 720, error_code = 4016, frequency = 1;
connection conn1;
insert into t1(c1,c2,c3,c4,c5) values(1,2,3,4,5);
insert into t1(c11,c21,c31,c41,c51) values(1,2,3,4,5);
insert into t1(c111,c121,c131,c141,c151) values(1,2,3,4,5);
insert into t2(c1,c2,c3,c4,c5) values(1,2,3,4,5);

select count(*) from t1;
select count(*) from t2;

source include/compaction/alter_tenant_obtest_major_freeze_and_sleep.inc;
ob1.check_until_timeout select count(*) > 0 from oceanbase.__all_server_event_history where module = 'merge_errsim' and event = 'co_merge_prepare_failed', 1, 600;
ob1.check_until_timeout select count(*) != 0 as c from oceanbase.__all_virtual_dag_warning_history, 1, 300;
#clear EN_COMPACTION_CO_MERGE_PREPARE_FAILED
ob1.mysql alter system set_tp tp_no = 720, error_code = 4016, frequency = 0;

let $tenant_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name = "obtest", tenant_id, 1);
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id = $tenant_id and LAST_SCN != GLOBAL_BROADCAST_SCN, 0, 300;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_dag where tenant_id = $tenant_id and dag_type like "%CO_MAJOR%", 0, 300;

# prepare dag will not cancel dag net
# EN_COMPACTION_CO_MERGE_PREPARE_FAILED = 4023
ob1.mysql alter system set_tp tp_no = 720, error_code = 4023, frequency = 1;
connection conn1;
insert into t1(c1,c2,c3,c4,c5) values(1,2,3,4,5);
insert into t1(c11,c21,c31,c41,c51) values(1,2,3,4,5);
insert into t1(c111,c121,c131,c141,c151) values(1,2,3,4,5);
insert into t2(c1,c2,c3,c4,c5) values(1,2,3,4,5);

select count(*) from t1;
select count(*) from t2;

source include/compaction/alter_tenant_obtest_major_freeze_and_sleep.inc;
ob1.check_until_timeout select count(*) > 0 from oceanbase.__all_server_event_history where module = 'merge_errsim' and event = 'co_merge_prepare_failed' and value1 = -4023, 1, 600;

let $tenant_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name = "obtest", tenant_id, 1);
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id = $tenant_id and LAST_SCN != GLOBAL_BROADCAST_SCN, 0, 300;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_dag where tenant_id = $tenant_id and dag_type like "%CO_MAJOR%", 0, 300;
#clear EN_COMPACTION_CO_MERGE_PREPARE_FAILED
ob1.mysql alter system set_tp tp_no = 720, error_code = 4023, frequency = 0;
ob1.check_until_timeout select count(*) > 0 from oceanbase.__all_virtual_tablet_compaction_history where tenant_id = $tenant_id and type like "%MAJOR%" and end_cg_id != 0 and kept_snapshot != "" and merge_level != "", 1, 300;

#########################################################################
# TEST_3: execute dag push table handle failed 4013
#########################################################################
#EN_COMPACTION_CO_PUSH_TABLES_FAILED = 4013
ob1.mysql alter system set_tp tp_no = 733, error_code = 4013, frequency = 1;
#EN_COMPACTION_ESTIMATE_ROW_FAILED, make it column store merge
ob1.mysql alter system set_tp tp_no = 736, error_code = 4013, frequency = 1;
connection conn1;
insert into t1(c1,c2,c3,c4,c5) values(1,2,3,4,5);
insert into t1(c11,c21,c31,c41,c51) values(1,2,3,4,5);
insert into t1(c111,c121,c131,c141,c151) values(1,2,3,4,5);
insert into t2(c1,c2,c3,c4,c5) values(1,2,3,4,5);

source include/compaction/alter_tenant_obtest_major_freeze_and_sleep.inc;
ob1.check_until_timeout select count(*) > 0 from oceanbase.__all_server_event_history where module = 'merge_errsim' and event = 'co_push_table_failed' and value1 = -4013, 1, 600;

#clear EN_COMPACTION_CO_PUSH_TABLES_FAILED
ob1.mysql alter system set_tp tp_no = 736, error_code = 4013, frequency = 0;
ob1.mysql alter system set_tp tp_no = 733, error_code = 4013, frequency = 0;

ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id = $tenant_id and LAST_SCN != GLOBAL_BROADCAST_SCN, 0, 300;