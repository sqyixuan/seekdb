# owner: yanmu.ztl
# owner group: rs
# description: 验证location_cache在不同region情况下的更新情况
#              1.副本类型装换
#                无论是F->R，还是R->F，由于都涉及到成员列表变更，所有region都能看到相应变化
#              2.宕机情况
#              
#              
--disable_query_log
ob1=OBI(cluster=2:2:2:2:2, init_unit_cpu=0, proxy_num=0, ct_num=0, locality=hz:hz:sh:sh:sz);

ob1.reboot;

ob1.mysql alter system set resource_hard_limit=900;
ob1.mysql alter system set resource_soft_limit=800;
ob1.mysql alter system set debug_sync_timeout = '1000s';
ob1.mysql alter system set enable_auto_leader_switch = 'false';
ob1.mysql alter system set enable_rebalance = 'false';
ob1.mysql alter system set enable_rereplication = 'true';
ob1.mysql alter system set balancer_idle_time = '10s';
ob1.mysql alter system set server_data_copy_out_concurrency = 20;
ob1.mysql alter system set server_data_copy_in_concurrency = 20;
ob1.mysql alter system set partition_table_check_interval = "1m";
ob1.mysql alter system set server_permanent_offline_time = "20s";

# 创建新租户
let $cpu = 1;
let $memory = 1073741824;
let $min_memory = 1073741824;
let $disk = 536870912;
let $iops = 100000;
let $session = 64;
ob1.mysql CREATE RESOURCE UNIT unit_1 MAX_CPU $cpu, MAX_MEMORY $memory, MAX_IOPS $iops, MAX_DISK_SIZE $disk, MAX_SESSION_NUM $session, MIN_CPU=1, MIN_MEMORY=$min_memory, MIN_IOPS=128;
ob1.mysql CREATE RESOURCE POOL pool_1 UNIT = 'unit_1', UNIT_NUM = 2, ZONE_LIST = ('z1','z2','z3','z4','z5');

let $z1_obs0_ip = deploy_get_value(ob1.z1.obs0.ip);
let $z1_obs0_mysql_port = deploy_get_value(ob1.z1.obs0.mysql_port);
connect (conn_sys_z1,$z1_obs0_ip,admin@sys,admin,oceanbase,$z1_obs0_mysql_port);
let $z3_obs0_ip = deploy_get_value(ob1.z3.obs0.ip);
let $z3_obs0_mysql_port = deploy_get_value(ob1.z3.obs0.mysql_port);
connect (conn_sys_z3,$z3_obs0_ip,admin@sys,admin,oceanbase,$z3_obs0_mysql_port);

#######################################
# case 4: 宕机情况
#######################################
## case 4.1: non-primary_region F 宕机
#######################################
--echo 4.1: non-primary_region F down
## 初始化租户
ob1.mysql CREATE TENANT tenant_3 RESOURCE_POOL_LIST = ('pool_1'), primary_zone = 'z3;z4;z1,z2;z5',locality='F{1}@z1,F{1}@z2,F{1}@z3,F{1}@z4,F{1}@z5' set ob_tcp_invited_nodes='%';
connect (conn_tenant_3_z1,$z1_obs0_ip,root@tenant_3,,test,$z1_obs0_mysql_port);
connection conn_tenant_3_z1;
use test;
create table t1(c1 int, c2 int) partition by hash(c1) partitions 2;
insert into t1(c1, c2) values(1,1);
insert into t1(c1, c2) values(2,2);
--disable_result_log
select * from test.t1 where c1 = 1;
select * from test.t1 where c1 = 2;
--enable_result_log
let $tenant_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name = "tenant_3", tenant_id, 1);
let $t1_id = deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where tenant_id = "$tenant_id" and table_name = "t1", table_id, 1);
let $f_replica_addr = deploy_get_value(ob1.select select concat(svr_ip, ":", svr_port) as addr from oceanbase.__all_virtual_meta_table where tenant_id = "$tenant_id" and table_id = "$t1_id" and zone = "z2" and replica_type = 0, addr, 1);
let $f_addr = deploy_get_value(ob1.select select concat(svr_ip, ":", sql_port) as addr from oceanbase.__all_virtual_meta_table where tenant_id = "$tenant_id" and table_id = "$t1_id" and zone = "z2" and replica_type = 0, addr, 1);
let $f_z2_obs = deploy_get_value(ob1.get_obs_by_addr $f_replica_addr);

let $f_replica_z5_addr = deploy_get_value(ob1.select select concat(svr_ip, ":", svr_port) as addr from oceanbase.__all_virtual_meta_table where tenant_id = "$tenant_id" and table_id = "$t1_id" and zone = "z5" and replica_type = 0, addr, 1);
let $r_z5_addr = deploy_get_value(ob1.select select concat(svr_ip, ":", inner_port) as addr from oceanbase.__all_server where zone = 'z5' and concat(svr_ip, ":", svr_port) != "$f_replica_z5_addr", addr, 1);
## 变更前检查
connection conn_sys_z1;
eval select count(*) as z1_f_count from oceanbase.__all_virtual_proxy_schema where tenant_name = "tenant_3" and database_name = "test" and table_name = "t1" and partition_id = 0 and spare1 = 0 and concat(svr_ip, ":", sql_port) = "$f_addr";
eval select count(*) as z5_r_count from oceanbase.__all_virtual_proxy_schema where tenant_name = "tenant_3" and database_name = "test" and table_name = "t1" and partition_id = 0 and spare1 = 16 and concat(svr_ip, ":", sql_port) = "$r_z5_addr";
connection conn_sys_z3;
eval select count(*) as z1_f_count from oceanbase.__all_virtual_proxy_schema where tenant_name = "tenant_3" and database_name = "test" and table_name = "t1" and partition_id = 0 and spare1 = 0 and concat(svr_ip, ":", sql_port) = "$f_addr";
eval select count(*) as z5_r_count from oceanbase.__all_virtual_proxy_schema where tenant_name = "tenant_3" and database_name = "test" and table_name = "t1" and partition_id = 0 and spare1 = 16 and concat(svr_ip, ":", sql_port) = "$r_z5_addr";
## 添加z5只读副本,z1,z3无感知
ob1.mysql alter tenant tenant_3 set locality = 'F{1}@z1,F{1}@z2,F{1}@z3,F{1}@z4,F{1},R{1}@z5';
let $last_job_id = deploy_get_value(ob1.select select max(job_id) as job_id from oceanbase.__all_rootservice_job where job_type = "ALTER_TENANT_LOCALITY" group by job_type, job_id, 1);
ob1.check_until_timeout select count(*) as c from oceanbase.__all_rootservice_job where job_id = "$last_job_id" and job_type = "ALTER_TENANT_LOCALITY" and job_status = "SUCCESS", 1, 120;
### 变更后检查
#connection conn_sys_z1;
#eval select count(*) as z1_f_count from oceanbase.__all_virtual_proxy_schema where tenant_name = "tenant_3" and database_name = "test" and table_name = "t1" and partition_id = 0 and spare1 = 0 and concat(svr_ip, ":", sql_port) = "$f_addr";
#eval select count(*) as z5_r_count from oceanbase.__all_virtual_proxy_schema where tenant_name = "tenant_3" and database_name = "test" and table_name = "t1" and partition_id = 0 and spare1 = 16 and concat(svr_ip, ":", sql_port) = "$r_z5_addr";
#connection conn_sys_z3;
#eval select count(*) as z1_f_count from oceanbase.__all_virtual_proxy_schema where tenant_name = "tenant_3" and database_name = "test" and table_name = "t1" and partition_id = 0 and spare1 = 0 and concat(svr_ip, ":", sql_port) = "$f_addr";
#eval select count(*) as z5_r_count from oceanbase.__all_virtual_proxy_schema where tenant_name = "tenant_3" and database_name = "test" and table_name = "t1" and partition_id = 0 and spare1 = 16 and concat(svr_ip, ":", sql_port) = "$r_z5_addr";
## z2 F副本所在机器宕机
$f_z2_obs.force_stop;
## 变更后检查, 由于F所在机器宕机，z1进行rpc刷新失败，走sql刷新，由于此时宕机的F仍在成员列表中(尚未永久下线)，故z1仍能看到宕机的F,且能看见z5的变化；z3看不到所有的变化
connection conn_sys_z1;
eval select count(*) as z1_f_count from oceanbase.__all_virtual_proxy_schema where tenant_name = "tenant_3" and database_name = "test" and table_name = "t1" and partition_id = 0 and spare1 = 0 and concat(svr_ip, ":", sql_port) = "$f_addr";
eval select count(*) as z5_r_count from oceanbase.__all_virtual_proxy_schema where tenant_name = "tenant_3" and database_name = "test" and table_name = "t1" and partition_id = 0 and spare1 = 16 and concat(svr_ip, ":", sql_port) = "$r_z5_addr";
connection conn_sys_z3;
eval select count(*) as z1_f_count from oceanbase.__all_virtual_proxy_schema where tenant_name = "tenant_3" and database_name = "test" and table_name = "t1" and partition_id = 0 and spare1 = 0 and concat(svr_ip, ":", sql_port) = "$f_addr";
eval select count(*) as z5_r_count from oceanbase.__all_virtual_proxy_schema where tenant_name = "tenant_3" and database_name = "test" and table_name = "t1" and partition_id = 0 and spare1 = 16 and concat(svr_ip, ":", sql_port) = "$r_z5_addr";
## 过了一段时间后，server宕机的情况被z1,z3感知到，走sql刷新，且由于永久下线，宕机的F从成员列表中移除，故z1,z3都能感知到F宕机及z5的变化
sleep 30;
--echo after a while
connection conn_sys_z1;
eval select count(*) as z1_f_count from oceanbase.__all_virtual_proxy_schema where tenant_name = "tenant_3" and database_name = "test" and table_name = "t1" and partition_id = 0 and spare1 = 0 and concat(svr_ip, ":", sql_port) = "$f_addr";
eval select count(*) as z5_r_count from oceanbase.__all_virtual_proxy_schema where tenant_name = "tenant_3" and database_name = "test" and table_name = "t1" and partition_id = 0 and spare1 = 16 and concat(svr_ip, ":", sql_port) = "$r_z5_addr";
connection conn_sys_z3;
eval select count(*) as z1_f_count from oceanbase.__all_virtual_proxy_schema where tenant_name = "tenant_3" and database_name = "test" and table_name = "t1" and partition_id = 0 and spare1 = 0 and concat(svr_ip, ":", sql_port) = "$f_addr";
eval select count(*) as z5_r_count from oceanbase.__all_virtual_proxy_schema where tenant_name = "tenant_3" and database_name = "test" and table_name = "t1" and partition_id = 0 and spare1 = 16 and concat(svr_ip, ":", sql_port) = "$r_z5_addr";

ob1.mysql drop tenant tenant_3 force;
$f_z2_obs.start;
ob1.check_until_timeout select count(*) from oceanbase.__all_server where zone = 'z2' and (start_service_time<=0 or status='inactive'),0,60;

######################################
# case 4.2: non-primary_region R 宕机
######################################
--echo 4.2: non-primary_region R down
## 初始化租户
ob1.mysql CREATE TENANT tenant_4 RESOURCE_POOL_LIST = ('pool_1'), primary_zone = 'z3;z4;z1,z2;z5',locality='F{1}@z1,R{1}@z2,F{1}@z3,F{1}@z4,F{1}@z5' set ob_tcp_invited_nodes='%';
connect (conn_tenant_4_z1,$z1_obs0_ip,root@tenant_4,,test,$z1_obs0_mysql_port);
connection conn_tenant_4_z1;
use test;
create table t1(c1 int, c2 int) partition by hash(c1) partitions 2;
insert into t1(c1, c2) values(1,1);
insert into t1(c1, c2) values(2,2);
--disable_result_log
select * from test.t1 where c1 = 1;
select * from test.t1 where c1 = 2;
--enable_result_log
let $tenant_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name = "tenant_4", tenant_id, 1);
let $t1_id = deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where tenant_id = "$tenant_id" and table_name = "t1", table_id, 1);

let $r_replica_addr = deploy_get_value(ob1.select select concat(svr_ip, ":", svr_port) as addr from oceanbase.__all_virtual_meta_table where tenant_id = "$tenant_id" and table_id = "$t1_id" and zone = "z2" and replica_type = 16, addr, 1);
let $r_addr = deploy_get_value(ob1.select select concat(svr_ip, ":", sql_port) as addr from oceanbase.__all_virtual_meta_table where tenant_id = "$tenant_id" and table_id = "$t1_id" and zone = "z2" and replica_type = 16, addr, 1);
let $r_z2_obs = deploy_get_value(ob1.get_obs_by_addr $r_replica_addr);

let $f_replica_z5_addr = deploy_get_value(ob1.select select concat(svr_ip, ":", svr_port) as addr from oceanbase.__all_virtual_meta_table where tenant_id = "$tenant_id" and table_id = "$t1_id" and zone = "z5" and replica_type = 0, addr, 1);
let $r_z5_addr = deploy_get_value(ob1.select select concat(svr_ip, ":", inner_port) as addr from oceanbase.__all_server where zone = 'z5' and concat(svr_ip, ":", svr_port) != "$f_replica_z5_addr", addr, 1);
## 变更前检查
connection conn_sys_z1;
eval select count(*) as z1_r_count from oceanbase.__all_virtual_proxy_schema where tenant_name = "tenant_4" and database_name = "test" and table_name = "t1" and partition_id = 0 and spare1 = 16 and concat(svr_ip, ":", sql_port) = "$r_addr";
eval select count(*) as z5_r_count from oceanbase.__all_virtual_proxy_schema where tenant_name = "tenant_4" and database_name = "test" and table_name = "t1" and partition_id = 0 and spare1 = 16 and concat(svr_ip, ":", sql_port) = "$r_z5_addr";
connection conn_sys_z3;
eval select count(*) as z1_r_count from oceanbase.__all_virtual_proxy_schema where tenant_name = "tenant_4" and database_name = "test" and table_name = "t1" and partition_id = 0 and spare1 = 16 and concat(svr_ip, ":", sql_port) = "$r_addr";
eval select count(*) as z5_r_count from oceanbase.__all_virtual_proxy_schema where tenant_name = "tenant_4" and database_name = "test" and table_name = "t1" and partition_id = 0 and spare1 = 16 and concat(svr_ip, ":", sql_port) = "$r_z5_addr";
## 添加z5只读副本,z1,z3无感知
ob1.mysql alter tenant tenant_4 set locality = 'F{1}@z1,R{1}@z2,F{1}@z3,F{1}@z4,F{1},R{1}@z5';
let $last_job_id = deploy_get_value(ob1.select select max(job_id) as job_id from oceanbase.__all_rootservice_job where job_type = "ALTER_TENANT_LOCALITY" group by job_type, job_id, 1);
ob1.check_until_timeout select count(*) as c from oceanbase.__all_rootservice_job where job_id = "$last_job_id" and job_type = "ALTER_TENANT_LOCALITY" and job_status = "SUCCESS", 1, 120;
### 变更后检查
#connection conn_sys_z1;
#eval select count(*) as z1_r_count from oceanbase.__all_virtual_proxy_schema where tenant_name = "tenant_4" and database_name = "test" and table_name = "t1" and partition_id = 0 and spare1 = 16 and concat(svr_ip, ":", sql_port) = "$r_addr";
#eval select count(*) as z5_r_count from oceanbase.__all_virtual_proxy_schema where tenant_name = "tenant_4" and database_name = "test" and table_name = "t1" and partition_id = 0 and spare1 = 16 and concat(svr_ip, ":", sql_port) = "$r_z5_addr";
#connection conn_sys_z3;
#eval select count(*) as z1_r_count from oceanbase.__all_virtual_proxy_schema where tenant_name = "tenant_4" and database_name = "test" and table_name = "t1" and partition_id = 0 and spare1 = 16 and concat(svr_ip, ":", sql_port) = "$r_addr";
#eval select count(*) as z5_r_count from oceanbase.__all_virtual_proxy_schema where tenant_name = "tenant_4" and database_name = "test" and table_name = "t1" and partition_id = 0 and spare1 = 16 and concat(svr_ip, ":", sql_port) = "$r_z5_addr";
## z2 R所在机器宕机
$r_z2_obs.force_stop;
## 变更后检查, R所在机器宕机，但由于下游列表更新需要时间，z1进行rpc刷新能成功,故感知不到的宕机及z5变化；z3由于与z1,z5不在一个region，走rpc刷新也能成功
connection conn_sys_z1;
eval select count(*) as z1_r_count from oceanbase.__all_virtual_proxy_schema where tenant_name = "tenant_4" and database_name = "test" and table_name = "t1" and partition_id = 0 and spare1 = 16 and concat(svr_ip, ":", sql_port) = "$r_addr";
eval select count(*) as z5_r_count from oceanbase.__all_virtual_proxy_schema where tenant_name = "tenant_4" and database_name = "test" and table_name = "t1" and partition_id = 0 and spare1 = 16 and concat(svr_ip, ":", sql_port) = "$r_z5_addr";
connection conn_sys_z3;
eval select count(*) as z1_r_count from oceanbase.__all_virtual_proxy_schema where tenant_name = "tenant_4" and database_name = "test" and table_name = "t1" and partition_id = 0 and spare1 = 16 and concat(svr_ip, ":", sql_port) = "$r_addr";
eval select count(*) as z5_r_count from oceanbase.__all_virtual_proxy_schema where tenant_name = "tenant_4" and database_name = "test" and table_name = "t1" and partition_id = 0 and spare1 = 16 and concat(svr_ip, ":", sql_port) = "$r_z5_addr";
## 过了一段时间后，下游列表更新，z1进行rpc刷新发现下游发生变化，而走sql刷新,此时宕机的R没到回收时间，故此时z1能看到宕机的R及z5的变化
## z3的rpc刷新一直是成功的，故感知不到其他region的变化
sleep 31;
--echo after a while
connection conn_sys_z1;
eval select count(*) as z1_r_count from oceanbase.__all_virtual_proxy_schema where tenant_name = "tenant_4" and database_name = "test" and table_name = "t1" and partition_id = 0 and spare1 = 16 and concat(svr_ip, ":", sql_port) = "$r_addr";
eval select count(*) as z5_r_count from oceanbase.__all_virtual_proxy_schema where tenant_name = "tenant_4" and database_name = "test" and table_name = "t1" and partition_id = 0 and spare1 = 16 and concat(svr_ip, ":", sql_port) = "$r_z5_addr";
connection conn_sys_z3;
eval select count(*) as z1_r_count from oceanbase.__all_virtual_proxy_schema where tenant_name = "tenant_4" and database_name = "test" and table_name = "t1" and partition_id = 0 and spare1 = 16 and concat(svr_ip, ":", sql_port) = "$r_addr";
eval select count(*) as z5_r_count from oceanbase.__all_virtual_proxy_schema where tenant_name = "tenant_4" and database_name = "test" and table_name = "t1" and partition_id = 0 and spare1 = 16 and concat(svr_ip, ":", sql_port) = "$r_z5_addr";
