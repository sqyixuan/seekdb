eval select count(*) as z1_f_count from oceanbase.__all_virtual_proxy_schema where tenant_name = "tenant_2" and database_name = "test" and table_name = "t1" and partition_id = 0 and spare1 = 0 and concat(svr_ip, ":", sql_port) in ("$f_z1_addr", "$f_z1_addr_1");
eval select count(*) as z1_r_count from oceanbase.__all_virtual_proxy_schema where tenant_name = "tenant_2" and database_name = "test" and table_name = "t1" and partition_id = 0 and spare1 = 16 and concat(svr_ip, ":", sql_port) in ("$f_z1_addr", "$f_z1_addr_1");
eval select count(*) as z5_r_count from oceanbase.__all_virtual_proxy_schema where tenant_name = "tenant_2" and database_name = "test" and table_name = "t1" and partition_id = 0 and spare1 = 16 and concat(svr_ip, ":", sql_port) = "$r_z5_addr";
connection conn_sys_z3;
eval select count(*) as z1_f_count from oceanbase.__all_virtual_proxy_schema where tenant_name = "tenant_2" and database_name = "test" and table_name = "t1" and partition_id = 0 and spare1 = 0 and concat(svr_ip, ":", sql_port) in ("$f_z1_addr", "$f_z1_addr_1");
eval select count(*) as z1_r_count from oceanbase.__all_virtual_proxy_schema where tenant_name = "tenant_2" and database_name = "test" and table_name = "t1" and partition_id = 0 and spare1 = 16 and concat(svr_ip, ":", sql_port) in ("$f_z1_addr", "$f_z1_addr_1");
eval select count(*) as z5_r_count from oceanbase.__all_virtual_proxy_schema where tenant_name = "tenant_2" and database_name = "test" and table_name = "t1" and partition_id = 0 and spare1 = 16 and concat(svr_ip, ":", sql_port) = "$r_z5_addr";
## z5加只读副本，z1,z3无感知
ob1.mysql alter tenant tenant_2 set locality = 'F{1}@z1,F{1},R{1}@z2,F{1},R{1}@z3,F{1},R{1}@z4,F{1},R{1}@z5';
let $last_job_id = deploy_get_value(ob1.select select max(job_id) as job_id from oceanbase.__all_rootservice_job where job_type = "ALTER_TENANT_LOCALITY" group by job_type, job_id, 1);
ob1.check_until_timeout select count(*) as c from oceanbase.__all_rootservice_job where job_id = "$last_job_id" and job_type = "ALTER_TENANT_LOCALITY" and job_status = "SUCCESS", 1, 120;
