# owner:yixin.lyx
# owner group:transaction
# description:
# 测试点：测试leader takeover的时候触发数据搬迁，去把未确定版本号的事务搬迁到active memstore
##
ob1=OBI(cluster=1:1,proxy_num=0,init_unit_cpu=5);
ob1.reboot;
sleep 10;

ob1.mysql alter system set enable_auto_leader_switch = false;

#在zone1上建立连接
let $l_ip=deploy_get_value(ob1.z1.obs0.ip);
let $l_port=deploy_get_value(ob1.z1.obs0.mysql_port);
connect (conn1,$l_ip,root@obtest,,test,$l_port);
connect (conn2,$l_ip,root@sys,,oceanbase,$l_port);

#在zone2上建立连接
let $l_ip2=deploy_get_value(ob1.z2.obs0.ip);
let $l_port2=deploy_get_value(ob1.z2.obs0.mysql_port);
connect (conn3,$l_ip2,root@obtest,,test,$l_port2);
connect (conn4,$l_ip2,root@sys,,oceanbase,$l_port2);

connection conn1;
use test;
set @@session.autocommit=off;
set @@session.ob_query_timeout=1000000000;
set @@session.ob_trx_timeout=1000000000;

create table t1(id1 int primary key, id2 int);
create table t2(id1 int primary key, id2 int);
sleep 5;

connection conn2;
ob1.z1.obs0.switch_partition obtest:test:t1;
sleep 5;

connection conn1;
insert into t1 values (1, 1);
insert into t2 values (1, 1);
select * from t1;
select * from t2;

###case 1 : 测试单分区事务AB切主
begin;
insert into t1 values (2, 2);
insert into t1 values (3, 3);

### 切主
connection conn2;
ob1.z2.obs0.switch_partition obtest:test:t1;
sleep 5;

connection conn4;
alter system minor freeze tenant = sys;
alter system minor freeze tenant = all_user;
alter system minor freeze tenant = all_meta;
sleep 5;

connection conn1;
insert into t1 values (4, 4);
commit;

select * from t1;

### 做major freeze看能不能合并成功
connection conn2;
alter system major freeze;
ob1.check_until_timeout select value from __all_zone where zone='' and name='last_merged_version', 2,3600;

connection conn2;
ob1.z1.obs0.switch_partition obtest:test:t1;
sleep 5;

###case 2 : 测试单分区事务ABA切主
connection conn1;
begin;
insert into t1 values (5, 5);
insert into t1 values (6, 6);

### 切主
connection conn2;
ob1.z2.obs0.switch_partition obtest:test:t1;
sleep 5;

connection conn4;
alter system minor freeze tenant = sys;
alter system minor freeze tenant = all_user;
alter system minor freeze tenant = all_meta;
sleep 5;

connection conn2;
ob1.z1.obs0.switch_partition obtest:test:t1;
sleep 5;

connection conn1;
rollback;

select * from t1;

### 做major freeze看能不能合并成功
connection conn2;
alter system major freeze;
ob1.check_until_timeout select value from __all_zone where zone='' and name='last_merged_version', 3,3600;

###case 3 : 测试分布式事务AB切主
connection conn1;
begin;
insert into t1 values (7, 7);
insert into t1 values (8, 8);
insert into t2 values (5, 5);
insert into t2 values (6, 6);

### 切主
connection conn2;
ob1.z2.obs0.switch_partition obtest:test:t1;
sleep 5;

connection conn4;
alter system minor freeze tenant = sys;
alter system minor freeze tenant = all_user;
alter system minor freeze tenant = all_meta;
sleep 5;

connection conn1;
insert into t1 values (9, 9);
commit;

select * from t1;
select * from t2;

### 做major freeze看能不能合并成功
connection conn2;
alter system major freeze;
ob1.check_until_timeout select value from __all_zone where zone='' and name='last_merged_version', 4,3600;

###case 4 : 测试分布式事务ABA切主
connection conn1;
begin;
insert into t1 values (10, 10);
insert into t1 values (11, 11);
insert into t2 values (7, 7);
insert into t2 values (8, 8);

### 切主
connection conn2;
ob1.z2.obs0.switch_partition obtest:test:t1;
sleep 5;

connection conn4;
alter system minor freeze tenant = sys;
alter system minor freeze tenant = all_user;
alter system minor freeze tenant = all_meta;
sleep 5;

connection conn2;
ob1.z1.obs0.switch_partition obtest:test:t1;
sleep 5;

connection conn1;
rollback;

select * from t1;
select * from t2;

### 做major freeze看能不能合并成功
connection conn2;
alter system major freeze;
ob1.check_until_timeout select value from __all_zone where zone='' and name='last_merged_version', 5,3600;

ob1.z1.obs0.count_log 'relocate transaction success when leader takeover without version';
ob1.z2.obs0.count_log 'relocate transaction success when leader takeover without version';
