#owner: handora.qc
#owner group: transaction
# 测试点：测试宕机后checksum正确
--disable_query_log
ob1=OBI(cluster=1:1,proxy_num=0,init_unit_cpu=5);

ob1.reboot;
sleep 5;

ob1.mysql alter system set enable_auto_leader_switch=false;

let $ip1=deploy_get_value(ob1.z1.obs0.ip);
let $sql_port1=deploy_get_value(ob1.z1.obs0.mysql_port);
let $port1=deploy_get_value(ob1.z1.obs0.port);
let $ip2=deploy_get_value(ob1.z2.obs0.ip);
let $sql_port2=deploy_get_value(ob1.z2.obs0.mysql_port);
let $port2=deploy_get_value(ob1.z2.obs0.port);

connect (conn1,$ip1,root@obtest,,test,$sql_port1);
connect (conn2,$ip1,root@obtest,,test,$sql_port1);
connect (conn_sys,$ip1,root@sys,,oceanbase,$sql_port1);

connection conn1;
create table a (x int);

# ================= 测试单机事务1 =======================
ob1.z1.obs0.switch_partition obtest:test:a:0;
sleep 5;
ob1.z1.obs0.check_leader obtest:test:a:0;

ob1.mysql alter system set_tp tp_no = 212, error_code = 4030, frequency = 1;

connection conn1;
begin;
insert into a value (1);

connection conn_sys;
# 将数据转储到备机
ob1.mysql alter system minor freeze tenant = sys;
ob1.mysql alter system minor freeze tenant = all_user;
ob1.mysql alter system minor freeze tenant = all_meta;
sleep 5;

connection conn1;
commit;

insert into a value (1);
insert into a value (2);
insert into a value (3);

connection conn_sys;
# 将数据转储到备机
ob1.mysql alter system minor freeze tenant = sys;
ob1.mysql alter system minor freeze tenant = all_user;
ob1.mysql alter system minor freeze tenant = all_meta;
sleep 5;

sleep 60;

ob1.z1.obs0.force_stop;
sleep 10;

ob1.z1.start;
sleep 60;

ob1.check_until_timeout select count(1) cnt from oceanbase.__all_server where status='active' and start_service_time>0,2,240;
