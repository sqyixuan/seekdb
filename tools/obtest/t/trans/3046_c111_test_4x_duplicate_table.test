ob1.mysql alter system switch replica leader ls = $t2_ls_id server = '$ip2:$port2' tenant = 'tt1';
## ob1.z2.obs0.check_leader tt1:test:t2;
ob1.check_until_timeout select count(*) from __all_virtual_ls_info where ls_id = $t2_ls_id and SVR_IP = '$ip2' and SVR_PORT = '$port2' and tenant_id = $tenant_id and ls_state = 'leader' , 1, 30;
## explain select * from t2, t2_dup where t2.x = t2_dup.x;

### 清理环境
--disable_warnings
drop table if exists t1;
drop table if exists t2;
drop table if exists t1_dup;
drop table if exists t2_dup;
--enable_warnings