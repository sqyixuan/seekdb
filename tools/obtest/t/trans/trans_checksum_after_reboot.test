#owner: handora.qc
#owner group: transaction
# 测试点：测试宕机后checksum正确
--disable_query_log
ob1=OBI(cluster=1:1,proxy_num=0,init_unit_cpu=5);

ob1.reboot;
sleep 5;

ob1.mysql alter system set enable_auto_leader_switch=false;

let $ip1=deploy_get_value(ob1.z1.obs0.ip);
let $sql_port1=deploy_get_value(ob1.z1.obs0.mysql_port);
let $port1=deploy_get_value(ob1.z1.obs0.port);
let $ip2=deploy_get_value(ob1.z2.obs0.ip);
let $sql_port2=deploy_get_value(ob1.z2.obs0.mysql_port);
let $port2=deploy_get_value(ob1.z2.obs0.port);

connect (conn1,$ip1,root@obtest,,test,$sql_port1);
connect (conn2,$ip1,root@obtest,,test,$sql_port1);
connect (conn_sys,$ip1,root@sys,,oceanbase,$sql_port1);

# ================= 测试单机事务 =======================
connection conn1;
create table a (x int);
insert into a value (1);

begin;
insert into a value (1);
insert into a value (2);
insert into a value (3);

connection conn_sys;
# 将数据转储到备机
ob1.mysql alter system minor freeze tenant obtest server = ('$ip1:$port1');
sleep 5;

connection conn2;
insert into a value (21);
insert into a value (22);

connection conn_sys;
# 将备机转储
ob1.mysql alter system minor freeze tenant obtest server = ('$ip2:$port2');
sleep 5;

sleep 60;

connection conn1;
insert into a value (11);
insert into a value (12);
insert into a value (13);
commit;

sleep 3;

# 模拟宕机
ob1.z2.obs0.force_stop;
sleep 10;

# 重启z2
ob1.z2.start;
sleep 100;

# ======================= 测试多机事务 ======================
create table b (x int, y int) partition by hash(y % 2) partitions 2;

# 切主以满足分布式事务
ob1.z1.obs0.switch_partition obtest:test:b:0;
ob1.z2.obs0.switch_partition obtest:test:b:1;
sleep 5;
ob1.z1.obs0.check_leader obtest:test:b:0;
ob1.z2.obs0.check_leader obtest:test:b:1;

insert into b value (1, 0);
insert into b value (1, 1);

begin;
insert into b value (1, 0);
insert into b value (2, 1);
insert into b value (3, 2);

connection conn_sys;
# 将数据转储到备机
ob1.mysql alter system minor freeze tenant obtest server = ('$ip1:$port1');
sleep 5;

connection conn2;
insert into b value (21, 0);
insert into b value (22, 1);

connection conn_sys;
# 将备机转储
ob1.mysql alter system minor freeze tenant obtest server = ('$ip2:$port2');
sleep 5;

sleep 60;

connection conn1;
insert into b value (11, 0);
insert into b value (12, 1);
insert into b value (13, 2);
commit;

sleep 3;

# 模拟宕机
ob1.z2.obs0.force_stop;
sleep 10;

# 重启z2
ob1.z2.start;
sleep 40;
