#owner: xiaoshi.xjl
#owner group: transaction
# 测试点：测试enable_smooth_leader_switch关闭之后事务的执行
##
ob1=OBI(cluster=1:1:1,proxy_num=0,init_unit_cpu=5);
ob1.reboot;
sleep 5;

let $l_ip=deploy_get_value(ob1.z1.obs0.ip);
let $l_port=deploy_get_value(ob1.z1.obs0.mysql_port);
connect (conn1,$l_ip,root@obtest,,test,$l_port);
connect (conn2,$l_ip,root@sys,,oceanbase,$l_port);

connection conn1;
set ob_query_timeout=90000000;
set ob_trx_timeout=1200000000;

create database obtest;
use obtest;
## case:检查表结构
create table t1(id1 int, id2 int) primary_zone='z1';
create table t2(id1 int, id2 int) primary_zone='z1';

sleep 5;
desc t1;
desc t2;

connection conn2;
ob1.mysql alter system set enable_auto_leader_switch=false;
ob1.mysql alter system set enable_smooth_leader_switch=false;
sleep 5;

connection conn1;
#case:测试enable_smooth_leader_switch关闭之后事务的执行
let $i=0;
start transaction;
while($i < 5)
{
  eval insert into t1 values(100 + $i, 1000 + $i);
  eval insert into t2 values(200 + $i, 2000 + $i);
  inc $i;
}

connection conn2;
ob1.z2.obs0.switch_partition obtest:obtest:t1;
sleep 5;

connection conn1;
while($i < 6)
{
--error 6002
  eval insert into t1 values(100 + $i, 1000 + $i);
  eval insert into t2 values(200 + $i, 2000 + $i);
  inc $i;
}

--error 6002
commit;

select * from t1;
select * from t2;

connection conn2;
ob1.mysql alter system major freeze;
ob1.check_until_timeout select value from __all_zone where zone='' and name='last_merged_version', 2,3600;

connection conn1;
select * from t1;
select * from t2;

drop table t1;
drop table t2;
