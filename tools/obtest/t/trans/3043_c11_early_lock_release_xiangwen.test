#
#owner: shanyan.g 
#owner group: transaction
# 测试点：单分区事务切换为分布式事务
##
ob1=OBI(cluster=1:1,proxy_num=0,init_unit_cpu=5);
ob1.reboot;
sleep 5;

ob1.mysql alter system set enable_auto_leader_switch=false;
#在zone1上建立连接
let $l_ip=deploy_get_value(ob1.z1.obs0.ip);
let $l_port=deploy_get_value(ob1.z1.obs0.mysql_port);
connect (conn1,$l_ip,root@obtest,,test,$l_port);

connection conn1;
## case:检查表结构
set ob_query_timeout = 100000000;
set ob_trx_timeout = 100000000;
create table elr_trans_test(a int, b int);
desc elr_trans_test;
insert into elr_trans_test values(1, 1);
sleep 5;
set global ob_early_lock_release = 1;
disconnect conn1;

ob1.mysql alter system set_tp tp_no = 114, error_code = 4012, frequency = 1;

connect (conn1,$l_ip,root@obtest,,test,$l_port);
connect (conn2,$l_ip,root@obtest,,test,$l_port);
connect (conn3,$l_ip,root@sys,,oceanbase,$l_port);

connection conn1;
rollback;
set autocommit = 0;
update elr_trans_test set b = b + 10 where a = 1;
send commit;

connection conn2;
show variables like 'ob_early_lock_release';
rollback;
set autocommit = 0;
sleep 1;
update elr_trans_test set b = b - 7 where a = 1;
select * from elr_trans_test;

connection conn3;
# 检查前驱
select count(1) from oceanbase.__all_virtual_trans_stat where prev_trans_count > 0;

ob1.mysql alter system set_tp tp_no = 114, error_code = 4012, frequency = 0;

connection conn2;
commit;

connection conn1;
reap;
select * from elr_trans_test;

ob1.z1.obs0.count_log 'elr trans success';

drop table elr_trans_test;
