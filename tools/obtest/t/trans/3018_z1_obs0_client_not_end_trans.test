# owner: shanyan.g
# owner group: transaction
# description: 主要测试单partition事务，如果客户端没有commit/rollback，合并是否能够继续 

--disable_query_log
ob1=OBI(cluster=1:1:1, proxy_num=0, init_unit_cpu=5);
ob1.reboot;

#设置灰度切主的时间为0，关闭自动切主，关闭自动balance
ob1.mysql alter system set resource_hard_limit = 800;
ob1.mysql alter system set merger_switch_leader_duration_time=0;
ob1.mysql alter system set enable_auto_leader_switch = false;
ob1.mysql alter system set enable_rereplication = false;
ob1.mysql alter system set enable_rebalance = false;

let $ip=deploy_get_value(ob1.z1.obs0.ip);
let $port=deploy_get_value(ob1.z1.obs0.mysql_port);
connect (conn1,$ip,root@obtest,,test,$port);
connect (conn2,$ip,root@obtest,,test,$port);

#插入数据
connection conn1;
set ob_trx_timeout=30000000;
create table test01 (c1 int primary key, c2 int, c3 int) primary_zone='z1';
set autocommit=0;
insert into test01 values(1, 1, 1);

connection conn2;
#发起合并,尽管上一个事务客户端尚未提交，但合并应该能够执行下去；
ob1.mysql alter system major freeze;
#check merge是否成功，同步操作
ob1.check_until_timeout select value from __all_zone where zone='' and name='last_merged_version', 2,3600;

#提交事务，预期事务commit返回被kill
connection conn1;
--error 4012
commit;

#预期事务回滚，结果应该为空
select * from test01;

set autocommit=1;
insert into test01 values (2, 2, 2);
select * from test01;
