#owner: xiaoshi.xjl
#owner group: transaction
# 测试点：改选及数据搬迁
##
ob1=OBI(cluster=1:1:1,proxy_num=0,init_unit_cpu=5);
ob1.reboot;
sleep 5;

ob1.mysql alter system set enable_auto_leader_switch=false;

let $l_ip=deploy_get_value(ob1.z1.obs0.ip);
let $l_port=deploy_get_value(ob1.z1.obs0.mysql_port);
connect (conn1,$l_ip,root@obtest,,test,$l_port);
connect (conn2,$l_ip,root@sys,,oceanbase,$l_port);

connection conn1;
set ob_query_timeout=90000000;
set ob_trx_timeout=1200000000;

create database obtest;
use obtest;
## case:检查表结构
create table t1(id1 int, id2 int) primary_zone='z1';
create table t2(id1 int, id2 int) primary_zone='z2';

sleep 5;
desc t1;
desc t2;

#case:测试事务切主之后发生数据搬迁
let $i=0;
start transaction;
while($i < 100)
{
  eval insert into t1 values(100 + $i, 1000 + $i);
  eval insert into t2 values(200 + $i, 2000 + $i);
  inc $i;
}
commit;

select * from t1;
select * from t2;

start transaction;

let $i=0;
while($i < 100)
{
  eval delete from t1 where id1 = 100 + $i;
  eval delete from t2 where id1 = 1000 + $i;
  inc $i;
}

let $i=0;
while($i < 40)
{
  eval insert into t1 values(100 + $i, 1000 + $i);
  eval insert into t2 values(200 + $i, 2000 + $i);
  inc $i;
}

connection conn2;
ob1.z2.obs0.switch_partition obtest:obtest:t1;
ob1.z1.obs0.switch_partition obtest:obtest:t2;
sleep 5;

connection conn1;
while($i < 60)
{
  eval insert into t1 values(100 + $i, 1000 + $i);
  eval insert into t2 values(200 + $i, 2000 + $i);
  inc $i;
}

connection conn2;
ob1.mysql alter system minor freeze tenant = sys;
ob1.mysql alter system minor freeze tenant = all_user;
ob1.mysql alter system minor freeze tenant = all_meta;
sleep 30;

connection conn1;
while($i < 100)
{
  eval insert into t1 values(100 + $i, 1000 + $i);
  eval insert into t2 values(200 + $i, 2000 + $i);
  inc $i;
}

let $i=0;
while($i < 100)
{
  eval update t1 set id2=id2 + 100 where id1=100 + $i;
  eval update t2 set id2=id2 + 1000 where id1=200 + $i;
  inc $i;
}

commit;

connection conn2;
ob1.mysql alter system major freeze;
ob1.check_until_timeout select value from __all_zone where zone='' and name='last_merged_version', 2,3600;

connection conn1;
select * from t1;
select * from t2;

drop table t1;
drop table t2;
