#ob1.check_until_timeout select count(*) c from __all_virtual_meta_table where table_id = $t_id and partition_id = 0 and  tenant_id = $tenant_id and concat(svr_ip,":",svr_port)='$dest_addr' and role = 1, 1, 30;


select * from test;
