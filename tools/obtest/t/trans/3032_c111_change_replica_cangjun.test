# owner: yanyuan.cxf
# owner group: TRANSACTION
#
# L to F, F to L, L to F
#

ob1=OBI(cluster=1:1:1, init_unit_cpu=0, proxy_num=0, ct_num = 0, locality=hz:hz:hz);
ob1.reboot;
let $case_index=1;

ob1.mysql alter system set resource_hard_limit=900;
ob1.mysql alter system set resource_soft_limit=800;
ob1.mysql alter system set debug_sync_timeout = '100s';
ob1.mysql alter system set enable_auto_leader_switch = 'False';
ob1.mysql alter system set balancer_idle_time = '10s';
ob1.mysql alter system set server_data_copy_out_concurrency = 20;
ob1.mysql alter system set server_data_copy_in_concurrency = 20;

let $cpu = 1;
let $memory = 1073741824;
let $min_memory = 1073741824;
let $disk = 536870912;
let $iops = 100000;
let $session = 64;

let $case_index=2;
ob1.mysql CREATE RESOURCE UNIT unit_$case_index MAX_CPU $cpu, MAX_MEMORY $memory, MAX_IOPS $iops, MAX_DISK_SIZE $disk, MAX_SESSION_NUM $session, MIN_CPU=1, MIN_MEMORY=$min_memory, MIN_IOPS=128;
ob1.mysql CREATE RESOURCE POOL pool_$case_index UNIT = 'unit_$case_index', UNIT_NUM = 1, ZONE_LIST = ('z1','z2','z3');
ob1.mysql CREATE TENANT tenant_$case_index RESOURCE_POOL_LIST = ('pool_$case_index'), locality='F@z1,F@z2,L@z3' set ob_tcp_invited_nodes='%';
let $tenant_id = deploy_get_value(ob1.select select tenant_id from __all_tenant where tenant_name = "tenant_2", tenant_id, 1);


ob_connect(sys_conn, ob1.z1.obs0, root,,test,USE_OB_CONNECTOR);
alter system set __balance_controller='{"ENABLE_MODIFY_QUORUM":"false"}';

ob_connect(tt_conn, ob1.z1.obs0, root@tenant_2,,test,USE_OB_CONNECTOR);
connection tt_conn;

sleep 10;

ob1.mysql alter system set enable_rebalance = 'false';
ob1.mysql alter system set enable_rereplication = 'false';

create table test(id int primary key, k int);

insert into test values(1,1);
insert into test values(2,2);
insert into test values(3,3);

ob1.mysql alter system major freeze;
ob1.check_until_timeout select value from __all_zone where zone='' and name='last_merged_version', 2,3600;

insert into test values(10,10);
insert into test values(11,11);

let $t_id = deploy_get_value(ob1.select select table_id from __all_virtual_table where table_name = "test" and tenant_id = "$tenant_id", table_id, 1);

let $dest_addr = deploy_get_value(ob1.select select concat(svr_ip,":", svr_port) addr from __all_virtual_meta_table where table_id = $t_id and partition_id = 0 and role = 2 and tenant_id = $tenant_id and replica_type=5 and zone='z3', addr, 1);

#ob1.mysql alter system change replica  partition_id='0%0@$t_id' server='$dest_addr' change replica_type='F';
#ob1.check_until_timeout select count(*) c from __all_virtual_meta_table where table_id = $t_id and partition_id = 0 and  tenant_id = $tenant_id and concat(svr_ip,":",svr_port)='$dest_addr' and replica_type=0, 1, 30;
#ob1.check_until_timeout select count(*) c from __all_virtual_meta_table where table_id = $t_id and partition_id = 0 and  tenant_id = $tenant_id and role = 1 and member_list like '%,%,%', 1, 30;

insert into test values(12,12);

