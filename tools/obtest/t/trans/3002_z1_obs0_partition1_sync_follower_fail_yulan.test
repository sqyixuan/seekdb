##
# owner:yulan.way
# owner group:transaction
# description:
# 测试点：单partition，分布式事务执行过程中有部分sql同步备机失败
# 测试场景：开启事务，执行SQL。阻塞主和备之间的网络，发起sql
##
ob1=OBI(cluster=2:2:2,proxy_num=0,init_unit_cpu=11,init_unit_num=1);
ob1.reboot;
sleep 5;

ob1.mysql alter system set enable_auto_leader_switch=false;

let $obs=deploy_get_value(ob1.z1.obs1.ip);
let $obs_port=deploy_get_value(ob1.z1.obs1.mysql_port);
connect (conn1,$obs,admin@obtest,admin,oceanbase,$obs_port);
connection conn1;

create database obtest;
use obtest;
create table t1(pk int primary key, c1 int, c2 varchar(20));

set autocommit=0;
insert into t1 values(1,1,'a');
insert into t1 values(2,2,'b');

let $leader=deploy_get_value(ob1.get_leader obtest:obtest:t1);
let $follower=deploy_get_value(ob1.get_follower obtest:obtest:t1);
$leader.block_net $follower;
$follower.block_net $leader;

update t1 set c2='aa' where pk=1;

commit;

$leader.clean_net $follower;
$follower.clean_net $leader;

set autocommit=1;
select * from t1;

