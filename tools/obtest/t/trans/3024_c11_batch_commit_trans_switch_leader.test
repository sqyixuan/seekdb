#
# owner:shanyan.g
# owner group:transaction
# description:
# 测试点：单机多分区事务执行过程中，各种情况下的切主操作
##
ob1=OBI(cluster=1:1,proxy_num=0,init_unit_cpu=5);
ob1.reboot;
sleep 5;

ob1.mysql alter system set enable_auto_leader_switch=false;
#在zone1上建立连接
let $l_ip=deploy_get_value(ob1.z1.obs0.ip);
let $l_port=deploy_get_value(ob1.z1.obs0.mysql_port);
connect (conn1,$l_ip,root@obtest,,test,$l_port);
connect (conn2,$l_ip,root@obtest,,test,$l_port);

connection conn1;
create table t1(id1 int, id2 int);
create table t2(id1 int, id2 int);

ob1.z1.obs0.switch_partition obtest:test:t1;
ob1.z1.obs0.switch_partition obtest:test:t2;
sleep 5;

####################################
#case 1 :正常执行
connection conn1;
set autocommit=0;
insert into t1 values(1,1);
insert into t2 values(2,2);
commit;
#校验数据
select * from t1;
select * from t2;

####################################
#case 2 : commit之前，其中一个参与者切主
connection conn1;
set autocommit=0;
insert into t1 values(1,1);
insert into t2 values(2,2);

connection conn2;
ob1.z2.obs0.switch_partition obtest:test:t1;
sleep 10;

connection conn1;
#预热下location cache，避免事务提交时出现未决得情况
select * from t1;
select * from t2;
commit;
#校验数据
select * from t1;
select * from t2;

####################################
#case 3 : commit之前，其中一个参与者切主，又切回
connection conn1;
set autocommit=0;
insert into t1 values(1,1);
insert into t2 values(2,2);

connection conn2;
ob1.z2.obs0.switch_partition obtest:test:t1;
sleep 10;
ob1.z1.obs0.switch_partition obtest:test:t1;
sleep 10;

connection conn1;
#预热下location cache，避免事务提交时出现未决得情况
select * from t1;
select * from t2;
commit;
#校验数据
select * from t1;
select * from t2;

####################################
#case 4 : commit之前，其中一个参与者切主，又切回，再执行语句
connection conn1;
set autocommit=0;
insert into t1 values(1,1);
insert into t2 values(2,2);

connection conn2;
ob1.z2.obs0.switch_partition obtest:test:t1;
sleep 10;
ob1.z1.obs0.switch_partition obtest:test:t1;
sleep 10;

connection conn1;
#预热下location cache，避免事务提交时出现未决得情况
select * from t1;
select * from t2;
insert into t1 values(3,3);
insert into t2 values(4,4);
commit;
#校验数据
select * from t1;
select * from t2;

####################################
#case 4 : commit之前，所有参与者切主
connection conn1;
set autocommit=0;
insert into t1 values(1,1);
insert into t2 values(2,2);

connection conn2;
ob1.z2.obs0.switch_partition obtest:test:t1;
ob1.z2.obs0.switch_partition obtest:test:t2;
sleep 10;

connection conn1;
#预热下location cache，避免事务提交时出现未决得情况
select * from t1;
select * from t2;
commit;
#校验数据
select * from t1;
select * from t2;

####################################
#case 5 : commit之前，所有参与者切主，又切回
connection conn1;
set autocommit=0;
insert into t1 values(1,1);
insert into t2 values(2,2);

connection conn2;
ob1.z2.obs0.switch_partition obtest:test:t1;
ob1.z2.obs0.switch_partition obtest:test:t2;
sleep 10;
ob1.z1.obs0.switch_partition obtest:test:t1;
ob1.z1.obs0.switch_partition obtest:test:t2;
sleep 10;

connection conn1;
insert into t1 values(3,3);
insert into t2 values(4,4);
commit;
#校验数据
select * from t1;
select * from t2;

drop table t1;
drop table t2;
