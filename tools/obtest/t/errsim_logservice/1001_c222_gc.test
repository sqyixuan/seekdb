# CASE_OWNER:
#    @yaoying.yyy
# CASE_DESC:
#    This case is aimed to test garbaging
#    We designed following cases to simulate different scenes:
#
#    CASE 1:  replica not in member_list (f & R replica)
#    CASE 2:  ls_droping
#    CASE 3: tenant_dropping
#    CASE 3: garbaging of migrating source replica

#######################################################################
#                        create inital objects
#######################################################################

ob1=OBI(cluster=2:2:2,proxy_num=0,init_unit_cpu=0);
source include/mini_ob_config.inc;
let $tenant_name = tt1;
ob1.set extra_config=$mini_ob_config;
ob1.reboot;

ob1.mysql alter system set debug_sync_timeout = '1000s';
ob1.mysql ALTER SYSTEM SET enable_rebalance = 'false';
ob1.mysql ALTER SYSTEM SET enable_rereplication = 'true';
ob1.mysql ALTER SYSTEM SET ls_gc_delay_time='1s';

let $proxy_ip = deploy_get_value(ob1.z1.obs0.ip);
let $proxy_port = deploy_get_value(ob1.z1.obs0.mysql_port);
connect(sys_conn, $proxy_ip, root@sys,,oceanbase, $proxy_port);

# create new tenant $tenant_name
source include/create_unit_config.inc;
ob1.mysql CREATE RESOURCE POOL tenant_pool UNIT = "2c2g", UNIT_NUM = 2, ZONE_LIST = ('z1', 'z2', 'z3');
ob1.mysql CREATE TENANT $tenant_name RESOURCE_POOL_LIST=('tenant_pool'), LOCALITY = "F@z1, F@z2, F@z3", PRIMARY_ZONE = "z1, z2" SET ob_tcp_invited_nodes='%';

let $tenant_id = deploy_get_value(ob1.select SELECT tenant_id FROM oceanbase.DBA_OB_TENANTS WHERE tenant_name = "$tenant_name", tenant_id, 1);

--echo =================================================================================
--echo                     prepare table and data
--echo =================================================================================
ob_connect(conn_mysql, ob1.z1.obs0, root@$tenant_name, , test, , USE_MYSQL_CONNECTOR);
connection conn_mysql;
create table empty_t1(c1 int) duplicate_scope = 'none';
create table normal_t1(c1 int) duplicate_scope = 'none';
insert into normal_t1(c1) values(1), (2), (3), (4);

create table part_table(c1 int, c2 int) duplicate_scope = 'none' partition by hash(c1) partitions 4;
create index part_table_idx on part_table(c2);
insert into part_table(c1, c2) values(1, 1);
insert into part_table(c1, c2) values(2, 2);
insert into part_table(c1, c2) values(3, 2);
insert into part_table(c1, c2) values(4, 4);

create table empty_dup_t1(c1 int, c2 int) duplicate_scope = 'cluster';
create table dup_t1(c1 int, c2 int) duplicate_scope = 'cluster';
insert into dup_t1(c1) values(1), (2), (3), (4);

create table part_table_with_dup(c1 int, c2 int) duplicate_scope = 'CLUSTER' partition by hash(c1) partitions 4;
create index part_table_with_dup_idx on part_table_with_dup(c2);
insert into part_table_with_dup(c1, c2) values(1, 1);
insert into part_table_with_dup(c1, c2) values(2, 2);
insert into part_table_with_dup(c1, c2) values(3, 3);
insert into part_table_with_dup(c1, c2) values(4, 4);

connect(sys_conn, $proxy_ip, root@sys,,oceanbase, $proxy_port);
connection sys_conn;
ob1.check_until_timeout select count(*) as dup_ls_cnt from oceanbase.CDB_OB_LS where flag like '%duplicate%', 1, 20;
let $ls_id = deploy_get_value(ob1.select select ls_id from oceanbase.CDB_OB_TABLE_LOCATIONS where table_name = 'dup_t1', ls_id, 1);

ob1.mysql ALTER SYSTEM SET ls_gc_delay_time='1s' tenant=sys;
ob1.mysql ALTER SYSTEM SET ls_gc_delay_time='1s' tenant=all_user;
ob1.mysql ALTER SYSTEM SET ls_gc_delay_time='1s' tenant=all_meta;
ob1.check_until_timeout select ls_id from oceanbase.CDB_OB_LS where flag like '%duplicate%', $ls_id, 20;
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_LS where tenant_id=$tenant_id, 6, 120;

ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_LS_LOCATIONS where ls_id = $ls_id and tenant_id=$tenant_id, 6, 20;

--echo =================================================================================
--echo                     test garbage replica not in member list(F & R): locality:"F@z1, F@z2, F@z3"->"F@z1, F@z2"
--echo =================================================================================

connect(sys_conn, $proxy_ip, root@sys,,oceanbase, $proxy_port);
connection sys_conn;
ob1.mysql alter system set_tp tp_name = EN_GC_CHECK_RD_TX, error_code = 4023, frequency = 1;
sleep 5;

let $ip=deploy_get_value(ob1.z3.obs0.ip);
let $port=deploy_get_value(ob1.z3.obs0.port);
let $z3_obs0_ls_id_1 = deploy_get_value(ob1.select select ls_id from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id = $tenant_id and ls_id != 1 and svr_ip="$ip" and svr_port=$port order by ls_id, ls_id, 1);
let $z3_obs0_ls_id_2 = deploy_get_value(ob1.select select ls_id from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id = $tenant_id and ls_id != 1 and svr_ip="$ip" and svr_port=$port order by ls_id, ls_id, 2);
let $z3_obs0_ls_id_3 = deploy_get_value(ob1.select select ls_id from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id = $tenant_id and ls_id != 1 and svr_ip="$ip" and svr_port=$port order by ls_id, ls_id, 3);

let $ip=deploy_get_value(ob1.z3.obs1.ip);
let $port=deploy_get_value(ob1.z3.obs1.port);
let $z3_obs1_ls_id_1 = deploy_get_value(ob1.select select ls_id from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id = $tenant_id and ls_id != 1 and svr_ip="$ip" and svr_port=$port order by ls_id, ls_id, 1);
let $z3_obs1_ls_id_2 = deploy_get_value(ob1.select select ls_id from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id = $tenant_id and ls_id != 1 and svr_ip="$ip" and svr_port=$port order by ls_id, ls_id, 2);
let $z3_obs1_ls_id_3 = deploy_get_value(ob1.select select ls_id from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id = $tenant_id and ls_id != 1 and svr_ip="$ip" and svr_port=$port order by ls_id, ls_id, 3);

ob1.mysql alter tenant $tenant_name set locality='F@z1, F@z2';


ob1.z3.obs0.check_log_until_success "need wait before readonly tx been cleaned up(ls_id=$z3_obs0_ls_id_1";
ob1.z3.obs0.check_log_until_success "need wait before readonly tx been cleaned up(ls_id=$z3_obs0_ls_id_2";
ob1.z3.obs0.check_log_until_success "need wait before readonly tx been cleaned up(ls_id=$z3_obs0_ls_id_3";
ob1.z3.obs1.check_log_until_success "need wait before readonly tx been cleaned up(ls_id=$z3_obs1_ls_id_1";
ob1.z3.obs1.check_log_until_success "need wait before readonly tx been cleaned up(ls_id=$z3_obs1_ls_id_2";
ob1.z3.obs1.check_log_until_success "need wait before readonly tx been cleaned up(ls_id=$z3_obs1_ls_id_3";
ob1.mysql alter system set_tp tp_name = EN_GC_CHECK_RD_TX, error_code = 4023, frequency = 0;
sleep 5;

ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_LS_LOCATIONS where ls_id = $ls_id and tenant_id=$tenant_id, 4, 120;
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_LS_LOCATIONS where ls_id = $ls_id and tenant_id=$tenant_id and zone ='z3', 0, 20;
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_LS where tenant_id=$tenant_id, 6, 120;

--echo =================================================================================
--echo                     test ls dropping: primary zone:"z1, z2"->"z1"
--echo =================================================================================

connect(sys_conn, $proxy_ip, root@sys,,oceanbase, $proxy_port);
connection sys_conn;

let $ip=deploy_get_value(ob1.z1.obs0.ip);
let $port=deploy_get_value(ob1.z1.obs0.port);
let $z1_obs0_ls_id_1 = deploy_get_value(ob1.select select ls_id from oceanbase.__all_virtual_log_stat where tenant_id = $tenant_id and ls_id != 1 and svr_ip="$ip" and svr_port=$port and role='FOLLOWER' order by ls_id, ls_id, 1);

let $ip=deploy_get_value(ob1.z1.obs1.ip);
let $port=deploy_get_value(ob1.z1.obs1.port);
let $z1_obs1_ls_id_1 = deploy_get_value(ob1.select select ls_id from oceanbase.__all_virtual_log_stat where tenant_id = $tenant_id and ls_id != 1 and svr_ip="$ip" and svr_port=$port and role='FOLLOWER' order by ls_id, ls_id, 1);

let $ip=deploy_get_value(ob1.z2.obs0.ip);
let $port=deploy_get_value(ob1.z2.obs0.port);
let $z2_obs0_ls_id_1 = deploy_get_value(ob1.select select ls_id from oceanbase.__all_virtual_log_stat where tenant_id = $tenant_id and ls_id != 1 and svr_ip="$ip" and svr_port=$port and role='LEADER' order by ls_id, ls_id, 1);

let $ip=deploy_get_value(ob1.z2.obs1.ip);
let $port=deploy_get_value(ob1.z2.obs1.port);
let $z2_obs1_ls_id_1 = deploy_get_value(ob1.select select ls_id from oceanbase.__all_virtual_log_stat where tenant_id = $tenant_id and ls_id != 1 and svr_ip="$ip" and svr_port=$port and role='LEADER' order by ls_id, ls_id, 1);

ob1.mysql alter system set_tp tp_name = EN_GC_CHECK_RD_TX, error_code = 4023, frequency = 1;
sleep 5;
ob1.mysql alter tenant $tenant_name set primary_zone='z1';

ob1.z2.obs0.check_log_until_success "need wait before readonly tx been cleaned up(ls_id=$z2_obs0_ls_id_1";
ob1.z2.obs1.check_log_until_success "need wait before readonly tx been cleaned up(ls_id=$z2_obs1_ls_id_1";

ob1.z1.obs0.check_log_until_success "need wait before readonly tx been cleaned up(ls_id=$z1_obs0_ls_id_1";
ob1.z1.obs1.check_log_until_success "need wait before readonly tx been cleaned up(ls_id=$z1_obs1_ls_id_1";


ob1.mysql alter system set_tp tp_name = EN_GC_CHECK_RD_TX, error_code = 4023, frequency = 0;
sleep 5;

ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_LS_LOCATIONS where ls_id = $ls_id, 4, 120;
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id=$tenant_id, 10, 120;
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_LS where tenant_id=$tenant_id, 4, 120;



--echo =================================================================================
--echo                     test force drop tenant
--echo =================================================================================

connect(sys_conn, $proxy_ip, root@sys,,oceanbase, $proxy_port);
connection sys_conn;

let $ip=deploy_get_value(ob1.z1.obs0.ip);
let $port=deploy_get_value(ob1.z1.obs0.port);
let $z1_obs0_ls_id_2 = deploy_get_value(ob1.select select ls_id from oceanbase.__all_virtual_log_stat where tenant_id = $tenant_id and ls_id != 1 and svr_ip="$ip" and svr_port=$port  order by ls_id, ls_id, 1);

let $ip=deploy_get_value(ob1.z1.obs1.ip);
let $port=deploy_get_value(ob1.z1.obs1.port);
let $z1_obs1_ls_id_2 = deploy_get_value(ob1.select select ls_id from oceanbase.__all_virtual_log_stat where tenant_id = $tenant_id and ls_id != 1 and svr_ip="$ip" and svr_port=$port  order by ls_id, ls_id, 1);

let $ip=deploy_get_value(ob1.z2.obs0.ip);
let $port=deploy_get_value(ob1.z2.obs0.port);
let $z2_obs0_ls_id_2 = deploy_get_value(ob1.select select ls_id from oceanbase.__all_virtual_log_stat where tenant_id = $tenant_id and ls_id != 1 and svr_ip="$ip" and svr_port=$port  order by ls_id, ls_id, 1);

let $ip=deploy_get_value(ob1.z2.obs1.ip);
let $port=deploy_get_value(ob1.z2.obs1.port);
let $z2_obs1_ls_id_2 = deploy_get_value(ob1.select select ls_id from oceanbase.__all_virtual_log_stat where tenant_id = $tenant_id and ls_id != 1 and svr_ip="$ip" and svr_port=$port  order by ls_id, ls_id, 1);

ob1.mysql alter system set_tp tp_name = EN_GC_CHECK_RD_TX, error_code = 4023, frequency = 1;
sleep 5;
ob1.mysql drop tenant $tenant_name force;

ob1.z1.obs0.check_log_until_success "tenant is dropping or dropped, no longer need to check read_only tx(ls_id=$z1_obs0_ls_id_2";
ob1.z1.obs1.check_log_until_success "tenant is dropping or dropped, no longer need to check read_only tx(ls_id=$z1_obs1_ls_id_2";

ob1.z2.obs0.check_log_until_success "tenant is dropping or dropped, no longer need to check read_only tx(ls_id=$z2_obs0_ls_id_2";
ob1.z2.obs1.check_log_until_success "tenant is dropping or dropped, no longer need to check read_only tx(ls_id=$z2_obs1_ls_id_2";

ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id=$tenant_id, 0, 120;
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_LS where tenant_id=$tenant_id, 0, 120;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_log_stat where tenant_id=$tenant_id, 0, 120;


