ob1.mysql_p select tenant_id, table_id,  sub_part_id,  is_deleted,  sub_part_name, high_bound_val,  b_high_bound_val, list_val,  b_list_val,  sub_part_idx, mapping_pg_sub_part_id from oceanbase.__all_virtual_def_sub_part_history where tenant_id=1001;

ob1.mysql_p select tenant_id, table_id,  sub_part_id,  sub_part_name, high_bound_val,  b_high_bound_val, list_val,  b_list_val,  sub_part_idx, mapping_pg_sub_part_id from oceanbase.__all_virtual_def_sub_part where tenant_id=1001;

