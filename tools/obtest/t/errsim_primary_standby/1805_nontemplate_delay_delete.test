#####################
# owner : yanmu.ztl
# owner group : rs
# description : 非模版话延迟删除逻辑延迟
#####################

ob1=OBI(cluster=1:1:1,init_unit_cpu=0,proxy_num=0);
ob2=OBI(cluster=1:1,leaderob=ob1,proxy_num=0);
ob1.z1.obs0.set extra_config=schema_drop_gc_delay_time='10s',ilog_flush_trigger_time='20s';
ob1.z2.obs0.set extra_config=schema_drop_gc_delay_time='10s',ilog_flush_trigger_time='20s';
ob1.z3.obs0.set extra_config=schema_drop_gc_delay_time='10s',ilog_flush_trigger_time='20s';
ob2.z1.obs0.set extra_config=schema_drop_gc_delay_time='10s',ilog_flush_trigger_time='20s';
ob2.z2.obs0.set extra_config=schema_drop_gc_delay_time='10s',ilog_flush_trigger_time='20s';
ob1.reboot;
ob2.reboot;

# 设置为最大保护模式
ob1.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO STANDBY, 20;
let $cluster_name = deploy_get_value(ob2.select select info from oceanbase.__all_zone where name = 'cluster', info, 1);
let $cluster_id = deploy_get_value(ob2.select select value from oceanbase.__all_virtual_sys_parameter_stat where name = 'cluster_id', value, 1);
ob1.mysql alter system modify cluster '$cluster_name' cluster_id $cluster_id set redo_transport_options='SYNC';

let $cluster_id = deploy_get_value(ob1.select select value from oceanbase.__all_virtual_sys_parameter_stat where name = 'cluster_id', value, 1);
ob1.mysql alter system modify cluster '$cluster_name' cluster_id $cluster_id set redo_transport_options='SYNC';

ob1.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO STANDBY, 20;
ob1.mysql ALTER SYSTEM SET STANDBY CLUSTER TO MAXIMIZE PROTECTION;
ob1.check_until_timeout select protection_level from oceanbase.__all_cluster where cluster_id = $cluster_id, MAXIMUM PROTECTION, 100;

ob1.mysql alter system set resource_hard_limit=900;
ob1.mysql alter system set resource_soft_limit=800;
ob1.mysql alter system set debug_sync_timeout = '1000s';
ob1.mysql alter system set enable_auto_leader_switch = 'false';
ob1.mysql alter system set enable_rebalance = 'false';
ob1.mysql alter system set enable_rereplication = 'false';
ob1.mysql alter system set balancer_idle_time = '10s';
ob1.mysql alter system set server_data_copy_out_concurrency = 20;
ob1.mysql alter system set server_data_copy_in_concurrency = 20;

ob2.mysql alter system set server_data_copy_out_concurrency = 20;
ob2.mysql alter system set server_data_copy_in_concurrency = 20;
ob2.mysql alter system set data_copy_concurrency = 20;

let $rs = deploy_get_value(ob1.get_leader sys:oceanbase:__all_core_table:0);
let $rs_ip = deploy_get_value($rs.ip);
let $rs_port = deploy_get_value($rs.port);
let $rs_mysql_port = deploy_get_value($rs.mysql_port);
connect (conn_sys,$rs_ip,admin@sys,admin,oceanbase,$rs_mysql_port);

let $cpu = 1;
let $memory = 1073741824;
let $min_memory = 1073741824;
let $disk = 536870912;
let $iops = 100000;
let $session = 64;

connection conn_sys;
eval CREATE RESOURCE UNIT unit_1 MAX_CPU $cpu, MAX_MEMORY $memory, MAX_IOPS $iops, MAX_DISK_SIZE $disk, MAX_SESSION_NUM $session, MIN_CPU=1, MIN_MEMORY=$min_memory, MIN_IOPS=128;
eval CREATE RESOURCE POOL pool_1 UNIT = 'unit_1', UNIT_NUM = 1, ZONE_LIST = ('z1','z2','z3');
set @@session.ob_query_timeout = 20000000;
eval CREATE TENANT t_oracle RESOURCE_POOL_LIST = ('pool_1'), primary_zone = 'z1;z2,z3', locality='F@z1,F@z2,F@z3' set ob_tcp_invited_nodes='%', ob_compatibility_mode='oracle', recyclebin = 'off';
sleep 10;

ob_connect(conn_t_oracle, ob1.z1.obs0, SYS@t_oracle, ,SYS, , USE_OB_CONNECTOR);

connection conn_t_oracle;
create user obtest IDENTIFIED BY "obtest";
grant all on *.* to obtest WITH GRANT OPTION;
grant dba to obtest;
ob_connect(conn_t_oracle_obtest,ob1,OBTEST@t_oracle,obtest,obtest,,USE_OB_CONNECTOR);

connection conn_t_oracle_obtest;

# 1. create table
create table t_range_range1 (c1 int, c2 int, c3 int, c4 int)
partition by range(c1)
subpartition by range(c2)
(
  partition t1rp0 values less than (100)
  (
    subpartition t1rp0sp0 values less than (100),
    subpartition t1rp0sp1 values less than (200),
    subpartition t1rp0sp2 values less than (300),
    subpartition t1rp0sp3 values less than (400)
  ),
  partition t1rp1 values less than (200)
  (
    subpartition t1rp1sp0 values less than (100),
    subpartition t1rp1sp1 values less than (200),
    subpartition t1rp1sp2 values less than (300),
    subpartition t1rp1sp3 values less than (400)
  ),
  partition t1rp2 values less than (400)
  (
    subpartition t1rp2sp0 values less than (100),
    subpartition t1rp2sp1 values less than (200),
    subpartition t1rp2sp2 values less than (300),
    subpartition t1rp2sp3 values less than (400)
  )
);

