# 2. alter table
alter table t_range_range1 drop partition t1rp0;

alter table t_range_range2 drop subpartition t2rp2sp1;

alter table t_range_range3 drop subpartition t3rp2sp1;
alter table t_range_range3 drop partition t3rp2;

alter table t_range_range4 drop partition t4rp0;
drop table t_range_range4;

alter table t_range_range5 drop subpartition t5rp2sp1;
drop table t_range_range5;

alter table t_range_range6 drop subpartition t6rp2sp1;
alter table t_range_range6 drop partition t6rp2;
drop table t_range_range6;

drop table t_range_range7;

# 3. check delaydelete result
ob1.mysql_p select tenant_id, table_id,  is_deleted, part_level,  part_func_type,  part_func_expr,  part_num,  sub_part_func_type,  sub_part_func_expr,  sub_part_num, max_used_part_id,  partition_status,  IF(partition_schema_version > 0, 1, 0),  IF(drop_schema_version > 0, 1, 0), is_sub_part_template from oceanbase.__all_virtual_table_history where tenant_id=1001;

ob1.mysql_p select tenant_id, table_id, part_level,  part_func_type,  part_func_expr,  part_num,  sub_part_func_type,  sub_part_func_expr,  sub_part_num, max_used_part_id,  partition_status,  IF(partition_schema_version > 0, 1, 0),  IF(drop_schema_version > 0, 1, 0), is_sub_part_template from oceanbase.__all_virtual_table where tenant_id=1001;

ob1.mysql_p select table_id, part_id, sub_part_num, IF(drop_schema_version > 0, 1, 0), is_deleted from oceanbase.__all_virtual_part_history where tenant_id=1001;

ob1.mysql_p select table_id, part_id, sub_part_num, part_name, IF(drop_schema_version > 0, 1, 0) from oceanbase.__all_virtual_part where tenant_id=1001;

ob1.mysql_p select table_id, part_id, sub_part_id, sub_part_name, IF(drop_schema_version > 0, 1, 0), is_deleted from oceanbase.__all_virtual_sub_part_history where tenant_id=1001;

ob1.mysql_p select table_id, part_id, sub_part_id, sub_part_name, IF(drop_schema_version > 0, 1, 0) from oceanbase.__all_virtual_sub_part where tenant_id=1001;

ob1.mysql_p select tenant_id, table_id,  sub_part_id,  is_deleted,  sub_part_name, high_bound_val,  b_high_bound_val, list_val,  b_list_val,  sub_part_idx, mapping_pg_sub_part_id from oceanbase.__all_virtual_def_sub_part_history where tenant_id=1001;

ob1.mysql_p select tenant_id, table_id,  sub_part_id,  sub_part_name, high_bound_val,  b_high_bound_val, list_val,  b_list_val,  sub_part_idx, mapping_pg_sub_part_id from oceanbase.__all_virtual_def_sub_part where tenant_id=1001;

ob1.mysql_p select tenant_id, table_id,  is_deleted,  part_type, part_num,  sub_part_type, def_sub_part_num,  part_expr, sub_part_expr from oceanbase.__all_virtual_part_info_history where tenant_id=1001;

ob1.mysql_p select tenant_id, table_id, is_deleted, part_type, part_num,  sub_part_type, def_sub_part_num,  part_expr, sub_part_expr from oceanbase.__all_virtual_part_info_history where tenant_id=1001;

ob1.mysql_p select tenant_id, table_id, part_type, part_num,  sub_part_type, def_sub_part_num,  part_expr, sub_part_expr from oceanbase.__all_virtual_part_info where tenant_id=1001;

ob1.mysql_p select tenant_id, table_id, partition_id from oceanbase.__all_virtual_tenant_gc_partition_info where tenant_id=1001;


# 4. check forcedrop result
sleep 60;

ob1.mysql_p select tenant_id, table_id,  is_deleted, part_level,  part_func_type,  part_func_expr,  part_num,  sub_part_func_type,  sub_part_func_expr,  sub_part_num, max_used_part_id,  partition_status,  IF(partition_schema_version > 0, 1, 0),  IF(drop_schema_version > 0, 1, 0), is_sub_part_template from oceanbase.__all_virtual_table_history where tenant_id=1001;

ob1.mysql_p select tenant_id, table_id, part_level,  part_func_type,  part_func_expr,  part_num,  sub_part_func_type,  sub_part_func_expr,  sub_part_num, max_used_part_id,  partition_status,  IF(partition_schema_version > 0, 1, 0),  IF(drop_schema_version > 0, 1, 0), is_sub_part_template from oceanbase.__all_virtual_table where tenant_id=1001;

ob1.mysql_p select table_id, part_id, sub_part_num, IF(drop_schema_version > 0, 1, 0), is_deleted from oceanbase.__all_virtual_part_history where tenant_id=1001;

ob1.mysql_p select table_id, part_id, sub_part_num, part_name, IF(drop_schema_version > 0, 1, 0) from oceanbase.__all_virtual_part where tenant_id=1001;

ob1.mysql_p select table_id, part_id, sub_part_id, sub_part_name, IF(drop_schema_version > 0, 1, 0), is_deleted from oceanbase.__all_virtual_sub_part_history where tenant_id=1001;

