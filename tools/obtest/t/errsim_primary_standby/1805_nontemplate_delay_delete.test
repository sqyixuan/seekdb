ob1.mysql_p select tenant_id, table_id, part_type, part_num,  sub_part_type, def_sub_part_num,  part_expr, sub_part_expr from oceanbase.__all_virtual_part_info where tenant_id=1001;

ob1.mysql_p select tenant_id, table_id, partition_id from oceanbase.__all_virtual_tenant_gc_partition_info where tenant_id=1001;

