# owner: msy164651
# owner group: rs
# description : 验证schema回收后，failover的convert操作一定可以选择到一个没回收的版本
ob1=OBI(cluster=1, init_unit_cpu=0, proxy_num=0, ct_num=0, locality=hz);
ob2=OBI(cluster=1,leaderob=ob1,proxy_num=0);
ob1.z1.obs0.set extra_config=schema_drop_gc_delay_time='10s',ilog_flush_trigger_time='20s';
ob2.z1.obs0.set extra_config=schema_drop_gc_delay_time='10s',ilog_flush_trigger_time='20s';
ob1.reboot;
ob2.reboot;

# set maximum protection mode
ob1.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO STANDBY, 20;
let $cluster_name = deploy_get_value(ob2.select select info from oceanbase.__all_zone where name = 'cluster', info, 1);
let $cluster_id = deploy_get_value(ob2.select select value from oceanbase.__all_virtual_sys_parameter_stat where name = 'cluster_id', value, 1);
ob1.mysql alter system modify cluster '$cluster_name' cluster_id $cluster_id set redo_transport_options='SYNC';

let $cluster_id = deploy_get_value(ob1.select select value from oceanbase.__all_virtual_sys_parameter_stat where name = 'cluster_id', value, 1);
ob1.mysql alter system modify cluster '$cluster_name' cluster_id $cluster_id set redo_transport_options='SYNC';

ob1.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO STANDBY, 20;
ob1.mysql ALTER SYSTEM SET STANDBY CLUSTER TO MAXIMIZE PROTECTION;
ob1.check_until_timeout select protection_level from oceanbase.__all_cluster where cluster_id = $cluster_id, MAXIMUM PROTECTION, 100;

--disable_query_log
ob1.mysql alter system set enable_auto_leader_switch = 'false';
ob1.mysql alter system set enable_rebalance = 'false';
ob1.mysql alter system set enable_rereplication = 'false';
ob1.mysql alter system set balancer_idle_time = '10s';
ob1.mysql alter system set schema_history_recycle_interval = "10s";
ob1.mysql alter system set schema_history_expire_time = '1m';

ob2.mysql alter system set schema_history_recycle_interval = "10s";
ob2.mysql alter system set schema_history_expire_time = '1m';
ob2.mysql alter system set data_copy_concurrency = 10;
ob2.mysql alter system set server_data_copy_out_concurrency = 10;
ob2.mysql alter system set server_data_copy_in_concurrency = 10;

let $cpu = 1;
let $memory = 1073741824;
let $min_memory = 1073741824;
let $disk = 536870912;
let $iops = 100000;
let $session = 64;

let $rs = deploy_get_value(ob1.get_leader sys:oceanbase:__all_core_table:0);
let $rs_ip = deploy_get_value($rs.ip);
let $rs_port = deploy_get_value($rs.port);
let $rs_mysql_port = deploy_get_value($rs.mysql_port);
connect (conn_sys,$rs_ip,admin@sys,admin,oceanbase,$rs_mysql_port);

connection conn_sys;
eval CREATE RESOURCE UNIT unit_1 MAX_CPU $cpu, MAX_MEMORY $memory, MAX_IOPS $iops, MAX_DISK_SIZE $disk, MAX_SESSION_NUM $session, MIN_CPU=1, MIN_MEMORY=$min_memory, MIN_IOPS=128;
eval CREATE RESOURCE POOL pool_1 UNIT = 'unit_1', UNIT_NUM = 1, ZONE_LIST = ('z1');
set @@session.ob_query_timeout = 20000000;
eval CREATE TENANT mysql RESOURCE_POOL_LIST = ('pool_1'), primary_zone = 'z1', locality='F@z1' set ob_tcp_invited_nodes='%', recyclebin = OFF;
let $mysql_tenant_id = query_get_value(select tenant_id from __all_tenant where tenant_name="mysql", tenant_id, 1);
sleep 10;

eval CREATE RESOURCE POOL pool_2 UNIT = 'unit_1', UNIT_NUM = 1, ZONE_LIST = ('z1');
set @@session.ob_query_timeout = 20000000;
eval CREATE TENANT oracle RESOURCE_POOL_LIST = ('pool_2'), primary_zone = 'z1', locality='F@z1' set ob_tcp_invited_nodes='%', ob_compatibility_mode='oracle', recyclebin = OFF;
sleep 10;

ob_connect(conn_oracle, ob1, SYS@oracle, ,SYS, , USE_OB_CONNECTOR);
connect (conn_mysql,$rs_ip,root@mysql,,test,$rs_mysql_port);

# case 0: create restore point
connection conn_mysql;
create restore point rs_point;
# case 1: table related
connection conn_mysql;
# case 1.1 drop table
create table table_to_drop(c1 int primary key, c2 int) partition by hash(c1) partitions 10;
drop table table_to_drop;
# case 1.2 alter table
create table table_to_modify(c1 int primary key, c2 int) partition by hash(c1) partitions 10;
create table table_to_modify_and_drop(c1 int primary key, c2 int) partition by hash(c1) partitions 10;
let $idx = 1;
while ($idx < 20)
{
  eval alter table table_to_modify set comment = "$idx";
  eval alter table table_to_modify_and_drop set comment = "";
  inc $idx;
}
drop table table_to_modify_and_drop;

# case 2: column related (only recycle)
connection conn_mysql;
# case 2.1: drop column
create table table_modify_column(c1 int primary key, column_to_drop int, column_to_modify varchar(20)) partition by hash(c1) partitions 10;
create table table_modify_column_and_drop(c1 int primary key, column_to_drop int, column_to_modify varchar(20)) partition by hash(c1) partitions 10;
alter table table_modify_column drop column column_to_drop;
# case 2.2: modify column
let $idx = 21;
while ($idx < 40)
{
  eval alter table table_modify_column modify column column_to_modify varchar($idx);
  eval alter table table_modify_column_and_drop modify column column_to_modify varchar($idx);
  inc $idx;
}
drop table table_modify_column_and_drop;

# case 3: partition related (only recycle)
connection conn_mysql;
create table table_partitioned_by_range (c1 int primary key, c2 int) partition by range(c1) (partition p0 values less than (500), partition p1 values less than (10000));
create table table_partitioned_by_range_hash (c1 int , c2 int, c3 int, primary key(c1, c2)) partition by range(c1) subpartition by hash(c2) subpartitions 2 (partition p0 values less than (500), partition p1 values less than (10000));
create table table_partitioned_by_range_and_drop (c1 int primary key, c2 int) partition by range(c1) (partition p0 values less than (500), partition p1 values less than (10000));
create table table_partitioned_by_range_hash_and_drop (c1 int , c2 int, c3 int, primary key(c1, c2)) partition by range(c1) subpartition by hash(c2) subpartitions 2 (partition p0 values less than (500), partition p1 values less than (10000));
let $idx = 2;
while ($idx < 20)
{
  inc $idx;
  eval alter table table_partitioned_by_range add partition (partition p$idx values less than (20000));
  eval alter table table_partitioned_by_range drop partition p$idx;
  eval alter table table_partitioned_by_range_hash add partition (partition p$idx values less than (20000));
  eval alter table table_partitioned_by_range_hash drop partition p$idx;

  eval alter table table_partitioned_by_range_and_drop add partition (partition p$idx values less than (20000));
  eval alter table table_partitioned_by_range_and_drop drop partition p$idx;
  eval alter table table_partitioned_by_range_hash_and_drop add partition (partition p$idx values less than (20000));
  eval alter table table_partitioned_by_range_hash_and_drop drop partition p$idx;
}
drop table table_partitioned_by_range_and_drop;
drop table table_partitioned_by_range_hash_and_drop;

# case 6: tablegroup
connection conn_mysql;
# case 6.1: drop tablegroup
create tablegroup tg_to_drop;
drop tablegroup tg_to_drop;
# case 6.2: drop tablegroup partition (only recycle)
create tablegroup tg_partitioned_by_range partition by range columns 1 (partition p0 values less than (500), partition p1 values less than (10000));
create tablegroup tg_partitioned_by_range_hash partition by range columns 1 subpartition by hash subpartitions 2 (partition p0 values less than (500), partition p1 values less than (10000));
create tablegroup tg_partitioned_by_range_and_drop partition by range columns 1 (partition p0 values less than (500), partition p1 values less than (10000));
create tablegroup tg_partitioned_by_range_hash_and_drop partition by range columns 1 subpartition by hash subpartitions 2 (partition p0 values less than (500), partition p1 values less than (10000));
let $idx = 2;
while ($idx < 20)
{
  inc $idx;
  eval alter tablegroup tg_partitioned_by_range add partition (partition p$idx values less than (20000));
  eval alter tablegroup tg_partitioned_by_range drop partition p$idx;
  eval alter tablegroup tg_partitioned_by_range_hash add partition (partition p$idx values less than (20000));
  eval alter tablegroup tg_partitioned_by_range_hash drop partition p$idx;

  eval alter tablegroup tg_partitioned_by_range_and_drop add partition (partition p$idx values less than (20000));
  eval alter tablegroup tg_partitioned_by_range_and_drop drop partition p$idx;
  eval alter tablegroup tg_partitioned_by_range_hash_and_drop add partition (partition p$idx values less than (20000));
  eval alter tablegroup tg_partitioned_by_range_hash_and_drop drop partition p$idx;
}
drop tablegroup tg_partitioned_by_range_and_drop;
drop tablegroup tg_partitioned_by_range_hash_and_drop;

# wait schema dropped actually
ob1.check_until_timeout select count(*) as cnt from __all_virtual_table_history where (table_id, schema_version) in (select table_id, max(schema_version) from __all_virtual_table_history where table_id in (select distinct(table_id) from __all_virtual_table_history where drop_schema_version > 0) group by table_id) and is_deleted != 1, 0, 600;
ob1.check_until_timeout select count(*) as cnt from __all_virtual_tablegroup_history where (tablegroup_id, schema_version) in (select tablegroup_id, max(schema_version) from __all_virtual_tablegroup_history where tablegroup_id in (select distinct(tablegroup_id) from __all_virtual_tablegroup_history where drop_schema_version > 0) group by tablegroup_id) and is_deleted != 1, 0, 600;
ob1.check_until_timeout select count(*) as cnt from __all_virtual_part_history where (table_id, part_id, schema_version) in (select table_id, part_id, max(schema_version) from __all_virtual_part_history where (table_id, part_id) in (select table_id, part_id from __all_virtual_part_history where drop_schema_version > 0 group by table_id, part_id) group by table_id, part_id) and is_deleted != 1, 0, 600;

# wait merge finished
let $idx = 2;
while ($idx <= 4)
{
  ob1.mysql alter system major freeze;
  ob1.check_until_timeout select value from __all_zone where zone='' and name='last_merged_version', $idx, 300;
  inc $idx;
}
--enable_query_log

# wait standby cluster sync
ob1.check_until_timeout select synchronization_status from oceanbase.v\$ob_standby_status, OK, 120;
ob2.check_until_timeout select value from __all_zone where zone='' and name='last_merged_version', 4, 300;

#######################################################
# check result
#######################################################


# table related
connection conn_sys;
select a.*, b.table_name from (select tenant_id, table_id, if (count(*) > 1, 2, count(*)) as history_cnt from __all_virtual_table_history where tenant_id != 1 and table_id & 0xffffffffff > 50000 group by tenant_id, table_id) as a join __all_virtual_table as b on a.tenant_id = b.tenant_id and a.table_id = b.table_id;
select a.*, b.table_name from (select tenant_id, table_id, count(*) as history_cnt from __all_virtual_column_history where tenant_id != 1 and table_id & 0xffffffffff > 50000 group by tenant_id, table_id) as a join __all_virtual_table as b on a.tenant_id = b.tenant_id and a.table_id = b.table_id;
select a.*, b.table_name from (select tenant_id, table_id, count(*) as history_cnt from __all_virtual_part_info_history where tenant_id != 1 and table_id & 0xffffffffff > 50000 group by tenant_id, table_id) as a join __all_virtual_table as b on a.tenant_id = b.tenant_id and a.table_id = b.table_id;
select a.*, b.table_name from (select tenant_id, table_id, count(*) as history_cnt from __all_virtual_sub_part_history where tenant_id != 1 and table_id & 0xffffffffff > 50000 group by tenant_id, table_id) as a join __all_virtual_table as b on a.tenant_id = b.tenant_id and a.table_id = b.table_id;
select a.*, b.table_name from (select tenant_id, table_id, count(*) as history_cnt from __all_virtual_part_history where tenant_id != 1 and table_id & 0xffffffffff > 50000 group by tenant_id, table_id) as a join __all_virtual_table as b on a.tenant_id = b.tenant_id and a.table_id = b.table_id;
select a.*, b.table_name from (select tenant_id, table_id, count(*) as history_cnt from __all_virtual_def_sub_part_history where tenant_id != 1 and table_id & 0xffffffffff > 50000 group by tenant_id, table_id) as a join __all_virtual_table as b on a.tenant_id = b.tenant_id and a.table_id = b.table_id;

# tablegroup related
connection conn_sys;
select a.*, b.tablegroup_name from (select tenant_id, tablegroup_id, if (count(*) > 1, 2, count(*)) as history_cnt from __all_virtual_tablegroup_history where tenant_id != 1 and tablegroup_id & 0xffffffffff > 50000 group by tenant_id, tablegroup_id) as a join __all_virtual_tablegroup as b on a.tenant_id = b.tenant_id and a.tablegroup_id = b.tablegroup_id;
select a.tenant_id, a.table_id as tablegroup_id, a.history_cnt, b.tablegroup_name from (select tenant_id, table_id, count(*) as history_cnt from __all_virtual_part_info_history where tenant_id != 1 and table_id & 0xffffffffff > 50000 group by tenant_id, table_id) as a join __all_virtual_tablegroup as b on a.tenant_id = b.tenant_id and a.table_id = b.tablegroup_id;
select a.tenant_id, a.table_id as tablegroup_id, a.history_cnt, b.tablegroup_name from (select tenant_id, table_id, count(*) as history_cnt from __all_virtual_sub_part_history where tenant_id != 1 and table_id & 0xffffffffff > 50000 group by tenant_id, table_id) as a join __all_virtual_tablegroup as b on a.tenant_id = b.tenant_id and a.table_id = b.tablegroup_id;
select a.tenant_id, a.table_id as tablegroup_id, a.history_cnt, b.tablegroup_name from (select tenant_id, table_id, count(*) as history_cnt from __all_virtual_part_history where tenant_id != 1 and table_id & 0xffffffffff > 50000 group by tenant_id, table_id) as a join __all_virtual_tablegroup as b on a.tenant_id = b.tenant_id and a.table_id = b.tablegroup_id;
select a.tenant_id, a.table_id as tablegroup_id, a.history_cnt, b.tablegroup_name from (select tenant_id, table_id, count(*) as history_cnt from __all_virtual_def_sub_part_history where tenant_id != 1 and table_id & 0xffffffffff > 50000 group by tenant_id, table_id) as a join __all_virtual_tablegroup as b on a.tenant_id = b.tenant_id and a.table_id = b.tablegroup_id;


#intact failver


ob1.force_stop;
let $cluster_id = deploy_get_value(ob2.select select value from oceanbase.__all_virtual_sys_parameter_stat where name = 'cluster_id', value, 1);
ob2.mysql alter system failover to '$cluster_name' cluster_id $cluster_id;
#failover后需要修改为最大性能；
ob2.mysql_p select protection_mode, protection_level from oceanbase.__all_virtual_cluster;
ob2.mysql_p select redo_transport_options, protection_level from oceanbase.__all_cluster;

ob1.z1.obs0.nstart -m disabled_cluster;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_core_meta_table, 1, 100;
ob1.mysql alter system convert to physical standby;
let $cluster_id = deploy_get_value(ob1.select select value from oceanbase.__all_virtual_sys_parameter_stat where name = 'cluster_id', value, 1);
ob_connect(conn4, ob2.z1.obs0, root@sys, ,oceanbase, , USE_OB_CONNECTOR);
connection conn4;
--disable_query_log
eval alter system enable cluster synchronization '$cluster_name' cluster_id = $cluster_id;
--enable_query_log

ob2.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO STANDBY, 60;

ob1.mysql_p select protection_mode, protection_level from oceanbase.__all_virtual_cluster;
ob1.mysql_p select redo_transport_options, protection_level from oceanbase.__all_cluster;

ob_connect(conn2, ob2.z1.obs0, root@mysql, ,oceanbase, , USE_OB_CONNECTOR);
connection conn2;
use test;
create table t111111(c1 int primary key, c2 int);
ob2.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO STANDBY, 60;
