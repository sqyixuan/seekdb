#owner: cxf262476
#owner group: transaction
# 测试点：一阶段优化宕机重启事务状态推进
##
ob1=OBI(cluster=1,proxy_num=0,init_unit_cpu=5);
ob1.reboot;
sleep 5;

#ob1.mysql alter system set enable_auto_leader_switch=false;
#ob1.mysql alter system set enable_one_phase_commit = true;

let $ip0=deploy_get_value(ob1.z1.obs0.ip);
let $port0=deploy_get_value(ob1.z1.obs0.port);
let $sql_port0=deploy_get_value(ob1.z1.obs0.mysql_port);
connect(conn1,$ip0,root@obtest,,test,$sql_port0);

set ob_query_timeout=90000000;
set ob_trx_timeout=1200000000;
create database obtest;
use obtest;
#ob1.mysql alter system set_tp tp_no = 362, error_code = 4023, frequency = 1;

create table t1(c1 int primary key, c2 int);
create table t2(c1 int primary key, c2 int);

start transaction;

insert into t1 values(1,1);
insert into t1 values(2,2);
insert into t1 values(3,3);
insert into t2 values(4,4);
insert into t2 values(5,5);
insert into t2 values(6,6);

ob1.mysql alter system minor freeze tenant = sys;
ob1.mysql alter system minor freeze tenant = all_user;
ob1.mysql alter system minor freeze tenant = all_meta;

sleep 1;

commit;

sleep 10;

let $tid1 = deploy_get_value(ob1.select select tablet_id from oceanbase.__all_virtual_table where table_name='t1', tablet_id, 1);
let $tid2 = deploy_get_value(ob1.select select tablet_id from oceanbase.__all_virtual_table where table_name='t2', tablet_id, 1);

ob1.check_until_timeout select count(1) from __all_virtual_table_mgr where tablet_id = $tid1 and table_type=0, 0, 120;
ob1.check_until_timeout select count(1) from __all_virtual_table_mgr where tablet_id = $tid2 and table_type=0, 0, 120;

ob1.z1.obs0.force_stop;

sleep 10;

ob1.z1.obs0.nstart;

sleep 30;


ob1.check_until_timeout select count(1) from __all_virtual_trans_stat, 0, 100;
connect(conn1,$ip0,root@obtest,,obtest,$sql_port0);
select * from t1;
select * from t2;
