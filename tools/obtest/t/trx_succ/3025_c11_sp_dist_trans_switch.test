#
#owner: shanyan.g 
#owner group: transaction
# 测试点：单分区事务切换为分布式事务
##
ob1=OBI(cluster=1:1,proxy_num=0,init_unit_cpu=5);
ob1.reboot;
sleep 5;

#在zone1上建立连接
let $l_ip=deploy_get_value(ob1.z1.obs0.ip);
let $l_port=deploy_get_value(ob1.z1.obs0.mysql_port);
connect (conn1,$l_ip,root@obtest,,test,$l_port);
connect (conn2,$l_ip,root@sys,,oceanbase,$l_port);

connection conn1;
## case:检查表结构
create table sp_trans_test(id1 int, id2 int);
desc sp_trans_test;
insert into sp_trans_test values(1, 1);
insert into sp_trans_test values(1, 2);
insert into sp_trans_test values(1, 3);
sleep 5;

####################################
##测试mini_sp_trans，autocommit=1的单partition只读事务
set @@session.tx_read_only=1;
select * from sp_trans_test;
select * from sp_trans_test;

##测试sp_trans，包括以下几种情况:
#case1 : autocommit=1，单partition读写事务
set autocommit=1;
set @@session.tx_read_only=0;
insert into sp_trans_test values(1, 4);
select *from sp_trans_test;

#case2 : autocommit=0, 单partition多条只读或者读写语句
set autocommit=0;
set @@session.tx_read_only=0;
begin;
select * from sp_trans_test;
insert into sp_trans_test values(1, 5);
select count(1) from sp_trans_test;
insert into sp_trans_test values(1, 6);
insert into sp_trans_test values(1, 7);
select count(1) from sp_trans_test;
commit;
select *from sp_trans_test;
ob1.mysql alter system major freeze tenant=sys;
ob1.mysql alter system major freeze tenant=all_user;
ob1.mysql alter system major freeze tenant=all_meta;

connection conn2;
let $__i__= 600;
while($__i__ > 0)
{
    sleep 1;
    dec $__i__;
    let $__frozen_scn__ = query_get_value(select sum(frozen_scn/1000) as sum_value from oceanbase.CDB_OB_MAJOR_COMPACTION, sum_value, 1);
    let $__merged_version__ = query_get_value(select sum(last_scn/1000) as sum_value from oceanbase.CDB_OB_MAJOR_COMPACTION, sum_value, 1);
    # all tenant should major merge complete
    # n conn1;
    if($__frozen_scn__ == $__merged_version__)
    {
        let $__i__ = -5;
    }
}
if($__i__ != -5)
{
    --echo major freeze failed
    select * from oceanbase.CDB_OB_MAJOR_COMPACTION;
    let $__tenant_id__ = query_get_value(select tenant_id from oceanbase.CDB_OB_MAJOR_COMPACTION where last_scn != frozen_scn, tenant_id, 1);
    let $__frozen_scn__ = query_get_value(select frozen_scn from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id = $__tenant_id__, frozen_scn, 1);
    eval select * from oceanbase.__all_virtual_server_compaction_event_history where tenant_id = $__tenant_id__ and compaction_scn = $__frozen_scn__;
    select * from oceanbase.__all_virtual_compaction_diagnose_info;
    --exit
}

connection conn1;
create table sp_trans_test2(id1 int, id2 int);
desc sp_trans_test2;

##测试sp_trans转化成分布式事务的场景(sp_trans->dist_trans)
#case1:
set autocommit=0;
set @@session.tx_read_only=0;
begin;
select * from sp_trans_test;
insert into sp_trans_test2 values(1, 8);
insert into sp_trans_test values(1, 9);
select * from sp_trans_test2;
commit;

#case2:
begin;
insert into sp_trans_test values(1, 10);
insert into sp_trans_test2 values(1, 11);
select * from sp_trans_test2;
select * from sp_trans_test;
commit;

#case3:
begin;
select * from sp_trans_test;
insert into sp_trans_test values(1, 12);
insert into sp_trans_test2 values(1, 13);
select * from sp_trans_test2;
commit;
select *from sp_trans_test;
select *from sp_trans_test2;

ob1.mysql alter system major freeze tenant=sys;
ob1.mysql alter system major freeze tenant=all_user;
ob1.mysql alter system major freeze tenant=all_meta;

connection conn2;
let $__i__= 600;
while($__i__ > 0)
{
    sleep 1;
    dec $__i__;
    let $__frozen_scn__ = query_get_value(select sum(frozen_scn/1000) as sum_value from oceanbase.CDB_OB_MAJOR_COMPACTION, sum_value, 1);
    let $__merged_version__ = query_get_value(select sum(last_scn/1000) as sum_value from oceanbase.CDB_OB_MAJOR_COMPACTION, sum_value, 1);
    # all tenant should major merge complete
    if($__frozen_scn__ == $__merged_version__)
    {
        let $__i__ = -5;
    }
}
if($__i__ != -5)
{
    --echo major freeze failed
    select * from oceanbase.CDB_OB_MAJOR_COMPACTION;
    let $__tenant_id__ = query_get_value(select tenant_id from oceanbase.CDB_OB_MAJOR_COMPACTION where last_scn != frozen_scn, tenant_id, 1);
    let $__frozen_scn__ = query_get_value(select frozen_scn from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id = $__tenant_id__, frozen_scn, 1);
    eval select * from oceanbase.__all_virtual_server_compaction_event_history where tenant_id = $__tenant_id__ and compaction_scn = $__frozen_scn__;
    select * from oceanbase.__all_virtual_compaction_diagnose_info;
    --exit
}
