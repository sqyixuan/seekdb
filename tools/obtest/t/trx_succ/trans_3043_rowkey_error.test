# owner:shanyan.g
# owner group:transaction
# description:
# 测试点：大小写不敏感的主键更新存在的正确性问题
##

ob1=OBI(cluster=1:1,proxy_num=0,init_unit_cpu=5,init_unit_num=1);
ob1.reboot;
sleep 5;

#在zone1上建立连接
let $l_ip=deploy_get_value(ob1.z1.obs0.ip);
let $l_port=deploy_get_value(ob1.z1.obs0.mysql_port);
connect (conn1,$l_ip,root@obtest,,test,$l_port);
connect (conn2,$l_ip,root@obtest,,test,$l_port);
connect (conn_sys,$l_ip,root@sys,,oceanbase,$l_port);

connection conn1;
create table t_update (a varchar(20), b varchar(200), c varchar(200), d int,  primary key(a, b , c), key i1(b));
begin;

connection conn2;
begin;

connection conn1;
insert into t_update values ('20200311', '1pages/addCard/addCard', 'mon_active_user', 123);
insert into t_update values ('20200311', '1pages/addcard/addcard', 'mon_active_user', 321) on duplicate key update a='20200311', b = '1pages/addcard/addcard', c = 'mon_active_user', d= 321;

connection conn2;
send insert into t_update values ('20200311', '1pages/addcard/addcard', 'mon_active_user', 321) on duplicate key update a='20200311', b = '1pages/addcard/addcard', c = 'mon_active_user', d= 321;

connection conn1;
commit;

ob1.mysql alter system minor freeze tenant = sys;
ob1.mysql alter system minor freeze tenant = all_user;
ob1.mysql alter system minor freeze tenant = all_meta;
sleep 40;

connection conn2;
commit;

ob1.mysql alter system major freeze tenant=sys;
ob1.mysql alter system major freeze tenant=all_user;
ob1.mysql alter system major freeze tenant=all_meta;

connection conn_sys;
let $__i__= 600;
while($__i__ > 0)
{
    sleep 1;
    dec $__i__;
    let $__frozen_scn__ = query_get_value(select sum(frozen_scn/1000) as sum_value from oceanbase.CDB_OB_MAJOR_COMPACTION, sum_value, 1);
    let $__merged_version__ = query_get_value(select sum(last_scn/1000) as sum_value from oceanbase.CDB_OB_MAJOR_COMPACTION, sum_value, 1);
    # all tenant should major merge complete
    if($__frozen_scn__ == $__merged_version__)
    {
        let $__i__ = -5;
    }
}
if($__i__ != -5)
{
    --echo major freeze failed
    select * from oceanbase.CDB_OB_MAJOR_COMPACTION;
    let $__tenant_id__ = query_get_value(select tenant_id from oceanbase.CDB_OB_MAJOR_COMPACTION where last_scn != frozen_scn, tenant_id, 1);
    let $__frozen_scn__ = query_get_value(select frozen_scn from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id = $__tenant_id__, frozen_scn, 1);
    eval select * from oceanbase.__all_virtual_server_compaction_event_history where tenant_id = $__tenant_id__ and compaction_scn = $__frozen_scn__;
    select * from oceanbase.__all_virtual_compaction_diagnose_info;
    --exit
}
