# owner: handora.qc
# owner group: transaction
# description: this case is use for minor freeze uncommitted transactions when switching leader

--disable_query_log
ob1=OBI(cluster=1:1,proxy_num=0,init_unit_cpu=2);

ob1.z1.obs0.set extra_config=_private_buffer_size='1B';
ob1.z2.obs0.set extra_config=_private_buffer_size='1B';
ob1.reboot;

ob1.mysql alter system set debug_sync_timeout = '1000s';
ob1.mysql set GLOBAL ob_query_timeout = 100000000000;
ob1.mysql set GLOBAL ob_trx_timeout = 100000000000;


let $ip0=deploy_get_value(ob1.z1.obs0.ip);
let $port0=deploy_get_value(ob1.z1.obs0.port);
let $sql_port0=deploy_get_value(ob1.z1.obs0.mysql_port);
let $ip1=deploy_get_value(ob1.z2.obs0.ip);
let $port1=deploy_get_value(ob1.z2.obs0.port);
let $sql_port1=deploy_get_value(ob1.z2.obs0.mysql_port);

connect(conn_sys,$ip0,root@sys,,oceanbase,$sql_port0);
connect(conn1,$ip0,root@obtest,,test,$sql_port0);
connect(conn2,$ip1,root@obtest,,test,$sql_port1);

connection conn1;
set ob_query_timeout = 100000000000;
set ob_trx_timeout = 100000000000;
set ob_trx_idle_timeout = 100000000000;

# 创建table和索引
connection conn1;
create table t1 (a int, b int, c int, d int, e int, index idx_a(a), index idx_b(b), index idx_c(c), index idx_d(d), unique key(a, b, c, d, e));

# 测试分布式事务的复制表
create table t2 (x int, y int, index idx_x(x), index idx_y(y), primary key(x, y)) partition by hash(y % 2) partitions 2;

# 获取tid
let $tid1=deploy_get_value(ob1.select select table_id from __all_virtual_table where table_name='t1', table_id, 1);
let $tid2=deploy_get_value(ob1.select select table_id from __all_virtual_table where table_name='t2', table_id, 1);

# 转储前插入数据
connection conn1;
insert into t1 value(0, 0, 0, 0, 0);
insert into t2 value(0, 0);

# ===================== 1.备机转储后切主读取数据 =====================
# 先提前分布leader位置
let $tenant_id=deploy_get_value(ob1.select select tenant_id from __all_tenant where tenant_name='obtest', tenant_id, 1);
ob1.mysql alter tenant obtest set primary_zone='z1';
ob1.check_until_timeout select count(1) from oceanbase.CDB_OB_LS where tenant_id=$tenant_id and ls_id!=1, 1, 100;
let $ls_id=deploy_get_value(ob1.select select ls_id from cdb_ob_ls where tenant_id=$tenant_id and ls_id != 1, ls_id, 1);
ob1.check_until_timeout select count(1) from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id=$tenant_id and ls_id=$ls_id and SVR_IP='$ip0' and svr_port='$port0' and ROLE='LEADER', 1, 100;

# 转储前读取数据
connection conn1;
insert into t1 value(1, 0, 0, 0, 0);
begin;
insert into t1 value(1, 0, 0, 0, 1);
select * from t1;

# 转储同步日志
ob1.mysql alter system minor freeze tenant obtest server = ('$ip0:$port0');
sleep 3;

# 切主到node B
ob1.mysql alter tenant obtest set primary_zone='z2';
ob1.check_until_timeout select count(1) from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id=$tenant_id and ls_id=$ls_id and SVR_IP='$ip1' and svr_port='$port1' and ROLE='LEADER', 1, 100;

connection conn1;
insert into t1 value(1, 0, 0, 0, 2);
select * from t1;

# 转储同步日志
ob1.mysql alter system minor freeze tenant obtest server = ('$ip1:$port1');
sleep 3;

# 切主到node A
ob1.mysql alter tenant obtest set primary_zone='z1';
ob1.check_until_timeout select count(1) from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id=$tenant_id and ls_id=$ls_id and SVR_IP='$ip0' and svr_port='$port0' and ROLE='LEADER', 1, 100;

# 转储后读取数据
connection conn1;
select * from t1;
commit;

# ===================== 2.切主后读取回滚事务 =====================
# 先提前分布leader位置
ob1.mysql alter tenant obtest set primary_zone='z1';
ob1.check_until_timeout select count(1) from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id=$tenant_id and ls_id=$ls_id and SVR_IP='$ip0' and svr_port='$port0' and ROLE='LEADER', 1, 100;

connection conn1;
insert into t1 value(2, 0, 0, 0, 0);
begin;
insert into t1 value(2, 0, 0, 0, 1);

# 转储A节点同步日志
ob1.mysql alter system minor freeze tenant obtest server = ('$ip0:$port0');
sleep 10;

# 切主到node B
ob1.mysql alter tenant obtest set primary_zone='z2';
ob1.check_until_timeout select count(1) from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id=$tenant_id and ls_id=$ls_id and SVR_IP='$ip1' and svr_port='$port1' and ROLE='LEADER', 1, 100;


connection conn1;
insert into t1 value(2, 0, 0, 0, 2);
select * from t1;

# 转储B节点同步日志
ob1.mysql alter system minor freeze tenant obtest server = ('$ip1:$port1');

#回滚
connection conn1;
rollback;

# 切主到node A
ob1.mysql alter tenant obtest set primary_zone='z1';
ob1.check_until_timeout select count(1) from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id=$tenant_id and ls_id=$ls_id and SVR_IP='$ip0' and svr_port='$port0' and ROLE='LEADER', 1, 100;
# 应该读取不到数据
connection conn1;
select * from t1;

