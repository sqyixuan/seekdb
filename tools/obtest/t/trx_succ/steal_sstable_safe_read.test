# owner: handora.qc
# owner group: transaction
# description: this case is use for minor freeze uncommitted transactions of safe read

--disable_query_log
ob1=OBI(cluster=1:1,proxy_num=0,init_unit_cpu=2);

ob1.reboot;

#ob1.mysql alter system set enable_auto_leader_switch=false;
ob1.mysql alter system set debug_sync_timeout = '1000s';
ob1.mysql alter system set syslog_level='debug';

# 防止卡住转储
ob1.mysql set GLOBAL optimizer_use_sql_plan_baselines = false;
ob1.mysql set GLOBAL optimizer_capture_sql_plan_baselines = false;

# 防止卡住转储
ob1.mysql set GLOBAL optimizer_use_sql_plan_baselines = false;
ob1.mysql set GLOBAL optimizer_capture_sql_plan_baselines = false;

# 创建租户
let $cpu = 2;
let $memory = 5368709120;

ob1.mysql CREATE RESOURCE UNIT sys_unit2 MAX_CPU $cpu, MEMORY_SIZE $memory;
ob1.mysql create resource pool qc unit = 'sys_unit2', unit_num =1;
ob1.mysql create tenant mysql replica_num = 1, primary_zone='z1', resource_pool_list=('qc') set ob_tcp_invited_nodes='%';
sleep 3;

let $ip0=deploy_get_value(ob1.z1.obs0.ip);
let $port0=deploy_get_value(ob1.z1.obs0.port);
let $sql_port0=deploy_get_value(ob1.z1.obs0.mysql_port);
let $ip1=deploy_get_value(ob1.z2.obs0.ip);
let $port1=deploy_get_value(ob1.z2.obs0.port);
let $sql_port1=deploy_get_value(ob1.z2.obs0.mysql_port);

connect(conn_sys,$ip0,root@sys,,oceanbase,$sql_port0);
connect(conn1,$ip0,root@mysql,,test,$sql_port0);
connect(conn2,$ip1,root@mysql,,test,$sql_port0);

connection conn_sys;
set optimizer_use_sql_plan_baselines = false;
set optimizer_capture_sql_plan_baselines = false;
set SESSION ob_query_timeout = 10000000000;
set SESSION ob_trx_timeout = 10000000000;
set SESSION ob_trx_idle_timeout = 10000000000;
connection conn1;
set optimizer_use_sql_plan_baselines = false;
set optimizer_capture_sql_plan_baselines = false;
set SESSION ob_query_timeout = 10000000000;
set SESSION ob_trx_timeout = 10000000000;
set SESSION ob_trx_idle_timeout = 10000000000;
connection conn2;
set optimizer_use_sql_plan_baselines = false;
set optimizer_capture_sql_plan_baselines = false;
set SESSION ob_query_timeout = 10000000000;
set SESSION ob_trx_timeout = 10000000000;
set SESSION ob_trx_idle_timeout = 10000000000;

connection conn1;
create table t1 (x int);

# 获取tid
let $tid1=deploy_get_value(ob1.select select tablet_id from __all_virtual_table where table_name='t1', tablet_id, 1);

connection conn1;
insert into t1 value(1);
insert into t1 value(2);
begin;
delete from t1 where x = 1;

connection conn_sys;
alter system minor freeze tenant = sys;
alter system minor freeze tenant = all_user;
alter system minor freeze tenant = all_meta;

ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table_mgr where tablet_id=$tid1 and table_type=0 and is_active='NO', 0, 300;
let $tenant_id=deploy_get_value(ob1.select select tenant_id from __all_tenant where tenant_name='mysql', tenant_id, 1);
let $ls_id=deploy_get_value(ob1.select select ls_id from cdb_ob_ls where tenant_id=$tenant_id and ls_id != 1, ls_id, 1);
ob1.check_until_timeout select count(1) from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id=$tenant_id and ls_id=$ls_id and SVR_IP='$ip0' and svr_port='$port0' and ROLE='LEADER', 1, 30;
ob1.mysql alter tenant mysql set primary_zone='z2';
ob1.check_until_timeout select count(1) from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id=$tenant_id and ls_id=$ls_id and SVR_IP='$ip1' and svr_port='$port1' and ROLE='LEADER', 1, 100;

connection conn2;
delete from t1 where x = 2;

connection conn_sys;
alter system minor freeze tenant = sys;
alter system minor freeze tenant = all_user;
alter system minor freeze tenant = all_meta;
sleep 5;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table_mgr where tablet_id=$tid1 and table_type=0 and is_active='NO', 0, 300;
