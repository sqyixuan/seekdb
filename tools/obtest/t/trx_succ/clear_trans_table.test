# owner: yanyuan.cxf
# owner group: transaction
# description: 清理事务上下文测试

--disable_query_log
ob1=OBI(cluster=1:1, proxy_num=0, init_unit_cpu=2);
ob1.reboot;

ob1.mysql alter system set debug_sync_timeout = '1000s';
#ob1.mysql alter system set syslog_level='debug';

let $ip0=deploy_get_value(ob1.z1.obs0.ip);
let $port0=deploy_get_value(ob1.z1.obs0.port);
let $sql_port0=deploy_get_value(ob1.z1.obs0.mysql_port);
let $ip1=deploy_get_value(ob1.z2.obs0.ip);
let $port1=deploy_get_value(ob1.z2.obs0.port);
let $sql_port1=deploy_get_value(ob1.z2.obs0.mysql_port);

connect(conn0,$ip0,root@sys,,oceanbase,$sql_port0);
connect(conn_obtest,$ip0,root@obtest,,test,$sql_port0);

connection conn_obtest;
set global ob_query_timeout = 100000000000;
set global ob_trx_timeout = 100000000000;
sleep 2;

let $tenant_id=deploy_get_value(ob1.select select tenant_id from __all_tenant where tenant_name='obtest', tenant_id, 1);
ob1.mysql alter tenant obtest set primary_zone='z1';
ob1.check_until_timeout select count(1) from oceanbase.CDB_OB_LS where tenant_id=$tenant_id and ls_id!=1, 1, 100;
let $ls_id=deploy_get_value(ob1.select select ls_id from cdb_ob_ls where tenant_id=$tenant_id and ls_id != 1, ls_id, 1);
ob1.check_until_timeout select count(1) from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id=$tenant_id and ls_id=$ls_id and SVR_IP='$ip0' and svr_port='$port0' and ROLE='LEADER', 1, 100;

# 测试用连接
connect(conn1,$ip0,root@obtest,,test,$sql_port0);

# 备机连接
connect(conn1_slave,$ip1,root@obtest,,test,$sql_port1);

connection conn1;
create table t1(a int primary key, b int, unique key u_idx(b));

insert into t1 (a, b) values (1, 1), (2, 2), (3, 3);


ob1.mysql alter tenant obtest set primary_zone='z2';
ob1.check_until_timeout select count(1) from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id=$tenant_id and ls_id=$ls_id and SVR_IP='$ip1' and svr_port='$port1' and ROLE='LEADER', 1, 100;
# <----------------------- 事务执行 -------------------------->

sleep 2;

connection conn1;
begin;
insert into t1 value(6, 6);
insert into t1 values(7, 7);

sleep 2;


# <----------------------- 冻结并转储 -------------------------->

connection conn0;
alter system minor freeze tenant obtest;
let $tid = deploy_get_value(ob1.select select tablet_id v from oceanbase.__all_virtual_table where table_name='t1', v, 1);
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table_mgr where tablet_id=$tid and table_type=0 and is_active='NO', 0, 200;

# <----------------------- 事务commit,事务上下文会被保留下来 -------------------------->

connection conn1;
commit;

sleep 10;

ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_trans_stat, 1, 100;

connection conn1;
insert into t1 values(10,10);

connection conn0;
alter system minor freeze tenant obtest;
let $tid = deploy_get_value(ob1.select select tablet_id v from oceanbase.__all_virtual_table where table_name='t1', v, 1);
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table_mgr where tablet_id=$tid and table_type=0 and is_active='NO', 0, 200;

connection conn1;
insert into t1 values(11,11);

connection conn0;
alter system minor freeze tenant obtest;
let $tid = deploy_get_value(ob1.select select tablet_id v from oceanbase.__all_virtual_table where table_name='t1', v, 1);
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table_mgr where tablet_id=$tid and table_type=0 and is_active='O', 0, 200;

# <----------------------- 转储多次后，脏数据会被消掉，事务上下文不需要了 -------------------------->

ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_trans_stat, 0, 100;
