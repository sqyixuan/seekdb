##############################
# owner: debin.jdb
# group: CLOG
#

ob1=OBI(cluster=1:1:1,proxy_num=0,init_unit_cpu=0,locality=HZ:HZ:SH);

ob1.reboot;

ob1.mysql alter system set max_stale_time_for_weak_consistency = '1h';
ob1.mysql alter system set enable_monotonic_weak_read = 1;
ob1.mysql alter system set resource_hard_limit=900;
ob1.mysql alter system set debug_sync_timeout = '1000s';
ob1.mysql alter system set enable_rebalance = 'false';
ob1.mysql alter system set enable_rereplication = 'false';
ob1.mysql alter system set balancer_idle_time = '10s';

# waiting for the servers to start service
sleep 10;
ob1.check_until_timeout select count(*) c from oceanbase.__all_server where start_service_time <= 0 or status = "inactive", 0, 120;

ob_connect(sys_conn, ob1.z1.obs0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);
connection sys_conn;
--disable_query_log

select zone,count(*) from __all_zone where name='status' and info = 'ACTIVE' group by zone order by zone;
select zone,count(*) from __all_server group by zone order by zone;
alter system set max_stale_time_for_weak_consistency = '1h';
alter system set balancer_idle_time = '10s';

let $cpu = 2;
let $memory = 2073741824;

################################################################
# 租户环境准备
# create tenant tt1
eval CREATE RESOURCE UNIT my_unit MAX_CPU $cpu, MEMORY_SIZE $memory;
CREATE RESOURCE POOL my_pool UNIT = 'my_unit', UNIT_NUM = 1, ZONE_LIST = ('z1', 'z2','z3');
# primary zone所在region必须要有另一个非只读zone，否则bootstrap失败
CREATE TENANT tt1 RESOURCE_POOL_LIST = ('my_pool'), locality='F@z1, F@z2, F@z3', primary_zone='z1' set ob_tcp_invited_nodes='%';

sleep 20;

ob_connect(tt1_conn, ob1.z3.obs0, root@tt1, ,test, , USE_MYSQL_CONNECTOR);
connection tt1_conn;

# 建表
# 首先创建十张表，每张100个分区
let $tbl_cnt = 10;
let $part_cnt = 100;

let $cnt =1;
while ($cnt <= $tbl_cnt)
{
  eval CREATE TABLE course_$cnt (c_id INT) PARTITION BY HASH(c_id) PARTITIONS $part_cnt;
  inc $cnt;
}

# 然后创建一张测试表
create table t1(c1 int primary key);
insert into t1 values (1), (2);
select * from t1;

connection sys_conn;

ob1.check_until_timeout select count(*) c from oceanbase.GV\$OB_LOG_STAT where in_sync = 'NO', 0, 30;

let $table_id = deploy_get_value(ob1.select select tablet_id from __all_virtual_table where table_name='t1', tablet_id, 1);

let $z1_obs0_ip = deploy_get_value(ob1.z1.obs0.ip);
let $z1_obs0_port = deploy_get_value(ob1.z1.obs0.port);
let $z2_obs0_ip = deploy_get_value(ob1.z2.obs0.ip);
let $z2_obs0_port = deploy_get_value(ob1.z2.obs0.port);
let $tenant_id=deploy_get_value(ob1.select select tenant_id from __all_tenant where tenant_name='tt1', tenant_id, 1);
let $ls_id=deploy_get_value(ob1.select select ls_id from cdb_ob_ls where tenant_id=$tenant_id and ls_id != 1, ls_id, 1);
################################################################
# CASE 1: 切主

# switch leader to z2
ob1.mysql alter tenant tt1 set primary_zone='z2';
ob1.check_until_timeout select count(1) from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id=$tenant_id and ls_id=$ls_id and SVR_IP='$z2_obs0_ip' and svr_port='$z2_obs0_port' and ROLE='LEADER', 1, 100;
# wait for switching leader finish
sleep 5;
ob1.check_until_timeout select count(*) c from oceanbase.GV\$OB_LOG_STAT where in_sync='NO', 0, 30;

# switch leader to z1
ob1.mysql alter tenant tt1 set primary_zone='z1';
ob1.check_until_timeout select count(1) from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id=$tenant_id and ls_id=$ls_id and SVR_IP='$z1_obs0_ip' and svr_port='$z1_obs0_port' and ROLE='LEADER', 1, 100;
# wait for switching leader finish
sleep 5;
ob1.check_until_timeout select count(*) c from oceanbase.GV\$OB_LOG_STAT where in_sync='NO', 0, 30;

# 验证插入数据并读取
connection tt1_conn;
insert into t1 values (3), (4);
select * from t1;

################################################################
# CASE 2: leader宕机
connection sys_conn;

# switch leader to z2
ob1.mysql alter tenant tt1 set primary_zone='z2';
ob1.check_until_timeout select count(1) from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id=$tenant_id and ls_id=$ls_id and SVR_IP='$z2_obs0_ip' and svr_port='$z2_obs0_port' and ROLE='LEADER', 1, 100;
# wait for switching leader finish
sleep 5;
ob1.check_until_timeout select count(*) c from oceanbase.GV\$OB_LOG_STAT where in_sync='NO', 0, 30;

# z2宕机
ob1.z2.obs0.stop;
sleep 20;
ob1.check_until_timeout select count(1) from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id=$tenant_id and ls_id=$ls_id and SVR_IP='$z1_obs0_ip' and svr_port='$z1_obs0_port' and ROLE='LEADER', 1, 100;
# 确认所有副本sync
ob1.check_until_timeout select count(*) c from oceanbase.GV\$OB_LOG_STAT where in_sync='NO', 0, 30;

# 验证插入数据并读取
connection tt1_conn;
insert into t1 values (5), (6);
select * from t1;

