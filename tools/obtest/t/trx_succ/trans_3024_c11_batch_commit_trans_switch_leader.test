#
# owner:shanyan.g
# owner group:transaction
# description:
# 测试点：单机多分区事务执行过程中，各种情况下的切主操作
##
ob1=OBI(cluster=1:1,proxy_num=0,init_unit_cpu=5);
ob1.reboot;
sleep 5;

#在zone1上建立连接
let $l_ip=deploy_get_value(ob1.z1.obs0.ip);
let $l_port=deploy_get_value(ob1.z1.obs0.mysql_port);
connect (conn1,$l_ip,root@obtest,,test,$l_port);
connect (conn2,$l_ip,root@sys,,oceanbase,$l_port);

connection conn1;
create table t1(id1 int, id2 int);
create table t2(id1 int, id2 int);

let $tenant_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name='obtest', tenant_id, 1);
let $ls_id0=deploy_get_value(ob1.select select ls_id  from CDB_OB_table_LOCATIONS where tenant_id=$tenant_id and ROLE='LEADER' and table_name='t1', ls_id, 1);
let $svr_ip0=deploy_get_value(ob1.select select svr_ip from CDB_OB_table_LOCATIONS where tenant_id=$tenant_id and ROLE='LEADER' and table_name='t1', svr_ip, 1);
let $svr_port0=deploy_get_value(ob1.select select svr_port from CDB_OB_table_LOCATIONS where tenant_id=$tenant_id and ROLE='LEADER' and table_name='t1', svr_port, 1);
let $leader_host0=deploy_get_value(ob1.select select concat(svr_ip,':',svr_port) as host from CDB_OB_table_LOCATIONS where tenant_id=$tenant_id and ROLE='LEADER' and table_name='t1', host, 1);

let $ls_id1=deploy_get_value(ob1.select select ls_id  from CDB_OB_table_LOCATIONS where tenant_id=$tenant_id and ROLE='LEADER' and table_name='t2', ls_id, 1);
let $svr_ip1=deploy_get_value(ob1.select select svr_ip from CDB_OB_table_LOCATIONS where tenant_id=$tenant_id and ROLE='LEADER' and table_name='t2', svr_ip, 1);
let $svr_port1=deploy_get_value(ob1.select select svr_port from CDB_OB_table_LOCATIONS where tenant_id=$tenant_id and ROLE='LEADER' and table_name='t2', svr_port, 1);
let $leader_host1=deploy_get_value(ob1.select select concat(svr_ip,':',svr_port) as host from CDB_OB_table_LOCATIONS where tenant_id=$tenant_id and ROLE='LEADER' and table_name='t2', host, 1);
####################################
#case 1 :正常执行
connection conn1;
set autocommit=0;
insert into t1 values(1,1);
insert into t2 values(2,2);
commit;
#校验数据
select * from t1;
select * from t2;

####################################
#case 2 : commit之前，其中一个参与者切主
connection conn1;
set autocommit=0;
insert into t1 values(1,1);
insert into t2 values(2,2);

connection conn2;

eval alter system switch replica leader ls=$ls_id0 server='$leader_host1' tenant='obtest';
ob1.check_until_timeout select count(1) from CDB_OB_table_LOCATIONS where tenant_id=$tenant_id  and ROLE='LEADER' and table_name='t1' and svr_ip='$svr_ip1' and svr_port='$svr_port1', 1, 100;
sleep 10;

connection conn1;
#预热下location cache，避免事务提交时出现未决得情况
select * from t1;
select * from t2;
commit;
#校验数据
select * from t1;
select * from t2;

####################################
#case 3 : commit之前，其中一个参与者切主，又切回
connection conn1;
set autocommit=0;
insert into t1 values(1,1);
insert into t2 values(2,2);

connection conn2;
eval alter system switch replica leader ls=$ls_id0 server='$leader_host0' tenant='obtest';
ob1.check_until_timeout select count(1) from CDB_OB_table_LOCATIONS where tenant_id=$tenant_id  and ROLE='LEADER' and table_name='t1' and svr_ip='$svr_ip0' and svr_port='$svr_port0', 1, 100;
sleep 10;
eval alter system switch replica leader ls=$ls_id0 server='$leader_host1' tenant='obtest';
ob1.check_until_timeout select count(1) from CDB_OB_table_LOCATIONS where tenant_id=$tenant_id  and ROLE='LEADER' and table_name='t1' and svr_ip='$svr_ip1' and svr_port='$svr_port1', 1, 100;
sleep 10;

connection conn1;
#预热下location cache，避免事务提交时出现未决得情况
select * from t1;
select * from t2;
commit;
#校验数据
select * from t1;
select * from t2;

####################################
#case 4 : commit之前，其中一个参与者切主，又切回，再执行语句
connection conn1;
set autocommit=0;
insert into t1 values(1,1);
insert into t2 values(2,2);

connection conn2;
eval alter system switch replica leader ls=$ls_id0 server='$leader_host0' tenant='obtest';
ob1.check_until_timeout select count(1) from CDB_OB_table_LOCATIONS where tenant_id=$tenant_id  and ROLE='LEADER' and table_name='t1' and svr_ip='$svr_ip0' and svr_port='$svr_port0', 1, 100;
sleep 10;
eval alter system switch replica leader ls=$ls_id0 server='$leader_host1' tenant='obtest';
ob1.check_until_timeout select count(1) from CDB_OB_table_LOCATIONS where tenant_id=$tenant_id  and ROLE='LEADER' and table_name='t1' and svr_ip='$svr_ip1' and svr_port='$svr_port1', 1, 100;
sleep 10;

connection conn1;
#预热下location cache，避免事务提交时出现未决得情况
select * from t1;
select * from t2;
insert into t1 values(3,3);
insert into t2 values(4,4);
commit;
#校验数据
select * from t1;
select * from t2;

####################################
#case 4 : commit之前，所有参与者切主
connection conn1;
set autocommit=0;
insert into t1 values(1,1);
insert into t2 values(2,2);

connection conn2;
eval alter system switch replica leader ls=$ls_id0 server='$leader_host0' tenant='obtest';
ob1.check_until_timeout select count(1) from CDB_OB_table_LOCATIONS where tenant_id=$tenant_id  and ROLE='LEADER' and table_name='t1' and svr_ip='$svr_ip0' and svr_port='$svr_port0', 1, 100;

eval alter system switch replica leader ls=$ls_id1 server='$leader_host0' tenant='obtest';
ob1.check_until_timeout select count(1) from CDB_OB_table_LOCATIONS where tenant_id=$tenant_id  and ROLE='LEADER' and table_name='t2' and svr_ip='$svr_ip0' and svr_port='$svr_port0', 1, 100;
sleep 10;

connection conn1;
#预热下location cache，避免事务提交时出现未决得情况
select * from t1;
select * from t2;
commit;
#校验数据
select * from t1;
select * from t2;

####################################
#case 5 : commit之前，所有参与者切主，又切回
connection conn1;
set autocommit=0;
insert into t1 values(1,1);
insert into t2 values(2,2);

connection conn2;
eval alter system switch replica leader ls=$ls_id0 server='$leader_host1' tenant='obtest';
ob1.check_until_timeout select count(1) from CDB_OB_table_LOCATIONS where tenant_id=$tenant_id  and ROLE='LEADER' and table_name='t1' and svr_ip='$svr_ip1' and svr_port='$svr_port1', 1, 100;

eval alter system switch replica leader ls=$ls_id1 server='$leader_host1' tenant='obtest';
ob1.check_until_timeout select count(1) from CDB_OB_table_LOCATIONS where tenant_id=$tenant_id  and ROLE='LEADER' and table_name='t2' and svr_ip='$svr_ip1' and svr_port='$svr_port1', 1, 100;

sleep 10;
eval alter system switch replica leader ls=$ls_id0 server='$leader_host0' tenant='obtest';
ob1.check_until_timeout select count(1) from CDB_OB_table_LOCATIONS where tenant_id=$tenant_id  and ROLE='LEADER' and table_name='t1' and svr_ip='$svr_ip0' and svr_port='$svr_port0', 1, 100;

eval alter system switch replica leader ls=$ls_id1 server='$leader_host0' tenant='obtest';
ob1.check_until_timeout select count(1) from CDB_OB_table_LOCATIONS where tenant_id=$tenant_id  and ROLE='LEADER' and table_name='t2' and svr_ip='$svr_ip0' and svr_port='$svr_port0', 1, 100;
sleep 10;

connection conn1;
insert into t1 values(3,3);
insert into t2 values(4,4);
commit;
#校验数据
select * from t1;
select * from t2;

drop table t1;
drop table t2;
