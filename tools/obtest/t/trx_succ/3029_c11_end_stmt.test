#owner: shanyan.g 
#owner group: transaction
# 测试点：测试语句回滚场景下，事务的执行情况
##
ob1=OBI(cluster=1:1,proxy_num=0,init_unit_cpu=5);
ob1.reboot;
sleep 5;

#在zone1上建立连接
let $l_ip=deploy_get_value(ob1.z1.obs0.ip);
let $l_port=deploy_get_value(ob1.z1.obs0.mysql_port);
connect (conn1,$l_ip,root@obtest,,oceanbase,$l_port);
connect (conn2,$l_ip,root@sys,,oceanbase,$l_port);

connection conn1;
use test;
## case:检查表结构
create table test01(pk int primary key, c1 int) partition by hash(pk % 2) partitions 2;
create table test02(pk int primary key, c1 int) partition by hash(pk % 2) partitions 2;

let $tenant_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name='obtest', tenant_id, 1);
let $ls_id0_p0=deploy_get_value(ob1.select select ls_id  from CDB_OB_table_LOCATIONS where tenant_id=$tenant_id and ROLE='LEADER' and table_name='test01' and partition_name='p0', ls_id, 1);
let $svr_ip0_p0=deploy_get_value(ob1.select select svr_ip from CDB_OB_table_LOCATIONS where tenant_id=$tenant_id and ROLE='LEADER' and table_name='test01' and partition_name='p0', svr_ip, 1);
let $svr_port0_p0=deploy_get_value(ob1.select select svr_port from CDB_OB_table_LOCATIONS where tenant_id=$tenant_id and ROLE='LEADER' and table_name='test01' and partition_name='p0', svr_port, 1);
let $leader_host0_p0=deploy_get_value(ob1.select select concat(svr_ip,':',svr_port) as host from CDB_OB_table_LOCATIONS where tenant_id=$tenant_id and ROLE='LEADER' and table_name='test01' and partition_name='p0', host, 1);

let $ls_id0_p1=deploy_get_value(ob1.select select ls_id  from CDB_OB_table_LOCATIONS where tenant_id=$tenant_id and ROLE='LEADER' and table_name='test01' and partition_name='p1', ls_id, 1);
let $svr_ip0_p1=deploy_get_value(ob1.select select svr_ip from CDB_OB_table_LOCATIONS where tenant_id=$tenant_id and ROLE='LEADER' and table_name='test01' and partition_name='p1', svr_ip, 1);
let $svr_port0_p1=deploy_get_value(ob1.select select svr_port from CDB_OB_table_LOCATIONS where tenant_id=$tenant_id and ROLE='LEADER' and table_name='test01' and partition_name='p1', svr_port, 1);
let $leader_host0_p1=deploy_get_value(ob1.select select concat(svr_ip,':',svr_port) as host from CDB_OB_table_LOCATIONS where tenant_id=$tenant_id and ROLE='LEADER' and table_name='test01' and partition_name='p1', host, 1);

let $ls_id1_p0=deploy_get_value(ob1.select select ls_id  from CDB_OB_table_LOCATIONS where tenant_id=$tenant_id and ROLE='LEADER' and table_name='test02' and partition_name='p0', ls_id, 1);
let $svr_ip1_p0=deploy_get_value(ob1.select select svr_ip from CDB_OB_table_LOCATIONS where tenant_id=$tenant_id and ROLE='LEADER' and table_name='test02' and partition_name='p0', svr_ip, 1);
let $svr_port1_p0=deploy_get_value(ob1.select select svr_port from CDB_OB_table_LOCATIONS where tenant_id=$tenant_id and ROLE='LEADER' and table_name='test02' and partition_name='p0', svr_port, 1);
let $leader_host1_p0=deploy_get_value(ob1.select select concat(svr_ip,':',svr_port) as host from CDB_OB_table_LOCATIONS where tenant_id=$tenant_id and ROLE='LEADER' and table_name='test02' and partition_name='p0', host, 1);

let $ls_id1_p1=deploy_get_value(ob1.select select ls_id  from CDB_OB_table_LOCATIONS where tenant_id=$tenant_id and ROLE='LEADER' and table_name='test02' and partition_name='p1', ls_id, 1);
let $svr_ip1_p1=deploy_get_value(ob1.select select svr_ip from CDB_OB_table_LOCATIONS where tenant_id=$tenant_id and ROLE='LEADER' and table_name='test02' and partition_name='p1', svr_ip, 1);
let $svr_port1_p1=deploy_get_value(ob1.select select svr_port from CDB_OB_table_LOCATIONS where tenant_id=$tenant_id and ROLE='LEADER' and table_name='test02' and partition_name='p1', svr_port, 1);
let $leader_host1_p1=deploy_get_value(ob1.select select concat(svr_ip,':',svr_port) as host from CDB_OB_table_LOCATIONS where tenant_id=$tenant_id and ROLE='LEADER' and table_name='test02' and partition_name='p1', host, 1);


insert into test01 values(1,1);
insert into test01 values(2,2);
insert into test01 values(3,3);
insert into test01 values(4,4);

insert into test02 values(1,1);
insert into test02 values(2,2);
insert into test02 values(3,3);
insert into test02 values(4,4);

ob1.mysql alter system set syslog_level="DEBUG";
#case1 : partition在单机
--error 1062
insert into test01 values(2,2);

#case2 : ac=1的remote类型的事务
--error 1062
insert into test01 values(1,2);
sleep 1;
ob1.mysql select count(1) from oceanbase.__all_virtual_trans_stat;

#case3 : 多条语句持续回滚的场景，每次回滚context都会立即释放
begin;
select * from test02 where pk=1;
#远程计划
--error 1062
insert into test01 values(1,1);
#本机计划
--error 1062
insert into test02 values(2,2);
commit;
sleep 1;
ob1.mysql select count(1) from oceanbase.__all_virtual_trans_stat;

#case4 : 分布式事务，语句出现回滚
begin;
select * from test02 where pk=1;
#访问p1
select * from test01 where pk=1;
#访问p0，出现主键冲突，语句回滚
--error 1062
insert into test01 values(1,1), (2,2), (3,3),(4,4);
commit;
sleep 1;
ob1.mysql select count(1) from oceanbase.__all_virtual_trans_stat;

connection conn2;
eval alter system switch replica leader ls=$ls_id0_p0 server='$leader_host0_p1' tenant='obtest';
ob1.check_until_timeout select count(1) from CDB_OB_table_LOCATIONS where tenant_id=$tenant_id  and ROLE='LEADER' and table_name='test01' and svr_ip='$svr_ip0_p1' and svr_port='$svr_port0_p1' and partition_name='p0', 1, 100;
eval alter system switch replica leader ls=$ls_id0_p1 server='$leader_host0_p0' tenant='obtest';
ob1.check_until_timeout select count(1) from CDB_OB_table_LOCATIONS where tenant_id=$tenant_id  and ROLE='LEADER' and table_name='test01' and svr_ip='$svr_ip0_p0' and svr_port='$svr_port0_p0' and partition_name='p1', 1, 100;
eval alter system switch replica leader ls=$ls_id1_p0 server='$leader_host1_p1' tenant='obtest';
ob1.check_until_timeout select count(1) from CDB_OB_table_LOCATIONS where tenant_id=$tenant_id  and ROLE='LEADER' and table_name='test02' and svr_ip='$svr_ip1_p1' and svr_port='$svr_port1_p1' and partition_name='p0', 1, 100;
eval alter system switch replica leader ls=$ls_id0_p1 server='$leader_host1_p0' tenant='obtest';
ob1.check_until_timeout select count(1) from CDB_OB_table_LOCATIONS where tenant_id=$tenant_id  and ROLE='LEADER' and table_name='test02' and svr_ip='$svr_ip1_p0' and svr_port='$svr_port1_p0' and partition_name='p1', 1, 100;
sleep 10;

#case5 : 由于location cache的问题，第一次查询语句会出现重试；
connection conn1;
begin;
select * from test01 where pk=1;
select * from test02 where pk=1;
commit;
ob1.mysql select count(1) from oceanbase.__all_virtual_trans_stat;

#case6 : 只读事务发生切主
begin;
select * from test01 where pk=1 union select * from test02 where pk=1;

#切主操作
connection conn2;
eval alter system switch replica leader ls=$ls_id0_p0 server='$leader_host0_p0' tenant='obtest';
ob1.check_until_timeout select count(1) from CDB_OB_table_LOCATIONS where tenant_id=$tenant_id  and ROLE='LEADER' and table_name='test01' and svr_ip='$svr_ip0_p0' and svr_port='$svr_port0_p0' and partition_name='p0', 1, 100;
eval alter system switch replica leader ls=$ls_id0_p1 server='$leader_host0_p1' tenant='obtest';
ob1.check_until_timeout select count(1) from CDB_OB_table_LOCATIONS where tenant_id=$tenant_id  and ROLE='LEADER' and table_name='test01' and svr_ip='$svr_ip0_p1' and svr_port='$svr_port0_p1' and partition_name='p1', 1, 100;
sleep 10;

connection conn1;
select * from test01 where pk=1 union select * from test02 where pk=1;
commit;
ob1.mysql alter system set syslog_level="INFO";

drop table test01;
drop table test02;
