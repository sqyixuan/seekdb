# 10.3.2 验证 variables表可读
connect (conn_sys_z1,$ipz1,root,,oceanbase,$portz1);
connect (conn_sys_z2,$ipz2,root,,oceanbase,$portz2);
connect (conn_sys_z3,$ipz3,root,,oceanbase,$portz3);
--disable_query_log
--disable_result_log
let $i=0;
while($i<16)
{
    connection conn_sys_z1;
    eval select count(*) from __all_sys_variable partition(p$i);
    eval select count(*) from __all_tablegroup partition(p$i);
    connection conn_sys_z2;
    eval select count(*) from __all_sys_variable partition(p$i);
    eval select count(*) from __all_tablegroup partition(p$i);
    connection conn_sys_z3;
    eval select count(*) from __all_sys_variable partition(p$i);
    eval select count(*) from __all_tablegroup partition(p$i);
    inc $i;
}
--enable_query_log
--enable_result_log
#ob1.check_until_timeout select count(*) > 0  from oceanbase.__all_sys_variable,1,60;

# 11. 执行升级后SQL
connection conn_sys;
set @@session.ob_query_timeout = 60000000;
alter system upgrade virtual schema;
sleep 5;
ob1.upgrade_commond_for_server post;
sleep 5;
ob1.mysql alter system end upgrade;
sleep 5;
ob1.mysql alter system run job 'root_inspection';
sleep 5;
ob1.upgrade_check_after;

# 12. 升级后检查schema
# 12.1
#ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_upgrade_inspection where info != "succeed", 0, 300;
#ob1.check_until_timeout select sum(value="2.2.0") from oceanbase.__all_virtual_sys_parameter_stat where name='min_observer_version', 3, 30;
# 12.2 校验拆分后的表可以查询
connect (conn_obtest,$ip,root@obtest,,*NO-ONE*,$port);
desc oceanbase.__all_sequence_v2;
desc oceanbase.__all_tenant_meta_table;
desc oceanbase.__all_tenant_gc_partition_info;
select count(*)>0 from oceanbase.__all_sequence_v2;
select count(*)>0 from oceanbase.__all_tenant_meta_table;
select count(*)>0 from oceanbase.__all_tenant_gc_partition_info;
# 12.3 检查删除的索引是否补齐了data_table_id
ob1.mysql_p select 1 from oceanbase.__all_virtual_table_history where is_deleted = 1 and data_table_id = (select distinct table_id from oceanbase.__all_virtual_table_history where table_name = 'tb_table_drop');

# 13. 升级后检查
# 13.1 查询数据
connect (conn_obtest_z1,$ipz1,root@obtest,,db1,$portz1);
# bugId: 
select pk1,pk2,gen_c1,gen_c2 from test.tb_table_gencol order by pk1,pk2 limit 10;
select * from test.table_hash where c1 = 1;
select * from test.table_range where c1 = 1;
select * from test.table_hash_range where c1 = 1;
select * from test.table_range_hash where c1 = 1;
# bugId: 
show index from test.tb_table_fulltext;
show create table test.tb_table_fulltext;
show create table test.tablegencol;
# 检验旧tablegroup的table能转移到新tablegroup中
create tablegroup tg_new partition by hash partitions 2;
let $tablegroup_id = deploy_get_value(ob1.select select tablegroup_id from oceanbase.__all_virtual_tablegroup where tablegroup_name = "tg_new", tablegroup_id, 1);
alter table test.table_with_tg set tablegroup = "";
alter table test.table_with_tg set tablegroup = "tg_new";
ob1.check_until_timeout select count(1) from oceanbase.__all_virtual_table where table_name = "table_with_tg" and tablegroup_id = "$tablegroup_id", 1, 5;
select * from test.tb_simple;
# 13.2 首先检查日志是同步状态,然后合并
ob1.check_until_timeout SELECT CAST(COUNT(*) AS SIGNED) as cnt FROM __all_virtual_clog_stat WHERE is_in_sync = 0 and is_offline=0,0,600;
ob1.mysql alter system major freeze;
sleep 60;
ob1.check_version 3;
ob1.check_until_timeout select info from __all_zone where zone='' and name='merge_status',IDLE,30;

#13.3 写入数据
connect (conn_obtest_z1,$ipz1,root@obtest,,db1,$portz1);
set autocommit=0;
insert into db1.tb_normal(pk,c1) values(901,'901'),(902,'902'),(903,'903'),(904,'904');
update db1.tb_normal set c1=concat(c1,'_x') where pk > 100;
delete from db1.tb_normal where pk=904;
update db1.tb_increment set pk=pk+1 order by pk desc limit 1;
insert into db1.tb_increment(pk,c1) values (901,901),(902,902);
replace into db1.tb_increment(pk,c1) values (901,902);
delete from db1.tb_increment where pk=902;
commit;
set autocommit=1;

#13.4 临时表
create temporary table test.tb_temp(c1 int, c2 int, c3 int);
show create table test.tb_temp;

#13.5 重启
ob1.force_stop;
sleep 5;
ob1.nstart;
sleep 30;
ob1.check_until_timeout select count(1) from __all_virtual_core_meta_table where role=1 and zone='z1',1,600;
ob1.check_until_timeout SELECT CAST(COUNT(*) AS SIGNED) as cnt FROM __all_virtual_clog_stat WHERE is_in_sync = 0 and is_offline=0,0,600;
ob1.mysql alter system major freeze;
sleep 60;
ob1.check_version 4;

# 14.case最后验证liboblog
source include/liboblog/compat/oblog_after_upgrade.inc;

# 15. 部署备库
# 升级之后执行至少三次major freeze，才能接入备库
ob1.mysql alter system major freeze;
ob1.mysql alter system major freeze;
sleep 60;
ob1.check_version 6;
ob2.reboot;
sleep 20;

# 修改配置项
ob2.mysql alter system set balancer_idle_time='10s';
ob2.mysql alter system set merger_check_interval='10s';
ob2.mysql alter system set resource_soft_limit=200;
ob2.mysql alter system set resource_hard_limit=200;

let $ob1_ip=deploy_get_value(ob1.z1.obs0.ip);
let $ob1_port=deploy_get_value(ob1.z1.obs0.mysql_port);
let $ob2_ip=deploy_get_value(ob2.z1.obs0.ip);
let $ob2_port=deploy_get_value(ob2.z1.obs0.mysql_port);
connect (conn_ob1_sys,$ob1_ip,root@sys,,oceanbase,$ob1_port);
connect (conn_ob2_sys,$ob2_ip,root@sys,,oceanbase,$ob2_port);

# 15.1. 等待备库同步成功
ob1.check_until_timeout_for_obs select switchover_status from oceanbase.v\$ob_cluster,TO STANDBY,600;
connection conn_ob1_sys;
select  switchover_status, switchover_info, cluster_role, cluster_id, cluster_status from v$ob_cluster;
connection conn_ob2_sys;
select  switchover_status, switchover_info, cluster_role, cluster_id, cluster_status from v$ob_cluster;

# 15.2 ob1 switchover to ob2
sleep 5;
ob1..check_until_timeout_for_obs select switchover_status from oceanbase.v\$ob_cluster,TO STANDBY,600;
ob1.z1.obs0.mysql alter system commit to switchover to physical standby;
ob2.check_until_timeout_for_obs select switchover_status from oceanbase.v\$ob_cluster,TO PRIMARY,600;
ob2.z1.obs0.mysql alter system commit to switchover to primary;

# 15.3 ob2 switchover to ob1
sleep 5;
ob2.check_until_timeout_for_obs select switchover_status from oceanbase.v\$ob_cluster,TO STANDBY,600;
ob2.z1.obs0.mysql alter system commit to switchover to physical standby;
ob1.check_until_timeout_for_obs select switchover_status from oceanbase.v\$ob_cluster,TO PRIMARY,600;
ob1.z1.obs0.mysql alter system commit to switchover to primary;

# 15.4 ob1 switchover to ob2
sleep 5;
ob1.check_until_timeout_for_obs select switchover_status from oceanbase.v\$ob_cluster,TO STANDBY,600;
ob1.z1.obs0.mysql alter system commit to switchover to physical standby;
ob2.check_until_timeout_for_obs select switchover_status from oceanbase.v\$ob_cluster,TO PRIMARY,600;
ob2.z1.obs0.mysql alter system commit to switchover to primary;

# 15.5 ob2 switchover to ob1
sleep 5;
ob2.check_until_timeout_for_obs select switchover_status from oceanbase.v\$ob_cluster,TO STANDBY,600;
ob2.z1.obs0.mysql alter system commit to switchover to physical standby;
ob1.check_until_timeout_for_obs select switchover_status from oceanbase.v\$ob_cluster,TO PRIMARY,600;
ob1.z1.obs0.mysql alter system commit to switchover to primary;

# 15.6 打印最后各个库状态
ob1.check_until_timeout_for_obs select switchover_status from oceanbase.v\$ob_cluster,TO STANDBY,600;
connection conn_ob1_sys;
select  switchover_status, switchover_info, cluster_role, cluster_id, cluster_status from v$ob_cluster;
connection conn_ob2_sys;
select  switchover_status, switchover_info, cluster_role, cluster_id, cluster_status from v$ob_cluster;
