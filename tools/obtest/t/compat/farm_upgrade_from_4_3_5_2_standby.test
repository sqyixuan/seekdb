connection conn_mysql_z2;
set autocommit=0;
insert into db1.tb_normal(pk,c1) values(301,'301'),(302,'302'),(303,'303'),(304,'304');
update db1.tb_normal set c1=concat(c1,'_x') where pk > 100;
delete from db1.tb_normal where pk=304;
update db1.tb_increment set pk=pk+1 order by pk desc limit 1;
insert into db1.tb_increment(pk,c1) values (301,301),(302,302);
replace into db1.tb_increment(pk,c1) values (301,302);
delete from db1.tb_increment where pk=302;
commit;
set autocommit=1;
select pk,c1 from db1.tb_normal order by pk;
select pk,c1 from db1.tb_increment order by pk limit 1;
select a.pk,a.c1,b.c1 from db1.tb_normal a join db1.tb_increment b where a.pk=b.pk order by a.pk limit 2;
show tables like 'tb_normal';
show create table db1.tb_increment;
use db1;
select /*+index(global_t6 primary)*/ * from global_t6;
