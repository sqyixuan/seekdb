update db1.tb_increment set pk=pk+1 order by pk desc limit 1;
insert into db1.tb_increment(pk,c1) values (801,801),(802,802);
replace into db1.tb_increment(pk,c1) values (801,802);
delete from db1.tb_increment where pk=802;
commit;
set autocommit=1;



