update global_t6 set b=19 where b=1;
select /*+index(global_t6 gkey)*/ a, b from global_t6;
update global_t6 set c=100 where b>=10;
select /*+index(global_t6 gkey)*/ a, b from global_t6;
delete from global_t6 where a=1;
select /*+index(global_t6 gkey)*/ a, b from global_t6;
delete from global_t6 where a=2 or a=3;
select /*+index(global_t6 gkey)*/ a, b from global_t6;
delete from global_t6 where b>=100;
select /*+index(global_t6 gkey)*/ a, b from global_t6;
delete from global_t6;
select /*+index(global_t6 primary)*/ * from global_t6;
insert into global_t6 values(1, 1, 1), (5, 6, 2), (4, 2, 1);
--sleep 1
select /*+index(global_t6 primary)*/ * from global_t6;
delete from global_t6 where b < 7 and b >1;
select /*+index(global_t6 gkey)*/ a, b from global_t6;
select /*+index(global_t6 primary)*/ a, b, c from global_t6;
insert into global_t6 values(2, 2, 2), (3, 3, 3), (4, 4, 4) on duplicate key update b=b+1;
select /*+index(global_t6 gkey)*/ a, b from global_t6;
select /*+index(global_t6 primary)*/ a, b, c from global_t6;
insert into global_t6 values(2, 2, 2), (3, 3, 3), (4, 4, 4) on duplicate key update b=b+1;
select /*+index(global_t6 gkey)*/ a, b from global_t6;
select /*+index(global_t6 primary)*/ a, b, c from global_t6;
replace into global_t6 values(2, 2, 2), (3, 3, 3), (4, 4, 4);
select /*+index(global_t6 gkey)*/ a, b from global_t6;
select /*+index(global_t6 primary)*/ a, b, c from global_t6;

