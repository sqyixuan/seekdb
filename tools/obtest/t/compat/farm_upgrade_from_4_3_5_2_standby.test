# 8.2.4 转储
ob1.mysql alter system minor freeze tenant = all;
connection conn_mysql_z1;
set autocommit=0;
insert into db1.tb_normal(pk,c1) values(601,'601'),(602,'602'),(603,'603'),(604,'604');
update db1.tb_normal set c1=concat(c1,'_x') where pk > 100;
delete from db1.tb_normal where pk=604;
update db1.tb_increment set pk=pk+1 order by pk desc limit 1;
insert into db1.tb_increment(pk,c1) values (601,601),(602,602);
replace into db1.tb_increment(pk,c1) values (601,602);
delete from db1.tb_increment where pk=602;
commit;
set autocommit=1;

ob1.mysql alter system start server '$server1_ip:$server1_port';

source t/compat/include_for_obtest/check_schema_sync.inc;

ob1.mysql alter system set server_permanent_offline_time = '20s';
ob1.z2.obs0.force_stop;
let $z2_ip0 = deploy_get_value(ob1.z2.obs0.ip);
let $z2_port0 = deploy_get_value(ob1.z2.obs0.port);
ob1.check_until_timeout select count(*) from __all_server where status = 'INACTIVE' and svr_ip = '$z2_ip0'and svr_port = $z2_port0, 1, 120;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_ls_meta_table where role = 1 and member_list like '%$z2_ip0:$z2_port0%', 0, 120;
ob1.mysql alter system set server_permanent_offline_time = '3600s';

ob1.z2.obs0.nstart;
ob1.check_until_timeout select count(*) from oceanbase.__all_server where zone = 'z2' and (start_service_time <= 0 or status='INACTIVE'),0,120;

ob1.check_until_timeout select count(*) > 0 from oceanbase.__all_rootservice_event_history where event like '%finish_add%' and value6 like '%ret:0%',1,120;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_ls_replica_task,0,120;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_ls_meta_table where role = 1 and member_list not like '%$z2_ip0:$z2_port0%', 0, 120;

let $leader_count = query_get_value(select count(1) as cnt from oceanbase.__all_virtual_ls_meta_table where role = 1, cnt, 1);
let $zone2_ls_count = query_get_value(select count(1) as cnt from oceanbase.__all_virtual_ls_meta_table where svr_ip = '$z2_ip0' and svr_port = $z2_port0, cnt, 1);

if($leader_count != $zone2_ls_count)
{
  --exit 
}


