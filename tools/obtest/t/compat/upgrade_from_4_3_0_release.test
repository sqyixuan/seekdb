let $z2_unitport=deploy_get_value(obdocker.select select svr_port from __all_server where zone="z2" and svr_port!=(select svr_port from  DBA_OB_UNITS where TENANT_ID = $mysql_tenant_id and ZONE="z2"),svr_port,1);
if ($z2_unitport==$z2_obs0port)
{
obdocker.z2.obs1.force_stop;
}
if ($z2_unitport==$z2_obs1port)
{
obdocker.z2.obs0.force_stop;
}
obdocker.check_until_timeout select SVR_PORT from DBA_OB_UNITS where zone="z2" and UNIT_ID=$z2_unitid,$z2_unitport,180;
obdocker.check_until_timeout select count(*) from  DBA_OB_UNITS where TENANT_ID =$mysql_tenant_id and ZONE="z2" and MIGRATE_FROM_SVR_IP IS NULL and MIGRATE_FROM_SVR_PORT IS NULL and MANUAL_MIGRATE IS NULL,1,120;
if ($z2_unitport==$z2_obs0port)
{
obdocker.z2.obs1.nstart;
}
if ($z2_unitport==$z2_obs1port)
{
obdocker.z2.obs0.nstart;
}
obdocker.check_until_timeout select count(*) from __all_server where STATUS="INACTIVE",0,300;
alter system set server_permanent_offline_time = "3600s";

obdocker.check_until_timeout select count(*) from dba_ob_unit_jobs where job_status!="success",0,600;
obdocker.check_until_timeout select count(*) from dba_ob_server_jobs where job_status!="success",0,600;

#2.3.5、扩缩容
connection proxy_conn;
eval ALTER RESOURCE UNIT $unit1name MAX_CPU 2, MEMORY_SIZE '6G';
obdocker.check_until_timeout select count(*) FROM oceanbase.DBA_OB_UNIT_CONFIGS WHERE NAME = "$unit1name" and MAX_CPU=2 and (MEMORY_SIZE/1073741824)=6, 1, 120;
eval ALTER RESOURCE UNIT $unit1name MAX_CPU 1, MEMORY_SIZE '3G';
obdocker.check_until_timeout select count(*) FROM oceanbase.DBA_OB_UNIT_CONFIGS WHERE NAME = "$unit1name" and MAX_CPU=1 and (MEMORY_SIZE/1073741824)=3, 1, 120;
sleep 120;
obdocker.check_until_timeout select count(*) from dba_ob_unit_jobs where job_status!="success",0,600;
obdocker.check_until_timeout select count(*) from GV\$OB_UNITS where STATUS!="NORMAL",0,1500;
eval ALTER RESOURCE TENANT $tent3name UNIT_NUM = 2;
sleep 60;
obdocker.check_until_timeout select count(*) from dba_ob_unit_jobs where job_status!="success",0,600;
obdocker.check_until_timeout select count(*) from GV\$OB_UNITS where STATUS!="NORMAL",0,1500;
obdocker.check_until_timeout select unit_count from DBA_OB_RESOURCE_POOLS where name="$pool3name",2,120;
eval ALTER RESOURCE TENANT $tent3name UNIT_NUM = 1;
sleep 60;
obdocker.check_until_timeout select count(*) from dba_ob_unit_jobs where job_status!="success",0,600;
obdocker.check_until_timeout select count(*) from GV\$OB_UNITS where STATUS!="NORMAL",0,1500;
obdocker.check_until_timeout select unit_count from DBA_OB_RESOURCE_POOLS where name="$pool3name",1,120;



##2.3.6仲裁升降级
connection proxy_conn;
let $degrade_ip=deploy_get_value(obdocker.select select distinct svr_ip from GV\$OB_LOG_STAT where tenant_id=$svr_tenant_id and SVR_IP in (select svr_ip from __all_server where zone="z2") limit 1,svr_ip,1);

obdocker.z2.force_stop;
obdocker.check_until_timeout  select count(*) from __all_virtual_log_stat where tenant_id=$svr_tenant_id and degraded_list not like "$degrade_ip%",0,180;
#
obdocker.z2.nstart;
obdocker.check_until_timeout  select count(*) from __all_virtual_log_stat where tenant_id=$svr_tenant_id and degraded_list not like "",0,180;
obdocker.check_until_timeout select count(*) from CDB_OB_MAJOR_COMPACTION where `GLOBAL_BROADCAST_SCN`!=`LAST_SCN` or STATUS!="IDLE",0,600;
source include/check_schema_sync_for_restart_obdocker.inc;
##2.3.7切换RS
connection proxy_conn;
let $rootservice_port=deploy_get_value(obdocker.select select svr_port from DBA_OB_SERVERS where WITH_ROOTSERVER="YES",svr_port,1);
let $rootservice_zone=deploy_get_value(obdocker.select select distinct zone from __all_server where zone not in ( select zone from __all_server where with_rootserver=1),zone,1);
obdocker.mysql alter tenant sys set primary_zone = "$rootservice_zone";
obdocker.check_until_timeout  select zone from DBA_OB_LS_LOCATIONS where role="leader",$rootservice_zone,120;
obdocker.check_until_timeout select count(*) from DBA_OB_SERVERS where WITH_ROOTSERVER="YES" and svr_ip = "$rootservice_port",0,120;
sleep 30;
#
#2.4z1升级
obdocker.mysql alter system stop zone 'z1';
obdocker.z1.force_stop;
obdocker.z1.upgrade;
obdocker.z1.start;
obdocker.check_until_timeout select count(*) from oceanbase.__all_server where (start_service_time is null  or status='INACTIVE'),0,300;
source include/check_schema_sync_for_restart_obdocker.inc;
obdocker.upgrade_health_checker z1;
obdocker.mysql alter system start zone 'z1';
obdocker.mysql alter tenant sys set primary_zone = "z1";
obdocker.check_until_timeout select count(*) from __all_virtual_tenant_parameter_stat where name = 'compatible' and value!="$source_version",0,1;
#破坏etc文件不影响dataversion
obdocker.z3.obs0.sh rm -rf /data/1/lisu/obdocker.z3.obs0/etc/observer.data_version*;
obdocker.check_until_timeout select count(*) from __all_virtual_tenant_parameter_stat where name = 'compatible' and value!="$source_version",0,1;

sleep 120;
#3、升级后检查
#3.1执行post脚本,还原配置项
obdocker.upgrade_health_checker;
obdocker.upgrade_commond_for_server post;
let $cnt1=1;
source t/compat/include_for_obtest/repost_obdocker.inc;
obdocker.mysql alter system set server_permanent_offline_time = "$server_permanent_offline_time";
obdocker.mysql alter system set enable_rebalance = "$enable_rebalance";
obdocker.mysql alter system set enable_rereplication = "$enable_rereplication";
obdocker.check_until_timeout select count(*) from __all_virtual_tenant_parameter_stat where name = 'compatible' and value!="$dest_version",0,1;
#增删节点检测dataversion是否正常
obdocker.z1.obs0.sh rm -rf 4_3_0_X.bak && mv  4_3_0_X 4_3_0_X.bak && mkdir -p 4_3_0_X/lib;
obdocker.z1.obs0.sh cp -r admin/ 4_3_0_X/admin/;
obdocker.z1.obs0.sh cp -r etc/ 4_3_0_X/etc;
obdocker.z1.obs0.sh cp -r bin/ 4_3_0_X/bin;
connection proxy_conn;
eval ALTER SYSTEM delete SERVER '$z3_obs0ip:$z3_obs0port'  ZONE 'z3';
obdocker.check_until_timeout select count(*) from __all_server where zone="z3",1,120;
obdocker.z3.obs0.sh ps -ef |grep observer |grep z3|grep obs0 |grep -v grep |awk '{print \$2}'|xargs kill -9  && echo "done" || echo "fail";
obdocker.z3.obs0.sh rm -rf /data/1/lisu/obdocker.z3.obs0*/* && rm -rf /data/0/lisu/obdocker.z3.obs0.xiaoqizhang.zxq/*;
obdocker.z3.obs0.reboot;
eval ALTER SYSTEM add SERVER '$z3_obs0ip:$z3_obs0port'  ZONE 'z3';
obdocker.check_until_timeout select count(*) from __all_server where zone="z3",2,120;
obdocker.check_until_timeout select count(*) from oceanbase.__all_server where (start_service_time is null  or status='INACTIVE'),0,300;
source include/check_schema_sync_for_restart_obdocker.inc;
obdocker.check_until_timeout select count(*) from __all_virtual_tenant_parameter_stat where name = 'compatible' and value!="$dest_version",0,1;
obdocker.z1.obs0.sh rm -rf 4_3_0_X && mv  4_3_0_X.bak 4_3_0_X;
#破坏etc文件不影响dataversion
obdocker.z3.obs0.sh rm -rf /data/1/lisu/obdocker.z3.obs0/etc/observer.data_version*;
obdocker.check_until_timeout select count(*) from __all_virtual_tenant_parameter_stat where name = 'compatible' and value!="$dest_version",0,1;


