# owner: zhenjiang.xzj
# owner group: storage
# Test the case: test resize data file disk percentage
ob1=OBI(cluster=1, proxy_num=0,init_unit_cpu=2);
ob1.z1.obs0.set extra_config=datafile_size=0M,datafile_disk_percentage=10;
ob1.reboot;
let $ip0=deploy_get_value(ob1.z1.obs0.ip);
let $sql_port0=deploy_get_value(ob1.z1.obs0.mysql_port);
let $ip1=deploy_get_value(ob1.z2.obs0.ip);
let $sql_port1=deploy_get_value(ob1.z2.obs0.mysql_port);
ob1.mysql alter system set resource_hard_limit=800;
#ob1.mysql alter system set merger_switch_leader_duration_time=0;
#ob1.mysql alter system set enable_auto_leader_switch=false;
ob1.mysql alter system set enable_rereplication=false;
ob1.mysql alter system set enable_rebalance=false;
ob1.mysql alter system set bf_cache_miss_count_threshold=5;
ob1.mysql alter system set debug_sync_timeout = '20s';
connect(conn0,$ip0,root@obtest,,test,$sql_port0);
connect(conn1,$ip0,root@sys,,oceanbase,$sql_port0);
connection conn0;
let $resize_percentage=deploy_get_value(ob1.select select value+5 as value from __all_virtual_sys_parameter_stat where name = 'datafile_disk_percentage', value, 1);
ob1.mysql alter system set datafile_disk_percentage = '$resize_percentage';
ob1.check_until_timeout select value from __all_virtual_sys_parameter_stat where name = 'datafile_disk_percentage', $resize_percentage, 120;
ob1.mysql set ob_global_debug_sync = 'DOING_MARK_AND_SWEEP wait_for signal_1';
sleep 7;
let $resize_percentage2=deploy_get_value(ob1.select select value+5 as value from __all_virtual_sys_parameter_stat where name = 'datafile_disk_percentage', value, 1);
ob1.mysql alter system set datafile_disk_percentage = '$resize_percentage2';
sleep 10;
ob1.mysql set ob_global_debug_sync = 'now signal signal_1';
ob1.check_until_timeout select value from __all_virtual_sys_parameter_stat where name = 'datafile_disk_percentage', $resize_percentage2, 120;
