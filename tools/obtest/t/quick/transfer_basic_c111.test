#######################################################################################
#owner : rs@all
#owner group: rs
#description: quick test
# 测试点：
#   在1:1:1的环境下Balance和Transfer专用测试case
#########################################################################################

ob1=OBI(cluster=1:1:1,proxy_num=0);

let $extra_conf = "cpu_count=16,memory_limit='20G',system_memory='5G',_hidden_sys_tenant_memory='1G',__min_full_resource_pool_memory='1073741824',cache_wash_threshold='1G',enable_async_syslog=false,_private_buffer_size='16K',_fast_commit_callback_count='1',log_disk_size='20G',diag_syslog_per_error_limit=100000";
ob1.z1.obs0.set extra_config=$extra_conf;
ob1.z2.obs0.set extra_config=$extra_conf;
ob1.z3.obs0.set extra_config=$extra_conf;

# 验证bootstrap
--echo ===============================================================
--echo ====================     bootstrap   ==========================
--echo ===============================================================
--echo test case for bootstrap begin
ob1.reboot;
sleep 3;
let $sys_tenant_id = 1;
ob1.mysql alter system set enable_rebalance='false';
--echo test case for bootstrap finish

ob_connect(conn_sys, ob1.z1.obs0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);

# 验证建租户
--echo ===============================================================
--echo ==================     create tenant   ========================
--echo ===============================================================
# 定义了：mysql_tenant_id 和 conn_mysql
source t/quick/include/create_mysql_tenant_fff.inc;
ob1.mysql alter system set _transfer_start_trans_timeout = '10s' tenant = 'mysql';

# case 1: 验证空集群负载均衡及transfer处理
# 空集群primary zone，从1->3
--echo ===============================================================
--echo =========  empty cluster primary zone from 1 to 3   ===========
--echo ===============================================================
connection conn_sys;
alter tenant mysql set primary_zone = 'RANDOM';

# 空集群验证负载均衡任务结果
--echo ===============================================================
--echo ==========   empty cluster verify transfer    =================
--echo ===============================================================
source t/quick/include/transfer_verify_balance_and_transfer_task_finished.inc;

# case 2: 验证分区表primary_zone变更（z1,z2,z3->z1）
# 初始化transfer需要的数据
--echo ===============================================================
--echo ==============     prepare transfer data   ====================
--echo ===============================================================
source t/quick/include/transfer_prepare_data.inc;

# 修改primary zone，从3->1
--echo ===============================================================
--echo ==============  primary zone from 3 to 1   ====================
--echo ===============================================================
connection conn_sys;
alter tenant mysql set primary_zone = 'z1';

# 等待负载均衡任务执行结束，并且验证结果
--echo ===============================================================
--echo ================     verify transfer    =======================
--echo ===============================================================
source t/quick/include/transfer_verify.inc;

# 删除mysql租户表里面的内容
--echo ===============================================================
--echo =================   delete tenant data    =====================
--echo ===============================================================
source t/quick/include/transfer_delete_data.inc;

# case 3: 验证分区表primary_zone变更（z1->z1,z2）
# 初始化transfer需要的数据
--echo ===============================================================
--echo ==============     prepare transfer data   ====================
--echo ===============================================================
source t/quick/include/transfer_prepare_data.inc;

# 修改primary zone，从1->2
--echo ===============================================================
--echo ==============  primary zone from 1 to 2   ====================
--echo ===============================================================
connection conn_sys;
alter tenant mysql set primary_zone = 'z1,z2';

# 等待负载均衡任务执行结束，并且验证结果
--echo ===============================================================
--echo ================     verify transfer    =======================
--echo ===============================================================
source t/quick/include/transfer_verify.inc;

# 删除mysql租户表里面的内容
--echo ===============================================================
--echo =================   delete tenant data    =====================
--echo ===============================================================
source t/quick/include/transfer_delete_data.inc;

# case 4 ：验证分区表primary_zone变更（z1,z2->z1,z2,z3）
# 初始化transfer需要的数据
--echo ===============================================================
--echo ==============     prepare transfer data   ====================
--echo ===============================================================
source t/quick/include/transfer_prepare_data.inc;

# 修改primary zone，从2->3
--echo ===============================================================
--echo ==============  primary zone from 2 to 3   ====================
--echo ===============================================================
connection conn_sys;
alter tenant mysql set primary_zone = RANDOM;

# 等待负载均衡任务执行结束，并且验证结果
--echo ===============================================================
--echo ================     verify transfer    =======================
--echo ===============================================================
source t/quick/include/transfer_verify.inc;

# 删除mysql租户的表内容，把primary_zone置为z1
--echo ===============================================================
--echo =================   reuse mysql tenant    =====================
--echo ===============================================================
source t/quick/include/transfer_delete_data.inc;

connection conn_sys;
alter tenant mysql set primary_zone = 'z1';

# 验证变更成功并且ls gc完成
source t/quick/include/transfer_verify_balance_and_transfer_task_finished.inc;

# case 5: 验证分区表primary_zone变更（z1->z1,z2,z3）
# 初始化transfer需要的数据
--echo ===============================================================
--echo ==============     prepare transfer data   ====================
--echo ===============================================================
source t/quick/include/transfer_prepare_data.inc;

# 修改primary zone，从1->3
--echo ===============================================================
--echo ==============  primary zone from 1 to 3   ====================
--echo ===============================================================
connection conn_sys;
alter tenant mysql set primary_zone = RANDOM;

# 等待负载均衡任务执行结束，并且验证结果
--echo ===============================================================
--echo ================     verify transfer    =======================
--echo ===============================================================
source t/quick/include/transfer_verify.inc;
