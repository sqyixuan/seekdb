ob1=OBI(cluster=1,proxy_num=0);

# case 1. 验证bootstrap
--echo ===============================================================
--echo ====================     bootstrap   ==========================
--echo ===============================================================
--echo test case for bootstrap begin
ob1.reboot;
sleep 3;
ob_connect(conn_sys, ob1.z1.obs0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);
--echo test case for bootstrap finish
--echo check server start_service_time
select count(*) as cnt from oceanbase.__all_virtual_server_stat where create_time != 0;
--error 4147
alter system set server_create_time = 1000;
ob1.check_until_timeout select count(*) as cnt from oceanbase.V\$OB_SERVER_STAT where start_service_time > 0, 1, 60;

