connection conn_oracle1;
select * from stu2;

declare l_xid DBMS_XA_XID; l_ret PLS_INTEGER; BEGIN l_xid := DBMS_XA_XID(0, '', ''); l_xid.formatid := 123; l_xid.gtrid := UTL_RAW.cast_to_raw('gtrid101'); l_xid.bqual := UTL_RAW.cast_to_raw('bqual001'); l_ret := DBMS_XA.XA_ROLLBACK(xid => l_xid); dbms_output.put_line('xa rollback one phase: ' || l_ret); END;
