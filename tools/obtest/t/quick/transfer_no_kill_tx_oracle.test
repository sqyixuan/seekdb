#END;

select * from stu2;

--echo ============= transfer stangby read  =======================
connection conn_mysql;
truncate table stu1;
truncate table stu2;

--disable_query_log
connection conn_mysql;
# insert randvlaue
commit;
set autocommit = 0;
let $rand_v = query_get_value(SELECT FLOOR(RAND() * 10000 + RAND() * 10000 + RAND() * 10000) as C1, C1, 1);
eval insert into stu1 values($rand_v, 1);
insert into stu2 values(1, 1);

# before prepare
connection conn_sys;
# get tenant_id and tx_id
let $mysql_tenant_id = query_get_value(select tenant_id from __all_tenant where tenant_name = 'mysql', tenant_id, 1);
let $tx_id = query_get_value(select transaction_id from __all_virtual_sql_audit where query_sql like '%values($rand_v, 1)%' and TENANT_ID = $mysql_tenant_id, transaction_id, 1);
# construct err reject code to control this transaction state
let $err_rej = query_get_value(select $tx_id * 10000 + $mysql_tenant_id as res, res, 1);
eval alter system set_tp tp_name = ERRSIM_DELAY_TX_SUBMIT_LOG, error_code = $err_rej, frequency = 1;
--enable_query_log

# do transfer
connection conn_mysql1;
alter table stu1 tablegroup='';
source t/quick/include/transfer_verify_balance_and_transfer_task_finished.inc;

connection conn_mysql;
--error 4012
commit;

--disable_query_log
connection conn_sys;
ALTER SYSTEM SWITCHOVER TO STANDBY TENANT mysql;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_tenant_info where tenant_id = $mysql_tenant_id and tenant_role = 'STANDBY' and switchover_status = 'NORMAL', 1, 10;
--enable_query_log

connection conn_mysql2;
select * from stu1;

connection conn_sys;
ALTER SYSTEM SWITCHOVER TO PRIMARY TENANT mysql;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_tenant_info where tenant_id = $mysql_tenant_id and tenant_role = 'PRIMARY' and switchover_status = 'NORMAL', 1, 20;
sleep 3;

--disable_query_log
connection conn_mysql;
# insert randvlaue
commit;
set autocommit = 0;
let $rand_v = query_get_value(SELECT FLOOR(RAND() * 10000 + RAND() * 10000 + RAND() * 10000) as C1, C1, 1);
eval insert into stu1 values($rand_v, 1);
insert into stu2 values(2, 1);

# before prepare
connection conn_sys;
eval alter system set_tp tp_name = ERRSIM_DELAY_TX_SUBMIT_LOG, error_code = $err_rej, frequency = 0;
# get tx_id
let $tx_id = query_get_value(select transaction_id from __all_virtual_sql_audit where query_sql like '%values($rand_v, 1)%' and TENANT_ID = $mysql_tenant_id, transaction_id, 1);
# construct err reject code to control this transaction state
let $err_rej = query_get_value(select $tx_id * 10000 + $mysql_tenant_id as res, res, 1);
eval alter system set_tp tp_name = ERRSIM_DELAY_TX_COMMIT, error_code = $err_rej, frequency = 1;
--enable_query_log

# do transfer
connection conn_mysql1;
alter tablegroup tg1 add stu1;
alter tablegroup tg1 add stu2;
source t/quick/include/transfer_verify_balance_and_transfer_task_finished.inc;

connection conn_mysql;
--error 4012
commit;

connection conn_sys;
ALTER SYSTEM SWITCHOVER TO STANDBY TENANT mysql;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_tenant_info where tenant_id = $mysql_tenant_id and tenant_role = 'STANDBY' and switchover_status = 'NORMAL', 1, 20;

--disable_query_log
connection conn_mysql2;
eval select col1 = $rand_v as res from stu1; 
select * from stu2;
--enable_query_log