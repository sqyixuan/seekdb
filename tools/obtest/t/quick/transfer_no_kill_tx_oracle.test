#########################################
#owner:       lana.lgx handora.qc
#owner group: transaction
#description: transfer support active tx move
# 测试点:
#  transfer不杀事务专用测试case
#########################################

ob1=OBI(cluster=1:1:1, proxy_num=0, init_unit_cpu=0, locality=HZ:HZ:HZ);

let $extra_conf = "cpu_count=16,memory_limit='100G',system_memory='10G',__min_full_resource_pool_memory='1073741824',stack_size='1536K',cache_wash_threshold='1G',enable_async_syslog=false,_private_buffer_size='16K',_fast_commit_callback_count='1',log_disk_size='150G'";
ob1.z1.obs0.set extra_config=$extra_conf;
ob1.z2.obs0.set extra_config=$extra_conf;
ob1.z3.obs0.set extra_config=$extra_conf;
sleep 3;
ob1.reboot;

ob_connect(conn_sys, ob1.z1.obs0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);

connection conn_sys;

ob1.mysql create resource unit box1 max_cpu 10, min_cpu 10, memory_size '10G', log_disk_size '30G';
ob1.mysql create resource pool pool1 unit = 'box1', unit_num = 1;
ob1.mysql create tenant mysql replica_num = 3,primary_zone='z1,z2,z3', resource_pool_list=('pool1') set ob_tcp_invited_nodes='%';

ob1.mysql create resource unit box2 max_cpu 2, min_cpu 2, memory_size '5G', log_disk_size '5G';
ob1.mysql create resource pool pool2 unit = 'box2', unit_num = 1;
ob1.mysql create tenant oracle replica_num = 3,primary_zone='z1,z2,z3', resource_pool_list=('pool2') set ob_tcp_invited_nodes='%',ob_compatibility_mode='oracle';
ob1.check_until_timeout select count(*) c from oceanbase.__all_server where start_service_time <= 0 or status = "inactive", 0, 120;

## get ob1 z1 ip1 and port1
let $ip1 = deploy_get_value(ob1.z1.obs0.ip);
let $port1 = deploy_get_value(ob1.z1.obs0.port);

## get ob1 z2 ip2 and port2
let $ip2 = deploy_get_value(ob1.z2.obs0.ip);
let $port2 = deploy_get_value(ob1.z2.obs0.port);

## get ob1 z3 ip3 and port3
let $ip3 = deploy_get_value(ob1.z3.obs0.ip);
let $port3 = deploy_get_value(ob1.z3.obs0.port);

let $mysql_tenant_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name = 'mysql', tenant_id, 1);
let $oracle_tenant_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name = 'oracle', tenant_id, 1);
ob_connect(conn_mysql, ob1.z1.obs0, root@mysql, , test, , USE_MYSQL_CONNECTOR);
ob_connect(conn_mysql1, ob1.z1.obs0, root@mysql, , test, , USE_MYSQL_CONNECTOR);
ob_connect(conn_mysql2, ob1.z1.obs0, root@mysql, , test, , USE_MYSQL_CONNECTOR);

connection conn_sys;
alter system set _enable_active_txn_transfer = True tenant all;

# create table
connection conn_mysql;
alter system set partition_balance_schedule_interval='11s';
create table stu1(col1 int, col2 int, primary key(col1));
create table stu2(col1 int, col2 int, primary key(col1));
let $stu1_table_id = deploy_get_value(ob1.select select table_id from __all_virtual_table where table_name='stu1', table_id, 1);
let $stu1_ls_id = deploy_get_value(ob1.select select ls_id from __all_virtual_tablet_to_ls where table_id='$stu1_table_id', ls_id, 1);

let $stu2_table_id = deploy_get_value(ob1.select select table_id from __all_virtual_table where table_name='stu2', table_id, 1);
let $stu2_ls_id = deploy_get_value(ob1.select select ls_id from __all_virtual_tablet_to_ls where table_id='$stu2_table_id', ls_id, 1);

--echo ============= transfer empty tablet =======================
connection conn_mysql;
create tablegroup tg1 sharding='NONE';
alter tablegroup tg1 add stu1,stu2;
source t/quick/include/transfer_verify_balance_and_transfer_task_finished.inc;

--echo ============= transfer no active tx =======================
connection conn_mysql;
insert into stu2 values(100, 100);
alter table stu2 tablegroup='';
source t/quick/include/transfer_verify_balance_and_transfer_task_finished.inc;
connection conn_mysql;
select sum(col1) from stu2;

--echo ============= transfer active tx =======================
connection conn_mysql;
truncate table stu1;
truncate table stu2;
# tx1
connection conn_mysql1;
set autocommit=0;
insert into stu2 values(100, 100);
# tx2
connection conn_mysql2;
set autocommit=0;
insert into stu1 values(200, 100);
insert into stu2 values(300, 100);

connection conn_mysql;
alter tablegroup tg1 add stu2;
source t/quick/include/transfer_verify_balance_and_transfer_task_finished.inc;

connection conn_mysql1;
insert into stu1 values(400, 100);
insert into stu2 values(500, 100);
select sum(col1) from stu1;
select sum(col1) from stu2;
commit;

connection conn_mysql2;
insert into stu1 values(600, 100);
insert into stu2 values(700, 100);
select sum(col1) from stu1;
select sum(col1) from stu2;
commit;

connection conn_mysql;
select sum(col1) from stu1;
select sum(col1) from stu2;

--echo ============= transfer A=>B B=>A  =======================
connection conn_mysql;
truncate table stu1;
truncate table stu2;
# tx1
connection conn_mysql1;
set autocommit=0;
insert into stu2 values(100, 100);
# tx2
connection conn_mysql2;
set autocommit=0;
insert into stu1 values(200, 100);
insert into stu2 values(300, 100);

connection conn_mysql;
alter table stu2 tablegroup='';
source t/quick/include/transfer_verify_balance_and_transfer_task_finished.inc;

connection conn_mysql;
alter tablegroup tg1 add stu2;
source t/quick/include/transfer_verify_balance_and_transfer_task_finished.inc;

connection conn_mysql1;
select sum(col1) from stu1;
select sum(col1) from stu2;
commit;

connection conn_mysql2;
select sum(col1) from stu1;
select sum(col1) from stu2;
commit;

connection conn_mysql;
select sum(col1) from stu1;
select sum(col1) from stu2;

--echo ============= transfer switch leader  =======================
connection conn_mysql;
truncate table stu1;
truncate table stu2;
# tx1
connection conn_mysql1;
set autocommit=0;
insert into stu2 values(100, 100);
# tx2
connection conn_mysql2;
set autocommit=0;
insert into stu1 values(200, 100);
insert into stu2 values(300, 100);

connection conn_mysql;
alter table stu2 tablegroup='';
source t/quick/include/transfer_verify_balance_and_transfer_task_finished.inc;

connection conn_sys;
ob1.mysql alter system switch replica leader ls=$stu2_ls_id server='$ip3:$port3' tenant='mysql';

connection conn_mysql;
alter tablegroup tg1 add stu2;
source t/quick/include/transfer_verify_balance_and_transfer_task_finished.inc;

connection conn_sys;
ob1.mysql alter system switch replica leader ls=$stu2_ls_id server='$ip2:$port2' tenant='mysql';

connection conn_mysql1;
commit;

connection conn_mysql2;
commit;

connection conn_mysql;
select sum(col1) from stu1;
select sum(col1) from stu2;

--echo ============= transfer rollback local  =======================
connection conn_mysql;
truncate table stu1;
truncate table stu2;
insert into stu1 values(100, 100);
insert into stu2 values(100, 100);

# tx1
ob_connect(conn_mysql20, ob1.z3.obs0, root@mysql, , test, , USE_MYSQL_CONNECTOR);
connection conn_mysql20
set autocommit=0;
insert into stu1 values(200, 100);
# tx2
ob_connect(conn_mysql21, ob1.z3.obs0, root@mysql, , test, , USE_MYSQL_CONNECTOR);
connection conn_mysql21
set autocommit=0;
insert into stu1 values(300, 100);

connection conn_mysql;
alter table stu2 tablegroup='';
source t/quick/include/transfer_verify_balance_and_transfer_task_finished.inc;

connection conn_mysql;
alter tablegroup tg1 add stu2;
source t/quick/include/transfer_verify_balance_and_transfer_task_finished.inc;

connection conn_mysql20;
explain basic insert into stu2 select * from stu1 ON DUPLICATE KEY UPDATE col2=1000;
insert into stu2 select * from stu1 ON DUPLICATE KEY UPDATE col2=1000;
commit;
connection conn_mysql21;
explain basic insert into stu2 select * from stu1 ON DUPLICATE KEY UPDATE col2=1000;
insert into stu2 select * from stu1 ON DUPLICATE KEY UPDATE col2=1000;
commit;
select col1,col2 from stu1;
select col1,col2 from stu2;


--echo ================== transfer for oracle tenant case==========================
ob_connect(conn_oracle, ob1.z1.obs0, SYS@oracle, ,SYS, , USE_OB_CONNECTOR);
ob_connect(conn_oracle1, ob1.z1.obs0, SYS@oracle, ,SYS, , USE_OB_CONNECTOR);
ob_connect(conn_oracle2, ob1.z1.obs0, SYS@oracle, ,SYS, , USE_OB_CONNECTOR);
ob_connect(conn_oracle3, ob1.z1.obs0, SYS@oracle, ,SYS, , USE_OB_CONNECTOR);

connection conn_oralce
alter system set partition_balance_schedule_interval='11s';
create table stu1(col1 int);
create table stu2(col1 int);

--echo ============= transfer table lock  =======================
# tx1
connection conn_oracle1
set autocommit=0;
insert into stu2 values(100);

# tx2
connection conn_oracle2
set autocommit =0;
lock table stu2 IN SHARE MODE;

connection conn_oracle;
create tablegroup tg1 sharding='NONE';
alter tablegroup tg1 add stu1,stu2;
source t/quick/include/transfer_verify_balance_and_transfer_task_finished_oracle.inc;

#connection conn_oracle;
#select obj_type, obj_id, lock_mode, ls_id from SYS.ALL_VIRTUAL_OBJ_LOCK;

connection conn_oracle3;
set autocommit =0;
set SESSION ob_trx_timeout = 10000000000;
set SESSION ob_query_timeout = 2000000;
set SESSION ob_trx_idle_timeout = 10000000000;
lock table stu2 IN EXCLUSIVE MODE;
ERROR HY000: resource busy; acquire with WAIT timeout expired
commit;

connection conn_oracle1;
commit;

connection conn_oracle3;
lock table stu2 IN EXCLUSIVE MODE;
ERROR HY000: resource busy; acquire with WAIT timeout expired
commit;

connection conn_oracle2;
commit;

connection conn_oracle3;
lock table stu2 IN EXCLUSIVE MODE;
commit;

connection conn_oracle;
select sum(col1) from stu1;
select sum(col1) from stu2;

--echo ============= transfer table lock2  =======================
# tx1
connection conn_oracle1
set autocommit=0;
lock table stu2 IN EXCLUSIVE MODE;

connection conn_oracle;
alter table stu2 tablegroup='';
source t/quick/include/transfer_verify_balance_and_transfer_task_finished_oracle.inc;

connection conn_oracle;
alter tablegroup tg1 add stu2;
source t/quick/include/transfer_verify_balance_and_transfer_task_finished_oracle.inc;

connection conn_oracle2;
set autocommit =0;
set SESSION ob_trx_timeout = 10000000000;
set SESSION ob_query_timeout = 2000000;
set SESSION ob_trx_idle_timeout = 10000000000;
lock table stu2 IN EXCLUSIVE MODE;
ERROR HY000: resource busy; acquire with WAIT timeout expired
commit;

connection conn_oracle1;
commit;

connection conn_oracle2;
lock table stu2 IN EXCLUSIVE MODE;
commit;

--echo ============= transfer xa before xa_end  =======================

connection conn_oracle1;
set autocommit=0;

declare l_xid DBMS_XA_XID; l_ret PLS_INTEGER; BEGIN l_xid := DBMS_XA_XID(0, '', ''); l_xid.formatid := 123; l_xid.gtrid := UTL_RAW.cast_to_raw('gtrid101'); l_xid.bqual := UTL_RAW.cast_to_raw('bqual001'); l_ret := DBMS_XA.XA_START(xid => l_xid, flag => 65536); dbms_output.put_line('xa start: ' || l_ret); END;
#declare
#l_xid DBMS_XA_XID;
#l_ret PLS_INTEGER;
#BEGIN
