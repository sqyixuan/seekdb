create materialized view log on t_with_max_multivalue_index parallel 9;
--enable_query_log
let $t_with_max_multivalue_index_id = deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where table_name = 't_with_max_multivalue_index', table_id, 1);
--echo # alter primary_zone to trigger transfer task
alter tenant mysql primary_zone = 'z1';
ob1.check_until_timeout select count(*) from CDB_OB_BALANCE_JOBS where tenant_id = $mysql_tenant_id, 1, 60;
ob1.check_until_timeout select count(*) from CDB_OB_BALANCE_JOBS where tenant_id = $mysql_tenant_id, 0, 200;
--echo # verify transfer success

eval select src_ls, dest_ls, tablet_count, status, result from oceanbase.DBA_OB_TRANSFER_TASK_HISTORY where part_list like "%$t_with_max_vec_index_id%" and result = 0;
eval select src_ls, dest_ls, tablet_count, status, result from oceanbase.DBA_OB_TRANSFER_TASK_HISTORY where part_list like "%$t_with_max_vec_ivfflat_index_id%" and result = 0;
eval select src_ls, dest_ls, tablet_count, status, result from oceanbase.DBA_OB_TRANSFER_TASK_HISTORY where part_list like "%$t_with_max_vec_ivfsq8_index_id%" and result = 0;
eval select src_ls, dest_ls, tablet_count, status, result from oceanbase.DBA_OB_TRANSFER_TASK_HISTORY where part_list like "%$t_with_max_vec_ivfpq_index_id%" and result = 0;
eval select src_ls, dest_ls, tablet_count, status, result from oceanbase.DBA_OB_TRANSFER_TASK_HISTORY where part_list like "%$t_with_max_fts_index_id%" and result = 0;
eval select src_ls, dest_ls, tablet_count, status, result from oceanbase.DBA_OB_TRANSFER_TASK_HISTORY where part_list like "%$t_with_max_multivalue_index_id%" and result = 0;

drop database d_transfer_max_aux_test;

--echo ##
--echo # 7 test _transfer_task_tablet_count_threshold
--echo # limit 0 < _transfer_task_tablet_count_threshold <= OB_MAX_TRANSFER_BINDING_TABLET_CNT
connection conn_sys;
set @@session.ob_query_timeout = 1000000000;
ob1.check_until_timeout select count(*) from CDB_OB_BALANCE_JOBS where tenant_id = $mysql_tenant_id, 0, 100;
--error 4147
alter system set _transfer_task_tablet_count_threshold = 0 tenant mysql;
--error 1210
alter system set _transfer_task_tablet_count_threshold = 519 tenant mysql;
alter system set _transfer_task_tablet_count_threshold = 518 tenant mysql;

connection conn_mysql;

set @@session.ob_query_timeout = 1000000000;
--echo # create normal table with max transfer tablets
--disable_query_log
create table t1 (c1 int, c2 int, primary key(c1)) partition by hash(c1) partitions 1036;
--enable_query_log

let $t1_id = deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where table_name = 't1', table_id, 1);

--echo # alter primary_zone to trigger transfer task

alter tenant mysql primary_zone = 'z1,z2';
ob1.check_until_timeout select count(*) from CDB_OB_BALANCE_JOBS where tenant_id = $mysql_tenant_id, 1, 60;
ob1.check_until_timeout select count(*) from CDB_OB_BALANCE_JOBS where tenant_id = $mysql_tenant_id, 0, 200;
--echo # verify transfer success
eval select src_ls, dest_ls, tablet_count, status, result from oceanbase.DBA_OB_TRANSFER_TASK_HISTORY where part_list like "%$t1_id%" and result = 0;

--echo drop tenants
connection conn_sys;
set recyclebin = off;
drop tenant mysql force;
