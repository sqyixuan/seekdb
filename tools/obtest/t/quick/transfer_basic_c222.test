#######################################################################################
#owner : rs@all
#owner group: rs
#description: quick test
# 测试点：
#   在2:2:2的环境下Balance和Transfer专用测试case
#########################################################################################

ob1=OBI(cluster=2:2:2,proxy_num=0);

let $extra_conf = "cpu_count=16,memory_limit='20G',system_memory='5G',_hidden_sys_tenant_memory='1G',__min_full_resource_pool_memory='1073741824',cache_wash_threshold='1G',enable_async_syslog=false,_private_buffer_size='16K',_fast_commit_callback_count='1',log_disk_size='20G',diag_syslog_per_error_limit=100000";
ob1.z1.obs0.set extra_config=$extra_conf;
ob1.z2.obs0.set extra_config=$extra_conf;
ob1.z3.obs0.set extra_config=$extra_conf;
ob1.z1.obs1.set extra_config=$extra_conf;
ob1.z2.obs1.set extra_config=$extra_conf;
ob1.z3.obs1.set extra_config=$extra_conf;


# case 1. 验证bootstrap
--echo ===============================================================
--echo ====================     bootstrap   ==========================
--echo ===============================================================
--echo test case for bootstrap begin
ob1.reboot;
sleep 3;
let $sys_tenant_id = 1;
ob1.mysql alter system set enable_rebalance='false';
--echo test case for bootstrap finish

ob_connect(conn_sys, ob1.z1.obs0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);

# 验证建租户
--echo ===============================================================
--echo ==================     create tenant   ========================
--echo ===============================================================
# 定义了：mysql_tenant_id 和 conn_mysql
source t/quick/include/create_mysql_tenant_fff.inc;
ob1.mysql alter system set _transfer_start_trans_timeout = '10s' tenant = 'mysql';

# case 2 验证集群unit_num变更
--echo ===============================================================
--echo ==============     prepare transfer data   ====================
--echo ===============================================================
source t/quick/include/transfer_prepare_data.inc;

# 修改unit_num:1->2
--echo ===============================================================
--echo ==============  unit num from 1 to 2   ====================
--echo ===============================================================
connection conn_sys;
ALTER RESOURCE TENANT mysql UNIT_NUM = 2;

--echo ===============================================================
--echo ================     verify transfer    =======================
--echo ===============================================================
source t/quick/include/transfer_verify.inc;

# 删除mysql租户表，把unit_num置为1
--echo ===============================================================
--echo =================   reset mysql tenant    =====================
--echo ===============================================================
connection conn_mysql;
set recyclebin = off;
DROP TABLE IF EXISTS t_part, t_subpart;

connection conn_sys;
# 要保留1001日志流，保证case的稳定性
ALTER RESOURCE TENANT mysql UNIT_NUM = 1 DELETE UNIT_GROUP = (1002);

# 验证变更成功并且ls gc完成
source t/quick/include/transfer_verify_balance_and_transfer_task_finished.inc;

# 验证offline ddl隐藏表的transfer
--echo ===============================================================
--echo ========   verify transfer offline ddl hidden table   =========
--echo ===============================================================
source t/quick/include/transfer_hidden_table_test.inc;

# case 2: 验证transfer和balance相关的配置项
--echo ===============================================================
--echo ============ test balance and transfer configs ================
--echo ===============================================================
source t/quick/include/transfer_and_balance_configs.inc;
