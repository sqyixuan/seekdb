#rs
#msy
#主备库同步ddl的时候，需要同步schema version
#create user，alter zone，alter tenant，alter table
ob1=OBI(cluster=1:1:1, proxy_num = 0);
ob2=OBI(cluster=2:2, proxy_num = 0, leaderob=ob1);
ob1.z1.obs0.set extra_config=__schema_split_mode=true;
ob1.z2.obs0.set extra_config=__schema_split_mode=true;
ob1.z3.obs0.set extra_config=__schema_split_mode=true;
ob1.reboot;
sleep 1;

ob2.z1.obs0.set extra_config=__schema_split_mode=true;
ob2.z1.obs1.set extra_config=__schema_split_mode=true;
ob2.z2.obs0.set extra_config=__schema_split_mode=true;
ob2.z2.obs1.set extra_config=__schema_split_mode=true;
ob2.reboot;
sleep 1;

ob1.mysql alter system set server_permanent_offline_time = 20;
ob1.mysql alter system set server_temporary_offline_time = 15;

let $resource_id = deploy_get_value(ob1.select select resource_pool_id from __all_resource_pool where tenant_id = 1, resource_pool_id,1);
let $tt1ip= deploy_get_value(ob1.select select svr_ip from __all_unit where zone='z1' and resource_pool_id = $resource_id limit 1, svr_ip, 1);
let $svr_port= deploy_get_value(ob1.select select svr_port from __all_unit where zone='z1' and resource_pool_id = $resource_id limit 1, svr_port, 1);
let $tt1port = deploy_get_value(ob1.select select inner_port from __all_server where svr_ip='$tt1ip' and svr_port=$svr_port, inner_port, 1);
connect(conn, $tt1ip, root@sys,,oceanbase, $tt1port);

#目前bootstrap阶段没有同步，所以建一个用户，同步到schema
ob1.mysql create user msy identified by 'wrewgdg';
let $schema_version = deploy_get_value(ob1.select select schema_version from oceanbase.__all_virtual_user_history where user_name = 'msy', schema_version, 1);
let $user_id = deploy_get_value(ob1.select select user_id from oceanbase.__all_virtual_user where user_name = 'msy', user_id, 1);
#检查备库是否同步
ob2.check_until_timeout select count(*) from oceanbase.__all_virtual_user where user_name = 'msy', 1, 10;
ob2.check_until_timeout select count(*) from oceanbase.__all_virtual_ddl_operation where schema_version = $schema_version, 1, 13;

#设置权限
ob1.mysql grant select on oceanbase.* to msy;
let $schema_version = deploy_get_value(ob1.select select schema_version from oceanbase.__all_virtual_ddl_operation where user_id = $user_id order by schema_version desc, schema_version, 1);
ob2.check_until_timeout select count(*) from oceanbase.__all_virtual_ddl_operation where schema_version = $schema_version, 1, 13;
ob1.mysql grant select on oceanbase.__all_virtual_table to msy;
let $schema_version = deploy_get_value(ob1.select select schema_version from oceanbase.__all_virtual_ddl_operation where user_id = $user_id order by schema_version desc, schema_version, 1);
ob2.check_until_timeout select count(*) from oceanbase.__all_virtual_ddl_operation where schema_version = $schema_version, 1, 13;

#删除权限
ob1.mysql revoke select on oceanbase.* from msy;
let $schema_version = deploy_get_value(ob1.select select schema_version from oceanbase.__all_virtual_ddl_operation where user_id = $user_id order by schema_version desc, schema_version, 1);
ob2.check_until_timeout select count(*) from oceanbase.__all_virtual_ddl_operation where schema_version = $schema_version, 1, 13;

#更改用户的密码
ob1.mysql alter user msy identified by 'fdgaskghow[qrguqogjskvnkgaw;ldksfjga]';
let $schema_version = deploy_get_value(ob1.select select schema_version from oceanbase.__all_virtual_ddl_operation where user_id = $user_id order by schema_version desc, schema_version, 1);
ob2.check_until_timeout select count(*) from oceanbase.__all_virtual_ddl_operation where schema_version = $schema_version, 1, 13;

#设置一个权限，顺便改密码
ob1.mysql grant all on oceanbase.__all_virtual_ddl_operation to msy identified by 'fdsafgdskljghurutyi346548929343rtihtgdsafadsgasg';
let $schema_version = deploy_get_value(ob1.select select schema_version from oceanbase.__all_virtual_ddl_operation where user_id = $user_id order by schema_version desc, schema_version, 1);
ob2.check_until_timeout select count(*) from oceanbase.__all_virtual_ddl_operation where schema_version = $schema_version, 1, 13;

#grant 一个不存在的用户，并且设置密码
ob1.mysql grant all on oceanbase.__all_virtual_ddl_operation to msy123456 identified by 'fdsafgdskljghurutyi346548929343rtihtg';
#会有两条DDL
let $user_id = deploy_get_value(ob1.select select user_id from oceanbase.__all_virtual_user where user_name = 'msy123456', user_id, 1);
let $schema_version = deploy_get_value(ob1.select select schema_version from oceanbase.__all_virtual_ddl_operation where user_id = $user_id and operation_type = 402, schema_version, 1);
#ob2.check_until_timeout select count(*) from oceanbase.__all_virtual_ddl_operation where schema_version = $schema_version, 1, 3;
#let $schema_version = deploy_get_value(ob1.select select schema_version from oceanbase.__all_virtual_ddl_operation where user_id = $user_id and operation_type = 406, schema_version, 1);
ob2.check_until_timeout select count(*) from oceanbase.__all_virtual_ddl_operation where schema_version = $schema_version, 1, 13;
let $schema_version = deploy_get_value(ob1.select select schema_version from oceanbase.__all_virtual_ddl_operation where user_id = $user_id and operation_type = 602, schema_version, 1);
ob2.check_until_timeout select count(*) from oceanbase.__all_virtual_ddl_operation where schema_version = $schema_version, 1, 13;

#删除用户
ob1.mysql drop user msy;
ob1.mysql drop user msy123456;
let $schema_version = deploy_get_value(ob1.select select schema_version from oceanbase.__all_virtual_ddl_operation where user_id = $user_id order by schema_version desc, schema_version, 1);
ob2.check_until_timeout select count(*) from oceanbase.__all_virtual_ddl_operation where schema_version = $schema_version, 1, 13;

#停掉一个zone
connection conn;
#备库不同步对variable的修改
set @@global.ob_query_timeout = 100000000;
ob1.mysql alter system stop zone z3;

let $schema_version = deploy_get_value(ob1.select select schema_version from oceanbase.__all_virtual_ddl_operation where operation_type = 806, schema_version, 1);

#备库同步推高schema version
ob2.check_until_timeout select count(*) from oceanbase.__all_virtual_ddl_operation where schema_version = $schema_version, 0, 13;
let $schema_version = deploy_get_value(ob1.select select schema_version from oceanbase.__all_virtual_ddl_operation where operation_type = 1504 and schema_version > $schema_version, schema_version, 1);
ob2.check_until_timeout select count(*) from oceanbase.__all_virtual_ddl_operation where schema_version = $schema_version, 1, 13;

#启动这个zone
ob1.mysql alter system start zone z3;
let $schema_version = deploy_get_value(ob1.select select schema_version from oceanbase.__all_virtual_ddl_operation where operation_type = 805, schema_version, 1);
ob2.check_until_timeout select count(*) from oceanbase.__all_virtual_ddl_operation where schema_version = $schema_version, 0, 13;
let $schema_version = deploy_get_value(ob1.select select schema_version from oceanbase.__all_virtual_ddl_operation where operation_type = 1504 and schema_version > $schema_version, schema_version, 1);
ob2.check_until_timeout select count(*) from oceanbase.__all_virtual_ddl_operation where schema_version = $schema_version, 1, 13;

#加一个zone
ob1.mysql alter system add zone z4;
let $schema_version = deploy_get_value(ob1.select select schema_version from oceanbase.__all_virtual_ddl_operation where operation_type = 803, schema_version, 1); 
ob2.check_until_timeout select count(*) from oceanbase.__all_virtual_ddl_operation where schema_version = $schema_version, 0, 13;
let $schema_version = deploy_get_value(ob1.select select schema_version from oceanbase.__all_virtual_ddl_operation where operation_type = 1504 and schema_version > $schema_version, schema_version, 1);
ob2.check_until_timeout select count(*) from oceanbase.__all_virtual_ddl_operation where schema_version = $schema_version, 1, 13;
#删除zone
ob1.mysql alter system delete zone z4; 
let $schema_version = deploy_get_value(ob1.select select schema_version from oceanbase.__all_virtual_ddl_operation where operation_type = 804, schema_version, 1);
ob2.check_until_timeout select count(*) from oceanbase.__all_virtual_ddl_operation where schema_version = $schema_version, 0, 13;
let $schema_version = deploy_get_value(ob1.select select schema_version from oceanbase.__all_virtual_ddl_operation where operation_type = 1504 and schema_version > $schema_version, schema_version, 1);
ob2.check_until_timeout select count(*) from oceanbase.__all_virtual_ddl_operation where schema_version = $schema_version, 1, 13;


#alter table 的同步
#打开开关
ob1.mysql alter system set enable_sys_table_ddl = true;
ob2.mysql alter system set enable_sys_table_ddl = true;
ob1.mysql alter table oceanbase.__all_part add column fail_list varchar(1024) NOT NULL DEFAULT "";
let $schema_version = deploy_get_value(ob1.select select schema_version from oceanbase.__all_virtual_ddl_operation where tenant_id = 1 and operation_type = 3 and ddl_stmt_str !='', schema_version, 1);
ob2.check_until_timeout select count(*) from oceanbase.__all_virtual_ddl_operation where schema_version = $schema_version, 1, 13;
ob2.mysql desc oceanbase.__all_part; 

ob1.mysql alter table oceanbase.__all_part drop column fail_list;
let $schema_version = deploy_get_value(ob1.select select max(schema_version) as schema_version from oceanbase.__all_virtual_ddl_operation where tenant_id = 1 and operation_type = 3, schema_version, 1);
ob2.check_until_timeout select count(*) from oceanbase.__all_virtual_ddl_operation where schema_version = $schema_version, 1, 13;
ob2.mysql desc oceanbase.__all_part;
#加约束
ob1.mysql alter table oceanbase.__all_virtual_ddl_operation add constraint c1 unique(schema_version);
let $schema_version = deploy_get_value(ob1.select select max(schema_version) as schema_version from oceanbase.__all_virtual_ddl_operation where tenant_id = 1 and operation_type = 3, schema_version, 1);
ob2.check_until_timeout select count(*) from oceanbase.__all_virtual_ddl_operation where schema_version = $schema_version, 1, 13;
#更新表名
ob1.mysql alter table oceanbase.__all_meta_table rename to oceanbase.__all_meta_table_old;
let $schema_version = deploy_get_value(ob1.select select max(schema_version) as schema_version from oceanbase.__all_virtual_ddl_operation where tenant_id = 1 and operation_type = 3, schema_version, 1);
ob2.check_until_timeout select count(*) from oceanbase.__all_virtual_ddl_operation where schema_version = $schema_version, 1, 13;
ob1.mysql select count(*) from oceanbase.__all_meta_table_old;
ob2.mysql select count(*) from oceanbase.__all_meta_table_old;
#改回来
ob1.mysql alter table oceanbase.__all_meta_table_old rename to oceanbase.__all_meta_table;
let $schema_version = deploy_get_value(ob1.select select max(schema_version) as schema_version from oceanbase.__all_virtual_ddl_operation where tenant_id = 1 and operation_type = 3, schema_version, 1);
ob2.check_until_timeout select count(*) from oceanbase.__all_virtual_ddl_operation where schema_version = $schema_version, 1, 13;
ob1.mysql select count(*) from oceanbase.__all_meta_table;
ob2.mysql select count(*) from oceanbase.__all_meta_table;
#删除约束
#ob1.mysql alter table __all_virtual_ddl_operation drop constraint (c1);
#let $schema_version = deploy_get_value(ob1.select select max(schema_version) as schema_version from oceanbase.__all_virtual_ddl_operation where tenant_id = 1 and operation_type = 3, schema_version, 1);
#ob2.check_until_timeout select count(*) from oceanbase.__all_virtual_ddl_operation where schema_version = $schema_version, 1, 3;
#指定table_id建表
ob1.mysql create table oceanbase.__test (c1 int primary key,c3 int) table_id = 1099511628476 tablegroup = 'oceanbase';
let $schema_version = deploy_get_value(ob1.select select max(schema_version) as schema_version from oceanbase.__all_virtual_ddl_operation where tenant_id = 1 and operation_type = 4, schema_version, 1);
ob2.check_until_timeout select count(*) from oceanbase.__all_virtual_ddl_operation where schema_version = $schema_version, 1, 13;

ob1.mysql create table oceanbase.__test1 (c1 int primary key,c3 int) table_id = 1099511628546 tablegroup = 'oceanbase' partition by hash(c1) partitions 10;
let $schema_version = deploy_get_value(ob1.select select max(schema_version) as schema_version from oceanbase.__all_virtual_ddl_operation where tenant_id = 1 and operation_type = 4, schema_version, 1);
ob2.check_until_timeout select count(*) from oceanbase.__all_virtual_ddl_operation where schema_version = $schema_version, 1, 13;

#建索引
#删除索引
#关闭开关
ob1.mysql alter system set enable_sys_table_ddl = false;
ob2.mysql alter system set enable_sys_table_ddl = false;

#建一个tenant
ob1.mysql create resource pool pl unit='sys_unit_config', unit_num =1, zone_list=('z1', 'z2');
ob1.mysql create tenant tt resource_pool_list=('pl');
let $tenant_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name ='tt', tenant_id, 1);
let $schema_version = deploy_get_value(ob1.select select schema_version from oceanbase.__all_virtual_ddl_operation where tenant_id = $tenant_id and operation_type = 102, schema_version, 1);
ob2.check_until_timeout select count(*) from oceanbase.__all_tenant where tenant_id = $tenant_id, 1, 10;
ob2.mysql_p select name, resource_pool_id, unit_count,  unit_config_id, zone_list, tenant_id from oceanbase.__all_resource_pool;
ob2.mysql_p select tenant_id, tenant_name, primary_zone, locality from oceanbase.__all_tenant;
ob2.check_until_timeout select count(*) from oceanbase.__all_virtual_ddl_operation where schema_version = $schema_version, 1, 13;

sleep 10;
#alter tenant只推schema
ob1.mysql alter tenant tt set primary_zone='z2;z1';
let $schema_version = deploy_get_value(ob1.select select schema_version from oceanbase.__all_virtual_ddl_operation where tenant_id = $tenant_id and operation_type = 103, schema_version, 1);
ob2.check_until_timeout select count(*) from oceanbase.__all_virtual_ddl_operation where schema_version = $schema_version, 0, 13;
let $schema_version = deploy_get_value(ob1.select select schema_version from oceanbase.__all_virtual_ddl_operation where operation_type = 1504 and schema_version > $schema_version, schema_version, 1);
ob2.check_until_timeout select count(*) from oceanbase.__all_virtual_ddl_operation where schema_version = $schema_version, 1, 13;
