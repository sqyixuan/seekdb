##############################
# owner: feizhi.cfz
# owner group: storage
# 功能点：测试日志副本的补副本操作

# 部署：
# 4台observer，每台server一个zone：z1~z4
# 部署在4个机房：全部部署在一个region里面。

ob1=OBI(cluster=2:2:2:2,proxy_num=1,init_unit_cpu=4);

ob1.reboot;

source include/fast_auto_rebalance_configuration.inc;

# 创建租户
ob1.mysql create resource pool pool1 unit = 'sys_unit_config', unit_num = 2, zone_list = ('z1', 'z2', 'z3');
ob1.mysql create resource pool pool2 unit = 'sys_unit_config', unit_num = 2, zone_list = ('z4');
ob1.mysql create tenant tt resource_pool_list=('pool1'), primary_zone = 'z1', locality = 'F@z1,F@z2,F@z3' set ob_tcp_invited_nodes='%';
sleep 5;

let $proxy_ip = deploy_get_value(ob1.proxy0.ip);
let $proxy_port = deploy_get_value(ob1.proxy0.port);

connect(tt_conn, $proxy_ip, root@tt,,test, $proxy_port);
connect(sys_conn, $proxy_ip, root@sys,,test, $proxy_port);

# 构建数据
--disable_query_log
connection tt_conn;
let $count = 0;
eval create table test01 (pk bigint primary key, name varchar(128));
while ($count < 20)
{
  eval insert into test01 (pk, name) values ($count, 'abc');
  inc $count;
}
--enable_query_log

connection sys_conn;
alter tenant tt resource_pool_list=('pool1', 'pool2');
let $tenant_id = deploy_get_value(ob1.select select tenant_id from __all_tenant where tenant_name = "tt", tenant_id, 1);

ob1.mysql alter tenant tt locality = "F@z1,F@z2,F@z3,L@z4";
# 检查变更是否完成
ob1.check_until_timeout select count(*) c from oceanbase.__all_tenant where tenant_id = $tenant_id and previous_locality != '', 0, 60;
# 检查member list是否存在
let $table_id = deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where table_name = 'test01' and tenant_id = $tenant_id, table_id, 1);
let $svr_port = deploy_get_value(ob1.select select svr_port from oceanbase.__all_virtual_partition_table where zone = 'z4' and replica_type = 5 and table_id = $table_id, svr_port, 1);
let $svr_ip = deploy_get_value(ob1.select select svr_ip from oceanbase.__all_virtual_partition_table where zone = 'z4' and replica_type = 5 and table_id = $table_id, svr_ip, 1);
ob1.check_until_timeout select count(*) c from oceanbase.__all_virtual_partition_table where role = 1 and member_list like '%$svr_ip:$svr_port%' and table_id = $table_id, 1, 60;
#ob1.check_until_timeout select count(*) c from __all_virtual_storage_stat where table_id = $table_id and svr_ip = '$svr_ip' and svr_port = $svr_port, 0, 1;

# 迁移结束后重新插入数据，检测写入是否正常，并检查目标端memstore是否为空
--disable_query_log
connection tt_conn;
while ($count < 40)
{
  eval insert into test01 (pk, name) values ($count, 'abc');
  inc $count;
}
--enable_query_log
ob1.check_until_timeout select count(*) from __all_virtual_table_mgr where table_id = $table_id and svr_ip = '$svr_ip' and svr_port = $svr_port, 0, 1;
select count(1) from test01;
