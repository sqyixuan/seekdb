#####################
#author:yiwan
#owner:yiwan
#owner group:storage
#功能：bug覆盖（测试复制迁移的partition有没有正确复制partition meta中的信息step_merge_num(现在叫progressive_merge_num)）
#
#场景：
#复制迁移后，查看partition的progressive_merge_num属性是否成功复制 ，然后进行合并
####################
--disable_query_log
ob1=OBI(cluster=2:2:2,proxy_num=0,init_unit_cpu=2,init_unit_num=2);
ob1.reboot;

ob1.mysql alter system set merger_check_interval='10s';
ob1.mysql alter system set enable_rebalance='false';
ob1.mysql alter system set enable_rereplication='false';

let $ip=deploy_get_value(ob1.z1.obs0.ip);
let $port=deploy_get_value(ob1.z1.obs0.mysql_port);
connect (conn1,$ip,admin@obtest,admin,oceanbase,$port);
connect (conn2,$ip,root@sys,,oceanbase,$port);
connection conn1;

#create table
use test;
create table test01(c1 int primary key,c2 int,c3 varchar(64));
let $table_id=deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where table_name='test01', table_id, 1);
#insert data
let $cnt=10;
while($cnt>0)
{
   eval insert into test01 values($cnt,$cnt,'obtest_data');
   dec $cnt;
}
ob1.mysql alter system major freeze;
ob1.check_version 2;
# migrate
let $src = deploy_get_value(ob1.get_follower obtest:test:test01:0,1);
let $src_ip = deploy_get_value($src.ip);
let $src_port = deploy_get_value($src.port);
let $src_zone = deploy_get_value($src.zone);
let $dst_host = deploy_get_value(ob1.select select concat(svr_ip, ':', svr_port) host from oceanbase.__all_server where zone='$src_zone' and svr_port!='$src_port', host, 1);
let $dst = deploy_get_value(ob1.get_obs_by_addr $dst_host);
let $dst_ip = deploy_get_value($dst.ip);
let $dst_port = deploy_get_value($dst.port);

ob1.mysql_p select data_version from oceanbase.__all_virtual_meta_table where table_id=$table_id and svr_ip='$src_ip' and svr_port='$src_port';
ob1.mysql_p select data_version from oceanbase.__all_virtual_meta_table where table_id=$table_id and svr_ip='$dst_ip' and svr_port='$dst_port';

ob1.mysql_p select progressive_merge_num from oceanbase.__all_virtual_table where table_id=$table_id;

$src.migrate_to $dst,obtest:test:test01;
sleep 20;
ob1.check_no_rebalance_task;
#check
ob1.mysql_p select progressive_merge_num from oceanbase.__all_virtual_table where table_id=$table_id;

ob1.mysql alter system major freeze;
ob1.check_version 3;

