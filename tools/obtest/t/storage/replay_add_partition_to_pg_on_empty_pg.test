# owner: weixue.cx
# owner group: storage
# description: test replay add_partition_to_pg on empty pg
##

ob1=OBI(cluster=1,proxy_num=0,init_unit_cpu=5);
ob1.reboot;
sleep 5;

let $ip=deploy_get_value(ob1.z1.obs0.ip);
let $port=deploy_get_value(ob1.z1.obs0.mysql_port);
connect (conn1,$ip,admin@obtest,admin,oceanbase,$port);
connect (conn2,$ip,root@sys,,oceanbase,$port);

# step 1: create binding pg
connection conn1;
use test;

create tablegroup test_tg binding true;
create table t1 (c1 int primary key, c2 int) tablegroup test_tg;

insert into t1 values (1,1), (2,2), (3,3);

ob1.mysql alter system minor freeze tenant = sys;
ob1.mysql alter system minor freeze tenant = all_user;
ob1.mysql alter system minor freeze tenant = all_meta;
ob1.check_until_timeout select count(1) as c from oceanbase.__all_virtual_table_mgr where is_active = 0 and table_type = 0, 0, 60;

connection conn1;
use test;
select * from t1 order by c1;

create table t2 (c1 int primary key, c2 int) tablegroup test_tg;
create table t3 (c1 int primary key, c2 int) tablegroup test_tg;

drop table t1;
drop table t2;
drop table t3;
purge recyclebin;
sleep 30;

--error 4179
create table t4 (c1 int primary key, c2 int) tablegroup test_tg;

ob1.z1.obs0.restart;
sleep 30;
ob1.check_until_timeout select status from oceanbase.__all_server where zone='z1', active, 60;
ob1.mysql alter system major freeze;
sleep 60;
ob1.check_version 2;
