# owner: yanyuan.cxf cxf262476@antgroup.com
# owner group: transaction
# description: 创建restore point，删除restore point，使用restore point进行数据查询
--disable_query_log
ob1=OBI(cluster=1,init_unit_cpu=0);
ob1.z1.obs0.set extra_config=devname=eth0;
ob1.reboot;

let $cpu = 1;
let $memory = 1073741824;
let $min_memory = 1073741824;
let $disk = 536870912;
let $iops = 100000;
let $session = 64;
let $case_index = 1;

ob_connect(sys_conn, ob1.z1.obs0, root, , oceanbase, , USE_OB_CONNECTOR);
connection sys_conn;

eval  CREATE RESOURCE UNIT unit MAX_CPU $cpu, MAX_MEMORY $memory, MAX_IOPS $iops, MAX_DISK_SIZE $disk, MAX_SESSION_NUM $session, MIN_CPU=1, MIN_MEMORY=$min_memory, MIN_IOPS=128;
eval  CREATE RESOURCE POOL pool UNIT = 'unit', UNIT_NUM = 1, ZONE_LIST = ('z1');
eval  CREATE TENANT tenant RESOURCE_POOL_LIST = ('pool'), primary_zone='z1', locality = 'F@z1' set ob_tcp_invited_nodes='%';

eval  CREATE RESOURCE POOL pool_oracle UNIT = 'unit', UNIT_NUM = 1, ZONE_LIST = ('z1');
eval  CREATE TENANT tenant_oracle RESOURCE_POOL_LIST = ('pool_oracle'), primary_zone='z1', locality = 'F@z1' set ob_tcp_invited_nodes='%', ob_compatibility_mode='oracle';

ob_connect(conn_mysql, ob1.z1.obs0, root@tenant, , test, , USE_OB_CONNECTOR);
ob_connect(conn_oracle, ob1.z1.obs0, SYS@tenant_oracle, , SYS, , USE_OB_CONNECTOR);
# **************************** mysql ************************************
connection conn_mysql;

# 1. create restore point
create table t(id int primary key, k int);
insert into t values(1,1);
sleep 1;
create restore point p1;
update t set k=2 where id=1;
select name from oceanbase.v$restore_point;
# p1

# 2. search with restore point
select * from t;
# 1  2

let $snapshot = deploy_get_value(ob1.select select snapshot from  oceanbase.v\$restore_point where name= 'p1', snapshot, 1);
eval select * from t as of snapshot $snapshot;
# 1 1

# 3. delete restore point
drop restore point p1;
select name from oceanbase.v$restore_point;

# ****************************** oracle ***********************************
connection conn_oracle;

# 4. create restore point
create table t(id int primary key, k int);
insert into t values(1,1);
sleep 1;
create restore point p1;
update t set k=2 where id=1;
select name from v$restore_point;
# P1

# 5. search with restore point
select * from t;
# 1  2

# we can not test oracle with deploy_get_value
# let $scn = deploy_get_value(ob1.select_cur_tenant select scn from  v\$restore_point where name='P1', scn, 1);
#sleep 1;
#eval select * from t as of scn $scn;
# 1 1

# 6. delete restore point
drop restore point p1;
select name from v$restore_point;



