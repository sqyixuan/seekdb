# owner: weixue.cx
# owner group: storage
# description: 转储未提交事务 lob test

--disable_query_log
ob1=OBI(cluster=1:1, proxy_num=1, init_unit_cpu=2, init_unit_num = 1);
ob1.reboot;

ob1.mysql alter system set enable_auto_leader_switch=false;
ob1.mysql alter system set enable_rereplication = false;
ob1.mysql alter system set enable_rebalance = false;
ob1.mysql alter system set _mini_merge_concurrency = 6;
ob1.mysql alter system set minor_compact_trigger = 10; 
ob1.mysql alter tenant obtest primary_zone='z1';
ob1.mysql alter system set debug_sync_timeout = '1000000s';

let $ip0=deploy_get_value(ob1.z1.obs0.ip);
let $port0=deploy_get_value(ob1.z1.obs0.port);
let $sql_port0=deploy_get_value(ob1.z1.obs0.mysql_port);

connect(conn0,$ip0,root@sys,,oceanbase,$sql_port0);

# 测试用连接
connect(conn1,$ip0,root@obtest,,test,$sql_port0);
connection conn1;
set global max_allowed_packet=500000000;
set global ob_query_timeout = 100000000000;
set global ob_trx_timeout = 100000000000;
set global ob_trx_idle_timeout = 10000000000;

connect(conn_obtest,$ip0,root@obtest,,test,$sql_port0);

connection conn_obtest;
create table t1 (pk1 int primary key, f1 mediumtext, c2 varchar(65535)) compression "none";
let $cnt =1;
while ($cnt < 100)
{
  eval insert into t1 values($cnt, repeat('a', 10000000), repeat('b', 65535));
  inc $cnt;
}

begin;
while ($cnt < 102)
{
  eval insert into t1 values($cnt, repeat('a', 10000000), repeat('b', 65535));
  inc $cnt;
}

ob1.mysql set ob_global_debug_sync = 'BLOCK_WEAK_READ_TIMESTAMP wait_for continue_signal';

let $tid = deploy_get_value(ob1.select select table_id from  __all_virtual_table where table_name = 't1', table_id, 1);

ob1.mysql alter system minor freeze tenant = sys;
ob1.mysql alter system minor freeze tenant = all_user;
ob1.mysql alter system minor freeze tenant = all_meta;

connection conn_obtest;
commit;
ob1.check_until_timeout select count(1) from oceanbase.__all_virtual_table_mgr where table_id = $tid and table_type = 0 and is_active = 0, 0, 300;


while ($cnt < 120)
{
  eval insert into t1 values($cnt, repeat('a', 10000000), repeat('b', 65535));
  inc $cnt;
}


ob1.mysql alter system minor freeze tenant = sys;
ob1.mysql alter system minor freeze tenant = all_user;
ob1.mysql alter system minor freeze tenant = all_meta;
ob1.check_until_timeout select count(1) from oceanbase.__all_virtual_table_mgr where table_id = $tid and table_type = 0 and is_active = 0, 0, 300;

ob1.mysql set ob_global_debug_sync = 'now signal continue_signal';

ob1.mysql alter system set minor_compact_trigger = 1;
ob1.check_until_timeout select count(1) from oceanbase.__all_virtual_table_mgr where table_id = $tid and table_type = 7, 2, 300;

--enable_query_log
connection conn_obtest;
select sum(length(f1)) from t1;
