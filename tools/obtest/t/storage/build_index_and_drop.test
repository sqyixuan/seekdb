# owner: yongle.xh
# owner group: storage
# description:this case is use for test migrate replica src to dst 
#
--disable_query_log
ob1=OBI(cluster=1:1:1,proxy_num=0,init_unit_cpu=2);
ob1.reboot;

ob1.mysql alter system set merger_check_interval='10s';
ob1.mysql alter system set enable_rebalance = 'false';
ob1.mysql alter system set enable_auto_leader_switch=true;
ob1.mysql alter system set debug_sync_timeout = '1000s';
ob1.mysql alter system set resource_hard_limit=500;
ob1.mysql alter system suspend merge;
ob1.mysql alter tenant obtest primary_zone='z1';

let $ip0=deploy_get_value(ob1.z1.obs0.ip);
let $sql_port0=deploy_get_value(ob1.z1.obs0.mysql_port);
connect(conn0,$ip0,root@obtest,,test,$sql_port0);
connection conn0;

sleep 5;
create table test01 (pk1 int, pk2 int, pk3 int, f1 varchar(1024), f2 varchar(4096), primary key(pk1,pk2,pk3));
let $cnt =1;
while ($cnt < 10)
{
	eval insert into test01 values($cnt, $cnt, $cnt, 'abc', 'def');
	inc $cnt;
}
#ob1.mysql set ob_global_debug_sync = 'BEFORE_LOCAL_INDEX_WAIT_TRANS_END wait_for continue_signal execute 1000000';
sleep 2;
create index i1 on test01(pk3);

ob1.mysql alter system major freeze;

ob1.check_until_timeout select count(1) from __all_virtual_freeze_info where frozen_version=2, 1, 60;
drop index i1 on test01;
sleep 2;

ob1.mysql alter system resume merge;
sleep 30;
ob1.z1.check_version 2;

#ob1.mysql set ob_global_debug_sync = 'now signal continue_signal';
#ob1.mysql set ob_global_debug_sync = 'BEFORE_LOCAL_INDEX_WAIT_TRANS_END clear';
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table_mgr where table_type=0 and is_active=0, 0, 90;

ob1.mysql alter system major freeze;
ob1.check_version 3;
select * from test01;

