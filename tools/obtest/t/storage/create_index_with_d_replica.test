# owner: chenqun
# owner group: storage
# description:this case is use for create index test
#
--disable_query_log
ob1=OBI(cluster=1:1:1,proxy_num=0,init_unit_cpu=2);
ob1.reboot;
sleep 5;

ob1.mysql alter system set merger_check_interval='10s';
ob1.mysql alter system set enable_rebalance = 'false';
ob1.mysql alter system set resource_hard_limit=500;
#ob1.mysql alter resource pool obtestpool unit_num 2;

ob1.mysql CREATE RESOURCE UNIT obstress MAX_CPU=2, MIN_CPU=2, MIN_MEMORY='10G', MAX_MEMORY='10G', MAX_DISK_SIZE='100G', MAX_IOPS=10000, MAX_SESSION_NUM=9223372036854775807;
ob1.mysql CREATE RESOURCE POOL pool_obstress0 unit='obstress', unit_num=1;
ob1.mysql CREATE TENANT obstress0 RESOURCE_POOL_LIST=('pool_obstress0'), locality = "F{1,memstore_percent:100}@z1,F{1,memstore_percent:0}@z2,L@z3" set ob_tcp_invited_nodes='%';

#在zone1上建立连接
let $ip=deploy_get_value(ob1.z1.obs0.ip);
let $port=deploy_get_value(ob1.z1.obs0.mysql_port);
connect (conn1,$ip,admin@obtest,admin,oceanbase,$port);
connect (conn2,$ip,root@sys,,oceanbase,$port);
connection conn1;
use test;

create table t1(c1 varchar(10) primary key, c2 varchar(8), c3 int);

insert into t1(c1, c3) values('test', 2);

create index i1 on t1(c2) local;
create unique index i2 on t1(c2) local;
