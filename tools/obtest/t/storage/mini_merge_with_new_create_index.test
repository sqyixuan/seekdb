# owner: chaser.ch
# owner group: storage
# Test the case: check mini merge of the old frozen memtable with new create index 
ob1=OBI(cluster=1,proxy_num=0,init_unit_cpu=2);
ob1.reboot;
ob1.mysql alter system set debug_sync_timeout = '1000s';
ob1.mysql alter system set _ob_minor_merge_schedule_interval = '3s';
ob1.mysql alter system suspend merge;;
let $ip=deploy_get_value(ob1.z1.obs0.ip);
let $port=deploy_get_value(ob1.z1.obs0.mysql_port);
connect (conn1,$ip,root@obtest,,test,$port);
connection conn1;
create user if not exists __oceanbase_inner_drc_user;
grant all privileges on *.* to __oceanbase_inner_drc_user;
sleep 5;
ob_connect(conn_drc_user, ob1.z1.obs0, __oceanbase_inner_drc_user@obtest, , test, , USE_MYSQL_CONNECTOR);
connection conn_drc_user;

create table t1(c1 int primary key, c2 int, c3 int);

let $tid = deploy_get_value(ob1.select select table_id from  __all_virtual_table where table_name = 't1', table_id, 1);


insert into t1 values(1,1,1), (2,2,2), (3,3,3);
sleep 5;
ob1.mysql alter system minor freeze tenant = sys;
ob1.mysql alter system minor freeze tenant = all_user;
ob1.mysql alter system minor freeze tenant = all_meta;
ob1.check_until_timeout select count(1) from oceanbase.__all_virtual_table_mgr where index_id = $tid and table_type = 7, 1, 300;
sleep 5;

ob1.mysql alter system major freeze;
sleep 5;

insert into t1 values(4,4,4), (5,5,5);
ob1.mysql alter system minor freeze tenant = sys;
ob1.mysql alter system minor freeze tenant = all_user;
ob1.mysql alter system minor freeze tenant = all_meta;
sleep 5;
ob1.check_until_timeout select count(1) from oceanbase.__all_virtual_table_mgr where index_id = $tid and table_type = 7, 2, 300;

insert into t1 values(6,6,6), (7,7,7);
ob1.mysql alter system minor freeze tenant = sys;
ob1.mysql alter system minor freeze tenant = all_user;
ob1.mysql alter system minor freeze tenant = all_meta;
sleep 5;
ob1.check_until_timeout select count(1) from oceanbase.__all_virtual_table_mgr where index_id = $tid and table_type = 7, 3, 300;

let $endts = deploy_get_value(ob1.select select max(end_log_ts) as max_ts from  __all_virtual_table_mgr where index_id = $tid and table_type = 7, max_ts, 1);

ob1.check_until_timeout select last_replay_log_ts from __all_virtual_partition_info where table_id = $tid, $endts, 300;

ob1.mysql set ob_global_debug_sync = 'BEFORE_BUILD_LOCAL_INDEX wait_for continue_signal execute 1000000';
connection conn_drc_user;
create index i2 on t1(c2) local;
let $iid = deploy_get_value(ob1.select select table_id from  __all_virtual_table where data_table_id= $tid, table_id, 1);

let $cnt = 1;
while ($cnt <= 6)
{
    let $mini_cnt = deploy_get_value(ob1.select select count(1) as cnt from oceanbase.__all_virtual_table_mgr where index_id = $iid and table_type =7, cnt, 1);
    if ($mini_cnt > 0)
    {
     --echo unexpected mini sstable with new create index
    }
     --echo mini_cnt : "$mini_cnt" ,  index_id: "$iid"
    inc $cnt;
    sleep 10;
}

ob1.mysql set ob_global_debug_sync = 'now signal continue_signal';
ob1.mysql set ob_global_debug_sync = 'BEFORE_BUILD_LOCAL_INDEX clear';

sleep 5;
ob1.check_until_timeout select count(1) as c from oceanbase.__all_virtual_table_mgr where table_type = 0 and is_active=0, 0, 300;
