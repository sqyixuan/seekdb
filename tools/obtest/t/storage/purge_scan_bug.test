# owner: zhenjiang.xzj
# owner group: storage
# Test the case: scan query for purge

ob1=OBI(cluster=1, proxy_num=0,init_unit_cpu=2);
ob1.reboot;

let $ip0=deploy_get_value(ob1.z1.obs0.ip);
let $sql_port0=deploy_get_value(ob1.z1.obs0.mysql_port);

ob1.mysql alter system set resource_hard_limit=800;
ob1.mysql alter system set merger_switch_leader_duration_time=0;
ob1.mysql alter system set enable_auto_leader_switch=false;
ob1.mysql alter system set enable_rereplication=false;
ob1.mysql alter system set enable_rebalance=false;


let $ip=deploy_get_value(ob1.z1.obs0.ip);
let $port=deploy_get_value(ob1.z1.obs0.mysql_port);
connect (conn0,$ip,admin@obtest,admin,oceanbase,$port);
connect (conn1,$ip,root@sys,,oceanbase,$port);
connection conn0;

use test;
create table test.t1(c1 int, c2 int, primary key(c1));
create index i1 on t1(c2);

--disable_query_log
let $cnt=1000;
while($cnt < 1100)
{
  eval insert into test.t1 values($cnt, $cnt);
  inc $cnt;
}
--enable_query_log

ob1.mysql alter system major freeze;
ob1.check_version 2;

--disable_query_log
let $cnt=1;
while($cnt < 1000)
{
  eval insert into test.t1 values($cnt, $cnt);
  inc $cnt;
}
--enable_query_log

delete from test.t1 where c1 < 1000;

ob1.mysql alter system minor freeze tenant = sys;
ob1.mysql alter system minor freeze tenant = all_user;
ob1.mysql alter system minor freeze tenant = all_meta;
sleep 120;

--disable_query_log
let $cnt=3;
while($cnt < 1000)
{
  eval insert into test.t1 values($cnt, $cnt);
  inc $cnt;
}
--enable_query_log

delete from test.t1 where c1 < 800 and c1 > 10;

set ob_enable_index_direct_select = 1;
sleep 2;

select * from __idx_1100611139453777_i1;
select * from __idx_1100611139453777_i1 where c1 = 1000;
