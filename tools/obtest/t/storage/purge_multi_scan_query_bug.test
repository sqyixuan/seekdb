# owner: zhenjiang.xzj
# owner group: storage
# Test the case: multi scan query for purge

ob1=OBI(cluster=1, proxy_num=0,init_unit_cpu=2);
ob1.reboot;

let $ip0=deploy_get_value(ob1.z1.obs0.ip);
let $sql_port0=deploy_get_value(ob1.z1.obs0.mysql_port);

ob1.mysql alter system set resource_hard_limit=800;
ob1.mysql alter system set merger_switch_leader_duration_time=0;
ob1.mysql alter system set enable_auto_leader_switch=false;
ob1.mysql alter system set enable_rereplication=false;
ob1.mysql alter system set enable_rebalance=false;

let $ip=deploy_get_value(ob1.z1.obs0.ip);
let $port=deploy_get_value(ob1.z1.obs0.mysql_port);
connect (conn0,$ip,admin@obtest,admin,oceanbase,$port);
connect (conn1,$ip,root@sys,,oceanbase,$port);
connection conn0;

use test;
create table test.t1(c1 int, c2 varchar(4096), primary key(c1, c2)) compression 'none';

--disable_query_log
--disable_result_log
let $cnt=10000;
while($cnt < 12000)
{
  eval insert into test.t1 values($cnt, repeat(rand(), 100));
  inc $cnt;
}

while($cnt < 10300)
{
  eval insert into test.t1 values($cnt, repeat(rand(), 100));
  inc $cnt;
}

ob1.mysql alter system major freeze;
ob1.check_version 2;

delete from test.t1 where c1 <= 10913 and c1 > 1;
select * from test.t1;
delete from test.t1 where c1 = 10914;
--enable_query_log
--enable_result_log
select c1 from test.t1 where c1 < 10913 or c1 >= 10914 and c1 < 11200;
