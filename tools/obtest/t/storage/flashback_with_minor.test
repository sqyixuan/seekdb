# owner: weixue.cx
# owner group: storage
# description: test flash back with minor 
##

ob1=OBI(cluster=1:1:1,proxy_num=0,init_unit_cpu=5);
ob1.reboot;
sleep 5;

ob1.mysql alter system set enable_auto_leader_switch='false';
ob1.mysql alter system set debug_sync_timeout = '1000000s';
ob1.mysql alter system set minor_compact_trigger = 10;
ob1.mysql alter system set syslog_io_bandwidth_limit = '10G';
ob1.mysql alter system set fuse_row_cache_priority = 1000;

ob1.mysql create resource unit flashback_box max_cpu 2, max_memory 2073741824, max_iops 100000, max_disk_size '5G', max_session_num 64, MIN_CPU=1, MIN_MEMORY=2073741824, MIN_IOPS=128;
ob1.mysql create resource pool flashback_pool unit = 'flashback_box', unit_num = 1;
ob1.mysql create tenant oracle replica_num = 1, resource_pool_list=('flashback_pool') set ob_tcp_invited_nodes='%', ob_compatibility_mode='oracle';
ob1.mysql alter tenant oracle set variables autocommit='on';

sleep 30;

ob_connect(conn_oracle, ob1, SYS@oracle, ,SYS, , USE_OB_CONNECTOR);
connection conn_oracle;
create user obtest IDENTIFIED BY "obtest";
grant all on *.* to obtest WITH GRANT OPTION;
grant dba to obtest;

ob_connect(conn1,ob1,OBTEST@oracle,obtest,obtest,,USE_OB_CONNECTOR);

let $ip=deploy_get_value(ob1.z1.obs0.ip);
let $mysql_port=deploy_get_value(ob1.z1.obs0.mysql_port);
let $port=deploy_get_value(ob1.z1.obs0.port);
connect (conn2,$ip,root@sys,,oceanbase,$mysql_port);

connection conn1;
set global UNDO_RETENTION = 2;

create table t1 (c1 int primary key, c2 int, c3 int) primary_zone = 'z1';

insert into t1 values (1,1,1);
insert into t1 values (2,2,2);
insert into t1 values (3,3,3);

sleep 3;
let $ts0 = deploy_get_value(ob1.select select time_to_usec(now(6)) as t from dual, t, 1);
sleep 3;

delete from t1 where c1 = 2;

--disable_query_log
eval flashback table t1 to scn $ts0;
--enable_query_log

select * from t1 where c1 = 0;

ob1.mysql set ob_global_debug_sync = 'BEFORE_UPDATE_FREEZE_SNAPSHOT_INFO wait_for continue_signal';
ob1.mysql set ob_global_debug_sync = 'MINOR_MERGE_TIMER_TASK wait_for merge_signal';

sleep 30;

ob1.mysql alter system major freeze;

sleep 15;

let $major_snapshot = deploy_get_value(ob1.select select frozen_snapshot from __all_virtual_freeze_info where frozen_version = 2, frozen_snapshot, 1);
let $tid = deploy_get_value(ob1.select select table_id from  __all_virtual_table where table_name = 't1', table_id, 1);

delete from t1 where c1 > 1;
insert into t1 values (4,4,4);
update t1 set c2 = 10 where c1 = 1;

sleep 3;
--disable_query_log
eval flashback table t1 to scn ($major_snapshot + 10);
--enable_query_log
sleep 3;

insert into t1 values (5,5,5);
update t1 set c3 = 10 where c1 = 1;

ob1.mysql alter system set minor_compact_trigger = 1;
ob1.mysql alter system minor freeze tenant = sys;
ob1.mysql alter system minor freeze tenant = all_user;
ob1.mysql alter system minor freeze tenant = all_meta;

ob1.mysql set ob_global_debug_sync = 'now signal merge_signal';

ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table_mgr where table_type = 0 and is_active = 0 and table_id = $tid, 0, 120;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table_mgr where table_type = 7 and table_id = $tid and svr_ip = "$ip" and svr_port = $port, 1, 120;

ob1.mysql set ob_global_debug_sync = 'now signal continue_signal';

ob1.check_version 2;

update t1 set c2 = 50 where c1 = 5;
ob1.mysql alter system minor freeze tenant = sys;
ob1.mysql alter system minor freeze tenant = all_user;
ob1.mysql alter system minor freeze tenant = all_meta;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table_mgr where table_type = 0 and is_active = 0 and table_id = $tid, 0, 120;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table_mgr where table_type = 7 and table_id = $tid and svr_ip = "$ip" and svr_port = $port, 2, 120;

select * from t1;

insert into t1 values (6,6,6);
update t1 set c2 = 30 where c1 = 3;
sleep 3;
let $ts1 = deploy_get_value(ob1.select select time_to_usec(now(6)) as t from dual, t, 1);
sleep 3;
insert into t1 values (7,7,70);
update t1 set c2 = 300 where c1 = 3;

--disable_query_log
eval flashback table t1 to scn $ts1;
--enable_query_log

select * from t1;

ob1.mysql alter system minor freeze tenant = sys;
ob1.mysql alter system minor freeze tenant = all_user;
ob1.mysql alter system minor freeze tenant = all_meta;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table_mgr where table_type = 0 and is_active = 0 and table_id = $tid, 0, 120;

ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table_mgr where table_type = 1 and table_id = $tid and svr_ip = "$ip" and svr_port = $port, 1, 120;



update t1 set c3 = 300 where c1 = 3;
insert into t1 values (7,7,7);

select * from t1;

ob1.mysql alter system minor freeze tenant = sys;
ob1.mysql alter system minor freeze tenant = all_user;
ob1.mysql alter system minor freeze tenant = all_meta;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table_mgr where table_type = 0 and is_active = 0 and table_id = $tid, 0, 120;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table_mgr where table_type = 7 and table_id = $tid and snapshot_version > $major_snapshot and svr_ip = "$ip" and svr_port = $port, 4, 120;

select * from t1;

ob1.mysql alter system set minor_compact_trigger = 1;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table_mgr where table_type = 7 and table_id = $tid and snapshot_version > $major_snapshot and svr_ip = "$ip" and svr_port = $port, 2, 180;

select * from t1;

ob1.mysql alter system major freeze;
ob1.check_version 3;

select * from t1 where c1 = 3;
select * from t1;

insert into t1 values (8,8,8);
update t1 set c2 = 70 where c1 = 7;
update t1 set c3 = 70 where c1 = 7;
ob1.mysql alter system minor freeze tenant = sys;
ob1.mysql alter system minor freeze tenant = all_user;
ob1.mysql alter system minor freeze tenant = all_meta;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table_mgr where table_type = 0 and is_active = 0 and table_id = $tid, 0, 120;

insert into t1 values (9,9,9);
ob1.mysql alter system minor freeze tenant = sys;
ob1.mysql alter system minor freeze tenant = all_user;
ob1.mysql alter system minor freeze tenant = all_meta;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table_mgr where table_type = 0 and is_active = 0 and table_id = $tid, 0, 120;

select * from t1 where c1 = 7;
