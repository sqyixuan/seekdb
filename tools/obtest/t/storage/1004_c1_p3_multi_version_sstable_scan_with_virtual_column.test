# owner: lingcang
# owner group: storage
# bug_15049340

--disable_query_log
ob1=OBI(cluster=1,proxy_num=0,init_unit_cpu=2);
ob1.reboot;

ob1.mysql alter system set resource_hard_limit = 800;
ob1.mysql alter system set merger_switch_leader_duration_time = 0;
ob1.mysql alter system set enable_auto_leader_switch = false;
ob1.mysql alter system set enable_rereplication = false;
ob1.mysql alter system set enable_rebalance = false;

let $ip=deploy_get_value(ob1.z1.obs0.ip);
let $port=deploy_get_value(ob1.z1.obs0.mysql_port);
connect (conn1,$ip,admin@obtest,admin,oceanbase,$port);
connect (conn2,$ip,root@sys,,oceanbase,$port);
connection conn1;

use test;
create table test01 (pk1 int(11) NOT NULL, pk2 int(11) NOT NULL, first_name varchar(100) DEFAULT NULL, last_name varchar(100) DEFAULT NULL, full_name varchar(100) GENERATED ALWAYS AS (concat(first_name, last_name)) VIRTUAL, PRIMARY KEY (pk1, pk2));

#插入数据
insert into test01 (pk1, pk2, first_name, last_name) values (482285402, -57, 'devi', 'budle');

#触发小版本冻结
ob1.mysql alter system minor freeze tenant = sys;
ob1.mysql alter system minor freeze tenant = all_user;
ob1.mysql alter system minor freeze tenant = all_meta;

#验证转储成功
let $tid = deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where table_name='test01', table_id, 1);
ob1.z1.obs0.check_log_until_success -c "sstable merge finish.*merge_type:2.*$tid";
sleep 30;

select * from test01;
