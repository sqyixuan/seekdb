# owner: jingyan.kfy
# owner group: storage
# description:this case is use for test replica type persistence
#
--disable_query_log
ob1=OBI(cluster=2:2:2,proxy_num=0,init_unit_cpu=4);
ob1.reboot;

ob1.mysql alter system set merger_check_interval='10s';
ob1.mysql alter system set enable_rebalance = 'false';
ob1.mysql alter system set enable_rereplication = 'false';
ob1.mysql alter system set enable_auto_leader_switch=false;
ob1.mysql alter system set balancer_idle_time='10s';
ob1.mysql alter system set resource_hard_limit=500;
ob1.mysql alter resource pool obtestpool unit_num 2;

let $ip = deploy_get_value(ob1.z1.obs1.ip);
let $port = deploy_get_value(ob1.z1.obs1.mysql_port);
connect (conn1,$ip,root@obtest,,test,$port);
connection conn1;

sleep 5;
use test;
create table test01 (c1 int primary key, c2 int) locality="F,R@z1, F,R@z2, F,R@z3";
let $cnt =1;
while ($cnt < 10)
{
	eval insert into test01 values($cnt, $cnt);
	inc $cnt;
}

let $follower = deploy_get_value(ob1.get_follower obtest:test:test01);
let $follower_ip = deploy_get_value($follower.ip);
let $follower_port = deploy_get_value($follower.port);
let $tid = deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where table_name = "test01", table_id, 1);

# remove one READONLY replica to prevent auto replica type change
let $drop_ip_port = deploy_get_value(ob1.select select concat(svr_ip,":",svr_port) addr from oceanbase.__all_virtual_meta_table where table_id = $tid and partition_id = 0 and role = 2 and replica_type = 16 and zone='z1', addr, 1);
ob1.mysql alter system drop replica partition_id='0%1@$tid' server='$drop_ip_port';

# change FULL replica to READONLY replica, that will write slog
let $change_ip_port = deploy_get_value(ob1.select select concat(svr_ip,":",svr_port) addr from oceanbase.__all_virtual_meta_table where table_id = $tid and partition_id = 0 and role = 2 and replica_type = 0 and svr_ip='$follower_ip' and svr_port='$follower_port', addr, 1);
ob1.mysql alter system change replica partition_id='0%1@$tid' server='$change_ip_port' change replica_type='R';
sleep 60;

$follower.force_stop;
$follower.restart;
sleep 60;
