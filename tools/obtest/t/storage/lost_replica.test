# owner: zhenjiang.xzj
# description: 测试迁移补副本的功能

--disable_query_log
ob1=OBI(cluster=1:1:1,proxy_num=0,init_unit_cpu=1);
ob1.reboot;
--enable_query_log

ob1.mysql create resource pool rp1 unit = 'sys_unit_config', unit_num = 1, zone_list = ('z1', 'z2', 'z3');
ob1.mysql create tenant tt1 replica_num 3, primary_zone 'z1', resource_pool_list ('rp1') set ob_tcp_invited_nodes='%';

let $ip00 = deploy_get_value(ob1.z1.obs0.ip);
let $mysql_port00 = deploy_get_value(ob1.z1.obs0.mysql_port);
let $port00 = deploy_get_value(ob1.z1.obs0.port);
connect(tt1_conn,$ip00,root@obtest,,test, $mysql_port00);


#ob1.mysql alter system set server_temporary_offline_time = '20s';
ob1.mysql alter system set merger_check_interval = '10s';
ob1.mysql alter system set server_permanent_offline_time = '20s';
connection tt1_conn;
create table test(c1 int primary key, c2 int);
insert into test values(1,2),(3,4),(5,6);
ob1.mysql_p alter system major freeze;
ob1.z3.obs0.force_stop;
sleep 30;
ob1.z3.obs0.nstart;
sleep 60;
ob1.check_version 2;


