# owner: muwei.ym
# owner group: storage
# Test the case: memstore_percent=0 and migrate

ob1=OBI(cluster=1:1:1,proxy_num=1,init_unit_cpu=2);
ob1.reboot;

let $ip2=deploy_get_value(ob1.z2.obs0.ip);
let $port2=deploy_get_value(ob1.z2.obs0.port);

let $ip3=deploy_get_value(ob1.z3.obs0.ip);
let $port3=deploy_get_value(ob1.z3.obs0.port);
let $sql_port3=deploy_get_value(ob1.z3.obs0.mysql_port);

ob1.mysql alter system set enable_auto_leader_switch=false;
ob1.mysql alter system set minor_deferred_gc_time='3600s';
ob1.mysql alter system set _follower_replica_merge_level=1;
ob1.mysql alter system set server_data_copy_in_concurrency=10;
ob1.mysql alter system set server_data_copy_out_concurrency=10;
ob1.mysql alter system set debug_sync_timeout = '100000s';
ob1.mysql alter system set merge_thread_count = 64;
ob1.mysql alter system set minor_merge_concurrency = 64;
ob1.mysql set ob_global_debug_sync = 'BEFORE_GET_MINOR_MERGE_TABLE_IDS wait_for continue_signal execute 10000'; 

ob1.z2.obs0.force_stop;
ob1.check_until_timeout select status from oceanbase.__all_server where svr_ip='$ip2' and svr_port = $port2, inactive, 60;
ob1.z2.obs0.restart;
ob1.check_until_timeout select status from oceanbase.__all_server where svr_ip='$ip2' and svr_port = $port2 and start_service_time != 0, active, 60;



connect(conn1,$ip3,root@sys,,oceanbase,$sql_port3);

connection conn1;
set ob_trx_timeout=100000000;
set ob_query_timeout=100000000;
create resource pool rp1 unit = 'sys_unit_config', unit_num = 1, zone_list = ('z1', 'z2', 'z3');
create tenant tt1 replica_num 3, primary_zone 'z2', resource_pool_list ('rp1'), locality = "L@z1,F{1,memstore_percent:100}@z2,F{1,memstore_percent:0}@z3" set ob_tcp_invited_nodes='%';
sleep 10;


connect(conn0,$ip3,root@tt1,,test,$sql_port3);
connection conn0;
create table test.t1(c1 int primary key, c2 int, c3 int, unique key u_idx(c2), index idx(c3));
let $table_id = deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where table_name='t1', table_id, 1);


ob1.check_until_timeout select role from oceanbase.__all_virtual_meta_table where svr_ip='$ip2' and svr_port = $port2 and table_id=$table_id, 1, 60;

# check basic dml
connection conn0;
--disable_query_log
let $cnt = 1;
while ($cnt <= 10)
{
    eval insert into test.t1 values($cnt, $cnt + 1, $cnt + 2);
    inc $cnt;
}

select * from test.t1;


connection conn0;
while ($cnt <= 15)
{
  eval insert into test.t1 values($cnt, $cnt + 1, $cnt + 2);
  ob1.mysql alter system minor freeze tenant = sys;
  ob1.mysql alter system minor freeze tenant = all_user;
  ob1.mysql alter system minor freeze tenant = all_meta;
  ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table_mgr where table_type=0 and is_active=0, 0, 600;
  inc $cnt;
}

ob1.check_until_timeout select count(*)  > 0 from oceanbase.__all_virtual_partition_migration_status where table_id = $table_id and result = 0 and action='END', 1, 100;
ob1.mysql_p select count(*) from oceanbase.__all_virtual_partition_migration_status where table_id = $table_id and result != 0;
ob1.mysql_p select sum(copy_size) - sum(mini_minor_size) from oceanbase.__all_virtual_partition_migration_status where table_id = $table_id;

select * from test.t1;
