# owner: jingyan.kfy
# owner group: storage
# description: test readonly/log replica exchange
#
--disable_query_log
ob1=OBI(cluster=2:2:2,proxy_num=0,init_unit_cpu=4);
ob1.reboot;

ob1.mysql alter system set merger_check_interval='10s';
ob1.mysql alter system set enable_rebalance = 'false';
ob1.mysql alter system set enable_rereplication = 'false';
ob1.mysql alter system set enable_auto_leader_switch=false;
ob1.mysql alter system set balancer_idle_time='10s';
ob1.mysql alter system set resource_hard_limit=500;
ob1.mysql alter resource pool obtestpool unit_num 2;

let $ip0=deploy_get_value(ob1.z1.obs0.ip);
let $sql_port0=deploy_get_value(ob1.z1.obs0.mysql_port);
connect(conn0,$ip0,root@obtest,,test,$sql_port0);
connection conn0;

sleep 5;
create table test01 (c1 int primary key, c2 int) locality="F,R@z1, F,R@z2, F,R@z3";
let $cnt =1;
while ($cnt < 10)
{
	eval insert into test01 values($cnt, $cnt);
	inc $cnt;
}

ob1.mysql alter system major freeze;
ob1.check_version 2;

while ($cnt < 20)
{
  eval insert into test01 values($cnt, $cnt);
  inc $cnt;
}

let $tid = deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where table_name = "test01", table_id, 1);

# remove one READONLY replica to prevent auto replica type change
let $drop_ip_port = deploy_get_value(ob1.select select concat(svr_ip,":",svr_port) addr from oceanbase.__all_virtual_meta_table where table_id = $tid and partition_id = 0 and role = 2 and replica_type = 16 and zone='z1', addr, 1);
ob1.mysql alter system drop replica partition_id='0%1@$tid' server='$drop_ip_port';
# remove a member from memberlist
let $follower_ip_port = deploy_get_value(ob1.select select concat(svr_ip,":",svr_port) addr from oceanbase.__all_virtual_meta_table where table_id = $tid and partition_id = 0 and role = 2 and replica_type = 0, addr, 1);
ob1.mysql alter system drop replica partition_id='0%1@$tid' server='$follower_ip_port';

## 1. READONLY ==> LOGONLY
# change FULL replica to LOGONLY replica
let $follower_ip = deploy_get_value(ob1.select select svr_ip from oceanbase.__all_virtual_meta_table where table_id = $tid and partition_id = 0 and role = 2 and replica_type = 16, svr_ip, 1);
let $follower_port = deploy_get_value(ob1.select select svr_port from oceanbase.__all_virtual_meta_table where table_id = $tid and partition_id = 0 and role = 2 and svr_ip = '$follower_ip' and replica_type = 16, svr_port, 1);
let $change_ip_port = deploy_get_value(ob1.select select concat('$follower_ip',':','$follower_port') addr from dual, addr, 1);
ob1.mysql alter system change replica partition_id='0%1@$tid' server='$change_ip_port' change replica_type='L';
sleep 5;

# check replica_type
ob1.mysql_p select replica_type from oceanbase.__all_virtual_meta_table where table_id = $tid and partition_id = 0 and svr_ip='$follower_ip' and svr_port='$follower_port';

# check minor merge
ob1.mysql alter system minor freeze tenant obtest;
sleep 5;
ob1.mysql_p select frozen_version, merged_version, active_version from oceanbase.__all_virtual_partition_info where table_id = $tid and partition_id = 0 and svr_ip='$follower_ip' and svr_port='$follower_port';
ob1.mysql_p select data_checksum from oceanbase.__all_virtual_meta_table where table_id = $tid and partition_id = 0 and svr_ip='$follower_ip' and svr_port='$follower_port';

# check major merge
ob1.mysql alter system major freeze;
ob1.check_version 3;
ob1.mysql_p select data_version, data_checksum from oceanbase.__all_virtual_meta_table where table_id = $tid and partition_id = 0 and svr_ip='$follower_ip' and svr_port='$follower_port';
ob1.mysql_p select count(*) from oceanbase.__all_virtual_partition_sstable_merge_info where table_id = $tid and partition_id = 0 and svr_ip='$follower_ip' and svr_port='$follower_port';


## 2. LOGONLY ==> FULL
# change LOGONLY replica to FULL replica
ob1.mysql alter system change replica partition_id='0%1@$tid' server='$change_ip_port' change replica_type='R';
sleep 5;
ob1.mysql_p select replica_type, data_version, data_checksum > 0 from oceanbase.__all_virtual_meta_table where table_id = $tid and partition_id = 0 and svr_ip='$follower_ip' and svr_port='$follower_port';

while ($cnt < 30)
{
  eval insert into test01 values($cnt, $cnt);
  inc $cnt;
}

# check major merge
ob1.mysql alter system major freeze;
ob1.check_version 4;
ob1.mysql_p select replica_type, data_version, data_checksum > 0 from oceanbase.__all_virtual_meta_table where table_id = $tid and partition_id = 0 and svr_ip='$follower_ip' and svr_port='$follower_port';
ob1.mysql_p select version from oceanbase.__all_virtual_partition_sstable_merge_info where table_id = $tid and partition_id = 0 and svr_ip='$follower_ip' and svr_port='$follower_port';

