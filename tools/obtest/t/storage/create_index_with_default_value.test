# owner: chenqun
# owner group: storage
# description:this case is use for create index test
#
--disable_query_log
ob1=OBI(cluster=1:1:1,proxy_num=0,init_unit_cpu=2);
ob1.reboot;

ob1.mysql alter system set merger_check_interval='10s';
ob1.mysql alter system set enable_rebalance = 'false';
ob1.mysql alter system set resource_hard_limit=500;
#ob1.mysql alter resource pool obtestpool unit_num 2;
#
let $ip = deploy_get_value(ob1.z1.obs0.ip);
let $port = deploy_get_value(ob1.z1.obs0.mysql_port);
connect (conn1,$ip,root@obtest,,test,$port);
connection conn1;

create table t1(c1 varchar(10) primary key);
insert into t1(c1) values('test');
ob1.mysql alter system major freeze;
sleep 60;
ob1.check_version 2;
alter table t1 add column c2 varchar(10) default 'yes';
alter table t1 add column c3 varchar(10) default 'no';
sleep 2;
create index i1 on t1(c2, c3);
ob1.mysql alter system major freeze;
sleep 60;
ob1.check_version 3;

ob1.check_until_timeout select index_status from oceanbase.__all_virtual_table where tenant_id=1001 and table_name like '%i1%', 2, 120;
select /*+ index(t1 i1) */ * from t1 where c2='yes';


