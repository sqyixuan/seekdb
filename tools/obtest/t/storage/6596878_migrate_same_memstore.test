###################
#author:yiwan
#owner: yiwan
#owner group:storage
#功能：bug覆盖（测试在partition迁出时是否清理了所有的memstore）
#
#场景：
#将一个partition先迁出，后迁入，检查是否发生版本冲突
###################
--disable_query_log
ob1=OBI(cluster=2:2:2,proxy_num=1,init_unit_cpu=2,init_unit_num=2);
ob1.reboot;

ob1.mysql alter system set merger_check_interval='10s';

let $ip=deploy_get_value(ob1.z1.obs0.ip);
let $port=deploy_get_value(ob1.z1.obs0.mysql_port);
connect (conn1,$ip,root@obtest,,test,$port);
connection conn1;

create table test01(c1 int primary key,c2 int,c3 varchar(64));
let $table_id=deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where table_name='test01', table_id, 1);
#insert data
let $cnt=10;
while($cnt>0)
{
   eval insert into test01 values($cnt,$cnt,'obtest_data');
   dec $cnt;
}
ob1.mysql alter system major freeze;
sleep 30;
ob1.check_frozen_version 2;
let $src=deploy_get_value(ob1.get_follower obtest:test:test01:0,1);
let $src_ip = deploy_get_value($src.ip);
let $src_port=deploy_get_value($src.port);
let $src_zone = deploy_get_value($src.zone);
let $dst_host = deploy_get_value(ob1.select select concat(svr_ip, ':', svr_port) host from oceanbase.__all_server where zone='$src_zone' and svr_port!='$src_port', host, 1);
let $dst = deploy_get_value(ob1.get_obs_by_addr $dst_host);
let $dst_ip = deploy_get_value($dst.ip);
sleep 10;
ob1.mysql_p select sum(mem_used) from oceanbase.__all_virtual_memstore_info where tenant_id=1002 && table_id=$table_id && svr_ip='$src_ip' && svr_port='$src_port';
#migrate
let $pkey = deploy_get_value(ob1.select select concat(tenant_id, ':', table_id, ':0') as pkey from oceanbase.__all_virtual_table where table_name='test01', pkey, 1);
$src.migrate_to $dst,obtest:test:test01;
ob1.wait_migrate_success $src,$dst,$pkey,30;
let $tenant_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name='obtest', tenant_id, 1);
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_meta_table where tenant_id=$tenant_id and table_id=$table_id and role=1 and member_list like '%$dst_ip%', 1, 120;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_meta_table a ,oceanbase.__all_virtual_meta_table b where a.tenant_id=$tenant_id and a.table_id=$table_id and b.table_id=$table_id  and a.member_list=b.member_list and a.role=1 and b.role=2 and b.svr_ip='$dst_ip', 1, 120;
ob1.mysql alter system set enable_rebalance = 'false';
sleep 20;

ob1.mysql_p select sum(mem_used) from oceanbase.__all_virtual_memstore_info where tenant_id=1002 && table_id=$table_id  && svr_ip='$src_ip' && svr_port='$src_port';


#ob1.mysql_p select total_memstore_used from oceanbase.__all_virtual_tenant_memstore_info where tenant_id!=1 && svr_ip='$dst_ip';




