#owner: yuanhong.wwj
#owner group: storage
#description: 
--disable_query_log
ob1=OBI(cluster=2:2:2,proxy_num=0,init_unit_cpu=2);
ob1.reboot;
sleep 10;

ob1.mysql alter system set merger_check_interval='10s';
ob1.mysql alter system set enable_rebalance = 'false';
ob1.mysql alter system set enable_rereplication = 'false';
ob1.mysql alter system set resource_hard_limit=500;
ob1.mysql alter resource pool obtestpool unit_num 2;

let $ip=deploy_get_value(ob1.z1.obs0.ip);
let $port=deploy_get_value(ob1.z1.obs0.mysql_port);
connect (conn1,$ip,root@obtest,,test,$port);
connection conn1;

# create partition
create table test01 (pk1 int, pk2 int, pk3 int, f1 varchar(1024), f2 varchar(4096), primary key(pk1,pk2,pk3));
let $pkey=deploy_get_value(ob1.select select concat(tenant_id, ':', table_id, ':0') as pkey from oceanbase.__all_virtual_table where table_name='test01', pkey, 1);

# insert data
let $cnt =1;
while ($cnt < 10)
{
        eval insert into test01 values($cnt, $cnt, $cnt, 'abc', 'def');
        inc $cnt;
}
# major freeze
ob1.mysql alter system major freeze;
sleep 30;
ob1.check_version 2;

let $src = deploy_get_value(ob1.get_follower obtest:test:test01:0,1);
let $dst = deploy_get_value(ob1.get_another_obs_in_same_zone $src);
$src.migrate_to $dst,obtest:test:test01;
ob1.wait_migrate_success $src,$dst,$pkey,60;

sleep 30;
$dst.migrate_to $src,obtest:test:test01;
ob1.wait_migrate_success $dst,$src,$pkey,60;
