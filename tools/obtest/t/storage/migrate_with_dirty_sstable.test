# owner: weixue.cx
# owner group: storage
# description: 转储未提交事务迁移测试

--disable_query_log
ob1=OBI(cluster=2:2:2, proxy_num=1, init_unit_cpu=2, init_unit_num = 2);
ob1.reboot;

ob1.mysql alter system set enable_auto_leader_switch=false;
ob1.mysql alter system set enable_rereplication = false;
ob1.mysql alter system set enable_rebalance = false;
ob1.mysql alter system set _mini_merge_concurrency = 6;
ob1.mysql alter system set minor_compact_trigger = 10; 
ob1.mysql alter tenant obtest primary_zone='z1';

let $ip0=deploy_get_value(ob1.z1.obs0.ip);
let $port0=deploy_get_value(ob1.z1.obs0.port);
let $sql_port0=deploy_get_value(ob1.z1.obs0.mysql_port);
let $ip1=deploy_get_value(ob1.z2.obs0.ip);
let $port1=deploy_get_value(ob1.z2.obs0.port);
let $sql_port1=deploy_get_value(ob1.z2.obs0.mysql_port);

connect(conn0,$ip0,root@sys,,oceanbase,$sql_port0);
connect(conn_obtest,$ip0,root@obtest,,test,$sql_port0);

connection conn_obtest;
set global ob_query_timeout = 100000000000;
set global ob_trx_timeout = 100000000000;
set global ob_trx_idle_timeout = 10000000000;

# 测试用连接
connect(conn1,$ip0,root@obtest,,test,$sql_port0);

connection conn_obtest;
create table t1 (c1 int primary key, c2 int);
create table t2 (c1 int primary key, c2 int) table_mode = 'queuing';

let $tid = deploy_get_value(ob1.select select table_id from  __all_virtual_table where table_name = 't1', table_id, 1);
let $tid2 = deploy_get_value(ob1.select select table_id from  __all_virtual_table where table_name = 't2', table_id, 1);

connection conn_obtest;
insert into t1 values (1,1);
insert into t1 values (2,2);
insert into t2 values (1,1);
insert into t2 values (2,2);
insert into t2 values (3,3);

connection conn1;
set global ob_query_timeout = 100000000000;
set global ob_trx_timeout = 100000000000;
set global ob_trx_idle_timeout = 10000000000;
begin;
insert into t1 values (3,3);
insert into t1 values (4,4);
delete from t2 where c1 = 1;

ob1.mysql alter system minor freeze tenant = sys;
ob1.mysql alter system minor freeze tenant = all_user;
ob1.mysql alter system minor freeze tenant = all_meta;
ob1.check_until_timeout select count(1) from oceanbase.__all_virtual_table_mgr where table_id = $tid and table_type = 0 and is_active = 0, 0, 300;
ob1.check_until_timeout select count(1) from oceanbase.__all_virtual_table_mgr where table_id = $tid2 and table_type = 0 and is_active = 0, 0, 300;

connection conn1;
commit;

ob1.mysql alter system major freeze;
sleep 30;
ob1.check_version 2;

connection conn_obtest;
set global ob_query_timeout = 100000000000;
set global ob_trx_timeout = 100000000000;
set global ob_trx_idle_timeout = 10000000000;
begin;
insert into t1 values (8,8);
insert into t1 values (9,9);
insert into t2 values (4,4);
insert into t2 values (5,5);

ob1.mysql alter system minor freeze tenant = sys;
ob1.mysql alter system minor freeze tenant = all_user;
ob1.mysql alter system minor freeze tenant = all_meta;
ob1.check_until_timeout select count(1) from oceanbase.__all_virtual_table_mgr where table_id = $tid and table_type = 0 and is_active = 0, 0, 300;
ob1.check_until_timeout select count(1) from oceanbase.__all_virtual_table_mgr where table_id = $tid2 and table_type = 0 and is_active = 0, 0, 300;

connection conn_obtest;
commit;
 
connection conn_obtest;
set global ob_query_timeout = 100000000000;
set global ob_trx_timeout = 100000000000;
set global ob_trx_idle_timeout = 10000000000;
begin;
update t1 set c2 = 100 where c1 = 1;
delete from t1 where c1 = 2;
delete from t2 where c1 <= 4;

ob1.mysql alter system minor freeze tenant = sys;
ob1.mysql alter system minor freeze tenant = all_user;
ob1.mysql alter system minor freeze tenant = all_meta;
ob1.check_until_timeout select count(1) from oceanbase.__all_virtual_table_mgr where table_id = $tid and table_type = 0 and is_active = 0, 0, 300;
ob1.check_until_timeout select count(1) from oceanbase.__all_virtual_table_mgr where table_id = $tid2 and table_type = 0 and is_active = 0, 0, 300;

connection conn_obtest;
commit;

ob1.check_until_timeout select count(1) from oceanbase.__all_virtual_table_mgr where table_id = $tid2 and table_type = 8, 3, 300;

let $src_host = deploy_get_value(ob1.select select concat(svr_ip, ':', svr_port) host from oceanbase.__all_virtual_meta_table where zone='z2' and table_id=$tid, host, 1);
let $src = deploy_get_value(ob1.get_obs_by_addr $src_host);
let $src_ip = deploy_get_value($src.ip);
let $src_port = deploy_get_value($src.port);
let $dst_host = deploy_get_value(ob1.select select concat(svr_ip, ':', svr_port) host from oceanbase.__all_server where zone='z2' and svr_port != $src_port and svr_ip != 'src_ip', host, 1);
let $dst = deploy_get_value(ob1.get_obs_by_addr $dst_host);
let $dst_ip = deploy_get_value($dst.ip);
let $dst_port = deploy_get_value($dst.port);
let $src_host2 = deploy_get_value(ob1.select select concat(svr_ip, ':', svr_port) host from oceanbase.__all_virtual_meta_table where zone='z2' and table_id=$tid2, host, 1);
let $src2 = deploy_get_value(ob1.get_obs_by_addr $src_host2);
let $src_ip2 = deploy_get_value($src2.ip);
let $src_port2 = deploy_get_value($src2.port);
let $dst_host2 = deploy_get_value(ob1.select select concat(svr_ip, ':', svr_port) host from oceanbase.__all_server where zone='z2' and svr_port != $src_port2 and svr_ip != 'src_ip2', host, 1);
let $dst2 = deploy_get_value(ob1.get_obs_by_addr $dst_host2);
let $dst_ip2 = deploy_get_value($dst2.ip);
let $dst_port2 = deploy_get_value($dst2.port);

$src.migrate_to $dst,obtest:test:t1;
$src2.migrate_to $dst2,obtest:test:t2;

ob1.check_until_timeout select count(1) from __all_virtual_meta_table where svr_ip = '$dst_ip' and svr_port = $dst_port and table_id = $tid and member_list like "%$dst_host%", 1, 60;
ob1.check_until_timeout select count(1) from __all_virtual_meta_table where svr_ip = '$dst_ip2' and svr_port = $dst_port2 and table_id = $tid2 and member_list like "%$dst_host2%", 1, 60;

ob1.mysql alter system switch replica leader partition_id='0%0@$tid' server='$dst_ip:$dst_port';
ob1.mysql alter system switch replica leader partition_id='0%0@$tid2' server='$dst_ip2:$dst_port2';
ob1.check_until_timeout select count(1) from __all_virtual_meta_table where svr_ip = '$dst_ip' and svr_port = $dst_port and table_id = $tid and member_list like "%$dst_host%" and role = 1, 1, 60;
ob1.check_until_timeout select count(1) from __all_virtual_meta_table where svr_ip = '$dst_ip2' and svr_port = $dst_port2 and table_id = $tid2 and member_list like "%$dst_host2%" and role = 1, 1, 60;
connection conn_obtest;
select * from t1;
select * from t2;


ob1.mysql alter system major freeze;
sleep 30;
ob1.check_version 3;

connection conn_obtest;
insert into t1 values (10, 10);
insert into t1 values (11, 11);

ob1.mysql alter system minor freeze tenant = sys;
ob1.mysql alter system minor freeze tenant = all_user;
ob1.mysql alter system minor freeze tenant = all_meta;
ob1.check_until_timeout select count(1) from oceanbase.__all_virtual_table_mgr where table_id = $tid and table_type = 0 and is_active = 0, 0, 300;

connection conn_obtest;
set global ob_query_timeout = 100000000000;
set global ob_trx_timeout = 100000000000;
set global ob_trx_idle_timeout = 10000000000;
begin;
insert into t1 values (12, 12);
delete from t1 where c1 = 11;
delete from t2 where c1 = 5;

ob1.mysql alter system minor freeze tenant = sys;
ob1.mysql alter system minor freeze tenant = all_user;
ob1.mysql alter system minor freeze tenant = all_meta;
ob1.check_until_timeout select count(1) from oceanbase.__all_virtual_table_mgr where table_id = $tid and table_type = 0 and is_active = 0, 0, 300;
ob1.check_until_timeout select count(1) from oceanbase.__all_virtual_table_mgr where table_id = $tid2 and table_type = 0 and is_active = 0, 0, 300;

connection conn_obtest;
rollback;

$dst.migrate_to $src,obtest:test:t1;
$dst2.migrate_to $src2,obtest:test:t2;

ob1.check_until_timeout select count(1) from __all_virtual_meta_table where svr_ip = '$src_ip' and svr_port = $src_port and table_id = $tid and member_list like "%$src_host%", 1, 60;
ob1.check_until_timeout select count(1) from __all_virtual_meta_table where svr_ip = '$src_ip2' and svr_port = $src_port2 and table_id = $tid2 and member_list like "%$src_host2%", 1, 60;

ob1.mysql alter system switch replica leader partition_id='0%0@$tid' server='$src_ip:$src_port';
ob1.mysql alter system switch replica leader partition_id='0%0@$tid2' server='$src_ip2:$src_port2';
ob1.check_until_timeout select count(1) from __all_virtual_meta_table where svr_ip = '$src_ip' and svr_port = $src_port and table_id = $tid and member_list like "%$src_host%" and role = 1, 1, 60;
ob1.check_until_timeout select count(1) from __all_virtual_meta_table where svr_ip = '$src_ip2' and svr_port = $src_port2 and table_id = $tid2 and member_list like "%$src_host2%" and role = 1, 1, 60;

connection conn_obtest;
select * from t1;
select * from t2;
