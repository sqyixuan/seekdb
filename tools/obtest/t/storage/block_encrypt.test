# owner: mingdou.tmd 
# owner group: storage 
# description: this case is use for encrypt
#
ob1=OBI(cluster=1:1:1,proxy_num=0,init_unit_cpu=2, init_unit_num=1);
ob1.reboot;

ob1.mysql alter system set enable_async_syslog=false;
ob1.mysql alter system set debug_sync_timeout = '100000s';


#在zone1上建立连接
let $ip=deploy_get_value(ob1.z1.obs0.ip);
let $port=deploy_get_value(ob1.z1.obs0.mysql_port);
connect (conn1,$ip,admin@obtest,admin,oceanbase,$port);
connect (conn2,$ip,root@sys,,oceanbase,$port);
connection conn1;
set global max_allowed_packet=50000000;

connect (conn3,$ip,admin@obtest,admin,oceanbase,$port);
connection conn3;

use test;

ALTER INSTANCE ROTATE INNODB MASTER KEY;

create tablespace ts1 encryption = 'y';

create table t1 (id1 int, id2 int) tablespace ts1;

insert into t1 values(1, 2);

create table t2(id1 int primary key, id2 longtext, id3 longtext) tablespace ts1;
insert into t2 values(3, repeat('a', 1000000), repeat('a', 1000000));
insert into t2 values(4, repeat('c', 1000000), repeat('d', 1000000));


ob1.mysql alter system major freeze;
ob1.check_version 2;

connection conn1;
use test;

select * from t1;
select id1, length(id2), substr(id3,1,10) from t2;

ALTER INSTANCE ROTATE INNODB MASTER KEY;
insert into t1 values(3, 4);
insert into t2 values(5, repeat('f', 1000000), repeat('g', 1000000));

ob1.mysql alter system major freeze;
ob1.check_version 3;

select * from t1;
select id1, length(id2), substr(id3,1,10) from t2;

create table test01 (pk1 int, pk2 int, pk3 int, f1 varchar(1024), f2 varchar(4096), primary key(pk1,pk2,pk3)) tablespace ts1;
let $cnt=1;
while($cnt < 10)
{
  eval insert into test01 values($cnt, $cnt, $cnt, 'ocean', 'base');
  inc $cnt;
}
ob1.mysql alter system minor freeze tenant obtest;
let $tid = deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where table_name='test01', table_id, 1);
ob1.check_until_timeout select count(1) from __all_virtual_table_mgr where table_id=$tid and table_type=0, 3, 120;

select * from test.test01;



