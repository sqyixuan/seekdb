# owner: jiahua.cjh
# owner group: storage
# Test the case: test queuing table purge with loser tree

ob1=OBI(cluster=1,proxy_num=0,init_unit_cpu=2);
ob1.reboot;

let $ip0=deploy_get_value(ob1.z1.obs0.ip);
let $sql_port0=deploy_get_value(ob1.z1.obs0.mysql_port);

ob1.mysql alter system set resource_hard_limit=800;
ob1.mysql alter system set merger_switch_leader_duration_time=0;
ob1.mysql alter system set enable_auto_leader_switch=false;
ob1.mysql alter system set enable_rereplication=false;
ob1.mysql alter system set enable_rebalance=false;

let $ip=deploy_get_value(ob1.z1.obs0.ip);
let $port=deploy_get_value(ob1.z1.obs0.mysql_port);
connect (conn0,$ip,admin@obtest,admin,oceanbase,$port);
connect (conn1,$ip,root@sys,,oceanbase,$port);
connection conn0;

use test;
create table t1(id1 bigint, id2 bigint, id3 bigint default 0, id4 bigint default 0, primary key(id1, id2)) progressive_merge_num=10 tablet_size=104857600;
insert into t1 values(0, 4000, 1, 1);

ob1.mysql alter system major freeze;
ob1.check_version 2;

# prepare data
--disable_query_log
let $string='test';
let $table_size = 0;
let $i = 0;
let $age = 0;
while($i < 4000)
{
  eval insert into t1 values(0, $i, 1, 1);
  inc $i;
  inc $age;
}

delete from t1 where id1 = 0 and id2 <= 3999;
update t1 set id3 = 5 where id1 = 0 and id2 = 4000;
select count(*) from t1 where id1 = 0 and id2 <= 4000;
select * from t1;
