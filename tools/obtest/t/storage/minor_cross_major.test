# owner: weixue.cx
# owner group: storage
# description: test minor cross major
##

ob1=OBI(cluster=1:1:1,proxy_num=0,init_unit_cpu=5);
ob1.reboot;
sleep 5;

ob1.mysql alter system set debug_sync_timeout = '10000000s';
ob1.mysql alter system set minor_compact_trigger = 1;

let $ip=deploy_get_value(ob1.z1.obs0.ip);
let $port=deploy_get_value(ob1.z1.obs0.mysql_port);
connect (conn1,$ip,admin@obtest,admin,oceanbase,$port);
connect (conn2,$ip,root@sys,,oceanbase,$port);


# step 1: create binding pg
connection conn1;
use test;

create tablegroup test_tg binding true;
create table t1 (c1 int primary key, c2 int) tablegroup test_tg;
create table t2 (c1 int primary key, c2 int) table_mode = 'queuing' tablegroup test_tg;

insert into t1 values (1,1), (2,2), (3,3);
insert into t2 values (1,1), (2,2), (3,3);

connection conn2;
ob1.mysql alter system major freeze;
ob1.check_version 2;

ob1.mysql alter system major freeze;
ob1.mysql set ob_global_debug_sync = 'BEFORE_UPDATE_FREEZE_SNAPSHOT_INFO wait_for continue_signal';
ob1.mysql set ob_global_debug_sync = 'BEFORE_SCHEDULE_ALL_PARTITIONS wait_for continue_merge';
sleep 40;

let $t1id = deploy_get_value(ob1.select select table_id from __all_virtual_table where table_name = 't1', table_id, 1);
let $t2id = deploy_get_value(ob1.select select table_id from __all_virtual_table where table_name = 't2', table_id, 1);
let $z3_ip = deploy_get_value(ob1.select select svr_ip from __all_server where zone = 'z3', svr_ip, 1);
let $z3_port = deploy_get_value(ob1.select select svr_port from __all_server where zone = 'z3', svr_port, 1);

ob1.z3.obs0.force_stop;
ob1.check_until_timeout select status from oceanbase.__all_server where zone='z3', inactive, 60; 
ob1.z3.obs0.nstart;
ob1.check_until_timeout select status from oceanbase.__all_server where zone='z3', active, 60; 

let $cnt = 300;
let $time = 0;
while ($cnt > 0)
{
  sleep 2;
  dec $cnt;
  let $time = deploy_get_value(ob1.select select start_service_time from oceanbase.__all_server where zone='z3', start_service_time, 1);
  if ($time > 0)
  {
    let $cnt = -1;
  }
}

if ($cnt != -1)
{
  --echo wait z3 for start service failed
}

connection conn1;
insert into t1 values (4,4);
delete from t2 where c1 = 1;

connect (conn2,$ip,root@sys,,oceanbase,$port);

connection conn2;
ob1.mysql alter system minor freeze tenant = sys;
ob1.mysql alter system minor freeze tenant = all_user;
ob1.mysql alter system minor freeze tenant = all_meta;
sleep 15;
ob1.check_until_timeout select count(1) from __all_virtual_table_mgr where table_type = 0 and is_active = 0, 0, 120;
ob1.check_until_timeout select count(1) from __all_virtual_table_mgr where table_type = 14 and table_id = $t1id and svr_ip = '$z3_ip' and svr_port = '$z3_port', 0, 300;
ob1.check_until_timeout select count(1) from __all_virtual_table_mgr where table_type = 14 and table_id = $t2id and svr_ip = '$z3_ip' and svr_port = '$z3_port', 1, 300;

connection conn1;
insert into t1 values (5,5);
delete from t2 where c1 = 2;
ob1.mysql alter system minor freeze tenant = sys;
ob1.mysql alter system minor freeze tenant = all_user;
ob1.mysql alter system minor freeze tenant = all_meta;
ob1.check_until_timeout select count(1) from __all_virtual_table_mgr where table_type = 0 and is_active = 0, 0, 120;

connection conn1;
insert into t1 values (55,55);
ob1.mysql alter system minor freeze tenant = sys;
ob1.mysql alter system minor freeze tenant = all_user;
ob1.mysql alter system minor freeze tenant = all_meta;
ob1.check_until_timeout select count(1) from __all_virtual_table_mgr where table_type = 0 and is_active = 0, 0, 120;

insert into t1 values (6,6);
ob1.mysql alter system minor freeze tenant = sys;
ob1.mysql alter system minor freeze tenant = all_user;
ob1.mysql alter system minor freeze tenant = all_meta;
ob1.check_until_timeout select count(1) from __all_virtual_table_mgr where table_type = 0 and is_active = 0, 0, 120;

ob1.check_until_timeout select count(1) from __all_virtual_table_mgr where table_type = 14, 3, 60;

let $i = 300;
while ($i > 0)
{
  dec $i;
  let $bf_snapshot = deploy_get_value(ob1.select select snapshot_version from __all_virtual_table_mgr where svr_ip='$z3_ip' and svr_port='$z3_port' and table_id=$t2id and table_type=14, snapshot_version, 1);
  let $mini_count = deploy_get_value(select count(*) from oceanbase.__all_virtual_table_mgr where svr_ip='$z3_ip' and svr_port='$z3_port' and table_id=$t2id and table_type=10 and snapshot_version > $bf_snapshot, 1);
  if ($mini_count == 0)
  {
    $i = -5;
  }
}
if ($i != -5)
{
  --echo buf error
}

ob1.check_until_timeout select count(1) from __all_virtual_table_mgr where table_type = 7 and table_id = $t1id and (svr_ip != '$z3_ip' or svr_port != '$z3_port'), 4, 300;

connection conn1;
insert into t1 values (66,66);
delete from t2 where c1 = 3;

connection conn2;
ob1.mysql alter system minor freeze tenant = sys;
ob1.mysql alter system minor freeze tenant = all_user;
ob1.mysql alter system minor freeze tenant = all_meta;
ob1.check_until_timeout select count(1) from __all_virtual_table_mgr where table_type = 0 and is_active = 0, 0, 120;
ob1.check_until_timeout select count(1) from __all_virtual_table_mgr where table_type = 14, 3, 60;

ob1.check_until_timeout select count(1) from __all_core_table a, __all_virtual_freeze_info b where column_name like "%snapshot_gc%" and frozen_snapshot = 2 and column_value > b.frozen_snapshot, 1, 60;

ob1.mysql set ob_global_debug_sync = 'now signal continue_signal';
sleep 15;

ob1.mysql set ob_global_debug_sync = 'now signal continue_merge';
ob1.check_version 3;

let $tid = deploy_get_value(ob1.select select table_id from __all_virtual_table where table_name = 't2', table_id, 1);
ob1.check_until_timeout select row_count from __all_virtual_partition_sstable_macro_info where table_id = $tid and data_version = 3, 2, 30;

connection conn1;
delete from t2 where c1 = 3;

connection conn2;
ob1.mysql alter system minor freeze tenant = sys;
ob1.mysql alter system minor freeze tenant = all_user;
ob1.mysql alter system minor freeze tenant = all_meta;
ob1.check_until_timeout select count(1) from __all_virtual_table_mgr where table_type = 0 and is_active = 0, 0, 120;
sleep 10;
ob1.check_until_timeout select count(1) from __all_virtual_table_mgr where table_type = 14 and svr_ip = '$z3_ip' and svr_port = '$z3_port', 1, 60;

# 触发Major 不会回收BufMinor
ob1.mysql alter system major freeze;
ob1.check_version 4;
ob1.check_until_timeout select count(1) from __all_virtual_table_mgr where table_type = 14, 3, 120;

connection conn1;
insert into t2 values (555,555);

connection conn2;
ob1.mysql alter system minor freeze tenant = sys;
ob1.mysql alter system minor freeze tenant = all_user;
ob1.mysql alter system minor freeze tenant = all_meta;
ob1.check_until_timeout select count(1) from __all_virtual_table_mgr where table_type = 0 and is_active = 0, 0, 120;
ob1.check_until_timeout select count(1) from __all_virtual_table_mgr where table_type = 14, 3, 120;

ob1.mysql alter system major freeze;
ob1.check_version 5;

connection conn1;
select * from t1;
select * from t2;

