# owner: jiahua.cjh
# owner group: storage
# description: test RS preempt in single zone deployment
#

ob1=OBI(cluster=2,proxy_num=0,init_unit_cpu=1, init_unit_num=1);

ob1.reboot;

ob1.mysql alter resource pool obtestpool unit_num 1;
ob1.mysql alter system set enable_rebalance = false;
ob1.mysql alter system set server_permanent_offline_time = 20;
ob1.mysql alter system set migrate_concurrency = 0;
sleep 5;

let $sys_ip = deploy_get_value(ob1.z1.obs0.ip);
let $sys_port = deploy_get_value(ob1.z1.obs0.mysql_port);

let $new_sys_ip = deploy_get_value(ob1.z1.obs1.ip);
let $new_sys_port = deploy_get_value(ob1.z1.obs1.mysql_port);

connect(new_sys_conn, $new_sys_ip, root@sys,,oceanbase, $new_sys_port);
connection new_sys_conn;

set ob_trx_timeout=100000000;
set ob_query_timeout=100000000;

--disable_warnings
drop table if exists fr_rs_preempt;
--enable_warnings

# create a table and then delete it
create table fr_rs_preempt(a int primary key);
eval replace into fr_rs_preempt values(2);
select * from fr_rs_preempt;

sleep 10;

# let RS down
ob1.z1.obs0.force_stop;
sleep 180;

select distinct(zone) from __all_server;

select * from fr_rs_preempt;
