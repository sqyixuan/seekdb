# owner: yunshan.tys
# owner group: storage
# description: single zone log replica basic test

ob1=OBI(cluster=2:4:4, proxy_num=0, ct_num =0, locality=HZ:SZ:HZ);

source include/mini_ob_config.inc;
ob1.z1.obs0.set extra_config=$mini_ob_config;
ob1.z1.obs1.set extra_config=$mini_ob_config;
ob1.z1.obs0.set extra_config=$mini_ob_config;
ob1.z2.obs1.set extra_config=$mini_ob_config;
ob1.z2.obs2.set extra_config=$mini_ob_config;
ob1.z2.obs3.set extra_config=$mini_ob_config;
ob1.z3.obs0.set extra_config=$mini_ob_config;
ob1.z3.obs1.set extra_config=$mini_ob_config;
ob1.z3.obs2.set extra_config=$mini_ob_config;
ob1.z3.obs3.set extra_config=$mini_ob_config;

ob1.reboot;

ob1.check_until_timeout select count(*) as cnt from oceanbase.__all_virtual_server_stat where start_service_time = 0, 0, 60;

ob1.mysql alter system set resource_hard_limit = 3200;
ob1.mysql alter system set merger_switch_leader_duration_time=0;
ob1.mysql alter system set enable_auto_leader_switch = false;
ob1.mysql alter system set enable_rereplication = true;
ob1.mysql alter system set enable_rebalance = false;
ob1.mysql alter system set merge_thread_count = 64;
ob1.mysql alter system set minor_merge_concurrency = 64;
ob1.mysql alter system set server_permanent_offline_time = '20s';
ob1.mysql alter system set server_data_copy_in_concurrency = 1000;
ob1.mysql alter system set server_data_copy_out_concurrency = 1000;
ob1.mysql alter system set merger_check_interval = '10s';
ob1.mysql alter system set data_copy_concurrency = 1000;
ob1.mysql alter system set migrate_concurrency = 64;
ob1.mysql alter system set minor_merge_concurrency = 64;
ob1.mysql alter system set _mini_merge_concurrency = 64;
ob1.mysql alter system set location_fetch_concurrency = 64;
ob1.mysql alter system set partition_table_check_interval = '1m';
ob1.mysql alter system set debug_sync_timeout = '100000s';

let $ip = deploy_get_value(ob1.z1.obs0.ip);
let $port = deploy_get_value(ob1.z1.obs0.mysql_port);

let $ip1 = deploy_get_value(ob1.z1.obs1.ip);
let $port1 = deploy_get_value(ob1.z1.obs1.mysql_port);

connect(sys_conn, $ip, root@sys,,test, $port);
connection sys_conn;

ob1.check_until_timeout select count(*) as cnt from oceanbase.__all_virtual_server_stat where start_service_time = 0, 0, 60;

ob1.mysql create resource unit box1 max_cpu 2, max_memory = '2G' , max_iops 100000, max_disk_size '5G', max_session_num 64, MIN_CPU=1, MIN_MEMORY='768M', MIN_IOPS=128;
ob1.mysql create resource pool pool1 unit = 'box1', unit_num = 2;
ob1.mysql create tenant tt1 replica_num = 4, resource_pool_list=('pool1'), primary_zone="z1", locality = "F@z1,L@z2,F,R@z3" set ob_tcp_invited_nodes='%';

sleep 2;

connect(tt1_conn, $ip, root@tt1,,test, $port);
connection tt1_conn;

use test;
create table t_1(c1 int primary key, f1 varchar(1024), f2 varchar(4096)) partition by hash(c1) partitions 10;

let $cnt = 1;

while ($cnt <= 20) 
{
  eval insert into t_1 values($cnt, 'OceanBase', 'Storage');
  inc $cnt;
}

connection sys_conn;

ob1.mysql alter system major freeze;

ob1.check_until_timeout select count(*) as cnt from oceanbase.__all_virtual_meta_table where data_version != 2 and zone != 'z2', 0, 480;

ob1.check_version 2;

let $crash_ip = deploy_get_value(ob1.z2.obs1.ip);
let $crash_port = deploy_get_value(ob1.z2.obs1.port);

ob1.z2.obs1.force_stop;

sleep 10;

ob1.check_until_timeout select count(*) from __all_rootservice_event_history where module = 'server_fast_recovery' and value1 like '%$crash_ip:$crash_port%' and event = 'switch state', 1, 480;

ob1.check_until_timeout select count(*) from __all_rootservice_event_history where module = 'server_fast_recovery' and value1 like '%$crash_ip:$crash_port%' and event = 'finish_recovery', 1, 480;

connection tt1_conn;

use test;

select count(*) from t_1;

connection sys_conn;

let $table_id = deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where table_name='t_1', table_id, 1);
let $src_host = deploy_get_value(ob1.select select concat(svr_ip, ':', svr_port) host from oceanbase.__all_virtual_meta_table where zone='z2' and table_id=$table_id, host, 1);
let $src = deploy_get_value(ob1.get_obs_by_addr $src_host);
let $src_ip = deploy_get_value($src.ip);
let $src_port = deploy_get_value($src.port);
let $dst_host = deploy_get_value(ob1.select select concat(svr_ip, ':', svr_port) host from oceanbase.__all_unit where zone='z2' and (svr_ip != '$src_ip' or svr_port != '$src_port') and resource_pool_id = 1001, host, 1);
let $dst = deploy_get_value(ob1.get_obs_by_addr $dst_host);
let $dst_ip = deploy_get_value($dst.ip);
let $dst_port = deploy_get_value($dst.port);

ob1.z2.obs1.start;

sleep 30;

ob1.check_until_timeout select count(*) from oceanbase.__all_server where svr_ip = "$crash_ip" and svr_port = "$crash_port", 0, 480; 

set @@session.ob_query_timeout = 200000000;
sleep 1;

--disable_query_log
eval alter system move replica partition_id "0%0@$table_id" source="$src_host" destination="$dst_host";
sleep 10;
--enable_query_log

ob1.check_until_timeout select count(*) from __all_virtual_partition_migration_status where migrate_type = 'FAST_MIGRATE_REPLICA_OP' and result = '0', 1, 480;

connection tt1_conn;

use test;

select * from t_1 order by c1;

