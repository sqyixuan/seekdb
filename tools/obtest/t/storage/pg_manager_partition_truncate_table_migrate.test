# owner:yongle.xh
# owner group:storage
--disable_query_log
ob1=OBI(cluster=1:1:1,proxy_num=0,init_unit_cpu=2);
ob1.reboot;

ob1.mysql alter system set merger_check_interval='10s';
ob1.mysql alter system set enable_rebalance = 'false';
ob1.mysql alter system set balancer_idle_time='10s';
ob1.mysql alter system set server_data_copy_in_concurrency=10;
ob1.mysql alter system set server_data_copy_out_concurrency=10;
ob1.mysql alter system set server_permanent_offline_time = '20s';
ob1.mysql alter system set resource_hard_limit=500;

ob_connect(sys_conn, ob1.z1.obs0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);
ob_connect(conn, ob1.z1.obs0, root@obtest, , oceanbase, , USE_MYSQL_CONNECTOR);
connection conn;
use test;
create tablegroup pg1 binding true partition by range(partition p0 values less than (100), partition p1 values less than (200));

create table t1 (c1 int primary key ,c2 int ,c3 int) tablegroup pg1 partition by range(c1)(partition p0 values less than (100), partition p1 values less than (200));
show create tablegroup pg1;
show create table t1;
alter tablegroup pg1 drop partition (p0);
show create tablegroup pg1;
show create table t1;
alter tablegroup pg1 add partition (partition p2 values less than (300));
show create tablegroup pg1;
show create table t1;
truncate table t1;
show create tablegroup pg1;
show create table t1;

let $tablegroup_id=deploy_get_value(ob1.select select tablegroup_id from oceanbase.__all_virtual_tablegroup where tablegroup_name='pg1', tablegroup_id, 1);
