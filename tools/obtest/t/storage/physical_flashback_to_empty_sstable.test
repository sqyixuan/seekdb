# owner: yongle.xh
# owner group: storage
# description: this case is use for reboot
#
#
#
ob1=OBI(cluster=1,proxy_num=0,init_unit_cpu=2, init_unit_num=1);
ob1.reboot;

ob1.source include/merge.inc;
let $ip = deploy_get_value(ob1.z1.obs0.ip);
let $port = deploy_get_value(ob1.z1.obs0.mysql_port);
ob1.mysql alter system set enable_async_syslog=false;

let $ip=deploy_get_value(ob1.z1.obs0.ip);
let $port=deploy_get_value(ob1.z1.obs0.mysql_port);
connect (conn1,$ip,admin@obtest,admin,oceanbase,$port);
connect (conn2,$ip,root@sys,,oceanbase,$port);
connection conn1;

use test;
create table t0(a int, b int default 1, index i1(b)) table_mode='queuing';
create table t1(a int);
insert into t0(a) values(1);
insert into t1(a) values(1);

show create table t0;
show create table t1;
ob1.mysql alter system minor freeze tenant = sys;
ob1.mysql alter system minor freeze tenant = all_user;
ob1.mysql alter system minor freeze tenant = all_meta;

ob1.mysql_p select table_name, table_mode from oceanbase.__all_virtual_table where table_name in ('t0', 't1');
let $tid_0 = deploy_get_value(ob1.select select table_id from  __all_virtual_table where table_name = 't0', table_id, 1);
let $tid_1 = deploy_get_value(ob1.select select table_id from  __all_virtual_table where table_name = 't1', table_id, 1);
let $svr_ip = deploy_get_value(ob1.select select svr_ip from __all_server where zone='z1', svr_ip, 1);
let $svr_port = deploy_get_value(ob1.select select svr_port from __all_server where zone='z1', svr_port, 1);

insert into t0(a) values(2);
insert into t1(a) values(2);
ob1.mysql alter system minor freeze tenant = sys;
ob1.mysql alter system minor freeze tenant = all_user;
ob1.mysql alter system minor freeze tenant = all_meta;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table_mgr where table_id=$tid_0 and index_id=$tid_0 and table_type=0 and is_active=0, 0, 120;

insert into t0(a) values(2);
insert into t1(a) values(2);
ob1.mysql alter system minor freeze tenant = sys;
ob1.mysql alter system minor freeze tenant = all_user;
ob1.mysql alter system minor freeze tenant = all_meta;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table_mgr where table_id=$tid_0 and index_id=$tid_0 and table_type=0 and is_active=0, 0, 120;


ob1.mysql alter system set minor_compact_trigger = 1;
ob1.mysql alter system minor freeze tenant = sys;
ob1.mysql alter system minor freeze tenant = all_user;
ob1.mysql alter system minor freeze tenant = all_meta;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table_mgr where table_id=$tid_0 and index_id=$tid_0 and table_type=0 and is_active=0, 0, 120;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table_mgr where svr_ip='$svr_ip' and svr_port='$svr_port' and table_id=$tid_0 and index_id=$tid_0 and table_type=14, 1, 120;

ob1.mysql alter system major freeze;
ob1.check_until_timeout select value from __all_zone where zone='' and name='last_merged_version', 2,3600;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table_mgr where table_id=$tid_0 and index_id=$tid_0 and table_type=0 and is_active=0, 0, 120;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table_mgr where svr_ip='$svr_ip' and svr_port='$svr_port' and table_id=$tid_0 and index_id=$tid_0 and table_type=14, 1, 120;

select * from t0;
select * from t1;
insert into t0(a) values(3);
insert into t1(a) values(3);
update t0 set a=-1 where a=1;

alter table t0 table_mode='normal';
alter table t1 table_mode='queuing';
ob1.mysql_p select table_name, table_mode from oceanbase.__all_virtual_table where table_name in ('t0', 't1');

ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table_mgr where table_id=$tid_0 and index_id=$tid_0 and table_type=0 and is_active=0, 0, 120;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table_mgr where svr_ip='$svr_ip' and svr_port='$svr_port' and table_id=$tid_1 and table_type=10, 1, 120;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table_mgr where svr_ip='$svr_ip' and svr_port='$svr_port' and table_id=$tid_0 and index_id=$tid_0 and table_type=14, 1, 120;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table_mgr where svr_ip='$svr_ip' and svr_port='$svr_port' and table_id=$tid_1 and index_id=$tid_1 and table_type=14, 0, 120;

ob1.mysql alter system major freeze;
ob1.check_until_timeout select value from __all_zone where zone='' and name='last_merged_version', 3,3600;

let $flashback_scn = deploy_get_value(ob1.select select frozen_snapshot from __all_virtual_freeze_info where frozen_version = 2, frozen_snapshot, 1);
let $flashback_scn = $flashback_scn - 1;
create table t2(a int);

ob1.z1.obs0.stop;
ob1.z1.obs0.nstart -m physical_flashback -f $flashback_scn;

sleep 120;
ob1.z1.obs0.nstart;
sleep 60;
connection conn2;
ob1.check_until_timeout select status from oceanbase.__all_server where zone='z1', active, 60;

insert into t0(a) values(8);
insert into t1(a) values(8);
ob1.mysql alter system minor freeze tenant = sys;
ob1.mysql alter system minor freeze tenant = all_user;
ob1.mysql alter system minor freeze tenant = all_meta;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table_mgr where table_id=$tid_0 and index_id=$tid_0 and table_type=0 and is_active=0, 0, 120;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table_mgr where svr_ip='$svr_ip' and svr_port='$svr_port' and table_id=$tid_0 and index_id=$tid_0 and table_type=14, 0, 120;

insert into t0(a) values(9);
insert into t1(a) values(9);
ob1.mysql alter system minor freeze tenant = sys;
ob1.mysql alter system minor freeze tenant = all_user;
ob1.mysql alter system minor freeze tenant = all_meta;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table_mgr where table_id=$tid_0 and index_id=$tid_0 and table_type=0 and is_active=0, 0, 120;

ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table_mgr where svr_ip='$svr_ip' and svr_port='$svr_port' and table_id=$tid_0 and index_id=$tid_0 and table_type=14, 0, 120;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table_mgr where svr_ip='$svr_ip' and svr_port='$svr_port' and table_id=$tid_1 and index_id=$tid_1 and table_type=14, 1, 120;


connect (conn1,$ip,admin@obtest,admin,oceanbase,$port);
connection conn1;
use test;
select * from t0;
select * from t1;

connect (conn2,$ip,root@sys,,oceanbase,$port);
connection conn2;
select * from __all_virtual_table where table_name = 't2';

