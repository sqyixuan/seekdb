#########################
#author:yiwan
#owner: yiwan
#owner group:storage
#功能：bug覆盖
#
#场景：
#一个partition迁走后重启原server，再将partition迁回

--disable_query_log
ob1=OBI(cluster=2:2:2,proxy_num=1,init_unit_cpu=2,init_unit_num=2);
ob1.reboot;
ob1.mysql alter system set merger_check_interval='10s';
ob1.mysql alter system set enable_rebalance='false';
ob1.mysql alter system set enable_rereplication='false';

let $ip=deploy_get_value(ob1.z1.obs0.ip);
let $port=deploy_get_value(ob1.z1.obs0.mysql_port);
connect (conn1,$ip,root@obtest,,test,$port);
connection conn1;

#create table
create table test01(c1 int primary key,c2 int,c3 varchar(64));
let $table_id=deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where table_name='test01', table_id, 1);
#insert data
let $cnt=10;
while($cnt>0)
{
    eval insert into test01 values($cnt,$cnt,'obtest_data');
    dec $cnt;
}

ob1.mysql alter system major freeze;
sleep 60;
ob1.check_version 2;
# migrate
let $src = deploy_get_value(ob1.get_follower obtest:test:test01:0,1);
let $src_ip = deploy_get_value($src.ip);
let $src_port = deploy_get_value($src.port);
let $src_zone = deploy_get_value($src.zone);
let $dst_host = deploy_get_value(ob1.select select concat(svr_ip, ':', svr_port) host from oceanbase.__all_server where zone='$src_zone' and svr_port!='$src_port', host, 1);
let $dst = deploy_get_value(ob1.get_obs_by_addr $dst_host);
let $dst_ip = deploy_get_value($dst.ip);
let $dst_port = deploy_get_value($dst.port);

#ob1.mysql_p select data_version from oceanbase.__all_virtual_meta_table where table_id=$table_id and svr_ip='$src_ip' and svr_port='$src_port';

$src.migrate_to $dst,obtest:test:test01;
sleep 20;
ob1.check_no_rebalance_task;
#删掉该partition在__all_virtual_meta_table中的记录
ob1.mysql_p delete from oceanbase.__all_virtual_meta_table where svr_ip='$src_ip'&& zone='$src_zone'&& tenant_id=1001;
#check
#ob1.mysql_p select data_version from oceanbase.__all_virtual_meta_table where table_id=$table_id and svr_ip='$src_ip' and svr_port='$svr_port';
let $tenant_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name='obtest', tenant_id, 1);
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_meta_table where tenant_id=$tenant_id and table_id=$table_id and role=1 and member_list like '%$dst_ip%', 1, 120;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_meta_table a ,oceanbase.__all_virtual_meta_table b where a.tenant_id=$tenant_id and b.tenant_id=$tenant_id and a.table_id=$table_id and b.table_id=$table_id  and a.member_list=b.member_list and a.role=1 and b.role=2 and b.svr_ip='$dst_ip', 1, 120;

#restart
$src.force_stop;
$src.restart;
sleep 20;
ob1.check_until_timeout select status from oceanbase.__all_server where svr_ip='$src_ip' and svr_port='$src_port', active, 50;

$dst.migrate_to $src,obtest:test:test01;
sleep 20;
ob1.check_no_rebalance_task;

#ob1.mysql_p select data_version from oceanbase.__all_virtual_meta_table where table_id=$table_id and svr_ip='$src_ip' and svr_port='$svr_port';

ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_meta_table where tenant_id=$tenant_id and table_id=$table_id and role=1 and member_list like '%$src_ip%', 1, 120;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_meta_table a ,oceanbase.__all_virtual_meta_table b where a.tenant_id=$tenant_id and a.table_id=$table_id and b.table_id=$table_id  and a.member_list=b.member_list and a.role=1 and b.role=2 and b.svr_ip='$src_ip', 1, 120;

ob1.mysql alter system set enable_rereplication='true';
ob1.mysql alter system set enable_rebalance='true';
