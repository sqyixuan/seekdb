# owner: yongle.xh
# owner group: storage
# description: this case is use for reboot
#
#
#
ob1=OBI(cluster=1:1:1,proxy_num=0,init_unit_cpu=2, init_unit_num=1);
ob1.reboot;

ob1.source include/merge.inc;
let $ip = deploy_get_value(ob1.z1.obs0.ip);
let $port = deploy_get_value(ob1.z1.obs0.mysql_port);
ob1.mysql alter system set enable_async_syslog=false;
ob1.mysql alter system set minor_compact_trigger = 1;

let $ip=deploy_get_value(ob1.z1.obs0.ip);
let $port=deploy_get_value(ob1.z1.obs0.mysql_port);
connect (conn1,$ip,admin@obtest,admin,oceanbase,$port);
connect (conn2,$ip,root@sys,,oceanbase,$port);
connection conn1;

use test;
create table t0(a int, b int default 1, index i1(b)) table_mode='queuing';

insert into t0(a) values(1);
create index i2 on t0(b);

show create table t0;
let $tid_0 = deploy_get_value(ob1.select select table_id from  __all_virtual_table where table_name = 't0', table_id, 1);
let $svr_ip = deploy_get_value(ob1.select select svr_ip from __all_server where zone='z1', svr_ip, 1);
let $svr_port = deploy_get_value(ob1.select select svr_port from __all_server where zone='z1', svr_port, 1);

ob1.mysql alter system suspend merge;

ob1.mysql alter system major freeze;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table_mgr where table_id=$tid_0 and index_id=$tid_0 and table_type=0 and is_active=0, 0, 120;

select * from t0;

delete from t0 where a = 1;
insert into t0(a) values(2);
ob1.mysql alter system minor freeze tenant = sys;
ob1.mysql alter system minor freeze tenant = all_user;
ob1.mysql alter system minor freeze tenant = all_meta;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table_mgr where table_id=$tid_0 and index_id=$tid_0 and table_type=0 and is_active=0, 0, 120;

insert into t0(a) values(3);
ob1.mysql alter system minor freeze tenant = sys;
ob1.mysql alter system minor freeze tenant = all_user;
ob1.mysql alter system minor freeze tenant = all_meta;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table_mgr where table_id=$tid_0 and index_id=$tid_0 and table_type=0 and is_active=0, 0, 120;

ob1.mysql alter system set minor_compact_trigger = 1;
sleep 60;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table_mgr where svr_ip='$svr_ip' and svr_port='$svr_port' and table_id=$tid_0 and table_type=14, 3, 120;

select * from t0;


