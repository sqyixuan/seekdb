# owner: chenqun
# owner group: storage
# description: this case for migrate partition has just built index sstable.
# bug: 
#

--disable_query_log
ob1=OBI(cluster=2:2:2,proxy_num=1,init_unit_cpu=2);
ob1.reboot;


#alter system set server_temporary_offline_time = '15s';
ob1.mysql alter system set merger_check_interval='10s';
ob1.mysql alter system set enable_rebalance = 'false';
ob1.mysql alter system set enable_rereplication = 'false';
ob1.mysql alter system set resource_hard_limit=500;
ob1.mysql alter resource pool obtestpool unit_num 2;

let $ip = deploy_get_value(ob1.z1.obs1.ip);
let $port = deploy_get_value(ob1.z1.obs1.mysql_port);
connect (conn1,$ip,root@obtest,,test,$port);
connection conn1;

create table test01 (pk1 int, pk2 int, pk3 int, i1 int, f1 varchar(1024), f2 varchar(4096), f3 varchar(4096) ,primary key(pk1,pk2,pk3));
sleep 10; 

let $cnt =1;
while ($cnt < 10)
{
	eval insert into test01 values($cnt, $cnt, $cnt, $cnt, 'abcdsa', 'sddabcds', 'aaa');
	inc $cnt;
}

ob1.mysql alter system major freeze;
ob1.check_version 2;

create index ti1 on test01(i1);
create index ti2 on test01(f1);
create index ti3 on test01(f3);


while ($cnt < 20)
{
	eval insert into test01 values($cnt, $cnt, $cnt, $cnt, 'abcdsa', 'sddabcds', 'aaa');
	inc $cnt;
}

ob1.mysql alter system major freeze;
sleep 60;

let $tenant_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name='obtest', tenant_id, 1);
let $src = deploy_get_value(ob1.get_follower obtest:test:test01:0,1);
let $src_ip = deploy_get_value($src.ip);
let $src_port = deploy_get_value($src.port);
let $src_zone = deploy_get_value(ob1.select select zone from oceanbase.__all_server where svr_ip='$src_ip', zone, 1);
let $dst_host = deploy_get_value(ob1.select select concat(svr_ip, ':', svr_port) host from oceanbase.__all_server where zone='$src_zone' and svr_port!='$src_port', host, 1);
let $dst = deploy_get_value(ob1.get_obs_by_addr $dst_host);
let $dst_ip = deploy_get_value($dst.ip);
let $table_id=deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where table_name='test01', table_id, 1);

ob1.mysql alter system start merge zone='$src_zone';
ob1.check_until_timeout select count(*) from oceanbase.__all_zone where zone='$src_zone' and name='last_merged_version' and value='3', 1, 3600;


$src.migrate_to $dst,obtest:test:test01;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_meta_table where tenant_id=$tenant_id and table_id=$table_id and role=1 and member_list like '%$dst_ip%', 1, 20;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_meta_table a ,oceanbase.__all_virtual_meta_table b where a.tenant_id=$tenant_id and a.table_id=$table_id and b.table_id=$table_id  and a.member_list=b.member_list and a.role=1 and b.role=2 and b.svr_ip='$dst_ip', 1, 20;


ob1.mysql alter system set merger_check_interval='10s';
ob1.check_version 3;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table where data_table_id=$table_id and index_status=2, 3, 3600;

