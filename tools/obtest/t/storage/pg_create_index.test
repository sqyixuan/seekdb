# owner: yongle.xh
# owner group: storage
# description:this case is use for test copy index after merge
#
--disable_query_log
ob1=OBI(cluster=1:1:1,proxy_num=0,init_unit_cpu=2);

ob1.reboot;

ob1.mysql alter system set merger_check_interval='10s';
ob1.mysql alter system set enable_rebalance = 'false';
ob1.mysql alter system set enable_auto_leader_switch=true;
ob1.mysql alter system set resource_hard_limit=500;
ob1.mysql alter system suspend merge;
ob1.mysql alter tenant obtest primary_zone='z1';

let $ip = deploy_get_value(ob1.z1.obs0.ip);
let $port = deploy_get_value(ob1.z1.obs0.mysql_port);
connect (conn1,$ip,root@obtest,,test,$port);

sleep 5;
connection conn1;
eval create tablegroup tg1 binding true;
eval create table t1(id1 int, id2 int) tablegroup tg1;

let $cnt =0;

while ($cnt < 10)
{
  eval insert into t1 values($cnt, $cnt);
  inc $cnt;
}

ob1.mysql alter system major freeze;
sleep 10;

while ($cnt < 20)
{
  eval insert into t1 values($cnt, $cnt);
  inc $cnt;
}

eval select * from t1;
sleep 2;
create index pg_index1 on t1(id1);

let $table_id=deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where table_name like '%pg_index1%', table_id, 1);
ob1.check_until_timeout select index_status from oceanbase.__all_virtual_table where table_id=$table_id, 2, 60;
