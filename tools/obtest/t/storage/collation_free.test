# owner: zhenjiang.xzj
# owner group: storage
# Test the case: collation free test

ob1=OBI(cluster=1:1, proxy_num=0,init_unit_cpu=2);
ob1.reboot;

let $ip0=deploy_get_value(ob1.z1.obs0.ip);
let $sql_port0=deploy_get_value(ob1.z1.obs0.mysql_port);

ob1.mysql alter system set resource_hard_limit=800;
ob1.mysql alter system set merger_switch_leader_duration_time=0;
ob1.mysql alter system set enable_auto_leader_switch=false;
ob1.mysql alter system set enable_rereplication=false;
ob1.mysql alter system set enable_rebalance=false;

connect(conn0,$ip0,root@obtest,,test,$sql_port0);
connect(conn1,$ip0,root@sys,,oceanbase,$sql_port0);

connection conn0;
create table test.t1(c1 varchar(1024) primary key, c2 int, c3 varchar(20));

--disable_query_log
let $cnt=1;
while($cnt < 50)
{
  eval insert into test.t1 values(concat('a', char($cnt)), $cnt, 'oceanbase');
  inc $cnt;
}
--enable_query_log

let $string=b;
let $cnt=1;
--disable_query_log
while($cnt < 1000)
{
  let $string=deploy_get_value(ob1.select select concat('$string', 'b') as s, s, 1);
  inc $cnt;
}
--enable_query_log

--disable_query_log
let $cnt=1;
while($cnt < 10000)
{
  eval insert into test.t1 values(concat('$string', '$cnt'), $cnt, 'oceanbase');
  inc $cnt;
}
--enable_query_log

insert into test.t1 values(' ', 100, 'oceanbase');

ob1.mysql alter system major freeze;
ob1.check_version 2;

# range查询

select hex(c1) from t1 where c1 like 'a%';

# 查询中带小于0x20的字符

select hex(c1) from t1 where c1 <= concat('a', char(0));
select hex(c1) from t1 where c1 <= concat('a', char(10));

# 查询中带大于0x80的字符

select hex(c1) from t1 where c1 <= concat('a', char(128));

# 查询中带有空格的

select hex(c1) from t1 where c1 <= 'a ';
select hex(c1) from t1 where c1 <= 'a  ';
select hex(c1) from t1 where c1 <= ' ';
select hex(c1) from t1 where c1 <= '  ';
select hex(c1) from t1 where c1 <= ' a';
select hex(c1) from t1 where c1 <= '  a';

# 正常的查询

select hex(c1) from t1 where c1 <= 'aa';
select hex(c1) from t1 where c1 <= 'a1';
select hex(c1) from t1 where c1 <= 'a';

# 空的查询

select hex(c1) from t1 where c1 <= '';
