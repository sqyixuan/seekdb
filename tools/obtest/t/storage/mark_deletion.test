# owner:weixue.cx
# owner group:storage
# description:
# test mark deletion

ob1=OBI(cluster=1,proxy_num=0,init_unit_cpu=5);
ob1.reboot;
sleep 5;

ob1.mysql alter system set enable_auto_leader_switch = false;

#在zone1上建立连接
let $ip=deploy_get_value(ob1.z1.obs0.ip);
let $port=deploy_get_value(ob1.z1.obs0.mysql_port);
connect (conn1,$ip,admin@obtest,admin,oceanbase,$port);
connect (conn2,$ip,root@sys,,oceanbase,$port);


connection conn1;
use test;

create tablegroup tg1 binding true;
create table t1_tg1(c1 int primary key, c2 int) tablegroup tg1;

--disable_query_log
--disable_result_log
let $cnt=1;
while($cnt < 300)
{
  eval insert into test.t1_tg1 values($cnt, $cnt);
  inc $cnt;
}
--enable_query_log
--enable_result_log

connection conn2;
let $tid1 = query_get_value(select table_id from oceanbase.__all_virtual_table where table_name = 't1_tg1', table_id, 1);
let $tgid = query_get_value(select tablegroup_id from oceanbase.__all_virtual_tablegroup where tablegroup_name = 'tg1', tablegroup_id, 1);

alter system set minor_compact_trigger = 10;

alter system minor freeze tenant = sys;
alter system minor freeze tenant = all_user;
alter system minor freeze tenant = all_meta;

ob1.check_until_timeout select count(1) from oceanbase.__all_virtual_table_mgr where table_type = 0 and table_id = $tgid and is_active = 0, 0, 180;

connection conn1;
delete from test.t1_tg1;

connection conn2;
alter system minor freeze tenant = sys;
alter system minor freeze tenant = all_user;
alter system minor freeze tenant = all_meta;

connection conn1;
insert into test.t1_tg1 values (2,2);

ob1.check_until_timeout select count(1) from oceanbase.__all_virtual_table_mgr where table_type = 0 and table_id = $tgid and is_active = 0, 0, 180;

connection conn1;
set ob_log_level = 'DEBUG';
select * from test.t1_tg1;
set ob_log_level = 'INFO';

ob1.z1.obs0.check_log_until_success "RangeSkip: skip range.*299";
