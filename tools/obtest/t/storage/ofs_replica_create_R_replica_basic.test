# owner: yunshan.tys
# owner group: storage
# description: add readonly replica in single zone
ob1=OBI(cluster=4, proxy_num=0, ct_num =0, locality=SH);

source include/mini_ob_config.inc;
ob1.z1.obs0.set extra_config=$mini_ob_config;
ob1.z1.obs1.set extra_config=$mini_ob_config;
ob1.z1.obs2.set extra_config=$mini_ob_config;
ob1.z1.obs3.set extra_config=$mini_ob_config;

ob1.reboot;

ob1.check_until_timeout select count(*) as cnt from oceanbase.__all_virtual_server_stat where start_service_time = 0, 0, 60;

ob1.mysql alter system set resource_hard_limit = 3200;
ob1.mysql alter system set merger_switch_leader_duration_time=0;
ob1.mysql alter system set enable_auto_leader_switch = false;
ob1.mysql alter system set enable_rereplication = true;
ob1.mysql alter system set enable_rebalance = false;
ob1.mysql alter system set merge_thread_count = 64;
ob1.mysql alter system set minor_merge_concurrency = 64;
ob1.mysql alter system set server_permanent_offline_time = '20s';
ob1.mysql alter system set server_data_copy_in_concurrency = 1000;
ob1.mysql alter system set server_data_copy_out_concurrency = 1000;
ob1.mysql alter system set merger_check_interval = '10s';
ob1.mysql alter system set data_copy_concurrency = 1000;
ob1.mysql alter system set migrate_concurrency = 64;
ob1.mysql alter system set minor_merge_concurrency = 64;
ob1.mysql alter system set _mini_merge_concurrency = 64;
ob1.mysql alter system set location_fetch_concurrency = 64;
ob1.mysql alter system set partition_table_check_interval = '1m';
ob1.mysql alter system set debug_sync_timeout = '100000s';

let $ip = deploy_get_value(ob1.z1.obs3.ip);
let $port = deploy_get_value(ob1.z1.obs3.mysql_port);

connect(sys_conn, $ip, root@sys,,test, $port);

ob1.check_until_timeout select count(*) as cnt from oceanbase.__all_virtual_server_stat where start_service_time = 0, 0, 60;

ob1.mysql create resource unit box1 max_cpu 2, max_memory = '2G' , max_iops 100000, max_disk_size '5G', max_session_num 64, MIN_CPU=1, MIN_MEMORY='768M', MIN_IOPS=128;
ob1.mysql create resource pool pool1 unit = 'box1', unit_num = 2;
ob1.mysql create tenant tt1 replica_num = 2, resource_pool_list=('pool1'), primary_zone="z1", locality = "F@z1" set ob_tcp_invited_nodes='%';

sleep 2;

let $ip1 = deploy_get_value(ob1.z1.obs2.ip);
let $port1 = deploy_get_value(ob1.z1.obs2.mysql_port);

connect(tt1_conn, $ip1, root@tt1,,test, $port1);
connection tt1_conn;

use test;
create table t_1(c1 int primary key, f1 varchar(1024), f2 varchar(4096)) partition by hash(c1) partitions 10;

let $cnt = 1;

while ($cnt <= 100) 
{
  eval insert into test.t_1 values($cnt, 'OceanBase', 'Storage Test');
  inc $cnt;
}

connection sys_conn;

ob1.mysql alter system major freeze;

ob1.check_until_timeout select count(*) as cnt from oceanbase.__all_virtual_meta_table where data_version != 2, 0, 480;

ob1.check_version 2;

let $tenant_id = deploy_get_value(ob1.select select tenant_id from __all_tenant where tenant_name = "tt1", tenant_id, 1);

ob1.mysql alter tenant tt1 locality='F,R@z1';

ob1.check_until_timeout select count(*) c from oceanbase.__all_tenant where tenant_id = $tenant_id and previous_locality != '', 0, 480;
ob1.check_until_timeout select count(*) c from oceanbase.__all_rootservice_job where job_status="SUCCESS", 1, 480;
sleep 30;

ob1.mysql alter system major freeze;

ob1.check_until_timeout select count(*) from __all_virtual_partition_migration_status where migrate_type = 'ADD_REPLICA_OP' and result != '0', 0, 480;

ob1.check_until_timeout select count(*) as cnt from oceanbase.__all_virtual_meta_table where data_version != 3, 0, 480;

ob1.check_version 3;
