# owner: yongle.xh
# owner group: storage
# description: this case is use for migrate_rebuild_during_wait_replay
#

--disable_query_log
ob1=OBI(cluster=2:2:2,proxy_num=0,init_unit_cpu=2, init_unit_num=2);
ob1.reboot;

#设置灰度切主的时间为0, 关闭自动切主，关闭自动balance
ob1.mysql alter system set resource_hard_limit = 800;
ob1.mysql alter system set merger_switch_leader_duration_time=0;
ob1.mysql alter system set enable_auto_leader_switch = false;
ob1.mysql alter system set enable_rereplication = false;
ob1.mysql alter system set enable_rebalance = false;
ob1.mysql alter system set debug_sync_timeout = '100000s';
let $ip = deploy_get_value(ob1.z1.obs0.ip);
let $port = deploy_get_value(ob1.z1.obs0.mysql_port);

connect (conn1,$ip,admin@obtest,admin,oceanbase,$port);
connect (conn2,$ip,root@sys,,oceanbase,$port);
connection conn1;

let $sys_pool = deploy_get_value(ob1.select select name from __all_resource_pool where tenant_id = 1, name, 1);
ob1.mysql alter resource pool $sys_pool unit_num 2;
sleep 2;
use test;
create table test01(c1 int, c2 int, c3 varchar(4096), primary key(c1)) primary_zone='z1';
create table t(a int primary key);
sleep 10;

let $cnt=1;
while($cnt < 10)
{
  eval insert into test01 values($cnt, $cnt, 'oceanbase');
  inc $cnt;
}

ob1.mysql alter system major freeze;
ob1.check_version 2;

let $tenant_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name='obtest', tenant_id, 1);
let $table_id = deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where table_name='test01', table_id, 1);
let $src_host = deploy_get_value(ob1.select select concat(svr_ip, ':', svr_port) host from oceanbase.__all_virtual_meta_table where zone='z2' and table_id=$table_id, host, 1);
let $src = deploy_get_value(ob1.get_obs_by_addr $src_host);
let $src_ip = deploy_get_value($src.ip);
let $src_port = deploy_get_value($src.port);
let $dst_host = deploy_get_value(ob1.select select concat(svr_ip, ':', svr_port) host from oceanbase.__all_unit where zone='z2' and (svr_ip != '$src_ip' or svr_port != $src_port) and resource_pool_id = 1001, host, 1);
let $dst = deploy_get_value(ob1.get_obs_by_addr $dst_host);
let $dst_ip = deploy_get_value($dst.ip);
let $member_list = deploy_get_value(ob1.select select member_list from oceanbase.__all_virtual_meta_table where table_id = $table_id and role = 1, member_list, 1);
let $version = deploy_get_value(ob1.select select data_version from oceanbase.__all_virtual_meta_table where table_id = $table_id and role=1, data_version, 1);

connection conn2;
alter system change tenant obtest;
eval update oceanbase.__all_tenant_meta_table set data_checksum=11111 where table_id = $table_id and zone='z1' and tenant_id=$tenant_id;

#发起迁移
$src.migrate_to $dst,obtest:test:test01;

#expect 4103,0
ob1.check_until_timeout select value4 from oceanbase.__all_rootservice_event_history where module='balancer' and event = 'finish_migrate_replica' and value1 like "%$table_id%" and value2 like '%$src_ip%', -4103, 30;

