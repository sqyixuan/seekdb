# owner: jianyun.sjy
# owner group: storage
# description: test migrate replica: src retakeover pg when handover failed
#

--disable_query_log
ob1=OBI(cluster=2:2:2,proxy_num=1,init_unit_cpu=5);
ob1.reboot;
ob1.mysql alter resource pool obtestpool unit_num 2;

# 关闭自动切主，设置永久下线时间
ob1.mysql alter system set resource_hard_limit = 500;
ob1.mysql alter system set enable_auto_leader_switch = false;
ob1.mysql alter system set merger_check_interval = '10s';
ob1.mysql alter system set server_permanent_offline_time = '20s';
ob1.mysql alter system set debug_sync_timeout = '100000s';

ob1.check_until_timeout select count(*) as cnt from oceanbase.__all_virtual_server_stat where start_service_time = 0, 0, 60;
let $ip = deploy_get_value(ob1.z1.obs0.ip);
let $port = deploy_get_value(ob1.z1.obs0.mysql_port);
connect (conn_obtest,$ip,root@obtest,,test,$port);
connection conn_obtest;
set @@session.ob_query_timeout = 20000000;

create table test01 (pk1 int, pk2 int, pk3 int, f1 varchar(1024), f2 varchar(4096), primary key(pk1,pk2,pk3));
sleep 10;
let $cnt=1;
while($cnt < 10)
{
  eval insert into test01 values($cnt, $cnt, $cnt, 'ocean', 'base');
  inc $cnt;
}
select pk1, pk2, pk3, f1, f2 from test01;

connect(conn2,$ip,root@sys,,,$port);
connection conn2;
set @@session.ob_query_timeout = 200000000;
use oceanbase;

let $tenant_id = deploy_get_value(ob1.select select tenant_id from __all_tenant where tenant_name='obtest', tenant_id, 1);
let $table_id = deploy_get_value(ob1.select select table_id from __all_virtual_table where table_name='test01', table_id, 1);
let $src_host = deploy_get_value(ob1.select select concat(svr_ip, ':', svr_port) host from __all_virtual_meta_table where table_id = $table_id and zone = 'z3', host, 1);
let $src = deploy_get_value(ob1.get_obs_by_addr $src_host);
let $src_ip = deploy_get_value($src.ip);
let $src_port = deploy_get_value($src.port);
let $dest_host = deploy_get_value(ob1.select select concat(svr_ip, ':', svr_port) host from __all_server where zone='z3' and (svr_ip != '$src_ip' or svr_port != '$src_port'), host, 1);
let $dst = deploy_get_value(ob1.get_obs_by_addr $dest_host);
let $dst_ip = deploy_get_value($dst.ip);
let $dst_port = deploy_get_value($dst.port);

ob1.mysql set ob_global_debug_sync = 'FAST_MIGRATE_AFTER_SUSPEND_SRC wait_for signal_1';
$src.migrate_to $dst,obtest:test:test01;
ob1.check_until_timeout select locate('$src_host', member_list) as pos from __all_virtual_meta_table where role=1 and table_id=$table_id, 0, 180;
sleep 120;
let $pos = deploy_get_value(ob1.select select locate('$src_host', member_list) as pos from __all_virtual_meta_table where role=1 and table_id = $table_id, pos, 1);
if ($pos > 0)
{
  --echo src retakeover succ
}
ob1.mysql set ob_global_debug_sync = 'now signal signal_1';
ob1.check_until_timeout select count(*) from __all_virtual_meta_table where table_id = $table_id, 3, 180;

ob1.mysql alter system switch replica leader partition_id='0%0@$table_id' server='$src_host';
sleep 10;
$src.check_leader obtest:test:test01;
connection conn_obtest;
select pk1, pk2, pk3, f1, f2 from test01;
