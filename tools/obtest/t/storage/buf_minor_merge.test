# owner: yongle.xh
# owner group: storage
# description: this case is use for reboot
#
#
#
ob1=OBI(cluster=1:1:1,proxy_num=0,init_unit_cpu=2, init_unit_num=1);
ob1.reboot;

ob1.source include/merge.inc;
let $ip = deploy_get_value(ob1.z1.obs0.ip);
let $port = deploy_get_value(ob1.z1.obs0.mysql_port);
ob1.mysql alter system set enable_async_syslog=false;

let $ip=deploy_get_value(ob1.z1.obs0.ip);
let $port=deploy_get_value(ob1.z1.obs0.mysql_port);
connect (conn1,$ip,admin@obtest,admin,oceanbase,$port);
connect (conn2,$ip,root@sys,,oceanbase,$port);
connection conn1;

use test;
create table t0(a int, b int default 1, index i1(b)) table_mode='queuing';
create table t1(a int);

ob1.mysql alter system set minor_compact_trigger = 10;

# 插入数据，得到第1个Mini SSTable
insert into t0(a) values(1);
insert into t1(a) values(1);
ob1.mysql alter system minor freeze tenant = sys;
ob1.mysql alter system minor freeze tenant = all_user;
ob1.mysql alter system minor freeze tenant = all_meta;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table_mgr where table_type=0 and is_active=0, 0, 120;

show create table t0;
show create table t1;
ob1.mysql_p select table_name, table_mode from oceanbase.__all_virtual_table where table_name in ('t0', 't1');
let $tid_0 = deploy_get_value(ob1.select select table_id from  __all_virtual_table where table_name = 't0', table_id, 1);
let $tid_1 = deploy_get_value(ob1.select select table_id from  __all_virtual_table where table_name = 't1', table_id, 1);
let $svr_ip = deploy_get_value(ob1.select select svr_ip from __all_server where zone='z1', svr_ip, 1);
let $svr_port = deploy_get_value(ob1.select select svr_port from __all_server where zone='z1', svr_port, 1);

# 插入数据，得到第2个Mini SSTable
insert into t0(a) values(2);
insert into t1(a) values(2);
ob1.mysql alter system minor freeze tenant = sys;
ob1.mysql alter system minor freeze tenant = all_user;
ob1.mysql alter system minor freeze tenant = all_meta;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table_mgr where table_type=0 and is_active=0, 0, 120;

# 插入数据，得到第3个Mini SSTable
insert into t0(a) values(3);
insert into t1(a) values(3);
update t0 set a=-1 where a=1;
ob1.mysql alter system minor freeze tenant = sys;
ob1.mysql alter system minor freeze tenant = all_user;
ob1.mysql alter system minor freeze tenant = all_meta;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table_mgr where table_type=0 and is_active=0, 0, 120;

# 改变trigger，触发t0的BufMinorMerge & t1的MiniMinorMerge
ob1.mysql alter system set minor_compact_trigger = 2;
ob1.mysql alter system minor freeze tenant = sys;
ob1.mysql alter system minor freeze tenant = all_user;
ob1.mysql alter system minor freeze tenant = all_meta;
sleep 60;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table_mgr where svr_ip='$svr_ip' and svr_port='$svr_port' and table_id=$tid_0 and table_type=14, 2, 120;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table_mgr where svr_ip='$svr_ip' and svr_port='$svr_port' and table_id=$tid_1 and table_type=10, 1, 30;

# 查询数据
select * from t0;
select * from t1;

# 触发MajorMerge
ob1.mysql alter system major freeze;
ob1.check_until_timeout select value from __all_zone where zone='' and name='last_merged_version', 2,3600;

# BufMinorSSTable不会回收  
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table_mgr where svr_ip='$svr_ip' and svr_port='$svr_port' and table_id=$tid_0 and table_type=14, 2, 120;

select * from t0;
select * from t1;

# 改变表的类型：t0变成普通表，t1变成BufMinor表
alter table t0 table_mode='normal';
alter table t1 table_mode='queuing';
ob1.mysql_p select table_name, table_mode from oceanbase.__all_virtual_table where table_name in ('t0', 't1');

ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table_mgr where svr_ip='$svr_ip' and svr_port='$svr_port' and table_id=$tid_1 and table_type=14, 0, 120;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table_mgr where svr_ip='$svr_ip' and svr_port='$svr_port' and table_id=$tid_0 and table_type=14, 2, 120;

# 生成t1的第2个Mini
insert into t0(a) values(333);
insert into t1(a) values(333);
ob1.mysql alter system minor freeze tenant = sys;
ob1.mysql alter system minor freeze tenant = all_user;
ob1.mysql alter system minor freeze tenant = all_meta;

# t0的BufMinor被回收
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table_mgr where table_id=$tid_0 and index_id=$tid_0 and table_type=0 and is_active=0, 0, 120;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table_mgr where svr_ip='$svr_ip' and svr_port='$svr_port' and table_id=$tid_0 and table_type=14, 0, 120;

# 生成t1的第3个Mini
insert into t1(a) values(333);
ob1.mysql alter system minor freeze tenant = sys;
ob1.mysql alter system minor freeze tenant = all_user;
ob1.mysql alter system minor freeze tenant = all_meta;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table_mgr where table_id=$tid_0 and index_id=$tid_0 and table_type=0 and is_active=0, 0, 120;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table_mgr where svr_ip='$svr_ip' and svr_port='$svr_port' and table_id=$tid_1 and table_type=14, 1, 120;

# 触发合并,t1的BufMinor不会回收
ob1.mysql alter system major freeze;
ob1.check_until_timeout select value from __all_zone where zone='' and name='last_merged_version', 3,3600;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table_mgr where svr_ip='$svr_ip' and svr_port='$svr_port' and table_id=$tid_1 and table_type=14, 1, 120;

insert into t0(a) values(4);
insert into t1(a) values(4);
ob1.mysql alter system minor freeze tenant = sys;
ob1.mysql alter system minor freeze tenant = all_user;
ob1.mysql alter system minor freeze tenant = all_meta;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table_mgr where table_id=$tid_0 and index_id=$tid_0 and table_type=0 and is_active=0, 0, 120;

insert into t0(a) values(5);
insert into t1(a) values(5);
ob1.mysql alter system minor freeze tenant = sys;
ob1.mysql alter system minor freeze tenant = all_user;
ob1.mysql alter system minor freeze tenant = all_meta;

# t1得到一个BufMinorSSTable
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table_mgr where svr_ip='$svr_ip' and svr_port='$svr_port' and table_id=$tid_1 and table_type=14, 1, 120;

ob1.mysql alter system suspend merge;

alter table t0 table_mode='queuing';
alter table t1 table_mode='queuing';

insert into t0(a) values(44);
insert into t1(a) values(44);
ob1.mysql alter system minor freeze tenant = sys;
ob1.mysql alter system minor freeze tenant = all_user;
ob1.mysql alter system minor freeze tenant = all_meta;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table_mgr where table_id=$tid_0 and index_id=$tid_0 and table_type=0 and is_active=0, 0, 120;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table_mgr where svr_ip='$svr_ip' and svr_port='$svr_port' and table_id=$tid_1 and table_type=14, 1, 120;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table_mgr where svr_ip='$svr_ip' and svr_port='$svr_port' and table_id=$tid_0 and table_type=14, 2, 120;

insert into t0(a) values(444);
insert into t1(a) values(444);
ob1.mysql alter system minor freeze tenant = sys;
ob1.mysql alter system minor freeze tenant = all_user;
ob1.mysql alter system minor freeze tenant = all_meta;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table_mgr where table_id=$tid_0 and index_id=$tid_0 and table_type=0 and is_active=0, 0, 120;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table_mgr where svr_ip='$svr_ip' and svr_port='$svr_port' and table_id=$tid_1 and table_type=14, 1, 120;

insert into t0(a) values(4445);
insert into t1(a) values(4445);
ob1.mysql alter system minor freeze tenant = sys;
ob1.mysql alter system minor freeze tenant = all_user;
ob1.mysql alter system minor freeze tenant = all_meta;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table_mgr where table_id=$tid_0 and index_id=$tid_0 and table_type=0 and is_active=0, 0, 120;

let $i = 300;
while ($i > 0)
{
  dec $i;
  let $bf_snapshot = deploy_get_value(ob1.select select snapshot_version from __all_virtual_table_mgr where svr_ip='$svr_ip' and svr_port='$svr_port' and table_id=$tid_1 and table_type=14, snapshot_version, 1);
  let $mini_count = deploy_get_value(select count(*) from oceanbase.__all_virtual_table_mgr where svr_ip='$svr_ip' and svr_port='$svr_port' and table_id=$tid_1 and table_type=10 and snapshot_version > $bf_snapshot, 1);
  if ($mini_count == 0)
  {
    $i = -5;
  }
}
if ($i != -5)
{
  --echo buf error
}

# 触发合并，所有的BufMinorSSTable不会被回收
ob1.mysql alter system major freeze;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table_mgr where table_id=$tid_0 and index_id=$tid_0 and table_type=0 and is_active=0, 0, 120;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table_mgr where svr_ip='$svr_ip' and svr_port='$svr_port' and table_id=$tid_0 and index_id=$tid_0 and table_type=14, 1, 120;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table_mgr where svr_ip='$svr_ip' and svr_port='$svr_port' and table_id=$tid_1 and table_type=14, 1, 120;

insert into t0(a) values(6);
insert into t1(a) values(6);
ob1.mysql alter system minor freeze tenant = sys;
ob1.mysql alter system minor freeze tenant = all_user;
ob1.mysql alter system minor freeze tenant = all_meta;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table_mgr where table_id=$tid_0 and index_id=$tid_0 and table_type=0 and is_active=0, 0, 120;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table_mgr where svr_ip='$svr_ip' and svr_port='$svr_port' and table_id=$tid_0 and index_id=$tid_0 and table_type=14, 1, 120;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table_mgr where svr_ip='$svr_ip' and svr_port='$svr_port' and table_id=$tid_1 and table_type=14, 1, 120;

ob1.mysql alter system resume merge;
ob1.check_until_timeout select value from __all_zone where zone='' and name='last_merged_version', 4,3600;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table_mgr where svr_ip='$svr_ip' and svr_port='$svr_port' and table_id=$tid_0 and index_id=$tid_0 and table_type=14, 1, 120;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table_mgr where svr_ip='$svr_ip' and svr_port='$svr_port' and table_id=$tid_1 and table_type=14, 1, 120;

