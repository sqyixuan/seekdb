# owner: lixia.yq
# owner group: storage
# description: this case is use for test new mini merge with multi memtables
#

--disable_query_log
ob1=OBI(cluster=1, proxy_num=0,init_unit_cpu=5);
ob1.reboot;
sleep 10;

let $l_ip1=deploy_get_value(ob1.z1.obs0.ip);
let $l_port1=deploy_get_value(ob1.z1.obs0.mysql_port);
connect (conn1,$l_ip1,root@sys,,oceanbase,$l_port1);
connect (conn2,$l_ip1,root@obtest,,test,$l_port1);
connect (conn3,$l_ip1,root@obtest,,test,$l_port1);

#设置灰度切主的时间为0, 关闭自动切主，关闭自动balance
ob1.mysql alter system set resource_hard_limit = 800;
ob1.mysql alter system set merger_switch_leader_duration_time=0;
ob1.mysql alter system set enable_auto_leader_switch = false;
ob1.mysql alter system set enable_rebalance=false;
ob1.mysql alter system set enable_rereplication=false;
ob1.mysql alter system set debug_sync_timeout = '100000s';

connection conn1;
set GLOBAL ob_trx_timeout = 10000000000;
set GLOBAL ob_trx_idle_timeout = 10000000000;
set GLOBAL ob_query_timeout = 10000000000;

let $tenant_id=deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name = "obtest", tenant_id, 1);

--enable_query_log
connection conn2;
create table test01(c1 int, c2 int, c3 varchar(4096), c4 int, c5 int, c6 double, c7 int, c8 varchar(512), c9 int, c10 float, primary key(c1)) primary_zone='z1';
begin;
--disable_query_log
let $cnt=1;
while($cnt < 30)
{
  eval insert into test01 values($cnt, $cnt, 'oceanbase', $cnt, $cnt, $cnt * 0.25, $cnt, 'hello world $cnt', $cnt, $cnt * 0.5);
  inc $cnt;
}
--enable_query_log

#冻结指定的partition
connection conn1;
let $table_id = deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where table_name = "test01", table_id, 1);
let $partition_id = deploy_get_value(ob1.select select partition_id from oceanbase.__all_virtual_table_mgr where table_id = $table_id, partition_id, 1);

ob1.mysql set ob_global_debug_sync = 'AFTER_FREEZE_BEFORE_MINI_MERGE wait_for signal_1';  

--disable_query_log
alter system minor freeze tenant obtest;
--enable_query_log

sleep 20;

#插入数据
connection conn2;
--disable_query_log
let $cnt=200;
while($cnt < 230)
{
  eval insert into test01 values($cnt, $cnt, 'oceanbase', $cnt, $cnt, $cnt * 0.25, $cnt, 'hello world $cnt', $cnt, $cnt * 0.5);
  inc $cnt;
}
--enable_query_log


connection conn1;
--disable_query_log
alter system minor freeze tenant obtest;
--enable_query_log
sleep 30;
ob1.mysql set ob_global_debug_sync = 'now signal signal_1';

connection conn1;
sleep 10;

ob1.check_until_timeout select count(*) from __all_virtual_table_mgr where is_active = 0 and table_type = 0 and tenant_id = tenant_id, 0, 120;

#检查指定partition是否含未提交事务
ob1.check_until_timeout select count(*) from __all_virtual_table_mgr where table_id = '$table_id' and contain_uncommitted_row = 1 and table_type = 7, 1, 10;

connection conn2;
commit;

connection conn3;
select * from test01 where c1 = 218;

connection conn2;
select count(*) from test01 where c1 < 200;

#插入数据
connection conn2;
begin;
--disable_query_log
let $cnt=300;
while($cnt < 330)
{
  eval insert into test01 values($cnt, $cnt, 'oceanbase', $cnt, $cnt, $cnt * 0.25, $cnt, 'hello world $cnt', $cnt, $cnt * 0.5);
  inc $cnt;
}
--enable_query_log

ob1.mysql alter system minor freeze tenant = sys;
ob1.mysql alter system minor freeze tenant = all_user;
ob1.mysql alter system minor freeze tenant = all_meta;
sleep 15;
ob1.check_until_timeout select count(1) from __all_virtual_table_mgr where table_type = 0 and is_active = 0, 0, 120;

connection conn3;
select * from test01 where c1 = 218;

connection conn2;
select count(*) from test01 where c1 < 200;

drop table test01;
