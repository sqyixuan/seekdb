# owner:lixia.yq
# owner group:storage
# description:
# test mark deletion with uncommitted trans

ob1=OBI(cluster=1,proxy_num=0,init_unit_cpu=5);
ob1.reboot;
sleep 5;

ob1.mysql alter system set enable_auto_leader_switch = false;

#在zone1上建立连接
let $ip=deploy_get_value(ob1.z1.obs0.ip);
let $port=deploy_get_value(ob1.z1.obs0.mysql_port);
connect (conn0,$ip,root@sys,,oceanbase,$port);

connection conn0;
set global ob_query_timeout = 100000000000;
set global ob_trx_timeout = 100000000000;
set global ob_trx_idle_timeout = 100000000000;
alter system set minor_compact_trigger = 10;
alter system set syslog_io_bandwidth_limit = '100G';

connect (conn1,$ip,admin@obtest,admin,oceanbase,$port);
connect (conn2,$ip,root@sys,,oceanbase,$port);

#创建表
connection conn1;
use test;
create table mark_deletion_with_uncom(c1 int primary key, c2 int);

#获得表ID
connection conn2;
let $tid1 = query_get_value(select table_id from oceanbase.__all_virtual_table where table_name = 'mark_deletion_with_uncom', table_id, 1);

#=========================含未提交事务的标记删除(范围中含脏事务)======================

connection conn1;
--disable_query_log
--disable_result_log
let $cnt=1;
while($cnt < 300)
{
  eval insert into test.mark_deletion_with_uncom values($cnt, $cnt);
  inc $cnt;
}
--enable_query_log
--enable_result_log

connection conn2;
alter system minor freeze tenant = sys;
alter system minor freeze tenant = all_user;
alter system minor freeze tenant = all_meta;
ob1.check_until_timeout select count(1) from oceanbase.__all_virtual_table_mgr where table_type = 0 and is_active = 0, 0, 180;

connection conn1;
delete from test.mark_deletion_with_uncom;
#开始事务
begin;
insert into test.mark_deletion_with_uncom values (77,77);

connection conn2;
alter system minor freeze tenant = sys;
alter system minor freeze tenant = all_user;
alter system minor freeze tenant = all_meta;
ob1.check_until_timeout select count(1) from oceanbase.__all_virtual_table_mgr where table_type = 0 and is_active = 0, 0, 180;

connection conn1;
set ob_log_level = 'DEBUG';
select * from test.mark_deletion_with_uncom;
set ob_log_level = 'INFO';
rollback;

#没有标记删除
ob1.z1.obs0.count_log "RangeSkip: skip range.*rowkey.*299";

#=========================含未提交事务的标记删除(范围中不含脏事务)======================

connection conn1;
--disable_query_log
--disable_result_log
let $cnt=1;
while($cnt < 300)
{
  eval insert into test.mark_deletion_with_uncom values($cnt, $cnt);
  inc $cnt;
}
--enable_query_log
--enable_result_log

connection conn2;
alter system minor freeze tenant = sys;
alter system minor freeze tenant = all_user;
alter system minor freeze tenant = all_meta;

ob1.check_until_timeout select count(1) from oceanbase.__all_virtual_table_mgr where table_type = 0 and is_active = 0, 0, 180;

connection conn1;
delete from test.mark_deletion_with_uncom;
#开始事务
begin;
insert into test.mark_deletion_with_uncom values (88,88);
delete from test.mark_deletion_with_uncom;

connection conn2;
alter system minor freeze tenant = sys;
alter system minor freeze tenant = all_user;
alter system minor freeze tenant = all_meta;
ob1.check_until_timeout select count(1) from oceanbase.__all_virtual_table_mgr where table_type = 0 and is_active = 0, 0, 180;

connection conn1;
set ob_log_level = 'DEBUG';
select * from test.mark_deletion_with_uncom;
set ob_log_level = 'INFO';
rollback;

#没有标记删除
ob1.z1.obs0.count_log "RangeSkip: skip range.*rowkey.*299";

#=========================含未提交事务的标记删除(范围中不含脏事务)======================

connection conn1;
--disable_query_log
--disable_result_log
let $cnt=100;
while($cnt < 500)
{
  eval insert into test.mark_deletion_with_uncom values($cnt, $cnt * 100);
  inc $cnt;
}
--enable_query_log
--enable_result_log

connection conn2;
alter system minor freeze tenant = sys;
alter system minor freeze tenant = all_user;
alter system minor freeze tenant = all_meta;
ob1.check_until_timeout select count(1) from oceanbase.__all_virtual_table_mgr where table_type = 0 and is_active = 0, 0, 180;

connection conn1;
delete from test.mark_deletion_with_uncom;

connection conn2;
alter system minor freeze tenant = sys;
alter system minor freeze tenant = all_user;
alter system minor freeze tenant = all_meta;
ob1.check_until_timeout select count(1) from oceanbase.__all_virtual_table_mgr where table_type = 0 and is_active = 0, 0, 180;

connection conn1;
set ob_log_level = 'DEBUG';
select * from test.mark_deletion_with_uncom;
set ob_log_level = 'INFO';

#标记0～299删除
ob1.z1.obs0.check_log_until_success "RangeSkip: skip range.*rowkey.*499.*gap_size=400";
