# owner: yongle.xh
# owner group: storage
# Test the case: memstore_percent=0 and migrate

ob1=OBI(cluster=1:1:1,proxy_num=0,init_unit_cpu=2);
ob1.reboot;

ob1.mysql alter system set resource_hard_limit = 800;
ob1.mysql alter system set merger_switch_leader_duration_time=0;
ob1.mysql alter system set enable_auto_leader_switch = true;
ob1.mysql alter system set enable_rereplication = true;
ob1.mysql alter system set enable_rebalance = true;
ob1.mysql alter system set debug_sync_timeout = '100000s';
ob1.mysql alter system set minor_compact_trigger=1;
ob1.mysql alter system set _follower_replica_merge_level = 0;
ob1.mysql alter system set sys_bkgd_migration_change_member_list_timeout='0s';

ob1.mysql create resource pool rp1 unit = 'sys_unit_config', unit_num = 1, zone_list = ('z1', 'z2', 'z3');
let $port = deploy_get_value(ob1.z1.obs0.mysql_port);
ob1.mysql create tenant tt1 replica_num 3, primary_zone 'z1', resource_pool_list ('rp1'), locality = "F{1,memstore_percent:100}@z1,F{1,memstore_percent:0}@z2,L@z3" set ob_tcp_invited_nodes='%';

sleep 5;

let $ip=deploy_get_value(ob1.z1.obs0.ip);
let $port=deploy_get_value(ob1.z1.obs0.mysql_port);
let $ip2=deploy_get_value(ob1.z2.obs0.ip);
let $port2=deploy_get_value(ob1.z2.obs0.port);

connect (conn1,$ip,root@tt1,,test,$port);
connect (conn2,$ip,root@sys,,oceanbase,$port);
connection conn1;

use test;
create table t1(c1 int primary key) table_mode='queuing';
let $table_id = deploy_get_value(ob1.select select table_id from  __all_virtual_table where table_name = 't1', table_id, 1);
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table_mgr a, oceanbase.__all_virtual_table b where b.table_name = 't1' and a.table_id=b.table_id and a.table_type=1, 2, 60; 

insert into  t1(c1) values(1);
ob1.mysql alter system minor freeze tenant = sys;
ob1.mysql alter system minor freeze tenant = all_user;
ob1.mysql alter system minor freeze tenant = all_meta;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table_mgr where table_type=0 and is_active=0 and table_id=$table_id, 0, 90;
insert into  t1(c1) values(999);
ob1.mysql alter system minor freeze tenant = sys;
ob1.mysql alter system minor freeze tenant = all_user;
ob1.mysql alter system minor freeze tenant = all_meta;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table_mgr where table_type=0 and is_active=0 and table_id=$table_id, 0, 90;


delete from t1 where c1 = 1;
insert into  t1(c1) values(2);
ob1.mysql alter system set migrate_concurrency = 0;
sleep 2;
ob1.mysql alter system minor freeze tenant = sys;
ob1.mysql alter system minor freeze tenant = all_user;
ob1.mysql alter system minor freeze tenant = all_meta;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table_mgr where table_type=0 and is_active=0 and table_id=$table_id, 0, 90;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table_mgr where table_type=7 and table_id=$table_id, 0, 90;


delete from t1 where c1 = 2;
insert into  t1(c1) values(3);

ob1.mysql alter system minor freeze tenant = sys;
ob1.mysql alter system minor freeze tenant = all_user;
ob1.mysql alter system minor freeze tenant = all_meta;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table_mgr where table_type=0 and is_active=0 and table_id=$table_id, 0, 90;
delete from t1 where c1 = 3;
insert into  t1(c1) values(4);

ob1.mysql alter system major freeze;
ob1.check_until_timeout select count(*) from (select distinct(snapshot_version) from oceanbase.__all_virtual_table_mgr where table_type=14), 1, 120;

ob1.mysql alter system set migrate_concurrency = 2;

ob1.check_until_timeout select count(*) from __all_virtual_partition_migration_status where table_id=$table_id and action='END', 2, 120;

#ob1.mysql alter system set migrate_concurrency = 0;
sleep 60;
ob1.check_version 2;

select * from t1;
ob1.mysql alter tenant tt1 primary_zone 'z2';
ob1.mysql alter system switch replica leader partition_id='0%0@$table_id' server='$ip2:$port2';
ob1.check_until_timeout select zone from oceanbase.__all_virtual_meta_table where table_id=$table_id and role = 1, z2, 90;
select * from t1;
ob1.z2.obs0.count_log "buf minor sstable cannot cut range";


