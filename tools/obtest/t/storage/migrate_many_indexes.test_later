ob1.mysql alter system major freeze;
ob1.check_version 2;


let $src = deploy_get_value(ob1.get_follower obtest:test:test01:0,1);
let $src_ip = deploy_get_value($src.ip);
let $src_zone = deploy_get_value(ob1.select select zone from oceanbase.__all_server where svr_ip='$src_ip', zone, 1);
let $dst_host = deploy_get_value(ob1.select select concat(svr_ip, ':', svr_port) host from oceanbase.__all_server where zone='$src_zone' and svr_ip!='$src_ip', host, 1);
let $dst = deploy_get_value(ob1.get_obs_by_addr $dst_host);
let $dst_ip = deploy_get_value($dst.ip);
let $tenant_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name='obtest', tenant_id, 1);

# 索引表i101是为了测试迁移未生效的索引表
create index i101 on test01(f2); 
$src.migrate_to $dst,obtest:test:test01;

let $table_id=deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where table_name='test01', table_id, 1);
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_meta_table where tenant_id=$tenant_id and table_id=$table_id and role=1 and member_list like '%$dst_ip%', 1, 20;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_meta_table a ,oceanbase.__all_virtual_meta_table b where a.tenant_id=$tenant_id and a.table_id=$table_id and b.table_id=$table_id  and a.member_list=b.member_list and a.role=1 and b.role=2 and b.svr_ip='$dst_ip', 1, 30;


# 测试数据表含数据未合并索引未生效的场景
create table test02(c0 int, c1 int,  primary key(c0));
create index i1 on test02(c1);
insert into test02 values(1,1);
let $src = deploy_get_value(ob1.get_follower obtest:test:test02:0,1);
let $src_ip = deploy_get_value($src.ip);
let $src_zone = deploy_get_value(ob1.select select zone from oceanbase.__all_server where svr_ip='$src_ip', zone, 1);
let $dst_host = deploy_get_value(ob1.select select concat(svr_ip, ':', svr_port) host from oceanbase.__all_server where zone='$src_zone' and svr_ip!='$src_ip', host, 1);
