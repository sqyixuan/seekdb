# owner: yongle.xh
# owner group: storage
# description: this case is use for raid reboot
#
ob1=OBI(cluster=1:1:1,proxy_num=0,init_unit_cpu=2, init_unit_num=1);
ob1.z3.obs0.set raid_disk_num=5;
ob1.reboot;

let $ip = deploy_get_value(ob1.z1.obs0.ip);
let $port = deploy_get_value(ob1.z1.obs0.mysql_port);
ob1.mysql alter system set enable_async_syslog=false;
ob1.mysql alter system set merger_check_interval='10s';

#在zone1上建立连接
let $ip=deploy_get_value(ob1.z1.obs0.ip);
let $port=deploy_get_value(ob1.z1.obs0.mysql_port);
connect (conn1,$ip,admin@obtest,admin,oceanbase,$port);
connect (conn2,$ip,root@sys,,oceanbase,$port);

connection conn1;
use test;

create table t1(a int);
insert into t1(a) values(1);

ob1.z3.obs0.force_stop;
ob1.check_until_timeout select status from oceanbase.__all_server where zone='z3', inactive, 60; 
ob1.z3.obs0.nstart;
ob1.check_until_timeout select status from oceanbase.__all_server where zone='z3', active, 60; 

select * from t1;
ob1.mysql alter system major freeze;
ob1.check_version 2;
ob1.check_until_timeout select count(*) from oceanbase.__all_server where status='active', 3, 3;

ob1.z3.obs0.force_stop;
ob1.check_until_timeout select status from oceanbase.__all_server where zone='z3', inactive, 60; 
ob1.z3.obs0.nstart;
ob1.check_until_timeout select status from oceanbase.__all_server where zone='z3', active, 60; 
insert into t1(a) values(2);
ob1.mysql alter system major freeze;
ob1.check_version 3;
ob1.check_until_timeout select count(*) from oceanbase.__all_server where status='active', 3, 3;
select * from t1;

# drop disk
let $host = deploy_get_value(ob1.select select concat(svr_ip, ':', svr_port) host from oceanbase.__all_server where zone='z3', host, 1);
ob1.mysql ALTER DISKGROUP data drop disk '1'  server='$host';
insert into t1(a) values(3);
ob1.mysql alter system major freeze;
ob1.check_version 4;
ob1.check_until_timeout select count(*) from oceanbase.__all_server where status='active', 3, 3;

# reboot after drop disk
ob1.z3.obs0.force_stop;
ob1.check_until_timeout select status from oceanbase.__all_server where zone='z3', inactive, 60; 
ob1.z3.obs0.nstart;
ob1.check_until_timeout select status from oceanbase.__all_server where zone='z3', active, 60; 
select * from t1;
insert into t1(a) values(4);
ob1.mysql alter system major freeze;
ob1.check_version 5;
ob1.check_until_timeout select count(*) from oceanbase.__all_server where status='active', 3, 3;
