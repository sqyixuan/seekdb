# owner: zhenjiang.xzj
# owner group: storage
# description: this case is use for test that index status with error do not merge

--disable_query_log
ob1=OBI(cluster=2:2:2,proxy_num=0,init_unit_cpu=2, init_unit_num=2);
ob1.reboot;

ob1.mysql alter system set resource_hard_limit = 800;
ob1.mysql alter system set merger_switch_leader_duration_time=0;
ob1.mysql alter system set enable_auto_leader_switch = false;
ob1.mysql alter system set enable_rebalance=false;
ob1.mysql alter system set enable_rereplication=false;
ob1.mysql alter system set debug_sync_timeout = '100000s';
ob1.mysql alter system set server_permanent_offline_time = '20s';

let $ip0=deploy_get_value(ob1.z1.obs0.ip);
let $sql_port0=deploy_get_value(ob1.z1.obs0.mysql_port);
connect(conn0,$ip0,root@obtest,,test,$sql_port0);
connection conn0;

create table test01(c1 int, c2 int, c3 varchar(4096), primary key(c1)) primary_zone='z1';
create index index01 on test01(c3, c2);
let $cnt=1;
while($cnt < 10)
{
  eval insert into test01 values($cnt, $cnt, 'oceanbase');
  inc $cnt;
}
ob1.mysql alter system suspend merge zone 'z1';
ob1.mysql alter system suspend merge zone 'z2';
ob1.mysql alter system suspend merge zone 'z3';
ob1.mysql alter system major freeze;
let $cnt=10;
while($cnt < 20)
{
  eval insert into test01 values($cnt, $cnt, 'oceanbase');
  inc $cnt;
}
let $src = deploy_get_value(ob1.get_follower obtest:test:test01:0,1);
let $src_ip = deploy_get_value($src.ip);
let $src_port = deploy_get_value($src.port);
let $src_zone = deploy_get_value(ob1.select select zone from oceanbase.__all_server where svr_ip='$src_ip' and svr_port='$src_port', zone, 1);
let $dst_host = deploy_get_value(ob1.select select concat(svr_ip, ':', svr_port) host from oceanbase.__all_server where zone='$src_zone' and (svr_ip!='$src_ip' or svr_port!='$src_port'), host, 1);
let $dst = deploy_get_value(ob1.get_obs_by_addr $dst_host);
let $dst_ip = deploy_get_value($dst.ip);
let $dst_port = deploy_get_value($dst.port);
let $tenant_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name='obtest', tenant_id, 1);
let $table_id=deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where table_name='test01', table_id, 1);
let $index_id=deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where table_name like '%index01%', table_id, 1);

ob1.mysql set ob_global_debug_sync = 'BEFORE_MIGRATE_COPY_BASE_DATA wait_for signal';
sleep 2;
$src.migrate_to $dst,obtest:test:test01;
ob1.mysql alter system resume merge zone 'z1';
ob1.mysql alter system resume merge zone 'z2';
ob1.mysql alter system resume merge zone 'z3';
ob1.check_version 2;
ob1.mysql set ob_global_debug_sync = 'now signal signal';
ob1.check_until_timeout select index_status from oceanbase.__all_virtual_table where table_name like '%index01%', 2, 120;
sleep 20;
let $replica_count = deploy_get_value(select count(*) as cnt from oceanbase.__all_virtual_meta_table where tenant_id=$tenant_id and table_id=$table_id and role=1 and member_list like '%$dst_host%', cnt, 1);
if ($replica_count == 1)
{
  ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_meta_table where tenant_id=$tenant_id and table_id=$table_id and role=1 and member_list like '%$dst_host%', 1, 20;
  ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_meta_table a ,oceanbase.__all_virtual_meta_table b where a.tenant_id=$tenant_id and a.table_id=$table_id and b.table_id=$table_id  and a.member_list=b.member_list and a.role=1 and b.role=2 and b.svr_ip='$dst_ip' and b.svr_port='$dst_port', 1, 20;
  sleep 2;
  ob1.check_until_timeout select * from __all_virtual_table_mgr where and table_type = 1 and svr_ip = '$dst_ip' and svr_port = '$dst_port' and index_id = $index_id and version = 2, 1, 20;
}
if ($replica_count == 0)
{
  $dst.check_log_until_success -c "fail to check member major sstable enough";
}
