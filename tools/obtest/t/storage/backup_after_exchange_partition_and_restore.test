# owner: lihongqin.lhq
# owner group: ddl
# Testing Case: Back up and restore case after exchange partition 

ob1=OBI(cluster=1:1:1, proxy_num=0);
ob2=OBI(cluster=1, proxy_num=0);

source include/mini_ob_config.inc;
ob1.z1.obs0.set extra_config = "cache_wash_threshold='1G',_ob_minor_merge_schedule_interval='3s'";
ob1.z2.obs0.set extra_config = "cache_wash_threshold='1G',_ob_minor_merge_schedule_interval='3s'";
ob1.z3.obs0.set extra_config = "cache_wash_threshold='1G',_ob_minor_merge_schedule_interval='3s'";
ob2.z1.obs0.set extra_config = "cache_wash_threshold='1G',_ob_minor_merge_schedule_interval='3s'";

let $backup_cluster_name = deploy_get_value(ob1.get_cluster_name);
let $backup_cluster_id = deploy_get_value(ob1.get_cluster_id);
let $backup_ip       = deploy_get_value(ob1.z1.obs0.ip);
let $backup_port     = deploy_get_value(ob1.z1.obs0.mysql_port);
let $restore_ip         = deploy_get_value(ob2.z1.obs0.ip);
let $restore_port       = deploy_get_value(ob2.z1.obs0.mysql_port);
let $backup_dest = deploy_get_value(ob1.get_backup_dest);
let $backup_oracle_tenant   = backup_oracle_tenant;
let $backup_oracle_tenant_new   = backup_oracle_tenant_new;
let $backup_mysql_tenant    = backup_mysql_tenant;
let $restore_oracle_tenant = restore_oracle_tenant;
let $restore_oracle_tenant_new = restore_oracle_tenant_new;
let $restore_mysql_tenant = restore_mysql_tenant;
let $log_backup_dest = deploy_get_value(ob1.get_log_backup_dest $backup_oracle_tenant);
let $data_backup_dest = deploy_get_value(ob1.get_data_backup_dest $backup_oracle_tenant);
let $restore_log_archive_dest = deploy_get_value(ob1.get_log_backup_dest $restore_oracle_tenant);

# 必须先stop掉老的，删除才能有效，不然可能会有残留。
ob1.force_stop;
ob1.clean_backup_dest;
ob1.reboot;

# 固定sys租户规格
ob1.mysql alter resource unit sys_unit_config memory_size='2G';

connect(backup_sys_conn, $backup_ip, root@sys,,oceanbase, $backup_port);
connection backup_sys_conn;
use oceanbase;
#source sql/physical_backup/prepare_single_zone_mini_resource.sql;
source sql/physical_backup/prepare_multi_zone_resource.sql;

ob1.mysql alter system set _backup_idle_time = '10s';
ob1.mysql alter system set _advance_checkpoint_timeout = '5m';
ob1.mysql alter system set merger_check_interval = '10s';
ob1.mysql alter system set enable_async_syslog=false;

# create oracle tenant, test create tenant before major freeze
ob1.mysql CREATE TENANT $backup_oracle_tenant RESOURCE_POOL_LIST = ('small_pool'), primary_zone = "z1" set ob_tcp_invited_nodes='%', ob_compatibility_mode='oracle';
let $backup_oracle_tenant_id = query_get_value(select tenant_id from oceanbase.__all_tenant where tenant_name='$backup_oracle_tenant', tenant_id, 1);
#创建tablet
ob_connect(sys_conn_oracle, ob1.z1.obs0, SYS@$backup_oracle_tenant, ,SYS, , USE_OB_CONNECTOR);
connection sys_conn_oracle;
set global wait_timeout = 288000;

--disable_all_result_log
eval alter system set data_backup_dest='$data_backup_dest';
eval alter system set log_archive_dest='location=$log_backup_dest';
ob1.mysql alter system set archive_lag_target = '60s' tenant = '$backup_oracle_tenant';
alter system set ha_high_thread_score=100;
alter system set ha_mid_thread_score=100;
alter system set ha_low_thread_score=100;
ob1.set_piece_switch_interval 1002 0 2m;
--enable_all_result_log

# Set piece_switch_interval to 2min manually.
connection backup_sys_conn;
let $__archive_lag_target__ = 5s;
let $__tenant_name__ = $backup_oracle_tenant;
source include/set_archive_lag_target.inc;
alter system change tenant tenant_id = 1001;
update __all_log_archive_dest_parameter set value='2m' where dest_no=0 and name='piece_switch_interval';

connection sys_conn_oracle;
set global wait_timeout = 288000;
create user test IDENTIFIED BY "test";
grant all on *.* to test WITH GRANT OPTION;
grant dba to test;
ob_connect(backup_oracle_conn, ob1.z1.obs0,TEST@$backup_oracle_tenant,test,test,,USE_OB_CONNECTOR);
connection backup_oracle_conn;

# 创建一张分区表pt
create table pt (c1 int, c2 int, c3 blob) partition by range(c1) (partition M1  VALUES LESS THAN (5), partition M2 VALUES LESS THAN (10), partition M3 VALUES LESS THAN (20));
insert into pt(c1, c2) values(1,1);
insert into pt(c1, c2) values(2,2);
insert into pt(c1, c2) values(3,3);
insert into pt(c1, c2) values(4,4);
insert into pt(c1, c2) values(5,5);
insert into pt(c1, c2) values(6,6);
insert into pt(c1, c2) values(7,7);
insert into pt(c1, c2) values(8,8);
insert into pt(c1, c2) values(9,9);
insert into pt(c1, c2) values(10,10);
insert into pt(c1, c2) values(11,11);
insert into pt(c1, c2) values(12,12);
insert into pt(c1, c2) values(13,13);
insert into pt(c1, c2) values(14,14);
insert into pt(c1, c2) values(15,15);
create index pt_local_idx on pt(c1, c2) local;
create index pt_global_idx on pt(c2) global;
select * from pt order by c1;
# 创建一张和分区表格式相同的非分区表nt
create table nt (c1 int, c2 int, c3 blob);
insert into nt(c1, c2) values(21,21);
insert into nt(c1, c2) values(22,22);
insert into nt(c1, c2) values(23,23);
insert into nt(c1, c2) values(24,24);
insert into nt(c1, c2) values(25,25);
insert into nt(c1, c2) values(26,26);
insert into nt(c1, c2) values(27,27);
insert into nt(c1, c2) values(28,28);
insert into nt(c1, c2) values(29,29);
insert into nt(c1, c2) values(30,30);
insert into nt(c1, c2) values(31,31);
insert into nt(c1, c2) values(32,32);
insert into nt(c1, c2) values(33,33);
insert into nt(c1, c2) values(34,34);
insert into nt(c1, c2) values(35,35);
create index nt_local_idx on nt(c1, c2);
select * from nt order by c1;

# 在分区表中新增加符合非分区表nt的分区
ALTER TABLE pt ADD PARTITION  M4 VALUES LESS THAN(40);
select * from pt order by c1;
select * from nt order by c1;

# pt表的分区M4和非分区表nt执行分区交换操作
alter table pt exchange partition M4 with table nt including indexes without validation;
select * from pt order by c1;
select * from nt order by c1;

#开启日志备份
ob1.mysql alter system archivelog;
ob1.check_until_timeout select status from oceanbase.CDB_OB_ARCHIVELOG where tenant_id=$backup_oracle_tenant_id, DOING, 600;

#检查piece start scn和round start scn相等
let $round_start_scn = deploy_get_value(ob1.select select start_scn from oceanbase.CDB_OB_ARCHIVELOG where tenant_id=$backup_oracle_tenant_id, start_scn, 1);
ob1.check_until_timeout select min(start_scn)=$round_start_scn from oceanbase.CDB_OB_ARCHIVELOG_PIECE_FILES where tenant_id=$backup_oracle_tenant_id, 1, 1;

ob1.mysql alter system major freeze tenant = '$backup_oracle_tenant';
sleep 10;
ob1.check_until_timeout select (frozen_scn - last_scn) as result from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id=$backup_oracle_tenant_id, 0, 600;

ob_connect(sys_conn, ob1.z1.obs0, root, , oceanbase, , USE_MYSQL_CONNECTOR);
connection sys_conn;
# check co sstable status
let $observer_id = 1;
let $tenant_name = '$backup_oracle_tenant';
let $table_name = "pt";
--source include/compaction/check_major_sstable_status.inc
let $table_name = "nt";
--source include/compaction/check_major_sstable_status.inc
ob_connect(backup_oracle_conn, ob1.z1.obs0,TEST@$backup_oracle_tenant,test,test,,USE_OB_CONNECTOR);
connection backup_oracle_conn;

#检查切piece
ob1.check_until_timeout select status from oceanbase.CDB_OB_ARCHIVELOG_PIECE_FILES where tenant_id=$backup_oracle_tenant_id and piece_id=1, FROZEN, 600;

ob1.mysql alter system set ha_low_thread_score = 3 tenant $backup_oracle_tenant;

#开启数据备份
ob1.mysql alter system backup database;
ob1.check_until_timeout select count(*) c from __all_backup_job_history where tenant_id = 1, 1, 600;
ob1.check_until_timeout select result from oceanbase.CDB_OB_BACKUP_JOB_HISTORY where tenant_id = $backup_oracle_tenant_id, 0, 10;
ob1.check_until_timeout select result from oceanbase.CDB_OB_BACKUP_TASK_HISTORY where tenant_id = $backup_oracle_tenant_id, 0, 10;

ob1.check_until_timeout select count(*) as cnt from oceanbase.__all_virtual_dag where dag_type like '%BACKUP%', 0, 60;

sleep 20;
connect(backup_sys_conn, $backup_ip, root@sys,,oceanbase, $backup_port);
connection backup_sys_conn;
use oceanbase;
let $restore_path = $log_backup_dest,$data_backup_dest;
let $ls_id1 = deploy_get_value(ob1.select select ls_id from oceanbase.__all_virtual_ls where tenant_id = $backup_oracle_tenant_id and ls_id != 1, ls_id, 1);
#TODO msy164651 expand not work
#ob1.mysql alter tenant $backup_oracle_tenant set primary_zone = 'z1,z2';
#ob1.check_until_timeout select count(*)>=3 from oceanbase.__all_virtual_ls_status where status = 'NORMAL' and tenant_id = $backup_oracle_tenant_id, 1, 100;
#let $ls_id2 = deploy_get_value(ob1.select select max(ls_id) as ls_id from oceanbase.__all_virtual_ls where tenant_id = $backup_oracle_tenant_id, ls_id, 1);
let $create_scn1 = deploy_get_value(ob1.select select create_scn from oceanbase.__all_virtual_ls where tenant_id = $backup_oracle_tenant_id and ls_id = $ls_id1, create_scn, 1);
#let $create_scn2 = deploy_get_value(ob1.select select create_scn from oceanbase.__all_virtual_ls where tenant_id = $backup_oracle_tenant_id and ls_id =  $ls_id2, create_scn, 1);
#sleep 3;
let $restore_checkpoint1 = `select ceil(min_restore_scn / 1000) as min_restore_scn from CDB_OB_BACKUP_SET_FILES where tenant_id = $backup_oracle_tenant_id`;
let $restore_checkpoint2 = `select ceil(UNIX_TIMESTAMP(current_timestamp(6)) * 1000000)`;
ob1.check_until_timeout select floor(checkpoint_scn / 1000) > '$restore_checkpoint1' from CDB_OB_ARCHIVELOG, 1, 600;
ob1.check_until_timeout select floor(checkpoint_scn / 1000) > '$restore_checkpoint2' from CDB_OB_ARCHIVELOG, 1, 600;
let $restore_checkpoint = $restore_checkpoint2;
let $restore_checkpoint = `select usec_to_time(floor(checkpoint_scn/1000)) from CDB_OB_ARCHIVELOG`;

#关闭日志备份
ob1.mysql alter system noarchivelog tenant=all;
ob1.check_until_timeout select status from oceanbase.CDB_OB_ARCHIVELOG_SUMMARY where tenant_id=$backup_oracle_tenant_id, STOP, 600;

# 检查所有piece状态
ob1.check_until_timeout select count(*)=0 from oceanbase.CDB_OB_ARCHIVELOG_PIECE_FILES where tenant_id=$backup_oracle_tenant_id and status!='FROZEN', 1, 60;

#修改租户名
connection backup_sys_conn;
ob1.mysql alter tenant $backup_oracle_tenant rename global_name to $backup_oracle_tenant_new;
ob1.mysql alter system archivelog;
ob1.check_until_timeout select status from oceanbase.CDB_OB_ARCHIVELOG where tenant_id=$backup_oracle_tenant_id, DOING, 600;

#关闭日志备份
ob1.mysql alter system noarchivelog tenant=all;
ob1.check_until_timeout select status from oceanbase.CDB_OB_ARCHIVELOG_SUMMARY where tenant_id=$backup_oracle_tenant_id, STOP, 600;

#开启数据恢复
ob2.reboot;
connect(restore_sys_conn, $restore_ip, root@sys,,oceanbase, $restore_port);
ob2.mysql alter system set debug_sync_timeout = '1000s';
ob2.mysql set ob_global_debug_sync = 'BEFORE_WAIT_RESTORE_TENANT_FINISH wait_for signal';
ob2.mysql alter resource unit sys_unit_config memory_size='2G';
connection restore_sys_conn;
source sql/physical_backup/prepare_single_zone_mini_resource.sql;
ob2.mysql alter system set enable_async_syslog=false;
ob2.mysql alter system restore $restore_oracle_tenant from '$restore_path' until time='$restore_checkpoint' with 'pool_list=small_pool_2&primary_zone=z1&concurrency=50';
ob2.check_until_timeout select count(*) > 0 as has_cnt from oceanbase.__all_tenant where tenant_name='$restore_oracle_tenant', 1, 600;
let $restore_oracle_tenant_id = query_get_value(select tenant_id from oceanbase.__all_tenant where tenant_name='$restore_oracle_tenant', tenant_id, 1);
ob2.check_until_timeout select count(*) > 0 as has_cnt from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id = $restore_oracle_tenant_id, 1, 600;
ob2.check_until_timeout select count(*) > 0 as has_cnt from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id = $restore_oracle_tenant_id - 1, 1, 600;
ob2.check_until_timeout select count(*) > 0 as has_cnt from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id = $restore_oracle_tenant_id, 1, 600;
ob2.check_until_timeout select count(*) > 0 as has_cnt from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id = $restore_oracle_tenant_id - 1, 1, 600;
ob2.mysql_p select status from oceanbase.__all_tenant;
ob2.mysql set ob_global_debug_sync = 'now signal signal';
ob2.check_until_timeout SELECT status FROM __all_tenant WHERE tenant_id = 1001, NORMAL, 200;
ob2.mysql alter system set ha_high_thread_score = 100 tenant = $restore_oracle_tenant;
ob2.mysql alter system set ha_mid_thread_score = 100 tenant = $restore_oracle_tenant;
ob2.mysql alter system set ha_low_thread_score = 100 tenant = $restore_oracle_tenant;
ob2.check_until_timeout select count(*) from __all_virtual_ls_meta_table where tenant_id = 1002 and restore_status = 0, 2, 600;
ob2.check_until_timeout select status FROM __all_tenant WHERE tenant_id = 1002, NORMAL, 200;
ob2.check_until_timeout select count(*) FROM __all_restore_job, 0, 200;

# check co sstable status
ob_connect(sys_conn, ob2.z1.obs0, root, , oceanbase, , USE_MYSQL_CONNECTOR);
connection sys_conn;
let $observer_id = 2;
let $tenant_name = '$restore_oracle_tenant';
let $tenant_id = deploy_get_value(ob2.select select tenant_id from oceanbase.__all_tenant where tenant_name=$tenant_name, tenant_id, 1);
ob2.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id = $tenant_id and last_scn = 1, 0, 200;
let $table_name = "pt";
--source include/compaction/check_major_sstable_status.inc
let $table_name = "nt";
--source include/compaction/check_major_sstable_status.inc

ob_connect(sys_conn, ob2.z1.obs0, root, , oceanbase, , USE_MYSQL_CONNECTOR);
connection sys_conn;
alter system change tenant tenant_id = 1001;
select tenant_role from __all_tenant_info where tenant_id = 1002;
# STANDBY

ob_connect(sys_conn, ob2.z1.obs0, root, , oceanbase, , USE_MYSQL_CONNECTOR);
connection sys_conn;
--error 1210
eval ALTER SYSTEM ACTIVATE STANDBY;

set ob_query_timeout  = 10000000;
eval ALTER SYSTEM ACTIVATE STANDBY TENANT $restore_oracle_tenant;

alter system change tenant tenant_id = 1001;
select tenant_role from __all_tenant_info where tenant_id = 1002;
# PRIMARY

ob_connect(restore_oracle_conn, ob2.z1.obs0, SYS@$restore_oracle_tenant, ,TEST, , USE_OB_CONNECTOR);
connection restore_oracle_conn;
select * from pt order by c1;
select * from nt order by c1;
# 向pt表中插入新的数据
insert into pt(c1, c2) values(36,36);
insert into pt(c1, c2) values(37,37);
insert into pt(c1, c2) values(38,38);
insert into pt(c1, c2) values(39,39);
select * from pt order by c1;
# 向nt表中插入新的数据
insert into nt(c1, c2) values(1,1);
insert into nt(c1, c2) values(2,2);
insert into nt(c1, c2) values(3,3);
insert into nt(c1, c2) values(4,4);
insert into nt(c1, c2) values(5,5);
insert into nt(c1, c2) values(6,6);
insert into nt(c1, c2) values(7,7);
insert into nt(c1, c2) values(8,8);
insert into nt(c1, c2) values(9,9);
insert into nt(c1, c2) values(10,10);
select * from nt order by c1;
# 在pt表中更新数据
update pt set c2 = -10 where c1 = 10;
update pt set c2 = -11 where c1 = 11;
update pt set c2 = -12 where c1 = 12;
select * from pt order by c1;
# 在nt表中更新数据
update nt set c2 = -1 where c1 = 1;
update nt set c2 = -2 where c1 = 2;
update nt set c2 = -3 where c1 = 3;
select * from nt order by c1;
# 在pt表中删除数据
delete from pt where c1 > 10;
select * from pt order by c1;
# 在nt表中删除数据
delete from nt where c1 > 5;
select * from nt order by c1;
alter table pt exchange partition M1 with table nt including indexes without validation;
select * from pt order by c1;
select * from nt order by c1;

# 开启日志备份
--disable_all_result_log
eval alter system set log_archive_dest='location=$restore_log_archive_dest';
ob2.set_piece_switch_interval 1002 0 2m;
--enable_all_result_log

# Set piece_switch_interval to 2min manually.
connection sys_conn;
alter system change tenant tenant_id = 1001;
update __all_log_archive_dest_parameter set value='2m' where dest_no=0 and name='piece_switch_interval'; 

connection restore_oracle_conn;
alter system archivelog;
ob2.check_until_timeout select status from oceanbase.CDB_OB_ARCHIVELOG where tenant_id=$restore_oracle_tenant_id, DOING, 600;
ob2.mysql_p select count(*) from oceanbase.__all_virtual_ls where tenant_id = $restore_oracle_tenant_id and ls_id = $ls_id1 and create_scn = $create_scn1;
#ob2.mysql_p select count(*) from oceanbase.__all_virtual_ls where tenant_id = $restore_oracle_tenant_id and ls_id = $ls_id2 and create_scn = $create_scn2;

#oracle 租户 failover
let $fo_oracle_tenant = fo_oracle_tenant;
ob2.mysql alter system restore $fo_oracle_tenant from '$restore_path' until time='$restore_checkpoint' with 'pool_list=small_pool_0&primary_zone=z1';
ob2.check_until_timeout SELECT status FROM __all_tenant WHERE tenant_id = 1003, NORMAL, 200;
ob2.mysql alter system set ha_high_thread_score = 100 tenant = $fo_oracle_tenant;
ob2.mysql alter system set ha_mid_thread_score = 100 tenant = $fo_oracle_tenant;
ob2.mysql alter system set ha_low_thread_score = 100 tenant = $fo_oracle_tenant;
ob2.check_until_timeout select count(*) from __all_virtual_ls_meta_table where tenant_id = 1004 and restore_status = 0, 2, 600;
ob2.check_until_timeout select status FROM __all_tenant WHERE tenant_id = 1004, NORMAL, 200;
ob2.check_until_timeout select count(*) FROM __all_restore_job, 0, 200;

ob_connect(sys_conn, ob2.z1.obs0, root, , oceanbase, , USE_MYSQL_CONNECTOR);
connection sys_conn;
select tenant_role from __all_virtual_tenant_info where tenant_id = 1004;
# STANDBY

select TENANT_ID, TENANT_NAME, TENANT_TYPE, COMPATIBILITY_MODE, STATUS, IN_RECYCLEBIN, LOCKED, TENANT_ROLE, SWITCHOVER_STATUS, LOG_MODE from DBA_OB_TENANTS order by TENANT_ID;
ob2.check_until_timeout select count(*) from DBA_OB_TENANTS where SYNC_SCN >= REPLAYABLE_SCN and REPLAYABLE_SCN>=READABLE_SCN and RECOVERY_UNTIL_SCN !=0 and TENANT_TYPE = "USER", 2, 10;
ob2.check_until_timeout select count(*) from DBA_OB_TENANTS where SYNC_SCN is NULL and REPLAYABLE_SCN is NULL and READABLE_SCN is NULL and RECOVERY_UNTIL_SCN  is NULL and TENANT_TYPE in ("SYS", "META"), 3, 10;

ob_connect(fo_oracle_tenant_conn, ob2.z1.obs0, SYS@$fo_oracle_tenant, ,SYS, , USE_OB_CONNECTOR);
connection fo_oracle_tenant_conn;
--error 600
eval ALTER SYSTEM ACTIVATE STANDBY TENANT $fo_oracle_tenant;

select TENANT_ID, TENANT_NAME, TENANT_TYPE, COMPATIBILITY_MODE, STATUS, IN_RECYCLEBIN, LOCKED, TENANT_ROLE, SWITCHOVER_STATUS, LOG_MODE from DBA_OB_TENANTS order by TENANT_ID;
select count(*) from DBA_OB_TENANTS where SYNC_SCN >= REPLAYABLE_SCN and REPLAYABLE_SCN>=READABLE_SCN and RECOVERY_UNTIL_SCN !=0 and TENANT_TYPE = 'USER';

set ob_query_timeout  = 10000000;
ALTER SYSTEM ACTIVATE STANDBY;

ob_connect(sys_conn, ob2.z1.obs0, root, , oceanbase, , USE_MYSQL_CONNECTOR);
connection sys_conn;
alter system change tenant tenant_id = 1003;
select tenant_role from __all_tenant_info where tenant_id = 1004;
# PRIMARY

ob_connect(fo_oracle_tenant_conn, ob2.z1.obs0, SYS@$fo_oracle_tenant, ,TEST, , USE_OB_CONNECTOR);
connection fo_oracle_tenant_conn;
select * from pt order by c1;
select * from nt order by c1;
ob_connect(sys_conn, ob2.z1.obs0, root, , oceanbase, , USE_MYSQL_CONNECTOR);
connection sys_conn;
# check co sstable status
let $observer_id = 2;
let $tenant_name = '$fo_oracle_tenant';
let $tenant_id = deploy_get_value(ob2.select select tenant_id from oceanbase.__all_tenant where tenant_name=$tenant_name, tenant_id, 1);
ob2.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id = $tenant_id and last_scn = 1, 0, 200;
let $table_name = "pt";
--source include/compaction/check_major_sstable_status.inc
let $table_name = "nt";
--source include/compaction/check_major_sstable_status.inc