# owner:weixue.cx
# owner group:storage
# description:
# 测试点：合并后新建租户建索引 28603770
##
ob1=OBI(cluster=1,proxy_num=0,init_unit_cpu=2);
ob1.reboot;
sleep 5;

ob1.mysql alter system set merger_check_interval='10s';
ob1.mysql alter system set enable_rebalance = 'false';

let $ip=deploy_get_value(ob1.z1.obs0.ip);
let $port=deploy_get_value(ob1.z1.obs0.mysql_port);
connect (conn1,$ip,admin@obtest,admin,oceanbase,$port);
connect (conn2,$ip,root@sys,,oceanbase,$port);

# 1. major freeze;
ob1.mysql alter system major freeze;
ob1.check_version 2;

# 2. create tenant;
ob1.mysql create resource pool rp1 unit = 'sys_unit_config', unit_num = 1, zone_list = ('z1');
ob1.mysql create tenant tt1 replica_num 1, primary_zone 'z1', resource_pool_list ('rp1'), locality = "F@z1" set ob_tcp_invited_nodes='%';

connect (conn3,$ip,root@tt1,,test,$port);
connection conn3;

create table t1(c1 int primary key, c2 int) partition by hash(c1) partitions 2;
insert into t1 values(1,1);
insert into t1 values(2,2);
insert into t1 values(3,3);

# 3. create index
create index i2 on t1(c2) global;
