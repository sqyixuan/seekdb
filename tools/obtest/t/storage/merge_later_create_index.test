# owner:yongle.xh
# owner group:storage
--disable_query_log
ob1=OBI(cluster=2:2:2,proxy_num=0,init_unit_cpu=4);
ob1.reboot;

ob1.mysql alter system set merger_check_interval='10s';
ob1.mysql alter system set enable_rebalance = 'false';
ob1.mysql alter system set resource_hard_limit=500;
ob1.mysql alter resource pool obtestpool unit_num 2;
ob1.mysql alter system set debug_sync_timeout = '100000s';

let $ip=deploy_get_value(ob1.z1.obs0.ip);
let $port=deploy_get_value(ob1.z1.obs0.mysql_port);
connect (conn1,$ip,admin@obtest,admin,oceanbase,$port);
connect (conn2,$ip,root@sys,,oceanbase,$port);
connection conn1;

use test;
create table test01 (pk1 int, pk2 int, pk3 int, f1 varchar(1024), f2 varchar(4096), primary key(pk1,pk2,pk3), index i1(f1));
insert into test01(pk1, pk2,pk3, f1, f2) values(1,1,1,'1', '2');
insert into test01(pk1, pk2,pk3, f1, f2) values(2,2,2,'1', '2');

ob1.mysql set ob_global_debug_sync = 'BEFORE_GET_MINOR_MGERGE_TABLES wait_for continue_signal';

ob1.mysql alter system minor freeze tenant = sys;
ob1.mysql alter system minor freeze tenant = all_user;
ob1.mysql alter system minor freeze tenant = all_meta;

--error 5703
create unique index i2 on test01(f1);
sleep 10;

ob1.mysql set ob_global_debug_sync = 'now signal continue_signal';

ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table_mgr where table_type=0 and is_active=0, 0, 60;

ob1.mysql alter system major freeze;
ob1.check_version 2;


