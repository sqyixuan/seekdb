# owner: zhenjiang.xzj
# owner group: storage
# Test the case: multi scan query

ob1=OBI(cluster=1:1, proxy_num=0,init_unit_cpu=2);
ob1.reboot;

ob1.mysql alter system set resource_hard_limit=800;
ob1.mysql alter system set merger_switch_leader_duration_time=0;
ob1.mysql alter system set enable_auto_leader_switch=false;
ob1.mysql alter system set enable_rereplication=false;
ob1.mysql alter system set enable_rebalance=false;
ob1.mysql alter system set bf_cache_miss_count_threshold=5;

let $ip=deploy_get_value(ob1.z1.obs0.ip);
let $port=deploy_get_value(ob1.z1.obs0.mysql_port);
connect (conn0,$ip,admin@obtest,admin,oceanbase,$port);
connect (conn1,$ip,root@sys,,oceanbase,$port);
connection conn0;

# test scan bloomfilter

create table test.t1(c1 int, c2 int, c3 varchar(20), primary key(c1, c2));

let $cnt=1;
while($cnt < 10)
{
  eval insert into test.t1 values(1, $cnt, 'oceanbase');
  inc $cnt;
  inc $cnt;
  inc $cnt;
  inc $cnt;
}

ob1.mysql alter system major freeze;
ob1.check_version 2;

let $cnt=1;
while($cnt < 4)
{
  eval select * from test.t1 where (c1=1 and c2>=2 and c2<4) or (c1=1 and c2>=6 and c2<8);
  inc $cnt;
}

let $table_id = deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where table_name='t1', table_id, 1);
let $host_ip = deploy_get_value(ob1.select select concat(svr_ip, ':', svr_port) host from oceanbase.__all_virtual_meta_table where table_id=$table_id and role=1, host, 1);
let $host = deploy_get_value(ob1.get_obs_by_addr $host_ip);

$host.check_log_until_success -c "Success to build bloom filter, (table_id=$table_id";
