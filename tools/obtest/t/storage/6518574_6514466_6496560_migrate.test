let $src_sql = select count(1) ct from oceanbase.__all_virtual_meta_table where table_id=$table_id and svr_ip='$src_ip2' and svr_port='$src_port2';
let $dst_sql = select count(1) ct from oceanbase.__all_virtual_meta_table where table_id=$table_id and svr_ip='$dst_ip2' and svr_port='$dst_port2';
# check replica distributed before move
let $src_bef = deploy_get_value(ob1.select $src_sql, ct, 1);
let $dst_bef = deploy_get_value(ob1.select $dst_sql, ct, 1);
# migrate
$src2.migrate_to $dst2,obtest:test:test01;
sleep 20;
# check replica distributed after move
let $src_aft = deploy_get_value(ob1.select $src_sql, ct, 1);
let $dst_aft = deploy_get_value(ob1.select $dst_sql, ct, 1);

#let $tmp = math($src_aft + 1);
#if ($src_bef == $tmp)
#{
#--echo succeed
#}
let $tmp = math($dst_aft - 1);
if ($dst_bef == $tmp)
{
--echo succeed
}
