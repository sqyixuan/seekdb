--disable_query_log
ob1=OBI(cluster=2:2:2,proxy_num=1,init_unit_cpu=2,init_unit_num=2);
ob1.reboot;

ob1.mysql alter system set merger_check_interval='10s';
ob1.mysql alter system set enable_rebalance='false';
ob1.mysql alter system set enable_rereplication='false';

let $ip=deploy_get_value(ob1.z1.obs0.ip);
let $port=deploy_get_value(ob1.z1.obs0.mysql_port);
connect (conn1,$ip,root@obtest,,test,$port);
connection conn1;

# create partition
create table test01 (pk1 int, pk2 int, pk3 int, f1 varchar(1024), f2 varchar(4096), primary key(pk1,pk2,pk3));
let $table_id=deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where table_name='test01', table_id, 1);

### migrate first follower
# insert data
let $cnt =1;
while ($cnt < 10)
{
	eval insert into test01 values($cnt, $cnt, $cnt, 'abc', 'def');
	inc $cnt;
}
# major freeze
ob1.mysql alter system major freeze;
sleep 60;
ob1.check_version 2;
ob1.check_until_timeout select sum(mem_used) from oceanbase.__all_virtual_memstore_info where tenant_id=1002 && is_active=1 && table_id='$table_id', 0, 120;
ob1.check_until_timeout select sum(mem_used) from oceanbase.__all_virtual_memstore_info where tenant_id=1002 && is_active=0 && table_id='$table_id', NULL, 120;
# get second follower
let $src = deploy_get_value(ob1.get_follower obtest:test:test01:0,1);
let $src_ip = deploy_get_value($src.ip);
let $src_port = deploy_get_value($src.port);
let $src_zone = deploy_get_value($src.zone);
let $dst_host = deploy_get_value(ob1.select select concat(svr_ip, ':', svr_port) host from oceanbase.__all_server where zone='$src_zone' and svr_port !='$src_port', host, 1);
let $dst = deploy_get_value(ob1.get_obs_by_addr $dst_host);
let $dst_ip = deploy_get_value($dst.ip);
let $dst_port = deploy_get_value($dst.port);
# get second follower
let $src2 = deploy_get_value(ob1.get_follower obtest:test:test01:0,2);
let $src_ip2 = deploy_get_value($src2.ip);
let $src_port2 = deploy_get_value($src2.port);
let $src_zone2 = deploy_get_value($src2.zone);
let $dst_host2 = deploy_get_value(ob1.select select concat(svr_ip, ':', svr_port) host from oceanbase.__all_server where zone='$src_zone2' and svr_port!='$src_port2', host, 1);
let $dst2 = deploy_get_value(ob1.get_obs_by_addr $dst_host2);
let $dst_ip2 = deploy_get_value($dst2.ip);
let $dst_port2 = deploy_get_value($dst2.port);

let $src_sql = select count(1) ct from oceanbase.__all_virtual_meta_table where table_id=$table_id and svr_ip='$src_ip' and svr_port='$src_port';
let $dst_sql = select count(1) ct from oceanbase.__all_virtual_meta_table where table_id=$table_id and svr_ip='$dst_ip' and svr_port='$dst_port';
# check replica distributed before move
let $src_bef = deploy_get_value(ob1.select $src_sql, ct, 1);
let $dst_bef = deploy_get_value(ob1.select $dst_sql, ct, 1);
# migrate
$src.migrate_to $dst,obtest:test:test01;
sleep 20;
# check replica distributed after move
let $src_aft = deploy_get_value(ob1.select $src_sql, ct, 1);
let $dst_aft = deploy_get_value(ob1.select $dst_sql, ct, 1);

#let $tmp = math($src_aft+1);
#if ($src_bef == $tmp)
#{
#--echo succeed
#}
let $tmp = math($dst_aft-1);
if ($dst_bef == $tmp)
{
--echo succeed
}
### migrate second follower
# insert data
let $cnt = 5;
while ($cnt < 15)
{
	eval replace into test01 values($cnt, $cnt, $cnt, 'abc', 'def');
	inc $cnt;
}
# major freeze
ob1.mysql alter system major freeze;
sleep 60;
ob1.check_version 3;
