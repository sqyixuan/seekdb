# owner: yunshan.tys
# owner group: storage
# description: this case is used for preprocess machine
#

ob1=OBI(cluster=2:2:2,proxy_num=0,init_unit_cpu=2, init_unit_num=2);

ob1.reboot;

ob1.mysql alter resource pool obtestpool unit_num 2;

let $ip = deploy_get_value(ob1.z2.obs0.ip);
let $port = deploy_get_value(ob1.z2.obs0.mysql_port);

connect(mysql_conn, $ip, root@obtest,,test, $port);
connect(sys_conn, $ip, root@sys,,oceanbase, $port);

connection mysql_conn;

set ob_trx_timeout=100000000;
set ob_query_timeout=100000000;

--disable_warnings
drop table if exists tt;
--enable_warnings

create table tt(a int primary key);

insert into tt values(1);
select * from tt;

#测试快速迁移完成后，目的端宕机重启。
connection sys_conn;
let $table_id = query_get_value(select * from __all_virtual_table where table_name='tt', table_id, 1);

let $role = 1;
let $timeout = 30;

--echo role = $role
--echo timeout = $timeout

# get src_ip, src_port, dest_ip, dest_port

let $zone = query_get_value(select * from __all_virtual_meta_table where table_id = $table_id and role = $role, zone, 1);

let $src_ip = query_get_value(select * from __all_virtual_meta_table where table_id = $table_id and zone = "$zone", svr_ip, 1);

let $src_port = query_get_value(select * from __all_virtual_meta_table where table_id = $table_id and zone = "$zone" and svr_ip = "$src_ip", svr_port, 1);

let $dest_ip = query_get_value(select * from __all_server where zone = "$zone" and (svr_ip != "$src_ip" or svr_port != $src_port), svr_ip, 1);

let $dest_port = query_get_value(select * from __all_server where zone = "$zone" and (svr_ip != "$src_ip" or svr_port != $src_port) and svr_ip = "$dest_ip", svr_port, 1);

# trigger partition move
--disable_query_log
eval alter system move replica partition_id = '0%1@$table_id' source='$src_ip:$src_port' destination='$dest_ip:$dest_port';

ob1.check_until_timeout select count(*) from __all_virtual_meta_table where table_id = $table_id and zone = "$zone", 1, 60000000; 

let $now_ip = query_get_value(select * from __all_virtual_meta_table where table_id = $table_id and zone = "$zone", svr_ip, 1);

let $now_port = query_get_value(select * from __all_virtual_meta_table where table_id = $table_id and zone = "$zone" and svr_ip = "$now_ip", svr_port, 1);

ob1.check_until_timeout select status from __all_virtual_meta_table where table_id = $table_id and zone = "$zone" and svr_ip = "$now_ip", NORMAL, 60000000;

--enable_query_log

connection mysql_conn;

select * from tt;

--echo fast_migrate_basic.test finished

sleep 20;

connection sys_conn;

let $stop_addr = deploy_get_value(ob1.select select concat(svr_ip, ":", svr_port) as addr from oceanbase.__all_server where svr_ip = "$now_ip" and svr_port = "$now_port", addr, 1);
let $stop_obs = deploy_get_value(ob1.get_obs_by_addr $stop_addr);

$stop_obs.force_stop;
$stop_obs.start;

sleep 20;

connection mysql_conn;

select * from tt;
