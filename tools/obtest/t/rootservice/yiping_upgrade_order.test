ob1=OBI(cluster=1:1:1,proxy_num=0,version=4_3_2_1);
ob1.reboot;

ob1.mysql create resource unit box max_cpu 4, memory_size='10G';
ob1.mysql create resource pool pool unit = 'box', unit_num = 1;
ob1.mysql create tenant mysql replica_num = 1, resource_pool_list=('pool');

ob1.check_until_timeout select count(1) as unsync_cnt from GV\$OB_LOG_STAT where in_sync = 'NO', 0, 600;

# 升级前检查
ob1.upgrade_check_before;

ob1.upgrade_commond_for_server pre;

ob1.force_stop;
ob1.upgrade;
ob1.nstart;

ob1.check_until_timeout select count(*) from oceanbase.__all_server where start_service_time <= 0 or status='INACTIVE',0,180;
ob1.check_until_timeout select count(1) as unsync_cnt from GV\$OB_LOG_STAT where in_sync = 'NO',0,600;
source include/check_schema_sync_for_restart.inc;

ob1.mysql alter system set enable_ddl=True;
ob1.check_until_timeout select count(*) from gv\$ob_parameters where name='enable_ddl' and value='False', 0, 600;
ob1.mysql alter system end rolling upgrade;

# target data version 没推，手动执行后续流程，预期报错
ob1.mysql alter system run upgrade job 'UPGRADE_SYSTEM_VARIABLE';
ob1.check_until_timeout select job_status from oceanbase.__all_rootservice_job where job_type like 'UPGRADE_%' order by job_id desc limit 1, FAILED, 600;
ob1.check_until_timeout select result_code from oceanbase.__all_rootservice_job where job_type like 'UPGRADE_%' order by job_id desc limit 1, -4179, 600;
ob1.mysql alter system run upgrade job 'UPGRADE_SYSTEM_TABLE';
ob1.check_until_timeout select job_status from oceanbase.__all_rootservice_job where job_type like 'UPGRADE_%' order by job_id desc limit 1, FAILED, 600;
ob1.check_until_timeout select result_code from oceanbase.__all_rootservice_job where job_type like 'UPGRADE_%' order by job_id desc limit 1, -4179, 600;
ob1.mysql alter system run upgrade job 'UPGRADE_VIRTUAL_SCHEMA';
ob1.check_until_timeout select job_status from oceanbase.__all_rootservice_job where job_type like 'UPGRADE_%' order by job_id desc limit 1, FAILED, 600;
ob1.check_until_timeout select result_code from oceanbase.__all_rootservice_job where job_type like 'UPGRADE_%' order by job_id desc limit 1, -4179, 600;
ob1.mysql alter system run upgrade job 'UPGRADE_SYSTEM_PACKAGE';
ob1.check_until_timeout select job_status from oceanbase.__all_rootservice_job where job_type like 'UPGRADE_%' order by job_id desc limit 1, FAILED, 600;
ob1.check_until_timeout select result_code from oceanbase.__all_rootservice_job where job_type like 'UPGRADE_%' order by job_id desc limit 1, -4179, 600;
ob1.mysql alter system run upgrade job 'UPGRADE_ALL_POST_ACTION';
ob1.check_until_timeout select job_status from oceanbase.__all_rootservice_job where job_type like 'UPGRADE_%' order by job_id desc limit 1, FAILED, 600;
ob1.check_until_timeout select result_code from oceanbase.__all_rootservice_job where job_type like 'UPGRADE_%' order by job_id desc limit 1, -4179, 600;
ob1.mysql alter system run upgrade job 'UPGRADE_END';
ob1.check_until_timeout select job_status from oceanbase.__all_rootservice_job where job_type like 'UPGRADE_%' order by job_id desc limit 1, FAILED, 600;
ob1.check_until_timeout select result_code from oceanbase.__all_rootservice_job where job_type like 'UPGRADE_%' order by job_id desc limit 1, -4179, 600;
ob1.mysql alter system run upgrade job 'UPGRADE_FINISH';
ob1.check_until_timeout select job_status from oceanbase.__all_rootservice_job where job_type like 'UPGRADE_%' order by job_id desc limit 1, FAILED, 600;
ob1.check_until_timeout select result_code from oceanbase.__all_rootservice_job where job_type like 'UPGRADE_%' order by job_id desc limit 1, -4179, 600;

ob1.mysql alter system run upgrade job 'UPGRADE_BEGIN';
ob1.check_until_timeout select job_status from oceanbase.__all_rootservice_job where job_type like 'UPGRADE_%' order by job_id desc limit 1, SUCCESS, 600;
ob1.mysql alter system run upgrade job 'UPGRADE_SYSTEM_VARIABLE';
ob1.check_until_timeout select job_status from oceanbase.__all_rootservice_job where job_type like 'UPGRADE_%' order by job_id desc limit 1, SUCCESS, 600;
ob1.mysql alter system run upgrade job 'UPGRADE_SYSTEM_TABLE';
ob1.check_until_timeout select job_status from oceanbase.__all_rootservice_job where job_type like 'UPGRADE_%' order by job_id desc limit 1, SUCCESS, 600;
ob1.mysql alter system run upgrade job 'UPGRADE_VIRTUAL_SCHEMA';
ob1.check_until_timeout select job_status from oceanbase.__all_rootservice_job where job_type like 'UPGRADE_%' order by job_id desc limit 1, SUCCESS, 600;
ob1.mysql alter system run upgrade job 'UPGRADE_SYSTEM_PACKAGE';
ob1.check_until_timeout select job_status from oceanbase.__all_rootservice_job where job_type like 'UPGRADE_%' order by job_id desc limit 1, SUCCESS, 600;
# current data version 没推，手动执行后续流程，预期报错
ob1.mysql alter system run upgrade job 'UPGRADE_END';
ob1.check_until_timeout select job_status from oceanbase.__all_rootservice_job where job_type like 'UPGRADE_%' order by job_id desc limit 1, FAILED, 600;
ob1.check_until_timeout select result_code from oceanbase.__all_rootservice_job where job_type like 'UPGRADE_%' order by job_id desc limit 1, -4179, 600;
ob1.mysql alter system run upgrade job 'UPGRADE_FINISH';
ob1.check_until_timeout select job_status from oceanbase.__all_rootservice_job where job_type like 'UPGRADE_%' order by job_id desc limit 1, FAILED, 600;
ob1.check_until_timeout select result_code from oceanbase.__all_rootservice_job where job_type like 'UPGRADE_%' order by job_id desc limit 1, -4179, 600;

ob1.mysql alter system run upgrade job 'UPGRADE_ALL_POST_ACTION';
ob1.check_until_timeout select job_status from oceanbase.__all_rootservice_job where job_type like 'UPGRADE_%' order by job_id desc limit 1, SUCCESS, 600;

# compatible 没推，手动执行后续流程，预期报错
ob1.mysql alter system run upgrade job 'UPGRADE_FINISH';
ob1.check_until_timeout select job_status from oceanbase.__all_rootservice_job where job_type like 'UPGRADE_%' order by job_id desc limit 1, FAILED, 600;
ob1.check_until_timeout select result_code from oceanbase.__all_rootservice_job where job_type like 'UPGRADE_%' order by job_id desc limit 1, -4179, 600;

ob1.mysql alter system run upgrade job 'UPGRADE_END';
ob1.check_until_timeout select job_status from oceanbase.__all_rootservice_job where job_type like 'UPGRADE_%' order by job_id desc limit 1, SUCCESS, 600;
ob1.mysql alter system run upgrade job 'UPGRADE_FINISH';
ob1.check_until_timeout select job_status from oceanbase.__all_rootservice_job where job_type like 'UPGRADE_%' order by job_id desc limit 1, SUCCESS, 600;
