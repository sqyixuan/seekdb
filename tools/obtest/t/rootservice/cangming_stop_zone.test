# CASE_OWNER:
#    @cangming.zl
# CASE_DESC:
#    本case是为了测试两台机器没有共同资源的时候，可以同时被stop;
#    case0: 只有系统租户，验证只有有primary zone存在，就能跨zone stop；
#    case1 :系统租户在z1.z2.z3,z4,z5; 用户租户在z1.z3.z4; 那么z2/z4可以同时stop;
#    case2: 同一个租户下，不能stop 全部primary zone的机器；

ob1=OBI(cluster=1:1:1:1:1,  proxy_num=0, ct_num = 0, locality=HZ:HZ:SH:SH:HZ);
ob1.reboot;
ob1.mysql alter system set balancer_idle_time = '10s';

# case0: 只有系统租户，验证只有有primary zone存在，就能跨zone stop；
ob_connect(conn_sys, ob1.z1.obs0, root, , oceanbase, , USE_MYSQL_CONNECTOR);
connection conn_sys;
set ob_query_timeout = 30000000;
###同时stop z3/z4
alter system stop zone 'z4';
--error 4660
alter system stop zone 'z3';
###同时stop z2/z4;
--error 4660
alter system stop zone 'z2';
alter system start zone 'z4';
alter system stop zone 'z2';
###同时stop z2/z5;
--error 4660
alter system stop zone 'z5';
##不剩余majority
--error 4660
alter system stop zone 'z1';
--error 4660
alter system stop zone 'z4';
alter system start zone 'z2';

let $case_index = 1;


ob1.mysql CREATE RESOURCE UNIT unit_$case_index MAX_CPU 2, MEMORY_SIZE '2G';
ob1.mysql CREATE RESOURCE POOL pool_$case_index UNIT = 'unit_$case_index', UNIT_NUM = 1, ZONE_LIST = ('z1', 'z3','z4');
ob1.mysql CREATE TENANT tenant_$case_index RESOURCE_POOL_LIST = ('pool_$case_index'), locality='F@z1,F@z3,F@z4', primary_zone='z3;z4;z1' set ob_tcp_invited_nodes='%';
ob_connect(tt1_conn, ob1.z1.obs0, root@tenant_1, , test, , USE_MYSQL_CONNECTOR);
connection tt1_conn;
create table tt(c1 int primary key, c2 int) partition by hash(c1) partitions 100;
create table tt2(c1 int primary key, c2 int) partition by hash(c1) partitions 100;

##case 1: 验证z2/z4能同时stop;
ob_connect(conn_sys, ob1.z1.obs0, root, , oceanbase, , USE_MYSQL_CONNECTOR);
connection conn_sys;
set ob_query_timeout = 30000000;
alter system stop zone 'z4';
#ob1.check_until_timeout select count(*) from __all_virtual_clog_stat where is_in_sync = 0 and is_offline = 0, 0, 30;
--error 4660
alter system stop zone 'z2';
--error 4660
alter system stop zone 'z3';
##单独stop z2的机器也一样；
let $ip = deploy_get_value(ob1.z2.obs0.ip);
let $port = deploy_get_value(ob1.z2.obs0.port);
--disable_query_log
--error 4660
eval alter system stop server '$ip:$port';
--enable_query_log
#恢复
alter system start zone 'z4';

# case2: 同一个租户下，不能stop 全部primary zone的机器；
###不能同时stop z3/z4;
alter system stop zone 'z4';
--error 4660
alter system stop zone 'z3';
##单独stop z3的机器也一样；
let $ip = deploy_get_value(ob1.z3.obs0.ip);
let $port = deploy_get_value(ob1.z3.obs0.port);
--disable_query_log
--error 4660
eval alter system stop server '$ip:$port';
--enable_query_log
alter system start zone 'z4';
###serve级别来一次
--disable_query_log
eval alter system stop server '$ip:$port';
--enable_query_log
let $ip = deploy_get_value(ob1.z4.obs0.ip);
let $port = deploy_get_value(ob1.z4.obs0.port);
--disable_query_log
--error 4660
eval alter system stop server '$ip:$port';
--enable_query_log
###恢复
--disable_query_log
eval alter system start server '$ip:$port';
--enable_query_log
###
