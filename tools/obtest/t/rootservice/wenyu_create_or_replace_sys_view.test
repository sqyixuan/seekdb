# CASE_OWNER:
#    @wenyu.ffz
# CASE_DESC:
#    校验replace sys view

ob1=OBI(cluster=1:1,proxy_num=0);
source include/mini_ob_config.inc;
ob1.set extra_config=$mini_ob_config;
ob1.reboot;

ob_connect(conn_sys, ob1.z1.obs0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);
eval CREATE RESOURCE UNIT unit_1 MAX_CPU 2, MEMORY_SIZE '4G';
eval CREATE RESOURCE POOL pool_1 UNIT = 'unit_1', UNIT_NUM = 1;
eval CREATE TENANT oracle RESOURCE_POOL_LIST = ('pool_1'), primary_zone='z1' set ob_tcp_invited_nodes='%', ob_compatibility_mode='oracle';
# enable_sys_table_ddl = false
alter system set enable_sys_table_ddl = false;
create table t1(col1 int);
--error 4179
create or replace view information_schema.columns as select * from t1;

ob_connect(conn_oracle, ob1.z1.obs0, SYS@oracle, ,SYS, , USE_OB_CONNECTOR);

create table t1(col1 int);
--error 600
create or replace view DBA_TAB_COLS as select * from t1;

connection conn_sys;
alter system set enable_sys_table_ddl = true;
create or replace view information_schema.columns as select * from t1;

connection conn_oracle;
create or replace view DBA_TAB_COLS as select * from t1;
