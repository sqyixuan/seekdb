# CASE_OWNER:
#    @jingyu.cr
# CASE_DESC:
#    测试rs宕机后，在永久下线内，all_core_table不会从成员列表中剔除, 全程关闭补副本开关

ob1=OBI(cluster=2:2:2,proxy_num=0,init_unit_cpu=0);
ob1.reboot;

ob1.mysql alter system set enable_rereplication = "false";
ob1.mysql alter system set balancer_idle_time = '10s';


ob_connect(conn_sys, ob1.z1.obs0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);
connection conn_sys;
ob1.mysql alter tenant sys primary_zone = 'z3;z2;z1';
ob1.check_until_timeout select count(1) from __all_virtual_core_meta_table where role=1 and zone='z3',1,120;
ob1.z3.obs0.force_stop;

ob1.check_until_timeout select count(1) from __all_virtual_core_meta_table where role=1 and zone='z2',1,240;
ob1.mysql alter tenant sys primary_zone = 'z1';
sleep 10;
ob1.z3.obs0.start;
ob1.check_until_timeout select count(*) c from oceanbase.__all_server where status = "active", 6, 600;
ob1.check_until_timeout select count(*) c from oceanbase.__all_virtual_core_meta_table, 3, 600;


ob1.z3.obs1.force_stop;
ob1.check_until_timeout select count(*) c from oceanbase.__all_server where status = "active", 5, 600;
ob1.z3.obs1.start;
ob1.check_until_timeout select count(*) c from oceanbase.__all_server where status = "active", 6, 600;
