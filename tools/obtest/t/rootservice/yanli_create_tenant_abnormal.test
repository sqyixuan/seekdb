# CASE_OWNER:
#    @msy164651
# CASE_DESC:
#    测试租户创建失败在任何阶段，都可以继续下去

ob1=OBI(cluster=1,proxy_num=0);
let $extra_conf = "cpu_count=32,memory_limit='50G',system_memory='5G',__min_full_resource_pool_memory='2147483648',cache_wash_threshold='1G',enable_async_syslog=false,_private_buffer_size='16K',_fast_commit_callback_count='1',log_disk_size='20G'";
ob1.z1.obs0.set extra_config=$extra_conf;

ob1.reboot;
ob1.mysql alter system set debug_sync_timeout = '1000s';
ob1.mysql CREATE RESOURCE UNIT unit_for_test MAX_CPU 1, MEMORY_SIZE '2G', LOG_DISK_SIZE '2G';
ob1.mysql alter resource unit sys_unit_config min_cpu 1, max_cpu 1, memory_size '2G';
ob_connect(conn_sys, ob1.z1.obs0, root, , oceanbase, , USE_MYSQL_CONNECTOR);

#case 1创建meta租户前失败
ob1.mysql set ob_global_debug_sync = 'BEFORE_CREATE_META_TENANT wait_for signal execute 1';
connection conn_sys;
set ob_query_timeout = 10000000;
alter system set _ob_ddl_timeout = '10s';
CREATE RESOURCE POOL pool_1 UNIT = 'unit_for_test', UNIT_NUM = 1, ZONE_LIST = ('z1');
--error 4012
CREATE TENANT tt RESOURCE_POOL_LIST = ('pool_1'), primary_zone='z1' set ob_tcp_invited_nodes='%';
let $tt_tenant_id = deploy_get_value(ob1.select select tenant_id from DBA_OB_TENANTS where tenant_name = 'tt', tenant_id, 1);
ob1.mysql_p select tenant_id, ls_id, status from oceanbase.__all_ls_status;
ob1.mysql set ob_global_debug_sync = 'now signal signal';
ob1.mysql_p select tenant_name, status from oceanbase.__all_tenant;
ob1.mysql_p select count(*) as cnt from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id = $tt_tenant_id;
ob1.mysql_p select count(*) as cnt from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id = $tt_tenant_id - 1;
ob1.mysql_p select count(*) > 0 as has_cnt from oceanbase.CDB_OB_TABLET_REPLICAS where tenant_id = $tt_tenant_id;
ob1.mysql_p select count(*) > 0 as has_cnt from oceanbase.CDB_OB_TABLET_REPLICAS where tenant_id = $tt_tenant_id - 1;
ob1.mysql_p select count(*) > 0 as has_cnt from oceanbase.__all_virtual_table where tenant_id = $tt_tenant_id;
ob1.mysql_p select count(*) > 0 as has_cnt from oceanbase.__all_virtual_table where tenant_id = $tt_tenant_id - 1;
drop tenant tt force;
drop resource pool pool_1;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_unit where tenant_id != 1, 0, 300;
#case 2 创建meta租户日志流成功之后，创建meta租户完成之前失败
ob1.mysql set ob_global_debug_sync = 'AFTER_CREATE_META_TENANT_SYS_LOGSTREAM wait_for signal execute 1';
connection conn_sys;
set ob_query_timeout = 10000000;
alter system set _ob_ddl_timeout = '10s';
CREATE RESOURCE POOL pool_1 UNIT = 'unit_for_test', UNIT_NUM = 1, ZONE_LIST = ('z1');
--error 4012
CREATE TENANT tt RESOURCE_POOL_LIST = ('pool_1'), primary_zone='z1' set ob_tcp_invited_nodes='%';
let $tt_tenant_id = deploy_get_value(ob1.select select tenant_id from DBA_OB_TENANTS where tenant_name = 'tt', tenant_id, 1);
ob1.mysql_p select tenant_id, ls_id, status from oceanbase.__all_ls_status;
ob1.mysql set ob_global_debug_sync = 'now signal signal';
ob1.mysql_p select tenant_name, status from oceanbase.__all_tenant;
ob1.mysql_p select count(*) as cnt from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id = $tt_tenant_id;
ob1.mysql_p select count(*) as cnt from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id = $tt_tenant_id - 1;
ob1.mysql_p select count(*) > 0 as has_cnt from oceanbase.CDB_OB_TABLET_REPLICAS where tenant_id = $tt_tenant_id;
ob1.mysql_p select count(*) > 0 as has_cnt from oceanbase.CDB_OB_TABLET_REPLICAS where tenant_id = $tt_tenant_id - 1;
ob1.mysql_p select count(*) > 0 as has_cnt from oceanbase.__all_virtual_table where tenant_id = $tt_tenant_id;
ob1.mysql_p select count(*) > 0 as has_cnt from oceanbase.__all_virtual_table where tenant_id = $tt_tenant_id - 1;
drop tenant tt force;
drop resource pool pool_1;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_unit where tenant_id != 1, 0, 300;
#case 3 创建用户租户前失败
ob1.mysql set ob_global_debug_sync = 'BEFORE_CREATE_USER_TENANT wait_for signal1 execute 1';
connection conn_sys;
alter system set _ob_ddl_timeout = '10s';
CREATE RESOURCE POOL pool_1 UNIT = 'unit_for_test', UNIT_NUM = 1, ZONE_LIST = ('z1');
--error 4012
CREATE TENANT tt RESOURCE_POOL_LIST = ('pool_1'), primary_zone='z1' set ob_tcp_invited_nodes='%';
ob1.mysql_p select tenant_id, ls_id, status from oceanbase.__all_ls_status;
ob1.mysql set ob_global_debug_sync = 'now signal signal1';
ob1.mysql_p select tenant_name, status from oceanbase.__all_tenant;
drop tenant tt force;
drop resource pool pool_1;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_unit where tenant_id != 1, 0, 300;
#case 4 创建用户租户日志流成功之后，创建用户租户完成之前失败
ob1.mysql set ob_global_debug_sync = 'AFTER_CREATE_USER_TENANT_SYS_LOGSTREAM wait_for signal2';
connection conn_sys;
set ob_query_timeout = 10000000;
alter system set _ob_ddl_timeout = '10s';
CREATE RESOURCE POOL pool_1 UNIT = 'unit_for_test', UNIT_NUM = 1, ZONE_LIST = ('z1');
send CREATE TENANT tt RESOURCE_POOL_LIST = ('pool_1'), primary_zone='z1' set ob_tcp_invited_nodes='%';
sleep 15;
ob1.mysql set ob_global_debug_sync = 'now signal signal2';
--error 4012
reap;
let $tt_tenant_id = deploy_get_value(ob1.select select tenant_id from DBA_OB_TENANTS where tenant_name = 'tt', tenant_id, 1);
ob1.mysql_p select tenant_id, ls_id, status from oceanbase.__all_ls_status;
ob1.mysql_p select tenant_name, status from oceanbase.__all_tenant;
ob1.mysql_p select count(*) as cnt from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id = $tt_tenant_id;
ob1.mysql_p select count(*) as cnt from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id = $tt_tenant_id - 1;
ob1.mysql_p select count(*) > 0 as has_cnt from oceanbase.CDB_OB_TABLET_REPLICAS where tenant_id = $tt_tenant_id;
ob1.mysql_p select count(*) > 0 as has_cnt from oceanbase.CDB_OB_TABLET_REPLICAS where tenant_id = $tt_tenant_id - 1;
ob1.mysql_p select count(*) > 0 as has_cnt from oceanbase.__all_virtual_table where tenant_id = $tt_tenant_id;
ob1.mysql_p select count(*) > 0 as has_cnt from oceanbase.__all_virtual_table where tenant_id = $tt_tenant_id - 1;
drop tenant tt force;
drop resource pool pool_1;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_unit where tenant_id != 1, 0, 300;
#case 5 create end 之前失败
ob1.mysql set ob_global_debug_sync = 'BEFORE_CREATE_TENANT_END wait_for signal4';
connection conn_sys;
CREATE RESOURCE POOL pool_1 UNIT = 'unit_for_test', UNIT_NUM = 1, ZONE_LIST = ('z1');
set ob_query_timeout = 10000000;
alter system set _ob_ddl_timeout = '15s';
send CREATE TENANT tt RESOURCE_POOL_LIST = ('pool_1'), primary_zone='z1' set ob_tcp_invited_nodes='%';
sleep 15;
ob1.mysql set ob_global_debug_sync = 'now signal signal4';
--error 4012
reap;
ob1.mysql_p select tenant_name, status from oceanbase.__all_tenant;
drop tenant tt force;
drop resource pool pool_1;
