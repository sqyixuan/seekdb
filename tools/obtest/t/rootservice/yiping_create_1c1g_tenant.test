ob1=OBI(cluster=1:1:1,proxy_num=0);
ob1.reboot;

let $ip = deploy_get_value(ob1.z1.obs0.ip);
let $port = deploy_get_value(ob1.z1.obs0.port);

ob1.mysql alter tenant sys set primary_zone='z1';
ob1.check_until_timeout select role from oceanbase.__all_ls_meta_table where tenant_id=1 and ls_id=1 and zone='z1', 1, 40;
ob1.check_until_timeout select count(*)>0 from oceanbase.__all_rootservice_event_history where event='full_rootservice' and value1=0 and value2 like '%$ip:$port%' order by 1 desc, 1, 10;

ob1.mysql create resource unit 1c1g max_cpu 1, memory_size='1G';
ob1.mysql create resource pool pool unit = '1c1g', unit_num = 1;

# 1c1g mysql租户
ob1.mysql create tenant mysql resource_pool_list('pool'), primary_zone 'z1';
let $tenant_id = deploy_get_value(ob1.select select max(tenant_id) a from dba_ob_tenants, a, 1);
ob1.check_until_timeout select count(*) from __all_virtual_ls_status where tenant_id=$tenant_id and ls_id!=1 and status='NORMAL', 1, 20;
ob1.check_until_timeout select count(*) from __all_virtual_ls_meta_table where tenant_id=$tenant_id and ls_id!=1 and role=1, 1, 20;
ob1.mysql drop tenant mysql force;

# 1c1g oracle租户
ob1.mysql create tenant oracle resource_pool_list('pool'), primary_zone 'z1' set ob_compatibility_mode='oracle';
let $tenant_id = deploy_get_value(ob1.select select max(tenant_id) a from dba_ob_tenants, a, 1);
ob1.check_until_timeout select count(*) from __all_virtual_ls_status where tenant_id=$tenant_id and ls_id!=1 and status='NORMAL', 1, 20;
ob1.check_until_timeout select count(*) from __all_virtual_ls_meta_table where tenant_id=$tenant_id and ls_id!=1 and role=1, 1, 20;
ob1.mysql drop tenant oracle force;
