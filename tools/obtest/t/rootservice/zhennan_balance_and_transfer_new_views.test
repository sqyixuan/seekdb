select task_type, src_ls, dest_ls, part_list, finished_part_list, part_count, finished_part_count, ls_group_id, status, comment from oceanbase.DBA_OB_BALANCE_TASK_HISTORY;
select src_ls, dest_ls, part_list, part_count, not_exist_part_list, lock_conflict_part_list, table_lock_tablet_list, tablet_list, tablet_count, status, comment from oceanbase.DBA_OB_TRANSFER_TASK_HISTORY;
