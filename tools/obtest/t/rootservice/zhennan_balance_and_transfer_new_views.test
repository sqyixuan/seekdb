--echo
--echo # 2.2 DBA/CDB_OB_LS_LOCATIONS
--echo # sys
connection conn_sys;
select count(*) from DBA_OB_LS_LOCATIONS;
select count(*) from CDB_OB_LS_LOCATIONS;
--echo # mysql
connection conn_mysql;
select count(*) from oceanbase.DBA_OB_LS_LOCATIONS;
--echo # oracle
connection conn_oracle;
select count(*) from DBA_OB_LS_LOCATIONS;

--echo
--echo # 2.3 DBA/CDB_OB_TABLE_LOCATIONS (object_id, tablegroup_name, tablegroup_id)
--echo # 2.3.1 prepare data
--disable_query_log
# tablegroup with different sharding
connection conn_mysql;
create tablegroup tg_none sharding = 'NONE';
create tablegroup tg_partition sharding = 'PARTITION';
create tablegroup tg_adaptive sharding = 'ADAPTIVE';

# nonpart table
create table t_nonpart_1 (c1 int primary key, c2 int);
create table t_nonpart_2 (c1 int primary key, c2 int);
alter tablegroup tg_none add t_nonpart_1, t_nonpart_2;

# part table
## range
CREATE TABLE t_part_r (log_id BIGINT NOT NULL,log_value VARCHAR(50),log_date TIMESTAMP NOT NULL)
       PARTITION BY RANGE(UNIX_TIMESTAMP(log_date)) 
        (PARTITION M202003 VALUES LESS THAN(UNIX_TIMESTAMP('2020/04/01'))
       , PARTITION M202004 VALUES LESS THAN(UNIX_TIMESTAMP('2020/08/01'))
       , PARTITION M202011 VALUES LESS THAN(UNIX_TIMESTAMP('2020/12/01'))
       );
## list
CREATE TABLE t_part_l (col1 BIGINT PRIMARY KEY,col2 VARCHAR(50))
       PARTITION BY LIST(col1) 
        (PARTITION p0 VALUES IN (1, 2, 3),
         PARTITION p1 VALUES IN (5, 6),
         PARTITION p2 VALUES IN (DEFAULT)
        );
## hash
CREATE TABLE t_part_h(col1 INT,col2 VARCHAR(50))
       PARTITION BY HASH(col1) PARTITIONS 3;
## key
CREATE TABLE t_part_k(id INT,gmt_create DATETIME,info VARCHAR(20))
       PARTITION BY KEY(id,gmt_create) PARTITIONS 3;
alter tablegroup tg_partition add t_part_k;

# sub part table
## Hash + Range
CREATE TABLE t_subpart_h_r (col1 INT,col2 INT) 
       PARTITION BY KEY(col1) 
       SUBPARTITION BY RANGE(col2)
         (PARTITION p1
          (SUBPARTITION sp0 VALUES LESS THAN (2020)
          ,SUBPARTITION sp1 VALUES LESS THAN (2021)
          ,SUBPARTITION sp2 VALUES LESS THAN (2022)
          ),
          PARTITION p2
          (SUBPARTITION sp4 VALUES LESS THAN (2020)
          ,SUBPARTITION sp5 VALUES LESS THAN (2021)
          ,SUBPARTITION sp6 VALUES LESS THAN (2022)
          )
         );
## List Columns + Hash
CREATE TABLE t_subpart_lc_h(col1 INT,col2 INT) 
       PARTITION BY LIST COLUMNS(col1)
       SUBPARTITION BY HASH(col2) SUBPARTITIONS 2
        (PARTITION p0 VALUES IN(100),
         PARTITION p1 VALUES IN(200),
         PARTITION p2 VALUES IN(300)
        ); 
## Range Columns + List Columns
CREATE TABLE t_subpart_rc_lc (col1 INT,col2 INT) 
       PARTITION BY RANGE COLUMNS(col1)
       SUBPARTITION BY LIST COLUMNS(col2)
       (PARTITION p0 VALUES LESS THAN(100)
         (SUBPARTITION sp0 VALUES IN(1,3),
          SUBPARTITION sp1 VALUES IN(4,6),
          SUBPARTITION sp2 VALUES IN(7,9)),
        PARTITION p1 VALUES LESS THAN(200)
         (SUBPARTITION sp3 VALUES IN(1,3),
          SUBPARTITION sp4 VALUES IN(4,6),
          SUBPARTITION sp5 VALUES IN(7,9))
       );
alter tablegroup tg_adaptive add t_subpart_rc_lc;

# "'XXX'" will be applied as ''XXX'', so remove first and last '
let $table_in_tablegroup = "t_nonpart_1', 't_nonpart_2', 't_part_k', 't_subpart_rc_lc";
let $nonpart_table_name = "t_nonpart_1', 't_nonpart_2";
let $part_table_name = "t_part_h', 't_part_k', 't_part_l', 't_part_r";
let $subpart_table_name = "t_subpart_h_r', 't_subpart_lc_h', 't_subpart_rc_lc";
let $all_table_name = $nonpart_table_name, $part_table_name, $subpart_table_name;

# oracle
connection conn_oracle;
create tablegroup tg_none_oracle sharding = 'NONE';
create table t_nonpart_oracle (c1 int primary key, c2 int);
alter tablegroup tg_none_oracle add t_nonpart_oracle;
--enable_query_log

--echo
--echo # 2.3.2 verify DBA_OB_TABLE_LOCATIONS
--echo # sys
connection conn_sys;
eval select distinct tenant_id, table_name, table_type, partition_name, subpartition_name, object_id, tablegroup_name, tablegroup_id, sharding from CDB_OB_TABLE_LOCATIONS where table_name in ($all_table_name) order by object_id;
# verify tablegroup_id
--echo # 36 = 3 * (1/*__all_core_table*/ + 1/*t_nonpart_1*/ + 1/*t_nonpart_2*/ + 3/*t_part_k*/ + 6/*t_subpart_rc_lc*/)
eval select count(*) from CDB_OB_TABLE_LOCATIONS A join CDB_OBJECTS B on A.TENANT_ID = B.CON_ID and A.TABLEGROUP_NAME = B.OBJECT_NAME and B.OBJECT_TYPE = 'TABLEGROUP' and A.TABLEGROUP_ID = B.OBJECT_ID where A.TABLE_NAME in ('__all_core_table', $table_in_tablegroup) and A.TENANT_ID = $mysql_tenant_id;
# verify object_id
--echo # 6 = 3 * (1/*t_nonpart_1*/ + 1/*t_nonpart_2*/)
eval select count(*) from CDB_OB_TABLE_LOCATIONS A join CDB_OBJECTS B on A.TENANT_ID = B.CON_ID and A.DATABASE_NAME = B.OWNER and A.TABLE_NAME = B.OBJECT_NAME and A.OBJECT_ID = B.OBJECT_ID where A.TABLE_NAME in ($nonpart_table_name) and A.TENANT_ID = $mysql_tenant_id;
--echo # 36 = 3 * (3/*t_part_h*/ + 3/*t_part_k*/ + 3/*t_part_l*/ + 3/*t_part_r*/)
eval select count(*) from CDB_OB_TABLE_LOCATIONS A join CDB_OBJECTS B on A.TENANT_ID = B.CON_ID and A.DATABASE_NAME = B.OWNER and A.TABLE_NAME = B.OBJECT_NAME and A.PARTITION_NAME = B.SUBOBJECT_NAME and A.OBJECT_ID = B.OBJECT_ID where A.TABLE_NAME in ($part_table_name) and A.TENANT_ID = $mysql_tenant_id;
--echo # 54 = 3 * (6/*t_subpart_h_r*/ + 6/*t_subpart_lc_h*/ + 6/*t_subpart_rc_lc*/)
eval select count(*) from CDB_OB_TABLE_LOCATIONS A join CDB_OBJECTS B on A.TENANT_ID = B.CON_ID and A.DATABASE_NAME = B.OWNER and A.TABLE_NAME = B.OBJECT_NAME and A.SUBPARTITION_NAME = B.SUBOBJECT_NAME and A.OBJECT_ID = B.OBJECT_ID where A.TABLE_NAME in ($subpart_table_name) and A.TENANT_ID = $mysql_tenant_id;
--echo # mysql
connection conn_mysql;
eval select /*+query_timeout(100000000)*/distinct table_name, table_type, partition_name, subpartition_name, object_id, tablegroup_name, tablegroup_id, sharding from oceanbase.DBA_OB_TABLE_LOCATIONS where table_name in ($all_table_name) order by object_id;
--echo # oracle
connection conn_oracle;
eval select distinct table_name, table_type, partition_name, subpartition_name, object_id, tablegroup_name, tablegroup_id, sharding from DBA_OB_TABLE_LOCATIONS where table_name = 'T_NONPART_ORACLE';

