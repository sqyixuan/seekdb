select balance_strategy, job_type, target_unit_num, target_primary_zone_num, status, comment from DBA_OB_BALANCE_JOB_HISTORY;
select tenant_id, balance_strategy, job_type, target_unit_num, target_primary_zone_num, status, comment from CDB_OB_BALANCE_JOB_HISTORY;
