ob1=OBI(cluster=2:2:2,init_unit_cpu=0,proxy_num=0);
let $extra_conf = "cpu_count=10,memory_limit='20G',system_memory='5G',__min_full_resource_pool_memory='1073741824',stack_size='1536K',cache_wash_threshold='1G',enable_async_syslog=false,_private_buffer_size='16K',_fast_commit_callback_count='1',log_disk_size='40G'";
ob1.z1.obs0.set extra_config=$extra_conf;
ob1.z1.obs1.set extra_config=$extra_conf;
ob1.z2.obs0.set extra_config=$extra_conf;
ob1.z2.obs1.set extra_config=$extra_conf;
ob1.z3.obs0.set extra_config=$extra_conf;
ob1.z3.obs1.set extra_config=$extra_conf;
ob1.reboot;

let $sys_tenant_id = 1;
ob1.mysql alter system set enable_rebalance='false';
ob1.mysql alter system set _transfer_start_trans_timeout = '60s';
ob1.mysql alter system set debug_sync_timeout = '1000s';
ob_connect(conn_sys, ob1.z1.obs0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);
connection conn_sys;
set @@session.ob_query_timeout = 1000000000;

--echo # create mysql tenant
CREATE RESOURCE UNIT if not exists unit_1 MAX_CPU 2, MEMORY_SIZE='3G';
CREATE RESOURCE POOL if not exists pool_1 UNIT = 'unit_1', UNIT_NUM = 1;
CREATE TENANT mysql RESOURCE_POOL_LIST = ('pool_1'), primary_zone='z1', locality="F@z1, F@z2, F@z3" set ob_tcp_invited_nodes='%';

--echo # create oracle tenant
CREATE RESOURCE POOL if not exists pool_2 UNIT = 'unit_1', UNIT_NUM = 1;
CREATE TENANT oracle RESOURCE_POOL_LIST = ('pool_2'), primary_zone='z1', locality="F@z1, F@z2, F@z3" set ob_tcp_invited_nodes='%', ob_compatibility_mode='oracle';
source include/check_schema_sync.inc;

--echo # create not used pool
CREATE RESOURCE POOL if not exists pool_3 UNIT = 'unit_1', UNIT_NUM = 1;

let $mysql_tenant_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name = 'mysql', tenant_id, 1);
let $oracle_tenant_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name = 'oracle', tenant_id, 1);
let $mysql_leader_ip_port=deploy_get_value(ob1.select select concat(svr_ip,':',svr_port) as host from __all_virtual_ls_meta_table where tenant_id = $mysql_tenant_id and ls_id =  1 and role = 1 limit 1, host, 1);
let $mysql_leader_obs =deploy_get_value(ob1.get_obs_by_addr $mysql_leader_ip_port);
let $oracle_leader_ip_port=deploy_get_value(ob1.select select concat(svr_ip,':',svr_port) as host from __all_virtual_ls_meta_table where tenant_id = $oracle_tenant_id and ls_id =  1 and role = 1 limit 1, host, 1);
let $oracle_leader_obs =deploy_get_value(ob1.get_obs_by_addr $oracle_leader_ip_port);
ob_connect(conn_mysql, $mysql_leader_obs, root@mysql, , test, , USE_MYSQL_CONNECTOR);
ob_connect(conn_oracle, $oracle_leader_obs, sys@oracle, , sys, , USE_OB_CONNECTOR);

--echo # create table
connection conn_mysql;
create table t1(c1 int primary key) partition by hash(c1) partitions 10;
connection conn_oracle;
create table t1(c1 int primary key) partition by hash(c1) partitions 10;

--echo # uint_num 1->2
--echo # verify unit_num of meta tenant in DBA_OB_TENANTS
connection conn_sys;
select tenant_id, unit_num from DBA_OB_TENANTS;
alter resource tenant mysql unit_num = 2;
select tenant_id, unit_num from DBA_OB_TENANTS;
alter resource tenant oracle unit_num = 2;
ob1.check_until_timeout select count(*) = 4 from DBA_OB_TENANTS where unit_num = 2 and tenant_id != 1, 1, 1;

ob1.mysql set ob_global_debug_sync = "AFTER_TRANSFER_PROCESS_INIT_TASK_AND_BEFORE_NOTIFY_STORAGE wait_for signal_lock_finish";

ob1.check_until_timeout select count(*) != 0 from oceanbase.__all_virtual_transfer_task where tenant_id = $mysql_tenant_id and status = 'START', 1, 120;
ob1.check_until_timeout select count(*) != 0 from oceanbase.__all_virtual_transfer_task where tenant_id = $oracle_tenant_id and status = 'START', 1, 120;

--echo ##########################
--echo # 1.verify new views in sys
connection conn_sys;
select balance_strategy, job_type, target_unit_num, target_primary_zone_num, status, comment from DBA_OB_BALANCE_JOBS;
select tenant_id, balance_strategy, job_type, target_unit_num, target_primary_zone_num, status, comment from CDB_OB_BALANCE_JOBS order by tenant_id;
select task_type, src_ls, dest_ls, part_list, finished_part_list, part_count, finished_part_count, ls_group_id, status, comment from DBA_OB_BALANCE_TASKS;
select tenant_id, task_type, src_ls, dest_ls, part_list, finished_part_list, part_count, finished_part_count, ls_group_id, status, comment from CDB_OB_BALANCE_TASKS order by tenant_id;
select src_ls, dest_ls, part_list, part_count, not_exist_part_list, lock_conflict_part_list, table_lock_tablet_list, tablet_list, tablet_count, status, comment from DBA_OB_TRANSFER_TASKS;
select tenant_id, src_ls, dest_ls, part_list, part_count, not_exist_part_list, lock_conflict_part_list, table_lock_tablet_list, tablet_list, tablet_count, status, comment from CDB_OB_TRANSFER_TASKS order by tenant_id;
--echo # verify new views in mysql
connection conn_mysql;
select balance_strategy, job_type, target_unit_num, target_primary_zone_num, status, comment from oceanbase.DBA_OB_BALANCE_JOBS;
select task_type, src_ls, dest_ls, part_list, finished_part_list, part_count, finished_part_count, ls_group_id, status, comment from oceanbase.DBA_OB_BALANCE_TASKS;
select src_ls, dest_ls, part_list, part_count, not_exist_part_list, lock_conflict_part_list, table_lock_tablet_list, tablet_list, tablet_count, status, comment from oceanbase.DBA_OB_TRANSFER_TASKS;
--echo # verify new views in oracle
connection conn_oracle;
select balance_strategy, job_type, target_unit_num, target_primary_zone_num, status, "COMMENT" from DBA_OB_BALANCE_JOBS;
select task_type, src_ls, dest_ls, part_list, finished_part_list, part_count, finished_part_count, ls_group_id, status, "COMMENT" from DBA_OB_BALANCE_TASKS;
select src_ls, dest_ls, part_list, part_count, not_exist_part_list, lock_conflict_part_list, table_lock_tablet_list, tablet_list, tablet_count, status, "COMMENT" from DBA_OB_TRANSFER_TASKS;

ob1.mysql set ob_global_debug_sync = "now signal signal_lock_finish";
--echo # wait balance finish
ob1.check_until_timeout select count(*) = 0 from oceanbase.__all_virtual_balance_job, 1, 120;
ob1.check_until_timeout select count(*) = 0 from oceanbase.__all_virtual_balance_task, 1, 120;
ob1.check_until_timeout select count(*) = 0 from oceanbase.__all_virtual_transfer_task, 1, 120;
ob1.check_until_timeout select count(*) = 0 from oceanbase.CDB_OB_LS where status != 'NORMAL', 1, 120;
ob1.check_until_timeout select count(*) = 0 from (select * from __all_virtual_ls_meta_table group by tenant_id, ls_id, zone having count(*) != 1), 1, 120;

--echo
