# CASE_OWNER:
#    @cangming.zl
# CASE_DESC:
#    Test whether heartbeat service can update __all_server table correctly
#    The various test cases is listed in the comments.

ob1=OBI(cluster=1:1:1,proxy_num=0);
ob1.z2.obs0.set status=disable;
ob1.reboot;
let $z1_ip = deploy_get_value(ob1.z1.obs0.ip);
let $z1_port = deploy_get_value(ob1.z1.obs0.port);
let $z2_ip = deploy_get_value(ob1.z2.obs0.ip);
let $z2_port = deploy_get_value(ob1.z2.obs0.port);
let $z3_ip = deploy_get_value(ob1.z3.obs0.ip);
let $z3_port = deploy_get_value(ob1.z3.obs0.port);
# ******************************************************************************************
# ****************************** 1. add server  ********************************************
# ******************************************************************************************
ob1.z2.obs0.set status=enable;
ob1.z2.obs0.start;
ob1.mysql alter system add zone 'z2';
ob1.mysql alter system start zone 'z2';
sleep 60;
ob1.z2.obs0.add;
ob1.check_until_timeout select count(*) from __all_server where svr_ip='$z2_ip' and svr_port=$z2_port and status='ACTIVE' and start_service_time > 0 and last_offline_time = 0,1,120;
# ******************************************************************************************
# ****************************** 2. server becomes offline  ********************************
# ******************************************************************************************
ob1.z2.obs0.force_stop;
ob1.check_until_timeout select count(*) from __all_server where svr_ip='$z2_ip' and svr_port=$z2_port and status='INACTIVE' and start_service_time = 0 and last_offline_time > 0,1,120;
# ******************************************************************************************
# ****************************** 3. server becomes online again  ***************************
# ******************************************************************************************
ob1.z2.obs0.start;
ob1.check_until_timeout select count(*) from __all_server where svr_ip='$z2_ip' and svr_port=$z2_port and status='ACTIVE' and start_service_time > 0 and last_offline_time = 0,1,120;

ob1.mysql alter resource pool sys_pool zone_list = ('z1','z2','z3');
ob1.mysql alter tenant sys locality="F@z1,F@z2,F@z3";
ob1.check_until_timeout select count(*) from __all_tenant where tenant_id = 1 and locality like "%FULL{1}@z1, FULL{1}@z2, FULL{1}@z3%",1,600;
ob1.mysql alter system set rootservice_list = '$z1_ip:$z1_port;$z2_ip:$z2_port;$z3_ip:$z3_port';
ob1.check_until_timeout SELECT COUNT(*) from __all_rootservice_job WHERE tenant_id = 1 AND job_type = "ALTER_TENANT_LOCALITY" AND sql_text LIKE "%F@z1,F@z2,F@z3%" AND extra_info like "%FULL{1}@z1, FULL{1}@z3%" AND job_status = "SUCCESS", 1, 120;
# ******************************************************************************************
# ****************************** 4. current leader (z1.obs0) becomes offline  **************
# ******************************************************************************************
ob1.z1.obs0.force_stop;
#ob_connect(conn_sys, ob1.z2.obs0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);
#connection conn_sys;
#eval select count(*) from __all_server where svr_ip='$z1_ip' and svr_port=$z1_port and status='INACTIVE' and start_service_time = 0 and last_offline_time > 0 and with_rootserver = 0;
#eval select count(*) from __all_server where with_rootserver = 1;
ob1.z3.obs0.check_until_timeout select count(*) from oceanbase.__all_server where svr_ip='$z1_ip' and svr_port=$z1_port and status='INACTIVE' and start_service_time = 0 and last_offline_time > 0 and with_rootserver = 0,1,120;
ob1.z3.obs0.check_until_timeout select count(*) from oceanbase.__all_server where with_rootserver = 1,1,120;
# ******************************************************************************************
# ****************************** 5. z1.obs0 becomes online and switch to leader ************
# ******************************************************************************************
ob1.z1.obs0.start;
ob1.check_until_timeout select count(*) from __all_server where svr_ip='$z1_ip' and svr_port=$z1_port and status='ACTIVE' and start_service_time > 0 and last_offline_time = 0 and with_rootserver = 0,1,120;
ob1.mysql alter system switch replica leader ls=1 server='$z1_ip:$z1_port' tenant='sys';
ob1.check_until_timeout select count(*) from __all_server where svr_ip='$z1_ip' and svr_port=$z1_port and  with_rootserver = 1, 1, 20;
ob1.check_until_timeout select count(*) from __all_server where with_rootserver = 1, 1, 20;
# ******************************************************************************************
# ****************************** 6. server disk error **************************************
# ******************************************************************************************
ob1.mysql alter system set_tp tp_name = ERRSIM_DISK_ERROR, error_code = 4016, frequency = 1;
ob1.check_until_timeout select count(*) from __all_server where id = 2 and stop_time > 0 and status='ACTIVE' and start_service_time > 0 and last_offline_time = 0,1,240;
# ******************************************************************************************
# ****************************** 7. server disk error repaired *****************************
# ******************************************************************************************
ob1.mysql alter system set_tp tp_name = ERRSIM_DISK_ERROR, error_code = 4016, frequency = 0;
ob1.check_until_timeout select count(*) from __all_server where id = 2 and stop_time = 0 and status='ACTIVE' and start_service_time > 0 and last_offline_time = 0,1,240;
# ******************************************************************************************
# ****************************** 8. stop / start server ************************************
# ******************************************************************************************
ob1.mysql alter system stop server '$z2_ip:$z2_port';
ob1.check_until_timeout select count(*) from __all_server where svr_ip='$z2_ip' and svr_port=$z2_port and stop_time > 0 and status='ACTIVE' and start_service_time > 0 and last_offline_time = 0,1,240;
ob1.mysql alter system start server '$z2_ip:$z2_port';
ob1.check_until_timeout select count(*) from __all_server where svr_ip='$z2_ip' and svr_port=$z2_port and stop_time = 0 and status='ACTIVE' and start_service_time > 0 and last_offline_time = 0,1,240;