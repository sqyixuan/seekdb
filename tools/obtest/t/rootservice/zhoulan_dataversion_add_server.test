##
# owner      : zg410411
# owner group: rs
# description: 测试在混部期间新增server，data_version的值不会被意外推高
##

ob1=OBI(cluster=1:1:2,version=4_3_0_1,oblog_version=current,proxy_num=0);
ob1.z3.obs1.set status=disable;
ob1.reboot;

ob_connect(conn_primary_sys, ob1.z1.obs0, root, , oceanbase, , USE_MYSQL_CONNECTOR);

ob1.upgrade_check_before;
ob1.upgrade_commond_for_server pre;

connection conn_primary_sys;
alter system stop zone 'z3';
ob1.check_until_timeout select status from DBA_OB_ZONES where zone='z3',INACTIVE,20;
ob1.check_until_timeout select count(1) as leader_count  from CDB_OB_LS_LOCATIONS where zone='z3' and role='leader',0,20;
ob1.z3.force_stop;
ob1.z3.upgrade;
ob1.z3.nstart;
ob1.check_until_timeout select count(*) from oceanbase.__all_server where zone = 'z3' and (start_service_time is null  or status='INACTIVE'),0,300;
ob1.check_until_timeout select count(1) as unsync_cnt from GV\$OB_LOG_STAT where in_sync = 'NO',0,600;
source include/check_schema_sync_for_restart.inc;
ob1.mysql alter system start zone 'z3';
sleep 30;

ob1.z3.obs1.set status=enable;
ob1.z3.obs1.start;
ob1.check_until_timeout select count(*) as cnt from oceanbase.__all_virtual_server_schema_info as a join oceanbase.__all_virtual_server_schema_info as b on a.tenant_id = b.tenant_id  where (a.refreshed_schema_version != b.refreshed_schema_version or a.refreshed_schema_version % 8 != 0) and a.tenant_id = 1, 0, 120;
ob1.z3.obs1.check_log_until_success -c "weak read service thread start";
ob1.z3.obs1.add;
ob1.check_until_timeout SELECT COUNT(*) c FROM DBA_OB_SERVERS WHERE START_SERVICE_TIME > 0, 4, 200;
# should be 4_3_0_1
select value from __all_virtual_tenant_parameter_info where name = 'compatible' and zone ='z3';
