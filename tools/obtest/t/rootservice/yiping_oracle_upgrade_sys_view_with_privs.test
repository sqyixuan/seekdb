ob1=OBI(cluster=2,proxy_num=0,version=4_3_2_0);
ob1.reboot;

let $z1_ip = deploy_get_value(ob1.z1.obs0.ip);
let $z1_port = deploy_get_value(ob1.z1.obs0.mysql_port);
let $obs2_ip = deploy_get_value(ob1.z1.obs1.ip);
let $obs2_port = deploy_get_value(ob1.z1.obs1.mysql_port);
ob_connect(sys_conn, $z1_ip, root@sys,,, $z1_port);
connection sys_conn;

create resource unit box max_cpu 1, memory_size='10G';
create resource pool pool unit = 'box', unit_num = 1;
create tenant oracle replica_num = 1, resource_pool_list=('pool') set ob_tcp_invited_nodes='%', ob_compatibility_mode='oracle';

ob_connect(sys_conn, $z1_ip, root@sys,,, $z1_port);
ob_connect(conn_oracle, $obs2_ip, SYS@oracle, ,SYS, $obs2_port, USE_OB_CONNECTOR);
connection sys_conn;

# 赋予用户oracle模式下所有内部视图的select权限，验证升级结束后权限不丢失
connection conn_oracle;
create user priv_test IDENTIFIED BY 123;
grant create session to priv_test;
# obtest里不能分行，所以都写进一行了，这行的作用是给priv_test用户添加所有内部视图的权限
BEGIN FOR r IN (select view_name from ALL_VIEWS where owner='SYS') LOOP EXECUTE IMMEDIATE 'GRANT SELECT ON SYS.' || r.view_name || ' TO PRIV_TEST'; END LOOP; END;
select count(*) from sys.all_views;
select count(*) from sys.dba_tab_privs where grantee = 'PRIV_TEST';

ob1.mysql alter system begin upgrade;
ob1.mysql alter system begin rolling upgrade;

ob1.z1.obs0.stop;
ob1.z1.obs0.upgrade;
ob1.z1.obs0.nstart;

ob1.z1.obs1.stop;
ob1.z1.obs1.upgrade;
ob1.z1.obs1.nstart;

source include/check_schema_sync_for_restart.inc;

# 验证存在server_id大于等于4096的机器之后无法升级
let $max_sid = deploy_get_value(ob1.z1.obs0.select select max(id) as max_id from oceanbase.__all_server, max_id, 1);
ob_connect(sys_conn, $z1_ip, root@sys,,, $z1_port);
connection sys_conn;
eval update oceanbase.__all_server set id = 4096 where id = $max_sid;
select id from oceanbase.__all_server order by id;
sleep 5;
--error 4179
alter system end rolling upgrade;
eval update oceanbase.__all_server set id = $max_sid where id = 4096;
select id from oceanbase.__all_server order by id;
sleep 5;
ob1.z1.obs1.delete;
ob1.check_until_timeout select count(*) from __all_server, 1,120;

ob1.mysql alter system end rolling upgrade;

ob1.mysql alter system run upgrade job 'UPGRADE_ALL';
ob1.check_until_timeout select job_status from oceanbase.__all_rootservice_job where job_type='UPGRADE_ALL' order by job_id limit 1, SUCCESS, 600;

ob1.mysql alter system end upgrade;

ob_connect(conn_oracle, $z1_ip, SYS@oracle, ,SYS, $z1_port, USE_OB_CONNECTOR);
connection conn_oracle;

# 这里数量应该和之前select相同
# 如果有删除视图的场景，删几张视图这里减几
select count(*) from sys.dba_tab_privs where grantee = 'PRIV_TEST';
