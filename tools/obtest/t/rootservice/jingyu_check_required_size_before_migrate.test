# CASE_OWNER:
#    @jingyu.cr
# CASE_DESC:
#    This case is aimed to test check log stream's required_size before do miragtion
#
#######################################################################
#                        create inital objects
#######################################################################

ob1=OBI(cluster=1:1:2,proxy_num=0,init_unit_cpu=0);
source include/mini_ob_config.inc;
ob1.set extra_config=$mini_ob_config;
ob1.reboot;

ob1.mysql alter system set debug_sync_timeout = '1000s';
ob1.mysql ALTER SYSTEM SET enable_rebalance = 'false';
ob1.mysql ALTER SYSTEM SET enable_rereplication = 'true';

let $proxy_ip = deploy_get_value(ob1.z1.obs0.ip);
let $proxy_port = deploy_get_value(ob1.z1.obs0.mysql_port);
connect(sys_conn, $proxy_ip, root@sys,,oceanbase, $proxy_port);

--echo ============================================
--echo            create mysql tenant
--echo ============================================
# create new tenant mysql
source include/create_unit_config.inc;
ob1.mysql CREATE RESOURCE POOL tenant_pool UNIT = "2c2g", UNIT_NUM = 1, ZONE_LIST = ('z1', 'z2', 'z3');
ob1.mysql CREATE TENANT mysql RESOURCE_POOL_LIST=('tenant_pool'), LOCALITY = "F@z1, F@z2, F@z3", PRIMARY_ZONE = "z1,z2,z3" SET ob_tcp_invited_nodes='%';

let $tenant_id = deploy_get_value(ob1.select SELECT tenant_id FROM oceanbase.DBA_OB_TENANTS WHERE tenant_name = "mysql", tenant_id, 1);
let $meta_tenant_id = deploy_get_value(ob1.select select tenant_id - 1 as meta_tenant_id from oceanbase.DBA_OB_TENANTS where tenant_name = "mysql", meta_tenant_id, 1);
let $resource_pool_id = deploy_get_value(ob1.select SELECT resource_pool_id FROM oceanbase.__all_resource_pool WHERE tenant_id = $tenant_id, resource_pool_id, 1);

# create table and insert data
ob_connect(conn_mysql, ob1.z1.obs0, root@mysql, , test, , USE_MYSQL_CONNECTOR);
connection conn_mysql;
create table t1_no_pk (c1 int);
insert into t1_no_pk values (1), (2), (3);
select * from t1_no_pk order by c1 asc;
update t1_no_pk set c1=c1+10;
select * from t1_no_pk order by c1 asc;
create table t1_pk (c1 int primary key);
insert into t1_pk values (1), (2), (3);
select * from t1_pk order by c1 asc;
update t1_pk set c1=c1+10;
select * from t1_pk order by c1 asc;
create table t1_part (c1 int primary key) partition by hash(c1) partitions 4;
insert into t1_part values (1), (2), (3), (4);
select * from t1_part order by c1 asc;
update t1_part set c1=c1+10;
select * from t1_part order by c1 asc;
connect(sys_conn, $proxy_ip, root@sys,,oceanbase, $proxy_port);
alter system minor freeze tenant mysql;
ob1.z1.obs0.check_log_until_success -c "succeed to release head data memtable";
ob1.z2.obs0.check_log_until_success -c "succeed to release head data memtable";
sleep 10;
connection conn_mysql;
insert into t1_no_pk values (4), (5), (6);
insert into t1_no_pk values (7), (8), (9);
insert into t1_no_pk values (10), (11), (12);
insert into t1_pk values (4), (5), (6);
insert into t1_pk values (7), (8), (9);
insert into t1_pk values (10);
insert into t1_part values (5), (6), (7), (8);
insert into t1_part values (9), (10), (21), (22);
connect(sys_conn, $proxy_ip, root@sys,,oceanbase, $proxy_port);
alter system minor freeze tenant mysql;
ob1.z1.obs0.check_log_until_success -c "succeed to release head data memtable";
ob1.z2.obs0.check_log_until_success -c "succeed to release head data memtable";
sleep 10;

--echo =============================================
--echo         check __all_virtal_ls_info
--echo =============================================
ob1.check_until_timeout select count(*) as cnt from oceanbase.__all_virtual_ls_info where required_data_disk_size = 0, 0, 30;

--echo =============================================
--echo         trigger migrate replcia task
--echo =============================================
# get tenant_for_migrate_locality's unit info in z3
let $z3_unit_id = deploy_get_value(ob1.select SELECT unit_id as unit_id FROM oceanbase.DBA_OB_UNITS WHERE resource_pool_id = $resource_pool_id AND zone = 'z3', unit_id, 1);
let $z3_ip = deploy_get_value(ob1.select SELECT svr_ip FROM oceanbase.DBA_OB_UNITS WHERE unit_id = $z3_unit_id, svr_ip, 1);
let $z3_port = deploy_get_value(ob1.select SELECT svr_port FROM oceanbase.DBA_OB_UNITS WHERE unit_id = $z3_unit_id, svr_port, 1);
let $z3_cur = $z3_ip:$z3_port;

let $z3_dst_ip0 = deploy_get_value(ob1.z3.obs0.ip);
let $z3_dst_ip1 = deploy_get_value(ob1.z3.obs1.ip);
let $z3_dst_port0 = deploy_get_value(ob1.z3.obs0.port);
let $z3_dst_port1 = deploy_get_value(ob1.z3.obs1.port);
let $z3_dst0 = $z3_dst_ip0:$z3_dst_port0;
let $z3_dst1 = $z3_dst_ip1:$z3_dst_port1;

if ($z3_cur != $z3_dst0)
{
  --disable_query_log
  eval ALTER SYSTEM MIGRATE UNIT $z3_unit_id DESTINATION "$z3_dst0";
  --enable_query_log
}

if ($z3_cur != $z3_dst1)
{
  --disable_query_log
  eval ALTER SYSTEM MIGRATE UNIT $z3_unit_id DESTINATION "$z3_dst1";
  --enable_query_log
}
ob1.check_until_timeout select count(*) > 0 from oceanbase.DBA_OB_ROOTSERVICE_EVENT_HISTORY where event like "%finish_mig%", 1, 60;
ob1.check_until_timeout select count(*) as cnt from oceanbase.DBA_OB_UNITS where migrate_from_svr_ip is not null, 0, 300;
