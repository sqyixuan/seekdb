# CASE_OWNER:
#    @shouju.zyp
# CASE_DESC:
#    The Basic failover testcase

ob1=OBI(cluster=1, proxy_num=0);
ob2=OBI(cluster=1, proxy_num=0);

source include/mini_ob_config.inc;
ob1.z1.obs0.set extra_config = "cpu_count=16,memory_limit='30G',system_memory='7G',__min_full_resource_pool_memory='1073741824',cache_wash_threshold='1G',_ob_minor_merge_schedule_interval='3s'";
ob2.z1.obs0.set extra_config = "cpu_count=16,memory_limit='30G',system_memory='7G',__min_full_resource_pool_memory='1073741824',cache_wash_threshold='1G',_ob_minor_merge_schedule_interval='3s'";

let $backup_cluster_name = deploy_get_value(ob1.get_cluster_name);
let $backup_cluster_id = deploy_get_value(ob1.get_cluster_id);
let $backup_ip       = deploy_get_value(ob1.z1.obs0.ip);
let $backup_port     = deploy_get_value(ob1.z1.obs0.mysql_port);
let $restore_ip         = deploy_get_value(ob2.z1.obs0.ip);
let $restore_port       = deploy_get_value(ob2.z1.obs0.mysql_port);
let $backup_dest = deploy_get_value(ob1.get_backup_dest);
let $backup_mysql_tenant   = backup_mysql_tenant;
let $backup_mysql_tenant    = backup_mysql_tenant;
let $restore_mysql_tenant = restore_mysql_tenant;
let $restore_mysql_tenant_new = restore_mysql_tenant_new;
let $restore_mysql_tenant = restore_mysql_tenant;
let $log_backup_dest = deploy_get_value(ob1.get_log_backup_dest $backup_mysql_tenant);
let $data_backup_dest = deploy_get_value(ob1.get_data_backup_dest $backup_mysql_tenant);
let $restore_log_backup_dest = deploy_get_value(ob2.get_log_backup_dest $restore_mysql_tenant);
let $restore_data_backup_dest = deploy_get_value(ob2.get_data_backup_dest $restore_mysql_tenant);

# 必须先stop掉老的，删除才能有效，不然可能会有残留。
ob1.force_stop;
ob1.clean_backup_dest;
ob1.reboot;

# 固定sys租户规格
ob1.mysql alter resource unit sys_unit_config memory_size='2G';

connect(backup_sys_conn, $backup_ip, root@sys,,oceanbase, $backup_port);
connection backup_sys_conn;
use oceanbase;
CREATE RESOURCE UNIT small_unit MAX_CPU=2, MEMORY_SIZE='4G', LOG_DISK_SIZE='2G';
CREATE RESOURCE POOL small_pool UNIT small_unit, UNIT_NUM 1, ZONE_LIST ('z1');

ob1.mysql alter system set _backup_idle_time = '10s';
ob1.mysql alter system set merger_check_interval = '10s';
ob1.mysql alter system set enable_async_syslog=false;

# create mysql tenant, test create tenant before major freeze
ob1.mysql CREATE TENANT $backup_mysql_tenant RESOURCE_POOL_LIST = ('small_pool'), primary_zone = "z1" set ob_tcp_invited_nodes='%', ob_compatibility_mode='mysql';
let $backup_mysql_tenant_id = query_get_value(select tenant_id from oceanbase.__all_tenant where tenant_name='$backup_mysql_tenant', tenant_id, 1);
#创建tablet
ob_connect(sys_conn_mysql, ob1.z1.obs0, root@$backup_mysql_tenant, ,oceanbase, , USE_MYSQL_CONNECTOR);
connection sys_conn_mysql;
set global wait_timeout = 288000;

--disable_all_result_log
eval alter system set data_backup_dest='$data_backup_dest';
eval alter system set log_archive_dest='location=$log_backup_dest';
--enable_all_result_log

connection backup_sys_conn;
let $__archive_lag_target__ = 2s;
let $__tenant_name__ = $backup_mysql_tenant;
source include/set_archive_lag_target.inc;

ob_connect(backup_mysql_conn, ob1.z1.obs0,root@$backup_mysql_tenant,,test,,USE_MYSQL_CONNECTOR);
connection backup_mysql_conn;

create table t1(a int, b int, c int);
insert into t1(a, b) values(1, 1);


#开启日志备份
ob1.mysql alter system archivelog;
ob1.check_until_timeout select status from oceanbase.CDB_OB_ARCHIVELOG where tenant_id=$backup_mysql_tenant_id, DOING, 600;

#开启数据备份
ob1.mysql alter system backup database;
ob1.check_until_timeout select count(*) c from __all_backup_job_history where tenant_id = 1, 1, 600;
ob1.check_until_timeout select result from oceanbase.CDB_OB_BACKUP_JOB_HISTORY where tenant_id = $backup_mysql_tenant_id, 0, 10;
ob1.check_until_timeout select result from oceanbase.CDB_OB_BACKUP_TASK_HISTORY where tenant_id = $backup_mysql_tenant_id, 0, 10;

sleep 20;
connect(backup_sys_conn, $backup_ip, root@sys,,oceanbase, $backup_port);
connection backup_sys_conn;
use oceanbase;
let $restore_path = $log_backup_dest,$data_backup_dest;
let $ls_id1 = deploy_get_value(ob1.select select ls_id from oceanbase.__all_virtual_ls where tenant_id = $backup_mysql_tenant_id and ls_id != 1, ls_id, 1);
ob1.mysql alter tenant $backup_mysql_tenant set primary_zone = 'z1';
ob1.check_until_timeout select count(*)>=1 from oceanbase.__all_virtual_ls_status where status = 'NORMAL' and tenant_id = $backup_mysql_tenant_id, 1, 100;
let $ls_id2 = deploy_get_value(ob1.select select max(ls_id) as ls_id from oceanbase.__all_virtual_ls where tenant_id = $backup_mysql_tenant_id, ls_id, 1);
let $create_scn1 = deploy_get_value(ob1.select select create_scn from oceanbase.__all_virtual_ls where tenant_id = $backup_mysql_tenant_id and ls_id = $ls_id1, create_scn, 1);
let $create_scn2 = deploy_get_value(ob1.select select create_scn from oceanbase.__all_virtual_ls where tenant_id = $backup_mysql_tenant_id and ls_id =  $ls_id2, create_scn, 1);
sleep 3;
let $restore_checkpoint1 = `select ceil(min_restore_scn / 1000) as min_restore_scn from CDB_OB_BACKUP_SET_FILES where tenant_id = $backup_mysql_tenant_id`;
let $restore_checkpoint2 = `select ceil(UNIX_TIMESTAMP(current_timestamp(6)) * 1000000)`;
ob1.check_until_timeout select floor(checkpoint_scn / 1000) > '$restore_checkpoint1' from CDB_OB_ARCHIVELOG, 1, 600;
ob1.check_until_timeout select floor(checkpoint_scn / 1000) > '$restore_checkpoint2' from CDB_OB_ARCHIVELOG, 1, 600;
let $restore_checkpoint = `select usec_to_time(floor(checkpoint_scn/1000)) from CDB_OB_ARCHIVELOG`;

#开启数据恢复
ob2.reboot;
connect(restore_sys_conn, $restore_ip, root@sys,,oceanbase, $restore_port);
ob2.mysql alter resource unit sys_unit_config memory_size='2G';
connection restore_sys_conn;

CREATE RESOURCE UNIT small_unit MAX_CPU=2, MEMORY_SIZE='4G', LOG_DISK_SIZE='2G';
CREATE RESOURCE POOL small_pool_0 UNIT small_unit, UNIT_NUM 1, ZONE_LIST ('z1');
CREATE RESOURCE POOL small_pool_2 UNIT small_unit, UNIT_NUM 1, ZONE_LIST ('z1');

ob2.mysql alter system set enable_async_syslog=false;
ob2.mysql alter system restore $restore_mysql_tenant from '$restore_path' until time='$restore_checkpoint' with 'pool_list=small_pool_2&primary_zone=z1';
ob2.check_until_timeout SELECT status FROM __all_tenant WHERE tenant_id = 1001, NORMAL, 200;
ob2.check_until_timeout select count(*) from __all_virtual_ls_meta_table where tenant_id = 1002 and restore_status = 0, 2, 1200;
ob2.check_until_timeout select status FROM __all_tenant WHERE tenant_id = 1002, NORMAL, 200;
ob2.check_until_timeout select count(*) FROM __all_restore_job, 0, 200;
ob2.mysql ALTER SYSTEM RECOVER STANDBY TENANT $restore_mysql_tenant UNTIL UNLIMITED;
let $restore_mysql_tenant_id = query_get_value(select tenant_id from oceanbase.__all_tenant where tenant_name='$restore_mysql_tenant', tenant_id, 1);


ob2.mysql alter system set debug_sync_timeout = '100000s';
ob2.mysql set ob_global_debug_sync = 'BLOCK_STANDBY_REFRESH_SCHEMA wait_for continue_standby_signal execute 10000';
sleep 10;

ob_connect(backup_mysql_conn, ob1.z1.obs0,root@$backup_mysql_tenant,,test,,USE_MYSQL_CONNECTOR);
connection backup_mysql_conn;

create table t2(a int, b int, c int);
insert into t2(a, b) values(10, 10);

let $p_received_schema_v=deploy_get_value(ob1.select select received_schema_version from __all_virtual_server_schema_info where tenant_id = $backup_mysql_tenant_id order by received_schema_version desc limit 1, received_schema_version, 1);

connect(backup_sys_conn, $backup_ip, root@sys,,oceanbase, $backup_port);
connection backup_sys_conn;
let $check_sync_scn = query_get_value(select end_scn from oceanbase.__all_virtual_log_stat where tenant_id = $backup_mysql_tenant_id and ls_id = 1001 and role = 'LEADER', end_scn, 1);

connect(restore_sys_conn, $restore_ip, root@sys,,oceanbase, $restore_port);
connection restore_sys_conn;
let $restore_mysql_tenant_id = query_get_value(select tenant_id from oceanbase.__all_tenant where tenant_name='$restore_mysql_tenant', tenant_id, 1);
# 备库同步到创建的t2表，但阻塞住刷新schema
ob2.check_until_timeout select count(*) FROM oceanbase.dba_ob_tenants where tenant_id = $restore_mysql_tenant_id and SYNC_SCN >= $check_sync_scn, 1, 50;

ob_connect(sys_conn, ob2.z1.obs0, root, , oceanbase, , USE_MYSQL_CONNECTOR);
connection sys_conn;
alter system change tenant tenant_id = 1001;
select tenant_role from __all_tenant_info where tenant_id = 1002;
# STANDBY
ob2.mysql alter system set debug_sync_timeout = '100000s';
ob2.mysql set ob_global_debug_sync = 'BEFORE_PREPARE_FLASHBACK wait_for continue_signal_f execute 10000';
sleep 3;
ob_connect(sys_conn, ob2.z1.obs0, root, , oceanbase, , USE_MYSQL_CONNECTOR);
connection sys_conn;
--error 1210
eval ALTER SYSTEM ACTIVATE STANDBY;

set ob_query_timeout  = 10000000;
send ALTER SYSTEM ACTIVATE STANDBY TENANT $restore_mysql_tenant;
sleep 13;
ob2.check_until_timeout select count(*) from __all_virtual_tenant_info where tenant_id = 1002 and switchover_status = 'PREPARE FLASHBACK' and tenant_role = 'STANDBY', 1, 5;

# 在主库普通日志流写新数据，并等待备租户同步到，但同步位点不会推过，测试这个更新会被flashback 动作裁剪掉
ob2.mysql alter system set_tp tp_name = ERRSIM_RECOVERY_LS_THREAD1, error_code = $restore_mysql_tenant_id, frequency = 1;
sleep 3;

ob_connect(backup_mysql_conn, ob1.z1.obs0,root@$backup_mysql_tenant,,test,,USE_MYSQL_CONNECTOR);
connection backup_mysql_conn;
update t1 set a=2, b=2;
let $primary_max_log_scn = deploy_get_value(ob1.select select max(end_scn) as primary_max_log_scn from oceanbase.__all_virtual_log_stat where tenant_id=1002, primary_max_log_scn, 1);
# 等待备租户日志流同步到update clog
ob2.check_until_timeout select count(*) from oceanbase.__all_virtual_log_stat where role = 'LEADER' and tenant_id = 1002 and end_scn >= $primary_max_log_scn and ls_id != 1, 1, 400;
ob2.mysql set ob_global_debug_sync = 'now signal continue_signal_f';
ob2.mysql set ob_global_debug_sync = 'BEFORE_PREPARE_FLASHBACK clear';

ob2.mysql set ob_global_debug_sync = 'BEFORE_DO_FLASHBACK wait_for continue_signal_ff execute 10000';
sleep 3;

ob_connect(sys_conn, ob2.z1.obs0, root, , oceanbase, , USE_MYSQL_CONNECTOR);
connection sys_conn;
--error 1210
eval ALTER SYSTEM ACTIVATE STANDBY;

ob_connect(sys_conn, ob2.z1.obs0, root, , oceanbase, , USE_MYSQL_CONNECTOR);
connection sys_conn;
set ob_query_timeout  = 5000000;
send ALTER SYSTEM ACTIVATE STANDBY TENANT $restore_mysql_tenant;
ob2.check_until_timeout select count(*) from __all_virtual_tenant_info where tenant_id = 1002 and switchover_status = 'FLASHBACK' and tenant_role = 'STANDBY' and recovery_until_scn < 4611686018427387903, 1, 5;
ob2.check_until_timeout select count(*) from __all_virtual_log_restore_source where tenant_id = 1002 and recovery_until_scn < 4611686018427387903, 1, 5;
sleep 6;
ob2.mysql set ob_global_debug_sync = 'now signal continue_signal_ff';
ob2.mysql set ob_global_debug_sync = 'BEFORE_DO_FLASHBACK clear';
ob2.mysql alter system set_tp tp_name = ERRSIM_RECOVERY_LS_THREAD1, error_code = $restore_mysql_tenant_id, frequency = 0;

ob_connect(restore_mysql_conn, ob2.z1.obs0, root@$restore_mysql_tenant, ,TEST, , USE_MYSQL_CONNECTOR);
connection restore_mysql_conn;
select * from t1;
#1 1	NULL

--error 1146
select * from t2;

ob2.mysql set ob_global_debug_sync = 'now signal continue_standby_signal';
ob2.mysql set ob_global_debug_sync = 'BLOCK_STANDBY_REFRESH_SCHEMA clear';
sleep 5;

ob_connect(sys_conn, ob2.z1.obs0, root, , oceanbase, , USE_MYSQL_CONNECTOR);
connection sys_conn;
eval ALTER SYSTEM ACTIVATE STANDBY TENANT $restore_mysql_tenant;
ob2.check_until_timeout select count(*) from __all_virtual_tenant_info where tenant_id = 1002 and tenant_role = 'PRIMARY' and switchover_status = 'NORMAL', 1, 5;

#wait schema refreshed, then can find t2 table
ob2.check_until_timeout SELECT count(*) FROM __all_virtual_server_schema_info where tenant_id= $restore_mysql_tenant_id and refreshed_schema_version < $p_received_schema_v, 0,240;

ob_connect(restore_mysql_conn, ob2.z1.obs0, root@$restore_mysql_tenant, ,TEST, , USE_MYSQL_CONNECTOR);
connection restore_mysql_conn;
select * from t1;
#1 1	NULL
select * from t2;
#10	10	NULL

ob2.mysql_p select count(*) from oceanbase.__all_virtual_ls where tenant_id = $restore_mysql_tenant_id and ls_id = $ls_id1 and create_scn = $create_scn1;
ob2.mysql_p select count(*) from oceanbase.__all_virtual_ls where tenant_id = $restore_mysql_tenant_id and ls_id = $ls_id2 and create_scn = $create_scn2;