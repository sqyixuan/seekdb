# CASE_OWNER:
#    @wangzhennan.wzn
# CASE_DESC:
#    Cluster may hung if gcore one server.
#    Bug: 

ob1=OBI(cluster=1:1:1,proxy_num=0,init_unit_cpu=1);
ob1.reboot;

ob1.mysql set global ob_query_timeout = 2000000;
sleep 1;

ob_connect(conn_sys, ob1.z2.obs0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);
connection conn_sys;
create table t1 (k int primary key, v int);
create table t2 (k int primary key, v int);
insert into t1 (k, v) values (1, 1);
insert into t2 (k, v) values (1, 1);
select * from t2;

ob1.z1.obs0.kill -19;
sleep 60;
connection conn_sys;
--enable_query_log

select * from t1;

select * from t2;
