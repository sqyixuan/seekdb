# CASE_OWNER:
#    @msy164651
# CASE_DESC:
#    Normal tenant has no privilege to execute alter system command.
#    See: 

ob1=OBI(cluster=1,proxy_num=0,init_unit_cpu=0);
ob1.reboot;


# create tenant t1
ob1.mysql create resource unit test_unit max_cpu = 1, memory_size = '2G';
ob1.mysql create resource pool p1 unit = 'test_unit', unit_num = 1;
ob1.mysql create tenant t1 replica_num = 1, primary_zone = 'z1', resource_pool_list('p1') set ob_tcp_invited_nodes='%';
sleep 3;
ob_connect(tt_conn, ob1.z1.obs0, root@t1,,oceanbase,USE_MYSQL_CONNECTOR);
connection tt_conn;

--error 1227
alter system bootstrap ZONE 'zone3' SERVER '100.81.152.44:43914',ZONE 'zone1' SERVER '100.81.152.41:43906',ZONE 'zone2' SERVER '100.81.152.42:43910';

--error 1227
alter system switch replica leader ls=1001 server = '100.81.152.37:43928' tenant ='test';

--error 1227
alter system delete server '100.81.152.41:43906';

--error 1227
alter system stop zone 'z1';

--error 1227
alter system refresh schema;

--error 1227
alter system clear location cache;

--error 1227
alter system reload unit;

--error 1227
alter system reload server;

--error 1227
alter system reload zone;

--error 1227
alter system migrate unit 2 DESTINATION  '100.81.152.44:52004';

--error 1227
alter system upgrade virtual schema;

--error 1227
alter system run job 'none';
