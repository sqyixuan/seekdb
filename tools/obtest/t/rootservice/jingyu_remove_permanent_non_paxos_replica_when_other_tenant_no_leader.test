# CASE_OWNER:
#    @jingyu.cr
# CASE_DESC:
#    lost_replica_checker在租户无主的情况下不能影响其余租户remove_replica
#    

ob1=OBI(cluster=1:1:1:1, init_unit_cpu=0, proxy_num=0, ct_num=0, locality=hz:hz:hz:hz);
ob1.reboot;

ob1.mysql alter system set debug_sync_timeout = '1000s';
ob1.mysql alter system set balancer_idle_time = '10s';
ob1.mysql alter system set server_permanent_offline_time = '20s';

ob_connect(conn_sys, ob1.z1.obs0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);

ob1.mysql CREATE RESOURCE UNIT unit_1 MAX_CPU 2, memory_size '4G';
ob1.mysql CREATE RESOURCE POOL pool_1 UNIT = 'unit_1', UNIT_NUM = 1, ZONE_LIST = ('z1','z3','z4');
ob1.mysql CREATE TENANT tenant_1 RESOURCE_POOL_LIST = ('pool_1'), primary_zone = 'z1', locality='F@z1,F@z3,F@z4' set ob_tcp_invited_nodes='%';
ob1.mysql CREATE RESOURCE POOL pool_2 UNIT = 'unit_1', UNIT_NUM = 1, ZONE_LIST = ('z1','z3','z2');
ob1.mysql CREATE TENANT tenant_2 RESOURCE_POOL_LIST = ('pool_2'), primary_zone = 'z1', locality='F@z1,F@z2,F@z3' set ob_tcp_invited_nodes='%';
let $tenant_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name = 'tenant_2', tenant_id, 1);

ob1.mysql alter tenant sys set primary_zone = "z1";
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_core_meta_table where zone = 'z1' and role = 1, 1, 200;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_ls_meta_table where zone = 'z1' and role = 1, 7, 200;

ob1.mysql alter tenant sys set locality = "F@z1,F@z2,F@z3";
ob1.check_until_timeout select count(*) from oceanbase.__all_tenant where tenant_name = "sys" and previous_locality != "", 0, 300;

# accerate root balance process while tenant has no leader
ob1.mysql alter system set internal_sql_execute_timeout = '10s';

# 让普通租户不满足多数派而无主；同时使系统租户1F宕机
ob1.z3.obs0.force_stop;
ob1.z4.obs0.force_stop;

# F副本宕机，需要等永久下线后，RS从meta表踢掉，locality才能做完
# 此时lost_replica_checker应该忽略tenant_1租户无主的影响，把永久下线的F副本从meta表踢掉
ob1.mysql alter tenant sys set locality = "F@z1,F@z2";
ob1.mysql alter tenant tenant_2 set locality = "F@z1,F@z2";
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_core_meta_table where zone = 'z3', 0, 100;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_ls_meta_table where zone = 'z3' and tenant_id = $tenant_id, 0, 100;
ob1.check_until_timeout select count(*) from oceanbase.__all_tenant where tenant_name = "sys" and previous_locality != "", 0, 300;
ob1.check_until_timeout select count(*) from oceanbase.__all_tenant where tenant_name = "tenant_2" and previous_locality != "", 0, 300;

