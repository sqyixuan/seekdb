###############################################################################
### CASE_OWNER:
###    @jingyu.cr
### CASE_DESC:
###    This case is aimed to test bugfix
###    Bug: If a cluster has too many log streams, sys tenant's
###         CPU resource could overused by arb service.
###         Arb service is service under sys/meta tenant to add/remove
###         arb replica for tenant. For each log stream, this service
###         executes inner sql every 2s under sys tenant. Too many inner
###         sql could overuse sys tenant's CPU resource.
###
###    Fix: 1. we use rpc to get arbitration member instead of useing inner sql.
###         2. adjust arb service schedule time from 2s to 10s and add
###            wakeup logic for it.
###
################################################################################
--echo ===============================================
--echo                  bootstrap
--echo ===============================================
ob1=OBI(cluster=1:1,proxy_num=0,init_unit_cpu=0,asvr_num=2);
source include/mini_ob_config.inc;
ob1.set extra_config=$mini_ob_config;
ob1.reboot;
sleep 3;

let $arb_extra_conf = "ob_startup_mode=arbitration,cpu_count=1,memory_limit=1G,__easy_memory_limit=256M";
ob1.asvr1.set status=enable;
ob1.asvr1.reboot;
# 获取仲裁server的ip、port
let $arb_svr_ip= deploy_get_value(ob1.asvr0.ip);
let $arb_svr_port= deploy_get_value(ob1.asvr0.port);
let $arb_svr_ip_2= deploy_get_value(ob1.asvr1.ip);
let $arb_svr_port_2= deploy_get_value(ob1.asvr1.port);

ob1.mysql alter system set debug_sync_timeout = '1000s';
ob1.mysql ALTER SYSTEM SET enable_rebalance = 'true' tenant = all;
ob1.mysql ALTER SYSTEM SET enable_rereplication = 'true';
ob1.mysql ALTER SYSTEM SET enable_transfer = 'true' tenant = all;

let $proxy_ip = deploy_get_value(ob1.z1.obs0.ip);
let $proxy_port = deploy_get_value(ob1.z1.obs0.mysql_port);
connect(sys_conn, $proxy_ip, root@sys,,oceanbase, $proxy_port);

# 获取仲裁server的ip、port
let $arb_svr_ip= deploy_get_value(ob1.asvr0.ip);
let $arb_svr_port= deploy_get_value(ob1.asvr0.port);
# add arbitration service, mytest.jar已经为本集群做了这一步
ob1.check_until_timeout select count(*) as cnt from oceanbase.DBA_OB_ARBITRATION_SERVICE where arbitration_service = "$arb_svr_ip:$arb_svr_port", 1, 5;

--echo =================================================
--echo               create tenant
--echo =================================================
# create new tenant mysql with arbitration service
source include/create_unit_config.inc;
ob1.mysql CREATE RESOURCE POOL tenant_pool UNIT = "2c2g", UNIT_NUM = 1, ZONE_LIST = ('z1', 'z2');
ob1.mysql CREATE TENANT mysql RESOURCE_POOL_LIST=('tenant_pool'), LOCALITY = "F@z1, F@z2", PRIMARY_ZONE = "z1,z2", enable_arbitration_service = true SET ob_tcp_invited_nodes='%';

let $sys_tenant_id = deploy_get_value(ob1.select select tenant_id as sys_tenant_id from oceanbase.DBA_OB_TENANTS where tenant_name = "sys", sys_tenant_id, 1);
let $tenant_id = deploy_get_value(ob1.select SELECT tenant_id FROM oceanbase.DBA_OB_TENANTS WHERE tenant_name = "mysql", tenant_id, 1);
let $meta_tenant_id = deploy_get_value(ob1.select select tenant_id - 1 as meta_tenant_id from oceanbase.DBA_OB_TENANTS where tenant_name = "mysql", meta_tenant_id, 1);
let $resource_pool_id = deploy_get_value(ob1.select SELECT resource_pool_id FROM oceanbase.__all_resource_pool WHERE tenant_id = $tenant_id, resource_pool_id, 1);

# get servers' addr in z1, z2 and z3
let $z1_dst_ip0 = deploy_get_value(ob1.z1.obs0.ip);
let $z1_dst_port0 = deploy_get_value(ob1.z1.obs0.port);
let $z1_dst0 = $z1_dst_ip0:$z1_dst_port0;
let $z2_dst_ip0 = deploy_get_value(ob1.z2.obs0.ip);
let $z2_dst_port0 = deploy_get_value(ob1.z2.obs0.port);
let $z2_dst0 = $z2_dst_ip0:$z2_dst_port0;

--echo =======================================================
--echo     check log_stream count and wait schema refresh
--echo =======================================================
connect(sys_conn, $proxy_ip, root@sys,,oceanbase, $proxy_port);
connection sys_conn;
ob1.check_until_timeout select count(*) as cnt from oceanbase.CDB_OB_LS, 5, 30; 
ob1.check_until_timeout select count(*) as cnt from oceanbase.__all_virtual_server_schema_info as a join oceanbase.__all_virtual_server_schema_info as b on a.tenant_id = b.tenant_id  where (a.refreshed_schema_version != b.refreshed_schema_version or a.refreshed_schema_version % 8 != 0) and a.tenant_id = 1, 0, 120;
ob1.z1.obs0.check_log_until_success -c "end refresh and add schema by tenant(ret=0, ret=\"OB_SUCCESS\", tenant_id=1001";
ob1.z1.obs0.check_log_until_success -c "end refresh and add schema by tenant(ret=0, ret=\"OB_SUCCESS\", tenant_id=1002";
sleep 5;

--echo ==================================================
--echo      statistic arbitration related inner sql
--echo ==================================================
connect(sys_conn, $proxy_ip, root@sys,,oceanbase, $proxy_port);
connection sys_conn;
# statistic sys/meta/user inner sql execution as benchmark
let $sys_inner_sql_count_before = deploy_get_value(ob1.select select count(*) as sys_inner_sql_count_before from GV\$OB_SQL_AUDIT where tenant_id = $sys_tenant_id and query_sql like "%arbitration_member%", sys_inner_sql_count_before, 1);
let $meta_inner_sql_count_before = deploy_get_value(ob1.select select count(*) as meta_inner_sql_count_before from GV\$OB_SQL_AUDIT where tenant_id = $meta_tenant_id and query_sql like "%arbitration_member%", meta_inner_sql_count_before, 1);
let $user_inner_sql_count_before = deploy_get_value(ob1.select select count(*) as user_inner_sql_count_before from GV\$OB_SQL_AUDIT where tenant_id = $tenant_id and query_sql like "%arbitration_member%", user_inner_sql_count_before, 1);
# sleep 30s to let arb service schedule several rounds
sleep 30;
# statistic sys/meta/user inner sql execution to compare with benchmark
let $sys_inner_sql_count_after = deploy_get_value(ob1.select select count(*) as sys_inner_sql_count_after from GV\$OB_SQL_AUDIT where tenant_id = $sys_tenant_id and query_sql like "%arbitration_member%" and query_sql like "%__all_virtual_log_stat%", sys_inner_sql_count_after, 1);
let $meta_inner_sql_count_after = deploy_get_value(ob1.select select count(*) as meta_inner_sql_count_after from GV\$OB_SQL_AUDIT where tenant_id = $meta_tenant_id and query_sql like "%arbitration_member%" and query_sql like "%__all_virtual_log_stat%", meta_inner_sql_count_after, 1);
let $user_inner_sql_count_after = deploy_get_value(ob1.select select count(*) as user_inner_sql_count_after from GV\$OB_SQL_AUDIT where tenant_id = $tenant_id and query_sql like "%arbitration_member%" and query_sql like "%__all_virtual_log_stat%", user_inner_sql_count_after, 1);

--echo ==================================================
--echo   check arbitration related inner sql under sys
--echo ==================================================
--echo check sys tenant inner sql execution
let $sys_inner_sql_expect_inc_count = 5;
if ($sys_inner_sql_count_after - $sys_inner_sql_count_before > $sys_inner_sql_expect_inc_count)
{
  --echo sys inner sql increased too much
  --echo $sys_inner_sql_expect_inc_count
  --echo $sys_inner_sql_count_before
  --echo $sys_inner_sql_count_after
}
ob1.check_until_timeout select $sys_inner_sql_count_after - $sys_inner_sql_count_before <= $sys_inner_sql_expect_inc_count as expected, 1, 1;

--echo ==================================================
--echo   check arbitration related inner sql under meta
--echo ==================================================
--echo check meta tenant inner sql execution
let $meta_inner_sql_expect_inc_count = 0;
if ($meta_inner_sql_count_after - $meta_inner_sql_count_before > $meta_inner_sql_expect_inc_count)
{
  --echo meta inner sql increased too much
  --echo $meta_inner_sql_expect_inc_count
  --echo $meta_inner_sql_count_before
  --echo $meta_inner_sql_count_after
}
ob1.check_until_timeout select $meta_inner_sql_count_after - $meta_inner_sql_count_before <= $meta_inner_sql_expect_inc_count as expected, 1, 1;

--echo ==================================================
--echo   check arbitration related inner sql under user
--echo ==================================================
--echo check user tenant inner sql execution
let $user_inner_sql_expect_inc_count = 0;
if ($user_inner_sql_count_after - $user_inner_sql_count_before > $user_inner_sql_expect_inc_count)
{
  --echo user inner sql increased too much
  --echo $user_inner_sql_expect_inc_count
  --echo $user_inner_sql_count_before
  --echo $user_inner_sql_count_after
}
ob1.check_until_timeout select $user_inner_sql_count_after - $user_inner_sql_count_before <= $user_inner_sql_expect_inc_count as expected, 1, 1;

--echo ==================================================================
--echo    check arb service can wakeup by replace arbitration service
--echo ==================================================================
--echo replace arbitration service A with B
--disable_query_log
ob1.mysql alter system replace arbitration service "$arb_svr_ip:$arb_svr_port" with "$arb_svr_ip_2:$arb_svr_port_2";
--enable_query_log
ob1.z1.obs0.check_rs_log_until_success -c "start to wakeup all tenant arbitration service";
ob1.z1.obs0.check_rs_log_until_success -c "success to wakeup tenant arbitration service(ret=0, ret=\"OB_SUCCESS\", tenant_id=$sys_tenant_id)";
ob1.z1.obs0.check_rs_log_until_success -c "success to wakeup tenant arbitration service(ret=0, ret=\"OB_SUCCESS\", tenant_id=$meta_tenant_id)";
ob1.check_until_timeout select count(*) as ctn from oceanbase.__all_virtual_log_stat where arbitration_member like "%$arb_svr_ip:$arb_svr_port%", 0, 10; 
ob1.check_until_timeout select count(*) as ctn from oceanbase.__all_virtual_log_stat where tenant_id in ($tenant_id, $meta_tenant_id) and arbitration_member not like "%$arb_svr_ip_2:$arb_svr_port_2%", 0, 30;

--echo ==================================================
--echo   check arb service can wakeup by alter tenant
--echo ==================================================
--echo enable tenant arbitration service again
alter tenant mysql set enable_arbitration_service = true;
ob1.z1.obs0.check_rs_log_until_success -c "success to wakeup tenant arbitration service(ret=0, ret=\"OB_SUCCESS\", tenant_id=$meta_tenant_id)";

--echo disable tenant arbitration service again
alter tenant sys set enable_arbitration_service = false;
ob1.z1.obs0.check_rs_log_until_success -c "success to wakeup tenant arbitration service(ret=0, ret=\"OB_SUCCESS\", tenant_id=$sys_tenant_id)";

--echo disable tenant arbitration service
alter tenant mysql set enable_arbitration_service = false;
ob1.z1.obs0.check_rs_log_until_success -c "success to wakeup tenant arbitration service(ret=0, ret=\"OB_SUCCESS\", tenant_id=$meta_tenant_id)";
ob1.check_until_timeout select count(*) as ctn from oceanbase.__all_virtual_log_stat where arbitration_member like "%$arb_svr_ip_2:$arb_svr_port_2%", 0, 10;

--echo enable tenant arbitration service
alter tenant mysql set enable_arbitration_service = true;
ob1.z1.obs0.check_rs_log_until_success -c "success to wakeup tenant arbitration service(ret=0, ret=\"OB_SUCCESS\", tenant_id=$meta_tenant_id)";
ob1.check_until_timeout select count(*) as ctn from oceanbase.__all_virtual_log_stat where tenant_id in ($tenant_id, $meta_tenant_id) and arbitration_member not like "%$arb_svr_ip_2:$arb_svr_port_2%", 0, 30;
