# CASE_OWNER:
#    @cangming.zl
# CASE_DESC:
#    本case是为了stop的时候，会考察机器上的UNIT，如果没有租户的UNIT则不影响整个租户的primary zone;
#    系统租户不参与计算；
#    case 1: 验证gts模式下，租户和表的primary zone必须要在一起；
#    case 2: 验证OBS上没有租户资源时，可以直接stop;
#    case 3: 验证两个租户有交集的时候，stop能够正常；

ob1=OBI(cluster=1:2:2:2:2:2,  proxy_num=0, ct_num = 0, locality=SZ:HZ:HZ:SH:SH:SZ);

ob1.z2.obs0.set status=disable;
ob1.z3.obs0.set status=disable;
ob1.z4.obs0.set status=disable;
ob1.z5.obs0.set status=disable;
ob1.z6.obs0.set status=disable;
ob1.z2.obs1.set status=disable;
ob1.z3.obs1.set status=disable;
ob1.z4.obs1.set status=disable;
ob1.z5.obs1.set status=disable;
ob1.z6.obs1.set status=disable;

ob1.reboot;

ob1.z6.add;
ob1.z6.start_zone;
ob1.z6.obs0.set status=enable;
ob1.z6.obs1.set status=enable;

ob1.z2.add;
ob1.z2.start_zone;
ob1.z2.obs0.set status=enable;
ob1.z2.obs1.set status=enable;

ob1.z3.add;
ob1.z3.start_zone;
ob1.z3.obs0.set status=enable;
ob1.z3.obs1.set status=enable;

ob1.z4.add;
ob1.z4.start_zone;
ob1.z4.obs0.set status=enable;
ob1.z4.obs1.set status=enable;

ob1.z5.add;
ob1.z5.start_zone;
ob1.z5.obs0.set status=enable;
ob1.z5.obs1.set status=enable;

ob1.z6.obs0.start;
ob1.z2.obs0.start;
ob1.z3.obs0.start;
ob1.z4.obs0.start;
ob1.z5.obs0.start;
ob1.z6.obs1.start;
ob1.z2.obs1.start;
ob1.z3.obs1.start;
ob1.z4.obs1.start;
ob1.z5.obs1.start;

sleep 30;

ob1.z6.obs0.add;
ob1.z2.obs0.add;
ob1.z3.obs0.add;
ob1.z4.obs0.add;
ob1.z5.obs0.add;

ob1.z6.obs1.add;
ob1.z2.obs1.add;
ob1.z3.obs1.add;
ob1.z4.obs1.add;
ob1.z5.obs1.add;
ob1.check_until_timeout select count(*) from __all_server where start_service_time>0, 11, 120;
ob1.mysql alter system set balancer_idle_time = '10s';

let $case_index = 1;

ob1.mysql CREATE RESOURCE UNIT unit_$case_index MAX_CPU 2, MEMORY_SIZE '2G';
ob1.mysql CREATE RESOURCE POOL pool_$case_index UNIT = 'unit_$case_index', UNIT_NUM = 1, ZONE_LIST = ('z6', 'z2','z3', 'z4', 'z5');
ob1.mysql CREATE TENANT tenant_$case_index RESOURCE_POOL_LIST = ('pool_$case_index'), locality='F@z6,F@z2,F@z3,F@z4,f@z5', primary_zone='z2;z3' set ob_tcp_invited_nodes='%';
#4.0 没有非tenant级别的primary_zone
##case 1: 验证gts模式下，租户和表的primary zone必须要在一起；
#let $case_index = 2;

#ob1.mysql CREATE RESOURCE UNIT unit_$case_index MAX_CPU $cpu, MAX_MEMORY $memory, MAX_IOPS $iops, MAX_DISK_SIZE $disk, MAX_SESSION_NUM $session, MIN_CPU=1, MIN_MEMORY=$min_memory, MIN_IOPS=128;
#ob1.mysql CREATE RESOURCE POOL pool_$case_index UNIT = 'unit_$case_index', UNIT_NUM = 1, ZONE_LIST = ('z6', 'z2','z3', 'z4', 'z5');
#ob1.mysql CREATE TENANT tenant_$case_index RESOURCE_POOL_LIST = ('pool_$case_index'), locality='F@z6,F@z2,F@z3,F@z4,f@z5', primary_zone='z2;z3' set ob_tcp_invited_nodes='%';
#sleep 4;
##获取租户的位置；
#ob_connect(tt2_conn, ob1.proxy0, root@tenant_2, , test, , USE_MYSQL_CONNECTOR);
#connection tt2_conn;
#--error 1235 
#create table t(c1 int primary key, c2 int) primary_zone='z3,z4';
#ob1.mysql drop tenant tenant_2 force;
ob1.mysql drop tenant tenant_1 force;
##case 2: 验证OBS上没有租户资源时，可以直接stop;
##有UNIT但是没有对应的租户；
ob_connect(sys_conn, ob1.z1.obs0, root, , oceanbase, , USE_MYSQL_CONNECTOR);
connection sys_conn;
--disable_query_log

let $ip = deploy_get_value(ob1.z2.obs1.ip);
let $port = deploy_get_value(ob1.z2.obs1.port);
eval alter system stop server '$ip:$port'; 

let $ip = deploy_get_value(ob1.z3.obs1.ip);
let $port = deploy_get_value(ob1.z3.obs1.port);
--error 4660 
eval alter system stop server '$ip:$port'; 

let $ip = deploy_get_value(ob1.z4.obs1.ip);
let $port = deploy_get_value(ob1.z4.obs1.port);
--error 4660 
eval alter system stop server '$ip:$port'; 

let $ip = deploy_get_value(ob1.z5.obs1.ip);
let $port = deploy_get_value(ob1.z5.obs1.port);
--error 4660 
eval alter system stop server '$ip:$port'; 

let $ip = deploy_get_value(ob1.z6.obs1.ip);
let $port = deploy_get_value(ob1.z6.obs1.port);
--error 4660 
eval alter system stop server '$ip:$port'; 

let $ip = deploy_get_value(ob1.z2.obs0.ip);
let $port = deploy_get_value(ob1.z2.obs0.port);
eval alter system stop server '$ip:$port'; 

let $ip = deploy_get_value(ob1.z3.obs0.ip);
let $port = deploy_get_value(ob1.z3.obs0.port);
--error 4660 
eval alter system stop server '$ip:$port'; 

let $ip = deploy_get_value(ob1.z4.obs0.ip);
let $port = deploy_get_value(ob1.z4.obs0.port);
--error 4660 
eval alter system stop server '$ip:$port'; 

let $ip = deploy_get_value(ob1.z5.obs0.ip);
let $port = deploy_get_value(ob1.z5.obs0.port);
--error 4660 
eval alter system stop server '$ip:$port'; 

let $ip = deploy_get_value(ob1.z6.obs0.ip);
let $port = deploy_get_value(ob1.z6.obs0.port);
--error 4660 
eval alter system stop server '$ip:$port'; 

#恢复；
let $ip = deploy_get_value(ob1.z2.obs1.ip);
let $port = deploy_get_value(ob1.z2.obs1.port);
eval alter system start server '$ip:$port'; 

let $ip = deploy_get_value(ob1.z2.obs0.ip);
let $port = deploy_get_value(ob1.z2.obs0.port);
eval alter system start server '$ip:$port'; 

#删除resource pool;
--enable_query_log
drop resource pool pool_1;
#由于现在的限制还是stop zone不能跨zone，所以后续的测试无效

