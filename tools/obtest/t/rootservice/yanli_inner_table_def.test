#验证负载均衡完成后DBA/CDB_OB_LS_HISTORY表的视图
ob1.mysql alter system set ls_gc_delay_time = '0s' tenant = 'mysql';
ob1.mysql alter system set ls_gc_delay_time = '0s' tenant = 'oracle';
ob1.mysql alter tenant mysql set primary_zone = 'z1';
ob1.mysql alter tenant oracle set primary_zone = 'z1, z2';
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_balance_job, 2, 30;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_balance_job, 0, 200;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_ls_status where status = 'WAIT_OFFLINE', 0, 100;
let $job_id = deploy_get_value(ob1.select select max(job_id) as id from oceanbase.__all_rootservice_job, id, 1);
ob1.check_until_timeout select count(*) from oceanbase.__all_rootservice_job where job_id = $job_id and job_status = 'SUCCESS', 1, 100;
connection conn_sys;
select ls_id, status,ls_group_id from DBA_OB_LS_HISTORY ORDER BY LS_ID;
select tenant_id, ls_id, status,ls_group_id from CDB_OB_LS_HISTORY ORDER BY tenant_id, LS_ID;
connection conn_mysql;
select ls_id, status,ls_group_id from DBA_OB_LS_HISTORY ORDER BY LS_ID;
connection conn_oracle;
select ls_id, status,ls_group_id from DBA_OB_LS_HISTORY ORDER BY LS_ID;
ob1.mysql alter tenant oracle set primary_zone = 'z1';
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_balance_job, 1, 30;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_balance_job, 0, 200;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_ls_status where status = 'WAIT_OFFLINE', 0, 100;

connection conn_sys;
select ls_id, status,ls_group_id from DBA_OB_LS_HISTORY ORDER BY LS_ID;
select tenant_id, ls_id, status,ls_group_id from CDB_OB_LS_HISTORY ORDER BY tenant_id, LS_ID;
connection conn_mysql;
select ls_id, status,ls_group_id from DBA_OB_LS_HISTORY ORDER BY LS_ID;
connection conn_oracle;
select ls_id, status,ls_group_id from DBA_OB_LS_HISTORY ORDER BY LS_ID;

