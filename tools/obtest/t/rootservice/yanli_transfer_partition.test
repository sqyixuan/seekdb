#owner :msy164651
# 测试点：
##########################

ob1=OBI(cluster=2:2,proxy_num=0);
source include/mini_ob_config.inc;
ob1.set extra_config=$mini_ob_config;
ob1.reboot;

ob_connect(conn_sys, ob1.z1.obs0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);

connection conn_sys;
alter system set balancer_idle_time = '10s';
ob1.mysql alter system set debug_sync_timeout = '1000s';
ob1.mysql alter system set _transfer_start_trans_timeout = '60s';


set @@session.ob_query_timeout = 1000000000;

#mysql tenant
eval CREATE RESOURCE UNIT unit_1 MAX_CPU 1, MEMORY_SIZE '2G';
eval CREATE RESOURCE POOL pool_1 UNIT = 'unit_1', UNIT_NUM = 2;
eval CREATE TENANT mysql RESOURCE_POOL_LIST = ('pool_1'), primary_zone='z1' set ob_tcp_invited_nodes='%';
let $tenant_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name = 'mysql', tenant_id, 1);
ob1.mysql alter system set balancer_idle_time = '10s' tenant = 'mysql';
ob1.mysql alter system set _transfer_service_wakeup_interval = '5s' tenant = 'mysql';
ob1.mysql alter system set _transfer_task_retry_interval = '0' tenant='mysql';
sleep 2;
ob_connect(conn_mysql, ob1.z1.obs1, root@mysql, , test, , USE_MYSQL_CONNECTOR);
connection conn_mysql;
set recyclebin=off;
let $count = 0;
while ($count < 30) 
{
eval create table non_partition_$count(pk int primary key, c3 int, c4 int, c2 longtext);
eval insert into non_partition_$count values(1, 1, 1, "xdrdgwrtqwrweqr");
eval create index il_$count on non_partition_$count(c3) local;
eval create index il1_$count on non_partition_$count(c3) global;

inc $count;
}
create table partition_one(c1 int , c2 int, c3 longtext) partition by hash(c1) partitions 4;
create index il_one on partition_one(c2) local;
create index il_one1 on partition_one(c2) global;

create table partition_two (c1 int, c2 int, c3 int, c4 longtext) partition by hash(c1) subpartition by list(c2) subpartition template(subpartition p0 values in (1,2,3), subpartition p1 values in (default)) partitions 3;
create index il_two on partition_two(c2) local;
create index il_two1 on partition_two(c3) global;

#创建广播日志流
# test create duplicate table
create table dup_t1(c1 int, c2 longtext) duplicate_scope = 'cluster';
insert into dup_t1 value (1, "123"), (2,"456"), (3,"789"), (4,"1"), (5, "2");
create table dup_pt1(c1 int) duplicate_scope = 'CLUSTER' partition by hash(c1) partitions 4;
insert into dup_pt1 value (1), (2), (3), (4), (5);
select * from dup_pt1 order by c1 asc;
# test create table like duplicate table
create table dup_from_t1 like dup_t1;
create table dup_t2(c1 int primary key,c2 int ,c3 int) duplicate_scope = 'cluster';
create index il on dup_t2(c2) local;
create index il1 on dup_t2(c2) global;

create table dup_t3(c1 int primary key,c2 int ,c3 int) duplicate_scope = 'cluster' partition by hash(c1) partitions 100;
create index il on dup_t3(c2) local;
create index il1 on dup_t3(c2) global;
ob1.mysql alter system major freeze tenant = 'mysql';
sleep 10;
ob1.mysql set ob_global_debug_sync = 'BEFORE_TENANT_BALANCE_SERVICE wait_for signal';
