# CASE_OWNER:
#    @shouju.zyp
# CASE_DESC:


ob1=OBI(cluster=1:1:1,proxy_num=0);

let $backup_ip       = deploy_get_value(ob1.z1.obs0.ip);
let $backup_port     = deploy_get_value(ob1.z1.obs0.mysql_port);
let $backup_mysql_tenant  = backup_mysql_tenant;

ob1.force_stop;
ob1.clean_backup_dest;
ob1.reboot;

ob1.mysql alter resource unit sys_unit_config memory_size='2G';

ob1.mysql CREATE RESOURCE UNIT unit_1 MAX_CPU 2, MEMORY_SIZE '2G';
ob1.mysql CREATE RESOURCE POOL pool_1 UNIT = 'unit_1', UNIT_NUM = 1, ZONE_LIST=('z1', 'z2', 'z3');

# 创建主租户
ob1.mysql CREATE TENANT $backup_mysql_tenant RESOURCE_POOL_LIST = ('pool_1'), primary_zone = "z2" set ob_tcp_invited_nodes='%', ob_compatibility_mode='mysql';

connect(backup_sys_conn, $backup_ip, root@sys,,oceanbase, $backup_port);
connection backup_sys_conn;
use oceanbase;
#################################################################################################
#########################   switch to standby 租户不是user租户   ###############################
#################################################################################################
--error 1210
ALTER SYSTEM SWITCHOVER TO STANDBY TENANT META$1002 VERIFY;
--error 1210
ALTER SYSTEM SWITCHOVER TO STANDBY TENANT sys VERIFY;

#################################################################################################
#########################   switch to standby失败 recovery_until_scn不是最大   #######################
#################################################################################################

let $tenant_recovery_until_scn = deploy_get_value(ob1.select select recovery_until_scn from oceanbase.__all_virtual_tenant_info WHERE tenant_id = 1002, recovery_until_scn, 1);
alter system change tenant tenant_id = 1001;
UPDATE oceanbase.__all_tenant_info SET recovery_until_scn = 100 where tenant_id=1002;
alter system change tenant tenant_id = 1;
SELECT recovery_until_scn FROM oceanbase.__all_virtual_tenant_info WHERE tenant_id = 1002;
--error 1210
eval ALTER SYSTEM SWITCHOVER TO STANDBY TENANT $backup_mysql_tenant VERIFY;

alter system change tenant tenant_id = 1001;
eval UPDATE oceanbase.__all_tenant_info SET recovery_until_scn = $tenant_recovery_until_scn where tenant_id=1002;
alter system change tenant tenant_id = 1;
ob1.mysql ALTER SYSTEM SWITCHOVER TO STANDBY TENANT $backup_mysql_tenant VERIFY;
SELECT tenant_role FROM oceanbase.__all_virtual_tenant_info WHERE tenant_id = 1002;

#################################################################################################
#########################   switch to standby失败 switchover_status无效   ########################
#################################################################################################
alter system change tenant tenant_id = 1001;
UPDATE oceanbase.__all_tenant_info SET switchover_status = 'PREPARE SWITCHING TO PRIMARY' where tenant_id=1002;
alter system change tenant tenant_id = 1;
SELECT switchover_status FROM oceanbase.__all_virtual_tenant_info WHERE tenant_id = 1002;
--error 4179
eval ALTER SYSTEM SWITCHOVER TO STANDBY TENANT $backup_mysql_tenant VERIFY;

alter system change tenant tenant_id = 1001;
UPDATE oceanbase.__all_tenant_info SET switchover_status = 'FLASHBACK' where tenant_id=1002;
alter system change tenant tenant_id = 1;
SELECT switchover_status FROM oceanbase.__all_virtual_tenant_info WHERE tenant_id = 1002;
--error 4179
eval ALTER SYSTEM SWITCHOVER TO STANDBY TENANT $backup_mysql_tenant VERIFY;

alter system change tenant tenant_id = 1001;
UPDATE oceanbase.__all_tenant_info SET switchover_status = 'PREPARE FLASHBACK' where tenant_id=1002;
alter system change tenant tenant_id = 1;
SELECT switchover_status FROM oceanbase.__all_virtual_tenant_info WHERE tenant_id = 1002;
--error 4179
eval ALTER SYSTEM SWITCHOVER TO STANDBY TENANT $backup_mysql_tenant VERIFY;
alter system change tenant tenant_id = 1001;
UPDATE oceanbase.__all_tenant_info SET switchover_status = 'SWITCHING TO PRIMARY' where tenant_id=1002;
alter system change tenant tenant_id = 1;
SELECT switchover_status FROM oceanbase.__all_virtual_tenant_info WHERE tenant_id = 1002;
--error 4179
eval ALTER SYSTEM SWITCHOVER TO STANDBY TENANT $backup_mysql_tenant VERIFY;

alter system change tenant tenant_id = 1001;
UPDATE oceanbase.__all_tenant_info SET switchover_status = 'NORMAL' where tenant_id=1002;


#################################################################################################
#########################   switch to standby之后还可以switchover to standby   ###############################
#################################################################################################
ob1.mysql ALTER SYSTEM SWITCHOVER TO STANDBY TENANT $backup_mysql_tenant;
ob1.mysql ALTER SYSTEM SWITCHOVER TO STANDBY TENANT $backup_mysql_tenant;