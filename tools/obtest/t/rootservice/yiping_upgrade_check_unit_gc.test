ob1=OBI(cluster=1,proxy_num=0);
ob1.reboot;
--disable_abort_on_error

ob1.mysql create resource unit box max_cpu 1, memory_size='10G';
ob1.mysql create resource pool pool unit = 'box', unit_num = 1;
ob1.mysql create tenant mysql replica_num = 1, resource_pool_list=('pool');

let $mysql_tenant_id=deploy_get_value(ob1.select select tenant_id from oceanbase.dba_ob_tenants where tenant_name='mysql', tenant_id, 1);

# 不让ls删除，进而避免unit被gc
ob1.mysql alter system set debug_sync_timeout = '100000s';
ob1.mysql set ob_global_debug_sync = 'STOP_PRIMARY_LS_THREAD wait_for signalxxx execute 10000';
ob1.mysql drop tenant mysql force;

let $z1_ip = deploy_get_value(ob1.z1.obs0.ip);
let $z1_port = deploy_get_value(ob1.z1.obs0.mysql_port);
ob_connect(sys_conn, $z1_ip, root@sys,,, $z1_port);
connection sys_conn;

# 预期tenant被删了，但是unit残留
eval select count(*) from oceanbase.dba_ob_tenants where tenant_id=$mysql_tenant_id;
eval select if(count(*)>0,1,0) from oceanbase.__all_virtual_unit where tenant_id=$mysql_tenant_id;
select count(*) from oceanbase.gv$ob_units a, oceanbase.__all_tenant_history b where b.is_deleted = 1 and a.tenant_id = b.tenant_id;

# upgrade check会失败
ob1.upgrade_check_before_fail;
select count(*) from oceanbase.gv$ob_units a, oceanbase.__all_tenant_history b where b.is_deleted = 1 and a.tenant_id = b.tenant_id;

ob1.mysql set ob_global_debug_sync = 'now broadcast signalxxx';
ob1.mysql set ob_global_debug_sync = 'STOP_PRIMARY_LS_THREAD clear';

ob1.check_until_timeout select count(*) from oceanbase.gv\$ob_units a, oceanbase.__all_tenant_history b where b.is_deleted = 1 and a.tenant_id = b.tenant_id, 0, 600;

# unit删完了 upgrade check成功
ob1.upgrade_check_before;
