##
# owner      : zg410411
# owner group: rs
# description: 测试从4.3.0.1升级到master分支，验证备库回放逻辑
##
# 1. 创建集群
ob1=OBI(cluster=1:1:1,version=4_3_0_1,oblog_version=current,proxy_num=0);
ob1.proxy0.set extra_config=syslog_level=debug;

ob1.reboot;
sleep 15;

ob2=OBI(cluster=1:1:1,version=4_3_0_1,oblog_version=current,proxy_num=0);
ob2.proxy0.set extra_config=syslog_level=debug;

ob2.reboot;
sleep 15;

# 2. 创建主租户
ob1.mysql create resource unit box1 max_cpu 2,memory_size 5368709120;
ob1.mysql create resource pool pool1 unit = 'box1', unit_num = 1;
ob1.mysql create tenant mysql resource_pool_list=('pool1') set ob_tcp_invited_nodes='%', ob_compatibility_mode='mysql';
sleep 5;
ob_connect(conn_primary_mysql, ob1.z1.obs0, root@mysql, , test, , USE_MYSQL_CONNECTOR);
ob_connect(conn_primary_sys, ob1.z1.obs0, root, , oceanbase, , USE_MYSQL_CONNECTOR);
connection conn_primary_sys;
let $primary_mysql_id = query_get_value(select tenant_id from oceanbase.__all_tenant where tenant_name='mysql', tenant_id, 1);
connection conn_primary_mysql;
create user rep_user IDENTIFIED BY 'rep_user';
grant select on oceanbase.* TO rep_user;
create table t1(id int);
insert into t1 values(1);

# 3. 创建备租户
let $server_ip_port_1=deploy_get_value(ob1.select select concat(svr_ip,':',sql_port) as host from CDB_OB_LS_LOCATIONS where tenant_id = $primary_mysql_id and ls_id = 1 and role = 'LEADER' order by svr_ip, sql_port limit 1;, host, 1);
let $server_ip_port_2=deploy_get_value(ob1.select select concat(svr_ip,':',sql_port) as host from CDB_OB_LS_LOCATIONS where tenant_id = $primary_mysql_id and ls_id = 1 and role = 'FOLLOWER' order by svr_ip, sql_port limit 1, host, 1);
let $server_ip_port_3=deploy_get_value(ob1.select select concat(svr_ip,':',sql_port) as host from CDB_OB_LS_LOCATIONS where tenant_id = $primary_mysql_id and ls_id = 1 and role = 'FOLLOWER' and concat(svr_ip,':',sql_port) not like "%$server_ip_port_2%" limit 1, host, 1);
ob2.mysql create resource unit box1 max_cpu 2,memory_size 5368709120;
ob2.mysql create resource pool pool1 unit = 'box1', unit_num = 1;
ob2.mysql CREATE STANDBY TENANT mysql_standby LOG_RESTORE_SOURCE = 'service=$server_ip_port_1;$server_ip_port_2;$server_ip_port_3 USER=rep_user@mysql PASSWORD=rep_user' RESOURCE_POOL_LIST=('pool1');
sleep 30;
ob_connect(conn_standby_mysql, ob2.z1.obs0, root@mysql_standby, , test, , USE_MYSQL_CONNECTOR);
ob_connect(conn_standby_sys, ob2.z1.obs0, root, , oceanbase, , USE_MYSQL_CONNECTOR);
connection conn_standby_sys;
let $standby_mysql_id = query_get_value(select tenant_id from oceanbase.__all_tenant where tenant_name='mysql_standby', tenant_id, 1);
ob2.check_until_timeout SELECT status FROM dba_ob_tenants WHERE tenant_id = $standby_mysql_id, NORMAL, 200;
connection conn_standby_mysql;
select * from t1;

# 4. 升级主租户
# 4.1.执行升级SQL
ob1.upgrade_check_before;
ob1.upgrade_commond_for_server pre;
# 4.2 升级z2
connection conn_primary_sys;
alter system stop zone 'z2';
ob1.check_until_timeout select status from DBA_OB_ZONES where zone='z2',INACTIVE,20;
ob1.check_until_timeout select count(1) as leader_count  from CDB_OB_LS_LOCATIONS where zone='z2' and role='leader',0,20;
ob1.z2.force_stop;
ob1.z2.upgrade;
ob1.z2.nstart;
ob1.check_until_timeout select count(*) from oceanbase.__all_server where zone = 'z2' and (start_service_time is null  or status='INACTIVE'),0,300;
ob1.check_until_timeout  select count(1) as unsync_cnt from GV\$OB_LOG_STAT where in_sync = 'NO',0,600;
source include/check_schema_sync_for_restart.inc;
ob1.mysql alter system start zone 'z2';
sleep 30;
# 4.3 升级z1
connection conn_primary_sys;
alter system stop zone 'z1';
ob1.check_until_timeout select status from DBA_OB_ZONES where zone='z1',INACTIVE,20;
ob1.check_until_timeout select count(1) as leader_count  from CDB_OB_LS_LOCATIONS where zone='z1' and role='leader',0,20;
ob1.z1.force_stop;
ob1.z1.upgrade;
ob1.z1.nstart;
ob1.check_until_timeout select count(*) from oceanbase.__all_server where zone = 'z1' and (start_service_time is null or status='INACTIVE'),0,300;
ob1.check_until_timeout  select count(1) as unsync_cnt from GV\$OB_LOG_STAT where in_sync = 'NO',0,600;
source include/check_schema_sync_for_restart.inc;
ob1.mysql alter system start zone 'z1';
sleep 30;
ob_connect(conn_primary_mysql, ob1.z1.obs0, root@mysql, , test, , USE_MYSQL_CONNECTOR);
ob_connect(conn_primary_sys, ob1.z1.obs0, root, , test, , USE_MYSQL_CONNECTOR);
# 4.4 升级z3
connection conn_primary_sys;
alter system stop zone 'z3';
ob1.check_until_timeout select status from DBA_OB_ZONES where zone='z3',INACTIVE,20;
ob1.check_until_timeout select count(1) as leader_count  from CDB_OB_LS_LOCATIONS where zone='z3' and role='leader',0,20;
ob1.z3.force_stop;
ob1.z3.upgrade;
ob1.z3.nstart;
ob1.check_until_timeout select count(*) from oceanbase.__all_server where zone = 'z3' and (start_service_time is null or status='INACTIVE'),0,300;
ob1.check_until_timeout  select count(1) as unsync_cnt from GV\$OB_LOG_STAT where in_sync = 'NO',0,600;
source include/check_schema_sync_for_restart.inc;
ob1.mysql alter system start zone 'z3';
sleep 30;
# 4.5 执行升级后SQL
connection conn_primary_sys;
ob1.upgrade_commond_for_server post;
alter system run job 'root_inspection';
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_upgrade_inspection where info != 'succeed',0,180;

# 5. 主租户升级后，检查备租户同步状态
connection conn_primary_mysql;
insert into t1 values(2),(3),(4);
select * from t1;
let $primary_finish_upgrade_time = `select current_timestamp(6)`;
sleep 10;
connection conn_standby_mysql;
select * from t1;
connection conn_standby_sys;
let $ls_id = deploy_get_value(ob2.select select max(ls_id) max_ls_id from oceanbase.__all_virtual_log_stat where tenant_id='$standby_mysql_id' and ls_id != 1, max_ls_id, 1);
--disable_query_log
eval select count(1) as cnt from oceanbase.__all_virtual_ha_diagnose where tenant_id=$standby_mysql_id and ls_id=$ls_id and scn_to_timestamp(max_replayed_scn) > timestamp'$primary_finish_upgrade_time';
--enable_query_log

# 6. 升级备租户
# 6.1.执行升级SQL
ob2.upgrade_check_before;
ob2.upgrade_commond_for_server pre;
# 6.2 升级z2
connection conn_standby_sys;
alter system stop zone 'z2';
ob2.check_until_timeout select status from DBA_OB_ZONES where zone='z2',INACTIVE,20;
ob2.check_until_timeout select count(1) as leader_count  from CDB_OB_LS_LOCATIONS where zone='z2' and role='leader',0,20;
ob2.z2.force_stop;
ob2.z2.upgrade;
ob2.z2.nstart;
ob2.check_until_timeout select count(*) from oceanbase.__all_server where zone = 'z2' and (start_service_time is null  or status='INACTIVE'),0,300;
ob2.check_until_timeout  select count(1) as unsync_cnt from GV\$OB_LOG_STAT where in_sync = 'NO',0,600;
source include/check_schema_sync_for_restart.inc;
ob2.mysql alter system start zone 'z2';
sleep 30;
# 6.3 升级z1
connection conn_standby_sys;
set @@session.ob_query_timeout = 60000000;
alter system stop zone 'z1';
ob2.check_until_timeout select status from DBA_OB_ZONES where zone='z1',INACTIVE,20;
ob2.check_until_timeout select count(1) as leader_count  from CDB_OB_LS_LOCATIONS where zone='z1' and role='leader',0,20;
ob2.z1.force_stop;
ob2.z1.upgrade;
ob2.z1.nstart;
ob2.check_until_timeout select count(*) from oceanbase.__all_server where zone = 'z1' and (start_service_time is null or status='INACTIVE'),0,300;
ob2.check_until_timeout  select count(1) as unsync_cnt from GV\$OB_LOG_STAT where in_sync = 'NO',0,600;
source include/check_schema_sync_for_restart.inc;
ob2.mysql alter system start zone 'z1';
sleep 60;
ob_connect(conn_standby_mysql, ob2.z1.obs0, root@mysql_standby, , test, , USE_MYSQL_CONNECTOR);
ob_connect(conn_standby_sys, ob2.z1.obs0, root, , oceanbase, , USE_MYSQL_CONNECTOR);
# 6.4 升级z3
connection conn_standby_sys;
set @@session.ob_query_timeout = 60000000;
alter system stop zone 'z3';
ob2.check_until_timeout select status from DBA_OB_ZONES where zone='z3',INACTIVE,20;
ob2.check_until_timeout select count(1) as leader_count  from CDB_OB_LS_LOCATIONS where zone='z3' and role='leader',0,20;
ob2.z3.force_stop;
ob2.z3.upgrade;
ob2.z3.nstart;
ob2.check_until_timeout select count(*) from oceanbase.__all_server where zone = 'z3' and (start_service_time is null or status='INACTIVE'),0,300;
ob2.check_until_timeout  select count(1) as unsync_cnt from GV\$OB_LOG_STAT where in_sync = 'NO',0,600;
source include/check_schema_sync_for_restart.inc;
ob2.mysql alter system start zone 'z3';
sleep 30;
# 6.5 开ERRSIM限制备租户data_version同步
ob_connect(conn_standby_mysql1, ob2.z1.obs0, root@mysql_standby, , test, , USE_MYSQL_CONNECTOR);
connection conn_standby_sys;
eval alter system set_tp tp_name=ERRSIM_DATA_VERSION_BARRIER_ERROR, error_code=4016, frequency=1;
# 6.6 执行升级后SQL
connection conn_standby_sys;
ob2.upgrade_commond_for_server post;
alter system run job 'root_inspection';
ob2.check_until_timeout select count(*) from oceanbase.__all_virtual_upgrade_inspection where info != 'succeed',0,180;
# 查表检查备租户回放进度
connection conn_standby_mysql1;
select * from t1;
connection conn_standby_sys;
--disable_query_log
eval select count(1) as cnt from oceanbase.__all_virtual_ha_diagnose where tenant_id=$standby_mysql_id and ls_id=$ls_id and scn_to_timestamp(max_replayed_scn) > timestamp'$primary_finish_upgrade_time';
--enable_query_log
# 6.7 放开data_version限制
connection conn_standby_sys;
eval alter system set_tp tp_name=ERRSIM_DATA_VERSION_BARRIER_ERROR, error_code=4016, frequency=0;
sleep 5;
# 查表检查备租户回放进度
ob2.check_until_timeout select count(*) from oceanbase.__all_virtual_timestamp_service where tenant_id=$standby_mysql_id and service_role='STS_LEADER' and scn_to_timestamp(ts_value) > timestamp'$primary_finish_upgrade_time', 1, 180;
connection conn_standby_mysql1;
select * from t1;
connection conn_standby_sys;
--disable_query_log
eval select count(1) as cnt from oceanbase.__all_virtual_ha_diagnose where tenant_id=$standby_mysql_id and ls_id=$ls_id and scn_to_timestamp(max_replayed_scn) > timestamp'$primary_finish_upgrade_time';
--enable_query_log