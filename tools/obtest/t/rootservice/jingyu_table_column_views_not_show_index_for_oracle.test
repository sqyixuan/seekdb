# CASE_OWNER:
#    @jingyu.cr
# CASE_DESC:
#  For oracle tenant, table columns related view should not show informations about index table
#  These table should adjust implementation:
#     ● ALL_TAB_COLUMNS
#     ● DBA_TAB_COLUMNS
#     ● USER_TAB_COLUMNS
#     ● ALL_TAB_COLS
#     ● DBA_TAB_COLS
#     ● USER_TAB_COLS
#     ● ALL_TAB_COLS_V$
#     ● DBA_TAB_COLS_V$
#     ● USER_TAB_COLS_V$
#     ● CDB_TAB_COLS_V$             （sys租户下的视图）
#     ● CDB_TAB_COLS                （sys租户下的视图）
#     ● CDB_TAB_COL_STATISTICS      （sys租户下的视图）
#
#   aone link: 
#

ob1=OBI(cluster=1, init_unit_cpu=0, proxy_num=0);
source include/mini_ob_config.inc;
ob1.set extra_config=$mini_ob_config;
ob1.reboot;

let $sys_ip = deploy_get_value(ob1.z1.obs0.ip);
let $sys_port = deploy_get_value(ob1.z1.obs0.mysql_port);
connect(conn_sys, $sys_ip, root@sys,,oceanbase, $sys_port);

--echo ===============================================
--echo             create oracle tenant
--echo ===============================================
connection conn_sys;
source include/create_unit_config.inc;
CREATE RESOURCE POOL oracle_pool UNIT = '2c2g', UNIT_NUM = 1;
CREATE TENANT oracle RESOURCE_POOL_LIST = ('oracle_pool'), primary_zone = 'z1', locality='F@z1' set ob_tcp_invited_nodes='%', ob_compatibility_mode='oracle';
let $oracle_tenant_id = query_get_value(select tenant_id from oceanbase.__all_tenant where tenant_name="oracle", tenant_id, 1);

--echo ===============================================
--echo             create table and index
--echo ===============================================
ob_connect(conn_oracle, ob1.z1.obs0, SYS@oracle, ,SYS, , USE_OB_CONNECTOR);
connection conn_oracle;
# create table t1
create table test_table_1 (c1 int primary key, c2 int, c3 int);
create index test_table_1_idx1 on test_table_1(c2) global partition by hash(c2) partitions 4;
create index test_table_1_idx2 on test_table_1(c3) local;
select table_name, column_name from ALL_TAB_COLUMNS where table_name like '%TEST_TABLE%' order by table_name, column_name;
select table_name, column_name from DBA_TAB_COLUMNS where table_name like '%TEST_TABLE%' order by table_name, column_name;
select table_name, column_name from USER_TAB_COLUMNS where table_name like '%TEST_TABLE%' order by table_name, column_name;
select table_name, column_name from ALL_TAB_COLS where table_name like '%TEST_TABLE%' order by table_name, column_name;
select table_name, column_name from DBA_TAB_COLS where table_name like '%TEST_TABLE%' order by table_name, column_name;
select table_name, column_name from USER_TAB_COLS where table_name like '%TEST_TABLE%' order by table_name, column_name;
select table_name, column_name from ALL_TAB_COLS_V$ where table_name like '%TEST_TABLE%' order by table_name, column_name;
select table_name, column_name from DBA_TAB_COLS_V$ where table_name like '%TEST_TABLE%' order by table_name, column_name;
select table_name, column_name from USER_TAB_COLS_V$ where table_name like '%TEST_TABLE%' order by table_name, column_name;

connection conn_sys;
select table_name, column_name from CDB_TAB_COLS_V$ where table_name like '%TEST_TABLE%' order by table_name, column_name;
select table_name, column_name from CDB_TAB_COLS where table_name like '%TEST_TABLE%' order by table_name, column_name;
select table_name, column_name from CDB_TAB_COL_STATISTICS where table_name like '%TEST_TABLE%' order by table_name, column_name;
