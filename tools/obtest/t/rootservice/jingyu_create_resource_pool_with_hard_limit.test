# CASE_OWNER:
#    @jingyu.cr
# CASE_DESC:
#    This case is aimed to test create resource pool below hard_limit
#    We designed following cases to simulate different scenes:
#
#    CASE 1: test create resource pool
#


#######################################################################
#                        create inital objects
#######################################################################

ob1=OBI(cluster=1,proxy_num=0,init_unit_cpu=0);
source include/mini_ob_config.inc;
ob1.set extra_config=$mini_ob_config;
ob1.reboot;

ob1.mysql alter system set debug_sync_timeout = '1000s';
ob1.mysql ALTER SYSTEM SET enable_rebalance = 'false';
ob1.mysql ALTER SYSTEM SET enable_rereplication = 'true';

let $proxy_ip = deploy_get_value(ob1.z1.obs0.ip);
let $proxy_port = deploy_get_value(ob1.z1.obs0.mysql_port);
connect(sys_conn, $proxy_ip, root@sys,,oceanbase, $proxy_port);

# create new tenant tenant_for_migrate_locality
source include/create_unit_config.inc;
alter system set resource_hard_limit = 1000;
let $cpu_capacity = deploy_get_value(ob1.select select cpu_capacity from oceanbase.GV\$OB_SERVERS where zone = 'z1', cpu_capacity, 1);
let $cpu_capacity_max = deploy_get_value(ob1.select select cpu_capacity_max from oceanbase.GV\$OB_SERVERS where zone = 'z1', cpu_capacity_max, 1);

ob1.mysql create resource unit if not exists mysql_unit max_cpu $cpu_capacity, min_cpu 2,  memory_size '2G';
ob1.mysql CREATE RESOURCE POOL tenant_pool UNIT = "mysql_unit", UNIT_NUM = 1, ZONE_LIST = ('z1');
ob1.mysql CREATE TENANT mysql RESOURCE_POOL_LIST=('tenant_pool'), LOCALITY = "F@z1", PRIMARY_ZONE = "z1" SET ob_tcp_invited_nodes='%';
