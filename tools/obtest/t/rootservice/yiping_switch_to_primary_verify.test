# CASE_OWNER:
#    @shouju.zyp
# CASE_DESC:
#    1. verify failover_to_primary
#    2. verify switchover_to_primary
#    3. verify switchover_to_standby

ob1=OBI(cluster=1:1:1,proxy_num=0);

let $backup_ip       = deploy_get_value(ob1.z1.obs0.ip);
let $backup_port     = deploy_get_value(ob1.z1.obs0.mysql_port);
let $backup_dest = deploy_get_value(ob1.get_backup_dest);
let $backup_mysql_tenant  = backup_mysql_tenant;
let $restore_mysql_tenant = restore_mysql_tenant;
let $log_backup_dest = deploy_get_value(ob1.get_log_backup_dest $backup_mysql_tenant);
let $data_backup_dest = deploy_get_value(ob1.get_data_backup_dest $backup_mysql_tenant);

ob1.force_stop;
ob1.clean_backup_dest;
ob1.reboot;

ob1.mysql alter resource unit sys_unit_config memory_size='2G';

ob1.mysql CREATE RESOURCE UNIT unit_1 MAX_CPU 2, MEMORY_SIZE '2G';
ob1.mysql CREATE RESOURCE POOL pool_1 UNIT = 'unit_1', UNIT_NUM = 1, ZONE_LIST=('z1', 'z2', 'z3');
ob1.mysql CREATE RESOURCE POOL pool_2 UNIT = 'unit_1', UNIT_NUM = 1, ZONE_LIST=('z1', 'z2', 'z3');
# 创建主租户
ob1.mysql CREATE TENANT $backup_mysql_tenant RESOURCE_POOL_LIST = ('pool_1'), primary_zone = "z2" set ob_tcp_invited_nodes='%', ob_compatibility_mode='mysql';
let $backup_mysql_tenant_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name='$backup_mysql_tenant', tenant_id, 1);
# 设置归档源
ob_connect(backup_mysql_conn, ob1.z1.obs0,root@$backup_mysql_tenant,,test,,USE_MYSQL_CONNECTOR);
connection backup_mysql_conn;
--disable_all_result_log
eval alter system set data_backup_dest='$data_backup_dest';
eval alter system set log_archive_dest='location=$log_backup_dest piece_switch_interval=1d';
--enable_all_result_log
# 准备一些数据
create table t1(a int primary key, b int, c int) partition by hash (a) partitions 100;
insert into t1(a, b) values(1, 1);
create table t2(a int primary key, b int, c int) partition by hash (a) partitions 100;
insert into t2(a, b) values(1, 1);
let $unit_count = deploy_get_value(ob1.select select count(*) c from __all_virtual_unit, c, 1);
create user mytest identified by "test";
grant SELECT on OCEANBASE.* to mytest;

ob1.mysql CREATE STANDBY TENANT IF NOT EXISTS standby_mysql_tenant LOG_RESTORE_SOURCE = 'service=$backup_ip:$backup_port USER=mytest@backup_mysql_tenant PASSWORD=test' PRIMARY_ZONE='z1', RESOURCE_POOL_LIST=('pool_2');
let $standby_mysql_tenant_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name='standby_mysql_tenant', tenant_id, 1);
ob1.check_until_timeout select count(*) from DBA_OB_TENANTS where TENANT_ID = $standby_mysql_tenant_id and TENANT_ROLE = 'STANDBY' and SWITCHOVER_STATUS = 'NORMAL',1,30;
connect(backup_sys_conn, $backup_ip, root@sys,,oceanbase, $backup_port);
connection backup_sys_conn;

#################################################################################################
#########################   switch to primary失败 网络直连的租户还是主租户  ##########################
#################################################################################################
--echo switch to primary失败 网络直连的租户还是主租户
--error 4179
eval ALTER SYSTEM SWITCHOVER TO PRIMARY TENANT standby_mysql_tenant VERIFY;
--error 4179
eval ALTER SYSTEM SWITCHOVER TO PRIMARY TENANT standby_mysql_tenant;

#################################################################################################
#########################   switch to primary失败 网络直连的租户 switchover status not normal  #####
#################################################################################################
--echo switch to primary失败 网络直连的租户 switchover status not normal
ob1.mysql ALTER SYSTEM SWITCHOVER TO STANDBY TENANT $backup_mysql_tenant;

alter system change tenant tenant_id = 1001;
UPDATE oceanbase.__all_tenant_info SET switchover_status = 'SWITCHING TO STANDBY' where tenant_id=1002;
alter system change tenant tenant_id = 1;
--error 4179
ALTER SYSTEM SWITCHOVER TO PRIMARY TENANT standby_mysql_tenant VERIFY;
--error 4179
ALTER SYSTEM SWITCHOVER TO PRIMARY TENANT standby_mysql_tenant;

alter system change tenant tenant_id = 1001;
UPDATE oceanbase.__all_tenant_info SET switchover_status = 'PREPARE SWITCHING TO STANDBY' where tenant_id=1002;
alter system change tenant tenant_id = 1;
--error 4179
ALTER SYSTEM SWITCHOVER TO PRIMARY TENANT standby_mysql_tenant VERIFY;
--error 4179
ALTER SYSTEM SWITCHOVER TO PRIMARY TENANT standby_mysql_tenant;
alter system change tenant tenant_id = 1001;
UPDATE oceanbase.__all_tenant_info SET switchover_status = 'NORMAL' where tenant_id=1002;
alter system change tenant tenant_id = 1;
#################################################################################################
#########################   switch to primary失败 网络直连的租户 status not normal  ################
#################################################################################################
--echo switch to primary失败 网络直连的租户 status not normal
eval UPDATE oceanbase.__all_tenant SET status='CREATING_STANDBY' where tenant_id=$backup_mysql_tenant_id;
--error 4179
ALTER SYSTEM SWITCHOVER TO PRIMARY TENANT standby_mysql_tenant VERIFY;
--error 4179
ALTER SYSTEM SWITCHOVER TO PRIMARY TENANT standby_mysql_tenant;

eval UPDATE oceanbase.__all_tenant SET status='NORMAL' where tenant_id=$backup_mysql_tenant_id;
eval select count(*) from DBA_OB_TENANTS where TENANT_ID = $standby_mysql_tenant_id and TENANT_ROLE = 'STANDBY' and SWITCHOVER_STATUS = 'NORMAL';
eval select count(*) from DBA_OB_TENANTS where TENANT_ID = $backup_mysql_tenant_id and TENANT_ROLE = 'STANDBY' and SWITCHOVER_STATUS = 'NORMAL';
drop tenant standby_mysql_tenant force;
ob1.check_until_timeout select count(*) from __all_virtual_unit, $unit_count, 180;
ob1.mysql ALTER SYSTEM SWITCHOVER TO PRIMARY TENANT $backup_mysql_tenant;
# 打开归档
ob1.mysql alter system archivelog;
# 检查归档状态
ob1.check_until_timeout select status from oceanbase.CDB_OB_ARCHIVELOG where tenant_id=$backup_mysql_tenant_id, DOING, 600;

# 执行数据备份
ob1.mysql alter system backup database;
# 检查备份状态
ob1.check_until_timeout select count(*) c from __all_backup_job_history where tenant_id = 1, 1, 600;
ob1.check_until_timeout select result from oceanbase.CDB_OB_BACKUP_JOB_HISTORY where tenant_id = $backup_mysql_tenant_id, 0, 10;
ob1.check_until_timeout select result from oceanbase.CDB_OB_BACKUP_TASK_HISTORY where tenant_id = $backup_mysql_tenant_id, 0, 10;

connection backup_sys_conn;
use oceanbase;

let $restore_path = $log_backup_dest,$data_backup_dest;
let $restore_checkpoint1 = `select ceil(min_restore_scn / 1000) as min_restore_scn from CDB_OB_BACKUP_SET_FILES where tenant_id = $backup_mysql_tenant_id`;
let $restore_checkpoint2 = `select ceil(UNIX_TIMESTAMP(current_timestamp(6)) * 1000000)`;
ob1.check_until_timeout select floor(checkpoint_scn / 1000) > '$restore_checkpoint1' from CDB_OB_ARCHIVELOG, 1, 600;
ob1.check_until_timeout select floor(checkpoint_scn / 1000) > '$restore_checkpoint2' from CDB_OB_ARCHIVELOG, 1, 600;
let $restore_checkpoint = $restore_checkpoint2;
let $restore_checkpoint = `select usec_to_time(floor(checkpoint_scn/1000)) from CDB_OB_ARCHIVELOG`;

--disable_all_result_log
# 在目标集群上执行RESTORE命令，使用租户的备份和归档，创建并恢复出备租户
ob1.mysql alter system restore $restore_mysql_tenant from '$restore_path' until time='$restore_checkpoint' with 'pool_list=pool_2&primary_zone=z1';
--enable_all_result_log
let $restore_mysql_tenant_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name='$restore_mysql_tenant', tenant_id, 1);
let $restore_mysql_meta_tenant_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name like '%1006', tenant_id, 1);
ob1.check_until_timeout SELECT status FROM __all_tenant WHERE tenant_id = $restore_mysql_meta_tenant_id, NORMAL, 200;
ob1.check_until_timeout select count(*) from __all_virtual_ls_meta_table where tenant_id = $restore_mysql_tenant_id and restore_status = 0, 6, 600;
#################################################################################################
#########################   switch to primary失败 租户不是normal状态   #############################
#################################################################################################
--echo switch to primary失败 租户不是normal状态
--error 4179
eval ALTER SYSTEM ACTIVATE STANDBY TENANT $restore_mysql_tenant VERIFY;
eval SELECT status FROM __all_tenant WHERE tenant_id = $restore_mysql_tenant_id;

--error 4179
eval ALTER SYSTEM SWITCHOVER TO PRIMARY TENANT $restore_mysql_tenant VERIFY;
eval SELECT status FROM __all_tenant WHERE tenant_id = $restore_mysql_tenant_id;

ob1.check_until_timeout select status FROM __all_tenant WHERE tenant_id = $restore_mysql_tenant_id, NORMAL, 200;

ob1.check_until_timeout select count(*) FROM __all_restore_job, 0, 200;

# 更改备租户恢复终点
ob1.mysql ALTER SYSTEM RECOVER STANDBY TENANT $restore_mysql_tenant UNTIL UNLIMITED;
ob1.mysql ALTER SYSTEM SWITCHOVER TO STANDBY TENANT $backup_mysql_tenant;

#################################################################################################
#########################   switch to primary失败 租户不是user租户   ###############################
#################################################################################################
--echo switch to primary失败 租户不是user租户
--error 1210
ALTER SYSTEM ACTIVATE STANDBY TENANT META$1006 VERIFY;
--error 1210
ALTER SYSTEM ACTIVATE STANDBY TENANT sys VERIFY;

--error 1210
ALTER SYSTEM SWITCHOVER TO PRIMARY TENANT META$1006 VERIFY;
--error 1210
ALTER SYSTEM SWITCHOVER TO PRIMARY TENANT sys VERIFY;

#################################################################################################
#########################   用户租户下 switch to primary verify, 此时不能写租户名   #################
#################################################################################################
--echo 用户租户下 switch to primary verify, 此时不能写租户名
connect(restore_conn, $backup_ip, root@restore_mysql_tenant,,oceanbase, $backup_port);
connection restore_conn;
ALTER SYSTEM ACTIVATE STANDBY VERIFY;
ALTER SYSTEM SWITCHOVER TO PRIMARY VERIFY;

--error 1210
eval ALTER SYSTEM ACTIVATE STANDBY TENANT $backup_mysql_tenant VERIFY;
--error 1210
eval ALTER SYSTEM SWITCHOVER TO PRIMARY TENANT $backup_mysql_tenant VERIFY;
--error 1210
eval ALTER SYSTEM ACTIVATE STANDBY TENANT $restore_mysql_tenant VERIFY;
--error 1210
eval ALTER SYSTEM SWITCHOVER TO PRIMARY TENANT $restore_mysql_tenant VERIFY;

#################################################################################################
#########################   switch to primary失败 租户有temporary offline server   ################
#################################################################################################
connection backup_sys_conn;
use oceanbase;
--echo switch to primary失败 租户有temporary offline server
let $obs3_ip = deploy_get_value(ob1.z3.obs0.ip);
let $obs3_port = deploy_get_value(ob1.z3.obs0.port);

ob1.z3.obs0.force_stop;
ob1.check_until_timeout select count(*) from __all_server where svr_ip='$obs3_ip' and svr_port=$obs3_port and status='INACTIVE',1,120;
--error 4179
eval ALTER SYSTEM ACTIVATE STANDBY TENANT $restore_mysql_tenant VERIFY;
eval SELECT tenant_role, status, switchover_status FROM oceanbase.DBA_OB_TENANTS WHERE tenant_id = $restore_mysql_tenant_id;

--error 4179
eval ALTER SYSTEM SWITCHOVER TO PRIMARY TENANT $restore_mysql_tenant VERIFY;
eval SELECT tenant_role, status, switchover_status FROM oceanbase.DBA_OB_TENANTS WHERE tenant_id = $restore_mysql_tenant_id;

#################################################################################################
#########################   switch to primary失败 租户有无主日志流   ###############################
#################################################################################################
--echo switch to primary失败 租户有无主日志流
ob1.mysql alter system set debug_sync_timeout = '100000s';
sleep 3;
ob1.mysql set ob_global_debug_sync = 'BEFORE_SEND_DRTASK_RPC wait_for continue_signal';
ob1.mysql alter system set server_permanent_offline_time = '20s';
sleep 30;
ob1.mysql alter system set_tp tp_name = CHECK_SERVER_EMPTY_WHEN_LS_HAS_NO_LEADER, error_code = 4016, frequency = 1;
--error 4179
eval ALTER SYSTEM ACTIVATE STANDBY TENANT $restore_mysql_tenant VERIFY;
eval SELECT tenant_role, status, switchover_status FROM oceanbase.DBA_OB_TENANTS WHERE tenant_id = $restore_mysql_tenant_id;

--error 4179
eval ALTER SYSTEM SWITCHOVER TO PRIMARY TENANT $restore_mysql_tenant VERIFY;
eval SELECT tenant_role, status, switchover_status FROM oceanbase.DBA_OB_TENANTS WHERE tenant_id = $restore_mysql_tenant_id;
ob1.mysql alter system set_tp tp_name = CHECK_SERVER_EMPTY_WHEN_LS_HAS_NO_LEADER, error_code = 4016, frequency = 0;


#################################################################################################
#########################   switch to primary失败 租户有日志流副本在永久下线的机器上   ################
#################################################################################################
--echo switch to primary失败 租户有日志流副本在永久下线的机器上
--echo 测试 member_list
--error 4179
eval ALTER SYSTEM ACTIVATE STANDBY TENANT $restore_mysql_tenant VERIFY;

--error 4179
eval ALTER SYSTEM SWITCHOVER TO PRIMARY TENANT $restore_mysql_tenant VERIFY;
ob1.mysql set ob_global_debug_sync = 'now signal continue_signal';
ob1.mysql set ob_global_debug_sync = 'BEFORE_SEND_DRTASK_RPC clear';

# wait clear meta table
ob1.check_until_timeout select count(*) from __all_virtual_ls_meta_table where tenant_id=$restore_mysql_tenant_id and svr_ip='$obs3_ip' and svr_port=$obs3_port, 0,120;
ob1.check_until_timeout select count(*) from __all_virtual_ls_meta_table where tenant_id=$restore_mysql_tenant_id and role=1 and member_list like '%$obs3_ip:$obs3_port%',0,120;
ob1.mysql ALTER SYSTEM ACTIVATE STANDBY TENANT $restore_mysql_tenant VERIFY;
eval SELECT tenant_role, status, switchover_status FROM oceanbase.DBA_OB_TENANTS WHERE tenant_id = $restore_mysql_tenant_id;
ob1.mysql ALTER SYSTEM SWITCHOVER TO PRIMARY TENANT $restore_mysql_tenant VERIFY;
eval SELECT tenant_role, status, switchover_status FROM oceanbase.DBA_OB_TENANTS WHERE tenant_id = $restore_mysql_tenant_id;

--echo 测试 learner_list
ob1.z3.obs0.start;
ob1.check_until_timeout select count(*) from __all_server where svr_ip='$obs3_ip' and svr_port=$obs3_port and status='ACTIVE',1,120;
alter tenant restore_mysql_tenant locality="F@z1,F@z2,R@z3";
ob1.check_until_timeout select count(*) from DBA_OB_TENANT_JOBS where job_type = 'ALTER_TENANT_LOCALITY' and job_status = 'INPROGRESS',1,60;
let $job_id = deploy_get_value(ob1.select select job_id from DBA_OB_TENANT_JOBS where job_type = 'ALTER_TENANT_LOCALITY' and job_status = 'INPROGRESS', job_id, 1);
ob1.check_until_timeout select count(*) from DBA_OB_TENANT_JOBS where job_id = $job_id and job_status = 'SUCCESS',1,180;
ob1.mysql set ob_global_debug_sync = 'BEFORE_SEND_DRTASK_RPC wait_for continue_signal';
ob1.z3.obs0.force_stop;
ob1.check_until_timeout select count(*) from __all_server where svr_ip='$obs3_ip' and svr_port=$obs3_port and status='INACTIVE',1,20;
sleep 13;
ob1.check_until_timeout select count(*) from __all_virtual_ls_meta_table where tenant_id=$restore_mysql_tenant_id and svr_ip='$obs3_ip' and svr_port=$obs3_port, 2,5;
ob1.check_until_timeout select count(*) from __all_virtual_ls_meta_table where tenant_id=$restore_mysql_tenant_id and role=1 and learner_list like '%$obs3_ip:$obs3_port%',2,5;
--error 4179
eval ALTER SYSTEM ACTIVATE STANDBY TENANT $restore_mysql_tenant VERIFY;

--error 4179
eval ALTER SYSTEM SWITCHOVER TO PRIMARY TENANT $restore_mysql_tenant VERIFY;
ob1.mysql set ob_global_debug_sync = 'now signal continue_signal';
ob1.mysql set ob_global_debug_sync = 'BEFORE_SEND_DRTASK_RPC clear';
ob1.check_until_timeout select count(*) from __all_virtual_ls_meta_table where tenant_id=$restore_mysql_tenant_id and svr_ip='$obs3_ip' and svr_port=$obs3_port, 0,120;
ob1.check_until_timeout select count(*) from __all_virtual_ls_meta_table where tenant_id=$restore_mysql_tenant_id and role=1 and learner_list like '%$obs3_ip:$obs3_port%',0,120;
#################################################################################################
#########################   switch to primary失败 日志不同步  #####################################
#################################################################################################
--echo switch to primary失败 日志不同步
ob1.mysql alter system set_tp tp_name = ERRSIM_GET_SYS_LS_SYNC_SCN_ERROR, error_code = 4012, frequency = 1;
--error 4179
eval ALTER SYSTEM SWITCHOVER TO PRIMARY TENANT $restore_mysql_tenant VERIFY;
--error 4179
eval ALTER SYSTEM SWITCHOVER TO PRIMARY TENANT $restore_mysql_tenant;
ob1.mysql alter system set_tp tp_name = ERRSIM_GET_SYS_LS_SYNC_SCN_ERROR, error_code = 4012, frequency = 0;
eval SELECT tenant_role, status, switchover_status FROM oceanbase.DBA_OB_TENANTS WHERE tenant_id = $restore_mysql_tenant_id;

#################################################################################################
#########################   switch to primary失败 recovery_until_scn无效   #######################
#################################################################################################
--echo switch to primary失败 recovery_until_scn无效
let $tenant_recovery_until_scn = deploy_get_value(ob1.select select recovery_until_scn from oceanbase.__all_virtual_tenant_info WHERE tenant_id = 1006, recovery_until_scn, 1);
eval alter system change tenant tenant_id = $restore_mysql_meta_tenant_id;
eval UPDATE oceanbase.__all_tenant_info SET recovery_until_scn = 0 where tenant_id=$restore_mysql_tenant_id;
alter system change tenant tenant_id = 1;
eval SELECT recovery_until_scn FROM oceanbase.__all_virtual_tenant_info WHERE tenant_id = $restore_mysql_tenant_id;
--error 1210
eval ALTER SYSTEM ACTIVATE STANDBY TENANT $restore_mysql_tenant VERIFY;

--error 1210
eval ALTER SYSTEM SWITCHOVER TO PRIMARY TENANT $restore_mysql_tenant VERIFY;
eval alter system change tenant tenant_id = $restore_mysql_meta_tenant_id;
eval UPDATE oceanbase.__all_tenant_info SET recovery_until_scn = $tenant_recovery_until_scn where tenant_id=$restore_mysql_tenant_id;
alter system change tenant tenant_id = 1;
ob1.mysql ALTER SYSTEM ACTIVATE STANDBY TENANT $restore_mysql_tenant VERIFY;
eval SELECT tenant_role, status, switchover_status FROM oceanbase.DBA_OB_TENANTS WHERE tenant_id = $restore_mysql_tenant_id;
ob1.mysql ALTER SYSTEM SWITCHOVER TO PRIMARY TENANT $restore_mysql_tenant VERIFY;
eval SELECT tenant_role, status, switchover_status FROM oceanbase.DBA_OB_TENANTS WHERE tenant_id = $restore_mysql_tenant_id;
#################################################################################################
#########################   switch to primary失败 switchover_status无效   #######################
#################################################################################################
--echo switch to primary失败 switchover_status无效
eval alter system change tenant tenant_id = $restore_mysql_meta_tenant_id;
eval UPDATE oceanbase.__all_tenant_info SET switchover_status = 'PREPARE SWITCHING TO STANDBY' where tenant_id=$restore_mysql_tenant_id;
alter system change tenant tenant_id = 1;
eval SELECT tenant_role, status, switchover_status FROM oceanbase.DBA_OB_TENANTS WHERE tenant_id = $restore_mysql_tenant_id;
--error 4179
eval ALTER SYSTEM ACTIVATE STANDBY TENANT $restore_mysql_tenant VERIFY;
eval SELECT tenant_role, status, switchover_status FROM oceanbase.DBA_OB_TENANTS WHERE tenant_id = $restore_mysql_tenant_id;

--error 4179
eval ALTER SYSTEM SWITCHOVER TO PRIMARY TENANT $restore_mysql_tenant VERIFY;
eval SELECT tenant_role, status, switchover_status FROM oceanbase.DBA_OB_TENANTS WHERE tenant_id = $restore_mysql_tenant_id;

eval alter system change tenant tenant_id = $restore_mysql_meta_tenant_id;
eval UPDATE oceanbase.__all_tenant_info SET switchover_status = 'SWITCHING TO STANDBY' where tenant_id=$restore_mysql_tenant_id;
alter system change tenant tenant_id = 1;
eval SELECT tenant_role, status, switchover_status FROM oceanbase.DBA_OB_TENANTS WHERE tenant_id = $restore_mysql_tenant_id;
--error 4179
eval ALTER SYSTEM ACTIVATE STANDBY TENANT $restore_mysql_tenant VERIFY;
eval SELECT tenant_role, status, switchover_status FROM oceanbase.DBA_OB_TENANTS WHERE tenant_id = $restore_mysql_tenant_id;

--error 4179
eval ALTER SYSTEM SWITCHOVER TO PRIMARY TENANT $restore_mysql_tenant VERIFY;
eval SELECT tenant_role, status, switchover_status FROM oceanbase.DBA_OB_TENANTS WHERE tenant_id = $restore_mysql_tenant_id;

eval alter system change tenant tenant_id = $restore_mysql_meta_tenant_id;
eval UPDATE oceanbase.__all_tenant_info SET switchover_status = 'NORMAL' where tenant_id=$restore_mysql_tenant_id;
alter system change tenant tenant_id = 1;
eval SELECT tenant_role, status, switchover_status FROM oceanbase.DBA_OB_TENANTS WHERE tenant_id = $restore_mysql_tenant_id;
ob1.mysql ALTER SYSTEM ACTIVATE STANDBY TENANT $restore_mysql_tenant VERIFY;
eval SELECT tenant_role, status, switchover_status FROM oceanbase.DBA_OB_TENANTS WHERE tenant_id = $restore_mysql_tenant_id;
ob1.mysql ALTER SYSTEM SWITCHOVER TO PRIMARY TENANT $restore_mysql_tenant VERIFY;
eval SELECT tenant_role, status, switchover_status FROM oceanbase.DBA_OB_TENANTS WHERE tenant_id = $restore_mysql_tenant_id;