# CASE_OWNER:
#    @jinqian.zzy
# CASE_DESC:
#    This case is aimed to test unit status in migrate and add task
#    We designed following cases to simulate different scenes:
#    1. migrate and add replica to the migration source unit is not allowed
#    2. allowed modify replica in migration source unit
#######################################################################
#                        create inital objects
#######################################################################

ob1=OBI(cluster=2:2:3,proxy_num=0,init_unit_cpu=0);
source include/mini_ob_config.inc;
ob1.set extra_config=$mini_ob_config;
ob1.z3.obs2.set status=disable;
ob1.reboot;

ob1.mysql alter system set debug_sync_timeout = '1000s';
ob1.mysql ALTER SYSTEM SET enable_rebalance = 'false';
ob1.mysql ALTER SYSTEM SET enable_rereplication = 'false';

let $proxy_ip = deploy_get_value(ob1.z1.obs0.ip);
let $proxy_port = deploy_get_value(ob1.z1.obs0.mysql_port);
connect(sys_conn, $proxy_ip, root@sys,,oceanbase, $proxy_port);

# create new tenant tenant_for_migrate_locality
source include/create_unit_config.inc;
ob1.mysql CREATE RESOURCE POOL tenant_pool UNIT = "2c2g", UNIT_NUM = 2, ZONE_LIST = ('z1', 'z2', 'z3');
ob1.mysql CREATE TENANT tenant_for_migrate_locality RESOURCE_POOL_LIST=('tenant_pool'), LOCALITY = "F@z1, F@z2", PRIMARY_ZONE = "z1" SET ob_tcp_invited_nodes='%';

let $tenant_id = deploy_get_value(ob1.select SELECT tenant_id FROM oceanbase.DBA_OB_TENANTS WHERE tenant_name = "tenant_for_migrate_locality", tenant_id, 1);
let $meta_tenant_id = deploy_get_value(ob1.select select tenant_id - 1 as meta_tenant_id from oceanbase.DBA_OB_TENANTS where tenant_name = "tenant_for_migrate_locality", meta_tenant_id, 1);
let $resource_pool_id = deploy_get_value(ob1.select SELECT resource_pool_id FROM oceanbase.__all_resource_pool WHERE tenant_id = $tenant_id, resource_pool_id, 1);

# get servers' addr in z1, z2 and z3
let $z1_dst_ip0 = deploy_get_value(ob1.z1.obs0.ip);
let $z1_dst_port0 = deploy_get_value(ob1.z1.obs0.port);
let $z1_dst0 = $z1_dst_ip0:$z1_dst_port0;

let $z1_dst_ip1 = deploy_get_value(ob1.z1.obs1.ip);
let $z1_dst_port1 = deploy_get_value(ob1.z1.obs1.port);
let $z1_dst1 = $z1_dst_ip1:$z1_dst_port1;

let $z2_dst_ip0 = deploy_get_value(ob1.z2.obs0.ip);
let $z2_dst_port0 = deploy_get_value(ob1.z2.obs0.port);
let $z2_dst0 = $z2_dst_ip0:$z2_dst_port0;

let $z2_dst_ip1 = deploy_get_value(ob1.z2.obs1.ip);
let $z2_dst_port1 = deploy_get_value(ob1.z2.obs1.port);
let $z2_dst1 = $z2_dst_ip1:$z2_dst_port1;

let $z3_dst_ip0 = deploy_get_value(ob1.z3.obs0.ip);
let $z3_dst_ip1 = deploy_get_value(ob1.z3.obs1.ip);
let $z3_dst_port0 = deploy_get_value(ob1.z3.obs0.port);
let $z3_dst_port1 = deploy_get_value(ob1.z3.obs1.port);
let $z3_dst0 = $z3_dst_ip0:$z3_dst_port0;
let $z3_dst1 = $z3_dst_ip1:$z3_dst_port1;

# get tenant_for_migrate_locality's unit info in z3
let $unit_id = deploy_get_value(ob1.select SELECT unit_id FROM oceanbase.DBA_OB_UNITS WHERE resource_pool_id = $resource_pool_id AND zone = 'z3' AND svr_ip = '$z3_dst_ip0' AND svr_port = $z3_dst_port0, unit_id, 1);

connection sys_conn;

ob1.z3.obs2.set extra_config=$extra_conf;
ob1.z3.obs2.set status=enable;
ob1.z3.obs2.start;
ob1.z3.obs2.check_log_until_success -c "weak read service thread start";
ob1.z3.obs2.add;
ob1.check_until_timeout SELECT COUNT(*) c FROM DBA_OB_SERVERS WHERE START_SERVICE_TIME > 0, 7, 200;

let $z3_dst_ip2 = deploy_get_value(ob1.z3.obs2.ip);
let $z3_dst_port2 = deploy_get_value(ob1.z3.obs2.port);
let $z3_dst2 = $z3_dst_ip2:$z3_dst_port2;

--echo "prepare finished"
let $tenant_ls_id = deploy_get_value(ob1.select SELECT ls_id as ls_id_tmp FROM oceanbase.CDB_OB_LS_LOCATIONS WHERE svr_ip = '$z1_dst_ip0' AND svr_port = $z1_dst_port0 AND ls_id > 1, ls_id_tmp, 1);
let $tenant_ls_id2 = deploy_get_value(ob1.select SELECT ls_id as ls_id_tmp FROM oceanbase.CDB_OB_LS_LOCATIONS WHERE svr_ip = '$z1_dst_ip1' AND svr_port = $z1_dst_port1 AND ls_id > 1, ls_id_tmp, 1);

--disable_query_log
eval ALTER SYSTEM MIGRATE UNIT $unit_id DESTINATION "$z3_dst2";
sleep 3;
--error 4018
eval alter system add replica ls = $tenant_ls_id server = '$z3_dst0' replica_type = 'R' tenant = 'tenant_for_migrate_locality';
eval alter system add replica ls = $tenant_ls_id server = '$z3_dst2' replica_type = 'R' tenant = 'tenant_for_migrate_locality';
sleep 3;
ob1.check_until_timeout SELECT COUNT(*) = 1 FROM oceanbase.CDB_OB_LS_LOCATIONS WHERE tenant_id = $tenant_id AND ls_id = $tenant_ls_id AND role = "LEADER" AND learner_list LIKE '%$z3_dst2%', 1, 60;
sleep 3;

eval alter system add replica ls = $tenant_ls_id2 server = '$z3_dst1' replica_type = 'R' tenant = 'tenant_for_migrate_locality';
sleep 3;
ob1.check_until_timeout SELECT COUNT(*) = 1 FROM oceanbase.CDB_OB_LS_LOCATIONS WHERE tenant_id = $tenant_id AND ls_id = $tenant_ls_id2 AND role = "LEADER" AND learner_list LIKE '%$z3_dst1%', 1, 60;
sleep 3;

--error 4018
eval alter system migrate replica ls = $tenant_ls_id2 source = '$z3_dst1' destination = '$z3_dst0' tenant = 'tenant_for_migrate_locality';
eval alter system migrate replica ls = $tenant_ls_id2 source = '$z3_dst1' destination = '$z3_dst2' tenant = 'tenant_for_migrate_locality';
sleep 3;
ob1.check_until_timeout select count(*) from __all_virtual_ls_meta_table where ls_id = $tenant_ls_id2, 3, 60;
ob1.check_until_timeout SELECT COUNT(*) = 1 FROM oceanbase.CDB_OB_LS_LOCATIONS WHERE tenant_id = $tenant_id AND ls_id = $tenant_ls_id2 AND role = "LEADER" AND member_list NOT LIKE '%$z3_dst1%' AND learner_list LIKE '%$z3_dst2%', 1, 20;
