ob1=OBI(cluster=1:1:1,proxy_num=0);
ob1.reboot;

ob1.mysql CREATE RESOURCE UNIT 2c4g MAX_CPU 2, MEMORY_SIZE '4G', LOG_DISK_SIZE='2G';
ob1.mysql CREATE RESOURCE POOL pool1 UNIT='2c4g',UNIT_NUM=1,ZONE_LIST=('z1','z2','z3');
ob1.mysql CREATE RESOURCE POOL large_pool_1 UNIT='2c4g',UNIT_NUM=1,ZONE_LIST=('z1','z2','z3');

ob1.mysql CREATE TENANT IF NOT EXISTS test_tenant ZONE_LIST=('z1','z2','z3'), RESOURCE_POOL_LIST=('pool1'), primary_zone = "z1" set ob_tcp_invited_nodes='%', ob_compatibility_mode='mysql';
ob1.mysql alter system set_tp tp_name = ERRSIM_WEAK_READ_INNER_TABLE, error_code = 4012, frequency = 1;

let $test_tenant_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name='test_tenant', tenant_id, 1);
# get primary tenant access point
let $server_ip_port_1=deploy_get_value(ob1.select select concat(svr_ip,':',sql_port) as host from CDB_OB_LS_LOCATIONS where tenant_id = $test_tenant_id and ls_id = 1 and role = 'LEADER' order by svr_ip, sql_port limit 1, host, 1);
let $server_ip_port_2=deploy_get_value(ob1.select select concat(svr_ip,':',sql_port) as host from CDB_OB_LS_LOCATIONS where tenant_id = $test_tenant_id and ls_id = 1 and role = 'FOLLOWER' order by svr_ip, sql_port limit 1, host, 1);
let $server_ip_port_3=deploy_get_value(ob1.select select concat(svr_ip,':',sql_port) as host from CDB_OB_LS_LOCATIONS where tenant_id = $test_tenant_id and ls_id = 1 and role = 'FOLLOWER' and concat(svr_ip,':',sql_port) not like "%$server_ip_port_2%" limit 1, host, 1);

# create log restore source user
ob_connect(primary_tenant_conn, ob1.z1.obs0,root@test_tenant,,test,,USE_MYSQL_CONNECTOR);
connection primary_tenant_conn;
create user mytest identified by "test";
GRANT SELECT on OCEANBASE.DBA_OB_ACCESS_POINT to mytest;
GRANT SELECT on OCEANBASE.GV$OB_UNITS to mytest;
GRANT SELECT on OCEANBASE.DBA_OB_TENANTS to mytest;
GRANT SELECT on OCEANBASE.GV$OB_PARAMETERS to mytest;
GRANT SELECT on OCEANBASE.GV$OB_LOG_STAT to mytest;
GRANT SELECT on OCEANBASE.DBA_OB_LS to mytest;

ob_connect(primary_tenant_conn, ob1.z1.obs0,root@test_tenant,,test,,USE_MYSQL_CONNECTOR);
connection primary_tenant_conn;
create table t1(a int, b int, c int);
insert into t1(a, b) values(1, 1);

ob1.mysql CREATE STANDBY TENANT IF NOT EXISTS standby_mysql_tenant LOG_RESTORE_SOURCE = 'service=$server_ip_port_1;$server_ip_port_2;$server_ip_port_3 USER=mytest@test_tenant PASSWORD=test' PRIMARY_ZONE='z1', RESOURCE_POOL_LIST=('large_pool_1'),locality='F@z1,F@z2,F@z3', comment='aaaaaaaa';
let $standby_mysql_tenant_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name='standby_mysql_tenant', tenant_id, 1);

let $check_scn=deploy_get_value(ob1.select select end_scn from __all_virtual_log_stat where tenant_id = $test_tenant_id and ls_id = 1001 and role = 'LEADER', end_scn, 1);
let $schema_version = deploy_get_value(ob1.select select max(schema_version) as s from oceanbase.__all_virtual_ddl_operation where tenant_id = $test_tenant_id, s, 1);
ob1.check_until_timeout SELECT count(*) FROM dba_ob_tenants WHERE TENANT_NAME = 'standby_mysql_tenant' and READABLE_SCN >= $check_scn, 1, 50;

let $p_received_schema_v=deploy_get_value(ob1.select select received_schema_version from __all_virtual_server_schema_info where tenant_id = $test_tenant_id order by received_schema_version desc limit 1, received_schema_version, 1);
ob1.check_until_timeout SELECT count(*) FROM __all_virtual_server_schema_info where tenant_id= $standby_mysql_tenant_id and refreshed_schema_version < $p_received_schema_v, 0,120;

ob_connect(standby_tenant_conn, ob1.z1.obs0,root@standby_mysql_tenant,,test,,USE_MYSQL_CONNECTOR);
connection standby_tenant_conn;
select * from t1;
# 1 1

ob1.mysql ALTER SYSTEM SWITCHOVER TO STANDBY TENANT test_tenant;
ob1.mysql ALTER SYSTEM SWITCHOVER TO PRIMARY TENANT standby_mysql_tenant;

ob_connect(standby_tenant_conn, ob1.z1.obs0,root@standby_mysql_tenant,,test,,USE_MYSQL_CONNECTOR);
connection standby_tenant_conn;
select * from t1;
# 1   1
insert into t1(a, b) values(3, 3);

ob_connect(conn_sys_ob1, ob1.z1.obs0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);
let $standby_mysql_tenant_id = query_get_value(select tenant_id from oceanbase.__all_tenant where tenant_name='standby_mysql_tenant', tenant_id, 1);

let $server_ip_port_1=deploy_get_value(ob1.select select concat(svr_ip,':',sql_port) as host from CDB_OB_LS_LOCATIONS where tenant_id = $standby_mysql_tenant_id and ls_id = 1 and role = 'LEADER' order by svr_ip, sql_port limit 1;, host, 1);
let $server_ip_port_2=deploy_get_value(ob1.select select concat(svr_ip,':',sql_port) as host from CDB_OB_LS_LOCATIONS where tenant_id = $standby_mysql_tenant_id and ls_id = 1 and role = 'FOLLOWER' order by svr_ip, sql_port limit 1, host, 1);
let $server_ip_port_3=deploy_get_value(ob1.select select concat(svr_ip,':',sql_port) as host from CDB_OB_LS_LOCATIONS where tenant_id = $standby_mysql_tenant_id and ls_id = 1 and role = 'FOLLOWER' and concat(svr_ip,':',sql_port) not like "%$server_ip_port_2%" limit 1, host, 1);

# 如果switchover epoch变了，但是plan cache不被淘汰，这里会因为我们加上了ERRSIM导致读__all_core_table失败，原因是备切主之后复用了之前备租户的弱读计划
--disable_all_result_log
eval alter system set LOG_RESTORE_SOURCE = 'service=$server_ip_port_1;$server_ip_port_2;$server_ip_port_3 USER=mytest@standby_mysql_tenant PASSWORD=test' tenant = 'test_tenant';
--enable_all_result_log

ob1.mysql ALTER SYSTEM SWITCHOVER TO STANDBY TENANT standby_mysql_tenant;
ob1.mysql ALTER SYSTEM SWITCHOVER TO PRIMARY TENANT test_tenant;

let $proxy_ip = deploy_get_value(ob1.z1.obs0.ip);
let $proxy_port = deploy_get_value(ob1.z1.obs0.mysql_port);
ob_connect(conn_mysql, ob1.z1.obs0, root@test_tenant, , test, , USE_MYSQL_CONNECTOR);
use test;

# 创建 Customers 表
CREATE TABLE Customers (
    customer_id INT PRIMARY KEY,
    first_name VARCHAR(50),
    last_name VARCHAR(50),
    email VARCHAR(100),
    phone_number VARCHAR(20)
);

# 插入 Customers 数据
INSERT INTO Customers (customer_id, first_name, last_name, email, phone_number) VALUES
(1, 'John', 'Doe', 'john.doe@example.com', '123-456-7890'),
(2, 'Jane', 'Smith', 'jane.smith@example.com', '234-567-8901'),
(3, 'Michael', 'Johnson', 'michael.johnson@example.com', '345-678-9012'),
(4, 'Emily', 'Davis', 'emily.davis@example.com', '456-789-0123'),
(5, 'William', 'Brown', 'william.brown@example.com', '567-890-1234');

# 清空plan cache缓存
alter system flush plan cache global;
sleep 5;

select count(*) as cnt from Customers;

let $primary_plan_id = deploy_get_value(ob1.select select plan_id from oceanbase.GV\$OB_PLAN_CACHE_PLAN_STAT where STATEMENT like "%as cnt from Customers%" limit 1, plan_id, 1);
--disable_query_log
eval select count(*) from oceanbase.GV\$OB_PLAN_CACHE_PLAN_STAT where STATEMENT like "%as cnt from Customers%" and plan_id=$primary_plan_id;
--enable_query_log

select count(*) as cnt from Customers;
--disable_query_log
eval select count(*) from oceanbase.GV\$OB_PLAN_CACHE_PLAN_STAT where STATEMENT like "%as cnt from Customers%" and plan_id=$primary_plan_id;
--enable_query_log

ALTER SYSTEM SWITCHOVER TO STANDBY;

select TENANT_ID, TENANT_ROLE, STATUS, SWITCHOVER_STATUS from oceanbase.DBA_OB_TENANTS;

select count(*) as cnt from Customers;

let $standby_plan_id = deploy_get_value(ob1.select select plan_id from oceanbase.GV\$OB_PLAN_CACHE_PLAN_STAT where STATEMENT like "%as cnt from Customers%" limit 1, plan_id, 1);
--disable_query_log
eval select count(*) from oceanbase.GV\$OB_PLAN_CACHE_PLAN_STAT where STATEMENT like "%as cnt from Customers%" and plan_id=$primary_plan_id;
eval select count(*) from oceanbase.GV\$OB_PLAN_CACHE_PLAN_STAT where STATEMENT like "%as cnt from Customers%" and plan_id=$standby_plan_id;
--enable_query_log

select count(*) as cnt from Customers;

--disable_query_log
eval select count(*) from oceanbase.GV\$OB_PLAN_CACHE_PLAN_STAT where STATEMENT like "%as cnt from Customers%" and plan_id=$standby_plan_id;
--enable_query_log

ALTER SYSTEM SWITCHOVER TO PRIMARY;
select count(*) as cnt from Customers;

let $primary_plan_id = deploy_get_value(ob1.select select plan_id from oceanbase.GV\$OB_PLAN_CACHE_PLAN_STAT where STATEMENT like "%as cnt from Customers%" limit 1, plan_id, 1);
--disable_query_log
eval select count(*) from oceanbase.GV\$OB_PLAN_CACHE_PLAN_STAT where STATEMENT like "%as cnt from Customers%" and plan_id=$primary_plan_id;
eval select count(*) from oceanbase.GV\$OB_PLAN_CACHE_PLAN_STAT where STATEMENT like "%as cnt from Customers%" and plan_id=$standby_plan_id;
--enable_query_log
