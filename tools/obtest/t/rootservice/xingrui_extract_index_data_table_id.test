# CASE_OWNER:
#    @xingrui.cwh
# CASE_DESC:
#    get index's data table id with illegal index_name will raise core
 
ob1=OBI(cluster=1:1,proxy_num=0);
source include/mini_ob_config.inc;
ob1.set extra_config=$mini_ob_config;
ob1.reboot;
 
ob_connect(conn_sys, ob1.z1.obs0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);
connection conn_sys;
ob1.mysql alter system set debug_sync_timeout = '1000000s';
set @@session.ob_query_timeout = 1000000000;
#create tenant
eval CREATE RESOURCE UNIT xingrui_extract_unit MAX_CPU 2, MEMORY_SIZE '4G';
eval CREATE RESOURCE POOL xingrui_extract_pool UNIT = 'xingrui_extract_unit', UNIT_NUM = 1;
#only oracle tenant will run this
eval CREATE TENANT xingrui_extract_tenant RESOURCE_POOL_LIST = ('xingrui_extract_pool'), primary_zone='z1,z2' set ob_tcp_invited_nodes='%', ob_compatibility_mode='oracle';
 
ob1.mysql alter system set_tp tp_name = ERRSIM_EXTRACT_DATA_TABLE_ID, error_code = 4002, frequency = 1;
ob1.mysql alter system set_tp tp_name = ERRSIM_INVALID_INDEX_NAME, error_code = 4002, frequency = 1;
ob_connect(conn_oracle, ob1.z1.obs0, SYS@xingrui_extract_tenant, ,SYS, , USE_OB_CONNECTOR);

connection conn_oracle;
create table xingrui_extract_index(col1 int);
--error 600
create index xingrui_idx on xingrui_extract_index(col1);

connection conn_sys;
ob1.mysql alter system set_tp tp_name = ERRSIM_EXTRACT_DATA_TABLE_ID, error_code = 4002, frequency = 0;
ob1.mysql alter system set_tp tp_name = ERRSIM_INVALID_INDEX_NAME, error_code = 4002, frequency = 0;