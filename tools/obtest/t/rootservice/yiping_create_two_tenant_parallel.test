ob1=OBI(cluster=1:1:1,proxy_num=0);
ob1.reboot;

let $ip = deploy_get_value(ob1.z1.obs0.ip);
let $port = deploy_get_value(ob1.z1.obs0.port);

ob1.mysql alter tenant sys set primary_zone='z1';
ob1.check_until_timeout select role from oceanbase.__all_ls_meta_table where tenant_id=1 and ls_id=1 and zone='z1', 1, 40;
ob1.check_until_timeout select count(*)>0 from oceanbase.__all_rootservice_event_history where event='full_rootservice' and value1=0 and value2 like '%$ip:$port%' order by 1 desc, 1, 10;

ob1.mysql create resource unit box max_cpu 2, memory_size='4G';
ob1.mysql create resource pool pool1 unit = 'box', unit_num = 1;
ob1.mysql create resource pool pool2 unit = 'box', unit_num = 1;

ob1.mysql alter system set debug_sync_timeout = '100000s';
ob1.mysql set ob_global_debug_sync = 'BEFORE_CREATE_TENANT_TABLE_SCHEMA wait_for sig1 execute 10000';

ob_connect(conn_sys1, ob1.z1.obs0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);
connection conn_sys1;
send create tenant mysql1 resource_pool_list('pool1');

ob1.z1.obs0.check_rs_log_until_success -c 'STEP 2.5. start init tenant schemas.*tenant_id.1001';
ob1.z1.obs0.check_rs_log_until_success -c 'STEP 2.5. start init tenant schemas.*tenant_id.1002';

ob_connect(conn_sys2, ob1.z1.obs0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);
connection conn_sys2;
send create tenant mysql2 resource_pool_list('pool2');

ob1.z1.obs0.check_rs_log_until_success -c 'STEP 2.5. start init tenant schemas.*tenant_id.1003';
ob1.z1.obs0.check_rs_log_until_success -c 'STEP 2.5. start init tenant schemas.*tenant_id.1004';

ob1.mysql set ob_global_debug_sync = 'BEFORE_CREATE_TENANT_TABLE_SCHEMA clear';
ob1.mysql set ob_global_debug_sync = 'now broadcast sig1';

connection conn_sys1;
reap;

connection conn_sys2;
reap;
