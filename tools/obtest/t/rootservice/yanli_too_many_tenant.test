# CASE_OWNER:
#    @msy164651
# CASE_DESC:
#

ob1=OBI(cluster=3,proxy_num=0);

let $extra_conf = "cpu_count=32,memory_limit='50G',system_memory='5G',__min_full_resource_pool_memory='1073741824',cache_wash_threshold='1G',enable_async_syslog=false,_private_buffer_size='16K',_fast_commit_callback_count='1',log_disk_size='50G'";
ob1.z1.obs0.set extra_config=$extra_conf;
ob1.z1.obs1.set extra_config=$extra_conf;
ob1.z1.obs2.set extra_config=$extra_conf;

ob1.reboot;
ob1.mysql CREATE RESOURCE UNIT unit_for_test MAX_CPU 1, MEMORY_SIZE '2G';
ob1.mysql alter resource unit sys_unit_config min_cpu 1, max_cpu 1, memory_size '2G';

#20mysql tenant
let $i = 1;
let $count = 10;
while ($i < $count)
{
  ob1.mysql CREATE RESOURCE POOL pool_$i UNIT = 'unit_for_test', UNIT_NUM = 1;
  ob1.mysql CREATE TENANT mysql_$i RESOURCE_POOL_LIST = ('pool_$i'), primary_zone='z1' set ob_tcp_invited_nodes='%';
  source include/check_schema_sync.inc;
  inc $i;
}

#20 oracle tenant
let $i = 1;
while ($i < $count)
{
  ob1.mysql CREATE RESOURCE POOL pool_2_$i UNIT = 'unit_for_test', UNIT_NUM = 1;
  ob1.mysql CREATE TENANT oracle_$i RESOURCE_POOL_LIST = ('pool_2_$i'), primary_zone='z1' set ob_tcp_invited_nodes='%', ob_compatibility_mode = 'oracle';
  source include/check_schema_sync.inc;
  inc $i;
}
#drop tenant
let $i = 8;
while ($i < $count)
{
ob1.mysql drop tenant oracle_$i force;
ob1.mysql drop tenant mysql_$i force;
source include/check_schema_sync.inc;
inc $i;
}
#底层unit删除太过耗时，暂时只删除10个租户
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_unit where tenant_id != 1, 28, 600;
