# CASE_OWNER:
#    @jingyu.cr
# CASE_DESC:
#    将一个OB集群(z1,z2,z3)彻底搬迁到z4,z5,z6
#    部署：
#    6台observer，每台server一个zone：z1~z6
#    起初启动三个zone: z1, z2, z3; 系统租户的locality初始为F@z1,F@z2,F@z3;
#    而后将z1,z2,z3依次搬迁至z4,z5,z6

ob1=OBI(cluster=1:1:1:1:1:1,proxy_num=0,init_unit_cpu=0,locality=HZ:HZ:HZ:SH:SH:SH);

# disable 3 servers
ob1.z4.obs0.set status=disable;
ob1.z5.obs0.set status=disable;
ob1.z6.obs0.set status=disable;

ob1.reboot;

ob1.z4.add;
ob1.z4.start_zone;
ob1.z4.obs0.set status=enable;
ob1.z4.obs0.start;

ob1.z5.add;
ob1.z5.start_zone;
ob1.z5.obs0.set status=enable;
ob1.z5.obs0.start;

ob1.z6.add;
ob1.z6.start_zone;
ob1.z6.obs0.set status=enable;
ob1.z6.obs0.start;
ob1.z4.obs0.add;
ob1.z5.obs0.add;
sleep 30;
ob1.z6.obs0.add;

ob1.mysql alter system set balancer_idle_time = '10s';

# 给系统租户加一个resource_pool sys_pool1
ob1.mysql create resource unit test_unit max_cpu = 1, memory_size = '2G';
ob1.mysql create resource pool sys_pool1 unit = 'test_unit', unit_num = 1, zone_list = ('z4');
ob1.mysql alter tenant sys resource_pool_list=('sys_pool', 'sys_pool1');
ob1.mysql alter tenant sys primary_zone = 'z3';
ob1.check_until_timeout select count(*) c from oceanbase.__all_virtual_core_meta_table where role =1 and zone ='z3', 1, 30;
sleep 20;

# 调整系统租户的locality，给系统租户在z4上添加一个全功能副本
ob1.mysql alter tenant sys locality = "F@z1,F@z2,F@z3,F@z4";
# 检查系统租户的locality变更是否完成
ob1.check_until_timeout select count(*) c from oceanbase.__all_tenant where tenant_id = 1 and previous_locality != '', 0, 600;
let $svr_port = deploy_get_value(ob1.select select svr_port from oceanbase.__all_server where zone = 'z4', svr_port, 1);
let $svr_ip = deploy_get_value(ob1.select select svr_ip from oceanbase.__all_server where zone = 'z4', svr_ip, 1);
# 校验all core table表加副本成功
ob1.check_until_timeout select count(*) c from oceanbase.__all_virtual_core_meta_table where role = 1 and member_list like '%$svr_ip:$svr_port%', 1, 360;

# 调整系统租户的locality，将系统租户在z1上的副本下掉
ob1.mysql alter tenant sys locality = "F@z2,F@z3,F@z4";
ob1.check_until_timeout select count(*) c from oceanbase.__all_tenant where tenant_id = 1 and previous_locality != '', 0, 600;
let $svr_port = deploy_get_value(ob1.select select svr_port from oceanbase.__all_server where zone = 'z1', svr_port, 1);
let $svr_ip = deploy_get_value(ob1.select select svr_ip from oceanbase.__all_server where zone = 'z1', svr_ip, 1);
# 校验all core table表减副本成功
ob1.check_until_timeout select count(*) c from oceanbase.__all_virtual_core_meta_table where role = 1 and member_list like '%$svr_ip:$svr_port%', 0, 360;

ob1.mysql alter resource pool sys_pool zone_list = ('z2', 'z3');

let $svr_port1 = deploy_get_value(ob1.select select svr_port from oceanbase.__all_server where zone = 'z1', svr_port, 1);
let $svr_ip1 = deploy_get_value(ob1.select select svr_ip from oceanbase.__all_server where zone = 'z1', svr_ip, 1);
ob1.mysql alter system delete server "$svr_ip1:$svr_port1";
ob1.check_until_timeout select count(*) c from oceanbase.__all_server where svr_ip = '$svr_ip1' and svr_port = $svr_port1, 0, 600;

let $ip = deploy_get_value(ob1.z4.obs0.ip);
let $port = deploy_get_value(ob1.z4.obs0.mysql_port);
connect(sys_conn, $ip, root@sys,,test, $port);

connection sys_conn;
set @saved_ob_query_timeout = @@session.ob_query_timeout;
set @@session.ob_query_timeout = 20000000;
alter system stop zone 'z1';
alter system delete zone 'z1';

# 给系统租户加一个resource_pool sys_pool2
ob1.mysql create resource pool sys_pool2 unit = 'test_unit', unit_num = 1, zone_list = ('z5');
ob1.mysql alter tenant sys resource_pool_list=('sys_pool', 'sys_pool1', 'sys_pool2');


# 调整系统租户的locality，给系统租户在z5上添加一个全功能副本
ob1.mysql alter tenant sys locality = "F@z2,F@z3,F@z4,F@z5";
# 检查系统租户的locality变更是否完成
ob1.check_until_timeout select count(*) c from oceanbase.__all_tenant where tenant_id = 1 and previous_locality != '', 0, 600;
let $svr_port = deploy_get_value(ob1.select select svr_port from oceanbase.__all_server where zone = 'z5', svr_port, 1);
let $svr_ip = deploy_get_value(ob1.select select svr_ip from oceanbase.__all_server where zone = 'z5', svr_ip, 1);
# 校验all core table表加副本成功
ob1.check_until_timeout select count(*) c from oceanbase.__all_virtual_core_meta_table where role = 1 and member_list like '%$svr_ip:$svr_port%', 1, 360;
# 调整系统租户的primary zone为z4
ob1.mysql alter tenant sys primary_zone = 'z4';

# 调整系统租户的locality，将系统租户在z2上的副本下掉
ob1.mysql alter tenant sys locality = "F@z3,F@z4,F@z5", primary_zone = "z4";
ob1.check_until_timeout select count(*) c from oceanbase.__all_tenant where tenant_id = 1 and previous_locality != '', 0, 600;
let $svr_port = deploy_get_value(ob1.select select svr_port from oceanbase.__all_server where zone = 'z2', svr_port, 1);
let $svr_ip = deploy_get_value(ob1.select select svr_ip from oceanbase.__all_server where zone = 'z2', svr_ip, 1);
# 校验all core table表减副本成功
ob1.check_until_timeout select count(*) c from oceanbase.__all_virtual_core_meta_table where role = 1 and member_list like '%$svr_ip:$svr_port%', 0, 360;
ob1.mysql alter resource pool sys_pool zone_list = ('z3');

let $svr_port1 = deploy_get_value(ob1.select select svr_port from oceanbase.__all_server where zone = 'z2', svr_port, 1);
let $svr_ip1 = deploy_get_value(ob1.select select svr_ip from oceanbase.__all_server where zone = 'z2', svr_ip, 1);
ob1.mysql alter system delete server "$svr_ip1:$svr_port1";
ob1.check_until_timeout select count(*) c from oceanbase.__all_server where svr_ip = '$svr_ip1' and svr_port = $svr_port1, 0, 600;

connection sys_conn;
set @saved_ob_query_timeout = @@session.ob_query_timeout;
set @@session.ob_query_timeout = 20000000;
alter system stop zone 'z2';
alter system delete zone 'z2';

# 给系统租户加一个resource_pool sys_pool3
ob1.mysql create resource pool sys_pool3 unit = 'test_unit', unit_num = 1, zone_list = ('z6');
ob1.mysql alter tenant sys resource_pool_list=('sys_pool', 'sys_pool1', 'sys_pool2', 'sys_pool3');


# 调整系统租户的locality，给系统租户在z5上添加一个全功能副本
ob1.mysql alter tenant sys locality = "F@z3,F@z4,F@z5,F@z6";
# 检查系统租户的locality变更是否完成
ob1.check_until_timeout select count(*) c from oceanbase.__all_tenant where tenant_id = 1 and previous_locality != '', 0, 600;
let $svr_port = deploy_get_value(ob1.select select svr_port from oceanbase.__all_server where zone = 'z6', svr_port, 1);
let $svr_ip = deploy_get_value(ob1.select select svr_ip from oceanbase.__all_server where zone = 'z6', svr_ip, 1);
# 校验all core table表加副本成功
ob1.check_until_timeout select count(*) c from oceanbase.__all_virtual_core_meta_table where role = 1 and member_list like '%$svr_ip:$svr_port%', 1, 360;
# 调整系统租户的locality，将系统租户在z3上的副本下掉
ob1.mysql alter tenant sys locality = "F@z4,F@z5,F@z6";
ob1.check_until_timeout select count(*) c from oceanbase.__all_tenant where tenant_id = 1 and previous_locality != '', 0, 600;
let $svr_port = deploy_get_value(ob1.select select svr_port from oceanbase.__all_server where zone = 'z3', svr_port, 1);
let $svr_ip = deploy_get_value(ob1.select select svr_ip from oceanbase.__all_server where zone = 'z3', svr_ip, 1);
# 校验all core table表减副本成功
ob1.check_until_timeout select count(*) c from oceanbase.__all_virtual_core_meta_table where role = 1 and member_list like '%$svr_ip:$svr_port%', 0, 360;
ob1.mysql alter tenant sys resource_pool_list=('sys_pool1','sys_pool2','sys_pool3');
ob1.mysql drop resource pool sys_pool;

let $svr_port1 = deploy_get_value(ob1.select select svr_port from oceanbase.__all_server where zone = 'z3', svr_port, 1);
let $svr_ip1 = deploy_get_value(ob1.select select svr_ip from oceanbase.__all_server where zone = 'z3', svr_ip, 1);
ob1.mysql alter system delete server "$svr_ip1:$svr_port1";
ob1.check_until_timeout select count(*) c from oceanbase.__all_server where svr_ip = '$svr_ip1' and svr_port = $svr_port1, 0, 600;

connection sys_conn;
set @saved_ob_query_timeout = @@session.ob_query_timeout;
set @@session.ob_query_timeout = 20000000;
alter system stop zone 'z3';
alter system delete zone 'z3';
#切主
let $leader_ip = deploy_get_value(ob1.select select svr_ip from oceanbase.__all_virtual_core_meta_table where role = 1, svr_ip, 1);
let $leader_port = deploy_get_value(ob1.select select svr_port from oceanbase.__all_virtual_core_meta_table where role = 1, svr_port, 1);
ob1.mysql alter system stop server '$leader_ip:$leader_port';
sleep 5;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_core_meta_table where role = 1,1, 30;
sleep 20;
connection sys_conn;
# 执行ddl操作，验证rs已经上任
create table tt (pk bigint primary key);
