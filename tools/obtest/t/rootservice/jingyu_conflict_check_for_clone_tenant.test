# CASE_OWNER:
#    @jingyu.cr
# CASE_DESC:
#    This case is aimed to test conflict check between clone and other cases
#    We designed following cases to simulate different scenes:
#
#######################################################################
#                        create inital objects
#######################################################################

ob1=OBI(cluster=2:3:3,proxy_num=0,init_unit_cpu=0);
source include/mini_ob_config.inc;
ob1.set extra_config=$mini_ob_config;
let $data_backup_dest = deploy_get_value(ob1.get_data_backup_dest mysql);
let $log_backup_dest = deploy_get_value(ob1.get_log_backup_dest mysql);

ob1.force_stop;
ob1.clean_backup_dest;
ob1.reboot;

# get servers' addr in z1, z2 and z3
let $z1_dst_ip0 = deploy_get_value(ob1.z1.obs0.ip);
let $z1_dst_port0 = deploy_get_value(ob1.z1.obs0.port);
let $z1_dst0 = $z1_dst_ip0:$z1_dst_port0;
let $z1_dst_ip1 = deploy_get_value(ob1.z1.obs1.ip);
let $z1_dst_port1 = deploy_get_value(ob1.z1.obs1.port);
let $z1_dst1 = $z1_dst_ip1:$z1_dst_port1;

let $z2_dst_ip0 = deploy_get_value(ob1.z2.obs0.ip);
let $z2_dst_ip1 = deploy_get_value(ob1.z2.obs1.ip);
let $z2_dst_ip2 = deploy_get_value(ob1.z2.obs2.ip);
let $z2_dst_port0 = deploy_get_value(ob1.z2.obs0.port);
let $z2_dst_port1 = deploy_get_value(ob1.z2.obs1.port);
let $z2_dst_port2 = deploy_get_value(ob1.z2.obs2.port);
let $z2_dst0 = $z2_dst_ip0:$z2_dst_port0;
let $z2_dst1 = $z2_dst_ip1:$z2_dst_port1;
let $z2_dst2 = $z2_dst_ip2:$z2_dst_port2;

let $z3_dst_ip0 = deploy_get_value(ob1.z3.obs0.ip);
let $z3_dst_ip1 = deploy_get_value(ob1.z3.obs1.ip);
let $z3_dst_ip2 = deploy_get_value(ob1.z3.obs2.ip);
let $z3_dst_port0 = deploy_get_value(ob1.z3.obs0.port);
let $z3_dst_port1 = deploy_get_value(ob1.z3.obs1.port);
let $z3_dst_port2 = deploy_get_value(ob1.z3.obs2.port);
let $z3_dst0 = $z3_dst_ip0:$z3_dst_port0;
let $z3_dst1 = $z3_dst_ip1:$z3_dst_port1;
let $z3_dst2 = $z3_dst_ip2:$z3_dst_port2;

ob1.mysql alter system set debug_sync_timeout = '1000s';
ob1.mysql ALTER SYSTEM SET enable_rebalance = 'false';
ob1.mysql ALTER SYSTEM SET enable_rereplication = 'true';

let $proxy_ip = deploy_get_value(ob1.z1.obs0.ip);
let $proxy_port = deploy_get_value(ob1.z1.obs0.mysql_port);
connect(sys_conn, $proxy_ip, root@sys,,oceanbase, $proxy_port);

let $proxy_ip_2 = deploy_get_value(ob1.z1.obs1.ip);
let $proxy_port_2 = deploy_get_value(ob1.z1.obs1.mysql_port);
connect(sys_conn_2, $proxy_ip_2, root@sys,,oceanbase, $proxy_port_2);

--echo =================================================================================
--echo                               create mysql tenant
--echo =================================================================================
connection sys_conn;
source include/create_unit_config.inc;
ob1.mysql CREATE RESOURCE POOL tenant_pool UNIT = "2c2g", UNIT_NUM = 1, ZONE_LIST = ('z1', 'z2', 'z3');
ob1.mysql CREATE TENANT mysql RESOURCE_POOL_LIST=('tenant_pool'), LOCALITY = "F@z1, F@z2, F@z3", PRIMARY_ZONE = "z1" SET ob_tcp_invited_nodes='%';

let $tenant_id = deploy_get_value(ob1.select SELECT tenant_id FROM oceanbase.DBA_OB_TENANTS WHERE tenant_name = "mysql", tenant_id, 1);
let $meta_tenant_id = deploy_get_value(ob1.select select tenant_id - 1 as meta_tenant_id from oceanbase.DBA_OB_TENANTS where tenant_name = "mysql", meta_tenant_id, 1);
let $resource_pool_id = deploy_get_value(ob1.select SELECT resource_pool_id FROM oceanbase.__all_resource_pool WHERE tenant_id = $tenant_id, resource_pool_id, 1);

# get mysql's unit info in z2
let $unit_id_in_zone2 = deploy_get_value(ob1.select SELECT unit_id FROM oceanbase.DBA_OB_UNITS WHERE resource_pool_id = $resource_pool_id AND zone = 'z2', unit_id, 1);
let $ip_zone2 = deploy_get_value(ob1.select SELECT svr_ip FROM oceanbase.DBA_OB_UNITS WHERE unit_id = $unit_id_in_zone2, svr_ip, 1);
let $port_zone2 = deploy_get_value(ob1.select SELECT svr_port FROM oceanbase.DBA_OB_UNITS WHERE unit_id = $unit_id_in_zone2, svr_port, 1);
let $z2_cur = $ip_zone2:$port_zone2;

# get mysql's unit info in z3
let $unit_id = deploy_get_value(ob1.select SELECT unit_id FROM oceanbase.DBA_OB_UNITS WHERE resource_pool_id = $resource_pool_id AND zone = 'z3', unit_id, 1);
let $ip = deploy_get_value(ob1.select SELECT svr_ip FROM oceanbase.DBA_OB_UNITS WHERE unit_id = $unit_id, svr_ip, 1);
let $port = deploy_get_value(ob1.select SELECT svr_port FROM oceanbase.DBA_OB_UNITS WHERE unit_id = $unit_id, svr_port, 1);
let $z3_cur = $ip:$port;

--echo =================================================================================
--echo                      enable archivelog for mysql tenant
--echo =================================================================================
let $mysql_leader_ip_port=deploy_get_value(ob1.select select concat(svr_ip,':',svr_port) as host from __all_virtual_ls_meta_table where tenant_id = $tenant_id and ls_id =  1 and role = 1 limit 1, host, 1);
let $mysql_leader_obs =deploy_get_value(ob1.get_obs_by_addr $mysql_leader_ip_port);
ob_connect(conn_mysql, $mysql_leader_obs, root@mysql, , test, , USE_MYSQL_CONNECTOR);
connection conn_mysql;
--disable_all_result_log
eval alter system set data_backup_dest='$data_backup_dest';
eval alter system set log_archive_dest='location=$log_backup_dest piece_switch_interval=1d';
--enable_all_result_log
ob1.mysql alter system archivelog;
ob1.check_until_timeout select status from oceanbase.CDB_OB_ARCHIVELOG where tenant_id=$tenant_id, DOING, 600;

--echo =================================================================================
--echo                   minor freeze for mysql tenant before clone
--echo =================================================================================
connection sys_conn;
ALTER SYSTEM MINOR FREEZE TENANT mysql;
let $unit_id1 = deploy_get_value(ob1.select SELECT unit_id FROM oceanbase.DBA_OB_UNITS WHERE resource_pool_id = $resource_pool_id AND zone = 'z1', unit_id, 1);
let $ip1 = deploy_get_value(ob1.select SELECT svr_ip FROM oceanbase.DBA_OB_UNITS WHERE unit_id = $unit_id1, svr_ip, 1);
let $port1 = deploy_get_value(ob1.select SELECT svr_port FROM oceanbase.DBA_OB_UNITS WHERE unit_id = $unit_id1, svr_port, 1);
let $z1_cur = $ip1:$port1;
let $unit_id2 = deploy_get_value(ob1.select SELECT unit_id FROM oceanbase.DBA_OB_UNITS WHERE resource_pool_id = $resource_pool_id AND zone = 'z2', unit_id, 1);
let $ip2 = deploy_get_value(ob1.select SELECT svr_ip FROM oceanbase.DBA_OB_UNITS WHERE unit_id = $unit_id2, svr_ip, 1);
let $port2 = deploy_get_value(ob1.select SELECT svr_port FROM oceanbase.DBA_OB_UNITS WHERE unit_id = $unit_id2, svr_port, 1);
let $z2_cur = $ip2:$port2;
let $unit_id3 = deploy_get_value(ob1.select SELECT unit_id FROM oceanbase.DBA_OB_UNITS WHERE resource_pool_id = $resource_pool_id AND zone = 'z3', unit_id, 1);
let $ip3 = deploy_get_value(ob1.select SELECT svr_ip FROM oceanbase.DBA_OB_UNITS WHERE unit_id = $unit_id3, svr_ip, 1);
let $port3 = deploy_get_value(ob1.select SELECT svr_port FROM oceanbase.DBA_OB_UNITS WHERE unit_id = $unit_id3, svr_port, 1);
let $z3_cur = $ip3:$port3;
if ($z1_cur != $z1_dst0)
{
ob1.z1.obs1.check_log_until_success -c "succeed to release head data memtable";
}
if ($z1_cur != $z1_dst1)
{
ob1.z1.obs0.check_log_until_success -c "succeed to release head data memtable";
}
if ($z2_cur == $z2_dst0)
{
ob1.z2.obs0.check_log_until_success -c "succeed to release head data memtable";
}
if ($z2_cur == $z2_dst1)
{
ob1.z2.obs1.check_log_until_success -c "succeed to release head data memtable";
}
if ($z2_cur == $z2_dst2)
{
ob1.z2.obs2.check_log_until_success -c "succeed to release head data memtable";
}
if ($z3_cur == $z3_dst0)
{
ob1.z3.obs0.check_log_until_success -c "succeed to release head data memtable";
}
if ($z3_cur == $z3_dst1)
{
ob1.z3.obs1.check_log_until_success -c "succeed to release head data memtable";
}
if ($z3_cur == $z3_dst2)
{
ob1.z3.obs2.check_log_until_success -c "succeed to release head data memtable";
}
sleep 10;

--echo ===========================================================================================
--echo       create snapshot when replica drtask exists, expect 9110(OB_ERR_CLONE_TENANT)
--echo ===========================================================================================
connection sys_conn;
ob1.mysql alter system set_tp tp_name = ERRSIM_CLEAN_TASK_FROM_DRTASK_TABLE_ERROR, error_code = 4002, frequency = 1;
eval ALTER TENANT mysql LOCALITY = "F@z1, F@z3";
ob1.check_until_timeout select count(*) > 0 from oceanbase.CDB_OB_LS_REPLICA_TASKS where tenant_id = $tenant_id and task_status = "INPROGRESS", 1, 20;
--error 9110
create tenant clone_tenant from mysql with resource_pool='test_pool', unit = '2c2g';

ob1.mysql alter system set_tp tp_name = ERRSIM_CLEAN_TASK_FROM_DRTASK_TABLE_ERROR, error_code = 4002, frequency = 0;
ob1.check_until_timeout select count(*) as cnt from oceanbase.CDB_OB_LS_REPLICA_TASKS where tenant_id = $tenant_id, 0, 120;

--echo ===========================================================================================
--echo         create snapshot when unit is migrating, expect 9110(OB_ERR_CLONE_TENANT)
--echo ===========================================================================================
connection sys_conn;
ob1.mysql set ob_global_debug_sync = 'BEFORE_SEND_MIGRATE_REPLICA_DRTASK wait_for signal_exec';
# migrate unit
--disable_query_log
if ($z3_cur == $z3_dst0)
{
  eval ALTER SYSTEM MIGRATE UNIT $unit_id DESTINATION "$z3_dst1"; 
}
if ($z3_cur != $z3_dst0)
{
  eval ALTER SYSTEM MIGRATE UNIT $unit_id DESTINATION "$z3_dst0";
}
--enable_query_log
# check create snapshot not allowed
--error 9110
create tenant clone_tenant from mysql with resource_pool='test_pool', unit = '2c2g';
ob1.mysql set ob_global_debug_sync = 'now signal signal_exec';
ob1.check_until_timeout select count(*) as cnt from oceanbase.CDB_OB_LS_REPLICA_TASKS where (tenant_id = $tenant_id or tenant_id = $meta_tenant_id), 0, 120;
ob1.check_until_timeout select count(*) as cnt from oceanbase.DBA_OB_UNITS where migrate_from_svr_ip is not NULL, 0, 30;
ob1.check_until_timeout select count(*) as cnt from oceanbase.DBA_OB_TENANTS where tenant_name = "mysql" and previous_locality is null, 1, 120;

--echo =================================================================================
--echo             create tenant snapshot and hold the lock on snapshot_id = 0
--echo =================================================================================
connection sys_conn;
ob1.mysql alter system set_tp tp_name = ERRSIM_CLONE_WAIT_CREATE_TENANT_ERROR, error_code = 4002, frequency = 1;
send create tenant clone_tenant from mysql with resource_pool='test_pool', unit = '2c2g';

--echo =========================================================================================
--echo        migrate unit when snapshot is creating, expect 4770(OB_CONFLICT_WITH_CLONE)
--echo =========================================================================================
connection sys_conn_2;
ob1.check_until_timeout select count(*) as cnt from oceanbase.DBA_OB_CLONE_PROGRESS where clone_tenant_name = "clone_tenant" and status = "CLONE_SYS_WAIT_TENANT_RESTORE_FINISH", 1, 300;
ob1.check_until_timeout select count(*) as cnt from oceanbase.DBA_OB_TENANTS where tenant_name = "clone_tenant", 1, 10;

# try migrate unit in zone2
--disable_query_log
if ($z2_cur == $z2_dst0)
{
  --error 4770
  eval ALTER SYSTEM MIGRATE UNIT $unit_id_in_zone2 DESTINATION "$z2_dst1";
}
if ($z2_cur != $z2_dst0)
{
  --error 4770
  eval ALTER SYSTEM MIGRATE UNIT $unit_id_in_zone2 DESTINATION "$z2_dst0";
}
--enable_query_log

--echo ========================================================================================
--echo    expand unit number when snapshot is creating, expect 4770(OB_CONFLICT_WITH_CLONE)
--echo ========================================================================================
# try expand unit number
--error 4770
alter resource tenant mysql unit_num = 2;

--echo ========================================================================================
--echo         alter ls when snapshot is creating, expect 4770(OB_CONFLICT_WITH_CLONE)
--echo ========================================================================================
# try create new ls
connection conn_mysql;
--error 4770
create table t1(c1 int) duplicate_scope = 'cluster';

--echo =========================================================================================
--echo   do ls replica dr-task when snapshot is creating, expect 4770(OB_CONFLICT_WITH_CLONE)
--echo =========================================================================================
connection sys_conn_2;
eval ALTER TENANT mysql LOCALITY = "F@z1, F@z2, F@z3";
ob1.check_until_timeout select count(*) as cnt from oceanbase.DBA_OB_TENANTS where tenant_id = $tenant_id and previous_locality like "%FULL{1}@z1, FULL{1}@z3%" and locality like "%FULL{1}@z1, FULL{1}@z2, FULL{1}@z3%", 1, 30;
ob1.check_until_timeout select count(*) > 0 from oceanbase.V\$OB_LS_REPLICA_TASK_PLAN, 1, 20;
ob1.check_until_timeout select count(*) as cnt from oceanbase.CDB_OB_LS_REPLICA_TASKS, 0, 20;
ob1.check_until_timeout select count(*) as cnt from oceanbase.DBA_OB_TENANTS where tenant_id = $tenant_id and previous_locality like "%FULL{1}@z1, FULL{1}@z3%" and locality like "%FULL{1}@z1, FULL{1}@z2, FULL{1}@z3%", 1, 30;
eval ALTER TENANT mysql LOCALITY = "F@z1, F@z3";
ob1.check_until_timeout select count(*) as cnt from oceanbase.DBA_OB_TENANTS where tenant_id = $tenant_id and previous_locality is null and locality like "%FULL{1}@z1, FULL{1}@z3%", 1, 30;
ob1.check_until_timeout select count(*) as cnt from oceanbase.CDB_OB_LS_REPLICA_TASKS where tenant_id = $tenant_id or tenant_id = $meta_tenant_id, 0, 120;

--echo =========================================================================================
--echo     drop source tenant when snapshot is creating, expect 4770(OB_CONFLICT_WITH_CLONE)
--echo =========================================================================================
connection sys_conn_2;
set recyclebin = off;
--error 4770
drop tenant mysql;

--echo =================================================================================
--echo                      let creating snapshot finished
--echo =================================================================================
connection sys_conn_2;
ob1.mysql alter system set_tp tp_name = ERRSIM_CLONE_WAIT_CREATE_TENANT_ERROR, error_code = 4002, frequency = 0;
connection sys_conn;
reap;
ob1.check_until_timeout select count(*) as cnt from oceanbase.DBA_OB_TENANTS where tenant_name = "CLONE_TENANT" and status = "NORMAL" and tenant_role = "STANDBY", 1, 30;

