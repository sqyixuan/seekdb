# CASE_OWNER:
#    @jinqian.zzy
# CASE_DESC:
#    This case is aimed to test cancel
#######################################################################
#                        create inital objects
#######################################################################

ob1=OBI(cluster=1:1:2,proxy_num=0,init_unit_cpu=0);
source include/mini_ob_config.inc;
ob1.set extra_config=$mini_ob_config;
ob1.reboot;

ob1.mysql alter system set debug_sync_timeout = '1000s';
ob1.mysql ALTER SYSTEM SET enable_rebalance = 'false';
ob1.mysql ALTER SYSTEM SET enable_rereplication = 'true';

let $proxy_ip = deploy_get_value(ob1.z1.obs0.ip);
let $proxy_port = deploy_get_value(ob1.z1.obs0.mysql_port);
connect(sys_conn, $proxy_ip, root@sys,,oceanbase, $proxy_port);

# create new tenant mysql_tenant
source include/create_unit_config.inc;
ob1.mysql CREATE RESOURCE POOL tenant_pool UNIT = "2c2g", UNIT_NUM = 1, ZONE_LIST = ('z1', 'z2', 'z3');
ob1.mysql CREATE TENANT mysql_tenant RESOURCE_POOL_LIST=('tenant_pool'), LOCALITY = "F@z1, F@z3", PRIMARY_ZONE = "z1" SET ob_tcp_invited_nodes='%';

let $tenant_id = deploy_get_value(ob1.select SELECT tenant_id FROM oceanbase.DBA_OB_TENANTS WHERE tenant_name = "mysql_tenant", tenant_id, 1);
let $meta_tenant_id = deploy_get_value(ob1.select select tenant_id - 1 as meta_tenant_id from oceanbase.DBA_OB_TENANTS where tenant_name = "mysql_tenant", meta_tenant_id, 1);
let $resource_pool_id = deploy_get_value(ob1.select SELECT resource_pool_id FROM oceanbase.DBA_OB_RESOURCE_POOLS WHERE tenant_id = $tenant_id, resource_pool_id, 1);

# get mysql_tenant's unit info in z3
let $unit_id = deploy_get_value(ob1.select SELECT unit_id FROM oceanbase.DBA_OB_UNITS WHERE resource_pool_id = $resource_pool_id AND zone = 'z3', unit_id, 1);
let $ip = deploy_get_value(ob1.select select svr_ip from oceanbase.DBA_OB_SERVERS where zone = 'z3' and CONCAT(svr_ip, ':', svr_port) not in (select CONCAT(svr_ip, ':', svr_port) from oceanbase.DBA_OB_UNITS where zone = 'z3' and unit_id >= 1001), svr_ip, 1);
let $port = deploy_get_value(ob1.select select svr_port from oceanbase.DBA_OB_SERVERS where zone = 'z3' and CONCAT(svr_ip, ':', svr_port) not in (select CONCAT(svr_ip, ':', svr_port) from oceanbase.DBA_OB_UNITS where zone = 'z3' and unit_id >= 1001), svr_port, 1);
let $dest_server = $ip:$port;

# create table and insert data
ob_connect(conn_mysql, ob1.z1.obs0, root@mysql_tenant, , test, , USE_MYSQL_CONNECTOR);
connection conn_mysql;
create table t1_no_pk (c1 int);
insert into t1_no_pk values (1), (2), (3);
select * from t1_no_pk;
update t1_no_pk set c1=c1+10;
select * from t1_no_pk;
create table t1_pk (c1 int primary key);
insert into t1_pk values (1), (2), (3);
select * from t1_pk;
update t1_pk set c1=c1+10;
select * from t1_pk;
create table t1_part (c1 int primary key) partition by hash(c1) partitions 4;
insert into t1_part values (1), (2), (3), (4);
select * from t1_part;
update t1_part set c1=c1+10;
select * from t1_part;
connect(sys_conn, $proxy_ip, root@sys,,oceanbase, $proxy_port);
alter system minor freeze tenant mysql_tenant;
ob1.z1.obs0.check_log_until_success -c "succeed to release head data memtable";
ob1.z3.obs1.check_log_until_success -c "succeed to release head data memtable";
sleep 10;
connection conn_mysql;
insert into t1_no_pk values (4), (5), (6);
insert into t1_no_pk values (7), (8), (9);
insert into t1_no_pk values (10), (11), (12);
insert into t1_pk values (4), (5), (6);
insert into t1_pk values (7), (8), (9);
insert into t1_pk values (10);
insert into t1_part values (5), (6), (7), (8);
insert into t1_part values (9), (10), (21), (22);
connect(sys_conn, $proxy_ip, root@sys,,oceanbase, $proxy_port);
alter system minor freeze tenant mysql_tenant;
ob1.z1.obs0.check_log_until_success -c "succeed to release head data memtable";
ob1.z3.obs1.check_log_until_success -c "succeed to release head data memtable";
sleep 10;

--echo "prepare finished"

connect(mysql_tenant_conn, $proxy_ip, root@mysql_tenant,,oceanbase, $proxy_port);
connection sys_conn;

# 任务在observer层执行过程中卡住
ob1.mysql set ob_global_debug_sync = 'BEFORE_WAIT_LOG_REPLAY_SYNC wait_for signal';

--disable_query_log
eval ALTER SYSTEM MIGRATE UNIT $unit_id DESTINATION "$dest_server";

# 确认该unit上的所有副本的迁移任务都生成了，并且等到任务只剩被卡住的任务，因为debug sync只能卡住一个observer的一个线程一次
# 且unit上多个副本的迁移请求到达observer的时间可能不同，不能知道是哪个副本请求先到达，只知道有一个副本的迁移任务必定会卡住
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_LS_REPLICA_TASK_HISTORY, 2, 60;
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_LS_REPLICA_TASKS, 1, 60;

let $tenant_id_tmp = deploy_get_value(ob1.select SELECT tenant_id FROM oceanbase.CDB_OB_LS_REPLICA_TASKS, tenant_id, 1);
let $ls_id_tmp = deploy_get_value(ob1.select SELECT ls_id FROM oceanbase.CDB_OB_LS_REPLICA_TASKS, ls_id, 1);
let $task_id = deploy_get_value(ob1.select SELECT task_id FROM oceanbase.CDB_OB_LS_REPLICA_TASKS WHERE tenant_id = $tenant_id_tmp and ls_id = $ls_id_tmp, task_id, 1);
let $tenant_name_tmp = deploy_get_value(ob1.select SELECT tenant_name FROM oceanbase.DBA_OB_TENANTS WHERE tenant_id = $tenant_id_tmp, tenant_name, 1);

# 通过task_id取消任务
eval ALTER SYSTEM CANCEL REPLICA TASK TASK_ID='$task_id' TENANT='$tenant_name_tmp';

# 任务开启
ob1.mysql set ob_global_debug_sync = 'now signal signal';

# 查询历史表，等待底层上报
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_LS_REPLICA_TASK_HISTORY where tenant_id = $tenant_id_tmp and ls_id = $ls_id_tmp and task_id = '$task_id' and task_status = 'CANCELED', 1, 60;

# 打印历史表
eval select task_type, task_status, priority, target_paxos_replica_number, target_replica_type, source_paxos_replica_number, source_replica_type, comment, is_manual from oceanbase.CDB_OB_LS_REPLICA_TASK_HISTORY where tenant_id = $tenant_id_tmp and ls_id = $ls_id_tmp;
