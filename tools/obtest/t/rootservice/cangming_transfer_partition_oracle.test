ob1.check_until_timeout select count(*) = 0 from __all_virtual_tenant_parameter_stat where tenant_id = 1002 and name = 'enable_transfer' and value = 'true', 1, 5;
--error 4179
eval ALTER SYSTEM TRANSFER PARTITION TABLE_ID $1001_t_id, OBJECT_ID $1001_o_id TO LS 1002 tenant=test_tenant_oracle;
ob1.mysql alter system set enable_transfer = 'true' tenant='test_tenant_oracle';
ob1.check_until_timeout select count(*) = 0 from __all_virtual_tenant_parameter_stat where tenant_id = 1002 and name = 'enable_transfer' and value = 'false', 1, 5;
eval ALTER SYSTEM TRANSFER PARTITION TABLE_ID $1001_t_id, OBJECT_ID $1001_o_id TO LS 1002 tenant=test_tenant_oracle;

