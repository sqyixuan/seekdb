ob1=OBI(cluster=2,proxy_num=0);
ob1.reboot;

ob_connect(sys_conn, ob1.z1.obs0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);

ob1.mysql CREATE RESOURCE UNIT 2c4g MAX_CPU 2, MEMORY_SIZE '4G';
ob1.mysql CREATE RESOURCE POOL pool1 UNIT='2c4g',UNIT_NUM=2,ZONE_LIST=('z1');
ob1.mysql CREATE RESOURCE POOL pool2 UNIT='2c4g',UNIT_NUM=2,ZONE_LIST=('z1');
CREATE TENANT IF NOT EXISTS test_tenant_oracle ZONE_LIST=('z1'), RESOURCE_POOL_LIST=('pool1') set ob_tcp_invited_nodes='%', ob_compatibility_mode='oracle';
CREATE TENANT IF NOT EXISTS test_tenant_2 ZONE_LIST=('z1'), RESOURCE_POOL_LIST=('pool2') set ob_tcp_invited_nodes='%', ob_compatibility_mode='oracle';
ob_connect(test_oracle_conn, ob1.z1.obs0, SYS@test_tenant_oracle, , SYS, , USE_OB_CONNECTOR);
connection test_oracle_conn;
let $test_cnt = 6;
while ($test_cnt > 0)
{
  eval create table tt_$test_cnt (c1 INT PRIMARY KEY, c2 INT) PARTITION BY HASH(c1) PARTITIONS 4;
  eval insert into tt_$test_cnt(c1, c2) values(1, 1);
  eval insert into tt_$test_cnt(c1, c2) values(2, 2);
  eval insert into tt_$test_cnt(c1, c2) values(3, 3);
  eval insert into tt_$test_cnt(c1, c2) values(4, 4);
  eval insert into tt_$test_cnt(c1, c2) values(5, 5);
  sleep 1;
  dec $test_cnt;
}
#局部索引表
create index il on tt_1(c2) local;
#lob 表
create table t_lob(c1 int, c2 char(10), c3 clob) partition by hash(c1) partitions 4;
#复制表
create table dup_t1(c1 int, c2 int) duplicate_scope = 'cluster';
insert into dup_t1 values (1, 123), (2,456), (3,789), (4,1), (5, 2);
#二级分区表
create table t_sub (c1 int, c2 int) partition by range(c1) subpartition by hash(c2) (partition p0 values less than(100) (subpartition sp0),partition p1 values less than(200) (subpartition sp2, subpartition sp3));
#########不允许系统租户下不填写租户名做transfer partition#########
--echo 不允许系统租户下不填写租户名做transfer partition
connection sys_conn;
let $1001_t_id = deploy_get_value(ob1.select select table_id from oceanbase.cdb_ob_table_locations where tenant_id=1002 and database_name='SYS' and table_name = 'tt_1' and ls_id=1001 order by object_id limit 1, table_id, 1);
let $1001_o_id = deploy_get_value(ob1.select select object_id from oceanbase.cdb_ob_table_locations where table_id=$1001_t_id order by object_id limit 1, object_id, 1);

--error 1235
eval ALTER SYSTEM TRANSFER PARTITION TABLE_ID $1001_t_id, OBJECT_ID  $1001_o_id TO LS 1002;

#########允许系统租户下填写租户名做transfer partition#########
--echo 允许系统租户下填写租户名做transfer partition
eval ALTER SYSTEM TRANSFER PARTITION TABLE_ID $1001_t_id, OBJECT_ID  $1001_o_id TO LS 1002 tenant=test_tenant_oracle;

