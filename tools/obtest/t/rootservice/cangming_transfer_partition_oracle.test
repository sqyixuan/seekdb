ALTER SYSTEM TRANSFER PARTITION TABLE_ID 11111, OBJECT_ID  11111 TO LS 1002 tenant=test_tenant_2;

#########不允许没有alter system权限的用户做transfer partition#######
create user usr_test identified by 123;
grant select on *.* to usr_test;
ob_connect(test_oracle_conn_usr, ob1.z1.obs0, usr_test@test_tenant_oracle, 123, usr_test, , USE_OB_CONNECTOR);
connection test_oracle_conn_usr;
--error 1031
ALTER SYSTEM TRANSFER PARTITION TABLE_ID 1, OBJECT_ID 1 TO LS 1002;
connection test_oracle_conn;
grant alter system to usr_test;
ob_connect(test_oracle_conn_usr1, ob1.z1.obs0, usr_test@test_tenant_oracle, 123, usr_test, , USE_OB_CONNECTOR);
connection test_oracle_conn_usr1;
--error 600
ALTER SYSTEM TRANSFER PARTITION TABLE_ID 1, OBJECT_ID 1 TO LS 1002;
connection test_oracle_conn;

