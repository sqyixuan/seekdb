#########不允许非primary normal租户做transfer partition#########
--echo 不允许非primary normal租户做transfer partition
let $1001_t_id = deploy_get_value(ob1.select select table_id from oceanbase.cdb_ob_table_locations where tenant_id=1002 and database_name='SYS' and table_name = 'tt_3' and ls_id=1001 order by object_id limit 1, table_id, 1);
let $1001_o_id = deploy_get_value(ob1.select select object_id from oceanbase.cdb_ob_table_locations where table_id=$1001_t_id order by object_id limit 1, object_id, 1);
connection sys_conn;
ALTER SYSTEM SWITCHOVER TO STANDBY TENANT test_tenant_oracle;
--error 4179
eval ALTER SYSTEM TRANSFER PARTITION TABLE_ID $1001_t_id, OBJECT_ID $1001_o_id TO LS 1002 tenant=test_tenant_oracle;
ALTER SYSTEM SWITCHOVER TO PRIMARY TENANT test_tenant_oracle;
alter system change tenant tenant_id = 1001;
UPDATE oceanbase.__all_tenant_info SET switchover_status = 'SWITCHING TO STANDBY' where tenant_id=1002;
alter system change tenant tenant_id = 1;
--error 4179
eval ALTER SYSTEM TRANSFER PARTITION TABLE_ID $1001_t_id, OBJECT_ID $1001_o_id TO LS 1002 tenant=test_tenant_oracle;
alter system change tenant tenant_id = 1001;
UPDATE oceanbase.__all_tenant_info SET switchover_status = 'PREPARE SWITCHING TO STANDBY' where tenant_id=1002;
alter system change tenant tenant_id = 1;
--error 4179
eval ALTER SYSTEM TRANSFER PARTITION TABLE_ID $1001_t_id, OBJECT_ID $1001_o_id TO LS 1002 tenant=test_tenant_oracle;
alter system change tenant tenant_id = 1001;
UPDATE oceanbase.__all_tenant_info SET switchover_status = 'NORMAL' where tenant_id=1002;

