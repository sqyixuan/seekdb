# CASE_OWNER:
#    @cangming.zl
# CASE_DESC:
#    用例场景：
#    1. start一个处于start状态的zone
#    2. stop一个处于start状态的zone
#    3. stop一个处于stop状态的zone
#    4. start一个处于stop状态的zone
#    5. start一个不存在的zone
#    6. stop一个不存在的zone

##construct the cluster
ob1=OBI(cluster=2:2:2,proxy_num=0);
ob1.reboot;
ob1.check_until_timeout select count(*) from oceanbase.__all_server where start_service_time > 0,6,10;

ob1.mysql CREATE RESOURCE UNIT test MAX_CPU 2, MEMORY_SIZE '4G';

##create the tenant
ob1.mysql CREATE RESOURCE POOL pool1 UNIT = 'test', UNIT_NUM = 2, ZONE_LIST = ('z1', 'z2', 'z3');
ob1.mysql CREATE TENANT tenant RESOURCE_POOL_LIST = ('pool1') set ob_tcp_invited_nodes='%';
let $tenant_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name = 'tenant', tenant_id, 1);
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_ls_status where tenant_id = $tenant_id, 7, 30;

##create the table
ob_connect(conn1, ob1.z1.obs0, root@tenant, , oceanbase, , USE_MYSQL_CONNECTOR);
connection conn1;
CREATE DATABASE db;
use db;

CREATE TABLE table1 (pk int, value int, primary key(pk));
sleep 2;

ob_connect(conn_root, ob1.z1.obs0, root, , oceanbase, , USE_MYSQL_CONNECTOR);
connection conn_root;

#########
##case 1
#########
echo case 1;
let $zone = z2;
--error 4633
eval alter system start zone '$zone';
source include/get_zone_status.inc;

#########
##case 2
#########
echo case 2;
ob1.mysql alter system stop zone '$zone';
sleep 10;
source include/get_zone_status.inc;
source include/get_zone_role.inc;

#########
##case 3
#########
echo case 3;
eval alter system stop zone '$zone';
source include/get_zone_status.inc;
source include/get_zone_role.inc;

#########
##case 4
#########
echo case 4;
ob1.mysql alter system start zone '$zone';
sleep 10;
source include/get_zone_status.inc;

#########
##case 5
#########
echo case 5;
let $invalid_zone = invalid_zone;
--error 4018
eval alter system start zone '$invalid_zone';

#########
##case 6
#########
echo case 6;
--error 4018
eval alter system stop zone '$invalid_zone';

