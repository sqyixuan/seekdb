# CASE_OWNER:
#    @cangming.zl
# CASE_DESC:
#     sys unit 独立部署case 2

ob1=OBI(cluster=3:3:3,proxy_num=0,init_unit_cpu=0);

ob1.reboot;

ob_connect(sys_conn, ob1.z1.obs0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);
connection sys_conn;
alter system set balancer_idle_time='10s';
sleep 5;
create resource unit test_unit max_cpu = 1, memory_size = '2G';
create resource pool pool1 unit_num=1, zone_list=('z1','z2','z3'), unit='test_unit';
create resource pool pool2 unit_num=1, zone_list=('z1','z2','z3'), unit='test_unit';
create resource pool pool3 unit_num=1, zone_list=('z1','z2','z3'), unit='test_unit';
create resource pool pool4 unit_num=1, zone_list=('z1','z2','z3'), unit='test_unit';

sleep 5;

ob1.check_until_timeout select count(*) from oceanbase.__all_server where start_service_time>0, 9, 300;

let $svr_ip1 = deploy_get_value(ob1.z1.obs0.ip);
let $svr_port1 = deploy_get_value(ob1.z1.obs0.port);

let $svr_ip2 = deploy_get_value(ob1.z2.obs0.ip);
let $svr_port2 = deploy_get_value(ob1.z2.obs0.port);

let $svr_ip3 = deploy_get_value(ob1.z3.obs0.ip);
let $svr_port3 = deploy_get_value(ob1.z3.obs0.port);

let $svr_ip4 = deploy_get_value(ob1.z1.obs1.ip);
let $svr_port4 = deploy_get_value(ob1.z1.obs1.port);

let $svr_ip5 = deploy_get_value(ob1.z2.obs1.ip);
let $svr_port5 = deploy_get_value(ob1.z2.obs1.port);

let $svr_ip6 = deploy_get_value(ob1.z3.obs1.ip);
let $svr_port6 = deploy_get_value(ob1.z3.obs1.port);

alter system set server_permanent_offline_time='20s';
ob1.z3.obs0.force_stop;
alter system set enable_sys_unit_standalone=true;
sleep 20;
# z3 sys unit迁走了
ob1.check_until_timeout select count(*) from oceanbase.__all_unit where unit_id=3 and (svr_ip!='$svr_ip3' or svr_port!=$svr_port3) and (migrate_from_svr_ip!='$svr_ip3' or migrate_from_svr_port!=$svr_port3), 1, 1800;
# 重启z3.obs0
ob1.z3.obs0.start;
ob1.check_until_timeout select count(*) from oceanbase.__all_server where zone = 'z3' and (start_service_time<=0 or status='INACTIVE'), 0, 300;

let $pool1_id = deploy_get_value(ob1.select select resource_pool_id from oceanbase.__all_resource_pool where name = "pool1", resource_pool_id, 1);
let $pool2_id = deploy_get_value(ob1.select select resource_pool_id from oceanbase.__all_resource_pool where name = "pool2", resource_pool_id, 1);
let $pool3_id = deploy_get_value(ob1.select select resource_pool_id from oceanbase.__all_resource_pool where name = "pool3", resource_pool_id, 1);
let $pool4_id = deploy_get_value(ob1.select select resource_pool_id from oceanbase.__all_resource_pool where name = "pool4", resource_pool_id, 1);

set ob_query_timeout=60000000;
create tenant wenduo1 primary_zone = 'z1', resource_pool_list = ('pool1');
create tenant wenduo2 primary_zone = 'z1', resource_pool_list = ('pool2');
create tenant wenduo3 primary_zone = 'z1', resource_pool_list = ('pool3');
create tenant wenduo4 primary_zone = 'z1', resource_pool_list = ('pool4');
--disable_query_log
eval alter system migrate unit 3 destination '$svr_ip3:$svr_port3';
--enable_query_log
ob1.check_until_timeout select count(*) from oceanbase.__all_unit where unit_id=3 and svr_ip='$svr_ip3' and svr_port=$svr_port3 and migrate_from_svr_ip='', 1, 1800;
# 开启租户间负载均衡
alter system set enable_rereplication=true;
alter system set enable_rebalance = true;

ob1.check_until_timeout select count(*) from oceanbase.__all_unit where svr_ip='$svr_ip4' and svr_port=$svr_port4 and migrate_from_svr_ip = '', 2, 1800;
ob1.check_until_timeout select count(*) from oceanbase.__all_unit where svr_ip='$svr_ip5' and svr_port=$svr_port5 and migrate_from_svr_ip = '', 2, 1800;
