# CASE_OWNER:
#    @wenyu.ffz
# CASE_DESC:
#    校验create_table_if_not_exists在table存在的情况下不等consensus schema

ob1=OBI(cluster=1:1:1,proxy_num=0);
source include/mini_ob_config.inc;
ob1.set extra_config=$mini_ob_config;
ob1.reboot;

ob_connect(conn_sys, ob1.z1.obs0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);
#create tenant
eval CREATE RESOURCE UNIT unit_1 MAX_CPU 2, MEMORY_SIZE '4G';
eval CREATE RESOURCE POOL pool_1 UNIT = 'unit_1', UNIT_NUM = 1;
eval CREATE TENANT mysql RESOURCE_POOL_LIST = ('pool_1'), primary_zone='z1' set ob_tcp_invited_nodes='%';

ob_connect(conn_mysql1, ob1.z1.obs0, root@mysql, ,test, , USE_OB_CONNECTOR);

create table if not exists t1 (col1 int);

ob1.z2.stop;
ob1.check_until_timeout select count(*) from oceanbase.__all_server where zone = 'z2' and status="INACTIVE" or start_service_time<=0, 1, 60;
ob1.z2.nstart;
ob1.check_until_timeout select count(*) from oceanbase.__all_server where zone = 'z2' and status="ACTIVE" and start_service_time>0, 1, 60;

ob_connect(conn_mysql2, ob1.z2.obs0, root@mysql, ,test, , USE_OB_CONNECTOR);

let $start_time = query_get_value(select now() as value, value, 1);

create table if not exists t1 (col1 int);

let $interval_second = query_get_value(select timestampdiff(second, '$start_time', now()) as value, value, 1);

if ($interval_second <= 3)
{
  --echo success;
}

if ($interval_second > 3)
{
  --echo $interval_second timeout;
}
