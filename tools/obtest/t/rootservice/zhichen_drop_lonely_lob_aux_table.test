ob1.z1.obs0.sh cd $work_dir/; ./etc/ob_admin -S run/rpc.sock force_drop_lonely_lob_aux_table $mysql_tenant_id:$data_table_id:$lob_meta_table_id:$lob_piece_table_id;
connection sys_conn;
