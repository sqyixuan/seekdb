# CASE_OWNER:
#    @cangming.zl
# CASE_DESC:
#    zone管理
#    用例场景：
#    1、delete zone
#    2、stop zone
#    3、restart zone
#    4、主动上下线zone
#    5、stop/delete zone include rs

ob1=OBI(cluster=2:2:2,proxy_num=0,init_unit_cpu=0);
ob1.z3.obs0.set status=disable;
ob1.z3.obs1.set status=disable;
ob1.reboot;
ob1.z3.add;
ob1.z3.start_zone;
ob1.z3.obs0.set status=enable;
ob1.z3.obs0.start;
sleep 30;
ob1.z3.obs0.add;
ob1.z3.obs1.set status=enable;
ob1.z3.obs1.start;
sleep 30;
ob1.z3.obs1.add;

ob1.mysql alter system set server_check_interval='15s';
ob1.mysql alter system set balancer_idle_time='10s';
ob_connect(sys_conn, ob1.z1.obs0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);
connection sys_conn;

ob_connect(sys1_conn, ob1.z1.obs0, root, , oceanbase, , USE_MYSQL_CONNECTOR);
connection sys1_conn;
set ob_query_timeout = 30000000;

eval  CREATE RESOURCE UNIT unit_1 MAX_CPU 1, MEMORY_SIZE '2G';
eval  CREATE RESOURCE POOL pool_1 UNIT = 'unit_1', UNIT_NUM = 1, ZONE_LIST = ('z1','z2');
eval  CREATE TENANT tenant_1 RESOURCE_POOL_LIST = ('pool_1'), primary_zone='z1' set ob_tcp_invited_nodes='%';
sleep 5;
ob_connect(ob_conn, ob1.z1.obs1, root@tenant_1, , test, , USE_MYSQL_CONNECTOR);
##create table
connection ob_conn;
let $tablenum=5;
let $difftablegroup=1;
source sql/init_table.sql;
connection sys_conn;
let $check_zone = select zone,info from oceanbase.__all_zone where name='status' and zone=;
##########
#case1: stop zone,delete zone
##########
set @saved_ob_query_timeout = @@session.ob_query_timeout;
set @@session.ob_query_timeout = 60000000;
alter system stop zone 'z3';
set @@session.ob_query_timeout = @saved_ob_query_timeout;

ob1.mysql_p $check_zone 'z3';

ob1.z3.obs0.delete;
ob1.z3.obs1.delete;
alter system set balancer_idle_time = '10s';
#ob1.mysql_p select * from oceanbase.__all_server where zone='z3' order by status;
ob1.check_until_timeout select count(*) from oceanbase.__all_server where zone = 'z3', 0, 60;
ob1.mysql alter system delete zone 'z3';
ob1.mysql_p $check_zone 'z3';

##########
#case2: add zone,start zone
###########
ob1.mysql alter system add zone 'z3';
#ob1.mysql $check_zone 'z3';
sleep 1;
ob1.mysql alter system start zone 'z3';
ob1.mysql_p $check_zone 'z3';

let $ip = deploy_get_value(ob1.z3.obs0.ip);
let $port = deploy_get_value(ob1.z3.obs0.port);
connection sys_conn;
--disable_all_result_log
--error 4179
eval alter system add server '$ip:$port' ZONE='z3';
--enable_all_result_log
let $ip = deploy_get_value(ob1.z3.obs1.ip);
let $port = deploy_get_value(ob1.z3.obs1.port);
connection sys_conn;
--disable_all_result_log
--error 4179
eval alter system add server '$ip:$port' ZONE='z3';
--enable_all_result_log


