select * from t6 order by c1 desc;

--echo =========================================
--echo        test zone5 can refresh schema
--echo =========================================
connect(mysql_conn5, $proxy_ip5, root@mysql,,test, $proxy_port5);
connection mysql_conn5;
--echo expect 6 lines
