#select * from t2 order by c1 desc;
select * from t3 order by c1 desc;
select * from t4 order by c1 desc;
select * from t5 order by c1 desc;
select * from t6 order by c1 desc;

--echo =============================================
--echo       revoke RS in z2 and hang RS again
--echo =============================================
connect(sys_conn1, $proxy_ip1, root@sys,,oceanbase, $proxy_port1);
connection sys_conn1;
--echo make sure RS on z1 again
eval update __all_server set stop_time = 0 where zone = "z1";
ob1.check_until_timeout select count(*) as cnt from oceanbase.GV\$OB_LOG_STAT where tenant_id = 1 and ls_id = 1 and role = "LEADER" and svr_ip = "$z1_dst_ip" and svr_port = $z1_dst_port, 1, 30;

--echo ===============================================
--echo      creata table and index in zone1 again
--echo ===============================================
connect(mysql_conn1, $proxy_ip1, root@mysql,,test, $proxy_port1);
connection mysql_conn1;
create table r2_t1(c1 int);
create table r2_t2(c1 int);
insert into r2_t1 values (1), (2), (3);
insert into r2_t2 values (1), (2), (3);
--echo expect 3 lines
select * from r2_t1 order by c1 desc;
--echo expect 3 lines
select * from r2_t2 order by c1 desc;
create index r2_t1_index1 on r2_t1(c1);
create index r2_t2_index1 on r2_t2(c1);
insert into r2_t1 values (4), (5), (6);
insert into r2_t2 values (4), (5), (6);
--echo expect 6 lines
select * from r2_t1 order by c1 desc;
--echo expect 6 lines
select * from r2_t2 order by c1 desc;

--echo ===============================================
