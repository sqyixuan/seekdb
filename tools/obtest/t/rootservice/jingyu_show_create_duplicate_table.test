# CASE_OWNER:
#    @jingyu.cr
# CASE_DESC:
#    This case is aimed to test create duplicate table and index table on it
#    Make sure show create duplicate table not show information about
#    duplicate scope of index table.
#
#    aone-link: 
#
#######################################################################
#                        create inital objects
#######################################################################

ob1=OBI(cluster=2:2,proxy_num=0,init_unit_cpu=0);
source include/mini_ob_config.inc;
ob1.set extra_config=$mini_ob_config;
ob1.reboot;

ob1.mysql alter system set debug_sync_timeout = '1000s';
ob1.mysql ALTER SYSTEM SET enable_rebalance = 'false';
ob1.mysql ALTER SYSTEM SET enable_rereplication = 'true';

let $proxy_ip = deploy_get_value(ob1.z1.obs0.ip);
let $proxy_port = deploy_get_value(ob1.z1.obs0.mysql_port);
connect(sys_conn, $proxy_ip, root@sys,,oceanbase, $proxy_port);

--echo =========================================================
--echo                   create tenant mysql
--echo =========================================================
# create new tenant mysql
source include/create_unit_config.inc;
ob1.mysql CREATE RESOURCE POOL tenant_pool UNIT = "2c2g", UNIT_NUM = 2, ZONE_LIST = ('z1', 'z2');
ob1.mysql CREATE TENANT mysql RESOURCE_POOL_LIST=('tenant_pool'), LOCALITY = "F@z1, F@z2", PRIMARY_ZONE = "z1" SET ob_tcp_invited_nodes='%';

let $tenant_id = deploy_get_value(ob1.select SELECT tenant_id FROM oceanbase.DBA_OB_TENANTS WHERE tenant_name = "mysql", tenant_id, 1);
let $meta_tenant_id = deploy_get_value(ob1.select select tenant_id - 1 as meta_tenant_id from oceanbase.DBA_OB_TENANTS where tenant_name = "mysql", meta_tenant_id, 1);

--echo =========================================================
--echo               create duplicate table dup_t1
--echo =========================================================
let $mysql_leader_ip_port = deploy_get_value(ob1.select select concat(svr_ip,':',svr_port) as host from __all_virtual_ls_meta_table where tenant_id = $tenant_id and ls_id =  1 and role = 1 limit 1, host, 1);
let $mysql_leader_obs = deploy_get_value(ob1.get_obs_by_addr $mysql_leader_ip_port);
ob_connect(conn_mysql, $mysql_leader_obs, root@mysql, , test, , USE_MYSQL_CONNECTOR);
connection conn_mysql;
create table dup_t1(c1 int) duplicate_scope = 'cluster';

--echo =========================================================
--echo         create index for duplicate table dup_t1
--echo =========================================================
create index dup_t1_idx_local on dup_t1(c1) local;
create index dup_t1_idx_global on dup_t1(c1) global;


--echo =========================================================
--echo                   check duplicate scope
--echo =========================================================
connect(sys_conn, $proxy_ip, root@sys,,oceanbase, $proxy_port);
connection sys_conn;
let $duplicate_ls_id = deploy_get_value(ob1.select select ls_id as duplicate_ls_id from oceanbase.CDB_OB_LS where tenant_id = $tenant_id and flag like "%DUPLICATE%", duplicate_ls_id, 1);
ob1.check_until_timeout select count(*) as cnt from oceanbase.CDB_OB_TABLE_LOCATIONS where table_name like "%DUP_T1%" and role like "%LEADER%" and duplicate_scope like "%CLUSTER%", 3, 30;
ob1.check_until_timeout select count(*) as cnt from oceanbase.CDB_OB_TABLE_LOCATIONS where table_name = "DUP_T1" and ls_id = $duplicate_ls_id, 4, 60;
ob1.check_until_timeout select count(*) as cnt from oceanbase.CDB_OB_TABLE_LOCATIONS where table_name like "%DUP_T1_IDX_LOCAL%" and ls_id = $duplicate_ls_id, 4, 60;
ob1.check_until_timeout select count(*) as cnt from oceanbase.CDB_OB_TABLE_LOCATIONS where table_name like "%DUP_T1_IDX_GLOBAL%" and ls_id = $duplicate_ls_id, 4, 60;

--echo =========================================================
--echo                      test show create table
--echo =========================================================
ob_connect(conn_mysql, $mysql_leader_obs, root@mysql, , test, , USE_MYSQL_CONNECTOR);
connection conn_mysql;
show create table dup_t1;
