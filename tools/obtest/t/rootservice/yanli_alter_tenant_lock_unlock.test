# CASE_OWNER:
#    @msy164651
# CASE_DESC:
#    测试alter tenant lock/unlock 功能
#    测试用例：
#    1. 对处于unlock状态的租户执行alter tenant unlock
#    2. 对处于unlock状态的租户执行alter tenant lock
#    3. 对处于lock状态的租户执行alter tenant lock
#    4. 对处于lock状态的租户执行alter tenant unlock

##construct the cluster
ob1=OBI(cluster=2);
ob1.reboot;

let $obs = deploy_get_value(ob1.proxy0.ip);
let $port = deploy_get_value(ob1.proxy0.port);

let $cpu = 1;
let $memory = 1073741824;

ob1.mysql CREATE RESOURCE UNIT test MAX_CPU $cpu, MEMORY_SIZE $memory;

##create the tenant
ob1.mysql CREATE RESOURCE POOL pool1 UNIT = 'test', UNIT_NUM = 2;
ob1.mysql CREATE TENANT tenant RESOURCE_POOL_LIST = ('pool1') set ob_tcp_invited_nodes='%';

connect (conn1,$obs,admin@sys,admin,oceanbase,$port);
connection conn1;

#########
##case 1
#########
let $tenant_name = tenant;
ob1.mysql alter tenant $tenant_name unlock;
eval select locked from oceanbase.__all_tenant where tenant_name = '$tenant_name';

#########
##case 2
#########
ob1.mysql alter tenant $tenant_name lock;
eval select locked from oceanbase.__all_tenant where tenant_name = '$tenant_name';

#########
##case 3
#########
ob1.mysql alter tenant $tenant_name lock;
eval select locked from oceanbase.__all_tenant where tenant_name = '$tenant_name';

#########
##case 4
#########
ob1.mysql alter tenant $tenant_name unlock;
eval select locked from oceanbase.__all_tenant where tenant_name = '$tenant_name';
