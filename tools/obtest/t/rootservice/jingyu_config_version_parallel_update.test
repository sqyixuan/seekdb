###############################################################################
# CASE_OWNER:
#    @jingyu.cr
# CASE_DESC:
#    This case is aimed to test parallel update config version
#
###############################################################################

ob1=OBI(cluster=1:1:1:1,proxy_num=0,init_unit_cpu=0);
source include/mini_ob_config.inc;
ob1.set extra_config=$mini_ob_config;
ob1.z4.obs0.set status=disable;
ob1.reboot;

ob1.mysql alter system set debug_sync_timeout = '1000s';
ob1.mysql ALTER SYSTEM SET enable_rebalance = 'true';
ob1.mysql ALTER SYSTEM SET enable_rereplication = 'true';

let $proxy_ip = deploy_get_value(ob1.z1.obs0.ip);
let $proxy_port = deploy_get_value(ob1.z1.obs0.mysql_port);
connect(sys_conn1, $proxy_ip, root@sys,,oceanbase, $proxy_port);
connection sys_conn1;

--echo =========================================
--echo      construct initial parameters
--echo =========================================
# get servers' addr in z1, z2, z3, z4
let $z1_dst_ip0 = deploy_get_value(ob1.z1.obs0.ip);
let $z1_dst_port0 = deploy_get_value(ob1.z1.obs0.port);
let $z1_dst0 = $z1_dst_ip0:$z1_dst_port0;
let $z2_dst_ip0 = deploy_get_value(ob1.z2.obs0.ip);
let $z2_dst_port0 = deploy_get_value(ob1.z2.obs0.port);
let $z2_dst0 = $z2_dst_ip0:$z2_dst_port0;
let $z3_dst_ip0 = deploy_get_value(ob1.z3.obs0.ip);
let $z3_dst_port0 = deploy_get_value(ob1.z3.obs0.port);
let $z3_dst0 = $z3_dst_ip0:$z3_dst_port0;
let $z4_dst_ip0 = deploy_get_value(ob1.z4.obs0.ip);
let $z4_dst_port0 = deploy_get_value(ob1.z4.obs0.port);
let $z4_dst0 = $z4_dst_ip0:$z4_dst_port0;

--echo =========================================
--echo           add server in zone4
--echo =========================================
ob1.z4.add;
ob1.z4.start_zone;
ob1.z4.obs0.set extra_config=$mini_ob_config;
ob1.z4.obs0.set status=enable;
ob1.z4.obs0.start;
ob1.check_until_timeout select count(*) as cnt from oceanbase.__all_virtual_server_schema_info as a join oceanbase.__all_virtual_server_schema_info as b on a.tenant_id = b.tenant_id  where (a.refreshed_schema_version != b.refreshed_schema_version or a.refreshed_schema_version % 8 != 0) and a.tenant_id = 1, 0, 120;
ob1.z4.obs0.check_log_until_success -c "weak read service thread start";
ob1.z4.obs0.add;
ob1.check_until_timeout SELECT COUNT(*) c FROM DBA_OB_SERVERS WHERE START_SERVICE_TIME > 0, 4, 200;

--echo =========================================
--echo           create mysql tenant
--echo =========================================
# create mysql tenant with FFF
source include/create_unit_config.inc;
ob1.mysql CREATE RESOURCE POOL mysql_pool UNIT = "2c2g", UNIT_NUM = 1, ZONE_LIST = ('z1', 'z2', 'z4');
ob1.mysql CREATE TENANT mysql RESOURCE_POOL_LIST=('mysql_pool'), LOCALITY = "F@z1, F@z2, F@z4", PRIMARY_ZONE = "z1" SET ob_tcp_invited_nodes='%';
let $sys_tenant_id = 1;
let $tenant_id = deploy_get_value(ob1.select SELECT tenant_id FROM oceanbase.DBA_OB_TENANTS WHERE tenant_name = "mysql", tenant_id, 1);
let $meta_tenant_id = deploy_get_value(ob1.select select tenant_id - 1 as meta_tenant_id from oceanbase.DBA_OB_TENANTS where tenant_name = "mysql", meta_tenant_id, 1);
let $resource_pool_id = deploy_get_value(ob1.select SELECT resource_pool_id FROM oceanbase.__all_resource_pool WHERE tenant_id = $tenant_id, resource_pool_id, 1);

--echo =========================================
--echo     reset parameters to default value
--echo =========================================
# cluster parameter and tenant parameter
ob1.mysql ALTER SYSTEM SET enable_rereplication = 'true';
ob1.mysql ALTER SYSTEM SET enable_transfer = 'true' tenant = all;
ob1.check_until_timeout select count(*) as cnt from oceanbase.__all_virtual_sys_parameter_stat where name = "enable_rereplication" and value = "True", 4, 20;
ob1.check_until_timeout select count(*) as cnt from oceanbase.__all_virtual_tenant_parameter_stat where name = "enable_transfer" and value = "True" and tenant_id = $sys_tenant_id, 4, 20;
ob1.check_until_timeout select count(*) as cnt from oceanbase.__all_virtual_tenant_parameter_stat where name = "enable_transfer" and value = "True" and tenant_id = $tenant_id, 3, 20;
ob1.mysql ALTER SYSTEM SET enable_transfer = 'false' tenant = sys;
ob1.check_until_timeout select count(*) as cnt from oceanbase.__all_virtual_tenant_parameter_stat where name = "enable_transfer" and value = "False" and tenant_id = $sys_tenant_id, 4, 20;
ob1.mysql ALTER SYSTEM SET enable_transfer = 'false' tenant = mysql;
ob1.check_until_timeout select count(*) as cnt from oceanbase.__all_virtual_tenant_parameter_stat where name = "enable_transfer" and value = "False" and tenant_id = $tenant_id, 3, 20;
ob1.mysql ALTER SYSTEM SET enable_transfer = 'false' tenant = all_meta;
ob1.check_until_timeout select count(*) as cnt from oceanbase.__all_virtual_tenant_parameter_stat where name = "enable_transfer" and value = "False" and tenant_id = $meta_tenant_id, 3, 20;

--echo =========================================
--echo          hang sys config update
--echo   let it update smaller config version
--echo =========================================
ob1.mysql alter system set_tp tp_name = ERRSIM_UPDATE_MIN_CONFIG_VERSION_ERROR, error_code = 4002, frequency = 1;
# expect 4036, OB_NEED_RETRY
--error 4036
alter system set enable_rereplication = false;

--echo =========================================
--echo        hang tenant config update
--echo   let it update smaller config version
--echo =========================================
# expect 4036, OB_NEED_RETRY
--error 4036
ALTER SYSTEM SET enable_transfer = 'true' tenant = all;
ob1.check_until_timeout select count(*) as cnt from oceanbase.__all_virtual_tenant_parameter_stat where name = "enable_transfer" and value = "False" and tenant_id = $sys_tenant_id, 4, 20;
ob1.check_until_timeout select count(*) as cnt from oceanbase.__all_virtual_tenant_parameter_stat where name = "enable_transfer" and value = "False" and tenant_id = $meta_tenant_id, 3, 20;
ob1.check_until_timeout select count(*) as cnt from oceanbase.__all_virtual_tenant_parameter_stat where name = "enable_transfer" and value = "False" and tenant_id = $tenant_id, 3, 20;
# expect 4036, OB_NEED_RETRY
--error 4036
ALTER SYSTEM SET enable_transfer = 'true' tenant = sys;
ob1.check_until_timeout select count(*) as cnt from oceanbase.__all_virtual_tenant_parameter_stat where name = "enable_transfer" and value = "False" and tenant_id = $sys_tenant_id, 4, 20;
ob1.check_until_timeout select count(*) as cnt from oceanbase.__all_virtual_tenant_parameter_stat where name = "enable_transfer" and value = "False" and tenant_id = $meta_tenant_id, 3, 20;
ob1.check_until_timeout select count(*) as cnt from oceanbase.__all_virtual_tenant_parameter_stat where name = "enable_transfer" and value = "False" and tenant_id = $tenant_id, 3, 20;
# expect 4036, OB_NEED_RETRY
--error 4036
ALTER SYSTEM SET enable_transfer = 'true' tenant = mysql;
ob1.check_until_timeout select count(*) as cnt from oceanbase.__all_virtual_tenant_parameter_stat where name = "enable_transfer" and value = "False" and tenant_id = $sys_tenant_id, 4, 20;
ob1.check_until_timeout select count(*) as cnt from oceanbase.__all_virtual_tenant_parameter_stat where name = "enable_transfer" and value = "False" and tenant_id = $meta_tenant_id, 3, 20;
ob1.check_until_timeout select count(*) as cnt from oceanbase.__all_virtual_tenant_parameter_stat where name = "enable_transfer" and value = "False" and tenant_id = $tenant_id, 3, 20;
