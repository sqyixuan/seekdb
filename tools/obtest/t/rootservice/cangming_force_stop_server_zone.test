# CASE_OWNER:
#    @cangming.zl
# CASE_DESC:
#    强制stop zone/server

ob1=OBI(cluster=1:1:1,proxy_num=0,init_unit_cpu=0);
ob1.reboot;

ob1.mysql alter system set balancer_idle_time = '10s';

let $proxy_ip = deploy_get_value(ob1.z1.obs0.ip);
let $proxy_port = deploy_get_value(ob1.z1.obs0.mysql_port);
connect(sys_conn, $proxy_ip, root@sys,,oceanbase, $proxy_port);
connection sys_conn;

eval alter system force stop zone "z3";
eval alter system start zone "z3";

let $stop_ip = deploy_get_value(ob1.z3.obs0.ip);
let $stop_port = deploy_get_value(ob1.z3.obs0.port);
--disable_query_log
eval alter system force stop server "$stop_ip:$stop_port";
eval alter system start server "$stop_ip:$stop_port";
--enable_query_log
