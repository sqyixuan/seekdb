# CASE_OWNER:
#    @jingyu.cr
# CASE_DESC:
#   This case is aimed to test basic locality alignment for duplicate table 
#
#   1. create tenant with 2F
#   2. create table notmal_t1
#   3. create table duplicate_t1
#   4. change locality from "F@z1, F@z2"             to "F@z1, F@z2, R@z3"
#   5. change locality from "F@z1, F@z2, R@z3"       to "F@z1, F@z2, F@z3"
#   6. change locality from "F@z1, F@z2, F@z3"       to "F@z1, R@z2, R@z3"
#   7. change locality from "F@z1, F@z2, F@z3"       to "F@z1, F@z2, R@z3"
#   8. change locality from "F@z1, F@z2, R@z3"       to "F@z1, F@z2"
#


--echo =====================================================================
--echo                        create inital objects
--echo =====================================================================

ob1=OBI(cluster=2:2:2,proxy_num=0,init_unit_cpu=0);
source include/mini_ob_config.inc;
ob1.set extra_config=$mini_ob_config;
ob1.reboot;

ob1.mysql alter system set debug_sync_timeout = '1000s';
ob1.mysql ALTER SYSTEM SET enable_rebalance = 'false';
ob1.mysql ALTER SYSTEM SET enable_rereplication = 'true';

let $proxy_ip = deploy_get_value(ob1.z1.obs0.ip);
let $proxy_port = deploy_get_value(ob1.z1.obs0.mysql_port);
connect(sys_conn, $proxy_ip, root@sys,,oceanbase, $proxy_port);

# create new tenant tenant_for_duplicate
source include/create_unit_config.inc;
ob1.mysql CREATE RESOURCE POOL tenant_pool UNIT = "2c2g", UNIT_NUM = 2, ZONE_LIST = ('z1', 'z2', 'z3');
ob1.mysql CREATE TENANT tenant_for_duplicate RESOURCE_POOL_LIST=('tenant_pool'), LOCALITY = "F@z1, F@z2", PRIMARY_ZONE = "z1" SET ob_tcp_invited_nodes='%';

let $tenant_id = deploy_get_value(ob1.select SELECT tenant_id FROM oceanbase.DBA_OB_TENANTS WHERE tenant_name = "tenant_for_duplicate", tenant_id, 1);
let $meta_tenant_id = deploy_get_value(ob1.select select tenant_id - 1 as meta_tenant_id from oceanbase.DBA_OB_TENANTS where tenant_name = "tenant_for_duplicate", meta_tenant_id, 1);
let $resource_pool_id = deploy_get_value(ob1.select SELECT resource_pool_id FROM oceanbase.__all_resource_pool WHERE tenant_id = $tenant_id, resource_pool_id, 1);

# get servers' addr in z1, z2 and z3
let $z1_dst_ip0 = deploy_get_value(ob1.z1.obs0.ip);
let $z1_dst_ip1 = deploy_get_value(ob1.z1.obs1.ip);
let $z2_dst_ip0 = deploy_get_value(ob1.z2.obs0.ip);
let $z2_dst_ip1 = deploy_get_value(ob1.z2.obs1.ip);
let $z3_dst_ip0 = deploy_get_value(ob1.z3.obs0.ip);
let $z3_dst_ip1 = deploy_get_value(ob1.z3.obs1.ip);

let $z1_dst_port0 = deploy_get_value(ob1.z1.obs0.port);
let $z1_dst_port1 = deploy_get_value(ob1.z1.obs1.port);
let $z2_dst_port0 = deploy_get_value(ob1.z2.obs0.port);
let $z2_dst_port1 = deploy_get_value(ob1.z2.obs1.port);
let $z3_dst_port0 = deploy_get_value(ob1.z3.obs0.port);
let $z3_dst_port1 = deploy_get_value(ob1.z3.obs1.port);

let $z1_dst0 = $z1_dst_ip0:$z1_dst_port0;
let $z1_dst1 = $z1_dst_ip1:$z1_dst_port1;
let $z2_dst0 = $z2_dst_ip0:$z2_dst_port0;
let $z2_dst1 = $z2_dst_ip1:$z2_dst_port1;
let $z3_dst0 = $z3_dst_ip0:$z3_dst_port0;
let $z3_dst1 = $z3_dst_ip1:$z3_dst_port1;

# create table and insert data
ob_connect(conn_mysql, ob1.z1.obs0, root@tenant_for_duplicate, , test, , USE_MYSQL_CONNECTOR);
connection conn_mysql;
create table t1_no_pk (c1 int);
create table t1_dup_no_pk (c1 int) duplicate_scope = 'CLUSTER';
insert into t1_no_pk values (1), (2), (3);
insert into t1_dup_no_pk values (1), (2), (3);
select * from t1_no_pk order by c1 asc;
select * from t1_dup_no_pk order by c1 asc;
update t1_no_pk set c1=c1+10;
update t1_dup_no_pk set c1=c1+10;
select * from t1_no_pk order by c1 asc;
select * from t1_dup_no_pk order by c1 asc;

create table t1_pk (c1 int primary key);
create table t1_dup_pk (c1 int primary key) duplicate_scope = 'CLUSTER';
insert into t1_pk values (1), (2), (3);
insert into t1_dup_pk values (1), (2), (3);
select * from t1_pk order by c1 asc;
select * from t1_dup_pk order by c1 asc;
update t1_pk set c1=c1+10;
update t1_dup_pk set c1=c1+10;
select * from t1_pk order by c1 asc;
select * from t1_dup_pk order by c1 asc;

create table t1_part (c1 int primary key) partition by hash(c1) partitions 4;
create table t1_dup_part (c1 int primary key) duplicate_scope = 'CLUSTER' partition by hash(c1) partitions 4;
insert into t1_part values (1), (2), (3), (4);
insert into t1_dup_part values (1), (2), (3), (4);
select * from t1_part order by c1 asc;
select * from t1_dup_part order by c1 asc;
update t1_part set c1=c1+10;
update t1_dup_part set c1=c1+10;
select * from t1_part order by c1 asc;
select * from t1_dup_part order by c1 asc;
connect(sys_conn, $proxy_ip, root@sys,,oceanbase, $proxy_port);
alter system minor freeze tenant tenant_for_duplicate;
ob1.z1.obs0.check_log_until_success -c "succeed to release head data memtable";
ob1.z2.obs0.check_log_until_success -c "succeed to release head data memtable";
sleep 10;
connection conn_mysql;
insert into t1_no_pk values (4), (5), (6);
insert into t1_no_pk values (7), (8), (9);
insert into t1_no_pk values (10), (11), (12);
insert into t1_dup_no_pk values (4), (5), (6);
insert into t1_dup_no_pk values (7), (8), (9);
insert into t1_dup_no_pk values (10), (11), (12);
insert into t1_pk values (4), (5), (6);
insert into t1_pk values (7), (8), (9);
insert into t1_pk values (10);
insert into t1_dup_pk values (4), (5), (6);
insert into t1_dup_pk values (7), (8), (9);
insert into t1_dup_pk values (10);
insert into t1_part values (5), (6), (7), (8);
insert into t1_part values (9), (10), (21), (22);
insert into t1_dup_part values (5), (6), (7), (8);
insert into t1_dup_part values (9), (10), (21), (22);
connect(sys_conn, $proxy_ip, root@sys,,oceanbase, $proxy_port);
alter system minor freeze tenant tenant_for_duplicate;
ob1.z1.obs0.check_log_until_success -c "succeed to release head data memtable";
ob1.z2.obs0.check_log_until_success -c "succeed to release head data memtable";
sleep 10;
--echo "prepare finished"


--echo ======================================================================
--echo               0. check duplicate log stream in meta table
--echo ======================================================================
connection sys_conn;
let $sys_ls_id = 1;
let $duplicate_ls_id = deploy_get_value(ob1.select select distinct ls_id from oceanbase.CDB_OB_TABLE_LOCATIONS where table_name = "T1_DUP_NO_PK", ls_id, 1);
let $normal_ls_id_min = deploy_get_value(ob1.select select min(ls_id) as ls_id from oceanbase.CDB_OB_LS where tenant_id = $tenant_id and (ls_id != $duplicate_ls_id and ls_id != $sys_ls_id), ls_id, 1);
let $normal_ls_id_max = deploy_get_value(ob1.select select max(ls_id) as ls_id from oceanbase.CDB_OB_LS where tenant_id = $tenant_id and (ls_id != $duplicate_ls_id and ls_id != $sys_ls_id), ls_id, 1);

ob1.check_until_timeout select count(*) as ls_cnt from oceanbase.CDB_OB_LS where tenant_id = $tenant_id and flag like "%DUPLICATE%", 1, 5;
ob1.check_until_timeout select ls_id from oceanbase.CDB_OB_LS where tenant_id = $tenant_id and flag like "%DUPLICATE%", $duplicate_ls_id, 5;
ob1.check_until_timeout select count(*) as ls_cnt from oceanbase.CDB_OB_LS where tenant_id = $tenant_id and flag not like "%DUPLICATE%", 3, 5;

--echo check meta tenant has expected member_list and learner_list
ob1.check_until_timeout select count(*) as check_members_list from oceanbase.__all_virtual_log_stat where tenant_id = $meta_tenant_id and ls_id = $sys_ls_id and role like "%LEADER%" and (paxos_member_list like "%$z1_dst0%" or paxos_member_list like "%$z1_dst1%") and (paxos_member_list like "%$z2_dst0%" or paxos_member_list like "%$z2_dst1%") and (paxos_member_list not like "%$z3_dst0%" and paxos_member_list not like "%$z3_dst1%") and paxos_replica_num = 2 and learner_list = "", 1, 5;
ob1.check_until_timeout select count(*) as check_members_list from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id = $meta_tenant_id and ls_id = $sys_ls_id and role like "%LEADER%" and (member_list like "%$z1_dst0%" or member_list like "%$z1_dst1%") and (member_list like "%$z2_dst0%" or member_list like "%$z2_dst1%") and (member_list not like "%$z3_dst0%" and member_list not like "%$z3_dst1%") and learner_list = "", 1, 5;
--echo check user tenant has expected member_list and learner_list
--echo check user tenant sys ls
ob1.check_until_timeout select count(*) as check_members_list from oceanbase.__all_virtual_log_stat where tenant_id = $tenant_id and ls_id = $sys_ls_id and role like "%LEADER%" and (paxos_member_list like "%$z1_dst0%" or paxos_member_list like "%$z1_dst1%") and (paxos_member_list like "%$z2_dst0%" or paxos_member_list like "%$z2_dst1%") and (paxos_member_list not like "%$z3_dst0%" and paxos_member_list not like "%$z3_dst1%") and paxos_replica_num = 2 and learner_list = "", 1, 5;
ob1.check_until_timeout select count(*) as check_members_list from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id = $tenant_id and ls_id = $sys_ls_id and role like "%LEADER%" and (member_list like "%$z1_dst0%" or member_list like "%$z1_dst1%") and (member_list like "%$z2_dst0%" or member_list like "%$z2_dst1%") and (member_list not like "%$z3_dst0%" and member_list not like "%$z3_dst1%") and learner_list = "", 1, 5;
--echo check user tenant normal_ls_id_min ls
ob1.check_until_timeout select count(*) as check_members_list from oceanbase.__all_virtual_log_stat where tenant_id = $tenant_id and ls_id = $normal_ls_id_min and role like "%LEADER%" and (paxos_member_list like "%$z1_dst0%" or paxos_member_list like "%$z1_dst1%") and (paxos_member_list like "%$z2_dst0%" or paxos_member_list like "%$z2_dst1%") and (paxos_member_list not like "%$z3_dst0%" and paxos_member_list not like "%$z3_dst1%") and paxos_replica_num = 2 and learner_list = "", 1, 5;
ob1.check_until_timeout select count(*) as check_members_list from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id = $tenant_id and ls_id = $normal_ls_id_min and role like "%LEADER%" and (member_list like "%$z1_dst0%" or member_list like "%$z1_dst1%") and (member_list like "%$z2_dst0%" or member_list like "%$z2_dst1%") and (member_list not like "%$z3_dst0%" and member_list not like "%$z3_dst1%") and learner_list = "", 1, 5;
--echo check user tenant normal_ls_id_max ls
ob1.check_until_timeout select count(*) as check_members_list from oceanbase.__all_virtual_log_stat where tenant_id = $tenant_id and ls_id = $normal_ls_id_max and role like "%LEADER%" and (paxos_member_list like "%$z1_dst0%" or paxos_member_list like "%$z1_dst1%") and (paxos_member_list like "%$z2_dst0%" or paxos_member_list like "%$z2_dst1%") and (paxos_member_list not like "%$z3_dst0%" and paxos_member_list not like "%$z3_dst1%") and paxos_replica_num = 2 and learner_list = "", 1, 5;
ob1.check_until_timeout select count(*) as check_members_list from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id = $tenant_id and ls_id = $normal_ls_id_max and role like "%LEADER%" and (member_list like "%$z1_dst0%" or member_list like "%$z1_dst1%") and (member_list like "%$z2_dst0%" or member_list like "%$z2_dst1%") and (member_list not like "%$z3_dst0%" and member_list not like "%$z3_dst1%") and learner_list = "", 1, 5;
--echo check user tenant duplicate_ls_id ls
ob1.check_until_timeout select count(*) as check_members_list from oceanbase.__all_virtual_log_stat where tenant_id = $tenant_id and ls_id = $duplicate_ls_id and role like "%LEADER%" and (paxos_member_list like "%$z1_dst0%" or paxos_member_list like "%$z1_dst1%") and (paxos_member_list like "%$z2_dst0%" or paxos_member_list like "%$z2_dst1%") and (paxos_member_list not like "%$z3_dst0%" and paxos_member_list not like "%$z3_dst1%") and paxos_replica_num = 2 and (learner_list like "%$z1_dst0%" or learner_list like "%$z1_dst1%") and (learner_list like "%$z2_dst0%" or learner_list like "%$z2_dst1%") and (learner_list not like "%$z3_dst0%" and learner_list not like "%$z3_dst1%"), 1, 5;
ob1.check_until_timeout select count(*) as check_members_list from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id = $tenant_id and ls_id = $duplicate_ls_id and role like "%LEADER%" and (member_list like "%$z1_dst0%" or member_list like "%$z1_dst1%") and (member_list like "%$z2_dst0%" or member_list like "%$z2_dst1%") and (member_list not like "%$z3_dst0%" and member_list not like "%$z3_dst1%") and (learner_list like "%$z1_dst0%" or learner_list like "%$z1_dst1%") and (learner_list like "%$z2_dst0%" or learner_list like "%$z2_dst1%") and (learner_list not like "%$z3_dst0%" and learner_list not like "%$z3_dst1%"), 1, 5;

--echo =====================================================================
--echo                 1. alter locality from FF to FFR
--echo =====================================================================
connect(tenant_for_duplicate_conn, $proxy_ip, root@tenant_for_duplicate,,oceanbase, $proxy_port);
connection sys_conn;
ob1.mysql set ob_global_debug_sync = 'BEFORE_SEND_DRTASK_RPC wait_for signal execute 10000';
eval ALTER TENANT tenant_for_duplicate LOCALITY = "F@z1,F@z2,R@z3";

# let sys ls and normal ls finish alter locality first
ob1.mysql set ob_global_debug_sync = 'now signal signal';
ob1.mysql set ob_global_debug_sync = 'now signal signal';
ob1.mysql set ob_global_debug_sync = 'now signal signal';
ob1.mysql set ob_global_debug_sync = 'now signal signal';
# check only duplicate ls add replica not finished
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id = $tenant_id and ls_id != $duplicate_ls_id, 9, 120;
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id = $tenant_id and ls_id = $duplicate_ls_id, 4, 1;
# check alter locality job will not finish and wait for duplicate ls
sleep 20;
ob1.check_until_timeout select count(*) from oceanbase.DBA_OB_TENANTS where tenant_id = $tenant_id and previous_locality is not NULL, 1, 1;

# clear debug_sync and finish
ob1.mysql set ob_global_debug_sync = 'now signal signal';
ob1.mysql set ob_global_debug_sync = 'now signal signal';
ob1.mysql set ob_global_debug_sync = 'BEFORE_SEND_DRTASK_RPC clear';
ob1.check_until_timeout select count(*) from oceanbase.DBA_OB_TENANTS where tenant_id = $tenant_id and previous_locality is NULL and locality like "%FULL{1}@z1, FULL{1}@z2, READONLY{1}@z3%", 1, 120;
--echo check task generated
ob1.check_until_timeout select count(*) as task_cnt from oceanbase.DBA_OB_ROOTSERVICE_EVENT_HISTORY where module like "%disaster%" and value1 = $meta_tenant_id and value2 = $sys_ls_id and event like "%start_add_ls_replica%" and value6 like "%add non-paxos replica according to locality%", 1, 5;
ob1.check_until_timeout select count(*) as task_cnt from oceanbase.DBA_OB_ROOTSERVICE_EVENT_HISTORY where module like "%disaster%" and value1 = $tenant_id and value2 = $sys_ls_id and event like "%start_add_ls_replica%" and value6 like "%add non-paxos replica according to locality%", 1, 5;
ob1.check_until_timeout select count(*) as task_cnt from oceanbase.DBA_OB_ROOTSERVICE_EVENT_HISTORY where module like "%disaster%" and value1 = $tenant_id and value2 = $normal_ls_id_min and event like "%start_add_ls_replica%" and value6 like "%add non-paxos replica according to locality%", 1, 5;
ob1.check_until_timeout select count(*) as task_cnt from oceanbase.DBA_OB_ROOTSERVICE_EVENT_HISTORY where module like "%disaster%" and value1 = $tenant_id and value2 = $normal_ls_id_max and event like "%start_add_ls_replica%" and value6 like "%add non-paxos replica according to locality%", 1, 5;
ob1.check_until_timeout select count(*) as task_cnt from oceanbase.DBA_OB_ROOTSERVICE_EVENT_HISTORY where module like "%disaster%" and value1 = $tenant_id and value2 = $duplicate_ls_id and event like "%start_add_ls_replica%" and value4 like "%$z3_dst0%" and value6 like "%add non-paxos replica according to locality%", 1, 5;
ob1.check_until_timeout select count(*) as task_cnt from oceanbase.DBA_OB_ROOTSERVICE_EVENT_HISTORY where module like "%disaster%" and value1 = $tenant_id and value2 = $duplicate_ls_id and event like "%start_add_ls_replica%" and value4 like "%$z3_dst1%" and value6 like "%add non-paxos replica according to locality%", 1, 5;

--echo check meta tenant has expected member_list and learner_list
ob1.check_until_timeout select count(*) as check_members_list from oceanbase.__all_virtual_log_stat where tenant_id = $meta_tenant_id and ls_id = $sys_ls_id and role like "%LEADER%" and (paxos_member_list like "%$z1_dst0%" or paxos_member_list like "%$z1_dst1%") and (paxos_member_list like "%$z2_dst0%" or paxos_member_list like "%$z2_dst1%") and (paxos_member_list not like "%$z3_dst0%" and paxos_member_list not like "%$z3_dst1%") and paxos_replica_num = 2 and (learner_list not like "%$z1_dst0%" and learner_list not like "%$z1_dst1%") and (learner_list not like "%$z2_dst0%" and learner_list not like "%$z2_dst1%") and (learner_list like "%$z3_dst0%" or learner_list like "%$z3_dst1%"), 1, 5;
ob1.check_until_timeout select count(*) as check_members_list from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id = $meta_tenant_id and ls_id = $sys_ls_id and role like "%LEADER%" and (member_list like "%$z1_dst0%" or member_list like "%$z1_dst1%") and (member_list like "%$z2_dst0%" or member_list like "%$z2_dst1%") and (member_list not like "%$z3_dst0%" and member_list not like "%$z3_dst1%") and (learner_list not like "%$z1_dst0%" and learner_list not like "%$z1_dst1%") and (learner_list not like "%$z2_dst0%" and learner_list not like "%$z2_dst1%") and (learner_list like "%$z3_dst0%" or learner_list like "%$z3_dst1%"), 1, 5;
--echo check user tenant has expected member_list and learner_list
--echo check user tenant sys ls
ob1.check_until_timeout select count(*) as check_members_list from oceanbase.__all_virtual_log_stat where tenant_id = $tenant_id and ls_id = $sys_ls_id and role like "%LEADER%" and (paxos_member_list like "%$z1_dst0%" or paxos_member_list like "%$z1_dst1%") and (paxos_member_list like "%$z2_dst0%" or paxos_member_list like "%$z2_dst1%") and (paxos_member_list not like "%$z3_dst0%" and paxos_member_list not like "%$z3_dst1%") and paxos_replica_num = 2 and (learner_list not like "%$z1_dst0%" and learner_list not like "%$z1_dst1%") and (learner_list not like "%$z2_dst0%" and learner_list not like "%$z2_dst1%") and (learner_list like "%$z3_dst0%" or learner_list like "%$z3_dst1%"), 1, 5;
ob1.check_until_timeout select count(*) as check_members_list from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id = $tenant_id and ls_id = $sys_ls_id and role like "%LEADER%" and (member_list like "%$z1_dst0%" or member_list like "%$z1_dst1%") and (member_list like "%$z2_dst0%" or member_list like "%$z2_dst1%") and (member_list not like "%$z3_dst0%" and member_list not like "%$z3_dst1%") and (learner_list not like "%$z1_dst0%" and learner_list not like "%$z1_dst1%") and (learner_list not like "%$z2_dst0%" and learner_list not like "%$z2_dst1%") and (learner_list like "%$z3_dst0%" or learner_list like "%$z3_dst1%"), 1, 5;
--echo check user tenant normal_ls_id_min ls
ob1.check_until_timeout select count(*) as check_members_list from oceanbase.__all_virtual_log_stat where tenant_id = $tenant_id and ls_id = $normal_ls_id_min and role like "%LEADER%" and (paxos_member_list like "%$z1_dst0%" or paxos_member_list like "%$z1_dst1%") and (paxos_member_list like "%$z2_dst0%" or paxos_member_list like "%$z2_dst1%") and (paxos_member_list not like "%$z3_dst0%" and paxos_member_list not like "%$z3_dst1%") and paxos_replica_num = 2 and (learner_list not like "%$z1_dst0%" and learner_list not like "%$z1_dst1%") and (learner_list not like "%$z2_dst0%" and learner_list not like "%$z2_dst1%") and (learner_list like "%$z3_dst0%" or learner_list like "%$z3_dst1%"), 1, 5;
ob1.check_until_timeout select count(*) as check_members_list from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id = $tenant_id and ls_id = $normal_ls_id_min and role like "%LEADER%" and (member_list like "%$z1_dst0%" or member_list like "%$z1_dst1%") and (member_list like "%$z2_dst0%" or member_list like "%$z2_dst1%") and (member_list not like "%$z3_dst0%" and member_list not like "%$z3_dst1%") and (learner_list not like "%$z1_dst0%" and learner_list not like "%$z1_dst1%") and (learner_list not like "%$z2_dst0%" and learner_list not like "%$z2_dst1%") and (learner_list like "%$z3_dst0%" or learner_list like "%$z3_dst1%"), 1, 5;
--echo check user tenant normal_ls_id_max ls
ob1.check_until_timeout select count(*) as check_members_list from oceanbase.__all_virtual_log_stat where tenant_id = $tenant_id and ls_id = $normal_ls_id_max and role like "%LEADER%" and (paxos_member_list like "%$z1_dst0%" or paxos_member_list like "%$z1_dst1%") and (paxos_member_list like "%$z2_dst0%" or paxos_member_list like "%$z2_dst1%") and (paxos_member_list not like "%$z3_dst0%" and paxos_member_list not like "%$z3_dst1%") and paxos_replica_num = 2 and (learner_list not like "%$z1_dst0%" and learner_list not like "%$z1_dst1%") and (learner_list not like "%$z2_dst0%" and learner_list not like "%$z2_dst1%") and (learner_list like "%$z3_dst0%" or learner_list like "%$z3_dst1%"), 1, 5;
