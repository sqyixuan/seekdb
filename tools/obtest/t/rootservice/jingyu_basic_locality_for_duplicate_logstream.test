ob1.check_until_timeout select count(*) as check_members_list from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id = $tenant_id and ls_id = $normal_ls_id_min and role like "%LEADER%" and (member_list like "%$z1_dst0%" or member_list like "%$z1_dst1%") and (member_list like "%$z2_dst0%" or member_list like "%$z2_dst1%") and (member_list not like "%$z3_dst0%" and member_list not like "%$z3_dst1%") and learner_list = "", 1, 5;
