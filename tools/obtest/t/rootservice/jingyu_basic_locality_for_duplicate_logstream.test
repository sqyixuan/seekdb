--echo check user tenant duplicate_ls_id ls
ob1.check_until_timeout select count(*) as check_members_list from oceanbase.__all_virtual_log_stat where tenant_id = $tenant_id and ls_id = $duplicate_ls_id and role like "%LEADER%" and (paxos_member_list like "%$z1_dst0%" or paxos_member_list like "%$z1_dst1%") and (paxos_member_list like "%$z2_dst0%" or paxos_member_list like "%$z2_dst1%") and (paxos_member_list not like "%$z3_dst0%" and paxos_member_list not like "%$z3_dst1%") and paxos_replica_num = 2 and (learner_list like "%$z1_dst0%" or learner_list like "%$z1_dst1%") and (learner_list like "%$z2_dst0%" or learner_list like "%$z2_dst1%") and (learner_list not like "%$z3_dst0%" and learner_list not like "%$z3_dst1%"), 1, 5;
ob1.check_until_timeout select count(*) as check_members_list from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id = $tenant_id and ls_id = $duplicate_ls_id and role like "%LEADER%" and (member_list like "%$z1_dst0%" or member_list like "%$z1_dst1%") and (member_list like "%$z2_dst0%" or member_list like "%$z2_dst1%") and (member_list not like "%$z3_dst0%" and member_list not like "%$z3_dst1%") and (learner_list like "%$z1_dst0%" or learner_list like "%$z1_dst1%") and (learner_list like "%$z2_dst0%" or learner_list like "%$z2_dst1%") and (learner_list not like "%$z3_dst0%" and learner_list not like "%$z3_dst1%"), 1, 5;
