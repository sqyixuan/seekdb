ob1.check_until_timeout select count(*) as task_cnt from oceanbase.DBA_OB_ROOTSERVICE_EVENT_HISTORY where module like "%disaster%" and value1 = $tenant_id and value2 = $duplicate_ls_id and event like "%start_remove_ls_non_paxos_replica%" and value6 like "%remove redundant non-paxos replica according to locality%" and value5 like "%$z3_dst1%" and value5 like "%replica_type:16%", 1, 5;

--echo check meta tenant has expected member_list and learner_list
ob1.check_until_timeout select count(*) as check_members_list from oceanbase.__all_virtual_log_stat where tenant_id = $meta_tenant_id and ls_id = $sys_ls_id and role like "%LEADER%" and (paxos_member_list like "%$z1_dst0%" or paxos_member_list like "%$z1_dst1%") and (paxos_member_list like "%$z2_dst0%" or paxos_member_list like "%$z2_dst1%") and (paxos_member_list not like "%$z3_dst0%" and paxos_member_list not like "%$z3_dst1%") and paxos_replica_num = 2 and learner_list = "", 1, 5;
ob1.check_until_timeout select count(*) as check_members_list from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id = $meta_tenant_id and ls_id = $sys_ls_id and role like "%LEADER%" and (member_list like "%$z1_dst0%" or member_list like "%$z1_dst1%") and (member_list like "%$z2_dst0%" or member_list like "%$z2_dst1%") and (member_list not like "%$z3_dst0%" and member_list not like "%$z3_dst1%") and learner_list = "", 1, 5;
--echo check user tenant has expected member_list and learner_list
--echo check user tenant sys ls
ob1.check_until_timeout select count(*) as check_members_list from oceanbase.__all_virtual_log_stat where tenant_id = $tenant_id and ls_id = $sys_ls_id and role like "%LEADER%" and (paxos_member_list like "%$z1_dst0%" or paxos_member_list like "%$z1_dst1%") and (paxos_member_list like "%$z2_dst0%" or paxos_member_list like "%$z2_dst1%") and (paxos_member_list not like "%$z3_dst0%" and paxos_member_list not like "%$z3_dst1%") and paxos_replica_num = 2 and learner_list = "", 1, 5;
ob1.check_until_timeout select count(*) as check_members_list from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id = $tenant_id and ls_id = $sys_ls_id and role like "%LEADER%" and (member_list like "%$z1_dst0%" or member_list like "%$z1_dst1%") and (member_list like "%$z2_dst0%" or member_list like "%$z2_dst1%") and (member_list not like "%$z3_dst0%" and member_list not like "%$z3_dst1%") and learner_list = "", 1, 5;
