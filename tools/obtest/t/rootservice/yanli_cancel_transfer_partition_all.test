##########################
#owner :msy164651
# 测试点： cancel transfer partition all
##########################

ob1=OBI(cluster=2:2,proxy_num=0);
source include/mini_ob_config.inc;
ob1.set extra_config=$mini_ob_config;
ob1.reboot;

ob_connect(conn_sys, ob1.z1.obs0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);

connection conn_sys;
alter system set balancer_idle_time = '10s';
ob1.mysql alter system set debug_sync_timeout = '1000s';
ob1.mysql alter system set _transfer_start_trans_timeout = '10s';

set @@session.ob_query_timeout = 1000000000;
#
eval CREATE RESOURCE UNIT unit_1 MAX_CPU 1, MEMORY_SIZE '2G';
eval CREATE RESOURCE POOL pool_2 UNIT = 'unit_1', UNIT_NUM = 2, zone_list = ('z1','z2');
eval CREATE TENANT mysql RESOURCE_POOL_LIST = ('pool_2'), primary_zone='z1, z2' set ob_tcp_invited_nodes='%', autocommit='on';
let $tenant_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name = 'mysql', tenant_id, 1);
ob1.mysql alter system set balancer_idle_time = '10s' tenant = 'mysql';
ob1.mysql alter system set _transfer_service_wakeup_interval = '5s' tenant = 'mysql';
ob1.mysql alter system set _transfer_task_tablet_count_threshold = 8 tenant = 'mysql';
ob1.mysql alter system set partition_balance_schedule_interval = '0s' tenant = 'mysql';
sleep 2;
ob_connect(conn1, ob1.z1.obs0, root@mysql, , test, , USE_OB_CONNECTOR);
connection conn1;
set recyclebin=off;
create tablegroup tg sharding = 'NONE';
create table t1(c1 int primary key, c2 int, c3 longtext)  tablegroup = 'tg'partition by hash(c1) partitions 200;
create table t2(c1 int primary key, c2 int, c3 longtext)  tablegroup = 'tg'partition by hash(c1) partitions 4;

#验证存在不同状态的任务时，可以cancel all
ob1.mysql set ob_global_debug_sync = 'BEFORE_TENANT_BALANCE_SERVICE wait_for signal';
let $count = 0;
connection conn_sys;
let $table_id = deploy_get_value(ob1.select select table_id from oceanbase.cdb_ob_table_locations where table_name = 't1', table_id, 1);
let $src_ls = deploy_get_value(ob1.select select ls_id from oceanbase.cdb_ob_table_locations where table_id = $table_id, ls_id, 1);
let $dest_ls = deploy_get_value(ob1.select select ls_id from oceanbase.__all_virtual_ls_status where tenant_id = $tenant_id and ls_id != 1 and ls_id != $src_ls, ls_id, 1);
--disable_query_log
while ($count < 200) 
{
let $part_id = deploy_get_value(ob1.select select object_id from oceanbase.cdb_ob_table_locations where table_name = 't1' and PARTITION_NAME = 'p$count', object_id, 1);
eval alter system transfer partition table_id = $table_id, object_id = $part_id to ls $dest_ls tenant = 'mysql';
inc $count;
}
--enable_query_log
ob1.mysql set ob_global_debug_sync = 'now signal signal';
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_balance_job, 1, 100;
ob1.check_until_timeout select count(*) > 0 from oceanbase.__all_virtual_transfer_task, 1, 20;
ob1.mysql set ob_global_debug_sync = 'BEFORE_PROCESS_BALANCE_TASK_TRANSFER_END wait_for signal2';
let $count = 0;
connection conn_sys;
--disable_query_log
while ($count < 4) 
{
let $table_id = deploy_get_value(ob1.select select table_id from oceanbase.cdb_ob_table_locations where table_name = 't2', table_id, 1);
let $part_id = deploy_get_value(ob1.select select object_id from oceanbase.cdb_ob_table_locations where table_name = 't2' and PARTITION_NAME = 'p$count', object_id, 1);
eval alter system transfer partition table_id = $table_id, object_id = $part_id to ls $dest_ls tenant = 'mysql';
inc $count;
}
--enable_query_log
ob1.mysql_p select distinct status from oceanbase.__all_virtual_transfer_partition_task order by status;
connection conn_sys;
--error 4025
alter system cancel transfer partition all tenant = 'mysql';
ob1.mysql set ob_global_debug_sync = 'now signal signal2';
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_balance_job, 0, 200;
ob1.mysql_p select count(*) from  oceanbase.__all_virtual_transfer_partition_task;
ob1.mysql_p select distinct status, comment from oceanbase.__all_virtual_transfer_partition_task_history where task_id > 0 order by status;

#验证task全都是doing状态，part_list不需要更新的场景，两个task，一个全是doing，一个全是init
connection conn1;
set recyclebin=off;
#预期应该分布在四个日志流上
create table t3(c1 int primary key, c2 int, c3 longtext)  partition by hash(c1) partitions 16;

ob1.mysql set ob_global_debug_sync = 'BEFORE_TENANT_BALANCE_SERVICE wait_for signal';
ob1.mysql set ob_global_debug_sync = 'BEFORE_PROCESS_BALANCE_TASK_TRANSFER_END wait_for signal2';
let $table_id = deploy_get_value(ob1.select select table_id from oceanbase.cdb_ob_table_locations where table_name = 't3', table_id, 1);
--disable_query_log
let $count = 0;
while ($count < 16) 
{
let $src_ls = deploy_get_value(ob1.select select ls_id from oceanbase.cdb_ob_table_locations where table_id = $table_id and PARTITION_NAME = 'p$count', ls_id, 1);
let $src_ls_group = deploy_get_value(ob1.select select ls_group_id from  oceanbase.__all_virtual_ls_status where tenant_id = $tenant_id and ls_id = $src_ls, ls_group_id, 1);
let $part_id = deploy_get_value(ob1.select select object_id from oceanbase.cdb_ob_table_locations where table_name = 't3' and PARTITION_NAME = 'p$count', object_id, 1);
let $dest_ls = deploy_get_value(ob1.select select ls_id from oceanbase.__all_virtual_ls_status where tenant_id = $tenant_id and ls_id != 1 and ls_id != $src_ls and ls_group_id = $src_ls_group, ls_id, 1);
eval alter system transfer partition table_id = $table_id, object_id = $part_id to ls $dest_ls tenant = 'mysql';
inc $count;
}
--enable_query_log
ob1.mysql set ob_global_debug_sync = 'now signal signal';
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_balance_job, 1, 100;
ob1.check_until_timeout select count(*) > 0 from oceanbase.__all_virtual_transfer_task, 1, 20;
ob1.mysql_p select status, count(*) from oceanbase.__all_virtual_transfer_partition_task group by status order by status;
connection conn_sys;
--error 4025
alter system cancel transfer partition all tenant = 'mysql';
ob1.mysql set ob_global_debug_sync = 'now signal signal2';
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_balance_job, 0, 200;

#验证全是init状态的cancel all，日志流个数不会发生变化
connection conn1; 
create table t4(c1 int primary key, c2 int, c3 longtext)  partition by hash(c1) partitions 16;
ob1.mysql set ob_global_debug_sync = 'BEFORE_TENANT_BALANCE_SERVICE wait_for signal';
ob1.mysql set ob_global_debug_sync = 'BEFORE_PROCESS_BALANCE_EXECUTE_WORK wait_for signal2';

let $table_id = deploy_get_value(ob1.select select table_id from oceanbase.cdb_ob_table_locations where table_name = 't4', table_id, 1);
--disable_query_log
let $count = 0;
while ($count < 16) 
{
let $src_ls = deploy_get_value(ob1.select select ls_id from oceanbase.cdb_ob_table_locations where table_id = $table_id and PARTITION_NAME = 'p$count', ls_id, 1);
let $src_ls_group = deploy_get_value(ob1.select select ls_group_id from  oceanbase.__all_virtual_ls_status where tenant_id = $tenant_id and ls_id = $src_ls, ls_group_id, 1);
let $part_id = deploy_get_value(ob1.select select object_id from oceanbase.cdb_ob_table_locations where table_name = 't4' and PARTITION_NAME = 'p$count', object_id, 1);
let $dest_ls = deploy_get_value(ob1.select select ls_id from oceanbase.__all_virtual_ls_status where tenant_id = $tenant_id and ls_id != 1 and ls_id != $src_ls and ls_group_id != $src_ls_group, ls_id, 1);
eval alter system transfer partition table_id = $table_id, object_id = $part_id to ls $dest_ls tenant = 'mysql';
inc $count;
}
--enable_query_log
ob1.mysql set ob_global_debug_sync = 'now signal signal';
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_balance_job, 1, 100;
sleep 3;
ob1.mysql_p select status, count(*) from oceanbase.__all_virtual_transfer_partition_task group by status order by status;
connection conn_sys;
alter system cancel transfer partition all tenant = 'mysql';
ob1.mysql set ob_global_debug_sync = 'now signal signal2';
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_balance_job, 0, 200;

ob1.mysql_p select status from oceanbase.__all_virtual_balance_job_history;
