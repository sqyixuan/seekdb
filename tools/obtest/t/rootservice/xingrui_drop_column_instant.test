# CASE_OWNER:
#    @xingrui.cwh
# CASE_DESC:
#    验证快速删列和行存列存+合并时的场景
ob1=OBI(cluster=1:1,proxy_num=0);
source include/mini_ob_config.inc;
ob1.set extra_config=$mini_ob_config;
ob1.reboot;
ob_connect(sys, ob1.z1.obs0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);
connection sys;
set @@session.ob_query_timeout = 1000000000;
#create tenant
eval CREATE RESOURCE UNIT xingrui_drop_column_instant_unit MAX_CPU 2, MEMORY_SIZE '2G';
eval CREATE RESOURCE POOL xingrui_drop_column_instant_pool UNIT = 'xingrui_drop_column_instant_unit', UNIT_NUM = 1;
eval CREATE TENANT xingrui_drop_column_instant RESOURCE_POOL_LIST = ('xingrui_drop_column_instant_pool'), primary_zone='z1,z2' set ob_tcp_invited_nodes='%', ob_compatibility_mode='oracle';
connection sys;
let $tenant_id = query_get_value(select tenant_id from __all_tenant where tenant_name = 'xingrui_drop_column_instant', tenant_id, 1);

ob_connect(oracle_sys, ob1.z1.obs0, SYS@xingrui_drop_column_instant, ,SYS, , USE_OB_CONNECTOR);
connection oracle_sys;
set global wait_timeout = 288000;
create user test IDENTIFIED BY "test";
grant all on *.* to test WITH GRANT OPTION;
grant dba to test;
ob_connect(conn_oracle, ob1.z1.obs0, SYS@xingrui_drop_column_instant,,TEST,,USE_OB_CONNECTOR);

connection conn_oracle;
#1.each column group
#1.1 each column group with create table
create table each_column_group (col1 varchar2(30) not null, col2 varchar2(30) not null, col3 varchar2(30) not null, col4 varchar2(30) not null, col5 int, col6 xmltype) with column group (each column);
insert into each_column_group values('a', 'b', 'c', 'd', 1, '<a>test_xmltype</a>');
alter table each_column_group add col7 int generated always as (col5 + 1);
alter table each_column_group add col8 clob, add col9 clob;
insert into each_column_group (col1, col2, col3, col4, col5, col6, col8, col9) values('a', 'b', 'c', 'd', 1, '<a>test_xmltype</a>', 'a', 'b');
alter table each_column_group drop column col7;
insert into each_column_group (col1, col2, col3, col4, col5, col6, col8, col9) values('a', 'b', 'c', 'd', 1, '<a>test_xmltype</a>', 'a', 'b');
select * from each_column_group;
alter table each_column_group drop column col3;
insert into each_column_group (col1, col2, col4, col5, col6, col8, col9) values('a', 'b', 'd', 1, '<a>test_xmltype</a>', 'a', 'b');
select * from each_column_group;
alter table each_column_group drop column col8;
insert into each_column_group (col1, col2, col4, col5, col6, col9) values('a', 'b', 'd', 1, '<a>test_xmltype</a>', 'b');
select * from each_column_group;
alter table each_column_group drop column group (each column);
insert into each_column_group (col1, col2, col4, col5, col6, col9) values('a', 'b', 'd', 1, '<a>test_xmltype</a>', 'b');
truncate table each_column_group;
insert into each_column_group (col1, col2, col4, col5, col6, col9) values('aa', 'bb', 'dd', 2, '<a>test_xmltype1</a>', 'bb');
select * from each_column_group;

