connection sys;
alter system major freeze tenant = 'xingrui_drop_column_instant';

let $i= 600;
while($i > 0)
{
    sleep 1;
    dec $i;
    let $frozen_scn = query_get_value(select sum(frozen_scn/1000) as sum_value from CDB_OB_MAJOR_COMPACTION where tenant_id = $tenant_id, sum_value, 1);
    let $merged_version = query_get_value(select sum(last_scn/1000) as sum_value from CDB_OB_MAJOR_COMPACTION where tenant_id = $tenant_id, sum_value, 1);
    if($frozen_scn == $merged_version)
    {
        let $i = -1;
    }
}
if($i != -1)
{
    --echo major freeze failed
}

