let $object_id =  deploy_get_value(ob1.select select object_id from oceanbase.cdb_ob_table_locations where index_name = 'il1_$count', object_id, 1);
let $src_ls = deploy_get_value(ob1.select select ls_id from oceanbase.cdb_ob_table_locations where table_id = $table_id and object_id = $object_id, ls_id, 1);
let $dest_ls = deploy_get_value(ob1.select select ls_id from oceanbase.__all_virtual_ls_status where tenant_id = $tenant_id and ls_id != 1 and ls_id != $src_ls, ls_id, 1);
eval alter system transfer partition table_id = $table_id, object_id = $object_id to ls $dest_ls;
inc $count;
}
connection conn_sys;
ob1.mysql set ob_global_debug_sync = 'now signal signal';
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_balance_job, 1, 150;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_transfer_partition_task, 0, 230;

