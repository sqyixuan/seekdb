# 测试场景2F1A：
# 1. 启动仲裁服务/server;
# 2. 添加仲裁服务到ob集群;
# 3. 建租户时指定开启仲裁服务；
# 4. 为sys租户开启仲裁服务;
# 5. kill followr触发降级;测试备库 sts继续推进
# 6. 建表、写入数据;
# 7. 启动follower，测试升级;测试备库 sts继续推进

ob1=OBI(cluster=1:1:1, proxy_num=0, asvr_num=1);

source include/mini_ob_config.inc;
let $extra_conf = "cpu_count=16,memory_limit='20G',system_memory='7G',__min_full_resource_pool_memory='1073741824',stack_size='1536K',cache_wash_threshold='1G',_ob_minor_merge_schedule_interval='3s'";
let $arb_extra_conf = "ob_startup_mode=arbitration,cpu_count=8,memory_limit='20G',system_memory='5G',__min_full_resource_pool_memory='1073741824',stack_size='1536K',cache_wash_threshold='1G',log_disk_size='20G'";
ob1.z1.obs0.set extra_config=$extra_conf;
ob1.z2.obs0.set extra_config=$extra_conf;
ob1.z3.obs0.set extra_config=$extra_conf;



let $backup_cluster_name = deploy_get_value(ob1.get_cluster_name);
let $backup_cluster_id = deploy_get_value(ob1.get_cluster_id);
let $backup_ip       = deploy_get_value(ob1.z1.obs0.ip);
let $backup_port     = deploy_get_value(ob1.z1.obs0.mysql_port);
let $restore_ip         = deploy_get_value(ob1.z1.obs0.ip);
let $restore_port       = deploy_get_value(ob1.z1.obs0.mysql_port);
let $backup_dest = deploy_get_value(ob1.get_backup_dest);
let $backup_mysql_tenant   = backup_mysql_tenant;
let $backup_mysql_tenant    = backup_mysql_tenant;
let $restore_mysql_tenant = restore_mysql_tenant;
let $restore_mysql_tenant_new = restore_mysql_tenant_new;
let $restore_mysql_tenant = restore_mysql_tenant;
let $log_backup_dest = deploy_get_value(ob1.get_log_backup_dest $backup_mysql_tenant);
let $data_backup_dest = deploy_get_value(ob1.get_data_backup_dest $backup_mysql_tenant);
let $restore_log_archive_dest = deploy_get_value(ob1.get_log_backup_dest $restore_mysql_tenant);

# 必须先stop掉老的，删除才能有效，不然可能会有残留。
ob1.force_stop;
ob1.clean_backup_dest;

# bootstrap
ob1.reboot;
sleep 3;

# 固定sys租户规格
ob1.mysql alter resource unit sys_unit_config memory_size='2G';

ob1.mysql alter system set _backup_idle_time = '10s';
ob1.mysql alter system set merger_check_interval = '10s';
ob1.mysql alter system set enable_async_syslog=false;

ob1.mysql alter tenant sys locality='F@z1, F@z2, F@z3';
ob1.check_until_timeout select count(*) from oceanbase.__all_tenant where tenant_name = "sys" and previous_locality != "", 0, 300;
ob_connect(conn_sys1, ob1.z1.obs0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);

# 获取仲裁server的ip、port, 检查仲裁server是否成功运行
let $arb_svr_ip= deploy_get_value(ob1.asvr0.ip);
let $arb_svr_port= deploy_get_value(ob1.asvr0.port);
ob1.check_until_timeout select count(*) from __all_arbitration_service where arbitration_service = "$arb_svr_ip:$arb_svr_port", 1, 30;

# case1. 建租户时指定开启仲裁服务;
let $cpu = 1;
let $memory = 1073741824;
let $min_memory = 1073741824;
let $disk = 536870912;
let $iops = 100000;
let $session = 64;
set @@session.ob_query_timeout = 1000000000;
# create mysql tenant (2F1A)
eval CREATE RESOURCE UNIT unit_1 MAX_CPU 1, MEMORY_SIZE='2G';
eval CREATE RESOURCE POOL pool_1 UNIT = 'unit_1', UNIT_NUM = 1, zone_list = ('z1', 'z2');
eval CREATE TENANT backup_mysql_tenant RESOURCE_POOL_LIST = ('pool_1'),  locality='F@z1, F@z2', primary_zone='RANDOM', enable_arbitration_service=true set ob_tcp_invited_nodes='%';
ob1.mysql alter system set ls_gc_delay_time = '0s' tenant='backup_mysql_tenant';
let $backup_mysql_tenant_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name='$backup_mysql_tenant', tenant_id, 1);

let $ob1_follower_ip_port1=deploy_get_value(ob1.select select concat(svr_ip,':',svr_port) as host from oceanbase.__all_virtual_ls_meta_table where tenant_id = $backup_mysql_tenant_id and ls_id =  1001 and role = 2 order by svr_port limit 1, host, 1);
let $ob1_follower_ip1=deploy_get_value(ob1.select select svr_ip from oceanbase.__all_virtual_ls_meta_table where tenant_id = $backup_mysql_tenant_id and ls_id =  1001 and role = 2 order by svr_port limit 1, svr_ip, 1);
let $ob1_follower_port1=deploy_get_value(ob1.select select svr_port from oceanbase.__all_virtual_ls_meta_table where tenant_id = $backup_mysql_tenant_id and ls_id = 1001 and role = 2 order by svr_port limit 1, svr_port, 1);
let $ob1_follower1_obs=deploy_get_value(ob1.get_obs_by_addr $ob1_follower_ip_port1);

# check arbitration member exist for tenant's ls
ob1.check_until_timeout select count(*) from __all_virtual_log_stat where tenant_id=$backup_mysql_tenant_id and arbitration_member like "%$arb_svr_ip:$arb_svr_port%", 6, 30;

# 获取leader、follower位置信息
let $ob1_z1_ip = deploy_get_value(ob1.z1.obs0.ip);
let $ob1_z1_port = deploy_get_value(ob1.z1.obs0.port);
let $ob1_z2_ip = deploy_get_value(ob1.z2.obs0.ip);
let $ob1_z2_port = deploy_get_value(ob1.z2.obs0.port);
let $ob1_z3_ip = deploy_get_value(ob1.z3.obs0.ip);
let $ob1_z3_port = deploy_get_value(ob1.z3.obs0.port);


#mysql租户  创建tablet
ob_connect(sys_conn_mysql, ob1.z1.obs0, root@$backup_mysql_tenant, ,oceanbase, , USE_MYSQL_CONNECTOR);
connection sys_conn_mysql;
set global wait_timeout = 288000;

--disable_all_result_log
eval alter system set data_backup_dest='$data_backup_dest';
eval alter system set log_archive_dest='location=$log_backup_dest piece_switch_interval=1d';
--enable_all_result_log

connection conn_sys1;
let $__archive_lag_target__ = 2s;
let $__tenant_name__ = $backup_mysql_tenant;
source include/set_archive_lag_target.inc;

ob_connect(backup_mysql_conn, ob1.z1.obs0,root@$backup_mysql_tenant,,test,,USE_MYSQL_CONNECTOR);
connection backup_mysql_conn;

create table t1(a int, b int, c int);
insert into t1(a, b) values(1, 1);

#mysql租户  开启日志备份
ob1.mysql alter system archivelog;
ob1.check_until_timeout select status from oceanbase.CDB_OB_ARCHIVELOG where tenant_id=$backup_mysql_tenant_id, DOING, 600;

ob1.mysql alter system major freeze tenant = '$backup_mysql_tenant';
sleep 10;
ob1.check_until_timeout select (frozen_scn - last_scn) as result from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id=$backup_mysql_tenant_id, 0, 600;

#mysql租户  开启数据备份
ob1.mysql alter system backup database;
ob1.check_until_timeout select count(*) c from __all_backup_job_history where tenant_id = 1, 1, 600;
ob1.check_until_timeout select result from oceanbase.CDB_OB_BACKUP_JOB_HISTORY where tenant_id = $backup_mysql_tenant_id, 0, 10;
ob1.check_until_timeout select result from oceanbase.CDB_OB_BACKUP_TASK_HISTORY where tenant_id = $backup_mysql_tenant_id, 0, 10;

sleep 20;
connect(backup_sys_conn, $backup_ip, root@sys,,oceanbase, $backup_port);
connection backup_sys_conn;
use oceanbase;
let $restore_path = $log_backup_dest,$data_backup_dest;
let $ls_id1 = deploy_get_value(ob1.select select ls_id from oceanbase.__all_virtual_ls where tenant_id = $backup_mysql_tenant_id and ls_id != 1, ls_id, 1);
ob1.mysql alter tenant $backup_mysql_tenant set primary_zone = 'z1';
ob1.check_until_timeout select count(*)>=1 from oceanbase.__all_virtual_ls_status where status = 'NORMAL' and tenant_id = $backup_mysql_tenant_id, 1, 100;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_ls_status where status = 'WAIT_OFFLINE'  and tenant_id = $backup_mysql_tenant_id, 0, 100;
let $ls_id2 = deploy_get_value(ob1.select select max(ls_id) as ls_id from oceanbase.__all_virtual_ls where tenant_id = $backup_mysql_tenant_id, ls_id, 1);
let $create_scn1 = deploy_get_value(ob1.select select create_scn from oceanbase.__all_virtual_ls where tenant_id = $backup_mysql_tenant_id and ls_id = $ls_id1, create_scn, 1);
let $create_scn2 = deploy_get_value(ob1.select select create_scn from oceanbase.__all_virtual_ls where tenant_id = $backup_mysql_tenant_id and ls_id =  $ls_id2, create_scn, 1);
sleep 3;
let $restore_checkpoint1 = `select ceil(min_restore_scn / 1000) as min_restore_scn from CDB_OB_BACKUP_SET_FILES where tenant_id = $backup_mysql_tenant_id`;
let $restore_checkpoint2 = `select ceil(UNIX_TIMESTAMP(current_timestamp(6)) * 1000000)`;
ob1.check_until_timeout select floor(checkpoint_scn / 1000) > '$restore_checkpoint1' from CDB_OB_ARCHIVELOG, 1, 600;
ob1.check_until_timeout select floor(checkpoint_scn / 1000) > '$restore_checkpoint2' from CDB_OB_ARCHIVELOG, 1, 600;
let $restore_checkpoint = $restore_checkpoint2;
let $restore_checkpoint = `select usec_to_time(floor(checkpoint_scn/1000)) from CDB_OB_ARCHIVELOG`;

#mysql租户  开启数据恢复
ob1.mysql CREATE RESOURCE POOL small_pool_1 UNIT = 'unit_1', UNIT_NUM = 1, zone_list = ('z1', 'z2');
--disable_all_result_log
ob1.mysql alter system restore $restore_mysql_tenant from '$restore_path' until time='$restore_checkpoint' with 'pool_list=small_pool_1&primary_zone=RANDOM';
--enable_all_result_log
ob1.check_until_timeout SELECT status FROM dba_ob_tenants WHERE TENANT_NAME = '$restore_mysql_tenant', NORMAL, 600;
let $restore_mysql_tenant_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name='$restore_mysql_tenant', tenant_id, 1);
let $restore_mysql_meta_tenant_id = deploy_get_value(ob1.select select tenant_id-1 from oceanbase.__all_tenant where tenant_name='$restore_mysql_tenant', tenant_id, 1);
ob1.check_until_timeout select count(*) from __all_virtual_ls_meta_table where tenant_id = $restore_mysql_tenant_id and restore_status !=0, 0, 600;
ob1.check_until_timeout select status FROM __all_tenant WHERE tenant_id = $restore_mysql_tenant_id, NORMAL, 600;
ob1.mysql alter system set ls_gc_delay_time = '0s' tenant='$restore_mysql_tenant';
ob1.check_until_timeout select count(*) FROM __all_restore_job, 0, 200;
ob1.mysql ALTER SYSTEM RECOVER STANDBY TENANT $restore_mysql_tenant UNTIL UNLIMITED;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_ls_status where status = 'WAIT_OFFLINE', 0, 100;

ob_connect(sys_conn, ob1.z1.obs0, root, , oceanbase, , USE_MYSQL_CONNECTOR);
connection sys_conn;
eval select tenant_role from __all_virtual_tenant_info where tenant_id = $restore_mysql_tenant_id;
#STANDBY
eval alter tenant $restore_mysql_tenant enable_arbitration_service = true;
ob1.check_until_timeout select count(*) from __all_virtual_log_stat where tenant_id=$restore_mysql_tenant_id and arbitration_member like "%$arb_svr_ip:$arb_svr_port%", 4, 100;


# case2. 建表、写入数据;
ob_connect(backup_mysql_conn, ob1.z1.obs0,root@$backup_mysql_tenant,,test,,USE_MYSQL_CONNECTOR);
connection backup_mysql_conn;

# wait leader takeover
sleep 1;
# 数据准备
create table t_2F1A(pk int primary key, c1 int, c2 varchar(20));
# 确认leader已经汇报成功
ob1.check_until_timeout select count(*) from __all_virtual_ls_meta_table where tenant_id = '$backup_mysql_tenant_id' and ls_id = 1001 and role = 1, 1, 60;
--disable_query_log
let $cnt=10;
while($cnt>0)
{
	eval insert into t_2F1A values($cnt,$cnt,'c$cnt');
	dec $cnt;
}

# case3. 验证升降级, 宕机, 保证server不会被RS永久下线
ob1.mysql alter system set server_permanent_offline_time = '3600s';
# case3.1 宕机follower1，验证降级
$ob1_follower1_obs.force_stop;
ob_connect(backup_mysql_conn, ob1.z1.obs0,root@$backup_mysql_tenant,,test,,USE_MYSQL_CONNECTOR);
connection backup_mysql_conn;
sleep 5;

let $ob1_ls_count = deploy_get_value(ob1.select select count(*) as cnt from __all_virtual_log_stat where tenant_id = $backup_mysql_tenant_id and paxos_member_list like '%$ob1_follower_ip_port1%', cnt, 1);

ob1.check_until_timeout select (count(*) = ($ob1_ls_count)) from __all_virtual_log_stat where tenant_id = $backup_mysql_tenant_id and degraded_list like "%$ob1_follower_ip_port1%", 1, 120;

# 验证备租户可读位点继续推进
let $sts_degrade_1 = deploy_get_value(ob1.select select READABLE_SCN from oceanbase.dba_ob_tenants where tenant_id = $restore_mysql_tenant_id, READABLE_SCN, 1);
ob1.check_until_timeout select count(*) from oceanbase.dba_ob_tenants where tenant_id = $restore_mysql_tenant_id and READABLE_SCN > $sts_degrade_1, 1, 10;

# case3.2 启动follower1，验证升级

$ob1_follower1_obs.nstart;
ob1.check_until_timeout select (count(*) = 0) from __all_virtual_log_stat where tenant_id = $backup_mysql_tenant_id and degraded_list like "%$ob1_follower_ip_port1%", 1, 120;


# case 1. 验证系统租户switchover  mysql 普通租户
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_tenant_info where tenant_id = $backup_mysql_tenant_id and tenant_role = 'PRIMARY' and switchover_status = 'NORMAL', 1, 10;
let $primary_switchover_epoch = deploy_get_value(ob1.select select switchover_epoch from oceanbase.__all_virtual_tenant_info where tenant_id = $backup_mysql_tenant_id, switchover_epoch, 1);
ob_connect(conn_sys_ob1, ob1.z1.obs0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);
select TENANT_ID, TENANT_NAME, TENANT_TYPE, COMPATIBILITY_MODE, STATUS, IN_RECYCLEBIN, LOCKED, TENANT_ROLE, SWITCHOVER_STATUS, LOG_MODE from DBA_OB_TENANTS order by TENANT_ID;
select count(*) from DBA_OB_TENANTS where SYNC_SCN >= REPLAYABLE_SCN and REPLAYABLE_SCN>=READABLE_SCN and RECOVERY_UNTIL_SCN !=0 and TENANT_TYPE = "USER";
# 2
eval ALTER SYSTEM SWITCHOVER TO STANDBY TENANT $backup_mysql_tenant;
let $primary_sync_scn = deploy_get_value(ob1.select select sync_scn from oceanbase.__all_virtual_tenant_info where tenant_id = $backup_mysql_tenant_id, sync_scn, 1);
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_tenant_info where tenant_id = $backup_mysql_tenant_id and switchover_epoch = $primary_switchover_epoch, 0, 10;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_tenant_info where tenant_id = $backup_mysql_tenant_id and tenant_role = 'STANDBY' and switchover_status = 'NORMAL' and replayable_scn = $primary_sync_scn, 1, 10;
let $to_standby_tenant_id = $backup_mysql_tenant_id;
let $to_primary_tenant_id = $restore_mysql_tenant_id;

#  等待主租户变为备租户，并且完成归档
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_tenant_info where tenant_id = $to_standby_tenant_id and tenant_role = 'STANDBY' and switchover_status = 'NORMAL', 1, 10;
source include/check_archive_finish.inc;
# 等待备租户switchover_status状态是normal
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_tenant_info where tenant_id = $to_primary_tenant_id and tenant_role = 'STANDBY' and switchover_status = 'NORMAL', 1, 10;

ob_connect(backup_mysql_tenant_conn, ob1.z1.obs0, root@$backup_mysql_tenant, ,test, , USE_MYSQL_CONNECTOR);
connection backup_mysql_tenant_conn;
select * from t1;
# 1   1

ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_tenant_info where tenant_id = $restore_mysql_tenant_id and tenant_role = 'STANDBY' and switchover_status = 'NORMAL', 1, 10;
let standby_switchover_epoch = deploy_get_value(ob1.select select switchover_epoch from oceanbase.__all_virtual_tenant_info where tenant_id = $restore_mysql_tenant_id, switchover_epoch, 1);
sleep 20;
ob_connect(conn_sys, ob1.z1.obs0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);
--disable_query_log
eval ALTER SYSTEM SWITCHOVER TO PRIMARY TENANT $restore_mysql_tenant;
--enable_query_log
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_tenant_info where tenant_id = $restore_mysql_tenant_id and switchover_epoch = $standby_switchover_epoch, 0, 10;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_tenant_info where tenant_id = $restore_mysql_tenant_id and tenant_role = 'PRIMARY' and switchover_status = 'NORMAL' and recovery_until_scn = 4611686018427387903, 1, 10;

ob_connect(conn_mysql, ob1.z1.obs0, root@$restore_mysql_tenant, , test, , USE_MYSQL_CONNECTOR);
connection conn_mysql;
select * from t1;
# 1   1
