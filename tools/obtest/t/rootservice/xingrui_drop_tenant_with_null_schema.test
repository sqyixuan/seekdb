# CASE_OWNER:
#    @xingrui.cwh
# CASE_DESC:
#    Test drop tenant concurrent situation

ob1=OBI(cluster=1:1,proxy_num=0);
source include/mini_ob_config.inc;
ob1.set extra_config=$mini_ob_config;
ob1.reboot;

ob_connect(conn_sys, ob1.z1.obs0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);
ob1.mysql alter system set debug_sync_timeout = '1000000s';
set @@session.ob_query_timeout = 1000000000;
#create tenant
eval CREATE RESOURCE UNIT xingrui_drop_tenant_unit MAX_CPU 2, MEMORY_SIZE '4G';
eval CREATE RESOURCE POOL xingrui_drop_tenant_pool UNIT = 'xingrui_drop_tenant_unit', UNIT_NUM = 1;
eval CREATE TENANT xingrui_drop_tenant RESOURCE_POOL_LIST = ('xingrui_drop_tenant_pool'), primary_zone='z1,z2' set ob_tcp_invited_nodes='%';


connection conn_sys;
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'BEFORE_DROP_TENANT wait_for signal';

ob_connect(conn_sys1, ob1.z2.obs0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);
connection conn_sys1;
set recyclebin = off;
send drop tenant if exists xingrui_drop_tenant;

ob_connect(conn_sys2, ob1.z2.obs0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);
connection conn_sys2;
drop tenant xingrui_drop_tenant;

connection conn_sys;
set ob_global_debug_sync = 'now signal signal';
set ob_global_debug_sync = 'reset';
connection conn_sys1;
reap;