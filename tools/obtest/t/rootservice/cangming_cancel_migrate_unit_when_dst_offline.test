# CASE_OWNER:
#    @cangming.zl
# CASE_DESC:
#    bug: 

# cancel migrate unit when dst server offline and we can't find other server to put the unit

ob1=OBI(cluster=2:2:2,proxy_num=0,init_unit_cpu=0);
ob1.reboot;

ob_connect(conn_sys, ob1.z1.obs0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);
connection conn_sys;
alter system set debug_sync_timeout = '1000s';
alter system set server_permanent_offline_time = '25s';
alter system set balancer_idle_time = '10s';
sleep 2;

ob1.mysql set ob_global_debug_sync = 'START_UNIT_BALANCE wait_for begin timeout 1000000000';
let $src_ip=deploy_get_value(ob1.z2.obs0.ip);
let $src_port=deploy_get_value(ob1.z2.obs0.port);
let $dst_ip=deploy_get_value(ob1.z2.obs1.ip);
let $dst_port=deploy_get_value(ob1.z2.obs1.port);
--disable_query_log
eval alter system migrate unit 2 destination '$dst_ip:$dst_port';
--enable_query_log
let $migrate_from_ip = query_get_value(select migrate_from_svr_ip from __all_unit where unit_id = 2, migrate_from_svr_ip, 1);
if ($src_ip == $migrate_from_ip)
{
  echo pass;
}

ob1.z2.obs1.force_stop;
sleep 30;
ob1.mysql set ob_global_debug_sync = 'NOW signal begin';
sleep 5;


#let $new_migrate_from_ip = query_get_value(select migrate_from_svr_ip from __all_unit where unit_id = 2, migrate_from_svr_ip, 1);
#let $new_migrate_from_port = query_get_value(select migrate_from_svr_port from __all_unit where unit_id = 2, migrate_from_svr_port, 1);
let $new_ip = query_get_value(select svr_ip from __all_unit where unit_id = 2, svr_ip, 1);
let $new_port = query_get_value(select svr_port from __all_unit where unit_id = 2, svr_port, 1);
ob1.check_until_timeout select count(*) from __all_unit where unit_id = 2 and migrate_from_svr_ip = '', 1, 60;
#if ($new_migrate_from_ip == $dst_ip)
#{
#  echo pass;
#}
#if ($new_migrate_from_port == $dst_port)
#{
#  echo pass;
#}
if ($new_ip == $src_ip)
{
  echo pass;
}
if ($new_port == $src_port)
{
  echo pass;
}

