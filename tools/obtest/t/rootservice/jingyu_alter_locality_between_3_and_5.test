# CASE_OWNER:
#    @jingyu.cr
# CASE_DESC:
#    This case is aimed to modify tenant's locality from 3 to 5

#######################################################################
#                        create inital objects
#######################################################################

ob1=OBI(cluster=1:1:1:1:1,proxy_num=0,init_unit_cpu=0);
source include/mini_ob_config.inc;
ob1.set extra_config=$mini_ob_config;
ob1.reboot;

ob1.mysql alter system set debug_sync_timeout = '1000s';
ob1.mysql ALTER SYSTEM SET enable_rebalance = 'true';
ob1.mysql ALTER SYSTEM SET balancer_idle_time = '10s';

let $proxy_ip = deploy_get_value(ob1.z1.obs0.ip);
let $proxy_port = deploy_get_value(ob1.z1.obs0.mysql_port);

connect(sys_conn, $proxy_ip, root@sys,,oceanbase, $proxy_port);
source include/create_unit_config.inc;

ob1.mysql CREATE RESOURCE POOL sys_pool_2 UNIT = "2c2g", UNIT_NUM = 1, ZONE_LIST = ('z1', 'z2', 'z3', 'z4', 'z5');
ob1.mysql CREATE TENANT tenant_for_migrate_locality RESOURCE_POOL_LIST=('sys_pool_2'), LOCALITY = "F@z1, F@z2, F@z3, F@z4, F@z5", PRIMARY_ZONE = "z1" SET ob_tcp_invited_nodes='%';

# create new tenant tenant_for_migrate_locality
let $tenant_id = deploy_get_value(ob1.select SELECT tenant_id FROM oceanbase.__all_tenant WHERE tenant_name = "tenant_for_migrate_locality", tenant_id, 1);
let $resource_pool_id = deploy_get_value(ob1.select SELECT resource_pool_id FROM oceanbase.__all_resource_pool WHERE tenant_id = $tenant_id, resource_pool_id, 1);

# get tenant_for_migrate_locality's unit info in z3
let $unit_id = deploy_get_value(ob1.select SELECT unit_id FROM oceanbase.__all_unit WHERE resource_pool_id = $resource_pool_id AND zone = 'z3', unit_id, 1);
let $ip = deploy_get_value(ob1.select SELECT svr_ip FROM oceanbase.__all_unit WHERE unit_id = $unit_id, svr_ip, 1);
let $port = deploy_get_value(ob1.select SELECT svr_port FROM oceanbase.__all_unit WHERE unit_id = $unit_id, svr_port, 1);
let $z3_cur = $ip:$port;

# get servers' addr in z1 and z2
let $z1_dst_ip0 = deploy_get_value(ob1.z1.obs0.ip);
let $z1_dst_port0 = deploy_get_value(ob1.z1.obs0.port);
let $z1_dst0 = $z1_dst_ip0:$z1_dst_port0;
let $z2_dst_ip0 = deploy_get_value(ob1.z2.obs0.ip);
let $z2_dst_port0 = deploy_get_value(ob1.z2.obs0.port);
let $z2_dst0 = $z2_dst_ip0:$z2_dst_port0;
let $z3_dst_ip0 = deploy_get_value(ob1.z3.obs0.ip);
let $z3_dst_port0 = deploy_get_value(ob1.z3.obs0.port);
let $z3_dst0 = $z3_dst_ip0:$z3_dst_port0;
let $z4_dst_ip0 = deploy_get_value(ob1.z4.obs0.ip);
let $z4_dst_port0 = deploy_get_value(ob1.z4.obs0.port);
let $z4_dst0 = $z4_dst_ip0:$z4_dst_port0;
let $z5_dst_ip0 = deploy_get_value(ob1.z5.obs0.ip);
let $z5_dst_port0 = deploy_get_value(ob1.z5.obs0.port);
let $z5_dst0 = $z5_dst_ip0:$z5_dst_port0;
--echo "prepare finished"
ob1.mysql alter tenant sys set primary_zone = "z1";
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_core_meta_table where role = 1 and zone = 'z1', 1, 100;

#######################################################################
#                   CASE  1        alter locality
#######################################################################

connection sys_conn;
# [case 1.1]
#    aim_to:  alter mysql tenant locality from 5F to 3F
#    expect:  success
--echo "case 1.1 start"
--enable_query_log
ob1.mysql set ob_global_debug_sync = 'BEFORE_SEND_DRTASK_RPC wait_for signal';
eval ALTER TENANT tenant_for_migrate_locality LOCALITY = "F@z1,F@z2,F@z3";
ob1.check_until_timeout SELECT COUNT(*) AS cnt FROM oceanbase.__all_rootservice_job WHERE tenant_id = $tenant_id AND job_type = "ALTER_TENANT_LOCALITY" AND sql_text LIKE "%F@z1,F@z2,F@z3%" AND extra_info like "%FULL{1}@z1, FULL{1}@z2, FULL{1}@z3, FULL{1}@z4, FULL{1}@z5%" AND job_status = "INPROGRESS", 1, 20;
ob1.mysql alter tenant sys set primary_zone = "z1";
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_core_meta_table where role = 1 and zone = 'z1', 1, 60;
connection sys_conn;
ob1.mysql set ob_global_debug_sync = 'now signal signal';
ob1.check_until_timeout SELECT COUNT(*) AS cnt FROM oceanbase.__all_tenant WHERE tenant_id = $tenant_id AND previous_locality = '', 1 ,600;
ob1.check_until_timeout SELECT COUNT(*) AS cnt FROM oceanbase.__all_tenant WHERE tenant_id = $tenant_id - 1 AND previous_locality = '', 1 ,600;
ob1.check_until_timeout SELECT COUNT(*) AS cnt FROM oceanbase.__all_tenant WHERE tenant_id = $tenant_id AND primary_zone = (SELECT primary_zone FROM oceanbase.__all_tenant WHERE tenant_id = $tenant_id - 1), 1 ,50;
ob1.check_until_timeout SELECT COUNT(*) AS cnt FROM oceanbase.__all_tenant WHERE tenant_id = $tenant_id AND zone_list = (SELECT zone_list FROM oceanbase.__all_tenant WHERE tenant_id = $tenant_id - 1), 1 ,50;
ob1.check_until_timeout SELECT COUNT(*) AS cnt FROM oceanbase.__all_rootservice_job WHERE tenant_id = $tenant_id AND job_type = "ALTER_TENANT_LOCALITY" AND sql_text LIKE "%F@z1,F@z2,F@z3%" AND extra_info like "%FULL{1}@z1, FULL{1}@z2, FULL{1}@z3, FULL{1}@z4, FULL{1}@z5%" AND job_status = "SUCCESS", 1, 20;
ob1.check_until_timeout SELECT COUNT(*) AS cnt FROM oceanbase.__all_virtual_ls_meta_table WHERE tenant_id = $tenant_id - 1 AND role = 1 AND member_list LIKE "%$z4_dst0%", 0, 20;
ob1.check_until_timeout SELECT COUNT(*) AS cnt FROM oceanbase.__all_virtual_ls_meta_table WHERE tenant_id = $tenant_id - 1 AND role = 1 AND member_list LIKE "%$z5_dst0%", 0, 20;
ob1.check_until_timeout SELECT COUNT(*) AS cnt FROM oceanbase.__all_virtual_ls_meta_table WHERE tenant_id = $tenant_id AND role = 1 AND member_list LIKE "%$z4_dst0%", 0, 20;
ob1.check_until_timeout SELECT COUNT(*) AS cnt FROM oceanbase.__all_virtual_ls_meta_table WHERE tenant_id = $tenant_id AND role = 1 AND member_list LIKE "%$z5_dst0%", 0, 20;
--echo "case 1.1 finish"

# [case 1.2]
#    aim_to:  alter sys tenant locality from 5F to 3F
#    expect:  success
--echo "case 1.2 start"
ob1.mysql set ob_global_debug_sync = 'BEFORE_SEND_DRTASK_RPC wait_for signal';
eval ALTER TENANT sys LOCALITY = "F@z1,F@z2,F@z3";
ob1.check_until_timeout SELECT COUNT(*) AS cnt FROM oceanbase.__all_rootservice_job WHERE tenant_id = 1 AND job_type = "ALTER_TENANT_LOCALITY" AND sql_text LIKE "%F@z1,F@z2,F@z3%" AND extra_info like "%FULL{1}@z1, FULL{1}@z2, FULL{1}@z3, FULL{1}@z4, FULL{1}@z5%" AND job_status = "INPROGRESS", 1, 20;
ob1.check_until_timeout SELECT COUNT(*) = 0 as cnt FROM oceanbase.__all_virtual_ls_replica_task, 0, 20;
ob1.mysql alter tenant sys set primary_zone = "z2";
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_core_meta_table where role = 1 and zone = 'z2', 1, 60;
connection sys_conn;
ob1.mysql set ob_global_debug_sync = 'now signal signal';
ob1.check_until_timeout select count(*) from oceanbase.DBA_OB_TENANTS where tenant_id = 1 and previous_locality is null, 1, 120;
ob1.check_until_timeout SELECT COUNT(*) AS cnt FROM oceanbase.__all_rootservice_job WHERE tenant_id = 1 AND job_type = "ALTER_TENANT_LOCALITY" AND sql_text LIKE "%F@z1,F@z2,F@z3%" AND extra_info like "%FULL{1}@z1, FULL{1}@z2, FULL{1}@z3, FULL{1}@z4, FULL{1}@z5%" AND job_status = "SUCCESS", 1, 20;
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id = 1 AND role = 'LEADER' and member_list NOT LIKE "%$z4_dst0%" AND member_list NOT LIKE "%$z5_dst0%" AND paxos_replica_number = 3, 1, 60;
--echo "case 1.2 finish"

# [case 1.3]
#    aim_to:  alter mysql tenant locality from 3F to 5F
#    expect:  success
--echo "case 1.3 start"
ob1.mysql set ob_global_debug_sync = 'BEFORE_SEND_DRTASK_RPC wait_for signal';
eval ALTER TENANT tenant_for_migrate_locality LOCALITY = "F@z1,F@z2,F@z3,F@z4,F@z5";
ob1.check_until_timeout SELECT COUNT(*) = 0 as cnt FROM oceanbase.__all_virtual_ls_replica_task, 0, 20;
ob1.mysql alter tenant sys set primary_zone = "z3";
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_core_meta_table where role = 1 and zone = 'z3', 1, 60;
ob1.check_until_timeout SELECT COUNT(*) AS cnt FROM oceanbase.__all_rootservice_job WHERE tenant_id = $tenant_id AND job_type = "ALTER_TENANT_LOCALITY" AND sql_text LIKE "%F@z1,F@z2,F@z3,F@z4,F@z5%" AND extra_info like "%FULL{1}@z1, FULL{1}@z2, FULL{1}@z3%" AND job_status = "INPROGRESS", 1, 20;
connection sys_conn;
ob1.mysql set ob_global_debug_sync = 'now signal signal';
ob1.check_until_timeout SELECT COUNT(*) AS cnt FROM oceanbase.__all_tenant WHERE tenant_id = $tenant_id AND previous_locality = '', 1 ,600;
ob1.check_until_timeout SELECT COUNT(*) AS cnt FROM oceanbase.__all_tenant WHERE tenant_id = $tenant_id - 1 AND previous_locality = '', 1 ,600;
ob1.check_until_timeout SELECT COUNT(*) AS cnt FROM oceanbase.__all_tenant WHERE tenant_id = $tenant_id AND primary_zone = (SELECT primary_zone FROM oceanbase.__all_tenant WHERE tenant_id = $tenant_id - 1), 1 ,50;
ob1.check_until_timeout SELECT COUNT(*) AS cnt FROM oceanbase.__all_tenant WHERE tenant_id = $tenant_id AND zone_list = (SELECT zone_list FROM oceanbase.__all_tenant WHERE tenant_id = $tenant_id - 1), 1 ,50;
ob1.check_until_timeout SELECT COUNT(*) AS cnt FROM oceanbase.__all_rootservice_job WHERE tenant_id = $tenant_id AND job_type = "ALTER_TENANT_LOCALITY" AND sql_text LIKE "%F@z1,F@z2,F@z3,F@z4,F@z5%" AND extra_info like "%FULL{1}@z1, FULL{1}@z2, FULL{1}@z3%" AND job_status = "SUCCESS", 1, 20;
ob1.check_until_timeout SELECT COUNT(*) AS cnt FROM oceanbase.__all_virtual_ls_meta_table WHERE tenant_id = $tenant_id - 1 AND role = 1 AND member_list NOT LIKE "%$z4_dst0%", 0, 20;
ob1.check_until_timeout SELECT COUNT(*) AS cnt FROM oceanbase.__all_virtual_ls_meta_table WHERE tenant_id = $tenant_id - 1 AND role = 1 AND member_list NOT LIKE "%$z5_dst0%", 0, 20;
ob1.check_until_timeout SELECT COUNT(*) AS cnt FROM oceanbase.__all_virtual_ls_meta_table WHERE tenant_id = $tenant_id AND role = 1 AND member_list NOT LIKE "%$z4_dst0%", 0, 20;
ob1.check_until_timeout SELECT COUNT(*) AS cnt FROM oceanbase.__all_virtual_ls_meta_table WHERE tenant_id = $tenant_id AND role = 1 AND member_list NOT LIKE "%$z5_dst0%", 0, 20;
--echo "case 1.3 finish"

# [case 1.4]
#    aim_to:  alter sys tenant locality from 3F to 5F
#    expect:  success
--echo "case 1.4 start"
ob1.mysql set ob_global_debug_sync = 'BEFORE_SEND_DRTASK_RPC wait_for signal';
eval ALTER TENANT sys LOCALITY = "F@z1,F@z2,F@z3,F@z4,F@z5";
ob1.check_until_timeout SELECT COUNT(*) AS cnt FROM oceanbase.__all_rootservice_job WHERE tenant_id = 1 AND job_type = "ALTER_TENANT_LOCALITY" AND sql_text LIKE "%F@z1,F@z2,F@z3,F@z4,F@z5%" AND extra_info like "%FULL{1}@z1, FULL{1}@z2, FULL{1}@z3%" AND job_status = "INPROGRESS", 1, 20;
ob1.check_until_timeout SELECT COUNT(*) = 0 as cnt FROM oceanbase.__all_virtual_ls_replica_task, 0, 20;
ob1.mysql alter tenant sys set primary_zone = "z1";
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_core_meta_table where role = 1 and zone = 'z1', 1, 60;
connection sys_conn;
ob1.mysql set ob_global_debug_sync = 'now signal signal';
ob1.check_until_timeout select count(*) from oceanbase.DBA_OB_TENANTS where tenant_id = 1 and previous_locality is null, 1, 120;
ob1.check_until_timeout SELECT COUNT(*) AS cnt FROM oceanbase.__all_rootservice_job WHERE tenant_id = 1 AND job_type = "ALTER_TENANT_LOCALITY" AND sql_text LIKE "%F@z1,F@z2,F@z3,F@z4,F@z5%" AND extra_info like "%FULL{1}@z1, FULL{1}@z2, FULL{1}@z3%" AND job_status = "SUCCESS", 1, 20;
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id = 1 AND role = 'LEADER' and member_list LIKE "%$z4_dst0%" AND member_list LIKE "%$z5_dst0%" AND paxos_replica_number = 5, 1, 60;
--echo "case 1.4 finish"

#######################################################################
#                   CASE  2       5F->3F when Minority down
#######################################################################
#
# [case 2.1] Minority permanet offline
--echo "case 2.1 start"
alter system set server_permanent_offline_time = '30s';

let $ls_cnt = deploy_get_value(ob1.select select count(*) as cnt from oceanbase.CDB_OB_LS_LOCATIONS where role = 'LEADER', cnt, 1);
ob1.mysql alter tenant sys set primary_zone = "z1";
ob1.mysql alter tenant tenant_for_migrate_locality set primary_zone = "z1";
ob1.check_until_timeout select count(*) c from oceanbase.CDB_OB_LS_LOCATIONS where role like "%LEADER%" and (zone = 'z4' or zone = 'z5'), 0, 60;
ob1.z4.obs0.force_stop;
ob1.z5.obs0.force_stop;

ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_LS_LOCATIONS where role = 'LEADER' and member_list NOT LIKE "%$z4_dst0%" AND member_list NOT LIKE "%$z5_dst0%" AND paxos_replica_number = 5, $ls_cnt, 120;
--echo "case 2.1 finish"

# [case 2.2] alter sys tenant locality from 5F to 3F
--echo "case 2.2 start"
alter tenant sys set locality = 'F@z1,F@z2,F@z3';
ob1.check_until_timeout select count(*) from oceanbase.DBA_OB_TENANTS where tenant_id = 1 and previous_locality is null, 1, 120;
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id = 1 AND role = 'LEADER' and member_list NOT LIKE "%$z4_dst0%" AND member_list NOT LIKE "%$z5_dst0%" AND paxos_replica_number = 3, 1, 60;
--echo "case 2.2 finish"

# [case 2.3] alter mysql tenant locality from 5F to 3F
--echo "case 2.3 start"
alter tenant tenant_for_migrate_locality set locality = 'F@z1,F@z2,F@z3';
ob1.check_until_timeout select count(*) from oceanbase.DBA_OB_TENANTS where tenant_id in ($tenant_id - 1, $tenant_id) and previous_locality is null, 2, 120;
ob1.check_until_timeout select IF(count(*) = $ls_cnt - 1, 1, 0) as pass from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id in ($tenant_id - 1, $tenant_id) AND role = 'LEADER' and member_list NOT LIKE "%$z4_dst0%" AND member_list NOT LIKE "%$z5_dst0%" AND paxos_replica_number = 3, 1, 60;
--echo "case 2.3 finish"


# TODO: shrink/revoke resource pool


