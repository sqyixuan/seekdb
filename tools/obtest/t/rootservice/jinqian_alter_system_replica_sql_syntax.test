# CASE_OWNER:
#    @jinqian.zzy
# CASE_DESC:
#    This case is aimed to test alter ls replica sql command syntax
#    We designed following cases to simulate different scenes:
#
#    CASE 1: test mysql sql command syntax
#       1.1:  add ls replica sql command
#       1.2:  remove ls replica sql command
#       1.3:  modify ls replica sql command
#       1.4:  modify ls paxos_replica_num sql command
#       1.5:  migrate ls replica sql command
#       1.6:  cancel ls replica sql command
#       1.7:  success case
#
#    CASE 2: test oracle sql command syntax
#       2.1:  add ls replica sql command
#       2.2:  remove ls replica sql command
#       2.3:  modify ls replica sql command
#       2.4:  modify ls paxos_replica_num sql command
#       2.5:  migrate ls replica sql command
#       2.6:  cancel ls replica sql command
#       2.7:  success case
#    CASE 3: test tenant not exist
#    CASE 4: sys tenant operate other tenant success
#    CASE 5: alter system priv check
#       5.1 mysql failed case
#       5.2 mysql success case
#       5.3 oracle failed case
#       5.4 oracle success case
#######################################################################
#                        create inital objects
#######################################################################
 
ob1=OBI(cluster=2:2:2,proxy_num=0,init_unit_cpu=0);
source include/mini_ob_config.inc;
ob1.set extra_config=$mini_ob_config;
ob1.reboot;
 
ob1.mysql alter system set debug_sync_timeout = '1000s';
ob1.mysql ALTER SYSTEM SET enable_rebalance = 'false';
ob1.mysql ALTER SYSTEM SET enable_rereplication = 'true';
 
let $proxy_ip = deploy_get_value(ob1.z1.obs0.ip);
let $proxy_port = deploy_get_value(ob1.z1.obs0.mysql_port);
connect(sys_conn, $proxy_ip, root@sys,,oceanbase, $proxy_port);
 
source include/create_unit_config.inc;
ob1.mysql CREATE RESOURCE POOL tenant_pool UNIT = "2c2g", UNIT_NUM = 2, ZONE_LIST = ('z1', 'z2', 'z3');
ob1.mysql CREATE TENANT mysql_tenant RESOURCE_POOL_LIST=('tenant_pool'), LOCALITY = "F@z1, F@z2", PRIMARY_ZONE = "z1" SET ob_tcp_invited_nodes='%';
connect(mysql_tenant, $proxy_ip, root@mysql_tenant,,oceanbase, $proxy_port);
 
ob1.mysql CREATE RESOURCE POOL tenant_pool1 UNIT = "2c2g", UNIT_NUM = 2, ZONE_LIST = ('z1', 'z2', 'z3');
ob1.mysql CREATE TENANT oracle_tenant RESOURCE_POOL_LIST=('tenant_pool1'), LOCALITY = "F@z1, F@z2", PRIMARY_ZONE = "z1" SET ob_tcp_invited_nodes='%', ob_compatibility_mode = 'oracle';
ob_connect(oracle_tenant, ob1.z1.obs0, SYS@oracle_tenant, , SYS, , USE_OB_CONNECTOR);

--echo ========================================================================
--echo ||                    [MILESTONE] prepare finished                    ||
--echo ========================================================================
 
--echo ========================================================================
--echo ||         [MILESTONE] case 1.1: mysql add ls replica command         ||
--echo ========================================================================
connection mysql_tenant;
--error 1227
# not sys tenant cannot operate other tenants
alter system add replica ls=100 server='100.88.107.212:5000' replica_type='F' data_source='100.88.107.212:5001' paxos_replica_num=3 tenant='oracle_tenant';
--error 1210
# server addr wrong
alter system add replica ls=100 server='100.88.1075000' replica_type='F' data_source='100.88.107.212:5001' paxos_replica_num=3 tenant='mysql_tenant';
--error 1210
# data_source addr wrong
alter system add replica ls=100 server='100.88.107.212:5000' replica_type='F' data_source='100.88.107:5001' paxos_replica_num=3 tenant='mysql_tenant';
--error 1210
# server and data_source addr wrong
alter system add replica ls=100 server='100.88.212:5000' replica_type='F' data_source='10.107.212:5001' paxos_replica_num=3 tenant='mysql_tenant';
--error 1210
# server and data_source addr wrong
alter system add replica ls=100 server='0.0.0.0:5000' replica_type='F' data_source='10.107.212:0' paxos_replica_num=3 tenant='mysql_tenant';
--error 1210
# server and data_source addr wrong
alter system add replica ls=100 server='0.0.0.0:0' replica_type='F' data_source='10.107.212:5001' paxos_replica_num=3 tenant='mysql_tenant';
--error 1210
# replica_type wrong
alter system add replica ls=100 server='100.88.107.212:5000' replica_type='x' data_source='100.88.107.212:5001' paxos_replica_num=3;
--error 1064
# replica_type wrong
alter system add replica ls=100 server='100.88.107.212:5000' replica_type=0 data_source='100.88.107.212:5001' paxos_replica_num=3;
--error 1064
# paxos_replica_num wrong
alter system add replica ls=100 server='100.88.107.212:5000' replica_type='f' data_source='100.88.107.212:5001' paxos_replica_num=x;
--error 1064
# ls wrong
alter system add replica ls='10' server='100.88.107.212:5000' replica_type='F' data_source='100.88.107.212:5001' paxos_replica_num=3;
--error 1210
# paxos_replica_num = 0
alter system add replica ls=100 server='100.1.88.212:5000' replica_type='F' data_source='10.107.1.212:5001' paxos_replica_num=0 tenant='mysql_tenant';
--error 1064
# paxos_replica_num < 0
alter system add replica ls=100 server='100.1.88.212:5000' replica_type='F' data_source='10.107.1.212:5001' paxos_replica_num=-1 tenant='mysql_tenant';

# syntax error, incorrect parameter order, or missing some required parameters
--error 1064
alter system add replica server='100.88.107.212:5000' replica_type='F' tenant='oracle_tenant' data_source='100.88.107.212:5001' paxos_replica_num=3;
--error 1064
alter system add replica ls=100 replica_type='F' tenant='oracle_tenant' data_source='100.88.107.212:5001' paxos_replica_num=3;
--error 1064
alter system add replica ls=100 tenant='oracle_tenant' data_source='100.88.107.212:5001' paxos_replica_num=3;
--error 1064
alter system add replica replica_type='F' ls=100 server='100.88.107.212:5000' tenant='oracle_tenant' data_source='100.88.107.212:5001' paxos_replica_num=3;
--error 1064
alter system add replica server='100.88.107.212:5000' ls=100 replica_type='F' tenant='oracle_tenant' data_source='100.88.107.212:5001' paxos_replica_num=3;
--error 1064
alter system add replica server='100.88.107.212:5000' ls=100 replica_type='F' paxos_replica_num=3 tenant='oracle_tenant' data_source='100.88.107.212:5001';
--error 1064
alter system add replica server='100.88.107.212:5000' ls=100 paxos_replica_num=3 data_source='100.88.107.212:5001' tenant='oracle_tenant';
 
