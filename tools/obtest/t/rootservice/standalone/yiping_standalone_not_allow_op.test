ob1=OBI(cluster=2:1,proxy_num=0);
ob1.z1.obs1.set status=disable;

# 1. 单机版bootstrap不能有多个机器

ob1.reset;
ob1.clean_all_asvr;
ob1.deploy;

let $z1s0ip = deploy_get_value(ob1.z1.obs0.ip);
let $z1s0port= deploy_get_value(ob1.z1.obs0.port);
let $z1s0mysqlport= deploy_get_value(ob1.z1.obs0.mysql_port);

ob1.z1.obs0.check_log_until_success -c "weak read service thread start";


let $z1s1ip = deploy_get_value(ob1.z1.obs1.ip);
let $z1s1port= deploy_get_value(ob1.z1.obs1.port);
let $z2s0ip = deploy_get_value(ob1.z2.obs0.ip);
let $z2s0port= deploy_get_value(ob1.z2.obs0.port);

# jdbc连接需要指定database，mysql_root_p不会返回error code，所以这里拿不到error code。
# 如果bootstrap成功了，那么后面select会有结果。失败了就没结果。
ob1.mysql_root_p alter system bootstrap zone 'z1' server '$z1s0ip:$z1s0port', zone 'z2' server '$z2s0ip:$z2s0port'; select count(*) from oceanbase.__all_core_table;

# 2. 单机版不能add server

ob1.z2.obs0.set status=disable;
ob1.reset;
ob1.clean_all_asvr;
ob1.deploy;
ob1.mysql_root_p alter system bootstrap zone 'z1' server '$z1s0ip:$z1s0port'; select count(*) > 0 from oceanbase.__all_core_table;

ob1.z1.obs1.set status=enable;
ob1.z1.obs1.start;
ob1.z1.obs1.check_log_until_success -c "weak read service thread start";

ob_connect(conn_sys1, ob1.z1.obs0, root@sys, , , , USE_MYSQL_CONNECTOR);
connection conn_sys1;
--error 4179
eval alter system add server '$z1s1ip:$z1s1port';

# 3. 单机版不能add zone

--error 4179
eval alter system add zone 'z2';
