# 验证在单机版模式下，election_epoch恒为1，election_role恒为leader，palf层的palf_proposal_id会正常变化
ob1=OBI(cluster=1,proxy_num=0);
ob1.reboot;

ob1.mysql create resource unit box max_cpu 2, memory_size='4G';
ob1.mysql create resource pool pool unit = 'box', unit_num = 1;
ob1.mysql create tenant mysql replica_num = 1, resource_pool_list=('pool');

ob1.mysql create resource pool pool1 unit = 'box', unit_num = 1;
ob1.mysql create tenant oracle replica_num = 1, resource_pool_list=('pool1') set ob_compatibility_mode='oracle';

# election_epoch恒为1
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_ha_diagnose where election_epoch != 1 or election_role != 'LEADER', 0, 10;

# 没重启过，palf_proposal_id恒为1
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_ha_diagnose where palf_proposal_id != 1, 0, 10;

ob1.force_stop;
ob1.nstart;

ob1.check_until_timeout select count(*) from oceanbase.__all_server where start_service_time <= 0 or status='INACTIVE',0,180;
ob1.check_until_timeout select count(1) as unsync_cnt from GV\$OB_LOG_STAT where in_sync = 'NO',0,600;
source include/check_schema_sync_for_restart.inc;

# election_epoch恒为1
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_ha_diagnose where election_epoch != 1 or election_role != 'LEADER', 0, 10;

# 重启过一次，palf_proposal_id恒为2
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_ha_diagnose where palf_proposal_id != 2, 0, 10;

ob1.force_stop;
ob1.nstart;

ob1.check_until_timeout select count(*) from oceanbase.__all_server where start_service_time <= 0 or status='INACTIVE',0,180;
ob1.check_until_timeout select count(1) as unsync_cnt from GV\$OB_LOG_STAT where in_sync = 'NO',0,600;
source include/check_schema_sync_for_restart.inc;

# election_epoch恒为1
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_ha_diagnose where election_epoch != 1 or election_role != 'LEADER', 0, 10;

# 重启过2次，palf_proposal_id恒为3
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_ha_diagnose where palf_proposal_id != 3, 0, 10;
