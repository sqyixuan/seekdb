# CASE_OWNER:
#    @jingyu.cr
# CASE_DESC:
#    When log stream has no leader, or replica not in leader's member_list
#    C replica could wrongly recognized as F replica
#
#######################################################################
#                        create inital objects
#######################################################################

ob1=OBI(cluster=1:1:1,proxy_num=0,init_unit_cpu=0);
source include/mini_ob_config.inc;
ob1.set extra_config=$mini_ob_config;
ob1.reboot;

ob1.mysql alter system set debug_sync_timeout = '1000s';
ob1.mysql ALTER SYSTEM SET enable_rebalance = 'false';
ob1.mysql ALTER SYSTEM SET enable_rereplication = 'true';

let $proxy_ip = deploy_get_value(ob1.z1.obs0.ip);
let $proxy_port = deploy_get_value(ob1.z1.obs0.mysql_port);
connect(sys_conn, $proxy_ip, root@sys,,oceanbase, $proxy_port);

--echo =========================================
--echo    create mysql tenant with C replica
--echo =========================================
# create new tenant mysql
source include/create_unit_config.inc;
ob1.mysql CREATE RESOURCE POOL tenant_pool UNIT = "2c2g", UNIT_NUM = 1, ZONE_LIST = ('z1', 'z2', 'z3');
ob1.mysql CREATE TENANT mysql RESOURCE_POOL_LIST=('tenant_pool'), LOCALITY = "F@z1, F@z2, C@z3", PRIMARY_ZONE = "z1;z2;z3" SET ob_tcp_invited_nodes='%';

let $tenant_id = deploy_get_value(ob1.select SELECT tenant_id FROM oceanbase.DBA_OB_TENANTS WHERE tenant_name = "mysql", tenant_id, 1);
let $meta_tenant_id = deploy_get_value(ob1.select select tenant_id - 1 as meta_tenant_id from oceanbase.DBA_OB_TENANTS where tenant_name = "mysql", meta_tenant_id, 1);
let $resource_pool_id = deploy_get_value(ob1.select SELECT resource_pool_id FROM oceanbase.__all_resource_pool WHERE tenant_id = $tenant_id, resource_pool_id, 1);

let $z1_dst_ip0 = deploy_get_value(ob1.z1.obs0.ip);
let $z1_dst_port0 = deploy_get_value(ob1.z1.obs0.port);
let $z1_dst0 = $z1_dst_ip0:$z1_dst_port0;
let $z2_dst_ip0 = deploy_get_value(ob1.z2.obs0.ip);
let $z2_dst_port0 = deploy_get_value(ob1.z2.obs0.port);
let $z2_dst0 = $z2_dst_ip0:$z2_dst_port0;
let $z3_dst_ip0 = deploy_get_value(ob1.z3.obs0.ip);
let $z3_dst_port0 = deploy_get_value(ob1.z3.obs0.port);
let $z3_dst0 = $z3_dst_ip0:$z3_dst_port0;

--echo ======================================================
--echo     errsim and set role to follower in meta table
--echo ======================================================
ob1.mysql alter system set_tp tp_name = ERRSIM_NOT_UPDATE_LS_META_TABLE, error_code = 4002, frequency = 1;
eval alter system change tenant tenant_id = $meta_tenant_id;
--echo check location cache is FFC
ob1.z1.obs0.check_log_until_success -c ".*dump tenant ls location caches.*tenant_id:1002, ls_id:{id:1001.*replica_type:\"COLUMNSTORE\".*";
update __all_ls_meta_table set role = 2 where ls_id = 1001; 

--echo check location cache is still FFC after meta_table has no leader
sleep 20;
let $work_dir=deploy_get_value(ob1.z1.obs0.workdir);
ob1.z1.obs0.sh cd $work_dir/ && rm -rf log/observer*;
ob1.z1.obs0.check_log_until_success -c ".*dump tenant ls location caches.*tenant_id:1002, ls_id:{id:1001.*replica_type:\"COLUMNSTORE\".*";

alter system change tenant tenant_id = 1;
ob1.mysql alter system set_tp tp_name = ERRSIM_NOT_UPDATE_LS_META_TABLE, error_code = 4002, frequency = 0;
ob1.check_until_timeout select count(*) as cnt from oceanbase.__all_virtual_ls_meta_table where tenant_id = $tenant_id and ls_id = 1001 and role = 1, 1, 20;

--echo =====================================================================
--echo      errsim and remove C-replica from leanrer_list in meta table
--echo =====================================================================
ob1.mysql alter system set_tp tp_name = ERRSIM_NOT_UPDATE_LS_META_TABLE, error_code = 4002, frequency = 1;
eval alter system change tenant tenant_id = $meta_tenant_id;
--echo check location cache is FFC
ob1.z1.obs0.check_log_until_success -c ".*dump tenant ls location caches.*tenant_id:1002, ls_id:{id:1001.*replica_type:\"COLUMNSTORE\".*";
update __all_ls_meta_table set learner_list = "" where ls_id = 1001;

--echo check location cache is still FFC when replica not in leader learner list
sleep 20;
let $work_dir=deploy_get_value(ob1.z1.obs0.workdir);
ob1.z1.obs0.sh cd $work_dir/ && rm -rf log/observer*;
ob1.z1.obs0.check_log_until_success -c ".*dump tenant ls location caches.*tenant_id:1002, ls_id:{id:1001.*replica_type:\"COLUMNSTORE\".*";

