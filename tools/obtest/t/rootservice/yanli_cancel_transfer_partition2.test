let $src_ls = deploy_get_value(ob1.select select ls_id from oceanbase.cdb_ob_table_locations where table_id = $table_id and object_id = $part_id, ls_id, 1);
let $dest_ls = deploy_get_value(ob1.select select ls_id from oceanbase.__all_virtual_ls_status where tenant_id = $tenant_id and ls_id != 1 and ls_id != $src_ls, ls_id, 1);
eval alter system transfer partition table_id = $table_id, object_id = $part_id to ls $dest_ls tenant = 'oracle';
let $part_id = deploy_get_value(ob1.select select object_id from oceanbase.cdb_ob_table_locations where table_name = 'ONE_$count' and PARTITION_NAME = 'p3', object_id, 1);
let $src_ls = deploy_get_value(ob1.select select ls_id from oceanbase.cdb_ob_table_locations where table_id = $table_id and object_id = $part_id, ls_id, 1);
let $dest_ls = deploy_get_value(ob1.select select ls_id from oceanbase.__all_virtual_ls_status where tenant_id = $tenant_id and ls_id != 1 and ls_id != $src_ls, ls_id, 1);
eval alter system transfer partition table_id = $table_id, object_id = $part_id to ls $dest_ls tenant = 'oracle';

inc $count;
}
