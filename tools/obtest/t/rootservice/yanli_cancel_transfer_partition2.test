eval alter system transfer partition table_id = $table_id, object_id = $part_id to ls $dest_ls tenant = 'oracle';
let $part_id = deploy_get_value(ob1.select select object_id from oceanbase.cdb_ob_table_locations where table_name = 'ONE_$count' and PARTITION_NAME = 'p1', object_id, 1);
