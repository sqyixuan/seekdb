# CASE_OWNER:
#    @cangming.zl
# CASE_DESC:
#    本case是为了测试isolate server命令;

ob1=OBI(cluster=1:1,proxy_num=0);
ob1.reboot;
sleep 3;
let $svr = deploy_get_value(ob1.select select concat(svr_ip,":",svr_port) addr from __all_virtual_core_meta_table where role = 1, addr, 1);

ob_connect(sys1_conn, ob1.z1.obs0, root, , oceanbase, , USE_MYSQL_CONNECTOR);
connection sys1_conn;
--disable_query_log
##stop server 失败;
--error 4179
eval alter system stop server '$svr';
##force stop server 失败;
--error 4179
eval alter system force stop server '$svr';
###isolate server 成功;
eval alter system isolate server '$svr';

#--error 4179
eval alter system stop server '$svr';
##force stop server 失败;
#--error 4179
eval alter system force stop server '$svr';
ob1.check_until_timeout select count(*) from __all_virtual_core_meta_table where role = 1 and concat(svr_ip,":",svr_port) = '$svr', 0, 60;
ob1.check_until_timeout select count(*) from __all_server where stop_time > 0, 1, 5;
eval alter system start server '$svr';
--enable_query_log
##leader切回
#由于系统租户的primary_zone是random，所以不会回切
#ob1.check_until_timeout select count(*) from __all_virtual_core_meta_table where role = 1 and zone = 'z2', 0, 60;
ob1.check_until_timeout select count(*) from __all_server where stop_time > 0, 0, 5;
