# CASE_OWNER:
#    @msy164651
# CASE_DESC:
#    Net Standby

ob1=OBI(cluster=2:2:2, proxy_num=0);
source include/mini_ob_config.inc;
ob1.set extra_config=$mini_ob_config;
ob1.reboot;
# 固定sys租户规格
ob1.mysql alter resource unit sys_unit_config memory_size='2G';

ob_connect(sys_conn, ob1.z1.obs0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);
CREATE RESOURCE UNIT large_unit MAX_CPU=2, MEMORY_SIZE='2G';
CREATE RESOURCE POOL pool UNIT large_unit, UNIT_NUM 2;
CREATE RESOURCE POOL pool_1 UNIT large_unit, UNIT_NUM 2;

ob1.mysql alter system set _backup_idle_time = '10s';
ob1.mysql alter system set merger_check_interval = '10s';
ob1.mysql alter system set enable_async_syslog=false;

# create oracle tenant, test create tenant before major freeze
ob1.mysql CREATE TENANT oracle RESOURCE_POOL_LIST = ('pool'), primary_zone = "z1,z2" set ob_tcp_invited_nodes='%', ob_compatibility_mode='oracle';
let $oracle_id = query_get_value(select tenant_id from oceanbase.__all_tenant where tenant_name='oracle', tenant_id, 1);

ob_connect(sys_conn, ob1.z1.obs0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);
# create log restore source user
ob_connect(primary_tenant_conn, ob1.z1.obs0,SYS@oracle,,SYS,,USE_OB_CONNECTOR);
connection primary_tenant_conn;
create user mytest identified by "test";
grant connect to mytest;
GRANT SELECT on SYS.DBA_OB_ACCESS_POINT to mytest;
GRANT SELECT on SYS.GV$OB_UNITS to mytest;
GRANT SELECT on SYS.DBA_OB_TENANTS to mytest;
GRANT SELECT on SYS.GV$OB_PARAMETERS to mytest;
GRANT SELECT on SYS.GV$OB_LOG_STAT to mytest;
GRANT SELECT on SYS.DBA_OB_LS to mytest;
GRANT SELECT on SYS.DBA_OB_LS_HISTORY to mytest;
# get primary tenant access point
let $server_ip_port_1=deploy_get_value(ob1.select select concat(svr_ip,':',sql_port) as host from CDB_OB_LS_LOCATIONS where tenant_id = $oracle_id and ls_id = 1 and role = 'LEADER' order by svr_ip, sql_port limit 1;, host, 1);
let $server_ip_port_2=deploy_get_value(ob1.select select concat(svr_ip,':',sql_port) as host from CDB_OB_LS_LOCATIONS where tenant_id = $oracle_id and ls_id = 1 and role = 'FOLLOWER' order by svr_ip, sql_port limit 1, host, 1);


ob1.mysql alter system set debug_sync_timeout = '100000s';
sleep 3;
#停掉备库的均衡逻辑，保证日志流创建在哪个unit组上不会被改变
ob1.mysql set ob_global_debug_sync = 'STOP_RECOVERY_LS_THREAD0 wait_for continue_signal_1 execute 10000';

--disable_all_result_log
ob1.mysql CREATE STANDBY TENANT IF NOT EXISTS standby_oracle_tenant LOG_RESTORE_SOURCE = 'service=$server_ip_port_1;$server_ip_port_2 USER=mytest@oracle PASSWORD=test' PRIMARY_ZONE='z1', RESOURCE_POOL_LIST=('pool_1'),locality='F@z1,F@z2', comment='aaaaaaaa';
--enable_all_result_log
ob1.check_until_timeout SELECT count(*) FROM oceanbase.__all_tenant WHERE tenant_name='standby_oracle_tenant', 1, 100;
let $tenant_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name='standby_oracle_tenant', tenant_id, 1);
ob1.check_until_timeout SELECT count(*) FROM oceanbase.__all_virtual_ls_status WHERE tenant_id=$tenant_id, 5, 50;
#验证备库新建的日志流，不同的日志流组，应该平铺在不同的unit组中
ob1.mysql_p select ls_id, ls_group_id, unit_group_id from oceanbase.__all_virtual_ls_status WHERE tenant_id = $tenant_id;

ob1.mysql alter system set ls_gc_delay_time = '0s' tenant='oracle';
ob1.mysql alter system set ls_gc_delay_time = '0s' tenant='standby_oracle_tenant';
ob1.mysql alter tenant oracle set primary_zone = 'z1';
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_balance_job_history where tenant_id = $tenant_id, 1, 100;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_ls_status where status = 'WAIT_OFFLINE', 0, 100;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_log_stat where tenant_id = $oracle_id, 9, 100;
connection sys_conn;
CREATE RESOURCE POOL pool_2 UNIT large_unit, UNIT_NUM 1;
let $server_ip_port_1=deploy_get_value(ob1.select select concat(svr_ip,':',sql_port) as host from CDB_OB_LS_LOCATIONS where tenant_id = $oracle_id and ls_id = 1 and role = 'LEADER' order by svr_ip, sql_port limit 1;, host, 1);
let $server_ip_port_2=deploy_get_value(ob1.select select concat(svr_ip,':',sql_port) as host from CDB_OB_LS_LOCATIONS where tenant_id = $oracle_id and ls_id = 1 and role = 'FOLLOWER' order by svr_ip, sql_port limit 1, host, 1);
#TODO
#--error 4179
#--disable_all_result_log
#eval CREATE STANDBY TENANT standby_oracle_tenant1 LOG_RESTORE_SOURCE = 'service=$server_ip_port_1;$server_ip_port_2 USER=mytest@oracle PASSWORD=test' PRIMARY_ZONE='z1', RESOURCE_POOL_LIST=('pool_2'),locality='F@z1,F@z2', comment='aaaaaaaa';
#--enable_all_result_log


#验证加密
ob_connect(primary_tenant_conn, ob1.z1.obs0,SYS@oracle,,SYS,,USE_OB_CONNECTOR);
connection primary_tenant_conn;
alter system set tde_method = 'internal';
sleep 2;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_server_schema_info as a join oceanbase.__all_virtual_server_schema_info as b on a.tenant_id = b.tenant_id  where a.refreshed_schema_version != b.refreshed_schema_version or a.refreshed_schema_version % 8 != 0, 0, 20;
connection primary_tenant_conn;
ADMINISTER KEY MANAGEMENT CREATE KEYSTORE keystore_name IDENTIFIED BY testtest;
sleep 2;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_server_schema_info as a join oceanbase.__all_virtual_server_schema_info as b on a.tenant_id = b.tenant_id  where a.refreshed_schema_version != b.refreshed_schema_version or a.refreshed_schema_version % 8 != 0, 0, 20;
ADMINISTER KEY MANAGEMENT SET KEYSTORE OPEN IDENTIFIED BY testtest;
sleep 2;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_server_schema_info as a join oceanbase.__all_virtual_server_schema_info as b on a.tenant_id = b.tenant_id  where a.refreshed_schema_version != b.refreshed_schema_version or a.refreshed_schema_version % 8 != 0, 0, 20;
ADMINISTER KEY MANAGEMENT SET KEY IDENTIFIED BY testtest;
sleep 2;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_server_schema_info as a join oceanbase.__all_virtual_server_schema_info as b on a.tenant_id = b.tenant_id  where a.refreshed_schema_version != b.refreshed_schema_version or a.refreshed_schema_version % 8 != 0, 0, 20;
create user link1 IDENTIFIED BY 123;
--disable_all_result_log
eval create database link my_link1 connect to link1@oracle identified by 123 host '$server_ip_port_1';
--enable_all_result_log
create tablespace haha;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_server_schema_info as a join oceanbase.__all_virtual_server_schema_info as b on a.tenant_id = b.tenant_id  where a.refreshed_schema_version != b.refreshed_schema_version or a.refreshed_schema_version % 8 != 0, 0, 20;
ob1.check_until_timeout select count(*) from  oceanbase.__all_virtual_master_key_version_info as a join oceanbase.__all_virtual_master_key_version_info as b on  a.tenant_id = b.tenant_id  where a.max_active_version != b.expect_version, 0, 20;
alter tablespace haha encryption using 'aes-256';
create table t1 (v1 int) tablespace haha;
insert into t1 values(1);
ob1.mysql alter system major freeze tenant = 'oracle';
ob1.check_until_timeout select (frozen_scn - last_scn) as result from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id=$oracle_id, 0, 600;
let $gts = deploy_get_value(ob1.select select ts_value from oceanbase.V\$OB_TIMESTAMP_SERVICE where tenant_id = $oracle_id, ts_value, 1);
ob1.check_until_timeout select count(*) from oceanbase.DBA_OB_TENANTS where READABLE_SCN > $gts and tenant_name = 'standby_oracle_tenant', 1, 100;
ob_connect(standby_tenant_conn, ob1.z1.obs0,SYS@standby_oracle_tenant,,SYS,,USE_OB_CONNECTOR);
connection standby_tenant_conn;
select * from t1;

#验证秘钥中出现\0没有问题
ob1.z3.obs0.force_stop;
ob1.z3.obs1.force_stop;
connection sys_conn;
--disable_all_result_log
eval CREATE RESOURCE POOL pool_3 UNIT large_unit, UNIT_NUM 1, zone_list = ('z1', 'z2');
eval CREATE STANDBY TENANT standby_oracle_tenant2 LOG_RESTORE_SOURCE = 'service=$server_ip_port_1;$server_ip_port_2 USER=mytest@oracle PASSWORD=test' PRIMARY_ZONE='z1', RESOURCE_POOL_LIST=('pool_3'),locality='F@z1,F@z2', comment='aaaaaaaa';
--enable_all_result_log

