# CASE_OWNER:
#    @jinqian.zzy
# CASE_DESC:
#    This case is aimed to test add ls replica sql command
#    We designed following cases to simulate different scenes:
#
#    CASE 1: basic test
#    CASE 2: modify error case
#    CASE 3: modify success case
#######################################################################
#                        create inital objects
#######################################################################

ob1=OBI(cluster=2:2:2,proxy_num=0,init_unit_cpu=0);
source include/mini_ob_config.inc;
ob1.set extra_config=$mini_ob_config;
ob1.reboot;

ob1.mysql ALTER SYSTEM SET enable_rereplication = 'false';
ob1.mysql alter system set server_permanent_offline_time = '20s';
ob1.mysql alter system set debug_sync_timeout = '100000s';

let $proxy_ip = deploy_get_value(ob1.z1.obs1.ip);
let $proxy_port = deploy_get_value(ob1.z1.obs1.mysql_port);
connect(sys_conn, $proxy_ip, root@sys,,oceanbase, $proxy_port);

source include/create_unit_config.inc;
ob1.mysql CREATE RESOURCE POOL tenant_pool UNIT = "2c2g", UNIT_NUM = 2, ZONE_LIST = ('z1', 'z2', 'z3');
ob1.mysql CREATE TENANT mysql_tenant RESOURCE_POOL_LIST=('tenant_pool'), LOCALITY = "F@z1, F@z2, F@z3", PRIMARY_ZONE = "z1" SET ob_tcp_invited_nodes='%';
connect(mysql_tenant, $proxy_ip, root@mysql_tenant,,oceanbase, $proxy_port);

connection sys_conn;
let $tenant_id = deploy_get_value(ob1.select SELECT tenant_id FROM oceanbase.DBA_OB_TENANTS WHERE tenant_name = "mysql_tenant", tenant_id, 1);
let $meta_tenant_id = deploy_get_value(ob1.select SELECT tenant_id - 1 as meta_tenant_id FROM oceanbase.DBA_OB_TENANTS WHERE tenant_name = "mysql_tenant", meta_tenant_id, 1);
let $meta_tenant_name = deploy_get_value(ob1.select SELECT tenant_name FROM oceanbase.DBA_OB_TENANTS WHERE tenant_id = $meta_tenant_id, tenant_name, 1);

ob1.check_until_timeout select count(*) from CDB_OB_LS_LOCATIONS where tenant_id = $tenant_id and ls_id = 1001 and role = 'leader', 1, 10;
ob1.check_until_timeout select count(*) from CDB_OB_LS_LOCATIONS where tenant_id = $tenant_id and ls_id = 1002 and role = 'leader', 1, 10;
ob1.check_until_timeout select count(*) from GV\$OB_LOG_STAT where tenant_id = $tenant_id and ls_id = 1001 and role = 'leader', 1, 10;
ob1.check_until_timeout select count(*) from GV\$OB_LOG_STAT where tenant_id = $tenant_id and ls_id = 1002 and role = 'leader', 1, 10;

# get servers' addr in z1, z2, z3
let $z1_obs0_ip = deploy_get_value(ob1.z1.obs0.ip);
let $z1_obs0_port = deploy_get_value(ob1.z1.obs0.port);
let $z1_obs0 = $z1_obs0_ip:$z1_obs0_port;

let $z1_obs1_ip = deploy_get_value(ob1.z1.obs1.ip);
let $z1_obs1_port = deploy_get_value(ob1.z1.obs1.port);
let $z1_obs1 = $z1_obs1_ip:$z1_obs1_port;

let $z2_obs0_ip = deploy_get_value(ob1.z2.obs0.ip);
let $z2_obs0_port = deploy_get_value(ob1.z2.obs0.port);
let $z2_obs0 = $z2_obs0_ip:$z2_obs0_port;

let $z2_obs1_ip = deploy_get_value(ob1.z2.obs1.ip);
let $z2_obs1_port = deploy_get_value(ob1.z2.obs1.port);
let $z2_obs1 = $z2_obs1_ip:$z2_obs1_port;

let $z3_obs0_ip = deploy_get_value(ob1.z3.obs0.ip);
let $z3_obs0_port = deploy_get_value(ob1.z3.obs0.port);
let $z3_obs0 = $z3_obs0_ip:$z3_obs0_port;

let $z3_obs1_ip = deploy_get_value(ob1.z3.obs1.ip);
let $z3_obs1_port = deploy_get_value(ob1.z3.obs1.port);
let $z3_obs1 = $z3_obs1_ip:$z3_obs1_port;


let $tenant_ls_id = deploy_get_value(ob1.select SELECT ls_id as ls_id_tmp FROM oceanbase.CDB_OB_LS_LOCATIONS WHERE svr_ip = '$z1_obs0_ip' AND svr_port = $z1_obs0_port AND ls_id > 1, ls_id_tmp, 1);

--disable_query_log
--echo ========================================================================
--echo ||                    [MILESTONE] prepare finished                    ||
--echo ========================================================================

--echo ========================================================================
--echo ||              [MILESTONE] case 1: basic test                        ||
--echo ========================================================================

--echo 1.1 tenant not exist
--error 5157
alter system modify ls = 100 paxos_replica_num=3 tenant='mysql_tenant_x';

--echo 1.2 ls not exist
--error 4018
alter system modify ls = 100 paxos_replica_num=3 tenant='mysql_tenant';

--echo 1.3 meta tenant can not operate normal tenant ls
--error 4018
eval alter system modify ls=$tenant_ls_id paxos_replica_num=3 tenant='$meta_tenant_name';

--echo ========================================================================
--echo ||           [MILESTONE] case 2: modify error case                    ||
--echo ========================================================================
--echo paxos_replica_num error

--error 1210
eval alter system modify ls=$tenant_ls_id paxos_replica_num=1 tenant='mysql_tenant';
--error 1210
eval alter system modify ls=$tenant_ls_id paxos_replica_num=2 tenant='mysql_tenant';
--error 1210
eval alter system modify ls=$tenant_ls_id paxos_replica_num=3 tenant='mysql_tenant';
--error 1210
eval alter system modify ls=$tenant_ls_id paxos_replica_num=4 tenant='mysql_tenant';
--error 1210
eval alter system modify ls=$tenant_ls_id paxos_replica_num=5 tenant='mysql_tenant';
--error 1210
eval alter system modify ls=$tenant_ls_id paxos_replica_num=6 tenant='mysql_tenant';
--error 1210
eval alter system modify ls=$tenant_ls_id paxos_replica_num=7 tenant='mysql_tenant';
--error 1210
eval alter system modify ls=$tenant_ls_id paxos_replica_num=8 tenant='mysql_tenant';

--echo ========================================================================
--echo ||        [MILESTONE] case 3: modify success case                     ||
--echo ========================================================================

ob1.z2.obs0.force_stop;
ob1.check_until_timeout select count(*) from __all_server where SVR_IP = '$z4_obs0_ip' and SVR_PORT = '$z4_obs0_port' and STATUS = 'ACTIVE', 0, 60;

# wait until member permanent offline and remove from member list
ob1.check_until_timeout select count(*) from __all_virtual_ls_meta_table where ls_id = $tenant_ls_id, 2, 60;
ob1.check_until_timeout SELECT COUNT(*) = 0 FROM oceanbase.CDB_OB_LS_LOCATIONS WHERE tenant_id = $tenant_id AND ls_id = $tenant_ls_id AND role = "LEADER" AND member_list LIKE '%$z2_obs0%', 1, 20;
sleep 3;

--echo modify p to 2
eval alter system modify ls=$tenant_ls_id paxos_replica_num=2 tenant='mysql_tenant';
ob1.check_until_timeout select PAXOS_REPLICA_NUMBER from __all_virtual_ls_meta_table where role = 1 and ls_id = $tenant_ls_id, 2, 60;
sleep 3;
eval select LS_ID, ZONE, ROLE, PAXOS_REPLICA_NUMBER, REPLICA_TYPE from __all_virtual_ls_meta_table where ls_id = $tenant_ls_id order by SVR_PORT;

--echo ========================================================================
--echo ||                [MILESTONE] print history table                     ||
--echo ========================================================================
select tenant_id, ls_id, task_type, task_status, priority, target_paxos_replica_number, target_replica_type, source_paxos_replica_number, source_replica_type, comment, is_manual from cdb_ob_ls_replica_task_history;
