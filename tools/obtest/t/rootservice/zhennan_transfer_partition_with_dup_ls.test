#####################
# owner : wangzhennan.wzn
# owner group : RS
# description : transfer partition with duplicate LS
#####################

ob1=OBI(cluster=2:2:2,proxy_num=0,init_unit_cpu=0);
let $extra_conf = "cpu_count=10,memory_limit='20G',system_memory='5G',__min_full_resource_pool_memory='1073741824',stack_size='1536K',cache_wash_threshold='1G',enable_async_syslog=false,_private_buffer_size='16K',_fast_commit_callback_count='1',log_disk_size='40G'";
ob1.z1.obs0.set extra_config=$extra_conf;
ob1.z1.obs1.set extra_config=$extra_conf;
ob1.z2.obs0.set extra_config=$extra_conf;
ob1.z2.obs1.set extra_config=$extra_conf;
ob1.reboot;

ob1.mysql alter system set debug_sync_timeout = '1000s';
ob_connect(conn_sys, ob1.z1.obs0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);

--echo # create mysql tenant
CREATE RESOURCE UNIT if not exists unit_1 MAX_CPU 2, MEMORY_SIZE='3G';
CREATE RESOURCE POOL if not exists pool_1 UNIT = 'unit_1', UNIT_NUM = 2;
CREATE TENANT mysql RESOURCE_POOL_LIST = ('pool_1'), primary_zone='z1', locality="F@z1, F@z2, F@z3" set ob_tcp_invited_nodes='%';

let $mysql_tenant_id = deploy_get_value(ob1.select select tenant_id from DBA_OB_TENANTS where tenant_name = 'mysql', tenant_id, 1);
let $mysql_leader_ip_port=deploy_get_value(ob1.select select concat(svr_ip,':',svr_port) as host from CDB_OB_LS_LOCATIONS where tenant_id = $mysql_tenant_id and ls_id =  1 and role = 'LEADER' limit 1, host, 1);
let $mysql_leader_obs =deploy_get_value(ob1.get_obs_by_addr $mysql_leader_ip_port);
ob_connect(conn_mysql, $mysql_leader_obs, root@mysql, , test, , USE_MYSQL_CONNECTOR);

--echo ##################################################
--echo # 0. prepare data
--echo # trun off the actual duplicate_scope conversion
ob1.mysql alter system set enable_rebalance = false tenant all_user;
ob1.mysql alter system set partition_balance_schedule_interval = '0s' tenant all_user;
--echo # create table
let $batch_count = 2;
let $idx = 1;
while ($idx <= $batch_count)
{
  eval create table normal_part_zero_$idx(c1 int, c2 int, c3 longtext, index(c1) local, index(c2) global);
  eval create table normal_part_one_$idx(c1 int, c2 int, c3 longtext, index(c1) local, index(c2) global) partition by hash(c1) partitions 2;
  eval create table normal_part_two_$idx(c1 int, c2 int, c3 longtext, index(c1) local, index(c2) global) partition by range(c1) subpartition by hash(c1) subpartitions 2 (partition p1 values less than (100), partition p2 values less than MAXVALUE);
  eval create table dup_part_zero_$idx(c1 int, c2 int, c3 longtext, index(c1) local, index(c2) global) duplicate_scope = 'cluster';
  eval create table dup_part_one_$idx(c1 int, c2 int, c3 longtext, index(c1) local, index(c2) global) duplicate_scope = 'cluster' partition by hash(c1) partitions 2;
  eval create table dup_part_two_$idx(c1 int, c2 int, c3 longtext, index(c1) local, index(c2) global) duplicate_scope = 'cluster' partition by range(c1) subpartition by hash(c1) subpartitions 2 (partition p1 values less than (100), partition p2 values less than MAXVALUE);
  inc $idx;
}
let $dup_ls_id = deploy_get_value(ob1.select select ls_id from CDB_OB_LS where tenant_id = $mysql_tenant_id and flag like "%duplicate%" order by ls_id limit 1, ls_id, 1);
let $normal_ls_id = deploy_get_value(ob1.select select ls_id from CDB_OB_LS where tenant_id = $mysql_tenant_id and ls_id > 1 and flag not like "%duplicate%" order by ls_id limit 1, ls_id, 1);

--echo # all normal tables are on normal LS
ob1.check_until_timeout select count(*) from CDB_OB_TABLE_LOCATIONS where tenant_id = $mysql_tenant_id and table_name like "%normal_part_%" and ls_id = $dup_ls_id, 0, 3;
--echo # all dup tables are on dup LS
ob1.check_until_timeout select count(*) from CDB_OB_TABLE_LOCATIONS where tenant_id = $mysql_tenant_id and table_name like "%dup_part_%" and ls_id != $dup_ls_id, 0, 3;

--echo ##################################################
--echo # 1. transfer partition to unmatched LS is not allowed
--echo ##
--echo # 1.1 transfer partition of normal table to dup ls is not allowed
let $table_id = deploy_get_value(ob1.select select table_id from CDB_OB_TABLE_LOCATIONS where tenant_id = $mysql_tenant_id and table_name = 'normal_part_zero_1', table_id, 1);
let $object_id = $table_id;
connection conn_sys;
--error 4179
eval ALTER SYSTEM TRANSFER PARTITION TABLE_ID $table_id, OBJECT_ID $object_id TO LS $dup_ls_id tenant mysql;
--echo ##
--echo # 1.2 transfer partition of dup table to normal ls is not allowed
let $table_id = deploy_get_value(ob1.select select table_id from CDB_OB_TABLE_LOCATIONS where tenant_id = $mysql_tenant_id and table_name = 'dup_part_zero_1', table_id, 1);
let $object_id = $table_id;
connection conn_sys;
--error 4179
eval ALTER SYSTEM TRANSFER PARTITION TABLE_ID $table_id, OBJECT_ID $object_id TO LS $normal_ls_id tenant mysql;

--echo ##################################################
--echo # 2. transfer partition of duplicate table from normal ls to dup ls
connection conn_mysql;
let $idx = 1;
while ($idx <= $batch_count)
{
  eval alter table normal_part_zero_$idx duplicate_scope = 'cluster';
  eval alter table normal_part_one_$idx duplicate_scope = 'cluster';
  eval alter table normal_part_two_$idx duplicate_scope = 'cluster';
  let $table_id = deploy_get_value(ob1.select select table_id from CDB_OB_TABLE_LOCATIONS where tenant_id = $mysql_tenant_id and table_name = 'normal_part_zero_$idx', table_id, 1);
  let $object_id = $table_id;
  eval ALTER SYSTEM TRANSFER PARTITION TABLE_ID $table_id, OBJECT_ID $object_id TO LS $dup_ls_id;
  let $table_id = deploy_get_value(ob1.select select table_id from CDB_OB_TABLE_LOCATIONS where tenant_id = $mysql_tenant_id and table_name = 'normal_part_one_$idx', table_id, 1);
  let $object_id = deploy_get_value(ob1.select select object_id from CDB_OB_TABLE_LOCATIONS where tenant_id = $mysql_tenant_id and table_name = 'normal_part_one_$idx' and partition_name = 'p0', object_id, 1);
  eval ALTER SYSTEM TRANSFER PARTITION TABLE_ID $table_id, OBJECT_ID $object_id TO LS $dup_ls_id;
  let $table_id = deploy_get_value(ob1.select select table_id from CDB_OB_TABLE_LOCATIONS where tenant_id = $mysql_tenant_id and table_name = 'normal_part_two_$idx', table_id, 1);
  let $object_id = deploy_get_value(ob1.select select object_id from CDB_OB_TABLE_LOCATIONS where tenant_id = $mysql_tenant_id and table_name = 'normal_part_two_$idx' and subpartition_name = 'p1sp0', object_id, 1);
  eval ALTER SYSTEM TRANSFER PARTITION TABLE_ID $table_id, OBJECT_ID $object_id TO LS $dup_ls_id;
  inc $idx;
}
--echo # verify partitions have been transferred to dup_ls
ob1.check_until_timeout select count(*) from CDB_OB_TABLE_LOCATIONS where tenant_id = $mysql_tenant_id and table_name like "%normal_part_zero_%" and ls_id != $dup_ls_id, 0, 420;
ob1.check_until_timeout select count(*) from CDB_OB_TABLE_LOCATIONS where tenant_id = $mysql_tenant_id and table_name like "%normal_part_one_%" and partition_name = 'p0' and ls_id != $dup_ls_id, 0, 420;
ob1.check_until_timeout select count(*) from CDB_OB_TABLE_LOCATIONS where tenant_id = $mysql_tenant_id and table_name like "%normal_part_two_%" and subpartition_name = 'p1sp0' and ls_id != $dup_ls_id, 0, 420;

--echo ##################################################
--echo # 3. transfer partition of normal table from dup ls to normal ls
connection conn_mysql;
let $idx = 1;
while ($idx <= $batch_count)
{
  eval alter table dup_part_zero_$idx duplicate_scope = 'none';
  eval alter table dup_part_one_$idx duplicate_scope = 'none';
  eval alter table dup_part_two_$idx duplicate_scope = 'none';
  let $table_id = deploy_get_value(ob1.select select table_id from CDB_OB_TABLE_LOCATIONS where tenant_id = $mysql_tenant_id and table_name = 'dup_part_zero_$idx', table_id, 1);
  let $object_id = $table_id;
  eval ALTER SYSTEM TRANSFER PARTITION TABLE_ID $table_id, OBJECT_ID $object_id TO LS $normal_ls_id;
  let $table_id = deploy_get_value(ob1.select select table_id from CDB_OB_TABLE_LOCATIONS where tenant_id = $mysql_tenant_id and table_name = 'dup_part_one_$idx', table_id, 1);
  let $object_id = deploy_get_value(ob1.select select object_id from CDB_OB_TABLE_LOCATIONS where tenant_id = $mysql_tenant_id and table_name = 'dup_part_one_$idx' and partition_name = 'p0', object_id, 1);
  eval ALTER SYSTEM TRANSFER PARTITION TABLE_ID $table_id, OBJECT_ID $object_id TO LS $normal_ls_id;
  let $table_id = deploy_get_value(ob1.select select table_id from CDB_OB_TABLE_LOCATIONS where tenant_id = $mysql_tenant_id and table_name = 'dup_part_two_$idx', table_id, 1);
  let $object_id = deploy_get_value(ob1.select select object_id from CDB_OB_TABLE_LOCATIONS where tenant_id = $mysql_tenant_id and table_name = 'dup_part_two_$idx' and subpartition_name = 'p1sp0', object_id, 1);
  eval ALTER SYSTEM TRANSFER PARTITION TABLE_ID $table_id, OBJECT_ID $object_id TO LS $normal_ls_id;
  inc $idx;
}
--echo # verify partitions have been transferred out of dup ls
ob1.check_until_timeout select count(*) from CDB_OB_TABLE_LOCATIONS where tenant_id = $mysql_tenant_id and table_name like "%dup_part_zero_%" and ls_id = $dup_ls_id, 0, 420;
ob1.check_until_timeout select count(*) from CDB_OB_TABLE_LOCATIONS where tenant_id = $mysql_tenant_id and table_name like "%dup_part_one_%" and partition_name = 'p0' and ls_id = $dup_ls_id, 0, 420;
ob1.check_until_timeout select count(*) from CDB_OB_TABLE_LOCATIONS where tenant_id = $mysql_tenant_id and table_name like "%dup_part_two_%" and subpartition_name = 'p1sp0' and ls_id = $dup_ls_id, 0, 420;

--echo ##################################################
--echo # 4. transfer partition of duplicate table between dup ls
--echo ##
--echo # 4.1. create redundant dup ls manually
ob1.check_until_timeout select count(*) from CDB_OB_LS where tenant_id = $mysql_tenant_id and flag like "%DUPLICATE%" and status = 'NORMAL' and ls_group_id = 0, 1, 30;
connection conn_sys;
alter system change tenant mysql;
let $redundant_dup_ls_id = 1999;
let $valid_ls_group_id = deploy_get_value(ob1.select select ls_group_id from CDB_OB_LS where tenant_id = $mysql_tenant_id and flag not like "%DUPLICATE%" and ls_group_id !=0 order by ls_group_id limit 1, ls_group_id, 1);
--disable_query_log
eval insert into __all_ls (ls_id, ls_group_id, status, flag, create_scn) values ($redundant_dup_ls_id, 0, 'CREATING', 'DUPLICATE', timestamp_to_scn(now()));
--enable_query_log
alter system change tenant sys;
ob1.check_until_timeout select count(*) from CDB_OB_LS where tenant_id = $mysql_tenant_id and flag like "%DUPLICATE%" and status = 'NORMAL', 2, 60;
--echo ##
--echo # 4.2. transfer partition between dup ls with 0 ls_group_id
let $table_id = deploy_get_value(ob1.select select table_id from CDB_OB_TABLE_LOCATIONS where tenant_id = $mysql_tenant_id and table_name = 'normal_part_zero_1', table_id, 1);
let $object_id = $table_id;
connection conn_mysql;
eval ALTER SYSTEM TRANSFER PARTITION TABLE_ID $table_id, OBJECT_ID $object_id TO LS $redundant_dup_ls_id;
ob1.check_until_timeout select count(*) from CDB_OB_TABLE_LOCATIONS where tenant_id = $mysql_tenant_id and table_id = $table_id and ls_id != $redundant_dup_ls_id, 0, 420;
ob1.check_until_timeout select count(*) from CDB_OB_TRANSFER_PARTITION_TASKS where tenant_id = $mysql_tenant_id and table_id = $table_id, 0, 30;
ob1.check_until_timeout select count(*) from CDB_OB_BALANCE_JOBS where tenant_id = $mysql_tenant_id, 0, 60;
connection conn_sys;
let $last_balance_job = deploy_get_value(ob1.select select job_id from CDB_OB_BALANCE_JOB_HISTORY where tenant_id = $mysql_tenant_id order by finish_time desc limit 1, job_id, 1);
--disable_query_log
eval select task_type, src_ls, dest_ls, finished_part_count, ls_group_id from CDB_OB_BALANCE_TASK_HISTORY where tenant_id = $mysql_tenant_id and job_id = $last_balance_job order by task_id;
--enable_query_log
--echo ##
--echo # 4.3. transfer partition from dup_ls with valid_ls_group_id to dup ls with ls_group_id = 0
connection conn_sys;
alter system change tenant mysql;
--disable_query_log
eval update __all_ls set ls_group_id = $valid_ls_group_id where ls_id = $redundant_dup_ls_id;
--enable_query_log
alter system change tenant sys;
ob1.check_until_timeout select count(*) from CDB_OB_LS where tenant_id = $mysql_tenant_id and ls_id = $redundant_dup_ls_id and ls_group_id != $valid_ls_group_id, 0, 30;
connection conn_mysql;
eval ALTER SYSTEM TRANSFER PARTITION TABLE_ID $table_id, OBJECT_ID $object_id TO LS $dup_ls_id;
ob1.check_until_timeout select count(*) from CDB_OB_TABLE_LOCATIONS where tenant_id = $mysql_tenant_id and table_id = $table_id and ls_id != $dup_ls_id, 0, 420;
ob1.check_until_timeout select count(*) from CDB_OB_TRANSFER_PARTITION_TASKS where tenant_id = $mysql_tenant_id and table_id = $table_id, 0, 30;
ob1.check_until_timeout select count(*) from CDB_OB_BALANCE_JOBS where tenant_id = $mysql_tenant_id, 0, 60;
connection conn_sys;
let $last_balance_job = deploy_get_value(ob1.select select job_id from CDB_OB_BALANCE_JOB_HISTORY where tenant_id = $mysql_tenant_id order by finish_time desc limit 1, job_id, 1);
--disable_query_log
eval select task_type, src_ls, dest_ls, finished_part_count, ls_group_id from CDB_OB_BALANCE_TASK_HISTORY where tenant_id = $mysql_tenant_id and job_id = $last_balance_job order by task_id;
--enable_query_log
--echo ##
--echo # 4.4. transfer partition from dup ls with ls_group_id = 0 to dup_ls with valid_ls_group_id
connection conn_mysql;
eval ALTER SYSTEM TRANSFER PARTITION TABLE_ID $table_id, OBJECT_ID $object_id TO LS $redundant_dup_ls_id;
ob1.check_until_timeout select count(*) from CDB_OB_TABLE_LOCATIONS where tenant_id = $mysql_tenant_id and table_id = $table_id and ls_id != $redundant_dup_ls_id, 0, 420;
ob1.check_until_timeout select count(*) from CDB_OB_TRANSFER_PARTITION_TASKS where tenant_id = $mysql_tenant_id and table_id = $table_id, 0, 30;
ob1.check_until_timeout select count(*) from CDB_OB_BALANCE_JOBS where tenant_id = $mysql_tenant_id, 0, 60;
connection conn_sys;
let $last_balance_job = deploy_get_value(ob1.select select job_id from CDB_OB_BALANCE_JOB_HISTORY where tenant_id = $mysql_tenant_id order by finish_time desc limit 1, job_id, 1);
--disable_query_log
eval select task_type, src_ls, dest_ls, finished_part_count, ls_group_id from CDB_OB_BALANCE_TASK_HISTORY where tenant_id = $mysql_tenant_id and job_id = $last_balance_job order by task_id;
--enable_query_log
--echo ##
--echo # 4.5. transfer partition between dup_ls with valid_ls_group_id
connection conn_sys;
alter system change tenant mysql;
--disable_query_log
eval update __all_ls set ls_group_id = $valid_ls_group_id where ls_id = $dup_ls_id;
--enable_query_log
alter system change tenant sys;
ob1.check_until_timeout select count(*) from CDB_OB_LS where tenant_id = $mysql_tenant_id and ls_id = $dup_ls_id and ls_group_id != $valid_ls_group_id, 0, 30;
connection conn_mysql;
eval ALTER SYSTEM TRANSFER PARTITION TABLE_ID $table_id, OBJECT_ID $object_id TO LS $dup_ls_id;
ob1.check_until_timeout select count(*) from CDB_OB_TABLE_LOCATIONS where tenant_id = $mysql_tenant_id and table_id = $table_id and ls_id != $dup_ls_id, 0, 420;
ob1.check_until_timeout select count(*) from CDB_OB_TRANSFER_PARTITION_TASKS where tenant_id = $mysql_tenant_id and table_id = $table_id, 0, 30;
ob1.check_until_timeout select count(*) from CDB_OB_BALANCE_JOBS where tenant_id = $mysql_tenant_id, 0, 60;
connection conn_sys;
let $last_balance_job = deploy_get_value(ob1.select select job_id from CDB_OB_BALANCE_JOB_HISTORY where tenant_id = $mysql_tenant_id order by finish_time desc limit 1, job_id, 1);
--disable_query_log
eval select task_type, src_ls, dest_ls, finished_part_count, ls_group_id from CDB_OB_BALANCE_TASK_HISTORY where tenant_id = $mysql_tenant_id and job_id = $last_balance_job order by task_id;
--enable_query_log
--echo # clear manual redundant dup ls
connection conn_sys;
alter system change tenant mysql;
--disable_query_log
eval update __all_ls set status = 'DROPPING' where ls_id = $redundant_dup_ls_id;
--enable_query_log
ob1.check_until_timeout select count(*) from CDB_OB_LS where tenant_id = $mysql_tenant_id and ls_id = $redundant_dup_ls_id, 0, 120;

--echo ##
--echo # 4.6. make 2 dup ls exist in the same time by turn off enable_rebalance
ob1.mysql set ob_global_debug_sync = 'BEFORE_DROPPING_LS_IN_BALANCE_MERGE_TASK wait_for signal_merge execute 1000';
--echo # turn on balance
ob1.mysql alter system set enable_rebalance = true tenant mysql;
ob1.mysql alter system set partition_balance_schedule_interval = '10s' tenant mysql;
ob1.check_until_timeout select count(distinct(ls_id)) from CDB_OB_LS where tenant_id = $mysql_tenant_id and flag like "%duplicate%" and status = 'NORMAL', 2, 420;
--echo # turn off balance
ob1.mysql alter system set enable_rebalance = false tenant mysql;
ob1.mysql alter system set partition_balance_schedule_interval = '0s' tenant mysql;
ob1.mysql set ob_global_debug_sync = 'BEFORE_DROPPING_LS_IN_BALANCE_MERGE_TASK clear';
ob1.mysql set ob_global_debug_sync = 'now signal signal_merge';
ob1.check_until_timeout select count(*) from CDB_OB_BALANCE_JOBS where tenant_id = $mysql_tenant_id, 0, 240;
--echo ##
--echo # 4.7. transfer partition between dup ls
let $redundant_dup_ls_id = deploy_get_value(ob1.select select ls_id from CDB_OB_LS where tenant_id = $mysql_tenant_id and flag like "%duplicate%" and ls_id != $dup_ls_id and status = 'NORMAL' order by ls_id limit 1, ls_id, 1);
--echo # verify partitions are on original dup_ls_id
ob1.check_until_timeout select count(*) from CDB_OB_TABLE_LOCATIONS where tenant_id = $mysql_tenant_id and table_name like "%normal_part_zero_%" and ls_id != $dup_ls_id, 0, 3;
ob1.check_until_timeout select count(*) from CDB_OB_TABLE_LOCATIONS where tenant_id = $mysql_tenant_id and table_name like "%normal_part_one_%" and partition_name = 'p0' and ls_id != $dup_ls_id, 0, 3;
ob1.check_until_timeout select count(*) from CDB_OB_TABLE_LOCATIONS where tenant_id = $mysql_tenant_id and table_name like "%normal_part_zero_%" and subpartition_name = 'p1sp0' and ls_id != $dup_ls_id, 0, 3;
connection conn_mysql;
let $idx = 1;
--disable_query_log
while ($idx <= $batch_count)
{
  let $table_id = deploy_get_value(ob1.select select table_id from CDB_OB_TABLE_LOCATIONS where tenant_id = $mysql_tenant_id and table_name = 'normal_part_zero_$idx', table_id, 1);
  let $object_id = $table_id;
  eval ALTER SYSTEM TRANSFER PARTITION TABLE_ID $table_id, OBJECT_ID $object_id TO LS $redundant_dup_ls_id;
  let $table_id = deploy_get_value(ob1.select select table_id from CDB_OB_TABLE_LOCATIONS where tenant_id = $mysql_tenant_id and table_name = 'normal_part_one_$idx', table_id, 1);
  let $object_id = deploy_get_value(ob1.select select object_id from CDB_OB_TABLE_LOCATIONS where tenant_id = $mysql_tenant_id and table_name = 'normal_part_one_$idx' and partition_name = 'p0', object_id, 1);
  eval ALTER SYSTEM TRANSFER PARTITION TABLE_ID $table_id, OBJECT_ID $object_id TO LS $redundant_dup_ls_id;
  let $table_id = deploy_get_value(ob1.select select table_id from CDB_OB_TABLE_LOCATIONS where tenant_id = $mysql_tenant_id and table_name = 'normal_part_two_$idx', table_id, 1);
  let $object_id = deploy_get_value(ob1.select select object_id from CDB_OB_TABLE_LOCATIONS where tenant_id = $mysql_tenant_id and table_name = 'normal_part_two_$idx' and subpartition_name = 'p1sp0', object_id, 1);
  eval ALTER SYSTEM TRANSFER PARTITION TABLE_ID $table_id, OBJECT_ID $object_id TO LS $redundant_dup_ls_id;
  inc $idx;
}
--enable_query_log
--echo # verify partitions are on original redundant_dup_ls_id
ob1.check_until_timeout select count(*) from CDB_OB_BALANCE_JOBS where tenant_id = $mysql_tenant_id and job_type = 'TRANSFER_PARTITION', 1, 30;
ob1.check_until_timeout select count(*) from CDB_OB_TABLE_LOCATIONS where tenant_id = $mysql_tenant_id and table_name like "%normal_part_zero_%" and ls_id != $redundant_dup_ls_id, 0, 420;
ob1.check_until_timeout select count(*) from CDB_OB_TABLE_LOCATIONS where tenant_id = $mysql_tenant_id and table_name like "%normal_part_one_%" and partition_name = 'p0' and ls_id != $redundant_dup_ls_id, 0, 420;
ob1.check_until_timeout select count(*) from CDB_OB_TABLE_LOCATIONS where tenant_id = $mysql_tenant_id and table_name like "%normal_part_zero_%" and subpartition_name = 'p1sp0' and ls_id != $redundant_dup_ls_id, 0, 420;