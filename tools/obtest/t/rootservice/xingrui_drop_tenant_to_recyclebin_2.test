# CASE_OWNER:
#    @xingrui.cwh
# CASE_DESC:
#    验证drop tenant时放入回收站
#    case 3：
#    purge tenant         使用原始的名字（名字重复时，删除最早进入回收站的tenant）将回收站中的tenant删除
#    purge tenant         使用回收站中的名字将回收站中的tenant删除
#    purge recyclebin     将回收站清空

#全部检查对普通租户的影响，普通租户不允许进行以上操作

ob1=OBI(cluster=1, proxy_num = 0, init_unit_cpu = 0);
let $extra_conf = "cpu_count=16,memory_limit='30G',system_memory='5G',__min_full_resource_pool_memory='1073741824',cache_wash_threshold='1G',enable_async_syslog=false";
ob1.z1.obs0.set extra_config=$extra_conf;

ob1.reboot;

let $obs0_ip= deploy_get_value(ob1.z1.obs0.ip);
let $obs0_port= deploy_get_value(ob1.z1.obs0.mysql_port);
connect(sys_conn, $obs0_ip, root@sys,,test, $obs0_port);

source include/create_unit_config.inc;

#case 3.1 purge tenant with original_name/object_name
echo "[CASE 3] [purge tenant with original_name/object_name]";
connection sys_conn;
set @@recyclebin = on;
create resource pool pool10 zone_list = ("z1"), unit = "1c2g", unit_num = 1;
create tenant t10 resource_pool_list = ("pool10") set ob_compatibility_mode = 'mysql' , ob_tcp_invited_nodes='%';
let $t10_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name = 't10', tenant_id, 1);

DROP TENANT t10;

let $object_name_10 = deploy_get_value(ob1.select select object_name from oceanbase.DBA_RECYCLEBIN where type = 'TENANT' and original_name = 't10' order by DROPTIME asc, object_name, 1);
eval select tenant_id, tenant_type, in_recyclebin from oceanbase.DBA_OB_TENANTS where (tenant_id = $t10_id or tenant_id = $t10_id - 1) order by tenant_id;
select original_name, type from oceanbase.DBA_RECYCLEBIN where type = 'TENANT';
eval select tenant_id, is_deleted, status from oceanbase.__all_tenant_history where (tenant_id = $t10_id or tenant_id = $t10_id - 1) order by tenant_id, schema_version;

create resource pool pool11 zone_list = ("z1"), unit = "1c2g", unit_num = 1;
create tenant t10 resource_pool_list = ("pool11") set ob_compatibility_mode = 'mysql' , ob_tcp_invited_nodes='%';
let $t11_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name = 't10', tenant_id, 1);

DROP TENANT t10;

let $object_name_11 = deploy_get_value(ob1.select select object_name from oceanbase.DBA_RECYCLEBIN where type = 'TENANT' and original_name = 't10' order by DROPTIME asc, object_name, 2);
eval select tenant_id, tenant_type, in_recyclebin from oceanbase.DBA_OB_TENANTS where (tenant_id = $t11_id or tenant_id = $t11_id - 1) order by tenant_id;
select original_name, type from oceanbase.DBA_RECYCLEBIN where type = 'TENANT';
eval select tenant_id, is_deleted, status from oceanbase.__all_tenant_history where (tenant_id = $t11_id or tenant_id = $t11_id - 1) order by tenant_id, schema_version;

create resource pool pool12 zone_list = ("z1"), unit = "1c2g", unit_num = 1;
create tenant t10 resource_pool_list = ("pool12") set ob_compatibility_mode = 'mysql' , ob_tcp_invited_nodes='%';
let $t12_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name = 't10', tenant_id, 1);

DROP TENANT t10;

let $object_name_12 = deploy_get_value(ob1.select select object_name from oceanbase.DBA_RECYCLEBIN where type = 'TENANT' and original_name = 't10' order by DROPTIME asc, object_name, 3);
eval select tenant_id, tenant_type, in_recyclebin from oceanbase.DBA_OB_TENANTS where (tenant_id = $t12_id or tenant_id = $t12_id - 1) order by tenant_id;
select original_name, type from oceanbase.DBA_RECYCLEBIN where type = 'TENANT';
eval select tenant_id, is_deleted, status from oceanbase.__all_tenant_history where (tenant_id = $t12_id or tenant_id = $t12_id - 1) order by tenant_id, schema_version;

select count(*) from DBA_RECYCLEBIN where type = 'TENANT' and original_name = 't10';

# purge最早进入回收站的租户
PURGE TENANT T10;

select count(*) from DBA_RECYCLEBIN where type = 'TENANT' and original_name = 't10';
--disable_query_log
eval select count(*) from DBA_RECYCLEBIN where type = 'TENANT' and original_name = 't10' and object_name = '$object_name_10';
--enable_query_log

--disable_query_log
eval PURGE TENANT $object_name_11;
--enable_query_log

select count(*) from DBA_RECYCLEBIN where type = 'TENANT' and original_name = 't10';
--disable_query_log
eval select count(*) from DBA_RECYCLEBIN where type = 'TENANT' and original_name = 't10' and object_name = '$object_name_11';
--enable_query_log

PURGE RECYCLEBIN;

ob1.check_until_timeout select count(*) from oceanbase.DBA_OB_TENANTS where (tenant_id >= $t10_id - 1 and tenant_id <= $t12_id), 0, 100;

eval select tenant_id, tenant_type, in_recyclebin from oceanbase.DBA_OB_TENANTS where (tenant_id >= $t10_id - 1 and tenant_id <= $t12_id) order by tenant_id;
select original_name, type from oceanbase.DBA_RECYCLEBIN where type = 'TENANT';
eval select tenant_id, is_deleted, status from oceanbase.__all_tenant_history where (tenant_id >= $t10_id - 1 and tenant_id <= $t12_id) order by tenant_id, schema_version;
drop resource pool pool10;
drop resource pool pool11;
drop resource pool pool12;

# case 4. 
echo "[CASE 4] [drop tenant to recyclebin & drop tenant force]";
connection sys_conn;
set @@recyclebin = on;
create resource pool pool13 zone_list = ("z1"), unit = "1c2g", unit_num = 1;
create tenant t13 resource_pool_list = ("pool13") set ob_compatibility_mode = 'mysql' , ob_tcp_invited_nodes='%';
let $t13 = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name = 't13', tenant_id, 1);

DROP TENANT t13;

let $object_name_13 = deploy_get_value(ob1.select select object_name from oceanbase.DBA_RECYCLEBIN where type = 'TENANT' and original_name = 't13', object_name, 1);

--error 5157
DROP TENANT T13 FORCE;
--disable_query_log
eval DROP TENANT $object_name_13 FORCE;
--enable_query_log

show recyclebin;
select original_name, type from oceanbase.DBA_RECYCLEBIN where type = 'TENANT';

