# CASE_OWNER:
#    @jinqian.zzy
# CASE_DESC:
#    测试带着仲裁副本的情况下(2F1A 4F1A):
#    1. 移除副本，容灾是否能恢复正常的locality
#    2. 副本降级时，删除副本命令是否能正常工作
#######################################################################
#                        create inital objects
#######################################################################

ob1=OBI(cluster=1:1:1:1:1,proxy_num=0,init_unit_cpu=0,asvr_num=1);
source include/mini_ob_config.inc;
ob1.set extra_config=$mini_ob_config;
ob1.reboot;
sleep 3;

let $arb_extra_conf = "ob_startup_mode=arbitration,cpu_count=1,memory_limit=1G,__easy_memory_limit=256M";

ob1.mysql alter system set debug_sync_timeout = '1000s';
ob1.mysql ALTER SYSTEM SET enable_rebalance = 'false';
ob1.mysql ALTER SYSTEM SET enable_rereplication = 'false';
ob1.mysql alter system set server_permanent_offline_time = '2000s';

let $proxy_ip = deploy_get_value(ob1.z1.obs0.ip);
let $proxy_port = deploy_get_value(ob1.z1.obs0.mysql_port);
connect(sys_conn, $proxy_ip, root@sys,,oceanbase, $proxy_port);

# 获取仲裁server的ip、port
let $arb_svr_ip= deploy_get_value(ob1.asvr0.ip);
let $arb_svr_port= deploy_get_value(ob1.asvr0.port);
# add arbitration service, mytest.jar已经为本集群做了这一步
ob1.check_until_timeout select count(*) as cnt from oceanbase.DBA_OB_ARBITRATION_SERVICE where arbitration_service = "$arb_svr_ip:$arb_svr_port", 1, 30;

--echo =================================================
--echo               create tenant
--echo =================================================

# create new tenant mysql
source include/create_unit_config.inc;
ob1.mysql CREATE RESOURCE POOL tenant_pool UNIT = "2c2g", UNIT_NUM = 1, ZONE_LIST = ('z1', 'z2', 'z3', 'z4');
ob1.mysql CREATE TENANT mysql RESOURCE_POOL_LIST=('tenant_pool'), LOCALITY = "F@z1, F@z2, F@z3, F@z4", PRIMARY_ZONE = "z1", enable_arbitration_service = true SET ob_tcp_invited_nodes='%';

let $tenant_id = deploy_get_value(ob1.select SELECT tenant_id FROM oceanbase.DBA_OB_TENANTS WHERE tenant_name = "mysql", tenant_id, 1);
let $meta_tenant_id = deploy_get_value(ob1.select select tenant_id - 1 as meta_tenant_id from oceanbase.DBA_OB_TENANTS where tenant_name = "mysql", meta_tenant_id, 1);
let $resource_pool_id = deploy_get_value(ob1.select SELECT resource_pool_id FROM oceanbase.__all_resource_pool WHERE tenant_id = $tenant_id, resource_pool_id, 1);


--disable_query_log
--disable_warnings

let $z1_dst_ip0 = deploy_get_value(ob1.z1.obs0.ip);
let $z1_dst_port0 = deploy_get_value(ob1.z1.obs0.port);
let $z1_dst0 = $z1_dst_ip0:$z1_dst_port0;
let $z2_dst_ip0 = deploy_get_value(ob1.z2.obs0.ip);
let $z2_dst_port0 = deploy_get_value(ob1.z2.obs0.port);
let $z2_dst0 = $z2_dst_ip0:$z2_dst_port0;
let $z3_dst_ip0 = deploy_get_value(ob1.z3.obs0.ip);
let $z3_dst_port0 = deploy_get_value(ob1.z3.obs0.port);
let $z3_dst0 = $z3_dst_ip0:$z3_dst_port0;
let $z4_dst_ip0 = deploy_get_value(ob1.z4.obs0.ip);
let $z4_dst_port0 = deploy_get_value(ob1.z4.obs0.port);
let $z4_dst0 = $z4_dst_ip0:$z4_dst_port0;

--echo =================================================
--echo               case 1: 4F1A auto disaser test
--echo =================================================

# 1. 移除2个副本，剩2F，paxos_replica_num=3
eval alter system remove replica ls=1001 server='$z2_dst0' paxos_replica_num = 4 tenant='mysql';
ob1.check_until_timeout SELECT COUNT(*) FROM oceanbase.CDB_OB_LS_LOCATIONS WHERE tenant_id = $tenant_id AND ls_id = 1001 AND role = "LEADER" AND member_list LIKE '%$z2_dst0%', 0, 20;
ob1.check_until_timeout SELECT COUNT(*) FROM oceanbase.CDB_OB_LS_LOCATIONS WHERE tenant_id = $tenant_id AND ls_id = 1001, 3, 30;
ob1.check_until_timeout SELECT COUNT(*) FROM oceanbase.CDB_OB_LS_REPLICA_TASKS WHERE tenant_id = $tenant_id, 0, 20;

--error 1210
eval alter system remove replica ls=1001 server='$z3_dst0' paxos_replica_num = 4 tenant='mysql';

eval alter system remove replica ls=1001 server='$z3_dst0' paxos_replica_num = 3 tenant='mysql';
ob1.check_until_timeout SELECT COUNT(*) FROM oceanbase.CDB_OB_LS_LOCATIONS WHERE tenant_id = $tenant_id AND ls_id = 1001 AND role = "LEADER" AND member_list LIKE '%$z3_dst0%', 0, 20;
ob1.check_until_timeout SELECT COUNT(*) FROM oceanbase.CDB_OB_LS_LOCATIONS WHERE tenant_id = $tenant_id AND ls_id = 1001, 2, 30;
ob1.check_until_timeout SELECT COUNT(*) FROM oceanbase.CDB_OB_LS_REPLICA_TASKS WHERE tenant_id = $tenant_id, 0, 20;

# 容灾可以自动补回来
ob1.mysql ALTER SYSTEM SET enable_rereplication = 'true';

ob1.check_until_timeout SELECT COUNT(*) FROM oceanbase.CDB_OB_LS_LOCATIONS WHERE tenant_id = $tenant_id AND ls_id = 1001 AND role = "LEADER" AND member_list LIKE '%$z3_dst0%', 1, 60;
ob1.check_until_timeout SELECT COUNT(*) FROM oceanbase.CDB_OB_LS_LOCATIONS WHERE tenant_id = $tenant_id AND ls_id = 1001 AND role = "LEADER" AND member_list LIKE '%$z2_dst0%', 1, 60;
ob1.check_until_timeout SELECT COUNT(*) FROM oceanbase.CDB_OB_LS_LOCATIONS WHERE tenant_id = $tenant_id AND ls_id = 1001, 4, 30;
ob1.check_until_timeout SELECT COUNT(*) FROM oceanbase.CDB_OB_LS_LOCATIONS WHERE tenant_id = $tenant_id AND ls_id = 1001 AND role = "LEADER" AND PAXOS_REPLICA_NUMBER = 4, 1, 60;
ob1.check_until_timeout SELECT COUNT(*) FROM oceanbase.CDB_OB_LS_REPLICA_TASKS WHERE tenant_id = $tenant_id, 0, 20;

ob1.mysql ALTER SYSTEM SET enable_rereplication = 'false';

# 2. 移除3个副本，剩1F，paxos_replica_num=1
eval alter system remove replica ls=1001 server='$z2_dst0' paxos_replica_num = 3 tenant='mysql';
ob1.check_until_timeout SELECT COUNT(*) FROM oceanbase.CDB_OB_LS_LOCATIONS WHERE tenant_id = $tenant_id AND ls_id = 1001 AND role = "LEADER" AND member_list LIKE '%$z2_dst0%', 0, 20;
ob1.check_until_timeout SELECT COUNT(*) FROM oceanbase.CDB_OB_LS_LOCATIONS WHERE tenant_id = $tenant_id AND ls_id = 1001, 3, 30;
ob1.check_until_timeout SELECT COUNT(*) FROM oceanbase.CDB_OB_LS_REPLICA_TASKS WHERE tenant_id = $tenant_id, 0, 20;

eval alter system remove replica ls=1001 server='$z3_dst0' paxos_replica_num = 2 tenant='mysql';
ob1.check_until_timeout SELECT COUNT(*) FROM oceanbase.CDB_OB_LS_LOCATIONS WHERE tenant_id = $tenant_id AND ls_id = 1001 AND role = "LEADER" AND member_list LIKE '%$z3_dst0%', 0, 20;
ob1.check_until_timeout SELECT COUNT(*) FROM oceanbase.CDB_OB_LS_LOCATIONS WHERE tenant_id = $tenant_id AND ls_id = 1001, 2, 30;
ob1.check_until_timeout SELECT COUNT(*) FROM oceanbase.CDB_OB_LS_REPLICA_TASKS WHERE tenant_id = $tenant_id, 0, 20;

eval alter system remove replica ls=1001 server='$z4_dst0' paxos_replica_num = 1 tenant='mysql';
ob1.check_until_timeout SELECT COUNT(*) FROM oceanbase.CDB_OB_LS_LOCATIONS WHERE tenant_id = $tenant_id AND ls_id = 1001 AND role = "LEADER" AND member_list LIKE '%$z4_dst0%', 0, 20;
ob1.check_until_timeout SELECT COUNT(*) FROM oceanbase.CDB_OB_LS_LOCATIONS WHERE tenant_id = $tenant_id AND ls_id = 1001, 1, 30;
ob1.check_until_timeout SELECT COUNT(*) FROM oceanbase.CDB_OB_LS_REPLICA_TASKS WHERE tenant_id = $tenant_id, 0, 20;

ob1.mysql ALTER SYSTEM SET enable_rereplication = 'true';

ob1.check_until_timeout SELECT COUNT(*) FROM oceanbase.CDB_OB_LS_LOCATIONS WHERE tenant_id = $tenant_id AND ls_id = 1001 AND role = "LEADER" AND member_list LIKE '%$z3_dst0%', 1, 100;
ob1.check_until_timeout SELECT COUNT(*) FROM oceanbase.CDB_OB_LS_LOCATIONS WHERE tenant_id = $tenant_id AND ls_id = 1001 AND role = "LEADER" AND member_list LIKE '%$z2_dst0%', 1, 100;
ob1.check_until_timeout SELECT COUNT(*) FROM oceanbase.CDB_OB_LS_LOCATIONS WHERE tenant_id = $tenant_id AND ls_id = 1001 AND role = "LEADER" AND member_list LIKE '%$z4_dst0%', 1, 100;
ob1.check_until_timeout SELECT COUNT(*) FROM oceanbase.CDB_OB_LS_LOCATIONS WHERE tenant_id = $tenant_id AND ls_id = 1001, 4, 30;
ob1.check_until_timeout SELECT COUNT(*) FROM oceanbase.CDB_OB_LS_REPLICA_TASKS WHERE tenant_id = $tenant_id, 0, 20;

ob1.mysql ALTER SYSTEM SET enable_rereplication = 'false';

# 3. 删除一F，3F p = 4，降级一个副本, 容灾是否能恢复
eval alter system remove replica ls=1001 server='$z2_dst0' paxos_replica_num = 4 tenant='mysql';
ob1.check_until_timeout SELECT COUNT(*) FROM oceanbase.CDB_OB_LS_LOCATIONS WHERE tenant_id = $tenant_id AND ls_id = 1001 AND role = "LEADER" AND member_list LIKE '%$z2_dst0%', 0, 20;
ob1.check_until_timeout SELECT COUNT(*) FROM oceanbase.CDB_OB_LS_LOCATIONS WHERE tenant_id = $tenant_id AND ls_id = 1001, 3, 30;
ob1.check_until_timeout SELECT COUNT(*) FROM oceanbase.CDB_OB_LS_REPLICA_TASKS WHERE tenant_id = $tenant_id, 0, 20;

ob1.z3.obs0.force_stop;
ob1.check_until_timeout select count(*) as cnt from oceanbase.DBA_OB_SERVERS where zone = 'z3' and status = 'INACTIVE', 1, 30;
ob1.check_until_timeout select COUNT(*) from oceanbase.__all_virtual_log_stat where tenant_id = 1002 and DEGRADED_LIST LIKE '%$z3_dst0%', 2, 20;

#永久下线时间为2000s
ob1.mysql ALTER SYSTEM SET enable_rereplication = 'true';
ob1.check_until_timeout SELECT COUNT(*) FROM oceanbase.CDB_OB_LS_LOCATIONS WHERE tenant_id = $tenant_id AND ls_id = 1001 AND role = "LEADER" AND member_list LIKE '%$z2_dst0%', 1, 60;
ob1.check_until_timeout SELECT COUNT(*) FROM oceanbase.CDB_OB_LS_LOCATIONS WHERE tenant_id = $tenant_id AND ls_id = 1001, 4, 30;
ob1.check_until_timeout SELECT COUNT(*) FROM oceanbase.CDB_OB_LS_REPLICA_TASKS WHERE tenant_id = $tenant_id, 0, 20;
ob1.mysql ALTER SYSTEM SET enable_rereplication = 'false';

--echo =================================================
--echo               case 2: 4F1A remove replica test
--echo =================================================

eval alter system remove replica ls=1001 server='$z2_dst0' paxos_replica_num = 4 tenant='mysql';
ob1.check_until_timeout SELECT COUNT(*) FROM oceanbase.CDB_OB_LS_LOCATIONS WHERE tenant_id = $tenant_id AND ls_id = 1001 AND role = "LEADER" AND member_list LIKE '%$z2_dst0%', 0, 20;
ob1.check_until_timeout SELECT COUNT(*) FROM oceanbase.CDB_OB_LS_LOCATIONS WHERE tenant_id = $tenant_id AND ls_id = 1001, 3, 30;
ob1.check_until_timeout SELECT COUNT(*) FROM oceanbase.CDB_OB_LS_REPLICA_TASKS WHERE tenant_id = $tenant_id, 0, 20;

# 删除3F中的一个可用副本，命令成功，结果上报失败。
eval alter system remove replica ls=1001 server='$z4_dst0' paxos_replica_num = 3 tenant='mysql';
ob1.check_until_timeout SELECT COUNT(*) FROM oceanbase.CDB_OB_LS_REPLICA_TASK_HISTORY WHERE tenant_id = $tenant_id AND ls_id = 1001 and TASK_STATUS = 'FAILED' and EXECUTE_RESULT like '%ret:-4002, OB_INVALID_ARGUMENT;%', 1, 30;
ob1.check_until_timeout SELECT COUNT(*) FROM oceanbase.CDB_OB_LS_REPLICA_TASKS WHERE tenant_id = $tenant_id, 0, 20;

# 此时删除3F中的降级副本，能够删除成功
eval alter system remove replica ls=1001 server='$z3_dst0' paxos_replica_num = 3 tenant='mysql';
ob1.check_until_timeout SELECT COUNT(*) FROM oceanbase.CDB_OB_LS_LOCATIONS WHERE tenant_id = $tenant_id AND ls_id = 1001 AND role = "LEADER" AND member_list LIKE '%$z3_dst0%', 0, 20;
ob1.check_until_timeout SELECT COUNT(*) FROM oceanbase.CDB_OB_LS_REPLICA_TASKS WHERE tenant_id = $tenant_id, 0, 20;


--echo =================================================
--echo               case 3: 2F1A remove replica
--echo =================================================

# 打开容灾开关，变更locality为2F1A
ob1.mysql ALTER SYSTEM SET enable_rereplication = 'true';
ob1.mysql alter system set server_permanent_offline_time = '20s';
alter tenant mysql locality="FULL{1}@z1, FULL{1}@z2";

# 当前副本情况为: Fz1 Fz4 p = 3，需要等到z2副本补充成功，z4副本删除成功
ob1.check_until_timeout SELECT COUNT(*) FROM oceanbase.CDB_OB_LS_LOCATIONS WHERE tenant_id = 1002 AND ls_id = 1001 AND role = "LEADER" AND member_list LIKE '%$z2_dst0%', 1, 40;
ob1.check_until_timeout SELECT COUNT(*) FROM oceanbase.CDB_OB_LS_LOCATIONS WHERE tenant_id = 1002 AND ls_id = 1001 AND role = "LEADER" AND member_list LIKE '%$z4_dst0%', 0, 40;
# z3机器被kill，该副本需要等到永久下线后才能被rs清理
ob1.check_until_timeout SELECT COUNT(*) FROM oceanbase.CDB_OB_LS_LOCATIONS WHERE tenant_id = 1002 AND ls_id = 1001, 2, 60;
ob1.mysql alter system set server_permanent_offline_time = '2000s';
ob1.mysql ALTER SYSTEM SET enable_rereplication = 'false';

# locality变更完成，开始测试
eval alter system remove replica ls=1001 server='$z2_dst0' paxos_replica_num=1 tenant='mysql';
ob1.check_until_timeout SELECT COUNT(*) FROM oceanbase.CDB_OB_LS_LOCATIONS WHERE tenant_id = 1002 AND ls_id = 1001 AND role = "LEADER" AND member_list LIKE '%$z2_dst0%', 0, 20;
ob1.check_until_timeout SELECT COUNT(*) FROM oceanbase.CDB_OB_LS_LOCATIONS WHERE tenant_id = 1002 AND ls_id = 1001, 1, 30;
ob1.check_until_timeout SELECT COUNT(*) FROM oceanbase.CDB_OB_LS_REPLICA_TASKS WHERE tenant_id = 1002, 0, 20;

ob1.mysql ALTER SYSTEM SET enable_rereplication = 'true';

ob1.check_until_timeout SELECT COUNT(*) FROM oceanbase.CDB_OB_LS_LOCATIONS WHERE tenant_id = 1002 AND ls_id = 1001 AND role = "LEADER" AND member_list LIKE '%$z2_dst0%', 1, 60;
ob1.check_until_timeout SELECT COUNT(*) FROM oceanbase.CDB_OB_LS_LOCATIONS WHERE tenant_id = 1002 AND ls_id = 1001, 2, 30;
ob1.check_until_timeout SELECT COUNT(*) FROM oceanbase.CDB_OB_LS_REPLICA_TASKS WHERE tenant_id = 1002, 0, 20;

ob1.mysql ALTER SYSTEM SET enable_rereplication = 'false';

--echo =================================================
--echo               case 4: 2F1A foce stop a server
--echo =================================================

ob1.z2.obs0.force_stop;
ob1.check_until_timeout select count(*) as cnt from oceanbase.DBA_OB_SERVERS where zone = 'z2' and status = 'INACTIVE', 1, 30;
ob1.check_until_timeout select COUNT(*) from oceanbase.__all_virtual_log_stat where tenant_id = 1002 and DEGRADED_LIST LIKE '%$z2_dst0%', 2, 20;
sleep 5;

# 2F1A, z2 server宕机触发降级，此时remove仅剩的z1的副本应该报错
--error 4179
eval alter system remove replica ls = 1001 server = '$z1_dst0' paxos_replica_num = 1 tenant = 'mysql';

# 2F1A, z2 server宕机触发降级，此时remove该副本应该是允许的
eval alter system remove replica ls = 1001 server = '$z2_dst0' paxos_replica_num = 1 tenant = 'mysql';

ob1.check_until_timeout SELECT COUNT(*) = 0 FROM oceanbase.CDB_OB_LS_LOCATIONS WHERE tenant_id = 1002 AND ls_id = 1001 AND role = "LEADER" AND member_list LIKE '%$z2_dst0%', 1, 20;
sleep 3;
eval select LS_ID, ZONE, ROLE, PAXOS_REPLICA_NUMBER, REPLICA_TYPE from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id = 1002 and ls_id = 1001 order by SVR_PORT;



