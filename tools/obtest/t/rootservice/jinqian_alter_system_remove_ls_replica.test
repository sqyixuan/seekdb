# CASE_OWNER:
#    @jinqian.zzy
# CASE_DESC:
#    This case is aimed to test remove and add ls replica sql command
#    We designed following cases to simulate different scenes:
#
#    CASE 1: basic test
#    CASE 2: remove error case
#    CASE 3: add success case
#    CASE 4: remove success case
#    CASE 5: remove flag r replica
#    CASE 6: remove replica 2F to 1F
#######################################################################
#                        create inital objects
#######################################################################

ob1=OBI(cluster=2:2:2:2:2,proxy_num=0,init_unit_cpu=0);
source include/mini_ob_config.inc;
ob1.set extra_config=$mini_ob_config;
ob1.reboot;

ob1.mysql ALTER SYSTEM SET enable_rereplication = 'false';
ob1.mysql alter system set server_permanent_offline_time = '20s';
ob1.mysql alter system set debug_sync_timeout = '100000s';

let $proxy_ip = deploy_get_value(ob1.z1.obs1.ip);
let $proxy_port = deploy_get_value(ob1.z1.obs1.mysql_port);
connect(sys_conn, $proxy_ip, root@sys,,oceanbase, $proxy_port);

source include/create_unit_config.inc;
ob1.mysql CREATE RESOURCE POOL tenant_pool UNIT = "2c2g", UNIT_NUM = 2, ZONE_LIST = ('z1', 'z2', 'z3', 'z4');
ob1.mysql CREATE TENANT mysql_tenant RESOURCE_POOL_LIST=('tenant_pool'), LOCALITY = "F@z1, F@z2, R@z3, F@z4", PRIMARY_ZONE = "z4" SET ob_tcp_invited_nodes='%';
connect(mysql_tenant, $proxy_ip, root@mysql_tenant,,oceanbase, $proxy_port);

connection sys_conn;
let $tenant_id = deploy_get_value(ob1.select SELECT tenant_id FROM oceanbase.DBA_OB_TENANTS WHERE tenant_name = "mysql_tenant", tenant_id, 1);
let $meta_tenant_id = deploy_get_value(ob1.select SELECT tenant_id - 1 as meta_tenant_id FROM oceanbase.DBA_OB_TENANTS WHERE tenant_name = "mysql_tenant", meta_tenant_id, 1);
let $meta_tenant_name = deploy_get_value(ob1.select SELECT tenant_name FROM oceanbase.DBA_OB_TENANTS WHERE tenant_id = $meta_tenant_id, tenant_name, 1);

ob1.check_until_timeout select count(*) from CDB_OB_LS_LOCATIONS where tenant_id = $tenant_id and ls_id = 1001 and role = 'leader', 1, 10;
ob1.check_until_timeout select count(*) from CDB_OB_LS_LOCATIONS where tenant_id = $tenant_id and ls_id = 1002 and role = 'leader', 1, 10;
ob1.check_until_timeout select count(*) from GV\$OB_LOG_STAT where tenant_id = $tenant_id and ls_id = 1001 and role = 'leader', 1, 10;
ob1.check_until_timeout select count(*) from GV\$OB_LOG_STAT where tenant_id = $tenant_id and ls_id = 1002 and role = 'leader', 1, 10;

# get servers' addr in z1, z2, z3 and z4
let $z1_obs0_ip = deploy_get_value(ob1.z1.obs0.ip);
let $z1_obs0_port = deploy_get_value(ob1.z1.obs0.port);
let $z1_obs0 = $z1_obs0_ip:$z1_obs0_port;

let $z1_obs1_ip = deploy_get_value(ob1.z1.obs1.ip);
let $z1_obs1_port = deploy_get_value(ob1.z1.obs1.port);
let $z1_obs1 = $z1_obs1_ip:$z1_obs1_port;

let $z2_obs0_ip = deploy_get_value(ob1.z2.obs0.ip);
let $z2_obs0_port = deploy_get_value(ob1.z2.obs0.port);
let $z2_obs0 = $z2_obs0_ip:$z2_obs0_port;

let $z2_obs1_ip = deploy_get_value(ob1.z2.obs1.ip);
let $z2_obs1_port = deploy_get_value(ob1.z2.obs1.port);
let $z2_obs1 = $z2_obs1_ip:$z2_obs1_port;

let $z3_obs0_ip = deploy_get_value(ob1.z3.obs0.ip);
let $z3_obs0_port = deploy_get_value(ob1.z3.obs0.port);
let $z3_obs0 = $z3_obs0_ip:$z3_obs0_port;

let $z3_obs1_ip = deploy_get_value(ob1.z3.obs1.ip);
let $z3_obs1_port = deploy_get_value(ob1.z3.obs1.port);
let $z3_obs1 = $z3_obs1_ip:$z3_obs1_port;

let $z4_obs0_ip = deploy_get_value(ob1.z4.obs0.ip);
let $z4_obs0_port = deploy_get_value(ob1.z4.obs0.port);
let $z4_obs0 = $z4_obs0_ip:$z4_obs0_port;

let $z4_obs1_ip = deploy_get_value(ob1.z4.obs1.ip);
let $z4_obs1_port = deploy_get_value(ob1.z4.obs1.port);
let $z4_obs1 = $z4_obs1_ip:$z4_obs1_port;

let $z5_obs0_ip = deploy_get_value(ob1.z5.obs0.ip);
let $z5_obs0_port = deploy_get_value(ob1.z5.obs0.port);
let $z5_obs0 = $z5_obs0_ip:$z5_obs0_port;

let $tenant_ls_id = deploy_get_value(ob1.select SELECT ls_id as ls_id_tmp FROM oceanbase.CDB_OB_LS_LOCATIONS WHERE svr_ip = '$z1_obs0_ip' AND svr_port = $z1_obs0_port AND ls_id > 1, ls_id_tmp, 1);

--disable_query_log
--echo ========================================================================
--echo ||                    [MILESTONE] prepare finished                    ||
--echo ========================================================================

--echo ========================================================================
--echo ||              [MILESTONE] case 1: basic test                   ||
--echo ========================================================================

--echo 1.1 tenant not exist
--error 5157
alter system remove replica ls=100 server='100.88.107.212:5000' paxos_replica_num=3 tenant='mysql_tenant_x';

--echo 1.2 ls not exist
--error 4018
alter system remove replica ls=100 server='100.88.107.212:5000' paxos_replica_num=3 tenant='mysql_tenant';

--echo 1.3 meta tenant can not operate normal tenant ls
--error 4018
eval alter system remove replica ls=$tenant_ls_id server='100.88.107.212:5000' paxos_replica_num=3 tenant='$meta_tenant_name';

--echo ========================================================================
--echo ||        [MILESTONE] case 2: remove error case                       ||
--echo ========================================================================

--echo 2.1 ls not exist
--error 4018
alter system remove replica ls=100 server='100.88.107.212:5000' paxos_replica_num=3 tenant='mysql_tenant';

--echo 2.2 no replica
--error 4018
eval alter system remove replica ls=$tenant_ls_id server='100.88.107.212:5000' paxos_replica_num=3 tenant='mysql_tenant';

--echo 2.3 paxos_replica_num
--echo remove r, provide error paxos_replica_num
--error 1210
eval alter system remove replica ls=$tenant_ls_id server='$z3_obs0' paxos_replica_num=2 tenant='mysql_tenant';
--error 1210
eval alter system remove replica ls=$tenant_ls_id server='$z3_obs0' paxos_replica_num=4 tenant='mysql_tenant';

--echo remove f, provide error paxos_replica_num
--error 1210
eval alter system remove replica ls=$tenant_ls_id server='$z1_obs0' paxos_replica_num=1 tenant='mysql_tenant';
--error 1210
eval alter system remove replica ls=$tenant_ls_id server='$z1_obs0' paxos_replica_num=4 tenant='mysql_tenant';

--echo add f, no provide
--error 1210
eval alter system add replica ls=$tenant_ls_id server='$z1_obs1' replica_type='F' tenant='mysql_tenant';

--echo ========================================================================
--echo ||        [MILESTONE] case 3: add success case                         ||
--echo ========================================================================

--echo 1 2 3 4
--echo F F R F p = 4
--echo F
eval alter system add replica ls=$tenant_ls_id server='$z1_obs1' replica_type='F' paxos_replica_num=4 tenant='mysql_tenant';
ob1.check_until_timeout select PAXOS_REPLICA_NUMBER from __all_virtual_ls_meta_table where role = 1 and ls_id = $tenant_ls_id, 4, 60;
ob1.check_until_timeout SELECT COUNT(*) = 1 FROM oceanbase.CDB_OB_LS_LOCATIONS WHERE tenant_id = $tenant_id AND ls_id = $tenant_ls_id AND role = "LEADER" AND member_list LIKE '%$z1_obs1%', 1, 20;
sleep 3;
eval select LS_ID, ZONE, ROLE, PAXOS_REPLICA_NUMBER, REPLICA_TYPE from __all_virtual_ls_meta_table where ls_id = $tenant_ls_id order by SVR_PORT;
ob1.check_until_timeout select count(*) from __all_virtual_ls_meta_table where ls_id = $tenant_ls_id and SVR_IP = '$z1_obs1_ip' and SVR_PORT = '$z1_obs1_port', 1, 5;

--echo 1 2 3 4
--echo F F R F p = 5
--echo F F
eval alter system add replica ls=$tenant_ls_id server='$z2_obs1' replica_type='F' paxos_replica_num=5 tenant='mysql_tenant';
ob1.check_until_timeout select PAXOS_REPLICA_NUMBER from __all_virtual_ls_meta_table where role = 1 and ls_id = $tenant_ls_id, 5, 60;
ob1.check_until_timeout SELECT COUNT(*) = 1 FROM oceanbase.CDB_OB_LS_LOCATIONS WHERE tenant_id = $tenant_id AND ls_id = $tenant_ls_id AND role = "LEADER" AND member_list LIKE '%$z2_obs1%', 1, 20;
sleep 3;
eval select LS_ID, ZONE, ROLE, PAXOS_REPLICA_NUMBER, REPLICA_TYPE from __all_virtual_ls_meta_table where ls_id = $tenant_ls_id order by SVR_PORT;
ob1.check_until_timeout select count(*) from __all_virtual_ls_meta_table where ls_id = $tenant_ls_id and SVR_IP = '$z2_obs1_ip' and SVR_PORT = '$z2_obs1_port', 1, 5;

--echo 1 2 3 4
--echo F F R F p = 6
--echo F F F
eval alter system add replica ls=$tenant_ls_id server='$z3_obs1' replica_type='F' paxos_replica_num=6 tenant='mysql_tenant';
ob1.check_until_timeout select PAXOS_REPLICA_NUMBER from __all_virtual_ls_meta_table where role = 1 and ls_id = $tenant_ls_id, 6, 60;
ob1.check_until_timeout SELECT COUNT(*) = 1 FROM oceanbase.CDB_OB_LS_LOCATIONS WHERE tenant_id = $tenant_id AND ls_id = $tenant_ls_id AND role = "LEADER" AND member_list LIKE '%$z3_obs1%', 1, 20;
sleep 3;
eval select LS_ID, ZONE, ROLE, PAXOS_REPLICA_NUMBER, REPLICA_TYPE from __all_virtual_ls_meta_table where ls_id = $tenant_ls_id order by SVR_PORT;
ob1.check_until_timeout select count(*) from __all_virtual_ls_meta_table where ls_id = $tenant_ls_id and SVR_IP = '$z3_obs1_ip' and SVR_PORT = '$z3_obs1_port', 1, 5;

--echo 1 2 3 4
--echo F F R F p = 7
--echo F F F F
eval alter system add replica ls=$tenant_ls_id server='$z4_obs1' replica_type='F' paxos_replica_num=7 tenant='mysql_tenant';
ob1.check_until_timeout select PAXOS_REPLICA_NUMBER from __all_virtual_ls_meta_table where role = 1 and ls_id = $tenant_ls_id, 7, 60;
ob1.check_until_timeout SELECT COUNT(*) = 1 FROM oceanbase.CDB_OB_LS_LOCATIONS WHERE tenant_id = $tenant_id AND ls_id = $tenant_ls_id AND role = "LEADER" AND member_list LIKE '%$z4_obs1%', 1, 20;
sleep 3;
eval select LS_ID, ZONE, ROLE, PAXOS_REPLICA_NUMBER, REPLICA_TYPE from __all_virtual_ls_meta_table where ls_id = $tenant_ls_id order by SVR_PORT;
ob1.check_until_timeout select count(*) from __all_virtual_ls_meta_table where ls_id = $tenant_ls_id and SVR_IP = '$z4_obs1_ip' and SVR_PORT = '$z4_obs1_port', 1, 5;

# 打开容灾开关，让容灾将多余副本都删除掉（等到task plan为空，且无用副本都GC掉了）
ob1.mysql ALTER SYSTEM SET enable_rereplication = 'true';
ob1.check_until_timeout select count(*) from oceanbase.V\$OB_LS_REPLICA_TASK_PLAN where ls_id = $tenant_ls_id and tenant_id = $tenant_id, 0, 200;
ob1.check_until_timeout select count(*) from __all_virtual_ls_meta_table where ls_id = $tenant_ls_id and tenant_id = $tenant_id, 4, 100;

sleep 5;
ob1.check_until_timeout select count(*) from oceanbase.V\$OB_LS_REPLICA_TASK_PLAN where ls_id = $tenant_ls_id and tenant_id = $tenant_id, 0, 200;
ob1.check_until_timeout select count(*) from __all_virtual_ls_meta_table where ls_id = $tenant_ls_id and tenant_id = $tenant_id, 4, 100;

--echo F F R F p = 3
eval select LS_ID, ZONE, ROLE, PAXOS_REPLICA_NUMBER, REPLICA_TYPE from __all_virtual_ls_meta_table where ls_id = $tenant_ls_id order by SVR_PORT;

ob1.mysql ALTER SYSTEM SET enable_rereplication = 'false';

ob1.check_until_timeout select count(*) from __all_virtual_ls_meta_table where ls_id = $tenant_ls_id and tenant_id = $tenant_id and SVR_IP = '$z1_obs0_ip' and SVR_PORT = '$z1_obs0_port', 1, 5;
ob1.check_until_timeout select count(*) from __all_virtual_ls_meta_table where ls_id = $tenant_ls_id and tenant_id = $tenant_id and SVR_IP = '$z2_obs0_ip' and SVR_PORT = '$z2_obs0_port', 1, 5;
ob1.check_until_timeout select count(*) from __all_virtual_ls_meta_table where ls_id = $tenant_ls_id and tenant_id = $tenant_id and SVR_IP = '$z3_obs0_ip' and SVR_PORT = '$z3_obs0_port', 1, 5;
ob1.check_until_timeout select count(*) from __all_virtual_ls_meta_table where ls_id = $tenant_ls_id and tenant_id = $tenant_id and SVR_IP = '$z4_obs0_ip' and SVR_PORT = '$z4_obs0_port', 1, 5;
ob1.check_until_timeout select count(*) from __all_virtual_ls_meta_table where ls_id = $tenant_ls_id and tenant_id = $tenant_id and SVR_IP = '$z1_obs1_ip' and SVR_PORT = '$z1_obs1_port', 0, 5;
ob1.check_until_timeout select count(*) from __all_virtual_ls_meta_table where ls_id = $tenant_ls_id and tenant_id = $tenant_id and SVR_IP = '$z2_obs1_ip' and SVR_PORT = '$z2_obs1_port', 0, 5;
ob1.check_until_timeout select count(*) from __all_virtual_ls_meta_table where ls_id = $tenant_ls_id and tenant_id = $tenant_id and SVR_IP = '$z3_obs1_ip' and SVR_PORT = '$z3_obs1_port', 0, 5;
ob1.check_until_timeout select count(*) from __all_virtual_ls_meta_table where ls_id = $tenant_ls_id and tenant_id = $tenant_id and SVR_IP = '$z4_obs1_ip' and SVR_PORT = '$z4_obs1_port', 0, 5;

ob1.mysql alter system set_tp tp_name = ERRSIM_DISASTER_RECOVERY_WORKER_START, error_code = 4016, frequency = 1;

sleep 11;
ob1.z2.obs0.force_stop;
ob1.check_until_timeout select count(*) from __all_server where SVR_IP = '$z2_obs0_ip' and SVR_PORT = '$z2_obs0_port' and STATUS = 'ACTIVE', 0, 60;
sleep 5;
--echo has other member inactive, remove this member result in no leader
--echo 1 2 3 4
--echo F 0 R F p = 3
--error 4179
eval alter system remove replica ls=$tenant_ls_id server='$z1_obs0' paxos_replica_num=2 tenant='mysql_tenant';

# wait permanent offline
sleep 30;
--echo remove permanent offline , paxos_replica_num = 3 not changed!
--echo 1 2 3 4
--echo F x R F p = 3
eval alter system remove replica ls=$tenant_ls_id server='$z2_obs0' tenant='mysql_tenant';
ob1.check_until_timeout select count(*) from __all_virtual_ls_meta_table where ls_id = $tenant_ls_id, 3, 60;
ob1.check_until_timeout SELECT COUNT(*) = 0 FROM oceanbase.CDB_OB_LS_LOCATIONS WHERE tenant_id = $tenant_id AND ls_id = $tenant_ls_id AND role = "LEADER" AND member_list LIKE '%$z2_obs0%', 1, 20;
sleep 3;
eval select LS_ID, ZONE, ROLE, PAXOS_REPLICA_NUMBER, REPLICA_TYPE from __all_virtual_ls_meta_table where ls_id = $tenant_ls_id order by SVR_PORT;
ob1.check_until_timeout select count(*) from __all_virtual_ls_meta_table where ls_id = $tenant_ls_id and SVR_IP = '$z2_obs0_ip' and SVR_PORT = '$z2_obs0_port', 0, 5;

--echo 1 2 3 4
--echo F x R F
--echo x x x F p = 3
eval alter system add replica ls=$tenant_ls_id server='$z4_obs1' replica_type='F' paxos_replica_num=3 tenant='mysql_tenant';
ob1.check_until_timeout select count(*) from __all_virtual_ls_meta_table where role = 1 and ls_id = $tenant_ls_id and member_list like '%$z4_obs1%', 1, 60;
ob1.check_until_timeout SELECT COUNT(*) = 1 FROM oceanbase.CDB_OB_LS_LOCATIONS WHERE tenant_id = $tenant_id AND ls_id = $tenant_ls_id AND role = "LEADER" AND member_list LIKE '%$z4_obs1%', 1, 20;
sleep 3;
eval select LS_ID, ZONE, ROLE, PAXOS_REPLICA_NUMBER, REPLICA_TYPE from __all_virtual_ls_meta_table where ls_id = $tenant_ls_id order by SVR_PORT;
ob1.check_until_timeout select count(*) from __all_virtual_ls_meta_table where ls_id = $tenant_ls_id and SVR_IP = '$z4_obs1_ip' and SVR_PORT = '$z4_obs1_port', 1, 5;

--echo 1 2 3 4
--echo F x R F 
--echo x x F F p = 4
eval alter system add replica ls=$tenant_ls_id server='$z3_obs1' replica_type='F' paxos_replica_num=4 tenant='mysql_tenant';
ob1.check_until_timeout select count(*) from __all_virtual_ls_meta_table where role = 1 and ls_id = $tenant_ls_id and member_list like '%$z3_obs1%', 1, 60;
ob1.check_until_timeout SELECT COUNT(*) = 1 FROM oceanbase.CDB_OB_LS_LOCATIONS WHERE tenant_id = $tenant_id AND ls_id = $tenant_ls_id AND role = "LEADER" AND member_list LIKE '%$z3_obs1%', 1, 20;
sleep 3;
eval select LS_ID, ZONE, ROLE, PAXOS_REPLICA_NUMBER, REPLICA_TYPE from __all_virtual_ls_meta_table where ls_id = $tenant_ls_id order by SVR_PORT;
ob1.check_until_timeout select count(*) from __all_virtual_ls_meta_table where ls_id = $tenant_ls_id and SVR_IP = '$z3_obs1_ip' and SVR_PORT = '$z3_obs1_port', 1, 5;

--echo server status wrong
--disable_result_log
--error 4179
eval alter system add replica ls=$tenant_ls_id server='$z2_obs0' replica_type='F' paxos_replica_num=4 tenant='mysql_tenant';
--enable_result_log

--echo ========================================================================
--echo ||        [MILESTONE] case 4: remove success case                     ||
--echo ========================================================================

--echo 1 2 3 4
--echo F x R F  p = 3
--echo x x x F
eval alter system remove replica ls=$tenant_ls_id server='$z3_obs1' paxos_replica_num=3 tenant='mysql_tenant';
ob1.check_until_timeout select count(*) from __all_virtual_ls_meta_table where ls_id = $tenant_ls_id, 4, 60;
ob1.check_until_timeout SELECT COUNT(*) = 0 FROM oceanbase.CDB_OB_LS_LOCATIONS WHERE tenant_id = $tenant_id AND ls_id = $tenant_ls_id AND role = "LEADER" AND member_list LIKE '%$z3_obs1%', 1, 20;
sleep 3;
eval select LS_ID, ZONE, ROLE, PAXOS_REPLICA_NUMBER, REPLICA_TYPE from __all_virtual_ls_meta_table where ls_id = $tenant_ls_id order by SVR_PORT;
ob1.check_until_timeout select count(*) from __all_virtual_ls_meta_table where ls_id = $tenant_ls_id and SVR_IP = '$z3_obs1_ip' and SVR_PORT = '$z3_obs1_port', 0, 5;

--echo 1 2 3 4
--echo F x x F
--echo x x x F p = 3
eval alter system remove replica ls=$tenant_ls_id server='$z3_obs0' paxos_replica_num=3 tenant='mysql_tenant';
ob1.check_until_timeout select count(*) from __all_virtual_ls_meta_table where ls_id = $tenant_ls_id, 3, 60;
ob1.check_until_timeout SELECT COUNT(*) = 0 FROM oceanbase.CDB_OB_LS_LOCATIONS WHERE tenant_id = $tenant_id AND ls_id = $tenant_ls_id AND role = "LEADER" AND member_list LIKE '%$z3_obs0%', 1, 20;
sleep 3;
eval select LS_ID, ZONE, ROLE, PAXOS_REPLICA_NUMBER, REPLICA_TYPE from __all_virtual_ls_meta_table where ls_id = $tenant_ls_id order by SVR_PORT;
ob1.check_until_timeout select count(*) from __all_virtual_ls_meta_table where ls_id = $tenant_ls_id and SVR_IP = '$z3_obs0_ip' and SVR_PORT = '$z3_obs0_port', 0, 5;

--echo 1 2 3 4
--echo F x x F
--echo x x x x p = 2
eval alter system remove replica ls=$tenant_ls_id server='$z4_obs1' paxos_replica_num=2 tenant='mysql_tenant';
ob1.check_until_timeout select count(*) from __all_virtual_ls_meta_table where ls_id = $tenant_ls_id, 2, 60;
ob1.check_until_timeout SELECT COUNT(*) = 0 FROM oceanbase.CDB_OB_LS_LOCATIONS WHERE tenant_id = $tenant_id AND ls_id = $tenant_ls_id AND role = "LEADER" AND member_list LIKE '%$z4_obs1%', 1, 20;
sleep 3;
eval select LS_ID, ZONE, ROLE, PAXOS_REPLICA_NUMBER, REPLICA_TYPE from __all_virtual_ls_meta_table where ls_id = $tenant_ls_id order by SVR_PORT;
ob1.check_until_timeout select count(*) from __all_virtual_ls_meta_table where ls_id = $tenant_ls_id and SVR_IP = '$z4_obs1_ip' and SVR_PORT = '$z4_obs1_port', 0, 5;

--echo 1 2 3 4
--echo F x F F
--echo x x x x p = 3
eval alter system add replica ls=$tenant_ls_id server='$z3_obs0' replica_type='F' paxos_replica_num=3 tenant='mysql_tenant';
ob1.check_until_timeout select PAXOS_REPLICA_NUMBER from __all_virtual_ls_meta_table where role = 1 and ls_id = $tenant_ls_id, 3, 60;
ob1.check_until_timeout SELECT COUNT(*) = 1 FROM oceanbase.CDB_OB_LS_LOCATIONS WHERE tenant_id = $tenant_id AND ls_id = $tenant_ls_id AND role = "LEADER" AND member_list LIKE '%$z3_obs0%', 1, 20;
sleep 3;
eval select LS_ID, ZONE, ROLE, PAXOS_REPLICA_NUMBER, REPLICA_TYPE from __all_virtual_ls_meta_table where ls_id = $tenant_ls_id order by SVR_PORT;
ob1.check_until_timeout select count(*) from __all_virtual_ls_meta_table where ls_id = $tenant_ls_id and SVR_IP = '$z3_obs0_ip' and SVR_PORT = '$z3_obs0_port', 1, 5;

--echo 1 2 3 4
--echo F x x F
--echo x x x x p = 2
eval alter system remove replica ls=$tenant_ls_id server='$z3_obs0' paxos_replica_num=2 tenant='mysql_tenant';
ob1.check_until_timeout select count(*) from __all_virtual_ls_meta_table where ls_id = $tenant_ls_id, 2, 60;
ob1.check_until_timeout SELECT COUNT(*) = 0 FROM oceanbase.CDB_OB_LS_LOCATIONS WHERE tenant_id = $tenant_id AND ls_id = $tenant_ls_id AND role = "LEADER" AND member_list LIKE '%$z3_obs0%', 1, 20;
eval select LS_ID, ZONE, ROLE, PAXOS_REPLICA_NUMBER, REPLICA_TYPE from __all_virtual_ls_meta_table where ls_id = $tenant_ls_id order by SVR_PORT;
ob1.check_until_timeout select count(*) from __all_virtual_ls_meta_table where ls_id = $tenant_ls_id and SVR_IP = '$z3_obs0_ip' and SVR_PORT = '$z3_obs0_port', 0, 5;
sleep 20;

--echo ========================================================================
--echo ||            [MILESTONE] case 5: remove flag r replica               ||
--echo ========================================================================

ob1.mysql set ob_global_debug_sync = 'AFTER_JOIN_LEARNER_LIST wait_for yyy_debug_sync_point';

eval alter system add replica ls = $tenant_ls_id server = '$z3_obs0' replica_type = 'F' paxos_replica_num = 3 tenant = 'mysql_tenant';
ob1.check_until_timeout SELECT COUNT(*) = 1 FROM oceanbase.CDB_OB_LS_LOCATIONS WHERE tenant_id = $tenant_id AND ls_id = $tenant_ls_id AND role = "LEADER" AND learner_list LIKE '%$z3_obs0%', 1, 60;
select LS_ID, ZONE, ROLE, PAXOS_REPLICA_NUMBER, REPLICA_TYPE from __all_virtual_ls_meta_table where ls_id = 1001 order by SVR_PORT;

# 上面的补副本任务在底层被卡住了，无法执行下面的删除动作，需要一种方式把这个任务从容灾任务列表中删除
ob1.z3.obs0.force_stop;
ob1.check_until_timeout select count(*) from __all_server where SVR_IP = '$z3_obs0_ip' and SVR_PORT = '$z3_obs0_port' and STATUS = 'ACTIVE', 0, 60;
ob1.check_until_timeout select count(*) from __all_virtual_ls_replica_task, 0, 100;

eval alter system remove replica ls=$tenant_ls_id server='$z3_obs0' paxos_replica_num=2 tenant='mysql_tenant';
ob1.check_until_timeout SELECT COUNT(*) FROM oceanbase.CDB_OB_LS_LOCATIONS WHERE tenant_id = $tenant_id AND ls_id = $tenant_ls_id AND role = "LEADER" AND learner_list LIKE '%$z3_obs0%', 0, 20;

--echo ========================================================================
--echo ||            [MILESTONE] case 6: remove replica 2F to 1F             ||
--echo ========================================================================

eval alter system remove replica ls=$tenant_ls_id server='$z1_obs0' paxos_replica_num=1 tenant='mysql_tenant';
ob1.check_until_timeout select count(*) from __all_virtual_ls_meta_table where ls_id = $tenant_ls_id and tenant_id = $tenant_id, 1, 60;
ob1.check_until_timeout SELECT COUNT(*) FROM oceanbase.CDB_OB_LS_LOCATIONS WHERE tenant_id = $tenant_id AND ls_id = $tenant_ls_id AND role = "LEADER" AND member_list LIKE '%$z1_obs0%', 0, 20;
ob1.check_until_timeout select PAXOS_REPLICA_NUMBER from __all_virtual_ls_meta_table where role = 1 and ls_id = $tenant_ls_id and tenant_id = $tenant_id, 1, 20;
