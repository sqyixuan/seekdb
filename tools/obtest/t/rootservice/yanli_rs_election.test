# CASE_OWNER:
#    @msy164651
# CASE_DESC:
#    rs模块的正常启动
#    用例场景：
#    1、rs模块启动前，重启partition所在observer
#    2、rs模块启动后，重启partition所在parttion
#    3、rs模块启动后，切换leader
#    4、rs模块启动后，重启整个集群
#    5、rs模块启动后，stop该模块所在observer

##########
# rs 模块启动前，重启observer
#########
ob1=OBI(cluster=2:2:2,proxy_num=0);
ob1.reboot;

ob1.check_until_timeout SELECT COUNT(*) c FROM DBA_OB_SERVERS WHERE START_SERVICE_TIME > 0, 6, 200;


--disable_query_log
ob_connect(conn_sys, ob1.z1.obs0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);
source sql/check_ddl.sql;

##########
#case1: 重启集群
##########
ob1.force_stop;
ob1.start;
# for rs election
ob1.check_until_timeout select count(*) as cnt from oceanbase.__all_server where start_service_time <= 0, 0 ,180;
source include/check_schema_sync_for_restart.inc;
ob_connect(conn_sys, ob1.z1.obs0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);
connection conn_sys;
source sql/check_ddl.sql;

##########
#case2: 切换leader
###########
ob1.mysql alter tenant sys set primary_zone = 'z1';
let $z1_ip = deploy_get_value(ob1.z1.obs0.ip);
let $z1_port = deploy_get_value(ob1.z1.obs0.port);
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_core_meta_table where tenant_id = 1 and svr_ip = '$z1_ip' and svr_port = '$z1_port' and role = 1, 1, 60;
sleep 20;
let $z2_ip = deploy_get_value(ob1.z2.obs0.ip);
let $z2_port = deploy_get_value(ob1.z2.obs0.port);
--disable_query_log
eval alter system switch replica leader ls=1 server='$z2_ip:$z2_port' tenant='sys';
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_core_meta_table where tenant_id = 1 and svr_ip = '$z2_ip' and svr_port = '$z2_port' and role = 1, 1, 60;
sleep 20;
let $z3_ip = deploy_get_value(ob1.z3.obs0.ip);
let $z3_port = deploy_get_value(ob1.z3.obs0.port);
eval alter system switch replica leader ls=1 server='$z3_ip:$z3_port' tenant='sys';
 --enable_query_log
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_core_meta_table where tenant_id = 1 and svr_ip = '$z3_ip' and svr_port = '$z3_port' and role = 1, 1, 60;
sleep 20;
connection conn_sys;
source sql/check_ddl.sql;

##########
#case4: stop 主rs所在observer
#############
let $leader_ip = deploy_get_value(ob1.select select svr_ip from oceanbase.__all_virtual_core_meta_table where role = 1, svr_ip, 1);
let $leader_port = deploy_get_value(ob1.select select svr_port from oceanbase.__all_virtual_core_meta_table where role = 1, svr_port, 1);
ob1.mysql alter system stop server '$leader_ip:$leader_port';
sleep 5;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_core_meta_table where role = 1,1, 30;
# sleep for election
sleep 20;

connection conn_sys;
source sql/check_ddl.sql;
ob1.mysql alter system start server '$leader_ip:$leader_port';
sleep 5;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_core_meta_table where role = 1,1, 30;
sleep 20;
#检查删除机器
let $leader_ip = deploy_get_value(ob1.select select svr_ip from oceanbase.__all_virtual_core_meta_table where role = 1, svr_ip, 1);
let $leader_port = deploy_get_value(ob1.select select svr_port from oceanbase.__all_virtual_core_meta_table where role = 1, svr_port, 1);
ob1.mysql alter system delete server '$leader_ip:$leader_port';
ob1.check_until_timeout select count(*) from oceanbase.__all_server, 5, 200;
ob1.mysql alter system major freeze;
connection conn_sys;

#租户权限

ob1.mysql CREATE RESOURCE UNIT unit1  max_cpu 2, memory_size '2G';
ob1.mysql CREATE RESOURCE POOL pool1 UNIT = 'unit1', UNIT_NUM = 1;
ob1.mysql CREATE TENANT tt primary_zone='z1', resource_pool_list=('pool1') set ob_tcp_invited_nodes='%';
source include/check_schema_sync.inc;
let $tenant_ip = deploy_get_value(ob1.select select a.svr_ip as ip from oceanbase.DBA_OB_UNITS as a join oceanbase.DBA_OB_TENANTS as b on a.tenant_id = b.tenant_id where b.tenant_name = 'tt' and a.zone = 'z1', ip, 1);
let $tenant_port = deploy_get_value(ob1.select select c.sql_port as port from oceanbase.DBA_OB_UNITS as a join oceanbase.DBA_OB_TENANTS as b on a.tenant_id = b.tenant_id join oceanbase.DBA_OB_SERVERS c on a.svr_ip = c.svr_ip and a.svr_port = c.svr_port where b.tenant_name = 'tt' and a.zone = 'z1', port, 1);
connect(conn_tt, $tenant_ip, root@tt, , oceanbase, $tenant_port);
--error 5099
alter system set enable_rereplicate=true;
--error 1227
CREATE RESOURCE UNIT unit1  max_cpu 2, memory_size '2G';
--error 1227
CREATE RESOURCE POOL pool1 UNIT = 'unit1', UNIT_NUM = 1;
--error 1227
CREATE TENANT tt primary_zone='z1', resource_pool_list=('pool1') set ob_tcp_invited_nodes='%';
#租户下可以合并了
alter system major freeze;
