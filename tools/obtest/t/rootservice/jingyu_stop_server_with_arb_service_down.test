# CASE_OWNER:
#    @jingyu.cr
# CASE_DESC:
#    This case is aimed to test two cases:
#
#    (1) stop zone with arbitration service should wait degration finished before return SUCCESS to client
#    (2) stop server/zone is not allowed if arbitration service is down under 2F1A
#
#    Bug: 

ob1=OBI(cluster=1:1:1:1, proxy_num=0, asvr_num=1);

let $extra_conf = "cpu_count=8,memory_limit='20G',system_memory='5G',__min_full_resource_pool_memory='1073741824',cache_wash_threshold='1G',log_disk_size='20G'";
let $arb_extra_conf = "ob_startup_mode=arbitration,cpu_count=8,memory_limit='20G',system_memory='5G',__min_full_resource_pool_memory='1073741824',cache_wash_threshold='1G',log_disk_size='20G'";
ob1.z1.obs0.set extra_config=$extra_conf;
ob1.z2.obs0.set extra_config=$extra_conf;
ob1.z3.obs0.set extra_config=$extra_conf;
ob1.z4.obs0.set extra_config=$extra_conf;

# bootstrap
ob1.reboot;
sleep 3;

ob1.mysql alter system set debug_sync_timeout = '1000s';
ob1.mysql ALTER SYSTEM SET enable_rebalance = 'false';
ob1.mysql ALTER SYSTEM SET enable_rereplication = 'true';
ob_connect(conn_sys, ob1.z1.obs0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);
# 启动仲裁server
# 获取仲裁server的ip、port
let $arb_svr_ip= deploy_get_value(ob1.asvr0.ip);
let $arb_svr_port= deploy_get_value(ob1.asvr0.port);
# add arbitration service, mytest.jar已经为本集群做了这一步
# check arbitration service add success
--disable_query_log
ob1.check_until_timeout select count(*) from DBA_OB_ARBITRATION_SERVICE where arbitration_service = "$arb_svr_ip:$arb_svr_port", 1, 30;

# get server infos of this cluster
let $z1_dst_ip0 = deploy_get_value(ob1.z1.obs0.ip);
let $z1_dst_port0 = deploy_get_value(ob1.z1.obs0.port);
let $z1_dst0 = $z1_dst_ip0:$z1_dst_port0;

let $z2_dst_ip0 = deploy_get_value(ob1.z2.obs0.ip);
let $z2_dst_port0 = deploy_get_value(ob1.z2.obs0.port);
let $z2_dst0 = $z2_dst_ip0:$z2_dst_port0;

let $z3_dst_ip0 = deploy_get_value(ob1.z3.obs0.ip);
let $z3_dst_port0 = deploy_get_value(ob1.z3.obs0.port);
let $z3_dst0 = $z3_dst_ip0:$z3_dst_port0;

let $z4_dst_ip0 = deploy_get_value(ob1.z4.obs0.ip);
let $z4_dst_port0 = deploy_get_value(ob1.z4.obs0.port);
let $z4_dst0 = $z4_dst_ip0:$z4_dst_port0;

# create mysql tenant(2F1A)
--echo ====================================================
--echo               create tenant with 2F1A
--echo ====================================================
--enable_query_log
ob1.mysql CREATE RESOURCE UNIT unit_1 MAX_CPU 1, MEMORY_SIZE='2G';
ob1.mysql CREATE RESOURCE POOL pool_1 UNIT = 'unit_1', UNIT_NUM = 1, zone_list = ('z1', 'z2', 'z3', 'z4');
ob1.mysql CREATE TENANT mysql RESOURCE_POOL_LIST = ('pool_1'),  locality='F@z1, F@z2', primary_zone='z1;z2', enable_arbitration_service=true set ob_tcp_invited_nodes='%';

let $mysql_tenant_id = deploy_get_value(ob1.select select tenant_id from oceanbase.DBA_OB_TENANTS where tenant_name = 'mysql', tenant_id, 1);
let $meta_tenant_id = deploy_get_value(ob1.select select tenant_id - 1 as meta_tenant_id from oceanbase.DBA_OB_TENANTS where tenant_name = "mysql", meta_tenant_id, 1);
let $ls_cnt = deploy_get_value(ob1.select select count(distinct ls_id) as ls_cnt from oceanbase.CDB_OB_LS where tenant_id = $mysql_tenant_id, ls_cnt, 1);
--disable_query_log
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_log_stat where tenant_id = $mysql_tenant_id and role = 'LEADER' and arbitration_member like "%$arb_svr_ip:$arb_svr_port%", $ls_cnt, 30;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_log_stat where tenant_id = $meta_tenant_id and role = 'LEADER' and arbitration_member like "%$arb_svr_ip:$arb_svr_port%", 1, 30;
--enable_query_log
let $max_ls_id = deploy_get_value(ob1.select select max(ls_id) as max_ls_id from oceanbase.CDB_OB_LS where tenant_id = $mysql_tenant_id, max_ls_id, 1);

--echo ====================================================
--echo                 test stop zone z2
--echo ====================================================
# stop zone z2
ob1.mysql alter system stop zone 'z2';

# check degration finished
let $degraded_ls_cnt = deploy_get_value(ob1.select select count(*) as degraded_ls_cnt from oceanbase.__all_virtual_log_stat where tenant_id=$mysql_tenant_id and role = 'LEADER' and degraded_list like "%$z2_dst0%", degraded_ls_cnt, 1);
let $degraded_meta_ls_cnt = deploy_get_value(ob1.select select count(*) as degraded_meta_ls_cnt from oceanbase.__all_virtual_log_stat where tenant_id=$meta_tenant_id and role = 'LEADER' and degraded_list like "%$z2_dst0%", degraded_meta_ls_cnt, 1);
--echo all ls should finished degration
eval select $degraded_ls_cnt = $ls_cnt as all_ls_finished_degration;
eval select $degraded_meta_ls_cnt = 1 as all_ls_finished_degration;

# start zone
ob1.mysql alter system start zone 'z2';
ob1.mysql alter system start server '$z2_dst0';

# wait upgration finished
ob1.check_until_timeout select count(*) as cnt from oceanbase.__all_virtual_log_stat where tenant_id=$mysql_tenant_id and role = 'LEADER' and degraded_list like "%$z2_dst0%", 0, 60;
ob1.check_until_timeout select count(*) as cnt from oceanbase.__all_virtual_log_stat where tenant_id=$meta_tenant_id and role = 'LEADER' and degraded_list like "%$z2_dst0%", 0, 60;
ob1.check_until_timeout select count(*) as cnt from oceanbase.DBA_OB_SERVERS where stop_time is not null, 0, 60;

--echo ====================================================
--echo     test stop server with arb service down (2F1A)
--echo ====================================================
ob1.asvr0.force_stop;
# ATTENTION!!!
# After kill arb server, KEEPALIVE could know the status of arb_server within 3s.
# This will make KEEPALIVE wrongly return the actual status of arb_server in 3s.
# SO PLEASE DO NOT REMOVE sleep(3) HERE.
sleep 3;
ob1.check_until_timeout select count(*) as cnt from oceanbase.__all_virtual_log_stat where tenant_id = $mysql_tenant_id and role = 'LEADER' and arbitration_member like "%$arb_svr_ip:$arb_svr_port%", $ls_cnt, 10;
ob1.check_until_timeout select count(*) as cnt from oceanbase.__all_virtual_log_stat where tenant_id = $meta_tenant_id and role = 'LEADER' and arbitration_member like "%$arb_svr_ip:$arb_svr_port%", 1, 10;
--echo test stop server(F) with 1A down in 2F1A, expect OB_OP_NOT_ALLOW 4179
--disable_query_log
--error 4179
eval alter system stop server '$z2_dst0';
--enable_query_log

--echo ====================================================
--echo      test stop zone with arb service down (2F1A)
--echo ====================================================
ob1.check_until_timeout select count(*) as cnt from oceanbase.__all_virtual_log_stat where tenant_id = $mysql_tenant_id and role = 'LEADER' and arbitration_member like "%$arb_svr_ip:$arb_svr_port%", $ls_cnt, 10;
ob1.check_until_timeout select count(*) as cnt from oceanbase.__all_virtual_log_stat where tenant_id = $meta_tenant_id and role = 'LEADER' and arbitration_member like "%$arb_svr_ip:$arb_svr_port%", 1, 10;
--echo test stop zone(F) with 1A down in 2F1A, expect OB_OP_NOT_ALLOW 4179
--error 4179
alter system stop zone 'z2';

--echo ====================================================
--echo       alter tenant mysql from 2F1A to 4F1A
--echo ====================================================
ob1.mysql alter tenant mysql locality = "F@z1, F@z2, F@z3, F@z4";
ob1.check_until_timeout SELECT COUNT(*) AS cnt FROM oceanbase.CDB_OB_LS_LOCATIONS WHERE tenant_id = $mysql_tenant_id AND role = "LEADER" AND member_list LIKE "%$z3_dst0%" AND member_list LIKE "%$z4_dst0%", $ls_cnt, 200;
ob1.check_until_timeout SELECT COUNT(*) AS cnt FROM oceanbase.CDB_OB_LS_LOCATIONS WHERE tenant_id = $meta_tenant_id AND role = "LEADER" AND member_list LIKE "%$z3_dst0%" AND member_list LIKE "%$z4_dst0%", 1, 200;
ob1.check_until_timeout SELECT COUNT(*) AS cnt FROM oceanbase.DBA_OB_TENANTS WHERE tenant_id = $mysql_tenant_id AND previous_locality is null AND locality like "%FULL{1}@z1, FULL{1}@z2, FULL{1}@z3, FULL{1}@z4%", 1 ,30;

--echo ====================================================
--echo           test stop server with 1F1A down
--echo ====================================================
--echo shut down server in zone3
ob1.mysql alter tenant sys set primary_zone = "z1;z2;z3";
ob1.check_until_timeout select count(*) c from oceanbase.CDB_OB_LS_LOCATIONS where role like "%LEADER%" and tenant_id = 1 and zone = 'z3', 0, 60;
ob1.z3.obs0.force_stop;
ob1.check_until_timeout select count(*) as cnt from oceanbase.DBA_OB_SERVERS where STATUS != "ACTIVE" and zone = "z3", 1, 60;
--echo test stop server(F) with 1F1A down in 4F1A, expect OB_OP_NOT_ALLOW 4179
--disable_query_log
--error 4179
eval alter system stop server '$z2_dst0';
--enable_query_log


--echo ====================================================
--echo            test stop zone with 1F1A down
--echo ====================================================
--echo test stop server(F) with 1F1A down in 4F1A, expect OB_OP_NOT_ALLOW 4179
--error 4179
alter system stop zone 'z2';
