# CASE_OWNER:
#    @cangming.zl
# CASE_DESC:
#     本case是为了验证unit迁移的时候，如果发生目的机器宕机，那么RS会重新选择目的端，重新开始调度；
#     A---> B; B宕机，RS会等B上的副本全部删成员后，重新开始调度A-->C；
#    (1) 永久下线，等踢成员后，重新调度；
#    (2) 临时下线，不会换目的端；
#    (3) block的话，需要将迁移的副本全部删掉后，重新开始迁移；

ob1=OBI(cluster=1:1:3,proxy_num=0);
ob1.z3.obs1.set status=disable;
ob1.z3.obs2.set status=disable;
ob1.reboot;

sleep 3;

ob1.z3.obs1.set status=enable;
ob1.z3.obs2.set status=enable;
ob1.z3.obs1.start;
ob1.z3.obs2.start;

ob1.z3.obs1.check_log_until_success -c "weak read service thread start";
ob1.z3.obs2.check_log_until_success -c "weak read service thread start";
ob1.z3.obs1.add;
ob1.z3.obs2.add;

ob1.check_until_timeout SELECT COUNT(*) c FROM DBA_OB_SERVERS WHERE START_SERVICE_TIME > 0, 5, 200;

ob1.source include/migrate.inc;
ob1.mysql alter system set server_permanent_offline_time ='20s';
##新建表；
ob1.mysql create table oceanbase.test(c1 int primary key, c2 int) partition by hash(c1) partitions 30;
ob1.mysql create table oceanbase.test2(c1 int primary key, c2 int) partition by hash(c1) partitions 30;
ob1.mysql create table oceanbase.test3(c1 int primary key, c2 int) partition by hash(c1) partitions 30;

##迁移unit_id= 3的unit;

let $src_ip = deploy_get_value(ob1.select select svr_ip  from __all_unit where unit_id = 3, svr_ip, 1);
let $src_port = deploy_get_value(ob1.select select svr_port  from __all_unit where unit_id = 3, svr_port, 1);

##默认系统表的unit都在obs0上面；
let $dest_ip = deploy_get_value(ob1.z3.obs1.ip);
let $dest_port = deploy_get_value(ob1.z3.obs1.port);

ob1.mysql alter system migrate unit 3 destination '$dest_ip:$dest_port';
###等待目的端已经迁移成功副本副本；
ob1.check_until_timeout select count(*) from __all_virtual_core_meta_table where svr_ip='$dest_ip' and svr_port=$dest_port, 1, 180;

ob1.z3.obs1.force_stop;
##等待RS会清除当前迁移信息；
##ob1.check_until_timeout select count(*)  from __all_unit where migrate_from_svr_ip != '', 0, 30;
let $count = 30;
while ($count > 0)
{
##如果当前还没有踢成员，则表明不会换迁移的目的端；
let $count = deploy_get_value(ob1.select select count(*) c from __all_virtual_core_meta_table where svr_ip='$dest_ip' and svr_port=$dest_port, c, 1);
if ($count > 0)
{
  let $migrate = deploy_get_value(ob1.select select count(*) c from __all_unit where unit_id = 3 and svr_ip = '$dest_ip' and svr_port = $dest_port, c, 1);
  if ($migrate != 1)
  {
    echo "fail";
  }
}
  dec $count;
  sleep 1;
}


ob1.check_until_timeout  select count(*) from __all_unit where svr_ip = '$src_ip' and svr_port = $src_port and unit_id=3, 1, 180;

