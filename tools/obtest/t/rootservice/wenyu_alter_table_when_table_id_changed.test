# CASE_OWNER:
#    @wenyu.ffz
# CASE_DESC:
#    校验alter table 发送到rs的过程中table_name对应table_id发生改变后可以正常执行

ob1=OBI(cluster=1:1,proxy_num=0);
source include/mini_ob_config.inc;
ob1.set extra_config=$mini_ob_config;
ob1.reboot;

ob_connect(conn_sys, ob1.z1.obs0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);
eval CREATE RESOURCE UNIT unit_1 MAX_CPU 2, MEMORY_SIZE '4G';
eval CREATE RESOURCE POOL pool_1 UNIT = 'unit_1', UNIT_NUM = 1;
eval CREATE TENANT oracle RESOURCE_POOL_LIST = ('pool_1'), primary_zone='z1' set ob_tcp_invited_nodes='%', ob_compatibility_mode='oracle';

alter system set debug_sync_timeout = '1000s';
sleep 2;
set ob_global_debug_sync = 'BEFORE_SEND_ALTER_TABLE wait_for signal execute 1';
alter system set _parallel_ddl_control = 'set_comment:off' tenant oracle;
ob_connect(conn_oracle, ob1.z1.obs0, SYS@oracle, ,SYS, , USE_OB_CONNECTOR);
create table t1 (col1 int);
send comment on table t1 is 'TC';
ob_connect(conn_oracle1, ob1.z1.obs0, SYS@oracle, ,SYS, , USE_OB_CONNECTOR);
sleep 1;
drop table t1;
create table t1 (col1 int);
connection conn_sys;
set ob_global_debug_sync = 'now signal signal';
connection conn_oracle;
reap;
select comments from DBA_TAB_COMMENTS where table_name = 'T1';
