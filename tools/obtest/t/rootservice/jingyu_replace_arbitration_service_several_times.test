# CASE_OWNER:
#    @jingyu.cr
# CASE_DESC:
#    This case is aimed to test replace arbitration service serveral times
#
#    1. create tenant with arbitration service arbs0
#    2. errsim remove_cluster_info
#    3. replace arbs0 with arbs1
#    4. errsim add_cluster_info
#    5. replace arbs1 with arbs0, this could fail
#    6. close errsim
#    7. replace arbs1 with arbs0, this should fail
#


#######################################################################
#                        create inital objects
#######################################################################

ob1=OBI(cluster=1:1,proxy_num=0,init_unit_cpu=0,asvr_num=2);
source include/mini_ob_config.inc;
ob1.set extra_config=$mini_ob_config;
ob1.reboot;
sleep 3;

let $arb_extra_conf = "ob_startup_mode=arbitration,cpu_count=1,memory_limit=1G,__easy_memory_limit=256M";
ob1.asvr1.set status=enable;
ob1.asvr1.reboot;

ob1.mysql alter system set debug_sync_timeout = '1000s';
ob1.mysql ALTER SYSTEM SET enable_rebalance = 'false';
ob1.mysql ALTER SYSTEM SET enable_rereplication = 'true';

let $proxy_ip = deploy_get_value(ob1.z1.obs0.ip);
let $proxy_port = deploy_get_value(ob1.z1.obs0.mysql_port);
connect(sys_conn, $proxy_ip, root@sys,,oceanbase, $proxy_port);

# 获取仲裁server的ip、port
let $arb_svr_ip= deploy_get_value(ob1.asvr0.ip);
let $arb_svr_port= deploy_get_value(ob1.asvr0.port);
let $arb_svr_ip_2= deploy_get_value(ob1.asvr1.ip);
let $arb_svr_port_2= deploy_get_value(ob1.asvr1.port);
# add arbitration service, mytest.jar已经为本集群做了这一步
ob1.check_until_timeout select count(*) as cnt from oceanbase.DBA_OB_ARBITRATION_SERVICE where arbitration_service = "$arb_svr_ip:$arb_svr_port", 1, 5;

--echo =================================================
--echo               create tenant
--echo =================================================

# create new tenant mysql
source include/create_unit_config.inc;
ob1.mysql CREATE RESOURCE POOL tenant_pool UNIT = "2c2g", UNIT_NUM = 1, ZONE_LIST = ('z1', 'z2');
ob1.mysql CREATE TENANT mysql RESOURCE_POOL_LIST=('tenant_pool'), LOCALITY = "F@z1, F@z2", PRIMARY_ZONE = "z1", enable_arbitration_service = true SET ob_tcp_invited_nodes='%';

let $tenant_id = deploy_get_value(ob1.select SELECT tenant_id FROM oceanbase.DBA_OB_TENANTS WHERE tenant_name = "mysql", tenant_id, 1);
let $meta_tenant_id = deploy_get_value(ob1.select select tenant_id - 1 as meta_tenant_id from oceanbase.DBA_OB_TENANTS where tenant_name = "mysql", meta_tenant_id, 1);
let $resource_pool_id = deploy_get_value(ob1.select SELECT resource_pool_id FROM oceanbase.__all_resource_pool WHERE tenant_id = $tenant_id, resource_pool_id, 1);

# get servers' addr in z1, z2 and z3
let $z1_dst_ip0 = deploy_get_value(ob1.z1.obs0.ip);
let $z1_dst_port0 = deploy_get_value(ob1.z1.obs0.port);
let $z1_dst0 = $z1_dst_ip0:$z1_dst_port0;
let $z2_dst_ip0 = deploy_get_value(ob1.z2.obs0.ip);
let $z2_dst_port0 = deploy_get_value(ob1.z2.obs0.port);
let $z2_dst0 = $z2_dst_ip0:$z2_dst_port0;

--echo ==================================================
--echo             replace asvr0 with asvr1
--echo ==================================================
ob1.mysql alter system set_tp tp_name = ERRSIM_REMOVE_CLUSTER_INFO_ERROR, error_code = 4016, frequency = 1;
--disable_query_log
ob1.mysql alter system replace arbitration service "$arb_svr_ip:$arb_svr_port" with "$arb_svr_ip_2:$arb_svr_port_2";
ob1.mysql alter system set_tp tp_name = ERRSIM_REMOVE_CLUSTER_INFO_ERROR, error_code = 4016, frequency = 0;

--echo ==================================================
--echo       errsim and replace asvr1 with asvr0
--echo ==================================================
ob1.mysql alter system set_tp tp_name = ERRSIM_ADD_CLUSTER_INFO_ERROR, error_code = 4016, frequency = 1;
--disable_query_log
# this operation should not clean replaces on asrv0
--error 4016
eval alter system replace arbitration service "$arb_svr_ip_2:$arb_svr_port_2" with "$arb_svr_ip:$arb_svr_port";
ob1.mysql alter system set_tp tp_name = ERRSIM_ADD_CLUSTER_INFO_ERROR, error_code = 4016, frequency = 0;

--echo ==================================================
--echo              replace asvr1 with asvr0
--echo ==================================================
# this operation could fail because garbage replica remains on asrv0
--error 4748
eval alter system replace arbitration service "$arb_svr_ip_2:$arb_svr_port_2" with "$arb_svr_ip:$arb_svr_port";
