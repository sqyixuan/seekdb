let $zone_list='z3';
let $locality=F@z3;
let $primary_zone=z3;
let $tenant_type=oracle;
let $executor=ob1.z3.obs0;
source t/rootservice/yiping_create_tenant_speed.inc;

ob_connect(conn_sys1, ob1.z1.obs0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);
connection conn_sys1;
let $cost=TIMESTAMPDIFF(MICROSECOND, start_time, greatest(ls_normal, ls_election, tenant_normal))/1000000;
# eval select tenant_id, locality, primary_zone, tenant_type, executor, $cost cost from $table_name;
let $bootstrap_start = deploy_get_value(ob1.select select time from sys_external_tbs.__all_external_alert_log_info where module = 'bootstrap' and event='OB_BOOTSTRAP_PREPARE_BEGIN', time, 1);
let $bootstrap_success = deploy_get_value(ob1.select select time from sys_external_tbs.__all_external_alert_log_info where event='OB_BOOTSTRAP_SUCCESS', time, 1);
# eval select TIMESTAMPDIFF(MICROSECOND, '$bootstrap_start', '$bootstrap_success') cost;
--disable_query_log
eval select count(*) where TIMESTAMPDIFF(MICROSECOND, '$bootstrap_start', '$bootstrap_success')/1000000 < 20;
--enable_query_log
let $low_speed_count=deploy_get_value(ob1.select select count(*) a from $table_name where $cost>15, a, 1);
if ($low_speed_count != 0)
{
ob1.mysql_p select * from oceanbase.__all_server;
ob1.mysql_p select *, $cost cost from $table_name;
ob1.mysql_p select *, $cost cost from $table_name where $cost>15;
}
