ob1=OBI(cluster=1:1:1,proxy_num=0);
ob1.reboot;

let $ip = deploy_get_value(ob1.z1.obs0.ip);
let $port = deploy_get_value(ob1.z1.obs0.port);

ob1.mysql alter tenant sys set primary_zone='z1';
ob1.check_until_timeout select role from oceanbase.__all_ls_meta_table where tenant_id=1 and ls_id=1 and zone='z1', 1, 40;
ob1.check_until_timeout select count(*)>0 from oceanbase.__all_rootservice_event_history where event='full_rootservice' and value1=0 and value2 like '%$ip:$port%' order by 1 desc, 1, 10;

ob1.check_until_timeout select count(*) from oceanbase.__all_rootservice_job where job_status='INPROGRESS', 0, 60;

let $table_name=test.create_tenant_speed;

ob1.mysql create table $table_name(tenant_id int, locality varchar(128), primary_zone varchar(128), tenant_type varchar(128), executor varchar(128), start_time timestamp(6), ls_normal timestamp(6), ls_election timestamp(6), tenant_normal timestamp(6));

ob1.mysql create resource unit box max_cpu 1, memory_size='3G';

##############################################################
#                         mysql
##############################################################

let $zone_list='z1','z2','z3';
let $locality=F@z1,F@z2,F@z3;
let $primary_zone=z1;
let $tenant_type=mysql;
let $executor=ob1.z1.obs0;
source t/rootservice/yiping_create_tenant_speed.inc;

let $zone_list='z1','z2','z3';
let $locality=F@z1,F@z2,F@z3;
let $primary_zone=z2;
let $tenant_type=mysql;
