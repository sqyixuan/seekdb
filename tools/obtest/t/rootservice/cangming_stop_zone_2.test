# CASE_OWNER:
#    @cangming.zl
# CASE_DESC:
#    本case是为了测试stop zone的问题；

ob1=OBI(cluster=1:1:1:1,  proxy_num=0, ct_num = 0, locality=HZ:SH:SH:HZ);
ob1.reboot;
#ob1.mysql create table oceanbase.test(c1 int, c2 int);
ob1.mysql alter system set balancer_idle_time = '10s';

let $case_index = 1;


ob1.mysql CREATE RESOURCE UNIT unit_$case_index MAX_CPU 2, MEMORY_SIZE '2G';
ob1.mysql CREATE RESOURCE POOL pool_$case_index UNIT = 'unit_$case_index', UNIT_NUM = 1, ZONE_LIST = ('z1', 'z2','z4');
ob1.mysql CREATE TENANT tenant_$case_index RESOURCE_POOL_LIST = ('pool_$case_index'), locality='F@z1,F@z2,F@z4', primary_zone='z4;z2;z1' set ob_tcp_invited_nodes='%';
ob_connect(tt1_conn, ob1.z1.obs0, root@tenant_1, , test, , USE_MYSQL_CONNECTOR);
connection tt1_conn;
create table tt(c1 int primary key, c2 int) partition by hash(c1) partitions 100;
create table tt2(c1 int primary key, c2 int) partition by hash(c1) partitions 100;


#case 1: stop z3, stop z2; 
#case 2: stop z3, stop z2.obs0 
#case 3: stop z3, stop z1 
#case 4: stop z3.obs0, stop z2.obs0
#case 5: stop z3.obs0, stop z2; 
#case 6: stop z3.obs0, stop z3.obs1
let $z2_obs_ip  = deploy_get_value(ob1.z4.obs0.ip);
let $z2_obs_mysql_port = deploy_get_value(ob1.z4.obs0.mysql_port);
connect (conn_z2_sys,$z2_obs_ip,admin@sys,admin,oceanbase,$z2_obs_mysql_port);
connection conn_z2_sys;
#case 1: stop z1, stop z2; 
set ob_query_timeout = 30000000;
alter system stop zone 'z4';
--error 4660 
alter system stop zone 'z2';
#case 2: stop z3, stop z2.obs0 
let $ip = deploy_get_value(ob1.z2.obs0.ip);
let $port = deploy_get_value(ob1.z2.obs0.port);
--disable_query_log
--error 4660 
eval alter system stop server '$ip:$port';
--enable_query_log
#case 3: stop z3, stop z3 
alter system stop zone 'z4';

##恢复；
alter system start zone 'z4';
sleep 5;
#case 4: stop z2.obs0, stop z3.obs0
--disable_query_log
eval alter system stop server '$ip:$port';
--enable_query_log
sleep 2;
let $ip2 = deploy_get_value(ob1.z3.obs0.ip);
let $port2 = deploy_get_value(ob1.z3.obs0.port);
--disable_query_log
--error 4660 
eval alter system stop server '$ip2:$port2';
--enable_query_log
#case 5: stop z2.obs0, stop z1; 
--error 4660
alter system stop zone 'z1';
#alter system start zone 'z1';
#case 6: stop z2.obs0, stop z3.obs1
--disable_query_log
--error 4660 
eval alter system stop server '$ip2:$port2';
--enable_query_log
##恢复；
--disable_query_log
eval alter system start server '$ip:$port';
--enable_query_log
sleep 5;
###PART2: 目标：检查剩余的副本满足majority;
#case 1: stop z2, z2.obs0处于lease expire
ob1.z2.obs0.force_stop;
sleep 9;
--error 4179
alter system stop zone 'z4';
#case 2: stop z1, z2.obs0处于start_service_time = 0;
ob1.z2.obs0.start;
sleep 1;
--error 4179
alter system stop zone 'z3';
ob1.check_until_timeout select count(*) c from oceanbase.__all_server where start_service_time = 0, 0, 60;
#case 3：stop z2, meta租户有副本处于only_in_member_list
#由于stop server不在参考meta表，所以删meta表并不会影响stop
ob1.mysql delete from oceanbase.__all_ls_meta_table where zone = 'z2';
alter system stop zone 'z4';
alter system start zone 'z4';

#alter system report replica;
#ob1.mysql alter tenant sys set locality='F@z1,F@z4,f@z2'
