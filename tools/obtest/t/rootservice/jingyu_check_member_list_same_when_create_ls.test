# CASE_OWNER:
#    @jingyu.cr
# CASE_DESC:
#    This case is aimed to test check member_lsit_and_learner_list_same problem
#    We designed following cases to simulate different scenes:
#
#######################################################################
#                        create inital objects
#######################################################################

ob1=OBI(cluster=2:2,proxy_num=0,init_unit_cpu=0);
source include/mini_ob_config.inc;
ob1.set extra_config=$mini_ob_config;
ob1.reboot;

ob1.mysql alter system set debug_sync_timeout = '1000s';
ob1.mysql ALTER SYSTEM SET enable_rebalance = 'false';
ob1.mysql ALTER SYSTEM SET enable_rereplication = 'true';

let $proxy_ip = deploy_get_value(ob1.z1.obs0.ip);
let $proxy_port = deploy_get_value(ob1.z1.obs0.mysql_port);
connect(sys_conn, $proxy_ip, root@sys,,oceanbase, $proxy_port);
let $proxy_ip2 = deploy_get_value(ob1.z2.obs0.ip);
let $proxy_port2 = deploy_get_value(ob1.z2.obs0.mysql_port);
connect(sys_conn2, $proxy_ip2, root@sys,,oceanbase, $proxy_port2);

let $z1_ip1 = deploy_get_value(ob1.z1.obs0.ip);
let $z1_port1 = deploy_get_value(ob1.z1.obs0.port);
let $z1_dst1 = $z1_ip1:$z1_port1;
let $z1_ip2 = deploy_get_value(ob1.z1.obs1.ip);
let $z1_port2 = deploy_get_value(ob1.z1.obs1.port);
let $z1_dst2 = $z1_ip2:$z1_port2;

let $z2_ip1 = deploy_get_value(ob1.z2.obs0.ip);
let $z2_port1 = deploy_get_value(ob1.z2.obs0.port);
let $z2_dst1 = $z2_ip1:$z2_port1;
let $z2_ip2 = deploy_get_value(ob1.z2.obs1.ip);
let $z2_port2 = deploy_get_value(ob1.z2.obs1.port);
let $z2_dst2 = $z2_ip2:$z2_port2;

--echo =================================================================================
--echo                               errsim at some point
--echo =================================================================================
connection sys_conn;
ob1.mysql alter tenant sys set primary_zone = "z1";
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_core_meta_table where role = 1 and zone = 'z1', 1, 100;
let $rs_dst0=deploy_get_value(ob1.select select concat(svr_ip,':',svr_port) as host from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id = 1 and ls_id =  1 and role = "LEADER" limit 1, host, 1);
ob1.mysql alter system set_tp tp_name = ERRSIM_CHECK_MEMBER_LIST_SAME_ERROR, error_code = 4002, frequency = 1;

--echo =================================================================================
--echo                             create mysql tenant
--echo =================================================================================
connection sys_conn2;
# create new tenant mysql
source include/create_unit_config.inc;
ob1.mysql CREATE RESOURCE POOL tenant_pool UNIT = "2c2g", UNIT_NUM = 1, ZONE_LIST = ('z1', 'z2');
send CREATE TENANT mysql RESOURCE_POOL_LIST=('tenant_pool'), LOCALITY = "F@z1, F@z2", PRIMARY_ZONE = "z1;z2" SET ob_tcp_invited_nodes='%';

--echo =================================================================================
--echo                           check log and release errsim
--echo =================================================================================
connection sys_conn;
ob1.check_until_timeout select count(*) as cnt from oceanbase.DBA_OB_TENANTS where tenant_name = "mysql", 1, 30;
let $tenant_id = deploy_get_value(ob1.select SELECT tenant_id FROM oceanbase.DBA_OB_TENANTS WHERE tenant_name = "mysql", tenant_id, 1);
let $meta_tenant_id = deploy_get_value(ob1.select select tenant_id - 1 as meta_tenant_id from oceanbase.DBA_OB_TENANTS where tenant_name = "mysql", meta_tenant_id, 1);
ob1.z2.obs0.check_log_until_success "fail to check member list and learner list all reported";
ob1.mysql alter system set_tp tp_name = ERRSIM_CHECK_MEMBER_LIST_SAME_ERROR, error_code = 4002, frequency = 0;

--echo =================================================================================
--echo                               check ls count
--echo =================================================================================
connection sys_conn2;
reap;
# mysql tenant should have LS-1 and LS-1001 due to unit_num = 1 and primary_zone = z1
ob1.check_until_timeout select count(*) as cnt from oceanbase.CDB_OB_LS where tenant_id = $tenant_id and status = "NORMAL", 2, 120;

--echo =================================================================================
--echo                               errsim at some point
--echo =================================================================================
connection sys_conn;
ob1.mysql alter system set_tp tp_name = ERRSIM_CHECK_MEMBER_LIST_SAME_ERROR, error_code = 4002, frequency = 1;

--echo =================================================================================
--echo              expand unit_num from 1 to 2 to create new log stream
--echo =================================================================================
connection sys_conn;
alter resource tenant mysql unit_num = 2;
# balance job could not success, because new log stream will not created successfully
ob1.check_until_timeout select count(*) as cnt from oceanbase.CDB_OB_BALANCE_JOBS where tenant_id = $tenant_id and status like "%DOING%", 1, 30;

--echo =================================================================================
--echo        wait a while and check again, make sure log stream remains creating
--echo =================================================================================
sleep 10;
ob1.check_until_timeout select count(*) as cnt from oceanbase.CDB_OB_LS where tenant_id = $tenant_id and status = "NORMAL", 2, 60;

--echo =================================================================================
--echo                let check_member_list_and_learner_list_smae continue
--echo =================================================================================
ob1.mysql alter system set_tp tp_name = ERRSIM_CHECK_MEMBER_LIST_SAME_ERROR, error_code = 4002, frequency = 0;
ob1.check_until_timeout select count(*) as cnt from oceanbase.CDB_OB_LS where tenant_id = $tenant_id and status = "NORMAL", 3, 60;

