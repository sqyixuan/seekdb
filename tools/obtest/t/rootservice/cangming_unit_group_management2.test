# CASE_OWNER:
#    @cangming.zl
# CASE_DESC:
#    unit group management associated

ob1=OBI(cluster=3:3:3,proxy_num=0,init_unit_cpu=0);

ob1.reboot;

ob1.mysql alter system set enable_rebalance = 'false';
ob1.mysql alter system set balancer_idle_time = '10s';

ob1.mysql create resource unit test_unit max_cpu = 1, memory_size = '2G';
ob1.mysql create resource pool pool0 unit = 'test_unit', unit_num = 3, zone_list = ('z1', 'z2', 'z3');
ob1.mysql create tenant tt resource_pool_list=('pool0'), primary_zone = 'z1', locality = 'F@z1,F@z2,F@z3' set ob_tcp_invited_nodes='%';
sleep 5;

let $proxy_ip = deploy_get_value(ob1.z1.obs0.ip);
let $proxy_port = deploy_get_value(ob1.z1.obs0.mysql_port);

connect(sys_conn, $proxy_ip, root@sys,,test, $proxy_port);
connect(tt_conn, $proxy_ip, root@tt,,test, $proxy_port);

connection tt_conn;
use test;
create table wenduo(pk int primary key) partition by hash (pk) partitions 10;

connection sys_conn;
## before split
select unit_id, unit_group_id, resource_pool_id, status, zone from oceanbase.__all_unit where unit_group_id != 1 order by unit_group_id, unit_id;
alter resource pool pool0 split into ('pool1', 'pool2', 'pool3') on ('z1', 'z2', 'z3');
## after split
select unit_id, unit_group_id, resource_pool_id, status, zone from oceanbase.__all_unit where unit_group_id != 1 order by unit_group_id, unit_id;

# case 1:
## alter unit num to 2
alter resource tenant tt unit_num = 2;
## rollback alter unit num
alter resource tenant tt unit_num = 3;

# case 2
## alter unit num to 1
alter resource tenant tt unit_num = 1;
## rollback alter unit num
alter resource tenant tt unit_num = 3;

# case 3
## alter unit num to 1 but delete unit group num not match
--error 4179
alter resource tenant tt unit_num = 1 delete unit_group (1002);
## alter unit num to 2 but delete unit group num not match
--error 4179
alter resource tenant tt unit_num = 2 delete unit_group (1002, 1003);

# case 4
## alter unit num to 1 and delete unit group num match
alter resource tenant tt unit_num = 1 delete unit_group (1002, 1003);
select unit_id, unit_group_id, resource_pool_id, status, zone from oceanbase.__all_unit where unit_group_id != 1 order by unit_group_id, unit_id;
## rollback alter unit num
alter resource tenant tt unit_num = 3;
select unit_id, unit_group_id, resource_pool_id, status, zone from oceanbase.__all_unit where unit_group_id != 1 order by unit_group_id, unit_id;

# case 5
## alter unit num to 2 and delete unit group num match
alter resource tenant tt unit_num = 2 delete unit_group (1003);
select unit_id, unit_group_id, resource_pool_id, status, zone from oceanbase.__all_unit where unit_group_id != 1 order by unit_group_id, unit_id;
## rollback alter unit num
alter resource tenant tt unit_num = 3;
select unit_id, unit_group_id, resource_pool_id, status, zone from oceanbase.__all_unit where unit_group_id != 1 order by unit_group_id, unit_id;

# case 6
## alter unit num to 2 and but delete unit group id not match
--error 4179
alter resource tenant tt unit_num = 2 delete unit_group (1);
select unit_id, unit_group_id, resource_pool_id, status, zone from oceanbase.__all_unit where unit_group_id != 1 order by unit_group_id, unit_id;
