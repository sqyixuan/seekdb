# case 2: truncate table with global index
# fix bug: 

# 构造建表带全局索引的场景，此时全局索引有partition（索引缺省是local，主表是分区表的场合，全局索引不为local storage，有partition）
create table table_with_global_index(c1 int primary key, c2 int, index global_index(c2) global) partition by hash(c1) partitions 2;

let $orig_table_id = deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where table_name = "table_with_global_index", table_id, 1);
let $orig_index_id = deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where data_table_id = $orig_table_id, table_id, 1);

ob1.check_until_timeout select count(*) from oceanbase.cdb_ob_table_locations where table_id = $orig_table_id, 6, 5;
ob1.check_until_timeout select count(*) from oceanbase.cdb_ob_table_locations where table_id = $orig_index_id, 3, 5;

# 触发truncate
truncate table table_with_global_index;

let $new_table_id = deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where table_name = "table_with_global_index", table_id, 1);
let $new_index_id = deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where data_table_id = $new_table_id, table_id, 1);

ob1.check_until_timeout select count(*) from oceanbase.cdb_ob_table_locations where table_id = $new_table_id, 6, 5;
ob1.check_until_timeout select count(*) from oceanbase.cdb_ob_table_locations where table_id = $new_index_id, 3, 5;
ob1.mysql_p select table_id, table_name, table_type, index_type from oceanbase.__all_virtual_table where table_id in ("$new_table_id", "$new_index_id") order by table_id asc;
