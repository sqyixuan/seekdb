# CASE_OWNER:
#    @cangming.zl
# CASE_DESC:
#

ob1=OBI(cluster=1:1:1,proxy_num=0,init_unit_cpu=0,node_cpu_count=64,memory_size_limit='25G');

ob1.reboot;

ob_connect(sys_conn, ob1.z1.obs0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);
connection sys_conn;
alter system set enable_rereplication=false;
alter system set balancer_idle_time='30s';
sleep 5;
create resource unit test_unit max_cpu = 1, memory_size = '2G';
create resource pool pool1 unit_num=1, zone_list=('z1','z2','z3'), unit='test_unit';
create resource pool pool2 unit_num=1, zone_list=('z1','z2','z3'), unit='test_unit';
create resource pool pool3 unit_num=1, zone_list=('z1','z2','z3'), unit='test_unit';

sleep 5;

let $svr_ip1 = deploy_get_value(ob1.z1.obs0.ip);
let $svr_port1 = deploy_get_value(ob1.z1.obs0.port);

let $svr_ip2 = deploy_get_value(ob1.z2.obs0.ip);
let $svr_port2 = deploy_get_value(ob1.z2.obs0.port);

let $svr_ip3 = deploy_get_value(ob1.z3.obs0.ip);
let $svr_port3 = deploy_get_value(ob1.z3.obs0.port);

set @@session.ob_query_timeout=30000000;
create tenant wenduo1 primary_zone = 'z1', resource_pool_list = ('pool1');
create tenant wenduo2 primary_zone = 'z2', resource_pool_list = ('pool2');
create tenant wenduo3 primary_zone = 'z3', resource_pool_list = ('pool3');
ob1.check_until_timeout select count(*) from __all_virtual_ls_meta_table, 30,100;

set @@session.ob_query_timeout=120000000;
--disable_query_log
eval alter system stop server '$svr_ip3:$svr_port3';
ob1.check_until_timeout select count(*) from oceanbase.__all_server where zone = 'z3' and (stop_time > 0),1,60;
eval alter system start server '$svr_ip3:$svr_port3';

eval alter system stop server '$svr_ip2:$svr_port2';
ob1.check_until_timeout select count(*) from oceanbase.__all_server where zone = 'z2' and (stop_time > 0),1,60;
eval alter system start server '$svr_ip2:$svr_port2';

eval alter system stop server '$svr_ip1:$svr_port1';
ob1.check_until_timeout select count(*) from oceanbase.__all_server where zone = 'z1' and (stop_time > 0),1,60;
eval alter system start server '$svr_ip1:$svr_port1';
--enable_query_log