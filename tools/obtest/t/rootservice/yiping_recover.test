# CASE_OWNER:
#    @shouju.zyp
# CASE_DESC:
#    The Basic recover testcase

ob1=OBI(cluster=1, proxy_num=0);

source include/mini_ob_config.inc;
ob1.z1.obs0.set extra_config = "cpu_count=16,memory_limit='30G',system_memory='7G',__min_full_resource_pool_memory='1073741824',cache_wash_threshold='1G',_ob_minor_merge_schedule_interval='3s'";

let $backup_cluster_name = deploy_get_value(ob1.get_cluster_name);
let $backup_cluster_id = deploy_get_value(ob1.get_cluster_id);
let $backup_ip       = deploy_get_value(ob1.z1.obs0.ip);
let $backup_port     = deploy_get_value(ob1.z1.obs0.mysql_port);
let $restore_ip         = deploy_get_value(ob1.z1.obs0.ip);
let $restore_port       = deploy_get_value(ob1.z1.obs0.mysql_port);
let $backup_dest = deploy_get_value(ob1.get_backup_dest);
let $backup_mysql_tenant   = backup_mysql_tenant;
let $backup_mysql_tenant    = backup_mysql_tenant;
let $restore_mysql_tenant = restore_mysql_tenant;
let $restore_mysql_tenant_new = restore_mysql_tenant_new;
let $restore_mysql_tenant = restore_mysql_tenant;
let $log_backup_dest = deploy_get_value(ob1.get_log_backup_dest $backup_mysql_tenant);
let $data_backup_dest = deploy_get_value(ob1.get_data_backup_dest $backup_mysql_tenant);
let $restore_log_archive_dest = deploy_get_value(ob1.get_log_backup_dest $restore_mysql_tenant);

# 必须先stop掉老的，删除才能有效，不然可能会有残留。
ob1.force_stop;
ob1.clean_backup_dest;
ob1.reboot;

# 固定sys租户规格
ob1.mysql alter resource unit sys_unit_config memory_size='2G';

connect(backup_sys_conn, $backup_ip, root@sys,,oceanbase, $backup_port);
connection backup_sys_conn;
use oceanbase;
source sql/physical_backup/prepare_single_zone_mini_resource.sql;

ob1.mysql alter system set _backup_idle_time = '10s';
ob1.mysql alter system set merger_check_interval = '10s';
ob1.mysql alter system set enable_async_syslog=false;

# create mysql tenant, test create tenant before major freeze
ob1.mysql CREATE TENANT $backup_mysql_tenant RESOURCE_POOL_LIST = ('small_pool'), primary_zone = "z1" set ob_tcp_invited_nodes='%', ob_compatibility_mode='mysql';
let $backup_mysql_tenant_id = query_get_value(select tenant_id from oceanbase.__all_tenant where tenant_name='$backup_mysql_tenant', tenant_id, 1);

#mysql租户  创建tablet
ob_connect(sys_conn_mysql, ob1.z1.obs0, root@$backup_mysql_tenant, ,oceanbase, , USE_MYSQL_CONNECTOR);
connection sys_conn_mysql;
set global wait_timeout = 288000;

--disable_all_result_log
eval alter system set data_backup_dest='$data_backup_dest';
eval alter system set log_archive_dest='location=$log_backup_dest piece_switch_interval=1d';
--enable_all_result_log
ob_connect(backup_mysql_conn, ob1.z1.obs0,root@$backup_mysql_tenant,,test,,USE_MYSQL_CONNECTOR);
connection backup_mysql_conn;

create table t1(a int, b int, c int);
insert into t1(a, b) values(1, 1);
connect(backup_sys_conn, $backup_ip, root@sys,,oceanbase, $backup_port);
connection backup_sys_conn;
let $__archive_lag_target__ = 2s;
let $__tenant_name__ = $backup_mysql_tenant;
source include/set_archive_lag_target.inc;

#mysql租户  开启日志备份
ob1.mysql alter system archivelog;
ob1.check_until_timeout select status from oceanbase.CDB_OB_ARCHIVELOG where tenant_id=$backup_mysql_tenant_id, DOING, 600;

ob1.mysql alter system major freeze tenant = '$backup_mysql_tenant';
sleep 10;
ob1.check_until_timeout select (frozen_scn - last_scn) as result from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id=$backup_mysql_tenant_id, 0, 600;

#mysql租户  开启数据备份
ob1.mysql alter system backup database;
ob1.check_until_timeout select count(*) c from __all_backup_job_history where tenant_id = 1, 1, 600;
ob1.check_until_timeout select result from oceanbase.CDB_OB_BACKUP_JOB_HISTORY where tenant_id = $backup_mysql_tenant_id, 0, 10;
ob1.check_until_timeout select result from oceanbase.CDB_OB_BACKUP_TASK_HISTORY where tenant_id = $backup_mysql_tenant_id, 0, 10;

sleep 20;
connection backup_sys_conn;

use oceanbase;
let $restore_path = $log_backup_dest,$data_backup_dest;
let $ls_id1 = deploy_get_value(ob1.select select ls_id from oceanbase.__all_virtual_ls where tenant_id = $backup_mysql_tenant_id and ls_id != 1, ls_id, 1);
ob1.mysql alter tenant $backup_mysql_tenant set primary_zone = 'z1';
ob1.check_until_timeout select count(*)>=1 from oceanbase.__all_virtual_ls_status where status = 'NORMAL' and tenant_id = $backup_mysql_tenant_id, 1, 100;
let $ls_id2 = deploy_get_value(ob1.select select max(ls_id) as ls_id from oceanbase.__all_virtual_ls where tenant_id = $backup_mysql_tenant_id, ls_id, 1);
let $create_scn1 = deploy_get_value(ob1.select select create_scn from oceanbase.__all_virtual_ls where tenant_id = $backup_mysql_tenant_id and ls_id = $ls_id1, create_scn, 1);
let $create_scn2 = deploy_get_value(ob1.select select create_scn from oceanbase.__all_virtual_ls where tenant_id = $backup_mysql_tenant_id and ls_id =  $ls_id2, create_scn, 1);
sleep 3;
let $restore_checkpoint1 = `select ceil(min_restore_scn / 1000) as min_restore_scn from CDB_OB_BACKUP_SET_FILES where tenant_id = $backup_mysql_tenant_id`;
let $restore_checkpoint2 = `select ceil(UNIX_TIMESTAMP(current_timestamp(6)) * 1000000)`;
ob1.check_until_timeout select floor(checkpoint_scn / 1000) > '$restore_checkpoint1' from CDB_OB_ARCHIVELOG, 1, 600;
ob1.check_until_timeout select floor(checkpoint_scn / 1000) > '$restore_checkpoint2' from CDB_OB_ARCHIVELOG, 1, 600;
let $restore_checkpoint = $restore_checkpoint2;
let $restore_checkpoint = `select usec_to_time(floor(checkpoint_scn/1000)) from CDB_OB_ARCHIVELOG`;

#mysql租户  开启数据恢复
--disable_all_result_log
ob1.mysql alter system restore $restore_mysql_tenant from '$restore_path' until time='$restore_checkpoint' with 'pool_list=small_pool_2&primary_zone=z1';
--enable_all_result_log
ob1.check_until_timeout SELECT status FROM __all_tenant WHERE tenant_id = 1003, NORMAL, 200;
ob1.check_until_timeout select count(*) from __all_virtual_ls_meta_table where tenant_id = 1004 and restore_status = 0, 2, 1200;
ob1.check_until_timeout select status FROM __all_tenant WHERE tenant_id = 1004, NORMAL, 200;
ob1.check_until_timeout select count(*) FROM __all_restore_job, 0, 200;

let $restore_mysql_tenant_id = query_get_value(select tenant_id from oceanbase.__all_tenant where tenant_name='$restore_mysql_tenant', tenant_id, 1);

ob_connect(sys_conn, ob1.z1.obs0, root, , oceanbase, , USE_MYSQL_CONNECTOR);
connection sys_conn;
alter system change tenant tenant_id = 1003;
select tenant_role from __all_tenant_info where tenant_id = 1004;
#STANDBY

#测试 RECOVER UNTIL TIME by SYS tenant
ob_connect(backup_mysql_conn, ob1.z1.obs0,root@$backup_mysql_tenant,,test,,USE_MYSQL_CONNECTOR);
connection backup_mysql_conn;
UPDATE t1 SET b = 2 WHERE a = 1;
sleep 3;
connect(backup_sys_conn, $backup_ip, root@sys,,oceanbase, $backup_port);
connection backup_sys_conn;
let $recover_checkpoint_time = `select current_timestamp(6);`;
let $recover_checkpoint_scn = `select max(end_scn) from __all_virtual_log_stat where tenant_id=1002`;
ob_connect(backup_mysql_conn, ob1.z1.obs0,root@$backup_mysql_tenant,,test,,USE_MYSQL_CONNECTOR);
connection backup_mysql_conn;
UPDATE t1 SET b = 3 WHERE a = 1;
ob_connect(sys_conn, ob1.z1.obs0, root, , oceanbase, , USE_MYSQL_CONNECTOR);
connection sys_conn;
--disable_all_result_log
eval ALTER SYSTEM RECOVER STANDBY TENANT $restore_mysql_tenant UNTIL TIME = '$recover_checkpoint_time';
--enable_all_result_log
# TODO clog支持restore完成后继续拉日志后打开此测试
# ob1.check_until_timeout select count(*) from __all_virtual_tenant_info where tenant_id = 1004 and sync_scn = $recover_checkpoint_scn, 1, 100;
ob_connect(restore_mysql_conn, ob1.z1.obs0, root@$restore_mysql_tenant, ,TEST, , USE_MYSQL_CONNECTOR);
connection restore_mysql_conn;
select * from t1;
#1	2	NULL

#测试 RECOVER UNTIL SCN by SYS tenant
connect(backup_sys_conn, $backup_ip, root@sys,,oceanbase, $backup_port);
connection backup_sys_conn;
let $recover_checkpoint_scn = `select max(end_scn) from __all_virtual_log_stat where tenant_id=1002`;
ob_connect(sys_conn, ob1.z1.obs0, root, , oceanbase, , USE_MYSQL_CONNECTOR);
connection sys_conn;
--disable_all_result_log
eval ALTER SYSTEM RECOVER STANDBY TENANT $restore_mysql_tenant UNTIL SCN = $recover_checkpoint_scn;
--enable_all_result_log
# TODO clog支持restore完成后继续拉日志后打开此测试
# ob1.check_until_timeout select count(*) from __all_virtual_tenant_info where tenant_id = 1004 and sync_scn = $recover_checkpoint_scn, 1, 100;
ob_connect(restore_mysql_conn, ob1.z1.obs0, root@$restore_mysql_tenant, ,TEST, , USE_MYSQL_CONNECTOR);
connection restore_mysql_conn;
select * from t1;
#1	3	NULL

# 命令测试  -- 系统租户操作普通租户
ob_connect(sys_conn, ob1.z1.obs0, root, , oceanbase, , USE_MYSQL_CONNECTOR);
connection sys_conn;

let $recovery_until_scn = deploy_get_value(ob1.select select sync_scn - 1 as recovery_until_scn from oceanbase.__all_virtual_tenant_info where tenant_id=1004, recovery_until_scn, 1);
--disable_all_result_log
--error 4179
eval ALTER SYSTEM RECOVER STANDBY TENANT $restore_mysql_tenant UNTIL SCN = $recovery_until_scn;
--enable_all_result_log

let $recovery_until_scn = deploy_get_value(ob1.select select sync_scn as recovery_until_scn from __all_virtual_ls_recovery_stat where tenant_id=1004 and ls_id = 1, recovery_until_scn, 1);
--disable_all_result_log
eval ALTER SYSTEM RECOVER STANDBY TENANT $restore_mysql_tenant UNTIL SCN = $recovery_until_scn;
--enable_all_result_log
ob1.check_until_timeout select count(*) from __all_virtual_tenant_info where tenant_id = 1004 and recovery_until_scn = $recovery_until_scn, 1, 5;

let $recovery_until_scn = deploy_get_value(ob1.select select sync_scn + 1 as recovery_until_scn from __all_virtual_ls_recovery_stat where tenant_id=1004 and ls_id = 1, recovery_until_scn, 1);
--disable_all_result_log
eval ALTER SYSTEM RECOVER STANDBY TENANT $restore_mysql_tenant UNTIL SCN = $recovery_until_scn;
--enable_all_result_log
ob1.check_until_timeout select count(*) from __all_virtual_tenant_info where tenant_id = 1004 and recovery_until_scn = $recovery_until_scn, 1, 5;

eval ALTER SYSTEM RECOVER STANDBY TENANT $restore_mysql_tenant UNTIL SCN = 4611686018427387903;
ob1.check_until_timeout select count(*) from __all_virtual_tenant_info where tenant_id = 1004 and recovery_until_scn = 4611686018427387903, 1, 5;
--error 1210
eval ALTER SYSTEM RECOVER STANDBY TENANT $restore_mysql_tenant UNTIL SCN = 0;
eval ALTER SYSTEM RECOVER STANDBY TENANT $restore_mysql_tenant CANCEL;
ob1.check_until_timeout select count(*) from __all_virtual_tenant_info where tenant_id = 1004 and recovery_until_scn = sync_scn, 1, 5;

let $cur_recovery_until_scn = deploy_get_value(ob1.select select recovery_until_scn from oceanbase.__all_virtual_tenant_info where tenant_id=1004, recovery_until_scn, 1);
ob1.mysql alter system set debug_sync_timeout = '100000s';
ob1.mysql set ob_global_debug_sync = 'BEFORE_UPDATE_RECOVERY_UNTIL_SCN wait_for continue_signal execute 10000';
send ALTER SYSTEM RECOVER STANDBY TENANT $restore_mysql_tenant UNTIL UNLIMITED;
sleep 12;
ob1.mysql set ob_global_debug_sync = 'now signal continue_signal execute 10000';
ob1.mysql set ob_global_debug_sync = 'reset';
sleep 2;
ob1.check_until_timeout select count(*) from __all_virtual_tenant_info where tenant_id = 1004 and recovery_until_scn = $cur_recovery_until_scn, 1, 5;
ob1.check_until_timeout select count(*) from __all_virtual_log_restore_source where tenant_id = 1004 and recovery_until_scn = $cur_recovery_until_scn, 1, 5;
ob1.check_until_timeout select count(*) from __all_virtual_tenant_info where tenant_id = 1004 and recovery_until_scn != 4611686018427387903, 1, 5;
ob1.check_until_timeout select count(*) from __all_virtual_log_restore_source where tenant_id = 1004 and recovery_until_scn != 4611686018427387903, 1, 5;

eval ALTER SYSTEM RECOVER STANDBY TENANT $restore_mysql_tenant UNTIL UNLIMITED;
ob1.check_until_timeout select count(*) from __all_virtual_tenant_info where tenant_id = 1004 and recovery_until_scn = 4611686018427387903, 1, 5;

--disable_all_result_log
--error 1210
eval ALTER SYSTEM RECOVER STANDBY UNTIL SCN = $recovery_until_scn;
--enable_all_result_log

# 命令测试  -- mysql租户
ob_connect(restore_mysql_conn, ob1.z1.obs0, root@$restore_mysql_tenant, ,TEST, , USE_MYSQL_CONNECTOR);
connection restore_mysql_conn;

let $recover_checkpoint_time = `select current_timestamp(6);`;
--disable_all_result_log
--error 1210
eval ALTER SYSTEM RECOVER STANDBY TENANT $restore_mysql_tenant UNTIL TIME = '$recover_checkpoint_time';
eval ALTER SYSTEM RECOVER STANDBY UNTIL TIME = '$recover_checkpoint_time';
--enable_all_result_log

let $recovery_until_scn = deploy_get_value(ob1.select select sync_scn - 1 as recovery_until_scn from oceanbase.__all_virtual_tenant_info where tenant_id=1004, recovery_until_scn, 1);
--disable_all_result_log
--error 4179
eval ALTER SYSTEM RECOVER STANDBY UNTIL SCN = $recovery_until_scn;
--enable_all_result_log

let $recovery_until_scn = deploy_get_value(ob1.select select sync_scn as recovery_until_scn from __all_virtual_ls_recovery_stat where tenant_id=1004 and ls_id = 1, recovery_until_scn, 1);
--disable_all_result_log
eval ALTER SYSTEM RECOVER STANDBY UNTIL SCN = $recovery_until_scn;
--enable_all_result_log
ob1.check_until_timeout select count(*) from __all_virtual_tenant_info where tenant_id = 1004 and recovery_until_scn = $recovery_until_scn, 1, 5;

let $recovery_until_scn = deploy_get_value(ob1.select select sync_scn + 1 as recovery_until_scn from __all_virtual_ls_recovery_stat where tenant_id=1004 and ls_id = 1, recovery_until_scn, 1);
--disable_all_result_log
eval ALTER SYSTEM RECOVER STANDBY UNTIL SCN = $recovery_until_scn;
--enable_all_result_log
ob1.check_until_timeout select count(*) from __all_virtual_tenant_info where tenant_id = 1004 and recovery_until_scn = $recovery_until_scn, 1, 5;

eval ALTER SYSTEM RECOVER STANDBY UNTIL SCN = 4611686018427387903;

--error 1210
eval ALTER SYSTEM RECOVER STANDBY UNTIL SCN = 0;

eval ALTER SYSTEM RECOVER STANDBY UNTIL UNLIMITED;
ob1.check_until_timeout select count(*) from __all_virtual_tenant_info where tenant_id = 1004 and recovery_until_scn = 4611686018427387903, 1, 5;

ob1.mysql set ob_global_debug_sync = 'STOP_LS_RECOVERY_THREAD wait_for continue_signal execute 10000';
ob1.check_until_timeout SELECT count(*) FROM __all_virtual_tenant_info l LEFT JOIN __all_virtual_ls_recovery_stat r ON l.tenant_id=r.tenant_id where r.ls_id = 1 and r.sync_scn - l.sync_scn > 1 and l.tenant_id = 1004, 1, 10;

eval ALTER SYSTEM RECOVER STANDBY CANCEL;
# 检查recover cancel位点小于系统LS的回放位点
ob1.check_until_timeout SELECT count(*) FROM __all_virtual_tenant_info l LEFT JOIN __all_virtual_ls_recovery_stat r ON l.tenant_id=r.tenant_id where r.ls_id = 1 and r.sync_scn - l.sync_scn > 1 and l.tenant_id = 1004, 1, 5;
ob1.check_until_timeout select count(*) from __all_virtual_tenant_info where tenant_id = 1004 and recovery_until_scn = sync_scn, 1, 5;
ob1.mysql set ob_global_debug_sync = 'now signal continue_signal execute 10000';
ob1.mysql set ob_global_debug_sync = 'reset';


# create oracle tenant
ob1.mysql CREATE TENANT backup_oracle_tenant RESOURCE_POOL_LIST = ('small_pool_0'), primary_zone = "z1" set ob_tcp_invited_nodes='%', ob_compatibility_mode='oracle';
let $backup_oracle_tenant_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name='backup_oracle_tenant', tenant_id, 1);

#oracle租户  创建tablet
ob_connect(sys_conn_oracle, ob1.z1.obs0, sys@backup_oracle_tenant, ,SYS, , USE_OB_CONNECTOR);
connection sys_conn_oracle;
set global wait_timeout = 288000;

let $oracle_log_backup_dest = deploy_get_value(ob1.get_log_backup_dest backup_oracle_tenant);
let $oracle_data_backup_dest = deploy_get_value(ob1.get_data_backup_dest backup_oracle_tenant);
--disable_all_result_log
eval alter system set data_backup_dest='$oracle_data_backup_dest';
eval alter system set log_archive_dest='location=$oracle_log_backup_dest piece_switch_interval=1d';
--enable_all_result_log
create user test IDENTIFIED BY "test";
grant all on *.* to test WITH GRANT OPTION;
grant dba to test;

connection backup_sys_conn;
let $__archive_lag_target__ = 2s;
let $__tenant_name__ = backup_oracle_tenant;
source include/set_archive_lag_target.inc;

ob_connect(backup_oracle_conn, ob1.z1.obs0, TEST@backup_oracle_tenant, test,test, , USE_OB_CONNECTOR);
connection backup_oracle_conn;

create table t1(a int, b int, c int);
insert into t1(a, b) values(11, 11);

#oracle租户  开启日志备份
ob1.mysql alter system archivelog;
ob1.check_until_timeout select status from oceanbase.CDB_OB_ARCHIVELOG where tenant_id=$backup_oracle_tenant_id, DOING, 600;

ob1.mysql alter system major freeze tenant = 'backup_oracle_tenant';
sleep 10;
ob1.check_until_timeout select (frozen_scn - last_scn) as result from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id=$backup_oracle_tenant_id, 0, 600;

#oracle租户  开启数据备份
ob1.mysql alter system backup database;
ob1.check_until_timeout select count(*) c from __all_backup_job_history where tenant_id = 1, 1, 600;
ob1.check_until_timeout select result from oceanbase.CDB_OB_BACKUP_JOB_HISTORY where tenant_id = $backup_oracle_tenant_id, 0, 600;
ob1.check_until_timeout select result from oceanbase.CDB_OB_BACKUP_TASK_HISTORY where tenant_id = $backup_oracle_tenant_id, 0, 10;

sleep 20;
connect(backup_sys_conn, $backup_ip, root@sys,,oceanbase, $backup_port);
connection backup_sys_conn;
use oceanbase;
let $oracle_restore_path = $oracle_log_backup_dest,$oracle_data_backup_dest;
let $ls_id1 = deploy_get_value(ob1.select select ls_id from oceanbase.__all_virtual_ls where tenant_id = $backup_oracle_tenant_id and ls_id != 1, ls_id, 1);
ob1.mysql alter tenant backup_oracle_tenant set primary_zone = 'z1';
ob1.check_until_timeout select count(*)>=1 from oceanbase.__all_virtual_ls_status where status = 'NORMAL' and tenant_id = $backup_oracle_tenant_id, 1, 100;
let $ls_id2 = deploy_get_value(ob1.select select max(ls_id) as ls_id from oceanbase.__all_virtual_ls where tenant_id = $backup_oracle_tenant_id, ls_id, 1);
let $create_scn1 = deploy_get_value(ob1.select select create_scn from oceanbase.__all_virtual_ls where tenant_id = $backup_oracle_tenant_id and ls_id = $ls_id1, create_scn, 1);
let $create_scn2 = deploy_get_value(ob1.select select create_scn from oceanbase.__all_virtual_ls where tenant_id = $backup_oracle_tenant_id and ls_id =  $ls_id2, create_scn, 1);
sleep 3;
let $restore_checkpoint1 = `select ceil(min_restore_scn / 1000) as min_restore_scn from CDB_OB_BACKUP_SET_FILES where tenant_id = $backup_oracle_tenant_id`;
let $restore_checkpoint2 = `select ceil(UNIX_TIMESTAMP(current_timestamp(6)) * 1000000)`;
ob1.check_until_timeout select floor(checkpoint_scn / 1000) > '$restore_checkpoint1' from CDB_OB_ARCHIVELOG where $backup_oracle_tenant_id = tenant_id, 1, 600;
ob1.check_until_timeout select floor(checkpoint_scn / 1000) > '$restore_checkpoint2' from CDB_OB_ARCHIVELOG where $backup_oracle_tenant_id = tenant_id, 1, 600;
let $restore_checkpoint = $restore_checkpoint2;
let $restore_checkpoint = `select usec_to_time(floor(checkpoint_scn/1000)) from CDB_OB_ARCHIVELOG where tenant_id = $backup_oracle_tenant_id`;
sleep 5;
#oracle租户  开启数据恢复
let $restore_oracle_tenant = restore_oracle_tenant;
ob1.mysql alter system restore $restore_oracle_tenant from '$oracle_restore_path' until time='$restore_checkpoint' with 'pool_list=small_pool_1&primary_zone=z1';
ob1.check_until_timeout SELECT status FROM __all_tenant WHERE tenant_id = 1007, NORMAL, 200;
ob1.check_until_timeout select count(*) from __all_virtual_ls_meta_table where tenant_id = 1008 and restore_status = 0, 2, 1200;
ob1.check_until_timeout select status FROM __all_tenant WHERE tenant_id = 1008, NORMAL, 200;
ob1.check_until_timeout select count(*) FROM __all_restore_job, 0, 200;

let $restore_oracle_tenant_id = query_get_value(select tenant_id from oceanbase.__all_tenant where tenant_name='$restore_oracle_tenant', tenant_id, 1);

ob_connect(sys_conn, ob1.z1.obs0, root, , oceanbase, , USE_OB_CONNECTOR);
connection sys_conn;
alter system change tenant tenant_id = 1007;
select tenant_role from __all_tenant_info where tenant_id = 1008;
#STANDBY
# 命令测试  -- oracle租户
let $recover_checkpoint_time = `select current_timestamp(6);`;
ob_connect(restore_oracle_conn, ob1.z1.obs0, SYS@$restore_oracle_tenant, ,TEST, , USE_OB_CONNECTOR);
connection restore_oracle_conn;

ob1.mysql set ob_global_debug_sync = 'STOP_LS_RECOVERY_THREAD wait_for continue_signal execute 10000';

--disable_all_result_log
--error 600
eval ALTER SYSTEM RECOVER STANDBY TENANT $restore_oracle_tenant UNTIL TIME = '$recover_checkpoint_time';
eval ALTER SYSTEM RECOVER STANDBY UNTIL TIME = '$recover_checkpoint_time';
--enable_all_result_log

ob1.check_until_timeout SELECT count(*) FROM __all_virtual_tenant_info l LEFT JOIN __all_virtual_ls_recovery_stat r ON l.tenant_id=r.tenant_id where r.ls_id = 1 and r.sync_scn - l.sync_scn > 1 and l.tenant_id = 1008, 1, 30;
let $recovery_until_scn = deploy_get_value(ob1.select select sync_scn - 1 as recovery_until_scn from oceanbase.__all_virtual_tenant_info where tenant_id=1008, recovery_until_scn, 1);
--disable_all_result_log
--error 600
eval ALTER SYSTEM RECOVER STANDBY UNTIL SCN = $recovery_until_scn;
--enable_all_result_log

let $recovery_until_scn = deploy_get_value(ob1.select select sync_scn as recovery_until_scn from __all_virtual_ls_recovery_stat where tenant_id=1008 and ls_id = 1, recovery_until_scn, 1);
--disable_all_result_log
eval ALTER SYSTEM RECOVER STANDBY UNTIL SCN = $recovery_until_scn;
--enable_all_result_log
ob1.check_until_timeout select count(*) from __all_virtual_tenant_info where tenant_id = 1008 and recovery_until_scn = $recovery_until_scn, 1, 5;

let $recovery_until_scn = deploy_get_value(ob1.select select sync_scn + 1 as recovery_until_scn from oceanbase.__all_virtual_tenant_info where tenant_id=1008, recovery_until_scn, 1);
--disable_all_result_log
eval ALTER SYSTEM RECOVER STANDBY UNTIL SCN = $recovery_until_scn;
--enable_all_result_log
ob1.check_until_timeout select count(*) from __all_virtual_tenant_info where tenant_id = 1008 and recovery_until_scn = $recovery_until_scn, 1, 5;
ob1.mysql set ob_global_debug_sync = 'now signal continue_signal execute 10000';
ob1.mysql set ob_global_debug_sync = 'reset';

eval ALTER SYSTEM RECOVER STANDBY UNTIL SCN = 4611686018427387903;

--error 600
eval ALTER SYSTEM RECOVER STANDBY UNTIL SCN = 0;

eval ALTER SYSTEM RECOVER STANDBY CANCEL;
ob1.check_until_timeout select count(*) from __all_virtual_tenant_info where tenant_id = 1008 and recovery_until_scn = sync_scn, 1, 5;

eval ALTER SYSTEM RECOVER STANDBY UNTIL UNLIMITED;
ob1.check_until_timeout select count(*) from __all_virtual_tenant_info where tenant_id = 1008 and recovery_until_scn = 4611686018427387903, 1, 5;

connection backup_sys_conn;
ob1.mysql ALTER SYSTEM RECOVER STANDBY TENANT $restore_oracle_tenant CANCEL;
sleep 1;
ob1.mysql ALTER SYSTEM RECOVER STANDBY TENANT $restore_oracle_tenant UNTIL UNLIMITED;
sleep 1;
ob1.mysql ALTER SYSTEM RECOVER STANDBY TENANT $restore_oracle_tenant CANCEL;
sleep 1;
ob1.mysql ALTER SYSTEM RECOVER STANDBY TENANT $restore_oracle_tenant UNTIL UNLIMITED;
sleep 1;
ob1.mysql ALTER SYSTEM RECOVER STANDBY TENANT $restore_oracle_tenant CANCEL;
sleep 1;
ob1.mysql ALTER SYSTEM RECOVER STANDBY TENANT $restore_oracle_tenant UNTIL UNLIMITED;
sleep 1;
ob1.mysql ALTER SYSTEM RECOVER STANDBY TENANT $restore_oracle_tenant CANCEL;
sleep 1;
ob1.mysql ALTER SYSTEM RECOVER STANDBY TENANT $restore_oracle_tenant UNTIL UNLIMITED;

let $current_timestamp = `select ceil(UNIX_TIMESTAMP(current_timestamp(6)))`;
ob1.check_until_timeout select count(*) from __all_virtual_tenant_info where tenant_id = 1008 and (sync_scn / 1000000) > $current_timestamp, 1, 60;
