# CASE_OWNER:
#    @msy164651
# CASE_DESC:
#    测试resource_pool拆分后增加机器

ob1=OBI(cluster=1:1:1, proxy_num=0, node_cpu_count=64, node_cpu_reserved=2);
ob1.z3.obs0.set status=disable;
ob1.reboot;

let $proxy_ip = deploy_get_value(ob1.z1.obs0.ip);
let $proxy_port = deploy_get_value(ob1.z1.obs0.mysql_port);
connect(sys_conn, $proxy_ip, root@sys,,oceanbase, $proxy_port);

connection sys_conn;


ALTER RESOURCE POOL sys_pool SPLIT INTO ('tt1_pool1', 'tt1_pool2') ON ('z1', 'z2');
ob1.z3.add;
ob1.z3.start_zone;
ob1.z3.obs0.set status=enable;
ob1.z3.obs0.start;
sleep 10;
ob1.z3.obs0.add;
ob1.check_until_timeout select count(*) c from oceanbase.__all_server where start_service_time != 0, 3, 100;

#check ls create majority

ob_connect(conn_sys, ob1.z1.obs0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);

connection conn_sys;
eval CREATE RESOURCE UNIT unit_1 MAX_CPU 1, MEMORY_SIZE '2G';
CREATE RESOURCE POOL pool_3 UNIT = 'unit_1', UNIT_NUM = 1,zone_list = ('z3');
alter tenant sys RESOURCE_POOL_LIST = ('pool_3', 'tt1_pool1', 'tt1_pool2');
alter tenant sys set locality 'f@z1,f@z2,f@z3';
ob1.check_until_timeout select count(*) from oceanbase.__all_tenant where previous_locality!='', 0,100;
set @@session.ob_query_timeout = 1000000000;
ob1.mysql alter system set debug_sync_timeout = '100000s';

#mysql tenant
eval CREATE RESOURCE POOL pool_1 UNIT = 'unit_1', UNIT_NUM = 1;
eval CREATE TENANT mysql RESOURCE_POOL_LIST = ('pool_1'), primary_zone='z1' set ob_tcp_invited_nodes='%';
let $tenant_id = deploy_get_value(ob1.select select tenant_id from oceanbase.DBA_OB_TENANTS where tenant_name = 'mysql', tenant_id, 1);
ob1.z2.obs0.force_stop;
ob1.check_until_timeout select count(*) c from oceanbase.__all_server where status = 'ACTIVE', 2, 100;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_core_meta_table where role = 1, 1, 100;
ob1.mysql alter tenant mysql set primary_zone = 'z1,z2';

ob1.check_until_timeout SELECT COUNT(*) c FROM oceanbase.__all_virtual_ls_status where tenant_id = $tenant_id and status = 'NORMAL', 3, 30;

#set member list rpc
ob1.z2.obs0.start;
ob1.check_until_timeout select count(*) c from oceanbase.__all_server where start_service_time != 0, 3, 100;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_core_meta_table where role = 1, 1, 100;
set ob_global_debug_sync = 'BEFORE_SET_LS_MEMBER_LIST wait_for continue_signal';
sleep 3;
ob1.mysql alter tenant mysql set primary_zone = 'z1,z2,z3';
ob1.check_until_timeout SELECT COUNT(*) c FROM oceanbase.__all_virtual_ls_status where tenant_id = $tenant_id, 5, 30;
ob1.z3.obs0.force_stop;
ob1.check_until_timeout select count(*) c from oceanbase.__all_server where status = 'ACTIVE', 2, 100;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_core_meta_table where role = 1, 1, 100;
set ob_global_debug_sync = 'now signal continue_signal';

ob1.check_until_timeout SELECT COUNT(*) c FROM oceanbase.__all_virtual_ls_status where tenant_id = $tenant_id and status = 'NORMAL', 4, 30;

