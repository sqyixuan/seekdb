# CASE_OWNER:
#    @xingrui.cwh
# CASE_DESC:
#   To test whether can create tenant with spical name like gts
#

ob1=OBI(cluster=1:1,proxy_num=0);
source include/mini_ob_config.inc;
ob1.set extra_config=$mini_ob_config;
ob1.reboot;

ob_connect(sys, ob1.z1.obs0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);
connection sys;
set @@session.ob_query_timeout = 1000000000;
#case 1.create gts and GTS tenant alone
#create gts tenant
CREATE RESOURCE UNIT xingrui_unit MAX_CPU 1, MEMORY_SIZE '2G';
CREATE RESOURCE POOL xingrui_pool UNIT = 'xingrui_unit', UNIT_NUM = 1;
CREATE TENANT gts RESOURCE_POOL_LIST = ('xingrui_pool'), primary_zone='z1,z2' set ob_tcp_invited_nodes='%';
ob_connect(mysql1, ob1.z1.obs0, root@gts, , test, , USE_MYSQL_CONNECTOR);
connection mysql1;
create table test(col1 int, col2 int);
connection sys;
drop tenant gts force;

#create GTS tenant
CREATE TENANT GTS RESOURCE_POOL_LIST = ('xingrui_pool'), primary_zone='z1,z2' set ob_tcp_invited_nodes='%';
ob_connect(mysql2, ob1.z1.obs0, root@GTS, , test, , USE_MYSQL_CONNECTOR);
connection mysql2;
create table test(col1 int, col2 int);
connection sys;
drop tenant GTS force;

#case 2.create gts and GTS at the same time
connection sys;
CREATE TENANT gts RESOURCE_POOL_LIST = ('xingrui_pool'), primary_zone='z1,z2' set ob_tcp_invited_nodes='%';
ob_connect(mysql1, ob1.z1.obs0, root@gts, , test, , USE_MYSQL_CONNECTOR);
connection mysql1;
create table test(col1 int, col2 int);

connection sys;
CREATE RESOURCE UNIT xingrui_unit1 MAX_CPU 1, MEMORY_SIZE '2G';
CREATE RESOURCE POOL xingrui_pool1 UNIT = 'xingrui_unit1', UNIT_NUM = 1;
CREATE TENANT GTS RESOURCE_POOL_LIST = ('xingrui_pool1'), primary_zone='z1,z2' set ob_tcp_invited_nodes='%';
ob_connect(mysql2, ob1.z1.obs0, root@GTS, , test, , USE_MYSQL_CONNECTOR);
connection mysql2;
create table test(col1 int, col2 int);

connection sys;
drop tenant gts force;
drop tenant GTS force;
