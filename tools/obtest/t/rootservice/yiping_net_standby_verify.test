ob1=OBI(cluster=1:1:1,proxy_num=0);

let $backup_ip       = deploy_get_value(ob1.z1.obs0.ip);
let $backup_port     = deploy_get_value(ob1.z1.obs0.mysql_port);
let $backup_svr_port = deploy_get_value(ob1.z1.obs0.port);
let $z3_ip       = deploy_get_value(ob1.z3.obs0.ip);
let $z3_port     = deploy_get_value(ob1.z3.obs0.mysql_port);
let $backup_dest = deploy_get_value(ob1.get_backup_dest);
let $backup_mysql_tenant  = backup_mysql_tenant;
let $backup_oracle_tenant  = backup_oracle_tenant;

ob1.force_stop;
ob1.clean_backup_dest;
ob1.reboot;

ob1.mysql alter resource unit sys_unit_config memory_size='2G';

ob1.mysql CREATE RESOURCE UNIT unit_1 MAX_CPU 2, MEMORY_SIZE '2G';
ob1.mysql CREATE RESOURCE POOL pool_1 UNIT = 'unit_1', UNIT_NUM = 1, ZONE_LIST=('z1');
ob1.mysql CREATE RESOURCE POOL pool_2 UNIT = 'unit_1', UNIT_NUM = 1, ZONE_LIST=('z2');
# 创建主租户
ob1.mysql CREATE TENANT $backup_mysql_tenant RESOURCE_POOL_LIST = ('pool_1'), primary_zone = "z1" set ob_tcp_invited_nodes='%', ob_compatibility_mode='mysql';
let $backup_mysql_tenant_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name='$backup_mysql_tenant', tenant_id, 1);
# 设置归档源
ob_connect(backup_mysql_conn, ob1.z1.obs0,root@$backup_mysql_tenant,,test,,USE_MYSQL_CONNECTOR);
connection backup_mysql_conn;
# 准备一些数据
create table t1(a int primary key, b int, c int) partition by hash (a) partitions 100;
insert into t1(a, b) values(1, 1);
create table t2(a int primary key, b int, c int) partition by hash (a) partitions 100;
insert into t2(a, b) values(1, 1);
let $unit_count = deploy_get_value(ob1.select select count(*) c from __all_virtual_unit, c, 1);
# 创建用户
create user mytest identified by "test";
grant SELECT on OCEANBASE.* to mytest;

ob1.mysql CREATE STANDBY TENANT IF NOT EXISTS standby_mysql_tenant LOG_RESTORE_SOURCE = 'service=$backup_ip:$backup_port USER=mytest@backup_mysql_tenant PASSWORD=test' PRIMARY_ZONE='z2', RESOURCE_POOL_LIST=('pool_2');
let $standby_mysql_tenant_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name='standby_mysql_tenant', tenant_id, 1);
ob1.check_until_timeout select count(*) from DBA_OB_TENANTS where TENANT_ID = $standby_mysql_tenant_id and TENANT_ROLE = 'STANDBY' and SWITCHOVER_STATUS = 'NORMAL',1,30;

#################################################################################################
############################# mysql 模式，主租户被lock   ##########################################
#################################################################################################
connect(backup_sys_conn, $z3_ip, root@sys,,oceanbase, $z3_port);
connection backup_sys_conn;
--echo #mysql 模式，主租户被lock
ALTER TENANT backup_mysql_tenant LOCK;
--error 4179
ALTER SYSTEM SWITCHOVER TO PRIMARY TENANT standby_mysql_tenant VERIFY;
ALTER TENANT backup_mysql_tenant UNLOCK;
--error 4179
ALTER SYSTEM SWITCHOVER TO PRIMARY TENANT standby_mysql_tenant VERIFY;
#################################################################################################
############################# mysql 模式，用户被lock   ############################################
#################################################################################################
--echo #mysql 模式，用户被lock
connection backup_mysql_conn;
ALTER USER mytest ACCOUNT LOCK;
connection backup_sys_conn;
--error 4179
ALTER SYSTEM SWITCHOVER TO PRIMARY TENANT standby_mysql_tenant VERIFY;
connection backup_mysql_conn;
ALTER USER mytest ACCOUNT UNLOCK;
connection backup_sys_conn;
--error 4179
ALTER SYSTEM SWITCHOVER TO PRIMARY TENANT standby_mysql_tenant VERIFY;
#################################################################################################
############################# mysql 模式，用户完全查询没有权限   ####################################
#################################################################################################
--echo #mysql 模式，用户完全查询没有权限
connection backup_mysql_conn;
REVOKE SELECT ON `oceanbase`.* FROM 'mytest';
SHOW GRANTS FOR mytest;
connection backup_sys_conn;
--error 4179
ALTER SYSTEM SWITCHOVER TO PRIMARY TENANT standby_mysql_tenant VERIFY;
#################################################################################################
############################# mysql 模式，用户查询权限不够   ########################################
#################################################################################################
--echo #mysql 模式，用户查询权限不够
connection backup_mysql_conn;
GRANT SELECT on OCEANBASE.DBA_OB_ACCESS_POINT to mytest;
connection backup_sys_conn;
--error 4179
ALTER SYSTEM SWITCHOVER TO PRIMARY TENANT standby_mysql_tenant VERIFY;
connection backup_mysql_conn;
REVOKE SELECT ON `oceanbase`.`DBA_OB_ACCESS_POINT` FROM 'mytest';
grant SELECT on OCEANBASE.* to mytest;
connection backup_sys_conn;
--error 4179
ALTER SYSTEM SWITCHOVER TO PRIMARY TENANT standby_mysql_tenant VERIFY;
#################################################################################################
############################# mysql 模式，用户名错误   #############################################
#################################################################################################
--echo #mysql 模式，用户名错误
connection backup_mysql_conn;
RENAME USER 'mytest' TO 'mytest1';
connection backup_sys_conn;
--error 4179
ALTER SYSTEM SWITCHOVER TO PRIMARY TENANT standby_mysql_tenant VERIFY;
connection backup_mysql_conn;
RENAME USER 'mytest1' TO 'mytest';
connection backup_sys_conn;
--error 4179
ALTER SYSTEM SWITCHOVER TO PRIMARY TENANT standby_mysql_tenant VERIFY;
#################################################################################################
############################# mysql 模式，用户密码错误   ###########################################
#################################################################################################
--echo #mysql 模式，用户密码错误
connection backup_mysql_conn;
ALTER USER 'mytest' IDENTIFIED BY 'tttt';
connection backup_sys_conn;
--error 4179
ALTER SYSTEM SWITCHOVER TO PRIMARY TENANT standby_mysql_tenant VERIFY;
connection backup_mysql_conn;
ALTER USER 'mytest' IDENTIFIED BY 'test';
connection backup_sys_conn;
--error 4179
ALTER SYSTEM SWITCHOVER TO PRIMARY TENANT standby_mysql_tenant VERIFY;

#################################################################################################
############################# LS STATE NOT MATCH   ##############################################
#################################################################################################
--echo #LS STATE NOT MATCH
ALTER SYSTEM SWITCHOVER TO STANDBY TENANT backup_mysql_tenant;
alter system set_tp tp_name = ERRSIM_LS_STATE_NOT_MATCH, error_code = 9089, frequency = 1;
--error 9089
ALTER SYSTEM SWITCHOVER TO PRIMARY TENANT standby_mysql_tenant VERIFY;
alter system set_tp tp_name = ERRSIM_LS_STATE_NOT_MATCH, error_code = 9089, frequency = 0;
#################################################################################################
############################## mysql 模式，主租户宕机   ############################################
#################################################################################################
--echo #mysql 模式，主租户宕机
ob1.z1.obs0.force_stop;
sleep 2;
connection backup_sys_conn;
--error 4179
ALTER SYSTEM SWITCHOVER TO PRIMARY TENANT standby_mysql_tenant VERIFY;

#################################################################################################
############################## 删掉 mysql 租户， 创建 oracle 租户   ################################
#################################################################################################
ob1.z1.obs0.start;
ob1.check_until_timeout select count(*) from __all_server where svr_ip='$backup_ip' and svr_port=$backup_svr_port and status='ACTIVE' and start_service_time > 0,1,120;
drop tenant backup_mysql_tenant force;
drop tenant standby_mysql_tenant force;
ob1.check_until_timeout select count(*) from __all_virtual_unit,3,180;

# 创建主租户
ob1.mysql CREATE TENANT $backup_oracle_tenant RESOURCE_POOL_LIST = ('pool_1'), primary_zone = "z1" set ob_tcp_invited_nodes='%', ob_compatibility_mode='oracle';
let $backup_oracle_tenant_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name='$backup_oracle_tenant', tenant_id, 1);
# 设置归档源
ob_connect(backup_oracle_conn, ob1.z1.obs0, SYS@backup_oracle_tenant, , SYS, , USE_OB_CONNECTOR);
connection backup_oracle_conn;
# 准备一些数据
create table t1(a int primary key, b int, c int) partition by hash (a) partitions 100;
insert into t1(a, b) values(1, 1);
create table t2(a int primary key, b int, c int) partition by hash (a) partitions 100;
insert into t2(a, b) values(1, 1);
let $unit_count = deploy_get_value(ob1.select select count(*) c from __all_virtual_unit, c, 1);
# 创建用户
create user mytest identified by test;
GRANT CONNECT to mytest;
GRANT SELECT on SYS.DBA_OB_ACCESS_POINT to mytest;
GRANT SELECT on SYS.GV$OB_UNITS to mytest;
GRANT SELECT on SYS.DBA_OB_TENANTS to mytest;
GRANT SELECT on SYS.GV$OB_PARAMETERS to mytest;
GRANT SELECT on SYS.GV$OB_LOG_STAT to mytest;
GRANT SELECT on SYS.DBA_OB_LS to mytest;
GRANT SELECT on SYS.DBA_OB_LS_HISTORY to mytest;


ob1.mysql CREATE STANDBY TENANT IF NOT EXISTS standby_oracle_tenant LOG_RESTORE_SOURCE = 'service=$backup_ip:$backup_port USER=mytest@backup_oracle_tenant PASSWORD=test' PRIMARY_ZONE='z2', RESOURCE_POOL_LIST=('pool_2');
let $standby_oracle_tenant_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name='standby_oracle_tenant', tenant_id, 1);
ob1.check_until_timeout select count(*) from DBA_OB_TENANTS where TENANT_ID = $standby_oracle_tenant_id and TENANT_ROLE = 'STANDBY' and SWITCHOVER_STATUS = 'NORMAL',1,30;

#################################################################################################
############################# oracle 模式，主租户被lock   ##########################################
#################################################################################################
connection backup_sys_conn;
--echo #oracle 模式，主租户被lock
ALTER TENANT backup_oracle_tenant LOCK;
--error 4179
ALTER SYSTEM SWITCHOVER TO PRIMARY TENANT standby_oracle_tenant VERIFY;
ALTER TENANT backup_oracle_tenant UNLOCK;
--error 4179
ALTER SYSTEM SWITCHOVER TO PRIMARY TENANT standby_oracle_tenant VERIFY;
#################################################################################################
############################# oracle 模式，用户被lock   ############################################
#################################################################################################
--echo #oracle 模式，用户被lock
connection backup_oracle_conn;
ALTER USER mytest ACCOUNT LOCK;
connection backup_sys_conn;
--error 4179
ALTER SYSTEM SWITCHOVER TO PRIMARY TENANT standby_oracle_tenant VERIFY;
connection backup_oracle_conn;
ALTER USER mytest ACCOUNT UNLOCK;
connection backup_sys_conn;
--error 4179
ALTER SYSTEM SWITCHOVER TO PRIMARY TENANT standby_oracle_tenant VERIFY;
#################################################################################################
############################# oracle 模式，用户查询权限不够   ####################################
#################################################################################################
--echo #oracle 模式，用户完全查询没有权限
connection backup_oracle_conn;
REVOKE SELECT on SYS.DBA_OB_TENANTS FROM mytest;
SHOW GRANTS FOR mytest;
connection backup_sys_conn;
--error 4179
ALTER SYSTEM SWITCHOVER TO PRIMARY TENANT standby_oracle_tenant VERIFY;
connection backup_oracle_conn;
GRANT SELECT on SYS.DBA_OB_TENANTS to mytest;
connection backup_sys_conn;
--error 4179
ALTER SYSTEM SWITCHOVER TO PRIMARY TENANT standby_oracle_tenant VERIFY;

#################################################################################################
############################# oracle 模式，用户密码错误   ##########################################
#################################################################################################
--echo #oracle 模式，用户密码错误
connection backup_oracle_conn;
ALTER USER mytest IDENTIFIED BY tttt;
connection backup_sys_conn;
--error 4179
ALTER SYSTEM SWITCHOVER TO PRIMARY TENANT standby_oracle_tenant VERIFY;
connection backup_oracle_conn;
ALTER USER mytest IDENTIFIED BY test;
connection backup_sys_conn;
--error 4179
ALTER SYSTEM SWITCHOVER TO PRIMARY TENANT standby_oracle_tenant VERIFY;

#################################################################################################
############################## mysql 模式，主租户宕机   ############################################
#################################################################################################
--echo #oracle 模式，主租户宕机
ob1.z1.obs0.force_stop;
sleep 3;
connection backup_sys_conn;
--error 4179
ALTER SYSTEM SWITCHOVER TO PRIMARY TENANT standby_oracle_tenant VERIFY;