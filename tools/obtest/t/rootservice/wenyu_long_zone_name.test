# CASE_OWNER:
#    @fanfnagzhou.ffz
# CASE_DESC:
#    test zone with long name

# test 8 zones with length of 127
let $z2 = z2_0000000000111111111122222222223333333333444444444455555555556666666666777777777788888888889999999999000000000011111111112end;
let $z3 = z3_0000000000111111111122222222223333333333444444444455555555556666666666777777777788888888889999999999000000000011111111112end;
let $z4 = z4_0000000000111111111122222222223333333333444444444455555555556666666666777777777788888888889999999999000000000011111111112end;
let $z5 = z5_0000000000111111111122222222223333333333444444444455555555556666666666777777777788888888889999999999000000000011111111112end;
let $z6 = z6_0000000000111111111122222222223333333333444444444455555555556666666666777777777788888888889999999999000000000011111111112end;
let $z7 = z7_0000000000111111111122222222223333333333444444444455555555556666666666777777777788888888889999999999000000000011111111112end;
let $z8 = z8_0000000000111111111122222222223333333333444444444455555555556666666666777777777788888888889999999999000000000011111111112end;
let $z9 = z9_0000000000111111111122222222223333333333444444444455555555556666666666777777777788888888889999999999000000000011111111112end;

ob1=OBI(cluster=1:1:1:1:1:1:1:1:1, zone_names=z1:$z2:$z3:$z4:$z5:$z6:$z7:$z8:$z9);
source include/mini_ob_config.inc;
ob1.set extra_config=$mini_ob_config;

# There can be only 7 zones at most when bootstrap. First disable z8 z9, and enable later.
ob1.$z8.obs0.set status=disable;
ob1.$z9.obs0.set status=disable;
ob1.reboot;
ob1.$z8.add;
ob1.$z8.start_zone;
ob1.$z8.obs0.set status=enable;
ob1.$z8.obs0.start;
ob1.$z9.add;
ob1.$z9.start_zone;
ob1.$z9.obs0.set status=enable;
ob1.$z9.obs0.start;
sleep 10;
ob1.$z8.obs0.add;
ob1.$z9.obs0.add;
# waiting for the servers to start service
ob1.check_until_timeout select count(*) from oceanbase.__all_server where zone in ("$z8", "$z9") and (start_service_time<=0 or status='inactive'),0,60;

ob_connect(conn_sys, ob1.z1.obs0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);

eval CREATE RESOURCE UNIT unit_1 MAX_CPU 2, MEMORY_SIZE '4G';
eval CREATE RESOURCE POOL pool_1 UNIT = 'unit_1', UNIT_NUM = 1;
eval CREATE TENANT mysql RESOURCE_POOL_LIST = ('pool_1'), primary_zone='z1,$z2,$z3', locality='F@z1, F@$z2, F@$z3, R@$z4, R@$z5, R@$z6, R@$z7, R@$z8, R@$z9'  set ob_tcp_invited_nodes='%';

# check zones in inner_table are properly displayed
select zone from oceanbase.__all_server order by zone;
select zone from oceanbase.dba_ob_zones order by zone;
select zone_list from oceanbase.__all_resource_pool;
select zone_list, locality from oceanbase.__all_tenant;

# check commands related to zones
alter tenant mysql primary_zone = RANDOM;
select primary_zone from __all_tenant where tenant_id = 1002;

eval alter tenant mysql primary_zone = "z1,$z2,$z3";
select primary_zone from __all_tenant where tenant_id = 1002;

eval alter tenant mysql primary_zone = "$z2";
select primary_zone from __all_tenant where tenant_id = 1002;

eval alter system stop zone $z2;
select primary_zone from __all_tenant where tenant_id = 1002;

eval alter tenant mysql locality = 'F@z1, F@$z2, F@$z3, F@$z4, R@$z5, R@$z6, R@$z7, R@$z8, R@$z9';
select locality, previous_locality from __all_tenant where tenant_id = 1002;
ob1.check_until_timeout select count(*) from oceanbase.__all_tenant where previous_locality != '', 0, 60;
select job_type, extra_info from oceanbase.__all_rootservice_job order by job_id desc limit 1;

eval alter tenant mysql locality = 'F@z1, F@$z2, F@$z3, F@$z4, R@$z5, R@$z6, R@$z7, R@$z8';
select locality, previous_locality from __all_tenant where tenant_id = 1002;
ob1.check_until_timeout select count(*) from oceanbase.__all_tenant where previous_locality != '', 0, 60;
select job_type, extra_info from oceanbase.__all_rootservice_job order by job_id desc limit 1;

eval alter resource pool pool_1 zone_list = ('z1', '$z2', '$z3', '$z4', '$z5', '$z6', '$z7', '$z8');
