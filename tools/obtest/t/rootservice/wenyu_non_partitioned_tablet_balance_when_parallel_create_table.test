ob1=OBI(cluster=2, init_unit_cpu=0, proxy_num=0, ct_num=0, locality=hz);
ob1.reboot;

let $rs = ob1.z1.obs0;
let $rs_ip = deploy_get_value($rs.ip);
let $rs_port = deploy_get_value($rs.port);
let $rs_mysql_port = deploy_get_value($rs.mysql_port);
connect (conn_sys,$rs_ip,admin@sys,admin,oceanbase,$rs_mysql_port);

connection conn_sys;
set @@session.ob_query_timeout = 100000000;
create resource unit if not exists 4c8g max_cpu 4, memory_size '8G';
CREATE RESOURCE POOL pool_1 UNIT = '4c8g', UNIT_NUM = 2;
CREATE TENANT mysql RESOURCE_POOL_LIST = ('pool_1'), primary_zone = 'z1', locality='F@z1' set ob_tcp_invited_nodes='%', recyclebin = OFF;

alter system set _wait_interval_after_parallel_ddl = '1us' tenant=all;
alter system set _enable_parallel_table_creation = 'True' tenant=all;
alter system set ls_gc_delay_time = '10s' tenant=all;
# disable partition balance
alter system set partition_balance_schedule_interval = '0s' tenant=all;
sleep 5;

let $tenant_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name = "mysql", tenant_id, 1);
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_ls_status where tenant_id = $tenant_id and status = "NORMAL" and ls_id > 1, 2, 120;

let $mysql_ip = deploy_get_value(ob1.select select unit.svr_ip, s.inner_port from DBA_OB_UNITS as unit join oceanbase.__all_virtual_ls_status as ls on unit.tenant_id = ls.tenant_id and unit.unit_group_id = ls.unit_group_id join oceanbase.__all_server as s on unit.svr_ip = s.svr_ip and unit.svr_port = s.svr_port where unit.tenant_id = $tenant_id and ls.ls_id = 1001 and unit.zone = "z1", svr_ip, 1);
let $mysql_port = deploy_get_value(ob1.select select unit.svr_ip, s.inner_port from DBA_OB_UNITS as unit join oceanbase.__all_virtual_ls_status as ls on unit.tenant_id = ls.tenant_id and unit.unit_group_id = ls.unit_group_id join oceanbase.__all_server as s on unit.svr_ip = s.svr_ip and unit.svr_port = s.svr_port where unit.tenant_id = $tenant_id and ls.ls_id = 1001 and unit.zone = "z1", inner_port, 1);
connect (conn_mysql,$mysql_ip,root@mysql,,test,$mysql_port);
connection conn_mysql;

# case 1: tablets are balanced in two ls
select ls_id, count(*) from oceanbase.__all_tablet_to_ls group by 1;

let $idx = 0;
while ($idx < 10)
{
--disable_query_log
eval create table t_$idx(c1 int primary key);
--enable_query_log
inc $idx;
}

select ls_id, count(*) from oceanbase.__all_tablet_to_ls group by 1;

# case 2: tablets are still balanced after non-parallel ddl (reload cache)
# NOTICE: maybe unstable when this already run 10min and trigger try_statistic_balance_group_status_() in backgroud.
set @@global.ob_query_timeout = 10000001;

while ($idx < 20)
{
--disable_query_log
eval create table t_$idx(c1 int primary key);
--enable_query_log
inc $idx;
}

select ls_id, count(*) from oceanbase.__all_tablet_to_ls group by 1;

# case 3: shrink unit num (reload cache)
let $delete_unit_group_id = deploy_get_value(ob1.select select unit_group_id from oceanbase.__all_virtual_ls_status where tenant_id = $tenant_id and ls_id = 1002, unit_group_id, 1);
connection conn_sys;
eval alter resource tenant mysql UNIT_NUM = 1 delete unit_group ($delete_unit_group_id);
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_ls_status where tenant_id = $tenant_id and ls_id > 1, 1, 180;
# wait 10min at most to trigger try_statistic_balance_group_status_() in backgroud to make case stable
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_balance_group_ls_stat where tenant_id = $tenant_id and balance_group_name = "NON_PART_TABLE", 1, 720;

connection conn_mysql;
while ($idx < 30)
{
--disable_query_log
eval create table t_$idx(c1 int primary key);
--enable_query_log
inc $idx;
}

select ls_id, count(*) from oceanbase.__all_tablet_to_ls group by 1;

# case 4: expand unit num (reload cache)
connection conn_sys;
eval alter resource tenant mysql UNIT_NUM = 2;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_ls_status where tenant_id = $tenant_id and ls_id > 1, 2, 180;
# wait 10min at most to trigger try_statistic_balance_group_status_() in backgroud to make case stable
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_balance_group_ls_stat where tenant_id = $tenant_id and balance_group_name = "NON_PART_TABLE" and tablet_group_count = 15, 2, 720;

connection conn_mysql;
while ($idx < 40)
{
--disable_query_log
eval create table t_$idx(c1 int primary key);
--enable_query_log
inc $idx;
}

select ls_id, count(*) from oceanbase.__all_tablet_to_ls group by 1;

# case 5: modify partition_balance_schedule_interval to trigger reload cache
# disable tranfer to make tablet placement stable
alter system set enable_transfer = false;
alter system set partition_balance_schedule_interval = "10s";
# wait time passed
sleep 15;

while ($idx < 50)
{
--disable_query_log
eval create table t_$idx(c1 int primary key);
--enable_query_log
inc $idx;
}

select ls_id, count(*) from oceanbase.__all_tablet_to_ls group by 1;
