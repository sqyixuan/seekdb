# CASE_OWNER:
#    @jingyu.cr
# CASE_DESC:
#    最大paxos replica num不得超过OB_MAX_MEMBER_NUMBER
#    部署：
#    八台observer，每台server一个zone：z1~z8

ob1=OBI(cluster=1:1:1:1:1:1:1:1,proxy_num=0,init_unit_cpu=0);

ob1.z8.obs0.set status=disable;

ob1.reboot;
ob1.z8.add;
ob1.z8.start_zone;
ob1.z8.obs0.set status=enable;
ob1.z8.obs0.start;
ob1.z8.obs0.add;
# waiting for the servers to start service
ob1.check_until_timeout select count(*) from oceanbase.__all_server where zone in ("z6", "z7", "z8") and (start_service_time<=0 or status='inactive'),0,60;

ob_connect(sys_conn, ob1.z1.obs0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);
connection sys_conn;

eval create resource unit unit1 max_cpu 2, memory_size '10G';

eval create resource pool tt_pool unit = 'unit1', unit_num = 1, zone_list = ('z1','z2','z3','z4','z5','z6','z7','z8');
--error 1210 
eval create tenant tt resource_pool_list=('tt_pool'), locality = 'F@z1,F@z2,F@z3,F@z4,F@z5,F@z6,F@z7,F@z8' set ob_tcp_invited_nodes='%';

eval create tenant tt resource_pool_list=('tt_pool'), locality = 'F@z1,F@z2,F@z3,F@z4,F@z5,F@z6,F@z7' set ob_tcp_invited_nodes='%';
--error 1210 
eval alter tenant tt locality = 'F@z1,F@z2,F@z3,F@z4,F@z5,F@z6,F@z7,F@z8';
