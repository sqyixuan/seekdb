# CASE_OWNER:
#    @jinqian.zzy
# CASE_DESC:
#    This case is aimed to test history view
#    We designed following cases to simulate different scenes:
#    CASE 1: basic test
#    CASE 2: print history table
#######################################################################
#                        create inital objects
#######################################################################

ob1=OBI(cluster=2:2:2:2:2,proxy_num=0,init_unit_cpu=0);
source include/mini_ob_config.inc;
ob1.set extra_config=$mini_ob_config;
ob1.reboot;

ob1.mysql ALTER SYSTEM SET enable_rereplication = 'false';
ob1.mysql alter system set server_permanent_offline_time = '20s';
ob1.mysql alter system set debug_sync_timeout = '100000s';

let $proxy_ip = deploy_get_value(ob1.z1.obs1.ip);
let $proxy_port = deploy_get_value(ob1.z1.obs1.mysql_port);
connect(sys_conn, $proxy_ip, root@sys,,oceanbase, $proxy_port);

source include/create_unit_config.inc;
ob1.mysql CREATE RESOURCE POOL tenant_pool UNIT = "2c2g", UNIT_NUM = 2, ZONE_LIST = ('z1', 'z2', 'z3', 'z4', 'z5');
ob1.mysql CREATE TENANT mysql_tenant RESOURCE_POOL_LIST=('tenant_pool'), LOCALITY = "F@z1, F@z2, F@z3, F@z4", PRIMARY_ZONE = "z1" SET ob_tcp_invited_nodes='%';
connect(mysql_tenant, $proxy_ip, root@mysql_tenant,,oceanbase, $proxy_port);

ob1.mysql CREATE RESOURCE POOL tenant_pool1 UNIT = "2c2g", UNIT_NUM = 2, ZONE_LIST = ('z1', 'z2', 'z3', 'z4', 'z5');
ob1.mysql CREATE TENANT oracle_tenant RESOURCE_POOL_LIST=('tenant_pool1'), LOCALITY = "F@z1, F@z2, F@z3, F@z4", PRIMARY_ZONE = "z1" SET ob_tcp_invited_nodes='%', ob_compatibility_mode = 'oracle';
ob_connect(oracle_tenant, ob1.z1.obs0, SYS@oracle_tenant, , SYS, , USE_OB_CONNECTOR);

connection sys_conn;
let $mysql_tenant_id = deploy_get_value(ob1.select SELECT tenant_id FROM oceanbase.DBA_OB_TENANTS WHERE tenant_name = "mysql_tenant", tenant_id, 1);
let $oracle_tenant_id = deploy_get_value(ob1.select SELECT tenant_id FROM oceanbase.DBA_OB_TENANTS WHERE tenant_name = "oracle_tenant", tenant_id, 1);
let $mysql_meta_tenant_id = deploy_get_value(ob1.select select tenant_id - 1 as meta_tenant_id from oceanbase.DBA_OB_TENANTS where tenant_name = "mysql_tenant", meta_tenant_id, 1);
let $oracle_meta_tenant_id = deploy_get_value(ob1.select select tenant_id - 1 as meta_tenant_id from oceanbase.DBA_OB_TENANTS where tenant_name = "oracle_tenant", meta_tenant_id, 1);



ob1.check_until_timeout select count(*) from CDB_OB_LS_LOCATIONS where tenant_id = $mysql_tenant_id and ls_id = 1001 and role = 'leader', 1, 10;
ob1.check_until_timeout select count(*) from CDB_OB_LS_LOCATIONS where tenant_id = $mysql_tenant_id and ls_id = 1002 and role = 'leader', 1, 10;
ob1.check_until_timeout select count(*) from CDB_OB_LS_LOCATIONS where tenant_id = $oracle_tenant_id and ls_id = 1001 and role = 'leader', 1, 10;
ob1.check_until_timeout select count(*) from CDB_OB_LS_LOCATIONS where tenant_id = $oracle_tenant_id and ls_id = 1002 and role = 'leader', 1, 10;
ob1.check_until_timeout select count(*) from GV\$OB_LOG_STAT where tenant_id = $mysql_tenant_id and ls_id = 1001 and role = 'leader', 1, 10;
ob1.check_until_timeout select count(*) from GV\$OB_LOG_STAT where tenant_id = $mysql_tenant_id and ls_id = 1002 and role = 'leader', 1, 10;
ob1.check_until_timeout select count(*) from GV\$OB_LOG_STAT where tenant_id = $oracle_tenant_id and ls_id = 1001 and role = 'leader', 1, 10;
ob1.check_until_timeout select count(*) from GV\$OB_LOG_STAT where tenant_id = $oracle_tenant_id and ls_id = 1002 and role = 'leader', 1, 10;

# get servers' addr
let $z1_obs0_ip = deploy_get_value(ob1.z1.obs0.ip);
let $z1_obs0_port = deploy_get_value(ob1.z1.obs0.port);
let $z1_obs0 = $z1_obs0_ip:$z1_obs0_port;

let $z1_obs1_ip = deploy_get_value(ob1.z1.obs1.ip);
let $z1_obs1_port = deploy_get_value(ob1.z1.obs1.port);
let $z1_obs1 = $z1_obs1_ip:$z1_obs1_port;

let $z2_obs0_ip = deploy_get_value(ob1.z2.obs0.ip);
let $z2_obs0_port = deploy_get_value(ob1.z2.obs0.port);
let $z2_obs0 = $z2_obs0_ip:$z2_obs0_port;

let $z2_obs1_ip = deploy_get_value(ob1.z2.obs1.ip);
let $z2_obs1_port = deploy_get_value(ob1.z2.obs1.port);
let $z2_obs1 = $z2_obs1_ip:$z2_obs1_port;

let $z3_obs0_ip = deploy_get_value(ob1.z3.obs0.ip);
let $z3_obs0_port = deploy_get_value(ob1.z3.obs0.port);
let $z3_obs0 = $z3_obs0_ip:$z3_obs0_port;

let $z3_obs1_ip = deploy_get_value(ob1.z3.obs1.ip);
let $z3_obs1_port = deploy_get_value(ob1.z3.obs1.port);
let $z3_obs1 = $z3_obs1_ip:$z3_obs1_port;

let $z4_obs0_ip = deploy_get_value(ob1.z4.obs0.ip);
let $z4_obs0_port = deploy_get_value(ob1.z4.obs0.port);
let $z4_obs0 = $z4_obs0_ip:$z4_obs0_port;

let $z4_obs1_ip = deploy_get_value(ob1.z4.obs1.ip);
let $z4_obs1_port = deploy_get_value(ob1.z4.obs1.port);
let $z4_obs1 = $z4_obs1_ip:$z4_obs1_port;

let $z5_obs0_ip = deploy_get_value(ob1.z5.obs0.ip);
let $z5_obs0_port = deploy_get_value(ob1.z5.obs0.port);
let $z5_obs0 = $z5_obs0_ip:$z5_obs0_port;

connection sys_conn;
let $mysql_tenant_ls_id = deploy_get_value(ob1.select SELECT ls_id as ls_id_tmp FROM oceanbase.CDB_OB_LS_LOCATIONS WHERE svr_ip = '$z1_obs0_ip' AND svr_port = $z1_obs0_port AND ls_id > 1 AND tenant_id = $mysql_tenant_id, ls_id_tmp, 1);
let $oracle_tenant_ls_id = deploy_get_value(ob1.select SELECT ls_id as ls_id_tmp FROM oceanbase.CDB_OB_LS_LOCATIONS WHERE svr_ip = '$z1_obs0_ip' AND svr_port = $z1_obs0_port AND ls_id > 1 AND tenant_id = $oracle_tenant_id, ls_id_tmp, 1);

--disable_query_log
--echo ========================================================================
--echo ||                    [MILESTONE] prepare finished                    ||
--echo ========================================================================

--echo ========================================================================
--echo ||              [MILESTONE] alter ls replica                           ||
--echo ========================================================================

--disable_query_log
connection sys_conn;
--echo 1.1 mysql tenant add replica
eval alter system add replica ls=$mysql_tenant_ls_id server='$z5_obs0' replica_type='F' paxos_replica_num=5 tenant='mysql_tenant';
ob1.check_until_timeout select PAXOS_REPLICA_NUMBER from __all_virtual_ls_meta_table where role = 1 and tenant_id = $mysql_tenant_id and ls_id = $mysql_tenant_ls_id, 5, 60;
ob1.check_until_timeout SELECT COUNT(*) = 1 FROM oceanbase.CDB_OB_LS_LOCATIONS WHERE tenant_id = $mysql_tenant_id AND role = "LEADER" AND member_list LIKE '%$z5_obs0%', 1, 20;
sleep 3;
--echo 1.2 mysql tenant modify replica
eval alter system modify replica ls=$mysql_tenant_ls_id server='$z3_obs0' replica_type='R' paxos_replica_num=4 tenant='mysql_tenant';
ob1.check_until_timeout select PAXOS_REPLICA_NUMBER from __all_virtual_ls_meta_table where role = 1 and tenant_id = $mysql_tenant_id and ls_id = $mysql_tenant_ls_id, 4, 60;
ob1.check_until_timeout SELECT COUNT(*) = 0 FROM oceanbase.CDB_OB_LS_LOCATIONS WHERE tenant_id = $mysql_tenant_id AND role = "LEADER" AND member_list LIKE '%$z3_obs0%', 1, 20;
sleep 3;
--echo 1.3 mysql tenant remove replica
eval alter system remove replica ls=$mysql_tenant_ls_id server='$z3_obs0' paxos_replica_num=4 tenant='mysql_tenant';
ob1.check_until_timeout select count(*) from __all_virtual_ls_meta_table where tenant_id = $mysql_tenant_id and ls_id = $mysql_tenant_ls_id, 4, 60;
ob1.check_until_timeout SELECT COUNT(*) = 0 FROM oceanbase.CDB_OB_LS_LOCATIONS WHERE tenant_id = $mysql_tenant_id AND role = "LEADER" AND learner_list LIKE '%$z3_obs0%', 1, 20;
sleep 3;
--echo 1.4 mysql tenant migrate replica
eval alter system migrate replica ls=$mysql_tenant_ls_id source='$z4_obs0' destination='$z4_obs1' tenant='mysql_tenant';
sleep 3;
ob1.check_until_timeout select count(*) from __all_virtual_ls_meta_table where tenant_id = $mysql_tenant_id and ls_id = $mysql_tenant_ls_id, 4, 60;
ob1.check_until_timeout SELECT COUNT(*) = 0 FROM oceanbase.CDB_OB_LS_LOCATIONS WHERE tenant_id = $mysql_tenant_id AND role = "LEADER" AND member_list NOT LIKE '%$z4_obs1%' AND member_list LIKE '%$z4_obs0%', 1, 20;
sleep 3;


--echo 2.1 oracle tenant add replica
eval alter system add replica ls=$oracle_tenant_ls_id server='$z5_obs0' replica_type='F' paxos_replica_num=5 tenant='oracle_tenant';
ob1.check_until_timeout select PAXOS_REPLICA_NUMBER from __all_virtual_ls_meta_table where role = 1 and tenant_id = $oracle_tenant_id and ls_id = $oracle_tenant_ls_id, 5, 60;
ob1.check_until_timeout SELECT COUNT(*) = 1 FROM oceanbase.CDB_OB_LS_LOCATIONS WHERE tenant_id = $oracle_tenant_id AND role = "LEADER" AND member_list LIKE '%$z5_obs0%', 1, 20;
sleep 3;
--echo 2.2 oracle tenant modify replica
eval alter system modify replica ls=$oracle_tenant_ls_id server='$z3_obs0' replica_type='R' paxos_replica_num=4 tenant='oracle_tenant';
ob1.check_until_timeout select PAXOS_REPLICA_NUMBER from __all_virtual_ls_meta_table where role = 1 and tenant_id = $oracle_tenant_id and ls_id = $oracle_tenant_ls_id, 4, 60;
ob1.check_until_timeout SELECT COUNT(*) = 0 FROM oceanbase.CDB_OB_LS_LOCATIONS WHERE tenant_id = $oracle_tenant_id AND role = "LEADER" AND member_list LIKE '%$z3_obs0%', 1, 20;
sleep 3;
--echo 2.3 oracle tenant remove replica
eval alter system remove replica ls=$oracle_tenant_ls_id server='$z3_obs0' paxos_replica_num=4 tenant='oracle_tenant';
ob1.check_until_timeout select count(*) from __all_virtual_ls_meta_table where tenant_id = $oracle_tenant_id and ls_id = $oracle_tenant_ls_id, 4, 60;
ob1.check_until_timeout SELECT COUNT(*) = 0 FROM oceanbase.CDB_OB_LS_LOCATIONS WHERE tenant_id = $oracle_tenant_id AND role = "LEADER" AND learner_list LIKE '%$z3_obs0%', 1, 20;
sleep 3;
--echo 2.4 oracle tenant migrate replica
eval alter system migrate replica ls=$oracle_tenant_ls_id source='$z4_obs0' destination='$z4_obs1' tenant='oracle_tenant';
sleep 3;
ob1.check_until_timeout select count(*) from __all_virtual_ls_meta_table where tenant_id = $oracle_tenant_id and ls_id = $oracle_tenant_ls_id, 4, 60;
ob1.check_until_timeout SELECT COUNT(*) = 0 FROM oceanbase.CDB_OB_LS_LOCATIONS WHERE tenant_id = $oracle_tenant_id AND role = "LEADER" AND member_list NOT LIKE '%$z4_obs1%' AND member_list LIKE '%$z4_obs0%', 1, 20;
sleep 3;

ob1.z2.obs0.force_stop;
ob1.check_until_timeout select count(*) from __all_server where SVR_IP = '$z2_obs0_ip' and SVR_PORT = '$z2_obs0_port' and STATUS = 'ACTIVE', 0, 60;
ob1.check_until_timeout select count(*) from __all_virtual_ls_meta_table where tenant_id = $mysql_tenant_id and ls_id = $mysql_tenant_ls_id, 3, 60;
ob1.check_until_timeout select count(*) from __all_virtual_ls_meta_table where tenant_id = $oracle_tenant_id and ls_id = $oracle_tenant_ls_id, 3, 60;
sleep 3;

--echo 3.1 mysql tenant modify paxos_replica_num
eval alter system modify ls=$mysql_tenant_ls_id paxos_replica_num=3 tenant='mysql_tenant';
ob1.check_until_timeout select PAXOS_REPLICA_NUMBER from __all_virtual_ls_meta_table where role = 1 and tenant_id = $mysql_tenant_id and ls_id = $mysql_tenant_ls_id, 3, 60;
sleep 3;
--echo 3.2 oracle tenant modify paxos_replica_num
eval alter system modify ls=$oracle_tenant_ls_id paxos_replica_num=3 tenant='oracle_tenant';
ob1.check_until_timeout select PAXOS_REPLICA_NUMBER from __all_virtual_ls_meta_table where role = 1 and tenant_id = $oracle_tenant_id and ls_id = $oracle_tenant_ls_id, 3, 60;
sleep 3;

--echo ========================================================================
--echo ||              [MILESTONE] print history table                       ||
--echo ========================================================================

--echo 1.sys tenant
connection sys_conn;
--echo cdb_ob_ls_replica_task_history:
select tenant_id, ls_id, task_type, task_status, priority, target_paxos_replica_number, target_replica_type, source_paxos_replica_number, source_replica_type, comment, is_manual from cdb_ob_ls_replica_task_history;
--echo dba_ob_ls_replica_task_history:
select ls_id, task_type, task_status, priority, target_paxos_replica_number, target_replica_type, source_paxos_replica_number, source_replica_type, comment, is_manual from dba_ob_ls_replica_task_history;

--echo 2.mysql_tenant
connection mysql_tenant;
--echo cdb_ob_ls_replica_task_history:
--error 1146
select tenant_id, ls_id, task_type, task_status, priority, target_paxos_replica_number, target_replica_type, source_paxos_replica_number, source_replica_type, comment, is_manual from cdb_ob_ls_replica_task_history;
--echo dba_ob_ls_replica_task_history:
select ls_id, task_type, task_status, priority, target_paxos_replica_number, target_replica_type, source_paxos_replica_number, source_replica_type, comment, is_manual from dba_ob_ls_replica_task_history;

--echo 3.mysql_tenant meta_tennat
connection sys_conn;
eval alter system change tenant tenant_id = $mysql_meta_tenant_id;
--echo dba_ob_ls_replica_task_history:
select ls_id, task_type, task_status, priority, target_paxos_replica_number, target_replica_type, source_paxos_replica_number, source_replica_type, comment, is_manual from dba_ob_ls_replica_task_history;


--echo 4.oracle_tenant
connection oracle_tenant;
--echo cdb_ob_ls_replica_task_history:
--error 942
select tenant_id, ls_id, task_type, task_status, priority, target_paxos_replica_number, target_replica_type, source_paxos_replica_number, source_replica_type, 'comment', is_manual from cdb_ob_ls_replica_task_history;
--echo dba_ob_ls_replica_task_history:
select ls_id, task_type, task_status, priority, target_paxos_replica_number, target_replica_type, source_paxos_replica_number, source_replica_type, "COMMENT", is_manual from dba_ob_ls_replica_task_history;

--echo 5.oracle_tenant meta_tennat
connection sys_conn;
eval alter system change tenant tenant_id = $oracle_meta_tenant_id;
--echo dba_ob_ls_replica_task_history:
select ls_id, task_type, task_status, priority, target_paxos_replica_number, target_replica_type, source_paxos_replica_number, source_replica_type, "COMMENT", is_manual from dba_ob_ls_replica_task_history;

