# CASE_OWNER:
#    @cangming.zl
# CASE_DESC:
#    C副本运维操作测试

ob1=OBI(cluster=2:2:2:2, proxy_num=0, init_unit_cpu=0);
ob1.reboot;
ob1.mysql alter system set balancer_idle_time = '10s';
ob1.mysql alter system set debug_sync_timeout = '100000s';
ob1.mysql alter system set undo_retention = 1800;

let $proxy_ip = deploy_get_value(ob1.z1.obs0.ip);
let $proxy_port = deploy_get_value(ob1.z1.obs0.mysql_port);
ob_connect(sys_conn, ob1.z1.obs0,root@sys, ,oceanbase, , USE_MYSQL_CONNECTOR);

connection sys_conn;

CREATE RESOURCE UNIT uc MAX_CPU 2, MEMORY_SIZE '4G';
CREATE RESOURCE POOL rp UNIT = 'uc', UNIT_NUM = 2;
CREATE RESOURCE POOL rp1 UNIT = 'uc', UNIT_NUM = 1;

--echo =========================================================
--echo           case 1: create tenant with C-replica
--echo =========================================================
CREATE TENANT tt1 RESOURCE_POOL_LIST = ('rp'), LOCALITY = 'F@z1,R@z2,C@z3,COLUMNSTORE@z4' set ob_tcp_invited_nodes='%';
ob1.check_until_timeout select count(*) from oceanbase.DBA_OB_TENANTS where tenant_name = 'tt1' and locality='FULL{1}@z1, READONLY{1}@z2, COLUMNSTORE{1}@z3, COLUMNSTORE{1}@z4', 1, 1;
ob_connect(conn1, ob1.z1.obs0, root@tt1, , test,, USE_MYSQL_CONNECTOR);
connection conn1;
CREATE TABLE t1 (c1 int,c2 int) PARTITION BY HASH(c1) PARTITIONS 8;
CREATE TABLE dup_t1 (c1 int,c2 int) DUPLICATE_SCOPE= 'cluster';
# waiting for updating member_list and learner_list
sleep 5;
# check ls locations and replica_type
select ls_id, zone, replica_type from oceanbase.DBA_OB_LS_LOCATIONS order by ls_id, zone, replica_type;
# DBA_OB_TABLE_LOCATIONs
select ls_id, zone, replica_type from oceanbase.DBA_OB_TABLE_LOCATIONS where table_name = 't1' order by ls_id, zone, replica_type;
select ls_id, zone, replica_type from oceanbase.DBA_OB_TABLE_LOCATIONS where table_name = 'dup_t1' order by zone, replica_type;
# __all_virtual_proxy_schema
select table_name, replica_type from oceanbase.__all_virtual_proxy_schema where tenant_name = 'tt1' and database_name = 'test' and table_name = 't1' order by replica_type;
select table_name, replica_type from oceanbase.__all_virtual_proxy_schema where tenant_name = 'tt1' and database_name = 'test' and table_name = 'dup_t1' order by replica_type;
select table_name, replica_type from oceanbase.__all_virtual_proxy_schema where tenant_name = 'tt1' and database_name = 'oceanbase' and table_name = '__all_dummy' order by replica_type;
select table_name, replica_type from oceanbase.__all_virtual_proxy_schema where tenant_name = 'tt1' and database_name = 'oceanbase' and table_name = '__all_user' order by replica_type;

# check oracle mode tenant
connection sys_conn;
CREATE TENANT tt3 RESOURCE_POOL_LIST = ('rp1'), LOCALITY = 'F@z1,C@z2' set ob_tcp_invited_nodes='%', ob_compatibility_mode='oracle';
ob1.check_until_timeout select count(*) from oceanbase.DBA_OB_TENANTS where tenant_name = 'tt3' and locality='FULL{1}@z1, COLUMNSTORE{1}@z2', 1, 1;
ob_connect(conn2, ob1.z1.obs1, SYS@tt3, ,SYS, , USE_OB_CONNECTOR);
connection conn2;
# waiting for updating member_list and learner_list
sleep 5;
# check ls locations and replica_type
select ls_id, zone, replica_type from SYS.DBA_OB_LS_LOCATIONS order by ls_id, zone, replica_type;
connection sys_conn;
DROP TENANT tt3 FORCE;

--echo =========================================================
--echo           case 2: alter tenant with C-replica
--echo =========================================================
connection sys_conn;
let $tenant_id1 = query_get_value(select tenant_id from __all_tenant where tenant_name = 'tt1', tenant_id, 1);

# remove C-replica
ALTER TENANT tt1 LOCALITY = 'F@z1,R@z2';
ob1.check_until_timeout select count(*) c from oceanbase.__all_tenant where tenant_id = $tenant_id1 and previous_locality = '', 1, 600;
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id = $tenant_id1 and replica_type = 'COLUMNSTORE', 0, 600;
# check ls locations and replica_type
connection conn1;
select ls_id, zone, replica_type from oceanbase.DBA_OB_LS_LOCATIONS order by ls_id, zone, replica_type;

# insert rows and do major freeze, to generate 2 compaction versions
let $i = 1;
connection conn1;
--disable_query_log
while ($i <= 32)
{
  eval INSERT INTO t1 VALUES($i, $i);
  eval INSERT INTO dup_t1 VALUES($i, $i);
  inc $i;
}
--enable_query_log
ob1.mysql alter system major freeze tenant = 'tt1';
sleep 10;
ob1.check_until_timeout select (frozen_scn - last_scn) as result from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id = $tenant_id1, 0, 600;

# add C-replica
connection sys_conn;
ALTER TENANT tt1 LOCALITY = 'F@z1,R@z2,C@z3';
ob1.check_until_timeout select count(*) c from oceanbase.__all_tenant where tenant_id = $tenant_id1 and previous_locality = '', 1, 600;
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id = $tenant_id1 and replica_type = 'COLUMNSTORE', 4, 600;
# check ls locations and replica_type
connection conn1;
select ls_id, zone, replica_type from oceanbase.DBA_OB_LS_LOCATIONS order by ls_id, zone, replica_type;
connection sys_conn;

# add C-replica
connection sys_conn;
ALTER TENANT tt1 LOCALITY = 'F@z1,R@z2,C@z3,C@z4';
ob1.check_until_timeout select count(*) c from oceanbase.__all_tenant where tenant_id = $tenant_id1 and previous_locality = '', 1, 600;
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id = $tenant_id1 and replica_type = 'COLUMNSTORE', 8, 600;
# check ls locations and replica_type
connection conn1;
select ls_id, zone, replica_type from oceanbase.DBA_OB_LS_LOCATIONS order by ls_id, zone, replica_type;

# insert rows and do major freeze, to generate 3 compaction versions
let $i = 17;
connection conn1;
--disable_query_log
while ($i <= 32)
{
  eval INSERT INTO t1 VALUES($i, $i);
  eval INSERT INTO dup_t1 VALUES($i, $i);
  inc $i;
}
--enable_query_log
ob1.mysql alter system major freeze tenant = 'tt1';
sleep 10;
ob1.check_until_timeout select (frozen_scn - last_scn) as result from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id = $tenant_id1, 0, 600;

# transform between C-replica and other type replica is not supported
connection sys_conn;
--error 4179
ALTER TENANT tt1 LOCALITY = 'F@z1,R@z2,C@z3,R@z4';
--error 4179
ALTER TENANT tt1 LOCALITY = 'F@z1,R@z2,C@z3,F@z4';
--error 4179
ALTER TENANT tt1 LOCALITY = 'F@z1,C@z2,R@z3,C@z4';

CREATE TENANT tt2 RESOURCE_POOL_LIST = ('rp1'), LOCALITY = 'F@z1,F@z2,F@z3,R@z4', PRIMARY_ZONE = 'z1';
--error 4179
ALTER TENANT tt2 LOCALITY = 'F@z1,F@z2,F@z3,C@z4';
--error 4179
ALTER TENANT tt2 LOCALITY = 'F@z1,F@z2,C@z3,R@z4';
DROP TENANT tt2 force;

--echo =========================================================
--echo           case 3: shrinking and expanding units
--echo =========================================================
# shrinking
ALTER RESOURCE TENANT tt1 UNIT_NUM 1;
ob1.check_until_timeout select job_status from __all_rootservice_job where tenant_id = $tenant_id1 order by job_id desc limit 1, SUCCESS, 600;
ob1.check_until_timeout select count(*) from __all_virtual_ls_replica_task_plan, 0, 600;
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id = $tenant_id1 and replica_type = 'COLUMNSTORE', 4, 20;
connection conn1;
sleep 20;
select ls_id, zone, replica_type from oceanbase.DBA_OB_LS_LOCATIONS order by ls_id, zone, replica_type;
connection sys_conn;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_unit where tenant_id in ($tenant_id1, $tenant_id1 - 1), 8, 600;

# expanding
ALTER RESOURCE TENANT tt1 UNIT_NUM 2;
ob1.check_until_timeout select job_status from __all_rootservice_job where tenant_id = $tenant_id1 order by job_id desc limit 1, SUCCESS, 600;
ob1.check_until_timeout select count(*) from __all_virtual_ls_replica_task_plan, 0, 600;
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id = $tenant_id1 and replica_type = 'COLUMNSTORE', 8, 60;
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id = $tenant_id1, 18, 60;
connection conn1;
select ls_id, zone, replica_type from oceanbase.DBA_OB_LS_LOCATIONS order by ls_id, zone, replica_type;
connection sys_conn;

--echo =========================================================
--echo           case 4: permanent offline and restart
--echo =========================================================
# permanent offline and remove replica
ob1.mysql alter system set server_permanent_offline_time = '20s';
ob1.z3.obs1.force_stop;
let $svr_ip = deploy_get_value(ob1.z3.obs1.ip);
let $svr_port = deploy_get_value(ob1.z3.obs1.port);
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_LS_LOCATIONS where svr_ip = '$svr_ip' and svr_port = $svr_port, 0, 100;
# restart add re-add replica
ob1.z3.obs1.nstart;
ob1.check_until_timeout select count(*) from __all_server where status='INACTIVE' or start_service_time <= 0, 0, 120;
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_LS_LOCATIONS where svr_ip = '$svr_ip' and svr_port = $svr_port and replica_type = 'COLUMNSTORE', 2, 600;

--echo =========================================================
--echo           case 5: ob_admin add and remove C_replica
--echo =========================================================
let $z1_dst_ip0 = deploy_get_value(ob1.z1.obs0.ip);
let $z1_dst_port0 = deploy_get_value(ob1.z1.obs0.port);
let $z1_dst0 = $z1_dst_ip0:$z1_dst_port0;
let $z2_dst_ip0 = deploy_get_value(ob1.z2.obs0.ip);
let $z2_dst_port0 = deploy_get_value(ob1.z2.obs0.port);
let $z2_dst0 = $z2_dst_ip0:$z2_dst_port0;
let $z3_dst_ip0 = deploy_get_value(ob1.z3.obs0.ip);
let $z3_dst_port0 = deploy_get_value(ob1.z3.obs0.port);
let $z3_dst0 = $z3_dst_ip0:$z3_dst_port0;
let $z4_dst_ip0 = deploy_get_value(ob1.z4.obs0.ip);
let $z4_dst_port0 = deploy_get_value(ob1.z4.obs0.port);
let $z4_dst0 = $z4_dst_ip0:$z4_dst_port0;

# sys_ls C replica in C zone will be automatically removed
let $ls_id = 1;
ob1.sh ./etc/ob_admin -h $z3_dst_ip0 -p $z3_dst_port0 add_ls_replica tenant_id = $tenant_id1 , ls_id = $ls_id, replica_type = 'C';
ob1.check_until_timeout select count(*) as cnt from oceanbase.DBA_OB_SERVER_EVENT_HISTORY where module like "%ob_admin%" and svr_ip = "$z3_dst_ip0" and svr_port = $z3_dst_port0 and value4 like "%OB_SUCCESS%" and value3 like "%tenant_id = $tenant_id1 , ls_id = $ls_id, replica_type = C%" and value6 like "%add ls replica trigger by ob_admin%", 1, 10;
ob1.check_until_timeout select count(*) as cnt from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id = $tenant_id1 and ls_id = $ls_id and role = "LEADER" and learner_list like "%$z3_dst0%", 1, 200;
ob1.check_until_timeout select count(*) as cnt from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id = $tenant_id1 and ls_id = $ls_id and role = "LEADER" and not learner_list like "%$z3_dst0%", 1, 200;

# add C_replica to zone1, zone2, and test it can be automatically removed
# zone 1, C in F zone
let $ls_id = query_get_value(select ls_id from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id = $tenant_id1 and role = "LEADER" and not member_list like "%$z1_dst0%" and ls_id != 1, ls_id, 1);
ob1.sh ./etc/ob_admin -h $z1_dst_ip0 -p $z1_dst_port0 add_ls_replica tenant_id = $tenant_id1 , ls_id = $ls_id, replica_type = 'C';
ob1.check_until_timeout select count(*) as cnt from oceanbase.DBA_OB_SERVER_EVENT_HISTORY where module like "%ob_admin%" and svr_ip = "$z1_dst_ip0" and svr_port = $z1_dst_port0 and value4 like "%OB_SUCCESS%" and value3 like "%tenant_id = $tenant_id1 , ls_id = $ls_id, replica_type = C%" and value6 like "%add ls replica trigger by ob_admin%", 1, 10;
ob1.check_until_timeout select count(*) as cnt from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id = $tenant_id1 and ls_id = $ls_id and role = "LEADER" and learner_list like "%$z1_dst0%", 1, 200;
ob1.check_until_timeout select count(*) as cnt from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id = $tenant_id1 and ls_id = $ls_id and role = "LEADER" and not learner_list like "%$z1_dst0%", 1, 200;

# zone2, C in R zone
let $ls_id = query_get_value(select ls_id from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id = $tenant_id1 and role = "LEADER" and not learner_list like "%$z2_dst0%" and ls_id != 1, ls_id, 1);
ob1.sh ./etc/ob_admin -h $z2_dst_ip0 -p $z2_dst_port0 add_ls_replica tenant_id = $tenant_id1 , ls_id = $ls_id, replica_type = 'C';
ob1.check_until_timeout select count(*) as cnt from oceanbase.DBA_OB_SERVER_EVENT_HISTORY where module like "%ob_admin%" and svr_ip = "$z2_dst_ip0" and svr_port = $z2_dst_port0 and value4 like "%OB_SUCCESS%" and value3 like "%tenant_id = $tenant_id1 , ls_id = $ls_id, replica_type = C%" and value6 like "%add ls replica trigger by ob_admin%", 1, 10;
ob1.check_until_timeout select count(*) as cnt from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id = $tenant_id1 and ls_id = $ls_id and role = "LEADER" and learner_list like "%$z2_dst0%", 1, 200;
ob1.check_until_timeout select count(*) as cnt from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id = $tenant_id1 and ls_id = $ls_id and role = "LEADER" and not learner_list like "%$z2_dst0%", 1, 200;

# add F, R replica to zone3, and test it can be automatically removed
# first alter locality to 2F2C
ALTER TENANT tt1 LOCALITY = 'F@z1,F@z2,C@z3,C@z4', primary_zone = 'z1';
ob1.check_until_timeout select count(*) c from oceanbase.__all_tenant where tenant_id = $tenant_id1 and previous_locality = '', 1, 600;
# zone3, F in C zone
let $ls_id = query_get_value(select ls_id from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id = $tenant_id1 and role = "LEADER" and not learner_list like "%$z3_dst0%" and ls_id != 1, ls_id, 1);
ob1.sh ./etc/ob_admin -h $z3_dst_ip0 -p $z3_dst_port0 add_ls_replica tenant_id = $tenant_id1 , ls_id = $ls_id, replica_type = 'F', new_paxos_replica_number = 3;
ob1.check_until_timeout select count(*) as cnt from oceanbase.DBA_OB_SERVER_EVENT_HISTORY where module like "%ob_admin%" and svr_ip = "$z3_dst_ip0" and svr_port = $z3_dst_port0 and value4 like "%OB_SUCCESS%" and value3 like "%tenant_id = $tenant_id1 , ls_id = $ls_id, replica_type = F%" and value6 like "%add ls replica trigger by ob_admin%", 1, 10;
ob1.check_until_timeout select count(*) as cnt from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id = $tenant_id1 and ls_id = $ls_id and role = "LEADER" and member_list like "%$z3_dst0%", 1, 200;
ob1.check_until_timeout select count(*) as cnt from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id = $tenant_id1 and ls_id = $ls_id and role = "LEADER" and not member_list like "%$z3_dst0%", 1, 200;

# zone3, R in C zone
let $ls_id = query_get_value(select ls_id from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id = $tenant_id1 and role = "LEADER" and not learner_list like "%$z4_dst0%" and ls_id != 1, ls_id, 1);
ob1.sh ./etc/ob_admin -h $z4_dst_ip0 -p $z4_dst_port0 add_ls_replica tenant_id = $tenant_id1 , ls_id = $ls_id, replica_type = 'R';
ob1.check_until_timeout select count(*) as cnt from oceanbase.DBA_OB_SERVER_EVENT_HISTORY where module like "%ob_admin%" and svr_ip = "$z4_dst_ip0" and svr_port = $z4_dst_port0 and value4 like "%OB_SUCCESS%" and value3 like "%tenant_id = $tenant_id1 , ls_id = $ls_id, replica_type = R%" and value6 like "%add ls replica trigger by ob_admin%", 1, 10;
ob1.check_until_timeout select count(*) as cnt from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id = $tenant_id1 and ls_id = $ls_id and role = "LEADER" and learner_list like "%$z4_dst0%", 1, 200;
ob1.check_until_timeout select count(*) as cnt from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id = $tenant_id1 and ls_id = $ls_id and role = "LEADER" and not learner_list like "%$z4_dst0%", 1, 200;

# remove C_replica in zone3
let $ls_id = query_get_value(select ls_id from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id = $tenant_id1 and role = "LEADER" and learner_list like "%$z3_dst0%" and ls_id != 1, ls_id, 1);
ob1.sh ./etc/ob_admin -h $z1_dst_ip0 -p $z1_dst_port0 remove_ls_replica tenant_id = $tenant_id1 , ls_id = $ls_id, replica_type = 'C', server = '$z3_dst0';
ob1.check_until_timeout select count(*) as cnt from oceanbase.DBA_OB_SERVER_EVENT_HISTORY where module like "%ob_admin%" and svr_ip = "$z1_dst_ip0" and svr_port = $z1_dst_port0 and value4 like "%OB_SUCCESS%" and value3 like "%tenant_id = $tenant_id1 , ls_id = $ls_id, replica_type = C, server = $z3_dst0%" and value6 like "%remove ls replica trigger by ob_admin%", 1, 10;
ob1.check_until_timeout select count(*) as cnt from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id = $tenant_id1 and ls_id = $ls_id and role = "LEADER" and learner_list like "%$z3_dst0%", 0, 200;

--echo =========================================================
--echo           case 6: create ls, fail and retry
--echo =========================================================
connection sys_conn;
ob1.mysql set ob_global_debug_sync = 'BEFORE_PROCESS_AFTER_HAS_MEMBER_LIST wait_for signal';
# -- alter tenant primary_zone
alter tenant tt1 primary_zone = 'z1,z2';
# -- wait ls creating
ob1.check_until_timeout select count(*) as cnt from oceanbase.__all_virtual_ls_status where tenant_id = $tenant_id1 and init_member_list != '', 1, 200;
let $ls_id = query_get_value(select ls_id from oceanbase.__all_virtual_ls_status where tenant_id = $tenant_id1 and init_member_list != '', ls_id, 1);
# -- restart cluster
ob1.force_stop;
sleep 10;
ob1.nstart;
ob1.check_until_timeout select count(*) from oceanbase.__all_server where (start_service_time<=0 or status='INACTIVE'),0,600;
ob1.check_until_timeout  select count(1) as unsync_cnt from GV\$OB_LOG_STAT where in_sync = 'NO',0,600;
# -- check ls continue to create
ob_connect(sys_conn, ob1.z1.obs0,root@sys, ,oceanbase, , USE_MYSQL_CONNECTOR);
connection sys_conn;
ob1.mysql set ob_global_debug_sync = 'now signal signal';
ob1.check_until_timeout select count(*) as cnt from oceanbase.__all_virtual_ls_status where tenant_id = $tenant_id1 and status = 'NORMAL', 6, 200;
ob1.check_until_timeout select count(*) as cnt from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id = $tenant_id1 and replica_type = 'COLUMNSTORE', 12, 200;
eval select ls_id, zone, replica_type from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id = $tenant_id1 and ls_id = $ls_id order by zone;

--echo =========================================================
--echo           case 7: drop ls
--echo =========================================================
connection sys_conn;
alter tenant tt1 primary_zone = 'z1';
ob1.check_until_timeout select job_status from oceanbase.__all_rootservice_job where tenant_id = $tenant_id1 order by gmt_create desc limit 1, SUCCESS, 200;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_ls_status where tenant_id = $tenant_id1, 4, 200;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_ls where tenant_id = $tenant_id1 and status = 'DROPPED', 3, 200;
