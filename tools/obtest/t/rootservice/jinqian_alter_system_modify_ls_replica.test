eval select count(*) from __all_virtual_ls_meta_table where ls_id = $tenant_ls_id and SVR_IP = '$z2_obs1_ip' and SVR_PORT = '$z2_obs1_port';

--echo 4.8 add f
--echo F F F F p = 7
--echo F F F
eval alter system add replica ls=$tenant_ls_id server='$z3_obs1' replica_type='F' paxos_replica_num = 7 tenant='mysql_tenant';
ob1.check_until_timeout select PAXOS_REPLICA_NUMBER from __all_virtual_ls_meta_table where role = 1 and ls_id = $tenant_ls_id, 7, 60;
