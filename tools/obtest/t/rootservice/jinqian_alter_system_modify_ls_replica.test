sleep 3;
eval select LS_ID, ROLE, PAXOS_REPLICA_NUMBER, REPLICA_TYPE from __all_virtual_ls_meta_table where ls_id = $tenant_ls_id order by ROLE, REPLICA_TYPE, PAXOS_REPLICA_NUMBER;
--echo expected 1
eval select count(*) from __all_virtual_ls_meta_table where ls_id = $tenant_ls_id and SVR_IP = '$z3_obs1_ip' and SVR_PORT = '$z3_obs1_port';

--echo 4.9 add f, number of F replica has reached the limit, add error
--error 4179
eval alter system add replica ls=$tenant_ls_id server='$z4_obs1' replica_type='F' paxos_replica_num = 8 tenant='mysql_tenant';

--echo 4.10 migrate f, number of F replica has reached the limit, add error
--error 4179
eval alter system migrate replica ls=$tenant_ls_id source='$z4_obs0' destination='$z4_obs1' tenant='mysql_tenant';

--echo 4.11 modify f, number of F replica has reached the limit, add error
--echo R F F F p = 6
--echo F F F
eval alter system modify replica ls=$tenant_ls_id server='$z1_obs0' replica_type = 'R' paxos_replica_num=6 tenant='mysql_tenant';
ob1.check_until_timeout select PAXOS_REPLICA_NUMBER from __all_virtual_ls_meta_table where role = 1 and ls_id = $tenant_ls_id, 6, 60;
ob1.check_until_timeout SELECT COUNT(*) = 0 FROM oceanbase.CDB_OB_LS_LOCATIONS WHERE tenant_id = $tenant_id AND ls_id = $tenant_ls_id AND role = "LEADER" AND member_list LIKE '%$z1_obs0%', 1, 20;
sleep 3;
eval select LS_ID, ROLE, PAXOS_REPLICA_NUMBER, REPLICA_TYPE from __all_virtual_ls_meta_table where ls_id = $tenant_ls_id order by ROLE, REPLICA_TYPE, PAXOS_REPLICA_NUMBER;
--echo expected 1
eval select count(*) from __all_virtual_ls_meta_table where ls_id = $tenant_ls_id and SVR_IP = '$z1_obs0_ip' and SVR_PORT = '$z1_obs0_port' and replica_type = 16;
--echo expected 0
eval select count(*) from __all_virtual_ls_meta_table where ls_id = $tenant_ls_id and SVR_IP = '$z1_obs0_ip' and SVR_PORT = '$z1_obs0_port' and replica_type = 0;

--echo add f
--echo R F F F p = 7
--echo F F F F
eval alter system add replica ls=$tenant_ls_id server='$z4_obs1' replica_type='F' paxos_replica_num = 7 tenant='mysql_tenant';
ob1.check_until_timeout select PAXOS_REPLICA_NUMBER from __all_virtual_ls_meta_table where role = 1 and ls_id = $tenant_ls_id, 7, 60;
ob1.check_until_timeout SELECT COUNT(*) = 1 FROM oceanbase.CDB_OB_LS_LOCATIONS WHERE tenant_id = $tenant_id AND ls_id = $tenant_ls_id AND role = "LEADER" AND member_list LIKE '%$z4_obs1%', 1, 20;
sleep 3;
eval select LS_ID, ROLE, PAXOS_REPLICA_NUMBER, REPLICA_TYPE from __all_virtual_ls_meta_table where ls_id = $tenant_ls_id order by ROLE, REPLICA_TYPE, PAXOS_REPLICA_NUMBER;
--echo expected 1
eval select count(*) from __all_virtual_ls_meta_table where ls_id = $tenant_ls_id and SVR_IP = '$z4_obs1_ip' and SVR_PORT = '$z4_obs1_port';

--error 4179
eval alter system modify replica ls=$tenant_ls_id server='$z1_obs0' replica_type = 'F' paxos_replica_num=8 tenant='mysql_tenant';

ob1.mysql set ob_global_debug_sync = 'now signal signal';
