# CASE_OWNER:
#    @gengfu.zpc
# CASE_DESC:
#    This case is designed to test setting parameters by zone.
#

ob1=OBI(cluster=1:1:1, proxy_num=0, init_unit_cpu=0);
ob1.reboot;

ob_connect(conn_sys, ob1.z1.obs0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);
connection conn_sys;

--result_format 4

# =========================== prepare tenant (mysql & oracle) ============================
CREATE RESOURCE UNIT unit_1 MAX_CPU 1, MEMORY_SIZE='2G';
CREATE RESOURCE POOL pool_1 UNIT = 'unit_1', UNIT_NUM = 1, ZONE_LIST = ('z1','z2','z3');
CREATE TENANT mysql_tenant RESOURCE_POOL_LIST = ('pool_1'), locality='F@z1,F@z2,F@z3', primary_zone='z1;z2;z3' set ob_tcp_invited_nodes='%', ob_compatibility_mode='mysql';

CREATE RESOURCE UNIT unit_2 MAX_CPU 1, MEMORY_SIZE='2G';
CREATE RESOURCE POOL pool_2 UNIT = 'unit_2', UNIT_NUM = 1, ZONE_LIST = ('z1','z2','z3');
CREATE TENANT oracle_tenant RESOURCE_POOL_LIST = ('pool_2'), locality='F@z1,F@z2,F@z3', primary_zone='z1;z2;z3' set ob_tcp_invited_nodes='%', ob_compatibility_mode='oracle';

sleep 3;

let $mysql_tenant_id = query_get_value(select tenant_id from DBA_OB_TENANTS where tenant_name = 'mysql_tenant', tenant_id, 1);
let $oracle_tenant_id = query_get_value(select tenant_id from DBA_OB_TENANTS where tenant_name = 'oracle_tenant', tenant_id, 1);
let $tcp_keepcnt_v1 = 10;
let $tcp_keepcnt_v2 = 12;
let $open_cursors_v1 = 50;
let $open_cursors_v2 = 55;
let $open_cursors_v3 = 65;

# set parameters for all zone, all server
eval alter system set tcp_keepcnt = $tcp_keepcnt_v1;
eval alter system set open_cursors = $open_cursors_v1 tenant = sys;
eval alter system set open_cursors = $open_cursors_v1 tenant = all_user;
eval alter system set open_cursors = $open_cursors_v1 tenant = all_meta;

sleep 3;

# set parameters by zone
eval alter system set tcp_keepcnt = $tcp_keepcnt_v2 zone = 'z2';
eval alter system set open_cursors = $open_cursors_v2 zone = 'z3' tenant = all_user;

sleep 3;

--disable_query_log
select zone, name, value, scope from __all_virtual_tenant_parameter_stat where name='tcp_keepcnt' order by zone;
# meke sure the result is correct for mysql_tenant and oracle_tenant
eval select zone, name, value, scope from __all_virtual_tenant_parameter_stat where name='open_cursors' and tenant_id = $mysql_tenant_id order by zone;
eval select zone, name, value, scope from __all_virtual_tenant_parameter_stat where name='open_cursors' and tenant_id = $oracle_tenant_id order by zone;
# make sure the result is correct for other tenants
eval select distinct name, value from __all_virtual_tenant_parameter_stat where name='open_cursors' and tenant_id != $mysql_tenant_id and tenant_id != $oracle_tenant_id;
--enable_query_log

ob_connect(conn_mysql, ob1.z1.obs0, root@mysql_tenant, , oceanbase, , USE_MYSQL_CONNECTOR);
connection conn_mysql;

# set parameters by zone in mysql tenant
eval alter system set open_cursors = $open_cursors_v3 zone = 'z1';

sleep 3;

connection conn_sys;
--disable_query_log
# meke sure the result is correct for mysql_tenant and oracle_tenant
eval select zone, name, value, scope from __all_virtual_tenant_parameter_stat where name='open_cursors' and tenant_id = $mysql_tenant_id order by zone;
eval select zone, name, value, scope from __all_virtual_tenant_parameter_stat where name='open_cursors' and tenant_id = $oracle_tenant_id order by zone;
# make sure the result is correct for other tenants
eval select distinct name, value from __all_virtual_tenant_parameter_stat where name='open_cursors' and tenant_id != $mysql_tenant_id and tenant_id != $oracle_tenant_id;
--enable_query_log
