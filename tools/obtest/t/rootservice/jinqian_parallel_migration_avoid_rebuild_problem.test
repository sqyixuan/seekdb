# CASE_OWNER:
#    @jinqian.zzy
# CASE_DESC:
#    测试并行迁移可以解决备库副本rebuild问题
#######################################################################
#                        create inital objects
#######################################################################
ob1=OBI(cluster=2:2:2, proxy_num=0);
source include/mini_ob_config.inc;
ob1.set extra_config=$mini_ob_config;
ob1.reboot;

ob1.mysql ALTER SYSTEM SET enable_rebalance = 'false';
let $proxy_ip = deploy_get_value(ob1.z1.obs0.ip);
let $proxy_port = deploy_get_value(ob1.z1.obs0.mysql_port);
connect(sys_conn, $proxy_ip, root@sys,,oceanbase, $proxy_port);

source include/create_unit_config.inc;
ob1.mysql CREATE RESOURCE POOL tenant_pool1 UNIT = "2c2g", UNIT_NUM = 2, ZONE_LIST = ('z1', 'z2', 'z3');
ob1.mysql CREATE RESOURCE POOL tenant_pool2 UNIT = "2c2g", UNIT_NUM = 2, ZONE_LIST = ('z1', 'z2', 'z3');

ob1.mysql CREATE TENANT oracle_tenant RESOURCE_POOL_LIST = ('tenant_pool1'), LOCALITY = "F@z1, F@z2, F@z3", primary_zone = "z1" set ob_tcp_invited_nodes='%', ob_compatibility_mode='oracle';
let $tenant_id = query_get_value(select tenant_id from oceanbase.__all_tenant where tenant_name='oracle_tenant', tenant_id, 1);

connection sys_conn;
# 延迟日志流的GC，否则恢复空备租户会由于日志流被GC掉卡住
ob1.mysql alter system set ls_gc_delay_time='100000s' tenant=all;

ob_connect(primary_tenant_conn, ob1.z1.obs0,SYS@oracle_tenant,,SYS,,USE_OB_CONNECTOR);

connection primary_tenant_conn;
create user mytest identified by "test";
grant connect to mytest;
GRANT SELECT on SYS.DBA_OB_ACCESS_POINT to mytest;
GRANT SELECT on SYS.GV$OB_UNITS to mytest;
GRANT SELECT on SYS.DBA_OB_TENANTS to mytest;
GRANT SELECT on SYS.GV$OB_PARAMETERS to mytest;
GRANT SELECT on SYS.GV$OB_LOG_STAT to mytest;
GRANT SELECT on SYS.DBA_OB_LS to mytest;
GRANT SELECT on SYS.DBA_OB_LS_HISTORY to mytest;

# 1. 主租户写数据
SET ob_query_timeout = 10000000000;
create table t1 (c1 varchar(10), c2 varchar(10));
insert into t1 select randstr(10, random()), randstr(10, random()) from table(generator(100));
create table t2 (c1 varchar(10), c2 varchar(10));
insert into t2 select randstr(10, random()), randstr(10, random()) from table(generator(100));
commit;
sleep 10;

# 2. 主租户缩容
connection sys_conn;
ALTER RESOURCE TENANT oracle_tenant UNIT_NUM = 1;
# 等待unit GC 完成
ob1.check_until_timeout select count(*) from GV\$ob_units where tenant_id = 1002, 3, 600;

# 3. 恢复备租户
# get primary tenant access point
let $server_ip_port_1=deploy_get_value(ob1.select select concat(svr_ip,':',sql_port) as host from CDB_OB_LS_LOCATIONS where tenant_id = $tenant_id and ls_id = 1 and role = 'LEADER' order by svr_ip, sql_port limit 1;, host, 1);
ob1.mysql CREATE STANDBY TENANT IF NOT EXISTS standby_oracle_tenant LOG_RESTORE_SOURCE = 'service=$server_ip_port_1 USER=mytest@oracle_tenant PASSWORD=test' PRIMARY_ZONE='z1', RESOURCE_POOL_LIST=('tenant_pool2'),locality='F@z1,F@z2,F@z3', comment='aaaaaaaa';

# alter system set replica_parallel_migration_mode = 'off' tenant = 'standby_oracle_tenant';

# 4. 等到备租户恢复的比较新
let $gts = deploy_get_value(ob1.select select ts_value from oceanbase.V\$OB_TIMESTAMP_SERVICE where tenant_id = $tenant_id, ts_value, 1);
ob1.check_until_timeout select count(*) from oceanbase.DBA_OB_TENANTS where READABLE_SCN > $gts and tenant_name = 'standby_oracle_tenant', 1, 600;

# 5. 等到备租户迁移任务完成
ob1.check_until_timeout SELECT count(*) FROM oceanbase.__all_server_event_history WHERE module = 'storage_ha' and event = 'ls_ha_finish' and value1 = 1004 and value2 > 1 and extra_info = 'MIGRATE_LS_OP', 3, 30;

# 6. 最后查看没有发生rebuild
sleep 30;
ob1.check_until_timeout SELECT count(*) FROM oceanbase.__all_server_event_history WHERE module = 'storage_ha' and event = 'ls_ha_finish' and value6 = '0' and extra_info = 'REBUILD_LS_OP', 0, 10;