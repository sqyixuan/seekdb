# CASE_OWNER:
#    @shouju.zyp
# CASE_DESC:


ob1=OBI(cluster=1,proxy_num=0);
let $proxy_ip = deploy_get_value(ob1.z1.obs0.ip);
let $proxy_port = deploy_get_value(ob1.z1.obs0.mysql_port);

ob1.reboot;

ob1.mysql CREATE RESOURCE UNIT 1c2g MAX_CPU 1, MEMORY_SIZE '2G';
ob1.mysql CREATE RESOURCE POOL pool1 UNIT='1c2g',UNIT_NUM=1,ZONE_LIST=('z1');
ob1.mysql CREATE RESOURCE POOL pool2 UNIT='1c2g',UNIT_NUM=1,ZONE_LIST=('z1');

ob1.mysql CREATE TENANT IF NOT EXISTS test_tenant_mysql ZONE_LIST=('z1'), RESOURCE_POOL_LIST=('pool1') set ob_tcp_invited_nodes='%', ob_compatibility_mode='mysql';
ob1.mysql CREATE TENANT IF NOT EXISTS test_tenant_oracle ZONE_LIST=('z1'), RESOURCE_POOL_LIST=('pool2') set ob_tcp_invited_nodes='%', ob_compatibility_mode='oracle';
#########mysql mock租户改名#########
ob1.mysql alter system set_tp tp_name = ERRSIM_MOCK_SERVICE_NAME, error_code = 4018, frequency = 1;
--disable_all_result_log
--error 4780
connect(mysql_conn, $proxy_ip, root@test_tenantkkk_mysql,,oceanbase, $proxy_port);
--enable_all_result_log
ob1.mysql alter system set_tp tp_name = ERRSIM_MOCK_SERVICE_NAME, error_code = 4018, frequency = 0;
ob1.z1.obs0.check_log_until_success "login via service_name but tenant not exist";

connect(test_mysql_conn, $proxy_ip, root@test_tenant_mysql,,oceanbase, $proxy_port);
connection test_mysql_conn;
#########mysql 不允许用户租户下不填写和自己不一致租户名做 service name 运维命令#########
--error 5157
ALTER SYSTEM CREATE SERVICE test_service tenant = testsss_tenant_mysql;
#########mysql 允许用户租户下不填写租户名做 service name 运维命令#########
ALTER SYSTEM CREATE SERVICE test_service;
#########mysql 允许用户租户下填写和自己一致的租户名做 service name 运维命令#########
ALTER SYSTEM STOP SERVICE test_service tenant = test_tenant_mysql;
SELECT SERVICE_NAME, SERVICE_STATUS FROM OCEANBASE.DBA_OB_SERVICES;
#########mysql 不允许没有alter system权限的用户做 service name 运维命令#######
create user usr_test;
grant select on test.* to usr_test;
connect(test_mysql_conn_usr, $proxy_ip, usr_test@test_tenant_mysql,,, $proxy_port);
connection test_mysql_conn_usr;
--error 1227
ALTER SYSTEM DELETE SERVICE test_service;
#########mysql 允许有alter system权限的用户做 service name 运维命令#######
connection test_mysql_conn;
grant alter system on *.* to usr_test;
connect(test_mysql_conn_usr1, $proxy_ip, usr_test@test_tenant_mysql,,, $proxy_port);
connection test_mysql_conn_usr1;
ALTER SYSTEM DELETE SERVICE test_service;
connection test_mysql_conn;
SELECT SERVICE_NAME, SERVICE_STATUS FROM OCEANBASE.DBA_OB_SERVICES;
ALTER SYSTEM CREATE SERVICE test_service;
SELECT SERVICE_NAME, SERVICE_STATUS FROM OCEANBASE.DBA_OB_SERVICES;
#########mysql 不允许有alter system权限但通过service_name登录的用户做 service name 运维命令和SO/FO #######
ob1.mysql alter system set_tp tp_name = ERRSIM_MOCK_SERVICE_NAME, error_code = 4018, frequency = 1;
connect(test_mysql_conn_2, $proxy_ip, root@test_tenant_mysql,,oceanbase, $proxy_port);
connection test_mysql_conn_2;
--error 4179
ALTER SYSTEM STOP SERVICE test_service;
--error 4179
ALTER SYSTEM CREATE SERVICE test_service_2;
--error 4179
ALTER SYSTEM SWITCHOVER TO STANDBY;
--error 4179
ALTER SYSTEM SWITCHOVER TO PRIMARY;
--error 4179
ALTER SYSTEM ACTIVATE STANDBY;
ob1.mysql alter system set_tp tp_name = ERRSIM_MOCK_SERVICE_NAME, error_code = 4018, frequency = 0;

ob_connect(test_oracle_conn, ob1.z1.obs0, SYS@test_tenant_oracle, , SYS, , USE_OB_CONNECTOR);
connection test_oracle_conn;
#########oracle 不允许用户租户下不填写和自己不一致租户名做 service name 运维命令#########
--error 600
ALTER SYSTEM CREATE SERVICE test_service tenant = testsss_tenant_oracle;
#########oracle 允许用户租户下不填写租户名做 service name 运维命令#########
ALTER SYSTEM CREATE SERVICE test_service;
#########oracle 允许用户租户下填写和自己一致的租户名做 service name 运维命令#########
ALTER SYSTEM STOP SERVICE test_service tenant = "test_tenant_oracle";
SELECT SERVICE_NAME, SERVICE_STATUS FROM SYS.DBA_OB_SERVICES;
#########oracle 不允许没有alter system权限的用户做 service name 运维命令#######
create user usr_test identified by 123;
grant select on *.* to usr_test;
ob_connect(test_oracle_conn_usr, ob1.z1.obs0, usr_test@test_tenant_oracle, 123, usr_test, , USE_OB_CONNECTOR);
connection test_oracle_conn_usr;
--error 1031
ALTER SYSTEM DELETE SERVICE test_service;
#########oracle 允许有alter system权限的用户做 service name 运维命令#######
connection test_oracle_conn;
grant alter system to usr_test;
ob_connect(test_oracle_conn_usr1, ob1.z1.obs0, usr_test@test_tenant_oracle, 123, usr_test, , USE_OB_CONNECTOR);
connection test_oracle_conn_usr1;
ALTER SYSTEM DELETE SERVICE test_service;
connection test_oracle_conn;
SELECT SERVICE_NAME, SERVICE_STATUS FROM SYS.DBA_OB_SERVICES;
ALTER SYSTEM CREATE SERVICE test_SERVICE;
SELECT SERVICE_NAME, SERVICE_STATUS FROM SYS.DBA_OB_SERVICES;
#########oracle 不允许有alter system权限但通过service_name登录的用户做 service name 运维命令和 SO/FO #######
ob1.mysql alter system set_tp tp_name = ERRSIM_MOCK_SERVICE_NAME, error_code = 4018, frequency = 1;
ob_connect(test_oracle_conn_2, ob1.z1.obs0, SYS@test_tenant_oracle, , SYS, , USE_OB_CONNECTOR);
connection test_oracle_conn_2;
--error 600
ALTER SYSTEM STOP SERVICE test_service;
--error 600
ALTER SYSTEM CREATE SERVICE test_service_2;
--error 600
ALTER SYSTEM SWITCHOVER TO STANDBY;
--error 600
ALTER SYSTEM SWITCHOVER TO PRIMARY;
--error 600
ALTER SYSTEM ACTIVATE STANDBY;
ob1.mysql alter system set_tp tp_name = ERRSIM_MOCK_SERVICE_NAME, error_code = 4018, frequency = 0;

ob1.mysql ALTER SYSTEM STOP SERVICE test_service tenant = test_tenant_mysql;
ob1.mysql ALTER SYSTEM STOP SERVICE TEST_SERVICE tenant = test_tenant_oracle;
ob1.mysql ALTER SYSTEM DELETE SERVICE tEst_Service tenant = test_tenant_mysql;
ob1.mysql ALTER SYSTEM DELETE SERVICE test_service tenant = test_tenant_oracle;
ob1.mysql ALTER SYSTEM CREATE SERVICE service_mysql tenant = test_tenant_mysql;
ob1.mysql ALTER SYSTEM CREATE SERVICE service_oracle tenant = test_tenant_oracle;
ob1.z1.obs0.check_rs_log_until_success "refresh service_names.*service_oracle";
ob1.z1.obs0.check_rs_log_until_success "refresh service_names.*service_mysql";
connect(sys_conn, $proxy_ip, root@sys,,oceanbase, $proxy_port);
# 基础的列验证以及缓存验证
alter system change tenant tenant_id = 1001;
SELECT SERVICE_NAME_ID, SERVICE_NAME, SERVICE_STATUS FROM OCEANBASE.__ALL_SERVICE;
alter system change tenant tenant_id = 1003;
SELECT SERVICE_NAME_ID, SERVICE_NAME, SERVICE_STATUS FROM OCEANBASE.__ALL_SERVICE;
alter system change tenant tenant_id = 1;
SELECT SERVICE_NAME_ID, SERVICE_NAME, SERVICE_STATUS FROM OCEANBASE.CDB_OB_SERVICES;

connect(test_mysql_conn, $proxy_ip, root@test_tenant_mysql,,oceanbase, $proxy_port);
SELECT SERVICE_NAME_ID, SERVICE_NAME, SERVICE_STATUS FROM OCEANBASE.DBA_OB_SERVICES;

ob_connect(test_oracle_conn, ob1.z1.obs0, SYS@test_tenant_oracle, , SYS, , USE_OB_CONNECTOR);
connection test_oracle_conn;
SELECT SERVICE_NAME_ID, SERVICE_NAME, SERVICE_STATUS FROM SYS.DBA_OB_SERVICES;

connect(sys_conn, $proxy_ip, root@sys,,oceanbase, $proxy_port);
connection sys_conn;
alter system change tenant tenant_id = 1001;
--disable_query_log
--error 1406
INSERT INTO __all_service (tenant_id, service_name_id, service_name, service_status) value (1002, 2, 'service_mysql__service_mysql__service_mysql__service_mysql__12345', 'STARTED');
--enable_query_log