# check progressive_merge_round increased when inner table add column
ob1=OBI(cluster=1,proxy_num=0,version=4_3_2_0);
ob1.reboot;

let $last_progressive_merge_round=deploy_get_value(ob1.select select progressive_merge_round a from __all_virtual_core_all_table where table_name='__all_table' and tenant_id=1, a, 1);

ob1.mysql alter system begin upgrade;
ob1.mysql alter system begin rolling upgrade;

ob1.force_stop;
ob1.upgrade;
ob1.nstart;

ob1.check_until_timeout select count(*) from oceanbase.__all_server where start_service_time <= 0 or status='INACTIVE',0,180;
ob1.check_until_timeout select count(1) as unsync_cnt from GV\$OB_LOG_STAT where in_sync = 'NO',0,600;
source include/check_schema_sync_for_restart.inc;

ob1.mysql alter system end rolling upgrade;
ob1.mysql alter system run upgrade job 'UPGRADE_ALL';
ob1.check_until_timeout select job_status from __all_rootservice_job where job_type='UPGRADE_ALL' order by job_id desc limit 1, SUCCESS, 600;
ob1.mysql alter system end upgrade;

let $current_progressive_merge_round_minus_1=deploy_get_value(ob1.select select progressive_merge_round - 1 as a from __all_virtual_core_all_table where table_name='__all_table' and tenant_id=1, a, 1);

if ($current_progressive_merge_round_minus_1 != $last_progressive_merge_round)
{
  --echo progressive_merge_round not changed
  --exit
}
