# CASE_OWNER:
#    @jingyu.cr
# CASE_DESC:
#    This cas eis to test replicate replica tasl
#    If a server is not alive, then migrate unit on that server, replicate task will be generated

ob1=OBI(cluster=1:1:2,proxy_num=0,init_unit_cpu=0);
source include/mini_ob_config.inc;
ob1.set extra_config=$mini_ob_config;
ob1.reboot;

ob1.mysql alter system set debug_sync_timeout = '1000s';
ob1.mysql alter system set enable_rereplication = true;
ob1.mysql alter system set server_permanent_offline_time = '3600s';

let $proxy_ip = deploy_get_value(ob1.z1.obs0.ip);
let $proxy_port = deploy_get_value(ob1.z1.obs0.mysql_port);
let $z3_obs0_ip = deploy_get_value(ob1.z3.obs0.ip);
let $z3_obs1_ip = deploy_get_value(ob1.z3.obs1.ip);
let $z3_obs0_port = deploy_get_value(ob1.z3.obs0.port);
let $z3_obs1_port = deploy_get_value(ob1.z3.obs1.port);
let $z3_obs0 = $z3_obs0_ip:$z3_obs0_port;
let $z3_obs1 = $z3_obs1_ip:$z3_obs1_port;

connect(sys_conn, $proxy_ip, root@sys,,oceanbase, $proxy_port);

# create tenant with unit_num = 2, construct $z3_cur_1, $z3_cur_2, $z3_cur_free
source include/create_unit_config.inc;
ob1.mysql CREATE RESOURCE POOL tenant_pool UNIT = "2c2g", UNIT_NUM = 1, ZONE_LIST = ('z1', 'z2', 'z3');
ob1.mysql CREATE TENANT tenant_for_replicate RESOURCE_POOL_LIST=('tenant_pool'), LOCALITY = "F@z1, F@z2, F@z3", PRIMARY_ZONE = "z1" SET ob_tcp_invited_nodes='%';
let $tenant_id = deploy_get_value(ob1.select SELECT tenant_id FROM oceanbase.DBA_OB_TENANTS WHERE tenant_name = "tenant_for_replicate", tenant_id, 1);
let $meta_tenant_id = deploy_get_value(ob1.select select tenant_id - 1 as meta_tenant_id from oceanbase.DBA_OB_TENANTS where tenant_name = "tenant_for_replicate", meta_tenant_id, 1);
let $resource_pool_id = deploy_get_value(ob1.select SELECT resource_pool_id FROM oceanbase.__all_resource_pool WHERE tenant_id = $tenant_id, resource_pool_id, 1);
let $z3_unit_id_1 = deploy_get_value(ob1.select SELECT unit_id FROM oceanbase.DBA_OB_UNITS WHERE resource_pool_id = $resource_pool_id AND zone = 'z3' order by unit_id desc limit 1, unit_id, 1);
let $z3_cur_ip_1 = deploy_get_value(ob1.select SELECT svr_ip FROM oceanbase.DBA_OB_UNITS WHERE unit_id = $z3_unit_id_1, svr_ip, 1);
let $z3_cur_port_1 = deploy_get_value(ob1.select SELECT svr_port FROM oceanbase.DBA_OB_UNITS WHERE unit_id = $z3_unit_id_1, svr_port, 1);
let $z3_cur_1 = $z3_cur_ip_1:$z3_cur_port_1;

# check nothing happened if do nothing after server not alive
let $ls_cnt = deploy_get_value(ob1.select select count(*) as ls_cnt from oceanbase.CDB_OB_LS_LOCATIONS where (tenant_id = $tenant_id or tenant_id = $meta_tenant_id) and role = "LEADER" and member_list like '%$z3_cur_1%', ls_cnt, 1);
ob1.mysql alter tenant tenant_for_replicate set primary_zone = "z1;z2;z3";
ob1.check_until_timeout select count(*) c from oceanbase.CDB_OB_LS_LOCATIONS where role like "%LEADER%" and tenant_id in ($tenant_id, $meta_tenant_id) and zone = 'z3', 0, 60;

--disable_all_result_log
if ($z3_cur_1 == $z3_obs0)
{
  ob1.z3.obs0.force_stop;
}
if ($z3_cur_1 == $z3_obs1)
{
  ob1.z3.obs1.force_stop;
}
--enable_all_result_log
ob1.check_until_timeout select count(*) = 1 from oceanbase.DBA_OB_SERVERS where svr_ip = '$z3_cur_ip_1' and svr_port = $z3_cur_port_1 and status != 'ACTIVE', 1, 30; 
select count(*) = 0 as no_task_generated from oceanbase.CDB_OB_LS_REPLICA_TASKS;

# check replicate task is generated if migrate unit
ob1.mysql set ob_global_debug_sync = 'BEFORE_DELETE_DRTASK_FROM_INNER_TABLE wait_for signal_for_delete_drtask';
sleep 5;
if ($z3_cur_1 == $z3_obs0)
{
  --disable_query_log
  eval ALTER SYSTEM MIGRATE UNIT $z3_unit_id_1 DESTINATION "$z3_obs1";
  --enable_query_log
  ob1.check_until_timeout select count(*) = $ls_cnt from oceanbase.CDB_OB_LS_REPLICA_TASKS, 1, 30;
  select tenant_id, ls_id, task_type, target_paxos_replica_number, source_paxos_replica_number, comment from oceanbase.CDB_OB_LS_REPLICA_TASKS;
  ob1.mysql set ob_global_debug_sync = 'now signal signal_for_delete_drtask';
  ob1.check_until_timeout select count(*) = $ls_cnt from oceanbase.DBA_OB_ROOTSERVICE_EVENT_HISTORY where event = "finish_migrate_ls_replica" and extra_info = "replicate to unit task", 1, 60;
  ob1.check_until_timeout select count(*) = $ls_cnt from oceanbase.CDB_OB_LS_LOCATIONS where (tenant_id = $tenant_id or tenant_id = $meta_tenant_id) and role = "LEADER" and member_list like '%$z3_obs1%' and member_list not like '%$z3_obs0%', 1, 60;
}
if ($z3_cur_1 == $z3_obs1)
{
  --disable_query_log
  eval ALTER SYSTEM MIGRATE UNIT $z3_unit_id_1 DESTINATION "$z3_obs0";
  --enable_query_log
  ob1.check_until_timeout select count(*) = $ls_cnt from oceanbase.CDB_OB_LS_REPLICA_TASKS, 1, 30;
  select tenant_id, ls_id, task_type, target_paxos_replica_number, source_paxos_replica_number, comment from oceanbase.CDB_OB_LS_REPLICA_TASKS;
  ob1.mysql set ob_global_debug_sync = 'now signal signal_for_delete_drtask';
  ob1.check_until_timeout select count(*) = $ls_cnt from oceanbase.DBA_OB_ROOTSERVICE_EVENT_HISTORY where event = "finish_migrate_ls_replica" and extra_info = "replicate to unit task", 1, 60;
  ob1.check_until_timeout select count(*) = $ls_cnt from oceanbase.CDB_OB_LS_LOCATIONS where (tenant_id = $tenant_id or tenant_id = $meta_tenant_id) and role = "LEADER" and member_list like '%$z3_obs0%' and member_list not like '%$z3_obs1%', 1, 60;
}
