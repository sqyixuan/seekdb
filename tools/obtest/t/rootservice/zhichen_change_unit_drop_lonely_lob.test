# owner: zhichen
# description: test drop lonely lob aux table by ob_admin

ob1=OBI(cluster=2:2:2,proxy_num=1);
ob1.reboot;
sleep 10;

let $work_dir=deploy_get_value(ob1.z1.obs0.workdir);

let $ip = deploy_get_value(ob1.proxy0.ip);
let $port = deploy_get_value(ob1.proxy0.port);
ob_connect(sys_conn, $ip, root@sys,,, $port);
connection sys_conn;

# create mysql tenant
eval CREATE RESOURCE UNIT unit_1 MAX_CPU 2, MEMORY_SIZE '4G';
eval CREATE RESOURCE POOL pool_1 UNIT = 'unit_1', UNIT_NUM = 1;
eval CREATE TENANT mysql RESOURCE_POOL_LIST = ('pool_1'), primary_zone = 'z1' set ob_tcp_invited_nodes = '%';

let $mysql_tenant_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name = 'mysql', tenant_id, 1);
ob_connect(conn_mysql,$ip,root@mysql,,,$port);
connection conn_mysql;
ALTER SYSTEM SET _parallel_ddl_control = 'DROP_TABLE:OFF';

use test;
# 1. create table with lob column
create table t1(c1 longtext);
insert  /*+ query_timeout(10000000000) */ into t1 select repeat('1', 1024 * 1024) from table(generator(10));
insert  /*+ query_timeout(10000000000) */ into t1 select repeat('1', 100 * 1024) from table(generator(100));
insert  /*+ query_timeout(10000000000) */ into t1 select repeat('1', 1 * 1024) from table(generator(100));

let $data_table_id = query_get_value(select table_id from oceanbase.__all_table where table_name='t1', table_id, 1);
let $lob_meta_table_id = query_get_value(select table_id from oceanbase.__all_table where data_table_id=$data_table_id and table_name like '%AUX_LOB_META%', table_id, 1);
let $lob_piece_table_id = query_get_value(select table_id from oceanbase.__all_table where data_table_id=$data_table_id and table_name like '%AUX_LOB_PIECE%', table_id, 1);

# 2. query and check table info
#  check __all_table_history
eval select count(*) from oceanbase.__all_table_history where table_id=$data_table_id;
eval select count(*) from oceanbase.__all_table_history where table_id=$lob_meta_table_id;
eval select count(*) from oceanbase.__all_table_history where table_id=$lob_piece_table_id;
# check __all_table
eval select count(*) from oceanbase.__all_table where table_id=$data_table_id;
eval select count(*) from oceanbase.__all_table where table_id=$lob_meta_table_id;
eval select count(*) from oceanbase.__all_table where table_id=$lob_piece_table_id;
# check tablet info
eval select count(*) from oceanbase.DBA_OB_TABLE_LOCATIONS where table_id=$data_table_id;
eval select count(*) from oceanbase.DBA_OB_TABLE_LOCATIONS where table_id=$lob_meta_table_id;
eval select count(*) from oceanbase.DBA_OB_TABLE_LOCATIONS where table_id=$lob_piece_table_id;

# expected empty result
select count(*) from ((select data_table_id from oceanbase.__all_table where data_table_id is not null and data_table_id != 0) minus (select table_id from oceanbase.__all_table));

# 3. force drop, but not sucess
sleep 10;
ob1.z1.obs0.sh cd $work_dir/; ./etc/ob_admin -S run/rpc.sock force_drop_lonely_lob_aux_table $mysql_tenant_id:$data_table_id:$lob_meta_table_id:$lob_piece_table_id;
connection sys_conn;
select module, event, name1, value1, name2, value2, name4, value4, name5, value5, name6, value6 from oceanbase.__all_rootservice_event_history where module = 'ddl scheduler' and event='force drop lonely lob table';
connection conn_mysql;

# 4. check
#  check __all_table_history
eval select count(*) from oceanbase.__all_table_history where table_id=$data_table_id;
eval select count(*) from oceanbase.__all_table_history where table_id=$lob_meta_table_id;
eval select count(*) from oceanbase.__all_table_history where table_id=$lob_piece_table_id;
# check __all_table
eval select count(*) from oceanbase.__all_table where table_id=$data_table_id;
eval select count(*) from oceanbase.__all_table where table_id=$lob_meta_table_id;
eval select count(*) from oceanbase.__all_table where table_id=$lob_piece_table_id;
# check tablet info
eval select count(*) from oceanbase.DBA_OB_TABLE_LOCATIONS where table_id=$data_table_id;
eval select count(*) from oceanbase.DBA_OB_TABLE_LOCATIONS where table_id=$lob_meta_table_id;
eval select count(*) from oceanbase.DBA_OB_TABLE_LOCATIONS where table_id=$lob_piece_table_id;
# expected empty result
select count(*) from ((select data_table_id from oceanbase.__all_table where data_table_id is not null and data_table_id != 0) minus (select table_id from oceanbase.__all_table));

# 5. errsim
connection sys_conn;
alter system set_tp tp_no = 525 , error_code = 4016, frequency = 1;
sleep 10;
connection conn_mysql;
use test;
drop table t1;

# 6. query and check table info
#  check __all_table_history
eval select count(*) from oceanbase.__all_table_history where table_id=$data_table_id;
eval select count(*) from oceanbase.__all_table_history where table_id=$lob_meta_table_id;
eval select count(*) from oceanbase.__all_table_history where table_id=$lob_piece_table_id;
# check __all_table
eval select count(*) from oceanbase.__all_table where table_id=$data_table_id;
eval select count(*) from oceanbase.__all_table where table_id=$lob_meta_table_id;
eval select count(*) from oceanbase.__all_table where table_id=$lob_piece_table_id;
# check tablet info
eval select count(*) from oceanbase.DBA_OB_TABLE_LOCATIONS where table_id=$data_table_id;
eval select count(*) from oceanbase.DBA_OB_TABLE_LOCATIONS where table_id=$lob_meta_table_id;
eval select count(*) from oceanbase.DBA_OB_TABLE_LOCATIONS where table_id=$lob_piece_table_id;
# expected non-empty result
select count(*) from ((select data_table_id from oceanbase.__all_table where data_table_id is not null and data_table_id != 0) minus (select table_id from oceanbase.__all_table));

# 7. change unit_num 2
connection sys_conn;
alter resource tenant mysql unit_num = 2;
sleep 10;
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_BALANCE_JOBS where tenant_id=$mysql_tenant_id, 0, 180;
ob1.check_until_timeout select count(*) from oceanbase.DBA_OB_TENANT_JOBS where tenant_id=$mysql_tenant_id and JOB_TYPE = 'ALTER_RESOURCE_TENANT_UNIT_NUM' and JOB_STATUS != 'SUCCESS', 0, 180;
sleep 10;
connection conn_mysql;

# 8.1 create partition table with multi log stream
use test;
create table t2(pk int AUTO_INCREMENT, c1 longtext, primary key(pk)) partition by hash(pk) partitions 16;
insert  /*+ query_timeout(10000000000) */ into t2(c1) select repeat('1', 1024 * 1024) from table(generator(10));
insert  /*+ query_timeout(10000000000) */ into t2(c1) select repeat('1', 100 * 1024) from table(generator(100));
insert  /*+ query_timeout(10000000000) */ into t2(c1) select repeat('1', 1 * 1024) from table(generator(100));
# 8.2 query table id of t2
let $t2_data_table_id = query_get_value(select table_id from oceanbase.__all_table where table_name='t2', table_id, 1);
let $t2_lob_meta_table_id = query_get_value(select table_id from oceanbase.__all_table where data_table_id=$t2_data_table_id and table_name like '%AUX_LOB_META%', table_id, 1);
let $t2_lob_piece_table_id = query_get_value(select table_id from oceanbase.__all_table where data_table_id=$t2_data_table_id and table_name like '%AUX_LOB_PIECE%', table_id, 1);
#  check __all_table_history
eval select count(*) from oceanbase.__all_table_history where table_id=$t2_data_table_id;
eval select count(*) from oceanbase.__all_table_history where table_id=$t2_lob_meta_table_id;
eval select count(*) from oceanbase.__all_table_history where table_id=$t2_lob_piece_table_id;
# check __all_table
eval select count(*) from oceanbase.__all_table where table_id=$t2_data_table_id;
eval select count(*) from oceanbase.__all_table where table_id=$t2_lob_meta_table_id;
eval select count(*) from oceanbase.__all_table where table_id=$t2_lob_piece_table_id;
# check tablet info, include ls count
eval select count(*), count(distinct ls_id) from oceanbase.DBA_OB_TABLE_LOCATIONS where table_id=$t2_data_table_id and role = 'leader';
eval select count(*), count(distinct ls_id) from oceanbase.DBA_OB_TABLE_LOCATIONS where table_id=$t2_lob_meta_table_id and role = 'leader';
eval select count(*), count(distinct ls_id) from oceanbase.DBA_OB_TABLE_LOCATIONS where table_id=$t2_lob_piece_table_id and role = 'leader';

# 8.3 drop t2, but not drop lob aux table of t2
drop table t2;
eval select count(*) from oceanbase.__all_table where table_id=$t2_data_table_id;
eval select count(*) from oceanbase.__all_table where table_id=$t2_lob_meta_table_id;
eval select count(*) from oceanbase.__all_table where table_id=$t2_lob_piece_table_id;
eval select count(*), count(distinct ls_id) from oceanbase.DBA_OB_TABLE_LOCATIONS where table_id=$t2_data_table_id and role = 'leader';
eval select count(*), count(distinct ls_id) from oceanbase.DBA_OB_TABLE_LOCATIONS where table_id=$t2_lob_meta_table_id and role = 'leader';
eval select count(*), count(distinct ls_id) from oceanbase.DBA_OB_TABLE_LOCATIONS where table_id=$t2_lob_piece_table_id and role = 'leader';

# 8.4 check table info of t1
#  check __all_table_history
eval select count(*) from oceanbase.__all_table_history where table_id=$data_table_id;
eval select count(*) from oceanbase.__all_table_history where table_id=$lob_meta_table_id;
eval select count(*) from oceanbase.__all_table_history where table_id=$lob_piece_table_id;
# check __all_table
eval select count(*) from oceanbase.__all_table where table_id=$data_table_id;
eval select count(*) from oceanbase.__all_table where table_id=$lob_meta_table_id;
eval select count(*) from oceanbase.__all_table where table_id=$lob_piece_table_id;
# check tablet info
eval select count(*) from oceanbase.DBA_OB_TABLE_LOCATIONS where table_id=$data_table_id;
eval select count(*) from oceanbase.DBA_OB_TABLE_LOCATIONS where table_id=$lob_meta_table_id;
eval select count(*) from oceanbase.DBA_OB_TABLE_LOCATIONS where table_id=$lob_piece_table_id;
# expected non-empty result
select count(*) from ((select data_table_id from oceanbase.__all_table where data_table_id is not null and data_table_id != 0) minus (select table_id from oceanbase.__all_table));

# 9. change unit_num 1
# 当unit_num 从 2->1时, 缩容unit的同时会删除日志流, 这个日志流正好是残留的LOB Tablet所在的日志流.
# 而当日志流删除时, 不会检查残留的LOB, 会顺带删除掉. 这样就会出现: schema存在LOB表，但是Tablet被删除的场景
connection sys_conn;
alter resource tenant mysql unit_num = 1;
sleep 10;
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_BALANCE_JOBS where tenant_id=$mysql_tenant_id, 0, 180;
ob1.check_until_timeout select count(*) from oceanbase.DBA_OB_TENANT_JOBS where tenant_id=$mysql_tenant_id and JOB_TYPE = 'ALTER_RESOURCE_TENANT_UNIT_NUM' and JOB_STATUS != 'SUCCESS', 0, 180;
sleep 10;

connection conn_mysql;
# 10.1 check table info of t1
#  check __all_table_history
eval select count(*) from oceanbase.__all_table_history where table_id=$data_table_id;
eval select count(*) from oceanbase.__all_table_history where table_id=$lob_meta_table_id;
eval select count(*) from oceanbase.__all_table_history where table_id=$lob_piece_table_id;
# check __all_table
eval select count(*) from oceanbase.__all_table where table_id=$data_table_id;
eval select count(*) from oceanbase.__all_table where table_id=$lob_meta_table_id;
eval select count(*) from oceanbase.__all_table where table_id=$lob_piece_table_id;
# check tablet info
# 当日志流删除时, 非分区表t1的LOB tablet都被删除了, 所欲预期都是0
eval select count(*) from oceanbase.DBA_OB_TABLE_LOCATIONS where table_id=$data_table_id;
eval select count(*) from oceanbase.DBA_OB_TABLE_LOCATIONS where table_id=$lob_meta_table_id;
eval select count(*) from oceanbase.DBA_OB_TABLE_LOCATIONS where table_id=$lob_piece_table_id;

# 10.2 check table info of t2
#  check __all_table_history
eval select count(*) from oceanbase.__all_table_history where table_id=$t2_data_table_id;
eval select count(*) from oceanbase.__all_table_history where table_id=$t2_lob_meta_table_id;
eval select count(*) from oceanbase.__all_table_history where table_id=$t2_lob_piece_table_id;
# check __all_table
eval select count(*) from oceanbase.__all_table where table_id=$t2_data_table_id;
eval select count(*) from oceanbase.__all_table where table_id=$t2_lob_meta_table_id;
eval select count(*) from oceanbase.__all_table where table_id=$t2_lob_piece_table_id;
# check tablet info, include ls count
# 当日志流删除时, 分区表t2的部分LOB tablet都被删除
eval select count(*), count(distinct ls_id) from oceanbase.DBA_OB_TABLE_LOCATIONS where table_id=$t2_data_table_id and role = 'leader';
eval select count(*), count(distinct ls_id) from oceanbase.DBA_OB_TABLE_LOCATIONS where table_id=$t2_lob_meta_table_id and role = 'leader';
eval select count(*), count(distinct ls_id) from oceanbase.DBA_OB_TABLE_LOCATIONS where table_id=$t2_lob_piece_table_id  and role = 'leader';

# expected non-empty result
select count(*) from ((select data_table_id from oceanbase.__all_table where data_table_id is not null and data_table_id != 0) minus (select table_id from oceanbase.__all_table));

# 11. force drop lob aux table t1 and t2
sleep 5;
ob1.z1.obs0.sh cd $work_dir/; ./etc/ob_admin -S run/rpc.sock force_drop_lonely_lob_aux_table $mysql_tenant_id:$data_table_id:$lob_meta_table_id:$lob_piece_table_id;
sleep 5;
ob1.z1.obs0.sh cd $work_dir/; ./etc/ob_admin -S run/rpc.sock force_drop_lonely_lob_aux_table $mysql_tenant_id:$t2_data_table_id:$t2_lob_meta_table_id:$t2_lob_piece_table_id;
connection sys_conn;
select module, event, name1, value1, name2, value2, name4, value4, name5, value5, name6, value6 from oceanbase.__all_rootservice_event_history where module = 'ddl scheduler' and event='force drop lonely lob table';

connection conn_mysql;
# 12.1 check table info of t1
