# CASE_OWNER:
#    @jingyu.cr
# CASE_DESC:
#    This case is aimed to test create ls when 2F1A with 1F down
#
#    1. create tenant with 2F1A and unit_num = 1
#    2. shut down 1F
#    3. create duplicate table trigger create new log stream
#    4. wait ls finish creating
#


#######################################################################
#                        create inital objects
#######################################################################

ob1=OBI(cluster=1:2:1,proxy_num=0,init_unit_cpu=0,asvr_num=1);
source include/mini_ob_config.inc;
ob1.set extra_config=$mini_ob_config;
ob1.z2.obs1.set status=disable;
ob1.reboot;
sleep 3;

let $arb_extra_conf = "ob_startup_mode=arbitration,cpu_count=1,memory_limit=1G,__easy_memory_limit=256M";

ob1.mysql alter system set debug_sync_timeout = '1000s';
ob1.mysql ALTER SYSTEM SET enable_rebalance = 'false';
ob1.mysql ALTER SYSTEM SET enable_rereplication = 'true';

let $proxy_ip = deploy_get_value(ob1.z1.obs0.ip);
let $proxy_port = deploy_get_value(ob1.z1.obs0.mysql_port);
connect(sys_conn, $proxy_ip, root@sys,,oceanbase, $proxy_port);

let $proxy_ip2 = deploy_get_value(ob1.z3.obs0.ip);
let $proxy_port2 = deploy_get_value(ob1.z3.obs0.mysql_port);
connect(sys_conn2, $proxy_ip2, root@sys,,oceanbase, $proxy_port2);

# 获取仲裁server的ip、port
let $arb_svr_ip= deploy_get_value(ob1.asvr0.ip);
let $arb_svr_port= deploy_get_value(ob1.asvr0.port);
# add arbitration service, mytest.jar已经为本集群做了这一步
ob1.check_until_timeout select count(*) as cnt from oceanbase.DBA_OB_ARBITRATION_SERVICE where arbitration_service = "$arb_svr_ip:$arb_svr_port", 1, 5;

--echo =================================================
--echo               create tenant
--echo =================================================

# create new tenant mysql
source include/create_unit_config.inc;
ob1.mysql CREATE RESOURCE POOL tenant_pool UNIT = "2c2g", UNIT_NUM = 1, ZONE_LIST = ('z1', 'z2');
ob1.mysql CREATE TENANT mysql RESOURCE_POOL_LIST=('tenant_pool'), LOCALITY = "F@z1, F@z2", PRIMARY_ZONE = "z1", enable_arbitration_service = true SET ob_tcp_invited_nodes='%';

let $tenant_id = deploy_get_value(ob1.select SELECT tenant_id FROM oceanbase.DBA_OB_TENANTS WHERE tenant_name = "mysql", tenant_id, 1);
let $meta_tenant_id = deploy_get_value(ob1.select select tenant_id - 1 as meta_tenant_id from oceanbase.DBA_OB_TENANTS where tenant_name = "mysql", meta_tenant_id, 1);
let $resource_pool_id = deploy_get_value(ob1.select SELECT resource_pool_id FROM oceanbase.__all_resource_pool WHERE tenant_id = $tenant_id, resource_pool_id, 1);

# get servers' addr in z1, z2 and z3
let $z1_dst_ip0 = deploy_get_value(ob1.z1.obs0.ip);
let $z1_dst_port0 = deploy_get_value(ob1.z1.obs0.port);
let $z1_dst0 = $z1_dst_ip0:$z1_dst_port0;
let $z2_dst_ip0 = deploy_get_value(ob1.z2.obs0.ip);
let $z2_dst_port0 = deploy_get_value(ob1.z2.obs0.port);
let $z2_dst0 = $z2_dst_ip0:$z2_dst_port0;
let $z2_dst_ip1 = deploy_get_value(ob1.z2.obs1.ip);
let $z2_dst_port1 = deploy_get_value(ob1.z2.obs1.port);
let $z2_dst1 = $z2_dst_ip1:$z2_dst_port1;

--echo ==================================================
--echo               get server info in z2
--echo ==================================================
# get mysql's unit info in z2
let $unit_id = deploy_get_value(ob1.select SELECT unit_id FROM oceanbase.DBA_OB_UNITS WHERE resource_pool_id = $resource_pool_id AND zone = 'z2', unit_id, 1);
let $ip = deploy_get_value(ob1.select SELECT svr_ip FROM oceanbase.DBA_OB_UNITS WHERE unit_id = $unit_id, svr_ip, 1);
let $port = deploy_get_value(ob1.select SELECT svr_port FROM oceanbase.DBA_OB_UNITS WHERE unit_id = $unit_id, svr_port, 1);
let $z2_cur = $ip:$port;

--echo ==================================================
--echo             shut down observer in z2
--echo ==================================================
connection sys_conn;
if ($z2_cur != $z2_dst1)
{
ob1.z2.obs0.force_stop;
ob1.check_until_timeout select count(*) as cnt from oceanbase.DBA_OB_SERVERS where zone = 'z2' and status = 'INACTIVE', 1, 30;
}
if ($z2_cur != $z2_dst0)
{
ob1.z2.obs1.force_stop;
ob1.check_until_timeout select count(*) as cnt from oceanbase.DBA_OB_SERVERS where zone = 'z2' and status = 'INACTIVE', 1, 30;
}

--echo ==================================================
--echo                  add debug sync
--echo ==================================================
connection sys_conn;
set ob_global_debug_sync = 'BEFORE_PROCESS_AFTER_HAS_MEMBER_LIST wait_for signal';

--echo ==================================================
--echo             create duplicate log stream
--echo ==================================================
ob_connect(conn_mysql, ob1.z1.obs0, root@mysql, , test, , USE_MYSQL_CONNECTOR);
connection conn_mysql;
ob1.check_until_timeout select count(*) as dup_ls_cnt from oceanbase.CDB_OB_LS where flag like '%duplicate%', 0, 20;
send create table dup_t1(c1 int) duplicate_scope = 'cluster';

--echo ==================================================
--echo          wait __all_ls_status table updated
--echo ==================================================
connection sys_conn;
ob1.check_until_timeout select count(*) as dup_ls_cnt from oceanbase.CDB_OB_LS where flag like '%duplicate%', 1, 20;
let $ls_id = deploy_get_value(ob1.select select ls_id from oceanbase.CDB_OB_LS where flag like '%duplicate%', ls_id, 1);
ob1.check_until_timeout select count(*) as cnt from oceanbase.__all_virtual_ls_status where tenant_id = $tenant_id and ls_id = $ls_id and init_member_list != '', 1, 200;

--echo ==================================================
--echo                  shut down arb server
--echo ==================================================
ob1.asvr0.force_stop;
sleep 5;
ob1.asvr0.nstart;
sleep 2;

--echo ==================================================
--echo          wait duplicate log stream created
--echo ==================================================
connection sys_conn;
ob1.mysql set ob_global_debug_sync = 'now signal signal';
ob1.check_until_timeout select count(*) as normal_dup_ls_cnt from oceanbase.CDB_OB_LS where tenant_id = $tenant_id and ls_id = $ls_id and flag like '%duplicate%' and status = 'NORMAL', 1, 120;
ob1.check_until_timeout select count(*) as ls_cnt from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id = $tenant_id and ls_id = $ls_id and paxos_replica_number = 1 and role = 'LEADER' and member_list like "%$z1_dst0%" and member_list not like "%$z2_dst0%" and member_list not like "%$z2_dst1%", 1, 30;

--echo ==================================================
--echo       raise z2-obs and wait replica added
--echo ==================================================
ob1.z2.obs1.set extra_config=$mini_ob_config;
ob1.z2.obs1.set status=enable;
ob1.z2.obs1.start;

ob1.check_until_timeout select count(*) as cnt from oceanbase.__all_virtual_server_schema_info as a join oceanbase.__all_virtual_server_schema_info as b on a.tenant_id = b.tenant_id  where (a.refreshed_schema_version != b.refreshed_schema_version or a.refreshed_schema_version % 8 != 0) and a.tenant_id = 1, 0, 120;
ob1.z2.obs1.check_log_until_success -c "weak read service thread start";
ob1.z2.obs1.add;
ob1.check_until_timeout SELECT COUNT(*) c FROM DBA_OB_SERVERS WHERE START_SERVICE_TIME > 0, 3, 200;
set @@session.ob_query_timeout = 100000000000;
SELECT COUNT(*) as server_count FROM DBA_OB_SERVERS WHERE STATUS = "ACTIVE";
ob1.mysql alter system set server_permanent_offline_time = '20s';
sleep 20;
ob1.check_until_timeout select count(*) as ls_cnt from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id = $tenant_id and ls_id = $ls_id and paxos_replica_number = 2 and role = 'LEADER' and member_list like "%$z1_dst0%" and member_list like "%$z2_dst1%", 1, 200;
