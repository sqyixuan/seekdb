##########################
#owner :msy164651
# 测试点：
##########################

ob1=OBI(cluster=3:3:3,proxy_num=0);
source include/mini_ob_config.inc;
ob1.set extra_config=$mini_ob_config;
ob1.reboot;

ob_connect(conn_sys, ob1.z1.obs0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);

connection conn_sys;
ob1.mysql alter system set debug_sync_timeout = '1000s';
ob1.mysql alter system set _transfer_start_trans_timeout = '60s';
ob1.mysql alter system set enable_rebalance=false;

set @@session.ob_query_timeout = 1000000000;

#mysql tenant
eval CREATE RESOURCE UNIT unit_1 MAX_CPU 1, MEMORY_SIZE '2G';
eval CREATE RESOURCE POOL pool_1 UNIT = 'unit_1', UNIT_NUM = 1;
eval CREATE TENANT mysql RESOURCE_POOL_LIST = ('pool_1'), primary_zone='z1,z2,z3' set ob_tcp_invited_nodes='%';
let $tenant_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name = 'mysql', tenant_id, 1);
let $meta_tenant_id = deploy_get_value(ob1.select select tenant_id -1 as tenant_id from oceanbase.__all_tenant where tenant_name = 'mysql', tenant_id, 1);
ob1.mysql alter system set ls_gc_delay_time = '0s' tenant='mysql';
ob1.mysql alter system set _transfer_task_retry_interval = '0s' tenant = 'mysql';
ob_connect(conn_mysql, ob1.z1.obs1, root@mysql, , test, , USE_MYSQL_CONNECTOR);
connection conn_mysql;
let $count = 0;
while ($count < 10) 
{
eval create table non_partition_$count(pk int primary key);
inc $count;
}

let $count = 0;
while ($count < 5) 
{
eval create table one_partition_$count(pk int primary key) partition by hash(pk) partitions 10;
inc $count;
}
let $count = 0;
while ($count < 5)
{
eval create table two_partition_$count (c1 int, c2 int, c3 int, c4 int) partition by range(c1) subpartition by range(c2) ( partition t1rp0 values less than (100) ( subpartition t1rp0sp0 values less than (100),  subpartition t1rp0sp1 values less than (200), subpartition t1rp0sp2 values less than (300), subpartition t1rp0sp3 values less than (400)), partition t1rp1 values less than (200) (subpartition t1rp1sp0 values less than (100),subpartition t1rp1sp1 values less than (200),subpartition t1rp1sp2 values less than (300),subpartition t1rp1sp3 values less than (400)));
inc $count;
}

#验证存在需要删除的unit_group和需要创建的unit_group
ob1.mysql set ob_global_debug_sync = 'BEFORE_TENANT_BALANCE_SERVICE wait_for signal';
ob1.mysql  ALTER RESOURCE TENANT mysql UNIT_NUM = 3;
ob1.mysql  ALTER RESOURCE TENANT mysql UNIT_NUM = 2;
#预期任务应该在一个新的unit_group里面
ob1.mysql set ob_global_debug_sync = 'now signal signal';
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_balance_job_history, 2, 100;
--disable_query_log
ob1.mysql_p select task_type, src_ls,dest_ls, ls_group_id from oceanbase.__all_virtual_balance_task_history  order by create_time;
--enable_query_log


ob1.mysql alter tenant mysql set primary_zone = 'z1';
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_balance_job, 1, 100;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_balance_job, 0, 100;
let $task_id = deploy_get_value(ob1.select select max(task_id) as task_id from oceanbase.__all_virtual_balance_task_history, task_id, 1);

#验证存在两个unit_group都缺少，一个unit_group中多了
ob1.mysql alter system set_tp tp_name = EN_TENANT_TRANSFER_CHECK_LS_MEMBER_LIST_NOT_SAME, error_code = 4114, frequency = 1;
ob1.mysql alter system set enable_rebalance = false tenant='mysql';
let $table_id = deploy_get_value(ob1.select select table_id from oceanbase.cdb_ob_table_locations where table_name = 'non_partition_0', table_id, 1);
let $src_ls = deploy_get_value(ob1.select select ls_id from oceanbase.cdb_ob_table_locations where table_id = $table_id, ls_id, 1);
let $src_ls_group_id = deploy_get_value(ob1.select select ls_group_id from oceanbase.__all_virtual_ls_status where tenant_id = $tenant_id and ls_id = $src_ls, ls_group_id, 1);
let $dest_ls = deploy_get_value(ob1.select select ls_id from oceanbase.__all_virtual_ls_status where tenant_id = $tenant_id and ls_id != 1 and ls_id != $src_ls and ls_group_id != $src_ls_group_id, ls_id, 1);
ob1.mysql alter system transfer partition table_id = $table_id, object_id = $table_id to ls $dest_ls tenant = 'mysql';
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_balance_job, 1, 100;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_balance_task where task_type = 'LS_SPLIT' and status = 'TRANSFER', 1, 100;
ob1.mysql alter system set enable_transfer = false tenant='mysql';

ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_balance_job, 0, 100;
ob1.mysql alter system cancel transfer partition all tenant = 'mysql';
ob1.mysql alter system set enable_transfer = true tenant='mysql';

sleep 3;
ob1.mysql alter system transfer partition table_id = $table_id, object_id = $table_id to ls $dest_ls tenant = 'mysql';
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_balance_job, 1, 100;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_balance_task where task_type = 'LS_SPLIT' and status = 'TRANSFER', 1, 100;
ob1.mysql alter system set enable_transfer = false tenant='mysql';

ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_balance_job, 0, 100;
ob1.mysql alter system cancel transfer partition all tenant = 'mysql';

ob1.mysql alter system set enable_transfer = true tenant='mysql';
sleep 3;
ob1.mysql alter system transfer partition table_id = $table_id, object_id = $table_id to ls $dest_ls tenant = 'mysql';
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_balance_job, 1, 100;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_balance_task where task_type = 'LS_SPLIT' and status = 'TRANSFER', 1, 100;
ob1.mysql alter system set enable_transfer = false tenant='mysql';

ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_balance_job, 0, 100;
ob1.mysql alter system cancel transfer partition all tenant = 'mysql';
ob1.mysql alter system set_tp tp_name = EN_TENANT_TRANSFER_CHECK_LS_MEMBER_LIST_NOT_SAME, error_code = 4114, frequency = 0;
#应该一个ls_group里面有四个，一个只有1个
ob1.mysql_p select ls_group_id, count(*) from oceanbase.__all_virtual_ls_status where tenant_id = $tenant_id group by ls_group_id order by ls_group_id;
let $job_id = deploy_get_value(ob1.select select max(job_id) as job_id from oceanbase.__all_virtual_balance_job_history, job_id, 1);
let $task_id = deploy_get_value(ob1.select select max(task_id) as task_id from oceanbase.__all_virtual_balance_task_history, task_id, 1);
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_unit where tenant_id = $tenant_id, 6, 100;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_unit where tenant_id = $meta_tenant_id, 6, 100;
sleep 2;
ob1.mysql set ob_global_debug_sync = 'BEFORE_TENANT_BALANCE_SERVICE wait_for signal';
ob1.mysql alter system set enable_transfer = true tenant='mysql';
ob1.mysql alter system set enable_rebalance = true tenant='mysql';
ob1.mysql alter tenant mysql set primary_zone = 'z1,z2';
ob1.mysql  ALTER RESOURCE TENANT mysql UNIT_NUM = 3;
ob1.mysql set ob_global_debug_sync = 'now signal signal';
#一个migrate和一个expand任务
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_balance_job_history where job_id > $job_id, 2, 200;

--disable_query_log
ob1.mysql_p select balance_strategy_name from oceanbase.__all_virtual_balance_job_history where job_id > $job_id order by job_id;
ob1.mysql_p select task_type, src_ls,dest_ls, ls_group_id from oceanbase.__all_virtual_balance_task_history where task_id > $task_id order by create_time;
--enable_query_log


