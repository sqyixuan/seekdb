# table related
connection conn_sys;
select a.*, b.table_name from (select tenant_id, table_id, count(*) as history_cnt from oceanbase.__all_virtual_table_history where (tenant_id & 0x1) = 0 and table_id & 0xffffffffff > 500000 group by tenant_id, table_id) as a join __all_virtual_table as b on a.tenant_id = b.tenant_id and a.table_id = b.table_id;
select a.*, b.table_name from (select tenant_id, table_id, count(*) as history_cnt from oceanbase.__all_virtual_column_history where (tenant_id & 0x1) = 0 and table_id & 0xffffffffff > 500000 group by tenant_id, table_id) as a join __all_virtual_table as b on a.tenant_id = b.tenant_id and a.table_id = b.table_id;
select a.*, b.table_name from (select tenant_id, table_id, count(*) as history_cnt from oceanbase.__all_virtual_part_info_history where (tenant_id & 0x1) = 0 and table_id & 0xffffffffff > 500000 group by tenant_id, table_id) as a join __all_virtual_table as b on a.tenant_id = b.tenant_id and a.table_id = b.table_id;
select a.*, b.table_name from (select tenant_id, table_id, count(*) as history_cnt from oceanbase.__all_virtual_sub_part_history where (tenant_id & 0x1) = 0 and table_id & 0xffffffffff > 500000 group by tenant_id, table_id) as a join __all_virtual_table as b on a.tenant_id = b.tenant_id and a.table_id = b.table_id;
select a.*, b.table_name from (select tenant_id, table_id, count(*) as history_cnt from oceanbase.__all_virtual_part_history where (tenant_id & 0x1) = 0 and table_id & 0xffffffffff > 500000 group by tenant_id, table_id) as a join __all_virtual_table as b on a.tenant_id = b.tenant_id and a.table_id = b.table_id;
select a.*, b.table_name from (select tenant_id, table_id, count(*) as history_cnt from oceanbase.__all_virtual_def_sub_part_history where (tenant_id & 0x1) = 0 and table_id & 0xffffffffff > 500000 group by tenant_id, table_id) as a join __all_virtual_table as b on a.tenant_id = b.tenant_id and a.table_id = b.table_id;

# tablegroup related
connection conn_sys;
select a.*, b.tablegroup_name from (select tenant_id, tablegroup_id, count(*) as history_cnt from oceanbase.__all_virtual_tablegroup_history where (tenant_id & 0x1) = 0 and tablegroup_id & 0xffffffffff > 500000 group by tenant_id, tablegroup_id) as a join __all_virtual_tablegroup as b on a.tenant_id = b.tenant_id and a.tablegroup_id = b.tablegroup_id;
select a.tenant_id, a.table_id as tablegroup_id, a.history_cnt, b.tablegroup_name from (select tenant_id, table_id, count(*) as history_cnt from oceanbase.__all_virtual_part_info_history where (tenant_id & 0x1) = 0 and table_id & 0xffffffffff > 500000 group by tenant_id, table_id) as a join __all_virtual_tablegroup as b on a.tenant_id = b.tenant_id and a.table_id = b.tablegroup_id;
select a.tenant_id, a.table_id as tablegroup_id, a.history_cnt, b.tablegroup_name from (select tenant_id, table_id, count(*) as history_cnt from oceanbase.__all_virtual_sub_part_history where (tenant_id & 0x1) = 0 and table_id & 0xffffffffff > 500000 group by tenant_id, table_id) as a join __all_virtual_tablegroup as b on a.tenant_id = b.tenant_id and a.table_id = b.tablegroup_id;
select a.tenant_id, a.table_id as tablegroup_id, a.history_cnt, b.tablegroup_name from (select tenant_id, table_id, count(*) as history_cnt from oceanbase.__all_virtual_part_history where (tenant_id & 0x1) = 0 and table_id & 0xffffffffff > 500000 group by tenant_id, table_id) as a join __all_virtual_tablegroup as b on a.tenant_id = b.tenant_id and a.table_id = b.tablegroup_id;
select a.tenant_id, a.table_id as tablegroup_id, a.history_cnt, b.tablegroup_name from (select tenant_id, table_id, count(*) as history_cnt from oceanbase.__all_virtual_def_sub_part_history where (tenant_id & 0x1) = 0 and table_id & 0xffffffffff > 500000 group by tenant_id, table_id) as a join __all_virtual_tablegroup as b on a.tenant_id = b.tenant_id and a.table_id = b.tablegroup_id;

