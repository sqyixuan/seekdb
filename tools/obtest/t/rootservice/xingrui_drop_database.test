# CASE_OWNER:
#    @xingrui.cwh
# CASE_DESC:
#    验证有outline等信息时，drop database是否正常
 
ob1=OBI(cluster=1:1,proxy_num=0);
source include/mini_ob_config.inc;
ob1.set extra_config=$mini_ob_config;
ob1.reboot;
 
ob_connect(conn_sys, ob1.z1.obs0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);
set @@session.ob_query_timeout = 1000000000;
#create tenant
eval CREATE RESOURCE UNIT xingrui_drop_database_unit MAX_CPU 1, MEMORY_SIZE '2G';
eval CREATE RESOURCE POOL xingrui_drop_database_pool UNIT = 'xingrui_drop_database_unit', UNIT_NUM = 1;
eval CREATE TENANT xingrui_drop_database_mysql RESOURCE_POOL_LIST = ('xingrui_drop_database_pool'), primary_zone='z1,z2' set ob_tcp_invited_nodes='%';

eval CREATE RESOURCE UNIT xingrui_drop_database_unit1 MAX_CPU 1, MEMORY_SIZE '2G';
eval CREATE RESOURCE POOL xingrui_drop_database_pool1 UNIT = 'xingrui_drop_database_unit1', UNIT_NUM = 1;
eval CREATE TENANT xingrui_drop_database_oracle RESOURCE_POOL_LIST = ('xingrui_drop_database_pool1'), primary_zone='z1,z2' set ob_tcp_invited_nodes='%', ob_compatibility_mode='oracle';

#1.mysql 
ob_connect(conn_mysql, ob1.z1.obs0, root@xingrui_drop_database_mysql, , test, , USE_MYSQL_CONNECTOR);
connection conn_mysql;
#1.1 mysql without recyclebin
create database xingrui_mysql_without_recyclebin;
use xingrui_mysql_without_recyclebin;
#1.1.1 create index and table
create table xingrui_test(col1 int);
create index xingrui_index on xingrui_test(col1);
insert into xingrui_test values('1');
create table xingrui_test1(col1 int);

#1.1.2 create outline
create outline xingrui_outline on select * from xingrui_test;

#1.1.3 routines(only can run in mysqltest)
#delimiter //;
#create procedure xingrui_routine()
#   BEGIN
#     select * from xingrui_test;
#   END //
#delimiter;//
#call xingrui_routine();

#1.1.4 mock_fk
create table xingrui_parent(id int NOT NULL, primary key (id));
​
create table xingrui_child(id int,
 parent_id int,
 index par_ind(parent_id),
 FOREIGN KEY (parent_id) REFERENCES xingrui_parent (id) ON DELETE CASCADE
);
drop database xingrui_mysql_without_recyclebin;

1.2 mysql with recyclebin
set recyclebin = on;
create database xingrui_mysql_with_recyclebin;
use xingrui_mysql_with_recyclebin;
#1.2.1 create index and table
create table xingrui_test(col1 int);
create index xingrui_index on xingrui_test(col1);
insert into xingrui_test values('1');
create table xingrui_test1(col1 int);

#1.2.2 create outline
create outline xingrui_outline on select * from xingrui_test;

##1.2.3 routines (only can run in mysqltest)
#delimiter //
#CREATE PROCEDURE xingrui_routine()
#   BEGIN
#     select * from xingrui_test;
#   END //
#delimiter ;
#call xingrui_routine();

#1.2.4 mock_fk
create table xingrui_parent(id int NOT NULL, primary key (id));
​
create table xingrui_child(id int,
 parent_id int,
 index par_ind(parent_id),
 FOREIGN KEY (parent_id) REFERENCES xingrui_parent (id) ON DELETE CASCADE
);
drop database xingrui_mysql_with_recyclebin;
purge recyclebin;

#2.oracle
ob_connect(conn_oracle, ob1.z1.obs0, SYS@xingrui_drop_database_oracle, ,SYS, , USE_OB_CONNECTOR);
connection conn_oracle;
#2.1 oracle without recyclebin
CREATE USER xingrui_without_recyclebin IDENTIFIED BY SYS;
ob_connect(conn_tmp1, ob1.z1.obs0, SYS@xingrui_drop_database_oracle, ,xingrui_without_recyclebin, , USE_OB_CONNECTOR);
connection conn_tmp1;
#2.1.1 create index
create table xingrui_test(col1 int);
create index xingrui_index on xingrui_test(col1);
insert into xingrui_test values('1');
create table xingrui_test1(col1 int);

#2.1.2 create outline
create outline xingrui_outline on select * from xingrui_test;

#2.1.3 create synonyms
create synonym xtb for xingrui_test;

#2.1.4 package(only can run in mysqltest)
#create package xingrui_package as
#function f1 return number as
#begin
#    return 2;
#end /

#2.1.5 routines(only can run in mysqltest)
#CREATE TABLE xingrui_log_history 
#      (userid VARCHAR2(20), 
#      logdate DATE DEFAULT SYSDATE);
#
#CREATE OR REPLACE PROCEDURE xingrui_routine 
#      IS
#  BEGIN
#      INSERT INTO xingrui_log_history (userid) VALUES (USER);
#  END;
#/

#2.1.6 udt(only can run in mysqltest)
#delimiter /;
#create or replace type xingrui_type as object(a number);
#delimiter /
#create table xingrui_udt(id xingrui_type);

#2.1.7 mock_fk
create table xingrui_supplier_groups(
     group_id NUMBER GENERATED BY DEFAULT AS IDENTITY,
     group_name VARCHAR2(127) NOT NULL,
     PRIMARY KEY (group_id)
     );

CREATE TABLE xingrui_suppliers (
     supplier_id NUMBER GENERATED BY DEFAULT AS IDENTITY,
     supplier_name VARCHAR2(127) NOT NULL,
     group_id NUMBER NOT NULL,
     PRIMARY KEY(supplier_id),
     CONSTRAINT fk_name FOREIGN KEY(group_id) REFERENCES xingrui_supplier_groups(group_id)
     );
connection conn_oracle;
drop user XINGRUI_WITHOUT_RECYCLEBIN cascade;

#2.2 oracle with recyclebin
connection conn_oracle;
CREATE USER xingrui_with_recyclebin IDENTIFIED BY SYS;
ob_connect(conn_tmp2, ob1.z1.obs0, SYS@xingrui_drop_database_oracle, ,xingrui_with_recyclebin, , USE_OB_CONNECTOR);
connection conn_tmp2;
set recyclebin = on;

#2.2.1 create index
create table xingrui_test(col1 int);
create index xingrui_index on xingrui_test(col1);
insert into xingrui_test values('1');
create table xingrui_test1(col1 int);

#2.2.2 create outline
create outline xingrui_outline on select * from xingrui_test;

#2.2.3 create synonyms
create synonym xtb for xingrui_test;

#2.2.4 package(only can run in mysqltest)
