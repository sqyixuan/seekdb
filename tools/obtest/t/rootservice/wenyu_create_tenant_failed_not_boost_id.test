# CASE_OWNER:
#    @wenyu.ffz
# CASE_DESC:
#    校验在create tenant在检查资源失败时不会推tenant_id

ob1=OBI(cluster=1:1:1,proxy_num=0);
source include/mini_ob_config.inc;
ob1.set extra_config=$mini_ob_config;
ob1.reboot;

ob_connect(conn_sys, ob1.z1.obs0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);
#create tenant
eval CREATE RESOURCE UNIT unit_1 MAX_CPU 2, MEMORY_SIZE '4G';
eval CREATE RESOURCE POOL pool_1 UNIT = 'unit_1', UNIT_NUM = 1;
select value from __all_sys_stat where name = 'ob_max_used_tenant_id';
--error 4650
eval CREATE TENANT mysql RESOURCE_POOL_LIST = ('pool_2'), primary_zone='z1' set ob_tcp_invited_nodes='%';
select value from __all_sys_stat where name = 'ob_max_used_tenant_id';
--error 1210
eval CREATE TENANT mysql RESOURCE_POOL_LIST = ('pool_1'), primary_zone='zone1' set ob_tcp_invited_nodes='%';
select value from __all_sys_stat where name = 'ob_max_used_tenant_id';
