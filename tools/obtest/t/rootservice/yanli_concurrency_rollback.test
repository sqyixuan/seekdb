##########################
#owner :msy164651
# 测试点：
##########################

ob1=OBI(cluster=1:1,proxy_num=0);
source include/mini_ob_config.inc;
ob1.set extra_config=$mini_ob_config;
ob1.reboot;

ob_connect(conn_sys, ob1.z1.obs0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);

connection conn_sys;
ob1.mysql alter system set debug_sync_timeout = '1000s';
ob1.mysql alter system set _transfer_start_trans_timeout = '60s';

set @@session.ob_query_timeout = 1000000000;

#mysql tenant
eval CREATE RESOURCE UNIT unit_1 MAX_CPU 1, MEMORY_SIZE '2G';
eval CREATE RESOURCE POOL pool_1 UNIT = 'unit_1', UNIT_NUM = 1;
eval CREATE TENANT mysql RESOURCE_POOL_LIST = ('pool_1'), primary_zone='z1' set ob_tcp_invited_nodes='%';
ob_connect(conn_mysql, ob1.z1.obs0, root@mysql, , test, , USE_MYSQL_CONNECTOR);
connection conn_mysql;
let $count = 0;
while ($count < 100) 
{
eval create table non_partition_$count(pk int primary key);
inc $count;
}

let $count = 0;
while ($count < 10) 
{
eval create table one_partition_$count(pk int primary key) partition by hash(pk) partitions 10;
inc $count;
}
let $count = 0;
while ($count < 20)
{
eval create table two_partition_$count (c1 int, c2 int, c3 int, c4 int) partition by range(c1) subpartition by range(c2) ( partition t1rp0 values less than (100) ( subpartition t1rp0sp0 values less than (100),  subpartition t1rp0sp1 values less than (200), subpartition t1rp0sp2 values less than (300), subpartition t1rp0sp3 values less than (400)), partition t1rp1 values less than (200) (subpartition t1rp1sp0 values less than (100),subpartition t1rp1sp1 values less than (200),subpartition t1rp1sp2 values less than (300),subpartition t1rp1sp3 values less than (400)));
inc $count;
}
#扩容，ls_split rollback
ob1.mysql alter system set enable_rebalance =false;
let $tenant_id = deploy_get_value(ob1.select select tenant_id from oceanbase.DBA_OB_TENANTS where tenant_name = 'mysql', tenant_id, 1);
ob1.mysql set ob_global_debug_sync = 'BEFORE_PROCESS_BALANCE_TASK_TRANSFER wait_for signal';
ob1.mysql alter tenant mysql set primary_zone = 'z1, z2';
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_balance_job, 1, 100;
let $job_id =  deploy_get_value(ob1.select select job_id from oceanbase.__all_virtual_balance_job, job_id, 1);
ob1.check_until_timeout select status from oceanbase.__all_virtual_balance_task, TRANSFER, 100;
sleep 2;
#卡在transfer阶段，回滚primary_zone，并且切主
ob1.mysql alter tenant mysql set primary_zone = 'z2';
ob1.mysql set ob_global_debug_sync = 'BEFORE_EXECUTE_BALANCE_TASK wait_for signal1';
ob1.mysql set ob_global_debug_sync = 'AFTER_TRANSFER_PROCESS_INIT_TASK_AND_BEFORE_NOTIFY_STORAGE wait_for signal3';
let $z2_ip = deploy_get_value(ob1.z2.obs0.ip);
let $z2_port = deploy_get_value(ob1.z2.obs0.port);
ob1.mysql alter system switch replica leader ls=1 server='$z2_ip:$z2_port' tenant='mysql';
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_ls_meta_table where tenant_id = $tenant_id and ls_id = 1 and role = 1 and zone = 'z2', 1, 100;
#保证新的balance_task_executor 上任
ob1.z2.obs0.check_log_until_success -c "balance task execute thread";
sleep 5;
ob1.mysql_p select count(*) from oceanbase.__all_virtual_balance_task where current_transfer_task_id != -1;
ob1.mysql set ob_global_debug_sync = 'now signal signal';
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_balance_task where current_transfer_task_id != -1, 1, 20;
ob1.check_until_timeout select status from oceanbase.__all_virtual_balance_job, CANCELING, 100;
ob1.mysql set ob_global_debug_sync = 'now signal signal1';
ob1.check_until_timeout select status from oceanbase.__all_virtual_balance_job_history where job_id = $job_id, CANCELED, 100;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_balance_job_history, 2, 100;
ob1.mysql_p select task_type, src_ls,dest_ls, finished_part_list, ls_group_id, status from oceanbase.__all_virtual_balance_task_history order by create_time;
ob1.mysql_p select count(*) from oceanbase.__all_virtual_transfer_task;
