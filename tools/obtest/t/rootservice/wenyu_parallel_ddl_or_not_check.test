# CASE_OWNER:
#    @fanfangzhou.ffz
# CASE_DESC:
#    test parallel ddl run parallel path, serial ddl run serial path
#

ob1=OBI(cluster=1, init_unit_cpu=0, proxy_num=0, ct_num=0, locality=hz);
ob1.reboot;


let $rs = ob1.z1.obs0;
let $rs_ip = deploy_get_value($rs.ip);
let $rs_port = deploy_get_value($rs.port);
let $rs_mysql_port = deploy_get_value($rs.mysql_port);
connect (sys,$rs_ip,admin@sys,admin,test,$rs_mysql_port);
# create table
select count(*) from oceanbase.__all_rootservice_event_history where event = 'create table';
select count(*) from oceanbase.__all_rootservice_event_history where event = 'parallel create table';
alter system set _enable_parallel_table_creation = false;
create table t1 (col1 int);
select count(*) from oceanbase.__all_rootservice_event_history where event = 'create table';
select count(*) from oceanbase.__all_rootservice_event_history where event = 'parallel create table';
alter system set _enable_parallel_table_creation = true;
create table t2(col1 int);
select count(*) from oceanbase.__all_rootservice_event_history where event = 'create table';
select count(*) from oceanbase.__all_rootservice_event_history where event = 'parallel create table';
# create index
select count(*) from oceanbase.__all_rootservice_event_history where event = 'create index';
select count(*) from oceanbase.__all_rootservice_event_history where event = 'update index status';
select count(*) from oceanbase.__all_rootservice_event_history where event = 'parallel create index';
select count(*) from oceanbase.__all_rootservice_event_history where event = 'parallel update index status';
alter system set _parallel_ddl_control = 'create_index:off';
create index i1 on t1(col1);
select count(*) from oceanbase.__all_rootservice_event_history where event = 'create index';
select count(*) from oceanbase.__all_rootservice_event_history where event = 'update index status';
select count(*) from oceanbase.__all_rootservice_event_history where event = 'parallel create index';
select count(*) from oceanbase.__all_rootservice_event_history where event = 'parallel update index status';
alter system set _parallel_ddl_control = 'create_index:on';
create index i2 on t2(col1);
select count(*) from oceanbase.__all_rootservice_event_history where event = 'create index';
select count(*) from oceanbase.__all_rootservice_event_history where event = 'update index status';
select count(*) from oceanbase.__all_rootservice_event_history where event = 'parallel create index';
select count(*) from oceanbase.__all_rootservice_event_history where event = 'parallel update index status';
# truncate table
select count(*) from oceanbase.__all_rootservice_event_history where event = 'truncate table';
select count(*) from oceanbase.__all_rootservice_event_history where event = 'truncate table new';
alter system set _parallel_ddl_control = 'truncate_table:off';
truncate table t1;
select count(*) from oceanbase.__all_rootservice_event_history where event = 'truncate table';
select count(*) from oceanbase.__all_rootservice_event_history where event = 'truncate table new';
alter system set _parallel_ddl_control = 'truncate_table:on';
truncate table t2;
select count(*) from oceanbase.__all_rootservice_event_history where event = 'truncate table';
select count(*) from oceanbase.__all_rootservice_event_history where event = 'truncate table new';


eval CREATE RESOURCE UNIT unit_1 MAX_CPU 2, MEMORY_SIZE '4G';
eval CREATE RESOURCE POOL pool_1 UNIT = 'unit_1', UNIT_NUM = 1;
eval CREATE TENANT oracle RESOURCE_POOL_LIST = ('pool_1'), primary_zone='z1' set ob_tcp_invited_nodes='%', ob_compatibility_mode = 'oracle';

ob_connect(conn_oracle1, ob1.z1.obs0, SYS@oracle, ,sys, , USE_OB_CONNECTOR);
create table t1(col1 int);
create table t2(col1 int);
# comment
connection sys;
select count(*) from oceanbase.__all_rootservice_event_history where event = 'parallel set comment';
select count(*) from oceanbase.__all_rootservice_event_history where event = 'alter table';
alter system set _parallel_ddl_control = 'set_comment:off' tenant = 'oracle';
connection conn_oracle1;
comment on table t1 is 'TC';
connection sys;
select count(*) from oceanbase.__all_rootservice_event_history where event = 'parallel set comment';
select count(*) from oceanbase.__all_rootservice_event_history where event = 'alter table';
alter system set _parallel_ddl_control = 'set_comment:on' tenant = 'oracle';
connection conn_oracle1;
comment on table t2 is 'TC';
connection sys;
select count(*) from oceanbase.__all_rootservice_event_history where event = 'parallel set comment';
select count(*) from oceanbase.__all_rootservice_event_history where event = 'alter table';
