# CASE_OWNER:
#    @jinqian.zzy
# CASE_DESC:
#     1. 删除一个R副本，自动容灾可以补充回来
#     2. 类型转换一个R副本为F，自动容灾可以类型转换回来
#     3. 删除一个F副本，容灾模块将剩余的R副本类型转换成F，后续再补充一个R副本

#######################################################################
#                        create inital objects
#######################################################################

ob1=OBI(cluster=2:2:2,proxy_num=0,init_unit_cpu=0);
source include/mini_ob_config.inc;
ob1.set extra_config=$mini_ob_config;
ob1.reboot;

ob1.mysql alter system set debug_sync_timeout = '1000s';
ob1.mysql alter system SET enable_rebalance = 'false';
ob1.mysql alter system SET enable_rereplication = 'false';

let $proxy_ip = deploy_get_value(ob1.z1.obs0.ip);
let $proxy_port = deploy_get_value(ob1.z1.obs0.mysql_port);
connect(sys_conn, $proxy_ip, root@sys,,oceanbase, $proxy_port);

# create new tenant mysql
--echo ============================================================
--echo              create tenant and duplicate table 
--echo ============================================================
source include/create_unit_config.inc;
ob1.mysql CREATE RESOURCE POOL tenant_pool UNIT = "2c2g", UNIT_NUM = 2, ZONE_LIST = ('z1', 'z2', 'z3');
ob1.mysql CREATE TENANT mysql RESOURCE_POOL_LIST=('tenant_pool'), LOCALITY = "F@z1, F@z2, F@z3", PRIMARY_ZONE = "z1" SET ob_tcp_invited_nodes='%';

let $tenant_id = deploy_get_value(ob1.select SELECT tenant_id FROM oceanbase.DBA_OB_TENANTS WHERE tenant_name = "mysql", tenant_id, 1);
let $meta_tenant_id = deploy_get_value(ob1.select select tenant_id - 1 as meta_tenant_id from oceanbase.DBA_OB_TENANTS where tenant_name = "mysql", meta_tenant_id, 1);
let $resource_pool_id = deploy_get_value(ob1.select SELECT resource_pool_id FROM oceanbase.__all_resource_pool WHERE tenant_id = $tenant_id, resource_pool_id, 1);

ob1.check_until_timeout select count(*) from CDB_OB_LS_LOCATIONS where tenant_id = $tenant_id and ls_id = 1001 and role = 'leader', 1, 10;
ob1.check_until_timeout select count(*) from CDB_OB_LS_LOCATIONS where tenant_id = $tenant_id and ls_id = 1002 and role = 'leader', 1, 10;
ob1.check_until_timeout select count(*) from GV\$OB_LOG_STAT where tenant_id = $tenant_id and ls_id = 1001 and role = 'leader', 1, 10;
ob1.check_until_timeout select count(*) from GV\$OB_LOG_STAT where tenant_id = $tenant_id and ls_id = 1002 and role = 'leader', 1, 10;

--disable_query_log

ob_connect(conn_mysql, ob1.z1.obs0, root@mysql, , test, , USE_MYSQL_CONNECTOR);
connection conn_mysql;
create table dup_t1(c1 int) duplicate_scope = 'cluster';

connect(sys_conn, $proxy_ip, root@sys,,oceanbase, $proxy_port);
connection sys_conn;
# get mysql's unit info in z1
let $duplicate_ls_id = deploy_get_value(ob1.select select ls_id from oceanbase.CDB_OB_LS where tenant_id = $tenant_id and flag like "%DUPLICATE%", ls_id, 1);
let $unit_id = deploy_get_value(ob1.select select unit_id from oceanbase.__all_virtual_ls_meta_table where tenant_id = $tenant_id and ls_id = $duplicate_ls_id and role = 1, unit_id, 1);
let $unit_group_id = deploy_get_value(ob1.select select unit_group_id from oceanbase.DBA_OB_UNITS where tenant_id = $tenant_id and unit_id = $unit_id, unit_group_id, 1);
let $z1_full_replica_ip = deploy_get_value(ob1.select SELECT svr_ip FROM oceanbase.DBA_OB_UNITS WHERE unit_id = $unit_id, svr_ip, 1);
let $z1_full_replica_port = deploy_get_value(ob1.select SELECT svr_port FROM oceanbase.DBA_OB_UNITS WHERE unit_id = $unit_id, svr_port, 1);
let $z1_full_replica_dst = $z1_full_replica_ip:$z1_full_replica_port;

# get servers' addr in z1, z2 and z3
let $z1_dst_ip0 = deploy_get_value(ob1.z1.obs0.ip);
let $z1_dst_ip1 = deploy_get_value(ob1.z1.obs1.ip);
let $z1_dst_port0 = deploy_get_value(ob1.z1.obs0.port);
let $z1_dst_port1 = deploy_get_value(ob1.z1.obs1.port);
let $z1_dst0 = $z1_dst_ip0:$z1_dst_port0;
let $z1_dst1 = $z1_dst_ip1:$z1_dst_port1;

let $z2_dst_ip0 = deploy_get_value(ob1.z2.obs0.ip);
let $z2_dst_ip1 = deploy_get_value(ob1.z2.obs1.ip);
let $z2_dst_port0 = deploy_get_value(ob1.z2.obs0.port);
let $z2_dst_port1 = deploy_get_value(ob1.z2.obs1.port);
let $z2_dst0 = $z2_dst_ip0:$z2_dst_port0;
let $z2_dst1 = $z2_dst_ip1:$z2_dst_port1;

let $z3_dst_ip0 = deploy_get_value(ob1.z3.obs0.ip);
let $z3_dst_ip1 = deploy_get_value(ob1.z3.obs1.ip);
let $z3_dst_port0 = deploy_get_value(ob1.z3.obs0.port);
let $z3_dst_port1 = deploy_get_value(ob1.z3.obs1.port);
let $z3_dst0 = $z3_dst_ip0:$z3_dst_port0;
let $z3_dst1 = $z3_dst_ip1:$z3_dst_port1;

--echo ============================================================
--echo              case 1: remove R replica
--echo ============================================================

ob1.check_until_timeout SELECT COUNT(*) FROM oceanbase.CDB_OB_LS_LOCATIONS WHERE tenant_id = $tenant_id AND ls_id = $duplicate_ls_id AND role = "LEADER", 1, 20;
sleep 5;
let $r_ip = deploy_get_value(ob1.select select svr_ip from cdb_ob_ls_locations where tenant_id = $tenant_id and ls_id = $duplicate_ls_id and REPLICA_TYPE = 'READONLY' limit 1, svr_ip, 1);
let $r_port = deploy_get_value(ob1.select select svr_port from cdb_ob_ls_locations where tenant_id = $tenant_id and ls_id = $duplicate_ls_id and REPLICA_TYPE = 'READONLY' limit 1, svr_port, 1);
let $r_replica_server = $r_ip:$r_port;

eval alter system remove replica ls=$duplicate_ls_id server='$r_replica_server' tenant='mysql';
ob1.check_until_timeout SELECT COUNT(*) FROM oceanbase.CDB_OB_LS_LOCATIONS WHERE tenant_id = $tenant_id AND ls_id = $duplicate_ls_id AND role = "LEADER" AND learner_list LIKE '%$r_replica_server%', 0, 20;
ob1.check_until_timeout SELECT COUNT(*) FROM oceanbase.CDB_OB_LS_LOCATIONS WHERE tenant_id = $tenant_id AND ls_id = $duplicate_ls_id, 5, 30;
ob1.check_until_timeout SELECT COUNT(*) FROM oceanbase.CDB_OB_LS_REPLICA_TASKS WHERE tenant_id = $tenant_id, 0, 20;

ob1.mysql alter system SET enable_rereplication = 'true';
ob1.check_until_timeout SELECT COUNT(*) FROM oceanbase.CDB_OB_LS_LOCATIONS WHERE tenant_id = $tenant_id AND ls_id = $duplicate_ls_id AND role = "LEADER" AND learner_list LIKE '%$r_replica_server%', 1, 30;
ob1.check_until_timeout SELECT COUNT(*) FROM oceanbase.CDB_OB_LS_LOCATIONS WHERE tenant_id = $tenant_id AND ls_id = $duplicate_ls_id, 6, 30;
ob1.mysql alter system SET enable_rereplication = 'false';
sleep 5;
--echo ============================================================
--echo              case 2: modify R to F
--echo ============================================================

eval alter system modify replica ls=$duplicate_ls_id server='$r_replica_server' replica_type = 'F' paxos_replica_num = 4 tenant='mysql';
ob1.check_until_timeout SELECT COUNT(*) FROM oceanbase.CDB_OB_LS_LOCATIONS WHERE tenant_id = $tenant_id AND ls_id = $duplicate_ls_id AND role = "LEADER" AND learner_list LIKE '%$r_replica_server%', 0, 20;
ob1.check_until_timeout SELECT COUNT(*) FROM oceanbase.CDB_OB_LS_LOCATIONS WHERE tenant_id = $tenant_id AND ls_id = $duplicate_ls_id AND role = "LEADER" AND member_list LIKE '%$r_replica_server%', 1, 20;
ob1.check_until_timeout SELECT COUNT(*) FROM oceanbase.CDB_OB_LS_REPLICA_TASKS WHERE tenant_id = $tenant_id, 0, 20;

ob1.mysql alter system SET enable_rereplication = 'true';
ob1.check_until_timeout SELECT COUNT(*) FROM oceanbase.CDB_OB_LS_LOCATIONS WHERE tenant_id = $tenant_id AND ls_id = $duplicate_ls_id AND role = "LEADER" AND learner_list LIKE '%$r_replica_server%', 1, 30;
ob1.check_until_timeout SELECT COUNT(*) FROM oceanbase.CDB_OB_LS_LOCATIONS WHERE tenant_id = $tenant_id AND ls_id = $duplicate_ls_id AND role = "LEADER" AND member_list LIKE '%$r_replica_server%', 0, 20;
ob1.check_until_timeout SELECT COUNT(*) FROM oceanbase.CDB_OB_LS_REPLICA_TASKS WHERE tenant_id = $tenant_id, 0, 20;

ob1.mysql alter system SET enable_rereplication = 'false';
sleep 5;
--echo ============================================================
--echo              case 3: remove F replica
--echo ============================================================
let $f_ip = deploy_get_value(ob1.select select svr_ip from cdb_ob_ls_locations where tenant_id = $tenant_id and ls_id = $duplicate_ls_id and REPLICA_TYPE = 'FULL' limit 1, svr_ip, 1);
let $f_port = deploy_get_value(ob1.select select svr_port from cdb_ob_ls_locations where tenant_id = $tenant_id and ls_id = $duplicate_ls_id and REPLICA_TYPE = 'FULL' limit 1, svr_port, 1);
let $f_replica_server = $f_ip:$f_port;

eval alter system remove replica ls=$duplicate_ls_id server='$f_replica_server' paxos_replica_num = 2 tenant='mysql';
ob1.check_until_timeout SELECT COUNT(*) FROM oceanbase.CDB_OB_LS_LOCATIONS WHERE tenant_id = $tenant_id AND ls_id = $duplicate_ls_id AND role = "LEADER" AND member_list LIKE '%$f_replica_server%', 0, 20;
ob1.check_until_timeout SELECT COUNT(*) FROM oceanbase.CDB_OB_LS_LOCATIONS WHERE tenant_id = $tenant_id AND ls_id = $duplicate_ls_id, 5, 30;
ob1.check_until_timeout SELECT COUNT(*) FROM oceanbase.CDB_OB_LS_REPLICA_TASKS WHERE tenant_id = $tenant_id, 0, 20;

ob1.mysql alter system SET enable_rereplication = 'true';
ob1.check_until_timeout SELECT COUNT(*) FROM oceanbase.CDB_OB_LS_LOCATIONS WHERE tenant_id = $tenant_id AND ls_id = $duplicate_ls_id AND role = "LEADER" AND (member_list LIKE '%$f_replica_server%' or learner_list LIKE '%$f_replica_server%'), 1, 30;
ob1.check_until_timeout SELECT COUNT(*) FROM oceanbase.CDB_OB_LS_LOCATIONS WHERE tenant_id = $tenant_id AND ls_id = $duplicate_ls_id, 6, 30;
