# CASE_OWNER:
#    @cangming.zl
# CASE_DESC:
#    When unit balance need to migrate system unit (all unit is migrating), rebalance task may
#    execute fail, because leader can not switch out since we need keep partition group leader
#    in one server.
#    BUG: 


############################################################################
# case 2: system unit can migrate success even all units migrate concurrently
############################################################################
ob1=OBI(cluster=2:2:2,proxy_num=0,init_unit_cpu=0);
ob1.reboot;

ob1.mysql alter system set balancer_idle_time = '10s';
ob1.mysql alter system set enable_rereplication = false;
ob1.mysql alter system set enable_rebalance= false;
ob1.mysql create resource unit big max_cpu=4, memory_size '10G';
ob1.mysql create resource pool big unit = 'big', unit_num = 1, zone_list = ('z1', 'z2', 'z3');
ob1.mysql create tenant big replica_num 3, resource_pool_list ('big') set ob_tcp_invited_nodes='%';

let $ip = deploy_get_value(ob1.z1.obs1.ip);
let $port = deploy_get_value(ob1.z1.obs1.port);
ob1.mysql alter system migrate unit 1 destination '$ip:$port';

let $ip = deploy_get_value(ob1.z2.obs1.ip);
let $port = deploy_get_value(ob1.z2.obs1.port);
ob1.mysql alter system migrate unit 2 destination '$ip:$port';

let $ip = deploy_get_value(ob1.z3.obs1.ip);
let $port = deploy_get_value(ob1.z3.obs1.port);
ob1.mysql alter system migrate unit 3 destination '$ip:$port';

ob1.mysql alter system set enable_rereplication = true;
ob1.mysql alter system set enable_rebalance= true;

ob1.check_until_timeout select count(*) > 0 from oceanbase.__all_unit where length(migrate_from_svr_ip) > 0, 0, 2000;
ob1.mysql_p select count(*) from oceanbase.__all_unit where length(migrate_from_svr_ip) > 0;
