# CASE_OWNER:
#    @jingyu.cr
# CASE_DESC:
#    This case is aimed to test alter duplicate log stream's unit_group_id
#    Check whether can find correct readonly replica to type transform
#
#######################################################################
#                        create inital objects
#######################################################################
ob1=OBI(cluster=3,proxy_num=0,init_unit_cpu=0);
source include/mini_ob_config.inc;
ob1.set extra_config=$mini_ob_config;
ob1.reboot;

ob1.mysql alter system set debug_sync_timeout = '1000s';
ob1.mysql ALTER SYSTEM SET enable_rebalance = 'false';
ob1.mysql ALTER SYSTEM SET enable_rereplication = 'true';

let $proxy_ip = deploy_get_value(ob1.z1.obs0.ip);
let $proxy_port = deploy_get_value(ob1.z1.obs0.mysql_port);
connect(sys_conn, $proxy_ip, root@sys,,oceanbase, $proxy_port);

--echo =============================================
--echo            create mysql tenant
--echo =============================================
# create new tenant mysql
source include/create_unit_config.inc;
ob1.mysql CREATE RESOURCE POOL tenant_pool UNIT = "2c2g", UNIT_NUM = 3, ZONE_LIST = ('z1');
ob1.mysql CREATE TENANT mysql RESOURCE_POOL_LIST=('tenant_pool'), LOCALITY = "F@z1", PRIMARY_ZONE = "z1" SET ob_tcp_invited_nodes='%';

let $tenant_id = deploy_get_value(ob1.select SELECT tenant_id FROM oceanbase.DBA_OB_TENANTS WHERE tenant_name = "mysql", tenant_id, 1);
let $meta_tenant_id = deploy_get_value(ob1.select select tenant_id - 1 as meta_tenant_id from oceanbase.DBA_OB_TENANTS where tenant_name = "mysql", meta_tenant_id, 1);
let $resource_pool_id = deploy_get_value(ob1.select SELECT resource_pool_id FROM oceanbase.__all_resource_pool WHERE tenant_id = $tenant_id, resource_pool_id, 1);

# get servers' addr in z1
let $z1_dst_ip0 = deploy_get_value(ob1.z1.obs0.ip);
let $z1_dst_port0 = deploy_get_value(ob1.z1.obs0.port);
let $z1_dst0 = $z1_dst_ip0:$z1_dst_port0;

let $z1_dst_ip1 = deploy_get_value(ob1.z1.obs1.ip);
let $z1_dst_port1 = deploy_get_value(ob1.z1.obs1.port);
let $z1_dst1 = $z1_dst_ip1:$z1_dst_port1;

let $z1_dst_ip2 = deploy_get_value(ob1.z1.obs2.ip);
let $z1_dst_port2 = deploy_get_value(ob1.z1.obs2.port);
let $z1_dst2 = $z1_dst_ip2:$z1_dst_port2;

--echo =============================================
--echo          create duplicate log stream
--echo =============================================
let $mysql_leader_ip_port=deploy_get_value(ob1.select select concat(svr_ip,':',svr_port) as host from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id = $tenant_id and ls_id = 1 and role = "LEADER" limit 1, host, 1);
let $mysql_leader_obs = deploy_get_value(ob1.get_obs_by_addr $mysql_leader_ip_port);
ob_connect(conn_mysql, $mysql_leader_obs, root@mysql, , test, , USE_MYSQL_CONNECTOR);
# create table and insert data
connection conn_mysql;
create table dup_t1(c1 int) duplicate_scope = "cluster";
insert into dup_t1 values (1), (2), (3), (4), (5);

--echo =============================================
--echo       get duplicate log stream infos
--echo =============================================
connection sys_conn;
ob1.check_until_timeout select count(*) as dup_ls_cnt from oceanbase.CDB_OB_LS where flag like '%duplicate%', 1, 20;
let $dup_ls_id = deploy_get_value(ob1.select select ls_id as dup_ls_id from oceanbase.CDB_OB_TABLE_LOCATIONS where table_name = 'dup_t1', dup_ls_id, 1);
ob1.check_until_timeout select ls_id as dup_ls_id from oceanbase.CDB_OB_LS where flag like '%duplicate%', $dup_ls_id, 20;
ob1.check_until_timeout select count(*) as cnt from oceanbase.CDB_OB_LS_LOCATIONS where ls_id = $dup_ls_id, 3, 20;

--echo =============================================
--echo           debug_sync some thread
--echo =============================================
ob1.mysql set ob_global_debug_sync = 'BEFORE_TENANT_BALANCE_SERVICE wait_for signal1';
ob1.mysql set ob_global_debug_sync = 'STOP_PRIMARY_LS_THREAD wait_for signal2';

--echo ====================================================================
--echo     caculate unit_group_id for r-replica with bigger svr_ip:port
--echo ====================================================================
let $target_unit_id = deploy_get_value(ob1.select select unit_id as target_unit_id from oceanbase.__all_virtual_ls_meta_table where tenant_id = $tenant_id and ls_id = $dup_ls_id and replica_type = 16 order by svr_ip desc, svr_port desc limit 1, target_unit_id, 1);
let $target_unit_group_id = deploy_get_value(ob1.select select unit_group_id as target_unit_group_id from oceanbase.DBA_OB_UNITS where unit_id = $target_unit_id, target_unit_group_id, 1);
let $target_svr_ip = deploy_get_value(ob1.select select svr_ip as target_svr_ip from oceanbase.DBA_OB_UNITS where unit_id = $target_unit_id, target_svr_ip, 1);
let $target_svr_port = deploy_get_value(ob1.select select svr_port as target_svr_port from oceanbase.DBA_OB_UNITS where unit_id = $target_unit_id, target_svr_port, 1);
let $target_dest = $target_svr_ip:$target_svr_port;

--echo ====================================================================
--echo         modify unit_group_id for dup ls in __all_ls_status
--echo ====================================================================
eval alter system change tenant tenant_id = $meta_tenant_id;
--disable_query_log
eval update oceanbase.__all_ls_status set unit_group_id = $target_unit_group_id where ls_id = $dup_ls_id;
--enable_query_log

--echo ====================================================================
--echo             check F-replica on correct unit
--echo ====================================================================
eval alter system change tenant tenant_id = 1;
ob1.check_until_timeout select count(*) as cnt from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id = $tenant_id and ls_id = $dup_ls_id and role = "LEADER" and member_list like "%$target_dest%" and paxos_replica_number = 1, 1, 300;
