# only test sql syntax
--echo
--echo ########################################
--echo ############ oracle tenant #############
--echo ########################################
--echo # create noraml table
connection conn_oracle;
create table ora_t1(c1 int, c2 int, c3 clob);
create index ora_l_idx_t1 on ora_t1(c1) local;
create index ora_g_idx_t1 on ora_t1(c2) global;
let $ora_t1_tid = deploy_get_value(ob1.select select table_id from CDB_OB_TABLE_LOCATIONS where tenant_id = $oracle_tenant_id and table_name = 'ORA_T1', table_id, 1);
ob1.check_until_timeout select count(*) from CDB_OB_TABLE_LOCATIONS where tenant_id = $oracle_tenant_id and (table_id = $ora_t1_tid or data_table_id = $ora_t1_tid) and role = 'LEADER' and duplicate_scope = 'NONE', 5, 3;
eval select table_id, table_name, table_type, duplicate_scope from SYS.DBA_OB_TABLE_LOCATIONS where (table_id = $ora_t1_tid or data_table_id = $ora_t1_tid) and role = 'LEADER' order by table_id;
ob1.check_until_timeout select count(*) from CDB_OB_LS where tenant_id = $oracle_tenant_id and flag like "%duplicate%", 0, 3;
--echo ##########
--echo # 1. normal table to duplicate table
alter table ora_t1 duplicate_scope = 'CLUSTER';
--echo # 1.1. change schemas of priamry table and aux tables
ob1.check_until_timeout select count(*) from CDB_OB_TABLE_LOCATIONS where tenant_id = $oracle_tenant_id and (table_id = $ora_t1_tid or data_table_id = $ora_t1_tid) and role = 'LEADER' and duplicate_scope = 'CLUSTER', 5, 3;
eval select table_id, table_name, table_type, duplicate_scope from SYS.DBA_OB_TABLE_LOCATIONS where (table_id = $ora_t1_tid or data_table_id = $ora_t1_tid) and role = 'LEADER' order by table_id;
--echo # 1.2. create duplicate_ls in the same time
ob1.check_until_timeout select count(*) from CDB_OB_LS where tenant_id = $oracle_tenant_id and flag like "%duplicate%", 1, 3;
--echo ##
--echo # 2. duplicate_scope table to normal table
alter table ora_t1 duplicate_scope = 'NONE';
--echo # 2.1. change schemas of priamry table and aux tables
ob1.check_until_timeout select count(*) from CDB_OB_TABLE_LOCATIONS where tenant_id = $oracle_tenant_id and (table_id = $ora_t1_tid or data_table_id = $ora_t1_tid) and role = 'LEADER' and duplicate_scope = 'NONE', 5, 3;
eval select table_id, table_name, table_type, duplicate_scope from SYS.DBA_OB_TABLE_LOCATIONS where (table_id = $ora_t1_tid or data_table_id = $ora_t1_tid) and role = 'LEADER' order by table_id;
--echo ##########
--echo # 3. duplicate_scope is conflicted with tablegroup
create tablegroup ora_tg;
create table ora_t2(c1 int) duplicate_scope = 'CLUSTER';
--error 600
alter table ora_t2 tablegroup = 'ORA_TG';
--error 600
alter tablegroup ora_tg add ora_t2;
--error 600
alter table ora_t2 duplicate_scope = 'CLUSTER' tablegroup = 'ORA_TG';
--error 0
alter table ora_t2 duplicate_scope = 'NONE' tablegroup = 'ORA_TG';
--error 600
alter table ora_t2 duplicate_scope = 'CLUSTER';
--error 0
alter table ora_t2 duplicate_scope = 'CLUSTER' tablegroup = '';


--echo
--echo ########################################
--echo ############ other tenant ##############
--echo ########################################
--echo # duplicate table is not allowed in sys tenant
connection conn_sys;
--error 1235
create table sys_t1(c1 int) duplicate_scope = 'CLUSTER';
create table sys_t1(c1 int) duplicate_scope = 'NONE';
--error 1235
alter table sys_t1 duplicate_scope = 'CLUSTER';
# meta tenant can't create table