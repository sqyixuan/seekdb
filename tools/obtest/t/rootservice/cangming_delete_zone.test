# CASE_OWNER:
#    @cangming.zl
# CASE_DESC:
#    非空非stop的zone不允许delete

ob1=OBI(cluster=2:2:2,proxy_num=0,init_unit_cpu=0);
ob1.z3.obs0.set status=disable;
ob1.z3.obs1.set status=disable;
ob1.reboot;
ob1.z3.add;
ob1.z3.start_zone;
ob1.z3.obs0.set status=enable;
ob1.z3.obs0.start;
ob1.z3.obs0.add;
ob1.z3.obs1.set status=enable;
ob1.z3.obs1.start;
ob1.z3.obs1.add;

let $tt1ip = deploy_get_value(ob1.z1.obs0.ip);
let $tt1port= deploy_get_value(ob1.z1.obs0.mysql_port);
connect(tt1_conn, $tt1ip, root,,oceanbase, $tt1port);
connection tt1_conn;
alter system set balancer_idle_time = '10s';
ob1.check_until_timeout select count(*) from __all_server where zone='z3' and status = 'active', 2, 60;
################
# case 1: not empty zone can not be deleted
################
select name, info from __all_zone where zone = 'z3' and name = 'status';
select status from __all_server where zone='z3' order by status;

--error 4668
alter system delete zone z3;

# delete one server of z3
ob1.z3.obs0.delete;
ob1.check_until_timeout select count(*) c from oceanbase.__all_server where zone = 'z3', 1, 600;
select status from __all_server where zone='z3' order by status;
--error 4668
alter system delete zone z3;

ob1.z3.obs1.force_stop;
ob1.check_until_timeout select count(*) from oceanbase.__all_server where zone = 'z3' and status != 'active', 1, 60;
select status from __all_server where zone='z3' order by status;
--error 4668
alter system delete zone z3;

ob1.z3.obs1.delete;
ob1.check_until_timeout select count(*) c from oceanbase.__all_server where zone = 'z3', 0, 600;
select status from __all_server where zone='z3' order by status;

# alive zone can not be deleted
--error 4633
alter system delete zone z3;
select name, info from __all_zone where zone = 'z3' and name = 'status';
alter system stop zone z3;
select name, info from __all_zone where zone = 'z3' and name = 'status';
alter system delete zone z3;

select * from __all_zone where zone = 'z3';
