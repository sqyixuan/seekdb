#######################################################################################
# CASE_OWNER:
#    @jingyu.cr
# CASE_DESC:
#    This case is aimed to test SYS ddl scheudler can work without switch to leader
#
#######################################################################################
ob1=OBI(cluster=1:1:1,proxy_num=0,init_unit_cpu=0);
source include/mini_ob_config.inc;
ob1.set extra_config=$mini_ob_config;
ob1.reboot;

ob1.mysql alter system set debug_sync_timeout = '1000s';
ob1.mysql ALTER SYSTEM SET enable_rebalance = 'false';
ob1.mysql ALTER SYSTEM SET enable_rereplication = 'true';

let $proxy_ip = deploy_get_value(ob1.z1.obs0.ip);
let $proxy_port = deploy_get_value(ob1.z1.obs0.mysql_port);
let $proxy_ip2 = deploy_get_value(ob1.z2.obs0.ip);
let $proxy_port2 = deploy_get_value(ob1.z2.obs0.mysql_port);
connect(sys_conn, $proxy_ip, root@sys,,oceanbase, $proxy_port);

--echo =============================================
--echo               create mysql tenant
--echo =============================================
source include/create_unit_config.inc;
ob1.mysql CREATE RESOURCE POOL mysql_pool UNIT = "2c2g", UNIT_NUM = 1, ZONE_LIST = ('z1', 'z2', 'z3');
ob1.mysql CREATE TENANT mysql RESOURCE_POOL_LIST=('mysql_pool'), LOCALITY = "F@z1, F@z2, F@z3", PRIMARY_ZONE = "z1" SET ob_tcp_invited_nodes='%';

let $tenant_id = deploy_get_value(ob1.select SELECT tenant_id FROM oceanbase.DBA_OB_TENANTS WHERE tenant_name = "mysql", tenant_id, 1);
let $meta_tenant_id = deploy_get_value(ob1.select select tenant_id - 1 as meta_tenant_id from oceanbase.DBA_OB_TENANTS where tenant_name = "mysql", meta_tenant_id, 1);
let $resource_pool_id = deploy_get_value(ob1.select SELECT resource_pool_id FROM oceanbase.__all_resource_pool WHERE tenant_id = $tenant_id, resource_pool_id, 1);

# get servers' addr in z1, z2 and z3
let $z1_dst_ip0 = deploy_get_value(ob1.z1.obs0.ip);
let $z1_dst_port0 = deploy_get_value(ob1.z1.obs0.port);
let $z1_dst0 = $z1_dst_ip0:$z1_dst_port0;
let $z2_dst_ip0 = deploy_get_value(ob1.z2.obs0.ip);
let $z2_dst_port0 = deploy_get_value(ob1.z2.obs0.port);
let $z2_dst0 = $z2_dst_ip0:$z2_dst_port0;
let $z3_dst_ip0 = deploy_get_value(ob1.z3.obs0.ip);
let $z3_dst_port0 = deploy_get_value(ob1.z3.obs0.port);
let $z3_dst0 = $z3_dst_ip0:$z3_dst_port0;

--echo ==============================================
--echo              switch leader to z2
--echo ==============================================
alter tenant sys primary_zone = "z2;z1;z3";
ob1.check_until_timeout select count(*) as cnt from oceanbase.__all_virtual_core_meta_table where role = 1 and svr_ip = "$z2_dst_ip0" and svr_port = $z2_dst_port0, 1, 200;

--echo ====================================================
--echo    create index under mysql with sys leader in z2
--echo ====================================================
connect(mysql_conn1, $proxy_ip, root@mysql,,test, $proxy_port);
connection mysql_conn1;
create table t1(c1 int);
insert into t1 values (1), (2), (3);
--echo expect 3 lines
select * from t1;
create index t1_index1 on t1(c1);
drop index t1_index1 on t1;

connect(mysql_conn2, $proxy_ip2, root@mysql,,test, $proxy_port2);
connection mysql_conn2;
create table t2(c1 int);
insert into t2 values (1), (2), (3);
--echo expect 3 lines
select * from t2;
create index t2_index1 on t2(c1);
drop index t2_index1 on t2;

--echo ==============================================
--echo              switch leader to z1
--echo ==============================================
connect(sys_conn, $proxy_ip, root@sys,,oceanbase, $proxy_port);
connection sys_conn;
alter tenant sys primary_zone = "z1;z2;z3";
ob1.check_until_timeout select count(*) as cnt from oceanbase.__all_virtual_core_meta_table where role = 1 and svr_ip = "$z1_dst_ip0" and svr_port = $z1_dst_port0, 1, 200;

--echo ==================================================
--echo   create index under mysql with sys leader in z1
--echo ==================================================
connect(mysql_conn1, $proxy_ip, root@mysql,,test, $proxy_port);
connection mysql_conn1;
create table t3(c1 int);
insert into t3 values (1), (2), (3);
--echo expect 3 lines
select * from t3;
create index t3_index1 on t3(c1);
drop index t3_index1 on t3;

connect(mysql_conn2, $proxy_ip2, root@mysql,,test, $proxy_port2);
connection mysql_conn2;
create table t4(c1 int);
insert into t4 values (1), (2), (3);
--echo expect 3 lines
select * from t4;
create index t4_index1 on t4(c1);
drop index t4_index1 on t4;

--echo ==============================================
--echo                restart cluster
--echo ==============================================
connect(sys_conn, $proxy_ip, root@sys,,oceanbase, $proxy_port);
connection sys_conn;
ob1.restart;
sleep 30;
ob1.check_until_timeout select count(*) as cnt from oceanbase.__all_server where start_service_time > 0, 3, 60;
ob1.check_until_timeout select count(*) as cnt from oceanbase.__all_virtual_server_schema_info as a join oceanbase.__all_virtual_server_schema_info as b on a.tenant_id = b.tenant_id  where (a.refreshed_schema_version != b.refreshed_schema_version or a.refreshed_schema_version % 8 != 0) and a.tenant_id = 1, 0, 120;
connect(sys_conn, $proxy_ip, root@sys,,oceanbase, $proxy_port);
connection sys_conn;
sleep 20;
alter system set internal_sql_execute_timeout = '200s';

--echo =============================================
--echo      create index after cluster restart
--echo =============================================
connect(mysql_conn1, $proxy_ip, root@mysql,,test, $proxy_port);
connection mysql_conn1;
create table t5(c1 int);
insert into t5 values (1), (2), (3);
--echo expect 3 lines
select * from t5;
create index t5_index1 on t5(c1);
drop index t5_index1 on t5;

connect(mysql_conn2, $proxy_ip2, root@mysql,,test, $proxy_port2);
connection mysql_conn2;
create table t6(c1 int);
insert into t6 values (1), (2), (3);
--echo expect 3 lines
select * from t6;
create index t6_index1 on t6(c1);
drop index t6_index1 on t6;

--echo ==============================================
--echo              switch leader to z2 again
--echo ==============================================
connect(sys_conn, $proxy_ip, root@sys,,oceanbase, $proxy_port);
connection sys_conn;
alter tenant sys primary_zone = "z2;z1;z3";
ob1.check_until_timeout select count(*) as cnt from oceanbase.__all_virtual_core_meta_table where role = 1 and svr_ip = "$z2_dst_ip0" and svr_port = $z2_dst_port0, 1, 200;

--echo ======================================================================
--echo           create index under mysql with sys leader in z2 again
--echo ======================================================================
connect(mysql_conn1, $proxy_ip, root@mysql,,test, $proxy_port);
connection mysql_conn1;
create table t7(c1 int);
insert into t7 values (1), (2), (3);
--echo expect 3 lines
select * from t7;
create index t7_index1 on t7(c1);
drop index t7_index1 on t7;

connect(mysql_conn2, $proxy_ip2, root@mysql,,test, $proxy_port2);
connection mysql_conn2;
create table t8(c1 int);
insert into t8 values (1), (2), (3);
--echo expect 3 lines
select * from t8;
create index t8_index1 on t8(c1);
drop index t8_index1 on t8;

--echo ==============================================
--echo              switch leader to z1 again
--echo ==============================================
connect(sys_conn, $proxy_ip, root@sys,,oceanbase, $proxy_port);
connection sys_conn;
alter tenant sys primary_zone = "z1;z2;z3";
ob1.check_until_timeout select count(*) as cnt from oceanbase.__all_virtual_core_meta_table where role = 1 and svr_ip = "$z1_dst_ip0" and svr_port = $z1_dst_port0, 1, 200;

--echo ======================================================================
--echo           create index under mysql with sys leader in z1 again
--echo ======================================================================
connect(mysql_conn1, $proxy_ip, root@mysql,,test, $proxy_port);
connection mysql_conn1;
create table t9(c1 int);
insert into t9 values (1), (2), (3);
--echo expect 3 lines
select * from t9;
create index t9_index1 on t9(c1);
drop index t9_index1 on t9;

connect(mysql_conn2, $proxy_ip2, root@mysql,,test, $proxy_port2);
connection mysql_conn2;
create table t10(c1 int);
insert into t10 values (1), (2), (3);
--echo expect 3 lines
select * from t10;
create index t10_index1 on t10(c1);
drop index t10_index1 on t10;

