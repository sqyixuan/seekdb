# CASE_OWNER:
#    @cangming.zl
# CASE_DESC:
#    alter system start/stop server命令功能测试
#
#用例场景：
#1. 不带zone参数的测试
####1.1 单个server的测试
########1.1.1 start处于start状态的server
########1.1.2 stop处于start状态的server
########1.1.3 stop处于stop状态的server
########1.1.4 start处于stop状态的server
########1.1.5 start不存在的server
########1.1.6 stop不存在的server
####1.2 多个server的测试
########1.2.1 start两个处于start状态的server
########1.2.2 stop两个处于start状态的server
########1.2.3 stop两个处于stop状态的server
########1.2.4 start两个处于stop状态的server
#2. 带zone参数的测试
####2.1 server和zone匹配的测试
########2.1.1 start一个处于start状态的server
########2.1.2 stop一个处于start状态的server
########2.1.3 stop一个处于stop状态的server
########2.1.4 start一个处于stop状态的server
####2.2 server和zone不匹配的测试
########2.2.1 start一个不在zone里面的server
########2.2.2 stop一个不在zone里面的server
########2.2.3 start两个不在zone里面的server
########2.2.4 stop两个不在zone里面的server
########2.2.5 start两个存在的server，但zone不存在
########2.2.6 stop两个存在的server，但zone不存在
########2.2.7 stop一个在zone里面的server，另一个不在zone里面的server
########2.2.8 start一个在zone里面的server，另一个不在zone里面的server

##construct the cluster
ob1=OBI(cluster=2:2:2, proxy_num = 0);
ob1.z1.obs1.set status=disable;
ob1.z2.obs1.set status=disable;
ob1.z3.obs1.set status=disable;
ob1.reboot;

sleep 3;

ob1.z1.obs1.set status=enable;
ob1.z2.obs1.set status=enable;
ob1.z3.obs1.set status=enable;
ob1.z1.obs1.start;
ob1.z2.obs1.start;
ob1.z3.obs1.start;

ob1.z1.obs1.check_log_until_success -c "weak read service thread start";
ob1.z2.obs1.check_log_until_success -c "weak read service thread start";
ob1.z3.obs1.check_log_until_success -c "weak read service thread start";
ob1.z1.obs1.add;
ob1.z2.obs1.add;
ob1.z3.obs1.add;

ob1.check_until_timeout SELECT COUNT(*) c FROM DBA_OB_SERVERS WHERE START_SERVICE_TIME > 0, 6, 200;

ob1.mysql set global ob_query_timeout = 30000000;

ob1.mysql CREATE RESOURCE UNIT test MAX_CPU 2, MEMORY_SIZE '4G';

##create the tenant
ob1.mysql CREATE RESOURCE POOL pool1 UNIT = 'test', UNIT_NUM = 2, ZONE_LIST = ('z1', 'z2', 'z3');
ob1.mysql CREATE TENANT tenant RESOURCE_POOL_LIST = ('pool1') set ob_tcp_invited_nodes='%';
ob1.check_until_timeout select count(*) as cnt from oceanbase.CDB_OB_LS_LOCATIONS where role = "LEADER", 9, 120;
ob1.check_until_timeout select count(*) as cnt from oceanbase.__all_virtual_log_stat where role = "LEADER" and in_sync = 1, 9, 120;

#wait for config taking effect
sleep 2;

##create the table
let $tenant_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name = 'tenant', tenant_id, 1);
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_server_schema_info where refreshed_schema_version = received_schema_version and tenant_id = $tenant_id, 6, 20;
ob_connect(conn1, ob1.z1.obs0, root@tenant, , oceanbase, , USE_MYSQL_CONNECTOR);
connection conn1;
CREATE DATABASE db;
use db;

CREATE TABLE table1 (pk int, value int, primary key(pk));
ob_connect(conn_root, ob1.z1.obs0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);
connection conn_root;

#############
##case 1.1.1 start处于start状态的server
#############
echo case 1.1.1;
let $table_id = deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where table_name = 'table1' and tenant_id = $tenant_id, table_id, 1);
let $tablet_id = deploy_get_value(ob1.select select tablet_id from oceanbase.__all_virtual_tablet_to_table_history where tenant_id = $tenant_id and table_id = $table_id, tablet_id, 1);
let $ls_id = deploy_get_value(ob1.select select ls_id from oceanbase.CDB_OB_TABLET_TO_LS where tenant_id = $tenant_id and tablet_id =$tablet_id, ls_id, 1);
let $leader = deploy_get_value(ob1.select select concat(svr_ip,":",svr_port) src from oceanbase.__all_virtual_ls_meta_table where tenant_id = $tenant_id and ls_id = $ls_id and role = 1, src, 1);
let $leader_ip = deploy_get_value(ob1.select select svr_ip src from oceanbase.__all_virtual_ls_meta_table where tenant_id = $tenant_id and ls_id = $ls_id and role = 1, src, 1);
let $leader_port = deploy_get_value(ob1.select select svr_port src from oceanbase.__all_virtual_ls_meta_table where tenant_id = $tenant_id and ls_id = $ls_id and role = 1, src, 1);

ob1.mysql alter system start server '$leader_ip:$leader_port';

#############
##case 1.1.2 stop处于start状态的server
#############
echo case 1.1.2;
ob1.mysql alter system stop server '$leader_ip:$leader_port';
ob1.check_until_timeout select count(*) from oceanbase.__all_server where stop_time > 0, 1, 10;

let $ip = $leader_ip;
let $port = $leader_port;
source include/get_server_stop_time.inc;
source include/get_server_leader_count.inc;

#############
##case 1.1.3 stop处于stop状态的server
#############
echo case 1.1.3;
ob1.mysql alter system stop server '$leader_ip:$leader_port';

let $ip = $leader_ip;
let $port = $leader_port;
source include/get_server_stop_time.inc;
source include/get_server_leader_count.inc;

#############
##case 1.1.4 start处于stop状态的server
#############
echo case 1.1.4;
ob1.mysql alter system start server '$leader_ip:$leader_port';
ob1.check_until_timeout select count(*) from oceanbase.__all_server where start_service_time > 0 and status = 'ACTIVE', 6, 100;
let $zone = deploy_get_value(ob1.select select zone from oceanbase.__all_server where svr_ip = "$leader_ip" and svr_port = $leader_port, zone, 1);
ob1.check_until_timeout select count(*) from __all_virtual_ls_meta_table where role != 1 and zone = "$zone" and (tenant_id, ls_id) in (select tenant_id, ls_id from __all_virtual_ls_election_reference_info where zone_priority like "$zone;%"), 0, 120;

let $ip = $leader_ip;
let $port = $leader_port;
source include/get_server_stop_time.inc;

#############
##case 1.1.5 start不存在的server
#############
echo case 1.1.5;
let $invalid_obs_ip = 127.0.0.1;
let $invalid_obs_port = 80;
--error 4630
eval alter system start server '$invalid_obs_ip:$invalid_obs_port';

#############
##case 1.1.6 stop不存在的server
#############
echo case 1.1.6;
--error 4018
eval alter system stop server '$invalid_obs_ip:$invalid_obs_port';

#############
##case 1.2.1 start两个处于start状态的server
#############
echo case 1.2.1;
let $server1 = ob1.z2.obs0;
let $server2 = ob1.z2.obs1;

let $server1_ip = deploy_get_value($server1.ip);
let $server1_port = deploy_get_value($server1.port);
let $server2_ip = deploy_get_value($server2.ip);
let $server2_port = deploy_get_value($server2.port);

ob1.mysql alter system start server '$server1_ip:$server1_port', '$server2_ip:$server2_port';
let $zone = deploy_get_value(ob1.select select zone from oceanbase.__all_server where svr_ip = "$server1_ip" and svr_port = $server1_port, zone, 1);
ob1.check_until_timeout select count(*) from __all_virtual_ls_meta_table where role != 1 and zone = "$zone" and (tenant_id, ls_id) in (select tenant_id, ls_id from __all_virtual_ls_election_reference_info where zone_priority like "$zone;%"), 0, 120;
let $zone = deploy_get_value(ob1.select select zone from oceanbase.__all_server where svr_ip = "$server2_ip" and svr_port = $server2_port, zone, 1);
ob1.check_until_timeout select count(*) from __all_virtual_ls_meta_table where role != 1 and zone = "$zone" and (tenant_id, ls_id) in (select tenant_id, ls_id from __all_virtual_ls_election_reference_info where zone_priority like "$zone;%"), 0, 120;

let $ip = $server1_ip;
let $port = $server1_port;
source include/get_server_stop_time.inc;

let $ip = $server2_ip;
let $port = $server2_port;
source include/get_server_stop_time.inc;


#############
##case 1.2.2 stop两个处于start状态的server
#############
echo case 1.2.2;
ob1.mysql alter system stop server '$server1_ip:$server1_port', '$server2_ip:$server2_port';
ob1.check_until_timeout select count(*) from oceanbase.__all_server where stop_time > 0, 2, 10;

let $ip = $server1_ip;
let $port = $server1_port;
source include/get_server_stop_time.inc;
source include/get_server_leader_count.inc;

let $ip = $server2_ip;
let $port = $server2_port;
source include/get_server_stop_time.inc;
source include/get_server_leader_count.inc;

#############
##case 1.2.3 stop两个处于stop状态的server
#############
echo case 1.2.3;
ob1.mysql alter system stop server '$server1_ip:$server1_port', '$server2_ip:$server2_port';
let $ip = $server1_ip;
let $port = $server1_port;
source include/get_server_stop_time.inc;
source include/get_server_leader_count.inc;

let $ip = $server2_ip;
let $port = $server2_port;
source include/get_server_stop_time.inc;
source include/get_server_leader_count.inc;

#############
##case 1.2.4 start两个处于stop状态的server
#############
echo case 1.2.4;
ob1.mysql alter system start server '$server1_ip:$server1_port', '$server2_ip:$server2_port';
ob1.check_until_timeout select count(*) from oceanbase.__all_server where start_service_time > 0 and status = 'ACTIVE', 6, 100;
let $zone = deploy_get_value(ob1.select select zone from oceanbase.__all_server where svr_ip = "$server1_ip" and svr_port = $server1_port, zone, 1);
ob1.check_until_timeout select count(*) from __all_virtual_ls_meta_table where role != 1 and zone = "$zone" and (tenant_id, ls_id) in (select tenant_id, ls_id from __all_virtual_ls_election_reference_info where zone_priority like "$zone;%"), 0, 120;
let $zone = deploy_get_value(ob1.select select zone from oceanbase.__all_server where svr_ip = "$server2_ip" and svr_port = $server2_port, zone, 1);
ob1.check_until_timeout select count(*) from __all_virtual_ls_meta_table where role != 1 and zone = "$zone" and (tenant_id, ls_id) in (select tenant_id, ls_id from __all_virtual_ls_election_reference_info where zone_priority like "$zone;%"), 0, 120;

let $ip = $server1_ip;
let $port = $server1_port;
source include/get_server_stop_time.inc;

let $ip = $server2_ip;
let $port = $server2_port;
source include/get_server_stop_time.inc;

#############
##case 2.1.1 start一个处于start状态的server
#############
echo case 2.1.1;
let $obs = ob1.z2.obs0;
let $obs_ip = deploy_get_value($obs.ip);
let $obs_port = deploy_get_value($obs.port);
let $zone = z2;
ob1.mysql alter system start server '$obs_ip:$obs_port' zone '$zone';
let $zone = deploy_get_value(ob1.select select zone from oceanbase.__all_server where svr_ip = "$obs_ip" and svr_port = $obs_port, zone, 1);
ob1.check_until_timeout select count(*) from __all_virtual_ls_meta_table where role != 1 and zone = "$zone" and (tenant_id, ls_id) in (select tenant_id, ls_id from __all_virtual_ls_election_reference_info where zone_priority like "$zone;%"), 0, 120;

let $ip = $obs_ip;
let $port = $obs_port;
source include/get_server_stop_time.inc;

#############
##case 2.1.2 stop一个处于start状态的server
#############
echo case 2.1.2;
ob1.mysql alter system stop server '$obs_ip:$obs_port' zone '$zone';
ob1.check_until_timeout select count(*) from oceanbase.__all_server where stop_time > 0, 1, 10;

let $ip = $obs_ip;
let $port = $obs_port;
source include/get_server_stop_time.inc;
source include/get_server_leader_count.inc;

#############
##case 2.1.3 stop一个处于stop状态的server
#############
echo case 2.1.3;
ob1.mysql alter system stop server '$obs_ip:$obs_port' zone '$zone';

let $ip = $obs_ip;
let $port = $obs_port;
source include/get_server_stop_time.inc;
source include/get_server_leader_count.inc;

#############
##case 2.1.4 start一个处于stop状态的server
#############
echo case 2.1.4;
ob1.mysql alter system start server '$obs_ip:$obs_port' zone '$zone';
ob1.check_until_timeout select count(*) from oceanbase.__all_server where start_service_time > 0 and status = 'ACTIVE', 6, 100;
let $zone = deploy_get_value(ob1.select select zone from oceanbase.__all_server where svr_ip = "$obs_ip" and svr_port = $obs_port, zone, 1);
ob1.check_until_timeout select count(*) from __all_virtual_ls_meta_table where role != 1 and zone = "$zone" and (tenant_id, ls_id) in (select tenant_id, ls_id from __all_virtual_ls_election_reference_info where zone_priority like "$zone;%"), 0, 120;

let $ip = $obs_ip;
let $port = $obs_port;
source include/get_server_stop_time.inc;

#############
##case 2.2.1 start一个不在zone里面的server
#############
echo case 2.2.1;
let $obs = ob1.z1.obs0;
let $zone = z2;
let $obs_ip = deploy_get_value($obs.ip);
let $obs_port = deploy_get_value($obs.port);
--disable_query_log
--error 4631
eval alter system start server '$obs_ip:$obs_port' zone '$zone';
--enable_query_log

#############
##case 2.2.2 stop一个不在zone里面的server
#############
echo case 2.2.2;
--disable_query_log
--error 4631
eval alter system stop server '$obs_ip:$obs_port' zone '$zone';
--enable_query_log

#############
##case 2.2.3 start两个不在zone里面的server
#############
echo case 2.2.3;
let $obs1 = ob1.z1.obs0;
let $obs2 = ob1.z1.obs1;
let $zone = z2;
let $obs1_ip = deploy_get_value($obs1.ip);
let $obs1_port = deploy_get_value($obs1.port);
let $obs2_ip = deploy_get_value($obs2.ip);
let $obs2_port = deploy_get_value($obs2.port);
--disable_query_log
--error 4631
eval alter system start server '$obs1_ip:$obs1_port', '$obs2_ip:$obs2_port' zone '$zone';
--enable_query_log

#############
##case 2.2.4 stop两个不在zone里面的server
#############
echo case 2.2.4;
--disable_query_log
--error 4631
eval alter system stop server '$obs1_ip:$obs1_port', '$obs2_ip:$obs2_port' zone '$zone';
--enable_query_log

#############
##case 2.2.5 start两个存在的server，但zone不存在
#############
echo case 2.2.5;
let $invalid_zone = invalid_zone;
--disable_query_log
--error 4631
eval alter system start server '$obs1_ip:$obs1_port', '$obs2_ip:$obs2_port' zone '$invalid_zone';
--enable_query_log

#############
##case 2.2.6 stop两个存在的server，但zone不存在
#############
echo case 2.2.6;
--disable_query_log
--error 4631
eval alter system stop server '$obs1_ip:$obs1_port', '$obs2_ip:$obs2_port' zone '$invalid_zone';
--enable_query_log

#############
##case 2.2.7 stop一个在zone里面的server，另一个不在zone里面的server
##结果应该为两个server都没被stop，因为第一个server stop失败然后退出
#############
echo case 2.2.7;
let $obs1 = ob1.z1.obs1;
let $obs2 = ob1.z2.obs0;
let $zone = z2;
let $obs1_ip = deploy_get_value($obs1.ip);
let $obs1_port = deploy_get_value($obs1.port);
let $obs2_ip = deploy_get_value($obs2.ip);
let $obs2_port = deploy_get_value($obs2.port);
--disable_query_log
--error 4631
eval alter system stop server '$obs1_ip:$obs1_port' zone '$zone';
--error 4179,4660,4631
eval alter system stop server '$obs1_ip:$obs1_port', '$obs2_ip:$obs2_port' zone '$zone';
--enable_query_log

#check obs2 is stopped
let $ip = $obs2_ip;
let $port = $obs2_port;
source include/get_server_stop_time.inc;
source include/get_server_leader_count.inc;

#############
##case 2.2.8 start一个在zone里面的server，另一个不在zone里面的server
##结果应该为两个server都没被start，因为第一个server start失败然后退出
##但是两个server本来就是start状态
#############
--disable_query_log
--error 4631
eval alter system start server '$obs1_ip:$obs1_port', '$obs2_ip:$obs2_port' zone '$zone';
--enable_query_log

#check obs2 is started
let $ip = $obs2_ip;
let $port = $obs2_port;
source include/get_server_stop_time.inc;
