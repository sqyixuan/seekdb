#eval create table wenduo_hehe(pk int primary key, c int) tablegroup wenduo primary_zone=DEFAULT;
#eval create table wenduo_hehe2(pk int primary key, c int) tablegroup wenduo primary_zone="z2";

connection conn_sys;
## 在alter tenant的primary zone时，本身不会查tenant和其下面的table/tg/database是否跨region
## 原因是，集群从一个region搬到另一个region过程中，一定会有这种操作。我们仅从下向上保证匹配
--error 1235
eval alter tenant tt1 primary_zone="RANDOM";
eval alter tenant tt1 primary_zone="z4";
connection conn_sys;
eval drop tenant tt1 force;
eval drop resource pool tt1_pool;

