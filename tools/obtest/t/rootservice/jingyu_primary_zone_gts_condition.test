# CASE_OWNER:
#    @jingyu.cr
# CASE_DESC:
#    用于系统租户的locality变更测试
#    部署：
#    5台observer，每台server一个zone：z1~z5
#    部署在5个机房：部署在两个region内，z1,z2,z3在HZ, z4,z5在SH。
#    起初启动三个zone: z1, z2, z3; 系统租户的locality初始为F@z1,F@z2,F@z3;
#    而后加上后两个zone: z4, z5

ob1=OBI(cluster=1:1:1:1:1,proxy_num=0,init_unit_cpu=0,locality=HZ:HZ:HZ:SH:SH);

ob1.reboot;

ob_connect(conn_sys, ob1.z1.obs0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);
# tenant的primary zone
connection conn_sys;

eval CREATE RESOURCE UNIT tenant_config MAX_CPU 2, MEMORY_SIZE '2G';

eval create resource pool tt1_pool unit = 'tenant_config', unit_num = 1, zone_list = ('z1','z2','z3','z4','z5');
--error 1235
eval create tenant tt1 resource_pool_list=('tt1_pool') set ob_tcp_invited_nodes='%';
## 多region情况下，不能是random
--error 1235
eval create tenant tt1 resource_pool_list=('tt1_pool'), primary_zone = "RANDOM" set ob_tcp_invited_nodes='%';
## z1, z4在不同region内
--error 1235
eval create tenant tt1 resource_pool_list=('tt1_pool'), primary_zone = "z1,z4" set ob_tcp_invited_nodes='%';
set @@session.ob_query_timeout = 20000000;
eval create tenant tt1 resource_pool_list=('tt1_pool'), primary_zone = "z1" set ob_tcp_invited_nodes='%';
## 多region情况下，不能是random
--error 1235
eval alter tenant tt1 primary_zone="RANDOM";
--error 1235
eval alter tenant tt1 primary_zone="z1,z4";
eval alter tenant tt1 primary_zone="z1,z2";
eval alter tenant tt1 primary_zone="z4,z5";
eval alter tenant tt1 primary_zone="z1";

ob_connect(conn_tt1, ob1.z1.obs0, root@tt1, , oceanbase, , USE_MYSQL_CONNECTOR);
#database primary not supported
## databaase的primary zone
