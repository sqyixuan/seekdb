# owner:shanyan.g
# owner group:transaction
# description:
# 测试点：redo log因为内存问题回放失败，重试回放场景下的正确性验证
##
ob1=OBI(cluster=1:1,proxy_num=0,init_unit_cpu=5);
ob1.reboot;
sleep 10;

#在zone1上建立连接
let $l_ip=deploy_get_value(ob1.z1.obs0.ip);
let $l_port=deploy_get_value(ob1.z1.obs0.mysql_port);
connect (conn1,$l_ip,root@obtest,,test,$l_port);
connect (conn2,$l_ip,root@sys,,oceanbase,$l_port);

connection conn2;
alter system set enable_auto_leader_switch = false;

connection conn1;
use test;
drop table if exists t1;
drop table if exists t2;
create table t1(a longtext, b longblob, c longtext);
create table t2(a longtext, b longblob, c longtext, d longtext, e longtext);
sleep 5;

#case1 : 多个普通行的写入，产生多条redo log
connection conn2;
alter system set_tp tp_no = 41, error_code = 4013, frequency = 1;
connection conn1;
begin;
let $i=0;
--disable_query_log
while($i < 20)
{
  insert into t1 values(repeat('a', 524288), repeat('a', 524288), repeat('a', 524288));
  inc $i;
}
--enable_query_log
commit;
sleep 10;
connection conn2;
alter system set_tp tp_no = 41, error_code = 4013, frequency = 0;
alter system major freeze;
ob1.check_version 2;

#case2 : 多个big row的写入，产生多条redo log
alter system set_tp tp_no = 41, error_code = 4013, frequency = 1;
connection conn1;
begin;
let $i=0;
--disable_query_log
while($i < 20)
{
  insert into t2 values(repeat('a', 3242880), repeat('b', 3242880), repeat('c', 3242880), repeat('d', 3242880), repeat('e', 3242880));
  inc $i;
}
--enable_query_log
commit;
sleep 10;
connection conn2;
alter system set_tp tp_no = 41, error_code = 4013, frequency = 0;
alter system major freeze;
ob1.check_version 3;

#case3 : 部分写入普通行，部分写入big row
alter system set_tp tp_no = 41, error_code = 4013, frequency = 1;
connection conn1;
begin;
let $i=0;
--disable_query_log
while($i < 10)
{
  insert into t1 values(repeat('a', 524288), repeat('a', 524288), repeat('a', 524288));
  insert into t2 values(repeat('a', 3242880), repeat('b', 3242880), repeat('c', 3242880), repeat('d', 3242880), repeat('e', 3242880));
  inc $i;
}
--enable_query_log
commit;
sleep 10;
connection conn2;
alter system set_tp tp_no = 41, error_code = 4013, frequency = 0;
alter system major freeze;
ob1.check_version 4;
