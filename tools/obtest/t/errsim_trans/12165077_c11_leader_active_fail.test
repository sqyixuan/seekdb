##
# owner:jingyan.kfy
# owner group:transaction
# description:
# 测试点：
#         测试leader_active由于leader已经切走导致失败的情况下是否能正常推进状态
# 测试场景：切主，事务做leader_active之前切走，观察状态转换是否正常
##
ob1=OBI(cluster=1:1,proxy_num=0);
ob1.reboot;
sleep 5;

ob1.mysql alter system set enable_auto_leader_switch = false;
# ob1.mysql alter system set syslog_io_bandwidth_limit = '1000m';

ob1.create_client;

create database obtest;
use obtest;
create table t1(pk int primary key, c1 int, c2 varchar(20));

sleep 5;

ob1.z1.obs0.switch_partition sys:obtest:t1;
sleep 2;

ob1.z2.obs0.mysql alter system set_tp tp_no = 38, error_code = 4038, frequency = 1;
sleep 2;
ob1.z2.obs0.switch_partition sys:obtest:t1;
sleep 2;
ob1.z2.obs0.mysql alter system set_tp tp_no = 38, error_code = 4038, frequency = 0;
sleep 30;

--disable_query_log
let $tid = query_get_value(select table_id v from oceanbase.__all_virtual_table where table_name='t1', v, 1);
use oceanbase;
eval select partition_state from __all_virtual_partition_info where table_id=$tid order by partition_state;
--enable_query_log
