# owner:shanyan.g
# owner group:transaction
# description:
# 测试点：
# 事务接口调用失败，sql是否会将错误码返回给客户端，验证错误码覆盖的问题
##
ob1=OBI(cluster=1:1,proxy_num=0,init_unit_cpu=5);
ob1.reboot;
sleep 10;

#在zone1上建立连接
let $l_ip1=deploy_get_value(ob1.z1.obs0.ip);
let $l_port1=deploy_get_value(ob1.z1.obs0.mysql_port);
connect (conn1,$l_ip1,root@sys,,oceanbase,$l_port1);
connect (conn2,$l_ip1,root@obtest,,test,$l_port1);

let $svr_ip = deploy_get_value(ob1.select select svr_ip from __all_server where zone = 'z2', svr_ip, 1);
let $svr_port = deploy_get_value(ob1.select select svr_port from __all_server where zone = 'z2', svr_port, 1);
let $host = deploy_get_value(ob1.select select concat(svr_ip, ':', svr_port) host from oceanbase.__all_server where zone='z2', host, 1);
let $observer = deploy_get_value(ob1.get_obs_by_addr $host);

connection conn1;
alter system set enable_auto_leader_switch = false;
connection conn2;
use test;
drop table if exists t1;
create table t1(id1 int, id2 int);
sleep 5;

#############################
#case1 : start_stmt报错
connection conn1;
alter system set_tp tp_no = 43, error_code = 4016, frequency = 1;
sleep 2;
# autocommit＝0的场景
connection conn2;
begin;
--error 4016
insert into t1 values(1, 1);
rollback;
connection conn1;
alter system set_tp tp_no = 43, error_code = 4016, frequency = 0;

# 验证数据
connection conn2;
select * from t1;

# autocommit＝1的场景
connection conn1;
alter system set_tp tp_no = 43, error_code = 4016, frequency = 1;
sleep 2;
alter system set syslog_level='DEBUG';
#--error 4016
connection conn2;
set autocommit=1
insert into t1 values(1, 1);
connection conn1;
alter system set syslog_level='INFO';
alter system set_tp tp_no = 43, error_code = 4016, frequency = 0;

# 验证数据
connection conn2;
select * from t1;

#############################
#case2 : start participant报错
connection conn1;
alter system set_tp tp_no = 44, error_code = 4016, frequency = 1;
sleep 2;
# autocommit＝0的场景
connection conn2;
begin;
--error 4016
insert into t1 values(2, 2);
rollback;
connection conn1;
alter system set_tp tp_no = 44, error_code = 4016, frequency = 0;

# 验证数据
connection conn2;
select * from t1;

# autocommit＝1的场景
connection conn1;
alter system set_tp tp_no = 44, error_code = 4016, frequency = 1;
sleep 2;
#--error 4016
connection conn2;
set autocommit=1
insert into t1 values(2, 2);
connection conn1;
alter system set_tp tp_no = 44, error_code = 4016, frequency = 0;

# 验证数据
connection conn2;
select * from t1;

#############################
#case3 : end_participant报错
connection conn1;
alter system set_tp tp_no = 45, error_code = 4016, frequency = 1;
sleep 2;
# autocommit＝0的场景
connection conn2;
begin;
--error 4016
insert into t1 values(3, 3);
rollback;
connection conn1;
alter system set_tp tp_no = 45, error_code = 4016, frequency = 0;

# 验证数据
connection conn2;
select * from t1;

# autocommit＝1的场景
connection conn1;
alter system set_tp tp_no = 45, error_code = 4016, frequency = 1;
sleep 2;
#--error 4016
connection conn2;
set autocommit=1
insert into t1 values(3, 3);
connection conn1;
alter system set_tp tp_no = 45, error_code = 4016, frequency = 0;

# 验证数据
connection conn2;
select * from t1;

#############################
#case4 : end_stmt报错
connection conn1;
alter system set_tp tp_no = 46, error_code = 4016, frequency = 1;
sleep 2;
# autocommit＝0的场景
connection conn2;
begin;
--error 4016
insert into t1 values(4, 4);
rollback;
connection conn1;
alter system set_tp tp_no = 46, error_code = 4016, frequency = 0;

# 验证数据
connection conn2;
select * from t1;

# autocommit＝1的场景
connection conn1;
alter system set_tp tp_no = 46, error_code = 4016, frequency = 1;
sleep 2;
#--error 4016
connection conn2;
set autocommit=1
insert into t1 values(4, 4);
connection conn1;
alter system set_tp tp_no = 46, error_code = 4016, frequency = 0;

# 验证数据
connection conn2;
select * from t1;
