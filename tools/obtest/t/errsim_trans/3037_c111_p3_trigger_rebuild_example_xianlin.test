##
# owner: xianlin.lh
# owner group: transaction
# description:
# 提供一个trigger rebuild的示例
##
ob1=OBI(cluster=1:1:1, proxy_num=0, init_unit_cpu=0);
ob1.reboot;
sleep 5;

let $leader=deploy_get_value(ob1.get_leader sys:oceanbase:__all_core_table);
let $follower_1=deploy_get_value(ob1.get_follower sys:oceanbase:__all_core_table,1);
let $follower_2=deploy_get_value(ob1.get_follower sys:oceanbase:__all_core_table,2);

let $ip = deploy_get_value($leader.ip);
let $port = deploy_get_value($leader.mysql_port);

connect(conn1, $ip, admin, admin, oceanbase, $port);
connection conn1;

# 新建一张表
create table t1(c1 int, c2 int) primary_zone='z1';

sleep 5;

alter system minor freeze tenant = sys;
alter system minor freeze tenant = all_user;
alter system minor freeze tenant = all_meta;
sleep 15;

# 打开配置项开关，只要落后日志，就会触发rebuild
alter system set trigger_rebuild_on_purpose=true;

# 阻塞leader和一个副本之间的网络
$leader.block_net $follower_1;

# 插入一行数据，leader和follower2形成majority，follower1未收到此日志
insert into t1 values(1, 1);

# 等待日志在leader和follower2形成多数派
sleep 5;

# 恢复网络，follower1会向leader获取日志，leader通知follower1需要执行rebuild；需要sleep 5
$leader.clean_net $follower_1;

# 等待follower1向leader拉取日志，触发rebuild，并汇报到__all_meta_table
sleep 5;

# 预期这张个replica需要执行rebuild
select count(*) from __all_rootservice_event_history where module like "balancer" and value1 like "%1099511677777%" and event like "%finish_rebuild_replica%" ;
