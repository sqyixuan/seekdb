# owner: yongle.xh
# owner group: storage
# description: this case is use for reboot
#
ob1=OBI(cluster=1:1:1,proxy_num=1,init_unit_cpu=2, init_unit_num=1);
ob1.reboot;

ob1.mysql alter system set resource_hard_limit=900;
ob1.mysql alter system set resource_soft_limit=800;
ob1.mysql alter system set debug_sync_timeout = '1000s';
ob1.mysql alter system set enable_auto_leader_switch = 'false';
ob1.mysql alter system set enable_rebalance = 'false';
ob1.mysql alter system set enable_rereplication = 'false';
ob1.mysql alter system set balancer_idle_time = '10s';
ob1.mysql alter system set server_data_copy_out_concurrency = 20;
ob1.mysql alter system set server_data_copy_in_concurrency = 20;

let $z1_obs0_ip  = deploy_get_value(ob1.z1.obs0.ip);
let $z1_obs0_mysql_port = deploy_get_value(ob1.z1.obs0.mysql_port);
let $z1_obs0_addr = deploy_get_value(ob1.z1.obs0.get_addr);

let $cpu = 1;
let $memory = 1073741824;
let $min_memory = 1073741824;
let $disk = 536870912;
let $iops = 100000;
let $session = 64;

ob1.mysql CREATE RESOURCE UNIT unit_1 MAX_CPU $cpu, MAX_MEMORY $memory, MAX_IOPS $iops, MAX_DISK_SIZE $disk, MAX_SESSION_NUM $session, MIN_CPU=1, MIN_MEMORY=$min_memory, MIN_IOPS=128;
ob1.mysql CREATE RESOURCE POOL pool_1 UNIT = 'unit_1', UNIT_NUM = 1, ZONE_LIST = ('z1','z2','z3');
ob1.mysql CREATE TENANT tenant_1 RESOURCE_POOL_LIST = ('pool_1'), primary_zone = 'z1;z2,z3', locality='F{1}@z1,F{1}@z2,F{1}@z3' set ob_tcp_invited_nodes='%';
sleep 5;

connect (conn_z1,$z1_obs0_ip,root@tenant_1,,test,$z1_obs0_mysql_port);
connection conn_z1;

use test;
create table t1(c1 int primary key, c2 int) partition by hash(c1) partitions 2;
let $tenant_id=deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name='tenant_1', tenant_id, 1);
let $t1_id = deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where tenant_id = "$tenant_id" and table_name = "t1", table_id, 1);
ob1.mysql alter system set enable_rebalance = 'true';
ob1.mysql alter system set enable_rereplication = 'true';

ob1.mysql alter tenant tenant_1 set locality = "F{1}@z1,F{1}@z2,L{1}@z3";
ob1.check_until_timeout select count(*) from oceanbase.__all_rootservice_job where job_status='SUCCESS', 1, 120;
ob1.check_until_timeout select count(*) from oceanbase.gv\$partition where tenant_id = "$tenant_id" and table_id = "$t1_id" and partition_id = 0 and zone = 'z3' and replica_type = 5, 1, 120;
sleep 2;

#ob1.z3.restart;
#sleep 20;
#ob1.check_until_timeout select status from oceanbase.__all_server where zone='z3', active, 200; 
ob1.mysql alter system major freeze;
ob1.check_version 2;


ob1.mysql alter tenant tenant_1 set locality = "F{1}@z1,F{1}@z2";
ob1.check_until_timeout select count(*) from oceanbase.__all_rootservice_job where job_status='SUCCESS', 2, 120;
ob1.mysql alter tenant tenant_1 set locality = "F{1}@z1,F{1}@z2,F{1}@z3";
ob1.check_until_timeout select count(*) from oceanbase.__all_rootservice_job where job_status='SUCCESS', 3, 120;
ob1.check_until_timeout select count(*) from oceanbase.gv\$partition where tenant_id = "$tenant_id" and table_id = "$t1_id" and partition_id = 0 and zone = 'z3' and replica_type = 0, 1, 120;
sleep 2;
#ob1.z3.restart;
#sleep 20;
#ob1.check_until_timeout select status from oceanbase.__all_server where zone='z3', active, 200; 

ob1.mysql alter system major freeze;
ob1.check_version 3;
