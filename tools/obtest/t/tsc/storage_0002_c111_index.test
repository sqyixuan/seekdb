# owner: shanyan.g
# owner group: trans
# description:this case is use for test copy index after merge
#
--disable_query_log
ob1=OBI(cluster=1:1:1,proxy_num=0,init_unit_cpu=2);

ob1.reboot;

ob1.mysql create resource pool rp1 unit = 'sys_unit_config', unit_num = 1, zone_list = ('z1', 'z2', 'z3');
ob1.mysql create tenant tt1 replica_num 3, primary_zone 'z1', resource_pool_list ('rp1'), locality = "F{1,memstore_percent:100}@z1,F{1,memstore_percent:0}@z2,L@z3" set ob_tcp_invited_nodes='%';

ob1.mysql alter system set merger_check_interval='10s';
ob1.mysql alter system set enable_rebalance = 'false';
ob1.mysql alter system set enable_auto_leader_switch=true;
ob1.mysql alter system set resource_hard_limit=500;
ob1.mysql alter tenant obtest primary_zone='z1';

#在zone1上建立连接
let $ip=deploy_get_value(ob1.z1.obs0.ip);
let $port=deploy_get_value(ob1.z1.obs0.mysql_port);
connect (conn1,$ip,admin@obtest,admin,oceanbase,$port);
connect (conn2,$ip,root@sys,,oceanbase,$port);
connect (conn3,$ip,root@tt1,,test,$port);

#普通副本上建索引
sleep 5;
connection conn1;
use test;
create tablegroup tg1 binding true;
create table t1(id1 int, id2 int) tablegroup tg1;

create tablegroup tg2 binding true;
create table t2(id1 int, id2 int) tablegroup tg2;
create table t3(id1 int, id2 int) tablegroup tg2;

let $cnt =0;

while ($cnt < 10)
{
  eval insert into t1 values($cnt, $cnt);
  eval insert into t2 values($cnt, $cnt);
  eval insert into t3 values($cnt, $cnt);
  inc $cnt;
}

ob1.mysql alter system major freeze;
ob1.check_until_timeout select value from __all_zone where zone='' and name='last_merged_version', 2,3600;

while ($cnt < 20)
{
  eval insert into t1 values($cnt, $cnt);
  eval insert into t2 values($cnt, $cnt);
  eval insert into t3 values($cnt, $cnt);
  inc $cnt;
}

select * from t1;
select * from t2;
select * from t3;
create index pg_index1 on t1(id1);
create index pg_index2 on t2(id1);
create index pg_index3 on t3(id1);

let $table_id=deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where table_name like '%pg_index1%', table_id, 1);
ob1.check_until_timeout select index_status from oceanbase.__all_virtual_table where table_id=$table_id, 2, 3600;

let $table_id=deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where table_name like '%pg_index2%', table_id, 1);
ob1.check_until_timeout select index_status from oceanbase.__all_virtual_table where table_id=$table_id, 2, 3600;

let $table_id=deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where table_name like '%pg_index3%', table_id, 1);
ob1.check_until_timeout select index_status from oceanbase.__all_virtual_table where table_id=$table_id, 2, 3600;

#验证FDL建索引
connection conn3;
use test;
create tablegroup tg3 binding true;
create table t4(id1 int, id2 int) tablegroup tg3;
create table t5(id1 int, id2 int) tablegroup tg3;

let $cnt =0;

while ($cnt < 10)
{
  eval insert into t4 values($cnt, $cnt);
  eval insert into t5 values($cnt, $cnt);
  inc $cnt;
}

ob1.mysql alter system major freeze;
ob1.check_until_timeout select value from __all_zone where zone='' and name='last_merged_version', 3,3600;

while ($cnt < 20)
{
  eval insert into t4 values($cnt, $cnt);
  eval insert into t5 values($cnt, $cnt);
  inc $cnt;
}

select * from t4;
select * from t5;
create index pg_index4 on t4(id1);
create index pg_index5 on t5(id1);

let $table_id=deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where table_name like '%pg_index4%', table_id, 1);
ob1.check_until_timeout select index_status from oceanbase.__all_virtual_table where table_id=$table_id, 2, 3600;

let $table_id=deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where table_name like '%pg_index5%', table_id, 1);
ob1.check_until_timeout select index_status from oceanbase.__all_virtual_table where table_id=$table_id, 2, 3600;

#删除索引
connection conn1;
drop index pg_index1 on t1;
drop index pg_index2 on t2;
drop index pg_index3 on t3;
select * from t1;
select * from t2;
select * from t3;
connection conn3;
drop index pg_index4 on t4;
drop index pg_index5 on t5;
select * from t4;
select * from t5;

let $tenant_id=deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name='obtest', tenant_id, 1);
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table_mgr where tenant_id=$tenant_id and table_type=0 and is_active=0, 0, 90;

ob1.mysql alter system major freeze;
ob1.check_until_timeout select value from __all_zone where zone='' and name='last_merged_version', 4,3600;
