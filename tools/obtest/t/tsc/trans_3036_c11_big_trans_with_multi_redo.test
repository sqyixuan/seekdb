# owner: shanyan.g
# owner group: transaction
# description:
# 测试点：大事务场景下，clog异步回调事务的正确性验证
##

ob1=OBI(cluster=1:1,proxy_num=0,init_unit_cpu=5,init_unit_num=1);
ob1.reboot;
sleep 5;

ob1.mysql alter system set enable_auto_leader_switch=false;

#在zone1上建立连接
let $l_ip=deploy_get_value(ob1.z1.obs0.ip);
let $l_port=deploy_get_value(ob1.z1.obs0.mysql_port);
connect (conn1,$l_ip,root@obtest,,test,$l_port);
connect (conn2,$l_ip,root@obtest,,test,$l_port);

connection conn1;
#每条记录占用内存大小（4KB，5KB）
create table t1(i int primary key, c1 varchar(1024), c256 varchar(1024), dt datetime(6), d  datetime(6));
#设置语句级的超时时间为100s
set ob_query_timeout=100000000000;
set ob_trx_timeout=100000000000;

--disable_query_log
#insert
begin;
#950个字符
let $value = ;
let $i=0;
while($i < 800)
{
    eval insert into t1(i,c1,c256,dt,d) values($i,'$value','$value','2012-10-10 12:00:00','2012-10-10');
    inc $i;
}
commit;
select count(i) from t1;

drop table t1;
