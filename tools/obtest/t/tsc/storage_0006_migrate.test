# owner: shanyan.g
# owner group: trans
--disable_query_log
ob1=OBI(cluster=2:2:2,proxy_num=0,init_unit_cpu=2);
ob1.reboot;

ob1.mysql alter system set merger_check_interval='10s';
ob1.mysql alter system set enable_rebalance = 'false';
ob1.mysql alter system set resource_hard_limit=500;
ob1.mysql alter resource pool obtestpool unit_num 2;

ob1.mysql create resource unit box1 max_cpu 2, max_memory 1080000000, max_iops 100000, max_disk_size 1080000000, max_session_num 64, MIN_CPU 2, MIN_MEMORY=1080000000, MIN_IOPS=128;
ob1.mysql create resource pool pool_largex unit = 'box1', unit_num = 2, zone_list = ('z1', 'z2', 'z3');
ob1.mysql create tenant tt1 replica_num = 3, primary_zone='z1', resource_pool_list=('pool_largex'), locality = "F@z1,L@z2,F@z3" set ob_tcp_invited_nodes='%';
sleep 5;

let $ip=deploy_get_value(ob1.z1.obs0.ip);
let $port=deploy_get_value(ob1.z1.obs0.mysql_port);
let $ip1=deploy_get_value(ob1.z2.obs1.ip);
let $port1=deploy_get_value(ob1.z2.obs1.mysql_port);
connect (conn1,$ip,admin@obtest,admin,oceanbase,$port);
connect (conn2,$ip1,root@tt1,,test,$port1);
connect (conn3,$ip,root@sys,,oceanbase,$port);

#####################################################################
#case 1 : 正常partition迁移
connection conn1;
use test;
create tablegroup tg1 binding true;
create table t1(id1 int, id2 int) tablegroup tg1;

let $cnt = 0;
while ($cnt < 10)
{
  eval insert into t1 values($cnt, $cnt);
  inc $cnt;
}
ob1.mysql alter system major freeze;
ob1.check_version 2;

while ($cnt < 20)
{
  eval insert into t1 values($cnt, $cnt);
  inc $cnt;
}
let $tablegroup_id=deploy_get_value(ob1.select select tablegroup_id from oceanbase.__all_virtual_tablegroup where tablegroup_name='tg1', tablegroup_id, 1);
let $tenant_id=deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name='obtest', tenant_id, 1);
let $src_host = deploy_get_value(ob1.select select concat(svr_ip,':',svr_port) host from __all_virtual_partition_location where tenant_id=$tenant_id and table_id=$tablegroup_id and role=1 and partition_id=0, host, 1);
let $src_port = deploy_get_value(ob1.select select svr_port from __all_virtual_partition_location where tenant_id=$tenant_id and table_id=$tablegroup_id and role=1 and partition_id=0, svr_port, 1);
let $src = deploy_get_value(ob1.get_obs_by_addr $src_host);
let $src_ip = deploy_get_value($src.ip);
let $src_zone = deploy_get_value(ob1.select select zone from oceanbase.__all_server where svr_ip='$src_ip' and svr_port = $src_port, zone, 1);
let $dst_host = deploy_get_value(ob1.select select concat(svr_ip, ':', svr_port) host from oceanbase.__all_server where zone='$src_zone' and (svr_ip!='$src_ip' or svr_port != $src_port), host, 1);
let $dst_port = deploy_get_value(ob1.select select svr_port from oceanbase.__all_server where zone='$src_zone' and (svr_ip!='$src_ip' or svr_port != $src_port), svr_port, 1);
let $dst = deploy_get_value(ob1.get_obs_by_addr $dst_host);
let $dst_ip = deploy_get_value($dst.ip);

ob1.mysql alter system move replica partition_id = '0%0@$tablegroup_id' source = '$src_ip:$src_port' DESTINATION = '$dst_ip:$dst_port';
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_partition_location where tenant_id=$tenant_id and table_id=$tablegroup_id and partition_id=0 and role=1 and member_list like '%$dst_ip:$dst_port%', 1, 300;
select * from t1;

#################################################################
#case 2 : 空PG迁移
create tablegroup tg2 binding true;

let $tablegroup_id=deploy_get_value(ob1.select select tablegroup_id from oceanbase.__all_virtual_tablegroup where tablegroup_name='tg2', tablegroup_id, 1);
let $tenant_id=deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name='obtest', tenant_id, 1);
let $src_host = deploy_get_value(ob1.select select concat(svr_ip,':',svr_port) host from __all_virtual_partition_location where tenant_id=$tenant_id and table_id=$tablegroup_id and role=1 and partition_id=0, host, 1);
let $src_port = deploy_get_value(ob1.select select svr_port from __all_virtual_partition_location where tenant_id=$tenant_id and table_id=$tablegroup_id and role=1 and partition_id=0, svr_port, 1);
let $src = deploy_get_value(ob1.get_obs_by_addr $src_host);
let $src_ip = deploy_get_value($src.ip);
let $src_zone = deploy_get_value(ob1.select select zone from oceanbase.__all_server where svr_ip='$src_ip' and svr_port = $src_port, zone, 1);
let $dst_host = deploy_get_value(ob1.select select concat(svr_ip, ':', svr_port) host from oceanbase.__all_server where zone='$src_zone' and (svr_ip!='$src_ip' or svr_port != $src_port), host, 1);
let $dst_port = deploy_get_value(ob1.select select svr_port from oceanbase.__all_server where zone='$src_zone' and (svr_ip!='$src_ip' or svr_port != $src_port), svr_port, 1);
let $dst = deploy_get_value(ob1.get_obs_by_addr $dst_host);
let $dst_ip = deploy_get_value($dst.ip);

ob1.mysql alter system move replica partition_id = '0%0@$tablegroup_id' source = '$src_ip:$src_port' DESTINATION = '$dst_ip:$dst_port';
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_partition_location where tenant_id=$tenant_id and table_id=$tablegroup_id and partition_id=0 and role=1 and member_list like '%$dst_ip:$dst_port%', 1, 300;

ob1.mysql alter system major freeze;
ob1.check_version 3;

################################################################
#case 3 : L副本迁移-stand alone partition
connection conn2;
use test;
create table t2(id1 int, id2 int);

let $cnt = 0;
while ($cnt < 10)
{
  eval insert into t2 values($cnt, $cnt);
  inc $cnt;
}
ob1.mysql alter system major freeze;
ob1.check_version 4;

while ($cnt < 20)
{
  eval insert into t2 values($cnt, $cnt);
  inc $cnt;
}
let $tenant_id=deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name='tt1', tenant_id, 1);
let $table_id=deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where table_name='t2', table_id, 1);
let $src_host = deploy_get_value(ob1.select select concat(svr_ip,':',svr_port) host from __all_virtual_partition_location where tenant_id=$tenant_id and table_id=$table_id and role=1 and partition_id=0, host, 1);
let $src_port = deploy_get_value(ob1.select select svr_port from __all_virtual_partition_location where tenant_id=$tenant_id and table_id=$table_id and role=1 and partition_id=0, svr_port, 1);
let $src = deploy_get_value(ob1.get_obs_by_addr $src_host);
let $src_ip = deploy_get_value($src.ip);
let $src_zone = deploy_get_value(ob1.select select zone from oceanbase.__all_server where svr_ip='$src_ip' and svr_port = $src_port, zone, 1);
let $dst_host = deploy_get_value(ob1.select select concat(svr_ip, ':', svr_port) host from oceanbase.__all_server where zone='$src_zone' and (svr_ip!='$src_ip' or svr_port != $src_port), host, 1);
let $dst_port = deploy_get_value(ob1.select select svr_port from oceanbase.__all_server where zone='$src_zone' and (svr_ip!='$src_ip' or svr_port != $src_port), svr_port, 1);
let $dst = deploy_get_value(ob1.get_obs_by_addr $dst_host);
let $dst_ip = deploy_get_value($dst.ip);

ob1.mysql alter system move replica partition_id = '0%0@$table_id' source = '$src_ip:$src_port' DESTINATION = '$dst_ip:$dst_port';
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_partition_location where tenant_id=$tenant_id and table_id=$table_id and partition_id=0 and role=1 and member_list like '%$dst_ip:$dst_port%', 1, 300;
select * from t2;
