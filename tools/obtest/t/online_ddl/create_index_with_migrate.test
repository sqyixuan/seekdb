# owner: jianyun.sjy
# owner group: storage/ddl

ob1=OBI(cluster=2:2:2, proxy_num=0);


--echo ===============================================================
--echo ====================     bootstrap   ==========================
--echo ===============================================================
--echo test case for bootstrap begin
ob1.reboot;
sleep 3;
let $sys_tenant_id = 1;
ob1.mysql alter system set enable_rebalance='false';
ob1.mysql alter system set syslog_io_bandwidth_limit = '4G';
ob_connect(conn_sys, ob1.z1.obs0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);
--echo test case for bootstrap finish

--echo ===============================================================
--echo ==================     create tenant   ========================
--echo ===============================================================
# 注意: 创建初始mysql租户'F@z1, F@z3'
--echo test case for create tenant begin
set @@session.ob_query_timeout = 1000000000;
#mysql tenant
eval CREATE RESOURCE UNIT unit_1 MAX_CPU 2, MEMORY_SIZE='8G';
eval CREATE RESOURCE POOL pool_1 UNIT = 'unit_1', UNIT_NUM = 1;
eval CREATE TENANT mysql RESOURCE_POOL_LIST = ('pool_1'), primary_zone='z1' set ob_tcp_invited_nodes='%';
source include/check_schema_sync.inc;
connection conn_sys;
let $mysql_tenant_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name = 'mysql', tenant_id, 1);
ob_connect(conn_mysql, ob1.z1.obs1, root@mysql, , test, , USE_MYSQL_CONNECTOR);
--echo test case for create tenant finish


--echo ===============================================================
--echo ===============     create index blocked    ===================
--echo ===============================================================
--echo test case for create index begin
# 回放到prepare日志前卡住，已回放宏块转储为ddl sstable后，触发迁移。
ob1.mysql alter system set debug_sync_timeout = '100000s';
ob1.mysql set ob_global_debug_sync = 'AFTER_DDL_WRITE_MACRO_BLOCK wait_for signal_1 execute 10000';
connection conn_mysql;
--disable_warnings
drop table if exists test_create_index;
drop sequence if exists s1;
--enable_warnings
create table test_create_index(c1 int, c2 varchar(1024), c3 varchar(1024), c4 varchar(1024));
create sequence s1 cache 1000000 noorder;
--disable_query_log
--enable_query_log
eval insert into test_create_index select s1.nextval c1, randstr(1024, random()) c2, randstr(1024, random()) c3, randstr(1024, random()) c4 from table(generator(1000));
select count(*) from test_create_index;

send create index i1 on test_create_index (c2, c3, c4);
sleep 2;

connection conn_sys;
alter system minor freeze tenant mysql;
let $data_table_id = deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where tenant_id = $mysql_tenant_id and table_name = 'test_create_index', table_id, 1);
let $index_tablet_id = deploy_get_value(ob1.select select tablet_id from oceanbase.__all_virtual_table where tenant_id = $mysql_tenant_id and data_table_id = $data_table_id, tablet_id, 1);
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_tablet_ddl_kv_info where tenant_id=$mysql_tenant_id and tablet_id=$index_tablet_id, 0, 90;
ob1.mysql set ob_global_debug_sync = 'AFTER_DDL_WRITE_MACRO_BLOCK clear';

--echo ===============================================================
--echo ==================     migrate unit    ========================
--echo ===============================================================
--echo test migrate unit begin
source t/quick/include/migrate_unit.inc;
source t/quick/include/migrate_unit_check_gc.inc;
--echo test migrate unit finish

--echo ===============================================================
--echo ===============     create index recover    ===================
--echo ===============================================================
ob1.mysql set ob_global_debug_sync = 'now signal signal_1';

connection conn_mysql;
reap;

alter system major freeze;
sleep 10;
ob1.check_until_timeout select FROZEN_SCN - LAST_SCN from oceanbase.DBA_OB_MAJOR_COMPACTION where STATUS = 'IDLE' and IS_ERROR = 'NO', 0, 120;
