# owner: zhenjiang.xzj
# owner group: storage
# description: 
# cluster_version >=4.0, we will allow to drop column when doing major freeze.

#--disable_query_log
--disable_warnings
#ob1=OBI(cluster=1:1:1,proxy_num=0);
ob1=OBI(cluster=1,proxy_num=0);
ob1.reboot;

#设置灰度切主的时间为0, 关闭自动切主，关闭自动balance
ob1.mysql alter system set resource_hard_limit = 800;
ob1.mysql alter system set enable_auto_leader_switch=false;
ob1.mysql alter system set debug_sync_timeout = '100000s';
let $ip = deploy_get_value(ob1.z1.obs0.ip);
let $port = deploy_get_value(ob1.z1.obs0.mysql_port);
let $version = 1;

ob_connect(conn1, ob1.z1.obs0, root@sys, , oceanbase, , USE_OB_CONNECTOR);
ob_connect(conn2, ob1.z1.obs0, root@sys, , oceanbase, , USE_OB_CONNECTOR);

# 1: drop column限制
connection conn1;
drop table if exists test;
create table test(a int, b int, c int, d int, e char(10), primary key(a,b)) partition by hash(b) partitions 3;
# 1.1: sql内部drop column与其他ddl的互斥
--error 1235
alter table test modify column d char(10), drop column d;
--error 1235
alter table test drop column d, add column f char(10);
--error 1235
alter table test add index idx(a,b), drop column d;
# 1.2: 不允许drop索引列
create index idx on test(c,d) local;
--error 5071
alter table test drop column c;
drop index idx on test;
# 1.3: 不允许drop主键列/分区键
--error 1235
alter table test drop column a;
--error 1235
alter table test drop column b;
drop table test;

# 2: 删列后该列从schema中彻底删除
# 2.1: 删单列
drop table if exists test;
create table test(a int, b int, c int, d int, e char(10), primary key(a,b)) partition by hash(b) partitions 3;
eval insert into test values(1,2,3,4,'a'), (5,6,7,8,'b'), (9,10,11,12,'c');
alter table test drop column c;
select *from test;
--error 1091
alter table test drop column c;
# 2.1: 删多列
alter table test drop column d, drop column e;
select *from test;
drop table test;

# 3: 删列后数据一致性
drop table if exists t1;
drop table if exists t2;
create table t1(a int, b int, c int, d int, e char(10), primary key(a,b)) partition by hash(b) partitions 3;
eval insert into t1 values(1,2,3,4,'a'), (2,3,4,5,'b'), (3,4,5,6,'c'), (4,5,6,7,'mu'), (5,6,7,8,'zh'), (6,7,8,9,'i');
create table t2(a int, b int, c int, e char(10), primary key(a,b)) partition by hash(b) partitions 3;
eval insert into t2 values(1,2,3,'a'), (2,3,4,'b'), (3,4,5,'c'), (4,5,6,'mu'), (5,6,7,'zh'), (6,7,8,'i');
let $t1 = deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where table_name='t1', table_id, 1);
let $t2 = deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where table_name='t2', table_id, 1);
alter system major freeze;
inc $version;
ob1.check_version $version;
let $checksum_2 = deploy_get_value(ob1.select select data_checksum from oceanbase.__all_sstable_checksum where data_table_id=$t2, data_checksum, 1);
alter table t1 drop column d;
let $checksum_1 = deploy_get_value(ob1.select select data_checksum from oceanbase.__all_sstable_checksum where data_table_id=$t1, data_checksum, 1);
ob1.check_until_timeout select $checksum_2, $checksum_1, 5;
drop table t1;
drop table t2;

# 4: 删列过程中列不可见，不可读不可写
connection conn1;
create table t1(a int, b int, c char(10), primary key(a));
eval insert into t1 values(1,1,'a');
ob1.mysql set ob_global_debug_sync = 'DROP_COLUMN_NOT_STORED_IN_MAJOR wait_for continue1';
ob1.mysql set ob_global_debug_sync = 'DROP_COLUMN_NOT_STORED_IN_MINOR wait_for continue2';
send alter table t1 drop column c;

connection conn2;
sleep 3;
let $table_id = deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where table_name='t1', table_id, 1);
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_column where table_id=$table_id, 3, 5;
desc t1;
eval insert into t1 values(2,2);
ob1.mysql set ob_global_debug_sync = 'now signal continue1';
eval select *from t1 where a = 1;
ob1.mysql set ob_global_debug_sync = 'now signal continue2';

connection conn1;
reap;
select *from t1;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_column where table_id=$table_id, 2, 5;
drop table t1;

# 5: drop not null且无default值导致的整张表停写
connection conn1;
drop table if exists t1;
create table t1(a int not null, b int);
insert into t1 values(1,1);
ob1.mysql set ob_global_debug_sync = 'DROP_COLUMN_NOT_STORED_IN_MAJOR wait_for continue1';
send alter table t1 drop column a;
connection conn2;
sleep 5;
select *from t1;
--error 1054
insert into t1(a) values(2);
--error 1364
insert into t1(b) values(2);
--error 1054
select a,b from t1;
select *from t1;
ob1.mysql set ob_global_debug_sync = 'now signal continue1';
connection conn1;
reap;
drop table t1;

# 6: 删列过程中不调度合并
connection conn1;
drop table if exists test;
create table test(a int, b int, c int, d int, e char(10), primary key(a,b)) partition by hash(b) partitions 3;
eval insert into test values(1,2,3,4,'a'), (5,6,7,8,'b'), (9,10,11,12,'c');
let $table_id = deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where table_name='test', table_id, 1);
sleep 5;
let $checksum = deploy_get_value(ob1.select select data_checksum from oceanbase.__all_sstable_checksum where data_table_id=$table_id, data_checksum, 1);
ob1.mysql set ob_global_debug_sync = 'DROP_COLUMN_NOT_STORED_IN_MAJOR wait_for continue1';
ob1.mysql set ob_global_debug_sync = 'DROP_COLUMN_NOT_STORED_IN_MINOR wait_for continue2';
send alter table test drop column c;

connection conn2;
alter system major freeze;
inc $version;
ob1.check_version $version;
ob1.check_until_timeout select data_checksum from oceanbase.__all_sstable_checksum where data_table_id=$table_id, $checksum, 1;
ob1.mysql set ob_global_debug_sync = 'now signal continue1';
alter system major freeze;
inc $version;
ob1.check_version $version;
ob1.check_until_timeout select data_checksum from oceanbase.__all_sstable_checksum where data_table_id=$table_id, $checksum, 1;
ob1.mysql set ob_global_debug_sync = 'now signal continue2';

connection conn1;
reap;
eval select data_checksum from oceanbase.__all_sstable_checksum where data_table_id=$table_id;
drop table test;