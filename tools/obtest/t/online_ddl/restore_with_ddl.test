ob1=OBI(cluster=1:1:1, proxy_num=0);

source include/mini_ob_config.inc;
ob1.z1.obs0.set extra_config = "cache_wash_threshold='1G',_ob_minor_merge_schedule_interval='3s'";
ob1.z2.obs0.set extra_config = "cache_wash_threshold='1G',_ob_minor_merge_schedule_interval='3s'";
ob1.z3.obs0.set extra_config = "cache_wash_threshold='1G',_ob_minor_merge_schedule_interval='3s'";

let $backup_cluster_name = deploy_get_value(ob1.get_cluster_name);
let $backup_cluster_id = deploy_get_value(ob1.get_cluster_id);
let $backup_ip       = deploy_get_value(ob1.z1.obs0.ip);
let $backup_port     = deploy_get_value(ob1.z1.obs0.mysql_port);
let $restore_ip         = deploy_get_value(ob2.z1.obs0.ip);
let $restore_port       = deploy_get_value(ob2.z1.obs0.mysql_port);
let $backup_dest = deploy_get_value(ob1.get_backup_dest);
let $backup_oracle_tenant   = backup_oracle_tenant;
let $backup_mysql_tenant    = backup_mysql_tenant;
let $restore_oracle_tenant = restore_oracle_tenant;
let $restore_oracle_tenant_new = restore_oracle_tenant_new;
let $restore_mysql_tenant = restore_mysql_tenant;
let $restore_mysql_tenant_new = restore_mysql_tenant_new;
let $log_backup_dest = deploy_get_value(ob1.get_log_backup_dest $backup_mysql_tenant);
let $data_backup_dest = deploy_get_value(ob1.get_data_backup_dest $backup_mysql_tenant);
let $restore_log_archive_dest = deploy_get_value(ob1.get_log_backup_dest $restore_mysql_tenant);

# 必须先stop掉老的，删除才能有效，不然可能会有残留。
ob1.force_stop;
ob1.clean_backup_dest;
ob1.reboot;

# 固定sys租户规格
ob1.mysql alter resource unit sys_unit_config memory_size='2G';

connect(backup_sys_conn, $backup_ip, root@sys,,oceanbase, $backup_port);
connection backup_sys_conn;
use oceanbase;
source sql/physical_backup/prepare_multi_zone_resource.sql;

ob1.mysql alter system set debug_sync_timeout = '100000s';
ob1.mysql alter system set _backup_idle_time = '10s';
ob1.mysql alter system set merger_check_interval = '10s';
ob1.mysql alter system set enable_async_syslog = false;
ob1.mysql alter system set ob_compaction_schedule_interval = '10s' tenant all_user;

--echo ===============================================================
--echo ==================     create tenant   ========================
--echo ===============================================================

ob1.mysql CREATE RESOURCE POOL resource_pool UNIT = "small_unit", UNIT_NUM = 1, ZONE_LIST = ('z1', 'z2');
ob1.mysql CREATE TENANT backup_mysql_tenant resource_pool_list=('resource_pool'), locality = "F@z1,F@z2", primary_zone = "z1,z2" set ob_tcp_invited_nodes='%', ob_compatibility_mode='mysql';
ob1.mysql alter system set ob_compaction_schedule_interval = '10s' tenant all_user;
source include/check_schema_sync.inc;
connection backup_sys_conn;
let $backup_mysql_tenant_id = query_get_value(select tenant_id from oceanbase.__all_tenant where tenant_name='$backup_mysql_tenant', tenant_id, 1);
let $resource_pool_id = deploy_get_value(ob1.select select resource_pool_id from oceanbase.__all_resource_pool where tenant_id = $backup_mysql_tenant_id, resource_pool_id, 1);
let $src_ls_id = 1001;
--echo create tenant finished


--echo ===============================================================
--echo ==================     create table ===========================
--echo ===============================================================
connect(sys_conn_mysql, $backup_ip, root@$backup_mysql_tenant,,oceanbase, $backup_port);
connection sys_conn_mysql;
set global wait_timeout = 288000;

--disable_all_result_log
eval alter system set data_backup_dest='$data_backup_dest';
eval alter system set log_archive_dest='location=$log_backup_dest';
ob1.set_piece_switch_interval $backup_mysql_tenant_id 0 2m;
--enable_all_result_log

connection sys_conn_mysql;
create user test IDENTIFIED BY "test";
grant all on *.* to test WITH GRANT OPTION;

connect(backup_mysql_conn, $backup_ip,test@$backup_mysql_tenant,test,test, $backup_port);
connection backup_mysql_conn;

create table t1(a int, b int, c int, PRIMARY KEY (a)) partition by hash(a) partitions 5;

let $i=1;
while($i < 20)
{
  --disable_query_log
  --disable_result_log
  eval insert into t1 (a, b, c) values($i, $i, $i);
  --enable_result_log
  --enable_query_log
  inc $i;
}


--echo ===============================================================
--echo ==================     start archive   ========================
--echo ===============================================================
ob1.mysql alter system archivelog;
ob1.check_until_timeout select status from oceanbase.CDB_OB_ARCHIVELOG where tenant_id=$backup_mysql_tenant_id, DOING, 600;

ob1.mysql alter system major freeze tenant = '$backup_mysql_tenant';
sleep 10;
ob1.check_until_timeout select (frozen_scn - last_scn) as result from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id=$backup_mysql_tenant_id, 0, 600;

let $i=20;
while($i < 30)
{
  --disable_query_log
  --disable_result_log
  eval insert into t1 (a, b, c) values($i, $i, $i);
  --enable_result_log
  --enable_query_log
  inc $i;
}

ob1.mysql set ob_global_debug_sync = 'BEFORE_TABLET_FULL_DIRECT_LOAD_MGR_CLOSE wait_for signal1 execute 10000';

send create /*+ parallel(10) */ index t1ib on t1(b) local;
sleep 5;

ob1.z1.obs0.check_log_until_success -c "start wait.*name=signal1, signal_cnt=0";

# 确认生成ddl_sstable
ob1.mysql alter system minor freeze tenant = '$backup_mysql_tenant';
ob1.check_until_timeout select count(*) >= 3 FROM __all_virtual_table_mgr where tenant_id=1002 and table_type=14 and tablet_id in (select tablet_id from __all_virtual_tablet_to_table_history where tenant_id=1002 and table_id in (select table_id from __all_virtual_table where table_name like '%t1ib%')), 1, 600;

--echo ===============================================================
--echo ==================     start backup data   ====================
--echo ===============================================================
ob1.mysql alter system backup database;
ob1.check_until_timeout select count(*) c from __all_backup_job_history where tenant_id = 1, 1, 600;
ob1.check_until_timeout select result from oceanbase.CDB_OB_BACKUP_JOB_HISTORY where tenant_id = $backup_mysql_tenant_id, 0, 10;
ob1.check_until_timeout select result from oceanbase.CDB_OB_BACKUP_TASK_HISTORY where tenant_id = $backup_mysql_tenant_id, 0, 10;

ob1.mysql set ob_global_debug_sync = 'BEFORE_TABLET_FULL_DIRECT_LOAD_MGR_CLOSE clear';
ob1.mysql set ob_global_debug_sync = 'now signal signal1';

connection backup_mysql_conn;
reap;

# 确认索引生效
ob1.check_until_timeout select STATUS from cdb_indexes where con_id=$backup_mysql_tenant_id and index_name like 't1ib', VALID, 300;

--echo ===============================================================
--echo ===============  CALC RESTORE POINT  ==========================
--echo ===============================================================
let $restore_path = $log_backup_dest,$data_backup_dest;
let $scn = deploy_get_value(ob1.select select timestamp_to_scn(current_timestamp(6)) scn, scn, 1);
ob1.check_until_timeout select checkpoint_scn > $scn from CDB_OB_ARCHIVELOG where tenant_id = $backup_mysql_tenant_id, 1, 600;


--echo ===============================================================
--echo ===============  FULL RESTORE  ===============================
--echo ===============================================================
ob1.mysql alter system restore $restore_mysql_tenant from '$restore_path' until scn=$scn with 'pool_list=small_pool_1&primary_zone=z1,z2&method=full';
ob1.check_until_timeout SELECT status FROM __all_tenant WHERE tenant_id = 1003, NORMAL, 600;
ob1.check_until_timeout select count(*) from __all_virtual_ls_meta_table where tenant_id = 1004 and restore_status = 0, 9, 600;
ob1.check_until_timeout select status FROM __all_tenant WHERE tenant_id = 1004, NORMAL, 600;
ob1.check_until_timeout select count(*) FROM __all_restore_job, 0, 600;

connection backup_sys_conn;
use oceanbase;
select count(*) as cnt FROM __all_virtual_table_mgr where tenant_id=1004 and ls_id=1 and table_flag!=0;
select count(*) as cnt FROM __all_virtual_table_mgr where tenant_id=1004 and ls_id!=1 and table_flag!=0;

# 等待ddl dump sstable合并生成major
ob1.check_until_timeout select count(*) FROM __all_virtual_table_mgr where tenant_id=1004 and table_type=14 and tablet_id in (select tablet_id from __all_virtual_tablet_to_table_history where tenant_id=1004 and table_id in (select table_id from __all_virtual_table where table_name like '%t1ib%')), 0, 600;
select count(*) FROM __all_virtual_table_mgr where tenant_id=1004 and table_type=14 and tablet_id in (select tablet_id from __all_virtual_tablet_to_table_history where tenant_id=1004 and table_id in (select table_id from __all_virtual_table where table_name like '%t1ib%'));
select count(*) FROM __all_virtual_table_mgr where tenant_id=1004 and table_type=10 and tablet_id in (select tablet_id from __all_virtual_tablet_to_table_history where tenant_id=1004 and table_id in (select table_id from __all_virtual_table where table_name like '%t1ib%'));

connect(restore_mysql_conn, $backup_ip,test@$restore_mysql_tenant,test,test, $backup_port);
connection restore_mysql_conn;
use test;
select * from t1;


