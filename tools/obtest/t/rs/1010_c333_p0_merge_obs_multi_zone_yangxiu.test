###########
#case3: 发起合并，stop/delete zone
###############
--disable_query_log
--disable_result_log
source sql/big_table_3.sql;
--enable_query_log
--enable_result_log

ob1.mysql alter system major freeze;

# major freeze 后会让各个 partition 写一条日志，sleep 一下确保日志同步完成
sleep 5;

ob1.mysql alter system stop zone 'z2';
sleep 60;

ob1.z1.check_version 3;
ob1.z3.check_version 3;

ob1.mysql alter system major freeze;


sleep 30;
ob1.check_version 4;

ob1.mysql alter system major freeze;


ob1.mysql alter system start zone 'z2';
sleep 30;

ob1.check_version 5;

############
#case4: 发起合并，部分obs无主
###############

let $f1 = deploy_get_value(ob1.get_follower obtest:test:big_table_3,1);
let $f2 = deploy_get_value(ob1.get_follower obtest:test:big_table_3,2);

ob1.mysql alter system major freeze;

$f1.stop;
$f2.stop;
# for merge
sleep 10;

$f1.nstart;
$f2.nstart;

sleep 30;

ob1.check_version 6;
