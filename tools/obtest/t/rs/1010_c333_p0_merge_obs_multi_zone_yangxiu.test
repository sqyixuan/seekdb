##############################
# owner: rongxuan.lc
# owner group: proxy
#功能点：
# 多zone情况下，合并过程中obs相关操作
#
#用例场景：
#1、发起合并,部分partition leader切换
#2、发起合并,rs处于无主状态
#3、发起合并,stop/delete zone
#4、发起合并,部分parition无主
#
###############################

ob1=OBI(cluster=3:3:3,init_unit_cpu=2);
ob1.reboot;

ob1.source include/merge.inc;
# 并发合并zone的数量，设置成统一合并

ob1.create_client;
ob1.prepare;
ob1.start_check;

# 创建3个table
let $tablenum = 3;
source sql/init_table.sql;

###########
#case1: 发起合并，部分partition切主
############
--disable_query_log
--disable_result_log
source sql/big_table_3.sql;
--enable_query_log
--enable_result_log

ob1.mysql alter system major freeze;

let $fw = deploy_get_value(ob1.get_follower obtest:test:obtest1);
$fw.switch_partition obtest:test:obtest1;

let $fw = deploy_get_value(ob1.get_follower obtest:test:big_table_3);
$fw.switch_partition obtest:test:big_table_3;

ob1.check_version 2;

select count(*) from big_table_3;
