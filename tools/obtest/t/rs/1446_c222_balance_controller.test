# owner: rongxuan.lc
# description: 本case是为了测试负载均衡的影响开关；

ob1=OBI(cluster=2:2:2,  proxy_num=0, ct_num = 0);
ob1.reboot;
#ob1.mysql create table oceanbase.test(c1 int, c2 int);
ob1.mysql alter system set resource_hard_limit=900;
ob1.mysql alter system set resource_soft_limit=800;
ob1.mysql alter system set enable_rebalance = 'false';
ob1.mysql alter system set enable_rereplication = 'false';
ob1.mysql alter system set balancer_idle_time = '10s';

let $z1_obs0_ip = deploy_get_value(ob1.z1.obs0.ip);
let $z1_obs0_mysql_port = deploy_get_value(ob1.z1.obs0.mysql_port);
connect(conn_z1_tenant_40, $z1_obs0_ip, root, , oceanbase, $z1_obs0_mysql_port);

##测试配置项
--error 4147
alter system set __balance_controller='{"ENABLE_REBUILD":"true","enable_migrate_to_unit":"tru"}';
--error 4147
alter system set __balance_controller='{"ENABLE_REBUILD":"true","enable_migrate":"true"}';
--error 4147
alter system set __balance_controller='{"ENABLE_REBUILD":"true",}';
alter system set __balance_controller='{"ENABLE_REBUILD" : "true"}';
alter system set __balance_controller='{"ENABLE_REBUILD" : "true", "ENABLE_EMERGENCY_REPLICATE" : "true"}';
##关掉的情况下，原有的配置项继续生效；
alter system set __balance_controller='';
ob1.mysql update oceanbase.__all_root_table set rebuild = 1 where tenant_id = 1 and role !=1  limit 1;
ob1.check_until_timeout select count(*) c from __all_root_table where rebuild = 1, 0, 60;

###测试其中几个开关；
###某些功能是不收enable_balance/enable_replicate控制的；比如 rebuild;
ob1.mysql update oceanbase.__all_root_table set rebuild = 1 where tenant_id = 1 and role !=1  limit 1;
ob1.check_until_timeout select count(*) c from __all_root_table where rebuild = 1, 0, 60;
alter system set __balance_controller='{"ENABLE_REBUILD":"false"}';
ob1.mysql update oceanbase.__all_root_table set rebuild = 1 where tenant_id = 1 and role !=1  limit 1;
sleep 60;
ob1.check_until_timeout select count(*) c from __all_root_table where rebuild = 1, 1, 5;
alter system set __balance_controller='{"ENABLE_REBUILD":"true"}';
ob1.check_until_timeout select count(*) c from __all_root_table where rebuild = 1, 0, 60;

###replicate 受enable_replicate控制，在关掉的enable_replicate的情况下，单独开启复制；
alter system set __balance_controller='';
ob1.mysql alter system set server_permanent_offline_time = '20s';
ob1.z2.obs0.force_stop;
sleep 120;
##检查unit没有迁移；
let $svr_ip = deploy_get_value(ob1.z2.obs0.ip);
let $svr_port = deploy_get_value(ob1.z2.obs0.port);
--disable_query_log
ob1.mysql_p select count(*) c from oceanbase.__all_unit where unit_id = 2 and svr_ip = '$svr_ip' and svr_port=$svr_port;

alter system set __balance_controller='{"ENABLE_REBUILD":"true","ENABLE_EMERGENCY_REPLICATE":"false","ENABLE_SERVER_BALANCE":"true"}';

ob1.check_until_timeout select count(*) from __all_unit where zone='z2' and svr_ip='$svr_ip' and svr_port=$svr_port, 0, 120;
##检查复制没有做；
ob1.mysql_p select count(*) from oceanbase.__all_root_table where zone = 'z2' and svr_ip!='$svr_ip' and svr_port != $svr_port;

alter system set __balance_controller='{"ENABLE_REBUILD":"true","ENABLE_EMERGENCY_REPLICATE":"false","ENABLE_SERVER_BALANCE":"true","ENABLE_REPLICATE":"true"}';

##检查副本复制；
ob1.check_until_timeout select count(*) > 0 from oceanbase.__all_root_table where zone = 'z2' and svr_ip!='$svr_ip' and svr_port != $svr_port, 1, 240;


