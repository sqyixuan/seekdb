# owner: rongxuan.lc
# description: 本case是为了验证alter system 操作replica时，记录的event信息可能不对；
# project/81079/issue/11449627
# 两个问题：
#（1） drop replica是，没有记录unit_id;
#（2）迁移的时候，记录的目的端zone不对；

ob1=OBI(cluster=2:2:2, proxy_num=0, ct_num = 0);
ob1.reboot;

ob1.mysql alter system set enable_rereplication = 'false';
ob1.mysql alter system set enable_auto_leader_switch = 'False';
##找一个系统表的replica，进行drop；
##在zone2找一个副本drop; 
let $addr = deploy_get_value(ob1.select select concat(svr_ip,":",svr_port) addr from __all_root_table where zone = 'z2', addr, 1);
let $table_id = deploy_get_value(ob1.select select table_id from __all_root_table where zone='z2' and concat(svr_ip,":",svr_port) =  '$addr', table_id, 1);
let $partition_id = deploy_get_value(ob1.select select partition_id from __all_root_table where zone='z2' and concat(svr_ip,":",svr_port) =  '$addr' and table_id = $table_id, partition_id, 1);
let $partition_cnt = deploy_get_value(ob1.select select partition_cnt from __all_root_table where zone='z2' and concat(svr_ip,":",svr_port) =  '$addr' and table_id = $table_id, partition_cnt, 1);
ob1.mysql alter system drop replica partition_id = '$partition_id%$partition_cnt@$table_id' server = '$addr';
ob1.mysql_p select count(*) c from oceanbase.__all_rootservice_event_history where value1 like '%$table_id%' and event = 'remove_member' and value2 like '%unit_id:2,%';

##对这个replica进行复制
let $ip = deploy_get_value(ob1.z1.obs0.ip);
let $port = deploy_get_value(ob1.z1.obs0.port);
##等待删除做完下线
ob1.check_until_timeout select  count(*) c from __all_virtual_partition_info where table_id = 1099511627779 and partition_idx = 0, 2, 30;
ob1.mysql alter system copy replica partition_id = '$partition_id%$partition_cnt@$table_id' source = '$ip:$port' destination = '$addr' force ;
ob1.check_until_timeout select count(*) from __all_rootservice_event_history where value1 like '%$table_id%' and event = 'finish_add_replica', 1, 30;
ob1.mysql_p select count(*) c from oceanbase.__all_rootservice_event_history where value1 like '%$table_id%' and event = 'start_add_replica' and value3 like '%{zone%z2%';


