# owner: rongxuan.lc
# owner group: STORAGE
#
# BUG: 
#
# replica copy task can be add when move task exist.

ob1=OBI(cluster=2:2:2,proxy_num=0,init_unit_cpu=0);
ob1.reboot;

ob1.mysql alter system set debug_sync_timeout = '1000s';
ob1.mysql alter system set enable_rebalance = 'False';
ob1.mysql alter system set enable_rereplication = 'False';
ob1.mysql alter system set resource_hard_limit=900;
ob1.mysql alter system set resource_soft_limit=800;

sleep 2;

ob1.mysql alter resource pool sys_pool unit_num = 2;
ob1.mysql set ob_global_debug_sync = 'BEFORE_REBALANCE_TASK_EXECUTE wait_for execute';

let $ip20 = deploy_get_value(ob1.z2.obs0.ip);
let $port20 =deploy_get_value(ob1.z2.obs0.port);

let $ip21 = deploy_get_value(ob1.z2.obs1.ip);
let $port21 =deploy_get_value(ob1.z2.obs1.port);

let $ip30 = deploy_get_value(ob1.z3.obs0.ip);
let $port30 =deploy_get_value(ob1.z3.obs0.port);

let $ip31 = deploy_get_value(ob1.z3.obs1.ip);
let $port31 =deploy_get_value(ob1.z3.obs1.port);

let $tt1ip = deploy_get_value(ob1.z1.obs0.ip);
let $tt1port= deploy_get_value(ob1.z1.obs0.mysql_port);
connect(tt1_conn, $tt1ip, root,,oceanbase, $tt1port);
connection tt1_conn;

--disable_query_log
eval alter system move replica partition_id = '0%1@1099511627911' source= '$ip20:$port20' destination = '$ip21:$port21';
eval alter system copy replica partition_id = '0%1@1099511627911' source= '$ip30:$port30' destination = '$ip31:$port31';
