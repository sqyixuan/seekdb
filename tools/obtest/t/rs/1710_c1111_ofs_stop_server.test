#owner zhengshi
#owner group: rs
#功能：ofs中stop server case验证

ob1=OBI(cluster=3+1,proxy_num=0,init_unit_cpu=0,ofs='11.167.235.142:15401');
ob1.z1.obs0.set extra_config=_single_zone_deployment_on=true;
ob1.z1.obs1.set extra_config=_single_zone_deployment_on=true;
ob1.z1.obs2.set extra_config=_single_zone_deployment_on=true;
ob1.z1.obs3.set extra_config=_single_zone_deployment_on=true;
ob1.reboot;

let $cpu = 1;
let $memory = 1073741824;
let $min_memory = 1073741824;
let $disk = 536870912;
let $iops = 100000;
let $session = 64;

ob1.mysql CREATE RESOURCE UNIT unit_1 MAX_CPU $cpu, MAX_MEMORY $memory, MAX_IOPS $iops, MAX_DISK_SIZE $disk, MAX_SESSION_NUM $session, MIN_CPU=1, MIN_MEMORY=$min_memory, MIN_IOPS=128;

let $proxy_ip = deploy_get_value(ob1.z1.obs0.ip);
let $proxy_port = deploy_get_value(ob1.z1.obs0.mysql_port);

connect(sys_conn, $proxy_ip, root@sys,,test, $proxy_port);
connection sys_conn;

ob1.mysql create resource pool pool_1 unit_num=3, zone_list=('z1'), unit='unit_1';

ob1.mysql create tenant tenant_1 RESOURCE_POOL_LIST = ('pool_1') set ob_tcp_invited_nodes='%';
let $tenant1_id = deploy_get_value(ob1.select select tenant_id from __all_tenant where tenant_name = "tenant_1", tenant_id, 1);
let $svr_ip0 = deploy_get_value(ob1.z1.obs0.ip);
let $svr_port0 = deploy_get_value(ob1.z1.obs0.port);

let $svr_ip1 = deploy_get_value(ob1.z1.obs1.ip);
let $svr_port1 = deploy_get_value(ob1.z1.obs1.port);

let $svr_ip2 = deploy_get_value(ob1.z1.obs2.ip);
let $svr_port2 = deploy_get_value(ob1.z1.obs2.port);


use test;
set ob_query_timeout = 6000000000;
create table t_1(c1 int primary key) partition by hash(c1) partitions 10;
let $table_id = deploy_get_value(ob1.select select table_id from __all_table where table_name = "t_1", table_id, 1);

--disable_query_log
eval alter system force stop server '$svr_ip1:$svr_port1';
--enable_query_log
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_meta_table where table_id = '$table_id' and svr_ip = "$svr_ip1" and svr_port = "$svr_port1" and role = 1, 0, 100;
eval alter system start server '$svr_ip1:$svr_port1';
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_meta_table where table_id = '$table_id' and svr_ip = "$svr_ip1" and svr_port = "$svr_port1" and role = 1, 3, 100;

