# owner: yanmu.ztl
# owner group: rs
# description: 主要验证F、L在同一个zone内部署的场景下，locality变更的功能是否正常
ob1=OBI(cluster=2:2:2, init_unit_cpu=0, proxy_num=0, ct_num=0, locality=hz:hz:hz);
ob1.reboot;

ob1.mysql alter system set enable_auto_leader_switch = 'true';
ob1.mysql alter system set enable_rebalance = 'true';
ob1.mysql alter system set enable_rereplication = 'true';
ob1.mysql alter system set balancer_idle_time = '10s';
ob1.mysql alter system set server_data_copy_out_concurrency = 20;
ob1.mysql alter system set server_data_copy_in_concurrency = 20;
ob1.mysql alter system set server_permanent_offline_time = '20s';

let $cpu = 1;
let $memory = 1073741824;
let $min_memory = 1073741824;
let $disk = 536870912;
let $iops = 100000;
let $session = 64;

let $rs = deploy_get_value(ob1.get_leader sys:oceanbase:__all_core_table:0);
let $rs_ip = deploy_get_value($rs.ip);
let $rs_port = deploy_get_value($rs.port);
let $rs_mysql_port = deploy_get_value($rs.mysql_port);
connect (conn_sys,$rs_ip,root,,oceanbase,$rs_mysql_port);

ob1.mysql CREATE RESOURCE UNIT unit_1 MAX_CPU $cpu, MAX_MEMORY $memory, MAX_IOPS $iops, MAX_DISK_SIZE $disk, MAX_SESSION_NUM $session, MIN_CPU=1, MIN_MEMORY=$min_memory, MIN_IOPS=128;
ob1.mysql CREATE RESOURCE POOL pool_1 UNIT = 'unit_1', UNIT_NUM = 1, ZONE_LIST = ('z1','z2','z3');
ob1.mysql CREATE RESOURCE POOL pool_2 UNIT = 'unit_1', UNIT_NUM = 1, ZONE_LIST = ('z1','z2','z3'), replica_type = "L";

ob1.mysql CREATE TENANT tenant_1 RESOURCE_POOL_LIST = ('pool_1','pool_2'), primary_zone = 'z1;z2;z3', locality='F{1}@z1,L{1}@z1,F{1}@z2,L{1}@z2,F{1}@z3' set ob_tcp_invited_nodes='%';
let $resource_pool_id = deploy_get_value(ob1.select select resource_pool_id from __all_resource_pool where name = 'pool_1', resource_pool_id, 1);
let $tenant1_id = deploy_get_value(ob1.select select tenant_id from __all_tenant where tenant_name = "tenant_1", tenant_id, 1);
sleep 10;

let $obs = deploy_get_value(ob1.get_leader tenant_1:oceanbase:__all_dummy:0);
let $obs_ip = deploy_get_value($obs.ip);
let $obs_port = deploy_get_value($obs.port);
let $obs_mysql_port = deploy_get_value($obs.mysql_port);
connect (conn_tenant1,$obs_ip,root@tenant_1,,test,$obs_mysql_port);

connection conn_tenant1;
use test;
create table t1(c1 int primary key, c2 int);
let $user_table_id = deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where tenant_id = "$tenant1_id" and table_name = "t1", table_id, 1);
insert into t1(c1, c2) values (1, 1);
select * from t1;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_partition_table where table_id = "$user_table_id", 5, 5;

# 由于primary_zone所在region至少有两个全功能副本，故下面仅考虑加减两L，及加减一个F、L的场景
# case 1: 加减两L
# {F,L@z1, F,L@z2, F@z3} -> {F@z1, F@z2, F@z3}
#let $stop_addr1 = deploy_get_value(ob1.select select concat(svr_ip, ":", svr_port) as addr from oceanbase.__all_virtual_partition_table where zone = "z1" and replica_type = 5, addr, 1);
#let $stop_addr2 = deploy_get_value(ob1.select select concat(svr_ip, ":", svr_port) as addr from oceanbase.__all_virtual_partition_table where zone = "z2" and replica_type = 5, addr, 1);
#let $stop_obs1 = deploy_get_value(ob1.get_obs_by_addr $stop_addr1);
#let $stop_obs2 = deploy_get_value(ob1.get_obs_by_addr $stop_addr2);
#$stop_obs1.force_stop;
#$stop_obs2.force_stop;
#ob1.check_until_timeout select count(*) from oceanbase.__all_server where concat(svr_ip, ":", svr_port) in ("$stop_addr1", "$stop_addr2") and (status = "inactive" or start_service_time <= 0), 2, 60;

ob1.mysql alter tenant tenant_1 set locality = "F{1}@z1,F{1}@z2,F{1}@z3";
ob1.check_until_timeout select count(*) from oceanbase.__all_tenant where tenant_id = "$tenant1_id" and previous_locality = "", 1, 360;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_partition_table where table_id = "$user_table_id", 3, 5;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_partition_table where tenant_id = "$tenant1_id" and role = 1 and quorum != 3, 0, 30;
select * from t1;

#$stop_obs1.start;
#$stop_obs2.start;
#ob1.check_until_timeout select count(*) from oceanbase.__all_server where concat(svr_ip, ":", svr_port) in ("$stop_addr1", "$stop_addr2") and (status = "active" and start_service_time > 0), 2, 60;

# {F@z1, F@z2, F@z3} -> {F,L@z1, F,L@z2, F@z3}
ob1.mysql alter tenant tenant_1 set locality = "F{1}@z1,L{1}@z1,F{1}@z2,L{1}@z2,F{1}@z3";
ob1.check_until_timeout select count(*) from oceanbase.__all_tenant where tenant_id = "$tenant1_id" and previous_locality = "", 1, 360;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_partition_table where table_id = "$user_table_id", 5, 5;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_partition_table where tenant_id = "$tenant1_id" and role = 1 and quorum != 5, 0, 30;
select * from t1;

# case 3: 加减一个F，一个L
# {F,L@z1, F,L@z2, F@z3} -> {F@z1, L@z2, F@z3}
#let $stop_addr1 = deploy_get_value(ob1.select select concat(svr_ip, ":", svr_port) as addr from oceanbase.__all_virtual_partition_table where zone = "z1" and replica_type = 5, addr, 1);
#let $stop_addr2 = deploy_get_value(ob1.select select concat(svr_ip, ":", svr_port) as addr from oceanbase.__all_virtual_partition_table where zone = "z2" and replica_type = 0, addr, 1);
#let $stop_obs1 = deploy_get_value(ob1.get_obs_by_addr $stop_addr1);
#let $stop_obs2 = deploy_get_value(ob1.get_obs_by_addr $stop_addr2);
#$stop_obs1.force_stop;
#$stop_obs2.force_stop;
#ob1.check_until_timeout select count(*) from oceanbase.__all_server where concat(svr_ip, ":", svr_port) in ("$stop_addr1", "$stop_addr2") and (status = "inactive" or start_service_time <= 0), 2, 60;

ob1.mysql alter tenant tenant_1 set locality = "F{1}@z1,L{1}@z2,F{1}@z3";
ob1.check_until_timeout select count(*) from oceanbase.__all_tenant where tenant_id = "$tenant1_id" and previous_locality = "", 1, 360;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_partition_table where table_id = "$user_table_id", 3, 5;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_partition_table where tenant_id = "$tenant1_id" and role = 1 and quorum != 3, 0, 30;
select * from t1;

#$stop_obs1.start;
#$stop_obs2.start;
#ob1.check_until_timeout select count(*) from oceanbase.__all_server where concat(svr_ip, ":", svr_port) in ("$stop_addr1", "$stop_addr2") and (status = "active" and start_service_time > 0), 2, 60;

# FL@z1, L@z1, F@z3} -> {F,L@z1, F,L@z1, F@z3}
ob1.mysql alter tenant tenant_1 set locality = "F{1}@z1,L{1}@z1,F{1}@z2,L{1}@z2,F{1}@z3";
ob1.check_until_timeout select count(*) from oceanbase.__all_tenant where tenant_id = "$tenant1_id" and previous_locality = "", 1, 360;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_partition_table where table_id = "$user_table_id", 5, 5;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_partition_table where tenant_id = "$tenant1_id" and role = 1 and quorum != 5, 0, 30;
select * from t1;

# {F,L@z1, F,L@z2, F@z3} -> {F,L@z1, F@z3}
#let $stop_addr1 = deploy_get_value(ob1.select select concat(svr_ip, ":", svr_port) as addr from oceanbase.__all_virtual_partition_table where zone = "z2" and replica_type = 0, addr, 1);
#let $stop_addr2 = deploy_get_value(ob1.select select concat(svr_ip, ":", svr_port) as addr from oceanbase.__all_virtual_partition_table where zone = "z2" and replica_type = 5, addr, 1);
#let $stop_obs1 = deploy_get_value(ob1.get_obs_by_addr $stop_addr1);
#let $stop_obs2 = deploy_get_value(ob1.get_obs_by_addr $stop_addr2);
#ob1.check_until_timeout select count(*) from oceanbase.__all_server where concat(svr_ip, ":", svr_port) in ("$stop_addr1", "$stop_addr2") and (status = "inactive" or start_service_time <= 0), 2, 60;

ob1.mysql alter tenant tenant_1 set locality = "F{1}@z1,L{1}@z1,F{1}@z3";
ob1.check_until_timeout select count(*) from oceanbase.__all_tenant where tenant_id = "$tenant1_id" and previous_locality = "", 1, 360;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_partition_table where table_id = "$user_table_id", 3, 5;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_partition_table where tenant_id = "$tenant1_id" and role = 1 and quorum != 3, 0, 30;
select * from t1;

#$stop_obs1.start;
#$stop_obs2.start;
#ob1.check_until_timeout select count(*) from oceanbase.__all_server where concat(svr_ip, ":", svr_port) in ("$stop_addr1", "$stop_addr2") and (status = "active" and start_service_time > 0), 2, 60;

# {F,L@z1, F@z3} -> {F,L@z1, F,L@z2, F@z3}
ob1.mysql alter tenant tenant_1 set locality = "F{1}@z1,L{1}@z1,F{1}@z2,L{1}@z2,F{1}@z3";
ob1.check_until_timeout select count(*) from oceanbase.__all_tenant where tenant_id = "$tenant1_id" and previous_locality = "", 1, 360;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_partition_table where table_id = "$user_table_id", 5, 5;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_partition_table where tenant_id = "$tenant1_id" and role = 1 and quorum != 5, 0, 30;
select * from t1;
