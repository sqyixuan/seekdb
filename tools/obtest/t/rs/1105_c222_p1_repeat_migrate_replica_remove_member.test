# owner: rongxuan.lc
# description: 本case是为测试反复迁移后，下线后remove_member失败的问题
# 
#主要过程为：
#create table时，生成所有partition的timestamp T1  
#replica A 从171 迁往 21  ;
#replica A 从21 迁往 171， 生成新的timestamp T2  ,主的成员列表中已经将该成员的timestamp改成了T2
#171 永久下线，需要从成员列表里面删掉
#在删除成员的时候，或者迁移的时候，生成task时，采用的timestamp都是用replica的create_time，即T1,
#  实际上这个值已经不是最新的副本的值 (T2)，导致remove member失败； 

ob1=OBI(cluster=2:2:2,proxy_num=0,init_unit_cpu=0);
ob1.reboot;

ob1.mysql alter system set balancer_idle_time = '10s';
ob1.mysql alter system set resource_hard_limit = 500;
ob1.mysql alter system set enable_rebalance = true;
ob1.mysql alter system set enable_rereplication = true;
ob1.mysql alter system set enable_auto_leader_switch = false;

#let $obs0ip = deploy_get_value(ob1.z1.obs0.ip);
#let $obs0port = deploy_get_value(ob1.z1.obs0.port);
#let $obs0mysqlport = deploy_get_value(ob1.z1.obs0.mysql_port);
let $z2ip = deploy_get_value(ob1.z2.obs0.ip);
let $z2port = deploy_get_value(ob1.z2.obs0.port);
let $z2sql_port = deploy_get_value(ob1.z2.obs0.mysql_port);

let $obs1ip = deploy_get_value(ob1.z1.obs1.ip);
let $obs1port = deploy_get_value(ob1.z1.obs1.port);
#let $obs1port = deploy_get_value(ob1.z1.obs1.port);
connect(sys, $z2ip, root,,oceanbase, $z2sql_port);
connection sys;

ob1.mysql create resource pool rp1 unit = 'sys_unit_config', unit_num = 1, zone_list = ('z1', 'z2', 'z3');
ob1.mysql create tenant tt1 replica_num 3, primary_zone 'z2', resource_pool_list ('rp1') set ob_tcp_invited_nodes='%';
sleep 3;
let $tt1ip= deploy_get_value(ob1.select select svr_ip from __all_unit where zone='z2' and resource_pool_id = 1001 limit 1, svr_ip, 1);
let $tt1port = deploy_get_value(ob1.select select svr_port from __all_unit where zone='z2' and resource_pool_id = 1001 limit 1, svr_port, 1);
let $tt1port = deploy_get_value(ob1.select select inner_port from __all_server where zone='z2' and svr_ip = "$tt1ip" and svr_port = "$tt1port", inner_port, 1);

let $src_addr = deploy_get_value(ob1.select select concat(svr_ip, ":", svr_port) as addr from oceanbase.__all_unit where zone = "z1" and unit_id = 1001, addr, 1);
let $dest_addr = deploy_get_value(ob1.select select concat(svr_ip, ":", svr_port) as addr from oceanbase.__all_server where zone = "z1" and concat(svr_ip, ":", svr_port) != "$src_addr", addr, 1);
connect(tt1_conn, $tt1ip, root@tt1,,test, $tt1port);
connect(sys_conn, $tt1ip, root,,, $tt1port);
connection tt1_conn;
create table test(c1 int primary key, c2 int);
insert into test values(1,2);

let $table_id = deploy_get_value(ob1.select select /*+ READ_CONSISTENCY(WEAK) */ table_id from oceanbase.__all_virtual_table where table_name = "test", table_id, 1);
connection sys;
--disable_query_log
eval alter system switch replica leader partition_id = '0%1@1099511627777' server='$z2ip:$z2port';
--enable_query_log
sleep 16;
#记录旧值
let $old_create_time = deploy_get_value(ob1.select select create_time from oceanbase.__all_virtual_meta_table where svr_ip = '$obs1ip' and svr_port = "$obs1port", create_time, 1);
--disable_query_log
eval alter system migrate unit 1001 destination '$dest_addr';
ob1.mysql alter system set enable_rebalance='false';
sleep 10;
eval alter system migrate unit 1001 destination '$src_addr';
ob1.mysql alter system set enable_rebalance='true';
--enable_query_log
ob1.mysql alter system set server_permanent_offline_time = '20s';
ob1.mysql alter system set server_temporary_offline_time = '15s';

ob1.z1.obs1.force_stop;
connection sys_conn;
alter system change tenant tt1;
#等待obs1永久下线
--disable_query_log
eval update oceanbase.__all_tenant_meta_table set create_time = $old_create_time where svr_ip = '$obs1ip' and svr_port = "$obs1port" and table_id = 1100611139453777 and tenant_id = 1001; 
--enable_query_log

ob1.check_until_timeout select IF(instr(member_list, '$obs1ip:$obs1port') = 0, 1, 0) as pass from oceanbase.__all_virtual_meta_table where tenant_id = 1001 and table_id = 1100611139453777 and role = 1, 1, 180;
