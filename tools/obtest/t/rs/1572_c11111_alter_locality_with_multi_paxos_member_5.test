# owner: yanmu.ztl
# owner group: rs
# description: 主要验证降级容灾场景下，quorum修正逻辑是否生效
ob1=OBI(cluster=1:1:1:1:1, init_unit_cpu=1, proxy_num=0, ct_num=0, locality=hz:hz:hz:hz:hz);

ob1.reboot;

ob1.mysql alter system set enable_auto_leader_switch = 'true';
ob1.mysql alter system set enable_rebalance = 'true';
ob1.mysql alter system set enable_rereplication = 'true';
ob1.mysql alter system set balancer_idle_time = '10s';
ob1.mysql alter system set server_data_copy_out_concurrency = 20;
ob1.mysql alter system set server_data_copy_in_concurrency = 20;
ob1.mysql alter system set server_permanent_offline_time = '20s';

let $cpu = 1;
let $memory = 1073741824;
let $min_memory = 1073741824;
let $disk = 536870912;
let $iops = 100000;
let $session = 64;

let $rs = deploy_get_value(ob1.get_leader sys:oceanbase:__all_core_table:0);
let $rs_ip = deploy_get_value($rs.ip);
let $rs_port = deploy_get_value($rs.port);
let $rs_mysql_port = deploy_get_value($rs.mysql_port);
connect (conn_sys,$rs_ip,root,,oceanbase,$rs_mysql_port);
connect (conn1,$rs_ip,root@obtest,,test,$rs_mysql_port);

# case 1: 5->3的降级容灾场景
# 顺便验证系统租户__all_core_table、__all_root_table的quorum值的汇报是否正常

# 先关闭自动修正quorum
connection conn_sys;
alter system set __balance_controller='{"ENABLE_MODIFY_QUORUM":"false"}';
sleep 5;

# 1.1: 发生永久下线踢成员之后，quorum值不匹配的场景下，机器重新上线后，能通过locality变更恢复
connection conn1;
use test;
create table sys_table(c1 int primary key, c2 int);
let $tenant_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name ='obtest', tenant_id,1);
let $table_id = deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where table_name = "sys_table", table_id, 1);
# 宕机场景下
ob1.z4.obs0.force_stop;
ob1.z5.obs0.force_stop;
ob1.check_until_timeout select count(*) from oceanbase.__all_server where zone in ('z4', 'z5') and (status = "inactive" or start_service_time <= 0), 2, 60;

# 等永久下线踢成员，不会修改quorum值
ob1.mysql alter system set replica_safe_remove_time = '1m';
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_partition_table where tenant_id = $tenant_id and role = 1 and member_list like "%,%,%,%,%", 0, 120;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_partition_table where tenant_id = $tenant_id and role = 1 and member_list like "%,%,%,%", 0, 120;
ob1.mysql alter system report replica;
sleep 10;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_partition_table where tenant_id = $tenant_id and role = 1 and quorum != 5, 0, 5;

connection conn_sys;
alter system set __balance_controller='{"ENABLE_REPLICATE":"true", "ENABLE_DELETE_REDUNDANT":"true", "ENABLE_MODIFY_QUORUM":"false"}';
ob1.mysql alter tenant obtest set locality = "F{1}@z1,F{1}@z2,F{1}@z3";
ob1.mysql alter tenant sys set locality = "F{1}@z1,F{1}@z2,F{1}@z3";
ob1.check_until_timeout select count(*) from oceanbase.__all_tenant where tenant_name = "obtest" and previous_locality = "", 1, 120;
ob1.check_until_timeout select count(*) from oceanbase.__all_tenant where tenant_name = "sys" and previous_locality = "", 1, 120;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_partition_table where tenant_id = $tenant_id and role = 1 and quorum != 5, 0, 5;

# 恢复 3 -> 5
ob1.mysql alter tenant obtest set locality = "F{1}@z1,F{1}@z2,F{1}@z3,F{1}@z4,F{1}@z5";
ob1.mysql alter tenant sys set locality = "F{1}@z1,F{1}@z2,F{1}@z3,F{1}@z4,F{1}@z5";

ob1.z4.obs0.start;
ob1.z5.obs0.start;
ob1.check_until_timeout select count(*) from oceanbase.__all_server where zone in ('z4', 'z5') and status = "active" and start_service_time > 0, 2, 60;

ob1.check_until_timeout select count(*) from oceanbase.__all_tenant where tenant_name = "obtest" and previous_locality = "", 1, 600;
ob1.check_until_timeout select count(*) from oceanbase.__all_tenant where tenant_name = "sys" and previous_locality = "", 1, 600;

ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_partition_table where tenant_id = $tenant_id and role = 1 and member_list not like "%,%,%,%,%", 0, 5;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_partition_table where tenant_id = $tenant_id and role = 1 and quorum != 5, 0, 5;

connection conn1;
use test;
drop table sys_table;

# 1.2: 先永久下线，后做locality变更
connection conn1;
use test;
create table sys_table(c1 int primary key, c2 int);
let $table_id = deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where table_name = "sys_table", table_id, 1);
# 宕机场景下
ob1.z4.obs0.force_stop;
ob1.z5.obs0.force_stop;
ob1.check_until_timeout select count(*) from oceanbase.__all_server where zone in ('z4', 'z5') and (status = "inactive" or start_service_time <= 0), 2, 60;

# 等永久下线踢成员，不会修改quorum值
ob1.mysql alter system set replica_safe_remove_time = '1m';
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_meta_table where table_id = $table_id, 3, 120;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_meta_table where table_id = $table_id and role = 1 and member_list not like "%,%,%,%,%", 1, 120;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_meta_table where table_id = $table_id and role = 1 and member_list not like "%,%,%,%", 1, 120;
ob1.mysql alter system report replica;
sleep 10;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_partition_table where tenant_id = $tenant_id and table_id = $table_id and role = 1 and quorum != 5, 0, 5;

ob1.mysql alter tenant sys set locality = "F{1}@z1,F{1}@z2,F{1}@z3";
ob1.mysql alter tenant obtest set locality = "F{1}@z1,F{1}@z2,F{1}@z3";
ob1.check_until_timeout select count(*) from oceanbase.__all_tenant where tenant_name = "sys" and previous_locality = "", 1, 120;
ob1.check_until_timeout select count(*) from oceanbase.__all_tenant where tenant_name = "obtest" and previous_locality = "", 1, 120;

ob1.mysql alter system report replica;
sleep 10;

# 做完locality变更之后，quorum值仍为5
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_partition_table where table_id = $table_id, 3, 5;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_partition_table where tenant_id = $tenant_id and table_id = $table_id and role = 1 and quorum != 5, 0, 5;

# 5->3->2, 此时因为quorum值为5，预期locality变更是没法做完的
ob1.mysql alter tenant sys set locality = "F{1}@z1,F{1}@z2";
ob1.mysql alter tenant obtest set locality = "F{1}@z1,F{1}@z2";

# 开启自动修正quorum, 当前正在做3->2的locality变更，quorum预期在[2,3]内才能做locality变更，所以应先修正quorum, 再做减成员操作
connection conn_sys;
alter system set __balance_controller='{"ENABLE_DELETE_REDUNDANT":"true", "ENABLE_MODIFY_QUORUM":"true"}';
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_partition_table where tenant_id = $tenant_id and role = 1 and quorum != 2, 0, 120;
ob1.check_until_timeout select IF(count(*) > 0, 1, 0) from oceanbase.__all_rootservice_event_history where event = "finish_modify_quorum" and value1 like "%$table_id%" and value2 = "4" and value5 = "0", 1, 60;
ob1.check_until_timeout select IF(count(*) > 0, 1, 0) from oceanbase.__all_rootservice_event_history where event = "finish_modify_quorum" and value1 like "%$table_id%" and value2 = "3" and value5 = "0", 1, 60;
ob1.check_until_timeout select IF(count(*) > 0, 1, 0) from oceanbase.__all_rootservice_event_history where event = "finish_remove_member" and value1 like "%$table_id%" and value3 = "2" and value5 = "0", 1, 60;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_election_info where replica_num != substr(member_list, 1, 1) and substr(member_list, 1, 1) != 0, 0, 5;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_election_info where replica_num != 2, 0, 120;
ob1.mysql alter tenant sys set locality = "F{1}@z1,F{1}@z2,F{1}@z3";
ob1.mysql alter tenant obtest set locality = "F{1}@z1,F{1}@z2,F{1}@z3";
ob1.check_until_timeout select count(*) from oceanbase.__all_tenant where tenant_name = "sys" and previous_locality = "", 1, 600;
ob1.check_until_timeout select count(*) from oceanbase.__all_tenant where tenant_name = "obtest" and previous_locality = "", 1, 600;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_meta_table where tenant_id = $tenant_id and role = 1 and member_list not like "%,%,%", 0, 120;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_election_info where replica_num != substr(member_list, 1, 1) and substr(member_list, 1, 1) != 0, 0, 120;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_election_info where replica_num != 3, 0, 120;

connection conn1;
use test;
drop table sys_table;

# case 2: 永久下线＋3->5 locality变更
ob1.z4.obs0.start;
ob1.z5.obs0.start;
ob1.check_until_timeout select count(*) from oceanbase.__all_server where zone in ('z4', 'z5') and status = "active" and start_service_time > 0, 2, 60;
connection conn_sys;
alter system set __balance_controller='{"ENABLE_DELETE_REDUNDANT":"false", "ENABLE_MODIFY_QUORUM":"false"}';

connection conn1;
use test;
create table sys_table(c1 int primary key, c2 int);
let $table_id = deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where table_name = "sys_table", table_id, 1);
# 宕机场景下
ob1.z2.obs0.force_stop;
ob1.check_until_timeout select count(*) from oceanbase.__all_server where zone in ('z2') and (status = "inactive" or start_service_time <= 0), 1, 60;

# 等永久下线踢成员，不会修改quorum值
ob1.mysql alter system set replica_safe_remove_time = '1m';
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_meta_table where table_id = $table_id, 2, 120;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_meta_table where table_id = $table_id and role = 1 and member_list not like "%,%,%", 1, 120;
ob1.mysql alter system report replica;
sleep 10;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_partition_table where tenant_id = $tenant_id and table_id = $table_id and role = 1 and quorum != 3, 0, 5;

ob1.mysql alter tenant sys set locality = "F{1}@z1,F{1}@z2,F{1}@z3,F{1}@z4,F{1}@z5";
ob1.mysql alter tenant obtest set locality = "F{1}@z1,F{1}@z2,F{1}@z3,F{1}@z4,F{1}@z5";

# 做完locality变更之后，若汇报不及时，quorum值有可能为4
# ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_partition_table where tenant_id = $tenant_id and table_id = $table_id and role = 1 and quorum != 5, 1, 5;

# 开启自动修正quorum
connection conn_sys;
alter system set __balance_controller='{"ENABLE_REPLICATE":"true", "ENABLE_MODIFY_QUORUM":"true"}';
# locality变更完成后，quorum值有可能是4，这种情况下需要quorum修正逻辑将quorum推到5
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_partition_table where tenant_id = $tenant_id and table_id = $table_id and role = 1 and quorum != 5, 0, 300;
# 机器上线，以满足补副本的需求，让locality做完
ob1.z2.obs0.start;
ob1.check_until_timeout select count(*) from oceanbase.__all_server where zone in ('z2') and status = "active" and start_service_time > 0, 1, 60;
ob1.check_until_timeout select count(*) from oceanbase.__all_tenant where tenant_name = "sys" and previous_locality = "", 1, 600;
ob1.check_until_timeout select count(*) from oceanbase.__all_tenant where tenant_name = "obtest" and previous_locality = "", 1, 600;
