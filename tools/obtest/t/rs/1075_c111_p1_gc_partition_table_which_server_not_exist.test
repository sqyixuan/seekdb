# owner group: STORAGE
#
# __all_virtual_meta_table may not clean if server delete success.
# Bug:
#   

ob1=OBI(cluster=1:1:1,proxy_num=0,init_unit_cpu=1);
ob1.reboot;

ob1.mysql alter system set partition_table_check_interval = '2h';
ob1.mysql alter system set replica_safe_remove_time = '1m';
sleep 1;
let $ip=deploy_get_value(ob1.z1.obs0.ip);
let $port=deploy_get_value(ob1.z1.obs0.mysql_port);
connect (conn_obtest,$ip,root@obtest,,*NO-ONE*,$port);
connect (conn_sys,$ip,root@sys,,oceanbase,$port);
connectition conn_obtest;
create tablet1 (k int primary key, v int);
INSERT INTO oceanbase.__all_tenant_meta_table(tenant_id, table_id, partition_id, svr_ip, svr_port, sql_port, unit_id, zone, partition_cnt, role, member_list, row_count, data_size, data_version, data_checksum, create_time, is_previous_leader, row_checksum, column_checksum, gmt_modified) VALUES (1, 1099511677777, 0, '127.0.0.1', 43906, 43907, 1, 'z1', 1, 0, '100.81.152.41:43906:1467192079557727,100.81.152.42:43908:1467192079557727,100.81.152.44:43910:1467192079557727', 0, 0, 1, 0, 1467192079557727, 0, 0, '', now(6));

select count(*) from oceanbase.__all_tenant_meta_table where svr_ip = '127.0.0.1';

ob1.mysql alter system set partition_table_check_interval = '1m';
ob1.mysql alter system set balancer_idle_time = '1m';

ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_meta_table where svr_ip = '127.0.0.1', 0, 120;
