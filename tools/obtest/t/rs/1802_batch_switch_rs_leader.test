# owner: zk250686
# description: batch switch rs leader: 在执行命令前后，分别记录原leader service和新leader service的上的为leader的partition数。

ob1=OBI(cluster=1:1:1,proxy_num=0);
ob1.reboot;
ob1.z1.obs0.mysql alter system set enable_auto_leader_switch = false;

# batch_switch_rs_leader
let $leader = deploy_get_value(ob1.get_leader sys:oceanbase:__all_core_table:0);
let $leader_ip = deploy_get_value($leader.ip);
let $leader_port = deploy_get_value($leader.port);

let $follower = deploy_get_value(ob1.get_follower sys:oceanbase:__all_core_table:0);
let $follower_ip = deploy_get_value($follower.ip);
let $follower_port = deploy_get_value($follower.port);

let $leader_count = deploy_get_value(ob1.select select count(*)c  from __all_virtual_clog_stat where svr_ip="$leader_ip" and svr_port=$leader_port and role='LEADER' and 1=(table_id >> 40) and 50000>=(table_id << 24)>>24, c, 1);
if ($leader_count > 0) 
{
  echo "leader_count > 0";
}

let $sum = deploy_get_value(ob1.select select count(*)c  from __all_virtual_clog_stat where role='LEADER' and 1=(table_id >> 40) and 50000>=(table_id << 24)>>24, c, 1);

ob1.sh ./etc/ob_admin -h $leader_ip -p $leader_port batch_switch_rs_leader  $follower_ip:$follower_port;
sleep 10;

let $leader_count2 = deploy_get_value(ob1.select select count(*)c  from __all_virtual_clog_stat where svr_ip="$leader_ip" and svr_port=$leader_port and role='LEADER' and 1=(table_id >> 40) and 50000>=(table_id << 24)>>24, c, 1);
if ($leader_count2 == 0) 
{
  echo "leader_count2 == 0";
}

let $sum2 = deploy_get_value(ob1.select select count(*)c  from __all_virtual_clog_stat where role='LEADER' and 1=(table_id >> 40) and 50000>=(table_id << 24)>>24, c, 1);
if ($sum == $sum2) 
{
  echo "batch rs leader success";
}

# auto_batch_switch_rs_leader
let $leader = deploy_get_value(ob1.get_leader sys:oceanbase:__all_core_table:0);
let $leader_ip = deploy_get_value($leader.ip);
let $leader_port = deploy_get_value($leader.port);

let $leader_count = deploy_get_value(ob1.select select count(*)c  from __all_virtual_clog_stat where svr_ip="$leader_ip" and svr_port=$leader_port and role='LEADER' and 1=(table_id >> 40) and 50000>=(table_id << 24)>>24, c, 1);
if ($leader_count > 0) 
{
  echo "leader_count > 0";
}

let $sum = deploy_get_value(ob1.select select count(*)c  from __all_virtual_clog_stat where role='LEADER' and 1=(table_id >> 40) and 50000>=(table_id << 24)>>24, c, 1);

ob1.sh ./etc/ob_admin -h $leader_ip -p $leader_port batch_switch_rs_leader;
sleep 10;

let $leader_count2 = deploy_get_value(ob1.select select count(*)c  from __all_virtual_clog_stat where svr_ip="$leader_ip" and svr_port=$leader_port and role='LEADER' and 1=(table_id >> 40) and 50000>=(table_id << 24)>>24, c, 1);
if ($leader_count2 == 0) 
{
  echo "leader_count2 == 0";
}

let $sum2 = deploy_get_value(ob1.select select count(*)c  from __all_virtual_clog_stat where role='LEADER' and 1=(table_id >> 40) and 50000>=(table_id << 24)>>24, c, 1);
if ($sum == $sum2) 
{
  echo "auto batch rs leader success";
}
