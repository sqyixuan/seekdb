# owner: wenduo.swd
# owner group: STORAGE
#
# enable_upgrade_mode will disable daily and balancing
#

ob1=OBI(cluster=2:2:2,proxy_num=0,init_unit_cpu=0);
ob1.reboot;

ob1.create_client tenant=sys,user=root,passwd=,database=oceanbase;

let $ip0 = deploy_get_value(ob1.z1.obs0.ip);
let $port0 = deploy_get_value(ob1.z1.obs0.port);
let $ip1 = deploy_get_value(ob1.z1.obs1.ip);
let $port1 = deploy_get_value(ob1.z1.obs1.port);

ob1.mysql alter system set resource_soft_limit = 500;
ob1.mysql alter system set resource_hard_limit = 800;
ob1.mysql alter system set balancer_idle_time = '10s';
ob1.mysql alter system set debug_sync_timeout = '100s';

ob1.create_client;

sleep 2;

ob1.mysql alter system major freeze;

ob1.check_version 2;

#ob1.mysql alter system set enable_upgrade_mode = 'True';
ob1.mysql alter system set enable_major_freeze = 'True';

# major freeze disabled
sleep 2;

--error 4217, 0
alter system major freeze;

sleep 10;
select zone, value, value, info from oceanbase.__all_zone where name = 'broadcast_version' order by zone;

# blanader disabled
set ob_global_debug_sync = 'BEFORE_REBALANCE_TASK_EXECUTE wait_for begin timeout 10000000000';
let $dst_ip=deploy_get_value(ob1.z2.obs1.ip);
let $dst_port=deploy_get_value(ob1.z2.obs1.port);
--disable_query_log
eval alter system migrate unit 2 destination '$dst_ip:$dst_port';
--enable_query_log

sleep 15;

select count(*) > 0 as c from oceanbase.__all_virtual_rebalance_task_stat;
