#owner:zhengshi
#owner group: rs
#功能：验证新leader均衡算法

#case1:检查正常情况下能否平铺
#case2:检查创建表之后能否平铺
#case3:检查执行切主后，能否平铺
#case4:检查stop一台server后能否平铺
#case5:检查增加一台server后能否平铺
#case6:轮转合并时，能否平铺
#case7:分别检查单分区表、1级分区表、2级分区表


#case1:检查正常情况下能否平铺
ob1=OBI(cluster=3:3:3,proxy_num=0,memory_size_limit='35G');
ob1.reboot;

let $ob1_ip=deploy_get_value(ob1.z1.obs0.ip);
let $ob1_port=deploy_get_value(ob1.z1.obs0.port);
let $ob2_ip=deploy_get_value(ob1.z1.obs1.ip);
let $ob2_port=deploy_get_value(ob1.z1.obs1.port);
let $ob3_ip=deploy_get_value(ob1.z2.obs0.ip);
let $ob3_port=deploy_get_value(ob1.z2.obs0.port);
let $ob4_ip=deploy_get_value(ob1.z2.obs1.ip);
let $ob4_port=deploy_get_value(ob1.z2.obs1.port);
let $ob5_ip=deploy_get_value(ob1.z3.obs0.ip);
let $ob5_port=deploy_get_value(ob1.z3.obs0.port);
let $ob6_ip=deploy_get_value(ob1.z3.obs1.ip);
let $ob6_port=deploy_get_value(ob1.z3.obs1.port);

#ob1.mysql alter system set resource_soft_limit = 500;
#ob1.mysql alter system set resource_hard_limit = 800;

let $cpu = 1;
let $memory = '1G';
let $min_memory = '1G';
let $disk = 536870912;
let $iops = 100000;
let $session = 64;

ob1.mysql CREATE RESOURCE UNIT test MAX_CPU $cpu, MAX_MEMORY $memory, MAX_IOPS $iops, MAX_DISK_SIZE $disk, MAX_SESSION_NUM $session, MIN_CPU=1, MIN_MEMORY=$min_memory, MIN_IOPS=128;


ob1.mysql CREATE RESOURCE POOL pool1 UNIT = 'test', UNIT_NUM = 2, ZONE_LIST = ('z1', 'z2', 'z3');
ob1.mysql CREATE TENANT obtest1 RESOURCE_POOL_LIST = ('pool1') set ob_tcp_invited_nodes='%';
ob1.mysql CREATE RESOURCE POOL pool2 UNIT = 'test', UNIT_NUM = 3, ZONE_LIST = ('z1', 'z2', 'z3');
ob1.mysql CREATE TENANT obtest2 RESOURCE_POOL_LIST = ('pool2') set ob_tcp_invited_nodes='%';
ob1.mysql CREATE RESOURCE POOL pool3 UNIT = 'test', UNIT_NUM = 3, ZONE_LIST = ('z1', 'z2', 'z3');
ob1.mysql CREATE TENANT obtest3 RESOURCE_POOL_LIST = ('pool3') set ob_tcp_invited_nodes='%';

ob1.mysql alter system set enable_auto_leader_switch = true;
# wait config start to work
sleep 2;

# login as new tenant
ob_connect(conn1, ob1.z1.obs1, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);
ob_connect(conn2, ob1.z1.obs1, root@obtest1, , oceanbase, , USE_MYSQL_CONNECTOR);
ob_connect(conn3, ob1.z1.obs1, root@obtest2, , oceanbase, , USE_MYSQL_CONNECTOR);
ob_connect(conn4, ob1.z1.obs1, root@obtest3, , oceanbase, , USE_MYSQL_CONNECTOR);
connection conn2;
CREATE DATABASE obtest;
use obtest;


#单分区表
let $table_id = 1;
let $table_num = 100;
--disable_query_log
while ($table_id <= $table_num)
{
  eval CREATE TABLE obtest$table_id (pk int, value int, primary key(pk));
  inc $table_id;
}
--enable_query_log
#binding的hash分区表
