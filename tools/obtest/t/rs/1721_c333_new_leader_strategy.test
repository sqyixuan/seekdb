#case3:检查执行切主后，能否平铺
#3.1单分区表

let $z1_leader_cnt = deploy_get_value(ob1.select select count(*) as cnt from oceanbase.__all_virtual_meta_table where table_id in (select table_id from oceanbase.__all_virtual_table where table_name like '%obtest%') and role = 1 and zone = 'z1', cnt, 1);
let $z2_leader_cnt = deploy_get_value(ob1.select select count(*) as cnt from oceanbase.__all_virtual_meta_table where table_id in (select table_id from oceanbase.__all_virtual_table where table_name like '%obtest%') and role = 1 and zone = 'z2', cnt, 1);
let $z3_leader_cnt = deploy_get_value(ob1.select select count(*) as cnt from oceanbase.__all_virtual_meta_table where table_id in (select table_id from oceanbase.__all_virtual_table where table_name like '%obtest%') and role = 1 and zone = 'z3', cnt, 1);

#10张表，leader分布为2731，2731，2730，选出leader数最大的和最小的。
if ($z1_leader_cnt > $z2_leader_cnt)
{
  let $max_leader_zone = 'z1';
  let $min_leader_zone = 'z2';
}
if ($z2_leader_cnt > $z3_leader_cnt)
{
  let $max_leader_zone = 'z2';
  let $min_leader_zone = 'z3';
}
if ($z3_leader_cnt > $z1_leader_cnt)
{
  let $max_leader_zone = 'z3';
  let $min_leader_zone = 'z1';
}

#由2731，2731，2730，变更成2731，2730，2731不会触发leader均衡算法。

let $table_id1 = deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_meta_table where table_id in (select table_id from oceanbase.__all_virtual_table where table_name like '%obtest%') and role = 1 and zone = $max_leader_zone, table_id, 1);
let $change_addr = deploy_get_value(ob1.select select concat(svr_ip, ":", svr_port) as addr from oceanbase.__all_virtual_meta_table where partition_id = 0 and replica_type = 0 and zone = $min_leader_zone and table_id = "$table_id1", addr, 1);
ob1.mysql alter system switch replica leader partition_id='0%0@$table_id1' server='$change_addr';
sleep 10;

#由2731，2730，2731，变更成2731，2729，2732会触发leader均衡算法
#经过刚刚的迁移，导致max_leader_zone变成min_leader_zone
let $table_id2 = deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_meta_table where table_id in (select table_id from oceanbase.__all_virtual_table where table_name like '%obtest%') and role = 1 and zone = $max_leader_zone, table_id, 1);
let $change_addr = deploy_get_value(ob1.select select concat(svr_ip, ":", svr_port) as addr from oceanbase.__all_virtual_meta_table where partition_id = 0 and replica_type = 0 and zone = $min_leader_zone and table_id = "$table_id2", addr, 1);
ob1.mysql alter system switch replica leader partition_id='0%0@$table_id2' server='$change_addr';
sleep 10;
let $table_id2 = deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_meta_table where table_id in (select table_id from oceanbase.__all_virtual_table where table_name like '%obtest%') and role = 1 and zone = $max_leader_zone, table_id, 1);
let $change_addr = deploy_get_value(ob1.select select concat(svr_ip, ":", svr_port) as addr from oceanbase.__all_virtual_meta_table where partition_id = 0 and replica_type = 0 and zone = $min_leader_zone and table_id = "$table_id2", addr, 1);
ob1.mysql alter system switch replica leader partition_id='0%0@$table_id2' server='$change_addr';
sleep 10;
let $table_id2 = deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_meta_table where table_id in (select table_id from oceanbase.__all_virtual_table where table_name like '%obtest%') and role = 1 and zone = $max_leader_zone, table_id, 1);
let $change_addr = deploy_get_value(ob1.select select concat(svr_ip, ":", svr_port) as addr from oceanbase.__all_virtual_meta_table where partition_id = 0 and replica_type = 0 and zone = $min_leader_zone and table_id = "$table_id2", addr, 1);
ob1.mysql alter system switch replica leader partition_id='0%0@$table_id2' server='$change_addr';
sleep 10;
let $table_id2 = deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_meta_table where table_id in (select table_id from oceanbase.__all_virtual_table where table_name like '%obtest%') and role = 1 and zone = $max_leader_zone, table_id, 1);
let $change_addr = deploy_get_value(ob1.select select concat(svr_ip, ":", svr_port) as addr from oceanbase.__all_virtual_meta_table where partition_id = 0 and replica_type = 0 and zone = $min_leader_zone and table_id = "$table_id2", addr, 1);
ob1.mysql alter system switch replica leader partition_id='0%0@$table_id2' server='$change_addr';
sleep 10;
let $table_id2 = deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_meta_table where table_id in (select table_id from oceanbase.__all_virtual_table where table_name like '%obtest%') and role = 1 and zone = $max_leader_zone, table_id, 1);
let $change_addr = deploy_get_value(ob1.select select concat(svr_ip, ":", svr_port) as addr from oceanbase.__all_virtual_meta_table where partition_id = 0 and replica_type = 0 and zone = $min_leader_zone and table_id = "$table_id2", addr, 1);
ob1.mysql alter system switch replica leader partition_id='0%0@$table_id2' server='$change_addr';


sleep 3;
ob1.mysql alter system set enable_auto_leader_switch = true;
