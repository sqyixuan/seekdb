#let $table_num = 2;
#while ($table_id <= $table_num)
#{
#  eval create table tbindhash$table_id (c1 int) tablegroup = tg1 partition by hash(c1) partitions 8192;
#  inc $table_id;
#}

#非binding的hash分区表
CREATE TABLEGROUP tg1 binding false partition by hash partitions 10;
let $table_id = 1;
let $table_num = 1;
while ($table_id <= $table_num)
{
  eval create table t1$table_id(c1 int) tablegroup = tg1 partition by hash(c1) partitions 10;
  inc $table_id;
}

CREATE TABLEGROUP tg2 binding false partition by hash partitions 256;
let $table_id = 1;
let $table_num = 1;
while ($table_id <= $table_num)
{
  eval create table tnobindhash$table_id(c1 int) tablegroup = tg2 partition by hash(c1) partitions 256;
  inc $table_id;
}


CREATE TABLEGROUP tg3 binding false partition by hash partitions 32;
let $table_id = 1;
let $table_num = 1;
while ($table_id <= $table_num)
{
  eval create table nobindhash$table_id(c1 int) tablegroup = tg3 partition by hash(c1) partitions 32;
  inc $table_id;
}

CREATE TABLEGROUP tg4 binding false partition by hash partitions 128;
let $table_id = 1;
let $table_num = 1;
while ($table_id <= $table_num)
{
  eval create table t4$table_id(c1 int) tablegroup = tg4 partition by hash(c1) partitions 128;
  inc $table_id;
}

