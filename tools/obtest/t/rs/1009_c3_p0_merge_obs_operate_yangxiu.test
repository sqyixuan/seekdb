##############################
# owner: rongxuan.lc
# owner group: proxy
#功能点：
# 单zone情况下，合并过程中obs相关操作
#
#用例场景：
#1、发起合并，大集群重启
#2、发起合并，部分obs下线
#3、发起合并，部分obs delete
#4、发起合并，新增obs机器
#
###############################

ob1=OBI(cluster=3:3:3);
ob1.z1.obs2.set status=disable;
ob1.reboot;
sleep 3;
# 并发合并zone的数量，设置成统一合并
ob1.source include/migrate.inc;
ob1.source include/merge.inc;

ob1.create_client;
#source sql/t.sql;
#
#ob1.prepare;
#ob1.start_check;

# 创建3个table:obtest1..obtest3
let $tablenum = 3;
source sql/init_table.sql;

###########
#case1: 发起合并，集群重启
############

ob1.mysql alter system major freeze;

ob1.restart;

# 集群重启需要等0s才能工作
sleep 110;

ob1.check_version 2;

# check data
select count(*) from obtest1;
select * from obtest2 where i1=20;
select * from obtest3 where i1<30 and i1>20;

#########
#case2: 发起合并，部分obs stop，进行迁移
############
--disable_query_log
--disable_result_log
source sql/big_table_3.sql;
--enable_query_log
--enable_result_log

ob1.mysql alter system major freeze;
ob1.z1.obs1.stop;

ob1.check_version 3;

sleep 15;
select count(*) from big_table_3;

ob1.z1.obs1.nstart;
sleep 10;
###########
#case3: 发起合并，部分obs delete
###############
--disable_query_log
--disable_result_log
source sql/big_table_3.sql;
--enable_query_log
--enable_result_log

ob1.mysql alter system major freeze;
ob1.z2.obs1.delete;
ob1.z3.obs2.delete;
ob1.check_version 4;
sleep 20;

ob1.z2.obs1.check_delete 100;
ob1.z3.obs2.check_delete 100;

ob1.z2.obs1.add;
ob1.z3.obs2.add;

select count(*) from big_table_3;
source sql/check_ddl.sql;


############
#case4: 发起合并，新增obs机器 （迁移合并并发）
###############
--disable_query_log
--disable_result_log
source sql/big_table_3.sql;
--enable_query_log
--enable_result_log

ob1.z1.obs2.set status=enable;
ob1.z1.obs2.start;

ob1.z1.obs2.add;
ob1.z1.obs1.delete;


ob1.mysql alter system major freeze;
ob1.check_version 5;

source sql/check_ddl.sql;







