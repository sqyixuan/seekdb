################################################################
# owner: yanmu.ztl
# owner group: storage
#alter system switch replica role功能点测试
#
#用例场景：
#1. 切单个partition的主
#####1.1 把原来为leader的partition切成leader
#####1.2 把原来为follower的partition切成follower
#####1.3 把原来为leader的partition切成follower
#####1.4 把原来为follower的partition的切成leader
#####1.5 把__all_core_table的partition切成leader
#####1.6 把__all_core_table的partition切成follower
#2. 切单个server的主
#####2.1 把server切成leader
#####2.2 把server切成follower
#####2.3 把一个server上某个租户的partition全部切成leader
#####2.4 把一个server上某个租户的partition全部切成follower
#3. 切单个zone的主
#####3.1 把zone切成leader
#####3.2 把zone切成follower
#####3.3 把一个zone上的某个租户的partition全部切成leader
#####3.4 把一个zone上的某个租户的partition全部切成follower
################################################################

##construct the cluster
ob1=OBI(cluster=1:1:1,proxy_num=0);
ob1.reboot;

let $obs = deploy_get_value(ob1.z1.obs0.ip);
let $port = deploy_get_value(ob1.z1.obs0.mysql_port);

ob1.mysql alter system set enable_auto_leader_switch = 'False';
ob1.mysql alter system set resource_hard_limit = '120';
sleep 2;

let $cpu = 1;
let $memory = 1073741824;
let $min_memory = 1073741824;
let $disk = 536870912;
let $iops = 100000;
let $session = 64;

ob1.mysql CREATE RESOURCE UNIT test MAX_CPU $cpu, MAX_MEMORY $memory, MAX_IOPS $iops, MAX_DISK_SIZE $disk, MAX_SESSION_NUM $session, MIN_CPU=1, MIN_MEMORY=$min_memory, MIN_IOPS=128;

##create the tenant
ob1.mysql CREATE RESOURCE POOL pool1 UNIT = 'test', UNIT_NUM = 1, ZONE_LIST = ('z1', 'z2', 'z3');
ob1.mysql CREATE TENANT tenant RESOURCE_POOL_LIST = ('pool1') set ob_tcp_invited_nodes='%';

ob1.mysql set @@ob_query_timeout = 200000000;
ob1.mysql set @@global.ob_query_timeout = 400000000000;
#wait for config taking effect
sleep 2;

##create the table
connect(conn1, $obs, root@tenant, , oceanbase, $port);
connection conn1;
CREATE DATABASE db;
use db;

CREATE TABLE table1 (pk int, value int, primary key(pk));

connect(conn_root, $obs, root@sys, , oceanbase, $port);
connection conn_root;

###########
##case 1.1
###########
echo case 1.1;
let $leader = deploy_get_value(ob1.get_leader tenant:db:table1:0);
let $leader_ip = deploy_get_value($leader.ip);
let $leader_port = deploy_get_value($leader.port);
let $table_id = deploy_get_value(ob1.select select /*+ read_consistency(weak) */ table_id from __all_virtual_table where table_name = 'table1', table_id, 1);
ob1.mysql alter system switch replica leader partition_id = '0%1@$table_id' server = '$leader_ip:$leader_port';
sleep 30;
let $partition_id = 0;
let $partition_cnt = 1;
let $ip = $leader_ip;
let $port = $leader_port;
source include/get_user_partition_role.inc;

###########
##case 1.2
###########
echo case 1.2;
let $follower = deploy_get_value(ob1.get_follower tenant:db:table1:0);
let $follower_ip = deploy_get_value($follower.ip);
let $follower_port = deploy_get_value($follower.port);
ob1.mysql alter system switch replica follower partition_id = '0%1@$table_id' server = '$follower_ip:$follower_port';
sleep 30;
let $ip = $follower_ip;
let $port = $follower_port;
source include/get_user_partition_role.inc;

###########
##case 1.3
###########
echo case 1.3;
let $leader = deploy_get_value(ob1.get_leader tenant:db:table1:0);
let $leader_ip = deploy_get_value($leader.ip);
let $leader_port = deploy_get_value($leader.port);
ob1.mysql alter system switch replica follower partition_id = '0%1@$table_id' server = '$leader_ip:$leader_port';
sleep 30;
let $ip = $leader_ip;
let $port = $leader_port;
source include/get_user_partition_role.inc;

###########
##case 1.4
###########
echo case 1.4;
let $follower = deploy_get_value(ob1.get_follower tenant:db:table1:0);
let $follower_ip = deploy_get_value($follower.ip);
let $follower_port = deploy_get_value($follower.port);
ob1.mysql alter system switch replica leader partition_id = '0%1@$table_id' server = '$follower_ip:$follower_port';
sleep 30;
let $ip = $follower_ip;
let $port = $follower_port;
source include/get_user_partition_role.inc;

###########
##case 1.5
##########
echo case 1.5;
let $follower = deploy_get_value(ob1.get_follower sys:oceanbase:__all_core_table:0);
let $follower_ip = deploy_get_value($follower.ip);
let $follower_port = deploy_get_value($follower.port);
let $table_id = deploy_get_value(ob1.select select /*+ read_consistency(weak) */ table_id from __all_virtual_core_meta_table, table_id, 1);
let $partition_id = 0;
let $partition_cnt = 1;
ob1.mysql alter system switch replica leader partition_id = '0%1@$table_id' server = '$follower_ip:$follower_port';
sleep 30;
let $ip = $follower_ip;
let $port = $follower_port;
source include/get_all_core_table_partition_role.inc;

###########
##case 1.6
##########
echo case 1.6;
let $leader = deploy_get_value(ob1.get_leader sys:oceanbase:__all_core_table:0);
let $leader_ip = deploy_get_value($leader.ip);
let $leader_port = deploy_get_value($leader.port);
ob1.mysql alter system switch replica follower partition_id = '0%1@$table_id' server = '$leader_ip:$leader_port';
sleep 30;
let $ip = $leader_ip;
let $port = $leader_port;
source include/get_all_core_table_partition_role.inc;

###########
##case 2.1
###########
echo case 2.1;
let $obs = deploy_get_value(ob1.get_follower tenant:db:table1:0);
let $obs_ip = deploy_get_value($obs.ip);
let $obs_port = deploy_get_value($obs.port);
--disable_query_log
--error 0,4550
eval alter system switch replica leader server = '$obs_ip:$obs_port';
--enable_query_log
sleep 30;
let $ip = $obs_ip;
let $port = $obs_port;
source include/get_server_role.inc;

###########
##case 2.2
###########
echo case 2.2;
--disable_query_log
--error 0,4550
eval alter system switch replica follower server = '$obs_ip:$obs_port';
--enable_query_log
sleep 30;
let $ip = $obs_ip;
let $port = $obs_port;
source include/get_server_role.inc;

###########
##case 2.3
###########
echo case 2.3;
let $follower = deploy_get_value(ob1.get_follower tenant:db:table1:0);
let $follower_ip = deploy_get_value($follower.ip);
let $follower_port = deploy_get_value($follower.port);
let $tenant_name = tenant;
ob1.mysql alter system switch replica leader server = '$follower_ip:$follower_port' tenant = '$tenant_name';
sleep 30;
let $ip = $follower_ip;
let $port = $follower_port;
source include/get_server_tenant_role.inc;

###########
##case 2.4
###########
echo case 2.4;
let $leader = deploy_get_value(ob1.get_leader tenant:db:table1:0);
let $leader_ip = deploy_get_value($leader.ip);
let $leader_port = deploy_get_value($leader.port);
let $tenant_name = tenant;
ob1.mysql alter system switch replica follower server = '$leader_ip:$leader_port' tenant = '$tenant_name';
sleep 30;
let $ip = $leader_ip;
let $port = $leader_port;
source include/get_server_tenant_role.inc;

###########
##case 3.1
###########
echo case 3.1;
let $zone = z1;
--disable_query_log
--error 0,4550
eval alter system switch replica leader zone = '$zone';
--enable_query_log
sleep 30;
source include/get_zone_role.inc;

###########
##case 3.2
###########
echo case 3.2;
let $zone = z2;
--disable_query_log
--error 0,4550
eval alter system switch replica follower zone = '$zone';
--enable_query_log
sleep 30;
source include/get_zone_role.inc;

###########
##case 3.3
###########
echo case 3.3;
let $zone = z2;
let $tenant_name = tenant;
ob1.mysql alter system switch replica leader zone = '$zone' tenant = '$tenant_name';
sleep 30;
source include/get_zone_tenant_role.inc;

###########
##case 3.4
###########
echo case 3.4;
let $zone = z2;
let $tenant_name = tenant;
ob1.mysql alter system switch replica follower zone = '$zone' tenant = '$tenant_name';
sleep 30;
source include/get_zone_tenant_role.inc;
