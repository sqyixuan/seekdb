source include/check_partition_placememt.inc;
let $table_id = deploy_get_value(ob1.select select table_id from __all_virtual_table where tenant_id = $tenant_id and table_name = 't3', table_id, 1);
ob1.check_until_timeout select count(*) from __all_virtual_meta_table where table_id = $table_id and data_version != -1, 9, 2; 
