##1. 不带TABLEGROUP；FFFLL; L2宕机；
let $stop_obs = deploy_get_value(ob1.select select concat(svr_ip,":",svr_port) addr from __all_unit where resource_pool_id = $resource_pool_id_3 and zone= 'z2' and replica_type=5, addr, 1);
let $obi2 = deploy_get_value(ob1.get_obs_by_addr $stop_obs);
$obi2.force_stop;
ob1.check_until_timeout select count(*) from __all_server where  start_service_time <= 0, 2, 120; 
set ob_create_table_strict_mode = on;
--error 4624
create table t3(c1 int primary key, c2 int) partition by hash(c1) partitions 3;
set ob_create_table_strict_mode = off;
