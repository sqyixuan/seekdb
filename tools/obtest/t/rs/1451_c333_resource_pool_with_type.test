$obi.start;
$obi2.start;
ob1.check_until_timeout select count(*) from __all_server where  start_service_time <= 0, 0, 120; 
create table t4(c1 int primary key, c2 int) partition by hash(c1) partitions 3;
source include/check_partition_placememt.inc;
drop table t4;
create tablegroup tg partition by hash partitions 6;
create table sample_test(c1 int primary key, c2 int) tablegroup tg partition by hash(c1) partitions 6;
