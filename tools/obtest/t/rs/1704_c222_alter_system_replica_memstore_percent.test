# owner: zhenghi.jhc
# owner group: rs
# 功能：增加memstore_percent语句，验证语句正确性，同时验证多replica_type、memstore_percent报错信息，给定不同replica对应的memstore_percent值，对错误输入报错。

ob1=OBI(cluster=2:2:2, node_cpu_count=64, memory_size_limit=1099511627776, proxy_num=0, ct_num=0);

ob1.reboot;

ob1.mysql alter system set resource_hard_limit=900;
ob1.mysql alter system set resource_soft_limit=800;

let $cpu = 1;
let $memory = 1073741824;
let $min_memory = 1073741824;
let $disk = 536870912;
let $iops = 100000;
let $session = 64;

ob1.mysql CREATE RESOURCE UNIT unit_1 MAX_CPU $cpu, MAX_MEMORY $memory, MAX_IOPS $iops, MAX_DISK_SIZE $disk, MAX_SESSION_NUM $session, MIN_CPU=1, MIN_MEMORY=$min_memory, MIN_IOPS=128;
ob1.mysql CREATE RESOURCE POOL pool_1 UNIT = 'unit_1', UNIT_NUM = 2, ZONE_LIST = ('z1','z2','z3');
ob1.mysql CREATE TENANT tenant_1 RESOURCE_POOL_LIST = ('pool_1'), primary_zone = 'z1;z2,z3', locality='F{1}@z1,F{1}@z2,F{1},R{1}@z3' set ob_tcp_invited_nodes='%';
let $resource_pool_id = deploy_get_value(ob1.select select resource_pool_id from __all_resource_pool where name = 'pool_1', resource_pool_id, 1);
let $tenant1_id = deploy_get_value(ob1.select select tenant_id from __all_tenant where tenant_name = "tenant_1", tenant_id, 1);

let $rs = deploy_get_value(ob1.get_leader sys:oceanbase:__all_core_table:0);
let $rs_ip = deploy_get_value($rs.ip);
let $rs_port = deploy_get_value($rs.port);
let $rs_mysql_port = deploy_get_value($rs.mysql_port);
connect (conn_sys,$rs_ip,admin@sys,admin,oceanbase,$rs_mysql_port);
connect (conn_tenant_1,$rs_ip,root@tenant_1,,test,$rs_mysql_port);
# 建表
connection conn_tenant_1;
use test;
create table t1(c1 int, c2 int) partition by hash(c1) partitions 3;
let $t1_id = deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where tenant_id = "$tenant1_id" and table_name = "t1", table_id, 1);

connection conn_sys;

#第一次测试将F->R
let $change_addr = deploy_get_value(ob1.select select concat(svr_ip, ":", svr_port) as addr from oceanbase.__all_virtual_meta_table where partition_id = 0 and replica_type = 0 and zone = "z3" and table_id = "$t1_id", addr, 1);
#--4016
ob1.mysql alter system change replica partition_id = "0%0@$t1_id" server = "$change_addr" change replica_type = "F" memstore_percent = 0;
ob1.check_until_timeout select count(*) from __all_virtual_table where table_id = $t1_id and previous_locality != '', 0, 100;
