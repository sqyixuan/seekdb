# owner: rongxuan.lc
# description: 本case是为了建resource pool的时候指定replica_type;满足一个zone内既有L又有F的需求；

ob1=OBI(cluster=2:2:2,  proxy_num=0, ct_num = 0);
ob1.reboot;
#ob1.mysql create table oceanbase.test(c1 int, c2 int);
ob1.mysql alter system set resource_hard_limit=900;
ob1.mysql alter system set resource_soft_limit=800;
ob1.mysql alter system set balancer_idle_time = '10s';
ob1.mysql alter system set server_data_copy_in_concurrency =50;
ob1.mysql alter system set server_data_copy_out_concurrency = 50;
ob1.mysql alter system set data_copy_concurrency = 200;

let $cpu = 1;
let $memory = 1073741824;
let $min_memory = 1073741824;
let $disk = 536870912;
let $iops = 100000;
let $session = 64;
let $case_index = 1;

ob1.mysql CREATE RESOURCE UNIT unit_$case_index MAX_CPU $cpu, MAX_MEMORY $memory, MAX_IOPS $iops, MAX_DISK_SIZE $disk, MAX_SESSION_NUM $session, MIN_CPU=1, MIN_MEMORY=$min_memory, MIN_IOPS=128;
ob1.mysql CREATE RESOURCE POOL pool_$case_index UNIT = 'unit_$case_index', UNIT_NUM = 1, ZONE_LIST = ('z1', 'z2','z3');
ob1.mysql CREATE TENANT tenant_$case_index RESOURCE_POOL_LIST = ('pool_$case_index'), locality='F@z1,F@z2,L@z3', primary_zone='z1;z2;z3' set ob_tcp_invited_nodes='%';

let $case_index = 2;
ob1.mysql CREATE RESOURCE UNIT unit_$case_index MAX_CPU $cpu, MAX_MEMORY $memory, MAX_IOPS $iops, MAX_DISK_SIZE $disk, MAX_SESSION_NUM $session, MIN_CPU=1, MIN_MEMORY=$min_memory, MIN_IOPS=128;
ob1.mysql CREATE RESOURCE POOL pool_$case_index UNIT = 'unit_$case_index', UNIT_NUM = 1, ZONE_LIST = ('z1', 'z2','z3'), replica_type= 'L';

ob1.create_client tenant=sys,user=root,passwd=,database=oceanbase;
--error 4179 
eval CREATE TENANT tenant_$case_index RESOURCE_POOL_LIST = ('pool_$case_index'), locality='F@z1,F@z2,L@z3', primary_zone='z1;z2;z3' set ob_tcp_invited_nodes='%';

ob1.mysql_p select replica_type from oceanbase.__all_unit order by unit_id;
ob1.mysql_p select replica_type from oceanbase.__all_resource_pool order by resource_pool_id;

ob1.mysql alter resource pool pool_1 unit_num = 2;
--error 1235
alter resource pool pool_2 unit_num = 2;
ob1.mysql_p select replica_type from oceanbase.__all_unit order by unit_id;

let $case_index = 3;
ob1.mysql CREATE RESOURCE POOL pool_$case_index UNIT = 'unit_2', UNIT_NUM = 1, ZONE_LIST = ('z1', 'z2','z3'), replica_type= 'F';
ob1.create_client tenant=sys,user=root,passwd=,database=oceanbase;
--error 4657
alter tenant tenant_1 RESOURCE_POOL_LIST = ('pool_1', 'pool_3');
let $case_index = 4;
ob1.mysql CREATE RESOURCE POOL pool_$case_index UNIT = 'unit_2', UNIT_NUM = 1, ZONE_LIST = ('z1', 'z2','z3'), replica_type= 'L';
--error 1235
alter tenant tenant_1 RESOURCE_POOL_LIST = ('pool_1', 'pool_4');
ob1.mysql alter tenant tenant_1 set locality='F@z1,F@z2';
ob1.check_until_timeout select count(*) from __all_rootservice_job where job_status = "SUCCESS", 1, 120;
--error 4656
alter tenant tenant_1 RESOURCE_POOL_LIST = ('pool_1', 'pool_4');

###新建租户有两个resource pool
let $case_index = 5;
ob1.mysql CREATE RESOURCE POOL pool_$case_index UNIT = 'unit_2', UNIT_NUM = 1, ZONE_LIST = ('z1', 'z2','z3'), replica_type= 'F';
let $case_index = 6;
--error 1235
eval CREATE RESOURCE POOL pool_$case_index UNIT = 'unit_2', UNIT_NUM = 2, ZONE_LIST = ('z1', 'z2'), replica_type= 'L';
ob1.mysql CREATE RESOURCE POOL pool_$case_index UNIT = 'unit_2', UNIT_NUM = 1, ZONE_LIST = ('z1', 'z2'), replica_type= 'L';
eval CREATE TENANT tenant_$case_index RESOURCE_POOL_LIST = ('pool_5', 'pool_6'), locality='F@z1,F@z2,F@z3,L@z1', primary_zone='z1;z2;z3' set ob_tcp_invited_nodes='%';
let $case_index = 7;
ob1.mysql CREATE RESOURCE POOL pool_$case_index UNIT = 'unit_2', UNIT_NUM = 1, ZONE_LIST = ('z1', 'z2'), replica_type= 'L';
###新建租户有三个resource pool
let $case_index = 8;
ob1.mysql CREATE RESOURCE POOL pool_$case_index UNIT = 'unit_2', UNIT_NUM = 1, ZONE_LIST = ('z1', 'z2');
let $case_index = 9;
ob1.mysql CREATE RESOURCE POOL pool_$case_index UNIT = 'unit_2', UNIT_NUM =1, zone_list=('z3');
let $case_index = 10;
ob1.mysql CREATE RESOURCE POOL pool_$case_index UNIT = 'unit_2', UNIT_NUM = 1, ZONE_LIST = ('z1', 'z2','z3'), replica_type= 'F';
let $case_index = 11;
ob1.mysql CREATE RESOURCE POOL pool_$case_index UNIT = 'unit_2', UNIT_NUM = 1, ZONE_LIST = ('z1', 'z2','z3'), replica_type= 'L';
###L unit只能存L副本；不能存R或者L；
###同一个zone只能有一个F；
#--error 4657
#CREATE TENANT tenant_$case_index RESOURCE_POOL_LIST = ('pool_8', 'pool_9', 'pool_11'), locality='F@z1,F@z2,F@z3,F@z1,L@z2,L@z3', primary_zone='z1;z2;z3' set ob_tcp_invited_nodes='%';
#--error 4657
#CREATE TENANT tenant_$case_index RESOURCE_POOL_LIST = ('pool_8', 'pool_9', 'pool_11'), locality='F@z1,F@z2,F@z3,R@z1,L@z2,L@z3', primary_zone='z1;z2;z3' set ob_tcp_invited_nodes='%';
--error 1210 
eval CREATE TENANT tenant_$case_index RESOURCE_POOL_LIST = ('pool_8', 'pool_9', 'pool_10'), locality='F@z1,F@z2,F@z3,L@z1,L@z2,L@z3', primary_zone='z1;z2;z3' set ob_tcp_invited_nodes='%';
eval CREATE TENANT tenant_$case_index RESOURCE_POOL_LIST = ('pool_8', 'pool_9', 'pool_11'), locality='F@z1,F@z2,F@z3,L@z1,L@z2,L@z3', primary_zone='z1;z2;z3' set ob_tcp_invited_nodes='%';
##检查一个租户的unit不在同一个机器上
let $tenant_id = deploy_get_value(ob1.select select tenant_id from __all_tenant where tenant_name = 'tenant_11', tenant_id, 1);
ob1.check_until_timeout select count(*) from (select distinct concat(svr_ip,svr_port) from __all_unit where resource_pool_id in (select resource_pool_id from __all_resource_pool where tenant_id = $tenant_id))s, 6, 3;

###建租户检查unit数是否满足locality;
ob1.mysql drop tenant tenant_6 force;
--error 4179
eval create tenant tenant_12 RESOURCE_POOL_LIST = ('pool_5'), locality='F@z1,F@z2,F@z3,R@z3' set ob_tcp_invited_nodes='%';
--error 1210 
eval CREATE TENANT tenant_12 RESOURCE_POOL_LIST = ('pool_5', 'pool_7'), locality='F@z1,F@z2,F@z3,L@z3', primary_zone='z1;z2;z3' set ob_tcp_invited_nodes='%';
ob1.mysql CREATE TENANT tenant_12 RESOURCE_POOL_LIST = ('pool_5', 'pool_7'), locality='F@z1,F@z2,F@z3,L@z1', primary_zone='z1;z2;z3' set ob_tcp_invited_nodes='%';
--error 4179
eval alter tenant tenant_12 set locality='F@z1,F@z2,F@z3,L@z1,R@z2';
--error 1210 
eval alter tenant tenant_12 set locality='F@z1,F@z2,F@z3,L@z1,L@z3';
create resource pool pool_obstress1 unit='unit_1', unit_num=1;
create resource pool pool_obstress2 unit='unit_1', unit_num=1, replica_type='L';
create tenant t1 resource_pool_list=('pool_obstress1') set ob_tcp_invited_nodes='%';
alter tenant t1 resource_pool_list=('pool_obstress1','pool_obstress2');
--error 4179
alter tenant t1 locality='FULL{1},L@z1, FULL@z2, F@z3,R@z2, R@z3';
--error 4179
alter tenant t1 locality='FULL{1}, FULL@z2, F@z3,R@z2';

