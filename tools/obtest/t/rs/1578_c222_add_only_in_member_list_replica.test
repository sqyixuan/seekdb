# owner: yanmu.ztl
# owner group: rs
# description: only_in_member_list的副本在补副本时，需要考虑locality分区，replica_type不能取缺省的F
#              

ob1=OBI(cluster=2:2:2, init_unit_cpu=0, proxy_num=0, ct_num=0, locality=hz:hz:hz);
ob1.reboot;

ob1.mysql alter system set balance_blacklist_failure_threshold = 0;

let $cpu = 1;
let $memory = 1073741824;
let $min_memory = 1073741824;
let $disk = 536870912;
let $iops = 100000;
let $session = 64;

let $rs = deploy_get_value(ob1.get_leader sys:oceanbase:__all_core_table:0);
let $rs_ip = deploy_get_value($rs.ip);
let $rs_port = deploy_get_value($rs.port);
let $rs_mysql_port = deploy_get_value($rs.mysql_port);
connect (conn_sys,$rs_ip,admin@sys,admin,oceanbase,$rs_mysql_port);

ob1.mysql CREATE RESOURCE UNIT unit_1 MAX_CPU $cpu, MAX_MEMORY $memory, MAX_IOPS $iops, MAX_DISK_SIZE $disk, MAX_SESSION_NUM $session, MIN_CPU=1, MIN_MEMORY=$min_memory, MIN_IOPS=128;
ob1.mysql CREATE RESOURCE POOL pool_1 UNIT = 'unit_1', UNIT_NUM = 1, ZONE_LIST = ('z1','z2','z3');
ob1.mysql CREATE RESOURCE POOL pool_2 UNIT = 'unit_1', UNIT_NUM = 1, ZONE_LIST = ('z1','z2','z3'), replica_type = 'L';
ob1.mysql CREATE TENANT tenant_1 RESOURCE_POOL_LIST = ('pool_1', 'pool_2'), primary_zone = 'z1;z2;z3', locality='F@z1,F,L@z2,F,L@z3' set ob_tcp_invited_nodes='%';
sleep 10;

connect (conn_tenant,$rs_ip,root@tenant_1,,test,$rs_mysql_port);
# 单向阻塞rs->z3的网络, 使新建partition缺失z3的两个副本
$rs.block_net ob1.z3.obs0;
$rs.block_net ob1.z3.obs1;
# 通过非严格模式建表，只要多数派成功即可
set @@session.ob_create_table_strict_mode = false;
create table t1(c1 int, c2 int);
# 解除网络阻塞
$rs.clean_net ob1.z3.obs0;
$rs.clean_net ob1.z3.obs1;
# 验证相关任务生成
let $table_id = deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where table_name = "t1", table_id, 1);
#let $condition = value1 like "%$table_id%" and value4 = 0 and ((event like "%finish_rebuild_replica%" and value6 like "%rebuild only in memberlist replica%") or (event like "%finish_migrate_replica%" and value6 like "%migrate only in memberlist replica%"));
let $condition = value1 like "%$table_id%" and ((event like "%start_rebuild_replica%" and value4 like "%rebuild only in memberlist replica%") or (event like "%start_migrate_replica%" and value4 like "%migrate only in memberlist replica%"));
ob1.check_until_timeout select count(*) from oceanbase.__all_rootservice_event_history where value2 like "%replica_type:0%" and $condition, 1, 360;
ob1.check_until_timeout select count(*) from oceanbase.__all_rootservice_event_history where value2 like "%replica_type:5%" and $condition, 1, 360;
