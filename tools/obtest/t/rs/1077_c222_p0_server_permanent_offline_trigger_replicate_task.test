# owner: rongxuan.lc
# owner group: STORAGE
#
# If server permanent offline, replicate task should be generated.
# Bug:
#   

ob1=OBI(cluster=2:2:2,proxy_num=0,init_unit_cpu=0);
ob1.reboot;

ob1.mysql alter system set debug_sync_timeout = '1000s';
ob1.mysql alter system set balancer_idle_time = '10s';
ob1.mysql alter system set server_permanent_offline_time = '20s';

sleep 2;
ob1.mysql set ob_global_debug_sync = 'REBALANCE_TASK_MGR_BEFORE_EXECUTE_OVER wait_for begin timeout 10000000000';
ob1.z3.obs0.force_stop;
let $ip = deploy_get_value(ob1.z3.obs0.ip);
ob1.check_until_timeout select count(*) > 0 from oceanbase.__all_virtual_rebalance_task_stat where task_type = "ADD_REPLICA", 1, 100;
ob1.check_until_timeout select count(*) > 0 from oceanbase.__all_virtual_rebalance_task_stat where is_replicate = "Yes", 1, 3;
ob1.mysql_p select task_type, is_replicate, cnt > 0 from (select task_type, is_replicate, count(*) cnt from oceanbase.__all_virtual_rebalance_task_stat);
