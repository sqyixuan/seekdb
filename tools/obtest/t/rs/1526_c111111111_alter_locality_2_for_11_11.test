# owner: yanmu.ztl
# owner group: rs
# description：验证2017年双11弹性大促方案中，流水型locality变更的过程
#
# 示例如下：
# 常态时的locality分布：
# |hz   |qdh        |sz                           |mancore       |
# |z9   |z7    z8   |z1       z2    z3       z4   |z5       z6   |
# |     |           |40/02(F)       40/02(F)      |40/02(F)      |
# |     |           |41/02(F)       41/02(F)      |41/02(F)      |
# |     |           |42/02(F)       42/02(F)      |42/02(F)      |
# |     |           |43/02(F)       43/02(F)      |43/02(F)      |
#
# ====》
#
# 弹出时的locality分布：
# |hz      |qdh              |sz                                 |mancore          |
# |z9      |z7    z8         |z1       z2       z3       z4      |z5       z6      |
# |        |                 |40/02(F)          40/02(F)         |40/02(F)         |
# |        |                 |         41/02(F)          41/02(F)|         41/02(F)|
# |41/52(F)|41/52(F) 41/52(F)|                                   |                 |
# |        |                 |42/02(F)          42/02(F)         |42/02(F)         |
# |        |                 |         42/52(F)          42/52(F)|         42/52(F)|
# |        |                 |43/02(F)          43/02(F)         |43/02(F)         |
# |43/52(F)|43/52(F) 43/52(F)|                                   |                 |
#
# ====》
#
# 弹回时的locality分布：
# |hz      |qdh              |sz                                 |mancore          |
# |z9      |z7    z8         |z1       z2       z3       z4      |z5       z6      |
# |        |                 |40/02(F)          40/02(F)         |40/02(F)         |
# |        |                 |41/02(F)          41/02(F)         |41/02(F)         |
# |        |                 |41/52(F)          41/52(F)         |41/52(F)         |
# |        |                 |42/02(F)          42/02(F)         |42/02(F)         |
# |        |                 |42/52(F)          42/52(F)         |42/52(F)         |
# |        |                 |43/02(F)          43/02(F)         |43/02(F)         |
# |        |                 |43/52(F)          43/52(F)         |43/52(F)         |
#
# 说明：
# A,B,C分别对应z1,z2,z3副本
# D,E,F分别对应z7,z8,z9/z2,z4,z6副本

ob1=OBI(cluster=1:1:1:1:1:1:1:1:1, init_unit_cpu=0, proxy_num=0, ct_num=0, locality = sz:sz:sz:sz:mancore:mancore:qdh:qdh:hz);

# disable 6 server, 系统租户在z1,z3,z5
ob1.z2.obs0.set status=disable;
ob1.z4.obs0.set status=disable;
ob1.z6.obs0.set status=disable;
ob1.z7.obs0.set status=disable;
ob1.z8.obs0.set status=disable;
ob1.z9.obs0.set status=disable;

ob1.reboot;

ob1.z2.add;
ob1.z2.start_zone;
ob1.z2.obs0.set status=enable;
ob1.z2.obs0.start;
ob1.z2.obs0.add;

ob1.z4.add;
ob1.z4.start_zone;
ob1.z4.obs0.set status=enable;
ob1.z4.obs0.start;
ob1.z4.obs0.add;

ob1.z6.add;
ob1.z6.start_zone;
ob1.z6.obs0.set status=enable;
ob1.z6.obs0.start;
ob1.z6.obs0.add;

ob1.z7.add;
ob1.z7.start_zone;
ob1.z7.obs0.set status=enable;
ob1.z7.obs0.start;
ob1.z7.obs0.add;

ob1.z8.add;
ob1.z8.start_zone;
ob1.z8.obs0.set status=enable;
ob1.z8.obs0.start;
ob1.z8.obs0.add;

ob1.z9.add;
ob1.z9.start_zone;
ob1.z9.obs0.set status=enable;
ob1.z9.obs0.start;
ob1.z9.obs0.add;

sleep 30;

ob1.mysql alter system set enable_auto_leader_switch = 'true';
ob1.mysql alter system set enable_rebalance = 'true';
ob1.mysql alter system set enable_rereplication = 'true';
ob1.mysql alter system set balancer_idle_time = '10s';

let $cpu = 1;
let $memory = 1073741824;
let $min_memory = 1073741824;
let $disk = 536870912;
let $iops = 100000;
let $session = 64;
ob1.mysql CREATE RESOURCE UNIT unit_1 MAX_CPU $cpu, MAX_MEMORY $memory, MAX_IOPS $iops, MAX_DISK_SIZE $disk, MAX_SESSION_NUM $session, MIN_CPU=1, MIN_MEMORY=$min_memory, MIN_IOPS=128;

# 创建resource_pool
ob1.mysql CREATE RESOURCE POOL pool_40_02 UNIT = 'unit_1', UNIT_NUM = 1, ZONE_LIST = ('z1','z3','z5');
ob1.mysql CREATE RESOURCE POOL pool_41_02 UNIT = 'unit_1', UNIT_NUM = 1, ZONE_LIST = ('z1','z3','z5');
ob1.mysql CREATE RESOURCE POOL pool_42_02 UNIT = 'unit_1', UNIT_NUM = 1, ZONE_LIST = ('z1','z3','z5');
ob1.mysql CREATE RESOURCE POOL pool_43_02 UNIT = 'unit_1', UNIT_NUM = 1, ZONE_LIST = ('z1','z3','z5');
ob1.mysql CREATE RESOURCE POOL pool_41_02_add UNIT = 'unit_1', UNIT_NUM = 1, ZONE_LIST = ('z2','z4','z6');
ob1.mysql CREATE RESOURCE POOL pool_40_52 UNIT = 'unit_1', UNIT_NUM = 1, ZONE_LIST = ('z1','z3','z5');
ob1.mysql CREATE RESOURCE POOL pool_41_52 UNIT = 'unit_1', UNIT_NUM = 1, ZONE_LIST = ('z1','z3','z5');
ob1.mysql CREATE RESOURCE POOL pool_42_52 UNIT = 'unit_1', UNIT_NUM = 1, ZONE_LIST = ('z1','z3','z5');
ob1.mysql CREATE RESOURCE POOL pool_43_52 UNIT = 'unit_1', UNIT_NUM = 1, ZONE_LIST = ('z1','z3','z5');
ob1.mysql CREATE RESOURCE POOL pool_41_52_add UNIT = 'unit_1', UNIT_NUM = 1, ZONE_LIST = ('z7','z8','z9');
ob1.mysql CREATE RESOURCE POOL pool_42_52_add UNIT = 'unit_1', UNIT_NUM = 1, ZONE_LIST = ('z2','z4','z6');
ob1.mysql CREATE RESOURCE POOL pool_43_52_add UNIT = 'unit_1', UNIT_NUM = 1, ZONE_LIST = ('z7','z8','z9');

let $z1_obs0_ip = deploy_get_value(ob1.z1.obs0.ip);
let $z1_obs0_mysql_port = deploy_get_value(ob1.z1.obs0.mysql_port);
let $z2_obs0_ip = deploy_get_value(ob1.z2.obs0.ip);
let $z2_obs0_mysql_port = deploy_get_value(ob1.z2.obs0.mysql_port);
let $z7_obs0_ip = deploy_get_value(ob1.z7.obs0.ip);
let $z7_obs0_mysql_port = deploy_get_value(ob1.z7.obs0.mysql_port);

############################
# 常态部署:A,B,C皆为F型副本
############################
ob1.mysql CREATE TENANT tenant_40_02 RESOURCE_POOL_LIST = ('pool_40_02'), primary_zone = 'z1;z3;z5', locality = 'F{1}@z1,F{1}@z3,F{1}@z5' set ob_tcp_invited_nodes='%';
ob1.mysql CREATE TENANT tenant_41_02 RESOURCE_POOL_LIST = ('pool_41_02'), primary_zone = 'z1;z3;z5', locality = 'F{1}@z1,F{1}@z3,F{1}@z5' set ob_tcp_invited_nodes='%';
ob1.mysql CREATE TENANT tenant_42_02 RESOURCE_POOL_LIST = ('pool_42_02'), primary_zone = 'z1;z3;z5', locality = 'F{1}@z1,F{1}@z3,F{1}@z5' set ob_tcp_invited_nodes='%';
ob1.mysql CREATE TENANT tenant_43_02 RESOURCE_POOL_LIST = ('pool_43_02'), primary_zone = 'z1;z3;z5', locality = 'F{1}@z1,F{1}@z3,F{1}@z5' set ob_tcp_invited_nodes='%';
let $tenant_40_02_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name = "tenant_40_02", tenant_id, 1);
let $tenant_41_02_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name = "tenant_41_02", tenant_id, 1);
let $tenant_42_02_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name = "tenant_43_02", tenant_id, 1);
let $tenant_43_02_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name = "tenant_43_02", tenant_id, 1);

connect(conn_z1_tenant_41_02, $z1_obs0_ip, root@tenant_41_02, , test, $z1_obs0_mysql_port);
# 41_02租户导入数据
--disable_query_log
let $table_limit = 10;
let $row_limit = 10;
let $41_idx = 1;
connection conn_z1_tenant_41_02;
let $count = 1;
while($count <= $table_limit)
{
  eval create table test.table_$count (c1 int, c2 int);
  let $row_count = 1;
  while($row_count <= $row_limit)
  {
    eval insert into test.table_$count(c1, c2) values($41_idx, $41_idx);
    inc $41_idx;
    inc $row_count;
  }
  inc $count;
}
--enable_query_log

let $row_limit = 100;

###################
# 弹出：1.空库弹出
###################
# 尝试进行major freeze
ob1.mysql alter system major freeze;

ob1.mysql CREATE TENANT tenant_40_52 RESOURCE_POOL_LIST = ('pool_40_52'), primary_zone = 'z1;z3;z5', locality = 'F{1}@z1,F{1}@z3,F{1}@z5' set ob_tcp_invited_nodes='%';
ob1.mysql CREATE TENANT tenant_41_52 RESOURCE_POOL_LIST = ('pool_41_52_add'), primary_zone = 'z7;z8;z9', locality = 'F{1}@z7,F{1}@z8,F{1}@z9' set ob_tcp_invited_nodes='%';
ob1.mysql CREATE TENANT tenant_42_52 RESOURCE_POOL_LIST = ('pool_42_52_add'), primary_zone = 'z2;z4;z6', locality = 'F{1}@z2,F{1}@z4,F{1}@z6' set ob_tcp_invited_nodes='%';
ob1.mysql CREATE TENANT tenant_43_52 RESOURCE_POOL_LIST = ('pool_43_52_add'), primary_zone = 'z7;z8;z9', locality = 'F{1}@z7,F{1}@z8,F{1}@z9' set ob_tcp_invited_nodes='%';
let $tenant_40_52_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name = "tenant_40_52", tenant_id, 1);
let $tenant_41_52_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name = "tenant_41_52", tenant_id, 1);
let $tenant_42_52_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name = "tenant_42_52", tenant_id, 1);
let $tenant_43_52_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name = "tenant_43_52", tenant_id, 1);

#############################################################
# 弹出：2.41_02租户均衡 {F@z1,F@z3,F@z5} -> {F@z2,F@z4,F@z6}
#############################################################
# 尝试进行major freeze
ob1.mysql alter system major freeze;

ob1.mysql ALTER TENANT tenant_41_02 set RESOURCE_POOL_LIST = ('pool_41_02', 'pool_41_02_add');

ob1.mysql ALTER TENANT tenant_41_02 set locality = "F{1}@z1,F{1}@z3,F{1}@z5,R{1}@z2,R{1}@z4,R{1}@z6";
# 简单验证读写操作
--disable_query_log
--disable_result_log
connection conn_z1_tenant_41_02;
let $row_count = 1;
while($row_count <= $row_limit)
{
  select count(*) from test.table_1;
  eval insert into test.table_1(c1, c2) values($41_idx, $41_idx);
  eval update test.table_1 set c1 = c1 + 1, c2 = c2 + 1 where c1 = $41_idx and c2 = $41_idx;
  eval delete from test.table_1 where c1 = $41_idx + 1 and c2 = $41_idx + 1;
  inc $41_idx;
  inc $row_count;
}
--enable_query_log
--enable_result_log
let $last_job_id = deploy_get_value(ob1.select select max(job_id) as job_id from oceanbase.__all_rootservice_job where job_type = "ALTER_TENANT_LOCALITY" group by job_type, job_id, 1);
ob1.check_until_timeout select count(*) as c from oceanbase.__all_rootservice_job where job_id = "$last_job_id" and job_type = "ALTER_TENANT_LOCALITY" and job_status = "SUCCESS", 1, 600;
ob1.mysql ALTER TENANT tenant_41_02 set primary_zone = "z1;z3;z5";
ob1.check_until_timeout select count(*) as c from oceanbase.__all_virtual_meta_table where role = 1 and zone != "z1" and tenant_id = "$tenant_41_02_id", 0, 120;

ob1.mysql ALTER TENANT tenant_41_02 set locality = "F{1}@z1,F{1}@z3,F{1}@z5,F{1}@z2,R{1}@z4,R{1}@z6";
let $last_job_id = deploy_get_value(ob1.select select max(job_id) as job_id from oceanbase.__all_rootservice_job where job_type = "ALTER_TENANT_LOCALITY" group by job_type, job_id, 1);
ob1.check_until_timeout select count(*) as c from oceanbase.__all_rootservice_job where job_id = "$last_job_id" and job_type = "ALTER_TENANT_LOCALITY" and job_status = "SUCCESS", 1, 600;
ob1.mysql ALTER TENANT tenant_41_02 set primary_zone = "z1;z3;z5;z2";
ob1.check_until_timeout select count(*) as c from oceanbase.__all_virtual_meta_table where role = 1 and zone != "z1" and tenant_id = "$tenant_41_02_id", 0, 120;

ob1.mysql ALTER TENANT tenant_41_02 set locality = "F{1}@z1,F{1}@z3,F{1}@z5,F{1}@z2,F{1}@z4,R{1}@z6";
let $last_job_id = deploy_get_value(ob1.select select max(job_id) as job_id from oceanbase.__all_rootservice_job where job_type = "ALTER_TENANT_LOCALITY" group by job_type, job_id, 1);
ob1.check_until_timeout select count(*) as c from oceanbase.__all_rootservice_job where job_id = "$last_job_id" and job_type = "ALTER_TENANT_LOCALITY" and job_status = "SUCCESS", 1, 600;
ob1.mysql ALTER TENANT tenant_41_02 set primary_zone = "z1;z3;z5;z2;z4";
ob1.check_until_timeout select count(*) as c from oceanbase.__all_virtual_meta_table where role = 1 and zone != "z1" and tenant_id = "$tenant_41_02_id", 0, 120;

ob1.mysql ALTER TENANT tenant_41_02 set locality = "F{1}@z1,R{1}@z3,F{1}@z5,F{1}@z2,F{1}@z4,R{1}@z6";
let $last_job_id = deploy_get_value(ob1.select select max(job_id) as job_id from oceanbase.__all_rootservice_job where job_type = "ALTER_TENANT_LOCALITY" group by job_type, job_id, 1);
ob1.check_until_timeout select count(*) as c from oceanbase.__all_rootservice_job where job_id = "$last_job_id" and job_type = "ALTER_TENANT_LOCALITY" and job_status = "SUCCESS", 1, 600;
ob1.mysql ALTER TENANT tenant_41_02 set primary_zone = "z1;z5;z2;z4";
ob1.check_until_timeout select count(*) as c from oceanbase.__all_virtual_meta_table where role = 1 and zone != "z1" and tenant_id = "$tenant_41_02_id", 0, 120;

ob1.mysql ALTER TENANT tenant_41_02 set locality = "F{1}@z1,R{1}@z3,R{1}@z5,F{1}@z2,F{1}@z4,R{1}@z6";
let $last_job_id = deploy_get_value(ob1.select select max(job_id) as job_id from oceanbase.__all_rootservice_job where job_type = "ALTER_TENANT_LOCALITY" group by job_type, job_id, 1);
ob1.check_until_timeout select count(*) as c from oceanbase.__all_rootservice_job where job_id = "$last_job_id" and job_type = "ALTER_TENANT_LOCALITY" and job_status = "SUCCESS", 1, 600;
ob1.mysql ALTER TENANT tenant_41_02 set primary_zone = "z2;z4;z1";
ob1.check_until_timeout select count(*) as c from oceanbase.__all_virtual_meta_table where role = 1 and zone != "z2" and tenant_id = "$tenant_41_02_id", 0, 120;

ob1.mysql ALTER TENANT tenant_41_02 set locality = "F{1}@z1,R{1}@z3,R{1}@z5,F{1}@z2,F{1}@z4,F{1}@z6";
let $last_job_id = deploy_get_value(ob1.select select max(job_id) as job_id from oceanbase.__all_rootservice_job where job_type = "ALTER_TENANT_LOCALITY" group by job_type, job_id, 1);
ob1.check_until_timeout select count(*) as c from oceanbase.__all_rootservice_job where job_id = "$last_job_id" and job_type = "ALTER_TENANT_LOCALITY" and job_status = "SUCCESS", 1, 600;
ob1.mysql ALTER TENANT tenant_41_02 set primary_zone = "z2;z4;z6;z1";
ob1.check_until_timeout select count(*) as c from oceanbase.__all_virtual_meta_table where role = 1 and zone != "z2" and tenant_id = "$tenant_41_02_id", 0, 120;

ob1.mysql ALTER TENANT tenant_41_02 set locality = "R{1}@z1,R{1}@z3,R{1}@z5,F{1}@z2,F{1}@z4,F{1}@z6";

connect(conn_z2_tenant_41_02, $z2_obs0_ip, root@tenant_41_02, , test, $z2_obs0_mysql_port);
# 简单验证读写操作
--disable_query_log
--disable_result_log
connection conn_z2_tenant_41_02;
let $row_count = 1;
while($row_count <= $row_limit)
{
  select count(*) from test.table_1;
  eval insert into test.table_1(c1, c2) values($41_idx, $41_idx);
  eval update test.table_1 set c1 = c1 + 1, c2 = c2 + 1 where c1 = $41_idx and c2 = $41_idx;
  eval delete from test.table_1 where c1 = $41_idx + 1 and c2 = $41_idx + 1;
  inc $41_idx;
  inc $row_count;
}
--enable_query_log
--enable_result_log
let $last_job_id = deploy_get_value(ob1.select select max(job_id) as job_id from oceanbase.__all_rootservice_job where job_type = "ALTER_TENANT_LOCALITY" group by job_type, job_id, 1);
ob1.check_until_timeout select count(*) as c from oceanbase.__all_rootservice_job where job_id = "$last_job_id" and job_type = "ALTER_TENANT_LOCALITY" and job_status = "SUCCESS", 1, 600;
ob1.mysql ALTER TENANT tenant_41_02 set primary_zone = "z2;z4;z6";
ob1.check_until_timeout select count(*) as c from oceanbase.__all_virtual_meta_table where role = 1 and zone != "z2" and tenant_id = "$tenant_41_02_id", 0, 120;

ob1.mysql ALTER TENANT tenant_41_02 set locality = "F{1}@z2,F{1}@z4,F{1}@z6";
let $last_job_id = deploy_get_value(ob1.select select max(job_id) as job_id from oceanbase.__all_rootservice_job where job_type = "ALTER_TENANT_LOCALITY" group by job_type, job_id, 1);
ob1.check_until_timeout select count(*) as c from oceanbase.__all_rootservice_job where job_id = "$last_job_id" and job_type = "ALTER_TENANT_LOCALITY" and job_status = "SUCCESS", 1, 600;
ob1.mysql ALTER TENANT tenant_41_02 set primary_zone = "z2;z4;z6";
ob1.check_until_timeout select count(*) as c from oceanbase.__all_virtual_meta_table where role = 1 and zone != "z2" and tenant_id = "$tenant_41_02_id", 0, 120;

ob1.mysql ALTER TENANT tenant_41_02 set RESOURCE_POOL_LIST = ('pool_41_02_add');

#############################################################
# 弹回：1.41_02租户归位 {F@z2,F@z4,F@z6} -> {F@z1,F@z3,F@z5}
#############################################################
# 尝试进行major freeze
ob1.mysql alter system major freeze;

ob1.mysql ALTER TENANT tenant_41_02 set RESOURCE_POOL_LIST = ('pool_41_02', 'pool_41_02_add');

ob1.mysql ALTER TENANT tenant_41_02 set locality = "F{1}@z2,F{1}@z4,F{1}@z6,R{1}@z1,R{1}@z3,R{1}@z5";
# 简单验证读写操作
--disable_query_log
--disable_result_log
connection conn_z2_tenant_41_02;
let $row_count = 1;
while($row_count <= $row_limit)
{
  select count(*) from test.table_1;
  eval insert into test.table_1(c1, c2) values($41_idx, $41_idx);
  eval update test.table_1 set c1 = c1 + 1, c2 = c2 + 1 where c1 = $41_idx and c2 = $41_idx;
  eval delete from test.table_1 where c1 = $41_idx + 1 and c2 = $41_idx + 1;
  inc $41_idx;
  inc $row_count;
}
--enable_query_log
--enable_result_log
let $last_job_id = deploy_get_value(ob1.select select max(job_id) as job_id from oceanbase.__all_rootservice_job where job_type = "ALTER_TENANT_LOCALITY" group by job_type, job_id, 1);
ob1.check_until_timeout select count(*) as c from oceanbase.__all_rootservice_job where job_id = "$last_job_id" and job_type = "ALTER_TENANT_LOCALITY" and job_status = "SUCCESS", 1, 600;
ob1.mysql ALTER TENANT tenant_41_02 set primary_zone = "z2;z4;z6";
ob1.check_until_timeout select count(*) as c from oceanbase.__all_virtual_meta_table where role = 1 and zone != "z2" and tenant_id = "$tenant_41_02_id", 0, 120;

ob1.mysql ALTER TENANT tenant_41_02 set locality = "F{1}@z2,F{1}@z4,F{1}@z6,F{1}@z1,R{1}@z3,R{1}@z5";
let $last_job_id = deploy_get_value(ob1.select select max(job_id) as job_id from oceanbase.__all_rootservice_job where job_type = "ALTER_TENANT_LOCALITY" group by job_type, job_id, 1);
ob1.check_until_timeout select count(*) as c from oceanbase.__all_rootservice_job where job_id = "$last_job_id" and job_type = "ALTER_TENANT_LOCALITY" and job_status = "SUCCESS", 1, 600;
ob1.mysql ALTER TENANT tenant_41_02 set primary_zone = "z2;z4;z6;z1";
ob1.check_until_timeout select count(*) as c from oceanbase.__all_virtual_meta_table where role = 1 and zone != "z2" and tenant_id = "$tenant_41_02_id", 0, 120;

ob1.mysql ALTER TENANT tenant_41_02 set locality = "F{1}@z2,F{1}@z4,F{1}@z6,F{1}@z1,F{1}@z3,R{1}@z5";
let $last_job_id = deploy_get_value(ob1.select select max(job_id) as job_id from oceanbase.__all_rootservice_job where job_type = "ALTER_TENANT_LOCALITY" group by job_type, job_id, 1);
ob1.check_until_timeout select count(*) as c from oceanbase.__all_rootservice_job where job_id = "$last_job_id" and job_type = "ALTER_TENANT_LOCALITY" and job_status = "SUCCESS", 1, 600;
