# owner: rongxuan.lc
# description: 本case是为了测试基本的locality变更过程；加入 farm中；

ob1=OBI(cluster=1:1:1:1:1,proxy_num=0,init_unit_cpu=0);
ob1.reboot;

source include/fast_auto_rebalance_configuration.inc;
ob1.mysql alter system set balance_blacklist_failure_threshold = 0;
# 创建租户
ob1.mysql create resource pool pool1 unit = 'sys_unit_config', unit_num = 1, zone_list = ('z1', 'z2', 'z3', 'z4', 'z5');
ob1.mysql create tenant tt resource_pool_list=('pool1'), primary_zone = 'z1', locality = 'F@z1,F@z2,F@z3, F@z4,F@z5' set ob_tcp_invited_nodes='%';
sleep 3;
let $proxy_ip = deploy_get_value(ob1.z1.obs0.ip);
let $proxy_port = deploy_get_value(ob1.z1.obs0.mysql_port);

connect(tt_conn, $proxy_ip, root@tt,,test, $proxy_port);
connect(sys_conn, $proxy_ip, root@sys,,test, $proxy_port);

connection tt_conn;
set ob_query_timeout = 30000000;
create table test(c1 int primary key, c2 int) partition by hash(c1) partitions 100;

let $tenant_id = deploy_get_value(ob1.select select tenant_id from __all_tenant where tenant_name = "tt", tenant_id, 1);

ob1.mysql alter tenant tt locality='F@z1,F@z2,F@z3';
ob1.check_until_timeout select count(*) c from oceanbase.__all_tenant where tenant_id = $tenant_id and previous_locality != '', 0, 100;
ob1.check_until_timeout select count(*) c from oceanbase.__all_rootservice_job where job_status="SUCCESS", 1, 30;

let $count = 2;
ob1.mysql alter tenant tt locality='F@z1,F@z2,F@z3,R@z4';
ob1.check_until_timeout select count(*) c from oceanbase.__all_tenant where tenant_id = $tenant_id and previous_locality != '', 0, 300;
ob1.check_until_timeout select count(*) c from oceanbase.__all_rootservice_job where job_status="SUCCESS", $count, 30;

inc $count;
ob1.mysql alter tenant tt locality='F@z1,F@z2,F@z3,F@z4';
ob1.check_until_timeout select count(*) c from oceanbase.__all_tenant where tenant_id = $tenant_id and previous_locality != '', 0, 300;
ob1.check_until_timeout select count(*) c from oceanbase.__all_rootservice_job where job_status="SUCCESS", $count, 30;

inc $count;
ob1.mysql alter tenant tt locality='F@z1,F@z2,F@z3';
ob1.check_until_timeout select count(*) c from oceanbase.__all_tenant where tenant_id = $tenant_id and previous_locality != '', 0, 300;
ob1.check_until_timeout select count(*) c from oceanbase.__all_rootservice_job where job_status="SUCCESS", $count, 30;

inc $count;
ob1.mysql alter tenant tt locality='F@z1,F@z2,F@z3,F@z4';
ob1.check_until_timeout select count(*) c from oceanbase.__all_tenant where tenant_id = $tenant_id and previous_locality != '', 0, 300;
ob1.check_until_timeout select count(*) c from oceanbase.__all_rootservice_job where job_status="SUCCESS", $count, 30;

inc $count;
ob1.mysql alter tenant tt locality='F@z1,F@z2,F@z3,L@z4';
ob1.check_until_timeout select count(*) c from oceanbase.__all_tenant where tenant_id = $tenant_id and previous_locality != '', 0, 300;
ob1.check_until_timeout select count(*) c from oceanbase.__all_rootservice_job where job_status="SUCCESS", $count, 30;

inc $count;
ob1.mysql alter tenant tt locality='F@z1,F@z2,F@z3';
ob1.check_until_timeout select count(*) c from oceanbase.__all_tenant where tenant_id = $tenant_id and previous_locality != '', 0, 300;
ob1.check_until_timeout select count(*) c from oceanbase.__all_rootservice_job where job_status="SUCCESS", $count, 30;

inc $count;
ob1.mysql alter tenant tt locality='F@z1,F@z2,F@z3,R@z4';
ob1.check_until_timeout select count(*) c from oceanbase.__all_tenant where tenant_id = $tenant_id and previous_locality != '', 0, 300;
ob1.check_until_timeout select count(*) c from oceanbase.__all_rootservice_job where job_status="SUCCESS", $count, 30;

inc $count;
ob1.mysql alter tenant tt locality='F@z1,F@z2,F@z3';
ob1.check_until_timeout select count(*) c from oceanbase.__all_tenant where tenant_id = $tenant_id and previous_locality != '', 0, 300;
ob1.check_until_timeout select count(*) c from oceanbase.__all_rootservice_job where job_status="SUCCESS", $count, 30;

inc $count;
ob1.mysql alter tenant tt locality='F@z1,F@z2,F@z3,F@z4';
ob1.check_until_timeout select count(*) c from oceanbase.__all_tenant where tenant_id = $tenant_id and previous_locality != '', 0, 300;
ob1.check_until_timeout select count(*) c from oceanbase.__all_rootservice_job where job_status="SUCCESS", $count, 30;

inc $count;
ob1.mysql alter tenant tt locality='F@z1,F@z2,F@z3,R@z4';
ob1.check_until_timeout select count(*) c from oceanbase.__all_tenant where tenant_id = $tenant_id and previous_locality != '', 0, 300;
ob1.check_until_timeout select count(*) c from oceanbase.__all_rootservice_job where job_status="SUCCESS", $count, 30;

