# owner: zhengshi 
# owner group: rs
# description: 创建足够多pool，验证报错信息是否变得明确
ob1=OBI(cluster=1:1:1, node_cpu_count=64, memory_size_limit=524288);
ob1.reboot;


let $proxy_ip = deploy_get_value(ob1.z1.obs0.ip);
let $proxy_port = deploy_get_value(ob1.z1.obs0.mysql_port);
connect(sys_conn, $proxy_ip, root@sys,,oceanbase, $proxy_port);
connection sys_conn;

CREATE RESOURCE UNIT small_unit MAX_CPU 25, MAX_MEMORY 1073741824, MAX_IOPS 100000, MAX_DISK_SIZE 536870912, MAX_SESSION_NUM 64, MIN_CPU=25, MIN_MEMORY=1073741824, MIN_IOPS=128;
CREATE RESOURCE pool pool1 unit_num=1, unit = 'small_unit', zone_list = ('z1', 'z2', 'z3');
CREATE RESOURCE pool pool2 unit_num=1, unit = 'small_unit', zone_list = ('z1', 'z2', 'z3');
--error 4624
CREATE RESOURCE pool pool3 unit_num=1, unit = 'small_unit', zone_list = ('z1', 'z2', 'z3');
