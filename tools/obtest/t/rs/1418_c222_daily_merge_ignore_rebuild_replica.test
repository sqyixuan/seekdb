# owner: rongxuan.lc
# description:
# 本case是为了验证每日合并检查的时候，会忽略rebuild的副本；但是索引不生效；不让rebuild影响合并；
# 索引的问题不好测，rebuild的状态不好进入。索引的状态不根据pt来定，是直接看__all_local_index_status;
# project/81079/issue/11896222  

ob1=OBI(cluster=2:2:2, init_unit_cpu=2, proxy_num=0, ct_num=0, locality=hz:hz:sh);
ob1.reboot;

ob1.mysql alter system set merger_check_interval = '10s';
ob1.mysql alter system set debug_sync_timeout = '1000s';

##发起每日合并，但是阻塞每日合并检查的线程；
ob1.mysql alter system major freeze;
##等待所有zone开始合并
ob1.check_until_timeout select count(*) c from oceanbase.__all_zone where name = 'merge_status' and info = 'MERGING', 4, 30;
ob1.mysql set ob_global_debug_sync = 'BEFORE_CHECK_ALL_PARTITION_MERGED wait_for begin';
ob1.mysql select 1 from oceanbase.__all_root_table;

##检查所有的副本版本都上升了。
ob1.check_until_timeout select count(*) c from oceanbase.__all_root_table where data_version = 1, 0, 360;
##修改副本的data_version = 1 and rebuild = 1
ob1.mysql update oceanbase.__all_root_table set data_version = 1,rebuild = 1 where table_id = 1099511627779 limit 1;
ob1.mysql update oceanbase.__all_root_table set data_version = 1,rebuild = 1 where table_id = 1099511627780 limit 1;
ob1.mysql update oceanbase.__all_root_table set data_version = 1,rebuild = 1 where table_id = 1099511627877 limit 1;
ob1.mysql set ob_global_debug_sync= 'now signal begin';

ob1.check_version 2;
ob1.mysql_p select count(*) from oceanbase.__all_root_table where data_version = 1 and rebuild  = 1;

