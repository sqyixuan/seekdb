--error 4179
alter tenant tenant_1 set locality = "F{1}@z1";
# 6 -> 2, 不支持
--error 4179
alter tenant tenant_1 set locality = "F{1}@z1, F{1}@z2";
# 6 -> 3, 3 < majority(6), 不支持
--error 4179
alter tenant tenant_1 set locality = "F{1}@z1, F{1}@z2, F{1}@z3";
