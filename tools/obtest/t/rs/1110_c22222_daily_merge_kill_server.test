# owner: rongxuan.lc
# owner group: SQL3
# description: 本case是为了测试每日合并过程中宕机的情况

#case 1：1台机器宕机
ob1=OBI(cluster=2:2:2:2:2,proxy_num=0,init_unit_cpu=5,locality=HZ:HZ:SH:SH:SZ);
ob1.reboot;
ob1.mysql alter system set merger_check_interval='10s';

ob1.mysql alter system major freeze;
ob1.check_version 2;
echo "case 2, permanent offline server";

ob1.mysql alter system set server_permanent_offline_time="20s";
ob1.mysql alter system major freeze;
#let $follower = deploy_get_value(ob1.get_follower sys:oceanbase:test);
#$follower.force_stop;
ob1.z5.obs0.force_stop;
let $max_cnt = 1;
let $cnt = 240;
while ($cnt > 0)
{
  let $zone_cnt = deploy_get_value(ob1.select select count(*) c from oceanbase.__all_zone where name ="last_merged_version" and value = 3, c, 1);
  if ($zone_cnt == 6)
  {
    let $cnt = 0;
    echo 'success';
  } 
  let $concurrency_cnt = deploy_get_value(ob1.select select count(*) c from oceanbase.__all_zone where name = "is_merging" and value = 1, c, 1);
  if ($concurrency_cnt >= $max_cnt) 
  {
    let $max_cnt = $concurrency_cnt;
  }
  sleep 1;
  dec $cnt;
}
#echo $max_cnt;
#$follower.nstart;
ob1.z5.obs0.nstart;
#case 2:
#
#Z1开始合并,is_merging； Z1宕机重启；z2开始合并is_merging;
#验证合并成功
sleep 10;
ob1.mysql alter system major freeze;
sleep 10;
#let $cnt = 20;
ob1.mysql update oceanbase.__all_zone set value = 1 where zone = 'z1' and name = 'is_merging';
ob1.mysql alter system reload zone;
ob1.z1.stop;
#while ($cnt > 0)
#{
#  let $start = deploy_get_value(ob1.select select count(*) c from oceanbase.__all_zone where zone = 'z1' and name = "is_merging" and value = 1, c, 1);
#  if ($start == 1)
#  {
#    echo "success";
#    ob1.z1.stop;
#    let $cnt = 0;
#  }
#  sleep 1;
#  dec $cnt;
#}
sleep 10;
ob1.z1.start;
sleep 30;
ob1.check_version 4;
