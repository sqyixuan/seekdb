let $tg_name = "tg4";
source include/check_tablegroup_schema.inc;

create tablegroup tg5 partition by range columns 2 (PARTITION c0 VALUES LESS THAN ('1990', 1990),PARTITION c1 VALUES LESS THAN ('2000', 2000),PARTITION c2 VALUES LESS THAN (MAXVALUE, MAXVALUE));
let $tg_name = "tg5";
source include/check_tablegroup_schema.inc;

# case 1.5: 非分区
create tablegroup tg6;
let $tg_name = "tg6";
source include/check_tablegroup_schema.inc;

