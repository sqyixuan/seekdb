# owner: yanmu.ztl
# owner group: rs
# description: 测试create tablegroup partition管理语法
ob1=OBI(cluster=1:1:1, init_unit_cpu=0, proxy_num=0, ct_num=0, locality=hz:hz:hz);
ob1.reboot;

ob1.mysql alter system set resource_hard_limit=900;
ob1.mysql alter system set resource_soft_limit=800;
ob1.mysql alter system set debug_sync_timeout = '1000s';
ob1.mysql alter system set enable_auto_leader_switch = 'false';
ob1.mysql alter system set enable_rebalance = 'false';
ob1.mysql alter system set enable_rereplication = 'false';
ob1.mysql alter system set balancer_idle_time = '10s';
ob1.mysql alter system set server_data_copy_out_concurrency = 20;
ob1.mysql alter system set server_data_copy_in_concurrency = 20;

let $rs = deploy_get_value(ob1.get_leader sys:oceanbase:__all_core_table:0);
let $rs_ip = deploy_get_value($rs.ip);
let $rs_port = deploy_get_value($rs.port);
let $rs_mysql_port = deploy_get_value($rs.mysql_port);
connect (conn_sys,$rs_ip,admin@sys,admin,oceanbase,$rs_mysql_port);

let $cpu = 1;
let $memory = 1073741824;
let $min_memory = 1073741824;
let $disk = 536870912;
let $iops = 100000;
let $session = 64;

ob1.mysql CREATE RESOURCE UNIT unit_1 MAX_CPU $cpu, MAX_MEMORY $memory, MAX_IOPS $iops, MAX_DISK_SIZE $disk, MAX_SESSION_NUM $session, MIN_CPU=1, MIN_MEMORY=$min_memory, MIN_IOPS=128;
ob1.mysql CREATE RESOURCE POOL pool_1 UNIT = 'unit_1', UNIT_NUM = 1, ZONE_LIST = ('z1','z2','z3');

ob1.mysql CREATE TENANT tenant_1 RESOURCE_POOL_LIST = ('pool_1'), primary_zone = 'z1;z2;z3', locality='F@z1,F@z2,F@z3' set ob_tcp_invited_nodes='%';
sleep 10;

connect (conn_tenant,$rs_ip,root@tenant_1,,test,$rs_mysql_port);

connection conn_tenant;

# case 1: 一级分区
# case 1.1: 一级hash
--error 1064
create tablegroup tg1 partition by hash(c1) partitions 2;
--error 1064
create tablegroup tg1 partition by hash 1 partitions 2;

create tablegroup tg1 partition by hash partitions 2;
let $tg_name = "tg1";
source include/check_tablegroup_schema.inc;

# case 1.2: 一级key
--error 1064
create tablegroup tg2 partition by key partitions 2;
--error 1064
create tablegroup tg2 partition by key(c1) parititions 2;

create tablegroup tg2 partition by key 2 partitions 2;
let $tg_name = "tg2";
source include/check_tablegroup_schema.inc;

# case 1.3: 一级range
--error 1064
create tablegroup tg3 partition by range (c1) (PARTITION c0 VALUES LESS THAN (1990),PARTITION c1 VALUES LESS THAN (2000),PARTITION c2 VALUES LESS THAN MAXVALUE);
--error 1064
create tablegroup tg3 partition by range 1 (PARTITION c0 VALUES LESS THAN (1990),PARTITION c1 VALUES LESS THAN (2000),PARTITION c2 VALUES LESS THAN MAXVALUE);
# 向量数不匹配，range只能为单表达式
--error 1653
create tablegroup tg3 partition by range (PARTITION c0 VALUES LESS THAN (1990,1990),PARTITION c1 VALUES LESS THAN (2000),PARTITION c2 VALUES LESS THAN MAXVALUE);
--error 1653
create tablegroup tg3 partition by range (PARTITION c0 VALUES LESS THAN (1990,1990),PARTITION c1 VALUES LESS THAN (2000,2000),PARTITION c2 VALUES LESS THAN (MAXVALUE,MAXVALUE));
# 列类型不匹配，只能为int
--error 1697
create tablegroup tg3 partition by range  (PARTITION c0 VALUES LESS THAN ('1990'),PARTITION c1 VALUES LESS THAN (2000),PARTITION c2 VALUES LESS THAN MAXVALUE);
--error 1697
create tablegroup tg3 partition by range  (PARTITION c0 VALUES LESS THAN ('1990'),PARTITION c1 VALUES LESS THAN ('2000'),PARTITION c2 VALUES LESS THAN MAXVALUE);
# 列名重复
--error 1517
create tablegroup tg3 partition by range (PARTITION c0 VALUES LESS THAN (1990),PARTITION c1 VALUES LESS THAN (2000),PARTITION c1 VALUES LESS THAN MAXVALUE);

create tablegroup tg3 partition by range (PARTITION c0 VALUES LESS THAN (1990),PARTITION c1 VALUES LESS THAN (2000),PARTITION c2 VALUES LESS THAN MAXVALUE);
let $tg_name = "tg3";
source include/check_tablegroup_schema.inc;

# case 1.4: 一级range column
--error 1064
create tablegroup tg4 partition by range columns (PARTITION c0 VALUES LESS THAN (1990),PARTITION c1 VALUES LESS THAN (2000),PARTITION c2 VALUES LESS THAN MAXVALUE);
