--error 1653
create tablegroup tg4 partition by range columns 1 (PARTITION c0 VALUES LESS THAN (1990,1990),PARTITION c1 VALUES LESS THAN (2000,2000),PARTITION c2 VALUES LESS THAN (MAXVALUE,MAXVALUE));
