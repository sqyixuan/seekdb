# case 3: list分区情况
# case 3.1: list
# 重复值
--error 1495
create tablegroup tg19 partition by list (partition p0 values in (1,2,3), partition p1 values in (2,9));
--error 1495
create tablegroup tg19 partition by list (partition p0 values in (1,2,3), partition p1 values in (9,9));
--error 1517
create tablegroup tg19 partition by list (partition p0 values in (2,1,10), partition p0 values in (7,9));

# 含default，default要加括号
--error 1064
create tablegroup tg19 partition by list (partition p0 values in (2,1,10), partition p1 values in (7,9), partition p2 values in default);
--error 1495
create tablegroup tg19 partition by list (partition p0 values in (2,1,10), partition p1 values in (7,9), partition p2 values in (default), partition p3 values in (default));

# list 只支持为int的情况
--error 1697
create tablegroup tg19 partition by list (partition p0 values in ('1'), partition p1 values in (7));
--error 1697
create tablegroup tg19 partition by list (partition p0 values in (2,'1',10), partition p1 values in (7,9));

create tablegroup tg19 partition by list (partition p0 values in (2,1,10), partition p1 values in (7,9));
create tablegroup tg20 partition by list (partition p0 values in (2,1,10), partition p1 values in (7,9), partition p2 values in (default));

# case 3.2: list columns
# 重复值
--error 1495
create tablegroup tg21 partition by list columns 2 (partition p0 values in ((10,1)), partition p1 values in ((10,1)));
--error 1495
create tablegroup tg21 partition by list columns 2 (partition p0 values in ((10,1), (10,1)), partition p1 values in ((3,9)));
--error 1495
create tablegroup tg21 partition by list columns 2 (partition p0 values in ((10,1), (3,9)), partition p1 values in ((3,9)));

# 含default的情况
--error 1064
create tablegroup tg21 partition by list columns 2 (partition p0 values in ((10,1), (3,8)), partition p1 values in ((3,9)), partition p2 values in default);
--error 1064
create tablegroup tg21 partition by list columns 2 (partition p0 values in ((10,1), (3,8)), partition p1 values in ((3,9)), partition p2 values in (default), partition p3 values in (default, default));
--error 1064
create tablegroup tg22 partition by list columns 2 (partition p0 values in ((10,1), (3,8)), partition p1 values in ((3,9)), partition p2 values in ((default)));
--error 1495
create tablegroup tg21 partition by list columns 2 (partition p0 values in ((10,1), (3,8)), partition p1 values in ((3,9)), partition p2 values in (default), partition p3 values in (default));

# 向量格式不对
--error 1653
create tablegroup tg21 partition by list columns 2 (partition p0 values in ((1,2,3)));
--error 1653
create tablegroup tg21 partition by list columns 2 (partition p0 values in ((1,2),3));
--error 1653
create tablegroup tg21 partition by list columns 2 (partition p0 values in ((1,2),(3)));
--error 1653
create tablegroup tg21 partition by list columns 2 (partition p0 values in ((10,1,7), (3,8)), partition p1 values in ((3,9)));

# 列向量类型不匹配
--error 1654
create tablegroup tg21 partition by list columns 2 (partition p0 values in (('10',1), (3,8)));
--error 1654
create tablegroup tg21 partition by list columns 2 (partition p0 values in (('10',1), ('3',8)), partition p1 values in ((2,7)));

create tablegroup tg21 partition by list columns 2 (partition p0 values in (('10',1), ('3',8), ('7',9)), partition p1 values in (('3',9)));
create tablegroup tg22 partition by list columns 2 (partition p0 values in (('10',1), ('3',8), ('7',9)), partition p1 values in (('2', 1), ('3',9)));

# case 3.3: 二级分区的情况
# 目前实现不支持range-range, list-list的情况
--error 4077
create tablegroup tg23 partition by list subpartition by list subpartition template (subpartition p0 values in (1,2,3), subpartition p1 values in (default)) (partition p0 values in (1,2,3), partition p1 values in (default));
--error 4077
create tablegroup tg23 partition by list subpartition by list columns 1 subpartition template (subpartition p0 values in (1,2,3), subpartition p1 values in (default)) (partition p0 values in (1,2,3), partition p1 values in (default));
--error 4077
create tablegroup tg23 partition by list columns 1 subpartition by list subpartition template (subpartition p0 values in (1,2,3), subpartition p1 values in (default)) (partition p0 values in (1,2,3), partition p1 values in (default));
