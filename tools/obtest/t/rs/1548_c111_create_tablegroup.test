--error 1653
create tablegroup tg4 partition by range columns 2 (PARTITION c0 VALUES LESS THAN (1990),PARTITION c1 VALUES LESS THAN (2000),PARTITION c2 VALUES LESS THAN MAXVALUE);
--error 1653
