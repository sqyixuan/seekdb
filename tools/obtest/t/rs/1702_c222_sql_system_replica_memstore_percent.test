#ob1.mysql alter system change replica partition_id = "0%0@$t2_id" server = "$change_addr" change replica_type = "F" memstore_percent = "0";
--error 1235,4007
eval alter system change replica partition_id = "0%0@$t2_id" server = "$change_addr2" change replica_type = "F" memstore_percent = 0 memstore_percent = 100;
