# owner: rongxuan.lc
# owner group: storage#

# When migrate leader replica, need switch leader to valid candidate first.
#
# Valid candidate: log_id > leader_log_id - 10000 (CLOG_SWITCH_LEADER_ALLOW_THRESHOLD)
#

ob1=OBI(cluster=2:2:2,proxy_num=0,init_unit_cpu=1);
ob1.reboot;
ob1.mysql alter system set enable_rebalance = 'False';
ob1.mysql alter system set enable_rereplication = 'False';
ob1.mysql alter system set enable_auto_leader_switch = 'False';
ob1.mysql alter system set resource_hard_limit = 800;

sleep 2;

let $sys_pool = deploy_get_value(ob1.select select name from __all_resource_pool where tenant_id = 1, name, 1);
ob1.mysql alter resource pool $sys_pool unit_num 2;
let $tenant_id =  deploy_get_value(ob1.select select tenant_id from __all_tenant where tenant_name ='obtest',tenant_id,1);
let $sys_pool = deploy_get_value(ob1.select select name from __all_resource_pool where tenant_id = $tenant_id, name, 1);
ob1.mysql alter resource pool $sys_pool unit_num 2;
sleep 2;

ob1.mysql alter system major freeze;
ob1.check_version 2;

let $ip = deploy_get_value(ob1.z1.obs0.ip);
let $port = deploy_get_value(ob1.z1.obs0.port);
let $mysql_port = deploy_get_value(ob1.z1.obs0.mysql_port);

let $ip1 = deploy_get_value(ob1.z1.obs1.ip);
let $port1 = deploy_get_value(ob1.z1.obs1.port);

let $z2_ip = deploy_get_value(ob1.z2.obs0.ip);
let $z2_port = deploy_get_value(ob1.z2.obs0.port);

connect(conn1,$ip,root@sys,,test,$mysql_port);
connection conn1;
connect(conn2,$ip,root@obtest,,test,$mysql_port);
connection conn2;

create table t1 (k int primary key, v int);
create table t2 (k int primary key, v int);
let $tenant_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name='obtest', tenant_id,1);
let $t1 = deploy_get_value(ob1.select select table_id v from __all_virtual_table where tenant_id = $tenant_id and table_name = 't1', v, 1);
let $t2 = deploy_get_value(ob1.select select table_id v from __all_virtual_table where tenant_id = $tenant_id and table_name = 't2', v, 1);

# observer in z1 not synced
ob1.z2.obs0.force_stop;
ob1.z2.obs1.force_stop;

sleep 15;

--disable_query_log
let $cnt = 11000;
while ($cnt > 0)
{
  eval insert into t1 (k, v) values ($cnt, 1);
  dec $cnt;
}
--enable_query_log

--disable_query_log
# now change leader doing async in election module, so here will return 0
#eval alter system switch replica leader partition_id = '0%1@$t1' server = '$z2_ip:$z2_port';
#sleep 30;

--enable_query_log

let $ip = deploy_get_value(ob1.select select svr_ip from oceanbase.__all_virtual_meta_table where tenant_id = $tenant_id and table_id = $t1 and zone = 'z1', svr_ip, 1);
let $port = deploy_get_value(ob1.select select svr_port from oceanbase.__all_virtual_meta_table where tenant_id = $tenant_id and table_id = $t1 and zone = 'z1', svr_port, 1);

let $ip1 = deploy_get_value(ob1.select select svr_ip from oceanbase.__all_server where (svr_ip != "$ip" or svr_port != $port) and zone = 'z1', svr_ip, 1);
let $port1 = deploy_get_value(ob1.select select svr_port from oceanbase.__all_server where (svr_ip != "$ip" or svr_port != $port) and zone = 'z1', svr_port, 1);
connection conn1;
--disable_query_log
eval alter system move replica partition_id = '0%1@$t1' source = '$ip:$port' DESTINATION = '$ip1:$port1';
--enable_query_log
ob1.check_no_rebalance_task;

# rebalance task stil execute failed, but switch leader to z3
eval select count(*) from oceanbase.__all_virtual_meta_table where tenant_id =$tenant_id and table_id = $t1 and role = 1 and zone = 'z3';

ob1.z2.obs0.start;
ob1.z2.obs1.start;
sleep 30;

# observer in z2 not synced
ob1.z3.obs0.force_stop;
ob1.z3.obs1.force_stop;

sleep 60;

let $ip = deploy_get_value(ob1.select select svr_ip from oceanbase.__all_virtual_meta_table where tenant_id = $tenant_id and table_id = $t2 and zone = 'z1', svr_ip, 1);
let $port = deploy_get_value(ob1.select select svr_port from oceanbase.__all_virtual_meta_table where tenant_id = $tenant_id and table_id = $t2 and zone = 'z1', svr_port, 1);

let $ip1 = deploy_get_value(ob1.select select svr_ip from oceanbase.__all_server where (svr_ip != "$ip" or svr_port != $port) and zone = 'z1', svr_ip, 1);
let $port1 = deploy_get_value(ob1.select select svr_port from oceanbase.__all_server where (svr_ip != "$ip" or svr_port != $port) and zone = 'z1', svr_port, 1);

--disable_query_log
eval alter system move replica partition_id = '0%1@$t2' source = '$ip:$port' DESTINATION = '$ip1:$port1';
--enable_query_log
ob1.check_no_rebalance_task;

# rebalance task stil execute failed, but switch leader to z2
eval select count(*) from oceanbase.__all_virtual_meta_table where tenant_id = $tenant_id and table_id = $t2 and role = 1 and zone = 'z2';
