# owner: yanmu.ztl
# owner group: rs
# description:
#
# schema拆分模式，drop tenant延迟生效：
# 1.禁非资源相关DDL 2.禁用户表读写

ob1=OBI(cluster=1:1:1, init_unit_cpu=0, proxy_num=0, ct_num=0, locality=hz:hz:hz);
ob1.z1.obs0.set extra_config=__schema_split_mode=true;
ob1.z2.obs0.set extra_config=__schema_split_mode=true;
ob1.z3.obs0.set extra_config=__schema_split_mode=true;
ob1.reboot;

ob1.mysql alter system set resource_hard_limit=900;
ob1.mysql alter system set resource_soft_limit=800;
ob1.mysql alter system set debug_sync_timeout = '1000s';
ob1.mysql alter system set enable_auto_leader_switch = 'false';
ob1.mysql alter system set enable_rebalance = 'true';
ob1.mysql alter system set enable_rereplication = 'true';
ob1.mysql alter system set balancer_idle_time = '10s';
ob1.mysql alter system set server_data_copy_out_concurrency = 20;
ob1.mysql alter system set server_data_copy_in_concurrency = 20;


let $cpu = 1;
let $memory = 1073741824;
let $min_memory = 1073741824;
let $disk = 536870912;
let $iops = 100000;
let $session = 64;

let $rs = deploy_get_value(ob1.get_leader sys:oceanbase:__all_core_table:0);
let $rs_ip = deploy_get_value($rs.ip);
let $rs_port = deploy_get_value($rs.port);
let $rs_mysql_port = deploy_get_value($rs.mysql_port);
connect (conn_sys,$rs_ip,admin@sys,admin,oceanbase,$rs_mysql_port);

ob1.mysql CREATE RESOURCE UNIT unit_1 MAX_CPU $cpu, MAX_MEMORY $memory, MAX_IOPS $iops, MAX_DISK_SIZE $disk, MAX_SESSION_NUM $session, MIN_CPU=1, MIN_MEMORY=$min_memory, MIN_IOPS=128;
ob1.mysql CREATE RESOURCE POOL pool_1 UNIT = 'unit_1', UNIT_NUM = 1, ZONE_LIST = ('z1','z2', 'z3');
ob1.mysql CREATE TENANT tenant_1 RESOURCE_POOL_LIST = ('pool_1'), primary_zone = 'z1;z2;z3', locality='F@z1,F@z2,F@z3' set ob_tcp_invited_nodes='%';
sleep 10;

let $obs_ip = deploy_get_value(ob1.z1.obs0.ip);
let $obs_port = deploy_get_value(ob1.z1.obs0.port);
let $mysql_port = deploy_get_value(ob1.z1.obs0.mysql_port);
connect (conn_tenant_z1,$obs_ip,root@tenant_1,,test,$mysql_port);

connection conn_tenant_z1;

# case 0: 正常情况
# 读写
use test;
create table tt1(c1 int primary key, c2 int) partition by hash(c1) partitions 2;
create table tt2(c1 int primary key, c2 int) partition by hash(c1) partitions 2;
insert into tt1(c1, c2) values(1,1),(2,2);
select * from tt1 order by c1 desc;

# locality变更
ob1.mysql alter tenant tenant_1 set locality = "F@z1,F@z2,R@z3";
ob1.check_until_timeout select count(*) from __all_tenant where previous_locality != "", 0, 360;

#minor
ob1.mysql alter system minor freeze tenant = sys;
ob1.mysql alter system minor freeze tenant = all_user;
ob1.mysql alter system minor freeze tenant = all_meta;
ob1.check_until_timeout select count(1) from __all_virtual_memstore_info where is_active=0, 0, 60;

#major
ob1.mysql alter system major freeze;
ob1.check_version 2;

# case 1: drop tenant延迟生效

ob1.mysql drop tenant tenant_1;
--error 5157
ob1.mysql_p drop tenant tenant_1;
# show warnings
ob1.mysql_p drop tenant if exists tenant_1;

# 可登录
let $obs_ip = deploy_get_value(ob1.z2.obs0.ip);
let $obs_port = deploy_get_value(ob1.z2.obs0.port);
let $mysql_port = deploy_get_value(ob1.z2.obs0.mysql_port);
connect (conn_tenant_z2,$obs_ip,root@tenant_1,,test,$mysql_port);
connection conn_tenant_z2;

# 禁非资源相关的DDL
use test;
--error 4179
create table tt3(c1 int primary key, c2 int) partition by hash(c1) partitions 2;
drop table tt2;

# 普通租户用户表不可读写
--error 4179
select * from tt1;
--error 4179
insert into tt1(c1,c2) values(3,3);

# 普通租户系统表可读写(仅通过change tenant可写)
# 普通租户登录，系统表仅可读
select count(*) from oceanbase.__all_tenant_meta_table;
--error 1044
update oceanbase.__all_tenant_meta_table set quorum = 2 where 1 = 1;
# 系统租户下change tenant，可读写
connection conn_sys;
alter system change tenant tenant_1;
select count(*) from oceanbase.__all_tenant_meta_table;
update oceanbase.__all_tenant_meta_table set quorum = 2 where 1 = 1;
select count(*) from oceanbase.__all_tenant_meta_table where quorum = 2;
update oceanbase.__all_tenant_meta_table set quorum = 3 where 1 = 1;
alter system change tenant sys;

# locality变更
ob1.mysql alter tenant tenant_1 set locality = "F@z1,F@z2,F@z3";
ob1.check_until_timeout select count(*) from __all_tenant where previous_locality != "", 0, 360;

#minor
ob1.mysql alter system minor freeze tenant = sys;
ob1.mysql alter system minor freeze tenant = all_user;
ob1.mysql alter system minor freeze tenant = all_meta;
ob1.check_until_timeout select count(1) from __all_virtual_memstore_info where is_active=0, 0, 60;

#major
ob1.mysql alter system major freeze;
ob1.check_version 3;

# case 2: drop tenant force立即生效
connection conn_sys;
# drop tenant force
drop tenant tenant_1 force;

# 登录失败
--error 5160
alter system change tenant tenant_1;

#minor
ob1.mysql alter system minor freeze tenant = sys;
ob1.mysql alter system minor freeze tenant = all_user;
ob1.mysql alter system minor freeze tenant = all_meta;
ob1.check_until_timeout select count(1) from __all_virtual_memstore_info where is_active=0, 0, 60;

#major
ob1.mysql alter system major freeze;
ob1.check_version 4;
