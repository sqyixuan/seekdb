# owner: zhengshi.jhc
# description: 解决alter resource unit以及alter resource pool报错信息不具体
#
# When unit balance need to migrate system unit (all unit is migrating), rebalance task may
# execute fail, because leader can not switch out since we need keep partition group leader
# in one server.
#
# BUG:
#   


ob1=OBI(cluster=1:1:1, node_cpu_count=20, memory_size_limit=524288);
#init_unit_cpu=0,
ob1.reboot;

ob1.mysql alter system set balancer_idle_time = '10s';
ob1.mysql alter system set resource_soft_limit = 100;
ob1.mysql alter system set resource_hard_limit = 100;
ob1.mysql alter system set enable_rereplication = false;
ob1.mysql alter system set enable_rebalance= false;
ob1.mysql alter system set server_data_copy_out_concurrency = 8;
ob1.mysql alter system set server_data_copy_in_concurrency = 8;
ob1.mysql alter tenant sys set primary_zone="z1";

let $proxy_ip = deploy_get_value(ob1.z1.obs0.ip);
let $proxy_port = deploy_get_value(ob1.z1.obs0.mysql_port);
connect(sys_conn, $proxy_ip, root@sys,,oceanbase, $proxy_port);

connection sys_conn;
#alter resource unit
--disable_query_log
--disable_result_log
create resource unit big max_cpu = 10, min_cpu = 10, max_memory 1073741824, min_memory = 1073741824, max_disk_size 536870912, max_iops = 128, max_session_num = 1000;
create resource pool big unit = 'big', unit_num = 1, zone_list = ('z1', 'z2', 'z3');
#ob1.mysql alter resource unit big max_cpu = 10, min_cpu = 10, max_memory = 1073741824, min_memory = 1073741824;
--error 4624
eval alter resource unit big max_cpu = 40, min_cpu = 40, max_memory = 1073741824, min_memory = 1073741824;


#alter resource pool
create resource unit b_unit max_cpu 15, max_memory 5368709120, max_iops 100000, max_disk_size 5368709120, max_session_num 64, MIN_CPU=15, MIN_MEMORY=5368709120, MIN_IOPS=128;
create resource unit s_unit max_cpu 1, max_memory 1073741824, max_iops 100000, max_disk_size 5368709120, max_session_num 64, MIN_CPU=1, MIN_MEMORY=1073741824, MIN_IOPS=128;


create resource pool tt_pool unit = "s_unit", unit_num = 1, zone_list = ('z1', 'z2', 'z3');
--error 4624
eval alter resource pool tt_pool unit = "b_unit";
--enable_query_log
--enable_result_log
