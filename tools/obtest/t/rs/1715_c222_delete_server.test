#owner: zhengshi.jhc
#owner group: rs
#delete server check unit resource

ob1=OBI(cluster=1:2:3,proxy_num=0,init_unit_num=1);

ob1.z2.obs1.set status=disable;
ob1.z3.obs1.set status=disable;
ob1.z3.obs2.set status=disable;
ob1.reboot;

ob1.z2.obs1.set status=enable;
ob1.z2.obs1.start;
sleep 10;
ob1.z2.obs1.add;

ob1.z3.obs1.set status=enable;
ob1.z3.obs1.start;
sleep 10;
ob1.z3.obs1.add;

ob1.z3.obs2.set status=enable;
ob1.z3.obs2.start;
sleep 10;
ob1.z3.obs2.add;

let $obs0_ip = deploy_get_value(ob1.z1.obs0.ip);
let $obs0_port = deploy_get_value(ob1.z1.obs0.port);
let $obs1_ip = deploy_get_value(ob1.z2.obs0.ip);
let $obs1_port = deploy_get_value(ob1.z2.obs0.port);
let $obs2_ip = deploy_get_value(ob1.z3.obs0.ip);
let $obs2_port = deploy_get_value(ob1.z3.obs0.port);


let $proxy_ip = deploy_get_value(ob1.z1.obs0.ip);
let $proxy_port = deploy_get_value(ob1.z1.obs0.mysql_port);

connect(sys_conn, $proxy_ip, root@sys,,test, $proxy_port);
connection sys_conn;
let $cpu = 1;
let $memory = 1073741824;
let $min_memory = 1073741824;
let $disk = 536870912;
let $iops = 100000;
let $session = 64;
let $case_index = 1;

ob1.mysql CREATE RESOURCE UNIT unit_1 MAX_CPU $cpu, MAX_MEMORY $memory, MAX_IOPS $iops, MAX_DISK_SIZE $disk, MAX_SESSION_NUM $session, MIN_CPU=1, MIN_MEMORY=$min_memory, MIN_IOPS=128;
ob1.mysql CREATE RESOURCE POOL pool_2 UNIT = 'unit_1', UNIT_NUM = 1, ZONE_LIST = ('z1', 'z2','z3');
ob1.mysql CREATE TENANT tenant_$case_index RESOURCE_POOL_LIST = ('pool_2'), locality='F@z1,F@z2,F@z3', primary_zone='z1;z2;z3' set ob_tcp_invited_nodes='%';
--error 4624
eval alter system delete server '$obs0_ip:$obs0_port';

sleep 10;
eval alter system delete server '$obs1_ip:$obs1_port';
ob1.check_until_timeout select count(*) from oceanbase.__all_rootservice_job where job_status = "INPROGRESS" , 0, 480;

eval alter system delete server '$obs2_ip:$obs2_port';

ob1.check_until_timeout select count(*) from oceanbase.__all_rootservice_job where job_status = "INPROGRESS" , 0, 480;


