# owner: rongxuan.lc
# description: 本case是为了测试disable_ddl的时候，容许部分修改primary zone的操作；

ob1=OBI(cluster=1,proxy_num=0,init_unit_cpu=0);
ob1.reboot;
ob1.mysql create resource pool pool1 unit = 'sys_unit_config', unit_num = 1, zone_list = ('z1');
ob1.mysql create tenant tt resource_pool_list=('pool1'), primary_zone = 'z1', locality = 'F@z1' set ob_tcp_invited_nodes='%';
ob1.mysql create resource pool pool2 unit = 'sys_unit_config', unit_num = 1, zone_list = ('z1');
sleep 3;

let $proxy_ip = deploy_get_value(ob1.z1.obs0.ip);
let $proxy_port = deploy_get_value(ob1.z1.obs0.mysql_port);

connect(sys_conn, $proxy_ip, root,,oceanbase,$proxy_port);
connect(conn1, $proxy_ip, root@tt,,test,$proxy_port);
connection conn1;
create table test(c1 int primary key, c2 int);
create tablegroup test;
connection sys_conn;
ob1.mysql alter system set enable_ddl = false;
connection conn1;
sleep 2;
--error 4179
create table test2(c1 int primary key, c2 int);
--error 4179
create tablegroup tt;
connection sys_conn;
--error 4179
create tenant ttt resource_pool_list=('pool2'), primary_zone = 'z1', locality = 'F@z1' set ob_tcp_invited_nodes='%';
connection conn1;
alter table test set primary_zone = 'z1';
alter tablegroup test set primary_zone = 'z1';
connection sys_conn;
alter tenant tt set primary_zone='z1';
--error 4179
alter tenant tt set locality='F@z1,R@z1';
--error 4179
alter tenant tt set locality='F@z1,R@z1', primary_zone = 'z1';
connection conn1;
--error 4179
alter table test add column c5 int;
--error 4179
alter tablegroup test set locality='F@z1,R@z1';
--error 4179
alter tablegroup test set locality='F@z1,R@z1', primary_zone='z1';





