# owner: rongxuan.lc
# description: 本case是为了测试stop zone的时候，记录majority的时候会考虑L；

ob1=OBI(cluster=2:2:2:2:2,  proxy_num=0, ct_num = 0);
ob1.reboot;
#ob1.mysql create table oceanbase.test(c1 int, c2 int);
ob1.mysql alter system set resource_hard_limit=900;
ob1.mysql alter system set resource_soft_limit=800;
ob1.mysql alter system set balancer_idle_time = '10s';
ob1.mysql alter system set server_data_copy_in_concurrency =50;
ob1.mysql alter system set server_data_copy_out_concurrency = 50;
ob1.mysql alter system set data_copy_concurrency = 200;

let $cpu = 1;
let $memory = 1073741824;
let $min_memory = 1073741824;
let $disk = 536870912;
let $iops = 100000;
let $session = 64;
let $case_index = 1;


ob1.mysql CREATE RESOURCE UNIT unit_$case_index MAX_CPU $cpu, MAX_MEMORY $memory, MAX_IOPS $iops, MAX_DISK_SIZE $disk, MAX_SESSION_NUM $session, MIN_CPU=1, MIN_MEMORY=$min_memory, MIN_IOPS=128;
ob1.mysql CREATE RESOURCE POOL pool_$case_index UNIT = 'unit_$case_index', UNIT_NUM = 2, ZONE_LIST = ('z1', 'z2','z3');
ob1.mysql CREATE TENANT tenant_$case_index RESOURCE_POOL_LIST = ('pool_$case_index'), locality='F@z1,F@z2,L@z3', primary_zone='z1;z2;z3' set ob_tcp_invited_nodes='%';

sleep 3;
ob1.create_client tenant=tenant_1,user=root,passwd=,database=test;
create table tt(c1 int primary key, c2 int) partition by hash(c1) partitions 50;
create table tt2(c1 int primary key, c2 int) partition by hash(c1) partitions 50;
sleep 5;
ob1.mysql alter system stop zone 'z2';
ob1.mysql alter system start zone 'z2';
ob1.mysql drop tenant tenant_1 force;
##majority 中必须要有一个F；
let $case_index = 2;
ob1.mysql CREATE RESOURCE UNIT unit_$case_index MAX_CPU $cpu, MAX_MEMORY $memory, MAX_IOPS $iops, MAX_DISK_SIZE $disk, MAX_SESSION_NUM $session, MIN_CPU=1, MIN_MEMORY=$min_memory, MIN_IOPS=128;
ob1.mysql CREATE RESOURCE POOL pool_$case_index UNIT = 'unit_$case_index', UNIT_NUM = 2, ZONE_LIST = ('z1', 'z2','z3','z4','z5');
ob1.mysql CREATE TENANT tenant_$case_index RESOURCE_POOL_LIST = ('pool_$case_index'), locality='F@z1,F@z2,L@z3,L@z4,L@z5', primary_zone='z1;z2;z3' set ob_tcp_invited_nodes='%';

sleep 3;
ob_connect(tt_conn, ob1.z1.obs0, root@sys, , test, , USE_MYSQL_CONNECTOR);
connection tt_conn;

#create table tt(c1 int primary key, c2 int) partition by hash(c1) partitions 50;
#create table tt2(c1 int primary key, c2 int) partition by hash(c1) partitions 50;

ob_connect(sys_conn, ob1.z1.obs0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);
connection sys_conn;

ob1.z2.obs0.force_stop;
sleep 20;
--error 4179
alter system stop zone 'z1';
alter system stop zone 'z3';

