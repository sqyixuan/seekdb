# owner: rongxuan.lc
# owner group: STORAGE
#
# Memory limit not checked in unit balance, assigned memory may exceed server memory limit.
#
# BUG:
#   

ob1=OBI(cluster=2:2:2,proxy_num=0,init_unit_cpu=0,node_cpu_count=24,memory_size_limit=81920);
ob1.reboot;

ob1.mysql alter system set balancer_idle_time = '10s';
ob1.mysql alter system set resource_soft_limit = 100;
ob1.mysql alter system set resource_hard_limit = 100;

sleep 2;
#
# available memory = memory_limit * (1 - system_memory_percentage) = 80G * 95% = 76G
#
ob1.mysql alter resource unit sys_unit_config max_cpu = 8, min_cpu = 8, max_memory = '25G', min_memory = '25G';
ob1.mysql create resource unit big_memory max_cpu=1,min_memory=1,max_memory='76G',min_memory='76G',max_disk_size='10G',max_iops=1000,max_session_num=1000;
ob1.mysql create resource pool bm unit = 'big_memory', unit_num = 1, zone_list = ('z1', 'z2', 'z3');
ob1.mysql create resource pool s0 unit = 'sys_unit_config',unit_num = 1, zone_list = ('z1', 'z2', 'z3');
ob1.mysql create resource pool s1 unit = 'sys_unit_config',unit_num = 1, zone_list = ('z1', 'z2', 'z3');

ob1.mysql_p select count(*) from oceanbase.__all_virtual_server_stat where mem_assigned_percent > 100;

ob1.mysql alter system set resource_soft_limit = 30;
sleep 25;
ob1.mysql_p select count(*) from oceanbase.__all_virtual_server_stat where mem_assigned_percent > 100;

ob1.mysql alter system set resource_hard_limit = 200;
sleep 25;
ob1.mysql_p select count(*) from oceanbase.__all_virtual_server_stat where mem_assigned_percent > 50;
