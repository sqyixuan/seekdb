# sleep 3;

# restart to make cpu_count, memory_limit take effect.
# ob1.z1.obs0.force_stop;
# ob1.z1.obs0.nstart;

# sleep 30;

ob1.mysql alter resource unit sys_unit_config max_cpu = 5, min_cpu = 5, max_memory = '1G', min_memory = '1G';
ob1.mysql create resource unit small max_cpu=3.4,min_memory=3.4,max_memory='1G',max_disk_size='1G',max_iops=1000,max_session_num=1000;

ob1.mysql create resource pool xx0  unit = 'small',unit_num = 1, zone_list = ('z1');
ob1.mysql create resource pool xx1  unit = 'small',unit_num = 1, zone_list = ('z1');
ob1.mysql create resource pool xx2  unit = 'small',unit_num = 1, zone_list = ('z1');
ob1.mysql create resource pool xx3  unit = 'small',unit_num = 1, zone_list = ('z1');
ob1.mysql create resource pool xx4  unit = 'small',unit_num = 1, zone_list = ('z1');

