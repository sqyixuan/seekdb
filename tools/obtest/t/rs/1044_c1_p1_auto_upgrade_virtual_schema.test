# owner: rongxuan.lc
# owner group: STORAGE
#
# alter system upgrade virtual schema

# case 1: auto create table exits in hard code schemas but not exist in memory
ob1=OBI(cluster=1,proxy_num=0,init_unit_cpu=1);
ob1.reboot;

ob1.mysql alter system set enable_sys_table_ddl = 'True';

sleep 2;

let $ip = deploy_get_value(ob1.z1.obs0.ip);
let $port = deploy_get_value(ob1.z1.obs0.mysql_port);

connect(conn1,$ip,root,,oceanbase,$port);
connection conn1;

select table_id from oceanbase.__all_virtual_table where tenant_id = 1 and table_name = '__all_virtual_memory_info';

desc oceanbase.__all_virtual_memory_info;
desc oceanbase.gv$session_event;

drop view oceanbase.gv$session_event;
delete from oceanbase.__all_column_history where tenant_id = 1 and table_id = 1099511638813 and rowkey_position = 0;
delete from oceanbase.__all_column where tenant_id = 1 and table_id = 1099511638813 and rowkey_position = 0;

ob1.z1.obs0.force_stop;
sleep 3;
ob1.z1.obs0.start;

sleep 120;

connect(conn2,$ip,root,,oceanbase,$port);
connection conn2;

desc oceanbase.__all_virtual_memory_info;
--error 1146
desc oceanbase.gv$session_event;

select * from oceanbase.__all_virtual_upgrade_inspection;

alter system upgrade virtual schema;

select * from oceanbase.__all_virtual_upgrade_inspection;

desc oceanbase.__all_virtual_memory_info;
desc oceanbase.gv$session_event;

# case 2: auto drop table not exist in hard code schemas but in memory
connect(conn3,$ip,root@obtest,,test,$port);
connection conn3;
create table __all_virtual_test_table (pk int, value int) table_id = 20000;
desc test.__all_virtual_test_table;
create table test_table (pk int, value int);
desc test.test_table;

connection conn2;
alter system upgrade virtual schema;

select * from oceanbase.__all_virtual_upgrade_inspection;
connection conn3;
--error 1146
desc test.__all_virtual_test_table;
desc test.test_table;
