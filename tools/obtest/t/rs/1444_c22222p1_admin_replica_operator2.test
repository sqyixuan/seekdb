# owner: rongxuan.lc
# description: 本case是为了测试alter system 对replica的操作
ob1=OBI(cluster=2:2:2:2:2,  proxy_num=0, ct_num = 0);
ob1.reboot;
#ob1.mysql create table oceanbase.test(c1 int, c2 int);
ob1.mysql alter system set resource_hard_limit=900;
ob1.mysql alter system set resource_soft_limit=800;
ob1.mysql alter system set enable_rebalance = 'false';
ob1.mysql alter system set enable_rereplication = 'false';
ob1.mysql alter system set balancer_idle_time = '10s';
ob1.mysql alter system set server_data_copy_in_concurrency =30;
ob1.mysql alter system set server_data_copy_out_concurrency = 30;
ob1.mysql alter system set data_copy_concurrency = 100;

let $cpu = 1;
let $memory = 1073741824;
let $min_memory = 1073741824;
let $disk = 536870912;
let $iops = 100000;
let $session = 64;
let $case_index = 1;


ob1.mysql CREATE RESOURCE UNIT unit_$case_index MAX_CPU $cpu, MAX_MEMORY $memory, MAX_IOPS $iops, MAX_DISK_SIZE $disk, MAX_SESSION_NUM $session, MIN_CPU=1, MIN_MEMORY=$min_memory, MIN_IOPS=128;
ob1.mysql CREATE RESOURCE POOL pool_$case_index UNIT = 'unit_$case_index', UNIT_NUM = 2, ZONE_LIST = ('z1', 'z2','z3', 'z4','z5');
ob1.mysql CREATE TENANT tenant_$case_index RESOURCE_POOL_LIST = ('pool_$case_index'), locality='F@z1,F@z2,R@z2,F@z3,R@z3,F@z4,R@z5', primary_zone='z1;z2;z3' set ob_tcp_invited_nodes='%';

sleep 3;
ob1.create_client tenant=tenant_1,user=root,passwd=,database=test;
create table tt(c1 int primary key, c2 int) partition by hash(c1) partitions 50;
create table tt2(c1 int primary key, c2 int) partition by hash(c1) partitions 50;

let $tenant_id = deploy_get_value(ob1.select select tenant_id from __all_tenant where tenant_name = 'tenant_1', tenant_id, 1);
let $table_id = deploy_get_value(ob1.select select table_id from __all_virtual_table where tenant_id = $tenant_id and table_name = 'tt', table_id, 1);
let $svr_ip = deploy_get_value(ob1.z1.obs0.ip);
let $svr_port = deploy_get_value(ob1.z1.obs0.mysql_port);

connect(sys_conn, $svr_ip, root@sys,,oceanbase, $svr_port);
connection sys_conn;

##类型转换F->R;
eval delete from oceanbase.__all_root_table where zone = 'z4' and replica_type = 0;
ob1.mysql alter tenant tenant_1 set locality='F@z1,F@z2,R@z2,F@z3,R@z3,R@z4,R@z5';
###等待变更做完  ===>only in member list的副本不会进行类型转换；
ob1.check_until_timeout select count(*) c from __all_root_table where zone = 'z4' and replica_type = 0, 0, 240;
ob1.mysql alter system report replica;
ob1.check_until_timeout select count(*)  c from __all_rootservice_job where job_status != 'success', 0, 240;
--disable_query_log
###不支持L->F； 改成F->L
##类型转换F->L；
let $partition_id = 0;
let $src = deploy_get_value(ob1.select select concat(svr_ip,":",svr_port) addr from __all_virtual_meta_table where table_id = $table_id and partition_id = $partition_id and zone='z2' and replica_type = 0, addr, 1);
eval alter system change replica partition_id='$partition_id%50@$table_id' server =  '$src' change replica_type = 'L'; 
##等待切换完成；
ob1.check_until_timeout select count(*) from __all_virtual_meta_table where table_id = $table_id and partition_id = $partition_id and zone='z2' and replica_type = 5, 1, 30;

alter system change tenant tenant_1;
##类型异常转换F->L；
let $partition_id = 1;
let $src = deploy_get_value(ob1.select select concat(svr_ip,":",svr_port) addr from __all_virtual_meta_table where table_id = $table_id and partition_id = $partition_id and zone='z2' and replica_type = 0, addr, 1);
eval delete from oceanbase.__all_tenant_meta_table where zone = 'z2' and replica_type = 5 and table_id = $table_id and partition_id = $partition_id;
ob1.mysql_p alter system change replica partition_id='$partition_id%50@$table_id' server =  '$src' change replica_type = 'L'; 
##等待切换完成；
ob1.check_until_timeout select count(*) from __all_virtual_meta_table where table_id = $table_id and partition_id = $partition_id and zone='z2' and replica_type = 5, 1, 30;
ob1.mysql_p alter system drop replica partition_id='$partition_id%50@$table_id' server =  '$src';
###类型转换R->F;
let $partition_id = 2;
let $src = deploy_get_value(ob1.select select concat(svr_ip,":",svr_port) addr from __all_virtual_meta_table where table_id = $table_id and partition_id = $partition_id and zone='z5' and replica_type = 16, addr, 1);
let $stop_server = deploy_get_value(ob1.select select concat(svr_ip,":",svr_port) addr from __all_virtual_meta_table where table_id = $table_id and partition_id = $partition_id and zone='z3' and replica_type =0, addr, 1);
ob1.mysql alter system set server_permanent_offline_time = '20s'; 
let $obi = deploy_get_value(ob1.get_obs_by_addr $stop_server);
$obi.force_stop;
sleep 30;
#ob1.mysql delete from oceanbase.__all_virtual_meta_table where zone = 'z5' and replica_type = 16 and table_id = $table_id and partition_id = $partition_id;
ob1.mysql_p alter system change replica partition_id='$partition_id%50@$table_id' server =  '$src' change replica_type = 'F';
ob1.check_until_timeout select count(*) from __all_virtual_meta_table where table_id = $table_id and partition_id = $partition_id and zone='z5' and replica_type = 0, 1, 30;
$obi.start;

sleep 4;
##异常类型转换R->F；删掉PT源端；
let $partition_id = 3;
let $src = deploy_get_value(ob1.select select concat(svr_ip,":",svr_port) addr from __all_virtual_meta_table where table_id = $table_id and partition_id = $partition_id and zone='z5' and replica_type = 16, addr, 1);
let $stop_server = deploy_get_value(ob1.select select concat(svr_ip,":",svr_port) addr from __all_virtual_meta_table where table_id = $table_id and partition_id = $partition_id and zone='z3' and replica_type =0, addr, 1);
ob1.mysql alter system set server_permanent_offline_time = '20s'; 
let $obi = deploy_get_value(ob1.get_obs_by_addr $stop_server);
$obi.force_stop;
sleep 25;
eval delete from oceanbase.__all_tenant_meta_table where zone = 'z5' and replica_type = 16 and table_id = $table_id and partition_id = $partition_id;
--error 4018
ob1.mysql_p alter system change replica partition_id='$partition_id%50@$table_id' server =  '$src' change replica_type = 'F';
ob1.mysql_p alter system change replica partition_id='$partition_id%50@$table_id' server =  '$src' change replica_type = 'F' force;
ob1.check_until_timeout select count(*) from __all_virtual_meta_table where table_id = $table_id and partition_id = $partition_id and zone='z5' and replica_type = 0, 1, 30;
$obi.start;

