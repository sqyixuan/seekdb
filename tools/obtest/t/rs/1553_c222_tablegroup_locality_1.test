alter tablegroup tg3 set locality = "F@z1, F@z2";
ob1.mysql alter system set enable_rereplication = 'true';
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_tablegroup where previous_locality != "" and tablegroup_name = "tg3", 0, 120;
ob1.mysql alter system set enable_rereplication = 'false';

alter table transfer_5 tablegroup = "tg3";
alter table transfer_8 tablegroup = "tg4";

# table处于locality变更过程中，禁止变更tablegroup
# (目前tablegroup中的table都为继承属性，且不允许变更tablegroup中table的locality，故只有不在tablegroup中的table会处于locality变更)
create tablegroup tg5 locality = "F@z1, F@z2, R@z2";
create table transfer_10 (c1 int, c2 int);

alter table transfer_10 locality = "F@z1, F@z2, R@z2";

--error 4179
alter tablegroup tg3 add transfer_10;
--error 4179
alter tablegroup tg5 add transfer_10;
--error 4179
alter table transfer_10 tablegroup = "tg3";
--error 4179
alter table transfer_10 tablegroup = "tg5";

## FIXME: 现在补副本的逻辑有问题, locality不会成功, 通过回滚操作使后续测试能进行下去
alter table transfer_10 set locality = "F@z1, F@z2";
ob1.mysql alter system set enable_rereplication = 'true';
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table where previous_locality != "" and table_name = "transfer_10", 0, 120;
ob1.mysql alter system set enable_rereplication = 'false';

alter tablegroup tg3 add transfer_10;
