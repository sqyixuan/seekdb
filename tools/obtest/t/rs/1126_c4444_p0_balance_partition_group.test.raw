##############################
#功能点：
# partition分配, partition_group的partition分布在同一个机器内。
# 不同的partition_group被打散到不同机器上
#
#用例场景：
#1、租户内多个unit，不同的tablegroup的partition
#2、相同partitiongroup的p落在相同单元上
###############################
#tags: partition_group, balance


##########
# rs 模块启动前，重启observer
#########
ob1=OBI(cluster=4:4:4:4,init_unit_cpu=5);
ob1.reboot;


ob1.mysql create resource pool rp1 unit = 'sys_unit_config', unit_num = 3, zone_list = ('z1', 'z2', 'z3', 'z4'), locality="F@z1,F@z2,F@z3,L@Z4,R@z4";
ob1.mysql create tenant tt1 replica_num 4, primary_zone 'z2', resource_pool_list ('rp1');

ob1.create_client tenant=tt1, user=root, database=test;

let $tenant_id = deploy_get_value(ob1.select select tenant_id from __all_tenant where tenant_name='tt1',tenant_id,1);

#####
#case 0：同一个table group的不同partition group 位于不同的机器上面
#####
create table test(c1 int primary key, c2 int) partition by hash(c1) partitions 15;
let $znum = deploy_get_value(ob1.z_num);
echo "同一个table group的不同partition group 位于不同的机器上面";
while ($znum > 0) 
{
  echo "zone index $znum";
  ob1.mysql_p use oceanbase; select count(*) from (select distinct(svr_ip) from __all_virtual_meta_table where tenant_id=$tenant_id and zone='z$znum') v;
  dec $znum;
}

#########
#case 1: 相同tablegroup的不同partition，分布在同一台机器上
###########
# init table:obtest1..obtest10;init tablegroup:tg
let $tablenum = 10;
let $difftablegroup = 0;
source sql/init_table.sql;

echo "相同tablegroup的不同partition，分布在同一台机器上";
let $znum = deploy_get_value(ob1.z_num);
while($znum > 0)
{
  echo "zone index $znum";
  ob1.mysql_p use oceanbase;select count(*) from (select distinct(svr_ip) from __all_virtual_meta_table where tenant_id=$tenant_id and zone='z$znum') v;
  dec $znum;
}

