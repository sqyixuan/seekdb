##############################
# owner: rongxuan.lc
# owner group: proxy
#功能点：
# 错峰合并，合并过程中delete/stop zone，不被允许
#
#用例场景：
#1、发起合并，stop正在合并过程中的zone
#2、发起合并，stop不在合并过程中的zone
#
###############################

ob1=OBI(cluster=3:3:3,init_unit_cpu=0);
ob1.reboot;
sleep 10;
# 并发合并zone的数量，设置成错峰合并

ob1.create_client;
ob1.prepare;
ob1.start_check;

# 创建3个table:obtest1,obtest2,obtest3
let $tablenum = 3;
source sql/init_table.sql;

###########
#case1: 发起合并，stop正在合并的zone
############
ob1.z1.obs0.switch_partition sys:oceanbase:__all_core_table;

ob1.mysql alter system suspend merge zone='z2';

ob1.mysql alter system major freeze;

--error 1227
alter system stop zone 'z2';

ob1.mysql alter system resume merge zone='z2';

ob1.check_version 2;

#########
#case2: 发起合并，stop不在合并中的zone
############
ob1.mysql alter system major freeze;
--error 1227
alter system stop zone 'z1';

--error 1227
alter system stop zone 'z3';

ob1.check_version 3;
