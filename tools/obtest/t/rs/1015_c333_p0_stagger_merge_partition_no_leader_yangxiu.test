##############################
# owner: rongxuan.lc
# owner group: proxy
#功能点：
# 错峰合并,部分partition处于无主状态
#
#用例场景：
#1、合并发起前，部分parition处于无主
#2、合并发起后，部分parition处于无主
#3、
#
###############################

ob1=OBI(cluster=3:3:3,init_unit_cpu=2,init_unit_num=2);
ob1.reboot;

ob1.mysql alter system set merger_check_interval='1m';
ob1.mysql alter system set merger_switch_leader_duration_time='0s';
sleep 2;

ob1.create_client tenant=obtest,user=admin,passwd=admin,database=test;
### tablename :obtest1,obtest2
let $tablenum=2;
source sql/init_table.sql;


###########
#case1: 合并发起前，部分partition处于无主
############
let $f1=deploy_get_value(ob1.get_follower obtest:test:obtest1,1);
let $f2=deploy_get_value(ob1.get_follower obtest:test:obtest1,2);

ob1.mysql_p alter system major freeze;

$f1.stop;
$f2.stop;

sleep 10;

$f1.nstart;
$f2.nstart;

ob1.check_version 2;

# wait for select leader
sleep 15;

select * from obtest1 partition(p0) limit 2;

#########
#case2: 合并发起后，部分partition处于无主
############
let $f1=deploy_get_value(ob1.get_follower obtest:test:obtest2,1);
let $f2=deploy_get_value(ob1.get_follower obtest:test:obtest2,2);

ob1.mysql alter system major freeze;

$f1.stop;
$f2.stop;
sleep 20;

$f1.nstart;
$f2.nstart;

sleep 10;

ob1.check_version 3;

