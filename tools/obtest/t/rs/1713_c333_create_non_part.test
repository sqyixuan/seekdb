let $unit_id = deploy_get_value(ob1.select select unit_id from oceanbase.__all_unit where svr_ip = "$obs5_ip" and svr_port = '$obs5_port' and resource_pool_id = $resource_pool_id, unit_id, 1);
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_meta_table where unit_id = $unit_id, 3, 10;
