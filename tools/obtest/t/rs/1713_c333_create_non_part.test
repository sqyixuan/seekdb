# owner: zhengshi.jhc
# oweer group: rs
# 功能：创建单分区表副本平铺检测
#case 1:
#系统租户:指定primary_zone:z1;z2,z3 单unit 正常模式
#case 2:
#普通租户:primary_zone:random/empty 多unit 正常模式: F,F,F
#case 3:
#普通租户:primary_zone:random/empty 多unit 正常模式: F,F,L
#case 4:
#普通租户:primary_zone:random/empty 多unit 混部: F{2},L
#case 5:
#普通租户:primary_zone:random/empty 多unit 正常模式: F,R{all_server}, F,R{all_server}, F,R{all_server}
# 设置集群规模
ob1=OBI(cluster=3:3:3, proxy_num = 0, init_unit_cpu = 0);
ob1.reboot;
ob1.mysql alter system set enable_auto_leader_switch = false;
#ob1.mysql alter system set enable_rebalance = false;
#自动配置参数并创建UNIT参数规格
#source include/fast_auto_rebalance_configuration.inc;
let $cpu = 1;
let $memory = 1073741824;
let $min_memory = 1073741824;
let $disk = 536870912;
let $iops = 100000;
let $session = 64;
ob1.mysql CREATE RESOURCE UNIT unit_1 MAX_CPU $cpu, MAX_MEMORY $memory, MAX_IOPS $iops, MAX_DISK_SIZE $disk, MAX_SESSION_NUM $session, MIN_CPU=1, MIN_MEMORY=$min_memory, MIN_IOPS=128;
#获得ip、port用于连接
let $proxy_ip = deploy_get_value(ob1.z1.obs0.ip);
let $proxy_port = deploy_get_value(ob1.z1.obs0.mysql_port);
let $obs0_ip = deploy_get_value(ob1.z1.obs0.ip);
let $obs0_port = deploy_get_value(ob1.z1.obs0.port);
let $obs1_ip = deploy_get_value(ob1.z1.obs1.ip);
let $obs1_port = deploy_get_value(ob1.z1.obs1.port);
let $obs2_ip = deploy_get_value(ob1.z1.obs2.ip);
let $obs2_port = deploy_get_value(ob1.z1.obs2.port);
let $obs3_ip = deploy_get_value(ob1.z2.obs0.ip);
let $obs3_port = deploy_get_value(ob1.z2.obs0.port);
let $obs4_ip = deploy_get_value(ob1.z2.obs1.ip);
let $obs4_port = deploy_get_value(ob1.z2.obs1.port);
let $obs5_ip = deploy_get_value(ob1.z2.obs2.ip);
let $obs5_port = deploy_get_value(ob1.z2.obs2.port);
let $obs6_ip = deploy_get_value(ob1.z3.obs0.ip);
let $obs6_port = deploy_get_value(ob1.z3.obs0.port);
let $obs7_ip = deploy_get_value(ob1.z3.obs1.ip);
let $obs7_port = deploy_get_value(ob1.z3.obs1.port);
let $obs8_ip = deploy_get_value(ob1.z3.obs2.ip);
let $obs8_port = deploy_get_value(ob1.z3.obs2.port);
connect(sys_conn, $proxy_ip, root@sys,,test, $proxy_port);
connection sys_conn;
let $count = 0;
while($count < 9)
{
  eval CREATE TABLE t1_$count (pk int primary key);
  inc $count;
}
let $tenant_id = deploy_get_value(ob1.select select tenant_id from __all_tenant where tenant_name = 'sys', tenant_id, 1);
let $resource_pool_id = deploy_get_value(ob1.select select resource_pool_id from __all_resource_pool where tenant_id = $tenant_id, resource_pool_id, 1);
let $unit_id1 = deploy_get_value(ob1.select select unit_id from oceanbase.__all_unit where resource_pool_id = $resource_pool_id and zone = 'z1', unit_id, 1);
let $unit_id2 = deploy_get_value(ob1.select select unit_id from oceanbase.__all_unit where resource_pool_id = $resource_pool_id and zone = 'z2', unit_id, 1);
let $unit_id3 = deploy_get_value(ob1.select select unit_id from oceanbase.__all_unit where resource_pool_id = $resource_pool_id and zone = 'z3', unit_id, 1);
#每个unit上有9个副本，leader都在z1上
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_meta_table where unit_id = $unit_id1, 9, 10;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_meta_table where unit_id = $unit_id2, 9, 10;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_meta_table where unit_id = $unit_id3, 9, 10;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_meta_table where role = 1 and unit_id = $unit_id1, 9, 10;
#创建分区表是否有影响
let $count = 0;
while($count < 9)
{
  eval CREATE TABLE t11_$count (pk int primary key) partition by hash(pk) partitions 10;
  inc $count;
}
#case 2 3unit primary_zone = '' F,F,F
connection sys_conn;
ob1.mysql CREATE RESOURCE POOL pool1 UNIT = 'unit_1', unit_num = 3, zone_list = ('z1', 'z2', 'z3');
ob1.mysql CREATE TENANT t1 resource_pool_list = ('pool1'), locality = "F@z1,F@z2,F@z3" set ob_tcp_invited_nodes = '%';
connect(t1_conn, $proxy_ip, root@t1,,test, $proxy_port);
let $tenant_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name = 't1', tenant_id, 1);
let $resource_pool_id = deploy_get_value(ob1.select select resource_pool_id from __all_resource_pool where tenant_id = $tenant_id, resource_pool_id, 1);
#let $unit_id = deploy_get_value(ob1.select select min(unit_id) from oceanbase.__all_unit where resource_pool_id = $resource_pool_id, unit_id, 1);
connection t1_conn;
let $count = 0;
while($count < 9)
{
  eval create table t_$count (value int);
  inc $count;
}
#检查该tenant下所有unit的副本数和leader数,建9张表,每个unit上3个副本，1个leader
#let $unit_id = deploy_get_value(ob1.select select unit_id from oceanbase.__all_unit where svr_ip = "$obs0_ip" and svr_port = '$obs0_port' and resource_pool_id = $resource_pool_id, unit_id, 1);
#let $unit_count = deploy_get_value(ob1.select select count(*) from oceanbase.__all_virtual_meta_table where unit_id = $unit_id, count(*), 1);
#eval echo $unit_count;
#let $leader_count = deploy_get_value(ob1.select select count(*) from oceanbase.__all_virtual_meta_table where role = 1 and unit_id = $unit_id, count(*), 1);
#eval echo $leader_count;
