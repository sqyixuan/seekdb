CREATE RESOURCE POOL pool3 UNIT = 'unit_1', unit_num = 3, zone_list = ('z1', 'z2', 'z3');
--error 1210
CREATE TENANT t3 primary_zone = 'RANDOM', resource_pool_list = ('pool3'), locality = "F{2},L@[z1,z2,z3]" set ob_tcp_invited_nodes = '%';
CREATE TENANT t3 primary_zone = 'RANDOM', resource_pool_list = ('pool3'), locality = "F@z1,F@z2,F@z3" set ob_tcp_invited_nodes = '%';
let $tenant3 = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name = 't3', tenant_id, 1);
connect(t3_conn, $proxy_ip, root@t3,,test, $proxy_port);
connection t3_conn;
