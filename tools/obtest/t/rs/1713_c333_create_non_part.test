connection sys_conn;
ob1.mysql CREATE RESOURCE POOL pool4 UNIT = 'unit_1', unit_num = 3, zone_list = ('z1', 'z2', 'z3');
ob1.mysql CREATE TENANT t4 primary_zone = 'RANDOM', resource_pool_list = ('pool4'), locality = "F,R{all_server}@z1, F,R{all_server}@z2, F,R{all_server}@z3" set ob_tcp_invited_nodes = '%';
