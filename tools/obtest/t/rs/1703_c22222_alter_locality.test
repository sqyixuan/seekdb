ALTER TENANT tt locality = "F@z1,L@z2,F@z3,F@z4,R@z5";
ob1.check_until_timeout select count(*) c from oceanbase.__all_tenant where tenant_id = $tenant_id and previous_locality != '', 0, 100;
ob1.check_until_timeout select count(*) c from oceanbase.__all_rootservice_job where job_status = "SUCCESS", 12, 300;

#创建tablegroup，对tablegroup的locality变更
connection tt1_conn;
CREATE TABLEGROUP tg ;
let $tg_id = deploy_get_value(ob1.select select tablegroup_id from oceanbase.__all_virtual_tablegroup where tablegroup_name = "tg", tablegroup_id, 1);
CREATE TABLE t1(c1 int, c2 int) TABLEGROUP = "tg";
CREATE TABLE t2(c1 int, c2 int) TABLEGROUP = "tg";
CREATE TABLE t3(c1 int, c2 int);
let $t1_id = deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where table_name = "t1",table_id, 1);
let $t2_id = deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where table_name = "t2",table_id, 1);
let $t3_id = deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where table_name = "t3",table_id, 1);

ob1.mysql ALTER TENANT tt locality = "F@z1,L@z2,F@z3,F,R{1}@z4";
ob1.check_until_timeout select count(*) from oceanbase.__all_tenant where tenant_id = $tenant_id and previous_locality != '', 0, 360;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_partition_table where table_id = $t1_id and partition_id = 0, 5,5;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_partition_table where table_id = $t2_id and partition_id = 0, 5,5;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_partition_table where table_id = $t3_id and partition_id = 0, 5,5;
ob1.check_until_timeout select count(*) c from oceanbase.__all_rootservice_job where job_status = "SUCCESS", 13, 300;

ob1.mysql ALTER TENANT tt locality = "F@z1,L@z2,F@z3,F,R{1}@z4,F,R{ALL_SERVER}@z5";
ob1.check_until_timeout select count(*) from oceanbase.__all_tenant where tenant_id = $tenant_id and previous_locality != '', 0, 360;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_partition_table where table_id = $t1_id and partition_id = 0, 7,5;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_partition_table where table_id = $t2_id and partition_id = 0, 7,5;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_partition_table where table_id = $t3_id and partition_id = 0, 7,5;
ob1.check_until_timeout select count(*) c from oceanbase.__all_rootservice_job where job_status = "SUCCESS", 14, 300;

#创建非继承tenant的locality的tablegroup以及table
CREATE TABLEGROUP tg1 locality = "F@z1,L@z2,F@z3,F,R{1}@z4,F@z5";
let $tg1_id = deploy_get_value(ob1.select select tablegroup_id from oceanbase.__all_virtual_tablegroup where tablegroup_name = "tg1", tablegroup_id, 1);
CREATE TABLE t4(c1 int, c2 int);
CREATE TABLE t5(c1 int, c2 int) TABLEGROUP = "tg1";
CREATE TABLE t6(c1 int, c2 int) locality = "F@z1,L@z2,F@z3,F@z4,F@z5";

let $t4_id = deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where table_name = "t4", table_id, 1);
let $t5_id = deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where table_name = "t5", table_id, 1);
let $t6_id = deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where table_name = "t6", table_id, 1);

ob1.mysql ALTER TENANT tt locality = "F@z1,L@z2,L@z3,F,R{1}@z4,F,R{ALL_SERVER}@z5";

ob1.check_until_timeout select count(*) from oceanbase.__all_tenant where tenant_id = $tenant_id and previous_locality != '', 0,360;
ob1.check_until_timeout select count(*) from oceanbase.__all_rootservice_job where job_status = "SUCCESS", 15, 300;
ALTER TABLEGROUP tg1 locality = "F@z1,L@z2,L@z3,F,R{1}@z4,F@z5";
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_tablegroup where tablegroup_id = $tg1_id and previous_locality != '', 0,360;
ob1.check_until_timeout select count(*) from oceanbase.__all_rootservice_job where job_status = "SUCCESS", 16, 300;
ALTER TABLE t6 locality = "F@z1,L@z2,L@z3,F@z4,F@z5";
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table where table_id = $t6_id and previous_locality != '', 0,360;
ob1.check_until_timeout select count(*) from oceanbase.__all_rootservice_job where job_status = "SUCCESS", 17, 300;
