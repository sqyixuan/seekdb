# owner: rongxuan.lc
# description: 本case是为了测试unit迁移过程中，遇到目的端block的场景；
# 1. 源端可以迁回； t/rs/1038_c222_p1_end_migrate_when_server_block.test
# 2. 源端不能迁回；

ob1=OBI(cluster=3:3:3,proxy_num=0,init_unit_cpu=0);
ob1.reboot;
ob1.mysql alter system set balancer_idle_time='10s' ;
ob1.mysql alter system set server_permanent_offline_time ='1800s';

##新建表；
#ob1.mysql create table oceanbase.test(c1 int primary key, c2 int) primary_zone z1 partition by hash(c1) partitions 30;
#ob1.mysql create table oceanbase.test2(c1 int primary key, c2 int) primary_zone z2 partition by hash(c1) partitions 30;
#ob1.mysql create table oceanbase.test3(c1 int primary key, c2 int) primary_zone z2 partition by hash(c1) partitions 30;

##迁移unit_id= 3的unit;

let $src_ip = deploy_get_value(ob1.select select svr_ip  from __all_unit where unit_id = 3, svr_ip, 1);
let $src_port = deploy_get_value(ob1.select select svr_port  from __all_unit where unit_id = 3, svr_port, 1);

##默认系统表的unit都在obs0上面；
let $dest_ip = deploy_get_value(ob1.z3.obs1.ip);
let $dest_port = deploy_get_value(ob1.z3.obs1.port);

ob1.mysql alter system migrate unit 3 destination '$dest_ip:$dest_port';

###等待目的端已经迁移成功副本副本；
ob1.check_until_timeout select count(*) from __all_virtual_core_meta_table where svr_ip='$dest_ip' and svr_port=$dest_port, 1, 120;

##停掉源端；
ob1.z3.obs0.force_stop;
##阻塞掉目的端；

# 由于现在还不支持set block_migrate_in_time，暂时注掉
#ob1.mysql update oceanbase.__all_server set block_migrate_in_time = time_to_usec(gmt_modified) where svr_ip = '$dest_ip' and svr_port=$dest_port;
#ob1.mysql alter system reload server;
#
###等待踢成员后选择目的端；
#ob1.check_until_timeout select count(*) from __all_virtual_core_meta_table where svr_ip='$dest_ip' and svr_port=$dest_port, 0, 120;
#
