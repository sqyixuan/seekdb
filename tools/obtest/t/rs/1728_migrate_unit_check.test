#user: zhengshi.jhc
#user group: rs
#funaction: check replica num before auto migrate unit

ob1=OBI(cluster=2:2:2,proxy_num=0,init_unit_num=1);
ob1.z1.obs1.set status=disable;
ob1.z2.obs1.set status=disable;
ob1.z3.obs1.set status=disable;

ob1.reboot;

let $cpu = 1;
let $memory = '2G';
let $min_memory = '2G';
let $disk = 536870912;
let $iops = 100000;
let $session = 64;

ob1.mysql CREATE RESOURCE UNIT test MAX_CPU $cpu, MAX_MEMORY $memory, MAX_IOPS $iops, MAX_DISK_SIZE $disk, MAX_SESSION_NUM $session, MIN_CPU=1, MIN_MEMORY=$min_memory, MIN_IOPS=128;
ob1.mysql CREATE RESOURCE POOL pool1 UNIT = 'test', UNIT_NUM = 1, ZONE_LIST = ('z1', 'z2', 'z3');
ob1.mysql CREATE RESOURCE POOL pool2 UNIT = 'test', UNIT_NUM = 1, ZONE_LIST = ('z1');
ob1.mysql CREATE TENANT obtest1 RESOURCE_POOL_LIST = ('pool1') set ob_tcp_invited_nodes='%';
ob1.mysql CREATE TENANT obtest2 RESOURCE_POOL_LIST = ('pool2') set ob_tcp_invited_nodes='%';

sleep 5;
ob1.z1.obs1.set status=enable;
ob1.z1.obs1.start;
sleep 20;
ob1.z1.obs1.add;
sleep 20;
ob1.z2.obs1.set status=enable;
ob1.z2.obs1.start;
sleep 20;
ob1.z2.obs1.add;
sleep 20;
ob1.z3.obs1.set status=enable;
ob1.z3.obs1.start;
sleep 20;
ob1.z3.obs1.add;
sleep 20;

ob_connect(conn1, ob1.z1.obs0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);
connection conn1;
set ob_query_timeout = 60000000;



sleep 10;
# When the unit migration is initiated, the migrated server will be recorded on migrate_from_svr_ip in _all_unit. 
# Here, it is checked that all migrations have been completed.
ob1.check_until_timeout select count(*) from __all_unit where migrate_from_svr_ip != '', 0, 100000;
# Supplemental check migration unit completed, pool1 has 3 units need to migrate, because there are 3 zones.
ob1.check_until_timeout select count(*) from __all_rootservice_event_history where event = 'finish_migrate_unit', 3, 1000000;
# Finally check migrate_unit, this means build migrate unit task. Only 3 migarate unit task had been builded.
ob1.check_until_timeout select count(*) from __all_rootservice_event_history where event = 'migrate_unit', 3, 1000000;



