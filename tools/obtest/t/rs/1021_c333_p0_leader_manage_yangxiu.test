##############################
# owner: rongxuan.lc
# owner group: proxy
#功能点：
# leader管理
#
#用例场景：
#1、同一个partition group的partition，若leader在不同机器上，需迁移至相同机器
#2、多数leader在相同机器上
#3、leader平均在多台机器上
###############################

ob1=OBI(cluster=2:2:2,init_unit_cpu=2);
ob1.reboot;

ob1.create_client tenant=obtest,user=admin,passwd=admin,database=test;

ob1.source include/migrate.inc;
# 创建2个tablegroup,1个tablegroup 3个表，另一个8个表
# tg1: obtest1..obtest3
# tg2: obtest4..obtest11
let $difftablegroup=0;
let $tablenum = 3;
let $partnum = 2;
source sql/init_table.sql;

let $tablenum = 8;
let $partnum = 2;
let $offset = 3;
source sql/init_table.sql;

#check leader in same mechine
let $leader = deploy_get_value(ob1.get_leader obtest:test:obtest1:0);
$leader.check_leader obtest:test:obtest2:0;
$leader.check_leader obtest:test:obtest3:0;

let $leader = deploy_get_value(ob1.get_leader obtest:test:obtest1:1);
$leader.check_leader obtest:test:obtest2:1;
$leader.check_leader obtest:test:obtest3:1;

let $leader = deploy_get_value(ob1.get_leader obtest:test:obtest1:1);
let $cnt = 11;
while ($cnt >3)
{
  $leader.check_leader obtest:test:obtest$cnt:1;
  dec $cnt;
}

let $leader = deploy_get_value(ob1.get_leader obtest:test:obtest1:0);
let $cnt = 11;
while ($cnt >3)
{
  $leader.check_leader obtest:test:obtest$cnt:0;
  dec $cnt;
}


#########
#case 1: 同一个partition group的partition,若leader在不同机器上，需迁移至相同机器
################
ob1.mysql alter system set enable_auto_leader_switch=false;
let $cnt = 1;
while ($cnt >= 0)
{
  # patition 迁移leader使得不在一个机器上
  ob1.z1.obs1.switch_partition obtest:test:obtest1:$cnt;
  ob1.z2.obs1.switch_partition obtest:test:obtest2:$cnt;
  ob1.z3.obs1.switch_partition obtest:test:obtest3:$cnt;
  dec $cnt;
}
sleep 15;

# check switch ok
let $cnt=1;
while ($cnt>=0)
{
  ob1.z1.obs1.check_leader obtest:test:obtest1:$cnt;
  ob1.z2.obs1.check_leader obtest:test:obtest2:$cnt;
  ob1.z3.obs1.check_leader obtest:test:obtest3:$cnt;
  dec $cnt;
}

ob1.mysql alter system set enable_auto_leader_switch=true;
# wait switch
sleep 20;

let $cnt=1;
while ($cnt>=0)
{
  let $leader = deploy_get_value(ob1.get_leader obtest:test:obtest1:$cnt);
  $leader.check_leader obtest:test:obtest2:$cnt;
  $leader.check_leader obtest:test:obtest3:$cnt;
  dec $cnt;
}

###########
#case 2: 多数leader在不同机器上
################
# 切换leader,cnt数需要迁移leader的表的数目
ob1.mysql alter system set enable_auto_leader_switch=false;
sleep 5;

let $cnt=5;
while ($cnt >0)
{
	let $zid = math($cnt%3+1);
	
	ob1.z$zid.obs1.switch_partition obtest:test:obtest$cnt:0;
	ob1.z$zid.obs1.switch_partition obtest:test:obtest$cnt:1;
	
	dec $cnt;		
}

ob1.mysql alter system set enable_auto_leader_switch=true;

# wait for switch
sleep 20;

let $cnt=8;
let $leader = deploy_get_value(ob1.get_leader obtest:test:obtest$cnt:0);
while ($cnt>0)
{
  $leader.check_leader obtest:test:obtest$cnt:0;
  dec $cnt;
}

let $cnt=8;
let $leader = deploy_get_value(ob1.get_leader obtest:test:obtest$cnt:1); 
while ($cnt>0)
{
  $leader.check_leader obtest:test:obtest$cnt:1;
  dec $cnt;
}

###########
#case 3: leader平均在不同机器上
################
ob1.mysql alter system set enable_auto_leader_switch=false;
let $cnt= 8;
while ($cnt >0)
{
  if($cnt > 4) 
  {
    ob1.z1.obs1.switch_partition obtest:test:obtest$cnt:0;
  }
  if($cnt <4)
  {
    ob1.z2.obs1.switch_partition obtest:test:obtest$cnt:0;
  }
  dec $cnt ;
}

ob1.mysql alter system set enable_auto_leader_switch=true;
sleep 20;

let $cnt=8;
let $leader = deploy_get_value(ob1.get_leader obtest:test:obtest$cnt:0);
while ($cnt>0)
{
  $leader.check_leader obtest:test:obtest$cnt:0;
  dec $cnt;
}


