# owner: xiongliyao.xly
# owner group: shenzhen
#
# 测试 Redis 模型 TTL 删除的一些基本场景
 
ob1=OBI(cluster=1,proxy_num=0);
ob1.reboot;
 
ob1.mysql alter system set enable_rebalance='false';
 
# build tenant
let $max_cpu = 4;
let $min_cpu = 1;
let $memory_size = 8589934592;
let $log_disk_size = 2147483648;
let $max_iops = 100000;
let $min_iops = 1024;
 
ob_connect(conn_sys, ob1.z1.obs0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);
set @@session.ob_query_timeout = 1000000000;
# mysql tenant
eval CREATE RESOURCE UNIT unit_1 MAX_CPU $max_cpu, MIN_CPU $min_cpu, MEMORY_SIZE $memory_size, LOG_DISK_SIZE $log_disk_size, MAX_IOPS $max_iops, MIN_IOPS $min_iops;
eval CREATE RESOURCE POOL pool_1 UNIT = 'unit_1', UNIT_NUM = 1;
eval CREATE TENANT mysql RESOURCE_POOL_LIST = ('pool_1'), primary_zone='z1' set ob_tcp_invited_nodes='%';
 
let $tenant_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name = 'mysql', tenant_id, 1);
 
ob_connect(sys_conn, ob1.z1.obs0, root,,test,USE_OB_CONNECTOR);
ob_connect(conn1, ob1.z1.obs0, root@mysql,, test,, USE_OB_CONNECTOR);
 
sleep 3;
 
--echo
--echo >>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>
--echo    1. delete all expired records in redis table
--echo >>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>
 
connection conn1;
 
# set system param
alter system minor freeze;
alter system set enable_kv_ttl = true;
 
# create table
CREATE TABLE obkv_redis_zset_table_test(
  db bigint not null,
  rkey varbinary(16384) not null, # 16K 
  expire_ts timestamp(6) default null,
  insert_ts timestamp(6) DEFAULT CURRENT_TIMESTAMP(6),
  score double default null,
  vk varbinary(16384) GENERATED ALWAYS AS (substr(rkey,9,conv(substr(rkey,1,8),16,10))) VIRTUAL,
  index index_score(db, vk, score) local,
  PRIMARY KEY(db, rkey))
  KV_ATTRIBUTES ='{"Redis": {"isTTL": true, "model": "zset"}}'
  PARTITION BY KEY(db, vk) PARTITIONS 97;

# insert data
--disable_query_log
--echo --> insert into obkv_redis_zset_table_test 1 meta row and 2000 data rows...
connection conn1;
let $cnt=0;
--disable_all_result_log
## insert meta
eval insert into obkv_redis_zset_table_test(db, rkey, expire_ts, insert_ts, score) values (0, "00000007testKey00", '2024-06-21 02:02:03.123456789', '2024-06-21 01:02:03.123456789', -99999999);
while($cnt < 2000)
{
  eval insert into obkv_redis_zset_table_test(db, rkey, expire_ts, insert_ts, score) values (0, concat("00000007testKey1", $cnt) , NULL, '2024-06-21 01:02:03.123456789', $cnt + 0.123);
	inc $cnt;
}
--enable_all_result_log
--echo --> insert 2000 rows end
 
# trigger ttl
alter system trigger ttl;
--echo --> trigger ttl
 
# check task finished
ob1.check_until_timeout select count(*) as task_cnt from oceanbase.cdb_ob_kv_ttl_tasks where task_type = "NORMAL" and tenant_id = $tenant_id, 0, 90;
--echo --> check task finished success

# check table records
--echo --> check table records, should be empty table
select * from obkv_redis_zset_table_test;

# check task result
SELECT TABLE_NAME, TRIGGER_TYPE, STATUS, TTL_DEL_CNT, MAX_VERSION_DEL_CNT, SCAN_CNT, RET_CODE from oceanbase.DBA_OB_KV_TTL_TASK_HISTORY where task_type = "NORMAL" and task_id = (select max(task_id) from oceanbase.DBA_OB_KV_TTL_TASK_HISTORY where task_type = "NORMAL") order by tablet_id asc;

# drop table
drop table obkv_redis_zset_table_test;