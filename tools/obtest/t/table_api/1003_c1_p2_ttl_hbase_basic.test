# owner: shenyunlong.syl
# owner group: shenzhen
#
# 测试 Hbase 模型 TTL 删除的一些基本场景
 
ob1=OBI(cluster=1,proxy_num=0);
ob1.reboot;
 
ob1.mysql alter system set enable_rebalance='false';
 
# build tenant
let $max_cpu = 4;
let $min_cpu = 1;
let $memory_size = 8589934592;
let $log_disk_size = 3221225472;
let $max_iops = 100000;
let $min_iops = 1024;
 
ob_connect(conn_sys, ob1.z1.obs0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);
set @@session.ob_query_timeout = 1000000000;
# mysql tenant
eval CREATE RESOURCE UNIT unit_1 MAX_CPU $max_cpu, MIN_CPU $min_cpu, MEMORY_SIZE $memory_size, LOG_DISK_SIZE $log_disk_size, MAX_IOPS $max_iops, MIN_IOPS $min_iops;
eval CREATE RESOURCE POOL pool_1 UNIT = 'unit_1', UNIT_NUM = 1;
eval CREATE TENANT mysql RESOURCE_POOL_LIST = ('pool_1'), primary_zone='z1' set ob_tcp_invited_nodes='%';
 
let $tenant_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name = 'mysql', tenant_id, 1);
 
ob_connect(sys_conn, ob1.z1.obs0, root,,test,USE_OB_CONNECTOR);
ob_connect(conn1, ob1.z1.obs0, root@mysql,, test,, USE_OB_CONNECTOR);
 
sleep 3;
 
--echo
--echo >>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>
--echo    1. Too many expired version records hbase table
--echo >>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>
# 
 
connection conn1;
 
# set system param
alter system minor freeze;
alter system set enable_kv_ttl = true;
 
# create table
create table if not exists ttl_hbase_table (K varbinary(1024), Q varbinary(256), T bigint, V varbinary(1024), primary key(K, Q, T)) kv_attributes ='{"Hbase": {"MaxVersions": 1}}' partition by key(K) partitions 3;
 
# insert data
--disable_query_log
--echo --> insert into ttl_hbase_table 1500 row...
connection conn1;
let $cnt=0;
--disable_all_result_log
while($cnt < 1500)
{
  eval insert into ttl_hbase_table(K, Q, T, V) values ("row0", "cq0", $cnt, "hello world");
	inc $cnt;
}
--enable_all_result_log
--echo --> insert 1500 rows end
 
# trigger ttl
alter system trigger ttl;
--echo --> trigger ttl
 
# check task finished
ob1.check_until_timeout select count(*) as task_cnt from oceanbase.cdb_ob_kv_ttl_tasks where task_type = "NORMAL" and tenant_id = $tenant_id, 0, 90;
--echo --> check task finished success

# check table records
select * from ttl_hbase_table order by T;

# check task result
SELECT TABLE_NAME, TRIGGER_TYPE, STATUS, TTL_DEL_CNT, MAX_VERSION_DEL_CNT, SCAN_CNT, RET_CODE from oceanbase.DBA_OB_KV_TTL_TASK_HISTORY where task_type = "NORMAL" and task_id = (select max(task_id) from oceanbase.DBA_OB_KV_TTL_TASK_HISTORY where task_type = "NORMAL") order by tablet_id asc;

# drop table
drop table ttl_hbase_table;

--echo
--echo >>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>
--echo    2. htable without max_version or time_to_live is not ttl table
--echo >>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>
# 
connection conn1;
 
# create table
create table if not exists non_ttl_htable (K varbinary(1024) NOT NULL, Q varbinary(256)  NOT NULL, T bigint NOT NULL, V varbinary(1024) DEFAULT NULL, PRIMARY KEY (K, Q, T) ) kv_attributes ='{"Hbase": {}}' partition by key(K) partitions 3;
 
# trigger ttl
alter system trigger ttl;
--echo --> trigger ttl
 
# check task finished
ob1.check_until_timeout select count(*) as task_cnt from oceanbase.cdb_ob_kv_ttl_tasks where task_type = "NORMAL" and tenant_id = $tenant_id, 0, 90;
--echo --> check task finished success

# check task result
SELECT TABLE_ID, TABLE_NAME, TRIGGER_TYPE, STATUS, TTL_DEL_CNT, MAX_VERSION_DEL_CNT, SCAN_CNT, RET_CODE from oceanbase.DBA_OB_KV_TTL_TASK_HISTORY where task_type = "NORMAL" and task_id = (select max(task_id) from oceanbase.DBA_OB_KV_TTL_TASK_HISTORY where task_type = "NORMAL") order by tablet_id asc;

# drop table
drop table non_ttl_htable;
