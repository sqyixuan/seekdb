# owner: zeli.lwb
# owner group: shenzhen
#
# Check TTL triggering when schema is changing
 
ob1=OBI(cluster=1,proxy_num=0);
ob1.reboot;
 
ob1.mysql alter system set enable_rebalance='false';

# build tenant
let $max_cpu = 4;
let $min_cpu = 1;
let $memory_size = 8589934592;
let $log_disk_size = 3221225472;
let $max_iops = 100000;
let $min_iops = 1024;
 
ob_connect(conn_sys, ob1.z1.obs0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);
set @@session.ob_query_timeout = 1000000000;
# mysql tenant
eval CREATE RESOURCE UNIT unit_1 MAX_CPU $max_cpu, MIN_CPU $min_cpu, MEMORY_SIZE $memory_size, LOG_DISK_SIZE $log_disk_size, MAX_IOPS $max_iops, MIN_IOPS $min_iops;
eval CREATE RESOURCE POOL pool_1 UNIT = 'unit_1', UNIT_NUM = 1;
eval CREATE TENANT mysql RESOURCE_POOL_LIST = ('pool_1'), primary_zone='z1' set ob_tcp_invited_nodes='%';
 
let $mysql_tenant_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name = 'mysql', tenant_id, 1);
 
ob_connect(sys_conn, ob1.z1.obs0, root,,test,USE_OB_CONNECTOR);
ob_connect(conn1, ob1.z1.obs0, root@mysql,, test,, USE_OB_CONNECTOR);

sleep 3;
 
--echo
--echo >>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>
--echo    1. Simple schema changed
--echo >>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>
 
connection conn1;
 
# sleep for tasks
--sleep 5
 
# set system param
alter system minor freeze;
alter system set enable_kv_ttl = true;
 
# create table 
create table ttl_table_origin_0(a varchar(1024), b int primary key, c timestamp) TTL(c + INTERVAL 0 SECOND) partition by key(b) partitions 513;
create table ttl_table_origin_1(a varchar(1024), b int primary key, c timestamp) TTL(c + INTERVAL 0 SECOND) partition by key(b) partitions 513;
create table ttl_table_origin_2(a varchar(1024), b int primary key, c timestamp) TTL(c + INTERVAL 0 SECOND) partition by key(b) partitions 32;
create table ttl_table_origin_3(a varchar(1024), b int primary key, c timestamp) TTL(c + INTERVAL 0 SECOND) partition by key(b) partitions 128;
 
# get tenant_id
let $tenant_id = query_get_value(select tenant_id from oceanbase.dba_ob_tenants where status = 'NORMAL' and tenant_name = 'mysql', tenant_id, 1);
 
# insert data
--disable_query_log
--echo --> insert into ttl_table_origin 100 row...
connection conn1;
let $cnt=0;
--disable_all_result_log
while($cnt < 100)
{
  eval insert into ttl_table_origin_0(a, b, c) values (concat('row', cast($cnt as char)), $cnt, now());
  eval insert into ttl_table_origin_1(a, b, c) values (concat('row', cast($cnt as char)), $cnt, now());
  eval insert into ttl_table_origin_2(a, b, c) values (concat('row', cast($cnt as char)), $cnt, now());
	inc $cnt;
}
--enable_all_result_log
--echo --> insert 100 rows end

# trigger ttl
alter system trigger ttl;
--echo --> trigger ttl

# create table 
create table ttl_table_before_check_rst(a varchar(1024), b int primary key, c timestamp) TTL(c + INTERVAL 0 SECOND) partition by key(b) partitions 32;
--echo --> create table ttl_table_before_check_rst

# check status is triggering
ob1.check_until_timeout select STATUS from oceanbase.cdb_ob_kv_ttl_tasks where task_type = "NORMAL" and tablet_id = -1, RS_TRIGGERING, 30;
--echo --> check trigger ttl

# create table 
create table ttl_table_after_check_rst(a varchar(1024), b int primary key, c timestamp) TTL(c + INTERVAL 0 SECOND) partition by key(b) partitions 32;
--echo --> create table ttl_table_after_check_rst

# check prepared
ob1.check_until_timeout select STATUS from oceanbase.cdb_ob_kv_ttl_tasks where task_type = "NORMAL" and STATUS = "PREPARED" limit 1, PREPARED, 30;

# create table 
create table ttl_table_after_check_prep(a varchar(1024), b int primary key, c timestamp) TTL(c + INTERVAL 0 SECOND) partition by key(b) partitions 32;
--echo --> create table ttl_table_after_check_prep

# check finished
ob1.check_until_timeout select STATUS from oceanbase.cdb_ob_kv_ttl_tasks where task_type = "NORMAL" and STATUS = "FINISHED" limit 1, FINISHED, 30;

# create table 
create table ttl_table_after_check_fin(a varchar(1024), b int primary key, c timestamp) TTL(c + INTERVAL 0 SECOND) partition by key(b) partitions 32;
--echo --> create table ttl_table_after_check_fin

# check status is finished
ob1.check_until_timeout select STATUS from oceanbase.cdb_ob_kv_ttl_task_history where task_type = "NORMAL", FINISHED, 1200;
--echo --> check status is finished

# drop table
drop table ttl_table_origin_0;
drop table ttl_table_origin_1;
drop table ttl_table_origin_2;
drop table ttl_table_origin_3;
drop table ttl_table_before_check_rst;
drop table ttl_table_after_check_rst;
drop table ttl_table_after_check_prep;
drop table ttl_table_after_check_fin;
