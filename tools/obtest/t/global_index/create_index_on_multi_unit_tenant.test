# owner: bin.lb
# owner group: sql3
#
# create global index on multi-units tenant.
# 

ob1=OBI(cluster=3,proxy_num=0,init_unit_cpu=0,node_cpu_count=20,memory_size_limit=480000);
ob1.reboot;

sleep 2;
ob1.mysql create resource pool xx1 unit = 'sys_unit_config',unit_num = 3, zone_list = ('z1');
ob1.mysql create tenant xx1 replica_num 1, primary_zone 'z1', resource_pool_list ('xx1') set ob_tcp_invited_nodes='%';

sleep 2;

let $ip = deploy_get_value(ob1.z1.obs1.ip);
let $mysql_port = deploy_get_value(ob1.z1.obs1.mysql_port);

connect(xx1_conn,$ip,root@xx1,,test, $mysql_port);
connection xx1_conn;

create tablegroup tg PARTITION BY key 1 partitions 16;

CREATE TABLE `linktable` ( `id1` bigint(20) unsigned NOT NULL DEFAULT '0', `id2` bigint(20) unsigned NOT NULL DEFAULT '0', `link_type` bigint(20) unsigned NOT NULL DEFAULT '0', `visibility` tinyint(3) NOT NULL DEFAULT '0', `data` varchar(255) NOT NULL DEFAULT '', `time` bigint(20) unsigned NOT NULL DEFAULT '0', `version` int(11) unsigned NOT NULL DEFAULT '0', PRIMARY KEY (link_type, `id1`,`id2`) ) TABLEGROUP tg PARTITION BY key(id1) PARTITIONS 16;

CREATE INDEX idx0 on linktable(id1,link_type,visibility,time,id2,version,data) global partition by HASH(id1) partitions 32;

ob1.check_until_timeout select index_status from oceanbase.__all_virtual_table where tenant_id=1001 and table_name like '%idx0%', 2, 100;

show index from linktable;
