# owner: bin.lb
# owner group: sql
# parallel build index
#
ob1=OBI(cluster=1,proxy_num=0,init_unit_cpu=0);
ob1.reboot;

ob1.mysql alter system set resource_hard_limit=900;
ob1.mysql alter system set enable_auto_leader_switch = 'false';
ob1.mysql alter system set merger_check_interval='10s';
ob1.create_client;

sleep 2;

ob1.mysql create resource pool xx1  unit = 'sys_unit_config',unit_num = 1, zone_list = ('z1');
ob1.mysql create tenant xx1 replica_num 1, resource_pool_list ('xx1') set ob_tcp_invited_nodes='%', ob_compatibility_mode='oracle';

let $ip = deploy_get_value(ob1.z1.obs0.ip);
let $port = deploy_get_value(ob1.z1.obs0.mysql_port);

ob_connect(xx1_conn,$ip,sys@xx1,,sys, $port, USE_OB_CONNECTOR);
ob_connect(sys_conn,$ip,root@sys,,oceanbase, $port);

connection xx1_conn;
create table t1 (c1 int primary key, c2 int, c3 int, c4 varchar(512)) NOCOMPRESS partition by hash(c1) partitions 2;
connection sys_conn;
alter system change tenant xx1;
# update tablet_size to 16K
update oceanbase.__all_table_v2 set tablet_size = 16384;
update oceanbase.__all_table_v2_history set tablet_size = 16384;
alter system change tenant sys;

ob1.obs0.restart;
sleep 30;
ob1.create_client;
ob_connect(xx1_conn2,$ip,sys@xx1,,sys, $port, USE_OB_CONNECTOR);
connection xx1_conn2;
show create table t1;

let $i=10000;
--disable_query_log
while ($i > 0)
{
  let $v=deploy_get_value(ob1.get_random_string 256);
  eval insert into t1 (c1, c2, c3, c4) values ($i, $i, 1, '$v');
  dec $i;
}
--enable_query_log

ob1.mysql alter system major freeze;
ob1.check_version 2;

sleep 1;

create unique index idx01 on t1(c2) global partition by hash(c2) partitions 2;

ob1.mysql_p select count(*) > 6 from oceanbase.__all_sql_execute_task;

# test sampling duplicate ranges
create index idx02 on t1(c3) global partition by hash(c3) partitions 2;

