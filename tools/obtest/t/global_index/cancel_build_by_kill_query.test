# owner: bin.lb
# owner group: sql
#
# 1. detect non execution task in RS.
# 2. cancel task execution by CTRL-C.

ob1=OBI(cluster=1,proxy_num=0,init_unit_cpu=0);
ob1.z1.obs0.set extra_config=devname=eth0;
ob1.reboot;

ob1.mysql create resource unit t1_unit max_cpu=5,min_memory='10G',max_memory='10G',max_disk_size='100G',max_iops=1000,max_session_num=1000;
ob1.mysql create resource pool t1_pool unit = 't1_unit', unit_num = 1, zone_list= ("z1");
ob1.mysql create tenant t1 replica_num 1, primary_zone = "z1", resource_pool_list ('t1_pool') set ob_tcp_invited_nodes='%';

let $ip0 = deploy_get_value(ob1.z1.obs0.ip);
let $port0 = deploy_get_value(ob1.z1.obs0.port);
let $mysql_port0 = deploy_get_value(ob1.z1.obs0.mysql_port);

sleep 2;

connect(sys_con,$ip0,root@sys,,oceanbase,$mysql_port0);
connect(t1_con,$ip0,root@t1,,test, $mysql_port0);
connection t1_con;

create table t1 (c1 int primary key, c2 int, c3 int) partition by hash(c1) partitions 2;
let $cnt = 1000;

--disable_query_log
while ($cnt > 0)
{
  eval insert into t1  (c1, c2, c3) values ($cnt, $cnt, $cnt);
  dec $cnt;
}
--enable_query_log



## 1. detect non execution task in RS.
connection sys_con;
# do not report complete message.
alter system set_tp tp_no = 242, error_code = 1, frequency = 1;
# check status frequently
alter system set_tp tp_no = 243, error_code = 1, frequency = 1;

connection t1_con;
send create index i1 on t1 (c3) global;

connection sys_con;
sleep 30;

select count(1) from oceanbase.__all_virtual_rebalance_task_stat where executing_time > 20000000;
alter system set_tp tp_no = 242, error_code = 1, frequency = 0;

connection t1_con;
reap;
show index from t1;

## 2. cancel task execution by CTRL-C.
alter table t1 add column c4 int generated always as (sleep(1)) virtual;

send create index i2 on t1 (c4) global;

sleep 30;

connection sys_con;

--disable_query_log
let $sid = deploy_get_value(ob1.select select id from __all_virtual_processlist where info like '%create index i2 on t1%', id, 1);
eval kill query $sid;
--enable_query_log

sleep 5;
select count(1) from oceanbase.__all_virtual_rebalance_task_stat;
