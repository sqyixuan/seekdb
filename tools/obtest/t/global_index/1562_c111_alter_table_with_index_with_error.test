# case 13: 测试全文索引相关
create table tt(c1 int primary key, c2 int, c3 varchar(20));
--error 1235
alter table tt add fulltext index idx(c3) local;
--error 1235
alter table tt add fulltext index idx(c3) global;
#--error 1235
#alter table tt add fulltext index idx(c3) partition by hash(c1) partitions 2;
alter table tt add fulltext index idx(c3);
connection conn_sys;
let $table_id = deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where table_name like "%idx", table_id, 1);
let $count = deploy_get_value(ob1.select select count(*) c from oceanbase.__all_tenant_meta_table where table_id = $table_id and role = 1, c, 1);
echo "partition num: $count";
eval select $basic_table_columns from oceanbase.__all_virtual_table where table_id = $table_id;
eval select $basic_part_columns from oceanbase.__all_virtual_part where table_id = $table_id;
eval select $basic_column_columns from oceanbase.__all_virtual_column where table_id = $table_id;
connection conn_1;
drop table tt;

# case 14：测试major freeze
create table tt(c1 int primary key, c2 int, c3 varchar(20));
#alter table tt add index idx1(c1) global partition by hash(c1) partitions 2;
alter table tt add index idx2(c2) local;
connection conn_sys;
#let $table1_id = deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where table_name like "%idx1", table_id, 1);
let $table2_id = deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where table_name like "%idx2", table_id, 1);
#ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table where table_id = "$table1_id" and index_status = 1, 1, 120;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table where table_id = "$table2_id" and index_status = 1, 1, 120;

ob1.mysql alter system major freeze;
ob1.check_version 2;
#ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table where table_id = "$table1_id" and index_status = 2, 1, 120;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table where table_id = "$table2_id" and index_status = 2, 1, 120;
