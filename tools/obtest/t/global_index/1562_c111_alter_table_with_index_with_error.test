# owner: yanmu.ztl
# owner group: rs
# description:
# 测试alter table带索引的情况, 以下是目前索引实现的一些限制：
# 1) 目前索引表不支持二级分区；
# 2) 目前索引表支持hash/key/range/range columns
# 3) 局部非前缀索引不能是唯一索引
# 4) 不支持全局非前缀索引(hash/key分区无全局非前缀索引一说)
# 
#
# TODO: 由于异步创建局部索引立即生效的实现不完全，通过手工触发合并观察到局部索引是生效的，为避免case执行时间过长，
#       此处暂时不检查局部索引生效的情况
# case说明：
# case 9: 测试分区相关
#         1）局部索引不支持指定分区的方式
#         2）索引不支持二级分区
#         3）全局索引需满足分区语法的限制（分区列类型，数目匹配）
# case 10：测试列不存在的情况
# case 11: 测试局部非前缀索引
# case 12：测试全局非前缀索引（hash/key分区无全局非前缀索引一说）
# case 13: 测试全文索引相关
# case 14: 测试major freeze及索引生效的场景
ob1=OBI(cluster=1:1:1, init_unit_cpu=1, proxy_num=0, ct_num=0, locality=hz:hz:hz);
ob1.reboot;

ob1.mysql alter system set resource_hard_limit=900;
ob1.mysql alter system set resource_soft_limit=800;
ob1.mysql alter system set enable_auto_leader_switch = 'false';
ob1.mysql alter system set enable_rebalance = 'false';
ob1.mysql alter system set enable_rereplication = 'false';
ob1.mysql alter system set balancer_idle_time = '10s';
ob1.mysql alter system set server_data_copy_out_concurrency = 20;
ob1.mysql alter system set server_data_copy_in_concurrency = 20;

let $cpu = 1;
let $memory = 1073741824;
let $min_memory = 1073741824;
let $disk = 536870912;
let $iops = 100000;
let $session = 64;

let $rs = deploy_get_value(ob1.get_leader sys:oceanbase:__all_core_table:0);
let $rs_ip = deploy_get_value($rs.ip);
let $rs_port = deploy_get_value($rs.port);
let $rs_mysql_port = deploy_get_value($rs.mysql_port);
connect (conn_sys,$rs_ip,admin@sys,admin,oceanbase,$rs_mysql_port);
connect (conn_1,$rs_ip,admin@obtest,admin,test,$rs_mysql_port);

let $basic_table_columns = tenant_id, table_id, table_name, database_id, tablegroup_id, data_table_id, index_type, index_status, part_level, part_func_type, part_func_expr, part_num, max_used_part_id;
let $basic_part_columns = tenant_id, table_id, part_id, part_name, high_bound_val, b_high_bound_val;
let $basic_column_columns = tenant_id, table_id, column_id, column_name, is_hidden, collation_type, orig_default_value;
connection conn_1;
use test;

## case 9: 分区相关
#create table tt(c1 int primary key, c2 int, c3 varchar(20));
## 局部索引不支持指定分区方式
#--error 1235
#alter table tt add index idx(c1, c2) local partition by hash(c1) partitions 2;
## 索引不支持二级分区
#--error 1235
#alter table tt add index idx(c1, c2) global partition by hash (c1) subpartition by range (c2) subpartition template (SUBPARTITION p0 VALUES LESS THAN (1990),  SUBPARTITION p1 VALUES LESS THAN (2000),  SUBPARTITION p2 VALUES LESS THAN MAXVALUE) partitions 2;
## 分区需要检查向量类型，向量数目是否匹配，以range columns为例
#--error 1653
#alter table tt add index idx(c3, c2) global partition by range columns (c3, c2) (PARTITION p0 VALUES LESS THAN ('1990'), partition p1 values less than('2000'));
#--error 1654
#alter table tt add index idx(c3) global partition by range columns (c3) (PARTITION p0 VALUES LESS THAN (1990), partition p1 values less than(2000));
## hash/range分区只支持int相关类型
#--error 1659
#alter table tt add index idx(c3) global partition by hash(c3) partitions 2;
#--error 1659
#alter table tt add index idx(c3) global partition by range (c3) (PARTITION p0 VALUES LESS THAN (1990), partition p1 values less than(20000));
#drop table tt;
#
#create table tt(c1 int primary key, c2 int, c3 varchar(20));
#alter table tt add index idx(c3) global partition by key(c3) partitions 2;
#let $table_id = deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where table_name like "%idx", table_id, 1);
#let $count = deploy_get_value(ob1.select select count(*) c from oceanbase.__all_tenant_meta_table where table_id = $table_id and role = 1, c, 1);
#echo "partition num: $count";
#eval select $basic_table_columns from oceanbase.__all_virtual_table where table_id = $table_id;
#eval select $basic_part_columns from oceanbase.__all_virtual_part where table_id = $table_id;
#eval select $basic_column_columns from oceanbase.__all_virtual_column where table_id = $table_id;
#ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table where table_id = "$table_id" and index_status = 2, 1, 120;
#drop table tt;
#
#create table tt (c1 int primary key, c2 int, c3 varchar(20));
#alter table tt add index idx(c3) global partition by range columns (c3) (PARTITION p0 VALUES LESS THAN ('1990'), partition p1 values less than('2000'));
#let $table_id = deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where table_name like "%idx", table_id, 1);
#let $count = deploy_get_value(ob1.select select count(*) c from oceanbase.__all_tenant_meta_table where table_id = $table_id and role = 1, c, 1);
#echo "partition num: $count";
#eval select $basic_table_columns from oceanbase.__all_virtual_table where table_id = $table_id;
#eval select $basic_part_columns from oceanbase.__all_virtual_part where table_id = $table_id;
#eval select $basic_column_columns from oceanbase.__all_virtual_column where table_id = $table_id;
#ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table where table_id = "$table_id" and index_status = 2, 1, 120;
#drop table tt;

## case 10: 列不存在
## 索引分区列不在索引列中
#create table tt(c1 int primary key, c2 int, c3 varchar(20));
#--error 1054
#alter table tt add index idx(c1) global partition by hash(c3) partitions 2;
#--error 1054
#alter table tt add index idx(c1) global partition by key(c3) partitions 2;
#--error 1054
#alter table tt add index idx(c1) global partition by range (c3) (PARTITION p0 VALUES LESS THAN (1990), partition p1 values less than(20000));
#--error 1054
#alter table tt add index idx(c1) global partition by range columns (c3) (PARTITION p0 VALUES LESS THAN (1990), partition p1 values less than(20000));
## 索引列不在主表声明的列中
#--error 1072
#alter table tt add index idx(c4) global partition by hash(c1) partitions 2;
#--error 1072
#alter table tt add index idx(c4) global partition by key(c1) partitions 2;
#--error 1072
#alter table tt add index idx(c4) global partition by range (c1) (PARTITION p0 VALUES LESS THAN (1990), partition p1 values less than(20000));
#--error 1072
#alter table tt add index idx(c4) global partition by range columns (c1) (PARTITION p0 VALUES LESS THAN (1990), partition p1 values less than(20000));
## storing列不存在
#--error 1054
#alter table tt add index idx(c1) global storing(c4) partition by hash(c1) partitions 2;
#--error 1054
#alter table tt add index idx(c1) global storing(c4) partition by key(c1) partitions 2;
#--error 1054
#alter table tt add index idx(c1) global storing(c4) partition by range (c1) (PARTITION p0 VALUES LESS THAN (1990), partition p1 values less than(20000));
#--error 1054
#alter table tt add index idx(c1) global storing(c4) partition by range columns (c1) (PARTITION p0 VALUES LESS THAN (1990), partition p1 values less than(20000));
## 虽然索引列会自动带上主表主键列，且对于hash/key分区无全局非前缀索引一说，但目前不支持这种写法
#--error 1503
#alter table tt add index idx(c2) global partition by hash(c1) partitions 2;
#drop table tt;

# case 11: 局部非前缀索引
# 局部非前缀索引的索引分区列与主表分区列相同
create table tt(c1 int primary key, c2 int, c3 varchar(20)) partition by hash(c1) partitions 2;
alter table tt add index idx(c2, c3) local;
connection conn_sys;
let $table_id = deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where table_name like "%idx", table_id, 1);
let $count = deploy_get_value(ob1.select select count(*) c from oceanbase.__all_tenant_meta_table where table_id = $table_id and role = 1, c, 1);
echo "partition num: $count";
eval select $basic_table_columns from oceanbase.__all_virtual_table where table_id = $table_id;
eval select $basic_part_columns from oceanbase.__all_virtual_part where table_id = $table_id;
eval select $basic_column_columns from oceanbase.__all_virtual_column where table_id = $table_id;
#ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table where table_id = "$table_id" and index_status = 2, 1, 120;
connection conn_1;
drop table tt;
# 局部非前缀索引不能为唯一索引
create table tt(c1 int primary key, c2 int, c3 varchar(20)) partition by hash(c1) partitions 2;
--error 1503
alter table tt add unique index idx(c2, c3) local;
drop table tt;

## case 12: 不支持全局非前缀索引(hash/key分区无全局非前缀索引一说)
