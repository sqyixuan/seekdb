# owner: zhenjiang.xzj
# owner group: storage
# description:this case is use for test create unique index on error data
#
--disable_query_log
ob1=OBI(cluster=1:1:1,proxy_num=0,init_unit_cpu=5);
ob1.reboot;

ob1.create_client;

ob1.mysql alter system set merger_check_interval='10s';
ob1.mysql alter system set enable_rebalance = 'false';
ob1.mysql alter system set resource_hard_limit=500;
ob1.mysql alter system set debug_sync_timeout = '100000s';

create table test01 (pk1 int, pk2 int, pk3 int, ui1 int, f1 varchar(1024), f2 varchar(4096), primary key(pk1,pk2,pk3)) partition by hash (pk1) partitions 2;
let $cnt =1;
while ($cnt < 10)
{
	eval insert into test01 values($cnt, $cnt, $cnt, $cnt, 'abc', 'def');
	inc $cnt;
}

ob1.mysql alter system major freeze;
ob1.check_version 2;

ob1.mysql set ob_global_debug_sync = 'AFTER_GLOBAL_INDEX_GET_SNAPSHOT wait_for begin';
sleep 2;
create unique index index_i1 on test01(ui1) global;
sleep 10;

eval insert into test01 values($cnt, $cnt, $cnt, 3, 'abc', 'def');
inc $cnt;
while ($cnt < 20)
{
	eval insert into test01 values($cnt, $cnt, $cnt, $cnt, 'abc', 'def');
	inc $cnt;
}

ob1.mysql set ob_global_debug_sync = 'NOW signal begin';

ob1.check_until_timeout select index_status from oceanbase.__all_virtual_table where table_name like '%index_i1%', 5, 100;

ob1.mysql alter system major freeze;
ob1.check_version 3;
let $index_id = deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where table_name like '%index_i1%', table_id, 1);
let $memtable_size = deploy_get_value(ob1.select select sum(size) as sum_size from oceanbase.__all_virtual_table_mgr where index_id = '$index_id' and table_type = 0, sum_size, 1);
echo $memtable_size;
