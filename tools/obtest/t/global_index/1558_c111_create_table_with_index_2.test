# case 8: 带storing列
# 局部索引
create table tt(c1 int primary key, c2 int, c3 varchar(20), index idx(c1, c3(3)) storing(c2) local);
connection conn_sys;
let $table_id = deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where table_name like "%idx", table_id, 1);
let $count = deploy_get_value(ob1.select select count(*) c from oceanbase.__all_virtual_meta_table where table_id = $table_id and role = 1, c, 1);
echo "partition num: $count";
eval select $basic_table_columns from oceanbase.__all_virtual_table where table_id = $table_id;
eval select $basic_part_columns from oceanbase.__all_virtual_part where table_id = $table_id;
eval select $basic_column_columns from oceanbase.__all_virtual_column where table_id = $table_id;
connection conn_1;
drop table tt;
# 全局索引，存储方式为local
create table tt(c1 int primary key, c2 int, c3 varchar(20), index idx(c1, c3(3)) storing(c2));
connection conn_sys;
let $table_id = deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where table_name like "%idx", table_id, 1);
let $count = deploy_get_value(ob1.select select count(*) c from oceanbase.__all_virtual_meta_table where table_id = $table_id and role = 1, c, 1);
echo "partition num: $count";
eval select $basic_table_columns from oceanbase.__all_virtual_table where table_id = $table_id;
eval select $basic_part_columns from oceanbase.__all_virtual_part where table_id = $table_id;
eval select $basic_column_columns from oceanbase.__all_virtual_column where table_id = $table_id;
connection conn_1;
drop table tt;
