# owner: bin.lb
# owner group: sql
#
# Switch RS is blocked by global index building:
# 

ob1=OBI(cluster=1:1,proxy_num=0,init_unit_cpu=0);
ob1.reboot;

ob1.mysql create resource unit t1_unit max_cpu=5,min_memory='10G',max_memory='10G',max_disk_size='100G',max_iops=1000,max_session_num=1000;
ob1.mysql create resource pool t1_pool unit = 't1_unit', unit_num = 1, zone_list= ("z1","z2");
ob1.mysql create tenant t1 replica_num 1, primary_zone = "z1;z2", resource_pool_list ('t1_pool') set ob_tcp_invited_nodes='%';

let $ip0 = deploy_get_value(ob1.z1.obs0.ip);
let $port0 = deploy_get_value(ob1.z1.obs0.port);
let $mysql_port0 = deploy_get_value(ob1.z1.obs0.mysql_port);

sleep 2;

connect(sys_con,$ip0,root@sys,,oceanbase,$mysql_port0);
connect(t1_con,$ip0,root@t1,,test, $mysql_port0);
connection t1_con;

create table t1 (c1 int primary key, c2 int) partition by hash(c1) partitions 2;
let $cnt = 1000;

--disable_query_log
while ($cnt > 0)
{
  eval insert into t1  (c1, c2) values ($cnt, $cnt);
  dec $cnt;
}
--enable_query_log

alter table t1 add column c3 int generated always as (sleep(1)) virtual;

send create index i1 on t1 (c3) global;

sleep 30;

connection sys_con;

# if stop rootservice is blocked, the continuous switch will timeout or report error.
alter system switch rootservice follower zone = 'z1';
sleep 2;
alter system switch rootservice follower zone = 'z2';
sleep 2;
alter system switch rootservice follower zone = 'z1';

--disable_query_log
let $sid = deploy_get_value(ob1.select select id from __all_virtual_processlist where info like '%create index i1 on t1%', id, 1);
eval kill query $sid;
--enable_query_log
