explain SELECT/*+leading(bmsql_warehouse,bmsql_customer),use_nl(bmsql_customer,bmsql_warehouse)*/ c_discount, c_last, c_credit, w_tax FROM bmsql_customer JOIN bmsql_warehouse ON (w_id = c_w_id) WHERE c_w_id = 56 AND c_d_id = 10 AND c_id = 2455;

SELECT/*+leading(bmsql_warehouse,bmsql_customer),use_nl(bmsql_customer,bmsql_warehouse)*/ c_discount, c_last, c_credit, w_tax FROM bmsql_customer JOIN bmsql_warehouse ON (w_id = c_w_id) WHERE c_w_id = 56 AND c_d_id = 10 AND c_id = 2455;

explain select count(*) from (SELECT/*+leading(bmsql_warehouse,bmsql_customer),use_nl(bmsql_customer,bmsql_warehouse)*/ w_id, c_discount, c_last, c_credit, w_tax FROM bmsql_customer JOIN bmsql_warehouse ON (w_id = c_w_id) WHERE c_w_id = 4 AND c_d_id = 4 AND c_id = 4) A group by   w_id union all select w_id from bmsql_warehouse;

select count(*) from (SELECT/*+leading(bmsql_warehouse,bmsql_customer),use_nl(bmsql_customer,bmsql_warehouse)*/ w_id, c_discount, c_last, c_credit, w_tax FROM bmsql_customer JOIN bmsql_warehouse ON (w_id = c_w_id) WHERE c_w_id = 4 AND c_d_id = 4 AND c_id = 4) A group by   w_id union all select w_id from bmsql_warehouse;

explain select c1, c_d_id from ((select count(*) c1 from (SELECT/*+leading(bmsql_warehouse,bmsql_customer),use_nl(bmsql_customer,bmsql_warehouse)*/ w_id, c_discount, c_last, c_credit, w_tax FROM bmsql_customer JOIN bmsql_warehouse ON (w_id = c_w_id) WHERE c_w_id = 4 AND c_d_id = 4 AND c_id = 4) A group by   w_id union all select w_id from bmsql_warehouse)) A join bmsql_customer on c1 = c_d_id;

select c1, c_d_id from ((select count(*) c1 from (SELECT/*+leading(bmsql_warehouse,bmsql_customer),use_nl(bmsql_customer,bmsql_warehouse)*/ w_id, c_discount, c_last, c_credit, w_tax FROM bmsql_customer JOIN bmsql_warehouse ON (w_id = c_w_id) WHERE c_w_id = 4 AND c_d_id = 4 AND c_id = 4) A group by   w_id union all select w_id from bmsql_warehouse)) A join bmsql_customer on c1 = c_d_id;

create database muhangtest;
use muhangtest;

create table t1(c1 int primary key, c2 int, c3 int, c4 date);
create table t2(c1 int(11) not null, c2 int(11) not null, c3 int(11) not null, primary key (c1, c2, c3)) partition by key(c1) partitions 4;
--sleep 1

explain basic select * from t1 join t2 on t1.c2 = t2.c1;
explain basic select * from t1 join t2 on t1.c1 = t2.c1;
explain basic select * from t1 join t2 on t1.c1 = t2.c2;

drop table t1;
drop table t2;

#一级分区 : 一级key分区
create table t1(c1 int primary key, c2 int, c3 int, c4 date) partition by hash(c1) partitions 2;
create table t2(c1 int(11) not null, c2 int(11) not null, c3 int(11) not null, primary key (c1, c2, c3)) partition by key(c1) partitions 4;

explain basic select * from t1 join t2 on t1.c1 = t2.c1;
explain basic select * from t1 join t2 on t1.c2 = t2.c1;
explain basic select * from t1 join t2 on t1.c1 = t2.c2;

drop table t1;
drop table t2;

#未分区 : 一级range columns 二级分区key 
create table t1(c1 int primary key, c2 int, c3 int, c4 date);
create table t2(c1 int(11) not null, c2 int(11) not null, c3 int(11) not null, primary key (c1, c2, c3)) partition by range columns(c2) subpartition by key(c3) subpartitions 4 (partition p0 values less than (5),partition p1 values less than (10));

explain basic select * from t1 join t2 on t1.c1 = t2.c1;
explain basic select * from t1 join t2 on t1.c1 = t2.c2;
explain basic select * from t1 join t2 on t1.c2 = t2.c1;
explain basic select * from t1 join t2 on t1.c2 = t2.c2;
explain basic select * from t1 join t2 on t1.c1 = t2.c1 and t1.c2=t2.c2;

drop table t1;
drop table t2;

#一级range columns二级key : 一级range columns二级key分区
create table t2(c1 int(11) not null, c2 int(11) not null, c3 int(11) not null, primary key (c1, c2, c3)) partition by range columns(c2) subpartition by key(c3) subpartitions 4 (partition p0 values less than (5),partition p1 values less than (10));
create table t1(c1 int, c2 int, c3 int, c4 date, primary key (c1, c2, c3)) partition by range columns(c2) subpartition by key(c3) subpartitions 2 (partition p0 values less than (10),partition p1 values less than (55));

explain basic select * from t1 join t2 on t1.c1 = t2.c2 and t1.c3 = t2.c3;
explain basic select * from t1 join t2 on t1.c2 = t2.c2 and t1.c3 = t2.c3;
explain basic select * from t1 join t2 on t1.c2 = t2.c1 and t1.c3 = t2.c3;

drop table t1;
drop table t2;

#case0 int型一级range columns/key/hash分区，右表未分区，左表分区键另表主键（非主键）可以re-shuffle
#case0.0 int 一级hash
create table t2(c1 int(11) not null, c2 int(11) not null, c3 date not null, primary key (c1, c2, c3)) partition by hash(c1) partitions 3;
create table t1(c1 int, c2 int, c3 date not null, primary key (c1));
explain basic select * from t1,t2 where t1.c1=t2.c1;
explain basic select * from t1,t2 where t1.c2=t2.c1;
#case0.1 int 一级range columns c1 
drop table t2;
create table t2(c1 int(11) not null, c2 int(11) not null, c3 date not null, primary key (c1, c2, c3)) partition by range columns(c1)
(
partition p0 values less than (10),
partition p1 values less than (MAXVALUE)
);
explain basic select * from t1,t2 where t1.c1=t2.c1;
explain basic select * from t1,t2 where t1.c1=t2.c1;
#case0.2 int 一级hash分区 
drop table t2;
create table t2(c1 int(11) not null, c2 int(11) not null, c3 date not null, primary key (c1, c2, c3)) partition by key(c1) partitions 3;
explain basic select * from t1,t2 where t1.c1=t2.c1;
explain basic select * from t1,t2 where t1.c1=t2.c1;

drop table t1;
drop table t2;


#case1 data型
#case1.0 range columns分区
create table t2(c1 int(11) not null, c2 int(11) not null, c3 date not null, primary key (c1, c2, c3)) partition by range columns(c3)
(
partition p201707 values less than ('2017-07-01 00:00:00'),
partition p201808 values less than ('2018-08-01 00:00:00')
);
create table t1(c1 int, c2 int, c3 date not null, primary key (c1));
explain basic select * from t1,t2 where t1.c1=t2.c3;
explain basic select * from t1,t2 where t1.c3=t2.c3;

drop table t1;
drop table t2;

#case1.1 key分区
create table t2(c1 int(11) not null, c2 int(11) not null, c3 date not null, primary key (c1, c2, c3)) partition by key(c3) partitions 4;  
create table t1(c1 int, c2 int, c3 date not null, primary key (c1, c2, c3));
explain basic select * from t1,t2 where t1.c3=t2.c3;

#case1.2 create table t2(c1 int(11) not null, c2 int(11) not null, c3 date not null, primary key (c1, c2, c3)) partition by hash(c3) partitions 4;  #date型不允许hash分区
drop table t1;
drop table t2;

#case2 varchar类型
#case2.0 一级range columns
create table t2(c1 int(11) not null, c2 int(11) not null, c3 varchar(32) not null, primary key (c1, c2, c3)) partition by range columns(c3)
(
partition p201707 values less than ('2017-07-01 00:00:00'),
partition p201808 values less than ('2018-08-01 00:00:00')
);
create table t1(c1 int, c2 int, c3 varchar(32) not null, primary key(c1));
explain basic select * from t1,t2 where t1.c3=t2.c3;
drop table t1;
create table t1(c1 int, c2 varchar(32), c3 varchar(32) not null, primary key(c1));
explain basic select * from t1,t2 where t1.c2=t2.c3; #不同数据类型不能re shuffle

#case2.1
#create table t2(c1 int(11) not null, c2 int(11) not null, c3 varchar(32) not null, primary key (c1, c2, c3)) partition by hash(c3) partitions 4; #varchar不允许hash分区
#case2.2 一级key分区
drop table t2;
create table t2(c1 int(11) not null, c2 int(11) not null, c3 varchar(32) not null, primary key (c1, c2, c3)) partition by key(c3) partitions 4; 
explain basic select * from t1,t2 where t1.c2=t2.c3; #不同数据类型不能re shuffle

drop table t1;
drop table t2;

#case3 二级分区
#一级range columns，二级key
create table t2(c1 int(11) not null, c2 int(11) not null, c3 date not null, primary key (c1, c2, c3)) partition by range columns(c1) subpartition by key(c2) subpartitions 3
(
partition p201707 values less than (100),
partition p201808 values less than (200)
);

create table t1(c1 int, c2 int, c3 date not null, primary key(c1));
explain basic select * from t1,t2 where t1.c1=t2.c1;
explain basic select * from t1,t2 where t1.c2=t2.c1;
explain basic select * from t1,t2 where t1.c1=t2.c2;
explain basic select * from t1,t2 where t1.c2=t2.c2;
explain basic select * from t1,t2 where t1.c1=t2.c1 and t1.c2=t2.c2;

drop table t1;
drop table t2;

#case4 二级分区
#4.0一级key 二级range columns
create table t2(c1 int(11) not null, c2 int(11) not null, c3 int(11) not null, primary key (c1, c2, c3)) partition by key(c1) 
subpartition by range columns(c1) subpartition template( subpartition sp_00 values less than (45), subpartition sp_01 values less than (100));

create table t1(c1 int, c2 int, c3 date not null, primary key(c1));
explain basic select * from t1,t2 where t1.c1=t2.c1;
explain basic select * from t1,t2 where t1.c2=t2.c1;
explain basic select * from t1,t2 where t1.c1=t2.c2;
explain basic select * from t1,t2 where t1.c2=t2.c2;
explain basic select * from t1,t2 where t1.c1=t2.c1 and t1.c2=t2.c2;

drop table t1;
drop table t2;

#4.1一级hash 二级range columns
create table t2(c1 int(11) not null, c2 int(11) not null, c3 int(11) not null, primary key (c1, c2, c3)) partition by hash(c1) 
subpartition by range columns(c2) subpartition template( subpartition sp_00 values less than (45), subpartition sp_01 values less than (100));

create table t1(c1 int, c2 int, c3 date not null, primary key(c1));
explain basic select * from t1,t2 where t1.c1=t2.c1;
explain basic select * from t1,t2 where t1.c2=t2.c1;
explain basic select * from t1,t2 where t1.c1=t2.c2;
explain basic select * from t1,t2 where t1.c2=t2.c2;
explain basic select * from t1,t2 where t1.c1=t2.c1 and t1.c2=t2.c2;

drop table t1;
drop table t2;

#case5 看看不同精度的类型是否可以进行分区计算 (能，这里可能有隐患)
create table t2(c1 int(13) not null, c2 int(11) not null, c3 varchar(32) not null, primary key (c1, c2, c3)) partition by range columns(c3)
(
partition p201707 values less than ('2017-07-01 00:00:00'),
partition p201808 values less than ('2018-08-01 00:00:00')
);
create table t1(c1 int, c2 int, c3 varchar(11) not null, primary key(c1));
explain basic select * from t1,t2 where t1.c3=t2.c3;
drop table t1;
drop table t2;

