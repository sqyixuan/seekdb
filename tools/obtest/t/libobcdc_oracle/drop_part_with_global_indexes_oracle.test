##########################
#owner :  qianxi
#owner group: liboblog
#description:
# test: drop_part_with_global_indexes_oracle
#

##########################

ob1=OBI(cluster=1,init_unit_cpu=2);
ob1.reboot;

source include/liboblog/create_oracle_tenant.inc;

# 启动oblog
ob1.oblog.gen_conf tb_white_list=oracle.*.* log_level=DEBUG enable_output_hidden_primary_key=0 enable_block_drop_part_ddl=1 skip_ob_version_compat_check=1;
ob1.oblog.restart;

sleep 30;
# t1
create table t1 (nr number, a clob, b blob);
ob1.oblog.next;

#create table t_range_range (c1 int, c2 int, c3 int, c4 int)
#partition by range(c1)
#subpartition by range(c2)
#(
#  partition rp0 values less than (100)
#  (
#    subpartition rp0sp0 values less than (100),
#    subpartition rp0sp1 values less than (200),
#    subpartition rp0sp2 values less than (300)
#  ),
#  partition rp1 values less than (200)
#  (
#    subpartition rp1sp0 values less than (100),
#    subpartition rp1sp1 values less than (200),
#    subpartition rp1sp2 values less than (300)
#  ),
#  partition rp2 values less than (300)
#  (
#    subpartition rp2sp0 values less than (100),
#    subpartition rp2sp1 values less than (200),
#    subpartition rp2sp2 values less than (300)
#  )
#);

create table t_range_range (c1 int, c2 int, c3 int, c4 int) partition by range(c1) subpartition by range(c2)(partition rp0 values less than (100)(subpartition rp0sp0 values less than (100),subpartition rp0sp1 values less than (200),subpartition rp0sp2 values less than (300)), partition rp1 values less than (200)(subpartition rp1sp0 values less than (100),subpartition rp1sp1 values less than (200),subpartition rp1sp2 values less than (300)), partition rp2 values less than (300)(subpartition rp2sp0 values less than (100),subpartition rp2sp1 values less than (200),subpartition rp2sp2 values less than (300)));
ob1.oblog.next;

create index idx_t_range_range on t_range_range(c1) global;
ob1.oblog.next;

# insert row
insert into t_range_range values(1,2,3,4);
ob1.oblog.next;
insert into t_range_range values(1,100,3,4);
ob1.oblog.next;
insert into t_range_range values(1,200,3,4);
ob1.oblog.next;
insert into t_range_range values(100,2,3,4);
ob1.oblog.next;
insert into t_range_range values(100,100,3,4);
ob1.oblog.next;
insert into t_range_range values(100,200,3,4);
ob1.oblog.next;
insert into t_range_range values(200,2,3,4);
ob1.oblog.next;
insert into t_range_range values(200,100,3,4);
ob1.oblog.next;
insert into t_range_range values(200,200,3,4);
ob1.oblog.next;

########################### truncate subpartition with update global indexes
alter table t_range_range truncate subpartition rp0sp1 update global indexes;
ob1.oblog.next;
insert into t_range_range values(1,100,3,4);
ob1.oblog.next;

alter table t_range_range truncate partition rp0 update global indexes;
ob1.oblog.next;

insert into t_range_range values(1,2,3,4);
ob1.oblog.next;
insert into t_range_range values(1,100,3,4);
ob1.oblog.next;
insert into t_range_range values(1,200,3,4);
ob1.oblog.next;

############################ truncate subpartition without update global indexes
alter table t_range_range truncate subpartition rp1sp1;
ob1.oblog.next;
insert into t_range_range values(100,100,3,4);
ob1.oblog.next;

drop index idx_t_range_range;
ob1.oblog.next;
create index idx_t_range_range on t_range_range(c1) global;
ob1.oblog.next;

alter table t_range_range truncate partition rp1;
ob1.oblog.next;

insert into t_range_range values(100,2,3,4);
ob1.oblog.next;
insert into t_range_range values(100,100,3,4);
ob1.oblog.next;
insert into t_range_range values(100,200,3,4);
ob1.oblog.next;


# stop liboblog
ob1.oblog.stop;
