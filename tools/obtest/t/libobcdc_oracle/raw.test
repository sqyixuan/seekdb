##########################
#owner :  qianxi
#owner group: liboblog
#description:
# 测试点：
# raw
#

##########################

ob1=OBI(cluster=1,init_unit_cpu=2);
ob1.reboot;

source include/liboblog/create_oracle_tenant.inc;

# 启动oblog
ob1.oblog.gen_conf tb_white_list=oracle.*.* log_level=DEBUG skip_ob_version_compat_check=1;
ob1.oblog.restart;

alter session set current_schema = oblog_db;
sleep 1;

# insert, delete, update
create table t1(c1 raw(3) default 'DEFA', c2 int);
ob1.oblog.next;
insert into t1(c2) values(-1);
ob1.oblog.next;
insert into t1(c1, c2) values('A', 0);
ob1.oblog.next;
insert into t1(c1, c2) values('0A', 0);
ob1.oblog.next;
insert into t1(c1, c2) values('AB', 1);
ob1.oblog.next;
insert into t1(c1, c2) values('ABC', 2);
ob1.oblog.next;
insert into t1(c1, c2) values('ABCD', 3);
ob1.oblog.next;
insert into t1(c1, c2) values('1', 0);
ob1.oblog.next;
insert into t1(c1, c2) values('12', 1);
ob1.oblog.next;
insert into t1(c1, c2) values('123', 2);
ob1.oblog.next;
insert into t1(c1, c2) values('1234', 3);
ob1.oblog.next;
insert into t1(c1, c2) values('', 4);
ob1.oblog.next;
insert into t1(c1, c2) values(NULL, 4);
ob1.oblog.next;
select UTL_RAW.cast_to_raw(c1), c2 from t1;
drop table t1;
ob1.oblog.next;

create table t1(c1 raw(2), c2 int);
ob1.oblog.next;
insert into t1(c1, c2) values('ABCD', 1);
ob1.oblog.next;
insert into t1(c1, c2) values('1234', 2);
ob1.oblog.next;
delete from t1 where c1 = 'ABCD';
ob1.oblog.next;
update t1 set c1 = '56' where c1 = '1234';
ob1.oblog.next;
# alter
alter table t1 add c3 raw(3);
ob1.oblog.next;
insert into t1(c1, c2) values('DCBA', 2);
ob1.oblog.next;
alter table t1 modify c3 raw(5) default 'ABC';
ob1.oblog.next;
insert into t1(c1, c2) values('DCBA', 2);
ob1.oblog.next;
select UTL_RAW.cast_to_raw(c1), c2 from t1;
drop table t1;
ob1.oblog.next;

## UTL_RAW.cast_to_raw 转换16进制
create table t1 (c1 int, c2 raw(50), c3 varchar2(50 BYTE), c4 varchar2(50 char));
ob1.oblog.next;
insert into t1 values (1, UTL_RAW.cast_to_raw(1), 1, 1);
ob1.oblog.next;
insert into t1 values (2, UTL_RAW.cast_to_raw(2), 2, 2);
ob1.oblog.next;
insert into t1 values (3, UTL_RAW.cast_to_raw(12), 12, 12);
ob1.oblog.next;
insert into t1 values (4, UTL_RAW.cast_to_raw(12345678901234567890123), 12345678901234567890123, 12345678901234567890123);
ob1.oblog.next;
insert into t1 values (5, UTL_RAW.cast_to_raw(''), '', '');
ob1.oblog.next;
insert into t1 values (6, UTL_RAW.cast_to_raw('a'), 'a', 'a');
ob1.oblog.next;
insert into t1 values (7, UTL_RAW.cast_to_raw('aa'), 'aa', 'aaa');
ob1.oblog.next;
insert into t1 values (8, UTL_RAW.cast_to_raw('aaa'), 'aaa', 'aaa');
ob1.oblog.next;
select c1, c2 from t1;
select c1, UTL_RAW.cast_to_raw(c2) from t1;
drop table t1;
ob1.oblog.next;

drop user oblog_db cascade;
ob1.oblog.next;

# stop liboblog
ob1.oblog.stop;
