##########################
#owner :  qianxi
#owner group: liboblog
#description:
# 测试点：
# number
#
# NUMBER 不指定 precision, scale
#

##########################

ob1=OBI(cluster=1,init_unit_cpu=2);
ob1.reboot;

ob1.mysql alter system set resource_hard_limit= 800;
sleep 2;
ob_connect(conn_sys, ob1.proxy0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);

--disable_warnings
drop tenant if exists oracle;
--disable_warnings
drop resource pool if exists oblog_pool;
--disable_warnings
drop resource unit if exists oblog_box;

###create oracle tenant
ob1.mysql create resource unit oblog_box max_cpu=2, memory_size='10G';
ob1.mysql create resource pool oblog_pool unit = 'oblog_box', unit_num = 1;
ob1.mysql create tenant oracle replica_num = 1, resource_pool_list=('oblog_pool') set ob_tcp_invited_nodes='%', ob_compatibility_mode='oracle';
sleep 2;
ob_connect(conn_oracle, ob1.z1.obs0, SYS@oracle, ,SYS, , USE_OB_CONNECTOR);

create user obtest IDENTIFIED BY "obtest";
grant all on *.* to obtest WITH GRANT OPTION;
grant dba to obtest;
--disable_query_log
create user oblog_db identified by "passwd";
grant dba to oblog_db;
grant dba to ORAAUDITOR;
--enable_query_log
ob_connect(conn_oracle_obtest,ob1.proxy0,OBTEST@oracle,obtest,obtest,,USE_OB_CONNECTOR);
alter session set current_schema = oblog_db;

# 启动oblog
ob1.oblog.gen_conf tb_white_list=oracle.*.* log_level=DEBUG skip_ob_version_compat_check=1;
ob1.oblog.restart;

# number不指定precision的时候，是浮点精度，可以最多存到40位有效数字, 规则如下:
# 1. 整数：如果插入总数奇数个就是39位 偶数个就是40位
# 2. 小数：最多39位
# 2. 遵循四舍五入规则
# 3. 整数超出范围会补全0, 但是不是有效位
create table number_1(c0 int primary key, c1 number);
ob1.oblog.next;
desc number_1;

############ 整数
# 45位 9 * 5组
# 四舍五入-舍
insert into number_1 values(1, 123456789123456789123456789123456789123456789);
select * from number_1 where C0=1;
ob1.oblog.next;

# 负数 四舍五入-舍
insert into number_1 values(2, -123456789123456789123456789123456789123456789);
select * from number_1 where C0=2;
ob1.oblog.next;

# 四舍五入-入
insert into number_1 values(3, 123456789123456789123456789123456789123556789);
select * from number_1 where C0=3;
ob1.oblog.next;

# 负数 四舍五入-入
insert into number_1 values(4, -123456789123456789123456789123456789123556789);
select * from number_1 where C0=4;
ob1.oblog.next;

# 44位
# 四舍五入-入
insert into number_1 values(5, 12345678912345678912345678912345678912345678);
select * from number_1 where C0=5;
ob1.oblog.next;

insert into number_1 values(6, -12345678912345678912345678912345678912345678);
select * from number_1 where C0=6;
ob1.oblog.next;

# 44位
# 四舍五入-舍
insert into number_1 values(7, 12345678912345678912345678912345678912344678);
select * from number_1 where C0=7;
ob1.oblog.next;

insert into number_1 values(8, -12345678912345678912345678912345678912344678);
select * from number_1 where C0=8;
ob1.oblog.next;

############ 带小数点, 负号
insert into number_1 values(9, 1234567.89);
select * from number_1 where C0=9;
ob1.oblog.next;

insert into number_1 values(10, 123456789.123456789);
select * from number_1 where C0=10;
ob1.oblog.next;

# 奇数 45位 9 * 5组
# 四舍五入-舍
insert into number_1 values(11, 123456789.123456789123456789123456789123456789);
select * from number_1 where C0=11;
ob1.oblog.next;

# 负号 四舍五入-舍
insert into number_1 values(12, -123456789.123456789123456789123456789123456789);
select * from number_1 where C0=12;
ob1.oblog.next;

# 四舍五入-入
insert into number_1 values(13, 123456789.123456789123456789123456789123556789);
select * from number_1 where C0=13;
ob1.oblog.next;

# 负号 四舍五入-入
insert into number_1 values(14, -123456789.123456789123456789123456789123556789);
select * from number_1 where C0=14;
ob1.oblog.next;

# 偶数 44位 9 * 4组+ 8
# 四舍五入-入
insert into number_1 values(15, 123456789.12345678912345678912345678912355678);
select * from number_1 where C0=15;
ob1.oblog.next;

# 负号 四舍五入-入
insert into number_1 values(16, -123456789.12345678912345678912345678912355678);
select * from number_1 where C0=16;
ob1.oblog.next;

# 四舍五入-舍
insert into number_1 values(17, 123456789.12345678912345678912345678912344678);
select * from number_1 where C0=17;
ob1.oblog.next;

# 负号 四舍五入-舍
insert into number_1 values(18, -123456789.12345678912345678912345678912344678);
select * from number_1 where C0=18;
ob1.oblog.next;

drop table number_1;
ob1.oblog.next;

#bug for mytest
set @@sql_mode='PIPES_AS_CONCAT,STRICT_ALL_TABLES,PAD_CHAR_TO_FULL_LENGTH';

create table number_1 (c0 number default 12.34, c1 binary_double default 12.34d, c2 binary_float default 12.34f, c3 number default 12.34e0, c4 float(10) default 12.34, c5 float default 12.34e0, c6 varchar2(100 char) default '12.34', c7 char(100 char) default '12.34', constraint number_1_pk primary key(c0));
ob1.oblog.next;

desc number_1;

