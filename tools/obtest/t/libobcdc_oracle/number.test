let $idx=19;
while ($idx < 83)
{
  eval update number_1 set c1=c6, c2=c6, c3=c6, c4=c6, c5=c6, c7=c6 where c0 = $idx;
  eval select c0, c6, c1, c2, c3, c4, c5, c7 from number_1 where c0 = $idx;
  ob1.oblog.next;

  inc $idx;
}

let $idx=119;
while ($idx < 183)
{
  eval update number_1 set c1=c6, c2=c6, c3=c6, c4=c6, c5=c6, c7=c6 where c0 = $idx;
  eval select c0, c6, c1, c2, c3, c4, c5, c7 from number_1 where c0 = $idx;
  ob1.oblog.next;

  inc $idx;
}

select c0, c6, c1, c2, c3, c4, c5, c7 from number_1;

create table TEST(nr number, "abc" number, "ABC" number);
ob1.oblog.next;
