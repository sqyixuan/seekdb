##########################
#owner : linlin.xll
#owner group: sql1
#description:
# 测试点：
#  procedure ddl
#

ob1=OBI(cluster=1,init_unit_cpu=2);
ob1.reboot;

source include/liboblog/create_oracle_tenant.inc;

ob1.oblog.gen_conf tb_white_list=oracle.*.* log_level=DEBUG skip_ob_version_compat_check=1;
ob1.oblog.restart;

## 创建TYPE
CREATE OR REPLACE TYPE ty1 IS TABLE OF INT;
ob1.oblog.next;

CREATE OR REPLACE TYPE ty2 IS TABLE OF VARCHAR2(1000);
ob1.oblog.next;

CREATE OR REPLACE TYPE ty2 IS TABLE OF NUMBER(24);
ob1.oblog.next;

CREATE OR REPLACE TYPE ty2 IS TABLE OF DATE;
ob1.oblog.next;

CREATE OR REPLACE TYPE ty2 IS TABLE OF TIMESTAMP;
ob1.oblog.next;

CREATE OR REPLACE TYPE ty2 IS TABLE OF BLOB;
ob1.oblog.next;

CREATE OR REPLACE TYPE ty2 IS TABLE OF ty1;
ob1.oblog.next;

CREATE OR REPLACE TYPE ty2 IS OBJECT(col1 INT, col2 NUMBER(20), col3 DATE);
ob1.oblog.next;

CREATE OR REPLACE TYPE ty2 IS OBJECT(col1 CLOB);
ob1.oblog.next;

CREATE OR REPLACE TYPE ty3 IS TABLE OF ty2;
ob1.oblog.next;

CREATE OR REPLACE TYPE ty3 IS VARRAY(3) OF INT;
ob1.oblog.next;

## 删除TYPE
DROP TYPE ty3;
ob1.oblog.next;

DROP TYPE ty2;
ob1.oblog.next;

DROP TYPE ty1;
ob1.oblog.next;

# stop liboblog
ob1.oblog.stop;