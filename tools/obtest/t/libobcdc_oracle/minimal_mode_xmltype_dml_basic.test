# update out row lob to in row lob
create table t3(pk int primary key, x xmltype);
ob1.oblog.next;

select calc_md5(construct_clob('<biglob>', 'xxx', 30001, 'x', '</biglob>')) as xml_md5 from dual;
insert into t3 values(3, xmltype(construct_clob('<biglob>', 'xxx', 30001, 'x', '</biglob>')));
ob1.oblog.next;

select calc_md5(TO_CLOB('<a>b</a>')) as xml_md5 from dual;
update t3 set x = '<a>b</a>' where pk=3;
ob1.oblog.next;

delete from t3 where pk = 3;
ob1.oblog.next;

drop table t3;
ob1.oblog.next;


# update in row lob to out row lob
create table t3(pk int primary key, x xmltype);
ob1.oblog.next;

insert into t3 values(3, '<a>b</a>');
ob1.oblog.next;

select calc_md5(construct_clob('<biglob>', 'xxx', 30002, 'x', '</biglob>')) as xml_md5 from dual;
update t3 set x = xmltype(construct_clob('<biglob>', 'xxx', 30002, 'x', '</biglob>')) where pk=3;
ob1.oblog.next;

delete from t3 where pk = 3;
ob1.oblog.next;

drop table t3;
ob1.oblog.next;


# update out row lob to out row lob
create table t3(pk int primary key, x xmltype);
ob1.oblog.next;

select calc_md5(construct_clob('<biglob>', 'xxxx', 30000, 'x', '</biglob>')) as xml_md5 from dual;
insert into t3 values(3, xmltype(construct_clob('<biglob>', 'xxxx', 30000, 'x', '</biglob>')));
ob1.oblog.next;

select calc_md5(construct_clob('<biglob>', 'zzzz', 30000, 'z', '</biglob>')) as xml_md5 from dual;
update t3 set x = xmltype(construct_clob('<biglob>', 'zzzz', 30000, 'z', '</biglob>')) where pk=3;
ob1.oblog.next;

delete from t3 where pk = 3;
ob1.oblog.next;

select calc_md5(construct_clob('<biglob>', 'xxxx', 3000, 'x', '</biglob>')) as xml_md5 from dual;
insert into t3 values(4, xmltype(construct_clob('<biglob>', 'xxxx', 3000, 'x', '</biglob>')));
ob1.oblog.next;

select calc_md5(construct_clob('<biglob>', 'xxxx', 10000, 'x', '</biglob>')) as xml_md5 from dual;
insert into t3 values(5, xmltype(construct_clob('<biglob>', 'xxxx', 10000, 'x', '</biglob>')));
ob1.oblog.next;

# outrow to outrow update, xmltype udt main column not nop
update t3 set x = xmltype(construct_clob('<big>', 'd', 5033160, 'd', '</big>')) where pk=5;
select calc_md5(construct_clob('<big>', 'd', 5033160, 'd', '</big>')) as xml_md5 from dual;
ob1.oblog.next;

drop table t3;
ob1.oblog.next;

create table t2(pk int primary key, x1 xmltype, x2 xmltype);
ob1.oblog.next;

select calc_md5(TO_CLOB('<a>b</a>')) as xml_md5 from dual;
select calc_md5(TO_CLOB('<c>d</c>')) as xml_md5 from dual;
select calc_md5(TO_CLOB('<a>c</a>')) as xml_md5 from dual;
insert into t2 values(1, '<a>b</a>', '<c>d</c>');
ob1.oblog.next;

update t2 set x1='<a>c</a>' where pk=1;
ob1.oblog.next;

drop table t2;
ob1.oblog.next;


create table t2(pk int primary key, x1 xmltype);
ob1.oblog.next;
select calc_md5(TO_CLOB('<a>b</a>')) as xml_md5 from dual;
insert into t2 values(1, '<a>b</a>');
ob1.oblog.next;

update t2 set pk=2 where pk=1;
ob1.oblog.next;

drop table t2;
ob1.oblog.next;


create table t2(pk int primary key, seq int, x1 xmltype, j json);
ob1.oblog.next;
select calc_md5(TO_CLOB('<a>b</a>')) as xml_md5 from dual;
insert into t2 values(1, 1, '<a>b</a>', '{"k" : "v"}');
ob1.oblog.next;

insert into t2 values(2, 2, '<a>b</a>', '{"k" : "v"}');
ob1.oblog.next;

update t2 set seq=2 where pk=1;
ob1.oblog.next;

select calc_md5(construct_clob('<biglob>', 'x', 2097152, 'x', '</biglob>')) as xml_md5 from dual;
select calc_md5(to_clob('<a></a>')) as xml_md5 from dual;
# 2M
insert into t2 values(3, 1, xmltype(construct_clob('<biglob>', 'x', 2097152, 'x', '</biglob>')), '{"k" : "v"}');
ob1.oblog.next;
update t2 set seq=2 where pk=3;
ob1.oblog.next;
update t2 set x1=NULL where pk=3;
ob1.oblog.next;
update t2 set x1='<a/>' where pk=3;
ob1.oblog.next;

drop table t2;
ob1.oblog.next;



# ref libobcdc.lob_dml
create table t1(pk int primary key, tiny_text xmltype, tiny_blob xmltype, text_type xmltype, blob_type xmltype, medium_text xmltype, medium_blob xmltype, long_text xmltype, long_blob xmltype);
ob1.oblog.next;

# NULL
insert into t1 values (1, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL);
ob1.oblog.next;

select calc_md5(to_clob('')) as xml_md5 from dual;
# 空
insert into t1 values (2, '', '', '', '', '', '', '', '');
ob1.oblog.next;

select calc_md5(construct_clob('<abc1>', '1', 243, '1', '</abc1>')) as xml_md5 from dual;
select calc_md5(construct_clob('<xyz1>', '2', 243, '2', '</xyz1>')) as xml_md5 from dual;
select calc_md5(construct_clob('<xyz1>', '3', 65523, '3', '</xyz1>')) as xml_md5 from dual;
select calc_md5(construct_clob('<xyz1>', '4', 65523, '4', '</xyz1>')) as xml_md5 from dual;
select calc_md5(construct_clob('<xyz1>', '5', 16777203, '5', '</xyz1>')) as xml_md5 from dual;
select calc_md5(construct_clob('<xyz1>', '6', 16777203, '6', '</xyz1>')) as xml_md5 from dual;

# 达到单列和单行限制
# 除了longtext和longblob外，其他列达到限制
insert into t1 values (3,
                       xmltype(construct_clob('<abc1>', '1', 243, '1', '</abc1>')),
                       xmltype(construct_clob('<xyz1>', '2', 243, '2', '</xyz1>')),
                       xmltype(construct_clob('<xyz1>', '3', 65523, '3', '</xyz1>')),
                       xmltype(construct_clob('<xyz1>', '4', 65523, '4', '</xyz1>')),
                       xmltype(construct_clob('<xyz1>', '5', 16777203, '5', '</xyz1>')),
                       xmltype(construct_clob('<xyz1>', '6', 16777203, '6', '</xyz1>')),
                       '', '');
ob1.oblog.next;

select calc_md5(construct_clob('<big>', 'a', 50331635, 'a', '</big>')) as xml_md5 from dual;
select calc_md5(construct_clob('<big>', 'b', 11534324, 'b', '</big>')) as xml_md5 from dual;
select calc_md5(construct_clob('<big>', 'c', 11534324, 'c', '</big>')) as xml_md5 from dual;
select calc_md5(construct_clob('<big>', 'd', 50331635, 'd', '</big>')) as xml_md5 from dual;
select calc_md5(construct_clob('<big>', 'e', 11534324, 'e', '</big>')) as xml_md5 from dual;
select calc_md5(construct_clob('<big>', 'f', 16777203, 'f', '</big>')) as xml_md5 from dual;
select calc_md5(construct_clob('<big>', 'g', 16777203, 'g', '</big>')) as xml_md5 from dual;
select calc_md5(construct_clob('<big>', 'h', 16777203, 'h', '</big>')) as xml_md5 from dual;

# longtext达到48M限制 + longblob 11M = 59M
# 注意：不能达到60M，还有其列，总和加起来一定大于了60M
insert into t1 values (4, '', '', '', '', '', '',
                      xmltype(construct_clob('<big>', 'a', 50331635, 'a', '</big>')),
                      xmltype(construct_clob('<big>', 'b', 11534324, 'b', '</big>')));
ob1.oblog.next;

# longtext 11M + longblob 48M = 59M
insert into t1 values (5, '', '', '', '', '', '',
                      xmltype(construct_clob('<big>', 'c', 11534324, 'c', '</big>')),
                      xmltype(construct_clob('<big>', 'd', 50331635, 'd', '</big>')));
ob1.oblog.next;

# longtext 11M + longblob 48M = 59M
# update 把longtext的值与longblob的值交换
update t1 set long_text=xmltype(construct_clob('<big>', 'd', 50331635, 'd', '</big>')), long_blob=xmltype(construct_clob('<big>', 'c', 11534324, 'c', '</big>')) where pk = 5;
ob1.oblog.next;

# update
# medium_text: 11M
# medium_blob: 16M
# long_text: 16M
# long_blob: 16M
update t1 set medium_text=xmltype(construct_clob('<big>', 'e', 11534324, 'e', '</big>')),
              medium_blob=xmltype(construct_clob('<big>', 'f', 16777203, 'f', '</big>')),
              long_text=xmltype(construct_clob('<big>', 'g', 16777203, 'g', '</big>')),
              long_blob=xmltype(construct_clob('<big>', 'h', 16777203, 'h', '</big>'))
          where pk=5;
ob1.oblog.next;

select calc_md5(construct_clob('<nxt>', '1', 2097140, '1', '</nxt>')) as xml_md5 from dual;
select calc_md5(construct_clob('<nxt>', '1', 16372, '1', '</nxt>')) as xml_md5 from dual;
select calc_md5(construct_clob('<nxt>', '3', 8388596, '3', '</nxt>')) as xml_md5 from dual;
select calc_md5(construct_clob('<nxt>', '4', 50331635, '4', '</nxt>')) as xml_md5 from dual;

# 单分区事务多行
begin;
# 小行
insert into t1 values (100, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL);
# 大行 2M
update t1 set long_blob=xmltype(construct_clob('<nxt>', '1', 2097140, '1', '</nxt>')) where pk = 100;

# 小行 16K
insert into t1 (pk, text_type) values (200, xmltype(construct_clob('<nxt>', '1', 16372, '1', '</nxt>')));

# 大行 8M
update t1 set medium_text=xmltype(construct_clob('<nxt>', '3', 8388596, '3', '</nxt>')) where pk = 200;

# 大行 48M + 8M
update t1 set long_text=xmltype(construct_clob('<nxt>', '4', 50331635, '4', '</nxt>')) where pk = 200;
commit;

ob1.oblog.next;

# delete
delete from t1;
ob1.oblog.next;

select calc_md5(construct_clob('<abc2>', '1', 243, '1', '</abc2>')) as xml_md5 from dual;
select calc_md5(construct_clob('<xyz2>', '2', 243, '2', '</xyz2>')) as xml_md5 from dual;
select calc_md5(construct_clob('<xyz2>', '3', 65523, '3', '</xyz2>')) as xml_md5 from dual;
select calc_md5(construct_clob('<xyz2>', '4', 65523, '4', '</xyz2>')) as xml_md5 from dual;
select calc_md5(construct_clob('<xyz2>', '5', 1048564, '5', '</xyz2>')) as xml_md5 from dual;
select calc_md5(construct_clob('<xyz2>', '6', 1048564, '6', '</xyz2>')) as xml_md5 from dual;

# 分布式事务
create table t2(pk int primary key, tiny_text xmltype, tiny_blob xmltype, text_type xmltype, blob_type xmltype, medium_text xmltype, medium_blob xmltype, long_text xmltype, long_blob xmltype);
ob1.oblog.next;

begin;
# 普通行
insert into t1 (pk) values (1);
insert into t2 (pk) values (1);

# 2M LOB行
insert into t1 values (2,
                       xmltype(construct_clob('<abc2>', '1', 243, '1', '</abc2>')),
                       xmltype(construct_clob('<xyz2>', '2', 243, '2', '</xyz2>')),
                       xmltype(construct_clob('<xyz2>', '3', 65523, '3', '</xyz2>')),
                       xmltype(construct_clob('<xyz2>', '4', 65523, '4', '</xyz2>')),
                       xmltype(construct_clob('<xyz2>', '5', 1048564, '5', '</xyz2>')),
                       xmltype(construct_clob('<xyz2>', '6', 1048564, '6', '</xyz2>')),
                      '', '');
insert into t2 values (2,
                       xmltype(construct_clob('<abc2>', '1', 243, '1', '</abc2>')),
                       xmltype(construct_clob('<xyz2>', '2', 243, '2', '</xyz2>')),
                       xmltype(construct_clob('<xyz2>', '3', 65523, '3', '</xyz2>')),
                       xmltype(construct_clob('<xyz2>', '4', 65523, '4', '</xyz2>')),
                       xmltype(construct_clob('<xyz2>', '5', 1048564, '5', '</xyz2>')),
                       xmltype(construct_clob('<xyz2>', '6', 1048564, '6', '</xyz2>')),
                      '', '');

select calc_md5(to_clob('<a>a</a>')) as xml_md5 from dual;
select calc_md5(to_clob('<bb>bb</bb>')) as xml_md5 from dual;
select calc_md5(to_clob('<ccc>ccc</ccc>')) as xml_md5 from dual;
select calc_md5(to_clob('<dddd>dddd</dddd>')) as xml_md5 from dual;
select calc_md5(to_clob('<eeee>eeee</eeee>')) as xml_md5 from dual;
select calc_md5(to_clob('<fffff>fffff</fffff>')) as xml_md5 from dual;
select calc_md5(to_clob('<gggggg>gggggg</gggggg>')) as xml_md5 from dual;
select calc_md5(to_clob('<hhhhhhh>hhhhhhh</hhhhhhh>')) as xml_md5 from dual;

# 普通行
insert into t1 values (3, '<a>a</a>', '<bb>bb</bb>', '<ccc>ccc</ccc>', '<dddd>dddd</dddd>', '<eeee>eeee</eeee>', '<fffff>fffff</fffff>', '<gggggg>gggggg</gggggg>', '<hhhhhhh>hhhhhhh</hhhhhhh>');
insert into t2 values (3, '<a>a</a>', '<bb>bb</bb>', '<ccc>ccc</ccc>', '<dddd>dddd</dddd>', '<eeee>eeee</eeee>', '<fffff>fffff</fffff>', '<gggggg>gggggg</gggggg>', '<hhhhhhh>hhhhhhh</hhhhhhh>');

select calc_md5(construct_clob('<abc3>', '1', 243, '1', '</abc3>')) as xml_md5 from dual;
select calc_md5(construct_clob('<xyz3>', '2', 243, '2', '</xyz3>')) as xml_md5 from dual;
select calc_md5(construct_clob('<xyz3>', '3', 65523, '3', '</xyz3>')) as xml_md5 from dual;
select calc_md5(construct_clob('<xyz3>', '4', 65523, '4', '</xyz3>')) as xml_md5 from dual;
select calc_md5(construct_clob('<xyz3>', '5', 1048564, '5', '</xyz3>')) as xml_md5 from dual;
select calc_md5(construct_clob('<xyz3>', '6', 1048564, '6', '</xyz3>')) as xml_md5 from dual;
select calc_md5(construct_clob('<xyz3>', '7', 6291444, '7', '</xyz3>')) as xml_md5 from dual;
select calc_md5(construct_clob('<xyz3>', '8', 6291444, '8', '</xyz3>')) as xml_md5 from dual;

# 16 M LOB行
insert into t1 values (4,
                       xmltype(construct_clob('<abc3>', '1', 243, '1', '</abc3>')),
                       xmltype(construct_clob('<xyz3>', '2', 243, '2', '</xyz3>')),
                       xmltype(construct_clob('<xyz3>', '3', 65523, '3', '</xyz3>')),
                       xmltype(construct_clob('<xyz3>', '4', 65523, '4', '</xyz3>')),
                       xmltype(construct_clob('<xyz3>', '5', 1048564, '5', '</xyz3>')),
                       xmltype(construct_clob('<xyz3>', '6', 1048564, '6', '</xyz3>')),
                       xmltype(construct_clob('<xyz3>', '7', 6291444, '7', '</xyz3>')),
                       xmltype(construct_clob('<xyz3>', '8', 6291444, '8', '</xyz3>')));
insert into t2 values (4,
                       xmltype(construct_clob('<abc3>', '1', 243, '1', '</abc3>')),
                       xmltype(construct_clob('<xyz3>', '2', 243, '2', '</xyz3>')),
                       xmltype(construct_clob('<xyz3>', '3', 65523, '3', '</xyz3>')),
                       xmltype(construct_clob('<xyz3>', '4', 65523, '4', '</xyz3>')),
                       xmltype(construct_clob('<xyz3>', '5', 1048564, '5', '</xyz3>')),
                       xmltype(construct_clob('<xyz3>', '6', 1048564, '6', '</xyz3>')),
                       xmltype(construct_clob('<xyz3>', '7', 6291444, '7', '</xyz3>')),
                       xmltype(construct_clob('<xyz3>', '8', 6291444, '8', '</xyz3>')));


select calc_md5(construct_clob('<abc4>', '1', 243, '1', '</abc4>')) as xml_md5 from dual;
select calc_md5(construct_clob('<xyz4>', '2', 243, '2', '</xyz4>')) as xml_md5 from dual;
select calc_md5(construct_clob('<xyz4>', '3', 65523, '3', '</xyz4>')) as xml_md5 from dual;
select calc_md5(construct_clob('<xyz4>', '4', 65523, '4', '</xyz4>')) as xml_md5 from dual;
select calc_md5(construct_clob('<xyz4>', '5', 16777203, '5', '</xyz4>')) as xml_md5 from dual;
select calc_md5(construct_clob('<xyz4>', '6', 16777203, '6', '</xyz4>')) as xml_md5 from dual;
select calc_md5(construct_clob('<xyz4>', '7', 13631476, '7', '</xyz4>')) as xml_md5 from dual;
select calc_md5(construct_clob('<xyz4>', '8', 13631476, '8', '</xyz4>')) as xml_md5 from dual;


# 60 M LOB行
insert into t1 values (5,
                       xmltype(construct_clob('<abc4>', '1', 243, '1', '</abc4>')),
                       xmltype(construct_clob('<xyz4>', '2', 243, '2', '</xyz4>')),
                       xmltype(construct_clob('<xyz4>', '3', 65523, '3', '</xyz4>')),
                       xmltype(construct_clob('<xyz4>', '4', 65523, '4', '</xyz4>')),
                       xmltype(construct_clob('<xyz4>', '5', 16777203, '5', '</xyz4>')),
                       xmltype(construct_clob('<xyz4>', '6', 16777203, '6', '</xyz4>')),
                       xmltype(construct_clob('<xyz4>', '7', 13631476, '7', '</xyz4>')),
                       xmltype(construct_clob('<xyz4>', '8', 13631476, '8', '</xyz4>')));
insert into t2 values (5,
                       xmltype(construct_clob('<abc4>', '1', 243, '1', '</abc4>')),
                       xmltype(construct_clob('<xyz4>', '2', 243, '2', '</xyz4>')),
                       xmltype(construct_clob('<xyz4>', '3', 65523, '3', '</xyz4>')),
                       xmltype(construct_clob('<xyz4>', '4', 65523, '4', '</xyz4>')),
                       xmltype(construct_clob('<xyz4>', '5', 16777203, '5', '</xyz4>')),
                       xmltype(construct_clob('<xyz4>', '6', 16777203, '6', '</xyz4>')),
                       xmltype(construct_clob('<xyz4>', '7', 13631476, '7', '</xyz4>')),
                       xmltype(construct_clob('<xyz4>', '8', 13631476, '8', '</xyz4>')));
commit;

ob1.oblog.next;

select calc_md5(to_clob('<data>clear longblob</data>')) as xml_md5 from dual;
select calc_md5(to_clob('<data>clear mediumblob</data>')) as xml_md5 from dual;

begin;
update t1 set long_blob='<data>clear longblob</data>';
update t2 set medium_blob='<data>clear mediumblob</data>';
update t2 set medium_blob='<data>clear mediumblob</data>';

# 更新主键
update t1 set pk = 6 where pk = 5;
commit;

ob1.oblog.next;

begin;
delete from t1 where pk = 1;
delete from t1 where pk = 4;
delete from t1 where pk = 3;
delete from t2 where pk = 2;
delete from t2 where pk = 5;
commit;

ob1.oblog.next;


ob1.oblog.stop;

#ob1.force_stop;
