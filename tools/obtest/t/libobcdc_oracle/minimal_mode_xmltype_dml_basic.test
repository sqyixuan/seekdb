#
# owner: zhichen
# owner group: shenzhen
# description:
#  xmltype test
##

ob1=OBI(cluster=1);
ob1.reboot;
ob1.create_client;

source include/liboblog/create_oracle_tenant.inc;

connection conn_sys;
alter tenant oracle set variables max_allowed_packet=1073741824;

sleep 2;
# 在oblog_tt租户下操作
connection conn_oracle_obtest;
set global max_allowed_packet=1073741824;
connection conn_oracle_obtest;
# 切换为minimal模式
set binlog_row_image='MINIMAL';
show variables like 'binlog_row_image';

ob1.oblog.set_extra_argument -m;
ob1.oblog.gen_conf tb_white_list=oracle.*.*  test_mode_on=1 test_mode_ignore_redo_count=10 sort_trans_participants=1 skip_ob_version_compat_check=1;
ob1.oblog.restart;

#sleep 10;

CREATE OR REPLACE FUNCTION construct_clob(start_str IN VARCHAR2, padding_1 IN VARCHAR2, pad_length IN INTEGER, padding_2 IN VARCHAR2, end_str IN VARCHAR2) RETURN CLOB IS BEGIN  RETURN (to_clob(start_str) || RPAD(to_clob(padding_1), pad_length, padding_2) || end_str); END;
ob1.oblog.next;
CREATE OR REPLACE FUNCTION calc_md5(input_data IN CLOB) RETURN VARCHAR2 IS BEGIN  RETURN LOWER(RAWTOHEX(DBMS_CRYPTO.HASH(input_data, DBMS_CRYPTO.HASH_MD5))); END;
ob1.oblog.next;

# simple case

create table simple_xml_test(pk int primary key, x xmltype);
ob1.oblog.next;

select calc_md5(TO_CLOB('<data>first</data>')) as xml_md5 from dual;
select calc_md5(TO_CLOB('<data>second</data>')) as xml_md5 from dual;

insert into simple_xml_test values(1, '<data>first</data>');
ob1.oblog.next;
insert into simple_xml_test values(2, NULL);
ob1.oblog.next;

update simple_xml_test set x = '<data>second</data>' where pk = 1;
ob1.oblog.next;

delete from simple_xml_test where pk=1;
ob1.oblog.next;

drop table simple_xml_test;
ob1.oblog.next;

create table t1(pk int primary key, x xmltype, j json);
ob1.oblog.next;

select calc_md5(TO_CLOB('<a>b</a>')) as xml_md5 from dual;
insert into t1 values(1, '<a>b</a>','{"k":"v"}');
ob1.oblog.next;
drop table t1;
ob1.oblog.next;


# alter table

create table xml_alter_test(pk int primary key, label varchar2(100));
ob1.oblog.next;

insert into xml_alter_test values(1, 'label1');
ob1.oblog.next;

alter table xml_alter_test add x xmltype;
ob1.oblog.next;

update xml_alter_test set label = 'label1.1' where pk = 1;
ob1.oblog.next;

update xml_alter_test set x = '<data>first</data>' where pk = 1;
ob1.oblog.next;

insert into xml_alter_test values(2, 'label2', '<data>first</data>');
ob1.oblog.next;

update xml_alter_test set x = '<data>second</data>' where pk = 2;
ob1.oblog.next;

update xml_alter_test set label = 'label2.1' where pk = 2;
ob1.oblog.next;

delete from xml_alter_test where pk=1;
ob1.oblog.next;

delete from xml_alter_test where pk=2;
ob1.oblog.next;

drop table xml_alter_test;
ob1.oblog.next;

create table xml_alter_test(pk int primary key, label varchar2(100), x xmltype);
ob1.oblog.next;

insert into xml_alter_test values(1, 'label1', '<data>first</data>');
ob1.oblog.next;
insert into xml_alter_test values(2, NULL, NULL);
ob1.oblog.next;

update xml_alter_test set x = '<data>second</data>' where pk = 1;
ob1.oblog.next;

alter table xml_alter_test drop column x;
ob1.oblog.next;

drop table xml_alter_test;
ob1.oblog.next;

# pk in middle postion

create table mid_pk_test(x xmltype, pk int primary key, other varchar2(100));
ob1.oblog.next;

select calc_md5(TO_CLOB('<data>1one</data>')) as xml_md5 from dual;
select calc_md5(TO_CLOB('<data>2two</data>')) as xml_md5 from dual;
select calc_md5(TO_CLOB('<data>null</data>')) as xml_md5 from dual;

insert into mid_pk_test values('<data>1one</data>', 1, 'other data');
ob1.oblog.next;
insert into mid_pk_test values('<data>2two</data>', 2, 'other data');
ob1.oblog.next;
update mid_pk_test set x = '<data>null</data>' where pk=2;
ob1.oblog.next;

drop table mid_pk_test;
ob1.oblog.next;

create table t2(pk int primary key, j json);
ob1.oblog.next;
insert into t2 values(1, '{"k":"v"}');
ob1.oblog.next;
alter table t2 add x xmltype;
select calc_md5(TO_CLOB('<a>b</a>')) as xml_md5 from dual;
ob1.oblog.next;
insert into t2 values(2, '{"k":"v"}', '<a>b</a>');
ob1.oblog.next;
update t2 set x = '<a>b</a>' where pk = 1;
ob1.oblog.next;

delete from t2 where pk = 1;
ob1.oblog.next;
delete from t2 where pk = 2;
ob1.oblog.next;

drop table t2;
ob1.oblog.next;

# mix column
create table xml_mix_test(x1 xmltype, pk int primary key, label varchar2(100), x xmltype, b blob, j json, c clob, seq number(20), t timestamp);
ob1.oblog.next;

insert into xml_mix_test values(NULL, 1, NULL, NULL, NULL, NULL, NULL, NULL, NULL);
ob1.oblog.next;

select calc_md5(TO_CLOB('<data1>first</data1>')) as xml_md5 from dual;
select calc_md5(TO_CLOB('<data4>four</data4>')) as xml_md5 from dual;
insert into xml_mix_test values('<data1>first</data1>', 2, 'lable3', '<data4>four</data4>', rawtohex('blob5'), '{"k6":"v6"}', 'clob7', 8, '2023-09-09');
ob1.oblog.next;

update xml_mix_test set x = '<data>second</data>' where pk = 1;
ob1.oblog.next;

drop table xml_mix_test;
ob1.oblog.next;

# virtual generated column
create table t_vr(pk int primary key, x xmltype, j json, c1 int, c2 int, c3 int generated always as(c1+c2));
ob1.oblog.next;
select calc_md5(TO_CLOB('<a>1</a>')) as xml_md5 from dual;
insert into t_vr(pk, x, j, c1, c2) values(1, '<a>1</a>', '{"a":1}', 1, 1);
ob1.oblog.next;
update t_vr set c1 = 2 where pk=1;
ob1.oblog.next;
drop table t_vr;
ob1.oblog.next;

