#
# owner: fankun.fan
# owner group: libobcdc
# description:
##

ob1=OBI(cluster=1,init_unit_cpu=5);
ob1.reboot;
ob1.create_client;

# 创建oracle租户，并切换到oracle租户
source include/liboblog/create_oracle_tenant.inc;

# 启动liboblog，同步oracle租户数据
ob1.oblog.gen_conf tb_white_list=oracle.*.white* tb_black_list=oracle.*.black* log_level=DEBUG skip_ob_version_compat_check=1;
ob1.oblog.restart;

let $ddl_stmt_count = 0;
let $dml_stmt_count = 0;

# sys-mysql租户获取当前时间
ob_connect(conn_sys, ob1.proxy0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);
let $restart_ts_usec = query_get_value(select time_to_usec(now(6)) as now, now, 1);
ob_connect(conn_oracle_obtest,ob1.z1.obs0,OBTEST@oracle,obtest,obtest,,USE_OB_CONNECTOR);

alter session set current_schema = oblog_db;
sleep 1;

create table "white1"(c1 int);
ob1.oblog.next;
inc $ddl_stmt_count;

create table white1(c1 int);
ob1.oblog.next;
inc $ddl_stmt_count;

insert into "white1" values(1);
ob1.oblog.next;

insert into white1 values(1);
ob1.oblog.next;
inc $dml_stmt_count;

ob1.oblog.gen_conf tb_white_list=oracle.*.WHITE* tb_black_list=oracle.*.BLACK* log_level=DEBUG skip_ob_version_compat_check=1 enable_oracle_mode_match_case_sensitive=1;
ob1.oblog.set_start_tstamp_usec $restart_ts_usec;
ob1.oblog.restart;

let $idx = 0;
while ($idx < $ddl_stmt_count)
{
    ob1.oblog.next;
    inc $idx;
}

let $idx = 0;
while ($idx < $dml_stmt_count)
{
    ob1.oblog.next;
    inc $idx;
}

ob1.oblog.gen_conf tb_white_list=oracle.*.WHITE* tb_black_list=oracle.*.BLACK* log_level=DEBUG skip_ob_version_compat_check=1 meta_data_refresh_mode=data_dict enable_oracle_mode_match_case_sensitive=1;
ob1.oblog.set_start_tstamp_usec $restart_ts_usec;
ob1.oblog.restart;

let $idx = 0;
while ($idx < $ddl_stmt_count)
{
    ob1.oblog.next;
    inc $idx;
}

let $idx = 0;
while ($idx < $dml_stmt_count)
{
    ob1.oblog.next;
    inc $idx;
}

ob1.oblog.gen_conf tb_white_list=oracle.*.WHITE* tb_black_list=oracle.*.BLACK* log_level=DEBUG skip_ob_version_compat_check=1 meta_data_refresh_mode=data_dict enable_oracle_mode_match_case_sensitive=1;
ob1.oblog.set_start_tstamp_usec $restart_ts_usec;
ob1.oblog.restart;
ob1.oblog.stop;

ob1.oblog.gen_conf tb_white_list=oracle.*.WHITE* tb_black_list=oracle.*.BLACK* log_level=DEBUG skip_ob_version_compat_check=1 enable_oracle_mode_match_case_sensitive=1;
ob1.oblog.set_start_tstamp_usec $restart_ts_usec;
ob1.oblog.restart;
ob1.oblog.stop;
