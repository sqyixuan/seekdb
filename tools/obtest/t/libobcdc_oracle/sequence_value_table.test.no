ob1=OBI(cluster=1,init_unit_cpu=2);
ob1.reboot;

### Formatter采用精准schema格式化
## 对于__all_sequence_value的, 其table_version=904, 这样刷新schema，会认为所属租户已经删除，从而过滤了数据
## __all_sequence_value本身是备份的需求，先注释：
## 后续如果有需求，支持方案：
## 1. 对于租户系统表，用sys租户来刷新对应的table schema
## 2. 或者结合租户基准schema version来刷新 max(table_version, tenant_start_schema_version)

source include/liboblog/create_oracle_tenant.inc;
## 验证以已存在租户启动，输出内部表__all_sequence_value
# 启动oblog
ob1.oblog.gen_conf tb_white_list=oracle.*.t1 enable_backup_mode=1 log_level=DEBUG skip_ob_version_compat_check=1;
ob1.oblog.restart;
sleep 1;

connection conn_sys;
alter system change tenant oracle;
insert into __all_sequence_value values ('2019-09-27 14:43:48.944146', '2019-09-27 14:43:48.944146', 1, 100);
ob1.oblog.next_dml;

update __all_sequence_value set next_value = 120, gmt_modified = '2019-09-28 14:43:48.944146' where sequence_id = 1;
ob1.oblog.next_dml;

delete from __all_sequence_value where sequence_id = 1;
ob1.oblog.next_dml;

connection conn_oracle;
create table t1 (pk int primary key, c1 int);
insert into t1 values(1009, 1008);
ob1.oblog.next_dml;

# 清理租户
connection conn_sys;
alter system change tenant sys;
drop tenant oracle force;

ob1.oblog.stop;
ob1.oblog.check_log "[ADD_TABLE] TENANT=oracle(1003) TABLE=oracle.oceanbase.__all_sequence_value";
ob1.oblog.check_log "[OFFLINE_PART] switch offline state success(pkey={tid:1102810162659543";

ob1.oblog.gen_conf tb_white_list=oracle.*.t1 enable_backup_mode=1 log_level=DEBUG skip_ob_version_compat_check=1;
ob1.oblog.restart;

## 验证liboblog启动之后，新增租户输出内部表__all_sequence_value
ob1.mysql create tenant oracle replica_num = 1, resource_pool_list=('oblog_pool') set ob_tcp_invited_nodes='%', ob_compatibility_mode='oracle';
ob_connect(conn_oracle, ob1.z1.obs0, SYS@oracle, ,SYS, , USE_OB_CONNECTOR);
create user obtest IDENTIFIED BY "obtest";
grant all on *.* to obtest WITH GRANT OPTION;
ob_connect(conn_oracle_obtest,ob1.z1.obs0,OBTEST@oracle,obtest,obtest,,USE_OB_CONNECTOR);

connection conn_sys;
alter system change tenant oracle;
# 支持ob升级租户拆分和liboblog启动之后创建租户
insert into __all_sequence_value values('2019-09-28 14:43:48.944146', '2019-09-28 14:43:48.944146', 1, 10);
ob1.oblog.next_dml;

update __all_sequence_value set next_value = 120, gmt_modified = '2019-09-29 14:43:48.944146' where sequence_id = 1;
ob1.oblog.next_dml;

delete from __all_sequence_value where sequence_id = 1;
ob1.oblog.next_dml;

connection conn_oracle;
create table t1 (pk int primary key, c1 int);
insert into t1 values(1009, 1008);
ob1.oblog.next_dml;

ob1.oblog.stop;
ob1.oblog.check_log "[ADD_TABLE] TENANT=oracle(1004) TABLE=oracle.oceanbase.__all_sequence_value";
