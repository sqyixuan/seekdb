##########################
#owner :  xinqi.zlm
#owner group: liboblog
#description:
# 测试点：dcl
#  grant sys priv
#  grant role
#  grant obj priv
#  revoke sys priv
#  revoke role
#  revoke obj priv
#  create role
#  alter role

##########################

ob1=OBI(cluster=1,init_unit_cpu=2);
#ob1.z1.obs0.set extra_config=devname=eth0;

ob1.reboot;

ob1.mysql alter system set resource_hard_limit= 800;
sleep 2;
ob_connect(conn_sys, ob1.proxy0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);


# 创建oracle租户，并切换到oracle租户
source include/liboblog/create_oracle_tenant.inc;

# 启动oblog
ob1.oblog.gen_conf tb_white_list=oracle.*.* log_level=DEBUG skip_ob_version_compat_check=1;
ob1.oblog.restart;

# 创建user1
create user dcl_u1 identified by dcl_u1;
# 输出创建user DDL
ob1.oblog.next;

# 创建user2
create user dcl_u2 identified by dcl_u2;
# 输出创建user DDL
ob1.oblog.next;

# 创建role r1
create role r1;
# 输出创建role DDL
ob1.oblog.next;

# 创建role r3
create role r3;
# 输出创建role DDL
ob1.oblog.next;

# 创建role r4
create role r4;
# 输出创建role DDL
ob1.oblog.next;

# 创建t1
create table t1 (nr number);
# 输出DDL
ob1.oblog.next;

# 执行grant syspriv 语句
grant create session , create any table to dcl_u1;
# 输出grant语句事务
ob1.oblog.next;

# 执行grant role to user语句
grant r1 to dcl_u1;
# 输出grant role to user语句
ob1.oblog.next;

# 执行grant obj priv语句
grant select ,delete on t1 to dcl_u1;
# 输出grant obj priv语句
ob1.oblog.next;

# 执行grant role, sys_priv to user 语句
grant r3, r4, select any table, create any view to dcl_u1;
# 输出grant role, sys_priv语句
ob1.oblog.next;

# 执行revoke sys priv from user
revoke create any table from dcl_u1;
# 输出revoke sys priv语句
ob1.oblog.next;

# 执行revoke sys priv from user
revoke create session from dcl_u1;
# 输出revoke sys priv语句
ob1.oblog.next;

# 执行revoke role from user
revoke r1 from dcl_u1;
# 执行revoke role from user
ob1.oblog.next;

# 执行revoke obj priv from user
revoke select on t1 from dcl_u1;
# 输出revoke sys priv语句
ob1.oblog.next;

# 执行revoke obj priv from user
revoke delete on t1 from dcl_u1;
# 输出revoke sys priv语句
ob1.oblog.next;

# 执行revoke role, sys_priv from user
revoke select any table, r4, create any view, r3 from dcl_u1;
# 输出revoke role, sys_priv语句
ob1.oblog.next;

grant select , insert on t1 to dcl_u1, dcl_u2;
ob1.oblog.next;
ob1.oblog.next;

revoke select, insert on t1 from dcl_u1, dcl_u2;
ob1.oblog.next;
ob1.oblog.next;

insert into t1 values(2);
ob1.oblog.next;

--echo # 创建 r2
create role r2 identified by 123;
--echo # 输出DDL
ob1.oblog.next;

--echo # 修改 r2 密码
alter role r2 identified by 456;
--echo # 输出DDL
ob1.oblog.next;
--echo # 修改 r2 密码为空
alter role r2 not identified;
--echo # 输出DDL
ob1.oblog.next;

--echo # 删除 r2
drop role r2;
--echo # 输出DDL
ob1.oblog.next;

--echo # 删除 r3
drop role r3;
--echo # 输出DDL
ob1.oblog.next;

--echo # 删除 r4
drop role r4;
--echo # 输出DDL
ob1.oblog.next;

# 删除表
drop table t1;
# 输出DDL
ob1.oblog.next;

# 删除r1
drop role r1;
# 输出DDL
ob1.oblog.next;

# 删除user
drop user dcl_u1 cascade;
# 输出DDL
ob1.oblog.next;

# 删除user
drop user dcl_u2 cascade;
# 输出DDL
ob1.oblog.next;

# stop liboblog
ob1.oblog.stop;