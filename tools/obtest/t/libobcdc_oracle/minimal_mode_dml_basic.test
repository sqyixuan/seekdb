# owner: debin.jdb
# owner group: clog
# description:
# 测试点: 测试minimal模式下各类table执行dml产生clog内容是否符合预期.
# 1. 1.1 无主键表, 无唯一键, update要记全列
#    1.2 无主键表, 有唯一键(允许为空), update需要记全列
#    1.3 无主键表, 有非空唯一键, update不需要记全列
# 2. 2.1 主键表, 无唯一键
#    2.2 主键表, 有唯一键
# 3. table包含时间列场景：date/datetime/time/timestamp.
#

ob1=OBI(cluster=1);
ob1.reboot;
ob1.create_client;

source include/liboblog/create_oracle_tenant.inc;

# 启动liboblog
# 1. 要求liboblog输出LOB数据时输出MD5值
# 2. 打开test_mode，忽略前10条redo日志，校验MISSING LOG处理逻辑
# 3. 排序参与者列表
ob1.oblog.set_extra_argument -m;
ob1.oblog.gen_conf tb_white_list=oracle.*.*  test_mode_on=1 test_mode_ignore_redo_count=10 sort_trans_participants=1 skip_ob_version_compat_check=1;
ob1.oblog.restart;

# 准备环境
#let $ip=deploy_get_value(ob1.proxy0.ip);
#let $port=deploy_get_value(ob1.proxy0.port);
#connect (oblog_conn_sys,$ip,admin@sys,admin,oceanbase,$port);

# sys租户下操作
#connection oblog_conn_sys;

# 设置最大包大小 1G
set global max_allowed_packet=1073741824;
ob1.oblog.next;

# 重新建立连接
# 让包大小设置生效
#connect (oblog_conn_sys,$ip,admin@sys,admin,oceanbase,$port);

connection conn_oracle_obtest;
# 设置事务超时时间: 100秒
set ob_trx_timeout=100000000;
set ob_query_timeout=100000000;

# 切换为minimal模式
set binlog_row_image='MINIMAL';
show variables like 'binlog_row_image';

# 1.1 创建表t1, 不带uk, old_row预期需要记全列
create table t1(id int, c1 timestamp(6), c2 date, c3 int, c4 varchar(64 char), c5 int);
# 输出create table DDL
ob1.oblog.next;
# 执行AC=1的insert
insert into t1 values(1, '2023-10-13 12:10:08.123456', '2023-10-30 12:00:00', 1, 't1', 111);
# 输出上述事务
ob1.oblog.next;
# 执行update
update t1 set id=2 where id=1;
ob1.oblog.next;
# 执行update
update t1 set c1='2023-10-13 12:10:58.678' where id=2;
ob1.oblog.next;
update t1 set c2='2023-11-13 12:10:58' where id=2;
ob1.oblog.next;
update t1 set c3=13 where id=2;
ob1.oblog.next;
update t1 set c4='t14' where id=2;
ob1.oblog.next;
update t1 set c5=15 where id=2;
ob1.oblog.next;
delete from t1 where id=2;
ob1.oblog.next;

# 1.2 创建表t2, 带uk(允许为空), old_row需要记全列
create table t2(id int, c1 timestamp(6), c2 date, c3 int, c4 varchar(64 char), c5 int, CONSTRAINT u2 UNIQUE(c3, c5));
# 输出create table DDL
ob1.oblog.next;
# 执行AC=1的insert
insert into t2 values(1, '2023-10-13 12:10:08.123456', '2023-10-30 12:00:00', 1, 't2', 111);
# 输出上述事务
ob1.oblog.next;
# 执行update
update t2 set id=2 where id=1;
ob1.oblog.next;
# 执行update
update t2 set c1='2023-10-13 12:10:58.678' where id=2;
ob1.oblog.next;
update t2 set c2='2023-11-13 12:10:58' where id=2;
ob1.oblog.next;
update t2 set c3=23 where id=2;
ob1.oblog.next;
update t2 set c4='t24' where id=2;
ob1.oblog.next;
update t2 set c5=25 where id=2;
ob1.oblog.next;
delete from t2 where id=2;
ob1.oblog.next;

# 1.3 创建表t3, 带uk(不允许为空), old_row预期不需要记全列
create table t3(id int, c1 timestamp(6), c2 date, c3 int NOT NULL, c4 varchar(64 char), c5 int NOT NULL, c6 int, CONSTRAINT u3 UNIQUE(c3, c5), CONSTRAINT u36 UNIQUE(c6));
# 输出create table DDL
ob1.oblog.next;
# 执行AC=1的insert
insert into t3 values(1, '2023-10-13 12:10:08.123456', '2023-10-30 12:00:00', 1, 't3', 111, 666);
# 输出上述事务
ob1.oblog.next;
# 执行update
update t3 set id=2 where id=1;
ob1.oblog.next;
# 执行update
update t3 set c1='2023-10-13 12:10:58.678' where id=2;
ob1.oblog.next;
update t3 set c2='2023-11-13 12:10:58' where id=2;
ob1.oblog.next;
update t3 set c3=33 where id=2;
ob1.oblog.next;
update t3 set c4='t34' where id=2;
ob1.oblog.next;
update t3 set c5=35 where id=2;
ob1.oblog.next;
delete from t3 where id=2;
ob1.oblog.next;

# 2.1 创建主键表t4, 不带uk
create table t4(id int PRIMARY KEY, c1 timestamp(6), c2 date, c3 int, c4 varchar(64 char), c5 int NOT NULL, c6 varchar(128 char), c7 int);
ob1.oblog.next;
# 执行AC=1的insert
insert into t4 values(1, '2023-10-13 12:10:08.123456', '2023-10-30 12:00:00', 3, 't4c4', 5, 't4c6', 7);
# 输出上述事务
ob1.oblog.next;
# 执行update
update t4 set c1='2023-10-13 12:10:58.678' where id=1;
ob1.oblog.next;
update t4 set c2='2023-11-13 12:10:58' where id=1;
ob1.oblog.next;
update t4 set c3=43 where id=1;
ob1.oblog.next;
update t4 set c4='t4c44' where id=1;
ob1.oblog.next;
update t4 set c5=45 where id=1;
ob1.oblog.next;
update t4 set c6='t4c66' where id=1;
ob1.oblog.next;
update t4 set c7=47 where id=1;
ob1.oblog.next;
update t4 set id=2 where id=1;
ob1.oblog.next;
delete from t4 where id=2;
ob1.oblog.next;

# 2.2 创建主键表t5, 无非空uk
create table t5(id int PRIMARY KEY, c1 timestamp(6), c2 date, c3 int NOT NULL, c4 varchar(64 char), c5 int, c6 varchar(128 char), c7 int, CONSTRAINT u5 UNIQUE(c5, c7));
ob1.oblog.next;
# 执行AC=1的insert
insert into t5 values(1, '2023-10-13 12:10:08.123456', '2023-10-30 12:00:00', 3, 't4c4', 5, 't4c6', 7);
# 输出上述事务
ob1.oblog.next;
# 执行update
update t5 set c1='2023-10-13 12:10:58.678' where id=1;
ob1.oblog.next;
update t5 set c2='2023-11-13 12:10:58' where id=1;
ob1.oblog.next;
update t5 set c3=43 where id=1;
ob1.oblog.next;
update t5 set c4='t4c44' where id=1;
ob1.oblog.next;
update t5 set c5=45 where id=1;
ob1.oblog.next;
update t5 set c6='t4c66' where id=1;
ob1.oblog.next;
update t5 set c7=47 where id=1;
ob1.oblog.next;
# If it returned -4377, we can use debug.
# update /*+log_level(debug)*/ t5 set id=2 where id=1;
update t5 set id=2 where id=1;
ob1.oblog.next;
delete from t5 where id=2;
ob1.oblog.next;


# 执行drop table DDL
drop table t1;
ob1.oblog.next;

# 执行drop table DDL
drop table t2;
ob1.oblog.next;

# 执行drop table DDL
drop table t3;
ob1.oblog.next;

# 执行drop table DDL
drop table t4;
ob1.oblog.next;

# 执行drop table DDL
drop table t5;
ob1.oblog.next;

ob1.oblog.stop;
