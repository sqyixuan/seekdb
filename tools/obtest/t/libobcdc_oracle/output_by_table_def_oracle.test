# owner: wenyue.zxl
# owner group: libobcdc
# test point: test output by table defination in oracle mode

ob1=OBI(cluster=1:1:1, init_unit_cpu=5);
ob1.reboot;

source include/liboblog/create_oracle_tenant.inc;

let $dml_cnt=0;

echo "#################### [CASE_BEGIN] Mixed Scenario in Oracle Mode ####################";
connection conn_sys;
let $start_timestamp_usec = query_get_value(select time_to_usec(now(6)) as now, now, 1);

connection conn_oracle_obtest;
ob1.oblog.gen_conf tb_white_list=oracle.*.* enable_output_by_table_def=1 enable_output_hidden_primary_key=1 enable_output_invisible_column=1 log_level=DEBUG skip_ob_version_compat_check=1;
ob1.oblog.restart;

create table t1(id int not null, c1 clob, primary key (id));

# id c1

insert into t1(id, c1) values (1, 'aaaaa');
inc $dml_cnt;
ob1.oblog.next_dml;

alter table t1 add c2 varchar(64) default 'abcdefgABCDEFG1234567!@#$%^&';

# id c1 c2

insert into t1(id, c1) values (2, 'abcdefg');
inc $dml_cnt;
ob1.oblog.next_dml;

alter table t1 add c3 varchar(128) generated always as (concat('key', c2)) virtual;

# id c1 c2 (c3)

insert into t1(id, c1) values (3, 'hijklmn');
inc $dml_cnt;
ob1.oblog.next_dml;

alter table t1 modify id invisible;

# c1 c2 (c3) id

insert into t1(id, c1) values (4, 'opqrstu');
inc $dml_cnt;
ob1.oblog.next_dml;

update t1 set c1='bbbbb' where id=1;
inc $dml_cnt;
ob1.oblog.next_dml;

delete from t1 where id=1;
inc $dml_cnt;
ob1.oblog.next_dml;

alter table t1 add c4 varchar(256) generated always as (concat(c2, c2)) virtual;

# c1 c2 (c3) id (c4)

insert into t1(id, c1, c2) values (5,'qwerty', 'asdfgh');
inc $dml_cnt;
ob1.oblog.next_dml;

alter table t1 modify id visible;

delete from t1 where id=2;
inc $dml_cnt;
ob1.oblog.next_dml;

alter table t1 drop column c4 cascade;
alter table t1 drop column c3 cascade;
alter table t1 drop column c2 cascade;

# c1 id;

insert into t1(id, c1) values (6, 'zxcvbn');
inc $dml_cnt;
ob1.oblog.next_dml;

update t1 set c1='?????' where id=3;
inc $dml_cnt;
ob1.oblog.next_dml;

alter table t1 add c5 varchar(64);

# c1 id c5

insert into t1(id, c1, c5) values (7, 'hhhhhh', 'iiiiii');
inc $dml_cnt;
ob1.oblog.next_dml;

create unique index unique_c5_idx on t1 (c5);

insert into t1(id, c1, c5) values (8, 'hhhhhh', 'jjjjjj');
inc $dml_cnt;
ob1.oblog.next_dml;


alter table t1 add c6 int invisible default 777;

# c1 id c5 c6

insert into t1(id, c1, c5) values (9999, '11111', '11111');
inc $dml_cnt;
ob1.oblog.next_dml;

alter table t1 modify c5 invisible, modify c1 invisible;

insert into t1(id, c1, c5) values (9, '22222', '22222');
inc $dml_cnt;
ob1.oblog.next_dml;

alter table t1 modify c5 visible, modify c1 visible;

insert into t1(id, c1, c5) values (10, '33333', '33333');
inc $dml_cnt;
ob1.oblog.next_dml;

delete from t1 where id=9999;
inc $dml_cnt;
ob1.oblog.next_dml;

create index exp_idx_id_c6 on t1 ((id+c6));

insert into t1(id, c1, c5, c6) values (11, '44444', '44444', 4444);
inc $dml_cnt;
ob1.oblog.next_dml;

create index prefix_idx_c5 on t1(substr(c5, 1, 10));

insert into t1(id, c1, c5, c6) values (12, '55555', '55555', 5555);
inc $dml_cnt;
ob1.oblog.next_dml;

alter table t1 drop primary key;

insert into t1(id, c1, c5, c6) values (13, '6666', '6666', 6666);
inc $dml_cnt;
ob1.oblog.next_dml;

alter table t1 drop column c1;

insert into t1(id, c5) values (14, NULL);
inc $dml_cnt;
ob1.oblog.next_dml;

delete from t1 where id<=4;
inc $dml_cnt;
ob1.oblog.next_dml;

echo "#################### [CASE_END] Mixed Scenario in Oracle Mode ####################";

ob1.oblog.stop;

echo "#################### [CASE_BEGIN] Fetch All History ####################";
ob1.oblog.set_start_tstamp_usec $start_timestamp_usec;
ob1.oblog.gen_conf tb_white_list=oracle.*.* enable_output_by_table_def=1 enable_output_hidden_primary_key=1 enable_output_invisible_column=1 log_level=DEBUG skip_ob_version_compat_check=1;
ob1.oblog.restart;

let $cnt=0;

while ($cnt < $dml_cnt)
{
  ob1.oblog.next_dml;
  inc $cnt;
}

ob1.oblog.stop;
echo "#################### [CASE_END] Fetch All History ####################";

echo "#################### [CASE_BEGIN] Fetch All History Ignore Invisible Columns ####################";
ob1.oblog.set_start_tstamp_usec $start_timestamp_usec;
ob1.oblog.gen_conf tb_white_list=oracle.*.* enable_output_by_table_def=1 enable_output_hidden_primary_key=1 log_level=DEBUG skip_ob_version_compat_check=1;
ob1.oblog.restart;

let $cnt=0;

while ($cnt < $dml_cnt)
{
  ob1.oblog.next_dml;
  inc $cnt;
}

ob1.oblog.stop;
echo "#################### [CASE_END] Fetch All History Ignore Invisible Columns ####################";