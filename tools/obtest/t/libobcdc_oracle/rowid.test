ob1=OBI(cluster=1,init_unit_cpu=2);
ob1.reboot;

source include/liboblog/create_oracle_tenant.inc;

# 启动oblog
ob1.oblog.gen_conf tb_white_list=oracle.*.* log_level=DEBUG sort_trans_participants=1 skip_ob_version_compat_check=1;
ob1.oblog.restart;

create table t0(c0 int, c1 int, c2 int, c3 int as(c0+c1+c2), c4 int as(c2+c1+c0), c5 int as(c0+c0+c0)) PARTITION BY hash(c5, c3) SUBPARTITION BY RANGE(c4) subpartition template (SUBPARTITION sp0 VALUES less than(100),SUBPARTITION sp1 VALUES less than(5000)) partitions 3;
ob1.oblog.next;
alter table t0 enable row movement;
ob1.oblog.next;

insert into t0(c0, c1, c2) values(1,2,3);
ob1.oblog.next;
insert into t0(c0, c1, c2) values(4,5,6);
ob1.oblog.next;
insert into t0(c0, c1, c2) values(7,8,9);
ob1.oblog.next;
select c0, c1, c2, rowid from t0;

create table t1(c0 rowid, c1 urowid, c2 int) partition by hash(c2);
ob1.oblog.next;

insert into t1(c0, c1, c2) select rowid, rowid, c3 from t0;
ob1.oblog.next;
# empty
insert into t1(c0, c1, c2) select rowid, rowid, c3 from t0 where c0 = 100;
# two same rows in t1
insert into t1(c0, c1, c2) select rowid, rowid, c3 from t0 where c0 = 7;
ob1.oblog.next;

select c0, c1, c2 from t1;

update t1 set c2 = 999 where c2 = 6;
select c0, c1, c2 from t1 where c2 = 6;
ob1.oblog.next;
delete from t1 where c0 = (select rowid from t0 where c0 = 7);
ob1.oblog.next;

select c0, c1, c2, rowid from t0 where rowid = (select c0 from t1 where c2 = 15);
update t0 set c0 = 100 where rowid = (select c0 from t1 where c2 = 15);
ob1.oblog.next;

create table t2(c1 int, c2 int as (c1+c1*3-c1+c1), c3 rowid) partition by range(c2) (partition p0 values less than(1000), partition p1 values less than(100000));
ob1.oblog.next;
alter table t2 enable row movement;
ob1.oblog.next;

insert into t2(c1, c3) select c2, c0 from t1;
ob1.oblog.next;
select c1, c3 from t2;
update t2 set c1 = 100 where c3 = (select c0 from t1 where c2 = 999);
ob1.oblog.next;
select c1, c3 from t2 where c3 = (select c0 from t1 where c2 = 999);

ob1.oblog.stop;
