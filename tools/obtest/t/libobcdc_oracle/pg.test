##########################
#owner :  qianxi
#owner group: liboblog
#description:
# 测试点：
# pg分区管理
# 1. 创建PG
# 2. 删除PG
# 3. 动态增减PG
# 4. PG分裂: 非分区表/分区表分裂
# 5. 启动时刻添加PG
#

##########################

ob1=OBI(cluster=1,init_unit_cpu=2);
ob1.reboot;

source include/liboblog/create_oracle_tenant.inc;
sleep 5;

# 启动oblog
ob1.oblog.gen_conf tb_white_list=oracle.*.* sort_trans_participants=1 skip_ob_version_compat_check=1;
ob1.oblog.restart;

alter session set current_schema = oblog_db;
sleep 1;

#### 1. create PG
create tablegroup tg1 binding true partition by range columns 1 (partition p0 values less than (10), partition p1 values less than (100),partition p2 values less than (1000), partition p3 values less than (maxvalue));
ob1.oblog.next;
create table t1 (c1 int primary key ,c2 int) tablegroup = tg1 partition by range (c1)  (partition p0 values less than (10), partition p1 values less than (100),partition p2 values less than (1000), partition p3 values less than (maxvalue));
ob1.oblog.next;
insert into t1 values(1, 2);
ob1.oblog.next;

begin;
insert into t1 values(2, 2);
insert into t1 values(33, 33);
insert into t1 values(444, 444);
commit;
ob1.oblog.next;

begin;
insert into t1 values(5, 5);
commit;

#begin;
#update t1 set c1=50 where c1=5;
#insert into t1 values(6, 6);
#commit;

ob1.oblog.next;
insert into t1 values(99, 99);
ob1.oblog.next;
insert into t1 values(999, 999);
ob1.oblog.next;
insert into t1 values(1001, 1001);
ob1.oblog.next;

####### 3. 动态增减分区
# alter tablegroup tg1 drop partition p3;
# ob1.oblog.next;

# alter tablegroup tg1 add partition p4 values less than (2000), partition p5 values less than (4000);
# ob1.oblog.next;

# insert into t1 values(1999, 1999);
# ob1.oblog.next;
# insert into t1 values(3999, 3999);
# ob1.oblog.next;

# alter tablegroup tg1 drop partition p2;
# ob1.oblog.next;
# insert into t1 values(998, 998);
# ob1.oblog.next;

####### 5. 删除PG
set recyclebin=off;
drop table t1;
ob1.oblog.next;

drop tablegroup tg1;
ob1.oblog.next;

# stop liboblog
ob1.oblog.stop;

####### 6. 启动时刻添加PG
create tablegroup tg1 binding true;
create table t1 (c1 int primary key ,c2 int) tablegroup = tg1;
create table t2 (c1 int primary key ,c2 int) tablegroup = tg1;

create tablegroup tg2 binding true;
create table t3 (c1 int primary key ,c2 int) tablegroup = tg2;

# 启动oblog
#ob1.oblog.gen_conf tb_white_list=oracle.*.* log_level=DEBUG skip_ob_version_compat_check=1;
ob1.oblog.gen_conf tb_white_list=oracle.*.* sort_trans_participants=1 skip_ob_version_compat_check=1;
ob1.oblog.restart;

begin;
insert into t1 values(2, 2);
insert into t2 values(444, 444);
commit;
ob1.oblog.next;

begin;
update t1 set c2=20 where c1=2;
insert into t3 values(555, 555);
commit;
ob1.oblog.next;

drop user oblog_db cascade;
ob1.oblog.next;

# stop liboblog
ob1.oblog.stop;
