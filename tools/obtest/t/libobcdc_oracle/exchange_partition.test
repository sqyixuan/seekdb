#
# owner: fankun.fan
# owner group: libobcdc
# description: alter table exchange partition
##

ob1=OBI(cluster=1,init_unit_cpu=5);
ob1.reboot;
ob1.create_client;

# 创建oracle租户，并切换到oracle租户
source include/liboblog/create_oracle_tenant.inc;

# 启动liboblog，同步oracle租户数据
ob1.oblog.gen_conf tb_white_list=oracle.*.* log_level=DEBUG skip_ob_version_compat_check=1;
ob1.oblog.set_extra_argument -m;
ob1.oblog.restart;

# sys-mysql租户获取当前时间
ob_connect(conn_sys, ob1.proxy0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);
let $restart_ts_usec = query_get_value(select time_to_usec(now(6)) as now, now, 1);
ob_connect(conn_oracle_obtest,ob1.z1.obs0,OBTEST@oracle,obtest,obtest,,USE_OB_CONNECTOR);


let $ddl_stmt_count = 0;
let $dml_stmt_count = 0;

alter session set current_schema = oblog_db;
sleep 1;

CREATE OR REPLACE FUNCTION construct_clob(start_str IN VARCHAR2, padding_1 IN VARCHAR2, pad_length IN INTEGER, padding_2 IN VARCHAR2, end_str IN VARCHAR2) RETURN CLOB IS BEGIN  RETURN (to_clob(start_str) || RPAD(to_clob(padding_1), pad_length, padding_2) || end_str); END;
ob1.oblog.next;
inc $ddl_stmt_count;

set @json:=construct_clob('[', '1', 65535, ',1', ']');

create table pt (c1 int not null primary key, c2 int, c3 json) partition by range(c1)(partition M1  VALUES LESS THAN (5), partition M2 VALUES LESS THAN (10), partition M3 VALUES LESS THAN (1000));
ob1.oblog.next;
inc $ddl_stmt_count;

insert into pt values(1, 1, NULL);
ob1.oblog.next;
inc $dml_stmt_count;

insert into pt values(6, 6, @json);
ob1.oblog.next;
inc $dml_stmt_count;

insert into pt values(500, 500, @json);
ob1.oblog.next;
inc $dml_stmt_count;

create table nt (c1 int not null primary key, c2 int, c3 json);
ob1.oblog.next;
inc $ddl_stmt_count;

insert into nt values(2, 2, @json);
ob1.oblog.next;
inc $dml_stmt_count;

alter table pt exchange partition M1 with table nt including indexes WITHOUT VALIDATION;
ob1.oblog.next;
inc $ddl_stmt_count;

insert into pt values(3, 3, @json);
ob1.oblog.next;
inc $dml_stmt_count;

insert into pt values(501, 501, @json);
ob1.oblog.next;
inc $dml_stmt_count;

insert into nt values(4, 4, @json);
ob1.oblog.next;
inc $dml_stmt_count;

ob1.oblog.gen_conf tb_white_list=oracle.*.* log_level=DEBUG skip_ob_version_compat_check=1;
ob1.oblog.set_extra_argument -m;
ob1.oblog.set_start_tstamp_usec $restart_ts_usec;
ob1.oblog.restart;

let $stmt_count = $ddl_stmt_count + $dml_stmt_count;
let $idx = 0;
while ($idx < $stmt_count)
{
    ob1.oblog.next;
    inc $idx;
}

ob1.oblog.stop;

ob1.oblog.gen_conf tb_white_list=oracle.*.* log_level=DEBUG meta_data_refresh_mode=data_dict skip_ob_version_compat_check=1;
ob1.oblog.set_extra_argument -m;
ob1.oblog.set_start_tstamp_usec $restart_ts_usec;
ob1.oblog.restart;

let $stmt_count = $ddl_stmt_count + $dml_stmt_count;
let $idx = 0;
while ($idx < $stmt_count)
{112
    ob1.oblog.next;
    inc $idx;
}

ob1.oblog.stop;

ob1.oblog.gen_conf tb_white_list=oracle.*.* log_level=DEBUG meta_data_refresh_mode=data_dict skip_ob_version_compat_check=1;
ob1.oblog.set_extra_argument -m;
ob1.oblog.restart;
ob1.oblog.stop;
