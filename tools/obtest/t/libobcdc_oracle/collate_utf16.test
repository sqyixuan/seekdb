select * from nls_database_parameters where PARAMETER='NLS_NCHAR_CHARACTERSET';


create table t1 (c1 int primary key, c2 nvarchar2(100));
ob1.oblog.next;
insert into t1 values (1, 'ad');
ob1.oblog.next;
insert into t1 values (2, '韥饢肯駟疶瞡苞粯');
ob1.oblog.next;
insert into t1 values (3, 'ッギヂ');
ob1.oblog.next;
insert into t1 values (4, 'Würzburg');
ob1.oblog.next;
insert into t1 values (5, 'café');
ob1.oblog.next;
select * from t1;
drop table t1;
ob1.oblog.next;

