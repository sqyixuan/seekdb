##########################
#owner :  xianzhi
#owner group: liboblog
#description:
# 测试点：
# directory object ddl operation
# 
#
##########################

# echo for debug
echo "[CASE_BEGIN] [directory]";

ob1=OBI(cluster=1, proxy_num=1, init_unit_cpu=2);
ob1.reboot;

ob1.mysql alter system set resource_hard_limit= 800;
sleep 2;
ob_connect(conn_sys, ob1.proxy0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);

# need tenant has priv to operate specified path or alter tenant set priv
# 
# 创建oracle租户，并切换到oracle租户
source include/liboblog/create_oracle_tenant.inc;

# 启动oblog
ob1.oblog.gen_conf tb_white_list=oracle.*.* log_level=DEBUG skip_ob_version_compat_check=1;
ob1.oblog.restart;

connection conn_oracle;
# 创建user
create user dir_user identified by "dir_user";
# 输出创建user DDL
ob1.oblog.next;
# grant
grant create any directory to dir_user;
ob1.oblog.next;

grant drop any directory to dir_user;
ob1.oblog.next;

sleep 1;
connection conn_sys;
ob1.mysql alter tenant oracle set variables secure_file_priv='/tmp';
ob1.oblog.next;
source include/liboblog/check_schema_fast_sync.inc;

ob_connect(conn_oracle_1, ob1.proxy0, SYS@oracle, ,SYS, , USE_OB_CONNECTOR);

# alter session不会生成redo日志，不需要执行liboblog输出数据
alter session set current_schema = dir_user;
# create/drop directory
create directory d1 as '/tmp';
ob1.oblog.next;

create or replace directory d1 as '/tmp/d1';
ob1.oblog.next;

create or replace directory d2 as '/tmp/d2';
ob1.oblog.next;

drop directory d1;
ob1.oblog.next;

drop directory d2;
ob1.oblog.next;

# 删除user
drop user dir_user cascade;
# 输出DDL
ob1.oblog.next;

# stop liboblog
ob1.oblog.stop;

# echo for debug
echo "[CASE_END] [directory]";
