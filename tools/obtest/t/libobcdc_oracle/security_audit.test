##########################
#owner :  mingdou.tmd
#owner group: liboblog
#description:
# 测试点：
# security audit
#

##########################

ob1=OBI(cluster=1,init_unit_cpu=2);
ob1.reboot;

# 创建oracle租户，并切换到oracle租户
source include/liboblog/create_oracle_tenant.inc;

# 启动oblog
ob1.oblog.gen_conf tb_white_list=oracle.*.* log_level=DEBUG skip_ob_version_compat_check=1;
ob1.oblog.restart;

ob_connect(conn_oracle, ob1.z1.obs0, SYS@oracle, ,SYS, , USE_OB_CONNECTOR);
grant dba to ORAAUDITOR;
alter user ORAAUDITOR account unlock;
ob1.oblog.next;
alter user ORAAUDITOR IDENTIFIED BY ORAAUDITOR;
ob1.oblog.next;

ob_connect(conn_oracle,ob1.z1.obs0,ORAAUDITOR@oracle,ORAAUDITOR,oblog_db,,USE_OB_CONNECTOR);
alter session set current_schema = oblog_db;

alter system set audit_sys_operations = 'true';
alter system set audit_trail = 'DB,EXTENDED';
set @@recyclebin=OFF;
set @@ob_enable_plan_cache=OFF;
set @@ob_query_timeout=10 * @@ob_query_timeout;

select TENANT_ID, bitand(AUDIT_ID, 1099511627775) AUDIT_ID, AUDIT_TYPE, bitand(OWNER_ID, 1099511627775) OWNER_ID, OPERATION_TYPE, IN_SUCCESS, IN_FAILURE from sys.ALL_VIRTUAL_TENANT_SECURITY_AUDIT_REAL_AGENT;

create sequence s1;
ob1.oblog.next;

create table t1 (pk int primary key, a int);
ob1.oblog.next;

insert into t1 values (s1.nextval, 1);
ob1.oblog.next;

audit all statements by ORAAUDITOR;
ob1.oblog.next;

audit all statements by SYS WHENEVER SUCCESSFUL;
ob1.oblog.next;

audit all statements;
ob1.oblog.next;

audit all on t1;
let $idx=0;
while ($idx < 11)
{
  ob1.oblog.next;
  inc $idx;
}

audit all on s1;
let $idx=0;
while ($idx < 4)
{
  ob1.oblog.next;
  inc $idx;
}

audit all on default;
let $idx=0;
while ($idx < 12)
{
  ob1.oblog.next;
  inc $idx;
}

select TENANT_ID, bitand(AUDIT_ID, 1099511627775) AUDIT_ID, AUDIT_TYPE, bitand(OWNER_ID, 1099511627775) OWNER_ID, OPERATION_TYPE, IN_SUCCESS, IN_FAILURE from sys.ALL_VIRTUAL_TENANT_SECURITY_AUDIT_REAL_AGENT;

insert into t1 values (s1.nextval, 2);
ob1.oblog.next;

update t1 set a =3;
ob1.oblog.next;

select * from t1;
delete from t1 where a=3;
ob1.oblog.next;

create table t2 (pk int primary key, a int);
ob1.oblog.next;

insert into t2 values (s1.currval, 1);
ob1.oblog.next;

update t2 set a =3;
ob1.oblog.next;

select * from t2;
delete from t2 where a=3;
ob1.oblog.next;

drop table t2;
ob1.oblog.next;

noaudit all statements by ORAAUDITOR;
ob1.oblog.next;

noaudit all statements by SYS WHENEVER SUCCESSFUL;
ob1.oblog.next;

noaudit all statements;
ob1.oblog.next;

noaudit all on t1;
let $idx=0;
while ($idx < 11)
{
  ob1.oblog.next;
  inc $idx;
}

noaudit all on s1;
let $idx=0;
while ($idx < 4)
{
  ob1.oblog.next;
  inc $idx;
}

noaudit all on default;
let $idx=0;
while ($idx < 12)
{
  ob1.oblog.next;
  inc $idx;
}

select TENANT_ID, bitand(AUDIT_ID, 1099511627775) AUDIT_ID, AUDIT_TYPE, bitand(OWNER_ID, 1099511627775) OWNER_ID, OPERATION_TYPE, IN_SUCCESS, IN_FAILURE from sys.ALL_VIRTUAL_TENANT_SECURITY_AUDIT_REAL_AGENT;

drop user oblog_db cascade;
ob1.oblog.next;

# stop liboblog
ob1.oblog.stop;
