# owner:linyi.cl
# owner group:liboblog
# description:
# 测试点:
#
##

ob1=OBI(cluster=1,init_unit_cpu=2);
ob1.reboot;

# 创建oracle租户，并切换到oracle租户
source include/liboblog/create_oracle_tenant.inc;

# 启动oblog
ob1.oblog.gen_conf tb_white_list=oracle.*.* log_level=DEBUG skip_ob_version_compat_check=1;
ob1.oblog.restart;

create external catalog ca1 properties=(type='odps');
ob1.oblog.next;

drop catalog ca1;
ob1.oblog.next;

# stop liboblog
ob1.oblog.stop;
