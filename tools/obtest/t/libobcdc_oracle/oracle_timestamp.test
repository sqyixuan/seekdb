##########################
#owner :  qianxi
#owner group: liboblog
#description:
# 测试点：

# 1. 测试sequencer对象
# 2. oracle三种时区类型 TIMESTAMP/TIMESTAMP WITH TIME ZONE/
#   TIMESTAMP WITH LOCAL TIME ZONE
# 3. date
##########################

ob1=OBI(cluster=2,init_unit_cpu=2);
ob1.reboot;

ob1.mysql alter system set resource_hard_limit= 800;
#NOTE: let test tenant locate on server without root_service, incase of refresh_timezone with rs_sql_proxy
ob1.mysql alter system set enable_sys_unit_standalone=true;
sleep 2;
ob_connect(conn_sys, ob1.proxy0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);

connection conn_sys;
###create oracle tenant
ob1.mysql create resource unit box1 max_cpu=2, memory_size='10G';
ob1.mysql create resource pool pool1 unit = 'box1', unit_num = 1;
ob1.mysql create tenant oracle replica_num = 1, resource_pool_list=('pool1') set ob_tcp_invited_nodes='%', ob_compatibility_mode='oracle';
ob1.mysql alter tenant oracle set variables nls_date_format='YYYY-MM-DD HH24:MI:SS';
ob1.mysql alter tenant oracle set variables nls_timestamp_format='YYYY-MM-DD HH24:MI:SS.FF';
ob1.mysql alter tenant oracle set variables nls_timestamp_tz_format='YYYY-MM-DD HH24:MI:SS.FF TZR TZD';
sleep 2;

# 倒入时区信息
# TODO  remove ob支持自动加载
ob_connect(conn_sys, ob1.z1.obs1, root@sys, , oceanbase, ,USE_OB_CONNECTOR);
--disable_query_log
source include/liboblog/import_time_zone.inc;
--enable_query_log
sleep 10;
connection conn_sys;
ob_connect(conn_oracle, ob1.z1.obs1, SYS@oracle, ,SYS, , USE_OB_CONNECTOR);

create user oblog_db IDENTIFIED BY "oblog_db";
grant all on *.* to oblog_db WITH GRANT OPTION;
grant dba to oblog_db;
ob_connect(conn_oracle_oblog_db,ob1.z1.obs1,OBLOG_DB@oracle,oblog_db,oblog_db,,USE_OB_CONNECTOR);

# 启动oblog
ob1.oblog.gen_conf tb_white_list=oracle.*.* log_level=DEBUG skip_ob_version_compat_check=1;
#ob1.oblog.gen_conf tb_white_list=oracle.*.* skip_ob_version_compat_check=1;
ob1.oblog.restart;

alter session set current_schema = oblog_db;
create sequence oblog_db_seq start with 1 cache 2 minvalue 0 maxvalue 100000;
ob1.oblog.next;

source include/liboblog/timestamp/otimestamp_dml_init.inc;
source include/liboblog/timestamp/otimestamp_dml_insert_oracle.test;

drop sequence oblog_db_seq;
ob1.oblog.next;

drop user oblog_db cascade;
ob1.oblog.next;

# stop liboblog
ob1.oblog.stop;
