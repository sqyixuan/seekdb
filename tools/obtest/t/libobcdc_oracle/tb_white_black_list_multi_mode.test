#
# owner: fankun.fan
# owner group: libobcdc
# description:
# 测试点:
# 1. json
##

ob1=OBI(cluster=1,init_unit_cpu=5);
ob1.reboot;
ob1.create_client;

# 创建oracle租户，并切换到oracle租户
source include/liboblog/create_oracle_tenant.inc;

# 启动liboblog，同步oracle租户数据
ob1.oblog.gen_conf tb_white_list=oracle.*.white* tb_black_list=oracle.*.black* log_level=DEBUG skip_ob_version_compat_check=1;
ob1.oblog.set_extra_argument -m;
ob1.oblog.restart;

# sys-mysql租户获取当前时间
ob_connect(conn_sys, ob1.proxy0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);
let $restart_ts_usec1 = query_get_value(select time_to_usec(now(6)) as now, now, 1);
ob_connect(conn_oracle_obtest,ob1.z1.obs0,OBTEST@oracle,obtest,obtest,,USE_OB_CONNECTOR);

alter session set current_schema = oblog_db;
sleep 1;

let $ddl_stmt_count = 0;
let $white_dml_stmt_count = 0;
let $black_dml_stmt_count = 0;

# ob1.mysql alter system set dump_data_dictionary_to_log_interval = '6s' tenant all;

CREATE OR REPLACE FUNCTION construct_clob(start_str IN VARCHAR2, padding_1 IN VARCHAR2, pad_length IN INTEGER, padding_2 IN VARCHAR2, end_str IN VARCHAR2) RETURN CLOB IS BEGIN  RETURN (to_clob(start_str) || RPAD(to_clob(padding_1), pad_length, padding_2) || end_str); END;
ob1.oblog.next;
inc $ddl_stmt_count;

# 创建黑白名单测试表
create table white0(id int);
ob1.oblog.next;
inc $ddl_stmt_count;

set @a:=construct_clob('[', '1', 65535, ',1', ']');
set @z:=construct_clob('[', '2', 65535, ',2', ']');

# 创建无json列的表
create table white1(pk int primary key);
ob1.oblog.next;
inc $ddl_stmt_count;

insert into white1 values(1);
ob1.oblog.next;
inc $white_dml_stmt_count;

# 增加json列
alter table white1 add json_col_1 json;
ob1.oblog.next;
inc $ddl_stmt_count;

# NULL
insert into white1 values(2, NULL);
ob1.oblog.next;
inc $white_dml_stmt_count;

# 删除json列
alter table white1 drop column json_col_1;
ob1.oblog.next;
inc $ddl_stmt_count;

# NULL
insert into white1 values(3);
ob1.oblog.next;
inc $white_dml_stmt_count;

# 创建单列json的表
create table white2(pk int primary key, json_col_1 json);
ob1.oblog.next;
inc $ddl_stmt_count;

# NULL
insert into white2 values(1, NULL);
ob1.oblog.next;
inc $white_dml_stmt_count;

# @a
insert into white2 values(2, @a);
ob1.oblog.next;
inc $white_dml_stmt_count;

# 删除json列
alter table white2 drop column json_col_1;
ob1.oblog.next;
inc $ddl_stmt_count;
insert into white2 values(3);
ob1.oblog.next;
inc $white_dml_stmt_count

# 增加json列
alter table white2 add json_col_1 json;
ob1.oblog.next;
inc $ddl_stmt_count;
insert into white2 values(4, @a);
ob1.oblog.next;
inc $white_dml_stmt_count;

# 创建多列json表
create table white3(pk int primary key, json_col_1 json, json_col_2 json);
ob1.oblog.next;
inc $ddl_stmt_count;

# NULL
insert into white3 values(1, NULL, NULL);
ob1.oblog.next;
inc $white_dml_stmt_count;

# @a
insert into white3 values(2, @a, @a);
ob1.oblog.next;
inc $white_dml_stmt_count;

# 增加json列
alter table white3 add json_col_3 json;
ob1.oblog.next;
inc $ddl_stmt_count;
insert into white3 values(3, @a, @a, @a);
ob1.oblog.next;
inc $white_dml_stmt_count;

# 增加多个json列
alter table white3 add (json_col_4 json, json_col_5 json);
ob1.oblog.next;
inc $ddl_stmt_count;
insert into white3 values(4, @a, @a, @a, @a, @a);
ob1.oblog.next;
inc $white_dml_stmt_count;

# 重命名json列
alter table white3 rename column json_col_1 to json_col_11;
ob1.oblog.next;
inc $ddl_stmt_count;
insert into white3 values(5, @a, @a, @a, @a, @a);
ob1.oblog.next;
inc $white_dml_stmt_count;
alter table white3 rename column json_col_11 to json_col_1;
ob1.oblog.next;
inc $ddl_stmt_count;
insert into white3 values(6, @a, @a, @a, @a, @a);
ob1.oblog.next;
inc $white_dml_stmt_count;

# 删除1个json列
alter table white3 drop column json_col_5;
ob1.oblog.next;
inc $ddl_stmt_count;
insert into white3 values(7, @a, @a, @a, @a);
ob1.oblog.next;
inc $white_dml_stmt_count;

# 增加1个json列
alter table white3 add json_col_5 json;
ob1.oblog.next;
inc $ddl_stmt_count;
insert into white3 values(8, @a, @a, @a, @a, @a);
ob1.oblog.next;
inc $white_dml_stmt_count;

# 删除全部json列
alter table white3 drop column json_col_1;
ob1.oblog.next;
inc $ddl_stmt_count;
alter table white3 drop column json_col_2;
ob1.oblog.next;
inc $ddl_stmt_count;
alter table white3 drop column json_col_3;
ob1.oblog.next;
inc $ddl_stmt_count;
alter table white3 drop column json_col_4;
ob1.oblog.next;
inc $ddl_stmt_count;
alter table white3 drop column json_col_5;
ob1.oblog.next;
inc $ddl_stmt_count;
insert into white3 values(9);
ob1.oblog.next;
inc $white_dml_stmt_count;

# 重命名为黑名单
rename white3 to black3;
ob1.oblog.next;
inc $ddl_stmt_count;

# 测试黑名单
insert into black3 values(10);
insert into white0 values(1);
ob1.oblog.next;
inc $black_dml_stmt_count;
inc $white_dml_stmt_count;

# 创建带有lob列的黑名单表
create table black1(pk int primary key, json_col_1 json);
ob1.oblog.next;
inc $ddl_stmt_count;

# NULL
insert into black1 values(1, NULL);
insert into white0 values(2);
ob1.oblog.next;
inc $black_dml_stmt_count;
inc $white_dml_stmt_count;

# 删除json列
alter table black1 drop column json_col_1;
ob1.oblog.next;
inc $ddl_stmt_count;

# NULL
insert into black1 values(2);
insert into white0 values(3);
ob1.oblog.next;
inc $black_dml_stmt_count;
inc $white_dml_stmt_count;

# 增加lob列
alter table black1 add json_col_1 json;
ob1.oblog.next;
inc $ddl_stmt_count;

# NULL;
insert into black1 values(3, NULL);
insert into white0 values(4);
ob1.oblog.next;
inc $black_dml_stmt_count;
inc $white_dml_stmt_count;

sleep 10;
ob1.oblog.stop;

# 回拉，启动liboblog，同步oracle租户数据
ob1.oblog.gen_conf tb_white_list=oracle.*.white* tb_black_list=oracle.*.black* log_level=DEBUG meta_data_refresh_mode=data_dict skip_ob_version_compat_check=1;
ob1.oblog.set_extra_argument -m;
ob1.oblog.set_start_tstamp_usec $restart_ts_usec1;
ob1.oblog.restart;

let $stmt_count = $ddl_stmt_count + $white_dml_stmt_count;

let $idx = 0;
while ($idx < $stmt_count)
{
    ob1.oblog.next;
    inc $idx;
}

ob1.oblog.stop;

# 回拉，启动liboblog，同步oracle租户数据
ob1.oblog.gen_conf tb_white_list=oracle.*.black* tb_black_list=oracle.*.white* log_level=DEBUG meta_data_refresh_mode=data_dict skip_ob_version_compat_check=1;
ob1.oblog.set_extra_argument -m;
ob1.oblog.set_start_tstamp_usec $restart_ts_usec1;
ob1.oblog.restart;

let $stmt_count = $ddl_stmt_count + $black_dml_stmt_count;

let $idx = 0;
while ($idx < $stmt_count)
{
    ob1.oblog.next;
    inc $idx;
}

ob1.oblog.stop;

ob1.oblog.gen_conf tb_white_list=oracle.*.black* tb_black_list=oracle.*.white* log_level=DEBUG meta_data_refresh_mode=data_dict skip_ob_version_compat_check=1;
ob1.oblog.set_extra_argument -m;
ob1.oblog.restart;
ob1.oblog.stop;

ob1.oblog.gen_conf tb_white_list=oracle.*.black* tb_black_list=oracle.*.white* log_level=DEBUG skip_ob_version_compat_check=1;
ob1.oblog.set_extra_argument -m;
ob1.oblog.restart;
ob1.oblog.stop;
