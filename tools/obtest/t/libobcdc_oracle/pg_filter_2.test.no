##########################
#owner :  qianxi
#owner group: liboblog
#description:
# 测试点：
# pg过滤
#   基于tablegroup白/黑名单过滤
#

##########################

ob1=OBI(cluster=1,init_unit_cpu=2);
ob1.reboot;

source include/liboblog/create_oracle_tenant.inc;

# 启动oblog
ob1.oblog.gen_conf tb_white_list=oracle.*.* sort_trans_participants=1 skip_ob_version_compat_check=1;
ob1.oblog.restart;

# sys-mysql租户获取当前时间
ob_connect(conn_sys, ob1.proxy0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);
let $start_tstamp1 = query_get_value(select time_to_usec(now(6)) as now, now, 1);
ob_connect(conn_oracle_obtest,ob1.z1.obs0,OBTEST@oracle,obtest,obtest,,USE_OB_CONNECTOR);

alter session set current_schema = oblog_db;
sleep 1;

################### 1. create PG: tg_alipay1, tg_alipay2, tg_alipay3, 默认不过滤
create tablegroup tg_alipay1 binding true;
ob1.oblog.next;
create table tant1 (c1 int primary key ,c2 int) tablegroup = tg_alipay1;
ob1.oblog.next;
create table tant2 (c1 int primary key ,c2 int) tablegroup = tg_alipay1;
ob1.oblog.next;

create tablegroup tg_alipay2 binding true;
ob1.oblog.next;
create table tant3 (c1 int primary key ,c2 int) tablegroup = tg_alipay2;
ob1.oblog.next;
create table tant4 (c1 int primary key ,c2 int) tablegroup = tg_alipay2;
ob1.oblog.next;

create tablegroup tg_alipay3 binding true;
ob1.oblog.next;
create table tant5 (c1 int primary key ,c2 int) tablegroup = tg_alipay3;
ob1.oblog.next;
create table tant6 (c1 int primary key ,c2 int) tablegroup = tg_alipay3;
ob1.oblog.next;

begin;
insert into tant1 values(1, 1);
insert into tant2 values(2, 2);
insert into tant3 values(3, 3);
insert into tant4 values(4, 4);
insert into tant5 values(5, 5);
insert into tant6 values(6, 6);
commit;
ob1.oblog.next;

# sys-mysql租户获取当前时间
ob_connect(conn_sys, ob1.proxy0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);
let $start_tstamp2 = query_get_value(select time_to_usec(now(6)) as now, now, 1);
ob_connect(conn_oracle_obtest,ob1.z1.obs0,OBTEST@oracle,obtest,obtest,,USE_OB_CONNECTOR);
alter session set current_schema = oblog_db;

# stop liboblog
ob1.oblog.stop;

#################### 2. 过滤1个PG的数据, tg_alipay3
# 启动oblog
# 配置tb_white_list 避免同步到proxy数据
ob1.oblog.gen_conf tablegroup_white_list=oracle.tg_alipay1|oracle.tg_alipay2 tb_white_list=oracle.oblog_db.* sort_trans_participants=1 log_level=DEBUG skip_ob_version_compat_check=1;
ob1.oblog.set_start_tstamp_usec $start_tstamp1;
ob1.oblog.restart;

ob1.oblog.next_dml;

# stop liboblo#g
ob1.oblog.stop;

#################### 3. 过滤2个PG的数据, tg_alipay1, tg_alipay3
# 启动oblog
ob1.oblog.gen_conf tablegroup_white_list=oracle.tg_alipay2 tb_white_list=oracle.oblog_db.* sort_trans_participants=1 log_level=DEBUG skip_ob_version_compat_check=1;
ob1.oblog.set_start_tstamp_usec $start_tstamp1;
ob1.oblog.restart;

ob1.oblog.next_dml;

# stop liboblog
ob1.oblog.stop;

#################### 4. 匹配白名单，但是匹配黑名单，tg_alipay2被过滤
ob1.oblog.set_start_tstamp_usec $start_tstamp1;
ob1.oblog.gen_conf tablegroup_white_list=oracle.tg_alipay1|oracle.tg_alipay2 tablegroup_black_list=oracle.tg_alipay2 tb_white_list=oracle.oblog_db.* sort_trans_participants=1 log_level=DEBUG skip_ob_version_compat_check=1;
ob1.oblog.restart;

ob1.oblog.next_dml;

# stop liboblog
ob1.oblog.stop;

#################### 5. 启动时刻已经创建了PG,验证启动时刻过滤
# 过滤tg_alipay3
ob1.oblog.gen_conf tablegroup_white_list=oracle.tg_alipay1|oracle.tg_alipay2 tb_white_list=oracle.oblog_db.* sort_trans_participants=1 log_level=DEBUG skip_ob_version_compat_check=1;
ob1.oblog.set_start_tstamp_usec $start_tstamp2;
ob1.oblog.restart;

begin;
insert into tant1 values(10, 1);
insert into tant2 values(20, 2);
insert into tant3 values(30, 3);
insert into tant4 values(40, 4);
insert into tant5 values(50, 5);
insert into tant6 values(60, 6);
commit;
ob1.oblog.next_dml;

# stop liboblog
ob1.oblog.stop;
