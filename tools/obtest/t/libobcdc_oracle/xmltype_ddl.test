#
# owner: zhichen
# owner group: shenzhen
# description:
#  xmltype test
##

ob1=OBI(cluster=1);
ob1.reboot;
ob1.create_client;

source include/liboblog/create_oracle_tenant.inc;

connection conn_sys;
alter tenant oracle set variables max_allowed_packet=1073741824;

sleep 2;
# 在oblog_tt租户下操作
connection conn_oracle_obtest;
set global max_allowed_packet=1073741824;
connection conn_oracle_obtest;

ob1.oblog.set_extra_argument -m;
ob1.oblog.gen_conf tb_white_list=oracle.*.*  test_mode_on=1 test_mode_ignore_redo_count=10 sort_trans_participants=1 skip_ob_version_compat_check=1;
ob1.oblog.restart;

#sleep 10;

CREATE OR REPLACE FUNCTION construct_clob(start_str IN VARCHAR2, padding_1 IN VARCHAR2, pad_length IN INTEGER, padding_2 IN VARCHAR2, end_str IN VARCHAR2) RETURN CLOB IS BEGIN  RETURN (to_clob(start_str) || RPAD(to_clob(padding_1), pad_length, padding_2) || end_str); END;
ob1.oblog.next;
CREATE OR REPLACE FUNCTION calc_md5_clob(input_data IN CLOB) RETURN VARCHAR2 IS BEGIN  RETURN LOWER(RAWTOHEX(DBMS_CRYPTO.HASH(input_data, DBMS_CRYPTO.HASH_MD5))); END;
ob1.oblog.next;
CREATE OR REPLACE FUNCTION calc_md5_blob(input_data IN BLOB) RETURN VARCHAR2 IS BEGIN  RETURN LOWER(RAWTOHEX(DBMS_CRYPTO.HASH(input_data, DBMS_CRYPTO.HASH_MD5))); END;
ob1.oblog.next;

create table xml_test(pk int primary key, c1 varchar(100), c2 clob, c3 blob, c4 xmltype, c5 xmltype);
ob1.oblog.next;

insert into xml_test values(1, 'v1', 'clob-v1', utl_raw.cast_to_raw('blob-v1'), xmltype('<z>v1</z>'), xmltype('<x>v1</x>'));
ob1.oblog.next;
select pk, calc_md5_clob(c2), calc_md5_blob(c3), calc_md5_clob('<z>v1</z>') as c4, calc_md5_clob('<x>v1</x>') as c5 from xml_test where pk = 1;

insert into xml_test values(2, 'v2', RPAD(to_clob('v2'), 10000, 'v2'), utl_raw.cast_to_raw('blob-v2'), xmltype(construct_clob('<biglob>', 'v2', 30000, 'v2', '</biglob>')), xmltype(construct_clob('<bigloby>', 'v2', 30000, 'v2', '</bigloby>')));
ob1.oblog.next;
select pk, calc_md5_clob(c2), calc_md5_blob(c3), calc_md5_clob(construct_clob('<biglob>', 'v2', 30000, 'v2', '</biglob>')) as c4, calc_md5_clob(construct_clob('<bigloby>', 'v2', 30000, 'v2', '</bigloby>')) as c5 from xml_test where pk = 2;


alter table xml_test drop column c5;
ob1.oblog.next;

insert into xml_test values(3, 'v3', 'clob-v3', utl_raw.cast_to_raw('blob-v3'), xmltype('<z>v3</z>'));
ob1.oblog.next;
select pk, calc_md5_clob(c2), calc_md5_blob(c3), calc_md5_clob('<z>v3</z>') as c4 from xml_test where pk = 3;

insert into xml_test values(4, 'v4', RPAD(to_clob('v4'), 10000, 'v4'), utl_raw.cast_to_raw('blob-v4'), xmltype(construct_clob('<biglob>', 'v4', 20000, 'v4', '</biglob>')));
ob1.oblog.next;
select pk, calc_md5_clob(c2), calc_md5_blob(c3), calc_md5_clob(construct_clob('<biglob>', 'v4', 20000, 'v4', '</biglob>')) as c4 from xml_test where pk = 4;

update xml_test set c3 = utl_raw.cast_to_raw('blob-update-v1') where pk = 1;
ob1.oblog.next;
select pk, calc_md5_blob(c3) from xml_test where pk = 1;

update xml_test set c4 = xmltype('<z>v3-v1</z>') where pk = 1;
ob1.oblog.next;
select pk, calc_md5_clob('<z>v3-v1</z>') as c4 from xml_test where pk = 1;

update xml_test set c4 = xmltype(construct_clob('<biglob-v1>', 'v2', 30000, 'v2', '</biglob-v1>')) where pk = 2;
ob1.oblog.next;
select pk, calc_md5_clob(construct_clob('<biglob-v1>', 'v2', 30000, 'v2', '</biglob-v1>')) as c4 from xml_test where pk = 2;

delete from xml_test;
ob1.oblog.next;

ob1.oblog.stop;

