#
# owner: fankun.fan
# owner group: libobcdc
# description:
# 测试点:
# 1. big conf
# 2. restart
# 3. restart with data_dict refresh mode
##

ob1=OBI(cluster=1,init_unit_cpu=5);
ob1.reboot;
ob1.create_client;

# 创建oracle租户，并切换到oracle租户
source include/liboblog/create_oracle_tenant.inc;

# 用超大黑白名单配置启动libobcdc
let $tb_white_list_conf = deploy_get_value(ob1.select select TRIM(TRAILING '|' FROM repeat('oracle.*.white*|', 5000)) as white_list, white_list, 1);
let $tb_black_list_conf = deploy_get_value(ob1.select select TRIM(TRAILING '|' FROM repeat('oracle.*.black*|', 5000)) as black_list, black_list, 1);
ob1.oblog.gen_conf tb_white_list=$tb_white_list_conf tb_black_list=$tb_black_list_conf log_level=DEBUG skip_ob_version_compat_check=1;
ob1.oblog.set_extra_argument '-c';
ob1.oblog.restart;

# sys-mysql租户获取当前时间
ob_connect(conn_sys, ob1.proxy0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);
let $restart_ts_usec = query_get_value(select time_to_usec(now(6)) as now, now, 1);
ob_connect(conn_oracle_obtest,ob1.z1.obs0,OBTEST@oracle,obtest,obtest,,USE_OB_CONNECTOR);

alter session set current_schema = oblog_db;
sleep 1;

let $ddl_stmt_count = 0;
let $dml_stmt_count = 0;

# ob1.mysql alter system set dump_data_dictionary_to_log_interval = '6s' tenant all;

let $tb_white_count=10;
let $idx = 0;
while ($idx < $tb_white_count)
{
    eval create table white$idx(c1 int, c2 int);
    inc $ddl_stmt_count;
    inc $idx;
}

let $tb_black_count=5;
let $idx = 0;
while ($idx < $tb_black_count)
{
    eval create table black$idx(c1 int, c2 int);
    inc $ddl_stmt_count;
    inc $idx;
}

let $insert_count=100;

# 开启事务
begin;

--disable_query_log

let $idx = 0;
while ($idx < $tb_white_count)
{   
    let $inserted_count = 0;
    while ($inserted_count < $insert_count)
    {
        eval insert into white$idx values($idx, $idx+1);
        inc $inserted_count;
    }
    inc $idx;
}

let $idx = 0;
while ($idx < $tb_black_count)
{   
    let $inserted_count = 0;
    while ($inserted_count < $insert_count)
    {
        eval insert into black$idx values($idx+2, $idx+3);
        inc $inserted_count;
    }
    inc $idx;
}

--enable_query_log

commit;
inc $dml_stmt_count;
ob1.oblog.next_dml;

sleep 10;
ob1.oblog.stop;

# 用超大黑白名单配置重新启动libobcdc
let $tb_white_list_conf = deploy_get_value(ob1.select select TRIM(TRAILING '|' FROM repeat('oracle.*.white*|', 5000)) as white_list, white_list, 1);
let $tb_black_list_conf = deploy_get_value(ob1.select select TRIM(TRAILING '|' FROM repeat('oracle.*.black*|', 5000)) as black_list, black_list, 1);
ob1.oblog.gen_conf tb_white_list=$tb_white_list_conf tb_black_list=$tb_black_list_conf log_level=DEBUG skip_ob_version_compat_check=1;
ob1.oblog.set_start_tstamp_usec $restart_ts_usec;
ob1.oblog.set_extra_argument '-c';
ob1.oblog.restart;

# output
let $idx = 0;
while ($idx < $ddl_stmt_count)
{
    ob1.oblog.next;
    inc $idx;
}

let $idx = 0;
while ($idx < $dml_stmt_count)
{
    ob1.oblog.next_dml;
    inc $idx;
}

# 用超大黑白名单配置重新启动libobcdc
let $tb_white_list_conf = deploy_get_value(ob1.select select TRIM(TRAILING '|' FROM repeat('oracle.*.white*|', 5000)) as white_list, white_list, 1);
let $tb_black_list_conf = deploy_get_value(ob1.select select TRIM(TRAILING '|' FROM repeat('oracle.*.black*|', 5000)) as black_list, black_list, 1);
ob1.oblog.gen_conf tb_white_list=$tb_white_list_conf tb_black_list=$tb_black_list_conf meta_data_refresh_mode=data_dict log_level=DEBUG skip_ob_version_compat_check=1;
ob1.oblog.set_start_tstamp_usec $restart_ts_usec;
ob1.oblog.set_extra_argument '-c';
ob1.oblog.restart;

# output
let $idx = 0;
while ($idx < $ddl_stmt_count)
{
    ob1.oblog.next;
    inc $idx;
}

let $idx = 0;
while ($idx < $dml_stmt_count)
{
    ob1.oblog.next_dml;
    inc $idx;
}

ob1.oblog.gen_conf tb_white_list=$tb_white_list_conf tb_black_list=$tb_black_list_conf meta_data_refresh_mode=data_dict log_level=DEBUG skip_ob_version_compat_check=1;
ob1.oblog.set_extra_argument '-c';
ob1.oblog.restart;
ob1.oblog.stop;

ob1.oblog.gen_conf tb_white_list=$tb_white_list_conf tb_black_list=$tb_black_list_conf log_level=DEBUG skip_ob_version_compat_check=1;
ob1.oblog.set_extra_argument '-c';
ob1.oblog.restart;
ob1.oblog.stop;
