ob1=OBI(cluster=1);
ob1.reboot;
ob1.create_client;

source include/liboblog/create_oracle_tenant.inc;

# 启动liboblog
# 1. 要求liboblog输出LOB数据时输出MD5值
# 2. 打开test_mode，忽略前10条redo日志，校验MISSING LOG处理逻辑
# 3. 排序参与者列表
ob1.oblog.set_extra_argument -m;
ob1.oblog.gen_conf tb_white_list=oracle.*.*  test_mode_on=1 test_mode_ignore_redo_count=10 sort_trans_participants=1 skip_ob_version_compat_check=1;
ob1.oblog.restart;

# 准备环境
#let $ip=deploy_get_value(ob1.proxy0.ip);
#let $port=deploy_get_value(ob1.proxy0.port);
#connect (oblog_conn_sys,$ip,admin@sys,admin,oceanbase,$port);

# sys租户下操作
#connection oblog_conn_sys;

# 设置最大包大小 1G
set global max_allowed_packet=1073741824;
ob1.oblog.next;

# 重新建立连接
# 让包大小设置生效
#connect (oblog_conn_sys,$ip,admin@sys,admin,oceanbase,$port);

connection conn_oracle_obtest;
# 切换为minimal模式
set binlog_row_image='MINIMAL';
show variables like 'binlog_row_image';
# 设置事务超时时间: 100秒
set ob_trx_timeout=100000000;
set ob_query_timeout=100000000;

