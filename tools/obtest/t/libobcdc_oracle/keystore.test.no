##########################
#owner :  mingdou.tmd
#owner group: liboblog
#description:
# 测试点：keystore
#  create
#  alter

##########################

ob1=OBI(cluster=1,init_unit_cpu=2);
ob1.reboot;

# 创建oracle租户，并切换到oracle租户
source include/liboblog/create_oracle_tenant.inc;

# 启动oblog
ob1.oblog.gen_conf tb_white_list=oracle.*.* log_level=DEBUG skip_ob_version_compat_check=1;
ob1.oblog.restart;

# 创建keystore
ADMINISTER KEY MANAGEMENT CREATE KEYSTORE keystore_name IDENTIFIED BY oceanbase_password;
# 输出DDL
ob1.oblog.next;

# 修改keystore属性
ADMINISTER KEY MANAGEMENT SET KEYSTORE OPEN IDENTIFIED BY oceanbase_password;
# 输出DDL
ob1.oblog.next;

# 修改keystore属性
ADMINISTER KEY MANAGEMENT SET KEYSTORE CLOSE IDENTIFIED BY oceanbase_password;
# 输出DDL
ob1.oblog.next;

# 修改keystore属性
ADMINISTER KEY MANAGEMENT ALTER KEYSTORE PASSWORD IDENTIFIED BY oceanbase_password SET new_password;
# 输出DDL
ob1.oblog.next;

# 修改keystore属性
ADMINISTER KEY MANAGEMENT SET KEY IDENTIFIED BY new_password;
# 输出DDL
ob1.oblog.next;


# stop liboblog
ob1.oblog.stop;
