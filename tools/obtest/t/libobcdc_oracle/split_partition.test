#
# owner: liujixiong.ljx
# owner group: ddl
# description: split partition
##

ob1=OBI(cluster=1, proxy_num=0, init_unit_cpu=1);
ob1.reboot;

# 创建oracle租户，并切换到oracle租户
source include/liboblog/create_oracle_tenant.inc;

# 启动liboblog，同步oracle租户数据
ob1.oblog.gen_conf tb_white_list=oracle.*.* log_level=DEBUG skip_ob_version_compat_check=1;
ob1.oblog.set_extra_argument -m;
ob1.oblog.restart;
sleep 10;

# sys-mysql租户获取当前时间
ob_connect(conn_sys, ob1.z1.obs0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);
let $restart_ts_usec = query_get_value(select time_to_usec(now(6)) as now, now, 1);
ob_connect(conn_oracle_obtest,ob1.z1.obs0,OBTEST@oracle,obtest,obtest,,USE_OB_CONNECTOR);


let $ddl_stmt_count = 0;
let $dml_stmt_count = 0;

alter session set current_schema = oblog_db;
sleep 10;

create sequence seq_small INCREMENT BY 1 start with 1 minvalue 1 maxvalue 100000 nocycle noorder nocache;
ob1.oblog.next;
inc $ddl_stmt_count;

create sequence seq_large INCREMENT BY 1 start with 5001 minvalue 1 maxvalue 100000 nocycle noorder nocache;
ob1.oblog.next;
inc $ddl_stmt_count;

create table test_table(c1 number, c2 number, c3 clob, primary key(c1, c2))partition by range(c1, c2) (partition p0 values less than (1, MAXVALUE), partition p1 values less than (10000, MAXVALUE), partition p2 values less than (MAXVALUE, MAXVALUE));
ob1.oblog.next;
inc $ddl_stmt_count;

--disable_query_log
while($dml_stmt_count <= 20)
{
    insert into test_table select seq_small.nextval, random(1), randstr(10000, 123) from table(generator(1));
    ob1.oblog.next;
    inc $dml_stmt_count;
    insert into test_table select seq_large.nextval, random(1), randstr(10000, 123) from table(generator(1));
    ob1.oblog.next;
    inc $dml_stmt_count;
}
--enable_query_log

alter table test_table split partition p1 at (5000, MAXVALUE) into (partition p1_0, partition p1_1);
ob1.oblog.next;
inc $ddl_stmt_count;

--disable_query_log
while($dml_stmt_count <= 40)
{
    insert into test_table select seq_small.nextval, random(1), randstr(10000, 123) from table(generator(1));
    ob1.oblog.next;
    inc $dml_stmt_count;
    insert into test_table select seq_large.nextval, random(1), randstr(10000, 123) from table(generator(1));
    ob1.oblog.next;
    inc $dml_stmt_count;
}
--enable_query_log

# split again.
alter table test_table split partition p1_1 at (5100, MAXVALUE) into (partition p1_1_0, partition p1_1_1);
ob1.oblog.next;
inc $ddl_stmt_count;

--disable_query_log
while($dml_stmt_count <= 60)
{
    insert into test_table select seq_small.nextval, random(1), randstr(10000, 123) from table(generator(1));
    ob1.oblog.next;
    inc $dml_stmt_count;
    insert into test_table select seq_large.nextval, random(1), randstr(10000, 123) from table(generator(1));
    ob1.oblog.next;
    inc $dml_stmt_count;
}
--enable_query_log


ob1.oblog.gen_conf tb_white_list=oracle.*.* log_level=DEBUG skip_ob_version_compat_check=1;
ob1.oblog.set_extra_argument -m;
ob1.oblog.set_start_tstamp_usec $restart_ts_usec;
ob1.oblog.restart;
sleep 10;

let $stmt_count = $ddl_stmt_count + $dml_stmt_count;
let $idx = 0;
while ($idx < $stmt_count)
{
    ob1.oblog.next;
    inc $idx;
}

ob1.oblog.stop;

ob1.oblog.gen_conf tb_white_list=oracle.*.* log_level=DEBUG meta_data_refresh_mode=data_dict skip_ob_version_compat_check=1;
ob1.oblog.set_extra_argument -m;
ob1.oblog.set_start_tstamp_usec $restart_ts_usec;
ob1.oblog.restart;
sleep 10;

let $stmt_count = $ddl_stmt_count + $dml_stmt_count;
let $idx = 0;
while ($idx < $stmt_count)
{
    ob1.oblog.next;
    inc $idx;
}

ob1.oblog.stop;

ob1.oblog.gen_conf tb_white_list=oracle.*.* log_level=DEBUG meta_data_refresh_mode=data_dict skip_ob_version_compat_check=1;
ob1.oblog.set_extra_argument -m;
ob1.oblog.restart;
ob1.oblog.stop;
