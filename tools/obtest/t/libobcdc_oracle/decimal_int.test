##########################
#owner :  zuojiao.hzj
#owner group: mysql2
#description:
# testcase: decimal int in oracle
#

##########################

ob1=OBI(cluster=1,init_unit_cpu=2);
ob1.reboot;

ob1.mysql alter system set resource_hard_limit= 800;
sleep 2;
ob_connect(conn_sys, ob1.proxy0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);

###create oracle tenant
ob1.mysql create resource unit box1 max_cpu=2, memory_size='10G';
ob1.mysql create resource pool pool1 unit = 'box1', unit_num = 1;
ob1.mysql create tenant oracle replica_num = 1, resource_pool_list=('pool1') set ob_tcp_invited_nodes='%', ob_compatibility_mode='oracle';
sleep 2;
ob_connect(conn_oracle, ob1.z1.obs0, SYS@oracle, ,SYS, , USE_OB_CONNECTOR);

create user obtest IDENTIFIED BY "obtest";
grant all on *.* to obtest WITH GRANT OPTION;
grant dba to obtest;
ob_connect(conn_oracle_obtest,ob1.z1.obs0,OBTEST@oracle,obtest,obtest,,USE_OB_CONNECTOR);

create user oblog_db identified by "passwd";
grant dba to oblog_db;
grant dba to ORAAUDITOR;
alter session set current_schema = oblog_db;
# 启动oblog
ob1.oblog.gen_conf tb_white_list=oracle.*.* log_level=DEBUG;
ob1.oblog.restart;

create table simple_number(c0 number, c1 number(10), c2 integer, c3 number(38, 10));
ob1.oblog.next;

insert into simple_number values(1.23, 2.3, 3.4, 4.56);
ob1.oblog.next;

insert into simple_number values(0, 0, 0, 0);
ob1.oblog.next;

insert into simple_number values(null, null, null, null);
ob1.oblog.next;

insert into simple_number values(999999.99999, 9999999999, 99999999999999999999, 999999999999999999.9999999999);
ob1.oblog.next;

insert into simple_number values(999999999999999999.9999999999, -9999999999, 99999999999999999999, 0.9999999999);
ob1.oblog.next;

delete from simple_number where c0=0;
ob1.oblog.next;

delete from simple_number where c1=9999999999;
ob1.oblog.next;

delete from simple_number where c2=3;
ob1.oblog.next;

delete from simple_number where c3=0.9999999999;
ob1.oblog.next;
select * from simple_number;

update simple_number set c0 = 1.23;
ob1.oblog.next;
select * from simple_number;

update simple_number set c1 = 3.45;
ob1.oblog.next;
select * from simple_number;

update simple_number set c2 = c1;
ob1.oblog.next;
select * from simple_number;

update simple_number set c3 = c2;
ob1.oblog.next;
select * from simple_number;

update simple_number set c3 = c1 + c2;
ob1.oblog.next;
select * from simple_number;

update simple_number set c3 = c1 - c2;
ob1.oblog.next;
select * from simple_number;

update simple_number set c3 = c1 * c2;
ob1.oblog.next;
select * from simple_number;

update simple_number set c3 = c1 / c2;
ob1.oblog.next;
select * from simple_number;

drop table simple_number;
ob1.oblog.next;
sleep 1;

## number作为主键
create table simple_number_pk(c1 number(10, 2) primary key);
ob1.oblog.next;

insert into simple_number_pk values(1.23);
ob1.oblog.next;

insert into simple_number_pk values(2.34);
ob1.oblog.next;

insert into simple_number_pk values(99999999.99);
ob1.oblog.next;
select * from simple_number_pk;

update simple_number_pk set c1 = 9999.99 where c1 = 99999999.99;
ob1.oblog.next;
select * from simple_number_pk;

drop table simple_number_pk;
ob1.oblog.next;
sleep 1;

## number作为主键2
create table simple_number_pk(c1 number(10) primary key);
ob1.oblog.next;

insert into simple_number_pk values(111);
ob1.oblog.next;

insert into simple_number_pk values(1234);
ob1.oblog.next;

insert into simple_number_pk values(1.23);
ob1.oblog.next;

update simple_number_pk set C1=11 where C1=1;
ob1.oblog.next;

drop table simple_number_pk;
ob1.oblog.next;
sleep 1;

create table simple_number_pk(c1 number(10, 2) primary key, c2 number(38, 10));
ob1.oblog.next;
sleep 1;

ob_connect(conn_sys, ob1.proxy0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);
sleep 1;
let $start_tstamp = query_get_value(select time_to_usec(now(6)) as now, now, 1);

ob_connect(conn_oracle_obtest,ob1.z1.obs0,OBTEST@oracle,obtest,obtest,,USE_OB_CONNECTOR);
alter session set current_schema = oblog_db;

insert into simple_number_pk values(1.23, 1);
delete from simple_number_pk;
insert into simple_number_pk values(99999999.99, 9999999999999999999999999999.9999999999);
delete from simple_number_pk;
insert into simple_number_pk values(-99999999.99, -9999999999999999999999999999.9999999999);
delete from simple_number_pk;

let $DECINT_PK_DML_CNT = 6;
while ($DECINT_PK_DML_CNT > 0)
{
  ob1.oblog.next;
  dec $DECINT_PK_DML_CNT;
}

# stop liboblog
ob1.oblog.stop;

# 回拉历史
ob1.oblog.set_start_tstamp_usec $start_tstamp;
ob1.oblog.gen_conf tb_white_list=oracle.*.* log_level=DEBUG;
ob1.oblog.set_extra_argument -x;
ob1.oblog.restart;

let $DECINT_PK_DML_CNT = 6;
while ($DECINT_PK_DML_CNT > 0)
{
  ob1.oblog.next_dml;
  dec $DECINT_PK_DML_CNT;
}

drop user oblog_db cascade;
ob1.oblog.next;

# stop liboblog
ob1.oblog.stop;
