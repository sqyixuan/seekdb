##########################
#owner :  mingdou.tmd
#owner group: liboblog
#description:
# 测试点：role
#  create
#  drop

##########################

ob1=OBI(cluster=1,init_unit_cpu=2);
ob1.reboot;

# 创建oracle租户，并切换到oracle租户
source include/liboblog/create_oracle_tenant.inc;

# 启动oblog
ob1.oblog.gen_conf tb_white_list=oracle.*.* log_level=DEBUG skip_ob_version_compat_check=1;
ob1.oblog.restart;

# 创建role
create role r1;
# 输出DDL
ob1.oblog.next;

# 创建user,赋予role
create user u1 identified by 123;
# 输出DDL
ob1.oblog.next;

grant r1 to u1;
# 输出DDL
ob1.oblog.next;

grant select on u1.* to r1;
# 输出DDL
ob1.oblog.next;

grant create on *.* to r1;
# 输出DDL
ob1.oblog.next;

revoke create on *.* from r1;
# 输出DDL
ob1.oblog.next;

# 删除role
drop role r1;
# 输出DDL
ob1.oblog.next;





# stop liboblog
ob1.oblog.stop;
