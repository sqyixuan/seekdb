# owner: yanmu.ztl
# owner group: rs
# description: 验证系统表需指定column_id加列（不放在mysqltest是因为涉及系统表DDL，怕影响日常测试）

ob1=OBI(cluster=1, init_unit_cpu=0, proxy_num=0, ct_num=0, locality=hz);
ob1.reboot;

let $rs = deploy_get_value(ob1.get_leader sys:oceanbase:__all_core_table:0);
let $rs_ip = deploy_get_value($rs.ip);
let $rs_port = deploy_get_value($rs.port);
let $rs_mysql_port = deploy_get_value($rs.mysql_port);
connect (conn_sys,$rs_ip,root,,oceanbase,$rs_mysql_port);
connection conn_sys;

# case 1: sys table add column
# should enable_sys_table_ddl
--error 1064
alter table __all_dummy add column `test1` bigint(20) id 16;

alter system set enable_sys_table_ddl = true;

# should append column
--error 4179
alter table __all_dummy add column `test1` bigint(20) id 16;
--error 4179
alter table __all_dummy add column `test1` bigint(20) id 18;

select table_id, table_name, max_used_column_id from __all_virtual_table where table_id = 1099511627911;
select column_id, column_name, prev_column_id from __all_virtual_column where table_id = 1099511627911;

alter table __all_dummy add column `test1` bigint(20) id 17;

select table_id, table_name, max_used_column_id from __all_virtual_table where table_id = 1099511627911;
select column_id, column_name, prev_column_id from __all_virtual_column where table_id = 1099511627911;

alter table __all_dummy add column `test2` bigint(20) id 18;

select table_id, table_name, max_used_column_id from __all_virtual_table where table_id = 1099511627911;
select column_id, column_name, prev_column_id from __all_virtual_column where table_id = 1099511627911;

--error 4179
alter table __all_dummy add column `test3` bigint(20);

select table_id, table_name, max_used_column_id from __all_virtual_table where table_id = 1099511627911;
select column_id, column_name, prev_column_id from __all_virtual_column where table_id = 1099511627911;


alter system set enable_sys_table_ddl = false;

# case 2: user table add column
create table test.tt (c1 int primary key, c2 int);

--error 1064
alter table test.tt add column `test1` bigint(20) id 16;

alter system set enable_sys_table_ddl = true;

# user table add column with column_id is not usefull
select table_id, table_name, max_used_column_id from __all_virtual_table where table_id = 1099511677777;
select column_id, column_name, prev_column_id from __all_virtual_column where table_id = 1099511677777;

alter table test.tt add column `test1` bigint(20) id 100;

select table_id, table_name, max_used_column_id from __all_virtual_table where table_id = 1099511677777;
select column_id, column_name, prev_column_id from __all_virtual_column where table_id = 1099511677777;

# user table add column no need to specify column_id
alter table test.tt add column `test2` bigint(20);

select table_id, table_name, max_used_column_id from __all_virtual_table where table_id = 1099511677777;
select column_id, column_name, prev_column_id from __all_virtual_column where table_id = 1099511677777;

alter system set enable_sys_table_ddl = false;

alter table test.tt add column `test3` bigint(20);

select table_id, table_name, max_used_column_id from __all_virtual_table where table_id = 1099511677777;
select column_id, column_name, prev_column_id from __all_virtual_column where table_id = 1099511677777;
