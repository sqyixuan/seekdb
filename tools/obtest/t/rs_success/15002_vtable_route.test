#owner : yanmu.ztl
#owner group : rs
#description : test vtable route policy and visibility

ob1=OBI(cluster=1:1:1,proxy_num=0);

let $extra_conf = "cpu_count=16,memory_limit='20G',system_memory='5G',__min_full_resource_pool_memory='1073741824',cache_wash_threshold='1G'";
ob1.z1.obs0.set extra_config=_enable_defensive_check=false,$extra_conf;
ob1.z2.obs0.set extra_config=_enable_defensive_check=false,$extra_conf;
ob1.z3.obs0.set extra_config=_enable_defensive_check=false,$extra_conf;

ob1.reboot;
sleep 3;

let $cpu = 1;
let $memory = 1073741824;
let $min_memory = 1073741824;
let $disk = 536870912;
let $iops = 100000;
let $session = 64;

ob1.mysql alter system set enable_rebalance='false';
ob1.mysql alter system set enable_rereplication='false';

let $z1_obs_ip = deploy_get_value(ob1.z1.obs0.ip);
let $z1_obs_port = deploy_get_value(ob1.z1.obs0.port);
let $z2_obs_ip = deploy_get_value(ob1.z2.obs0.ip);
let $z2_obs_port = deploy_get_value(ob1.z2.obs0.port);
let $z3_obs_ip = deploy_get_value(ob1.z3.obs0.ip);
let $z3_obs_port = deploy_get_value(ob1.z3.obs0.port);

ob_connect(conn_sys, ob1.z1.obs0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);

# create mysql tenant
eval CREATE RESOURCE UNIT unit_1 MAX_CPU $cpu, MEMORY_SIZE $memory, MAX_IOPS $iops, MIN_CPU=1, MIN_IOPS=1024;
eval CREATE RESOURCE POOL pool_1 UNIT = 'unit_1', ZONE_LIST = ('z1', 'z2'), UNIT_NUM = 1;
eval CREATE TENANT mysql RESOURCE_POOL_LIST = ('pool_1'), primary_zone='z1' set ob_tcp_invited_nodes='%';
#source include/check_schema_sync.inc;
let $mysql_tenant_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name = 'mysql', tenant_id, 1);
let $addr_str = select svr_ip, svr_port from oceanbase.__all_server where zone in ('z1', 'z2');
ob1.check_until_timeout select count(*) as cnt from oceanbase.__all_virtual_server_schema_info as a join oceanbase.__all_virtual_server_schema_info as b on a.tenant_id = b.tenant_id where a.refreshed_schema_version != b.refreshed_schema_version and (a.svr_ip, a.svr_port) in ($addr_str) and (b.svr_ip, b.svr_port) in ($addr_str) and a.tenant_id in ($mysql_tenant_id, $mysql_tenant_id - 1), 0, 60;

# create oracle tenant
connection conn_sys;
eval CREATE RESOURCE UNIT unit_2 MAX_CPU $cpu, MEMORY_SIZE $memory, MAX_IOPS $iops, MIN_CPU=1, MIN_IOPS=1024;
eval CREATE RESOURCE POOL pool_2 UNIT = 'unit_2', ZONE_LIST = ('z1', 'z3'), UNIT_NUM = 1;
eval CREATE TENANT oracle RESOURCE_POOL_LIST = ('pool_2'), primary_zone='z1' set ob_tcp_invited_nodes='%', ob_compatibility_mode = 'oracle';
#source include/check_schema_sync.inc;
let $oracle_tenant_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name = 'oracle', tenant_id, 1);
let $addr_str = select svr_ip, svr_port from oceanbase.__all_server where zone in ('z1', 'z3');
ob1.check_until_timeout select count(*) as cnt from oceanbase.__all_virtual_server_schema_info as a join oceanbase.__all_virtual_server_schema_info as b on a.tenant_id = b.tenant_id where a.refreshed_schema_version != b.refreshed_schema_version and (a.svr_ip, a.svr_port) in ($addr_str) and (b.svr_ip, b.svr_port) in ($addr_str) and a.tenant_id in ($oracle_tenant_id, $oracle_tenant_id - 1), 0, 60;

# case 1: test vtable route policy and visibility in mysql
ob_connect(conn_mysql, ob1.z2.obs0, root@mysql, , oceanbase, , USE_MYSQL_CONNECTOR);
# __all_virtual_server_schema_info related
show create table oceanbase.__all_virtual_server_schema_info;
show create table oceanbase.GV$OB_SERVER_SCHEMA_INFO;
show create table oceanbase.V$OB_SERVER_SCHEMA_INFO;
select tenant_id, count(*) as cnt from oceanbase.__all_virtual_server_schema_info group by tenant_id;
--disable_query_log
eval select tenant_id, count(*) as cnt from oceanbase.__all_virtual_server_schema_info where (svr_ip, svr_port) in (("$z1_obs_ip", $z1_obs_port), ("$z2_obs_ip", $z2_obs_port)) group by tenant_id;
--enable_query_log
select tenant_id, count(*) as cnt from oceanbase.GV$OB_SERVER_SCHEMA_INFO group by tenant_id;
--disable_query_log
eval select tenant_id, count(*) as cnt from oceanbase.GV\$OB_SERVER_SCHEMA_INFO where (svr_ip, svr_port) in (("$z1_obs_ip", $z1_obs_port), ("$z2_obs_ip", $z2_obs_port)) group by tenant_id;
--enable_query_log
select tenant_id, count(*) as cnt from oceanbase.V$OB_SERVER_SCHEMA_INFO group by tenant_id;

# end case 1 ##########################################

# case 2: test vtable route policy and visibility in oracle
ob_connect(conn_oracle, ob1.z3.obs0, SYS@oracle, ,SYS, , USE_OB_CONNECTOR);
# __all_virtual_server_schema_info related
--error 942
show create table SYS.ALL_VIRTUAL_SERVER_SCHEMA_INFO;
show create table SYS.GV$OB_SERVER_SCHEMA_INFO;
show create table SYS.V$OB_SERVER_SCHEMA_INFO;
--error 942
select tenant_id, count(*) as cnt from SYS.ALL_VIRTUAL_SERVER_SCHEMA_INFO group by tenant_id;
select tenant_id, count(*) as cnt from SYS.GV$OB_SERVER_SCHEMA_INFO group by tenant_id;
--disable_query_log
eval select tenant_id, count(*) as cnt from SYS.GV\$OB_SERVER_SCHEMA_INFO where (svr_ip, svr_port) in (("$z1_obs_ip", $z1_obs_port), ("$z3_obs_ip", $z3_obs_port)) group by tenant_id;
--enable_query_log
select tenant_id, count(*) as cnt from SYS.V$OB_SERVER_SCHEMA_INFO group by tenant_id;

# end case 2 ##########################################

# case 3: test vtable route policy and visibility in sys
connection conn_sys;
# __all_virtual_server_schema_info related
show create table __all_virtual_server_schema_info;
show create table GV$OB_SERVER_SCHEMA_INFO;
show create table V$OB_SERVER_SCHEMA_INFO;
select tenant_id, count(*) as cnt from oceanbase.__all_virtual_server_schema_info group by tenant_id;
select tenant_id, count(*) as cnt from oceanbase.GV$OB_SERVER_SCHEMA_INFO group by tenant_id;
select tenant_id, count(*) as cnt from oceanbase.V$OB_SERVER_SCHEMA_INFO group by tenant_id;

set @@session.ob_query_timeout = 1000000000;

# end case 0 ##########################################
