# owner: yanmu.ztl
# description: 

#ob1=OBI(cluster=1);
ob1=OBI(cluster=1,proxy_num=0);
#ob1=OBI(cluster=1,version=1_4_76,oblog_version=current);
ob1.reboot;
ob1.create_client;

# 准备环境
let $ip=deploy_get_value(ob1.z1.obs0.ip);
let $port=deploy_get_value(ob1.z1.obs0.mysql_port);
connect (oblog_conn_sys,$ip,admin@sys,admin,oceanbase,$port);

connection oblog_conn_sys;

create table t_range_hash (c1 int, c2 int, c3 int, c4 int) partition by range(c1) subpartition by hash(c2) subpartitions 4 (   partition rp0 values less than (100),   partition rp1 values less than (200),    partition rp2 values less than (300) );

select partition_id from __all_tenant_gc_partition_info join __all_table_v2 on __all_table_v2.table_id=__all_tenant_gc_partition_info.table_id where table_name='t_range_hash';
alter table t_range_hash add partition (  partition rp3 values less than (400) );
select partition_id from __all_tenant_gc_partition_info join __all_table_v2 on __all_table_v2.table_id=__all_tenant_gc_partition_info.table_id where table_name='t_range_hash';

create table t_range (c1 int, c2 int, c3 int, c4 int) partition by range(c1) (   partition rp0 values less than (100),   partition rp1 values less than (200),   partition rp2 values less than (300) );

select partition_id from __all_tenant_gc_partition_info join __all_table_v2 on __all_table_v2.table_id=__all_tenant_gc_partition_info.table_id where table_name='t_range';
alter table t_range add partition (  partition rp3 values less than (400) );
select partition_id from __all_tenant_gc_partition_info join __all_table_v2 on __all_table_v2.table_id=__all_tenant_gc_partition_info.table_id where table_name='t_range';
