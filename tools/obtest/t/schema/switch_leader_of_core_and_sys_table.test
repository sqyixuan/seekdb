## owner:nijia.nj
## owner group:sql2
## description:
## 测试点：
#  测试修改oceanbase库的primary_zone后，核心表以及系统表的leader是否会随之切走

ob1=OBI(cluster=1:1:1,proxy_num=1);
ob1.reboot;

ob1.mysql_root alter system set enable_auto_leader_switch = True;
sleep 5;

ob1.create_client tenant=sys,user=root,passwd=,database=oceanbase;


let $leader = deploy_get_value(ob1.get_leader sys:oceanbase:__all_database:0);
let $leader2 = deploy_get_value(ob1.get_leader sys:oceanbase:__all_table:0);
echo $leader;
echo $leader2;

#source include/clear_core_and_sys_table_primary_zone.inc;
alter database oceanbase primary_zone = 'z2';
sleep 10;

let $leader = deploy_get_value(ob1.get_leader sys:oceanbase:__all_database:0);
let $leader2 = deploy_get_value(ob1.get_leader sys:oceanbase:__all_table:0);
echo $leader;
echo $leader2;

alter database oceanbase primary_zone = DEFAULT;
sleep 10;

let $leader = deploy_get_value(ob1.get_leader sys:oceanbase:__all_database:0);
let $leader2 = deploy_get_value(ob1.get_leader sys:oceanbase:__all_table:0);
echo $leader;
echo $leader2;
