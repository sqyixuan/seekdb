# owner: lixinze.lxz
# group: transaction
# test_no: 1003
# description: this case is used to xa for standby

ob1=OBI(cluster=1:1, proxy_num=0);

source include/mini_ob_config.inc;
ob1.z1.obs0.set extra_config = "cpu_count=16,memory_limit='29G',system_memory='7G',__min_full_resource_pool_memory='1073741824',cache_wash_threshold='1G',_ob_minor_merge_schedule_interval='3s'";

let $backup_cluster_name = deploy_get_value(ob1.get_cluster_name);
let $backup_cluster_id = deploy_get_value(ob1.get_cluster_id);
let $backup_ip       = deploy_get_value(ob1.z1.obs0.ip);
let $backup_port     = deploy_get_value(ob1.z1.obs0.mysql_port);
let $restore_ip         = deploy_get_value(ob1.z1.obs0.ip);
let $restore_port       = deploy_get_value(ob1.z1.obs0.mysql_port);
let $backup_dest = deploy_get_value(ob1.get_backup_dest);
let $backup_oracle_tenant   = backup_oracle_tenant;
let $restore_oracle_tenant = restore_oracle_tenant;
let $restore_oracle_tenant_new = restore_oracle_tenant_new;
let $log_backup_dest = deploy_get_value(ob1.get_log_backup_dest $backup_oracle_tenant);
let $data_backup_dest = deploy_get_value(ob1.get_data_backup_dest $backup_oracle_tenant);
let $restore_log_archive_dest = deploy_get_value(ob1.get_log_backup_dest $restore_oracle_tenant);

# 必须先stop掉老的，删除才能有效，不然可能会有残留。
ob1.force_stop;
ob1.clean_backup_dest;
ob1.reboot;

# 固定sys租户规格
ob1.mysql alter resource unit sys_unit_config memory_size='2G';

connect(backup_sys_conn, $backup_ip, root@sys,,oceanbase, $backup_port);
connection backup_sys_conn;
use oceanbase;
--disable_all_result_log
alter system set resource_hard_limit = 1000;
alter system set _restore_idle_time = '10s';

CREATE RESOURCE UNIT small_unit MAX_CPU=1, MEMORY_SIZE='4G';

CREATE RESOURCE POOL small_pool UNIT small_unit, UNIT_NUM 1, ZONE_LIST ('z1','z2');
CREATE RESOURCE POOL small_pool_0 UNIT small_unit, UNIT_NUM 1, ZONE_LIST ('z1','z2');
--enable_all_result_log

ob1.mysql alter system set _backup_idle_time = '10s';
ob1.mysql alter system set merger_check_interval = '10s';
ob1.mysql alter system set enable_async_syslog=false;

# create oracle tenant, test create tenant before major freeze
ob1.mysql CREATE TENANT $backup_oracle_tenant RESOURCE_POOL_LIST = ('small_pool'), primary_zone = "RANDOM" set ob_tcp_invited_nodes='%', ob_compatibility_mode='oracle';
let $backup_oracle_tenant_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name='$backup_oracle_tenant', tenant_id, 1);

#oracle租户  创建tablet
ob_connect(sys_conn_oracle, ob1.z1.obs0, sys@$backup_oracle_tenant, ,sys, , USE_OB_CONNECTOR);
connection sys_conn_oracle;
set global wait_timeout = 288000;

--disable_all_result_log
eval alter system set data_backup_dest='$data_backup_dest';
eval alter system set log_archive_dest='location=$log_backup_dest piece_switch_interval=1d';
--enable_all_result_log
ob_connect(backup_oracle_conn, ob1.z1.obs0,sys@$backup_oracle_tenant,,sys,,USE_OB_CONNECTOR);
connection backup_oracle_conn;

create table xa_tt01(a int, b int);

#oracle租户  开启日志备份
ob1.mysql alter system archivelog;
ob1.check_until_timeout select status from oceanbase.CDB_OB_ARCHIVELOG where tenant_id=$backup_oracle_tenant_id, DOING, 600;

# Note: there may be unfinished major_merge, which are launched according to major_freeze_duty_time.
# Therefore, we need to disable daily_merge and wait the launched major_merge to finish here.
ob1.mysql alter system set major_freeze_duty_time = 'Disable' tenant sys;
ob1.mysql alter system set major_freeze_duty_time = 'Disable' tenant all_user;
ob1.mysql alter system set major_freeze_duty_time = 'Disable' tenant all_meta;
ob1.check_until_timeout select (frozen_scn - last_scn) from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id = $backup_oracle_tenant_id, 0, 600;

#oracle租户  开启数据备份
ob1.mysql alter system backup database;
ob1.check_until_timeout select count(*) c from __all_backup_job_history where tenant_id = 1, 1, 600;
ob1.check_until_timeout select result from oceanbase.CDB_OB_BACKUP_JOB_HISTORY where tenant_id = $backup_oracle_tenant_id, 0, 10;
ob1.check_until_timeout select result from oceanbase.CDB_OB_BACKUP_TASK_HISTORY where tenant_id = $backup_oracle_tenant_id, 0, 10;

ob_connect(backup_oracle_conn, ob1.z1.obs0,sys@$backup_oracle_tenant,,sys,,USE_OB_CONNECTOR);
connection backup_oracle_conn;

# 1. start xa trans and insert values into tables;
# declare
# l_xid DBMS_XA_XID;
# l_ret PLS_INTEGER;
# BEGIN
# l_xid := DBMS_XA_XID(0, '', '');
# l_xid.formatid := 123;
# l_xid.gtrid := UTL_RAW.cast_to_raw('gtrid01003');
# l_xid.bqual := UTL_RAW.cast_to_raw('bqual001');
# l_ret := DBMS_XA.XA_START(xid => l_xid, flag => DBMS_XA.TMNOFLAGS);
# insert into xa_tt01 values (1, 1);
# END;

set autocommit = 'OFF';
declare l_xid DBMS_XA_XID; l_ret PLS_INTEGER; BEGIN l_xid := DBMS_XA_XID(0, '', ''); l_xid.formatid := 123; l_xid.gtrid := UTL_RAW.cast_to_raw('gtrid01003'); l_xid.bqual := UTL_RAW.cast_to_raw('bqual001'); l_ret := DBMS_XA.XA_START(xid => l_xid, flag => DBMS_XA.TMNOFLAGS); insert into xa_tt01 values (1, 1); END;

# 2. end xa branch
# declare
# l_xid DBMS_XA_XID;
# l_ret PLS_INTEGER;
# BEGIN
# l_xid := DBMS_XA_XID(0, '', '');
# l_xid.formatid := 123;
# l_xid.gtrid := UTL_RAW.cast_to_raw('gtrid01003');
# l_xid.bqual := UTL_RAW.cast_to_raw('bqual001');
# l_ret := DBMS_XA.XA_END(xid => l_xid, flag => DBMS_XA.TMSUSPEND);
# END;

declare l_xid DBMS_XA_XID; l_ret PLS_INTEGER; BEGIN l_xid := DBMS_XA_XID(0, '', ''); l_xid.formatid := 123; l_xid.gtrid := UTL_RAW.cast_to_raw('gtrid01003'); l_xid.bqual := UTL_RAW.cast_to_raw('bqual001'); l_ret := DBMS_XA.XA_END(xid => l_xid, flag => DBMS_XA.TMSUSPEND); END;

# 3. xa prepare
# declare
# l_xid DBMS_XA_XID;
# l_ret PLS_INTEGER;
# BEGIN
# l_xid := DBMS_XA_XID(0, '', '');
# l_xid.formatid := 123;
# l_xid.gtrid := UTL_RAW.cast_to_raw('gtrid01003');
# l_xid.bqual := UTL_RAW.cast_to_raw('bqual001');
# l_ret := DBMS_XA.XA_PREPARE(xid => l_xid);
# END;

declare l_xid DBMS_XA_XID; l_ret PLS_INTEGER; BEGIN l_xid := DBMS_XA_XID(0, '', ''); l_xid.formatid := 123; l_xid.gtrid := UTL_RAW.cast_to_raw('gtrid01003'); l_xid.bqual := UTL_RAW.cast_to_raw('bqual001'); l_ret := DBMS_XA.XA_PREPARE(xid => l_xid); END;
select globalid, branchid from gv$ob_transaction_participants where role = 'LEADER' and formatid = 123;
select tenant_id, formatid, globalid, branchid from gv$ob_global_transaction;
let $check_scn = `select end_scn from gv\$ob_log_stat`;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_log_archive_progress where checkpoint_scn>=$check_scn and tenant_id=$backup_oracle_tenant_id, 1, 50;
sleep 20;

#oracle租户  开启数据恢复
connect(backup_sys_conn, $backup_ip, root@sys,,oceanbase, $backup_port);
connection backup_sys_conn;
use oceanbase;
let $restore_path = $log_backup_dest,$data_backup_dest;
--disable_all_result_log
ob1.mysql alter system restore $restore_oracle_tenant from '$restore_path' until scn=$check_scn with 'pool_list=small_pool_0&primary_zone=z1';
--enable_all_result_log
ob1.check_until_timeout SELECT status FROM __all_tenant WHERE tenant_id = 1003, NORMAL, 200;
ob1.check_until_timeout select count(*) from __all_virtual_ls_meta_table where tenant_id = 1004 and restore_status = 0, 6, 600;
ob1.check_until_timeout select status FROM __all_tenant WHERE tenant_id = 1004, NORMAL, 200;
ob1.check_until_timeout select count(*) FROM __all_restore_job, 0, 200;
ob1.mysql ALTER SYSTEM RECOVER STANDBY TENANT $restore_oracle_tenant UNTIL UNLIMITED;

let $restore_oracle_tenant_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name='$restore_oracle_tenant', tenant_id, 1);

ob_connect(sys_conn, ob1.z1.obs0, root, , oceanbase, , USE_MYSQL_CONNECTOR);
connection sys_conn;
select tenant_role from __all_virtual_tenant_info where tenant_id = 1004;
#STANDBY

ob_connect(restore_oracle_conn, ob1.z1.obs0,sys@$restore_oracle_tenant,,sys,,USE_OB_CONNECTOR);
connection restore_oracle_conn;
select tenant_id, formatid, globalid, branchid from gv$ob_global_transaction;

ob_connect(sys_conn, ob1.z1.obs0, root, , oceanbase, , USE_MYSQL_CONNECTOR);
connection sys_conn;
select gtrid, bqual, format_id,	coordinator from __all_pending_transaction;

ob1.mysql ALTER SYSTEM ACTIVATE STANDBY TENANT $restore_oracle_tenant;

ob_connect(sys_conn, ob1.z1.obs0, root, , oceanbase, , USE_MYSQL_CONNECTOR);
connection sys_conn;
select tenant_role from __all_virtual_tenant_info where tenant_id = 1004;
#PRIMARY

# 4. xa commit
# declare
# l_xid DBMS_XA_XID;
# l_ret PLS_INTEGER;
# BEGIN
# l_xid := DBMS_XA_XID(0, '', '');
# l_xid.formatid := 123;
# l_xid.gtrid := UTL_RAW.cast_to_raw('gtrid01001');
# l_xid.bqual := UTL_RAW.cast_to_raw('bqual001');
# l_ret := DBMS_XA.XA_COMMIT(xid => l_xid, onePhase => FALSE);
# END;

ob_connect(restore_oracle_conn, ob1.z1.obs0,sys@$restore_oracle_tenant,,sys,,USE_OB_CONNECTOR);
connection restore_oracle_conn;
declare l_xid DBMS_XA_XID; l_ret PLS_INTEGER; BEGIN l_xid := DBMS_XA_XID(0, '', ''); l_xid.formatid := 123; l_xid.gtrid := UTL_RAW.cast_to_raw('gtrid01003'); l_xid.bqual := UTL_RAW.cast_to_raw('bqual001'); l_ret := DBMS_XA.XA_COMMIT(xid => l_xid, onePhase => FALSE); END;
select * from xa_tt01;

ob_connect(sys_conn, ob1.z1.obs0, root, , oceanbase, , USE_MYSQL_CONNECTOR);
connection sys_conn;
select gtrid, bqual, format_id,	coordinator from __all_pending_transaction;

ob_connect(backup_oracle_conn, ob1.z1.obs0,sys@$backup_oracle_tenant,,sys,,USE_OB_CONNECTOR);
connection backup_oracle_conn;
declare l_xid DBMS_XA_XID; l_ret PLS_INTEGER; BEGIN l_xid := DBMS_XA_XID(0, '', ''); l_xid.formatid := 123; l_xid.gtrid := UTL_RAW.cast_to_raw('gtrid01003'); l_xid.bqual := UTL_RAW.cast_to_raw('bqual001'); l_ret := DBMS_XA.XA_COMMIT(xid => l_xid, onePhase => FALSE); END;
select * from xa_tt01;

ob_connect(sys_conn, ob1.z1.obs0, root, , oceanbase, , USE_MYSQL_CONNECTOR);
connection sys_conn;
select gtrid, bqual, format_id,	coordinator from __all_pending_transaction;
