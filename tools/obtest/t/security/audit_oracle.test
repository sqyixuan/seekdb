ob1=OBI(cluster=1,proxy_num=0,init_unit_cpu=0);
ob1.reboot;
sleep 5;
#owner: scott.sx
#owner group: sql1
# tags: ddl
# oracle模式下审计功能, 需求及概要设计见 
# 本测例为针对性测试
# 因为参数修改后需要重启集群因此用obtest
ob_connect (conn11, ob1, root@sys, , oceanbase, , USE_OB_CONNECTOR);

--disable_warnings
drop tenant if exists oracle;
--disable_warnings
drop resource pool if exists audit_pool;
--disable_warnings
drop resource unit if exists audit_box;

let $ip = deploy_get_value(ob1.z1.obs0.ip);
let $port = deploy_get_value(ob1.z1.obs0.port);
let $pwd = deploy_get_value(ob1.z1.obs0.workdir);

#--echo $ip
#--echo $port
#--echo $pwd

###create oracle tenant
ob1.mysql create resource unit audit_box max_cpu 2, max_memory 2073741824, max_iops 100000, max_disk_size '5G', max_session_num 64, MIN_CPU=1, MIN_MEMORY=2073741824, MIN_IOPS=128;
ob1.mysql create resource pool audit_pool unit = 'audit_box', unit_num = 1;
ob1.mysql create tenant oracle replica_num = 1, resource_pool_list=('audit_pool') set ob_tcp_invited_nodes='%', ob_compatibility_mode='oracle';
sleep 2;
ob_connect(conn_oracle, ob1, ORAAUDITOR@oracle, ,SYS, , USE_OB_CONNECTOR);

create user obtest IDENTIFIED BY "obtest";
grant all on *.* to obtest WITH GRANT OPTION;
grant dba to obtest;
ob_connect(conn_oracle_obtest,ob1,OBTEST@oracle,obtest,obtest,,USE_OB_CONNECTOR);
###非审计员没有权限创建规则
--error 600
audit table by SYS by access;
--error 600
noaudit table by SYS by access;

--disable_warnings
--error 0,942
drop table t1;
--error 0,942
drop table t2;
--error 0,942
drop table f_t1;
--error 0,942
drop table f_t2;
--error 0,942
drop table f_t1_copy;
--error 0,942
drop table f_t2_copy;
--error 0,942
drop table m;
--error 0,942
drop view vv;
--enable_warnings
--echo ###Q1 系统变量测试
#alter system set sql_work_area = '200M';
#show parameters like 'sql_work_area%';

#show parameters like 'audit_sys_operations';
alter system set audit_sys_operations = 'false';
alter system set audit_sys_operations = '1';
--error 600
alter system set audit_sys_operations = '12A';

alter system set audit_trail = 'OS';
--error 600
alter system set audit_trail = 'DB2';
alter system set audit_trail = 'DB';
alter system set audit_trail = 'XML';


alter system set audit_sys_operations = 'true';
alter system set audit_trail = 'OS';

#重启以生效参数修改
ob1.restart;
ob1.check_until_timeout SELECT CAST(COUNT(*) AS SIGNED) as cnt FROM __all_virtual_clog_stat WHERE is_in_sync = 0 and is_offline=0,0,600;
#ob_connect(conn_oracle_obtest,ob1,OBTEST@oracle,obtest,obtest,,USE_OB_CONNECTOR);
sleep 60;
ob_connect(conn_oracle, ob1, ORAAUDITOR@oracle, ,SYS, , USE_OB_CONNECTOR);

#--disable_result_log
#ob1.z1.mysql show parameters like 'audit%';
#--enable_result_log

--echo ###Q2 审计基础语法功能的测试
select count(*) from sys.ALL_VIRTUAL_STMT_AUDIT_OPTS_AGENT;

audit table by ORAAUDITOR by access;
noaudit table by ORAAUDITOR by access;
--error 600
audit all statements by access whenever not successful;
--error 600
audit all statements by access;
--error 600
audit all statements by ORAAUDITOR by access;
audit table by ORAAUDITOR by access;
audit table by ORAAUDITOR by access;
noaudit table by ORAAUDITOR by access;
--error 600
noaudit all by scott,songxin by access whenever NOT SUCCESSFUL;
--error 600
noaudit table,view by scott,songxin by access whenever SUCCESSFUL;
noaudit table  by access;

create table m(c int);
create view vv  as select 1/0 as x from m;

audit table by ORAAUDITOR by access;
audit select table by ORAAUDITOR by access;

select count(*) from sys.ALL_VIRTUAL_STMT_AUDIT_OPTS_AGENT;

select * from m where 'ssssssssss123' is not null ;
--replace_regex /.*ACTION.*/ACTION
ob1.ssh $ip grep "ssssssssss123" $pwd/adump/observer_*.aud

select * from m where 'ssssssssss124' is not null;
--replace_regex /.*ACTION.*/ACTION
ob1.ssh $ip grep "ssssssssss124" $pwd/adump/observer_*.aud

select * from m where c > 588999;
--replace_regex /.*ACTION\:*/ACTION
ob1.ssh $ip grep "588999" $pwd/adump/observer_*.aud

drop view vv;
--replace_regex /.*ACTION.*/ACTION
ob1.ssh $ip grep "drop view vv" $pwd/adump/observer_*.aud

--echo ###Q1.2 取消后不会再进行审计
noaudit select table by ORAAUDITOR by access;
select * from m where 'abcd778899'='abcd';
--replace_regex /.*ACTION /.*ACTION /g
ob1.ssh $ip grep "abcd778899" $pwd/adump/observer_*.aud

--echo ###Q1.3 仅审计错误的情况
audit select table by ORAAUDITOR by access whenever NOT SUCCESSFUL;
select (select 1 from dual) from dual;
--replace_regex /.*ACTION /.*ACTION /g
ob1.ssh $ip grep "select (select 1 from dual)" $pwd/adump/observer_*.aud

--error 600
select (select 1 from dual union all select 2 from dual) from dual;
#--replace_regex /.*ACTION /.*ACTION /g
ob1.ssh $ip grep "select 1 from dual union all select 2 from dual" $pwd/adump/observer_*.aud

noaudit select table by ORAAUDITOR by access;
noaudit table by ORAAUDITOR by access;

