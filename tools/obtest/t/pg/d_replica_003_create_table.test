# owner: shanyan.g
# owner group: transaction
# Test the case: 验证D副本当选为leader之后再创建partition的行为
#
ob1=OBI(cluster=1:1:1,proxy_num=0,init_unit_cpu=2);
ob1.reboot;

ob1.mysql alter system set enable_auto_leader_switch=false;
ob1.mysql create resource pool rp1 unit = 'sys_unit_config', unit_num = 1, zone_list = ('z1', 'z2', 'z3');
ob1.mysql create tenant tt1 replica_num 3, primary_zone 'z1', resource_pool_list ('rp1'), locality = "F{1,memstore_percent:100}@z1,F{1,memstore_percent:0}@z2,L@z3" set ob_tcp_invited_nodes='%';

sleep 5;

let $ip0=deploy_get_value(ob1.z1.obs0.ip);
let $port0=deploy_get_value(ob1.z1.obs0.port);
let $ip1=deploy_get_value(ob1.z2.obs0.ip);
let $port1=deploy_get_value(ob1.z2.obs0.port);
let $sql_port0=deploy_get_value(ob1.z2.obs0.mysql_port);

connect(conn0,$ip1,root@tt1,,test,$sql_port0);
connect(conn1,$ip1,root@sys,,oceanbase,$sql_port0);

##################################################
#功能点1：创建空PG，F当选为leader，对于空PG的场景，预期不应该创建memtable
connection conn0;
use test;
create tablegroup zehuan_tg1 binding true;
sleep 5;

connection conn1;
let $tg_id = query_get_value(select tablegroup_id from __all_virtual_tablegroup where tablegroup_name='zehuan_tg1', 'tablegroup_id', 1);
eval select count(*) from oceanbase.__all_virtual_table_mgr where table_type=0 and table_id=$tg_id;

#################################################
#功能点2：向PG内新建表，预期能够成功，且创建memtable
connection conn0;
use test;
create table t1(c1 int primary key, c2 int, c3 int, unique key u_idx(c2), index idx(c3)) tablegroup zehuan_tg1;
sleep 5;

connection conn1;
let $table_id = query_get_value(select table_id from __all_virtual_table where table_name='t1', 'table_id', 1);
eval select count(*) from oceanbase.__all_virtual_table_mgr where table_type=0 and table_id=$tg_id;

connection conn0;
--disable_query_log
let $cnt = 1;
while ($cnt <= 10)
{
    eval insert into test.t1 values($cnt, $cnt + 1, $cnt + 2);
    inc $cnt;
}
select * from test.t1;

connection conn1;
alter system major freeze;
ob1.check_version 2;

connection conn0;
use test;
drop table t1;
purge recyclebin;
drop tablegroup zehuan_tg1;

#################################################
#功能点3：kill F，让D副本当选为leader，检查D是否能够提供服务
connection conn0;
use test;
create tablegroup zehuan_tg2 binding true;
sleep 5;

#让D副本当选leader，空PG预期不应该创建memtable
connection conn1;
#ob1.z1.obs0.force_stop;
#sleep 70;
let $tg_id = query_get_value(select /*+read_consistency(weak)+*/tablegroup_id from __all_virtual_tablegroup where tablegroup_name='zehuan_tg2', 'tablegroup_id', 1);
eval select count(*) from oceanbase.__all_virtual_table_mgr where table_type=0 and table_id=$tg_id;

connection conn0;
use test;
create table t2(c1 int primary key, c2 int, c3 int, unique key u_idx(c2), index idx(c3)) tablegroup zehuan_tg2;
sleep 5;

connection conn1;
eval select count(*) from oceanbase.__all_virtual_table_mgr where table_type=0 and table_id=$tg_id;

connection conn0;
let $cnt = 11;
while ($cnt <= 20)
{
    eval insert into test.t2 values($cnt, $cnt + 1, $cnt + 2);
    inc $cnt;
}
select * from test.t2;

ob1.z1.obs0.restart;
sleep 10;

connection conn1;
alter system major freeze;
ob1.check_until_timeout select value from __all_zone where zone='' and name='last_merged_version', 3,3600;

connection conn0;
use test;
drop table t2;
purge recyclebin;
drop tablegroup zehuan_tg2;

##############################################
#功能点4：空PG+D副本调度转储
#
