# owner: jingyan.kfy
# owner group: transaction
# Test the case: pg memstore_percent=0

ob1=OBI(cluster=1:1:1,proxy_num=0,init_unit_cpu=2);
ob1.reboot;

ob1.mysql alter system set enable_auto_leader_switch=false;
ob1.mysql create resource pool rp1 unit = 'sys_unit_config', unit_num = 1, zone_list = ('z1', 'z2', 'z3');
ob1.mysql create tenant tt1 replica_num 3, primary_zone 'z1', resource_pool_list ('rp1'), locality = "F{1,memstore_percent:100}@z1,F{1,memstore_percent:0}@z2,L@z3" set ob_tcp_invited_nodes='%';

sleep 5;

let $ip0=deploy_get_value(ob1.z1.obs0.ip);
let $port0=deploy_get_value(ob1.z1.obs0.port);
let $sql_port0=deploy_get_value(ob1.z1.obs0.mysql_port);
let $ip1=deploy_get_value(ob1.z2.obs0.ip);
let $port1=deploy_get_value(ob1.z2.obs0.port);

connect(conn0,$ip0,root@tt1,,test,$sql_port0);
connect(conn1,$ip0,root@sys,,oceanbase,$sql_port0);

connection conn0;
create tablegroup tg1 binding true;
create table t1(c1 int primary key, c2 int, c3 int, unique key u_idx(c2), index idx(c3)) tablegroup tg1;

# check basic dml
--disable_query_log
let $cnt = 1;
while ($cnt <= 10)
{
    eval insert into test.t1 values($cnt, $cnt + 1, $cnt + 2);
    inc $cnt;
}

select * from test.t1;

# check memtable
connection conn1;

sleep 10;

let $tg_id = query_get_value(select tablegroup_id from __all_virtual_table where table_name='t1', 'tablegroup_id', 1);
let $table_id = query_get_value(select table_id from __all_virtual_table where table_name='t1', 'table_id', 1);
# eval select count(*) from oceanbase.__all_virtual_table_mgr where table_type=0 and table_id=$table_id;

eval alter system switch replica leader partition_id='0%0@$tg_id' server='$ip1:$port1';
sleep 15;
ob1.check_until_timeout select count(*) c from __all_virtual_meta_table where table_id = $tg_id and concat(svr_ip,":",svr_port)='$ip1:$port1' and role = 1, 1, 30;

eval select count(*) from oceanbase.__all_virtual_table_mgr where table_type=0 and table_id=$tg_id;

connection conn0;
let $cnt = 11;
while ($cnt <= 20)
{
    eval insert into test.t1 values($cnt, $cnt + 1, $cnt + 2);
    inc $cnt;
}
select * from test.t1;

connection conn1;

eval alter system switch replica leader partition_id='0%0@$tg_id' server='$ip0:$port0';
sleep 15;
ob1.check_until_timeout select count(*) c from __all_virtual_meta_table where table_id = $tg_id and concat(svr_ip,":",svr_port)='$ip0:$port0' and role = 1, 1, 30;

eval select count(*) from oceanbase.__all_virtual_table_mgr where table_type=0 and table_id=$tg_id;

connection conn0;
select * from test.t1;