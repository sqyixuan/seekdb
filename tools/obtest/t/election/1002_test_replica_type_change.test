# owner: debin.jdb
# owner group: election
# description: 验证F->R->F这种连续转换场景下，election模块迁入、迁出虚拟组是否正常.
# bug: 

ob1=OBI(cluster=1:1:1, init_unit_cpu=0, proxy_num=0, ct_num=0, locality=hz:hz:hz);
ob1.reboot;

--disable_query_log

ob1.mysql alter system set resource_hard_limit=900;
ob1.mysql alter system set resource_soft_limit=800;
ob1.mysql alter system set debug_sync_timeout = '1000s';
ob1.mysql alter system set enable_auto_leader_switch = 'false';
ob1.mysql alter system set enable_rebalance = 'false';
ob1.mysql alter system set enable_rereplication = 'false';
ob1.mysql alter system set balancer_idle_time = '10s';
ob1.mysql alter system set server_data_copy_out_concurrency = 20;
ob1.mysql alter system set server_data_copy_in_concurrency = 20;

let $cpu = 1;
let $memory = 1073741824;
let $min_memory = 1073741824;
let $disk = 536870912;
let $iops = 100000;
let $session = 64;

ob1.mysql CREATE RESOURCE UNIT unit_1 MAX_CPU $cpu, MAX_MEMORY $memory, MAX_IOPS $iops, MAX_DISK_SIZE $disk, MAX_SESSION_NUM $session, MIN_CPU=1, MIN_MEMORY=$min_memory, MIN_IOPS=128;
ob1.mysql CREATE RESOURCE POOL pool_1 UNIT = 'unit_1', UNIT_NUM = 1, ZONE_LIST = ('z1','z2','z3');
ob1.mysql CREATE TENANT tenant_1 RESOURCE_POOL_LIST = ('pool_1'), primary_zone = 'z1;z2,z3', locality='F{1}@z1,F{1}@z2,F{1}@z3' set ob_tcp_invited_nodes='%';
sleep 5;
let $resource_pool_id = deploy_get_value(ob1.select select resource_pool_id from __all_resource_pool where name = 'pool_1', resource_pool_id, 1);
let $tenant1_id = deploy_get_value(ob1.select select tenant_id from __all_tenant where tenant_name = "tenant_1", tenant_id, 1);

let $z1_obs0_ip  = deploy_get_value(ob1.z1.obs0.ip);
let $z1_obs0_mysql_port = deploy_get_value(ob1.z1.obs0.mysql_port);
let $z1_obs0_addr = deploy_get_value(ob1.z1.obs0.get_addr);

let $z3_obs0_ip = deploy_get_value(ob1.z3.obs0.ip);
let $z3_obs0_mysql_port = deploy_get_value(ob1.z3.obs0.mysql_port);
let $z3_obs0_addr = $z3_obs0_ip:$z3_obs0_port;

connect (conn_z1,$z1_obs0_ip,root@tenant_1,,test,$z1_obs0_mysql_port);
connect (conn_z3,$z3_obs0_ip,root@sys,,test,$z3_obs0_mysql_port);

connection conn_z1;
use test;
## 建表
create table t1(c1 int primary key, c2 int) partition by hash(c1) partitions 2;
let $database_name = test;
let $table_name = t1;
let $data_row_count = 1000;
let $tid = deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where tenant_id = "$tenant1_id" and table_name = "t1", table_id, 1);

## 写入数据
insert into t1 values (1, 1);
insert into t1 values (2, 2);
insert into t1 values (3, 3);

## case 1: tenant locality变更
ob1.mysql alter system set enable_rebalance = 'true';
ob1.mysql alter system set enable_rereplication = 'true';
connection conn_z3;
## 写入数据
connection conn_z1;
insert into t1 values (4, 1);
insert into t1 values (5, 2);
insert into t1 values (6, 3);

ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_election_info where table_id = "$tid" and partition_idx = 0 and is_running=1 and eg_id > 0, 3, 120;

## F->R
ob1.mysql alter tenant tenant_1 set locality = "F{1}@z1,F{1}@z2,R{1}@z3";
ob1.check_until_timeout select count(*) from oceanbase.gv\$partition where tenant_id = "$tenant1_id" and table_id = "$tid" and partition_id = 0 and zone = 'z3' and replica_type = 0, 0, 120;
ob1.check_until_timeout select count(*) from oceanbase.gv\$partition where tenant_id = "$tenant1_id" and table_id = "$tid" and partition_id = 0 and zone = 'z3' and replica_type = 16, 1, 120;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_election_info where table_id = "$tid" and partition_idx = 0 and is_running=0 and eg_id=0, 1, 120;

sleep 5;

## R->F
## 写入数据
insert into t1 values (7, 1);
insert into t1 values (8, 2);
insert into t1 values (9, 3);

sleep 5;
# 确认转换之后没有unsync的副本
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_clog_stat where table_id = "$tid" and partition_idx = 0 and is_in_sync = 0, 0, 30;

ob1.mysql alter tenant tenant_1 set locality = "F{1}@z1,F{1}@z2,F{1}@z3";
ob1.check_until_timeout select count(*) from oceanbase.gv\$partition where tenant_id = "$tenant1_id" and table_id = "$tid" and partition_id = 0 and zone = 'z3' and replica_type = 16, 0, 120;
ob1.check_until_timeout select count(*) from oceanbase.gv\$partition where tenant_id = "$tenant1_id" and table_id = "$tid" and partition_id = 0 and zone = 'z3' and replica_type = 0, 1, 120;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_election_info where table_id = "$tid" and partition_idx = 0 and is_running=1 and eg_id > 0, 3, 120;

