##ob1.check_until_timeout select count(1) from oceanbase.gv\$partition where tenant_id = "$tenant_id" and table_id = "$table_id" and partition_id = 0 and zone = 'z3', 1, 120;
##sleep 10;
##
###待复制完成之后，drop 掉该副本，且等待gc 完成
##eval alter system drop replica partition_id = "$partition_id%$partition_cnt@$table_id" server = "$dest_host";
##ob1.check_until_timeout select count(1) from oceanbase.gv\$partition where tenant_id = "$tenant_id" and table_id = "$table_id" and partition_id = 0 and zone = 'z3', 0, 120;
##ob1.check_until_timeout select count(1) from oceanbase.__all_virtual_partition_info where tenant_id = "$tenant_id" and table_id = "$table_id"  and svr_ip = '$dest_ip' and svr_port=$dest_port, 0, 120;
##
###构造一个last_replay_log_id 更小的赋值，从z2_obs0复制
##eval alter system copy replica partition_id = "$partition_id%$partition_cnt@$table_id" source = "$z2_host" destination = "$dest_host";
##ob1.check_until_timeout select count(1) from oceanbase.gv\$partition where tenant_id = "$tenant_id" and table_id = "$table_id" and partition_id = 0 and zone = 'z3', 1, 120;
##ob1.check_until_timeout select count(1) from oceanbase.__all_virtual_partition_info where tenant_id = "$tenant_id" and table_id = "$table_id"  and svr_ip = '$dest_ip' and svr_port=$dest_port, 1, 120;
##sleep 10;

## 测试重启流程
##此时第二次迁移写的日志所写的ilog未刷盘
let $z3_2 = deploy_get_value(ob1.get_obs_by_addr $z3_2_host);

let $last_start_time = deploy_get_value(ob1.select select start_service_time as start_ts from oceanbase.__all_server where svr_ip = '$z3_2_ip' and svr_port=$z3_2_port, start_ts, 1);

$z3_2.restart;
ob1.check_until_timeout select count(1) from oceanbase.__all_server where svr_ip = '$z3_2_ip' and svr_port=$z3_2_port and start_service_time > $last_start_time, 1, 120;

ob1.mysql alter system set ilog_flush_trigger_time="10s";
sleep 30;

ob1.mysql alter system set ilog_flush_trigger_time="1800s";
##此时第二次迁移写的日志所写的ilog已刷盘
let $last_start_time = deploy_get_value(ob1.select select start_service_time as start_ts from oceanbase.__all_server where svr_ip = '$z3_2_ip' and svr_port=$z3_2_port, start_ts, 1);
$z3_2.restart;
ob1.check_until_timeout select count(1) from oceanbase.__all_server where svr_ip = '$z3_2_ip' and svr_port=$z3_2_port and start_service_time > $last_start_time, 1, 120;
$z3_2.check_log_until_success -c "clog is obsoleted, no need to submit";
$z3_2.check_log_until_success -c "success to purge_preceding_items_";






