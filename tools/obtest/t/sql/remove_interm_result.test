# owner: bin.lb
# owner group: sql
# remove interm result when early terminate execution.

ob1=OBI(cluster=1,proxy_num=0,init_unit_cpu=0);
ob1.reboot;

ob1.mysql alter system set resource_hard_limit=900;
ob1.create_client;

sleep 2;

ob1.mysql create resource pool xx1  unit = 'sys_unit_config',unit_num = 1, zone_list = ('z1');
ob1.mysql create tenant xx1 replica_num 1, resource_pool_list ('xx1') set ob_tcp_invited_nodes='%', ob_compatibility_mode='mysql';

let $ip = deploy_get_value(ob1.z1.obs0.ip);
let $port = deploy_get_value(ob1.z1.obs0.mysql_port);

ob_connect(xx1_conn,$ip,root@xx1,,test, $port);
connection xx1_conn;

create table t1 (c1 int primary key, c2 varchar(1000)) partition by hash (c1) partitions 4;

let $i=2200;
--disable_query_log
while ($i > 0)
{
  eval insert into t1 (c1, c2) values ($i, 'aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa');
  dec $i;
}
--enable_query_log
set ob_query_timeout = 36000000000;
set ob_trx_timeout = 36000000000;

select /*+ no_use_px */ sum(length(c2)) from (select * from t1 limit 500) a;
select /*+ no_use_px */ sum(length(c2)) from (select * from t1 limit 500) a;
select /*+ no_use_px */ sum(length(c2)) from (select * from t1 limit 500) a;
select /*+ no_use_px */ sum(length(c2)) from (select * from t1 limit 500) a;
select /*+ no_use_px */ sum(length(c2)) from (select * from t1 limit 500) a;
select /*+ no_use_px */ sum(length(c2)) from (select * from t1 limit 500) a;
select /*+ no_use_px */ sum(length(c2)) from (select * from t1 limit 500) a;
select /*+ no_use_px */ sum(length(c2)) from (select * from t1 limit 500) a;
select /*+ no_use_px */ sum(length(c2)) from (select * from t1 limit 500) a;
select /*+ no_use_px */ sum(length(c2)) from (select * from t1 limit 500) a;

select count(*) < 5 from oceanbase.__tenant_virtual_interm_result;
