#owner: fy373789
#owner group: SQL-执行器

ob1=OBI(cluster=2:2,proxy_num=0);
ob1.reboot;
sleep 3;

ob_connect(root, ob1.z1.obs0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);

set @@session.ob_query_timeout = 1000000000;
eval CREATE RESOURCE UNIT unit_1 MAX_CPU 2, MEMORY_SIZE='4G';
eval CREATE RESOURCE POOL pool_1 UNIT = 'unit_1', UNIT_NUM = 1;
eval CREATE TENANT t1 RESOURCE_POOL_LIST = ('pool_1'), primary_zone='RANDOM' set ob_tcp_invited_nodes='%';

connection root;
let $dst_ip=deploy_get_value(ob1.z1.obs1.ip);
let $dst_port=deploy_get_value(ob1.z1.obs1.port);
let $dst_addr = $dst_ip:$dst_port;

ob_connect(default, ob1.z1.obs1, root@t1, , test, , USE_MYSQL_CONNECTOR);
CREATE TABLE tt2 (
    c1 BIGINT AUTO_INCREMENT,
    c2 BIGINT,
    c3 BIGINT,
    c4 BIGINT,
   PRIMARY KEY (c1, c2)
)
PARTITION BY RANGE(c2) (
   PARTITION p1 VALUES LESS THAN (700000),
   PARTITION p2 VALUES LESS THAN (800000),
   PARTITION p3 VALUES LESS THAN (900000),
   PARTITION p4 VALUES LESS THAN (MAXVALUE)
);
insert into tt2(c2,c3,c4) select abs(random(456) % 1000000), abs(random(456) % 1000000), abs(random(456) % 1000000) from table(generator(10000));

# test hint
--disable_result_log
select /*+ monitor parallel(20) PX_NODE_POLICY('data')*/ avg(c4) from (select max(c3) as max_c3,c4 from tt2 where c2 < 700000 group by c4) group by max_c3;
--enable_result_log
select count(distinct svr_ip, svr_port) from oceanbase.__all_virtual_sql_plan_monitor where trace_id = (select last_trace_id() from dual) and PLAN_LINE_ID = 5;

--disable_result_log
select /*+ monitor parallel(20) PX_NODE_POLICY('zone')*/ avg(c4) from (select max(c3) as max_c3,c4 from tt2 where c2 < 700000 group by c4) group by max_c3;
--enable_result_log
select count(distinct svr_ip, svr_port) from oceanbase.__all_virtual_sql_plan_monitor where trace_id = (select last_trace_id() from dual) and PLAN_LINE_ID = 5;

--disable_result_log
