--disable_result_log
select /*+ monitor parallel(20) PX_NODE_POLICY('cluster') PX_NODE_COUNT(1)*/ avg(c4) from (select max(c3) as max_c3,c4 from tt2 where c2 < 700000 group by c4) group by max_c3;
--enable_result_log
select count(distinct svr_ip, svr_port) from oceanbase.__all_virtual_sql_plan_monitor where trace_id = (select last_trace_id() from dual) and PLAN_LINE_ID = 5;

--disable_result_log
select /*+ monitor parallel(20) PX_NODE_POLICY('cluster') PX_NODE_COUNT(5)*/ avg(c4) from (select max(c3) as max_c3,c4 from tt2 where c2 < 700000 group by c4) group by max_c3;
--enable_result_log
select count(distinct svr_ip, svr_port) from oceanbase.__all_virtual_sql_plan_monitor where trace_id = (select last_trace_id() from dual) and PLAN_LINE_ID = 5;

--disable_query_log
--disable_result_log
eval select /*+ monitor parallel(20) PX_NODE_POLICY('cluster') PX_NODE_ADDRS('$dst_addr')*/ avg(c4) from (select max(c3) as max_c3,c4 from tt2 where c2 < 700000 group by c4) group by max_c3;
--enable_result_log
--echo "select /*+ monitor parallel(20) PX_NODE_POLICY('cluster') PX_NODE_ADDRS('dst_addr')*/ avg(c4) from (select max(c3) as max_c3,c4 from tt2 where c2 < 700000 group by c4) group by max_c3;"
let $trace_id = query_get_value(select last_trace_id() as trace_id from dual, trace_id, 1);
eval select count(distinct svr_ip, svr_port) from oceanbase.__all_virtual_sql_plan_monitor where trace_id = "$trace_id" and PLAN_LINE_ID = 5;
--enable_query_log
--echo "select count(distinct svr_ip, svr_port) from oceanbase.__all_virtual_sql_plan_monitor where trace_id = (select last_trace_id() from dual) and PLAN_LINE_ID = 5;"
let $excute_ip = query_get_value(select distinct svr_ip from oceanbase.__all_virtual_sql_plan_monitor where trace_id = "$trace_id" and PLAN_LINE_ID = 5, svr_ip, 1);
let $excute_port = query_get_value(select distinct svr_port from oceanbase.__all_virtual_sql_plan_monitor where trace_id = "$trace_id" and PLAN_LINE_ID = 5, svr_port, 1);
let $excute_addr = $excute_ip:$excute_port;
if ($excute_addr != $dst_addr) 
{
   --echo "use parallel hint addr error1";
   --echo $excute_addr;
   --echo $dst_addr
}

