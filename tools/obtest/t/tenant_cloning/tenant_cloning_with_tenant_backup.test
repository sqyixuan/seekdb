# owner: chensen.cs
# owner group: transaction
# Testing Case: basic tenant cloning with source tenant backup
#######################################################################
#                        create inital objects
#######################################################################

ob1=OBI(cluster=1:1:1, proxy_num=0);
source include/mini_ob_config.inc;
ob1.z1.obs0.set extra_config = "cache_wash_threshold='1G',_ob_minor_merge_schedule_interval='3s'";
ob1.z2.obs0.set extra_config = "cache_wash_threshold='1G',_ob_minor_merge_schedule_interval='3s'";
ob1.z3.obs0.set extra_config = "cache_wash_threshold='1G',_ob_minor_merge_schedule_interval='3s'";

let $clone_ip       = deploy_get_value(ob1.z1.obs0.ip);
let $clone_port     = deploy_get_value(ob1.z1.obs0.mysql_port);
let $source_mysql_tenant    = mysql;
let $clone_mysql_tenant = clone_mysql_tenant;
let $clone_mysql_resource_pool = clone_mysql_resource_pool;
let $log_backup_dest = deploy_get_value(ob1.get_log_backup_dest $source_mysql_tenant);
let $data_backup_dest = deploy_get_value(ob1.get_data_backup_dest $source_mysql_tenant);
let $restore_mysql_tenant = restore_mysql_tenant;

ob1.force_stop;
ob1.clean_backup_dest;
ob1.reboot;

# 固定sys租户规格
ob1.mysql alter resource unit sys_unit_config memory_size='2G';

connect(sys_conn, $clone_ip, root@sys,, oceanbase, $clone_port);
connection sys_conn;
source sql/physical_backup/prepare_multi_zone_resource.sql;

ob1.mysql alter system set _backup_idle_time = '10s';
ob1.mysql alter system set enable_async_syslog=false;

--echo =================================================================================
--echo                           create source mysql tenant
--echo =================================================================================
connection sys_conn;
ob1.mysql CREATE TENANT $source_mysql_tenant RESOURCE_POOL_LIST = ('small_pool'), primary_zone = "z1" set ob_tcp_invited_nodes='%', ob_compatibility_mode='mysql';
let $source_mysql_tenant_id = query_get_value(select tenant_id from oceanbase.__all_tenant where tenant_name='$source_mysql_tenant', tenant_id, 1);
ob_connect(conn_mysql, ob1.z1.obs0, root@$source_mysql_tenant, ,test, , USE_MYSQL_CONNECTOR);
connection conn_mysql;
set global wait_timeout = 288000;

--echo =================================================================================
--echo                           create tablet for mysql
--echo =================================================================================
connection conn_mysql;
create table t1(c1 int, c2 int, c3 varchar(20));
--disable_query_log
let $cnt=200;
while($cnt>0)
{
  eval insert into t1 values ($cnt, $cnt, "aaa");
  dec $cnt;
}
--enable_query_log

--echo =================================================================================
--echo                      enable archivelog for mysql tenant
--echo =================================================================================
connection sys_conn;
--disable_all_result_log
eval alter system set log_archive_dest='location=$log_backup_dest' tenant=$source_mysql_tenant;
eval alter system archivelog tenant= $source_mysql_tenant;
--enable_all_result_log
ob1.check_until_timeout select status from oceanbase.__all_virtual_log_archive_progress where tenant_id=$source_mysql_tenant_id, DOING, 600;
let $start_scn = query_get_value(select start_scn from oceanbase.__all_virtual_log_archive_progress where tenant_id=$source_mysql_tenant_id, start_scn, 1);
--disable_all_result_log
eval alter system minor freeze tenant = $source_mysql_tenant;
--enable_all_result_log
ob1.check_until_timeout select count(*)>0 from oceanbase.__all_virtual_ls_info where tenant_id=$source_mysql_tenant_id and (select MIN(checkpoint_scn) as min_scn from oceanbase.__all_virtual_ls_info where tenant_id=$source_mysql_tenant_id) >= $start_scn, 1, 600;

--echo =================================================================================
--echo                      enable backup for mysql tenant
--echo =================================================================================
connection sys_conn;
--disable_all_result_log
eval alter system set data_backup_dest='$data_backup_dest' tenant = $source_mysql_tenant;
send alter system backup tenant = $source_mysql_tenant;
--enable_all_result_log
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_BACKUP_JOBS where tenant_id = $source_mysql_tenant_id, 1, 100;

--echo =================================================================================
--echo                            clone tenant from mysql
--echo =================================================================================
ob1.mysql CREATE TENANT $clone_mysql_tenant FROM $source_mysql_tenant WITH RESOURCE_POOL = $clone_mysql_resource_pool, UNIT = small_unit;
ob1.check_until_timeout select status from oceanbase.__all_clone_job_history where clone_tenant_name='$clone_mysql_tenant', CLONE_SYS_SUCCESS, 300;

ob1.check_until_timeout select count(*) as cnt from oceanbase.DBA_OB_TENANTS where tenant_name = "$clone_mysql_tenant" and status = "NORMAL", 1, 60;
let $clone_mysql_tenant_id = query_get_value(SELECT tenant_id as clone_mysql_tenant_id FROM oceanbase.DBA_OB_TENANTS WHERE tenant_name = "$clone_mysql_tenant", clone_mysql_tenant_id, 1);
ob1.check_until_timeout select count(*) as cnt from oceanbase.__all_virtual_tenant_info where tenant_id = $clone_mysql_tenant_id and tenant_role = "STANDBY", 1, 60;

--echo =================================================================================
--echo                            clone tenant finished
--echo =================================================================================

--echo =================================================================================
--echo                           check data from clone tenant
--echo =================================================================================
ob_connect(clone_conn_mysql, ob1.z1.obs0, root@$clone_mysql_tenant, ,test, , USE_MYSQL_CONNECTOR);
connection clone_conn_mysql;
select count(*) from t1;
select * from t1 order by c1 limit 5;

--echo =================================================================================
--echo                            wait backup finished
--echo =================================================================================
ob_connect(conn_sys, ob1.z1.obs0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);
connection conn_sys;
ob1.check_until_timeout select count(*) c from __all_backup_job_history where tenant_id = 1, 1, 600;
ob1.check_until_timeout select result from oceanbase.CDB_OB_BACKUP_JOB_HISTORY where tenant_id = $source_mysql_tenant_id, 0, 10;
ob1.check_until_timeout select result from oceanbase.CDB_OB_BACKUP_TASK_HISTORY where tenant_id = $source_mysql_tenant_id, 0, 10;

let $restore_checkpoint_ts = `select ceil(UNIX_TIMESTAMP(current_timestamp(6)) * 1000000)`;
ob1.check_until_timeout select floor(checkpoint_scn / 1000) > '$restore_checkpoint_ts' from CDB_OB_ARCHIVELOG, 1, 600;
let $restore_checkpoint = `select usec_to_time(floor(checkpoint_scn/1000)) from CDB_OB_ARCHIVELOG`;

--echo =================================================================================
--echo                            restore tenant
--echo =================================================================================
let $restore_path = $log_backup_dest,$data_backup_dest;
ob1.mysql alter system restore $restore_mysql_tenant from '$restore_path' until time='$restore_checkpoint' with 'pool_list=small_pool_1&primary_zone=z1';
ob1.check_until_timeout select count(*) FROM __all_restore_job, 0, 600;

ob1.check_until_timeout select count(*) as cnt from oceanbase.DBA_OB_TENANTS where tenant_name = "$restore_mysql_tenant" and status = "NORMAL", 1, 600;
let $restore_mysql_tenant_id = query_get_value(SELECT tenant_id as restore_mysql_tenant_id FROM oceanbase.DBA_OB_TENANTS WHERE tenant_name = "$restore_mysql_tenant", restore_mysql_tenant_id, 1);
ob1.check_until_timeout select status from cdb_ob_restore_history where tenant_id = 1 and restore_tenant_id = $restore_mysql_tenant_id, SUCCESS, 60;
ob1.check_until_timeout select count(*) as cnt from oceanbase.__all_virtual_tenant_info where tenant_id = $restore_mysql_tenant_id and tenant_role = "STANDBY", 1, 60;

--echo =================================================================================
--echo                            restore tenant finished
--echo =================================================================================

--echo =================================================================================
--echo                           check data from restore tenant
--echo =================================================================================
ob_connect(restore_conn_mysql, ob1.z1.obs0, root@$restore_mysql_tenant, ,test, , USE_MYSQL_CONNECTOR);
connection restore_conn_mysql;
select count(*) from t1;
select * from t1 order by c1 limit 5;
