
# owner: chensen.cs
# owner group: transaction
# Testing Case: basic tenant cloning with oracle mode
#######################################################################
#                        create inital objects
#######################################################################

ob1=OBI(cluster=1:1:1, proxy_num=0);
source include/mini_ob_config.inc;
ob1.z1.obs0.set extra_config = "cache_wash_threshold='1G',_ob_minor_merge_schedule_interval='3s'";
ob1.z2.obs0.set extra_config = "cache_wash_threshold='1G',_ob_minor_merge_schedule_interval='3s'";
ob1.z3.obs0.set extra_config = "cache_wash_threshold='1G',_ob_minor_merge_schedule_interval='3s'";

let $clone_ip       = deploy_get_value(ob1.z1.obs0.ip);
let $clone_port     = deploy_get_value(ob1.z1.obs0.mysql_port);
let $source_oracle_tenant    = oracle;
let $clone_oracle_tenant = clone_oracle_tenant;
let $clone_oracle_resource_pool = clone_oracle_resource_pool;
let $log_backup_dest = deploy_get_value(ob1.get_log_backup_dest $source_oracle_tenant);

ob1.force_stop;
ob1.clean_backup_dest;
ob1.reboot;

# 固定sys租户规格
ob1.mysql alter resource unit sys_unit_config memory_size='2G';

connect(sys_conn, $clone_ip, root@sys,, oceanbase, $clone_port);
connection sys_conn;
source sql/physical_backup/prepare_multi_zone_resource.sql;

ob1.mysql alter system set _backup_idle_time = '10s';
ob1.mysql alter system set enable_async_syslog=false;

--echo =================================================================================
--echo                           create source oracle tenant
--echo =================================================================================
connection sys_conn;
ob1.mysql CREATE TENANT $source_oracle_tenant RESOURCE_POOL_LIST = ('small_pool'), primary_zone = "z1" set ob_tcp_invited_nodes='%', ob_compatibility_mode='oracle';
let $source_oracle_tenant_id = query_get_value(select tenant_id from oceanbase.__all_tenant where tenant_name='$source_oracle_tenant', tenant_id, 1);
ob_connect(conn_oracle, ob1.z1.obs0, SYS@$source_oracle_tenant, ,SYS, , USE_OB_CONNECTOR);
connection conn_oracle;
set global wait_timeout = 288000;
create user test IDENTIFIED BY "test";
grant all on *.* to test WITH GRANT OPTION;
grant dba to test;
ob_connect(source_conn_oracle, ob1.z1.obs0,TEST@$source_oracle_tenant,test,test,,USE_OB_CONNECTOR);
connection source_conn_oracle;

--echo =================================================================================
--echo                           create tablet for orcale
--echo =================================================================================
connection source_conn_oracle;
create table t1(c1 int, c2 int);
--disable_query_log
let $cnt=10;
while($cnt>0)
{
  eval insert into t1 values ($cnt, $cnt);
  dec $cnt;
}
--enable_query_log

--echo =================================================================================
--echo                      enable archivelog for oracle tenant
--echo =================================================================================
connection sys_conn;
--disable_all_result_log
eval alter system set log_archive_dest='location=$log_backup_dest' tenant=$source_oracle_tenant;
eval alter system archivelog tenant= $source_oracle_tenant;
--enable_all_result_log
ob1.check_until_timeout select status from oceanbase.__all_virtual_log_archive_progress where tenant_id=$source_oracle_tenant_id, DOING, 600;
let $start_scn = query_get_value(select start_scn from oceanbase.__all_virtual_log_archive_progress where tenant_id=$source_oracle_tenant_id, start_scn, 1);
--disable_all_result_log
eval alter system minor freeze tenant = $source_oracle_tenant;
--enable_all_result_log
ob1.check_until_timeout select count(*)>0 from oceanbase.__all_virtual_ls_info where tenant_id=$source_oracle_tenant_id and (select MIN(checkpoint_scn) as min_scn from oceanbase.__all_virtual_ls_info where tenant_id=$source_oracle_tenant_id) >= $start_scn, 1, 600;

--echo =================================================================================
--echo                            clone tenant from oracle
--echo =================================================================================
connection sys_conn;
ob1.mysql CREATE TENANT $clone_oracle_tenant FROM $source_oracle_tenant WITH RESOURCE_POOL = $clone_oracle_resource_pool, UNIT = small_unit;
ob1.check_until_timeout select status from oceanbase.__all_clone_job_history where clone_tenant_name='$clone_oracle_tenant', CLONE_SYS_SUCCESS, 300;

ob1.check_until_timeout select count(*) as cnt from oceanbase.DBA_OB_TENANTS where tenant_name = "$clone_oracle_tenant" and status = "NORMAL", 1, 60;
let $clone_oracle_tenant_id = query_get_value(SELECT tenant_id as clone_oracle_tenant_id FROM oceanbase.DBA_OB_TENANTS WHERE tenant_name = "$clone_oracle_tenant", clone_oracle_tenant_id, 1);
ob1.check_until_timeout select count(*) as cnt from oceanbase.__all_virtual_tenant_info where tenant_id = $clone_oracle_tenant_id and tenant_role = "STANDBY", 1, 60;

--echo =================================================================================
--echo                            clone tenant finished
--echo =================================================================================

--echo =================================================================================
--echo                           check data from clone tenant
--echo =================================================================================
ob_connect(clone_conn_oracle, ob1.z1.obs0, SYS@$clone_oracle_tenant, ,TEST, , USE_OB_CONNECTOR);
connection clone_conn_oracle;
select * from t1;
select count(*) from t1;
