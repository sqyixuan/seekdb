# 10.1 DML
#验证oracle 模式 trigger
connection conn_oracle;
insert into t_test_trg_ora values (1);
connection conn_mysql;
use test;
#验证mysql 模式 trigger
insert into t_test_trg_mysql values (1);

let $cnt=200;
while($cnt <= 300)
{
  eval insert into db1.tb_normal (pk) values($cnt);
  eval insert into db1.tb_increment (c1) values($cnt);
  eval insert into db1.tb_bigtable (c1,c2,c3,c4) values(repeat('A',65536),repeat('B',65536),repeat('C',65536),repeat('D',65536));
  eval insert into test.tb_table_gencol(pk1,pk2,c1,c2) values($cnt,'$cnt',repeat('A',65536),repeat('B',65536));
  eval insert into test.tablegencol(c1,USER_ID,ADDRESS) values($cnt, repeat('A',32),repeat('B',256));
  eval insert into test.table_hash(c1, c2) values($cnt, $cnt);
  eval insert into test.table_range(c1, c2) values($cnt, $cnt);
  eval insert into test.table_hash_range(c1, c2) values($cnt, $cnt);
  eval insert into test.table_range_hash(c1, c2) values($cnt, $cnt);
  inc $cnt;
}
let $cnt=1;
while($cnt <= 100)
{
  eval update db1.tb_normal set c1=$cnt where pk = $cnt;
  eval update db1.tb_increment set c1 = $cnt where pk = $cnt;
  eval insert into db1.tb_bigtable (c1,c2,c3,c4) values(repeat('A',65536),repeat('B',65536),repeat('C',65536),repeat('D',65536));
  eval replace into test.tb_table_gencol(pk1,pk2,c1,c2) values($cnt,'$cnt',repeat('A',65536),repeat('B',65536));
  eval replace into test.tablegencol(c1,USER_ID,ADDRESS) values($cnt, repeat('A',32),repeat('B',256));
  eval replace into test.table_hash(c1, c2) values($cnt, $cnt);
  eval replace into test.table_range(c1, c2) values($cnt, $cnt);
  eval replace into test.table_hash_range(c1, c2) values($cnt, $cnt);
  eval replace into test.table_range_hash(c1, c2) values($cnt, $cnt);
  inc $cnt;
}
select pk1,pk2,gen_c1,gen_c2 from test.tb_table_gencol order by pk1,pk2 limit 10;
select * from test.table_hash where c1 = 1;
select * from test.table_range where c1 = 1;
select * from test.table_hash_range where c1 = 1;
select * from test.table_range_hash where c1 = 1;
