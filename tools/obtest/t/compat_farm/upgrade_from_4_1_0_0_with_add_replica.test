grant all on *.* to dblink_test WITH GRANT OPTION;
grant dba to dblink_test;
ob_connect(conn_oracle_dblink_test, ob1.proxy0, dblink_test@oracle, 123, dblink_test, USE_OB_CONNECTOR);
create table dblink_t1(a number, b varchar2(60));
insert into dblink_t1 values (1, 'a'), (2, 'b'), (3, 'c');
commit;

ob_connect(conn_oracle_obtest,ob1.proxy0,OBTEST@oracle,obtest,OBTEST,,USE_OB_CONNECTOR);
create table t1(pk int primary key, c1 number, c2 date default Date '2012-01-02', c3 timestamp default Timestamp '2012-12-01 01:02:03.123456789', c4 timestamp with time zone default Timestamp '2012-12-01 01:02:03.123456789 +02:00');
insert into t1 (pk, c1) values(1,1),(2,2);
delete from t1 where pk=1;
select pk, c1, to_char(c2), to_char(c3), to_char(c4) from t1;

create table global_t1(a int, b int, c int, primary key(a)) partition by hash(a) partitions 2;
create index gkey on global_t1(b) global;
insert into global_t1 values(1, 1, 1), (2, 2, 2), (3, 3, 3), (4, 4, 4), (5, 5, 5);
create table global_t2(a int, b int, c int, primary key(a));
insert into global_t2 values(1, 5, 1), (2, 4, 2), (3, 3, 3), (4, 2, 4), (5, 1, 5);

create tablespace tp1;

create table t_parent(c1 int, c2 int, constraint t_parent_pk primary key(c1, c2));
create table t_child(c1 int, c2 int, constraint t_child_fk foreign key(c2, c1) references t_parent(c1, c2));

create table t_check_1(c1 int, c2 int, constraint cst1 check(c1 = c2));
create table t_check_2(c1 int, c2 int, constraint cst2 check(c2 = c1));

create table t_notnull_pk(c1 int primary key, c2 int, c3 int not null);
desc t_notnull_pk;
create table t_notnull_nopk(c2 int, c3 int not null) partition by hash(c2,c3) partitions 3;

#test dblink schema compatibility
--disable_query_log
--disable_result_log
eval create database link oci_link connect to dblink_test@oracle identified by 123 host '$ip:$port';
--enable_result_log
--enable_query_log
select * from dblink_t1@oci_link;


# 6. 第1次合并
connection conn_sys;
set @@session.ob_query_timeout = 60000000;
alter system major freeze tenant=all;
let $__i__= 600;
while($__i__ > 0)
{
    sleep 1;
    dec $__i__;
    let $__frozen_scn__ = query_get_value(select sum(frozen_scn/1000) as sum_value from oceanbase.CDB_OB_MAJOR_COMPACTION, sum_value, 1);
    let $__merged_version__ = query_get_value(select sum(last_scn/1000) as sum_value from oceanbase.CDB_OB_MAJOR_COMPACTION, sum_value, 1);
    # all tenant should major merge complete
    if($__frozen_scn__ == $__merged_version__)
    {
        let $__i__ = -5;
    }
}
if($__i__ != -5)
{
    --echo major freeze failed
    select * from oceanbase.CDB_OB_MAJOR_COMPACTION;
    let $__tenant_id__ = query_get_value(select tenant_id from oceanbase.CDB_OB_MAJOR_COMPACTION where last_scn != frozen_scn, tenant_id, 1);
    let $__frozen_scn__ = query_get_value(select frozen_scn from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id = $__tenant_id__, frozen_scn, 1);
    eval select * from oceanbase.__all_virtual_server_compaction_event_history where tenant_id = $__tenant_id__ and compaction_scn = $__frozen_scn__;
    select * from oceanbase.__all_virtual_compaction_diagnose_info;
    --exit
}

