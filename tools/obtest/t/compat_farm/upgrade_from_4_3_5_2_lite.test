let $portz2=deploy_get_value(ob1.z2.obs0.mysql_port);
let $server_portz2=deploy_get_value(ob1.z2.obs0.port);

ob1.mysql alter system end upgrade;

# 验证升级期间做DDL
connect (conn_ddl_z1,$ipz1,root@mysql,,test,$portz1);
connection conn_ddl_z1;

ob1.mysql alter system set enable_ddl = true;
ob1.check_until_timeout select count(*) from __all_virtual_tenant_parameter_stat where name='enable_ddl' and value!='true', 0, 600;

let $raw_sys_primary_zone=deploy_get_value(ob1.select select primary_zone a from dba_ob_tenants where tenant_id=1, a, 1);
let $raw_mysql_primary_zone=deploy_get_value(ob1.select select primary_zone a from dba_ob_tenants where tenant_id=$mysql_tenant_id, a, 1);

# z2新 z1旧

# rs z2 mysql z1
ob1.mysql alter tenant sys set primary_zone='z2'; 
ob1.check_until_timeout select job_status from oceanbase.__all_rootservice_job where job_type='ALTER_TENANT_PRIMARY_ZONE' order by job_id desc limit 1, SUCCESS, 600;
