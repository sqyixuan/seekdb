commit;
# 升级前开启SPM
set global optimizer_use_sql_plan_baselines = 1;
set global optimizer_capture_sql_plan_baselines = 1;

#
#ob1.mysql alter tenant obtest set primary_zone='z1';
#ob1.check_until_timeout select count(*) from CDB_OB_LS_LOCATIONS where zone != 'z1' and role='leader' and tenant_id = (select tenant_id from __all_tenant where tenant_name='obtest'),0,60;
ob1.check_until_timeout  select count(1) as unsync_cnt from GV\$OB_LOG_STAT where in_sync = 'NO',0,600;

# 升级ob集群之前，仲裁server已经升级，在这种混跑阶段测试仲裁升降级功能
# kill z2触发降级;
ob1.z2.obs0.force_stop;
let $z2_ip0 = deploy_get_value(ob1.z2.obs0.ip);
let $z2_port0 = deploy_get_value(ob1.z2.obs0.port);
# 确认降级成功
ob1.check_until_timeout select count(*) from __all_virtual_log_stat where tenant_id=$mysql_tenant_id and degraded_list not like '%$z2_ip0:$z2_port0%', 0, 30;
ob1.check_until_timeout select count(*) from oceanbase.DBA_OB_SERVERS where zone = 'z2' and status='INACTIVE',1,60;

# start follower触发升级
ob1.z2.obs0.nstart;
ob1.check_until_timeout select count(*) from oceanbase.__all_server where zone = 'z2' and (start_service_time <= 0 or status='INACTIVE'),0,120;
# 确认升级成功
ob1.check_until_timeout select count(*) from __all_virtual_log_stat where degraded_list like '%$z2_ip0:$z2_port0%', 0, 120;

source include/check_schema_sync.inc;

# 7 打开升级配置, 升级前检查
let $count=20;
while ($count > 0)
{
   let $result_checker=deploy_get_value(ob1.upgrade_check_before);
   if ($result_checker == true)
   {
        let $count = -1;
   }
   if ($result_checker == false)
   {
        dec $count;
        sleep 2;
   }
}
if($count == 0)
{
   --exit
}

# 8.执行升级SQL
ob1.upgrade_commond_for_server pre;
#sleep 5;
#8.1 升级z2
connection conn_sys;
set @@session.ob_query_timeout = 60000000;
alter system stop zone 'z2';
ob1.check_until_timeout select status from DBA_OB_ZONES where zone='z2',INACTIVE,20;
ob1.check_until_timeout select count(1) as leader_count  from CDB_OB_LS_LOCATIONS where zone='z2' and role='leader',0,20;
ob1.z2.force_stop;
ob1.check_until_timeout select count(*) from oceanbase.DBA_OB_SERVERS where zone = 'z2' and (start_service_time is null and status='INACTIVE'),1,60;
ob1.z2.upgrade;
ob1.z2.nstart;
ob1.check_until_timeout select count(*) from oceanbase.__all_server where zone = 'z2' and (start_service_time is null  or status='INACTIVE'),0,300;
ob1.check_until_timeout  select count(1) as unsync_cnt from GV\$OB_LOG_STAT where in_sync = 'NO',0,600;
source include/check_schema_sync_for_restart.inc;
ob1.mysql alter system start zone 'z2';
ob1.check_until_timeout select status from DBA_OB_ZONES where zone='z2',ACTIVE,20;

