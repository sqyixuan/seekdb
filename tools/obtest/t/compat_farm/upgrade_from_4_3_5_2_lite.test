# 10.7 创建string类型
--disable_warnings
drop table if exists tb_str1, tb_str2, tb_str3, tb_str4;
--enable_warnings
create table tb_str1(c1 string);
insert into tb_str1 values("string");
create table tb_str2(c1 string primary key);
insert into tb_str2 values("string");
create table tb_str3(c1 string, key(c1));
insert into tb_str3 values("string");
create table tb_str4(c1 string) partition by key(c1) partitions 4;
insert into tb_str4 values("string");
