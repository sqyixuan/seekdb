let $count=deploy_get_value(ob1.select select count(*) a from oceanbase.dba_ob_tenants, a, 1);
let $i=0;
while ($i<$count)
{
  inc $i;
  let $tenant=deploy_get_value(ob1.select select tenant_name a from oceanbase.dba_ob_tenants order by tenant_id desc, a, $i);
  eval alter system change tenant $tenant;
  eval update oceanbase.__all_core_table set column_value=$start_data_version where table_name='__all_global_stat' and row_id=1 and column_name='current_data_version';
}

ob1.mysql alter system run upgrade job 'upgrade_all';
