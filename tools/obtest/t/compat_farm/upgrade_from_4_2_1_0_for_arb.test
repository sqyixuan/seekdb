# group: logservice
# owner: debin.jdb, yunlong.cb
# 测试仲裁 Server 就地升级场景：
# 1. 启动仲裁服务;
# 2. 添加仲裁服务到ob集群;
# 3. 建租户mysql,开启仲裁服务；
# 4. 为sys租户开启仲裁服务;
# 5. upgrade仲裁server;
# 6. kill followr触发降级;
# 7. 启动follower触发升级;
# 8. 执行升级前置脚本;
# 9. 升级ob集群各个zone;
# 10. kill followr触发降级,验证混跑期间能否降级
# 11. 启动follower，验证混跑期间能否升级;

# 启动 4_1_0_0 版本的集群, obtest 自动添加仲裁服务
ob1=OBI(cluster=1:1:1:1, version=4_2_1_0, proxy_num=1, oblog_version=current, asvr_num=1);
ob1.proxy0.set extra_config=syslog_level=debug;
ob1.proxy0.set extra_config="enable_strict_kernel_release=false";

let $extra_conf = "cpu_count=8,memory_limit='20G',system_memory='5G',__min_full_resource_pool_memory='1073741824',stack_size='1536K',cache_wash_threshold='1G',log_disk_size='20G'";

ob1.z1.obs0.set extra_config=$extra_conf;
ob1.z2.obs0.set extra_config=$extra_conf;
ob1.z3.obs0.set extra_config=$extra_conf;
ob1.z4.obs0.set extra_config=$extra_conf;

# 本地测试环境可能需要指定网卡名(非bond0时)
# let $arb_extra_conf = "memory_limit='1G',log_disk_size='5G',devname='eth0'";
let $arb_extra_conf = "memory_limit='1G',log_disk_size='5G'";
ob1.asvr0.set extra_config=$arb_extra_conf;

# bootstrap
ob1.reboot;
sleep 3;

ob1.mysql alter system set debug_sync_timeout = '1000s';
ob1.mysql ALTER SYSTEM SET enable_rebalance = 'false';
ob1.mysql ALTER SYSTEM SET enable_rereplication = 'true';

let $ip=deploy_get_value(ob1.proxy0.ip);
let $port=deploy_get_value(ob1.proxy0.port);
connect (conn_sys,$ip,root@sys,,oceanbase,$port);

# 1. 启动仲裁server
# 获取仲裁server的ip、port
let $arb_svr_ip= deploy_get_value(ob1.asvr0.ip);
let $arb_svr_port= deploy_get_value(ob1.asvr0.port);
# 2. add arbitration service, mytest.jar已经为本集群做了这一步
# check arbitration service add success
ob1.check_until_timeout select count(*) from DBA_OB_ARBITRATION_SERVICE where arbitration_service = "$arb_svr_ip:$arb_svr_port", 1, 120;

# step 3. 建开启仲裁服务的租户
eval CREATE RESOURCE UNIT unit_1 MAX_CPU 1, MEMORY_SIZE='2G';
eval CREATE RESOURCE POOL pool_1 UNIT = 'unit_1', UNIT_NUM = 1, zone_list = ('z1', 'z2', 'z3', 'z4');

eval CREATE TENANT mysql RESOURCE_POOL_LIST = ('pool_1'),  locality='F@z1, F@z2', primary_zone='RANDOM', enable_arbitration_service=true set ob_tcp_invited_nodes='%';

# source include/check_schema_sync.inc;

let $sys_tenant_id=1;
let $mysql_tenant_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name = 'mysql', tenant_id, 1);

# check arbitration member exist for tenant's ls
ob1.check_until_timeout select count(*) from __all_virtual_log_stat where tenant_id=$mysql_tenant_id and arbitration_member not like "%$arb_svr_ip:$arb_svr_port%", 0, 60;

# step 4. 为sys租户开启仲裁服务;
eval alter tenant sys enable_arbitration_service = true;
ob1.check_until_timeout select count(*) from __all_virtual_log_stat where tenant_id=$sys_tenant_id and arbitration_member not like "%$arb_svr_ip:$arb_svr_port%", 0, 60;

# step 5. 升级仲裁 Server 版本
ob1.asvr0.force_stop;
ob1.asvr0.upgrade;
ob1.asvr0.nstart;
sleep 5;

# step 6. kill follower触发降级;
ob1.z2.obs0.force_stop;
ob1.z3.obs0.force_stop;
ob1.check_until_timeout select count(*) from oceanbase.DBA_OB_SERVERS where zone = 'z2' and status='INACTIVE',1,60;
ob1.check_until_timeout select count(*) from oceanbase.DBA_OB_SERVERS where zone = 'z3' and status='INACTIVE',1,60;
let $z1_ip0 = deploy_get_value(ob1.z1.obs0.ip);
let $z1_sqlport0 = deploy_get_value(ob1.z1.obs0.mysql_port);
let $z2_ip0 = deploy_get_value(ob1.z2.obs0.ip);
let $z2_port0 = deploy_get_value(ob1.z2.obs0.port);
let $z3_ip0 = deploy_get_value(ob1.z3.obs0.ip);
let $z3_port0 = deploy_get_value(ob1.z3.obs0.port);
# sys tenant is 4F1A
ob1.check_until_timeout select count(*) from __all_virtual_log_stat where tenant_id=$sys_tenant_id and degraded_list not like '%$z2_ip0:$z2_port0%', 0, 60;
ob1.check_until_timeout select count(*) from __all_virtual_log_stat where tenant_id=$sys_tenant_id and degraded_list not like '%$z3_ip0:$z3_port0%', 0, 60;
ob1.check_until_timeout select count(*) from __all_virtual_log_stat where tenant_id=$mysql_tenant_id and degraded_list not like '%$z2_ip0:$z2_port0%', 0, 60;

# step 7. restart follower触发升级
ob1.z2.obs0.nstart;
ob1.z3.obs0.nstart;
ob1.check_until_timeout select count(*) from oceanbase.DBA_OB_SERVERS where zone = 'z2' and (start_service_time is null or status='INACTIVE'),0,120;
ob1.check_until_timeout select count(*) from oceanbase.DBA_OB_SERVERS where zone = 'z3' and (start_service_time is null or status='INACTIVE'),0,120;
ob1.check_until_timeout select count(*) from __all_virtual_log_stat where tenant_id=$sys_tenant_id and degraded_list like '%$z2_ip0:$z2_port0%', 0, 60;
ob1.check_until_timeout select count(*) from __all_virtual_log_stat where tenant_id=$mysql_tenant_id and degraded_list like '%$z2_ip0:$z2_port0%', 0, 60;

# 8. 打开升级配置, 升级前检查
connect (conn_sys_svr,$z1_ip0,root@sys,,oceanbase,$z1_sqlport0);
connection conn_sys_svr;
ob1.check_until_timeout select count(*) from __all_service_epoch where name = 'freeze_service_epoch', 1, 120;
let $mysql_meta_tenant_id = math($mysql_tenant_id - 1);
# change to mysql meta tenant
--disable_query_log
eval alter system change tenant tenant_id=$mysql_meta_tenant_id;
let $cnt=0;
while ($cnt != 2)
{
  let $cnt = query_get_value(select count(*) as cnt from __all_service_epoch where name = 'freeze_service_epoch', cnt, 1);
}
if ($mysql_meta_tenant_id > 1001)
{
# 集群存在proxy租户，也需要一并check
  let $proxy_meta_tenant_id = math($mysql_meta_tenant_id - 2);
  eval alter system change tenant tenant_id=$proxy_meta_tenant_id;
  let $cnt=0;
  while ($cnt != 2)
  {
    let $cnt = query_get_value(select count(*) as cnt from __all_service_epoch where name = 'freeze_service_epoch', cnt, 1);
  }
}
--enable_query_log

connection conn_sys;
set @@session.ob_query_timeout = 60000000;
alter system major freeze tenant=all;
let $__i__= 600;
while($__i__ > 0)
{
    sleep 1;
    dec $__i__;
    let $__frozen_scn__ = query_get_value(select sum(frozen_scn/1000) as sum_value from oceanbase.CDB_OB_MAJOR_COMPACTION, sum_value, 1);
    let $__merged_version__ = query_get_value(select sum(last_scn/1000) as sum_value from oceanbase.CDB_OB_MAJOR_COMPACTION, sum_value, 1);
    # all tenant should major merge complete
    if($__frozen_scn__ == $__merged_version__)
    {
        let $__i__ = -5;
    }
}
if($__i__ != -5)
{
    --echo major freeze failed
    select * from oceanbase.CDB_OB_MAJOR_COMPACTION;
    let $__tenant_id__ = query_get_value(select tenant_id from oceanbase.CDB_OB_MAJOR_COMPACTION where last_scn != frozen_scn, tenant_id, 1);
    let $__frozen_scn__ = query_get_value(select frozen_scn from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id = $__tenant_id__, frozen_scn, 1);
    eval select * from oceanbase.__all_virtual_server_compaction_event_history where tenant_id = $__tenant_id__ and compaction_scn = $__frozen_scn__;
    select * from oceanbase.__all_virtual_compaction_diagnose_info;
    --exit
}

connection conn_sys;
source include/check_schema_sync.inc;
ob1.check_until_timeout  select count(1) as unsync_cnt from GV\$OB_LOG_STAT where in_sync = 'NO',0,600;
ob1.upgrade_check_before;

# 9. 执行升级SQL
ob1.upgrade_commond_for_server pre;
# 9.1 升级z2
connection conn_sys;
set @@session.ob_query_timeout = 60000000;
alter system stop zone 'z2';
ob1.check_until_timeout select status from DBA_OB_ZONES where zone='z2',INACTIVE,20;
ob1.check_until_timeout select count(1) as leader_count  from CDB_OB_LS_LOCATIONS where zone='z2' and role='leader',0,20;
ob1.z2.force_stop;
ob1.check_until_timeout select count(*) from oceanbase.DBA_OB_SERVERS where zone = 'z2' and status='INACTIVE',1,60;
ob1.z2.upgrade;
ob1.z2.nstart;
ob1.check_until_timeout select count(*) from oceanbase.DBA_OB_SERVERS where zone = 'z2' and (start_service_time is null or status='INACTIVE'),0,120;
ob1.check_until_timeout  select count(1) as unsync_cnt from GV\$OB_LOG_STAT where in_sync = 'NO',0,600;
source include/check_schema_sync_for_restart.inc;
ob1.mysql alter system start zone 'z2';
sleep 2;
ob1.check_until_timeout select status from DBA_OB_ZONES where zone='z2',ACTIVE,20;
ob1.check_until_timeout select count(*) from oceanbase.__all_server where zone = 'z2' and start_service_time > 0,1,120;

# 9.2 升级z3
connection conn_sys;
set @@session.ob_query_timeout = 60000000;
alter system stop zone 'z3';
ob1.check_until_timeout select status from DBA_OB_ZONES where zone='z3',INACTIVE,20;
ob1.check_until_timeout select count(1) as leader_count  from CDB_OB_LS_LOCATIONS where zone='z3' and role='leader',0,20;
ob1.z3.force_stop;
ob1.check_until_timeout select count(*) from oceanbase.DBA_OB_SERVERS where zone = 'z3' and status='INACTIVE',1,60;
ob1.z3.upgrade;
ob1.z3.nstart;
ob1.check_until_timeout select count(*) from oceanbase.DBA_OB_SERVERS where zone = 'z3' and (start_service_time is null or status='INACTIVE'),0,120;
ob1.check_until_timeout  select count(1) as unsync_cnt from GV\$OB_LOG_STAT where in_sync = 'NO',0,600;
source include/check_schema_sync_for_restart.inc;
ob1.mysql alter system start zone 'z3';
sleep 2;
ob1.check_until_timeout select status from DBA_OB_ZONES where zone='z3',ACTIVE,20;
ob1.check_until_timeout select count(*) from oceanbase.__all_server where zone = 'z3' and start_service_time > 0,1,120;

# z2,z3已升级完成，测试混跑期间升降级
# kill follower触发降级;
ob1.z3.obs0.force_stop;
ob1.z4.obs0.force_stop;
ob1.check_until_timeout select count(*) from oceanbase.DBA_OB_SERVERS where zone = 'z3' and status='INACTIVE',1,60;
ob1.check_until_timeout select count(*) from oceanbase.DBA_OB_SERVERS where zone = 'z4' and status='INACTIVE',1,60;
let $z4_ip0 = deploy_get_value(ob1.z4.obs0.ip);
let $z4_port0 = deploy_get_value(ob1.z4.obs0.port);
ob1.check_until_timeout select count(*) from __all_virtual_log_stat where tenant_id=$sys_tenant_id and degraded_list not like '%$z3_ip0:$z3_port0%', 0, 60;
ob1.check_until_timeout select count(*) from __all_virtual_log_stat where tenant_id=$sys_tenant_id and degraded_list not like '%$z4_ip0:$z4_port0%', 0, 60;

# start follower触发升级
ob1.z3.obs0.nstart;
ob1.z4.obs0.nstart;
ob1.check_until_timeout select count(*) from oceanbase.DBA_OB_SERVERS where zone = 'z3' and (start_service_time is null or status='INACTIVE'),0,120;
ob1.check_until_timeout select count(*) from oceanbase.DBA_OB_SERVERS where zone = 'z4' and (start_service_time is null or status='INACTIVE'),0,120;
ob1.check_until_timeout select count(*) from __all_virtual_log_stat where tenant_id=$sys_tenant_id and degraded_list like '%$z3_ip0:$z3_port0%', 0, 120;
ob1.check_until_timeout select count(*) from __all_virtual_log_stat where tenant_id=$sys_tenant_id and degraded_list like '%$z4_ip0:$z4_port0%', 0, 120;

# 9.3 升级z4
connection conn_sys;
set @@session.ob_query_timeout = 60000000;
alter system stop zone 'z4';
ob1.check_until_timeout select status from DBA_OB_ZONES where zone='z4',INACTIVE,20;
ob1.check_until_timeout select count(1) as leader_count  from CDB_OB_LS_LOCATIONS where zone='z4' and role='leader',0,20;
ob1.z4.force_stop;
ob1.check_until_timeout select count(*) from oceanbase.DBA_OB_SERVERS where zone = 'z4' and status='INACTIVE',1,60;
ob1.z4.upgrade;
ob1.z4.nstart;
ob1.check_until_timeout select count(*) from oceanbase.DBA_OB_SERVERS where zone = 'z4' and (start_service_time is null or status='INACTIVE'),0,120;
ob1.check_until_timeout  select count(1) as unsync_cnt from GV\$OB_LOG_STAT where in_sync = 'NO',0,600;
source include/check_schema_sync_for_restart.inc;
ob1.mysql alter system start zone 'z4';
sleep 2;
ob1.check_until_timeout select status from DBA_OB_ZONES where zone='z4',ACTIVE,20;
ob1.check_until_timeout select count(*) from oceanbase.__all_server where zone = 'z4' and start_service_time > 0,1,120;

# z2,z3,z4已升级完成，测试混跑期间升降级
# kill follower触发降级;
ob1.z3.obs0.force_stop;
ob1.z4.obs0.force_stop;
ob1.check_until_timeout select count(*) from oceanbase.DBA_OB_SERVERS where zone = 'z3' and status='INACTIVE',1,60;
ob1.check_until_timeout select count(*) from oceanbase.DBA_OB_SERVERS where zone = 'z4' and status='INACTIVE',1,60;
let $z4_ip0 = deploy_get_value(ob1.z4.obs0.ip);
let $z4_port0 = deploy_get_value(ob1.z4.obs0.port);
ob1.check_until_timeout select count(*) from __all_virtual_log_stat where tenant_id=$sys_tenant_id and degraded_list not like '%$z3_ip0:$z3_port0%', 0, 60;
ob1.check_until_timeout select count(*) from __all_virtual_log_stat where tenant_id=$sys_tenant_id and degraded_list not like '%$z4_ip0:$z4_port0%', 0, 60;

# start follower触发升级
ob1.z3.obs0.nstart;
ob1.z4.obs0.nstart;
ob1.check_until_timeout select count(*) from oceanbase.DBA_OB_SERVERS where zone = 'z3' and (start_service_time is null or status='INACTIVE'),0,120;
ob1.check_until_timeout select count(*) from oceanbase.DBA_OB_SERVERS where zone = 'z4' and (start_service_time is null or status='INACTIVE'),0,120;
ob1.check_until_timeout select count(*) from __all_virtual_log_stat where tenant_id=$sys_tenant_id and degraded_list like '%$z3_ip0:$z3_port0%', 0, 60;
ob1.check_until_timeout select count(*) from __all_virtual_log_stat where tenant_id=$sys_tenant_id and degraded_list like '%$z4_ip0:$z4_port0%', 0, 60;

# 9.4 升级z1
connection conn_sys;
set @@session.ob_query_timeout = 60000000;
alter system stop zone 'z1';
ob1.check_until_timeout select status from DBA_OB_ZONES where zone='z1',INACTIVE,20;
ob1.check_until_timeout select count(1) as leader_count  from CDB_OB_LS_LOCATIONS where zone='z1' and role='leader',0,20;
ob1.z1.force_stop;
ob1.check_until_timeout select count(*) from oceanbase.DBA_OB_SERVERS where zone = 'z1' and status='INACTIVE',1,60;
ob1.z1.upgrade;
ob1.z1.nstart;
ob1.check_until_timeout select count(*) from oceanbase.DBA_OB_SERVERS where zone = 'z1' and (start_service_time is null or status='INACTIVE'),0,120;
ob1.check_until_timeout  select count(1) as unsync_cnt from GV\$OB_LOG_STAT where in_sync = 'NO',0,600;
source include/check_schema_sync_for_restart.inc;
ob1.mysql alter system start zone 'z1';
sleep 2;
ob1.check_until_timeout select status from DBA_OB_ZONES where zone='z1',ACTIVE,20;
ob1.check_until_timeout select count(*) from oceanbase.__all_server where zone = 'z1' and start_service_time > 0,1,120;

# 10. 执行升级后SQL
#
connection conn_sys;
ob1.upgrade_commond_for_server post;
# 自检
set @@session.ob_query_timeout = 600000000;
alter system run job 'root_inspection';
set @@session.ob_query_timeout = 10000000;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_upgrade_inspection where info != 'succeed',0,180;

# step 11. kill follower触发降级;
ob1.z3.obs0.force_stop;
ob1.z4.obs0.force_stop;
ob1.check_until_timeout select count(*) from oceanbase.DBA_OB_SERVERS where zone = 'z3' and status='INACTIVE',1,60;
ob1.check_until_timeout select count(*) from oceanbase.DBA_OB_SERVERS where zone = 'z4' and status='INACTIVE',1,60;
let $z4_ip0 = deploy_get_value(ob1.z4.obs0.ip);
let $z4_port0 = deploy_get_value(ob1.z4.obs0.port);
# sys tenant is 4F1A
ob1.check_until_timeout select count(*) from __all_virtual_log_stat where tenant_id=$sys_tenant_id and degraded_list not like '%$z3_ip0:$z3_port0%', 0, 60;
ob1.check_until_timeout select count(*) from __all_virtual_log_stat where tenant_id=$sys_tenant_id and degraded_list not like '%$z4_ip0:$z4_port0%', 0, 60;

# step 12. start follower触发升级
ob1.z3.obs0.nstart;
ob1.z4.obs0.nstart;
ob1.check_until_timeout select count(*) from oceanbase.DBA_OB_SERVERS where zone = 'z3' and (start_service_time is null or status='INACTIVE'),0,120;
ob1.check_until_timeout select count(*) from oceanbase.DBA_OB_SERVERS where zone = 'z4' and (start_service_time is null or status='INACTIVE'),0,120;
ob1.check_until_timeout select count(*) from __all_virtual_log_stat where tenant_id=$sys_tenant_id and degraded_list like '%$z3_ip0:$z3_port0%', 0, 60;
ob1.check_until_timeout select count(*) from __all_virtual_log_stat where tenant_id=$sys_tenant_id and degraded_list like '%$z4_ip0:$z4_port0%', 0, 60;
# step 13. 验证 cluster 占位目录名称
let $arb_dir=deploy_get_value(ob1.asvr0.workdir);
# check cluster name, 1 expected
ob1.asvr0.sh_p cd $arb_dir; cd ./store/clog; ls | egrep 'cluster_1_clustername_.+' | wc -l;
connection conn_sys;
eval ALTER TENANT sys SET enable_arbitration_service = false;
eval ALTER TENANT mysql SET enable_arbitration_service = false;
ob1.check_until_timeout select count(*) from oceanbase.DBA_OB_TENANTS where arbitration_service_status != "DISABLED",0,120;
--disable_query_log
eval ALTER SYSTEM REMOVE ARBITRATION SERVICE "$arb_svr_ip:$arb_svr_port";
--enable_query_log
# check clustername dir, 0 expected
ob1.asvr0.sh_p cd $arb_dir; cd ./store/clog; ls | egrep 'cluster_1_clustername_.+' | wc -l;
--disable_query_log
eval ALTER SYSTEM ADD ARBITRATION SERVICE "$arb_svr_ip:$arb_svr_port";
--enable_query_log
eval ALTER TENANT mysql SET enable_arbitration_service = true;
eval ALTER TENANT sys SET enable_arbitration_service = true;

# check arbitration member exist for tenant's ls
ob1.check_until_timeout select count(*) from __all_virtual_log_stat where tenant_id=$sys_tenant_id and arbitration_member not like "%$arb_svr_ip:$arb_svr_port%", 0, 60;
ob1.check_until_timeout select count(*) from __all_virtual_log_stat where tenant_id=$mysql_tenant_id and arbitration_member not like "%$arb_svr_ip:$arb_svr_port%", 0, 60;
# check cluster name, 1 expected
ob1.asvr0.sh_p cd $arb_dir; cd ./store/clog; ls | egrep 'cluster_1_clustername_.+' | wc -l;

# step 14. 验证 arb server 重启后降级
ob1.asvr0.force_stop;
ob1.asvr0.nstart;
sleep 5;
ob1.z2.obs0.force_stop;
ob1.z3.obs0.force_stop;
ob1.check_until_timeout select count(*) from oceanbase.DBA_OB_SERVERS where zone = 'z2' and status='INACTIVE',1,60;
ob1.check_until_timeout select count(*) from oceanbase.DBA_OB_SERVERS where zone = 'z3' and status='INACTIVE',1,60;
# sys tenant is 4F1A
ob1.check_until_timeout select count(*) from __all_virtual_log_stat where tenant_id=$sys_tenant_id and degraded_list not like '%$z2_ip0:$z2_port0%', 0, 60;
ob1.check_until_timeout select count(*) from __all_virtual_log_stat where tenant_id=$sys_tenant_id and degraded_list not like '%$z3_ip0:$z3_port0%', 0, 60;
ob1.check_until_timeout select count(*) from __all_virtual_log_stat where tenant_id=$mysql_tenant_id and degraded_list not like '%$z2_ip0:$z2_port0%', 0, 60;
