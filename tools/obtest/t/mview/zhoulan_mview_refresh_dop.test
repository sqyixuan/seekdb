##
# owner      : zg410411
# owner group: mv
# description: 测试mview增量刷新并行度
##
ob1=OBI(cluster=1,oblog_version=current,proxy_num=0,asvr_num=0);
ob1.reboot;

ob_connect(conn_z1_sys, ob1.z1.obs0, root, , oceanbase, , USE_MYSQL_CONNECTOR);
alter system set syslog_level = 'sql.*:trace';
CREATE RESOURCE UNIT unit_1 MAX_CPU 2, MEMORY_SIZE '4G';
CREATE RESOURCE POOL pool_1 UNIT = 'unit_1', UNIT_NUM = 1;
CREATE TENANT mysql RESOURCE_POOL_LIST = ('pool_1'), primary_zone='z1' set ob_tcp_invited_nodes='%';

ob_connect(conn_mysql1, ob1.z1.obs0, root@mysql, ,test, , USE_OB_CONNECTOR);

# 1. 不设置刷新并行度，记录增量刷新时间intv1
create table t (i int auto_increment, k bigint, primary key(i));
create materialized view log on t with(k) purge start with sysdate() next sysdate() + interval 1 day;
create materialized view tf refresh fast as select count(*) as cnt, k as k from t group by k;
insert /*+ parallel(8) enable_parallel_dml */ into t(k) select uniform(1,10,random()) from table(generator(1000000));
let $start_time = query_get_value(select now() as value, value, 1);
call dbms_mview.refresh("tf","f");
let $intv1 = query_get_value(select timestampdiff(second, '$start_time', now()) as value, value, 1);

# 2. 设置刷新并行度为15，记录增量刷新时间intv2
drop materialized view log on t;
drop table t;
drop materialized view tf;
create table t (i int auto_increment, k bigint, primary key(i));
create materialized view log on t parallel 8 with(k) purge start with sysdate() next sysdate() + interval 1 day;
create materialized view tf refresh fast as select count(*) as cnt, k as k from t group by k;
insert /*+ parallel(8) enable_parallel_dml */ into t(k) select uniform(1,10,random()) from table(generator(1000000));
let $start_time = query_get_value(select now() as value, value, 1);
call dbms_mview.refresh("tf","f", 15);
let $intv2 = query_get_value(select timestampdiff(second, '$start_time', now()) as value, value, 1);

# 3. 预期刷新时间intv2应该小于intv1
if ($intv2 < $intv1)
{
  --echo success;
}

# 4. 检查px日志，确认并行度设置生效
let $work_dir=deploy_get_value(ob1.z1.obs0.workdir);
--disable_query_log
ob1.z1.obs0.sh_p cd $work_dir/log; grep -a "px_dop=15" observer.log* | wc -l | awk '{if (\$1 > 0) print 1}';
--enable_query_log

