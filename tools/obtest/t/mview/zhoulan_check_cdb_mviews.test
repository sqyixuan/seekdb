##
# owner      : zg410411
# owner group: mv
# description: 测试CDB_MVIEWS的正确性
##
ob1=OBI(cluster=1,oblog_version=current,proxy_num=0,asvr_num=0);
ob1.reboot;

ob_connect(conn_z1_sys, ob1.z1.obs0, root, , oceanbase, , USE_MYSQL_CONNECTOR);
CREATE RESOURCE UNIT unit_1 MAX_CPU 2, MEMORY_SIZE '4G';
CREATE RESOURCE POOL pool_1 UNIT = 'unit_1', UNIT_NUM = 1;
CREATE TENANT mysql RESOURCE_POOL_LIST = ('pool_1'), primary_zone='z1' set ob_tcp_invited_nodes='%';
let $tenant_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name='mysql', tenant_id, 1);
CREATE RESOURCE UNIT unit_2 MAX_CPU 2, MEMORY_SIZE '4G';
CREATE RESOURCE POOL pool_2 UNIT = 'unit_1', UNIT_NUM = 1;
CREATE TENANT mysql2 RESOURCE_POOL_LIST = ('pool_2'), primary_zone='z1' set ob_tcp_invited_nodes='%';
let $tenant_id2 = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name='mysql', tenant_id, 1);
ob_connect(conn_mysql1, ob1.z1.obs0, root@mysql, ,test, , USE_OB_CONNECTOR);
ob_connect(conn_mysql2, ob1.z1.obs0, root@mysql2, ,test, , USE_OB_CONNECTOR);

## ------------check mv creation with concurrent compaction------------
connection conn_mysql1;
create table t1(c1 int, c2 int);
create materialized view mv1 as select * from t1;

connection conn_mysql2;
create table t1(c1 int, c2 int);
create materialized view mv1 as select * from t1;

connection conn_z1_sys;
select OWNER, MVIEW_NAME from oceanbase.CDB_MVIEWS;
