
--echo "1. =========== bootstrap ==========="
ob1=OBI(cluster=1:1, proxy_num=0, init_unit_cpu=0);
source include/mini_ob_config.inc;
ob1.set extra_config=$mini_ob_config;
ob1.reboot;

ob1.mysql ALTER SYSTEM SET enable_rebalance = 'false';
ob1.mysql ALTER SYSTEM SET enable_rereplication = 'true';

let $proxy_ip = deploy_get_value(ob1.z1.obs0.ip);
let $proxy_port = deploy_get_value(ob1.z1.obs0.mysql_port);
connect(sys_conn, $proxy_ip, root@sys,,oceanbase, $proxy_port);

--echo "2. =========== create tenant ==========="
source include/create_unit_config.inc;
ob1.mysql CREATE RESOURCE POOL tenant_pool UNIT = "2c2g", UNIT_NUM = 1, ZONE_LIST = ('z1', 'z2');
ob1.mysql CREATE TENANT test_tenant RESOURCE_POOL_LIST=('tenant_pool') SET ob_tcp_invited_nodes='%';

alter tenant test_tenant set primary_zone='z1';
ob1.check_until_timeout select role from oceanbase.__all_virtual_ls_meta_table where ls_id=1001 and zone='z1', 1, 60;

--echo "3. =========== create mv ==========="
ob_connect(conn_mysql, ob1.z1.obs0, root@test_tenant, , test, , USE_MYSQL_CONNECTOR);
connection conn_mysql;

CREATE TABLE t1(col1 INT, col2 INT, col3 INT);
CREATE MATERIALIZED VIEW LOG ON t1 WITH PRIMARY KEY, ROWID, SEQUENCE (col1, col2, col3) INCLUDING NEW VALUES;

--echo "4. =========== insert data ==========="
insert into t1 values(1,1,1);
let $seq1 = query_get_value(select SEQUENCE\$\$ as seq from MLOG\$_t1 order by ora_rowscn desc limit 1, seq, 1);

alter tenant test_tenant set primary_zone='z2';
ob1.check_until_timeout select role from oceanbase.__all_virtual_ls_meta_table where ls_id=1001 and zone='z2', 1, 60;

insert into t1 values(1,1,1);
let $seq2 = query_get_value(select SEQUENCE\$\$ as seq from test.MLOG\$_t1 order by ora_rowscn desc limit 1, seq, 1);

if ($seq1 < $seq2)
{
  echo "seq1 < seq2";
}

alter tenant test_tenant set primary_zone='z1';
ob1.check_until_timeout select role from oceanbase.__all_virtual_ls_meta_table where ls_id=1001 and zone='z1', 1, 60;

insert into t1 values(1,1,1);
let $seq3 = query_get_value(select SEQUENCE\$\$ as seq from test.MLOG\$_t1 order by ora_rowscn desc limit 1, seq, 1);

if ($seq2 < $seq3)
{
  echo "seq2 < seq3";
}

--echo "5. =========== materialized view case ==========="
CREATE TABLE t2(col1 INT, col2 INT, col3 INT);
CREATE MATERIALIZED VIEW LOG ON t2 WITH PRIMARY KEY, ROWID, SEQUENCE (col1, col2, col3) INCLUDING NEW VALUES;
CREATE MATERIALIZED VIEW mv(count,sum) ENABLE ON QUERY COMPUTATION as select count(col2), sum(col2) from t2;

insert into t2 values(1,1,1);

alter tenant test_tenant set primary_zone='z2';
ob1.check_until_timeout select role from oceanbase.__all_virtual_ls_meta_table where ls_id=1001 and zone='z2', 1, 60;

update t2 set col2=2;

alter tenant test_tenant set primary_zone='z1';
ob1.check_until_timeout select role from oceanbase.__all_virtual_ls_meta_table where ls_id=1001 and zone='z1', 1, 60;

// update
update t2 set col2=3;

select*from mv;
