##
# owner      : zg410411
# owner group: mv
# description: 测试replace mlog过程中切主
##

# 0. prepare
ob1=OBI(cluster=1:1:1,proxy_num=0);
source include/mini_ob_config.inc;
ob1.set extra_config=$mini_ob_config;
ob1.reboot;

ob_connect(conn_sys, ob1.z1.obs0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);
eval CREATE RESOURCE UNIT unit_1 MAX_CPU 2, MEMORY_SIZE '4G';
eval CREATE RESOURCE POOL pool_1 UNIT = 'unit_1', UNIT_NUM = 1;
eval CREATE TENANT mysql RESOURCE_POOL_LIST = ('pool_1'), primary_zone='z1;z2' set ob_tcp_invited_nodes='%';
alter system set debug_sync_timeout = '10000s';
ob1.check_until_timeout select value from gv\$ob_parameters where name = 'debug_sync_timeout', 10000s, 10;
alter tenant sys set primary_zone='z2';
ob1.check_until_timeout select count(*) from oceanbase.__all_server where zone = 'z2' and with_rootserver=1, 1, 60;
sleep 2;
ob_connect(conn_mysql1, ob1.z1.obs0, root@mysql, ,test, , USE_OB_CONNECTOR);
ob_connect(conn_mysql2, ob1.z1.obs0, root@mysql, ,test, , USE_OB_CONNECTOR);

--echo 1. check the REBUILD_SCHEMA phase is reentrant
ob1.mysql set ob_global_debug_sync = 'REBUILD_INDEX_WAIT_CREATE_TASK_FINISH wait_for signal execute 1';
connection conn_mysql1;
create table t1(c1 int, c2 int);
let $t1_id = query_get_value(select table_id from oceanbase.__all_virtual_table where tenant_id = 1002 and table_name = 't1', table_id, 1);
create materialized view log on t1 with (c1);
send create or replace materialized view log on t1 with (c2);
sleep 2;
connection conn_mysql2;
insert into t1 values(1, 1);
--disable_query_log
eval select table_name from oceanbase.__all_table where data_table_id = $t1_id;
--enable_query_log
select * from mlog$_t1;
select * from tmlog$_t1;
ob1.z2.stop;
ob1.check_until_timeout select count(*) from oceanbase.__all_server where zone = 'z2' and status="INACTIVE" or start_service_time<=0, 1, 60;
connection conn_mysql2;
insert into t1 values(2, 2);
--disable_query_log
eval select table_name from oceanbase.__all_table where data_table_id = $t1_id;
--enable_query_log
select * from mlog$_t1;
select * from tmlog$_t1;
ob1.mysql set ob_global_debug_sync = 'now signal signal';
ob1.mysql set ob_global_debug_sync = 'reset';
connection conn_mysql1;
reap;
insert into t1 values(3, 3);
--disable_query_log
eval select table_name from oceanbase.__all_table where data_table_id = $t1_id;
--enable_query_log
select * from mlog$_t1;

--echo 2. check the PURGE_OLD_MLOG phase is reentrant
ob1.mysql set ob_global_debug_sync = 'REBUILD_INDEX_WAIT_PURGE_OLD_MLOG wait_for signal execute 1';
connection conn_mysql1;
create table t2(c1 int, c2 int);
let $t2_id = query_get_value(select table_id from oceanbase.__all_virtual_table where tenant_id = 1002 and table_name = 't2', table_id, 1);
create materialized view log on t2 with (c1);
send create or replace materialized view log on t2 with (c2);
sleep 2;
connection conn_mysql2;
insert into t2 values(1, 1);
--disable_query_log
eval select table_name from oceanbase.__all_table where data_table_id = $t2_id;
--enable_query_log
select * from mlog$_t2;
select * from tmlog$_t2;
ob1.z2.stop;
ob1.check_until_timeout select count(*) from oceanbase.__all_server where zone = 'z2' and status="INACTIVE" or start_service_time<=0, 1, 60;
connection conn_mysql2;
insert into t2 values(2, 2);
--disable_query_log
eval select table_name from oceanbase.__all_table where data_table_id = $t2_id;
--enable_query_log
select * from mlog$_t2;
select * from tmlog$_t2;
ob1.mysql set ob_global_debug_sync = 'now signal signal';
ob1.mysql set ob_global_debug_sync = 'reset';
connection conn_mysql1;
reap;
insert into t2 values(3, 3);
--disable_query_log
eval select table_name from oceanbase.__all_table where data_table_id = $t2_id;
--enable_query_log
select * from mlog$_t2;

--echo 3. check the SWITCH_INDEX_SCHEMA phase is reentrant
ob1.mysql set ob_global_debug_sync = 'REBUILD_VEC_INDEX_SWITCH_INDEX_NAME wait_for signal execute 1';
connection conn_mysql1;
create table t3(c1 int, c2 int);
let $t3_id = query_get_value(select table_id from oceanbase.__all_virtual_table where tenant_id = 1002 and table_name = 't3', table_id, 1);
create materialized view log on t3 with (c1);
send create or replace materialized view log on t3 with (c2);
sleep 2;
connection conn_mysql2;
insert into t3 values(1, 1);
--disable_query_log
eval select table_name from oceanbase.__all_table where data_table_id = $t3_id;
--enable_query_log
select * from mlog$_t3;
select * from tmlog$_t3;
ob1.z2.stop;
ob1.check_until_timeout select count(*) from oceanbase.__all_server where zone = 'z2' and status="INACTIVE" or start_service_time<=0, 1, 60;
connection conn_mysql2;
insert into t3 values(2, 2);
--disable_query_log
eval select table_name from oceanbase.__all_table where data_table_id = $t3_id;
--enable_query_log
select * from mlog$_t3;
select * from tmlog$_t3;
ob1.mysql set ob_global_debug_sync = 'now signal signal';
ob1.mysql set ob_global_debug_sync = 'reset';
connection conn_mysql1;
reap;
insert into t3 values(3, 3);
--disable_query_log
eval select table_name from oceanbase.__all_table where data_table_id = $t3_id;
--enable_query_log
select * from mlog$_t3;

--echo 4. check the DROP_SCHEMA phase is reentrant
ob1.mysql set ob_global_debug_sync = 'REBUILD_INDEX_WAIT_DROP_TASK_FINISH wait_for signal execute 1';
connection conn_mysql1;
create table t4(c1 int, c2 int);
let $t4_id = query_get_value(select table_id from oceanbase.__all_virtual_table where tenant_id = 1002 and table_name = 't4', table_id, 1);
create materialized view log on t4 with (c1);
send create or replace materialized view log on t4 with (c2);
sleep 2;
connection conn_mysql2;
insert into t4 values(1, 1);
--disable_query_log
eval select table_name from oceanbase.__all_table where data_table_id = $t4_id;
--enable_query_log
select * from mlog$_t4;
ob1.z2.stop;
ob1.check_until_timeout select count(*) from oceanbase.__all_server where zone = 'z2' and status="INACTIVE" or start_service_time<=0, 1, 60;
connection conn_mysql2;
insert into t4 values(2, 2);
--disable_query_log
eval select table_name from oceanbase.__all_table where data_table_id = $t4_id;
--enable_query_log
select * from mlog$_t4;
ob1.mysql set ob_global_debug_sync = 'now signal signal';
ob1.mysql set ob_global_debug_sync = 'reset';
connection conn_mysql1;
reap;
insert into t4 values(3, 3);
--disable_query_log
eval select table_name from oceanbase.__all_table where data_table_id = $t4_id;
--enable_query_log
select * from mlog$_t4;
