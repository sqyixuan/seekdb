# owner: wangxiaohui.wxh
# owner group: physical_backup
# Testing Case: basic restore

ob1=OBI(cluster=1:1:1, proxy_num=0);

source include/mini_ob_config.inc;
ob1.set extra_config=$mini_ob_config;
ob1.z1.obs0.set extra_config = "cache_wash_threshold='1G',_ob_minor_merge_schedule_interval='3s'";
ob1.z2.obs0.set extra_config = "cache_wash_threshold='1G',_ob_minor_merge_schedule_interval='3s'";
ob1.z3.obs0.set extra_config = "cache_wash_threshold='1G',_ob_minor_merge_schedule_interval='3s'";

let $backup_cluster_name = deploy_get_value(ob1.get_cluster_name);
let $backup_cluster_id = deploy_get_value(ob1.get_cluster_id);
let $backup_ip       = deploy_get_value(ob1.z1.obs0.ip);
let $backup_port     = deploy_get_value(ob1.z1.obs0.mysql_port);
let $restore_ip         = deploy_get_value(ob2.z1.obs0.ip);
let $restore_port       = deploy_get_value(ob2.z1.obs0.mysql_port);
let $backup_dest = deploy_get_value(ob1.get_backup_dest);
let $backup_oracle_tenant   = backup_oracle_tenant;
let $backup_mysql_tenant    = backup_mysql_tenant;
let $restore_oracle_tenant = restore_oracle_tenant;
let $restore_oracle_tenant_new = restore_oracle_tenant_new;
let $restore_mysql_tenant = restore_mysql_tenant;
let $restore_mysql_tenant_new = restore_mysql_tenant_new;
let $log_backup_dest = deploy_get_value(ob1.get_log_backup_dest $backup_mysql_tenant);
let $data_backup_dest = deploy_get_value(ob1.get_data_backup_dest $backup_mysql_tenant);
let $restore_log_archive_dest = deploy_get_value(ob1.get_log_backup_dest $restore_mysql_tenant);

# 必须先stop掉老的，删除才能有效，不然可能会有残留。
ob1.force_stop;
ob1.clean_backup_dest;
ob1.reboot;

# 固定sys租户规格
ob1.mysql alter resource unit sys_unit_config memory_size='2G';

connect(backup_sys_conn, $backup_ip, root@sys,,oceanbase, $backup_port);
connection backup_sys_conn;
use oceanbase;
alter system set resource_hard_limit = 1000;
alter system set _restore_idle_time = '10s';
CREATE RESOURCE UNIT small_unit MIN_CPU=1, MAX_CPU=1, MEMORY_SIZE='4G';
CREATE RESOURCE POOL small_pool_1 UNIT small_unit, UNIT_NUM 1, ZONE_LIST ('z1','z2','z3');
CREATE RESOURCE POOL small_pool_2 UNIT small_unit, UNIT_NUM 1, ZONE_LIST ('z1','z2','z3');

ob1.mysql alter system set _backup_idle_time = '10s';
ob1.mysql alter system set enable_async_syslog = false;
ob1.mysql alter system set ob_compaction_schedule_interval = '10s' tenant all_user;
alter system set ob_compaction_schedule_interval='5s' tenant=all;
alter system set merger_check_interval='10s' tenant=all;
alter system set ob_compaction_schedule_interval = '10s' tenant = all;


--echo ===============================================================
--echo ==================     create tenant   ========================
--echo ===============================================================

ob1.mysql CREATE RESOURCE POOL resource_pool UNIT = "small_unit", UNIT_NUM = 1, ZONE_LIST = ('z1', 'z2');
ob1.mysql CREATE TENANT backup_mysql_tenant resource_pool_list=('resource_pool'), locality = "F@z1,F@z2", primary_zone = "z1" set ob_tcp_invited_nodes='%', ob_compatibility_mode='mysql';
source include/check_schema_sync.inc;
connection backup_sys_conn;
let $backup_mysql_tenant_id = query_get_value(select tenant_id from oceanbase.__all_tenant where tenant_name='$backup_mysql_tenant', tenant_id, 1);
let $resource_pool_id = deploy_get_value(ob1.select select resource_pool_id from oceanbase.__all_resource_pool where tenant_id = $backup_mysql_tenant_id, resource_pool_id, 1);
let $ls_cnt = deploy_get_value(ob1.select select count(unique(ls_id)) as ls_cnt from oceanbase.__all_virtual_ls_info where tenant_id = $backup_mysql_tenant_id, ls_cnt, 1);
let $src_ls_id = 1001;
--echo create tenant finished
ob1.mysql alter system set ob_compaction_schedule_interval = '10s' tenant backup_mysql_tenant;

# 设置undo retention
ob1.mysql alter system set undo_retention = 86400;

--echo ===============================================================
--echo ==================     create table ===========================
--echo ===============================================================
connect(sys_conn_mysql, $backup_ip, root@$backup_mysql_tenant,,oceanbase, $backup_port);
connection sys_conn_mysql;
set global wait_timeout = 288000;

--disable_all_result_log
eval alter system set data_backup_dest='$data_backup_dest';
eval alter system set log_archive_dest='location=$log_backup_dest';
ob1.set_piece_switch_interval $backup_mysql_tenant_id 0 2m;
--enable_all_result_log

connection sys_conn_mysql;
create user test IDENTIFIED BY "test";
grant all on *.* to test WITH GRANT OPTION;

connect(backup_mysql_conn, $backup_ip,test@$backup_mysql_tenant,test,test, $backup_port);
connection backup_mysql_conn;

# 创建小表
create table t1(a int, b int, c int, PRIMARY KEY (a));
insert into t1(a, b) values(1, 1);
insert into t1(a, b) values(2, 2);
insert into t1(a, b) values(3, 3);
insert into t1(a, b) values(4, 4);

# 创建mview
create tablegroup tg1 sharding='PARTITION';
create table mv_tt(c1 int,c2 int, primary key(c1,c2)) tablegroup='tg1' partition by hash(c1) partitions 2;
create table mv_tg(c2 int, c3 int, primary key(c2)) duplicate_scope = 'cluster' duplicate_read_consistency='weak';
insert into mv_tt values(1,1), (2,1),(3,1);
insert into mv_tg values(1,1), (2,1),(3,2);
create materialized view mv1 (primary key(mv_tt_c1,mv_tt_c2)) tablegroup='tg1' partition by hash(mv_tt_c1) partitions 2 REFRESH FAST ON DEMAND  ENABLE QUERY REWRITE ENABLE ON QUERY COMPUTATION as select /*+read_consistency(weak) use_nl(mv_tt mv_tg) leading(mv_tt mv_tg) use_das(mv_tg) no_use_nl_materialization(mv_tg)*/ mv_tt.c1 mv_tt_c1,mv_tt.c2 mv_tt_c2,mv_tg.c2 mv_tg_c2,mv_tg.c3 mv_tg_c3 from mv_tt join mv_tg on mv_tt.c2=mv_tg.c2;

select /*+read_consistency(weak) use_nl(mv_tt mv_tg) leading(mv_tt mv_tg) use_das(mv_tg) no_use_nl_materialization(mv_tg)*/ mv_tt.c1 mv_tt_c1,mv_tt.c2 mv_tt_c2,mv_tg.c2 mv_tg_c2,mv_tg.c3 mv_tg_c3 from mv_tt join mv_tg on mv_tt.c2=mv_tg.c2;

--echo ===============================================================
--echo ==================     start archive   ========================
--echo ===============================================================
ob1.mysql alter system archivelog;
ob1.check_until_timeout select status from oceanbase.CDB_OB_ARCHIVELOG where tenant_id=$backup_mysql_tenant_id, DOING, 600;

ob1.mysql alter system major freeze tenant = '$backup_mysql_tenant';

# 等待合并结果
connection backup_sys_conn;
source include/wait_tenant_major_merge.inc;

connection backup_mysql_conn;
let $major_merge_scn = deploy_get_value(ob1.select select last_merged_scn from oceanbase.__all_virtual_merge_info where tenant_id = $backup_mysql_tenant_id, last_merged_scn, 1);
ob1.check_until_timeout select min(mv_major_merge_scn) = $major_merge_scn from oceanbase.__all_virtual_ls_info where tenant_id = $backup_mysql_tenant_id and ls_id not like 1, 1 , 180;
ob1.check_until_timeout select count(*) as cnt from oceanbase.__all_virtual_core_table where column_name = 'major_refresh_mv_merge_scn' and tenant_id = $backup_mysql_tenant_id, 1, 120;
ob1.check_until_timeout select column_value = $major_merge_scn as tenant_mv_merge_scn_check from oceanbase.__all_virtual_core_table where column_name = 'major_refresh_mv_merge_scn' and tenant_id = $backup_mysql_tenant_id, 1, 60;

insert into t1(a, b) values(5, 5);
insert into t1(a, b) values(6, 6);

# 创建空表
create table t2(a int, b int, c int, PRIMARY KEY (a));

--echo ===============================================================
--echo ==================     start backup data   ====================
--echo ===============================================================
# write some data after data backup
begin;
insert into t1(a, b) values(7, 7);
insert into t1(a, b) values(8, 8);
update t1 set c=1;
update t1 set b=b+1;
commit;
begin;
update t1 set c=2;
delete from t1 where a=1;
commit;

create table t3(a int, b int, c int, PRIMARY KEY (a));
insert into t3(a, b, c) values(1, 1, 1);
insert into t3(a, b, c) values(2, 2, 1);
begin;
insert into t3(a, b, c) values(3, 3, 3);
insert into t3(a, b, c) values(4, 4, 4);
update t3 set c=1;
update t3 set b=b+1;
commit;

sleep 10;
connection backup_mysql_conn;
insert into t3(a, b, c) values(5, 5, 5);
insert into t3(a, b, c) values(6, 6, 6);
commit;

create materialized view mv2 (primary key(mv_tt_c1,mv_tt_c2)) tablegroup='tg1' partition by hash(mv_tt_c1) partitions 2 REFRESH FAST ON DEMAND  ENABLE QUERY REWRITE ENABLE ON QUERY COMPUTATION as select /*+read_consistency(weak) use_nl(mv_tt mv_tg) leading(mv_tt mv_tg) use_das(mv_tg) no_use_nl_materialization(mv_tg)*/ mv_tt.c1 mv_tt_c1,mv_tt.c2 mv_tt_c2,mv_tg.c2 mv_tg_c2,mv_tg.c3 mv_tg_c3 from mv_tt join mv_tg on mv_tt.c2=mv_tg.c2;

# 做第二次合并
ob1.mysql alter system major freeze tenant = '$backup_mysql_tenant';
# 等待合并结果
source include/wait_tenant_major_merge.inc;

# 做第三次合并
ob1.mysql alter system major freeze tenant = '$backup_mysql_tenant';
# 等待合并结果
source include/wait_tenant_major_merge.inc;

sleep 3;
connect(backup_sys_conn, $backup_ip, root@sys,,oceanbase, $backup_port);
connection backup_sys_conn;
use oceanbase;
let $restore_path = $log_backup_dest,$data_backup_dest;

#### 备份多次合并结果
ob1.mysql alter system backup database;
ob1.check_until_timeout select count(*) c from __all_backup_job_history where tenant_id = 1, 1, 600;
ob1.check_until_timeout select result from oceanbase.CDB_OB_BACKUP_JOB_HISTORY where tenant_id = $backup_mysql_tenant_id, 0, 10;
ob1.check_until_timeout select result from oceanbase.CDB_OB_BACKUP_TASK_HISTORY where tenant_id = $backup_mysql_tenant_id, 0, 10;

ob1.check_until_timeout select count(*) from __all_virtual_mem_leak_checker_info where mod_name like 'BackupIO', 0, 60;

--echo ===============================================================
--echo ===============  CALC RESTORE POINT  ==========================
--echo ===============================================================
let $now = `select timestamp_to_scn(current_timestamp(6))`;
ob1.check_until_timeout select checkpoint_scn > $now from CDB_OB_ARCHIVELOG where tenant_id = $backup_mysql_tenant_id, 1, 600;

--echo ===============================================================
--echo ===============  FULL RESTORE  ===============================
--echo ===============================================================
######## locality 2
ob1.mysql alter system set_tp tp_name = ERRSIM_WAIT_RESTORE_SAFE_MVIEW, error_code = 4023, frequency = 1;

ob1.mysql alter system restore $restore_mysql_tenant from '$restore_path' until scn=$now with 'pool_list=small_pool_1&primary_zone=z1&locality=F@z1,F@z2';
ob1.check_until_timeout SELECT status FROM __all_tenant WHERE tenant_id = 1003, NORMAL, 600;
ob1.mysql alter system set ob_compaction_schedule_interval = '10s' tenant $restore_mysql_tenant;
ob1.check_until_timeout select count(*) from __all_virtual_restore_job where tenant_id = 1004 and name = 'status' and value = 'UPGRADE', 1, 600;

let $sys_ip_port = deploy_get_value(ob1.select select concat(svr_ip,':',svr_port) as host from __all_virtual_ls_meta_table where tenant_id = 1004 and ls_id =  1 and role = 1 order by svr_ip, svr_port limit 1, host, 1);
let $dst = deploy_get_value(ob1.get_obs_by_addr $sys_ip_port);
$dst.check_log_until_success -c "exist new mv in restore";

