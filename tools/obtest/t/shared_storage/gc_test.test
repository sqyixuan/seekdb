connection gc_conn_7;
create table test(c1 bigint, c2 longtext, c3 longtext, c4 varchar(1024));
insert /*+ query_timeout(100000000000) parallel(32) enable_parallel_dml */ into test select random() c1, randstr(1024, random()) c2, randstr(1024,random()) c3, randstr(1024,random()) c4 from table(generator(100000));
connection sys_conn;
let $tenant_id = query_get_value(select tenant_id from __all_tenant where tenant_name = 'gc_tenant_8',tenant_id,1);
let $unit_id = query_get_value(select unit_id from GV\$OB_UNITS where tenant_id = $tenant_id and zone = 'z1', unit_id, 1);
