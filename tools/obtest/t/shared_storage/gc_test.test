#---------------------------------------------------
#test case 10: recyclebin purge
#---------------------------------------------------
SET GLOBAL recyclebin = 1;
connection sys_conn;

create resource pool gc_test_resource_pool_4 unit gc_test_unit_1, unit_num 1, zone_list = ('z1', 'z2');
create tenant gc_tenant_7 primary_zone = 'z1', resource_pool_list=('gc_test_resource_pool_4') set ob_tcp_invited_nodes = '%';
connect(gc_conn_6, $proxy_ip, root@gc_tenant_7,,test, $proxy_port);
connection gc_conn_6;
create table test(c1 bigint, c2 longtext, c3 longtext, c4 varchar(1024));
insert /*+ query_timeout(100000000000) parallel(32) enable_parallel_dml */ into test select random() c1, randstr(1024, random()) c2, randstr(1024,random()) c3, randstr(1024,random()) c4 from table(generator(100000));
connection sys_conn;
let $tenant_id = query_get_value(select tenant_id from __all_tenant where tenant_name = 'gc_tenant_7',tenant_id,1);
let $unit_id = query_get_value(select unit_id from GV\$OB_UNITS where tenant_id = $tenant_id and zone = 'z1', unit_id, 1);
let $svr_ip = query_get_value(select svr_ip from GV\$OB_UNITS where tenant_id = $tenant_id and zone = 'z1' and unit_id=$unit_id, svr_ip, 1);
let $svr_port = query_get_value(select svr_port from GV\$OB_UNITS where tenant_id = $tenant_id and zone = 'z1' and unit_id = $unit_id, svr_port, 1);
let $server_id = query_get_value(select id from __all_server where svr_ip = '$svr_ip' and svr_port = $svr_port, id, 1);
let $local_dir = query_get_value(show parameters where name = 'data_dir' and svr_ip = '$svr_ip' and svr_port = $svr_port, value, 1); 
let $endpoint = query_get_value(select endpoint from __all_virtual_server_storage where svr_ip = '$svr_ip' and svr_port = $svr_port, endpoint, 1);
let $oss_location = query_get_value(select path from __all_zone_storage where zone = 'z1', path, 1);

drop tenant gc_tenant_7;
sleep 5;
let $tenant_name = query_get_value(show recyclebin, original_name, 1);
PURGE RECYCLEBIN;
sleep 30;
ob1.z1.obs0.check_tenant_dir_exists $svr_ip, $tenant_id, $server_id, $local_dir, private;
ob1.z1.obs0.check_tenant_dir_exists $endpoint, $tenant_id, $server_id, $oss_location, private;



