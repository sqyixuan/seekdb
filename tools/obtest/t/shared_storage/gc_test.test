# author: 哈嗖
# Storage QA Team 2

ob1=OBI(cluster=2:2:2,proxy_num=1);
ob1.reboot;

let $proxy_ip = deploy_get_value(ob1.proxy0.ip);
let $proxy_port = deploy_get_value(ob1.proxy0.port);
connect(sys_conn, $proxy_ip, root@sys,,oceanbase, $proxy_port);
connection sys_conn;
SET GLOBAL recyclebin = 0;
connection sys_conn;
ob1.mysql alter system set _ss_deleted_tablet_gc_time = '5s' tenant sys;

ob1.mysql CREATE RESOURCE UNIT gc_test_unit_1 MAX_CPU 1, MEMORY_SIZE '2G', DATA_DISK_SIZE = '2G';
ob1.mysql CREATE RESOURCE POOL gc_test_resource_pool_1 UNIT gc_test_unit_1, UNIT_NUM 2, ZONE_LIST = ('z1', 'z2');


