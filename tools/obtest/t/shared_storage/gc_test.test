#---------------------------------------------------
# test case 2: unit gc
#---------------------------------------------------
ob1.mysql ALTER SYSTEM SET enable_rebalance = false;
ob1.mysql ALTER SYSTEM SET enable_transfer = false;
ob1.mysql alter resource pool gc_test_resource_pool_1 unit_num 1;
ob1.mysql CREATE TENANT gc_tenant_2 primary_zone = 'z1', resource_pool_list=('gc_test_resource_pool_1') set ob_tcp_invited_nodes = '%';
let $tenant_id = query_get_value(select tenant_id from __all_tenant where tenant_name = 'gc_tenant_2', tenant_id, 1);
let $unit_id = query_get_value(select unit_id from GV\$OB_UNITS where tenant_id = $tenant_id and zone = 'z1', unit_id, 1);
let $origin_ip = query_get_value(select SVR_IP from GV\$OB_UNITS where tenant_id = $tenant_id and zone = 'z1', svr_ip, 1);
let $origin_port = query_get_value(select SVR_PORT from GV\$OB_UNITS where tenant_id = $tenant_id and zone = 'z1', svr_port, 1);
let $server_id = query_get_value(select id from __all_server where svr_ip = '$origin_ip' and svr_port = $origin_port, id, 1);
let $dest_ip = query_get_value(select svr_ip from __all_server where zone = 'z1' and id != $server_id, svr_ip, 1);
let $dest_port = query_get_value(select svr_port from __all_server where zone = 'z1' and id != $server_id, svr_port, 1);
let $local_dir = query_get_value(show parameters where name = 'data_dir' and svr_ip = '$origin_ip' and svr_port = $origin_port, value, 1);
let $oss_location = query_get_value(select path from __all_zone_storage where zone = 'z1', path, 1);
let $endpoint = query_get_value(select endpoint from __all_virtual_server_storage where svr_ip = '$origin_ip' and svr_port = $origin_port, endpoint, 1);
connect(tenant_conn, $proxy_ip, root@gc_tenant_2,,test, $proxy_port);
connection tenant_conn;
create table unit_test(c1 bigint, c2 longtext, c3 longtext, c4 varchar(1024));
insert /*+ query_timeout(100000000000) parallel(32) enable_parallel_dml */ into unit_test select random() c1, randstr(1024, random()) c2, randstr(1024,random()) c3, randstr(1024,random()) c4 from table(generator(100000));
connection sys_conn;
# trigger gc by migrating a unit
eval ALTER SYSTEM MIGRATE UNIT = $unit_id destination = '$dest_ip:$dest_port';
ob1.check_until_timeout select JOB_STATUS status from DBA_OB_UNIT_JOBS where unit_id = $unit_id and JOB_TYPE = 'MIGRATE_UNIT', SUCCESS, 600;
ob1.check_until_timeout select SVR_PORT from GV\$OB_UNITS where unit_id = $unit_id and svr_ip = '$dest_ip', $dest_port, 300;
ob1.z1.obs0.check_tenant_dir_exists $origin_ip, $tenant_id, $server_id, $local_dir, private;
sleep 30;
ob1.z1.obs0.check_tenant_dir_exists $endpoint, $tenant_id, $server_id, $oss_location, private;


