#######################################################################################
#owner : rs@all
#owner group: rs
#description: quick test
# 测试点：
# 本case是obtest准入case，是一堆功能验证的集合。每个功能场景都对应一个inc文件，例如：
# 1. t/quick/include/add_server.inc              添加server
# 2. t/quick/include/create_mysql_tenant.inc     创建租户
#
# 新增验证case方法：
# 1. 参照t/quick/include/add_server.inc，新增验证case文件
# 2. 将case放在本文件合适的位置，格式参照其他case格式
# 3. 修改CODEOWNER文件，标注inc文件的owner
# 4. 运行本case，更新result文件
#
# 说明：（1）在验证add server后会成为2:2:2部署的集群
#       （2）在验证创建租户后会有mysql租户
#       （3）可使用connection conn_sys/conn_mysql登录sys或者mysql租户
#       （4）可共享的变量：
#            $mysql_tenant_id  mysql租户id
#            $sys_tenant_id    sys租户id
#        (5) 尽量复用已有的case文件
#########################################################################################

ob1=OBI(cluster=2:2:3,proxy_num=0);

let $extra_conf = "cpu_count=16,memory_limit='20G',system_memory='5G',__min_full_resource_pool_memory='1073741824',cache_wash_threshold='1G',enable_async_syslog=false,_private_buffer_size='16K',_fast_commit_callback_count='1',log_disk_size='20G'";
ob1.z1.obs0.set extra_config=$extra_conf;
ob1.z2.obs0.set extra_config=$extra_conf;
ob1.z3.obs0.set extra_config=$extra_conf;
ob1.z1.obs1.set status=disable;
ob1.z2.obs1.set status=disable;
ob1.z3.obs1.set status=disable;
ob1.z3.obs2.set status=disable;

# case 1. 验证bootstrap
--echo ===============================================================
--echo ====================     bootstrap   ==========================
--echo ===============================================================
--echo test case for bootstrap begin
ob1.reboot;
sleep 3;
let $sys_tenant_id = 1;
ob1.mysql alter tenant sys set primary_zone = 'z3;z2;z1';
ob1.mysql alter system set enable_rebalance='false';
ob1.check_until_timeout select role from __all_ls_meta_table where tenant_id=1 and ls_id=1 and zone='z3', 1, 600;
--echo test case for bootstrap finish

# case 2. 验证add server @jingyu.cr
--echo ===============================================================
--echo ====================     add server   =========================
--echo ===============================================================
# 注意: 经过该步骤集群从1:1:1扩充成2:2:2
--echo test case for add server begin
ob_connect(conn_sys, ob1.z1.obs0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);
source t/quick/include/add_server.inc;
--echo test case for add server finish

# case 3. 验证建租户 @yanmu.ztl
--echo ===============================================================
--echo ==================     create tenant   ========================
--echo ===============================================================
# 注意: 创建初始mysql租户'F@z1, F@z3'
--echo test case for create tenant begin
source t/quick/include/create_mysql_tenant.inc;
ob_connect(conn_sys, ob1.z1.obs0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);
ob_connect(conn_mysql, ob1.z1.obs1, root@mysql, , test, , USE_MYSQL_CONNECTOR);
--echo test case for create tenant finish

# case 4. 验证sys租户创建表和DML/SELECT操作 @yanmu.ztl
--echo ===============================================================
--echo ===========     dml/select under sys tenant   =================
--echo ===============================================================
--echo test case for dml and select under sys tenant begin
source t/quick/include/sys_tenant_dml_and_select.inc;
--echo test case for dml and select under sys tenant finish

