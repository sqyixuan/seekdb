# owner: shifangdan.sfd
# owner group: cloud storage
# Testing Case: hidden sys tenant data disk size manager

ob1=OBI(cluster=2, proxy_num=0, init_unit_cpu=0);
ob1.reboot;

let $proxy_ip = deploy_get_value(ob1.z1.obs0.ip);
let $proxy_port = deploy_get_value(ob1.z1.obs0.mysql_port);
let $svr0_ip = deploy_get_value(ob1.z1.obs0.ip);
let $svr0_port = deploy_get_value(ob1.z1.obs0.port);
let $svr1_ip = deploy_get_value(ob1.z1.obs1.ip);
let $svr1_port = deploy_get_value(ob1.z1.obs1.port);
connect(sys_conn, $proxy_ip, root@sys,,oceanbase, $proxy_port);
connection sys_conn;

--echo # =========================================================
--echo #                    basic test
--echo # =========================================================
SELECT data_disk_capacity / (1024 * 1024 * 1024) AS data_disk_capacity_gb, data_disk_assigned / (1024 * 1024 * 1024) AS data_disk_assigned_gb from oceanbase.__all_virtual_server order by svr_port;
SELECT data_disk_size / (1024 * 1024 * 1024) AS data_disk_size_gb from oceanbase.__all_virtual_unit where tenant_id = 1;


--echo # =========================================================
--echo #               sys unit migrate test A-->B
--echo # =========================================================
ob1.mysql ALTER SYSTEM MIGRATE UNIT 1 DESTINATION '$svr1_ip:$svr1_port';
ob1.check_until_timeout select count(*) from oceanbase.__all_unit where svr_ip='$svr1_ip' and svr_port =$svr1_port and migrate_from_svr_ip ='', 1, 400;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_unit where svr_ip='$svr0_ip' and svr_port =$svr0_port, 0, 400;
sleep 5;
SELECT data_disk_capacity / (1024 * 1024 * 1024) AS data_disk_capacity_gb, data_disk_assigned / (1024 * 1024 * 1024) AS data_disk_assigned_gb from oceanbase.__all_virtual_server order by svr_port;
SELECT data_disk_size / (1024 * 1024 * 1024) AS data_disk_size_gb from oceanbase.__all_virtual_unit where tenant_id = 1;


--echo # =========================================================
--echo #              sys unit migrate test B-->A
--echo # =========================================================
ob1.mysql ALTER SYSTEM MIGRATE UNIT 1 DESTINATION '$svr0_ip:$svr0_port';
ob1.check_until_timeout select count(*) from oceanbase.__all_unit where svr_ip='$svr0_ip' and svr_port =$svr0_port and migrate_from_svr_ip ='', 1, 400;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_unit where svr_ip='$svr1_ip' and svr_port =$svr1_port, 0, 400;
sleep 5;
SELECT data_disk_capacity / (1024 * 1024 * 1024) AS data_disk_capacity_gb, data_disk_assigned / (1024 * 1024 * 1024) AS data_disk_assigned_gb from oceanbase.__all_virtual_server order by svr_port;
SELECT data_disk_size / (1024 * 1024 * 1024) AS data_disk_size_gb from oceanbase.__all_virtual_unit where tenant_id = 1;


--echo # =========================================================
--echo #              sys unit config change test
--echo # =========================================================
ob1.mysql ALTER RESOURCE UNIT sys_unit_config DATA_DISK_SIZE = '20G';
sleep 20;
SELECT data_disk_capacity / (1024 * 1024 * 1024) AS data_disk_capacity_gb, data_disk_assigned / (1024 * 1024 * 1024) AS data_disk_assigned_gb from oceanbase.__all_virtual_server order by svr_port;
SELECT data_disk_size / (1024 * 1024 * 1024) AS data_disk_size_gb from oceanbase.__all_virtual_unit where tenant_id = 1;


--echo # =========================================================
--echo #              sys unit migrate test A-->B
--echo # =========================================================
ob1.mysql ALTER SYSTEM MIGRATE UNIT 1 DESTINATION '$svr1_ip:$svr1_port';
ob1.check_until_timeout select count(*) from oceanbase.__all_unit where svr_ip='$svr1_ip' and svr_port =$svr1_port and migrate_from_svr_ip ='', 1, 400;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_unit where svr_ip='$svr0_ip' and svr_port =$svr0_port, 0, 400;
sleep 5;
SELECT data_disk_capacity / (1024 * 1024 * 1024) AS data_disk_capacity_gb, data_disk_assigned / (1024 * 1024 * 1024) AS data_disk_assigned_gb from oceanbase.__all_virtual_server order by svr_port;
SELECT data_disk_size / (1024 * 1024 * 1024) AS data_disk_size_gb from oceanbase.__all_virtual_unit where tenant_id = 1;


--echo # =========================================================
--echo #           restart after sys unit migrate test
--echo # =========================================================
# restart
ob1.z1.obs0.restart;
ob1.z1.obs1.restart;
ob1.check_until_timeout select status from oceanbase.__all_server where zone = 'z1', ACTIVE, 60;
ob1.check_until_timeout select count(*) from oceanbase.__all_server where zone = 'z1' and start_service_time > 0, 2, 600;
connect(sys_conn, $proxy_ip, root@sys,,oceanbase, $proxy_port);
connection sys_conn;
SELECT data_disk_capacity / (1024 * 1024 * 1024) AS data_disk_capacity_gb, data_disk_assigned / (1024 * 1024 * 1024) AS data_disk_assigned_gb from oceanbase.__all_virtual_server order by svr_port;
SELECT data_disk_size / (1024 * 1024 * 1024) AS data_disk_size_gb from oceanbase.__all_virtual_unit where tenant_id = 1;


--echo # =========================================================
--echo #      _ss_hidden_sys_tenant_data_disk_size test
--echo # =========================================================
ob1.mysql ALTER SYSTEM SET _ss_hidden_sys_tenant_data_disk_size='10G';
sleep 20;
SELECT data_disk_capacity / (1024 * 1024 * 1024) AS data_disk_capacity_gb, data_disk_assigned / (1024 * 1024 * 1024) AS data_disk_assigned_gb from oceanbase.__all_virtual_server order by svr_port;
SELECT data_disk_size / (1024 * 1024 * 1024) AS data_disk_size_gb from oceanbase.__all_virtual_unit where tenant_id = 1;

--echo # =========================================================
--echo #              sys unit config change test
--echo # =========================================================
ob1.mysql ALTER RESOURCE UNIT sys_unit_config DATA_DISK_SIZE = '80G';
sleep 20;
SELECT data_disk_capacity / (1024 * 1024 * 1024) AS data_disk_capacity_gb, data_disk_assigned / (1024 * 1024 * 1024) AS data_disk_assigned_gb from oceanbase.__all_virtual_server order by svr_port;
SELECT data_disk_size / (1024 * 1024 * 1024) AS data_disk_size_gb from oceanbase.__all_virtual_unit where tenant_id = 1;

--echo # =========================================================
--echo #              sys unit migrate test B-->A
--echo # =========================================================
--disable_query_log
--disable_result_log
--error 4624
eval ALTER SYSTEM MIGRATE UNIT 1 DESTINATION '$svr0_ip:$svr0_port';
--enable_query_log
--enable_result_log


--echo # =========================================================
--echo #       tmp file preread task test
--echo # =========================================================
connect(sys_conn, $proxy_ip, root@sys,,oceanbase, $proxy_port);
connection sys_conn;

--disable_query_log
CREATE RESOURCE UNIT direct_load_unit MAX_CPU=2, MEMORY_SIZE='4G', DATA_DISK_SIZE='4G';
CREATE RESOURCE POOL direct_load_pool UNIT direct_load_unit, UNIT_NUM 1, ZONE_LIST ('z1');
CREATE TENANT tt RESOURCE_POOL_LIST = ('direct_load_pool'), primary_zone = "z1", locality = 'F@z1' SET VARIABLES ob_compatibility_mode='mysql',secure_file_priv = '/', ob_tcp_invited_nodes='%';
let $tt_ip = deploy_get_value(ob1.select select svr_ip from __all_virtual_unit where tenant_id = 1002, svr_ip, 1);
let $tt_port = deploy_get_value(ob1.select select svr_port from __all_virtual_unit where tenant_id = 1002, svr_port, 1);
let $tt_proxy_port = 0;
if ($tt_port == $svr0_port)
{
  let $tt_ip = deploy_get_value(ob1.z1.obs0.ip);
  let $tt_proxy_port = deploy_get_value(ob1.z1.obs0.mysql_port);
}
if ($tt_port == $svr1_port)
{
  let $tt_ip = deploy_get_value(ob1.z1.obs1.ip);
  let $tt_proxy_port = deploy_get_value(ob1.z1.obs1.mysql_port);
}
--enable_query_log

--echo # =========================================================
--echo #                 direct load data
--echo # =========================================================
connect(conn1, $tt_ip, root@tt,, test, $tt_proxy_port);
connection conn1;
set ob_query_timeout=10000000000;
create table t1 (c1 varchar(10), c2 bigint, c3 bigint, c4 bigint, c5 bigint, PRIMARY KEY (c1, c2));

insert /*+ append enable_parallel_dml parallel(8) */ into t1 select
  randstr(10, random()) c1,
  random() c2,
  zipf(1, 100, random(3)),
  normal(0, 1, random()),
  uniform(1, 100, random())
from
  table(generator(10000000));

connect(sys_conn, $proxy_ip, root@sys,,oceanbase, $proxy_port);
connection sys_conn;
ob1.check_until_timeout select value from __all_virtual_sysstat where tenant_id = 1002 and name like "%ss_local_cache%" and stat_id = 245006, 0, 60;
ob1.check_until_timeout select value from __all_virtual_sysstat where tenant_id = 1002 and name like "%ss_local_cache%" and stat_id = 245007, 0, 60;
let $tmp_file_hit_cnt = query_get_value(select value from __all_virtual_sysstat where tenant_id = 1002 and name like "%ss_tmpfile_cache%" and stat_id = 240017, value, 1);
let $tmp_file_miss_cnt = query_get_value(select value from __all_virtual_sysstat where tenant_id = 1002 and name like "%ss_tmpfile_cache%" and stat_id = 240018, value, 1);
if ($tmp_file_hit_cnt < ($tmp_file_hit_cnt + $tmp_file_miss_cnt) * 0.8)
{
  --echo tmp file preread cache hit rate is too low
  --echo $tmp_file_hit_cnt
  --echo $tmp_file_miss_cnt
}
select value from __all_virtual_sysstat where tenant_id = 1002 and name like "%ss_local_cache%" and stat_id = 245006;
select value from __all_virtual_sysstat where tenant_id = 1002 and name like "%ss_local_cache%" and stat_id = 245007;

--echo # =========================================================
--echo #                   create index
--echo # =========================================================
connect(conn1, $tt_ip, root@tt,, test, $tt_proxy_port);
connection conn1;
create /*+parallel(32)*/ index idx_t1_c5 on t1(c5);

connect(sys_conn, $proxy_ip, root@sys,,oceanbase, $proxy_port);
connection sys_conn;
ob1.check_until_timeout select value from __all_virtual_sysstat where tenant_id = 1002 and name like "%ss_local_cache%" and stat_id = 245006, 0, 60;
ob1.check_until_timeout select value from __all_virtual_sysstat where tenant_id = 1002 and name like "%ss_local_cache%" and stat_id = 245007, 0, 60;
let $tmp_file_hit_cnt = query_get_value(select value from __all_virtual_sysstat where tenant_id = 1002 and name like "%ss_tmpfile_cache%" and stat_id = 240017, value, 1);
let $tmp_file_miss_cnt = query_get_value(select value from __all_virtual_sysstat where tenant_id = 1002 and name like "%ss_tmpfile_cache%" and stat_id = 240018, value, 1);
if ($tmp_file_hit_cnt < ($tmp_file_hit_cnt + $tmp_file_miss_cnt) * 0.8)
{
  --echo tmp file preread cache hit rate is too low
  --echo $tmp_file_hit_cnt
  --echo $tmp_file_miss_cnt
}
let $major_macro_hit_cnt = query_get_value(select * from __all_virtual_sysstat where tenant_id = 1002 and name like "%ss_major_macro_cache%" and stat_id = 240020, value, 1);
let $major_macro_miss_cnt = query_get_value(select * from __all_virtual_sysstat where tenant_id = 1002 and name like "%ss_major_macro_cache%" and stat_id = 240021, value, 1);
if ($major_macro_hit_cnt < ($major_macro_hit_cnt + $major_macro_miss_cnt) * 0.6)
{
  --echo major macro preread cache hit rate is too low
  --echo $major_macro_hit_cnt
  --echo $major_macro_miss_cnt
}

select value from __all_virtual_sysstat where tenant_id = 1002 and name like "%ss_local_cache%" and stat_id = 245006;
select value from __all_virtual_sysstat where tenant_id = 1002 and name like "%ss_local_cache%" and stat_id = 245007;
