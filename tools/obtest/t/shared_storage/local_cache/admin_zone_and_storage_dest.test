ob1=OBI(cluster=3:2:2:1, proxy_num=0, init_unit_cpu=0);
ob1.z1.obs1.set status=disable;
ob1.z2.obs1.set status=disable;
ob1.z3.obs1.set status=disable;
ob1.z1.obs2.set status=disable;
ob1.z4.obs0.set status=disable;

ob1.reboot;

let $proxy_ip = deploy_get_value(ob1.z1.obs0.ip);
let $proxy_port = deploy_get_value(ob1.z1.obs0.mysql_port);
connect(sys_conn, $proxy_ip, root@sys,,test, $proxy_port);
connection sys_conn;


ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_server_storage where state = 'ADDED', 3, 600;

# check regions of all zones must keep the same

let $curr_region = query_get_value(select region from oceanbase.DBA_OB_ZONES, region, 1);
let $path = query_get_value(select path from oceanbase.__all_virtual_server_storage, path, 1);
let $endpoint = query_get_value(select endpoint from oceanbase.__all_virtual_server_storage, endpoint, 1);

# check add zone
--error 1235
alter system add zone z9 region 'new_region';
--error 1235
alter system alter zone z3 set region 'new_region';

eval alter system add zone z9 region '$curr_region';
select count(*) from oceanbase.DBA_OB_ZONES where zone='z9';

# check storage_type in __all_zone
select zone, name, value, info from oceanbase.__all_zone where name = 'storage_type' order by zone;

alter system delete zone z9;

let $z1s1addr = deploy_get_value(ob1.z1.obs1.get_addr);
let $z2s1addr = deploy_get_value(ob1.z2.obs1.get_addr);
let $z3s1addr = deploy_get_value(ob1.z3.obs1.get_addr);
let $z1s2addr = deploy_get_value(ob1.z1.obs2.get_addr);
ob1.z1.obs1.set status=enable;
ob1.z2.obs1.set status=enable;
ob1.z3.obs1.set status=enable;
ob1.z1.obs2.set status=enable;
ob1.z1.obs1.start;
ob1.z2.obs1.start;
ob1.z3.obs1.start;
ob1.z1.obs2.start;
ob1.z1.obs1.check_log_until_success -c "weak read service thread start";
ob1.z2.obs1.check_log_until_success -c "weak read service thread start";
ob1.z3.obs1.check_log_until_success -c "weak read service thread start";
ob1.z1.obs2.check_log_until_success -c "weak read service thread start";

# sleep to wait server init
sleep 2;

disable_query_log;

# not the same zone
eval alter system add server '$z1s1addr', '$z2s1addr';
ob1.check_until_timeout select count(*) from oceanbase.__all_server where zone='z1', 2, 60;
ob1.check_until_timeout select count(*) from oceanbase.__all_server where zone='z2', 2, 60;

eval alter system add server '$z1s2addr' zone 'z1';
ob1.check_until_timeout select count(*) from oceanbase.__all_server where zone='z1', 3, 60;

# zone not match
--error 4631
eval alter system add server '$z3s1addr' zone 'z1';

eval ALTER SYSTEM ALTER SHARED_STORAGE_DEST PATH='$path?$endpoint' SET ATTRIBUTE='max_iops=10000&max_bandwidth=10GB';
ob1.check_until_timeout select count(*) from oceanbase.__all_zone_storage where state='CHANGED', 3, 60;

eval ALTER SYSTEM ALTER SHARED_STORAGE_DEST PATH='$path?$endpoint' SET ATTRIBUTE='max_iops=10000&max_bandwidth=10GB';
ob1.check_until_timeout select count(*) from oceanbase.__all_zone_storage where state='CHANGED', 3, 60;

-- error 9116
eval ALTER SYSTEM ALTER SHARED_STORAGE_DEST PATH='$path?$endpoint' SET ACCESS_INFO='access_id=xxx&access_key=xxx&s3_region=us-east-1';

-- error 9116
eval ALTER SYSTEM ALTER SHARED_STORAGE_DEST PATH='$path?$endpoint' SET ACCESS_INFO='access_id=xxx&access_key=xxx&s3_region=us-east-1';

ob1.mysql alter system set debug_sync_timeout = '100000s';
sleep 3;
ob1.mysql set ob_global_debug_sync = 'BEFORE_ADD_SERVER_TRANS wait_for signal_storage_changed execute 1';
# 100s
set @@session.ob_query_timeout = 100000000;
send alter system add server '$z3s1addr';

connect(sys_conn1, $proxy_ip, root@sys,,test, $proxy_port);
connection sys_conn1;

ob1.z1.obs0.check_rs_log_until_success -c 'execute action.*wait:\"signal_storage_changed\"';
eval ALTER SYSTEM ALTER SHARED_STORAGE_DEST PATH='$path?$endpoint' SET ATTRIBUTE='max_iops=9999&max_bandwidth=10GB';
ob1.check_until_timeout select count(*) from oceanbase.__all_zone_storage where state='CHANGED', 3, 60;
ob1.mysql set ob_global_debug_sync = 'now signal signal_storage_changed';

connection sys_conn;
--error 4179
reap;

enable_query_log;

## add
ob1.z4.add_zone_without_storage;
ob1.z4.start_zone;
ob1.z4.obs0.set status=enable;
ob1.z4.obs0.start;
ob1.z4.obs0.check_log_until_success -c "weak read service thread start";

## add server with shared storage info not add
let $z4s0addr = deploy_get_value(ob1.z4.obs0.get_addr);
disable_query_log;
--error 4179
eval alter system add server '$z4s0addr' zone 'z4';
enable_query_log;

ob1.z4.add_storage;
ob1.z4.obs0.add;

## drop storage on active zone and avtive servers
disable_query_log;
--error 1235
eval ALTER SYSTEM DROP SHARED_STORAGE_DEST PATH='$path?$endpoint' FOR ALL zone = 'z4';
enable_query_log;

## drop storage on zone with active servers
ob1.z4.stop_zone;
disable_query_log;
--error 1235
eval ALTER SYSTEM DROP SHARED_STORAGE_DEST PATH='$path?$endpoint' FOR ALL zone = 'z4';
enable_query_log;

ob1.z4.obs0.delete;
ob1.check_until_timeout select count(*) from oceanbase.__all_rootservice_job where job_status = "INPROGRESS" , 0, 480;
## delete zone with shared storage info not delete
--error 4179
eval alter system delete zone 'z4';

ob1.z4.delete_storage;
ob1.z4.delete_zone_without_storage;
