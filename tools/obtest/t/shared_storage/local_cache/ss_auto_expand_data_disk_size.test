# owner: shifangdan.sfd
# owner group: cloud storage
# Testing Case: auto expand data disk size in shared storage mode

ob1=OBI(cluster=2, proxy_num=0, init_unit_cpu=0);
ob1.reboot;

let $proxy_ip = deploy_get_value(ob1.z1.obs0.ip);
let $proxy_port = deploy_get_value(ob1.z1.obs0.mysql_port);
let $svr0_ip = deploy_get_value(ob1.z1.obs0.ip);
let $svr0_port = deploy_get_value(ob1.z1.obs0.port);
let $svr1_ip = deploy_get_value(ob1.z1.obs1.ip);
let $svr1_port = deploy_get_value(ob1.z1.obs1.port);
connect(sys_conn, $proxy_ip, root@sys,,oceanbase, $proxy_port);
connection sys_conn;

--echo # =========================================================
--echo #       auto expand data disk size test
--echo # =========================================================
connect(sys_conn, $proxy_ip, root@sys,,oceanbase, $proxy_port);
connection sys_conn;

--disable_query_log
# cpu_count=16, sys_cpu=3, direct_load_unit_cpu=1, remain cpu_count=12, resvered_size=12*2G=24G
# datafile_size=100G, resvered_size=24G, disk_capacity=76G, expansion_size=disk_capacity*90%=68.4G
# hidden_sys_data_disk_size=6G, sys_unit_data_disk_size=60G, direct_load_unit_init_data_disk_size=2G, auto_expand=1G, ss_data_disk_operation_suggested is EXPAND
ALTER SYSTEM SET _ss_hidden_sys_tenant_data_disk_size = '6G';
ob1.check_until_timeout select value from __all_virtual_sysstat where tenant_id=1 and name like "%hidden sys data disk size%" limit 1, 6442450944, 100;
ALTER RESOURCE UNIT sys_unit_config DATA_DISK_SIZE = '60G';
CREATE RESOURCE UNIT direct_load_unit MAX_CPU=1, MEMORY_SIZE='8G', DATA_DISK_SIZE=0;
CREATE RESOURCE POOL direct_load_pool UNIT direct_load_unit, UNIT_NUM 1, ZONE_LIST ('z1');
CREATE TENANT tt RESOURCE_POOL_LIST = ('direct_load_pool'), primary_zone = "z1", locality = 'F@z1' SET VARIABLES ob_compatibility_mode='mysql',secure_file_priv = '/', ob_tcp_invited_nodes='%';
let $tt_ip = deploy_get_value(ob1.select select svr_ip from __all_virtual_unit where tenant_id = 1002, svr_ip, 1);
let $tt_port = deploy_get_value(ob1.select select svr_port from __all_virtual_unit where tenant_id = 1002, svr_port, 1);
let $tt_proxy_port = 0;
if ($tt_port == $svr0_port)
{
  let $tt_ip = deploy_get_value(ob1.z1.obs0.ip);
  let $tt_proxy_port = deploy_get_value(ob1.z1.obs0.mysql_port);
}
if ($tt_port == $svr1_port)
{
  let $tt_ip = deploy_get_value(ob1.z1.obs1.ip);
  let $tt_proxy_port = deploy_get_value(ob1.z1.obs1.mysql_port);
}
--enable_query_log

sleep 20;
SELECT data_disk_capacity / (1024 * 1024 * 1024) AS data_disk_capacity_gb, data_disk_assigned / (1024 * 1024 * 1024) AS data_disk_assigned_gb, ss_data_disk_operation_suggested, ss_data_disk_size_suggested from oceanbase.__all_virtual_server order by svr_port;
SELECT data_disk_capacity / (1024 * 1024 * 1024) AS data_disk_capacity_gb, data_disk_assigned / (1024 * 1024 * 1024) AS data_disk_assigned_gb, ss_data_disk_operation_suggested, ss_data_disk_size_suggested from oceanbase.gv$ob_servers order by svr_port;
SELECT data_disk_capacity / (1024 * 1024 * 1024) AS data_disk_capacity_gb, data_disk_assigned / (1024 * 1024 * 1024) AS data_disk_assigned_gb, ss_data_disk_operation_suggested, ss_data_disk_size_suggested from oceanbase.v$ob_servers order by svr_port;
SELECT tenant_id, data_disk_size / (1024 * 1024 * 1024) AS data_disk_size_gb from oceanbase.__all_virtual_unit order by tenant_id;

--echo # =========================================================
--echo #                 direct load data
--echo # =========================================================
connect(conn1, $tt_ip, root@tt,, test, $tt_proxy_port);
connection conn1;
set ob_query_timeout=10000000000;

create table t1 (c1 varchar(10), c2 bigint, c3 bigint, c4 bigint, c5 bigint, PRIMARY KEY (c1, c2)) COMPRESSION='none';
insert /*+ append enable_parallel_dml parallel(8) */ into t1 select
  randstr(10, random()) c1,
  random() c2,
  zipf(1, 100, random(3)),
  normal(0, 1, random()),
  uniform(1, 100, random())
from
  table(generator(60000000));

connect(sys_conn, $proxy_ip, root@sys,,oceanbase, $proxy_port);
connection sys_conn;
ALTER SYSTEM SET ss_cache_max_percentage=100;

connect(conn1, $tt_ip, root@tt,, test, $tt_proxy_port);
connection conn1;
set ob_query_timeout=10000000000;
create table t2 (c1 varchar(10), c2 bigint, c3 bigint, c4 bigint, c5 bigint, PRIMARY KEY (c1, c2)) COMPRESSION='none';
insert /*+ append enable_parallel_dml parallel(8) */ into t2 select
  randstr(10, random()) c1,
  random() c2,
  zipf(1, 100, random(3)),
  normal(0, 1, random()),
  uniform(1, 100, random())
from
  table(generator(40000000));

create table t3 (c1 varchar(10), c2 bigint, c3 bigint, c4 bigint, c5 bigint, PRIMARY KEY (c1, c2)) COMPRESSION='none';
insert /*+ append enable_parallel_dml parallel(8) */ into t3 select
randstr(10, random()) c1,
random() c2,
zipf(1, 100, random(3)),
normal(0, 1, random()),
uniform(1, 100, random())
from
table(generator(40000000));

connect(sys_conn, $proxy_ip, root@sys,,oceanbase, $proxy_port);
connection sys_conn;
SELECT ss_data_disk_operation_suggested, ss_data_disk_size_suggested from oceanbase.__all_virtual_server order by svr_port;
SELECT ss_data_disk_operation_suggested, ss_data_disk_size_suggested from oceanbase.gv$ob_servers order by svr_port;
SELECT ss_data_disk_operation_suggested, ss_data_disk_size_suggested from oceanbase.v$ob_servers order by svr_port;
let $data_disk_size = deploy_get_value(ob1.select SELECT data_disk_size / (1024 * 1024 * 1024) AS data_disk_size_gb from oceanbase.__all_virtual_unit where tenant_id = 1002, data_disk_size_gb, 1);
if ($data_disk_size >= 4)
{
  --echo direct load data auto expand data disk size is incorect
  --echo $data_disk_size
}

--echo # =========================================================
--echo #         direct_load_unit migrate test A-->B
--echo # =========================================================
ob1.mysql alter system enable_rebalance = false;
ob1.mysql ALTER SYSTEM MIGRATE UNIT 1001 DESTINATION '$svr0_ip:$svr0_port';
ob1.check_until_timeout select count(*) from oceanbase.__all_unit where svr_ip='$svr0_ip' and svr_port =$svr0_port and migrate_from_svr_ip ='', 2, 400;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_unit where svr_ip='$svr1_ip' and svr_port =$svr1_port, 0, 400;
sleep 5;
SELECT ss_data_disk_operation_suggested, ss_data_disk_size_suggested from oceanbase.__all_virtual_server order by svr_port;
SELECT ss_data_disk_operation_suggested, ss_data_disk_size_suggested from oceanbase.gv$ob_servers order by svr_port;
SELECT ss_data_disk_operation_suggested, ss_data_disk_size_suggested from oceanbase.v$ob_servers order by svr_port;
let $data_disk_size = deploy_get_value(ob1.select SELECT data_disk_size / (1024 * 1024 * 1024) AS data_disk_size_gb from oceanbase.__all_virtual_unit where tenant_id = 1002, data_disk_size_gb, 1);
if ($data_disk_size >= 4)
{
  --echo migrate test A-->B auto expand data disk size is incorect
  --echo $data_disk_size
}

--echo # =========================================================
--echo #         direct_load_unit migrate test B-->A
--echo # =========================================================
ob1.mysql alter system enable_rebalance = false;
ob1.mysql ALTER SYSTEM MIGRATE UNIT 1001 DESTINATION '$svr1_ip:$svr1_port';
ob1.check_until_timeout select count(*) from oceanbase.__all_unit where svr_ip='$svr1_ip' and svr_port =$svr1_port and migrate_from_svr_ip ='', 1, 400;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_unit where svr_ip='$svr0_ip' and svr_port =$svr0_port, 1, 400;
sleep 5;
SELECT ss_data_disk_operation_suggested, ss_data_disk_size_suggested from oceanbase.__all_virtual_server order by svr_port;
SELECT ss_data_disk_operation_suggested, ss_data_disk_size_suggested from oceanbase.gv$ob_servers order by svr_port;
SELECT ss_data_disk_operation_suggested, ss_data_disk_size_suggested from oceanbase.v$ob_servers order by svr_port;
let $data_disk_size = deploy_get_value(ob1.select SELECT data_disk_size / (1024 * 1024 * 1024) AS data_disk_size_gb from oceanbase.__all_virtual_unit where tenant_id = 1002, data_disk_size_gb, 1);
if ($data_disk_size >= 4)
{
  --echo migrate test B-->A auto expand data disk size is incorect
  --echo $data_disk_size
}

--echo # =========================================================
--echo #                restart test
--echo # =========================================================
ob1.z1.obs0.restart;
ob1.z1.obs1.restart;
ob1.check_until_timeout select status from oceanbase.__all_server where zone = 'z1', ACTIVE, 60;
ob1.check_until_timeout select count(*) from oceanbase.__all_server where zone = 'z1' and start_service_time > 0, 2, 600;
connect(sys_conn, $proxy_ip, root@sys,,oceanbase, $proxy_port);
connection sys_conn;
SELECT ss_data_disk_operation_suggested, ss_data_disk_size_suggested from oceanbase.__all_virtual_server order by svr_port;
SELECT ss_data_disk_operation_suggested, ss_data_disk_size_suggested from oceanbase.gv$ob_servers order by svr_port;
SELECT ss_data_disk_operation_suggested, ss_data_disk_size_suggested from oceanbase.v$ob_servers order by svr_port;
let $data_disk_size = deploy_get_value(ob1.select SELECT data_disk_size / (1024 * 1024 * 1024) AS data_disk_size_gb from oceanbase.__all_virtual_unit where tenant_id = 1002, data_disk_size_gb, 1);
if ($data_disk_size >= 4)
{
  --echo restart test auto expand data disk size is incorect
  --echo $data_disk_size
}

--disable_query_log
CREATE RESOURCE UNIT insert_data_unit MAX_CPU=1, MEMORY_SIZE='2G', DATA_DISK_SIZE=0;
CREATE RESOURCE POOL insert_data_pool UNIT insert_data_unit, UNIT_NUM 1, ZONE_LIST ('z1');
CREATE TENANT tt1 RESOURCE_POOL_LIST = ('insert_data_pool'), primary_zone = "z1", locality = 'F@z1' SET VARIABLES ob_compatibility_mode='mysql',secure_file_priv = '/', ob_tcp_invited_nodes='%';
let $tt1_ip = deploy_get_value(ob1.select select svr_ip from __all_virtual_unit where tenant_id = 1004, svr_ip, 1);
let $tt1_port = deploy_get_value(ob1.select select svr_port from __all_virtual_unit where tenant_id = 1004, svr_port, 1);
let $tt1_proxy_port = 0;
if ($tt1_port == $svr0_port)
{
  let $tt1_ip = deploy_get_value(ob1.z1.obs0.ip);
  let $tt1_proxy_port = deploy_get_value(ob1.z1.obs0.mysql_port);
}
if ($tt1_port == $svr1_port)
{
  let $tt1_ip = deploy_get_value(ob1.z1.obs1.ip);
  let $tt1_proxy_port = deploy_get_value(ob1.z1.obs1.mysql_port);
}
--enable_query_log

--echo # =========================================================
--echo #                 insert data test
--echo # =========================================================
connect(conn1, $tt1_ip, root@tt1,, test, $tt1_proxy_port);
connection conn1;
set ob_query_timeout=10000000000;
create table t0 (c1 varchar(10), c2 bigint, c3 bigint, c4 bigint, c5 bigint, PRIMARY KEY (c1, c2)) COMPRESSION='none';
insert /* enable_parallel_dml parallel(8) */ into t0 select
  randstr(10, random()) c1,
  random() c2,
  zipf(1, 100, random(3)),
  normal(0, 1, random()),
  uniform(1, 100, random())
from
  table(generator(1000000));
create table t01 (c1 varchar(10), c2 bigint, c3 bigint, c4 bigint, c5 bigint, PRIMARY KEY (c1, c2)) COMPRESSION='none';
insert /* enable_parallel_dml parallel(8) */ into t01 select
  randstr(10, random()) c1,
  random() c2,
  zipf(1, 100, random(3)),
  normal(0, 1, random()),
  uniform(1, 100, random())
from
  table(generator(1000000));
create table t02 (c1 varchar(10), c2 bigint, c3 bigint, c4 bigint, c5 bigint, PRIMARY KEY (c1, c2)) COMPRESSION='none';
insert /* enable_parallel_dml parallel(8) */ into t02 select
  randstr(10, random()) c1,
  random() c2,
  zipf(1, 100, random(3)),
  normal(0, 1, random()),
  uniform(1, 100, random())
from
  table(generator(1000000));
create table t03 (c1 varchar(10), c2 bigint, c3 bigint, c4 bigint, c5 bigint, PRIMARY KEY (c1, c2)) COMPRESSION='none';
insert /* enable_parallel_dml parallel(8) */ into t03 select
  randstr(10, random()) c1,
  random() c2,
  zipf(1, 100, random(3)),
  normal(0, 1, random()),
  uniform(1, 100, random())
from
  table(generator(1000000));
create table t04 (c1 varchar(10), c2 bigint, c3 bigint, c4 bigint, c5 bigint, PRIMARY KEY (c1, c2)) COMPRESSION='none';
insert /* enable_parallel_dml parallel(8) */ into t04 select
  randstr(10, random()) c1,
  random() c2,
  zipf(1, 100, random(3)),
  normal(0, 1, random()),
  uniform(1, 100, random())
from
  table(generator(1000000));

connect(sys_conn, $proxy_ip, root@sys,,oceanbase, $proxy_port);
connection sys_conn;
SELECT ss_data_disk_operation_suggested, ss_data_disk_size_suggested from oceanbase.__all_virtual_server order by svr_port;
SELECT ss_data_disk_operation_suggested, ss_data_disk_size_suggested from oceanbase.gv$ob_servers order by svr_port;
SELECT ss_data_disk_operation_suggested, ss_data_disk_size_suggested from oceanbase.v$ob_servers order by svr_port;
let $data_disk_size = deploy_get_value(ob1.select SELECT data_disk_size / (1024 * 1024 * 1024) AS data_disk_size_gb from oceanbase.__all_virtual_unit where tenant_id = 1004, data_disk_size_gb, 1);
if ($data_disk_size >= 4)
{
  --echo restart test auto expand data disk size is incorect
  --echo $data_disk_size
}
