
--echo "1. =========== bootstrap ==========="
ob1=OBI(cluster=1:1:2, proxy_num=0, init_unit_cpu=0);
source include/mini_ob_config.inc;
ob1.set extra_config=$mini_ob_config;
ob1.reboot;

ob1.mysql ALTER SYSTEM SET enable_rebalance = 'false';
ob1.mysql ALTER SYSTEM SET enable_rereplication = 'true';

let $proxy_ip = deploy_get_value(ob1.z1.obs0.ip);
let $proxy_port = deploy_get_value(ob1.z1.obs0.mysql_port);
connect(sys_conn, $proxy_ip, root@sys,,oceanbase, $proxy_port);

--echo "2. =========== create tenant ==========="
source include/create_unit_config.inc;
ob1.mysql CREATE RESOURCE POOL tenant_pool UNIT = "2c2g", UNIT_NUM = 1, ZONE_LIST = ('z1', 'z2', 'z3');
ob1.mysql CREATE TENANT gc_tenant RESOURCE_POOL_LIST=('tenant_pool') SET ob_tcp_invited_nodes='%';
let $tenant_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name='gc_tenant', tenant_id, 1);

--echo "3. =========== create table and insert data ==========="
ob_connect(conn_mysql, ob1.z1.obs0, root@gc_tenant, , test, , USE_MYSQL_CONNECTOR);
connection conn_mysql;
let $cnt = 100;
while ($cnt > 0)
{
  eval create table t$cnt (a int);
  eval insert into t$cnt values (1);
  dec $cnt;
}

let $start_tablet_id = deploy_get_value(ob1.select select tablet_id from oceanbase.__all_virtual_table where table_name="t100", tablet_id, 1);

--echo "4. =========== major freeze ==========="
sleep 5;
alter system set ob_compaction_schedule_interval = '10s';
alter system major freeze;
source include/compaction/wait_tenant_major_finish_on_ss.inc;
connection conn_mysql;

--echo "5. =========== insert data again ==========="
let $cnt = 100;
while ($cnt > 0)
{
  eval insert into t$cnt values (1);
  dec $cnt;
}

--echo "6. =========== major freeze again ==========="
sleep 5;
alter system major freeze;
source include/compaction/wait_tenant_major_finish_on_ss.inc;
connection conn_mysql;

--echo "7. =========== wait gc meta version ==========="
let $major_scn = deploy_get_value(ob1.select select GLOBAL_BROADCAST_SCN from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id=$tenant_id, GLOBAL_BROADCAST_SCN, 1);
alter system set _ss_old_ver_retention_time = '10m';
let $shared_gc_ip_port = deploy_get_value(ob1.select select concat(svr_ip,':',svr_port) as host from __all_virtual_ls_meta_table where tenant_id = $tenant_id and ls_id =  1 and role = 1 order by svr_ip, svr_port limit 1, host, 1);

let $start_time = deploy_get_value(ob1.select select time_to_usec(now(6)) as scn, scn, 1);
let $gc_time = math($start_time + 600000000);

let $shared_obs = deploy_get_value(ob1.get_obs_by_addr $shared_gc_ip_port);

let $cnt = 100;
let $tablet_id = $start_tablet_id;
while ($cnt > 0)
{
  $shared_obs.check_log_until_success -c "finish shared tablet meta gc.*ret=0.*min_retain_tablet_meta_version=$major_scn.*id:$tablet_id"
  inc $tablet_id;
  dec $cnt;
}
let $end_time = deploy_get_value(ob1.select select time_to_usec(now(6)) as scn, scn, 1);

--echo 8. =========== check gc safe time ===========
if ($end_time < $gc_time)
{
  --echo ss_old_ver_retention_time error
  echo $end_time;
  echo $gc_time;
  --exit
}

--echo 9. =========== migrate unit ===========
connection sys_conn;
let $resource_pool_id = deploy_get_value(ob1.select SELECT resource_pool_id FROM oceanbase.__all_resource_pool WHERE tenant_id = $tenant_id, resource_pool_id, 1);
let $unit_id = deploy_get_value(ob1.select SELECT unit_id FROM oceanbase.DBA_OB_UNITS WHERE resource_pool_id = $resource_pool_id AND zone = 'z3', unit_id, 1);
let $dest_addr = deploy_get_value(ob1.select select concat(svr_ip, ':', svr_port) host from oceanbase.__all_server where zone='z3' and concat(svr_ip, ':', svr_port) not in (select concat(svr_ip, ':', svr_port) host FROM oceanbase.DBA_OB_UNITS WHERE unit_id = $unit_id), host, 1);
let $src_addr = deploy_get_value(ob1.select select concat(svr_ip, ':', svr_port) host FROM oceanbase.DBA_OB_UNITS WHERE unit_id = $unit_id, host, 1);
--disable_query_log
--disable_result_log
eval ALTER SYSTEM MIGRATE UNIT $unit_id DESTINATION "$dest_addr";
--enable_query_log
--enable_result_log

--echo 10. =========== wait unit gc ===========
let $src_obs = deploy_get_value(ob1.get_obs_by_addr $src_addr);
$src_obs.check_log_until_success -c "finish private tenant dir gc.*ret=0.*tenant_id:$tenant_id";

--echo 11. =========== drop table ===========
connection conn_mysql;
let $cnt = 100;
while ($cnt > 0)
{
  eval drop table t$cnt;
  dec $cnt;
}
purge recyclebin;

--echo 12. =========== wait gc tablet ===========
alter system set _ss_deleted_tablet_gc_time = '10m'; 
let $start_time = deploy_get_value(ob1.select select time_to_usec(now(6)) as scn, scn, 1);
let $gc_time = math($start_time + 600000000);

let $svr_cnt = 3;
while ($svr_cnt > 0)
{
  let $svr_addr = deploy_get_value(ob1.select select concat(svr_ip, ':', svr_port) host from __all_unit where resource_pool_id=$resource_pool_id, host, $svr_cnt);
  let $dst = deploy_get_value(ob1.get_obs_by_addr $svr_addr);
  dec $svr_cnt;

  let $dst = deploy_get_value(ob1.get_obs_by_addr $shared_gc_ip_port);
  
  let $cnt = 100;
  let $tablet_id = $start_tablet_id;
  while ($cnt > 0)
  {
    $dst.check_log_until_success -c "finish private tablet gc.*ret=0.*id:$tablet_id"
    inc $tablet_id;
    dec $cnt;
  }
}

let $cnt = 100;
let $tablet_id = $start_tablet_id;
while ($cnt > 0)
{
  $shared_obs.check_log_until_success -c "finish shared tablet gc.*ret=0.*need_gc=true.*id:$tablet_id"
  inc $tablet_id;
  dec $cnt;
}

let $end_time = deploy_get_value(ob1.select select time_to_usec(now(6)) as scn, scn, 1);

--echo 13. =========== check gc safe time ===========
if ($end_time < $gc_time)
{
  --echo ss_deleted_tablet_gc_time error
  echo $end_time;
  echo $gc_time;
  --exit
}

--echo 14. =========== drop tenant ===========
connection sys_conn;
drop tenant gc_tenant;
purge recyclebin;

--echo 15. =========== wait tenant gc ===========

let $svr_cnt = 3;
while ($svr_cnt > 0)
{
  let $svr_addr = deploy_get_value(ob1.select select concat(svr_ip, ':', svr_port) host from __all_unit where resource_pool_id=$resource_pool_id, host, $svr_cnt);
  let $dst = deploy_get_value(ob1.get_obs_by_addr $svr_addr);
  dec $svr_cnt;

  let $dst = deploy_get_value(ob1.get_obs_by_addr $shared_gc_ip_port);
  
  $dst.check_log_until_success -c "finish private tenant dir gc.*ret=0.*tenant_id:$tenant_id";
}

alter system set _ss_deleted_tablet_gc_time = '10m';
let $start_time = deploy_get_value(ob1.select select time_to_usec(now(6)) as scn, scn, 1);
let $gc_time = math($start_time + 600000000);

let $shared_obs = deploy_get_value(ob1.get_obs_by_addr $shared_gc_ip_port);
$shared_obs.check_log_until_success -c "finish tenant shared dir gc.*ret=0.*need_gc=true.*tenant_id=$tenant_id";

let $end_time = deploy_get_value(ob1.select select time_to_usec(now(6)) as scn, scn, 1);

--echo 16. =========== check gc safe time ===========
if ($end_time < $gc_time)
{
  --echo sys ss_deleted_tablet_gc_time error
  echo $end_time;
  echo $gc_time;
  --exit
}

