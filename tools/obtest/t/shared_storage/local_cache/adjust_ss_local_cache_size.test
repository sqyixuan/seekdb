# CASE_OWNER:
#    @donglou.zl
# CASE_DESC:
#    OB 4.3.5BP2版本支持通过ob_admin的方式调整本地宏/微块缓存空间
#    1. 只允许调大微块缓存、调小宏块缓存
#    2. 调整后的二者总空间需等于调整前的二者总空间


ob1=OBI(cluster=1, proxy_num=0);
ob1.reboot;
ob_connect(sys_conn, ob1.z1.obs0,root@sys, ,oceanbase, , USE_MYSQL_CONNECTOR);
connection sys_conn;

# check shared-storage mode
ob1.check_until_timeout select count(*) c from __all_virtual_sys_parameter_stat where name like '%startup%', 1, 1;

CREATE RESOURCE UNIT uc MAX_CPU 2, MEMORY_SIZE '4G';
CREATE RESOURCE POOL rp UNIT = 'uc', UNIT_NUM = 1;

let $tenant_id = query_get_value(select tenant_id from __all_tenant where tenant_name = 'sys', tenant_id, 1);
let $z1_dst_ip0 = deploy_get_value(ob1.z1.obs0.ip);
let $z1_dst_port0 = deploy_get_value(ob1.z1.obs0.port);
--echo ================ CASE 1: keep original ratio ========================
let $new_micro_ratio = 40;
let $new_macro_ratio = 38;
ob1.sh ./etc/ob_admin -h $z1_dst_ip0 -p $z1_dst_port0 set_ss_cache_size_ratio $tenant_id:$new_micro_ratio:$new_macro_ratio;

--echo ================ CASE 2: set wrong ratio ========================
let $new_micro_ratio = 42;
let $new_macro_ratio = 37;
ob1.sh ./etc/ob_admin -h $z1_dst_ip0 -p $z1_dst_port0 set_ss_cache_size_ratio $tenant_id:$new_micro_ratio:$new_macro_ratio;

--echo ================ CASE 3: set correct ratio ========================
let $new_micro_ratio = 45;
let $new_macro_ratio = 33;
ob1.check_until_timeout select alloc_disk_size from oceanbase.__all_virtual_ss_local_cache_info where tenant_id=$tenant_id and svr_ip = "$z1_dst_ip0" and svr_port = $z1_dst_port0 and cache_name="ss_micro_cache", 2576980377, 10;
ob1.sh ./etc/ob_admin -h $z1_dst_ip0 -p $z1_dst_port0 set_ss_cache_size_ratio $tenant_id:$new_micro_ratio:$new_macro_ratio;
ob1.check_until_timeout select alloc_disk_size from oceanbase.__all_virtual_ss_local_cache_info where tenant_id=$tenant_id and svr_ip = "$z1_dst_ip0" and svr_port = $z1_dst_port0 and cache_name="ss_micro_cache", 2899102924, 10;

--echo ================ CASE 4: set wrong ratio ========================
let $new_micro_ratio = 43;
let $new_macro_ratio = 35;
ob1.sh ./etc/ob_admin -h $z1_dst_ip0 -p $z1_dst_port0 set_ss_cache_size_ratio $tenant_id:$new_micro_ratio:$new_macro_ratio;
ob1.check_until_timeout select alloc_disk_size from oceanbase.__all_virtual_ss_local_cache_info where tenant_id=$tenant_id and svr_ip = "$z1_dst_ip0" and svr_port = $z1_dst_port0 and cache_name="ss_micro_cache", 2899102924, 10;
