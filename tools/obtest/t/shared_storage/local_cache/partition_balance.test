#####################
# owner : wangzhennan.wzn
# owner group : RS
# description : test partition balance for shared storage mode
#####################
ob1=OBI(cluster=1:1:1,proxy_num=0);

let $extra_conf = "cpu_count=16,memory_limit='20G',system_memory='5G',_hidden_sys_tenant_memory='1G',__min_full_resource_pool_memory='1073741824',cache_wash_threshold='1G',enable_async_syslog=false,_private_buffer_size='16K',_fast_commit_callback_count='1',log_disk_size='20G',diag_syslog_per_error_limit=100000";
ob1.z1.obs0.set extra_config=$extra_conf;
ob1.z2.obs0.set extra_config=$extra_conf;
ob1.z3.obs0.set extra_config=$extra_conf;

ob1.reboot;
sleep 3;
let $sys_tenant_id = 1;
ob1.mysql alter system set enable_rebalance='false';
ob1.mysql alter system set _transfer_start_trans_timeout = '10s';

ob_connect(conn_sys, ob1.z1.obs0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);
connection conn_sys;
set @@session.ob_query_timeout = 1000000000;
alter system set debug_sync_timeout = '1000s';

--echo ===============================================================
--echo ============== test create tablet distribution ================
--echo ===============================================================
source t/quick/include/create_tablet_distribution.inc;
# wait unit gc after tenant dropped
ob1.check_until_timeout select count(*) from GV\$OB_UNITS where tenant_id != 1, 0, 120;

--echo ===============================================================
--echo ================= test partition rebalance ====================
--echo ===============================================================
--echo # wait unit gc for dropped tenant
ob1.check_until_timeout select count(*) from GV\$OB_UNITS where tenant_id != 1, 0, 120;
--echo # create mysql tenant
CREATE RESOURCE UNIT if not exists unit_1 MAX_CPU 2, MEMORY_SIZE='4G';
CREATE RESOURCE POOL if not exists pool_1 UNIT = 'unit_1', UNIT_NUM = 1;
CREATE TENANT mysql RESOURCE_POOL_LIST = ('pool_1'), primary_zone='z1,z2,z3', locality="F@z1,F@z2,F@z3" set ob_tcp_invited_nodes='%';

let $mysql_tenant_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name = 'mysql', tenant_id, 1);
let $mysql_leader_ip_port=deploy_get_value(ob1.select select concat(svr_ip,':',svr_port) as host from __all_virtual_ls_meta_table where tenant_id = $mysql_tenant_id and ls_id =  1 and role = 1 limit 1, host, 1);
let $mysql_leader_obs =deploy_get_value(ob1.get_obs_by_addr $mysql_leader_ip_port);
ob_connect(conn_mysql, $mysql_leader_obs, root@mysql, , test, , USE_MYSQL_CONNECTOR);

--echo ################################################
--echo # 1. prepare data
--echo # create tablegroup
create tablegroup tg_none sharding = 'NONE';
create tablegroup tg_part sharding = 'PARTITION';
create tablegroup tg_adapt_one sharding = 'ADAPTIVE';
create tablegroup tg_adapt_two sharding = 'ADAPTIVE';
--echo # create table
# block the balance thread to make the table creation distribution stable
ob1.mysql set ob_global_debug_sync = 'BEFORE_TENANT_BALANCE_SERVICE wait_for signal_balance';

create table t_nonpart_1(c1 int, c2 int, c3 longtext, index(c1) local, index(c2) global);
create table t_part_1(c1 int, c2 int, c3 longtext, index(c1) local, index(c2) global) partition by hash(c1) partitions 3;
create table t_subpart_1(c1 int, c2 int, c3 longtext, index(c1) local, index(c2) global) partition by hash(c1) partitions 3 subpartition by hash(c2) subpartitions 3;
create table t_subpart_2(c1 int, c2 int, c3 longtext, index(c1) local, index(c2) global) partition by hash(c1) partitions 3 subpartition by hash(c2) subpartitions 3;
# TODO: @yunyi, enable me later.
#create table t_multivalue_part_1 (c1 int primary key, id BIGINT not null,  modified  BIGINT not null, custinfo JSON, index multi_zips( (CAST(custinfo->'$.zipcode' AS UNSIGNED ARRAY))) )  partition by hash(c1) partitions 3;

# TODO: @jinzhu, enable me later.
#create table t_fts_part_1 (c1 int primary key, c2 varchar(100), c3 text, fulltext ctx(c2, c3)) partition by hash(c1) partitions 3;

# TODO: create the table with vec index to verify.

ob1.mysql set ob_global_debug_sync = 'now signal signal_balance';
connection conn_sys;
let $mysql_tenant_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name = 'mysql', tenant_id, 1);
#let $t_multivalue_table_id = deploy_get_value(ob1.select select table_id from CDB_OB_TABLE_LOCATIONS where tenant_id=$mysql_tenant_id and table_name = 't_multivalue_part_1', table_id, 1);
#eval select distinct table_id, table_name, partition_name, subpartition_name, tablet_id, ls_id from CDB_OB_TABLE_LOCATIONS where tenant_id=$mysql_tenant_id and (table_id= $t_multivalue_table_id  or data_table_id=$t_multivalue_table_id) order by table_id, tablet_id;

#let $t_fts_table_id = deploy_get_value(ob1.select select table_id from CDB_OB_TABLE_LOCATIONS where tenant_id=$mysql_tenant_id and table_name = 't_fts_part_1', table_id, 1);
#eval select distinct table_id, table_name, partition_name, subpartition_name, tablet_id, ls_id from CDB_OB_TABLE_LOCATIONS where tenant_id=$mysql_tenant_id and (table_id= $t_fts_table_id  or data_table_id=$t_fts_table_id) order by table_id, tablet_id;

eval select distinct table_id, table_name, partition_name, subpartition_name, tablet_id, ls_id from CDB_OB_TABLE_LOCATIONS where tenant_id = $mysql_tenant_id and table_type = 'USER TABLE' order by table_id, tablet_id;

--echo ###################
--echo # 2. test tablegroup
connection conn_mysql;
alter table t_nonpart_1 tablegroup tg_none;
alter table t_part_1 tablegroup tg_none;
alter table t_subpart_1 tablegroup tg_none;
alter table t_subpart_2 tablegroup tg_none;
#alter table t_multivalue_part_1 tablegroup tg_none;
#alter table t_fts_part_1 tablegroup tg_none;

ob1.mysql alter system set partition_balance_schedule_interval = '10s' tenant mysql;
ob1.check_until_timeout select count(distinct(ls_id)) from CDB_OB_TABLE_LOCATIONS where tenant_id = $mysql_tenant_id and table_type = 'USER TABLE', 1, 120;
connection conn_sys;
#eval select distinct table_id, table_name, partition_name, subpartition_name, tablet_id, ls_id from CDB_OB_TABLE_LOCATIONS where tenant_id = $mysql_tenant_id and table_type = 'USER TABLE' or (table_id in ($t_multivalue_table_id, $t_fts_table_id) or data_table_id in ($t_multivalue_table_id, $t_fts_table_id)) order by table_id, tablet_id;

--echo # 2.2. test tablegroup sharding = 'PARTITION'
connection conn_mysql;
alter table t_part_1 tablegroup tg_part;
#alter table t_multivalue_part_1 tablegroup tg_part;
#alter table t_fts_part_1 tablegroup tg_part;
alter table t_subpart_1 tablegroup tg_part;
ob1.check_until_timeout select count(distinct(ls_id)) from CDB_OB_TABLE_LOCATIONS where tenant_id = $mysql_tenant_id and table_name = 't_part_1', 3, 60;
#ob1.check_until_timeout select count(distinct(ls_id)) from CDB_OB_TABLE_LOCATIONS where tenant_id = $mysql_tenant_id and table_name = 't_multivalue_part_1', 3, 60;
#ob1.check_until_timeout select count(distinct(ls_id)) from CDB_OB_TABLE_LOCATIONS where tenant_id = $mysql_tenant_id and table_name = 't_fts_part_1', 3, 60;
ob1.check_until_timeout select count(distinct(ls_id)) from CDB_OB_TABLE_LOCATIONS where tenant_id = $mysql_tenant_id and table_name = 't_subpart_1', 3, 60;
ob1.check_until_timeout select count(*) from CDB_OB_BALANCE_JOBS where tenant_id = $mysql_tenant_id, 0, 120;
let $tg_part_table_ids = select table_id from CDB_OB_TABLE_LOCATIONS where tenant_id = $mysql_tenant_id and table_name in ('t_part_1', 't_subpart_1', 't_multivalue_part_1', 't_fts_part_1');
connection conn_sys;
eval select distinct ls_id, table_id, table_name, partition_name, subpartition_name, tablet_id from CDB_OB_TABLE_LOCATIONS where tenant_id = $mysql_tenant_id and table_id in ($tg_part_table_ids) order by table_id, tablet_id;

--echo ##
--echo # 2.2. test tablegroup sharding = 'ADAPTIVE'
connection conn_mysql;
alter table t_part_1 tablegroup tg_adapt_one;
alter table t_subpart_1 tablegroup tg_adapt_two;
ob1.check_until_timeout select count(*) > 0 from CDB_OB_BALANCE_JOBS where tenant_id = $mysql_tenant_id, 1, 120;
ob1.check_until_timeout select count(distinct(ls_id)) from CDB_OB_TABLE_LOCATIONS where tenant_id = $mysql_tenant_id and table_name = 't_subpart_1' and partition_name = 'p0', 3, 60;
ob1.check_until_timeout select count(distinct(ls_id)) from CDB_OB_TABLE_LOCATIONS where tenant_id = $mysql_tenant_id and table_name = 't_subpart_1' and partition_name = 'p1', 3, 60;
ob1.check_until_timeout select count(distinct(ls_id)) from CDB_OB_TABLE_LOCATIONS where tenant_id = $mysql_tenant_id and table_name = 't_subpart_1' and partition_name = 'p2', 3, 60;
ob1.check_until_timeout select count(distinct(ls_id)) from CDB_OB_TABLE_LOCATIONS where tenant_id = $mysql_tenant_id and table_name = 't_part_1', 3, 60;
ob1.check_until_timeout select count(*) from CDB_OB_BALANCE_JOBS where tenant_id = $mysql_tenant_id, 0, 120;
let $tg_adapt_table_ids = select table_id from CDB_OB_TABLE_LOCATIONS where tenant_id = $mysql_tenant_id and table_name in ('t_part_1', 't_subpart_1');
connection conn_sys;
eval select distinct ls_id, table_id, table_name, partition_name, subpartition_name, tablet_id from CDB_OB_TABLE_LOCATIONS where tenant_id = $mysql_tenant_id and table_id in ($tg_adapt_table_ids) order by table_id, tablet_id;

--echo ##
--echo # 2.3. all local index and aux lob tables are bound to primary table
let $global_index_table_ids = select table_id from __all_virtual_table where tenant_id = $mysql_tenant_id and index_type in (3,4,11,17,18,19) and table_id > 500000;
let $all_user_tablets = select distinct ls_id, table_id, data_table_id, table_name, partition_name, subpartition_name, tablet_id from CDB_OB_TABLE_LOCATIONS where tenant_id = $mysql_tenant_id and table_type = 'USER TABLE';
let $all_binding_tablets = select distinct ls_id, table_id, data_table_id, table_name, partition_name, subpartition_name, tablet_id from CDB_OB_TABLE_LOCATIONS where tenant_id = $mysql_tenant_id and table_type != 'USER TABLE' and table_id > 500000 and table_id not in ($global_index_table_ids);
ob1.check_until_timeout select count(*) from ($all_user_tablets) as A join ($all_binding_tablets) as B on A.table_id = B.data_table_id and A.partition_name = B.partition_name and A.subpartition_name = B.subpartition_name and A.ls_id != B.ls_id, 0, 1;


--echo ################################################
--echo # 3. partition balance of all user tables and global indexes
connection conn_mysql;
alter table t_nonpart_1 tablegroup '';
alter table t_part_1 tablegroup '';
alter table t_subpart_1 tablegroup '';
alter table t_subpart_2 tablegroup '';
ob1.check_until_timeout select count(*) from CDB_OB_BALANCE_JOBS where tenant_id = $mysql_tenant_id, 1, 60;
ob1.check_until_timeout select count(*) from CDB_OB_BALANCE_JOBS where tenant_id = $mysql_tenant_id, 0, 120;
ob1.check_until_timeout select count(*) from (select * from __all_virtual_balance_group_ls_stat where tenant_id = $mysql_tenant_id group by balance_group_name having (max(tablet_group_count) - min(tablet_group_count) > 1)), 0, 60;
ob1.check_until_timeout select max(cnt) - min(cnt) <= 1 from (select sum(tablet_group_count) as cnt, ls_id from __all_virtual_balance_group_ls_stat where tenant_id = $mysql_tenant_id group by ls_id), 1, 60;
connection conn_sys;
--echo ##
--echo # 3.1. all balance groups
eval select ls_id, balance_group_id_high, balance_group_id_low, tablet_group_count, balance_group_name from __all_virtual_balance_group_ls_stat where tenant_id = $mysql_tenant_id order by balance_group_id_high, balance_group_id_low, ls_id;
--echo ##
--echo # 3.2. distribution of all user tables and global indexes
eval select A.ls_id, count(*) as cnt from CDB_OB_TABLE_LOCATIONS A left join __all_virtual_table B on A.tenant_id = B.tenant_id and A.table_id = B.table_id where A.tenant_id = $mysql_tenant_id and (A.table_type = 'USER TABLE' or B.index_type in (3,4,11,17,18,19)) and A.role = 'LEADER' and A.table_id > 500000 group by A.ls_id order by A.ls_id;
--echo ##
--echo # 3.3. all local index and aux lob tables are bound to primary table
ob1.check_until_timeout select count(*) from ($all_user_tablets) as A join ($all_binding_tablets) as B on A.table_id = B.data_table_id and A.partition_name = B.partition_name and A.subpartition_name = B.subpartition_name and A.ls_id != B.ls_id, 0, 1;

# there has no disk partition balance in shared storage mode

--echo drop tenants
connection conn_sys;
set recyclebin = off;
drop tenant mysql force;
