# owner: shifangdan.sfd
# owner group: cloud storage
# Testing Case: exist ss_format file lead to boostrap fail

ob1=OBI(cluster=1, proxy_num=0, init_unit_cpu=0);
ob1.reboot;
let $shared_storage_info = deploy_get_value(ob1.get_shared_storage_info);
ob1.force_stop;
ob1.z1.obs0.rmdir;

--echo # =========================================================
--echo #      reboot again with the same shared storage path
--echo # ========================================================
ob1.deploy;
let $z1_ip = deploy_get_value(ob1.z1.obs0.ip);
let $z1_port = deploy_get_value(ob1.z1.obs0.port);
sleep 20;
--error 4117
ob1.mysql_root_p ALTER SYSTEM BOOTSTRAP ZONE 'z1' SERVER '$z1_ip:$z1_port' $shared_storage_info;
ob1.force_stop;