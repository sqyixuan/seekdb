# owner: fengjingkun.fjk
# owner group: storage
# Test Case: multi-replica tenant major merge in shared storage mode


#################################### reboot && connect sys tenant  ####################################
ob1=OBI(cluster=1:1:1, proxy_num=0, init_unit_cpu=0);
ob1.reboot;

let $svr_ip = deploy_get_value(ob1.z1.obs0.ip);
let $svr_port = deploy_get_value(ob1.z1.obs0.mysql_port);

connect (obsys, $svr_ip, root@sys, , oceanbase, $svr_port);
connection obsys;


#####################################  set related tenant config  #####################################
alter system set major_freeze_duty_time = 'Disable' tenant sys;
alter system set ob_compaction_schedule_interval = '10s' tenant sys;
alter system set _ss_major_compaction_prewarm_level = 2 tenant sys;



###################################  prepare table for sys tenant   ###################################
create table t1 (c1 int PRIMARY KEY, c2 int, c3 int);
# shared-storage does not support column group right now, test column group later
#create table t2 (c1 int PRIMARY KEY, c2 int, c3 int) with column group (each column);
insert into t1 value(1, 1, 1);
insert into t1 value(2, 2, 2);
insert into t1 value(3, 3, 3);
#insert into t2 value(1, 1, 1);
#insert into t2 value(2, 2, 2);
#insert into t2 value(3, 3, 3);


######################  one round of major merge && check major merge status  ######################
alter system major freeze tenant sys;
source include/compaction/wait_tenant_major_finish_on_ss.inc;

select * from t1;
let $tablet_id = deploy_get_value(ob1.select select tablet_id from oceanbase.__all_virtual_table where table_name="t1", tablet_id, 1);
let $major_scn = deploy_get_value(ob1.select select GLOBAL_BROADCAST_SCN from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id=1, GLOBAL_BROADCAST_SCN, 1);
let $sstable_cnt = deploy_get_value(ob1.select select count(*) > 3 as cnt from oceanbase.__all_virtual_table_mgr where tablet_id=$tablet_id and end_log_scn=$major_scn and table_type=10, cnt, 1);
if ($sstable_cnt != 1) {
--echo "row store major sstable not refresh"
}


#############################################  drop table #############################################
--disable_warnings
drop table if exists t1;
--enable_warnings

disconnect obsys;

