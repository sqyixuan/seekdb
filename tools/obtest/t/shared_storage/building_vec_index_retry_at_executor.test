# owner: fanfangyao.ffy
# owner group: storage
# description: test building vector index retry at executor in ss mode

ob1=OBI(cluster=1:1,proxy_num=0,init_unit_cpu=2);
ob1.reboot;

ob1.mysql alter system set merger_check_interval='10s';
ob1.mysql alter system set enable_rebalance = 'false';
ob1.mysql alter system set resource_hard_limit=500;
ob1.mysql alter system set debug_sync_timeout = '100000s';

let $ip0 = deploy_get_value(ob1.z1.obs0.ip);
let $mysql_port0 = deploy_get_value(ob1.z1.obs0.mysql_port);

connect (conn_sys, $ip0, root@sys, , oceanbase, $mysql_port0);
connection conn_sys;

connect(conn_obtest1,$ip0,root@obtest,,test,$mysql_port0);

# test create path for building vector index (hnsw)
connection conn_obtest1;
create table t_vec(c1 int primary key, c2 vector(3));
insert into t_vec values (0, '[0.1,0.2,0.3]');
insert into t_vec values (1, '[0.4,0.5,0.6]');
insert into t_vec values (2, '[0.7,0.8,0.9]');

ob1.z1.obs0.mysql alter system set_tp tp_name = EN_POST_VEC_INDEX_BUILD_ROWKEY_VID_TBL_ERR, error_code = 4013, frequency = 1;
sleep 5;

send create vector index idx_vec on t_vec(c2) with (distance=l2, type=hnsw, lib=vsag);
sleep 2;

ob1.z1.obs0.mysql alter system set_tp tp_name = EN_POST_VEC_INDEX_BUILD_ROWKEY_VID_TBL_ERR, error_code = 0, frequency = 1;
sleep 5;

let $ret_code = deploy_get_value(ob1.select select ret_code from __all_virtual_ddl_error_message where ret_code=-4013 limit 1, ret_code, 1);
echo $ret_code;

sleep 5;
connection conn_obtest1;
--error 5703
reap;


