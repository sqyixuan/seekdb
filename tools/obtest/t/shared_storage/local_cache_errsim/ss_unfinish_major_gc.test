
--echo "1. =========== bootstrap ==========="
ob1=OBI(cluster=1:1, proxy_num=0, init_unit_cpu=0);
source include/mini_ob_config.inc;
ob1.set extra_config=$mini_ob_config;
ob1.reboot;

ob1.mysql ALTER SYSTEM SET enable_rebalance = 'false';
ob1.mysql ALTER SYSTEM SET enable_rereplication = 'true';

let $proxy_ip = deploy_get_value(ob1.z1.obs0.ip);
let $proxy_port = deploy_get_value(ob1.z1.obs0.mysql_port);
connect(sys_conn, $proxy_ip, root@sys,,oceanbase, $proxy_port);

let $proxy_ip2 = deploy_get_value(ob1.z2.obs0.ip);
let $proxy_port2 = deploy_get_value(ob1.z2.obs0.mysql_port);
connect(sys_conn2, $proxy_ip2, root@sys,,oceanbase, $proxy_port2);

--echo "2. =========== create tenant ==========="
source include/create_unit_config.inc;
ob1.mysql CREATE RESOURCE POOL tenant_pool UNIT = "2c2g", UNIT_NUM = 1, ZONE_LIST = ('z1', 'z2');
ob1.mysql CREATE TENANT gc_tenant RESOURCE_POOL_LIST=('tenant_pool') SET ob_tcp_invited_nodes='%';
let $tenant_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name='gc_tenant', tenant_id, 1);

--echo "3. =========== create table and insert data ==========="
ob_connect(conn_mysql, ob1.z1.obs0, root@gc_tenant, , test, , USE_MYSQL_CONNECTOR);
connection conn_mysql;
eval create table t (a int);

let $tablet_id = deploy_get_value(ob1.select select tablet_id from oceanbase.__all_virtual_table where table_name="t", tablet_id, 1);

insert into t values (1);

--echo "4. =========== major freeze ==========="
sleep 60;
alter system set ob_compaction_schedule_interval = '10s';
alter system major freeze;
source include/compaction/wait_tenant_major_finish_on_ss.inc;
connection conn_mysql;

--echo "5. =========== insert data again ==========="
#delete from t where a=1;
insert into t values (2);

--echo "6. =========== major freeze again ==========="
sleep 5;
# EN_SHARED_STORAGE_DONT_UPDATE_LS_STATE=(INDEX_VERIFY)
ob1.mysql alter system set_tp tp_no=746, error_code=3, frequency=1;
alter system major freeze;
# source include/compaction/wait_tenant_major_finish_on_ss.inc;
connection conn_mysql;

--echo "7. =========== wait gc meta version ==========="
alter system set _ss_old_ver_retention_time = '1s';
let $shared_gc_ip_port = deploy_get_value(ob1.select select concat(svr_ip,':',svr_port) as host from __all_virtual_ls_meta_table where tenant_id = $tenant_id and ls_id =  1 and role = 1 order by svr_ip, svr_port limit 1, host, 1);

let $shared_obs = deploy_get_value(ob1.get_obs_by_addr $shared_gc_ip_port);

$shared_obs.check_log_until_success -c "there is uncompaction finish tablet_version.*id:$tablet_id";

sleep 10;
$shared_obs.check_log_until_success -c "finish shared tablet meta gc.*ret=0.*id:$tablet_id";

--echo "8. =========== clear cache ==========="
connection sys_conn;
alter system flush kvcache tenant='gc_tenant';
alter system flush ss_micro_cache tenant='gc_tenant';
connection sys_conn2;
alter system flush kvcache tenant='gc_tenant';
alter system flush ss_micro_cache tenant='gc_tenant';
sleep 50;

--echo "9. reboot"
ob1.restart;

sleep 50;
--echo "10. select old version"
ob_connect(conn_mysql, ob1.z1.obs0, root@gc_tenant, , test, , USE_MYSQL_CONNECTOR);
connection conn_mysql;
select*from t;

# clear EN_SHARED_STORAGE_DONT_UPDATE_LS_STATE=(INDEX_VERIFY)
ob1.mysql alter system set_tp tp_no=746, error_code=3, frequency=0;

