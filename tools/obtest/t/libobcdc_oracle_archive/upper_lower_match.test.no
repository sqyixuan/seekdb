##########################
#owner :  qianxi
#owner group: liboblog
#description:
# 测试点：
# tenant没有大小写
# database/table存在大小写
# 需要区分大小写
#

##########################

ob1=OBI(cluster=1,init_unit_cpu=2);
ob1.force_stop;
ob1.clean_backup_dest;
ob1.reboot;

ob1.mysql alter system set resource_hard_limit= 800;
sleep 2;
ob_connect(conn_sys, ob1.proxy0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);

###create oracle tenant
ob1.mysql create resource unit box1 max_cpu=2,memory_size='10G';
ob1.mysql create resource pool pool1 unit = 'box1', unit_num = 1;
ob1.mysql create tenant oracle replica_num = 1, resource_pool_list=('pool1') set ob_tcp_invited_nodes='%', ob_compatibility_mode='oracle';
sleep 2;
ob_connect(conn_oracle, ob1.z1.obs0, SYS@oracle, ,SYS, , USE_OB_CONNECTOR);

create user obtest IDENTIFIED BY "obtest";
grant all on *.* to obtest WITH GRANT OPTION;
grant dba to obtest;

# sys-mysql租户获取当前时间
ob_connect(conn_sys, ob1.proxy0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);
let $start_tstamp = query_get_value(select round(time_to_usec(now()) / 1000000) as now, now, 1);

ob_connect(conn_oracle_obtest,ob1.z1.obs0,OBTEST@oracle,obtest,obtest,,USE_OB_CONNECTOR);

source include/liboblog/enable_oracle_archive.inc;
# 大写db
create user oblog_db identified by "passwd";
# 小写db
create user 'oblog_db' identified by "passwd";

# 启动oblog
ob1.oblog.gen_conf tb_white_list=oracle.*.* log_level=DEBUG test_mode_force_fetch_archive=1 skip_ob_version_compat_check=1;
ob1.oblog.restart;
sleep 1;

## 大写db操作
alter session set current_schema = oblog_db;
# 大写table
create table upper_db_upper_table(c0 int primary key, c1 int);
ob1.oblog.next;
insert into upper_db_upper_table values(1, 1);
ob1.oblog.next;
# 小写table
create table "upper_db_lower_table"(c0 int primary key, c1 int);
ob1.oblog.next;
begin;
update oblog_db.upper_db_upper_table set C1 = 10 where C0=1;
insert into "upper_db_lower_table" values(1, 1);
commit;
ob1.oblog.next;

# 小写db操作
alter session set current_schema = "oblog_db";
# 大写table
create table lower_db_upper_table(c0 int primary key, c1 int);
ob1.oblog.next;
begin;
update oblog_db."upper_db_lower_table" set C1 = 10 where C0=1;
insert into lower_db_upper_table values(1, 1);
commit;
ob1.oblog.next;
# 小写table
create table "lower_db_lower_table"(c0 int primary key, c1 int);
ob1.oblog.next;
begin;
update "oblog_db".lower_db_upper_table set C1 = 10 where C0=1;
insert into "lower_db_lower_table" values(1, 1);
commit;
ob1.oblog.next;

# stop liboblog
ob1.oblog.stop;

# 回拉历史
# 只同步大写db
ob1.oblog.set_start_tstamp $start_tstamp;
ob1.oblog.gen_conf tb_white_list=oracle.OBLOG_DB.* log_level=DEBUG enable_oracle_mode_match_case_sensitive=1 test_mode_force_fetch_archive=1 skip_ob_version_compat_check=1;
ob1.oblog.restart;

let $DML_CNT = 2;
while ($DML_CNT > 0)
{
  ob1.oblog.next_dml;
  dec $DML_CNT;
}
# stop liboblog
ob1.oblog.stop;

# 回拉历史
# 只同小写db
ob1.oblog.set_start_tstamp $start_tstamp;
ob1.oblog.gen_conf tb_white_list=oracle.oblog_db.* log_level=DEBUG enable_oracle_mode_match_case_sensitive=1 test_mode_force_fetch_archive=1 skip_ob_version_compat_check=1;
ob1.oblog.restart;

let $DML_CNT = 2;
while ($DML_CNT > 0)
{
  ob1.oblog.next_dml;
  dec $DML_CNT;
}
# stop liboblog
ob1.oblog.stop;

# 回拉历史
# 只同大写db大写table
ob1.oblog.set_start_tstamp $start_tstamp;
ob1.oblog.gen_conf tb_white_list=oracle.OBLOG_DB.UPPER_DB_UPPER_TABLE log_level=DEBUG enable_oracle_mode_match_case_sensitive=1 test_mode_force_fetch_archive=1 skip_ob_version_compat_check=1;
ob1.oblog.restart;

let $DML_CNT = 2;
while ($DML_CNT > 0)
{
  ob1.oblog.next_dml;
  dec $DML_CNT;
}
# stop liboblog
ob1.oblog.stop;

# 回拉历史
# 只同小写db小写table
ob1.oblog.set_start_tstamp $start_tstamp;
ob1.oblog.gen_conf tb_white_list=oracle.oblog_db.lower_db_lower_table log_level=DEBUG enable_oracle_mode_match_case_sensitive=1 test_mode_force_fetch_archive=1 skip_ob_version_compat_check=1;
ob1.oblog.restart;

let $DML_CNT = 1;
while ($DML_CNT > 0)
{
  ob1.oblog.next_dml;
  dec $DML_CNT;
}
# stop liboblog
ob1.oblog.stop;

################################################# 默认大小写匹配不敏感
# 回拉历史
ob1.oblog.set_start_tstamp $start_tstamp;
ob1.oblog.gen_conf tb_white_list=oracle.oblog_db.* log_level=DEBUG test_mode_force_fetch_archive=1 skip_ob_version_compat_check=1;
ob1.oblog.restart;

let $DML_CNT = 4;
while ($DML_CNT > 0)
{
  ob1.oblog.next_dml;
  dec $DML_CNT;
}
# stop liboblog
ob1.oblog.stop;

# 回拉历史
# 默认大小写匹配不敏感
ob1.oblog.set_start_tstamp $start_tstamp;
ob1.oblog.gen_conf tb_white_list=oracle.OBLOG_DB.* log_level=DEBUG test_mode_force_fetch_archive=1 skip_ob_version_compat_check=1;
ob1.oblog.restart;

let $DML_CNT = 4;
while ($DML_CNT > 0)
{
  ob1.oblog.next_dml;
  dec $DML_CNT;
}
# stop liboblog
ob1.oblog.stop;

# 回拉历史
# 只同小写db小写table
ob1.oblog.set_start_tstamp $start_tstamp;
ob1.oblog.gen_conf tb_white_list=oracle.oblog_db.LOWER_DB_LOWER_TABLE log_level=DEBUG test_mode_force_fetch_archive=1 skip_ob_version_compat_check=1;
ob1.oblog.restart;

let $DML_CNT = 1;
while ($DML_CNT > 0)
{
  ob1.oblog.next_dml;
  dec $DML_CNT;
}
# stop liboblog
ob1.oblog.stop;

# 回拉历史
# 只同小写db小写table
ob1.oblog.set_start_tstamp $start_tstamp;
ob1.oblog.gen_conf tb_white_list=oracle.OBLOG_DB.LOWER_DB_LOWER_TABLE log_level=DEBUG test_mode_force_fetch_archive=1 skip_ob_version_compat_check=1;
ob1.oblog.restart;

let $DML_CNT = 1;
while ($DML_CNT > 0)
{
  ob1.oblog.next_dml;
  dec $DML_CNT;
}

drop user oblog_db cascade;
ob1.oblog.next;

# stop liboblog
ob1.oblog.stop;
