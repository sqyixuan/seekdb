#ret := dbms_xa.xa_rollback(xid);
#dbms_output.put_line(ret);
#end;

#理论上不输出或输出EOF
#ob1.oblog.next;
select * from t1;
# --------- end rollback case --------------

# --------- start special character case -----
set autocommit = 'OFF';
declare xid dbms_xa_xid; ret pls_integer; begin xid := dbms_xa_xid(0, '', ''); xid.formatid := 2; xid.gtrid := UTL_RAW.cast_to_raw('奥星贝斯@∂∑πœ¡™£º–ƒ¶≠≤µœ¬'); xid.bqual := UTL_RAW.cast_to_raw('阿里巴巴ø¬∫ßå∂œ'); ret := dbms_xa.xa_start(xid, dbms_xa.tmnoflags); dbms_output.put_line(ret); insert into t1 values(300); insert into t1 values(500); ret := dbms_xa.xa_end(xid, dbms_xa.tmsuccess); dbms_output.put_line(ret); ret := dbms_xa.xa_prepare(xid); dbms_output.put_line(ret); ret := dbms_xa.xa_commit(xid, false); dbms_output.put_line(ret); end;
