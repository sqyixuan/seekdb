ob1.oblog.next;
# --------- end special character case ---------

# ----------start empty redo case----------
connection conn_sys;
let $start_tstamp = query_get_value(select time_to_usec(now(6)) as now, now, 1);
connection conn_oracle_obtest;
# 理论上autocommit已经是OFF了，这里重复设置确认下
set autocommit = 'OFF';
# show variables like 'autocommit';

declare xid dbms_xa_xid; ret pls_integer; begin xid := dbms_xa_xid(0, '', ''); xid.formatid := 2; xid.gtrid := UTL_RAW.cast_to_raw('NFL'); xid.bqual := UTL_RAW.cast_to_raw('chiefs'); ret := dbms_xa.xa_start(xid, dbms_xa.tmnoflags); insert into test_xa(c1, c2) values(1, 1); delete from test_xa; ret := dbms_xa.xa_end(xid, dbms_xa.tmsuccess); ret := dbms_xa.xa_prepare(xid); ret := dbms_xa.xa_commit(xid, false); end;
#declare
#xid dbms_xa_xid;
#ret pls_integer;
#begin xid.formatid := 2;
#xid.gtrid := UTL_RAW.cast_to_raw('NFL');
#xid.bqual := UTL_RAW.cast_to_raw('chiefs');
#ret := dbms_xa.xa_start(xid, dbms_xa.tmnoflags);
#insert into test_xa(c1, c2) values(1, 1);
#delete from test_xa;
#ret := dbms_xa.xa_end(xid, dbms_xa.tmsuccess);
#ret := dbms_xa.xa_prepare(xid);
#ret := dbms_xa.xa_commit(xid, false);
#end;

ob1.oblog.next;

#--- restart with miss log
ob1.oblog.gen_conf tb_white_list=oracle.*.* sort_trans_participants=1 log_level=DEBUG test_mode_on=1 test_mode_ignore_redo_count=2 test_mode_force_fetch_archive=1 skip_ob_version_compat_check=1;
ob1.oblog.set_start_tstamp_usec $start_tstamp;
ob1.oblog.restart;
ob1.oblog.next;

# ----------end empty redo case------------

drop table test_xa;
ob1.oblog.next;

drop table t1;
ob1.oblog.next;

ob1.oblog.stop;
