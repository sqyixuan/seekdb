##########################
#owner : linlin.xll
#owner group: sql1
#description:
# 测试点：
#  procedure ddl
#

ob1=OBI(cluster=1,init_unit_cpu=2);
ob1.force_stop;
ob1.clean_backup_dest;
ob1.reboot;

source include/liboblog/create_oracle_tenant.inc;
source include/liboblog/enable_oracle_archive.inc;

ob1.oblog.gen_conf tb_white_list=oracle.*.* log_level=DEBUG test_mode_force_fetch_archive=1 skip_ob_version_compat_check=1;
ob1.oblog.restart;

## 创建procedure
create or replace procedure proc is begin null; end;
ob1.oblog.next;

## 删除procedure
drop procedure proc;
ob1.oblog.next;

## 创建function
create or replace function func return int is begin return 1; end;
ob1.oblog.next;

## 删除function
drop function func;
ob1.oblog.next;

## 创建package
create or replace package pack is x int; y char(1); procedure proc; end;
ob1.oblog.next;

## 删除package
drop package pack;
ob1.oblog.next;

## 创建package body
create or replace package body pack is procedure proc is begin null; end; end;
ob1.oblog.next;

## 删除package
drop package body pack;
ob1.oblog.next;

## 创建package
create or replace package pack is x int; y char(1); procedure proc; end;
ob1.oblog.next;

## 创建package body
create or replace package body pack is procedure proc is begin null; end; end;
ob1.oblog.next;

## 删除package
drop package pack;
ob1.oblog.next;

## 创建udt
create or replace type ty is table of int;
ob1.oblog.next;

## 删除udt
drop type ty;
ob1.oblog.next;

## 创建udt
create or replace type ty is object(col1 int, col2 int);
ob1.oblog.next;

## 删除udt
drop type ty;
ob1.oblog.next;

## 创建表
create table t(col int);
ob1.oblog.next;

## 匿名块中执行dml
begin insert into t values(1); insert into t values(2); update t set col = 3 where col = 1; end;
ob1.oblog.next;

## 匿名块中执行dml, SELECT语句不会产生日志, 不需要调用oblog.next
declare type t is table of int; x t; begin select col bulk collect into x from t; end;

## prcedure中执行dml
create or replace procedure proc is begin delete from t; end;
ob1.oblog.next;

## call
call proc();
ob1.oblog.next;

## 删除procedure
drop procedure proc;
ob1.oblog.next;

## package中的procedure执行dml
create or replace package pack is procedure proc; end;
ob1.oblog.next;

create or replace package body pack is procedure proc is begin delete from t; end; end;
ob1.oblog.next;

## 在表中插入一行数据
insert into t values(1);
ob1.oblog.next;

call pack.proc();
ob1.oblog.next;

drop package pack;
ob1.oblog.next;

## 匿名块中执行ddl
begin execute immediate 'drop table t;'; end;
ob1.oblog.next;

## 匿名块中执行ddl,dml
begin execute immediate 'create table t(col int)'; execute immediate 'insert into t values(1)'; end;
ob1.oblog.next;
ob1.oblog.next;

## 删除表
drop table t;
ob1.oblog.next;
