##########################
#owner :  qianxi
#owner group: liboblog
#description:
# 测试点：
# blob
#

##########################

ob1=OBI(cluster=1,init_unit_cpu=2);
ob1.reboot;

source include/liboblog/create_oracle_tenant.inc;

ob_connect(conn_sys, ob1.proxy0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);
# 导入时区信息
# TODO  remove ob支持自动加载
source include/liboblog/import_time_zone.inc;

connection conn_oracle_obtest;

# 启动oblog
ob1.oblog.gen_conf tb_white_list=oracle.*.* log_level=DEBUG skip_ob_version_compat_check=1;
ob1.oblog.restart;

alter session set current_schema = oblog_db;
sleep 1;

create table t20181202 (c1 int);
ob1.oblog.next;

alter table t20181202 add c2 timestamp with time zone default Date '2012-12-02';
ob1.oblog.next;
insert into t20181202 (c1) values (1);
ob1.oblog.next;

alter table t20181202 add c3 timestamp with time zone default Timestamp '2012-12-02 12:01:02.123';
ob1.oblog.next;
insert into t20181202 (c1) values (2);
ob1.oblog.next;

alter table t20181202 add c4 timestamp with time zone default Timestamp '2012-12-02 12:01:02.123 +08:00';
ob1.oblog.next;
insert into t20181202 (c1) values (3);
ob1.oblog.next;

alter table t20181202 add c5 timestamp with time zone default Timestamp '2012-12-02 12:01:02.123 Asia/Shanghai';
ob1.oblog.next;
insert into t20181202 (c1) values (4);
ob1.oblog.next;

alter table t20181202 add c6 timestamp with time zone default '2012-12-02';
ob1.oblog.next;
insert into t20181202 (c1) values (5);
ob1.oblog.next;

insert into t20181202 (c1, c2) values (6, '2012-12-02 12:01:02.123 Asia/Shanghai');
ob1.oblog.next;

drop user oblog_db cascade;
ob1.oblog.next;

# stop liboblog
ob1.oblog.stop;
