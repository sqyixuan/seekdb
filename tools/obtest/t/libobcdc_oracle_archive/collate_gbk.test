
ob1=OBI(cluster=1,init_unit_cpu=2);
ob1.force_stop;
ob1.clean_backup_dest;
ob1.reboot;

# 创建oracle租户, 指定字符集，并切换到oracle租户
ob1.mysql alter system set resource_hard_limit= 800;
sleep 2;
ob_connect(conn_sys, ob1.proxy0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);

--disable_warnings
drop tenant if exists oracle;
--disable_warnings
drop resource pool if exists oblog_pool;
--disable_warnings
drop resource unit if exists oblog_box;

### create oracle tenant
ob1.mysql create resource unit oblog_box max_cpu=2, memory_size='10G';
ob1.mysql create resource pool oblog_pool unit = 'oblog_box', unit_num = 1;
################################################################ 创建租户指定collate collate gbk_bin
ob1.mysql create tenant oracle replica_num = 1, resource_pool_list=('oblog_pool'), collate gbk_bin set ob_tcp_invited_nodes='%', ob_compatibility_mode='oracle';
ob1.mysql alter tenant oracle set variables autocommit='on';
ob1.mysql alter tenant oracle set variables nls_date_format='YYYY-MM-DD HH24:MI:SS';
ob1.mysql alter tenant oracle set variables nls_timestamp_format='YYYY-MM-DD HH24:MI:SS.FF';
ob1.mysql alter tenant oracle set variables nls_timestamp_tz_format='YYYY-MM-DD HH24:MI:SS.FF TZR TZD';

sleep 2;
ob_connect(conn_oracle, ob1.z1.obs0, SYS@oracle, ,SYS, , USE_OB_CONNECTOR);

### create user
create user obtest IDENTIFIED BY "obtest";
grant all on *.* to obtest WITH GRANT OPTION;
grant dba to obtest;
ob_connect(conn_oracle_obtest,ob1.z1.obs0,OBTEST@oracle,obtest,obtest,,USE_OB_CONNECTOR);

let $oracle_tenant_name=oracle;
let $original_conn=conn_oracle_obtest;

source include/liboblog/enable_oracle_archive.inc;

# 启动oblog
ob1.oblog.gen_conf tb_white_list=oracle.*.* log_level=DEBUG test_mode_force_fetch_archive=1 skip_ob_version_compat_check=1;
# 只打印HEX
ob1.oblog.set_extra_argument -O -x;
ob1.oblog.restart;

# 创建user
create user oblog_db identified by "passwd";
# 输出创建user DDL
ob1.oblog.next;

# alter session不会生成redo日志，不需要执行liboblog输出数据
alter session set current_schema = oblog_db;
sleep 1;

# 创建t1
create table t1 (c1 int primary key, c2 varchar(100));
# 输出DDL
ob1.oblog.next;

insert into t1 values (1, 'ad');
select lower(UTL_RAW.cast_to_raw(c2)) from t1 where c1=1;
ob1.oblog.next;

insert into t1 values (2, '韥饢肯駟疶瞡苞粯');
select lower(UTL_RAW.cast_to_raw(c2)) from t1 where c1=2;
ob1.oblog.next;

insert into t1 values (3, '嫿');
select lower(UTL_RAW.cast_to_raw(c2)) from t1 where c1=3;
ob1.oblog.next;

insert into t1 values (4, '爟觑洔');
select lower(UTL_RAW.cast_to_raw(c2)) from t1 where c1=4;
ob1.oblog.next;

insert into t1 values (5, '昺摝鵕活魹胩彀莲瘨');
select lower(UTL_RAW.cast_to_raw(c2)) from t1 where c1=5;
ob1.oblog.next;

insert into t1 values (6, '祕躠閶弹偓葒');
select lower(UTL_RAW.cast_to_raw(c2)) from t1 where c1=6;
ob1.oblog.next;

# 删除表
drop table t1;
# 输出DDL
ob1.oblog.next;

# 删除user
drop user oblog_db cascade;
# 输出DDL
ob1.oblog.next;

# stop liboblog
ob1.oblog.stop;
