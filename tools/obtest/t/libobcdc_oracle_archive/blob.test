##########################
#owner :  qianxi
#owner group: liboblog
#description:
# 测试点：
# blob
#

##########################

ob1=OBI(cluster=1,init_unit_cpu=2);
ob1.force_stop;
ob1.clean_backup_dest;
ob1.reboot;

source include/liboblog/create_oracle_tenant.inc;
source include/liboblog/enable_oracle_archive.inc;

# 启动oblog
ob1.oblog.gen_conf tb_white_list=oracle.*.* log_level=DEBUG test_mode_force_fetch_archive=1 skip_ob_version_compat_check=1;
ob1.oblog.restart;

alter session set current_schema = oblog_db;
sleep 1;

set ob_default_lob_inrow_threshold=4000;
# t1
create table t1 (nr number, a clob, b blob);
ob1.oblog.next;

insert into t1 values (1, 'ad', '6164');
select * from t1 where nr=1;
ob1.oblog.next;

update t1 set b = '414243' where nr = 1;
select * from t1 where nr=1;
ob1.oblog.next;

insert into t1 values (2, '616263', '616263');
select * from t1 where nr=2;
ob1.oblog.next;

update t1 set b = '616263' || '64' where nr = 2;
select * from t1 where nr=2;
ob1.oblog.next;

insert into t1 values (3, '68656C6C6F', '68656C6C6F');
select * from t1 where nr=3;
ob1.oblog.next;

insert into t1 values (4, 'xyz', rawtohex('xyz'));
select * from t1 where nr=4;
ob1.oblog.next;

drop table t1;
ob1.oblog.next;

create table t1(pk int primary key, content blob);
ob1.oblog.next;

--let $insert_sql_base=insert into t1 values
# value = 10 hex byte = 5 byte
--let $value=6464646464
--let $kb=1
# append= 10 hex byte = 5 byte
--let $append=6162636465
while($kb<10)
{
  --let $value=$value$append
  --let $insert_sql=$insert_sql_base($kb, '$value' )
  --disable_query_log
  eval $insert_sql;
  ob1.oblog.next;
  inc $kb;
}
#eval select * from t1 where nr=$kb;
select * from t1;

drop user oblog_db cascade;
ob1.oblog.next;

# stop liboblog
ob1.oblog.stop;
