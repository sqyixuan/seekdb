##########################
# owner :  xiaofeng.lby
# owner group: sql2
# description:
# 测试点：
# invisible column in oracle mode
#

##########################

ob1=OBI(cluster=1,init_unit_cpu=2);
ob1.force_stop;
ob1.clean_backup_dest;
ob1.reboot;

source include/liboblog/create_oracle_tenant.inc;
source include/liboblog/enable_oracle_archive.inc;

connection conn_sys;
let $start_tstamp = query_get_value(select time_to_usec(now(6)) as now, now, 1);
connection conn_oracle_obtest;
# 启动oblog
ob1.oblog.gen_conf tb_white_list=oracle.*.* log_level=DEBUG enable_output_invisible_column=1 enable_output_hidden_primary_key=1 test_mode_force_fetch_archive=1 skip_ob_version_compat_check=1;
ob1.oblog.restart;

alter session set current_schema = oblog_db;
sleep 1;

# 测试 invisible 列定义为 not null 属性的情况
create table t1(c1 int invisible not null, c2 int);
ob1.oblog.next;
insert into t1(c1, c2) values(1, 2);
ob1.oblog.next;
desc t1;
select * from t1;
select c1, c2 from t1;

# 测试 invisible 列不为 not null （default null）的情况
create table t2(c1 int invisible, c2 int);
ob1.oblog.next;
insert into t2 values(2);
ob1.oblog.next;
insert into t2(c1, c2) values(1, 2);
ob1.oblog.next;
desc t2;
select * from t2;
select c1, c2 from t2;

# 测试视图的定义是 select * from 一张包含 invisible 列的表
create view v1 as select c1, c2 from t1;
ob1.oblog.next;
select * from v1;
desc v1;
select c1, c2 from v1;
create view v2 as select * from t1;
ob1.oblog.next;
select * from v2;
desc v2;

# 测试 modify invisible column
create table t3(c1 int invisible, c2 int);
ob1.oblog.next;
desc t3;
alter table t3 modify c2 invisible, modify c1 visible;
ob1.oblog.next;
desc t3;
alter table t3 modify c2 visible, modify c1 invisible;
ob1.oblog.next;
desc t3;

# 测试 add invisible column
create table t4(c1 int invisible, c2 char(10));
ob1.oblog.next;
desc t4;
alter table t4 modify c1 visible, modify c2 invisible;
ob1.oblog.next;
alter table t4 add c3 int invisible default 123;
ob1.oblog.next;
# alter table t4 add c4 int invisible unique;
# 加索引，不和其他ddl并发执行
# DDL用同一个arg发到rs执行，当执行了创建索引话，由于需要同步等待索引build，如果出现build失败，则回滚删掉该索引，另外的加列操作也要回滚
alter table t4 add c4 int invisible;
ob1.oblog.next;
desc t4;

# 测试 insert into invisible column
insert into t4 values(1);
ob1.oblog.next;
insert into t4 values(2);
ob1.oblog.next;
insert into t4(c1, c2, c3) values(3, 456, 78910);
ob1.oblog.next;
select * from t4;
select c1, c2, c3 from t4;

# 测试 drop invisible column
alter table t4 drop column c3;
ob1.oblog.next;
desc t4;

# 测试 create table as select xxx
create table t5(c1 int invisible, c2 int);
ob1.oblog.next;
create table t6 as select * from t1;
ob1.oblog.next;
ob1.oblog.next;
desc t6;

# clean up
drop table t1;
ob1.oblog.next;
drop table t2;
ob1.oblog.next;
drop table t3;
ob1.oblog.next;
drop table t4;
ob1.oblog.next;
drop table t5;
ob1.oblog.next;
drop table t6;
ob1.oblog.next;
drop view v1;
ob1.oblog.next;
drop view v2;
ob1.oblog.next;
drop user oblog_db cascade;
ob1.oblog.next;

# stop liboblog
ob1.oblog.stop;

ob1.oblog.gen_conf tb_white_list=oracle.*.* log_level=DEBUG enable_output_invisible_column=1 enable_output_hidden_primary_key=0 test_mode_force_fetch_archive=1 skip_ob_version_compat_check=1;
ob1.oblog.set_start_tstamp_usec $start_tstamp;
ob1.oblog.restart;
ob1.oblog.next_dml;
ob1.oblog.stop;
ob1.oblog.gen_conf tb_white_list=oracle.*.* log_level=DEBUG enable_output_invisible_column=0 enable_output_hidden_primary_key=0 test_mode_force_fetch_archive=1 skip_ob_version_compat_check=1;
ob1.oblog.set_start_tstamp_usec $start_tstamp;
ob1.oblog.restart;
ob1.oblog.next_dml;
ob1.oblog.stop;
ob1.oblog.gen_conf tb_white_list=oracle.*.* log_level=DEBUG enable_output_invisible_column=0 enable_output_hidden_primary_key=1 test_mode_force_fetch_archive=1 skip_ob_version_compat_check=1;
ob1.oblog.set_start_tstamp_usec $start_tstamp;
ob1.oblog.restart;
ob1.oblog.next_dml;
ob1.oblog.stop;
