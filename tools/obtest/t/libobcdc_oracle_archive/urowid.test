ob1=OBI(cluster=1,init_unit_cpu=2);
ob1.force_stop;
ob1.clean_backup_dest;
ob1.reboot;

source include/liboblog/create_oracle_tenant.inc;
source include/liboblog/enable_oracle_archive.inc;

# 启动oblog
ob1.oblog.gen_conf tb_white_list=oracle.*.* log_level=DEBUG test_mode_force_fetch_archive=1 skip_ob_version_compat_check=1;
ob1.oblog.restart;

create table test_int(pk int primary key);
ob1.oblog.next;

create table test_urowid(stored_rowid urowid, org_pk int primary key);
ob1.oblog.next;

insert into test_int values (1);
ob1.oblog.next;
insert into test_int values (2);
ob1.oblog.next;
insert into test_int values (3);
select rowid from test_int;
ob1.oblog.next;

insert into test_urowid select rowid as stored_rowid, pk as org_pk from test_int;
select stored_rowid, org_pk from test_urowid;
ob1.oblog.next;

update test_urowid set stored_rowid = '*AAEPAQEAwAIAAAA=' where org_pk = 1;
ob1.oblog.next;

delete test_urowid where stored_rowid = '*AAEPAQEAwAIAAAA=';
ob1.oblog.next;

drop table test_int;
ob1.oblog.next;

drop table test_urowid;
ob1.oblog.next;

ob1.oblog.stop;