#
# owner:lixia.yq
# owner group:liboblog
# description:
# 测试点:
#  1. 无主键表, 隐藏主键列，column id < 16
#  insert/update/delete
#  2. 索引
#
##
ob1=OBI(cluster=1,init_unit_cpu=2);
ob1.force_stop;
ob1.clean_backup_dest;
ob1.reboot;

source include/liboblog/create_oracle_tenant.inc;
source include/liboblog/enable_oracle_archive.inc;

# 启动liboblog
ob1.oblog.gen_conf tb_white_list=oracle.*.* log_level=DEBUG enable_output_hidden_primary_key=1 sort_trans_participants=1 enable_output_trans_order_by_sql_operation=1 test_mode_force_fetch_archive=1 skip_ob_version_compat_check=1;
ob1.oblog.set_extra_argument -i;
ob1.oblog.restart;

##### 1. 列数：1	分区键：1
create table t0(c0 int, c1 int as (c0 + 100)) partition by hash(c1);
ob1.oblog.next;
alter table t0 enable row movement;
ob1.oblog.next;

insert into t0(c0) values(1);
ob1.oblog.next;
insert into t0(c0) values(2);
ob1.oblog.next;

update t0 set c0=999 where c1=101;
ob1.oblog.next;

# not exists
delete from t0 where c0=200;
# not exists
delete from t0 where c0=201;

delete from t0;
ob1.oblog.next;

##### 2. 列数：3	分区键：1
create table t1(c0 int, c1 int, c2 int as (c0+c1)) partition by hash(c2);
ob1.oblog.next;
alter table t1 enable row movement;
ob1.oblog.next;

insert into t1(c0, c1) values(1, 2);
ob1.oblog.next;
insert into t1(c0, c1) values(3, 4);
ob1.oblog.next;
insert into t1(c0, c1) values(5, 6);
ob1.oblog.next;

update t1 set c1 = 100 where c1 = 6;
ob1.oblog.next;

delete from t1 where c0 = 3;
ob1.oblog.next;

update t1 set c0 = 1999 where c0 = 1;
ob1.oblog.next;

#### 3. 列数：5		分区键：3
create table t2(c0 int, c1 int, c2 int as(c0+c1), c3 int as(c0*c1)) partition by hash(c2, c3);
ob1.oblog.next;
alter table t2 enable row movement;
ob1.oblog.next;

insert into t2(c0, c1) values(1, 2);
ob1.oblog.next;
insert into t2(c0, c1) values(3, 4);
ob1.oblog.next;

update t2 set c1 = 100 where c0 = 1;
ob1.oblog.next;
update t2 set c1 = 200 where c0 = 3;
ob1.oblog.next;

update t2 set c0 = 99, c1 = 1 where c2 = 101;
ob1.oblog.next;

#### 3. 列数：5		分区键：3
create table t3(c0 int, c1 int, c2 int, c3 int as(c0+c1+c2), c4 int as(c2+c1+c0), c5 int as(c0+c0+c0)) PARTITION BY hash(c5, c3) SUBPARTITION BY RANGE(c4) subpartition template (SUBPARTITION sp0 VALUES less than(100),SUBPARTITION sp1 VALUES less than(5000)) partitions 3;
ob1.oblog.next;
alter table t3 enable row movement;
ob1.oblog.next;

insert into t3(c0,c1,c2) values(1, 2, 3);
ob1.oblog.next;
insert into t3(c0,c1,c2) values(6, 7, 8);
ob1.oblog.next;

update t3 set c2 = 100 where c3 = 6;
ob1.oblog.next;

# not exists
update t3 set c0 = 200 where c4 = 9;

update t3 set c0 = 999, c1 = 111, c2 = 444 where c3 = 21;
ob1.oblog.next;

delete from t3 where c0 = 999;
ob1.oblog.next;

### 4. 增删分区
create table t4(c1 int, c2 int as (c1+c1*3-c1+c1)) partition by range(c2) (partition p0 values less than(10), partition p1 values less than(1000));
ob1.oblog.next;
alter table t4 enable row movement;
ob1.oblog.next;

insert into t4(c1) values(1);
ob1.oblog.next;
insert into t4(c1) values(2);
ob1.oblog.next;

update t4 set c1 = 99 where c1 = 1;
ob1.oblog.next;
update t4 set c1 = 88 where c1 = 2;
ob1.oblog.next;

alter table t4 add partition p2 values less than (10000), partition p3 values less than (maxvalue);
ob1.oblog.next;

insert into t4(c1) values(5000);
ob1.oblog.next;

update t4 set c1 = 20000 where c1 = 99;
ob1.oblog.next;

alter table t4 drop partition p3;
ob1.oblog.next;

##### 创建多列, 带索引的表
create table t5(c1 int, c2 int, c3 int, c4 int as (c2 + c1), c5 int as (c3 + c2 + c1), constraint uk_t5 unique(c1, c2)) partition by hash(c5, c4);
ob1.oblog.next;
create index idx_t5 on t5(c3);
ob1.oblog.next;
alter table t5 enable row movement;
ob1.oblog.next;

insert into t5(c1, c2, c3) values(1, 2, 3);
ob1.oblog.next;
insert into t5(c1, c2, c3) values(11, 12, 13);
ob1.oblog.next;
update t5 set c1=10 where c4 = 3;
ob1.oblog.next;
delete from t5 where c1=10;
ob1.oblog.next;
delete from t5;
ob1.oblog.next;

##### 7.二级分区
create table t7(c1 int, c2 int, c3 int as (c1 - c2), c4 int, c5 int as (c4 - c2)) PARTITION BY hash(c5, c3) SUBPARTITION BY RANGE(c2) subpartition template (SUBPARTITION sp0 VALUES less than(100),SUBPARTITION sp1 VALUES less than(200)) partitions 3;
ob1.oblog.next;
alter table t7 enable row movement;
ob1.oblog.next;

sleep 1;
let $dml_cnt=0;

insert into t7(c1, c2, c4) values(1, 2, 3);
ob1.oblog.next;
inc $dml_cnt;

alter table t7 add c6 as (c1 + c2);
ob1.oblog.next;
# Defining a generated column on generated column(s)' is not supported for generated columns.
--error 600
alter table t7 add c7 as (c2 + c3);

#### 8.二级分区
create table t8(c1 int, c2 int, c3 int as (c2 - c1), c4 int default 1, c5 int default 1) PARTITION BY hash(c1, c2) SUBPARTITION BY RANGE(c3) subpartition template (SUBPARTITION sp0 VALUES less than(100),SUBPARTITION sp1 VALUES less than(2000)) partitions 5;
ob1.oblog.next;
alter table t8 enable row movement;
ob1.oblog.next;

insert into t8(c1, c2) values(1, 2);
ob1.oblog.next;
insert into t8(c1, c2) values(9, 10);
ob1.oblog.next;

select * from t8;
update t8 set c1 = 999;
ob1.oblog.next;

select * from t8;
update t8 set c1 = 123, c2 = 234 where c4 = 1;
ob1.oblog.next;

delete from t8 where c1 = 123;
ob1.oblog.next;

# stop liboblog
ob1.oblog.stop;

# 清理数据
--disable_warnings
drop user oblog_db cascade;
