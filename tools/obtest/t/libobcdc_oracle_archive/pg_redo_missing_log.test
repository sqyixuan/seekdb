##########################
#owner :  qianxi
#owner group: liboblog
#description:
# 测试点：
# pg redo missing log
#
#

##########################

ob1=OBI(cluster=1,init_unit_cpu=2);
ob1.force_stop;
ob1.clean_backup_dest;
ob1.reboot;

source include/liboblog/create_oracle_tenant.inc;
source include/liboblog/enable_oracle_archive.inc;

# 启动oblog
#ob1.oblog.gen_conf tb_white_list=oracle.*.* log_level=DEBUG test_mode_force_fetch_archive=1 skip_ob_version_compat_check=1;
ob1.oblog.gen_conf tb_white_list=oracle.*.* test_mode_on=1 test_mode_ignore_redo_count=1 test_mode_force_fetch_archive=1 skip_ob_version_compat_check=1;
ob1.oblog.restart;

alter session set current_schema = oblog_db;
sleep 1;

create tablegroup tg1 binding true;
ob1.oblog.next;
create table t1 (c1 int primary key ,c2 int) tablegroup = tg1;
ob1.oblog.next;
insert into t1 values(1, 2);
ob1.oblog.next;

begin;
insert into t1 values(2, 2);
insert into t1 values(33, 33);
insert into t1 values(444, 444);
commit;
ob1.oblog.next;

begin;
insert into t1 values(5, 5);
commit;

begin;
update t1 set c1=50 where c1=5;
insert into t1 values(6, 6);
commit;

ob1.oblog.next;
ob1.oblog.next;

drop user oblog_db cascade;
ob1.oblog.next;

# stop liboblog
ob1.oblog.stop;
