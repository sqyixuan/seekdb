#################  4. range-hash   ##################################
#create table t_range_hash1 (c1 int, c2 int, c3 int, primary key (c1, c2)) partition by range(c1)
#subpartition by hash(c2)
#(
#  partition p0 values less than (100)
#  (
#    subpartition p0_h1,
#    subpartition p0_h2,
#    subpartition p0_h3
#  ),
#  partition p1 values less than (200)(
#    subpartition p1_h1,
#    subpartition p1_h2,
#    subpartition p1_h3
#  ),
#  partition p2 values less than (300)
#  (
#    subpartition p2_h1,
#    subpartition p2_h2
#  )
#);

create table t_range_hash1 (c1 int, c2 int, c3 int, primary key (c1, c2)) partition by range(c1) subpartition by hash(c2)(partition p0 values less than (100)(subpartition p0_h1,subpartition p0_h2,subpartition p0_h3),partition p1 values less than (200)(subpartition p1_h1,subpartition p1_h2,subpartition p1_h3), partition p2 values less than (300)(subpartition p2_h1,subpartition p2_h2));
ob1.oblog.next;
alter table t_range_hash1 add partition p4 values less than (500) (subpartition p4_h1,subpartition p4_h2,subpartition p4_h3);
ob1.oblog.next;
alter table t_range_hash1 drop partition p0;
ob1.oblog.next;

# 覆盖所有分区的数据
