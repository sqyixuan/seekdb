create table t_list_hash1 (c1 int, c2 int, c3 int, primary key (c1, c2)) partition by list (c1) subpartition by hash(c2) (partition p0 values (1,2,3,4,5)(subpartition p0_h1,subpartition p0_h2),partition p1 values (6,7,8,9,10)(subpartition p1_h1,subpartition p1_h2));
