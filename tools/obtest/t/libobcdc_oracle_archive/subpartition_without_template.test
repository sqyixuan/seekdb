# create table t_range_list1 (c1 int, c2 int, c3 int, primary key (c1, c2)) partition by range (c1)
# subpartition by list(c2)
# (
#   partition p0 values less than (100)
#   (
#     subpartition p0_l1 values (1,2,3,4,5),
#     subpartition p0_l2 values (6,7,8,9,10)
#   ),
#   partition p1 values less than (200)
#   (
#     subpartition p1_l1 values (1,2,3,4,5),
#     subpartition p1_l2 values (6,7,8,9,10)
#     )
# );

create table t_range_list1 (c1 int, c2 int, c3 int, primary key (c1, c2)) partition by range (c1) subpartition by list(c2) (partition p0 values less than (100) (subpartition p0_l1 values (1,2,3,4,5),subpartition p0_l2 values (6,7,8,9,10)),partition p1 values less than (200)(subpartition p1_l1 values (1,2,3,4,5),subpartition p1_l2 values (6,7,8,9,10)));
ob1.oblog.next;
alter table t_range_list1 add partition p2 values less than (300) (subpartition p2_l1 values (1,2,3,4,5), subpartition p2_l2 values (6,7,8,9,10));
ob1.oblog.next;
alter table t_range_list1 drop subpartition P2_L2;
ob1.oblog.next;
alter table t_range_list1 modify partition P2 add subpartition P2_L3 values (11,12,13,14);
ob1.oblog.next;
