create table t_list_range1 (c1 int, c2 int, c3 int, primary key (c1, c2)) partition by list (c1) subpartition by range(c2) (partition p0 values (1,2,3,4,5)(subpartition p0_r1 values less than (100),subpartition p0_r2 values less than (200)),partition p1 values (6,7,8,9,10)(subpartition p1_r1 values less than (100),subpartition p1_r2 values less than (200)));
ob1.oblog.next;
# 添加一级分区，效果在后面验证
alter table t_list_range1 add partition p4 values (21,22,23,24,25) (subpartition p4_r1 values less than (100),subpartition p4_r2 values less than (200),subpartition p4_r3 values less than (300));
ob1.oblog.next;
