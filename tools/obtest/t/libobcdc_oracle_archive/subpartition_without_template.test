####################################################################
#################  9. list-list   ##################################
#create table t_list_list1 (c1 int, c2 int, c3 int, primary key (c1, c2)) partition by list (c1)
#subpartition by list(c2)
#(
#  partition p0 values (1,2,3,4,5)
#  (
#    subpartition p0_l1 values (1,2,3,4,5),
#    subpartition p0_l2 values (6,7,8,9,10),
#    subpartition p0_l3 values (11,12,13,14,15)
#  ),
#  partition p1 values (6,7,8,9,10)
#  (
#    subpartition p1_l1 values (1,2,3,4,5),
#    subpartition p1_l2 values (6,7,8,9,10),
#    subpartition p1_l3 values (11,12,13,14,15)
#  ),
#  partition p2 values (11,12,13,14,15)
#  (
#    subpartition p2_l1 values (1,2,3,4,5),
#    subpartition p2_l2 values (6,7,8,9,10),
#    subpartition p2_l3 values (11,12,13,14,15)
#  )
#);
create table t_list_list1 (c1 int, c2 int, c3 int, primary key (c1, c2)) partition by list (c1) subpartition by list(c2) (partition p0 values (1,2,3,4,5)(subpartition p0_l1 values (1,2,3,4,5),subpartition p0_l2 values (6,7,8,9,10),subpartition p0_l3 values (11,12,13,14,15)),partition p1 values (6,7,8,9,10)(subpartition p1_l1 values (1,2,3,4,5),subpartition p1_l2 values (6,7,8,9,10),subpartition p1_l3 values (11,12,13,14,15)),partition p2 values (11,12,13,14,15)(subpartition p2_l1 values (1,2,3,4,5),subpartition p2_l2 values (6,7,8,9,10),subpartition p2_l3 values (11,12,13,14,15)));
ob1.oblog.next;

connection conn_sys;
let $table_id = query_get_value(select table_id from __all_virtual_table where table_name = 't_list_list1' and tenant_id=$tenant_id and database_id=$database_id, table_id, 1);
# echo $table_id;

# drop subpartition 删除一个分区
# 物理分区id的生成规则：(((uint64_t)part_idx << OB_PART_ID_SHIFT) | sub_part_idx) | OB_TWOPART_BEGIN_MASK
# OB_TWOPART_BEGIN_MASK：1152921504875282432 为 (((uint64_t)0x1) << 28 |((uint64_t) 0x1 << 60))
let $partition_id = query_get_value(select part_id << 32 | sub_part_id | 1152921504875282432 as partition_id from (select part_id, sub_part_id from __all_virtual_sub_part where table_id = $table_id and sub_part_name = 'p2_l1'), partition_id, 1);
connection conn_oracle_obtest;
alter table t_list_list1 drop subpartition p2_l1;
ob1.oblog.next;

# add subpartition
alter table t_list_list1 modify partition p1 add subpartition p1_l4 values (16,17,18,19,20);
ob1.oblog.next;
insert into t_list_list1 values (6, 16, 6);
ob1.oblog.next;

# 连续在不同一级分区增删二级分区
alter table t_list_list1 modify partition p0 add subpartition p0_l4 values (16,17,18,19,20);
alter table t_list_list1 modify partition p2 add subpartition p2_l4 values (16,17,18,19,20);
ob1.oblog.next;
ob1.oblog.next;
insert into t_list_list1 values (1, 17, 1);
ob1.oblog.next;
insert into t_list_list1 values (11, 20, 11);
ob1.oblog.next;

connection conn_sys;
let $partition_id_1 = query_get_value(select part_id << 32 | sub_part_id | 1152921504875282432 as partition_id from (select part_id, sub_part_id from __all_virtual_sub_part where table_id = $table_id and sub_part_name = 'p0_l4'), partition_id, 1);
let $partition_id_2 = query_get_value(select part_id << 32 | sub_part_id | 1152921504875282432 as partition_id from (select part_id, sub_part_id from __all_virtual_sub_part where table_id = $table_id and sub_part_name = 'p2_l4'), partition_id, 1);
connection conn_oracle_obtest;
alter table t_list_list1 drop subpartition p0_l4;
alter table t_list_list1 drop subpartition p2_l4;
ob1.oblog.next;
ob1.oblog.next;
alter table t_list_list1 modify partition p0 add subpartition p0_l4 values (16,17,18,19,20);
ob1.oblog.next;
insert into t_list_list1 values (1, 17, 1);
ob1.oblog.next;

alter table t_list_list1 add partition p4 values (21,22,23,24,25) (subpartition p4_l1 values (1,2,3,4,5),subpartition p4_l2 values (6,7,8,9,10),subpartition p4_l3 values (11,12,13,14,15));
ob1.oblog.next;

# drop subpartition 删除多个分区
connection conn_sys;
let $partition_id_3 = query_get_value(select part_id << 32 | sub_part_id | 1152921504875282432 as partition_id from (select part_id, sub_part_id from __all_virtual_sub_part where table_id = $table_id and sub_part_name = 'p0_l1'), partition_id, 1);
let $partition_id_4 = query_get_value(select part_id << 32 | sub_part_id | 1152921504875282432 as partition_id from (select part_id, sub_part_id from __all_virtual_sub_part where table_id = $table_id and sub_part_name = 'p0_l2'), partition_id, 1);
let $partition_id_5 = query_get_value(select part_id << 32 | sub_part_id | 1152921504875282432 as partition_id from (select part_id, sub_part_id from __all_virtual_sub_part where table_id = $table_id and sub_part_name = 'p0_l3'), partition_id, 1);
let $partition_id_6 = query_get_value(select part_id << 32 | sub_part_id | 1152921504875282432 as partition_id from (select part_id, sub_part_id from __all_virtual_sub_part where table_id = $table_id and sub_part_name = 'p0_l4'), partition_id, 1);
connection conn_oracle_obtest;
alter table t_list_list1 drop subpartition p0_l1, p0_l2;
ob1.oblog.next;

#echo $partition_id_3;
#echo $partition_id_4;


alter table t_list_list1 drop partition p0;
ob1.oblog.next;

