##########################
#owner :  bohou.ws
#owner group: liboblog
#description:
# 测试点：
# 测试liboblog对非模版化二级分区动态增删的支持
#

##########################

ob1=OBI(cluster=1,init_unit_cpu=2);
ob1.force_stop;
ob1.clean_backup_dest;
ob1.reboot;

source include/liboblog/create_oracle_tenant.inc;
source include/liboblog/enable_oracle_archive.inc;

# 启动oblog
ob1.oblog.gen_conf tb_white_list=oracle.*.* log_level=DEBUG test_mode_force_fetch_archive=1 skip_ob_version_compat_check=1;
ob1.oblog.restart;

connection conn_sys;
let $tenant_id = query_get_value(select tenant_id from __all_tenant where tenant_name = 'oracle', tenant_id, 1);
let $database_id = query_get_value(select database_id from __all_virtual_database where database_name = 'oblog_db' and tenant_id = $tenant_id, database_id, 1);
# echo $tenant_id;
# echo $database_id;
connection conn_oracle_obtest;

####################################################################
#################  1. hash-hash   ##################################

# 一二级均为hash，不支持动态增删

#create table t_hash_hash1 (c1 int, c2 int, c3 int, primary key (c1, c2)) partition by hash(c1)
#subpartition by hash(c2)
#(
#  partition p0
#  (
#    subpartition p0_1,
#    subpartition p0_2,
#    subpartition p0_3
#  ),
#  partition p1
#  (
#    subpartition p1_1,
#    subpartition p1_2,
#    subpartition p1_3
#  ),
#  partition p2
#  (
#    subpartition p2_1,
#    subpartition p2_2
#  )
#);

create table t_hash_hash1 (c1 int, c2 int, c3 int, primary key (c1, c2)) partition by hash(c1) subpartition by hash(c2) (partition p0 (subpartition p0_1, subpartition p0_2, subpartition p0_3), partition p1 (subpartition p1_1, subpartition p1_2, subpartition p1_3), partition p2 (subpartition p2_1, subpartition p2_2));
ob1.oblog.next;
let $idx=0;
while ($idx < 3)
{
  eval insert into t_hash_hash1 values ($idx, $idx, $idx);
  ob1.oblog.next;
  eval insert into t_hash_hash1 values ($idx, $idx+1, $idx);
  ob1.oblog.next;
  eval insert into t_hash_hash1 values ($idx, $idx+2, $idx);
  ob1.oblog.next;
  inc $idx;
}

####################################################################
#################  2. hash-range   ##################################
#create table t_hash_range1 (c1 int, c2 int, c3 int, primary key (c1, c2)) partition by hash(c1)
#subpartition by range(c2)
#(
#  partition p0
#  (
#    subpartition p0_r1 values less than (100),
#    subpartition p0_r2 values less than (200),
#    subpartition p0_r3 values less than (300)
#  ),
#  partition p1
#  (
#    subpartition p1_r1 values less than (100),
#    subpartition p1_r2 values less than (200),
#    subpartition p1_r3 values less than (300)
#  ),
#  partition p2
#  (
#    subpartition p2_r1 values less than (100),
#    subpartition p2_r2 values less than (200),
#    subpartition p2_r3 values less than (300)
#  )
#);

create table t_hash_range1 (c1 int, c2 int, c3 int, primary key (c1, c2)) partition by hash(c1) subpartition by range(c2)(partition p0(subpartition p0_r1 values less than (100),subpartition p0_r2 values less than (200),subpartition p0_r3 values less than (300)),partition p1(subpartition p1_r1 values less than (100),subpartition p1_r2 values less than (200),subpartition p1_r3 values less than (300)),partition p2(subpartition p2_r1 values less than (100),subpartition p2_r2 values less than (200),subpartition p2_r3 values less than (300)));
ob1.oblog.next;

alter table t_hash_range1 drop subpartition p2_r1;
ob1.oblog.next;

# add subpartition
alter table t_hash_range1 modify partition p1 add subpartition p1_r4 values less than (400);
ob1.oblog.next;
insert into t_hash_range1 values (0, 399, 0);
ob1.oblog.next;

# 连续在不同一级分区增删二级分区
alter table t_hash_range1 modify partition p0 add subpartition p0_r4 values less than (500);
alter table t_hash_range1 modify partition p2 add subpartition p2_r4 values less than (600);
ob1.oblog.next;
ob1.oblog.next;
insert into t_hash_range1 values (2, 499, 1);
ob1.oblog.next;
insert into t_hash_range1 values (3, 599, 2);
ob1.oblog.next;

alter table t_hash_range1 drop subpartition p0_r4;
alter table t_hash_range1 drop subpartition p2_r4;
ob1.oblog.next;
ob1.oblog.next;

# 构造覆盖所有分区的事务
insert into t_hash_range1 values (1, 99, 1);
ob1.oblog.next;
insert into t_hash_range1 values (1, 199, 1);
ob1.oblog.next;
insert into t_hash_range1 values (1, 299, 1);
ob1.oblog.next;
insert into t_hash_range1 values (2, 199, 2);
ob1.oblog.next;
insert into t_hash_range1 values (2, 99, 2);
ob1.oblog.next;
insert into t_hash_range1 values (2, 299, 2);
ob1.oblog.next;
insert into t_hash_range1 values (3, 99, 3);
ob1.oblog.next;
insert into t_hash_range1 values (3, 199, 3);
ob1.oblog.next;
insert into t_hash_range1 values (3, 299, 3);
ob1.oblog.next;

# drop subpartition 删除多个分区
alter table t_hash_range1 drop subpartition p0_r1, p0_r2;
ob1.oblog.next;

####################################################################
#################  3. hash-list   ##################################
#create table t_hash_list1 (c1 int, c2 int, c3 int, primary key (c1, c2)) partition by hash(c1)
#subpartition by list (c2)
#(
#  partition p0
#  (
#    subpartition p0_l0 values (1,2,3,4,5),
#    subpartition p0_l1 values (6,7,8,9,10)
#  ),
#  partition p1
#  (
#    subpartition p1_l0 values (1,2,3,4,5),
#    subpartition p1_l1 values (6,7,8,9,10)
#  )
#);

create table t_hash_list1 (c1 int, c2 int, c3 int, primary key (c1, c2)) partition by hash(c1) subpartition by list (c2) (partition p0 (subpartition p0_l0 values (1,2,3,4,5),subpartition p0_l1 values (6,7,8,9,10)), partition p1 (subpartition p1_l0 values (1,2,3,4,5),subpartition p1_l1 values (6,7,8,9,10)));
ob1.oblog.next;
alter table t_hash_list1 modify partition p1 add subpartition p1_l4 values (11,12,13,14,15);
ob1.oblog.next;
insert into t_hash_list1 values (1, 11, 2);
ob1.oblog.next;
alter table t_hash_list1 drop subpartition p1_l1;
ob1.oblog.next;


# 覆盖所有分区的数据
insert into t_hash_list1 values (2, 1, 1);
ob1.oblog.next;
insert into t_hash_list1 values (2, 6, 3);
ob1.oblog.next;
insert into t_hash_list1 values (3, 2, 2);
ob1.oblog.next;

