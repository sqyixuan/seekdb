ob1.oblog.next;
insert into t_range_hash1 values (270, 2, 1);
ob1.oblog.next;
insert into t_range_hash1 values (360, 1, 1);
ob1.oblog.next;
insert into t_range_hash1 values (490, 2, 1);
ob1.oblog.next;

