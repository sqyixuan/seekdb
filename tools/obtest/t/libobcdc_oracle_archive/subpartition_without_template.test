create table t_range_range1 (c1 int, c2 int, c3 int, primary key (c1, c2)) partition by range(c1) subpartition by range (c2) (partition p0 values less than (100)(subpartition p0_r1 values less than (100),subpartition p0_r2 values less than (200)),partition p1 values less than (200) (subpartition p1_r1 values less than (100),subpartition p1_r2 values less than (200)));
