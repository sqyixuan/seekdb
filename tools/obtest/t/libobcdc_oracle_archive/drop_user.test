##########################
#owner :  qianxi
#owner group: liboblog
#description:
# 测试点：
#   1. blob
#   2. pg
#   3. 全局索引
#

##########################

ob1=OBI(cluster=1,init_unit_cpu=2);
ob1.force_stop;
ob1.clean_backup_dest;
ob1.reboot;

source include/liboblog/create_oracle_tenant.inc;
source include/liboblog/enable_oracle_archive.inc;

# 启动oblog
ob1.oblog.gen_conf tb_white_list=oracle.*.* log_level=DEBUG test_mode_force_fetch_archive=1 skip_ob_version_compat_check=1;
ob1.oblog.restart;

# t1
create table t1 (nr number, a clob, b blob);
ob1.oblog.next;

insert into t1 values (1, 'ad', '6164');
select * from t1 where nr=1;
ob1.oblog.next;

# t2
create table t2 (nr number, a clob, b blob);
ob1.oblog.next;

# t3
create table t3 (nr number, a clob, b blob);
ob1.oblog.next;


# 创建pg
create tablegroup tg1 binding true;
ob1.oblog.next;
create table ta1 (c1 int primary key ,c2 int) tablegroup = tg1;
ob1.oblog.next;
insert into ta1 values(1, 2);
ob1.oblog.next;
create table ta2 (c1 int primary key ,c2 int) tablegroup = tg1;
ob1.oblog.next;
insert into ta2 values(12, 22);
ob1.oblog.next;


# 全局索引
create table ta3  (c1 int, c2 int, c3 int, c4 int, primary key (c1));
ob1.oblog.next;

create index g_index_3 on ta3(c2, c3, c4) global partition by hash(c2) partitions 4;
ob1.oblog.next;

insert into ta3 values (1,2,3,4);
ob1.oblog.next;

drop user oblog_db cascade;
ob1.oblog.next;

# stop liboblog
ob1.oblog.stop;

ob1.oblog.check_log "[STAT] [DDL_PROCESSOR] [DDL] [HANDLE_STMT] TENANT_ID=1006 OP_TYPE=OB_DDL_DROP_TABLE";
ob1.oblog.check_log "[STAT] [DDL] [PARSE] OP_TYPE=OB_DDL_DEL_DATABASE";
