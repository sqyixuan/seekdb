##########################
#owner :  qianxi
#owner group: liboblog
#description:
# 测试点：
# pg内table过滤
# 1. 创建PG, 包含多张表，测试过滤单/多张表
# 2. 创建table, 包含普通索引，唯一索引，测试过滤普通索引，保留唯一索引
#

##########################

ob1=OBI(cluster=1,init_unit_cpu=2);
ob1.force_stop;
ob1.clean_backup_dest;
ob1.reboot;

source include/liboblog/create_oracle_tenant.inc;
source include/liboblog/enable_oracle_archive.inc;

# 启动oblog
ob1.oblog.gen_conf tb_white_list=oracle.*.* sort_trans_participants=1 test_mode_force_fetch_archive=1 skip_ob_version_compat_check=1;
ob1.oblog.restart;

# sys-mysql租户获取当前时间
ob_connect(conn_sys, ob1.z1.obs0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);
let $start_tstamp = query_get_value(select round(time_to_usec(now()) / 1000000) as now, now, 1);
ob_connect(conn_oracle_obtest,ob1.z1.obs0,OBTEST@oracle,obtest,obtest,,USE_OB_CONNECTOR);

alter session set current_schema = oblog_db;
sleep 1;

source include/liboblog/global_index/oracle_global_index_create_table.inc;
set @@recyclebin = off;

# 预期结果为21
ob1.oblog.stat_check_log_cnt "[SERVED_TABLE_ID_CACHE] [ADD]";

################################ 2. 删除
################################ (1) 删除主表，索引
# Note: oracle 语法 drop index index_name
#       mysql  语法 drop index index_name on table_name
# 删除全局普通索引
drop index g_normal_key_t3;
ob1.oblog.next;
drop index g_normal_key_t4;
ob1.oblog.next;
drop index g_normal_key_t5;
ob1.oblog.next;
drop index g_normal_key_t6;
ob1.oblog.next;

# 删除全局唯一索引
drop index g_unique_gkey_t7;
ob1.oblog.next;
drop index g_unique_gkey_t8;
ob1.oblog.next;
drop index g_unique_gkey_t9;
ob1.oblog.next;
drop index g_unique_gkey_t10;
ob1.oblog.next;

# 预期结果为4
ob1.oblog.stat_check_log_cnt "[SERVED_TABLE_ID_CACHE] [REMOVE]";

# 删除主表
drop table t11;
ob1.oblog.next;

# 预期结果为8 drop table t11会删除主表、删除全局索引、删除2个唯一索引
ob1.oblog.stat_check_log_cnt "[SERVED_TABLE_ID_CACHE] [REMOVE]";

drop user oblog_db cascade;
ob1.oblog.next;

# 预期结果为21
ob1.oblog.stat_check_log_cnt "[SERVED_TABLE_ID_CACHE] [REMOVE]";

# stop liboblog
ob1.oblog.stop;
