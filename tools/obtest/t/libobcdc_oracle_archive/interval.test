##########################
#owner :  jim.wjh
#owner group: liboblog
#description:
# 测试点：
#
##########################

ob1=OBI(cluster=1,init_unit_cpu=2);
ob1.force_stop;
ob1.clean_backup_dest;
ob1.reboot;

# 创建oracle租户，并切换到oracle租户
source include/liboblog/create_oracle_tenant.inc;
source include/liboblog/enable_oracle_archive.inc;

# 启动oblog
ob1.oblog.gen_conf tb_white_list=oracle.*.* log_level=DEBUG test_mode_force_fetch_archive=1 skip_ob_version_compat_check=1;
ob1.oblog.restart;

# 创建user

# alter session不会生成redo日志，不需要执行liboblog输出数据
alter session set current_schema = oblog_db;
sleep 1;

# 创建t1
create table t1(p1 number primary key, c1 interval year to month, c2 interval year(9) to month, c3 interval year(0) to month);
# 输出DDL
ob1.oblog.next;

# 执行INSERT语句，AC=1的事务
insert into t1 values (1, '99-11', '999999999-11', '0-0');
# 输出INSERT语句事务
ob1.oblog.next;

# 执行UPDATE语句，AC=1的事务
update t1 set c2 = '-999999999-11' where p1 = 1;
# 输出UPDATE语句事务
ob1.oblog.next;

# 删除表
drop table t1;
# 输出DDL
ob1.oblog.next;

# 创建t1
create table t1(p1 number primary key, c1 interval day to second, c2 interval day(9) to second, c3 interval day(0) to second);
# 输出DDL
ob1.oblog.next;

# 执行INSERT语句，AC=1的事务
insert into t1 values (1, '12 23:58:59.123456', '-123456789 00:00:00', '0 00:00:00.0');
# 输出INSERT语句事务
ob1.oblog.next;

# 执行UPDATE语句，AC=1的事务
update t1 set c2 = '56789 1:1:1';
# 输出UPDATE语句事务
ob1.oblog.next;

# 删除表
drop table t1;
# 输出DDL
ob1.oblog.next;

# 删除user
drop user oblog_db cascade;
# 输出DDL
ob1.oblog.next;

# stop liboblog
ob1.oblog.stop;
