ob1=OBI(cluster=1, proxy_num=0, init_unit_cpu=2);

--echo ===============================================================
--echo ====================     bootstrap   ==========================
--echo ===============================================================
--echo test case for bootstrap begin
ob1.reboot;
sleep 3;
let $sys_tenant_id = 1;
ob1.mysql alter system set enable_rebalance='false';
ob1.mysql alter system set syslog_io_bandwidth_limit = '4G';
ob_connect(conn_sys, ob1.z1.obs0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);
--echo test case for bootstrap finish

--echo ===============================================================
--echo ==================     create tenant   ========================
--echo ===============================================================
# 注意: 创建初始mysql租户'F@z1, F@z3'
--echo test case for create tenant begin
set @@session.ob_query_timeout = 1000000000;
#mysql tenant
eval CREATE RESOURCE UNIT unit_1 MAX_CPU 2, MEMORY_SIZE='8G';
eval CREATE RESOURCE POOL pool_1 UNIT = 'unit_1', UNIT_NUM = 1;
eval CREATE TENANT mysql RESOURCE_POOL_LIST = ('pool_1'), primary_zone='z1' set ob_tcp_invited_nodes='%';
source include/check_schema_sync.inc;
connection conn_sys;
let $mysql_tenant_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name = 'mysql', tenant_id, 1);


--echo ===============================================================
--echo ============             execute ddl            ===============
--echo ===============================================================
--echo test case for create index begin
ob1.mysql alter system set_tp tp_no = 801, error_code = 3, frequency = 1;
create table t1(c1 int, c2 int, c3 int, c4 varchar(400), c5 varchar(400), primary key(c1,c2));
create sequence s1 cache 1000000 noorder;
insert into t1 select s1.nextval, s1.nextval, s1.nextval, randstr(250, random()), randstr(250, random()) from table (generator(5000));
alter system minor freeze;
alter table t1 modify column c1 bigint, modify column  c2 bigint, modify column  c3 bigint;
insert into t1 select s1.nextval, s1.nextval, s1.nextval, randstr(400, random()), randstr(250, random()) from table (generator(4000));
alter system minor freeze;
sleep 10;

select count(*) from __all_virtual_table_mgr where tablet_id in (select tablet_id from __all_virtual_tablet_to_table_history where table_id in (select table_id from __all_virtual_table where table_name like 't1')) and table_type < 4; 




--echo ===============================================================
--echo ===================         clear      ========================
--echo ===============================================================
