##############################
#owner: lihongqin.lhq
#owner group: qa
#description: 在默认值为表达式的ddl操作场景中，报错tenant allocator not exist。
###############################


--echo ===============================================================
--echo ====================     bootstrap   ==========================
--echo ===============================================================
--echo test case for bootstrap begin
ob1=OBI(cluster=1:1,init_unit_cpu=8,proxy_num=0);
ob1.reboot;
let $proxy_ip = deploy_get_value(ob1.z1.obs0.ip);
let $proxy_port = deploy_get_value(ob1.z1.obs0.mysql_port);
let $proxy_ip2 = deploy_get_value(ob1.z2.obs0.ip);
let $proxy_port2 = deploy_get_value(ob1.z2.obs0.mysql_port);

connect(sys_conn, $proxy_ip, root@sys,,oceanbase, $proxy_port);
connection sys_conn;

#设置sys租户的主为z1
alter tenant sys set primary_zone='z1';

#当需要建立的资源存在的时候删除掉
--disable_warnings
eval drop tenant if exists sy_tenant force;
eval DROP RESOURCE POOL IF EXISTS sy_pool;
eval DROP RESOURCE UNIT IF EXISTS sy_unit;
sleep 2;
--echo test case for bootstrap finish


--echo ===============================================================
--echo ==================     create tenant   ========================
--echo ===============================================================
#创建租户sy_tenant在z2
--echo test case for create tenant begin
--enable_warnings
eval create resource unit if not exists sy_unit max_cpu 1, memory_size '1G' , LOG_DISK_SIZE  2147483648, MAX_IOPS  10000, MIN_IOPS  10000, IOPS_WEIGHT 1;
eval create resource pool if not exists sy_pool unit = 'sy_unit', unit_num = 1, ZONE_LIST=('z2');
eval create tenant if not exists sy_tenant resource_pool_list('sy_pool') set ob_tcp_invited_nodes='%', ob_compatibility_mode='oracle';
sleep 5;

#设置oracle租户的主为z2
alter tenant sy_tenant set primary_zone = 'z2';
sleep 3;
--echo test case for create tenant finish

ob_connect(tenent_conn, ob1.z2.obs0, SYS@sy_tenant, ,SYS, , USE_OB_CONNECTOR);

sleep 2;

--echo ================================================================================================================================================
--echo ===============     Error occurs when rs is not on the machine where the ordinary tenant unit is located in previous versions===================
--echo ================================================================================================================================================
--echo test case begin
connection tenent_conn;

ALTER SYSTEM SET NLS_DATE_FORMAT='YYYY-MM-DD HH24:MI:SS';
ALTER SYSTEM SET NLS_TIMESTAMP_FORMAT='YYYY-MM-DD HH24:MI:SS.FF';
ALTER SYSTEM SET NLS_TIMESTAMP_TZ_FORMAT='YYYY-MM-DD HH24:MI:SS.FF TZR TZD';

--error 0, 942
drop table test CASCADE CONSTRAINTS purge;
create table test(c1 int primary key, c2 int, c3 int, c4 varchar(50), c5 float);

alter TABLE test modify c4 varchar(40 char) default to_char(Date '2012-12-02', 'yyyy-mm-dd');

alter table test add c6 varchar(40 byte) default to_char(Timestamp '2012-12-02 12:01:02.1234', 'hh:mi:dd');

alter TABLE test add c7 varchar(40 char) default to_char(sysdate + interval '1' day, 'yyyy');

alter table test add c8 varchar(40 byte) default to_char(sysdate + interval '1' day, 'yyyy');

alter table test add c9 varchar(40 byte) default to_char(Timestamp '2012-12-02 12:01:02.1234', 'hh:mi:dd');

alter table test add (c10 varchar(12) default to_char(Systimestamp,'YYYYMMDD'));

alter table test modify c9  default to_char(Systimestamp,'YYYYMMDD');

alter table test add c11 char(40 byte) default to_char(sysdate + interval '1' day, 'yyyy');

--echo test case finish

--echo ===============================================================================================================================
--echo ===============     When rs is on the machine where the ordinary tenant unit is located, it runs normally    ===================
--echo ===============================================================================================================================
--echo test case begin
connection sys_conn;
#设置sys租户的主为z2
alter tenant sys set primary_zone='z2';
sleep 10;

connection tenent_conn;
--error 0, 942
drop table test CASCADE CONSTRAINTS purge;
create table test(c1 int primary key, c2 int, c3 int, c4 varchar(50), c5 float);

alter TABLE test modify c4 varchar(40 char) default to_char(Date '2012-12-02', 'yyyy-mm-dd');

alter table test add c6 varchar(40 byte) default to_char(Timestamp '2012-12-02 12:01:02.1234', 'hh:mi:dd');

alter TABLE test add c7 varchar(40 char) default to_char(sysdate + interval '1' day, 'yyyy');

alter table test add c8 varchar(40 byte) default to_char(sysdate + interval '1' day, 'yyyy');

alter table test add c9 varchar(40 byte) default to_char(Timestamp '2012-12-02 12:01:02.1234', 'hh:mi:dd');

alter table test add (c10 varchar(12) default to_char(Systimestamp,'YYYYMMDD'));

alter table test modify c9  default to_char(Systimestamp,'YYYYMMDD');

alter table test add c11 char(40 byte) default to_char(sysdate + interval '1' day, 'yyyy');
