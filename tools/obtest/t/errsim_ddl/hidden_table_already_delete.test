# owner: youchuan.yc
# owner group: storage
# description: test building fts index retry at executor in ss mode

ob1=OBI(cluster=1:1,proxy_num=0,init_unit_cpu=2);
ob1.reboot;

ob1.mysql alter system set merger_check_interval='10s';
ob1.mysql alter system set enable_rebalance = 'false';
ob1.mysql alter system set resource_hard_limit=500;
ob1.mysql alter system set debug_sync_timeout = '100000s';
let $ip0 = deploy_get_value(ob1.z1.obs0.ip);
let $mysql_port0 = deploy_get_value(ob1.z1.obs0.mysql_port);

connect (conn_sys, $ip0, root@sys, , oceanbase, $mysql_port0);
connection conn_sys
alter system set _enable_add_fulltext_index_to_existing_table = true;

connect(conn_obtest1,$ip0,root@obtest,,test,$mysql_port0);

#test alter table path for building fts index
connection conn_obtest1;
create table t1(c1 int, c2 varchar(255), c3 varchar(255));
create index idx0 on t1(c2);
create fulltext index idx1 on t1(c3);
insert into t1 values (0, "oceanbase", "oceanbase");
insert into t1 values (1, "oceanbase", "oceanbase");
insert into t1 values (2, "oceanbase", "oceanbase");

connection conn_sys;
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'BUILD_FTS_INDEX_PREPARE_STATUS wait_for continue_signal_fts_afterward execute 10000';

connection conn_obtest1;
ob1.z1.obs0.mysql alter system set_tp tp_no = 545, error_code = 4184, frequency = 1;

send alter table t1 add primary key (c1);
sleep 8;

connection conn_sys;
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'now broadcast continue_signal_fts_afterward';

connection conn_obtest1;
--error 4184
reap;

connection conn_sys;
sleep 8;
select * from __all_virtual_ddl_task_status;