# owner: youchuan.yc
# owner group: storage
# description: test building fts index retry at executor in ss mode

ob1=OBI(cluster=1:1,proxy_num=0,init_unit_cpu=2);
ob1.reboot;

ob1.mysql alter system set merger_check_interval='10s';
ob1.mysql alter system set enable_rebalance = 'false';
ob1.mysql alter system set resource_hard_limit=500;
ob1.mysql alter system set debug_sync_timeout = '100000s';
let $ip0 = deploy_get_value(ob1.z1.obs0.ip);
let $mysql_port0 = deploy_get_value(ob1.z1.obs0.mysql_port);

connect (conn_sys, $ip0, root@sys, , oceanbase, $mysql_port0);
connection conn_sys
alter system set _enable_add_fulltext_index_to_existing_table = true;

connect(conn_obtest1,$ip0,root@obtest,,test,$mysql_port0);

#test alter table path for building fts index
connection conn_obtest1;
create table t1(c1 int primary key, c2 varchar(255), c3 varchar(255));
insert into t1 values (0, "oceanbase", "oceanbase");
insert into t1 values (1, "oceanbase", "oceanbase");
insert into t1 values (2, "oceanbase", "oceanbase");

ob1.z1.obs0.mysql alter system set_tp tp_no = 545, error_code = 6231, frequency = 1;
sleep 5;

send alter table t1 add fulltext index idx0(c2);
sleep 2;

ob1.z1.obs0.mysql alter system set_tp tp_no = 545, error_code = 0, frequency = 1;
sleep 5;
let $ret_code = deploy_get_value(ob1.select select ret_code from __all_virtual_ddl_error_message where ret_code=-6231 limit 1, ret_code, 1);
echo $ret_code;

sleep 5;
connection conn_obtest1;
reap;

# test create path for building fts index
connection conn_obtest1;
create table t2(c1 int primary key, c2 varchar(255), c3 varchar(255));
insert into t2 values (0, "oceanbase", "oceanbase");
insert into t2 values (1, "oceanbase", "oceanbase");
insert into t2 values (2, "oceanbase", "oceanbase");

ob1.z1.obs0.mysql alter system set_tp tp_no = 545, error_code = 4012, frequency = 1;
sleep 5;

send create fulltext index idx1 on t2(c3);
sleep 2;

ob1.z1.obs0.mysql alter system set_tp tp_no = 545, error_code = 0, frequency = 1;
sleep 5;
let $ret_code = deploy_get_value(ob1.select select ret_code from __all_virtual_ddl_error_message where ret_code=-4012 limit 1, ret_code, 1);
echo $ret_code;

sleep 5;
connection conn_obtest1;
reap;

# test alter table path for building multivalue index
connection conn_obtest1;
create table t3(c1 int primary key, c2 json, c3 json);

ob1.z1.obs0.mysql alter system set_tp tp_no = 545, error_code = 4023, frequency = 1;
sleep 5;

send alter table t3 add index idx0( (CAST(c2->'\$.zipcode' AS UNSIGNED ARRAY)) );
sleep 2;

ob1.z1.obs0.mysql alter system set_tp tp_no = 545, error_code = 0, frequency = 1;
sleep 5;
let $ret_code = deploy_get_value(ob1.select select ret_code from __all_virtual_ddl_error_message where ret_code=-4023 limit 1, ret_code, 1);
echo $ret_code;

sleep 5;
connection conn_obtest1;
reap;

# test create index path for building multivalue index
connection conn_obtest1;
create table t4(c1 int primary key, c2 json, c3 json);

ob1.z1.obs0.mysql alter system set_tp tp_no = 545, error_code = 5627, frequency = 1;
sleep 5;

send create index idx1 on t4( (CAST(c3->'\$.zipcode' AS UNSIGNED ARRAY)) );
sleep 2;

ob1.z1.obs0.mysql alter system set_tp tp_no = 545, error_code = 0, frequency = 1;
sleep 5;
let $ret_code = deploy_get_value(ob1.select select ret_code from __all_virtual_ddl_error_message where ret_code=-5627 limit 1, ret_code, 1);
echo $ret_code;

sleep 5;
connection conn_obtest1;
reap;