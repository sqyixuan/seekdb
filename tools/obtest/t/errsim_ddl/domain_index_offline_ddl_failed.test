# owner: miyuan.ljr
# owner group: shenzhen
# description: test domain index offline ddl failed may be hung.

--disable_query_log
ob1=OBI(cluster=1:1,proxy_num=0,init_unit_cpu=2);
ob1.reboot;
sleep 3;

ob_connect(conn_sys, ob1.z1.obs0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);
connection conn_sys
set @@global.ob_query_timeout = 1000000000;
--enable_query_log

alter system set_tp tp_name = FTS_INDEX_SUBTASK_BUILD_SSTABLE_FAILED, error_code = 4016, frequency = 1;

--disable_query_log
ob_connect(conn_mysql, ob1.z1.obs0, root@obtest, , test, , USE_MYSQL_CONNECTOR);
connection conn_mysql
--enable_query_log

--disable_warnings
drop table if exists t;
--enable_warnings
create table t(c1 int primary key,c2 varchar(30), c3 varchar(30), fulltext index idx1(c2), fulltext index idx2(c3));
insert into t values(1,'[1,2,3]', '[3,2,1]');
--error 4016
alter table t add column c5 int auto_increment;
drop table t;

create table t(c1 int,c2 vector(3), c3 vector(3),vector index idx1(c2) with (distance=l2, type=hnsw),vector index idx2(c3) with (distance=l2, type=hnsw));
insert into t values(1,'[1,2,3]', '[3,2,1]');
--error 4016
alter table t add column c5 int auto_increment;
drop table t;

--disable_query_log
ob_connect(conn_sys, ob1.z1.obs0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);
connection conn_sys
--enable_query_log
alter system set_tp tp_name = FTS_INDEX_SUBTASK_BUILD_SSTABLE_FAILED, error_code = 4016, frequency = 0;
