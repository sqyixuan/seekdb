# owner: youchuan.yc
# owner group: storage
# description: test drop and rename fts index parallel

ob1=OBI(cluster=1:1,proxy_num=0);
ob1.reboot;
sleep 3;

ob_connect(conn_sys, ob1.z1.obs0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);
ob_connect(conn_sys_0, ob1.z1.obs0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);
ob_connect(conn_sys_1, ob1.z1.obs0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);
connection conn_sys;
set @@global.ob_query_timeout = 1000000000;
alter system set _enable_add_fulltext_index_to_existing_table = true;

--disable_warnings
drop table if exists t;
--enable_warnings
create table t (id int, name varchar(20));
insert into t (id, name) values (0, 'John Doe'), (1, 'Jane Smith'), (2, 'Alice Johnson');

alter system set_tp tp_no = 543, error_code = 4023, frequency = 1;
sleep 1;

connection conn_sys_0;
send create fulltext index idx0 on t(name);
sleep 8;

connection conn_sys_1;
send alter table t rename index idx0 to deleted;

connection conn_sys;
alter system set_tp tp_no = 543, error_code = 0, frequency = 1;
sleep 8;

connection conn_sys_0;
reap;

connection conn_sys_1;
reap;