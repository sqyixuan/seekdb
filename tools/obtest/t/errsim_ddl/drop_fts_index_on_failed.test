# owner: youchuan.yc
# owner group: storage
# description: test drop fts index when building fts index failed.

--disable_query_log

ob1=OBI(cluster=1:1,proxy_num=0);
ob1.reboot;
sleep 3;

ob_connect(conn_sys, ob1.z1.obs0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);
connection conn_sys
set @@global.ob_query_timeout = 1000000000;
alter system set _enable_add_fulltext_index_to_existing_table = true;

--echo
--echo
--echo ##### case 1: test for create fulltext index fail #####
--disable_warnings
drop table if exists t;
--enable_warnings
create table t (id int, name varchar(20));
insert into t (id, name) values (0, 'John Doe'), (1, 'Jane Smith'), (2, 'Alice Johnson');
alter system set_tp tp_no = 541, error_code = 4000, frequency = 1;
sleep 1;
--error 4000
create fulltext index idx on t(name);
select is_deleted, index_type from __all_table_history 
    where data_table_id = ( select table_id from __all_table where table_name = 't' ) and  is_deleted = 1;

alter system set_tp tp_no = 541, error_code = 4000, frequency = 0;
alter system set_tp tp_no = 542, error_code = 4000, frequency = 1;
sleep 1;

--error 4000
create fulltext index idx on t(name);

select is_deleted, index_type from __all_table_history 
    where data_table_id = ( select table_id from __all_table where table_name = 't' ) and  is_deleted = 1;

alter system set_tp tp_no = 542, error_code = 4000, frequency = 0;
alter system set_tp tp_no = 543, error_code = 4000, frequency = 1;
sleep 1;

--error 4000
create fulltext index idx on t(name);
select is_deleted, index_type from __all_table_history 
    where data_table_id = ( select table_id from __all_table where table_name = 't' ) and  is_deleted = 1;

alter system set_tp tp_no = 543, error_code = 4000, frequency = 0;
drop table t;

--echo
--echo
--echo ##### case 2: test for create fulltext index fail in the condition where there is already other fulltext index  #####
--disable_warnings
drop table if exists t;
--enable_warnings
alter system set_tp tp_no = 543, error_code = 4000, frequency = 0;
sleep 1;
create table t (id int, name varchar(20));
insert into t (id, name) values (0, 'John Doe'), (1, 'Jane Smith'), (2, 'Alice Johnson');
create fulltext index idx1 on t(name);

alter system set_tp tp_no = 543, error_code = 4000, frequency = 1;
sleep 1;

--error 4000
create fulltext index idx2 on t(name);

select is_deleted, index_type from __all_table_history 
    where data_table_id = ( select table_id from __all_table where table_name = 't' ) and  is_deleted = 1;

alter system set_tp tp_no = 543, error_code = 4000, frequency = 0;
drop table t;
