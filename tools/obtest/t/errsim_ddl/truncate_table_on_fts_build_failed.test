# owner: youchuan.yc
# owner group: storage
# description: test truncate table on fts build failed.

--disable_query_log

ob1=OBI(cluster=1:1,proxy_num=0);
ob1.reboot;
sleep 3;

ob_connect(conn_sys, ob1.z1.obs0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);
connection conn_sys
set @@global.ob_query_timeout = 10000000;
alter system set _enable_add_fulltext_index_to_existing_table = true;

--disable_warnings
drop table if exists t1;
--enable_warnings

CREATE TABLE t1(
    id bigint,
    content TEXT
);

insert into t1 values(1, 'abc');

alter system set_tp tp_no = 543, error_code = 4000, frequency = 1;
sleep 1;
--error 4000
create fulltext index idx on t1(content);
truncate t1;
select * from t1;
alter system set_tp tp_no = 543, error_code = 4000, frequency = 0;

drop table t1;