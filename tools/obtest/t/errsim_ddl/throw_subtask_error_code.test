# owner: youchuan.yc
# owner group: storage
# description: test fts parent task throw the error code of sub-task.

--disable_query_log

ob1=OBI(cluster=1:1,proxy_num=0);
ob1.reboot;
sleep 3;

ob_connect(conn_sys, ob1.z1.obs0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);
connection conn_sys
set @@global.ob_query_timeout = 1000000000;
alter system set _enable_add_fulltext_index_to_existing_table = true;
alter system set_tp tp_no = 544, error_code = 4016, frequency = 1;
sleep 2;
--disable_warnings
drop table if exists t;
--enable_warnings
create table t (id int, name varchar(20));
insert into t (id, name) values (0, 'John Doe'), (1, 'Jane Smith'), (2, 'Alice Johnson');
--error 4016
create fulltext index idx0 on t(name);
--error 4016
alter table t add fulltext index idx1(name);

sleep 2;

select count(*) from __all_ddl_task_status where 
    object_id = (select table_id from __all_table where table_name="t") and ddl_type = 7;

select count(*) from __all_table_history where 
      data_table_id = (select table_id from __all_table where table_name="t") and is_deleted = 1;

