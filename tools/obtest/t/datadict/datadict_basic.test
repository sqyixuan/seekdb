######################
#owner: bohou.ws
#description:
# test data dict basic function
#####################

ob1=OBI(cluster=1:1:1, proxy_num=1, init_unit_cpu=5);
ob1.reboot;
ob1.create_client;

source include/liboblog/check_schema_fast_sync.inc;
ob_connect(conn_dict, ob1.proxy0, root@obtest, , test, , USE_OB_CONNECTOR);
connection conn_dict;
ob1.mysql alter system set dump_data_dictionary_to_log_interval='30s' tenant sys;
ob1.mysql alter system set dump_data_dictionary_to_log_interval='30s' tenant all_user;
ob1.mysql alter system set dump_data_dictionary_to_log_interval='30s' tenant all_meta;
let $tb_cnt = 100;
let $part_cnt = 100;
--disable_query_log
use test;
set autocommit=1;
eval create table dict_test_test_test_test_t0(c0 bigint not null auto_increment) partition by hash(c0) partitions $part_cnt;
let $col_cnt = 500;
while ($col_cnt > 0)
{
  eval alter table dict_test_test_test_test_t0 add column column_column_column_column_column$col_cnt varchar(102) default "defaultdefaultdefaultdefaultdefaultdefaultdefaultdefaultdefault";
  dec $col_cnt;
}

while ($tb_cnt > 10)
{
  eval create table dict_test_test_test_test_t$tb_cnt like dict_test_test_test_test_t0;
  dec $tb_cnt;
}
let $tenant_name = "obtest";
let $ls_id = 1;
source include/liboblog/switch_replica_leader.inc;
--disable_query_log
sleep 40;
connection conn_dict;
while ($tb_cnt > 0)
{
  eval create table dict_test_test_test_test_t$tb_cnt like dict_test_test_test_test_t0;
  dec $tb_cnt;
}
source include/liboblog/check_schema_fast_sync.inc;

sleep 40;
# wait to generate data_dict;
--enable_query_log
# ob1.stop;
