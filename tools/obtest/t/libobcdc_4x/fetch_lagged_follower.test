ob1=OBI(cluster=1:1:1, proxy_num=0);

ob1.reboot;

source include/liboblog/create_tenant_multiple_zone.inc;

let $mysql_tenant_id=deploy_get_value(ob1.select select tenant_id from __all_tenant where tenant_name='oblog_tt', tenant_id, 1);

let $leader_ip_port=deploy_get_value(ob1.select select concat(svr_ip,':',svr_port) as host from __all_virtual_log_stat where tenant_id=$mysql_tenant_id and ls_id = 1001 and role='LEADER', host, 1);

let $follower_ip_port_1=deploy_get_value(ob1.select select concat(svr_ip,':',svr_port) as host from __all_virtual_log_stat where tenant_id=$mysql_tenant_id and ls_id = 1001 and role='FOLLOWER' order by svr_ip, svr_port, host, 1);
let $follower_ip_port_2=deploy_get_value(ob1.select select concat(svr_ip,':',svr_port) as host from __all_virtual_log_stat where tenant_id=$mysql_tenant_id and ls_id = 1001 and role='FOLLOWER' order by svr_ip, svr_port, host, 2);

let $leader=deploy_get_value(ob1.get_obs_by_addr $leader_ip_port);
let $follower_1=deploy_get_value(ob1.get_obs_by_addr $follower_ip_port_1);

ob1.oblog.gen_conf tb_white_list=oblog_tt.*.* skip_ob_version_compat_check=1 server_blacklist=$follower_ip_port_2 ls_fetch_progress_update_timeout_sec=1000;
ob1.oblog.restart;
sleep 10;

ob1.oblog.checkRealTime;

$leader.block_net $follower_1;
sleep 10;
ob1.oblog.check_log "LAGGED_FOLLOWER";
sleep 10;
ob1.oblog.checkRealTime;
$leader.clean_net $follower_1;
ob1.oblog.stop;
