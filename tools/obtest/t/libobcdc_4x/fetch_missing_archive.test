# owner: wenyue.zxl
# test point: test fetch missing log in archive
#

ob1=OBI(cluster=1, init_unit_cpu=5, proxy_num=0);
ob1.force_stop;
ob1.clean_backup_dest;
ob1.z1.obs0.set extra_config=_private_buffer_size='1B';
ob1.reboot;

source include/liboblog/create_tenant.inc;
source include/liboblog/enable_mysql_archive.inc;

connection oblog_conn_tt;

create database oblog_db;
use oblog_db;

--disable_all_result_log
create table dummy_table0(id int auto_increment primary key, c1 varchar(1024), c2 varchar(1024), c3 varchar(1024), c4 varchar(1024));
let $one_round = 256;
let $done = 0;
while ($done != 1)
{
  let $count = 0;
  while ($count < $one_round)
  {
    insert into dummy_table0(c1, c2, c3, c4) values (repeat('a', 1024), repeat('b', 1024), repeat('c', 1024), repeat('d', 1024));
    inc $count;
  }
  let $write_bytes = query_get_value(select end_lsn/1024/1024 as size from oceanbase.__all_virtual_log_stat where ls_id=1001, size, 1);
  if ($write_bytes > 20)
  {
    inc $done;
  }
}
--enable_all_result_log

create table test_tt0(id int primary key, name text);
begin;
insert into test_tt0 values (1, 'a');
insert into test_tt0 values (2, 'a');
insert into test_tt0 values (3, 'a');
insert into test_tt0 values (4, 'a');
sleep 1;
let $start_tstamp_usec0 = query_get_value(select time_to_usec(now(6)) as now, now, 1);
sleep 1;
insert into test_tt0 values (5, 'a');
insert into test_tt0 values (6, 'a');
insert into test_tt0 values (7, 'a');
insert into test_tt0 values (8, 'a');
commit;

ob1.oblog.set_start_tstamp_usec $start_tstamp_usec0;
ob1.oblog.gen_conf tb_white_list=oblog_tt.*.* log_level=DEBUG test_mode_force_fetch_archive=1 skip_ob_version_compat_check=1;
ob1.oblog.set_extra_argument -x;
ob1.oblog.restart;

ob1.oblog.next;

ob1.oblog.stop;

create table test_tt(id int primary key, name text);
create table dummy_table(id int primary key AUTO_INCREMENT, c1 varchar(1024), c2 varchar(1024), c3 varchar(1024), c4 varchar(1024));
set autocommit=0;

begin;
insert into test_tt values (1, 'a');
--disable_all_result_log
ob_connect(dummy_conn, ob1.z1.obs0, root@oblog_tt, , oblog_db, , USE_MYSQL_CONNECTOR);

connection dummy_conn;
let $dummy_num = 1024;
while ($dummy_num > 0)
{
  insert into dummy_table(c1, c2, c3, c4) values (repeat('a', 1024), repeat('b', 1024), repeat('c', 1024), repeat('d', 1024));
  dec $dummy_num;
}
connection oblog_conn_tt;
--enable_all_result_log

insert into test_tt values (2, 'a');

--disable_all_result_log
connection dummy_conn;
let $dummy_num = 1024;
while ($dummy_num > 0)
{
  insert into dummy_table(c1, c2, c3, c4) values (repeat('a', 1024), repeat('b', 1024), repeat('c', 1024), repeat('d', 1024));
  dec $dummy_num;
}
connection oblog_conn_tt;
--enable_all_result_log

insert into test_tt values (3, 'a');

--disable_all_result_log
connection dummy_conn;
let $dummy_num = 1024;
while ($dummy_num > 0)
{
  insert into dummy_table(c1, c2, c3, c4) values (repeat('a', 1024), repeat('b', 1024), repeat('c', 1024), repeat('d', 1024));
  dec $dummy_num;
}
connection oblog_conn_tt;
--enable_all_result_log

insert into test_tt values (4, null);

--disable_all_result_log
connection dummy_conn;
let $dummy_num = 1024;
while ($dummy_num > 0)
{
  insert into dummy_table(c1, c2, c3, c4) values (repeat('a', 1024), repeat('b', 1024), repeat('c', 1024), repeat('d', 1024));
  dec $dummy_num;
}
connection oblog_conn_tt;
--enable_all_result_log

insert into test_tt values (5, 'a');

--disable_all_result_log
connection dummy_conn;
let $dummy_num = 1024;
while ($dummy_num > 0)
{
  insert into dummy_table(c1, c2, c3, c4) values (repeat('a', 1024), repeat('b', 1024), repeat('c', 1024), repeat('d', 1024));
  dec $dummy_num;
}
connection oblog_conn_tt;
--enable_all_result_log

insert into test_tt values (6, 'a');
insert into test_tt values (7, 'a');

sleep 1;
connection oblog_conn_sys;
let $start_tstamp_usec = query_get_value(select time_to_usec(now(6)) as now, now, 1);
connection oblog_conn_tt;
sleep 1;

insert into test_tt values (8, 'a');
commit;

ob1.oblog.set_start_tstamp_usec $start_tstamp_usec;
ob1.oblog.gen_conf tb_white_list=oblog_tt.*.* log_level=DEBUG test_mode_force_fetch_archive=1 skip_ob_version_compat_check=1;
ob1.oblog.set_extra_argument -x;
ob1.oblog.restart;

ob1.oblog.next;

ob1.oblog.stop;



