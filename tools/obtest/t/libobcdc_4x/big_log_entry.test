#
# owner: liuhanyi.lhy
# owner group: liboblog
# description:
# 测试点:
#  1. 测试cdc能否正常读取消费3.5MB的日志
##
 
ob1=OBI(cluster=1,init_unit_cpu=5);
ob1.reboot;
ob1.create_client;
 
# 创建mysql租户oblog_tt，并且切换到mysql租户下
source include/liboblog/4_x/create_mysql_tenant.inc;
set @@session.ob_query_timeout = 1000000000;
# 启动liboblog，同步oblog_tt租户数据
ob1.oblog.gen_conf tb_white_list=obcdc_mysql.*.* log_level=DEBUG skip_ob_version_compat_check=1;
ob1.oblog.set_extra_argument -m;
ob1.oblog.restart;
 
# 创建database 1
create database oblog_db1;
use oblog_db1;

source include/prepare_for_big_log.inc;
select pk, md5(f383) from big_table;
# 输出create database DDL
ob1.oblog.next;
# 输出create table DDL
ob1.oblog.next;
# 输出insert DDL
ob1.oblog.next;
# 输出update DDL
ob1.oblog.next;
 
 
# set系统变量不会生成redo日志，不需要迭代数据
set @@time_zone = '+06:00';
 
# stop liboblog
ob1.oblog.stop;