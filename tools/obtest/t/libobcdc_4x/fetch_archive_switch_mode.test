ob1=OBI(cluster=1, proxy_num=0);
ob1.force_stop;
ob1.clean_backup_dest;
ob1.reboot;

source include/liboblog/create_tenant.inc;
source include/liboblog/enable_mysql_archive.inc;

create database obcdc_test;
use obcdc_test;

create table t0 (id int primary key, col1 int);
sleep 1;
let $start_tstamp_usec = query_get_value(select time_to_usec(now(6)) as now, now, 1);
create table t1(a int primary key, b int, c int);
sleep 15;
ob1.oblog.set_start_tstamp_usec $start_tstamp_usec;
ob1.oblog.gen_conf tb_white_list=oblog_tt.*.* log_level=DEBUG test_mode_switch_fetch_mode=1 skip_ob_version_compat_check=1;
ob1.oblog.restart;

ob1.oblog.next;


insert into t1(a, b) values(1, 1);
ob1.oblog.next;

insert into t1 values (2, 2, 2);
ob1.oblog.next;


ob1.oblog.stop;
