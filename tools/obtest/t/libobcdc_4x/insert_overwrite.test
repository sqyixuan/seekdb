#
# owner: TODO
# owner group: liboblog
# description:
# 测试点:
#  TODO
##

ob1=OBI(cluster=1,init_unit_cpu=5);
ob1.reboot;
ob1.create_client;

# 创建mysql租户oblog_tt，并且切换到mysql租户下
source include/liboblog/4_x/create_mysql_tenant.inc;
sleep 30;
# 启动liboblog，同步oblog_tt租户数据
ob1.oblog.gen_conf tb_white_list=obcdc_mysql.*.* log_level=DEBUG skip_ob_version_compat_check=1;
ob1.oblog.restart;

# 创建database 1
create database oblog_db1;
# 输出create database DDL
ob1.oblog.next;

use oblog_db1;

# 创建表
create table t1(id int, c1 timestamp(6), c2 datetime);
# 输出create table DDL
ob1.oblog.next;

# 执行AC=1的DML事务
insert into t1 values(1, '2019-1-30 12:00:00.123456', '2019-1-30 12:00:00');
# 输出上述事务
ob1.oblog.next;

create table t2(id int, c1 timestamp(6), c2 datetime);
# 输出create table DDL
ob1.oblog.next;

# 输出 
insert overwrite t2 select * from t1;

# 执行AC=1的DML事务
insert into t1 values(1, '2019-1-30 12:00:00.123456', '2019-1-30 12:00:00');
# 输出上述事务
ob1.oblog.next;

# 输出 
insert overwrite t2 select * from t1;

# 执行drop table DDL
drop table t1;
# 输出drop table DDL
ob1.oblog.next;

# set系统变量不会生成redo日志，不需要迭代数据
set @@time_zone = '+06:00';

# stop liboblog
ob1.oblog.stop;
