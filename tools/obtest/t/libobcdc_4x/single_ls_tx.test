##############
#owner: bohou.ws
#test point: obcdc handle single ls transaction
##############
# prepare cluster and tenant
ob1=OBI(cluster=1,proxy_num=1);

let $extra_conf = "cpu_count=16,memory_limit='30G',system_memory='5G',__min_full_resource_pool_memory='268435456',cache_wash_threshold='1G'";

# case 1. 验证bootstrap
ob1.reboot;
sleep 3;

# case 2. 验证创建表和DML/SELECT操作
ob_connect(conn_sys, ob1.z1.obs0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);

# case 3. 验证建租户
let $cpu = 1;
let $memory = '20G';

set @@session.ob_query_timeout = 1000000000;
#mysql tenant
eval CREATE RESOURCE UNIT unit_1 MAX_CPU=$cpu, MEMORY_SIZE=$memory;
CREATE RESOURCE POOL pool_1 UNIT = 'unit_1', UNIT_NUM = 1;
#source include/liboblog/check_schema_fast_sync.inc;
CREATE TENANT cdc_mysql RESOURCE_POOL_LIST = ('pool_1'), primary_zone='z1' set ob_tcp_invited_nodes='%';
source include/check_schema_sync.inc;

ob_connect(conn_obcdc_mysql, ob1.proxy0, root@cdc_mysql, , oceanbase, , USE_MYSQL_CONNECTOR);

let $start_tstamp_usec = query_get_value(select time_to_usec(now(6)) as now, now, 1);
ob1.oblog.gen_conf tb_white_list=cdc_mysql.*.* log_level=DEBUG skip_ob_version_compat_check=1;
ob1.oblog.restart;

source include/liboblog/4_x/basic.inc;
source include/liboblog/4_x/tx_overall.inc;

ob1.oblog.stop;

ob1.oblog.gen_conf tb_white_list=cdc_mysql.*.* log_level=DEBUG skip_ob_version_compat_check=1;
ob1.oblog.set_start_tstamp_usec $start_tstamp_usec;
ob1.oblog.restart;
sleep 10;
ob1.oblog.stop;
ob1.oblog.check_log "init obcdc";

ob1.oblog.gen_conf tb_white_list=cdc_mysql.*.* log_level=DEBUG skip_ob_version_compat_check=1;
ob1.oblog.set_start_tstamp_usec $restart_ts1_usec;
ob1.oblog.set_extra_argument '-c';
ob1.oblog.restart;
ob1.oblog.next;
ob1.oblog.stop;
ob1.oblog.check_log "init obcdc";

ob1.oblog.gen_conf tb_white_list=cdc_mysql.*.* log_level=DEBUG skip_ob_version_compat_check=1;
ob1.oblog.set_start_tstamp_usec $restart_ts2_usec;
ob1.oblog.set_extra_argument '-c';
ob1.oblog.restart;
ob1.oblog.next;
ob1.oblog.stop;
ob1.oblog.check_log "init obcdc";
