# owner: wenyue.zxl
# test point: test fetch missing log in archive
#

ob1=OBI(cluster=1, init_unit_cpu=5);
ob1.force_stop;
ob1.clean_backup_dest;
ob1.z1.obs0.set extra_config=_private_buffer_size='1B';
ob1.reboot;

source include/liboblog/create_tenant.inc;
source include/liboblog/enable_mysql_archive.inc;

connection oblog_conn_tt;
set global max_allowed_packet=1073741824;
connection oblog_conn_tt;
set ob_trx_timeout=100000000;
set ob_query_timeout=1000000000;

create database oblog_db;
use oblog_db;

create table test_tt(id int primary key, name text);

set autocommit=0;

begin;
insert into test_tt values (1, 'a');
insert into test_tt values (2, 'a');
insert into test_tt values (3, 'a');
insert into test_tt values (4, null);
sleep 1;
connection oblog_conn_sys;
let $start_tstamp_usec = query_get_value(select time_to_usec(now(6)) as now, now, 1);
connection oblog_conn_tt;
sleep 1;
insert into test_tt values (5, 'a');
insert into test_tt values (6, 'a');
insert into test_tt values (7, 'a');
insert into test_tt values (8, 'a');
commit;

ob1.oblog.set_start_tstamp_usec $start_tstamp_usec;
ob1.oblog.gen_conf tb_white_list=oblog_tt.*.* log_level=DEBUG fetching_log_mode=direct archive_dest=$log_backup_dest;
ob1.oblog.set_extra_argument;
ob1.oblog.restart;

ob1.oblog.next;

ob1.oblog.stop;

create table t1(id int primary key, c1 longtext);

begin;
insert into t1 values (1, 'a');
insert into t1 values (2, 'a');
insert into t1 values (3, 'a');
insert into t1 values (4, 'a');
sleep 1;
connection oblog_conn_sys;
let $start_tstamp_usec1 = query_get_value(select time_to_usec(now(6)) as now, now, 1);
connection oblog_conn_tt;
sleep 1;
insert into t1 values (5, repeat('a', 2097152));
insert into t1 values (6, repeat('a', 2097152));
insert into t1 values (7, repeat('a', 2097152));
insert into t1 values (8, repeat('a', 2097152));
select md5(c1) from t1 order by id desc;
commit;

ob1.oblog.set_start_tstamp_usec $start_tstamp_usec1;
ob1.oblog.gen_conf tb_white_list=oblog_tt.*.* log_level=DEBUG test_fetch_missing_errsim=1 fetching_log_mode=direct archive_dest=$log_backup_dest;
ob1.oblog.set_extra_argument -m;
ob1.oblog.restart;

ob1.oblog.next;

ob1.oblog.stop;