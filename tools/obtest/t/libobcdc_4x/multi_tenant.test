#
# owner: TODO
# owner group: liboblog
# description:
# 测试点:
#  TODO
##

ob1=OBI(cluster=1,init_unit_cpu=5);
ob1.reboot;
ob1.create_client;

source include/liboblog/4_x/create_mysql_tenant.inc;
ob_connect(conn_obcdc_obtest, ob1.z1.obs0, root@obtest, , oceanbase, , USE_MYSQL_CONNECTOR);

connection conn_obcdc_mysql;
create database cdc_mysql_db;
use cdc_mysql_db;
create table fake(m int primary key);
# fake表占位table_id 500003
create table t1(m int primary key);

connection conn_obcdc_obtest;
create database cdc_obtest_db;
use cdc_obtest_db;
create table t2(o int primary key);
sleep 3;

connection conn_sys;
use oceanbase;
let $start_tstamp= query_get_value(select time_to_usec(now(6)) as now, now, 1);
let $m_schema_version = query_get_value(select time_to_usec(now()) as now, now, 1);
--disable_query_log
#echo "$m_schema_version"
alter system change tenant obcdc_mysql;
eval update __all_ddl_operation set schema_version = $m_schema_version where schema_version in (select max(schema_version) from __all_ddl_operation);
alter system change tenant obtest;
eval update __all_ddl_operation set schema_version = $m_schema_version where schema_version in (select max(schema_version) from __all_ddl_operation);
--enable_query_log
sleep 2;

# TODO: use tenant get from inner_table instead of hardcode.
ob1.oblog.gen_conf tb_white_list=*cdc*.*.*|obtest.*.* log_level=DEBUG data_start_schema_version=1004:$m_schema_version|1006:$m_schema_version skip_ob_version_compat_check=1;
ob1.oblog.set_start_tstamp_usec $start_tstamp;
ob1.oblog.restart;
sleep 5;

connection conn_obcdc_mysql;
use cdc_mysql_db;
insert into t1 values (1), (2), (3);
ob1.oblog.next_dml;

connection conn_obcdc_obtest;
use cdc_obtest_db;
insert into t2 values (4), (5), (6);
ob1.oblog.next_dml;

ob1.oblog.stop;

ob1.oblog.gen_conf tb_white_list=*cdc*.*.*|obtest.*.* log_level=DEBUG data_start_schema_version=1004:$m_schema_version|1006:$m_schema_version skip_ob_version_compat_check=1;
ob1.oblog.set_start_tstamp_usec $start_tstamp;
ob1.oblog.restart;
ob1.oblog.next_dml;
ob1.oblog.next_dml;

ob1.oblog.stop;
