##############################
#owner: luyun
#owner group: java_client1.0
#description: 验证zone合并，流量发到不在合并的机器
###############################

ob1=OBI(cluster=1:1:1,init_unit_cpu=8,proxy_num=0);
ob1.reboot;

ob1.mysql alter system set merger_switch_leader_duration_time='0s';

ob1.set_ds_global_config serverStateRefreshInterval=1000;

ob1.create_client tenant=obtest,user=admin,passwd=admin,database=test;
ob1.set_ds_global_config commonLoggerLevel=DEBUG;

--disable_result_log
drop table if exists t1;
create table t1(id int primary key);
insert into t1 values(1);
select * from t1;
--enable_result_log

## 验证第一条sql发给leader
let $leader = deploy_get_value(ob1.get_leader obtest:test:t1);

select * from t1;

source include/get_ob_connector_last_query_addr.inc;

if ($leader != $obs)
{
  -- echo leader is $leader, query_obs is $obs
  --exit
}

let $leader_zone = deploy_get_value(ob1.get_leader_zone obtest:test:t1);

### leader zone is merging
let $zone = deploy_get_value(ob1.$leader_zone.name);
ob1.mysql alter system suspend merge zone = '$zone';
sleep 2;

ob1.mysql alter system major freeze;
sleep 5;
ob1.mysql alter system start merge zone='$zone';
sleep 2;

$leader_zone.check_state_in_congest MERGE;

## zone merge, but still send first sql to leader
select * from t1;

source include/get_ob_connector_last_query_addr.inc;
if ($obs != $leader)
{
  --echo leader $leader is merge, but query $obs
  --exit
}
