##############################
#owner: luyun
#owner group: java_client1.0
#description: 验证活不可用惩罚机制
###############################

ob1=OBI(cluster=1:1:1,init_unit_cpu=8,proxy_num=0);
ob1.reboot;

ob1.source include/merge.inc;
ob1.mysql alter system set enable_auto_leader_switch = 'false';
ob1.mysql alter system set enable_rebalance=false;
ob1.mysql alter system set enable_rereplication=false;
ob1.set_ds_global_config congestionFailureThreshold=1;
ob1.set_ds_global_config serverStateRefreshInterval=1000;
ob1.set_ds_global_config congestionRetryInterval=3000;

ob1.create_client tenant=obtest,user=admin,passwd=admin,database=test,connProps=socketTimeout=5000;
ob1.set_ds_global_config commonLoggerLevel=DEBUG;

--disable_result_log
drop table if exists t1;
create table t1(id int primary key);
insert into t1 values(1);
select * from t1;
--enable_result_log

#等待2s，确保刷新一次server list
sleep 2;

select * from t1;

let $last_addr = deploy_get_value(ob1.get_last_query_addr rpc);
let $query_obs = deploy_get_value(ob1.get_obs_by_addr $last_addr);
let $query_zone = deploy_get_value(ob1.get_zone_by_addr $last_addr);

let $leader = deploy_get_value(ob1.get_leader obtest:test:t1);
if ($leader != $query_obs)
{
  --echo leader is $leader, query obs is $query_obs !!!
  --exit
}

$query_obs.check_state_in_congest ACTIVE;

# hang住leader,重试follwoer，leader加入活不可用
ob1.set_ds_global_config serverStateRefreshInterval=3600000;

sleep 2;

$leader.hang_in_net sql;

select * from t1;

let $last_addr = deploy_get_value(ob1.get_last_query_addr rpc);
let $query_obs = deploy_get_value(ob1.get_obs_by_addr $last_addr);
let $query_zone = deploy_get_value(ob1.get_zone_by_addr $last_addr);
if ($leader == $query_obs)
{
  --echo alive congested leader is $leader, query obs is still $query_obs !!!
  --exit
}

let $stat =deploy_get_value($leader.get_congestion_info alive_congested);
--echo $stat

# sleep 4, 重试活不可用的leader, retry延长为6s
sleep 4;
select * from t1;

let $last_addr = deploy_get_value(ob1.get_last_query_addr rpc);
let $query_obs = deploy_get_value(ob1.get_obs_by_addr $last_addr);
let $query_zone = deploy_get_value(ob1.get_zone_by_addr $last_addr);
if ($leader == $query_obs)
{
  --echo alive congested leader is $leader, query obs is still $query_obs !!!
  --exit
}

let $stat =deploy_get_value($leader.get_congestion_info alive_congested);
--echo $stat

# sleep 4, 重试时间被延长, 不重试leader
$leader.clean_hang_in_net sql;
sleep 4;

select * from t1;

let $last_addr = deploy_get_value(ob1.get_last_query_addr rpc);
let $query_obs = deploy_get_value(ob1.get_obs_by_addr $last_addr);
let $query_zone = deploy_get_value(ob1.get_zone_by_addr $last_addr);
if ($leader == $query_obs)
{
  --echo alive congested leader is $leader, query obs is still $query_obs !!!
  --exit
}

# sleep 4, 重试leader，leader被洗白
sleep 4;
select * from t1;

let $last_addr = deploy_get_value(ob1.get_last_query_addr rpc);
let $query_obs = deploy_get_value(ob1.get_obs_by_addr $last_addr);
let $query_zone = deploy_get_value(ob1.get_zone_by_addr $last_addr);
if ($leader != $query_obs)
{
  --echo alive congested leader is $leader, query obs is $query_obs !!!
  --exit
}

let $stat =deploy_get_value($leader.get_congestion_info alive_congested);
--echo $stat
