##############################
#owner: luyun
#owner group: java_client1.0
#description: 验证刷新server list失败，更新rslist
###############################

ob1=OBI(cluster=2:2:2,init_unit_cpu=8,proxy_num=0);
ob1.reboot;

ob1.source include/merge.inc;
ob1.mysql alter system set enable_auto_leader_switch = 'false';
ob1.mysql alter system set balancer_idle_time='10s';
ob1.mysql alter system set server_data_copy_in_concurrency=10;
ob1.mysql alter system set server_data_copy_out_concurrency=10;
ob1.mysql alter system set balancer_task_timeout='30s';
ob1.set_ds_global_config serverStateRefreshInterval=1000;

ob1.create_client tenant=obtest,user=admin,passwd=admin,database=test;
ob1.set_ds_global_config commonLoggerLevel=DEBUG;

create table t1(id int primary key);
insert into t1 values(1);
select * from t1;

#等待2s，确保刷新一次server list
sleep 2;

let $leader = deploy_get_value(ob1.get_leader obtest:test:t1);

let $last_addr = deploy_get_value(ob1.get_last_query_addr rpc);
let $query_obs = deploy_get_value(ob1.get_obs_by_addr $last_addr);
let $query_zone = deploy_get_value(ob1.get_zone_by_addr $last_addr);

if ($leader != $query_obs)
{
  --echo leader is $leader, query_obs $query_obs
  --exit
}

## delete 一台follower，更新rs list
let $follower = ob1.z2.obs0;

$follower.check_in_rslist;

$follower.delete;
$follower.check_delete 300;
sleep 3;
$follower.check_not_exsit_in_congest;
$follower.check_not_in_rslist;
