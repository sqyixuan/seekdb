##############################
#owner: luyun
#owner group: proxy
#description: 验证查询两张表
###############################

ob1=OBI(cluster=2:2:2,init_unit_cpu=8,proxy_num=0);
ob1.reboot;

ob1.mysql alter system set enable_auto_leader_switch = 'false';

ob1.set_ds_global_config serverStateRefreshInterval=1000;
ob1.create_client tenant=obtest,user=root,passwd=,database=test;
ob1.set_ds_global_config commonLoggerLevel=DEBUG;

create table t1 (c1 int);
insert into t1 values (1);
create table t2 (c2 int);
insert into t2 values (2);

let $leader1 = deploy_get_value(ob1.get_leader obtest:test:t1);
let $leader2 = deploy_get_value(ob1.get_leader obtest:test:t2);
let $follower1 = deploy_get_value(ob1.get_follower obtest:test:t1);
let $follower2 = deploy_get_value(ob1.get_follower obtest:test:t2);

if ($leader1 != $leader2)
{
  --echo leader1 is $leader1, leader2 is $leader2
  --exit
}

## 强一致性读，发给共同的leader

select t1.c1, t2.c2 from t1, t2;

source include/get_ob_connector_last_query_addr.inc;

if ($leader1 != $obs)
{
  --echo common leader is $leader1, but query $obs
  --exit
}

## switch leader1
$follower1.switch_partition obtest:test:t1;
sleep 15;

let $leader1 = deploy_get_value(ob1.get_leader obtest:test:t1);
if ($leader1 != $follower1)
{
  --echo fail to switch leader1 to $follower1, current leader1 is $leader1
  --exit
}

select * from t1;
select * from t1;
source include/get_ob_connector_last_query_addr.inc;
if ($obs != $leader1)
{
  --echo leader1 is $leader1, but query $obs
  --exit
}

let $leader2 = deploy_get_value(ob1.get_leader obtest:test:t2);

if ($leader1 == $leader2)
{
  --echo leader1 still equals to leader2, leader is $leader1
  --exit
}

## 没有共同leader, 随机发，server不支持强一致性读
--disable_result_log
--error 1235
select t1.c1, t2.c2 from t1, t2;
--enable_result_log

## 弱一致性读，随机发
select /*+ read_consistency(weak)*/ t1.c1, t2.c2 from t1, t2;
