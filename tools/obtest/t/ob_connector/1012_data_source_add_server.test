##############################
#owner: luyun
#owner group: java_client1.0
#description: 验证添加一台server，server list可以及时更新
###############################

ob1=OBI(cluster=2:2:2,init_unit_cpu=8,proxy_num=0);
ob1.reboot;

ob1.source include/merge.inc;
ob1.mysql alter system set balancer_idle_time='10s';
ob1.mysql alter system set balancer_task_timeout='30s';
ob1.set_ds_global_config serverStateRefreshInterval=1000;

ob1.create_client tenant=obtest,user=admin,passwd=admin,database=test;
ob1.set_ds_global_config commonLoggerLevel=DEBUG;

create table t1(id int primary key);
insert into t1 values(1);
select * from t1;

#等待2s，确保刷新一次server list
sleep 2;

let $leader = deploy_get_value(ob1.get_leader obtest:test:t1);

select * from t1;

source include/get_ob_connector_last_query_addr.inc;

if ($leader != $obs)
{
  --echo leader is $leader, query_obs is $obs
  --exit
}

## delete 一台follower
let $follower = deploy_get_value(ob1.get_follower obtest:test:t1);

$follower.check_state_in_congest ACTIVE;

$follower.delete;
$follower.check_delete 300;

## 验证server已经不在黑名单中
sleep 2;
$follower.check_not_exsit_in_congest;

sleep 15;

## add server
let $ip = deploy_get_value($follower.ip);
let $port = deploy_get_value($follower.port);

ob1.mysql alter system add server '$ip:$port';
ob1.check_until_timeout select count(*) from __all_server where svr_ip='$ip' and svr_port=$port,1,20;

## 黑名单更新
sleep 2;
$follower.check_state_in_congest ACTIVE;
