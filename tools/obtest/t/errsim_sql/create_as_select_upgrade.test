# owner: yibo.tyf
# owner group: SQL1
# description: Verify ctas failed and generate duty data in inner table. Then upgrade can handle duty data.
#              Note that server with version 3_1_1 must build with errsim flag.

ob1=OBI(cluster=1:1:1,init_unit_cpu=2,init_unit_num=1,init_unit_mem=805306368,version=3_1_1,oblog_version=current);
let $extra_conf = "cpu_count=16,memory_limit='10G',system_memory='5G',__min_full_resource_pool_memory='268435456',cache_wash_threshold='1G'";
ob1.proxy0.set extra_config=syslog_level=debug;
ob1.z1.obs0.set extra_config=$extra_conf;
ob1.z2.obs0.set extra_config=$extra_conf;
ob1.z3.obs0.set extra_config=$extra_conf;
ob1.reboot;
let $ip=deploy_get_value(ob1.proxy0.ip);
let $port=deploy_get_value(ob1.proxy0.port);
let $ipz1=deploy_get_value(ob1.z1.obs0.ip);
let $portz1=deploy_get_value(ob1.z1.obs0.mysql_port);
let $ipz2=deploy_get_value(ob1.z2.obs0.ip);
let $portz2=deploy_get_value(ob1.z2.obs0.mysql_port);
let $ipz3=deploy_get_value(ob1.z3.obs0.ip);
let $portz3=deploy_get_value(ob1.z3.obs0.mysql_port);
connect (ob_conn1,$ip,root@sys,,oceanbase,$port);
connection ob_conn1;

# 1 设置租户的主
ob1.mysql alter tenant sys set primary_zone='z1';
ob1.check_until_timeout select count(1) from __all_virtual_core_meta_table where role=1 and zone='z1',1,120;
ob1.check_until_timeout select count(1) from __all_virtual_server_stat,3,120;

# 2 构造升级前的脏数据
create table t1(c1 int, c2 varchar(10));
insert into t1 values(1, 'test1'), (2, 'test2'), (3, 'test3'), (4, 'test4'), (5, 'test5'),
                     (6, 'test6'), (7, 'test7'), (8, 'test8'), (9, 'test9'), (10, 'test10');
create table t2 as select a.* from t1 a, t1 b, t1 c;

alter system set _ob_ddl_timeout = '5s';
ob1.mysql alter system set_tp tp_no = 57, error_code = 4012, frequency = 1;
--error 4012
create table xy as select a.* from t2 a, t2 b, t2 c;
--error 4012
create table xy1 as select a.* from t2 a, t2 b, t2 c;
ob1.mysql alter system set_tp tp_no = 57, error_code = 4012, frequency = 0;
alter system set _ob_ddl_timeout = '1000s';
## 存在脏数据xy
ob1.check_until_timeout select count(*) from __all_table_v2 where table_name = 'xy' and session_id > 0, 1, 30;
ob1.check_until_timeout select count(*) from __all_table_v2 where table_name = 'xy1' and session_id > 0, 1, 30;
let $xy_table_id = deploy_get_value(ob1.select select table_id from __all_table_v2 where table_name = 'xy' and session_id > 0, table_id, 1);
let $xy1_table_id = deploy_get_value(ob1.select select table_id from __all_table_v2 where table_name = 'xy1' and session_id > 0, table_id, 1);
let $create_host_ip = deploy_get_value(ob1.select select svr_ip from __all_tenant_meta_table where table_id = $xy_table_id, svr_ip, 1);
let $create_host_port = deploy_get_value(ob1.select select svr_port from __all_tenant_meta_table where table_id = $xy_table_id, svr_port, 1);
## 在__all_temp_table表中插入数据用于升级后清理脏数据
eval insert into __all_temp_table values (1, $xy_table_id, '$create_host_ip:$create_host_port');
eval insert into __all_temp_table values (1, $xy1_table_id, '$create_host_ip:$create_host_port');

# 3 升级
# 3.1 第1次合并
ob1.mysql alter system major freeze;
sleep 120;
ob1.check_version 2;
ob1.check_until_timeout select info from __all_zone where zone='' and name='merge_status',IDLE,30;

# 3.2 打开升级配置, 升级前检查
ob1.upgrade_check_before;
ob1.mysql alter system begin upgrade;
sleep 2;

# 3.3 执行升级SQL
ob1.upgrade_commond_for_server pre;
sleep 5;

# 3.4 先升级z2 rs在老server上
# 3.4.1 首先检查日志是同步状态
ob1.check_until_timeout select count(1) from __all_virtual_core_meta_table where role=1 and zone='z1',1,120;
ob1.check_until_timeout SELECT CAST(COUNT(*) AS SIGNED) as cnt FROM __all_virtual_clog_stat WHERE is_in_sync = 0 and is_offline=0,0,600;
connection ob_conn1;
set @saved_ob_query_timeout = @@session.ob_query_timeout;
set @@session.ob_query_timeout = 60000000;
alter system stop zone 'z2';
set @@session.ob_query_timeout = @saved_ob_query_timeout;
ob1.check_until_timeout select info from __all_zone where zone='z2' and name='status',INACTIVE,20;
ob1.check_until_timeout select leader_count from __all_virtual_server_stat where zone = 'z2',0,20;
#sleep 2;
#ob1.z2.check_state_in_congest upgrade;

# 3.4.2 升级版本
ob1.z2.force_stop;
ob1.check_until_timeout select count(*) from oceanbase.__all_server where zone = 'z2' and (start_service_time<=0 and status='INACTIVE'),1,60;
ob1.z2.upgrade;
ob1.z2.nstart;
ob1.check_until_timeout select count(*) from oceanbase.__all_server where zone = 'z2' and (start_service_time<=0 or status='INACTIVE'),0,90;
ob1.check_until_timeout SELECT CAST(COUNT(*) AS SIGNED) as cnt FROM __all_virtual_clog_stat WHERE is_in_sync = 0 and is_offline=0,0,600;
ob1.check_until_timeout select count(*) from (select a.tenant_id, count(*) from oceanbase.__all_tenant as a left join oceanbase.__all_virtual_server_schema_info as b on a.tenant_id = b.tenant_id where refreshed_schema_version > 1 group by a.tenant_id having count(*) != 3),0,15;
ob1.mysql alter system start zone 'z2';
sleep 2;
ob1.check_until_timeout select count(1) from __all_virtual_server_stat,3,120;
#ob1.z2.check_state_in_congest active;

# 3.4.3 验证新server发create table rpc到旧RS上
connect (ob_z2_conn,$ipz2,root@sys,,oceanbase,$portz2);
connection ob_z2_conn;
alter system set enable_ddl = true;
create table t_high_server_low_rs (c1 int, c2 int);
insert into t_high_server_low_rs values (1,2), (3,4);
create table ctas_high_server_low_rs as select * from t_high_server_low_rs;
select * from ctas_high_server_low_rs;
alter system set enable_ddl = false;

# 3.5 再升级z1 rs在新server上
# 3.5.1 首先检查日志是同步状态
ob1.check_until_timeout select count(1) from __all_virtual_core_meta_table where role=1 and zone='z1',1,120;
ob1.check_until_timeout select count(1) from __all_virtual_server_stat,3,120;
ob1.check_until_timeout SELECT CAST(COUNT(*) AS SIGNED) as cnt FROM __all_virtual_clog_stat WHERE is_in_sync = 0 and is_offline=0,0,600;
connection ob_conn1;
set @@session.ob_query_timeout = 60000000;
alter system stop zone 'z1';
ob1.check_until_timeout select info from __all_zone where zone='z1' and name='status',INACTIVE,20;
ob1.check_until_timeout select leader_count from __all_virtual_server_stat where zone = 'z1',0,20;
#sleep 2;
#ob1.z1.check_state_in_congest upgrade;

# 3.5.2 升级版本
ob1.z1.force_stop;
sleep 30;
ob1.check_until_timeout select count(*) from oceanbase.__all_server where zone = 'z1' and (start_service_time<=0 or status='INACTIVE'),1,60;
ob1.z1.upgrade;
ob1.z1.nstart;
ob1.check_until_timeout select count(*) from oceanbase.__all_server where zone = 'z1' and (start_service_time>0 and status='ACTIVE'),1,90;
ob1.check_until_timeout SELECT CAST(COUNT(*) AS SIGNED) as cnt FROM __all_virtual_clog_stat WHERE is_in_sync = 0 and is_offline=0,0,600;
ob1.check_until_timeout select count(*) from (select a.tenant_id, count(*) from oceanbase.__all_tenant as a left join oceanbase.__all_virtual_server_schema_info as b on a.tenant_id = b.tenant_id where refreshed_schema_version > 1 group by a.tenant_id having count(*) != 3),0,15;
ob1.mysql alter system start zone 'z1';
sleep 2;
ob1.check_until_timeout select count(1) from __all_virtual_server_stat,3,120;
#ob1.z1.check_state_in_congest active;
ob1.check_until_timeout select count(1) from __all_virtual_core_meta_table where role=1 and zone='z1',1,120;
sleep 5;

# 3.5.3 验证旧server发create table rpc到新RS上
connect (ob_z3_conn,$ipz3,root@sys,,oceanbase,$portz3);
connection ob_z3_conn;
alter system set enable_ddl = true;
create table t_low_server_high_rs (c1 int, c2 int);
insert into t_low_server_high_rs values (1,2), (3,4);
create table ctas_low_server_high_rs as select * from t_low_server_high_rs;
select * from ctas_low_server_high_rs;
alter system set enable_ddl = false;

# 3.6 最后升级z3
# 3.6.1 首先检查日志是同步状态
ob1.check_until_timeout select count(1) from __all_virtual_core_meta_table where role=1 and zone='z1',1,120;
ob1.check_until_timeout select count(1) from __all_virtual_server_stat,3,120;
ob1.check_until_timeout SELECT CAST(COUNT(*) AS SIGNED) as cnt FROM __all_virtual_clog_stat WHERE is_in_sync = 0 and is_offline=0,0,600;
set @@session.ob_query_timeout = 60000000;
alter system stop zone 'z3';
ob1.check_until_timeout select info from __all_zone where zone='z3' and name='status',INACTIVE,20;
ob1.check_until_timeout select leader_count from __all_virtual_server_stat where zone = 'z3',0,20;
#sleep 2;
#ob1.z3.check_state_in_congest upgrade;

# 3.6.2 升级版本
ob1.z3.force_stop;
ob1.check_until_timeout select count(*) from oceanbase.__all_server where zone = 'z3' and (start_service_time<=0 and status='INACTIVE'),1,60;
ob1.z3.upgrade;
ob1.z3.nstart;
ob1.check_until_timeout select count(*) from oceanbase.__all_server where zone = 'z3' and (start_service_time<=0 or status='INACTIVE'),0,90;
ob1.check_until_timeout SELECT CAST(COUNT(*) AS SIGNED) as cnt FROM __all_virtual_clog_stat WHERE is_in_sync = 0 and is_offline=0,0,600;
ob1.check_until_timeout select count(*) from (select a.tenant_id, count(*) from oceanbase.__all_tenant as a left join oceanbase.__all_virtual_server_schema_info as b on a.tenant_id = b.tenant_id where refreshed_schema_version > 1 group by a.tenant_id having count(*) != 3),0,15;
ob1.mysql alter system start zone 'z3';
sleep 2;
ob1.check_until_timeout select count(1) from __all_virtual_server_stat,3,120;
#ob1.z3.check_state_in_congest active;
ob1.check_until_timeout select count(1) from __all_virtual_core_meta_table where role=1 and zone='z1',1,120;
sleep 5;

# 3.7 执行升级后SQL
connection ob_conn1;
set @@session.ob_query_timeout = 600000000;
alter system upgrade virtual schema;
sleep 10;

ob1.upgrade_commond_for_server post;
ob1.mysql alter system end upgrade;
sleep 10;
ob1.mysql set @@ob_log_level='debug';
ob1.mysql alter system run job 'root_inspection';
sleep 10;
ob1.upgrade_check_after;


# 3.8 验证升级后可以清理脏数据
connect (ob_z1_conn,$ipz1,root@sys,,oceanbase,$portz1);
connection ob_z1_conn;
ob1.check_until_timeout select count(*) from __all_table_v2 where table_name = 'xy' and session_id > 0, 1, 30;
ob1.check_until_timeout select count(*) from __all_table_v2 where table_name = 'xy1' and session_id > 0, 1, 30;
## 在z1上随便建一个ctas表触发ctas cleanup task
create table t_trigger as select * from t1;
sleep 70;
ob1.check_until_timeout select count(*) from __all_table_v2 where table_name = 'xy' and session_id > 0, 0, 30;
ob1.check_until_timeout select count(*) from __all_table_v2 where table_name = 'xy1' and session_id > 0, 0, 30;