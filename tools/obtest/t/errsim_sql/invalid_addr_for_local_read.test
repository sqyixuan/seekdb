# owner: xiaochu.yh
# owner group: SQL2
# 

--disable_query_log
ob1=OBI(cluster=1:1,proxy_num=0,init_unit_cpu=1);
ob1.reboot;

ob_connect (ob_conn3, ob1, root@sys,, oceanbase,, USE_OB_CONNECTOR);
connection ob_conn3;

sleep 10;

create table test(c1 int, c2 int);
insert into test values(1,1);

# OB_REPLICA_NOT_READABLE
# 没有注入错误，可以读取数据
select * from test;
ob1.mysql alter system set_tp tp_no = 215, error_code = 4139, frequency = 1;
# 强一致性读数据，会time out
--error 4012
select * from test;
# 弱读，local读取数据的时候，会注入对应的错误，会返回对应的结果
select /*+read_consistency(weak) */ * from test;
# 关闭注入错误
ob1.mysql alter system set_tp tp_no = 215, error_code = 4139, frequency = 0;
select * from test;
# OB_DATA_NOT_UPTODATE
ob1.mysql alter system set_tp tp_no = 215, error_code = 6231, frequency = 1;
# 强一致性读数据，会time out
--error 4012
select * from test;
select /*+read_consistency(weak) */ * from test;
ob1.mysql alter system set_tp tp_no = 215, error_code = 6231, frequency = 0;
select * from test;
