ob1=OBI(cluster=1,proxy_num=0);
ob1.reboot;

--disable_query_log
#set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: mingdou.tmd
# owner group: SQL2
# tags: optimizer
# description:
#
# 测试 dtl drain with blocking channel


ob1.mysql alter system set_tp tp_no = 128, error_code = 4201, frequency = 1;
ob1.mysql alter system set_tp tp_no = 131, error_code = 4200, frequency = 1;
sleep 2;

ob1.mysql create resource unit t1_unit max_cpu=5,min_memory='10G',max_memory='10G',max_disk_size='100G',max_iops=1000,max_session_num=1000;
ob1.mysql create resource pool t1_pool unit = 't1_unit', unit_num = 1, zone_list= ("z1");
ob1.mysql create tenant t1 replica_num 1, resource_pool_list ('t1_pool') set ob_tcp_invited_nodes='%';

let $ip0 = deploy_get_value(ob1.z1.obs0.ip);
let $port0 = deploy_get_value(ob1.z1.obs0.port);
let $mysql_port0 = deploy_get_value(ob1.z1.obs0.mysql_port);

connect(t1_con,$ip0,root@t1,,test, $mysql_port0);
connection t1_con;


create table t1(c1 int,c2 int,c3 int) partition by hash(c1) partitions 7;
create table t2(c1 int,c2 int,c3 int) partition by hash(c1) partitions 5;

insert into t1 values(1,1,1);
insert into t1 values(2,2,2);
insert into t1 values(3,3,3);
insert into t1 values(4,5,4);
insert into t1 values(5,5,5);
insert into t1 values(6,6,6);
insert into t1 values(7,7,7);
insert into t1 values(8,8,8);
insert into t1 values(9,9,9);
insert into t1 values(10,10,10);
insert into t1 values(11,11,11);
insert into t1 values(12,12,12);

insert into t2 values(1,1,1);
##insert into t2 values(2,2,2);
##insert into t2 values(3,3,3);
##insert into t2 values(4,4,4);
##insert into t2 values(5,5,5);
commit;


--result_format 4
--explain_protocol 1

set  ob_query_timeout=200000000;
set  ob_trx_timeout=200000000;
#set ob_enable_trace_log=1;
#set ob_log_level='trace';

explain select /*+ tracing(21,12) parallel(1) leading(b (a c)) use_hash(b (a c))  use_merge(c) pq_distribute(c broadcast none ) pq_distribute((b a) broadcast none)*/d.c2+1,sum(d.c1) from
(select c1 from t1 group by c1)c, (select a.* from (select distinct c3 c1,c2 c2 from t2)a,t2 b where a.c1=b.c1)d where c.c1=d.c1 group by d.c2+1;
select /*+ tracing(21,12) parallel(1) leading(b (a c)) use_hash(b (a c))  use_merge(c) pq_distribute(c broadcast none ) pq_distribute((b a) broadcast none)*/d.c2+1,sum(d.c1) from
(select c1 from t1 group by c1)c, (select a.* from (select distinct c3 c1,c2 c2 from t2)a,t2 b where a.c1=b.c1)d where c.c1=d.c1 group by d.c2+1;

explain select /*+ tracing(9,21,12) parallel(1) leading(b (a c)) use_hash(b (a c))  use_merge(c) pq_distribute(c broadcast none ) pq_distribute((b a) broadcast none)*/d.c2+1,sum(d.c1) from (select c1 from t2 group by c1)c, (select a.* from (select distinct c3 c1,c2 c2 from t1)a,t2 b where a.c1=b.c1)d where c.c1=d.c1 group by d.c2+1;

select /*+ tracing(9,21,12) parallel(1) leading(b (a c)) use_hash(b (a c))  use_merge(c) pq_distribute(c broadcast none ) pq_distribute((b a) broadcast none)*/d.c2+1,sum(d.c1) from (select c1 from t2 group by c1)c, (select a.* from (select distinct c3 c1,c2 c2 from t1)a,t2 b where a.c1=b.c1)d where c.c1=d.c1 group by d.c2+1;

explain select /*+ tracing(9,21,12) parallel(1) leading(b (a c)) use_hash(b (a c))  use_merge(c) pq_distribute(c broadcast none ) pq_distribute((b a) broadcast none)*/d.c2+1,sum(d.c1) from
(select c1 from t2 group by c1)c, (select a.* from (select distinct c3 c1,c2 c2 from t1)a,t2 b where a.c1=b.c1)d where c.c1=d.c1 group by d.c2+1;
select /*+ tracing(9,21,12) parallel(1) leading(b (a c)) use_hash(b (a c))  use_merge(c) pq_distribute(c broadcast none ) pq_distribute((b a) broadcast none)*/d.c2+1,sum(d.c1) from
(select c1 from t2 group by c1)c, (select a.* from (select distinct c3 c1,c2 c2 from t1)a,t2 b where a.c1=b.c1)d where c.c1=d.c1 group by d.c2+1;

explain select /*+ parallel(2) leading(b (a c)) use_hash(b (a c))  use_merge(c) pq_distribute(c broadcast none ) pq_distribute((b a) broadcast none)*/d.c2+1,sum(d.c1) from
(select c1 from t2 group by c1)c, (select a.* from (select distinct c3 c1,c2 c2 from t1)a,t2 b where a.c1=b.c1)d where c.c1=d.c1 group by d.c2+1;
select /*+ parallel(2) leading(b (a c)) use_hash(b (a c))  use_merge(c) pq_distribute(c broadcast none ) pq_distribute((b a) broadcast none)*/d.c2+1,sum(d.c1) from
(select c1 from t2 group by c1)c, (select a.* from (select distinct c3 c1,c2 c2 from t1)a,t2 b where a.c1=b.c1)d where c.c1=d.c1 group by d.c2+1;


ob1.mysql alter system set_tp tp_no = 128, error_code = 0, frequency = 0;
ob1.mysql alter system set_tp tp_no = 131, error_code = 0, frequency = 0;
sleep 2;


