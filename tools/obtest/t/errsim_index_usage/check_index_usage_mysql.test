# owner: yangjiali.yjl
# owner group: opensource
# description: this case is use for check index usage inner table or view.

--disable_result_log
--enable_query_log

ob1=OBI(cluster=1,proxy_num=0,init_unit_cpu=2);
ob1.reboot;
sleep 3;

# test sys tenant
ob_connect(conn_sys, ob1.z1.obs0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);
connection conn_sys;

alter system set _iut_stat_collection_type='ALL';

# insert data
create table t1(c1 int, c2 int);
insert into t1 values (1, 1);

let $cnt=1;
while($cnt < 10)
{
  eval insert into t1 select * from t1;
  inc $cnt;
}

# create single index
create index idx1 on t1(c1);

# use index
eval select c1 from t1;
sleep 5;

# check index usage
--enable_result_log
eval select total_exec_count from oceanbase.__all_index_usage_info;
eval select TOTAL_EXEC_COUNT from oceanbase.DBA_INDEX_USAGE;
--disable_result_log

drop table t1;

# test mysql tenant
eval CREATE RESOURCE UNIT unit MAX_CPU=1, MEMORY_SIZE=1073741824;
eval CREATE RESOURCE POOL pool UNIT = 'unit', UNIT_NUM = 1, zone_list = ('z1');
eval CREATE TENANT mysql RESOURCE_POOL_LIST = ('pool'), primary_zone='z1' set ob_tcp_invited_nodes='%';

ob_connect(conn_mysql, ob1.z1.obs0, root@mysql, , test, , USE_MYSQL_CONNECTOR);
connection conn_mysql;

alter system set _iut_stat_collection_type='ALL';

# insert data
eval create table t1(c1 int, c2 int);
eval insert into t1 values (1, 1);

let $cnt=1;
while($cnt < 10)
{
  eval insert into t1 select * from t1;
  inc $cnt;
}

# create single index
eval create index idx1 on t1(c1);

# use index
eval select c1 from t1;
sleep 5;

# check index usage

--enable_result_log
eval select total_exec_count from oceanbase.__all_index_usage_info;
eval select TOTAL_EXEC_COUNT from oceanbase.DBA_INDEX_USAGE;
--disable_result_log

eval drop index idx1 on t1;
sleep 20;

--enable_result_log
eval select total_exec_count from oceanbase.__all_index_usage_info;
eval select TOTAL_EXEC_COUNT from oceanbase.DBA_INDEX_USAGE;
--disable_result_log

# create multi index
eval create index idx1 on t1(c1);
eval create index idx2 on t1(c2);

# use index
eval select c1 from t1;
eval select c2 from t1;
sleep 5;

--enable_result_log
eval select total_exec_count from oceanbase.__all_index_usage_info;
eval select TOTAL_EXEC_COUNT from oceanbase.DBA_INDEX_USAGE;
--disable_result_log

drop index idx1 on t1;
drop index idx2 on t1;
sleep 20;

--enable_result_log
eval select total_exec_count from oceanbase.__all_index_usage_info;
eval select TOTAL_EXEC_COUNT from oceanbase.DBA_INDEX_USAGE;
--disable_result_log

drop table t1;
