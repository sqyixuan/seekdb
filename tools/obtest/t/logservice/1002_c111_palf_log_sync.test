##########################
# owner : debin.jdb
# owner group: clog
# description: test for palf log sync
# 测试点：
# 1. 多副本日志同步
# 2. 切主
# 3. 宕机重启
##########################

ob1=OBI(cluster=1:1:1, proxy_num=0);

let $extra_conf = "cpu_count=8,memory_limit='16G',system_memory='5G',__min_full_resource_pool_memory='1073741824',cache_wash_threshold='1G',log_disk_size='50G',cluster_id=1";
ob1.z1.obs0.set extra_config=$extra_conf;
ob1.z2.obs0.set extra_config=$extra_conf;
ob1.z3.obs0.set extra_config=$extra_conf;

# case 1. 验证bootstrap
ob1.reboot;
sleep 3;

ob1.mysql alter system set enable_rebalance='false';

# case 2. 验证建租户
let $max_cpu = 4;
let $min_cpu = 1;
let $memory_size = 8589934592;
let $log_disk_size = 2147483648;
let $max_iops = 100000;
let $min_iops = 1024;

ob_connect(conn_sys, ob1.z1.obs0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);
set @@session.ob_query_timeout = 1000000000;

# mysql tenant
eval CREATE RESOURCE UNIT unit_1 MAX_CPU $max_cpu, MIN_CPU $min_cpu, MEMORY_SIZE $memory_size, LOG_DISK_SIZE $log_disk_size, MAX_IOPS $max_iops, MIN_IOPS $min_iops;
eval CREATE RESOURCE POOL pool_1 UNIT = 'unit_1', UNIT_NUM = 1, zone_list = ('z1', 'z2', 'z3');;
eval CREATE TENANT mysql RESOURCE_POOL_LIST = ('pool_1'), primary_zone='z1;z2;z3' set ob_tcp_invited_nodes='%';

source include/check_schema_sync.inc;

let $mysql_tenant_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name = 'mysql', tenant_id, 1);

# case 3. 验证mysql租户下表的DML/SELECT
ob_connect(conn_mysql, ob1.z1.obs0, root@mysql, , test, , USE_MYSQL_CONNECTOR);
# wait leader takeover
sleep 3;
create table t1 (c1 int);
source include/check_schema_sync.inc;
insert into t1 values (1), (2), (3), (4), (5);
select * from t1;
select count(*) from t1;

# case 4. 验证mysql租户下的switch replica leader
ob_connect(conn_sys, ob1.z1.obs0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);
connection conn_sys;

let $leader_ip_port=deploy_get_value(ob1.select select concat(svr_ip,':',svr_port) as host from __all_virtual_ls_meta_table where tenant_id = $mysql_tenant_id and ls_id = 1001 and role = 1, host, 1);
let $leader_obs=deploy_get_value(ob1.get_obs_by_addr $leader_ip_port);

# 重启leader
$leader_obs.force_stop;
sleep 10;
$leader_obs.nstart;
sleep 20;
ob1.check_until_timeout select count(*) from __all_virtual_ls_meta_table where tenant_id = $mysql_tenant_id and ls_id = 1001 and role = 1, 1, 120;
source include/check_schema_sync.inc;
# 写入数据
ob_connect(conn_mysql, ob1.z1.obs0, root@mysql, , test, , USE_MYSQL_CONNECTOR);
insert into t1 values (6), (7), (8), (9), (10);
select count(*) from t1;

let $leader_svr_ip = deploy_get_value(ob1.select select svr_ip from __all_virtual_ls_meta_table where tenant_id = $mysql_tenant_id and ls_id = 1001 and role = 1, svr_ip, 1);
let $leader_svr_port = deploy_get_value(ob1.select select svr_port from __all_virtual_ls_meta_table where tenant_id = $mysql_tenant_id and ls_id = 1001 and role = 1, svr_port, 1);
let $follower1_svr_ip = deploy_get_value(ob1.select select svr_ip from __all_virtual_ls_meta_table where tenant_id = $mysql_tenant_id and ls_id = 1001 and role = 2 order by svr_ip, svr_port limit 1, svr_ip, 1);
let $follower1_svr_port = deploy_get_value(ob1.select select svr_port from __all_virtual_ls_meta_table where tenant_id = $mysql_tenant_id and ls_id = 1001 and role = 2 order by svr_ip, svr_port limit 1, svr_port, 1);

# 切主
ob_connect(conn_sys, ob1.z1.obs0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);
connection conn_sys;
--disable_query_log
eval select count(*) from __all_virtual_ls_meta_table where tenant_id = '$mysql_tenant_id' and svr_ip = '$follower1_svr_ip' and svr_port='$follower1_svr_port' and ls_id = 1001 and role = 1;
sleep 1;
eval alter system switch replica leader ls=1001 server='$follower1_svr_ip:$follower1_svr_port' tenant='mysql';
ob1.check_until_timeout select count(*) from __all_virtual_ls_meta_table where tenant_id = '$mysql_tenant_id' and svr_ip = '$follower1_svr_ip' and svr_port='$follower1_svr_port' and ls_id = 1001 and role = 1, 1, 30;
eval select count(*) from __all_virtual_ls_meta_table where tenant_id = '$mysql_tenant_id' and svr_ip = '$follower1_svr_ip' and svr_port='$follower1_svr_port' and ls_id = 1001 and role = 1;
--enable_query_log

# 写入数据
ob_connect(conn_mysql, ob1.z1.obs0, root@mysql, , test, , USE_MYSQL_CONNECTOR);
insert into t1 values (6), (7), (8), (9), (10);
select count(*) from t1;

# switch leader
ob_connect(conn_sys, ob1.z1.obs0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);
connection conn_sys;
--disable_query_log
eval alter system switch replica leader ls=1001 server='$leader_svr_ip:$leader_svr_port' tenant='mysql';
ob1.check_until_timeout select count(*) from __all_virtual_ls_meta_table where tenant_id = '$mysql_tenant_id' and svr_ip = '$leader_svr_ip' and svr_port='$leader_svr_port' and ls_id = 1001 and role = 1, 1, 30;
eval select count(*) from __all_virtual_ls_meta_table where tenant_id = '$mysql_tenant_id' and svr_ip = '$leader_svr_ip' and svr_port='$leader_svr_port' and ls_id = 1001 and role = 1;
--enable_query_log

# 写入数据
ob_connect(conn_mysql, ob1.z1.obs0, root@mysql, , test, , USE_MYSQL_CONNECTOR);
insert into t1 values (6), (7), (8), (9), (10);
select count(*) from t1;

# case 5. 验证重启之后数据是否完整
ob1.z2.obs0.force_stop;
sleep 10;
ob1.z2.obs0.nstart;
sleep 20;
ob1.check_until_timeout select count(*) from __all_virtual_ls_meta_table where tenant_id = $mysql_tenant_id and ls_id = 1001 and role = 1, 1, 120;
source include/check_schema_sync.inc;

ob1.z3.obs0.force_stop;
sleep 10;
ob1.z3.obs0.nstart;
sleep 20;
ob1.check_until_timeout select count(*) from __all_virtual_ls_meta_table where tenant_id = $mysql_tenant_id and ls_id = 1001 and role = 1, 1, 120;
source include/check_schema_sync.inc;

ob1.z1.obs0.force_stop;
sleep 10;
ob1.z1.obs0.nstart;
sleep 20;
ob1.check_until_timeout select count(*) from __all_virtual_ls_meta_table where tenant_id = $mysql_tenant_id and ls_id = 1001 and role = 1, 1, 120;
source include/check_schema_sync.inc;

# check row count
ob_connect(conn_mysql, ob1.z1.obs0, root@mysql, , test, , USE_MYSQL_CONNECTOR);
select count(*) from t1;
