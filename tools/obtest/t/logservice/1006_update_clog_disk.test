##########################
# owner : zjf225077
# owner group: CLOG
# description: test update clog disk
# 测试点：
##########################

ob1=OBI(cluster=1:1:2, proxy_num=0);

let $extra_conf = "cpu_count=8,memory_limit='20G',system_memory='5G',__min_full_resource_pool_memory='1073741824',cache_wash_threshold='1G',log_disk_size=100G";
ob1.z1.obs0.set extra_config=$extra_conf;
ob1.z2.obs0.set extra_config=$extra_conf;
ob1.z3.obs0.set extra_config=$extra_conf;

# case 1. 验证bootstrap
ob1.reboot;
sleep 3;

# case 2. 验证建租户
let $cpu = 1;
let $memory = '3G';
let $min_memory = 1073741824;
let $disk = 536870912;
let $iops = 100000;
let $session = 64;

ob_connect(conn_sys, ob1.z1.obs0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);
set @@session.ob_query_timeout = 1000000000;
# mysql tenant
eval CREATE RESOURCE UNIT unit_1 MAX_CPU $cpu, MEMORY_SIZE $memory, LOG_DISK_SIZE '4G';
eval CREATE RESOURCE POOL pool_1 UNIT = 'unit_1', UNIT_NUM = 1, zone_list = ('z1', 'z2', 'z3');;
eval CREATE TENANT clog_update_disk RESOURCE_POOL_LIST = ('pool_1'), primary_zone='z1;z2;z3' set ob_tcp_invited_nodes='%';

source include/check_schema_sync.inc;

let $mysql_tenant_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name = 'clog_update_disk', tenant_id, 1);

# get servers' addr in z1 and z2
let $z1_dst_ip0 = deploy_get_value(ob1.z1.obs0.ip);
let $z1_dst_port0 = deploy_get_value(ob1.z1.obs0.port);
let $z1_dst0 = $z1_dst_ip0:$z1_dst_port0;
let $z2_dst_ip0 = deploy_get_value(ob1.z2.obs0.ip);
let $z2_dst_port0 = deploy_get_value(ob1.z2.obs0.port);
let $z2_dst0 = $z2_dst_ip0:$z2_dst_port0;

# get servers' addr in z3
let $z3_dst_ip0 = deploy_get_value(ob1.z3.obs0.ip);
let $z3_dst_ip1 = deploy_get_value(ob1.z3.obs1.ip);
let $z3_dst_port0 = deploy_get_value(ob1.z3.obs0.port);
let $z3_dst_port1 = deploy_get_value(ob1.z3.obs1.port);
let $z3_dst0 = $z3_dst_ip0:$z3_dst_port0;
let $z3_dst1 = $z3_dst_ip1:$z3_dst_port1;

# get clog_update_disk 's unit info in z3
let $tenant_id = deploy_get_value(ob1.select SELECT tenant_id FROM oceanbase.__all_tenant WHERE tenant_name = "clog_update_disk", tenant_id, 1);
let $resource_pool_id = deploy_get_value(ob1.select SELECT resource_pool_id FROM oceanbase.__all_resource_pool WHERE tenant_id = $tenant_id, resource_pool_id, 1);
let $unit_id = deploy_get_value(ob1.select SELECT unit_id FROM oceanbase.__all_unit WHERE resource_pool_id = $resource_pool_id AND zone = 'z3', unit_id, 1);
let $ip = deploy_get_value(ob1.select SELECT svr_ip FROM oceanbase.__all_unit WHERE unit_id = $unit_id, svr_ip, 1);
let $port = deploy_get_value(ob1.select SELECT svr_port FROM oceanbase.__all_unit WHERE unit_id = $unit_id, svr_port, 1);
let $z3_cur = $ip:$port;

# create table and insert data
ob_connect(conn_mysql, ob1.z1.obs0, root@clog_update_disk, , test, , USE_MYSQL_CONNECTOR);
connection conn_mysql;
create table t1_no_pk (c1 int);
insert into t1_no_pk values (1), (2), (3);
select * from t1_no_pk;
update t1_no_pk set c1=c1+10;
select * from t1_no_pk;
create table t1_pk (c1 int primary key);
insert into t1_pk values (1), (2), (3);
select * from t1_pk;
update t1_pk set c1=c1+10;
select * from t1_pk;
create table t1_part (c1 int primary key) partition by hash(c1) partitions 4;
insert into t1_part values (1), (2), (3), (4);
select * from t1_part;
update t1_part set c1=c1+10;
select * from t1_part;
connection conn_sys;
alter system minor freeze tenant clog_update_disk;
ob1.z1.obs0.check_log_until_success -c "succeed to release head data memtable";
ob1.z3.obs1.check_log_until_success -c "succeed to release head data memtable";
sleep 10;
connection conn_mysql;
insert into t1_no_pk values (4), (5), (6);
insert into t1_no_pk values (7), (8), (9);
insert into t1_no_pk values (10), (11), (12);
insert into t1_pk values (4), (5), (6);
insert into t1_pk values (7), (8), (9);
insert into t1_pk values (10);
insert into t1_part values (5), (6), (7), (8);
insert into t1_part values (9), (10), (21), (22);
connection conn_sys;
alter system minor freeze tenant clog_update_disk;
ob1.z1.obs0.check_log_until_success -c "succeed to release head data memtable";
ob1.z3.obs1.check_log_until_success -c "succeed to release head data memtable";
sleep 10;

--echo "prepare finished"

ob1.mysql alter tenant sys set primary_zone = "z1";
ob1.check_until_timeout select count(*) from __all_virtual_core_meta_table where role = 1 and zone = 'z1', 1, 60;
ob1.mysql alter tenant sys set primary_zone = "z2";
ob1.check_until_timeout select count(*) from __all_virtual_core_meta_table where role = 1 and zone = 'z2', 1, 60;
ob1.mysql alter tenant sys set primary_zone = "z1";
ob1.check_until_timeout select count(*) from __all_virtual_core_meta_table where role = 1 and zone = 'z1', 1, 60;

#######################################################################
#                   CASE  1        migrate unit
#######################################################################
connection conn_sys;

# 修改迁移目的端的log_disk_size
if ($z3_cur != $z3_dst0)
{
  --disable_query_log
  sleep 2;
  eval ALTER RESOURCE UNIT unit_1 LOG_DISK_SIZE='12G';
  sleep 2;
  ob1.z3.obs0.mysql alter system set log_disk_size = '10G';
  sleep 12;
  --disable_result_log
  --error 4624
  eval ALTER SYSTEM MIGRATE UNIT $unit_id DESTINATION "$z3_dst0";
}
if ($z3_cur != $z3_dst1)
{
  --disable_query_log
  eval ALTER RESOURCE UNIT $unit_id LOG_DISK_SIZE='12G';
  sleep 2;
  ob1.z3.obs1.mysql alter system set log_disk_size = '10G';
  sleep 12;
  --error 4624
  eval ALTER SYSTEM MIGRATE UNIT $unit_id DESTINATION "$z3_dst1";
}

#######################################################################
#                   CASE  2       restart 
#######################################################################
ob1.z3.force_stop;
ob1.z3.start;
source include/check_schema_sync_for_restart.inc;
connection conn_sys;
if ($z3_cur != $z3_dst0)
{
  --disable_query_log
  eval ALTER RESOURCE UNIT unit_1 LOG_DISK_SIZE='12G';
  sleep 2;
  ob1.z3.obs0.mysql alter system set log_disk_size = '10G';
  sleep 12;
  --disable_result_log
  --error 4624
  eval ALTER SYSTEM MIGRATE UNIT $unit_id DESTINATION "$z3_dst0";
}
if ($z3_cur != $z3_dst1)
{
  --disable_query_log
  eval ALTER RESOURCE UNIT unit_1 LOG_DISK_SIZE='12G';
  sleep 2;
  ob1.z3.obs0.mysql alter system set log_disk_size = '10G';
  sleep 12;
  --error 4624
  eval ALTER SYSTEM MIGRATE UNIT $unit_id DESTINATION "$z3_dst1";
}
