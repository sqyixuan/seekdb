# Notice: 由于该case运行时间过长,已被拆分为1106,1107,1108三个case.
#
# 测试场景2F1A：
# 1. 启动仲裁服务/server;
# 2. 添加仲裁服务到ob集群;
# 3. 建租户时指定开启仲裁服务；
# 4. 为sys租户开启仲裁服务;
# 5. kill followr触发降级;
# 6. 建表、写入数据;
# 7. 启动follower，测试升级;
#
ob1=OBI(cluster=1:2:1:1, proxy_num=0, asvr_num=2);

let $extra_conf = "cpu_count=8,memory_limit='20G',system_memory='5G',_hidden_sys_tenant_memory='1G',__min_full_resource_pool_memory='1073741824',cache_wash_threshold='1G',log_disk_size='30G'";
ob1.z1.obs0.set extra_config=$extra_conf;
ob1.z2.obs0.set extra_config=$extra_conf;
ob1.z2.obs1.set extra_config=$extra_conf;
ob1.z3.obs0.set extra_config=$extra_conf;
ob1.z4.obs0.set extra_config=$extra_conf;

let $arb_extra_conf = "ob_startup_mode=arbitration,cpu_count=1,memory_limit=1G,__easy_memory_limit=256M";
ob1.asvr0.set extra_config=$arb_extra_conf;
ob1.asvr1.set extra_config=$arb_extra_conf;

ob1.asvr1.set status=disable;
# bootstrap
ob1.reboot;
sleep 3;

ob1.asvr1.set status=enable;
ob1.asvr1.reboot;

ob1.mysql alter system set ls_gc_delay_time='10s' tenant=sys;
ob1.mysql alter system set ls_gc_delay_time='10s' tenant=all_user;
ob1.mysql alter system set ls_gc_delay_time='10s' tenant=all_meta;
ob1.mysql alter system set debug_sync_timeout = '1000s';
ob1.mysql ALTER SYSTEM SET enable_rebalance = 'false';
ob1.mysql ALTER SYSTEM SET enable_rereplication = 'true';
ob_connect(conn_sys, ob1.z1.obs0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);
# 启动仲裁server
# 获取仲裁server的ip、port
let $arb_svr_ip= deploy_get_value(ob1.asvr0.ip);
let $arb_svr_port= deploy_get_value(ob1.asvr0.port);
let $arb_svr_ip_2= deploy_get_value(ob1.asvr1.ip);
let $arb_svr_port_2= deploy_get_value(ob1.asvr1.port);
# add arbitration service, mytest.jar已经为本集群做了这一步
# check arbitration service add success
ob1.check_until_timeout select count(*) from DBA_OB_ARBITRATION_SERVICE where arbitration_service = "$arb_svr_ip:$arb_svr_port", 1, 30;
ob1.check_until_timeout select count(*) from __all_virtual_arbitration_service_status, 5, 10;

# 验证添加非法仲裁服务, 预期返回 OB_INVALID_ARGUMENT
--echo test case for add arb service with invalid argument, expect OB_INVALID_ARGUMENT 1210
--error 1210
eval alter system add arbitration service "aaa";

# 验证已有仲裁服务的场景下再次添加仲裁服务, 预期返回 OB_ARBITRATION_SERVICE_ALREADY_EXIST
--disable_query_log
--echo test case for add arb service again, expect OB_ARBITRATION_SERVICE_ALREADY_EXIST 4748
--error 4748
eval alter system add arbitration service "$arb_svr_ip:$arb_svr_port";

--enable_query_log
# 验证移除非法仲裁服务, 预期返回 OB_INVALID_ARGUMENT
--echo test case for remove arb service with invalid argument, expect OB_INVALID_ARGUMENT 1210
--error 1210
eval alter system remove arbitration service "aaa";

# 验证移除一个不存在的仲裁服务，预期返回 OB_OP_NOT_ALLOW
--echo test case for remove arb service not exist, expect OB_OP_NOT_ALLOW 4179
--error 4179
eval alter system remove arbitration service "1.1.1.1:1";

--disable_query_log
# 验证删除仲裁服务, 注入清除持久化信息的错误，预期成功，但有warn信息输出
ob1.mysql alter system set_tp tp_name = ERRSIM_REMOVE_CLUSTER_INFO_ERROR, error_code = 4016, frequency = 1;
--echo test case for remove arb service, expect OB_SUCCESS
ob1.mysql alter system remove arbitration service "$arb_svr_ip:$arb_svr_port";
ob1.check_until_timeout select count(*) from DBA_OB_ARBITRATION_SERVICE, 0, 10;
ob1.check_until_timeout select count(*) from __all_virtual_arbitration_service_status, 0, 20;
ob1.mysql alter system set_tp tp_name = ERRSIM_REMOVE_CLUSTER_INFO_ERROR, error_code = 4016, frequency = 0;

# 验证在没有仲裁服务的情况下删除仲裁服务，预期返回 OB_OP_NOT_ALLOW
--echo test case for remove arb service without arb service, expect OB_ARBITRATION_SERVICE_NOT_EXIST 4747
--error 4747
eval alter system remove arbitration service "$arb_svr_ip:$arb_svr_port";

--enable_query_log
# 验证在没有仲裁服务的情况下，尝试开启租户仲裁服务，预期返回 OB_OP_NOT_ALLOW
--echo test case for enable tenant arb service without arb service, expect OB_OP_NOT_ALLOW 4179
--error 4179
eval alter tenant sys enable_arbitration_service = true;

# 验证错误注入的情况下，持久化集群信息时，添加仲裁服务的行为, 预期返回 4016
--disable_query_log
ob1.mysql alter system set_tp tp_name = ERRSIM_ADD_CLUSTER_INFO_ERROR, error_code = 4016, frequency = 1;
--echo test errsim when persist cluster info to arbitration server
--error 4016
eval alter system add arbitration service "$arb_svr_ip:$arb_svr_port";
ob1.mysql alter system set_tp tp_name = ERRSIM_ADD_CLUSTER_INFO_ERROR, error_code = 4016, frequency = 0;

# 重新add arbitration service
eval alter system add arbitration service "$arb_svr_ip:$arb_svr_port";

# 验证错误注入的情况下，持久化集群信息时，替换仲裁服务的行为，预期返回 4016
ob1.mysql alter system set_tp tp_name = ERRSIM_ADD_CLUSTER_INFO_ERROR, error_code = 4016, frequency = 1;
--error 4016
eval alter system replace arbitration service "$arb_svr_ip:$arb_svr_port" with "$arb_svr_ip_2:$arb_svr_port_2";
ob1.mysql alter system set_tp tp_name = ERRSIM_ADD_CLUSTER_INFO_ERROR, error_code = 4016, frequency = 0;

#replace arbitration service when all tenant with disabled arb status
ob1.mysql alter system replace arbitration service "$arb_svr_ip:$arb_svr_port" with "$arb_svr_ip_2:$arb_svr_port_2";
ob1.check_until_timeout select count(*) from DBA_OB_ARBITRATION_SERVICE where previous_arbitration_service != "", 0, 120;
ob1.check_until_timeout select count(*) from DBA_OB_ARBITRATION_SERVICE where arbitration_service = "$arb_svr_ip_2:$arb_svr_port_2", 1, 120;
#验证replace命令发给非RS机器时，remove_cluster_info动作不会报错
ob1.mysql alter tenant sys primary_zone = "z1";
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id = 1 and role = "LEADER" and zone = "z1", 1, 30;
ob1.z3.obs0.mysql alter system replace arbitration service "$arb_svr_ip_2:$arb_svr_port_2" with "$arb_svr_ip:$arb_svr_port";
ob1.z3.obs0.mysql alter system replace arbitration service "$arb_svr_ip:$arb_svr_port" with "$arb_svr_ip_2:$arb_svr_port_2";

# 验证错误注入清除持久化信息时，替换仲裁服务成功，但是报warning的行为
ob1.mysql alter system set_tp tp_name = ERRSIM_REMOVE_CLUSTER_INFO_ERROR, error_code = 4016, frequency = 1;
ob1.mysql alter system replace arbitration service "$arb_svr_ip_2:$arb_svr_port_2" with "$arb_svr_ip:$arb_svr_port";
ob1.check_until_timeout select count(*) from DBA_OB_ARBITRATION_SERVICE where previous_arbitration_service != "", 0, 120;
ob1.check_until_timeout select count(*) from DBA_OB_ARBITRATION_SERVICE where arbitration_service = "$arb_svr_ip:$arb_svr_port", 1, 120;
ob1.mysql alter system set_tp tp_name = ERRSIM_REMOVE_CLUSTER_INFO_ERROR, error_code = 4016, frequency = 0;
--enable_query_log

let $sys_tenant_id=1;
set @@session.ob_query_timeout = 1000000000;
# create mysql tenant (2F1A)
eval CREATE RESOURCE UNIT unit_1 MAX_CPU 1, MEMORY_SIZE='2G', LOG_DISK_SIZE='6G';
eval CREATE RESOURCE POOL pool_1 UNIT = 'unit_1', UNIT_NUM = 1, zone_list = ('z1', 'z2', 'z3', 'z4');

eval CREATE TENANT mysql RESOURCE_POOL_LIST = ('pool_1'),  locality='F@z1, F@z2', primary_zone='RANDOM', enable_arbitration_service=true set ob_tcp_invited_nodes='%';

ob1.mysql alter system set ls_gc_delay_time='10s' tenant=sys;
ob1.mysql alter system set ls_gc_delay_time='10s' tenant=all_user;
ob1.mysql alter system set ls_gc_delay_time='10s' tenant=all_meta;

# source include/check_schema_sync.inc;

let $mysql_tenant_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name = 'mysql', tenant_id, 1);

# check arbitration member exist for tenant's ls
ob1.check_until_timeout select count(*) from __all_virtual_log_stat where tenant_id=$mysql_tenant_id and arbitration_member like "%$arb_svr_ip:$arb_svr_port%", 6, 30;

# 验证仲裁租户的locality变更
let $z3_dst_ip0 = deploy_get_value(ob1.z3.obs0.ip);
let $z4_dst_ip0 = deploy_get_value(ob1.z4.obs0.ip);
let $z3_dst_port0 = deploy_get_value(ob1.z3.obs0.port);
let $z4_dst_port0 = deploy_get_value(ob1.z4.obs0.port);
let $z3_dst0 = $z3_dst_ip0:$z3_dst_port0;
let $z4_dst0 = $z4_dst_ip0:$z4_dst_port0;
eval ALTER TENANT mysql set locality = 'F@z1, F@z2, F@z3, F@z4';
ob1.check_until_timeout select count(*) from oceanbase.DBA_OB_TENANTS where tenant_id = $mysql_tenant_id and previous_locality != '', 1, 30;
--echo test case for disable tenant arb service when locality is changing, expect OB_OP_NOT_ALLOW 4179
--error 4179
eval alter tenant mysql enable_arbitration_service = false;

# 验证mysql租户locality 2变4
ob1.mysql set ob_global_debug_sync = 'now signal signal_for_locality';
ob1.check_until_timeout select count(*) = 0 from oceanbase.DBA_OB_TENANTS where previous_locality != '', 1, 120;
let $mysql_tenant_ls_cnt = 5;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_ls_status where tenant_id = $mysql_tenant_id, $mysql_tenant_ls_cnt, 100;
ob1.check_until_timeout select count(*) = $mysql_tenant_ls_cnt from CDB_OB_LS_LOCATIONS where role = 'LEADER' and tenant_id = $mysql_tenant_id and (member_list like '%$z3_dst0%' and member_list like '%$z4_dst0%'), 1, 10;
ob1.check_until_timeout select count(*) = 1 from CDB_OB_LS_LOCATIONS where role = 'LEADER' and tenant_id = $mysql_tenant_id -1 and (member_list like '%$z3_dst0%' and member_list like '%$z4_dst0%'), 1, 10;

# mysql租户locality 4变2
eval ALTER TENANT mysql set locality = 'F@z1, F@z2';
ob1.check_until_timeout select count(*) = 0 from oceanbase.DBA_OB_TENANTS where previous_locality != '', 1, 120;
ob1.check_until_timeout select count(*) from __all_virtual_ls_status where tenant_id=$mysql_tenant_id and status = 'NORMAL', 3, 100;
ob1.check_until_timeout select count(*) from __all_virtual_ls_status where tenant_id=$mysql_tenant_id and status != 'NORMAL', 0, 100;
let $mysql_tenant_ls_cnt = 3;
ob1.check_until_timeout select count(*) = $mysql_tenant_ls_cnt from oceanbase.CDB_OB_LS_LOCATIONS where role = 'LEADER' and tenant_id = $mysql_tenant_id and (member_list not like '%$z3_dst0%' and member_list not like '%$z4_dst0%'), 1, 40;
ob1.check_until_timeout select count(*) = 1 from oceanbase.CDB_OB_LS_LOCATIONS where role = 'LEADER' and tenant_id = $mysql_tenant_id -1 and (member_list not like '%$z3_dst0%' and member_list not like '%$z4_dst0%'), 1, 10;


# 验证locality变更过程中开启租户仲裁服务， 预期返回 OB_OP_NOT_ALLOW
ob1.mysql set ob_global_debug_sync = 'BEFORE_SEND_DRTASK_RPC wait_for signal_for_sys';
eval ALTER TENANT sys set locality = 'F@z1, F@z2, F@z3';
ob1.check_until_timeout select count(*) from oceanbase.DBA_OB_TENANTS where tenant_id = $sys_tenant_id and previous_locality != '', 1, 30;
--echo test case for enable tenant arb service when locality is changing, expect OB_OP_NOT_ALLOW 4179
--error 4179
eval alter tenant sys enable_arbitration_service = true;
ob1.mysql set ob_global_debug_sync = 'now signal signal_for_sys';
ob1.check_until_timeout select count(*) from oceanbase.DBA_OB_TENANTS where tenant_id = $sys_tenant_id and previous_locality IS NULL, 1, 120;
eval ALTER TENANT sys set locality = 'F@z1, F@z2, F@z3, F@z4';
ob1.check_until_timeout select count(*) = 0 from oceanbase.DBA_OB_TENANTS where previous_locality != '', 1, 120;
ob1.check_until_timeout select count(*) = 1 from oceanbase.CDB_OB_LS_LOCATIONS where role = 'LEADER' and tenant_id = $sys_tenant_id and (member_list like '%$z3_dst0%' and member_list like '%$z4_dst0%'), 1, 30;

ob_connect(conn_mysql, ob1.z1.obs0, root@mysql, , test, , USE_MYSQL_CONNECTOR);
# wait leader takeover
sleep 1;

# create tenant(4F1A)
connection conn_sys;
eval CREATE RESOURCE POOL pool_2 UNIT = 'unit_1', UNIT_NUM = 1, zone_list = ('z1', 'z2', 'z3', 'z4');

eval CREATE TENANT mysql_2 RESOURCE_POOL_LIST = ('pool_2'),  locality='F@z1, F@z2, F@z3, F@z4', primary_zone='RANDOM', enable_arbitration_service=true set ob_tcp_invited_nodes='%';

ob1.mysql alter system set ls_gc_delay_time='10s' tenant=sys;
ob1.mysql alter system set ls_gc_delay_time='10s' tenant=all_user;
ob1.mysql alter system set ls_gc_delay_time='10s' tenant=all_meta;

# source include/check_schema_sync.inc;

let $mysql_2_tenant_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name = 'mysql_2', tenant_id, 1);

# check arbitration member exist for tenant's ls
ob1.check_until_timeout select count(*) from __all_virtual_log_stat where tenant_id=$mysql_2_tenant_id and arbitration_member like "%$arb_svr_ip:$arb_svr_port%", 20, 30;

let $sys_tenant_id=1;
connection conn_sys;
# test enable tenant arb service
ob1.mysql set ob_global_debug_sync = 'BEFORE_EXECUTE_ARB_REPLICA_TASK wait_for signal_to_add';
eval alter tenant sys enable_arbitration_service = true;
# wait add arb replica finished
ob1.check_until_timeout select count(*) from CDB_OB_LS_ARB_REPLICA_TASKS where tenant_id = $sys_tenant_id and task_type = 'ADD REPLICA', 1, 20;
ob1.check_until_timeout select count(*) from DBA_OB_LS_ARB_REPLICA_TASKS where task_type = 'ADD REPLICA', 1, 20;
ob1.mysql set ob_global_debug_sync = 'now signal signal_to_add';
ob1.check_until_timeout select count(*) from CDB_OB_LS_ARB_REPLICA_TASK_HISTORY where tenant_id = $sys_tenant_id and task_type = 'ADD REPLICA' and execute_result like '%ret:0%', 1, 10;
ob1.check_until_timeout select count(*) from DBA_OB_LS_ARB_REPLICA_TASK_HISTORY where task_type = 'ADD REPLICA' and execute_result like '%ret:0%', 1, 10;
ob1.check_until_timeout select count(*) from __all_tenant where tenant_id=$sys_tenant_id and arbitration_service_status='ENABLED', 1, 60;
ob1.check_until_timeout select count(*) from __all_virtual_log_stat where tenant_id=$sys_tenant_id and arbitration_member like "%$arb_svr_ip:$arb_svr_port%", 4, 30;
# change sys tenant to 2F
eval alter tenant sys set locality = 'F@z1, F@z2';
ob1.check_until_timeout select count(*) from __all_tenant where previous_locality != '', 0, 60;
# test disable tenant arb service
ob1.mysql set ob_global_debug_sync = 'BEFORE_EXECUTE_ARB_REPLICA_TASK wait_for signal_to_remove';
eval alter tenant sys enable_arbitration_service = false;
# wait remove arb replica finished
ob1.check_until_timeout select count(*) from CDB_OB_LS_ARB_REPLICA_TASKS where tenant_id = $sys_tenant_id and task_type = 'REMOVE REPLICA', 1, 20;
ob1.check_until_timeout select count(*) from DBA_OB_LS_ARB_REPLICA_TASKS where task_type = 'REMOVE REPLICA', 1, 20;
ob1.mysql set ob_global_debug_sync = 'now signal signal_to_remove';
ob1.check_until_timeout select count(*) from __all_tenant where tenant_id=$sys_tenant_id and arbitration_service_status='DISABLED', 1, 60;
ob1.check_until_timeout select count(*) from CDB_OB_LS_ARB_REPLICA_TASK_HISTORY where tenant_id = $sys_tenant_id and task_type = 'REMOVE REPLICA' and execute_result like '%ret:0%', 1, 10;
ob1.check_until_timeout select count(*) from DBA_OB_LS_ARB_REPLICA_TASK_HISTORY where task_type = 'REMOVE REPLICA' and execute_result like '%ret:0%', 1, 10;
ob1.check_until_timeout select count(*) from __all_virtual_log_stat where tenant_id=$sys_tenant_id and arbitration_member = '', 2, 30;
# test enable tenant arb service
ob1.mysql set ob_global_debug_sync = 'BEFORE_EXECUTE_ARB_REPLICA_TASK wait_for signal';
eval alter tenant sys enable_arbitration_service = true;
# switch rs
ob1.check_until_timeout select count(*) from CDB_OB_LS_ARB_REPLICA_TASKS where tenant_id = $sys_tenant_id and task_type = 'ADD REPLICA', 1, 20;
ob1.check_until_timeout select count(*) from DBA_OB_LS_ARB_REPLICA_TASKS where task_type = 'ADD REPLICA', 1, 20;
ob1.mysql set ob_global_debug_sync = 'now signal signal';
ob1.check_until_timeout select count(*) from CDB_OB_LS_ARB_REPLICA_TASK_HISTORY where tenant_id = $sys_tenant_id and task_type = 'ADD REPLICA' and execute_result like '%ret:0%', 2, 10;
ob1.check_until_timeout select count(*) from DBA_OB_LS_ARB_REPLICA_TASK_HISTORY where task_type = 'ADD REPLICA' and execute_result like '%ret:0%', 2, 10;
ob1.check_until_timeout select count(*) from __all_tenant where tenant_id=$sys_tenant_id and arbitration_service_status='ENABLED', 1, 60;
# check arbitration member exist for tenant's ls
ob1.check_until_timeout select count(*) from __all_virtual_log_stat where tenant_id=$sys_tenant_id and arbitration_member like "%$arb_svr_ip:$arb_svr_port%", 2, 30;
ob1.mysql alter tenant sys set primary_zone='z1';
ob1.check_until_timeout select count(*) = 1 from oceanbase.DBA_OB_LS_LOCATIONS where role = 'LEADER' and zone = 'z1', 1, 60;

# test disable arb service
eval alter tenant mysql enable_arbitration_service = false;
# wait remove arb replica finished
ob1.check_until_timeout select count(*) from __all_tenant where tenant_id=$mysql_tenant_id and arbitration_service_status='DISABLED', 1, 60;
# test enable arb service
eval alter tenant mysql enable_arbitration_service = true;
ob1.check_until_timeout select count(*) from __all_tenant where tenant_id=$mysql_tenant_id and arbitration_service_status='ENABLED', 1, 60;

let $z1_obs0_ip = deploy_get_value(ob1.z1.obs0.ip);
let $z1_obs0_port = deploy_get_value(ob1.z1.obs0.port);
let $z1_obs0_addr = $z1_obs0_ip:$z1_obs0_port;
let $z2_obs0_ip = deploy_get_value(ob1.z2.obs0.ip);
let $z2_obs0_port = deploy_get_value(ob1.z2.obs0.port);
let $z2_obs0_addr = $z2_obs0_ip:$z2_obs0_port;
let $z2_obs1_ip = deploy_get_value(ob1.z2.obs1.ip);
let $z2_obs1_port = deploy_get_value(ob1.z2.obs1.port);
let $z2_obs1_addr = $z2_obs1_ip:$z2_obs1_port;

# get unit_id
let $resource_pool_id = deploy_get_value(ob1.select SELECT resource_pool_id FROM oceanbase.__all_resource_pool WHERE name = "pool_1", resource_pool_id, 1);
let $unit_id = deploy_get_value(ob1.select SELECT unit_id FROM oceanbase.DBA_OB_UNITS WHERE resource_pool_id = $resource_pool_id AND zone = 'z2', unit_id, 1);
let $ip = deploy_get_value(ob1.select SELECT svr_ip FROM oceanbase.DBA_OB_UNITS WHERE unit_id = $unit_id, svr_ip, 1);
let $port = deploy_get_value(ob1.select SELECT svr_port FROM oceanbase.DBA_OB_UNITS WHERE unit_id = $unit_id, svr_port, 1);
let $mysql_z2_obs_addr = $ip:$port;
# get obs in z2 for mysql tenant
let $mysql_z2_obs=deploy_get_value(ob1.get_obs_by_addr $mysql_z2_obs_addr);

# test arb server restart
ob1.asvr0.force_stop;
sleep 5;
ob1.asvr0.nstart;
sleep 2;

# test degrade
connection conn_sys;

# check z2 has leader
ob1.check_until_timeout select count(1) > 0 from __all_virtual_log_stat where tenant_id=$mysql_tenant_id and role = 'LEADER' and concat(svr_ip,':',svr_port) = '$mysql_z2_obs_addr', 1, 30;
# 将mysql租户的仲裁超时时间调大至600s
ob1.mysql alter system set arbitration_timeout='600s' tenant='mysql';
ob1.check_until_timeout select count(1) from __all_virtual_tenant_parameter_info where name like "%arbitration_timeout%" and tenant_id=$mysql_tenant_id and value != '600s', 0, 30;

# stop z2.obs0
$mysql_z2_obs.force_stop;
ob1.check_until_timeout select count(*) from oceanbase.DBA_OB_SERVERS where zone = 'z2' and status='INACTIVE',1,60;
sleep 5;
connection conn_sys;

# check degrade not happen
sleep 15;

ob1.check_until_timeout select count(*) from __all_virtual_log_stat where tenant_id=$mysql_tenant_id and degraded_list like "%$mysql_z2_obs_addr%", 0, 30;

# 将mysql租户的仲裁超时时间调至30s,验证降级
ob1.mysql alter system set arbitration_timeout='30s' tenant='mysql';
ob1.check_until_timeout select count(1) from __all_virtual_tenant_parameter_info where name like "%arbitration_timeout%" and tenant_id=$mysql_tenant_id and value != '30s', 0, 30;

# check degrade result
ob1.check_until_timeout select count(*) from __all_virtual_log_stat where tenant_id=$mysql_tenant_id and degraded_list not like "%$mysql_z2_obs_addr%", 0, 120;
sleep 3;
# check leader exist
ob1.check_until_timeout select count(*) from __all_virtual_log_stat where tenant_id=$mysql_tenant_id and role != 'LEADER', 0, 10;

ob1.check_until_timeout select count(*) from __all_virtual_log_stat where tenant_id=$sys_tenant_id and role = 'LEADER', 1, 60;
ob1.check_until_timeout select count(*)=$mysql_tenant_ls_cnt from __all_virtual_log_stat where tenant_id=$mysql_tenant_id and role = 'LEADER', 1, 60;

# 将mysql租户的仲裁超时时间调回5s
ob1.mysql alter system set arbitration_timeout='5s' tenant='mysql';
ob1.check_until_timeout select count(1) from __all_virtual_tenant_parameter_info where name like "%arbitration_timeout%" and tenant_id=$mysql_tenant_id and value != '5s', 0, 30;

# 验证降级场景下关闭租户仲裁服务， 预期返回 OB_OP_NOT_ALLOW
#--echo test case for disable tenant arb service when log stream in degrading state, expect OB_OP_NOT_ALLOW 4179
#--error 4179
#eval alter tenant mysql enable_arbitration_service = false;

# 验证降级场景下替换仲裁服务地址， 预期返回 OB_OP_NOT_ALLOW
#--disable_query_log
#--echo test case for replace arb service when log stream in degrading state, expect OB_OP_NOT_ALLOW 4179
#--error 4179
#eval alter system replace arbitration service "$arb_svr_ip:$arb_svr_port" with "1.1.1.1:1";
#--enable_query_log

# test migrate unit
connection conn_sys;
ob1.mysql alter system set enable_rebalance = false;
ob1.mysql alter system set enable_rereplication = false;
--disable_query_log
if ($mysql_z2_obs_addr != $z2_obs0_addr)
{
  eval ALTER SYSTEM MIGRATE UNIT $unit_id DESTINATION "$z2_obs0_addr";
  ob1.check_until_timeout SELECT COUNT(*) = 1 FROM oceanbase.__all_rootservice_job WHERE unit_id = $unit_id AND job_type = "MIGRATE_UNIT" AND job_status = "INPROGRESS", 1, 30;
  ob1.check_until_timeout SELECT COUNT(*) = 1 FROM oceanbase.__all_rootservice_job WHERE unit_id = $unit_id AND job_type = "MIGRATE_UNIT" AND job_status = "SUCCESS", 1, 120;
  ob1.check_until_timeout SELECT COUNT(*) AS cnt FROM oceanbase.DBA_OB_UNITS WHERE UNIT_ID = $unit_id AND TENANT_ID = $mysql_tenant_id AND concat(svr_ip,':',svr_port) = '$z2_obs0_addr' , 1, 30;
}
if ($mysql_z2_obs_addr != $z2_obs1_addr)
{
  eval ALTER SYSTEM MIGRATE UNIT $unit_id DESTINATION "$z2_obs1_addr";
  ob1.check_until_timeout SELECT COUNT(*) = 1 FROM oceanbase.__all_rootservice_job WHERE unit_id = $unit_id AND job_type = "MIGRATE_UNIT" AND job_status = "INPROGRESS", 1, 30;
  ob1.check_until_timeout SELECT COUNT(*) = 1 FROM oceanbase.__all_rootservice_job WHERE unit_id = $unit_id AND job_type = "MIGRATE_UNIT" AND job_status = "SUCCESS", 1, 120;
  ob1.check_until_timeout SELECT COUNT(*) AS cnt FROM oceanbase.DBA_OB_UNITS WHERE UNIT_ID = $unit_id AND TENANT_ID = $mysql_tenant_id AND concat(svr_ip,':',svr_port) = '$z2_obs1_addr' , 1, 30;
}
# check degraded_list已经变为空, 因为降级的server已经被迁走
ob1.check_until_timeout select count(*) from __all_virtual_log_stat where tenant_id=$mysql_tenant_id and degraded_list like "%$mysql_z2_obs_addr%", 0, 120;
ob1.mysql ALTER SYSTEM SET enable_rereplication = 'false';

# test upgrade
# start z2.obs0
$mysql_z2_obs.nstart;
sleep 5;
connection conn_sys;
# check upgrade result
ob1.check_until_timeout select count(*) from __all_virtual_log_stat where tenant_id=$mysql_tenant_id and degraded_list like "%$mysql_z2_obs_addr%", 0, 120;
sleep 3;
# check leader exist
ob1.check_until_timeout select count(*)=$mysql_tenant_ls_cnt from __all_virtual_log_stat where tenant_id=$mysql_tenant_id and role = 'LEADER', 1, 60;
ob1.check_until_timeout select count(*)=$mysql_tenant_ls_cnt from __all_virtual_log_stat where tenant_id=$mysql_tenant_id and role = 'FOLLOWER', 1, 60;

# stop z3.obs0
ob1.z3.obs0.force_stop;
ob1.check_until_timeout select count(*) from oceanbase.DBA_OB_SERVERS where zone = 'z3' and status='INACTIVE',1,60;
# stop z4.obs0
ob1.z4.obs0.force_stop;
ob1.check_until_timeout select count(*) from oceanbase.DBA_OB_SERVERS where zone = 'z4' and status='INACTIVE',1,60;
sleep 5;
let $z3_obs0_ip = deploy_get_value(ob1.z3.obs0.ip);
let $z3_obs0_port = deploy_get_value(ob1.z3.obs0.port);
let $z4_obs0_ip = deploy_get_value(ob1.z4.obs0.ip);
let $z4_obs0_port = deploy_get_value(ob1.z4.obs0.port);
connection conn_sys;
# check degrade result
ob1.check_until_timeout select count(*) from __all_virtual_log_stat where tenant_id=$mysql_2_tenant_id and degraded_list like "%$z3_obs0_ip:$z3_obs0_port%", 10, 120;
ob1.check_until_timeout select count(*) from __all_virtual_log_stat where tenant_id=$mysql_2_tenant_id and degraded_list like "%$z4_obs0_ip:$z4_obs0_port%", 10, 120;
sleep 3;
# check leader exist
ob1.check_until_timeout select count(*) from __all_virtual_log_stat where tenant_id=$mysql_2_tenant_id and role = 'LEADER', 5, 10;
# 测试降级后切主
# modify primary zone to trigger leader switch
ob1.mysql alter tenant mysql_2 set primary_zone='z2;z1;z3;z4';
# check leader is at z2
ob1.check_until_timeout select count(*) from __all_virtual_log_stat where tenant_id=$mysql_2_tenant_id and role = 'LEADER' and concat(svr_ip,':',svr_port) not like '$z2_obs0_addr' and concat(svr_ip,':',svr_port) not like '$z2_obs1_addr', 0, 120;
# modify primary zone to trigger leader switch
ob1.mysql alter tenant mysql set primary_zone='z1;z2';
ob1.mysql alter tenant mysql_2 set primary_zone='z1;z2;z3;z4';
# check leader is at z1
ob1.check_until_timeout select count(*) from __all_virtual_log_stat where tenant_id=$mysql_tenant_id and role = 'LEADER' and concat(svr_ip,':',svr_port) not like '$z1_obs0_addr', 0, 120;
ob1.check_until_timeout select count(*) from __all_virtual_log_stat where tenant_id=$mysql_2_tenant_id and role = 'LEADER' and concat(svr_ip,':',svr_port) not like '$z1_obs0_addr', 0, 120;
ob1.check_until_timeout select count(*) from __all_virtual_ls_status where tenant_id=$mysql_tenant_id and status != 'NORMAL', 0, 100;
let $mysql_tenant_ls_cnt = 2;

# start z3, z4
ob1.z3.obs0.nstart;
ob1.z4.obs0.nstart;
sleep 5;
connection conn_sys;
# check upgrade result
ob1.check_until_timeout select count(*) from __all_virtual_log_stat where degraded_list like "%$z3_obs0_ip:$z3_obs0_port%", 0, 120;
ob1.check_until_timeout select count(*) from __all_virtual_log_stat where degraded_list like "%$z4_obs0_ip:$z4_obs0_port%", 0, 120;
sleep 3;
# check leader exist
ob1.check_until_timeout select count(*) from __all_virtual_log_stat where tenant_id=$mysql_2_tenant_id and role = 'LEADER', 2, 120;
ob1.check_until_timeout select count(*) from __all_virtual_log_stat where tenant_id=$mysql_2_tenant_id and role = 'FOLLOWER', 6, 60;

# test stop server
let $unit_id = deploy_get_value(ob1.select SELECT unit_id FROM oceanbase.DBA_OB_UNITS WHERE resource_pool_id = $resource_pool_id AND zone = 'z2', unit_id, 1);
let $ip = deploy_get_value(ob1.select SELECT svr_ip FROM oceanbase.DBA_OB_UNITS WHERE unit_id = $unit_id, svr_ip, 1);
let $port = deploy_get_value(ob1.select SELECT svr_port FROM oceanbase.DBA_OB_UNITS WHERE unit_id = $unit_id, svr_port, 1);
let $mysql_z2_obs_addr = $ip:$port;
# get obs in z2 for mysql tenant
let $mysql_z2_obs=deploy_get_value(ob1.get_obs_by_addr $mysql_z2_obs_addr);

# wait previous migrate task finished
ob1.check_until_timeout select count(*) from __all_virtual_ls_meta_table where tenant_id = $mysql_tenant_id and paxos_replica_number != 2, 0, 60;
ob1.check_until_timeout select count(*) from __all_virtual_log_stat where tenant_id = $mysql_tenant_id and paxos_replica_num != 2, 0, 120;

# check all servers active and in service before stop server
ob1.check_until_timeout select count(*) from __all_server where status='INACTIVE' or start_service_time <= 0, 0, 120;
# stop server
ob1.mysql alter system stop server "$mysql_z2_obs_addr";
# check degrade result
let $total_mysql_tenant_ls_cnt=2*$mysql_tenant_ls_cnt;
ob1.check_until_timeout select count(*)=$total_mysql_tenant_ls_cnt from __all_virtual_log_stat where tenant_id=$mysql_tenant_id and degraded_list like "%$mysql_z2_obs_addr%", 1, 120;
ob1.check_until_timeout select count(*)=$mysql_tenant_ls_cnt from __all_virtual_ha_diagnose where tenant_id=$mysql_tenant_id and palf_role like '%LEADER%' and arb_srv_info like '%STOPPED%', 1, 120;
sleep 2;
# test start server
ob1.mysql alter system start server "$mysql_z2_obs_addr";
# check upgrade result
ob1.check_until_timeout select count(*) from __all_virtual_log_stat where degraded_list like "%$mysql_z2_obs_addr%", 0, 120;
# test replace arbitration server
ob1.mysql alter system replace arbitration service "$arb_svr_ip:$arb_svr_port" with "$arb_svr_ip_2:$arb_svr_port_2";
# check arbitration service replace success
ob1.check_until_timeout select count(*) from DBA_OB_ARBITRATION_SERVICE where previous_arbitration_service != "", 0, 120;
ob1.check_until_timeout select count(*) from DBA_OB_ARBITRATION_SERVICE where arbitration_service = "$arb_svr_ip_2:$arb_svr_port_2", 1, 120;
ob1.check_until_timeout select count(*) from __all_virtual_log_stat where tenant_id=$mysql_tenant_id and arbitration_member like "%$arb_svr_ip:$arb_svr_port%", 0, 120;
ob1.check_until_timeout select count(*) from DBA_OB_ARBITRATION_SERVICE where previous_arbitration_service != "", 0, 120;
sleep 5;

# 验证2F1A部署的永久下线
eval alter system set server_permanent_offline_time = '20s';
ob1.z2.obs0.force_stop;
ob1.z2.obs1.force_stop;
ob1.check_until_timeout select count(*) from oceanbase.DBA_OB_SERVERS where zone = 'z2' and status='INACTIVE',2,60;
ob1.mysql alter system set enable_rebalance = true;
ob1.mysql alter system set enable_rereplication = true;
ob1.check_until_timeout select count(*) from __all_virtual_log_stat where paxos_member_list like "%$z2_obs0_addr%" or paxos_member_list like "%$z2_obs1_addr%", 0, 120;

# 验证永久下线后的重启
ob1.z2.obs0.nstart;
ob1.z2.obs1.nstart;
ob1.check_until_timeout select count(*) from oceanbase.__all_server where zone = 'z2' and status='ACTIVE' and start_service_time > 0,2,600;
ob1.check_until_timeout select count(*) from __all_virtual_log_stat where paxos_member_list not like "%$z2_obs0_addr%" and paxos_member_list not like "%$z2_obs1_addr%",0,240;

# test case 3: enable arbitration service for tenant when some servers are down
connection conn_sys;
eval alter system set server_permanent_offline_time = '1h';
eval CREATE RESOURCE POOL pool_3 UNIT = 'unit_1', UNIT_NUM = 1, zone_list = ('z1', 'z2', 'z3', 'z4');
eval CREATE TENANT mysql_3 RESOURCE_POOL_LIST = ('pool_3'),  locality='F@z1, F@z2, F@z3, F@z4', primary_zone='z1', enable_arbitration_service=true set ob_tcp_invited_nodes='%';

ob1.mysql alter system set ls_gc_delay_time='10s' tenant=sys;
ob1.mysql alter system set ls_gc_delay_time='10s' tenant=all_user;
ob1.mysql alter system set ls_gc_delay_time='10s' tenant=all_meta;

# check arbitration member exist for tenant's ls
let $mysql_3_tenant_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name = 'mysql_3', tenant_id, 1);
ob1.check_until_timeout select count(*) from __all_virtual_log_stat where tenant_id=$mysql_3_tenant_id and arbitration_member like "%$arb_svr_ip_2:$arb_svr_port_2%", 8, 30;

# 在mysql租户降级场景下执行加F变更，验证replica_num不会超限
ob1.z2.obs0.force_stop;
ob1.z2.obs1.force_stop;
ob1.check_until_timeout select count(*) from oceanbase.DBA_OB_SERVERS where zone = 'z2' and status='INACTIVE',2,60;
# check degrade result
ob1.check_until_timeout select count(*) from __all_virtual_log_stat where tenant_id=$mysql_tenant_id and degraded_list like "", 0, 120;
# alter mysql's locality to 4F during degrade state
eval ALTER TENANT mysql set locality = 'F@z1, F@z2, F@z3, F@z4';
ob1.check_until_timeout select count(*) from __all_tenant where previous_locality != '', 0, 120;
# check replica_num is 4
ob1.check_until_timeout select count(*) from __all_virtual_log_stat where tenant_id=$mysql_tenant_id and paxos_replica_num != 4, 0, 30;

ob1.z2.obs0.nstart;
ob1.z2.obs1.nstart;
sleep 3;
ob1.check_until_timeout select count(*) from oceanbase.DBA_OB_SERVERS where zone = 'z2' and status='INACTIVE',0,60;
# wait upgrade finish
ob1.check_until_timeout select count(*) from __all_virtual_log_stat where tenant_id=$mysql_tenant_id and degraded_list not like "", 0, 120;

ob1.z4.obs0.force_stop;
ob1.check_until_timeout select count(*) from oceanbase.DBA_OB_SERVERS where zone = 'z4' and status='INACTIVE',1,60;
sleep 5;
ob1.mysql alter tenant mysql_3 set primary_zone='RANDOM';
# check leader and memberlist, wait 30s for creating new ls and transfer
ob1.check_until_timeout select count(*) from __all_virtual_log_stat where tenant_id=$mysql_3_tenant_id and role = 'LEADER', 5, 30;
ob1.check_until_timeout select count(*) from __all_virtual_log_stat where tenant_id=$mysql_3_tenant_id and paxos_member_list like "%$z3_obs0_ip:$z3_obs0_port%", 15, 120;
# LS:1 and LS:1001 are built before z4 is killed, so the number of replica is 6
ob1.check_until_timeout select count(*) from __all_virtual_log_stat where tenant_id=$mysql_3_tenant_id and paxos_member_list like "%$z4_obs0_ip:$z4_obs0_port%", 6, 120;

ob1.z3.obs0.force_stop;
ob1.check_until_timeout select count(*) from oceanbase.DBA_OB_SERVERS where zone = 'z3' and status='INACTIVE',1,60;
# after killing both z4 and z3, z3 should be degraded
ob1.check_until_timeout select count(*) from __all_virtual_log_stat where tenant_id=$mysql_3_tenant_id and degraded_list like "%$z3_obs0_ip:$z3_obs0_port%", 10, 120;
ob1.check_until_timeout select count(*) from __all_virtual_log_stat where tenant_id=$mysql_3_tenant_id and role = 'LEADER', 5, 10;
ob1.z3.obs0.nstart;
ob1.z4.obs0.nstart;
# check upgrade
ob1.check_until_timeout select count(*) from __all_virtual_log_stat where tenant_id=$mysql_3_tenant_id and degraded_list like "%$z3_obs0_ip:$z3_obs0_port%", 0, 120;
ob1.check_until_timeout select count(*) from __all_virtual_log_stat where tenant_id=$mysql_3_tenant_id and degraded_list like "%$z4_obs0_ip:$z4_obs0_port%", 0, 120;
# check leader
ob1.check_until_timeout select count(*) from __all_virtual_log_stat where tenant_id=$mysql_3_tenant_id and role = 'LEADER', 5, 10;

# 验证删除租户, 检查日志流目录不存在
drop tenant mysql_2;
let $arb_dir=deploy_get_value(ob1.asvr1.workdir);
sleep 8;
ob1.asvr1.sh_p cd $arb_dir; cd ./store/clog; ls | grep cluster_1_tenant_1004 | wc -l;

eval CREATE RESOURCE UNIT unit_4 MAX_CPU 1, MEMORY_SIZE='2G';
eval CREATE RESOURCE POOL pool_4 UNIT = 'unit_4', UNIT_NUM = 1, zone_list = ('z3', 'z4');
eval CREATE TENANT mysql_single_replica RESOURCE_POOL_LIST = ('pool_4'),  locality='F@z3, F@z4', primary_zone='RANDOM', enable_arbitration_service=true set ob_tcp_invited_nodes='%';
let $mysql_single_replica_tenant_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name = 'mysql_single_replica', tenant_id, 1);
drop tenant mysql_single_replica;
sleep 8;
ob1.asvr1.sh_p cd $arb_dir; cd ./store/clog; ls | grep cluster_1_tenant_1008 | wc -l;

# 验证删除仲裁 Server上集群信息, 集群目录预期被删除
eval alter tenant sys enable_arbitration_service = false;
eval alter tenant mysql enable_arbitration_service = false;
eval alter tenant mysql_3 enable_arbitration_service = false;
# wait remove arb replica finished
ob1.check_until_timeout select count(*) from __all_tenant where tenant_id=$mysql_3_tenant_id and arbitration_service_status='DISABLED', 1, 60;
ob1.check_until_timeout select count(*) from __all_tenant where tenant_id=$mysql_tenant_id and arbitration_service_status='DISABLED', 1, 60;
ob1.check_until_timeout select count(*) from __all_tenant where tenant_id=$sys_tenant_id and arbitration_service_status='DISABLED', 1, 60;
eval alter system remove arbitration service "$arb_svr_ip_2:$arb_svr_port_2";
ob1.asvr1.sh_p cd $arb_dir; cd ./store/clog; ls | grep cluster | wc -l;
