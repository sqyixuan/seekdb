# 测试场景：
# case1. 建租户时指定开启仲裁服务
# case2. 建表、写入数据
# case3. 验证升降级, 宕机
# case4. 验证升降级, 断网
# case5. 验证仲裁server宕机重启
# case6. 验证2f1a变4f1a
# case7. 验证迁移复制
# case8. 4f1a变2f1a
# case9. 验证多集群接入
#
ob1=OBI(cluster=2:2:2:2, proxy_num=0, asvr_num=1);

let $extra_conf = "cpu_count=8,memory_limit='20G',system_memory='5G',__min_full_resource_pool_memory='1073741824',cache_wash_threshold='1G',log_disk_size='20G',cluster_id=1";
let $arb_extra_conf = "ob_startup_mode=arbitration,cpu_count=8,memory_limit='20G',system_memory='5G',__min_full_resource_pool_memory='1073741824',cache_wash_threshold='1G',log_disk_size='20G'";

ob1.z1.obs0.set extra_config=$extra_conf;
ob1.z2.obs0.set extra_config=$extra_conf;
ob1.z3.obs0.set extra_config=$extra_conf;
ob1.z4.obs0.set extra_config=$extra_conf;
ob1.z1.obs1.set extra_config=$extra_conf;
ob1.z2.obs1.set extra_config=$extra_conf;
ob1.z3.obs1.set extra_config=$extra_conf;
ob1.z4.obs1.set extra_config=$extra_conf;
# bootstrap
ob1.reboot;
sleep 3;

ob1.mysql alter tenant sys locality='F@z1, F@z2, F@z3';
ob1.check_until_timeout select count(*) from oceanbase.__all_tenant where tenant_name = "sys" and previous_locality != "", 0, 300;
ob_connect(conn_sys1, ob1.z1.obs0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);

# 获取仲裁server的ip、port, 检查仲裁server是否成功运行
let $arb_svr_ip= deploy_get_value(ob1.asvr0.ip);
let $arb_svr_port= deploy_get_value(ob1.asvr0.port);
ob1.check_until_timeout select count(*) from __all_arbitration_service where arbitration_service = "$arb_svr_ip:$arb_svr_port", 1, 30;

# case1. 建租户时指定开启仲裁服务;
let $cpu = 1;
let $memory = 1073741824;
let $min_memory = 1073741824;
let $disk = 536870912;
let $iops = 100000;
let $session = 64;
set @@session.ob_query_timeout = 1000000000;
# create mysql tenant (2F1A)
eval CREATE RESOURCE UNIT unit_1 MAX_CPU 1, MEMORY_SIZE='2G';
eval CREATE RESOURCE POOL pool_1 UNIT = 'unit_1', UNIT_NUM = 1, zone_list = ('z1', 'z2', 'z3', 'z4');
eval CREATE TENANT mysql RESOURCE_POOL_LIST = ('pool_1'),  locality='F@z1, F@z2', primary_zone='RANDOM', enable_arbitration_service=true set ob_tcp_invited_nodes='%';
let $ob1_mysql_tenant_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name = 'mysql', tenant_id, 1);

let $ob1_follower_ip_port1=deploy_get_value(ob1.select select concat(svr_ip,':',svr_port) as host from oceanbase.__all_virtual_ls_meta_table where tenant_id = $ob1_mysql_tenant_id and ls_id =  1001 and role = 2 order by svr_port limit 1, host, 1);
let $ob1_follower_ip1=deploy_get_value(ob1.select select svr_ip from oceanbase.__all_virtual_ls_meta_table where tenant_id = $ob1_mysql_tenant_id and ls_id =  1001 and role = 2 order by svr_port limit 1, svr_ip, 1);
let $ob1_follower_port1=deploy_get_value(ob1.select select svr_port from oceanbase.__all_virtual_ls_meta_table where tenant_id = $ob1_mysql_tenant_id and ls_id = 1001 and role = 2 order by svr_port limit 1, svr_port, 1);
let $ob1_follower1_obs=deploy_get_value(ob1.get_obs_by_addr $ob1_follower_ip_port1);

# check arbitration member exist for tenant's ls
ob1.check_until_timeout select count(*) from __all_virtual_log_stat where tenant_id=$ob1_mysql_tenant_id and arbitration_member like "%$arb_svr_ip:$arb_svr_port%", 6, 30;

let $ob1_leader_ip_port=deploy_get_value(ob1.select select concat(svr_ip,':',svr_port) as host from __all_virtual_ls_meta_table where tenant_id = $ob1_mysql_tenant_id and ls_id =  1001 and role = 1 limit 1, host, 1);
let $ob1_leader_obs =deploy_get_value(ob1.get_obs_by_addr $ob1_leader_ip_port);

# 获取leader、follower位置信息
let $ob1_z1_ip = deploy_get_value(ob1.z1.obs0.ip);
let $ob1_z1_port = deploy_get_value(ob1.z1.obs0.port);
let $ob1_z2_ip = deploy_get_value(ob1.z2.obs0.ip);
let $ob1_z2_port = deploy_get_value(ob1.z2.obs0.port);
let $ob1_z3_ip = deploy_get_value(ob1.z3.obs0.ip);
let $ob1_z3_port = deploy_get_value(ob1.z3.obs0.port);
let $ob1_z4_ip = deploy_get_value(ob1.z4.obs0.ip);
let $ob1_z4_port = deploy_get_value(ob1.z4.obs0.port);

# case2. 建表、写入数据;
ob_connect(conn_mysql, $ob1_leader_obs, root@mysql, , test, , USE_MYSQL_CONNECTOR);
# wait leader takeover
sleep 1;
# 数据准备
create table t1(pk int primary key, c1 int, c2 varchar(20));
# 确认leader已经汇报成功
ob1.check_until_timeout select count(*) from __all_virtual_ls_meta_table where tenant_id = '$ob1_mysql_tenant_id' and ls_id = 1001 and role = 1, 1, 60;
--disable_query_log
let $cnt=10;
while($cnt>0)
{
	eval insert into t1 values($cnt,$cnt,'c$cnt');
	dec $cnt;
}

# case3. 验证升降级, 宕机, 保证server不会被RS永久下线
ob1.mysql alter system set server_permanent_offline_time = '3600s';
# case3.1 宕机follower1，验证降级
$ob1_follower1_obs.force_stop;
ob_connect(conn_mysql, $ob1_leader_obs, root@mysql, , test, , USE_MYSQL_CONNECTOR);
sleep 5;

let $ob1_ls_count = deploy_get_value(ob1.select select count(*) as cnt from __all_virtual_log_stat where tenant_id = $ob1_mysql_tenant_id and paxos_member_list like '%$ob1_follower_ip_port1%', cnt, 1);
ob1.check_until_timeout select (count(*) = ($ob1_ls_count)) from __all_virtual_log_stat where tenant_id = $ob1_mysql_tenant_id and degraded_list like "%$ob1_follower_ip_port1%", 1, 120;

# case3.2 启动follower1，验证升级

$ob1_follower1_obs.nstart;
ob1.check_until_timeout select (count(*) = 0) from __all_virtual_log_stat where tenant_id = $ob1_mysql_tenant_id and degraded_list like "%$ob1_follower_ip_port1%", 1, 120;

# case4. 验证升降级, 断网, 保证server不会被RS永久下线
# case4.1 block_net follower1，验证降级
#$ob1_leader_obs.block_net $ob1_follower1_obs;
#let $ob1_ls_count = deploy_get_value(ob1.select select count(*) as cnt from __all_virtual_log_stat where tenant_id = $ob1_mysql_tenant_id and paxos_member_list like '%$ob1_follower_ip_port1%', cnt, 1);
#ob1.check_until_timeout select (count(*) = ($ob1_ls_count)) from __all_virtual_log_stat where tenant_id = $ob1_mysql_tenant_id and degraded_list like "%$ob1_follower_ip_port1%", 1, 120;

# case4.2 block_net follower2，验证升级
#$ob1_leader_obs.unblock_net $ob1_follower1_obs;
#ob1.check_until_timeout select (count(*) = 0) from __all_virtual_log_stat where tenant_id = $ob1_mysql_tenant_id and degraded_list like "%$ob1_follower_ip_port1%", 1, 120;

# case5. 验证宕机重启
ob1.asvr0.force_stop;
ob1.asvr0.nstart;
sleep 3;

# case6. 验证2f1a变4f1a
ob1.check_until_timeout select (count(*) = 0) from oceanbase.__all_virtual_log_stat where tenant_id = $ob1_mysql_tenant_id and paxos_replica_num = 2, 0, 120;
ob1.mysql alter tenant mysql locality='F@z1,F@z2,F@z3,F@z4';
ob1.check_until_timeout select count(*) from oceanbase.__all_tenant where tenant_name = "mysql" and previous_locality != "", 0, 300;
ob1.check_until_timeout select (count(*) = 0) from oceanbase.__all_virtual_log_stat where tenant_id = $ob1_mysql_tenant_id and paxos_replica_num = 2, 1, 120;

let $ob1_follower_ip_port2=deploy_get_value(ob1.select select concat(svr_ip,':',svr_port) as host from __all_virtual_ls_meta_table where tenant_id = $ob1_mysql_tenant_id and ls_id =  1001 and role = 2 order by svr_port desc limit 1, host, 1);
let $ob1_follower_ip2=deploy_get_value(ob1.select select svr_ip from __all_virtual_ls_meta_table where tenant_id = $ob1_mysql_tenant_id and ls_id =  1001 and role = 2 order by svr_port desc limit 1, svr_ip, 1);
let $ob1_follower_port2=deploy_get_value(ob1.select select svr_port from __all_virtual_ls_meta_table where tenant_id = $ob1_mysql_tenant_id and ls_id = 1001 and role = 2 order by svr_port desc limit 1, svr_port, 1);

let $ob1_follower2_obs=deploy_get_value(ob1.get_obs_by_addr $ob1_follower_ip_port2);

# case6.1 验证4f1a，单台server故障，预期不降级
$ob1_follower1_obs.force_stop;
sleep 10;
ob1.check_until_timeout select (count(*) = 0) from __all_virtual_log_stat where tenant_id = $ob1_mysql_tenant_id and ls_id=1001 and degraded_list like "%$ob1_follower_ip_port1%", 1, 120;

# case6.2 验证4f1a，两台server故障，触发降级
$ob1_follower2_obs.force_stop;
sleep 10;
ob1.check_until_timeout select (count(*) != 0) from __all_virtual_log_stat where tenant_id = $ob1_mysql_tenant_id and ls_id=1001 and degraded_list like "%$ob1_follower_ip_port2%", 1, 120;
ob1.check_until_timeout select (count(*) != 0) from __all_virtual_log_stat where tenant_id = $ob1_mysql_tenant_id and ls_id=1001 and degraded_list like "%$ob1_follower_ip_port1%", 1, 120;

# case6.3 验证4f1a，拉起一台故障server，触发升级
$ob1_follower1_obs.nstart;
sleep 3;
ob1.check_until_timeout select (count(*) = 0) from __all_virtual_log_stat where tenant_id = $ob1_mysql_tenant_id and ls_id=1001 and degraded_list like "%$ob1_follower_ip_port1%", 1, 120;

# case6.4 验证4f1a，拉起第二台故障server，触发升级
$ob1_follower2_obs.nstart;
sleep 3;
ob1.check_until_timeout select (count(*) = 0) from __all_virtual_log_stat where tenant_id = $ob1_mysql_tenant_id and ls_id=1001 and degraded_list like "%$ob1_follower_ip_port2%", 1, 120;

# case7. 验证迁移复制
let $resource_pool_id = deploy_get_value(ob1.select select resource_pool_id from oceanbase.__all_resource_pool where tenant_id = $ob1_mysql_tenant_id, resource_pool_id, 1);
let $unit_id = deploy_get_value(ob1.select select unit_id from oceanbase.__all_unit where resource_pool_id = $resource_pool_id and svr_port = $ob1_follower_port1 and svr_ip = '$ob1_follower_ip1', unit_id, 1);
let $zone = deploy_get_value(ob1.select select zone from oceanbase.DBA_OB_UNITS where tenant_id = $ob1_mysql_tenant_id and svr_port = $ob1_follower_port1 and svr_port = '$ob1_follower_port1', zone, 1);

let $dst0_ip=deploy_get_value(ob1.select select svr_ip from oceanbase.DBA_OB_UNITS where zone = '$zone' and svr_port != $ob1_follower_port1 limit 1, svr_ip, 1);
let $dst0_port=deploy_get_value(ob1.select select svr_port from oceanbase.DBA_OB_UNITS where zone = '$zone' and svr_port != $ob1_follower_port1 limit 1, svr_port, 1);
let $dst0=deploy_get_value(ob1.select select concat(svr_ip,':',svr_port) as host from DBA_OB_UNITS where svr_port = $dst0_port limit 1, host, 1);

#ob1.mysql alter system migrate unit $unit_id destination "$dst0";
#ob1.check_until_timeout select count(1) from oceanbase.__all_virtual_ls_meta_table where tenant_id = $tenant_id and ls_id = 1001 and svr_ip = '$dst0_ip' and svr_port = '$dst0_port' and replica_status = 'NORMAL', 1, 100;

## case7.1 回迁到原本unit
#ob1.mysql alter system migrate unit $unit_id destination "$ob1_follower_ip_port1";
#ob1.check_until_timeout select count(1) from oceanbase.__all_virtual_ls_meta_table where tenant_id = $tenant_id and ls_id = 1001 and svr_ip = '$ob1_follower_ip1' and svr_port = '$ob1_follower_port1' and replica_status = 'NORMAL', 1, 100;

## case7.2 ob1_follower1_obs宕机，手动迁移到dst0
$ob1_follower1_obs.force_stop;
sleep 10;
## 单台serer单机，4f1a不会触发降级
ob1.check_until_timeout select (count(*) = 0) from __all_virtual_log_stat where tenant_id = $ob1_mysql_tenant_id and degraded_list like "%$ob1_follower_ip_port1%" and ls_id=1001, 1, 120;
## 手动迁移unit
ob1.mysql alter system migrate unit $unit_id destination "$dst0";
ob1.check_until_timeout select count(1) from oceanbase.__all_virtual_ls_meta_table where tenant_id = $ob1_mysql_tenant_id and ls_id = 1001 and svr_ip = '$dst0_ip' and svr_port = '$dst0_port' and replica_status = 'NORMAL', 1, 100;

## 验证写入功能是否正常
ob_connect(conn_mysql, $ob1_leader_obs, root@mysql, , test, , USE_MYSQL_CONNECTOR);
# wait leader takeover
sleep 1;
# 数据准备
create table t10(pk int primary key, c1 int, c2 varchar(20));
# 确认leader已经汇报成功
ob1.check_until_timeout select count(*) from __all_virtual_ls_meta_table where tenant_id = $ob1_mysql_tenant_id and ls_id = 1001 and role = 1, 1, 60;
--disable_query_log
let $cnt=10;
while($cnt>0)
{
	eval insert into t10 values($cnt,$cnt,'c$cnt');
	dec $cnt;
}

## case8. 4f1a变2f1a
ob1.mysql alter tenant mysql locality='F@z1,F@z2';
ob1.check_until_timeout select count(*) from oceanbase.__all_tenant where tenant_name = "mysql" and previous_locality != "", 0, 300;
ob1.check_until_timeout select count(*) from __all_virtual_log_stat where tenant_id = $ob1_mysql_tenant_id and paxos_replica_num = 4, 0, 300;

## case9. 验证多集群接入
ob2=OBI(cluster=1:1, proxy_num=0, asvr_num=1, share_asvr=ob1);
let $ob2_extra_conf = "cpu_count=8,memory_limit='20G',system_memory='5G',__min_full_resource_pool_memory='1073741824',cache_wash_threshold='1G',log_disk_size='20G',cluster_id=2";
ob2.z1.obs0.set extra_config=$ob2_extra_conf;
ob2.z2.obs0.set extra_config=$ob2_extra_conf;
ob2.reboot;
# 为sys租户启动仲裁服务
ob2.mysql alter tenant sys enable_arbitration_service = true;
sleep 1;
ob_connect(conn_sys2, ob2.z1.obs0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);

# case9.1 获取仲裁server的ip、port, 检查仲裁server是否成功运行
let $arb_svr_ip= deploy_get_value(ob2.asvr0.ip);
let $arb_svr_port= deploy_get_value(ob2.asvr0.port);
ob2.check_until_timeout select count(*) from __all_arbitration_service where arbitration_service = "$arb_svr_ip:$arb_svr_port", 1, 30;

# case9.2 创建租户
let $cpu = 1;
let $memory = 1073741824;
let $min_memory = 1073741824;
let $disk = 536870912;
let $iops = 100000;
let $session = 64;
set @@session.ob_query_timeout = 1000000000;
# create mysql tenant (2F1A)
eval CREATE RESOURCE UNIT unit_1 MAX_CPU 1, MEMORY_SIZE='2G';
eval CREATE RESOURCE POOL pool_1 UNIT = 'unit_1', UNIT_NUM = 1, zone_list = ('z1', 'z2');
eval CREATE TENANT mysql RESOURCE_POOL_LIST = ('pool_1'),  locality='F@z1, F@z2', primary_zone='RANDOM', enable_arbitration_service=true set ob_tcp_invited_nodes='%';
let $ob2_mysql_tenant_id = deploy_get_value(ob2.select select tenant_id from oceanbase.__all_tenant where tenant_name = 'mysql', tenant_id, 1);
# check arbitration member exist for tenant's ls
ob2.check_until_timeout select count(*) from __all_virtual_log_stat where tenant_id=$ob2_mysql_tenant_id and arbitration_member like "%$arb_svr_ip:$arb_svr_port%", 6, 30;

let $ob2_leader_ip_port=deploy_get_value(ob2.select select concat(svr_ip,':',svr_port) as host from __all_virtual_ls_meta_table where tenant_id = $ob2_mysql_tenant_id and ls_id =  1001 and role = 1 limit 1, host, 1);
let $ob2_follower_ip_port1=deploy_get_value(ob2.select select concat(svr_ip,':',svr_port) as host from __all_virtual_ls_meta_table where tenant_id = $ob2_mysql_tenant_id and ls_id =  1001 and role = 2 order by svr_port limit 1, host, 1);
let $ob2_leader_obs=deploy_get_value(ob2.get_obs_by_addr $ob2_leader_ip_port);
let $ob2_follower1_obs=deploy_get_value(ob2.get_obs_by_addr $ob2_follower_ip_port1);

## case9.3 建表、写入数据;
ob_connect(conn_mysql, $ob2_leader_obs, root@mysql, , test, , USE_MYSQL_CONNECTOR);
# wait leader takeover
sleep 1;
# 数据准备
create table t100(pk int primary key, c1 int, c2 varchar(20));
# 确认leader已经汇报成功
ob2.check_until_timeout select count(*) from __all_virtual_ls_meta_table where tenant_id = '$ob2_mysql_tenant_id' and ls_id = 1001 and role = 1, 1, 60;
--disable_query_log
let $cnt=10;
while($cnt>0)
{
	eval insert into t100 values($cnt,$cnt,'c$cnt');
	dec $cnt;
}

## case 9.4 宕机后是否触发
$ob2_follower1_obs.force_stop;
ob_connect(conn_mysql, $ob2_leader_obs, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);
sleep 5;

let $ob2_ls_count = deploy_get_value(ob2.select select count(*) as cnt from __all_virtual_log_stat where tenant_id = $ob2_mysql_tenant_id and paxos_member_list like '%$ob2_follower_ip_port1%', cnt, 1);
ob2.check_until_timeout select (count(*) = ($ob2_ls_count)) from __all_virtual_log_stat where tenant_id = $ob2_mysql_tenant_id and degraded_list like "%$ob2_follower_ip_port1%", 1, 120;

# case3.2 启动follower1，验证升级

$ob2_follower1_obs.nstart;
ob2.check_until_timeout select (count(*) = 0) from __all_virtual_log_stat where tenant_id = $ob2_mysql_tenant_id and degraded_list like "%$ob2_follower_ip_port1%", 1, 120;
