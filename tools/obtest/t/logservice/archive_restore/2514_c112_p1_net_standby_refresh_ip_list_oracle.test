# owner: ziqi
# owner group: log
# Testing Case: ip list refresh on net standby

ob1=OBI(cluster=1:1:2,proxy_num=0);
ob2=OBI(cluster=1,proxy_num=0);

let $extra_conf = "cpu_count=8,memory_limit='16G',system_memory='5G',__min_full_resource_pool_memory='1073741824',cache_wash_threshold='1G',log_disk_size='100G',cluster_id=1";
ob1.z1.obs0.set extra_config=$extra_conf;
ob1.z2.obs0.set extra_config=$extra_conf;
ob1.z3.obs0.set extra_config=$extra_conf;
ob1.z3.obs1.set extra_config=$extra_conf;
ob2.z1.obs0.set extra_config=$extra_conf;

let $backup_cluster_name  = deploy_get_value(ob1.get_cluster_name);
let $backup_cluster_id    = deploy_get_value(ob1.get_cluster_id);
let $backup_ip            = deploy_get_value(ob1.z1.obs0.ip);
let $backup_port          = deploy_get_value(ob1.z1.obs0.mysql_port);
let $delete_ip            = deploy_get_value(ob1.z3.obs1.ip);
let $delete_port          = deploy_get_value(ob1.z3.obs1.port);
let $restore_ip           = deploy_get_value(ob2.z1.obs0.ip);
let $restore_port         = deploy_get_value(ob2.z1.obs0.mysql_port);
let $backup_dest          = deploy_get_value(ob1.get_backup_dest);
let $backup_oracle_tenant  = backup_oracle_tenant;
let $restore_oracle_tenant = restore_oracle_tenant;
let $log_backup_dest      = deploy_get_value(ob1.get_log_backup_dest $backup_oracle_tenant);
let $data_backup_dest     = deploy_get_value(ob1.get_data_backup_dest $backup_oracle_tenant);
let $standby_archive_dest = deploy_get_value(ob1.get_log_backup_dest $restore_oracle_tenant);

ob1.force_stop;
ob1.clean_backup_dest;
ob1.reboot;

# 固定sys租户规格
ob1.mysql alter resource unit sys_unit_config memory_size='2G';

connect(backup_sys_conn, $backup_ip, root@sys,,oceanbase, $backup_port);
connection backup_sys_conn;
use oceanbase;
alter system set resource_hard_limit = 1000;
alter system set _restore_idle_time  = '10s';

CREATE RESOURCE UNIT large_unit MAX_CPU=5, MEMORY_SIZE='4G';
CREATE RESOURCE POOL large_pool UNIT large_unit, UNIT_NUM 1, ZONE_LIST ('z1','z2','z3');

ob1.mysql alter system set _backup_idle_time = '10s';
ob1.mysql alter system set merger_check_interval = '10s';
ob1.mysql alter system set enable_async_syslog=false;

# create oracle tenant, test create tenant before major freeze
ob1.mysql CREATE TENANT $backup_oracle_tenant RESOURCE_POOL_LIST = ('large_pool'), primary_zone = "z1" set ob_tcp_invited_nodes='%', ob_compatibility_mode='oracle';
let $backup_oracle_tenant_id = query_get_value(select tenant_id from oceanbase.__all_tenant where tenant_name='$backup_oracle_tenant', tenant_id, 1);

#创建tablet
ob_connect(sys_conn_oracle, ob1.z1.obs0, SYS@$backup_oracle_tenant, , SYS, , USE_OB_CONNECTOR);
connection sys_conn_oracle;
set global wait_timeout = 288000;

--disable_all_result_log
eval alter system set data_backup_dest='$data_backup_dest';
eval alter system set log_archive_dest='location=$log_backup_dest piece_switch_interval=1d';
ob1.set_piece_switch_interval 1002 0 2m;
--enable_all_result_log

# Set piece_switch_interval to 2min manually.
connection backup_sys_conn;
alter system change tenant tenant_id = 1001;
update __all_log_archive_dest_parameter set value='2m' where dest_no=0 and name='piece_switch_interval';

ob_connect(backup_oracle_conn, ob1.z1.obs0, SYS@$backup_oracle_tenant, , SYS, , USE_OB_CONNECTOR);
connection backup_oracle_conn;

#mysql租户  开启日志备份
ob1.mysql alter system archivelog;
ob1.check_until_timeout select status from oceanbase.CDB_OB_ARCHIVELOG where tenant_id=$backup_oracle_tenant_id, DOING, 600;

ob1.mysql alter system major freeze tenant = '$backup_oracle_tenant';
ob1.check_until_timeout select (frozen_scn - last_scn) as result from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id=$backup_oracle_tenant_id, 0, 600;

#mysql租户  开启数据备份
ob1.mysql alter system backup database;
ob1.check_until_timeout select count(*) c from __all_backup_job_history where tenant_id = 1, 1, 600;
ob1.check_until_timeout select result from oceanbase.CDB_OB_BACKUP_JOB_HISTORY where tenant_id = $backup_oracle_tenant_id, 0, 10;
ob1.check_until_timeout select result from oceanbase.CDB_OB_BACKUP_TASK_HISTORY where tenant_id = $backup_oracle_tenant_id, 0, 10;


connect(backup_sys_conn, $backup_ip, root@sys,,oceanbase, $backup_port);
connection backup_sys_conn;
use oceanbase;
let $restore_path = $log_backup_dest,$data_backup_dest;
let $ls_id1 = deploy_get_value(ob1.select select ls_id from oceanbase.__all_virtual_ls where tenant_id = $backup_oracle_tenant_id and ls_id != 1, ls_id, 1);
ob1.mysql alter tenant $backup_oracle_tenant set primary_zone = 'z1';
ob1.check_until_timeout select count(*)>=1 from oceanbase.__all_virtual_ls_status where status = 'NORMAL' and tenant_id = $backup_oracle_tenant_id, 1, 100;
let $ls_id2 = deploy_get_value(ob1.select select max(ls_id) as ls_id from oceanbase.__all_virtual_ls where tenant_id = $backup_oracle_tenant_id, ls_id, 1);
let $create_scn1 = deploy_get_value(ob1.select select create_scn from oceanbase.__all_virtual_ls where tenant_id = $backup_oracle_tenant_id and ls_id = $ls_id1, create_scn, 1);
let $create_scn2 = deploy_get_value(ob1.select select create_scn from oceanbase.__all_virtual_ls where tenant_id = $backup_oracle_tenant_id and ls_id = $ls_id2, create_scn, 1);
sleep 2;
let $restore_checkpoint1 = `select ceil(min_restore_scn / 1000) as min_restore_scn from CDB_OB_BACKUP_SET_FILES where tenant_id = $backup_oracle_tenant_id`;
let $restore_checkpoint2 = `select ceil(UNIX_TIMESTAMP(current_timestamp(6)) * 1000000)`;
ob1.check_until_timeout select floor(checkpoint_scn / 1000) > '$restore_checkpoint1' from CDB_OB_ARCHIVELOG, 1, 600;
ob1.check_until_timeout select floor(checkpoint_scn / 1000) > '$restore_checkpoint2' from CDB_OB_ARCHIVELOG, 1, 600;
let $restore_checkpoint = $restore_checkpoint2;
let $restore_checkpoint = `select usec_to_time(floor(checkpoint_scn/1000)) from CDB_OB_ARCHIVELOG`;


ob2.reboot;
# set tenant resource
ob2.mysql alter resource unit sys_unit_config memory_size='2G';
connect(restore_sys_conn, $restore_ip, root@sys, ,oceanbase, $restore_port);
connection restore_sys_conn;
use oceanbase;
alter system set resource_hard_limit = 1000;
alter system set _restore_idle_time = '10s';
ob2.mysql alter system set _backup_idle_time = '10s';
ob2.mysql alter system set merger_check_interval = '10s';
ob2.mysql alter system set enable_async_syslog=false;

CREATE RESOURCE UNIT large_unit_1 MAX_CPU=5, MEMORY_SIZE='4G';
CREATE RESOURCE POOL large_pool_1 UNIT large_unit_1, UNIT_NUM 1, ZONE_LIST ('z1');

# start restore
--disable_all_result_log
ob2.mysql alter system restore $restore_oracle_tenant from '$restore_path' until time='$restore_checkpoint' with 'pool_list=large_pool_1&primary_zone=z1';
--enable_all_result_log

ob2.check_until_timeout SELECT status FROM __all_tenant WHERE tenant_id = 1001, NORMAL, 200;
ob2.check_until_timeout SELECT count(*) FROM __all_virtual_ls_meta_table where tenant_id = 1002 and restore_status = 0, 2, 1200;
ob2.check_until_timeout SELECT status FROM __all_tenant WHERE tenant_id = 1002, NORMAL, 200;
ob2.check_until_timeout SELECT count(*) FROM __all_restore_job, 0, 200;

let $restore_oracle_tenant_id = query_get_value(select tenant_id from oceanbase.__all_tenant where tenant_name='$restore_oracle_tenant', tenant_id, 1);
ob2.mysql ALTER SYSTEM RECOVER STANDBY TENANT $restore_oracle_tenant UNTIL UNLIMITED;

# create primary log restore source user
ob_connect(backup_oracle_conn, ob1.z1.obs0,sys@$backup_oracle_tenant,,sys,,USE_OB_CONNECTOR);
connection backup_oracle_conn;
create user oracle_user identified by "mypassword";
grant connect to oracle_user;
grant SELECT on SYS.DBA_OB_TENANTS to oracle_user;
grant SELECT on SYS.GV$OB_PARAMETERS to oracle_user;
grant SELECT on SYS.DBA_OB_ACCESS_POINT to oracle_user;
grant SELECT on SYS.GV$OB_LOG_STAT to oracle_user;
grant SELECT on SYS.GV$OB_UNITS to oracle_user;

# get primary tenant access point
let $server_ip_port_1=deploy_get_value(ob1.select select concat(svr_ip,':',sql_port) as host from CDB_OB_ACCESS_POINT where tenant_id=$backup_oracle_tenant_id order by svr_ip, sql_port limit 0,1;, host, 1);
let $server_ip_port_2=deploy_get_value(ob1.select select concat(svr_ip,':',sql_port) as host from CDB_OB_ACCESS_POINT where tenant_id=$backup_oracle_tenant_id order by svr_ip, sql_port limit 1,1;, host, 1);
let $server_ip_port_3=deploy_get_value(ob1.select select concat(svr_ip,':',sql_port) as host from CDB_OB_ACCESS_POINT where tenant_id=$backup_oracle_tenant_id order by svr_ip, sql_port limit 2,1;, host, 1);


# set log_restore_source for standby restore_oracle_tenant
--disable_all_result_log
ob2.mysql alter system set log_restore_source = 'service=$server_ip_port_1;$server_ip_port_2;$server_ip_port_3 USER=oracle_user@$backup_oracle_tenant PASSWORD=mypassword' tenant = '$restore_oracle_tenant';
--enable_all_result_log

# check standby log_restore_source
ob2.check_until_timeout select count(*)>=1 from OCEANBASE.CDB_OB_LOG_RESTORE_SOURCE where tenant_id=$restore_oracle_tenant_id and type='SERVICE', 1, 600;

# check standby sync status normal
connection restore_sys_conn;
let $current = `select ceil(UNIX_TIMESTAMP(current_timestamp(6)) * 1000000)`;
ob2.check_until_timeout select floor(sync_scn / 1000) > '$current' from __all_virtual_tenant_info where tenant_id = $restore_oracle_tenant_id, 1, 600;

# check if standby log_restore_source server
ob2.check_until_timeout select SUBSTRING(value, INSTR(value,"IP_LIST")+8, INSTR(value,"USER")-INSTR(value,"IP_LIST")-9)='$server_ip_port_1;$server_ip_port_2;$server_ip_port_3' from CDB_OB_LOG_RESTORE_SOURCE where tenant_id=$backup_oracle_tenant_id, 1, 600;

# delete server
ob1.check_until_timeout select count(*) = 1 from OCEANBASE.DBA_OB_SERVERS where SVR_IP = '$delete_ip' and SVR_PORT = $delete_port, 1, 600;
connection backup_sys_conn;
alter system set server_permanent_offline_time = 20;
--disable_all_result_log
eval alter system DELETE SERVER '$delete_ip:$delete_port' ZONE 'z3';
--enable_all_result_log
ob1.check_until_timeout select count(*) = 0 from OCEANBASE.DBA_OB_SERVERS where SVR_IP = '$delete_ip' and SVR_PORT = $delete_port, 1, 600;

# get new primary tenant access point after delete server
let $server_ip_port_4=deploy_get_value(ob1.select select concat(svr_ip,':',sql_port) as host from CDB_OB_ACCESS_POINT where tenant_id=$backup_oracle_tenant_id order by svr_ip, sql_port limit 0,1;, host, 1);
let $server_ip_port_5=deploy_get_value(ob1.select select concat(svr_ip,':',sql_port) as host from CDB_OB_ACCESS_POINT where tenant_id=$backup_oracle_tenant_id order by svr_ip, sql_port limit 1,1;, host, 1);
let $server_ip_port_6=deploy_get_value(ob1.select select concat(svr_ip,':',sql_port) as host from CDB_OB_ACCESS_POINT where tenant_id=$backup_oracle_tenant_id order by svr_ip, sql_port limit 2,1;, host, 1);

sleep 10;
# check if standby log_restore_source update after delete server
ob2.check_until_timeout select SUBSTRING(value, INSTR(value,"IP_LIST")+8, INSTR(value,"USER")-INSTR(value,"IP_LIST")-9)='$server_ip_port_4;$server_ip_port_5;$server_ip_port_6' from CDB_OB_LOG_RESTORE_SOURCE where tenant_id=$backup_oracle_tenant_id, 1, 600;

# check standby sync status
connection backup_sys_conn;
let $current = `select ceil(UNIX_TIMESTAMP(current_timestamp(6)) * 1000000)`;
ob2.check_until_timeout select floor(sync_scn / 1000) > '$current' from __all_virtual_tenant_info where tenant_id = $restore_oracle_tenant_id, 1, 600;

# add server back, need to clean dir
ob1.z3.obs1.force_stop;
ob1.z3.obs1.rmdir;
ob1.z3.obs1.mkdir;
ob1.z3.obs1.rsync;
ob1.z3.obs1.start;

# add server
connection backup_sys_conn;
--disable_all_result_log
eval alter system ADD SERVER '$delete_ip:$delete_port' ZONE 'z3';
--enable_all_result_log
ob1.check_until_timeout select count(*) = 1 from OCEANBASE.DBA_OB_SERVERS where SVR_IP = '$delete_ip' and SVR_PORT = $delete_port, 1, 600;

# get new primary tenant access point
let $server_ip_port_7=deploy_get_value(ob1.select select concat(svr_ip,':',sql_port) as host from CDB_OB_ACCESS_POINT where tenant_id=$backup_oracle_tenant_id order by svr_ip, sql_port limit 0,1;, host, 1);
let $server_ip_port_8=deploy_get_value(ob1.select select concat(svr_ip,':',sql_port) as host from CDB_OB_ACCESS_POINT where tenant_id=$backup_oracle_tenant_id order by svr_ip, sql_port limit 1,1;, host, 1);
let $server_ip_port_9=deploy_get_value(ob1.select select concat(svr_ip,':',sql_port) as host from CDB_OB_ACCESS_POINT where tenant_id=$backup_oracle_tenant_id order by svr_ip, sql_port limit 2,1;, host, 1);


# check if standby log_restore_source update after add server
ob2.check_until_timeout select SUBSTRING(value, INSTR(value,"IP_LIST")+8, INSTR(value,"USER")-INSTR(value,"IP_LIST")-9)='$server_ip_port_7;$server_ip_port_8;$server_ip_port_9' from CDB_OB_LOG_RESTORE_SOURCE where tenant_id=$backup_oracle_tenant_id, 1, 600;

# check standby sync status
connection backup_sys_conn;
let $current = `select ceil(UNIX_TIMESTAMP(current_timestamp(6)) * 1000000)`;
ob2.check_until_timeout select floor(sync_scn / 1000) > '$current' from __all_virtual_tenant_info where tenant_id = $restore_oracle_tenant_id, 1, 600;