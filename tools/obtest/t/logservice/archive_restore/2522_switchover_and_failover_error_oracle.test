# CASE_OWNER:
#    @zhaoyongheng.zyh
# CASE_DESC:
#    备租户switchover

ob1=OBI(cluster=1:1:2, proxy_num=0);

source include/mini_ob_config.inc;
ob1.z1.obs0.set extra_config = "cpu_count=16,memory_limit='30G',system_memory='7G',__min_full_resource_pool_memory='1073741824',cache_wash_threshold='1G',_ob_minor_merge_schedule_interval='3s'";
ob1.z2.obs0.set extra_config = "cpu_count=16,memory_limit='30G',system_memory='7G',__min_full_resource_pool_memory='1073741824',cache_wash_threshold='1G',_ob_minor_merge_schedule_interval='3s'";
ob1.z3.obs0.set extra_config = "cpu_count=16,memory_limit='30G',system_memory='7G',__min_full_resource_pool_memory='1073741824',cache_wash_threshold='1G',_ob_minor_merge_schedule_interval='3s'";
ob1.z3.obs1.set extra_config = "cpu_count=16,memory_limit='30G',system_memory='7G',__min_full_resource_pool_memory='1073741824',cache_wash_threshold='1G',_ob_minor_merge_schedule_interval='3s'";

let $backup_cluster_name = deploy_get_value(ob1.get_cluster_name);
let $backup_cluster_id = deploy_get_value(ob1.get_cluster_id);
let $backup_ip       = deploy_get_value(ob1.z1.obs0.ip);
let $backup_port     = deploy_get_value(ob1.z1.obs0.mysql_port);
let $restore_ip         = deploy_get_value(ob1.z1.obs0.ip);
let $restore_port       = deploy_get_value(ob1.z1.obs0.mysql_port);
let $backup_dest = deploy_get_value(ob1.get_backup_dest);
let $backup_oracle_tenant   = backup_oracle_tenant;
let $backup_oracle_tenant    = backup_oracle_tenant;
let $restore_oracle_tenant = restore_oracle_tenant;
let $restore_oracle_tenant_new = restore_oracle_tenant_new;
let $restore_oracle_tenant = restore_oracle_tenant;
let $log_backup_dest = deploy_get_value(ob1.get_log_backup_dest $backup_oracle_tenant);
let $data_backup_dest = deploy_get_value(ob1.get_data_backup_dest $backup_oracle_tenant);
let $restore_log_archive_dest = deploy_get_value(ob1.get_log_backup_dest $restore_oracle_tenant);

# 必须先stop掉老的，删除才能有效，不然可能会有残留。
ob1.force_stop;
ob1.clean_backup_dest;
ob1.reboot;

# 固定sys租户规格
ob1.mysql alter resource unit sys_unit_config memory_size='2G';

connect(backup_sys_conn, $backup_ip, root@sys,,oceanbase, $backup_port);
connection backup_sys_conn;
use oceanbase;
--disable_all_result_log
alter system set resource_hard_limit = 1000;
alter system set _restore_idle_time = '10s';
CREATE RESOURCE UNIT small_unit MIN_CPU=2, MAX_CPU=2, MEMORY_SIZE='4G';
CREATE RESOURCE POOL small_pool UNIT small_unit, UNIT_NUM 1, ZONE_LIST ('z1','z2','z3');
CREATE RESOURCE POOL small_pool_0 UNIT small_unit, UNIT_NUM 1, ZONE_LIST ('z1','z2','z3');
CREATE RESOURCE POOL small_pool_2 UNIT small_unit, UNIT_NUM 1, ZONE_LIST ('z1','z2','z3');
--enable_all_result_log

ob1.mysql alter system set _backup_idle_time = '10s';
ob1.mysql alter system set merger_check_interval = '10s';
ob1.mysql alter system set enable_async_syslog=false;

# create oracle tenant, test create tenant before major freeze
ob1.mysql CREATE TENANT $backup_oracle_tenant RESOURCE_POOL_LIST = ('small_pool'), primary_zone = "z1" set ob_tcp_invited_nodes='%', ob_compatibility_mode='oracle';
let $backup_oracle_tenant_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name='$backup_oracle_tenant', tenant_id, 1);

#oracle租户  创建tablet
ob_connect(sys_conn_oracle, ob1.z1.obs0, SYS@$backup_oracle_tenant, ,SYS, , USE_OB_CONNECTOR);
connection sys_conn_oracle;
set global wait_timeout = 288000;

--disable_all_result_log
eval alter system set data_backup_dest='$data_backup_dest';
eval alter system set log_archive_dest='location=$log_backup_dest piece_switch_interval=1d';
--enable_all_result_log
ob_connect(backup_oracle_conn, ob1.z1.obs0,SYS@$backup_oracle_tenant,,SYS,,USE_OB_CONNECTOR);
connection backup_oracle_conn;

create table t1(a int, b int, c int);
insert into t1(a, b) values(1, 1);


#oracle租户  开启日志备份
ob1.mysql alter system archivelog;
ob1.check_until_timeout select status from oceanbase.CDB_OB_ARCHIVELOG where tenant_id=$backup_oracle_tenant_id, DOING, 600;

ob1.mysql alter system major freeze tenant = '$backup_oracle_tenant';
sleep 10;
ob1.check_until_timeout select (frozen_scn - last_scn) as result from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id=$backup_oracle_tenant_id, 0, 600;

#oracle租户  开启数据备份
ob1.mysql alter system backup database;
ob1.check_until_timeout select count(*) c from __all_backup_job_history where tenant_id = 1, 1, 600;
ob1.check_until_timeout select result from oceanbase.CDB_OB_BACKUP_JOB_HISTORY where tenant_id = $backup_oracle_tenant_id, 0, 10;
ob1.check_until_timeout select result from oceanbase.CDB_OB_BACKUP_TASK_HISTORY where tenant_id = $backup_oracle_tenant_id, 0, 10;

sleep 20;
connect(backup_sys_conn, $backup_ip, root@sys,,oceanbase, $backup_port);
connection backup_sys_conn;
use oceanbase;
let $restore_path = $log_backup_dest,$data_backup_dest;
let $ls_id1 = deploy_get_value(ob1.select select ls_id from oceanbase.__all_virtual_ls where tenant_id = $backup_oracle_tenant_id and ls_id != 1, ls_id, 1);
ob1.mysql alter tenant $backup_oracle_tenant set primary_zone = 'z1';
ob1.check_until_timeout select count(*)>=1 from oceanbase.__all_virtual_ls_status where status = 'NORMAL' and tenant_id = $backup_oracle_tenant_id, 1, 100;
let $ls_id2 = deploy_get_value(ob1.select select max(ls_id) as ls_id from oceanbase.__all_virtual_ls where tenant_id = $backup_oracle_tenant_id, ls_id, 1);
let $create_scn1 = deploy_get_value(ob1.select select create_scn from oceanbase.__all_virtual_ls where tenant_id = $backup_oracle_tenant_id and ls_id = $ls_id1, create_scn, 1);
let $create_scn2 = deploy_get_value(ob1.select select create_scn from oceanbase.__all_virtual_ls where tenant_id = $backup_oracle_tenant_id and ls_id =  $ls_id2, create_scn, 1);
sleep 3;
let $restore_checkpoint1 = `select ceil(min_restore_scn / 1000) as min_restore_scn from CDB_OB_BACKUP_SET_FILES where tenant_id = $backup_oracle_tenant_id`;
let $restore_checkpoint2 = `select ceil(UNIX_TIMESTAMP(current_timestamp(6)) * 1000000)`;
ob1.check_until_timeout select floor(checkpoint_scn / 1000) > '$restore_checkpoint1' from CDB_OB_ARCHIVELOG, 1, 600;
ob1.check_until_timeout select floor(checkpoint_scn / 1000) > '$restore_checkpoint2' from CDB_OB_ARCHIVELOG, 1, 600;
let $restore_checkpoint = $restore_checkpoint2;
let $restore_checkpoint = `select usec_to_time(floor(checkpoint_scn/1000)) from CDB_OB_ARCHIVELOG`;

#oracle租户  开启数据恢复
--disable_all_result_log
ob1.mysql alter system restore $restore_oracle_tenant from '$restore_path' until time='$restore_checkpoint' with 'pool_list=small_pool_2&primary_zone=z1';
--enable_all_result_log
ob1.check_until_timeout SELECT status FROM __all_tenant WHERE tenant_id = 1003, NORMAL, 200;
ob1.check_until_timeout select count(*) from __all_virtual_ls_meta_table where tenant_id = 1004 and restore_status = 0, 6, 1200;
ob1.check_until_timeout select status FROM __all_tenant WHERE tenant_id = 1004, NORMAL, 200;
ob1.check_until_timeout select count(*) FROM __all_restore_job, 0, 200;
ob1.mysql ALTER SYSTEM RECOVER STANDBY TENANT $restore_oracle_tenant UNTIL UNLIMITED;

let $restore_oracle_tenant_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name='$restore_oracle_tenant', tenant_id, 1);

ob_connect(sys_conn, ob1.z1.obs0, root, , oceanbase, , USE_MYSQL_CONNECTOR);
connection sys_conn;
select tenant_role from __all_virtual_tenant_info where tenant_id = 1004;
#STANDBY

let $primary_1001_sync_scn = deploy_get_value(ob1.select select end_scn from oceanbase.__all_virtual_log_stat where tenant_id = 1002 and ls_id = 1001 and role='LEADER', end_scn, 1);
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_tenant_info where tenant_id = 1004 and tenant_role = 'STANDBY' and READABLE_SCN >= $primary_1001_sync_scn, 1, 100;

ob_connect(conn_oracle, ob1.z1.obs0, SYS@$restore_oracle_tenant, , SYS, , USE_OB_CONNECTOR);
connection conn_oracle;
select * from t1;
# 1   1


# case 1. 验证系统租户switchover  oracle 普通租户
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_tenant_info where tenant_id = 1002 and tenant_role = 'PRIMARY' and switchover_status = 'NORMAL', 1, 10;
let $primary_switchover_epoch = deploy_get_value(ob1.select select switchover_epoch from oceanbase.__all_virtual_tenant_info where tenant_id = 1002, switchover_epoch, 1);
ob_connect(conn_sys_ob1, ob1.z1.obs0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);
select TENANT_ID, TENANT_NAME, TENANT_TYPE, COMPATIBILITY_MODE, STATUS, IN_RECYCLEBIN, LOCKED, TENANT_ROLE, SWITCHOVER_STATUS, LOG_MODE from DBA_OB_TENANTS order by TENANT_ID;
select count(*) from DBA_OB_TENANTS where SYNC_SCN >= REPLAYABLE_SCN and REPLAYABLE_SCN>=READABLE_SCN and RECOVERY_UNTIL_SCN !=0 and TENANT_TYPE = "USER";
# 2
eval ALTER SYSTEM SWITCHOVER TO STANDBY TENANT $backup_oracle_tenant VERIFY;
eval ALTER SYSTEM SWITCHOVER TO STANDBY TENANT $backup_oracle_tenant;


let $primary_sync_scn = deploy_get_value(ob1.select select sync_scn from oceanbase.__all_virtual_tenant_info where tenant_id = 1002, sync_scn, 1);
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_tenant_info where tenant_id = 1002 and switchover_epoch = $primary_switchover_epoch, 0, 10;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_tenant_info where tenant_id = 1002 and tenant_role = 'STANDBY' and switchover_status = 'NORMAL' and replayable_scn = $primary_sync_scn, 1, 10;
let $to_standby_tenant_id = 1002;
let $to_primary_tenant_id = 1004;

#  等待主租户变为备租户，并且完成归档
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_tenant_info where tenant_id = $to_standby_tenant_id and tenant_role = 'STANDBY' and switchover_status = 'NORMAL', 1, 10;
source include/check_archive_finish.inc;
# 等待备租户switchover_status状态是normal
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_tenant_info where tenant_id = $to_primary_tenant_id and tenant_role = 'STANDBY' and switchover_status = 'NORMAL', 1, 10;

ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_tenant_info where tenant_id = 1004 and tenant_role = 'STANDBY' and switchover_status = 'NORMAL', 1, 10;
let standby_switchover_epoch = deploy_get_value(ob1.select select switchover_epoch from oceanbase.__all_virtual_tenant_info where tenant_id = 1004, switchover_epoch, 1);
sleep 20;
ob_connect(conn_sys, ob1.z1.obs0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);
ob1.mysql alter system set debug_sync_timeout = '11s';
ob1.mysql set ob_global_debug_sync = 'BEFORE_UPDATE_RECOVERY_UNTIL_SCN wait_for continue_signal_2 execute 10000';
--error 4012
eval ALTER SYSTEM SWITCHOVER TO PRIMARY TENANT $restore_oracle_tenant;
ob1.mysql set ob_global_debug_sync = 'BEFORE_UPDATE_RECOVERY_UNTIL_SCN clear';
ob1.mysql set ob_global_debug_sync = 'now signal continue_signal_2 execute 10000';
eval ALTER SYSTEM SWITCHOVER TO PRIMARY TENANT $restore_oracle_tenant VERIFY;
eval ALTER SYSTEM SWITCHOVER TO PRIMARY TENANT $restore_oracle_tenant;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_tenant_info where tenant_id = 1004 and switchover_epoch = $standby_switchover_epoch, 0, 10;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_tenant_info where tenant_id = 1004 and tenant_role = 'PRIMARY' and switchover_status = 'NORMAL' and recovery_until_scn = 4611686018427387903, 1, 10;

ob_connect(conn_oracle, ob1.z1.obs0, SYS@$restore_oracle_tenant, , SYS, , USE_OB_CONNECTOR);
connection conn_oracle;
select * from t1;
# 1   1

#oracle 租户 switchover
let $sw_oracle_tenant = sw_oracle_tenant;
ob1.mysql alter system restore $sw_oracle_tenant from '$restore_path' until time='$restore_checkpoint' with 'pool_list=small_pool_0&primary_zone=z1';
ob1.check_until_timeout SELECT status FROM __all_tenant WHERE tenant_id = 1005, NORMAL, 200;
ob1.check_until_timeout select count(*) from __all_virtual_ls_meta_table where tenant_id = 1006 and restore_status = 0, 6, 1200;
ob1.check_until_timeout select status FROM __all_tenant WHERE tenant_id = 1006, NORMAL, 200;
ob1.check_until_timeout select count(*) FROM __all_restore_job, 0, 200;
ob1.mysql ALTER SYSTEM RECOVER STANDBY TENANT $sw_oracle_tenant UNTIL UNLIMITED;

#备租户开启归档
let $sw_data_backup_dest = deploy_get_value(ob1.get_data_backup_dest $sw_oracle_tenant);
let $sw_log_backup_dest = deploy_get_value(ob1.get_log_backup_dest $sw_oracle_tenant);
ob_connect(sys_conn_oracle, ob1.z1.obs0, SYS@$sw_oracle_tenant, ,SYS, , USE_OB_CONNECTOR);
connection sys_conn_oracle;
set wait_timeout = 288000;
--disable_all_result_log
eval alter system set data_backup_dest='$sw_data_backup_dest';
eval alter system set log_archive_dest='location=$sw_log_backup_dest piece_switch_interval=1d';
--enable_all_result_log

let $sw_oracle_tenant_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name='$sw_oracle_tenant', tenant_id, 1);
let $to_standby_tenant_id = $sw_oracle_tenant_id;
let $to_primary_tenant_id = $sw_oracle_tenant_id;

#  等待主租户变为备租户，并且完成归档
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_tenant_info where tenant_id = $to_standby_tenant_id and tenant_role = 'STANDBY' and switchover_status = 'NORMAL', 1, 10;
source include/check_archive_finish.inc;
# 等待备租户switchover_status状态是normal
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_tenant_info where tenant_id = $to_primary_tenant_id and tenant_role = 'STANDBY' and switchover_status = 'NORMAL', 1, 10;

ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_tenant_info where tenant_id = 1006 and tenant_role = 'STANDBY' and switchover_status = 'NORMAL', 1, 10;
let standby_switchover_epoch = deploy_get_value(ob1.select select switchover_epoch from oceanbase.__all_virtual_tenant_info where tenant_id = 1006, switchover_epoch, 1);

ob_connect(sys_conn, ob1.z1.obs0, root@sys, , oceanbase, , USE_OB_CONNECTOR);
connection sys_conn;
set ob_query_timeout=100000000;

alter system set_tp tp_name = ERRSIM_TENANT_ROLE_TRANS_WAIT_SYNC_ERROR, error_code = 1142, frequency = 1;
--error 4179
eval ALTER SYSTEM SWITCHOVER TO PRIMARY tenant $sw_oracle_tenant;

alter system set_tp tp_name = ERRSIM_TENANT_ROLE_TRANS_WAIT_SYNC_ERROR, error_code = 942, frequency = 1;
--error 4179
eval ALTER SYSTEM SWITCHOVER TO PRIMARY tenant $sw_oracle_tenant;

alter system set_tp tp_name = ERRSIM_TENANT_ROLE_TRANS_WAIT_SYNC_ERROR, error_code = 1045, frequency = 1;
--error 4179
eval ALTER SYSTEM SWITCHOVER TO PRIMARY tenant $sw_oracle_tenant;

alter system set_tp tp_name = ERRSIM_TENANT_ROLE_TRANS_WAIT_SYNC_ERROR, error_code = 1044, frequency = 1;
--error 4179
eval ALTER SYSTEM SWITCHOVER TO PRIMARY tenant $sw_oracle_tenant;

alter system set_tp tp_name = ERRSIM_TENANT_ROLE_TRANS_WAIT_SYNC_ERROR, error_code = 5361, frequency = 1;
--error 4179
eval ALTER SYSTEM SWITCHOVER TO PRIMARY tenant $sw_oracle_tenant;

alter system set_tp tp_name = ERRSIM_TENANT_ROLE_TRANS_WAIT_SYNC_ERROR, error_code = 4152, frequency = 1;
--error 4179
eval ALTER SYSTEM SWITCHOVER TO PRIMARY tenant $sw_oracle_tenant;

alter system set_tp tp_name = ERRSIM_TENANT_ROLE_TRANS_WAIT_SYNC_ERROR, error_code = 4242, frequency = 1;
--error 4179
eval ALTER SYSTEM SWITCHOVER TO PRIMARY tenant $sw_oracle_tenant;

alter system set_tp tp_name = ERRSIM_TENANT_ROLE_TRANS_WAIT_SYNC_ERROR, error_code = 2002, frequency = 1;
--error 4179
eval ALTER SYSTEM SWITCHOVER TO PRIMARY tenant $sw_oracle_tenant;

alter system set_tp tp_name = ERRSIM_TENANT_ROLE_TRANS_WAIT_SYNC_ERROR, error_code = 4043, frequency = 1;
--error 4179
eval ALTER SYSTEM SWITCHOVER TO PRIMARY tenant $sw_oracle_tenant;

alter system set_tp tp_name = ERRSIM_TENANT_ROLE_TRANS_WAIT_SYNC_ERROR, error_code = 5260, frequency = 1;
--error 4179
eval ALTER SYSTEM SWITCHOVER TO PRIMARY tenant $sw_oracle_tenant;

alter system set_tp tp_name = ERRSIM_TENANT_ROLE_TRANS_WAIT_SYNC_ERROR, error_code = 9089, frequency = 1;
--error 9089
eval ALTER SYSTEM SWITCHOVER TO PRIMARY tenant $sw_oracle_tenant;
alter system set_tp tp_name = ERRSIM_TENANT_ROLE_TRANS_WAIT_SYNC_ERROR, error_code = 9089, frequency = 0;
eval ALTER SYSTEM SWITCHOVER TO PRIMARY tenant $sw_oracle_tenant;

ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_tenant_info where tenant_id = 1006 and switchover_epoch = $standby_switchover_epoch, 0, 10;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_tenant_info where tenant_id = 1006 and tenant_role = 'PRIMARY' and switchover_status = 'NORMAL' and recovery_until_scn = 4611686018427387903, 1, 10;

ob_connect(conn_oracle, ob1.z1.obs0, SYS@$sw_oracle_tenant, , SYS, , USE_OB_CONNECTOR);
connection conn_oracle;
select * from t1;
# 1   1
