# owner: duotian
# owner group: LOG
# Testing Case: Test empty first piece, no log match the first piece expect for logs compensated for 64MB alignment

ob1=OBI(cluster=2,proxy_num=0);

let $backup_cluster_name = deploy_get_value(ob1.get_cluster_name);
let $backup_cluster_id   = deploy_get_value(ob1.get_cluster_id);
let $backup_ip           = deploy_get_value(ob1.z1.obs0.ip);
let $backup_port         = deploy_get_value(ob1.z1.obs0.mysql_port);
let $backup_dest         = deploy_get_value(ob1.get_backup_dest);
let $backup_mysql_tenant = backup_mysql_tenant;
let $restore_mysql_tenant = restore_mysql_tenant;
let $log_backup_dest     = deploy_get_value(ob1.get_log_backup_dest $backup_mysql_tenant);
let $data_backup_dest    = deploy_get_value(ob1.get_data_backup_dest $backup_mysql_tenant);

ob1.force_stop;
ob1.clean_backup_dest;
ob1.reboot;

ob1.mysql alter resource unit sys_unit_config memory_size='2G';

connect(backup_sys_conn, $backup_ip, root@sys,,oceanbase, $backup_port);
connection backup_sys_conn;
use oceanbase;

CREATE RESOURCE UNIT large_unit MAX_CPU=5, MEMORY_SIZE='10G';

CREATE RESOURCE POOL large_pool UNIT large_unit, UNIT_NUM 2, ZONE_LIST ('z1');

ob1.mysql alter system set _backup_idle_time = '10s';
ob1.mysql alter system set merger_check_interval = '10s';
ob1.mysql alter system set enable_async_syslog=false;
ob1.mysql alter system set enable_rebalance= false;

# create mysql tenant, test create tenant before major freeze
ob1.mysql CREATE TENANT $backup_mysql_tenant RESOURCE_POOL_LIST = ('large_pool'), primary_zone = "z1" set ob_tcp_invited_nodes='%', ob_compatibility_mode='mysql';
let $backup_mysql_tenant_id = query_get_value(select tenant_id from oceanbase.__all_tenant where tenant_name='$backup_mysql_tenant', tenant_id, 1);

ob_connect(sys_conn_mysql, ob1.z1.obs0, root@$backup_mysql_tenant, ,oceanbase, , USE_MYSQL_CONNECTOR);
connection sys_conn_mysql;
set global wait_timeout = 288000;
ob1.mysql alter system set debug_sync_timeout = '100000s';

--disable_all_result_log
eval alter system set data_backup_dest='$data_backup_dest';
eval alter system set log_archive_dest='location=$log_backup_dest piece_switch_interval=1d';

# modify piece_switch_interval to 1m
ob1.set_piece_switch_interval 1002 0 1m;
--enable_all_result_log

ob_connect(backup_mysql_conn, ob1.z1.obs0,root@$backup_mysql_tenant,,test,,USE_MYSQL_CONNECTOR);
connection backup_mysql_conn;

create table t1(a int, b int, c int);
insert into t1(a, b) values(1, 1);

ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_ls_status where tenant_id=$backup_mysql_tenant_id, 3, 600;

# get the server to kill
let $ip_port_to_kill=deploy_get_value(ob1.select select concat(svr_ip,':',svr_port) as host from oceanbase.__all_server where svr_port not in (select svr_port from oceanbase.__all_virtual_log_stat where tenant_id=$backup_mysql_tenant_id and ls_id=1), host, 1);
let $server_to_kill=deploy_get_value(ob1.get_obs_by_addr $ip_port_to_kill);

# get the rs server, if it is in the server to kill, move it to another server
let $rs_server=deploy_get_value(ob1.select select concat(svr_ip,':',svr_port) as host from oceanbase.__all_virtual_log_stat where  tenant_id=1 and ls_id=1, host, 1);
# get the server to remove to
let $server_to=deploy_get_value(ob1.select select concat(svr_ip,':',svr_port) as host from oceanbase.__all_virtual_log_stat where tenant_id=$backup_mysql_tenant_id and ls_id=1, host, 1);

# migrate rs
ob1.mysql alter system migrate unit 1 destination "$server_to";

# get the alive server, to start archive
let $server_alive=deploy_get_value(ob1.get_obs_by_addr $server_to);
# check rs migration success
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_log_stat where  tenant_id=1 and ls_id=1 and concat(svr_ip,':',svr_port) = '$server_to' and role = 'leader', 1, 120;

# kill server
$server_to_kill.force_stop;
$server_alive.check_until_timeout select count(*) as server_cnt from oceanbase.DBA_OB_SERVERS where status like "%INACTIVE%", 1, 120;

#start archivelog
$server_alive.mysql alter system archivelog;

# debug sync to generate persist record with fake checkpoint_scn
$server_alive.mysql set ob_global_debug_sync = 'ARCHIVE_SENDER_HANDLE_TASK_DONE wait_for signal1 execute 10000';

# sleep 120s, generate empty piece
sleep 180;

$server_alive.mysql set ob_global_debug_sync = 'now broadcast signal1';
$server_alive.mysql set ob_global_debug_sync = 'ARCHIVE_SENDER_HANDLE_TASK_DONE clear';

# check archive stay in beginning status
$server_alive.check_until_timeout select status from oceanbase.CDB_OB_ARCHIVELOG where tenant_id=$backup_mysql_tenant_id, BEGINNING, 600;

# restart server
$server_to_kill.nstart;

# check server start success
$server_alive.check_until_timeout select count(*) from oceanbase.__all_server where start_service_time <= 0 or status = 'inactive', 0, 60;

# check archive normal
$server_alive.check_until_timeout select status from oceanbase.CDB_OB_ARCHIVELOG where tenant_id=$backup_mysql_tenant_id, DOING, 600;
