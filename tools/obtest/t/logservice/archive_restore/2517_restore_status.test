# owner: ziqi
# owner group: LOG
# Testing Case: Restore Status

ob1=OBI(cluster=1:1:1, proxy_num=0);
ob2=OBI(cluster=1:1:1, proxy_num=0);

let $backup_cluster_name = deploy_get_value(ob1.get_cluster_name);
let $backup_cluster_id = deploy_get_value(ob1.get_cluster_id);
let $backup_ip       = deploy_get_value(ob1.z1.obs0.ip);
let $backup_port     = deploy_get_value(ob1.z1.obs0.mysql_port);
let $restore_ip         = deploy_get_value(ob2.z1.obs0.ip);
let $restore_port       = deploy_get_value(ob2.z1.obs0.mysql_port);
let $backup_dest = deploy_get_value(ob1.get_backup_dest);
let $backup_mysql_tenant   = backup_mysql_tenant;
let $restore_mysql_tenant = restore_mysql_tenant;
let $log_backup_dest = deploy_get_value(ob1.get_log_backup_dest $backup_mysql_tenant);
let $data_backup_dest = deploy_get_value(ob1.get_data_backup_dest $backup_mysql_tenant);
let $standby_archive_dest = deploy_get_value(ob1.get_log_backup_dest $restore_mysql_tenant);

# 必须先stop掉老的，删除才能有效，不然可能会有残留。
ob1.force_stop;
ob1.clean_backup_dest;
ob1.reboot;

# 固定sys租户规格
ob1.mysql alter resource unit sys_unit_config memory_size='2G';

connect(backup_sys_conn, $backup_ip, root@sys,,oceanbase, $backup_port);
connection backup_sys_conn;
use oceanbase;
alter system set resource_hard_limit = 1000;
alter system set _restore_idle_time = '10s';

### create tenant backup_mysql_tenant
CREATE RESOURCE UNIT large_unit MAX_CPU=5, MEMORY_SIZE='8G';
CREATE RESOURCE POOL large_pool UNIT large_unit, UNIT_NUM 1, ZONE_LIST ('z1', 'z2', 'z3');

ob1.mysql alter system set _backup_idle_time = '10s';
ob1.mysql alter system set merger_check_interval = '10s';
ob1.mysql alter system set enable_async_syslog=false;

# create mysql tenant, test create tenant before major freeze
ob1.mysql CREATE TENANT $backup_mysql_tenant RESOURCE_POOL_LIST = ('large_pool'), primary_zone = "z1" set ob_tcp_invited_nodes='%', ob_compatibility_mode='mysql';
let $backup_mysql_tenant_id = query_get_value(select tenant_id from oceanbase.__all_tenant where tenant_name='$backup_mysql_tenant', tenant_id, 1);

# mysql租户  创建tablet
ob_connect(sys_conn_mysql, ob1.z1.obs0, root@$backup_mysql_tenant, ,oceanbase, , USE_MYSQL_CONNECTOR);
connection sys_conn_mysql;
set global wait_timeout = 288000;

connection sys_conn_mysql;
--disable_all_result_log
eval alter system set data_backup_dest='$data_backup_dest';
eval alter system set log_archive_dest='location=$log_backup_dest piece_switch_interval=1d';
ob1.set_piece_switch_interval 1002 0 2m;
--enable_all_result_log

# Set piece_switch_interval to 2min manually.
connection backup_sys_conn;
alter system change tenant tenant_id = 1001;
update __all_log_archive_dest_parameter set value='2m' where dest_no=0 and name='piece_switch_interval';

#mysql租户  开启日志备份
ob_connect(backup_mysql_conn, ob1.z1.obs0,root@$backup_mysql_tenant,,test,,USE_MYSQL_CONNECTOR);
connection backup_mysql_conn;
ob1.mysql alter system archivelog;
ob1.check_until_timeout select status from oceanbase.CDB_OB_ARCHIVELOG where tenant_id=$backup_mysql_tenant_id, DOING, 600;

ob1.mysql alter system major freeze tenant = '$backup_mysql_tenant';
ob1.check_until_timeout select (frozen_scn - last_scn) as result from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id=$backup_mysql_tenant_id, 0, 600;

#mysql租户  开启数据备份
ob1.mysql alter system backup database;
ob1.check_until_timeout select count(*) c from __all_backup_job_history where tenant_id >= 1, 1, 600;
ob1.check_until_timeout select result from oceanbase.CDB_OB_BACKUP_JOB_HISTORY where tenant_id = $backup_mysql_tenant_id, 0, 10;
ob1.check_until_timeout select result from oceanbase.CDB_OB_BACKUP_TASK_HISTORY where tenant_id = $backup_mysql_tenant_id, 0, 10;
#ob1.check_until_timeout select result from oceanbase.CDB_OB_BACKUP_JOB_HISTORY where tenant_id = $backup_mysql_tenant_id_1, 0, 10;
#ob1.check_until_timeout select result from oceanbase.CDB_OB_BACKUP_TASK_HISTORY where tenant_id = $backup_mysql_tenant_id_1, 0, 10;

connect(backup_sys_conn, $backup_ip, root@sys,,oceanbase, $backup_port);
connection backup_sys_conn;
use oceanbase;
let $restore_path = $log_backup_dest,$data_backup_dest;
let $ls_id1 = deploy_get_value(ob1.select select ls_id from oceanbase.__all_virtual_ls where tenant_id = $backup_mysql_tenant_id and ls_id != 1, ls_id, 1);
ob1.mysql alter tenant $backup_mysql_tenant set primary_zone = 'z1';
ob1.check_until_timeout select count(*)>=1 from oceanbase.__all_virtual_ls_status where status = 'NORMAL' and tenant_id = $backup_mysql_tenant_id, 1, 100;
let $ls_id2 = deploy_get_value(ob1.select select max(ls_id) as ls_id from oceanbase.__all_virtual_ls where tenant_id = $backup_mysql_tenant_id, ls_id, 1);
let $create_scn1 = deploy_get_value(ob1.select select create_scn from oceanbase.__all_virtual_ls where tenant_id = $backup_mysql_tenant_id and ls_id = $ls_id1, create_scn, 1);
let $create_scn2 = deploy_get_value(ob1.select select create_scn from oceanbase.__all_virtual_ls where tenant_id = $backup_mysql_tenant_id and ls_id = $ls_id2, create_scn, 1);
sleep 2;
let $restore_checkpoint1 = `select ceil(min_restore_scn / 1000) as min_restore_scn from CDB_OB_BACKUP_SET_FILES where tenant_id = $backup_mysql_tenant_id`;
let $restore_checkpoint2 = `select ceil(UNIX_TIMESTAMP(current_timestamp(6)) * 1000000)`;
ob1.check_until_timeout select floor(checkpoint_scn / 1000) > '$restore_checkpoint1' from CDB_OB_ARCHIVELOG, 1, 600;
ob1.check_until_timeout select floor(checkpoint_scn / 1000) > '$restore_checkpoint2' from CDB_OB_ARCHIVELOG, 1, 600;
let $restore_checkpoint = $restore_checkpoint2;
let $restore_checkpoint = `select usec_to_time(floor(checkpoint_scn/1000)) from CDB_OB_ARCHIVELOG`;

ob2.reboot;
# 固定sys租户规格
ob2.mysql alter resource unit sys_unit_config memory_size='2G';
connect(restore_sys_conn, $restore_ip, root@sys,,oceanbase, $restore_port);
connection restore_sys_conn;
use oceanbase;
alter system set resource_hard_limit = 1000;
alter system set _restore_idle_time = '10s';
ob2.mysql alter system set _backup_idle_time = '10s';
ob2.mysql alter system set merger_check_interval = '10s';
ob2.mysql alter system set enable_async_syslog=false;

CREATE RESOURCE UNIT large_unit MAX_CPU=5, MEMORY_SIZE='10G';
CREATE RESOURCE POOL large_pool_1 UNIT large_unit, UNIT_NUM 1, ZONE_LIST ('z1', 'z2', 'z3');
#mysql租户  开启数据恢复
--disable_all_result_log
ob2.mysql alter system restore $restore_mysql_tenant from '$restore_path' until time='$restore_checkpoint' with 'pool_list=large_pool_1&primary_zone=z1';
--enable_all_result_log
ob2.check_until_timeout SELECT status FROM __all_tenant WHERE tenant_id = 1001, NORMAL, 200;
ob2.check_until_timeout select count(*) from __all_virtual_ls_meta_table where tenant_id = 1002 and restore_status = 0, 6, 1200;
ob2.check_until_timeout select status FROM __all_tenant WHERE tenant_id = 1002, NORMAL, 200;
ob2.check_until_timeout select count(*) FROM __all_restore_job, 0, 200;

let $restore_mysql_tenant_id = query_get_value(select tenant_id from oceanbase.__all_tenant where tenant_name='$restore_mysql_tenant', tenant_id, 1);

ob2.mysql ALTER SYSTEM RECOVER STANDBY TENANT $restore_mysql_tenant UNTIL UNLIMITED;
alter system set open_cursors=100 tenant=sys;
alter system set open_cursors=100 tenant=all_user;
alter system set open_cursors=100 tenant=all_meta;

# create log restore source user for tenant backup_mysql_tenant
ob_connect(backup_mysql_conn, ob1.z1.obs0,root@$backup_mysql_tenant,,test,,USE_MYSQL_CONNECTOR);
connection backup_mysql_conn;
create user mytest identified by "test";
GRANT SELECT on OCEANBASE.DBA_OB_TENANTS to mytest;
GRANT SELECT on OCEANBASE.GV$OB_PARAMETERS to mytest;
GRANT SELECT on OCEANBASE.DBA_OB_ACCESS_POINT to mytest;
GRANT SELECT on OCEANBASE.GV$OB_LOG_STAT to mytest;
GRANT SELECT on OCEANBASE.GV$OB_UNITS to mytest;

# get primary tenant access point
let $server_ip_port_1=deploy_get_value(ob1.select select concat(svr_ip,':',sql_port) as host from CDB_OB_ACCESS_POINT where tenant_id=$backup_mysql_tenant_id order by svr_ip, sql_port limit 0,1;, host, 1);
let $server_ip_port_2=deploy_get_value(ob1.select select concat(svr_ip,':',sql_port) as host from CDB_OB_ACCESS_POINT where tenant_id=$backup_mysql_tenant_id order by svr_ip, sql_port limit 1,1;, host, 1);
let $server_ip_port_3=deploy_get_value(ob1.select select concat(svr_ip,':',sql_port) as host from CDB_OB_ACCESS_POINT where tenant_id=$backup_mysql_tenant_id order by svr_ip, sql_port limit 2,1;, host, 1);

# set log_restore_source for standby
--disable_all_result_log
ob2.mysql alter system set log_restore_source = 'service=$server_ip_port_1;$server_ip_port_2;$server_ip_port_3 USER=mytest@$backup_mysql_tenant PASSWORD=test' tenant = '$restore_mysql_tenant';
--enable_all_result_log
ob2.check_until_timeout select count(*)>=1 from CDB_OB_LOG_RESTORE_SOURCE where tenant_id = $restore_mysql_tenant_id and TYPE = 'SERVICE', 1, 600;

# check standby sync status normal
let $current = `select ceil(UNIX_TIMESTAMP(current_timestamp(6)) * 1000000)`;
ob2.check_until_timeout select floor(sync_scn / 1000) > '$current' from __all_virtual_tenant_info where tenant_id = $restore_mysql_tenant_id, 1, 600;


# check restore status -> normal
ob2.check_until_timeout select SYNC_STATUS from V\$OB_LS_LOG_RESTORE_STATUS where tenant_id = $restore_mysql_tenant_id and ls_id = 1, NORMAL, 600;
ob2.check_until_timeout select ERR_CODE from V\$OB_LS_LOG_RESTORE_STATUS where tenant_id = $restore_mysql_tenant_id and ls_id = 1, 0, 600;
ob2.check_until_timeout select SYNC_STATUS from V\$OB_LS_LOG_RESTORE_STATUS where tenant_id = $restore_mysql_tenant_id and ls_id = 1001, NORMAL, 600;
ob2.check_until_timeout select ERR_CODE from V\$OB_LS_LOG_RESTORE_STATUS where tenant_id = $restore_mysql_tenant_id and ls_id = 1001, 0, 600;


# check restore status -> restore suspend
connection restore_sys_conn;
ob2.mysql alter system recover standby tenant $restore_mysql_tenant cancel;
ob2.check_until_timeout select SYNC_STATUS from V\$OB_LS_LOG_RESTORE_STATUS where tenant_id = $restore_mysql_tenant_id and ls_id = 1, RESTORE SUSPEND, 600;
ob2.check_until_timeout select ERR_CODE from V\$OB_LS_LOG_RESTORE_STATUS where tenant_id = $restore_mysql_tenant_id and ls_id = 1, 0, 600;
ob2.check_until_timeout select SYNC_STATUS from V\$OB_LS_LOG_RESTORE_STATUS where tenant_id = $restore_mysql_tenant_id and ls_id = 1001, RESTORE SUSPEND, 600;
ob2.check_until_timeout select ERR_CODE from V\$OB_LS_LOG_RESTORE_STATUS where tenant_id = $restore_mysql_tenant_id and ls_id = 1001, 0, 600;

ob2.mysql alter system recover standby tenant $restore_mysql_tenant until unlimited;
ob2.check_until_timeout select SYNC_STATUS from V\$OB_LS_LOG_RESTORE_STATUS where tenant_id = $restore_mysql_tenant_id and ls_id = 1, NORMAL, 600;
ob2.check_until_timeout select ERR_CODE from V\$OB_LS_LOG_RESTORE_STATUS where tenant_id = $restore_mysql_tenant_id and ls_id = 1, 0, 600;
ob2.check_until_timeout select SYNC_STATUS from V\$OB_LS_LOG_RESTORE_STATUS where tenant_id = $restore_mysql_tenant_id and ls_id = 1001, NORMAL, 600;
ob2.check_until_timeout select ERR_CODE from V\$OB_LS_LOG_RESTORE_STATUS where tenant_id = $restore_mysql_tenant_id and ls_id = 1001, 0, 600;


# check restore status -> standby log not match
connection backup_sys_conn;
alter system set_tp tp_name = ERRSIM_FETCH_LOG_RESP_ERROR, error_code = 4070, frequency = 1;
ob2.check_until_timeout select count(*)>=1 from V\$OB_LS_LOG_RESTORE_STATUS where tenant_id = $restore_mysql_tenant_id and SYNC_STATUS='STANDBY LOG NOT MATCH', 1, 600;
ob2.check_until_timeout select count(*)>=1 from V\$OB_LS_LOG_RESTORE_STATUS where tenant_id = $restore_mysql_tenant_id and ERR_CODE=-4070, 1, 600;
alter system set_tp tp_name = ERRSIM_FETCH_LOG_RESP_ERROR, error_code = 4070, frequency = 0;
ob2.check_until_timeout select count(*) from V\$OB_LS_LOG_RESTORE_STATUS where tenant_id = $restore_mysql_tenant_id and SYNC_STATUS='NORMAL', 2, 600;
ob2.check_until_timeout select count(*) from V\$OB_LS_LOG_RESTORE_STATUS where tenant_id = $restore_mysql_tenant_id and ERR_CODE=0, 2, 600;


# OB_CHECKSUM_ERROR = -4103
alter system set_tp tp_name = ERRSIM_FETCH_LOG_RESP_ERROR, error_code = 4103, frequency = 1;
ob2.check_until_timeout select count(*)>=1 from V\$OB_LS_LOG_RESTORE_STATUS where tenant_id = $restore_mysql_tenant_id and SYNC_STATUS='STANDBY LOG NOT MATCH', 1, 600;
ob2.check_until_timeout select count(*)>=1 from V\$OB_LS_LOG_RESTORE_STATUS where tenant_id = $restore_mysql_tenant_id and ERR_CODE=-4103, 1, 600;
alter system set_tp tp_name = ERRSIM_FETCH_LOG_RESP_ERROR, error_code = 4103, frequency = 0;
ob2.check_until_timeout select count(*) from V\$OB_LS_LOG_RESTORE_STATUS where tenant_id = $restore_mysql_tenant_id and SYNC_STATUS='NORMAL', 2, 600;
ob2.check_until_timeout select count(*) from V\$OB_LS_LOG_RESTORE_STATUS where tenant_id = $restore_mysql_tenant_id and ERR_CODE=0, 2, 600;


# check restore status -> fetch log time out
# OB_TIMEOUT = -4012
connection restore_sys_conn;
alter system set_tp tp_name = ERRSIM_FETCH_LOG_TIME_OUT, error_code = 4012, frequency = 1;
ob2.check_until_timeout select count(*)>=1 from V\$OB_LS_LOG_RESTORE_STATUS where tenant_id = $restore_mysql_tenant_id and SYNC_STATUS='FETCH LOG TIMEOUT', 1, 600;
ob2.check_until_timeout select count(*)>=1 from V\$OB_LS_LOG_RESTORE_STATUS where tenant_id = $restore_mysql_tenant_id and ERR_CODE=-4012, 1, 600;
alter system set_tp tp_name = ERRSIM_FETCH_LOG_TIME_OUT, error_code = 4012, frequency = 0;
ob2.check_until_timeout select count(*) from V\$OB_LS_LOG_RESTORE_STATUS where tenant_id = $restore_mysql_tenant_id and SYNC_STATUS='NORMAL', 2, 600;
ob2.check_until_timeout select count(*) from V\$OB_LS_LOG_RESTORE_STATUS where tenant_id = $restore_mysql_tenant_id and ERR_CODE=0, 2, 600;


# check restore status -> check user or password
# -ER_ACCESS_DENIED_ERROR = -1045
alter system set_tp tp_name = ERRSIM_FETCH_LOG_SYS_QUERY_FAILED, error_code = 1045, frequency = 1;
ob2.check_until_timeout select count(*)>=1 from V\$OB_LS_LOG_RESTORE_STATUS where tenant_id = $restore_mysql_tenant_id and SYNC_STATUS='CHECK USER OR PASSWORD', 1, 600;
ob2.check_until_timeout select count(*)>=1 from V\$OB_LS_LOG_RESTORE_STATUS where tenant_id = $restore_mysql_tenant_id and ERR_CODE=-1045, 1, 600;
alter system set_tp tp_name = ERRSIM_FETCH_LOG_SYS_QUERY_FAILED, error_code = 1045, frequency = 0;
ob2.check_until_timeout select count(*) from V\$OB_LS_LOG_RESTORE_STATUS where tenant_id = $restore_mysql_tenant_id and SYNC_STATUS='NORMAL', 2, 600;
ob2.check_until_timeout select count(*) from V\$OB_LS_LOG_RESTORE_STATUS where tenant_id = $restore_mysql_tenant_id and ERR_CODE=0, 2, 600;


# check restore status -> check network
# -ER_CONNECT_FAILED = -2002
alter system set_tp tp_name = ERRSIM_FETCH_LOG_SYS_QUERY_FAILED, error_code = 2002, frequency = 1;
ob2.check_until_timeout select count(*)>=1 from V\$OB_LS_LOG_RESTORE_STATUS where tenant_id = $restore_mysql_tenant_id and SYNC_STATUS='CHECK NETWORK', 1, 600;
ob2.check_until_timeout select count(*)>=1 from V\$OB_LS_LOG_RESTORE_STATUS where tenant_id = $restore_mysql_tenant_id and ERR_CODE=-2002, 1, 600;
alter system set_tp tp_name = ERRSIM_FETCH_LOG_SYS_QUERY_FAILED, error_code = 2002, frequency = 0;
ob2.check_until_timeout select count(*) from V\$OB_LS_LOG_RESTORE_STATUS where tenant_id = $restore_mysql_tenant_id and SYNC_STATUS='NORMAL', 2, 600;
ob2.check_until_timeout select count(*) from V\$OB_LS_LOG_RESTORE_STATUS where tenant_id = $restore_mysql_tenant_id and ERR_CODE=0, 2, 600;


# check restore status -> source has a gap when fetch log
# OB_ERR_OUT_OF_LOWER_BOUND = -4233
connection backup_sys_conn;
alter system set_tp tp_name = ERRSIM_FETCH_LOG_RESP_ERROR, error_code = 4233, frequency = 1;
ob2.check_until_timeout select count(*)>=1 from V\$OB_LS_LOG_RESTORE_STATUS where tenant_id = $restore_mysql_tenant_id and SYNC_STATUS='SOURCE HAS A GAP', 1, 600;
ob2.check_until_timeout select count(*)>=1 from V\$OB_LS_LOG_RESTORE_STATUS where tenant_id = $restore_mysql_tenant_id and ERR_CODE=-4233, 1, 600;
alter system set_tp tp_name = ERRSIM_FETCH_LOG_RESP_ERROR, error_code = 4233, frequency = 0;
ob2.check_until_timeout select count(*) from V\$OB_LS_LOG_RESTORE_STATUS where tenant_id = $restore_mysql_tenant_id and SYNC_STATUS='NORMAL', 2, 600;
ob2.check_until_timeout select count(*) from V\$OB_LS_LOG_RESTORE_STATUS where tenant_id = $restore_mysql_tenant_id and ERR_CODE=0, 2, 600;

# OB_ARCHIVE_ROUND_NOT_CONTINUOUS = -9077
alter system set_tp tp_name = ERRSIM_FETCH_LOG_RESP_ERROR, error_code = 9077, frequency = 1;
ob2.check_until_timeout select count(*)>=1 from V\$OB_LS_LOG_RESTORE_STATUS where tenant_id = $restore_mysql_tenant_id and SYNC_STATUS='SOURCE HAS A GAP', 1, 600;
ob2.check_until_timeout select count(*)>=1 from V\$OB_LS_LOG_RESTORE_STATUS where tenant_id = $restore_mysql_tenant_id and ERR_CODE=-9077, 1, 600;
alter system set_tp tp_name = ERRSIM_FETCH_LOG_RESP_ERROR, error_code = 9077, frequency = 0;
ob2.check_until_timeout select count(*) from V\$OB_LS_LOG_RESTORE_STATUS where tenant_id = $restore_mysql_tenant_id and SYNC_STATUS='NORMAL', 2, 600;
ob2.check_until_timeout select count(*) from V\$OB_LS_LOG_RESTORE_STATUS where tenant_id = $restore_mysql_tenant_id and ERR_CODE=0, 2, 600;

# OB_ARCHIVE_LOG_RECYCLED = -9079
alter system set_tp tp_name = ERRSIM_FETCH_LOG_RESP_ERROR, error_code = 9079, frequency = 1;
ob2.check_until_timeout select count(*)>=1 from V\$OB_LS_LOG_RESTORE_STATUS where tenant_id = $restore_mysql_tenant_id and SYNC_STATUS='SOURCE HAS A GAP', 1, 600;
ob2.check_until_timeout select count(*)>=1 from V\$OB_LS_LOG_RESTORE_STATUS where tenant_id = $restore_mysql_tenant_id and ERR_CODE=-9079, 1, 600;
alter system set_tp tp_name = ERRSIM_FETCH_LOG_RESP_ERROR, error_code = 9079, frequency = 0;
ob2.check_until_timeout select count(*) from V\$OB_LS_LOG_RESTORE_STATUS where tenant_id = $restore_mysql_tenant_id and SYNC_STATUS='NORMAL', 2, 600;
ob2.check_until_timeout select count(*) from V\$OB_LS_LOG_RESTORE_STATUS where tenant_id = $restore_mysql_tenant_id and ERR_CODE=0, 2, 600;

# OB_SIZE_OVERFLOW = -4019
alter system set_tp tp_name = ERRSIM_FETCH_LOG_RESP_ERROR, error_code = 4019, frequency = 1;
ob2.check_until_timeout select count(*)>=1 from V\$OB_LS_LOG_RESTORE_STATUS where tenant_id = $restore_mysql_tenant_id and SYNC_STATUS='QUERY PRIMARY FAILED', 1, 600;
ob2.check_until_timeout select count(*)>=1 from V\$OB_LS_LOG_RESTORE_STATUS where tenant_id = $restore_mysql_tenant_id and ERR_CODE=-4019, 1, 600;
alter system set_tp tp_name = ERRSIM_FETCH_LOG_RESP_ERROR, error_code = 4019, frequency = 0;
ob2.check_until_timeout select count(*) from V\$OB_LS_LOG_RESTORE_STATUS where tenant_id = $restore_mysql_tenant_id and SYNC_STATUS='NORMAL', 2, 600;
ob2.check_until_timeout select count(*) from V\$OB_LS_LOG_RESTORE_STATUS where tenant_id = $restore_mysql_tenant_id and ERR_CODE=0, 2, 600;

# check restore status -> NOT AVAILABLE
# OB_ERR_UNEXPECTED = -4017
alter system set_tp tp_name = ERRSIM_FETCH_LOG_RESP_ERROR, error_code = 4017, frequency = 1;
ob2.check_until_timeout select count(*)>=1 from V\$OB_LS_LOG_RESTORE_STATUS where tenant_id = $restore_mysql_tenant_id and SYNC_STATUS='NOT AVAILABLE', 1, 600;
ob2.check_until_timeout select count(*)>=1 from V\$OB_LS_LOG_RESTORE_STATUS where tenant_id = $restore_mysql_tenant_id and ERR_CODE=-4017, 1, 600;
alter system set_tp tp_name = ERRSIM_FETCH_LOG_RESP_ERROR, error_code = 4017, frequency = 0;
ob2.check_until_timeout select count(*) from V\$OB_LS_LOG_RESTORE_STATUS where tenant_id = $restore_mysql_tenant_id and SYNC_STATUS='NORMAL', 2, 600;
ob2.check_until_timeout select count(*) from V\$OB_LS_LOG_RESTORE_STATUS where tenant_id = $restore_mysql_tenant_id and ERR_CODE=0, 2, 600;


# check standby sync status
connection restore_sys_conn;
let $current = `select ceil(UNIX_TIMESTAMP(current_timestamp(6)) * 1000000)`;
ob2.check_until_timeout select floor(sync_scn / 1000) > '$current' from __all_virtual_tenant_info where tenant_id = $restore_mysql_tenant_id, 1, 600;

# inject OB_ALLOCATE_MEMORY_FAILED and check if it would get stuck forever afterwards

alter system set_tp tp_name = ALLOC_FETCH_LOG_ARPC_REQ_FAIL, error_code = 4013, frequency = 1;
alter system set_tp tp_name = ALLOC_FETCH_LOG_ARPC_CB_FAIL, error_code = 4013, frequency = 1;
alter system set_tp tp_name = ALLOC_FETCH_LOG_ARPC_RESULT_FAIL, error_code = 4013, frequency = 1;

# let alloc fail with a 1/8 chance.

alter system set_tp tp_name = ALLOC_FETCH_LOG_ARPC_REQ_FAIL, error_code = 4013, frequency = 8;
alter system set_tp tp_name = ALLOC_FETCH_LOG_ARPC_CB_FAIL, error_code = 4013, frequency = 8;
alter system set_tp tp_name = ALLOC_FETCH_LOG_ARPC_RESULT_FAIL, error_code = 4013, frequency = 8;
sleep 10;


# WAITING LS CREATED
ob2.check_until_timeout select SYNC_STATUS from V\$OB_LS_LOG_RESTORE_STATUS where tenant_id = $restore_mysql_tenant_id and ls_id = 1001, NORMAL, 600;
ob2.check_until_timeout select ERR_CODE from V\$OB_LS_LOG_RESTORE_STATUS where tenant_id = $restore_mysql_tenant_id and ls_id = 1001, 0, 600;

ob2.mysql alter system set debug_sync_timeout = '1000s';
ob2.mysql set ob_global_debug_sync = 'BEFORE_PROCESS_AFTER_HAS_MEMBER_LIST wait_for signal';
ob1.mysql alter tenant $backup_mysql_tenant set primary_zone=RANDOM;

ob2.check_until_timeout select count(*)>=1 from V\$OB_LS_LOG_RESTORE_STATUS where tenant_id = $restore_mysql_tenant_id and SYNC_STATUS='WAITING LS CREATED' and ls_id=1, 1, 600;
ob2.check_until_timeout select count(*)>=1 from V\$OB_LS_LOG_RESTORE_STATUS where tenant_id = $restore_mysql_tenant_id and ERR_CODE=-4719 and ls_id=1, 1, 600;

# check restore status -> normal
ob2.mysql set ob_global_debug_sync = 'now signal signal';
ob2.check_until_timeout select SYNC_STATUS from V\$OB_LS_LOG_RESTORE_STATUS where tenant_id = $restore_mysql_tenant_id and ls_id = 1, NORMAL, 600;
ob2.check_until_timeout select ERR_CODE from V\$OB_LS_LOG_RESTORE_STATUS where tenant_id = $restore_mysql_tenant_id and ls_id = 1, 0, 600;
ob2.check_until_timeout select count(*) from V\$OB_LS_LOG_RESTORE_STATUS where tenant_id = $restore_mysql_tenant_id and SYNC_STATUS!='NORMAL', 0, 600;
ob2.check_until_timeout select count(*) from V\$OB_LS_LOG_RESTORE_STATUS where tenant_id = $restore_mysql_tenant_id and ERR_CODE!=0, 0, 600;


# stop inject error and see if it would recover.
alter system set_tp tp_name = ALLOC_FETCH_LOG_ARPC_REQ_FAIL, error_code = 4013, frequency = 0;
alter system set_tp tp_name = ALLOC_FETCH_LOG_ARPC_CB_FAIL, error_code = 4013, frequency = 0;
alter system set_tp tp_name = ALLOC_FETCH_LOG_ARPC_RESULT_FAIL, error_code = 4013, frequency = 0;
ob2.check_until_timeout select count(*)=0 from V\$OB_LS_LOG_RESTORE_STATUS where tenant_id = $restore_mysql_tenant_id and SYNC_STATUS=!'NORMAL', 1, 600;
ob2.check_until_timeout select count(*)=0 from V\$OB_LS_LOG_RESTORE_STATUS where tenant_id = $restore_mysql_tenant_id and ERR_CODE!=0, 1, 600;

ob2.check_until_timeout select (time_to_usec(now(6)) - floor(sync_scn / 1000)) < 1000000 from __all_virtual_tenant_info where tenant_id = $restore_mysql_tenant_id, 1, 600;