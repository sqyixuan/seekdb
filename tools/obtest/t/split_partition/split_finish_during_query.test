# owner: lihongqin.lhq
# owner group: storage
# description: split finish during large query
#

--disable_query_log
# Notice 
# 1. `obproxy` can not be created if specify init_unit_cpu = 1;
# 2. Tenant `mysql` and `obtest` can not be created without init_unit_cpu=num.
ob1=OBI(cluster=1:1:1, proxy_num=0, init_unit_cpu=1);
ob1.reboot;
sleep 2;

ob_connect(obsys, ob1.z1.obs0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);
set @@global.ob_query_timeout = 1000000000000;
ob1.mysql alter system set merger_check_interval='10s';
ob1.mysql alter system set enable_rebalance = 'false';
ob1.mysql alter system set resource_hard_limit=500;
ob1.mysql alter system set debug_sync_timeout = '100000s';
ob1.mysql alter system set server_permanent_offline_time = '20s';
ob1.mysql alter system set syslog_io_bandwidth_limit = '4G';
ob1.mysql alter system set enable_async_syslog = 'false';

ob_connect(conn1, ob1.z1.obs0, root@obtest, , test, , USE_MYSQL_CONNECTOR);
set ob_query_timeout=10000000000000;
ob_connect(conn2, ob1.z1.obs0, root@obtest, , test, , USE_MYSQL_CONNECTOR);
set ob_query_timeout=10000000000000;

create table t1(c1 int primary key, c2 int) partition by range(c1) (partition p0 values less than (100), partition p1 values less than (maxvalue));
create index i1 on t1(c2) local;
insert into t1 values (1,10);
insert into t1 values (2,9);
insert into t1 values (3,8);
insert into t1 values (4,7);
insert into t1 values (5,6);
insert into t1 values (6,5);
insert into t1 values (7,4);
insert into t1 values (8,3);
insert into t1 values (9,2);
insert into t1 values (10,1);
ob1.mysql set ob_global_debug_sync = 'reset';
ob1.mysql set ob_global_debug_sync = 'PARTITION_SPLIT_WAIT_FREEZE_END wait_for signal1 execute 10000';
ob1.mysql set ob_global_debug_sync = 'BEFORE_FILL_AUTO_SPLIT_PARAMS wait_for signal2 execute 10000';
connection conn1;
send alter table t1 reorganize partition p0 into (partition p00 values less than (5), partition p01 values less than (100));
sleep 3;
connection conn2;
send select /*+index(t1 i1)*/ c1 from t1 partition(p00);
sleep 3;
ob1.mysql set ob_global_debug_sync = 'reset';
ob1.mysql set ob_global_debug_sync = 'now signal signal1';
connection conn1;
reap;
ob1.mysql set ob_global_debug_sync = 'reset';
ob1.mysql set ob_global_debug_sync = 'now signal signal2';
connection conn2;
reap;
drop table t1;

