# owner: liujixiong.ljx
# owner group: DDL
# Testing Case: to test restore end between split start log and split finish log.
# 1. create table and load data.
# 2. archive log.
# 3. backup data.
# 4. split partition.
# 5. restore(create split source empty shell 
#            -> replay create dest with Full 
#            -> replay split start to wait data split end.).

ob1=OBI(cluster=1:1:1, proxy_num=0);

source include/mini_ob_config.inc;
ob1.z1.obs0.set extra_config = "cache_wash_threshold='1G',_ob_minor_merge_schedule_interval='3s'";
ob1.z2.obs0.set extra_config = "cache_wash_threshold='1G',_ob_minor_merge_schedule_interval='3s'";
ob1.z3.obs0.set extra_config = "cache_wash_threshold='1G',_ob_minor_merge_schedule_interval='3s'";

let $backup_cluster_name = deploy_get_value(ob1.get_cluster_name);
let $backup_cluster_id = deploy_get_value(ob1.get_cluster_id);
let $backup_ip       = deploy_get_value(ob1.z1.obs0.ip);
let $backup_port     = deploy_get_value(ob1.z1.obs0.mysql_port);
let $backup_dest = deploy_get_value(ob1.get_backup_dest);
let $backup_oracle_tenant   = backup_oracle_tenant;
let $backup_mysql_tenant    = backup_mysql_tenant;
let $restore_oracle_tenant = restore_oracle_tenant;
let $restore_oracle_tenant_new = restore_oracle_tenant_new;
let $restore_mysql_tenant = restore_mysql_tenant;
let $restore_mysql_tenant_new = restore_mysql_tenant_new;
let $log_backup_dest = deploy_get_value(ob1.get_log_backup_dest $backup_mysql_tenant);
let $data_backup_dest = deploy_get_value(ob1.get_data_backup_dest $backup_mysql_tenant);
let $restore_log_archive_dest = deploy_get_value(ob1.get_log_backup_dest $restore_mysql_tenant);

# 必须先stop掉老的，删除才能有效，不然可能会有残留。
ob1.force_stop;
ob1.clean_backup_dest;
ob1.reboot;

# 固定sys租户规格
ob1.mysql alter resource unit sys_unit_config memory_size='2G';

connect(backup_sys_conn, $backup_ip, root@sys,,oceanbase, $backup_port);
connection backup_sys_conn;
use oceanbase;
source sql/physical_backup/prepare_multi_zone_resource.sql;

ob1.mysql alter system set _backup_idle_time = '10s';
ob1.mysql alter system set merger_check_interval = '10s';
ob1.mysql alter system set enable_async_syslog = false;
ob1.mysql alter system set ob_compaction_schedule_interval = '10s' tenant all_user;
ob1.mysql alter system set debug_sync_timeout = '100000s';

--echo ===============================================================
--echo ==================     create tenant   ========================
--echo ===============================================================

ob1.mysql CREATE RESOURCE UNIT mine_unit MAX_CPU=8, MEMORY_SIZE='8G';
ob1.mysql CREATE RESOURCE POOL mine_pool UNIT mine_unit, UNIT_NUM 1, ZONE_LIST ('z1', 'z2');
ob1.mysql CREATE TENANT backup_mysql_tenant resource_pool_list=('mine_pool'), locality = "F@z1,F@z2", primary_zone = "z1,z2" set ob_tcp_invited_nodes='%', ob_compatibility_mode='mysql';
source include/check_schema_sync.inc;
connection backup_sys_conn;
let $backup_mysql_tenant_id = query_get_value(select tenant_id from oceanbase.__all_tenant where tenant_name='$backup_mysql_tenant', tenant_id, 1);
let $resource_pool_id = deploy_get_value(ob1.select select resource_pool_id from oceanbase.__all_resource_pool where tenant_id = $backup_mysql_tenant_id, resource_pool_id, 1);
let $src_ls_id = 1001;
--echo create tenant finished

alter system set ob_compaction_schedule_interval = '10s' tenant all_user;

--echo ===============================================================
--echo ==================     create table ===========================
--echo ===============================================================
connect(sys_conn_mysql, $backup_ip, root@$backup_mysql_tenant,,oceanbase, $backup_port);
connection sys_conn_mysql;
set global wait_timeout = 288000;

--disable_all_result_log
eval alter system set data_backup_dest='$data_backup_dest';
eval alter system set log_archive_dest='location=$log_backup_dest';
ob1.set_piece_switch_interval $backup_mysql_tenant_id 0 2m;
--enable_all_result_log

connection sys_conn_mysql;
create user test IDENTIFIED BY "test";
grant all on *.* to test WITH GRANT OPTION;

connect(backup_mysql_conn, $backup_ip,test@$backup_mysql_tenant,test,test, $backup_port);
connection backup_mysql_conn;

# 创建表
create sequence seq_small INCREMENT BY 1 start with 1 minvalue 1 maxvalue 5000000 nocycle noorder nocache;
create sequence seq_large INCREMENT BY 1 start with 2500 minvalue 1 maxvalue 5000000 nocycle noorder nocache;
create table test_with_restore(c1 bigint, c2 bigint, c3 varchar(4096), c4 varchar(4096), c5 varchar(4096), c6 longtext, primary key(c1)) row_format = redundant, compression = 'none'
  partition by range(c1) (
    partition p0 values less than (1), 
    partition p1 values less than (5000),
    partition p2 values less than MAXVALUE);
SET SESSION _FORCE_PARALLEL_DDL_DOP = 32;
insert /*+ append query_timeout(100000000000) parallel(16) enable_parallel_dml */ into test_with_restore 
  select seq_small.nextval, random(10), randstr(4096, random(10)), randstr(4096, random(10)), randstr(4096, random(10)), randstr(10240, random(10)) from table(generator(1000));
insert /*+ append query_timeout(100000000000) parallel(16) enable_parallel_dml */ into test_with_restore 
  select seq_large.nextval, random(10), randstr(4096, random(10)), randstr(4096, random(10)), randstr(4096, random(10)), randstr(10240, random(10)) from table(generator(1000));
insert /*+ query_timeout(100000000000) parallel(16) enable_parallel_dml */ into test_with_restore 
  select seq_small.nextval, random(10), randstr(4096, random(10)), randstr(4096, random(10)), randstr(4096, random(10)), randstr(10240, random(10)) from table(generator(500));
insert /*+ query_timeout(100000000000) parallel(16) enable_parallel_dml */ into test_with_restore 
  select seq_large.nextval, random(10), randstr(4096, random(10)), randstr(4096, random(10)), randstr(4096, random(10)), randstr(10240, random(10)) from table(generator(500));

--echo ===============================================================
--echo ==================     start archive   ========================
--echo ===============================================================
ob1.mysql alter system archivelog;
ob1.check_until_timeout select status from oceanbase.CDB_OB_ARCHIVELOG where tenant_id=$backup_mysql_tenant_id, DOING, 600;
ob1.check_until_timeout select (frozen_scn - last_scn) as result from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id=$backup_mysql_tenant_id, 0, 600;

--echo ===============================================================
--echo ==================     start backup data   ====================
--echo ===============================================================
ob1.mysql alter system backup database;
ob1.check_until_timeout select count(*) c from __all_backup_job_history where tenant_id = 1, 1, 600;
ob1.check_until_timeout select result from oceanbase.CDB_OB_BACKUP_JOB_HISTORY where tenant_id = $backup_mysql_tenant_id, 0, 10;
ob1.check_until_timeout select result from oceanbase.CDB_OB_BACKUP_TASK_HISTORY where tenant_id = $backup_mysql_tenant_id, 0, 10;
ob1.check_until_timeout select count(*) from __all_virtual_mem_leak_checker_info where mod_name like 'BackupIO', 0, 60;

# stuck split before writting split finish log.
ob1.mysql set ob_global_debug_sync = 'PARTITION_SPLIT_WAIT_TRANS_END wait_for signal execute 10000';
sleep 5;
# execute partition split after data backup
send alter table test_with_restore reorganize partition p1 into ( partition p1_0 values less than (2500), partition p1_1 values less than (5000));
ob1.check_until_timeout select status from __all_virtual_ddl_task_status where tenant_id=1002, 2, 600;
connect(backup_sys_conn, $backup_ip, root@sys,,oceanbase, $backup_port);
connection backup_sys_conn;
use oceanbase;
let $restore_path = $log_backup_dest,$data_backup_dest;

--echo ===============================================================
--echo ===============  CALC RESTORE POINT  ==========================
--echo ===============================================================
# calc restore end point before signal/writting split-finish log.
let $now = `select timestamp_to_scn(current_timestamp(6))`;
ob1.mysql set ob_global_debug_sync = 'PARTITION_SPLIT_WAIT_TRANS_END clear';
sleep 2;
ob1.mysql set ob_global_debug_sync = 'now signal signal';
sleep 2;

ob1.check_until_timeout select checkpoint_scn > $now from CDB_OB_ARCHIVELOG where tenant_id = $backup_mysql_tenant_id, 1, 600;

--echo ===============================================================
--echo ===============  FULL RESTORE  ===============================
--echo ===============================================================
ob1.mysql alter system restore $restore_mysql_tenant from '$restore_path' until scn=$now with 'pool_list=small_pool_1&primary_zone=z1,z2';
ob1.check_until_timeout SELECT status FROM __all_tenant WHERE tenant_id = 1003, NORMAL, 600;
ob1.check_until_timeout select count(*) from __all_virtual_ls_meta_table where tenant_id = 1004 and restore_status = 0, 9, 600;
ob1.check_until_timeout select status FROM __all_tenant WHERE tenant_id = 1004, NORMAL, 600;
ob1.check_until_timeout select count(*) FROM __all_restore_job, 0, 600;


connection backup_sys_conn;
use oceanbase;

# 校验恢复进度统计信息
select (tablet_count-inner_table_cnt) as tablet_count,(finish_tablet_count-inner_table_cnt) as finish_tablet_count from cdb_ob_restore_history a inner join (select tenant_id, count(1) as inner_table_cnt from CDB_OB_TABLET_TO_LS where tenant_id=1004 and ls_id=1) b on a.tenant_id=b.tenant_id;
select ls_id, tablet_count as total_tablet_count, finish_tablet_count from __all_virtual_ls_restore_history where tenant_id=1004 and ls_id!=1 order by ls_id;
select count(*) as cnt from __all_virtual_ls_restore_history where tenant_id = 1004 and total_bytes = 0 or finish_bytes = 0;
select count(*) as cnt from __all_virtual_ls_restore_history where tenant_id = 1004 and (total_bytes-finish_bytes) != 0;
select count(*) as cnt from cdb_ob_restore_history where tenant_id = 1004 and total_bytes > 0 and finish_bytes > 0 and (total_bytes-finish_bytes)=0;

#校验restore_data_mode
select restore_data_mode from oceanbase.DBA_OB_TENANTS where tenant_id = 1;
select restore_data_mode from oceanbase.DBA_OB_TENANTS where tenant_id = 1003;
select restore_data_mode from oceanbase.DBA_OB_TENANTS where tenant_id = 1004;

#expect 0, sys ls should not have any sstable on backup, 0: pure local, 1: has local & has backup, 2:empty, 3: pure remote
select count(*) as cnt FROM __all_virtual_table_mgr where tenant_id=1004 and ls_id=1 and table_flag in (1, 3);
#expect 0, fully retored ls has no sstable on backup
select count(*) as cnt FROM __all_virtual_table_mgr where tenant_id=1004 and ls_id!=1 and table_flag in (1, 3);
#expect 18(6 tablets * 3 svrs), 1 data_tablet + 2 lob_tablet ->(split) => 2 data_tablet + 4 lob_tablet.
select count(*) as cnt FROM __all_virtual_table_mgr where tenant_id=1004 and table_type = 10 and tablet_id in 
  (select tablet_id from __all_virtual_part where tenant_id=1004 and part_name like 'p1_%');

connect(restore_mysql_conn, $backup_ip,test@$restore_mysql_tenant,test,test, $backup_port);
connection restore_mysql_conn;
use test;
select c1, c2, md5(c3), md5(c4), md5(c5), md5(c6) from test_with_restore partition(p1_0) order by c1 asc limit 10;
select c1, c2, md5(c3), md5(c4), md5(c5), md5(c6) from test_with_restore partition(p1_0) order by c1 desc limit 10;
select c1, c2, md5(c3), md5(c4), md5(c5), md5(c6) from test_with_restore partition(p1_1) order by c1 asc limit 10;
select c1, c2, md5(c3), md5(c4), md5(c5), md5(c6) from test_with_restore partition(p1_1) order by c1 desc limit 10;
ob1.check_until_timeout select count(*) from __all_virtual_mem_leak_checker_info where mod_name like 'BackupIO', 0, 60;
