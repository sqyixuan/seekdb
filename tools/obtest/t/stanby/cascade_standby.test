# CASE_OWNER:
#    @nijia.nj
# CASE_DESC:
#    Test cascade standby cluster (Primary -> Standby1 -> Standby2)
#    This test verifies:
#    1. Standby2 can sync from Standby1 (not directly from Primary)
#    2. Data consistency across all three clusters
#    3. Switchover scenarios in cascade topology
#    4. Failover scenarios in cascade topology
#
#    Topology:
#      Primary (db_p) -> Standby1 (db_s1) -> Standby2 (db_s2)
#
#    Test cases:
#    1. Initial setup: db_p (PRIMARY), db_s1 (STANDBY from db_p), db_s2 (STANDBY from db_s1)
#    2. Verify cascade sync: data written to db_p syncs to db_s1, then to db_s2
#    3. Switchover db_p to standby, db_s1 to primary
#    4. Verify db_s2 continues syncing from new primary (db_s1)
#    5. Switchover db_s1 back to standby, db_p back to primary
#    6. Verify db_s2 continues syncing from db_s1 (which syncs from db_p)

db_p=OBI(cluster=1,proxy_num=0,role=primary);
db_p.reboot;

db_s1=OBI(cluster=1,proxy_num=0,primary=db_p);
db_s1.reboot;

# 等待 db_s1 初始化完成
sleep 5;

# 创建 db_s2，从 db_s1 同步（级联备库）
db_s2=OBI(cluster=1,proxy_num=0,primary=db_s1);
db_s2.reboot;

# 等待集群初始化完成
sleep 5;

#################################################################################################
#########################   Initialization: Verify Topology  ###################################
#################################################################################################
--echo ========== Initialization: Verify Cascade Topology ==========

--disable_query_log
--disable_result_log

# 验证主库集群当前状态为 PRIMARY
db_p.check_until_timeout select count(*) from oceanbase.__all_virtual_server_stat where role = 'PRIMARY', 1, 30;

# 验证备库1集群当前状态为 STANDBY
db_s1.check_until_timeout select count(*) from oceanbase.__all_virtual_server_stat where role = 'STANDBY', 1, 30;

# 验证备库2集群当前状态为 STANDBY
db_s2.check_until_timeout select count(*) from oceanbase.__all_virtual_server_stat where role = 'STANDBY', 1, 30;

# TODO@jingyu.cr: 移除RS上任卸任的流程后，删掉下面三个RS上任的检查
# 验证主集群的RS能成功上任
db_p.z1.obs0.check_log_until_success -c ".*finish do_restart(ret=0,.*";

# 验证备集群1的RS能成功上任
db_p.z1.obs0.check_log_until_success -c ".*finish do_restart(ret=0,.*";

# 验证备集群2的RS能成功上任
db_p.z1.obs0.check_log_until_success -c ".*finish do_restart(ret=0,.*";

# 获取 db_s1 的 svr_ip 和 rpc_port（用于验证 db_s2 的 log_restore_source）
let $db_s1_svr_ip = deploy_get_value(db_s1.select select svr_ip from oceanbase.__all_virtual_server_stat limit 1, svr_ip, 1);
let $db_s1_rpc_port = deploy_get_value(db_s1.select select rpc_port from oceanbase.__all_virtual_server_stat limit 1, rpc_port, 1);

# 验证 db_s2 的 log_restore_source 指向 db_s1（级联关系）
db_s2.check_until_timeout select count(*) from oceanbase.__all_virtual_server_stat where log_restore_source like '%:$db_s1_rpc_port', 1, 30;

--enable_query_log
--enable_result_log

--echo Initialization completed: Cascade topology verified (db_p -> db_s1 -> db_s2)

#################################################################################################
#########################   Case 1: Verify Cascade Sync  #######################################
#################################################################################################
--echo ========== Case 1: Verify Cascade Sync ==========

--disable_query_log
--disable_result_log

# 连接主库
ob_connect(conn_sys_p, db_p.z1.obs0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);
connection conn_sys_p;

--enable_query_log
--enable_result_log

# 在主库创建表和初始数据
create table if not exists test_cascade_standby(id int primary key, name varchar(100), value int);
insert into test_cascade_standby values(1, 'init_data', 100);
insert into test_cascade_standby values(2, 'init_data_2', 200);

--disable_query_log
--disable_result_log

# 触发转储
ALTER SYSTEM MINOR FREEZE;
sleep 5;

# 等待备库1同步完成
db_s1.check_until_timeout select count(*) from test_cascade_standby where id = 1, 1, 120;
db_s1.check_until_timeout select count(*) from test_cascade_standby where id = 2, 1, 30;

# 等待备库2同步完成（级联同步）
db_s2.check_until_timeout select count(*) from test_cascade_standby where id = 1, 1, 180;
db_s2.check_until_timeout select count(*) from test_cascade_standby where id = 2, 1, 60;

--enable_query_log
--enable_result_log

# 验证备库1数据
ob_connect(conn_sys_s1, db_s1.z1.obs0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);
connection conn_sys_s1;
select count(*) from test_cascade_standby;

# 验证备库1的DDL需要失败
--error 4688
create table standby_t1 (c1 int);
--error 4688
call DBMS_AI_SERVICE.CREATE_AI_MODEL('ob_embed', '{"type": "dense_embedding","model_name": "text-embedding-v3"}');

# 2

# 验证备库2数据（级联同步）
ob_connect(conn_sys_s2, db_s2.z1.obs0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);
connection conn_sys_s2;
select count(*) from test_cascade_standby;

# 2

# 验证备库2的DDL需要失败
--error 4688
create table standby_t1 (c1 int);
--error 4688
call DBMS_AI_SERVICE.CREATE_AI_MODEL('ob_embed', '{"type": "dense_embedding","model_name": "text-embedding-v3"}');

--echo Case 1 completed: Cascade sync verified (db_p -> db_s1 -> db_s2)

#################################################################################################
#########################   Case 2: Switchover in Cascade Topology  ###########################
#################################################################################################
--echo ========== Case 2: Switchover in Cascade Topology ==========

--disable_query_log
--disable_result_log

# 设置 db_p 的 log_restore_source 指向 db_s1（为后续切换做准备）
let $db_s1_svr_ip = deploy_get_value(db_s1.select select svr_ip from oceanbase.__all_virtual_server_stat limit 1, svr_ip, 1);
let $db_s1_rpc_port = deploy_get_value(db_s1.select select rpc_port from oceanbase.__all_virtual_server_stat limit 1, rpc_port, 1);

connection conn_sys_p;
eval alter system set log_restore_source = '$db_s1_svr_ip:$db_s1_rpc_port';

# 验证 log_restore_source 设置成功
db_p.check_until_timeout select count(*) from oceanbase.__all_virtual_server_stat where log_restore_source like '%:$db_s1_rpc_port', 1, 30;

--enable_query_log
--enable_result_log

# 在主库写入更多数据
connection conn_sys_p;
insert into test_cascade_standby values(3, 'before_switchover', 300);

--disable_query_log
--disable_result_log

# 等待备库1和备库2同步
db_s1.check_until_timeout select count(*) from test_cascade_standby where id = 3, 1, 120;
db_s2.check_until_timeout select count(*) from test_cascade_standby where id = 3, 1, 180;

--enable_query_log
--enable_result_log

# 执行主库切换为备库
connection conn_sys_p;
ALTER SYSTEM SWITCHOVER TO STANDBY;

--disable_query_log
--disable_result_log

# 验证主库已切换为备库
db_p.check_until_timeout select count(*) from oceanbase.__all_virtual_server_stat where role = 'STANDBY', 1, 60;

# 等待状态稳定
sleep 5;

--enable_query_log
--enable_result_log

# 执行备库1切换为主库
connection conn_sys_s1;
ALTER SYSTEM SWITCHOVER TO PRIMARY;

--disable_query_log
--disable_result_log

# 验证备库1已切换为主库
db_s1.check_until_timeout select count(*) from oceanbase.__all_virtual_server_stat where role = 'PRIMARY', 1, 60;

--enable_query_log
--enable_result_log

# 验证新主库（db_s1）可以执行写操作
connection conn_sys_s1;
insert into test_cascade_standby values(4, 'after_switchover', 400);

--disable_query_log
--disable_result_log

# 等待新备库（db_p）同步
db_p.check_until_timeout select count(*) from test_cascade_standby where id = 4, 1, 120;

# 验证新备库（db_p）的DDL需要失败
connection conn_sys_p;
--error 4688
create table standby_t1 (c1 int);
--error 4688
call DBMS_AI_SERVICE.CREATE_AI_MODEL('ob_embed', '{"type": "dense_embedding","model_name": "text-embedding-v3"}');

# 等待级联备库（db_s2）同步（从 db_s1）
connection conn_sys_s1;
db_s2.check_until_timeout select count(*) from test_cascade_standby where id = 4, 1, 180;

--enable_query_log
--enable_result_log

# 验证级联备库（db_s2）数据一致性
connection conn_sys_s2;
select count(*) from test_cascade_standby;

# 验证级联备库（db_s2）的DDL需要失败
--error 4688
create table standby_t1 (c1 int);
--error 4688
call DBMS_AI_SERVICE.CREATE_AI_MODEL('ob_embed', '{"type": "dense_embedding","model_name": "text-embedding-v3"}');

# 4

--echo Case 2 completed: Switchover in cascade topology verified

#################################################################################################
#########################   Case 3: Roundtrip Switchover in Cascade Topology  ###################
#################################################################################################
--echo ========== Case 3: Roundtrip Switchover in Cascade Topology ==========

--disable_query_log
--disable_result_log

# 设置 db_s1 的 log_restore_source 指向 db_p（为回切做准备）
let $db_p_svr_ip = deploy_get_value(db_p.select select svr_ip from oceanbase.__all_virtual_server_stat limit 1, svr_ip, 1);
let $db_p_rpc_port = deploy_get_value(db_p.select select rpc_port from oceanbase.__all_virtual_server_stat limit 1, rpc_port, 1);

connection conn_sys_s1;
eval alter system set log_restore_source = '$db_p_svr_ip:$db_p_rpc_port';

# 验证 log_restore_source 设置成功
db_s1.check_until_timeout select count(*) from oceanbase.__all_virtual_server_stat where log_restore_source like '%:$db_p_rpc_port', 1, 30;

--enable_query_log
--enable_result_log

# 在新主库（db_s1）写入数据
connection conn_sys_s1;
insert into test_cascade_standby values(5, 'before_roundtrip', 500);

--disable_query_log
--disable_result_log

# 等待同步
db_p.check_until_timeout select count(*) from test_cascade_standby where id = 5, 1, 120;
db_s2.check_until_timeout select count(*) from test_cascade_standby where id = 5, 1, 180;

--enable_query_log
--enable_result_log

# 执行新主库（db_s1）切换为备库
connection conn_sys_s1;
ALTER SYSTEM SWITCHOVER TO STANDBY;

--disable_query_log
--disable_result_log

# 验证 db_s1 已切换为备库
db_s1.check_until_timeout select count(*) from oceanbase.__all_virtual_server_stat where role = 'STANDBY', 1, 60;

# 等待状态稳定
sleep 5;

--enable_query_log
--enable_result_log

# 执行原主库（db_p）切换为主库
connection conn_sys_p;
ALTER SYSTEM SWITCHOVER TO PRIMARY;

--disable_query_log
--disable_result_log

# 验证 db_p 已切换为主库
db_p.check_until_timeout select count(*) from oceanbase.__all_virtual_server_stat where role = 'PRIMARY', 1, 60;

--enable_query_log
--enable_result_log

# 验证新主库（db_p）可以执行写操作
connection conn_sys_p;
insert into test_cascade_standby values(6, 'after_roundtrip', 600);

--disable_query_log
--disable_result_log

# 等待备库1（db_s1）同步
db_s1.check_until_timeout select count(*) from test_cascade_standby where id = 6, 1, 120;

# 等待级联备库（db_s2）同步（从 db_s1）
db_s2.check_until_timeout select count(*) from test_cascade_standby where id = 6, 1, 180;

--enable_query_log
--enable_result_log

# 验证所有集群数据一致性
connection conn_sys_p;
select count(*) from test_cascade_standby;
# 6

connection conn_sys_s1;
select count(*) from test_cascade_standby;
# 6

connection conn_sys_s2;
select count(*) from test_cascade_standby;
# 6

--echo Case 3 completed: Roundtrip switchover in cascade topology verified

#################################################################################################
#########################   Case 4: Failover in Cascade Topology  #############################
#################################################################################################
--echo ========== Case 4: Failover in Cascade Topology ==========

--disable_query_log
--disable_result_log

# 当前状态：db_p (PRIMARY), db_s1 (STANDBY from db_p), db_s2 (STANDBY from db_s1)

# 在主库写入数据
connection conn_sys_p;
insert into test_cascade_standby values(7, 'before_failover', 700);

# 等待同步
db_s1.check_until_timeout select count(*) from test_cascade_standby where id = 7, 1, 120;
db_s2.check_until_timeout select count(*) from test_cascade_standby where id = 7, 1, 180;

--enable_query_log
--enable_result_log

# 执行备库1（db_s1）failover 为主库
connection conn_sys_s1;
ALTER SYSTEM ACTIVATE STANDBY;

--disable_query_log
--disable_result_log

# 验证 db_s1 已 failover 为主库
db_s1.check_until_timeout select count(*) from oceanbase.__all_virtual_server_stat where role = 'PRIMARY', 1, 60;

--enable_query_log
--enable_result_log

# 验证新主库（db_s1）可以执行写操作
connection conn_sys_s1;
insert into test_cascade_standby values(8, 'after_failover', 800);

--disable_query_log
--disable_result_log

# 等待级联备库（db_s2）同步（从 db_s1）
db_s2.check_until_timeout select count(*) from test_cascade_standby where id = 8, 1, 180;

--enable_query_log
--enable_result_log

# 验证级联备库（db_s2）数据一致性
connection conn_sys_s2;
select count(*) from test_cascade_standby;
# 8

# 验证原主库（db_p）状态（failover 后应该还是 PRIMARY）
db_p.check_until_timeout select count(*) from oceanbase.__all_virtual_server_stat where role = 'PRIMARY', 1, 30;

--echo Case 4 completed: Failover in cascade topology verified

#################################################################################################
#########################   Summary  ###########################################################
#################################################################################################
--echo ========== Test Summary ==========
--echo All cascade standby test cases completed successfully:
--echo   1. Cascade sync verification (db_p -> db_s1 -> db_s2): PASSED
--echo   2. Switchover in cascade topology: PASSED
--echo   3. Roundtrip switchover in cascade topology: PASSED
--echo   4. Failover in cascade topology: PASSED
--echo Cascade standby topology verified successfully
