#rs
#msy164651
#测试点：创建partition失败之后，还是可以推高一次schema version，可以保证gc掉废弃的partition
ob1=OBI(cluster=1, proxy_num = 0);
ob1.reboot;
ob_connect(conn1, ob1.z1.obs0, root@sys, , oceanbase, , USE_OB_CONNECTOR);
connection conn1;
ob1.mysql CREATE RESOURCE POOL pool_1 UNIT = 'sys_unit_config', UNIT_NUM = 1, ZONE_LIST = ('z1');
ob1.mysql CREATE TENANT tt RESOURCE_POOL_LIST = ('pool_1'), primary_zone='z1' set ob_tcp_invited_nodes='%';
sleep 3;
ob_connect(conn2, ob1.z1.obs0, root@tt, , test, , USE_OB_CONNECTOR);
connection conn2;
create table t1(c1 int primary key, c2 int) partition by range(c1)(partition p0 values less than (10));
let $schema_version = query_get_value( select max(schema_version) as c from oceanbase.__all_ddl_operation, c, 1);
connection conn1;
alter system set_tp tp_no = 82, error_code = 4013, frequency = 1;
connection conn2;
#建表失败
--error 4013
create table t2(c1 int primary key, c2 int);
eval select tenant_id, operation_type from oceanbase.__all_ddl_operation where schema_version > $schema_version;
#create table like
let $schema_version = query_get_value( select max(schema_version) as c from oceanbase.__all_ddl_operation, c, 1);
--error 4013
create table t2 like t1;
eval select tenant_id, operation_type from oceanbase.__all_ddl_operation where schema_version > $schema_version;
#建tablegroup失败
let $schema_version = query_get_value( select max(schema_version) as c from oceanbase.__all_ddl_operation, c, 1);
--error 4013
create tablegroup pg binding = true;
eval select tenant_id, operation_type from oceanbase.__all_ddl_operation where schema_version > $schema_version;

#建tenant 失败
connection conn1;
CREATE RESOURCE POOL pool_2 UNIT = 'sys_unit_config', UNIT_NUM = 1, ZONE_LIST = ('z1');
let $schema_version = query_get_value( select max(schema_version) as c from oceanbase.__all_ddl_operation , c, 1);
--error 4013
CREATE TENANT tt2 RESOURCE_POOL_LIST = ('pool_2'), primary_zone='z1' set ob_tcp_invited_nodes='%';
eval select tenant_id, operation_type from oceanbase.__all_ddl_operation where schema_version > $schema_version;
connection conn2;
#增加分区失败
let $schema_version = query_get_value( select max(schema_version) as c from oceanbase.__all_ddl_operation, c, 1);
--error 4013
alter table t1 add partition (partition p1 values less than (100));
eval select tenant_id, operation_type from oceanbase.__all_ddl_operation where schema_version > $schema_version;
#truncate table失败
let $schema_version = query_get_value( select max(schema_version) as c from oceanbase.__all_ddl_operation, c, 1);
--error 4013
truncate table t1;
eval select tenant_id, operation_type from oceanbase.__all_ddl_operation where schema_version > $schema_version;
connection conn1;
alter system set_tp tp_no = 82, error_code = 4013, frequency = 0;
