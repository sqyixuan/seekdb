ob1=OBI(cluster=1,proxy_num=0);

let $extra_conf = "cpu_count=16,memory_limit='20G',system_memory='5G',__min_full_resource_pool_memory='268435456',cache_wash_threshold='1G'";
ob1.z1.obs0.set extra_config=_enable_defensive_check=false,$extra_conf;
ob1.reboot;
sleep 3;

ob_connect(conn_sys, ob1.z1.obs0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);
ob_connect(conn_sys_new, ob1.z1.obs0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);

connection conn_sys;

let $cpu = 1;
let $memory = 268435456;
let $min_memory = 268435456;
let $disk = 536870912;
let $iops = 100000;
let $session = 64;

set @@session.ob_query_timeout = 1000000000;
eval CREATE RESOURCE UNIT unit_1 MAX_CPU $cpu, MAX_MEMORY $memory, MAX_IOPS $iops, MAX_DISK_SIZE $disk, MAX_SESSION_NUM $session, MIN_CPU=1, MIN_MEMORY=$min_memory, MIN_IOPS=128;
eval CREATE RESOURCE POOL pool_1 UNIT = 'unit_1', UNIT_NUM = 1;
eval CREATE TENANT mysql RESOURCE_POOL_LIST = ('pool_1'), primary_zone='z1' set ob_tcp_invited_nodes='%';

# get current session_id
let $session_id = `select id from oceanbase.__all_virtual_processlist where info is not null`;

--disable_query_log
eval select count(*) from oceanbase.__all_virtual_processlist where id = $session_id;
--enable_query_log

alter system set_tp tp_no = 182, error_code = 4016, frequency = 1;
# err ret will be overwrite
--error 5066
alter system change tenant mysql;

connection conn_sys_new;
--disable_query_log
eval select count(*) from oceanbase.__all_virtual_processlist where id = $session_id;
--enable_query_log

