# owner: wenduo
# description:
# 本case模拟磁盘故障时，rs主动stop server的场景；

ob1=OBI(cluster=1:1:1,proxy_num=1,init_unit_cpu=0);
ob1.reboot;
sleep 15;

let $proxy_ip = deploy_get_value(ob1.proxy0.ip);
let $proxy_port = deploy_get_value(ob1.proxy0.port);

connect(sys_conn, $proxy_ip, root@sys,,oceanbase, $proxy_port);
connection sys_conn;

select * from oceanbase.__all_server where stop_time != 0;
alter system set enable_disk_error_test = 'true';
ob1.check_until_timeout select count(*) c from oceanbase.__all_server where stop_time != 0, 1, 360;
select zone from oceanbase.__all_server where stop_time != 0;
alter system set enable_disk_error_test = 'false';
ob1.check_until_timeout select count(*) c from oceanbase.__all_server where stop_time != 0, 0, 360;
