###设置错误注入点；并且等待超时；
ob1.z1.obs0.mysql set @@global.ob_query_timeout = 10000000;
ob1.z1.obs0.mysql alter system set_tp tp_no=39, error_code=4012,frequency =1;
ob1.mysql alter system set debug_sync_timeout = '10s';
ob1.z1.obs0.mysql set ob_global_debug_sync = 'UNIT_MANAGER_WAIT_FOR_TIMEOUT wait_for begin timeout 10000000';  

let $case_index = 5;
ob1.create_client tenant=sys,user=root,passwd=,database=oceanbase;
ob1.mysql CREATE RESOURCE UNIT unit_$case_index MAX_CPU $cpu, MAX_MEMORY $memory, MAX_IOPS $iops, MAX_DISK_SIZE $disk, MAX_SESSION_NUM $session, MIN_CPU=1, MIN_MEMORY=$min_memory, MIN_IOPS=128;
--error 4012
eval CREATE RESOURCE POOL pool_$case_index UNIT = 'unit_$case_index', UNIT_NUM = 2, ZONE_LIST = ('z1', 'z2','z3');
#ob1.mysql CREATE TENANT tenant_$case_index RESOURCE_POOL_LIST = ('pool_$case_index'), locality='F@z1,F@z2,F@z3', primary_zone='z1;z2;z3' set ob_tcp_invited_nodes='%';
sleep 2;
--error 4651
eval CREATE RESOURCE POOL pool_$case_index UNIT = 'unit_$case_index', UNIT_NUM = 2, ZONE_LIST = ('z1', 'z2','z3');
ob1.mysql alter system set debug_sync_timeout = '0';
ob1.z1.obs0.mysql alter system set_tp tp_no=39, error_code=4012,frequency =0;
let $case_index = 6;
eval CREATE RESOURCE POOL pool_$case_index UNIT = 'unit_5', UNIT_NUM = 2, ZONE_LIST = ('z1', 'z2','z3');
ob1.z1.obs0.force_stop;
sleep 10;
ob1.z2.obs0.mysql select count(*) from oceanbase.__all_virtual_core_meta_table;
ob1.z1.obs0.start;
###等待主切到z1;
ob1.check_until_timeout select count(*) from __all_server where with_rootserver=1 and zone = 'z1', 1, 60;
ob1.check_until_timeout select count(*)>0 from oceanbase.__all_virtual_core_meta_table,1, 60;



