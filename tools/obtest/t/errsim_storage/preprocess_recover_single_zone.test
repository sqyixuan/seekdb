# owner: yunshan.tys
# owner group: storage
# description: this case is used for testing  fast recovery for single zone
#

ob1=OBI(cluster=3,proxy_num=0,init_unit_cpu=1, init_unit_num=1);
ob1.reboot;
ob1.mysql alter resource pool obtestpool unit_num 1;
ob1.mysql alter system set enable_rebalance=false;
ob1.mysql alter system set enable_ilog_recycle = false;
ob1.mysql alter system set ilog_flush_trigger_time='10s';
ob1.mysql alter system set migrate_concurrency = 0;
ob1.mysql alter system set server_permanent_offline_time = 40;

let $sys_ip = deploy_get_value(ob1.z1.obs0.ip);
let $sys_port = deploy_get_value(ob1.z1.obs0.mysql_port);
sleep 10;
connect(sys_conn, $sys_ip, root@sys,,oceanbase, $sys_port);
let $tenant_id = query_get_value(select tenant_id from oceanbase.__all_tenant where tenant_name='obtest', tenant_id, 1);

let $meta_host = deploy_get_value(ob1.select select concat(svr_ip,':',svr_port) host from __all_unit  a inner join __all_resource_pool b where  a.resource_pool_id=b.resource_pool_id and b.tenant_id=$tenant_id, host, 1);
let $meta_port = deploy_get_value(ob1.select select svr_port from __all_unit  a inner join __all_resource_pool b where  a.resource_pool_id=b.resource_pool_id and b.tenant_id=$tenant_id, svr_port, 1);

let $meta_addr = deploy_get_value(ob1.get_obs_by_addr $meta_host);
let $meta_ip = deploy_get_value($meta_addr.ip);


ob1.mysql alter resource pool obtestpool unit_num 2;
ob1.check_until_timeout select count(1) from __all_unit  a inner join __all_resource_pool b where  a.resource_pool_id=b.resource_pool_id and b.tenant_id=$tenant_id, 2, 60;
sleep 10;

let $stop_host = deploy_get_value(ob1.select select concat(svr_ip,':',svr_port) host from __all_unit a inner join __all_resource_pool b where  a.resource_pool_id=b.resource_pool_id and b.tenant_id=$tenant_id order by unit_id desc limit 1, host, 1);
let $stop_port = deploy_get_value(ob1.select select svr_port from __all_unit  a inner join __all_resource_pool b where  a.resource_pool_id=b.resource_pool_id and b.tenant_id=$tenant_id order by unit_id desc limit 1, svr_port, 1);

let $stop_addr = deploy_get_value(ob1.get_obs_by_addr $stop_host);
let $stop_ip = deploy_get_value($stop_addr.ip);

let $ip = deploy_get_value(ob1.z1.obs1.ip);
let $port = deploy_get_value(ob1.z1.obs1.mysql_port);
connect(mysql_conn, $ip, root@obtest,,test, $port);


connection mysql_conn;
set ob_trx_timeout=100000000;
set ob_query_timeout=100000000;
--disable_warnings
drop table if exists tt;
--enable_warnings

create table tt(a int primary key) partition by hash(a) partitions 10;
let $cnt = 1;
--disable_query_log
while ($cnt <= 200)
{
  eval insert into tt values($cnt);
  inc $cnt;
}
select count(*) from tt;

sleep 15;

let $cnt = 400;
while ($cnt <= 600)
{
  eval insert into tt values($cnt);
  inc $cnt;
}
--enable_query_log
select count(*) from tt;

connection sys_conn;
let $part_cnt = deploy_get_value(ob1.select select count(*) count from __all_virtual_meta_table where zone = "z1", count, 1);

$stop_addr.force_stop;
ob1.check_until_timeout select status from oceanbase.__all_server where svr_ip = "$stop_ip" and svr_port = "$stop_port", inactive, 6000;
ob1.check_until_timeout select count(*) from __all_rootservice_event_history where module = 'server_fast_recovery' and value1 like '%$stop_ip:$stop_port%' and value3 = '0', 1, 60000000;
ob1.check_until_timeout select count(*) from __all_rootservice_event_history where module = 'server_fast_recovery' and value1 like '%$stop_ip:$stop_port%' and event = 'finish_recovery', 1, 60000000;
ob1.check_until_timeout select count(*) from __all_virtual_meta_table where zone = "z1", $part_cnt, 60000000;
