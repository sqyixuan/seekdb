# owner:yongle.xh
# owner group:storage
ob1=OBI(cluster=1:1:1, proxy_num=0, init_unit_cpu=2);
ob1.reboot;
sleep 5;

ob1.mysql alter system set merger_check_interval='10s';
ob1.mysql alter system set enable_rebalance = 'false';
ob1.mysql alter system set resource_hard_limit=500;
ob1.mysql alter system set balancer_idle_time='10s';
ob1.mysql alter system set debug_sync_timeout = '100000s';

let $leader_host = deploy_get_value(ob1.select select concat(svr_ip,':', svr_port) host from __all_server where zone='z1', host, 1);
let $leader = deploy_get_value(ob1.get_obs_by_addr $leader_host);
let $follow_host = deploy_get_value(ob1.select select concat(svr_ip,':', svr_port) host from __all_server where zone='z2', host, 1);
let $follower_1 = deploy_get_value(ob1.get_obs_by_addr $follow_host);

let $ip = deploy_get_value($leader.ip);
let $mysql_port = deploy_get_value($leader.mysql_port);
let $port = deploy_get_value($leader.port);

connect(conn1, $ip, admin, admin, oceanbase, $mysql_port);
connection conn1;
ob1.create_client tenant=obtest,user=admin,passwd=admin,database=test;
# 新建一张表
create tablegroup tg1 binding true;
create table t1(c1 int, c2 int) primary_zone='z1' tablegroup tg1;
let $table_id = deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where table_name='t1', table_id, 1);
sleep 5;
$follower_1.mysql alter system set_tp tp_no = 91, error_code = 4013, frequency = 1;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table_mgr where table_id=$table_id, 3, 10;
let $pg_id = deploy_get_value(ob1.select select tablegroup_id from __all_virtual_tablegroup where tablegroup_name='tg1', tablegroup_id, 1);

# 打开配置项开关，只要落后日志，就会触发rebuild
ob1.mysql alter system set _ob_enable_rebuild_on_purpose=true;
sleep 3;
create table t2(c1 int, c2 int) primary_zone='z1' tablegroup tg1;
let $table_id2 = deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where table_name='t2', table_id, 1);
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table_mgr where table_id=$table_id2, 1, 10;

# 阻塞leader和一个副本之间的网络
$leader.block_net $follower_1;

# 插入一行数据，leader和follower2形成majority，follower1未收到此日志
insert into t1 values(1, 1);
ob1.mysql alter system minor freeze tenant obtest server = ('$leader_host');

# 等待日志在leader和follower2形成多数派
sleep 5;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table_mgr where table_type=0 and is_active=0 and svr_ip='$ip' and svr_port=$port, 0, 90;
sleep 5;


# 恢复网络，follower1会向leader获取日志，leader通知follower1需要执行rebuild；需要sleep 5
$leader.clean_net $follower_1;

# 等待follower1向leader拉取日志，触发rebuild，并汇报到__all_meta_table
sleep 5;

# 预期这张个replica需要执行rebuild

ob1.check_until_timeout select count(*) from __all_virtual_partition_migration_status  where migrate_type = 'REBUILD_REPLICA_OP' and result = 0 and action='END' and table_id=$pg_id, 1, 180;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table_mgr where table_id=$table_id2 and table_type=1, 2, 10;
$follower_1.mysql alter system set_tp tp_no = 91, error_code = 4013, frequency = 0;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table_mgr where table_id=$table_id2 and table_type=1, 3, 10;

ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_meta_table where rebuild=1, 0, 180;
sleep 2;

insert into t1 values(2, 1);
insert into t2 values(2, 1);

ob1.mysql alter system major freeze;
sleep 30;
ob1.check_version 2;
select * from t1;
select * from t2;
