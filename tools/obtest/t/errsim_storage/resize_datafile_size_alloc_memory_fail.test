# owner: zhenjiang.xzj
# owner group: storage
# Test the case: multi scan query
ob1=OBI(cluster=1, proxy_num=0,init_unit_cpu=2);
ob1.reboot;
let $ip0=deploy_get_value(ob1.z1.obs0.ip);
let $sql_port0=deploy_get_value(ob1.z1.obs0.mysql_port);
let $ip1=deploy_get_value(ob1.z2.obs0.ip);
let $sql_port1=deploy_get_value(ob1.z2.obs0.mysql_port);
ob1.mysql alter system set resource_hard_limit=800;
ob1.mysql alter system set merger_switch_leader_duration_time=0;
ob1.mysql alter system set enable_auto_leader_switch=false;
ob1.mysql alter system set enable_rereplication=false;
ob1.mysql alter system set enable_rebalance=false;
ob1.mysql alter system set bf_cache_miss_count_threshold=5;
connect(conn0,$ip0,root@obtest,,test,$sql_port0);
connect(conn1,$ip0,root@sys,,oceanbase,$sql_port0);
connection conn1;
ob1.z1.obs0.mysql alter system set_tp tp_no = 235, error_code = 4016, frequency = 1;
let $resize_size=deploy_get_value(ob1.select select concat(4 * total_count, "M") as block_file_size from __all_virtual_macro_block_marker_status, block_file_size, 1);
ob1.mysql alter system set datafile_size = '$resize_size';
sleep 10;
ob1.z1.obs0.check_log_until_success -c "error sim, alloc memory failed";
ob1.z1.obs0.mysql alter system set_tp tp_no = 235, error_code = 4016, frequency = 0;
ob1.mysql alter system set datafile_size = '$resize_size';
ob1.check_until_timeout select concat(2 * total_count, "M") as block_file_size from __all_virtual_macro_block_marker_status, $resize_size, 120;
