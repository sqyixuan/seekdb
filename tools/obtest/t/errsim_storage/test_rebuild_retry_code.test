# owner: debin.jdb
# owner group: clog
# description: 测试rebuild重试机制
##
ob1=OBI(cluster=2:2:2, init_unit_cpu=11, init_unit_num=2, proxy_num=0);
ob1.reboot;
sleep 5;

let $rs = deploy_get_value(ob1.get_leader sys:oceanbase:__all_core_table:0);
let $ip=deploy_get_value($rs.ip);
let $port=deploy_get_value($rs.mysql_port);
connect (conn_sys,$ip,root,,oceanbase,$port);

let $obs = deploy_get_value(ob1.get_leader obtest:oceanbase:__all_dummy:0);
let $ip=deploy_get_value($obs.ip);
let $port=deploy_get_value($obs.mysql_port);
connect (conn_obtest,$ip,root@obtest,,test,$port);

connection conn_sys;
alter system set enable_rebalance=false;
alter system set enable_rereplication=false;
alter system set balancer_idle_time='10s';

ob1.mysql alter tenant obtest set variables ob_tcp_invited_nodes='%';
# 给两个follower注入错误：
# 1）ObMigratePrepareTask::gen_rebuild_task会返回-4016；
# 2）pls->restore_replayed_log() 会返回-4016;
#    PS：实际并不会调用到，因为上面的注入导致不生成ObMigrateFinishTask.
ob1.z3.obs0.mysql alter system set_tp tp_no = 60, error_code = 4016, frequency = 1;
ob1.z3.obs0.mysql alter system set_tp tp_no = 61, error_code = 4016, frequency = 1;
ob1.z3.obs1.mysql alter system set_tp tp_no = 60, error_code = 4016, frequency = 1;
ob1.z3.obs1.mysql alter system set_tp tp_no = 61, error_code = 4016, frequency = 1;
ob1.z2.obs0.mysql alter system set_tp tp_no = 60, error_code = 4016, frequency = 1;
ob1.z2.obs0.mysql alter system set_tp tp_no = 61, error_code = 4016, frequency = 1;
ob1.z2.obs1.mysql alter system set_tp tp_no = 60, error_code = 4016, frequency = 1;
ob1.z2.obs1.mysql alter system set_tp tp_no = 61, error_code = 4016, frequency = 1;

connection conn_obtest;
# 新建一张表
create table t1(c1 int, c2 int) primary_zone='z1';
sleep 5;

# 保证obtest租户上的用户表和系统表不在一台server上
let $tid=deploy_get_value(ob1.select select table_id from __all_virtual_table where table_name='t1', table_id, 1);

# 将t1迁到z3一个单独的sever上,以便仅让它自己触发rebuild.
let $expect_host=deploy_get_value(ob1.select select concat(svr_ip,':',svr_port) as host from __all_server where zone='z3' except select distinct concat(svr_ip,':',svr_port) from __all_virtual_partition_table where table_id!='$tid' and zone='z3', host, 1);
let $actual_host=deploy_get_value(ob1.select select concat(svr_ip,':',svr_port) as host from __all_virtual_meta_table where table_id='$tid' and zone='z3', host, 1);
echo $expect_host;
echo $actual_host;
if($actual_host != $expect_host)
{
    connection conn_sys;
    let $expect = deploy_get_value(ob1.get_obs_by_addr $expect_host);
    let $actual = deploy_get_value(ob1.get_obs_by_addr $actual_host);
    $actual.migrate_to $expect,obtest:test:t1;
    sleep 5;
    ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_clog_stat where table_id=$tid and concat(svr_ip,':',svr_port) = '$expect_host', 1, 60;
}

connection conn_sys;
# 打开配置项开关，只要落后日志，就会触发rebuild
alter system set trigger_rebuild_on_purpose=true;
# 关闭rs的rebuild调度
alter system set __balance_controller='{"ENABLE_REBUILD":"false"}';

# 获取t1表的leader和follower
let $leader=deploy_get_value(ob1.get_leader obtest:test:t1);
let $leader_ip=deploy_get_value($leader.ip);
let $leader_port=deploy_get_value($leader.port);
# let $follower_1=deploy_get_value(ob1.get_follower obtest:test:t1,1);
let $follower_1 = deploy_get_value(ob1.get_obs_by_addr $expect_host);
let $follower1_host=deploy_get_value($follower_1.ip);
let $follower1_port=deploy_get_value($follower_1.port);

# 阻塞leader和一个副本之间的网络
$leader.block_net $follower_1;
# sleep 等待生效
sleep 5;

connection conn_obtest;
# 插入10行数据，leader和follower2形成majority，follower1未收到此日志
let $cnt=10;
while($cnt>0)
{
    eval insert into t1 values($cnt, $cnt);;
    dec $cnt;
}
# 等待日志在leader和follower2形成多数派
sleep 5;

ob1.mysql alter system minor freeze tenant obtest server = ('$leader_ip:$leader_port');
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table_mgr where table_id=$tid and svr_ip = "$leader_ip" and svr_port = '$leader_port' and table_type=4 and size > 0, 1, 60;

# 恢复网络，follower1会向leader获取日志，leader通知follower1需要执行rebuild；需要sleep 5
$leader.clean_net $follower_1;
sleep 5;

# 确认follower1的rebuild标记为1
ob1.check_until_timeout select count(*) c from oceanbase.__all_virtual_clog_stat where svr_ip = '$follower1_host' and svr_port = '$follower1_port' and table_id = '$tid' and is_need_rebuild = 1, 1, 120;
# ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_clog_stat where table_id='$tid' and svr_ip='$follower1_host' and svr_port='$follower1_port' and rebuild = 1, 1, 120;

## 打开rebuild
connection conn_sys;
alter system set __balance_controller='';

# 等待执行
sleep 30;
# 确认clog为offline状态
ob1.check_until_timeout select count(*) c from oceanbase.__all_virtual_clog_stat where svr_ip = '$follower1_host' and svr_port = '$follower1_port' and table_id = '$tid' and is_offline = 1, 1, 120;
# 确认partition的need_rebuild标记为1
ob1.check_until_timeout select count(*) c from oceanbase.__all_virtual_partition_info where svr_ip = '$follower1_host' and svr_port = '$follower1_port' and table_id = '$tid' and is_need_rebuild = 1, 1, 120;
let $rebuild_cnt = deploy_get_value(ob1.select select count(*) c from oceanbase.__all_rootservice_event_history where module='balancer' and event='finish_rebuild_replica' and value1 like "%$tid%" and value3 like '%$follower1_host:$follower1_port%', c, 1);

# 关闭错误注入
ob1.mysql alter system set trigger_rebuild_on_purpose=false;
ob1.z3.obs0.mysql alter system set_tp tp_no = 61, error_code = 4016, frequency = 0;
ob1.z3.obs1.mysql alter system set_tp tp_no = 61, error_code = 4016, frequency = 0;
ob1.z2.obs0.mysql alter system set_tp tp_no = 61, error_code = 4016, frequency = 0;
ob1.z2.obs1.mysql alter system set_tp tp_no = 61, error_code = 4016, frequency = 0;
ob1.z3.obs0.mysql alter system set_tp tp_no = 60, error_code = 4016, frequency = 0;
ob1.z3.obs1.mysql alter system set_tp tp_no = 60, error_code = 4016, frequency = 0;
ob1.z2.obs0.mysql alter system set_tp tp_no = 60, error_code = 4016, frequency = 0;
ob1.z2.obs1.mysql alter system set_tp tp_no = 60, error_code = 4016, frequency = 0;

