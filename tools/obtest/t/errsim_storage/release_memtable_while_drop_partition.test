#owner : weixue.cx
#group : storage
#description: test if memtable can be released while partition drop

--disable_query_log
ob1=OBI(cluster=1:1:1,proxy_num=0,init_unit_cpu=2);
ob1.reboot;
sleep 5;


let $ip=deploy_get_value(ob1.z1.obs0.ip);
let $port=deploy_get_value(ob1.z1.obs0.mysql_port);
connect (conn1,$ip,admin@obtest,admin,oceanbase,$port);
connect (conn2,$ip,root@sys,,oceanbase,$port);

ob1.mysql alter system major freeze;
ob1.check_version 2;


# step 1: create binding pg
connection conn1;
use test;

create tablegroup test_tg binding true;
create table t1 (c1 int primary key, c2 int) tablegroup test_tg;
create table t2 (c1 int primary key, c2 int) tablegroup test_tg;
insert into t1 values (1,1), (2,2);
insert into t2 values (1,1), (2,2);

# step 2: create standalone pg
create table test (c1 int primary key, c2 int);
insert into test values (1,1), (2,2);

# step 3: inject fault
ob1.mysql alter system set_tp tp_no = 106, error_code = 4002, frequency = 1;
ob1.mysql alter system set_tp tp_no = 107, error_code = 4002, frequency = 1;

# step 4: drop partition
drop table t2;
drop table test;
purge recyclebin;

sleep 5;

alter table t1 add column c3 int;
insert into t1 values (3,3,3);

sleep 60;

# step 5: minor freeze
ob1.mysql alter system minor freeze tenant = sys;
ob1.mysql alter system minor freeze tenant = all_user;
ob1.mysql alter system minor freeze tenant = all_meta;

# step 6: check if memtable released
ob1.check_until_timeout select count(1) from oceanbase.__all_virtual_table_mgr where table_type = 0 and is_active = 0, 0, 120;
