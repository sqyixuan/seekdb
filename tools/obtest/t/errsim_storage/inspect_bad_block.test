# owner:jianyun.sjy
# owner group:storage
#--disable_query_log
ob1=OBI(cluster=1:1:1, proxy_num=0, init_unit_cpu=4);
ob1.reboot;

ob1.mysql alter system set merger_check_interval = '10s';
ob1.mysql alter system set enable_rebalance = 'false';
ob1.mysql alter system set debug_sync_timeout = '500s';
#ob1.mysql alter resource pool obtestpool unit_num 2;

# create user and table
ob1.create_client tenant=obtest, user=root, database=test;
create table test01 (pk1 int, pk2 int, pk3 int, f1 varchar(1024), f2 varchar(4096), primary key(pk1, pk2, pk3), index i1(f1));
insert into test01(pk1, pk2, pk3, f1, f2) values(1,1,1,'1','1');


let $table_id = deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where table_name='test01', table_id, 1);
let $host_ip = deploy_get_value(ob1.select select concat(svr_ip, ':', svr_port) host from oceanbase.__all_virtual_meta_table where table_id=$table_id and role=1, host, 1);
let $host = deploy_get_value(ob1.get_obs_by_addr $host_ip);

let $bad_block_count = deploy_get_value(ob1.select select count(*) c from oceanbase.__all_virtual_bad_block_table, c, 1);
if ($bad_block_count == 0)
{
  echo "Not found any bad block";
}
$host.mysql alter system set_tp tp_no = 55, error_code = 4103, frequency = 1;
ob1.mysql alter system major freeze;
ob1.check_version 2;
$host.check_log_until_success -c "Found a bad block";
let $bad_block_count = deploy_get_value(ob1.select select count(*) c from oceanbase.__all_virtual_bad_block_table, c, 1);
if ($bad_block_count > 0)
{
  echo "Found bad blocks";
}
$host.mysql alter system set_tp tp_no = 55, error_code = 4103, frequency = 0;

