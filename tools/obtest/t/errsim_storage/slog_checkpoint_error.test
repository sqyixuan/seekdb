# owner: gaishun.gs
# owner group: storage
# test rollback slog checkpoint

ob1=OBI(cluster=1,proxy_num=0,init_unit_cpu=2, init_unit_num=1);
ob1.reboot;
let $ip0=deploy_get_value(ob1.z1.obs0.ip);
let $port0=deploy_get_value(ob1.z1.obs0.mysql_port);
let $rpc_port=deploy_get_value(ob1.select select svr_port from DBA_OB_UNITS where zone = 'z1' limit 1, svr_port, 1);
ob1.mysql alter system minor freeze tenant = sys;
ob1.mysql alter system minor freeze tenant = all_user;
ob1.mysql alter system minor freeze tenant = all_meta;

connect (conn1,$ip0,root@sys,,oceanbase,$port0);
connection conn1;

alter system set_tp tp_no = 218, error_code = 4725, frequency = 1;
--disable_query_log
--error 4012
eval alter system checkpoint slog tenant_id = 1 server = '$ip0:$rpc_port';
--enable_query_log
ob1.z1.obs0.check_log_until_success -c "finsh checkpoint rollback(ret=0";
