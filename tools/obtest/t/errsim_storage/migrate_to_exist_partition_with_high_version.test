# owner: yongle.xh
# owner group: storage
# description: this case is use for migrate_rebuild_during_wait_replay
#

--disable_query_log
ob1=OBI(cluster=2:2:2,proxy_num=0,init_unit_cpu=2, init_unit_num=2);
ob1.reboot;

#设置灰度切主的时间为0, 关闭自动切主，关闭自动balance
ob1.mysql alter system set resource_hard_limit = 800;
ob1.mysql alter system set merger_switch_leader_duration_time=0;
ob1.mysql alter system set enable_auto_leader_switch = false;
ob1.mysql alter system set enable_rereplication = false;
ob1.mysql alter system set enable_rebalance = false;
ob1.mysql alter system set debug_sync_timeout = '100000s';
let $ip = deploy_get_value(ob1.z1.obs0.ip);
let $port = deploy_get_value(ob1.z1.obs0.mysql_port);

ob1.create_client tenant=obtest,user=root,passwd=,database=test;

create table test01(c1 int, c2 int, c3 varchar(4096), primary key(c1)) primary_zone='z1';

let $cnt=1;
while($cnt < 10)
{
  eval insert into test01 values($cnt, $cnt, 'oceanbase');
  inc $cnt;
}

ob1.mysql alter system major freeze;
ob1.check_version 2;

# another merge process
while ($cnt < 20)
{
  eval insert into test01 values($cnt, $cnt, 'oceanbase');
  inc $cnt;
}

ob1.mysql alter system suspend merge zone 'z1';
ob1.mysql alter system suspend merge zone 'z3';
ob1.mysql alter system major freeze;
ob1.z2.check_version 3;

let $tenant_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name='obtest', tenant_id, 1);
let $table_id = deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where table_name='test01', table_id, 1);
let $src_host = deploy_get_value(ob1.select select concat(svr_ip, ':', svr_port) host from oceanbase.__all_virtual_meta_table where zone='z2' and table_id=$table_id, host, 1);
let $src = deploy_get_value(ob1.get_obs_by_addr $src_host);
let $src_ip = deploy_get_value($src.ip);
let $dst_host = deploy_get_value(ob1.select select concat(svr_ip, ':', svr_port) host from oceanbase.__all_unit where zone='z2' and svr_ip != '$src_ip' and resource_pool_id = 1001, host, 1);
let $dst = deploy_get_value(ob1.get_obs_by_addr $dst_host);
let $dst_ip = deploy_get_value($dst.ip);
let $member_list = deploy_get_value(ob1.select select member_list from oceanbase.__all_virtual_meta_table where table_id = $table_id and role = 1, member_list, 1);
let $version = deploy_get_value(ob1.select select data_version from oceanbase.__all_virtual_meta_table where table_id = $table_id and role=1, data_version, 1);

#失败的迁移，构造本地有版本为3的partition 
$dst.mysql alter system set_tp tp_no = 11, error_code = 4019, frequency = 1;
sleep 3;
$src.migrate_to $dst,obtest:test:test01;
sleep 3;
ob1.mysql_p select value4 from oceanbase.__all_rootservice_event_history where module='balancer' and event = 'finish_migrate_replica' and value1 like "%$table_id%" and value2 like '%$src_ip%' and value3 like '%$dst_ip%' and value5 like '%$src_ip%';

#迁入源端为版本2的partition 
let $src_host = deploy_get_value(ob1.select select concat(svr_ip, ':', svr_port) host from oceanbase.__all_virtual_meta_table where zone='z1' and table_id=$table_id, host, 1);
let $src = deploy_get_value(ob1.get_obs_by_addr $src_host);
let $src_ip = deploy_get_value($src.ip);
$dst.mysql alter system set_tp tp_no = 11, error_code = 4019, frequency = 0;
$src.copy_to $dst,obtest:test:test01;

sleep 3;
ob1.mysql_p select value4 from oceanbase.__all_rootservice_event_history where module='balancer' and event = 'finish_add_replica' and value1 like "%$table_id%" and value2 like '%$src_ip%' and value3 like '%$dst_ip%' and value5 like '%$src_ip%';

ob1.mysql alter system resume merge zone 'z1';
ob1.mysql alter system resume merge zone 'z3';
ob1.check_version 3;

ob1.mysql alter system major freeze;
ob1.check_version 4;

ob1.mysql_p select count(*) from oceanbase.__all_virtual_concurrency_object_pool where free_list_name like '%ObPartitionBaseDataInfo%' and count != 0;
ob1.mysql_p select count(*) from oceanbase.__all_virtual_concurrency_object_pool where free_list_name like '%ObPartitionMacroBlockObReader%' and count != 0;
ob1.mysql_p select count(*) from oceanbase.__all_virtual_concurrency_object_pool where free_list_name like '%ObPartitionBaseDataMetaObReader%' and count != 0;
ob1.mysql_p select sum(USED), sum(COUNT) from oceanbase.__all_virtual_memory_info where mod_name like 'OB_PARTITION_MIGRATE';
