# owner: yongle.xh
# owner group: storage
# description: this case is use for  batch migration
#

--disable_query_log
ob1=OBI(cluster=2:2:2,proxy_num=0,init_unit_cpu=2, init_unit_num=1);
ob1.reboot;

ob1.mysql alter system set resource_hard_limit = 800;
ob1.mysql alter system set merger_switch_leader_duration_time=0;
ob1.mysql alter system set enable_auto_leader_switch = true;
ob1.mysql alter system set enable_rereplication = true;
ob1.mysql alter system set enable_rebalance = true;
ob1.mysql alter system set debug_sync_timeout = '100000s';
let $ip = deploy_get_value(ob1.z1.obs0.ip);
let $port = deploy_get_value(ob1.z1.obs0.mysql_port);

ob1.create_client tenant=obtest,user=root,passwd=,database=test;

create tablegroup test_group;
let $table_count = 10;
let $i = 0;

while ($i < $table_count)
{
  eval create table test$i(c1 int, c2 int, c3 varchar(4096), primary key(c1)) tablegroup='test_group' primary_zone='z1';
  inc $i;
}


ob1.mysql alter system major freeze;
ob1.check_version 2;

let $unit_id = deploy_get_value(ob1.select select unit_id from __all_resource_pool a, __all_unit b, __all_tenant c where c.tenant_id=a.tenant_id and a.resource_pool_id=b.resource_pool_id and c.tenant_name = 'obtest' and zone='z2', unit_id, 1);
let $src_host = deploy_get_value(ob1.select select concat(svr_ip,':', svr_port) host from __all_resource_pool a, __all_unit b, __all_tenant c where c.tenant_id=a.tenant_id and a.resource_pool_id=b.resource_pool_id and c.tenant_name = 'obtest' and zone='z2', host, 1);
let $src = deploy_get_value(ob1.get_obs_by_addr $src_host);
let $src_ip = deploy_get_value(ob1.select select svr_ip from __all_resource_pool a, __all_unit b, __all_tenant c where c.tenant_id=a.tenant_id and a.resource_pool_id=b.resource_pool_id and c.tenant_name = 'obtest' and zone='z2', svr_ip, 1);
let $src_port = deploy_get_value(ob1.select select svr_port from __all_resource_pool a, __all_unit b, __all_tenant c where c.tenant_id=a.tenant_id and a.resource_pool_id=b.resource_pool_id and c.tenant_name = 'obtest' and zone='z2', svr_port, 1);

let $tenant_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name='obtest', tenant_id, 1);
let $dst_host = deploy_get_value(ob1.select select concat(svr_ip, ':', svr_port) host from oceanbase.__all_server where zone='z2' and svr_ip != '$src_ip' and svr_port != '$src_port', host, 1);
let $dst = deploy_get_value(ob1.get_obs_by_addr $dst_host);
let $dst_ip = deploy_get_value($dst.ip);
let $dst_port = deploy_get_value($dst.port);

ob1.mysql set ob_global_debug_sync = 'BEFORE_BATCH_ADD_MEMBER wait_for signal1';
ob1.mysql alter system set sys_bkgd_migration_change_member_list_timeout = '600s';
ob1.mysql alter system set fake_add_member_error = 2;
ob1.mysql alter system migrate unit $unit_id destination = "$dst_host";
sleep 10;
$dst.check_log_until_success -c "start try_batch_add_member";
ob1.mysql alter system set enable_rebalance = false;
sleep 3;
ob1.mysql set ob_global_debug_sync = 'now signal signal1';
$dst.check_log_until_success -c "fake batch_post_add_replica_mc_msg";

sleep 30;
ob1.mysql alter system set fake_add_member_error = 0;
ob1.check_until_timeout select count(*) from oceanbase.__all_unit where migrate_from_svr_ip != '', 0, 60;

# 批量迁移add member的时候是不重试的，所以这里还是会失败
ob1.mysql_p select count(*) > 0 from oceanbase.__all_rootservice_event_history where module='balancer' and event = 'finish_migrate_replica' and value4 != 0;
# 迁移失败后由于没加member list，会触发复制流程。
ob1.mysql_p select * from oceanbase.__all_rootservice_event_history where module='balancer' and event = 'finish_add_replica' and value4 != 0;
ob1.mysql_p select * from oceanbase.__all_virtual_partition_migration_status where result != 0;

ob1.mysql alter system major freeze;
ob1.check_version 3;

ob1.mysql_p select count(*) from oceanbase.__all_virtual_concurrency_object_pool where free_list_name like '%ObPartitionBaseDataInfo%' and count != 0;
ob1.mysql_p select count(*) from oceanbase.__all_virtual_concurrency_object_pool where free_list_name like '%ObPartitionMacroBlockObReader%' and count != 0;
ob1.mysql_p select count(*) from oceanbase.__all_virtual_concurrency_object_pool where free_list_name like '%ObPartitionBaseDataMetaObReader%' and count != 0;
ob1.mysql_p select sum(USED), sum(COUNT) from oceanbase.__all_virtual_memory_info where mod_name like 'OB_PARTITION_MIGRATE';

