#owner : weixue.cx
#group : storage
#description: test create pg partition with larger snapshot version than next major ts

--disable_query_log
ob1=OBI(cluster=1,proxy_num=0,init_unit_cpu=2);
ob1.reboot;
sleep 5;

let $ip=deploy_get_value(ob1.z1.obs0.ip);
let $port=deploy_get_value(ob1.z1.obs0.mysql_port);
connect (conn1,$ip,admin@obtest,admin,oceanbase,$port);
connect (conn2,$ip,root@sys,,oceanbase,$port);

ob1.mysql alter system major freeze;
ob1.check_version 2;


# step 1: create binding pg
connection conn1;
use test;

create tablegroup test_tg binding true;
create table t1 (c1 int primary key, c2 int) tablegroup test_tg;

ob1.mysql alter system set_tp tp_no = 95, error_code = 4002, frequency = 1;

create table t2 (c1 int primary key, c2 int) tablegroup test_tg;

let $tid = deploy_get_value(ob1.select select table_id from __all_virtual_table where table_name = 't2', table_id, 1);

ob1.check_until_timeout select count(1) from __all_virtual_table_mgr where index_id = $tid and table_type = 1 and version = 2, 1, 120;

ob1.mysql alter system set_tp tp_no = 95, error_code = 4002, frequency = 0;

create table t3 (c1 int primary key, c2 int) tablegroup test_tg, table_mode = 'queuing';

let $btid = deploy_get_value(ob1.select select table_id from __all_virtual_table where table_name = 't3', table_id, 1);

insert into t3 values (1,1), (2,2);

ob1.mysql alter system major freeze;
ob1.mysql alter system suspend merge;

ob1.check_until_timeout select count(1) from __all_virtual_table_mgr where index_id = $btid and table_type = 8, 1, 120;

ob1.mysql alter system resume merge;
ob1.check_version 3;

ob1.check_until_timeout select count(1) from __all_virtual_table_mgr where index_id = $btid and table_type = 1 and size > 0 and version = 3, 1, 120;
