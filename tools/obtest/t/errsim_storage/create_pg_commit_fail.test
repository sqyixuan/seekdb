# owner: yongle.xh
# owner group: storage
# description: this case is use for create pg commit fail
#

--disable_query_log
ob1=OBI(cluster=1:1:1,proxy_num=1,init_unit_cpu=2, init_unit_num=1);
ob1.reboot;

#设置灰度切主的时间为0, 关闭自动切主，关闭自动balance
ob1.mysql alter system set resource_hard_limit = 800;
ob1.mysql alter system set merger_switch_leader_duration_time=0;
ob1.mysql alter system set enable_auto_leader_switch = true;
ob1.mysql alter system set enable_rereplication = false;
ob1.mysql alter system set enable_rebalance = false;
ob1.mysql alter system set debug_sync_timeout = '100000s';
ob1.mysql alter system set enable_pg = true;
ob1.mysql alter system set schema_drop_gc_delay_time = '10s';

#在zone1上建立连接
let $ip=deploy_get_value(ob1.z1.obs0.ip);
let $port=deploy_get_value(ob1.z1.obs0.mysql_port);
connect (conn1,$ip,admin@obtest,admin,oceanbase,$port);
connect (conn2,$ip,root@sys,,oceanbase,$port);

connection conn1;
use test;
create tablegroup tg1 primary_zone = 'z2'  binding = true partition by hash partitions 20 ;
ob1.check_until_timeout select count(*) from __all_virtual_tablegroup a, __all_virtual_meta_table b where a.tablegroup_name = 'tg1' and a.tablegroup_id=b.table_id and role=1 and zone='z2', 20, 60;
let $tg_id1= deploy_get_value(ob1.select select tablegroup_id from  __all_virtual_tablegroup where tablegroup_name = 'tg1', tablegroup_id, 1);

ob1.z2.obs0.mysql alter system set_tp tp_no = 14, error_code = 4184, frequency = 1;
sleep 3;

# test create pg fail
--error 4184
create tablegroup tg2 primary_zone = 'z2' binding = true  partition by hash partitions 20 ;
--error 4184
create table test2(c1 int primary key, c2 int) tablegroup = 'tg1' partition by hash(c1) partitions 20;

ob1.z2.obs0.mysql alter system set_tp tp_no = 14, error_code = 4184, frequency = 0;

create tablegroup tg2 primary_zone = 'z2' binding = true  partition by hash partitions 20 ;
create table test3(c1 int primary key, c2 int) tablegroup = 'tg2' partition by hash(c1) partitions 20;
create table test2(c1 int primary key, c2 int) tablegroup = 'tg1' partition by hash(c1) partitions 20;
let $tg_id2= deploy_get_value(ob1.select select tablegroup_id from  __all_virtual_tablegroup where tablegroup_name = 'tg2', tablegroup_id, 1);

insert into test2(c1,c2) values(1,1);
insert into test3(c1,c2) values(1,1);

ob1.z2.obs0.force_stop;
ob1.check_until_timeout select status from oceanbase.__all_server where zone='z2', inactive, 60; 
ob1.z2.obs0.nstart;
ob1.check_until_timeout select status from oceanbase.__all_server where zone='z2', active, 60; 
ob1.check_until_timeout select count(*) from __all_virtual_tablegroup a, __all_virtual_meta_table b where a.tablegroup_name = 'tg1' and a.tablegroup_id=b.table_id and role=1 and zone='z2', 20, 60;
insert into test2(c1,c2) values(2,1);
insert into test3(c1,c2) values(2,1);
select * from test2;
select * from test3;


ob1.mysql alter system major freeze;
ob1.check_version 2;

drop table test2;
ob1.z2.obs0.force_stop;
ob1.check_until_timeout select status from oceanbase.__all_server where zone='z2', inactive, 60; 
ob1.z2.obs0.nstart;
ob1.check_until_timeout select status from oceanbase.__all_server where zone='z2', active, 60; 
ob1.check_until_timeout select count(*) from __all_virtual_tablegroup a, __all_virtual_meta_table b where a.tablegroup_name = 'tg1' and a.tablegroup_id=b.table_id and role=1 and zone='z2', 20, 60;
insert into test3(c1,c2) values(3,1);
select * from test3;

ob1.z2.obs0.mysql alter system set_tp tp_no = 14, error_code = 4184, frequency = 1;

# leader drop pg fail
purge recyclebin;
drop tablegroup tg1;
purge recyclebin;

# follower drop pg fail
ob1.z2.obs0.force_stop;
ob1.check_until_timeout select status from oceanbase.__all_server where zone='z2', inactive, 60; 
ob1.z2.obs0.nstart;
ob1.check_until_timeout select status from oceanbase.__all_server where zone='z2', active, 60; 
ob1.check_until_timeout select count(*) from __all_virtual_tablegroup a, __all_virtual_meta_table b where a.tablegroup_name = 'tg2' and a.tablegroup_id=b.table_id and role=1 and zone='z2', 20, 60;
drop table test3;
purge recyclebin;
drop tablegroup tg2;
purge recyclebin;

ob1.z2.obs0.mysql alter system set_tp tp_no = 14, error_code = 0, frequency = 0;
ob1.check_until_timeout select count(*) from oceanbase.__all_tenant_gc_partition_info where table_id = $tg_id1, 0, 100;
ob1.check_until_timeout select count(*) from oceanbase.__all_tenant_gc_partition_info where table_id = $tg_id2, 0, 100;

ob1.check_until_timeout select count(*) from  __all_virtual_tablegroup where tablegroup_name = 'tg1', 0, 1;
ob1.check_until_timeout select count(*) from  __all_virtual_tablegroup where tablegroup_name = 'tg2', 0, 1;
ob1.check_until_timeout select count(*) from __all_virtual_meta_table where table_id = $tg_id1, 0, 100;
ob1.check_until_timeout select count(*) from __all_virtual_meta_table where table_id = $tg_id2, 0, 100;

## test reboot
ob1.z2.obs0.force_stop;
ob1.check_until_timeout select status from oceanbase.__all_server where zone='z2', inactive, 60; 
ob1.z2.obs0.nstart;
ob1.check_until_timeout select status from oceanbase.__all_server where zone='z2', active, 60; 

ob1.check_until_timeout select count(*) from __all_virtual_meta_table where table_id = $tg_id1, 0, 1;
ob1.check_until_timeout select count(*) from __all_virtual_meta_table where table_id = $tg_id2, 0, 1;

ob1.mysql alter system major freeze;
ob1.check_version 3;
