# owner: baichangmin.bcm
# owner group:storage
# encoding build micro block checksum error, print dignose log

ob1=OBI(cluster=1, proxy_num=0, init_unit_cpu=2);
ob1.reboot;
sleep 5;

ob1.mysql alter system set syslog_io_bandwidth_limit = '100G';

let $ip = deploy_get_value(ob1.z1.obs0.ip);
let $port = deploy_get_value(ob1.z1.obs0.mysql_port);
let $pwd = deploy_get_value(ob1.z1.obs0.workdir);

connect (conn1,$ip,root@obtest,,test,$port);
connection conn1;

drop table if exists test_encoding;
create table test_encoding(c1 int, c2 int, c3 varchar(4096), primary key(c1));

sleep 2;

--disable_query_log
let $cnt=1;
while($cnt < 12)
{
  eval insert into test_encoding values($cnt, $cnt, repeat('ab', 1024));
  inc $cnt;
}
--enable_query_log

ob1.mysql alter system set_tp tp_no = 712, error_code = 4103, occur = 1, frequency = 1;

ob1.mysql alter system major freeze;

sleep 40;

# print dump_diagnose_info
ob1.z1.obs0.check_log_until_success -c "print encoder status:";
ob1.z1.obs0.check_log_until_success -c "error micro block store_row (original)";

# print micro block row
ob1.z1.obs0.check_log_until_success -c "error micro block row";

#ob1.check_version 2;
#ob1.check_until_timeout select info from __all_zone where zone='' and name='merge_status',IDLE,30;


drop table if exists test_encoding;
