# owner: lixia.yq
# owner group: storage
# description: this case is use for sync storage schema failure
#

--disable_query_log
ob1=OBI(cluster=1:1:1,proxy_num=1,init_unit_cpu=2, init_unit_num=1);
ob1.reboot;

#设置灰度切主的时间为0, 关闭自动切主，关闭自动balance
ob1.mysql alter system set resource_hard_limit = 800;
ob1.mysql alter system set merger_switch_leader_duration_time=0;
ob1.mysql alter system set enable_auto_leader_switch = true;
ob1.mysql alter system set enable_rereplication = false;
ob1.mysql alter system set enable_rebalance = false;
ob1.mysql alter system set debug_sync_timeout = '100000s';
ob1.mysql alter system set enable_pg = true;
ob1.mysql alter system set schema_drop_gc_delay_time = '10s';
ob1.mysql alter system set _ob_clog_timeout_to_force_switch_leader = 10; // switch leader when clog is timeout

#在zone1上建立连接
let $ip=deploy_get_value(ob1.z1.obs0.ip);
let $port=deploy_get_value(ob1.z1.obs0.mysql_port);
connect (conn1,$ip,admin@obtest,admin,oceanbase,$port);
connect (conn2,$ip,root@sys,,oceanbase,$port);

connection conn1;
use test;
create table test01(c1 int primary key, c2 int) partition by hash(c1) partitions 20;

let $table_id = deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where table_name = "test01", table_id, 1);
# wait for leader election
ob1.check_until_timeout select count(*) from __all_virtual_clog_stat where role = 'LEADER' and status = 'ACTIVE' and table_id = '$table_id' , 20, 120;

# block net between leader and follower
ob1.z1.obs0.block_net ob1.z2.obs0;
ob1.z1.obs0.block_net ob1.z3.obs0;
ob1.z2.obs0.block_net ob1.z1.obs0;
ob1.z3.obs0.block_net ob1.z1.obs0;

connection conn1;
--error 4012
insert into test01 values(1, 1);

sleep 20;

# clean net between leader and follower
ob1.z1.obs0.clean_net ob1.z2.obs0;
ob1.z1.obs0.clean_net ob1.z3.obs0;
ob1.z2.obs0.clean_net ob1.z1.obs0;
ob1.z3.obs0.clean_net ob1.z1.obs0;

 # count log of schema clog callback failure
ob1.z1.obs0.count_log 'schema log finish callback';

connection conn1;
drop table test01;