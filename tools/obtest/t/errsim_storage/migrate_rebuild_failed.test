# owner: yongle.xh
# owner group: storage
# description:
#

--disable_query_log
ob1=OBI(cluster=1:1:1,proxy_num=1,init_unit_cpu=2);
ob1.reboot;

ob1.create_client;

ob1.mysql alter system set merger_check_interval='10s';
ob1.mysql alter system set enable_rebalance = 'true';
ob1.mysql alter system set resource_hard_limit=500;
ob1.mysql alter system set balancer_idle_time = '10s';

ob1.create_client tenant=sys,user=root,passwd=,database=test;
ob1.z2.obs0.mysql alter system set_tp tp_no = 52, error_code = 4016, frequency = 1;
ob1.z3.obs0.mysql alter system set_tp tp_no = 52, error_code = 4016, frequency = 1;

sleep 5;
create table test01 (pk1 int, pk2 int, pk3 int, f1 varchar(1024), f2 varchar(262144), primary key(pk1,pk2,pk3)) primary_zone='z1';
insert into test01(pk1, pk2, pk3, f1, f2) values(1,2,3,'f1', 'f2');

let $table_id=deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where table_name='test01', table_id, 1);
let $slave_ip1 = deploy_get_value(ob1.z3.obs0.ip);
let $slave_port1 = deploy_get_value(ob1.z3.obs0.port);
let $slave_ip2 = deploy_get_value(ob1.z2.obs0.ip);
let $slave_port2 = deploy_get_value(ob1.z2.obs0.port);

let $cnt = 100;

while ($cnt > 1) 
{
  eval update oceanbase.__all_tenant_meta_table set rebuild=1 where table_id=$table_id and zone = 'z3';
  sleep 1;
  let $value = deploy_get_value(ob1.select select count(*) from oceanbase.__all_rootservice_event_history where module='balancer' and event='finish_rebuild_replica' and value3 like '%$slave_ip1:$slave_port1%', count(*), 1);
  if ($value > 0) 
  {
    let $cnt = 0;
  }
}
echo $cnt;

eval update oceanbase.__all_tenant_meta_table set rebuild=0 where table_id=$table_id and zone = 'z3';

let $cnt = 100;
while ($cnt > 1) 
{
  eval update oceanbase.__all_tenant_meta_table set rebuild=1 where table_id=$table_id and zone = 'z2';
  sleep 1;
  let $value = deploy_get_value(ob1.select select count(*) from oceanbase.__all_rootservice_event_history where module='balancer' and event='finish_rebuild_replica' and value3 like '%$slave_ip2:$slave_port2%', count(*), 1);
  if ($value > 0) 
  {
    let $cnt = 0;
  }
}
echo $cnt;

eval update oceanbase.__all_tenant_meta_table set rebuild=0 where table_id=$table_id and zone = 'z2';

sleep 10;

ob1.z1.obs0.force_stop;
sleep 30;

# 发起合并，等待合并完成
ob1.mysql select count(*) from oceanbase.__all_tenant_meta_table a, oceanbase.__all_server b where b.status = 'active' and b.zone = a.zone and a.role=1 and a.table_id=$table_id;
ob1.mysql alter system major freeze;
ob1.check_version 2;

ob1.mysql select pk1,pk2,pk3 from test.test01;

