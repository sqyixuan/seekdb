# owner: debin.jdb
# owner group: clog
# description: 利用errsim模式测试副本rebuild的场景

ob1=OBI(cluster=2:2:2, init_unit_cpu=11, init_unit_num=2, proxy_num=0);

ob1.z1.obs0.set extra_config=devname=eth2;
ob1.z1.obs1.set extra_config=devname=eth2;
ob1.z2.obs0.set extra_config=devname=eth2;
ob1.z2.obs1.set extra_config=devname=eth2;

ob1.reboot;
sleep 5;

let $rs = deploy_get_value(ob1.get_leader sys:oceanbase:__all_core_table:0);
let $ip=deploy_get_value($rs.ip);
let $port=deploy_get_value($rs.mysql_port);
connect (conn_sys,$ip,root,,oceanbase,$port);

let $obs = deploy_get_value(ob1.get_leader obtest:oceanbase:__all_dummy:0);
let $obtest_lip=deploy_get_value($obs.ip);
let $obtest_lport=deploy_get_value($obs.mysql_port);
connect (conn_obtest,$obtest_lip,root@obtest,,test,$obtest_lport);

connection conn_sys;
alter system set enable_rebalance=false;
alter system set enable_auto_leader_switch=false;
alter system set enable_rereplication=false;
alter system set balancer_idle_time='10s';
alter system set server_data_copy_in_concurrency=20;
alter system set server_data_copy_out_concurrency=20;

ob1.mysql alter tenant obtest set variables ob_tcp_invited_nodes='%';

connection conn_obtest;
# 新建一张表
create table t1(c1 int, c2 int) primary_zone='z1';
sleep 5;

# 保证obtest租户上的用户表和系统表不在一台server上
let $tenant_id=deploy_get_value(ob1.select select tenant_id from __all_tenant where tenant_name='obtest', tenant_id, 1);
let $tid=deploy_get_value(ob1.select select table_id from __all_virtual_table where table_name='t1', table_id, 1);

# 将t1迁到z3一个单独的sever上,以便仅让它自己触发rebuild.
let $tenant_sys_host=deploy_get_value(ob1.select select distinct concat(svr_ip,':',svr_port) as host from __all_virtual_partition_table where zone='z3' and tenant_id = $tenant_id and table_id & 0xffffffffff < 10000, host, 1);

let $sys_obs = deploy_get_value(ob1.get_obs_by_addr $tenant_sys_host);
let $sys_ip=deploy_get_value($sys_obs.ip);
let $sys_port=deploy_get_value($sys_obs.mysql_port);

let $expect_host=deploy_get_value(ob1.select select concat(svr_ip,':',svr_port) as host from __all_server where zone='z3' and (svr_ip != '$sys_ip' or svr_port != $sys_port), host, 1);

let $actual_host=deploy_get_value(ob1.select select concat(svr_ip,':',svr_port) as host from __all_virtual_meta_table where table_id='$tid' and zone='z3', host, 1);

if($actual_host == $tenant_sys_host)
{
    connection conn_sys;
    let $actual = deploy_get_value(ob1.get_obs_by_addr $actual_host);
    let $expect = deploy_get_value(ob1.get_obs_by_addr $expect_host);
    $actual.migrate_to $expect,obtest:test:t1;
    sleep 5;
    ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_clog_stat where table_id=$tid and concat(svr_ip,':',svr_port) = '$expect_host', 1, 300;
}

let $actual_host=deploy_get_value(ob1.select select concat(svr_ip,':',svr_port) as host from __all_virtual_meta_table where table_id='$tid' and zone='z3', host, 1);

connection conn_sys;
# 打开配置项开关，只要落后一次转储，就会触发rebuild
alter system set _ob_enable_rebuild_on_purpose = true;
# 关闭rs的rebuild调度
alter system set __balance_controller='{"ENABLE_REBUILD":"false"}';

# 获取t1表的leader和follower
let $leader=deploy_get_value(ob1.get_leader obtest:test:t1);
let $leader_ip=deploy_get_value($leader.ip);
let $leader_port=deploy_get_value($leader.port);
# let $follower_1=deploy_get_value(ob1.get_follower obtest:test:t1,1);
let $follower_1 = deploy_get_value(ob1.get_obs_by_addr $actual_host);
let $follower1_host=deploy_get_value($follower_1.ip);
let $follower1_port=deploy_get_value($follower_1.port);

# 阻塞leader和一个副本之间的网络
$leader.block_net $follower_1;
# sleep 等待生效
sleep 5;

connection conn_obtest;
# 插入10行数据，leader和follower2形成majority，follower1未收到此日志
let $cnt=10;
while($cnt>0)
{
    eval insert into t1 values($cnt, $cnt);;
    dec $cnt;
}
# 等待日志在leader和follower2形成多数派
sleep 5;

# 在leader上触发转储
ob1.mysql alter system minor freeze tenant obtest server = ('$leader_ip:$leader_port');
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table_mgr where table_id=$tid and svr_ip = "$leader_ip" and svr_port = '$leader_port' and table_type = 0 and is_active = 0, 0, 300;

# 转储完成后，再次写入10条数据
let $cnt=10;
while($cnt>0)
{
    eval insert into t1 values($cnt, $cnt);;
    dec $cnt;
}

# 恢复网络，follower1会向leader获取日志，leader通知follower1需要执行rebuild；需要sleep 5
$leader.clean_net $follower_1;
sleep 5;

# 确认follower1的rebuild标记为1
ob1.check_until_timeout select count(*) c from oceanbase.__all_virtual_clog_stat where svr_ip = '$follower1_host' and svr_port = '$follower1_port' and table_id = '$tid' and is_need_rebuild = 1, 1, 120;

# 等待执行
sleep 30;
# 确认clog已经同步
ob1.check_until_timeout select count(*) c from oceanbase.__all_virtual_clog_stat where svr_ip = '$follower1_host' and svr_port = '$follower1_port' and table_id = '$tid' and is_in_sync = 1, 0, 120;

ob1.check_until_timeout select count(*) c from oceanbase.__all_virtual_clog_stat where svr_ip = '$follower1_host' and svr_port = '$follower1_port' and table_id = '$tid' and is_need_rebuild = 1, 0, 120;

