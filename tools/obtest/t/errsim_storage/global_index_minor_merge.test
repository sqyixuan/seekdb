# owner: weixue
# owner group: storage
# desc: minor merge after creating global index and global index's memtable is empty
ob1=OBI(cluster=1:1:1,proxy_num=0,init_unit_cpu=1);
ob1.reboot;
ob1.mysql alter system set enable_auto_leader_switch=false;
#ob1.mysql create resource pool rp1 unit = 'sys_unit_config', unit_num = 1, zone_list = ('z1', 'z2', 'z3');
#ob1.mysql create tenant tt1 replica_num 3, primary_zone 'z1', resource_pool_list ('rp1'), locality "F@z1,F@z2,F@z3" set ob_tcp_invited_nodes='%';
sleep 5;
let $ip=deploy_get_value(ob1.z1.obs0.ip);
let $port=deploy_get_value(ob1.z1.obs0.mysql_port);
connect (conn1,$ip,admin@obtest,admin,test,$port);
connect (conn2,$ip,root@sys,,oceanbase,$port);
connection conn1;
--disable_query_log
# step 1: create table and global index

create table test_global_index (c1 int primary key, c2 int) partition by hash(c1) partitions 2;
insert into test_global_index values (1,1),(2,2),(3,3),(4,4);


ob1.mysql alter system set_tp tp_no = 103, error_code = 4013, frequency = 1;

create index global_index_i2 on test_global_index(c2) partition by hash(c2) partitions 2;

let $index_id=deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where table_name like "__%global_index_i2%", table_id, 1);
let $dst_ip = deploy_get_value(ob1.select select svr_ip from __all_virtual_meta_table where table_id = $index_id and partition_id = 0 and role = 2 order by zone, svr_ip, 1);
let $dst_port = deploy_get_value(ob1.select select svr_port from __all_virtual_meta_table where table_id = $index_id and partition_id = 0 and role = 2 order by zone, svr_port, 1);

# step 2: 写clog日志
connection conn2;
eval alter system switch replica leader partition_id='0%0@$index_id' server='$dst_ip:$dst_port';
sleep 3;
connection conn1;
# 打开配置项开关，防止转储被跳过
ob1.mysql alter system set _ob_enable_rebuild_on_purpose = true;
sleep 3;
# step 3: 转储，等memstore释放
ob1.mysql alter system minor freeze tenant = sys;
ob1.mysql alter system minor freeze tenant = all_user;
ob1.mysql alter system minor freeze tenant = all_meta;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table_mgr where table_id=$index_id and base_version = 1 and table_type=0, 0, 120;
