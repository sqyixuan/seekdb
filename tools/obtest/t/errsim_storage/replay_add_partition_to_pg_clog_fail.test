# owner: weixue.cx
# owner group: storage
# description: this case is use for test replay add partition to pg clog fail
#

--disable_query_log
ob1=OBI(cluster=1:1:1,proxy_num=1,init_unit_cpu=2, init_unit_num=1);
ob1.reboot;

ob1.create_client tenant=obtest,user=root,passwd=,database=test;
create tablegroup tg1 primary_zone = 'z1' binding = true partition by hash partitions 20;

ob1.mysql alter system set_tp tp_no = 92, error_code = 4013, frequency = 1;

create table test1(c1 int primary key, c2 int) tablegroup = 'tg1' partition by hash (c1) partitions 20;

ob1.z2.obs0.check_log_until_success "failed to replay add partition to pg clog after create sstable";
ob1.check_until_timeout select count(1) as c from oceanbase.__all_virtual_pg_partition_info a, oceanbase.__all_virtual_table b where a.table_id = b.table_id and b.table_name = 'test1', 20, 10;

ob1.z2.obs0.force_stop;
ob1.check_until_timeout select status from oceanbase.__all_server where zone='z2', inactive, 60; 
ob1.z2.obs0.nstart;
ob1.check_until_timeout select status from oceanbase.__all_server where zone='z2', active, 60; 

ob1.z3.obs0.force_stop;
ob1.check_until_timeout select status from oceanbase.__all_server where zone='z3', inactive, 60; 
ob1.z3.obs0.nstart;
ob1.check_until_timeout select status from oceanbase.__all_server where zone='z3', active, 60; 

ob1.check_until_timeout select count(1) as c from oceanbase.__all_virtual_pg_partition_info a, oceanbase.__all_virtual_table b where a.table_id = b.table_id and b.table_name = 'test1', 60, 60;
