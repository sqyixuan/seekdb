# owner: jingyan.kfy
# owner group: transaction

ob1=OBI(cluster=2:2:2,proxy_num=0,init_unit_cpu=2);
ob1.reboot;

ob1.mysql alter system set enable_auto_leader_switch=false;

ob1.mysql create resource pool rp1 unit = 'sys_unit_config', unit_num = 2, zone_list = ('z1', 'z2', 'z3');
ob1.mysql create tenant tt1 replica_num 3, primary_zone 'z1', resource_pool_list ('rp1'), locality "F@z1,F@z2,F@z3" set ob_tcp_invited_nodes='%';
sleep 5;

let $ip=deploy_get_value(ob1.z1.obs0.ip);
let $port=deploy_get_value(ob1.z1.obs0.mysql_port);
let $ip1=deploy_get_value(ob1.z2.obs1.ip);
let $port1=deploy_get_value(ob1.z2.obs1.mysql_port);

connect (conn1,$ip1,root@tt1,,test,$port1);
connect (conn2,$ip,root@sys,,oceanbase,$port);
connection conn1;

--disable_query_log

# step 1: 迁移空pg
create tablegroup tg1 binding true;

let $tablegroup_id=deploy_get_value(ob1.select select tablegroup_id from oceanbase.__all_virtual_tablegroup where tablegroup_name='tg1', tablegroup_id, 1);
let $tenant_id=deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name='tt1', tenant_id, 1);
let $src_host = deploy_get_value(ob1.select select concat(svr_ip,':',svr_port) host from __all_virtual_partition_location where tenant_id=$tenant_id and table_id=$tablegroup_id and role=1 and partition_id=0, host, 1);
let $src_port = deploy_get_value(ob1.select select svr_port from __all_virtual_partition_location where tenant_id=$tenant_id and table_id=$tablegroup_id and role=1 and partition_id=0, svr_port, 1);
let $src = deploy_get_value(ob1.get_obs_by_addr $src_host);
let $src_ip = deploy_get_value($src.ip);
let $src_zone = deploy_get_value(ob1.select select zone from oceanbase.__all_server where svr_ip='$src_ip' and svr_port = $src_port, zone, 1);
let $dst_host = deploy_get_value(ob1.select select concat(svr_ip, ':', svr_port) host from oceanbase.__all_server where zone='$src_zone' and (svr_ip!='$src_ip' or svr_port != $src_port), host, 1);
let $dst_port = deploy_get_value(ob1.select select svr_port from oceanbase.__all_server where zone='$src_zone' and (svr_ip!='$src_ip' or svr_port != $src_port), svr_port, 1);
let $dst = deploy_get_value(ob1.get_obs_by_addr $dst_host);
let $dst_ip = deploy_get_value($dst.ip);

ob1.mysql alter system move replica partition_id = '0%0@$tablegroup_id' source = '$src_ip:$src_port' DESTINATION = '$dst_ip:$dst_port';
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_partition_location where tenant_id=$tenant_id and table_id=$tablegroup_id and partition_id=0 and role=1 and member_list like '%$dst_ip:$dst_port%', 1, 300;

# step 2: 创建partition
create table test(id1 int, id2 int) tablegroup tg1;
sleep 3;

# step 3: 写clog日志
connection conn2;
eval alter system switch replica leader partition_id='0%0@$tablegroup_id' server='$dst_ip:$dst_port';
sleep 3;
connection conn1;

# 打开配置项开关，防止转储被跳过
ob1.mysql alter system set _ob_enable_rebuild_on_purpose = true;
sleep 3;

# step 4: 转储，等memstore释放
ob1.mysql alter system minor freeze tenant = sys;
ob1.mysql alter system minor freeze tenant = all_user;
ob1.mysql alter system minor freeze tenant = all_meta;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table_mgr where table_id=$tablegroup_id and table_type=0, 3, 60;

ob1.mysql alter system major freeze;
ob1.check_version 2;
