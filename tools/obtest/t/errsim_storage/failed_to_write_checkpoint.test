# owner: yongle.xh
# owner group: storage
# description: this case is use for failed_to_write_checkpoint 
#

--disable_query_log
ob1=OBI(cluster=1,proxy_num=0,init_unit_cpu=2, init_unit_num=1);
ob1.reboot;

#设置灰度切主的时间为0, 关闭自动切主，关闭自动balance
ob1.mysql alter system set resource_hard_limit = 800;
ob1.mysql alter system set merger_switch_leader_duration_time=0;
ob1.mysql alter system set enable_auto_leader_switch = false;
ob1.mysql alter system set enable_rereplication = false;
ob1.mysql alter system set enable_rebalance = false;
ob1.mysql alter system set debug_sync_timeout = '100000s';

ob1.create_client tenant=obtest,user=root,passwd=,database=test;

ob1.z1.obs0.mysql alter system set_tp tp_no = 34, error_code = 4012, frequency = 1;
ob1.mysql alter system major freeze;
ob1.check_version 2;
ob1.z1.obs0.check_log_until_success -c "write checkpoint";
ob1.z1.obs0.count_log "Fail to write checkpoint in long time";
ob1.z1.obs0.count_log "Fail to write checkpoint in short time";

ob1.mysql alter system set fail_write_checkpoint_alert_interval = '10s';
ob1.mysql alter system set retry_write_checkpoint_min_interval = '60s';
sleep 10;
ob1.mysql alter system major freeze;
ob1.check_version 3;
ob1.z1.obs0.count_log "Fail to write checkpoint in long time";
ob1.z1.obs0.count_log "Fail to write checkpoint in short time";


ob1.z1.obs0.force_stop;
ob1.z1.obs0.nstart;
sleep 30;

ob1.z1.obs0.mysql alter system set_tp tp_no = 34, error_code = 4012, frequency = 0;
ob1.mysql alter system major freeze;
ob1.check_version 4;

ob1.z1.obs0.check_log_until_success -c "Success to write checkpoint";
ob1.z1.obs0.count_log "Fail to write checkpoint in long time";
ob1.z1.obs0.count_log "Fail to write checkpoint in short time";
ob1.z1.obs0.count_log "Success to write checkpoint";
