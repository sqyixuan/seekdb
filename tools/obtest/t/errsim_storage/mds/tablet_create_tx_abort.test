# owner: bowen.gbw
# owner group: storage
# Testing Case: tablet create transaction abort, verify tablet gc service and empty shell task

ob1=OBI(cluster=1:1:1,proxy_num=0,init_unit_cpu=0);
ob1.reboot;
let $test_tenant = test_tenant;


--echo ===============================================================
--echo ====================     bootstrap   ==========================
--echo ===============================================================
--echo test case for bootstrap begin
ob1.mysql alter system set enable_rebalance = 'true';
ob1.mysql alter system set default_compress_func = 'none';
ob1.mysql alter system set debug_sync_timeout = '100000s';
ob1.mysql alter system set _transfer_start_trans_timeout = '60s';
let $proxy_ip = deploy_get_value(ob1.z1.obs0.ip);
let $proxy_port = deploy_get_value(ob1.z1.obs0.mysql_port);
connect(conn_sys, $proxy_ip, root@sys,,oceanbase, $proxy_port);
--echo test case for bootstrap finish


--echo ===============================================================
--echo ==================     create tenant   ========================
--echo ===============================================================
--echo create tenant begin
ob1.mysql CREATE RESOURCE UNIT unit_1 MAX_CPU = 1, MEMORY_SIZE = '2G', MAX_IOPS = 1024, LOG_DISK_SIZE = '2G';
ob1.mysql CREATE RESOURCE POOL resource_pool UNIT = "unit_1", UNIT_NUM = 1, ZONE_LIST = ('z1', 'z2', 'z3');
ob1.mysql CREATE TENANT test_tenant resource_pool_list=('resource_pool'), locality = "F@z1,F@z2,F@z3", primary_zone = "z1;z2;z3" set ob_tcp_invited_nodes='%', ob_compatibility_mode='oracle';
source include/check_schema_sync.inc;
connection conn_sys;
let $tenant_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name = 'test_tenant', tenant_id, 1);
let $resource_pool_id = deploy_get_value(ob1.select select resource_pool_id from oceanbase.__all_resource_pool where tenant_id = $tenant_id, resource_pool_id, 1);
--echo create tenant finish


--echo ===============================================================
--echo ==================    set ddl timeout   =======================
--echo ===============================================================
--echo set ddl timeout begin
ob1.mysql alter system set _ob_ddl_timeout = '5s';
--echo set ddl timeout begin


--echo ===============================================================
--echo ==================     create table    ========================
--echo ===============================================================
--echo create table begin
# let tablet create tx abort
ob1.mysql alter system set_tp tp_name = "EN_SUBMIT_TX_PREPARE_LOG", error_code = 6224, frequency = 1;

ob_connect(sys_conn_oracle, ob1.z1.obs0, SYS@$test_tenant, ,SYS, , USE_OB_CONNECTOR);
connection sys_conn_oracle;
set global wait_timeout = 288000;
create user test IDENTIFIED BY "test";
grant all on *.* to test WITH GRANT OPTION;
grant dba to test;
ob_connect(user_oracle_conn, ob1.z1.obs0,TEST@$test_tenant,test,test,,USE_OB_CONNECTOR);
connection user_oracle_conn;
--error 600
eval create table test_tx_aborted(a int primary key, b int);
--echo create table finish


--echo ===============================================================
--echo ================    switch replica leader    ==================
--echo ===============================================================
--echo switch replica leader begin
connection conn_sys;
ob1.mysql alter system set _ob_ddl_timeout = '1000s';

# switch replica leader to z2
let $z2_svr_ip = deploy_get_value(ob1.select select svr_ip from oceanbase.__all_server where zone = 'z2', svr_ip, 1);
let $z2_svr_port = deploy_get_value(ob1.select select svr_port from oceanbase.__all_server where zone = 'z2', svr_port, 1);
let $ls_id = deploy_get_value(ob1.select select ls_id from oceanbase.__all_virtual_ls_info where tenant_id = $tenant_id and svr_ip = '$z2_svr_ip' and svr_port = $z2_svr_port and ls_id > 1, ls_id, 1);

--disable_query_log
eval select count(*) from oceanbase.__all_virtual_ls_info where tenant_id = $tenant_id and svr_ip = '$z2_svr_ip' and svr_port = $z2_svr_port and ls_state = 'LEADER';
--enable_query_log

eval alter system switch replica leader ls = $ls_id server = '$z2_svr_ip:$z2_svr_port' tenant = '$test_tenant';
--echo switch replica leader finish


--echo ===============================================================
--echo ==================     verify table    ========================
--echo ===============================================================
--echo verify table begin
ob1.check_until_timeout select count(*) from __all_virtual_tablet_pointer_status where tenant_id = $tenant_id and tablet_id > 200000, 0, 60;
--echo verify table finish