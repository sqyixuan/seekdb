# owner: yongle.xh

ob1=OBI(cluster=1:1:1,proxy_num=0,init_unit_cpu=0);
ob1.reboot;

source include/fast_auto_rebalance_configuration.inc;
# 创建租户
ob1.mysql create resource pool pool1 unit = 'sys_unit_config', unit_num = 1, zone_list = ('z1', 'z2', 'z3');
ob1.mysql create tenant tt resource_pool_list=('pool1'), primary_zone = 'z1', locality = 'F@z1,F@z2,F@z3' set ob_tcp_invited_nodes='%';
sleep 3;
let $proxy_ip = deploy_get_value(ob1.z1.obs0.ip);
let $proxy_port = deploy_get_value(ob1.z1.obs0.mysql_port);

connect(tt_conn, $proxy_ip, root@tt,,test, $proxy_port);
connect(sys_conn, $proxy_ip, root@sys,,test, $proxy_port);

connection tt_conn;
create table test(c1 int primary key, c2 int);

let $tenant_id = deploy_get_value(ob1.select select tenant_id from __all_tenant where tenant_name = "tt", tenant_id, 1);

ob1.mysql alter tenant tt locality='F@z1,F@z2,R@z3';
ob1.check_until_timeout select count(*) c from oceanbase.__all_tenant where tenant_id = $tenant_id and previous_locality != '', 0, 100;
ob1.check_until_timeout select count(*) c from oceanbase.__all_rootservice_job where job_status="SUCCESS", 1, 30;
sleep 30;

ob1.mysql alter system set sys_bkgd_migration_change_member_list_timeout = '600s';
ob1.mysql alter system set enable_rereplication = false;
ob1.mysql alter system set fake_add_member_error = 2;
sleep 3;

let $count = 2;
ob1.mysql alter tenant tt locality='F@z1,F@z2,F@z3';
ob1.z3.obs0.check_log_until_success -c "fake batch_post_add_replica_mc_msg";
sleep 30;
ob1.z3.obs0.count_log "GC remove_partition success";
ob1.mysql alter system set sys_bkgd_migration_change_member_list_timeout = '10s';
ob1.z3.obs0.check_log_until_success -c "GC remove_partition success";
ob1.mysql select distinct(value4) from oceanbase.__all_rootservice_event_history  where module = 'balancer' and event = 'finish_type_tranform' and value4 != 0;

ob1.mysql alter system set enable_rereplication = true;
let $count = deploy_get_value(ob1.select select count(*) count from oceanbase.gv\$partition where tenant_id=$tenant_id and zone='z1', count, 1);
ob1.check_until_timeout select count(*) from oceanbase.gv\$partition where tenant_id=$tenant_id and zone='z3', $count, 30;
