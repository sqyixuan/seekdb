--disable_query_log
ob1=OBI(cluster=1, proxy_num=1,init_unit_cpu=2, init_unit_num=1);
ob1.reboot;


let $ip=deploy_get_value(ob1.z1.obs0.ip);
let $port=deploy_get_value(ob1.z1.obs0.mysql_port);
connect (conn1,$ip,root@obtest,,test,$port);

ob1.mysql alter system major freeze;
ob1.check_version 2;

ob1.mysql alter system set_tp tp_no = 109, error_code = 4013, frequency = 1;

create table test1(c1 int primary key, c2 int);

ob1.check_until_timeout select count(1) as c from oceanbase.__all_virtual_table_mgr a, oceanbase.__all_virtual_table b where a.table_id = b.table_id and b.table_name = 'test1' and a.table_type = 7, 1, 120;

ob1.mysql alter system major freeze;
ob1.check_version 3;
