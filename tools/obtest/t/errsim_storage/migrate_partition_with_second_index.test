# owner: yongle.xh
# owner group: storage
# description: this case is use for migrate low version to high version
#

--disable_query_log
ob1=OBI(cluster=3:3:3,proxy_num=1,init_unit_cpu=2, init_unit_num=2);
ob1.reboot;

#设置灰度切主的时间为0, 关闭自动切主，关闭自动balance
ob1.mysql alter system set resource_hard_limit = 800;
ob1.mysql alter system set merger_switch_leader_duration_time=0;
ob1.mysql alter system set enable_auto_leader_switch = false;
ob1.mysql alter system set enable_rereplication = false;
ob1.mysql alter system set enable_rebalance = false;
let $ip = deploy_get_value(ob1.z1.obs0.ip);
let $port = deploy_get_value(ob1.z1.obs0.mysql_port);

ob1.z1.obs0.mysql alter system set_tp tp_no = 26, error_code = 1, frequency = 1;
ob1.z1.obs1.mysql alter system set_tp tp_no = 26, error_code = 1, frequency = 1;
ob1.z2.obs0.mysql alter system set_tp tp_no = 26, error_code = 1, frequency = 1;
ob1.z2.obs1.mysql alter system set_tp tp_no = 26, error_code = 1, frequency = 1;
ob1.z3.obs0.mysql alter system set_tp tp_no = 26, error_code = 1, frequency = 1;
ob1.z3.obs1.mysql alter system set_tp tp_no = 26, error_code = 1, frequency = 1;

ob1.create_client tenant=obtest,user=root,passwd=,database=test;

create table test01 (pk1 int, pk2 int, pk3 int, f1 varchar(1024), f2 varchar(4096), primary key(pk1,pk2,pk3)) primary_zone='z1';
sleep 10;

let $cnt=1;
while($cnt < 10)
{
  eval insert into test01 values($cnt, $cnt, $cnt, 'ocean', 'base');
  inc $cnt;
}

ob1.mysql alter system major freeze;
ob1.check_version 2;

# another merge process
while ($cnt < 20)
{
  eval insert into test01 values($cnt, $cnt, $cnt, 'ocean', 'base');
  inc $cnt;
}

ob1.mysql alter system major freeze;
ob1.check_version 3;

# another merge process
while ($cnt < 300)
{
  eval insert into test01 values($cnt, $cnt, $cnt, 'ocean', 'base');
  inc $cnt;
}

#关闭z1的合并,使z1的版本低于z2、z3
ob1.mysql alter system suspend merge zone='z1';
ob1.mysql alter system major freeze;

let $__i__=180
while($__i__ > 0)
{
  sleep 1;
  dec $__i__;
  let $z2_merge_version = query_get_value(select value from __all_zone where zone='zone2' and name='all_merged_version');
  let $z3_merge_version = query_get_value(select value from __all_zone where zone='zone3' and name='all_merged_version');
  if($z2_merge_version == 4 && $z3_merge_version == 4)
  {
    let $__i__ = -5;
  }
}

let $tenant_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name='obtest', tenant_id, 1);
let $table_id = deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where table_name='test01', table_id, 1);
let $src_host = deploy_get_value(ob1.select select concat(svr_ip, ':', svr_port) host from oceanbase.__all_virtual_meta_table where zone='z2' and table_id=$table_id, host, 1);
let $src = deploy_get_value(ob1.get_obs_by_addr $src_host);
let $src_ip = deploy_get_value($src.ip);
let $dst_host = deploy_get_value(ob1.select select concat(svr_ip, ':', svr_port) host from oceanbase.__all_unit where zone='z2' and svr_ip != '$src_ip' and resource_pool_id = 1002, host, 1);
let $dst = deploy_get_value(ob1.get_obs_by_addr $dst_host);
let $dst_ip = deploy_get_value($dst.ip);

# rs指定的src比leader的高
$src.migrate_to $dst,obtest:test:test01;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_meta_table where tenant_id=$tenant_id and table_id=$table_id and role=1 and member_list like '%$dst_ip%', 1, 50;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_meta_table a ,oceanbase.__all_virtual_meta_table b where a.tenant_id=$tenant_id and a.table_id=$table_id and b.table_id=$table_id and a.member_list=b.member_list and a.role=1 and b.role=2 and b.svr_ip='$dst_ip', 1, 20;
sleep 10;

let $src_host_another = deploy_get_value(ob1.select select concat(svr_ip, ':', svr_port) host from oceanbase.__all_virtual_meta_table where zone='z1' and table_id=$table_id, host, 1);
let $src_another = deploy_get_value(ob1.get_obs_by_addr $src_host_another);

alter table test01 primary_zone='z2';
ob1.mysql alter system set enable_auto_leader_switch = true;
ob1.check_until_timeout select count(*) from __all_zone where name = 'merge_status' and zone = 'z2' and info = 'IDLE', 1, 30;
ob1.check_until_timeout select role from oceanbase.__all_virtual_meta_table where tenant_id=$tenant_id and table_id=$table_id and svr_ip='$dst_ip', 1, 15;

# rs指定的src比leader的低
connect(conn2,$ip,root@sys,,,$port);
use oceanbase;
ob1.mysql alter system drop replica partition_id='0%1@$table_id' server='$dst_host';
sleep 3;
eval alter system copy replica partition_id '0%1@$table_id' source='$src_host_another' destination='$src_host';
sleep 3;
eval select value4 from __all_rootservice_event_history where module='balancer' and event = 'finish_add_replica' and value1 like "%$table_id%" and value3 like '%$src_ip%';

ob1.mysql alter system resume merge zone='z1';
ob1.check_version 4;
ob1.mysql alter system major freeze;
ob1.check_version 5;
