# owner: jiahua.cjh
# owner group: storage
# description: test fast recovery failed before add member list
#

ob1=OBI(cluster=1:1:2,proxy_num=0,init_unit_cpu=1, init_unit_num=1);

ob1.reboot;

ob1.mysql alter resource pool obtestpool unit_num 1;
ob1.mysql alter system set migrate_concurrency = 0;
ob1.mysql alter system set server_permanent_offline_time = 20;

let $sys_ip = deploy_get_value(ob1.z1.obs0.ip);
let $sys_port = deploy_get_value(ob1.z1.obs0.mysql_port);

connect(sys_conn, $sys_ip, root@sys,,oceanbase, $sys_port);

let $svr_ip2 = deploy_get_value(ob1.z3.obs0.ip);
let $svr_port2 = deploy_get_value(ob1.z3.obs0.port);

# open errsim
connection sys_conn;
ob1.mysql alter system set_tp tp_no = 222, error_code = 4016, frequency = 1;

# trigger fast recovery
ob1.z3.obs0.force_stop;

sleep 60;

# make sure fast recovery start
ob1.check_until_timeout select count(*) from __all_rootservice_event_history where module = 'server_fast_recovery' and value1 like '%$svr_ip2:$svr_port2%' and event = 'switch state' and value4 = '1', 1, 180000000;

# check fast recovery success
ob1.check_until_timeout select count(*) from __all_rootservice_event_history where module = 'server_fast_recovery' and value1 like '%$svr_ip2:$svr_port2%' and event = 'finish_recovery', 1, 180000000;

# close errsim
ob1.mysql alter system set_tp tp_no = 222, error_code = 4016, frequency = 0;

# check background task success
ob1.z3.obs1.check_log_until_success -c "keep_tmp_file=true";
