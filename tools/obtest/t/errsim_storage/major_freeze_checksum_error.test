# owner: duoqiao.sc
# owner group: storage
# description: this case is used for testing checksum error when parallel merge
#

--disable_query_log
ob1=OBI(cluster=2:2:2,proxy_num=0,init_unit_cpu=2, init_unit_num=2);
ob1.reboot;

#设置灰度切主的时间为0, 关闭自动切主，关闭自动balance
ob1.mysql alter system set resource_hard_limit = 800;
ob1.mysql alter system set debug_sync_timeout = '100000s';
let $ip = deploy_get_value(ob1.z1.obs0.ip);
let $port = deploy_get_value(ob1.z1.obs0.mysql_port);

ob1.create_client tenant=obtest,user=root,passwd=,database=test;

create table test01(c1 int, c2 int, c3 varchar(4096), primary key(c1)) primary_zone='z1';
sleep 10;

let $cnt=1;
while($cnt < 10)
{
  eval insert into test01 values($cnt, $cnt, 'oceanbase');
  inc $cnt;
}
ob1.mysql alter system major freeze;
ob1.check_version 2;

let $tenant_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name='obtest', tenant_id, 1);
let $table_id = deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where table_name='test01', table_id, 1);
let $src_host = deploy_get_value(ob1.select select concat(svr_ip, ':', svr_port) host from oceanbase.__all_virtual_meta_table where zone='z2' and table_id=$table_id, host, 1);
let $src = deploy_get_value(ob1.get_obs_by_addr $src_host);
let $src_ip = deploy_get_value($src.ip);
let $cnt=10;
while($cnt < 20)
{
  eval insert into test01 values($cnt, $cnt, 'oceanbase');
  inc $cnt;
}
$src.mysql alter system set_tp tp_no = 22, error_code = 4103, frequency = 1;
ob1.mysql alter system minor freeze tenant obtest;
while($cnt < 30)
{
  eval insert into test01 values($cnt, $cnt, 'oceanbase');
  inc $cnt;
}
sleep 10;
ob1.mysql alter system major freeze;
$src.check_log_until_success -c "succ to dump";
#expect 
ob1.check_until_timeout select value from oceanbase.__all_zone where name='merge_status' and zone ='', 3, 10;
ob1.check_until_timeout select hold_count from oceanbase.__all_virtual_macro_block_marker_status where svr_ip = '$ip', 0, 10;
