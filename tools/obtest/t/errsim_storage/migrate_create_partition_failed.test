# owner: yongle.xh
# owner group: storage
# description: this case is use for migrate_check_sub_task_fail.test
#

--disable_query_log
ob1=OBI(cluster=2:2:2,proxy_num=0,init_unit_cpu=2, init_unit_num=2);
ob1.reboot;

#设置灰度切主的时间为0, 关闭自动切主，关闭自动balance
ob1.mysql alter system set resource_hard_limit = 800;
ob1.mysql alter system set merger_switch_leader_duration_time=0;
ob1.mysql alter system set enable_auto_leader_switch = false;
ob1.mysql alter system set enable_rereplication = false;
ob1.mysql alter system set enable_rebalance = false;
ob1.mysql alter system set debug_sync_timeout = '100000s';

let $ip = deploy_get_value(ob1.z1.obs0.ip);
let $port = deploy_get_value(ob1.z1.obs0.mysql_port);

connect (conn,$ip,root@obtest,,test,$port);
connection conn;

create table test01(c1 int, c2 int, c3 varchar(4096), primary key(c1)) primary_zone='z1';
sleep 10;

let $cnt=1;
while($cnt < 10)
{
  eval insert into test01 values($cnt, $cnt, 'oceanbase');
  inc $cnt;
}

ob1.mysql alter system major freeze;
ob1.check_version 2;

# another merge process
while ($cnt < 20)
{
  eval insert into test01 values($cnt, $cnt, 'oceanbase');
  inc $cnt;
}

ob1.mysql alter system major freeze;
ob1.check_version 3;

let $tenant_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name='obtest', tenant_id, 1);
let $table_id = deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where table_name='test01', table_id, 1);
let $src_host = deploy_get_value(ob1.select select concat(svr_ip, ':', svr_port) host from oceanbase.__all_virtual_partition_location where  tenant_id=$tenant_id and zone='z2' and table_id=$table_id and partition_id=0, host, 1);
let $src = deploy_get_value(ob1.get_obs_by_addr $src_host);
let $src_ip = deploy_get_value($src.ip);
let $src_port = deploy_get_value($src.port);
let $dst_host = deploy_get_value(ob1.select select concat(svr_ip, ':', svr_port) host from oceanbase.__all_unit where zone='z2' and !(svr_ip = '$src_ip' and svr_port = $src_port) and resource_pool_id = 1001, host, 1);
let $dst = deploy_get_value(ob1.get_obs_by_addr $dst_host);
let $dst_ip = deploy_get_value($dst.ip);
let $member_list = deploy_get_value(ob1.select select member_list from oceanbase.__all_virtual_partition_location where  tenant_id=$tenant_id and table_id=$table_id and partition_id=0 and role=1, member_list, 1);

# small task, no retry
$dst.mysql alter system set_tp tp_no = 216, error_code = 4016, frequency = 1;
sleep 1;
$src.migrate_to $dst,obtest:test:test01;
#expect 4015
ob1.check_until_timeout select value4 from oceanbase.__all_rootservice_event_history where module='balancer' and event = 'finish_migrate_replica' and value1 like "%$table_id%" order by gmt_create desc limit 1, -4016, 30;
$dst.mysql alter system set_tp tp_no = 216, error_code = 4016, frequency = 0;

#TODO(haofan) this has bug, log service partition can not removed
sleep 600;
$src.migrate_to $dst,obtest:test:test01;
ob1.check_until_timeout select value4 from oceanbase.__all_rootservice_event_history where module='balancer' and event = 'finish_migrate_replica' and value1 like "%$table_id%" order by gmt_create desc limit 1, 0, 30;



let $ip = deploy_get_value($dst.ip);
let $port = deploy_get_value($dst.mysql_port);
connect (conn_dst,$ip,root@obtest,,test,$port);
connection conn_dst;
select /*+read_consistency(weak)*/ * from test01;

