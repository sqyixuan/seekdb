# owner: yongle.xh
# owner group: storage
# description: this case is use for migrate_rebuild_during_wait_replay
#

--disable_query_log
ob1=OBI(cluster=1:2:1,proxy_num=0,init_unit_cpu=2, init_unit_num=1);

ob1.z2.obs1.set status=disable;
ob1.reboot;

#设置灰度切主的时间为0, 关闭自动切主，关闭自动balance
ob1.mysql alter system set resource_hard_limit = 800;
ob1.mysql alter system set merger_switch_leader_duration_time=0;
ob1.mysql alter system set enable_auto_leader_switch = false;
ob1.mysql alter system set enable_rebalance=true;
ob1.mysql alter system set enable_rereplication=true;
ob1.mysql alter system set debug_sync_timeout = '100000s';
ob1.mysql alter system set server_data_copy_in_concurrency = 10;
ob1.mysql alter system set server_data_copy_out_concurrency = 10;
#ob1.mysql alter system set replica_safe_remove_time='60s';
#ob1.mysql alter system set partition_table_check_interval='60s';
#ob1.mysql alter system set server_permanent_offline_time='20s';
ob1.mysql alter system set balancer_idle_time='10s';

ob1.create_client tenant=obtest,user=root,passwd=,database=test;

let $count=1;
while($count < 10)
{
  eval create table test_$count(c1 int, c2 int, c3 varchar(4096), primary key(c1)) primary_zone='z1';
  inc $count;
}

ob1.z1.obs0.mysql alter system major freeze;
ob1.check_version 2;

ob1.z2.obs1.set status=enable;
ob1.z2.obs1.start;
sleep 10;
ob1.z2.obs1.add;
sleep 30;

let $pool_id = deploy_get_value(ob1.select select resource_pool_id from oceanbase.__all_resource_pool where name = 'obtestpool', resource_pool_id, 1);
let $unit_id = deploy_get_value(ob1.select select unit_id from oceanbase.__all_unit where zone='z2' and resource_pool_id=$pool_id, unit_id, 1);

#用于模拟is_log_sync返回OB_SUCCESS,is_sync false的情况。让所有的task都卡在wait replay。
ob1.mysql set ob_global_debug_sync = 'BEFORE_MIGRATE_WAIT_REPLAY wait_for later timeout 3000000 execute 10000';
ob1.z2.obs0.mysql alter system set_tp tp_no = 10, error_code = 4012, frequency = 1;
ob1.z2.obs1.mysql alter system set_tp tp_no = 10, error_code = 4012, frequency = 1;

ob1.z2.migrate_unit $unit_id;
sleep 30;

ob1.z2.obs0.stop;
ob1.z2.obs0.check_stop;
ob1.z2.obs1.stop;
ob1.z2.obs1.check_stop;

ob1.z1.obs0.mysql_p select value4 from oceanbase.__all_rootservice_event_history where module='balancer' and event = 'finish_migrate_replica';

ob1.z1.obs0.mysql_p select count(*) from oceanbase.__all_virtual_concurrency_object_pool where free_list_name like '%ObPartitionBaseDataInfo%' and count != 0;
ob1.z1.obs0.mysql_p select count(*) from oceanbase.__all_virtual_concurrency_object_pool where free_list_name like '%ObPartitionMacroBlockObReader%' and count != 0;
ob1.z1.obs0.mysql_p select count(*) from oceanbase.__all_virtual_concurrency_object_pool where free_list_name like '%ObPartitionBaseDataMetaObReader%' and count != 0;
ob1.z1.obs0.mysql_p select sum(USED), sum(COUNT) from oceanbase.__all_virtual_memory_info where mod_name like 'OB_PARTITION_MIGRATE';
