# owner: yongle.xh
# owner group: storage
# description: this case is use for test_macro_block_writer_leak
#

--disable_query_log
ob1=OBI(cluster=1,proxy_num=0,init_unit_cpu=2, init_unit_num=1);
ob1.z1.obs0.set extra_config=mark_and_sweep_interval='2s';
ob1.reboot;

#设置灰度切主的时间为0, 关闭自动切主，关闭自动balance
ob1.mysql alter system set resource_hard_limit = 800;
ob1.mysql alter system set merger_switch_leader_duration_time=0;
ob1.mysql alter system set enable_auto_leader_switch = false;
ob1.mysql alter system set enable_rereplication = false;
ob1.mysql alter system set enable_rebalance = false;
ob1.mysql alter system set merge_thread_count=64;
ob1.mysql alter system set debug_sync_timeout = '100000s';

ob1.create_client tenant=obtest,user=root,passwd=,database=test;

create table test(id int primary key, v1 varchar(65535), v2 varchar(65535)) tablet_size=104857600 compression='none';

# prepare data
--disable_query_log
let $table_size = 0;
let $i=0;
while($i < 200)
{
  eval insert into test values($i, repeat(rand(),3000), repeat(rand(),3000));
  inc $i;
}
--enable_query_log

ob1.mysql alter system major freeze;
ob1.check_version 2;

update test set v1='aaa' where id=1;

ob1.mysql alter system set macro_block_builder_errsim_flag=2;
sleep 3;
ob1.mysql alter system major freeze;
ob1.z1.obs0.check_log_until_success -c "macro_block_builder_errsim_flag=2";
ob1.mysql alter system set macro_block_builder_errsim_flag=0;
ob1.check_version 3;

sleep 3;
ob1.mysql_p select hold_count from oceanbase.__all_virtual_macro_block_marker_status;

