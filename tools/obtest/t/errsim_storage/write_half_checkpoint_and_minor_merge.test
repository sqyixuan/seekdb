# owner: zhenjiang.xzj
# owner group: storage
# description:this case is use for create index test
#
--disable_query_log
ob1=OBI(cluster=1:1:1,proxy_num=1,init_unit_cpu=2);
ob1.reboot;

ob1.create_client;

ob1.mysql alter system set merger_check_interval='10s';
ob1.mysql alter system set enable_rebalance = 'false';
ob1.mysql alter system set resource_hard_limit=500;
ob1.mysql alter system set schema_drop_gc_delay_time='1s';
ob1.create_client tenant=obtest,user=root,passwd=,database=test;

create table t1 (c1 int, c2 int, c3 varchar(25), c4 int, primary key(c1)) partition by hash (c1) partitions 2;
insert into t1 values (1, 2, '3', 4);
insert into t1 values (5, 2, '7', 8);
insert into t1 values (9, 10, '11', 12);
insert into t1 values(13, NULL, '15', 16);

ob1.mysql alter system major freeze;
ob1.check_version 2;
ob1.z1.obs0.check_log_until_success -c "succeed to write checkpoint";

ob1.z1.obs0.force_stop;
ob1.check_until_timeout select status from oceanbase.__all_server where zone='z1', inactive, 60;
ob1.z1.obs0.nstart;
ob1.check_until_timeout select status from oceanbase.__all_server where zone='z1', active, 60;
sleep 10;
ob1.z1.obs0.mysql alter system set_tp tp_no = 129, error_code = 4016, frequency = 1;
create table t2 (c1 int, c2 int, c3 varchar(25), c4 int, primary key(c1)) partition by hash (c1) partitions 2;
insert into t2 values (1, 2, '3', 4);
insert into t2 values (5, 2, '7', 8);
create index i1 on t2(c2);

ob1.mysql alter system minor freeze tenant = sys;
ob1.mysql alter system minor freeze tenant = all_user;
ob1.mysql alter system minor freeze tenant = all_meta;
sleep 5;

ob1.z1.obs0.force_stop;
ob1.check_until_timeout select status from oceanbase.__all_server where zone='z1', inactive, 60;
ob1.z1.obs0.nstart;
ob1.check_until_timeout select status from oceanbase.__all_server where zone='z1', active, 60;
sleep 10;
ob1.z1.obs0.check_log_until_success -c "succeed to write checkpoint";

ob1.mysql alter system minor freeze tenant = sys;
ob1.mysql alter system minor freeze tenant = all_user;
ob1.mysql alter system minor freeze tenant = all_meta;
sleep 5;
drop index i1 on t2;
sleep 2;

ob1.z1.obs0.force_stop;
ob1.check_until_timeout select status from oceanbase.__all_server where zone='z1', inactive, 60;
ob1.z1.obs0.nstart;
ob1.check_until_timeout select status from oceanbase.__all_server where zone='z1', active, 60;
sleep 10;
ob1.z1.obs0.check_log_until_success -c "succeed to write checkpoint";
