# owner: buwen.wbw
# owner group: storage
# 
# 

ob1=OBI(cluster=1:1:1, init_unit_cpu=2, proxy_num=0, ct_num = 0);
ob1.reboot;
sleep 5;

ob1.create_client tenant=obtest,user=admin,passwd=admin,database=test;
ob1.mysql alter system set merge_thread_count = 1;

create table info (
  l_user_id bigint not null,
  l_item_type bigint not null,
  l_item_id bigint not null,
  l_collect_time bigint not null,
  l_info_from varchar(255) default null,
  l_info_note char(255) default null,
  primary key (l_user_id, l_item_type, l_item_id)
) partition by key (l_user_id) partitions 2;

alter table info set compression = 'none';

create table item (
  r_item_id bigint not null,
  r_item_type bigint not null,
  r_item_title varchar(255) default null,
  r_item_price bigint default null,
  r_item_note char(255) default null,
  primary key (r_item_id, r_item_type)
)locality='F,R{all_server}@z1, F,R{all_server}@z2, F,R{all_server}@z3';

alter table item set compression = 'none';

create materialized view mv_info_item as
  select info.l_item_id, info.l_info_from, info.l_info_note, item.r_item_title, item.r_item_price, item.r_item_note, info.l_user_id, info.l_item_type, info.l_collect_time, item.r_item_id, item.r_item_type
  from info, item where info.l_item_type = item.r_item_type and info.l_item_id = item.r_item_id
  order by info.l_user_id, info.l_item_type, info.l_collect_time;

let $from='fromfromfromfromfromfromfromfromfromfromfromfromfromfromfromfromfromfromfromfromfromfromfromfromfromfromfromfromfromfromfromfromfromfromfromfromfromfromfromfromfromfromfromfromfromfromfromfrom';
let $note='notenotenotenotenotenotenotenotenotenotenotenotenotenotenotenotenotenotenotenotenotenotenotenotenotenotenotenotenotenotenotenotenotenotenotenotenotenotenotenotenotenotenotenotenotenotenotenote';
let $title='titletitletitletitletitletitletitletitletitletitletitletitletitletitletitletitletitletitletitletitletitletitletitletitletitletitletitletitletitletitletitletitletitletitletitletitletitletitle';

let $mv_tid = deploy_get_value(ob1.select select table_id as v from __all_virtual_table where table_name = 'mv_info_item', v, 1);
let $z1_ip = deploy_get_value(ob1.z1.obs0.ip);
let $z1_port = deploy_get_value(ob1.z1.obs0.port);
let $z2_ip = deploy_get_value(ob1.z2.obs0.ip);
let $z2_port = deploy_get_value(ob1.z2.obs0.port);
let $z3_ip = deploy_get_value(ob1.z3.obs0.ip);
let $z3_port = deploy_get_value(ob1.z3.obs0.port);

# 插入数据，保证mv有2个宏块
--disable_query_log
--disable_result_log
let $i=1;
set @cnt=1;
while($i < 8000)
{
  let $stmt=insert into info values (@cnt, 10+@cnt, 100+@cnt, 1000+@cnt, $from, $note);
  eval $stmt;
  set @cnt=@cnt+1;
  inc $i;
}

let $i=1;
set @cnt=1;
while($i < 7000)
{
  let $stmt=insert into item values (100+@cnt, 10+@cnt, $title, 10000+@cnt, $note);
  eval $stmt;
  set @cnt=@cnt+1;
  inc $i;
}
--enable_query_log
--enable_result_log

sleep 1;
ob1.mysql alter system major freeze;
ob1.check_until_timeout  select value from oceanbase.__all_zone where name='last_merged_version' and zone = '', 2, 500;
ob1.check_until_timeout select index_status from oceanbase.__all_virtual_table where tenant_id=1001 and table_name = 'mv_info_item', 2, 20;

### case 1: mv 的依赖表没处理空删问题
#   步骤： 
#     1. insert一条数据
#     2. 某台follower做转储
#     3. del这条数据
#     4. scan这条数据，此时leader会purge，但是做了转储的follower不会。
#     5. 保证前一个宏块有删除，这样没有purge的会重写两个宏块，purge过的只重写一个宏块

insert into item values (7500, 7410, '11', 7500, '11');
--disable_query_log
--disable_result_log
let $i=1;
while($i < 500)
{
  eval delete from info where l_user_id = $i;
  inc $i;
}
--enable_query_log
--enable_result_log

sleep 1;
let $tid = deploy_get_value(ob1.select select table_id as v from __all_virtual_table where table_name = 'info', v, 1);
ob1.mysql alter system minor freeze tenant obtest server = ('$z2_ip:$z2_port');
ob1.z2.obs0.check_log_until_success -c "Success to do trans minor merge partition.*$tid.*3-0-0";

# 使用scan触发purge
delete from item where r_item_id = 7500;
--disable_result_log
select * from item where r_item_id > 6999;
select * from item where r_item_id > 6999;
--enable_result_log

sleep 1;
ob1.mysql alter system major freeze;
ob1.check_until_timeout  select value from oceanbase.__all_zone where name='last_merged_version' and zone = '', 3, 500;


# 比较data_checksum
let $mv_checksum_p0_z1 = deploy_get_value(ob1.select select data_checksum as v from __all_virtual_storage_stat where sstable_id = $mv_tid and major_version = 3 and svr_ip = '$z1_ip' and svr_port = '$z1_port' and partition_id = 0, v, 1);
let $mv_checksum_p0_z2 = deploy_get_value(ob1.select select data_checksum as v from __all_virtual_storage_stat where sstable_id = $mv_tid and major_version = 3 and svr_ip = '$z2_ip' and svr_port = '$z2_port' and partition_id = 0, v, 1);
let $mv_checksum_p0_z3 = deploy_get_value(ob1.select select data_checksum as v from __all_virtual_storage_stat where sstable_id = $mv_tid and major_version = 3 and svr_ip = '$z3_ip' and svr_port = '$z3_port' and partition_id = 0, v, 1);
let $mv_checksum_p1_z1 = deploy_get_value(ob1.select select data_checksum as v from __all_virtual_storage_stat where sstable_id = $mv_tid and major_version = 3 and svr_ip = '$z1_ip' and svr_port = '$z1_port' and partition_id = 1, v, 1);
let $mv_checksum_p1_z2 = deploy_get_value(ob1.select select data_checksum as v from __all_virtual_storage_stat where sstable_id = $mv_tid and major_version = 3 and svr_ip = '$z2_ip' and svr_port = '$z2_port' and partition_id = 1, v, 1);
let $mv_checksum_p1_z3 = deploy_get_value(ob1.select select data_checksum as v from __all_virtual_storage_stat where sstable_id = $mv_tid and major_version = 3 and svr_ip = '$z3_ip' and svr_port = '$z3_port' and partition_id = 1, v, 1);

ob1.mysql_p select '$mv_checksum_p0_z1' = '$mv_checksum_p0_z2' as checksum_cmp;
ob1.mysql_p select '$mv_checksum_p0_z1' = '$mv_checksum_p0_z3' as checksum_cmp;
ob1.mysql_p select '$mv_checksum_p1_z1' = '$mv_checksum_p1_z2' as checksum_cmp;
ob1.mysql_p select '$mv_checksum_p1_z1' = '$mv_checksum_p1_z3' as checksum_cmp;

### case 2: item表合并导致的问题
# 步骤：
#   1. 在前一个宏块删除部分数据，同时保证MV中第二个宏块的部分行中右表部分为空
#   2. 注入错误使得mv合并失败（merge thread count = 1）
#   3. 如果item先合并，那么会重写两个宏块；否则只会重写前一个宏块

--disable_query_log
--disable_result_log
let $i=500;
while($i < 1000)
{
  eval delete from info where l_user_id = $i;
  inc $i;
}
--enable_query_log
--enable_result_log

ob1.mysql alter system set_tp tp_no = 7, error_code = 6215, frequency = 2;

sleep 1;
ob1.mysql alter system major freeze;
ob1.check_until_timeout  select value from oceanbase.__all_zone where name='last_merged_version' and zone = '', 4, 600;

# 比较data_checksum
let $mv_checksum_p0_z1 = deploy_get_value(ob1.select select data_checksum as v from __all_virtual_storage_stat where sstable_id = $mv_tid and major_version = 4 and svr_ip = '$z1_ip' and svr_port = '$z1_port' and partition_id = 0, v, 1);
let $mv_checksum_p0_z2 = deploy_get_value(ob1.select select data_checksum as v from __all_virtual_storage_stat where sstable_id = $mv_tid and major_version = 4 and svr_ip = '$z2_ip' and svr_port = '$z2_port' and partition_id = 0, v, 1);
let $mv_checksum_p0_z3 = deploy_get_value(ob1.select select data_checksum as v from __all_virtual_storage_stat where sstable_id = $mv_tid and major_version = 4 and svr_ip = '$z3_ip' and svr_port = '$z3_port' and partition_id = 0, v, 1);
let $mv_checksum_p1_z1 = deploy_get_value(ob1.select select data_checksum as v from __all_virtual_storage_stat where sstable_id = $mv_tid and major_version = 4 and svr_ip = '$z1_ip' and svr_port = '$z1_port' and partition_id = 1, v, 1);
let $mv_checksum_p1_z2 = deploy_get_value(ob1.select select data_checksum as v from __all_virtual_storage_stat where sstable_id = $mv_tid and major_version = 4 and svr_ip = '$z2_ip' and svr_port = '$z2_port' and partition_id = 1, v, 1);
let $mv_checksum_p1_z3 = deploy_get_value(ob1.select select data_checksum as v from __all_virtual_storage_stat where sstable_id = $mv_tid and major_version = 4 and svr_ip = '$z3_ip' and svr_port = '$z3_port' and partition_id = 1, v, 1);

ob1.mysql_p select '$mv_checksum_p0_z1' = '$mv_checksum_p0_z2' as checksum_cmp;
ob1.mysql_p select '$mv_checksum_p0_z1' = '$mv_checksum_p0_z3' as checksum_cmp;
ob1.mysql_p select '$mv_checksum_p1_z1' = '$mv_checksum_p1_z2' as checksum_cmp;
ob1.mysql_p select '$mv_checksum_p1_z1' = '$mv_checksum_p1_z3' as checksum_cmp;

### case 3: item表rebuild使得item表先合并，同时item表有A-> update B -> update A这样的操作，item先合并后mv无法判断是否A是否有update
# 步骤：
# 2. z2-3上item设置为rebuild
# 3. 卡住info表合并（info一直合并失败），直到z2-3的item表rebuild成功
# 4. info表开始合并

--disable_query_log
--disable_result_log
let $i=1000;
while($i < 1100)
{
  eval delete from info where l_user_id = $i;
  inc $i;
}
--enable_query_log
--enable_result_log

update item set r_item_title = 'aaa' where r_item_id = 6900;
eval update item set r_item_title = $title where r_item_id = 6900;

let $item_tid = deploy_get_value(ob1.select select table_id as v from __all_virtual_table where table_name = 'item', v , 1);

ob1.mysql alter system major freeze;
ob1.check_until_timeout  select value from oceanbase.__all_zone where name='last_merged_version' and zone = 'z1', 5, 500;
ob1.mysql alter system set_tp tp_no = 7, error_code = 6215, frequency = 1;
ob1.mysql update oceanbase.__all_virtual_meta_table set rebuild = 1 where tenant_id = 1001 and table_id = $item_tid and zone = 'z2';
ob1.mysql update oceanbase.__all_virtual_meta_table set rebuild = 1 where tenant_id = 1001 and table_id = $item_tid and zone = 'z3';

# wait rebuild finish
ob1.check_until_timeout select count(*) c from __all_virtual_meta_table where tenant_id = 1001 and table_id = $item_tid and rebuild = 1, 0, 1000;

ob1.mysql alter system set_tp tp_no = 7, error_code = 6215, frequency = 1000000;
ob1.check_until_timeout  select value from oceanbase.__all_zone where name='last_merged_version' and zone = '', 5, 500;

# 比较data_checksum
let $mv_checksum_p0_z1 = deploy_get_value(ob1.select select data_checksum as v from __all_virtual_storage_stat where sstable_id = $mv_tid and major_version = 5 and svr_ip = '$z1_ip' and svr_port = '$z1_port' and partition_id = 0, v, 1);
let $mv_checksum_p0_z2 = deploy_get_value(ob1.select select data_checksum as v from __all_virtual_storage_stat where sstable_id = $mv_tid and major_version = 5 and svr_ip = '$z2_ip' and svr_port = '$z2_port' and partition_id = 0, v, 1);
let $mv_checksum_p0_z3 = deploy_get_value(ob1.select select data_checksum as v from __all_virtual_storage_stat where sstable_id = $mv_tid and major_version = 5 and svr_ip = '$z3_ip' and svr_port = '$z3_port' and partition_id = 0, v, 1);
let $mv_checksum_p1_z1 = deploy_get_value(ob1.select select data_checksum as v from __all_virtual_storage_stat where sstable_id = $mv_tid and major_version = 5 and svr_ip = '$z1_ip' and svr_port = '$z1_port' and partition_id = 1, v, 1);
let $mv_checksum_p1_z2 = deploy_get_value(ob1.select select data_checksum as v from __all_virtual_storage_stat where sstable_id = $mv_tid and major_version = 5 and svr_ip = '$z2_ip' and svr_port = '$z2_port' and partition_id = 1, v, 1);
let $mv_checksum_p1_z3 = deploy_get_value(ob1.select select data_checksum as v from __all_virtual_storage_stat where sstable_id = $mv_tid and major_version = 5 and svr_ip = '$z3_ip' and svr_port = '$z3_port' and partition_id = 1, v, 1);

ob1.mysql_p select '$mv_checksum_p0_z1' = '$mv_checksum_p0_z2' as checksum_cmp;
ob1.mysql_p select '$mv_checksum_p0_z1' = '$mv_checksum_p0_z3' as checksum_cmp;
ob1.mysql_p select '$mv_checksum_p1_z1' = '$mv_checksum_p1_z2' as checksum_cmp;
ob1.mysql_p select '$mv_checksum_p1_z1' = '$mv_checksum_p1_z3' as checksum_cmp;
