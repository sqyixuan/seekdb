# owner: yanyuan.cxf
# owner group: transaction
# description: 转储未提交事务lob功能测试

--disable_query_log
ob1=OBI(cluster=1:1, proxy_num=0, init_unit_cpu=2);
ob1.reboot;

ob1.mysql alter system set enable_auto_leader_switch=false;
ob1.mysql alter system set enable_one_phase_commit=true;
#ob1.mysql alter system set syslog_level='debug';

let $ip0=deploy_get_value(ob1.z1.obs0.ip);
let $port0=deploy_get_value(ob1.z1.obs0.port);
let $sql_port0=deploy_get_value(ob1.z1.obs0.mysql_port);
let $ip1=deploy_get_value(ob1.z2.obs0.ip);
let $port1=deploy_get_value(ob1.z2.obs0.port);
let $sql_port1=deploy_get_value(ob1.z2.obs0.mysql_port);

connect(conn0,$ip0,root@sys,,oceanbase,$sql_port0);
connect(conn_obtest,$ip0,root@obtest,,test,$sql_port0);

connection conn_obtest;
set global ob_query_timeout = 100000000000;
set global ob_trx_timeout = 100000000000;
set global max_allowed_packet=1000000000;
sleep 2;

# 测试用连接
connect(conn1,$ip0,root@obtest,,test,$sql_port0);

# 备机连接
connect(conn1_slave,$ip1,root@obtest,,test,$sql_port1);

connection conn1;
create table t(id1 int primary key, id2 int, id3 int) partition by hash(id1) partitions 10;
begin;
insert into t values(1, 2, 3);
insert into t values(2, 2, 3);
insert into t values(3, 2, 3);
insert into t values(4, 2, 3);
insert into t values(5, 2, 3);
insert into t values(6, 2, 3);
insert into t values(7, 2, 3);
insert into t values(8, 2, 3);
commit;

ob1.mysql alter system minor freeze tenant = sys;
ob1.mysql alter system minor freeze tenant = all_user;
ob1.mysql alter system minor freeze tenant = all_meta;
let $tid = deploy_get_value(ob1.select select table_id v from oceanbase.__all_virtual_table where table_name='t', v, 1);
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table_mgr where table_id=$tid and table_type=0 and is_active=0, 0, 300;

create table t1(id1 int primary key, id2 int, id3 int) partition by hash(id1) partitions 10;
begin;
insert into t1 values(1, 2, 3);
insert into t1 values(2, 2, 3);
insert into t1 values(3, 2, 3);
insert into t1 values(4, 2, 3);
insert into t1 values(5, 2, 3);
insert into t1 values(6, 2, 3);
insert into t1 values(7, 2, 3);
insert into t1 values(8, 2, 3);
commit;

ob1.force_stop;

sleep 5;

ob1.nstart;

sleep 60;

ob1.mysql alter system minor freeze tenant = sys;
ob1.mysql alter system minor freeze tenant = all_user;
ob1.mysql alter system minor freeze tenant = all_meta;
sleep 1;
let $tid1 = deploy_get_value(ob1.select select table_id v from oceanbase.__all_virtual_table where table_name='t1', v, 1);
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table_mgr where table_id=$tid1 and table_type=0 and is_active=0, 0, 300;
