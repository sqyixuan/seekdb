# owner: yanyuan.cxf
# owner group: transaction
# description: 宕机重启恢复事务状态表

--disable_query_log
ob1=OBI(cluster=1:1, proxy_num=0, init_unit_cpu=2);
ob1.reboot;

ob1.mysql alter system set enable_auto_leader_switch=false;
ob1.mysql alter system set debug_sync_timeout = '1000s';
#ob1.mysql alter system set syslog_level='debug';
#
ob1.create_client tenant=obtest,user=root,passwd=,database=test;

let $ip0=deploy_get_value(ob1.z1.obs0.ip);
let $port0=deploy_get_value(ob1.z1.obs0.port);
let $sql_port0=deploy_get_value(ob1.z1.obs0.mysql_port);
let $ip1=deploy_get_value(ob1.z2.obs0.ip);
let $port1=deploy_get_value(ob1.z2.obs0.port);
let $sql_port1=deploy_get_value(ob1.z2.obs0.mysql_port);

connect(conn0,$ip0,root@sys,,oceanbase,$sql_port0);
connect(conn_obtest,$ip0,root@obtest,,test,$sql_port0);

connection conn_obtest;
set global ob_query_timeout = 100000000000;
set global ob_trx_timeout = 100000000000;
sleep 2;

# 测试用连接
connect(conn1,$ip0,root@obtest,,test,$sql_port0);
connect(conn2,$ip0,root@obtest,,test,$sql_port0);
connect(conn3,$ip0,root@obtest,,test,$sql_port0);
connect(conn4,$ip0,root@obtest,,test,$sql_port0);

# 备机连接
connect(conn1_slave,$ip1,root@obtest,,test,$sql_port1);

connection conn1;
create table t1(a int primary key, b int, unique key u_idx(b));

insert into t1 (a, b) values (1, 1), (2, 2), (3, 3);

ob1.z2.obs0.switch_partition obtest:test:t1;
sleep 5;
ob1.z2.obs0.check_leader obtest:test:t1;

# <----------------------- 事务执行 -------------------------->

sleep 2;

connection conn1;
begin;
insert into t1 value(6, 6);
insert into t1 values(7, 7);

sleep 2;


# <----------------------- 冻结并转储 -------------------------->

connection conn0;
alter system minor freeze tenant obtest;
let $tid = deploy_get_value(ob1.select select table_id v from oceanbase.__all_virtual_table where table_name='t1', v, 1);
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table_mgr where table_id=$tid and table_type=0 and is_active=0, 0, 100;

# <----------------------- 事务提交前，另一个事务查 -------------------------->

connection conn2;
select * from t1;

connection conn1;
commit;

# <----------------------- 事务提交后，另一个事务查 -------------------------->

connection conn2;
select * from t1;

# <----------------------- 宕机重启后查询 -------------------------->

ob1.z2.obs0.force_stop;

sleep 5;

ob1.z2.obs0.nstart;

sleep 30;

ob1.check_until_timeout select count(1) cnt from oceanbase.__all_server where status='active' and start_service_time>0,2,240;

ob1.z2.obs0.switch_partition obtest:test:t1;
sleep 5;
ob1.z2.obs0.check_leader obtest:test:t1;

select * from t1;

# <----------------------- 验证结果 -------------------------->
sleep 1;


### 验证处于prepare阶段的事务宕机重启的情况

# <----------------------- 事务执行 -------------------------->

sleep 2;
connect(conn1_slave,$ip1,root@obtest,,test,$sql_port1);
connection conn1_slave;
set optimizer_use_sql_plan_baselines = false;
set optimizer_capture_sql_plan_baselines = false;
begin;
insert into t1 value(66, 66);
insert into t1 values(77, 77);

# 卡住提交
ob1.mysql set ob_global_debug_sync = 'BEFORE_DIST_COMMIT wait_for continue_signal2 execute 1000';

commit;

sleep 10;

# <----------------------- 冻结并转储 -------------------------->

connection conn0;
alter system minor freeze tenant obtest;
let $tid = deploy_get_value(ob1.select select table_id v from oceanbase.__all_virtual_table where table_name='t1', v, 1);
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table_mgr where table_id=$tid and table_type=0 and is_active=0, 0, 100;


# <----------------------- 宕机重启后查询 -------------------------->
ob1.mysql set ob_global_debug_sync = 'BEFORE_DIST_COMMIT clear';
ob1.z2.obs0.force_stop;

sleep 5;

ob1.z2.obs0.nstart;

sleep 30;

ob1.check_until_timeout select count(1) cnt from oceanbase.__all_server where status='active' and start_service_time>0,2,240;

ob1.z2.obs0.switch_partition obtest:test:t1;
sleep 5;
ob1.z2.obs0.check_leader obtest:test:t1;

sleep 10;
connect(conn1_slave,$ip1,root@obtest,,test,$sql_port1);
connection conn1_slave;
select * from t1;

# <----------------------- 验证结果 -------------------------->
sleep 1;
