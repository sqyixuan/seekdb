# owner: jingyan.kfy
# owner group: minor_freeze
# Test the case: leader and follower are with different minor versions.

ob1=OBI(cluster=1:1:1,proxy_num=0,init_unit_cpu=1);
ob1.reboot;

let $ip=deploy_get_value(ob1.z1.obs0.ip);
let $port=deploy_get_value(ob1.z1.obs0.mysql_port);
connect (conn_obtest,$ip,root@obtest,,test,$port);
connect (conn_sys,$ip,root@sys,,oceanbase,$port);
connection conn_obtest;
create table t1(c1 int primary key, c2 int);

let $leader = deploy_get_value(ob1.get_leader obtest:oceanbase:t1);
let $leader_ip = deploy_get_value($leader.ip);
let $leader_port = deploy_get_value($leader.port);
let $leader_zone = deploy_get_value(ob1.select select zone z from oceanbase.__all_server where svr_ip='$leader_ip' and svr_port=$leader_port, z, 1);
let $follower = deploy_get_value(ob1.get_follower obtest:oceanbase:t1);
let $follower_ip = deploy_get_value($follower.ip);
let $follower_port = deploy_get_value($follower.port);
let $tid = deploy_get_value(ob1.select select table_id v from oceanbase.__all_virtual_table where table_name='t1', v, 1);

# prevent leader minor merge
ob1.mysql alter system suspend merge zone '$leader_zone';
sleep 5;
insert into t1 values(1, 2);
ob1.mysql alter system minor freeze tenant obtest;
sleep 5;

$leader.force_stop;
$leader.restart;
sleep 60;

# resume merge
ob1.mysql alter system resume merge zone '$leader_zone';
sleep 1;

# after restart, $leader has no frozen memstore
ob1.mysql_p select base_version from oceanbase.__all_virtual_table_mgr where svr_ip="$leader_ip" and svr_port="$leader_port" and table_id=$tid and table_type=0;

insert into t1 values(3, 4);
select * from t1;

# change back to old leader
$leader.switch_partition obtest:oceanbase:t1;
sleep 3;

insert into t1 values(5, 6);
select * from t1;

