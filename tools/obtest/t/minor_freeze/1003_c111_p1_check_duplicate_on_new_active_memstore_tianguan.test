# owner: jingyan.kfy
# owner group: minor_freeze
# Test the case: check duplicate on new active memstore

ob1=OBI(cluster=1:1:1,proxy_num=0,init_unit_cpu=2);
ob1.reboot;

let $ip0=deploy_get_value(ob1.z1.obs0.ip);
let $sql_port0=deploy_get_value(ob1.z1.obs0.mysql_port);

ob1.mysql alter system set resource_hard_limit=800;
ob1.mysql alter system set merger_switch_leader_duration_time=0;
ob1.mysql alter system set enable_auto_leader_switch=false;
ob1.mysql alter system set enable_rereplication=false;
ob1.mysql alter system set enable_rebalance=false;

ob1.create_client tenant=obtest,user=root,passwd=,database=test;
connect(conn0,$ip0,root@obtest,,test,$sql_port0);
connect(conn1,$ip0,root@sys,,oceanbase,$sql_port0);

connection conn0;
create table test.t1(c1 int primary key, c2 int, unique key u_idx(c2));
insert into test.t1 values(1, 2);
let $tid = deploy_get_value(ob1.select select table_id v from oceanbase.__all_virtual_table where table_name='t1', v, 1);

ob1.mysql alter system suspend merge;

ob1.mysql alter system set debug_sync_timeout = '100s';
sleep 2;
ob1.mysql set ob_global_debug_sync = 'DELAY_INDEX_WRITE wait_for index_write timeout 1000000000';
sleep 2;

# wait freeze before index write
set ob_query_timeout=500000000000000;
set ob_trx_timeout=500000000000000;
send insert into test.t1 values(3, 4);

# other connection triggers minor freeze
connection conn1;
send alter system minor freeze tenant obtest;
ob1.check_until_timeout select count(1) from __all_virtual_table_mgr where table_id=$tid and table_type=0 and is_active=0, 3, 120;
sleep 2;
set ob_global_debug_sync = 'NOW signal index_write';

connection conn0;
reap;
# do duplicate checking includ the new active memstore
--error 1062
insert into test.t1 values(4, 4);

