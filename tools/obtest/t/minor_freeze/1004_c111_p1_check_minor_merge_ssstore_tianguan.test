# owner: jingyan.kfy
# owner group: minor_freeze
# Test the case: check minor merge ssstore

ob1=OBI(cluster=1:1:1,proxy_num=0,init_unit_cpu=1);
ob1.reboot;

let $ip0=deploy_get_value(ob1.z1.obs0.ip);
let $sql_port0=deploy_get_value(ob1.z1.obs0.mysql_port);

connect(conn0,$ip0,root@obtest,,test,$sql_port0);
connect(conn1,$ip0,root@obtest,,test,$sql_port0);

connection conn0;
create table t1(c1 int primary key, c2 int, index(c2));
insert into t1 values(1, 2);
insert into t1 values(3, 4);
let $tid = deploy_get_value(ob1.select select table_id v from oceanbase.__all_virtual_table where table_name='t1', v, 1);

#alter system suspend merge;
#sleep 2;
ob1.mysql alter system minor freeze tenant obtest;
ob1.check_until_timeout select count(1) from __all_virtual_table_mgr where table_id=$tid and table_type=0, 3, 120;

connection conn1;
## check final value of data table and index table
# check data table
select * from t1 where c1=3;
# check index table
select * from t1 where c2=4;
#指定frozen version读暂不支持
# check frozen data table
#select /*+frozen_version(2)*/* from oceanbase.t1 where c1=3;
# check frozen index table
#select /*+frozen_version(2)*/* from oceanbase.t1 where c2=4;
#select /*+frozen_version(2)*/* from oceanbase.t1 where c1=1;

