#转储多版本兼容性测试
# owner: muwei
# owner group: storage
# description: this case is use for multi version compatible minor merge
#

--disable_query_log
ob1=OBI(cluster=1:1:1,proxy_num=0,init_unit_cpu=2);
ob1.reboot;

#设置灰度切主的时间为0,关闭自动切主,关闭自动balance
ob1.mysql alter system set resource_hard_limit = 800;
ob1.mysql alter system set merger_switch_leader_duration_time = 0;
ob1.mysql alter system set enable_auto_leader_switch = false;
ob1.mysql alter system set enable_rereplication = false;
ob1.mysql alter system set enable_rebalance = false;

ob1.create_client tenant=obtest,user=root,passwd=,database=test;

create table test01 (pk1 int, pk2 int, pk3 int, f1 varchar(1024), f2 varchar(4096), primary key(pk1,pk2,pk3));
#case 1: 没有前置版本的转储，不开启多版本转储，验证转储功能，以及转储数据的正确性
echo "case 1:";
#step 1):插入数据
let $cnt=1;
while($cnt < 10)
{
  eval insert into test01 values($cnt, $cnt, $cnt, 'ocean', 'base');
  inc $cnt;
}

#step 2):发起小版本2-0的冻结
ob1.mysql alter system minor freeze tenant obtest;

#step 3):验证转储功能
let $tid = deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where table_name='test01', table_id, 1);
ob1.check_until_timeout select count(1) from __all_virtual_table_mgr where table_id=$tid and table_type=0, 3, 120;

#step 4):验证转储数据的正确性
select * from test.test01;

#case 2: 有前置转储版本的转储，当前值转储版本是 MINOR_SSSTORE，验证转储功能，以及转储数据的正确性
echo "case:2";
#step 1):插入数据
ob1.mysql alter system set enable_multi_version_minor_merge = true;
let $cnt=1;
while($cnt < 10)
{
	eval update test.test01 set f1 = 'space' where pk1 = $cnt;
  #eval insert into test.test01 values($cnt, $cnt, $cnt, 'ocean', 'base');
  inc $cnt;
}

#step 2):发起小版本2-1的冻结
ob1.mysql alter system minor freeze tenant obtest;

#step 3):验证转储功能
ob1.check_until_timeout select count(1) from __all_virtual_table_mgr where table_id=$tid and table_type=0, 3, 120;
#step 4):验证转储数据的正确性
select * from test.test01;

#case 3: 转储多版本有转储版本数据，且转储版本数据是MULTI_VERISON_MINOR_SSSTORE，对原有数据进行update操作，验证大版本合并功能，以及数据的正确性
#echo 'case:3';
#step 1):插入数据
let $cnt = 1;
while($cnt < 10)
{
	eval update test.test01 set f2 = 'invincible' where pk1 = $cnt;
  #eval replace into test.test01 values($cnt, $cnt, $cnt, 'space', 'invincible');
  inc $cnt;
}

#step 2):发起大版本2-2冻结
ob1.mysql alter system minor freeze tenant obtest;

#step 3):验证大版本合并的功能
ob1.check_until_timeout select count(1) from __all_virtual_table_mgr where table_id=$tid and table_type=0, 3, 120;

#step 4):验证转储数据的正确性
select * from test.test01;
