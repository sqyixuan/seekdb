# owner: jingyan.kfy
# owner group: transaction
# Test the case: 最基本的转储功能

ob1=OBI(cluster=1:1:1,proxy_num=0,init_unit_cpu=2);
ob1.reboot;

let $ip0=deploy_get_value(ob1.z1.obs0.ip);
let $sql_port0=deploy_get_value(ob1.z1.obs0.mysql_port);


ob1.create_client tenant=obtest,user=root,passwd=,database=test;

connect(conn0,$ip0,root@obtest,,test,$sql_port0);
connect(conn1,$ip0,root@sys,,oceanbase,$sql_port0);

connection conn0;
create table test.t1(c1 int primary key, c2 int, c3 int, unique key u_idx(c2), index idx(c3));

# insert data
--disable_query_log
let $cnt = 1;
while ($cnt <= 10)
{
    eval insert into test.t1 values($cnt, $cnt + 1, $cnt + 2);
    inc $cnt;
}
--enable_query_log

# minor freeze
connection conn1;
alter system minor freeze tenant = sys;
alter system minor freeze tenant = all_user;
alter system minor freeze tenant = all_meta;
sleep 2;

# check memtable destroy
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table_mgr where table_type=0 and is_active=0, 0, 90;

select count(*) > 0 from oceanbase.__all_virtual_table_mgr where table_type=4;

connection conn0;
select * from test.t1;
