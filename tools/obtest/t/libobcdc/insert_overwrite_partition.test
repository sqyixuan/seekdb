#
# owner: yuya.yu
# owner group: storage
# description: insert overwrite partition (direct load)
##

ob1=OBI(cluster=1,init_unit_cpu=5);
ob1.reboot;
ob1.create_client;

# 创建mysql租户oblog_tt，并且切换到mysql租户下
source include/liboblog/create_tenant_with_gts.inc;

# 启动liboblog，同步oblog_tt租户数据
ob1.oblog.gen_conf tb_white_list=oblog_tt.*.* log_level=DEBUG skip_ob_version_compat_check=1;
ob1.oblog.set_extra_argument -m;
ob1.oblog.restart;

let $restart_ts_usec = query_get_value(select time_to_usec(now(6)) as now, now, 1);

let $ddl_stmt_count = 0;
let $dml_stmt_count = 0;

create database oblog_db1;
ob1.oblog.next;
inc $ddl_stmt_count;

use oblog_db1;

create table t1_ins_overwrt (c1 int primary key, c2 int, c3 text) partition by range(c1)(partition p0 values less than(15), partition p1 values less than(25), partition p2 values less than(35), partition p3 values less than(45), partition p4 values less than (MAXVALUE));
ob1.oblog.next;
inc $ddl_stmt_count;

insert into t1_ins_overwrt values (4, 40, repeat('4', 4000));
ob1.oblog.next;
inc $dml_stmt_count;
select md5(c3) from t1_ins_overwrt where c1 = 4;

insert into t1_ins_overwrt values (9, 90, repeat('9', 9000));
ob1.oblog.next;
inc $dml_stmt_count;
select md5(c3) from t1_ins_overwrt where c1 = 9;

insert into t1_ins_overwrt values (15, 150, repeat('5', 5000));
ob1.oblog.next;
inc $dml_stmt_count;
select md5(c3) from t1_ins_overwrt where c1 = 15;

insert into t1_ins_overwrt values (30, 300, repeat('1', 1111));
ob1.oblog.next;
inc $dml_stmt_count;
select md5(c3) from t1_ins_overwrt where c1 = 30;

insert into t1_ins_overwrt values (43, 430, repeat('3', 3000));
ob1.oblog.next;
inc $dml_stmt_count;
select md5(c3) from t1_ins_overwrt where c1 = 43;

create table t2_ins_overwrt (c1 int primary key, c2 int, c3 text) partition by range(c1)(partition p0 values less than(10), partition p1 values less than(20), partition p2 values less than(30), partition p3 values less than (MAXVALUE));
ob1.oblog.next;
inc $ddl_stmt_count;

insert into t2_ins_overwrt values (2, 20, repeat('2', 2000));
ob1.oblog.next;
inc $dml_stmt_count;
select md5(c3) from t2_ins_overwrt where c1 = 2;

insert into t2_ins_overwrt values (17, 170, repeat('7', 7000));
ob1.oblog.next;
inc $dml_stmt_count;
select md5(c3) from t2_ins_overwrt where c1 = 17;

insert into t2_ins_overwrt values (23, 230, repeat('1', 10000));
ob1.oblog.next;
inc $dml_stmt_count;
select md5(c3) from t2_ins_overwrt where c1 = 23;

insert into t2_ins_overwrt values (29, 290, repeat('8', 8000));
ob1.oblog.next;
inc $dml_stmt_count;
select md5(c3) from t2_ins_overwrt where c1 = 29;

set ob_query_timeout=90000000;
# cdc does not support insert overwrite partition
insert overwrite  t2_ins_overwrt partition(p0, p1, p3) select * from t1_ins_overwrt;

insert into t1_ins_overwrt values (5, 50, repeat('a', 5000)), (16, 160, repeat('b', 100)), (27, 270, repeat('c', 6000)), (78, 780, repeat('d', 5000));
ob1.oblog.next;
inc $dml_stmt_count;
select md5(c3) from t1_ins_overwrt where c1 in (5, 16, 27, 78);

insert into t2_ins_overwrt values (6, 60, repeat('h', 400)), (11, 110, repeat('j', 2000)), (13, 130, repeat('k', 930)), (24, 240, repeat('l', 550)), (101, 1010, repeat('s', 9999));
ob1.oblog.next;
inc $dml_stmt_count;
select md5(c3) from t2_ins_overwrt where c1 in (6, 11, 13, 24, 101);

ob1.oblog.gen_conf tb_white_list=oblog_tt.*.* log_level=DEBUG skip_ob_version_compat_check=1;
ob1.oblog.set_extra_argument -m;
ob1.oblog.set_start_tstamp_usec $restart_ts_usec;
ob1.oblog.restart;

let $stmt_count = $ddl_stmt_count + $dml_stmt_count;
let $idx = 0;
while ($idx < $stmt_count)
{
    ob1.oblog.next;
    inc $idx;
}

ob1.oblog.stop;

ob1.oblog.gen_conf tb_white_list=oblog_tt.*.* log_level=DEBUG meta_data_refresh_mode=data_dict skip_ob_version_compat_check=1;
ob1.oblog.set_extra_argument -m;
ob1.oblog.set_start_tstamp_usec $restart_ts_usec;
ob1.oblog.restart;

let $stmt_count = $ddl_stmt_count + $dml_stmt_count;
let $idx = 0;
while ($idx < $stmt_count)
{
    ob1.oblog.next;
    inc $idx;
}

ob1.oblog.stop;

ob1.oblog.gen_conf tb_white_list=oblog_tt.*.* log_level=DEBUG meta_data_refresh_mode=data_dict skip_ob_version_compat_check=1;
ob1.oblog.set_extra_argument -m;
ob1.oblog.restart;
ob1.oblog.stop;
