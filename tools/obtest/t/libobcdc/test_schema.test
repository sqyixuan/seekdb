#
# owner:
# owner group: libobcdc
# description:
# 测试点:
# Test data dictionary
# Many tables
#
##

ob1=OBI(cluster=1,init_unit_cpu=5);
ob1.reboot;
ob1.create_client;

# 准备环境
let $ip=deploy_get_value(ob1.proxy0.ip);
let $port=deploy_get_value(ob1.proxy0.port);
connect (oblog_conn_sys,$ip,admin@sys,admin,oceanbase,$port);

connection oblog_conn_sys;

--disable_warnings
drop tenant if exists oblog_tt;
--disable_warnings
drop resource pool if exists oblog_pool;
--disable_warnings
drop resource unit if exists oblog_box;
--disable_warnings
drop database if exists oblog_db1;

# create tenant, 创建oblog_tt租户
create resource unit oblog_box max_cpu=2, memory_size='20G';
create resource pool oblog_pool unit = 'oblog_box', unit_num = 1, zone_list = ('z1');
create tenant oblog_tt replica_num = 1, primary_zone='z1', resource_pool_list=('oblog_pool') set ob_tcp_invited_nodes='%';

sleep 2;
# 在oblog_tt租户下操作
connect (oblog_conn_tt,$ip,root@oblog_tt,,oceanbase,$port);
connection oblog_conn_tt;


# 30 column
#create table t(
#  id            int primary key,
#  col_int8      tinyint default 1,
#  col_int16     smallint,
#  col_int24     mediumint default 2,
#  col_int32     int,
#  col_int64     bigint,
#  col_uint8     tinyint unsigned,
#  col_uint16    smallint unsigned,
#  col_uint24    mediumint unsigned default 10000,
#  col_uint32    int unsigned,
#  col_uint64    bigint unsigned,
#  col_float     float,
#  col_double    double,
#  col_ufloat    float unsigned,
#  col_udouble   double unsigned,
#  col_decimal   decimal(20, 2) default 11.11,
#  col_udecimal  decimal(20, 4) unsigned,
#  col_datetime  datetime(2),
#  col_timestamp timestamp(3) default '2020-01-01 00:00:00',
#  col_date      date,
#  col_time      time(4),
#  col_year      year(4),
#  col_varchar   varchar(6) default 'helo oceanbase',
#  col_char      char(5),
#  col_varbinary varbinary(5) default 'word oceanbase cdc',
#  col_binary    binary(4),
#  tiny_text     tinytext,
#  tiny_blob     tinyblob,
#  text_type     text,
#  blob_type     blob,
#  medium_text   mediumtext,
#  medium_blob   mediumblob,
#  long_text     longtext,
#  long_blob     longblob
#);

# 创建database 1
create database oblog_db1;
use oblog_db1;

#let $TABLE_COUNT = 10 * 10000;
let $TABLE_COUNT = 10;
let $table_idx = 1;

while ($table_idx <= $TABLE_COUNT)
{
  eval create table tcdc$table_idx( id int primary key, col_int8      tinyint default 1, col_int16     smallint, col_int24     mediumint default 2, col_int32     int, col_int64     bigint, col_uint8     tinyint unsigned, col_uint16    smallint unsigned, col_uint24    mediumint unsigned default 10000, col_uint32    int unsigned, col_uint64    bigint unsigned, col_float     float, col_double    double, col_ufloat    float unsigned, col_udouble   double unsigned, col_decimal   decimal(20, 2) default 11.11, col_udecimal  decimal(20, 4) unsigned, col_datetime  datetime(2), col_timestamp timestamp(3) default '2020-01-01 00:00:00', col_date      date, col_time      time(4), col_year      year(4), col_varchar   varchar(50) default 'helo oceanbase', col_char      char(5), col_varbinary varbinary(100) default 'word oceanbase cdc', col_binary    binary(4), tiny_text     tinytext, tiny_blob     tinyblob, text_type     text, blob_type     blob, medium_text   mediumtext, medium_blob   mediumblob, long_text     longtext, long_blob     longblob);
  inc $table_idx;
}

#source include/liboblog/enable_data_dictionary.inc;

ob1.mysql alter system set dump_data_dictionary_to_log_interval = '10s' tenant sys;
ob1.mysql alter system set dump_data_dictionary_to_log_interval = '10s' tenant all_user;
ob1.mysql alter system set dump_data_dictionary_to_log_interval = '10s' tenant all_meta;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_data_dictionary_in_log where tenant_id=1006, 1, 60000;
sleep 2;

# 启动liboblog
ob1.oblog.gen_conf tb_white_list=sys.oblog*.*|oblog_tt.*.* log_level=DEBUG meta_data_refresh_mode=data_dict;
ob1.oblog.set_extra_argument -i;
ob1.oblog.restart;

CREATE TABLE t (b BIT(8));
ob1.oblog.next;

INSERT INTO t SET b = b'11111111';
ob1.oblog.next;

INSERT INTO t SET b = b'1010';
ob1.oblog.next;

INSERT INTO t SET b = b'1111';
ob1.oblog.next;

CREATE TABLE t2 (b BIT(12));
ob1.oblog.next;

INSERT INTO t2 SET b = b'0';
ob1.oblog.next;

INSERT INTO t2 SET b = b'10';
ob1.oblog.next;

INSERT INTO t2 SET b = b'01';
ob1.oblog.next;

INSERT INTO t2 SET b = b'001';
ob1.oblog.next;

INSERT INTO t2 SET b = b'11111111';
ob1.oblog.next;

INSERT INTO t2 SET b = b'001100000000';
ob1.oblog.next;

INSERT INTO t2 SET b = b'111111111111';
ob1.oblog.next;

# bit最大64位
CREATE TABLE t3 (b BIT(64));
ob1.oblog.next;

INSERT INTO t3 SET b = 0xFFFFFFFFFFFFFFFF;
ob1.oblog.next;

# the range of the length of the BIT type is [1, 64]
CREATE TABLE t4(b BIT(1));
ob1.oblog.next;

INSERT INTO t4 SET b = b'0';
ob1.oblog.next;

INSERT INTO t4 SET b = b'1';
ob1.oblog.next;

# stop liboblog
ob1.oblog.stop;
