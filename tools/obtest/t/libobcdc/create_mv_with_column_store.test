# owner: lana.lgx
# owner group: data
# description: create mv with column group
# 测试点:
#  TODO
##

ob1=OBI(cluster=1,init_unit_cpu=5);
ob1.reboot;
ob1.create_client;

# 创建mysql租户oblog_tt，并且切换到mysql租户下
source include/liboblog/create_tenant_with_gts.inc;

# 启动liboblog，同步oblog_tt租户数据
ob1.oblog.gen_conf tb_white_list=oblog_tt.*.* log_level=DEBUG;
ob1.oblog.restart;

# 创建database 1
create database oblog_db1;
# 输出create database DDL
ob1.oblog.next;

use oblog_db1;

# 创建表
create table t1(c1 int, c2 int, c3 int);
# 输出create table DDL
ob1.oblog.next;

# 执行事务
insert into t1 values(1, 1, 1);
ob1.oblog.next;
insert into t1 values(2, 2, 2);
ob1.oblog.next;
create materialized view mv1 with column group (all columns) as select t1.c1 from t1;
ob1.oblog.next;
create materialized view mv2 with column group (each column) as select t1.c1 from t1;
ob1.oblog.next;
create materialized view mv3 with column group (all columns, each column) as select t1.c1 from t1;
ob1.oblog.next;


# 执行事务
update t1 set c1 = 3 where c1 = 1;
ob1.oblog.next;
update t1 set c1 = 4 where c1 = 2;
ob1.oblog.next;
create materialized view mv4 with column group (all columns) as select t1.c1 from t1;
ob1.oblog.next;
create materialized view mv5 with column group (each column) as select t1.c1 from t1;
ob1.oblog.next;
create materialized view mv6 with column group (all columns, each column) as select t1.c1 from t1;
ob1.oblog.next;


# 执行事务
delete from t1 where c1 = 3;
ob1.oblog.next;
delete from t1 where c1 = 4;
ob1.oblog.next;
create materialized view mv7 with column group (all columns) as select t1.c1 from t1;
ob1.oblog.next;
create materialized view mv8 with column group (each column) as select t1.c1 from t1;
ob1.oblog.next;
create materialized view mv9 with column group (all columns, each column) as select t1.c1 from t1;
ob1.oblog.next;


# 执行drop table DDL
drop table t1;
ob1.oblog.next;
# 执行drop materialized view DDL
drop materialized view mv1;
ob1.oblog.next;
drop materialized view mv2;
ob1.oblog.next;
drop materialized view mv3;
ob1.oblog.next;
drop materialized view mv4;
ob1.oblog.next;
drop materialized view mv5;
ob1.oblog.next;
drop materialized view mv6;
ob1.oblog.next;
drop materialized view mv7;
ob1.oblog.next;
drop materialized view mv8;
ob1.oblog.next;
drop materialized view mv9;
ob1.oblog.next;

# set系统变量不会生成redo日志，不需要迭代数据
set @@time_zone = '+06:00';

# stop liboblog
ob1.oblog.stop;