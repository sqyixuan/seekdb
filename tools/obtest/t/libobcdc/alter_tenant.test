#
# owner:千溪
# owner group:liboblog
# description:
# 测试点:
#     create databae 'a.b'
#     alter tenant
#
##

ob1=OBI(cluster=1);
ob1.reboot;
ob1.create_client;

# 准备环境
source include/liboblog/create_tenant.inc;

# 启动liboblog
ob1.oblog.gen_conf tb_white_list=sys.oblog*.*|oblog_tt.*.* skip_ob_version_compat_check=1;
ob1.oblog.restart;

# 创建database 1
create database `oblog_db1.test`;
ob1.oblog.next;

use `oblog_db1.test`;
create table t1 (pk int primary key);
ob1.oblog.next;

# alter tenant
connection oblog_conn_sys;
alter tenant oblog_tt COMMENT='alter tenant';
ob1.oblog.next;

# 租户下执行alter tenant
connection oblog_conn_tt;
# set variables系列是记录在租户自身下的
alter tenant oblog_tt set variables autocommit = 'off';
ob1.oblog.next;

# 其他类型仍然记录在SYS租户下
alter tenant oblog_tt primary_zone='z1';
ob1.oblog.next;

# 删除oblog_tt租户
connection oblog_conn_sys;
set @@recyclebin = off;
drop tenant oblog_tt force;
ob1.oblog.next;

# stop liboblog
ob1.oblog.stop;

# 清理数据
--disable_warnings
drop resource pool if exists oblog_pool;
--disable_warnings
drop resource unit if exists oblog_box;
--disable_warnings
drop database if exists `oblog_db1.test`;
