#
# owner:shuning.tsn
# description:
# 测试点：测试"租户删除"场景，liboblog是否可以区分租户被删除还是分区是未来分区
#

ob1=OBI(cluster=1, version=2_1_20,oblog_version=current, init_unit_cpu=5);
ob1.reboot;
ob_connect(conn1, ob1.z1.obs0, root, , test, , USE_MYSQL_CONNECTOR);

source include/liboblog/create_tenant_with_gts.inc;

--disable_warnings
drop database if exists oblog_db;
create database oblog_db;
use oblog_db;

# 关闭回收站
set recyclebin=off;

#创建表
create table t1(a int);
create table t2(a int);
sleep 1;
let $start_tstamp = query_get_value(select round(time_to_usec(now()) / 1000000) as now, now, 1);

#构建事务
begin;
insert into t1 values(1);
insert into t1 values(1);
commit;

#设置测试模式
#ob1.oblog.set_extra_argument -H oblog/heartbeat.log;
ob1.oblog.gen_conf tb_white_list=oblog_tt.oblog_db.t*|sys.*.* sort_trans_participants=1 log_level=INFO test_mode_on=1 test_mode_block_verify_participants_time_sec=5 skip_ob_version_compat_check=1;
ob1.oblog.set_start_tstamp $start_tstamp;
ob1.oblog.restart;

sleep 3;

#sys连接drop tenant
connection oblog_conn_sys;
drop tenant oblog_tt;

#ob1.oblog.checkRealTime;
ob1.oblog.stop;

#验证日志
#验证liboblog是否检测到"分区删除"
ob1.oblog.check_log "STATUS=PART_EXIST";
ob1.oblog.check_log "PART_NOT_SERVE";
