# owner bohou.ws
# owner group: LOG
# descriptor: test support for ObTxSegmentBuf

ob1=OBI(cluster=1, init_unit_cpu=5);
ob1.reboot;
ob1.create_client;
source include/liboblog/4_x/create_mysql_tenant.inc;
set @@recyclebin = on;

create database cdc_db;
use cdc_db;

--disable_query_log
let $tb_cnt = 300;
let $part_cnt = 100;
eval create table t0(pk int primary key) partition by hash (pk) partitions $part_cnt;
let $col_cnt = 100;
let $col_idx = 0;
let $col_size = 512;
while ($col_idx < $col_cnt)
{
  inc $col_idx;
  eval alter table t0 add column c$col_idx varchar($col_size) default "default";
}

create unique index uidx_c1 on t0(pk, c1);
create unique index uidx_c1_c2 on t0(pk, c1, c2);
create unique index uidx_c2_c3 on t0(pk, c2, c3);
create unique index uidx_c3_c4 on t0(pk, c3, c4);
create unique index uidx_c4_c5 on t0(pk, c4, c5);

# duplicate table
let $tb_idx = 0;

while ($tb_idx < $tb_cnt)
{
  inc $tb_idx;
  eval create table t$tb_idx like t0;
}

--enable_query_log
sleep 1;
let $restart_usec = query_get_value(select time_to_usec(now(6)) as now, now, 1);
ob1.oblog.gen_conf tb_white_list=*cdc*.*.* log_level=ALL.*:WARN;STORAGE.TRANS:DEBUG;TLOG.*:INFO;TLOG.FETCHER:DEBUG skip_ob_version_compat_check=1;
ob1.oblog.restart;

drop database cdc_db;
use oceanbase;
let $restart_usec1 = query_get_value(select schema_version from __all_ddl_operation where ddl_stmt_str = "drop database cdc_db" order by schema_version desc limit 1, now, 1);
ob1.oblog.next;
ob1.oblog.stop;

# restart after modify ddl_table
ob1.oblog.gen_conf tb_white_list=*cdc*.*.* log_level=ALL.*:WARN;STORAGE.TRANS:DEBUG;TLOG.*:INFO;TLOG.FETCHER:DEBUG skip_ob_version_compat_check=1;
ob1.oblog.set_start_tstamp_usec $restart_usec1;
ob1.oblog.restart;
ob1.oblog.next;
ob1.oblog.stop;

# restart after modify ddl_table
# TODO: add misslog case for big_segment_buf trans log.
ob1.oblog.gen_conf test_mode_on=1 tb_white_list=*cdc*.*.* log_level=ALL.*:WARN;STORAGE.TRANS:DEBUG;TLOG.*:INFO;TLOG.FETCHER:DEBUG skip_ob_version_compat_check=1;
ob1.oblog.set_start_tstamp_usec $restart_usec;
ob1.oblog.restart;
ob1.oblog.next;
ob1.oblog.stop;
