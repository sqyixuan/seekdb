ob1=OBI(cluster=1,init_unit_cpu=5);
ob1.reboot;
ob1.create_client;

# 准备环境
source include/liboblog/create_tenant_with_gts.inc;

# 启动liboblog
ob1.oblog.gen_conf tb_white_list=oblog_tt.*.* log_level=DEBUG skip_ob_version_compat_check=1;
# 只打印HEX
ob1.oblog.set_extra_argument -O -x;
ob1.oblog.restart;

# 创建database 1
create database oblog_db1;
ob1.oblog.next;

use oblog_db1;
# 创建表t1
create table t1(c1 int primary key, c2 varchar(100), c3 varchar(100)) collate gbk_chinese_ci;
ob1.oblog.next;

# 测试插入数据
insert into t1 values(1, 'hello', 'world');
select lower(hex(c2)), lower(hex(c3)) from t1 where c1=1;
ob1.oblog.next;

insert into t1 values(2, '中国', '蚂蚁');
select lower(hex(c2)), lower(hex(c3)) from t1 where c1=2;
ob1.oblog.next;
insert into t1 values(3, 'Xǐxī', 'xixi');
select lower(hex(c2)), lower(hex(c3)) from t1 where c1=3;
ob1.oblog.next;

drop table oblog_db1.t1;
ob1.oblog.next;

create table t1(c1 int primary key, c2 varchar(100) collate gbk_bin);
ob1.oblog.next;

insert into t1 values(1, 'nice');
select lower(hex(c2)) from t1 where c1=1;
ob1.oblog.next;

insert into t1 values(2, '中国');
select lower(hex(c2)) from t1 where c1=2;
ob1.oblog.next;

insert into t1 values(3, 'Xǐxī');
select lower(hex(c2)) from t1 where c1=3;
ob1.oblog.next;

#删除表t1
drop table oblog_db1.t1;
ob1.oblog.next;

create table t1(c1 int primary key, c2 varchar(100)) collate utf16_bin;
ob1.oblog.next;

insert into t1 values(1, '龖龖');
select lower(hex(c2)) from t1 where c1=1;
ob1.oblog.next;

insert into t1 values(2, 'かか');
select lower(hex(c2)) from t1 where c1=2;
ob1.oblog.next;

insert into t1 values(3, 'Würzburg');
select lower(hex(c2)) from t1 where c1=3;
ob1.oblog.next;

drop table oblog_db1.t1;
ob1.oblog.next;

create table t1(c1 int primary key, c2 varchar(100) collate utf16_bin, c3 varchar(100) collate gbk_bin);
ob1.oblog.next;

insert into t1 values(1, '겄겶', '很好');
select lower(hex(c2)), lower(hex(c3)) from t1 where c1=1;
ob1.oblog.next;

insert into t1 values(2, 'café', '疣絸鍄銘莋冝');
select lower(hex(c2)), lower(hex(c3)) from t1 where c1=2;
ob1.oblog.next;

insert into t1 values(3, '꒧꒹꒭', '編緐');
select lower(hex(c2)), lower(hex(c3)) from t1 where c1=3;
ob1.oblog.next;

drop table oblog_db1.t1;
ob1.oblog.next;

#test ascii
create table t1(c1 int primary key, c2 varchar(100) collate ascii_general_ci, c3 varchar(100) collate ascii_bin);
ob1.oblog.next;

insert into t1 values(1, 0x01, 0x7f);
select lower(hex(c2)), lower(hex(c3)) from t1 where c1=1;
ob1.oblog.next;

insert into t1 values(2, 'abcde', 'abcde');
select lower(hex(c2)), lower(hex(c3)) from t1 where c1=2;
ob1.oblog.next;

drop table oblog_db1.t1;
ob1.oblog.next;

#test tis620
create table t1(c1 int primary key, c2 varchar(100) collate tis620_thai_ci, c3 varchar(100) collate tis620_bin);
ob1.oblog.next;

insert into t1 values(1, 0x01, 0xff);
select lower(hex(c2)), lower(hex(c3)) from t1 where c1=1;
ob1.oblog.next;

insert into t1 values(2, 'abcde', 'abcde');
select lower(hex(c2)), lower(hex(c3)) from t1 where c1=2;
ob1.oblog.next;

insert into t1 values(3, 'aใ๓๖', '๛๚๕e');
select lower(hex(c2)), lower(hex(c3)) from t1 where c1=3;
ob1.oblog.next;

drop table oblog_db1.t1;
ob1.oblog.next;

# test utf16le
create table t1(c1 int primary key, c2 varchar(100)) collate utf16le_bin;
ob1.oblog.next;

insert into t1 values(1, '龖龖');
select lower(hex(c2)) from t1 where c1=1;
ob1.oblog.next;

insert into t1 values(2, 'かか');
select lower(hex(c2)) from t1 where c1=2;
ob1.oblog.next;

insert into t1 values(3, 'Würzburg');
select lower(hex(c2)) from t1 where c1=3;
ob1.oblog.next;

drop table oblog_db1.t1;
ob1.oblog.next;

# test hkscsbin
create table t1(c1 int primary key, c2 varchar(100)) collate hkscs_bin;
ob1.oblog.next;

insert into t1 values(1, '㴝');
select lower(hex(c2)) from t1 where c1=1;
ob1.oblog.next;

drop table oblog_db1.t1;
ob1.oblog.next;

create table t1(c1 int primary key, c2 varchar(100)) collate hkscs31_bin;
ob1.oblog.next;

insert into t1 values(1, '㴝');
select lower(hex(c2)) from t1 where c1=1;
ob1.oblog.next;

drop table oblog_db1.t1;
ob1.oblog.next;

create table t1(c1 int primary key, c2 varchar(100)) collate big5_bin;
ob1.oblog.next;

insert into t1 values(1, '許');
select lower(hex(c2)) from t1 where c1=1;
ob1.oblog.next;

drop table oblog_db1.t1;
ob1.oblog.next;

# drop database
drop database oblog_db1;
ob1.oblog.next;

# stop liboblog
ob1.oblog.stop;
