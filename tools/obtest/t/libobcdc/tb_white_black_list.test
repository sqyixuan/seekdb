#
# owner:花隆
# owner group:liboblog
# description:
# 测试点:
#   测试黑名单和白名单
##


ob1=OBI(cluster=1, init_unit_cpu=5);
ob1.reboot;
ob1.create_client;

source include/liboblog/create_tenant.inc;

--disable_warnings
drop database if exists oblog_db;

# 启动liboblog
ob1.oblog.gen_conf tb_white_list=oblog_tt.*.* tb_black_list=oblog_tt.*.*_t|oblog_tt.*.t?[0-9]_[!ab][a-z]|sys.*.*_[00][a-z] skip_ob_version_compat_check=1;
ob1.oblog.restart;

create database oblog_db;
ob1.oblog.next;

use oblog_db;

create table t_abc (pk int primary key);
ob1.oblog.next;

insert into t_abc values (1);
ob1.oblog.next;

create table t_abc_t (pk int primary key);
ob1.oblog.next;
# 被黑名单过滤，期望不输出
insert into t_abc_t values (1);

create table t21_cz(pk int primary key);
ob1.oblog.next;
# 被黑名单过滤，期望不输出
insert into t21_cz values(1);

create table t22_aa(pk int primary key);
ob1.oblog.next;
insert into t22_aa values (1);
ob1.oblog.next;

create table t_abc_00 (pk int primary key);
ob1.oblog.next;
insert into t_abc_00 values (1);
ob1.oblog.next;

create table t_abc_0a (pk int primary key);
ob1.oblog.next;
insert into t_abc_0a values (1);
ob1.oblog.next;

create table t_abc00 (pk int primary key);
ob1.oblog.next;
insert into t_abc00 values (1);
ob1.oblog.next;

create table t_abc0b (pk int primary key);
ob1.oblog.next;
insert into t_abc0b values (1);
ob1.oblog.next;

create table t_ab_c0b (pk int primary key);
ob1.oblog.next;
insert into t_ab_c0b values (1);
ob1.oblog.next;

create table t_ab_c0bt (pk int primary key);
ob1.oblog.next;
insert into t_ab_c0bt values (1);
ob1.oblog.next;

create table t_ab_c0bt_t_a (pk int primary key);
ob1.oblog.next;
insert into t_ab_c0bt_t_a values (1);
ob1.oblog.next;

create table t_ab_c0bt_t_0a_x (pk int primary key);
ob1.oblog.next;
insert into t_ab_c0bt_t_0a_x values (1);
ob1.oblog.next;

# 清理数据
--disable_warnings
drop database if exists oblog_db;
ob1.oblog.next;

ob1.oblog.stop;

ob1.oblog.gen_conf tb_white_list=oblog_tt.*.white* tb_black_list=oblog_tt.*.black* log_level=DEBUG meta_data_refresh_mode=data_dict skip_ob_version_compat_check=1;
ob1.oblog.set_extra_argument -m;
ob1.oblog.restart;
ob1.oblog.stop;

ob1.oblog.gen_conf tb_white_list=oblog_tt.*.white* tb_black_list=oblog_tt.*.black* log_level=DEBUG skip_ob_version_compat_check=1;
ob1.oblog.set_extra_argument -m;
ob1.oblog.restart;
ob1.oblog.stop;
