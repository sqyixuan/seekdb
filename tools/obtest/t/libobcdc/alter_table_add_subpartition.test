#   partition p0
#   (
#     subpartition p0sp0 values in (10, 20, 30),
#     subpartition p0sp1 values in (40, 50, 60)
#   ),
#   partition p1
#   (
#     subpartition p1sp0 values in (10, 20, 30),
#     subpartition p1sp1 values in (40, 50, 60)
#   )
# );
create table t_hash_list_columns (c1 int, c2 int, c3 int) partition by hash (c1) subpartition by list columns (c2)(  partition p0  (    subpartition p0sp0 values in (10, 20, 30),    subpartition p0sp1 values in (40, 50, 60)  ),  partition p1  (    subpartition p1sp0 values in (10, 20, 30),    subpartition p1sp1 values in (40, 50, 60)  ));
ob1.oblog.next;
alter table t_hash_list_columns modify partition p0 add subpartition(  subpartition p0sp2 values in (70, 80, 90));
ob1.oblog.next;
alter table t_hash_list_columns modify partition p1 add subpartition(  subpartition p1sp2 values in (70, 80, 90));
ob1.oblog.next;
insert into t_hash_list_columns values (0, 70, 0);
ob1.oblog.next;


