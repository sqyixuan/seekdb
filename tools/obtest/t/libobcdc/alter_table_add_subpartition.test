#
# owner: zhaoziqian.zzq
# owner group: rs
# description:
#   test obcdc add subpartition in mysql mode
#
#   +-------------------------------------------+--------------+
#   | type                                      | subpartition |
#   +-------------------------------------------+--------------+
#   | range/range_columns + range/range_columns | add          |
#   | range/range_columns + list/list_columns   | add          |
#   | range/range_columns + hash/key            | -            |
#   | list/list_columns + range/range_columns   | add          |
#   | list/list_columns + list/list_columns     | add          |
#   | list/list_columns + hash/key              | -            |
#   | hash/key + range/range_columns            | add          |
#   | hash/key + list/list_columns              | add          |
#   | hash/key + hash/key                       | -            |
#   +-------------------------------------------+--------------+
#
##

ob1=OBI(cluster=1);
ob1.reboot;
ob1.create_client;

# prepare env
let $ip=deploy_get_value(ob1.proxy0.ip);
let $port=deploy_get_value(ob1.proxy0.port);
connect (oblog_conn_sys,$ip,admin@sys,admin,oceanbase,$port);

connection oblog_conn_sys;

--disable_warnings
drop tenant if exists oblog_tt;
--disable_warnings
drop resource pool if exists oblog_pool;
--disable_warnings
drop resource unit if exists oblog_box;

# start obcdc
ob1.oblog.gen_conf tb_white_list=sys.oblog*.*|oblog_tt.*.* skip_ob_version_compat_check=1;
ob1.oblog.restart;

# sys tenant
connection oblog_conn_sys;

# create tenant oblog_tt
create resource unit oblog_box max_cpu=2, memory_size='20G';
create resource pool oblog_pool unit = 'oblog_box', unit_num = 1, zone_list = ('z1');
create tenant oblog_tt replica_num = 1, primary_zone='z1', resource_pool_list=('oblog_pool') set ob_tcp_invited_nodes='%';
ob1.oblog.next;

# oblog_tt tenant
connect (oblog_conn_tt,$ip,root@oblog_tt,,oceanbase,$port);
connection oblog_conn_tt;

# create database
create database oblog_db;
ob1.oblog.next;

use oblog_db;

##### range + range
# create table t_range_range (c1 int, c2 int, c3 int) partition by range (c1)
# subpartition by range (c2)
# (
#   partition p0 values less than (100)
#   (
#     subpartition p0sp0 values less than (1000),
#     subpartition p0sp1 values less than (2000)
#   ),
#   partition p1 values less than (200)
#   (
#     subpartition p1sp0 values less than (1000),
#     subpartition p1sp1 values less than (2000)
#   )
# );
create table t_range_range (c1 int, c2 int, c3 int) partition by range (c1)subpartition by range (c2)(  partition p0 values less than (100)  (    subpartition p0sp0 values less than (1000),    subpartition p0sp1 values less than (2000)  ),  partition p1 values less than (200)  (    subpartition p1sp0 values less than (1000),    subpartition p1sp1 values less than (2000)  ));
ob1.oblog.next;
alter table t_range_range modify partition p1 add subpartition(  subpartition p1sp2 values less than (3000));
ob1.oblog.next;
insert into t_range_range values (150, 2500, 0);
ob1.oblog.next;


##### range + range_columns
# create table t_range_range_columns (c1 int, c2 int, c3 int) partition by range (c1)
# subpartition by range columns (c2)
# (
#   partition p0 values less than (100)
#   (
#     subpartition p0sp0 values less than (1000),
#     subpartition p0sp1 values less than (2000)
#   ),
#   partition p1 values less than (200)
#   (
#     subpartition p1sp0 values less than (1000),
#     subpartition p1sp1 values less than (2000)
#   )
# );
create table t_range_range_columns (c1 int, c2 int, c3 int) partition by range (c1)subpartition by range columns (c2)(  partition p0 values less than (100)  (    subpartition p0sp0 values less than (1000),    subpartition p0sp1 values less than (2000)  ),  partition p1 values less than (200)  (    subpartition p1sp0 values less than (1000),    subpartition p1sp1 values less than (2000)  ));
ob1.oblog.next;
alter table t_range_range_columns modify partition p1 add subpartition(  subpartition p1sp2 values less than (3000));
ob1.oblog.next;
insert into t_range_range_columns values (150, 2500, 1);
ob1.oblog.next;


##### range + list
# create table t_range_list (c1 int, c2 int, c3 int) partition by range (c1)
# subpartition by list (c2)
# (
#   partition p0 values less than (100)
#   (
#     subpartition p0sp0 values in (1, 2, 3),
#     subpartition p0sp1 values in (4, 5, 6)
#   ),
#   partition p1 values less than (200)
#   (
#     subpartition p1sp0 values in (1, 2, 3),
#     subpartition p1sp1 values in (4, 5, 6)
#   )
# );
create table t_range_list (c1 int, c2 int, c3 int) partition by range (c1)subpartition by list (c2)(  partition p0 values less than (100)  (    subpartition p0sp0 values in (1, 2, 3),    subpartition p0sp1 values in (4, 5, 6)  ),  partition p1 values less than (200)  (    subpartition p1sp0 values in (1, 2, 3),    subpartition p1sp1 values in (4, 5, 6)  ));
ob1.oblog.next;
alter table t_range_list modify partition p1 add subpartition(  subpartition p1sp2 values in (7, 8, 9));
ob1.oblog.next;
insert into t_range_list values (150, 7, 0);
ob1.oblog.next;


