# owner:嘉格
# owner group:liboblog
# description:
# 测试点：测试liboblog刷mv schema不core, 顺便简单验证mv数据同步
##

ob1=OBI(cluster=1:1:1,init_unit_cpu=5);
ob1.reboot;
ob1.create_client;

source include/liboblog/create_tenant_multiple_zone.inc;

--disable_warnings
drop database if exists oblog_db;
create database oblog_db;
use oblog_db;

# 启动liboblog
ob1.oblog.gen_conf tb_white_list=oblog_tt.oblog_db.* skip_ob_version_compat_check=1;
ob1.oblog.restart;

# 创建表
--disable_warnings
drop table if exists info;
create table info (
  l_user_id bigint not null,
  l_item_type bigint not null,
  l_item_id bigint not null,
  l_collect_time bigint not null,
  l_info_from varchar(20) default null,
  l_info_note varchar(20) default null,
  primary key (l_user_id, l_item_type, l_item_id)
) partition by key (l_user_id) partitions 2;

drop table if exists item;
create table item (
  r_item_id bigint not null,
  r_item_type bigint not null,
  r_item_title varchar(20) not null,
  r_item_price bigint not null,
  primary key (r_item_id, r_item_type)
);

drop view if exists mv_info_item;
create view mv_info_item as
  select info.l_item_id, info.l_info_from, info.l_info_note, item.r_item_title, item.r_item_price, info.l_user_id, info.l_item_type, info.l_collect_time, item.r_item_id, item.r_item_type
  from info, item where info.l_item_type = item.r_item_type and info.l_item_id = item.r_item_id
  order by info.l_user_id, info.l_item_type, info.l_collect_time;

# 插入数据，保证收到
replace into info(l_user_id, l_item_type, l_item_id, l_collect_time) values (1, 1, 1, 312312), (1,1,2, 4341231);
ob1.oblog.next_dml;
`
replace into item(r_item_type, r_item_id, r_item_title, r_item_price) values (1, 1, "a", 4), (1,2, "b", 3), (1,3, "c", 6);
ob1.oblog.next_dml;
