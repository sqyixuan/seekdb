#
# owner:千溪
# owner group:liboblog
# description:
# 测试点:
#   test add pos column
##

ob1=OBI(cluster=1, init_unit_cpu=5);
ob1.reboot;
ob1.create_client;

source include/liboblog/create_tenant.inc;

# 准备环境
--disable_warnings
drop database if exists oblog_db1;

# 启动liboblog
ob1.oblog.gen_conf tb_white_list=oblog_tt.oblog*.* skip_ob_version_compat_check=1 enable_output_by_table_def=1 enable_output_hidden_primary_key=1;
ob1.oblog.restart;

# 创建database 1
create database oblog_db1;
ob1.oblog.next;
use oblog_db1;

##############
# 1.add column before/after/first
##############
create table t1(c1 int, c2 int, c3 int, index(c1));
ob1.oblog.next;
insert into t1 values(11, 21, 31);
ob1.oblog.next;
show columns from t1;
select * from t1;

# add first
alter table t1 add column c4 varchar(20) default 'hello_ant' first;
ob1.oblog.next;
insert into t1 values("c4_oblog1", 12, 22, 32);
ob1.oblog.next;
show columns from t1;
select * from t1;

# add before
alter table t1 add column c5 timestamp default '20180314' before c2;
ob1.oblog.next;
insert into t1 values("c4_oblog2", 13, '20180430', 23, 33);
ob1.oblog.next;
show columns from t1;
select * from t1;

# add after
alter table t1 add column c6 datetime(6) default '20180224' after c2;
ob1.oblog.next;
insert into t1 values("c4_oblog3", 14, '20180430', 24, '20180430', 34);
ob1.oblog.next;
show columns from t1;
select * from t1;

# add first+before+after
alter table t1 add column c7 int after c2, add column c8 smallint first, add column c9 int before c5;
ob1.oblog.next;
insert into t1 values(81, "c4_oblog4", 15, 91, '20180430', 25, 71,  '20180430', 35);
ob1.oblog.next;
show columns from t1;
select * from t1;

# add first+before+after, 前后依赖
--error ER_BAD_FIELD_ERROR
alter table t1 add column c11 int after c12, add column c12 smallint after c5;
# 添加前列序列
# c8 c4 c1 c9 c5 c2 c7 c6 c3
#
# 添加后列序列
# c8 c4 c1 c9 c5 [c11, c13, c12] c2 c7 c6 c3
alter table t1 add column c11 int after c5, add column c12 smallint after c11, add column c13 int after c11;
ob1.oblog.next;
insert into t1 values(82, "c4_oblog5", 16, 92, '20180430', 111, 131, 121, 26, 72,  '20180430', 36);
ob1.oblog.next;
show columns from t1;
select * from t1;

##############
# 2.add column/ drop column mixture
##############
# 添加前列序列
# c8 c4 c1 c9 c5 c11  c13, c12 c2 c7 c6 c3
#
# 添加后列序列
# c8 c4 c1    c5           c12 c2 c7 c6 c3 c15 c16 c14
alter table t1 drop column c13, add column c14 int, drop column c11, add column c15 varchar(30) before c14, drop column c9, add column c16 int after c15;
ob1.oblog.next;
insert into t1 values(82, "c4_oblog6", 16, '20180430', 121, 26, 72,  '20180430', 36, "15_1", 161, 141);
ob1.oblog.next;
show columns from t1;
select * from t1;

##############
# 3. generated column
##############
create table gen_t1(c1 varchar(10) primary key, c2 varchar(8) generated always as (substring(c1, 2)) virtual, c3 int) partition by key(c2) partitions 5;
ob1.oblog.next;
# c1 c2 c3
insert into gen_t1(c1, c3) values('liboblog1', 1);
ob1.oblog.next;

alter table gen_t1 add column c4 varchar(64) generated always as (substring(c1, 2)) virtual;
ob1.oblog.next;
# c1 c2 c3 c4
insert into gen_t1(c1, c3) values('liboblog2', 1);
ob1.oblog.next;

alter table gen_t1 add column c5 varchar(64) generated always as (repeat('a', 6)) stored before c1;
ob1.oblog.next;
insert into gen_t1(c1, c3) values('liboblog3', 1);
ob1.oblog.next;
alter table gen_t1 add column c6 varchar(64) generated always as (repeat('a', 6)) virtual before c2;
ob1.oblog.next;
insert into gen_t1(c1, c3) values('liboblog4', 1);
ob1.oblog.next;
alter table gen_t1 add column c7 varchar(64) generated always as (repeat('a', 6)) stored before c4;
ob1.oblog.next;
insert into gen_t1(c1, c3) values('liboblog5', 1);
ob1.oblog.next;
alter table gen_t1 add column c8 varchar(64) generated always as (repeat('a', 6)) virtual after c4;
ob1.oblog.next;
insert into gen_t1(c1, c3) values('liboblog6', 1);
ob1.oblog.next;
alter table gen_t1 add column c9 varchar(64) generated always as (repeat('a', 6)) stored after c5;
ob1.oblog.next;
insert into gen_t1(c1, c3) values('liboblog7', 1);
ob1.oblog.next;
alter table gen_t1 add column c10 varchar(64) generated always as (repeat('a', 6)) virtual after c3;
ob1.oblog.next;
insert into gen_t1(c1, c3) values('liboblog8', 1);
ob1.oblog.next;

# stop liboblog
ob1.oblog.stop;

# 清理数据
--disable_warnings
use oblog_db1;
drop table if exists t1, gen_t1;
--disable_warnings
drop database if exists oblog_db1;
