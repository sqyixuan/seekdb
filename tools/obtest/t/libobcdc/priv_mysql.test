#
# owner: TODO
# owner group: liboblog
# description:
# 测试点:
#  TODO
##

ob1=OBI(cluster=1,init_unit_cpu=5);
ob1.reboot;
ob1.create_client;

# 创建mysql租户oblog_tt，并且切换到mysql租户下
source include/liboblog/create_tenant_with_gts.inc;

# 启动liboblog，同步oblog_tt租户数据
ob1.oblog.gen_conf tb_white_list=oblog_tt.*.* log_level=DEBUG skip_ob_version_compat_check=1;
ob1.oblog.restart;

# 创建database 1
create database oblog_db1;
# 输出create database DDL
ob1.oblog.next;

use oblog_db1;

# 创建表
create table t1(id int, c1 timestamp(6), c2 datetime);
# 输出create table DDL
ob1.oblog.next;


create user u1 identified by '123';
ob1.oblog.next;

create role r1;
ob1.oblog.next;

create role r2;
ob1.oblog.next;

grant r1,r2 to u1;
ob1.oblog.next;

revoke r1 from u1;
ob1.oblog.next;

grant select(id) on oblog_db1.t1 to u1;
ob1.oblog.next;

grant insert(c1) on oblog_db1.t1 to u1;
ob1.oblog.next;

revoke select on oblog_db1.t1 from u1;
ob1.oblog.next;

# 执行drop table DDL
drop table t1;
# 输出drop table DDL
ob1.oblog.next;

drop role r1;
ob1.oblog.next;

drop role r2;
ob1.oblog.next;
drop user u1;
ob1.oblog.next;


# stop liboblog
ob1.oblog.stop;
