#
# owner:伯厚
# owner group:liboblog
# description:
# 测试点：测试事务内语句排序输出的正确性
# TODO 4.0下需要修改表的分区分布
##

#ob1=OBI(cluster=1, init_unit_cpu=5);
ob1=OBI(cluster=1:1:1, init_unit_cpu=5);
ob1.reboot;
ob1.create_client;


source include/liboblog/create_tenant_multiple_zone.inc;
#source include/liboblog/create_tenant.inc;

set autocommit=0;

# 清理环境
--disable_warnings
drop database if exists oblog_db;

create database oblog_db;
use oblog_db;

create table t1_1 (pk int primary key, c1 int);
create table t2_1 (pk int primary key, c1 int);
create table t3_1 (pk int primary key, c1 int);

create table t1_2 (pk int primary key, c1 int) partition by list(pk) (partition p0 values in (1,2,3), partition p2 values in (default));
create table t2_2 (pk int primary key, c1 int) partition by list(pk) (partition p0 values in (1,2,3), partition p2 values in (default));
create table t3_2 (pk int primary key, c1 int) partition by list(pk) (partition p0 values in (1,2,3), partition p2 values in (default));

create table t1_3 (pk int primary key, c1 int);
create table t2_3 (pk int primary key, c1 int);
create table t3_3 (pk int primary key, c1 int);

create table t1_4 (pk int primary key, c1 int) partition by list(pk) (partition p0 values in (1,2,3), partition p2 values in (default));
create table t2_4 (pk int primary key, c1 int) partition by list(pk) (partition p0 values in (1,2,3), partition p2 values in (default));
create table t3_4 (pk int primary key, c1 int) partition by list(pk) (partition p0 values in (1,2,3), partition p2 values in (default));

create table t1_5 (pk int primary key, c1 int) partition by hash (pk) partitions 10;
create table t2_5 (pk int primary key, c1 int) partition by hash (pk) partitions 10;

# 启动liboblog
# 设置排序事务内参与者列表配置项为true，保证集群重启情况下，多分区事务语句顺序一致
ob1.oblog.gen_conf tb_white_list=oblog_tt.oblog_db.* log_level=DEBUG sort_trans_participants=1 enable_output_trans_order_by_sql_operation=1 test_mode_on=1 skip_ob_version_compat_check=1;
#ob1.oblog.gen_conf tb_white_list=oblog_tt.oblog_db.* log_level=DEBUG sort_trans_participants=1 skip_ob_version_compat_check=1;
ob1.oblog.restart;

# 单机多表，表单分区
begin;
insert into t3_1 values (1,1);
insert into t2_1 values (1,1);
insert into t1_1 values (1,1);
insert into t2_1 values (2,2);
insert into t1_1 values (2,2);
insert into t3_1 values (2,2);
commit;
ob1.oblog.next;

# 单机单表，表单分区
begin;
insert into t1_2 values (2, 2);
insert into t1_2 values (3, 3);
insert into t1_2 values (1, 1);
delete from t1_2 where c1 = 2;
insert into t1_2 values (4, 2);
update t1_2 set c1 = 6 where pk = 4;
commit;
ob1.oblog.next;

truncate table t1_2;
ob1.oblog.next;

# 单机多表，表多分区
begin;
insert into t2_2 values (4, 4);
insert into t3_2 values (4, 4);
insert into t3_2 values (1, 1);
insert into t1_2 values (3, 3);
insert into t2_2 values (2, 2);
commit;
ob1.oblog.next;

# 集群多表，表单分区
begin;
insert into t3_3 values (1,1);
insert into t2_3 values (1,1);
insert into t1_3 values (1,1);
insert into t2_3 values (2,2);
insert into t1_3 values (2,2);
insert into t3_3 values (2,2);
commit;
ob1.oblog.next;

# 集群多表，表多分区
begin;
insert into t2_4 values (4, 4);
insert into t3_4 values (4, 4);
insert into t3_4 values (1, 1);
insert into t1_4 values (3, 3);
insert into t2_4 values (2, 2);
commit;
ob1.oblog.next;

# 集群多表多分区，先一个表执行，后另一个表
begin;
insert into t1_5 values (1, 1);
insert into t1_5 values (2, 1);
insert into t1_5 values (3, 1);
insert into t1_5 values (4, 1);
insert into t1_5 values (5, 1);
insert into t1_5 values (6, 1);
insert into t1_5 values (7, 1);
insert into t1_5 values (8, 1);
insert into t1_5 values (9, 1);
insert into t1_5 values (10, 1);
update t1_5 set c1 = 9 where pk = 9;
update t1_5 set c1 = 8 where pk = 8;
update t1_5 set c1 = 7 where pk = 7;
update t1_5 set c1 = 6 where pk = 6;
update t1_5 set c1 = 5 where pk = 5;
update t1_5 set c1 = 4 where pk = 4;
update t1_5 set c1 = 3 where pk = 3;
update t1_5 set c1 = 2 where pk = 2;
delete from t1_5 where pk = 10;
insert into t2_5 values (1, 1);
insert into t2_5 values (3, 3);
insert into t2_5 values (6, 6);
insert into t2_5 values (9, 9);
commit;
ob1.oblog.next;

--disable_warnings
drop database if exists oblog_db;

ob1.oblog.stop;
