#
# owner: fankun.fan
# owner group: libobcdc
# description: alter table exchange partition
##

ob1=OBI(cluster=1,init_unit_cpu=5);
ob1.reboot;
ob1.create_client;

# 创建mysql租户oblog_tt，并且切换到mysql租户下
source include/liboblog/create_tenant_with_gts.inc;

# 启动liboblog，同步oblog_tt租户数据
ob1.oblog.gen_conf tb_white_list=oblog_tt.*.* log_level=DEBUG skip_ob_version_compat_check=1;
ob1.oblog.set_extra_argument -m;
ob1.oblog.restart;

let $restart_ts_usec = query_get_value(select time_to_usec(now(6)) as now, now, 1);

let $ddl_stmt_count = 0;
let $dml_stmt_count = 0;

create database oblog_db1;
ob1.oblog.next;
inc $ddl_stmt_count;

use oblog_db1;

set @blob:=repeat('f', 63210);

create table pt (c1 int not null primary key, c2 int, c3 blob) partition by range(c1)(partition M1  VALUES LESS THAN (5), partition M2 VALUES LESS THAN (10), partition M3 VALUES LESS THAN (1000));
ob1.oblog.next;
inc $ddl_stmt_count;

insert into pt values(1, 1, NULL);
ob1.oblog.next;
inc $dml_stmt_count;

insert into pt values(6, 6, 'f');
ob1.oblog.next;
inc $dml_stmt_count;

insert into pt values(500, 500, @blob);
ob1.oblog.next;
inc $dml_stmt_count;

create table nt (c1 int not null primary key, c2 int, c3 blob);
ob1.oblog.next;
inc $ddl_stmt_count;

insert into nt values(2, 2, @blob);
ob1.oblog.next;
inc $dml_stmt_count;

alter table pt exchange partition M1 with table nt WITHOUT VALIDATION;
ob1.oblog.next;
inc $ddl_stmt_count;

insert into pt values(3, 3, 'a');
ob1.oblog.next;
inc $dml_stmt_count;

insert into pt values(501, 501, @blob);
ob1.oblog.next;
inc $dml_stmt_count;

insert into nt values(4, 4, 'c');
ob1.oblog.next;
inc $dml_stmt_count;

ob1.oblog.gen_conf tb_white_list=oblog_tt.*.* log_level=DEBUG skip_ob_version_compat_check=1;
ob1.oblog.set_extra_argument -m;
ob1.oblog.set_start_tstamp_usec $restart_ts_usec;
ob1.oblog.restart;

let $stmt_count = $ddl_stmt_count + $dml_stmt_count;
let $idx = 0;
while ($idx < $stmt_count)
{
    ob1.oblog.next;
    inc $idx;
}

ob1.oblog.stop;

ob1.oblog.gen_conf tb_white_list=oblog_tt.*.* log_level=DEBUG meta_data_refresh_mode=data_dict skip_ob_version_compat_check=1;
ob1.oblog.set_extra_argument -m;
ob1.oblog.set_start_tstamp_usec $restart_ts_usec;
ob1.oblog.restart;

let $stmt_count = $ddl_stmt_count + $dml_stmt_count;
let $idx = 0;
while ($idx < $stmt_count)
{112
    ob1.oblog.next;
    inc $idx;
}

ob1.oblog.stop;

ob1.oblog.gen_conf tb_white_list=oblog_tt.*.* log_level=DEBUG meta_data_refresh_mode=data_dict skip_ob_version_compat_check=1;
ob1.oblog.set_extra_argument -m;
ob1.oblog.restart;
ob1.oblog.stop;
