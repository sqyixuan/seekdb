# owner:千溪
# owner group:liboblog
# description:
# 测试点:
#   测试liboblog动态添加或者删除分区
#   1. 一级list分区: ADD PARTITION/DROP PARTITION 功能
#   2. 二级分区一级list分区: ADD PARTITION/DROP PARTITION 功能
#
##

ob1=OBI(cluster=1);
ob1.reboot;
ob1.create_client;

# 准备环境
let $ip=deploy_get_value(ob1.proxy0.ip);
let $port=deploy_get_value(ob1.proxy0.port);
connect (oblog_conn_sys,$ip,admin@sys,admin,oceanbase,$port);

connection oblog_conn_sys;

--disable_warnings
drop tenant if exists oblog_tt;
--disable_warnings
drop resource pool if exists oblog_pool;
--disable_warnings
drop resource unit if exists oblog_box;
--disable_warnings
drop database if exists oblog_db;

# 启动liboblog
ob1.oblog.gen_conf tb_white_list=sys.oblog*.*|oblog_tt.*.* skip_ob_version_compat_check=1;
ob1.oblog.restart;

# sys租户下操作
connection oblog_conn_sys;

# create tenant, 创建oblog_tt租户
create resource unit oblog_box max_cpu=2, memory_size='20G';
create resource pool oblog_pool unit = 'oblog_box', unit_num = 1, zone_list = ('z1');
# TODO test
#create tenant oblog_tt replica_num = 1, primary_zone='z1', resource_pool_list=('oblog_pool') set ob_tcp_invited_nodes='%';
create tenant oblog_tt replica_num = 1, primary_zone='z1', resource_pool_list=('oblog_pool') set ob_tcp_invited_nodes='%';
ob1.oblog.next;

# 在oblog_tt租户下操作
connect (oblog_conn_tt,$ip,root@oblog_tt,,oceanbase,$port);
connection oblog_conn_tt;

# 创建database
create database oblog_db;
ob1.oblog.next;

use oblog_db;

################### 一级list分区 ###################
create table t1 (c1 int, c2 varchar(10), c3 int, primary key(c1,c2)) partition by list columns(c1, c2)(partition p0 values in ((1,"1"), (2,"2"), (3,"3")), partition p1 values in ((4,"4"), (5, "5")));
ob1.oblog.next;
insert into t1 values (1, '1', 1);
ob1.oblog.next;
insert into t1 values (2, '2', 2);
ob1.oblog.next;

# 为t1表动态增加3个list分区
alter table t1 add partition (partition p2 values in((6,'6'), (7,'7')), partition p3 values in((8, "8"), (9,"9")));
ob1.oblog.next;
insert into t1 values (6, '6', 6);
ob1.oblog.next;
insert into t1 values (8, '8', 8);
ob1.oblog.next;

alter table t1 add partition (partition p4 values in (default));
ob1.oblog.next;
insert into t1 values (41, '1', 2);
ob1.oblog.next;


# t1表动态删除list分区
alter table t1 drop partition (p4);
ob1.oblog.next;

alter table t1 drop partition (p0, p3);
ob1.oblog.next;

alter table t1 drop partition (p1);
ob1.oblog.next;


################### 二级分区一级list分区 ###################
create table t2(c1 int, c2 int, primary key(c1,c2)) partition by list (c1) subpartition by hash(c2) subpartitions 3 (partition p0 values in (1,2,3,4,5), partition p1 values in(6,7,8,9,0));
ob1.oblog.next;
insert into t2 values (1, 1);
ob1.oblog.next;
insert into t2 values (2, 2);
ob1.oblog.next;

# 为t2表动态增加4个range分区
alter table t2 add partition (partition p2 values in (11,22,33,44,55), partition p3 values in (66,77,88), partition p4 values in(99));
ob1.oblog.next;
insert into t2 values (22, 1);
ob1.oblog.next;
insert into t2 values (66, 2);
ob1.oblog.next;
insert into t2 values (88, 1);
ob1.oblog.next;

alter table t2 add partition (partition p5 values in (default));
ob1.oblog.next;
insert into t2 values (51, 2);
ob1.oblog.next;

# t2表动态删除range分区
alter table t2 drop partition (p5);
ob1.oblog.next;

alter table t2 drop partition (p4, p0, p1, p2);
ob1.oblog.next;

# 删除oblog_tt租户
connection oblog_conn_sys;
set @@recyclebin = off;
drop tenant oblog_tt force;
ob1.oblog.next;

# stop liboblog
ob1.oblog.stop;

# 清理数据
--disable_warnings
drop resource pool if exists oblog_pool;
--disable_warnings
drop resource unit if exists oblog_box;
--disable_warnings
drop database if exists oblog_db;
