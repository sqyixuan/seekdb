#
# owner:wenyue
# owner group:liboblog
# description:
# test for decimal meta info sync, i.e. precision and scale.
#
##


ob1=OBI(cluster=1, init_unit_cpu=5);
ob1.reboot;
ob1.create_client;

# 准备环境
source include/liboblog/create_tenant.inc;
#alter system set syslog_level='debug';

--disable_warnings
drop database if exists oblog_db1;

let $start_tstamp = query_get_value(select round(time_to_usec(now()) / 1000000) as now, now, 1);

# 启动liboblog
ob1.oblog.set_start_tstamp $start_tstamp;
ob1.oblog.gen_conf tb_white_list=oblog_tt.oblog*.* log_level=DEBUG skip_ob_version_compat_check=1;
ob1.oblog.set_extra_argument -i;
ob1.oblog.restart;

# sys租户下操作
set sql_mode ='';

# 创建database
create database oblog_db1;
ob1.oblog.next;
use oblog_db1;

create table t1(c1 int primary key, c2 decimal(5,5));
ob1.oblog.next;
insert into t1 values (1, .55555);
ob1.oblog.next;
insert into t1 values (2, -.55555);
ob1.oblog.next;
insert into t1 values (3, 0);
ob1.oblog.next;
insert into t1 values (4, null);
ob1.oblog.next;
insert into t1 values (5, 0.1);
ob1.oblog.next;

select c1, c2, c2-1 from t1;

create table t2(c1 int primary key, c2 decimal(33,11));
ob1.oblog.next;
insert into t2 values (1, 11111.11111);
ob1.oblog.next;
insert into t2 values (2, null);
ob1.oblog.next;
insert into t2 values (4, 1111.12345678901);
ob1.oblog.next;
update t2 set c2=009.999 where c1=4;
ob1.oblog.next;
delete from t2 where c1=4;
ob1.oblog.next;

select c1, c2 from t2;

create table t3(c1 int primary key, c2 decimal(33) default 12345);
ob1.oblog.next;
insert into t3 values (1, 11111);
ob1.oblog.next;
insert into t3 values (2, 123456789012345678901234567890);
ob1.oblog.next;
insert into t3 values (3, null);
ob1.oblog.next;
insert into t3(c1) values (4);
ob1.oblog.next;

select c1, c2 from t3;

create table t3_1(c1 int primary key, c2 decimal);
ob1.oblog.next;
insert into t3_1 values (1, 11111);
ob1.oblog.next;
insert into t3_1 values (2, 1234567890);
ob1.oblog.next;
insert into t3_1 values (3, null);

ob1.oblog.next;

select c1, c2 from t3_1;

create table t4(c1 decimal(65,30) primary key);
ob1.oblog.next;
insert into t4 values (1.1);
ob1.oblog.next;
insert into t4 values (0);
ob1.oblog.next;
insert into t4 values (12345678901234567890123456789012345.123456789012345678901234567890);
ob1.oblog.next;

select c1 from t4;

create table t5(c1 decimal(1,0) primary key);
ob1.oblog.next;
insert into t5 values (1);
ob1.oblog.next;
insert into t5 values (0);
ob1.oblog.next;
insert into t5 values (-1);
ob1.oblog.next;

select c1 from t5;

create table t6(c1 decimal(1,1) primary key);
ob1.oblog.next;
insert into t6 values (0.1);
ob1.oblog.next;
insert into t6 values (0);
ob1.oblog.next;
insert into t6 values (-0.1);
ob1.oblog.next;

select c1 from t6;

# stop liboblog
ob1.oblog.stop;
