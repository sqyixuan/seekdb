#
# owner:千溪
# owner group:liboblog
# description: 测试分裂相关
#
# TODO 后续继续补充
#
# case: 只分裂一个分区
# case: 非分区表转分区表
##

ob1=OBI(cluster=1, init_unit_cpu=5);
ob1.reboot;
ob1.create_client;

# 准备环境
source include/liboblog/create_tenant.inc;
alter system set _enable_split_partition = true;
sleep 5;

--disable_warnings
drop database if exists oblog_db1;

# 启动liboblog
ob1.oblog.gen_conf tb_white_list=oblog_tt.oblog*.* skip_ob_version_compat_check=1;
ob1.oblog.restart;

# 创建database
create database oblog_db1;
ob1.oblog.next;
use oblog_db1;

# 创建表分区：p0~p5
create table if not exists t1(c1 bigint(11) NOT NULL,c2 bigint(11) NOT NULL,c3 bigint(11) NOT NULL,gmt_create timestamp(6) default now(6), gmt_modified timestamp(6) default now(6), primary key(c1,c2), KEY i2(c2, c1) LOCAL, key i3(c3,c1) LOCAL) partition by range(c1%10)(partition p0 values less than (1), partition p1 values less than (2), partition p2 values less than (3), partition p3 values less than (4), partition p4 values less than (5),  partition p5 values less than (6));
ob1.oblog.next;

# 删除分区 p0, p2, p4
alter table t1 drop partition(p0,p2,p4);
ob1.oblog.next;

# 只分裂一个分区: p1 -> [p0, p1], 表中其他分区不分裂
alter table t1 reorganize partition p1 into(partition p0 values less than(1),partition p1 values less than (2));
ob1.oblog.next;

# 非分区表转分区表
create table t2 (c1 int primary key ,c2 int ,c3 int);
ob1.oblog.next;

alter table t2 partition by range (c1)(partition p0 values less than (10),partition p1 values less than (100),partition p2 values less than (MAXVALUE));
ob1.oblog.next;

insert into t2 values(1, 2, 3);
ob1.oblog.next;

insert into t2 values(11, 2, 3);
ob1.oblog.next;

insert into t2 values(101, 2, 3);
ob1.oblog.next;

# stop liboblog
ob1.oblog.stop;
