#
# owner:gehao.wh
# owner group:shenzhen
# description: vector_type basic test
##

ob1=OBI(cluster=1,init_unit_cpu=5);
ob1.reboot;
ob1.create_client;

# 创建mysql租户oblog_tt，并且切换到mysql租户下
source include/liboblog/create_tenant_with_gts.inc;
alter system set ob_vector_memory_limit_percentage = 30;

create database oblog_db1;

use oblog_db1;

echo "[CASE_BEGIN] [vector_type]";

# max size of vector is 64KB (dim = 16000), max size of vector can create index is 8KB
alter tenant oblog_tt set variables max_allowed_packet=10485760;
set global max_allowed_packet=10485760;

let $record_cnt=0;
let $start_tstamp_usec = query_get_value(select time_to_usec(now(6)) as now, now, 1);

# 启动liboblog，同步oblog_tt租户数据
ob1.oblog.gen_conf tb_white_list=oblog_tt.*.* log_level=DEBUG skip_ob_version_compat_check=1;
ob1.oblog.set_extra_argument -x;
ob1.oblog.restart;

echo "[SECTION_BEGIN] [basic_test]";
create table t1(pk int primary key, c2 vector(3));
ob1.oblog.next;
inc $record_cnt;

# insert null
insert into t1 values(0, NULL);
ob1.oblog.next;
inc $record_cnt;

# insert
insert into t1 values(1, [1, 1, 1]);
ob1.oblog.next;
inc $record_cnt;
insert into t1 values(2, [2.2,2.3,2.4]);
ob1.oblog.next;
inc $record_cnt;
insert into t1 values(3, [3.55,3.66,3.777]);
ob1.oblog.next;
inc $record_cnt;
insert into t1 values(4, [1.1122,2.3322,3]);
ob1.oblog.next;
inc $record_cnt;

# insert with string
insert into t1 values(5, '[1, 1, 1]');
ob1.oblog.next;
inc $record_cnt;
insert into t1 values(6, '[2.2,2.3,2.4]');
ob1.oblog.next;
inc $record_cnt;
insert into t1 values(7, '[3.55,3.66,3.777]');
ob1.oblog.next;
inc $record_cnt;
insert into t1 values(8, '[1.1122,2.3322,3]');
ob1.oblog.next;
inc $record_cnt;

# insert with array
insert into t1 values(9, array(1,1,1));
ob1.oblog.next;
inc $record_cnt;
insert into t1 values(10, array(2.2,2.3,2.4));
ob1.oblog.next;
inc $record_cnt;
insert into t1 values(11, array(3.55,3.66,3.777));
ob1.oblog.next;
inc $record_cnt;
insert into t1 values(12, array(1.1122,2.3322,3));
ob1.oblog.next;
inc $record_cnt;

# update test
update t1 set c2 = '[0.615558,0.613338,0.031494]' where pk=3;
ob1.oblog.next;
inc $record_cnt;

update t1 set c2 = [0.124528,0.652454,0.937912] where pk=7;
ob1.oblog.next;
inc $record_cnt;

update t1 set c2 = array(1, 2, 3) where pk=11;
ob1.oblog.next;
inc $record_cnt;

# update rowkey
update t1 set pk = 30001 where pk = 1;
ob1.oblog.next;
inc $record_cnt;

delete from t1 where pk = 12;
ob1.oblog.next;
inc $record_cnt;

drop table t1;
ob1.oblog.next;
inc $record_cnt;

echo "[SECTION_END] [basic_test]";

# test with index
echo "[SECTION_BEGIN] [test_with_index]";
create table t2(pk int primary key, c2 vector(3));
ob1.oblog.next;
inc $record_cnt;

create vector index vec_idx on t2(c2) with (distance=l2, type=hnsw, lib=vsag);
ob1.oblog.next;
inc $record_cnt;

# insert null
insert into t2 values(0, NULL);
ob1.oblog.next;
inc $record_cnt;

# insert
insert into t2 values(1, [1, 1, 1]);
ob1.oblog.next;
inc $record_cnt;
insert into t2 values(2, [2.2,2.3,2.4]);
ob1.oblog.next;
inc $record_cnt;
insert into t2 values(3, [3.55,3.66,3.777]);
ob1.oblog.next;
inc $record_cnt;
insert into t2 values(4, [1.1122,2.3322,3]);
ob1.oblog.next;
inc $record_cnt;

# insert with string
insert into t2 values(5, '[1, 1, 1]');
ob1.oblog.next;
inc $record_cnt;
insert into t2 values(6, '[2.2,2.3,2.4]');
ob1.oblog.next;
inc $record_cnt;
insert into t2 values(7, '[3.55,3.66,3.777]');
ob1.oblog.next;
inc $record_cnt;
insert into t2 values(8, '[1.1122,2.3322,3]');
ob1.oblog.next;
inc $record_cnt;

# insert with array
insert into t2 values(9, array(1,1,1));
ob1.oblog.next;
inc $record_cnt;
insert into t2 values(10, array(2.2,2.3,2.4));
ob1.oblog.next;
inc $record_cnt;
insert into t2 values(11, array(3.55,3.66,3.777));
ob1.oblog.next;
inc $record_cnt;
insert into t2 values(12, array(1.1122,2.3322,3));
ob1.oblog.next;
inc $record_cnt;

# update test
update t2 set c2 = '[0.615558,0.613338,0.031494]' where pk=3;
ob1.oblog.next;
inc $record_cnt;

update t2 set c2 = [0.124528,0.652454,0.937912] where pk=7;
ob1.oblog.next;
inc $record_cnt;

update t2 set c2 = array(1, 2, 3) where pk=11;
ob1.oblog.next;
inc $record_cnt;

# update rowkey
update t2 set pk = 30001 where pk = 3;
ob1.oblog.next;
inc $record_cnt;

delete from t2 where pk = 12;
ob1.oblog.next;
inc $record_cnt;

drop index vec_idx on t2;
ob1.oblog.next;
inc $record_cnt;

drop table t2;
ob1.oblog.next;
inc $record_cnt;

echo "[SECTION_END] [test_with_index]";

# test multi vector column
echo "[SECTION_BEGIN] [test_with_multi_vector_column]";

CREATE TABLE t3 (c1 int primary key, c2 vector(3), c3 vector(3) ,c4 vector(3));
ob1.oblog.next;
inc $record_cnt;

insert into t3(c1,c2,c3,c4) values(1,'[1,1,2]','[2,2,3]','[1,3,2]');
ob1.oblog.next;
inc $record_cnt;

insert into t3(c1,c2,c3,c4) values(2,'[1,0,3]','[1,0,3]','[2,3,2]');
ob1.oblog.next;
inc $record_cnt;

insert into t3(c1,c2,c3,c4) values(3,'[-1,2,2]','[-3,2,3]','[4,3,3]');
ob1.oblog.next;
inc $record_cnt;

insert into t3(c1,c2,c3,c4) values(4,'[-1,-2,-2]','[-4,2,3]',null);
ob1.oblog.next;
inc $record_cnt;

insert into t3(c1,c2,c3,c4) values(5,'[-1,-3,-2]',null,'[2,3,1]');
ob1.oblog.next;
inc $record_cnt;

# update test
update t3 set c2 = '[0.615558,0.613338,0.031494]' where c1=3;
ob1.oblog.next;
inc $record_cnt;

update t3 set c3 = [0.124528,0.652454,0.937912] where c1=3;
ob1.oblog.next;
inc $record_cnt;

# update from null
update t3 set c4 = [1, 1, 1] where c1=4;
ob1.oblog.next;
inc $record_cnt;

# update to null
update t3 set c3 = null where c1=4;
ob1.oblog.next;
inc $record_cnt;

# update rowkey
update t3 set c1 = 30001 where c1 = 1;
ob1.oblog.next;
inc $record_cnt;

delete from t3 where c1 = 30001;
ob1.oblog.next;
inc $record_cnt;

drop table t3;
ob1.oblog.next;
inc $record_cnt;

echo "[SECTION_END] [test_with_multi_vector_column]";

# stop libobcdc
ob1.oblog.stop;

echo "[SECTION_BEGIN] [test_outrow_vector]";

# 启动liboblog，同步oblog_tt租户数据
ob1.oblog.set_start_tstamp_usec $start_tstamp_usec;
ob1.oblog.gen_conf tb_white_list=oblog_tt.*.* log_level=DEBUG meta_data_refresh_mode=data_dict;
ob1.oblog.set_extra_argument -m;
ob1.oblog.restart;

let $idx = 0;
while ($idx < $record_cnt)
{
  ob1.oblog.next;
  inc $idx;
}

# 设置事务超时时间: 100秒
set ob_trx_timeout=100000000;

SET @large_vector1:=CONCAT('[',REPEAT('123.321,', 15999),'123.321]');
SET @large_vector2:=CONCAT('[',REPEAT('987.01,',15999),'987.05]');
SET @large_vector3:=CONCAT('[',REPEAT('0.0001,',15999),'0.0005]');

create table outrow_vec_t1(c1 int primary key, c2 vector(16000));
ob1.oblog.next;

# insert outrow
insert into outrow_vec_t1 values(1, @large_vector1);
ob1.oblog.next;
select md5(@large_vector1);

## outrow->outrow
update outrow_vec_t1 set c2=@large_vector2 where c1=1;
ob1.oblog.next;
select md5(@large_vector2);

## outrow->null
update outrow_vec_t1 set c2=null where c1=1;
ob1.oblog.next;

## null->outrow
update outrow_vec_t1 set c2=@large_vector3 where c1=1;
ob1.oblog.next;
select md5(@large_vector3);

## delete outrow
delete from outrow_vec_t1 where c1=1;
ob1.oblog.next;

drop table outrow_vec_t1;
ob1.oblog.next;

echo "[SECTION_END] [test_outrow_vector]";

echo "[SECTION_BEGIN] [test_outrow_vector_with_index]";

SET @large_index_vector1:=CONCAT('[',REPEAT('123.321,', 1999),'123.321]');
SET @large_index_vector2:=CONCAT('[',REPEAT('987.01,',1999),'987.05]');
SET @large_index_vector3:=CONCAT('[',REPEAT('0.0001,',1999),'0.0005]');

create table outrow_vec_t2(c1 int primary key, c2 vector(2000));
ob1.oblog.next;

create vector index vec_idx2 on outrow_vec_t2(c2) with (distance=l2, type=hnsw, lib=vsag);
ob1.oblog.next;

# insert outrow
insert into outrow_vec_t2 values(1, @large_index_vector1);
ob1.oblog.next;
select md5(@large_index_vector1);

## outrow->outrow
update outrow_vec_t2 set c2=@large_index_vector2 where c1=1;
ob1.oblog.next;
select md5(@large_index_vector2);

## outrow->null
update outrow_vec_t2 set c2=null where c1=1;
ob1.oblog.next;

## null->outrow
update outrow_vec_t2 set c2=@large_index_vector3 where c1=1;
ob1.oblog.next;
select md5(@large_index_vector3);

## delete outrow
delete from outrow_vec_t2 where c1=1;
ob1.oblog.next;

drop table outrow_vec_t2;
ob1.oblog.next;

echo "[SECTION_END] [test_outrow_vector_with_index]";

echo "[CASE_END] [case_name]";
