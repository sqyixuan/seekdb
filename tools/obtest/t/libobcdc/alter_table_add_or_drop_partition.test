#
# owner:еҚғжәӘ
# owner group:liboblog
# description:
# жөӢиҜ•зӮ№:
#   жөӢиҜ•liboblogеҠЁжҖҒж·»еҠ жҲ–иҖ…еҲ йҷӨеҲҶеҢә
#   1. дёҖзә§rangeеҲҶеҢә: ADD PARTITION/DROP PARTITION еҠҹиғҪ
#   2. дәҢзә§еҲҶеҢәдёҖзә§rangeеҲҶеҢә: ADD PARTITION/DROP PARTITION еҠҹиғҪ
#
##

ob1=OBI(cluster=1);
ob1.reboot;
ob1.create_client;

# еҮҶеӨҮзҺҜеўғ
let $ip=deploy_get_value(ob1.proxy0.ip);
let $port=deploy_get_value(ob1.proxy0.port);
connect (oblog_conn_sys,$ip,admin@sys,admin,oceanbase,$port);

connection oblog_conn_sys;

--disable_warnings
drop tenant if exists oblog_tt;
--disable_warnings
drop resource pool if exists oblog_pool;
--disable_warnings
drop resource unit if exists oblog_box;
--disable_warnings
drop database if exists oblog_db;

# еҗҜеҠЁliboblog
ob1.oblog.gen_conf tb_white_list=sys.oblog*.*|oblog_tt.*.* skip_ob_version_compat_check=1;
ob1.oblog.restart;

# sysз§ҹжҲ·дёӢж“ҚдҪң
connection oblog_conn_sys;

# create tenant, еҲӣе»әoblog_ttз§ҹжҲ·
create resource unit oblog_box max_cpu=2, memory_size='20G';
create resource pool oblog_pool unit = 'oblog_box', unit_num = 1, zone_list = ('z1');
# TODO test
#create tenant oblog_tt replica_num = 1, primary_zone='z1', resource_pool_list=('oblog_pool') set ob_tcp_invited_nodes='%';
create tenant oblog_tt replica_num = 1, primary_zone='z1', resource_pool_list=('oblog_pool') set ob_tcp_invited_nodes='%';
ob1.oblog.next;

# еңЁoblog_ttз§ҹжҲ·дёӢж“ҚдҪң
connect (oblog_conn_tt,$ip,root@oblog_tt,,oceanbase,$port);
connection oblog_conn_tt;

# еҲӣе»әdatabase
create database oblog_db;
ob1.oblog.next;

use oblog_db;

################### дёҖзә§rangeеҲҶеҢә ###################
#  ж–°еҲӣе»әиЎЁpkeyе…¶partition_cntй»ҳи®ӨеқҮдёә0пјҢж–°еўһеҲҶеҢәеҸӘйҖ’еўһpartition_idx
#  иҖҒзүҲжң¬pkeyпјҢеҒҮи®ҫpartition_cntдёә6, ж–°еўһеҲҶеҢәдҝқжҢҒparition_cntеҖјдёҚеҸҳпјҢд»Қдёә6
create table t1(c1 int, c2 int, primary key(c1,c2)) partition by range(c1) (partition p0 values less than(10), partition p1 values less than(20));
ob1.oblog.next;
insert into t1 values (1, 1);
ob1.oblog.next;
insert into t1 values (11, 1);
ob1.oblog.next;

# дёәt1иЎЁеҠЁжҖҒеўһеҠ 4дёӘrangeеҲҶеҢә
alter table t1 add partition (partition p2 values less than(30), partition p3 values less than(40));
ob1.oblog.next;
insert into t1 values (21, 1);
ob1.oblog.next;
insert into t1 values (31, 1);
ob1.oblog.next;

alter table t1 add partition (partition p4 values less than(50));
ob1.oblog.next;
insert into t1 values (41, 1);
ob1.oblog.next;

alter table t1 add partition (partition p5 values less than(60));
ob1.oblog.next;
insert into t1 values (51, 1);
ob1.oblog.next;

# t1иЎЁеҠЁжҖҒеҲ йҷӨrangeеҲҶеҢә
alter table t1 drop partition (p4);
ob1.oblog.next;

alter table t1 drop partition (p0, p3);
ob1.oblog.next;

alter table t1 drop partition (p1);
ob1.oblog.next;


################### дәҢзә§еҲҶеҢәдёҖзә§rangeеҲҶеҢә ###################
create table t2(c1 int, c2 int, primary key(c1,c2)) partition by range(c1) subpartition by hash(c2) subpartitions 3 (partition p0 values less than(10), partition p1 values less than(20));
ob1.oblog.next;
insert into t2 values (1, 1);
ob1.oblog.next;
insert into t2 values (11, 1);
ob1.oblog.next;

# дёәt2иЎЁеҠЁжҖҒеўһеҠ 4дёӘrangeеҲҶеҢә
alter table t2 add partition (partition p2 values less than(30), partition p3 values less than(40), partition p4 values less than(50));
ob1.oblog.next;
insert into t2 values (21, 1);
ob1.oblog.next;
insert into t2 values (31, 1);
ob1.oblog.next;
insert into t2 values (41, 1);
ob1.oblog.next;

alter table t2 add partition (partition p5 values less than(60));
ob1.oblog.next;
insert into t2 values (51, 1);
ob1.oblog.next;

# t2иЎЁеҠЁжҖҒеҲ йҷӨrangeеҲҶеҢә
alter table t2 drop partition (p5);
ob1.oblog.next;

alter table t2 drop partition (p4, p0, p1, p2);
ob1.oblog.next;

# еҲ йҷӨoblog_ttз§ҹжҲ·
connection oblog_conn_sys;
set @@recyclebin = off;
drop tenant oblog_tt force;
ob1.oblog.next;

# stop liboblog
ob1.oblog.stop;

# жё…зҗҶж•°жҚ®
--disable_warnings
drop resource pool if exists oblog_pool;
--disable_warnings
drop resource unit if exists oblog_box;
--disable_warnings
drop database if exists oblog_db;
