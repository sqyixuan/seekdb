#
# owner: linlin.xll
# owner group: sql1
# description:
# 测试点:
#  测试PL相关DDL
##

ob1=OBI(cluster=1,init_unit_cpu=5);
ob1.reboot;
ob1.create_client;
source include/liboblog/create_tenant_with_gts.inc;
ob1.oblog.gen_conf tb_white_list=oblog_tt.*.* log_level=DEBUG skip_ob_version_compat_check=1;
ob1.oblog.restart;
create database oblog_db1;
ob1.oblog.next;
use oblog_db1;
CREATE PROCEDURE my_proc() BEGIN END;
ob1.oblog.next;
DROP PROCEDURE my_proc;
ob1.oblog.next;
CREATE PROCEDURE my_proc(x INT, y INT) BEGIN set x=y; END;
ob1.oblog.next;
DROP PROCEDURE my_proc;
ob1.oblog.next;
CREATE FUNCTION my_proc() RETURNS INT BEGIN RETURN 1; END;
ob1.oblog.next;
DROP FUNCTION my_proc;
ob1.oblog.next;
CREATE TABLE t(col INT);
ob1.oblog.next;
CREATE PROCEDURE my_proc() BEGIN INSERT INTO t VALUES(1); END;
ob1.oblog.next;
CALL my_proc();
ob1.oblog.next;
DROP PROCEDURE my_proc;
ob1.oblog.next;
CREATE PROCEDURE my_proc() BEGIN UPDATE t SET col = 2; END;
ob1.oblog.next;
CALL my_proc();
ob1.oblog.next;
DROP PROCEDURE my_proc;
ob1.oblog.next;
CREATE PROCEDURE my_proc() BEGIN INSERT INTO t VALUES(3); UPDATE t SET COL = COL + 1; END;
ob1.oblog.next;
CALL my_proc();
ob1.oblog.next;
ob1.oblog.next;
DROP PROCEDURE my_proc;
ob1.oblog.next;
CREATE PROCEDURE my_proc() BEGIN DROP TABLE t; END;
ob1.oblog.next;
CALL my_proc();
ob1.oblog.next;
DROP PROCEDURE my_proc;
ob1.oblog.next;
CREATE PROCEDURE my_proc() BEGIN CREATE TABLE t(col int); INSERT INTO t VALUES(1); END;
ob1.oblog.next;
CALL my_proc();
ob1.oblog.next;
ob1.oblog.next;
DROP PROCEDURE my_proc;
ob1.oblog.next;
DROP TABLE t;
ob1.oblog.next;
CREATE PROCEDURE my_proc() BEGIN CREATE TABLE t(col INT); CREATE TABLE t1(col INT); END;
ob1.oblog.next;
CALL my_proc();
ob1.oblog.next;
ob1.oblog.next;
DROP PROCEDURE my_proc;
ob1.oblog.next;
# stop liboblog
ob1.oblog.stop;