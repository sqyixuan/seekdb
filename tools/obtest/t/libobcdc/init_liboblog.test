#
# owner: bohou.ws
# owner group: liboblog
# description:
# 测试点:
#  测试启动时刻通过sqlServer获取RS列表失败时，不断重试直到获取成功
##

ob1=OBI(cluster=1,init_unit_cpu=5);
ob1.reboot;
ob1.create_client;

# 创建mysql租户oblog_tt，并且切换到mysql租户下
source include/liboblog/create_tenant_with_gts.inc;

# 启动liboblog，同步oblog_tt租户数据
ob1.oblog.gen_conf tb_white_list=oblog_tt.*.* log_level=DEBUG test_mode_on=1 test_mode_block_sqlserver_count=2 skip_ob_version_compat_check=1;
ob1.oblog.restart;

# 创建database 1
create database oblog_db1;
# 输出create database DDL
ob1.oblog.next;

use oblog_db1;

# 创建表
create table t1(id int, c1 timestamp(6), c2 datetime);
# 输出create table DDL
ob1.oblog.next;

# 执行AC=1的DML事务
insert into t1 values(1, '2019-1-30 12:00:00.123456', '2019-1-30 12:00:00');
# 输出上述事务
ob1.oblog.next;

# 执行drop table DDL
drop table t1;
# 输出drop table DDL
ob1.oblog.next;

# set系统变量不会生成redo日志，不需要迭代数据
set @@time_zone = '+06:00';

# stop liboblog
ob1.oblog.stop;
ob1.oblog.check_log "refresh rs list fail, will retry until success";