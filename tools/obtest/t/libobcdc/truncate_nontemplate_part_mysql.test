#     subpartition hp3sp1 values less than (200),
#     subpartition hp3sp2 values less than (300)
#   )
# );

# create table t_hash_range (c1 int, c2 int, c3 int, c4 int) partition by hash(c1) subpartition by range(c2) (partition hp0(subpartition hp0sp0 values less than (100),subpartition hp0sp1 values less than (200),subpartition hp0sp2 values less than (300)),partition hp1(subpartition hp1sp0 values less than (100),subpartition hp1sp1 values less than (200),subpartition hp1sp2 values less than (300)),partition hp2(subpartition hp2sp0 values less than (100),subpartition hp2sp1 values less than (200),subpartition hp2sp2 values less than (300)),partition hp3(subpartition hp3sp0 values less than (100),subpartition hp3sp1 values less than (200),subpartition hp3sp2 values less than (300)));
