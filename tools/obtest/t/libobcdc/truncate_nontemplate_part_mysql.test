##################### 2. range_hash
# create table t_range_hash (c1 int, c2 int, c3 int, c4 int)
# partition by range(c1)
# subpartition by hash(c2)
# (
#   partition rp0 values less than (100)
#   (
#   subpartition rp0sp0,
#   subpartition rp0sp1,
#   subpartition rp0sp2,
#   subpartition rp0sp3
#   ),
#   partition rp1 values less than (200)
#   (
#   subpartition rp1sp0,
#   subpartition rp1sp1,
#   subpartition rp1sp2,
#   subpartition rp1sp3
#   ),
#   partition rp2 values less than (300)
#   (
#   subpartition rp2sp0,
#   subpartition rp2sp1,
#   subpartition rp2sp2,
#   subpartition rp2sp3
#   )
# );

create table t_range_hash (c1 int, c2 int, c3 int, c4 int) partition by range(c1) subpartition by hash(c2) (partition rp0 values less than (100)(subpartition rp0sp0,subpartition rp0sp1,subpartition rp0sp2,subpartition rp0sp3), partition rp1 values less than (200)(subpartition rp1sp0,subpartition rp1sp1,subpartition rp1sp2,subpartition rp1sp3), partition rp2 values less than (300)(subpartition rp2sp0,subpartition rp2sp1,subpartition rp2sp2,subpartition rp2sp3));
ob1.oblog.next;

# insert row
insert into t_range_hash values(1,2,3,4);
ob1.oblog.next;
insert into t_range_hash values(1,100,3,4);
ob1.oblog.next;
insert into t_range_hash values(1,200,3,4);
ob1.oblog.next;
insert into t_range_hash values(100,2,3,4);
ob1.oblog.next;
insert into t_range_hash values(100,100,3,4);
ob1.oblog.next;
insert into t_range_hash values(100,200,3,4);
ob1.oblog.next;
insert into t_range_hash values(200,2,3,4);
ob1.oblog.next;
insert into t_range_hash values(200,100,3,4);
ob1.oblog.next;
insert into t_range_hash values(200,200,3,4);
ob1.oblog.next;

alter table t_range_hash truncate partition rp0,rp1;
ob1.oblog.next;

insert into t_range_hash values(1,2,3,4);
ob1.oblog.next;
insert into t_range_hash values(1,100,3,4);
ob1.oblog.next;
insert into t_range_hash values(1,200,3,4);
ob1.oblog.next;
insert into t_range_hash values(100,2,3,4);
ob1.oblog.next;
insert into t_range_hash values(100,100,3,4);
ob1.oblog.next;
insert into t_range_hash values(100,200,3,4);
ob1.oblog.next;

# drop 8 part, add 8 part
#ob1.oblog.stat_check_log_cnt "recycle partition is offline";

# stop liboblog
ob1.oblog.stop;
