#
# owner:zhichen
# owner group:shenzhen
# description:
# 测试CDC内部OutRow LOB数据缓存
##

ob1=OBI(cluster=1);
ob1.reboot;
ob1.create_client;

# 准备环境
let $ip=deploy_get_value(ob1.proxy0.ip);
let $port=deploy_get_value(ob1.proxy0.port);
connect (oblog_conn_sys,$ip,admin@sys,admin,oceanbase,$port);

connection oblog_conn_sys;

# create tenant, 创建oblog_tt租户
create resource unit oblog_box_mysql max_cpu 2, memory_size='10G';
create resource pool oblog_pool_mysql unit = 'oblog_box_mysql', unit_num = 1, zone_list = ('z1');
create tenant oblog_tt replica_num = 1, primary_zone='z1', resource_pool_list=('oblog_pool_mysql') set ob_tcp_invited_nodes='%';

connection oblog_conn_sys;
alter tenant oblog_tt set variables max_allowed_packet=1073741824;

sleep 2;
# 在oblog_tt租户下操作
connect (oblog_conn_tt,$ip,root@oblog_tt,,oceanbase,$port);
connection oblog_conn_tt;
set global max_allowed_packet=1073741824;
connection oblog_conn_tt;

# 启动liboblog
ob1.oblog.set_extra_argument -m;
ob1.oblog.gen_conf tb_white_list=oblog*.*.* log_level=DEBUG lob_data_storage_memory_limit=128M;
ob1.oblog.restart;

# 设置事务超时时间: 100秒
set ob_trx_timeout=100000000;
set ob_query_timeout=1000000000;

let $restart_usec = query_get_value(select time_to_usec(now(6)) as now, now, 1);

# 创建database 1
create database oblog_db1;
use oblog_db1;

create table t1(pk int primary key, d1 longtext, d2 longblob);

# 4K
insert into t1 values (1, repeat('1', 4096), repeat('1', 4096));
ob1.oblog.next_dml;
select md5(d1), md5(d2) from t1 where pk = 1;

update t1 set d1 = repeat('x', 4000), d2 = repeat('x', 4000) where pk = 1;
ob1.oblog.next_dml;
select md5(d1), md5(d2) from t1 where pk = 1;

delete from t1 where pk=1;
ob1.oblog.next_dml;

# 64K
insert into t1 values (2, repeat('2', 65536), repeat('2', 65536));
ob1.oblog.next_dml;
select md5(d1), md5(d2) from t1 where pk = 2;

update t1 set d1 = repeat('y', 65536), d2 = repeat('y', 65536) where pk = 2;
ob1.oblog.next_dml;
select md5(d1), md5(d2) from t1 where pk = 2;

delete from t1 where pk=2;
ob1.oblog.next_dml;

# 256K
insert into t1 values (3, repeat('2', 262144), repeat('2', 262144 + 2));
ob1.oblog.next_dml;
select md5(d1), md5(d2) from t1 where pk = 3;

update t1 set d1 = repeat('y', 262144 + 2), d2 = repeat('y', 262144) where pk = 3;
ob1.oblog.next_dml;
select md5(d1), md5(d2) from t1 where pk = 3;

delete from t1 where pk=3;
ob1.oblog.next_dml;

# 1M
insert into t1 values (4, repeat('2', 1048576), repeat('2', 1048576));
ob1.oblog.next_dml;
select md5(d1), md5(d2) from t1 where pk = 4;

update t1 set d1 = repeat('y', 1048576), d2 = repeat('y', 1048576) where pk = 4;
ob1.oblog.next_dml;
select md5(d1), md5(d2) from t1 where pk = 4;

delete from t1 where pk=4;
ob1.oblog.next_dml;

# 16 M * 4
insert into t1 values (5, repeat('2', 16777216), repeat('2', 16777216));
ob1.oblog.next_dml;
select md5(d1), md5(d2) from t1 where pk = 5;

update t1 set d1 = repeat('y', 16777216), d2 = repeat('y', 16777216) where pk = 5;
ob1.oblog.next_dml;
select md5(d1), md5(d2) from t1 where pk = 5;

delete from t1 where pk=5;
ob1.oblog.next_dml;

insert into t1 values (501, repeat('2', 16777216), repeat('2', 16777216));
ob1.oblog.next_dml;
select md5(d1), md5(d2) from t1 where pk = 501;
update t1 set d1 = repeat('y', 16777216), d2 = repeat('y', 16777216) where pk = 501;
ob1.oblog.next_dml;
select md5(d1), md5(d2) from t1 where pk = 501;
delete from t1 where pk=501;
ob1.oblog.next_dml;

insert into t1 values (502, repeat('2', 16777216), repeat('2', 16777216));
ob1.oblog.next_dml;
select md5(d1), md5(d2) from t1 where pk = 502;
update t1 set d1 = repeat('y', 16777216), d2 = repeat('y', 16777216) where pk = 502;
ob1.oblog.next_dml;
select md5(d1), md5(d2) from t1 where pk = 502;
delete from t1 where pk=502;
ob1.oblog.next_dml;

insert into t1 values (503, repeat('2', 16777216), repeat('2', 16777216));
ob1.oblog.next_dml;
select md5(d1), md5(d2) from t1 where pk = 503;
update t1 set d1 = repeat('y', 16777216), d2 = repeat('y', 16777216) where pk = 503;
ob1.oblog.next_dml;
select md5(d1), md5(d2) from t1 where pk = 503;
delete from t1 where pk=503;
ob1.oblog.next_dml;

# 60 M  should write to disk
insert into t1 values (6, repeat('2', 62914560), repeat('2', 62914560));
ob1.oblog.next_dml;
select md5(d1), md5(d2) from t1 where pk = 6;

update t1 set d1 = repeat('y', 62914560), d2 = repeat('y', 62914560) where pk = 6;
ob1.oblog.next_dml;
select md5(d1), md5(d2) from t1 where pk = 6;

delete from t1 where pk=6;
ob1.oblog.next_dml;

sleep 10;
# trigger last clean lob data
insert into t1(pk) values (0);
ob1.oblog.next_dml;
ob1.oblog.stop;

# restart from restart_usec
ob1.oblog.gen_conf tb_white_list=oblog*.*.* log_level=DEBUG enable_lob_data_storage_memory=0;
ob1.oblog.set_start_tstamp_usec $restart_usec;
ob1.oblog.set_extra_argument -m;
ob1.oblog.restart;
ob1.oblog.waitUntilRealtime 2400;
ob1.oblog.next_dml;
ob1.oblog.stop;

ob1.oblog.gen_conf tb_white_list=oblog*.*.* log_level=DEBUG enable_lob_data_storage_memory=0;
ob1.oblog.set_extra_argument -m;
ob1.oblog.restart;
ob1.oblog.stop;
