#
# owner:千溪
# owner group:liboblog
# description:
# 测试点:
#   test foreign key
##

ob1=OBI(cluster=1);
ob1.reboot;
ob1.create_client;

# 准备环境
let $ip=deploy_get_value(ob1.proxy0.ip);
let $port=deploy_get_value(ob1.proxy0.port);
connect (oblog_conn_sys,$ip,admin@sys,admin,oceanbase,$port);

connection oblog_conn_sys;

--disable_warnings
drop database if exists oblog_db1;
--disable_warnings
drop table if exists t6, t5, t4, t3, t2, t1;

source include/liboblog/create_tenant_with_gts.inc;
set foreign_key_checks=on;

# 启动liboblog
ob1.oblog.gen_conf tb_white_list=sys.oblog*.*|oblog_tt.*.* sort_trans_participants=1 skip_ob_version_compat_check=1;
ob1.oblog.restart;

# 创建database 1
create database oblog_db1;
ob1.oblog.next;
use oblog_db1;

create table t1(pk int, a int, b int, primary key (pk), unique key uk_a_b (b, a));
ob1.oblog.next;
create table t2(pk int, a int, b int, primary key (pk), unique key uk_a_b (a, b), foreign key (a, b) references t1 (b, a) on update CASCADE on delete CASCADE);
ob1.oblog.next;
create table t3(pk int, a int, b int, primary key (pk), unique key uk_a_b (b, a), foreign key (a, b) references t2 (a, b) on update CASCADE on delete CASCADE);
ob1.oblog.next;
create table t4(pk int, a int, b int, primary key (pk), unique key uk_a_b (a, b), foreign key (a, b) references t3 (b, a) on update CASCADE on delete CASCADE);
ob1.oblog.next;
insert into t1 values (10, 11, 12), (20, 21, 22), (30, 31, 32), (40, 41, 42), (50, 51, 52), (60, 61, 62), (70, 71, 72), (80, 81, 82);
ob1.oblog.next;
insert into t2 values (10, 12, 11), (20, 22, 21), (30, 32, 31), (40, 42, 41), (50, 52, 51), (60, 62, 61), (70, 72, 71);
ob1.oblog.next;
insert into t3 values (10, 12, 11), (20, 22, 21), (30, 32, 31), (40, 42, 41), (50, 52, 51), (60, 62, 61);
ob1.oblog.next;
insert into t4 values (10, 11, 12), (20, 21, 22), (30, 31, 32), (40, 41, 42), (50, 51, 52), (60, 61, 62);
ob1.oblog.next;

# ERROR: uncertain plan violating external consistency not supported
delete from t1 where pk = 10;
ob1.oblog.next;
update t1 set a = a * 10 where pk = 20;
ob1.oblog.next;
update t2 set a = 82, b = 81 where pk = 30;
ob1.oblog.next;
update t3 set a = 72, b = 71 where pk = 40;
ob1.oblog.next;

select * from t1 order by pk;
select * from t2 order by pk;
select * from t3 order by pk;
select * from t4 order by pk;

create table t5(pk int, a int, b int, primary key (pk), unique key uk_a_b (b, a), foreign key (a, b) references t4 (a, b) on update RESTRICT on delete NO ACTION);
ob1.oblog.next;
create table t6(pk int, a int, b int, primary key (pk), unique key uk_a_b (a, b), foreign key (a, b) references t5 (b, a) on update CASCADE on delete CASCADE);
ob1.oblog.next;
insert into t5 values (50, 51, 52), (60, 61, 62), (70, 71, 72);
ob1.oblog.next;
insert into t6 values (50, 52, 51), (60, 62, 61);
ob1.oblog.next;
update t5 set a = 81, b = 82 where pk = 50;
ob1.oblog.next;
update t6 set a = 72, b = 71 where pk = 60;
ob1.oblog.next;
select * from t5 order by pk;
select * from t6 order by pk;

#--disable_result_log
select * from t1 order by pk;
select * from t2 order by pk;
select * from t3 order by pk;
select * from t4 order by pk;
select * from t5 order by pk;
select * from t6 order by pk;

drop table if exists t6, t5, t4, t3, t2, t1;
let $table_cnt=6;
let $idx = 1;
while ($idx <= $table_cnt)
{
  # drop table DDL
  ob1.oblog.next;
  inc $idx;
}

create table t1(pk int, a varchar(16), b datetime(6), primary key (pk), unique key uk_a_b (b, a));
ob1.oblog.next;
create table t2(pk int, a datetime(6), b varchar(16), primary key (pk), unique key uk_a_b (a, b), foreign key (a, b) references t1 (b, a) on update CASCADE on delete CASCADE);
ob1.oblog.next;
insert into t1 values (10, 'abc', '2018-03-31 12:00:00'),
                      (20, 'DEF', '2018-03-31 13:00:00'),
                      (30, 'ghi', '2018-03-31 14:00:00'),
                      (40, 'JKL', '2018-03-31 15:00:00'),
                      (50, 'mno', '2018-03-31 16:00:00'),
                      (60, 'PQR', '2018-03-31 17:00:00');
ob1.oblog.next;
insert into t2 values (10, '2018-03-31 12:00:00', 'ABC'),
                      (20, '2018-03-31 13:00:00', 'def'),
                      (30, '2018-03-31 14:00:00', 'GHI'),
                      (40, '2018-03-31 15:00:00', 'jkl');
ob1.oblog.next;
delete from t1 where pk = 10;
ob1.oblog.next;
update t1 set a = 'stu' where pk = 20;
ob1.oblog.next;
update t1 set a = 'VWX', b = '2018-03-31 19:00:00' where pk = 30;
ob1.oblog.next;
select * from t1 order by pk;
select * from t2 order by pk;

create table t3(pk int, a datetime(6), b varchar(16), primary key (pk), unique key uk_a_b (a, b), foreign key (a, b) references t1 (b, a) on update RESTRICT on delete NO ACTION);
ob1.oblog.next;
insert into t3 values (40, '2018-03-31 15:00:00', 'jkl');
ob1.oblog.next;
select * from t3 order by pk;

# stop liboblog
ob1.oblog.stop;
# 清理数据
--disable_warnings
use oblog_db1;
drop table if exists t6, t5, t4, t3, t2, t1;
--disable_warnings
drop database if exists oblog_db1;
