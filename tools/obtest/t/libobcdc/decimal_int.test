##########################
#owner :  zuojiao.hzj
#owner group: sql
#description:
# 测试点：
# 1. decimal_int
#

##########################

ob1=OBI(cluster=1,init_unit_cpu=2);
ob1.reboot;
ob1.create_client;

source include/liboblog/create_tenant_with_gts.inc;

# 启动oblog
ob1.oblog.gen_conf tb_white_list=oblog_tt.oblog_db1.* log_level=DEBUG;
ob1.oblog.set_extra_argument -i;
ob1.oblog.restart;

# 创建database 1
create database oblog_db1;
ob1.oblog.next;
use oblog_db1;

create table simple_decimal_int(c0 decimal(10, 2), c1 decimal(18, 2), c2 decimal(38, 30));
ob1.oblog.next;

insert into simple_decimal_int values(1.23, 23.45, 56.70001);
ob1.oblog.next;

insert into simple_decimal_int values(8.90, 10.21, 32321321.321321321321);
ob1.oblog.next;

insert into simple_decimal_int values(0, 0, 0);
ob1.oblog.next;

insert into simple_decimal_int values(null, null, null);
ob1.oblog.next;

insert into simple_decimal_int values(99999999.99, 9999999999999999.99, 99999999.999999999999999999999999999999);
ob1.oblog.next;
select * from simple_decimal_int;

update simple_decimal_int set c0 = 1.2;
ob1.oblog.next;
select * from simple_decimal_int;

update simple_decimal_int set c1 = 99999999.99;
ob1.oblog.next;
select * from simple_decimal_int;

update simple_decimal_int set c2 = 99999999.99999999999999999999999999999;
ob1.oblog.next;
select * from simple_decimal_int;

update simple_decimal_int set c1 = c0 + c1;
ob1.oblog.next;
select * from simple_decimal_int;

update simple_decimal_int set c2 = c2 - c1;
ob1.oblog.next;
select * from simple_decimal_int;

update simple_decimal_int set c2 = c0 * c0;
ob1.oblog.next;
select * from simple_decimal_int;

update simple_decimal_int set c2 = c2 / c0;
ob1.oblog.next;
select * from simple_decimal_int;

drop table simple_decimal_int;
ob1.oblog.next;
sleep 1;

## decimal int作为主键
create table simple_decimal_int_pk(c1 decimal(20, 10) primary key, c2 decimal(65, 30));
ob1.oblog.next;
sleep 1;

let $start_tstamp = query_get_value(select round(time_to_usec(now()) / 1000000) as now, now, 1);

insert into simple_decimal_int_pk values(1.23, 1);
delete from simple_decimal_int_pk;
insert into simple_decimal_int_pk values(99999999.9999999, 99999999.999999999999999999999999999999);
delete from simple_decimal_int_pk;
insert into simple_decimal_int_pk values(99999999.9999999999999, 99999999.999999999999999999999999999999);
delete from simple_decimal_int_pk;

let $DECINT_PK_DML_CNT = 6;
while ($DECINT_PK_DML_CNT > 0)
{
  ob1.oblog.next;
  dec $DECINT_PK_DML_CNT;
}

# stop liboblog
ob1.oblog.stop;

# 回拉历史
ob1.oblog.set_start_tstamp $start_tstamp;
ob1.oblog.gen_conf tb_white_list=oblog_tt.oblog_db1.* log_level=DEBUG;
ob1.oblog.set_extra_argument -i;
ob1.oblog.restart;

let $DECINT_PK_DML_CNT = 6;
while ($DECINT_PK_DML_CNT > 0)
{
  ob1.oblog.next;
  dec $DECINT_PK_DML_CNT;
}

# stop liboblog
ob1.oblog.stop;
