#
# owner: bohou.ws
# owner group: obcdc
# description:
# 测试点:
#  OBCDC对大小写敏感场景的支持
##

ob1=OBI(cluster=1,init_unit_cpu=5);
ob1.reboot;
ob1.create_client;

# create tenant, specified lower_case_table_names = 0: case sensitive(default is 1, case insensitive)

let $ip=deploy_get_value(ob1.z1.obs0.ip);
let $port=deploy_get_value(ob1.z1.obs0.mysql_port);
connect (oblog_conn_sys,$ip,root@sys,,oceanbase,$port);
connection oblog_conn_sys;
# can not create user database in sys tenant, create oblog_tt tenant
create resource unit oblog_box max_cpu 2, memory_size='20G';
create resource pool oblog_pool unit = 'oblog_box', unit_num = 1, zone_list = ('z1');
create tenant oblog_tt replica_num = 1, primary_zone='z1', resource_pool_list=('oblog_pool') set ob_tcp_invited_nodes='%', lower_case_table_names=0;
connect (oblog_conn_tt,$ip,root@oblog_tt,,oceanbase,$port);
connection oblog_conn_tt;

ob1.oblog.gen_conf tb_white_list=oblog_tt.*.* log_level=DEBUG;
ob1.oblog.restart;
create database cdc_db;
ob1.oblog.next;
use cdc_db;
create table cdc_tb(a int primary key, b int, c int);
ob1.oblog.next;
create table CDC_Tb(a int primary key, b int, c int);
ob1.oblog.next;
insert into cdc_tb(a, b, c) values (1, 1, 1), (2, 2, 2);
ob1.oblog.next;
insert into CDC_Tb(a, b, c) values (1, 1, 1), (2, 2, 2);
ob1.oblog.next;
truncate table cdc_tb;
ob1.oblog.next;
select count(*) from CDC_Tb;
create database CDC_DB;
ob1.oblog.next;
use CDC_DB;
create table cdc_tb(a int primary key, b int, c int);
ob1.oblog.next;
insert into cdc_tb(a, b, c) values (1, 1, 1), (2, 2, 2);
ob1.oblog.next;

set autocommit = 'off';
begin;
insert into CDC_DB.cdc_tb(a, b, c) values (3, 3, 3);
insert into cdc_db.CDC_Tb(a, b, c) values (3, 3, 3);
insert into cdc_db.cdc_tb(a, b, c) values (3, 3, 3);
commit;
ob1.oblog.next;
set autocommit = 'on';

use cdc_db;
drop table CDC_Tb;
ob1.oblog.next;
drop table cdc_tb;
ob1.oblog.next;

use CDC_DB;
drop table cdc_tb;
ob1.oblog.next;
ob1.oblog.stop;

