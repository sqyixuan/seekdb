#
# owner:千溪
# owner group:liboblog
# description:
# 测试点:
#  ssl file mode
#
##

ob1=OBI(cluster=1,init_unit_cpu=5);
# server launch SSL
ob1.z1.obs0.set extra_config=ssl_client_authentication=true,rpc_client_authentication_method=SSL_NO_ENCRYPT,rpc_server_authentication_method=SSL_NO_ENCRYPT,_ob_ssl_invited_nodes=\'ALL\',ssl_external_kms_info=\'\';
ob1.reboot;
ob1.create_client;

# 准备环境
let $ip=deploy_get_value(ob1.proxy0.ip);
let $port=deploy_get_value(ob1.proxy0.port);
connect (oblog_conn_sys,$ip,admin@sys,admin,oceanbase,$port);

connection oblog_conn_sys;
# select * from __all_virtual_sys_parameter_stat where name like '%ssl%';

--disable_warnings
drop tenant if exists oblog_tt;
--disable_warnings
drop resource pool if exists oblog_pool;
--disable_warnings
drop resource unit if exists oblog_box;
--disable_warnings
drop database if exists oblog_db1;

source include/liboblog/create_tenant.inc;
sleep 2;
# 在oblog_tt租户下操作
connect (oblog_conn_tt,$ip,root@oblog_tt,,oceanbase,$port);
connection oblog_conn_tt;
let $start_tstamp_usec = query_get_value(select time_to_usec(now(6)) as now, now, 1);

# 启动liboblog
ob1.oblog.gen_conf tb_white_list=sys.oblog*.*|oblog_tt.*.* log_level=DEBUG ssl_client_authentication=1 rpc_client_authentication_method=SSL_NO_ENCRYPT ssl_external_kms_ skip_ob_version_compat_check=1;
ob1.oblog.restart;
sleep 30;
# 创建database 1
create database oblog_db1;
ob1.oblog.next;

use oblog_db1;
CREATE TABLE t (b BIT(8));
ob1.oblog.next;

INSERT INTO t SET b = b'11111111';
ob1.oblog.next;

INSERT INTO t SET b = b'1010';
ob1.oblog.next;

INSERT INTO t SET b = b'1111';
ob1.oblog.next;

CREATE TABLE t2 (b BIT(12));
ob1.oblog.next;

INSERT INTO t2 SET b = b'0';
ob1.oblog.next;

INSERT INTO t2 SET b = b'10';
ob1.oblog.next;

INSERT INTO t2 SET b = b'01';
ob1.oblog.next;

INSERT INTO t2 SET b = b'001';
ob1.oblog.next;

INSERT INTO t2 SET b = b'11111111';
ob1.oblog.next;

INSERT INTO t2 SET b = b'001100000000';
ob1.oblog.next;

INSERT INTO t2 SET b = b'111111111111';
ob1.oblog.next;

# bit最大64位
CREATE TABLE t3 (b BIT(64));
ob1.oblog.next;

INSERT INTO t3 SET b = 0xFFFFFFFFFFFFFFFF;
ob1.oblog.next;

# stop liboblog
ob1.oblog.stop;

ob1.oblog.gen_conf tb_white_list=sys.oblog*.*|oblog_tt.*.* log_level=DEBUG ssl_client_authentication=1 rpc_client_authentication_method=SSL_NO_ENCRYPT ssl_external_kms_;
ob1.oblog.set_start_tstamp_usec $start_tstamp_usec;
ob1.oblog.restart;
ob1.oblog.waitUntilRealtime 400;
