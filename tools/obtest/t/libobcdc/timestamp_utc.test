#
# owner:千溪
# owner group:liboblog
# description:
# 测试点:
#  测试 timestamp
#       datetime
##

ob1=OBI(cluster=1,init_unit_cpu=5);
ob1.reboot;
ob1.create_client;

source include/liboblog/create_tenant_with_gts.inc;

# 启动liboblog
ob1.oblog.gen_conf tb_white_list=sys.oblog*.*|oblog_tt.*.* log_level=DEBUG skip_ob_version_compat_check=1;
ob1.oblog.set_extra_argument -i;
ob1.oblog.restart;

# 创建database 1
create database oblog_db1;
ob1.oblog.next;

use oblog_db1;

# 默认不设置 +8
create table t1(id int, c1 timestamp(6), c2 datetime);
ob1.oblog.next;
insert into t1 values(1, '2019-1-30 12:00:00.123456', '2019-1-30 12:00:00');
ob1.oblog.next;
insert into t1 values(2, '2019-1-30 12:30:00.123456', '2019-1-30 12:30:00');
ob1.oblog.next;
insert into t1 values(3, '2019-1-30 12:55:55.123456', '2019-1-30 12:55:55');
ob1.oblog.next;
insert into t1 values(4, '1900-1-30 12:55:55.123456', '0000-1-30 12:55:55');
ob1.oblog.next;
drop table t1;
ob1.oblog.next;

set @@time_zone = '+06:00';
create table t1(id int, c1 timestamp(6), c2 datetime);
ob1.oblog.next;
insert into t1 values(1, '2019-1-30 12:00:00.123', '2019-1-30 12:00:00');
ob1.oblog.next;
insert into t1 values(2, '2019-1-30 12:30:00.123', '2019-1-30 12:30:00');
ob1.oblog.next;
insert into t1 values(3, '2019-1-30 12:55:55.123', '2019-1-30 12:55:55');
ob1.oblog.next;
drop table t1;
ob1.oblog.next;

set @@time_zone = '+01:00';
create table t1(id int, c1 timestamp, c2 datetime);
ob1.oblog.next;
insert into t1 values(1, '2019-1-30 12:00:00', '2019-1-30 12:00:00');
ob1.oblog.next;
insert into t1 values(2, '2019-1-30 12:30:00', '2019-1-30 12:30:00');
ob1.oblog.next;
insert into t1 values(3, '2019-1-30 12:55:55', '2019-1-30 12:55:55');
ob1.oblog.next;
drop table t1;
ob1.oblog.next;

# stop liboblog
ob1.oblog.stop;

# 启动liboblog
ob1.oblog.gen_conf tb_white_list=sys.oblog*.*|oblog_tt.*.* log_level=DEBUG enable_convert_timestamp_to_unix_timestamp=1 skip_ob_version_compat_check=1;
ob1.oblog.set_extra_argument -i;
ob1.oblog.restart;

use oblog_db1;

# 默认不设置 +8
set @@time_zone = '+08:00';
create table t1(id int, c1 timestamp(6), c2 datetime);
ob1.oblog.next;
insert into t1 values(1, '2019-1-30 12:00:00.123456', '2019-1-30 12:00:00');
select UNIX_TIMESTAMP(c1) from t1 where id=1;
ob1.oblog.next;
insert into t1 values(2, '2019-1-30 12:30:00.123456', '2019-1-30 12:30:00');
select UNIX_TIMESTAMP(c1) from t1 where id=2;
ob1.oblog.next;
insert into t1 values(3, '2019-1-30 12:55:55.123456', '2019-1-30 12:55:55');
select UNIX_TIMESTAMP(c1) from t1 where id=3;
ob1.oblog.next;
# server 会记录GMT标准时区时间
insert into t1 values(4, '1900-1-30 12:55:55.123456', '0000-1-30 12:55:55');
select UNIX_TIMESTAMP(c1) from t1 where id=4;
ob1.oblog.next;
drop table t1;
ob1.oblog.next;

set @@time_zone = '+06:00';
create table t1(id int, c1 timestamp(3), c2 datetime);
ob1.oblog.next;
insert into t1 values(1, '2019-1-30 12:00:00.123', '2019-1-30 12:00:00');
select UNIX_TIMESTAMP(c1) from t1 where id=1;
ob1.oblog.next;
insert into t1 values(2, '2019-1-30 12:30:00.123', '2019-1-30 12:30:00');
select UNIX_TIMESTAMP(c1) from t1 where id=2;
ob1.oblog.next;
insert into t1 values(3, '2019-1-30 12:55:55.123', '2019-1-30 12:55:55');
select UNIX_TIMESTAMP(c1) from t1 where id=3;
ob1.oblog.next;
drop table t1;
ob1.oblog.next;

set @@time_zone = '+01:00';
create table t1(id int, c1 timestamp, c2 datetime);
ob1.oblog.next;
insert into t1 values(1, '2019-1-30 12:00:00', '2019-1-30 12:00:00');
select UNIX_TIMESTAMP(c1) from t1 where id=1;
ob1.oblog.next;
insert into t1 values(2, '2019-1-30 12:30:00', '2019-1-30 12:30:00');
select UNIX_TIMESTAMP(c1) from t1 where id=2;
ob1.oblog.next;
insert into t1 values(3, '2019-1-30 12:55:55', '2019-1-30 12:55:55');
select UNIX_TIMESTAMP(c1) from t1 where id=3;
ob1.oblog.next;
drop table t1;
ob1.oblog.next;

set @@time_zone = '+00:00';
create table t1(id int, c1 timestamp(6), c2 datetime);
ob1.oblog.next;
insert into t1 values(1, '1970-1-1 00:00:00', '1970-1-1 00:00:00');
select UNIX_TIMESTAMP(c1) from t1 where id=1;
ob1.oblog.next;
insert into t1 values(2, '1970-1-1 00:01:00.01', '1970-1-1 00:01:00');
select UNIX_TIMESTAMP(c1) from t1 where id=2;
ob1.oblog.next;
insert into t1 values(3, '1970-1-1 01:00:00.001', '1970-1-1 01:00:00');
select UNIX_TIMESTAMP(c1) from t1 where id=3;
ob1.oblog.next;
insert into t1 values(4, '1970-1-1 02:00:00.00012', '1970-1-1 01:00:00');
select UNIX_TIMESTAMP(c1) from t1 where id=4;
ob1.oblog.next;
insert into t1 values(5, '1970-1-1 02:00:00.000001', '1970-1-1 01:00:00');
select UNIX_TIMESTAMP(c1) from t1 where id=5;
ob1.oblog.next;
insert into t1 values(6, '1970-1-1 02:00:00.0123', '1970-1-1 01:00:00');
select UNIX_TIMESTAMP(c1) from t1 where id=6;
ob1.oblog.next;
insert into t1 values(7, '1970-1-1 02:00:00.123', '1970-1-1 01:00:00');
select UNIX_TIMESTAMP(c1) from t1 where id=7;
ob1.oblog.next;
drop table t1;
ob1.oblog.next;

## 补充测试datetime精度
## 数据需要按照精度转换
create table t2(id int, c1 datetime(3), c2 datetime(4), c3 datetime(5), c4 datetime(6));
ob1.oblog.next;
insert into t2 values(1, '2019-1-30 12:00:00.123456', '2019-1-30 12:00:00.123456', '2019-1-30 12:00:00.123456', '2019-1-30 12:00:00.123456');
ob1.oblog.next;
insert into t2 values(2, '2019-1-30 12:00:00.000000', '2019-1-30 12:00:00.000000', '2019-1-30 12:00:00.000000', '2019-1-30 12:00:00.000000');
ob1.oblog.next;

# test for datatype time
create table t3(id int primary key, c1 time(1), c2 timestamp(2), c3 datetime(3));
ob1.oblog.next;
insert into t3 values (1, '99:59:59.9', '1970-1-1 00:00:00.11', '2019-1-30 12:00:00.123');
ob1.oblog.next;
insert into t3 values (2, '99:59:59.99', '1970-1-1 00:00:00.111', '2019-1-30 12:00:00.123456');
ob1.oblog.next;

# stop liboblog
ob1.oblog.stop;
