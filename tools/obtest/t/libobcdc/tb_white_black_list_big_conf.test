#
# owner: fankun.fan
# owner group: libobcdc
# description: big conf
##

ob1=OBI(cluster=1,init_unit_cpu=5);
ob1.reboot;
ob1.create_client;

# 创建mysql租户oblog_tt，并且切换到mysql租户下
source include/liboblog/create_tenant_with_gts.inc;

# 用超大黑白名单配置启动libobcdc
let $tb_white_list_conf = deploy_get_value(ob1.select select TRIM(TRAILING '|' FROM repeat('oblog_tt.*.white*|', 5000)) as white_list, white_list, 1);
let $tb_black_list_conf = deploy_get_value(ob1.select select TRIM(TRAILING '|' FROM repeat('oblog_tt.*.black*|', 5000)) as black_list, black_list, 1);
ob1.oblog.gen_conf tb_white_list=$tb_white_list_conf tb_black_list=$tb_black_list_conf log_level=DEBUG skip_ob_version_compat_check=1;
ob1.oblog.set_extra_argument '-c';
ob1.oblog.restart;

let $restart_ts_usec = query_get_value(select time_to_usec(now(6)) as now, now, 1);

let $ddl_stmt_count = 0;
let $dml_stmt_count = 0;

create database oblog_db1;
ob1.oblog.next;
inc $ddl_stmt_count;

# ob1.mysql alter system set dump_data_dictionary_to_log_interval = '6s' tenant all;

use oblog_db1;

let $tb_white_count=10;
let $idx = 0;
while ($idx < $tb_white_count)
{
    eval create table white$idx(c1 int, c2 int);
    inc $ddl_stmt_count;
    inc $idx;
}

let $tb_black_count=5;
let $idx = 0;
while ($idx < $tb_black_count)
{
    eval create table black$idx(c1 int, c2 int);
    inc $ddl_stmt_count;
    inc $idx;
}

let $insert_count=100;

# 开启事务
begin;

--disable_query_log

let $idx = 0;
while ($idx < $tb_white_count)
{   
    let $inserted_count = 0;
    while ($inserted_count < $insert_count)
    {
        eval insert into white$idx values($idx, $idx+1);
        inc $inserted_count;
    }
    inc $idx;
}

let $idx = 0;
while ($idx < $tb_black_count)
{   
    let $inserted_count = 0;
    while ($inserted_count < $insert_count)
    {
        eval insert into black$idx values($idx+2, $idx+3);
        inc $inserted_count;
    }
    inc $idx;
}

--enable_query_log

commit;
inc $dml_stmt_count;
ob1.oblog.next_dml;

sleep 10;
ob1.oblog.stop;

# 用超大黑白名单配置重新启动libobcdc
let $tb_white_list_conf = deploy_get_value(ob1.select select TRIM(TRAILING '|' FROM repeat('oblog_tt.*.white*|', 5000)) as white_list, white_list, 1);
let $tb_black_list_conf = deploy_get_value(ob1.select select TRIM(TRAILING '|' FROM repeat('oblog_tt.*.black*|', 5000)) as black_list, black_list, 1);
ob1.oblog.gen_conf tb_white_list=$tb_white_list_conf tb_black_list=$tb_black_list_conf log_level=DEBUG skip_ob_version_compat_check=1;
ob1.oblog.set_start_tstamp_usec $restart_ts_usec;
ob1.oblog.set_extra_argument '-c';
ob1.oblog.restart;

# output
let $idx = 0;
while ($idx < $ddl_stmt_count)
{
    ob1.oblog.next;
    inc $idx;
}

let $idx = 0;
while ($idx < $dml_stmt_count)
{
    ob1.oblog.next_dml;
    inc $idx;
}

# 用超大黑白名单配置重新启动libobcdc
let $tb_white_list_conf = deploy_get_value(ob1.select select TRIM(TRAILING '|' FROM repeat('oblog_tt.*.white*|', 5000)) as white_list, white_list, 1);
let $tb_black_list_conf = deploy_get_value(ob1.select select TRIM(TRAILING '|' FROM repeat('oblog_tt.*.black*|', 5000)) as black_list, black_list, 1);
ob1.oblog.gen_conf tb_white_list=$tb_white_list_conf tb_black_list=$tb_black_list_conf meta_data_refresh_mode=data_dict log_level=DEBUG skip_ob_version_compat_check=1;
ob1.oblog.set_start_tstamp_usec $restart_ts_usec;
ob1.oblog.set_extra_argument '-c';
ob1.oblog.restart;

# output
let $idx = 0;
while ($idx < $ddl_stmt_count)
{
    ob1.oblog.next;
    inc $idx;
}

let $idx = 0;
while ($idx < $dml_stmt_count)
{
    ob1.oblog.next_dml;
    inc $idx;
}

ob1.oblog.gen_conf tb_white_list=oblog_tt.*.white* tb_black_list=oblog_tt.*.black* log_level=DEBUG meta_data_refresh_mode=data_dict skip_ob_version_compat_check=1;
ob1.oblog.set_extra_argument -m;
ob1.oblog.restart;
ob1.oblog.stop;

ob1.oblog.gen_conf tb_white_list=oblog_tt.*.white* tb_black_list=oblog_tt.*.black* log_level=DEBUG skip_ob_version_compat_check=1;
ob1.oblog.set_extra_argument -m;
ob1.oblog.restart;
ob1.oblog.stop;
