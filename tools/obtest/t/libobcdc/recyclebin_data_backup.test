#
# owner:千溪
# owner group:liboblog
# description:
# 测试点: 在增量备份模式下，支持备份回收站中数据

ob1=OBI(cluster=1, init_unit_cpu=5);
ob1.reboot;
ob1.create_client;

# 准备环境
source include/liboblog/create_tenant.inc;

# 在oblog_tt租户下操作
connection oblog_conn_tt;
--disable_warnings
create user if not exists __oceanbase_inner_drc_user;
grant all privileges on *.* to __oceanbase_inner_drc_user;
--enable_warnings

# 开启回收站
set @@recyclebin = on;
show variables like 'recyclebin';
purge recyclebin;

connection oblog_conn_sys;
let $tenant_id = query_get_value(select tenant_id from __all_tenant where tenant_name="oblog_tt", tenant_id, 1);
delete from oceanbase.__all_ddl_id;
connect (conn_drc,$ip,__oceanbase_inner_drc_user@oblog_tt,,,$port);
connection conn_drc;

let $start_tstamp_usec = query_get_value(select time_to_usec(now(6)) as now, now, 1);
let $DML_COUNT=0;

set @__oceanbase_ddl_id = '1_123456710';
create database oblog_db1;
use oblog_db1;
set @__oceanbase_ddl_id = '1_123456711';
create table oblog_db1.t1 (pk int primary key, c1 int);

insert into t1 values(1, 1);
inc $DML_COUNT;

begin;
insert into t1 values(2, 2);
update t1 set c1=10 where pk=1;
commit;
inc $DML_COUNT;

begin;
insert into t1 values(3, 3);
update t1 set c1=11 where pk=1;
commit;
inc $DML_COUNT;

set @@recyclebin = on;
set @__oceanbase_ddl_id = '1_123456712';
drop table oblog_db1.t1;

use oceanbase;
let $drop_table_ddl_schema_version = query_get_value(select max(schema_version) as ver from __all_ddl_operation, ver, 1);

# 启动liboblog
ob1.oblog.set_start_tstamp_usec $start_tstamp_usec;
ob1.oblog.gen_conf tb_white_list=sys.oblog*.*|oblog_tt.*.* enable_backup_mode=1 data_start_schema_version=$tenant_id:$drop_table_ddl_schema_version enable_formatter_print_log=1 skip_ob_version_compat_check=1;
ob1.oblog.restart;

let $count = $DML_COUNT;
while ($count>0)
{
  ob1.oblog.next_dml;
  dec $count;
}

ob1.oblog.stop;
