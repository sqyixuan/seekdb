#
# owner:shuning.tsn
#
# description: 测试schema未拆分，update或者delete __all_ddl_operation表liboblog不会退出
# 测试点:

ob1=OBI(cluster=1);
ob1.reboot;

source include/liboblog/create_tenant_with_gts.inc;
let $start_tstamp = query_get_value(select round(time_to_usec(now(6))) as now, now, 1);
connection oblog_conn_sys;
use oceanbase;
let $tenant_id = query_get_value(select tenant_id from __all_tenant where tenant_name="oblog_tt", tenant_id, 1);

ob1.oblog.gen_conf tb_white_list=oblog_tt.*.* log_level=INFO skip_ob_version_compat_check=1;
ob1.oblog.set_start_tstamp_usec $start_tstamp;
ob1.oblog.restart;
sleep 2;
eval update __all_ddl_operation set ddl_stmt_str='test update' where tenant_id = $tenant_id and operation_type = 102;
eval insert into __all_ddl_operation (schema_version, tenant_id, user_id, database_id, database_name, tablegroup_id, table_id, table_name, operation_type, ddl_stmt_str, exec_tenant_id) values (1234567890, $tenant_id, 0, 1, '', 10031, 1234, '', 104, 'test insert', 1);

eval delete from __all_ddl_operation where tenant_id = $tenant_id and ddl_stmt_str = 'test insert';
connection oblog_conn_tt;
create database oblog_db;
use oblog_db;
create table ta1(a int, b int);
insert into ta1 values(1,1);
ob1.oblog.next_dml;
ob1.oblog.stop;
