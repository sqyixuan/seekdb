#
# owner: bohou.ws
# owner group: OBCDC
# description:
#  防御OUTROW LOB从empty更新到empty的场景
##

ob1=OBI(cluster=1,version=4_1_0_0,init_unit_cpu=5, oblog_version=current);
ob1.reboot;
ob1.create_client;

# 创建mysql租户oblog_tt，并且切换到mysql租户下
source include/liboblog/create_tenant_with_gts.inc;

# 启动liboblog，同步oblog_tt租户数据
ob1.oblog.set_extra_argument -m;
ob1.oblog.gen_conf tb_white_list=oblog_tt.*.* log_level=ALL.*:INFO;TLOG.*:TRACE;
ob1.oblog.restart;
set ob_trx_timeout=100000000;
set ob_query_timeout=1000000000;

# 创建database 1
create database oblog_db1;
# 输出create database DDL
ob1.oblog.next;
use oblog_db1;

create table t_1(pk int primary key, data text, c2 varchar(100));
ob1.oblog.next;
insert into t_1 values(1, repeat('1', 5000), '123');
ob1.oblog.next;
update t_1 set c2 = '345', data = '' where pk = 1;
ob1.oblog.next;
# update empty outrow to empty outrow
update t_1 set c2 = '678', data = '' where pk = 1;
ob1.oblog.next;
delete from t_1 where pk = 1;
ob1.oblog.next;

# update rowkey and outrow lob to empty
insert into t_1 values(1, repeat('1', 5000), '123');
ob1.oblog.next;
update t_1 set pk = 2, c2 = '345', data = '' where pk = 1;
ob1.oblog.next;
# update empty outrow to empty outrow
update t_1 set pk = 3, c2 = '689', data = '' where pk = 2;
ob1.oblog.next;
delete from t_1 where pk = 3;
ob1.oblog.next;

# 执行drop table DDL
drop table t_1;
# 输出drop table DDL
ob1.oblog.next;

# stop liboblog
ob1.oblog.stop;
