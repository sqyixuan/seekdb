#
# owner:linyi.cl
# owner group:liboblog
# description:
# 测试点:
#
##

ob1=OBI(cluster=1);
ob1.reboot;
ob1.create_client;

# 准备环境
source include/liboblog/create_tenant.inc;

# 启动liboblog
ob1.oblog.gen_conf tb_white_list=sys.oblog*.*|oblog_tt.*.* skip_ob_version_compat_check=1;
ob1.oblog.restart;

--disable_warnings
drop catalog if exists ca1;
create external catalog ca1 properties=(type='odps');
ob1.oblog.next;

drop catalog ca1;
ob1.oblog.next;

# stop liboblog
ob1.oblog.stop;
