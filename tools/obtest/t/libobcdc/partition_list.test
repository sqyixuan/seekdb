#
# owner:千溪
# owner group:liboblog
# description:
# 测试点:
#   测试liboblog 支持list 分区
#
##

ob1=OBI(cluster=1, init_unit_cpu=5);
ob1.reboot;
ob1.create_client;

# 准备环境
source include/liboblog/create_tenant.inc;

--disable_warnings
drop database if exists oblog_db;

# 启动liboblog
ob1.oblog.gen_conf tb_white_list=oblog_tt.oblog*.* skip_ob_version_compat_check=1;
ob1.oblog.restart;

# sys租户下操作
# 创建database
create database oblog_db;
ob1.oblog.next;
use oblog_db;

######################################## case 1 简单list分区
create table t1 (c1 int, c2 int) partition by list(c1) (partition p0 values in (1,2,3), partition p1 values in (7,9));
ob1.oblog.next;

insert into t1 values(1,2);
ob1.oblog.next;
insert into t1 values(2,2);
ob1.oblog.next;
insert into t1 values(3,2);
ob1.oblog.next;
insert into t1 values(7,2);
ob1.oblog.next;
insert into t1 values(9,2);
ob1.oblog.next;

drop table t1;
ob1.oblog.next;

######################################## case 2 简单list分区 含有默认值

create table t1 (c1 int, c2 int) partition by list(c1) (partition p0 values in (1,2,3), partition p1 values in (7,9), partition p2 values in (default));
ob1.oblog.next;

insert into t1 values(10, 1);
ob1.oblog.next;
insert into t1 values(100, 1);
ob1.oblog.next;
insert into t1 values(1000, 1);
ob1.oblog.next;

drop table t1;
ob1.oblog.next;

######################################## case 3 简单list分区 单个元素
create table t1 (c1 year, c2 int) partition by list(c1) (partition p0 values in (2018));
ob1.oblog.next;

insert into t1 values(2018, 1);
ob1.oblog.next;

drop table t1;
ob1.oblog.next;

######################################## case 4 简单list分区 含有表达式
create table t1 (c1 int, c2 int) partition by list(c1 + 1) (partition p0 values in (1), partition p1 values in (2,3));
ob1.oblog.next;

insert into t1 values(0, 1);
ob1.oblog.next;
insert into t1 values(1, 1);
ob1.oblog.next;
insert into t1 values(2, 1);
ob1.oblog.next;
drop table t1;
ob1.oblog.next;

create table t1 (c1 int, c2 int) partition by list(c1 + c2) (partition p0 values in (1), partition p1 values in (2,3));
ob1.oblog.next;

insert into t1 values(-1, 2);
ob1.oblog.next;
insert into t1 values(0, 2);
ob1.oblog.next;
insert into t1 values(1, 2);
ob1.oblog.next;
drop table t1;
ob1.oblog.next;

######################################## case 5 简单list column分区
create table t1 (c1 int, c2 int, c3 int) partition by list columns(c1,c2) (partition p0 values in ((98, 99)));
ob1.oblog.next;
insert into t1 values(98, 99, 100);
ob1.oblog.next;
drop table t1;
ob1.oblog.next;

create table t1 (c1 int, c2 int, c3 int) partition by list columns(c1,c2) (partition p0 values in (98,99));
ob1.oblog.next;
insert into t1 values(98, 99, 100);
ob1.oblog.next;
drop table t1;
ob1.oblog.next;

create table t1 (c1 int, c2 int, c3 int) partition by list columns(c1,c2) (partition p0 values in (1,2), partition p1 values in ((3, 5)));
ob1.oblog.next;
insert into t1 values(1, 2, 100);
ob1.oblog.next;
insert into t1 values(3, 5, 100);
ob1.oblog.next;
drop table t1;
ob1.oblog.next;

create table t1 (c1 int, c2 int, c3 int) partition by list columns(c1,c2) (partition p0 values in ((1,2),(3,4)));
ob1.oblog.next;
insert into t1 values(1, 2, 100);
ob1.oblog.next;
insert into t1 values(3, 4, 100);
ob1.oblog.next;
drop table t1;
ob1.oblog.next;

create table t1 (c1 int, c2 int, c3 int) partition by list columns(c1,c2) (partition p0 values in (1,2), partition p1 values in (default));
ob1.oblog.next;
insert into t1 values(1, 2, 100);
ob1.oblog.next;
insert into t1 values(66, 77, 100);
ob1.oblog.next;
drop table t1;
ob1.oblog.next;

######################################## case 6 二级list分区: 1. list作为第一分区 2. list作为第二分区
create table t1 (c1 int, c2 int, c3 int) partition by hash(c1) subpartition by list(c2) subpartition template(subpartition p0 values in (1,2,3), subpartition p1 values in (default)) partitions 3;
ob1.oblog.next;
# c2 - p0
insert into t1 values(0,1,3);
ob1.oblog.next;
# c2 - p1
insert into t1 values(0,5,3);
ob1.oblog.next;
drop table t1;
ob1.oblog.next;

create table t1 (c1 int, c2 int, c3 int) partition by list(c1) subpartition by hash(c2) subpartitions 3 (partition p0 values in (1,2,3), partition p1 values in (default));
ob1.oblog.next;
# c1 - p0
insert into t1 values(1,0,3);
ob1.oblog.next;
# c2 - p1
insert into t1 values(5,0,3);
ob1.oblog.next;
drop table t1;
ob1.oblog.next;

create table t1 (c1 int, c2 int, c3 int) partition by list(c1) subpartition by range(c2) subpartition template (subpartition p0 values less than (5), subpartition p1 values less than (maxvalue)) (partition p0 values in (1,2,3), partition p1 values in (default));
ob1.oblog.next;
insert into t1 values(0,1,3);
ob1.oblog.next;
insert into t1 values(6,5,3);
ob1.oblog.next;
drop table t1;
ob1.oblog.next;

create table t1 (c1 int, c2 int, c3 int) partition by range(c1) subpartition by list(c2) subpartition template (subpartition p0 values in (1,2,3), subpartition p1 values in (default)) (partition p0 values less than (5), partition p1 values less than(10));
ob1.oblog.next;
# c1, c2 均位于p0
insert into t1 values(0,1,3);
ob1.oblog.next;
# c1, c2 均位于p1
insert into t1 values(6,5,3);
ob1.oblog.next;
drop table t1;
ob1.oblog.next;

######################################## case 7 交易支付场景
# 
#create table pmt_pay_ord_00 (payment_id varchar(32), apply_id varchar(32), partition_id varchar(2) GENERATED ALWAYS AS (substring(payment_id, 14, 2));

# 生成列
create table pmt_pay_ord_00 (payment_id varchar(32) primary key, apply_id varchar(32), partition_id varchar(2) GENERATED ALWAYS AS (substring(payment_id, 14, 2)), CONSTRAINT chk_Person CHECK (substring(payment_id, 14, 2) = substring(apply_id, 14, 2)))  partition by list columns(partition_id) (partition p0 values in ("00"), partition p1 values in ('01'), partition p2 values in ('02'), partition p3 values in ('03'));
ob1.oblog.next;

# partition_id: 00
insert into pmt_pay_ord_00(payment_id, apply_id) values ("123456789101200", "123456789101200");
ob1.oblog.next;

# partition_id: 01
insert into pmt_pay_ord_00(payment_id, apply_id) values ("123456789101201", "123456789101201");
ob1.oblog.next;

# partition_id: 02
insert into pmt_pay_ord_00(payment_id, apply_id) values ("123456789101202", "123456789101202");
ob1.oblog.next;

# partition_id: 03
insert into pmt_pay_ord_00(payment_id, apply_id) values ("123456789101203", "123456789101203");
ob1.oblog.next;

# stop liboblog
ob1.oblog.stop;

# 清理数据
--disable_warnings
drop database if exists oblog_db;
