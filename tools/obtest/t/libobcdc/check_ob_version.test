#
# owner:shuning.tsn
#
# description: 测试liboblog版本必须大于等于ob版本
#
# 测试点: 1. liboblog和ob版本格式，如2.2.1(major.minor.patch)
#         2. 只比较major和minor

ob1=OBI(cluster=1,oblog_version=current);
ob1.reboot;

let $ip=deploy_get_value(ob1.proxy0.ip);
let $port=deploy_get_value(ob1.proxy0.port);
#connect (oblog_conn_sys,$ip,admin@sys,admin,oceanbase,$port);
connect (oblog_conn_sys,$ip,root@sys,,oceanbase,$port);

# 连接sys租户
connection oblog_conn_sys;

# 查询observer版本
let $ver = query_get_value(show PARAMETERS like '%min_observer_version%', value, 1);
let $major = query_get_value(select substring_index("$ver", '.', 1) as value, value, 1);
let $minor = query_get_value(select substring_index(substring_index("$ver", '.', 2), '.', -1) as value, value, 1);
let $patch = query_get_value(select substring_index(substring_index("$ver", '.', 3), '.', -1) as value, value, 1);
#echo $major;
#echo $minor;
#echo $patch;

# 提升patch，验证oblog兼容
inc $patch;
let $ver_1 = query_get_value(select concat($major, '.', $minor, '.', $patch) as value, value, 1);
--disable_query_log
eval alter system set min_observer_version="$ver_1";
--enable_query_log

ob1.oblog.gen_conf tb_white_list=*.*.* log_level=INFO skip_ob_version_compat_check=0;
ob1.oblog.restart;
sleep 5;
ob1.oblog.stop;
ob1.oblog.check_log ') compatible with observer_version';

# 提升minor，验证oblog不兼容退出
ob1.oblog.gen_conf tb_white_list=*.*.* log_level=INFO cluster_version_refresh_interval_sec=8 skip_ob_version_compat_check=0;
ob1.oblog.restart;
inc $minor;
let $ver_2 = query_get_value(select concat($major, '.', $minor, '.', $patch) as value, value, 1);
--disable_query_log
eval alter system set min_observer_version="$ver_2";
--enable_query_log
sleep 15;
ob1.oblog.check_log 'not compatible with observer_version';

ob1.oblog.gen_conf tb_white_list=*.*.* log_level=INFO skip_ob_version_compat_check=1 cluster_version_refresh_interval_sec=8;
ob1.oblog.restart;
sleep 10;
ob1.oblog.stop;
ob1.oblog.check_log 'skip_ob_version_compat_check is true, skip check';
