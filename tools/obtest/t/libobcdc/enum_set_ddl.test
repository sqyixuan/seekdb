


ob1=OBI(cluster=1, init_unit_cpu=5);
ob1.reboot;
ob1.create_client;

# 准备环境
source include/liboblog/create_tenant.inc;
#alter system set syslog_level='debug';

--disable_warnings
drop database if exists oblog_db1;

let $start_tstamp = query_get_value(select round(time_to_usec(now()) / 1000000) as now, now, 1);

# 启动liboblog
ob1.oblog.set_start_tstamp $start_tstamp;
ob1.oblog.gen_conf tb_white_list=oblog_tt.oblog*.* log_level=DEBUG skip_ob_version_compat_check=1;
ob1.oblog.set_extra_argument -i;
ob1.oblog.restart;

# sys租户下操作
set sql_mode ='';

# 创建database
create database oblog_db1;
ob1.oblog.next;
use oblog_db1;

create table t_tmp(c1 int primary key, c2 char(12));
ob1.oblog.next;
insert into t_tmp values(1, '1');
ob1.oblog.next;
insert into t_tmp values(2, 'a');
ob1.oblog.next;
insert into t_tmp values(3, '');
ob1.oblog.next;
insert into t_tmp values(4, NULL);
ob1.oblog.next;

create table t_enum(c1 int primary key, c2 enum('a', 'b', 'c'));
ob1.oblog.next;
insert into t_enum values(1, 1);
ob1.oblog.next;
insert into t_enum values(2, 'a');
ob1.oblog.next;
insert into t_enum values(3, 0);
ob1.oblog.next;
insert into t_enum values(4, "invalid");
ob1.oblog.next;
insert into t_enum values(5, null);
ob1.oblog.next;

select c1, c2, c2+1-1 from t_enum;
insert into t_enum values (6, 'a'), (7, 'invalid'), (8, NULL);
ob1.oblog.next;
select c1, c2, c2+1-1 from t_enum;

create table t_enum2(c1 enum('a', 'b', 'c') primary key, c2 int );
ob1.oblog.next;
insert into t_enum2 values('a', 1);
ob1.oblog.next;
insert into t_enum2 values(2, 2);
ob1.oblog.next;
insert into t_enum2 values('c', 3);
ob1.oblog.next;
insert into t_enum2 values('invald', 4);
ob1.oblog.next;
select c2, c1, c1+1-1 from t_enum2;

create table t_set(c1 int primary key, c2 set('a', 'b', 'c'));
ob1.oblog.next;
insert into t_set values(1, 1);
ob1.oblog.next;
insert into t_set values(2, "a,c");
ob1.oblog.next;
insert into t_set values(3, 0);
ob1.oblog.next;
insert into t_set values(4, "invalid");
ob1.oblog.next;
insert into t_set values(5, null);
ob1.oblog.next;
insert into t_set values(6, "a,b,d");
ob1.oblog.next;
select c1, c2, c2+1-1 from t_set;

create table t_set2(c1 set('a', 'b', 'c')  primary key, c2 int);
ob1.oblog.next;
insert into t_set2 values('a', 1);
ob1.oblog.next;
insert into t_set2 values(3, 2);
ob1.oblog.next;
insert into t_set2 values('a,b,c', 3);
ob1.oblog.next;
insert into t_set2 values('invalid', 4);
ob1.oblog.next;
select c2, c1, c1+1-1 from t_set2;

create table t_set_enum1(c1 set('a', 'b', 'c', 'd') primary key, c2 enum('a', 'b', 'c', 'd', 'e'), c3 int);
ob1.oblog.next;
insert into t_set_enum1 values('a', 'a', 1);
ob1.oblog.next;
insert into t_set_enum1 values('b', 5, 1);
ob1.oblog.next;
insert into t_set_enum1 values('a,b', null, 2);
ob1.oblog.next;
insert into t_set_enum1 values('invalid', 'd', 3);
ob1.oblog.next;
update t_set_enum1 set c2='b' where c1='b';
ob1.oblog.next;
delete from t_set_enum1 where c1='a';
ob1.oblog.next;
select c1, c2, c2+1-1, c3 from t_set_enum1;

create table t_set_enum2(c1 set('a', 'b', 'c', 'd'), c2 enum('a', 'b', 'c', 'ddddd', 'e')  primary key, c3 int);
ob1.oblog.next;
insert into t_set_enum2 values('a', 1, 1);
ob1.oblog.next;
insert into t_set_enum2 values('b', 'e', 1);
ob1.oblog.next;
insert into t_set_enum2 values('a,b', 'c', 2);
ob1.oblog.next;
insert into t_set_enum2 values('invalid', 'ddddd', 3);
ob1.oblog.next;
update t_set_enum2 set c2='b' where c1='b';
ob1.oblog.next;
delete from t_set_enum2 where c1='a';
ob1.oblog.next;
select c1, c2, c2+1-1, c3 from t_set_enum2;

# stop liboblog
ob1.oblog.stop;
