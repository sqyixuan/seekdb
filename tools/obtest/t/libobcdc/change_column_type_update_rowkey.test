#
# owner:shuning.tsn
#
# description: 测试liboblog对主键列类型转换的支持
#    1. 反复修改主键列，liboblog对row key可比


ob1=OBI(cluster=1, init_unit_cpu=5);
ob1.reboot;

source include/liboblog/create_tenant_with_gts.inc;
set global max_allowed_packet = 1073741824;
let $ip=deploy_get_value(ob1.proxy0.ip);
let $port=deploy_get_value(ob1.proxy0.port);
connect (oblog_conn_tt,$ip,root@oblog_tt,,oceanbase,$port);
connection oblog_conn_tt;

--disable_warnings
drop database if exists oblog_db;
create database oblog_db;
use oblog_db;

source include/liboblog/change_column_type_update_rowkey.inc;
