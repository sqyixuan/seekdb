##########################
#owner :  zuojiao.hzj
#owner group: sql
#description:
# 测试点：
# 1. mysql date 和 mysql datetime
#

##########################

ob1=OBI(cluster=1,init_unit_cpu=2);
ob1.reboot;
ob1.create_client;

source include/liboblog/create_tenant_with_gts.inc;

# 启动oblog
ob1.oblog.gen_conf tb_white_list=oblog_tt.oblog_db1.* log_level=DEBUG;
ob1.oblog.set_extra_argument -i;
ob1.oblog.restart;

# 创建database 1
create database oblog_db1;
ob1.oblog.next;
use oblog_db1;

set sql_mode = 'STRICT_ALL_TABLES,ALLOW_INVALID_DATES';

create table simple_mysql_date(c0 date, c1 datetime, c2 datetime(6));
ob1.oblog.next;

insert into simple_mysql_date values(date'2024-07-30', '2024-07-30 18:30:45', '2024-07-30 18:30:45.123456');
ob1.oblog.next;

insert into simple_mysql_date values(date'2024-02-31', '2024-02-31 18:30:45', '2024-02-31 18:30:45.123456');
ob1.oblog.next;

insert into simple_mysql_date values('2024-00-31', '2024-00-31 18:30:45', '2024-00-31 18:30:45.654321');
ob1.oblog.next;

insert into simple_mysql_date values('2024-01-00', '2024-06-00 18:30:45', '2024-12-00 18:30:45.654321');
ob1.oblog.next;

insert into simple_mysql_date values('2024-00-00', '2024-00-00 18:30:45', '2024-00-00 18:30:45.654321');
ob1.oblog.next;

insert into simple_mysql_date values(0, 0, 0);
ob1.oblog.next;

insert into simple_mysql_date values(null, null, null);
ob1.oblog.next;

set sql_mode = 'STRICT_ALL_TABLES,NO_ZERO_IN_DATE';

--error 1292
insert into simple_mysql_date values('2024-00-31', '2024-00-31 18:30:45', '2024-00-31 18:30:45.654321');

--error 1292
insert into simple_mysql_date values('2024-01-00', '2024-06-00 18:30:45', '2024-12-00 18:30:45.654321');

--error 1292
insert into simple_mysql_date values('2024-00-00', '2024-00-00 18:30:45', '2024-00-00 18:30:45.654321');

insert into simple_mysql_date values(0, 0, 0);
ob1.oblog.next;

set sql_mode = 'STRICT_ALL_TABLES,ALLOW_INVALID_DATES';

select * from simple_mysql_date;

update simple_mysql_date set c0 = date'2024-02-31';
ob1.oblog.next;
select * from simple_mysql_date;

update simple_mysql_date set c1 = '2024-00-01';
ob1.oblog.next;
select * from simple_mysql_date;

update simple_mysql_date set c1 = '2024-12-00 12:34:56';
ob1.oblog.next;
select * from simple_mysql_date;

update simple_mysql_date set c2 = '2024-00-00 00:00:00.999999';
ob1.oblog.next;
select * from simple_mysql_date;

drop table simple_mysql_date;
ob1.oblog.next;
sleep 1;

## date datetime 作为主键
create table simple_mysql_date(c1 date, c2 datetime, c3 int, primary key(c1, c2));
ob1.oblog.next;
sleep 1;

let $start_tstamp = query_get_value(select round(time_to_usec(now()) / 1000000) as now, now, 1);

insert into simple_mysql_date values(date'2024-02-31', '2024-02-31 12:34:56', 1);
delete from simple_mysql_date;
insert into simple_mysql_date values(date'2024-00-31', '2024-00-31 12:34:56', 2);
delete from simple_mysql_date;
insert into simple_mysql_date values(date'2024-00-00', '2024-00-00 12:34:56', 3);
delete from simple_mysql_date;

let $DECINT_PK_DML_CNT = 6;
while ($DECINT_PK_DML_CNT > 0)
{
  ob1.oblog.next;
  dec $DECINT_PK_DML_CNT;
}

# stop liboblog
ob1.oblog.stop;

# 回拉历史
ob1.oblog.set_start_tstamp $start_tstamp;
ob1.oblog.gen_conf tb_white_list=oblog_tt.oblog_db1.* log_level=DEBUG;
ob1.oblog.set_extra_argument -i;
ob1.oblog.restart;

let $DECINT_PK_DML_CNT = 6;
while ($DECINT_PK_DML_CNT > 0)
{
  ob1.oblog.next;
  dec $DECINT_PK_DML_CNT;
}

# stop liboblog
ob1.oblog.stop;
