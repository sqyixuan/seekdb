#
# owner:千溪
# owner group:liboblog
# description:
# 测试点:
#  测试mysql
#
#  mysql database/table始终转换为小写, 匹配不区分大小写
#
##

ob1=OBI(cluster=1,init_unit_cpu=5);
ob1.reboot;
ob1.create_client;

source include/liboblog/create_tenant_with_gts.inc;

# 启动liboblog
ob1.oblog.gen_conf tb_white_list=oblog_tt.oblog_db1.* skip_ob_version_compat_check=1;
ob1.oblog.restart;

let $start_tstamp = query_get_value(select round(time_to_usec(now()) / 1000000) as now, now, 1);

# 创建database
create database oblog_db1;
ob1.oblog.next;

### oblog_db1
use oblog_db1;
create table OBLOG_DB1_T1(c0 int primary key, c1 int);
ob1.oblog.next;
insert into OBLOG_DB1_T1 values(1, 1);
ob1.oblog.next;

create table oblog_db1_t2(c0 int primary key, c1 int);
ob1.oblog.next;

begin;
update OBLOG_DB1_T1 set C1 = 10 where C0=1;
insert into oblog_db1_t2 values(1, 1);
commit;
ob1.oblog.next;

# 回拉配置大写db
ob1.oblog.set_start_tstamp $start_tstamp;
ob1.oblog.gen_conf tb_white_list=oblog_tt.OBLOG_DB1.* log_level=DEBUG skip_ob_version_compat_check=1;
ob1.oblog.restart;

let $DML_CNT = 2;
while ($DML_CNT > 0)
{
  ob1.oblog.next_dml;
  dec $DML_CNT;
}
# stop liboblog
ob1.oblog.stop;

# 回拉配置大写table
ob1.oblog.set_start_tstamp $start_tstamp;
ob1.oblog.gen_conf tb_white_list=oblog_tt.ObLoG_Db1.OBLOG_DB1_T1 log_level=DEBUG skip_ob_version_compat_check=1;
ob1.oblog.restart;

let $DML_CNT = 2;
while ($DML_CNT > 0)
{
  ob1.oblog.next_dml;
  dec $DML_CNT;
}
# stop liboblog
ob1.oblog.stop;

# 回拉配置大写db, 大小写均有table
ob1.oblog.set_start_tstamp $start_tstamp;
ob1.oblog.gen_conf tb_white_list=oblog_tt.OBLOG_DB1.ObLoG_dB1_t1 log_level=DEBUG skip_ob_version_compat_check=1;
ob1.oblog.restart;

let $DML_CNT = 2;
while ($DML_CNT > 0)
{
  ob1.oblog.next_dml;
  dec $DML_CNT;
}
# stop liboblog
ob1.oblog.stop;

# 回拉配置大写db, 小写table
ob1.oblog.set_start_tstamp $start_tstamp;
ob1.oblog.gen_conf tb_white_list=oblog_tt.OBLOG_DB1.oblog_db1_t2 log_level=DEBUG skip_ob_version_compat_check=1;
ob1.oblog.restart;

let $DML_CNT = 1;
while ($DML_CNT > 0)
{
  ob1.oblog.next_dml;
  dec $DML_CNT;
}
# stop liboblog
ob1.oblog.stop;
