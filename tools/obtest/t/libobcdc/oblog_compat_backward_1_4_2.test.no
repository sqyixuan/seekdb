#
# owner:千溪
# owner group:liboblog
# 测试点：测试liboblog的向前兼容性，采用最新版本liboblog向老版本observer取日志
# 1. 要求schema模块向前兼容，新版本schema可以连接老版本observer构建起来
# 2. 要求liboblog取日志模块向前兼容

# OB版本是1.4.2
# liboblog版本是当前版本
ob1=OBI(cluster=1:1:1,init_unit_cpu=5,init_unit_num=1,init_unit_mem=5368709120,version=1_4_2,oblog_version=current);
ob1.reboot;
sleep 5;

source include/oblog_compat_backward_common.inc;
source include/all_ddl_type.inc;
