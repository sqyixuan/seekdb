#
# owner:千溪
# owner group:liboblog
# description:
# 测试点: 测试分区划分方式，不依赖database, tablegroup

ob1=OBI(cluster=2);
ob1.reboot;

# 准备环境
let $user_define_tenant_size=1;
let $max_cpu=2;
let $memory_size='20G';
source include/liboblog/4_x/create_mysql_tenant_multi_unit.inc;
#ob_connect (oblog_conn_tt,ob1.z1.obs0,root@obtest,,oceanbase,USE_OB_CONNECTOR);
#connection oblog_conn_tt;
--disable_warnings
drop database if exists oblog_db1;
--disable_warnings
drop database if exists oblog_db2;
--disable_warnings
drop tablegroup if exists tg0;

# 启动liboblog
ob1.oblog.gen_conf tb_white_list=*cdc*.*.* instance_index=0 instance_num=2 sort_trans_participants=1 skip_ob_version_compat_check=1;
ob1.oblog.restart;

# 创建database
create database oblog_db1;
ob1.oblog.next;
create database oblog_db2;
ob1.oblog.next;

use oblog_db1;
create tablegroup tg0;
ob1.oblog.next;

create table test1(pk int primary key, c1 int);
ob1.oblog.next;
create table test2(pk int primary key, c1 int);
ob1.oblog.next;

create table t1 (c1 varchar(20), c2 int, primary key (c1,c2)) partition by list columns (c1,c2)  (partition p0 values in (('1',1),('2',2)), partition p1 values in (('3',3),('4',4)), partition p2 values in (('5',5), ('6',6)), partition p3 values in (('7',7), ('8',8)));
ob1.oblog.next;
begin;
insert into test1 values (1,1);
insert into test2 values (1,1);
insert into t1 values ('1', 1);
commit;

begin;
update test1 set c1=c1+1 where pk=1;
update test2 set c1=c1+1 where pk=1;
insert into t1 values ('3', 3);
commit;

begin;
update test1 set c1=c1+1 where pk=1;
update test2 set c1=c1+1 where pk=1;
insert into t1 values ('5', 5);
commit;

begin;
update test1 set c1=c1+1 where pk=1;
update test2 set c1=c1+1 where pk=1;
insert into t1 values ('7', 7);
commit;

ob1.oblog.next;
ob1.oblog.next;
ob1.oblog.next;
ob1.oblog.next;

create table t2 (c1 varchar(20), c2 int, primary key (c1,c2)) tablegroup = 'tg0' partition by list columns (c1,c2)  (partition p0 values in (('1',1),('2',2)), partition p1 values in (('3',3),('4',4)), partition p2 values in (('5',5), ('6',6)), partition p3 values in (('7',7), ('8',8)));
ob1.oblog.next;

begin;
update test1 set c1=c1+1 where pk=1;
update test2 set c1=c1+1 where pk=1;
insert into t2 values ('2', 2);
commit;

begin;
update test1 set c1=c1+1 where pk=1;
update test2 set c1=c1+1 where pk=1;
insert into t2 values ('4', 4);
commit;

begin;
update test1 set c1=c1+1 where pk=1;
update test2 set c1=c1+1 where pk=1;
insert into t2 values ('6', 6);
commit;

begin;
update test1 set c1=c1+1 where pk=1;
update test2 set c1=c1+1 where pk=1;
insert into t2 values ('8', 8);
commit;

ob1.oblog.next;
ob1.oblog.next;
ob1.oblog.next;
ob1.oblog.next;

alter table t1 set tablegroup tg0;
ob1.oblog.next;

# rename table-database
RENAME table oblog_db1.t2 to oblog_db2.t2;
ob1.oblog.next;

################### 验证tablegroup_id, database_id不影响分区方式###################
# 启动liboblog
ob1.oblog.gen_conf tb_white_list=*cdc*.*.* instance_index=0 instance_num=2 sort_trans_participants=1 skip_ob_version_compat_check=1;
ob1.oblog.restart;

let $start_tstamp = query_get_value(select round(time_to_usec(now()) / 1000000) as now, now, 1);

begin;
update test1 set c1=c1+1 where pk=1;
update test2 set c1=c1+1 where pk=1;
insert into t1 values ('2', 2);
commit;

begin;
update test1 set c1=c1+1 where pk=1;
update test2 set c1=c1+1 where pk=1;
insert into t1 values ('4', 4);
commit;

begin;
update test1 set c1=c1+1 where pk=1;
update test2 set c1=c1+1 where pk=1;
insert into t1 values ('6', 6);
commit;

begin;
update test1 set c1=c1+1 where pk=1;
update test2 set c1=c1+1 where pk=1;
insert into t1 values ('8', 8);
commit;

ob1.oblog.next;
ob1.oblog.next;
ob1.oblog.next;
ob1.oblog.next;

use oblog_db2;
begin;
update oblog_db1.test1 set c1=c1+1 where pk=1;
update oblog_db1.test2 set c1=c1+1 where pk=1;
insert into t2 values ('1', 1);
commit;

begin;
update oblog_db1.test1 set c1=c1+1 where pk=1;
update oblog_db1.test2 set c1=c1+1 where pk=1;
insert into t2 values ('3', 3);
commit;

begin;
update oblog_db1.test1 set c1=c1+1 where pk=1;
update oblog_db1.test2 set c1=c1+1 where pk=1;
insert into t2 values ('5', 5);
commit;

begin;
update oblog_db1.test1 set c1=c1+1 where pk=1;
update oblog_db1.test2 set c1=c1+1 where pk=1;
insert into t2 values ('7', 7);
commit;

ob1.oblog.next;
ob1.oblog.next;
ob1.oblog.next;
ob1.oblog.next;

################### 同步其他数据###################
# 启动liboblog
ob1.oblog.set_start_tstamp $start_tstamp;
ob1.oblog.gen_conf tb_white_list=*cdc*.*.* instance_index=1 instance_num=2 sort_trans_participants=1 skip_ob_version_compat_check=1;
ob1.oblog.restart;

# 8条DML,包括test1-table
let $DML_CNT = 8;
while ($DML_CNT > 0)
{
  ob1.oblog.next_dml;
  dec $DML_CNT;
}

# 停止liboblog
ob1.oblog.stop;
