#
# owner:zhichen
# owner group:shenzhen
# description:
# test:
# json partial update
#
##

ob1=OBI(cluster=1);
ob1.reboot;
ob1.create_client;

source include/liboblog/create_tenant_with_gts.inc;

--disable_warnings
drop database if exists oblog_db;

# start obcdc
ob1.oblog.set_extra_argument -m;
ob1.oblog.gen_conf tb_white_list=oblog_tt.*.* log_level=DEBUG;
ob1.oblog.restart;

# create database
create database oblog_db;
ob1.oblog.next;
use oblog_db;

set log_row_value_options="partial_json";
set GLOBAL max_allowed_packet=1073741824;
ob1.oblog.next;
set ob_query_timeout=100000000000;

create table json_test(pk int, j json) JSON(j) STORE AS (CHUNK '1K');
ob1.oblog.next;

insert into json_test values(9 , json_object('name', 'zero', 'age', 100, 'position', 'software engineer', 'hrofile', repeat('x', 4000), 'like', json_array('a', 'b', 'c'), 'nickname', repeat('z', 100), 'big1', repeat('z', 1000), 'big2', repeat('z', 300), 'big3', repeat('z', 500), 'big4', repeat('z', 500), 'big5', repeat('z', 500), 'big6', repeat('z', 500), repeat('y', 1048570), 'big-key-y', repeat('z', 1048570), 'big-key-z', repeat('x', 1048570), 'big-key-x'));
select md5(j), json_extract(j, concat('$.', repeat('x', 1048570)), concat('$.', repeat('y', 1048570)), concat('$.', repeat('z', 1048570)) ) as value from json_test where pk=9;
ob1.oblog.next;

# construct result to check md5
create table tmp(d longtext);
ob1.oblog.next;
insert into tmp values('');
ob1.oblog.next;
select md5(concat(d, '{"version": 1, "diffs": ',
    json_array(
        json_object('op', 'replace', 'value', 'big-key-x1', 'path', concat('$.\"', repeat('x', 1048570), '\"')),
        json_object('op', 'replace', 'value', 'big-key-y1', 'path', concat('$.\"', repeat('y', 1048570), '\"')),
        json_object('op', 'replace', 'value', 'big-key-z1', 'path', concat('$.\"', repeat('z', 1048570), '\"'))
    ), '}')) as md5_sum from tmp;
drop table tmp;
ob1.oblog.next;

update json_test set j = json_set(j, concat('$.', repeat('x', 1048570)), 'big-key-x1', concat('$.', repeat('y', 1048570)), 'big-key-y1', concat('$.', repeat('z', 1048570)), 'big-key-z1') where pk=9;
select md5(j), json_extract(j, concat('$.', repeat('x', 1048570)), concat('$.', repeat('y', 1048570)), concat('$.', repeat('z', 1048570)) ) as data from json_test where pk=9;
ob1.oblog.next;

drop table json_test;
ob1.oblog.next;
ob1.oblog.stop;
