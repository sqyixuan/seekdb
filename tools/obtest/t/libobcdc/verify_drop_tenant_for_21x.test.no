ob1=OBI(cluster=1,version=2_1_20,oblog_version=current);
ob1.reboot;

source include/liboblog/create_tenant_with_gts.inc;

## 测试drop tenant之后，ddl执行可以获取到tenant
let $start_tstamp = query_get_value(select round(time_to_usec(now(6))) as now, now, 1);
let $cnt=0;
while ($cnt<30)
{
  eval create database t$cnt;
  inc $cnt;
}

connection oblog_conn_sys;
drop tenant oblog_tt;

ob1.oblog.gen_conf tb_white_list=oblog_tt.oblog_db.* log_level=INFO test_mode_on=1 test_mode_block_committer_handle_time_sec=2 test_mode_committer_handle_trans_count_upper_limit=1 skip_ob_version_compat_check=1;
ob1.oblog.set_start_tstamp_usec $start_tstamp;

ob1.oblog.restart;
let $tmp_cnt=0;
while ($tmp_cnt < $cnt)
{
  ob1.oblog.next;
  inc $tmp_cnt;
}

ob1.oblog.stop;

## 测试add/del tenant，白名单过滤
let $start_tstamp = query_get_value(select round(time_to_usec(now(6))) as now, now, 1);
connection oblog_conn_sys;
create tenant tt1 replica_num = 1, primary_zone='z1', resource_pool_list=('oblog_pool') set ob_tcp_invited_nodes='%';
sleep 1;
drop tenant tt1;

ob1.oblog.gen_conf tb_white_list=oblog_tt.oblog_db.* log_level=INFO test_mode_on=1 test_mode_block_committer_handle_time_sec=2 test_mode_committer_handle_trans_count_upper_limit=1 skip_ob_version_compat_check=1;
ob1.oblog.set_start_tstamp_usec $start_tstamp;

ob1.oblog.restart;
ob1.oblog.stop;
ob1.oblog.check_log "[FILTER_DDL_STMT] TENANT_ID=1 OP_TYPE=OB_DDL_DEL_TENANT";
