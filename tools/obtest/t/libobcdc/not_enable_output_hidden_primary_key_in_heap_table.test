#
# owner:lixia.yq
# owner group:liboblog
# description:
# 测试点:
#  1. 无主键表, 隐藏主键列，column id < 16
#  insert/update/delete
#  2. 索引
#
##

## TODO(@lixia.yq) 添加生成列做分区键相关的case

ob1=OBI(cluster=1, init_unit_cpu=5);
ob1.reboot;
ob_connect(conn1, ob1.z1.obs0, root, , test, , USE_MYSQL_CONNECTOR);

# 准备环境
source include/liboblog/create_tenant.inc;

--disable_warnings
drop database if exists oblog_db;

# 启动liboblog
ob1.oblog.gen_conf tb_white_list=oblog_tt.oblog_db.* log_level=DEBUG enable_output_hidden_primary_key=0 sort_trans_participants=1 enable_output_trans_order_by_sql_operation=1 skip_ob_version_compat_check=1;
ob1.oblog.set_extra_argument -i;
ob1.oblog.restart;

create database oblog_db;
ob1.oblog.next;
use oblog_db;

##### 1. 列数：1	分区键：1
create table t0(c0 int NOT NULL) partition by hash(c0);
ob1.oblog.next;

insert into t0 values(1);
ob1.oblog.next;
insert into t0 values(2);
ob1.oblog.next;

update t0 set c0=999 where c0=1;
ob1.oblog.next;

# not exists
delete from t0 where c0=200;
# not exists
delete from t0 where c0=201;

delete from t0;
ob1.oblog.next;

##### 2. 列数：3	分区键：1
create table t1(column_auto_inc float auto_increment NOT NULL, c1 varchar(50) NULL default NULL, c2 int) partition by hash(c2);
ob1.oblog.next;

insert into t1 values(1, "oblog", 3);
ob1.oblog.next;
insert into t1 values(2, "oblog", 4);
ob1.oblog.next;
insert into t1 values(3, "oblog", 5);
ob1.oblog.next;

update t1 set c1 = "liboblog" where c2 = 5;
ob1.oblog.next;

delete from t1 where c2 = 3;
ob1.oblog.next;

update t1 set c2 = 999 where column_auto_inc = 2;
ob1.oblog.next;

#### 3. 列数：5		分区键：3
create table t2(c1 int, c2 int, c3 int, c4 int, c5 int) partition by hash(c4 + c3 + c1) partitions 5;
ob1.oblog.next;

insert into t2 values(1, 2, 3, 4, 5);
ob1.oblog.next;
insert into t2 values(6, 7, 8, 9, 10);
ob1.oblog.next;

update t2 set c2 = 100 where c3 = 3;
ob1.oblog.next;
update t2 set c3 = 200;
ob1.oblog.next;

update t2 set c3 = 999, c1 = 111, c4 = 444 where c2 = 100;
ob1.oblog.next;

delete from t2 where c1 = 111;
ob1.oblog.next;

#### 3. 列数：5		分区键：3
create table t3(c1 int, c2 int, c3 int, c4 int, c5 int) partition by hash(c1 + c2 + c3) partitions 5;
ob1.oblog.next;

insert into t3 values(1, 2, 3, 4, 5);
ob1.oblog.next;
insert into t3 values(6, 7, 8, 9, 10);
ob1.oblog.next;

update t3 set c2 = 100 where c3 = 3;
ob1.oblog.next;
update t3 set c3 = 200 where c4 = 9;
ob1.oblog.next;

update t3 set c3 = 999, c1 = 111, c4 = 444 where c2 = 100;
ob1.oblog.next;

delete from t3 where c3 = 999;
ob1.oblog.next;

### 4. 增删分区
create table t4(c1 int, c2 int) partition by range(c1) (partition p0 values less than(10), partition p1 values less than(100));
ob1.oblog.next;

insert into t4 values(1, 2);
ob1.oblog.next;
insert into t4 values(3, 4);
ob1.oblog.next;

update t4 set c2 = 999 where c1 = 1;
ob1.oblog.next;
update t4 set c1 = 88 where c2 = 4;
ob1.oblog.next;

alter table t4 add partition (partition p2 values less than (10000), partition p3 values less than (maxvalue));
ob1.oblog.next;

insert into t4 values(300, 5);
ob1.oblog.next;

update t4 set c1 = 20000 where c2 = 5;
ob1.oblog.next;

alter table t4 drop partition p3;
ob1.oblog.next;

##### 创建多列, 带索引的表
create table t5(c1 int, c2 int, c3 int, c4 int, c5 int, index(c1), unique key(c1, c2));
ob1.oblog.next;
insert into t5 values(1, 2, 3, 4, 5);
ob1.oblog.next;
insert into t5 values(11, 12, 13, 14, 15);
ob1.oblog.next;
update t5 set c1=10 where c4 = 4;
ob1.oblog.next;
delete from t5 where c1=10;
ob1.oblog.next;
delete from t5;
ob1.oblog.next;

##### 频繁增减列
# 偶数列删除
create table t6(c1 int) partition by hash(c1);
ob1.oblog.next;
insert into t6 values(1);
ob1.oblog.next;
# add c2, c3, c4
alter table t6 add column c2 varchar(20) default 'c2_hello_ant';
ob1.oblog.next;
begin;
insert into t6 values(2, "c2");
update t6 set c1=100 where c1=1;
commit;
ob1.oblog.next;
alter table t6 add column c3 varchar(20) default 'c3_hello_ant';
ob1.oblog.next;
begin;
insert into t6 values(3, "c2", "c3");
update t6 set c1=101 where c1=100;
commit;
ob1.oblog.next;
alter table t6 add column c4 varchar(20) default 'c4_hello_ant';
ob1.oblog.next;
begin;
insert into t6 values(4, "c2", "c3", "c4");
update t6 set c1=102 where c1=101;
commit;
ob1.oblog.next;

# romove c2, c4
alter table t6 drop column c2;
ob1.oblog.next;
begin;
insert into t6 values(5, "c3", "c4");
update t6 set c1=103 where c1=102;
commit;
ob1.oblog.next;
alter table t6 drop column c4;
ob1.oblog.next;
begin;
insert into t6 values(6, "c3");
update t6 set c1=104 where c1=103;
commit;
ob1.oblog.next;

##### 7.二级分区
create table t7(c1 int, c2 int, c3 int, c4 int, c5 int) PARTITION BY key(c5, c3) SUBPARTITION BY RANGE(c2) subpartition template (SUBPARTITION sp0 VALUES less than(100),SUBPARTITION sp1 VALUES less than(200)) partitions 3;

ob1.oblog.next;
sleep 1;
let $start_tstamp = query_get_value(select round(time_to_usec(now()) / 1000000) as now, now, 1);
let $dml_cnt=0;

insert into t7 values(1, 2, 3, 4, 5);
ob1.oblog.next;
inc $dml_cnt;

let $cnt=20;
let $idx=6;
while($idx < $cnt)
{
  eval alter table t7 add column c$idx int default $idx;
  ob1.oblog.next;
  inc $idx;
}

#### 8.二级分区
create table t8(c1 int, c2 int, c3 int, c4 int, c5 int) PARTITION BY key(c1, c2) SUBPARTITION BY RANGE(c3) subpartition template (SUBPARTITION sp0 VALUES less than(100),SUBPARTITION sp1 VALUES less than(2000)) partitions 5;
ob1.oblog.next;

insert into t8 values(1, 2, 3, 4, 5);
ob1.oblog.next;
insert into t8 values(9,10,11,12,13);
ob1.oblog.next;

select * from t8;
update t8 set c1 = 999;
ob1.oblog.next;

update t8 set c1 = 123, c2 = 234, c3 = 345 where c4 = 4;
ob1.oblog.next;

delete from t8 where c1 = 123;
ob1.oblog.next;

connection oblog_conn_sys;
use oceanbase;
let $tenant_id = query_get_value(select tenant_id from __all_tenant where tenant_name="oblog_tt", tenant_id, 1);
connection oblog_conn_tt;
# schema split mode, 在租户本身下面查询
use oceanbase;
let $max_ddl_schema_version = query_get_value(select max(schema_version) as ver from __all_ddl_operation, ver, 1);

# stop liboblog
ob1.oblog.stop;

connection oblog_conn_tt;
# 启动liboblog, 回拉
ob1.oblog.set_start_tstamp $start_tstamp;
ob1.oblog.gen_conf tb_white_list=oblog_tt.oblog_db.* log_level=DEBUG enable_output_hidden_primary_key=0 data_start_schema_version=$tenant_id:$max_ddl_schema_version sort_trans_participants=1 enable_output_trans_order_by_sql_operation=1 skip_ob_version_compat_check=1;
ob1.oblog.set_extra_argument -i;
ob1.oblog.restart;

let $idx=0;
while($idx < $dml_cnt)
{
  ob1.oblog.next_dml;
  inc $idx;
}

# stop liboblog
ob1.oblog.stop;

# 清理数据
--disable_warnings
drop database if exists oblog_db;
