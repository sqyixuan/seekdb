#
# owner:千溪
# owner group:liboblog
# description:
# 测试点:
#   全局索引测试
#   1. 分区添加测试:
#      (1) 创建主表(携带普通/唯一索引)
#      (2) 创建主表后, 再创建全局普通/唯一索引
#   2. 启动时刻添加所有全局索引分区
#   3. 分区删除测试:
#      (1) 删除全局索引
#      (2) 删除主表
#      (3) 删除DB
#      (4) 删除租户
#
#  本case测试：
#  1. 分区添加
#  2. 启动时刻添加所有全局索引分区
#
##

ob1=OBI(cluster=1);
ob1.reboot;
ob1.create_client;

# 准备环境
let $ip=deploy_get_value(ob1.proxy0.ip);
let $port=deploy_get_value(ob1.proxy0.port);
connect (oblog_conn_sys,$ip,admin@sys,admin,oceanbase,$port);
connection oblog_conn_sys;

--disable_warnings
drop tenant if exists oblog_tt;
--disable_warnings
drop resource pool if exists oblog_pool;
--disable_warnings
drop resource unit if exists oblog_box;

source include/liboblog/create_tenant_with_gts.inc;

--disable_warnings
drop database if exists oblog_db1;

#ob1.oblog.gen_conf tb_white_list=oblog_tt.oblog_db1.* sort_trans_participants=1 log_level=DEBUG skip_ob_version_compat_check=1;
ob1.oblog.gen_conf tb_white_list=oblog_tt.oblog_db1.* sort_trans_participants=1 skip_ob_version_compat_check=1;
ob1.oblog.restart;

# 创建database
create database oblog_db1;
ob1.oblog.next;
use oblog_db1;

################################ 1 分区添加测试
# 全局索引建表
source include/liboblog/global_index/global_index_create_table.inc;

# stop liboblog
ob1.oblog.stop;

########## 测试启动时刻添加全局索引分区: 包括全局普通/唯一
#ob1.oblog.gen_conf tb_white_list=oblog_tt.oblog_db1.* log_level=DEBUG skip_ob_version_compat_check=1;
ob1.oblog.gen_conf tb_white_list=oblog_tt.oblog_db1.* sort_trans_participants=1 skip_ob_version_compat_check=1;
ob1.oblog.restart;

let $DML_CNT=0;
# DML
insert into t1 values(10, 200, 3, 4);
inc $DML_CNT;

begin;
insert into t2 values(10, 200, 3, 4);
update t1 set c2=20 where c1=10;
commit;
inc $DML_CNT;

begin;
insert into t3 values(10, 200, 3, 4);
update t1 set c2=21 where c1=10;
commit;
inc $DML_CNT;

begin;
insert into t4 values(10, 200, 3, 4);
update t1 set c2=22 where c1=10;
commit;
inc $DML_CNT;

begin;
insert into t5 values(10, 200, 3, 4);
update t1 set c2=23 where c1=10;
commit;
inc $DML_CNT;

begin;
insert into t6 values(10, 200, 3, 4);
update t1 set c2=24 where c1=10;
commit;
inc $DML_CNT;

begin;
insert into t7 values(10, 200, 3, 4);
update t1 set c2=25 where c1=10;
commit;
inc $DML_CNT;

begin;
insert into t8 values(10, 200, 3, 4);
update t1 set c2=26 where c1=10;
commit;
inc $DML_CNT;

begin;
insert into t9 values(10, 200, 3, 4);
update t1 set c2=27 where c1=10;
commit;
inc $DML_CNT;

begin;
insert into t10 values(10, 200, 3, 4);
update t1 set c2=28 where c1=10;
commit;
inc $DML_CNT;

let $idx = 1;
while ($idx <= $DML_CNT)
{
  ob1.oblog.next;
  inc $idx;
}

# stop liboblog
ob1.oblog.stop;

# 清理数据
--disable_warnings
drop database if exists oblog_db1;
