#
# owner:修铭
# owner group:liboblog
# description:
# 测试点：测试主键、唯一键信息准确性
##

ob1=OBI(cluster=1,init_unit_cpu=5);
ob1.force_stop;
ob1.clean_backup_dest;
ob1.reboot;
ob1.create_client;
source include/liboblog/create_tenant.inc;
# 清理环境
--disable_warnings
drop database if exists oblog_db;

let $record_cnt=0;
create database oblog_db;
use oblog_db;
CREATE TABLE `obschema_t_eq` ( `obschema_c_0_j57` tinyint(255) NOT NULL DEFAULT '1', PRIMARY KEY (`obschema_c_0_j57`), KEY `obschema_i_0_vPoBi` (`obschema_c_0_j57`) BLOCK_SIZE 16384 LOCAL, KEY `obschema_i_1_CdLL3Sc` (`obschema_c_0_j57`) BLOCK_SIZE 16384 LOCAL, KEY `obschema_i_2_Fplcu1` (`obschema_c_0_j57`) BLOCK_SIZE 16384 LOCAL);
let $mysql_tenant_name=oblog_tt;
let $original_conn=oblog_conn_tt;
source include/liboblog/enable_mysql_archive.inc;
ob1.z1.obs0.check_log_until_success -c "get_data_dict_meta_info";
use oblog_db;
let $start_tstamp_usec = query_get_value(select time_to_usec(now(6)) as now, now, 1);
# 启动liboblog
# 设置排序事务内参与者列表配置项为true，保证集群重启情况下，多分区事务语句顺序一致
ob1.oblog.gen_conf tb_white_list=oblog_tt.oblog_db.* log_level=TLOG.*:DEBUG skip_ob_version_compat_check=1;
ob1.oblog.restart;
sleep 10;
insert into obschema_t_eq values (1);
ob1.oblog.next;
inc $record_cnt;
# 无主键表
create table t1 (c1 int, c2 varchar(100));
ob1.oblog.next;
inc $record_cnt;

replace into t1 values (1, 1);
ob1.oblog.next;
inc $record_cnt;

replace into t1 values (2, 2);
ob1.oblog.next;
inc $record_cnt;

# 自增列
alter table t1 add column c3 int auto_increment;
ob1.oblog.next;
inc $record_cnt;

# 只更新一行，因为如果两行都更新
# 当后面 create unique index unique_index_c3_c2 on t1 (c3, c2); 因为唯一索引检查会失败
# 2.2分支索引生效为同步的, 即创建索引后检查直至生效, 死等到索引构建完成，返回其构建状态。
# 2.2分支之前索引为异步的, 需要用户或者测试case里面检查索引构建状态
update t1 set c2='I am what I am' where c1=1;
ob1.oblog.next;
inc $record_cnt;

# 增加索引
create index index_c1 on t1 (c1);
ob1.oblog.next;
inc $record_cnt;

replace into t1 (c1, c2) values (3, 3);
ob1.oblog.next;
inc $record_cnt;

create index index_c2 on t1 (c2);
ob1.oblog.next;
inc $record_cnt;

replace into t1 (c1, c2) values (4, 4);
ob1.oblog.next;
inc $record_cnt;

create index index_c3 on t1 (c3);
ob1.oblog.next;
inc $record_cnt;

replace into t1 (c1, c2) values (5, 5);
ob1.oblog.next;
inc $record_cnt;

# 增加唯一索引
create unique index unique_index_c1 on t1 (c1);
ob1.oblog.next;
inc $record_cnt;

replace into t1 (c1, c2) values (6, 6);
ob1.oblog.next;
inc $record_cnt;

create unique index unique_index_c1_c3 on t1 (c1, c3);
ob1.oblog.next;
inc $record_cnt;

replace into t1 (c1, c2) values (7, 7);
ob1.oblog.next;
inc $record_cnt;

create unique index unique_index_c1_c3_c2 on t1 (c1, c3, c2);
ob1.oblog.next;
inc $record_cnt;

replace into t1 (c1, c2) values (8, 8);
ob1.oblog.next;
inc $record_cnt;

create unique index unique_index_c2_c3_c1 on t1 (c2, c3, c1);
ob1.oblog.next;
inc $record_cnt;

replace into t1 (c1, c2) values (9, 9);
ob1.oblog.next;
inc $record_cnt;

create unique index unique_index_c3_c2 on t1 (c3, c2);
ob1.oblog.next;
inc $record_cnt;

replace into t1 (c1, c2) values (10, 10);
ob1.oblog.next;
inc $record_cnt;

# 有主键的表
create table t2 (c1 int, c2 varchar(100), c3 timestamp, c4 int, primary key(c4, c1, c3, c2));
ob1.oblog.next;
inc $record_cnt;
replace into t2 values (1, 1, '2018-4-17 16:00', 1);
ob1.oblog.next;
inc $record_cnt;

create index index_c3_c4 on t2(c3, c4);
ob1.oblog.next;
inc $record_cnt;
replace into t2 values (2, 2, '2018-4-17 16:00', 1);
ob1.oblog.next;
inc $record_cnt;

alter table t2 add column c5 int default 100;
ob1.oblog.next;
inc $record_cnt;

create unique index index_c5_c1 on t2(c5, c1);
ob1.oblog.next;
inc $record_cnt;

replace into t2 values (3, 3, '2019-4-17 16:00', 1, 1000);
ob1.oblog.next;
inc $record_cnt;

create unique index index_c3_c2_c1 on t2(c3, c2, c1);
ob1.oblog.next;
inc $record_cnt;

replace into t2 values (4, 4, '2020-4-17 16:00', 1, 2000);
ob1.oblog.next;
inc $record_cnt;

# 清理环境
ob1.oblog.stop;
drop table t1, t2;

# use data_dict + log_archive
ob1.oblog.set_start_tstamp_usec $start_tstamp_usec;
ob1.oblog.gen_conf tb_white_list=oblog_tt.*.* log_level=DEBUG fetching_log_mode=direct meta_data_refresh_mode=data_dict archive_dest=$log_backup_dest;
ob1.oblog.restart;
let $idx = 0;
while ($idx < $record_cnt)
{
  ob1.oblog.next;
  inc $idx;
}
ob1.oblog.stop;
# use data_dict + online log
ob1.oblog.set_start_tstamp_usec $start_tstamp_usec;
ob1.oblog.gen_conf tb_white_list=oblog_tt.*.* log_level=DEBUG meta_data_refresh_mode=data_dict;
ob1.oblog.restart;
let $idx = 0;
while ($idx < $record_cnt)
{
  ob1.oblog.next;
  inc $idx;
}
ob1.oblog.stop;
