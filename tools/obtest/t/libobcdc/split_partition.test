#
# owner: liujixiong.ljx
# owner group: ddl
# description: split partition
##

ob1=OBI(cluster=1, proxy_num=0, init_unit_cpu=1);
ob1.reboot;
sleep 2;

# 创建mysql租户oblog_tt，并且切换到mysql租户下
source include/liboblog/create_tenant_with_gts.inc;

# 启动liboblog，同步oblog_tt租户数据
ob1.oblog.gen_conf tb_white_list=oblog_tt.*.* log_level=DEBUG skip_ob_version_compat_check=1;
ob1.oblog.set_extra_argument -m;
ob1.oblog.restart;
sleep 10;

let $restart_ts_usec = query_get_value(select time_to_usec(now(6)) as now, now, 1);

let $ddl_stmt_count = 0;
let $dml_stmt_count = 0;

create database oblog_db1;
sleep 10;
ob1.oblog.next;
inc $ddl_stmt_count;

use oblog_db1;

create sequence seq_small INCREMENT BY 1 start with 1 minvalue 1 maxvalue 100000 nocycle noorder nocache;
ob1.oblog.next;
inc $ddl_stmt_count;
create sequence seq_large INCREMENT BY 1 start with 5001 minvalue 1 maxvalue 100000 nocycle noorder nocache;
ob1.oblog.next;
inc $ddl_stmt_count;

create table test_table(c1 bigint, c2 bigint, c3 longtext, primary key(c1))partition by range(c1) (partition p0 values less than (1), partition p1 values less than (10000), partition p2 values less than MAXVALUE);
ob1.oblog.next;
inc $ddl_stmt_count;

--disable_query_log
while($dml_stmt_count <= 20)
{
    insert into test_table select seq_small.nextval, random(1), randstr(10000, 123) from table(generator(1));
    ob1.oblog.next;
    inc $dml_stmt_count;
    insert into test_table select seq_large.nextval, random(1), randstr(10000, 123) from table(generator(1));
    ob1.oblog.next;
    inc $dml_stmt_count;
}
--enable_query_log

alter table test_table reorganize partition p1 into ( partition p1_0 values less than (5000), partition p1_1 values less than (10000));
ob1.oblog.next;
inc $ddl_stmt_count;

--disable_query_log
while($dml_stmt_count <= 40)
{
    insert into test_table select seq_small.nextval, random(1), randstr(10000, 123) from table(generator(1));
    ob1.oblog.next;
    inc $dml_stmt_count;
    insert into test_table select seq_large.nextval, random(1), randstr(10000, 123) from table(generator(1));
    ob1.oblog.next;
    inc $dml_stmt_count;
}
--enable_query_log

alter table test_table reorganize partition p1_1 into ( partition p1_1_0 values less than (5100), partition p1_1_1 values less than (10000));
ob1.oblog.next;
inc $ddl_stmt_count;

--disable_query_log
while($dml_stmt_count <= 60)
{
    insert into test_table select seq_small.nextval, random(1), randstr(10000, 123) from table(generator(1));
    ob1.oblog.next;
    inc $dml_stmt_count;
    insert into test_table select seq_large.nextval, random(1), randstr(10000, 123) from table(generator(1));
    ob1.oblog.next;
    inc $dml_stmt_count;
}
--enable_query_log

ob1.oblog.gen_conf tb_white_list=oblog_tt.*.* log_level=DEBUG skip_ob_version_compat_check=1;
ob1.oblog.set_extra_argument -m;
ob1.oblog.set_start_tstamp_usec $restart_ts_usec;
ob1.oblog.restart;
sleep 10;

let $stmt_count = $ddl_stmt_count + $dml_stmt_count;
let $idx = 0;
while ($idx < $stmt_count)
{
    ob1.oblog.next;
    inc $idx;
}

ob1.oblog.stop;

ob1.oblog.gen_conf tb_white_list=oblog_tt.*.* log_level=DEBUG meta_data_refresh_mode=data_dict skip_ob_version_compat_check=1;
ob1.oblog.set_extra_argument -m;
ob1.oblog.set_start_tstamp_usec $restart_ts_usec;
ob1.oblog.restart;
sleep 10;

let $stmt_count = $ddl_stmt_count + $dml_stmt_count;
let $idx = 0;
while ($idx < $stmt_count)
{
    ob1.oblog.next;
    inc $idx;
}

ob1.oblog.stop;

ob1.oblog.gen_conf tb_white_list=oblog_tt.*.* log_level=DEBUG meta_data_refresh_mode=data_dict skip_ob_version_compat_check=1;
ob1.oblog.set_extra_argument -m;
ob1.oblog.restart;
ob1.oblog.stop;
