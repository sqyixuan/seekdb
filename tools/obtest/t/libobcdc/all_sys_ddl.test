#
# owner:yanmu.ztl
# owner group:rs
# description:
# 测试点:
#     add/delete/start/stop/alter zone
#
##

ob1=OBI(cluster=1);
ob1.reboot;

# 准备环境
source include/liboblog/create_tenant.inc;

# 启动liboblog
ob1.oblog.gen_conf tb_white_list=sys.oblog*.*|oblog_tt.*.* skip_ob_version_compat_check=1;
ob1.oblog.restart;

# 创建database 1
create database oblog_db1;
ob1.oblog.next;

use oblog_db1;
# 创建表t1
create table oblog_db1.t1 (pk int primary key);
ob1.oblog.next;

# 插入一条数据
insert into oblog_db1.t1 values(1);
ob1.oblog.next;


# 2.测试add/delete/start/stop/alter zone,迭代出空语句
# sys租户下操作
connection oblog_conn_sys;

alter system add zone 'z2';

alter system start zone 'z2';

alter system modify zone 'z2' idc 'aa';

## 目前只读zone不检查server、replica数量
#alter system stop zone 'z2';
#alter system delete zone 'z2';

# 3.验证sys_ddl操作过后插入数据是否正常
connection oblog_conn_tt;
# 插入一条数据
insert into oblog_db1.t1 values(2);
ob1.oblog.next;

# 删除oblog_tt租户
connection oblog_conn_sys;
set @@recyclebin = off;
drop tenant oblog_tt force;
ob1.oblog.next;

# stop liboblog
ob1.oblog.stop;

# 清理数据
--disable_warnings
drop resource pool if exists oblog_pool;
--disable_warnings
drop resource unit if exists oblog_box;
--disable_warnings
drop database if exists oblog_db1;
--disable_warnings
drop database if exists oblog_db2;
