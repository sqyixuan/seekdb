#
# owner: fankun.fan
# owner group: libobcdc
# description: bitmap basic test
##

ob1=OBI(cluster=1,init_unit_cpu=5);
ob1.reboot;
ob1.create_client;

# 创建mysql租户oblog_tt，并且切换到mysql租户下
source include/liboblog/create_tenant_with_gts.inc;

# EMPTY
SET @p1 = x'0100';
SET @p1_after = x'01053a30000000000000';

# SINGLE_32: 1
SET @p2 = x'010101000000';
SET @p2_after = x'01053a3000000100000000000000100000000100';

# SINGLE_32: 2
SET @p3 = x'010102000000';
SET @p3_after = x'01053a3000000100000000000000100000000200';

# SINGLE_64: 1
SET @p4 = x'01020100000000000000';
SET @p4_after = x'01053a3000000100000000000000100000000100';

# SET_32: 1,2,3
SET @p5 = x'010303010000000200000003000000';
SET @p5_after = x'01053a300000010000000000020010000000010002000300';

# SET_32: 2,3,4
SET @p6 = x'010303020000000300000004000000';
SET @p6_after = x'01053a300000010000000000020010000000020003000400';

# SET_64: 4294967297,8589934593
SET @p7 = x'01040201000000010000000100000002000000';
SET @p7_after = x'01060200000000000000010000003a3000000100000000000000100000000100020000003a3000000100000000000000100000000100';

# BITMAP_32: 1
SET @p8 = x'01053a3000000100000000000000100000000100';
SET @p8_after = x'01053a3000000100000000000000100000000100';

# BITMAP_64: 0~32
SET @p9 = x'01060100000000000000000000003a30000001000000000020001000000000000100020003000400050006000700080009000a000b000c000d000e000f0010001100120013001400150016001700180019001a001b001c001d001e001f002000';
SET @p9_after = x'01060100000000000000000000003a30000001000000000020001000000000000100020003000400050006000700080009000a000b000c000d000e000f0010001100120013001400150016001700180019001a001b001c001d001e001f002000';

# BITMAP_64: 10~42
SET @p10 = x'01060100000000000000000000003a3000000100000000002000100000000a000b000c000d000e000f0010001100120013001400150016001700180019001a001b001c001d001e001f0020002100220023002400250026002700280029002a00';
SET @p10_after = x'01060100000000000000000000003a3000000100000000002000100000000a000b000c000d000e000f0010001100120013001400150016001700180019001a001b001c001d001e001f0020002100220023002400250026002700280029002a00';

create database oblog_db1;

use oblog_db1;

--disable_query_log
--disable_result_log
create table tmp(c1 int, c2 text);
insert into tmp values(1, '1');
let $idx = 2;
while ($idx < 4001)
{
  eval update tmp set c2 = concat(c2, ',$idx');
  inc $idx;
}
--enable_result_log
--enable_query_log

# outrow lob
# 1,2,3,...4000
let $p11 = `select c2 from tmp where c1=1`;

# 启动liboblog，同步oblog_tt租户数据
ob1.oblog.gen_conf tb_white_list=oblog_tt.*.* log_level=DEBUG skip_ob_version_compat_check=1;
ob1.oblog.set_extra_argument -x;
ob1.oblog.restart;

CREATE TABLE t1 (k int, rb roaringbitmap);
ob1.oblog.next;

# NULL
INSERT INTO t1 VALUES (0, NULL);
ob1.oblog.next;

@p1
INSERT INTO t1 VALUES (1, @p1);
ob1.oblog.next;
select rb_to_string(rb_build_varbinary(@p1_after));

@p2
INSERT INTO t1 VALUES (2, @p2);
ob1.oblog.next;
select rb_to_string(rb_build_varbinary(@p2_after));

@p3
INSERT INTO t1 VALUES (3, @p3);
ob1.oblog.next;
select rb_to_string(rb_build_varbinary(@p3_after));

@p4
INSERT INTO t1 VALUES (4, @p4);
ob1.oblog.next;
select rb_to_string(rb_build_varbinary(@p4_after));

@p5
INSERT INTO t1 VALUES (5, @p5);
ob1.oblog.next;
select rb_to_string(rb_build_varbinary(@p5_after));

@p6
INSERT INTO t1 VALUES (6, @p6);
ob1.oblog.next;
select rb_to_string(rb_build_varbinary(@p6_after));

@p7
INSERT INTO t1 VALUES (7, @p7);
ob1.oblog.next;
select rb_to_string(rb_build_varbinary(@p7_after));

@p8
INSERT INTO t1 VALUES (8, @p8);
ob1.oblog.next;
select rb_to_string(rb_build_varbinary(@p8_after));

@p9
INSERT INTO t1 VALUES (9, @p9);
ob1.oblog.next;
select rb_to_string(rb_build_varbinary(@p9_after));

@p10
INSERT INTO t1 VALUES (10, @p10);
ob1.oblog.next;
select rb_to_string(rb_build_varbinary(@p10_after));

DELETE FROM t1 where k=0;
ob1.oblog.next;

UPDATE t1 set rb=@p2 where k=1;
ob1.oblog.next;

DELETE FROM t1 where k<=2;
ob1.oblog.next;

UPDATE t1 set rb=@p7;
ob1.oblog.next;

CREATE TABLE t2 (k int, rb roaringbitmap) LOB_INROW_THRESHOLD=4;
ob1.oblog.next;

# NULL
INSERT INTO t2 VALUES (0, NULL);
ob1.oblog.next;

@p1
INSERT INTO t2 VALUES (1, @p1);
ob1.oblog.next;
select rb_to_string(rb_build_varbinary(@p1_after));

@p2
INSERT INTO t2 VALUES (2, @p2);
ob1.oblog.next;
select rb_to_string(rb_build_varbinary(@p2_after));

@p3
INSERT INTO t2 VALUES (3, @p3);
ob1.oblog.next;
select rb_to_string(rb_build_varbinary(@p3_after));

@p4
INSERT INTO t2 VALUES (4, @p4);
ob1.oblog.next;
select rb_to_string(rb_build_varbinary(@p4_after));

@p5
INSERT INTO t2 VALUES (5, @p5);
ob1.oblog.next;
select rb_to_string(rb_build_varbinary(@p5_after));

@p6
INSERT INTO t2 VALUES (6, @p6);
ob1.oblog.next;
select rb_to_string(rb_build_varbinary(@p6_after));

@p7
INSERT INTO t2 VALUES (7, @p7);
ob1.oblog.next;
select rb_to_string(rb_build_varbinary(@p7_after));

@p8
INSERT INTO t2 VALUES (8, @p8);
ob1.oblog.next;
select rb_to_string(rb_build_varbinary(@p8_after));

@p9
INSERT INTO t2 VALUES (9, @p9);
ob1.oblog.next;
select rb_to_string(rb_build_varbinary(@p9_after));

@p10
INSERT INTO t2 VALUES (10, @p10);
ob1.oblog.next;
select rb_to_string(rb_build_varbinary(@p10_after));

ob1.oblog.stop;

# 启动liboblog，同步oblog_tt租户数据
ob1.oblog.gen_conf tb_white_list=oblog_tt.*.* log_level=DEBUG skip_ob_version_compat_check=1;
ob1.oblog.set_extra_argument -x -m;
ob1.oblog.restart;

eval INSERT INTO t1 VALUES(11, rb_from_string('$p11'));
ob1.oblog.next;

select md5(rb_to_varbinary(rb, 'roaring')) from t1 where k=11;

ob1.oblog.stop;
