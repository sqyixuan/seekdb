#
# owner: debin.jdb
# owner group: clog
# description:
# 测试点: 测试minimal模式下各类table执行dml产生clog内容是否符合预期.
# 1. 1.1 无主键表, 无唯一键, update要记全列
#    1.2 无主键表, 有唯一键(允许为空), update需要记全列
#    1.3 无主键表, 有非空唯一键, update不需要记全列
# 2. 2.1 主键表, 无唯一键
#    2.2 主键表, 有唯一键
# 3. table包含时间列场景：date/datetime/time/timestamp.
#

ob1=OBI(cluster=1,init_unit_cpu=5);
ob1.reboot;
ob1.create_client;

# 创建mysql租户oblog_tt，并且切换到mysql租户下
source include/liboblog/create_tenant_with_gts.inc;

# 切换为minimal模式
set binlog_row_image='MINIMAL';
show variables like "binlog_row_image";

# 启动liboblog，同步oblog_tt租户数据
ob1.oblog.gen_conf tb_white_list=oblog_tt.*.* log_level=DEBUG skip_ob_version_compat_check=1 skip_dirty_data=1;
ob1.oblog.restart;

# 创建database 1
create database oblog_db1;
# 输出create database DDL
ob1.oblog.next;

use oblog_db1;

# 1.1 创建表t1, 不带uk, old_row预期要记全列
create table t1(id int, c1 timestamp(6), c2 datetime, c3 time, c4 date, c5 int NOT NULL, c6 varchar(64), c7 bigint);
# 输出create table DDL
ob1.oblog.next;
# 执行AC=1的insert
insert into t1 values(1, '2023-10-13 12:10:08.123456', '2023-10-30 12:00:00', '01:30:15.123', '2023-09-30', 1, 't1', 111);
# 输出上述事务
ob1.oblog.next;
# 执行update
update t1 set id=2 where id=1;
ob1.oblog.next;
# 执行update
update t1 set c1='2023-10-13 12:10:58.678' where id=2;
ob1.oblog.next;
update t1 set c2='2023-11-13 12:10:58.678' where id=2;
ob1.oblog.next;
update t1 set c3='12:10:58.678' where id=2;
ob1.oblog.next;
update t1 set c4='2023-11-15' where id=2;
ob1.oblog.next;
update t1 set c5=15 where id=2;
ob1.oblog.next;
update t1 set c6='t11' where id=2;
ob1.oblog.next;
update t1 set c7=17 where id=2;
ob1.oblog.next;
delete from t1 where id=2;
ob1.oblog.next;

# 1.2 创建表t2, 无非空uk, old_row预期要记全列
create table t2(id int, c1 timestamp(6), c2 datetime, c3 time, c4 date, c5 int, c6 varchar(64), c7 bigint, c8 int UNIQUE, CONSTRAINT cons_1 UNIQUE(c5, c7));
# 输出create table DDL
ob1.oblog.next;
# 执行AC=1的DML事务
insert into t2 values(1, '2023-10-13 12:10:08.123456', '2023-10-30 12:00:00', '01:30:15.123', '2023-09-30', 1, 't2', 111, 11);
# 输出上述事务
ob1.oblog.next;
# 执行update普通列（非pk/uk）
update t2 set id=2 where id=1;
ob1.oblog.next;
update t2 set c1='2023-10-13 12:10:58.678' where id=2;
ob1.oblog.next;
update t2 set c2='2023-11-13 12:10:58.678' where id=2;
ob1.oblog.next;
update t2 set c3='12:10:58.678' where id=2;
ob1.oblog.next;
update t2 set c4='2023-11-15' where id=2;
ob1.oblog.next;
# 执行update uk
update t2 set c5=25 where id=2;
ob1.oblog.next;
# 执行update普通列
update t2 set c6='t23' where id=2;
ob1.oblog.next;
# 执行update uk
update t2 set c7=27 where id=2;
ob1.oblog.next;
update t2 set c8=28 where id=2;
ob1.oblog.next;
delete from t2 where id=2;
ob1.oblog.next;

# 1.3 创建表t3, 带非空uk, old_row预期不需要记全列
create table t3(id int, c1 timestamp(6), c2 datetime, c3 time, c4 date, c5 int NOT NULL, c6 varchar(64), c7 bigint NOT NULL, UNIQUE(c5, c7));
# 输出create table DDL
ob1.oblog.next;
# 执行AC=1的DML事务
insert into t3 values(1, '2023-10-13 12:10:08.123456', '2023-10-30 12:00:00', '01:30:15.123', '2023-09-30', 1, 't3', 111);
# 输出上述事务
ob1.oblog.next;
# 执行update普通列（非pk/uk）
update t3 set id=2 where id=1;
ob1.oblog.next;
update t3 set c1='2023-10-13 12:10:58.678' where id=2;
ob1.oblog.next;
update t3 set c2='2023-11-13 12:10:58.678' where id=2;
ob1.oblog.next;
update t3 set c3='12:10:58.678' where id=2;
ob1.oblog.next;
update t3 set c4='2023-11-15' where id=2;
ob1.oblog.next;
# 执行update uk
update t3 set c5=35 where id=2;
ob1.oblog.next;
# 执行update普通列
update t3 set c6='t32' where id=2;
ob1.oblog.next;
# 执行update uk
update t3 set c7=37 where id=2;
ob1.oblog.next;
delete from t3 where id=2;
ob1.oblog.next;

# 1.4 创建表t31, uk中包含非空列c5和nullable列c7, old_row预期需要记全列
create table t31(id int, c1 timestamp(6), c2 datetime, c3 time, c4 date, c5 int NOT NULL, c6 varchar(64), c7 bigint, UNIQUE(c5, c7));
# 输出create table DDL
ob1.oblog.next;
# 执行AC=1的DML事务
insert into t31 values(1, '2023-10-13 12:10:08.123456', '2023-10-30 12:00:00', '01:30:15.123', '2023-09-30', 1, 't31', 111);
# 输出上述事务
ob1.oblog.next;
# 执行update普通列（非pk/uk）
update t31 set id=2 where id=1;
ob1.oblog.next;
update t31 set c1='2023-10-13 12:10:58.678' where id=2;
ob1.oblog.next;
update t31 set c2='2023-11-13 12:10:58.678' where id=2;
ob1.oblog.next;
update t31 set c3='12:10:58.678' where id=2;
ob1.oblog.next;
update t31 set c4='2023-11-15' where id=2;
ob1.oblog.next;
# 执行update uk
update t31 set c5=35 where id=2;
ob1.oblog.next;
# 执行update普通列
update t31 set c6='t32' where id=2;
ob1.oblog.next;
# 执行update uk
update t31 set c7=37 where id=2;
ob1.oblog.next;
delete from t31 where id=2;
ob1.oblog.next;

# 1.5 创建表t32, 带多个uk, 其中有非空uk, old_row预期不需要记全列
create table t32(id int, c1 timestamp(6), c2 datetime, c3 time, c4 date, c5 int NOT NULL, c6 varchar(64), c7 bigint NOT NULL, c8 int, UNIQUE(c5, c7), UNIQUE(c8));
# 输出create table DDL
ob1.oblog.next;
# 执行AC=1的DML事务
insert into t32 values(1, '2023-10-13 12:10:08.123456', '2023-10-30 12:00:00', '01:30:15.123', '2023-09-30', 1, 't32', 111, 888);
# 输出上述事务
ob1.oblog.next;
# 执行update普通列（非pk/uk）
update t32 set id=2 where id=1;
ob1.oblog.next;
update t32 set c1='2023-10-13 12:10:58.678' where id=2;
ob1.oblog.next;
update t32 set c2='2023-11-13 12:10:58.678' where id=2;
ob1.oblog.next;
update t32 set c3='12:10:58.678' where id=2;
ob1.oblog.next;
update t32 set c4='2023-11-15' where id=2;
ob1.oblog.next;
# 执行update uk
update t32 set c5=35 where id=2;
ob1.oblog.next;
# 执行update普通列
update t32 set c6='t32' where id=2;
ob1.oblog.next;
# 执行update uk
update t32 set c7=37 where id=2;
ob1.oblog.next;
delete from t32 where id=2;
ob1.oblog.next;

# 2.1 创建主键表t4, 不带uk
create table t4(id int PRIMARY KEY, c1 timestamp(6), c2 datetime, c3 time, c4 date, c5 int NOT NULL, c6 varchar(64), c7 bigint);
ob1.oblog.next;
# 执行AC=1的insert
insert into t4 values(1, '2023-10-13 12:10:08.123456', '2023-10-30 12:00:00', '01:30:15.123', '2023-09-30', 1, 't4', 111);
# 输出上述事务
ob1.oblog.next;
# 执行update
update t4 set c1='2023-10-13 12:10:58.678' where id=1;
ob1.oblog.next;
update t4 set c2='2023-11-13 12:10:58.678' where id=1;
ob1.oblog.next;
update t4 set c3='12:10:58.678' where id=1;
ob1.oblog.next;
update t4 set c4='2023-11-15' where id=1;
ob1.oblog.next;
update t4 set c5=45 where id=1;
ob1.oblog.next;
update t4 set c6='t44' where id=1;
ob1.oblog.next;
update t4 set c7=47 where id=1;
ob1.oblog.next;
update t4 set id=2 where id=1;
ob1.oblog.next;
delete from t4 where id=2;
ob1.oblog.next;

# 2.2 创建主键表t5, 无非空uk
create table t5(id int PRIMARY KEY, c1 timestamp(6), c2 datetime, c3 time, c4 date, c5 int, c6 varchar(64), c7 bigint, c8 int UNIQUE, CONSTRAINT cons_1 UNIQUE(c5, c7));
# 输出create table DDL
ob1.oblog.next;
# 执行AC=1的DML事务
insert into t5 values(1, '2023-10-13 12:10:08.123456', '2023-10-30 12:00:00', '01:30:15.123', '2023-09-30', 1, 't5', 111, 11);
# 输出上述事务
ob1.oblog.next;
# 执行update普通列（非pk/uk）
update t5 set id=2 where id=1;
ob1.oblog.next;
update t5 set c1='2023-10-13 12:10:58.678' where id=2;
ob1.oblog.next;
update t5 set c2='2023-11-13 12:10:58.678' where id=2;
ob1.oblog.next;
update t5 set c3='12:10:58.678' where id=2;
ob1.oblog.next;
update t5 set c4='2023-11-15' where id=2;
ob1.oblog.next;
# 执行update uk
update t5 set c5=55 where id=2;
ob1.oblog.next;
# 执行update普通列
update t5 set c6='t55' where id=2;
ob1.oblog.next;
# 执行update uk
update t5 set c7=57 where id=2;
ob1.oblog.next;
update t5 set c8=58 where id=2;
ob1.oblog.next;
delete from t5 where id=2;
ob1.oblog.next;

# 执行drop table DDL
drop table t1;
ob1.oblog.next;

# 执行drop table DDL
drop table t2;
ob1.oblog.next;

# 执行drop table DDL
drop table t3;
ob1.oblog.next;

# 执行drop table DDL
drop table t4;
ob1.oblog.next;

# 执行drop table DDL
drop table t5;
ob1.oblog.next;

# stop liboblog
ob1.oblog.stop;
