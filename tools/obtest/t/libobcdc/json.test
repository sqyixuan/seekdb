#
# owner:千溪
# owner group:liboblog
# description:
# test:
# JSON
#
##

ob1=OBI(cluster=1,init_unit_cpu=5);
ob1.reboot;
ob1.create_client;

# 准备环境
let $ip=deploy_get_value(ob1.proxy0.ip);
let $port=deploy_get_value(ob1.proxy0.port);
connect (oblog_conn_sys,$ip,admin@sys,admin,oceanbase,$port);

connection oblog_conn_sys;

--disable_warnings
drop tenant if exists oblog_tt;
--disable_warnings
drop resource pool if exists oblog_pool;
--disable_warnings
drop resource unit if exists oblog_box;
--disable_warnings
drop database if exists oblog_db1;

# Operate under the obtest tenant
connect (oblog_conn_tt,$ip,root@obtest,,oceanbase,$port);
connection oblog_conn_tt;

connection oblog_conn_tt;
# 设置最大包大小 1G
set global max_allowed_packet=1073741824;

connection oblog_conn_tt;

# 设置事务超时时间: 100秒
set ob_trx_timeout=100000000;
set ob_default_lob_inrow_threshold=4096;

# start obcdc
ob1.oblog.set_extra_argument -m;
ob1.oblog.gen_conf tb_white_list=sys.oblog*.*|obtest.*.* log_level=DEBUG skip_ob_version_compat_check=1;
ob1.oblog.restart;

# create database
create database oblog_db1;
ob1.oblog.next;

use oblog_db1;
CREATE TABLE t (b BIT(8));
ob1.oblog.next;

INSERT INTO t SET b = b'11111111';
ob1.oblog.next;

CREATE TABLE t1(pk int primary key, json_col_1 JSON);
ob1.oblog.next;

# inrow
SET @a:=CONCAT('[',REPEAT('"a",',2),'"a"]');
SELECT JSON_TYPE(@a), LENGTH(@a), LENGTH(@a)*3;
INSERT INTO t1 VALUES(1, @a);
select md5(json_col_1) from t1 where pk = 1;
ob1.oblog.next;

# inrow
SET @a:=CONCAT('[',REPEAT('"a",',5),'"a"]');
SELECT JSON_TYPE(@a), LENGTH(@a), LENGTH(@a)*3;
INSERT INTO t1 VALUES(2, @a);
select md5(json_col_1) from t1 where pk = 2;
ob1.oblog.next;

# insert outrow
SET @a:=CONCAT('[',REPEAT('"a",',200000),'"a"]');
SELECT JSON_TYPE(@a), LENGTH(@a), LENGTH(@a)*3;
INSERT INTO t1 VALUES(3, @a);
select md5(json_col_1) from t1 where pk = 3;
ob1.oblog.next;

# update outrow -> outrow
SET @b:=CONCAT('[',REPEAT('"b",',200000),'"b"]');
update t1 set json_col_1 = @b;
select md5(json_col_1) from t1 where pk = 3;
ob1.oblog.next;

# update outrow -> inrow
SET @a:=CONCAT('[',REPEAT('"a",',5),'"a"]');
update t1 set json_col_1 = @a where pk=3;
select md5(json_col_1) from t1 where pk = 3;
ob1.oblog.next;

# update inrow -> inrow
SET @a:=CONCAT('[',REPEAT('"a",',6),'"a"]');
update t1 set json_col_1 = @a where pk=3;
select md5(json_col_1) from t1 where pk = 3;
ob1.oblog.next;

# update inrow -> outrow
SET @a:=CONCAT('[',REPEAT('"a",',200000),'"a"]');
update t1 set json_col_1 = @a where pk=3;
select md5(json_col_1) from t1 where pk = 3;
ob1.oblog.next;

# update rowkey
insert into t1 values(30001, CONCAT('{"K1": "', REPEAT('x', 4096),'"}'));
select md5(json_col_1) from t1 where pk = 30001;
ob1.oblog.next;
update t1 set pk = 30002 where pk = 30001;
ob1.oblog.next;
delete from t1 where pk = 30002;
ob1.oblog.next;

# delete
delete from t1;
ob1.oblog.next;

CREATE TABLE t2(pk int primary key, json_col_1 JSON, json_col_2 JSON, json_col_3 JSON, json_col_4 JSON);
ob1.oblog.next;

# insert all inrow
SET @a:=CONCAT('[',REPEAT('"a",',5),'"a"]');
INSERT INTO t2 VALUES(1, @a, @a, @a, @a);
select md5(json_col_1), md5(json_col_2), md5(json_col_3), md5(json_col_4) from t2 where pk = 1;
ob1.oblog.next;

# insert all outrow
SET @a:=CONCAT('[',REPEAT('"c",',200000),'"c"]');
INSERT INTO t2 VALUES(2, @a, @a, @a, @a);
select md5(json_col_1), md5(json_col_2), md5(json_col_3), md5(json_col_4) from t2 where pk = 2;
ob1.oblog.next;

# update outrow -> outrow
SET @a:=CONCAT('[',REPEAT('"d",',200000),'"d"]');
update t2 set json_col_1 = @a, json_col_3 = @a where pk=2;
select md5(json_col_1), md5(json_col_2), md5(json_col_3), md5(json_col_4) from t2 where pk = 2;
ob1.oblog.next;

# update outrow -> inrow
SET @a:=CONCAT('[',REPEAT('"e",',5),'"e"]');
update t2 set json_col_1 = @a, json_col_3 = @a where pk=2;
select md5(json_col_1), md5(json_col_2), md5(json_col_3), md5(json_col_4) from t2 where pk = 2;
ob1.oblog.next;

# update inrow -> outrow
SET @a:=CONCAT('[',REPEAT('"f",',200000),'"f"]');
update t2 set json_col_1 = @a, json_col_3 = @a where pk=2;
select md5(json_col_1), md5(json_col_2), md5(json_col_3), md5(json_col_4) from t2 where pk = 2;
ob1.oblog.next;

delete from t2;
ob1.oblog.next;

# stop libobcdc
ob1.oblog.stop;
