#
# owner:千溪
# owner group:liboblog
# description:
# 测试点:
#   全局索引测试
#   1. 分区添加测试:
#      (1) 创建主表(携带普通/唯一索引)
#      (2) 创建主表后, 再创建全局普通/唯一索引
#   2. 启动时刻添加所有全局索引分区
#   3. 分区删除测试:
#      (1) 删除全局索引
#      (2) 删除主表
#      (3) 删除DB
#      (4) 删除租户
#
#  本case测试：
#  1. 分区添加
#  2. 分区删除各种场景
#
##

ob1=OBI(cluster=1);
ob1.reboot;
ob1.create_client;

# 准备环境
let $ip=deploy_get_value(ob1.proxy0.ip);
let $port=deploy_get_value(ob1.proxy0.port);
connect (oblog_conn_sys,$ip,admin@sys,admin,oceanbase,$port);
connection oblog_conn_sys;

--disable_warnings
drop tenant if exists oblog_tt;
--disable_warnings
drop resource pool if exists oblog_pool;
--disable_warnings
drop resource unit if exists oblog_box;

source include/liboblog/create_tenant_with_gts.inc;

--disable_warnings
drop database if exists oblog_db1;

ob1.oblog.gen_conf tb_white_list=sys.*.*|oblog_tt.oblog_db1.* sort_trans_participants=1 skip_ob_version_compat_check=1;
ob1.oblog.restart;

# 创建database
create database oblog_db1;
ob1.oblog.next;
use oblog_db1;

################################ 1. 分区添加测试
# 全局索引建表
source include/liboblog/global_index/global_index_create_table.inc;

set @@recyclebin = off;

################################ 2. 分区删除
################################ (1) 删除全局索引

# 删除全局普通索引
drop index g_normal_key_t3 on t3;
ob1.oblog.next;
drop index g_normal_key_t4 on t4;
ob1.oblog.next;
drop index g_normal_key_t5 on t5;
ob1.oblog.next;
drop index g_normal_key_t6 on t6;
ob1.oblog.next;

drop index g_unique_gkey_t7 on t7;
ob1.oblog.next;
drop index g_unique_gkey_t8 on t8;
ob1.oblog.next;
drop index g_unique_gkey_t9 on t9;
ob1.oblog.next;
drop index g_unique_gkey_t10 on t10;
ob1.oblog.next;

drop database oblog_db1;
ob1.oblog.next;

################################ (2) 删除主表
# 创建database
create database oblog_db1;
ob1.oblog.next;
use oblog_db1;

# 全局索引建表
source include/liboblog/global_index/global_index_create_table.inc;

let $TABLE_NUMBER = 10;
let $i = 1;
while ($i <= $TABLE_NUMBER)
{
  eval drop table t$i;
  ob1.oblog.next;
  inc $i;
}

drop database oblog_db1;
ob1.oblog.next;

################################ (3) 删除DB
# 创建database
create database oblog_db1;
ob1.oblog.next;
use oblog_db1;

# 全局索引建表
source include/liboblog/global_index/global_index_create_table.inc;

drop database oblog_db1;
ob1.oblog.next;

################################ (4) 删除租户
# 创建database
create database oblog_db1;
ob1.oblog.next;
use oblog_db1;

# 全局索引建表
source include/liboblog/global_index/global_index_create_table.inc;

connection oblog_conn_sys;
drop tenant oblog_tt;
ob1.oblog.next;

# stop liboblog
ob1.oblog.stop;

# 清理数据
--disable_warnings
drop database if exists oblog_db1;
