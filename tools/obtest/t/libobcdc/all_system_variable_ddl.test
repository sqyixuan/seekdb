#
# owner:千溪
# owner group:liboblog
# description:
# 测试点:
#   1. 同步__all_sys_variable, 系统变量会设置到_all_ddl_operation
#   2. date_type: 5(ObIntType) 10(ObUInt64Type) 15(ObNumberType) 22(ObVarcharType)
#      其中15是session级别num类型，不能global设置，不测试
#
##

ob1=OBI(cluster=1, init_unit_cpu=5);
ob1.reboot;
ob1.create_client;

# 准备环境
source include/liboblog/create_tenant.inc;

# 启动liboblog
ob1.oblog.gen_conf tb_white_list=sys.oblog*.*|oblog_tt.*.* skip_ob_version_compat_check=1;
ob1.oblog.restart;

# 2. sys租户下操作
connection oblog_conn_sys;

# data_type = 5
set global read_only = 1;
ob1.oblog.next;
set global read_only = 0;
ob1.oblog.next;
set global read_only = true;
ob1.oblog.next;
set global read_only = false;
ob1.oblog.next;
set global read_only = on;
ob1.oblog.next;
set global read_only = off;
ob1.oblog.next;

set global explicit_defaults_for_timestamp = off;
ob1.oblog.next;
set global explicit_defaults_for_timestamp = on;
ob1.oblog.next;

set global max_allowed_packet = 1073741824;
ob1.oblog.next;
set global max_allowed_packet = default;
ob1.oblog.next;

set global net_buffer_length = 2048;
ob1.oblog.next;
set global net_buffer_length = default;
ob1.oblog.next;

set global ob_enable_transmission_checksum=OFF;
ob1.oblog.next;
set global ob_enable_transmission_checksum=ON;
ob1.oblog.next;

# data_type = 10
set global auto_increment_increment = 5;
ob1.oblog.next;
set global auto_increment_increment = default;
ob1.oblog.next;

set global max_user_connections = 100000;
ob1.oblog.next;
set global max_user_connections = default;
ob1.oblog.next;

# data_type = 22
set global time_zone = '+12:00';
ob1.oblog.next;

# 3. 在oblog_tt租户下操作
connect (oblog_conn_tt,$ip,root@oblog_tt,,oceanbase,$port);
connection oblog_conn_tt;

# data_type = 5
set global read_only = 1;
ob1.oblog.next;
set global read_only = 0;
ob1.oblog.next;
set global read_only = true;
ob1.oblog.next;
set global read_only = false;
ob1.oblog.next;
set global read_only = on;
ob1.oblog.next;
set global read_only = off;
ob1.oblog.next;

set global explicit_defaults_for_timestamp = off;
ob1.oblog.next;
set global explicit_defaults_for_timestamp = on;
ob1.oblog.next;

set global max_allowed_packet = 1073741824;
ob1.oblog.next;
set global max_allowed_packet = default;
ob1.oblog.next;

set global net_buffer_length = 2048;
ob1.oblog.next;
set global net_buffer_length = default;
ob1.oblog.next;

set global ob_enable_transmission_checksum=OFF;
ob1.oblog.next;
set global ob_enable_transmission_checksum=ON;
ob1.oblog.next;

# data_type = 10
set global auto_increment_increment = 5;
ob1.oblog.next;
set global auto_increment_increment = default;
ob1.oblog.next;

set global max_user_connections = 100000;
ob1.oblog.next;
set global max_user_connections = default;
ob1.oblog.next;

# data_type = 22
 set global time_zone = '+12:00';
 ob1.oblog.next;

## 删除oblog_tt租户
connection oblog_conn_sys;
drop tenant oblog_tt;
ob1.oblog.next;

# stop liboblog
ob1.oblog.stop;
