#
# owner:千溪
# owner group:liboblog
# description:
# 测试点:
#  测试BEGIN binlogrecord transID
#
##

ob1=OBI(cluster=1,init_unit_cpu=5);
ob1.reboot;
ob1.create_client;

# 准备环境
source include/liboblog/create_tenant_with_gts.inc;

# 启动liboblog
ob1.oblog.gen_conf tb_white_list=sys.oblog*.*|oblog_tt.*.* sort_trans_participants=1 log_level=DEBUG skip_ob_version_compat_check=1;
ob1.oblog.set_extra_argument -P;
ob1.oblog.restart;

# 创建database 1
create database oblog_db1;
ob1.oblog.next;

use oblog_db1;
CREATE TABLE t (b BIT(8));
ob1.oblog.next;

CREATE TABLE t1 (c1 int primary key, c2 int);
ob1.oblog.next;

INSERT INTO t SET b = b'11111111';
ob1.oblog.next;

INSERT INTO t SET b = b'1010';
ob1.oblog.next;

INSERT INTO t SET b = b'1111';
ob1.oblog.next;

begin;
INSERT INTO t SET b = b'11111111';
INSERT INTO t1 values(1, 2);
commit;
ob1.oblog.next;

# stop liboblog
ob1.oblog.stop;
