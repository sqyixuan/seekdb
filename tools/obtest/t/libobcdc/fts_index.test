#
# owner: yunshan.tys
# owner group: liboblog
# description:
# 测试点:
#  fulltext search index
##

ob1=OBI(cluster=1,init_unit_cpu=5);
ob1.reboot;
ob1.create_client;

ob1.mysql alter system set _enable_add_fulltext_index_to_existing_table = true;

# 创建mysql租户oblog_tt，并且切换到mysql租户下
source include/liboblog/create_tenant_with_gts.inc;

# 启动liboblog，同步oblog_tt租户数据
ob1.oblog.gen_conf tb_white_list=oblog_tt.*.* log_level=DEBUG;
ob1.oblog.restart;

# 创建database 1
create database oblog_fts;
# 输出create database DDL
ob1.oblog.next;

use oblog_fts;

# 创建带全文索引的表
create table articles (title VARCHAR(200) primary key, body Text, FULLTEXT fts_idx(title, body));
# 输出create table DDL
ob1.oblog.next;

# 执行AC=1的DML事务
insert into articles(title, body) values
  ('OceanBase Tutorial', 'This is a tutorial about OceanBase Fulltext.'),
  ('Fulltext Index', 'Fulltext index can be very useful.'),
  ('OceanBase Test Case', 'Writing test cases helps ensure quality.');
# 输出上述事务
ob1.oblog.next;

update articles set title = 'OceanBase' where title = 'OceanBase Tutorial';
ob1.oblog.next;

delete from articles where title = 'OceanBase';
ob1.oblog.next;

# 执行drop table DDL
drop table articles;
# 输出drop table DDL
ob1.oblog.next;

create table articles2 (title VARCHAR(200) primary key, body Text);
ob1.oblog.next;

insert into articles2(title, body) values
  ('OceanBase Tutorial', 'This is a tutorial about OceanBase Fulltext.'),
  ('Fulltext Index', 'Fulltext index can be very useful.'),
  ('OceanBase Test Case', 'Writing test cases helps ensure quality.');
ob1.oblog.next;

create fulltext index fts_idx on articles2(title, body);
ob1.oblog.next;

alter table articles2 add fulltext index fts_idx2(title);
ob1.oblog.next;

drop index fts_idx on articles2;
ob1.oblog.next;

drop table articles2;
ob1.oblog.next;

create table czt_coupon_main_body (coupon_body_id bigint unsigned not null auto_increment, coupon_name varchar(60) not null default '', extra_contains json not null, primary key (coupon_body_id), key contain_store_ids_index ((cast(json_extract(extra_contains,'$.contain_store_ids') as unsigned array))));
ob1.oblog.next;

insert into czt_coupon_main_body (coupon_name, extra_contains) values
('优惠券A', '{"contain_store_ids": [1000010001, 1000010002, 1000010003]}'),
('优惠券B', '{"contain_store_ids": [2000010001, 2000010002, 2000010003]}');
ob1.oblog.next;

drop table czt_coupon_main_body;
ob1.oblog.next;

# set系统变量不会生成redo日志，不需要迭代数据
set @@time_zone = '+06:00';
create table cdc_tb(a binary(8));
ob1.oblog.next;
insert into cdc_tb values('a'),('b');
ob1.oblog.next;

# stop liboblog
ob1.oblog.stop;
