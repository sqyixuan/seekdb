#
# owner: gehao
# owner group: liboblog
# description:
# 测试点:
#  geometry
##

ob1=OBI(cluster=1,init_unit_cpu=5);
ob1.reboot;
ob1.create_client;

# 创建mysql租户oblog_gis，并且切换到mysql租户下
--disable_result_log
source include/liboblog/create_tenant_with_srs.inc;
--enable_result_log

# 启动liboblog，同步oblog_gis租户数据
ob1.oblog.gen_conf tb_white_list=oblog_gis.*.* log_level=DEBUG skip_ob_version_compat_check=1;
ob1.oblog.restart;

# 创建database 1
create database oblog_db1;
# 输出create database DDL
ob1.oblog.next;

use oblog_db1;

# 测试geometry列不带任何限制
create table t1(id int, g1 geometry);
# 输出create table DDL
ob1.oblog.next;

# point
insert into t1 values(1, ST_GeomFromText('Point(1 2)'));
# 输出上述事务
ob1.oblog.next;
insert into t1 values(2, ST_GeomFromText('Point(0 0)'));
ob1.oblog.next;
insert into t1 values(3, ST_GeomFromText('POINT(-1234 +5678)'));
ob1.oblog.next;
insert into t1 values(4, ST_GeomFromText('POINT(25.416666666666668 25.416666666666668)'));
ob1.oblog.next;
insert into t1 values(5, ST_GeomFromText('POINT(1e8 -23e4)'));
ob1.oblog.next;
# LineString
insert into t1 values(6, ST_GeomFromText('LINESTRING(0 0,10 10)'));
ob1.oblog.next;
insert into t1 values(7, ST_GeomFromText('LINESTRING(0 0,-4 8, 2000 2000)'));
ob1.oblog.next;
# Polygon
insert into t1 values(8, ST_GeomFromText('Polygon((0 0, 0 8, 8 8, 8 10, -10 10, -10 0, 0 0))'));
ob1.oblog.next;
# MultiPoint
insert into t1 values(9, ST_GeomFromText('MULTIPOINT(1 1, 11 11, 11 21, 21 21)'));
ob1.oblog.next;
insert into t1 values(10, ST_GeomFromText('MULTIPOINT((0 0),(10 10),(10 20),(20 20))'));
ob1.oblog.next;
# MultiLineString
insert into t1 values(11, ST_GeomFromText('MULTILINESTRING((10 48,10 21,10 0),(16 0,16 23,16 48))'));
ob1.oblog.next;
# MultiPolyGon
insert into t1 values(12, ST_GeomFromText('MULTIPOLYGON(((28 26,28 0,84 0,84 42,28 26),(52 18,66 23,73 9,48 6,52 18)),((59 18,67 18,67 13,59 13,59 18)))'));
ob1.oblog.next;
# Collection
insert into t1 values(13, ST_GeomFromText('GEOMETRYCOLLECTION EMPTY'));
ob1.oblog.next;
insert into t1 values(14, ST_GeomFromText('GEOMETRYCOLLECTION ()'));
ob1.oblog.next;
insert into t1 values(15, ST_GeomFromText('GEOMETRYCOLLECTION(Point(9 9),LINESTRING(1 5,0 0),POLYGON((2 2,2 8,8 8,8 2,2 2)))'));
ob1.oblog.next;
insert into t1 values(16, ST_GEOMFROMTEXT('GEOMETRYCOLLECTION(POLYGON((0 0,50 45,40 50,0 0)),LINESTRING(-10 -10,0 0),LINESTRING(46.666666666666664 46.666666666666664,200 200,199 201,45.333333333333336 47.333333333333336),LINESTRING(8 10,-11 -9))'));
ob1.oblog.next;
insert into t1 values(17, ST_GEOMFROMTEXT('GEOMETRYCOLLECTION(GEOMETRYCOLLECTION(POINT(1 1)),GEOMETRYCOLLECTION(LINESTRING(1 1,2 2)))'));
ob1.oblog.next;
insert into t1 values(18, ST_GEOMFROMTEXT('GEOMETRYCOLLECTION(GEOMETRYCOLLECTION(),GEOMETRYCOLLECTION EMPTY, GEOMETRYCOLLECTION(POINT(1 1)), MULTILINESTRING((10 48,10 21,10 0),(16 0,16 23,16 48)), MULTIPOLYGON(((28 26,28 0,84 0,84 42,28 26),(52 18,66 23,73 9,48 6,52 18)),((59 18,67 18,67 13,59 13,59 18))), MULTIPOINT((0 0),(10 10),(10 20),(20 20)), MULTIPOINT(1 1, 11 11, 11 21, 21 21), GEOMETRYCOLLECTION(LINESTRING(1 1,2 2)), GEOMETRYCOLLECTION(POLYGON((0 0,50 45,40 50,0 0)),LINESTRING(-10 -10,0 0),LINESTRING(46.666666666666664 46.666666666666664,200 200,199 201,45.333333333333336 47.333333333333336),LINESTRING(8 10,-11 -9)))'));
ob1.oblog.next;
# multiple insert
INSERT INTO t1 (id, g1) VALUES
  (101, ST_GeomFromText("POINT(1 1)")),
  (102, ST_GeomFromText("POINT(-100 +2e6)")),
  (103, ST_GeomFromText("LINESTRING(0 0,1 1,2 2)")),
  (104, ST_GeomFromText("POLYGON((0 0,1 0,1 1,0 1,0 0),(5 5,7 5,7 7,5 7,5 5))")),
  (105, ST_GeomFromText("MULTIPOINT(9 9,8 1,1 5)")),
  (106, ST_GeomFromText("MULTILINESTRING((2 2,2 8,-2 8),(-6 -6, 6 6),(10 10, 14 14))")),
  (107, ST_GeomFromText("MULTIPOLYGON(((0 0, 3 0, 3 3, 0 3, 0 0)),((6 6,6 9,9 9,9 6,6 6)))")),
  (108, ST_GeomFromText("GEOMETRYCOLLECTION(POINT(0 0),
                         LINESTRING(0 0,5 5,10 10),
                         POLYGON((0 0,0 10,10 10,10 0,0 0)),
                         MULTIPOINT(0 0,2 2,4 4),
                         MULTILINESTRING((0 0,5 5,0 0),(0 0,-5 -5,0 0)),
                         MULTIPOLYGON(((0 0,0 5,5 5,5 0,0 0)),((5 5,5 10,10 10,10 5,5 5))))"));
ob1.oblog.next;

# Decimals and Scientific Notation
insert into t1 values(201, _ST_GeomFromEWKT('SRID=4269;POLYGON((0.123456789876543212345678987654321 0.123456789876543212345678987654321, 0.123456789876543212345678987654321 0.123456789876543212345678987654321,
                                        0.123456789876543212345678987654321 0.123456789876543212345678987654321,
                                        0.123456789876543212345678987654321 0.123456789876543212345678987654321))'));
ob1.oblog.next;
# POINT(2.093e-320 5.332997387e-315)
insert into t1 values(202, _st_geomfromewkb(x'01010000008C100000000000000080564000000000'));
ob1.oblog.next;
# POINT(1.32993e-319 5.33817804e-315)
insert into t1 values(203, _st_geomfromewkb(x'010100000026690000000000000080664000000000'));
ob1.oblog.next;

insert into t1 values(204, _st_geomfromewkt('srid=4269;point(1e-15 1e-15)'));
ob1.oblog.next;
insert into t1 values(205, _st_geomfromewkt('srid=4269;point(0.1e-15 1e-15)'));
ob1.oblog.next;
insert into t1 values(206, _st_geomfromewkt('srid=4269;point(1.123456789e-15 1.123456789e-15)'));
ob1.oblog.next;
insert into t1 values(207, _st_geomfromewkt('srid=4269;point(1e-6 1e-10)'));
ob1.oblog.next;

# SRID=4269;POINT(0.0000001 1e-10)
insert into t1 values(208, _st_geomfromewkt('srid=4269;point(1e-7 1e-10)'));
ob1.oblog.next;
# SRID=4269;POINT(0.0007 1e-10)
insert into t1 values(209, _st_geomfromewkt('srid=4269;point(7000e-7 1e-10)'));
ob1.oblog.next;
# SRID=4269;POINT(0.00000007 1e-10)
insert into t1 values(210, _st_geomfromewkt('srid=4269;point(0.7e-7 1e-10)'));
ob1.oblog.next;
# POINT(1.001e-15 1e-16)
insert into t1 values(211, _st_geomfromewkt('point(1.001110000000000000009e-15 1e-16)'));
ob1.oblog.next;
# POINT(1.001e-15 1e-16)
insert into t1 values(212, _st_geomfromewkt('point(1.001110000000000000009e-15 1e-16)'));
ob1.oblog.next;
# POINT(1e-15 1e-16)
insert into t1 values(213, _st_geomfromewkt('point(1.001110000000000000009e-15 1e-16)'));
ob1.oblog.next;
# POINT(1e-16 1.001e-16)
insert into t1 values(214, _st_geomfromewkt('point(1e-16 1.001410000000000000009e-16)'));
ob1.oblog.next;
# POINT(1e-16 1.002e-16)
insert into t1 values(215, _st_geomfromewkt('point(1e-16 1.001510000000000000009e-16)'));
ob1.oblog.next;

# update
UPDATE t1 SET g1=_st_geomfromewkt('srid=4269;point(7000e-7 1e-10)') WHERE id=1;
ob1.oblog.next;

UPDATE t1 SET g1=ST_GeomFromText('MULTILINESTRING((10 48,10 21,10 0), (16 0,16 23,16 48))') WHERE id=5;
ob1.oblog.next;

# 测试坐标序参数场景
insert into t1 values(2, ST_GeomFromText('Point(1 2)', 4326));
ob1.oblog.next;
insert into t1 values(1, ST_GeomFromText('Point(1 2)', 4326, 'axis-order=long-lat'));
ob1.oblog.next;

insert into t1 values(1, ST_GeomFromText('Point(1 2)', 4326, 'axis-order=lat-long'));
ob1.oblog.next;
insert into t1 values(1, ST_GeomFromText('Point(1 2)', 2284));
ob1.oblog.next;
insert into t1 values(1, ST_GeomFromText('Point(1 2)', 2284, 'axis-order=lat-long'));
ob1.oblog.next;

# 测试其它表达式写入数据
insert into t1 values(2, ST_Buffer(ST_GeomFromText('Point(0 0)'), 10));
ob1.oblog.next;

# 测试ObGeoTypeUtil::geo_to_ewkt输出precision
insert into t1 values(20, ST_GeomFromText('Point(-1.3921288835191632 1)'));
ob1.oblog.next;

# 执行drop table DDL
drop table t1;
# 输出drop table DDL
ob1.oblog.next;



# 测试列上带有not null 和srid，建立索引，球面坐标系
create table t2(id int, g1 geometry not null srid 4326);
ob1.oblog.next;
create spatial index sidx2 on t2(g1);
ob1.oblog.next;

# point
insert into t2 values(1, ST_GeomFromText('Point(1 2)', 4326));
# 输出上述事务
ob1.oblog.next;
insert into t2 values(2, ST_GeomFromText('Point(0 0)', 4326));
ob1.oblog.next;
insert into t2 values(3, ST_GeomFromText('POINT(-12.34 +56.78)', 4326));
ob1.oblog.next;
insert into t2 values(4, ST_GeomFromText('POINT(25.416666666666668 25.416666666666668)', 4326));
ob1.oblog.next;
insert into t2 values(5, ST_GeomFromText('POINT(1e-8 -23e-4)', 4326));
ob1.oblog.next;
# LineString
insert into t2 values(6, ST_GeomFromText('LINESTRING(0 0,10 10)', 4326));
ob1.oblog.next;
insert into t2 values(7, ST_GeomFromText('LINESTRING(0 0,-4 8, 20.00 20.00)', 4326));
ob1.oblog.next;
# Polygon
insert into t2 values(8, ST_GeomFromText('Polygon((0 0, 0 8, 8 8, 8 10, -10 10, -10 0, 0 0))', 4326));
ob1.oblog.next;
# MultiPoint
insert into t2 values(9, ST_GeomFromText('MULTIPOINT(1 1, 11 11, 11 21, 21 21)', 4326));
ob1.oblog.next;
insert into t2 values(10, ST_GeomFromText('MULTIPOINT((0 0),(10 10),(10 20),(20 20))', 4326));
ob1.oblog.next;
# MultiLineString
insert into t2 values(11, ST_GeomFromText('MULTILINESTRING((10 48,10 21,10 0),(16 0,16 23,16 48))', 4326));
ob1.oblog.next;
# MultiPolyGon
insert into t2 values(12, ST_GeomFromText('MULTIPOLYGON(((28 26,28 0,84 0,84 42,28 26),(52 18,66 23,73 9,48 6,52 18)),((59 18,67 18,67 13,59 13,59 18)))', 4326));
ob1.oblog.next;
# Collection
insert into t2 values(13, ST_GeomFromText('GEOMETRYCOLLECTION EMPTY', 4326));
ob1.oblog.next;
insert into t2 values(14, ST_GeomFromText('GEOMETRYCOLLECTION ()', 4326));
ob1.oblog.next;
insert into t2 values(15, ST_GeomFromText('GEOMETRYCOLLECTION(Point(9 9),LINESTRING(1 5,0 0),POLYGON((2 2,2 8,8 8,8 2,2 2)))', 4326));
ob1.oblog.next;
insert into t2 values(16, ST_GEOMFROMTEXT('GEOMETRYCOLLECTION(POLYGON((0 0,50 45,40 50,0 0)),LINESTRING(-10 -10,0 0), LINESTRING(46.666666666666664 46.666666666666664, 20.0 20.0, 19.9 20.1, 45.333333333333336 47.333333333333336), LINESTRING(8 10,-11 -9))', 4326));
ob1.oblog.next;
insert into t2 values(17, ST_GEOMFROMTEXT('GEOMETRYCOLLECTION(GEOMETRYCOLLECTION(POINT(1 1)),GEOMETRYCOLLECTION(LINESTRING(1 1,2 2)))', 4326));
ob1.oblog.next;
insert into t2 values(18, ST_GEOMFROMTEXT('GEOMETRYCOLLECTION(GEOMETRYCOLLECTION(),GEOMETRYCOLLECTION EMPTY, GEOMETRYCOLLECTION(POINT(1 1)), MULTILINESTRING((10 48,10 21,10 0),(16 0,16 23,16 48)), MULTIPOLYGON(((28 26,28 0,84 0,84 42,28 26),(52 18,66 23,73 9,48 6,52 18)),((59 18,67 18,67 13,59 13,59 18))), MULTIPOINT((0 0),(10 10),(10 20),(20 20)), MULTIPOINT(1 1, 11 11, 11 21, 21 21), GEOMETRYCOLLECTION(LINESTRING(1 1,2 2)), GEOMETRYCOLLECTION(POLYGON((0 0,50 45,40 50,0 0)),LINESTRING(-10 -10,0 0),LINESTRING(46.666666666666664 46.666666666666664,20.0 20.0,19.9 20.1,45.333333333333336 47.333333333333336),LINESTRING(8 10,-11 -9)))', 4326));
ob1.oblog.next;
# multiple insert
