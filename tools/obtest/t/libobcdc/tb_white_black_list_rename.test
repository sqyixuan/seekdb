#
# owner: fankun.fan
# owner group: libobcdc
# description: rename
##

ob1=OBI(cluster=1,init_unit_cpu=5);
ob1.reboot;
ob1.create_client;

# 创建mysql租户oblog_tt，并且切换到mysql租户下
source include/liboblog/create_tenant_with_gts.inc;

let $restart_ts_usec1 = query_get_value(select time_to_usec(now(6)) as now, now, 1);

# 启动liboblog，同步oblog_tt租户数据
ob1.oblog.gen_conf tb_white_list=oblog_tt.*.white* tb_black_list=oblog_tt.*.black* meta_data_refresh_mode=data_dict log_level=DEBUG skip_ob_version_compat_check=1;
ob1.oblog.restart;

let $ddl_stmt_count = 0;
let $white_dml_stmt_count = 0;
let $black_dml_stmt_count = 0;

# 创建database 1
create database oblog_db1;
ob1.oblog.next;
inc $ddl_stmt_count;

# 创建database 2
create database oblog_db2;
ob1.oblog.next;
inc $ddl_stmt_count;

# ob1.mysql alter system set dump_data_dictionary_to_log_interval = '6s' tenant all;

use oblog_db1;

# 创建黑白名单测试表，防止ob1.oblog.next输出EOF 
create table white0(id int);
ob1.oblog.next;
inc $ddl_stmt_count;

# 创建白名单表
create table white1(id int, c1 timestamp(6), c2 datetime);
ob1.oblog.next;
inc $ddl_stmt_count;

# 输出
insert into white1 values(1, '2019-1-30 12:00:00.123456', '2019-1-30 12:00:00');
ob1.oblog.next;
inc $white_dml_stmt_count;

# rename
rename table oblog_db1.white1 to oblog_db1.black1;
ob1.oblog.next;
inc $ddl_stmt_count;

# rename
rename table oblog_db1.black1 to oblog_db2.black1;
ob1.oblog.next;
inc $ddl_stmt_count;

# 不输出
use oblog_db2;
insert into black1 values(2, '2020-1-30 12:00:00.123456', '2020-1-30 12:00:00');
use oblog_db1;
insert into white0 values(1);
ob1.oblog.next;
inc $black_dml_stmt_count;
inc $white_dml_stmt_count;

# 创建黑名单表
create table black2(id int, c1 timestamp(6), c2 datetime);
ob1.oblog.next;
inc $ddl_stmt_count;

# 不输出
insert into black2 values(1, '2019-1-30 12:00:00.123456', '2019-1-30 12:00:00');
insert into white0 values(2);
ob1.oblog.next;
inc $white_dml_stmt_count;
inc $black_dml_stmt_count;

# rename
rename table oblog_db1.black2 to oblog_db1.white2;
ob1.oblog.next;
inc $ddl_stmt_count;

# rename
rename table oblog_db1.white2 to oblog_db2.white2;
ob1.oblog.next;
inc $ddl_stmt_count;

# 输出
use oblog_db2;
insert into white2 values(2, '2020-1-30 12:00:00.123456', '2020-1-30 12:00:00');
ob1.oblog.next;
inc $white_dml_stmt_count;

# wait to generate data_dict
sleep 10;

# stop liboblog
ob1.oblog.stop;

# 目前存在的表：black1, white2
# 重新启动libobcdc
ob1.oblog.gen_conf tb_white_list=oblog_tt.*.white* tb_black_list=oblog_tt.*.black* log_level=DEBUG skip_ob_version_compat_check=1;
ob1.oblog.set_start_tstamp_usec $restart_ts_usec1;
ob1.oblog.restart;

# ouput the ddls and dmls
let $stmt_count = $ddl_stmt_count + $white_dml_stmt_count;
let $idx = 0;
while ($idx < $stmt_count)
{
    ob1.oblog.next;
    inc $idx;
}

# 目前存在的表：black1, white2
# 重新启动libobcdc并指定不同的黑白名单
ob1.oblog.gen_conf tb_white_list=oblog_tt.*.black* tb_black_list=oblog_tt.*.white* log_level=DEBUG skip_ob_version_compat_check=1;
ob1.oblog.set_start_tstamp_usec $restart_ts_usec1;
ob1.oblog.restart;

# ouput
let $stmt_count = $ddl_stmt_count + $black_dml_stmt_count;
let $idx = 0;
while ($idx < $stmt_count)
{
    ob1.oblog.next;
    inc $idx;
}

# 以数据字典模式重新启动libobcdc
ob1.oblog.gen_conf tb_white_list=oblog_tt.*.black* tb_black_list=oblog_tt.*.white* meta_data_refresh_mode=data_dict log_level=DEBUG skip_ob_version_compat_check=1;
ob1.oblog.set_start_tstamp_usec $restart_ts_usec1;
ob1.oblog.restart;

# ouput
let $stmt_count = $ddl_stmt_count + $black_dml_stmt_count;
let $idx = 0;
while ($idx < $stmt_count)
{
    ob1.oblog.next;
    inc $idx;
}

# 启动liboblog，同步oblog_tt租户数据
ob1.oblog.gen_conf tb_white_list=oblog_tt.*.white* tb_black_list=oblog_tt.*.black* log_level=DEBUG skip_ob_version_compat_check=1;
ob1.oblog.restart;

let $restart_ts_usec2 = query_get_value(select time_to_usec(now(6)) as now, now, 1);

let $ddl_stmt_count = 0;
let $white_dml_stmt_count = 0;
let $black_dml_stmt_count = 0;

# ob1.mysql alter system set dump_data_dictionary_to_log_interval = '6s' tenant all;

use oblog_db1;

# 创建白名单表
create table white3(id int, c1 timestamp(6), c2 datetime);
ob1.oblog.next;
inc $ddl_stmt_count;

# 输出
insert into white3 values(1, '2019-1-30 12:00:00.123456', '2019-1-30 12:00:00');
ob1.oblog.next;
inc $white_dml_stmt_count;

# rename成黑名单
alter table oblog_db1.white3 rename to oblog_db1.black3;
ob1.oblog.next;
inc $ddl_stmt_count;

# 不输出
insert into black3 values(2, '2020-1-30 12:00:00.123456', '2020-1-30 12:00:00');
insert into white0 values(3);
ob1.oblog.next;
inc $black_dml_stmt_count;
inc $white_dml_stmt_count;

# 创建黑名单表
create table black4(id int, c1 timestamp(6), c2 datetime);
ob1.oblog.next;
inc $ddl_stmt_count;

# 不输出
insert into black4 values(1, '2019-1-30 12:00:00.123456', '2019-1-30 12:00:00');
insert into white0 values(4);
ob1.oblog.next;
inc $black_dml_stmt_count;
inc $white_dml_stmt_count;

# rename成白名单
alter table oblog_db1.black4 rename to oblog_db1.white4;
ob1.oblog.next;
inc $ddl_stmt_count;

# 输出
insert into white4 values(2, '2020-1-30 12:00:00.123456', '2020-1-30 12:00:00');
ob1.oblog.next;
inc $white_dml_stmt_count;

# wait to generate data_dict
sleep 10;

# stop liboblog
ob1.oblog.stop;

# 目前存在的表：black3, white4
# 重新启动libobcdc
ob1.oblog.gen_conf tb_white_list=oblog_tt.*.white* tb_black_list=oblog_tt.*.black* log_level=DEBUG skip_ob_version_compat_check=1;
ob1.oblog.set_start_tstamp_usec $restart_ts_usec2;
ob1.oblog.restart;

# ouput the ddls and dmls
let $stmt_count = $ddl_stmt_count + $white_dml_stmt_count;
let $idx = 0;
while ($idx < $stmt_count)
{
    ob1.oblog.next;
    inc $idx;
}

# 目前存在的表：black1, white2
# 重新启动libobcdc并指定不同的黑白名单
ob1.oblog.gen_conf tb_white_list=oblog_tt.*.black* tb_black_list=oblog_tt.*.white* log_level=DEBUG skip_ob_version_compat_check=1;
ob1.oblog.set_start_tstamp_usec $restart_ts_usec2;
ob1.oblog.restart;

# ouput
let $stmt_count = $ddl_stmt_count + $black_dml_stmt_count;
let $idx = 0;
while ($idx < $stmt_count)
{
    ob1.oblog.next;
    inc $idx;
}

# 以数据字典模式重新启动libobcdc
ob1.oblog.gen_conf tb_white_list=oblog_tt.*.black* tb_black_list=oblog_tt.*.white* meta_data_refresh_mode=data_dict log_level=DEBUG skip_ob_version_compat_check=1;
ob1.oblog.set_start_tstamp_usec $restart_ts_usec2;
ob1.oblog.restart;

# ouput
let $stmt_count = $ddl_stmt_count + $black_dml_stmt_count;
let $idx = 0;
while ($idx < $stmt_count)
{
    ob1.oblog.next;
    inc $idx;
}

ob1.oblog.gen_conf tb_white_list=oblog_tt.*.white* tb_black_list=oblog_tt.*.black* log_level=DEBUG meta_data_refresh_mode=data_dict skip_ob_version_compat_check=1;
ob1.oblog.set_extra_argument -m;
ob1.oblog.restart;
ob1.oblog.stop;

ob1.oblog.gen_conf tb_white_list=oblog_tt.*.white* tb_black_list=oblog_tt.*.black* log_level=DEBUG skip_ob_version_compat_check=1;
ob1.oblog.set_extra_argument -m;
ob1.oblog.restart;
ob1.oblog.stop;
