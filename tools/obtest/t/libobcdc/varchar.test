##########################
#owner :  qianxi
#owner group: liboblog
#description:
# 测试点：
# 1. varchar
# 2. char
#

##########################

ob1=OBI(cluster=1,init_unit_cpu=2);
ob1.reboot;
ob1.create_client;

source include/liboblog/create_tenant_with_gts.inc;

# 启动oblog
ob1.oblog.gen_conf tb_white_list=oblog_tt.oblog_db1.* log_level=DEBUG skip_ob_version_compat_check=1;
ob1.oblog.set_extra_argument -i;
ob1.oblog.restart;

# 创建database 1
create database oblog_db1;
ob1.oblog.next;
use oblog_db1;

create table simple_varchar(c0 int, c1 varchar(10), c2 varchar(10), c3 char(10), c4 char(10));
ob1.oblog.next;

insert into simple_varchar values(1, 'a ', 'a ', 'a ', 'a ');
ob1.oblog.next;

insert into simple_varchar values(2, 'a         ', 'a  ', 'a ', 'a  ');
ob1.oblog.next;

insert into simple_varchar values(3, '', '', '', '');
ob1.oblog.next;

insert into simple_varchar values(4, '', '', '', '');
ob1.oblog.next;

insert into simple_varchar values(5, 'a       ', 'a  ', 'a ', 'a  ');
ob1.oblog.next;

insert into simple_varchar(c0, c1) values(6, 'a '), (7, 'a '), (8, 'a ');
ob1.oblog.next;

## varchar作为主键
create table simple_varchar_pk(c1 varchar(10) primary key, c2 int);
ob1.oblog.next;
sleep 1;

let $start_tstamp = query_get_value(select round(time_to_usec(now()) / 1000000) as now, now, 1);

insert into simple_varchar_pk values('a', 1);
delete from simple_varchar_pk;
insert into simple_varchar_pk values('a ', 2);
delete from simple_varchar_pk;
insert into simple_varchar_pk values('a  ', 3);
delete from simple_varchar_pk;

let $VARCHER_PK_DML_CNT = 6;
while ($VARCHER_PK_DML_CNT > 0)
{
  ob1.oblog.next;
  dec $VARCHER_PK_DML_CNT;
}

# stop liboblog
ob1.oblog.stop;

# 回拉历史
ob1.oblog.set_start_tstamp $start_tstamp;
ob1.oblog.gen_conf tb_white_list=oblog_tt.oblog_db1.* log_level=DEBUG skip_ob_version_compat_check=1;
ob1.oblog.set_extra_argument -i;
ob1.oblog.restart;

let $VARCHER_PK_DML_CNT = 6;
while ($VARCHER_PK_DML_CNT > 0)
{
  ob1.oblog.next;
  dec $VARCHER_PK_DML_CNT;
}

# stop liboblog
ob1.oblog.stop;
