#
# owner: QianXi
# owner group:liboblog
# description:
# Test add primary key/drop primary key
#
#  alter table oblog_db1.t1 drop primary key;
#  ERROR 1235 (0A000): Not supported feature or function
#
#  first remove and add
##

ob1=OBI(cluster=1, init_unit_cpu=5);
ob1.reboot;
ob1.create_client;

source include/liboblog/create_tenant.inc;
#alter system set syslog_level='debug';

--disable_warnings
drop database if exists oblog_db1;

# create database
create database oblog_db1;
use oblog_db1;

let $start_tstamp1 = query_get_value(select time_to_usec(now(6)) as now, now, 1);

# 启动liboblog
ob1.oblog.set_start_tstamp_usec $start_tstamp1;
ob1.oblog.gen_conf tb_white_list=oblog_tt.oblog*.* log_level=DEBUG skip_ob_version_compat_check=1;
ob1.oblog.restart;

let $t1_count = 0;
let $t1_alter_count = 0;
let $t2_count = 0;
let $t2_alter_count = 0;

create table t1(c1 int, c2 char(4));
ob1.oblog.next;
inc $t1_count;

Insert into t1 values(1,'a');
ob1.oblog.next;
inc $t1_count;
Insert into t1 values(2,'a');
ob1.oblog.next;
inc $t1_count;
Insert into t1 values(3,'a');
ob1.oblog.next;
inc $t1_count;
Insert into t1 values(4,'a');
ob1.oblog.next;
inc $t1_count;
Insert into t1 values(5,'a');
ob1.oblog.next;
inc $t1_count;

create table t2(c1 int, c2 int, c3 int);
ob1.oblog.next;
inc $t2_count;

Insert into t2 values(1, 1, 1);
ob1.oblog.next;
inc $t2_count;
Insert into t2 values(2, 2, 2);
ob1.oblog.next;
inc $t2_count;
Insert into t2 values(3, 3, 3);
ob1.oblog.next;
inc $t2_count;

let $cur_max_schema_version = query_get_value(select max(schema_version) as ver from oceanbase.__all_ddl_operation, ver, 1);

#### add one primary key
alter table t1 add primary key(c1);
ob1.oblog.next;
inc $t1_count;
inc $t1_alter_count;
let $start_tstamp2 = query_get_value(select schema_version from oceanbase.__all_ddl_operation where schema_version > $cur_max_schema_version and operation_type=1503 limit 1, ver, 1);

insert into t1 values (20, 'b');
ob1.oblog.next;
inc $t1_count;
inc $t1_alter_count;
insert into t1 values (30, 'c');
ob1.oblog.next;
inc $t1_count;
inc $t1_alter_count;
insert into t1 values (40, 'd');
ob1.oblog.next;
inc $t1_count;
inc $t1_alter_count;

let $cur_max_schema_version = query_get_value(select max(schema_version) as ver from oceanbase.__all_ddl_operation, ver, 1);

#### add tow primary key
alter table t2 add primary key(c1, c2);
ob1.oblog.next;
inc $t2_count;
inc $t2_alter_count;
let $start_tstamp3 = query_get_value(select schema_version from oceanbase.__all_ddl_operation where schema_version > $cur_max_schema_version and operation_type=1503 limit 1, ver, 1);

Insert into t2 values(4, 4, 4);
ob1.oblog.next;
inc $t2_count;
inc $t2_alter_count;

Insert into t2 values(5, 5, 5);
ob1.oblog.next;
inc $t2_count;
inc $t2_alter_count;

# stop liboblog
ob1.oblog.stop;


##############################################
#######
####### Fetch all table history
ob1.oblog.set_start_tstamp_usec $start_tstamp1;
ob1.oblog.gen_conf tb_white_list=oblog_tt.oblog*.* log_level=DEBUG test_mode_block_verify_participants_time_sec=1 skip_ob_version_compat_check=1;
ob1.oblog.restart;

let $idx = 1;
let $total_count = $t1_count + $t2_count;
while ($idx <= $total_count)
{
  inc $idx;
  ob1.oblog.next;
}

# stop liboblog
ob1.oblog.stop;

##############################################
#######
####### Fetch t1 table history
ob1.oblog.set_start_tstamp_usec $start_tstamp1;
ob1.oblog.gen_conf tb_white_list=oblog_tt.oblog*.t1 log_level=DEBUG test_mode_block_verify_participants_time_sec=1 skip_ob_version_compat_check=1;
ob1.oblog.restart;

let $t1_idx = 1;
let $t1_cnt = $t1_count;
# output create table t2**
inc $t1_cnt;
while ($t1_idx <= $t1_cnt)
{
  inc $t1_idx;
  ob1.oblog.next;
}

# stop liboblog
ob1.oblog.stop;

##############################################
#######
####### Fetch t1 table history, Test add hidden table when start-up
ob1.oblog.set_start_tstamp_usec $start_tstamp2;
ob1.oblog.gen_conf tb_white_list=oblog_tt.oblog*.t1 log_level=DEBUG test_mode_block_verify_participants_time_sec=1 skip_ob_version_compat_check=1;
ob1.oblog.restart;

let $t1_idx = 1;
while ($t1_idx <= $t1_alter_count)
{
  inc $t1_idx;
  ob1.oblog.next;
}

# stop liboblog
ob1.oblog.stop;

##############################################
#######
####### Fetch t2 table history
ob1.oblog.set_start_tstamp_usec $start_tstamp1;
ob1.oblog.gen_conf tb_white_list=oblog_tt.oblog*.t2 log_level=DEBUG test_mode_block_verify_participants_time_sec=1 skip_ob_version_compat_check=1;
ob1.oblog.restart;

let $t2_idx = 1;
let $t2_cnt = $t2_count;
# output create table t1**
# output alter table t1**
inc $t2_cnt;
inc $t2_cnt;
while ($t2_idx <= $t2_cnt)
{
  inc $t2_idx;
  ob1.oblog.next;
}

# stop liboblog
ob1.oblog.stop;

##############################################
#######
####### Fetch t1 table history, Test add hidden table when start-up
ob1.oblog.set_start_tstamp_usec $start_tstamp3;
ob1.oblog.gen_conf tb_white_list=oblog_tt.oblog*.t2 log_level=DEBUG test_mode_block_verify_participants_time_sec=1 skip_ob_version_compat_check=1;
ob1.oblog.restart;

let $t2_idx = 1;
while ($t2_idx <= $t2_alter_count)
{
  inc $t2_idx;
  ob1.oblog.next;
}

# stop liboblog
ob1.oblog.stop;

#############################################
#######
####### remove primary key
ob1.oblog.gen_conf tb_white_list=oblog_tt.oblog*.t3 log_level=DEBUG skip_ob_version_compat_check=1;
ob1.oblog.restart;

create table t3(c1 int primary key, c2 char(4));
ob1.oblog.next;
Insert into t3 values(1,'a');
ob1.oblog.next;

alter table t3 drop primary key, add primary key(c1,c2);
ob1.oblog.next;
Insert into t3 values(2,'b');
ob1.oblog.next;
Insert into t3 values(3,'c');
ob1.oblog.next;

alter table t3 drop primary key, add primary key(c1);
ob1.oblog.next;
Insert into t3 values(4,'a');
ob1.oblog.next;

ob1.oblog.stop;
