#
# owner:修铭
# owner group:liboblog
# description:
# 测试点: 测试skip_dirty_data配置项

ob1=OBI(cluster=1, init_unit_cpu=5);
ob1.reboot;
ob1.create_client;

# 准备环境
source include/liboblog/create_tenant.inc;

# 准备数据
--disable_warnings
drop database if exists oblog_db;
create database oblog_db;
use oblog_db;
create table t1 (pk int primary key, v1 int, v2 varchar(100));
create table t2 (pk int primary key, v1 int, v2 varchar(100));
create table t3 (pk int primary key, v1 int, v2 varchar(100));
create table t4 (pk int primary key, v1 int, v2 varchar(100));

# 启动liboblog
# 默认黑名单: | , set cluster_id_black_list=2147473648 to filter
ob1.oblog.gen_conf tb_white_list=oblog_tt.oblog_db.t* cluster_id_black_list=2147473648 skip_ob_version_compat_check=1;
ob1.oblog.restart;

# 1. 正常集群的数据，要求能够获取到
replace into t1 values (1, 1, 'a');
ob1.oblog.next_dml;

# 2. 设置一个无关的cluster_id，要求也能够输出，不过滤
set ob_org_cluster_id=100;
replace into t1 values (2, 1, 'b');
ob1.oblog.next_dml;

# 3. 设置默认黑名单中的cluster_id，要求过滤掉数据
# 这条数据是过滤掉的，要求在输出下一条时，没有这条数据
set ob_org_cluster_id=2147473648;
replace into t1 values (3, 1, 'c');
# 输入一个不过滤掉的数据，要求输出该数据
set ob_org_cluster_id=200;
replace into t1 values (4, 1, 'd');
ob1.oblog.next_dml;


# 4. 要求过滤多条事务数据
set ob_org_cluster_id=2147473648;
begin;
replace into t1 values (5, 1, 'e');
replace into t2 values (6, 1, 'f');
replace into t3 values (7, 1, 'g');
replace into t4 values (8, 1, 'h');
commit;
begin;
replace into t1 values (9, 1, 'e');
replace into t2 values (10, 1, 'f');
replace into t3 values (11, 1, 'g');
replace into t4 values (12, 1, 'h');
commit;
begin;
replace into t1 values (13, 1, 'i');
replace into t2 values (14, 1, 'j');
replace into t3 values (15, 1, 'k');
replace into t4 values (16, 1, 'l');
commit;
begin;
replace into t1 values (17, 1, 'm');
replace into t2 values (18, 1, 'n');
replace into t3 values (19, 1, 'o');
replace into t4 values (20, 1, 'p');
commit;
begin;
replace into t1 values (21, 1, 'q');
replace into t2 values (22, 1, 'r');
replace into t3 values (23, 1, 's');
replace into t4 values (24, 1, 't');
commit;
# 输入一个不过滤掉的数据，要求输出该数据
set ob_org_cluster_id=300;
replace into t1 values (25, 1, 'u');
ob1.oblog.next_dml;


# 5. 重新设置黑名单，要求成功过滤
# 注意：黑名单的值需要在有效区间中: cluster_id_black_value_min(2147473648)，cluster_id_black_value_max(2147483647)
ob1.oblog.stop;
ob1.oblog.gen_conf tb_white_list=oblog_tt.oblog_db.t*  cluster_id_black_list=2147473649|2147483647|2147483646 skip_ob_version_compat_check=1;
ob1.oblog.restart;

# 设置第一个黑名单值
set ob_org_cluster_id=2147473649;
begin;
replace into t1 values (101, 1, 'a');
replace into t2 values (102, 1, 'b');
replace into t3 values (103, 1, 'c');
replace into t4 values (104, 1, 'd');
commit;
# 设置不过率的值，要求输出该数据
set ob_org_cluster_id=10000;
replace into t1 values (105, 1, 'e');
ob1.oblog.next_dml;

# 设置第二个黑名单值
set ob_org_cluster_id=2147483647;
begin;
replace into t1 values (106, 1, 'f');
replace into t2 values (107, 1, 'g');
replace into t3 values (108, 1, 'h');
replace into t4 values (109, 1, 'i');
commit;
# 设置不过率的值，要求输出该数据
set ob_org_cluster_id=20000;
replace into t1 values (110, 1, 'j');
ob1.oblog.next_dml;

# 设置第三个黑名单值
set ob_org_cluster_id=2147483646;
begin;
replace into t1 values (111, 1, 'k');
replace into t2 values (112, 1, 'l');
replace into t3 values (113, 1, 'm');
replace into t4 values (114, 1, 'n');
commit;
# 设置不过率的值，要求输出该数据
set ob_org_cluster_id=30000;
replace into t1 values (115, 1, 'o');
ob1.oblog.next_dml;

# 停止liboblog
ob1.oblog.stop;
