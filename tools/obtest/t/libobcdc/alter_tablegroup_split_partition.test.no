#
# owner:千溪
# owner group:liboblog
# description:
# 测试点:
#   测试liboblog tablegroup split partition
#
##

ob1=OBI(cluster=1);
ob1.reboot;
ob1.create_client;

# 准备环境
let $ip=deploy_get_value(ob1.proxy0.ip);
let $port=deploy_get_value(ob1.proxy0.port);
connect (oblog_conn_sys,$ip,admin@sys,admin,oceanbase,$port);

connection oblog_conn_sys;

--disable_warnings
drop database if exists oblog_db;
--disable_warnings
drop tablegroup if exists tg_for_split;

# 启动liboblog
ob1.oblog.gen_conf tb_white_list=sys.oblog*.* skip_ob_version_compat_check=1;
ob1.oblog.restart;

# sys租户下操作
connection oblog_conn_sys;
# 关闭回收站
# tablegroup下table进去回收站不允许删除tablegroup
set @@recyclebin = off;
# 创建database
create database oblog_db;
ob1.oblog.next;
use oblog_db;

######################################## case 1 tablegroup 1个表
create tablegroup tg_for_split;
ob1.oblog.next;
create table tt(c1 int primary key, c2 int) tablegroup tg_for_split;
ob1.oblog.next;
insert into tt values(1,1);
ob1.oblog.next;
insert into tt values(2,2);
ob1.oblog.next;
insert into tt values(3,3);
ob1.oblog.next;
alter table tt modify partition by hash(c1) partitions 1;
ob1.oblog.next;
select * from tt partition(p0);
select * from tt;
# tablegroup split
alter tablegroup tg_for_split modify partition by hash partitions 3;
ob1.oblog.next;

#alter system major freeze;
#ob1.check_version 2;

select * from tt partition(p0);
select * from tt partition(p1);
select * from tt partition(p2);
select * from tt;

insert into tt values(4,4);
ob1.oblog.next;
insert into tt values(5,5);
ob1.oblog.next;
insert into tt values(6,6);
ob1.oblog.next;
select * from tt partition(p0);
select * from tt partition(p1);
select * from tt partition(p2);
select * from tt;

######################################## case  2 tablegroup 多个表 hash 分区
drop table tt;
ob1.oblog.next;
drop tablegroup tg_for_split;
ob1.oblog.next;
create tablegroup tg_for_split;
ob1.oblog.next;
create table tt(c1 int primary key, c2 int) tablegroup tg_for_split;
ob1.oblog.next;
create table tt2(c1 int primary key, c2 int) tablegroup tg_for_split;
ob1.oblog.next;

insert into tt values(1,1);
ob1.oblog.next;
insert into tt values(2,2);
ob1.oblog.next;
insert into tt values(3,3);
ob1.oblog.next;
insert into tt2 values(1,1);
ob1.oblog.next;
insert into tt2 values(2,2);
ob1.oblog.next;
insert into tt2 values(3,3);
ob1.oblog.next;

alter table tt modify partition by hash(c1) partitions 1;
ob1.oblog.next;
alter table tt2 modify partition by hash(c1) partitions 1;
ob1.oblog.next;

# 查看数据
select * from tt partition(p0);
select * from tt;
select * from tt2;

# split
alter tablegroup tg_for_split modify partition by hash partitions 3;
ob1.oblog.next;
insert into tt values(4,4);
ob1.oblog.next;
insert into tt values(5,5);
ob1.oblog.next;
insert into tt values(6,6);
ob1.oblog.next;
insert into tt2 values(4, 4);
ob1.oblog.next;
insert into tt2 values(5, 5);
ob1.oblog.next;
insert into tt2 values(6, 6);
ob1.oblog.next;

select * from tt partition(p0);
select * from tt partition(p1);
select * from tt partition(p2);
select * from tt2 partition(p0);
select * from tt2 partition(p1);
select * from tt2 partition(p2);
select * from tt2;

######################################## case  3 tablegroup 多个表 range分区
drop table tt;
ob1.oblog.next;
drop table tt2;
ob1.oblog.next;
drop tablegroup tg_for_split;
ob1.oblog.next;
create tablegroup tg_for_split;
ob1.oblog.next;
create table tt(c1 int primary key, c2 int) tablegroup tg_for_split;
ob1.oblog.next;
create table tt2(c1 int primary key, c2 int) tablegroup tg_for_split;
ob1.oblog.next;

insert into tt values(1,1);
ob1.oblog.next;
insert into tt values(12,2);
ob1.oblog.next;
insert into tt values(23,3);
ob1.oblog.next;
insert into tt2 values(1,1);
ob1.oblog.next;
insert into tt2 values(22,2);
ob1.oblog.next;
insert into tt2 values(23,3);
ob1.oblog.next;

alter table tt modify partition by hash(c1) partitions 1;
ob1.oblog.next;
alter table tt2 modify partition by hash(c1) partitions 1;
ob1.oblog.next;
# range 分裂为2个分区
alter tablegroup tg_for_split modify partition by range (partition p0 values less than (10), partition p1 values less than MAXVALUE);
ob1.oblog.next;
select * from tt partition(p0);
select * from tt partition(p1);
select * from tt2 partition(p0);
select * from tt2 partition(p1);

insert into tt values(9,9);
ob1.oblog.next;
insert into tt values(10,10);
ob1.oblog.next;
insert into tt2 values(9,9);
ob1.oblog.next;
insert into tt2 values(10,10);
ob1.oblog.next;
select * from tt partition(p0);
select * from tt partition(p1);
select * from tt2 partition(p0);
select * from tt2 partition(p1);

drop table tt;
ob1.oblog.next;
drop table tt2;
ob1.oblog.next;

# stop liboblog
ob1.oblog.stop;

# 清理数据
--disable_warnings
drop database if exists oblog_db;
--disable_warnings
drop tablegroup if exists tg_for_split;
