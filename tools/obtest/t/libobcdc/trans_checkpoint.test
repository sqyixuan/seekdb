#
# owner:千溪
# owner group:liboblog
# description:
# 测试点:
#     1. 测试单机多分区事务
#     2. 一阶段优化checkpoint
#
##

ob1=OBI(cluster=1, init_unit_cpu=5);
ob1.reboot;
ob1.create_client;

# 准备环境
source include/liboblog/create_tenant.inc;

--disable_warnings
drop database if exists oblog_db;

# 启动liboblog
ob1.oblog.gen_conf tb_white_list=oblog_tt.*.* log_level=DEBUG sort_trans_participants=1 skip_ob_version_compat_check=1;
ob1.oblog.restart;

create database oblog_db;
ob1.oblog.next;

use oblog_db;
# 创建表t1
# DDL分区，单机多分区事务，liboblog需要依靠checkpoint日志来推进事务
create table t1 (pk int primary key);
ob1.oblog.next;

# 创建表t2
create table t2 (pk int primary key);
ob1.oblog.next;

insert into t1 values(0);
ob1.oblog.next;

insert into t2 values(0);
ob1.oblog.next;
let $dml_cnt = 5;

# 单机多分区事务
begin;
insert into t1 values(1);
insert into t2 values(1);
update t1 set pk=10 where pk=1;
commit;

begin;
insert into t1 values(2);
insert into t2 values(2);
update t1 set pk=11 where pk=10;
commit;

begin;
insert into t1 values(3);
insert into t2 values(3);
update t1 set pk=12 where pk=11;
commit;

begin;
insert into t1 values(4);
insert into t2 values(4);
update t1 set pk=13 where pk=12;
commit;

begin;
insert into t1 values(5);
insert into t2 values(5);
update t1 set pk=14 where pk=13;
commit;

let $idx=$dml_cnt;
while($idx > 0)
{
 ob1.oblog.next;
 dec $idx;
}

# stop liboblog
ob1.oblog.stop;

# 清理数据
--disable_warnings
drop table if exists t1, t2;
