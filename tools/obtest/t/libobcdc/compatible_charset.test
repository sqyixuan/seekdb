# test if compatible charset is correctly set

ob1=OBI(cluster=1,init_unit_cpu=5);
ob1.reboot;

source include/liboblog/create_tenant.inc;

create database oblog_db1;
use oblog_db1;

ob1.oblog.gen_conf log_level=DEBUG tb_white_list=oblog_tt.*.* enable_compatible_charset=1 skip_ob_version_compat_check=1;
ob1.oblog.restart;

create table t1 (id int primary key, c1 char(10), c2 varchar(10), c3 binary(10), c4 varbinary(10));
ob1.oblog.next;

insert into t1(id, c1, c2, c3, c4) values (1, 'a', 'b', 'c', 'd');
ob1.oblog.next;

insert into t1(id, c1, c2, c3, c4) values (2, 'aa', 'bb', 'cc', 'dd');
ob1.oblog.next;

update t1 set c1='aaa', c2='bbb', c3='ccc', c4='ddd' where id=1;
ob1.oblog.next;

delete from t1 where id=1;
ob1.oblog.next;

create table t2 (id int primary key, c1 tinytext, c2 text, c3 mediumtext, c4 longtext);
ob1.oblog.next;

insert into t2(id, c1, c2, c3, c4) values (1, 'a', 'b', 'c', 'd');
ob1.oblog.next;

insert into t2(id, c1, c2, c3, c4) values (2, 'aa', 'bb', 'cc', 'dd');
ob1.oblog.next;

update t2 set c1='aaa', c2='bbb', c3='ccc', c4='ddd' where id=1;
ob1.oblog.next;

delete from t2 where id=1;
ob1.oblog.next;

create table t3 (id int primary key, c1 tinyblob, c2 blob, c3 mediumblob, c4 longblob);
ob1.oblog.next;

insert into t3(id, c1, c2, c3, c4) values (1, 'a', 'b', 'c', 'd');
ob1.oblog.next;

insert into t3(id, c1, c2, c3, c4) values (2, 'aa', 'bb', 'cc', 'dd');
ob1.oblog.next;

update t3 set c1='aaa', c2='bbb', c3='ccc', c4='ddd' where id=1;
ob1.oblog.next;

delete from t3 where id=1;
ob1.oblog.next;

create table t4 (id int primary key, c1 enum ('a','b'), c2 set ('a', 'b'), c3 float, c4 datetime);
ob1.oblog.next;

insert into t4(id, c1, c2, c3, c4) values (1, 'a', 'b', 1.1, '1999-09-09 09:59:59');
ob1.oblog.next;

insert into t4(id, c1, c2, c3, c4) values (2, 'a', 'b', 2.2, '2022-02-02 22:22:22');
ob1.oblog.next;

update t4 set c1='b', c2='b' where id=1;
ob1.oblog.next;

delete from t4 where id=1;
ob1.oblog.next;

create table t_type(id int primary key auto_increment, col_int8 tinyint default 1, col_int16 smallint, col_int24 mediumint default 2, col_int32 int, col_int64 bigint, col_uint8 tinyint unsigned, col_uint16 smallint unsigned, col_uint24 mediumint unsigned default 10000, col_uint32 int unsigned, col_uint64 bigint unsigned, col_bit bit(10), col_float float, col_double double, col_ufloat float unsigned, col_udouble double unsigned, col_decimal decimal(20, 2) default 11.11, col_udecimal decimal(20, 4) unsigned, col_datetime datetime(2), col_timestamp timestamp(3) default '2020-01-01 00:00:00', col_date date, col_time time(4), col_year year(4), col_varchar varchar(6) default 'helo$', col_char char(5), col_varbinary varbinary(5) default 'word#', col_binary binary(4), col_tinyblob tinyblob, col_blob blob, col_mediumblob mediumblob, col_longblob longblob, col_tinytext tinytext, col_text text, col_mediumtext mediumtext, col_longtext longtext, col_enum enum('a', 'b'), col_set set('a', 'b'), col_json json, col_geo geometry, col_point point, col_line linestring, col_poly polygon);
ob1.oblog.next;

insert into t_type(col_json) values ('{"a":99}');
ob1.oblog.next;

create table t_type1(id int primary key auto_increment, col_int8 tinyint default 1, col_int16 smallint, col_int24 mediumint default 2, col_int32 int, col_int64 bigint, col_uint8 tinyint unsigned, col_uint16 smallint unsigned, col_uint24 mediumint unsigned default 10000, col_uint32 int unsigned, col_uint64 bigint unsigned, col_bit bit(10), col_float float, col_double double, col_ufloat float unsigned, col_udouble double unsigned, col_decimal decimal(20, 2) default 11.11, col_udecimal decimal(20, 4) unsigned, col_datetime datetime(2), col_timestamp timestamp(3) default '2020-01-01 00:00:00', col_date date, col_time time(4), col_year year(4), col_varchar varchar(6) default 'helo$', col_char char(5), col_varbinary varbinary(5) default 'word#', col_binary binary(4), col_tinyblob tinyblob, col_blob blob, col_mediumblob mediumblob, col_longblob longblob, col_tinytext tinytext, col_text text, col_mediumtext mediumtext, col_longtext longtext, col_enum enum('a', 'b'), col_set set('a', 'b'), col_json json, col_geo geometry, col_point point, col_line linestring, col_poly polygon) character set binary;
ob1.oblog.next;

insert into t_type1(col_json) values ('{"a":99}');
ob1.oblog.next;

ob1.oblog.stop;

connection oblog_conn_sys;
drop tenant oblog_tt force;

source include/liboblog/create_oracle_tenant.inc;

ob1.oblog.gen_conf log_level=DEBUG tb_white_list=oracle.*.* enable_compatible_charset=1 skip_ob_version_compat_check=1;
ob1.oblog.restart;

create table t1 (id int primary key, c1 blob, c2 clob);
ob1.oblog.next;

insert into t1 values (1, '6161', 'aa');
ob1.oblog.next;

insert into t1 values (2, '6262', 'bb');
ob1.oblog.next;

update t1 set c1='616161', c2='aaa' where id=1;
ob1.oblog.next;

delete from t1 where id=1;
ob1.oblog.next;

create table t_type(col_char char(10), col_nchar nchar(10), col_varchar2 varchar2(10), col_varchar varchar(10), col_nvarchar2 nvarchar2(10), col_number number(10), col_float float(5), col_bfloat binary_float, col_bdouble binary_double, col_date date, col_timestamp timestamp, col_timestamp_with_time_zone timestamp with time zone, col_time_stamp_with_local_time_zone timestamp with local time zone, col_interval_y2m interval year to month, col_interval_d2s interval day to second, col_raw raw(10), col_rowid rowid, col_urowid urowid, col_blob blob, col_clob clob, col_xml xmltype);
ob1.oblog.next;

insert into t_type(col_char) values ('aaa');
ob1.oblog.next;

ob1.oblog.stop;