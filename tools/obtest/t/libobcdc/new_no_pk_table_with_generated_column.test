#
# owner:lixia.yq
# owner group:liboblog
# description:
# 测试点:
#  1. 无主键表, 隐藏主键列，column id < 16
#  insert/update/delete
#  2. 索引
#
##

## TODO(@lixia.yq) 添加生成列做分区键相关的case

ob1=OBI(cluster=1, init_unit_cpu=5);
ob1.reboot;
ob_connect(conn1, ob1.z1.obs0, root, , test, , USE_MYSQL_CONNECTOR);

# 准备环境
source include/liboblog/create_tenant.inc;

--disable_warnings
drop database if exists oblog_db;

# 启动liboblog
ob1.oblog.gen_conf tb_white_list=oblog_tt.oblog_db.* log_level=DEBUG enable_output_hidden_primary_key=1 sort_trans_participants=1 enable_output_trans_order_by_sql_operation=1 skip_ob_version_compat_check=1;
ob1.oblog.set_extra_argument -i;
ob1.oblog.restart;

create database oblog_db;
ob1.oblog.next;
use oblog_db;

# ob1.oblog.next;
##### 1. 列数：1	分区键：1
# 未制定分区数目，为单分区
create table t0(c0 int, c1 int as (c0 + 100)) partition by hash(c1);
ob1.oblog.next;

insert into t0(c0) values(1);
ob1.oblog.next;
insert into t0(c0) values(2);
ob1.oblog.next;

update t0 set c0=999 where c1=101;
ob1.oblog.next;

# not exists
delete from t0 where c0=200;
# not exists
delete from t0 where c0=201;

delete from t0;
ob1.oblog.next;

# 补充case: 上述case改为99个分区
create table tt0(c0 int, c1 int as (c0 + 100)) partition by hash(c1) partitions 99;
ob1.oblog.next;

insert into tt0(c0) values(1);
ob1.oblog.next;
insert into tt0(c0) values(2);
ob1.oblog.next;

update tt0 set c0=999 where c1=101;
ob1.oblog.next;

##### 2. 列数：3	分区键：1
create table t1(c0 int, c1 int, c2 int as (c0+c1)) partition by hash(c2);
ob1.oblog.next;

insert into t1(c0, c1) values(1, 2);
ob1.oblog.next;
insert into t1(c0, c1) values(3, 4);
ob1.oblog.next;
insert into t1(c0, c1) values(5, 6);
ob1.oblog.next;

update t1 set c1 = 100 where c1 = 6;
ob1.oblog.next;

delete from t1 where c0 = 3;
ob1.oblog.next;

update t1 set c0 = 1999 where c0 = 1;
ob1.oblog.next;

#### 3. 列数：5		分区键：3
create table t2(c0 int, c1 int, c2 int as(c0+c1), c3 int as(c0*c1)) partition by hash(c2 + c3);
ob1.oblog.next;

insert into t2(c0, c1) values(1, 2);
ob1.oblog.next;
insert into t2(c0, c1) values(3, 4);
ob1.oblog.next;

update t2 set c1 = 100 where c0 = 1;
ob1.oblog.next;
update t2 set c1 = 200 where c0 = 3;
ob1.oblog.next;

update t2 set c0 = 99, c1 = 1 where c2 = 101;
ob1.oblog.next;

#### 3. 列数：5		分区键：3
create table t3(c0 int, c1 int, c2 int, c3 int as(c0+c1+c2), c4 int as(c2+c1+c0), c5 int as(c0+c0+c0)) PARTITION BY key(c5, c3) SUBPARTITION BY RANGE(c4) subpartition template (SUBPARTITION sp0 VALUES less than(100),SUBPARTITION sp1 VALUES less than(5000)) partitions 3;
ob1.oblog.next;

insert into t3(c0,c1,c2) values(1, 2, 3);
ob1.oblog.next;
insert into t3(c0,c1,c2) values(6, 7, 8);
ob1.oblog.next;

update t3 set c2 = 100 where c3 = 6;
ob1.oblog.next;

# not exists
update t3 set c0 = 200 where c4 = 9;

update t3 set c0 = 999, c1 = 111, c2 = 444 where c3 = 21;
ob1.oblog.next;

delete from t3 where c0 = 999;
ob1.oblog.next;

### 4. 增删分区
create table t4(c1 int, c2 int as (c1+c1*3-c1+c1)) partition by range(c2) (partition p0 values less than(10), partition p1 values less than(1000));
ob1.oblog.next;

insert into t4(c1) values(1);
ob1.oblog.next;
insert into t4(c1) values(2);
ob1.oblog.next;

update t4 set c1 = 99 where c1 = 1;
ob1.oblog.next;
update t4 set c1 = 88 where c1 = 2;
ob1.oblog.next;

alter table t4 add partition (partition p2 values less than (10000), partition p3 values less than (maxvalue));
ob1.oblog.next;

insert into t4(c1) values(5000);
ob1.oblog.next;

update t4 set c1 = 20000 where c1 = 99;
ob1.oblog.next;

alter table t4 drop partition p3;
ob1.oblog.next;

##### 创建多列, 带索引的表
create table t5(c1 int, c2 int, c3 int, c4 int as (c2 + c1), c5 int as (c3 + c2 + c1), index(c1), unique key(c1, c2));
ob1.oblog.next;
insert into t5(c1, c2, c3) values(1, 2, 3);
ob1.oblog.next;
insert into t5(c1, c2, c3) values(11, 12, 13);
ob1.oblog.next;
update t5 set c1=10 where c4 = 3;
ob1.oblog.next;
delete from t5 where c1=10;
ob1.oblog.next;
delete from t5;
ob1.oblog.next;

##### 7.二级分区
create table t7(c1 int, c2 int, c3 int as (c1 - c2), c4 int, c5 int as (c4 - c2)) PARTITION BY key(c5, c3) SUBPARTITION BY RANGE(c2) subpartition template (SUBPARTITION sp0 VALUES less than(100),SUBPARTITION sp1 VALUES less than(200)) partitions 3;

ob1.oblog.next;
sleep 1;
let $start_tstamp = query_get_value(select round(time_to_usec(now()) / 1000000) as now, now, 1);
let $dml_cnt=0;

insert into t7(c1, c2, c4) values(1, 2, 3);
ob1.oblog.next;
inc $dml_cnt;

let $cnt=20;
let $idx=6;
while($idx < $cnt)
{
  eval alter table t7 add column c$idx int as (c1 + c2);
  ob1.oblog.next;
  inc $idx;
}

let $cnt=30;
let $idx=20;
while($idx < $cnt)
{
  eval alter table t7 add column c$idx int as (c1 + c2) stored;
  ob1.oblog.next;
  inc $idx;
}

insert into t7(c1, c2, c4) values(4, 5, 6);
ob1.oblog.next;
inc $dml_cnt;

#### 8.二级分区
create table t8(c1 int, c2 int, c3 int as (c2 - c1), c4 int default 1, c5 int default 1) PARTITION BY key(c1, c2) SUBPARTITION BY RANGE(c3) subpartition template (SUBPARTITION sp0 VALUES less than(100),SUBPARTITION sp1 VALUES less than(2000)) partitions 5;
ob1.oblog.next;

insert into t8(c1, c2) values(1, 2);
ob1.oblog.next;
insert into t8(c1, c2) values(9, 10);
ob1.oblog.next;

select * from t8;
update t8 set c1 = 999;
ob1.oblog.next;

select * from t8;
update t8 set c1 = 123, c2 = 234 where c4 = 1;
ob1.oblog.next;

delete from t8 where c1 = 123;
ob1.oblog.next;

connection oblog_conn_sys;
use oceanbase;
let $tenant_id = query_get_value(select tenant_id from __all_tenant where tenant_name="oblog_tt", tenant_id, 1);
connection oblog_conn_tt;
# schema split mode, 在租户本身下面查询
use oceanbase;
let $max_ddl_schema_version = query_get_value(select max(schema_version) as ver from __all_ddl_operation, ver, 1);

# stop liboblog
ob1.oblog.stop;

connection oblog_conn_tt;
# 启动liboblog, 回拉
ob1.oblog.set_start_tstamp $start_tstamp;
ob1.oblog.gen_conf tb_white_list=oblog_tt.oblog_db.* log_level=DEBUG enable_output_hidden_primary_key=1 sort_trans_participants=1 enable_output_trans_order_by_sql_operation=1 skip_ob_version_compat_check=1;
ob1.oblog.set_extra_argument -i;
ob1.oblog.restart;

let $idx=0;
while($idx < $dml_cnt)
{
  ob1.oblog.next_dml;
  inc $idx;
}

# stop liboblog
ob1.oblog.stop;

ob1.oblog.set_start_tstamp $start_tstamp;
ob1.oblog.gen_conf tb_white_list=oblog_tt.oblog_db.* log_level=DEBUG enable_output_hidden_primary_key=1 data_start_schema_version=$tenant_id:$max_ddl_schema_version sort_trans_participants=1 enable_output_trans_order_by_sql_operation=1 skip_ob_version_compat_check=1;
ob1.oblog.set_extra_argument -i;
ob1.oblog.restart;
let $idx=0;
while($idx < $dml_cnt)
{
  ob1.oblog.next_dml;
  inc $idx;
}
ob1.oblog.stop;
# 清理数据
--disable_warnings
drop database if exists oblog_db;
