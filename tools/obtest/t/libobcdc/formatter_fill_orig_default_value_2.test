#
# owner:千溪
# owner group:liboblog
# description:
# 测试点:
#   test formatter fill default value
#   测试defalut value为NULL, ''等场景
##

ob1=OBI(cluster=1,init_unit_cpu=5);
ob1.reboot;
ob1.create_client;

# 准备环境
source include/liboblog/create_tenant.inc;

--disable_warnings
drop database if exists oblog_db1;

let $start_tstamp = query_get_value(select round(time_to_usec(now()) / 1000000) as now, now, 1);

# 启动liboblog
ob1.oblog.set_start_tstamp $start_tstamp;
ob1.oblog.gen_conf tb_white_list=oblog_tt.oblog*.* skip_ob_version_compat_check=1;
ob1.oblog.restart;

let $t1_dml_count = 0;

# 创建database 1
create database oblog_db1;
ob1.oblog.next;
use oblog_db1;

create table t1(c1 int);
ob1.oblog.next;
insert into t1 values(11);
ob1.oblog.next;
inc $t1_dml_count;

alter table t1 add column c2 varchar(20) default '';
ob1.oblog.next;
begin;
update t1 set c1=110 where c1=11;
insert into t1 values(12, "21");
commit;
ob1.oblog.next;
inc $t1_dml_count;

alter table t1 add column c3 varchar(20) default NULL;
ob1.oblog.next;
begin;
update t1 set c1=120 where c1=12;
insert into t1 values(13, "22", "31");
commit;
ob1.oblog.next;
inc $t1_dml_count;

alter table t1 add column c4 datetime(6) default NULL;
ob1.oblog.next;
begin;
update t1 set c1=130 where c1=13;
insert into t1 values(14, "23", "32", "20180725");
commit;
ob1.oblog.next;
inc $t1_dml_count;

alter table t1 add column c5 int default NULL;
ob1.oblog.next;
begin;
update t1 set c1=140 where c1=14;
insert into t1 values(15, "24", "33", "20180725", 51);
commit;
ob1.oblog.next;
inc $t1_dml_count;

connect (oblog_conn_sys,$ip,admin@sys,admin,oceanbase,$port);
connection oblog_conn_sys;
let $tenant_id = query_get_value(select tenant_id from __all_tenant where tenant_name="oblog_tt", tenant_id, 1);
alter system change tenant oblog_tt;
use oceanbase;
let $newest_ddl_schema_version = query_get_value(select max(schema_version) as ver from __all_ddl_operation, ver, 1);

# stop liboblog
ob1.oblog.stop;

# reboot
# 1. 回拉历史日志
# 2. 采用最新的schema version, 测试格式化数据填充默认值
ob1.oblog.set_start_tstamp $start_tstamp;
# 设置data ddl schema version
ob1.oblog.gen_conf tb_white_list=oblog_tt.oblog*.* data_start_schema_version=$tenant_id:$newest_ddl_schema_version skip_ob_version_compat_check=1;

ob1.oblog.restart;
while ($t1_dml_count > 0)
{
  ob1.oblog.next_dml;
  dec $t1_dml_count;
}
