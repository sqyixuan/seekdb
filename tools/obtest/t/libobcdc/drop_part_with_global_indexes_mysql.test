#
# owner:千溪
# owner group:liboblog
# description:
# test:
#    drop_part_with_global_indexes_mysql
#
##

ob1=OBI(cluster=1,init_unit_cpu=5);
ob1.reboot;
ob1.create_client;

# 准备环境
let $ip=deploy_get_value(ob1.proxy0.ip);
let $port=deploy_get_value(ob1.proxy0.port);
connect (oblog_conn_sys,$ip,admin@sys,admin,oceanbase,$port);

connection oblog_conn_sys;

--disable_warnings
drop tenant if exists oblog_tt;
--disable_warnings
drop resource pool if exists oblog_pool;
--disable_warnings
drop resource unit if exists oblog_box;
--disable_warnings
drop database if exists oblog_db1;

# create tenant, 创建oblog_tt租户
create resource unit oblog_box max_cpu=2, memory_size='20G';
create resource pool oblog_pool unit = 'oblog_box', unit_num = 1, zone_list = ('z1');
create tenant oblog_tt replica_num = 1, primary_zone='z1', resource_pool_list=('oblog_pool') set ob_tcp_invited_nodes='%';

sleep 2;
# 在oblog_tt租户下操作
connect (oblog_conn_tt,$ip,root@oblog_tt,,oceanbase,$port);
connection oblog_conn_tt;

# 启动liboblog
ob1.oblog.gen_conf tb_white_list=sys.oblog*.*|oblog_tt.*.* log_level=DEBUG enable_output_hidden_primary_key=0 enable_block_drop_part_ddl=1 skip_ob_version_compat_check=1;
ob1.oblog.restart;

# 创建database 1
create database oblog_db1;
ob1.oblog.next;
use oblog_db1;

##################### 1. range_range
# create table t_range_range (c1 int, c2 int, c3 int, c4 int)
# partition by range(c1)
# subpartition by range(c2)
# (
#   partition rp0 values less than (100)
#   (
#     subpartition rp0sp0 values less than (100),
#     subpartition rp0sp1 values less than (200),
#     subpartition rp0sp2 values less than (300)
#   ),
#   partition rp1 values less than (200)
#   (
#     subpartition rp1sp0 values less than (100),
#     subpartition rp1sp1 values less than (200),
#     subpartition rp1sp2 values less than (300)
#   ),
#   partition rp2 values less than (300)
#   (
#     subpartition rp2sp0 values less than (100),
#     subpartition rp2sp1 values less than (200),
#     subpartition rp2sp2 values less than (300)
#   )
# );

create table t_range_range (c1 int, c2 int, c3 int, c4 int) partition by range(c1) subpartition by range(c2) (partition rp0 values less than (100) (subpartition rp0sp0 values less than (100),subpartition rp0sp1 values less than (200),subpartition rp0sp2 values less than (300)), partition rp1 values less than (200) (subpartition rp1sp0 values less than (100),subpartition rp1sp1 values less than (200),subpartition rp1sp2 values less than (300)), partition rp2 values less than (300) (subpartition rp2sp0 values less than (100),subpartition rp2sp1 values less than (200),subpartition rp2sp2 values less than (300)));
ob1.oblog.next;

create index idx_t_range_range on t_range_range(c1) global;
ob1.oblog.next;

# insert row
insert into t_range_range values(1,2,3,4);
ob1.oblog.next;
insert into t_range_range values(1,100,3,4);
ob1.oblog.next;
insert into t_range_range values(1,200,3,4);
ob1.oblog.next;
insert into t_range_range values(100,2,3,4);
ob1.oblog.next;
insert into t_range_range values(100,100,3,4);
ob1.oblog.next;
insert into t_range_range values(100,200,3,4);
ob1.oblog.next;
insert into t_range_range values(200,2,3,4);
ob1.oblog.next;
insert into t_range_range values(200,100,3,4);
ob1.oblog.next;
insert into t_range_range values(200,200,3,4);
ob1.oblog.next;

alter table t_range_range truncate subpartition rp1sp1;
ob1.oblog.next;
insert into t_range_range values(100,100,3,4);
ob1.oblog.next;

# drop 1 part, add 1 part
ob1.oblog.stat_check_log_cnt "CDC_CREATE_TABLET";
ob1.oblog.stat_check_log_cnt "CDC_DELETE_TABLET";

drop index idx_t_range_range on t_range_range;
ob1.oblog.next;
create index idx_t_range_range on t_range_range(c1) global;
ob1.oblog.next;

alter table t_range_range drop partition rp1;
ob1.oblog.next;

# drop 1+3 part, add 1+3 part
ob1.oblog.stat_check_log_cnt "CDC_CREATE_TABLET";
ob1.oblog.stat_check_log_cnt "CDC_DELETE_TABLET";

# stop liboblog
ob1.oblog.stop;
