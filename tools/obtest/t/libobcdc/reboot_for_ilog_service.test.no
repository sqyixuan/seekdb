#
# owner:修铭
# owner group:liboblog
# description:
# 测试点:
#   重启observer后，要求继续服务重启之前的所有的ilog
#   BUG: 
##

ob1=OBI(cluster=1);
ob1.reboot;
ob1.create_client;

# 准备环境
let $ip=deploy_get_value(ob1.proxy0.ip);
let $port=deploy_get_value(ob1.proxy0.port);
connect (oblog_conn_sys,$ip,admin@sys,admin,oceanbase,$port);

connection oblog_conn_sys;

# 准备数据
--disable_warnings
drop table if exists oblog_test;

create table oblog_test (pk int primary key, str varchar(1024));

let $TOTAL_CNT=1000;

# 获取liboblog启动时间戳
let $start_tstamp = query_get_value(select round(time_to_usec(now()) / 1000000) as now, now, 1);

# 第一次插入数据
let $cnt = $TOTAL_CNT;
while ($cnt > 0)
{
  eval replace into oblog_test values (1, 'c$cnt');
  dec $cnt;
}

# 发起每日合并
alter system major freeze;

# 检查版本到2
ob1.check_version 2;

# 再次插入数据
let $cnt = $TOTAL_CNT;
while ($cnt > 0)
{
  eval replace into oblog_test values (1, 'c$cnt');
  dec $cnt;
}

# 重启集群
ob1.restart;

# 启动liboblog
ob1.oblog.set_start_tstamp $start_tstamp;
ob1.oblog.gen_conf tb_white_list=*.*.oblog_test skip_ob_version_compat_check=1;
ob1.oblog.restart;

# 验证重启之前的数据可以拉到
let $cnt = $TOTAL_CNT;
while ($cnt > 0)
{
  ob1.oblog.next_dml;
  dec $cnt;
}

# 验证重启之后的数据可以拉到
let $cnt = $TOTAL_CNT;
while ($cnt > 0)
{
  ob1.oblog.next_dml;
  dec $cnt;
}

ob1.oblog.stop;
