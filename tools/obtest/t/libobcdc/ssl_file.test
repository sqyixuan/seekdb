#
# owner:千溪
# owner group:liboblog
# description:
# 测试点:
#  ssl file mode
#
##

ob1=OBI(cluster=1,init_unit_cpu=5);
ob1.reboot;
ob1.create_client;

# 准备环境
let $ip=deploy_get_value(ob1.proxy0.ip);
let $port=deploy_get_value(ob1.proxy0.port);
connect (oblog_conn_sys,$ip,admin@sys,admin,oceanbase,$port);

connection oblog_conn_sys;
# select * from __all_virtual_sys_parameter_stat where name like '%ssl%';
# server launch SSL
alter system set ssl_external_kms_info = '';
alter system set ssl_client_authentication = 'TRUE';
alter system set rpc_client_authentication_method = 'SSL_NO_ENCRYPT';
alter system set rpc_server_authentication_method = 'SSL_NO_ENCRYPT';
alter system set _ob_ssl_invited_nodes='ALL';

--disable_warnings
drop tenant if exists oblog_tt;
--disable_warnings
drop resource pool if exists oblog_pool;
--disable_warnings
drop resource unit if exists oblog_box;
--disable_warnings
drop database if exists oblog_db1;

source include/liboblog/create_tenant.inc;
sleep 2;
# 在oblog_tt租户下操作
connect (oblog_conn_tt,$ip,root@oblog_tt,,oceanbase,$port);
connection oblog_conn_tt;

# 启动liboblog
ob1.oblog.gen_conf tb_white_list=sys.oblog*.*|oblog_tt.*.* log_level=DEBUG ssl_client_authentication=1 rpc_client_authentication_method=SSL_NO_ENCRYPT ssl_external_kms_info=file skip_ob_version_compat_check=1;
ob1.oblog.restart;

# 创建database 1
create database oblog_db1;
ob1.oblog.next;

use oblog_db1;
CREATE TABLE t (b BIT(8));
ob1.oblog.next;

INSERT INTO t SET b = b'11111111';
ob1.oblog.next;

INSERT INTO t SET b = b'1010';
ob1.oblog.next;

INSERT INTO t SET b = b'1111';
ob1.oblog.next;

CREATE TABLE t2 (b BIT(12));
ob1.oblog.next;

INSERT INTO t2 SET b = b'0';
ob1.oblog.next;

INSERT INTO t2 SET b = b'10';
ob1.oblog.next;

INSERT INTO t2 SET b = b'01';
ob1.oblog.next;

INSERT INTO t2 SET b = b'001';
ob1.oblog.next;

INSERT INTO t2 SET b = b'11111111';
ob1.oblog.next;

INSERT INTO t2 SET b = b'001100000000';
ob1.oblog.next;

INSERT INTO t2 SET b = b'111111111111';
ob1.oblog.next;

# bit最大64位
CREATE TABLE t3 (b BIT(64));
ob1.oblog.next;

INSERT INTO t3 SET b = 0xFFFFFFFFFFFFFFFF;
ob1.oblog.next;

# stop liboblog
ob1.oblog.stop;
