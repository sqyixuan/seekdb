#
# owner:Qianxi
# owner group:libobcdc
# description:
# LOB类型与对应的长度限制：
# - tinyetext tinyblob
#   - 256 byte
# - text blob
#   - 64 KB
# - mediumtext mediumblob
#   - 16 MB
# - longtext longblob
#   - 48MB
#
# 一行长度限制：60M
##

ob1=OBI(cluster=1);
ob1.force_stop;
ob1.clean_backup_dest;
ob1.reboot;
ob1.create_client;

# 准备环境
let $ip=deploy_get_value(ob1.proxy0.ip);
let $port=deploy_get_value(ob1.proxy0.port);
connect (oblog_conn_sys,$ip,admin@sys,admin,oceanbase,$port);

#source include/liboblog/create_oracle_tenant.inc;

connection oblog_conn_sys;

# create tenant, 创建oblog_tt租户
create resource unit oblog_box_mysql max_cpu 2, memory_size='10G';
create resource pool oblog_pool_mysql unit = 'oblog_box_mysql', unit_num = 1, zone_list = ('z1');
create tenant oblog_tt replica_num = 1, primary_zone='z1', resource_pool_list=('oblog_pool_mysql') set ob_tcp_invited_nodes='%';

connection oblog_conn_sys;
alter tenant oblog_tt set variables max_allowed_packet=1073741824;

sleep 2;
# 在oblog_tt租户下操作
connect (oblog_conn_tt,$ip,root@oblog_tt,,oceanbase,$port);
connection oblog_conn_tt;

connection oblog_conn_tt;
# 设置最大包大小 1G
set global max_allowed_packet=1073741824;

connection oblog_conn_tt;

# 设置事务超时时间: 100秒
set ob_trx_timeout=100000000;

# 创建database 1
create database oblog_db1;
use oblog_db1;

# NOTICE: lob column don't have default value
create table t1(pk int primary key, long_text longtext);

let $mysql_tenant_name=oblog_tt;
let $original_conn=oblog_conn_tt;
source include/liboblog/enable_mysql_archive.inc;
ob1.z1.obs0.check_log_until_success -c "get_data_dict_meta_info";
use oblog_db1;
let $record_cnt=0;
let $start_tstamp_usec = query_get_value(select time_to_usec(now(6)) as now, now, 1);
# 启动liboblog
ob1.oblog.set_extra_argument -m;
ob1.oblog.gen_conf tb_white_list=sys.oblog*.*|oblog_tt.*.* log_level=DEBUG skip_ob_version_compat_check=1;
ob1.oblog.restart;

insert into t1 values (4, repeat('a', 50331647));
select pk, md5(long_text) from t1 where pk = 4;
ob1.oblog.next_dml;
inc $record_cnt;

# update inrow to empty or null
update t1 set long_text='' where pk = 4;
select pk, md5(long_text) from t1 where pk = 4;
ob1.oblog.next_dml;
inc $record_cnt;

update t1 set long_text= NULL where pk = 4;
select pk, md5(long_text) from t1 where pk = 4;
ob1.oblog.next_dml;
inc $record_cnt;

## inrow-> outrow
update t1 set long_text= repeat('a', 50331647)  where pk = 4;
select pk, md5(long_text) from t1 where pk = 4;
ob1.oblog.next_dml;
inc $record_cnt;

# update outrow to empty or null
update t1 set long_text=NULL where pk = 4;
select pk, md5(long_text) from t1 where pk = 4;
ob1.oblog.next_dml;
inc $record_cnt;

update t1 set long_text= '' where pk = 4;
select pk, md5(long_text) from t1 where pk = 4;
ob1.oblog.next_dml;
inc $record_cnt;

# ddl and modify charset
alter table t1 modify column long_text longtext character set utf16;
ob1.oblog.next;

## inrow-> outrow
insert into t1 values (1, repeat('韥饢ッギヂ', 2000000));
select pk, md5(long_text) from t1 where pk = 1;
ob1.oblog.next_dml;
inc $record_cnt;

delete from t1 where pk=4;
ob1.oblog.next_dml;
inc $record_cnt;

ob1.oblog.stop;
# use data_dict + log_archive
ob1.oblog.set_start_tstamp_usec $start_tstamp_usec;
ob1.oblog.gen_conf tb_white_list=oblog_tt.*.* log_level=DEBUG fetching_log_mode=direct meta_data_refresh_mode=data_dict archive_dest=$log_backup_dest;
ob1.oblog.set_extra_argument -m;
ob1.oblog.restart;
let $idx = 0;
while ($idx < $record_cnt)
{
  ob1.oblog.next_dml;
  inc $idx;
}
ob1.oblog.stop;
# use data_dict + online log
ob1.oblog.set_start_tstamp_usec $start_tstamp_usec;
ob1.oblog.gen_conf tb_white_list=oblog_tt.*.* log_level=DEBUG meta_data_refresh_mode=data_dict;
ob1.oblog.set_extra_argument -m;
ob1.oblog.restart;
let $idx = 0;
while ($idx < $record_cnt)
{
  ob1.oblog.next_dml;
  inc $idx;
}
ob1.oblog.stop;

ob1.oblog.gen_conf tb_white_list=oblog_tt.*.* log_level=DEBUG meta_data_refresh_mode=data_dict;
ob1.oblog.set_extra_argument -m;
ob1.oblog.restart;
ob1.oblog.stop;
