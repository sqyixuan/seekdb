#
# owner:zhixin.lm
# owner group:liboblog
# description:
# 测试点:
#   alter table rename index
#
##

ob1=OBI(cluster=1,init_unit_cpu=5);
ob1.reboot;
ob1.create_client;

# 准备环境
source include/liboblog/create_tenant_with_gts.inc;

# 启动liboblog
ob1.oblog.gen_conf tb_white_list=oblog_tt.*.* log_level=DEBUG skip_ob_version_compat_check=1;
ob1.oblog.restart;

# 创建database 1
create database oblog_db1;
ob1.oblog.next;

use oblog_db1;
# 创建表t1
create table t1 (pk int primary key, c1 int, c2 varchar(100), KEY idx_1 (c1));
ob1.oblog.next;

# 测试插入数据
insert into t1 values(1, 2, 'hello');
ob1.oblog.next;

# 测试renameindex功能
alter table t1 rename index idx_1 to idx_11;
ob1.oblog.next;

# rename index 以后插入数据
insert into t1 values(2, 3, 'world');
ob1.oblog.next;

# 建立unique索引
create unique index idx_c2 on t1(c2);
ob1.oblog.next;

insert into t1 values(3, 4, 'go');
ob1.oblog.next;

# 修改唯一索引的名字
alter table t1 rename index idx_c2 to idx_2;
ob1.oblog.next;

insert into t1 values(4, 5, 'nice');
ob1.oblog.next;

#删除表t1
drop table oblog_db1.t1;
ob1.oblog.next;

# drop database
drop database oblog_db1;
ob1.oblog.next;

# stop liboblog
ob1.oblog.stop;
