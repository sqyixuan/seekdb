#
# owner: fankun.fan
# owner group: libobcdc
# description: distributed transaction
##

ob1=OBI(cluster=1:1:1, init_unit_cpu=5);
ob1.reboot;
ob1.create_client;

source include/liboblog/create_tenant_multiple_zone.inc;

connection oblog_conn_sys;
alter tenant oblog_tt set primary_zone = RANDOM;
let $tenant_id=query_get_value(select tenant_id from __all_tenant where tenant_name='oblog_tt', tenant_id, 1);
ob1.check_until_timeout select count(distinct ls_id)>=3 as ls_num_lt_3 from __all_virtual_ls_meta_table where tenant_id=$tenant_id, 1, 300;

connection oblog_conn_tt;

create database oblog_db1;

use oblog_db1;

let $restart_ts_usec1 = query_get_value(select time_to_usec(now(6)) as now, now, 1);

let $idx = 0;
while ($idx < 10)
{
    eval create table white$idx(id int primary key, c1 varchar(10));
    eval create table black$idx(id int primary key, c1 varchar(10));
    inc $idx;
}

begin;

let $idx = 0;
while ($idx < 10)
{
    eval insert into white$idx values(1, '111');
    eval insert into black$idx values(1, '111');
    inc $idx;
}

commit;

# 重新启动libobcdc
ob1.oblog.gen_conf tb_white_list=oblog_tt.*.* log_level=DEBUG skip_ob_version_compat_check=1;
ob1.oblog.set_start_tstamp_usec $restart_ts_usec1;
ob1.oblog.set_extra_argument '-c';
ob1.oblog.restart;

ob1.oblog.next_dml;

ob1.oblog.stop;

ob1.oblog.gen_conf tb_white_list=oblog_tt.*.white* tb_black_list=oblog_tt.*.black* log_level=DEBUG meta_data_refresh_mode=data_dict skip_ob_version_compat_check=1;
ob1.oblog.set_extra_argument -m;
ob1.oblog.restart;
ob1.oblog.stop;

ob1.oblog.gen_conf tb_white_list=oblog_tt.*.white* tb_black_list=oblog_tt.*.black* log_level=DEBUG skip_ob_version_compat_check=1;
ob1.oblog.set_extra_argument -m;
ob1.oblog.restart;
ob1.oblog.stop;
