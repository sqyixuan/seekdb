insert /*+ enable_parallel_dml parallel(2) direct(true, 0, 'inc_replace') */ into t3_pqTly6tEb1 select c1, json_object('c2', c2) as c2 from t4_pqTly6tEb1;
ob1.oblog.next;
inc $dml_stmt_count;

delete from t3_pqTly6tEb1;
