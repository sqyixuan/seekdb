--echo ================ test rollback to savepoint =========

create table t1_pqTly6tEb1  (c1 int primary key, c2 int);
ob1.oblog.next;
inc $ddl_stmt_count;

create table t2_pqTly6tEb1  (c1 int primary key, c2 int);
ob1.oblog.next;
inc $ddl_stmt_count;

insert into t1_pqTly6tEb1 values(1,2),(3,4),(5,6);
ob1.oblog.next;
inc $dml_stmt_count;

begin;
insert /*+ enable_parallel_dml parallel(2) direct(true, 0, 'inc_replace') */ into t2_pqTly6tEb1 select * from t1_pqTly6tEb1;
savepoint sv1;
insert into t2_pqTly6tEb1 values(7,8);
rollback to savepoint sv1;
commit;
ob1.oblog.next;
inc $dml_stmt_count;

delete from t2_pqTly6tEb1;
ob1.oblog.next;
inc $dml_stmt_count;

begin;
insert into t2_pqTly6tEb1 values(7,8);
savepoint sv1;
insert /*+ enable_parallel_dml parallel(2) direct(true, 0, 'inc_replace') */ into t2_pqTly6tEb1 select * from t1_pqTly6tEb1;
rollback to savepoint sv1;
commit;
ob1.oblog.next;
inc $dml_stmt_count;

# test load data ignore duplicate
truncate table t3_pqTly6tEb1;
ob1.oblog.next;
inc $ddl_stmt_count;

insert into t3_pqTly6tEb1 values(5,'hello'), (6, 'world'), (3, 'maybe very long text longer than ten chars');
ob1.oblog.next;
inc $dml_stmt_count;

--disable_query_log
eval load data /*+ direct(true, 0, 'inc') */ infile '$OBSERVER_DIR/$DATA_FOLDER_NAME/misc/load_data_inc3.csv' ignore into table t3_pqTly6tEb1 fields terminated by ',';
--enable_query_log
ob1.oblog.next;
inc $dml_stmt_count;

drop table t1_pqTly6tEb1;
ob1.oblog.next;
inc $ddl_stmt_count;

drop table t2_pqTly6tEb1;
ob1.oblog.next;
inc $ddl_stmt_count;

drop table t3_pqTly6tEb1;
ob1.oblog.next;
inc $ddl_stmt_count;

--echo ================ test big lob =========

connection oblog_conn_sys;
alter tenant oblog_tt set variables max_allowed_packet=1073741824;
ob1.oblog.next;
inc $ddl_stmt_count;

# 在oblog_tt租户下操作
sleep 2;
connect (oblog_conn_tt,$ip,root@oblog_tt,,oceanbase,$port);
connection oblog_conn_tt;
# 设置最大包大小 1G
set global max_allowed_packet=1073741824;

connection oblog_conn_tt;

use test;

set @text:=repeat('a', 63210);
set @long_text:=repeat('b', 50331647);
set @long_blob:=repeat('c', 50331647);

select md5(@text);
select md5(@long_text);
select md5(@long_blob);

create table t1_pqTly6tEb1  (c1 int primary key, c2 text, c3 longtext, c4 longblob);
ob1.oblog.next;
inc $ddl_stmt_count;

create table t2_pqTly6tEb1  (c1 int primary key, c2 text, c3 longtext, c4 longblob);
ob1.oblog.next;
inc $ddl_stmt_count;

insert into t1_pqTly6tEb1 values(1, @text, @long_text, @long_blob);
ob1.oblog.next;
inc $dml_stmt_count;

insert into t2_pqTly6tEb1 values(1, 'a', 'b', 'c');
ob1.oblog.next;
inc $dml_stmt_count;

insert /*+ enable_parallel_dml parallel(2) direct(true, 0, 'inc_replace') */ into t2_pqTly6tEb1 select * from t1_pqTly6tEb1;
ob1.oblog.next;
inc $dml_stmt_count;

begin;
update t2_pqTly6tEb1 set c3=@long_blob where c1=1;
insert into t2_pqTly6tEb1 values(2, @text, @long_text, @long_blob);
savepoint sv1;
insert /*+ enable_parallel_dml parallel(2) direct(true, 0, 'inc_replace') */ into t2_pqTly6tEb1 select * from t1_pqTly6tEb1;
savepoint sv2;
insert into t2_pqTly6tEb1 values(3, @text, @long_text, @long_blob);
rollback to savepoint sv1;
commit;
ob1.oblog.next;
inc $dml_stmt_count;

begin;
delete from t2_pqTly6tEb1;
insert /*+ enable_parallel_dml parallel(2) direct(true, 0, 'inc_replace') */ into t2_pqTly6tEb1 select * from t1_pqTly6tEb1;
savepoint sv1;
insert into t2_pqTly6tEb1 values(2, @text, @long_text, @long_blob);
rollback to savepoint sv1;
commit;
ob1.oblog.next;
inc $dml_stmt_count;

