#
# owner: fankun.fan
# owner group: libobcdc
# description: support direct load inc
##

ob1=OBI(cluster=1,init_unit_cpu=5);
ob1.reboot;
ob1.create_client;

# 创建mysql租户oblog_tt，并且切换到mysql租户下
source include/liboblog/create_tenant_with_gts.inc;

let $OBSERVER_DIR=deploy_get_value(ob1.z1.obs0.workdir);
let $HOST_IP=query_get_value(select host_ip() as host_ip, host_ip, 1);
let $DATA_FOLDER_NAME = mysqltest_data_direct_load_inc;

# create file
--disable_query_log
let $SCP_CMD = ssh $HOST_IP 'mkdir -p "$OBSERVER_DIR/$DATA_FOLDER_NAME"' && scp -r include/liboblog/direct_load_data/* $HOST_IP:"$OBSERVER_DIR/$DATA_FOLDER_NAME";
exec $SCP_CMD;
--enable_query_log

ob1.mysql alter system set dump_data_dictionary_to_log_interval = '6s' tenant all;

let $restart_ts_usec1 = query_get_value(select time_to_usec(now(6)) as now, now, 1);

# set secure_file_priv
ob1.z1.obs0.sh obclient -S $OBSERVER_DIR/run/sql.sock -uroot@oblog_tt -Dtest -A -e 'SET GLOBAL secure_file_priv=\"/\"';

connect (oblog_conn_tt,$ip,root@oblog_tt,,oceanbase,$port);
connection oblog_conn_tt;
let $mysql_tenant_name=oblog_tt;
source include/liboblog/set_direct_load_allow_fallback_false.inc;
connection oblog_conn_tt;
use test;

set ob_default_lob_inrow_threshold=4096;

--disable_warnings
--disable_query_log
drop table if exists t_pqTly6tEb1;
drop table if exists t1_pqTly6tEb1;
drop table if exists t2_pqTly6tEb1;
drop table if exists t3_pqTly6tEb1;
drop table if exists t4_pqTly6tEb1;
--enable_query_log
--enable_warnings

# 启动liboblog，同步oblog_tt租户数据
ob1.oblog.gen_conf tb_white_list=oblog_tt.*.* enable_direct_load_inc=1;
ob1.oblog.set_extra_argument -m;
ob1.oblog.restart;

select md5('hello');
select md5('world');
select md5(repeat('1', 7000));
select md5('kkk');

--echo ================ test rowkey table =========
create table t_pqTly6tEb1  (c1 int primary key, c2 int);
ob1.oblog.next;

insert into t_pqTly6tEb1 values(-100, 5);
ob1.oblog.next;
sleep 30;
--disable_query_log
eval load data /*+ direct(true, 0, 'inc_replace') */ infile '$OBSERVER_DIR/$DATA_FOLDER_NAME/misc/load_data_inc0.csv' into table t_pqTly6tEb1 fields terminated by ',';
ob1.oblog.next;
eval load data /*+ direct(true, 0, 'inc_replace') */ infile '$OBSERVER_DIR/$DATA_FOLDER_NAME/misc/load_data_inc1.csv' into table t_pqTly6tEb1 fields terminated by ',';
ob1.oblog.next;
eval load data /*+ direct(true, 0, 'inc_replace') */ infile '$OBSERVER_DIR/$DATA_FOLDER_NAME/misc/load_data_inc2.csv' into table t_pqTly6tEb1 fields terminated by ',';
ob1.oblog.next;
--enable_query_log

insert into t_pqTly6tEb1 values(100,4);
ob1.oblog.next;

drop table t_pqTly6tEb1;
ob1.oblog.next;

--echo ================ test heap table =========
# 测试堆表

create table t_pqTly6tEb1  (c1 int, c2 int);
ob1.oblog.next;

insert into t_pqTly6tEb1 values(-100, 5);
ob1.oblog.next;

--disable_query_log
eval load data /*+ direct(true, 0, 'inc_replace') */ infile '$OBSERVER_DIR/$DATA_FOLDER_NAME/misc/load_data_inc0.csv' into table t_pqTly6tEb1 fields terminated by ',';
ob1.oblog.next;
--enable_query_log

insert into t_pqTly6tEb1 values(100,4);
ob1.oblog.next;

# select * from t_pqTly6tEb1;

drop table t_pqTly6tEb1;
ob1.oblog.next;

--echo ================ test insert into select =========
# 测试insert into select

create table t1_pqTly6tEb1  (c1 int primary key, c2 int);
ob1.oblog.next;
create table t2_pqTly6tEb1  (c1 int primary key, c2 int);
ob1.oblog.next;

insert into t1_pqTly6tEb1 values(1,2),(3,4),(5,6);
ob1.oblog.next;
insert /*+ enable_parallel_dml parallel(2) direct(true, 0, 'inc_replace') */ into t2_pqTly6tEb1 select * from t1_pqTly6tEb1;
ob1.oblog.next;

# select * from t2_pqTly6tEb1;

delete from t2_pqTly6tEb1;
ob1.oblog.next;


begin;
insert into t2_pqTly6tEb1 values(100, 1);
insert /*+ enable_parallel_dml parallel(2) direct(true, 0, 'inc_replace') */ into t2_pqTly6tEb1 select * from t1_pqTly6tEb1;
# select * from t2_pqTly6tEb1;
rollback;

# select * from t2_pqTly6tEb1;


begin;
insert into t2_pqTly6tEb1 values(100, 1);
insert /*+ enable_parallel_dml parallel(2) direct(true, 0, 'inc_replace') */ into t2_pqTly6tEb1 select * from t1_pqTly6tEb1;
insert into t2_pqTly6tEb1 values(101, 1);
# select * from t2_pqTly6tEb1;
rollback;

# select * from t2_pqTly6tEb1;

let $ddl_stmt_count = 0;
let $dml_stmt_count = 0;
sleep 2;
begin;
insert into t2_pqTly6tEb1 values(100, 1);
insert /*+ enable_parallel_dml parallel(2) direct(true, 0, 'inc_replace') */ into t2_pqTly6tEb1 select * from t1_pqTly6tEb1;

let $restart_ts_usec2 = query_get_value(select time_to_usec(now(6)) as now, now, 1);
insert into t2_pqTly6tEb1 values(101, 1);
# select * from t2_pqTly6tEb1;
commit;
ob1.oblog.next;
inc $dml_stmt_count;


# select * from t2_pqTly6tEb1;


drop table t1_pqTly6tEb1;
ob1.oblog.next;
inc $ddl_stmt_count;
drop table t2_pqTly6tEb1;
ob1.oblog.next;
inc $ddl_stmt_count;

