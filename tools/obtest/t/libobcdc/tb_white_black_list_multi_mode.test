#
# owner: fankun.fan
# owner group: libobcdc
# description: json, gis
##

ob1=OBI(cluster=1,init_unit_cpu=5);
ob1.reboot;
ob1.create_client;

# 创建mysql租户oblog_tt，并且切换到mysql租户下
--disable_result_log
source include/liboblog/create_tenant_with_srs.inc;
--enable_result_log

# 启动liboblog，同步oblog_tt租户数据
ob1.oblog.gen_conf tb_white_list=oblog*.*.white* tb_black_list=oblog*.*.black* log_level=DEBUG skip_ob_version_compat_check=1 enable_output_by_table_def=1;
ob1.oblog.set_extra_argument -m;
ob1.oblog.restart;

let $restart_ts_usec1 = query_get_value(select time_to_usec(now(6)) as now, now, 1);

let $ddl_stmt_count = 0;
let $white_dml_stmt_count = 0;
let $black_dml_stmt_count = 0;

# 创建database 1
create database oblog_db1;
ob1.oblog.next;
inc $ddl_stmt_count;

# ob1.mysql alter system set dump_data_dictionary_to_log_interval = '6s' tenant all;

use oblog_db1;

# 创建黑白名单测试表
create table white0(id int);
ob1.oblog.next;
inc $ddl_stmt_count;

set @a:=concat('[',repeat('"a",',200000),'"a"]');
set @z:=concat('[',repeat('"z",',200000),'"z"]');

# 创建无json列的表
create table white1(pk int primary key);
ob1.oblog.next;
inc $ddl_stmt_count;

# NULL
insert into white1 values(1);
ob1.oblog.next;
inc $white_dml_stmt_count;

# 增加json列
alter table white1 add column json_col_1 json;
ob1.oblog.next;
inc $ddl_stmt_count;

# NULL
insert into white1 values(2, NULL);
ob1.oblog.next;
inc $white_dml_stmt_count;

# 删除json列
alter table white1 drop column json_col_1;
ob1.oblog.next;
inc $ddl_stmt_count;

# NULL
insert into white1 values(3);
ob1.oblog.next;
inc $white_dml_stmt_count;

# 创建单列json的表
create table white2(pk int primary key, json_col_1 json);
ob1.oblog.next;
inc $ddl_stmt_count;

# NULL
insert into white2 values(1, NULL);
ob1.oblog.next;
inc $white_dml_stmt_count;

# @a
insert into white2 values(2, @a);
ob1.oblog.next;
inc $white_dml_stmt_count;

# 删除json列
alter table white2 drop column json_col_1;
ob1.oblog.next;
inc $ddl_stmt_count;
insert into white2 values(3);
ob1.oblog.next;
inc $white_dml_stmt_count

# 增加json列
alter table white2 add column json_col_1 json;
ob1.oblog.next;
inc $ddl_stmt_count;
insert into white2 values(4, @a);
ob1.oblog.next;
inc $white_dml_stmt_count;

# 创建多列json表
create table white3(pk int primary key, json_col_1 json, json_col_2 json);
ob1.oblog.next;
inc $ddl_stmt_count;

# NULL
insert into white3 values(1, NULL, NULL);
ob1.oblog.next;
inc $white_dml_stmt_count;

# @a
insert into white3 values(2, @a, @a);
ob1.oblog.next;
inc $white_dml_stmt_count;

# 增加json列
alter table white3 add column json_col_3 json;
ob1.oblog.next;
inc $ddl_stmt_count;
insert into white3 values(3, @a, @a, @a);
ob1.oblog.next;
inc $white_dml_stmt_count;

# 增加多个json列
alter table white3 add column (json_col_4 json, json_col_5 json);
ob1.oblog.next;
inc $ddl_stmt_count;
insert into white3 values(4, @a, @a, @a, @a, @a);
ob1.oblog.next;
inc $white_dml_stmt_count;

# 重命名json列
alter table white3 rename column json_col_1 to json_col_11;
ob1.oblog.next;
inc $ddl_stmt_count;
insert into white3 values(5, @a, @a, @a, @a, @a);
ob1.oblog.next;
inc $white_dml_stmt_count;
alter table white3 rename column json_col_11 to json_col_1;
ob1.oblog.next;
inc $ddl_stmt_count;
insert into white3 values(6, @a, @a, @a, @a, @a);
ob1.oblog.next;
inc $white_dml_stmt_count;

# 删除1个json列
alter table white3 drop column json_col_3;
ob1.oblog.next;
inc $ddl_stmt_count;
insert into white3 values(7, @a, @a, @a, @a);
ob1.oblog.next;
inc $white_dml_stmt_count;

# 增加1个json列
alter table white3 add column json_col_3 json after json_col_2;
ob1.oblog.next;
inc $ddl_stmt_count;
insert into white3 values(8, @a, @a, @a, @a, @a);
ob1.oblog.next;
inc $white_dml_stmt_count;

# 删除全部json列
alter table white3 drop column json_col_1;
ob1.oblog.next;
inc $ddl_stmt_count;
alter table white3 drop column json_col_2;
ob1.oblog.next;
inc $ddl_stmt_count;
alter table white3 drop column json_col_3;
ob1.oblog.next;
inc $ddl_stmt_count;
alter table white3 drop column json_col_4;
ob1.oblog.next;
inc $ddl_stmt_count;
alter table white3 drop column json_col_5;
ob1.oblog.next;
inc $ddl_stmt_count;
insert into white3 values(9);
ob1.oblog.next;
inc $white_dml_stmt_count;

# 重命名为黑名单
rename table oblog_db1.white3 to oblog_db1.black3;
ob1.oblog.next;
inc $ddl_stmt_count;

# 测试黑名单
insert into black3 values(10);
insert into white0 values(1);
ob1.oblog.next;
inc $black_dml_stmt_count;
inc $white_dml_stmt_count;

# 创建带有lob列的黑名单表
create table black1(pk int primary key, json_col_1 json);
ob1.oblog.next;
inc $ddl_stmt_count;

# NULL
insert into black1 values(1, NULL);
insert into white0 values(2);
ob1.oblog.next;
inc $black_dml_stmt_count;
inc $white_dml_stmt_count;

# 删除json列
alter table black1 drop column json_col_1;
ob1.oblog.next;
inc $ddl_stmt_count;

# NULL
insert into black1 values(2);
insert into white0 values(3);
ob1.oblog.next;
inc $black_dml_stmt_count;
inc $white_dml_stmt_count;

# 增加lob列
alter table black1 add column json_col_1 json;
ob1.oblog.next;
inc $ddl_stmt_count;

# NULL;
insert into black1 values(3, NULL);
insert into white0 values(4);
ob1.oblog.next;
inc $black_dml_stmt_count;
inc $white_dml_stmt_count;

# GIS
create table white4(g GEOMETRY);
ob1.oblog.next;
inc $ddl_stmt_count;

insert into white4 values(_st_geomfromewkt('srid=4269;POINT(15 20)'));
ob1.oblog.next;
inc $white_dml_stmt_count;

# 增加空间列
alter table white4 add column pt point;
ob1.oblog.next;
inc $ddl_stmt_count;

insert into white4 values(_st_geomfromewkt('srid=4269;POINT(1 2)'),_st_geomfromewkt('srid=4269;POINT(3 4)'));
ob1.oblog.next;
select _ST_ASEWKT(g), md5(_ST_ASEWKT(g)), _ST_ASEWKT(pt), md5(_ST_ASEWKT(pt)) from white4;
inc $white_dml_stmt_count;

# 删除空间列
alter table white4 drop column pt;
ob1.oblog.next;
inc $ddl_stmt_count;

insert into white4 values(_st_geomfromewkt('srid=4269;POINT(5 6)'));
ob1.oblog.next;
inc $white_dml_stmt_count;
select _ST_ASEWKT(g), md5(_ST_ASEWKT(g)) from white4;

# 重命名为黑名单
alter table white4 rename to black4;
ob1.oblog.next;
inc $ddl_stmt_count;

insert into black4 values(ST_GeomFromText('POINT(7 8)'));
insert into white0 values(5);
ob1.oblog.next;
inc $white_dml_stmt_count;
inc $black_dml_stmt_count;

sleep 10;
ob1.oblog.stop;

# 回拉，启动liboblog，同步oblog_tt租户数据
ob1.oblog.gen_conf tb_white_list=oblog*.*.white* tb_black_list=oblog*.*.black* log_level=DEBUG meta_data_refresh_mode=data_dict skip_ob_version_compat_check=1 enable_output_by_table_def=1;
ob1.oblog.set_extra_argument -m;
ob1.oblog.set_start_tstamp_usec $restart_ts_usec1;
ob1.oblog.restart;

let $stmt_count = $ddl_stmt_count + $white_dml_stmt_count;

let $idx = 0;
while ($idx < $stmt_count)
{
    ob1.oblog.next;
    inc $idx;
}

ob1.oblog.stop;

# 回拉，启动liboblog，同步oblog_tt租户数据
ob1.oblog.gen_conf tb_white_list=oblog*.*.black* tb_black_list=oblog*.*.white* log_level=DEBUG meta_data_refresh_mode=data_dict skip_ob_version_compat_check=1 enable_output_by_table_def=1;
ob1.oblog.set_extra_argument -m;
ob1.oblog.set_start_tstamp_usec $restart_ts_usec1;
ob1.oblog.restart;

let $stmt_count = $ddl_stmt_count + $black_dml_stmt_count;

let $idx = 0;
while ($idx < $stmt_count)
{
    ob1.oblog.next;
    inc $idx;
}

ob1.oblog.stop;

ob1.oblog.gen_conf tb_white_list=oblog*.*.white* tb_black_list=oblog*.*.black* log_level=DEBUG meta_data_refresh_mode=data_dict skip_ob_version_compat_check=1 enable_output_by_table_def=1;
ob1.oblog.set_extra_argument -m;
ob1.oblog.restart;
ob1.oblog.stop;

ob1.oblog.gen_conf tb_white_list=oblog*.*.white* tb_black_list=oblog*.*.black* log_level=DEBUG skip_ob_version_compat_check=1 enable_output_by_table_def=1;
ob1.oblog.set_extra_argument -m;
ob1.oblog.restart;
ob1.oblog.stop;
