#
# owner: bohou.ws
# owner group: liboblog
# description:
# 测试点:
#  测试过滤临时表
#  1. 目前支持对临时表create temporary table/drop table的操作
#  2. 目前支持mysql模式，TODO Oracle模式
##

ob1=OBI(cluster=1,init_unit_cpu=5);
ob1.reboot;
ob1.create_client;

# 创建mysql租户oblog_tt，并且切换到mysql租户下
source include/liboblog/create_tenant_with_gts.inc;

# 启动liboblog，同步oblog_tt租户数据
ob1.oblog.gen_conf tb_white_list=oblog_tt.*.* log_level=DEBUG skip_ob_version_compat_check=1;
ob1.oblog.restart;

# 创建database 1
create database oblog_db1;
# 输出create database DDL
ob1.oblog.next;

use oblog_db1;

# 创建表
create table t1(id int, c1 timestamp(6), c2 datetime);
# 输出create table DDL
ob1.oblog.next;

# 执行AC=1的DML事务
insert into t1 values(1, '2019-1-30 12:00:00.123456', '2019-1-30 12:00:00');
# 输出上述事务
ob1.oblog.next;

# 创建临时表
create temporary table t1_tmp(d1 int, d2 datetime);

# 向临时表写数据
insert into t1_tmp values(2, '2020-8-30 00:00:00');

update t1_tmp set d2='2020-9-01 00:00:00' where d1=2;

delete from t1_tmp where d1=2;

# drop 临时表
drop temporary table t1_tmp;

# update 原始表
update t1 set c2='2019-1-31 00:00:00' where id=1;
# 输出update该原始表的DML
ob1.oblog.next;

# 执行drop table DDL
drop table t1;
# 输出drop table DDL
ob1.oblog.next;

# set系统变量不会生成redo日志，不需要迭代数据
set @@time_zone = '+06:00';

# stop liboblog
ob1.oblog.stop;
