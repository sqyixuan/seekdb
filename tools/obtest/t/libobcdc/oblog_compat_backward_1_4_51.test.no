# owner:千溪
# owner group:liboblog
# 测试点：测试liboblog的向前兼容性，采用最新版本liboblog向老版本observer取日志
# 1. 要求schema模块向前兼容，新版本schema可以连接老版本observer构建起来
# 2. 要求liboblog取日志模块向前兼容

# OB版本是1.4.51
# liboblog版本是当前版本
ob1=OBI(cluster=1:1:1,init_unit_cpu=5,init_unit_num=1,init_unit_mem=5368709120,version=1_4_51,oblog_version=current);
ob1.reboot;
let $SCHEMA_SPLIT_MODE=1;
let $is_schema_split_mode=0;
sleep 5;

########### 1.创建mysql租户: oblog_tt
source include/liboblog/tenant/create_tenant_under_1_4_7.inc;

########### 2. source 相关场景测试, 在source中不允许新建租户，除了有删除租户场景
source include/oblog_compat_backward_common.inc;
source include/all_ddl_type.inc;
source include/all_ddl_type_1.4.4_upder_147.inc;
source include/all_ddl_type_1.4.50.inc;
source include/145_lob_data.inc;
