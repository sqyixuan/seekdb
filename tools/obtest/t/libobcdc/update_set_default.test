#
# owner: bohou.ws
# owner group: liboblog
# description:
# 测试点:
#  set default value for column (obtest copy from mysql test liboblog_t/update_set_default.test)
##

ob1=OBI(cluster=1,init_unit_cpu=5);
ob1.reboot;
ob1.create_client;

# 创建mysql租户oblog_tt，并且切换到mysql租户下
source include/liboblog/create_tenant_with_gts.inc;
connect (oblog_conn_tt_ddl,$ip,root@oblog_tt,,oceanbase,$port);
connection oblog_conn_tt;
# 启动liboblog，同步oblog_tt租户数据
ob1.oblog.gen_conf tb_white_list=oblog_tt.*.* log_level=DEBUG skip_ob_version_compat_check=1;
ob1.oblog.restart;
# wait obcdc start.
sleep 30;
create database oblog_db;
ob1.oblog.next;

use oblog_db;

set @@session.explicit_defaults_for_timestamp=off;

create table test (c1 int auto_increment primary key, c2 int not null, c3 int not null default 3,c4 char(10) not null, c5 char(10) not null default 'hello',c6 timestamp not null default '2020-01-01 00:00:00', c7 timestamp not null default '1998-09-23 12:34:12',c8 time not null, c9 time not null default '12:23:23',c10 datetime not null, c11 datetime not null default '1998-09-23 12:34:12');
ob1.oblog.next;
set @@sql_mode='strict_all_tables,strict_trans_tables';
insert into test(c1,c2,c3,c4,c5,c6,c7,c8,c9,c10,c11) values(1, 100, 100,'y','y','1999-09-09 12:09:09', '1999-09-09 12:09:09','12:12:12','12:12:12', '1999-09-09 12:09:09', '1999-09-09 12:09:09');
ob1.oblog.next;
update test set c3=default,c5=default,c6=default,c7=default,c9=default,c11=default;
ob1.oblog.next;
truncate table test;
ob1.oblog.next;
insert into test(c1,c2,c3,c4,c5,c6,c7,c8,c9,c10,c11) values(1, 100, 100,'y','y','1999-09-09 12:09:09', '1999-09-09 12:09:09','12:12:12','12:12:12', '1999-09-09 12:09:09', '1999-09-09 12:09:09');
ob1.oblog.next;
update test set c3=default(c3),c5=default(c5),c6=default(c6),c7=default(c7),c9=default(c9),c11=default(c11);
ob1.oblog.next;

create table test1 (c1 int auto_increment primary key, c2 int, c3 int default 3,c4 char(10), c5 char(10) default 'hello',c6 timestamp default '2020-01-01 00:00:00', c7 timestamp default '1998-09-23 12:34:12',c8 time default '09:06:08', c9 time default '12:23:23',c10 datetime, c11 datetime default '1998-09-23 12:34:12');
ob1.oblog.next;

insert into test1(c1,c2,c3,c4,c5,c6,c7,c8,c9,c10,c11) values(1, 100, 100,'y','y','1999-09-09 12:09:09', '1999-09-09 12:09:09','12:12:12','12:12:12', '1999-09-09 12:09:09', '1999-09-09 12:09:09');
ob1.oblog.next;
update test1 set c2=default,c3=default,c4=default,c5=default,c6=default,c7=default,c8=default,c9=default,c10=default,c11=default;
ob1.oblog.next;
set @@sql_mode='';
truncate table test1;
ob1.oblog.next;
insert into test1(c1,c2,c3,c4,c5,c6,c7,c8,c9,c10,c11) values(1, 100, 100,'y','y','1999-09-09 12:09:09', '1999-09-09 12:09:09','12:12:12','12:12:12', '1999-09-09 12:09:09', '1999-09-09 12:09:09');
ob1.oblog.next;
update test1 set c2=default(c2),c3=default(c3),c4=default(c4),c5=default(c5),c6=default(c6),c7=default(c7),c8=default(c8),c9=default(c9),c10=default(c10),c11=default(c11);
ob1.oblog.next;

delete from test1;
ob1.oblog.next;
insert into test1(c1,c2,c3,c4,c5,c6,c7,c8,c9,c10,c11) values(1, 100, 100,'y','y','1999-09-09 12:09:09', '1999-09-09 12:09:09','12:12:12','12:12:12', '1999-09-09 12:09:09', '1999-09-09 12:09:09');
ob1.oblog.next;
update test1 set c2=default,c3=default,c4=default,c5=default,c6=default,c7=default,c8=default,c9=default,c10=default,c11=default;
ob1.oblog.next;
delete from test1;
ob1.oblog.next;
insert into test1(c1,c2,c3,c4,c5,c6,c7,c8,c9,c10,c11) values(1, 100, 100,'y','y','1999-09-09 12:09:09', '1999-09-09 12:09:09','12:12:12','12:12:12', '1999-09-09 12:09:09', '1999-09-09 12:09:09');
ob1.oblog.next;
update test1 set c2=default(c2),c3=default(c3),c4=default(c4),c5=default(c5),c6=default(c6),c7=default(c7),c8=default(c8),c9=default(c9),c10=default(c10),c11=default(c11);
ob1.oblog.next;


create table test2 (c1 int auto_increment primary key, c2 int not null, c3 int not null default 3,c4 char(10) not null, c5 char(10) not null default 'hello',c6 timestamp not null default '2020-01-01 00:00:00', c7 timestamp not null default '1998-09-23 12:34:12',c8 time not null default '09:06:08', c9 time not null default '12:23:23',c10 datetime not null, c11 datetime not null default '1998-09-23 12:34:12');
ob1.oblog.next;
insert into test2(c1,c2,c3,c4,c5,c6,c7,c8,c9,c10,c11) values(1, 100, 100,'y','y','1999-09-09 12:09:09', '1999-09-09 12:09:09','12:12:12','12:12:12', '1999-09-09 12:09:09', '1999-09-09 12:09:09');
ob1.oblog.next;
update test2 set c2=default,c3=default,c4=default,c5=default,c6=default,c7=default,c8=default,c9=default,c10=default,c11=default;
ob1.oblog.next;
delete from test2;
ob1.oblog.next;
insert into test2(c1,c2,c3,c4,c5,c6,c7,c8,c9,c10,c11) values(1, 100, 100,'y','y','1999-09-09 12:09:09', '1999-09-09 12:09:09','12:12:12','12:12:12', '1999-09-09 12:09:09', '1999-09-09 12:09:09');
ob1.oblog.next;
update test2 set c3=default(c3),c5=default(c5),c6=default(c6),c7=default(c7),c9=default(c9),c11=default(c11);
ob1.oblog.next;

# test dist_ddl
connection oblog_conn_sys;
alter system set _ob_ddl_timeout = '2s';
source include/liboblog/check_schema_fast_sync.inc;
connection oblog_conn_tt;
set autocommit=0;
begin;
insert into test2(c1,c2,c3,c4,c5,c6,c7,c8,c9,c10,c11) values(2, 100, 100,'y','y','1999-09-09 12:09:09', '1999-09-09 12:09:09','12:12:12','12:12:12', '1999-09-09 12:09:09', '1999-09-09 12:09:09');
insert into test1(c1,c2,c3,c4,c5,c6,c7,c8,c9,c10,c11) values(2, 100, 100,'y','y','1999-09-09 12:09:09', '1999-09-09 12:09:09','12:12:12','12:12:12', '1999-09-09 12:09:09', '1999-09-09 12:09:09');

connection oblog_conn_tt_ddl;
use oblog_db;
send truncate table test2;truncate table test1;
sleep 10;
connection oblog_conn_tt;
# expect truncate failed.
select count(*) from test1;
select count(*) from test2;
commit;
select count(*) from test1;
select count(*) from test2;
ob1.oblog.next;

connection oblog_conn_sys;
alter system set _ob_ddl_timeout = '16s';
source include/liboblog/check_schema_fast_sync.inc;

connection oblog_conn_tt;
set autocommit=0;
begin;
insert into test2(c1,c2,c3,c4,c5,c6,c7,c8,c9,c10,c11) values(3, 100, 100,'y','y','1999-09-09 12:09:09', '1999-09-09 12:09:09','12:12:12','12:12:12', '1999-09-09 12:09:09', '1999-09-09 12:09:09');
insert into test1(c1,c2,c3,c4,c5,c6,c7,c8,c9,c10,c11) values(3, 100, 100,'y','y','1999-09-09 12:09:09', '1999-09-09 12:09:09','12:12:12','12:12:12', '1999-09-09 12:09:09', '1999-09-09 12:09:09');
connect (oblog_conn_tt_ddl1,$ip,root@oblog_tt,,oblog_db,$port);
connection oblog_conn_tt_ddl1;
send truncate table test2;truncate table test1;
sleep 2;
connection oblog_conn_tt;
# expect truncate success.
select count(*) from test1;
select count(*) from test2;
commit;
ob1.oblog.next;
# wait truncate
sleep 8;
select count(*) from test1;
select count(*) from test2;
# truncate test1
ob1.oblog.next;
# truncate test2
ob1.oblog.next;

drop table test, test1, test2;
ob1.oblog.next;

ob1.oblog.stop;
