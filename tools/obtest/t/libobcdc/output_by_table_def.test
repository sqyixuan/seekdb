# owner: wenyue.zxl
# owner group: libobcdc
# test point: test the correctness of libobcdc when enable_output_by_table_def is enabled;
#             consider various cases, include tables without primary key/alter table add or drop column/
#             change the order of column/invisible column/hidden column/virtual column/stored generated column/lob/ etc.

ob1=OBI(cluster=1:1:1, init_unit_cpu=5);
ob1.reboot;

source include/liboblog/create_tenant.inc;

alter system set dump_data_dictionary_to_log_interval = '3s';
sleep 4;

create database oblog_db1;
use oblog_db1;

let $start_timestamp_usec = query_get_value(select time_to_usec(now(6)) as now, now, 1);

ob1.oblog.gen_conf tb_white_list=oblog_tt.*.* log_level=DEBUG enable_output_hidden_primary_key=1 enable_output_by_table_def=1 skip_ob_version_compat_check=1;
ob1.oblog.restart;

let $dml_cnt = 0;
let $restart1_cnt = 0;
let $restart2_cnt = 0;

echo "#################### [CASE_BEGIN] Non-primary-key Table ####################";

# c1 c2 c3 __pk_increment
create table non_pk_tbl(c1 int, c2 varchar(10), c3 text);

insert into non_pk_tbl values (1, '11', '111');
inc $dml_cnt;
inc $restart1_cnt;
ob1.oblog.next_dml;

insert into non_pk_tbl values (2, '22', '222');
inc $dml_cnt;
inc $restart1_cnt;
ob1.oblog.next_dml;

update non_pk_tbl set c2 = '222' where c1 = 1;
inc $dml_cnt;
inc $restart1_cnt;
ob1.oblog.next_dml;

# c1 c2 c3 __pk_increment c4

alter table non_pk_tbl add column c4 int default 9999;

insert into non_pk_tbl values (3, '33', '333', 3333);
inc $dml_cnt;
inc $restart1_cnt;
ob1.oblog.next_dml;

delete from non_pk_tbl where c1=1;
inc $dml_cnt;
inc $restart1_cnt;
ob1.oblog.next_dml;

alter table non_pk_tbl modify c4 int first, modify c3 text after c4, modify c2 varchar(10) after c3, modify c1 int after c2;

# c4 c3 c2 c1 __pk_increment

insert into non_pk_tbl values (4444, '444', '44', 4);
inc $dml_cnt;
inc $restart1_cnt;
ob1.oblog.next_dml;

# c4 c3 c2 c1

alter table non_pk_tbl add primary key (c1, c4);

insert into non_pk_tbl values (5555, '555', '55', 5);
inc $dml_cnt;
inc $restart1_cnt;
ob1.oblog.next_dml;

update non_pk_tbl set c3='5555', c2='555' where c1=5;
inc $dml_cnt;
inc $restart1_cnt;
ob1.oblog.next_dml;

delete from non_pk_tbl where c1=5;
inc $dml_cnt;
inc $restart1_cnt;
ob1.oblog.next_dml;

# c3 c4 c1 c2

alter table non_pk_tbl modify c3 text first, modify c2 varchar(10) after c1;

insert into non_pk_tbl(c1, c2 ,c3, c4) values (5, 'c2c2', 'c3c3c3', 5555);
inc $dml_cnt;
inc $restart1_cnt;
ob1.oblog.next_dml;

update non_pk_tbl set c3='5555', c2='555' where c1=5;
inc $dml_cnt;
inc $restart1_cnt;
ob1.oblog.next_dml;

delete from non_pk_tbl where c1=5;
inc $dml_cnt;
inc $restart1_cnt;
ob1.oblog.next_dml;

# c3 c4 c1 c2 __pk_increment

alter table non_pk_tbl drop primary key;

insert into non_pk_tbl(c1, c2, c3, c4) values (6, '66', '666', 6666);
inc $dml_cnt;
inc $restart1_cnt;
ob1.oblog.next_dml;

echo "#################### [CASE_END] Non-primary-key Table ####################";

echo "#################### [CASE_BEGIN] Generated Virtual Column ####################";

create table gen_virtual_tbl (c1 int, c2 int, c3 int generated always as (c1 + c2) virtual);

# c1 c2 __pk_increment

insert into gen_virtual_tbl(c1, c2) values (1, 1);
inc $dml_cnt;
inc $restart1_cnt;
ob1.oblog.next_dml;

insert into gen_virtual_tbl(c1, c2) values (2, 1);
inc $dml_cnt;
inc $restart1_cnt;
ob1.oblog.next_dml;

# c1 c2

alter table gen_virtual_tbl add primary key (c1);

insert into gen_virtual_tbl(c1, c2) values (3, 1);
inc $dml_cnt;
inc $restart1_cnt;
ob1.oblog.next_dml;

sleep 4;
let $restart_ts_us1 = query_get_value(select time_to_usec(now(6)) as now, now, 1);

# c2 c1

alter table gen_virtual_tbl modify column c2 int first, modify c1 int after c2;

insert into gen_virtual_tbl(c1, c2) values (4, 1);
inc $dml_cnt;
inc $restart2_cnt;
ob1.oblog.next_dml;

# c4 c2 c1
alter table gen_virtual_tbl add column c4 varchar(10) first;

insert into gen_virtual_tbl(c1, c2 ,c4) values (5, 1, 'OceanBase');
inc $dml_cnt;
inc $restart2_cnt;
ob1.oblog.next_dml;

# c4 c2 c1 __pk_increment

alter table gen_virtual_tbl drop primary key;

insert into gen_virtual_tbl(c1, c2, c4) values (6, 1, '66666');
inc $dml_cnt;
inc $restart2_cnt;
ob1.oblog.next_dml;

echo "#################### [CASE_END] Generated Virtual Column ####################";

echo "#################### [CASE_BEGIN] Generated Stored Column ####################";

create table gen_stored_tbl (c1 int, c2 int, c3 int generated always as (c1 + c2) stored);

# c1 c2 c3 __pk_increment

insert into gen_stored_tbl(c1, c2) values (1, 1);
inc $dml_cnt;
inc $restart2_cnt;
ob1.oblog.next_dml;

insert into gen_stored_tbl(c1, c2) values (2, 1);
inc $dml_cnt;
inc $restart2_cnt;
ob1.oblog.next_dml;

# c1 c2 c3

alter table gen_stored_tbl add primary key (c1);

insert into gen_stored_tbl(c1, c2) values (3, 1);
inc $dml_cnt;
inc $restart2_cnt;
ob1.oblog.next_dml;

# c3 c2 c1

alter table gen_stored_tbl modify c3 int generated always as (c1 + c2) stored first, modify column c2 int after c3, modify c1 int after c2;

insert into gen_stored_tbl(c1, c2) values (4, 1);
inc $dml_cnt;
inc $restart2_cnt;
ob1.oblog.next_dml;

# c4 c3 c2 c1
alter table gen_stored_tbl add column c4 varchar(10) first;

insert into gen_stored_tbl(c1, c2 ,c4) values (5, 1, 'OceanBase');
inc $dml_cnt;
inc $restart2_cnt;
ob1.oblog.next_dml;

# c4 c3 c2 c1 __pk_increment

alter table gen_stored_tbl drop primary key;

insert into gen_stored_tbl(c1, c2, c4) values (6, 1, '66666');
inc $dml_cnt;
inc $restart2_cnt;
ob1.oblog.next_dml;

echo "#################### [CASE_END] Generated Stored Column ####################";

echo "#################### [CASE_BEGIN] Hidden Column ####################";

create table hidden_tbl (c1 int, c2 varchar(10));

insert into hidden_tbl values (1, 'aaaaa');
inc $dml_cnt;
inc $restart2_cnt;
ob1.oblog.next_dml;

alter table hidden_tbl add index hd_idx (c2(5));

insert into hidden_tbl values (2, 'bbbbb');
inc $dml_cnt;
inc $restart2_cnt;
ob1.oblog.next_dml;

alter table hidden_tbl add primary key (c1);

insert into hidden_tbl values (3, 'ccccc');
inc $dml_cnt;
inc $restart2_cnt;
ob1.oblog.next_dml;

alter table hidden_tbl drop index hd_idx;

insert into hidden_tbl values (4, 'ddddd');
inc $dml_cnt;
inc $restart2_cnt;
ob1.oblog.next_dml;

echo "#################### [CASE_END] Hidden Column ####################";

echo "#################### [CASE_BEGIN] Mixed Scenario ####################";

create table t1(id int);

insert into t1 values (1);
inc $dml_cnt;
inc $restart2_cnt;
ob1.oblog.next_dml;

alter table t1 add column c1 int default 1;

# id __pk_increment c1

delete from t1 where id=1;
inc $dml_cnt;
inc $restart2_cnt;
ob1.oblog.next_dml;

alter table t1 add unique index unique_id_idx (id);

insert into t1(id, c1) values (1, NULL);
inc $dml_cnt;
inc $restart2_cnt;
ob1.oblog.next_dml;

update t1 set c1=1 where id=1;
inc $dml_cnt;
inc $restart2_cnt;
ob1.oblog.next_dml;

insert into t1 values (2, 2);
inc $dml_cnt;
inc $restart2_cnt;
ob1.oblog.next_dml;

sleep 4;
let $restart_ts_us2 = query_get_value(select time_to_usec(now(6)) as now, now, 1);

# id (c2) __pk_increment c1

alter table t1 add column c2 int as (c1+1) virtual after id;

insert into t1(id,c1) values (3, 3);
inc $dml_cnt;
ob1.oblog.next_dml;

alter table t1 add column c3 int as (c1*2) stored first;

# c3 id (c2) __pk_increment c1

insert into t1(id,c1) values (4, 4);
inc $dml_cnt;
ob1.oblog.next_dml;

alter table t1 add primary key (id, c1);

# c3 id (c2) c1

insert into t1(id,c1) values (5, 5);
inc $dml_cnt;
ob1.oblog.next_dml;

create unique index unique_c1_ind on t1(c1);

insert into t1(id,c1) values (6, 6);
inc $dml_cnt;
ob1.oblog.next_dml;

# c3 id (c2) c1 c4
alter table t1 add column c4 varchar(64) generated always as ('OceanBase') stored;

insert into t1(id,c1) values (7, 7);
inc $dml_cnt;
ob1.oblog.next_dml;

delete from t1 where id=1;
inc $dml_cnt;
ob1.oblog.next_dml;

# c3 id (c2) c1 c5 c4
alter table t1 add column c5 varchar(64) generated always as ('OceanBase') stored before c4;

insert into t1(id,c1) values (8, 8);
inc $dml_cnt;
ob1.oblog.next_dml;

# c3 id (c2) (c6) c1 c4
alter table t1 add column c6 varchar(64) generated always as ('OceanBase') virtual before c1, drop column c5;

insert into t1(id,c1) values (9, 9);
inc $dml_cnt;
ob1.oblog.next_dml;

update t1 set c1=c1+1 where id=9;
inc $dml_cnt;
ob1.oblog.next_dml;

drop index unique_id_idx on t1;

delete from t1 where id=9;
inc $dml_cnt;
ob1.oblog.next_dml;

# c3 id (c2) c1 c4
alter table t1 drop column c6;

insert into t1(id,c1) values (10, 10);
inc $dml_cnt;
ob1.oblog.next_dml;

# c3 id (c2) c7 c1 c4
alter table t1 add column c7 varchar(64) default '77777' after c2;

insert into t1(id, c1, c7) values (11, 11, 'abcdefg~!@#$%^&*()_+');
inc $dml_cnt;
ob1.oblog.next_dml;

create index c7_prefix_idx on t1(c7(10));

insert into t1(id, c1, c7) values (12, 12, 'ABCDEFG,.<>;:');
inc $dml_cnt;
ob1.oblog.next_dml;

update t1 set c1 = 13, c7='ABCDEFG,.<>;:?' where id=12;
inc $dml_cnt;
ob1.oblog.next_dml;

update t1 set c1=-2 where id=2;
inc $dml_cnt;
ob1.oblog.next_dml;

delete from t1 where id<=3;
inc $dml_cnt;
ob1.oblog.next_dml;

delete from t1 where id=12;
inc $dml_cnt;
ob1.oblog.next_dml;

echo "#################### [CASE_END] Mixed Scenario ####################";

ob1.oblog.stop;

echo "#################### [CASE_BEGIN] Fetch All History ####################";

ob1.oblog.set_start_tstamp_usec $start_timestamp_usec;
ob1.oblog.gen_conf tb_white_list=oblog_tt.*.* log_level=DEBUG enable_output_hidden_primary_key=1 enable_output_by_table_def=1 skip_ob_version_compat_check=1;
ob1.oblog.restart;

let $cnt=0;

while ($cnt < $dml_cnt)
{
  ob1.oblog.next_dml;
  inc $cnt;
}
ob1.oblog.stop;
echo "#################### [CASE_END] Fetch All History ####################";

echo "#################### [CASE_BEGIN] Fetch Part History ####################";

ob1.oblog.set_start_tstamp_usec $restart_ts_us1;
ob1.oblog.gen_conf tb_white_list=oblog_tt.*.* log_level=DEBUG enable_output_hidden_primary_key=1 enable_output_by_table_def=1 skip_ob_version_compat_check=1;
ob1.oblog.restart;

let $cnt=0;
let $restart1_dml_cnt = $dml_cnt-$restart1_cnt;

while ($cnt < $restart1_dml_cnt)
{
  ob1.oblog.next_dml;
  inc $cnt;
}

ob1.oblog.stop;

echo "#################### [CASE_END] Fetch Part History ####################";

echo "#################### [CASE_BEGIN] Fetch Part History Using Data Dict ####################";
ob1.oblog.set_start_tstamp_usec $restart_ts_us2;
ob1.oblog.gen_conf tb_white_list=oblog_tt.*.* log_level=DEBUG meta_data_refresh_mode=data_dict enable_output_hidden_primary_key=1 enable_output_by_table_def=1;
ob1.oblog.restart;

let $cnt=0;
let $restart2_dml_cnt = $dml_cnt-$restart1_cnt-$restart2_cnt;

while ($cnt < $restart2_dml_cnt)
{
  ob1.oblog.next_dml;
  inc $cnt;
}

ob1.oblog.stop;
echo "#################### [CASE_END] Fetch Part History Using Data Dict ####################";

echo "#################### [CASE_BEGIN] Non Usr Col ####################";

let $start_timestamp_usec2 = query_get_value(select time_to_usec(now(6)) as now, now, 1);
ob1.oblog.gen_conf tb_white_list=oblog_tt.*.* log_level=DEBUG enable_output_hidden_primary_key=1 enable_output_by_table_def=1 skip_ob_version_compat_check=1;
ob1.oblog.restart;

create table tn (a int, b int, c int);
create table gen_non_usr_col(c1 int generated always as (1) virtual, key(c1));

insert into gen_non_usr_col values ();
ob1.oblog.next_dml;
insert into tn values(1, 1, 1);
ob1.oblog.next_dml;
delete from gen_non_usr_col;
ob1.oblog.next_dml;
delete from tn;
ob1.oblog.next_dml;
ob1.oblog.stop;

ob1.oblog.set_start_tstamp_usec $start_timestamp_usec2;
ob1.oblog.gen_conf tb_white_list=oblog_tt.*.* log_level=DEBUG enable_output_hidden_primary_key=0 enable_output_by_table_def=1 skip_ob_version_compat_check=1;
ob1.oblog.restart;
# expect output operation of tn while not output hidden_pk;
ob1.oblog.next_dml;
ob1.oblog.next_dml;
ob1.oblog.stop;

ob1.oblog.set_start_tstamp_usec $start_timestamp_usec2;
ob1.oblog.gen_conf tb_white_list=oblog_tt.*.* log_level=DEBUG enable_output_hidden_primary_key=1 enable_output_by_table_def=0 skip_ob_version_compat_check=1;
ob1.oblog.restart;
ob1.oblog.next_dml;
ob1.oblog.next_dml;
ob1.oblog.next_dml;
ob1.oblog.next_dml;
ob1.oblog.stop;

ob1.oblog.set_start_tstamp_usec $start_timestamp_usec2;
ob1.oblog.gen_conf tb_white_list=oblog_tt.*.* log_level=DEBUG enable_output_hidden_primary_key=0 enable_output_by_table_def=0 skip_ob_version_compat_check=1;
ob1.oblog.restart;
ob1.oblog.next_dml;
ob1.oblog.next_dml;
ob1.oblog.stop;

ob1.oblog.set_start_tstamp_usec $start_timestamp_usec2;
ob1.oblog.gen_conf tb_white_list=oblog_tt.*.* log_level=DEBUG enable_output_hidden_primary_key=0 enable_output_by_table_def=0 skip_ob_version_compat_check=1;
ob1.oblog.restart;
ob1.oblog.next_dml;
ob1.oblog.next_dml;
ob1.oblog.stop;
echo "#################### [CASE_END] Non Usr Col ####################";
