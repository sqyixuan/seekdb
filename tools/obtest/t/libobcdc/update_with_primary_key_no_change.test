# owner:修铭
# owner group:liboblog
# description:
# 测试点: 测试update语句原地更新主键场景下，是否会写全量日志

ob1=OBI(cluster=1, init_unit_cpu=5);
ob1.reboot;
ob1.create_client;

# 准备环境
source include/liboblog/create_tenant.inc;

--disable_warnings
drop database if exists oblog_db;
create database oblog_db;
use oblog_db;
create table oblog_test (pk int primary key, v1 int, v2 int);

# 启动liboblog
ob1.oblog.gen_conf tb_white_list=oblog_tt.oblog_db.oblog_test skip_ob_version_compat_check=1;
ob1.oblog.restart;

# 插入数据
insert into oblog_test values (1, 1, 1);
ob1.oblog.next_dml;

# update普通列，不指定主键列
update oblog_test set v1=2 where pk=1;
ob1.oblog.next_dml;

# update普通列，指定主键列
update oblog_test set v2=2, pk=1 where pk=1;
ob1.oblog.next_dml;

# update普通列，全部的列，指定主键列
update oblog_test set v1=3, v2=3, pk=1 where pk=1;
ob1.oblog.next_dml;

# update 列自增
update oblog_test set v1=v1+1 where pk=1;
ob1.oblog.next_dml;

# update 列自增
update oblog_test set pk=1, v1=v1+1 where pk=1;
ob1.oblog.next_dml;

# update 列自增
update oblog_test set pk=1, v1=v1+1, v2=v1*10 where pk=1;
ob1.oblog.next_dml;

# update主键列
update oblog_test set pk=2 where pk=1;
ob1.oblog.next_dml;

# replace语句: 指定全部列
replace into oblog_test values (2, 100, 100);
ob1.oblog.next_dml;

# replace语句: 部分部分列
replace into oblog_test (pk, v1) values (2, 200);
ob1.oblog.next_dml;

# insert on duplicate key update
# 不指定主键
insert into oblog_test values (2, 400, 400) on duplicate key update v2=400;
ob1.oblog.next_dml;

# insert on duplicate key update
# 更新部分列
insert into oblog_test values (2, 500, 500) on duplicate key update v2=500, v1=500;
ob1.oblog.next_dml;

# insert on duplicate key update
# 更新全部列
insert into oblog_test values (2, 600, 600) on duplicate key update v2=600, v1=600, pk=2;
ob1.oblog.next_dml;

# insert on duplicate key update
# 更新相同的值，不会更新任何一列
insert into oblog_test values (2, 600, 600) on duplicate key update v2=600, v1=600, pk=2;
# 不期望迭代到任何一列

# insert on duplicate key update
# 更新主键
insert into oblog_test values (2, 700, 700) on duplicate key update v2=700, v1=700, pk=3;
ob1.oblog.next_dml;

# 停止liboblog
ob1.oblog.stop;
