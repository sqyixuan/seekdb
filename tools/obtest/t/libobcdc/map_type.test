#
# owner:xuqijia.xqj
# owner group:shenzhen
# description: map_type basic test
##

ob1=OBI(cluster=1,init_unit_cpu=5);
ob1.reboot;
ob1.create_client;

# 创建mysql租户 oblog_tt，并且切换到mysql租户下
source include/liboblog/create_tenant_with_gts.inc;

create database oblog_db1;

use oblog_db1;

# max size of map is 32MB
alter tenant oblog_tt set variables max_allowed_packet=52428800;
set global max_allowed_packet=52428800;

# 设置事务超时时间: 100秒
set ob_trx_timeout=100000000;

let $record_cnt=0;
let $start_tstamp_usec = query_get_value(select time_to_usec(now(6)) as now, now, 1);

echo "[CASE_BEGIN] [vector_type]";
# 启动liboblog，同步oblog_tt租户数据
ob1.oblog.gen_conf tb_white_list=oblog_tt.*.* log_level=DEBUG skip_ob_version_compat_check=1;
ob1.oblog.set_extra_argument -x;
ob1.oblog.restart;

echo "[SECTION_BEGIN] [basic_test]";
create table map_t1(c1 int primary key, c2 map(varchar(16),array(array(varchar(16)))), c3 map(float,array(array(float))), c4 map(double,array(array(array(double)))));
ob1.oblog.next;
inc $record_cnt;

# insert null
insert into map_t1 values(0, null, null, null);
ob1.oblog.next;
inc $record_cnt;

insert into map_t1 values(1, map("a",[["hello", "world"], [null, "hi"]]), 
                             map(1.23,[[5.55, 7.87, 44], [66, 123.67, null], [null, 3.1415, 289.33]]),
                             map(10,[[[100, 3.1415926, 4.56, 7.88], [5.55, 7.87, 44]], [[null, 3.1415, 289.33],[2.111144455, 3.444555666, null]]]));
ob1.oblog.next;
inc $record_cnt;

insert into map_t1 values(2, map(null,[null, [null, "hi"]], "aa", [["ocean","base"]]), 
                             map(null,[[5.55, 7.87, 44], null, [null, 3.1415, 289.33]], 2.34, [[1.234,5.678]]),
                             map(null,[[[100, 3.1415926, 4.56, 7.88], [5.55, 7.87, 44]], null], 100, [[[2.345,3.456]]]));
ob1.oblog.next;
inc $record_cnt;

insert into map_t1 values(3, map(null,[null, [null, null]]), 
                             map(null,[null, null, [null, null, null]]),
                             map(null,[[[null]]]));
ob1.oblog.next;
inc $record_cnt;

insert into map_t1 values(4, map("bb",[["hello", "world"], [null, "hi"]]), 
                             map(88,[[5, 7, 44], [66, 123, null], [null, 31415, 28933]]),
                             map(1234,[[[100, 314, 456, 788], [555, 787, 44]], [[null, 31415, 28933],[2115, 3444, null]]]));
ob1.oblog.next;
inc $record_cnt;

insert into map_t1 values(5, '{}', '{}', '{}');
ob1.oblog.next;
inc $record_cnt;

insert into map_t1 values(6, '{"a":[[]]}', '{55.5:[[]]}', '{66.6:[[[]]]}');
ob1.oblog.next;
inc $record_cnt;

# update test
update map_t1 set c2=map("a",[["hello", "world"], [null, "hi"]]) where c1 = 0;
ob1.oblog.next;
inc $record_cnt;

update map_t1 set c2=map("a",[["hello", "world"], [null, "hi"]]) where c1 = 2;
ob1.oblog.next;
inc $record_cnt;

update map_t1 set c3=map(1.23,[[1.11, 7.87, 44], [66, 123.67, 2.22], [3.33, 3.1415, 289.33]]) where c1=2;
ob1.oblog.next;
inc $record_cnt;

update map_t1 set c3=map(1.1, [[1.11, 7.87, 44]], 2.2, [[66, 123.67, 2.22]], 3.3, [[3.33, 3.1415, 289.33]]) where c1=3;
ob1.oblog.next;
inc $record_cnt;

update map_t1 set c4=null where c1 = 4;
ob1.oblog.next;
inc $record_cnt;

# update primary key
update map_t1 set c1 = 12 where c1 = 2;
ob1.oblog.next;
inc $record_cnt;

delete from map_t1 where c1 = 1;
ob1.oblog.next;
inc $record_cnt;

drop table map_t1;
ob1.oblog.next;
inc $record_cnt;

# stop libobcdc
ob1.oblog.stop;

echo "[SECTION_END] [basic_test]";

echo "[SECTION_BEGIN] [outrow_test]";

# 启动liboblog，同步oblog_tt租户数据，改变extra_argument
ob1.oblog.set_start_tstamp_usec $start_tstamp_usec;
ob1.oblog.gen_conf tb_white_list=oblog_tt.*.* log_level=DEBUG meta_data_refresh_mode=data_dict;
ob1.oblog.set_extra_argument -m;
ob1.oblog.restart;

let $idx = 0;
while ($idx < $record_cnt)
{
  ob1.oblog.next;
  inc $idx;
}

## test outrow number map
SET @large_double_map1:=CONCAT('{1:[',REPEAT('123.321,', 100000),'123.321]}');
SET @large_double_map2:=CONCAT('{1:[',REPEAT('987.05,',100000),'987.05]}');
SET @large_double_map3:=CONCAT('{1:[',REPEAT('0.0001,',100000),'0.0005]}');

create table outrow_map_t1(c1 int primary key, c2 map(int,array(double)));
ob1.oblog.next;

# insert outrow
insert into outrow_map_t1 values(1, @large_double_map1);
ob1.oblog.next;
select md5(@large_double_map1);

insert into outrow_map_t1 values(2, @large_double_map2);
ob1.oblog.next;
select md5(@large_double_map2);

## outrow->outrow
update outrow_map_t1 set c2=@large_double_map3 where c1=1;
ob1.oblog.next;
select md5(@large_double_map3);

## outrow->inrow
update outrow_map_t1 set c2=map(2,[1,2,3]) where c1=1;  
ob1.oblog.next;

## outrow->null
update outrow_map_t1 set c2=null where c1=2;
ob1.oblog.next;

## null->outrow
update outrow_map_t1 set c2=@large_double_map3 where c1=2;
ob1.oblog.next;
select md5(@large_double_map3);

## inrow->null
update outrow_map_t1 set c2=null where c1=1;  
ob1.oblog.next;

## null->inrow
update outrow_map_t1 set c2=map(0,[0, 0, 0]) where c1=1;  
ob1.oblog.next;

## delete outrow
delete from outrow_map_t1 where c1=2;
ob1.oblog.next;

drop table outrow_map_t1;
ob1.oblog.next;

## test outrow varchar map with nested array
SET @long_str_map1:=CONCAT('{1:[',REPEAT('["abc012","xyz456","wuv-+"],',100000),'["abc012","xyz456","wuv-+"]]}');
SET @long_str_map2:=CONCAT('{1:[',REPEAT('["Hello","World"],',100000),'["Hello","World"]]}');
SET @long_str_map3:=CONCAT('{1:[',REPEAT('["aaa","bbb","ccc"],',100000),'["aaa","bbb","ccc"]]}');

create table outrow_map_t2(c1 int primary key, c2 map(int,array(array(varchar(16)))));
ob1.oblog.next;

# insert outrow
insert into outrow_map_t2 values(1, @long_str_map1);
ob1.oblog.next;
select md5(@long_str_map1);

insert into outrow_map_t2 values(2, @long_str_map2);
ob1.oblog.next;
select md5(@long_str_map2);

## outrow->outrow
update outrow_map_t2 set c2=@long_str_map3 where c1=1;
ob1.oblog.next;
select md5(@long_str_map3);

## outrow->inrow
update outrow_map_t2 set c2=map(2,[["1","2","3"]]) where c1=1;  
ob1.oblog.next;

## outrow->null
update outrow_map_t2 set c2=null where c1=2;
ob1.oblog.next;

## null->outrow
update outrow_map_t2 set c2=@long_str_map3 where c1=2;
ob1.oblog.next;
select md5(@long_str_map3);

## inrow->null
update outrow_map_t2 set c2=null where c1=1;  
ob1.oblog.next;

## null->inrow
update outrow_map_t2 set c2=map(0,[["0", "0", "0"]]) where c1=1;  
ob1.oblog.next;

## delete outrow
delete from outrow_map_t2 where c1=2;
ob1.oblog.next;

drop table outrow_map_t2;
ob1.oblog.next;

echo "[SECTION_END] [outrow_test]";

echo "[CASE_END] [case_name]";
