#
# owner: fangshenglan.fsl
# owner group: liboblog
# description: test CDC functionalities in heap organized tables
# 测试点: 
#  test heap organized tables
##

ob1=OBI(cluster=1);
ob1.reboot;
ob1.create_client;

# 创建mysql租户oblog_tt，并且切换到mysql租户下
source include/liboblog/create_tenant_with_gts.inc;

let $record_cnt=0;
let $start_tstamp_usec = query_get_value(select time_to_usec(now(6)) as now, now, 1);

# 启动liboblog，同步oblog_tt租户数据
ob1.oblog.gen_conf tb_white_list=oblog_tt.*.* log_level=DEBUG skip_ob_version_compat_check=1;
ob1.oblog.restart;

# 创建database 1
create database oblog_db1;
# 输出create database DDL
ob1.oblog.next;
inc $record_cnt;

use oblog_db1;

# 创建iot表
create table t1(id int, c1 timestamp(6), c2 datetime);
# 输出create table DDL
ob1.oblog.next;
inc $record_cnt;

# 执行AC=1的DML事务
insert into t1 values(1, '2019-1-30 12:00:00.123456', '2019-1-30 12:00:00');
# 输出上述事务
ob1.oblog.next;
inc $record_cnt;

# 创建heap表
create table t2(id int, c1 timestamp(6), c2 datetime, PRIMARY KEY (id)) ORGANIZATION HEAP;
# 输出create table DDL
ob1.oblog.next;
inc $record_cnt;
# 执行AC=1的DML事务
insert into t2 values(1, '2019-1-30 12:00:00.123456', '2019-1-30 12:00:00');
# 输出上述事务
ob1.oblog.next;
inc $record_cnt;

# 执行drop table DDL
drop table t1;
# 输出drop table DDL
ob1.oblog.next;
inc $record_cnt;

# 执行drop table DDL
drop table t2;
# 输出drop table DDL
ob1.oblog.next;
inc $record_cnt;

alter system set default_table_organization = 'HEAP';
# schema 信息同步
source include/check_schema_sync.inc;
# 创建heap表
create table t2(id int, c1 timestamp(6), c2 datetime, PRIMARY KEY (id));
# 执行AC=1的DML事务
insert into t2 values(1, '2019-1-30 12:00:00.123456', '2019-1-30 12:00:00');
# 输出上述事务
ob1.oblog.next;
inc $record_cnt;
# 输出create table DDL
ob1.oblog.next;
inc $record_cnt;

# stop liboblog
ob1.oblog.stop;

# 启动liboblog，同步oblog_tt租户数据
ob1.oblog.set_start_tstamp_usec $start_tstamp_usec;
ob1.oblog.gen_conf tb_white_list=oblog_tt.*.* log_level=DEBUG meta_data_refresh_mode=data_dict;
ob1.oblog.set_extra_argument -m;
ob1.oblog.restart;
let $idx = 0;
while ($idx < $record_cnt)
{
  ob1.oblog.next;
  inc $idx;
}

ob1.oblog.gen_conf tb_white_list=oblog_tt.*.* log_level=DEBUG test_mode_on=1 test_mode_init_fail=1;
ob1.oblog.restart;
sleep 20;
ob1.oblog.check_log "libobcdc end";


