#
# owner: xingrui.cwh
# owner group: RS
# description: 测试MySQL中间快速加列
# 测试点:
#  1.add column
#  2.add column and modify column
#  3.add column and other ddl
##

ob1=OBI(cluster=1,init_unit_cpu=5);
ob1.reboot;
ob1.create_client;

source include/liboblog/create_tenant_with_gts.inc;
let $start_timestamp_usec = query_get_value(select time_to_usec(now(6)) as now, now, 1);
ob1.oblog.gen_conf tb_white_list=oblog_tt.*.* log_level=DEBUG enable_output_hidden_primary_key=0 enable_output_by_table_def=1 skip_ob_version_compat_check=1;
ob1.oblog.restart;

create database oblog_db1;
ob1.oblog.next;
use oblog_db1;
let $dml_cnt = 0;

# case 1.add column
create table xingrui_normal_table(col1 int, col2 char(10));
ob1.oblog.next;
insert into xingrui_normal_table values(1, 'a');
inc $dml_cnt;
ob1.oblog.next;
alter table xingrui_normal_table add column col3 bigint after col1;
ob1.oblog.next;

# case 2.add column and modify column
drop table xingrui_normal_table;
ob1.oblog.next;
#online
create table xingrui_normal_table (a decimal(10,0), b int);
ob1.oblog.next;
insert into xingrui_normal_table values(1, 1);
inc $dml_cnt;
ob1.oblog.next;
alter table xingrui_normal_table add column c int after a,modify column a decimal(14,2);
ob1.oblog.next;
insert into xingrui_normal_table values(666.6, 1, 8);
inc $dml_cnt;
ob1.oblog.next;
update xingrui_normal_table set c = 888.8 where a = 666.6;
inc $dml_cnt;
ob1.oblog.next;

#offline
drop table xingrui_normal_table;
ob1.oblog.next;
create table xingrui_normal_table (a decimal(10,0), b int);
ob1.oblog.next;
insert into xingrui_normal_table values(1, 1);
inc $dml_cnt;
ob1.oblog.next;
alter table xingrui_normal_table add column c char(10) after a,modify column a decimal(10,2);
ob1.oblog.next;
insert into xingrui_normal_table values(666.6, 'a', 1);
inc $dml_cnt;
ob1.oblog.next;
update xingrui_normal_table set a = 888.8 where b = 1;
inc $dml_cnt;
ob1.oblog.next;

#case 3.add column and other ddl
#truncate
truncate table xingrui_normal_table;
ob1.oblog.next;
insert into xingrui_normal_table values(666.6, 'a', 1);
inc $dml_cnt;
ob1.oblog.next;
alter table xingrui_normal_table add column d bigint after a;
ob1.oblog.next;
insert into xingrui_normal_table values(666.6, 1, 'a', 1);
inc $dml_cnt;
ob1.oblog.next;
truncate table xingrui_normal_table;
ob1.oblog.next;

#drop column
drop table xingrui_normal_table;
ob1.oblog.next;
create table xingrui_normal_table (a int, b char(10));
ob1.oblog.next;
insert into xingrui_normal_table values(1, 'a');
inc $dml_cnt;
ob1.oblog.next;
alter table xingrui_normal_table add column c int after a;
ob1.oblog.next;
insert into xingrui_normal_table values(1, 1, 'a');
inc $dml_cnt;
ob1.oblog.next;
alter table xingrui_normal_table drop column c;
ob1.oblog.next;

ob1.oblog.stop;

#回拉数据
ob1.oblog.set_start_tstamp_usec $start_timestamp_usec;
ob1.oblog.gen_conf tb_white_list=oblog_tt.*.* log_level=DEBUG enable_output_hidden_primary_key=0 enable_output_by_table_def=1 skip_ob_version_compat_check=1;
ob1.oblog.restart;

let $cnt=0;
while ($cnt < $dml_cnt)
{
  ob1.oblog.next_dml;
  inc $cnt;
}

# stop liboblog
ob1.oblog.stop;