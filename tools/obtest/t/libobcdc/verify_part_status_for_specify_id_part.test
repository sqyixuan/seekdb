#
# owner:修铭
# owner group:liboblog
# description:
# 测试点：测试"验证参与者状态"功能是否正常，能否正常检测出“未来分区”、“分区删除”、“分区存在”等场景
#
# 场景：指定ID创建的分区动态添加和删除
# 采用__oceanbase_inner_restore_user和__oceanbase_inner_drc_user可以指定ID新建分区。
#

ob1=OBI(cluster=1, init_unit_cpu=5);
ob1.reboot;

source include/liboblog/create_tenant_with_gts.inc;

# 关闭warning
--disable_warnings

# 关闭回收站
set recyclebin=off;

# 创建__oceanbase_inner_drc_user和连接
create user if not exists __oceanbase_inner_drc_user identified by 'drc';
grant all privileges on *.* to __oceanbase_inner_drc_user;
connect (oblog_conn_drc,$ip,__oceanbase_inner_drc_user@oblog_tt,drc,oceanbase,$port);
connection oblog_conn_drc;
use test;

######### 场景1: 指定ID新建分区 动态添加场景
# 下面验证这种新建的分区可以识别出来
#
# 1.1 创建table
drop table if exists t_base, t_range;
create table t_base (pk int primary key);
create table t_range (pk int primary key, c1 int) max_used_part_id = 1000 partition by range(pk) (partition p1 values less than (10) id 100, partition p2 values less than (20) id 200);
# 1.2 保存启动时刻时间戳
# 因为启动时间戳是秒级别的，为了保证越过上一个操作，此处要sleep 1秒
sleep 1;
let $start_tstamp = query_get_value(select round(time_to_usec(now()) / 1000000) as now, now, 1);
# 1.4 添加分区
alter table t_range add partition (partition p3 values less than (30));
alter table t_range add partition (partition p4 values less than (40));
alter table t_range add partition (partition p5 values less than (50));
# 1.5 插入数据
begin;
insert into t_base values (1);
insert into t_range values (28,28),(19,19),(9,9);
commit;
# 1.6 回拉数据
ob1.oblog.gen_conf tb_white_list=oblog_tt.test.t* sort_trans_participants=1 log_level=INFO test_mode_on=1 test_mode_block_alter_table_ddl_sec=3 skip_ob_version_compat_check=1;
ob1.oblog.set_start_tstamp $start_tstamp;
ob1.oblog.restart;
ob1.oblog.next_dml;
# 1.7 验证日志
# 验证liboblog是否有检测到"未来分区"
#ob1.oblog.check_log "STATUS=PART_NOT_CREATE";
# 验证liboblog是否有检测到"分区存在"
#ob1.oblog.check_log "STATUS=PART_EXIST";
ob1.oblog.stop;
# 1.8 清理环境
drop table t_base, t_range;

######### 场景2: 指定ID新建分区 动态删除场景
#
# 2.1 首先保存启动时刻时间戳，让后面的表的日志拉取时间晚点，让DDL早点生效
let $start_tstamp = query_get_value(select round(time_to_usec(now()) / 1000000) as now, now, 1);
# 2.2 创建table，range分区
drop table if exists t_base, t_second_part;
create table t_base (pk int primary key);
create table t_second_part (pk int primary key, c1 int) max_used_part_id = 1000 partition by range(pk) subpartition by hash(pk) subpartitions 4 (partition p1 values less than (10) id 100, partition p2 values less than (20) id 200);
# 2.3 执行分布式事务，包含即将被删除的分区
begin;
insert into t_base values (1);
# 插入p1分区
insert into t_second_part values (9,9);
# 插入p2分区
insert into t_second_part values (11,11);
commit;
# 2.4 删除分区
# 删除p1分区
alter table t_second_part drop partition (p1);
# 2.5 回拉数据
# 设置排序事务内参与者列表配置项为true，保证集群重启情况下，多分区事务语句顺序一致
# 设置测试模式，并且阻塞参与者列表确认过程，保证在确认参与者时，分区已经删除成功。
ob1.oblog.gen_conf tb_white_list=oblog_tt.test.t* sort_trans_participants=1 log_level=INFO test_mode_on=1 test_mode_block_verify_participants_time_sec=1 skip_ob_version_compat_check=1;
ob1.oblog.set_start_tstamp $start_tstamp;
ob1.oblog.restart;
ob1.oblog.next_dml;
ob1.oblog.stop;
# 2.6 验证日志
# 验证liboblog是否有检测到"分区删除"
#ob1.oblog.check_log "STATUS=PART_DELETED";
# 2.7 清理环境
drop table t_base, t_second_part;
