##

ob1=OBI(cluster=1);
ob1.reboot;
ob1.create_client;

# е‡†е¤‡зЋЇеўѓ
source include/liboblog/create_tenant.inc;

# еђЇеЉЁliboblog
ob1.oblog.gen_conf tb_white_list=sys.oblog*.*|oblog_tt.*.* skip_ob_version_compat_check=1;
ob1.oblog.restart;

# е€›е»єdatabase 1
create database `oblog_db1.test`;
ob1.oblog.next;
use `oblog_db1.test`;

CREATE TABLE `deerbinary` (`name` varbinary(20) NOT NULL,`age` int(10) NOT NULL,`address` varbinary(20) NOT NULL,`sex` float NOT NULL, `class` int(10) NOT NULL) DEFAULT CHARSET = binary COMPRESSION = 'lz4_1.0' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 10;
ob1.oblog.next;
insert into `deerbinary` values("ob", 10, "BJ", 1.0, 3);
ob1.oblog.next;

CREATE TABLE `deerbinary_2` (`name` varbinary(20) NOT NULL,`age` int(10) NOT NULL,`address` varbinary(20) NOT NULL,`sex` float NOT NULL, `class` int(10) NOT NULL) DEFAULT CHARSET = utf8mb4 COMPRESSION = 'lz4_1.0' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 10;
ob1.oblog.next;
insert into `deerbinary_2` values("ob", 10, "BJ", 1.0, 3);
ob1.oblog.next;

# c1 varchar column_encoding-utf8mb4
CREATE TABLE `deerbinary_3` (`name` varbinary(20) NOT NULL,`age` int(10) NOT NULL,`address` varbinary(20) NOT NULL,`sex` float NOT NULL, `class` int(10) NOT NULL, c1 varchar(10)) DEFAULT CHARSET = utf8mb4 COMPRESSION = 'lz4_1.0' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 10;
ob1.oblog.next;
insert into `deerbinary_3` values("ob", 10, "BJ", 1.0, 3, "alipay");
ob1.oblog.next;

# stop liboblog
ob1.oblog.stop;
