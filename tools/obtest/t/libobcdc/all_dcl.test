#
# owner:花隆
# owner group:liboblog
# description:
# 测试点:
#     create/drop user
#     rename user
#     lock/unlock user
#     grant/revoke user priviledge
#     grant/revoke db priviledge
#     grant/revoke table priviledge
##
ob1=OBI(cluster=1);
ob1.reboot;
ob1.create_client;
# 准备环境
let $ip=deploy_get_value(ob1.proxy0.ip);
let $port=deploy_get_value(ob1.proxy0.port);
connect (oblog_conn_sys,$ip,admin@sys,admin,oceanbase,$port);
connection oblog_conn_sys;
--disable_warnings
drop tenant if exists oblog_tt;
--disable_warnings
drop resource pool if exists oblog_pool;
--disable_warnings
drop resource unit if exists oblog_box;
--disable_warnings
drop database if exists oblog_db1;
--disable_warnings
drop database if exists oblog_db2;
# sys租户下操作
connection oblog_conn_sys;
# create tenant, 创建oblog_tt租户
create resource unit oblog_box max_cpu=2, memory_size='20G';
create resource pool oblog_pool unit = 'oblog_box', unit_num = 1, zone_list = ('z1');
# TODO test
# 当sys租户为GTS，创建普通租户为LTS，刷新schema会报错，导致无法启动；原因：当通过change tenant的方式刷新普通租户schema, fast select用了sys租户的GTS 判断报错不支持, 需修复
# create tenant oblog_tt replica_num = 1, primary_zone='z1', resource_pool_list=('oblog_pool') set ob_tcp_invited_nodes='%';
create tenant oblog_tt replica_num = 1, primary_zone='z1', resource_pool_list=('oblog_pool') set ob_tcp_invited_nodes='%';
# 保证不输出create tennat ddl语句
sleep 2;
# 在oblog_tt租户下操作
connect (oblog_conn_tt,$ip,root@oblog_tt,,oceanbase,$port);
connection oblog_conn_tt;
# 启动liboblog
ob1.oblog.gen_conf tb_white_list=sys.oblog*.*|oblog_tt.*.* skip_ob_version_compat_check=1;
ob1.oblog.restart;
### create/drop user
create user hualong2 identified by '123456';
ob1.oblog.next;
set password for hualong2 = password('456');
ob1.oblog.next;
#set password for hualong2 = '*6bb4837eb74329105ee4568dda7dc67ed2ca2ad9';
#ob1.oblog.next;
alter user hualong2 identified by '789';
ob1.oblog.next;
grant select on test.* to hualong2;
ob1.oblog.next;
connect (conn1, $ip, hualong2@oblog_tt, 789, test, $port);
connection conn1;
set password = password('123');
ob1.oblog.next;
set password = '';
ob1.oblog.next;
connection oblog_conn_tt;
drop user hualong2;
ob1.oblog.next;
### rename user
create user user_r1;
ob1.oblog.next;
create user user_r2;
ob1.oblog.next;
rename user user_r1 to user_ra, user_r2 to user_rb;
ob1.oblog.next;
ob1.oblog.next;
drop user user_ra, user_rb;
ob1.oblog.next;
ob1.oblog.next;
### lock/unlock user
create user 'lock_user_1';
ob1.oblog.next;
alter user 'lock_user_1' account lock;
ob1.oblog.next;
alter user 'lock_user_1' account unlock;
ob1.oblog.next;
drop user 'lock_user_1';
ob1.oblog.next;
### user level privilege
create user priv_user;
ob1.oblog.next;
create user priv_user2;
ob1.oblog.next;
create user priv_user3;
ob1.oblog.next;
grant usage on *.* to priv_user;
ob1.oblog.next;
grant alter on *.* to priv_user;
ob1.oblog.next;
grant create on *.* to priv_user;
ob1.oblog.next;
grant create user on *.* to priv_user;
ob1.oblog.next;
grant delete on *.* to priv_user;
ob1.oblog.next;
grant drop on *.* to priv_user;
ob1.oblog.next;
grant grant option on *.* to priv_user;
ob1.oblog.next;
grant insert on *.* to priv_user;
ob1.oblog.next;
grant update on *.* to priv_user;
ob1.oblog.next;
grant select on *.* to priv_user;
ob1.oblog.next;
grant index on *.* to priv_user;
ob1.oblog.next;
grant create view on *.* to priv_user;
ob1.oblog.next;
grant show view on *.* to priv_user;
ob1.oblog.next;
grant show databases on *.* to priv_user;
ob1.oblog.next;
grant super on *.* to priv_user;
ob1.oblog.next;
grant all on *.* to priv_user2;
ob1.oblog.next;
grant all on *.* to priv_user3 with grant option;
ob1.oblog.next;
#### grant to not exist user
grant all on *.* to priv_user4 identified by '123' with grant option;
ob1.oblog.next;
ob1.oblog.next;
grant all on *.* to priv_user5 identified by password '*6bb4837eb74329105ee4568dda7dc67ed2ca2ad9' with grant option;
ob1.oblog.next;
ob1.oblog.next;
#### grant o exist user with different password
create user priv_user6 identified by '111111';
ob1.oblog.next;
grant all on *.* to priv_user6 identified by password '*6bb4837eb74329105ee4568dda7dc67ed2ca2ad9' with grant option;
ob1.oblog.next;
ob1.oblog.next;
revoke usage on *.* from priv_user;
ob1.oblog.next;
revoke alter on *.* from priv_user;
ob1.oblog.next;
revoke create on *.* from priv_user;
ob1.oblog.next;
revoke create user on *.* from priv_user;
ob1.oblog.next;
revoke delete on *.* from priv_user;
ob1.oblog.next;
revoke drop on *.* from priv_user;
ob1.oblog.next;
revoke grant option on *.* from priv_user;
ob1.oblog.next;
revoke insert on *.* from priv_user;
ob1.oblog.next;
revoke update on *.* from priv_user;
ob1.oblog.next;
revoke select on *.* from priv_user;
ob1.oblog.next;
revoke index on *.* from priv_user;
ob1.oblog.next;
revoke create view on *.* from priv_user;
ob1.oblog.next;
revoke show view on *.* from priv_user;
ob1.oblog.next;
revoke show databases on *.* from priv_user;
ob1.oblog.next;
revoke super on *.* from priv_user;
ob1.oblog.next;
drop user priv_user, priv_user2, priv_user3, priv_user4, priv_user5, priv_user6;
ob1.oblog.next;
ob1.oblog.next;
ob1.oblog.next;
ob1.oblog.next;
ob1.oblog.next;
ob1.oblog.next;
### db level priviledge
create user db_priv_user;
ob1.oblog.next;
create user db_priv_user2;
ob1.oblog.next;
create user db_priv_user3;
ob1.oblog.next;
create database priv_db;
ob1.oblog.next;
# grant usage on specified db won't do any change to observer, won't record dcl to clog
#grant usage on priv_db.* to db_priv_user;
#ob1.oblog.next;
grant alter on priv_db.* to db_priv_user;
ob1.oblog.next;
grant create on priv_db.* to db_priv_user;
ob1.oblog.next;
--error ER_WRONG_USAGE
grant create user on priv_db.* to db_priv_user;
grant delete on priv_db.* to db_priv_user;
ob1.oblog.next;
grant drop on priv_db.* to db_priv_user;
ob1.oblog.next;
grant grant option on priv_db.* to db_priv_user;
ob1.oblog.next;
grant insert on priv_db.* to db_priv_user;
ob1.oblog.next;
grant update on priv_db.* to db_priv_user;
ob1.oblog.next;
grant select on priv_db.* to db_priv_user;
ob1.oblog.next;
grant index on priv_db.* to db_priv_user;
ob1.oblog.next;
grant create view on priv_db.* to db_priv_user;
ob1.oblog.next;
grant show view on priv_db.* to db_priv_user;
ob1.oblog.next;
--error ER_WRONG_USAGE
grant show databases on priv_db.* to db_priv_user;
--error ER_WRONG_USAGE
grant super on priv_db.* to db_priv_user;
grant all on priv_db.* to db_priv_user2;
ob1.oblog.next;
grant all on priv_db.* to db_priv_user3 with grant option;
ob1.oblog.next;
grant all on priv_db.* to db_priv_user4 identified by '123' with grant option;
ob1.oblog.next;
ob1.oblog.next;
grant all on priv_db.* to db_priv_user5 identified by password '*6bb4837eb74329105ee4568dda7dc67ed2ca2ad9' with grant option;
ob1.oblog.next;
ob1.oblog.next;
create user db_priv_user6 identified by '111111';
ob1.oblog.next;
grant all on priv_db.* to db_priv_user6 identified by password '*6bb4837eb74329105ee4568dda7dc67ed2ca2ad9' with grant option;
ob1.oblog.next;
ob1.oblog.next;
#revoke usage on priv_db.* from db_priv_user;
#ob1.oblog.next;
revoke alter on priv_db.* from db_priv_user;
ob1.oblog.next;
revoke create on priv_db.* from db_priv_user;
ob1.oblog.next;
--error ER_WRONG_USAGE
revoke create user on priv_db.* from db_priv_user;
revoke delete on priv_db.* from db_priv_user;
ob1.oblog.next;
revoke drop on priv_db.* from db_priv_user;
ob1.oblog.next;
revoke grant option on priv_db.* from db_priv_user;
ob1.oblog.next;
revoke insert on priv_db.* from db_priv_user;
ob1.oblog.next;
revoke update on priv_db.* from db_priv_user;
ob1.oblog.next;
revoke select on priv_db.* from db_priv_user;
ob1.oblog.next;
revoke index on priv_db.* from db_priv_user;
ob1.oblog.next;
revoke create view on priv_db.* from db_priv_user;
ob1.oblog.next;
revoke show view on priv_db.* from db_priv_user;
ob1.oblog.next;
--error ER_WRONG_USAGE
revoke show databases on priv_db.* from db_priv_user;
--error ER_WRONG_USAGE
revoke super on priv_db.* from db_priv_user;
revoke all on priv_db.* from db_priv_user2;
ob1.oblog.next;
revoke all, grant option from db_priv_user3;
ob1.oblog.next;
drop user db_priv_user, db_priv_user2, db_priv_user3, db_priv_user4, db_priv_user5, db_priv_user6;
ob1.oblog.next;
ob1.oblog.next;
ob1.oblog.next;
ob1.oblog.next;
ob1.oblog.next;
ob1.oblog.next;
## table level priviledge
create user table_priv_user;
ob1.oblog.next;
create user table_priv_user2;
ob1.oblog.next;
create user table_priv_user3;
ob1.oblog.next;
create table priv_db.priv_table (c1 int);
ob1.oblog.next;
create view priv_db.priv_view as select * from priv_db.priv_table;
ob1.oblog.next;
#grant usage on priv_db.priv_table to table_priv_user;
#ob1.oblog.next;
grant alter on priv_db.priv_table to table_priv_user;
ob1.oblog.next;
grant create on priv_db.priv_table to table_priv_user;
ob1.oblog.next;
--error ER_ILLEGAL_GRANT_FOR_TABLE
grant create user on priv_db.priv_table  to table_priv_user;
grant delete on priv_db.priv_table to table_priv_user;
ob1.oblog.next;
grant drop on priv_db.priv_table to table_priv_user;
ob1.oblog.next;
grant grant option on priv_db.priv_table to table_priv_user;
ob1.oblog.next;
grant insert on priv_db.priv_table to table_priv_user;
ob1.oblog.next;
grant update on priv_db.priv_table to table_priv_user;
ob1.oblog.next;
grant select on priv_db.priv_table to table_priv_user;
ob1.oblog.next;
grant index on priv_db.priv_table to table_priv_user;
ob1.oblog.next;
grant create view on priv_db.priv_table to table_priv_user;
ob1.oblog.next;
grant show view on priv_db.priv_table to table_priv_user;
ob1.oblog.next;
--error ER_ILLEGAL_GRANT_FOR_TABLE
grant show databases on priv_db.priv_table to table_priv_user;
--error ER_ILLEGAL_GRANT_FOR_TABLE
grant super on priv_db.priv_table to table_priv_user;
grant all on priv_db.priv_table to table_priv_user2;
ob1.oblog.next;
grant all on priv_db.priv_table to table_priv_user3 with grant option;
ob1.oblog.next;
grant all on priv_db.priv_table to table_priv_user4 identified by '123' with grant option;
ob1.oblog.next;
ob1.oblog.next;
grant all on priv_db.priv_table to table_priv_user5 identified by password '*6bb4837eb74329105ee4568dda7dc67ed2ca2ad9' with grant option;
ob1.oblog.next;
ob1.oblog.next;
create user table_priv_user6 identified by '111111';
ob1.oblog.next;
grant all on priv_db.priv_table to table_priv_user6 identified by password '*6bb4837eb74329105ee4568dda7dc67ed2ca2ad9' with grant option;
ob1.oblog.next;
ob1.oblog.next;
#revoke usage on priv_db.priv_table from table_priv_user;
#ob1.oblog.next;
revoke alter on priv_db.priv_table from table_priv_user;
ob1.oblog.next;
revoke create on priv_db.priv_table from table_priv_user;
ob1.oblog.next;
--error ER_ILLEGAL_GRANT_FOR_TABLE
revoke create user on priv_db.priv_table from table_priv_user;
revoke delete on priv_db.priv_table from table_priv_user;
ob1.oblog.next;
revoke drop on priv_db.priv_table from table_priv_user;
ob1.oblog.next;
revoke grant option on priv_db.priv_table from table_priv_user;
ob1.oblog.next;
revoke insert on priv_db.priv_table from table_priv_user;
ob1.oblog.next;
revoke update on priv_db.priv_table from table_priv_user;
ob1.oblog.next;
revoke select on priv_db.priv_table from table_priv_user;
ob1.oblog.next;
revoke index on priv_db.priv_table from table_priv_user;
ob1.oblog.next;
revoke create view on priv_db.priv_table from table_priv_user;
ob1.oblog.next;
revoke show view on priv_db.priv_table from table_priv_user;
ob1.oblog.next;
--error ER_ILLEGAL_GRANT_FOR_TABLE
revoke show databases on priv_db.priv_table from table_priv_user;
--error ER_ILLEGAL_GRANT_FOR_TABLE
revoke super on priv_db.priv_table from table_priv_user;
revoke all on priv_db.priv_table from table_priv_user2;
ob1.oblog.next;
revoke all, grant option from table_priv_user3;
ob1.oblog.next;
# 删除oblog_tt租户
connection oblog_conn_sys;
# TODO 当前drop tenant回直接删租户及其日志流，可能拉不到租户的日志导致OBCDC报错退出（等不到OBCDC消费到OFFLINE日志触发租户回收逻辑）
# 带支持消费归档后，再放开drop tenant
#drop tenant oblog_tt;
#ob1.oblog.next;
# stop liboblog
ob1.oblog.stop;
