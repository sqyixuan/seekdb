# owner: zhenjiang.xzj
# owner group: storage
# description: this case is use for scheduling build index failed

--disable_query_log
ob1=OBI(cluster=1,proxy_num=0);
ob1.reboot;

#设置灰度切主的时间为0, 关闭自动切主，关闭自动balance
ob1.mysql alter system set resource_hard_limit = 800;
ob1.mysql alter system set merger_switch_leader_duration_time=0;
ob1.mysql alter system set enable_auto_leader_switch = false;
ob1.mysql alter system set enable_rereplication = false;
ob1.mysql alter system set enable_rebalance = false;
ob1.mysql alter system set debug_sync_timeout = '100000s';

let $ip = deploy_get_value(ob1.z1.obs0.ip);
let $port = deploy_get_value(ob1.z1.obs0.mysql_port);

ob1.create_client tenant=sys,user=root,passwd=,database=test;

create table test01(c1 int, c2 int, c3 varchar(4096), primary key(c1)) primary_zone='z1';
sleep 10;

let $cnt=1;
while($cnt < 10)
{
  eval insert into test01 values($cnt, $cnt, 'oceanbase');
  inc $cnt;
}

ob1.mysql alter system major freeze;
ob1.check_version 2;

create index index01 on test01(c3);
ob1.z1.obs0.mysql alter system set_tp tp_no = 19, error_code = 4109, frequency = 1;
sleep 10;
ob1.mysql alter system major freeze;
ob1.check_version 3;
ob1.check_until_timeout select index_status from oceanbase.__all_virtual_table where table_name like '%index01%', 5, 20;
select hold_count from oceanbase.__all_virtual_macro_block_marker_status;
select hold from oceanbase.__all_virtual_memory_info where mod_name = 'OB_ASYNC_EXTERNAL_SORTER' and tenant_id = 500;
select hold from oceanbase.__all_virtual_memory_info where mod_name = 'OB_SORT_TEMP_MACRO_READER' and tenant_id = 500;
select hold from oceanbase.__all_virtual_memory_info where mod_name = 'OB_SORT_TEMP_MACRO_WRITER' and tenant_id = 500;
