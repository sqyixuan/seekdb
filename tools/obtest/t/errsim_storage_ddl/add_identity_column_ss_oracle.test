# owner: jianyun.sjy
# owner group: storage
# description: simulate error for adding identity column in shared storage mode, which should retry via another table

--disable_query_log
ob1=OBI(cluster=1,proxy_num=0);
ob1.reboot;

ob1.mysql alter system set merger_check_interval='10s';
ob1.mysql alter system set enable_rebalance = 'false';
ob1.mysql alter system set resource_hard_limit=500;
ob1.mysql alter system set debug_sync_timeout = '100000s';
ob1.mysql alter system set syslog_io_bandwidth_limit = '4G';
let $ip0 = deploy_get_value(ob1.z1.obs0.ip);
let $mysql_port0 = deploy_get_value(ob1.z1.obs0.mysql_port);

--echo ===============================================================
--echo ==================     create tenant   ========================
--echo ===============================================================
--echo test case for create tenant begin
#Oracle tenant
ob_connect(conn_sys, ob1.z1.obs0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);
set @@session.ob_query_timeout = 1000000000;
eval CREATE RESOURCE UNIT unit_1 MAX_CPU 2, MEMORY_SIZE='4G';
eval CREATE RESOURCE POOL pool_1 UNIT = 'unit_1', UNIT_NUM = 1;
eval CREATE TENANT obtest RESOURCE_POOL_LIST = ('pool_1'), primary_zone='z1' set ob_tcp_invited_nodes='%', ob_compatibility_mode='oracle';
--echo test case for create tenant finish


ob_connect(conn_oracle, ob1.z1.obs0, SYS@obtest, ,SYS, , USE_OB_CONNECTOR);
connection conn_oracle;
create user test IDENTIFIED BY "test";
grant all on *.* to test WITH GRANT OPTION;

ob_connect(conn_obtest1, ob1.z1.obs0, SYS@obtest, ,test, , USE_OB_CONNECTOR);

connection conn_obtest1;
create table t1(c1 int, c2 int);
insert into t1 values (1, 1000);
insert into t1 values (2, null);
insert into t1 values (3, 1010);
insert into t1 values (4, null);

ob1.z1.obs0.mysql alter system set_tp tp_no = 512, error_code = 6231, frequency = 1;
sleep 5;
let $table_id = deploy_get_value(ob1.select select table_id from __all_virtual_table where table_name like '%t1%', table_id, 1);
let $leader_host = deploy_get_value(ob1.select select concat(svr_ip, ':', svr_port) host from __all_virtual_core_meta_table where role = 1, host, 1);
let $leader_obs = deploy_get_value(ob1.get_obs_by_addr $leader_host);

sleep 2;
send alter table t1 add c3 NUMBER GENERATED BY DEFAULT AS IDENTITY;
sleep 2;

ob1.z1.obs0.mysql alter system set_tp tp_no = 512, error_code = 0, frequency = 1;
sleep 5;
let $ret_code = deploy_get_value(ob1.select select ret_code from __all_virtual_ddl_error_message where ret_code=-6231 limit 1, ret_code, 1);
echo $ret_code;

sleep 5;
connection conn_obtest1;
reap;
