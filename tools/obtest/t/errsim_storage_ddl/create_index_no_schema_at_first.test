# owner: zhenjiang.xzj
# owner group: storage
# description: simulate build index cannot find schema and retry

--disable_query_log
ob1=OBI(cluster=1:1:1,proxy_num=0,init_unit_cpu=2);
ob1.reboot;

let $ip0 = deploy_get_value(ob1.z1.obs0.ip);
let $mysql_port0 = deploy_get_value(ob1.z1.obs0.mysql_port);

connect(conn_obtest1,$ip0,root@obtest,,test,$mysql_port0);

connection conn_obtest1;
create table t1(c1 int, c2 int);
insert into t1 values (1, 1);

# mock schema error at 50% chance, following index build should always success
ob1.mysql alter system set_tp tp_no = 512, error_code = 5019, frequency = 2;

sleep 2;
create index i1 on t1(c1) local;
sleep 5;
