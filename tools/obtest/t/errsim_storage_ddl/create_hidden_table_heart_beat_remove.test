# owner: hanshiyv.hsy
# owner group: storage
# description: create_hidden_table() fail heart_beat remove

--disable_query_log
ob1=OBI(cluster=1:1:1,proxy_num=0);
ob1.reboot;
sleep 3;

let $cpu = 5;
let $memory = 2073741824;
let $pwd = deploy_get_value(ob1.z1.obs0.workdir);
ob_connect(conn_mysql, ob1.z1.obs0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);
--enable_query_log
create table t1 (a int, b int);
set @@ob_query_timeout = 1000000*60*60*10, @@ob_trx_timeout=1000000*60*60*10;

--disable_query_log
insert into t1 values (1, 1);
insert into t1 values (2, 2);
insert into t1 values (3, 3);
insert into t1 values (4, 4);
insert into t1 values (5, 5);
insert into t1 values (6, 6);
insert into t1 values (7, 7);
select count(*) from t1;
--enable_query_log
create table t2 (a int, b int);

--disable_query_log
ob1.z1.obs0.mysql alter system set_tp tp_no = 517, error_code = 4002, frequency = 1;
sleep 3;
--error 1210
insert /*+ enable_parallel_dml parallel(2) append */ into t2 select * from t1;
--enable_query_log
