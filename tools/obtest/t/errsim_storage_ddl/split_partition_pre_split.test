### 20. 自动分区非分区表，创建全局唯一索引预分裂 (单列，多列)
echo "------------------------------ case 20 --------------------------------";
drop table if exists t1;
create table t1(c1 int, c2 int, c3 int, primary key(c1)) partition by range();
insert into t1 values(1,1,1);
insert into t1 values(2,1,1);
insert into t1 values(3,1,1);
insert into t1 values(4,1,1);
insert into t1 values(5,1,1);
insert into t1 values(6,1,1);
insert into t1 values(7,1,1);
insert into t1 values(8,1,1);
insert into t1 values(9,1,1);
insert into t1 values(10,1,1);

alter system minor freeze;
sleep 5;

create unique index idx1 on t1(c1) global;
create unique index idx2 on t1(c1,c2) global;

show create table t1;


drop table if exists t1;
