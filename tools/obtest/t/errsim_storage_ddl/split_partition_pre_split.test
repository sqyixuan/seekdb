insert into t1 values(5,1,1);
insert into t1 values(6,1,1);
insert into t1 values(7,1,1);
insert into t1 values(8,1,1);
insert into t1 values(9,1,1);
insert into t1 values(10,1,1);

alter system minor freeze;
sleep 5;

create index idx1 on t1(c1,c2) global;
show create table t1;

alter table t1 add index idx2(c1,c2) global;
show create table t1;

### 4. 自动分区分区表，创建全局索引分区表
echo "------------------------------ case 04 --------------------------------";
drop table if exists t1;
create table t1(c1 int, c2 int, c3 int, primary key(c1)) partition by range(c1) size('10GB') (partition p0 values less than (5), partition p1 values less than (maxvalue));
insert into t1 values(1,1,1);
insert into t1 values(2,1,1);
insert into t1 values(3,1,1);
insert into t1 values(4,1,1);
insert into t1 values(5,1,1);
insert into t1 values(6,1,1);
insert into t1 values(7,1,1);
insert into t1 values(8,1,1);
insert into t1 values(9,1,1);
insert into t1 values(10,1,1);

alter system minor freeze;
sleep 5;

create index idx1 on t1(c1,c2) global partition by range columns(c1,c2) (partition p0 values less than (5,5), partition p1 values less than (maxvalue,maxvalue));
show create table t1;

alter table t1 add index idx2(c1,c2) global partition by range columns(c1,c2) (partition p0 values less than (5,5), partition p1 values less than (maxvalue,maxvalue));
show create table t1;

