create table t1(c1 int, c2 int, c3 int, primary key(c1)) partition by range(c1) size('10GB') (partition p0 values less than (5), partition p1 values less than (maxvalue));
insert into t1 values(1,1,1);
insert into t1 values(2,1,1);
insert into t1 values(3,1,1);
