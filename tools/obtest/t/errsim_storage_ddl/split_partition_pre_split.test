show create table t1;

### 10. 自动分区分区表，modify column
echo "------------------------------ case 10 --------------------------------";
drop table if exists t1;
create table t1(c1 int, c2 int, c3 varchar(20), primary key(c1)) partition by range(c1) size('10GB') (partition p0 values less than (5), partition p1 values less than (maxvalue));
insert into t1 values(1,1,'abc');
insert into t1 values(2,1,'bbc');
insert into t1 values(3,1,'cbc');
insert into t1 values(4,1,'dbc');
insert into t1 values(5,1,'ebc');
insert into t1 values(6,1,'fbc');
insert into t1 values(7,1,'gbc');
insert into t1 values(8,1,'hbc');
insert into t1 values(9,1,'ibc');
insert into t1 values(10,1,'jbc');

alter system minor freeze;
sleep 5;

alter table t1 modify c3 varchar(20) character set 'utf16';
show create table t1;

