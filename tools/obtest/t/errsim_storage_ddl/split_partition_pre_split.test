# owner: yangjiali.yjl
# owner group: opensource
# description: this case is use for check split partition pre_split

###--disable_result_log
###--enable_query_log

ob1=OBI(cluster=1,proxy_num=0,init_unit_cpu=2);
ob1.force_stop;
ob1.reboot;
sleep 3;

# create user tenant
ob_connect(conn_sys, ob1.z1.obs0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);
connection conn_sys;

CREATE RESOURCE UNIT unit MAX_CPU=1, MEMORY_SIZE=2147483648;
CREATE RESOURCE POOL pool UNIT = 'unit', UNIT_NUM = 1, zone_list = ('z1');
CREATE TENANT pre_split_tenant RESOURCE_POOL_LIST = ('pool'), primary_zone='z1' set ob_tcp_invited_nodes='%';

ob_connect(conn_pre_split, ob1.z1.obs0, root@pre_split_tenant, , test, , USE_MYSQL_CONNECTOR);
connection conn_pre_split;

### 1. 非自动分区表，创建全局索引表
echo "------------------------------ case 01 --------------------------------";
drop table if exists t1;
create table t1(c1 int, c2 int, c3 int, primary key(c1)) partition by range(c1) (partition p0 values less than (5), partition p1 values less than (maxvalue));
insert into t1 values(1,1,1);
insert into t1 values(2,1,1);
insert into t1 values(3,1,1);
insert into t1 values(4,1,1);
insert into t1 values(5,1,1);
insert into t1 values(6,1,1);
insert into t1 values(7,1,1);
insert into t1 values(8,1,1);
insert into t1 values(9,1,1);
insert into t1 values(10,1,1);

alter system minor freeze;
sleep 5;

create index idx1 on t1(c1) global;
show create table t1;
alter table t1 add index idx2(c2) global;
show create table t1;

### 2. 非自动分区表，修改分区规则
echo "------------------------------ case 02 --------------------------------";
drop table if exists t1;
create table t1(c1 int, c2 int, c3 int, primary key(c1)) partition by range(c1) (partition p0 values less than (5), partition p1 values less than (maxvalue));
