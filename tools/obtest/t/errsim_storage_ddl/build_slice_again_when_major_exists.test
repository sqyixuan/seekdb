# owner: liujixiong.ljx
# owner group: ddl
# description: to test the behavior of retry to write sstable slice when major has already existed.

--disable_query_log
ob1=OBI(cluster=1, proxy_num=0, init_unit_cpu=2, init_unit_num=1);
ob1.force_stop;
ob1.reboot;

ob_connect(conn_sys, ob1.z1.obs0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);
set @@global.ob_query_timeout = 100000000000;
ob1.mysql alter system set resource_hard_limit = 800;
ob1.mysql alter system set debug_sync_timeout = '100000s';

ob_connect(conn1, ob1.z1.obs0, root@obtest, , test, , USE_MYSQL_CONNECTOR);
sleep 2;
create sequence seq_pk INCREMENT BY 1 start with 1 minvalue 1 maxvalue 10000000 nocycle noorder nocache;
create table test(c1 bigint, c2 varchar(4096), c3 varchar(4096), c4 longtext) row_format = redundant, compression = 'none' with column group (all columns, each column);
insert /*+ query_timeout(100000000000) parallel(32) enable_parallel_dml */ into test select seq_pk.nextval c1, randstr(4096, random()) c2, randstr(4096,random()) c3, randstr(10240,random()) c4 from table(generator(2000));

ob1.mysql alter system set_tp tp_no = 520, error_code = 4614, frequency = 1;
SET SESSION _FORCE_PARALLEL_DDL_DOP = 3;
send alter table test add primary key(c1);
sleep 20;

ob_connect(conn2, ob1.z1.obs0, root@obtest, , test, , USE_MYSQL_CONNECTOR);
ob1.mysql alter system set_tp tp_no = 520, error_code = 0, frequency = 1;

connection conn1;
reap;
show create table test;
drop table test;
drop sequence seq_pk;
