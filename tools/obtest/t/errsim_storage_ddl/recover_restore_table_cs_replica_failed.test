# owner: ouyanghongrong.oyh
# owner group: storage
# Testing Case: recover restore table to column store replica is not supported
 
ob1=OBI(cluster=1:1, proxy_num=0);
source include/mini_ob_config.inc;
ob1.z1.obs0.set extra_config = "cache_wash_threshold='1G',_ob_minor_merge_schedule_interval='3s'";
 
let $backup_ip       = deploy_get_value(ob1.z1.obs0.ip);
let $backup_port     = deploy_get_value(ob1.z1.obs0.mysql_port);
let $backup_dest = deploy_get_value(ob1.get_backup_dest);
let $backup_oracle_tenant   = backup_oracle_tenant;
let $backup_mysql_tenant    = backup_mysql_tenant;
let $log_backup_dest = deploy_get_value(ob1.get_log_backup_dest $backup_oracle_tenant);
let $data_backup_dest = deploy_get_value(ob1.get_data_backup_dest $backup_oracle_tenant);
 
# 必须先stop掉老的，删除才能有效，不然可能会有残留。
ob1.force_stop;
ob1.clean_backup_dest;
ob1.reboot;
 
# 固定sys租户规格
ob1.mysql alter resource unit sys_unit_config memory_size='2G';
 
connect(backup_sys_conn, $backup_ip, root@sys,,oceanbase, $backup_port);
connection backup_sys_conn;
use oceanbase;
 
alter system set resource_hard_limit = 1000;
alter system set _restore_idle_time = '10s';
 
CREATE RESOURCE UNIT small_unit MAX_CPU=1, MEMORY_SIZE='4G';
CREATE RESOURCE POOL small_pool UNIT small_unit, UNIT_NUM 1, ZONE_LIST ('z1', 'z2');
CREATE RESOURCE POOL small_pool_0 UNIT small_unit, UNIT_NUM 1, ZONE_LIST ('z1');
 
ob1.mysql alter system set _backup_idle_time = '10s';
ob1.mysql alter system set enable_async_syslog=false;
 
# create oracle tenant, test create tenant before major freeze
ob1.mysql CREATE TENANT $backup_oracle_tenant RESOURCE_POOL_LIST = ('small_pool'), zone_list = ('z1', 'z2'), locality = "F@z1, C@z2" set ob_tcp_invited_nodes='%', ob_compatibility_mode='mysql',lower_case_table_names=1;
let $backup_oracle_tenant_id = query_get_value(select tenant_id from oceanbase.__all_tenant where tenant_name='$backup_oracle_tenant', tenant_id, 1);
 
ob_connect(sys_conn_oracle, ob1.z1.obs0, root@$backup_oracle_tenant, ,oceanbase, , USE_OB_CONNECTOR);
connection sys_conn_oracle;
set global wait_timeout = 288000;
 
--disable_all_result_log
eval alter system set log_archive_dest='location=$log_backup_dest';
eval alter system set data_backup_dest='$data_backup_dest';
--enable_all_result_log
 
--echo ===============================================================
--echo ====================     create table   =======================
--echo ===============================================================
connection sys_conn_oracle;
use test;
create table t0 (c0 int primary key, c1 char(100));
create table t1 (c1 int primary key,
                 c2 char(100) not null,
                 c3 char(50) unique,
                 c4 int check(c4>20),
                 c5 int,
                 c6 set ('abc', 'cde', 'def'),
                 c7 enum ('a', 'b', 'c'),
                 c8 char(100) generated always as (substr(c2, 1, 20)) virtual,
                 c9 char(100) generated always as (substr(c2, 1, 20)) stored,
                 CONSTRAINT t1_fk FOREIGN KEY(c1) REFERENCES t0 (c0));
insert into t0 values (1, "Mysql");
insert into t0 values (2, "Oracle");
insert into t0 values (3, "OceanBase");
insert into t0 values (4, "Mysql");
insert into t1 (c1, c2, c3, c4, c5, c6, c7) values (1, 'allen ', '1234567890123', 30, 1, 'abc', 'a');
insert into t1 (c1, c2, c3, c4, c5, c6, c7) values (2, 'sam ', '2234567890123', 30, 2, 'cde', 'c');
insert into t1 (c1, c2, c3, c4, c5, c6, c7) values (3, 'billy ', '3234567890123', 30, 3, 'cde', 'b');
insert into t1 (c1, c2, c3, c4, c5, c6, c7) values (4, 'carl', '4234567890123', 30, 4, 'cde', 'a');
 
create table t2 (c1 int, 
                 c2 int, 
                 c3 int, 
                 c4 int, 
                 c5 int,
                 CONSTRAINT t2_cst_pk PRIMARY KEY (c1),
                 constraint t2_cst_chk_1 check(c1=c2),
                 constraint t2_cst_chk_2 check(c1=c2),
                 constraint t2_cst_unique_1 unique(c3, c1),
                 constraint t2_cst_unique_2 unique(c4, c1),
                 constraint t2_OBCHECK_123456 check(c2=c3),
                 constraint t2_OBUNIQUE_123456 unique(c5, c1),
                 constraint t2_fk_1 FOREIGN KEY(c1) REFERENCES t0(c0),
                 constraint t2_fk_2 FOREIGN KEY(c1) REFERENCES t1(c1)) partition by hash(c1) partitions 3;
insert into t2 values(1, 1, 1, 1, 1);
insert into t2 values(2, 2, 2, 2, 2);
insert into t2 values(3, 3, 3, 3, 3);
insert into t2 values(4, 4, 4, 4, 4);
 
# trigger related.
CREATE TRIGGER recover_trig1 BEFORE insert on t2 FOR EACH ROW BEGIN insert into t0 values(5, "Mysql"); END;

CREATE TRIGGER recover_trig2 BEFORE update on t2 FOR EACH ROW BEGIN update t0 set c1 = "Mysql 8.0" where c1 = "Mysql"; END;

CREATE TRIGGER recover_trig3 BEFORE delete on t1 FOR EACH ROW BEGIN insert into t1 (c1, c2, c3, c4, c5, c6, c7) values (100, 'allen_bob ', 'trigger_insert', 30, 1, 'abc', 'a'); END;


--echo ===============================================================
--echo ==============   check constraint and index   =================
--echo ===============================================================
connection backup_sys_conn;
use oceanbase;
--replace_regex /__idx_[0-9]*/__idx_DATA_TABLE_ID/g
--replace_regex /OBUNIQUE_[0-9]*/OBUNIQUE_TIMESTAMP/g
select table_name, index_type, index_status from oceanbase.__all_virtual_table where data_table_id in (
    select table_id from oceanbase.__all_virtual_table where table_name = 't1' or table_name = 't2');
--replace_regex /OBPK_[0-9]*/OBPK_TIMESTAMP/g
--replace_regex /OBNOTNULL_[0-9]*/OBNOTNULL_TIMESTAMP/g
--replace_regex /OBCHECK_[0-9]*/OBCHECK_TIMESTAMP/g
select constraint_name, constraint_type, check_expr, rely_flag, enable_flag, validate_flag from oceanbase.__all_virtual_constraint where table_id in (
    select table_id from oceanbase.__all_virtual_table where table_name = 't1' or table_name = 't2');
 
--echo ===============================================================
--echo ==============   backup and archive   =========================
--echo ===============================================================
connection backup_sys_conn;
use oceanbase;
ob1.mysql alter system archivelog;
ob1.check_until_timeout select status from oceanbase.CDB_OB_ARCHIVELOG where tenant_id=$backup_oracle_tenant_id, DOING, 600;
ob1.mysql alter system backup database;
ob1.check_until_timeout select count(*) from cdb_ob_backup_jobs, 0, 600;
let $restore_checkpoint1 = query_get_value(select min_restore_scn from CDB_OB_BACKUP_SET_FILES where tenant_id = $backup_oracle_tenant_id, min_restore_scn, 1);
ob1.check_until_timeout select checkpoint_scn > $restore_checkpoint1 from CDB_OB_ARCHIVELOG, 1, 600;
 
--echo ===============================================================
--echo ====================   recover table   ========================
--echo ===============================================================
connection sys_conn_oracle;
create database recover_test;
 
connection backup_sys_conn;
use oceanbase;
let $restore_path = $log_backup_dest,$data_backup_dest;
ob1.mysql alter system recover table test.t0, test.t1, test.t2 to tenant backup_oracle_tenant from '$restore_path' until scn = $restore_checkpoint1 with 'pool_list=small_pool_0&primary_zone=z1' remap table test.t0:recover_test.t0,test.t1:recover_test.recover_restore_normal_table_t1,test.t2:recover_test.recover_restore_normal_table_t2;
 
ob1.check_until_timeout select status from cdb_ob_restore_history where tenant_id = 1 and restore_tenant_id = 1004, SUCCESS, 600;
ob1.check_until_timeout select count(*) from __all_virtual_recover_table_job, 0, 600;

--echo
--echo to check result after trigger operation.
connection sys_conn_oracle;
use recover_test;
insert into recover_restore_normal_table_t2 values(5, 5, 5, 5, 5);
select * from t0;

update recover_restore_normal_table_t2 set c5 = 100 where c5 = 1;
select * from t0;

--error 1146
delete from recover_restore_normal_table_t1 where c1 = 4;
select * from recover_restore_normal_table_t1;

--echo
--echo to show rebuild index, csts, foreign keys.
connection backup_sys_conn;
use oceanbase;
--replace_regex /__idx_[0-9]*/__idx_DATA_TABLE_ID/g
--replace_regex /OBUNIQUE_[0-9]*/OBUNIQUE_TIMESTAMP/g
select table_name, index_type, index_status from oceanbase.__all_virtual_table where data_table_id in (
    select table_id from oceanbase.__all_virtual_table where table_name like '%recover_restore_normal_table%');
--replace_regex /OBPK_[0-9]*/OBPK_TIMESTAMP/g
--replace_regex /OBNOTNULL_[0-9]*/OBNOTNULL_TIMESTAMP/g
--replace_regex /OBCHECK_[0-9]*/OBCHECK_TIMESTAMP/g
select constraint_name, constraint_type, check_expr, rely_flag, enable_flag, validate_flag from oceanbase.__all_virtual_constraint where table_id in (
    select table_id from oceanbase.__all_virtual_table where table_name like '%recover_restore_normal_table%');
select foreign_key_name, update_action, delete_action, ref_cst_type, rely_flag, enable_flag, validate_flag, is_parent_table_mock from oceanbase.__all_virtual_foreign_key where child_table_id in (select table_id from oceanbase.__all_virtual_table where table_name like '%recover_restore_normal_table%');
select trigger_name, trigger_type, trigger_events, timing_points, trigger_flags, trigger_body, package_spec_source, package_body_source from oceanbase.__all_virtual_trigger where base_object_id in (select table_id from oceanbase.__all_virtual_table where table_name like '%recover_restore_normal_table%');
eval SELECT DDL_STMT_STR FROM OCEANBASE.__ALL_VIRTUAL_DDL_OPERATION WHERE tenant_id = $backup_oracle_tenant_id and (ddl_stmt_str != '' and ddl_stmt_str not like '%GRANT%' and ddl_stmt_str not like '%USER%' and ddl_stmt_str not like '%ROLE%') order by gmt_create;
