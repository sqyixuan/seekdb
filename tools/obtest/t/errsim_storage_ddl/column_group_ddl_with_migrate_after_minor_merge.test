# owner: jianyun.sjy
# owner group: storage/ddl
# test for column group ddl with migrate in this condition:
# 1. parallel ddl write data and dump ddl sstable
# 2. migrate copy ddl sstable to another server and replay macro blocks remained
# 3. execute major compaction and check replica checksum, to prevent incorrect block order

ob1=OBI(cluster=2:2:2, proxy_num=0);


--echo ===============================================================
--echo ====================     bootstrap   ==========================
--echo ===============================================================
--echo test case for bootstrap begin
ob1.reboot;
sleep 3;
let $sys_tenant_id = 1;
ob1.mysql alter system set enable_rebalance='false';
ob1.mysql alter system set syslog_io_bandwidth_limit = '4G';
ob_connect(conn_sys, ob1.z1.obs0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);
--echo test case for bootstrap finish

--echo ===============================================================
--echo ==================     create tenant   ========================
--echo ===============================================================
# 注意: 创建初始mysql租户'F@z1, F@z3'
--echo test case for create tenant begin
set @@session.ob_query_timeout = 1000000000;
#mysql tenant
eval CREATE RESOURCE UNIT unit_1 MAX_CPU 2, MEMORY_SIZE='8G';
eval CREATE RESOURCE POOL pool_1 UNIT = 'unit_1', UNIT_NUM = 1;
eval CREATE TENANT mysql RESOURCE_POOL_LIST = ('pool_1'), primary_zone='z1' set ob_tcp_invited_nodes='%';
source include/check_schema_sync.inc;
connection conn_sys;
let $mysql_tenant_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name = 'mysql', tenant_id, 1);
ob_connect(conn_mysql, ob1.z1.obs1, root@mysql, , test, , USE_MYSQL_CONNECTOR);
--echo test case for create tenant finish


--echo ===============================================================
--echo ============             execute ddl            ===============
--echo ===============================================================
--echo test case for create index begin

ob1.mysql alter system set debug_sync_timeout = '100000s';
sleep 5;

# debug sync after write the first macro block
ob1.mysql set ob_global_debug_sync = 'AFTER_MACRO_BLOCK_WRITER_DDL_CALLBACK_WAIT wait_for signal_ddl_callback execute 100000';
connection conn_mysql;

# create table with column group and write some data
create table t1(c1 varchar(1024), c2 bigint, c3 varchar(1024), primary key(c1, c2)) with column group (all columns, each column);
create sequence s1 cache 1000000 noorder;
set ob_query_timeout=100000000;
insert into t1 select randstr(1024, random()) c1, s1.nextval c2, randstr(512, random()) c3 from table(generator(100000));

# execute ddl with parallel 2
SET SESSION _FORCE_PARALLEL_DDL_DOP = 2;
send alter table t1 modify column c3 varchar(512);
sleep 5;

--echo ===============================================================
--echo ============           dump ddl sstable         ===============
--echo ===============================================================
connection conn_sys;
alter system minor freeze tenant mysql;

let $data_table_id = deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where tenant_id = $mysql_tenant_id and table_name like '%hidden%', table_id, 1);
let $data_tablet_id = deploy_get_value(ob1.select select tablet_id from oceanbase.__all_virtual_table where tenant_id = $mysql_tenant_id and table_id = $data_table_id, tablet_id, 1);

# wait ddl merge finish
let $__index__ = 1;
while ($__index__ <= 120)
{
  let $macro_block_count = deploy_get_value(ob1.select select sum(data_block_count) as data_block_cnt from oceanbase.__all_virtual_table_mgr where tenant_id = $mysql_tenant_id and tablet_id = $data_tablet_id and table_type=22, data_block_cnt, 1);
  sleep 1;
  inc $__index__;
  if ($macro_block_count >= 6)
  {
    let $__index__ = 1000;
  }
}

ob_connect(conn0, ob1.z1.obs0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);
source include/wait_minor_merge.inc;

--echo ===============================================================
--echo ==================     migrate unit    ========================
--echo ===============================================================
--echo test migrate unit begin
source t/quick/include/migrate_unit.inc;
source t/quick/include/migrate_unit_check_gc.inc;
--echo test migrate unit finish

--echo ===============================================================
--echo ==================     recover ddl     ========================
--echo ===============================================================
--echo recover ddl begin
ob1.mysql set ob_global_debug_sync = 'AFTER_MACRO_BLOCK_WRITER_DDL_CALLBACK_WAIT clear';
ob1.mysql set ob_global_debug_sync = 'now broadcast signal_ddl_callback';

connection conn_mysql;
reap;
select count(*) from t1;
sleep 10;

connection conn_sys;
alter system major freeze tenant mysql;
ob1.check_until_timeout select (frozen_scn - last_scn) as result from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id=$mysql_tenant_id, 0, 600;
# check replica checksum error
select * from CDB_OB_TABLET_CHECKSUM_ERROR_INFO;

--echo ===============================================================
--echo ===================         clear      ========================
--echo ===============================================================

