############################### Oracle tenant and tp_no = 501 ###############################
--disable_query_log
# ob1=OBI(cluster=1, proxy_num=1, init_unit_cpu=2, init_unit_num=1);
ob1.force_stop;
ob1.reboot;

###create oracle tenant
ob1.mysql create resource unit box1 max_cpu 2, max_memory 5368709120, max_iops 100000, max_disk_size '5G', max_session_num 64, MIN_CPU=1, MIN_MEMORY=5368709120, MIN_IOPS=128;
ob1.mysql create resource pool pool1 unit = 'box1', unit_num = 1;
ob1.mysql create tenant oracle replica_num = 1, resource_pool_list=('pool1') set ob_tcp_invited_nodes='%', ob_compatibility_mode='oracle';
ob1.mysql alter tenant oracle set variables autocommit='on';

ob_connect(conn_oracle, ob1, SYS@oracle, ,SYS, , USE_OB_CONNECTOR);
connection conn_oracle;
create user obtest IDENTIFIED BY "obtest";
grant all to obtest;
ob_connect(conn_oracle_obtest, ob1, OBTEST@oracle, obtest, OBTEST,, USE_OB_CONNECTOR);
ob1.mysql alter system set_tp tp_no = 501, error_code = 4103, frequency = 1;

# check constraint, char(m)-> char(>m);
create table t0(c1 int, c2 char(20) check(c2 in ('Test1', 'Test2', 'Test3')));
insert into t0 values(1, 'Test1'), (2, 'Test2'), (3, 'Test3');
--error 600
alter table t0 modify c2 char(21);
drop table t0;

# partition key, char(m) -> char(>m)
create table t0(c1 int, c2 char(20)) partition by hash(c2) partitions 2;
insert into t0 values(1, 'Test1'), (2, 'Test2'), (3, 'Test3');
### data type or length of a table partitioning column may not be changed
--error 14060 
alter table t0 modify c2 char(21);
drop table t0;

# char(m) -> (char(>m), varchar(>m))
create table t1(c1 int, c2 char(20) primary key);
insert into t1 values(1, 'Test1'), (2, 'Test2'), (3, 'Test3');
--error 600
alter table t1 modify c2 char(21);
--error 600
alter table t1 modify c2 varchar(21);
drop table t1;

# vachar(m) -> {varchar(n), char(<n)} m > n
create table t2(c1 int, c2 varchar(20) primary key);
insert into t2 values(1, 'Test1'), (2, 'Test2'), (3, 'Test3');
--error 600
alter table t2 modify c2 varchar(15);
--error 600
alter table t2 modify c2 char(13);
# 长度变长，大类型变更有依赖对象需要offline
--error 600
alter table t2 modify c2 char(50);
drop table t2;

# nchar(n) -> {nchar(>n), nvarchar2} 
create table t3 (c1 int, c2 nchar(10) primary key);
insert into t3 values(1, 'Test1'), (2, 'Test2'), (3, 'Test3');
--error 600
alter table t3 modify c2 nchar(20);
--error 600
alter table t3 modify c2 nvarchar2(20);
drop table t3;

# nvarchar2(m) -> {nvarchar2(<m), nchar}
create table t4(c1 int, c2 nvarchar2(30) primary key);
insert into t4 values(1, 'Test1'), (2, 'Test2'), (3, 'Test3');
--error 600
alter table t4 modify c2 nvarchar2(20);
--error 600
alter table t4 modify c2 nchar(10);
drop table t4;

# 源类型精度<目标类型精度，且大类型变更有依赖对象需要offline
create table t5 (c1 int, c2 timestamp check(c2 > timestamp '1971-01-01 00:00:00'));
insert into t5 values(1, current_timestamp), (2, current_timestamp), (3, current_timestamp);
--error 600
alter table t5 modify c2 timestamp(9);
drop table t5;

create table t6 (c1 int, c2 timestamp) partition by range(c2)
(
    partition p1 values less than (timestamp '2000-01-01 00:00:00'),
    partition p2 values less than (timestamp '2010-01-01 00:00:00'),
    partition p3 values less than (maxvalue)
);
insert into t6 values(1, current_timestamp), (2, current_timestamp), (3, current_timestamp);
### data type or length of a table partitioning column may not be changed
--error 14060
alter table t6 modify c2 timestamp(9);
drop table t6;

# urowid 降低精度需要offline ddl，urowid(size)指的是字节数
UROWID(m) -> {UROWID(<m)}
create table t7 (c1 int, c2 UROWID(100));
insert into t7 values (1, '*AAEtFwAAAAABDwQEAMEVzVsHsWjeOhXNWwfq/D40'), (2, '*AAEtFwAAAAABDwQEAMEVzVsHsWjeOhXNWwfq/D40');
--error 600
alter table t7 modify c2 UROWID(50);


