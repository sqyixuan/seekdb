# owner: liujixiong.ljx
# owner group: storage
# description: this case is use for test the program execution logic after checksum error injection.

############################### Mysql tenant and tp_no = 501 ###############################
--disable_query_log
ob1=OBI(cluster=1, proxy_num=1, init_unit_cpu=2, init_unit_num=1);
ob1.force_stop;
ob1.reboot;

#设置灰度切主的时间为0, 关闭自动切主，关闭自动balance
ob1.mysql alter system set resource_hard_limit = 800;
ob1.mysql alter system set merger_switch_leader_duration_time=0;
ob1.mysql alter system set enable_auto_leader_switch = false;
ob1.mysql alter system set enable_rereplication = false;
ob1.mysql alter system set enable_rebalance = false;
ob1.mysql alter system set debug_sync_timeout = '100000s';

let $ip = deploy_get_value(ob1.z1.obs0.ip);
let $port = deploy_get_value(ob1.z1.obs0.mysql_port);

connect (conn_obtest,$ip,root@obtest,,test,$port);
connection conn_obtest;

# int -> mediumint
create table test01(c1 int, c2 int);
let $cnt=1;
while($cnt < 10)
{
  eval insert into test01 values($cnt, $cnt);
  inc $cnt;
}
# ob1.mysql alter system major freeze;
# ob1.check_version 2;
ob1.z1.obs0.mysql alter system set_tp tp_no = 501, error_code = 4103, frequency = 1;
--error 4103
alter table test01 modify column c2 mediumint;
drop table test01;

# mediumint ->int, 有依赖对象为主键、分区键、check约束等时，需要offline
create table test01(c1 int, c2 mediumint) partition by range(c2)
(
  partition p1 values less than(5),
  partition p2 values less than(maxvalue)
);
let $cnt=1;
while($cnt < 10)
{
  eval insert into test01 values($cnt, $cnt);
  inc $cnt;
}
--error 4103
alter table test01 modify c2 int;
drop table test01;

# char(m) -> {char(<m) -> varchar  -> char(>m 有依赖对象)}
create table test02(c1 int, c2 char(30));
insert into test02 values(1, 'Test1'), (2, 'Test2'), (3, 'Test3');
--error 4103
alter table test02 modify column c2 char(20);
--error 4103
alter table test02 modify column c2 varchar(18);
drop table test02;

# char类型长度变长，有依赖对象，需要offline
create table test02(c1 int, c2 char(30) primary key);
insert into test02 values(1, 'Test1'), (2, 'Test2'), (3, 'Test3');
--error 4103
alter table test02 modify column c2 char(50);
drop table test02;

# varchar(m) -> {varchar(<m), char(<m), char(>m 有依赖对象)}
create table test02(c1 int, c2 varchar(30));
insert into test02 values(1, 'Test1'), (2, 'Test2'), (3, 'Test3');
--error 4103
alter table test02 modify column c2 varchar(15);
--error 4103
alter table test02 modify column c2 char(10);
drop table test02;

create table test02(c1 int, c2 varchar(30) primary key);
insert into test02 values(1, 'Test1'), (2, 'Test2'), (3, 'Test3');
--error 4103
alter table test02 modify column c2 char(50);


