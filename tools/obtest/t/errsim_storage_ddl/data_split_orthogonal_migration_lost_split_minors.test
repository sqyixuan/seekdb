##########################
# owner : jyx441808, liujixiong.ljx
# owner group: HA, DDL
# description: to test minor sstables generated by the data split are discarded by the ls migration.
# A, B, C1(migrate source) & C2 (migrate dest) replicas.
# 1. create table and load data(major and multi minors).
# 2. block MDS mini merge.
# 3. ERRSIM to block data split in Replica C1.
# 4. insert incremental data into table, and minor freeze.
# 5. trigger ls migration
# 6. wait replica C2 data split finished.
# 7. migration op copies dest tablets' sstables(only incremental minors), C2 will discard all split-minors, and keeps the incremental minors copied from C1.

# 问题场景：数据分裂正交日志流迁移场景下，迁移拷贝到的end_scn更大的增量转储"覆盖了"目的端物理分裂产生的转储(实际上迁移认为拉到了更新的转储，认为本地较老的转储是过期数据而直接丢弃).
# case触发时序如下(日志流有A, B, C1(迁移源端)， C2(迁移目的端))
# 1. 建表，并往分区灌数据，产生转储
# 2. 阻止MDS数据转储，因为C2端需要SPLIT-MDS来进行物理分裂，依赖C2回放SPLIT-MDS多源日志
# 3. 触发分裂，其中需要卡C1的物理分裂，以阻止C1端的目的分区有物理分裂产生的转储&基线(SPLIT-MDS在C2端回放产生了，不会影响C2物理分裂)
# 4. 往分区灌数据，触发转储，以形成新增量转储
# 5. 触发迁移，C2从C1拷贝数据只看到新增量转储，同时卡增量转储放到C2端的table store
# 6. C2端物理分裂完成
# 7. 迁移拷贝的新增量转储开始放入C2端table store时，认为老转储(end_scn更小)是过期数据便丢弃，导致老转储数据丢失
# 注，数据完整/正确的校验依赖case最后的等合并完成，并检查是否有chksum error.



ob1=OBI(cluster=1:1:2,proxy_num=0,init_unit_cpu=0);
ob1.reboot;

let $tenant_name = migrate_rebuild_1005_2;

--echo ===============================================================
--echo ====================     bootstrap   ==========================
--echo ===============================================================

ob1.mysql alter system set enable_rebalance = 'false';
ob1.mysql alter system set default_compress_func = 'none';
ob1.mysql alter system set debug_sync_timeout = '100000s';

let $proxy_ip = deploy_get_value(ob1.z1.obs0.ip);
let $proxy_port = deploy_get_value(ob1.z1.obs0.mysql_port);

ob_connect(sys_conn, $proxy_ip, root@sys,,oceanbase, $proxy_port);

--echo ===============================================================
--echo ==================     create tenant   ========================
--echo ===============================================================

connection sys_conn;

ob1.mysql CREATE RESOURCE UNIT unit_1 MAX_CPU = 2, MEMORY_SIZE = '4G', MAX_IOPS = 2048, LOG_DISK_SIZE = '10G';
ob1.mysql CREATE RESOURCE POOL pool_1 UNIT = "unit_1", UNIT_NUM = 1, ZONE_LIST = ('z1', 'z2', 'z3');
ob1.mysql CREATE TENANT $tenant_name resource_pool_list=('pool_1'), locality = "F@z1,F@z3", primary_zone = "z1" set ob_tcp_invited_nodes='%';

let $tenant_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name = "$tenant_name", tenant_id, 1);
let $resource_pool_id = deploy_get_value(ob1.select select resource_pool_id from oceanbase.__all_resource_pool where tenant_id = $tenant_id, resource_pool_id, 1);

ob1.mysql alter system set ob_compaction_schedule_interval = '10s' tenant sys;
ob1.mysql alter system set ob_compaction_schedule_interval = '10s' tenant all_user;
ob1.mysql alter system set ob_compaction_schedule_interval = '10s' tenant all_meta;

--echo ===============================================================
--echo ===================    create tables   ========================
--echo ===============================================================

# skip mds mini merge
ob1.mysql alter system set_tp tp_name = EN_SKIP_MDS_MINI_MERGE, error_code = 4016, frequency = 1;

ob_connect(z1_obs0, ob1.z1.obs0, root@$tenant_name, , test, , USE_MYSQL_CONNECTOR);
ob_connect(z1_obs0_1, ob1.z1.obs0, root@$tenant_name, , test, , USE_MYSQL_CONNECTOR);
ob_connect(z1_obs0_2, ob1.z1.obs0, root@$tenant_name, , test, , USE_MYSQL_CONNECTOR);

connection z1_obs0;

let $dst_ip0 = deploy_get_value(ob1.z3.obs0.ip);
let $dst_port0 = deploy_get_value(ob1.z3.obs0.port);

let $dst_ip1 = deploy_get_value(ob1.z3.obs1.ip);
let $dst_port1 = deploy_get_value(ob1.z3.obs1.port);

let $dst0 = $dst_ip0:$dst_port0;
let $dst1 = $dst_ip1:$dst_port1;

let $unit_id = deploy_get_value(ob1.select select unit_id from oceanbase.__all_unit where resource_pool_id = $resource_pool_id and zone = 'z3', unit_id, 1);
let $ip = deploy_get_value(ob1.select select svr_ip from oceanbase.__all_unit where unit_id = $unit_id, svr_ip, 1);
let $port = deploy_get_value(ob1.select select svr_port from oceanbase.__all_unit where unit_id = $unit_id, svr_port, 1);

let $cur = $ip:$port;

# z3s0 -> z3s1
if ($cur == $dst0)
{
    let $cur_obs = ob1.z3.obs0;
    let $dst_obs = ob1.z3.obs1;
    let $dst_ip = $dst_ip1;
    let $dst_port = $dst_port1;
    let $dst = $dst_ip:$dst_port;
    let $cur_ip = $dst_ip0;
    let $cur_port = $dst_port0;
    let $cur = $cur_ip:$cur_port;
}
# z3s1 -> z3s0
if ($cur == $dst1)
{
    let $cur_obs = ob1.z3.obs1;
    let $dst_obs = ob1.z3.obs0;
    let $dst_ip = $dst_ip0;
    let $dst_port = $dst_port0;
    let $dst = $dst_ip:$dst_port;
    let $cur_ip = $dst_ip1;
    let $cur_port = $dst_port1;
    let $cur = $cur_ip:$cur_port;
}
ob_connect(cur_conn, $cur_obs, root@$tenant_name, , test, , USE_MYSQL_CONNECTOR);

connection z1_obs0;

# create split table
create sequence seq_pk_small INCREMENT BY 1 start with 1 minvalue 1 maxvalue 5000000 nocycle noorder nocache;
create sequence seq_pk_large INCREMENT BY 1 start with 5001 minvalue 1 maxvalue 5000000 nocycle noorder nocache;
create table test_with_migrate(c1 bigint, c2 bigint, c3 varchar(4096), c4 varchar(4096), c5 varchar(4096),  primary key(c1)) row_format = redundant, compression = 'none'
  partition by range(c1) (
    partition p0 values less than (1), 
    partition p1 values less than (10000),
    partition p2 values less than MAXVALUE);
insert /*+ query_timeout(100000000000) parallel(16) enable_parallel_dml */ into test_with_migrate 
  select seq_pk_small.nextval, random(10), randstr(4096, random(10)), randstr(4096, random(10)), randstr(4096, random(10)) from table(generator(2000));
insert /*+ query_timeout(100000000000) parallel(16) enable_parallel_dml */ into test_with_migrate 
  select seq_pk_large.nextval, random(10), randstr(4096, random(10)), randstr(4096, random(10)), randstr(4096, random(10)) from table(generator(2000));

connection sys_conn;

# trigger minor freeze
eval alter system minor freeze tenant = '$tenant_name';

# check z1_obs0 minor freeze done
connection z1_obs0;
source include/compaction/tenant_minor_freeze_and_wait_done.inc;

# connect to actual z3 observer to check minor freeze done
connection cur_conn;
source include/compaction/tenant_minor_freeze_and_wait_done.inc;
sleep 10;

connection z1_obs0;

--echo ===============================================================
--echo ================== migrate z3 forward =========================
--echo ===============================================================


ob1.mysql alter system set errsim_migration_src_server_addr = "$cur";

sleep 5;

# enable debug sync
ob1.mysql alter system set_tp tp_name = EN_BLOCK_SPLIT_BEFORE_SSTABLES_SPLIT, error_code = 4192, frequency = 1;
ob1.mysql set ob_global_debug_sync = 'BEFORE_MIGRATION_CREATE_TABLE_STORE wait_for signal3 execute 10000';
sleep 2;

connection sys_conn;

# execute partition split
connection z1_obs0_1;
send alter table test_with_migrate reorganize partition p1 into ( partition p1_0 values less than (5000), partition p1_1 values less than (10000));
connection z1_obs0;

# wait logical split finish
ob1.check_until_timeout select count(*) > 0 from oceanbase.__all_rootservice_event_history where module like "%ddl scheduler%" and event like "%switch_state%" and extra_info like "%WAIT_COMPACTION_END%", 1, 600;

let $errsim_tablet_id = deploy_get_value(ob1.select select tablet_id from __all_virtual_part where part_name="p1_0" and tablet_id < 300000, tablet_id, 1);
ob1.mysql alter system set errsim_test_tablet_id = $errsim_tablet_id;

connection z1_obs0_2;
# write some data then do minor 
insert /*+ query_timeout(100000000000) parallel(16) enable_parallel_dml */ into test_with_migrate 
  select seq_pk_small.nextval, random(10), randstr(4096, random(10)), randstr(4096, random(10)), randstr(4096, random(10)) from table(generator(10));
insert /*+ query_timeout(100000000000) parallel(16) enable_parallel_dml */ into test_with_migrate 
  select seq_pk_large.nextval, random(10), randstr(4096, random(10)), randstr(4096, random(10)), randstr(4096, random(10)) from table(generator(10));
  
connection sys_conn;
eval alter system minor freeze tenant = '$tenant_name';

connection z1_obs0;
source include/compaction/tenant_minor_freeze_and_wait_done.inc;

ob1.check_until_timeout select count(*) > 0 from oceanbase.__all_virtual_table_mgr where tablet_id = $errsim_tablet_id and table_type in (11, 12) and svr_ip = '$cur_ip' and svr_port = '$cur_port', 1, 500;

# trigger migration
ob1.mysql alter system migrate unit $unit_id destination "$dst";

ob1.check_until_timeout select count(*) > 0 from oceanbase.__all_server_event_history where module = 'storage_ha' and event = 'ls_ha_start' and value1 = '$tenant_id' and value2 = '1001' and extra_info = 'MIGRATE_LS_OP', 1, 600;
ob1.check_until_timeout select count(*) > 0 from oceanbase.__all_server_event_history where module = 'storage_ha' and event = 'physical_copy_task' and value1 = '$tenant_id' and value2 = '1001' and value3 = $errsim_tablet_id, 1, 600;

ob1.mysql alter system set_tp tp_name = EN_BLOCK_SPLIT_BEFORE_SSTABLES_SPLIT, error_code = 0, frequency = 1;
sleep 2;

# split keeps hung for migration dest which waits for migration copy sstable.
connection sys_conn;
sleep 30;
eval select * from oceanbase.__all_server_event_history where module = 'ddl' and event = 'replica_split_resp' and svr_port = '$dst_port' order by gmt_create desc limit 2;

# let migration copies sstable finished.
ob1.mysql set ob_global_debug_sync = 'BEFORE_MIGRATION_CREATE_TABLE_STORE clear';
ob1.mysql set ob_global_debug_sync = 'now broadcast signal3';

ob1.check_until_timeout select count(*) as cnt from oceanbase.__all_rootservice_job where unit_id = $unit_id AND job_type = "MIGRATE_UNIT" and job_status = "SUCCESS", 1, 600;
ob1.check_until_timeout select count(1) from oceanbase.__all_virtual_ls_meta_table where tenant_id = $tenant_id and ls_id = 1001 and svr_ip = '$dst_ip' and svr_port = '$dst_port' and replica_status = 'NORMAL', 1, 100;

# check ddl finished
connection z1_obs0_1;
reap;
connection z1_obs0;
ob1.check_until_timeout select count(1) as cnt from oceanbase.__all_virtual_ddl_task_status, 0, 600;

# trigger major freeze, check replica checksum.
ob1.mysql alter system major freeze tenant = '$tenant_name';
sleep 10;
ob1.check_until_timeout select (frozen_scn - last_scn) as result from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id=$tenant_id, 0, 600;
connection sys_conn;
select /*+ query_timeout(1000000000) */ * from oceanbase.CDB_OB_TABLET_CHECKSUM_ERROR_INFO;
