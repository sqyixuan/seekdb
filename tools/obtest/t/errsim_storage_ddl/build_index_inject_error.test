# owner: zhenjiang.xzj
# owner group: storage
# description: simulate build index fail

--disable_query_log
ob1=OBI(cluster=1:1:1,proxy_num=0);
ob1.reboot;
sleep 3;

let $cpu = 1;
let $memory = 1073741824;

ob_connect(conn_sys, ob1.z1.obs0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);
set @@session.ob_query_timeout = 1000000000;
# mysql tenant
eval CREATE RESOURCE UNIT unit_1 MAX_CPU=$cpu, MEMORY_SIZE=$memory;
eval CREATE RESOURCE POOL pool_1 UNIT = 'unit_1', UNIT_NUM = 1, zone_list = ('z1', 'z2', 'z3');;
eval CREATE TENANT mysql RESOURCE_POOL_LIST = ('pool_1'), primary_zone='z1;z2;z3' set ob_tcp_invited_nodes='%';

ob_connect(conn_mysql, ob1.z1.obs0, root@mysql, , test, , USE_MYSQL_CONNECTOR);
connection conn_mysql;

create table t1(c1 int, c2 int);
insert into t1 values (1, 1);

ob1.mysql alter system set_tp tp_no = 510, error_code = 6, frequency = 1;
ob1.mysql alter system set_tp tp_no = 511, error_code = 5840, frequency = 1;

sleep 2;
--error 5840
create index i1 on t1(c1) local;
sleep 2;

ob1.mysql alter system set_tp tp_no = 510, error_code = 6, frequency = 0;
ob1.mysql alter system set_tp tp_no = 511, error_code = 5840, frequency = 0;

sleep 2;
create index i1 on t1(c1) local;
sleep 2;
