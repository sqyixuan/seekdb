# owner: liujixiong.ljx
# owner group: storage
# description: to test concurrent behavior of ddl and drop tenant.
#
--disable_query_log
ob1=OBI(cluster=1:1:1,proxy_num=0);
ob1.reboot;
sleep 3;

let $cpu = 1;
let $memory = 2073741824;
ob_connect(conn_sys, ob1.z1.obs0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);
set @@session.ob_query_timeout = 1000000000;
ob1.mysql alter system set debug_sync_timeout = '100000s';
eval CREATE RESOURCE UNIT unit_1 MAX_CPU=$cpu, MEMORY_SIZE=$memory;
eval CREATE RESOURCE POOL pool_1 UNIT = 'unit_1', UNIT_NUM = 1, zone_list = ('z1', 'z2', 'z3');;

--echo ==================== test behavior of offline ddl and drop tenant start ====================
--echo 1. create tenant.
connection conn_sys;
eval CREATE TENANT mysql RESOURCE_POOL_LIST = ('pool_1'), primary_zone='z1;z2;z3' set ob_tcp_invited_nodes='%';

--echo 2. do offline ddl.
ob_connect(conn1, ob1.z1.obs0, root@mysql, , test, , USE_MYSQL_CONNECTOR);
create table t1(c1 int, c2 int);
insert into t1 values(1, 1);
ob1.mysql set ob_global_debug_sync = 'COLUMN_REDEFINITION_REPLICA_BUILD wait_for signal execute 10000';

sleep 2;
send alter table t1 drop column c2;
sleep 10;

--echo 3. drop tenant and clear debug point.
connection conn_sys;
drop tenant mysql force;

sleep 2;
ob1.mysql set ob_global_debug_sync = 'COLUMN_REDEFINITION_REPLICA_BUILD clear';
sleep 2;
ob1.mysql set ob_global_debug_sync = 'now signal signal';
sleep 2;

--echo 4. show result.
connection conn1;
--error 5685
reap;

connection conn_sys;
eval select count(*) from oceanbase.__all_virtual_ddl_task_status;
--echo ==================== test behavior of offline ddl and drop tenant end ====================


--echo ==================== test behavior of create index and drop tenant start ====================
--echo 1. create tenant.
connection conn_sys;
eval CREATE TENANT mysql RESOURCE_POOL_LIST = ('pool_1'), primary_zone='z1;z2;z3' set ob_tcp_invited_nodes='%';

--echo 2. create index.
ob_connect(conn1, ob1.z1.obs0, root@mysql, , test, , USE_MYSQL_CONNECTOR);
create table t1(c1 int, c2 int);
insert into t1 values(1, 1);
ob1.mysql set ob_global_debug_sync = 'CREATE_INDEX_REPLICA_BUILD wait_for signal execute 10000';

sleep 2;
send create index idx on t1(c1);
sleep 10;

--echo 3. drop tenant and clear debug point.
connection conn_sys;
drop tenant mysql force;

sleep 2;
ob1.mysql set ob_global_debug_sync = 'CREATE_INDEX_REPLICA_BUILD clear';
sleep 2;
ob1.mysql set ob_global_debug_sync = 'now signal signal';
sleep 2;

--echo 4. show result.
connection conn1;
--error 5685
reap;

connection conn_sys;
eval select count(*) from oceanbase.__all_virtual_ddl_task_status;
--echo ==================== test behavior of create index and drop tenant end ====================


--echo ==================== test behavior of cst task and drop tenant start ====================
--echo 1. create tenant.
connection conn_sys;
eval CREATE TENANT mysql RESOURCE_POOL_LIST = ('pool_1'), primary_zone='z1;z2;z3' set ob_tcp_invited_nodes='%';

--echo 2. add constraint.
ob_connect(conn1, ob1.z1.obs0, root@mysql, , test, , USE_MYSQL_CONNECTOR);
create table t1(c1 int, c2 int);
insert into t1 values(1, 1);
ob1.mysql set ob_global_debug_sync = 'CONSTRAINT_VALIDATE wait_for signal execute 10000';

sleep 2;
send alter table t1 add constraint check_c1_equal_c2 check(c1=c2);
sleep 10;

--echo 3. drop tenant and clear debug point.
connection conn_sys;
drop tenant mysql force;

sleep 2;
ob1.mysql set ob_global_debug_sync = 'CONSTRAINT_VALIDATE clear';
sleep 2;
ob1.mysql set ob_global_debug_sync = 'now signal signal';
sleep 2;

--echo 4. show result.
connection conn1;
--error 5685
reap;

--echo ==================== test behavior of cst task and drop tenant end ====================
