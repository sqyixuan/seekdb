# owner: lihongqin.lhq
# owner group: storage
# description: this case is use for simulate checksum error on index building.

--disable_query_log
ob1=OBI(cluster=1:1:1,proxy_num=0,init_unit_cpu=2);
ob1.reboot;

ob1.create_client;

ob1.mysql alter system set merger_check_interval='10s';
ob1.mysql alter system set enable_rebalance = 'false';
ob1.mysql alter system set resource_hard_limit=500;
ob1.mysql alter system set schema_drop_gc_delay_time='1s';
ob1.create_client tenant=obtest,user=root,passwd=,database=test;

create table t1(c1 char(10), c2 varchar(10), c3 int) partition by hash(c3);
insert into t1 values ('abc', 'abcd 123', 1);

create index i1 on t1(c1) local;
create index i2 on t1(c1) global;
create index i3 on t1(c1, c2(5)) local;
create index i4 on t1(c1, c2(5)) global;

drop index i1 on t1;
drop index i2 on t1;
drop index i3 on t1;
drop index i4 on t1;

# error code 4109 or whatever, don't care
ob1.z1.obs0.mysql alter system set_tp tp_no = 506, error_code = 4109, frequency = 1;
sleep 10;

--error 4103
create index i1 on t1(c1) local;
--error 4103
create index i1 on t1(c1) global;
--error 4103
create index i1 on t1(c1, c2(5)) local;
--error 4103
create index i1 on t1(c1, c2(5)) global;

drop table t1;
