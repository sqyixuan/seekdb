##############################
# owner: debin.jdb
# group: CLOG
#
# 测试功能点：
# 1. 切主触发只读副本切换parent；
# 2. kill parent触发只读副本切换parent;
# 3. 同region的F优先替换同region的R副本;
#
# 未测到的功能点：
# 1. leader下游列表满（5个）时，新region的只读副本将强制挂在leader下；
#
# 当前级联策略已知bad case：
# 1. 假设region-HZ中有F、R两个副本，F宕机重启后重新加入leader的下游列表时可能时间戳还未sync故无法替换R
#    这样F、R均作为leader的child(如果leader下游列表有足够空位)，且R可能没有机会被踢掉.
#    如果leader下游列表无法同时放下F、R，那么F在unsync时无法替换R，只能继续追日志，达到sync状态时直接替换R.

# 部署：
# 5台observer，每台server一个zone：z1~z5
# 副本分布 locality = F@z1, R@z2, F@z3, R@z4, F@z5

ob1=OBI(cluster=1:1:1:1:1,proxy_num=0,init_unit_cpu=0,locality=HZ:SZ:SH:SH:HZ);

ob1.reboot;

ob1.mysql alter system set max_stale_time_for_weak_consistency = '1h';
ob1.mysql alter system set enable_monotonic_weak_read = 1;
ob1.mysql alter system set resource_hard_limit=900;
ob1.mysql alter system set resource_soft_limit=800;
ob1.mysql alter system set debug_sync_timeout = '1000s';
ob1.mysql alter system set enable_auto_leader_switch = 'false';
ob1.mysql alter system set enable_rebalance = 'false';
ob1.mysql alter system set enable_rereplication = 'false';
ob1.mysql alter system set balancer_idle_time = '10s';
ob1.mysql alter system set server_data_copy_out_concurrency = 20;
ob1.mysql alter system set server_data_copy_in_concurrency = 20;
# 日志限流
# ob1.mysql alter system set syslog_io_bandwidth_limit = '1024MB';

# waiting for the servers to start service
sleep 10;
ob1.check_until_timeout select count(*) c from oceanbase.__all_server where start_service_time <= 0 or status = "inactive", 0, 120;

ob_connect(sys_conn, ob1.z1.obs0, root@sys, , oceanbase, , USE_MYSQL_CONNECTOR);
connection sys_conn;
--disable_query_log

select zone,count(*) from __all_zone where name='status' and info = 'ACTIVE' group by zone order by zone;
select zone,count(*) from __all_server group by zone order by zone;
alter system set max_stale_time_for_weak_consistency = '1h';
alter system set balancer_idle_time = '10s';
alter system set server_data_copy_out_concurrency = 30;
alter system set server_data_copy_in_concurrency = 30;
alter system set data_copy_concurrency = 30;

# 给系统租户在其他所有Zone添加只读副本
select B.zone, B.replica_type from oceanbase.__all_virtual_table A, oceanbase.__all_root_table B where A.tenant_id=1 and A.table_name='__all_sys_variable' and A.table_id=B.table_id and B.partition_id=0 order by B.zone, B.replica_type;
let $cpu = 2;
let $min_cpu = 1;
let $memory = 2073741824;
let $min_memory = 1073741824;
let $disk = 536870912;
let $iops = 100000;
let $session = 64;

eval CREATE RESOURCE UNIT sys_unit2 MAX_CPU $cpu, MAX_MEMORY $memory, MAX_IOPS $iops, MAX_DISK_SIZE $disk, MAX_SESSION_NUM $session, MIN_CPU=$min_cpu, MIN_MEMORY=$min_memory, MIN_IOPS=128;
CREATE RESOURCE POOL sys_pool2 UNIT = 'sys_unit2', UNIT_NUM = 1, ZONE_LIST = ('z2', 'z4');
alter tenant sys locality = 'F@z1, R@z2, F@z3, R@z4, F@z5';
# ob1.mysql_p select * from oceanbase.__all_rootservice_event_history where module = 'balancer';
select primary_zone, zone_list, locality, replica_num, previous_locality from oceanbase.__all_tenant where tenant_id = 1;
# 检查sys租户的locality变更是否完成
ob1.check_until_timeout select count(*) c from oceanbase.__all_tenant where tenant_id = 1 and previous_locality != '', 1, 360;
select B.zone, B.replica_type from oceanbase.__all_virtual_table A, oceanbase.__all_root_table B where A.tenant_id=1 and A.table_name='__all_sys_variable' and A.table_id=B.table_id and B.partition_id=0 order by B.zone, B.replica_type;
################################################################
# 租户环境准备
# create tenant tt1
eval CREATE RESOURCE UNIT my_unit MAX_CPU $cpu, MAX_MEMORY $memory, MAX_IOPS $iops, MAX_DISK_SIZE $disk, MAX_SESSION_NUM $session, MIN_CPU=$min_cpu, MIN_MEMORY=$min_memory, MIN_IOPS=128;
CREATE RESOURCE POOL my_pool UNIT = 'my_unit', UNIT_NUM = 1, ZONE_LIST = ('z1', 'z2','z3', 'z4', 'z5');
# primary zone所在region必须要有另一个非只读zone，否则bootstrap失败
CREATE TENANT tt1 RESOURCE_POOL_LIST = ('my_pool'), locality='F@z1, R@z2, F@z3, R@z4, F@z5', primary_zone='z1,z5;' set ob_tcp_invited_nodes='%';

sleep 20;

ob_connect(tt1_conn, ob1.z5.obs0, root@tt1, ,test, , USE_MYSQL_CONNECTOR);
connection tt1_conn;

create table t1(c1 int primary key);
insert into t1 values (1), (2);
select * from t1;

connection sys_conn;
# change zone type
# 2.2.0版本开始不再有只读zone，这种操作已经被禁止
#alter system modify zone 'z2' zone_type 'readonly';
#alter system modify zone 'z4' zone_type 'readonly';

# 验证副本类型和分布
select B.zone, B.replica_type from oceanbase.__all_virtual_table A, oceanbase.__all_virtual_meta_table B where A.table_name='t1' and A.table_id=B.table_id order by B.zone, B.replica_type;
# 确定所有follower都分配到了有效的parent
ob1.check_until_timeout select count(*) c from oceanbase.__all_virtual_clog_stat where role != 'LEADER' and parent like '%0.0.0.0%', 0, 30;

let $table_id = deploy_get_value(ob1.select select table_id from __all_virtual_table where table_name='t1', table_id, 1);
let $z3_obs0_ip = deploy_get_value(ob1.z3.obs0.ip);
let $z3_obs0_port = deploy_get_value(ob1.z3.obs0.port);
let $z4_obs0_ip = deploy_get_value(ob1.z4.obs0.ip);
let $z4_obs0_port = deploy_get_value(ob1.z4.obs0.port);
let $z5_obs0_ip = deploy_get_value(ob1.z5.obs0.ip);
let $z5_obs0_port = deploy_get_value(ob1.z5.obs0.port);

################################################################
# CASE 1: 执行切主，检查只读zone是否都有正常的parent

# switch leader to z3, z4 will lose parent
ob1.mysql alter system switch replica leader partition_id = '0%1@$table_id' server = '$z5_obs0_ip:$z5_obs0_port';
# wait for switching leader finish
sleep 10;
# check all readonly replica has got a valid parent
ob1.check_until_timeout select count(*) c from oceanbase.__all_virtual_clog_stat where role != 'LEADER' and parent like '%0.0.0.0%', 0, 30;
# check z4's parent is z3
# ob1.check_until_timeout select count(*) c from oceanbase.__all_virtual_clog_stat where table_id='$table_id' and svr_ip='$z4_obs0_ip' and parent like '%$z3_obs0_ip:$z3_obs0_port%', 1, 120;

let $z1_obs0_ip = deploy_get_value(ob1.z1.obs0.ip);
let $z1_obs0_port = deploy_get_value(ob1.z1.obs0.port);
# switch leader to z1, z4 will lose parent again
ob1.mysql alter system switch replica leader partition_id = '0%1@$table_id' server = '$z1_obs0_ip:$z1_obs0_port';
# wait for switching leader finish
sleep 10;
# check all readonly replica has got a valid parent
ob1.check_until_timeout select count(*) c from oceanbase.__all_virtual_clog_stat where role != 'LEADER' and parent like '%0.0.0.0%', 0, 30;
# check z4's parent is z3
# ob1.check_until_timeout select count(*) c from oceanbase.__all_virtual_clog_stat where table_id='$table_id' and svr_ip='$z4_obs0_ip' and parent like '%$z3_obs0_ip:$z3_obs0_port%', 1, 120;

# 验证插入数据并读取
connection tt1_conn;
insert into t1 values (3), (4);
select * from t1;

sleep 7;
ob1.check_until_timeout select count(*) c from oceanbase.__all_virtual_clog_stat where table_id = '$table_id' and is_in_sync=0, 0, 30;

################################################################
# CASE 2: 验证级联杀parent逻辑：如果没有同region可选的F，只读副本R将挂在leader下面，kill z3后z4将挂到leader下
connection sys_conn;

ob1.z3.obs0.stop;
sleep 20;
# z4的parent将变为leader-z1
ob1.check_until_timeout select count(*) c from oceanbase.__all_virtual_clog_stat where table_id='$table_id' and svr_ip='$z4_obs0_ip' and svr_port = '$z4_obs0_port' and parent like '%$z1_obs0_ip:$z1_obs0_port%', 1, 5;
# 验证所有人都有parent
ob1.check_until_timeout select count(*) c from oceanbase.__all_virtual_clog_stat where svr_ip != '$z3_obs0_ip' and role != 'LEADER' and parent like '%0.0.0.0%', 0, 30;

# 验证插入数据并读取
connection tt1_conn;
insert into t1 values (5), (6);
select * from t1;

sleep 7;
ob1.check_until_timeout select count(*) c from oceanbase.__all_virtual_clog_stat where table_id = '$table_id' and is_in_sync=0, 0, 30;

################################################################
# CASE 3: 验证级联下游列表的替换策略：同region的F优先替换同region的R副本，再次启动z3，其将再次成为z4的parent  (leader的children_list将发生替换操作，即全功能副本z3将把只读副本z4踢掉，并成为其parent)
connection sys_conn;

ob1.z3.obs0.start;
ob1.check_until_timeout select count(*) c from oceanbase.__all_server where svr_ip = '$z3_obs0_ip' and svr_port = '$z3_obs0_port' and status = 'active' and start_service_time > 0, 1, 60;

sleep 15;
# 验证所有人都有parent
ob1.check_until_timeout select count(*) c from oceanbase.__all_virtual_clog_stat where svr_ip != '$z3_obs0_ip' and role != 'LEADER' and parent like '%0.0.0.0%', 0, 60;
# z4的parent将切回z3
# 目前做了成员列表、下游列表拆分之后暂时不会替换
# ob1.check_until_timeout select count(*) c from oceanbase.__all_virtual_clog_stat where table_id='$table_id' and svr_ip='$z4_obs0_ip' and svr_port = '$z4_obs0_port' and parent like '%$z3_obs0_ip:$z3_obs0_port%', 1, 120;

# 验证插入数据并读取
connection tt1_conn;
insert into t1 values (7), (8);
select * from t1;

sleep 7;
ob1.check_until_timeout select count(*) c from oceanbase.__all_virtual_clog_stat where table_id = '$table_id' and is_in_sync=0, 0, 30;

