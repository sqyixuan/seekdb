##
# owner: xianlin.lh
# owner group: transaction
# description:
# 测试在执行stop server后，目标server不允许作为Leader
##

ob1=OBI(cluster=1:1:1, proxy_num=0, init_unit_cpu=0);
ob1.reboot;
sleep 5;

let $ip3 = deploy_get_value(ob1.z3.obs0.ip);
let $port3 = deploy_get_value(ob1.z3.obs0.port);

--disable_query_log
ob1.mysql alter system stop server '$ip3:$port3';
--enable_query_log

ob1.mysql alter system set enable_auto_leader_switch = false;

# for heartbeat
sleep 5;

--disable_query_log
ob1.mysql alter system switch replica leader partition_id = '0%1@1099511627777' server='$ip3:$port3';
--enable_query_log

ob1.z2.obs0.force_stop;

sleep 15;

ob1.z1.obs0.check_leader sys:oceanbase:__all_core_table;
