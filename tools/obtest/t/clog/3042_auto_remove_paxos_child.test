##############################
# owner: debin.jdb
# owner group: clog
#
# 测试功能点：
# 1. 只读副本转换为F副本之后，能够从leader的children_list中删除.
#
# fix 

--disable_query_log
ob1=OBI(cluster=1:1:1:1:1, init_unit_cpu=0, proxy_num=0, ct_num=0, locality=hz:hz:hz:sh:sz);

ob1.reboot;

ob1.mysql alter system set resource_hard_limit=900;
ob1.mysql alter system set resource_soft_limit=800;
ob1.mysql alter system set debug_sync_timeout = '1000s';
ob1.mysql alter system set enable_auto_leader_switch = 'false';
ob1.mysql alter system set enable_rebalance = 'false';
ob1.mysql alter system set enable_rereplication = 'true';
ob1.mysql alter system set balancer_idle_time = '10s';
ob1.mysql alter system set server_data_copy_out_concurrency = 20;
ob1.mysql alter system set server_data_copy_in_concurrency = 20;
ob1.mysql alter system set partition_table_check_interval = "1m";
ob1.mysql alter system set server_permanent_offline_time = "20s";

# 创建新租户
let $cpu = 1;
let $memory = 1073741824;
let $min_memory = 1073741824;
let $disk = 536870912;
let $iops = 100000;
let $session = 64;
ob1.mysql CREATE RESOURCE UNIT unit_1 MAX_CPU $cpu, MAX_MEMORY $memory, MAX_IOPS $iops, MAX_DISK_SIZE $disk, MAX_SESSION_NUM $session, MIN_CPU=1, MIN_MEMORY=$min_memory, MIN_IOPS=128;
ob1.mysql CREATE RESOURCE POOL pool_1 UNIT = 'unit_1', UNIT_NUM = 1, ZONE_LIST = ('z1','z2','z3','z4','z5');

let $z1_obs0_ip = deploy_get_value(ob1.z1.obs0.ip);
let $z1_obs0_mysql_port = deploy_get_value(ob1.z1.obs0.mysql_port);
connect (conn_sys_z1,$z1_obs0_ip,admin@sys,admin,oceanbase,$z1_obs0_mysql_port);
let $z3_obs0_ip = deploy_get_value(ob1.z3.obs0.ip);
let $z3_obs0_mysql_port = deploy_get_value(ob1.z3.obs0.mysql_port);
connect (conn_sys_z3,$z3_obs0_ip,admin@sys,admin,oceanbase,$z3_obs0_mysql_port);

## 初始化租户
ob1.mysql CREATE TENANT tenant_1 RESOURCE_POOL_LIST = ('pool_1'), primary_zone = 'z3;z4;z1,z2;z5',locality='F{1}@z1,F{1}@z2,F{1}@z3,R{1}@z4,R{1}@z5' set ob_tcp_invited_nodes='%';
let $tenant_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name = "tenant_1", tenant_id, 1);
connect (conn_tenant_1_z1,$z1_obs0_ip,root@tenant_1,,test,$z1_obs0_mysql_port);
connection conn_tenant_1_z1;
use test;
create table t1(c1 int, c2 int) partition by hash(c1) partitions 2;
let $t1_id = deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where tenant_id = "$tenant_id" and table_name = "t1", table_id, 1);
insert into t1(c1, c2) values(1,1);
insert into t1(c1, c2) values(2,2);
--disable_result_log
select * from test.t1 where c1 = 1;
select * from test.t1 where c1 = 2;
--enable_result_log
connection conn_sys_z1;
eval select count(*) from oceanbase.__all_virtual_meta_table where table_id = "$t1_id" and partition_id = 0 and replica_type = 16;
let $r_z5_addr = deploy_get_value(ob1.select select concat(svr_ip, ":", svr_port) as addr from oceanbase.__all_virtual_meta_table where tenant_id = "$tenant_id" and table_id = "$t1_id" and partition_id = 0 and zone = "z5" and replica_type = 16, addr, 1);
## z5执行R->F
ob1.mysql alter tenant tenant_1 set locality = 'F{1}@z1,F{1}@z2,F{1}@z3,R{1}@z4,F{1}@z5';
let $last_job_id = deploy_get_value(ob1.select select max(job_id) as job_id from oceanbase.__all_rootservice_job where job_type = "ALTER_TENANT_LOCALITY" group by job_type, job_id, 1);
ob1.check_until_timeout select count(*) as c from oceanbase.__all_rootservice_job where job_id = "$last_job_id" and job_type = "ALTER_TENANT_LOCALITY" and job_status = "SUCCESS", 1, 180;
## 检查z5副本不在任何副本的下游列表中
ob1.check_until_timeout select count(*) as c from oceanbase.__all_virtual_clog_stat where table_id = "$t1_id" and partition_idx = 0 and locate("$r_z5_addr", children_list) != 0, 0, 60;
