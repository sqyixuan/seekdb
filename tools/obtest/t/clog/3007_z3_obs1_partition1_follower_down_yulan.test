##
# owner:yulan.way
# owner group:transaction
# description:
# 测试功能点：多机单partition，备partition宕机
# 用例描述：备机向主机请求落后的日志
##
ob1=OBI(cluster=2:2:2,proxy_num=0,init_unit_cpu=11,init_unit_num=1);
ob1.reboot;
sleep 5;

#数据准备
let $ip=deploy_get_value(ob1.z1.obs1.ip);
let $port=deploy_get_value(ob1.z1.obs1.mysql_port);
connect (conn1,$ip,admin@obtest,admin,oceanbase,$port);
connection conn1;

create database obtest;
use obtest;
create table t1(pk int primary key, c1 int, c2 varchar(20));

ob1.z1.obs1.switch_partition obtest:obtest:t1;

sleep 3;

--disable_query_log
let $cnt=50;
while($cnt>0)
{
	eval insert into t1 values($cnt,$cnt,'c$cnt');
	dec $cnt;
}

let $follower_1=deploy_get_value(ob1.get_follower obtest:obtest:t1,1);

--enable_query_log
select * from t1;

##备partition宕机
$follower_1.force_stop;

let $cnt=3000;
while($cnt>0)
{
	eval replace into t1 values($cnt,$cnt,'c$cnt');
	dec $cnt;
}

##备partition重启
$follower_1.nstart;

sleep 60;

##切为主(可能由于日志不同步而切换失败)
$follower_1.switch_partition obtest:obtest:t1;

sleep 3;

##验证数据正确性
--enable_query_log
select * from t1;


















