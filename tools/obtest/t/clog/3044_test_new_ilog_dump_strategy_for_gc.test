# owner: runlin.zjf
# owner group: clog
# description: 验证缩短ilog memstore dump周期后，是否能够尽快的完成物理资源的释放
## 
ob1=OBI(cluster=1:1:1,proxy_num=0,init_unit_cpu=0);
 ob1.reboot;
sleep 2;

ob1.mysql alter system set resource_soft_limit = 100;

ob1.mysql create resource unit ut1 max_memory '15g', max_cpu 10, max_iops 20000, max_disk_size '100g', max_session_num 100;
ob1.mysql create resource pool rp1 unit = 'ut1', unit_num = 1, zone_list = ('z1','z2','z3');
ob1.mysql create tenant tt1 replica_num 3, primary_zone 'z1', resource_pool_list('rp1') set ob_tcp_invited_nodes='%';

let $src_ip = deploy_get_value(ob1.z1.obs0.ip);
let $src_mysql_port= deploy_get_value(ob1.z1.obs0.mysql_port);

connect(rl1_conn, $src_ip, root@tt1,, test, $src_mysql_port);
connect(rl2_conn, $src_ip, root@sys,, oceanbase, $src_mysql_port);

connection rl1_conn;
create table t2(k int primary key, v int);
let $table_id = deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where table_name='t2', table_id, 1);

# gc drop table
drop table t2;
PURGE RECYCLEBIN;

connection rl2_conn;
ob1.check_until_timeout select count(*) from __all_virtual_clog_stat where table_id=$table_id, 0, 2000;
