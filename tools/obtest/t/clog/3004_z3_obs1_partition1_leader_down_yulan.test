##
# owner:yulan.way
# owner group:transaction
# description:
# 测试功能点：多机单partition，主partition宕机
# 用例描述：1. 主partition宕机 2. 选出新主后未写入新数据 3. 旧的主partition重启 4. 将其指定为新的主
##
ob1=OBI(cluster=1:1:1,proxy_num=0, init_unit_cpu=5);
ob1.reboot;
sleep 5;

ob_connect(conn_obtest, ob1.z1.obs0, root@obtest, , test, , USE_MYSQL_CONNECTOR);
create database obtest;

##数据准备
#create database obtest;
use obtest;
create table t1(pk int primary key, c1 int, c2 varchar(20));

--disable_query_log
let $cnt=50;
while($cnt>0)
{
	eval insert into t1 values($cnt,$cnt,'c$cnt');
	dec $cnt;
}

sleep 10;

ob1.z2.obs0.switch_partition obtest:obtest:t1;

sleep 2;

--enable_query_log
select * from t1;

##主partition宕机
ob1.z2.obs0.force_stop;

##选出新主后验证数据正确性
sleep 100;
--enable_query_log
select * from t1;

##重启
ob1.z2.obs0.nstart;

sleep 100;

##切换为主
ob1.z2.obs0.switch_partition obtest:obtest:t1;

##验证
select * from t1;













