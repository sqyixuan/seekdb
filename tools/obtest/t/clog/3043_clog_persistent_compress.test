##
# owner:yaoying.yyy
# owner group:transaction
# description:
# 测试功能点：测试clog持久化压缩相关功能
# 用例描述：1. 压缩开关开启和关闭
#           2. 压缩算法切换
#           3. 宕机重启读clog日志是否正常(单机宕机，整个集群宕机)
#           4. 切主的场景
##
ob1=OBI(cluster=1:1:1,proxy_num=0, init_unit_cpu=5);
ob1.reboot;
sleep 5;

ob_connect(conn_obtest, ob1.z1.obs0, root@obtest, , test, , USE_MYSQL_CONNECTOR);
create database obtest;

##数据准备
#create database obtest;
use obtest;
create table t1(pk int primary key, c1 int, c2 varchar(20)) partition by hash(pk) partitions 5;

--disable_query_log
let $cnt=50;
while($cnt>10)
{
	eval insert into t1 values($cnt,$cnt,'c$cnt');
	dec $cnt;
}
set autocommit=0;
while($cnt>0)
{
	eval insert into t1 values($cnt,$cnt,'c$cnt');
	dec $cnt;
}
commit;
set autocommit=1;
select *, pk%50 from t1 where pk in (41, 92, 135, 178, 231, 280,321, 370, 411) order by pk;

##开启压缩开关
alter system set enable_clog_persistence_compress=true;
sleep 5;

--disable_query_log

let $cnt=50;
while($cnt>10)
{
	eval insert into t1 values($cnt+50,$cnt,'c$cnt');
	dec $cnt;
}
set autocommit=0;
while($cnt>0)
{
	eval insert into t1 values($cnt+50,$cnt,'c$cnt');
	dec $cnt;
}
commit;
set autocommit=1;

select *, pk%50 from t1 where pk in (41, 92, 135, 178, 231, 280,321, 370, 411) order by pk;

##关闭压缩开关
alter system set enable_clog_persistence_compress=false;
sleep 5;

--disable_query_log
let $cnt=50;
while($cnt>10)
{
	eval insert into t1 values($cnt+100,$cnt,'c$cnt');
	dec $cnt;
}
set autocommit=0;
while($cnt>0)
{
	eval insert into t1 values($cnt+100,$cnt,'c$cnt');
	dec $cnt;
}
commit;
set autocommit=1;


select *, pk%50 from t1 where pk in (41, 92, 135, 178, 231, 280,321, 370, 411) order by pk;

##开启压缩开关
alter system set enable_clog_persistence_compress=true;
alter system set clog_persistence_compress_func='zstd_1.3.8';
sleep 5;

--disable_query_log
let $cnt=50;
while($cnt>10)
{
	eval insert into t1 values($cnt+150,$cnt,'c$cnt');
	dec $cnt;
}
set autocommit=0;
while($cnt>0)
{
	eval insert into t1 values($cnt+150,$cnt,'c$cnt');
	dec $cnt;
}
commit;
set autocommit=1;
select *, pk%50 from t1 where pk in (41, 92, 135, 178, 231, 280,321, 370, 411) order by pk;

##切换压缩算法 lz4_1.0 -> 'none'
alter system set clog_persistence_compress_func='none';
sleep 5;

--disable_query_log
let $cnt=50;
while($cnt>10)
{
	eval insert into t1 values($cnt+200,$cnt,'c$cnt');
	dec $cnt;
}
set autocommit=0;
while($cnt>0)
{
	eval insert into t1 values($cnt+200,$cnt,'c$cnt');
	dec $cnt;
}
commit;
set autocommit=1;
select *, pk%50 from t1 where pk in (41, 92, 135, 178, 231, 280,321, 370, 411) order by pk;

##切换压缩算法 'none' ->'zstd_1.3.8'
alter system set clog_persistence_compress_func='zstd_1.3.8';
sleep 5;

--disable_query_log
let $cnt=50;
while($cnt>10)
{
	eval insert into t1 values($cnt+250,$cnt,'c$cnt');
	dec $cnt;
}
set autocommit=0;
while($cnt>0)
{
	eval insert into t1 values($cnt+250,$cnt,'c$cnt');
	dec $cnt;
}
commit;
set autocommit=1;

sleep 5;
ob1.z2.obs0.switch_partition obtest:obtest:t1;
sleep 2;
select *, pk%50 from t1 where pk in (41, 92, 135, 178, 231, 280,321, 370, 411) order by pk;

##切换压缩算法 'zstd_1.3.8' -> 'lz4_1.0'
alter system set clog_persistence_compress_func='lz4_1.0';
sleep 5;

--disable_query_log
let $cnt=50;
while($cnt>10)
{
	eval insert into t1 values($cnt+300,$cnt,'c$cnt');
	dec $cnt;
}
set autocommit=0;
while($cnt>0)
{
	eval insert into t1 values($cnt+300,$cnt,'c$cnt');
	dec $cnt;
}
commit;
set autocommit=1;


select *, pk%50 from t1 where pk in (41, 92, 135, 178, 231, 280,321, 370, 411) order by pk;

##主partition宕机
ob1.z2.obs0.force_stop;

sleep 5;

##重启
ob1.z2.obs0.nstart;
sleep 50;
ob1.check_until_timeout select count(*) from oceanbase.__all_server where zone = 'z2' and (start_service_time<=0 or status='INACTIVE'),0,1000;

--disable_query_log
let $cnt=50;
while($cnt>10)
{
	eval insert into t1 values($cnt+350,$cnt,'c$cnt');
	dec $cnt;
}
set autocommit=0;
while($cnt>0)
{
	eval insert into t1 values($cnt+350,$cnt,'c$cnt');
	dec $cnt;
}
commit;
set autocommit=1;
##验证
select *, pk%50 from t1 where pk in (41, 92, 135, 178, 231, 280,321, 370, 411) order by pk;

##整个集群宕机重启, 读取回放日志是否报错
ob1.force_stop;
sleep 10;
ob1.nstart;
sleep 30;
ob1.check_until_timeout select count(*) from oceanbase.__all_server where (start_service_time<=0 or status='INACTIVE'),0,1000;
ob1.check_until_timeout SELECT CAST(COUNT(*) AS SIGNED) as cnt FROM __all_virtual_clog_stat WHERE is_in_sync = 0 and is_offline=0,0,600;

ob_connect(conn_obtest, ob1.z1.obs0, root@obtest, , test, , USE_MYSQL_CONNECTOR);
use obtest;
sleep 2;
--disable_query_log
let $cnt=50;
while($cnt>10)
{
	eval insert into t1 values($cnt+400,$cnt,'c$cnt');
	dec $cnt;
}
set autocommit=0;
while($cnt>0)
{
	eval insert into t1 values($cnt+400,$cnt,'c$cnt');
	dec $cnt;
}
commit;
set autocommit=1;
select *, pk%50 from t1 where pk in (41, 92, 135, 178, 231, 280,321, 370, 411) order by pk;

### 查看是否有error日志
let $work_dir=deploy_get_value(ob1.z1.obs0.workdir);
ob1.z1.obs0.sh cd $work_dir/log; grep " ERROR " * |grep -v "init io benchmark fail";
let $work_dir=deploy_get_value(ob1.z2.obs0.workdir);
ob1.z2.obs0.sh cd $work_dir/log; grep " ERROR " * |grep -v "init io benchmark fail";
let $work_dir=deploy_get_value(ob1.z3.obs0.workdir);
ob1.z3.obs0.sh cd $work_dir/log; grep " ERROR " * |grep -v "init io benchmark fail";
