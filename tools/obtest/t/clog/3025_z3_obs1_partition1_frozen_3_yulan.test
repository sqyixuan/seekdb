##
# owner:yulan.way
# owner group:transaction
# description:
# 测试功能点：多机单partition，复杂场景，冻结日志
# 用例描述: 3)	连续多次冻结后重启
##
ob1=OBI(cluster=1:1:1, init_unit_cpu=5);
ob1.reboot;
sleep 5;

ob1.mysql alter system set enable_auto_leader_switch=false;

let $ip=deploy_get_value(ob1.z1.obs0.ip);
let $port=deploy_get_value(ob1.z1.obs0.mysql_port);
connect (conn1,$ip,root@obtest,,test,$port);

##数据准备
connection conn1
create database obtest;
use obtest;
create table t1(pk int primary key, c1 int, c2 varchar(20));

--disable_query_log
let $cnt=10;
while($cnt>0)
{
	eval insert into t1 values($cnt,$cnt,'c$cnt');
	dec $cnt;
}

let $leader=deploy_get_value(ob1.get_leader obtest:obtest:t1);
let $follower_1=deploy_get_value(ob1.get_follower obtest:obtest:t1,1);
follower_2=deploy_get_value(ob1.get_follower obtest:obtest:t1,2);

##写入数据
--disable_query_log
let $cnt=1000;
while($cnt>10)
{
	eval insert into t1 values($cnt,$cnt,'c$cnt');
	dec $cnt;
}

##发起合并
ob1.mysql alter system major freeze;
ob1.mysql alter system major freeze;
ob1.mysql alter system major freeze;

##集群重启
ob1.z1.obs0.restart;
ob1.z2.obs0.restart;
ob1.z3.obs0.restart;

sleep 120;
ob1.check_until_timeout select value from __all_zone where zone='' and name='last_merged_version', 4,3600;















































