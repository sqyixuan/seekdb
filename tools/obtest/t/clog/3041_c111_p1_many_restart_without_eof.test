##
# owner: xianlin.lh
# owner group: transaction
# description:
# 写入、重启、查询、写入、重启、查询...
##
#

ob1=OBI(cluster=1:1:1,proxy_num=0,init_unit_cpu=0);
ob1.reboot;
sleep 5;

ob1.mysql create resource pool xx1 unit = 'sys_unit_config', unit_num = 1, zone_list = ('z1', 'z2', 'z3');
ob1.mysql create tenant xx1 replica_num 3, primary_zone 'z1', resource_pool_list ('xx1') set ob_tcp_invited_nodes='%';
sleep 5;

let $ip = deploy_get_value(ob1.z2.obs0.ip);
let $port = deploy_get_value(ob1.z2.obs0.mysql_port);

connect(xx1_conn, $ip, root@xx1,, test, $port);
connection xx1_conn;

create table t1 (a int, b varchar(262144));

select count(*) from t1;
let $count1 = 400;

--disable_result_log
while ($count1 > 0)
{
  insert into t1 values(1, repeat('a', 262144));
  dec $count1;
}
--enable_result_log

connect(xx2_conn, $ip, root@xx1,, test, $port);
connection xx2_conn;

select count(*) from t1;
let $count2 = 500;

--disable_result_log
while ($count2 > 0)
{
  insert into t1 values(1, repeat('a', 262144));
  dec $count2;
}
--enable_result_log

connect(xx3_conn, $ip, root@xx1,, test, $port);
connection xx3_conn;

select count(*) from t1;
let $count3 = 600;

--disable_result_log
while ($count3 > 0)
{
  insert into t1 values(1, repeat('a', 262144));
  dec $count3;
}
--enable_result_log

ob1.z1.obs0.restart;

sleep 100;

connect(xx4_conn, $ip, root@xx1,, test, $port);
connection xx4_conn;

select count(*) from t1;
let $count4 = 700;

--disable_result_log
while ($count4 > 0)
{
  insert into t1 values(1, repeat('a', 262144));
  dec $count4;
}
--enable_result_log

ob1.z1.obs0.restart;

sleep 100;

connect(xx5_conn, $ip, root@xx1,, test, $port);
connection xx5_conn;

select count(*) from t1;
let $count5 = 800;

--disable_result_log
while ($count5 > 0)
{
  insert into t1 values(1, repeat('a', 262144));
  dec $count5;
}
--enable_result_log
