##
# owner:yulan.way
# owner group:transaction
# description:
# 测试功能点：多机单partition，切换
# 用例描述：反复切换
##
ob1=OBI(cluster=1:1:1,proxy_num=0, init_unit_cpu=2);
ob1.reboot;
sleep 5;

let $ip=deploy_get_value(ob1.z1.obs0.ip);
let $port=deploy_get_value(ob1.z1.obs0.mysql_port);
connect (conn_obtest,$ip,root@obtest,,oceanbase,$port);
connection conn_obtest;
create database obtest;

##数据准备
use obtest;
create table t1(pk int primary key, c1 int, c2 varchar(20));

--disable_query_log
let $cnt=50;
while($cnt>0)
{
	eval insert into t1 values($cnt,$cnt,'c$cnt');
	dec $cnt;
}

##指定observer切换
ob1.z1.obs0.switch_partition obtest:obtest:t1;
sleep 15;
--enable_query_log
select * from t1;

##切换
ob1.z2.obs0.switch_partition obtest:obtest:t1;
sleep 15;
select * from t1;
##更新数据
--disable_query_log
let $cnt=30;
while($cnt>0)
{
	eval update t1 set c2='c$cnt$cnt' where pk=$cnt;
	dec $cnt;
}

select * from t1;

##进行一次主备切换
ob1.z3.obs0.switch_partition obtest:obtest:t1;
sleep 15;
##更新数据
let $cnt=50;
while($cnt>30)
{
	eval delete from t1 where pk=$cnt;
	dec $cnt;
}

select * from t1;


#切换
ob1.z1.obs0.switch_partition obtest:obtest:t1;
sleep 5;
##更新数据
let $cnt=60;
while($cnt>50)
{
	eval insert into t1 values($cnt,$cnt,'c$cnt');
	dec $cnt;
}

select * from t1;








