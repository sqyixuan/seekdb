##
# owner:yulan.way
# owner group:transaction
# description:
# 测试功能点：多机单partition，主partition宕机
# 用例描述：1. 主partition宕机 2. 选出新主后写入新的数据 3. 旧的主partition重启 4. 将其指定为新的主
##
ob1=OBI(cluster=2:2:2,proxy_num=0,init_unit_cpu=11,init_unit_num=2);
ob1.reboot;

sleep 5;

let $ip=deploy_get_value(ob1.z1.obs0.ip);
let $port=deploy_get_value(ob1.z1.obs0.mysql_port);
connect (conn1,$ip,root@obtest,,test,$port);

set ob_trx_timeout=15000000;

##数据准备
connection conn1;
use test;
create table t1(pk int primary key, c1 int, c2 varchar(20));

--disable_query_log
let $cnt=50;
while($cnt>0)
{
	eval insert into t1 values($cnt,$cnt,'c$cnt');
	dec $cnt;
}

let $leader=deploy_get_value(ob1.get_leader obtest:test:t1);
let $follower=deploy_get_value(ob1.get_follower obtest:test:t1);

let $follower_ip=deploy_get_value($follower.ip);
let $follower_port=deploy_get_value($follower.mysql_port);
connect (conn,$follower_ip,admin@obtest,admin,test,$follower_port);
connection conn;

--enable_query_log
select * from t1;

##主partition宕机
$leader.force_stop;

##选出新主后验证数据正确性
sleep 15;
--enable_query_log
select * from t1;

##refresh location
--error 0,4012
replace into t1 values(50,50,'c50');

sleep 15;

##写入新的数据
--disable_query_log
let $cnt=30;
while($cnt>0)
{
	eval update t1 set c2='c$cnt$cnt' where pk=$cnt;
	dec $cnt;
}

let $cnt=50;
while($cnt>30)
{
	eval delete from t1 where pk=$cnt;
	dec $cnt;
}

let $cnt=60;
while($cnt>50)
{
	eval insert into t1 values($cnt,$cnt,'c$cnt');
	dec $cnt;
}

##重启
$leader.nstart;

sleep 15;

##切换为主
$leader.switch_partition obtest:test:t1;

sleep 5;

##验证
select * from t1;













