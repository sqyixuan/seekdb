##
# owner:yulan.way
# owner group:transaction
# description:
# 测试功能点：多机单partition，备partition宕机
# 用例描述：依次停掉两个备 
##
ob1=OBI(cluster=2:2:2,proxy_num=0,init_unit_cpu=11,init_unit_num=1);
ob1.reboot;
sleep 15;


##数据准备
let $ip=deploy_get_value(ob1.z1.obs1.ip);
let $port=deploy_get_value(ob1.z1.obs1.mysql_port);
connect (conn1,$ip,admin@obtest,admin,oceanbase,$port);
connection conn1;

create database obtest;
use obtest;
create table t1(pk int primary key, c1 int, c2 varchar(20));

--disable_query_log
let $cnt=50;
while($cnt>0)
{
	eval insert into t1 values($cnt,$cnt,'c$cnt');
	dec $cnt;
}

ob1.z1.obs1.switch_partition obtest:obtest:t1;

sleep 3;

--enable_query_log
select * from t1;

##备partition宕机
ob1.z2.obs1.force_stop;

--disable_query_log
let $cnt=30;
while($cnt>0)
{
	eval update t1 set c2='c$cnt$cnt' where pk=$cnt;
	dec $cnt;
}

let $cnt=50;
while($cnt>30)
{
	eval delete from t1 where pk=$cnt;
	dec $cnt;
}

let $cnt=60;
while($cnt>50)
{
	eval insert into t1 values($cnt,$cnt,'c$cnt');
	dec $cnt;
}

##验证数据正确性
--enable_query_log
select * from t1;

##第二个备partition宕机
ob1.z3.obs1.force_stop;

sleep 30;

--error 4012
insert into t1 values(100,100,'c100');

--error 4012
select * from t1;

##重启备
ob1.z2.obs1.nstart;
ob1.z3.obs1.nstart;

sleep 60;

select * from t1;

##切换为主
ob1.z2.obs1.switch_partition obtest:obtest:t1;

sleep 3;

--disable_query_log
let $cnt=30;
while($cnt>10)
{
	eval update t1 set c2='c$cnt$cnt$cnt' where pk=$cnt;
	dec $cnt;
}

let $cnt=60;
while($cnt>55)
{
	eval delete from t1 where pk=$cnt;
	dec $cnt;
}

let $cnt=70;
while($cnt>60)
{
	eval insert into t1 values($cnt,$cnt,'c$cnt');
	dec $cnt;
}

select * from t1;

##切换为主
##距离上一次切换时间间隔为10s，否则会切换失败，成员的log id未更新
sleep 10;
ob1.z3.obs1.switch_partition obtest:obtest:t1;
sleep 3;

--disable_query_log
let $cnt=20;
while($cnt>10)
{
	eval update t1 set c2='c$cnt$cnt$cnt$cnt' where pk=$cnt;
	dec $cnt;
}

let $cnt=70;
while($cnt>65)
{
	eval delete from t1 where pk=$cnt;
	dec $cnt;
}

let $cnt=80;
while($cnt>70)
{
	eval insert into t1 values($cnt,$cnt,'c$cnt');
	dec $cnt;
}

select * from t1;











