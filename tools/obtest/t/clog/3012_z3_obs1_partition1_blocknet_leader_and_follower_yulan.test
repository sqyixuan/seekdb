##
# owner:yulan.way
# owner group:transaction
# description:
# 测试功能点：多机单partition，网络出现分区
# 用例描述：阻塞主备之间的网络/阻塞备备之间的网络
##
ob1=OBI(cluster=2:2:2,proxy_num=0,init_unit_cpu=11,init_unit_num=1);
ob1.reboot;
sleep 15;

ob1.create_client tenant=obtest;
create database obtest;

let $ip=deploy_get_value(ob1.z1.obs1.ip);
let $port=deploy_get_value(ob1.z1.obs1.mysql_port);
let $cluster=deploy_get_value(ob1.app_name);
connect (conn1,$ip,admin@obtest,admin,obtest,$port);
connection conn1;

##数据准备
use obtest;
create table t1(pk int primary key, c1 int, c2 varchar(20));

--disable_query_log
let $cnt=50;
while($cnt>0)
{
	eval insert into t1 values($cnt,$cnt,'c$cnt');
	dec $cnt;
}

##阻塞主备之间的网络
let $leader=deploy_get_value(ob1.get_leader obtest:obtest:t1);
let $follower=deploy_get_value(ob1.get_follower obtest:obtest:t1);

$leader.block_net $follower;

--enable_query_log
select * from t1;

##更新数据
--disable_query_log
let $cnt=30;
while($cnt>0)
{
	eval update t1 set c2='c$cnt$cnt' where pk=$cnt;
	dec $cnt;
}

let $cnt=50;
while($cnt>30)
{
	eval delete from t1 where pk=$cnt;
	dec $cnt;
}

let $cnt=60;
while($cnt>50)
{
	eval insert into t1 values($cnt,$cnt,'c$cnt');
	dec $cnt;
}

select * from t1;

##恢复主备之间的网络
$leader.clean_net $follower;

select * from t1;

##阻塞备备之间的网络
let $follower_1 = deploy_get_value(ob1.get_follower obtest:obtest:t1,1);
let $follower_2 = deploy_get_value(ob1.get_follower obtest:obtest:t1,2);

$follower_1.block_net $follower_2;

let $cnt=70;
while($cnt>60)
{
	eval insert into t1 values($cnt,$cnt,'c$cnt');
	dec $cnt;
}
select * from t1;

##将一个备切换为主
sleep 10;
$follower_1.switch_partition obtest:obtest:t1;

sleep 10;

let $cnt=80;
while($cnt>70)
{
	eval insert into t1 values($cnt,$cnt,'c$cnt');
	dec $cnt;
}
select * from t1;

$follower_1.clean_net $follower_2;























