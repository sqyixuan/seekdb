##
# owner:yulan.way
# owner group:transaction
# description:
# 测试功能点：多机单partition，集群重启
# 用例描述: 所有server日志同步
##
ob1=OBI(cluster=1:1:1,proxy_num=0, init_unit_cpu=5);
ob1.reboot;
sleep 5;

ob_connect(conn1, ob1.z1.obs0, root@obtest, , oceanbase, , USE_MYSQL_CONNECTOR);
##数据准备
create database obtest;
use obtest;
create table t1(pk int primary key, c1 int, c2 varchar(20));

--disable_query_log
let $cnt=50;
while($cnt>0)
{
	eval insert into t1 values($cnt,$cnt,'c$cnt');
	dec $cnt;
}

ob1.z1.obs0.switch_partition obtest:obtest:t1;

--enable_query_log
select * from t1;

##集群重启
ob1.force_stop;
sleep 1;
ob1.nstart;

sleep 90;

ob_connect(conn1, ob1.z1.obs0, root@obtest, , obtest, , USE_MYSQL_CONNECTOR);
##验证数据正确性
--enable_query_log
select * from t1;

--disable_query_log
let $cnt=30;
while($cnt>0)
{
	    eval update t1 set c2='c$cnt$cnt' where pk=$cnt;
		    dec $cnt;
}

let $cnt=50;
while($cnt>30)
{
	    eval delete from t1 where pk=$cnt;
		    dec $cnt;
}

let $cnt=60;
while($cnt>50)
{
	    eval insert into t1 values($cnt,$cnt,'c$cnt');
		    dec $cnt;
}

select * from t1;


# 进行一次主备切换
let $follwer=deploy_get_value(ob1.get_follwer obtest:obtest:t1,1);
$follwer.switch_partition obtest:obtest:t1;

sleep 3;

select * from t1;








