ob1=OBI(cluster=1, proxy_num = 0);
ob2=OBI(cluster=1, proxy_num = 0, leaderob=ob1);

ob1.reboot;
ob2.reboot;

let $cpu = 1;
let $memory = 1073741824;
let $min_memory = 1073741824;
let $disk = 536870912;
let $iops = 100000;
let $session = 64;
let $case_index = 1;

ob_connect(conn2_1, ob2.z1.obs0, root@sys,,oceanbase,,USE_OB_CONNECTOR);
connection conn2_1;
source include/standby_sync_ddl.inc;
ob1.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO STANDBY, 60;

let $cluster_name = deploy_get_value(ob2.select select info from oceanbase.__all_zone where name = 'cluster', info, 1);
let $cluster_id_standby2 = deploy_get_value(ob2.select select value from oceanbase.__all_virtual_sys_parameter_stat where name = 'cluster_id', value, 1);
let $cluster_id_primary = deploy_get_value(ob1.select select value from oceanbase.__all_virtual_sys_parameter_stat where name = 'cluster_id', value, 1);

ob1.mysql alter system modify cluster '$cluster_name' cluster_id $cluster_id_standby2 set redo_transport_options='SYNC'; 
ob1.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO STANDBY, 60;
ob1.mysql ALTER SYSTEM SET STANDBY CLUSTER TO MAXIMIZE PROTECTION;
ob2.check_until_timeout select protection_mode from oceanbase.v\$ob_cluster, MAXIMUM PROTECTION, 30;
ob1.mysql alter system modify cluster '$cluster_name' cluster_id $cluster_id_primary set redo_transport_options='SYNC'; 

ob1.mysql CREATE RESOURCE UNIT unit_1 MAX_CPU $cpu, MAX_MEMORY $memory, MAX_IOPS $iops, MAX_DISK_SIZE $disk, MAX_SESSION_NUM $session, MIN_CPU=1, MIN_MEMORY=$min_memory, MIN_IOPS=128;

ob1.mysql CREATE RESOURCE POOL pool_1 UNIT = 'unit_1', UNIT_NUM = 1, ZONE_LIST = ('z1');
ob1.mysql CREATE TENANT tt1 RESOURCE_POOL_LIST = ('pool_1'), primary_zone='z1' set ob_tcp_invited_nodes='%';

ob1.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO STANDBY, 400;

ob2.mysql alter system set debug_sync_timeout = '100000s';
#卡住gc点
ob2.mysql set ob_global_debug_sync = 'BLOCK_FREEZE_INFO_UPDATE wait_for continue_signal';

ob_connect(tt1_conn, ob1.z1.obs0, root@tt1, , test, , USE_MYSQL_CONNECTOR);
connection tt1_conn;
create table t(c1 int primary key, c2 int);
#插入用户表数据
insert into t VALUES (1,1);

#重启主备库
ob1.force_stop;
ob2.force_stop;

sleep 20;

ob2.z1.obs0.start;
ob2.check_until_timeout select count(*) from oceanbase.__all_virtual_core_meta_table, 1, 100;
ob2.check_until_timeout select count(*) from oceanbase.__all_virtual_server_schema_info where refreshed_schema_version>0, 2, 100;
ob_connect(sys1_conn, ob2.z1.obs0, root, , oceanbase, , USE_MYSQL_CONNECTOR);
connection sys1_conn;
set ob_query_timeout=200000000;
#执行failover
ALTER SYSTEM ACTIVATE PHYSICAL STANDBY CLUSTER;
ob2.check_until_timeout select cluster_role from oceanbase.__all_virtual_cluster, PRIMARY, 100;
ob2.check_until_timeout select cluster_status from oceanbase.__all_virtual_cluster, VALID, 100;

ob_connect(tt1_conn2, ob2.z1.obs0, root@tt1, , test, , USE_MYSQL_CONNECTOR);
connection tt1_conn2;
#如果能查出新插入的数据，说明执行的是无损failover
select * from t;
