#rs
#msy
#主备库切换时，需要保证全部同步到
#起主库，起备库
#禁止备库同步ddl
#在主库上做ddl
#查看主备库上的__all_virtual_cluster
#打开同步，查看__all_virtual_cluster
#禁止同步
#做switchover
#查看__all_virtual_cluster
#打开同步，做切换
ob1=OBI(cluster=1, proxy_num = 0);
ob2=OBI(cluster=1, proxy_num = 0, leaderob=ob1);

ob1.reboot;
ob2.reboot;
#检查备库同步完成主库
let $schema_version = deploy_get_value(ob1.select select max(schema_version) as schema_version from oceanbase.__all_ddl_operation, schema_version, 1);
ob2.check_until_timeout select count(*) from oceanbase.__all_virtual_ddl_operation where schema_version = $schema_version, 1, 30;

#禁止备库同步
ob2.mysql alter system set debug_sync_timeout = '100000s';
ob2.mysql set ob_global_debug_sync = 'BEFORE_FOLLOWER_CLUSTER_SYNC_SCHEMA wait_for continue_signal';
ob_connect(conn1, ob1.z1.obs0, root@sys, , oceanbase, , USE_OB_CONNECTOR);
ob_connect(conn2, ob2.z1.obs0, root@sys, , oceanbase, , USE_OB_CONNECTOR);
#创建用户
ob1.mysql create user msy identified by 'wrewgdg';
#打开ddl限制
ob1.mysql alter system set enable_sys_table_ddl = true;
#建3000张表
let $db_id = deploy_get_value(ob1.select select database_id from oceanbase.__all_virtual_database where database_name = 'oceanbase' and tenant_id = 1, database_id, 1);
let $cnt = deploy_get_value(ob1.select select max(table_id & 0xffffffffff) as t_id from oceanbase.__all_virtual_table where database_id = $db_id and (table_id & 0xffffffffff) < 5000, t_id, 1);
let $i = 1;
while ($i < 30)
{
  let $table_id = deploy_get_value(ob1.select select ($i + $cnt) as c from dual, c,1);
  ob1.mysql create table oceanbase.__t$i (c1 int primary key,c3 int) table_id = $table_id tablegroup = 'oceanbase';
  inc $i;
}
#授权这三千张表
let $i = 1;
while ($i < 30) 
{
  ob1.mysql grant select on oceanbase.__t$i to msy;
  inc $i;
}
#删除用户
let $user_id = deploy_get_value(ob1.select select user_id from oceanbase.__all_virtual_user where user_name = 'msy', user_id, 1);
ob1.mysql drop user msy;

#检查
ob1.mysql_p select cluster_id,cluster_role,switchover_status from oceanbase.__all_virtual_cluster;
ob2.mysql_p select cluster_id,cluster_role,switchover_status from oceanbase.__all_virtual_cluster;
#开始备库同步
ob2.mysql set ob_global_debug_sync = 'now signal continue_signal';
ob2.mysql alter system set enable_sys_table_ddl = false;
#检测用户是否同步
let $schema_version = deploy_get_value(ob1.select select schema_version from oceanbase.__all_virtual_user_history where user_name = 'msy', schema_version, 1);
ob2.check_until_timeout select count(*) > 0 from oceanbase.__all_virtual_user_history where user_name = 'msy', 1, 10;
ob2.check_until_timeout select count(*) from oceanbase.__all_virtual_ddl_operation where schema_version = $schema_version, 1, 3;
#测试剩下ddl同步
let $count = deploy_get_value(ob1.select select count(*) as count from oceanbase.__all_virtual_ddl_operation where schema_version > $schema_version, count, 1);
ob2.check_until_timeout select count(*) from oceanbase.__all_virtual_ddl_operation where schema_version > $schema_version, $count, 300;
dec $count;
while ($count)
{
  let $schema_version = deploy_get_value(ob1.select select schema_version from oceanbase. __all_virtual_ddl_operation where schema_version > $schema_version limit 1,schema_version, 1);
  ob2.check_until_timeout select count(*) from oceanbase.__all_virtual_ddl_operation where schema_version = $schema_version, 1, 3;
  dec $count;
}
ob2.mysql set @@session.ob_query_timeout=30000000;
#查看状态
ob1.mysql_p select cluster_id,cluster_role,switchover_status from oceanbase.__all_virtual_cluster;
ob2.mysql_p select cluster_id,cluster_role,switchover_status from oceanbase.__all_virtual_cluster;

#禁止同步，做switchover
ob2.mysql set ob_global_debug_sync = 'BEFORE_FOLLOWER_CLUSTER_SYNC_SCHEMA wait_for continue_signal';
sleep 3;
#打开同步，切换失败
#主切备
connection conn1;
set ob_query_timeout = 15000000;
--error 4179
alter system COMMIT TO SWITCHOVER TO PHYSICAL STANDBY;
#备切主
#切换失败
connection conn2;
set ob_query_timeout = 15000000;
--error 4179
alter system COMMIT TO SWITCHOVER TO PRIMARY;
#打开同步
ob2.mysql set ob_global_debug_sync = 'now signal continue_signal';
#备库同步到最后一条
let $schema_version = deploy_get_value(ob1.select select max(schema_version) as schema_version from oceanbase.__all_ddl_operation, schema_version, 1);
ob2.check_until_timeout select count(*) from oceanbase.__all_virtual_ddl_operation where schema_version = $schema_version, 1, 3;
ob1.check_until_timeout select switchover_status from oceanbase.__all_virtual_cluster, TO STANDBY, 30;
#主切备成功
ob1.mysql alter system COMMIT TO SWITCHOVER TO PHYSICAL STANDBY;
ob2.check_until_timeout select switchover_status from oceanbase.__all_virtual_cluster, TO PRIMARY, 30;
#备库检查同步，切换成功
alter system COMMIT TO SWITCHOVER TO PRIMARY;

#在新主库上做操作，备库可以同步到新主库
ob2.mysql create user newmsy identified by 'wrewgdg';
let $schema_version = deploy_get_value(ob2.select select max(schema_version) as schema_version from oceanbase.__all_ddl_operation, schema_version, 1);
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_ddl_operation where schema_version = $schema_version, 1, 30;

#建租户
ob2.mysql CREATE RESOURCE POOL pool_1 UNIT = 'sys_unit_config', UNIT_NUM = 1, ZONE_LIST = ('z1');
ob2.mysql CREATE TENANT tt RESOURCE_POOL_LIST = ('pool_1'), primary_zone='z1' set ob_tcp_invited_nodes='%', ob_compatibility_mode='oracle';
let $primary_schema_version = deploy_get_value(ob2.select select max(schema_version) as s from oceanbase.__all_ddl_operation, s, 1);
ob2.check_until_timeout select count(*) c from __all_virtual_server_schema_info where refreshed_schema_version = $primary_schema_version and tenant_id = 1, 1, 30;
let $primary_schema_version = deploy_get_value(ob2.select select max(schema_version) as s from oceanbase.__all_virtual_ddl_operation where tenant_id = 1001, s, 1);
ob2.check_until_timeout select count(*) c from __all_virtual_server_schema_info where refreshed_schema_version = $primary_schema_version and tenant_id = 1001, 1, 30;
ob_connect(conn3, ob2, SYS@tt, ,SYS, , USE_OB_CONNECTOR);
connection conn3;
create table t1(c1 int primary key);
insert into t1 values(1);
#检查新备库是否可以同步完成
let $primary_schema_version = deploy_get_value(ob2.select select max(schema_version) as s from oceanbase.__all_ddl_operation, s, 1);
ob1.check_until_timeout select count(*) from oceanbase.__all_ddl_operation where schema_version = $primary_schema_version, 1, 30;
ob1.mysql alter system set balancer_idle_time = '10s';
ob1.mysql alter system set server_data_copy_out_concurrency = 30;
ob1.mysql alter system set server_data_copy_in_concurrency = 30;
ob1.mysql alter system set data_copy_concurrency = 60;
let $partition_cnt = deploy_get_value(ob2.select select count(*) c from __all_root_table where tenant_id = 1001, c, 1);
ob1.check_until_timeout select count(*) c from __all_root_table where tenant_id = 1001, $partition_cnt, 120;
let $partition_cnt = deploy_get_value(ob2.select select count(*) c from __all_virtual_meta_table where tenant_id = 1001, c, 1);
ob1.check_until_timeout select count(*) c from __all_virtual_meta_table where tenant_id = 1001, $partition_cnt, 120;
ob2.check_until_timeout select switchover_status from oceanbase.__all_virtual_cluster, TO STANDBY, 100;
let $primary_schema_version = deploy_get_value(ob2.select select max(schema_version) as s from oceanbase.__all_virtual_ddl_operation where tenant_id = 1001, s, 1);
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_ddl_operation where schema_version = $primary_schema_version, 1, 90;

#登陆备库查询
let $primary_schema_version = deploy_get_value(ob1.select select max(schema_version) as s from oceanbase.__all_ddl_operation, s, 1);
ob1.check_until_timeout select count(*) c from __all_virtual_server_schema_info where refreshed_schema_version = $primary_schema_version and tenant_id = 1, 1, 30;
let $primary_schema_version = deploy_get_value(ob1.select select max(schema_version) as s from oceanbase.__all_virtual_ddl_operation where tenant_id = 1001, s, 1);
ob1.check_until_timeout select count(*) c from __all_virtual_server_schema_info where refreshed_schema_version = $primary_schema_version and tenant_id = 1001, 1, 30;

ob_connect(conn4, ob1, SYS@tt, ,SYS, , USE_OB_CONNECTOR);
connection conn4;
select  * from t1;


