#同时创建一下表和database，检查purge recyclebin
connection conn1;
CREATE TABLE t1(c1 int);
let $table_id = deploy_get_value(ob1.select select table_id from __all_virtual_table where table_name = 't1', table_id, 1);
drop table t1;
CREATE TABLE t2(c1 int);
drop table t2;

ob1.check_until_timeout select count(*) from __all_recyclebin where table_id = $table_id, 1, 10;

ob1.mysql PURGE RECYCLEBIN;

ob1.check_until_timeout select count(*) from __all_recyclebin where tenant_id = $t9, 0, 10;
ob1.check_until_timeout select count(*) from __all_tenant where tenant_id = $t9 and status = 'TENANT_STATUS_DROPPING', 1, 10;
ob1.check_until_timeout select count(*) from __all_recyclebin, 0, 10;


#检查备库是否同步

ob2.check_until_timeout select count(*) from oceanbase.__all_tenant where tenant_id = 1009 and status = 'TENANT_STATUS_DROPPING', 1, 30;
ob2.check_until_timeout select count(*) from oceanbase.__all_recyclebin where tenant_id = 1009, 0, 30;

