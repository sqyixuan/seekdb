ob2.check_until_timeout select count(*) from oceanbase.__all_recyclebin where tenant_id = 1007, 1, 30;

ob1.mysql FLASHBACK TENANT t7 to before drop rename to aa;

ob2.check_until_timeout select count(*) from __all_recyclebin where tenant_id = $t7, 0, 10;
ob2.check_until_timeout select count(*) from __all_tenant where tenant_name = 'aa', 1, 10;


