ob1.check_until_timeout select count(*) from oceanbase.__all_recyclebin where tenant_id = 1007, 0, 30;

#case 3 purge tenant
#在主库上创建一个租户
ob1.mysql CREATE RESOURCE POOL pool_8 UNIT = 'unit_1', UNIT_NUM = 1, ZONE_LIST = ('z1');
ob1.mysql CREATE TENANT t8 RESOURCE_POOL_LIST = ('pool_8'), primary_zone='z1' set ob_tcp_invited_nodes='%';
let $primary_schema_version = deploy_get_value(ob1.select select max(schema_version) as s from oceanbase.__all_ddl_operation, s, 1);
ob1.check_until_timeout select count(*) c from __all_ddl_operation where schema_version = $primary_schema_version and tenant_id = 1, 1, 30;


#登陆备库查询
ob2.check_until_timeout select count(*) c from __all_ddl_operation where schema_version >= $primary_schema_version and tenant_id = 1, 1, 30;


connection conn1;
set global recyclebin = on;
connection conn2;
set global recyclebin = on;

let $t8 = deploy_get_value(ob1.select select tenant_id from __all_tenant where tenant_name = 't8', tenant_id, 1); 
ob1.mysql DROP TENANT t8;

ob1.check_until_timeout select count(*) from __all_recyclebin where tenant_id = $t8, 1, 10;
ob1.check_until_timeout select count(*) from __all_tenant where tenant_name = 't8', 0, 10;
#检查备库是否同步
let $primary_schema_version = deploy_get_value(ob1.select select max(schema_version) as s from oceanbase.__all_ddl_operation, s, 1);
ob1.check_until_timeout select count(*) c from __all_ddl_operation where schema_version = $primary_schema_version and tenant_id = 1, 1, 30;
ob2.check_until_timeout select count(*) c from __all_ddl_operation where schema_version >= $primary_schema_version and tenant_id = 1, 1, 30;
ob2.check_until_timeout select count(*) from oceanbase.__all_tenant where tenant_id = 1008 , 1, 30;
ob2.check_until_timeout select count(*) from oceanbase.__all_recyclebin where tenant_id = 1008, 1, 30;

ob1.mysql PURGE TENANT t8;

ob1.check_until_timeout select count(*) from __all_recyclebin where tenant_id = $t8, 0, 10;
ob1.check_until_timeout select count(*) from __all_tenant where tenant_id = $t8 and status = 'TENANT_STATUS_DROPPING', 1, 10;


#检查备库是否同步
let $primary_schema_version = deploy_get_value(ob1.select select max(schema_version) as s from oceanbase.__all_ddl_operation, s, 1);
ob1.check_until_timeout select count(*) c from __all_ddl_operation where schema_version = $primary_schema_version and tenant_id = 1, 1, 30;
ob2.check_until_timeout select count(*) c from __all_ddl_operation where schema_version >= $primary_schema_version and tenant_id = 1, 1, 30;

ob2.check_until_timeout select count(*) from oceanbase.__all_tenant where tenant_id = 1008 and status = 'TENANT_STATUS_DROPPING', 1, 30;
ob2.check_until_timeout select count(*) from oceanbase.__all_recyclebin where tenant_id = 1008, 0, 30;

