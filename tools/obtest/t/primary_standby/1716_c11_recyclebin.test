#owner: zhengshi.jhc
# owner group: rs
# 功能：验证drop tenant时放入回收站对备库的支持

#case 1
#a.主库关闭回收站
#drop tenant 主库不放入回收站，备库无论是否打开回收站，都应将租户直接删除，不放入回收站
#b.主库打开回收站
#drop tenant 主库不放入回收站，备库无论是否打开回收站，都应将租户放入回收站中。
#c.主库无论打开还是关闭回收站
#drop tenant purge/force 主库不放入回收站，备库行为与主库一致，不放入回收站。

#case 2
#备库同步主库的flashback tenant

#case 3
#备库同步主库的purge tenant操作

#case 4
#备库同步主库的purge recyclebin操作，应将回收站中的所有类型都删除


ob1=OBI(cluster=1, proxy_num = 0);
ob2=OBI(cluster=1, proxy_num = 0, leaderob=ob1);

ob1.reboot;
ob2.reboot;
ob_connect(conn1, ob1.z1.obs0, root@sys, , oceanbase, , USE_OB_CONNECTOR);
connection conn1;
ob_connect(conn2, ob2.z1.obs0, root@sys, , oceanbase, , USE_OB_CONNECTOR);
connection conn2;

let $cpu = 1;
let $memory = 1073741824;
let $min_memory = 1073741824;
let $disk = 536870912;
let $iops = 100000;
let $session = 64;
let $case_index = 1;

ob1.mysql CREATE RESOURCE UNIT unit_1 MAX_CPU $cpu, MAX_MEMORY $memory, MAX_IOPS $iops, MAX_DISK_SIZE $disk, MAX_SESSION_NUM $session, MIN_CPU=1, MIN_MEMORY=$min_memory, MIN_IOPS=128;

#检查备库同步完成主库
let $schema_version = deploy_get_value(ob1.select select max(schema_version) as schema_version from oceanbase.__all_ddl_operation, schema_version, 1);
ob2.check_until_timeout select count(*) from oceanbase.__all_virtual_ddl_operation where schema_version = $schema_version, 1, 30;

ob_connect(conn1, ob1.z1.obs0, root@sys, ,oceanbase, , USE_OB_CONNECTOR);
connection conn1;

#case 1 
#主库关闭回收站
#a.1.备库打开回收站

#在主库上创建一个租户
ob1.mysql CREATE RESOURCE POOL pool_1 UNIT = 'unit_1', UNIT_NUM = 1, ZONE_LIST = ('z1');
ob1.mysql CREATE TENANT t1 RESOURCE_POOL_LIST = ('pool_1'), primary_zone='z1' set ob_tcp_invited_nodes='%';
let $primary_schema_version = deploy_get_value(ob1.select select max(schema_version) as s from oceanbase.__all_ddl_operation, s, 1);
ob1.check_until_timeout select count(*) c from __all_ddl_operation where schema_version = $primary_schema_version and tenant_id = 1, 1, 30;


sleep 20;
#登陆备库查询
ob2.check_until_timeout select count(*) c from __all_ddl_operation where schema_version >= $primary_schema_version and tenant_id = 1, 1, 30;


connection conn1;
set global recyclebin = off;
connection conn2;
set global recyclebin = on;

let $t1 = deploy_get_value(ob1.select select tenant_id from __all_tenant where tenant_name = 't1', tenant_id, 1); 
ob1.mysql DROP TENANT t1;

ob1.check_until_timeout select count(*) from __all_recyclebin where tenant_id = $t1, 0, 10;
ob1.check_until_timeout select count(*) from __all_tenant where tenant_id = $t1 and status = 'TENANT_STATUS_DROPPING', 1, 10;


#检查备库是否同步
let $primary_schema_version = deploy_get_value(ob1.select select max(schema_version) as s from oceanbase.__all_ddl_operation, s, 1);
ob1.check_until_timeout select count(*) c from __all_ddl_operation where schema_version = $primary_schema_version and tenant_id = 1, 1, 30;
ob2.check_until_timeout select count(*) c from __all_ddl_operation where schema_version >= $primary_schema_version and tenant_id = 1, 1, 30;

ob2.check_until_timeout select count(*) from oceanbase.__all_tenant where tenant_id = 1001 and status = 'TENANT_STATUS_DROPPING', 1, 30;
ob2.check_until_timeout select count(*) from oceanbase.__all_recyclebin where tenant_id = 1001, 0, 30;

#a.2.备库关闭回收站

#在主库上创建一个租户
ob1.mysql CREATE RESOURCE POOL pool_2 UNIT = 'unit_1', UNIT_NUM = 1, ZONE_LIST = ('z1');
ob1.mysql CREATE TENANT t2 RESOURCE_POOL_LIST = ('pool_2'), primary_zone='z1' set ob_tcp_invited_nodes='%';
