ob1.nstart;
ob1.check_until_timeout select count(*) from (select count(*)c from oceanbase.__all_virtual_core_meta_table)s where s.c > 0, 1, 200;
# downgrade from max protection to max performance
ob1.mysql alter system set standby cluster to maximize performance;
ob1.mysql alter system remove cluster '$cluster_name' cluster_id = $cluster_id_ob2;

ob2.mysql_p select value from oceanbase.__all_sys_parameter where name = "cluster";
ob2.mysql_p select value from oceanbase.__all_sys_parameter where name = "obconfig_url";
