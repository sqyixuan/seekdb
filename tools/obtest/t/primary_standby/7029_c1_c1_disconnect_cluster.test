connection tt2_conn_z2;

ob_connect(tt2_conn_z3, ob2.z3.obs0, root, , oceanbase, , USE_MYSQL_CONNECTOR);
connection tt2_conn_z3;

ob2.check_until_timeout select count(*) from oceanbase.__all_virtual_processlist, 5, 20;
ob2.mysql set ob_global_debug_sync = 'BEFORE_SET_CLUSTER_NAME_CONFIGURL wait_for set_cluster_name';
ob_connect(tt2_conn, ob2.z1.obs0, root, , oceanbase, , USE_MYSQL_CONNECTOR);
connection tt2_conn;
--disable_query_log
--error 4012
eval ALTER SYSTEM DISCONNECT STANDBY CLUSTER '$cluster_name' CLUSTER_ID $cluster_id_ob2 SET CLUSTER_NAME 'newcluster_name' OBCONFIG_URL 'asdf' FORCE;
