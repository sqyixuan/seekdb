ob2.check_until_timeout select count(*) from oceanbase.__all_cluster where rs_list like "%\"ObCluster\":\"newcluster_name\"%" and cluster_id = $cluster_id_ob2, 1, 200;
ob2.mysql_p select cluster_idx, cluster_name, cluster_status, redo_transport_options, protection_level from oceanbase.__all_cluster;
