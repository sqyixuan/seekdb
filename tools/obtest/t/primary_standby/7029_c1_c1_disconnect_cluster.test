# owner: shouju.zyp

ob1=OBI(cluster=1:1:1,proxy_num=0);
ob2=OBI(cluster=1:1:1,leaderob=ob1,proxy_num=0);
ob3=OBI(cluster=1,leaderob=ob1,proxy_num=0);
ob1.reboot;
ob2.reboot;
ob3.reboot;
let $case_index = 1;
let $unit_num = 1;
let $locality = 'f@z1,f@z2,f@z3';
let $zone_list = 'z1','z2','z3';
source include/create_tenant_1.inc;

ob_connect(tt1_conn, ob1.z1.obs0, root@tenant_1, , test, , USE_MYSQL_CONNECTOR);
connection tt1_conn;
create table t(c1 int primary key, c2 char(10), c3 int);
create table t1(c1 int primary key, c2 int, c3 int);
create tablegroup pg binding = true;
create tablegroup pg1 binding = true;
create table t2(c1 int primary key, c2 int, c3 int) tablegroup = 'pg1';
insert into t values (1,1,1);
select * from t;


let $cluster_id_ob1 = deploy_get_value(ob1.select select value from oceanbase.__all_virtual_sys_parameter_stat where name = 'cluster_id', value, 1);
let $cluster_id_ob2 = deploy_get_value(ob2.select select value from oceanbase.__all_virtual_sys_parameter_stat where name = 'cluster_id', value, 1);
let $cluster_id_ob3 = deploy_get_value(ob3.select select value from oceanbase.__all_virtual_sys_parameter_stat where name = 'cluster_id', value, 1);

ob_connect(tt2_conn, ob2.z1.obs0, root, , oceanbase, , USE_MYSQL_CONNECTOR);
connection tt2_conn;
source include/standby_sync_ddl.inc;

ob1.check_until_timeout select switchover_status from oceanbase.__all_virtual_cluster, TO STANDBY, 200;
ob1.check_until_timeout select synchronization_status from oceanbase.__all_virtual_standby_status where cluster_id=$cluster_id_ob2, OK, 200;
ob1.check_until_timeout select synchronization_status from oceanbase.__all_virtual_standby_status where cluster_id=$cluster_id_ob3, OK, 200;
let $cluster_name = deploy_get_value(ob2.select select info from oceanbase.__all_zone where name = 'cluster', info, 1);

# set maximum protection mode
ob1.mysql alter system modify cluster '$cluster_name' cluster_id $cluster_id_ob2 set redo_transport_options='SYNC';
ob1.mysql alter system modify cluster '$cluster_name' cluster_id $cluster_id_ob1 set redo_transport_options='SYNC';
ob1.check_until_timeout select count(*) from v\$ob_cluster where switchover_info = 'SYNCED STANDBY CLUSTERS: 2,3', 1, 360;
ob1.mysql ALTER SYSTEM SET STANDBY CLUSTER TO MAXIMIZE PROTECTION;
ob1.check_until_timeout select protection_level from oceanbase.__all_cluster where cluster_id = $cluster_id_ob2, MAXIMUM PROTECTION, 100;

#create another ob2 connection, to check whether disconnect cluster can kill it
ob_connect(tt2_conn_2, ob2.z2.obs0, root, , oceanbase, , USE_MYSQL_CONNECTOR);
connection tt2_conn_2;

alter system set debug_sync_timeout = '1000s';

--disable_query_log
--error 4179
eval ALTER SYSTEM DISCONNECT STANDBY CLUSTER '$cluster_name' CLUSTER_ID $cluster_id_ob2 SET CLUSTER_NAME 'newcluster_name' OBCONFIG_URL 'asdf';
--enable_query_log

--disable_query_log
--error 4179
eval ALTER SYSTEM DISCONNECT STANDBY CLUSTER '$cluster_name' CLUSTER_ID $cluster_id_ob2 SET CLUSTER_NAME 'newcluster_name' OBCONFIG_URL 'asdf' VERIFY;
--enable_query_log

--disable_query_log
--error 4179
eval ALTER SYSTEM DISCONNECT STANDBY CLUSTER '$cluster_name' CLUSTER_ID $cluster_id_ob2 SET CLUSTER_NAME 'newcluster_name' OBCONFIG_URL 'asdf' FORCE VERIFY;
--enable_query_log

# stop primary to do force disconnect cluster in max protection mode
ob1.force_stop;

#disconnect cluster 2
