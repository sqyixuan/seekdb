#owner: msy164651
#owner group: rs
#description: 主备库系统租户ddl的同步 

ob1=OBI(cluster=1, proxy_num = 0);
ob2=OBI(cluster=1, proxy_num = 0, leaderob=ob1);
ob1.reboot;
ob2.reboot;
ob1.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO STANDBY, 30;
ob_connect(conn1, ob1.z1.obs0, root@sys,,oceanbase,,USE_OB_CONNECTOR);
ob1.mysql alter system set enable_sys_table_ddl = true;
ob2.mysql alter system set enable_sys_table_ddl = false;

ob_connect(conn2, ob2.z1.obs0, root@sys,,oceanbase,,USE_OB_CONNECTOR);
source include/standby_sync_ddl.inc;
#租户相关
let $cpu = 1;
let $memory = 1073741824;
let $min_memory = 1073741824;
let $disk = 536870912;
let $iops = 100000;
let $session = 64;
#创建租户
ob1.mysql create resource unit test_resource_unit max_cpu $cpu, max_memory $memory, max_iops $iops, max_disk_size $disk, max_session_num $session, MIN_CPU=1, MIN_MEMORY=$min_memory, MIN_IOPS=128;
ob1.mysql create resource pool test_resource_pool1 unit = 'test_resource_unit', unit_num = 1, zone_list = ('z1');
ob1.mysql create tenant tt1 replica_num = 1, primary_zone='z1', locality='F@z1', resource_pool_list=('test_resource_pool1') set ob_tcp_invited_nodes='%';
let $tenant_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name = 'tt1', tenant_id, 1);
#在备库中查询同步到租户的schema
ob2.check_until_timeout select count(*) from oceanbase.__all_tenant where tenant_id = $tenant_id, 1, 10;
ob2.mysql_p select tenant_id, tenant_name , primary_zone, locality from oceanbase.__all_tenant; 
ob1.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO STANDBY, 200;
#modify tenant

#系统变量
#add system variable只在升级的时候使用，因为不插all_ddl_operation表，备库需要独立处理，否则同步不来
#modify sys variable
ob1.mysql set global ob_query_timeout = 100000000;
ob1.mysql set global ob_query_timeout = 100000001;
ob1.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO STANDBY, 30;
ob2.mysql_p select value from oceanbase.__all_sys_variable where name = 'ob_query_timeout';

#create database
#系统database同步，用户database不同步
ob1.mysql create database msy database_id = 999 tablegroup = oceanbase;
ob1.mysql create database msy1;
ob1.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO STANDBY, 30;
sleep 4;
ob2.mysql_p select database_name from oceanbase.__all_database where database_id = 1 << 40 | 999;
ob2.mysql create database msy1;

#create tablegroup
#需要在备份恢复的账户下
ob1.mysql create user __oceanbase_inner_drc_user;
ob1.mysql grant all privileges on *.* to __oceanbase_inner_drc_user;
ob_connect(conn11, ob1.z1.obs0, __oceanbase_inner_drc_user@sys,,oceanbase,,USE_OB_CONNECTOR);
connection conn11;
let $tg_id = deploy_get_value(ob1.select select 1 << 39 | 999 as tg, tg, 1);
eval create tablegroup tg tablegroup_id = $tg_id partition by hash partitions 10;
eval create tablegroup tg3 tablegroup_id = 899 partition by range (partition p0 values less than(10));
let $tg_id = deploy_get_value(ob1.select select 1 << 39 | 9999 as tg, tg, 1);
eval create tablegroup tg1 tablegroup_id = $tg_id;
ob1.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO STANDBY, 30;
ob2.mysql_p select tablegroup_name from oceanbase.__all_tablegroup where tablegroup_id = 1 << 40 | 999;
ob_connect(conn21, ob2.z1.obs0, __oceanbase_inner_drc_user@sys,,oceanbase,,USE_OB_CONNECTOR);
connection conn21;
sleep 4;
eval create tablegroup tg1 tablegroup_id = $tg_id;

#create table
connection conn1;
create table t1(c1 int primary key, c2 int, c3 int) tablegroup = oceanbase table_id = 780;
insert into t1 values(1,1,1);
create table t2(c1 int primary key, c2 int, c3 int) tablegroup='tg1';
ob1.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO STANDBY, 30;
ob2.mysql_p select table_name from oceanbase.__all_virtual_table where table_id = 1 << 40 | 780;
ob2.mysql_p select * from oceanbase.t1;
sleep 4;
connection conn2;
create table t2(c1 int primary key, c2 int, c3 int) tablegroup='tg1';

#alter table
connection conn1;
#alter table t1 add column c4 int id 100;
alter table t2 tablegroup = '';
ob1.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO STANDBY, 30;
sleep 4;
connection conn2;
#insert into t1 values(1,1,1,1);
alter table t2 tablegroup = '';
#alter database
ob1.mysql alter database msy tablegroup = oceanbase;
ob1.mysql alter database msy1 tablegroup = tg1;
ob1.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO STANDBY, 30;
sleep 4;
ob2.mysql alter database msy1 tablegroup = tg1;
#drop database
ob1.mysql drop database msy;
ob1.mysql drop database msy1;
ob1.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO STANDBY, 30;
sleep 4;
ob2.mysql drop database msy1;
