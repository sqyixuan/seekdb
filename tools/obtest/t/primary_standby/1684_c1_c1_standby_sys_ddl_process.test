ob1.mysql grant select on *.* to 'u101';

#optimize 系统表
ob1.mysql optimize table oceanbase.__all_root_table;
ob1.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO STANDBY, 30;
connection conn2;
--error 4179
optimize table __all_root_table;
#使用创建的用户，登陆备库
ob2.check_until_timeout select count(*) from oceanbase.__all_virtual_user where user_name='u101', 1, 35;
ob_connect(ob2_conn, ob2.z1.obs0, u101@sys, pass1,oceanbase,,USE_OB_CONNECTOR);
ob2.mysql_p select user_name,user_id,passwd from oceanbase.__all_user where user_name = 'u101';
ob1.mysql_p select user_name,user_id,passwd from oceanbase.__all_user where user_name = 'u101';
#更改用户名

ob1.mysql rename user 'u101' to 'u99'; 
ob2.check_until_timeout select count(*) from oceanbase.__all_virtual_user where user_name='u99', 1, 5;
ob2.mysql_p select user_name,user_id,passwd from oceanbase.__all_user where user_name = 'u99';
ob1.mysql_p select user_name,user_id,passwd from oceanbase.__all_user where user_name = 'u99';
#改密码
ob1.mysql alter user u99 identified by '99';
let $schema_version = deploy_get_value(ob1.select select max(schema_version) as s from oceanbase.__all_virtual_user_history where user_name='u99', s, 1);
ob2.check_until_timeout select count(*) from oceanbase.__all_ddl_operation where schema_version = $schema_version, 1, 20;
ob2.mysql_p select user_name,user_id,passwd from oceanbase.__all_user where user_name = 'u99';
ob1.mysql_p select user_name,user_id,passwd from oceanbase.__all_user where user_name = 'u99';

#锁用户
ob1.mysql alter user u99 ACCOUNT LOCK;
let $schema_version = deploy_get_value(ob1.select select max(schema_version) as s from oceanbase.__all_virtual_user_history where user_name='u99', s, 1);
ob2.check_until_timeout select count(*) from oceanbase.__all_ddl_operation where schema_version = $schema_version, 1, 20;
ob2.mysql_p select user_name,user_id,passwd from oceanbase.__all_user where user_name = 'u99';
ob1.mysql_p select user_name,user_id,passwd from oceanbase.__all_user where user_name = 'u99';
ob1.mysql alter user u99 ACCOUNT UNLOCK;
let $schema_version = deploy_get_value(ob1.select select max(schema_version) as s from oceanbase.__all_virtual_user_history where user_name='u99', s, 1);
ob2.check_until_timeout select count(*) from oceanbase.__all_ddl_operation where schema_version = $schema_version, 1, 20;
ob2.mysql_p select user_name,user_id,passwd from oceanbase.__all_user where user_name = 'u99';
ob1.mysql_p select user_name,user_id,passwd from oceanbase.__all_user where user_name = 'u99';
#revoke

