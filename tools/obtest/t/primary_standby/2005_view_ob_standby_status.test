# owner: 修铭
# description:
# 验证V$OB_STANDBY_STATUS视图

ob1=OBI(cluster=1,proxy_num=0);
ob2=OBI(cluster=1,leaderob=ob1,proxy_num=0);
ob3=OBI(cluster=1,leaderob=ob1,proxy_num=0);
ob1.reboot;
ob2.reboot;
ob3.reboot;
let $cpu = 1;
let $memory = 1073741824;
let $min_memory = 1073741824;
let $disk = 536870912;
let $iops = 100000;
let $session = 64;
let $case_index = 1;

ob1.mysql CREATE RESOURCE UNIT unit_1 MAX_CPU $cpu, MAX_MEMORY $memory, MAX_IOPS $iops, MAX_DISK_SIZE $disk, MAX_SESSION_NUM $session, MIN_CPU=1, MIN_MEMORY=$min_memory, MIN_IOPS=128;
ob1.mysql CREATE RESOURCE POOL pool_1 UNIT = 'unit_1', UNIT_NUM = 1, ZONE_LIST = ('z1');
ob1.mysql CREATE TENANT tenant_1 RESOURCE_POOL_LIST = ('pool_1'), primary_zone='z1' set ob_tcp_invited_nodes='%';

# sleep一下，保证租户在主库上创建成功
sleep 3;

ob1.check_until_timeout select count(*) from __all_virtual_cluster where switchover_status='TO STANDBY', 1, 360;

# 验证所有列查询情况
# 这里过滤掉了cluster_name、current_scn，rootservice_list这些不稳定列
ob1.mysql_p select cluster_id, cluster_role, cluster_status from oceanbase.__all_virtual_standby_status;
ob2.mysql_p select cluster_id, cluster_role, cluster_status from oceanbase.__all_virtual_standby_status;

let $cluster_name = deploy_get_value(ob1.select select cluster_name from __all_virtual_cluster, cluster_name, 1);

# 指定列查询
ob1.mysql_p select cluster_id, cluster_role, cluster_status from oceanbase.__all_virtual_standby_status where cluster_role = 'PHYSICAL STANDBY';
ob1.mysql_p select cluster_id, cluster_role, cluster_status from oceanbase.__all_virtual_standby_status where cluster_status = 'VALID';
ob1.mysql_p select cluster_id, cluster_role, cluster_status from oceanbase.__all_virtual_standby_status where cluster_id = 2;
ob1.mysql_p select cluster_id, cluster_role, cluster_status from oceanbase.__all_virtual_standby_status where cluster_name = '$cluster_name';

let $primary_current_scn = deploy_get_value(ob1.select select current_scn from __all_virtual_cluster, current_scn, 1);
ob1.check_until_timeout select count(*) from __all_virtual_standby_status where current_scn > $primary_current_scn, 2, 360;
