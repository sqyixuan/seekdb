#rs
#msy
#验证disable cluster之后，备库不会进行同步
ob1=OBI(cluster=1, proxy_num = 0);
ob2=OBI(cluster=1, proxy_num = 0, leaderob=ob1);

ob1.reboot;
ob2.reboot;
ob1.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO STANDBY, 60;
ob2.mysql alter system set balancer_idle_time = '10s';
ob2.mysql alter system set server_data_copy_out_concurrency = 30;
ob2.mysql alter system set server_data_copy_in_concurrency = 30;
ob2.mysql alter system set data_copy_concurrency = 60;
#case 1
#建租户
let $case_index = 1;
let $unit_num = 1;
let $locality = 'f@z1';
let $zone_list = 'z1';
source include/create_tenant_1.inc;
let $primary_schema_version = deploy_get_value(ob1.select select max(schema_version) as s from oceanbase.__all_ddl_operation, s, 1);
ob1.check_until_timeout select count(*) c from __all_virtual_server_schema_info where refreshed_schema_version = $primary_schema_version and tenant_id = 1, 1, 30;
let $primary_schema_version = deploy_get_value(ob1.select select max(schema_version) as s from oceanbase.__all_virtual_ddl_operation where tenant_id = 1001, s, 1);
ob1.check_until_timeout select count(*) c from __all_virtual_server_schema_info where refreshed_schema_version = $primary_schema_version and tenant_id = 1001, 1, 30;
ob_connect(conn1, ob1.z1.obs0, root@tenant_1, ,test, , USE_OB_CONNECTOR);
connection conn1;
create table t1(c1 int primary key, c2 int);
insert into t1 values(1, 1);
create index il on t1(c2);
ob1.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO STANDBY, 600;
let $cluster_name = deploy_get_value(ob2.select select info from oceanbase.__all_zone where name = 'cluster', info, 1);
let $cluster_id = deploy_get_value(ob2.select select value from oceanbase.__all_virtual_sys_parameter_stat where name = 'cluster_id', value, 1);
--disable_query_log
ob1.mysql alter system disable cluster synchronization '$cluster_name' cluster_id = $cluster_id;
--enable_query_log
ob2.check_until_timeout select count(*) from oceanbase.__all_cluster where cluster_id = $cluster_id and cluster_status = 2, 1, 10;
let $case_index = 2;
sleep 5;
source include/create_tenant_1.inc;
ob_connect(conn1, ob1.z1.obs0, root@tenant_1, ,test, , USE_OB_CONNECTOR);
connection conn1;
create table t2(c1 int);
ob1.mysql alter system major freeze;
sleep 20;
ob2.mysql_p select * from oceanbase.__all_tenant where tenant_name = 'tenant_2';
let $table_id = deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where table_name = 't2', table_id, 1);
ob2.mysql_p select * from oceanbase.__all_virtual_meta_table where table_id = $table_id;
ob2.mysql_p select tenant_id, frozen_version, schema_version from oceanbase.__all_freeze_schema_version;
#enable备库，不需要检查
--disable_query_log
ob1.mysql alter system enable cluster synchronization '$cluster_name' cluster_id = $cluster_id;
--enable_query_log
ob1.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO STANDBY, 600;
ob1.mysql alter system commit to switchover to physical standby;
ob1.mysql_p select cluster_status from oceanbase.__all_virtual_cluster;
ob2.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO PRIMARY, 60;
ob2.mysql alter system commit to switchover to primary;
ob2.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO STANDBY, 100;
ob2.mysql alter system commit to switchover to physical standby;
ob1.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO PRIMARY, 100;
ob1.mysql alter system commit to switchover to primary;
