# owner: rongxuan.lc
# description: 本case是为了测试建索引快照点大于未确定schema_version的冻结快照点时，为索引sstable确定最大冻结点为静态版本version;


ob1=OBI(cluster=1:1:1,proxy_num=0);
ob1.reboot;
let $cpu = 1;
let $memory = 1073741824;
let $min_memory = 1073741824;
let $disk = 536870912;
let $iops = 100000;
let $session = 64;
let $case_index = 1;
ob1.mysql alter system set debug_sync_timeout = '100000s';
ob_connect(sys1_conn, ob1.z1.obs0, root, , oceanbase, , USE_MYSQL_CONNECTOR);
connection sys1_conn;
set ob_query_timeout = 30000000;
eval  CREATE RESOURCE UNIT unit_1 MAX_CPU $cpu, MAX_MEMORY $memory, MAX_IOPS $iops, MAX_DISK_SIZE $disk, MAX_SESSION_NUM $session, MIN_CPU=1, MIN_MEMORY=$min_memory, MIN_IOPS=128;
eval  CREATE RESOURCE POOL pool_1 UNIT = 'unit_1', UNIT_NUM = 1, ZONE_LIST = ('z1');
eval  CREATE TENANT tenant_$case_index RESOURCE_POOL_LIST = ('pool_1'), primary_zone='z1' set ob_tcp_invited_nodes='%';
ob_connect(tt1_conn, ob1.z1.obs0, root@tenant_1, , test, , USE_MYSQL_CONNECTOR);
connection tt1_conn;
create table t(c1 int primary key, c2 int);
insert into t values (1,2),(3,4),(5,6);
##发起一次冻结点，但是不容许设置schema_version
ob1.mysql alter system major freeze;
ob1.mysql set ob_global_debug_sync = 'BLOCK_FREEZE_INFO_UPDATE wait_for continue_signal';
sleep 15;
###验证当前时间大于冻结点；
ob1.check_until_timeout select count(*) from __all_core_table where table_name = '__all_freeze_info' and row_id = 2 and column_name= 'frozen_timestamp' and (time_to_usec(now()) - column_value) > 0, 1, 3;
ob1.check_until_timeout select count(*) from __all_freeze_schema_version where frozen_version = 2, 0, 3;
connection tt1_conn;
create index t_global on t(c2) global;
###验证此时freeze_schema_Version为空；
ob1.check_until_timeout select count(*) from __all_freeze_schema_version where frozen_version = 2, 0, 3;
ob1.mysql set ob_global_debug_sync = 'now signal continue_signal';
##检查合并完成；
ob1.check_version 2;
ob1.mysql alter system major freeze;
ob1.check_version 3;
