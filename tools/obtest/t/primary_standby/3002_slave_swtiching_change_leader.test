##############################
# owner: debin.jdb
# group: CLOG
#
# 测试功能点：
# 1. leader切换时下游副本不会出现秒级落后；
# 2. 卸任后，能够将不同region的child清理掉;
# 3. leader可以清理掉重复region的下游（仅children_list中,不考虑paxos member_list）;
#

ob1=OBI(cluster=1:1,proxy_num=0,init_unit_cpu=0,locality=HZ:HZ:SH);
ob2=OBI(cluster=1:1,leaderob=ob1,proxy_num=0,locality=HZ:HZ:SZ);

ob1.reboot;
sleep 5;
ob2.reboot;

ob1.mysql alter system set resource_hard_limit=900;
ob1.mysql alter system set resource_soft_limit=800;
ob1.mysql alter system set balancer_idle_time = '10s';
ob1.mysql alter system set enable_auto_leader_switch = 'false';

let $cpu = 1;
let $memory = 1073741824;
let $min_memory = 1073741824;
let $disk = 536870912;
let $iops = 100000;
let $session = 64;
let $case_index = 1;

ob1.mysql CREATE RESOURCE UNIT unit_1 MAX_CPU $cpu, MAX_MEMORY $memory, MAX_IOPS $iops, MAX_DISK_SIZE $disk, MAX_SESSION_NUM $session, MIN_CPU=1, MIN_MEMORY=$min_memory, MIN_IOPS=128;
ob1.mysql CREATE RESOURCE POOL pool_1 UNIT = 'unit_1', UNIT_NUM = 1, ZONE_LIST = ('z1','z2');
ob1.mysql CREATE TENANT tt1 RESOURCE_POOL_LIST = ('pool_1'), primary_zone='z1;z2;' set ob_tcp_invited_nodes='%';

sleep 3;
ob_connect(conn_ob1_sys, ob1.z1.obs0, root@sys,, oceanbase,, USE_MYSQL_CONNECTOR);
ob_connect(conn_ob2_sys, ob2.z1.obs0, root@sys,, oceanbase,, USE_MYSQL_CONNECTOR);
ob_connect(conn_ob1_tt1, ob1.z1.obs0, root@tt1, ,test, , USE_MYSQL_CONNECTOR);


# waiting for the servers to start service
sleep 10;
ob1.check_until_timeout select count(*) c from oceanbase.__all_server where start_service_time <= 0 or status = "inactive", 0, 120;
ob2.check_until_timeout select count(*) c from oceanbase.__all_server where start_service_time <= 0 or status = "inactive", 0, 120;

connection conn_ob1_sys;
--disable_query_log
alter system set server_data_copy_out_concurrency = 30;
alter system set server_data_copy_in_concurrency = 30;
alter system set data_copy_concurrency = 60;
ob1.check_until_timeout select count(*) from v\$ob_cluster where switchover_status='TO STANDBY', 1, 360;

# 建表
connection conn_ob1_tt1;

create table t1(c1 int primary key);
insert into t1 values (1), (2);
select * from t1;

# 确定所有follower都分配到了有效的parent
ob1.check_until_timeout select count(*) c from oceanbase.__all_virtual_clog_stat where role != 'LEADER' and parent like '%0.0.0.0%', 0, 30;
ob2.check_until_timeout select count(*) c from oceanbase.__all_virtual_clog_stat where role != 'LEADER' and parent like '%0.0.0.0%', 0, 30;

let $table_id = deploy_get_value(ob1.select select table_id from __all_virtual_table where table_name='t1', table_id, 1);
let $z2_ip = deploy_get_value(ob1.z2.obs0.ip);
let $z2_port = deploy_get_value(ob1.z2.obs0.port);
let $z1_ip = deploy_get_value(ob1.z1.obs0.ip);
let $z1_port = deploy_get_value(ob1.z1.obs0.port);

let $ob2_z1_ip = deploy_get_value(ob2.z1.obs0.ip);
let $ob2_z1_port = deploy_get_value(ob2.z1.obs0.port);
let $ob2_z2_ip = deploy_get_value(ob2.z2.obs0.ip);
let $ob2_z2_port = deploy_get_value(ob2.z2.obs0.port);

################################################################
# CASE 1: 执行切主，检查只读zone是否都有正常的parent
# 确认所有副本log sync
ob1.check_until_timeout select count(1) c from oceanbase.__all_virtual_clog_stat where table_id = "$table_id" and is_in_sync = 0, 0, 30;
ob2.check_until_timeout select count(1) c from oceanbase.__all_virtual_clog_stat where table_id = "$table_id" and is_in_sync = 0, 0, 30;
# 原主库切备
connection conn_ob1_sys;
alter system commit to switchover to physical standby;
sleep 3;
# 开始为t1切leader
# 首先确认leader位置
ob1.check_until_timeout select count(*) c from oceanbase.__all_virtual_clog_stat where table_id = "$table_id" and role = 'LEADER' and svr_ip like '%$z1_ip%' and svr_port = $z1_port, 1, 30;
# 执行切主会报错，因为election不允许;注意拦截错误码不能用ob1.mysql来执行sql,要直连执行
connection conn_ob1_sys;
--enable_result_log
--error 4109
eval alter system switch replica leader partition_id = '0%1@$table_id' server = '$z2_ip:$z2_port';
