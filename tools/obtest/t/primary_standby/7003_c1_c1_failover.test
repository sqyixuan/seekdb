#rs
#zbf
ob1=OBI(cluster=1:1:1:1, proxy_num = 0);
ob2=OBI(cluster=1:1:1, proxy_num = 0, leaderob=ob1);
ob3=OBI(cluster=1:1:1, proxy_num = 0, leaderob=ob1);
ob4=OBI(cluster=1:1:1:1, proxy_num = 0, leaderob=ob1);

ob1.reboot;
ob2.reboot;
ob_connect(conn2, ob2.z1.obs0, root@sys, ,oceanbase, , USE_OB_CONNECTOR);
connection conn2;
source include/standby_sync_ddl.inc;

ob1.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO STANDBY, 500;
ob1.force_stop;
sleep 30;
#When tenant is not created, test the execution of possible-dataloss Failover
ob2.mysql ALTER SYSTEM ACTIVATE PHYSICAL STANDBY CLUSTER;
ob2.mysql_p select cluster_role,protection_mode,protection_level from oceanbase.__all_virtual_cluster;

ob2.force_stop;
sleep 30;
ob1.reboot;
ob3.reboot;

ob_connect(conn3, ob3.z1.obs0, root@sys, ,oceanbase, , USE_OB_CONNECTOR);
connection conn3;
source include/standby_sync_ddl.inc;

let $cpu = 1;
let $memory = 1073741824;
let $min_memory = 1073741824;
let $disk = 536870912;
let $iops = 100000;
let $session = 64;
let $case_index = 1;

ob1.mysql CREATE RESOURCE UNIT unit_1 MAX_CPU $cpu, MAX_MEMORY $memory, MAX_IOPS $iops, MAX_DISK_SIZE $disk, MAX_SESSION_NUM $session, MIN_CPU=1, MIN_MEMORY=$min_memory, MIN_IOPS=128;
ob1.mysql CREATE RESOURCE POOL pool_1 UNIT = 'unit_1', UNIT_NUM = 1, ZONE_LIST = ('z1', 'z2', 'z3');
ob1.mysql CREATE TENANT tenant_$case_index RESOURCE_POOL_LIST = ('pool_1'), primary_zone='z1' set ob_tcp_invited_nodes='%';

ob1.mysql CREATE RESOURCE POOL pool_2 UNIT = 'unit_1', UNIT_NUM = 1, ZONE_LIST = ('z1', 'z2', 'z3');
ob1.mysql CREATE TENANT tenant_2 RESOURCE_POOL_LIST = ('pool_2'), primary_zone='z1' set ob_tcp_invited_nodes='%';

ob1.mysql CREATE RESOURCE POOL pool_3 UNIT = 'unit_1', UNIT_NUM = 1, ZONE_LIST = ('z1', 'z2', 'z3');
ob1.mysql CREATE TENANT tenant_3 RESOURCE_POOL_LIST = ('pool_3'), primary_zone='z1' set ob_tcp_invited_nodes='%';

ob1.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO STANDBY, 2000;
ob1.force_stop;
sleep 30;
#When tenant is created, test the execution of possible-dataloss Failover
ob_connect(conn3, ob3.z1.obs0, root@sys, ,oceanbase, , USE_OB_CONNECTOR);
connection conn3;
set ob_query_timeout=240000000;
ob3.mysql alter system set _mini_merge_concurrency = 16;
ob3.mysql alter system set _ob_minor_merge_schedule_interval = '3s';
ALTER SYSTEM ACTIVATE PHYSICAL STANDBY CLUSTER;
ob3.mysql alter system set _mini_merge_concurrency = 3;
ob3.mysql alter system set _ob_minor_merge_schedule_interval = '20s';
ob3.mysql_p select cluster_role,protection_mode,protection_level from oceanbase.__all_virtual_cluster;



ob3.force_stop;
sleep 30;
ob1.reboot;
ob4.reboot;
ob1.mysql CREATE RESOURCE UNIT unit_2 MAX_CPU $cpu, MAX_MEMORY $memory, MAX_IOPS $iops, MAX_DISK_SIZE $disk, MAX_SESSION_NUM $session, MIN_CPU=1, MIN_MEMORY=$min_memory, MIN_IOPS=128;
ob1.mysql CREATE RESOURCE POOL pool_4 UNIT = 'unit_2', UNIT_NUM = 1, ZONE_LIST = ('z1', 'z2', 'z3', 'z4');
ob1.mysql CREATE TENANT tenant_4 RESOURCE_POOL_LIST = ('pool_4'), primary_zone='z1' set ob_tcp_invited_nodes='%';
ob1.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO STANDBY, 3000;

ob_connect(conn_tenant_4, ob1.z1.obs0, root@tenant_4, , test, , USE_MYSQL_CONNECTOR);
create table t1(pk int primary key, c1 int, c2 varchar(20));
insert into t1 values(1,1,'a');
commit;

ob4.mysql alter tenant tenant_4 set locality = "F{1}@z1,F{1}@z2,R{1}@z3,F{1}@z4";
ob4.check_until_timeout select count(*) c from oceanbase.__all_tenant where previous_locality != "", 0, 360;
ob4.mysql alter tenant tenant_4 set locality = "F{1}@z1,F{1}@z2,R{1}@z3,L{1}@z4";
ob4.check_until_timeout select count(*) c from oceanbase.__all_tenant where previous_locality != "", 0, 360;

ob1.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO STANDBY, 3000;
ob1.force_stop;
sleep 30;
#tenant's locality is 2F+1R+1L, test the execution of possible-dataloss Failover
ob_connect(conn4, ob4.z1.obs0, root@sys, ,oceanbase, , USE_OB_CONNECTOR);
connection conn4;
set ob_query_timeout=300000000;
ob4.z1.obs0.mysql alter system set debug_sync_timeout = '100000s';
ob4.z1.obs0.mysql set ob_global_debug_sync = 'AFTER_WRITE_USER_TABLE_CUTDATA_CLOG wait_for continue_signal';
# test reentrant of fo after WRITE_USER_TABLE_CUTDATA_CLOG
--error 4012
ALTER SYSTEM ACTIVATE PHYSICAL STANDBY CLUSTER;
ob4.z1.obs0.mysql set ob_global_debug_sync = 'now signal continue_signal';
ob4.mysql_p select switchover_status,cluster_role,protection_mode,protection_level from oceanbase.__all_virtual_cluster;

ob_connect(conn4, ob4.z1.obs0, root@sys, ,oceanbase, , USE_OB_CONNECTOR);
connection conn4;
set ob_query_timeout=240000000;
ob4.mysql alter system set _mini_merge_concurrency = 16;
ob4.mysql alter system set _ob_minor_merge_schedule_interval = '3s';
ALTER SYSTEM ACTIVATE PHYSICAL STANDBY CLUSTER;
ob4.mysql alter system set _mini_merge_concurrency = 3;
ob4.mysql alter system set _ob_minor_merge_schedule_interval = '20s';
ob4.mysql_p select cluster_role,protection_mode,protection_level from oceanbase.__all_virtual_cluster;
