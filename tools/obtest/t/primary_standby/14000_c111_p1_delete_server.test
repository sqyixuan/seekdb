# owner: rongxuan.lc
# description: 本case是为了测试delete server之后，location cache不会返回已经delete掉的OBS;

ob1=OBI(cluster=1:1:1,proxy_num=0);
ob1.reboot;
let $cpu = 1;
let $memory = 1073741824;
let $min_memory = 1073741824;
let $disk = 536870912;
let $iops = 100000;
let $session = 64;
let $case_index = 1;

ob1.mysql CREATE RESOURCE UNIT unit_1 MAX_CPU $cpu, MAX_MEMORY $memory, MAX_IOPS $iops, MAX_DISK_SIZE $disk, MAX_SESSION_NUM $session, MIN_CPU=1, MIN_MEMORY=$min_memory, MIN_IOPS=128;
ob1.mysql CREATE RESOURCE POOL pool_1 UNIT = 'unit_1', UNIT_NUM = 1, ZONE_LIST = ('z1','z2','z3');
ob1.mysql CREATE TENANT tenant_$case_index RESOURCE_POOL_LIST = ('pool_1'), primary_zone='z1' set ob_tcp_invited_nodes='%';
sleep 3;

ob_connect(tt1_conn, ob1.z1.obs0, root@tenant_1, , test, , USE_MYSQL_CONNECTOR);
connection tt1_conn;
create table t(c1 int primary key, c2 int);
insert into t values (1,2),(3,4),(5,6);
select * from t;
ob1.mysql alter tenant sys set locality = 'F@z2,F@z3';
ob1.mysql alter tenant tenant_1 set locality = 'F@z2,F@z3';
ob1.check_until_timeout select count(*) from __all_tenant where previous_locality != '', 0, 240; 

ob1.mysql alter resource pool sys_pool  zone_list = ('z3','z2');
ob1.mysql alter resource pool pool_1 zone_list = ('z3','z2');
let $ip = deploy_get_value(ob1.z1.obs0.ip); 
let $port = deploy_get_value(ob1.z1.obs0.port); 
ob_connect(sys_conn, ob1.z2.obs0, root, , test, , USE_MYSQL_CONNECTOR);
connection sys_conn;
ob1.mysql alter system delete server '$ip:$port';
ob1.check_until_timeout select count(*) from __all_server, 2, 120;
ob1.z1.obs0.force_stop;
sleep 15;
ob_connect(tt1_conn, ob1.z2.obs0, root@tenant_1, , test, , USE_MYSQL_CONNECTOR);
connection tt1_conn;
select * from t;
ob1.z2.obs0.check_log_until_success -c "update location to be follower succes";
