#rs
#msy164651
#切换过程中，去掉configserver，保证all_cluster表的准确性
ob1=OBI(cluster = 1, proxy_num = 0);
ob2=OBI(cluster = 1, proxy_num = 0, leaderob=ob1);
ob1.reboot;
ob_connect(conn1, ob1.z1.obs0, root@sys, , oceanbase, , USE_OB_CONNECTOR);
connection conn1;
alter system set balancer_idle_time = '10s';
alter system set server_data_copy_out_concurrency = 30;
alter system set server_data_copy_in_concurrency = 30;
alter system set data_copy_concurrency = 60;
#在主库上创建一个租户
let $case_index = 1;
let $unit_num = 1;
let $locality = 'f@z1';
let $zone_list = 'z1';
source include/create_tenant_1.inc;
ob1.mysql alter system major freeze;
ob1.check_version 2;
ob2.reboot;
ob_connect(conn2, ob2.z1.obs0, root@sys, , oceanbase, , USE_OB_CONNECTOR);
connection conn2;
alter system set balancer_idle_time = '10s';
alter system set server_data_copy_out_concurrency = 30;
alter system set server_data_copy_in_concurrency = 30;
alter system set data_copy_concurrency = 60;
alter system set debug_sync_timeout = '100000s';
#检查备库同步完成
let $tenant_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name = 'tenant_1', tenant_id, 1);
ob1.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO STANDBY, 300;

#去掉configserver
ob1.mysql alter system set obconfig_url = 'test';
ob2.mysql alter system set obconfig_url = 'test';
sleep 4;

ob1.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO STANDBY, 100;
ob1.mysql alter system commit to switchover to physical standby;
ob2.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO PRIMARY, 20;
ob2.mysql  alter system commit to switchover to primary;
ob2.check_until_timeout select count(*) > 0 from oceanbase.__all_cluster where rs_list like "%\"Type\":\"PRIMARY\"%", 1, 20;
#二次切换
ob2.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO STANDBY, 100;
ob2.mysql alter system commit to switchover to physical standby;
ob1.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO PRIMARY, 20;
ob1.mysql  alter system commit to switchover to primary;
ob1.check_until_timeout select count(*) > 0 from oceanbase.__all_cluster where rs_list like "%\"Type\":\"PRIMARY\"%", 1, 20;
#三次切换
ob1.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO STANDBY, 100;
ob1.mysql alter system commit to switchover to physical standby;
ob2.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO PRIMARY, 20;
ob2.mysql  alter system commit to switchover to primary;
ob2.check_until_timeout select count(*) > 0 from oceanbase.__all_cluster where rs_list like "%\"Type\":\"PRIMARY\"%", 1, 20;

