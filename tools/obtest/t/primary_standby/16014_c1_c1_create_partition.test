#创建一个很多分区的表
connection conn11;
set ob_query_timeout = 300000000;
create table t1(c1 int , c2 int,c3 int ,primary key(c1,c2)) partition by range(c1) subpartition by hash(c2)  subpartitions 1111 (PARTITION p0 VALUES LESS THAN (1990), partition p1 values less than (4500));
alter table t1 add partition (partition p2 values less than(maxvalue));
insert into t1 values(1,1,1);
let $cut_scn = deploy_get_value(ob1.select select time_to_usec(now(6)) as scn, scn, 1);
ob1.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO STANDBY, 200;
sleep 10;
connection conn21;
set ob_query_timeout = 100000000;
select * from t1 where c1 = 1 and c2 =1;
connection conn11;

drop table t1;

#256个分区
connection conn11;
set ob_query_timeout = 300000000;
create table t1(c1 int , c2 int,c3 int ,primary key(c1,c2)) partition by hash(c1) partitions 256;
insert into t1 values(1,1,1);
ob1.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO STANDBY, 200;
sleep 10;
connection conn21;
set ob_query_timeout = 100000000;
select * from t1 where c1 = 1 and c2 =1;
connection conn11;

drop table t1;


#257分分区
connection conn11;
set ob_query_timeout = 300000000;
create table t1(c1 int , c2 int,c3 int ,primary key(c1,c2)) partition by hash(c1) partitions 257;
insert into t1 values(1,1,1);
ob1.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO STANDBY, 200;
sleep 10;
connection conn21;
set ob_query_timeout = 100000000;
select * from t1 where c1 = 1 and c2 =1;
connection conn11;

drop table t1;


#512个分区

connection conn11;
set ob_query_timeout = 300000000;
create table t1(c1 int , c2 int,c3 int ,primary key(c1,c2)) partition by hash(c1) partitions 512;
insert into t1 values(1,1,1);
ob1.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO STANDBY, 200;

sleep 10;
connection conn21;
ob2.check_until_timeout select current_scn > $cut_scn from oceanbase.__all_virtual_cluster, 1, 10;
sleep 10;
set ob_query_timeout = 100000000;
select * from t1 where c1 = 1 and c2 =1;
connection conn11;

drop table t1;


