#rs
#msy164651
#测试点：pg相关的迁移复制等和运维命令等
ob1=OBI(cluster = 1, proxy_num = 0);
ob2=OBI(cluster = 2:2:2, proxy_num = 0, leaderob=ob1);
ob1.reboot;
ob2.reboot;
ob1.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO STANDBY, 100;
#case 1 在主库上创建租户，带有空pg，带两张表的pg, 空tablegroup，带两张表的tablegroup，standalone的表
ob_connect(conn1, ob1.z1.obs0, root@sys, , oceanbase, , USE_OB_CONNECTOR);
connection conn1;
ob_connect(conn2, ob2.z1.obs0, root@sys, , oceanbase, , USE_OB_CONNECTOR);
connection conn2;
alter system set balancer_idle_time = '10s';
#在主库上创建一个租户
ob1.mysql CREATE RESOURCE POOL pool_1 UNIT = 'sys_unit_config', UNIT_NUM = 1, ZONE_LIST = ('z1');
ob1.mysql CREATE TENANT tt RESOURCE_POOL_LIST = ('pool_1'), primary_zone='z1' set ob_tcp_invited_nodes='%';
let $primary_schema_version = deploy_get_value(ob1.select select max(schema_version) as s from oceanbase.__all_ddl_operation, s, 1);
ob1.check_until_timeout select count(*) c from __all_virtual_server_schema_info where refreshed_schema_version = $primary_schema_version and tenant_id = 1, 1, 30;
let $primary_schema_version = deploy_get_value(ob1.select select max(schema_version) as s from oceanbase.__all_virtual_ddl_operation where tenant_id = 1001, s, 1);
ob1.check_until_timeout select count(*) c from __all_virtual_server_schema_info where refreshed_schema_version = $primary_schema_version and tenant_id = 1001, 1, 30;
ob_connect(conn3, ob1, root@tt, ,test, , USE_OB_CONNECTOR);
connection conn3;
create table t1(c1 int primary key);
insert into t1 values(1);
create tablegroup pg binding = true partition by hash partitions 10;
create table t2 (c1 int primary key, c2 int) tablegroup = pg partition by hash (c1) partitions 10;
create table t3 (c1 int primary key, c2 int) tablegroup = pg partition by hash (c1) partitions 10;
create tablegroup pg_empty binding = true partition by range (partition p0 values less than (10), partition p1 values less than (100));
create tablegroup tg;
create table t4 (c1 int primary key, c3 int) tablegroup = tg;
create tablegroup tg_empty;
create tablegroup pg1 binding = true partition by list (partition p0 values in (10,11), partition p1 values in (100));
create table t6 (c1 int primary key, c2 int) tablegroup = pg1 partition by list(c1) (partition p0 values in (10,11), partition p1 values in (100));
insert into t6 values(11,1),(100,1);
insert into t2 values(1,1),(2,2),(3,3);
insert into t3 values(1,1),(2,2),(3,3);
insert into t4 values(1,1),(2,2),(3,3);
##备库同步完成
let $primary_schema_version = deploy_get_value(ob1.select select max(schema_version) as s from oceanbase.__all_ddl_operation, s, 1);
ob2.check_until_timeout select count(*) from oceanbase.__all_ddl_operation where schema_version = $primary_schema_version, 1, 30;
ob2.mysql_p select unit_count from oceanbase.__all_resource_pool where tenant_id = 1001;
ob2.mysql alter resource pool __resource_pool_1001 unit_num = 2;

ob1.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO STANDBY, 1000;
# case 2: 在pg上做分区管理操作，确定可以继续同步
connection conn3;
alter tablegroup pg_empty drop partition p1;
alter tablegroup pg_empty add partition (partition p1 values less than(maxvalue));
alter tablegroup pg1 add partition (partition p2 values in (default));
insert into t6 values (1,1),(2,2);
alter tablegroup pg1 drop partition p2, p1;
alter tablegroup pg1 add partition (partition p2 values in (default));
insert into t6 values (12,1),(3,2);
ob1.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO STANDBY, 100;
#case 3: 操作pg，可以继续同步
connection conn3;
drop table t3;
drop table t1;
drop tablegroup pg_empty;
create table t5 (c1 int primary key, c3 int) tablegroup = tg;
create tablegroup pg_empty binding = true;
sleep 10;
ob1.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO STANDBY, 100;

#pg的迁移
connection conn2;
--disable_query_log
#删除pg所在的partition
let $pg_empty = deploy_get_value(ob1.select select tablegroup_id from oceanbase.__all_virtual_tablegroup where tablegroup_name = 'pg_empty', tablegroup_id, 1);
let $pg = deploy_get_value(ob1.select select tablegroup_id from oceanbase.__all_virtual_tablegroup where tablegroup_name = 'pg', tablegroup_id, 1);
let $src = deploy_get_value(ob2.select select concat(svr_ip,":",svr_port) as ip from oceanbase.__all_virtual_meta_table where table_id = $pg_empty, ip, 1);
eval alter system drop replica partition_id='0%0@$pg_empty' server = '$src';
let $src = deploy_get_value(ob2.select select concat(svr_ip,":",svr_port) as ip from oceanbase.__all_virtual_meta_table where table_id = $pg, ip, 1);
eval alter system drop replica partition_id='0%0@$pg' server = '$src';
sleep 50;
ob2.check_until_timeout select count(*) from oceanbase.__all_virtual_meta_table where table_id = $pg_empty, 3, 100;
#pg迁移
let $src = deploy_get_value(ob2.select select concat(svr_ip,":",svr_port) as ip from oceanbase.__all_virtual_meta_table where table_id = $pg_empty and zone = 'z3', ip, 1);
let $dest = deploy_get_value(ob2.select select concat(svr_ip,":",svr_port) addr from __all_server where concat(svr_ip,":",svr_port) != '$src' and zone = 'z3', addr,1);
eval alter system move replica  partition_id='0%0@$pg_empty' source = '$src' destination = '$dest'; 
ob2.check_until_timeout select count(*) from oceanbase.__all_virtual_meta_table where table_id = $pg_empty and concat(svr_ip,":",svr_port) = '$dest' and partition_id = 0, 1, 100;
let $src = deploy_get_value(ob2.select select concat(svr_ip,":",svr_port) as ip from oceanbase.__all_virtual_meta_table where table_id = $pg and zone = 'z1', ip, 1);
let $dest = deploy_get_value(ob2.select select concat(svr_ip,":",svr_port) addr from __all_server where concat(svr_ip,":",svr_port) != '$src' and zone = 'z1', addr,1);
eval alter system move replica  partition_id='0%0@$pg' source = '$src' destination = '$dest'; 
ob2.check_until_timeout select count(*) from oceanbase.__all_virtual_meta_table where table_id = $pg and concat(svr_ip,":",svr_port) = '$dest' and partition_id = 0, 1, 100;
--enable_query_log
#等待副本补齐
ob1.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO STANDBY, 100;
#stop zone 
let $tenant_id = deploy_get_value(ob1.select select tenant_id from __all_tenant where tenant_name ='tt', tenant_id,1);
connection conn2;
eval alter resource pool __resource_pool_$tenant_id unit_num = 1;
let $job_id =  deploy_get_value(ob2.select select job_id from oceanbase.__all_rootservice_job where job_type = 'SHRINK_RESOURCE_POOL_UNIT_NUM' , job_id, 1);
ob2.check_until_timeout select count(*) from oceanbase.__all_rootservice_job where job_id= $job_id and job_status = 'SUCCESS', 1, 12000;
#unit迁移太慢，还有tenant_exist问题
