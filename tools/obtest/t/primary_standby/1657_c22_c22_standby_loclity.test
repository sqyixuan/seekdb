ob2.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO STANDBY, 100;
alter system commit to switchover to physical standby;
ob1.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO PRIMARY, 100;
ob1.mysql alter system commit to switchover to primary;
connection tt_conn;
use test;
create table t11(c1 int primary key, c2 int) partition by hash (c1) partitions 10;
#在备库上有L副本的情况下，可以同步完成
ob1.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO STANDBY, 100;
#等新主库推一次schema version,备库之前作为主库执行了ddl操作，可能会导致备库上的schema version偏大
sleep 10;
# case 5：在备库上下掉L副本
connection conn2;
alter tenant tt set locality = 'f@z1,f@z2,f@z3';
let $job_id = deploy_get_value(ob2.select select max(job_id) as job_id from oceanbase.__all_rootservice_job where job_type = 'ALTER_TENANT_LOCALITY', job_id, 1);
alter system set enable_rebalance = true;
alter system set enable_rereplication = true;
connection conn2;
ob2.check_until_timeout select job_status from oceanbase.__all_rootservice_job where job_id = $job_id, SUCCESS, 100;



