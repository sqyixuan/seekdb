connection conn2;
#ob2.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO STANDBY, 10;
#set ob_global_debug_sync = 'AFTER_TENANT_BALANCE_GATHER_STAT wait_for continue_signal';
