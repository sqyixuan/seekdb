# owner: rongxuan.lc
# description: 本case是为了测试failover之后，所有其他集群的状态都会变成disable;
ob1=OBI(cluster=1, proxy_num = 0);
ob2=OBI(cluster=1, proxy_num = 0, leaderob=ob1);
ob3=OBI(cluster=1, proxy_num = 0, leaderob=ob1);
ob4=OBI(cluster=1, proxy_num = 0, leaderob=ob1);
ob5=OBI(cluster=1, proxy_num = 0, leaderob=ob1);

ob1.reboot;
ob2.reboot;
ob3.reboot;
ob4.reboot;
let $cpu = 1;
let $memory = 1073741824;
let $min_memory = 1073741824;
let $disk = 536870912;
let $iops = 100000;
let $session = 64;
let $case_index = 1;
ob_connect(conn2, ob2.z1.obs0, root, , oceanbase, , USE_MYSQL_CONNECTOR);
connection conn2;
source include/standby_sync_ddl.inc;
ob_connect(conn3, ob3.z1.obs0, root, , oceanbase, , USE_MYSQL_CONNECTOR);
connection conn3;
source include/standby_sync_ddl.inc;

ob1.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO STANDBY, 60;
ob_connect(sys1_conn, ob1.z1.obs0, root, , oceanbase, , USE_MYSQL_CONNECTOR);
connection sys1_conn;
set ob_query_timeout = 30000000;
eval CREATE RESOURCE UNIT unit_1 MAX_CPU $cpu, MAX_MEMORY $memory, MAX_IOPS $iops, MAX_DISK_SIZE $disk, MAX_SESSION_NUM $session, MIN_CPU=1, MIN_MEMORY=$min_memory, MIN_IOPS=128;
eval CREATE RESOURCE POOL pool_1 UNIT = 'unit_1', UNIT_NUM = 1, ZONE_LIST = ('z1');
eval CREATE TENANT tenant_$case_index RESOURCE_POOL_LIST = ('pool_1'), primary_zone='z1' set ob_tcp_invited_nodes='%';

ob1.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO STANDBY, 300;

##验证三个集群之间的信息相同
ob1.check_until_timeout select count(*) from __all_cluster where cluster_status = 1, 4, 10; 
ob2.check_until_timeout select count(*) from __all_cluster where cluster_status = 1, 4, 10; 
ob3.check_until_timeout select count(*) from __all_cluster where cluster_status = 1, 4, 10; 
ob4.check_until_timeout select count(*) from __all_cluster where cluster_status = 1, 4, 10; 

let $cluster_id = deploy_get_value(ob4.select select cluster_id from v\$ob_cluster, cluster_id, 1);
let $cluster_name = deploy_get_value(ob4.select select cluster_name from v\$ob_cluster, cluster_name, 1);
##删掉ob4
ob1.mysql alter system remove cluster '$cluster_name' cluster_id = $cluster_id;
ob4.force_stop;

##验证三个集群之间的信息相同
ob1.check_until_timeout select count(*) from __all_cluster where cluster_status = 1, 3, 10; 
ob2.check_until_timeout select count(*) from __all_cluster where cluster_status = 1, 3, 30; 
ob3.check_until_timeout select count(*) from __all_cluster where cluster_status = 1, 3, 30; 

ob_connect(sys1_conn, ob1.z1.obs0, root, , oceanbase, , USE_MYSQL_CONNECTOR);
connection sys1_conn;
set ob_query_timeout = 40000000;
ob2.check_until_timeout select count(*) from oceanbase.__all_virtual_replica_task, 0, 100;
ob1.check_until_timeout select count(*) from v\$ob_cluster where switchover_status='TO STANDBY', 1, 100;
alter system commit to switchover to physical standby;
ob_connect(sys2_conn, ob2.z1.obs0, root, , oceanbase, , USE_MYSQL_CONNECTOR);
connection sys2_conn;
set ob_query_timeout = 20000000;
ob2.check_until_timeout select count(*) from v\$ob_cluster where switchover_status='TO PRIMARY', 1, 60;
alter system commit to switchover to primary;
let $cluster_id = deploy_get_value(ob2.select select cluster_id from v\$ob_cluster, cluster_id, 1);
let $cluster_name = deploy_get_value(ob2.select select cluster_name from v\$ob_cluster, cluster_name, 1);
#同步到主库的心跳
ob1.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, NOT ALLOWED, 30;
ob1.check_until_timeout select cluster_status from oceanbase.v\$ob_cluster, VALID, 10;
ob2.force_stop;

###做一次failover
connection sys1_conn;
set ob_query_timeout = 1000000000;
alter system ACTIVATE PHYSICAL STANDBY CLUSTER;
ob1.check_until_timeout select count(*) from __all_cluster where cluster_status != 1, 2, 3;
#ob3.check_until_timeout select count(*) from __all_cluster where cluster_status != 1, 2, 15;
#删掉ob2;
ob1.mysql alter system remove cluster '$cluster_name' cluster_id = $cluster_id;
ob1.check_until_timeout select count(*) from oceanbase.__all_acquired_snapshot where snapshot_type = 2, 0, 300;
##ob3处于disable状态；不同步数据
ob5.reboot;
ob_connect(conn5, ob5.z1.obs0, root, , oceanbase, , USE_MYSQL_CONNECTOR);
connection conn5;
source include/standby_sync_ddl.inc;
ob1.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO STANDBY, 500;
ob1.check_until_timeout select count(*) from __all_cluster where cluster_status != 1, 1, 3;
ob1.check_until_timeout select count(*) from __all_cluster where cluster_status = 1, 2, 3;
ob5.check_until_timeout select count(*) from __all_cluster where cluster_status != 1, 1, 15;
ob5.check_until_timeout select count(*) from __all_cluster where cluster_status = 1, 2, 15;
