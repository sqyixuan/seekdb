# owner: wenduo.swd
# owner group: rs
# description: 测试复制表的locality
ob1=OBI(cluster=3:3:3,proxy_num=0,init_unit_cpu=0);
ob1.reboot;
sleep 10;

ob1.mysql alter system set enable_auto_leader_switch = "true";
ob1.mysql alter system set balancer_idle_time = '10s';

let $proxy_ip = deploy_get_value(ob1.z1.obs0.ip);
let $proxy_port = deploy_get_value(ob1.z1.obs0.mysql_port);

connect(sys_conn, $proxy_ip, root@sys,,oceanbase, $proxy_port);
connection sys_conn;

# create resource pool
ob1.mysql CREATE RESOURCE UNIT unit1 max_cpu 1, max_memory '1G', max_iops 100000,max_disk_size '10G', max_session_num 64, MIN_CPU=1, MIN_MEMORY='1G', MIN_IOPS=128;
ob1.mysql CREATE RESOURCE POOL tt_pool UNIT = "unit1", UNIT_NUM = 3, ZONE_LIST = ('z1', 'z2', 'z3');
# create tenant
ob1.mysql CREATE TENANT tt resource_pool_list=('tt_pool'), locality = "F@z1,F@z2,F@z3" set ob_tcp_invited_nodes='%';
sleep 3;
connect(tt_conn, $proxy_ip, root@tt,,test, $proxy_port);
# 创建两个复制表
connection tt_conn;
create table t1(c1 int, c2 int, primary key(c1,c2)) duplicate_scope = 'cluster';
create table t2(c1 int, c2 int, primary key(c1,c2)) locality = 'F,R@z1,F,R{all_server}@z2,F@z3', duplicate_scope = 'cluster';
create table t3(c1 int, c2 int, primary key(c1,c2));

connection sys_conn;
# 检查表的分区数
let $t1_id = deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where table_name = 't1', table_id, 1);
let $t2_id = deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where table_name = 't2', table_id, 1);
# t1表9个分区
ob1.check_until_timeout select count(*) c from oceanbase.__all_virtual_meta_table where table_id = $t1_id, 9, 360;
# t2表6个分区
ob1.check_until_timeout select count(*) c from oceanbase.__all_virtual_meta_table where table_id = $t2_id, 6, 360;

alter system set enable_rereplication = 'false';

let $t1_ip=deploy_get_value(ob1.select select svr_ip from oceanbase.__all_virtual_meta_table where table_id=$t1_id and replica_type=16 and zone='z1', svr_ip, 1);
let $t1_port=deploy_get_value(ob1.select select svr_port from oceanbase.__all_virtual_meta_table where table_id=$t1_id and replica_type=16 and zone='z1', svr_port, 1);
let $t2_ip=deploy_get_value(ob1.select select svr_ip from oceanbase.__all_virtual_meta_table where table_id=$t2_id and replica_type=16 and zone='z1', svr_ip, 1);
let $t2_port=deploy_get_value(ob1.select select svr_port from oceanbase.__all_virtual_meta_table where table_id=$t2_id and replica_type=16 and zone='z1', svr_port, 1);

eval alter system drop replica partition_id='0%0@$t1_id' server='$t1_ip:$t1_port';
eval alter system drop replica partition_id='0%0@$t2_id' server='$t2_ip:$t2_port';

# t1表9个分区
ob1.check_until_timeout select count(*) c from oceanbase.__all_virtual_meta_table where table_id = $t1_id, 8, 360;
# t2表6个分区
ob1.check_until_timeout select count(*) c from oceanbase.__all_virtual_meta_table where table_id = $t2_id, 5, 360;

# 开启补副本
alter system set enable_rereplication = 'true';
# t1表9个分区
ob1.check_until_timeout select count(*) c from oceanbase.__all_virtual_meta_table where table_id = $t1_id and status = 'REPLICA_STATUS_NORMAL', 9, 360;
# t2表6个分区
ob1.check_until_timeout select count(*) c from oceanbase.__all_virtual_meta_table where table_id = $t2_id and status = 'REPLICA_STATUS_NORMAL', 6, 360;

connection tt_conn;
drop table t2;
purge recyclebin;

connection sys_conn;
# 测试减locality
ALTER TENANT tt locality = "F@z1,F@z2";
ob1.check_until_timeout select count(*) c from oceanbase.__all_tenant where previous_locality != "", 0, 600;
# t1表6个分区
ob1.check_until_timeout select count(*) c from oceanbase.__all_virtual_meta_table where table_id = $t1_id and status = 'REPLICA_STATUS_NORMAL', 6, 360;

# 测试加locality
ALTER TENANT tt locality = "F@z1,F@z2,F@z3";
ob1.check_until_timeout select count(*) c from oceanbase.__all_tenant where previous_locality != "", 0, 600;
# t1表9个分区
ob1.check_until_timeout select count(*) c from oceanbase.__all_virtual_meta_table where table_id = $t1_id and status = 'REPLICA_STATUS_NORMAL', 9, 360;
