#rs
#msy164651
#验证备库创建partition的能力
ob1=OBI(cluster = 1, proxy_num = 0);
ob2=OBI(cluster = 1, proxy_num = 0, leaderob=ob1);
ob1.reboot;
ob_connect(conn1, ob1.z1.obs0, root@sys, , oceanbase, , USE_OB_CONNECTOR);
connection conn1;
#在主库上创建一个租户
let $case_index = 1;
let $unit_num = 1;
let $locality = 'f@z1';
let $zone_list = 'z1';
source include/create_tenant_1.inc;

let $tenant_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name = 'tenant_1', tenant_id, 1);
let $row_id = deploy_get_value(ob1.select select row_id from oceanbase.__all_core_table where table_name like "%schema_status%" and column_name ='tenant_id' and column_value = '$tenant_id', row_id, 1);

ob_connect(conn11, ob1.z1.obs0, root@tenant_1, , test, , USE_OB_CONNECTOR);
connection conn11;
#建表
create tablegroup test_tg binding true;
create table t2(c1 int) tablegroup test_tg;
create table t1(c1 int) tablegroup test_tg;

let $table_id = deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where table_name = 't1', table_id, 1);
connection conn1;
eval insert into __all_acquired_snapshot set gmt_create = now(6), snapshot_type = 1, snapshot_ts = 1, tenant_id = $tenant_id, table_id = $table_id, schema_version = 0;

connection conn11;
let $cnt = 1;
while ($cnt < 100)
{
  eval insert into t1 values($cnt);
  inc $cnt;
}
 
ob1.mysql alter system major freeze;
ob1.check_version 2;


while ($cnt < 200)
{
  eval insert into t1 values($cnt);
  inc $cnt;
}

ob1.mysql alter system major freeze;
ob1.check_version 3;

while ($cnt < 300)
{
  eval insert into t1 values($cnt);
  inc $cnt;
}

ob1.mysql alter system major freeze;
ob1.check_version 3;
 
while ($cnt < 300)
{
  eval insert into t1 values($cnt);
  inc $cnt;
}

ob1.mysql alter system major freeze;
sleep 50;
ob1.check_version 4;


ob2.reboot;
ob_connect(conn2, ob2.z1.obs0, root@sys, , oceanbase, , USE_OB_CONNECTOR);
connection conn2;
alter system set server_data_copy_out_concurrency = 40;
alter system set server_data_copy_in_concurrency = 40;
ob1.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO STANDBY, 300;




