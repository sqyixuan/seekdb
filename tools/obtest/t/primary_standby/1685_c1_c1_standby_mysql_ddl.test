#owner: msy164651
#owner group: rs
#description: 主备库mysql租户ddl的同步 

ob1=OBI(cluster=1, proxy_num = 0);
ob2=OBI(cluster=1, proxy_num = 0, leaderob=ob1);
ob1.reboot;
ob2.reboot;
ob1.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO STANDBY, 30;
ob1.mysql alter system set enable_sys_table_ddl = true;
ob2.mysql alter system set enable_sys_table_ddl = false;
ob_connect(conn2, ob2.z1.obs0, root@sys,,oceanbase,,USE_OB_CONNECTOR);
connection conn2;
source include/standby_sync_ddl.inc;
#租户相关
let $cpu = 1;
let $memory = 1073741824;
let $min_memory = 1073741824;
let $disk = 536870912;
let $iops = 100000;
let $session = 64;
#创建租户
ob1.mysql create resource unit test_resource_unit max_cpu $cpu, max_memory $memory, max_iops $iops, max_disk_size $disk, max_session_num $session, MIN_CPU=1, MIN_MEMORY=$min_memory, MIN_IOPS=128;
ob1.mysql create resource pool test_resource_pool1 unit = 'test_resource_unit', unit_num = 1, zone_list = ('z1');
ob1.mysql create tenant tt replica_num = 1, primary_zone='z1', locality='F@z1', resource_pool_list=('test_resource_pool1') set ob_tcp_invited_nodes='%';
let $tenant_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name = 'tt', tenant_id, 1);
#在备库中查询同步到租户的schema
ob2.check_until_timeout select count(*) from oceanbase.__all_tenant where tenant_id = $tenant_id, 1, 10;
ob2.mysql_p select tenant_id, tenant_name , primary_zone, locality from oceanbase.__all_tenant; 
ob1.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO STANDBY, 200;
ob_connect(conn1, ob1.z1.obs0, root@tt,,test,,USE_OB_CONNECTOR);
ob_connect(conn2, ob1.z1.obs0, root@tt,,test,,USE_OB_CONNECTOR);
set ob_read_consistency = 2;

#系统变量
#add system variable只在升级的时候使用，因为不插all_ddl_operation表，备库需要独立处理，否则同步不来
#modify sys variable
connection conn1;
set global ob_query_timeout = 100000000;
set global ob_query_timeout = 100000001;
ob1.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO STANDBY, 30;
connection conn2;
select value from oceanbase.__all_sys_variable where name = 'ob_query_timeout';

#create database
connection conn1;
create database msy;
create database msy1;
ob1.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO STANDBY, 30;
connection conn2;
use msy;
use msy1;

#create tablegroup
connection conn1;
create tablegroup tg  partition by hash partitions 10;
create tablegroup tg1 binding true;
ob1.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO STANDBY, 100;
drop tablegroup tg;
drop tablegroup tg1;
#create table
connection conn1;
set recyclebin = off; 
create tablegroup tg1 binding true;
create table t1(c1 int primary key, c2 int, c3 int) partition by hash(c1) partitions 10;
insert into t1 values(1,1,1);
create table t2(c1 int primary key, c2 int, c3 int) tablegroup='tg1';
ob1.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO STANDBY, 100;
drop table t2;
drop table t1;
drop tablegroup tg1;
set recyclebin = on;
#alter table 
connection conn1;
set recyclebin = off;
create table t1(c1 int primary key, c2 int, c3 int) partition by hash(c1) partitions 10;
alter table t1 add column c4 int;
ob1.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO STANDBY, 100;
drop table t1;
set recyclebin = on;
#alter database
connection conn1;
create tablegroup tg  partition by hash partitions 10;
create tablegroup tg1 binding true;
alter database msy tablegroup = tg;
alter database msy1 tablegroup = tg1;
ob1.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO STANDBY, 100;
#drop database
connection conn1;
drop database msy;
drop database msy1;
drop tablegroup tg;
drop tablegroup tg1;
ob1.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO STANDBY, 30;
#alter tablegroup
connection conn1;
set recyclebin = off;
create tablegroup tg  partition by hash partitions 10;
create table t1(c1 int primary key, c2 int, c3 int) partition by hash(c1) partitions 10;
alter tablegroup tg add table t1;
create table t3(c1 int primary key, c2 int, c3 int) partition by hash(c1) partitions 10;
alter tablegroup tg add table t3;
#alter tablegroup tg1 add table t2;
ob1.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO STANDBY, 100;
drop table t1;
drop table t3;
drop tablegroup tg;
set recyclebin = on;
#drop tablegroup
connection conn1;
create tablegroup tg1 binding true;
create table t2(c1 int primary key, c2 int, c3 int) tablegroup='tg1';
let $table_id = query_get_value(select table_id from oceanbase.__all_table_v2 where table_name = 't2', table_id, 1);
drop table t2;
let $obj_name = query_get_value(select object_name from oceanbase.__all_recyclebin where table_id = $table_id, object_name, 1);
--disable_query_log
eval purge table $obj_name;
--enable_query_log
drop tablegroup tg1;
ob1.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO STANDBY, 100;
#rename table
connection conn1;
set recyclebin = off;
create tablegroup tg  partition by hash partitions 10;
create table t1(c1 int primary key, c2 int, c3 int) partition by hash(c1) partitions 10;
rename table t1 to t11;
create table t2(c1 int primary key, c2 int, c3 int) tablegroup=tg partition by hash(c1) partitions 10;
rename table t2 to t1;
insert into t1 values (7,1,1);
ob1.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO STANDBY, 130;
drop table t1;
drop table t11;
drop tablegroup tg;
set recyclebin = on;
#truncate table
connection conn1;
create table t1(c1 int primary key, c2 int, c3 int) partition by hash(c1) partitions 10;
truncate table t1;
truncate table t1;
ob1.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO STANDBY, 100;
drop table t1;
#create index
connection conn1;
create table t1(c1 int primary key, c2 int, c3 int) partition by hash(c1) partitions 10;
create index il on t1(c2);
create index il1 on t1(c3);
ob1.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO STANDBY, 100;
#drop index
connection conn1;
drop index il on t1;
drop index il1 on t1;
ob1.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO STANDBY, 30;
drop table t1;
#flashback index
#暂时不单独使用
#purge index
#暂时不单独使用
#create table like
#不能使用，语法不支持
connection conn1;
create table t1(c1 int primary key, c2 int, c3 int) partition by hash(c1) partitions 10;
create table t2 like t1;
create table t4 like t1;
ob1.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO STANDBY, 100;
drop table t1;
drop table t2;
drop table t4;

#flashback table
#系统表不能删除
connection conn1;
create table t2(c1 int primary key, c2 int, c3 int) partition by hash(c1) partitions 10;
let $table_id = query_get_value(select table_id from oceanbase.__all_table_v2 where table_name = 't2', table_id, 1);
create index il on t2(c2);
create index ill on t2(c3) local;
drop table t2;
ob1.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO STANDBY, 100;
let $obj_name = query_get_value(select object_name from oceanbase.__all_recyclebin where table_id = $table_id, object_name, 1);
--disable_query_log
eval flashback table $obj_name to before drop;
--enable_query_log
ob1.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO STANDBY, 30;
#purge table
connection conn1;
drop table t2;
let $obj_name = query_get_value(select object_name from oceanbase.__all_recyclebin where table_id = $table_id, object_name, 1);
--disable_query_log
eval purge table $obj_name;
--enable_query_log
ob1.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO STANDBY, 30;
#flashback database
connection conn1;
create database msy;
let $db_id = query_get_value(select database_id from oceanbase.__all_database where database_name = 'msy', database_id, 1);
use msy;
create table t1(c1 int primary key, c2 int, c3 int);
create table t2(c1 int primary key, c2 int, c3 int);
create table t3(c1 int primary key, c2 int, c3 int);
create index il on t1(c2);
drop database msy;
let $obj_name = query_get_value(select object_name from oceanbase.__all_recyclebin where database_id = $db_id, object_name, 1);
--disable_query_log
eval flashback database $obj_name to before drop;
--enable_query_log
ob1.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO STANDBY, 100;

#purge database
connection conn1;
use oceanbase;
drop database msy;
let $obj_name = query_get_value(select object_name from oceanbase.__all_recyclebin where database_id = $db_id, object_name, 1);
--disable_query_log
eval purge database $obj_name;
--enable_query_log
ob1.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO STANDBY, 30;
connection conn2;
--error 1049
use msy;

#optimize table
connection conn1;
set recyclebin = off;
purge recyclebin;
use test;
optimize table t11;
optimize table t1;
optimize tenant tt;
ob1.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO STANDBY, 30;
ob1.mysql optimize tenant tt;
ob1.mysql optimize tenant all;
ob1.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO STANDBY, 30;

#create user
connection conn1;
create user 'u101' identified by 'pass1';
ob1.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO STANDBY, 30;
grant select on *.* to 'u101';
ob1.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO STANDBY, 30;
rename user 'u101' to 'u99'; 
ob1.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO STANDBY, 30;
alter user u99 identified by '99';
ob1.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO STANDBY, 30;
alter user u99 ACCOUNT LOCK;
ob1.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO STANDBY, 30;
alter user u99 ACCOUNT UNLOCK;
ob1.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO STANDBY, 30;
revoke drop on *.* from 'u99';
ob1.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO STANDBY, 30;
drop user 'u99';
ob1.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO STANDBY, 30;
#create alter drop outline
connection conn1;
create outline o1 on select 1;
#alter outline o1 add select * from t1;
ob2.check_until_timeout select count(*) from oceanbase.__all_virtual_user where user_name='u99', 0, 10;
#create drop utd
#create drop synonym
connection conn1;
create synonym syn1 for t1;
drop synonym syn1;
ob1.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO STANDBY, 30;
