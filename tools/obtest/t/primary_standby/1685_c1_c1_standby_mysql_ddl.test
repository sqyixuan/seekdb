ob1.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO STANDBY, 30;
#virtual
#run job
ob1.mysql alter system set enable_sys_table_ddl = false;
ob1.mysql alter system set enable_ddl = false;
ob1.mysql alter system run job 'STATISTIC_PRIMARY_ZONE_ENTITY_COUNT';
connection conn1;
let $schema_version = query_get_value(select max(schema_version) s from oceanbase.__all_ddl_operation, s, 1);
--disable_query_log
eval select operation_type from oceanbase.__all_ddl_operation where schema_version = $schema_version;
--enable_query_log
ob1.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO STANDBY, 30;
ob1.mysql alter system run job 'STATISTIC_PRIMARY_ZONE_ENTITY_COUNT';
--disable_query_log
eval select operation_type from oceanbase.__all_ddl_operation where schema_version > $schema_version;
--enable_query_log
ob1.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO STANDBY, 30;
let $schema_version = query_get_value(select max(schema_version) s from oceanbase.__all_ddl_operation, s, 1);
ob1.mysql alter system run job 'STATISTIC_PRIMARY_ZONE_ENTITY_COUNT';
ob1.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO STANDBY, 30;
--disable_query_log
eval select operation_type from oceanbase.__all_ddl_operation where schema_version > $schema_version;
--enable_query_log

ob1.mysql alter system set enable_ddl = true;
ob1.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO STANDBY, 30;
ob1.mysql alter system commit to switchover to physical standby;
ob2.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO PRIMARY, 30;
ob2.mysql alter system commit to switchover to primary;
sleep 10;
ob2.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO STANDBY, 30;
ob2.mysql alter system commit to switchover to physical standby;
ob1.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO PRIMARY, 30;
ob1.mysql alter system commit to switchover to primary;


