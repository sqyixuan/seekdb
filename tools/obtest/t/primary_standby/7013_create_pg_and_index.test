eval create tablegroup  tg_with_tb_range_hash binding = true partition by range subpartition by hash subpartitions 2 (partition p1 values less than (1000), partition p2 values less than (2000));
eval create table tb_in_pg_range_hash(c1 int, c2 int, c3 int, primary key(c1, c2)) tablegroup "tg_with_tb_range_hash" partition by range(c1) subpartition by hash(c2) subpartitions 2 (partition p1 values less than (1000), partition p2 values less than (2000));
eval create index  idx_in_pg_range_hash_local on  tb_in_pg_range_hash(c2) local;
eval create index  idx_in_pg_range_hash_global on  tb_in_pg_range_hash(c1, c3) partition by hash(c1) partitions 2;
 
eval create tablegroup  tg_logical_with_tb_basic binding=false;
eval create table tb_in_tg_basic(c1 int primary key, c2 int, c3 int) tablegroup "tg_logical_with_tb_basic";
eval create index  idx_in_tg_basic_local on  tb_in_tg_basic(c2) local;
eval create index  idx_in_tg_basic_global on  tb_in_tg_basic(c1, c3) partition by hash(c1) partitions 2;

eval create tablegroup  tg_logical_with_tb_range binding=false partition by range (partition p1 values less than (1000), partition p2 values less than (2000));
eval create table tb_in_tg_range(c1 int primary key, c2 int, c3 int) tablegroup "tg_logical_with_tb_range" partition by range(c1) (partition p1 values less than (1000), partition p2 values less than (2000));
eval create index  idx_in_tg_range_local on  tb_in_tg_range(c2) local;
eval create index  idx_in_tg_range_global on tb_in_tg_range(c1, c3) partition by hash(c1) partitions 2;
 
eval create tablegroup  tg_logical_with_tb_range_hash binding=false partition by range subpartition by hash subpartitions 2 (partition p1 values less than (1000), partition p2 values less than (2000));
eval create table tb_in_tg_range_hash(c1 int, c2 int, c3 int, primary key(c1, c2)) tablegroup "tg_logical_with_tb_range_hash" partition by range(c1) subpartition by hash(c2) subpartitions 2 (partition p1 values less than (1000), partition p2 values less than (2000));
eval create index  idx_in_tg_range_hash_local on  tb_in_tg_range_hash(c2) local;
eval create index  idx_in_tg_range_hash_global on  tb_in_tg_range_hash(c1, c3) partition by hash(c1) partitions 2;
 
