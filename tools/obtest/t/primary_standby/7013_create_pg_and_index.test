ob1=OBI(cluster=1:1:1,proxy_num=0);
ob2=OBI(cluster=1:1:1,leaderob=ob1,proxy_num=0);
ob1.reboot;
ob2.reboot;

ob_connect(tt2_conn, ob2.z1.obs0, root, , oceanbase, , USE_MYSQL_CONNECTOR);
connection tt2_conn;
source include/standby_sync_ddl.inc;
alter system set debug_sync_timeout = '1000s';

let $case_index = 1;
let $unit_num = 1;
let $locality = 'f@z1,f@z2,f@z3';
let $zone_list = 'z1','z2','z3';


ob1.mysql alter system set resource_hard_limit=900;
ob1.mysql alter system set resource_soft_limit=800;

let $cpu = 1;
let $memory = '1G';
let $min_memory = '1G';
let $disk = 536870912;
let $iops = 100000;

ob1.mysql CREATE RESOURCE UNIT unit_$case_index MAX_CPU $cpu, MAX_MEMORY $memory, MAX_IOPS $iops, MAX_DISK_SIZE $disk, MAX_SESSION_NUM 64, MIN_CPU=1, MIN_MEMORY=$min_memory, MIN_IOPS=128;
ob1.mysql CREATE RESOURCE POOL pool_$case_index UNIT = 'unit_$case_index', UNIT_NUM = $unit_num, ZONE_LIST = ($zone_list);
ob1.mysql CREATE TENANT tenant_$case_index RESOURCE_POOL_LIST = ('pool_$case_index'), locality=$locality;


--disable_warnings
--disable_query_log
--disable_result_log
sleep 5;
--error 0,1064
ob1.mysql alter tenant tenant_$case_index set variables ob_tcp_invited_nodes='%';
--enable_warnings
--enable_query_log
--enable_result_log

ob_connect(tt1_conn, ob1.z1.obs0, root@tenant_1, , test, , USE_MYSQL_CONNECTOR);
connection tt1_conn;

set ob_query_timeout=100000000;
set recyclebin='off';

#1. standalone partition

eval create table tb_basic(c1 int primary key, c2 int, c3 int);
eval create index  idx_basic_local on  tb_basic(c2);
eval create index  idx_basic_global on  tb_basic(c1, c3) partition by hash(c1) partitions 2;
 
eval create table tb_range(c1 int primary key, c2 int, c3 int) partition by range(c1) (partition p1 values less than (1000), partition p2 values less than (2000));
eval create index  idx_range_local on  tb_range(c2) local;
 
eval create table tb_range_hash(c1 int, c2 int, c3 int, primary key (c1, c2)) partition by range(c1) subpartition by hash(c2) subpartitions 2 (partition p1 values less than (1000), partition p2 values less than (2000));
eval create index  idx_range_hash_local on  tb_range_hash(c2) local;
 
#2. empty PG/tablegroup
eval create tablegroup  tg_basic binding = true;
eval create tablegroup  tg_range binding = true partition by range (partition p1 values less than (1000), partition p2 values less than (2000));
eval create tablegroup  tg_range_hash binding = true partition by range subpartition by hash subpartitions 2 (partition p1 values less than (1000), partition p2 values less than (2000));

eval create tablegroup  tg_logical_basic binding=false;
eval create tablegroup  tg_logical_range binding=false partition by range (partition p1 values less than (1000), partition p2 values less than (2000));
eval create tablegroup  tg_logical_range_hash binding=false partition by range subpartition by hash subpartitions 2 (partition p1 values less than (1000), partition p2 values less than (2000));
 
#3. PG with table
 
#3.1 PG/tablegroup to drop
eval create tablegroup  tg_with_tb_basic binding = true;
eval create table tb_in_pg_basic(c1 int primary key, c2 int, c3 int) tablegroup "tg_with_tb_basic";
eval create index  idx_in_pg_basic_local on  tb_in_pg_basic(c2) local;
eval create index  idx_in_pg_basic_global on  tb_in_pg_basic(c1, c3) partition by hash(c1) partitions 2;
 
eval create tablegroup  tg_with_tb_range binding = true partition by range (partition p1 values less than (1000), partition p2 values less than (2000));
