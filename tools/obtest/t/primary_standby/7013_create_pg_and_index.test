#4. drop schema
eval drop table tb_basic;
eval alter table tb_range drop partition p1;
eval alter table tb_range_hash drop partition p1;

eval drop tablegroup tg_basic;
eval alter tablegroup tg_range drop partition p1;
eval alter tablegroup tg_range_hash drop partition p1;

eval drop tablegroup tg_logical_basic;
eval alter tablegroup tg_logical_range drop partition p1;
eval alter tablegroup tg_logical_range_hash drop partition p1;

eval drop table tb_in_pg_basic;
eval drop tablegroup tg_with_tb_basic;
 
eval drop table tb_in_pg_range;
eval drop tablegroup tg_with_tb_range;
 
eval drop table tb_in_pg_range_hash;
eval drop tablegroup tg_with_tb_range_hash;
 
eval drop table tb_in_tg_basic;
eval drop tablegroup tg_logical_with_tb_basic;
 
eval drop table tb_in_tg_range;
eval drop tablegroup tg_logical_with_tb_range;
 
eval drop table tb_in_tg_range_hash;
