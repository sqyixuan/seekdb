# owner: rongxuan.lc
# description: 本case是为了测试快照接入后，租户schema未拷贝完而误认为可以切换
#  
#  负载均衡线程没有看到完整的tenant_schema导致误任务任务做完，后续负载均衡进入idle阶段；
#
##case 1:快照接入阶段回放出租户schema，等所有系统表分区都拷贝完以后挂起负载均衡，此时再刷新出来最新的schema
##case 2: 正常回放阶段，如果当前负载均衡任务正在执行，那么主库新建了一张表，备库回放线程回放到，wakeup balance, 但是balance正在做而且会在这是把状态设置成no_task; ====>这个阶段不会有问题，因为schema已经被推倒最新了。 除非此时更新了schema_status但是没有刷新schema


##case1:通过限制广播新的tenant_schema来保证只复制系统表
ob1=OBI(cluster=1,proxy_num=0);
ob2=OBI(cluster=1,leaderob=ob1,proxy_num=0);
ob1.reboot;

let $cpu = 1;
let $memory = 1073741824;
let $min_memory = 1073741824;
let $disk = 536870912;
let $iops = 100000;
let $session = 64;
let $case_index = 1;

ob_connect(sys1_conn, ob1.z1.obs0, root, , oceanbase, , USE_MYSQL_CONNECTOR);
connection sys1_conn;
set ob_query_timeout = 30000000;
eval  CREATE RESOURCE UNIT unit_1 MAX_CPU $cpu, MAX_MEMORY $memory, MAX_IOPS $iops, MAX_DISK_SIZE $disk, MAX_SESSION_NUM $session, MIN_CPU=1, MIN_MEMORY=$min_memory, MIN_IOPS=128;
eval  CREATE RESOURCE POOL pool_1 UNIT = 'unit_1', UNIT_NUM = 1, ZONE_LIST = ('z1');
eval  CREATE TENANT tenant_$case_index RESOURCE_POOL_LIST = ('pool_1'), primary_zone='z1' set ob_tcp_invited_nodes='%';
sleep 3;

ob_connect(tt1_conn, ob1.z1.obs0, root@tenant_1, , test, , USE_MYSQL_CONNECTOR);
connection tt1_conn;
create table t(c1 int primary key, c2 int) partition by hash(c1) partitions 6;

ob1.mysql alter system major freeze;
ob1.check_version 2;
ob1.mysql alter system major freeze;
ob1.check_version 3;
ob1.mysql alter system major freeze;
ob1.check_version 4;
ob2.reboot;
sleep 3;
ob_connect(tt2_conn, ob2.z1.obs0, root, , oceanbase, , USE_MYSQL_CONNECTOR);
connection tt2_conn;
sleep 3;
alter system set debug_sync_timeout = '100000s';
alter system set balancer_idle_time = '10s';
alter system set server_data_copy_out_concurrency = 30;
alter system set server_data_copy_in_concurrency = 30;
alter system set data_copy_concurrency = 60;
##卡住备库普通租户回放线程；
sleep 5;
ob2.mysql set ob_global_debug_sync = 'BEFORE_PROCESS_USER_SCHEMA wait_for signal';
let $table_count = deploy_get_value(ob1.select select count(*) c from __all_root_table, c, 1);
ob2.check_until_timeout select count(*) from __all_root_table where status = 'REPLICA_STATUS_NORMAL', $table_count, 240;
##卡住负载均衡线程；放开回放线程；
ob2.z1.obs0.check_rs_log_until_success -c "not new enough(target_version={tenant_id:1001";
ob2.mysql set ob_global_debug_sync = 'UNIT_BALANCE_BEFORE_PARTITION_BALANCE wait_for signal2';
sleep 5;
ob2.mysql set ob_global_debug_sync = 'now signal signal';
##等待schema version推上去；
let $schema = deploy_get_value(ob1.select select max(schema_version) version from __all_virtual_ddl_operation where tenant_id = 1001, version, 1);
ob2.check_until_timeout select column_value from __all_core_table where table_name like '%schema_status%'  and column_name = 'readable_schema_version' and row_id != 1, $schema, 60;
sleep 10;
###检查当前不能进行切换；
ob1.check_until_timeout select count(*) from v\$ob_cluster where switchover_status='TO STANDBY', 0, 10;
###唤醒负载均衡线程；
ob2.mysql set ob_global_debug_sync = 'now signal signal2';
ob1.check_until_timeout select count(*) from v\$ob_cluster where switchover_status='TO STANDBY', 1, 60;


####case 2: 正常回放期间，遇到建表wakeup可能不生效；
