#rs
#msy164651
#case 1:创建租户，同步完成switchover成功；
#case 2:在switching状态switchover成功；
#case 3:在switchin状态failover成功
#case 4:failover成功后，不物理flashback，应该失败掉
ob1=OBI(cluster = 2, proxy_num = 0);
ob2=OBI(cluster = 2, proxy_num = 0, leaderob=ob1);
ob1.reboot;
ob2.reboot;
ob_connect(conn1, ob1.z1.obs0, root@sys, , oceanbase, , USE_OB_CONNECTOR);
connection conn1;
alter system set balancer_idle_time = '10s';
alter system set server_data_copy_out_concurrency = 30;
alter system set server_data_copy_in_concurrency = 30;
alter system set data_copy_concurrency = 60;
ob_connect(conn2, ob2.z1.obs0, root@sys, , oceanbase, , USE_OB_CONNECTOR);
connection conn2;
#检查备库同步完成
ob1.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO STANDBY, 100;
#在主库上创建一个租户
ob1.mysql CREATE RESOURCE POOL pool_1 UNIT = 'sys_unit_config', UNIT_NUM = 2, ZONE_LIST = ('z1');
ob1.mysql CREATE TENANT tt RESOURCE_POOL_LIST = ('pool_1'), primary_zone='z1' set ob_tcp_invited_nodes='%';
ob1.mysql alter system major freeze;
##备库同步完成
let $primary_schema_version = deploy_get_value(ob1.select select max(schema_version) as s from oceanbase.__all_ddl_operation, s, 1);
ob2.check_until_timeout select count(*) from oceanbase.__all_ddl_operation where schema_version = $primary_schema_version, 1, 30;
let $partition_cnt = deploy_get_value(ob1.select select count(*) c from __all_root_table where tenant_id = 1001, c, 1);
ob1.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO STANDBY, 1000;
ob1.check_version 2;
ob2.check_version 2;
ob1.mysql set ob_query_timeout=30000000;

connection conn1;
alter system commit to switchover to physical standby;
ob2.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO PRIMARY, 20;
connection conn2;
alter system commit to switchover to primary;

#case 2

ob2.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO STANDBY, 100;
ob2.mysql alter system commit to switchover to physical standby;
ob2.mysql alter system commit to switchover to primary;

#case 3
connection conn2;
set ob_query_timeout = 10000000;
set ob_trx_timeout = 10000000;
set ob_trx_idle_timeout = 9000000000;
set autocommit = false;
--disable_all_result_log
select column_value from __all_core_table where table_name ="__all_global_stat" and column_name = 'snapshot_gc_ts' for update;
--enable_all_result_log
ob_connect(tt2_conn, ob2.z1.obs0, root@tt, , test, , USE_MYSQL_CONNECTOR);
connection tt2_conn;
let $tablenum=2;
source sql/init_table.sql;


ob2.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO STANDBY, 100;
ob2.mysql alter system commit to switchover to physical standby;
let $cluster_id = deploy_get_value(ob1.select select value from oceanbase.__all_virtual_sys_parameter_stat where name = 'cluster_id', value, 1);
ob1.force_stop;

ob2.mysql alter system activate physical standby cluster;
ob2.mysql_p select count(*) from oceanbase.__all_failover_info;
ob2.mysql_p select cluster_status from oceanbase.__all_cluster where cluster_id = $cluster_id;
let $cur_scn = deploy_get_value(ob2.select select standby_became_primary_scn from oceanbase.__all_virtual_cluster, standby_became_primary_scn, 1);
sleep 20;
ob1.z1.obs0.nstart -m disabled_cluster;
ob1.z1.obs1.nstart -m disabled_cluster;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_core_meta_table, 1, 100;
ob1.mysql alter system convert to physical standby;
ob1.check_until_timeout select count(*) from oceanbase.__all_server where status = 'ACTIVE', 2, 100;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_core_meta_table, 1, 100;
let $cluster_name = deploy_get_value(ob1.select select info from oceanbase.__all_zone where name = 'cluster', info, 1);
ob2.check_until_timeout select count(*) from oceanbase.__all_acquired_snapshot where snapshot_type = 2, 0, 200;
--disable_query_log
ob2.mysql alter system enable cluster synchronization '$cluster_name' cluster_id = $cluster_id;
--enable_query_log
ob2.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO STANDBY, 100;
ob2.mysql alter system commit to switchover to physical standby;
ob1.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO PRIMARY, 20;
ob1.mysql  alter system commit to switchover to primary;


