# ob1.check_until_timeout select status from oceanbase.__all_backup_validation_task_history where job_id = 1 and tenant_id = $backup_mysql_tenant_id, FINISHED, 10;
#


# test views
--disable_all_result_log
connection backup_sys_conn;
use test;
select *  from oceanbase.CDB_OB_BACKUP_ARCHIVELOG_SUMMARY;
select *  from oceanbase.CDB_OB_BACKUP_JOB_DETAILS;
select *  from oceanbase.CDB_OB_BACKUP_SET_DETAILS;
select *  from oceanbase.CDB_OB_BACKUP_SET_EXPIRED;
select *  from oceanbase.CDB_OB_BACKUP_PROGRESS;
select *  from oceanbase.CDB_OB_BACKUP_ARCHIVELOG_PROGRESS;
select *  from oceanbase.CDB_OB_BACKUP_CLEAN_HISTORY;
select *  from oceanbase.CDB_OB_BACKUP_TASK_CLEAN_HISTORY;
select *  from oceanbase.CDB_OB_RESTORE_PROGRESS;
select *  from oceanbase.CDB_OB_RESTORE_HISTORY;
select *  from oceanbase.CDB_OB_BACKUP_VALIDATION_JOB;
select *  from oceanbase.CDB_OB_BACKUP_VALIDATION_JOB_HISTORY;
select *  from oceanbase.CDB_OB_TENANT_BACKUP_VALIDATION_TASK;
select *  from oceanbase.CDB_OB_BACKUP_VALIDATION_TASK_HISTORY;
select *  from oceanbase.CDB_OB_BACKUP_SET_OBSOLETE;
select *  from oceanbase.CDB_OB_BACKUP_BACKUPSET_JOB;
select *  from oceanbase.CDB_OB_BACKUP_BACKUPSET_JOB_HISTORY;
select *  from oceanbase.CDB_OB_BACKUP_BACKUPSET_TASK;
select *  from oceanbase.CDB_OB_BACKUP_BACKUPSET_TASK_HISTORY;
select *  from oceanbase.CDB_OB_BACKUP_BACKUP_ARCHIVELOG_SUMMARY;
select *  from oceanbase.CDB_OB_BACKUP_PIECE_FILES;
select *  from oceanbase.CDB_OB_BACKUP_SET_FILES;
select *  from oceanbase.CDB_OB_BACKUP_BACKUPPIECE_JOB;
select *  from oceanbase.CDB_OB_BACKUP_BACKUPPIECE_JOB_HISTORY;
select *  from oceanbase.CDB_OB_BACKUP_BACKUPPIECE_TASK;
select *  from oceanbase.CDB_OB_BACKUP_BACKUPPIECE_TASK_HISTORY;
select *  from oceanbase.CDB_OB_BACKUP_ARCHIVELOG;
select *  from oceanbase.CDB_OB_BACKUP_BACKUP_ARCHIVELOG;
--enable_all_result_log

# do restore oracle
ob2.reboot;
connect(restore_sys_conn, $restore_ip, root@sys,,oceanbase, $restore_port);
connection restore_sys_conn;
source sql/physical_backup/prepare_single_zone_resource.sql;
ob2.mysql alter system set enable_async_syslog=false;

ob2.check_until_timeout select column_value > (time_to_usec('$restore_checkpoint2') + 10 * 1000 * 1000) from __all_core_table where column_name = 'snapshot_gc_ts', 1, 60;

ob2.mysql alter system restore $restore_oracle_tenant_new from $backup_oracle_tenant at '$backup_dest' until '$restore_checkpoint1' with 'backup_cluster_name=$backup_cluster_name&backup_cluster_id=$backup_cluster_id&pool_list=small_pool_1&locality=F@z1&primary_zone=z1';
ob2.check_until_timeout select status from CDB_OB_RESTORE_HISTORY where tenant_name = '$restore_oracle_tenant_new', RESTORE_SUCCESS, 360;
ob2.check_until_timeout select status from __all_tenant where tenant_name = '$restore_oracle_tenant_new', TENANT_STATUS_NORMAL, 90;

let $restore_oracle_tenant_id = query_get_value(select tenant_id from oceanbase.__all_tenant where tenant_name='$restore_oracle_tenant_new', tenant_id, 1);
let $table_count = `select count(1) from oceanbase.__all_virtual_table where tenant_id = $restore_oracle_tenant_id and data_table_id = 0`;

ob_connect(restore_oracle_conn, ob2,TEST@$restore_oracle_tenant_new,test,test,,USE_OB_CONNECTOR);
let $i=1;
while ($i <= $table_count)
{
  eval select * from t$i order by 1,2;
  eval show create table t$i;
  inc $i;
}

connection restore_sys_conn;
ob2.mysql alter system minor freeze tenant $restore_oracle_tenant_new;
let $tablegroup_id = `select tablegroup_id from oceanbase.__all_virtual_tablegroup where tablegroup_name='tg1' and tenant_id=$restore_oracle_tenant_id`;
ob2.check_until_timeout select count(1) from __all_virtual_table_mgr where table_id=$tablegroup_id and partition_id=0 and is_active=0 and table_type=0, 0, 120;

ob2.mysql drop tenant $restore_oracle_tenant_new force;
sleep 10;

ob2.mysql alter system restore $restore_oracle_tenant from $backup_oracle_tenant at '$backup_dest' until '$restore_checkpoint2' with 'backup_cluster_name=$backup_cluster_name&backup_cluster_id=$backup_cluster_id&pool_list=small_pool_1&locality=F@z1&primary_zone=z1';
ob2.check_until_timeout select status from CDB_OB_RESTORE_HISTORY where tenant_name = '$restore_oracle_tenant', RESTORE_SUCCESS, 360;
ob2.check_until_timeout select status from __all_tenant where tenant_name = '$restore_oracle_tenant', TENANT_STATUS_NORMAL, 90;
let $restore_oracle_tenant_id = query_get_value(select tenant_id from oceanbase.__all_tenant where tenant_name='$restore_oracle_tenant', tenant_id, 1);
let $table_count = `select count(1) from oceanbase.__all_virtual_table where tenant_id = $restore_oracle_tenant_id and data_table_id = 0`;

# 验证基线生效索引被重新调度的bugfix，预期只有一行
select index_type, index_status from oceanbase.__all_virtual_table_history where table_name like "%NEW_I21%" order by schema_version;

ob_connect(restore_oracle_conn, ob2,TEST@$restore_oracle_tenant,test,test,,USE_OB_CONNECTOR);
let $i=1;
while ($i <= $table_count)
{
  eval select * from t$i order by 1,2;
  eval show create table t$i;
  inc $i;
}


ob2.mysql alter system restore $restore_mysql_tenant from $backup_mysql_tenant at '$backup_dest' until '$restore_checkpoint2' with 'backup_cluster_name=$backup_cluster_name&backup_cluster_id=$backup_cluster_id&pool_list=small_pool_2&locality=F@z1&primary_zone=z1';
ob2.check_until_timeout select status from CDB_OB_RESTORE_HISTORY where tenant_name = '$restore_mysql_tenant', RESTORE_SUCCESS, 360;
ob2.check_until_timeout select status from __all_tenant where tenant_name = '$restore_mysql_tenant', TENANT_STATUS_NORMAL, 90;
connect(restore_mysql_conn, $restore_ip,root@$restore_mysql_tenant,,oceanbase, $restore_port);
use backup_db;
select * from t1;
select * from t2;

ob3.reset;
ob3.deploy;
ob3.bootstrap;

ob_connect(conn3, ob3.z1.obs0, root@sys, ,oceanbase, , USE_OB_CONNECTOR);
connection conn3;
let $cluster_id = query_get_value(select value from __all_virtual_sys_parameter_stat where name = 'cluster_id', cluster_id, 1);
let $cluster_name = query_get_value(select value from __all_virtual_sys_parameter_stat where name = 'cluster', cluster_name, 1);
ob_connect(conn2, ob2.z1.obs0, root@sys, ,oceanbase, , USE_OB_CONNECTOR);
connection conn2;

# can not add standby when has restore tenant before major freeze
--disable_query_log
--error 4709
eval alter system add cluster '$cluster_name' cluster_id = $cluster_id;
--enable_query_log

--error 4709
eval ALTER SYSTEM ADD CLUSTER VERIFY;

# wait freeze finished
ob2.mysql alter system major freeze;
ob2.check_until_timeout select count(*) from oceanbase.__all_zone where name = 'last_merged_version' and value =2, 2, 200;

ob_connect(conn2, ob2.z1.obs0, root@sys, ,oceanbase, , USE_OB_CONNECTOR);
connection conn2;
--disable_query_log
eval ALTER SYSTEM REMOVE CLUSTER '$cluster_name'  CLUSTER_ID = $cluster_id;
--enable_query_log

ob3.force_stop;
ob3.reboot;

ob2.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO STANDBY, 60;
ob2.check_until_timeout select synchronization_status from oceanbase.v\$ob_standby_status, OK, 60;

ob2.mysql_p select cluster_role,cluster_status,protection_level,synchronization_status from oceanbase.__all_virtual_standby_status;
ob2.mysql_p select cluster_role, cluster_status, switchover_status, switchover_info, protection_mode, protection_level from oceanbase.__all_virtual_cluster;

# can add standby cluster
ob2.mysql ALTER SYSTEM ADD CLUSTER VERIFY;
