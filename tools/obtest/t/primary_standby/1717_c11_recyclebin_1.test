#owner: zhengshi
#owner group: rs
#功能：租户级回收站主备同步

#case 5
#备库自主发起的purge recyclebin操作，删掉回收站中除了TENANT类型以外的所有类型

#case 6
#备库禁止自主发起drop tenant、flashback tenant、purge tenant操作

ob1=OBI(cluster=1, proxy_num = 0);
ob2=OBI(cluster=1, proxy_num = 0, leaderob=ob1);

ob1.reboot;
ob2.reboot;
ob_connect(conn1, ob1.z1.obs0, root@sys, , oceanbase, , USE_OB_CONNECTOR);
connection conn1;
ob_connect(conn2, ob2.z1.obs0, root@sys, , oceanbase, , USE_OB_CONNECTOR);
connection conn2;

let $cpu = 1;
let $memory = 1073741824;
let $min_memory = 1073741824;
let $disk = 536870912;
let $iops = 100000;
let $session = 64;
let $case_index = 1;

ob1.mysql CREATE RESOURCE UNIT unit_1 MAX_CPU $cpu, MAX_MEMORY $memory, MAX_IOPS $iops, MAX_DISK_SIZE $disk, MAX_SESSION_NUM $session, MIN_CPU=1, MIN_MEMORY=$min_memory, MIN_IOPS=128;

#case 5 purge  recyclebin 备库自动发起

#在主库上创建一个租户
ob1.mysql CREATE RESOURCE POOL pool_10 UNIT = 'unit_1', UNIT_NUM = 1, ZONE_LIST = ('z1');
ob1.mysql CREATE TENANT t10 RESOURCE_POOL_LIST = ('pool_10'), primary_zone='z1' set ob_tcp_invited_nodes='%';
let $primary_schema_version = deploy_get_value(ob1.select select max(schema_version) as s from oceanbase.__all_ddl_operation, s, 1);
ob1.check_until_timeout select count(*) c from __all_ddl_operation where schema_version = $primary_schema_version and tenant_id = 1, 1, 30;


#登陆备库查询
ob2.check_until_timeout select count(*) c from __all_ddl_operation where schema_version >= $primary_schema_version and tenant_id = 1, 1, 30;

connection conn1;
set global recyclebin = on;
connection conn2;
set global recyclebin = on;

let $t10 = deploy_get_value(ob1.select select tenant_id from __all_tenant where tenant_name = 't10', tenant_id, 1); 

ob1.mysql DROP TENANT t10;

ob1.check_until_timeout select count(*) from __all_recyclebin where tenant_id = $t10, 1, 10;
ob1.check_until_timeout select count(*) from __all_tenant where tenant_name = 't10', 0, 10;


#检查备库是否同步
let $primary_schema_version = deploy_get_value(ob1.select select max(schema_version) as s from oceanbase.__all_ddl_operation, s, 1);
ob1.check_until_timeout select count(*) c from __all_ddl_operation where schema_version = $primary_schema_version and tenant_id = 1, 1, 30;
ob2.check_until_timeout select count(*) c from __all_ddl_operation where schema_version >= $primary_schema_version and tenant_id = 1, 1, 30;
sleep 5;

ob2.mysql PURGE RECYCLEBIN;

ob2.check_until_timeout select count(*) from oceanbase.__all_tenant where tenant_id = $t10 and status = 'TENANT_STATUS_DROPPING', 0, 30;
ob2.check_until_timeout select count(*) from oceanbase.__all_recyclebin where tenant_id = $t10, 1, 30;


#case 6 禁止ddl
#在主库上创建一个租户
ob1.mysql CREATE RESOURCE POOL pool_11 UNIT = 'unit_1', UNIT_NUM = 1, ZONE_LIST = ('z1');
ob1.mysql CREATE TENANT t11 RESOURCE_POOL_LIST = ('pool_11'), primary_zone='z1' set ob_tcp_invited_nodes='%';
let $primary_schema_version = deploy_get_value(ob1.select select max(schema_version) as s from oceanbase.__all_ddl_operation, s, 1);
ob1.check_until_timeout select count(*) c from __all_ddl_operation where schema_version = $primary_schema_version and tenant_id = 1, 1, 30;


#登陆备库查询
ob2.check_until_timeout select count(*) c from __all_ddl_operation where schema_version >= $primary_schema_version and tenant_id = 1, 1, 30;

connection conn2;
set global recyclebin = on;

--error 4179
DROP TENANT t11;

--error 4179
FLASHBACK TENANT t11 to before drop;

--error 4179
PURGE TENANT t11;



