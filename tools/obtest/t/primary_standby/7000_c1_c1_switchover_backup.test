#rs
#zbf
#开启备份，主库显示PRIMARY CLUSTER DOING BACKUP，不能进行切换
ob1=OBI(cluster=1, proxy_num = 0);
ob2=OBI(cluster=1, proxy_num = 0, leaderob=ob1);

ob1.reboot;
ob2.reboot;

ob1.check_until_timeout select switchover_status from oceanbase.__all_virtual_cluster, TO STANDBY, 30;
#检查
ob1.mysql_p select cluster_id,cluster_role,switchover_status, switchover_info from oceanbase.__all_virtual_cluster;
ob2.mysql_p select cluster_id,cluster_role,switchover_status, switchover_info from oceanbase.__all_virtual_cluster;
#开启备份
let $backup_dest = deploy_get_value(ob1.get_backup_dest);
ob1.clean_backup_dest;
ob1.mysql alter system set backup_dest='$backup_dest';
ob1.mysql alter system archivelog;
ob1.mysql_p select cluster_id,cluster_role,switchover_status, switchover_info from oceanbase.__all_virtual_cluster;
ob2.mysql_p select cluster_id,cluster_role,switchover_status, switchover_info from oceanbase.__all_virtual_cluster;


#切换报错
ob_connect(conn1, ob1.z1.obs0, root@sys, ,oceanbase, , USE_OB_CONNECTOR);
connection conn1;
--error 9036
alter system COMMIT TO SWITCHOVER TO PHYSICAL STANDBY;
--error 9036
alter system convert to physical standby;
--error 9036
alter system activate physical standby cluster; 
