# owner: rongxuan.lc
# description: 本case是为了统一测试主库和备库部分容灾过程；
#主库容灾：server 临时下线；永久下线；RS和OBS网络分区；网络阻塞；迁移：系统表或者用户表迁移；合并中迁移，主备库版本不同情况下的迁移；或者复制
#备库容许，同上；
#拆分成t/primary_standby/14004_c111_c111_p0_disaster.test和当前case;
##本case主要和合并交叉；
###备库拷贝进来高版本；合并期间发生迁移；

ob1=OBI(cluster=1:2:1,proxy_num=1);
ob2=OBI(cluster=1:2:1,leaderob=ob1,proxy_num=0);
ob1.reboot;
sleep 3;
ob2.reboot;
let $cpu = 1;
let $memory = 1073741824;
let $min_memory = 1073741824;
let $disk = 536870912;
let $iops = 100000;
let $session = 64;
let $case_index = 1;

ob_connect(sys_conn, ob1.z1.obs0, root, , oceanbase, , USE_MYSQL_CONNECTOR);
connection sys_conn;
set ob_query_timeout = 30000000;
ob1.mysql CREATE RESOURCE UNIT unit_1 MAX_CPU $cpu, MAX_MEMORY $memory, MAX_IOPS $iops, MAX_DISK_SIZE $disk, MAX_SESSION_NUM $session, MIN_CPU=1, MIN_MEMORY=$min_memory, MIN_IOPS=128;
ob1.mysql CREATE RESOURCE POOL pool_1 UNIT = 'unit_1', UNIT_NUM = 1, ZONE_LIST = ('z1', 'z2', 'z3');
eval CREATE TENANT tenant_$case_index RESOURCE_POOL_LIST = ('pool_1'), primary_zone='z1' set ob_tcp_invited_nodes='%';
sleep 3;

ob_connect(tt1_conn, ob1.z1.obs0, root@tenant_1, , test, , USE_MYSQL_CONNECTOR);
connection tt1_conn;
create table t(c1 int primary key, c2 int) partition by hash(c1) partitions 5;
ob_connect(tt2_conn, ob2.z1.obs0, root, , oceanbase, , USE_MYSQL_CONNECTOR);
connection tt2_conn;
source include/standby_sync_ddl.inc;
###case 1: 主库合并完成后，再发起合并；
ob1.mysql alter system major freeze;
ob1.mysql alter system major freeze;
ob1.check_until_timeout select value from __all_zone where name = "last_merged_version" and zone = 'z2', 2, 400;
ob1.check_until_timeout select value from __all_zone where name = "last_merged_version" and zone = 'z2', 3, 400;
ob1.check_until_timeout select count(*) from v\$ob_cluster where switchover_status='TO STANDBY', 1, 600;
ob2.check_until_timeout select value from __all_zone where name = 'last_merged_version' and zone = '', 3, 400;

###cae2: 高版本机器宕机触发复制；
ob1.mysql alter system set server_permanent_offline_time = '20s';
ob2.mysql alter system set server_permanent_offline_time = '20s';
ob1.mysql alter system major freeze;
ob1.check_until_timeout select count(*)>0 from __all_freeze_schema_version where frozen_version = 4, 1, 30;
ob1.check_until_timeout select value from __all_zone where name = 'global_broadcast_version' and zone = '', 4, 30;
ob1.mysql alter system start merge zone 'z2';
ob2.check_until_timeout select count(*)>0 from __all_freeze_schema_version where frozen_version = 4, 1, 10;
ob2.check_until_timeout select value from __all_zone where name = 'global_broadcast_version' and zone = '', 4, 30;
ob2.mysql alter system start merge zone 'z2';
ob1.check_until_timeout select value from __all_zone where name = "last_merged_version" and zone = 'z2', 4, 400;
ob2.check_until_timeout select value from __all_zone where name = "last_merged_version" and zone = 'z2', 4, 400;

##把z2的一个机器当掉；
let $dest = deploy_get_value(ob1.select select concat(svr_ip, ":", svr_port) svr from __all_unit where zone = 'z2', svr, 1);
let $obs = deploy_get_value(ob1.get_obs_by_addr $dest);
$obs.force_stop;
let $dest = deploy_get_value(ob2.select select concat(svr_ip, ":", svr_port) svr from __all_unit where zone = 'z2', svr, 1);
let $obs = deploy_get_value(ob2.get_obs_by_addr $dest);
$obs.force_stop;
##等待迁移
ob1.check_until_timeout select count(*)>0 from __all_unit where migrate_from_svr_ip != '', 1, 60;
ob2.check_until_timeout select count(*)>0 from __all_unit where migrate_from_svr_ip != '', 1, 60;

ob1.check_until_timeout select count(*)>0 from __all_unit where migrate_from_svr_ip != '', 0, 1200;
ob2.check_until_timeout select count(*)>0 from __all_unit where migrate_from_svr_ip != '', 0, 1200;
ob1.check_until_timeout select value from __all_zone where name = "last_merged_version" and zone = '', 4, 180;
ob2.check_until_timeout select value from __all_zone where name = "last_merged_version" and zone = '', 4, 180;

