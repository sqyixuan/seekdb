# owner: msy164651 
# description: 本case是为了复现failover后crc的问题，并且保证修复的正确性

ob1=OBI(cluster=1,proxy_num=0);
ob2=OBI(cluster=1:1,leaderob=ob1,proxy_num=0);
ob1.reboot;
ob2.reboot;
let $case_index = 1;
let $unit_num = 1;
let $locality = 'f@z1';
let $zone_list = 'z1';
source include/create_tenant_1.inc;

ob_connect(tt1_conn, ob1.z1.obs0, root@tenant_1, , test, , USE_MYSQL_CONNECTOR);
connection tt1_conn;
create table t(c1 int primary key, c2 int, c3 int);
create table t1(c1 int primary key, c2 int, c3 int);
create tablegroup pg binding = true;
create tablegroup pg1 binding = true;
create table t2(c1 int primary key, c2 int, c3 int) tablegroup = 'pg1';
insert into t values (1,1,1);
select * from t;
ob_connect(tt2_conn, ob2.z1.obs0, root, , oceanbase, , USE_MYSQL_CONNECTOR);
connection tt2_conn;
source include/standby_sync_ddl.inc;
alter system set debug_sync_timeout = '1000s';

ob1.check_until_timeout select switchover_status from oceanbase.__all_virtual_cluster, TO STANDBY, 500;
ob2.mysql set global ob_query_timeout = 100000000;
let $table_id = deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where table_name = 't', table_id, 1);
sleep 10;
#卡住gc点的推进
ob2.mysql set ob_global_debug_sync = 'BLOCK_FREEZE_INFO_UPDATE wait_for signal';
connection tt1_conn;
update t set c2 = 2 where c1 = 1;
update t set c2 = 3 where c1 = 1;
ob1.check_until_timeout select switchover_status from oceanbase.__all_virtual_cluster, TO STANDBY, 50;
ob_connect(tt2_conn, ob2.z1.obs0, root@tenant_1, , test, , USE_MYSQL_CONNECTOR);
connection tt2_conn;
sleep 3;
select /*+ read_consistency(weak)*/* from t;
#宕机主备库

ob1.force_stop;
ob2.force_stop;
sleep 10;
ob2.start;
ob2.check_until_timeout select count(*) from oceanbase.__all_server where status = 'active', 2, 200;
ob2.check_until_timeout select count(*) from oceanbase.__all_virtual_core_meta_table, 2, 100;
ob2.mysql set ob_global_debug_sync = 'BEFORE_DO_MINOR_FREEZE wait_for signal';
ob2.check_until_timeout select count(*) from oceanbase.__all_server where start_service_time >0 , 2, 600;
ob2.mysql alter system set _mini_merge_concurrency = 16;
ob2.mysql alter system set _ob_minor_merge_schedule_interval = '3s';
ob_connect(conn2, ob2.z1.obs0, root@sys, ,oceanbase, , USE_OB_CONNECTOR);
connection conn2;
set ob_query_timeout=1000000000;
ALTER SYSTEM ACTIVATE PHYSICAL STANDBY CLUSTER;
ob2.mysql alter system set _mini_merge_concurrency = 3;
ob2.mysql alter system set _ob_minor_merge_schedule_interval = '20s';
sleep 20;
ob_connect(tt2_conn, ob2.z1.obs0, root@tenant_1, , test, , USE_MYSQL_CONNECTOR);
connection tt2_conn;
update t set c3 = 2 where c1 = 1;
update t set c3 = 4 where c1 = 1;
update t set c3 = 5 where c1 = 1;
update t set c3 = 6 where c1 = 1;
update t set c3 = 7 where c1 = 1;
update t set c3 = 8 where c1 = 1;
update t set c3 = 9 where c1 = 1;
update t set c3 = 10 where c1 = 1;
update t set c3 = 11 where c1 = 1;
update t set c3 = 12 where c1 = 1;
select * from t;

ob2.check_until_timeout  select value from oceanbase.__all_zone where name='last_merged_version' and zone = '', 2, 600;
ob2.check_until_timeout select count(*) from oceanbase.__all_acquired_snapshot where snapshot_type = 2, 0, 300;
connection tt2_conn;
select * from t;
ob2.mysql set ob_global_debug_sync = 'now signal signal';
#发起一轮转储
let $ft = deploy_get_value(ob2.select select column_value from oceanbase.__all_core_table where table_name like "%freeze%" and row_id = 2 and column_name like "%timestamp%", column_value, 1);
ob2.check_until_timeout select count(*) from oceanbase.__all_virtual_table_mgr where table_id = $table_id and table_type = 7 and base_version >= $ft, 2, 100;
sleep 30;
connection tt2_conn;
select * from t;

