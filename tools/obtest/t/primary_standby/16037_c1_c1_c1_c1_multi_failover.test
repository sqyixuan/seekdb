#接入D集群
ob4=OBI(cluster=1,leaderob=ob1,proxy_num=0);
ob4.reboot;
ob_connect(conn4, ob4.z1.obs0, root, , oceanbase, , USE_MYSQL_CONNECTOR);
connection conn4;
source include/standby_sync_ddl.inc;

ob1.check_until_timeout select switchover_status from oceanbase.__all_virtual_cluster, TO STANDBY, 500;
ob4.mysql set global ob_query_timeout = 100000000;

ob4.mysql_p select count(*) from oceanbase.__all_failover_info;
#failover D集群
ob2.force_stop;
ob1.force_stop;
ob4.mysql alter system set _mini_merge_concurrency = 16;
ob4.mysql alter system set _ob_minor_merge_schedule_interval = '3s';
ob4.mysql alter system ACTIVATE PHYSICAL STANDBY CLUSTER;
ob4.mysql alter system set _mini_merge_concurrency = 3;
ob4.mysql alter system set _ob_minor_merge_schedule_interval = '20s';

