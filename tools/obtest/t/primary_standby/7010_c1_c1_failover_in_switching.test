#rs
#zbf
ob1=OBI(cluster=1, proxy_num = 0);
ob2=OBI(cluster=1, proxy_num = 0, leaderob=ob1);
ob3=OBI(cluster=1, proxy_num = 0, leaderob=ob1);
ob4=OBI(cluster=1, proxy_num = 0, leaderob=ob1);

ob1.reboot;
ob2.reboot;
ob_connect(conn2, ob2.z1.obs0, root@sys, ,oceanbase, , USE_OB_CONNECTOR);
connection conn2;
source include/standby_sync_ddl.inc;

ob1.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO STANDBY, 60;
let $cluster_name = deploy_get_value(ob2.select select info from oceanbase.__all_zone where name = 'cluster', info, 1);
let $cluster_id = deploy_get_value(ob2.select select value from oceanbase.__all_virtual_sys_parameter_stat where name = 'cluster_id', value, 1);
ob1.mysql alter system modify cluster '$cluster_name' cluster_id $cluster_id set redo_transport_options='SYNC'; 
let $cluster_id = deploy_get_value(ob2.select select value from oceanbase.__all_virtual_sys_parameter_stat where name = 'cluster_id', value, 1);
#设置主库为强同步
ob1.mysql alter system modify cluster '$cluster_name' cluster_id $cluster_id set redo_transport_options='SYNC'; 

ob1.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO STANDBY, 30;
ob1.mysql ALTER SYSTEM SET STANDBY CLUSTER TO MAXIMIZE PROTECTION;
let $cluster_id = deploy_get_value(ob2.select select value from oceanbase.__all_virtual_sys_parameter_stat where name = 'cluster_id', value, 1);
ob1.check_until_timeout select protection_level from oceanbase.__all_cluster where cluster_id = $cluster_id, MAXIMUM PROTECTION, 100;

let $cluster_id1 = deploy_get_value(ob1.select select value from oceanbase.__all_virtual_sys_parameter_stat where name = 'cluster_id', value, 1);
ob1.mysql alter system modify cluster '$cluster_name' cluster_id $cluster_id1 set redo_transport_options='SYNC'; 
ob1.mysql alter system commit to switchover to physical standby;

#MAXIMIZE PROTECTION模式，SWITCHOVER SWITCHING状态下执行无损FO
ob1.mysql alter system failover to '$cluster_name' cluster_id $cluster_id1;
ob1.mysql_p select cluster_role,protection_mode,protection_level from oceanbase.__all_virtual_cluster;

#设置主库为ASYNC同步模式
ob1.mysql alter system modify cluster '$cluster_name' cluster_id $cluster_id set redo_transport_options='ASYNC'; 
ob2.force_stop;
ob3.reboot;
ob1.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO STANDBY, 60;

ob1.mysql alter system commit to switchover to physical standby;
#MAXIMIZE PERFORMANCE模式下，SWITCHOVER SWITCHING状态下执行无损FO
ob1.mysql alter system failover to '$cluster_name' cluster_id $cluster_id1;
ob1.mysql_p select cluster_role,protection_mode,protection_level from oceanbase.__all_virtual_cluster;

ob3.force_stop;
ob4.reboot;
ob1.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO STANDBY, 60;

ob1.mysql alter system commit to switchover to physical standby;
#MAXIMIZE PERFORMANCE模式下，SWITCHOVER SWITCHING状态下执行有损FO
ob1.mysql ALTER SYSTEM ACTIVATE PHYSICAL STANDBY CLUSTER;
ob1.mysql_p select cluster_role,protection_mode,protection_level from oceanbase.__all_virtual_cluster;
