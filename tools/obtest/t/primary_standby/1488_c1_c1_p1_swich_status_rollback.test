# owner: rongxuan.lc
# description: 本case是为了测试切换状态回退的问题；
##case1:验证切换过程中， swich_timestamp的值会++;
ob1=OBI(cluster=1,proxy_num=0);
ob2=OBI(cluster=1,leaderob=ob1,proxy_num=0);
ob1.reboot;
sleep 3;
ob2.reboot;

let $cpu = 1;
let $memory = 1073741824;
let $min_memory = 1073741824;
let $disk = 536870912;
let $iops = 100000;
let $session = 64;
let $case_index = 1;

ob1.mysql CREATE RESOURCE UNIT unit_1 MAX_CPU $cpu, MAX_MEMORY $memory, MAX_IOPS $iops, MAX_DISK_SIZE $disk, MAX_SESSION_NUM $session, MIN_CPU=1, MIN_MEMORY=$min_memory, MIN_IOPS=128;
ob1.mysql CREATE RESOURCE POOL pool_1 UNIT = 'unit_1', UNIT_NUM = 1, ZONE_LIST = ('z1');
ob1.mysql CREATE TENANT tenant_$case_index RESOURCE_POOL_LIST = ('pool_1'), primary_zone='z1' set ob_tcp_invited_nodes='%';
sleep 3;

ob_connect(tt1_conn, ob1.z1.obs0, root@tenant_1, , test, , USE_MYSQL_CONNECTOR);
connection tt1_conn;
let $tablenum=2;
source sql/init_table.sql;
ob_connect(tt2_conn, ob2.z1.obs0, root, , oceanbase, , USE_MYSQL_CONNECTOR);
connection tt2_conn;
sleep 3;
alter system set balancer_idle_time = '10s';
alter system set server_data_copy_out_concurrency = 30;
alter system set server_data_copy_in_concurrency = 30;
alter system set data_copy_concurrency = 60;
alter system set enable_auto_leader_switch = false;
let $partition_cnt = deploy_get_value(ob1.select select count(*) c from __all_virtual_meta_table where tenant_id = 1001, c, 1);
ob2.check_until_timeout select count(*) c from __all_virtual_meta_table where tenant_id = 1001, $partition_cnt, 120;

ob1.check_until_timeout select count(*) from v\$ob_cluster where switchover_status='TO STANDBY', 1, 360;
###case 0: 对主切备再切成主；
ob1.mysql alter system commit to switchover to physical standby;
let $pure_switch_timestamp = deploy_get_value(ob1.select select (column_value&~0x2ff) as column_value from __all_core_table where table_name like '%__all_cluster%' and column_name = 'switchover_timestamp', column_value, 1);
let $step = deploy_get_value(ob1.select select (column_value&0x2ff) as column_value from __all_core_table where table_name like '%__all_cluster%' and column_name = 'switchover_timestamp', column_value, 1);
if (1 == $step) 
{
  echo "step is one, success";
}
ob1.mysql alter system commit to switchover to primary;

let $new_switch_timestamp = deploy_get_value(ob1.select select (column_value&~0x2ff) as column_value from __all_core_table where table_name like '%__all_cluster%' and column_name = 'switchover_timestamp', column_value, 1);

if ($pure_switch_timestamp == $new_switch_timestamp)
{
  echo "equal pure timestamp, success";
}

