# owner: rongxuan.lc
# description: 本case是为了测试备库snapshot_gc_ts的用法；
#在备库不推snapshot_gc_ts的情况下，是否影响迁移复制；

ob1=OBI(cluster=1,proxy_num=0);
ob2=OBI(cluster=1:2:1,leaderob=ob1,proxy_num=0);
ob1.reboot;
sleep 3;
ob2.reboot;

--disable_query_log
ob_connect(sys1_conn, ob1.z1.obs0, root, , oceanbase, , USE_MYSQL_CONNECTOR);
connection sys1_conn;
set ob_query_timeout = 9000000000;
set ob_trx_timeout = 9000000000;
set ob_trx_idle_timeout = 9000000000;
let $old_snapshot_ts = deploy_get_value(ob1.select select column_value from __all_core_table where table_name ="__all_global_stat" and column_name = 'snapshot_gc_ts',column_value, 1);
set autocommit = false;
--disable_result_log
select column_value from __all_core_table where table_name ="__all_global_stat" and column_name = 'snapshot_gc_ts' for update;
--enable_query_log
--enable_result_log
let $cpu = 1;
let $memory = 1073741824;
let $min_memory = 1073741824;
let $disk = 536870912;
let $iops = 100000;
let $session = 64;
let $case_index = 1;

ob1.mysql CREATE RESOURCE UNIT unit_1 MAX_CPU $cpu, MAX_MEMORY $memory, MAX_IOPS $iops, MAX_DISK_SIZE $disk, MAX_SESSION_NUM $session, MIN_CPU=1, MIN_MEMORY=$min_memory, MIN_IOPS=128;
ob1.mysql CREATE RESOURCE POOL pool_1 UNIT = 'unit_1', UNIT_NUM = 1, ZONE_LIST = ('z1');
ob1.mysql CREATE TENANT tenant_$case_index RESOURCE_POOL_LIST = ('pool_1'), primary_zone='z1' set ob_tcp_invited_nodes='%';
sleep 3;
ob_connect(sys2_conn, ob2.z1.obs0, root, , oceanbase, , USE_MYSQL_CONNECTOR);
connection sys2_conn;
alter system set debug_sync_timeout = '100000s';
alter system set balancer_idle_time = '10s';
alter system set server_data_copy_out_concurrency = 30;
alter system set server_data_copy_in_concurrency = 30;
alter system set data_copy_concurrency = 60;
alter system set merger_check_interval='10s';
ob1.check_until_timeout select count(*) from v\$ob_cluster where switchover_status='TO STANDBY', 1, 360;

ob1.check_until_timeout select column_value from __all_core_table where table_name ="__all_global_stat" and column_name = 'snapshot_gc_ts', $old_snapshot_ts, 3;
ob1.check_until_timeout select count(*) from __all_core_table where table_name ="__all_global_stat" and column_name = 'snapshot_gc_ts' and column_value <= $old_snapshot_ts,1, 3;

##测试迁移；
###unit= 2的迁移；
let $unit_id = deploy_get_value(ob2.select select unit_id from __all_unit where zone = 'z2' and resource_pool_id = 1, unit_id, 1);
let $source = deploy_get_value(ob2.select select concat(svr_ip,":",svr_port) addr from __all_unit where zone = 'z2' and unit_id = $unit_id, addr, 1);
let $dest = deploy_get_value(ob2.select select concat(svr_ip,":",svr_port) addr from __all_server where concat(svr_ip,":",svr_port) != '$source' and zone = 'z2', addr, 1);
connection sys2_conn;
--disable_query_log
eval alter system migrate unit $unit_id destination '$dest';
--enable_query_log
ob2.check_until_timeout select count(*) from __all_unit where migrate_from_svr_ip != '', 0, 360;
ob1.check_until_timeout select column_value from __all_core_table where table_name ="__all_global_stat" and column_name = 'snapshot_gc_ts', $old_snapshot_ts, 3;
ob1.check_until_timeout select count(*) from __all_core_table where table_name ="__all_global_stat" and column_name = 'snapshot_gc_ts' and column_value <= $old_snapshot_ts,1, 3;

###unit=1002的迁移；
let $unit_id = deploy_get_value(ob2.select select unit_id from __all_unit where zone = 'z2' and resource_pool_id = 1001, unit_id, 1);
let $source = deploy_get_value(ob2.select select concat(svr_ip,":",svr_port) addr from __all_unit where zone = 'z2' and unit_id = $unit_id, addr, 1);
let $dest = deploy_get_value(ob2.select select concat(svr_ip,":",svr_port) addr from __all_server where zone = 'z2' and concat(svr_ip,":",svr_port) != '$source', addr, 1);
connection sys2_conn;
--disable_query_log
eval alter system migrate unit $unit_id destination '$dest';
--enable_query_log
ob2.check_until_timeout select count(*) from __all_unit where migrate_from_svr_ip != '', 0, 800;
ob1.check_until_timeout select column_value from __all_core_table where table_name ="__all_global_stat" and column_name = 'snapshot_gc_ts', $old_snapshot_ts, 3;
ob1.check_until_timeout select count(*) from __all_core_table where table_name ="__all_global_stat" and column_name = 'snapshot_gc_ts' and column_value <= $old_snapshot_ts,1, 3;

connection sys1_conn;
commit;
ob1.mysql alter system major freeze;
ob1.check_version 2;
ob2.check_version 2;
