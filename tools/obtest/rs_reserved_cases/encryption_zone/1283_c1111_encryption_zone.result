ob1=OBI(cluster=1:1:1:1,proxy_num=0,init_unit_cpu=0);
ob1.z4.obs0.set status=disable;
ob1.reboot;
alter system add zone "z4" zone_type = "encryption";
alter system start zone "z4";
ob1.z4.obs0.set status=enable;
ob1.z4.obs0.start;
ob1.z4.obs0.add;
create resource pool pool1 unit = 'sys_unit_config', unit_num = 1, zone_list = ('z1', 'z2', 'z3', 'z4');
create tenant wenduo resource_pool_list=("pool1"), locality="F@z1,F@z2,F@z3,F@z4";
