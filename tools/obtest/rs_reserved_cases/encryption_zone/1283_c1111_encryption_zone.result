create tenant wenduo resource_pool_list=("pool1"), locality="F@z1,F@z2,F@z3,E@z4";
alter tenant wenduo locality = "F@z1,F@z2,E@z3,E@z4";
ERROR HY000: Incorrect arguments to encryption type, replica num or memstore percentage illegal
alter tenant wenduo locality = "F@z1,F@z2,F@z3,F@z4";
