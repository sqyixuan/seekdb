# owner: wenduo
# group: RS
# description: encryption zone associated

ob1=OBI(cluster=1:1:1:1,proxy_num=0,init_unit_cpu=0);
ob1.z4.obs0.set status=disable;
ob1.reboot;

let $tt1ip = deploy_get_value(ob1.z1.obs0.ip);
let $tt1port= deploy_get_value(ob1.z1.obs0.mysql_port);
connect(tt1_conn, $tt1ip, root,,oceanbase, $tt1port);
connection tt1_conn;

--disable_query_log
alter system set tde_method = 'internal';
ALTER INSTANCE ROTATE INNODB MASTER KEY;
sleep 15;
--enable_query_log
# ADD ZONE
alter system add zone "z4" zone_type = "encryption";
alter system start zone "z4";
# ADD SERVER 
ob1.z4.obs0.set status=enable;
ob1.z4.obs0.start;
sleep 30;
ob1.z4.obs0.add;
sleep 60;

# 创建新租户
connection tt1_conn;
create resource pool pool1 unit = 'sys_unit_config', unit_num = 1, zone_list = ('z1', 'z2', 'z3', 'z4');
--error 1210
create tenant wenduo resource_pool_list=("pool1"), locality="F@z1,F@z2,F@z3,F@z4";
--error 1210
create tenant wenduo resource_pool_list=("pool1"), locality="F@z1,F@z2,E@z3,E@z4";
# good
create tenant wenduo resource_pool_list=("pool1"), locality="F@z1,F@z2,F@z3,E@z4";

--error 1210
alter tenant wenduo locality = "F@z1,F@z2,E@z3,E@z4";
--error 1210
alter tenant wenduo locality = "F@z1,F@z2,F@z3,F@z4";

--error 1235
alter system modify zone "z3" zone_type = "encryption";
--error 1235
alter system modify zone "z4" zone_type = "readwrite";

drop tenant wenduo force;

create tenant wenduo resource_pool_list=("pool1");

select locality from oceanbase.__all_tenant where tenant_name = "wenduo";
