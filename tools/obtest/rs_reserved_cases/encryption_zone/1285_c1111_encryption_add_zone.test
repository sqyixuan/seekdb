# owner: wenduo
# group: RS
# description: encryption zone associated

ob1=OBI(cluster=1:1:1:1,proxy_num=0,init_unit_cpu=0);
ob1.z4.obs0.set status=disable;
ob1.reboot;

let $tt1ip = deploy_get_value(ob1.z1.obs0.ip);
let $tt1port= deploy_get_value(ob1.z1.obs0.mysql_port);
connect(tt1_conn, $tt1ip, root,,oceanbase, $tt1port);
connection tt1_conn;

alter system set tde_method = 'internal';
ALTER INSTANCE ROTATE INNODB MASTER KEY;

# ADD ZONE
--error 4179
eval alter system add zone "z4" zone_type = "encryption";

sleep 15;
eval alter system add zone "z4" zone_type = "encryption";
