# owner: rongxuan.lc
# description: 本case是为了测试在多类型副本进行pg coordinate的时候，如果遇上unit迁移的话，则会导致pg
# coordinate报错；

ob1=OBI(cluster=3:3:3, init_unit_cpu=0, proxy_num=0, ct_num = 0, locality=hz:hz:sh);
ob1.reboot;
let $case_index=1;

ob1.mysql alter system set resource_hard_limit=900;
ob1.mysql alter system set resource_soft_limit=800;
ob1.mysql alter system set debug_sync_timeout = '100s';
ob1.mysql alter system set enable_auto_leader_switch = 'False';
ob1.mysql alter system set balancer_idle_time = '10s';
ob1.mysql alter system set server_data_copy_out_concurrency = 20;
ob1.mysql alter system set server_data_copy_in_concurrency = 20;

let $cpu = 1;
let $memory = 1073741824;
let $min_memory = 1073741824;
let $disk = 536870912;
let $iops = 100000;
let $session = 64;

let $case_index=2;
ob1.mysql CREATE RESOURCE UNIT unit_$case_index MAX_CPU $cpu, MAX_MEMORY $memory, MAX_IOPS $iops, MAX_DISK_SIZE $disk, MAX_SESSION_NUM $session, MIN_CPU=1, MIN_MEMORY=$min_memory, MIN_IOPS=128;
ob1.mysql CREATE RESOURCE POOL pool_$case_index UNIT = 'unit_$case_index', UNIT_NUM = 2, ZONE_LIST = ('z1','z2','z3');
ob1.mysql CREATE TENANT tenant_$case_index RESOURCE_POOL_LIST = ('pool_$case_index'), locality='F@z1,F@z2,F@z3,R@z3' set ob_tcp_invited_nodes='%';
sleep 3;
let $tenant_id = deploy_get_value(ob1.select select tenant_id from __all_tenant where tenant_name = "tenant_2", tenant_id, 1); 

ob1.create_client tenant=tenant_2,user=root,passwd=,database=test;

create tablegroup tg1 partition by hash partitions 2;
create table test2(c1 int primary key, c2 int) tablegroup = 'tg1' partition by hash(c1) partitions 2;
create table test3(c1 int primary key, c2 int) tablegroup = 'tg1' partition by hash(c1) partitions 2;

let $t2_id = deploy_get_value(ob1.select select table_id from __all_virtual_table where table_name = "test2" and tenant_id = "$tenant_id", table_id, 1);
let $t3_id = deploy_get_value(ob1.select select table_id from __all_virtual_table where table_name = "test3" and tenant_id = "$tenant_id", table_id, 1);

##在z3上面制造需要coordinate的场景；
ob1.mysql alter system set enable_rebalance = 'false';
ob1.mysql alter system set enable_rereplication = 'false';

let $svr_ip0 = deploy_get_value(ob1.z3.obs0.ip);
let $svr_port0 = deploy_get_value(ob1.z3.obs0.port);
let $svr_ip1 = deploy_get_value(ob1.z3.obs1.ip);
let $svr_port1 = deploy_get_value(ob1.z3.obs1.port);

let $dest_ip = deploy_get_value(ob1.select select svr_ip from __all_virtual_meta_table where table_id = $t2_id and tenant_id = $tenant_id and zone='z3' and replica_type = 0 and partition_id = 0, svr_ip, 1);
let $dest_port = deploy_get_value(ob1.select select svr_port from __all_virtual_meta_table where table_id = $t2_id and tenant_id = $tenant_id and zone='z3' and replica_type = 0 and partition_id = 0, svr_port, 1);

--disable_all_result_log
##检查test3：p0 F型副本是否和test2 p0R 在一台机器上，如果不在的话，则remove member; 然后type_transfrom. 然后add R;
let $count = deploy_get_value(ob1.select select count(*)c from __all_virtual_meta_table where table_id = $t3_id and tenant_id = $tenant_id and zone='z3' and partition_id = 0 and concat(svr_ip,":",svr_port) = '$dest_ip:$dest_port', c, 1);
if ($count == 1)
{
#获取t3在dest_ip上的副本类型；
let $second_type = deploy_get_value(ob1.select select replica_type from __all_virtual_meta_table where table_id = $t3_id and tenant_id = $tenant_id and zone='z3' and partition_id = 0 and concat(svr_ip,":",svr_port) = '$dest_ip:$dest_port', replica_type, 1);
if ($second_type == 0)
{
###两个f在一台机器上面，需要做删除、type_transform/ add
##先删掉旧的F；
ob1.mysql alter system drop replica partition_id='0%2@$t3_id' server='$dest_ip:$dest_port';
##等待删除做完；
ob1.check_until_timeout select count(*) from __all_virtual_meta_table where table_id = $t3_id and tenant_id = $tenant_id and partition_id = 0 and role = 1 and member_list like '%,%,%', 0, 30;
##获得R的位置
let $read_ip= deploy_get_value(ob1.select select svr_ip from __all_virtual_meta_table where table_id = $t3_id and tenant_id = $tenant_id and zone='z3' and replica_type = 16 and partition_id = 0, svr_ip, 1);
let $read_port = deploy_get_value(ob1.select select svr_port from __all_virtual_meta_table where table_id = $t3_id and tenant_id = $tenant_id and zone='z3' and replica_type = 16 and partition_id = 0, svr_port, 1);

##做类型转换
ob1.mysql alter system change replica partition_id='0%2@$t3_id' server='$read_ip:$read_port' change replica_type='F';
##等待做完；
ob1.check_until_timeout select replica_type from __all_virtual_meta_table where table_id = $t3_id and tenant_id = $tenant_id and zone='z3' and concat(svr_ip,":",svr_port) = '$read_ip:$read_port' and partition_id = 0, 0, 30;
}
}
--enable_all_result_log

##开始复制，等待R出来
ob1.mysql alter system set enable_rereplication = 'true';
ob1.check_until_timeout select count(*) from __all_virtual_meta_table where table_id = $t3_id and tenant_id = $tenant_id AND partition_id = 0 and replica_type = 16, 1, 60;

###开始unit迁移
##将t2的f所在的unit做一次unit迁移；
##选择目的机器；
let $migrate_dest = deploy_get_value(ob1.select select concat(svr_ip,":",svr_port) addr from __all_server where zone='z3' except select concat(svr_ip,":",svr_port) addr from __all_unit where resource_pool_id = $tenant_id and zone='z3', addr, 1);
let $unit_id = deploy_get_value(ob1.select select unit_id from __all_virtual_meta_table where table_id = $t2_id and tenant_id = $tenant_id and partition_id = 0 and concat(svr_ip,":",svr_port) = '$dest_ip:$dest_port', unit_id, 1);
ob1.mysql alter system migrate unit $unit_id destination '$migrate_dest';
##在zone2和zone1上分别来说迁移；
let $unit_id = deploy_get_value(ob1.select select unit_id from __all_virtual_meta_table where table_id = $t2_id and tenant_id = $tenant_id and partition_id = 0 and zone='z1', unit_id, 1);
let $dst = deploy_get_value(ob1.select select concat(svr_ip,":",svr_port) addr from __all_server where zone='z1' except select concat(svr_ip,":",svr_port) addr from __all_unit where zone='z1' and resource_pool_id = $tenant_id, addr, 1);
ob1.mysql alter system migrate unit $unit_id destination '$dst';

let $unit_id = deploy_get_value(ob1.select select unit_id from __all_virtual_meta_table where table_id = $t2_id and tenant_id = $tenant_id and partition_id = 0 and zone='z2', unit_id, 1);
let $dst = deploy_get_value(ob1.select select  concat(svr_ip,":",svr_port) addr from __all_server where zone='z2' except select concat(svr_ip,":",svr_port) addr from __all_unit where zone='z2' and resource_pool_id = $tenant_id, addr, 1);
ob1.mysql alter system migrate unit $unit_id destination '$dst';

ob1.mysql alter system set enable_rebalance = 'true';
##等待unit迁移做完
ob1.check_until_timeout select count(*) from __all_unit where migrate_from_svr_ip != '', 0, 240;
