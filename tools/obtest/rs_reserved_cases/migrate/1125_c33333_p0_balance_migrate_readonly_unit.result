ob1=OBI(cluster=3:3:3:3:3, init_unit_cpu=2);
ob1.reboot;
ob1.mysql alter system set resource_hard_limit=900;
ob1.mysql alter system set resource_soft_limit=800;
ob1.mysql alter system set enable_rebalance = 'false';
ob1.mysql alter system set enable_rereplication = 'false';
ob1.mysql alter system set debug_sync_timeout = '100s';
ob1.mysql alter system set enable_auto_leader_switch = 'False';
ob1.mysql alter system set server_data_copy_out_concurrency = 10;
ob1.mysql alter system set server_data_copy_in_concurrency = 10;
ob1.mysql CREATE RESOURCE UNIT block_unit MAX_CPU $cpu, MAX_MEMORY $memory, MAX_IOPS $iops, MAX_DISK_SIZE $disk, MAX_SESSION_NUM $session, MIN_CPU=1, MIN_MEMORY=$min_memory, MIN_IOPS=128;
ob1.mysql CREATE RESOURCE POOL block_unit_pool1 UNIT = 'block_unit', UNIT_NUM = 2, ZONE_LIST = ('z1', 'z2','z3', 'z4', 'z5');
ob1.mysql CREATE TENANT block_unit_tenant RESOURCE_POOL_LIST = ('block_unit_pool1'), locality='F@z1,F@z2,F@z3,F@z4,R@z4,F@z5,R@z5' set ob_tcp_invited_nodes='%';
CREATE DATABASE obtest;
use obtest;
create table test_table (pk int primary key);
ob1.mysql alter system migrate unit $unit_id destination="$unit_ip:$unit_port";
ob1.mysql alter system set enable_rebalance = 'true';
ob1.mysql alter system set balancer_idle_time = '10s';
ob1.check_until_timeout select count(*) c from oceanbase.__all_unit where unit_id=$unit_id and migrate_from_svr_port =$migrate_from_port, 0, 360;
'migrate unit with readonly success;'
'migrate readonly replica success;'
'migrate remove old row success;'
