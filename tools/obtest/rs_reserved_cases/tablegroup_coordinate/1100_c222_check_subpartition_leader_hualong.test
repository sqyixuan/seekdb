CREATE TABLE t_sub5(c1 int, c2 int, primary key (c1, c2)) tablegroup = 'tg1' PARTITION BY hash (c1) subpartition by range columns(c2) subpartition template(subpartition p0 values less than (100), subpartition p1 values less than (200), subpartition p2 values less than (300), subpartition p3 values less than (maxvalue)) partitions 1 ;
