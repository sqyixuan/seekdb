CREATE TABLE t_sub7(c1 int, c2 int, primary key (c1, c2)) tablegroup = 'tg1' PARTITION BY hash (c1) subpartition by range columns(c2) subpartition template(subpartition p0 values less than (100), subpartition p1 values less than (200), subpartition p2 values less than (300), subpartition p3 values less than (maxvalue)) partitions 1 ;
CREATE TABLE t_sub8(c1 int, c2 int, primary key (c1, c2)) tablegroup = 'tg1' PARTITION BY hash (c1) subpartition by range columns(c2) subpartition template(subpartition p0 values less than (100), subpartition p1 values less than (200), subpartition p2 values less than (300), subpartition p3 values less than (maxvalue)) partitions 1 ;
CREATE TABLE t_sub9(c1 int, c2 int, primary key (c1, c2)) tablegroup = 'tg1' PARTITION BY hash (c1) subpartition by range columns(c2) subpartition template(subpartition p0 values less than (100), subpartition p1 values less than (200), subpartition p2 values less than (300), subpartition p3 values less than (maxvalue)) partitions 1 ;
CREATE TABLE t_sub10(c1 int, c2 int, primary key (c1, c2)) tablegroup = 'tg1' PARTITION BY hash (c1) subpartition by range columns(c2) subpartition template(subpartition p0 values less than (100), subpartition p1 values less than (200), subpartition p2 values less than (300), subpartition p3 values less than (maxvalue)) partitions 1 ;

let $tt1_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name = 'tt1', tenant_id, 1);
let $t_sub1_id = deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where table_name = 't_sub1' and tenant_id = $tt1_id, table_id, 1);
let $t_sub2_id = deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where table_name = 't_sub2' and tenant_id = $tt1_id, table_id, 1);
let $t_sub3_id = deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where table_name = 't_sub3' and tenant_id = $tt1_id, table_id, 1);
let $t_sub4_id = deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where table_name = 't_sub4' and tenant_id = $tt1_id, table_id, 1);
let $t_sub5_id = deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where table_name = 't_sub5' and tenant_id = $tt1_id, table_id, 1);
let $t_sub6_id = deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where table_name = 't_sub6' and tenant_id = $tt1_id, table_id, 1);
let $t_sub7_id = deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where table_name = 't_sub7' and tenant_id = $tt1_id, table_id, 1);
let $t_sub8_id = deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where table_name = 't_sub8' and tenant_id = $tt1_id, table_id, 1);
let $t_sub9_id = deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where table_name = 't_sub9' and tenant_id = $tt1_id, table_id, 1);
let $t_sub10_id = deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where table_name = 't_sub10' and tenant_id = $tt1_id, table_id, 1);

ob1.mysql_p select partition_id, role, zone, count(*) from oceanbase.__all_virtual_meta_table  where table_id in ($t_sub1_id, $t_sub2_id, $t_sub3_id, $t_sub4_id, $t_sub5_id, $t_sub6_id, $t_sub7_id, $t_sub8_id, $t_sub9_id, $t_sub10_id) group by partition_id, role, svr_ip, svr_port, zone order by partition_id, role, zone;
