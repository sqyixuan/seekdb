# owner: rongxuan.lc
# owner group: rs 
# 场景：单 zone 3 server  3 unit. 
#       t1, t2 两个表属于同一 tg，均有 5 个 partition
#       人工将这些 partition 迁移到 obs0
#       并让 obs2 宕机, 剩余 obs0, obs1
# 预期：obs2 宕机不会影响负载均衡，最终副本会均衡到 obs0, obs1 上
# 测试：1. 创建tg1, 创建 t1 table_group=tg1 partition 5, t2 table_group=tg1 partition 5
#       2. 关闭负载均衡
#       3. 人工迁移所有副本到 obs0
#       4. 杀 obs2
#       5. 打开负载均衡 
#       6. 检查副本均衡到了 obs0, obs1

ob1=OBI(cluster=3:3:3,proxy_num=0,init_unit_cpu=1);
ob1.reboot;

ob1.mysql alter system set resource_hard_limit=900;
ob1.mysql alter system set resource_soft_limit=800;
ob1.mysql alter system set server_data_copy_out_concurrency = 4;
ob1.mysql alter system set server_data_copy_in_concurrency = 4;
ob1.mysql alter system set enable_rootservice_standalone = 'false';
ob1.mysql alter system set balancer_idle_time = '10s';
ob1.mysql alter system set enable_auto_leader_switch = 'false';
ob1.mysql alter system set enable_rereplication = 'false';
ob1.mysql alter system set enable_rebalance = 'false';
ob1.mysql alter resource pool sys_pool unit_num = 3;

ob1.mysql CREATE RESOURCE POOL pl UNIT = 'sys_unit_config', UNIT_NUM = 3,ZONE_LIST =('z1','z2','z3');
ob1.mysql CREATE TENANT tt RESOURCE_POOL_LIST = ('pl') set ob_tcp_invited_nodes='%';
let $tenant_id = deploy_get_value(ob1.select select tenant_id from __all_tenant where tenant_name = 'tt', tenant_id, 1);
sleep 3;
let $ip=deploy_get_value(ob1.z1.obs0.ip);
let $port=deploy_get_value(ob1.z1.obs0.mysql_port);
connect(conn1,$ip,root@obtest,,test,$port);
connect(conn_sys,$ip,root@sys,,oceanbase,$port);

connection conn1;
# ensure alloc enough unit for tenant
use test;
create table t0 (pk int primary key, i int) partition by hash(pk) partitions 5;

ob1.z1.obs1.force_stop;
ob1.z1.obs2.force_stop;

sleep 20;

use test;
create tablegroup tg1 partition by hash partitions 5;
create table t1 (pk int primary key, i int) tablegroup 'tg1' partition by hash(pk) partitions 5;
create table t2 (pk int primary key, i int) tablegroup 'tg1' partition by hash(pk) partitions 5;

ob1.mysql alter system set enable_rebalance = 'true';
ob1.z1.obs1.start;
#ob1.z1.obs2.start;

sleep 10;
connection conn_sys;


let $check_times = 60;
while ($check_times > 0)
{
  dec $check_times;
  let $task_cnt = query_get_value(select count(*) c from oceanbase.__all_virtual_rebalance_task_stat,c,1);
  if ($task_cnt > 0)
  {
    echo "rebalance still works after one server down";
    let $check_times = 0;
  }
  sleep 1;
}
ob1.z1.obs2.start;
ob1.check_until_timeout select count(*) from __all_server where  start_service_time<= 0, 0, 30;
let $cpu = 1;
let $memory = 1073741824;
let $min_memory = 1073741824;
let $disk = 536870912;
let $iops = 100000;
let $session = 64;
let $case_index = 1;
ob1.mysql alter system set enable_rereplication = 'true';
ob1.mysql alter system set enable_rebalance = 'true';

ob1.mysql CREATE RESOURCE UNIT unit_$case_index MAX_CPU $cpu, MAX_MEMORY $memory, MAX_IOPS $iops, MAX_DISK_SIZE $disk, MAX_SESSION_NUM $session, MIN_CPU=1, MIN_MEMORY=$min_memory, MIN_IOPS=128;
ob1.mysql CREATE RESOURCE POOL pool_2 UNIT = 'unit_1', UNIT_NUM = 2, ZONE_LIST = ('z1', 'z2','z3');
ob1.mysql CREATE RESOURCE POOL pool_3 UNIT = 'unit_1', UNIT_NUM = 1, ZONE_LIST = ('z1', 'z2','z3'),replica_type = 'L';
ob1.mysql CREATE TENANT tenant_$case_index RESOURCE_POOL_LIST = ('pool_2', 'pool_3'), locality='F@z1,F@z2,F@z3,L@z1', primary_zone='z2;z3' set ob_tcp_invited_nodes='%';
sleep 3;
ob1.create_client tenant=tenant_1,user=root,passwd=,database=test;
create tablegroup tg1 partition by hash partitions 5;
create table t1 (pk int primary key, i int) tablegroup 'tg1' partition by hash(pk) partitions 5;
create table t2 (pk int primary key, i int) tablegroup 'tg1' partition by hash(pk) partitions 5;
let $tenant_id = deploy_get_value(ob1.select select tenant_id from __all_tenant where tenant_name = 'tenant_1', tenant_id, 1);
let $table_id = deploy_get_value(ob1.select select table_id from __all_virtual_table where tenant_id = $tenant_id and table_name = 't1', table_id , 1);
let $table_id2 = deploy_get_value(ob1.select select table_id from __all_virtual_table where tenant_id = $tenant_id and table_name = 't2', table_id , 1);
let $source = deploy_get_value(ob1.select select concat(svr_ip,":",svr_port) addr from __all_virtual_meta_table where tenant_id = $tenant_id and table_id = $table_id and partition_id = 3 and replica_type = 0 and zone='z1', addr, 1);
ob1.mysql alter system drop replica partition_id='3%0@$table_id' server='$source';
ob1.check_until_timeout select count(*) from __all_virtual_meta_table where table_id = $table_id and tenant_id =  $tenant_id and partition_id = 3, 4, 60;
ob1.mysql alter system drop replica partition_id='3%0@$table_id2' server='$source';
ob1.check_until_timeout select count(*) from __all_virtual_meta_table where table_id = $table_id2 and tenant_id =  $tenant_id and partition_id = 3, 4, 60;

