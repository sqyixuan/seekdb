# owner: rongxuan.lc
# description: 本case是为了测试pg group的时候，处理paxos类型的coordinate;
#(1) ppr缺失f, 未永久下线；不报错
#(2) pr缺失F,未永久下线；不报错
#(4) ppr F所在位置已经有R了，需要先删除后迁移

ob1=OBI(cluster=3:3:3, init_unit_cpu=2, proxy_num=0, ct_num = 0);
ob1.reboot;
let $case_index=1;

ob1.mysql alter system set resource_hard_limit=900;
ob1.mysql alter system set resource_soft_limit=800;
ob1.mysql alter system set enable_rebalance = 'false';
ob1.mysql alter system set enable_rereplication = 'false';
ob1.mysql alter system set debug_sync_timeout = '100s';
ob1.mysql alter system set enable_auto_leader_switch = 'False';
ob1.mysql alter system set balancer_idle_time = '10s';
ob1.mysql alter system set server_data_copy_out_concurrency = 10;
ob1.mysql alter system set server_data_copy_in_concurrency = 10;
sleep 2;

let $cpu = 1;
let $memory = 1073741824;
let $min_memory = 1073741824;
let $disk = 536870912;
let $iops = 100000;
let $session = 64;

ob1.mysql CREATE RESOURCE UNIT unit_$case_index MAX_CPU $cpu, MAX_MEMORY $memory, MAX_IOPS $iops, MAX_DISK_SIZE $disk, MAX_SESSION_NUM $session, MIN_CPU=1, MIN_MEMORY=$min_memory, MIN_IOPS=128;
ob1.mysql CREATE RESOURCE POOL pool_$case_index UNIT = 'unit_$case_index', UNIT_NUM = 3, ZONE_LIST = ('z1', 'z2','z3');
ob1.mysql CREATE TENANT tenant_$case_index RESOURCE_POOL_LIST = ('pool_$case_index'), primary_zone = 'z1', locality='F@z1,F@z2,F@z3,R@z3' set ob_tcp_invited_nodes='%';

let $tenant_id = deploy_get_value(ob1.select select tenant_id from __all_tenant where tenant_name = "tenant_1", tenant_id, 1); 

ob1.create_client tenant=tenant_1,user=root,passwd=,database=test;
create tablegroup tg1 partition by hash partitions 20;
create table test2(c1 int primary key, c2 int) tablegroup = 'tg1' partition by hash(c1) partitions 20;
create table test3(c1 int primary key, c2 int) tablegroup = 'tg1' partition by hash(c1) partitions 20;

let $t2_id = deploy_get_value(ob1.select select table_id from __all_virtual_table where table_name = "test2" and tenant_id = "$tenant_id", table_id, 1);
let $t3_id = deploy_get_value(ob1.select select table_id from __all_virtual_table where table_name = "test3" and tenant_id = "$tenant_id", table_id, 1);

### (1) ppr缺失f, 未永久下线；不报错
##partition_id = 0; 在zone2找到副本在test2的所在位置，将OBS下线掉；等待30秒，不发生pg group；

ob1.mysql alter system set enable_rebalance = 'true';
ob1.mysql alter system set enable_rereplication = 'true';
##检查所有的pg都已经均衡
ob1.check_until_timeout select count(*) from (select count(distinct unit_id)c, partition_id from gv\$partition where table_id in ($t2_id, $t3_id) and zone = 'z1' and tenant_id = $tenant_id group by partition_id)s where s.c > 1, 0, 60;
ob1.check_until_timeout select count(*) from (select count(distinct unit_id)c, partition_id from gv\$partition where table_id in ($t2_id, $t3_id) and zone = 'z2' and tenant_id = $tenant_id group by partition_id)s where s.c > 1, 0, 60;
ob1.check_until_timeout select count(*) from (select count(distinct unit_id)c, partition_id from gv\$partition where table_id in ($t2_id, $t3_id) and zone = 'z3' and replica_type = 16 and tenant_id = $tenant_id group by partition_id)s where s.c > 1, 0, 60;
ob1.check_until_timeout select count(*) from (select count(distinct unit_id)c, partition_id from gv\$partition where replica_type = 0 and table_id in ($t2_id, $t3_id) and  zone = 'z3' and tenant_id = $tenant_id group by partition_id)s where s.c > 1, 0, 60;

let $old_count = deploy_get_value(ob1.select select count(*) c from __all_rootservice_event_history where value5 like '%migrate replica for partition group coordinate%', c, 1);
let $svr_ip = deploy_get_value(ob1.select select svr_ip from __all_virtual_meta_table where tenant_id = $tenant_id and table_id = $t2_id and zone='z2', svr_ip, 1);
let $svr_port = deploy_get_value(ob1.select select svr_port from __all_virtual_meta_table where tenant_id = $tenant_id and table_id = $t2_id and zone='z2', svr_port, 1);
let $ip_port = deploy_get_value(ob1.select select concat(svr_ip, ":", svr_port) c from __all_virtual_meta_table where tenant_id = $tenant_id and table_id = $t2_id and zone='z2', c, 1);
let $obi = deploy_get_value(ob1.get_obs_by_addr $ip_port);
$obi.force_stop;
sleep 30;

let $new_count = deploy_get_value(ob1.select select count(*) c from __all_rootservice_event_history where value5 like '%migrate replica for partition group coordinate%', c, 1);
if ($old_count == $new_count)
{
  echo "temporary offline not migrate for coordinate";
}
$obi.start;
sleep 2;

#(2) pr缺失F,未永久下线；不报错
##partition_id = 0; 在zone2找到副本在test3所在位置，将obs下线。等待30s 不发生pg group；
let $ip_port = deploy_get_value(ob1.select select concat(svr_ip, ":", svr_port) c from __all_virtual_meta_table where tenant_id = $tenant_id and table_id = $t3_id and zone='z3' and replica_type = 0, c, 1);
let $obi = deploy_get_value(ob1.get_obs_by_addr $ip_port);
$obi.force_stop;
sleep 30;

let $new_count = deploy_get_value(ob1.select select count(*) c from __all_rootservice_event_history where value5 like '%migrate replica for partition group coordinate%', c, 1);
if ($old_count == $new_count)
{
  echo "temporary offline not migrate for coordinate 2";
}
##检查所有的pg都已经均衡
ob1.check_until_timeout select count(*) from (select count(distinct unit_id)c, partition_id from gv\$partition where table_id in ($t2_id, $t3_id) and zone = 'z1' and tenant_id = $tenant_id group by partition_id)s where s.c > 1, 0, 60;
ob1.check_until_timeout select count(*) from (select count(distinct unit_id)c, partition_id from gv\$partition where table_id in ($t2_id, $t3_id) and zone = 'z2' and tenant_id = $tenant_id group by partition_id)s where s.c > 1, 0, 60;
ob1.check_until_timeout select count(*) from (select count(distinct unit_id)c, partition_id from gv\$partition where table_id in ($t2_id, $t3_id) and zone = 'z3' and replica_type = 16 and tenant_id = $tenant_id group by partition_id)s where s.c > 1, 0, 60;
ob1.check_until_timeout select count(*) from (select count(distinct unit_id)c, partition_id from gv\$partition where replica_type = 0 and table_id in ($t2_id, $t3_id) and  zone = 'z3' and tenant_id = $tenant_id group by partition_id)s where s.c > 1, 0, 60;
$obi.start;
sleep 2;
ob1.mysql alter system set enable_rebalance = 'false';
ob1.mysql alter system set enable_rereplication = 'false';

#(4) pr F所在位置已经有R了，需要先删除后迁移
#test3:partition_id = 0, 在zone3上面，把f迁移到一台空闲的机器上面，然后把R迁移到 test2 F所在位置； 
###先迁移f到空闲；
sleep 5;
let $dest_ip = deploy_get_value(ob1.select select svr_ip from __all_server where zone='z3' except select svr_ip from __all_virtual_meta_table where table_id = $t3_id and tenant_id = $tenant_id and zone='z3' and partition_id = 0, svr_ip, 1);
let $dest_port = deploy_get_value(ob1.select select svr_port from __all_server where zone='z3' except select svr_port from __all_virtual_meta_table where table_id = $t3_id and tenant_id = $tenant_id and zone='z3' and partition_id = 0, svr_port, 1);
let $src_ip = deploy_get_value(ob1.select select svr_ip from gv\$partition where table_id = $t3_id and tenant_id = $tenant_id and zone='z3' and partition_id = 0 and replica_type = 0, svr_ip, 1);
let $src_port = deploy_get_value(ob1.select select svr_port from gv\$partition where table_id = $t3_id and tenant_id = $tenant_id and zone='z3' and partition_id = 0 and replica_type = 0, svr_port, 1);
ob1.mysql alter system move replica partition_id="0%20@$t3_id" source '$src_ip:$src_port' destination '$dest_ip:$dest_port'; 
##等待迁移做完
ob1.check_until_timeout select count(*) from gv\$partition where tenant_id = $tenant_id and zone='z3' and partition_id = 0 and  table_id = $t3_id and svr_ip='$dest_ip' and svr_port=$dest_port and replica_type = 0, 1, 30;
#sleep 5;
#ob1.mysql alter system drop replica  partition_id="0%20@$t3_id" server '$src_ip:$src_port';
###将R迁到src上面；
let $readonly_ip = deploy_get_value(ob1.select select svr_ip from gv\$partition where table_id = $t3_id and tenant_id = $tenant_id and zone='z3' and partition_id = 0 and replica_type = 16, svr_ip, 1);
let $readonly_port = deploy_get_value(ob1.select select svr_port from gv\$partition where table_id = $t3_id and tenant_id = $tenant_id and zone='z3' and partition_id = 0 and replica_type = 16, svr_port, 1);
ob1.mysql alter system move replica partition_id="0%20@$t3_id" source '$readonly_ip:$readonly_port' destination '$src_ip:$src_port'; 

ob1.mysql alter system set enable_rebalance = 'true';
ob1.mysql alter system set enable_rereplication = 'true';

##预期：f副本对齐；R对齐；
ob1.check_until_timeout select count(*) c from gv\$partition where tenant_id = $tenant_id and zone='z3' and partition_id = 0 and replica_type = 0 and table_id in ($t2_id, $t3_id) group by svr_ip, svr_port, 2, 120;
ob1.check_until_timeout select count(*) c from gv\$partition where tenant_id = $tenant_id and zone='z3' and partition_id = 0 and replica_type = 16 and table_id in ($t2_id, $t3_id) group by svr_ip, svr_port, 2, 120;

##检查所有的pg都已经均衡
ob1.check_until_timeout select count(*) from (select count(distinct unit_id)c, partition_id from gv\$partition where table_id in ($t2_id, $t3_id) and zone = 'z1' and tenant_id = $tenant_id group by partition_id)s where s.c > 1, 0, 60;
ob1.check_until_timeout select count(*) from (select count(distinct unit_id)c, partition_id from gv\$partition where table_id in ($t2_id, $t3_id) and zone = 'z2' and tenant_id = $tenant_id group by partition_id)s where s.c > 1, 0, 60;
ob1.check_until_timeout select count(*) from (select count(distinct unit_id)c, partition_id from gv\$partition where table_id in ($t2_id, $t3_id) and zone = 'z3' and replica_type = 16 and tenant_id = $tenant_id group by partition_id)s where s.c > 1, 0, 60;
ob1.check_until_timeout select count(*) from (select count(distinct unit_id)c, partition_id from gv\$partition where replica_type = 0 and table_id in ($t2_id, $t3_id) and  zone = 'z3' and tenant_id = $tenant_id group by partition_id)s where s.c > 1, 0, 60;


