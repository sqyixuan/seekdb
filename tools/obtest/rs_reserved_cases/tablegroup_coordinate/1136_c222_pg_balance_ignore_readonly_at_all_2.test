# owner: rongxuan.lc
# description: 本case是为了验证在pg复制均衡的时候，要忽略掉readonly@all的副本；

#提供多张需要进行PG均衡的表，让readonly@all的pgcount 最小。按照之前的逻辑会选择pg count最小的进行迁移；现在会跳过readonly@all


ob1=OBI(cluster=2:2:2, init_unit_cpu=2);
ob1.reboot;
let $case_index=1;

ob1.mysql alter system set resource_hard_limit=900;
ob1.mysql alter system set resource_soft_limit=800;
ob1.mysql alter system set enable_rebalance = 'false';
ob1.mysql alter system set enable_rereplication = 'false';
ob1.mysql alter system set debug_sync_timeout = '100s';
ob1.mysql alter system set enable_auto_leader_switch = 'False';
ob1.mysql alter system set balancer_idle_time = '10s';
sleep 4;

let $cpu = 1;
let $memory = 1073741824;
let $min_memory = 1073741824;
let $disk = 536870912;
let $iops = 100000;
let $session = 64;

ob1.mysql CREATE RESOURCE UNIT unit_$case_index MAX_CPU $cpu, MAX_MEMORY $memory, MAX_IOPS $iops, MAX_DISK_SIZE $disk, MAX_SESSION_NUM $session, MIN_CPU=1, MIN_MEMORY=$min_memory, MIN_IOPS=128;
ob1.mysql CREATE RESOURCE POOL pool_$case_index UNIT = 'unit_$case_index', UNIT_NUM = 2, ZONE_LIST = ('z1', 'z2', 'z3');
ob1.mysql CREATE TENANT tenant_$case_index RESOURCE_POOL_LIST = ('pool_$case_index'), locality='F@z1,F@z2,F@z3', primary_zone = "z1" set ob_tcp_invited_nodes='%';

let $tenant_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where  tenant_name = "tenant_$case_index", tenant_id, 1);

let $obs = deploy_get_value(ob1.select select svr_ip from __all_unit where resource_pool_id = 1003 and zone = 'z1' order by unit_id, svr_ip, svr_port limit 1, svr_ip, 1);
let $rpc_port= deploy_get_value(ob1.select select svr_port from __all_unit where resource_pool_id = 1003 and zone = 'z1' order by unit_id, svr_ip, svr_port limit 1, svr_port, 1);
let $port = deploy_get_value(ob1.select select inner_port from __all_server where svr_ip='$obs' and svr_port=$rpc_port, inner_port, 1);

sleep 2;
connect(conn1,$obs,root@tenant_$case_index,,,$port);
connection conn1;
use test;

#（1）新建一个新的表，
create table test(c1 int primary key, c2 int) locality="F@z1,F@z2,F@z3,R{all_server}@z2,R{all_server}@z3" partition by hash(c1) partitions 20;
create tablegroup tg1 partition by hash partitions 20;
create table test2(c1 int primary key, c2 int) locality="F@z1,F@z2,F@z3" tablegroup = 'tg1' partition by hash(c1) partitions 20;
create table test3(c1 int primary key, c2 int) tablegroup = 'tg1' partition by hash(c1) partitions 20;

let $source_ip = deploy_get_value(ob1.z2.obs1.ip);
let $source_port = deploy_get_value(ob1.z2.obs1.port);
let $dest_ip = deploy_get_value(ob1.z2.obs0.ip);
let $dest_port = deploy_get_value(ob1.z2.obs0.port);

#全部到z2.obs0上面迁走；
let $table_id = deploy_get_value(ob1.select select table_id from __all_virtual_table where table_name = "test2", table_id, 1);
let $count = 20;
let $partition_id = 0;
--disable_all_result_log
while ($count > 0)
{
  let $replica_count = deploy_get_value(ob1.select select count(*) c from __all_virtual_meta_table where tenant_id = $tenant_id and table_id = $table_id and partition_id=$partition_id and concat(svr_ip,":",svr_port) = '$source_ip:$source_port', c, 1);
  if ($replica_count == 1) 
  {
    ob1.mysql alter system move replica partition_id="$partition_id%20@$table_id" source="$source_ip:$source_port" destination="$dest_ip:$dest_port";
  }
  dec $count;
  inc $partition_id;
}
--enable_all_result_log
##检查所有的副本都已经迁过去；
let $count = deploy_get_value(ob1.select select count(*) c from  __all_virtual_meta_table where tenant_id =   $tenant_id and svr_ip = "$source_ip" and svr_port=$source_port, c, 1);
if ($count == 0)
{
  echo migrate_replica_success;
}
--enable_all_result_log

let $table_id = deploy_get_value(ob1.select select table_id from __all_virtual_table where table_name = "test3", table_id, 1);
let $count = 20;
let $partition_id = 0;
--disable_all_result_log
while ($count > 0)
{
  let $replica_count = deploy_get_value(ob1.select select count(*) c from __all_virtual_meta_table where tenant_id = $tenant_id and table_id = $table_id and partition_id=$partition_id and concat(svr_ip,":",svr_port) = '$source_ip:$source_port', c, 1);
  if ($replica_count == 1) 
  {
    ob1.mysql alter system move replica partition_id="$partition_id%20@$table_id" source="$source_ip:$source_port" destination="$dest_ip:$dest_port";
  }
  dec $count;
  inc $partition_id;
}
--enable_all_result_log
##检查所有的副本都已经迁过去；
let $count = deploy_get_value(ob1.select select count(*) c from  __all_virtual_meta_table where tenant_id =   $tenant_id and svr_ip = "$source_ip" and svr_port=$source_port, c, 1);
if ($count == 0)
{
  echo migrate_replica_success;
}
--enable_all_result_log

###有PG的倾斜，需要产生PG 均衡
ob1.mysql alter system set enable_rebalance = 'true';
ob1.mysql alter system set enable_rereplication = 'true';
sleep 10;
ob1.check_until_timeout select count(*) c from __all_rootservice_event_history where event = "tenant_balance_finished", 1, 240;
let $table_id_old = deploy_get_value(ob1.select select table_id from __all_virtual_table where table_name = "test", table_id, 1);
let $count = deploy_get_value(ob1.select select count(*) c from __all_rootservice_event_history where value5 = "migrate pg replica" and value1 like '%$table_id_readonly%", c ,1);
if ($count == 0)
{
  echo "migrate pg ignore readonly@all success";
}

