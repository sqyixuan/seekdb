ob1=OBI(cluster=2:2:2, proxy_num=0, init_unit_cpu=0);
ob1.reboot;
ob1.mysql create resource pool rp1 unit = 'sys_unit_config',unit_num = 2, zone_list = ('z1', 'z2', 'z3');
ob1.mysql create tenant tt1 replica_num 3, primary_zone 'z1', resource_pool_list ('rp1') set ob_tcp_invited_nodes='%';
CREATE TABLEGROUP tg1 PARTITION BY hash subpartition by range columns 1 subpartition template(subpartition p0 values less than (100), subpartition p1 values less than (200), subpartition p2 values less than (300), subpartition p3 values less than (maxvalue)) partitions 1;
CREATE TABLE t_sub1(c1 int, c2 int, primary key (c1, c2)) tablegroup = 'tg1' PARTITION BY hash (c1) subpartition by range columns(c2) subpartition template(subpartition p0 values less than (100), subpartition p1 values less than (200), subpartition p2 values less than (300), subpartition p3 values less than (maxvalue)) partitions 1 ;
