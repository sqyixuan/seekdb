#}
--enable_all_result_log

##放置test2 的readonly 在obs3,4上面;
#F类型一定是主，不能迁移
--disable_all_result_log
#查看obs3上面有没有副本；
let $in = deploy_get_value(ob1.select select count(*) c from __all_virtual_meta_table where tenant_id = $tenant_id and table_id = $t3_id and partition_id = 0 and svr_ip='$svr_ip3' and svr_port=$svr_port3, c, 1);
if ($in != 1) 
{
  ##如果不在，则需要迁移；
  let $src_ip = deploy_get_value(ob1.select select svr_ip from  __all_virtual_meta_table where replica_type = 16 and tenant_id = $tenant_id and table_id = $t3_id and partition_id = 0 and concat(svr_ip,":", svr_port) not in("$svr_ip3:$svr_port3", "$svr_ip4:$svr_port4", "$svr_ip5:$svr_port5"), svr_ip, 1);
  let $src_port = deploy_get_value(ob1.select select svr_port from  __all_virtual_meta_table where replica_type = 16 and tenant_id = $tenant_id and table_id = $t3_id and partition_id = 0 and concat(svr_ip,":", svr_port) not in("$svr_ip3:$svr_port3", "$svr_ip4:$svr_port4", "$svr_ip5:$svr_port5"), svr_port, 1);
  ob1.mysql alter system move replica partition_id='0%20@$t3_id' source '$src_ip:$src_port' destination '$svr_ip3:$svr_port3';
  ob1.check_until_timeout select count(*) from gv\$partition where tenant_id = $tenant_id and table_id = $t3_id and partition_id = 0 and svr_ip='$svr_ip3' and svr_port=$svr_port3, 1, 30;
  let $count= deploy_get_value(ob1.select select count(*) c from gv\$partition where tenant_id = $tenant_id and table_id = $t3_id and partition_id = 0 and unit_id = -1, c, 1);
  if ($count == 1)
  {
    ob1.mysql_p select * from __all_virtual_meta_table where tenant_id = $tenant_id and table_id = $t2_id and partition_id = 0;
  }

}
sleep 5;
let $in = deploy_get_value(ob1.select select count(*) c from __all_virtual_meta_table where tenant_id = $tenant_id and table_id = $t3_id and partition_id = 0 and svr_ip='$svr_ip4' and svr_port=$svr_port4, c, 1);
if ($in != 1) 
{
  ##如果不在，则需要迁移；
  let $src_ip = deploy_get_value(ob1.select select svr_ip from  __all_virtual_meta_table where tenant_id = $tenant_id and replica_type = 16 and table_id = $t3_id and partition_id = 0 and concat(svr_ip,":", svr_port) not in("$svr_ip3:$svr_port3", "$svr_ip4:$svr_port4", "$svr_ip5:$svr_port5"), svr_ip, 1);
  let $src_port = deploy_get_value(ob1.select select svr_port from  __all_virtual_meta_table where tenant_id = $tenant_id and table_id = $t3_id and replica_type = 16 and partition_id = 0 and concat(svr_ip,":", svr_port) not in("$svr_ip3:$svr_port3", "$svr_ip4:$svr_port4", "$svr_ip5:$svr_port5"), svr_port, 1);
  ob1.mysql alter system move replica partition_id='0%20@$t3_id' source '$src_ip:$src_port' destination '$svr_ip4:$svr_port4';
  ob1.check_until_timeout select count(*) from gv\$partition where tenant_id = $tenant_id and table_id = $t3_id and partition_id = 0 and svr_ip='$svr_ip4' and svr_port=$svr_port4, 1, 30;
  let $count = deploy_get_value(ob1.select select count(*) c from gv\$partition where tenant_id = $tenant_id and table_id = $t3_id and partition_id = 0 and unit_id = -1, c, 1);
  if ($c == 1)
  {
    ob1.mysql_p select * from __all_virtual_meta_table where tenant_id = $tenant_id and table_id = $t2_id and partition_id = 0;
  }

}
