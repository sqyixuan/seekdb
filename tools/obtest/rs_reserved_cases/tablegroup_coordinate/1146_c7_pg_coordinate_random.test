# owner: rongxuan.lc
# description: 本case是为了测试副本的对齐；
# table_1: FRR; table_2:FRR . 都错开。 检查能够均衡成功；

ob1=OBI(cluster=7, init_unit_cpu=2, proxy_num=0, ct_num = 0);
ob1.reboot;
let $case_index=1;

ob1.mysql alter system set resource_hard_limit=900;
ob1.mysql alter system set resource_soft_limit=800;
ob1.mysql alter system set enable_rebalance = 'false';
ob1.mysql alter system set enable_rereplication = 'false';
ob1.mysql alter system set debug_sync_timeout = '100s';
ob1.mysql alter system set enable_auto_leader_switch = 'False';
ob1.mysql alter system set balancer_idle_time = '10s';
ob1.mysql alter system set server_data_copy_out_concurrency = 40;
ob1.mysql alter system set server_data_copy_in_concurrency = 40;
ob1.mysql alter system set data_copy_concurrency=600;
sleep 4;

let $cpu = 1;
let $memory = 1073741824;
let $min_memory = 1073741824;
let $disk = 536870912;
let $iops = 100000;
let $session = 64;

ob1.mysql CREATE RESOURCE UNIT unit_$case_index MAX_CPU $cpu, MAX_MEMORY $memory, MAX_IOPS $iops, MAX_DISK_SIZE $disk, MAX_SESSION_NUM $session, MIN_CPU=1, MIN_MEMORY=$min_memory, MIN_IOPS=128;
ob1.mysql CREATE RESOURCE POOL pool_$case_index UNIT = 'unit_$case_index', UNIT_NUM = 7;
ob1.mysql CREATE TENANT tenant_$case_index RESOURCE_POOL_LIST = ('pool_$case_index'), locality='F@z1,R{2}@z1' set ob_tcp_invited_nodes='%';
sleep 3;

let $tenant_id = deploy_get_value(ob1.select select tenant_id from __all_tenant where tenant_name = "tenant_1", tenant_id, 1); 

ob1.create_client tenant=tenant_1,user=root,passwd=,database=test;
create tablegroup tg1 partition by hash partitions 20;
create table test2(c1 int primary key, c2 int) tablegroup = 'tg1' partition by hash(c1) partitions 20;
create table test3(c1 int primary key, c2 int) tablegroup = 'tg1' partition by hash(c1) partitions 20;
let $t2_id = deploy_get_value(ob1.select select table_id from __all_virtual_table where table_name = "test2" and tenant_id = "$tenant_id", table_id, 1);
let $t3_id = deploy_get_value(ob1.select select table_id from __all_virtual_table where table_name = "test3" and tenant_id = "$tenant_id", table_id, 1);

###将table1的三个副本部署在obs0,obs1,obs2上面；
let $svr_ip0 = deploy_get_value(ob1.z1.obs0.ip);
let $svr_port0 = deploy_get_value(ob1.z1.obs0.port);
let $svr_ip1 = deploy_get_value(ob1.z1.obs1.ip);
let $svr_port1 = deploy_get_value(ob1.z1.obs1.port);
let $svr_ip2 = deploy_get_value(ob1.z1.obs2.ip);
let $svr_port2 = deploy_get_value(ob1.z1.obs2.port);

let $svr_ip3 = deploy_get_value(ob1.z1.obs3.ip);
let $svr_port3 = deploy_get_value(ob1.z1.obs3.port);
let $svr_ip4 = deploy_get_value(ob1.z1.obs4.ip);
let $svr_port4 = deploy_get_value(ob1.z1.obs4.port);
let $svr_ip5 = deploy_get_value(ob1.z1.obs5.ip);
let $svr_port5 = deploy_get_value(ob1.z1.obs5.port);

--disable_all_result_log
#查看obs0上面有没有副本；
let $in = deploy_get_value(ob1.select select count(*) c from __all_virtual_meta_table where tenant_id = $tenant_id and table_id = $t2_id and partition_id = 0 and svr_ip='$svr_ip0' and svr_port=$svr_port0, c, 1);
if ($in != 1) 
{
  ##如果不在，则需要迁移；
  let $src_ip = deploy_get_value(ob1.select select svr_ip from  __all_virtual_meta_table where tenant_id = $tenant_id and table_id = $t2_id  and replica_type != 0 and partition_id = 0 and concat(svr_ip,":", svr_port) not in("$svr_ip0:$svr_port0", "$svr_ip1:$svr_port1", "$svr_ip2:$svr_port2"), svr_ip, 1);
  let $src_port = deploy_get_value(ob1.select select svr_port from  __all_virtual_meta_table where tenant_id = $tenant_id and table_id = $t2_id and partition_id = 0 and replica_type != 0 and concat(svr_ip,":", svr_port) not in("$svr_ip0:$svr_port0", "$svr_ip1:$svr_port1", "$svr_ip2:$svr_port2") and svr_ip = '$src_ip', svr_port, 1);
  ob1.mysql alter system move replica partition_id='0%20@$t2_id' source '$src_ip:$src_port' destination '$svr_ip0:$svr_port0';
  ob1.check_until_timeout select count(*) from gv\$partition where tenant_id = $tenant_id and table_id = $t2_id and partition_id = 0 and svr_ip='$svr_ip0' and svr_port=$svr_port0, 1, 30;
  let $count= deploy_get_value(ob1.select select count(*) c from gv\$partition where tenant_id = $tenant_id and table_id = $t2_id and partition_id = 0 and unit_id = -1, c, 1);
  if ($count == 1)
  {
    ob1.mysql_p select * from __all_virtual_meta_table where tenant_id = $tenant_id and table_id = $t2_id and partition_id = 0;
  }
}
sleep 5;
#查看obs1上面有没有副本；
let $in = deploy_get_value(ob1.select select count(*) c from __all_virtual_meta_table where tenant_id = $tenant_id and table_id = $t2_id and partition_id = 0 and svr_ip='$svr_ip1' and svr_port=$svr_port1, c, 1);
if ($in != 1) 
{
##如果不在，则需要迁移；
  let $count = deploy_get_value(ob1.select select count(*) c from  __all_virtual_meta_table where tenant_id = $tenant_id and table_id = $t2_id and partition_id = 0 and concat(svr_ip,":", svr_port) not in("$svr_ip0:$svr_port0", "$svr_ip1:$svr_port1", "$svr_ip2:$svr_port2") and replica_type = 16, c, 1);
  if ($count  == 1) 
  {
    let $src_ip = deploy_get_value(ob1.select select svr_ip from  __all_virtual_meta_table where tenant_id = $tenant_id and table_id = $t2_id and partition_id = 0 and concat(svr_ip,":", svr_port) not in("$svr_ip0:$svr_port0", "$svr_ip1:$svr_port1", "$svr_ip2:$svr_port2"), svr_ip, 1);
    let $src_port = deploy_get_value(ob1.select select svr_port from  __all_virtual_meta_table where tenant_id = $tenant_id and table_id = $t2_id and partition_id = 0 and svr_ip = '$src_ip' and concat(svr_ip,":", svr_port) not in("$svr_ip0:$svr_port0", "$svr_ip1:$svr_port1", "$svr_ip2:$svr_port2"), svr_port, 1);
    ob1.mysql alter system move replica partition_id='0%20@$t2_id' source '$src_ip:$src_port' destination '$svr_ip1:$svr_port1';
###等待迁移做完
    ob1.check_until_timeout select count(*) from gv\$partition where tenant_id = $tenant_id and table_id = $t2_id and partition_id = 0 and svr_ip='$svr_ip1' and svr_port=$svr_port1, 1, 30;
    let $count= deploy_get_value(ob1.select select count(*) c from gv\$partition where tenant_id = $tenant_id and table_id = $t2_id and partition_id = 0 and unit_id = -1, c, 1);
    if ($count== 1)
    {
      ob1.mysql_p select * from __all_virtual_meta_table where tenant_id = $tenant_id and table_id = $t2_id and partition_id = 0;
    }
  }
}
##查看obs2上面有没有副本；
