ob1=OBI(cluster=2:2:2,proxy_num=1,init_unit_cpu=0);
ob1.reboot;
ob1.mysql alter system set balancer_idle_time = '10s';
ob1.mysql alter system set enable_rebalance = 'true';
ob1.mysql alter system set enable_auto_leader_switch = "false";
ob1.mysql CREATE RESOURCE POOL sys_pool_2 UNIT = 'sys_unit_config', UNIT_NUM = 1, ZONE_LIST = ('z1', 'z2', 'z3');
ob1.mysql CREATE TENANT tt resource_pool_list=('sys_pool_2'), locality = 'F@z1,F@z2,F@z3' set ob_tcp_invited_nodes='%';
create database db primary_zone = 'z1';
use db;
create tablegroup tg1 partition by range (partition p0 values less than(10), partition p1 values less than(20), partition p2 values less than(30));
create table t1(c1 int, c2 int, primary key(c1,c2)) tablegroup='tg1' partition by range(c1) (partition p0 values less than(10), partition p1 values less than(20), partition p2 values less than(30));
create table t2(c1 int, c2 int, primary key(c1,c2)) tablegroup='tg1' partition by range(c1) (partition p0 values less than(10), partition p1 values less than(20), partition p2 values less than(30));
create table t3(c1 int, c2 int, primary key(c1,c2)) tablegroup='tg1' partition by range(c1) (partition p0 values less than(10), partition p1 values less than(20), partition p2 values less than(30));
alter tablegroup tg1 add partition (partition p3 values less than(40), partition p4 values less than(50));
alter tablegroup tg1 drop partition (p3);
alter tablegroup tg1 drop partition (p4);
alter tablegroup tg1 add partition (partition p3 values less than(40));
alter tablegroup tg1 add partition (partition p4 values less than(50));
use oceanbase;
ob1.mysql alter system migrate unit $unit_id destination "$ip_to:$port_to";
ob1.check_until_timeout select count(*) c from oceanbase.__all_unit where migrate_from_svr_ip != "", 0, 360;
