# owner: yanmu.ztl
# owner group: rs
# description: 测试alter tablegroup partition的语法
ob1=OBI(cluster=1:1:1, init_unit_cpu=0, proxy_num=0, ct_num=0, locality=hz:hz:hz);
ob1.reboot;

ob1.mysql alter system set resource_hard_limit=900;
ob1.mysql alter system set resource_soft_limit=800;
ob1.mysql alter system set debug_sync_timeout = '1000s';
ob1.mysql alter system set enable_auto_leader_switch = 'false';
ob1.mysql alter system set enable_rebalance = 'false';
ob1.mysql alter system set enable_rereplication = 'false';
ob1.mysql alter system set balancer_idle_time = '10s';
ob1.mysql alter system set server_data_copy_out_concurrency = 20;
ob1.mysql alter system set server_data_copy_in_concurrency = 20;

let $rs = deploy_get_value(ob1.get_leader sys:oceanbase:__all_core_table:0);
let $rs_ip = deploy_get_value($rs.ip);
let $rs_port = deploy_get_value($rs.port);
let $rs_mysql_port = deploy_get_value($rs.mysql_port);
connect (conn_sys,$rs_ip,admin@sys,admin,oceanbase,$rs_mysql_port);

let $cpu = 1;
let $memory = 1073741824;
let $min_memory = 1073741824;
let $disk = 536870912;
let $iops = 100000;
let $session = 64;

ob1.mysql CREATE RESOURCE UNIT unit_1 MAX_CPU $cpu, MAX_MEMORY $memory, MAX_IOPS $iops, MAX_DISK_SIZE $disk, MAX_SESSION_NUM $session, MIN_CPU=1, MIN_MEMORY=$min_memory, MIN_IOPS=128;
ob1.mysql CREATE RESOURCE POOL pool_1 UNIT = 'unit_1', UNIT_NUM = 1, ZONE_LIST = ('z1','z2','z3');

ob1.mysql CREATE TENANT tenant_1 RESOURCE_POOL_LIST = ('pool_1'), primary_zone = 'z1;z2,z3', locality='F@z1,F@z2,F@z3' set ob_tcp_invited_nodes='%';
sleep 10;

connect (conn_tenant,$rs_ip,root@tenant_1,,test,$rs_mysql_port);

connection conn_tenant;

# case 0: 目前仅支持一级range/range column 动态增删分区
create tablegroup tg0 primary_zone = "z1;z2,z3" partition by range (PARTITION c0 VALUES LESS THAN (1990),PARTITION c1 VALUES LESS THAN (2000),PARTITION c2 VALUES LESS THAN MAXVALUE);
create tablegroup tg1 primary_zone = "z1;z2,z3" partition by range columns 1 (PARTITION c0 VALUES LESS THAN (1990),PARTITION c1 VALUES LESS THAN (2000),PARTITION c2 VALUES LESS THAN (MAXVALUE));
create tablegroup tg2 primary_zone = "z1;z2,z3" partition by range columns 2 (PARTITION c0 VALUES LESS THAN (1990, '1990'),PARTITION c1 VALUES LESS THAN (2000, '2000'),PARTITION c2 VALUES LESS THAN (MAXVALUE, MAXVALUE));

create tablegroup tg3 primary_zone = "z1;z2,z3" partition by range subpartition by hash subpartitions 2 (PARTITION c0 VALUES LESS THAN (1990), PARTITION c1 VALUES LESS THAN (2000), PARTITION c2 VALUES LESS THAN MAXVALUE);
create tablegroup tg4 primary_zone = "z1;z2,z3" partition by range subpartition by key 1 subpartitions 2 (PARTITION c0 VALUES LESS THAN (1990), PARTITION c1 VALUES LESS THAN (2000), PARTITION c2 VALUES LESS THAN MAXVALUE);
create tablegroup tg5 primary_zone = "z1;z2,z3" partition by range subpartition by key 2 subpartitions 2 (PARTITION c0 VALUES LESS THAN (1990), PARTITION c1 VALUES LESS THAN (2000), PARTITION c2 VALUES LESS THAN MAXVALUE);
create tablegroup tg6 primary_zone = "z1;z2,z3" partition by range columns 1 subpartition by hash subpartitions 2 (PARTITION c0 VALUES LESS THAN (1990),PARTITION c1 VALUES LESS THAN (2000),PARTITION c2 VALUES LESS THAN MAXVALUE);
create tablegroup tg7 primary_zone = "z1;z2,z3" partition by range columns 1 subpartition by key 1 subpartitions 2 (PARTITION c0 VALUES LESS THAN (1990),PARTITION c1 VALUES LESS THAN (2000),PARTITION c2 VALUES LESS THAN MAXVALUE);
create tablegroup tg8 primary_zone = "z1;z2,z3" partition by range columns 1 subpartition by key 2 subpartitions 2 (PARTITION c0 VALUES LESS THAN (1990),PARTITION c1 VALUES LESS THAN (2000),PARTITION c2 VALUES LESS THAN MAXVALUE);

create tablegroup tg9 primary_zone = "z1;z2,z3" partition by range columns 2 subpartition by hash subpartitions 2 (PARTITION c0 VALUES LESS THAN (1990, 1990),PARTITION c1 VALUES LESS THAN (2000, 2000),PARTITION c2 VALUES LESS THAN (MAXVALUE, MAXVALUE));
create tablegroup tg10 primary_zone = "z1;z2,z3" partition by range columns 2 subpartition by key 2 subpartitions 2 (PARTITION c0 VALUES LESS THAN (1990, 1990),PARTITION c1 VALUES LESS THAN (2000, 2000),PARTITION c2 VALUES LESS THAN (MAXVALUE, MAXVALUE));
create tablegroup tg11 primary_zone = "z1;z2,z3" partition by range columns 2 subpartition by key 1 subpartitions 2 (PARTITION c0 VALUES LESS THAN (1990, 1990),PARTITION c1 VALUES LESS THAN (2000, 2000),PARTITION c2 VALUES LESS THAN (MAXVALUE, MAXVALUE));

create tablegroup tg12 primary_zone = "z1;z2,z3" partition by range subpartition by list subpartition template (subpartition p0 values in (1,2,3), subpartition p1 values in (default)) (partition p0 values less than (1000), partition p1 values less than MAXVALUE);
# TODO：由于list分区create table时存在缺陷，对于二级分区的情况，不支持一级分区和二级分区的向量数不同，故先不测这种情况
#create tablegroup tg13 primary_zone = "z1;z2,z3" partition by range columns 2 subpartition by list subpartition template (subpartition p0 values in (1,2,3), subpartition p1 values in (default)) (partition p0 values less than (1000, 1000), partition p1 values less than (MAXVALUE, MAXVALUE)) ;
#create tablegroup tg14 primary_zone = "z1;z2,z3" partition by range subpartition by list columns 3 subpartition template (subpartition p0 values in (1,2,3), subpartition p1 values in (default)) (partition p0 values less than (1000), partition p1 values less than MAXVALUE);
#create tablegroup tg15 primary_zone = "z1;z2,z3" partition by range columns 2 subpartition by list columns 3 subpartition template (subpartition p0 values in (1,2,3), subpartition p1 values in (default)) (partition p0 values less than (1000, 1000), partition p1 values less than (MAXVALUE, MAXVALUE)) ;
create tablegroup tg13 primary_zone = "z1;z2,z3" partition by range columns 1 subpartition by list subpartition template (subpartition p0 values in (1,2,3), subpartition p1 values in (default)) (partition p0 values less than (1000), partition p1 values less than (MAXVALUE)) ;
create tablegroup tg14 primary_zone = "z1;z2,z3" partition by range subpartition by list columns 1 subpartition template (subpartition p0 values in (1,2,3), subpartition p1 values in (default)) (partition p0 values less than (1000), partition p1 values less than MAXVALUE);
create tablegroup tg15 primary_zone = "z1;z2,z3" partition by range columns 1 subpartition by list columns 1 subpartition template (subpartition p0 values in (1,2,3), subpartition p1 values in (default)) (partition p0 values less than (1000), partition p1 values less than (MAXVALUE)) ;

# 以下是不支持动态增删分区的tablegroup类型
create tablegroup tg_fail_1 primary_zone = "z1;z2,z3";
create tablegroup tg_fail_2 primary_zone = "z1;z2,z3" partition by hash partitions 2;
create tablegroup tg_fail_3 primary_zone = "z1;z2,z3" partition by key 1 partitions 2;
create tablegroup tg_fail_4 primary_zone = "z1;z2,z3" partition by key 2 partitions 2;
create tablegroup tg_fail_5 primary_zone = "z1;z2,z3" partition by hash subpartition by range subpartition template (SUBPARTITION p0 VALUES LESS THAN (1990),  SUBPARTITION p1 VALUES LESS THAN (2000),  SUBPARTITION p2 VALUES LESS THAN MAXVALUE) partitions 2;
create tablegroup tg_fail_6 primary_zone = "z1;z2,z3" partition by hash subpartition by range columns 1 subpartition template (SUBPARTITION p0 VALUES LESS THAN (1990),  SUBPARTITION p1 VALUES LESS THAN (2000),  SUBPARTITION p2 VALUES LESS THAN (MAXVALUE)) partitions 2;
create tablegroup tg_fail_7 primary_zone = "z1;z2,z3" partition by hash subpartition by range columns 2 subpartition template (SUBPARTITION p0 VALUES LESS THAN (1990, 1990),  SUBPARTITION p1 VALUES LESS THAN (2000, 2000),  SUBPARTITION p2 VALUES LESS THAN (MAXVALUE, MAXVALUE)) partitions 2;
create tablegroup tg_fail_8 primary_zone = "z1;z2,z3" partition by key 1 subpartition by range subpartition template (SUBPARTITION p0 VALUES LESS THAN (1990),  SUBPARTITION p1 VALUES LESS THAN (2000),  SUBPARTITION p2 VALUES LESS THAN MAXVALUE) partitions 2;
create tablegroup tg_fail_9 primary_zone = "z1;z2,z3" partition by key 2 subpartition by range subpartition template (SUBPARTITION p0 VALUES LESS THAN (1990),  SUBPARTITION p1 VALUES LESS THAN (2000),  SUBPARTITION p2 VALUES LESS THAN MAXVALUE) partitions 2;
create tablegroup tg_fail_10 primary_zone = "z1;z2,z3" partition by key 1 subpartition by range columns 1 subpartition template (SUBPARTITION p0 VALUES LESS THAN (1990),  SUBPARTITION p1 VALUES LESS THAN (2000),  SUBPARTITION p2 VALUES LESS THAN MAXVALUE) partitions 2;
create tablegroup tg_fail_11 primary_zone = "z1;z2,z3" partition by key 1 subpartition by range columns 2 subpartition template (SUBPARTITION p0 VALUES LESS THAN (1990, 1990),  SUBPARTITION p1 VALUES LESS THAN (2000, 2000),  SUBPARTITION p2 VALUES LESS THAN (MAXVALUE, MAXVALUE)) partitions 2;
create tablegroup tg_fail_12 primary_zone = "z1;z2,z3" partition by key 2 subpartition by range columns 1 subpartition template (SUBPARTITION p0 VALUES LESS THAN (1990),  SUBPARTITION p1 VALUES LESS THAN (2000),  SUBPARTITION p2 VALUES LESS THAN MAXVALUE) partitions 2;
create tablegroup tg_fail_13 primary_zone = "z1;z2,z3" partition by key 2 subpartition by range columns 2 subpartition template (SUBPARTITION p0 VALUES LESS THAN (1990, 1990),  SUBPARTITION p1 VALUES LESS THAN (2000, 2000),  SUBPARTITION p2 VALUES LESS THAN (MAXVALUE, MAXVALUE)) partitions 2;

create tablegroup tg_fail_14 primary_zone = "z1;z2,z3" partition by list (partition p0 values in (2,1,10), partition p1 values in (7,9), partition p2 values in (default));
create tablegroup tg_fail_15 primary_zone = "z1;z2,z3" partition by list columns 2 (partition p0 values in (('10',1), ('3',8), ('7',9)), partition p1 values in (('2', 1), ('3',9)));

create tablegroup tg_fail_16 primary_zone = "z1;z2,z3" partition by list subpartition by hash subpartitions 2 (partition p0 values in (1,2,3), partition p1 values in (default));
create tablegroup tg_fail_17 primary_zone = "z1;z2,z3" partition by list subpartition by key 2 subpartitions 2 (partition p0 values in (1,2,3), partition p1 values in (default));
create tablegroup tg_fail_18 primary_zone = "z1;z2,z3" partition by list subpartition by range subpartition template (subpartition p0 values less than (1000), subpartition p1 values less than MAXVALUE) (partition p0 values in (1,2,3), partition p1 values in (default));
# TODO：由于list分区create table时存在缺陷，对于二级分区的情况，不支持一级分区和二级分区的向量数不同，故先不测这种情况
#create tablegroup tg_fail_19 primary_zone = "z1;z2,z3" partition by list subpartition by range columns 2 subpartition template (subpartition p0 values less than (1000, 1000), subpartition p1 values less than (MAXVALUE, MAXVALUE)) (partition p0 values in (1,2,3), partition p1 values in (default));
create tablegroup tg_fail_19 primary_zone = "z1;z2,z3" partition by list subpartition by range columns 1 subpartition template (subpartition p0 values less than (1000), subpartition p1 values less than (MAXVALUE)) (partition p0 values in (1,2,3), partition p1 values in (default));

create tablegroup tg_fail_20 primary_zone = "z1;z2,z3" partition by list columns 3 subpartition by hash subpartitions 2 (partition p0 values in ((1,2,3)), partition p1 values in (default));

create tablegroup tg_fail_21 primary_zone = "z1;z2,z3" partition by list columns 3 subpartition by key 2 subpartitions 2 (partition p0 values in ((1,2,3)), partition p1 values in (default));

# TODO：由于list分区create table时存在缺陷，对于二级分区的情况，不支持一级分区和二级分区的向量数不同，故先不测这种情况
#create tablegroup tg_fail_22 partition by list columns 3 subpartition by range subpartition template (subpartition p0 values less than (1000), subpartition p1 values less than MAXVALUE) (partition p0 values in (1,2,3), partition p1 values in (default));
#create tablegroup tg_fail_23 partition by list columns 3 subpartition by range columns 2 subpartition template (subpartition p0 values less than (1000, 1000), subpartition p1 values less than (MAXVALUE, MAXVALUE)) (partition p0 values in (1,2,3), partition p1 values in (default));
create tablegroup tg_fail_22 primary_zone = "z1;z2,z3" partition by list columns 1 subpartition by range subpartition template (subpartition p0 values less than (1000), subpartition p1 values less than MAXVALUE) (partition p0 values in (1,2,3), partition p1 values in (default));
create tablegroup tg_fail_23 primary_zone = "z1;z2,z3" partition by list columns 1 subpartition by range columns 1 subpartition template (subpartition p0 values less than (1000), subpartition p1 values less than (MAXVALUE)) (partition p0 values in (1,2,3), partition p1 values in (default));

create tablegroup tg_fail_24 primary_zone = "z1;z2,z3" partition by hash subpartition by list subpartition template (subpartition p0 values in (1,2,3), subpartition p1 values in (default)) partitions 2;

create tablegroup tg_fail_25 primary_zone = "z1;z2,z3" partition by key 2 subpartition by list subpartition template (subpartition p0 values in (1,2,3), subpartition p1 values in (default)) partitions 2;

create tablegroup tg_fail_26 primary_zone = "z1;z2,z3" partition by hash subpartition by list columns 3 subpartition template (subpartition p0 values in ((1,2,3)), subpartition p1 values in (default)) partitions 2;

create tablegroup tg_fail_27 primary_zone = "z1;z2,z3" partition by key 2 subpartition by list columns 3 subpartition template (subpartition p0 values in ((1,2,3)), subpartition p1 values in (default)) partitions 2;


let $index = 1;
let $max_index = 27;
while($index <= $max_index)
{
  --error 1235, 1512, 1505, 1507
  eval alter tablegroup tg_fail_$index drop partition (c0);
  --error 5598, 1235, 1512, 1505, 1653, 1507
  eval alter tablegroup tg_fail_$index add partition (partition c4 values less than (3000));
  inc $index;
}

# case 1: drop partition 场景
# case 1.1: partition name should exist
--error 1507
alter tablegroup tg0 drop partition (c9, c0);
--error 1507
alter tablegroup tg0 drop partition (c9);
--error 1507
alter tablegroup tg1 drop partition (c9, c0);
--error 1507
alter tablegroup tg1 drop partition (c9);
--error 1507
alter tablegroup tg2 drop partition (c9, c0);
--error 1507
alter tablegroup tg2 drop partition (c9);

# case 1.2: part_name duplicate
--error 1517
alter tablegroup tg0 drop partition (c0, c0);
--error 1517
alter tablegroup tg1 drop partition (c0, c0);
--error 1517
alter tablegroup tg2 drop partition (c0, c0);

# case 1.3: 正常删除分区
let $tg_name = "tg0";
source include/check_tablegroup_schema.inc;
alter tablegroup tg0 drop partition (c2, c0);
let $tg_name = "tg0";
source include/check_tablegroup_schema.inc;

let $tg_name = "tg1";
source include/check_tablegroup_schema.inc;
alter tablegroup tg1 drop partition (c2, c0);
let $tg_name = "tg1";
source include/check_tablegroup_schema.inc;

let $tg_name = "tg2";
source include/check_tablegroup_schema.inc;
alter tablegroup tg2 drop partition (c2, c0);
let $tg_name = "tg2";
source include/check_tablegroup_schema.inc;

# case 1.4: can't drop all partitions
--error 1508
alter tablegroup tg0 drop partition (c1);
--error 1508
alter tablegroup tg1 drop partition (c1);
--error 1508
alter tablegroup tg2 drop partition (c1);

# case 2: add partittion 场景
# case 2.1: partition name should not exist
--error 1517
alter tablegroup tg0 add partition (partition c1 values less than (3000));
--error 1517
alter tablegroup tg0 add partition (partition c1 values less than (3000), partition c2 values less than (4000));
--error 1517
alter tablegroup tg0 add partition (partition c2 values less than (3000), partition c2 values less than (4000));
--error 1517
alter tablegroup tg1 add partition (partition c1 values less than (3000));
--error 1517
alter tablegroup tg1 add partition (partition c1 values less than (3000), partition c2 values less than (4000));
--error 1517
alter tablegroup tg1 add partition (partition c2 values less than (3000), partition c2 values less than (4000));
--error 1517
alter tablegroup tg2 add partition (partition c1 values less than (3000, '3000'));
--error 1517
alter tablegroup tg2 add partition (partition c1 values less than (3000, '3000'), partition c2 values less than (4000, '4000'));
--error 1517
alter tablegroup tg2 add partition (partition c2 values less than (3000, '3000'), partition c2 values less than (4000, '4000'));

# case 2.2: 非递增
--error 1493
alter tablegroup tg0 add partition (partition c4 values less than(40));
--error 1493
alter tablegroup tg0 add partition (partition c4 values less than(40), partition c5 values less than (50));
--error 1493
alter tablegroup tg0 add partition (partition c4 values less than(3000), partition c5 values less than (50));
--error 1493
alter tablegroup tg0 add partition (partition c4 values less than(4000), partition c5 values less than (3000));

--error 1493
alter tablegroup tg1 add partition (partition c4 values less than(40));
--error 1493
alter tablegroup tg1 add partition (partition c4 values less than(40), partition c5 values less than (50));
--error 1493
alter tablegroup tg1 add partition (partition c4 values less than(3000), partition c5 values less than (50));
--error 1493
alter tablegroup tg1 add partition (partition c4 values less than(4000), partition c5 values less than (3000));

--error 1493
alter tablegroup tg2 add partition (partition c4 values less than(40, '1000'));
--error 1493
alter tablegroup tg2 add partition (partition c4 values less than(40, '3000'));
--error 1493
alter tablegroup tg2 add partition (partition c4 values less than(40, '1000'), partition c5 values less than (50, '1001'));
--error 1493
alter tablegroup tg2 add partition (partition c4 values less than(3000, '1000'), partition c5 values less than (50, '1001'));
--error 1493
alter tablegroup tg2 add partition (partition c4 values less than(40, '1000'), partition c5 values less than (3000, '1001'));
--error 1493
alter tablegroup tg2 add partition (partition c4 values less than(4000, '4000'), partition c5 values less than (50, '1001'));
--error 1493
alter tablegroup tg2 add partition (partition c4 values less than(4000, '4000'), partition c5 values less than (3000, '3000'));

# case 2.3: 向量数不匹配
--error 1653
alter tablegroup tg0 add partition (partition c4 values less than(40, 40), partition c5 values less than (50, 50));
--error 1653
alter tablegroup tg1 add partition (partition c4 values less than(40), partition c5 values less than (50, 50));
--error 1653
alter tablegroup tg2 add partition (partition c4 values less than(4000), partition c5 values less than (5000));
--error 1653
alter tablegroup tg0 add partition (partition c4 values less than(40), partition c5 values less than (50, 50));
--error 1653
alter tablegroup tg1 add partition (partition c4 values less than(40), partition c5 values less than (50, 50));
--error 1653
alter tablegroup tg2 add partition (partition c4 values less than(4000), partition c5 values less than (5000, '5000'));

# case 2.4: 类型不匹配
# range分区仅支持int类型
--error 1697
alter tablegroup tg0 add partition (partition c4 values less than('40'), partition c5 values less than ('50'));
--error 1654
alter tablegroup tg0 add partition (partition c4 values less than('40'), partition c5 values less than (50));
# range columns
--error 1654
alter tablegroup tg1 add partition (partition c2 values less than ('3000'));
--error 1654
alter tablegroup tg2 add partition (partition c2 values less than ('3000' , '4000'));
--error 1654
alter tablegroup tg2 add partition (partition c2 values less than ('3000' , 4000));
--error 1654
alter tablegroup tg2 add partition (partition c2 values less than (3000 , 4000));

# case 2.5: part_name duplicate
--error 1517
alter tablegroup tg0 add partition (partition c3 values less than(3000), partition c3 values less than(4000));
--error 1517
alter tablegroup tg1 add partition (partition c3 values less than(3000), partition c3 values less than(4000));
--error 1517
alter tablegroup tg2 add partition (partition c3 values less than(3000, '3000'), partition c3 values less than(4000, '4000'));

# case 2.6: 正常add partition
let $tg_name = "tg0";
source include/check_tablegroup_schema.inc;
alter tablegroup tg0 add partition (partition c0 values less than(3000));
let $tg_name = "tg0";
source include/check_tablegroup_schema.inc;

let $tg_name = "tg1";
source include/check_tablegroup_schema.inc;
alter tablegroup tg1 add partition (partition c0 values less than(3000));
let $tg_name = "tg1";
source include/check_tablegroup_schema.inc;

let $tg_name = "tg2";
source include/check_tablegroup_schema.inc;
alter tablegroup tg2 add partition (partition c0 values less than(3000, '3000'));
let $tg_name = "tg2";
source include/check_tablegroup_schema.inc;

let $tg_name = "tg0";
source include/check_tablegroup_schema.inc;
alter tablegroup tg0 add partition (partition c2 values less than(4000), partition c3 values less than(5000));
let $tg_name = "tg0";
source include/check_tablegroup_schema.inc;

let $tg_name = "tg1";
source include/check_tablegroup_schema.inc;
alter tablegroup tg1 add partition (partition c2 values less than(4000), partition c3 values less than(5000));
let $tg_name = "tg1";
source include/check_tablegroup_schema.inc;

let $tg_name = "tg2";
source include/check_tablegroup_schema.inc;
alter tablegroup tg2 add partition (partition c2 values less than(4000, '4000'), partition c3 values less than(5000, '5000'));
let $tg_name = "tg2";
source include/check_tablegroup_schema.inc;

# case 2.7: 二级分区的情况
let $index = 3;
let $max_index = 8;
while($index <= $max_index)
{
  let $tg_name = "tg$index";
  source include/check_tablegroup_schema.inc;

  eval alter tablegroup tg$index drop partition (c2);

  let $tg_name = "tg$index";
  source include/check_tablegroup_schema.inc;

  eval alter tablegroup tg$index add partition (partition c2 values less than (3000));

  let $tg_name = "tg$index";
  source include/check_tablegroup_schema.inc;
  inc $index;
}

let $index = 9;
let $max_index = 11;
while($index <= $max_index)
{
  let $tg_name = "tg$index";
  source include/check_tablegroup_schema.inc;

  eval alter tablegroup tg$index drop partition (c2);

  let $tg_name = "tg$index";
  source include/check_tablegroup_schema.inc;
  eval alter tablegroup tg$index add partition (partition c2 values less than (3000, 3000));

  let $tg_name = "tg$index";
  source include/check_tablegroup_schema.inc;
  inc $index;
}

# case 3: 测试批量增删tablegroup中table的分区

# case 3.1: tablegroup分区方式发生变更，table加入tablegroup以新的分区方式为准
# tg0 原始分区方式： (PARTITION p0 VALUES LESS THAN (1990),PARTITION p1 VALUES LESS THAN (2000), PARTITION p2 VALUES LESS THAN MAXVALUE)
# tg0 目前分区方式： (partition c1 values less than (2000), partition c0 values less than (3000), partition c2 values less than (4000), partition c3 values less than (5000))

# case 3.1.1: create table加入tablegroup的方式
--error 4179
create table t_create_0(c1 int primary key, c2 int) tablegroup = "tg0" partition by range(c1) (PARTITION p0 VALUES LESS THAN (2000),PARTITION p1 VALUES LESS THAN (3000), PARTITION p2 VALUES LESS THAN (4000), PARTITION p3 VALUES LESS THAN (6000));
--error 4179
create table t_create_0(c1 int primary key, c2 int) tablegroup = "tg0" partition by range(c1) (PARTITION p0 VALUES LESS THAN (1990),PARTITION p1 VALUES LESS THAN (2000), PARTITION p2 VALUES LESS THAN MAXVALUE);
create table t_create_0(c1 int primary key, c2 int) tablegroup = "tg0" partition by range(c1) (PARTITION p0 VALUES LESS THAN (2000),PARTITION p1 VALUES LESS THAN (3000), PARTITION p2 VALUES LESS THAN (4000), PARTITION p3 VALUES LESS THAN (5000));

# case 3.1.2: alter table加入tablegroup的方式
create table t_alter_1_0(c1 int primary key, c2 int) partition by range(c1) (PARTITION p0 VALUES LESS THAN (2000),PARTITION p1 VALUES LESS THAN (3000), PARTITION p2 VALUES LESS THAN (4000), PARTITION p3 VALUES LESS THAN (6000));
create table t_alter_2_0(c1 int primary key, c2 int) partition by range(c1) (PARTITION p0 VALUES LESS THAN (1990),PARTITION p1 VALUES LESS THAN (2000), PARTITION p2 VALUES LESS THAN MAXVALUE);
create table t_alter_3_0(c1 int primary key, c2 int) partition by range(c1) (PARTITION p0 VALUES LESS THAN (2000),PARTITION p1 VALUES LESS THAN (3000), PARTITION p2 VALUES LESS THAN (4000), PARTITION p3 VALUES LESS THAN (5000));
--error 4179
alter table t_alter_1_0 set tablegroup = "tg0";
--error 4179
alter table t_alter_2_0 set tablegroup = "tg0";
alter table t_alter_3_0 set tablegroup = "tg0";

# case 3.1.3: add table加入tablegroup的方式
create table t_add_1_0(c1 int primary key, c2 int) partition by range(c1) (PARTITION p0 VALUES LESS THAN (2000),PARTITION p1 VALUES LESS THAN (3000), PARTITION p2 VALUES LESS THAN (4000), PARTITION p3 VALUES LESS THAN (6000));
create table t_add_2_0(c1 int primary key, c2 int) partition by range(c1) (PARTITION p0 VALUES LESS THAN (1990),PARTITION p1 VALUES LESS THAN (2000), PARTITION p2 VALUES LESS THAN MAXVALUE);
create table t_add_3_0(c1 int primary key, c2 int) partition by range(c1) (PARTITION p0 VALUES LESS THAN (2000),PARTITION p1 VALUES LESS THAN (3000), PARTITION p2 VALUES LESS THAN (4000), PARTITION p3 VALUES LESS THAN (5000));
--error 4179
alter tablegroup tg0 add t_add_1_0;
--error 4179
alter tablegroup tg0 add t_add_2_0;
alter tablegroup tg0 add t_add_3_0;

# case 3.2: 检查drop/add partition后，tablegroup中table的分区方式是否发生变化
# case 3.2.1: 第一次drop/add partition
# 检查
let $tg_name = "tg0";
source include/check_tablegroup_schema.inc;
show create table t_create_0;
show create table t_add_3_0;
show create table t_alter_3_0;
# drop partition
alter tablegroup tg0 drop partition (c1);
# 检查
let $tg_name = "tg0";
source include/check_tablegroup_schema.inc;
show create table t_create_0;
show create table t_add_3_0;
show create table t_alter_3_0;
# add partition
alter tablegroup tg0 add partition (partition c1 values less than (6000));
# 检查
let $tg_name = "tg0";
source include/check_tablegroup_schema.inc;
show create table t_create_0;
show create table t_add_3_0;
show create table t_alter_3_0;

# case 3.2.2: 第二次drop/add partition
# drop partition
alter tablegroup tg0 drop partition (c2);
# 检查
let $tg_name = "tg0";
source include/check_tablegroup_schema.inc;
show create table t_create_0;
show create table t_add_3_0;
show create table t_alter_3_0;
# add partition
alter tablegroup tg0 add partition (partition c2 values less than (7000));
# 检查
let $tg_name = "tg0";
source include/check_tablegroup_schema.inc;
show create table t_create_0;
show create table t_add_3_0;
show create table t_alter_3_0;
