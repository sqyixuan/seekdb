ob1=OBI(cluster=3:3:3, proxy_num=0, init_unit_cpu=2);
ob1.reboot;
ob1.mysql alter system set resource_hard_limit=900;
ob1.mysql alter system set resource_soft_limit=800;
ob1.mysql alter system set enable_rebalance = 'false';
ob1.mysql alter system set enable_rereplication = 'false';
ob1.mysql alter system set debug_sync_timeout = '100s';
ob1.mysql alter system set enable_auto_leader_switch = 'False';
ob1.mysql alter system set balancer_idle_time = '10s';
ob1.mysql alter system set server_permanent_offline_time = '20s';
ob1.mysql alter system set replica_safe_remove_time='1m';
ob1.mysql alter system set server_data_copy_out_concurrency = 5;
ob1.mysql alter system set server_data_copy_in_concurrency = 5;
ob1.mysql CREATE RESOURCE UNIT unit_1 MAX_CPU $cpu, MAX_MEMORY $memory, MAX_IOPS $iops, MAX_DISK_SIZE $disk, MAX_SESSION_NUM $session, MIN_CPU=1, MIN_MEMORY=$min_memory, MIN_IOPS=128;
ob1.mysql CREATE RESOURCE POOL pool_1 UNIT = 'unit_1', UNIT_NUM = 2, ZONE_LIST = ('z1', 'z2', 'z3');
ob1.mysql CREATE TENANT tenant_1 RESOURCE_POOL_LIST = ('pool_1'), locality='F@z1,F@z2,F@z3,R{all_server}@z3' set ob_tcp_invited_nodes='%';
ob1.create_client tenant=tenant_1,user=root,passwd=,database=test;
use test;
CREATE TABLE __my_dummy (pk int primary key, val int);
ob1.create_client tenant=sys,user=root,passwd=,database=oceanbase;
ob1.check_until_timeout select count(*) c from __all_virtual_meta_table where zone='z3' and replica_type = 0 and concat(svr_ip, ':', svr_port) = '$f_svr_host', 1, 180;
'check full exists at old unit ok'
ob1.check_until_timeout select count(*) c from __all_virtual_meta_table where zone='z3' and replica_type = 0 and concat(svr_ip, ':', svr_port) != '$f_svr_host', 0, 180;
'check full not exists at anywhere else ok'
$r_obi.force_stop;
'server stopped, trigger unit migration to idle server'
ob1.mysql alter system set enable_rereplication = 'true';
ob1.mysql alter system set enable_rebalance = 'true';
'check if lost replica migrated to new server'
ob1.check_until_timeout select count(*) c from __all_virtual_meta_table where zone='z3' and replica_type = 0 and concat(svr_ip, ':', svr_port) != '$f_svr_host', 1, 1600;
'replica migrated to new server ok'
ob1.check_until_timeout select count(*) c from __all_virtual_meta_table where zone='z3', 2, 10;
'check system in new stable state ok'
