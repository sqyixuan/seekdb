# owner: wenduo.swd
# description:
# 本case用于测试initial leader的选取，用以验证

ob1=OBI(cluster=1:1:1, proxy_num=0, init_unit_cpu=2, node_cpu_count=64,node_cpu_reserved=2,memory_size_limit=262144);
ob1.reboot;


##新建租户
ob1.mysql create resource unit box1 max_cpu 5, max_memory 1080000000, max_iops 100000, max_disk_size 1080000000, max_session_num 64, MIN_CPU 5, MIN_MEMORY=1080000000, MIN_IOPS=128;
ob1.mysql create resource pool pool_large unit = 'box1', unit_num = 1, zone_list = ('z1', 'z2', 'z3');
ob1.mysql create tenant tt1 replica_num = 3,primary_zone='z1;z3;z2', resource_pool_list=('pool_large'), locality = "L@z1,F@z2,F@z3" set ob_tcp_invited_nodes='%';

sleep 2;
let $tt1ip= deploy_get_value(ob1.select select svr_ip from __all_unit where zone='z1' and resource_pool_id = 1001 limit 1, svr_ip, 1);
let $port= deploy_get_value(ob1.select select svr_port from __all_unit where zone='z1' and resource_pool_id = 1001 limit 1, svr_port, 1);
let $tt1port = deploy_get_value(ob1.select select inner_port from __all_server where svr_ip='$tt1ip' and svr_port = $port, inner_port, 1);

connect(tt1_conn, $tt1ip, root@tt1,,test, $tt1port);
connection tt1_conn;
eval create table test1(c1 int primary key, c2 int);

let $obs0ip = deploy_get_value(ob1.z3.obs0.ip);
let $obs0sqlport = deploy_get_value(ob1.z3.obs0.mysql_port);

connect(conn, $obs0ip, root,,test, $obs0sqlport);
connection conn;

sleep 10;

let $zone = deploy_get_value(ob1.select select zone from oceanbase.__all_virtual_meta_table where role = 1, zone, 1);
echo $zone;

