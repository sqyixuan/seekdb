# create table with empty locality
connection tt2_conn;
eval create table tt4_test(pk int primary key);
eval create table tt5_test(pk int primary key);
eval create table tt6_test(pk int primary key);
# alter table locality
connection tt2_conn;
eval alter table tt4_test locality = "F@z1,F@z2,L,R{ALL_SERVER}@z3";
# show locality
connection sys_conn;
let $tt2_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name = "tt2", tenant_id, 1);
let $locality = deploy_get_value(ob1.select select locality from oceanbase.__all_virtual_table where tenant_id = $tt2_id order by table_id, locality, 1);
echo $locality;
ob1.check_until_timeout select count(*) c from oceanbase.__all_rootservice_job where job_type="ALTER_TABLE_LOCALITY" and job_status="SUCCESS" ,1,50;
# alter table locality
connection tt2_conn;
eval alter table tt5_test locality = "F@z1,F@z2,L,R@z3";
# show locality
connection sys_conn;
let $tt2_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name = "tt2", tenant_id, 1);
let $locality = deploy_get_value(ob1.select select locality from oceanbase.__all_virtual_table where tenant_id = $tt2_id order by table_id, locality, 2);
echo $locality;
ob1.check_until_timeout select count(*) c from oceanbase.__all_rootservice_job where job_type="ALTER_TABLE_LOCALITY" and job_status="SUCCESS" ,2,60;
