# owner: wenduo.swd
# description:
# 本case用于调整locality，添加只读副本，本例仅测试ddl

ob1=OBI(cluster=3:3:3, proxy_num=1, init_unit_cpu=0);
ob1.reboot;

ob1.mysql alter system set enable_rebalance = false;
ob1.mysql alter system set enable_rereplication = true;


##新建租户1
ob1.mysql create resource unit box1 max_cpu 5, max_memory 1080000000, max_iops 100000, max_disk_size 1080000000, max_session_num 64, MIN_CPU 5, MIN_MEMORY=1080000000, MIN_IOPS=128;
#ob1.mysql create resource pool pool_large unit = 'box1', unit_num = 3, zone_list = ('z1', 'z2', 'z3');
#ob1.mysql create tenant tt1 replica_num = 3,primary_zone='z1,z2', resource_pool_list=('pool_large'), locality = "F{2},L@default_region" set ob_tcp_invited_nodes='%';

##新建租户2
ob1.mysql create resource pool pool_largex unit = 'box1', unit_num = 3, zone_list = ('z1', 'z2', 'z3');
ob1.mysql create tenant tt2 replica_num = 3,primary_zone='z1,z2', resource_pool_list=('pool_largex'), locality = "F@z1,F@z2,L@z3" set ob_tcp_invited_nodes='%';

sleep 2;
let $proxy_ip = deploy_get_value(ob1.proxy0.ip);
let $proxy_port = deploy_get_value(ob1.proxy0.port);

connect(sys_conn, $proxy_ip, root@sys,,test, $proxy_port);
#connect(tt1_conn, $proxy_ip, root@tt1,,test, $proxy_port);
connect(tt2_conn, $proxy_ip, root@tt2,,test, $proxy_port);
