ob1=OBI(cluster=1:1:1:1:1:1:1,proxy_num=0,init_unit_cpu=0, locality=SZ:SZ:SH:SH:HZ:SZ:SZ);
ob1.z6.obs0.set status=disable;
ob1.z7.obs0.set status=disable;
ob1.reboot;
ob1.mysql alter system set balancer_idle_time = '10s';
ob1.z6.add;
ob1.z6.start_zone;
ob1.z6.obs0.set status=enable;
ob1.z6.obs0.start;
ob1.z6.obs0.add;
ob1.z7.add;
ob1.z7.start_zone;
ob1.z7.obs0.set status=enable;
ob1.z7.obs0.start;
ob1.z7.obs0.add;
ob1.mysql create resource pool pool1 unit = 'sys_unit_config', unit_num = 1, zone_list = ('z1', 'z2', 'z3', 'z4', 'z5');
ob1.mysql create resource pool pool2 unit = 'sys_unit_config', unit_num = 1, zone_list = ('z6', 'z7');
ob1.mysql create tenant tt resource_pool_list=('pool1'), primary_zone = 'z1', locality = "F@z1,F@z2,F@z3,F@z4,F@z5" set ob_tcp_invited_nodes='%';
ob1.mysql alter tenant tt locality = "F@z1,F@z2,F@z3,F@z4,R@z5";
select job_status, tenant_id, sql_text from oceanbase.__all_rootservice_job order by job_id desc limit 1;
job_status	tenant_id	sql_text
INPROGRESS	1001	alter tenant tt locality = 'F@z1,F@z2,F@z3,F@z4,R@z5'
ob1.check_until_timeout select count(*) c from oceanbase.__all_tenant where tenant_id = $tenant_id and previous_locality != '', 0, 600;
select job_status, tenant_id, sql_text from oceanbase.__all_rootservice_job order by job_id desc limit 1;
job_status	tenant_id	sql_text
SUCCESS	1001	alter tenant tt locality = 'F@z1,F@z2,F@z3,F@z4,R@z5'
