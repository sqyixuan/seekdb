ob1=OBI(cluster=3:3:3, init_unit_cpu=2, proxy_num=0, ct_num = 0);
ob1.reboot;
ob1.mysql alter system set resource_hard_limit=900;
ob1.mysql alter system set resource_soft_limit=800;
ob1.mysql alter system set debug_sync_timeout = '100s';
ob1.mysql alter system set enable_auto_leader_switch = 'False';
ob1.mysql alter system set balancer_idle_time = '20s';
ob1.mysql alter system set server_data_copy_out_concurrency = 20;
ob1.mysql alter system set server_data_copy_in_concurrency = 20;
ob1.mysql CREATE RESOURCE UNIT unit_$case_index MAX_CPU $cpu, MAX_MEMORY $memory, MAX_IOPS $iops, MAX_DISK_SIZE $disk, MAX_SESSION_NUM $session, MIN_CPU=1, MIN_MEMORY=$min_memory, MIN_IOPS=128;
ob1.mysql CREATE RESOURCE POOL pool_$case_index UNIT = 'unit_$case_index', UNIT_NUM = 3, ZONE_LIST = ('z1','z2','z3');
ob1.mysql CREATE TENANT tenant_$case_index RESOURCE_POOL_LIST = ('pool_$case_index'), locality='F@z1,F@z2,F@z3,R{2}@z3', primary_zone='z1' set ob_tcp_invited_nodes='%';
create table test2(c1 int primary key, c2 int) partition by hash(c1) partitions 2;
ob1.mysql update oceanbase.__all_root_table set data_version = 5 where table_id = $t2_id and tenant_id = $tenant_id and partition_id = 0 and concat(svr_ip,":",svr_port) in ('$src_ip:$src_port', '$dest_ip:$dest_port');
ob1.mysql alter system move replica partition_id='0%2@$t2_id' source = '$src_ip:$src_port' destination = '$dest_ip:$dest_port';
ob1.check_until_timeout select count(*) from __all_rootservice_event_history where value1 like '%{tid:$t2_id, partition_id:0, part_cnt:%' and name4='result', 1,60;
ob1.check_until_timeout select count(*) c from __all_root_table where table_id = $t2_id and tenant_id = $tenant_id and data_version = 5, 0, 30;
