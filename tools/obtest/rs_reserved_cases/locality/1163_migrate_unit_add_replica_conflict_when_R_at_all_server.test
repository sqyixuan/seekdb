# author: msy164651
# owner: rongxuan.lc
# 测试： z1 上一个R所在unit被迁移到另外一个server,
#        但副本还没来得及迁移的时候会被在新unit补充副本
#        导致后面的负载均衡迁移unit副本失败
# 要点： issue 

ob1=OBI(cluster=3:3:3, init_unit_cpu=2, proxy_num=0, ct_num=0, locality=hz:hz:hz);
ob1.reboot;

ob1.mysql alter system set resource_hard_limit=900;
ob1.mysql alter system set resource_soft_limit=800;
ob1.mysql alter system set debug_sync_timeout = '100s';
ob1.mysql alter system set enable_auto_leader_switch = 'False';
ob1.mysql alter system set enable_rebalance = 'true';
ob1.mysql alter system set enable_rereplication = 'true';
ob1.mysql alter system set balancer_idle_time = '10s';
ob1.mysql alter system set server_data_copy_out_concurrency = 20;
ob1.mysql alter system set server_data_copy_in_concurrency = 20;

let $cpu = 1;
let $memory = 1073741824;
let $min_memory = 1073741824;
let $disk = 536870912;
let $iops = 100000;
let $session = 64;

ob1.mysql CREATE RESOURCE UNIT unit_1 MAX_CPU $cpu, MAX_MEMORY $memory, MAX_IOPS $iops, MAX_DISK_SIZE $disk, MAX_SESSION_NUM $session, MIN_CPU=1, MIN_MEMORY=$min_memory, MIN_IOPS=128;
ob1.mysql CREATE RESOURCE POOL pool_1 UNIT = 'unit_1', UNIT_NUM = 2, ZONE_LIST = ('z1','z2','z3');
ob1.mysql CREATE TENANT tenant_1 RESOURCE_POOL_LIST = ('pool_1'), locality='F@z1,R{all_server}@z1,F@z2,R{all_server}@z2,F@z3,R{all_server}@z3', PRIMARY_ZONE = 'z1' set ob_tcp_invited_nodes='%';
sleep 3;
let $tenant_id = deploy_get_value(ob1.select select tenant_id from __all_tenant where tenant_name = "tenant_1", tenant_id, 1);

ob1.create_client tenant=tenant_1,user=root,passwd=,database=test;
create table test1(c1 int primary key, c2 int) partition by hash(c1) partitions 2;


ob1.create_client tenant=sys,user=root,passwd=,database=oceanbase;
let $t1_id = deploy_get_value(ob1.select select table_id from __all_virtual_table where table_name = "test1" and tenant_id = "$tenant_id", table_id, 1);

let $unit_old_svr = deploy_get_value(ob1.select select concat(svr_ip, ":", svr_port) unit_old_svr FROM __all_virtual_meta_table where tenant_id = "$tenant_id" AND table_id = $t1_id AND partition_id=0 AND zone = 'z2' AND role = 2 AND replica_type = 16,  unit_old_svr, 1);
# 没有 unit 的 svr
let $unit_dest_svr = deploy_get_value(ob1.select  select concat(svr_ip, ":", svr_port) dest_svr from __all_server WHERE zone = 'z2' EXCEPT select concat(svr_ip, ":", svr_port) dest_svr FROM __all_virtual_meta_table where tenant_id = "$tenant_id" AND table_id = $t1_id AND partition_id=0 AND zone = 'z2',  dest_svr, 1);
# 待迁移的 unit
let $unit_id = deploy_get_value(ob1.select select unit_id FROM __all_virtual_meta_table WHERE tenant_id = "$tenant_id" AND table_id = $t1_id AND partition_id=0 AND zone = 'z2' AND role = 2 AND replica_type = 16, unit_id, 1);
# 把 unit_id 迁移到 unit_dest_svr
ob1.mysql alter system migrate unit $unit_id destination = "$unit_dest_svr";

sleep 20;

# 还是 2 个副本，老 svr 上的 R 能够被删除
ob1.check_until_timeout select count(*) c from __all_virtual_meta_table where tenant_id = $tenant_id and table_id = $t1_id and partition_id = 0 and replica_type = 0 and zone = 'z2', 1, 120;
ob1.check_until_timeout select count(*) c from __all_virtual_meta_table where tenant_id = $tenant_id and table_id = $t1_id and partition_id = 0 and role = 2 and replica_type = 16 and zone = 'z2' and concat(svr_ip, ":", svr_port) = "$unit_old_svr", 0, 120;
ob1.check_until_timeout select count(*) c from __all_virtual_meta_table where tenant_id = $tenant_id and table_id = $t1_id and partition_id = 0 and role = 2 and replica_type = 16 and zone = 'z2' and concat(svr_ip, ":", svr_port) = "$unit_dest_svr", 1, 120;
