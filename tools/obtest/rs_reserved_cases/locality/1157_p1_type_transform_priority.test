# owner: rongxuan.lc
# description: 本case是为了……
#（2）当存在多个类型的副本转换工作时，RS会优先进行F类型的转换，然后才是L, 最后才是R

ob1=OBI(cluster=3:3:3, init_unit_cpu=0, proxy_num=0, ct_num = 0, locality=hz:hz:hz);
ob1.reboot;
let $case_index=1;

ob1.mysql alter system set resource_hard_limit=900;
ob1.mysql alter system set resource_soft_limit=800;
ob1.mysql alter system set debug_sync_timeout = '100s';
ob1.mysql alter system set enable_auto_leader_switch = 'False';
ob1.mysql alter system set balancer_idle_time = '20s';
ob1.mysql alter system set server_data_copy_out_concurrency = 20;
ob1.mysql alter system set server_data_copy_in_concurrency = 20;

let $cpu = 1;
let $memory = 1073741824;
let $min_memory = 1073741824;
let $disk = 536870912;
let $iops = 100000;
let $session = 64;

let $case_index=2;
ob1.mysql CREATE RESOURCE UNIT unit_$case_index MAX_CPU $cpu, MAX_MEMORY $memory, MAX_IOPS $iops, MAX_DISK_SIZE $disk, MAX_SESSION_NUM $session, MIN_CPU=1, MIN_MEMORY=$min_memory, MIN_IOPS=128;
ob1.mysql CREATE RESOURCE POOL pool_$case_index UNIT = 'unit_$case_index', UNIT_NUM = 3, ZONE_LIST = ('z1','z2','z3');
ob1.mysql CREATE TENANT tenant_$case_index RESOURCE_POOL_LIST = ('pool_$case_index'), locality='F@z1,L@z2,F@z3,R@z3', primary_zone='z1' set ob_tcp_invited_nodes='%';
sleep 3;
let $tenant_id = deploy_get_value(ob1.select select tenant_id from __all_tenant where tenant_name = "tenant_2", tenant_id, 1); 

ob1.create_client tenant=tenant_2,user=root,passwd=,database=test;
create tablegroup tg1 partition by hash partitions 21;
create table test2(c1 int primary key, c2 int) tablegroup = 'tg1' partition by hash(c1) partitions 21;
create table test3(c1 int primary key, c2 int) tablegroup = 'tg1' partition by hash(c1) partitions 21;
let $t2_id = deploy_get_value(ob1.select select table_id from __all_virtual_table where table_name = "test2" and tenant_id = "$tenant_id", table_id, 1);
let $t3_id = deploy_get_value(ob1.select select table_id from __all_virtual_table where table_name = "test3" and tenant_id = "$tenant_id", table_id, 1);

ob1.mysql alter system set enable_rebalance = 'false';
ob1.mysql alter system set enable_rereplication = 'false';

###将partition_id = 4的zone2 L-->F;  zone3 F-->L;
#等待RS先将L-->F; 然后执行F-->L；
ob_connect(sys_conn, ob1.z1.obs0, root,,oceanbase,USE_MYSQL_CONNECTOR);
connection sys_conn;
alter system set __balance_controller='{"ENABLE_TYPE_TRANSFORM":"false"}';
let $z2_addr = deploy_get_value(ob1.select select concat(svr_ip,":",svr_port) addr from __all_virtual_meta_table where table_id = $t3_id and tenant_id = $tenant_id and partition_id = 4 and zone='z2', addr, 1);
ob1.mysql alter system change replica partition_id='4%21@$t3_id' server='$z2_addr' change replica_type="F";
ob1.check_until_timeout select count(*) from __all_virtual_meta_table where table_id = $t3_id and tenant_id = $tenant_id and partition_id = 4 and zone='z2' and replica_type = 0,1, 60;

let $z3_addr = deploy_get_value(ob1.select select concat(svr_ip,":",svr_port) addr from __all_virtual_meta_table where table_id = $t3_id and tenant_id = $tenant_id and partition_id = 4 and zone='z3' and replica_type=0, addr, 1);
ob1.mysql alter system change replica partition_id='4%21@$t3_id' server='$z3_addr' change replica_type="L";
ob1.check_until_timeout select count(*) from __all_virtual_meta_table where table_id = $t3_id and tenant_id = $tenant_id and partition_id = 4 and zone='z3' and replica_type = 5,1, 60;

alter system set __balance_controller='';
##先检查zone3的F转换出来
ob1.check_until_timeout select count(*) from __all_virtual_meta_table where table_id = $t3_id and tenant_id = $tenant_id and partition_id = 4 and zone='z3' and replica_type=0, 1, 30;
##检查zone2的还是F;
let $count = deploy_get_value(ob1.select select count(*) c from __all_virtual_meta_table where table_id = $t3_id and tenant_id = $tenant_id and partition_id = 4 and zone='z2' and replica_type=0, c, 1);
if ($count == 1)
{
  echo "transform to F first;";
}

ob1.check_until_timeout select count(*) from __all_virtual_meta_table where table_id = $t3_id and tenant_id = $tenant_id and partition_id = 4 and zone='z2' and replica_type=5, 1, 60;


