# owner: yanmu.ztl
# owner group: rs
# description: 1.RS生成任务时检查locality是否发生变更，若发生变更则拒绝生成任务；
#              2.RS执行任务时重新计算quorum值，若quorum值发生变更，则拒绝执行任务。
#              

ob1=OBI(cluster=1:1:1, init_unit_cpu=0, proxy_num=0, ct_num=0, locality=hz:hz:hz);
ob1.reboot;

ob1.mysql alter system set enable_auto_leader_switch = 'false';
ob1.mysql alter system set enable_rebalance = 'true';
ob1.mysql alter system set enable_rereplication = 'true';
ob1.mysql alter system set balancer_idle_time = '10s';
ob1.mysql alter system set server_data_copy_out_concurrency = 20;
ob1.mysql alter system set server_data_copy_in_concurrency = 20;
ob1.mysql alter system set server_permanent_offline_time = '20s';
ob1.mysql alter system set replica_safe_remove_time = '1m';
ob1.mysql alter system set debug_sync_timeout = '100000s';
ob1.mysql alter system set balance_blacklist_failure_threshold = 0;

let $cpu = 1;
let $memory = 1073741824;
let $min_memory = 1073741824;
let $disk = 536870912;
let $iops = 100000;
let $session = 64;

let $rs = deploy_get_value(ob1.get_leader sys:oceanbase:__all_core_table:0);
let $rs_ip = deploy_get_value($rs.ip);
let $rs_port = deploy_get_value($rs.port);
let $rs_mysql_port = deploy_get_value($rs.mysql_port);
connect (conn_sys,$rs_ip,admin@sys,admin,oceanbase,$rs_mysql_port);

connection conn_sys;
alter system set __balance_controller='{"ENABLE_TYPE_TRANSFORM":"true"}';
sleep 5;


# case 1 : 任务生成前locality发生变更，此时不会生成任务

# 使root_balance用旧locality进行gather_stat
ob1.mysql set ob_global_debug_sync = 'AFTER_TENANT_BALANCE_GATHER_STAT wait_for begin_1';
sleep 20;

# 防止进入下一轮root_balance
ob1.mysql set ob_global_debug_sync = 'UNIT_BALANCE_BEFORE_PARTITION_BALANCE wait_for begin_2';
sleep 5;

# 变更locality
ob1.mysql alter tenant sys set locality = "F@z1,F@z2,R@z3";
sleep 5;

# 使RS利用新schema生成任务
ob1.mysql set ob_global_debug_sync = 'now signal begin_1';

# 等一段时间，预期无任务生成
sleep 30;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_rebalance_task_stat, 0, 5;
ob1.check_until_timeout select count(*) from oceanbase.__all_rootservice_event_history where event = "finish_type_tranform", 0, 5;

# 恢复现场
ob1.mysql alter tenant sys set locality = "F@z1,F@z2,F@z3";
ob1.mysql set ob_global_debug_sync = 'now signal begin_2';
ob1.check_until_timeout select count(*) from oceanbase.__all_tenant where tenant_id = 1 and previous_locality != "", 0, 30;

# 2.1开始回滚locality会清队列任务，以下case无法验证
## case 2 : 任务生成后加队列，在执行前locality发生变更，此时RS会取消任务
