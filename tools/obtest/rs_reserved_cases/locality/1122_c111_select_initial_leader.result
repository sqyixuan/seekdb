ob1=OBI(cluster=1:1:1, proxy_num=0, init_unit_cpu=2, node_cpu_count=64,node_cpu_reserved=2,memory_size_limit=262144);
ob1.reboot;
ob1.mysql create resource unit box1 max_cpu 5, max_memory 1080000000, max_iops 100000, max_disk_size 1080000000, max_session_num 64, MIN_CPU 5, MIN_MEMORY=1080000000, MIN_IOPS=128;
ob1.mysql create resource pool pool_large unit = 'box1', unit_num = 1, zone_list = ('z1', 'z2', 'z3');
ob1.mysql create tenant tt1 replica_num = 3,primary_zone='z1;z3;z2', resource_pool_list=('pool_large'), locality = "L@z1,F@z2,F@z3" set ob_tcp_invited_nodes='%';
create table test1(c1 int primary key, c2 int);
