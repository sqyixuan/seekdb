# owner: wenduo.swd
# owner group：rs
# description: 本case是为了验证在primary zone上进行alter locality副本转换；

ob1=OBI(cluster=1:1:1, init_unit_cpu=2, proxy_num=1, ct_num = 0);
ob1.reboot;

ob1.mysql alter system set resource_hard_limit=900;
ob1.mysql alter system set resource_soft_limit=800;
ob1.mysql alter system set balancer_idle_time = '10s';
ob1.mysql alter system set server_data_copy_out_concurrency = 20;
ob1.mysql alter system set server_data_copy_in_concurrency = 20;

ob1.mysql CREATE RESOURCE POOL pool1 UNIT = 'sys_unit_config', UNIT_NUM = 1, ZONE_LIST = ('z1','z2','z3');
ob1.mysql CREATE TENANT tt RESOURCE_POOL_LIST = ('pool1'), locality='F@z1,F@z2,F@z3', primary_zone = 'z1;z2' set ob_tcp_invited_nodes='%';
sleep 3;

let $proxy_ip = deploy_get_value(ob1.proxy0.ip);
let $proxy_port = deploy_get_value(ob1.proxy0.port);

connect(tt_conn, $proxy_ip, root@tt,,test, $proxy_port);
connect(sys_conn, $proxy_ip, root@sys,,test, $proxy_port);

connection tt_conn;

create table table1 (pk int primary key);
create table table2 (pk int primary key);
create table table3 (pk int primary key);
create table table4 (pk int primary key);
create table table5 (pk int primary key);

connection sys_conn;

let $tenant_id = deploy_get_value(ob1.select select tenant_id from oceanbase.__all_tenant where tenant_name = "tt", tenant_id, 1);
let $t1_id = deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where tenant_id = $tenant_id and table_name = 'table1', table_id, 1);
let $t2_id = deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where tenant_id = $tenant_id and table_name = 'table2', table_id, 1);
let $t3_id = deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where tenant_id = $tenant_id and table_name = 'table3', table_id, 1);
let $t4_id = deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where tenant_id = $tenant_id and table_name = 'table4', table_id, 1);
let $t5_id = deploy_get_value(ob1.select select table_id from oceanbase.__all_virtual_table where tenant_id = $tenant_id and table_name = 'table5', table_id, 1);

ob1.check_until_timeout select zone from oceanbase.__all_virtual_meta_table where table_id = $t1_id and role = 1, z1, 360;
ob1.check_until_timeout select zone from oceanbase.__all_virtual_meta_table where table_id = $t2_id and role = 1, z1, 360;
ob1.check_until_timeout select zone from oceanbase.__all_virtual_meta_table where table_id = $t3_id and role = 1, z1, 360;
ob1.check_until_timeout select zone from oceanbase.__all_virtual_meta_table where table_id = $t4_id and role = 1, z1, 360;
ob1.check_until_timeout select zone from oceanbase.__all_virtual_meta_table where table_id = $t5_id and role = 1, z1, 360;

ob1.mysql alter tenant tt locality = "R@z1,F@z2,F@z3";
ob1.check_until_timeout select count(*) c from oceanbase.__all_tenant where tenant_id = $tenant_id and previous_locality != '', 0, 600;

ob1.check_until_timeout select zone from oceanbase.__all_virtual_meta_table where table_id = $t1_id and role = 1, z2, 360;
ob1.check_until_timeout select zone from oceanbase.__all_virtual_meta_table where table_id = $t2_id and role = 1, z2, 360;
ob1.check_until_timeout select zone from oceanbase.__all_virtual_meta_table where table_id = $t3_id and role = 1, z2, 360;
ob1.check_until_timeout select zone from oceanbase.__all_virtual_meta_table where table_id = $t4_id and role = 1, z2, 360;
ob1.check_until_timeout select zone from oceanbase.__all_virtual_meta_table where table_id = $t5_id and role = 1, z2, 360;
