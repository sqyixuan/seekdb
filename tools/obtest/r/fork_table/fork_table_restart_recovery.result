===============================================================
===== 5. Restart at SUCCESS Stage (FORK_TABLE_SUCCESS) ==========
===============================================================
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_ddl_task_status where ddl_type = 10009, 0, 600;
drop table if exists t_succ_fork;
Warnings:
Note	1051	Unknown table 'oceanbase.t_succ_fork'
drop table if exists t_succ;
Warnings:
Note	1051	Unknown table 'oceanbase.t_succ'
create table t_succ(c1 int primary key, c2 varchar(50));
insert into t_succ values(1, 'OK1'), (2, 'OK2');
ob1.mysql set ob_global_debug_sync = 'FORK_TABLE_SUCCESS wait_for succ_sig execute 10000';
ob1.mysql fork table oceanbase.t_succ to oceanbase.t_succ_fork;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_ddl_task_status where ddl_type = 10009 and status = 100, 1, 600;
ob1.z1.obs0.stop;
ob1.z1.obs0.nstart;
ob1.check_until_timeout select count(*) as cnt from oceanbase.__all_server where start_service_time <= $stop_tstamp_usec, 0 ,180;
ob1.mysql set ob_global_debug_sync = 'FORK_TABLE_SUCCESS clear';
ob1.mysql set ob_global_debug_sync = 'now signal succ_sig';
ob1.check_until_timeout select count(*) from oceanbase.t_succ_fork, 2, 600;
select * from t_succ_fork order by c1;
c1	c2
1	OK1
2	OK2
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_ddl_task_status where ddl_type = 10009, 0, 600;
