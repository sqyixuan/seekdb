===============================================================
==================     split partition  =======================
===============================================================
alter system set _ob_enable_truncate_partition_preserve_global_index = true;
alter table test_with_restore truncate partition p1;
alter system set _ob_enable_truncate_partition_preserve_global_index = false;
alter table test_with_restore partition by range() size('128mb');
insert /*+ query_timeout(100000000000) parallel(16) enable_parallel_dml */ into test_with_restore
select seq_pk_large.nextval, random(10), randstr(2048, random(10)), null, null, null from table(generator(80000));
ob1.check_until_timeout select count(*) > 3 from __all_virtual_part where tenant_id = $backup_mysql_tenant_id and table_id = (select table_id from __all_virtual_table where tenant_id = $backup_mysql_tenant_id and table_name = 'test_with_restore'), 1, 600;
ob1.check_until_timeout select count(*) > 1 from __all_virtual_part where tenant_id = $backup_mysql_tenant_id and table_id = (select table_id from __all_virtual_table where tenant_id = $backup_mysql_tenant_id and index_type = 3 and data_table_id = (select table_id from __all_virtual_table where tenant_id = $backup_mysql_tenant_id and table_name = 'test_with_restore')), 1, 600;
===============================================================
