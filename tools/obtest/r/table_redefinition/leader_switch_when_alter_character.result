ob1=OBI(cluster=1:1:1, proxy_num=1, init_unit_cpu=2);
ob1.reboot;
ob1.mysql alter system set merger_check_interval='10s';
ob1.mysql alter system set enable_rebalance = 'false';
ob1.mysql alter system set resource_hard_limit=500;
ob1.mysql alter system set debug_sync_timeout = '100000s';
ob1.mysql alter system set server_permanent_offline_time = '20s';
ob1.mysql alter system set syslog_io_bandwidth_limit = '4G';
ob1.mysql alter system set enable_async_syslog = 'false';
==============================================
=====  Test switch RS at replica build.  =====
==============================================
$ob1.mysql set ob_global_debug_sync = 'TABLE_REDEFINITION_REPLICA_BUILD wait_for signal execute 10000';
switch RS.
$ob1.mysql alter tenant sys set primary_zone='z2';
$ob1.mysql set ob_global_debug_sync = 'TABLE_REDEFINITION_REPLICA_BUILD clear';
$ob1.mysql set ob_global_debug_sync = 'now signal signal';
