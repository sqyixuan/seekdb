ob1.mysql alter system set_tp tp_no = 738, error_code = 4016, frequency = 1;
ob1.mysql alter system major freeze tenant = 'obtest';
ob1.z1.obs0.check_log_until_success -c "ERRSIM EN_CO_MREGE_DAG_READY_FOREVER";
ob1.mysql alter system migrate unit $unit_id destination "$dst";
ob1.check_until_timeout SELECT COUNT(*) as cnt FROM oceanbase.__all_rootservice_job WHERE unit_id = $unit_id AND job_type = "MIGRATE_UNIT" AND job_status = "SUCCESS", 1, 600;
ob1.check_until_timeout select count(1) from oceanbase.__all_virtual_ls_meta_table where tenant_id = $tenant_id and ls_id = $ls_id and svr_port = '$dst_port' and replica_status = 'NORMAL', 1, 600;
ob1.check_until_timeout select count(*) as cnt from oceanbase.GV\$OB_UNITS where unit_id = $unit_id and svr_ip = '$ip' and svr_port = $port, 0, 600;
ob1.mysql alter system set_tp tp_no = 738, error_code = 4016, frequency = 0;
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id = $tenant_id and LAST_SCN != GLOBAL_BROADCAST_SCN , 0, 300;
