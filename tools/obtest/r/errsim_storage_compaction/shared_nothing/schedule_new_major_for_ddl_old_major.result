ob1=OBI(cluster=1, proxy_num=0, init_unit_cpu=2);
ob1.reboot;
ob1.mysql alter system set enable_rebalance = 'false';
ob1.mysql alter system set resource_hard_limit=500;
ob1.mysql alter system set balancer_idle_time='10s';
ob1.mysql alter system set debug_sync_timeout = '100000s';
ob1.mysql alter system set minor_compact_trigger = 3 tenant sys;
ob1.mysql alter system set minor_compact_trigger = 3 tenant all_user;
ob1.mysql alter system set minor_compact_trigger = 3 tenant all_meta;
ob1.mysql alter system set syslog_io_bandwidth_limit = '100G';
ob1.mysql alter system set ob_compaction_schedule_interval = '10s' tenant sys;
ob1.mysql alter system set ob_compaction_schedule_interval = '10s' tenant all_user;
ob1.mysql alter system set ob_compaction_schedule_interval = '10s' tenant all_meta;
ob1.mysql alter system set server_permanent_offline_time = '20s';
ob1.mysql alter system set merger_check_interval = '10s' tenant sys;
ob1.mysql alter system set merger_check_interval = '10s' tenant all_user;
ob1.mysql alter system set merger_check_interval = '10s' tenant all_meta;
create table test01(c1 int, c2 int, c3 varchar(4096));
create index idx1 on test01(c2);
ob1.mysql alter system set_tp tp_no = 711, error_code = 4016, frequency = 1;
ob1.mysql alter system major freeze tenant obtest;
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where LAST_SCN != GLOBAL_BROADCAST_SCN , 0, 300;
ob1.mysql alter system major freeze tenant obtest;
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where LAST_SCN != GLOBAL_BROADCAST_SCN , 0, 300;
ob1.mysql alter system set_tp tp_no = 711, error_code = 4016, frequency = 0;
ob1.mysql alter system set_tp tp_no = 710, error_code = 5489, frequency = 1;
ob1.z1.obs0.check_until_timeout select count(*) > 0 from oceanbase.__all_server_event_history where module='merge_errsim' and event='schema_recycled', 1, 600;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_tablet_meta_table where tenant_id = $tenant_id and compaction_scn < $last_major_scn, 0, 300;
