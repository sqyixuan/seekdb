ob1=OBI(cluster=1, proxy_num=0, init_unit_cpu=2);
ob1.reboot;
===============================================================
======== Step 0: prepare and create table, insert data ========
===============================================================
ob1.mysql alter system set_tp tp_name = "EN_COMPACTION_DISABLE_ROW_COL_SWITCH", error_code = 4016, frequency = 1;
create table t1 (k int primary key, c1 int, c2 int, c3 int, c4 int, c5 int, c6 int, c7 int, c8 int, c9 int, c10 int, c11 int, c12 int, c13 int, c14 int, c15 int, c16 int, c17 int, c18 int, c19 int, c20 int, c21 int, c22 int, c23 int, c24 int, c25 int, c26 int, c27 int, c28 int,c29 int,c30 int,c31 int, c32 int) with column group (each column);
create sequence seq cache 100000 noorder;
insert into t1 (k, c1, c11, c21, c31) select seq.nextval, seq.nextval + 1, seq.nextval + 11,  seq.nextval + 21,  seq.nextval + 31 from table(generator(50000));
insert into t1 (k, c2, c12, c22, c32) select seq.nextval, seq.nextval + 1, seq.nextval + 11,  seq.nextval + 21,  seq.nextval + 31 from table(generator(50000));
===============================================================
======== Step 1: do major freeze with tx data recycled ========
===============================================================
ob1.mysql alter system set_tp tp_name = "EN_COMPACTION_TX_DATA_RECYCLED", error_code = 6213, frequency = 1;
ob1.mysql alter system major freeze tenant obtest;
ob1.check_until_timeout select count(*) > 0 from oceanbase.__all_server_event_history where module = 'row_col_switch' and event = 'disable_row_col_switch', 1, 600;
ob1.z1.obs0.check_log_until_success -c "ERRSIM EN_COMPACTION_TX_DATA_RECYCLED.*6213";
ob1.z1.obs0.check_log_until_success -c "skip dag retry for specific errcode.*retry_strategy=2.*6213";
ob1.z1.obs0.check_log_until_success -c "Cancel this worker since the whole dag is canceled";
ob1.z1.obs0.check_log_until_success -c "finish waiting dag in canceled dag net";
ob1.z1.obs0.check_log_until_success -c "start finish dag net.*is_stopped:true, is_cancel:true";
ob1.mysql alter system set_tp tp_name = "EN_COMPACTION_TX_DATA_RECYCLED", error_code = 6213, frequency = 0;
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id = $tenant_id and LAST_SCN != GLOBAL_BROADCAST_SCN , 0, 1200;
===============================================================
======== Step 1: do major freeze with alloc mem failed ========
===============================================================
ob1.mysql alter system set_tp tp_name = "EN_COMPACTION_BATCH_EXE_ALLOC_MEM_FAILED", error_code = 4013, frequency = 1;
insert into t1 (k, c1, c11, c21, c31) select seq.nextval, seq.nextval + 1, seq.nextval + 11,  seq.nextval + 21,  seq.nextval + 31 from table(generator(50000));
insert into t1 (k, c2, c12, c22, c32) select seq.nextval, seq.nextval + 1, seq.nextval + 11,  seq.nextval + 21,  seq.nextval + 31 from table(generator(50000));
ob1.mysql alter system major freeze tenant obtest;
ob1.z1.obs0.check_log_until_success -c "EN EN_COMPACTION_BATCH_EXE_ALLOC_MEM_FAILED.*4013";
ob1.z1.obs0.check_log_until_success -c "skip dag retry for specific errcode.*retry_strategy=1.*4013";
ob1.z1.obs0.check_log_until_success -c "start finish dag net.*is_cancel:false.*merge_batch_size:5";
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id = $tenant_id and LAST_SCN != GLOBAL_BROADCAST_SCN , 0, 1200;
