ob1=OBI(cluster=1:1:1,proxy_num=0);
ob1.z1.obs0.set extra_config=$extra_conf;
ob1.z2.obs0.set extra_config=$extra_conf;
ob1.z3.obs0.set extra_config=$extra_conf;
===============================================================
============     special index test case     ==================
===============================================================
test case for spatial index begin
ob1.reboot;
ob1.mysql alter system set enable_rebalance='false';
ob1.mysql alter system set merger_check_interval='10s';
CREATE RESOURCE UNIT unit_special MAX_CPU =2, MEMORY_SIZE ='4G';
CREATE RESOURCE POOL pool_special UNIT = 'unit_special', UNIT_NUM = 1, ZONE_LIST = ('z1', 'z2', 'z3');
CREATE TENANT test01 RESOURCE_POOL_LIST = ('pool_special'), primary_zone='z1,z2,z3', locality='F@z1,F@z2,F@z3' set ob_tcp_invited_nodes='%';
===============================================================
=========== case 1: special index construct ===================
===============================================================
===============================================================
=========== case 2: major merge and checksum validation ====
===============================================================
ob1.mysql alter system major freeze tenant test01;
ob1.check_until_timeout select GLOBAL_BROADCAST_SCN > $last_broadcast_scn from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id = $test_tenant_id , 1, 30;
ob1.mysql alter system set_tp tp_name = "EN_SPECIAL_INDEX_TABLE_VERIFY", error_code = 4016, frequency = 1;
ob1.check_until_timeout select count(*) > 51 from oceanbase.__all_server_event_history where module = 'storage_engine' and event = 'special_index_table_verify', 1, 500;
ob1.mysql alter system set_tp tp_name = "EN_SPECIAL_INDEX_TABLE_VERIFY", error_code = 4016, frequency = 0;
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id = $test_tenant_id and LAST_SCN = GLOBAL_BROADCAST_SCN and LAST_SCN != 1, 1, 1200;
