ob1=OBI(cluster=1:1, proxy_num=0, init_unit_cpu=2);
ob1.reboot;
ob1.mysql alter system set enable_rebalance = 'false';
ob1.mysql alter system set resource_hard_limit=500;
ob1.mysql alter system set balancer_idle_time='10s';
ob1.mysql alter system set debug_sync_timeout = '100000s';
ob1.mysql alter system set minor_compact_trigger = 3 tenant obtest;
ob1.mysql alter system set syslog_io_bandwidth_limit = '100G';
ob1.mysql alter system set ob_compaction_schedule_interval = '10s' tenant obtest;
ob1.mysql alter system set merger_check_interval = '10s' tenant obtest;
create table test01(c1 int, c2 int, c3 varchar(40960)) compression = 'none' partition by hash(c1) partitions 10;
create index idx1 on test01(c2) global partition by hash(c2) partitions 10;
ob1.mysql alter system major freeze tenant = 'obtest';
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where LAST_SCN != GLOBAL_BROADCAST_SCN , 1, 100;
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where LAST_SCN != GLOBAL_BROADCAST_SCN , 0, 300;
ob1.mysql alter system set_tp tp_no = 717, error_code = 4023, frequency = 1;
ob1.mysql alter system major freeze tenant = 'obtest';
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where LAST_SCN != GLOBAL_BROADCAST_SCN , 1, 100;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_tablet_meta_table where tenant_id=$tenant_id and (tablet_id = $tablet_id or tablet_id=$index_tablet_id) and report_scn >= $major_scn, 0, 300;
ob1.mysql alter system set_tp tp_no = 717, error_code = 4023, frequency = 0;
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where LAST_SCN != GLOBAL_BROADCAST_SCN , 0, 300;
create index idx2 on test01(c2, c1) local;
ob1.mysql alter system set_tp tp_no = 729, error_code = 4016, frequency = 1;
ob1.mysql alter system major freeze tenant = 'obtest';
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where LAST_SCN != GLOBAL_BROADCAST_SCN , 1, 100;
ob1.check_until_timeout select /*+LOG_LEVEL(DEBUG)*/count(1) > 0 as c from oceanbase.__all_virtual_compaction_diagnose_info where diagnose_info like "%rs check%" , 1, 300;
alter table test01 drop index idx2;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table where data_table_id=$data_table_id, 1, 300;
ob1.mysql alter system set_tp tp_no = 729, error_code = 4016, frequency = 0;
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id = $tenant_id and LAST_SCN != GLOBAL_BROADCAST_SCN , 0, 300;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_compaction_diagnose_info, 0, 100;
ob1.mysql alter system set_tp tp_no = 726, error_code = 4023, frequency = 1;
ob1.mysql alter system major freeze tenant = 'obtest';
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where LAST_SCN != GLOBAL_BROADCAST_SCN , 1, 100;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_tablet_meta_table where tenant_id=$tenant_id and compaction_scn < $major_scn, 0, 300;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_tablet_meta_table where tenant_id=$tenant_id and report_scn < $major_scn and tablet_id = 1 and svr_ip = '$ip' and svr_port = '$svr_port', 1, 300;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_tablet_compaction_info where tenant_id = $tenant_id and tablet_id=$tablet_id and wait_check_scn=0, 1, 100;
ob1.mysql alter system switch replica leader ls=1 server='$switch_dst_ip:$switch_dst_port' tenant='obtest';
ob1.mysql alter system set_tp tp_no = 726, error_code = 4023, frequency = 0;
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where LAST_SCN != GLOBAL_BROADCAST_SCN , 0, 300;
ob1.mysql alter system set_tp tp_no = 729, error_code = 4023, frequency = 1;
create table test02(c1 int, c2 int, c3 varchar(40960), c4 int, c5 int) compression = 'none' partition by hash(c1) partitions 10;
create index idx1 on test02(c2, c1) global;
create index idx2 on test02(c4, c2) global;
create index idx3 on test02(c5, c2) global;
ob1.mysql alter system major freeze tenant = 'obtest';
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where LAST_SCN != GLOBAL_BROADCAST_SCN , 1, 100;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_tablet_meta_table where tenant_id=$tenant_id and compaction_scn < $major_scn, 0, 300;
ob1.mysql alter system set_tp tp_no = 742, error_code = 4187, frequency = 1;
ob1.mysql alter system set_tp tp_no = 729, error_code = 4023, frequency = 0;
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where LAST_SCN != GLOBAL_BROADCAST_SCN , 0, 300;
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_COLUMN_CHECKSUM_ERROR_INFO, 0, 10;
ob1.mysql alter system set_tp tp_no = 729, error_code = 4023, frequency = 1;
create table test03(c0 varchar(4096), c1 int, c2 int, c3 int, c4 varchar(40960), c5 varchar(40960), c6 int, c7 int, c8 int, c9 int, c10 int, c11 int, c12 int, primary key(c0, c1)) with column group (each column);
create table test04(c1 int, c2 int, c3 varchar(40960), c4 varchar(40960)) compression= 'none' partition by range(c2) (partition p1 values less than (100), partition p2 values less than (200), partition p3 values less than MAXVALUE);
ob1.mysql alter system major freeze tenant = 'obtest';
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where LAST_SCN != GLOBAL_BROADCAST_SCN , 1, 100;
ob1.check_until_timeout select count(*) > 10 as c from oceanbase.__all_virtual_tablet_meta_table where compaction_scn = $major_scn, 1, 100;
alter table test01 drop index idx1;
alter table test04 drop partition p1;
ob1.mysql alter system set_tp tp_no = 729, error_code = 4023, frequency = 0;
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where LAST_SCN != GLOBAL_BROADCAST_SCN , 0, 300;
