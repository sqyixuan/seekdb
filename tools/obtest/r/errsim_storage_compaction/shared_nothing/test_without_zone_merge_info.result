ob1=OBI(cluster=1:1:1,proxy_num=0,init_unit_cpu=5);
ob1.reboot;
CREATE RESOURCE UNIT large_unit_1 MAX_CPU=5, MEMORY_SIZE='10G';
CREATE RESOURCE POOL large_pool_1 UNIT large_unit_1, UNIT_NUM 1, ZONE_LIST ('z1','z2','z3');
ob1.mysql alter system set ob_compaction_schedule_interval='3s' tenant test_tenant;
ob1.mysql alter system set merger_check_interval='10s' tenant test_tenant;
ob1.mysql alter system set compaction_low_thread_score=20 tenant test_tenant;
create table test01(c1 int, c2 int, c3 varchar(40960)) compression= 'none';
ob1.mysql alter system set_tp tp_name = SKIP_REFRESH_ZONE_INFO, error_code = 4023, frequency = 1;
ob1.mysql alter tenant test_tenant locality='F@z1,F@z2,F@z3';
ob1.check_until_timeout select count(*) c from oceanbase.__all_tenant where tenant_id = $tenant_id and previous_locality != '', 0, 300;
ob1.mysql alter system major freeze tenant test_tenant;
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id=$tenant_id and LAST_SCN != GLOBAL_BROADCAST_SCN , 1, 100;
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id=$tenant_id and LAST_SCN != GLOBAL_BROADCAST_SCN , 0, 600;
ob1.mysql alter system set_tp tp_name = SKIP_REFRESH_ZONE_INFO, error_code = 4023, frequency = 0;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_tablet_meta_table where tenant_id = $tenant_id and compaction_scn < $major_scn, 0, 100;
