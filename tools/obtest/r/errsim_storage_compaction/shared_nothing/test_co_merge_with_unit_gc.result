insert into t1(c1,c2,c3,c4,c5) values(1,2,3,4,5);
insert into t1(c11,c21,c31,c41,c51) values(1,2,3,4,5);
insert into t1(c111,c121,c131,c141,c151) values(1,2,3,4,5);
insert into t1(c1,c2,c3,c4,c5) values(1,2,3,4,5);
ob1.mysql alter system set_tp tp_no = 734, error_code = 4016, frequency = 1;
ob1.mysql alter system major freeze tenant = 'mysql';
ob1.z1.obs0.check_log_until_success -c "ERRSIM EN_COMPACTION_CO_MERGE_PARTITION_LONG_TIME";
ob1.mysql drop tenant mysql;
ob1.check_until_timeout SELECT COUNT(*) as cnt FROM DBA_OB_TENANTS WHERE tenant_name = "mysql", 0, 600;
ob1.mysql alter system set_tp tp_no = 734, error_code = 4016, frequency = 0;
