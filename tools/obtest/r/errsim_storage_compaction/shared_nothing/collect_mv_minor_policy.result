alter system major freeze tenant sys;
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id = $sys_tenant_id and LAST_SCN = GLOBAL_BROADCAST_SCN and LAST_SCN != 1, 1, 1200;
ob1.mysql alter system set_tp tp_no = 762, error_code = 4677, frequency = 1;
