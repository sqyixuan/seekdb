ob1=OBI(cluster=1:1:1,proxy_num=0,init_unit_cpu=5);
ob1.reboot;
ob1.mysql alter system set_tp tp_name = "EN_COMPACTION_REFRESH_MULTI_VERSION_START" , error_code = 4023, frequency = 1;
ob1.mysql alter system set _ob_enable_truncate_partition_preserve_global_index=true tenant obtest;
alter system set undo_retention = 0;
create table test01(c1 int, c2 int, primary key(c1, c2)) partition by list(c1) (
partition p0 values in ((100)),
partition p1 values in ((200), (300)),
partition p2 values in ((400)),
partition p3 values in ((500), (700)),
partition p4 values in (DEFAULT));
create unique index idx1 on test01(c2) global partition by hash(c2) partitions 2;
alter table test01 truncate partition p1,p2;
ob1.check_until_timeout select count(*) > 0 from oceanbase.__all_virtual_mds_node_stat where tenant_id = $tenant_id and ls_id=$index_ls_id and tablet_id=$index_tablet_id and unit_id=5, 1, 100;
ob1.check_until_timeout select count(*)>0 as cnt from oceanbase.__all_virtual_tablet_compaction_history where tenant_id=$tenant_id and type="MEDIUM_MERGE" and merge_reason='RECYCLE_TRUNCATE_INFO', 1, 1200;
ob1.check_until_timeout select count(*)>0 as cnt from oceanbase.__all_virtual_tablet_compaction_info where tenant_id=$tenant_id and tablet_id=$index_tablet_id and max_received_scn>finished_scn, 0, 600;
alter table test01 truncate partition p3,p1;
ob1.check_until_timeout select count(*) > 0 from oceanbase.__all_virtual_mds_node_stat where tenant_id = $tenant_id and ls_id=$index_ls_id and tablet_id=$index_tablet_id and unit_id=5, 1, 100;
ob1.mysql alter system major freeze tenant='obtest';
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id=$tenant_id and LAST_SCN != GLOBAL_BROADCAST_SCN , 1, 100;
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id=$tenant_id and LAST_SCN != GLOBAL_BROADCAST_SCN , 0, 600;
ob1.check_until_timeout select count(*) >= 2 from oceanbase.__all_virtual_table_mgr where tenant_id = $tenant_id and tablet_id=$index_tablet_id and svr_port=$svr_port and table_type=26, 1, 600;
ob1.mysql alter system set minor_compact_trigger=1 tenant obtest;
ob1.check_until_timeout select count(*) > 0 from oceanbase.__all_virtual_table_mgr where tenant_id = $tenant_id and tablet_id=$index_tablet_id and svr_port=$svr_port and table_type=27, 1, 600;
ob1.check_until_timeout select count(*) > 0 from oceanbase.__all_virtual_mds_node_stat where tenant_id = $tenant_id and ls_id=$index_ls_id and tablet_id=$index_tablet_id and unit_id=5, 0, 100;
