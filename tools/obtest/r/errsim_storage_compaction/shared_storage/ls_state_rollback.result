ob1.mysql alter system set_tp tp_no=746, error_code=6, frequency=0;
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where LAST_SCN != GLOBAL_BROADCAST_SCN , 1, 100;
ob1.mysql alter system set_tp tp_no=746, error_code=6, frequency=1;
ob1.mysql alter system major freeze tenant test_tenant;
