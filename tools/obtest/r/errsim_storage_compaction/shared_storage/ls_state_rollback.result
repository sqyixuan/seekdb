ob1.mysql alter tenant test_tenant locality='F@z1,F@z2';
ob1.check_until_timeout select count(*) c from oceanbase.__all_tenant where tenant_id = $tenant_id and previous_locality != '', 0, 300;
ob1.mysql alter system set_tp tp_name = SKIP_LS_STATE_UPDATE, error_code = 4023, frequency = 1;
ob1.mysql alter system set_tp tp_no=746, error_code=4, frequency=0;
ob1.check_until_timeout select count(*) > 0 as c from oceanbase.__all_virtual_shared_storage_compaction_info where tenant_id=$tenant_id and tablet_id=0 and ls_id=$ls_id and obj_type="LS_COMPACTION_STATUS" and info like "%expect_state=\"COMPACT\"%", 1, 300;
ob1.mysql alter system set_tp tp_name = SKIP_LS_STATE_UPDATE, error_code = 4023, frequency = 0;
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where LAST_SCN != GLOBAL_BROADCAST_SCN , 1, 100;
