ob1.mysql alter system set_tp tp_name = EN_RS_UPDATE_LS_STATE, error_code = 4023, frequency = 1;
ob1.mysql alter system major freeze tenant test_tenant;
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id=$tenant_id and LAST_SCN != GLOBAL_BROADCAST_SCN , 1, 100;
ob1.check_until_timeout select count(*) > 0 as c from oceanbase.__all_virtual_shared_storage_compaction_info where tenant_id=$tenant_id and tablet_id=0 and ls_id=1 and obj_type="LS_COMPACTION_STATUS" and info like "%REFRESH%", 1, 600;
ob1.check_until_timeout select count(*) > 0 from __all_server_event_history where module='ss_merge_errsim' and event='skip_rs_update_ls_state' and value1=$tenant_id and value2=$ls_id, 1, 600;
