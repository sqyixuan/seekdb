ob1.check_until_timeout select count(*) > 0 from __all_virtual_shared_storage_compaction_info where tenant_id= $tenant_id and ls_id=$ls_id and obj_type="LS_COMPACTION_STATUS" and info like "%REPLICA_VERIFY%", 1, 600;
ob1.check_until_timeout select count(*) > 0 from __all_server_event_history where module='ss_merge_errsim' and event='leader_refresh_major' and name1='merge_version' and value1=$major_scn1, 1, 600;
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id=$tenant_id and LAST_SCN != GLOBAL_BROADCAST_SCN , 0, 600;
ob1.check_until_timeout select count(*) > 0 from __all_server_event_history where module='ss_merge_errsim' and event='follower_refresh_major' and name1='refresh_scn' and value1=$major_scn1, 1, 600;
ob1.check_until_timeout select count(*) > 0 as c from oceanbase.__all_virtual_table_mgr where tenant_id=$tenant_id and table_type=10 and end_log_scn=$major_scn1 and tablet_id=$tablet_id, 1, 100;
ob1.check_until_timeout select count(*) > 0 as c from oceanbase.__all_virtual_table_mgr where tenant_id=$tenant_id and table_type=17 and end_log_scn=$major_scn1 and tablet_id=$tablet_id2, 1, 100;
ob1.mysql alter system major freeze tenant='obtest';
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where LAST_SCN != GLOBAL_BROADCAST_SCN , 1, 100;
