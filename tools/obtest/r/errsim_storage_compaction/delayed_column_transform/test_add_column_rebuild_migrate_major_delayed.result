ob1=OBI(cluster=1:1,proxy_num=0,init_unit_cpu=4);
ob1.reboot;
===============================================================
=================  Step 0: prepare env   ======================
===============================================================
ob1.mysql alter resource unit sys_unit_config memory_size='2G';
ob1.mysql alter system set enable_rebalance = 'false';
ob1.mysql alter system set default_compress_func = 'none';
ob1.mysql alter system set debug_sync_timeout = '100000s';
ob1.mysql alter system set ob_compaction_schedule_interval = '10s' tenant obtest;
ob1.mysql alter system set merger_check_interval = '10s' tenant obtest;
===============================================================
=================  Step 1: create tenant   ====================
===============================================================
CREATE RESOURCE UNIT user_unit_config MAX_CPU = 1, MEMORY_SIZE = '2G', MAX_IOPS = 1024, LOG_DISK_SIZE = '3G';
ob1.mysql create resource pool cs_replica_pool unit = "user_unit_config", unit_num = 1, zone_list = ('z1', 'z2');
ob1.mysql create TENANT tenant1 resource_pool_list=('cs_replica_pool'), replica_num=2, zone_list = ('z1', 'z2'), locality = "F@z1, C@z2" set ob_tcp_invited_nodes='%';
ob1.mysql alter system set ob_compaction_schedule_interval = '10s' tenant tenant1;
ob1.mysql alter system set merger_check_interval = '10s' tenant tenant1;
alter system set_tp tp_name = "EN_COMPACTION_SKIP_CS_REPLICA_TO_REBUILD", error_code = 4016, frequency = 1;
===============================================================
==== Step 2: create table and do major freeze  ================
===============================================================
create table t1 (c1 int, c2 int, c3 int);
create table t2 (c1 int, c2 int, c3 int);
insert into t1 values (1, 2, 3), (2, 3, 4), (3, 4, 5);
insert into t2 values (1, 2, 3), (2, 3, 4), (3, 4, 5);
select * from t1 order by c1 asc;
c1	c2	c3
1	2	3
2	3	4
3	4	5
select * from t2 order by c1 asc;
c1	c2	c3
1	2	3
2	3	4
3	4	5
select * from t1 order by c1 asc;
c1	c2	c3
1	2	3
2	3	4
3	4	5
select * from t2 order by c1 asc;
c1	c2	c3
1	2	3
2	3	4
3	4	5
alter system major freeze;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_tablet_meta_table where compaction_scn != 1 and tenant_id = $tenant_id and tablet_id = $tablet_id1, 1, 600;
alter table t1 add column group (each column) delayed;
alter table t2 add column group (each column, all columns) delayed;
alter table t1 add column c4 int;
alter table t2 add column c4 int;
insert into t1 value (4, 5, 6, 7), (5, 6, 7, 8);
insert into t2 value (4, 5, 6, 7), (5, 6, 7, 8);
alter system minor freeze;
select sum(c2) from t1 where c1 > 3;
sum(c2)
11
select sum(c2) from t2 where c1 > 3;
sum(c2)
11
select sum(c4) from t1 where c2 <= 2;
sum(c4)
NULL
select sum(c4) from t2 where c2 <= 2;
sum(c4)
NULL
===============================================================
==== Step 3: trigger rebuild ================
===============================================================
ob1.mysql alter system set errsim_rebuild_ls_id = $ls_id;
ob1.mysql alter system set errsim_rebuild_addr = "$z2_addr";
ob1.mysql set ob_global_debug_sync = 'BEFORE_CHOOSE_SOURCE wait_for signal2 execute 10000';
ob1.mysql alter system set_tp tp_name = EN_MANUAL_REBUILD , error_code = 4016, frequency = 1;
ob1.check_until_timeout select count(*) > 0 from oceanbase.__all_server_event_history where event = "mannual_rebuild", 1, 300;
ob1.check_until_timeout select count(*) > 0 from oceanbase.__all_server_event_history where module = 'storage_ha' and event = 'ls_ha_start' and value1 = '$tenant_id' and value2 = '1001' and extra_info = 'REBUILD_LS_OP', 1, 600;
ob1.mysql alter system set_tp tp_name = EN_MANUAL_REBUILD , error_code = 4016, frequency = 0;
ob1.mysql set ob_global_debug_sync = 'BEFORE_CHOOSE_SOURCE clear';
ob1.mysql set ob_global_debug_sync = 'now broadcast signal2';
ob1.check_until_timeout select count(*) > 0 from oceanbase.__all_server_event_history where module = 'storage_ha' and event = 'ls_ha_finish' and value1 = '$tenant_id' and value2 = '1001' and extra_info = 'REBUILD_LS_OP', 1, 600;
ob1.check_until_timeout select count(*) from GV\$OB_SSTABLES where tablet_id = $tablet_id1 and svr_port = $z1_obs0_port and table_type = 'MAJOR', 2, 600;
ob1.check_until_timeout select count(*) from GV\$OB_SSTABLES where tablet_id = $tablet_id2 and svr_port = $z1_obs0_port and table_type = 'MAJOR', 2, 600;
ob1.check_until_timeout select count(*) from GV\$OB_SSTABLES where tablet_id = $tablet_id1 and svr_port = $z2_obs0_port and table_type = 'MAJOR', 1, 600;
ob1.check_until_timeout select count(*) from GV\$OB_SSTABLES where tablet_id = $tablet_id2 and svr_port = $z2_obs0_port and table_type = 'MAJOR', 1, 600;
ob1.check_until_timeout select count(*) from GV\$OB_SSTABLES where tablet_id = $tablet_id1 and svr_port = $z2_obs0_port and table_type = 'CO_MAJOR', 1, 600;
ob1.check_until_timeout select count(*) from GV\$OB_SSTABLES where tablet_id = $tablet_id2 and svr_port = $z2_obs0_port and table_type = 'CO_MAJOR', 1, 600;
alter system set_tp tp_name = "EN_COMPACTION_SKIP_CS_REPLICA_TO_REBUILD", error_code = 4016, frequency = 0;
ob1.check_until_timeout select count(*) from CDB_OB_MAJOR_COMPACTION where tenant_id = $tenant_id and status = 'IDLE', 1, 600;
ob1.check_until_timeout select count(*) from GV\$OB_SSTABLES where tablet_id = $tablet_id1 and svr_port = $z1_obs0_port and table_type = 'MAJOR', 2, 600;
ob1.check_until_timeout select count(*) from GV\$OB_SSTABLES where tablet_id = $tablet_id2 and svr_port = $z1_obs0_port and table_type = 'MAJOR', 2, 600;
ob1.check_until_timeout select count(*) from GV\$OB_SSTABLES where tablet_id = $tablet_id1 and svr_port = $z2_obs0_port and table_type = 'CO_MAJOR', 2, 600;
ob1.check_until_timeout select count(*) from GV\$OB_SSTABLES where tablet_id = $tablet_id2 and svr_port = $z2_obs0_port and table_type = 'CO_MAJOR', 2, 600;
insert into t1 values (6, 7, 8, 9), (7, 8, 9, 10);
insert into t2 values (6, 7, 8, 9), (7, 8, 9, 10);
alter system major freeze;
ob1.check_until_timeout select count(*) from CDB_OB_MAJOR_COMPACTION where tenant_id = $tenant_id and status = 'IDLE', 1, 600;
ob1.check_until_timeout select count(*) from __all_virtual_tablet_meta_table where tenant_id = $tenant_id and tablet_id = $tablet_id1 and status = 0, 2, 100;
ob1.check_until_timeout select count(*) from __all_virtual_tablet_meta_table where tenant_id = $tenant_id and tablet_id = $tablet_id2 and status = 0, 2, 100;
ob1.check_until_timeout select count(*) from GV\$OB_SSTABLES where tablet_id = $tablet_id1 and svr_port = $z2_obs0_port and table_type = 'CO_MAJOR', 3, 600;
ob1.check_until_timeout select count(*) from GV\$OB_SSTABLES where tablet_id = $tablet_id2 and svr_port = $z2_obs0_port and table_type = 'CO_MAJOR', 3, 600;