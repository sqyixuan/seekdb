ob1=OBI(cluster=1:1:1,proxy_num=0,init_unit_cpu=4);
ob1.reboot;
===============================================================
========  Step 0: prepare env   ===============================
===============================================================
ob1.mysql alter resource unit sys_unit_config memory_size='2G';
ob1.mysql alter system set enable_rebalance = 'false';
ob1.mysql alter system set default_compress_func = 'none';
ob1.mysql alter system set debug_sync_timeout = '100000s';
ob1.mysql alter system set ob_compaction_schedule_interval = '10s' tenant obtest;
ob1.mysql alter system set merger_check_interval = '10s' tenant obtest;
===============================================================
========  Step 1: create tenant   =============================
===============================================================
CREATE RESOURCE UNIT user_unit_config MAX_CPU = 1, MEMORY_SIZE = '2G', MAX_IOPS = 1024, LOG_DISK_SIZE = '3G';
ob1.mysql create resource pool cs_replica_pool unit = "user_unit_config", unit_num = 1, zone_list = ('z1', 'z2', 'z3');
ob1.mysql create TENANT tenant1 resource_pool_list=('cs_replica_pool'), locality = "F@z1, F@z2, C@z3", primary_zone = "z1, z2" set ob_tcp_invited_nodes='%';
===============================================================
=======  Step 2: create table   ===============================
===============================================================
create table t1 (k int primary key, v1 int, v2 int) partition by hash(k) partitions 8;
create table t2 (k int primary key, v1 int, v2 int) partition by hash(k) partitions 8;
create sequence seq1 cache 10000 noorder;
insert into t1 select seq1.nextval, seq1.nextval + 1, seq1.nextval + 2 from table(generator(1000));
create sequence seq2 cache 10000 noorder;
insert into t2 select seq2.nextval, seq2.nextval + 1, seq2.nextval + 2 from table(generator(1000));
select * from t1 order by k limit 3;
k	v1	v2
1	2	3
2	3	4
3	4	5
select * from t2 order by k limit 3;
k	v1	v2
1	2	3
2	3	4
3	4	5
alter table t1 add column group (each column) delayed;
alter table t2 add column group (each column, all columns) delayed;
===============================================================
========  Step 3: wait major freeze   =========================
===============================================================
ob1.mysql alter system major freeze tenant tenant1;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_tablet_meta_table where compaction_scn != $last_scn and tenant_id = $tenant_id and tablet_id in (select distinct(tablet_id) from oceanbase.CDB_OB_TABLE_LOCATIONS where tenant_id = $tenant_id and table_id = $table_id1), 24, 600;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_tablet_meta_table where compaction_scn != $last_scn and tenant_id = $tenant_id and tablet_id in (select distinct(tablet_id) from oceanbase.CDB_OB_TABLE_LOCATIONS where tenant_id = $tenant_id and table_id = $table_id2), 24, 600;
===============================================================
========  Step 4: alter primary zone(transfer)   ==============
===============================================================
ob1.mysql alter TENANT tenant1 primary_zone = "z1";
ob1.check_until_timeout select count(*) from CDB_OB_LS_LOCATIONS where tenant_id = $tenant_id and ls_id != 1 and zone = 'z3', 1, 60;
===============================================================
========  Step 5: transfer with mixed stored tablet ===========
===============================================================
ob1.mysql alter TENANT tenant1 set locality = "F{1}@z1,F{1}@z2";
ob1.check_until_timeout select count(*) from (select * from oceanbase.DBA_OB_TENANT_JOBS where tenant_id = $tenant_id order by START_TIME desc limit 1) where job_status = "SUCCESS", 1, 100;
ob1.mysql alter TENANT tenant1 primary_zone = "z1, z2";
ob1.check_until_timeout select count(*) from CDB_OB_LS_LOCATIONS where tenant_id = $tenant_id and ls_id != 1 and zone = 'z1', 2, 60;
ob1.mysql alter TENANT tenant1 set locality = "F{1}@z1,F{1}@z2,C{1}@z3";
ob1.check_until_timeout select count(*) from (select * from oceanbase.DBA_OB_TENANT_JOBS where tenant_id = $tenant_id order by START_TIME desc limit 1) where job_status = "SUCCESS", 1, 100;
ob1.mysql alter TENANT tenant1 primary_zone = "z1";
ob1.check_until_timeout select count(*) from CDB_OB_LS_LOCATIONS where tenant_id = $tenant_id and ls_id != 1 and zone = 'z3', 1, 60;
ob1.check_until_timeout select count(*) from oceanbase.GV\$OB_SSTABLES where tenant_id = $tenant_id and table_type ='MAJOR' and svr_ip = '$z1_ip0' and svr_port = $z1_port0 and tablet_id in (select distinct(tablet_id) from oceanbase.CDB_OB_TABLE_LOCATIONS where tenant_id = $tenant_id and table_id = $table_id1), 8, 600;
ob1.check_until_timeout select count(*) from oceanbase.GV\$OB_SSTABLES where tenant_id = $tenant_id and table_type ='MAJOR' and svr_ip = '$z1_ip0' and svr_port = $z1_port0 and tablet_id in (select distinct(tablet_id) from oceanbase.CDB_OB_TABLE_LOCATIONS where tenant_id = $tenant_id and table_id = $table_id2), 8, 600;
ob1.check_until_timeout select count(*) from oceanbase.GV\$OB_SSTABLES where tenant_id = $tenant_id and table_type ='CO_MAJOR' and svr_ip = '$z1_ip0' and svr_port = $z1_port0 and tablet_id in (select distinct(tablet_id) from oceanbase.CDB_OB_TABLE_LOCATIONS where tenant_id = $tenant_id and table_id = $table_id1), 8, 600;
ob1.check_until_timeout select count(*) from oceanbase.GV\$OB_SSTABLES where tenant_id = $tenant_id and table_type ='CO_MAJOR' and svr_ip = '$z1_ip0' and svr_port = $z1_port0 and tablet_id in (select distinct(tablet_id) from oceanbase.CDB_OB_TABLE_LOCATIONS where tenant_id = $tenant_id and table_id = $table_id2), 8, 600;
ob1.check_until_timeout select count(*) from oceanbase.GV\$OB_SSTABLES where tenant_id = $tenant_id and table_type ='MAJOR' and svr_ip = '$z3_ip0' and svr_port = $z3_port0 and tablet_id in (select distinct(tablet_id) from oceanbase.CDB_OB_TABLE_LOCATIONS where tenant_id = $tenant_id and table_id = $table_id1), 8, 600;
ob1.check_until_timeout select count(*) from oceanbase.GV\$OB_SSTABLES where tenant_id = $tenant_id and table_type ='MAJOR' and svr_ip = '$z3_ip0' and svr_port = $z3_port0 and tablet_id in (select distinct(tablet_id) from oceanbase.CDB_OB_TABLE_LOCATIONS where tenant_id = $tenant_id and table_id = $table_id2), 8, 600;
ob1.check_until_timeout select count(*) from oceanbase.GV\$OB_SSTABLES where tenant_id = $tenant_id and table_type ='CO_MAJOR' and svr_ip = '$z3_ip0' and svr_port = $z3_port0 and tablet_id in (select distinct(tablet_id) from oceanbase.CDB_OB_TABLE_LOCATIONS where tenant_id = $tenant_id and table_id = $table_id1), 8, 600;
ob1.check_until_timeout select count(*) from oceanbase.GV\$OB_SSTABLES where tenant_id = $tenant_id and table_type ='CO_MAJOR' and svr_ip = '$z3_ip0' and svr_port = $z3_port0 and tablet_id in (select distinct(tablet_id) from oceanbase.CDB_OB_TABLE_LOCATIONS where tenant_id = $tenant_id and table_id = $table_id2), 8, 600;