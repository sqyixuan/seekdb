ob1=OBI(cluster=1:1:1,proxy_num=0,init_unit_cpu=4);
ob1.reboot;
===============================================================
=================  Step 0: prepare env   ======================
===============================================================
ob1.mysql alter resource unit sys_unit_config memory_size='2G';
ob1.mysql alter system set enable_rebalance = 'false';
ob1.mysql alter system set default_compress_func = 'none';
ob1.mysql alter system set debug_sync_timeout = '100000s';
ob1.mysql alter system set ob_compaction_schedule_interval = '10s' tenant obtest;
ob1.mysql alter system set merger_check_interval = '10s' tenant obtest;
===============================================================
=================  Step 1: create tenant   ====================
===============================================================
CREATE RESOURCE UNIT user_unit_config MAX_CPU = 1, MEMORY_SIZE = '2G', MAX_IOPS = 1024, LOG_DISK_SIZE = '3G';
ob1.mysql create resource pool cs_replica_pool unit = "user_unit_config", unit_num = 1, zone_list = ('z1', 'z2', 'z3');
ob1.mysql create TENANT $tenant_name resource_pool_list=('cs_replica_pool'), locality = "F@z1, F@z2, C@z3", primary_zone = "z1" set ob_tcp_invited_nodes='%';
ob1.mysql alter system set ob_compaction_schedule_interval = '10s' tenant $tenant_name;
ob1.mysql alter system set merger_check_interval = '10s' tenant $tenant_name;
===============================================================
=================  Step 2: create table   =====================
===============================================================
create table t1 (k int primary key, v1 int, v2 int);
create table t2 (k int primary key, v1 int, v2 int);
insert into t1 values (1, 1, 1);
insert into t2 values (1, 1, 1);
insert into t1 values (2, 2, 2);
insert into t2 values (2, 2, 2);
insert into t1 values (3, 3, 3);
insert into t2 values (3, 3, 3);
select * from t1 order by k;
k	v1	v2
1	1	1
2	2	2
3	3	3
select * from t2 order by k;
k	v1	v2
1	1	1
2	2	2
3	3	3
select count(*), avg(k), avg(v1), avg(v2) from t1;
count(*)	avg(k)	avg(v1)	avg(v2)
3	2.0000	2.0000	2.0000
select count(*), avg(k), avg(v1), avg(v2) from t2;
count(*)	avg(k)	avg(v1)	avg(v2)
3	2.0000	2.0000	2.0000
alter table t1 add column group (each column) delayed;
alter table t2 add column group (each column, all columns) delayed;
set ob_route_policy=COLUMN_STORE_ONLY;
set ob_read_consistency = WEAK;
select * from t1 order by k;
k	v1	v2
1	1	1
2	2	2
3	3	3
select * from t2 order by k;
k	v1	v2
1	1	1
2	2	2
3	3	3
select count(*), avg(k), avg(v1), avg(v2) from t1;
count(*)	avg(k)	avg(v1)	avg(v2)
3	2.0000	2.0000	2.0000
select count(*), avg(k), avg(v1), avg(v2) from t2;
count(*)	avg(k)	avg(v1)	avg(v2)
3	2.0000	2.0000	2.0000
set ob_read_consistency = STRONG;
set ob_route_policy=READONLY_ZONE_FIRST;
===============================================================
========  Step 3: drop and re-add cs replica ==================
===============================================================
ob1.check_until_timeout select count(*) from oceanbase.GV\$OB_SSTABLES where tablet_id = $tablet_id1 and table_type ='MAJOR' and svr_ip = '$z1_ip0' and svr_port = $z1_port0, 1, 60;
ob1.check_until_timeout select count(*) from oceanbase.GV\$OB_SSTABLES where tablet_id = $tablet_id1 and table_type ='CO_MAJOR' and svr_ip = '$z3_ip0' and svr_port = $z3_port0, 1, 60;
ob1.check_until_timeout select count(*) from oceanbase.GV\$OB_SSTABLES where tablet_id = $tablet_id2 and table_type ='MAJOR' and svr_ip = '$z1_ip0' and svr_port = $z1_port0, 1, 60;
ob1.check_until_timeout select count(*) from oceanbase.GV\$OB_SSTABLES where tablet_id = $tablet_id2 and table_type ='CO_MAJOR' and svr_ip = '$z3_ip0' and svr_port = $z3_port0, 1, 60;
ob1.mysql alter tenant $tenant_name set locality = "F{1}@z1,F{1}@z2";
ob1.check_until_timeout select count(*) from (select * from oceanbase.DBA_OB_TENANT_JOBS where tenant_id = $tenant_id order by START_TIME desc limit 1) where job_status = "SUCCESS", 1, 100;
ob1.mysql alter tenant $tenant_name set locality = "F{1}@z1,F{1}@z2,C{1}@z3";
ob1.check_until_timeout select count(*) from (select * from oceanbase.DBA_OB_TENANT_JOBS where tenant_id = $tenant_id order by START_TIME desc limit 1) where job_status = "SUCCESS", 1, 100;
set ob_route_policy=COLUMN_STORE_ONLY;
set ob_read_consistency = WEAK;
select * from t1 order by k;
k	v1	v2
1	1	1
2	2	2
3	3	3
select * from t2 order by k;
k	v1	v2
1	1	1
2	2	2
3	3	3
select count(*), avg(k), avg(v1), avg(v2) from t1;
count(*)	avg(k)	avg(v1)	avg(v2)
3	2.0000	2.0000	2.0000
select count(*), avg(k), avg(v1), avg(v2) from t2;
count(*)	avg(k)	avg(v1)	avg(v2)
3	2.0000	2.0000	2.0000
set ob_read_consistency = STRONG;
set ob_route_policy=READONLY_ZONE_FIRST;
select count(*) from GV$OB_SSTABLES where (tenant_id, tablet_id) = (select tenant_id, tablet_id from __all_virtual_table where table_name = 't1') and table_type in ('CO_MAJOR');
count(*)
1
select count(*) from GV$OB_SSTABLES where (tenant_id, tablet_id) = (select tenant_id, tablet_id from __all_virtual_table where table_name = 't1') and table_type in ('NORMAL_CG');
count(*)
0
select count(*) from GV$OB_SSTABLES where (tenant_id, tablet_id) = (select tenant_id, tablet_id from __all_virtual_table where table_name = 't1') and table_type in ('MAJOR');
count(*)
2
select count(*) from GV$OB_SSTABLES where (tenant_id, tablet_id) = (select tenant_id, tablet_id from __all_virtual_table where table_name = 't2') and table_type in ('CO_MAJOR');
count(*)
1
select count(*) from GV$OB_SSTABLES where (tenant_id, tablet_id) = (select tenant_id, tablet_id from __all_virtual_table where table_name = 't2') and table_type in ('NORMAL_CG');
count(*)
0
select count(*) from GV$OB_SSTABLES where (tenant_id, tablet_id) = (select tenant_id, tablet_id from __all_virtual_table where table_name = 't2') and table_type in ('MAJOR');
count(*)
2