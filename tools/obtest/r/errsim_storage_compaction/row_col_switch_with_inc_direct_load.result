===============================================================
=======  Step 2: test skip many mini rows  ====================
===============================================================
[INFO] Start check inc data threshold, should merge ino columnar store
insert into t1 select seq1.nextval, seq1.nextval + 1 from table(generator(10000));
insert into t2 select seq2.nextval, seq2.nextval + 1, seq2.nextval + 2, seq2.nextval + 3, seq2.nextval + 4, seq2.nextval + 5, seq2.nextval + 6 from table(generator(10000));
select count(*) from t1;
count(*)
10500
select count(*) from t2;
count(*)
10500
alter system minor freeze;
delete from t1 where c1 > 500;
delete from t2 where c1 > 500;
select count(*) from t1;
count(*)
500
select count(*) from t2;
count(*)
500
alter system minor freeze;
[INFO] Start major freeze for +-10000 lines
ob1.mysql alter system major freeze tenant obtest;
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id = $tenant_id and LAST_SCN != GLOBAL_BROADCAST_SCN and GLOBAL_BROADCAST_SCN = $frozen_scn, 0, 1200;
