create table t_normal   (c1 int, c2 int, c3 int, c4 int, c5 int, c6 int, c7 int, c8 int, c9 int, c10 int, c11 int, c12 int, c13 int, c14 int, c15 int) table_mode = 'normal';
create table t_queuing  (c1 int, c2 int, c3 int, c4 int, c5 int, c6 int, c7 int, c8 int, c9 int, c10 int, c11 int, c12 int, c13 int, c14 int, c15 int) table_mode = 'queuing';
create table t_moderate (c1 int, c2 int, c3 int, c4 int, c5 int, c6 int, c7 int, c8 int, c9 int, c10 int, c11 int, c12 int, c13 int, c14 int, c15 int) table_mode = 'moderate';
create table t_super    (c1 int, c2 int, c3 int, c4 int, c5 int, c6 int, c7 int, c8 int, c9 int, c10 int, c11 int, c12 int, c13 int, c14 int, c15 int) table_mode = 'super';
create table t_extreme  (c1 int, c2 int, c3 int, c4 int, c5 int, c6 int, c7 int, c8 int, c9 int, c10 int, c11 int, c12 int, c13 int, c14 int, c15 int) table_mode = 'extreme';
insert into t_normal   select * from t1;
insert into t_queuing  select * from t1;
insert into t_moderate select * from t1;
insert into t_super    select * from t1;
insert into t_extreme  select * from t1;
