ob1=OBI(cluster=1, proxy_num=0, init_unit_cpu=0);
ob1.reboot;
CREATE RESOURCE UNIT 2c8g MAX_CPU=2, memory_size='8G';
CREATE RESOURCE POOL test_pool1 UNIT = '2c8g', UNIT_NUM = 1, ZONE_LIST = ('z1');
CREATE TENANT test01 RESOURCE_POOL_LIST=('test_pool1'), primary_zone='z1', locality='F@z1' SET VARIABLES ob_compatibility_mode='mysql', secure_file_priv = '/',ob_tcp_invited_nodes='%';
alter system set major_freeze_duty_time = 'Disable' tenant sys;
alter system set ob_compaction_schedule_interval = '10s' tenant sys;
alter system set _enable_adaptive_compaction = 'False' tenant sys;
alter system set undo_retention = 7200 tenant test01;
drop table if exists t1;
Warnings:
Note	1051	Unknown table 'test.t1'
create table t1 (c1 bigint, c2 varchar(10));
alter system set minor_compact_trigger = 0 tenant test01;
alter system major freeze tenant test01;
