ob1=OBI(cluster=1, proxy_num=0, init_unit_cpu=2);
ob1.reboot;
ob1.mysql alter system set_tp tp_no = 2502, error_code = 4016, frequency = 1;
ob1.mysql alter system set_tp tp_name = "EN_COMPACTION_DISABLE_ROW_COL_SWITCH", error_code = 4016, frequency = 1;
ob1.mysql alter system set_tp tp_name = "EN_COMPACTION_DISABLE_SHARED_MACRO", error_code = 4023, frequency = 1;
create table t1(a int, b varchar(3048), primary key (a), c int) with column group (all columns, each column);
create table t2(a int, b varchar(3048), primary key (a), c int) with column group (each column);
create table t3(pk int, c1 int, c2 int unsigned, c3 varchar(100));
INSERT INTO t1 VALUES(1, "111", 1);
INSERT INTO t2 VALUES(1, "111", 1);
INSERT INTO t3 VALUES(1, 1, 1, "111");
ob1.mysql alter system major freeze tenant obtest;
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where LAST_SCN != GLOBAL_BROADCAST_SCN , 1, 100;
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where LAST_SCN != GLOBAL_BROADCAST_SCN , 0, 1200;
alter table t3 add column d int, add column e int;
alter table t1 add column d int, add column e int;
alter table t2 add column d int, add column e int;
INSERT INTO t1(a,b,c) VALUES(2, "111", 1);
INSERT INTO t2(a,b,c) VALUES(2, "111", 1);
INSERT INTO t3(pk,c1,c2,c3) VALUES(2, 1, 1, "111");
alter system major freeze;
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where LAST_SCN != GLOBAL_BROADCAST_SCN , 1, 100;
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where LAST_SCN != GLOBAL_BROADCAST_SCN , 0, 1200;
alter system major freeze;
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where LAST_SCN != GLOBAL_BROADCAST_SCN , 1, 100;
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where LAST_SCN != GLOBAL_BROADCAST_SCN , 0, 1200;
ob1.z1.obs0.check_until_timeout select count(*) > 0 from oceanbase.__all_server_event_history where module='merge_errsim' and event='progressive_merge_finish' and name1='tablet_id' and value1=$tablet_id, 1, 600;
drop table t1,t2,t3;
