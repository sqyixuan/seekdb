ob1=OBI(cluster=2:2:2,proxy_num=0,init_unit_cpu=4);
ob1.reboot;
===============================================================
========  Step 0: prepare env   ===============================
===============================================================
ob1.mysql alter resource unit sys_unit_config memory_size='2G';
ob1.mysql alter system set enable_rebalance = 'false';
ob1.mysql alter system set default_compress_func = 'none';
ob1.mysql alter system set debug_sync_timeout = '100000s';
ob1.mysql alter system set ob_compaction_schedule_interval = '10s' tenant obtest;
ob1.mysql alter system set merger_check_interval = '10s' tenant obtest;
===============================================================
========  Step 1: create tenant   =============================
===============================================================
CREATE RESOURCE UNIT user_unit_config MAX_CPU = 1, MEMORY_SIZE = '2G', MAX_IOPS = 1024, LOG_DISK_SIZE = '3G';
ob1.mysql create resource pool cs_replica_pool unit = "user_unit_config", unit_num = 1, zone_list = ('z1', 'z2', 'z3');
ob1.mysql create TENANT tenant1 resource_pool_list=('cs_replica_pool'), locality = "F@z1, F@z2, C@z3", primary_zone = "z1, z2" set ob_tcp_invited_nodes='%';
===============================================================
=======  Step 2: create table   ===============================
===============================================================
create table t1 (k int primary key, v1 int, v2 int) partition by hash(k) partitions 8;
create table t2 (k int primary key, v1 int, v2 int) partition by hash(k) partitions 8;
create sequence seq1 cache 10000 noorder;
create sequence seq2 cache 10000 noorder;
insert into t1 select seq1.nextval, seq1.nextval + 1, seq1.nextval + 2 from table(generator(1000));
insert into t2 select seq2.nextval, seq2.nextval + 1, seq2.nextval + 2 from table(generator(1000));
select * from t1 order by k limit 3;
k	v1	v2
1	2	3
2	3	4
3	4	5
select * from t2 order by k limit 3;
k	v1	v2
1	2	3
2	3	4
3	4	5
===============================================================
========  Step 3: alter primary zone(transfer)   ==============
===============================================================
alter table t1 add column group(each column) delayed;
alter table t2 add column group(all columns, each column) delayed;
alter table t1 add column v3 int;
alter table t2 add column v3 int;
ob1.mysql alter TENANT tenant1 primary_zone = "z1";
ob1.check_until_timeout select count(*) from CDB_OB_LS_LOCATIONS where tenant_id = $tenant_id and ls_id != 1 and zone = 'z3', 1, 60;
===============================================================
========  Step 3: wait major freeze   =========================
===============================================================
ob1.mysql alter system major freeze tenant tenant1;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_tablet_meta_table where compaction_scn != $last_scn and tenant_id = $tenant_id and tablet_id in (select distinct(tablet_id) from oceanbase.CDB_OB_TABLE_LOCATIONS where tenant_id = $tenant_id and table_id = $table_id), 24, 600;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_tablet_meta_table where compaction_scn != $last_scn and tenant_id = $tenant_id and tablet_id in (select distinct(tablet_id) from oceanbase.CDB_OB_TABLE_LOCATIONS where tenant_id = $tenant_id and table_id = $table_id), 24, 600;
ob1.z3.obs0.check_log_until_success -c "Decide build column store from rowkey cg for potential cs replica";
ob1.z3.obs0.check_log_until_success -c "Decide build redundant row store from rowkey cg for potential cs replica";
ob1.check_until_timeout select count(*) from CDB_OB_MAJOR_COMPACTION where tenant_id = $tenant_id and GLOBAL_BROADCAST_SCN = LAST_SCN and GLOBAL_BROADCAST_SCN != $last_scn, 1, 300;
