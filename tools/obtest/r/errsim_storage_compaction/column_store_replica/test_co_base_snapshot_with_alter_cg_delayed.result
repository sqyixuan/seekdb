===============================================================
==== Step 4: full direct load data and convert co merge =======
===============================================================
create table t3    (k int primary key, c1 int, c2 int, c3 int);
create table tload (k int primary key, c1 int, c2 int, c3 int);
create sequence seq3 cache 1000 noorder;
insert into tload select seq3.nextval, seq3.nextval + 1, seq3.nextval + 2, seq3.nextval + 3 from table(generator(1000));
insert /*+ enable_parallel_dml parallel(7) append*/ into t3 select * from tload;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_tablet_replica_checksum where tenant_id = $tenant_id and tablet_id = $tablet_id_t3 and co_base_snapshot_version > 0, 2, 600;
ob1.mysql alter system major freeze tenant tenant1;
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id = $tenant_id and LAST_SCN != GLOBAL_BROADCAST_SCN , 0, 600;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_tablet_replica_checksum where tenant_id = $tenant_id and tablet_id = $tablet_id_t3 and co_base_snapshot_version > 0, 2, 600;
===============================================================
==== Step 5: errsim and make data checksum error ==============
===============================================================
ob1.mysql alter system set_tp tp_name = "EN_COMPACTION_DATA_CHECKSUM_ERROR", error_code = $tablet_id_t3, frequency = 1;
ob1.mysql alter system set_tp tp_name = "EN_COMPACTION_DATA_CHECKSUM_CO_BASE_SNAPSHOT_VERSION", error_code = 4016, frequency = 1;
ob1.mysql alter system major freeze tenant tenant1;
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id = $tenant_id and INFO = 'CHECKSUM_ERROR' , 1, 600;
