ob1=OBI(cluster=1:1:1,proxy_num=0,init_unit_cpu=4);
ob1.reboot;
===============================================================
=================  Step 0: prepare env   ======================
===============================================================
ob1.mysql alter resource unit sys_unit_config memory_size='2G';
ob1.mysql alter system set enable_rebalance = 'false';
ob1.mysql alter system set default_compress_func = 'none';
ob1.mysql alter system set debug_sync_timeout = '100000s';
ob1.mysql alter system set ob_compaction_schedule_interval = '10s' tenant obtest;
ob1.mysql alter system set merger_check_interval = '10s' tenant obtest;
===============================================================
=================  Step 1: create tenant   ====================
===============================================================
CREATE RESOURCE UNIT user_unit_config MAX_CPU = 1, MEMORY_SIZE = '2G', MAX_IOPS = 1024, LOG_DISK_SIZE = '3G';
ob1.mysql create resource pool cs_replica_pool unit = "user_unit_config", unit_num = 1, zone_list = ('z1', 'z2', 'z3');
ob1.mysql create TENANT $tenant_name resource_pool_list=('cs_replica_pool'), locality = "F@z1, F@z2, C@z3", primary_zone = "z1" set ob_tcp_invited_nodes='%';
ob1.mysql alter system set ob_compaction_schedule_interval = '10s' tenant $tenant_name;
ob1.mysql alter system set merger_check_interval = '10s' tenant $tenant_name;
===============================================================
=================  Step 2: create table   =====================
===============================================================
create table t1 (k int primary key, v1 int, v2 int);
insert into t1 values (1, 1, 1);
insert into t1 values (2, 2, 2);
insert into t1 values (3, 3, 3);
select * from t1 order by k;
k	v1	v2
1	1	1
2	2	2
3	3	3
select count(*), avg(k), avg(v1), avg(v2) from t1;
count(*)	avg(k)	avg(v1)	avg(v2)
3	2.0000	2.0000	2.0000
set ob_route_policy=COLUMN_STORE_ONLY;
set ob_read_consistency = WEAK;
select * from t1 order by k;
k	v1	v2
1	1	1
2	2	2
3	3	3
select count(*), avg(k), avg(v1), avg(v2) from t1;
count(*)	avg(k)	avg(v1)	avg(v2)
3	2.0000	2.0000	2.0000
set ob_read_consistency = STRONG;
set ob_route_policy=READONLY_ZONE_FIRST;
===============================================================
=================  Step 3: do offline ddl =====================
===============================================================
insert into t1 values (4, 4, 4);
alter table t1 modify v1 decimal(10, 1);
select * from t1 order by k;
k	v1	v2
1	1.0	1
2	2.0	2
3	3.0	3
4	4.0	4
select count(*), avg(k), avg(v1), avg(v2) from t1;
count(*)	avg(k)	avg(v1)	avg(v2)
4	2.5000	2.50000	2.5000
set ob_route_policy=COLUMN_STORE_ONLY;
set ob_read_consistency = WEAK;
select * from t1 order by k;
k	v1	v2
1	1.0	1
2	2.0	2
3	3.0	3
4	4.0	4
select count(*), avg(k), avg(v1), avg(v2) from t1;
count(*)	avg(k)	avg(v1)	avg(v2)
4	2.5000	2.50000	2.5000
set ob_read_consistency = STRONG;
set ob_route_policy=READONLY_ZONE_FIRST;
===============================================================
========  Step 4: do offline ddl with replay redo failed ======
===============================================================
alter system set_tp tp_name = "EN_REPLAY_REDO_DDL_LOG_WAIT", error_code = 4016, frequency = 1;
insert into t1 values (5, 5, 5);
alter table t1 modify v2 decimal(10, 3);
select * from t1 order by k;
k	v1	v2
1	1.0	1.000
2	2.0	2.000
3	3.0	3.000
4	4.0	4.000
5	5.0	5.000
select count(*), avg(k), avg(v1), avg(v2) from t1;
count(*)	avg(k)	avg(v1)	avg(v2)
5	3.0000	3.00000	3.0000000
ob1.z2.obs0.check_log_until_success -c "EN_REPLAY_REDO_DDL_LOG_WAIT replay ddl redo failed.*4016";
ob1.z3.obs0.check_log_until_success -c "EN_REPLAY_REDO_DDL_LOG_WAIT replay ddl redo failed.*4016";
===============================================================
========  Step 5: drop and re-add cs replica ==================
===============================================================
ob1.mysql alter tenant $tenant_name set locality = "F{1}@z1,F{1}@z2";
ob1.check_until_timeout select count(*) from (select * from oceanbase.DBA_OB_TENANT_JOBS where tenant_id = $tenant_id order by START_TIME desc limit 1) where job_status = "SUCCESS", 1, 100;
ob1.mysql alter tenant $tenant_name set locality = "F{1}@z1,F{1}@z2,C{1}@z3";
ob1.check_until_timeout select count(*) from (select * from oceanbase.DBA_OB_TENANT_JOBS where tenant_id = $tenant_id order by START_TIME desc limit 1) where job_status = "INPROGRESS", 1, 100;
ob1.z3.obs0.check_log_until_success -c "EN_REPLAY_REDO_DDL_LOG_WAIT replay ddl redo failed.*4016";
alter system  set_tp tp_no = 720, error_code = 4016, frequency = 1;
alter system set_tp tp_name = "EN_REPLAY_REDO_DDL_LOG_WAIT", error_code = 4016, frequency = 0;
ob1.z3.obs0.check_log_until_success -c "finish replay ddl commit log.*200003";
select count(*) from GV$OB_SSTABLES where (tenant_id, tablet_id) = (select tenant_id, tablet_id from __all_virtual_table where table_name = 't1') and table_type in ('CO_MAJOR');
count(*)
0
select count(*) from GV$OB_SSTABLES where (tenant_id, tablet_id) = (select tenant_id, tablet_id from __all_virtual_table where table_name = 't1') and table_type in ('MAJOR');
count(*)
3
alter system  set_tp tp_no = 720, error_code = 4016, frequency = 0;
ob1.check_until_timeout select count(*) from (select * from oceanbase.DBA_OB_TENANT_JOBS where tenant_id = $tenant_id order by START_TIME desc limit 1) where job_status = "SUCCESS", 1, 100;
set ob_route_policy=COLUMN_STORE_ONLY;
set ob_read_consistency = WEAK;
select * from t1 order by k;
k	v1	v2
1	1.0	1.000
2	2.0	2.000
3	3.0	3.000
4	4.0	4.000
5	5.0	5.000
select count(*), avg(k), avg(v1), avg(v2) from t1;
count(*)	avg(k)	avg(v1)	avg(v2)
5	3.0000	3.00000	3.0000000
set ob_read_consistency = STRONG;
set ob_route_policy=READONLY_ZONE_FIRST;
select count(*) from GV$OB_SSTABLES where (tenant_id, tablet_id) = (select tenant_id, tablet_id from __all_virtual_table where table_name = 't1') and table_type in ('CO_MAJOR');
count(*)
1
select count(*) from GV$OB_SSTABLES where (tenant_id, tablet_id) = (select tenant_id, tablet_id from __all_virtual_table where table_name = 't1') and table_type in ('MAJOR');
count(*)
2
