ob1=OBI(cluster=2:2:2,init_unit_cpu=8,proxy_num=0);
ob1.reboot;
ob1.source include/merge.inc;
ob1.mysql alter system set enable_auto_leader_switch = 'false';
ob1.mysql alter system set balancer_idle_time='10s';
ob1.mysql alter system set server_data_copy_in_concurrency=10;
ob1.mysql alter system set server_data_copy_out_concurrency=10;
ob1.mysql alter system set balancer_task_timeout='30s';
ob1.set_ds_global_config serverStateRefreshInterval=1000;
ob1.create_client tenant=obtest,user=admin,passwd=admin,database=test;
ob1.set_ds_global_config commonLoggerLevel=DEBUG;
create table t1(id int primary key);
insert into t1 values(1);
select * from t1;
id
1
select * from t1;
id
1
ob1.z1.obs0.check_state_in_congest ACTIVE;
$follower.switch_partition obtest:test:t1;
ob1.set_ds_global_config serverStateRefreshInterval=3600000;
select * from t1;
id
1
select * from t1;
id
1
$leader.force_stop;
ob1.check_until_timeout select status from __all_server where svr_ip='$ip' and svr_port='$port',inactive,20;
select * from t1;
id
1
select * from t1;
id
1
$leader.check_state_in_congest INACTIVE;
dead_congested state : true
$leader.nstart;
ob1.check_until_timeout select start_service_time != 0 from __all_server where svr_ip='$ip' and svr_port='$port',1,20;
$leader.check_state_in_congest REPLAY;
