===============================================================
==================      boostrap           ====================
===============================================================
ob1=OBI(cluster=1:1:1, proxy_num=0);
ob1.set extra_config = "cache_wash_threshold='1G',_ob_minor_merge_schedule_interval='3s'";
ob1.force_stop;
ob1.clean_backup_dest;
ob1.reboot;
use oceanbase;
===============================================================
==================      oracle tenant      ====================
===============================================================
ob1.create_tenant CREATE TENANT $backup_oracle_tenant RESOURCE_POOL_LIST = ('small_pool_0'), primary_zone = "z1" set ob_tcp_invited_nodes='%', ob_compatibility_mode='oracle';
set global wait_timeout = 288000;
ob1.check_until_timeout select count(*) from __all_rootservice_event_history where event = 'change_external_storage_dest', 5, 10;
===============================================================
==================      mysql tenant       ====================
===============================================================
use oceanbase;
ob1.create_tenant CREATE TENANT $backup_mysql_tenant RESOURCE_POOL_LIST = ('small_pool_1'), primary_zone = "z1" set ob_tcp_invited_nodes='%';
set global wait_timeout = 288000;
ob1.check_until_timeout select count(*) from __all_rootservice_event_history where event = 'change_external_storage_dest', 10, 10;
