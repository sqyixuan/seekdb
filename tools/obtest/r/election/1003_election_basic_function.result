ob1.check_until_timeout select count(*) c from oceanbase.__all_virtual_clog_stat where is_in_sync=0, 0, 30;
ob1.check_until_timeout select count(*) c from oceanbase.__all_virtual_clog_stat where role != 'LEADER' and parent like '%0.0.0.0%', 0, 30;
ob1.mysql alter system switch replica leader partition_id = '0%1@$table_id' server = '$z2_obs0_ip:$z2_obs0_port';
ob1.check_until_timeout select count(*) c from oceanbase.__all_virtual_clog_stat where table_id = '$table_id' and role = 'LEADER' and concat(svr_ip, ':', svr_port) like '%$z2_obs0_ip:$z2_obs0_port%', 1, 30;
