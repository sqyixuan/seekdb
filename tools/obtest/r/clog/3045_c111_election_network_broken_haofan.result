ob1=OBI(cluster=1:1:1:1:1,proxy_num=0,init_unit_cpu=0,locality=HZ:HZ:SH:SH:SH);
ob1.reboot;
ob1.mysql alter system set max_stale_time_for_weak_consistency = '1h';
ob1.mysql alter system set enable_monotonic_weak_read = 1;
ob1.mysql alter system set resource_hard_limit=900;
ob1.mysql alter system set resource_soft_limit=800;
ob1.mysql alter system set debug_sync_timeout = '1000s';
ob1.mysql alter system set enable_auto_leader_switch = 'false';
ob1.mysql alter system set enable_rebalance = 'false';
ob1.mysql alter system set enable_rereplication = 'false';
ob1.mysql alter system set balancer_idle_time = '10s';
ob1.mysql alter system set server_data_copy_out_concurrency = 20;
ob1.mysql alter system set server_data_copy_in_concurrency = 20;
ob1.mysql alter system set election_blacklist_interval = '0s';
ob1.check_until_timeout select count(*) c from oceanbase.__all_server where start_service_time <= 0 and status = 'active', 0, 120;
ob1.mysql create resource pool rp1 unit = 'sys_unit_config', unit_num = 1, zone_list = ('z1', 'z2', 'z3', 'z4', 'z5');
ob1.mysql create tenant tt1 replica_num 5, primary_zone 'z1;z2;', resource_pool_list('rp1') set ob_tcp_invited_nodes='%';
ob1.check_until_timeout select count(*) c from oceanbase.__all_virtual_server_blacklist where is_in_blacklist = 1, 0, 30;
count(*)
1
ob1.z3.obs0.block_net ob1.z1.obs0;
ob1.z4.obs0.block_net ob1.z1.obs0;
ob1.z5.obs0.block_net ob1.z1.obs0;
ob1.check_until_timeout select count(*) c from oceanbase.__all_virtual_server_blacklist where svr_ip = '$z1_ip' and svr_port = '$z1_port' and dst_ip = '$z3_ip' and dst_port = '$z3_port' and is_in_blacklist = 1, 1, 60;
ob1.check_until_timeout select count(*) c from oceanbase.__all_virtual_server_blacklist where svr_ip = '$z1_ip' and svr_port = '$z1_port' and dst_ip = '$z4_ip' and dst_port = '$z4_port' and is_in_blacklist = 1, 1, 60;
ob1.check_until_timeout select count(*) c from oceanbase.__all_virtual_server_blacklist where svr_ip = '$z1_ip' and svr_port = '$z1_port' and dst_ip = '$z5_ip' and dst_port = '$z5_port' and is_in_blacklist = 1, 1, 60;
ob1.z3.obs0.clean_net ob1.z1.obs0;
ob1.z4.obs0.clean_net ob1.z1.obs0;
ob1.z5.obs0.clean_net ob1.z1.obs0;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_meta_table where role = 1 and svr_ip = '$z2_ip' and svr_port = '$z2_port', 1, 60;
ob1.z3.obs0.block_net ob1.z2.obs0;
ob1.z4.obs0.block_net ob1.z2.obs0;
ob1.z5.obs0.block_net ob1.z2.obs0;
ob1.check_until_timeout select count(*) c from oceanbase.__all_virtual_server_blacklist where svr_ip = '$z3_ip' and svr_port = '$z3_port' and dst_ip = '$z2_ip' and dst_port = '$z2_port' and is_in_blacklist = 1, 0, 60;
ob1.check_until_timeout select count(*) c from oceanbase.__all_virtual_server_blacklist where svr_ip = '$z3_ip' and svr_port = '$z3_port' and dst_ip = '$z4_ip' and dst_port = '$z4_port' and is_in_blacklist = 1, 0, 60;
ob1.check_until_timeout select count(*) c from oceanbase.__all_virtual_server_blacklist where svr_ip = '$z3_ip' and svr_port = '$z3_port' and dst_ip = '$z5_ip' and dst_port = '$z5_port' and is_in_blacklist = 1, 0, 60;
ob1.z3.obs0.clean_net ob1.z2.obs0;
ob1.z4.obs0.clean_net ob1.z2.obs0;
ob1.z5.obs0.clean_net ob1.z2.obs0;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_meta_table where role = 1 and svr_ip = '$z1_ip' and svr_port = '$z1_port', 1, 60;
