ob1=OBI(cluster=1:1:1,proxy_num=0,init_unit_cpu=5);
ob1.reboot;
ob1.mysql_root alter system set enable_auto_leader_switch = True;
create database db primary_zone = 'z1';
create table db.t1(c1 int primary key auto_increment, c2 int);
ob1.z1.obs0
insert into db.t1(c1, c2) values(NULL, 0), (NULL, 1);
select * from db.t1;
