ob1=OBI(cluster=2,proxy_num=1,init_unit_cpu=0);
ob1.reboot;
ob1.mysql alter system set resource_hard_limit=100;
ob1.mysql alter system set enable_auto_leader_switch = 'false';
ob1.mysql alter system set merger_check_interval='10s';
ob1.mysql create resource pool xx1  unit = 'sys_unit_config',unit_num = 1, zone_list = ('z1');
ob1.mysql create tenant xx1 replica_num 1, resource_pool_list ('xx1') set ob_tcp_invited_nodes='%', ob_compatibility_mode='mysql';
create table t1 (c1 int, c2 int, c3 int, c4 int, primary key(c1, c2)) partition by hash(c1) partitions 2;
insert into t1 (c1, c2, c3, c4) values (1, 1, 1, 1);
insert into t1 (c1, c2, c3, c4) values (2, 1, 1, 1);
insert into t1 (c1, c2, c3, c4) values (3, 1, 1, 1);
insert into t1 (c1, c2, c3, c4) values (4, 1, 1, 1);
create index i1 on t1 (c3) partition by hash(c3) partitions 2;
