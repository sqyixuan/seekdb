ob1=OBI(cluster=1,proxy_num=0,init_unit_cpu=0);
ob1.reboot;
ob1.mysql alter system set merger_check_interval='10s';
ob1.create_client;
create table t1 (c1 int primary key, c2 int, c3 int, c4 varchar(512)) compression 'none' partition by hash(c1) partitions 2;
ob1.mysql update oceanbase.__all_table set tablet_size = 16384 where table_id = $tid;
ob1.mysql update oceanbase.__all_table_history set tablet_size = 16384 where table_id = $tid;
ob1.obs0.restart;
ob1.create_client;
show create table t1;
Table	Create Table
t1	CREATE TABLE `t1` (
  `c1` int(11) NOT NULL,
  `c2` int(11) DEFAULT NULL,
  `c3` int(11) DEFAULT NULL,
  `c4` varchar(512) DEFAULT NULL,
  PRIMARY KEY (`c1`)
) DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'none' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
 partition by hash(c1) partitions 2

ob1.mysql alter system major freeze;
ob1.check_version 2;
create unique index idx01 on t1(c2) global partition by hash(c2) partitions 2;
show index from t1;
Table	Non_unique	Key_name	Seq_in_index	Column_name	Collation	Cardinality	Sub_part	Packed	Null	Index_type	Comment	Index_comment	Visible
t1	0	PRIMARY	1	c1	A	NULL	NULL	NULL		BTREE	available		YES
t1	0	idx01	1	c2	A	NULL	NULL	NULL	YES	BTREE	available		YES
ob1.mysql_p select count(*) > 6 from oceanbase.__all_sql_execute_task;
count(*) > 6
1
create index idx02 on t1(c3) global partition by hash(c3) partitions 2;
