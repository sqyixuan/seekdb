ob1=OBI(cluster=1,proxy_num=0,init_unit_cpu=0);
ob1.reboot;
ob1.mysql alter system set resource_hard_limit=900;
ob1.mysql alter system set enable_auto_leader_switch = 'false';
ob1.mysql alter system set merger_check_interval='10s';
ob1.create_client;
ob1.mysql create resource pool xx1  unit = 'sys_unit_config',unit_num = 1, zone_list = ('z1');
ob1.mysql create tenant xx1 replica_num 1, resource_pool_list ('xx1') set ob_tcp_invited_nodes='%', ob_compatibility_mode='oracle';
create table t1 (c1 int primary key, c2 int, c3 int, c4 varchar(512)) NOCOMPRESS partition by hash(c1) partitions 2;
alter system change tenant xx1;
update oceanbase.__all_table set tablet_size = 16384;
update oceanbase.__all_table_history set tablet_size = 16384;
alter system change tenant sys;
ob1.obs0.restart;
ob1.create_client;
show create table t1;
TABLE	CREATE TABLE
T1	CREATE TABLE "T1" (
  "C1" NUMBER(38) NOT NULL,
  "C2" NUMBER(38),
  "C3" NUMBER(38),
  "C4" VARCHAR2(512),
  CONSTRAINT "T1_OBPK_1576581103939292" PRIMARY KEY ("C1")
) NOCOMPRESS REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
 partition by hash(c1) partitions 2

ob1.mysql alter system major freeze;
ob1.check_version 2;
create unique index idx01 on t1(c2) global partition by hash(c2) partitions 2;
ob1.mysql_p select count(*) > 6 from oceanbase.__all_sql_execute_task;
count(*) > 6
1
create index idx02 on t1(c3) global partition by hash(c3) partitions 2;
