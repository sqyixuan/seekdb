ob1=OBI(cluster=1,proxy_num=0,init_unit_cpu=5);
ob1.reboot;
ob1.mysql alter system set enable_auto_leader_switch=false;
ob1.mysql alter system set enable_one_phase_commit = true;
ob1.create_client tenant=obtest;
set ob_query_timeout=90000000;
set ob_trx_timeout=1200000000;
create database obtest;
use obtest;
create table t1(c1 int primary key, c2 int);
create table t2(c1 int primary key, c2 int);
start transaction;
insert into t1 values(1,1);
insert into t1 values(2,2);
insert into t1 values(3,3);
insert into t2 values(4,4);
insert into t2 values(5,5);
insert into t2 values(6,6);
ob1.mysql alter system minor freeze tenant = sys;
ob1.mysql alter system minor freeze tenant = all_user;
ob1.mysql alter system minor freeze tenant = all_meta;
commit;
ob1.check_until_timeout select count(1) from __all_virtual_table_mgr where table_id = $tid1 and table_type=0, 1, 120;
ob1.check_until_timeout select count(1) from __all_virtual_table_mgr where table_id = $tid2 and table_type=0, 1, 120;
ob1.z1.obs0.force_stop;
ob1.z1.obs0.nstart;
ob1.check_until_timeout select state from __all_virtual_trans_stat limit 1, 4, 120;
