db_p=OBI(cluster=1,proxy_num=0,role=primary);
db_p.reboot;
db_s=OBI(cluster=1,proxy_num=0,primary=db_p);
db_s.reboot;
========== Initialization: Set log_restore_source for db_p ==========
db_p.check_until_timeout select count(*) from oceanbase.__all_virtual_server_stat where role = 'PRIMARY', 1, 30;
db_s.check_until_timeout select count(*) from oceanbase.__all_virtual_server_stat where role = 'STANDBY', 1, 30;
dp_p.mysql_p alter system set ob_compaction_schedule_interval = '1s';
dp_s.mysql_p alter system set ob_compaction_schedule_interval = '1s';
alter system set log_restore_source = '127.0.0.1:1275';
db_p.check_until_timeout select count(*) from oceanbase.__all_virtual_server_stat where log_restore_source like '%$db_s_svr_ip%', 1, 30;
Initialization completed: log_restore_source set for db_p
========== Phase 1: Initial Primary Operations ==========
create table if not exists test_switchover_roundtrip(
id int primary key,
name varchar(100),
value int,
create_time timestamp default current_timestamp
);
insert into test_switchover_roundtrip values(1, 'test1', 100, current_timestamp);
insert into test_switchover_roundtrip values(2, 'test2', 200, current_timestamp);
insert into test_switchover_roundtrip values(3, 'test3', 300, current_timestamp);
ALTER SYSTEM MINOR FREEZE;
ALTER SYSTEM MAJOR FREEZE;
db_p.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where LAST_SCN != GLOBAL_BROADCAST_SCN, 1, 100;
Phase 1 completed: Primary operations, minor freeze, and major freeze completed
========== Phase 2: Verify Standby Sync and Data Consistency ==========
db_s.check_until_timeout select count(*) from oceanbase.__all_virtual_server_stat where role = 'STANDBY' and sync_scn >= $primary_last_scn_1, 1, 120;
db_s.check_until_timeout select count(*) from oceanbase.__all_virtual_server_stat where role = 'STANDBY', 1, 30;
select count(*) from test_switchover_roundtrip;
count(*)
3
select id, name, value from test_switchover_roundtrip order by id;
id	name	value
1	test1	100
2	test2	200
3	test3	300
