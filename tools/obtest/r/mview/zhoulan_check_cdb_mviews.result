CREATE RESOURCE POOL pool_2 UNIT = 'unit_1', UNIT_NUM = 1;
CREATE TENANT mysql2 RESOURCE_POOL_LIST = ('pool_2'), primary_zone='z1' set ob_tcp_invited_nodes='%';
