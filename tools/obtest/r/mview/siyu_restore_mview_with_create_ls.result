1	1
===============================================================
===============  CALC RESTORE POINT  ==========================
===============================================================
ob1.check_until_timeout select checkpoint_scn > $now from CDB_OB_ARCHIVELOG where tenant_id = $backup_mysql_tenant_id, 1, 600;
===============================================================
===============  FULL RESTORE  ===============================
===============================================================
ob1.mysql alter system restore $restore_mysql_tenant from '$restore_path' until scn=$now with 'pool_list=small_pool_1&primary_zone=z1&locality=F@z1,F@z2';
ob1.check_until_timeout SELECT status FROM __all_tenant WHERE tenant_id = 1003, NORMAL, 600;
ob1.mysql alter system set ob_compaction_schedule_interval = '10s' tenant $restore_mysql_tenant;
ob1.mysql alter system set_tp tp_name = ERRSIM_WAIT_RESTORE_SAFE_MVIEW, error_code = 4023, frequency = 1;
ob1.check_until_timeout select count(*) from __all_virtual_restore_job where tenant_id = 1004 and name = 'status' and value = 'UPGRADE', 1, 600;
ob1.check_until_timeout select count(unique(ls_id)) from __all_virtual_log_stat where tenant_id = 1004 and ls_id not like 1, 5, 180;
ls_id	publish_scn_check	safe_scn_check
1003	1	1
1003	1	1
ob1.mysql alter system set_tp tp_name = ERRSIM_WAIT_RESTORE_SAFE_MVIEW, error_code = 4023, frequency = 0;
ob1.check_until_timeout select count(*) = $restore_tenant_ls_cnt * 2 from __all_virtual_ls_meta_table where tenant_id = 1004 and restore_status = 0, 1, 600;
ob1.check_until_timeout select status FROM __all_tenant WHERE tenant_id = 1004, NORMAL, 600;
ob1.check_until_timeout select count(*) FROM __all_restore_job, 0, 600;
ob1.check_until_timeout select min(mv_major_merge_scn) >= $tenant_mv_merge_scn from oceanbase.__all_virtual_ls_info a join oceanbase.__all_virtual_ls b on a.ls_id = b.ls_id where a.tenant_id = 1004 and a.ls_id not like 1 and status = 'normal', 1 , 180;
