ob1=OBI(cluster=1:1:1,version=4_3_0_1,oblog_version=current,asvr_num=1);
ob1.proxy0.set extra_config=syslog_level=debug;
ob1.asvr0.set extra_config=$arb_extra_conf;
ob1.reboot;
ob1.mysql alter system set leak_mod_to_check='ModulePageAlloc';
ob1.mysql alter system set debug_sync_timeout = '1000s';
ob1.z1.obs0.sh cd $work_dir/; ls -l {etc,etc2,etc3}/observer.conf*.bin;
ob1.z2.obs0.sh cd $work_dir/; ls -l {etc,etc2,etc3}/observer.conf*.bin;
ob1.z3.obs0.sh cd $work_dir/; ls -l {etc,etc2,etc3}/observer.conf*.bin;
ob1.mysql alter tenant sys set primary_zone = "z1";
ob1.mysql create resource unit box1 max_cpu 2,memory_size 5368709120;
ob1.mysql create resource pool pool1 unit = 'box1', unit_num = 1;
ob1.mysql create tenant oracle replica_num = 1, resource_pool_list=('pool1') set ob_tcp_invited_nodes='%', ob_compatibility_mode='oracle';
ob1.mysql alter tenant oracle set variables autocommit='on';
create user obtest IDENTIFIED BY obtest;
grant all on *.* to obtest WITH GRANT OPTION;
grant dba to obtest;
ob1.check_until_timeout select count(*) from DBA_OB_ARBITRATION_SERVICE where arbitration_service = "$arb_svr_ip:$arb_svr_port", 1, 30;
ob1.mysql CREATE RESOURCE UNIT unit_1 MAX_CPU 1, MEMORY_SIZE='2G';
ob1.mysql CREATE RESOURCE POOL pool_1 UNIT = 'unit_1', UNIT_NUM = 1, zone_list = ('z1', 'z2');
ob1.mysql CREATE TENANT mysql RESOURCE_POOL_LIST = ('pool_1'),  locality='F@z1, F@z2', primary_zone='RANDOM', enable_arbitration_service=true set ob_tcp_invited_nodes='%';
ob1.check_until_timeout select count(*) from __all_virtual_log_stat where tenant_id=$mysql_tenant_id and arbitration_member not like "%$arb_svr_ip:$arb_svr_port%", 0, 30;
ob1.asvr0.force_stop;
ob1.asvr0.upgrade;
ob1.asvr0.nstart;
ob1.asvr0.force_stop;
ob1.asvr0.nstart;
create database oblog_db;
use oblog_db;
ob1.oblog.gen_conf tb_white_list=mysql.*.*;
ob1.oblog.restart;
drop table if exists oblog_test;
create table oblog_test (pk int primary key, c1 varchar(100));
set ob_org_cluster_id=1234;
replace into oblog_test values (1, 1), (2,2), (3,3);
ob1.oblog.next_dml;
