ob1.mysql alter system start server '$server1_ip:$server1_port';
ob1.z2.obs0.force_stop;
ob1.check_until_timeout select count(*) from __all_virtual_log_stat where tenant_id=$mysql_tenant_id and degraded_list not like '%$z2_ip0:$z2_port0%', 0, 30;
ob1.check_until_timeout select count(*) from oceanbase.DBA_OB_SERVERS where zone = 'z2' and status='INACTIVE',1,60;
ob1.z2.obs0.nstart;
ob1.check_until_timeout select count(*) from oceanbase.__all_server where zone = 'z2' and (start_service_time <= 0 or status='INACTIVE'),0,120;
ob1.check_until_timeout select count(*) from __all_virtual_log_stat where degraded_list like '%$z2_ip0:$z2_port0%', 0, 120;
ob1.check_until_timeout select count(*) as cnt from oceanbase.__all_virtual_server_schema_info as a join oceanbase.__all_virtual_server_schema_info as b on a.tenant_id = b.tenant_id  where a.refreshed_schema_version != b.refreshed_schema_version, 0, 60;
ob1.mysql alter system set server_permanent_offline_time = '20s';
ob1.z2.obs0.force_stop;
ob1.check_until_timeout select count(*) from __all_server where status = 'INACTIVE' and svr_ip = '$z2_ip0'and svr_port = $z2_port0, 1, 120;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_ls_meta_table where role = 1 and member_list like '%$z2_ip0:$z2_port0%', 0, 120;
ob1.mysql alter system set server_permanent_offline_time = '3600s';
ob1.z2.obs0.nstart;
ob1.check_until_timeout select count(*) from oceanbase.__all_server where zone = 'z2' and (start_service_time <= 0 or status='INACTIVE'),0,120;
ob1.check_until_timeout select count(*) > 0 from oceanbase.__all_rootservice_event_history where event like '%finish_add%' and value6 like '%ret:0%',1,120;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_ls_replica_task,0,120;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_ls_meta_table where role = 1 and member_list not like '%$z2_ip0:$z2_port0%', 0, 120;
ob1.mysql ALTER SYSTEM SWITCHOVER TO STANDBY TENANT mysql;
ob1.mysql ALTER SYSTEM ACTIVATE STANDBY TENANT mysql;
ob1.z2.obs0.mysql ALTER SYSTEM SWITCHOVER TO STANDBY TENANT oracle;
ob1.z2.obs0.mysql ALTER SYSTEM ACTIVATE STANDBY TENANT oracle;
ob1.check_until_timeout  select count(1) as unsync_cnt from GV\$OB_LOG_STAT where in_sync = 'NO',0,600;
set @@session.ob_query_timeout = 60000000;
alter system stop zone 'z1';
ob1.check_until_timeout select status from DBA_OB_ZONES where zone='z1',INACTIVE,20;
ob1.check_until_timeout select count(1) as leader_count  from CDB_OB_LS_LOCATIONS where zone='z1' and role='leader',0,20;
ob1.z1.force_stop;
ob1.check_until_timeout select count(*) from oceanbase.DBA_OB_SERVERS where zone = 'z1' and (start_service_time is null and status='INACTIVE'),1,60;
ob1.z1.upgrade;
ob1.z1.nstart;
ob1.check_until_timeout select count(*) from oceanbase.__all_server where zone = 'z1' and (start_service_time is null or status='INACTIVE'),0,300;
ob1.check_until_timeout  select count(1) as unsync_cnt from GV\$OB_LOG_STAT where in_sync = 'NO',0,600;
ob1.check_until_timeout select count(*) from oceanbase.__all_server a left join oceanbase.__all_virtual_server_schema_info b on a.svr_ip = b.svr_ip and a.svr_port = b.svr_port where b.svr_ip is null, 0, 120;
ob1.check_until_timeout select count(*) as cnt from oceanbase.__all_virtual_server_schema_info as a join oceanbase.__all_virtual_server_schema_info as b on a.tenant_id = b.tenant_id  where a.refreshed_schema_version != b.refreshed_schema_version or a.refreshed_schema_version % 8 != 0, 0, 180;
ob1.mysql alter system start zone 'z1';
ob1.check_until_timeout select count(*) from CDB_OB_LS_LOCATIONS where zone != 'z1' and role='leader' and tenant_id = (select tenant_id from __all_tenant where tenant_name='sys'),0,60;
