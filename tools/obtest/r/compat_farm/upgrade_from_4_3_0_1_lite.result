show create table test.t_begin_micro_index_clustered;
Table	Create Table
t_begin_micro_index_clustered	CREATE TABLE `t_begin_micro_index_clustered` (
  `a` int(11) DEFAULT NULL,
  `b` text DEFAULT NULL,
