__all_table	CREATE TABLE `__all_table` (\n  `gmt_create` timestamp(6) NULL DEFAULT CURRENT_TIMESTAMP(6),\n  `gmt_modified` timestamp(6) NULL DEFAULT CURRENT_TIMESTAMP(6) ON UPDATE CURRENT_TIMESTAMP(6),\n  `tenant_id` bigint(20) NOT NULL,\n  `table_id` bigint(20) NOT NULL,\n  `table_name` varchar(256) NOT NULL DEFAULT '',\n  `database_id` bigint(20) NOT NULL,\n  `table_type` bigint(20) NOT NULL,\n  `load_type` bigint(20) NOT NULL,\n  `def_type` bigint(20) NOT NULL,\n  `rowkey_column_num` bigint(20) NOT NULL,\n  `index_column_num` bigint(20) NOT NULL,\n  `max_used_column_id` bigint(20) NOT NULL,\n  `autoinc_column_id` bigint(20) NOT NULL,\n  `auto_increment` bigint(20) unsigned DEFAULT '1',\n  `read_only` bigint(20) NOT NULL,\n  `rowkey_split_pos` bigint(20) NOT NULL,\n  `compress_func_name` varchar(128) NOT NULL,\n  `expire_condition` varchar(4096) NOT NULL,\n  `is_use_bloomfilter` bigint(20) NOT NULL,\n  `comment` varchar(4096) NOT NULL DEFAULT '',\n  `block_size` bigint(20) NOT NULL,\n  `collation_type` bigint(20) NOT NULL,\n  `data_table_id` bigint(20) DEFAULT NULL,\n  `index_status` bigint(20) NOT NULL,\n  `tablegroup_id` bigint(20) NOT NULL,\n  `progressive_merge_num` bigint(20) NOT NULL,\n  `index_type` bigint(20) NOT NULL,\n  `part_level` bigint(20) NOT NULL,\n  `part_func_type` bigint(20) NOT NULL,\n  `part_func_expr` varchar(4096) NOT NULL,\n  `part_num` bigint(20) NOT NULL,\n  `sub_part_func_type` bigint(20) NOT NULL,\n  `sub_part_func_expr` varchar(4096) NOT NULL,\n  `sub_part_num` bigint(20) NOT NULL,\n  `schema_version` bigint(20) NOT NULL,\n  `view_definition` longtext NOT NULL,\n  `view_check_option` bigint(20) NOT NULL,\n  `view_is_updatable` bigint(20) NOT NULL,\n  `index_using_type` bigint(20) NOT NULL DEFAULT '0',\n  `parser_name` varchar(128) DEFAULT NULL,\n  `index_attributes_set` bigint(20) DEFAULT '0',\n  `tablet_size` bigint(20) NOT NULL DEFAULT '134217728',\n  `pctfree` bigint(20) NOT NULL DEFAULT '10',\n  `partition_status` bigint(20) DEFAULT '0',\n  `partition_schema_version` bigint(20) DEFAULT '0',\n  `session_id` bigint(20) DEFAULT '0',\n  `pk_comment` varchar(4096) NOT NULL DEFAULT '',\n  `sess_active_time` bigint(20) DEFAULT '0',\n  `row_store_type` varchar(128) DEFAULT 'encoding_row_store',\n  `store_format` varchar(128) DEFAULT '',\n  `duplicate_scope` bigint(20) DEFAULT '0',\n  `progressive_merge_round` bigint(20) DEFAULT '0',\n  `storage_format_version` bigint(20) DEFAULT '2',\n  `table_mode` bigint(20) NOT NULL DEFAULT '0',\n  `encryption` varchar(128) DEFAULT '',\n  `tablespace_id` bigint(20) NOT NULL DEFAULT '-1',\n  `sub_part_template_flags` bigint(20) NOT NULL DEFAULT '0',\n  `dop` bigint(20) NOT NULL DEFAULT '1',\n  `character_set_client` bigint(20) NOT NULL DEFAULT '0',\n  `collation_connection` bigint(20) NOT NULL DEFAULT '0',\n  `auto_part_size` bigint(20) NOT NULL DEFAULT '-1',\n  `auto_part` tinyint(4) NOT NULL DEFAULT '0',\n  `association_table_id` bigint(20) NOT NULL DEFAULT '-1',\n  `tablet_id` bigint(20) NOT NULL DEFAULT '0',\n  `max_dependency_version` bigint(20) NOT NULL DEFAULT '-1',\n  `define_user_id` bigint(20) NOT NULL DEFAULT '-1',\n  `transition_point` varchar(4096) DEFAULT NULL,\n  `b_transition_point` varchar(8192) DEFAULT NULL,\n  `interval_range` varchar(4096) DEFAULT NULL,\n  `b_interval_range` varchar(8192) DEFAULT NULL,\n  `object_status` bigint(20) NOT NULL DEFAULT '1',\n  `table_flags` bigint(20) NOT NULL DEFAULT '0',\n  `truncate_version` bigint(20) NOT NULL DEFAULT '-1',\n  PRIMARY KEY (`tenant_id`, `table_id`),\n  KEY `idx_data_table_id` (`data_table_id`) BLOCK_SIZE 16384 LOCAL,\n  KEY `idx_db_tb_name` (`database_id`, `table_name`) BLOCK_SIZE 16384 LOCAL,\n  KEY `idx_tb_name` (`table_name`) BLOCK_SIZE 16384 LOCAL\n) DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'none' REPLICA_NUM = 3 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 10 TABLEGROUP = 'oceanbase'
ob1.z2.mysql show parameters like 'zone_merge_concurrency';
ob1.mysql alter system minor freeze tenant = all;
set autocommit=0;
insert into db1.tb_normal(pk,c1) values(601,'601'),(602,'602'),(603,'603'),(604,'604');
update db1.tb_normal set c1=concat(c1,'_x') where pk > 100;
delete from db1.tb_normal where pk=604;
update db1.tb_increment set pk=pk+1 order by pk desc limit 1;
insert into db1.tb_increment(pk,c1) values (601,601),(602,602);
replace into db1.tb_increment(pk,c1) values (601,602);
delete from db1.tb_increment where pk=602;
commit;
set autocommit=1;
ob1.mysql alter system start server '$server1_ip:$server1_port';
ob1.z2.obs0.force_stop;
ob1.check_until_timeout select count(*) from oceanbase.DBA_OB_SERVERS where zone = 'z2' and status='INACTIVE',1,60;
ob1.z2.obs0.nstart;
ob1.check_until_timeout select count(*) from oceanbase.__all_server where zone = 'z2' and (start_service_time <= 0 or status='INACTIVE'),0,120;
ob1.check_until_timeout select count(*) as cnt from oceanbase.__all_virtual_server_schema_info as a join oceanbase.__all_virtual_server_schema_info as b on a.tenant_id = b.tenant_id  where a.refreshed_schema_version != b.refreshed_schema_version, 0, 60;
ob1.mysql alter system set server_permanent_offline_time = '20s';
ob1.z2.obs0.force_stop;
ob1.z2.obs0.nstart;
ob1.check_until_timeout select count(*) from oceanbase.__all_server where zone = 'z2' and (start_service_time <= 0 or status='INACTIVE'),0,120;
ob1.check_until_timeout select count(*) > 0 from oceanbase.__all_rootservice_event_history where event like '%finish_add%' and value6 like '%ret:0;%',1,120;
