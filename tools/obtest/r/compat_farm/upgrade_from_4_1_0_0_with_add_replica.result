ob1=OBI(cluster=1:1:1,version=4_1_0_0,oblog_version=current);
ob1.proxy0.set extra_config=syslog_level=debug;
ob1.asvr0.set extra_config=$arb_extra_conf;
ob1.reboot;
ob1.mysql alter system set leak_mod_to_check='ModulePageAlloc';
ob1.mysql alter system set debug_sync_timeout = '1000s';
ob1.z1.obs0.sh cd $work_dir/; ls -l {etc,etc2,etc3}/observer.conf*.bin;
ob1.z2.obs0.sh cd $work_dir/; ls -l {etc,etc2,etc3}/observer.conf*.bin;
ob1.z3.obs0.sh cd $work_dir/; ls -l {etc,etc2,etc3}/observer.conf*.bin;
ob1.mysql alter tenant sys set primary_zone = "z1";
ob1.mysql create resource unit box1 max_cpu 2,memory_size 5368709120;
ob1.mysql create resource pool pool1 unit = 'box1', unit_num = 1;
ob1.mysql create tenant oracle replica_num = 1, resource_pool_list=('pool1') set ob_tcp_invited_nodes='%', ob_compatibility_mode='oracle';
ob1.mysql alter tenant oracle set variables autocommit='on';
ob1.mysql alter tenant oracle set primary_zone = 'z1';
create user obtest IDENTIFIED BY obtest;
grant all on *.* to obtest WITH GRANT OPTION;
grant dba to obtest;
ob1.mysql CREATE RESOURCE UNIT unit_1 MAX_CPU 1, MEMORY_SIZE='2G';
ob1.mysql CREATE RESOURCE POOL pool_1 UNIT = 'unit_1', UNIT_NUM = 1, zone_list = ('z1', 'z2', 'z3');
ob1.mysql CREATE TENANT mysql RESOURCE_POOL_LIST = ('pool_1'),  locality='F@z1, F@z2, F@z3', primary_zone='RANDOM' set ob_tcp_invited_nodes='%';
ob1.mysql alter system set balancer_idle_time='10s';
ob1.mysql alter system set merger_check_interval='10s' tenant all;
ob1.mysql alter system set ob_compaction_schedule_interval='10s' tenant all;
ob1.mysql set global ob_sql_audit_percentage=80;
alter proxyconfig set server_state_refresh_interval='1s';
create database db1;
create tablegroup tg;
create table db1.tb_normal (pk int primary key,c1 varchar(1024) default '0', c2 timestamp(6) default now(6), c3 timestamp default now(), index i1(c2), index i2(c1)) tablegroup tg;
create table db1.tb_increment (pk int primary key auto_increment,c1 int, c2 datetime(6) DEFAULT CURRENT_TIMESTAMP(6) ON UPDATE CURRENT_TIMESTAMP(6), index i1(c2)) tablegroup tg;
create table db1.tb_bigtable (c1 varchar(65536),c2 varchar(65536),c3 varchar(65536),c4 varchar(65536), pk bigint primary key auto_increment) COMPRESSION = 'none' tablegroup tg;
create table db1.global_t6(a int, b int, c int, primary key(a)) partition by hash(a) partitions 2;
create index gkey on db1.global_t6(b) global;
insert into db1.global_t6 values(1, 5, 1), (2, 4, 2), (3, 3, 3), (4, 2, 4), (5, 1, 5);
create table db1.global_t7(a int, b int, c int, primary key(a));
insert into db1.global_t7 values(1, 5, 1), (2, 4, 2), (3, 3, 3), (4, 2, 4), (5, 1, 5);
create table test.tb_table_gencol(pk1 bigint, pk2 varchar(2048),c1 varchar(65536), c2 varchar(65536),ac1 bigint auto_increment,
ts timestamp(6) DEFAULT CURRENT_TIMESTAMP(6) ON UPDATE CURRENT_TIMESTAMP(6),  gmt_create timestamp(6) default now(6), gmt_modified timestamp(6) default now(6),
gen_c1 varchar(10) GENERATED ALWAYS AS (substr(c1,1,10)) virtual,
gen_c2 varchar(10) GENERATED ALWAYS AS (substr(c2,1,10)) stored,
primary key(pk1, pk2),index i1(ts));
create table test.tablegencol(c1 bigint primary key,user_id varchar(32) NOT NULL default '' comment 'Alipay User ID', address varchar(256) NOT NULL default '' comment 'address', index(user_id,address(255)));
create table test.table_hash(c1 int primary key, c2 int) partition by hash(c1) partitions 2;
create table test.table_range(c1 int primary key, c2 int) partition by range(c1) (partition p0 values less than (100), partition p1 values less than (200), partition p2 values less than MAXVALUE);
create table test.table_hash_range (c1 int primary key, c2 int) partition by hash(c1) subpartition by range(c1) subpartition template(SUBPARTITION c0 VALUES LESS THAN(1990), SUBPARTITION c1 VALUES LESS THAN (2000), SUBPARTITION c2 VALUES LESS THAN MAXVALUE) partitions 2;
create table test.table_range_hash (c1 int primary key, c2 int) partition by range(c1) subpartition by hash(c1) subpartitions 2 (PARTITION c0 VALUES LESS THAN (1980), PARTITION c1 VALUES LESS THAN (1990), PARTITION c2 VALUES LESS THAN (1995), PARTITION c3 VALUES LESS THAN (2000), PARTITION c4 VALUES LESS THAN MAXVALUE);
create tablegroup tg_old;
create tablegroup tg_part_old partition by hash partitions 2;
create table test.table_with_tg(c1 int primary key, c2 int) tablegroup tg_old;
create table test.t_parent(c1 int, c2 int, constraint t_parent_pk primary key(c1, c2));
create table test.t_child(c1 int, c2 int, constraint t_child_fk foreign key(c2, c1) references test.t_parent(c1, c2));
create table test.t_check_1(c1 int, c2 int, constraint cst1 check(c1 = c2));
create table test.t_check_2(c1 int, c2 int, constraint cst2 check(c2 = c1));
create user dblink_test IDENTIFIED BY 123;
grant all on *.* to dblink_test WITH GRANT OPTION;
grant dba to dblink_test;
create table dblink_t1(a number, b varchar2(60));
insert into dblink_t1 values (1, 'a'), (2, 'b'), (3, 'c');
commit;
create table t1(pk int primary key, c1 number, c2 date default Date '2012-01-02', c3 timestamp default Timestamp '2012-12-01 01:02:03.123456789', c4 timestamp with time zone default Timestamp '2012-12-01 01:02:03.123456789 +02:00');
insert into t1 (pk, c1) values(1,1),(2,2);
delete from t1 where pk=1;
select pk, c1, to_char(c2), to_char(c3), to_char(c4) from t1;
PK	C1	TO_CHAR(C2)	TO_CHAR(C3)	TO_CHAR(C4)
2	2	02-JAN-12	01-DEC-12 01.02.03.123457 AM	01-DEC-12 01.02.03.123457 AM +02:00
create table global_t1(a int, b int, c int, primary key(a)) partition by hash(a) partitions 2;
create index gkey on global_t1(b) global;
insert into global_t1 values(1, 1, 1), (2, 2, 2), (3, 3, 3), (4, 4, 4), (5, 5, 5);
create table global_t2(a int, b int, c int, primary key(a));
insert into global_t2 values(1, 5, 1), (2, 4, 2), (3, 3, 3), (4, 2, 4), (5, 1, 5);
create tablespace tp1;
create table t_parent(c1 int, c2 int, constraint t_parent_pk primary key(c1, c2));
create table t_child(c1 int, c2 int, constraint t_child_fk foreign key(c2, c1) references t_parent(c1, c2));
create table t_check_1(c1 int, c2 int, constraint cst1 check(c1 = c2));
create table t_check_2(c1 int, c2 int, constraint cst2 check(c2 = c1));
create table t_notnull_pk(c1 int primary key, c2 int, c3 int not null);
desc t_notnull_pk;
FIELD	TYPE	NULL	KEY	DEFAULT	EXTRA
C1	NUMBER(38)	NO	PRI	NULL	NULL
C2	NUMBER(38)	YES	NULL	NULL	NULL
C3	NUMBER(38)	NO	NULL	NULL	NULL
create table t_notnull_nopk(c2 int, c3 int not null) partition by hash(c2,c3) partitions 3;
