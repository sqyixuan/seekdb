ob1=OBI(cluster=1, proxy_num=0, init_unit_cpu=2);
ob1.z1.obs0.set extra_config=datafile_size='1G';
ob1.reboot;
#
# Test datafile_next param
#
alter system set datafile_next=1;
alter system set datafile_next=1M;
