ob1=OBI(cluster=1:1:1, proxy_num=0, node_cpu_count=64, node_cpu_reserved=2);
ob1.z3.obs0.set status=disable;
ob1.reboot;
ob1.mysql alter system set major_freeze_duty_time = 'Disable' tenant sys;
ob1.mysql alter system set major_freeze_duty_time = 'Disable' tenant all_user;
ob1.mysql alter system set major_freeze_duty_time = 'Disable' tenant all_meta;
ob1.check_until_timeout select frozen_scn=last_scn from CDB_OB_MAJOR_COMPACTION where tenant_id = 1, 1, 600;
ob1.mysql alter system major freeze;
ob1.check_until_timeout select frozen_scn = last_scn from CDB_OB_MAJOR_COMPACTION where tenant_id = 1 and frozen_scn = $frozen_scn, 1, 600;
ob1.z3.add;
ob1.z3.start_zone;
ob1.z3.obs0.set status=enable;
ob1.z3.obs0.start;
ob1.z3.obs0.add;
ob1.check_until_timeout select count(*) c from oceanbase.__all_server where start_service_time != 0, 3, 100;
ob1.check_until_timeout select count(*) from __all_resource_pool where zone_list not like "%z3%", 0, 600;
ob1.check_until_timeout select count(*) from __all_tenant where locality not like "%z3%", 0, 600;
ob1.check_until_timeout select count(*) from __all_tenant where previous_locality != '', 0, 600;
ob1.mysql alter system major freeze;
ob1.check_until_timeout select frozen_scn = last_scn from CDB_OB_MAJOR_COMPACTION where tenant_id = 1 and frozen_scn = $frozen_scn, 1, 600;
