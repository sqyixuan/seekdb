create database test_mview;
use test_mview;
create table t1(c1 int primary key, c2 int, c3 int, c4 int);
create table t1_mix(c1 int primary key, c2 int, c3 int, c4 int);
create materialized view log on t1 with primary key, sequence (c2, c3) including new values;
create materialized view mv1 refresh fast on demand as select c2 as c2, count(*) cnt, count(c3) cnt_c3, sum(c3) sum_c3 from t1 group by c2;
create materialized view mv2 as select * from t1;
create sequence s1 cache 1000000 noorder;
call dbms_mview_stats.set_mvref_stats_params('mv1', 'NONE', 31);
call dbms_mview_stats.set_mvref_stats_params('mv2', 'NONE', 31);
select OWNER,MVIEW_NAME,QUERY,REFRESH_MODE,REFRESH_METHOD,BUILD_MODE,LAST_REFRESH_DATE IS NULL,LAST_REFRESH_END_TIME IS NULL from oceanbase.DBA_MVIEWS where OWNER = 'test_mview' AND MVIEW_NAME IN ('mv1', 'mv2') ORDER BY MVIEW_NAME;
OWNER	MVIEW_NAME	QUERY	REFRESH_MODE	REFRESH_METHOD	BUILD_MODE	LAST_REFRESH_DATE IS NULL	LAST_REFRESH_END_TIME IS NULL
test_mview	mv1	select `test_mview`.`t1`.`c2` AS `c2`,count(*) AS `cnt`,count(`test_mview`.`t1`.`c3`) AS `cnt_c3`,sum(`test_mview`.`t1`.`c3`) AS `sum_c3` from `test_mview`.`t1` group by `test_mview`.`t1`.`c2`	DEMAND	FAST	IMMEDIATE	0	0
test_mview	mv2	select `test_mview`.`t1`.`c1` AS `c1`,`test_mview`.`t1`.`c2` AS `c2`,`test_mview`.`t1`.`c3` AS `c3`,`test_mview`.`t1`.`c4` AS `c4` from `test_mview`.`t1`	DEMAND	FORCE	IMMEDIATE	0	0
insert into t1 select s1.nextval, s1.nextval, s1.nextval, s1.nextval from table(generator(100000));
call dbms_mview.refresh('mv1');
call dbms_mview.refresh('mv2');
select OWNER,MVIEW_NAME,QUERY,REFRESH_MODE,REFRESH_METHOD,BUILD_MODE,LAST_REFRESH_DATE IS NULL,LAST_REFRESH_END_TIME IS NULL,TIMESTAMPDIFF(SECOND, LAST_REFRESH_DATE, LAST_REFRESH_END_TIME) < 10 from oceanbase.DBA_MVIEWS where OWNER = 'test_mview' AND MVIEW_NAME IN ('mv1', 'mv2') ORDER BY MVIEW_NAME;
