use test_mview;
SET ob_query_timeout = 20000000000;
create table t1_after(c1 int primary key, c2 int, c3 int, c4 int);
create materialized view log on t1_after with primary key, sequence (c2, c3) including new values;
create materialized view mv1_after refresh fast on demand as select c2 as c2, count(*) cnt, count(c3) cnt_c3, sum(c3) sum_c3 from t1_after group by c2;
create materialized view mv2_after as select * from t1_after;
create sequence s1_after cache 1000000 noorder;
call dbms_mview_stats.set_mvref_stats_params('mv1_after', 'NONE', 31);
call dbms_mview_stats.set_mvref_stats_params('mv2_after', 'NONE', 31);
select OWNER,MVIEW_NAME,QUERY,REFRESH_MODE,REFRESH_METHOD,BUILD_MODE,LAST_REFRESH_DATE IS NULL,LAST_REFRESH_END_TIME IS NULL from oceanbase.DBA_MVIEWS where OWNER = 'test_mview' AND MVIEW_NAME IN ('mv1_after', 'mv2_after') ORDER BY MVIEW_NAME;
OWNER	MVIEW_NAME	QUERY	REFRESH_MODE	REFRESH_METHOD	BUILD_MODE	LAST_REFRESH_DATE IS NULL	LAST_REFRESH_END_TIME IS NULL
test_mview	mv1_after	select `test_mview`.`t1_after`.`c2` AS `c2`,count(*) AS `cnt`,count(`test_mview`.`t1_after`.`c3`) AS `cnt_c3`,sum(`test_mview`.`t1_after`.`c3`) AS `sum_c3` from `test_mview`.`t1_after` group by `test_mview`.`t1_after`.`c2`	DEMAND	FAST	IMMEDIATE	0	0
test_mview	mv2_after	select `test_mview`.`t1_after`.`c1` AS `c1`,`test_mview`.`t1_after`.`c2` AS `c2`,`test_mview`.`t1_after`.`c3` AS `c3`,`test_mview`.`t1_after`.`c4` AS `c4` from `test_mview`.`t1_after`	DEMAND	FORCE	IMMEDIATE	0	0
insert into t1_after select s1_after.nextval, s1_after.nextval, s1_after.nextval, s1_after.nextval from table(generator(100000));
call dbms_mview.refresh('mv1_after');
call dbms_mview.refresh('mv2_after');
select OWNER,MVIEW_NAME,QUERY,REFRESH_MODE,REFRESH_METHOD,BUILD_MODE,LAST_REFRESH_DATE IS NULL,LAST_REFRESH_END_TIME IS NULL,TIMESTAMPDIFF(SECOND, LAST_REFRESH_DATE, LAST_REFRESH_END_TIME) < 10 from oceanbase.DBA_MVIEWS where OWNER = 'test_mview' AND MVIEW_NAME IN ('mv1_after', 'mv2_after') ORDER BY MVIEW_NAME;
OWNER	MVIEW_NAME	QUERY	REFRESH_MODE	REFRESH_METHOD	BUILD_MODE	LAST_REFRESH_DATE IS NULL	LAST_REFRESH_END_TIME IS NULL	TIMESTAMPDIFF(SECOND, LAST_REFRESH_DATE, LAST_REFRESH_END_TIME) < 10
test_mview	mv1_after	select `test_mview`.`t1_after`.`c2` AS `c2`,count(*) AS `cnt`,count(`test_mview`.`t1_after`.`c3`) AS `cnt_c3`,sum(`test_mview`.`t1_after`.`c3`) AS `sum_c3` from `test_mview`.`t1_after` group by `test_mview`.`t1_after`.`c2`	DEMAND	FAST	IMMEDIATE	0	0	1
test_mview	mv2_after	select `test_mview`.`t1_after`.`c1` AS `c1`,`test_mview`.`t1_after`.`c2` AS `c2`,`test_mview`.`t1_after`.`c3` AS `c3`,`test_mview`.`t1_after`.`c4` AS `c4` from `test_mview`.`t1_after`	DEMAND	FORCE	IMMEDIATE	0	0	1
