obdocker=OBI(cluster=2:2:2,proxy_num=2,ct_num=1,locality=SZ:SZ:SZ,asvr_num=1,version=4_3_4_0);
obdocker.reboot;
CREATE RESOURCE UNIT unit_mysql  MEMORY_SIZE = '3G',MAX_CPU = 1, MIN_CPU = 1,LOG_DISK_SIZE = '6G',MAX_IOPS = 10000, MIN_IOPS = 10000, IOPS_WEIGHT=1;
obdocker.check_until_timeout select count(*) FROM oceanbase.DBA_OB_UNIT_CONFIGS WHERE NAME = "$unit1name", 1, 120;
CREATE RESOURCE POOL pool_mysql UNIT= unit_mysql ,UNIT_NUM=1, ZONE_LIST=('z1','z2','z3');
obdocker.check_until_timeout select count(*) FROM DBA_OB_RESOURCE_POOLS WHERE NAME = "$pool1name",1, 120;
CREATE TENANT IF NOT EXISTS tent_mysql PRIMARY_ZONE='z1',locality='F@z1,F@z2,R@z3',RESOURCE_POOL_LIST=('pool_mysql') ,enable_arbitration_service=true SET OB_TCP_INVITED_NODES='%' ;
obdocker.check_until_timeout select count(*) FROM DBA_OB_TENANTS WHERE TENANT_NAME = "$tent1name",1,120;
alter user root identified by 'tent1pw';
CREATE RESOURCE UNIT unit_oracle  MEMORY_SIZE = '3G',MAX_CPU = 1, MIN_CPU = 1,LOG_DISK_SIZE = '6G',MAX_IOPS = 10000, MIN_IOPS = 10000, IOPS_WEIGHT=1;
obdocker.check_until_timeout select count(*) FROM oceanbase.DBA_OB_UNIT_CONFIGS WHERE NAME = "$unit2name", 1, 120;
CREATE RESOURCE POOL pool_oracle UNIT= unit_oracle ,UNIT_NUM=1, ZONE_LIST=('z1','z2','z3');
obdocker.check_until_timeout select count(*) FROM DBA_OB_RESOURCE_POOLS WHERE NAME = "$pool2name",1, 120;
CREATE TENANT IF NOT EXISTS tent_oracle PRIMARY_ZONE='z1',RESOURCE_POOL_LIST=('pool_oracle') SET OB_TCP_INVITED_NODES='%',ob_compatibility_mode='oracle';
obdocker.check_until_timeout select count(*) FROM DBA_OB_TENANTS WHERE TENANT_NAME = "$tent2name",1,120;
alter user sys identified by tent2pw;
CREATE RESOURCE UNIT unit_not_minor  MEMORY_SIZE = '3G',MAX_CPU = 1, MIN_CPU = 1,LOG_DISK_SIZE = '6G',MAX_IOPS = 10000, MIN_IOPS = 10000, IOPS_WEIGHT=1;
obdocker.check_until_timeout select count(*) FROM oceanbase.DBA_OB_UNIT_CONFIGS WHERE NAME = "$unit4name", 1, 120;
CREATE RESOURCE POOL pool_not_minor UNIT= unit_not_minor ,UNIT_NUM=1, ZONE_LIST=('z1','z2','z3');
obdocker.check_until_timeout select count(*) FROM DBA_OB_RESOURCE_POOLS WHERE NAME = "$pool4name",1, 120;
CREATE TENANT IF NOT EXISTS tent_not_minor PRIMARY_ZONE='z1',RESOURCE_POOL_LIST=('pool_not_minor') SET OB_TCP_INVITED_NODES='%',ob_compatibility_mode='oracle';
obdocker.check_until_timeout select count(*) FROM DBA_OB_TENANTS WHERE TENANT_NAME = "$tent4name",1,120;
alter user sys identified by tent4pw;
drop tenant tent_not_minor;
CREATE TENANT IF NOT EXISTS tent_not_minor PRIMARY_ZONE='z1',locality='F@z1,F@z2,C@z3',RESOURCE_POOL_LIST=('pool_not_minor'),enable_arbitration_service=true SET OB_TCP_INVITED_NODES='%',ob_compatibility_mode='oracle';
obdocker.check_until_timeout select count(*) FROM DBA_OB_TENANTS WHERE TENANT_NAME = "$tent4name",1,120;
alter user sys identified by tent4pw;
obdocker.mysql ALTER SYSTEM SET ls_gc_delay_time='0s';
obdocker.mysql ALTER SYSTEM SET ls_gc_delay_time='0s' TENANT =all_meta;
obdocker.mysql ALTER SYSTEM SET ls_gc_delay_time='0s' TENANT =all_user;
obdocker.mysql alter tenant $tent1name set variables autocommit='on';
obdocker.mysql alter tenant $tent2name set variables autocommit='on';
obdocker.mysql alter tenant $tent4name set variables autocommit='on';
