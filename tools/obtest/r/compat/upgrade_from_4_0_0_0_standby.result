ob1=OBI(cluster=1:1:1,proxy_num=0,version=4_0_0_0);
ob1.z1.obs0.set extra_config = "cache_wash_threshold='1G',_ob_minor_merge_schedule_interval='3s'";
ob1.z2.obs0.set extra_config = "cache_wash_threshold='1G',_ob_minor_merge_schedule_interval='3s'";
ob1.z3.obs0.set extra_config = "cache_wash_threshold='1G',_ob_minor_merge_schedule_interval='3s'";
ob1.force_stop;
ob1.clean_backup_dest;
ob1.reboot;
ob1.mysql alter resource unit sys_unit_config memory_size='2G';
use oceanbase;
ob1.mysql alter system set _backup_idle_time = '10s';
ob1.mysql alter system set _advance_checkpoint_timeout = '5m';
ob1.mysql alter system set merger_check_interval = '10s';
ob1.mysql alter system set enable_async_syslog=false;
ob1.mysql CREATE TENANT update_oracle_tenant RESOURCE_POOL_LIST = ('small_pool'), primary_zone = "z1" set ob_tcp_invited_nodes='%', ob_compatibility_mode='oracle';
set global wait_timeout = 288000;
create user test IDENTIFIED BY "test";
grant all on *.* to test WITH GRANT OPTION;
grant dba to test;
create table t1(a int, b int, c int, CONSTRAINT "c1" PRIMARY KEY ("A"));
create index idx_b on t1(B);
insert into t1(a, b) values(1, 1);
insert into t1(a, b) values(2, 2);
ob1.upgrade_check_before;
ob1.upgrade_commond_for_server pre;
ob1.z1.force_stop;
ob1.z1.upgrade;
ob1.z1.nstart;
ob1.check_until_timeout select count(*) from oceanbase.__all_server where zone = 'z1' and (start_service_time is null or status='INACTIVE'),0,120;
ob1.check_until_timeout  select count(1) as unsync_cnt from GV\$OB_LOG_STAT where in_sync = 'NO',0,600;
ob1.check_until_timeout select count(*) from oceanbase.__all_server a left join oceanbase.__all_virtual_server_schema_info b on a.svr_ip = b.svr_ip and a.svr_port = b.svr_port where b.svr_ip is null, 0, 120;
ob1.check_until_timeout select count(*) as cnt from oceanbase.__all_virtual_server_schema_info as a join oceanbase.__all_virtual_server_schema_info as b on a.tenant_id = b.tenant_id  where a.refreshed_schema_version != b.refreshed_schema_version or a.refreshed_schema_version % 8 != 0, 0, 180;
ob1.check_until_timeout select count(*) from oceanbase.GV\$OB_PARAMETERS where name = "compatible" and value != "0.0.0.0", 0, 1;
ALTER SYSTEM SWITCHOVER TO STANDBY TENANT update_oracle_tenant;
ERROR 0A000: Tenant COMPATIBLE is below 4.1.0.0, switch tenant is not supported
ALTER SYSTEM SWITCHOVER TO PRIMARY TENANT update_oracle_tenant;
ERROR 0A000: Tenant COMPATIBLE is below 4.1.0.0, switch tenant is not supported
ALTER SYSTEM ACTIVATE STANDBY TENANT update_oracle_tenant;
ERROR 0A000: Tenant COMPATIBLE is below 4.1.0.0, switch tenant is not supported
ALTER SYSTEM RECOVER STANDBY TENANT update_oracle_tenant UNTIL UNLIMITED;
ERROR 0A000: Tenant COMPATIBLE is below 4.1.0.0, recover tenant is not supported
ob1.z2.force_stop;
ob1.z2.upgrade;
ob1.z2.nstart;
ob1.check_until_timeout select count(*) from oceanbase.__all_server where zone = 'z2' and (start_service_time is null or status='INACTIVE'),0,120;
ob1.z3.force_stop;
ob1.z3.upgrade;
ob1.z3.nstart;
ob1.check_until_timeout select count(*) from oceanbase.__all_server where zone = 'z3' and (start_service_time is null or status='INACTIVE'),0,120;
ob1.check_until_timeout  select count(1) as unsync_cnt from GV\$OB_LOG_STAT where in_sync = 'NO',0,600;
ob1.check_until_timeout select count(*) from oceanbase.GV\$OB_PARAMETERS where tenant_id = 1002 and name = "compatible" and value != "4.1.0.0", 3, 20;
ALTER SYSTEM SWITCHOVER TO STANDBY TENANT update_oracle_tenant;
ERROR 0A000: Tenant COMPATIBLE is below 4.1.0.0, switch tenant is not supported
ALTER SYSTEM SWITCHOVER TO PRIMARY TENANT update_oracle_tenant;
ERROR 0A000: Tenant COMPATIBLE is below 4.1.0.0, switch tenant is not supported
ALTER SYSTEM ACTIVATE STANDBY TENANT update_oracle_tenant;
ERROR 0A000: Tenant COMPATIBLE is below 4.1.0.0, switch tenant is not supported
ALTER SYSTEM RECOVER STANDBY TENANT update_oracle_tenant UNTIL UNLIMITED;
ERROR 0A000: Tenant COMPATIBLE is below 4.1.0.0, recover tenant is not supported
ob1.check_until_timeout select count(*) from oceanbase.__all_server a left join oceanbase.__all_virtual_server_schema_info b on a.svr_ip = b.svr_ip and a.svr_port = b.svr_port where b.svr_ip is null, 0, 120;
ob1.check_until_timeout select count(*) as cnt from oceanbase.__all_virtual_server_schema_info as a join oceanbase.__all_virtual_server_schema_info as b on a.tenant_id = b.tenant_id  where a.refreshed_schema_version != b.refreshed_schema_version or a.refreshed_schema_version % 8 != 0, 0, 180;
ob1.upgrade_commond_for_server post;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_upgrade_inspection where name = "data_version_check" and info = "succeed", 1, 1;
ob1.check_until_timeout select count(*) from oceanbase.GV\$OB_PARAMETERS where tenant_id = 1 and name = "compatible" and value = "4.1.0.0", 3, 1;
ob1.check_until_timeout select count(*) from oceanbase.GV\$OB_PARAMETERS where tenant_id = 1002 and name = "compatible" and value = "4.1.0.0", 3, 5;
ob1.mysql ALTER SYSTEM SWITCHOVER TO STANDBY TENANT update_oracle_tenant;
select * from t1;
A	B	C
1	1	NULL
2	2	NULL
ob1.mysql CREATE TENANT $backup_oracle_tenant RESOURCE_POOL_LIST = ('small_pool_1'), primary_zone = "z1" set ob_tcp_invited_nodes='%', ob_compatibility_mode='oracle';
set global wait_timeout = 288000;
set global wait_timeout = 288000;
create user test IDENTIFIED BY "test";
grant all on *.* to test WITH GRANT OPTION;
grant dba to test;
create table t2(a int, b int, c int, CONSTRAINT "c2" PRIMARY KEY ("A"));
create index idx_b on t2(B);
insert into t2(a, b) values(1, 1);
insert into t2(a, b) values(2, 2);
ob1.mysql alter system archivelog;
ob1.check_until_timeout select status from oceanbase.CDB_OB_ARCHIVELOG where tenant_id=$backup_oracle_tenant_id, DOING, 600;
ob1.mysql alter system major freeze tenant = '$backup_oracle_tenant';
ob1.check_until_timeout select (frozen_scn - last_scn) as result from oceanbase.CDB_OB_MAJOR_COMPACTION where tenant_id=$backup_oracle_tenant_id, 0, 600;
ob1.mysql alter system backup database;
ob1.check_until_timeout select count(*) c from __all_backup_job_history where tenant_id = 1, 1, 600;
ob1.check_until_timeout select result from oceanbase.CDB_OB_BACKUP_JOB_HISTORY where tenant_id = $backup_oracle_tenant_id, 0, 10;
ob1.check_until_timeout select result from oceanbase.CDB_OB_BACKUP_TASK_HISTORY where tenant_id = $backup_oracle_tenant_id, 0, 10;
ob1.check_until_timeout select count(*) as cnt from oceanbase.__all_virtual_dag where dag_type like '%BACKUP%', 0, 60;
use oceanbase;
ob1.mysql alter tenant $backup_oracle_tenant set primary_zone = 'z1';
ob1.check_until_timeout select count(*)>=2 from oceanbase.__all_virtual_ls_status where status = 'NORMAL' and tenant_id = $backup_oracle_tenant_id, 1, 100;
ob1.check_until_timeout select floor(checkpoint_scn / 1000) > '$restore_checkpoint1' from CDB_OB_ARCHIVELOG, 1, 600;
ob1.check_until_timeout select floor(checkpoint_scn / 1000) > '$restore_checkpoint2' from CDB_OB_ARCHIVELOG, 1, 600;
ob1.mysql alter resource unit sys_unit_config memory_size='2G';
ob1.mysql alter system set enable_async_syslog=false;
ob1.mysql alter system restore $restore_oracle_tenant from '$restore_path' until time='$restore_checkpoint' with 'pool_list=small_pool_2&primary_zone=z1';
ob1.check_until_timeout SELECT status FROM __all_tenant WHERE tenant_id = 1005, NORMAL, 200;
ob1.check_until_timeout select count(*) from __all_virtual_ls_meta_table where tenant_id = 1006 and restore_status = 0, 6, 1200;
ob1.check_until_timeout select status FROM __all_tenant WHERE tenant_id = 1006, NORMAL, 200;
ob1.check_until_timeout select count(*) FROM __all_restore_job, 0, 200;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_tenant_info where tenant_id = 1006 and tenant_role = 'STANDBY' and switchover_status = 'NORMAL', 1, 10;
ob1.mysql ALTER SYSTEM RECOVER STANDBY TENANT $restore_oracle_tenant UNTIL UNLIMITED;
create table t3(a int, b int, c int, CONSTRAINT "c3" PRIMARY KEY ("A"));
create index idx_3 on t3(B);
insert into t3(a, b) values(1, 1);
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_tenant_info where tenant_id = 1004 and tenant_role = 'PRIMARY' and switchover_status = 'NORMAL', 1, 10;
select TENANT_ID, TENANT_NAME, TENANT_TYPE, COMPATIBILITY_MODE, STATUS, IN_RECYCLEBIN, LOCKED, TENANT_ROLE, SWITCHOVER_STATUS, LOG_MODE from DBA_OB_TENANTS order by TENANT_ID;
