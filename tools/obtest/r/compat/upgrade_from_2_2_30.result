set` bigint(20) DEFAULT '0',\n  `locality` varchar(4096) NOT NULL DEFAULT '',\n  `tablet_size` bigint(20) NOT NULL DEFAULT '134217728',\n  `pctfree` bigint(20) NOT NULL DEFAULT '10',\n  `previous_locality` varchar(4096) NOT NULL DEFAULT '',\n  `max_used_part_id` bigint(20) NOT NULL DEFAULT '-1',\n  `partition_cnt_within_partition_table` bigint(20) NOT NULL DEFAULT '-1',\n  `partition_status` bigint(20) DEFAULT '0',\n  `partition_schema_version` bigint(20) DEFAULT '0',\n  `max_used_constraint_id` bigint(20) DEFAULT NULL,\n  `session_id` bigint(20) DEFAULT '0',\n  `pk_comment` varchar(4096) NOT NULL DEFAULT '',\n  `sess_active_time` bigint(20) DEFAULT '0',\n  `row_store_type` varchar(128) DEFAULT 'encoding_row_store',\n  `store_format` varchar(128) DEFAULT '',\n  `duplicate_scope` bigint(20) DEFAULT '0',\n  `binding` tinyint(4) DEFAULT '0',\n  `progressive_merge_round` bigint(20) DEFAULT '0',\n  `storage_format_version` bigint(20) DEFAULT '2',\n  `table_mode` bigint(20) NOT NULL DEFAULT '0',\n  `encryption` varchar(128) DEFAULT '',\n  `tablespace_id` bigint(20) NOT NULL DEFAULT '-1',\n  `drop_schema_version` bigint(20) NOT NULL DEFAULT '-1',\n  PRIMARY KEY (`tenant_id`, `table_id`)\n) DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'none' REPLICA_NUM = 3 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 10 TABLEGROUP = 'oceanbase'\n partition by key (tenant_id) partitions 16\n
