ob1.mysql alter system minor freeze tenant = all;
set autocommit=0;
insert into db1.tb_normal(pk,c1) values(801,'801'),(802,'802'),(803,'803'),(804,'804');
update db1.tb_normal set c1=concat(c1,'_x') where pk > 100;
delete from db1.tb_normal where pk=804;
update db1.tb_increment set pk=pk+1 order by pk desc limit 1;
insert into db1.tb_increment(pk,c1) values (801,801),(802,802);
replace into db1.tb_increment(pk,c1) values (801,802);
delete from db1.tb_increment where pk=802;
commit;
set autocommit=1;
set @@session.ob_query_timeout = 60000000;
alter system upgrade virtual schema;
ob1.upgrade_commond_for_server post;
ob1.mysql alter system end upgrade;
ob1.mysql alter system run job 'root_inspection';
ob1.upgrade_check_after;
