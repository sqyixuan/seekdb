  `id` int(11) DEFAULT NULL,
  `body` varchar(10) DEFAULT NULL, 
 FULLTEXT KEY `body` (`body`) CTXCAT(`body`) WITH PARSER 'TAOBAO_CHN' BLOCK_SIZE 16384
) DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.0' REPLICA_NUM = 3 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 10
show create table test.tablegencol;
Table	Create Table
tablegencol	CREATE TABLE `tablegencol` (
  `c1` bigint(20) NOT NULL,
  `user_id` varchar(32) NOT NULL DEFAULT '' COMMENT 'Alipay User ID',
  `address` varchar(256) NOT NULL DEFAULT '' COMMENT 'address',
  PRIMARY KEY (`c1`),
  KEY `user_id` (`user_id`, `address`(255)) BLOCK_SIZE 16384 GLOBAL
) DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.0' REPLICA_NUM = 3 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 10
