__all_table	CREATE TABLE `__all_table` (\n  `gmt_create` timestamp(6) NULL DEFAULT CURRENT_TIMESTAMP(6),\n  `gmt_modified` timestamp(6) NULL DEFAULT CURRENT_TIMESTAMP(6) ON UPDATE CURRENT_TIMESTAMP(6),\n  `tenant_id` bigint(20) NOT NULL,\n  `table_id` bigint(20) NOT NULL,\n  `table_name` varchar(256) NOT NULL DEFAULT '',\n  `database_id` bigint(20) NOT NULL,\n  `table_type` bigint(20) NOT NULL,\n  `load_type` bigint(20) NOT NULL,\n  `def_type` bigint(20) NOT NULL,\n  `rowkey_column_num` bigint(20) NOT NULL,\n  `index_column_num` bigint(20) NOT NULL,\n  `max_used_column_id` bigint(20) NOT NULL,\n  `replica_num` bigint(20) NOT NULL,\n  `autoinc_column_id` bigint(20) NOT NULL,\n  `auto_increment` bigint(20) unsigned DEFAULT '1',\n  `read_only` bigint(20) NOT NULL,\n  `rowkey_split_pos` bigint(20) NOT NULL,\n  `compress_func_name` varchar(128) NOT NULL,\n  `expire_condition` varchar(4096) NOT NULL,\n  `is_use_bloomfilter` bigint(20) NOT NULL,\n  `comment` varchar(4096) NOT NULL DEFAULT '',\n  `block_size` bigint(20) NOT NULL,\n  `collation_type` bigint(20) NOT NULL,\n  `data_table_id` bigint(20) DEFAULT NULL,\n  `index_status` bigint(20) NOT NULL,\n  `tablegroup_id` bigint(20) NOT NULL,\n  `progressive_merge_num` bigint(20) NOT NULL,\n  `index_type` bigint(20) NOT NULL,\n  `part_level` bigint(20) NOT NULL,\n  `part_func_type` bigint(20) NOT NULL,\n  `part_func_expr` varchar(4096) NOT NULL,\n  `part_num` bigint(20) NOT NULL,\n  `sub_part_func_type` bigint(20) NOT NULL,\n  `sub_part_func_expr` varchar(4096) NOT NULL,\n  `sub_part_num` bigint(20) NOT NULL,\n  `create_mem_version` bigint(20) NOT NULL,\n  `schema_version` bigint(20) NOT NULL,\n  `view_definition` varchar(65536) NOT NULL,\n  `view_check_option` bigint(20) NOT NULL,\n  `view_is_updatable` bigint(20) NOT NULL,\n  `zone_list` varchar(8192) NOT NULL,\n  `primary_zone` varchar(128) DEFAULT NULL,\n  `index_using_type` bigint(20) NOT NULL DEFAULT '0',\n  `parser_name` varchar(128) DEFAULT NULL,\n  `index_attributes_set` bigint(20) DEFAULT '0',\n  `locality` varchar(4096) NOT NULL DEFAULT '',\n  `tablet_size` bigint(20) NOT NULL DEFAULT '134217728',\n  `pctfree` bigint(20) NOT NULL DEFAULT '10',\n  `previous_locality` varchar(4096) NOT NULL DEFAULT '',\n  `max_used_part_id` bigint(20) NOT NULL DEFAULT '-1',\n  `partition_cnt_within_partition_table` bigint(20) NOT NULL DEFAULT '-1',\n  `partition_status` bigint(20) DEFAULT '0',\n  `partition_schema_version` bigint(20) DEFAULT '0',\n  `max_used_constraint_id` bigint(20) DEFAULT NULL,\n  `session_id` bigint(20) DEFAULT '0',\n  `pk_comment` varchar(4096) NOT NULL DEFAULT '',\n  `sess_active_time` bigint(20) DEFAULT '0',\n  `row_store_type` varchar(128) DEFAULT 'encoding_row_store',\n  `store_format` varchar(128) DEFAULT '',\n  `duplicate_scope` bigint(20) DEFAULT '0',\n  `binding` tinyint(4) DEFAULT '0',\n  `progressive_merge_round` bigint(20) DEFAULT '0',\n  `storage_format_version` bigint(20) DEFAULT '2',\n  `table_mode` bigint(20) NOT NULL DEFAULT '0',\n  `encryption` varchar(128) DEFAULT '',\n  `tablespace_id` bigint(20) NOT NULL DEFAULT '-1',\n  `drop_schema_version` bigint(20) NOT NULL DEFAULT '-1',\n  PRIMARY KEY (`tenant_id`, `table_id`)\n) DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'none' REPLICA_NUM = 3 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 10 TABLEGROUP = 'oceanbase'\n partition by key (tenant_id) partitions 16\n
