create index idx1 on t_cg_1(c1);
create index idx2 on t_cg_2(c1);
create index idx3 on t_cg_3(c1);
create database db1;
create tablegroup tg;
create table db1.tb_normal (pk int primary key,c1 varchar(1024) default '0', c2 timestamp(6) default now(6), c3 timestamp default now(), index i1(c2), index i2(c1)) tablegroup tg;
create table db1.tb_increment (pk int primary key auto_increment,c1 int, c2 datetime(6) DEFAULT CURRENT_TIMESTAMP(6) ON UPDATE CURRENT_TIMESTAMP(6), index i1(c2)) tablegroup tg;
create table db1.tb_bigtable (c1 varchar(65536),c2 varchar(65536),c3 varchar(65536),c4 varchar(65536), pk bigint primary key auto_increment) COMPRESSION = 'none' tablegroup tg;
create table db1.global_t6(a int, b int, c int, primary key(a)) partition by hash(a) partitions 2;
create index gkey on db1.global_t6(b) global;
insert into db1.global_t6 values(1, 5, 1), (2, 4, 2), (3, 3, 3), (4, 2, 4), (5, 1, 5);
create table db1.global_t7(a int, b int, c int, primary key(a));
insert into db1.global_t7 values(1, 5, 1), (2, 4, 2), (3, 3, 3), (4, 2, 4), (5, 1, 5);
create table test.tb_table_gencol(pk1 bigint, pk2 varchar(2048),c1 varchar(65536), c2 varchar(65536),ac1 bigint auto_increment,
ts timestamp(6) DEFAULT CURRENT_TIMESTAMP(6) ON UPDATE CURRENT_TIMESTAMP(6),  gmt_create timestamp(6) default now(6), gmt_modified timestamp(6) default now(6),
gen_c1 varchar(10) GENERATED ALWAYS AS (substr(c1,1,10)) virtual,
gen_c2 varchar(10) GENERATED ALWAYS AS (substr(c2,1,10)) stored,
primary key(pk1, pk2),index i1(ts));
create table test.tablegencol(c1 bigint primary key,user_id varchar(32) NOT NULL default '' comment 'Alipay User ID', address varchar(256) NOT NULL default '' comment 'address', index(user_id,address(255)));
create table test.table_hash(c1 int primary key, c2 int) partition by hash(c1) partitions 2;
create table test.table_range(c1 int primary key, c2 int) partition by range(c1) (partition p0 values less than (100), partition p1 values less than (200), partition p2 values less than MAXVALUE);
create table test.table_hash_range (c1 int primary key, c2 int) partition by hash(c1) subpartition by range(c1) subpartition template(SUBPARTITION c0 VALUES LESS THAN(1990), SUBPARTITION c1 VALUES LESS THAN (2000), SUBPARTITION c2 VALUES LESS THAN MAXVALUE) partitions 2;
create table test.table_range_hash (c1 int primary key, c2 int) partition by range(c1) subpartition by hash(c1) subpartitions 2 (PARTITION c0 VALUES LESS THAN (1980), PARTITION c1 VALUES LESS THAN (1990), PARTITION c2 VALUES LESS THAN (1995), PARTITION c3 VALUES LESS THAN (2000), PARTITION c4 VALUES LESS THAN MAXVALUE);
create tablegroup tg_old;
create table test.table_with_tg(c1 int primary key, c2 int) tablegroup tg_old;
create table test.t_parent(c1 int, c2 int, constraint t_parent_pk primary key(c1, c2));
create table test.t_child(c1 int, c2 int, constraint t_child_fk foreign key(c2, c1) references test.t_parent(c1, c2));
create table test.t_check_1(c1 int, c2 int, constraint cst1 check(c1 = c2));
create table test.t_check_2(c1 int, c2 int, constraint cst2 check(c2 = c1));
create table test.local_var(c1 timestamp, c2_local_var date as (c1), index i1 (c2_local_var));
