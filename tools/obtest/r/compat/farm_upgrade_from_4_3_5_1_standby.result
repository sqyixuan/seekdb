ob1=OBI(cluster=1:1:1,proxy_num=1,ct_num=1,locality=SZ:SZ:SZ,version=4_3_5_1);
ob2=OBI(cluster=1:1:1,share_proxy=ob1,ct_num=1,locality=SZ:SZ:SZ,version=4_3_5_1);
ob1.reboot;
ob2.reboot;
ob1.z1.obs0.sh cd $work_dir/; ls -l {etc,etc2,etc3}/observer.conf*.bin;
ob1.z2.obs0.sh cd $work_dir/; ls -l {etc,etc2,etc3}/observer.conf*.bin;
ob1.z3.obs0.sh cd $work_dir/; ls -l {etc,etc2,etc3}/observer.conf*.bin;
ob2.z1.obs0.sh cd $work_dir/; ls -l {etc,etc2,etc3}/observer.conf*.bin;
ob2.z2.obs0.sh cd $work_dir/; ls -l {etc,etc2,etc3}/observer.conf*.bin;
ob2.z3.obs0.sh cd $work_dir/; ls -l {etc,etc2,etc3}/observer.conf*.bin;
ob1.mysql alter tenant sys set primary_zone = "z1";
ob2.mysql alter tenant sys set primary_zone = "z1";
CREATE RESOURCE UNIT unit_primary  MEMORY_SIZE = '5G',MAX_CPU = 1, MIN_CPU = 1,LOG_DISK_SIZE = '6G',MAX_IOPS = 10000, MIN_IOPS = 10000, IOPS_WEIGHT=1;
ob1.check_until_timeout select count(*) FROM oceanbase.DBA_OB_UNIT_CONFIGS WHERE NAME = "$unit1name", 1, 120;
CREATE RESOURCE POOL pool_primary UNIT= unit_primary ,UNIT_NUM=1, ZONE_LIST=('z1','z2','z3');
ob1.check_until_timeout select count(*) FROM DBA_OB_RESOURCE_POOLS WHERE NAME = "$pool1name",1, 120;
CREATE TENANT IF NOT EXISTS tenant_primary PRIMARY_ZONE='z1',RESOURCE_POOL_LIST=('pool_primary') SET OB_TCP_INVITED_NODES='%';
ob1.check_until_timeout select count(*) FROM DBA_OB_TENANTS WHERE TENANT_NAME = "$tenant_primary",1,120;
ob1.check_until_timeout  select count(*) as num from ((SELECT LS_ID FROM oceanbase.CDB_OB_LS_HISTORY WHERE TENANT_ID = $mysql_tenant_id) EXCEPT (SELECT LS_ID FROM oceanbase.CDB_OB_LS WHERE TENANT_ID = $mysql_tenant_id)),0,5;
ob1.check_until_timeout  select count(LS_ID) as num FROM oceanbase.GV\$OB_LOG_STAT WHERE ROLE = 'LEADER' and  BEGIN_LSN=0 and TENANT_ID =$mysql_tenant_id,2,5;
create user user identified by 'userpw';
GRANT SELECT ON oceanbase.* TO 'user';
CREATE RESOURCE UNIT unit_primary MAX_CPU 1, MEMORY_SIZE = '5G';
CREATE RESOURCE POOL pool_primary UNIT = 'unit_primary', UNIT_NUM = 1, ZONE_LIST = ('z1','z2','z3');
ob1.mysql alter tenant $tenant_primary set variables autocommit='on';
ob2.mysql alter tenant $tenant_standby set variables autocommit='on';
ob1.mysql alter system set balancer_idle_time='10s';
ob1.mysql alter system set merger_check_interval='10s' tenant all;
ob1.mysql alter system set ob_compaction_schedule_interval='10s' tenant all;
ob2.mysql alter system set balancer_idle_time='10s';
ob2.mysql alter system set merger_check_interval='10s' tenant all;
ob2.mysql alter system set ob_compaction_schedule_interval='10s' tenant all;
ob1.mysql set global ob_sql_audit_percentage=80;
ob2.mysql set global ob_sql_audit_percentage=80;
alter proxyconfig set server_state_refresh_interval='1s';
alter proxyconfig set server_state_refresh_interval='1s';
create database int2bigint;
create sequence int2bigint.s_mix cache 1000000 noorder;
create sequence int2bigint.s_finish cache 1000000 noorder;
create sequence int2bigint.s_finish_end cache 1000000 noorder;
create table int2bigint.t_foreign_depend (i_f_d int primary key);
create table int2bigint.t_mix (i_p int primary key, i_i int, i_g_d int, i_g_i_d int, i_f int, i_u int unsigned, i_c int, c char(20), c_g_d char(20), d decimal(10,2), d_i decimal(10,2), i_g int GENERATED ALWAYS AS (i_g_d+1) stored, i_g_i int GENERATED ALWAYS AS (i_g_i_d+1) stored, c_g char(40) GENERATED ALWAYS AS (concat(c_g_d,c_g_d)) virtual, foreign key (i_f) references int2bigint.t_foreign_depend(i_f_d), check (i_c<10000));
create table int2bigint.t_finish (i_p int primary key, i_i int, i_g_d int, i_g_i_d int, i_f int, i_u int unsigned, i_c int, c char(20), c_g_d char(20), d decimal(10,2), d_i decimal(10,2), i_g int GENERATED ALWAYS AS (i_g_d+1) stored, i_g_i int GENERATED ALWAYS AS (i_g_i_d+1) stored, c_g char(40) GENERATED ALWAYS AS (concat(c_g_d,c_g_d)) virtual, foreign key (i_f) references int2bigint.t_foreign_depend(i_f_d), check (i_c<10000));
insert into int2bigint.t_foreign_depend values (1);
create index idx_t_mix_i_i on int2bigint.t_mix(i_i);
create index idx_t_mix_d_i on int2bigint.t_mix(d_i);
create index idx_t_mix_i_g_i on int2bigint.t_mix(i_g_i);
create index idx_t_finish_i_i on int2bigint.t_finish(i_i);
create index idx_t_finish_d_i on int2bigint.t_finish(d_i);
create index idx_t_finish_i_g_i on int2bigint.t_finish(i_g_i);
