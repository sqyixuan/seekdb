ob2.check_until_timeout select count(*) from __all_virtual_tenant_parameter_stat where name = 'compatible' and value!="$dest_version",0,2;
ob1.check_until_timeout SELECT SWITCHOVER_STATUS FROM DBA_OB_TENANTS WHERE TENANT_NAME= '$tenant_primary' and TENANT_ROLE="STANDBY",NORMAL,120;
