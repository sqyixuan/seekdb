create database test1;
use test1;
create table t_cg_0(c1 int, c2 int unique, c3 text);
create table t_cg_1(c1 int, c2 int unique, c3 text);
create table t_cg_2(c1 int, c2 int unique, c3 text);
create table t_cg_3(c1 int, c2 int unique, c3 text);
