use db1;
select /*+index(global_t6 primary)*/ a, b, c from global_t6;
a	b	c
2	1	1
20	2	2
30	3	3
40	4	4
ob1.mysql alter system minor freeze tenant = all;
set autocommit=0;
insert into db1.tb_normal(pk,c1) values(701,'701'),(702,'702'),(703,'703'),(704,'704');
update db1.tb_normal set c1=concat(c1,'_x') where pk > 100;
delete from db1.tb_normal where pk=704;
update db1.tb_increment set pk=pk+1 order by pk desc limit 1;
insert into db1.tb_increment(pk,c1) values (702,702),(703,703);
replace into db1.tb_increment(pk,c1) values (702,701);
delete from db1.tb_increment where pk=703;
commit;
set autocommit=1;
ob1.check_until_timeout select count(*) as cnt from oceanbase.__all_virtual_server_schema_info as a join oceanbase.__all_virtual_server_schema_info as b on a.tenant_id = b.tenant_id  where a.refreshed_schema_version != b.refreshed_schema_version, 0, 60;
ob1.check_until_timeout  select count(1) as unsync_cnt from GV\$OB_LOG_STAT where in_sync = 'NO',0,600;
set @@session.ob_query_timeout = 60000000;
alter system stop zone 'z3';
ob1.check_until_timeout select status from DBA_OB_ZONES where zone='z3',INACTIVE,20;
ob1.check_until_timeout select count(1) as leader_count  from CDB_OB_LS_LOCATIONS where zone='z3' and role='leader',0,20;
ob1.z3.force_stop;
ob1.check_until_timeout select count(*) from oceanbase.DBA_OB_SERVERS where zone = 'z3' and (start_service_time is null and status='INACTIVE'),1,60;
ob1.z3.upgrade;
ob1.z3.nstart;
ob1.check_until_timeout select count(*) from oceanbase.__all_server where zone = 'z3' and (start_service_time <= 0 or status='INACTIVE'),0,120;
ob1.check_until_timeout  select count(1) as unsync_cnt from GV\$OB_LOG_STAT where in_sync = 'NO',0,600;
ob1.check_until_timeout select count(*) from oceanbase.__all_server a left join oceanbase.__all_virtual_server_schema_info b on a.svr_ip = b.svr_ip and a.svr_port = b.svr_port where b.svr_ip is null, 0, 120;
ob1.check_until_timeout select count(*) as cnt from oceanbase.__all_virtual_server_schema_info as a join oceanbase.__all_virtual_server_schema_info as b on a.tenant_id = b.tenant_id  where a.refreshed_schema_version != b.refreshed_schema_version or a.refreshed_schema_version % 8 != 0, 0, 180;
ob1.mysql alter system start zone 'z3';
ob1.mysql alter system minor freeze tenant = all;
set autocommit=0;
insert into db1.tb_normal(pk,c1) values(801,'801'),(802,'802'),(803,'803'),(804,'804');
update db1.tb_normal set c1=concat(c1,'_x') where pk > 100;
delete from db1.tb_normal where pk=804;
update db1.tb_increment set pk=pk+1 order by pk desc limit 1;
insert into db1.tb_increment(pk,c1) values (801,801),(802,802);
replace into db1.tb_increment(pk,c1) values (801,802);
delete from db1.tb_increment where pk=802;
commit;
set autocommit=1;
ob1.z1.obs0.mysql select * from mysql.proc;
ob1.z1.obs0.mysql select * from mysql.db;
ob1.z1.obs0.mysql select * from mysql.user;
ob1.z2.obs0.mysql select * from mysql.proc;
ob1.z2.obs0.mysql select * from mysql.db;
ob1.z2.obs0.mysql select * from mysql.user;
ob1.z3.obs0.mysql select * from mysql.proc;
ob1.z3.obs0.mysql select * from mysql.db;
ob1.z3.obs0.mysql select * from mysql.user;
ob1.upgrade_commond_for_server post;
ob1.check_until_timeout select count(*) from __all_virtual_tenant_parameter_stat where name = 'compatible' and value!="$dest_version",0,5;
ob2.check_until_timeout select count(*) from __all_virtual_tenant_parameter_stat where name = 'compatible' and value!="$dest_version",0,5;
ALTER SYSTEM SET query_response_time_stats=true;
ob2.check_until_timeout SELECT count(*) FROM oceanbase.GV\$OB_PARAMETERS WHERE NAME LIKE "query_response_time_stats" and value!="true" and tenant_id=1,0,5;
ob1.check_until_timeout select count(*) from __all_virtual_tenant_parameter_stat where name = 'compatible' and value!="$dest_version",0,2;
ob2.check_until_timeout select count(*) from __all_virtual_tenant_parameter_stat where name = 'compatible' and value!="$dest_version",0,2;
ALTER SYSTEM SET query_response_time_stats=false;
ob2.check_until_timeout SELECT count(*) FROM oceanbase.GV\$OB_PARAMETERS WHERE NAME LIKE "query_response_time_stats" and value!="false"and tenant_id=1,0,5;
ob1.check_until_timeout select count(*) from __all_virtual_tenant_parameter_stat where name = 'compatible' and value!="$dest_version",0,2;
ob2.check_until_timeout select count(*) from __all_virtual_tenant_parameter_stat where name = 'compatible' and value!="$dest_version",0,2;
set @@session.ob_query_timeout = 600000000;
alter system run job 'root_inspection';
set @@session.ob_query_timeout = 10000000;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_upgrade_inspection where info != 'succeed',0,180;
ob1.mysql_p select tenant_id, max_ls_id from oceanbase.__all_virtual_tenant_info order by tenant_id;
