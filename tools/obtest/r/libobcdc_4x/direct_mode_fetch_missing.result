ob1=OBI(cluster=1, init_unit_cpu=5);
ob1.force_stop;
ob1.clean_backup_dest;
ob1.z1.obs0.set extra_config=_private_buffer_size='1B';
ob1.reboot;
create resource unit oblog_box max_cpu 2, memory_size='20G';
create resource pool oblog_pool unit = 'oblog_box', unit_num = 1, zone_list = ('z1');
create tenant oblog_tt replica_num = 1, primary_zone='z1', resource_pool_list=('oblog_pool') set ob_tcp_invited_nodes='%';
ob1.check_until_timeout select count(*) as num from oceanbase.__all_virtual_archive_stat, 0, 60;
ob1.mysql alter system archivelog;
ob1.check_until_timeout select status from oceanbase.CDB_OB_ARCHIVELOG where tenant_id=$backup_tenant_id, DOING, 600;
set global max_allowed_packet=1073741824;
set ob_trx_timeout=100000000;
set ob_query_timeout=1000000000;
create database oblog_db;
use oblog_db;
create table test_tt(id int primary key, name text);
set autocommit=0;
begin;
insert into test_tt values (1, 'a');
insert into test_tt values (2, 'a');
insert into test_tt values (3, 'a');
insert into test_tt values (4, null);
insert into test_tt values (5, 'a');
insert into test_tt values (6, 'a');
insert into test_tt values (7, 'a');
insert into test_tt values (8, 'a');
commit;
ob1.oblog.set_start_tstamp_usec $start_tstamp_usec;
ob1.oblog.gen_conf tb_white_list=oblog_tt.*.* log_level=DEBUG fetching_log_mode=direct archive_dest=$log_backup_dest;
ob1.oblog.set_extra_argument;
ob1.oblog.restart;
ob1.oblog.next;
