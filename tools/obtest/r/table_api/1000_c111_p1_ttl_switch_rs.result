ob1=OBI(cluster=1:1:1,proxy_num=1);
ob1.reboot;
ob1.mysql alter system set enable_rebalance='false';
set @@session.ob_query_timeout = 1000000000;
CREATE RESOURCE UNIT unit_1 MAX_CPU 4, MIN_CPU 1, MEMORY_SIZE 8589934592, LOG_DISK_SIZE 3221225472, MAX_IOPS 100000, MIN_IOPS 1024;
CREATE RESOURCE POOL pool_1 UNIT = 'unit_1', UNIT_NUM = 1;
CREATE TENANT mysql RESOURCE_POOL_LIST = ('pool_1'), primary_zone='z1' set ob_tcp_invited_nodes='%';

>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>
1: TTL SYS LS SWITCH TEST
>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>
alter system minor freeze;
alter system set enable_kv_ttl = true;
create table ttl_table_sw_rs(a varchar(1024), b int primary key, c timestamp) TTL(c + INTERVAL 0 SECOND) partition by key(b) partitions 32;
--> get Log Stream leader done
--> get Log Stream follower done
--> insert into ttl_table_sw_rs 200 row...
--> insert 200 rows end
ob1.mysql alter system switch replica leader ls=1 server='$follower' tenant='mysql';
--> switch ls completed
ob1.check_until_timeout select concat(svr_ip,':',svr_port) as host from oceanbase.cdb_ob_ls_locations where tenant_id = $tenant_id and ls_id = 1 and ROLE = 'LEADER' limit 1, $follower, 15;
ob1.mysql alter system trigger ttl tenant = mysql;
--> trigger ttl
ob1.mysql alter system suspend ttl tenant = mysql;
--> suspend ttl
ob1.mysql alter system switch replica leader ls=1 server='$leader' tenant='mysql';
--> switch ls back completed
ob1.check_until_timeout select concat(svr_ip,':',svr_port) as host from oceanbase.cdb_ob_ls_locations where tenant_id = $tenant_id and ls_id = 1 and ROLE = 'LEADER' limit 1, $leader, 15;
ERROR HY000: TTL command is not allowed, current TTL status is 'PENDING'
--> trigger ttl
TotalCount
1
--> resume ttl
