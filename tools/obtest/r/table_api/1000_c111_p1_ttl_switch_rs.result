3: TTL Multi-Leader TEST
>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>
ob1.mysql alter system set debug_sync_timeout = '100000s';
ob1.mysql set ob_global_debug_sync = 'BEFORE_CHECK_TTL_TASK_FINISH wait_for continue_signal execute 10000';
ob1.mysql alter system trigger ttl tenant = mysql;
--> trigger ttl
ob1.check_until_timeout select count(*) as task_cnt from oceanbase.cdb_ob_kv_ttl_tasks where task_type = "NORMAL" and table_id != -1 and tenant_id = $tenant_id, 32, 90;
ob1.mysql set ob_global_debug_sync = 'BEFORE_TTL_SCHEDULER_RUN wait_for continue_signal execute 10000';
ob1.mysql alter system switch replica leader ls=1 server='$follower' tenant='mysql';
--> switch ls completed
ob1.check_until_timeout select concat(svr_ip,':',svr_port) as host from oceanbase.cdb_ob_ls_locations where tenant_id = $tenant_id and ls_id = 1 and ROLE = 'LEADER' limit 1, $follower, 15;
ob1.mysql set ob_global_debug_sync = 'BEFORE_TTL_SCHEDULER_RUN clear';
ob1.mysql set ob_global_debug_sync = 'BEFORE_CHECK_TTL_TASK_FINISH clear';
ob1.mysql set ob_global_debug_sync = 'now broadcast continue_signal';
ob1.check_until_timeout select count(*) as task_cnt from oceanbase.cdb_ob_kv_ttl_tasks where task_type = "NORMAL" and tenant_id = $tenant_id, 0, 90;
