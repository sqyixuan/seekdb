1. Too many expired version records hbase table
>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>
alter system minor freeze;
alter system set enable_kv_ttl = true;
create table if not exists ttl_hbase_table (K varbinary(1024), Q varbinary(256), T bigint, V varbinary(1024), primary key(K, Q, T)) kv_attributes ='{"Hbase": {"MaxVersions": 1}}' partition by key(K) partitions 3;
--> insert into ttl_hbase_table 1500 row...
--> insert 1500 rows end
--> trigger ttl
ob1.check_until_timeout select count(*) as task_cnt from oceanbase.cdb_ob_kv_ttl_tasks where task_type = "NORMAL" and tenant_id = $tenant_id, 0, 90;
--> check task finished success
K	Q	T	V
row0	cq0	0	hello world
