ob1=OBI(cluster=1,proxy_num=0);
ob1.reboot;
create table t1(c1 int, c2 varchar(10), c3 date);
insert into t1 values(5236, 'scott', '2018-5-8');
insert into t1 values(1024, 'songxin', '2018-1-1');
### Q1 basic test
create table t1_x11 as select * from t1;
show create table t1_x11;
Table	Create Table
t1_x11	CREATE TABLE `t1_x11` (
  `c1` int(11) DEFAULT NULL,
  `c2` varchar(10) DEFAULT NULL,
  `c3` date DEFAULT NULL
) DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
insert into t1_x11 values(1, 'x', '2018-5-12'), (11, 'x2', '2018-5-12'), (31, 'x4', '2018-5-12'),
(13, '44x', '2018-5-12'), (1, '5x', '2018-5-12'), (1, 'xz', '2018-5-12'), (1, 'x6', '2018-5-12'),
(31, 'x44', '2018-5-12');
create table t1_x11_copy as select a.* from t1_x11 a, t1_x11 b, t1_x11 c;
ob1.mysql alter system set_tp tp_no = 57, error_code = 4012, frequency = 1;
create table xy as select a.* from t1_x11_copy a;
ERROR HY000: Timeout
ob1.mysql alter system set_tp tp_no = 57, error_code = 4012, frequency = 0;
ob1.check_until_timeout select count(*) from __all_table_v2 where table_name = 'xy' and session_id > 0, 1, 30;
ob1.check_until_timeout select count(*) from __all_table_v2 where table_name = 'xy' and session_id > 0, 0, 30;
alter system set _ob_ddl_timeout = '5s';
create table xy as select a.* from t1_x11_copy a, t1_x11_copy b, t1_x11_copy c;
ERROR HY000: Timeout
alter system set _ob_ddl_timeout = '1000s';
ob1.check_until_timeout select count(*) from __all_table_v2 where table_name = 'xy' and session_id > 0, 0, 30;
