### Q1.2 table defination and select item duplicated, expect to use the one in table define(c1,c2)
create table t1_x2 (c1 char(10)) as select c1,c2 from t1;
show create table t1_x2;
Table	Create Table
t1_x2	CREATE TABLE `t1_x2` (
  `c1` char(10) DEFAULT NULL,
  `c2` varchar(10) DEFAULT NULL
) DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
### Q1.3 table defination and select item match but with different order, expect result(c1,c3,c2)
create table t1_y (c1 int, c2 varchar(10), c3 date) as select c1, c3, c2 from t1;
select * from t1_y;
c1	c3	c2
5236	2018-05-08	scott
1024	2018-01-01	songxin
### Q1.4 table defination and select item have some in common but with different datatypes,  mysql returns(c2 int,c4 int,c1 date,c3 char(100))
create table t1_z (c2 int, c3 char(100), c4 int) as
select c3 as c1, cast(c1 as char(40)) as c3 from t1;
select * from t1_z;
c2	c4	c1	c3
NULL	NULL	2018-05-08	5236
NULL	NULL	2018-01-01	1024
### Q2 complex case
create table t1_complex(c1 int default 555, c2 varchar(100), c3 bigint, c4 date, c5 int, c6 double)
partition by hash(c3) partitions 2
as select c1 as x, c2 , c1 * 100, c3, c1 - 1 as y, c1 / 3.1 as z from t1;
ERROR 0A000: uncertain plan violating external consistency not supported
create table t1_complex2(c3 bigint) partition by hash(c3) partitions 2
as select 5 as c3 from t1;
create table t1_complex3 (c1 int, c2 int, constraint chk check (c1 = c2)) select c1, length(c2) as c2 from t1;
create table t1_complex_query as
select min(c1), max(c2), c3 from t1 group by c3
union all
select * from t1 x where x.c1 in (select y.c1 from t1 y where x.c2 = y.c2 and x.c3 <> y.c3) and
length(x.c2) > (select count(*) from t1 aa left join t1 bb on aa.c1 = bb.c1 where aa.c1 - bb.c1 < x.c1 - x.c1*1.5)
union all
select a.* from t1 a, t1 b where a.c1 = 1 or length(a.c2) > (select count(*) from t1 c where c.c1 = b.c1 or c.c2 > concat(b.c2 , a.c2))
and not exists (select 1 from t1 d where d.c1 = a.c1 and d.c2 < (select '1' from t1 where c1+length(c2) in (1,2,3)));
select * from t1_complex_query ;
min(c1)	max(c2)	c3
5236	scott	2018-05-08
1024	songxin	2018-01-01
5236	scott	2018-05-08
1024	songxin	2018-01-01
5236	scott	2018-05-08
1024	songxin	2018-01-01
