select count(*) from t222_var;
count(*)
1024
set  ob_query_timeout=200000000;
set  ob_trx_timeout=200000000;
select /*+ trac1ing(11)*/ sum(length(a.c1)),sum(d.c0),count(*)  from t222_var d
,
(select /*+ use_px parallel(2)  */ distinct a.c1,a.c2 from (select /*+ leading(b (c a) ) use_hash(b a) pq_distribute((a,c) hash hash) pq_distribute(a broadcast None) */
a.*
from (select a.* from t222_var a, t222_var c where a.c0=c.c0)a,t333_var b  where a.c0=b.c0) a)a
where d.c1=a.c1;
sum(length(a.c1))	sum(d.c0)	count(*)
4096000	568888889856	1024
select /*+ trac1ing(11)*/ sum(length(a.c1)),sum(d.c0),count(*)  from t222_var d
,
(select /*+ no_use_px */ distinct a.c1,a.c2 from (select /*+ leading(b (c a) ) use_hash(b a) pq_distribute((a,c) hash hash) pq_distribute(a broadcast None) */
a.*
from (select a.* from t222_var a, t222_var c where a.c0=c.c0)a,t333_var b  where a.c0=b.c0) a)a
where d.c1=a.c1;
