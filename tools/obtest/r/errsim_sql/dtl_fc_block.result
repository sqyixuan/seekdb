select /*+ use_px parallel(2)  use_merge(a,b)*/ SQL_CALC_FOUND_ROWS count(*), sum(length(a.c1)), sum(length(a.c2)),sum(length(a.c3)),sum(length(a.c4)),sum(length(a.c5)),sum(length(a.c6)),sum(length(a.c7)),sum(b.c0) from (select a.c0 as c00, a.* from t222_var a)a join t333_var b on a.c00=b.c0 where a.c0 >=b.c0 order by a.c0 limit 1;
