ob1=OBI(cluster=1,proxy_num=0);
ob1.reboot;
ob1.mysql alter system set_tp tp_no = 128, error_code = 4201, frequency = 1;
ob1.mysql create resource unit t1_unit max_cpu=5,min_memory='10G',max_memory='10G',max_disk_size='100G',max_iops=1000,max_session_num=1000;
ob1.mysql create resource pool t1_pool unit = 't1_unit', unit_num = 1, zone_list= ("z1");
ob1.mysql create tenant t1 replica_num 1, resource_pool_list ('t1_pool') set ob_tcp_invited_nodes='%';
create table t333_var(c0 bigint ,c1 varchar(4000), c2 varchar(4000), c3 varchar(4000), c4 varchar(4000), c5 varchar(4000),c6 varchar(4000), c7 longtext)
partition by hash(c0) partitions 7;
insert into t333_var values(1,repeat('ab',2000),repeat('ab',2000),repeat('ab',2000),repeat('ab',2000),repeat('ab',2000),repeat('ab',2000),repeat('abcdefghij',4000));
insert into t333_var select c0+1,c1,c2,c3,c4,c5,c6,c7 from t333_var;
insert into t333_var select c0+10,c1,c2,c3,c4,c5,c6,c7 from t333_var;
insert into t333_var select c0+100,c1,c2,c3,c4,c5,c6,c7 from t333_var;
insert into t333_var select c0+1000,c1,c2,c3,c4,c5,c6,c7 from t333_var;
insert into t333_var select c0+10000,c1,c2,c3,c4,c5,c6,c7 from t333_var;
insert into t333_var select c0+100000,c1,c2,c3,c4,c5,c6,c7 from t333_var;
insert into t333_var select c0+1000000,c1,c2,c3,c4,c5,c6,c7 from t333_var;
insert into t333_var select c0+10000000,c1,c2,c3,c4,c5,c6,c7 from t333_var;
insert into t333_var select c0+100000000,c1,c2,c3,c4,c5,c6,c7 from t333_var;
insert into t333_var select c0+1000000000,c1,c2,c3,c4,c5,c6,c7 from t333_var;
insert into t333_var select c0+10000000000,c1,c2,c3,c4,c5,c6,c7 from t333_var;
commit;
create table t222_var(c0 bigint ,c1 varchar(4000), c2 varchar(4000), c3 varchar(4000), c4 varchar(4000), c5 varchar(4000),c6 varchar(4000), c7 longtext);
insert into t222_var values(1,repeat('ab',2000),repeat('ab',2000),repeat('ab',2000),repeat('ab',2000),repeat('ab',2000),repeat('ab',2000),repeat('abcdefghij',4000));
insert into t222_var select c0+1,c1,c2,c3,c4,c5,c6,c7 from t222_var;
insert into t222_var select c0+10,c1,c2,c3,c4,c5,c6,c7 from t222_var;
insert into t222_var select c0+100,c1,c2,c3,c4,c5,c6,c7 from t222_var;
insert into t222_var select c0+1000,c1,c2,c3,c4,c5,c6,c7 from t222_var;
insert into t222_var select c0+10000,c1,c2,c3,c4,c5,c6,c7 from t222_var;
insert into t222_var select c0+100000,c1,c2,c3,c4,c5,c6,c7 from t222_var;
insert into t222_var select c0+1000000,c1,c2,c3,c4,c5,c6,c7 from t222_var;
insert into t222_var select c0+10000000,c1,c2,c3,c4,c5,c6,c7 from t222_var;
insert into t222_var select c0+100000000,c1,c2,c3,c4,c5,c6,c7 from t222_var;
commit;
insert into t222_var select c0+1000000000,c1,c2,c3,c4,c5,c6,c7 from t222_var;
commit;
select count(*) from t333_var;
