ob1=OBI(cluster=1);
ob1.reboot;
ob1.create_client;
ob1.mysql alter system set resource_hard_limit= 800;
drop tenant if exists oracle;
drop resource pool if exists oblog_pool;
drop resource unit if exists oblog_box;
ob1.mysql create resource unit oblog_box max_cpu 2, memory_size='20G';
ob1.mysql create resource pool oblog_pool unit = 'oblog_box', unit_num = 1;
ob1.mysql create tenant oracle replica_num = 1, resource_pool_list=('oblog_pool') set ob_tcp_invited_nodes='%', ob_compatibility_mode='oracle';
ob1.mysql alter tenant oracle set variables autocommit='on';
ob1.mysql alter tenant oracle set variables nls_date_format='YYYY-MM-DD HH24:MI:SS';
ob1.mysql alter tenant oracle set variables nls_timestamp_format='YYYY-MM-DD HH24:MI:SS.FF';
ob1.mysql alter tenant oracle set variables nls_timestamp_tz_format='YYYY-MM-DD HH24:MI:SS.FF TZR TZD';
create user obtest IDENTIFIED BY "obtest";
grant all on *.* to obtest WITH GRANT OPTION;
grant dba to obtest;
alter session set current_schema = oblog_db;
ob1.oblog.set_extra_argument -m;
ob1.oblog.gen_conf tb_white_list=oracle.*.*  test_mode_on=1 test_mode_ignore_redo_count=10 sort_trans_participants=1 redo_dispatcher_memory_limit=128M enable_output_trans_order_by_sql_operation=1 skip_ob_version_compat_check=1;
ob1.oblog.restart;
set ob_query_timeout=90000000000000;
set ob_trx_timeout=1200000000000000;
create table t_small_tx(c0 number(38) GENERATED ALWAYS as IDENTITY START with 1 INCREMENT by 1) partition by hash (c0) partitions 10;
create table t_big_tx(c0 number(38) GENERATED ALWAYS as IDENTITY START with 1 INCREMENT by 1) partition by hash (c0) partitions 10;
alter table t_small_tx add c10 xmltype;
alter table t_big_tx add c10 xmltype;
alter table t_small_tx add c9 xmltype;
alter table t_big_tx add c9 xmltype;
alter table t_small_tx add c8 xmltype;
alter table t_big_tx add c8 xmltype;
alter table t_small_tx add c7 xmltype;
alter table t_big_tx add c7 xmltype;
alter table t_small_tx add c6 xmltype;
alter table t_big_tx add c6 xmltype;
alter table t_small_tx add c5 xmltype;
alter table t_big_tx add c5 xmltype;
alter table t_small_tx add c4 xmltype;
alter table t_big_tx add c4 xmltype;
alter table t_small_tx add c3 xmltype;
alter table t_big_tx add c3 xmltype;
alter table t_small_tx add c2 xmltype;
alter table t_big_tx add c2 xmltype;
alter table t_small_tx add c1 xmltype;
alter table t_big_tx add c1 xmltype;
set ob_query_timeout=90000000000000;
set ob_trx_timeout=1200000000000000;
set autocommit=0;
COUNT(*)
16
COUNT(*)
32
ob1.oblog.waitUntilRealtime 2400;
ob1.oblog.next_dml;
