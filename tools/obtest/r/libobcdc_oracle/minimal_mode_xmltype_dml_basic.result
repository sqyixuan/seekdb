CREATE OR REPLACE FUNCTION calc_md5(input_data IN CLOB) RETURN VARCHAR2 IS BEGIN  RETURN LOWER(RAWTOHEX(DBMS_CRYPTO.HASH(input_data, DBMS_CRYPTO.HASH_MD5))); END;
