ob1=OBI(cluster=1:1:1, proxy_num=0, init_unit_cpu=0, locality=HZ:HZ:HZ);
ob1.z1.obs0.set extra_config=$extra_conf;
ob1.z2.obs0.set extra_config=$extra_conf;
ob1.z3.obs0.set extra_config=$extra_conf;
ob1.reboot;
ob1.mysql create resource unit box1 max_cpu 2, min_cpu 1, memory_size '10G', log_disk_size '30G';
ob1.mysql create resource pool pool1 unit = 'box1', unit_num = 1;
ob1.mysql create tenant tt1 replica_num = 3, resource_pool_list=('pool1') set ob_tcp_invited_nodes='%';
ob1.check_until_timeout select count(*) c from oceanbase.__all_server where start_service_time <= 0 or status = "inactive", 0, 120;
use test;
drop table if exists t1;
drop table if exists t2;
drop table if exists t1_dup;
drop table if exists t2_dup;
create table t1 (x int, y int);
create table t2 (x int, y int);
create table t1_dup (x int, y int) duplicate_scope = 'cluster';
create table t2_dup (x int, y int) duplicate_scope = 'cluster';
use oceanbase;
ob1.mysql alter system switch replica leader ls = $t1_ls_id server = '$ip1:$port1' tenant = 'tt1';
ob1.mysql alter system switch replica leader ls = $t2_ls_id server = '$ip1:$port1' tenant = 'tt1';
ob1.mysql alter system switch replica leader ls = $t1_dup_ls_id server = '$ip1:$port1' tenant = 'tt1';
ob1.mysql alter system switch replica leader ls = $t2_dup_ls_id server = '$ip1:$port1' tenant = 'tt1';
ob1.check_until_timeout select count(*) from __all_virtual_ls_info where ls_id = $t1_ls_id and SVR_IP = '$ip1' and SVR_PORT = '$port1' and tenant_id = $tenant_id and ls_state = 'leader' , 1, 30;
ob1.check_until_timeout select count(*) from __all_virtual_ls_info where ls_id = $t2_ls_id and SVR_IP = '$ip1' and SVR_PORT = '$port1' and tenant_id = $tenant_id and ls_state = 'leader' , 1, 30;
ob1.check_until_timeout select count(*) from __all_virtual_ls_info where ls_id = $t1_dup_ls_id and SVR_IP = '$ip1' and SVR_PORT = '$port1' and tenant_id = $tenant_id and ls_state = 'leader' , 1, 30;
ob1.check_until_timeout select count(*) from __all_virtual_ls_info where ls_id = $t2_dup_ls_id and SVR_IP = '$ip1' and SVR_PORT = '$port1' and tenant_id = $tenant_id and ls_state = 'leader' , 1, 30;
