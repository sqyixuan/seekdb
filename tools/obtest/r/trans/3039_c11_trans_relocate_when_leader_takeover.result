alter system major freeze;
ob1.check_until_timeout select value from __all_zone where zone='' and name='last_merged_version', 4,3600;
begin;
insert into t1 values (10, 10);
insert into t1 values (11, 11);
insert into t2 values (7, 7);
insert into t2 values (8, 8);
ob1.z2.obs0.switch_partition obtest:test:t1;
alter system minor freeze tenant = sys;
alter system minor freeze tenant = all_user;
alter system minor freeze tenant = all_meta;
ob1.z1.obs0.switch_partition obtest:test:t1;
rollback;
