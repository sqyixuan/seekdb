ob1=OBI(cluster=3:3:3,proxy_num=0,init_unit_cpu=11,init_unit_num=2);
ob1.reboot;
ob1.mysql alter system set enable_auto_leader_switch=false;
ob1.mysql alter system set enable_monotonic_weak_read=false;
create database obtest;
use obtest;
create table t1(pk int primary key, c1 int, c2 varchar(20)) partition by hash(pk % 2) partitions 2;
set autocommit=0;
insert into t1 values(0,0,'a');
insert into t1 values(1,1,'b');
$leader0.block_net $follower0_1;
$follower0_1.block_net $leader0;
$leader0.block_net $follower0_2;
$follower0_2.block_net $leader0;
commit;
Got one of the listed errors
set autocommit=1;
select /*+ read_consistency(weak)*/* from t1;
pk	c1	c2
$leader0.clean_net $follower0_1;
$leader0.clean_net $follower0_2;
$follower0_1.clean_net $leader0;
$follower0_2.clean_net $leader0;
$leader0.switch_partition obtest:obtest:t1:1;
set autocommit=1;
select /*+ read_consistency(weak)*/* from t1;
pk	c1	c2
