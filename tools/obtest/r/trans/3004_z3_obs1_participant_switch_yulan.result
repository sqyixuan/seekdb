ob1=OBI(cluster=1:1:1,proxy_num=0,init_unit_cpu=5);
ob1.reboot;
ob1.mysql alter system set enable_auto_leader_switch=false;
create table t1(pk int primary key, c1 int, c2 varchar(20));
ob1.mysql alter system set enable_auto_leader_switch=false;
ob1.z3.obs0.switch_partition obtest:test:t1;
set autocommit=0;
insert into t1 values(1,1,'a');
insert into t1 values(2,2,'b');
ob1.z2.obs0.switch_partition obtest:test:t1;
update t1 set c2='aa' where pk=1;
commit;
set autocommit=1;
select * from t1;
pk	c1	c2
1	1	aa
2	2	b
set autocommit=0;
insert into t1 values(3,1,'a');
insert into t1 values(4,2,'b');
ob1.z3.obs0.switch_partition obtest:test:t1;
update t1 set c2='aa' where pk=3;
rollback;
commit;
set autocommit=1;
select * from t1;
pk	c1	c2
1	1	aa
2	2	b
