ob1=OBI(cluster=1:1:1, init_unit_cpu=5);
ob1.reboot;
create resource unit oblog_box max_cpu 2, memory_size='20G';
create resource pool oblog_pool unit = 'oblog_box', unit_num = 1, zone_list = ('z1');
create tenant oblog_tt replica_num = 1, primary_zone='z1', resource_pool_list=('oblog_pool') set ob_tcp_invited_nodes='%';
alter system set dump_data_dictionary_to_log_interval = '3s';
create database oblog_db1;
use oblog_db1;
ob1.oblog.gen_conf tb_white_list=oblog_tt.*.* log_level=DEBUG enable_output_hidden_primary_key=1 enable_output_by_table_def=1 skip_ob_version_compat_check=1;
ob1.oblog.restart;
