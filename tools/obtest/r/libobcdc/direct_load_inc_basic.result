ob1=OBI(cluster=1,init_unit_cpu=5);
ob1.reboot;
ob1.create_client;
create resource unit oblog_box max_cpu 2, memory_size='20G';
create resource pool oblog_pool unit = 'oblog_box', unit_num = 1, zone_list = ('z1');
create tenant oblog_tt replica_num = 1, primary_zone='z1', resource_pool_list=('oblog_pool') set ob_tcp_invited_nodes='%';
ob1.mysql alter system set dump_data_dictionary_to_log_interval = '6s' tenant all;
ob1.z1.obs0.sh obclient -S $OBSERVER_DIR/run/sql.sock -uroot@oblog_tt -Dtest -A -e 'SET GLOBAL secure_file_priv=\"/\"';
alter system set direct_load_allow_fallback=False;
use test;
set ob_default_lob_inrow_threshold=4096;
ob1.oblog.gen_conf tb_white_list=oblog_tt.*.* enable_direct_load_inc=1;
ob1.oblog.set_extra_argument -m;
ob1.oblog.restart;
select md5('hello');
md5('hello')
5d41402abc4b2a76b9719d911017c592
select md5('world');
md5('world')
7d793037a0760186574b0282f2f435e7
select md5(repeat('1', 7000));
md5(repeat('1', 7000))
b29acb0f1cc3d25bae2e8fa8ed6446d2
select md5('kkk');
md5('kkk')
cb42e130d1471239a27fca6228094f0e
