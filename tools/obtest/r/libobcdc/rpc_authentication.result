ob1=OBI(cluster=1,init_unit_cpu=5);
ob1.reboot;
ob1.create_client;
alter system set ssl_external_kms_info = '';
alter system set ssl_client_authentication = 'TRUE';
alter system set rpc_client_authentication_method="SSL_NO_ENCRYPT";
alter system set rpc_server_authentication_method="SSL_NO_ENCRYPT";
drop tenant if exists oblog_tt;
drop resource pool if exists oblog_pool;
drop resource unit if exists oblog_box;
drop database if exists oblog_db1;
create resource unit oblog_box max_cpu 2, memory_size='20G';
create resource pool oblog_pool unit = 'oblog_box', unit_num = 1, zone_list = ('z1');
create tenant oblog_tt replica_num = 1, primary_zone='z1', resource_pool_list=('oblog_pool') set ob_tcp_invited_nodes='%';
ob1.oblog.gen_conf tb_white_list=sys.oblog*.*|oblog_tt.*.* log_level=DEBUG ssl_client_authentication=1 ssl_external_kms_info=file rpc_client_authentication_method=SSL_NO_ENCRYPT skip_ob_version_compat_check=1;
ob1.oblog.restart;
create database oblog_db1;
ob1.oblog.next;
