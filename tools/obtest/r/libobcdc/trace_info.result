ob1=OBI(cluster=2, init_unit_cpu=5);
ob1.reboot;
create resource unit obcdc_mysql_box max_cpu 2, memory_size='20G';
create resource pool obcdc_mysql_pool unit = 'obcdc_mysql_box', unit_num = 2, zone_list = ('z1');
create tenant obcdc_mysql replica_num = 1, primary_zone='z1', resource_pool_list=('obcdc_mysql_pool') set ob_tcp_invited_nodes='%';
create user obcdc identified by "obcdc";
grant all on *.* to obcdc;
drop database if exists oblog_db;
create database oblog_db;
use oblog_db;
ob1.oblog.gen_conf tb_white_list=obcdc_mysql.*.* sort_trans_participants=1 enable_output_trans_order_by_sql_operation=0 log_level=DEBUG skip_ob_version_compat_check=1;
ob1.oblog.set_extra_argument -I;
ob1.oblog.restart;
create table t1(id int primary key, c1 int);
set ob_trace_info='abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ';
insert into t1 values (1, 1);
