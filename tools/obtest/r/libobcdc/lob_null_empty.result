ob1=OBI(cluster=1);
ob1.force_stop;
ob1.clean_backup_dest;
ob1.reboot;
ob1.create_client;
create resource unit oblog_box_mysql max_cpu 2, memory_size='10G';
create resource pool oblog_pool_mysql unit = 'oblog_box_mysql', unit_num = 1, zone_list = ('z1');
create tenant oblog_tt replica_num = 1, primary_zone='z1', resource_pool_list=('oblog_pool_mysql') set ob_tcp_invited_nodes='%';
alter tenant oblog_tt set variables max_allowed_packet=1073741824;
set global max_allowed_packet=1073741824;
set ob_trx_timeout=100000000;
create database oblog_db1;
use oblog_db1;
create table t1(pk int primary key, long_text longtext);
ob1.check_until_timeout select count(*) as num from oceanbase.__all_virtual_archive_stat, 0, 60;
ob1.mysql alter system archivelog;
ob1.check_until_timeout select status from oceanbase.CDB_OB_ARCHIVELOG where tenant_id=$backup_tenant_id, DOING, 600;
ob1.z1.obs0.check_log_until_success -c "get_data_dict_meta_info";
use oblog_db1;
ob1.oblog.set_extra_argument -m;
ob1.oblog.gen_conf tb_white_list=sys.oblog*.*|oblog_tt.*.* log_level=DEBUG skip_ob_version_compat_check=1;
ob1.oblog.restart;
insert into t1 values (4, repeat('a', 50331647));
select pk, md5(long_text) from t1 where pk = 4;
pk	md5(long_text)
4	c57d4c3741dc0eb85d767497f9736503
ob1.oblog.next_dml;
