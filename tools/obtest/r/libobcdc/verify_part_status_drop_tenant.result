ob1.oblog.gen_conf tb_white_list=oblog_tt.test.* sort_trans_participants=1 log_level=INFO test_mode_on=1 test_mode_force_check_tenant_status=1 test_mode_block_verify_participants_time_sec=5 skip_ob_version_compat_check=1;
