ob1=OBI(cluster=1:1:1, init_unit_cpu=5);
ob1.reboot;
drop tenant if exists oblog_tt;
drop resource pool if exists oblog_pool;
drop resource unit if exists oblog_box;
create resource unit oblog_box max_cpu=2, memory_size='10G';
create resource pool oblog_pool unit = 'oblog_box', unit_num = 1, zone_list = ('z1', 'z2', 'z3');
create tenant oblog_tt replica_num = 1, primary_zone='z1', resource_pool_list=('oblog_pool') set ob_tcp_invited_nodes='%';
drop database if exists oblog_db;
create database oblog_db;
use oblog_db;
set recyclebin=off;
create table t1(a int);
create table t2(a int);
begin;
insert into t1 values(1);
insert into t1 values(1);
commit;
ob1.oblog.gen_conf tb_white_list=oblog_tt.oblog_db.t*|sys.*.* sort_trans_participants=1 log_level=INFO test_mode_on=1 skip_ob_version_compat_check=1;
ob1.oblog.set_start_tstamp $start_tstamp;
ob1.oblog.restart;
drop tenant oblog_tt force;
ob1.oblog.stop;
ob1.oblog.check_log "STATUS=PART_EXIST";
ob1.oblog.check_log "PART_NOT_SERVE";
create tenant oblog_tt replica_num = 1, primary_zone='z1', resource_pool_list=('oblog_pool') set ob_tcp_invited_nodes='%';
create table t1(pk int primary key);
create table t2(pk int primary key) primary_zone='z1,z2,z3' partition by hash(pk) partitions 3;
alter table t2 add column a int default 0;
insert into t2 values(1, 1);
set autocommit='OFF';
begin;
insert into t2 (pk, a) values (2,2), (3,3), (4,4);
insert into t1 values (1);
update t2 set a = 5 where pk = 1;
commit;
ob1.oblog.gen_conf tb_white_list=oblog_tt.*.* sort_trans_participants=1 log_level=INFO test_mode_on=1 test_mode_force_check_tenant_status=1 test_mode_block_verify_participants_time_sec=5 skip_ob_version_compat_check=1;
ob1.oblog.set_start_tstamp_usec $start_tstamp;
ob1.oblog.restart;
ob1.oblog.next;
