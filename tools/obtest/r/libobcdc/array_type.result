ob1=OBI(cluster=1,init_unit_cpu=5);
ob1.reboot;
ob1.create_client;
create resource unit oblog_box max_cpu 2, memory_size='20G';
create resource pool oblog_pool unit = 'oblog_box', unit_num = 1, zone_list = ('z1');
create tenant oblog_tt replica_num = 1, primary_zone='z1', resource_pool_list=('oblog_pool') set ob_tcp_invited_nodes='%';
create database oblog_db1;
use oblog_db1;
alter tenant oblog_tt set variables max_allowed_packet=52428800;
set global max_allowed_packet=52428800;
set ob_trx_timeout=100000000;
'[CASE_BEGIN] [vector_type]'
ob1.oblog.gen_conf tb_white_list=oblog_tt.*.* log_level=DEBUG skip_ob_version_compat_check=1;
ob1.oblog.set_extra_argument -x;
ob1.oblog.restart;
'[SECTION_BEGIN] [basic_test]'
create table arr_t1(c1 int primary key, c2 array(array(varchar(16))), c3 array(array(float)), c4 array(array(array(double))));
ob1.oblog.next;
