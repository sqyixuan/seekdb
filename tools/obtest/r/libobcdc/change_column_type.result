ob1=OBI(cluster=1, init_unit_cpu=5);
ob1.reboot;
create resource unit oblog_box max_cpu 2, memory_size='20G';
create resource pool oblog_pool unit = 'oblog_box', unit_num = 1, zone_list = ('z1');
create tenant oblog_tt replica_num = 1, primary_zone='z1', resource_pool_list=('oblog_pool') set ob_tcp_invited_nodes='%';
set global max_allowed_packet = 1073741824;
set ob_query_timeout=90000000;
set ob_trx_timeout=1200000000;
drop database if exists oblog_db;
create database oblog_db;
use oblog_db;
drop database if exists oblog_db;
create database oblog_db;
use oblog_db;
create table t1 (id int primary key, v1 varchar(20), v2 tinytext, v3 text, v4 mediumtext, v5 longtext, v6 char(20));
create table t2 (id int primary key, v1 tinyint, v2 smallint, v3 mediumint, v4 int, v5 bigint);
create table t3 (id int primary key, v1 varbinary(50), v2 tinyblob, v3 blob, v4 mediumblob, v5 longblob);
create table t_varchar (id int primary key, v1 varchar(20), v2 varchar(50), v3 varchar(60), v4 varchar(80), v5 char(20));
create table t_binary (id int primary key, v0 binary(40), v1 varbinary(50), v2 tinyblob, v3 blob, v4 mediumblob, v5 longblob);
ob1.oblog.gen_conf tb_white_list=oblog_tt.oblog_db.* log_level=INFO skip_ob_version_compat_check=1;
ob1.oblog.set_extra_argument -i;
ob1.oblog.restart;
insert into t1 values (1, 'oceanbase_c1', 'oceanbase_c1', 'oceanbase_c1', 'oceanbase_c1', 'oceanbase_c1', 'oceanbase_c1');
ob1.oblog.next;
