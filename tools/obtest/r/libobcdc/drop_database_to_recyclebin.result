ob1=OBI(cluster=1, init_unit_cpu=5);
ob1.reboot;
ob1.create_client;
create resource unit obcdc_mysql_box max_cpu 2, memory_size='20G';
create resource pool obcdc_mysql_pool unit = 'obcdc_mysql_box', unit_num = 1, zone_list = ('z1');
create tenant obcdc_mysql replica_num = 1, primary_zone='z1', resource_pool_list=('obcdc_mysql_pool') set ob_tcp_invited_nodes='%';
create user obcdc identified by "obcdc";
grant all on *.* to obcdc;
set @@recyclebin = on;
create database cdc_db;
use cdc_db;
ob1.oblog.gen_conf tb_white_list=*cdc*.*.* log_level=ALL.*:WARN;STORAGE.TRANS:DEBUG;TLOG.*:INFO;TLOG.FETCHER:DEBUG skip_ob_version_compat_check=1;
ob1.oblog.restart;
drop database cdc_db;
use oceanbase;
ob1.oblog.next;
[R0] record_type:EDDL;[R0] db_name:obcdc_mysql.cdc_db;[R0] table_name:;[R0] column_count:1;[R0] column_name:ddl;[R0] ddl_stmt_str: drop database cdc_db;[R0] ddl_stmt_len: 20;
ob1.oblog.stop;
ob1.oblog.gen_conf tb_white_list=*cdc*.*.* log_level=ALL.*:WARN;STORAGE.TRANS:DEBUG;TLOG.*:INFO;TLOG.FETCHER:DEBUG skip_ob_version_compat_check=1;
ob1.oblog.set_start_tstamp_usec $restart_usec1;
ob1.oblog.restart;
ob1.oblog.next;
[R0] record_type:EDDL;[R0] db_name:obcdc_mysql.cdc_db;[R0] table_name:;[R0] column_count:1;[R0] column_name:ddl;[R0] ddl_stmt_str: drop database cdc_db;[R0] ddl_stmt_len: 20;
ob1.oblog.stop;
ob1.oblog.gen_conf test_mode_on=1 tb_white_list=*cdc*.*.* log_level=ALL.*:WARN;STORAGE.TRANS:DEBUG;TLOG.*:INFO;TLOG.FETCHER:DEBUG skip_ob_version_compat_check=1;
ob1.oblog.set_start_tstamp_usec $restart_usec;
ob1.oblog.restart;
ob1.oblog.next;
[R0] record_type:EDDL;[R0] db_name:obcdc_mysql.cdc_db;[R0] table_name:;[R0] column_count:1;[R0] column_name:ddl;[R0] ddl_stmt_str: drop database cdc_db;[R0] ddl_stmt_len: 20;
ob1.oblog.stop;
