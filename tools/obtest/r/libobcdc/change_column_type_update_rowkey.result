ob1=OBI(cluster=1, init_unit_cpu=5);
ob1.reboot;
create resource unit oblog_box max_cpu 2, memory_size='20G';
create resource pool oblog_pool unit = 'oblog_box', unit_num = 1, zone_list = ('z1');
create tenant oblog_tt replica_num = 1, primary_zone='z1', resource_pool_list=('oblog_pool') set ob_tcp_invited_nodes='%';
set global max_allowed_packet = 1073741824;
drop database if exists oblog_db;
create database oblog_db;
use oblog_db;
drop database if exists oblog_db;
create database oblog_db;
use oblog_db;
create table tc1 (id tinyint, name varchar(5), v1 int, primary key(id, name));
insert into tc1 values (1, repeat('a', 5), 1);
update tc1 set id = 1, name = repeat('a', 1) where v1 = 1;
update tc1 set id = 2, name = repeat('a', 2) where v1 = 1;
update tc1 set id = 1, name = repeat('b', 1) where v1 = 1;
update tc1 set id = 2, name = repeat('b', 2) where v1 = 1;
update tc1 set id = 1, name = repeat('c', 1) where v1 = 1;
update tc1 set id = 2, name = repeat('c', 2) where v1 = 1;
alter table tc1 modify name varchar(10);
update tc1 set id = 10, name = repeat('d', 10) where v1 = 1;
alter table tc1 modify name varchar(11);
update tc1 set id = 11, name = repeat('d', 11) where v1 = 1;
use oceanbase;
use oceanbase;
use oblog_db;
ob1.oblog.gen_conf tb_white_list=oblog_tt.oblog_db.* log_level=INFO data_start_schema_version=$tenant_id:$max_ddl_schema_version;
ob1.oblog.set_start_tstamp $start_tstamp;
ob1.oblog.restart;
update tc1 set id = 1, name = repeat('e', 1) where v1 = 1;
update tc1 set id = 2, name = repeat('e', 2) where v1 = 1;
update tc1 set id = 1, name = repeat('f', 1) where v1 = 1;
update tc1 set id = 1 , name = repeat('g', 1) where v1 = 1;
update tc1 set id = 2 , name = repeat('g', 2) where v1 = 1;
update tc1 set id = 3 , name = repeat('g', 3) where v1 = 1;
update tc1 set id = 4 , name = repeat('g', 4) where v1 = 1;
update tc1 set id = 5 , name = repeat('g', 5) where v1 = 1;
alter table tc1 modify name varchar(30);
update tc1 set id = 30, name = repeat('h', 30) where v1 = 1;
alter table tc1 modify name varchar(31);
update tc1 set id = 31, name = repeat('h', 31) where v1 = 1;
