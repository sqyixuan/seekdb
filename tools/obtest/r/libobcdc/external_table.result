ob1=OBI(cluster=1,init_unit_cpu=5);
ob1.reboot;
ob1.create_client;
create resource unit oblog_box max_cpu 2, memory_size='20G';
create resource pool oblog_pool unit = 'oblog_box', unit_num = 1, zone_list = ('z1');
create tenant oblog_tt replica_num = 1, primary_zone='z1', resource_pool_list=('oblog_pool') set ob_tcp_invited_nodes='%';
ob1.mysql alter system set dump_data_dictionary_to_log_interval = '6s' tenant all;
ob1.z1.obs0.sh obclient -S $OBSERVER_DIR/run/sql.sock -uroot@oblog_tt -Dtest -A -e 'SET GLOBAL secure_file_priv=\"/\"';
use test;
CREATE EXTERNAL TABLE white1(c1 int, c2 char) LOCATION='$OBSERVER_DIR/$DATA_FOLDER_NAME' FORMAT=(TYPE='CSV' FIELD_DELIMITER=',') PATTERN='data.csv';
ob1.oblog.gen_conf tb_white_list=oblog_tt.*.white* tb_black_list=oblog_tt.*.black* log_level=DEBUG meta_data_refresh_mode=data_dict skip_ob_version_compat_check=1;
ob1.oblog.set_extra_argument '-c';
ob1.oblog.restart;
drop table white1;
ob1.oblog.next;
[R0] record_type:EDDL;[R0] db_name:oblog_tt.test;[R0] table_name:;[R0] column_count:1;[R0] column_name:ddl;[R0] ddl_stmt_str: DROP TABLE `test`.`white1`;[R0] ddl_stmt_len: 26;
ob1.oblog.stop;
