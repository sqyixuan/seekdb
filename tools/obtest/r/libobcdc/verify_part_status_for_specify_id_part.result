ob1=OBI(cluster=1, init_unit_cpu=5);
ob1.reboot;
create resource unit oblog_box max_cpu 2, memory_size='20G';
create resource pool oblog_pool unit = 'oblog_box', unit_num = 1, zone_list = ('z1');
create tenant oblog_tt replica_num = 1, primary_zone='z1', resource_pool_list=('oblog_pool') set ob_tcp_invited_nodes='%';
set recyclebin=off;
create user if not exists __oceanbase_inner_drc_user identified by 'drc';
grant all privileges on *.* to __oceanbase_inner_drc_user;
use test;
drop table if exists t_base, t_range;
create table t_base (pk int primary key);
create table t_range (pk int primary key, c1 int) max_used_part_id = 1000 partition by range(pk) (partition p1 values less than (10) id 100, partition p2 values less than (20) id 200);
alter table t_range add partition (partition p3 values less than (30));
alter table t_range add partition (partition p4 values less than (40));
alter table t_range add partition (partition p5 values less than (50));
begin;
insert into t_base values (1);
insert into t_range values (28,28),(19,19),(9,9);
commit;
ob1.oblog.gen_conf tb_white_list=oblog_tt.test.t* sort_trans_participants=1 log_level=INFO test_mode_on=1 test_mode_block_alter_table_ddl_sec=3 skip_ob_version_compat_check=1;
ob1.oblog.set_start_tstamp $start_tstamp;
ob1.oblog.restart;
ob1.oblog.next_dml;
