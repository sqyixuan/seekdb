] [C2] column_is_not_null:false;[R3] [C2] column_value_new:[19](2);$[R4] record_type:INSERT;[R4] database_name:oblog_tt.test;[R4] table_name:t_range;[R4] log_event:true;[R4] column_count:2;[R4] source_category:SRC_FULL_RECORDED;[R4] source_type:SRC_OCEANBASE_1_0;[R4] has_pk:true;[R4] pk_info:(0);[R4] pks:pk;[R4] has_uk:false;[R4] uk_info:(null);[R4] uks:(null);[R4] [C1] column_name:pk;[R4] [C1] column_type:MYSQL_TYPE_LONG;[R4] [C1] column_is_rowkey:true;[R4] [C1] column_is_signed:true;[R4] [C1] column_encoding:binary;[R4] [C1] column_is_not_null:true;[R4] [C1] column_value_new:[9](1);[R4] [C2] column_name:c1;[R4] [C2] column_type:MYSQL_TYPE_LONG;[R4] [C2] column_is_rowkey:false;[R4] [C2] column_is_signed:true;[R4] [C2] column_encoding:binary;[R4] [C2] column_is_not_null:false;[R4] [C2] column_value_new:[9](1);$[R5] COMMIT;
ob1.oblog.stop;
drop table t_base, t_range;
drop table if exists t_base, t_second_part;
create table t_base (pk int primary key);
create table t_second_part (pk int primary key, c1 int) max_used_part_id = 1000 partition by range(pk) subpartition by hash(pk) subpartitions 4 (partition p1 values less than (10) id 100, partition p2 values less than (20) id 200);
begin;
insert into t_base values (1);
insert into t_second_part values (9,9);
insert into t_second_part values (11,11);
commit;
alter table t_second_part drop partition (p1);
ob1.oblog.gen_conf tb_white_list=oblog_tt.test.t* sort_trans_participants=1 log_level=INFO test_mode_on=1 test_mode_block_verify_participants_time_sec=1 skip_ob_version_compat_check=1;
ob1.oblog.set_start_tstamp $start_tstamp;
ob1.oblog.restart;
ob1.oblog.next_dml;
