ob1=OBI(cluster=3:3:3,proxy_num=0,init_unit_cpu=0);
ob1.reboot;
ob1.mysql alter system set balancer_idle_time='10s' ;
ob1.mysql alter system set server_permanent_offline_time ='1800s';
ob1.mysql alter system set server_data_copy_in_concurrency=30;
ob1.mysql alter system set server_data_copy_out_concurrency=200;
ob1.mysql alter system set data_copy_concurrency=6000;
ob1.source include/merge.inc;
ob1.mysql create table oceanbase.test(c1 int);
ob1.mysql alter system major freeze;
ob1.check_version 2;
ob1.mysql INSERT INTO oceanbase.__all_tenant_meta_table (tenant_id, table_id, partition_id, svr_ip, svr_port,    sql_port, unit_id, zone, partition_cnt, role, member_list, row_count, data_size, data_version,    data_checksum, create_time, is_previous_leader, row_checksum, column_checksum,    replica_type,required_size, status) VALUES (1, $table_id, 0, '$ip', $port, $sql_port, 1, 'z2',      0, 1, '127.0.0.1:16824:1505416850447999,127.0.0.2:16828:1505416850447999', 0, 0, 2, 0, 0, 1505416851968252, 122, '', 16, 0, 'REPLICA_STATUS_OFFLINE');
