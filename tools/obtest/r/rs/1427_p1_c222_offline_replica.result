'success to find no version = 1 in partition view'
'success to find two version = 1 in meta_table'
'success to find two version = 1 in root_table'
ob1.mysql_p select status from __all_virutal_core_meta_table; 
ob1.mysql_p select status from __all_virutal_core_root_table; 
ob1.mysql_p select status from __all_virtual_partition_info where table_id = 1099511627891 and partition_id = 0;
