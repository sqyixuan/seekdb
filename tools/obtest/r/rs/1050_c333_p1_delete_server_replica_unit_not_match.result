ob1=OBI(cluster=3:3:3,proxy_num=0,init_unit_cpu=0);
ob1.reboot;
alter system set debug_sync_timeout = '1000s';
alter system set balancer_idle_time = '10s';
alter system set resource_soft_limit = 10;
alter system set resource_hard_limit = 800;
alter system set enable_rebalance = "false";
alter system set enable_rereplication = 'false';
set ob_global_debug_sync = 'UNIT_BALANCE_BEFORE_PARTITION_BALANCE wait_for begin timeout 1000000000';
CREATE RESOURCE UNIT test MAX_CPU 1, MAX_MEMORY 1073741824, MAX_IOPS 100000, MAX_DISK_SIZE 536870912, MAX_SESSION_NUM 64, MIN_CPU=1, MIN_MEMORY=1073741824, MIN_IOPS=128;
CREATE RESOURCE POOL pool1 UNIT = 'test', UNIT_NUM = 1, ZONE_LIST = ('z1', 'z2', 'z3');
CREATE TENANT obtest1 RESOURCE_POOL_LIST = ('pool1') set ob_tcp_invited_nodes='%';
CREATE DATABASE obtest;
use obtest;
CREATE TABLE obtest1 (pk int, value int, primary key(pk));
CREATE TABLE obtest2 (pk int, value int, primary key(pk));
CREATE TABLE obtest3 (pk int, value int, primary key(pk));
alter system set migration_disable_time = '1h';
alter system reload server;
pass
set ob_global_debug_sync = 'NOW signal begin';
alter system set enable_rebalance = "true";
alter system set enable_rereplication = 'true';
pass
ob1.check_until_timeout select count(*) c from oceanbase.__all_rootservice_job where job_id = $job_id and job_status="SUCCESS" ,1,30;
