ob1=OBI(cluster=1:1:1, init_cpu_count=2, locality=HZ:HZ:SH);
ob1.reboot;
ob1.create_client tenant=sys,user=root,passwd=,database=oceanbase;
ob1.mysql create resource unit box1 max_cpu 5, max_memory 1080000000, max_iops 100000, max_disk_size 1080000000, max_session_num 64, MIN_CPU 5, MIN_MEMORY=1080000000, MIN_IOPS=128;
ob1.mysql create resource pool pool_large unit = 'box1', unit_num = 1, zone_list = ('z1', 'z2', 'z3');
CREATE TENANT tenant_1 RESOURCE_POOL_LIST = ('pool_large'), primary_zone = "z3" set ob_tcp_invited_nodes='%';
