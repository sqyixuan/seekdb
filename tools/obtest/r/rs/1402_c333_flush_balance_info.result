ob1=OBI(cluster=3:3:3,  proxy_num=0, ct_num = 0);
ob1.reboot;
ob1.mysql alter system set debug_sync_timeout = '100s';
ob1.mysql alter system set enable_auto_leader_switch = 'False';
ob1.mysql alter system set balancer_idle_time = '10s';
ob1.mysql alter system set server_data_copy_out_concurrency = 1;
ob1.mysql alter system set server_data_copy_in_concurrency = 1;
ob1.create_client tenant=sys,user=root,passwd=,database=oceanbase;
set ob_query_timeout=60000000;
create table oceanbase.test(c1 int primary key, c2 int) partition by hash(c1) partitions 5000;
create table oceanbase.test2(c1 int primary key, c2 int) partition by hash(c1) partitions 5000;
ob1.mysql alter tenant sys locality='f@z1,f@z2,R@z3';
ob1.check_until_timeout select count(*) > 5000 from __all_virtual_rebalance_task_stat, 1, 50;
ob1.mysql alter system flush balance cache;
'clear success'
