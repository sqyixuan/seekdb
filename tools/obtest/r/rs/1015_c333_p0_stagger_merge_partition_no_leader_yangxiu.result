ob1=OBI(cluster=3:3:3,init_unit_cpu=2,init_unit_num=2);
ob1.reboot;
ob1.mysql alter system set merger_check_interval='1m';
ob1.mysql alter system set merger_switch_leader_duration_time='0s';
ob1.create_client tenant=obtest,user=admin,passwd=admin,database=test;
ob1.mysql_p alter system major freeze;
$f1.stop;
$f2.stop;
$f1.nstart;
$f2.nstart;
ob1.check_version 2;
select * from obtest1 partition(p0) limit 2;
