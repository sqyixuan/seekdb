0	0	0_obtest	0_obtest	0.001	1970-01-01 08:00:00	0.000	0
1	1	1_obtest	1_obtest	1.001	1970-01-01 08:00:00	1.000	0
ob1.mysql alter system major freeze;
$f1.stop;
$f2.stop;
$f1.nstart;
$f2.nstart;
ob1.check_version 3;
