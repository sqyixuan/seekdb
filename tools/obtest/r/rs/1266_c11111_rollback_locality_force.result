ob1=OBI(cluster=1:1:1:1:1,proxy_num=0,init_unit_cpu=0);
ob1.reboot;
ob1.mysql alter system set balancer_idle_time = '10s';
ob1.mysql alter system set server_data_copy_in_concurrency = 100;
ob1.mysql alter system set server_data_copy_out_concurrency = 100;
ob1.mysql alter system set  data_copy_concurrency = 200;
ob1.mysql create resource pool tt_pool unit = 'sys_unit_config', unit_num = 1, zone_list = ('z1', 'z2', 'z3', 'z4', 'z5');
ob1.mysql create tenant tt resource_pool_list = ('tt_pool'), locality = "F@z1,F@z2,F@z3,F@z4,F@z5" set ob_tcp_invited_nodes='%';
use test;
create table table_test(pk bigint primary key) locality = 'F,R{ALL_SERVER}@z1,F@z2,F@z3,F@z4,F@z5';
create tablegroup tablegroup_test1 locality = 'F,R{ALL_SERVER}@z1,F@z2,F@z3,F@z4,F@z5', binding = true;
create tablegroup tablegroup_test2 locality = 'F,R{ALL_SERVER}@z1,F@z2,F@z3,F@z4,F@z5', binding = false;
ob1.mysql alter tenant sys locality = "F@z1,F@z2,F@z3";
ob1.check_until_timeout select count(*) c from oceanbase.__all_tenant where tenant_id = 1 and previous_locality != '', 0, 600;
ob1.mysql alter tenant tt locality = "F@z1,F@z2,F@z3,F@z4,R@z5";
use test;
alter table table_test locality = 'F,R{ALL_SERVER}@z1,F@z2,F@z3,F@z4,R@z5';
alter tablegroup tablegroup_test1 locality = 'F,R{ALL_SERVER}@z1,F@z2,F@z3,F@z4,R@z5';
alter tablegroup tablegroup_test2 locality = 'F,R{ALL_SERVER}@z1,F@z2,F@z3,F@z4,R@z5';
ob1.z4.obs0.force_stop;
ob1.z5.obs0.force_stop;
ob1.mysql alter tenant tt locality = "F@z1,F@z2,F@z3,F@z4,F@z5" force;
use test;
alter table table_test locality = 'F,R{ALL_SERVER}@z1,F@z2,F@z3,F@z4,F@z5' force;
alter tablegroup tablegroup_test1 locality = 'F,R{ALL_SERVER}@z1,F@z2,F@z3,F@z4,F@z5' force;
alter tablegroup tablegroup_test2 locality = 'F,R{ALL_SERVER}@z1,F@z2,F@z3,F@z4,F@z5' force;
ob1.mysql alter tenant tt locality = "F@z1,F@z2,F@z3";
use test;
alter table table_test locality = 'F,R{ALL_SERVER}@z1,F@z2,F@z3';
alter tablegroup tablegroup_test1 locality = 'F,R{ALL_SERVER}@z1,F@z2,F@z3';
alter tablegroup tablegroup_test2 locality = 'F,R{ALL_SERVER}@z1,F@z2,F@z3';
ob1.check_until_timeout select count(*) c from oceanbase.__all_tenant where tenant_id = $tenant_id and previous_locality != '', 0, 600;
ob1.check_until_timeout select count(*) c from oceanbase.__all_table where tenant_id = $tenant_id and previous_locality != '', 0, 600;
ob1.check_until_timeout select count(*) c from oceanbase.__all_tablegroup where tenant_id = $tenant_id and previous_locality != '', 0, 600;
