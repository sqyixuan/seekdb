ob1=OBI(cluster=2:2:2,proxy_num=0,init_unit_cpu=0);
ob1.reboot;
ob1.mysql create resource pool rp1 unit = 'sys_unit_config', unit_num = 1, zone_list = ('z1', 'z2', 'z3');
ob1.mysql create tenant tt1 replica_num 3, primary_zone 'z1', resource_pool_list ('rp1') set ob_tcp_invited_nodes='%';
ob1.mysql alter system set merger_check_interval = '10s';
create table test(c1 int primary key, c2 int);
insert into test values(1,2),(3,4),(5,6);
ob1.mysql_p alter system major freeze;
ob1.z3.obs1.force_stop;
ob1.z2.obs1.force_stop;
select value from oceanbase.__all_zone where name = "global_broadcast_version";
value
2
select zone, name, value from oceanbase.__all_zone where name = "is_merge_timeout";
zone	name	value
z1	is_merge_timeout	0
z2	is_merge_timeout	0
z3	is_merge_timeout	0
ob1.mysql alter system set zone_merge_timeout = '70s';
ob1.check_until_timeout select info from oceanbase.__all_zone where name = "merge_status" and zone = "", TIMEOUT, 120;
select count(*) > 1 from oceanbase.__all_zone where name = "is_merge_timeout";
count(*) > 1
1
