ob1=OBI(cluster=1:1:1,proxy_num=0,init_unit_cpu=0);
ob1.reboot;
ob1.mysql alter system set enable_auto_leader_switch = false;
ob1.mysql alter system set resource_hard_limit = 500;
ob1.mysql create resource pool xx1  unit = 'sys_unit_config',unit_num = 1, zone_list = ('z1', 'z2', 'z3');
ob1.mysql create tenant xx1 replica_num 3, primary_zone 'z1', resource_pool_list ('xx1') set ob_tcp_invited_nodes='%';
create table  t1 (k int primary key, v int);
create table  t2 (k int primary key, v int);
set ob_query_timeout = 100000000;
set autocommit = 0;
select 1 from __all_root_table for update;
alter system switch replica follower zone = 'z1' tenant = 'xx1';
alter system switch rootservice leader zone = 'z2';
select zone from __all_server where with_rootserver = 1;
zone
z2
