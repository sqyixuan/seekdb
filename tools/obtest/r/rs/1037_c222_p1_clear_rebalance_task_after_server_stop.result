ob1=OBI(cluster=2:2:2,proxy_num=1,init_unit_cpu=0);
ob1.reboot;
ob1.mysql alter system set resource_hard_limit=900;
ob1.mysql alter system set resource_soft_limit=800;
ob1.mysql alter system set debug_sync_timeout = '100s';
ob1.mysql alter system set server_permanent_offline_time = '25s';
ob1.mysql alter system set data_copy_concurrency = 2;
ob1.mysql alter system set balancer_idle_time = '10s';
ob1.create_client tenant=sys,user=admin,passwd=admin;
set ob_global_debug_sync = 'REBALANCE_TASK_MGR_BEFORE_EXECUTE_OVER wait_for begin timeout 10000000000';
ob1.z3.obs0.force_stop;
select count(*) from oceanbase.__all_virtual_rebalance_task_stat where is_scheduled = 'Yes';
count(*)
