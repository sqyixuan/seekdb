ob1=OBI(cluster=2:2:2,proxy_num=0,init_unit_cpu=0);
ob1.reboot;
ob1.mysql alter system set balancer_idle_time='10s' ;
ob1.mysql alter system set server_permanent_offline_time ='1800s';
ob1.mysql alter system set server_data_copy_in_concurrency=20;
ob1.mysql alter system set server_data_copy_out_concurrency=20;
ob1.mysql alter system set data_copy_concurrency=60;
ob1.mysql alter system set balance_blacklist_failure_threshold=0;
ob1.mysql create table oceanbase.test(c1 int primary key, c2 int) primary_zone z1 partition by hash(c1) partitions 30;
ob1.mysql create table oceanbase.test2(c1 int primary key, c2 int) primary_zone z2 partition by hash(c1) partitions 30;
ob1.mysql create table oceanbase.test3(c1 int primary key, c2 int) primary_zone z2 partition by hash(c1) partitions 30;
ob1.mysql update oceanbase.__all_tenant_meta_table set required_size = 9999999999;
ob1.mysql alter system delete server '$ip:$port';
ob1.check_until_timeout select count(*) from __all_server where status = 'deleting', 1, 3;
ob1.check_until_timeout select count(*) from __all_unit where migrate_from_svr_port != 0, 0, 3;
ob1.mysql alter system cancel delete server '$ip:$port';
ob1.mysql alter tenant sys set locality='F@z1,F@z2,L@z3';
ob1.check_until_timeout select count(*) from __all_rootservice_job where job_type = 'ALTER_TENANT_LOCALITY' and job_status = 'SUCCESS', 1, 30;
ob1.mysql update oceanbase.__all_tenant_meta_table set required_size = 9999999999;
ob1.mysql alter system delete server '$ip:$port';
ob1.check_until_timeout select count(*) from __all_unit where migrate_from_svr_port != 0, 1, 30;
ob1.check_until_timeout select count(*)>1 from gv\$partition where svr_ip = '$dest_ip' and svr_port = '$dest_port', 1, 60;
