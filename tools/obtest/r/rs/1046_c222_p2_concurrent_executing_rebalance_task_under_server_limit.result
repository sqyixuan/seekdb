ob1=OBI(cluster=2:2:2,proxy_num=0,init_unit_cpu=0);
ob1.reboot;
ob1.mysql alter system set balancer_idle_time = '10s';
ob1.mysql alter system set server_temporary_offline_time = '15s';
ob1.mysql alter system set resource_hard_limit = 800;
ob1.z3.obs0.force_stop;
ob1.mysql alter system set server_permanent_offline_time = '25s';
