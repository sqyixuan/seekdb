ob1=OBI(cluster=2:2:2,proxy_num=0,init_unit_cpu=0,node_cpu_count=24,memory_size_limit=81920);
ob1.reboot;
ob1.mysql alter system set balancer_idle_time = '10s';
ob1.mysql alter system set resource_soft_limit = 100;
ob1.mysql alter system set resource_hard_limit = 100;
ob1.mysql alter system set debug_sync_timeout = '1000s';
ob1.mysql alter resource unit sys_unit_config max_cpu = 4, min_cpu = 4, max_memory = '10G', min_memory = '10G';
ob1.mysql create resource unit half max_cpu=10,min_cpu=10,max_memory='5G',min_memory='5G',max_disk_size='5G',max_iops=1000,max_session_num=1000;
ob1.mysql create resource pool half unit = 'half', unit_num = 1, zone_list = ('z1', 'z2', 'z3');
ob1.mysql create tenant half replica_num 3, resource_pool_list ('half') set ob_tcp_invited_nodes='%';
ob1.mysql create resource pool half2 unit = 'half', unit_num = 1, zone_list = ('z1', 'z2', 'z3');
ob1.mysql create tenant half2 replica_num 3, resource_pool_list ('half2') set ob_tcp_invited_nodes='%';
ob1.mysql alter system migrate unit $unit_id destination = "$dest_ip:$dest_port";
ob1.mysql alter system migrate unit $unit_id destination = "$dest_ip:$dest_port";
ob1.mysql alter system migrate unit $unit_id destination = "$dest_ip:$dest_port";
ob1.check_until_timeout select count(*) from oceanbase.__all_unit where length(migrate_from_svr_ip) > 0, 0, 240;
ob1.mysql set ob_global_debug_sync = 'BEFORE_REBALANCE_TASK_EXECUTE wait_for x';
ob1.mysql alter system set resource_soft_limit = 30;
ob1.mysql_p select count(*) from oceanbase.__all_unit where length(migrate_from_svr_ip) > 0 and resource_pool_id = $tenant_id;
count(*)
