ob1=OBI(cluster=3:3:3,proxy_num=0,memory_size_limit='30G');
ob1.reboot;
ob1.mysql CREATE RESOURCE UNIT test MAX_CPU $cpu, MAX_MEMORY $memory, MAX_IOPS $iops, MAX_DISK_SIZE $disk, MAX_SESSION_NUM $session, MIN_CPU=1, MIN_MEMORY=$min_memory, MIN_IOPS=128;
ob1.mysql CREATE RESOURCE POOL pool1 UNIT = 'test', UNIT_NUM = 3, ZONE_LIST = ('z1', 'z2', 'z3');
ob1.mysql CREATE TENANT obtest1 RESOURCE_POOL_LIST = ('pool1'),primary_zone='z1' set ob_tcp_invited_nodes='%';
ob1.mysql alter system set enable_auto_leader_switch = false;
ob1.mysql alter system server_data_copy_out_concurrency = 20;
ob1.mysql alter system server_data_copy_in_concurrency = 20;
ob1.mysql alter system balancer_idle_time = '10s';
ob1.mysql alter system enable_rebalance = true;
CREATE DATABASE obtest;
use obtest;
create table t1(c1 int) partition by hash(c1) partitions 20;
create tablegroup tg1 binding=true;
set ob_query_timeout = 1000000000;
alter system stop server '100.88.107.209:34480';
ob1.check_until_timeout select ($count_zone_2 + $count_zone_3), $count_server, 10;
ob1.mysql alter tenant obtest1 primary_zone = 'z3';
ob1.check_until_timeout select count(*) from __all_virtual_meta_table where role = 1 and zone = 'z3' and tenant_id = 1001, $count_zone_3, 10;
ob1.mysql alter resource pool pool1 unit_num = 2;
ob1.check_until_timeout select count(*) from __all_rootservice_job where job_type = 'SHRINK_RESOURCE_POOL_UNIT_NUM' and job_status = 'SUCCESS', 1, 1000000;
