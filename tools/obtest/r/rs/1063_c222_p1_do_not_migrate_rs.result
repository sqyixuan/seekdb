ob1=OBI(cluster=2:2:2,proxy_num=0,init_unit_cpu=0);
ob1.reboot;
ob1.mysql alter system set resource_hard_limit=900;
ob1.mysql alter system set resource_soft_limit=800;
ob1.mysql alter system set server_data_copy_out_concurrency = 4;
ob1.mysql alter system set server_data_copy_in_concurrency = 4;
ob1.mysql alter system set enable_rootservice_standalone = 'false';
ob1.mysql alter system set balancer_idle_time = '10s';
ob1.mysql alter system set enable_auto_leader_switch = 'false';
ob1.mysql alter resource pool sys_pool unit_num = 2;
ob1.check_rebalance_task 240;
ob1.mysql_p select role from oceanbase.__all_virtual_core_meta_table where svr_ip = '$ip' and svr_port = $port;
role
1
ob1.mysql_p select max(cnt) / min(cnt), max(cnt) % min(cnt) from (select count(*) cnt from oceanbase.__all_root_table where table_id = 1099511627779 and zone = 'z1' and tenant_id = 1 group by svr_ip, svr_port) a;
max(cnt) / min(cnt)	max(cnt) % min(cnt)
1.0000	0
