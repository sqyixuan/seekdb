ob1=OBI(cluster=2:2:2,proxy_num=0,init_unit_cpu=0);
ob1.reboot;
ob1.mysql alter system set debug_sync_timeout = '1000s';
ob1.mysql alter system set server_data_copy_in_concurrency = 1;
ob1.mysql alter system set server_data_copy_out_concurrency = 1;
ob1.mysql alter system set enable_rebalance = 'false';
ob1.mysql alter system set resource_hard_limit = 500;
ob1.mysql set ob_global_debug_sync = 'REBALANCE_TASK_MGR_BEFORE_EXECUTE_OVER wait_for execute';
ob1.mysql alter resource pool sys_pool unit_num = 2;
ob1.mysql alter system move replica partition_id = '$i%16@$t0' source = '$z3obs0ip:$z3obs0port' destination = '$z3obs1ip:$z3obs1port';
