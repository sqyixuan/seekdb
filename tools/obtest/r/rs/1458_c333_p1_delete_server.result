ob1=OBI(cluster=3:3:3,  proxy_num=0, ct_num = 0);
ob1.reboot;
ob1.mysql alter system set balancer_idle_time = '10s';
ob1.mysql alter system set server_data_copy_in_concurrency = 2;
ob1.mysql alter system set server_data_copy_out_concurrency = 2;
ob1.mysql alter system set enable_rereplication = false;
ob1.mysql CREATE RESOURCE UNIT unit_$case_index MAX_CPU $cpu, MAX_MEMORY $memory, MAX_IOPS $iops, MAX_DISK_SIZE $disk, MAX_SESSION_NUM $session, MIN_CPU=1, MIN_MEMORY=$min_memory, MIN_IOPS=128;
ob1.mysql CREATE RESOURCE POOL pool_2 UNIT = 'unit_1', UNIT_NUM = 1, ZONE_LIST = ('z1', 'z2','z3');
ob1.mysql CREATE TENANT tenant_$case_index RESOURCE_POOL_LIST = ('pool_2'), locality='F@z1,F@z2,F@z3', primary_zone='z1;z2;z3' set ob_tcp_invited_nodes='%';
ob1.create_client tenant=tenant_1,user=root,passwd=,database=test;
create table test(c1 int primary key, c2 int) partition by hash(c1) partitions 10;
ob1.mysql alter system enable_rebalance = false;
ob1.create_client tenant=sys,user=root,passwd=,database=oceanbase;
ob1.mysql alter system enable_rebalance = true;
ob1.check_until_timeout select count(*) from __all_rootservice_event_history where event like '%finish_migrate_unit%' and value2 like '2', 1, 40;
ob1.check_until_timeout select count(*) from __all_unit where unit_id=$unit_id and concat(svr_ip,":", svr_port) = '$unit_addr', 1, 30;
ob1.check_until_timeout select count(*) c from oceanbase.__all_rootservice_job where job_id = $mjob_id and job_status="FAILED" ,1,30;
ob1.check_until_timeout select count(*) from __all_server, 8, 600;
ob1.check_until_timeout select count(*) c from oceanbase.__all_rootservice_job where job_id = $job_id and job_status="SUCCESS" ,1,30;
ob1.mysql alter system enable_rebalance = true;
ob1.check_until_timeout select count(*) from __all_unit where migrate_from_svr_port != 0, 0, 60;
ob1.check_until_timeout select count(*) c from __all_server, 8, 120;
ob1.check_until_timeout select count(*) c from oceanbase.__all_rootservice_job where job_id = $job_id and job_status="SUCCESS" ,1,30;
ob1.mysql update oceanbase.__all_virtual_meta_table set required_size = 1073741824;
ob1.check_until_timeout select count(*) from __all_unit where unit_id =$unit_id and concat(svr_ip,":", svr_port) = '$unit_addr', 1, 3;
ob1.check_until_timeout select count(*) c from oceanbase.__all_rootservice_job where job_id = $job_id and job_status="FAILED" ,1,30;
ob1.mysql alter system report replica;
ob1.mysql alter system set enable_rereplication = false;
$obi.force_stop;
ob1.check_until_timeout select count(*) from __all_server where status = 'inactive', 1, 12;
ob1.mysql alter system set enable_rereplication = true;
ob1.check_until_timeout select count(*) from __all_unit where migrate_from_svr_port != 0, 0, 60;
ob1.check_until_timeout select count(*) from __all_unit where unit_id =$unit_id and concat(svr_ip,":", svr_port) = '$dest_addr', 0, 60;
ob1.check_until_timeout select count(*) c from oceanbase.__all_rootservice_job where job_id = $mjob_id and job_status="SUCCESS" ,1,30;
