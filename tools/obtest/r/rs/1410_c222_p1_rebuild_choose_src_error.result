ob1=OBI(cluster=2:2:2, init_unit_cpu=2, proxy_num=0, ct_num=0);
ob1.reboot;
ob1.mysql alter system set enable_auto_leader_switch = 'False';
ob1.mysql alter system set balancer_idle_time = '10s';
ob1.mysql_p update oceanbase.__all_root_table set rebuild = 1,data_version = data_version + 1 where table_id = 1099511627932 and concat(svr_ip,":", svr_port) = '$dest';
ob1.check_until_timeout select count(*)>=1 from __all_rootservice_event_history where value1 like '%tid:1099511627932%' and event = 'finish_rebuild_replica' and value1 not like '%$dest%', 1, 30;
