1	ALTER_TENANT_LOCALITY	SUCCESS	0	100	alter tenant sys resource_pool_list=('sys_pool', 'sys_pool1'), primary_zone = 'z1', locality = 'F@z1,F@z2,F@z3,F@z4'
2	ALTER_TENANT_LOCALITY	SUCCESS	0	100	alter tenant sys resource_pool_list=('sys_pool', 'sys_pool1', 'sys_pool2'), primary_zone = 'z1', locality = 'F@z1,F@z2,F@z3,F@z4,F@z5'
