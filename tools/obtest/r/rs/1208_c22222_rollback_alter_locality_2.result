ob1=OBI(cluster=2:2:2:2:2,proxy_num=0,init_unit_cpu=0,node_cpu_count=64,memory_size_limit=524288);
ob1.z4.obs0.set status=disable;
ob1.z4.obs1.set status=disable;
ob1.z5.obs0.set status=disable;
ob1.z5.obs1.set status=disable;
ob1.reboot;
ob1.z4.add;
ob1.z4.start_zone;
ob1.z4.obs0.set status=enable;
ob1.z4.obs0.start;
ob1.z4.obs0.add;
ob1.z4.obs1.set status=enable;
ob1.z4.obs1.start;
ob1.z4.obs1.add;
ob1.z5.add;
ob1.z5.start_zone;
ob1.z5.obs0.set status=enable;
ob1.z5.obs0.start;
ob1.z5.obs0.add;
ob1.z5.obs1.set status=enable;
ob1.z5.obs1.start;
ob1.z5.obs1.add;
ob1.mysql alter system set enable_rebalance = 'true';
ob1.mysql alter system set enable_rereplication = 'true';
ob1.mysql alter system set balancer_idle_time = '10s';
ob1.mysql alter system set server_data_copy_in_concurrency = 20;
ob1.mysql alter system set server_data_copy_out_concurrency = 20;
ob1.mysql create resource pool sys_pool1 unit = 'sys_unit_config', unit_num = 1, zone_list = ('z4');
ob1.mysql create resource pool sys_pool2 unit = 'sys_unit_config', unit_num = 1, zone_list = ('z5');
ob1.mysql create resource pool tt1_pool0 unit = 'sys_unit_config', unit_num = 2, zone_list = ('z1', 'z2', 'z3');
ob1.mysql create resource pool tt1_pool1 unit = 'sys_unit_config', unit_num = 2, zone_list = ('z4');
ob1.mysql create resource pool tt1_pool2 unit = 'sys_unit_config', unit_num = 2, zone_list = ('z5');
ob1.mysql create tenant tt1 resource_pool_list = ('tt1_pool0'), primary_zone = 'z1', locality = 'F@z1,F@z2,F@z3' set ob_tcp_invited_nodes='%';
ob1.mysql alter tenant sys resource_pool_list=('sys_pool', 'sys_pool1'), primary_zone = 'z1', locality = 'F@z1,F@z2,F@z3,F@z4';
ob1.check_until_timeout select count(*) c from oceanbase.__all_tenant where tenant_id = $tenant_id and previous_locality != "", 0, 600;
ob1.check_until_timeout select count(*) c from oceanbase.__all_virtual_core_meta_table where role = 1 and member_list like '%$svr_ip:$svr_port%', 1, 360;
ob1.check_until_timeout select count(*) c from oceanbase.__all_core_table where row_id = $row_id and table_name = '__all_root_table' and column_name = 'member_list' and column_value like '%$svr_ip:$svr_port%', 1, 360;
ob1.check_until_timeout select count(*) c from oceanbase.__all_root_table where role = 1 and member_list like '%$svr_ip:$svr_port%', $sys_table_num, 360;
ob1.check_until_timeout select count(*) c from oceanbase.__all_rootservice_job where job_id = $job_id and job_status="SUCCESS" ,1,30;
ob1.mysql alter tenant sys resource_pool_list=('sys_pool', 'sys_pool1', 'sys_pool2'), primary_zone = 'z1', locality = 'F@z1,F@z2,F@z3,F@z4,F@z5';
ob1.check_until_timeout select count(*) c from oceanbase.__all_tenant where tenant_id = $tenant_id and previous_locality != "", 0, 600;
ob1.check_until_timeout select count(*) c from oceanbase.__all_virtual_core_meta_table where role = 1 and member_list like '%$svr_ip:$svr_port%', 1, 360;
ob1.check_until_timeout select count(*) c from oceanbase.__all_core_table where row_id = $row_id and table_name = '__all_root_table' and column_name = 'member_list' and column_value like '%$svr_ip:$svr_port%', 1, 360;
ob1.check_until_timeout select count(*) c from oceanbase.__all_root_table where role = 1 and member_list like '%$svr_ip:$svr_port%', $sys_table_num, 360;
ob1.check_until_timeout select count(*) c from oceanbase.__all_rootservice_job where job_id = $job_id and job_status="SUCCESS" ,1,30;
