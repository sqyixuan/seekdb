ob1=OBI(cluster=3:3:3,proxy_num=0,init_unit_cpu=0);
ob1.reboot;
ob1.mysql alter system set balancer_idle_time = '30s';
ob1.mysql alter system set enable_auto_leader_switch = 'False';
ob1.mysql alter system  set enable_rebalance='false';
ob1.mysql alter system set server_data_copy_in_concurrency = 20;
ob1.mysql alter system set server_data_copy_out_concurrency = 20;
ob1.mysql CREATE RESOURCE UNIT testunit max_cpu 4, max_memory 1073741824, max_iops 100000, max_disk_size 536870912, max_session_num 64, MIN_CPU=4, MIN_MEMORY=1073741824,MIN_IOPS=128;
ob1.mysql CREATE RESOURCE POOL sys_pool_2 UNIT = 'testunit', UNIT_NUM = 3, ZONE_LIST = ('z1', 'z2', 'z3');
ob1.mysql CREATE TENANT tt resource_pool_list=('sys_pool_2'), locality = 'F@z1,F@z2,F,R@z3' set ob_tcp_invited_nodes='%';
use test;
create tablegroup tg locality = 'F@z1,F@z2,F@z3' partition by hash partitions 100;
create table t1 (c1 int primary key, c2 int) tablegroup = tg locality = 'F@z1,F@z2,F@z3' partition by hash(c1) partitions 100;
insert into t1 values(1,1),(2,2),(3,3),(100,100),(11,11);
create table t2 (c1 int,c2 int ,primary key(c1))  locality ='F@z1,F@z2,F@z3' partition by range(c1) (partition p0 values less than(10), partition p1 values less than(20), partition p2 values less than(30), partition p3 values less than(40), partition p4 values less than(50));
insert into t2 values(1,1),(2,2),(3,3),(10,100),(11,11);
ob1.mysql alter system set debug_sync_timeout = '100000s';
ob1.mysql set ob_global_debug_sync = 'BEFORE_CHECK_LOCALITY wait_for continue_signal';
ob1.mysql alter tenant tt locality = "F@z1,F@z2,F@z3";
ob1.check_until_timeout select count(*) c from oceanbase.__all_rootservice_job where job_id = $job_id and job_status="INPROGRESS" ,1,3;
ob1.mysql alter tenant tt locality = "F@z1,F@z2,F,R@z3";
