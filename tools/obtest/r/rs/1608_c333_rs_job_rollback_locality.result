ob1.mysql alter tenant tt locality = "F@z1,F@z2,F,R@z3";
ob1.mysql alter tenant tt locality = "F@z1,F@z2,F@z3";
ob1.mysql alter system set enable_rebalance='true';
ob1.check_until_timeout select count(*) c from oceanbase.__all_rootservice_job where job_id = $job_id and job_status="FAILED" ,1,3;
ob1.check_until_timeout select count(*) c from oceanbase.__all_rootservice_job where job_type="ROLLBACK_ALTER_TENANT_LOCALITY" ,4,3;
ob1.mysql set ob_global_debug_sync = 'now signal continue_signal';
ob1.check_until_timeout select count(*) c from oceanbase.__all_rootservice_job where job_id = $job_id and job_status="SUCCESS" ,1,300;
