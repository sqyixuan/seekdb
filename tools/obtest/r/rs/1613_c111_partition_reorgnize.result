ob1=OBI(cluster=1:1:1,  proxy_num=0, ct_num = 0,init_unit_cpu=5);
ob1.reboot;
create database db;
use db;
create table t1 (c1 int primary key ,c2 int ,c3 int) partition by range (c1)(partition p0 values less than (10),partition p1 values less than (100),partition p2 values less than (1000));
create table t2 (c1 int primary key ,c2 int ,c3 int) partition by range (c1)(partition p0 values less than (10),partition p1 values less than (100),partition p2 values less than (MAXVALUE));
create table t3 (c1 int ,c2 int ,c3 int, primary key (c1,c2)) partition by range columns (c1,c2)(partition p0 values less than (10,10),partition p1 values less than (100,100),partition p2 values less than (maxvalue,maxvalue));
