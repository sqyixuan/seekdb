ob1=OBI(cluster=1:2:3,proxy_num=0,init_unit_num=1);
ob1.z2.obs1.set status=disable;
ob1.z3.obs1.set status=disable;
ob1.z3.obs2.set status=disable;
ob1.reboot;
ob1.z2.obs1.set status=enable;
ob1.z2.obs1.start;
ob1.z2.obs1.add;
ob1.z3.obs1.set status=enable;
ob1.z3.obs1.start;
ob1.z3.obs1.add;
ob1.z3.obs2.set status=enable;
ob1.z3.obs2.start;
ob1.z3.obs2.add;
ob1.mysql CREATE RESOURCE UNIT unit_1 MAX_CPU $cpu, MAX_MEMORY $memory, MAX_IOPS $iops, MAX_DISK_SIZE $disk, MAX_SESSION_NUM $session, MIN_CPU=1, MIN_MEMORY=$min_memory, MIN_IOPS=128;
ob1.mysql CREATE RESOURCE POOL pool_2 UNIT = 'unit_1', UNIT_NUM = 1, ZONE_LIST = ('z1', 'z2','z3');
ob1.mysql CREATE TENANT tenant_$case_index RESOURCE_POOL_LIST = ('pool_2'), locality='F@z1,F@z2,F@z3', primary_zone='z1;z2;z3' set ob_tcp_invited_nodes='%';
alter system delete server '11.165.237.138:34333';
ERROR HY000: machine resource is not enough to hold a new unit
alter system delete server '11.165.237.138:34334';
ob1.check_until_timeout select count(*) from oceanbase.__all_rootservice_job where job_status = "INPROGRESS" , 0, 480;
alter system delete server '11.167.235.142:34336';
ob1.check_until_timeout select count(*) from oceanbase.__all_rootservice_job where job_status = "INPROGRESS" , 0, 480;
