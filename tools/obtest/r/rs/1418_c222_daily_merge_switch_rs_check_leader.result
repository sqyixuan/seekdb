ob1=OBI(cluster=2:2:2, init_unit_cpu=2, proxy_num=0, ct_num=0, locality=hz:hz:hz);
ob1.reboot;
ob1.mysql alter system set merger_check_interval = '10s';
ob1.mysql alter system set debug_sync_timeout = '30s';
ob1.mysql CREATE RESOURCE UNIT unit_$case_index MAX_CPU $cpu, MAX_MEMORY $memory, MAX_IOPS $iops, MAX_DISK_SIZE $disk, MAX_SESSION_NUM 64, MIN_CPU=1, MIN_MEMORY=$min_memory, MIN_IOPS=128;
ob1.mysql CREATE RESOURCE POOL pool_$case_index UNIT = 'unit_$case_index', UNIT_NUM = 2, ZONE_LIST =('z1', 'z2','z3');
ob1.mysql CREATE TENANT tenant_$case_index RESOURCE_POOL_LIST = ('pool_$case_index'),locality='F@z1,F@z2,F@z3', primary_zone='z1,z2' set ob_tcp_invited_nodes='%';
ob1.create_client tenant=tenant_1,user=root,passwd=,database=test;
create table tt(c1 int primary key, c2 int) partition by hash(c1) partitions 100;
create table tt2(c1 int primary key, c2 int) partition by hash(c1) partitions 100;
ob1.mysql CREATE RESOURCE UNIT unit_$case_index MAX_CPU $cpu, MAX_MEMORY $memory, MAX_IOPS $iops, MAX_DISK_SIZE $disk, MAX_SESSION_NUM 64, MIN_CPU=1, MIN_MEMORY=$min_memory, MIN_IOPS=128;
ob1.mysql CREATE RESOURCE POOL pool_$case_index UNIT = 'unit_$case_index', UNIT_NUM = 2, ZONE_LIST =('z1', 'z2','z3');
ob1.mysql CREATE TENANT tenant_$case_index RESOURCE_POOL_LIST = ('pool_$case_index'),locality='F@z1,F@z2,F@z3', primary_zone='z1,z2' set ob_tcp_invited_nodes='%';
ob1.create_client tenant=tenant_2,user=root,passwd=,database=test;
create table tt(c1 int primary key, c2 int) partition by hash(c1) partitions 100;
create table tt2(c1 int primary key, c2 int) partition by hash(c1) partitions 100;
ob1.create_client tenant=sys,user=root,passwd=,database=oceanbase;
ob1.mysql alter system major freeze;
set ob_global_debug_sync = 'BEFORE_AUTO_COORDINATE wait_for y';
select count(*)>0 c from oceanbase.__all_table;
c
1
ob1.check_until_timeout select count(*) from oceanbase.__all_zone where zone = 'z1' and name = 'is_merging' and value = 1, 1, 120;
ob1.z2.obs0.switch_partition sys:oceanbase:__all_core_table;
ob1.mysql_p select zone, name, info, value from oceanbase.__all_zone where name ='merge_status';
zone	name	info	value
	merge_status	MERGING	1
z1	merge_status	IDLE	0
z2	merge_status	IDLE	0
z3	merge_status	IDLE	0
ob1.mysql_p select * from __all_virtual_meta_table where role = 1;
ob1.check_version 2;
ob1.mysql_p select count(*) c from oceanbase.__all_rootservice_event_history where module like '%daily%' and event ='switch_leader_fail';
c
0
