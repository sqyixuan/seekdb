ob1=OBI(cluster=2:2:2,proxy_num=0,init_unit_cpu=0,node_cpu_count=20,memory_size_limit=480000);
ob1.reboot;
ob1.mysql alter system set balancer_idle_time = '10s';
ob1.mysql alter system set resource_soft_limit = 5;
ob1.mysql alter system set resource_hard_limit = 50;
ob1.z3.obs1.force_stop;
ob1.mysql create resource pool xx1  unit = 'sys_unit_config',unit_num = 1, zone_list = ('z1', 'z2', 'z3');
ob1.mysql create tenant xx1 replica_num 3, primary_zone 'z1', resource_pool_list ('xx1') set ob_tcp_invited_nodes='%';
set ob_create_table_strict_mode = 0;
create table t1 (k int primary key, v int);
create table t2 (k int primary key, v int);
ob1.mysql alter system set server_permanent_offline_time = '20s';
ob1.check_until_timeout select with_partition from oceanbase.__all_server where status != 'active', 0, 120;
ob1.mysql_p select count(*) from oceanbase.__all_server s, oceanbase.__all_virtual_meta_table m where m.zone = 'z3' and s.svr_ip = m.svr_ip and s.svr_port = m.svr_port and s.status = 'active';
count(*)
2
ob1.mysql alter system set resource_hard_limit = 200;
ob1.mysql alter system set resource_soft_limit = 200;
ob1.mysql_p select count(*) from oceanbase.__all_server s, oceanbase.__all_virtual_meta_table m where m.zone = 'z3' and s.svr_ip = m.svr_ip and s.svr_port = m.svr_port and s.status = 'active';
count(*)
2
ob1.mysql delete from oceanbase.__all_rootservice_event_history;
ob1.z1.obs1.force_stop;
ob1.check_until_timeout select count(*) from oceanbase.__all_server s, oceanbase.__all_virtual_meta_table m where m.zone = 'z1' and s.svr_ip = m.svr_ip and s.svr_port = m.svr_port and s.status = 'active', 2, 60;
