ERROR 42000: Access denied for user 'root'@'%' to database 'oceanbase'
alter system change tenant tenant_1;
select count(*) from oceanbase.__all_tenant_meta_table;
count(*)
12
update oceanbase.__all_tenant_meta_table set quorum = 2 where 1 = 1;
select count(*) from oceanbase.__all_tenant_meta_table where quorum = 2;
count(*)
12
update oceanbase.__all_tenant_meta_table set quorum = 3 where 1 = 1;
alter system change tenant sys;
ob1.mysql alter tenant tenant_1 set locality = "F@z1,F@z2,F@z3";
ob1.check_until_timeout select count(*) from __all_tenant where previous_locality != "", 0, 360;
ob1.mysql alter system minor freeze tenant = sys;
ob1.mysql alter system minor freeze tenant = all_user;
ob1.mysql alter system minor freeze tenant = all_meta;
ob1.check_until_timeout select count(1) from __all_virtual_memstore_info where is_active=0, 0, 60;
ob1.mysql alter system major freeze;
ob1.check_version 3;
drop tenant tenant_1 force;
alter system change tenant tenant_1;
ERROR HY000: invalid tenant name specified in connection string
ob1.mysql alter system minor freeze tenant = sys;
ob1.mysql alter system minor freeze tenant = all_user;
ob1.mysql alter system minor freeze tenant = all_meta;
ob1.check_until_timeout select count(1) from __all_virtual_memstore_info where is_active=0, 0, 60;
ob1.mysql alter system major freeze;
ob1.check_version 4;
