ob1=OBI(cluster=1:1:1, init_unit_cpu=0, proxy_num=0, ct_num=0, locality=hz:hz:hz);
ob1.z1.obs0.set extra_config=__schema_split_mode=true;
ob1.z2.obs0.set extra_config=__schema_split_mode=true;
ob1.z3.obs0.set extra_config=__schema_split_mode=true;
ob1.reboot;
ob1.mysql alter system set resource_hard_limit=900;
ob1.mysql alter system set resource_soft_limit=800;
ob1.mysql alter system set debug_sync_timeout = '1000s';
ob1.mysql alter system set enable_auto_leader_switch = 'false';
ob1.mysql alter system set enable_rebalance = 'true';
ob1.mysql alter system set enable_rereplication = 'true';
ob1.mysql alter system set balancer_idle_time = '10s';
ob1.mysql alter system set server_data_copy_out_concurrency = 20;
ob1.mysql alter system set server_data_copy_in_concurrency = 20;
ob1.mysql CREATE RESOURCE UNIT unit_1 MAX_CPU $cpu, MAX_MEMORY $memory, MAX_IOPS $iops, MAX_DISK_SIZE $disk, MAX_SESSION_NUM $session, MIN_CPU=1, MIN_MEMORY=$min_memory, MIN_IOPS=128;
ob1.mysql CREATE RESOURCE POOL pool_1 UNIT = 'unit_1', UNIT_NUM = 1, ZONE_LIST = ('z1','z2', 'z3');
ob1.mysql CREATE TENANT tenant_1 RESOURCE_POOL_LIST = ('pool_1'), primary_zone = 'z1;z2;z3', locality='F@z1,F@z2,F@z3' set ob_tcp_invited_nodes='%';
use test;
create table tt1(c1 int primary key, c2 int) partition by hash(c1) partitions 2;
create table tt2(c1 int primary key, c2 int) partition by hash(c1) partitions 2;
insert into tt1(c1, c2) values(1,1),(2,2);
select * from tt1 order by c1 desc;
c1	c2
2	2
1	1
ob1.mysql alter tenant tenant_1 set locality = "F@z1,F@z2,R@z3";
ob1.check_until_timeout select count(*) from __all_tenant where previous_locality != "", 0, 360;
ob1.mysql alter system minor freeze tenant = sys;
ob1.mysql alter system minor freeze tenant = all_user;
ob1.mysql alter system minor freeze tenant = all_meta;
ob1.check_until_timeout select count(1) from __all_virtual_memstore_info where is_active=0, 0, 60;
ob1.mysql alter system major freeze;
ob1.check_version 2;
ob1.mysql drop tenant tenant_1;
ob1.mysql_p drop tenant tenant_1;
ob1.mysql_p drop tenant if exists tenant_1;
use test;
create table tt3(c1 int primary key, c2 int) partition by hash(c1) partitions 2;
ERROR HY000: ddl operation during dropping tenant not allowed
drop table tt2;
select * from tt1;
ERROR HY000: read/write user table in dropped tenant not allowed
insert into tt1(c1,c2) values(3,3);
ERROR HY000: read/write user table in dropped tenant not allowed
