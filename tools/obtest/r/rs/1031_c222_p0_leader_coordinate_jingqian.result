ob1.mysql CREATE RESOURCE POOL pool3 UNIT = 'test', UNIT_NUM = 2, ZONE_LIST = ('z1', 'z2', 'z3');
ob1.mysql CREATE TENANT obtest3 RESOURCE_POOL_LIST = ('pool3') set ob_tcp_invited_nodes='%';
ob1.mysql alter system set enable_auto_leader_switch = false;
CREATE DATABASE obtest;
use obtest;
CREATE TABLEGROUP tablegroup1 PRIMARY_ZONE = 'z1' PARTITION BY KEY 1 PARTITIONS 2;
CREATE TABLEGROUP tablegroup2 PRIMARY_ZONE = 'z2' PARTITION BY KEY 1 PARTITIONS 2;
CREATE TABLEGROUP tablegroup3 PRIMARY_ZONE = 'z3' PARTITION BY KEY 1 PARTITIONS 2;
CREATE TABLE table1 (pk int, value int, primary key(pk)) PRIMARY_ZONE 'z1' TABLEGROUP 'tablegroup1' PARTITION BY KEY(pk) PARTITIONS 2;
CREATE TABLE table2 (pk int, value int, primary key(pk)) PRIMARY_ZONE 'z1' TABLEGROUP 'tablegroup1' PARTITION BY KEY(pk) PARTITIONS 2;
CREATE TABLE table3 (pk int, value int, primary key(pk)) PRIMARY_ZONE 'z2' TABLEGROUP 'tablegroup2' PARTITION BY KEY(pk) PARTITIONS 2;
CREATE TABLE table4 (pk int, value int, primary key(pk)) PRIMARY_ZONE 'z2' TABLEGROUP 'tablegroup2' PARTITION BY KEY(pk) PARTITIONS 2;
CREATE TABLE table5 (pk int, value int, primary key(pk)) PRIMARY_ZONE 'z3' TABLEGROUP 'tablegroup3' PARTITION BY KEY(pk) PARTITIONS 2;
CREATE TABLE table6 (pk int, value int, primary key(pk)) PRIMARY_ZONE 'z3' TABLEGROUP 'tablegroup3' PARTITION BY KEY(pk) PARTITIONS 2;
ob1.mysql alter system set enable_auto_leader_switch = true;
