ob1=OBI(cluster=2:2:2,node_cpu_count=64,node_cpu_reserved=2,memory_size_limit=262144);
ob1.reboot;
ob1.mysql alter system set resource_soft_limit = 500;
ob1.mysql alter system set resource_hard_limit = 800;
ob1.mysql CREATE RESOURCE UNIT test MAX_CPU $cpu, MAX_MEMORY $memory, MAX_IOPS $iops, MAX_DISK_SIZE $disk, MAX_SESSION_NUM $session, MIN_CPU=1, MIN_MEMORY=$min_memory, MIN_IOPS=128;
ob1.mysql CREATE RESOURCE POOL pool1 UNIT = 'test', UNIT_NUM = 1, ZONE_LIST = ('z1', 'z2', 'z3');
ob1.mysql CREATE TENANT obtest1 RESOURCE_POOL_LIST = ('pool1') set ob_tcp_invited_nodes='%';
ob1.mysql alter system set enable_auto_leader_switch = false;
CREATE DATABASE obtest;
use obtest;
CREATE TABLE obtest1 (pk int, value int, primary key(pk));
CREATE TABLE obtest2 (pk int, value int, primary key(pk));
CREATE TABLE obtest3 (pk int, value int, primary key(pk));
$leader.check_leader obtest1:obtest:obtest$table_id:0;
$leader.check_leader obtest1:obtest:obtest$table_id:0;
$leader.check_leader obtest1:obtest:obtest$table_id:0;
ob1.z2.switch_partition obtest1:obtest:obtest1:0;
$expected_leader.check_leader obtest1:obtest:obtest1:0;
ob1.mysql alter system set enable_auto_leader_switch = true;
$leader.check_leader obtest1:obtest:obtest$table_id:0;
$leader.check_leader obtest1:obtest:obtest$table_id:0;
$leader.check_leader obtest1:obtest:obtest$table_id:0;
