ob1=OBI(cluster=1:1:1,proxy_num=0,init_unit_cpu=0);
ob1.reboot;
ob1.mysql alter system set merger_check_interval = '10s';
ob1.mysql alter system major freeze;
ob1.z1.check_version 2;
ob1.mysql alter system major freeze;
ob1.mysql alter system add zone 'z4';
ob1.mysql alter system start zone 'z4';
ob1.z2.check_version 3;
ob1.mysql_p select value from oceanbase.__all_zone where zone = 'z4' and name = 'is_merge_timeout';
value
