ob1.check_until_timeout select count(*) c from __all_virtual_meta_table where role = 1 and member_list not like '%,%,%', 300, 60;
ob1.mysql alter system set enable_rereplication = 'true';
ob1.check_until_timeout select count(*) < 300 from __all_virtual_meta_table where role = 1 and member_list not like '%,%,%', 1, 120;
ob1.mysql update oceanbase.__all_tenant_meta_table set rebuild = 1 where svr_ip= '$svr_ip' and svr_port = $svr_port and tenant_id = $tenant_id limit 10;
