ob1=OBI(cluster=3:2:2,init_unit_cpu=2,init_unit_num=1, node_cpu_count=64, node_cpu_reserved=2);
ob1.reboot;
ob1.source include/migrate.inc;
ob1.source include/merge.inc;
ob1.mysql alter system set enable_auto_leader_switch = false;
ob1.mysql alter system set resource_hard_limit = 800;
ob1.proxy0.mysql_root alter proxyconfig set server_state_refresh_interval = '2s';
ob1.create_client;
ob1.z3.obs0.stop;
ob1.mysql_p $check_server;
