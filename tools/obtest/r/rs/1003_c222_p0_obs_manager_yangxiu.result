ob1.z1.obs1.delete;
ob1.z1.obs1.check_delete 400;
ob1.z1.obs1.add;
ob1.mysql alter system set enable_auto_leader_switch=false;
$obs.stop;
$obs.nstart;
$leader.delete;
$leader.check_delete 420;
ob1.mysql alter system major freeze;
ob1.check_version 2;
ob1.mysql CREATE RESOURCE UNIT $unitname max_cpu 2, max_memory 1073741824, max_iops 100000, max_disk_size 536870912, max_session_num 64, MIN_CPU=1, MIN_MEMORY=1073741824, MIN_IOPS=128;
ob1.mysql CREATE RESOURCE POOL $poolname UNIT = '$unitname', UNIT_NUM = 1, zone_list = ('$zone_name');
ob1.mysql CREATE TENANT $ttname replica_num = 1, primary_zone='$zone_name', resource_pool_list=('$poolname');
ob1.mysql alter tenant $ttname set variables ob_tcp_invited_nodes='%';
ob1.mysql select * from oceanbase.__all_tenant where tenant_name='$ttname';
ob1.mysql CREATE DATABASE $dbname;
ob1.mysql_p select database();
