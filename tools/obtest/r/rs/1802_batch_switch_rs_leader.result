ob1=OBI(cluster=1:1:1,proxy_num=0);
ob1.reboot;
ob1.z1.obs0.mysql alter system set enable_auto_leader_switch = false;
'leader_count > 0'
ob1.sh ./etc/ob_admin -h $leader_ip -p $leader_port batch_switch_rs_leader  $follower_ip:$follower_port;
'leader_count2 == 0'
'batch rs leader success'
'leader_count > 0'
ob1.sh ./etc/ob_admin -h $leader_ip -p $leader_port batch_switch_rs_leader;
'leader_count2 == 0'
'auto batch rs leader success'
