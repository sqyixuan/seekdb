ob1=OBI(cluster=2:2:2,proxy_num=0,init_unit_cpu=0);
ob1.reboot;
ob1.mysql alter system set enable_rebalance = 'False';
ob1.mysql alter system set enable_rereplication = 'False';
ob1.mysql alter system set enable_auto_leader_switch = 'False';
ob1.mysql alter system set resource_hard_limit = 800;
ob1.mysql alter resource pool $sys_pool unit_num 2;
ob1.mysql alter system major freeze;
ob1.check_version 2;
create table t1 (k int primary key, v int);
create table t2 (k int primary key, v int);
ob1.z2.obs0.force_stop;
ob1.z2.obs1.force_stop;
ob1.check_no_rebalance_task;
select count(*) from oceanbase.__all_virtual_meta_table where tenant_id = 1 and table_id = 1099511677777 and role = 1 and zone = 'z3';
count(*)
1
ob1.z2.obs0.start;
ob1.z2.obs1.start;
ob1.z3.obs0.force_stop;
ob1.z3.obs1.force_stop;
ob1.check_no_rebalance_task;
select count(*) from oceanbase.__all_virtual_meta_table where tenant_id = 1 and table_id = 1099511677778 and role = 1 and zone = 'z2';
count(*)
1
