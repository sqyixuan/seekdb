ob1=OBI(cluster=1:1:1:1:1, proxy_num = 0);
ob2=OBI(cluster=1, proxy_num = 0, leaderob=ob1);
ob1.z3.obs0.set status=disable;
ob1.z4.obs0.set status=disable;
ob1.z5.obs0.set status=disable;
ob1.reboot;
ob1.mysql alter system set balancer_idle_time = '10s';
ob1.mysql alter system set server_data_copy_out_concurrency = 10;
ob1.mysql alter system set server_data_copy_in_concurrency = 10;
ob1.mysql alter system set enable_auto_leader_switch = 'False';
ob2.reboot;
ob1.z1.obs0.switch_rs;
ob1.z1.obs0.check_leader sys:oceanbase:__all_core_table;
ob1.mysql create user 'u101' identified by 'pass1';
ob1.mysql grant select on *.* to 'u101';
ob1.mysql_p select * from oceanbase.v$database;
cluster_id	cluster_name	open_mode	cluster_role	switchover_status	current_scn	standby_became_primary_scn
