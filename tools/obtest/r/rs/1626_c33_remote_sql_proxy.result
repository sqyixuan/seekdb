ob1.z3.add;
ob1.z3.start_zone;
ob1.z3.obs0.set status=enable;
ob1.z3.obs0.start;
ob1.z3.obs0.add;
ob1.z4.add;
ob1.z4.start_zone;
ob1.z4.obs0.set status=enable;
ob1.z4.obs0.start;
ob1.z4.obs0.add;
ob1.check_until_timeout select count(*) from oceanbase.__all_server where status = 'active' and start_service_time > 0, 4, 260;
ob1.mysql alter system set enable_auto_leader_switch = 'true';
ob1.mysql create resource pool pl unit = 'sys_unit_config', zone_list = ('z3', 'z4'), unit_num = 1;
ob1.mysql alter tenant sys resource_pool_list = ('pl', 'sys_pool');
ob1.mysql alter tenant sys set locality = 'F@z1, f@z2, f@z3';
ob1.check_until_timeout select count(*) from oceanbase.__all_rootservice_job where job_type = "ALTER_TENANT_LOCALITY" and job_status = 'SUCCESS' and job_id = $job_id, 1,600;
ob1.z3.obs0.switch_rs;
ob1.mysql alter tenant sys set locality = 'F@z1, f@z3';
ob1.check_until_timeout select count(*) from oceanbase.__all_rootservice_job where job_type = "ALTER_TENANT_LOCALITY" and job_status = 'SUCCESS' and job_id = $job_id, 1,600;
