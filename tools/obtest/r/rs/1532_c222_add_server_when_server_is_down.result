ob1=OBI(cluster=2:2:2,proxy_num=0,init_unit_cpu=0,ct_num=0,locality=hz:hz:sh);
ob1.reboot;
ob1.mysql alter system set enable_auto_leader_switch = 'false';
ob1.mysql alter system set enable_rebalance = 'true';
ob1.mysql alter system set enable_rereplication = 'true';
ob1.mysql alter system set balancer_idle_time = '10s';
ob1.mysql alter system set server_permanent_offline_time = "25s";
ob1.mysql alter system delete server "$z3_obs1_ip:$z3_obs1_port";
ob1.check_until_timeout select count(*) from oceanbase.__all_server where svr_ip = "$z3_obs1_ip" and svr_port = "$z3_obs1_port", 0, 600;
ob1.z3.obs1.stop;
ob1.mysql alter system add server "$z3_obs1_ip:$z3_obs1_port";
ob1.check_until_timeout select count(*) c from oceanbase.__all_server where zone = '', 1, 10;
ob1.mysql alter system modify zone 'z1' idc 'hz';
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_server_clog_stat where zone = 'z1' and idc != 'hz', 0, 30;
