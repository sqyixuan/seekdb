ob1=OBI(cluster=3:3:3,proxy_num=1,init_unit_cpu=0);
ob1.reboot;
ob1.mysql alter system set balancer_idle_time = '10s';
ob1.mysql alter system set enable_rebalance = 'true';
ob1.mysql CREATE RESOURCE POOL sys_pool_2 UNIT = 'sys_unit_config', UNIT_NUM = 3, ZONE_LIST = ('z1', 'z2', 'z3');
ob1.mysql CREATE TENANT tt resource_pool_list=('sys_pool_2'), locality = 'F@z1,F@z2,F@z3' set ob_tcp_invited_nodes='%';
use test;
create tablegroup tg1 partition by range (partition p0 values less than(10), partition p1 values less than(20), partition p2 values less than(30));
create table t1(c1 int, c2 int, primary key(c1,c2)) tablegroup='tg1' partition by range(c1) (partition p0 values less than(10), partition p1 values less than(20), partition p2 values less than(30));
create table t2(c1 int, c2 int, primary key(c1,c2)) tablegroup='tg1' partition by range(c1) (partition p0 values less than(10), partition p1 values less than(20), partition p2 values less than(30));
create table t3(c1 int, c2 int, primary key(c1,c2)) tablegroup='tg1' partition by range(c1) (partition p0 values less than(10), partition p1 values less than(20), partition p2 values less than(30));
alter tablegroup tg1 add partition (partition p3 values less than(40), partition p4 values less than(50));
alter table t3 drop partition (p3);
ERROR HY000: add/drop table partition in 2.0 tablegroup not allowed
alter table t3 add partition (partition p3 values less than(40));
ERROR HY000: add/drop table partition in 2.0 tablegroup not allowed
alter tablegroup tg1 add partition (partition p5 values less than(60), partition p6 values less than(70));
create table r1(c1 int, c2 int, primary key(c1,c2)) tablegroup='tg1' partition by range(c1) (partition p0 values less than(10), partition p1 values less than(20), partition p2 values less than(30));
ERROR HY000: table partition option differ from tablegroup not allowed
create table r1(c1 int, c2 int, primary key(c1,c2)) tablegroup='tg1' partition by range(c1) (partition p0 values less than(10), partition p1 values less than(20), partition p2 values less than(30),partition p3 values less than(40),partition p4 values less than(50),partition p5 values less than(60), partition p6 values less than(70));
create table r2(c1 int, c2 int, primary key(c1,c2)) tablegroup='tg1' partition by range(c1) (partition p0 values less than(10), partition p1 values less than(20), partition p2 values less than(30),partition p3 values less than(40),partition p4 values less than(50),partition p5 values less than(60), partition p6 values less than(70));
create table r3(c1 int, c2 int, primary key(c1,c2)) tablegroup='tg1' partition by range(c1) (partition p0 values less than(10), partition p1 values less than(20), partition p2 values less than(30),partition p3 values less than(40),partition p4 values less than(50),partition p5 values less than(60), partition p6 values less than(70));
use oceanbase;
'after balanced'
ob1.check_until_timeout select COUNT(1) from __all_virtual_meta_table a, __all_virtual_table b WHERE a.table_id = b.table_id AND zone = 'z1' AND b.table_name in ('t1','t2','t3') AND INSTR(member_list, CONCAT(svr_ip, ':', svr_port)) > 0 AND a.partition_id = 4 GROUP BY a.unit_id order by a.partition_id, a.unit_id, b.table_name, a.zone, 3, 120;
ob1.check_until_timeout select COUNT(1) from __all_virtual_meta_table a, __all_virtual_table b WHERE a.table_id = b.table_id AND zone = 'z1' AND b.table_name in ('t1','t2','t3') AND INSTR(member_list, CONCAT(svr_ip, ':', svr_port)) > 0 AND a.partition_id = 5 GROUP BY a.unit_id order by a.partition_id, a.unit_id, b.table_name, a.zone, 3, 120;
ob1.check_until_timeout select COUNT(1) from __all_virtual_meta_table a, __all_virtual_table b WHERE a.table_id = b.table_id AND zone = 'z1' AND b.table_name in ('t1','t2','t3') AND INSTR(member_list, CONCAT(svr_ip, ':', svr_port)) > 0 AND a.partition_id = 6 GROUP BY a.unit_id order by a.partition_id, a.unit_id, b.table_name, a.zone, 3, 120;
ob1.check_until_timeout select COUNT(1) from __all_virtual_meta_table a, __all_virtual_table b WHERE a.table_id = b.table_id AND zone = 'z2' AND b.table_name in ('t1','t2','t3') AND INSTR(member_list, CONCAT(svr_ip, ':', svr_port)) > 0 AND a.partition_id = 4 GROUP BY a.unit_id order by a.partition_id, a.unit_id, b.table_name, a.zone, 3, 120;
ob1.check_until_timeout select COUNT(1) from __all_virtual_meta_table a, __all_virtual_table b WHERE a.table_id = b.table_id AND zone = 'z3' AND b.table_name in ('t1','t2','t3') AND INSTR(member_list, CONCAT(svr_ip, ':', svr_port)) > 0 AND a.partition_id = 4 GROUP BY a.unit_id order by a.partition_id, a.unit_id, b.table_name, a.zone, 3, 120;
ob1.check_until_timeout select COUNT(1) from __all_virtual_meta_table a, __all_virtual_table b WHERE a.table_id = b.table_id AND zone = 'z1' AND b.table_name in ('r1','r2','r3') AND INSTR(member_list, CONCAT(svr_ip, ':', svr_port)) > 0 AND a.partition_id = 4 AND b.table_name IN ('r1', 'r2', 'r3') GROUP BY a.unit_id order by a.partition_id, a.unit_id, b.table_name, a.zone, 3, 120;
ob1.check_until_timeout select COUNT(1) from __all_virtual_meta_table a, __all_virtual_table b WHERE a.table_id = b.table_id AND zone = 'z1' AND b.table_name in ('r1','r2','r3') AND INSTR(member_list, CONCAT(svr_ip, ':', svr_port)) > 0 AND a.partition_id = 5 AND b.table_name IN ('r1', 'r2', 'r3') GROUP BY a.unit_id order by a.partition_id, a.unit_id, b.table_name, a.zone, 3, 120;
ob1.check_until_timeout select COUNT(1) from __all_virtual_meta_table a, __all_virtual_table b WHERE a.table_id = b.table_id AND zone = 'z1' AND b.table_name in ('r1','r2','r3') AND INSTR(member_list, CONCAT(svr_ip, ':', svr_port)) > 0 AND a.partition_id = 6 AND b.table_name IN ('r1', 'r2', 'r3') GROUP BY a.unit_id order by a.partition_id, a.unit_id, b.table_name, a.zone, 3, 120;
