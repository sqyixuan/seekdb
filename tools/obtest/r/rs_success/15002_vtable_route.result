ob1=OBI(cluster=1:1:1,proxy_num=0);
ob1.z1.obs0.set extra_config=_enable_defensive_check=false,$extra_conf;
ob1.z2.obs0.set extra_config=_enable_defensive_check=false,$extra_conf;
ob1.z3.obs0.set extra_config=_enable_defensive_check=false,$extra_conf;
ob1.reboot;
ob1.mysql alter system set enable_rebalance='false';
ob1.mysql alter system set enable_rereplication='false';
CREATE RESOURCE UNIT unit_1 MAX_CPU 1, MEMORY_SIZE 1073741824, MAX_IOPS 100000, MIN_CPU=1, MIN_IOPS=1024;
CREATE RESOURCE POOL pool_1 UNIT = 'unit_1', ZONE_LIST = ('z1', 'z2'), UNIT_NUM = 1;
CREATE TENANT mysql RESOURCE_POOL_LIST = ('pool_1'), primary_zone='z1' set ob_tcp_invited_nodes='%';
ob1.check_until_timeout select count(*) as cnt from oceanbase.__all_virtual_server_schema_info as a join oceanbase.__all_virtual_server_schema_info as b on a.tenant_id = b.tenant_id where a.refreshed_schema_version != b.refreshed_schema_version and (a.svr_ip, a.svr_port) in ($addr_str) and (b.svr_ip, b.svr_port) in ($addr_str) and a.tenant_id in ($mysql_tenant_id, $mysql_tenant_id - 1), 0, 60;
CREATE RESOURCE UNIT unit_2 MAX_CPU 1, MEMORY_SIZE 1073741824, MAX_IOPS 100000, MIN_CPU=1, MIN_IOPS=1024;
CREATE RESOURCE POOL pool_2 UNIT = 'unit_2', ZONE_LIST = ('z1', 'z3'), UNIT_NUM = 1;
CREATE TENANT oracle RESOURCE_POOL_LIST = ('pool_2'), primary_zone='z1' set ob_tcp_invited_nodes='%', ob_compatibility_mode = 'oracle';
ob1.check_until_timeout select count(*) as cnt from oceanbase.__all_virtual_server_schema_info as a join oceanbase.__all_virtual_server_schema_info as b on a.tenant_id = b.tenant_id where a.refreshed_schema_version != b.refreshed_schema_version and (a.svr_ip, a.svr_port) in ($addr_str) and (b.svr_ip, b.svr_port) in ($addr_str) and a.tenant_id in ($oracle_tenant_id, $oracle_tenant_id - 1), 0, 60;
show create table oceanbase.__all_virtual_server_schema_info;
Table	Create Table
__all_virtual_server_schema_info	CREATE TABLE `__all_virtual_server_schema_info` (
  `svr_ip` varchar(46) NOT NULL,
  `svr_port` bigint(20) NOT NULL,
  `tenant_id` bigint(20) NOT NULL,
  `refreshed_schema_version` bigint(20) NOT NULL,
  `received_schema_version` bigint(20) NOT NULL,
  `schema_count` bigint(20) NOT NULL,
  `schema_size` bigint(20) NOT NULL,
  `min_sstable_schema_version` bigint(20) NOT NULL
) DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'none' REPLICA_NUM = 2 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 10
 partition by list columns(svr_ip, svr_port)
(partition p0 values in (DEFAULT))
show create table oceanbase.GV$OB_SERVER_SCHEMA_INFO;
View	Create View	character_set_client	collation_connection
GV$OB_SERVER_SCHEMA_INFO	CREATE VIEW `GV$OB_SERVER_SCHEMA_INFO` AS  SELECT   SVR_IP,   SVR_PORT,   TENANT_ID,   REFRESHED_SCHEMA_VERSION,   RECEIVED_SCHEMA_VERSION,   SCHEMA_COUNT,   SCHEMA_SIZE,   MIN_SSTABLE_SCHEMA_VERSION FROM   oceanbase.__all_virtual_server_schema_info 	utf8mb4	utf8mb4_general_ci
show create table oceanbase.V$OB_SERVER_SCHEMA_INFO;
View	Create View	character_set_client	collation_connection
V$OB_SERVER_SCHEMA_INFO	CREATE VIEW `V$OB_SERVER_SCHEMA_INFO` AS  SELECT * FROM   oceanbase.GV$OB_SERVER_SCHEMA_INFO WHERE   SVR_IP=HOST_IP() AND   SVR_PORT=RPC_PORT() 	utf8mb4	utf8mb4_general_ci
