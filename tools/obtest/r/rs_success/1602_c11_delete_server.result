ob1=OBI(cluster=1:1,proxy_num=0);
ob1.z1.obs0.set extra_config=_enable_defensive_check=false,$extra_conf;
ob1.z2.obs0.set extra_config=_enable_defensive_check=false,$extra_conf;
ob1.z2.obs0.set status=disable;
ob1.reboot;
alter system add zone "z2" ;
alter system start zone "z2";
ob1.z2.obs0.set status=enable;
ob1.z2.obs0.start;
ob1.z2.obs0.add;
ob1.check_until_timeout select count(*) from oceanbase.__all_server where zone = "z2" and status = "ACTIVE" and start_service_time > 0, 1, 60;
set @@session.ob_query_timeout = 1000000000;
CREATE RESOURCE UNIT unit_1 MAX_CPU 1, MAX_MEMORY 5073741824, MAX_IOPS 100000, MAX_DISK_SIZE 536870912, MAX_SESSION_NUM 64, MIN_CPU=1, MIN_MEMORY=5073741824, MIN_IOPS=128;
CREATE RESOURCE POOL pool_1 UNIT = 'unit_1', UNIT_NUM = 1;
CREATE TENANT mysql RESOURCE_POOL_LIST = ('pool_1'), primary_zone='z1' set ob_tcp_invited_nodes='%';
ob1.mysql alter system set  balancer_idle_time = '10s';
ob1.mysql alter system set replica_safe_remove_time = '60s';
ob1.check_until_timeout select count(*) from oceanbase.__all_ls_meta_table where tenant_id = 1009, 0, 100;
ob1.check_until_timeout select count(*) from oceanbase.__all_ls_meta_table where tenant_id = 1011, 0, 10;
ob1.mysql drop tenant mysql force;
ob1.mysql drop resource pool pool_1;
ob1.check_until_timeout select count(*) from oceanbase.__all_server where zone = "z2", 0, 300;
