ob1=OBI(cluster=1:1:1:1:1,proxy_num=1,init_unit_cpu=0,locality=HZ:HZ:HZ:SH:SH);
ob1.reboot;
CREATE RESOURCE UNIT tenant_config MAX_CPU 1, MAX_MEMORY 1073741824, MAX_IOPS 100000, MAX_DISK_SIZE 536870912, MAX_SESSION_NUM 64, MIN_CPU=1, MIN_MEMORY=1073741824, MIN_IOPS=128;
create resource pool tt1_pool unit = 'tenant_config', unit_num = 1, zone_list = ('z1','z2','z3','z4','z5');
create tenant tt1 resource_pool_list=('tt1_pool') set ob_tcp_invited_nodes='%';
