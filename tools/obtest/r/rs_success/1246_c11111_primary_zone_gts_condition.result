ERROR 0A000: tenant primary zone span regions when GTS is on not supported
create tenant tt1 resource_pool_list=('tt1_pool'), primary_zone = 'z1,z4' set ob_tcp_invited_nodes='%';
ERROR 0A000: tenant primary zone span regions when GTS is on not supported
set @@session.ob_query_timeout = 20000000;
create tenant tt1 resource_pool_list=('tt1_pool'), primary_zone = 'z1' set ob_tcp_invited_nodes='%';
alter tenant tt1 primary_zone='RANDOM';
