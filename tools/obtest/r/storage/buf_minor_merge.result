Table	Create Table
t0	CREATE TABLE `t0` (
  `a` int(11) DEFAULT NULL,
  `b` int(11) DEFAULT '1',
  KEY `i1` (`b`) BLOCK_SIZE 16384 GLOBAL
) DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 3 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0 TABLE_MODE = 'QUEUING'
