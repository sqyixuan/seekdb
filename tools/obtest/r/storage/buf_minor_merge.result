ob1=OBI(cluster=1:1:1,proxy_num=0,init_unit_cpu=2, init_unit_num=1);
ob1.reboot;
ob1.source include/merge.inc;
ob1.mysql alter system set enable_async_syslog=false;
use test;
create table t0(a int, b int default 1, index i1(b)) table_mode='queuing';
create table t1(a int);
ob1.mysql alter system set minor_compact_trigger = 10;
insert into t0(a) values(1);
insert into t1(a) values(1);
ob1.mysql alter system minor freeze tenant = sys;
ob1.mysql alter system minor freeze tenant = all_user;
ob1.mysql alter system minor freeze tenant = all_meta;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table_mgr where table_type=0 and is_active=0, 0, 120;
