ob1=OBI(cluster=1:1:1,proxy_num=0,init_unit_cpu=1,init_unit_num=1);
ob1.reboot;
ob1.mysql alter system set ofs_list='$ofs_list_3;z4@$ofs_url';
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_sys_parameter_stat where name='ofs_list' and value='$ofs_list_3;z4@$ofs_url', 3, 10000000;
ob1.mysql alter system add zone z4;
ob1.check_until_timeout select value from __all_zone where zone='z4' and name='status', 1, 10000000;
ob1.mysql alter system start zone z4;
ob1.check_until_timeout select value from __all_zone where zone='z4' and name='status', 2, 10000000;
ob1.mysql alter system stop zone z4;
ob1.check_until_timeout select value from __all_zone where zone='z4' and name='status', 1, 10000000;
ob1.mysql alter system delete zone z4;
ob1.check_until_timeout select count(*) from __all_zone where zone='z4', 0, 30000000;
ob1.mysql alter system set ofs_list='$ofs_list_3';
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_sys_parameter_stat where name='ofs_list' and value='$ofs_list_3', 3, 10000000;
