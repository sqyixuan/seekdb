ob1=OBI(cluster=1,proxy_num=0,init_unit_cpu=2, init_unit_num=1);
ob1.reboot;
ob1.source include/merge.inc;
ob1.mysql alter system set enable_async_syslog=false;
ob1.mysql alter system set minor_compact_trigger = 1;
use test;
create table t0(a int, b int default 1, index i1(b)) table_mode='queuing';
create table t1(a int);
insert into t0(a) values(1);
insert into t1(a) values(1);
show create table t0;
Table	Create Table
t0	CREATE TABLE `t0` (
  `a` int(11) DEFAULT NULL,
  `b` int(11) DEFAULT '1',
  KEY `i1` (`b`) BLOCK_SIZE 16384
) DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.0' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0 TABLE_MODE = 'QUEUING'
show create table t1;
Table	Create Table
t1	CREATE TABLE `t1` (
  `a` int(11) DEFAULT NULL
) DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.0' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
ob1.mysql_p select table_name, table_mode from oceanbase.__all_virtual_table where table_name in ('t0', 't1');
table_name	table_mode
t0	1
t1	0
ob1.mysql alter system minor freeze tenant = sys;
ob1.mysql alter system minor freeze tenant = all_user;
ob1.mysql alter system minor freeze tenant = all_meta;
