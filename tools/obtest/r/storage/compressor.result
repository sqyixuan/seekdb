ob1=OBI(cluster=1:1:1,proxy_num=0,init_unit_cpu=2, init_unit_num=1);
ob1.reboot;
ob1.mysql alter system set enable_async_syslog=false;
ob1.mysql alter system set debug_sync_timeout = '100000s';
use test;
create table t0(a int) compression= 'none';
create table t1(a int) compression= 'lz4_1.0';
create table t2(a int) compression= 'zstd_1.0';
create table t3(a int) compression= 'lz4_1.9.1';
create table t4(a int) compression= 'zstd_1.3.8';
create table t5(a int) compression= 'zlib_1.0';
create table t6(a int) compression= 'snappy_1.0';
insert into t0(a) values(1);
insert into t1(a) values(1);
insert into t2(a) values(1);
insert into t3(a) values(1);
insert into t4(a) values(1);
insert into t5(a) values(1);
insert into t6(a) values(1);
ob1.mysql alter system major freeze;
ob1.check_version 2;
