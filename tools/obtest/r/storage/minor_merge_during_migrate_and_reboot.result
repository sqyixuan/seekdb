$dst.force_stop;
$dst.nstart;
ob1.check_until_timeout select count(*) from oceanbase.__all_server where status='inactive', 0, 300;
ob1.check_until_timeout select count(*) from oceanbase.__all_server where start_service_time = 0, 0, 160;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_partition_store_info where table_id=$table_id, 3, 60;
