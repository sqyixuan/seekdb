ob1=OBI(cluster=1:1:1,proxy_num=0,init_unit_cpu=5);
ob1.reboot;
ob1.mysql alter system set enable_auto_leader_switch='false';
ob1.mysql alter system set debug_sync_timeout = '1000000s';
ob1.mysql alter system set minor_compact_trigger = 10;
ob1.mysql alter system set syslog_io_bandwidth_limit = '10G';
ob1.mysql alter system set fuse_row_cache_priority = 1000;
ob1.mysql create resource unit flashback_box max_cpu 2, max_memory 2073741824, max_iops 100000, max_disk_size '5G', max_session_num 64, MIN_CPU=1, MIN_MEMORY=2073741824, MIN_IOPS=128;
ob1.mysql create resource pool flashback_pool unit = 'flashback_box', unit_num = 1;
ob1.mysql create tenant oracle replica_num = 1, resource_pool_list=('flashback_pool') set ob_tcp_invited_nodes='%', ob_compatibility_mode='oracle';
ob1.mysql alter tenant oracle set variables autocommit='on';
create user obtest IDENTIFIED BY "obtest";
grant all on *.* to obtest WITH GRANT OPTION;
grant dba to obtest;
set global UNDO_RETENTION = 2;
create table t1 (c1 int primary key, c2 int, c3 int) primary_zone = 'z1';
insert into t1 values (1,1,1);
insert into t1 values (2,2,2);
insert into t1 values (3,3,3);
delete from t1 where c1 = 2;
select * from t1 where c1 = 0;
C1	C2	C3
ob1.mysql set ob_global_debug_sync = 'BEFORE_UPDATE_FREEZE_SNAPSHOT_INFO wait_for continue_signal';
ob1.mysql set ob_global_debug_sync = 'MINOR_MERGE_TIMER_TASK wait_for merge_signal';
ob1.mysql alter system major freeze;
delete from t1 where c1 > 1;
insert into t1 values (4,4,4);
update t1 set c2 = 10 where c1 = 1;
insert into t1 values (5,5,5);
update t1 set c3 = 10 where c1 = 1;
ob1.mysql alter system minor freeze tenant = sys;
ob1.mysql alter system minor freeze tenant = all_user;
ob1.mysql alter system minor freeze tenant = all_meta;
ob1.mysql set ob_global_debug_sync = 'now signal merge_signal';
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table_mgr where table_type = 0 and is_active = 0 and table_id = $tid, 0, 120;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table_mgr where table_type = 7 and table_id = $tid and svr_ip = "$ip" and svr_port = $port, 1, 120;
ob1.mysql set ob_global_debug_sync = 'now signal continue_signal';
ob1.check_version 2;
update t1 set c2 = 50 where c1 = 5;
ob1.mysql alter system minor freeze tenant = sys;
ob1.mysql alter system minor freeze tenant = all_user;
ob1.mysql alter system minor freeze tenant = all_meta;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table_mgr where table_type = 0 and is_active = 0 and table_id = $tid, 0, 120;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table_mgr where table_type = 7 and table_id = $tid and svr_ip = "$ip" and svr_port = $port, 2, 120;
select * from t1;
