ob1=OBI(cluster=2:2:2,proxy_num=0,init_unit_cpu=2);
ob1.reboot;
ob1.mysql alter system set merger_check_interval='10s';
ob1.mysql alter system set enable_rebalance = 'false';
ob1.mysql alter system set enable_auto_leader_switch=false;
ob1.mysql alter system set resource_hard_limit=500;
ob1.mysql alter resource pool obtestpool unit_num 2;
ob1.mysql alter system major freeze;
ob1.check_version 2;
ob1.mysql alter system set minor_compact_trigger = 1;
ob1.mysql alter system minor freeze tenant = sys;
ob1.mysql alter system minor freeze tenant = all_user;
ob1.mysql alter system minor freeze tenant = all_meta;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table_mgr where table_id=$table_id and table_type=10, 3, 300;
$src.migrate_to $dst,obtest:test:test01;
ob1.check_until_timeout select value4 from __all_rootservice_event_history where module='balancer' and event = 'finish_migrate_replica' and value1 like "%$table_id%" and value3 like '%$dst_ip:$dst_port%', 0, 30;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_meta_table where tenant_id=$tenant_id and table_id=$table_id and role=1 and member_list like '%$dst_ip:$dst_port%', 1, 60;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_meta_table a, oceanbase.__all_virtual_meta_table b where a.tenant_id=$tenant_id and a.table_id=$table_id and b.table_id=$table_id and a.member_list=b.member_list and a.role=1 and b.role=2 and b.svr_ip='$dst_ip' and b.svr_port='$dst_port', 1, 20;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table_mgr where table_id=$table_id and svr_ip='$src_ip' and svr_port=$svr_port, 0, 60;
$dst.migrate_to $src,obtest:test:test01;
ob1.check_until_timeout select value4 from __all_rootservice_event_history where module='balancer' and event = 'finish_migrate_replica' and value1 like "%$table_id%" and value3 like '%$src_ip:$src_port%', 0, 30;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_meta_table where tenant_id=$tenant_id and table_id=$table_id and role=1 and member_list like '%$src_ip:$src_port%', 1, 60;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_meta_table a, oceanbase.__all_virtual_meta_table b where a.tenant_id=$tenant_id and a.table_id=$table_id and b.table_id=$table_id and a.member_list=b.member_list and a.role=1 and b.role=2 and b.svr_ip='$src_ip' and b.svr_port='$src_port', 1, 20;
ob1.mysql alter system major freeze;
ob1.check_version 3;
