ob1=OBI(cluster=1:1:1,proxy_num=0,init_unit_cpu=2, init_unit_num=1);
ob1.reboot;
ob1.mysql alter system set enable_async_syslog=false;
ob1.mysql alter system set debug_sync_timeout = '100000s';
set global max_allowed_packet=50000000;
use test;
ALTER INSTANCE ROTATE INNODB MASTER KEY;
create tablespace ts1 encryption = 'y';
create table t1 (id1 int, id2 int) tablespace ts1;
insert into t1 values(1, 2);
create table t2(id1 int primary key, id2 longtext, id3 longtext) tablespace ts1;
insert into t2 values(3, repeat('a', 1000000), repeat('a', 1000000));
insert into t2 values(4, repeat('c', 1000000), repeat('d', 1000000));
ob1.mysql alter system major freeze;
ob1.check_version 2;
use test;
select * from t1;
id1	id2
1	2
select id1, length(id2), substr(id3,1,10) from t2;
id1	length(id2)	substr(id3,1,10)
3	1000000	aaaaaaaaaa
4	1000000	dddddddddd
ALTER INSTANCE ROTATE INNODB MASTER KEY;
insert into t1 values(3, 4);
insert into t2 values(5, repeat('f', 1000000), repeat('g', 1000000));
ob1.mysql alter system major freeze;
ob1.check_version 3;
select * from t1;
id1	id2
1	2
3	4
select id1, length(id2), substr(id3,1,10) from t2;
id1	length(id2)	substr(id3,1,10)
3	1000000	aaaaaaaaaa
4	1000000	dddddddddd
5	1000000	gggggggggg
create table test01 (pk1 int, pk2 int, pk3 int, f1 varchar(1024), f2 varchar(4096), primary key(pk1,pk2,pk3)) tablespace ts1;
insert into test01 values(1, 1, 1, 'ocean', 'base');
insert into test01 values(2, 2, 2, 'ocean', 'base');
insert into test01 values(3, 3, 3, 'ocean', 'base');
insert into test01 values(4, 4, 4, 'ocean', 'base');
insert into test01 values(5, 5, 5, 'ocean', 'base');
insert into test01 values(6, 6, 6, 'ocean', 'base');
insert into test01 values(7, 7, 7, 'ocean', 'base');
insert into test01 values(8, 8, 8, 'ocean', 'base');
insert into test01 values(9, 9, 9, 'ocean', 'base');
ob1.mysql alter system minor freeze tenant obtest;
ob1.check_until_timeout select count(1) from __all_virtual_table_mgr where table_id=$tid and table_type=0, 3, 120;
select * from test.test01;
pk1	pk2	pk3	f1	f2
1	1	1	ocean	base
2	2	2	ocean	base
3	3	3	ocean	base
4	4	4	ocean	base
5	5	5	ocean	base
6	6	6	ocean	base
7	7	7	ocean	base
8	8	8	ocean	base
9	9	9	ocean	base
