ob1=OBI(cluster=1:1:2,proxy_num=1,init_unit_cpu=2,init_unit_mem=805306368);
ob1.z1.obs0.set extra_config=$mini_ob_config;
ob1.z1.obs1.set extra_config=$mini_ob_config;
ob1.z2.obs0.set extra_config=$mini_ob_config;
ob1.z2.obs1.set extra_config=$mini_ob_config;
ob1.reboot;
ob1.mysql alter system set merger_switch_leader_duration_time = '10s';
ob1.mysql alter system set resource_hard_limit= 1600;
ob1.source include/merge.inc;
ob1.source include/migrate.inc;
set @@session.ob_query_timeout = 20000000;
ob1.check_until_timeout select count(*) as cnt from oceanbase.__all_virtual_server_stat where start_service_time = 0, 0, 60;
create resource unit box1 max_cpu 2, max_memory = '768M' , max_iops 100000, max_disk_size '5G', max_session_num 64, MIN_CPU=1, MIN_MEMORY='768M', MIN_IOPS=128;
create resource pool pool1 unit = 'box1', unit_num = 1;
create tenant oracle replica_num = 1, resource_pool_list=('pool1'), primary_zone="z1;z2" set ob_tcp_invited_nodes='%', ob_compatibility_mode='oracle', autocommit='on';
set @@session.ob_query_timeout = 10000000;
ob1.check_until_timeout select count(*) as cnt from oceanbase.__all_virtual_server_schema_info as a join oceanbase.__all_virtual_server_schema_info as b on a.tenant_id = b.tenant_id  where a.refreshed_schema_version != b.refreshed_schema_version, 0, 10;
create user obtest IDENTIFIED BY obtest;
grant all on *.* to obtest WITH GRANT OPTION;
grant dba to obtest;
ob1.check_until_timeout select count(*) as cnt from oceanbase.__all_virtual_server_schema_info as a join oceanbase.__all_virtual_server_schema_info as b on a.tenant_id = b.tenant_id  where a.refreshed_schema_version != b.refreshed_schema_version, 0, 10;
create table t1(pk int primary key, c1 number);
insert into t1 values(1,1),(2,2);
delete from t1 where pk=1;
select * from t1;
PK	C1
2	2
ob1.mysql alter system minor freeze tenant = sys;
ob1.mysql alter system minor freeze tenant = all_user;
ob1.mysql alter system minor freeze tenant = all_meta;
ob1.check_until_timeout select count(1) from __all_virtual_memstore_info where is_active=0, 0, 120;
create table t2(pk int primary key, c1 number);
insert into t2 values(1,1),(2,2);
delete from t2 where pk=1;
select * from t2;
PK	C1
2	2
ob1.mysql alter system major freeze;
ob1.check_until_timeout select count(*) from __all_zone where name = 'merge_status' and zone = '' and info = 'IDLE', 1, 480;
select * from t1;
PK	C1
2	2
select * from t2;
PK	C1
2	2
ob1.z3.migrate_unit $unit_id;
ob1.check_no_migrate_unit 240;
