ob1=OBI(cluster=1:1:1,proxy_num=0,init_unit_cpu=2);
ob1.reboot;
ob1.mysql alter system set merger_check_interval='10s';
ob1.mysql alter system set enable_rebalance = 'false';
ob1.mysql alter system set resource_hard_limit=500;
ob1.mysql CREATE RESOURCE UNIT obstress MAX_CPU=2, MIN_CPU=2, MIN_MEMORY='10G', MAX_MEMORY='10G', MAX_DISK_SIZE='100G', MAX_IOPS=10000, MAX_SESSION_NUM=9223372036854775807;
ob1.mysql CREATE RESOURCE POOL pool_obstress0 unit='obstress', unit_num=1;
ob1.mysql CREATE TENANT obstress0 RESOURCE_POOL_LIST=('pool_obstress0'), locality = "F{1,memstore_percent:100}@z1,F{1,memstore_percent:0}@z2,L@z3" set ob_tcp_invited_nodes='%';
