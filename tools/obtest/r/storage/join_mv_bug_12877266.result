ob1=OBI(cluster=2:2:2,proxy_num=0,init_unit_cpu=0);
ob1.reboot;
ob1.mysql create resource unit box1 max_cpu 5, max_memory 1080000000, max_iops 100000, max_disk_size 1080000000, max_session_num 64, MIN_CPU 5, MIN_MEMORY=1080000000, MIN_IOPS=128;
ob1.mysql create resource pool pool_largex unit = 'box1', unit_num = 2, zone_list = ('z1', 'z2', 'z3');
ob1.mysql create tenant tt replica_num = 3, primary_zone='z1,z2', resource_pool_list=('pool_largex'), locality = "F@z1,F@z2,L@z3" set ob_tcp_invited_nodes='%';
create table l (lk1 int, lk2 int, lk3 int , lv1 int, lv2 varchar(512), primary key(lk1, lk2, lk3)) compression = 'none' locality = 'F,R{all_server}@z1,F,R{all_server}@z2,L,R{all_server}@z3';
create table r (rk int, rv1 int, rv2 varchar(512), primary key(rk)) locality = 'F,R{all_server}@z1,F,R{all_server}@z2,L,R{all_server}@z3';
create materialized view mv as select lk1, lk2, lk3, lv1, lv2, rk, rv1, rv2 from l, r where lk2 = rk order by lk1, lv1;
ob1.mysql alter system major freeze;
ob1.check_version 2;
ob1.mysql_p select index_status from oceanbase.__all_virtual_table where table_id = $mvid;
index_status
5
