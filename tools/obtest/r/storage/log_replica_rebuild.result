ob1=OBI(cluster=1:1:1,proxy_num=1,init_unit_cpu=4);
ob1.reboot;
ob1.mysql alter tenant sys set locality = 'F@z1,F@z2,L@z3';
ob1.mysql alter system set balancer_idle_time = '10s';
ob1.check_until_timeout select rebuild from oceanbase.__all_tenant_meta_table where tenant_id=$tenant_id and table_id=$table_id and replica_type=5, 0, 60;
ob1.check_until_timeout select value4 from __all_rootservice_event_history where module = 'balancer' and event like '%finish%' and value1 like '%$table_id%', 0, 60;
