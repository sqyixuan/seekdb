ob1=OBI(cluster=1:1:2,proxy_num=1,init_unit_cpu=5);
ob1.reboot;
ob1.create_client;
ob1.mysql alter system set resource_hard_limit = 500;
ob1.mysql alter system set enable_auto_leader_switch = false;
ob1.mysql alter system set merger_check_interval = '10s';
ob1.mysql alter system set server_permanent_offline_time = '20s';
ob1.mysql alter system set debug_sync_timeout = '100000s';
ob1.check_until_timeout select count(*) as cnt from oceanbase.__all_virtual_server_stat where start_service_time = 0, 0, 60;
pk1	pk2	pk3	f1	f2
1	1	1	ocean	base
2	2	2	ocean	base
3	3	3	ocean	base
4	4	4	ocean	base
5	5	5	ocean	base
6	6	6	ocean	base
7	7	7	ocean	base
8	8	8	ocean	base
9	9	9	ocean	base
ob1.mysql set ob_global_debug_sync = 'FAST_MIGRATE_AFTER_SUSPEND_SRC wait_for signal_1';
ob1.mysql alter system delete server '$src_host';
$src.force_stop;
ob1.mysql set ob_global_debug_sync = 'now signal signal_1';
ob1.check_until_timeout select count(*) from __all_rootservice_event_history where module = 'server_fast_recovery' and value1 like '%$src_host%' and event = 'finish_recovery', 1, 480;
recover success, 1
ob1.mysql alter system switch replica leader partition_id='0%0@$table_id' server='$final_host';
$final_obs.check_leader obtest:test:test01;
