ob1=OBI(cluster=1:1:1, proxy_num=0,init_unit_cpu=5);
ob1.reboot;
ob1.mysql alter system set resource_hard_limit = 800;
ob1.mysql alter system set merger_switch_leader_duration_time=0;
ob1.mysql alter system set enable_auto_leader_switch = false;
ob1.mysql alter system set enable_rebalance=false;
ob1.mysql alter system set enable_rereplication=false;
ob1.mysql alter system set debug_sync_timeout = '100000s';
create table test01(c1 int, c2 int, c3 varchar(4096), c4 int, c5 int, c6 double, c7 int, c8 varchar(512), c9 int, c10 float, primary key(c1)) primary_zone='z1';
ob1.mysql alter system switch replica leader partition_id='0%0@$tid' server='$z2_ip:$z2_port';
ob1.check_until_timeout select count(1) from __all_virtual_meta_table where svr_ip = '$z2_ip' and svr_port = $z2_port and table_id = $tid and member_list like "%$z2_host%" and role = 1, 1, 60;
alter table test01 add column c11 double;
ob1.mysql alter system minor freeze tenant = sys;
ob1.mysql alter system minor freeze tenant = all_user;
ob1.mysql alter system minor freeze tenant = all_meta;
ob1.check_until_timeout select count(1) from oceanbase.__all_virtual_table_mgr where table_id = $tid and table_type = 0 and is_active = 0, 0, 300;
ob1.mysql alter system switch replica leader partition_id='0%0@$tid' server='$z3_ip:$z3_port';
ob1.check_until_timeout select count(1) from __all_virtual_meta_table where svr_ip = '$z3_ip' and svr_port = $z3_port and table_id = $tid and member_list like "%$z3_host%" and role = 1, 1, 60;
alter table test01 drop column c7;
ob1.mysql alter system minor freeze tenant = sys;
ob1.mysql alter system minor freeze tenant = all_user;
ob1.mysql alter system minor freeze tenant = all_meta;
ob1.check_until_timeout select count(1) from oceanbase.__all_virtual_table_mgr where table_id = $tid and table_type = 0 and is_active = 0, 0, 300;
drop table test01;
