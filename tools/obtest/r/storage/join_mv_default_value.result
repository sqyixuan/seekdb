ob1=OBI(cluster=1,proxy_num=0,init_unit_cpu=0);
ob1.reboot;
create table l (lk1 int, lk2 int, lv1 int, lv2 varchar(128), primary key(lk1, lk2)) partition by key (lk1) partitions 2;
create table r (rk int, rv1 int, rv2 varchar(128), primary key(rk)) locality = 'F@z1, R{all_server}@z1';
insert into l values (1, 1, 10, 'aaaaaaa');
insert into l values (1, 2, 20, 'bbbbbbb');
insert into r values (1, 100, 'right value1');
insert into r values (2, 200, 'right value1');
insert into r values (3, 300, 'right value1');
alter system major freeze;
ob1.check_version 2;
alter table l add column lv3 int default 1;
alter table r add column rv3 int default 8;
create materialized view mv as select lk1, lk2, lv1, lv2, lv3, rk, rv1, rv2, rv3 from l, r where lk2 = rk order by lk1, lv1;
alter system major freeze;
ob1.check_version 3;
ob1.check_until_timeout select index_status from oceanbase.__all_virtual_table where tenant_id=1 and table_name = 'mv', 2, 100;
select * from mv;
lk1	lv1	lk2	rk	lv2	lv3	rv1	rv2	rv3
1	10	1	1	aaaaaaa	1	100	right value1	8
1	20	2	2	bbbbbbb	1	200	right value1	8
insert into l values (1, 3, 30, 'ccccc', 13);
update r set rv3 = 82 where rk = 2;
select * from mv;
lk1	lv1	lk2	rk	lv2	lv3	rv1	rv2	rv3
1	10	1	1	aaaaaaa	1	100	right value1	8
1	20	2	2	bbbbbbb	1	200	right value1	82
1	30	3	3	ccccc	13	300	right value1	8
alter system major freeze;
ob1.check_version 4;
select * from mv;
lk1	lv1	lk2	rk	lv2	lv3	rv1	rv2	rv3
1	10	1	1	aaaaaaa	1	100	right value1	8
1	20	2	2	bbbbbbb	1	200	right value1	82
1	30	3	3	ccccc	13	300	right value1	8
