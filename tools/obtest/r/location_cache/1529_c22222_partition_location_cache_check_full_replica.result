case 2.3: move F replica
ob1.mysql CREATE TENANT tenant_6 RESOURCE_POOL_LIST = ('pool_1'), primary_zone = 'z3;z4;z1,z2;z5',locality='F{1},R{1}@z1,F{1}@z2,F{1},R{1}@z3,F{1},R{1}@z4,F{1}@z5' set ob_tcp_invited_nodes='%';
