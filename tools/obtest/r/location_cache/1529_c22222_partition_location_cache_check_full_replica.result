ob1.check_until_timeout select count(*) as c from oceanbase.__all_rootservice_job where job_id = "$last_job_id" and job_type = "ALTER_TENANT_LOCALITY" and job_status = "SUCCESS", 1, 120;
ob1.mysql alter system move replica partition_id = "0%0@$t1_id" source = "$src_addr" destination = "$dest_addr";
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_meta_table where tenant_id = "$tenant_id" and table_id = "$t1_id" and partition_id = 0 and replica_type = 0 and concat(svr_ip, ":", svr_port) = "$src_addr", 0, 10;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_meta_table where tenant_id = "$tenant_id" and table_id = "$t1_id" and partition_id = 0 and replica_type = 0 and concat(svr_ip, ":", svr_port) = "$dest_addr", 1, 10;
