ob1=OBI(cluster=2:2:2,proxy_num=1);
ob1.reboot;
SET GLOBAL recyclebin = 0;
ob1.mysql alter system set _ss_deleted_tablet_gc_time = '5s' tenant sys;
ob1.mysql CREATE RESOURCE UNIT gc_test_unit_1 MAX_CPU 1, MEMORY_SIZE '2G', DATA_DISK_SIZE = '2G';
ob1.mysql CREATE RESOURCE POOL gc_test_resource_pool_1 UNIT gc_test_unit_1, UNIT_NUM 2, ZONE_LIST = ('z1', 'z2');
ob1.mysql CREATE TENANT gc_tenant_1 primary_zone = 'z1', resource_pool_list=('gc_test_resource_pool_1') set ob_tcp_invited_nodes = '%';
create table t_gc_1(c1 bigint, c2 longtext, c3 longtext, c4 varchar(1024));
insert /*+ query_timeout(100000000000) parallel(32) enable_parallel_dml */ into t_gc_1 select random() c1, randstr(1024, random()) c2, randstr(1024,random()) c3, randstr(1024,random()) c4 from table(generator(100000));
drop table t_gc_1;
ob1.z1.obs0.check_tablet_exists $svr_ip, $tenant_id, $server_id, $tablet_id, $local_dir, private;
non_exist
tablet gc finished;
DROP TENANT gc_tenant_1 FORCE;
ob1.z1.obs0.check_tenant_dir_exists $svr_ip, $tenant_id, $server_id, $local_dir, private;
non_exist
ob1.z1.obs0.check_tenant_dir_exists $endpoint, $tenant_id, $server_id, $oss_location, private;
no directory found
ob1.z1.obs0.check_tenant_dir_exists $endpoint, $tenant_id, $server_id, $oss_location, public;
tenant non_exist
