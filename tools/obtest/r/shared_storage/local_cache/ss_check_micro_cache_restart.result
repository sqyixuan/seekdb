ob1=OBI(cluster=1, proxy_num=0, init_unit_cpu=2);
ob1.reboot;
ob1.mysql alter system set ob_compaction_schedule_interval = '10s' tenant sys;
ob1.mysql alter system set ob_compaction_schedule_interval = '10s' tenant all_user;
ob1.mysql alter system set ob_compaction_schedule_interval = '10s' tenant all_meta;
ob1.mysql alter system set merger_check_interval = '10s' tenant sys;
ob1.mysql alter system set merger_check_interval = '10s' tenant all_user;
ob1.mysql alter system set merger_check_interval = '10s' tenant all_meta;
ob1.mysql alter system set _ss_major_compaction_prewarm_level = 0 tenant sys;
ob1.mysql alter system set _ss_major_compaction_prewarm_level = 0 tenant all_user;
ob1.mysql alter system set _ss_major_compaction_prewarm_level = 0 tenant all_meta;
ob1.mysql alter system set major_freeze_duty_time = 'Disable' tenant sys;
ob1.mysql alter system set major_freeze_duty_time = 'Disable' tenant all_user;
ob1.mysql alter system set major_freeze_duty_time = 'Disable' tenant all_meta;
ob1.check_until_timeout select $ori_used_disk_size > 0, 1, 60;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_ss_local_cache_info where tenant_id = $tenant_id and cache_name = 'ss_micro_cache' and used_mem_size = 0, 1, 60;
create table t1(c1 int, c2 int, c3 varchar(40960), c4 varchar(40960)) compression= 'none';
ob1.mysql alter system major freeze tenant = 'obtest';
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where LAST_SCN != GLOBAL_BROADCAST_SCN , 1, 100;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_ss_local_cache_info where tenant_id = $tenant_id and cache_name = 'ss_micro_cache' and used_mem_size > 0, 1, 60;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_ss_local_cache_info where tenant_id = $tenant_id and cache_name = 'ss_micro_cache' and used_disk_size > $ori_used_disk_size, 1, 60;
ob1.obs0.restart;
ob1.mysql alter system set ob_compaction_schedule_interval = '10s' tenant sys;
ob1.mysql alter system set ob_compaction_schedule_interval = '10s' tenant all_user;
ob1.mysql alter system set ob_compaction_schedule_interval = '10s' tenant all_meta;
ob1.mysql alter system set merger_check_interval = '10s' tenant sys;
ob1.mysql alter system set merger_check_interval = '10s' tenant all_user;
ob1.mysql alter system set merger_check_interval = '10s' tenant all_meta;
ob1.mysql alter system set _ss_major_compaction_prewarm_level = 0 tenant sys;
ob1.mysql alter system set _ss_major_compaction_prewarm_level = 0 tenant all_user;
ob1.mysql alter system set _ss_major_compaction_prewarm_level = 0 tenant all_meta;
ob1.check_until_timeout select $cur_used_mem_size > 0, 1, 60;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_ss_local_cache_info where tenant_id = $tenant_id and cache_name = 'ss_micro_cache' and used_disk_size > $ori_used_disk_size, 1, 60;
ob1.mysql alter system major freeze tenant = 'obtest';
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where LAST_SCN != GLOBAL_BROADCAST_SCN , 1, 100;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_ss_local_cache_info where tenant_id = $tenant_id and cache_name = 'ss_micro_cache' and used_mem_size > $cur_used_mem_size, 1, 60;
ob1.obs0.restart;
ob1.mysql alter system set ob_compaction_schedule_interval = '10s' tenant sys;
ob1.mysql alter system set ob_compaction_schedule_interval = '10s' tenant all_user;
ob1.mysql alter system set ob_compaction_schedule_interval = '10s' tenant all_meta;
ob1.mysql alter system set merger_check_interval = '10s' tenant sys;
ob1.mysql alter system set merger_check_interval = '10s' tenant all_user;
ob1.mysql alter system set merger_check_interval = '10s' tenant all_meta;
ob1.mysql alter system set _ss_major_compaction_prewarm_level = 0 tenant sys;
ob1.mysql alter system set _ss_major_compaction_prewarm_level = 0 tenant all_user;
ob1.mysql alter system set _ss_major_compaction_prewarm_level = 0 tenant all_meta;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_ss_local_cache_info where tenant_id = $tenant_id and cache_name = 'ss_micro_cache' and used_mem_size > 0, 1, 60;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_ss_local_cache_info where tenant_id = $tenant_id and cache_name = 'ss_micro_cache' and used_disk_size > $ori_used_disk_size, 1, 60;
