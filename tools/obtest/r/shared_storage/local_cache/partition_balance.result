##
# 5.2. all local index and aux lob tables are bound to primary table
ob1.check_until_timeout select count(*) > 0 from ($all_user_tablets) as A join ($all_binding_tablets) as B on A.table_id = B.data_table_id and A.partition_name = B.partition_name and A.subpartition_name = B.subpartition_name and A.ls_id = B.ls_id, 1, 1;
ob1.check_until_timeout select count(*) from ($all_user_tablets) as A join ($all_binding_tablets) as B on A.table_id = B.data_table_id and A.partition_name = B.partition_name and A.subpartition_name = B.subpartition_name and A.ls_id != B.ls_id, 0, 1;
##
# 5.3. specially, the global index of a non-partitioned table is actually a local index
ob1.check_until_timeout select count(distinct(ls_id)) from CDB_OB_TABLE_LOCATIONS where tenant_id = $mysql_tenant_id and (table_name = 't_nonpart_2' or index_name = 'global_index_t_nonpart_2_c2'), 1, 1;
ob1.check_until_timeout select count(distinct(ls_id)) from CDB_OB_TABLE_LOCATIONS where tenant_id = $mysql_tenant_id and (table_name = 't_nonpart_in_tg_none_2' or index_name = 'global_index_t_nonpart_in_tg_none_2_c2'), 1, 1;
ob1.mysql set ob_global_debug_sync = 'now signal signal_balance';
drop tenants
set recyclebin = off;
drop tenant mysql force;
ob1.check_until_timeout select count(*) from GV\$OB_UNITS where tenant_id != 1, 0, 120;
===============================================================
================= test partition rebalance ====================
===============================================================
# wait unit gc for dropped tenant
ob1.check_until_timeout select count(*) from GV\$OB_UNITS where tenant_id != 1, 0, 120;
# create mysql tenant
CREATE RESOURCE UNIT if not exists unit_1 MAX_CPU 2, MEMORY_SIZE='4G';
Warnings:
Note	4649	resource unit 'unit_1' already exist
CREATE RESOURCE POOL if not exists pool_1 UNIT = 'unit_1', UNIT_NUM = 1;
Warnings:
Note	4651	resource pool 'pool_1' exist
CREATE TENANT mysql RESOURCE_POOL_LIST = ('pool_1'), primary_zone='z1,z2,z3', locality="F@z1,F@z2,F@z3" set ob_tcp_invited_nodes='%';
################################################
# 1. prepare data
# create tablegroup
create tablegroup tg_none sharding = 'NONE';
create tablegroup tg_part sharding = 'PARTITION';
create tablegroup tg_adapt_one sharding = 'ADAPTIVE';
create tablegroup tg_adapt_two sharding = 'ADAPTIVE';
# create table
ob1.mysql set ob_global_debug_sync = 'BEFORE_TENANT_BALANCE_SERVICE wait_for signal_balance';
create table t_nonpart_1(c1 int, c2 int, c3 longtext, index(c1) local, index(c2) global);
create table t_part_1(c1 int, c2 int, c3 longtext, index(c1) local, index(c2) global) partition by hash(c1) partitions 3;
create table t_subpart_1(c1 int, c2 int, c3 longtext, index(c1) local, index(c2) global) partition by hash(c1) partitions 3 subpartition by hash(c2) subpartitions 3;
create table t_subpart_2(c1 int, c2 int, c3 longtext, index(c1) local, index(c2) global) partition by hash(c1) partitions 3 subpartition by hash(c2) subpartitions 3;
ob1.mysql set ob_global_debug_sync = 'now signal signal_balance';
select distinct table_id, table_name, partition_name, subpartition_name, tablet_id, ls_id from CDB_OB_TABLE_LOCATIONS where tenant_id = 1004 and table_type = 'USER TABLE' order by table_id, tablet_id;
table_id	table_name	partition_name	subpartition_name	tablet_id	ls_id
