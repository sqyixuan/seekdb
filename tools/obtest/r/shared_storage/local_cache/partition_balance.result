# 2. test tablegroup
alter table t_nonpart_1 tablegroup tg_none;
alter table t_part_1 tablegroup tg_none;
alter table t_subpart_1 tablegroup tg_none;
alter table t_subpart_2 tablegroup tg_none;
ob1.mysql alter system set partition_balance_schedule_interval = '10s' tenant mysql;
ob1.check_until_timeout select count(distinct(ls_id)) from CDB_OB_TABLE_LOCATIONS where tenant_id = $mysql_tenant_id and table_type = 'USER TABLE', 1, 120;
