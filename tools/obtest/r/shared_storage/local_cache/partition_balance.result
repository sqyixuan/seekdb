ob1=OBI(cluster=1:1:1,proxy_num=0);
ob1.z1.obs0.set extra_config=$extra_conf;
ob1.z2.obs0.set extra_config=$extra_conf;
ob1.z3.obs0.set extra_config=$extra_conf;
ob1.reboot;
ob1.mysql alter system set enable_rebalance='false';
ob1.mysql alter system set _transfer_start_trans_timeout = '10s';
set @@session.ob_query_timeout = 1000000000;
alter system set debug_sync_timeout = '1000s';
===============================================================
============== test create tablet distribution ================
===============================================================
set @@session.ob_query_timeout = 1000000000;
alter system set debug_sync_timeout = '1000s';
# create mysql tenant
CREATE RESOURCE UNIT if not exists unit_1 MAX_CPU 2, MEMORY_SIZE='4G';
CREATE RESOURCE POOL if not exists pool_1 UNIT = 'unit_1', UNIT_NUM = 1;
CREATE TENANT mysql RESOURCE_POOL_LIST = ('pool_1'), primary_zone='z1,z2,z3', locality="F@z1,F@z2,F@z3" set ob_tcp_invited_nodes='%';
################################################
# 1. create tablet without tablegroup
ob1.mysql set ob_global_debug_sync = 'BEFORE_TENANT_BALANCE_SERVICE wait_for signal_balance';
# nonpart table
create table t_nonpart_1(c1 int, c2 int, c3 longtext, index(c1) local, index(c2) global);
create table t_nonpart_2(c1 int, c2 int, c3 longtext);
create index local_index_t_nonpart_2_c1 on t_nonpart_2(c1);
create index global_index_t_nonpart_2_c2 on t_nonpart_2(c2) global;
create table t_nonpart_3(c1 int, c2 int, c3 longtext);
create index local_index_t_nonpart_3_c1 on t_nonpart_3(c1);
create unique index unique_global_index_t_nonpart_3_c2 on t_nonpart_3(c2) global partition by hash(c2) partitions 2;
# part table
create table t_part_1(c1 int, c2 int, c3 longtext, index(c1) local, index(c2) global) partition by hash(c1) partitions 3;
create table t_part_2 (c1 int, c2 int, c3 longtext, index(c1) local, index(c2) global) partition by range(c1) (partition p0 values less than (100), partition p1 values less than (200));
create table t_part_3(c1 int, c2 int, c3 longtext) partition by hash(c1) partitions 3;
create index local_index_t_part_3_c1 on t_part_3(c1);
create unique index unique_global_index_t_part_3_c2 on t_part_3(c2) global partition by hash(c2) partitions 2;
create table t_part_4 like t_part_1;
# subpart table
set session _ENABLE_PARALLEL_DDL = 0;
create table t_subpart_1(c1 int, c2 int, c3 longtext, index(c1) local, index(c2) global) partition by range(c1) subpartition by hash(c1) subpartitions 3 (partition p1 values less than (100), partition p2 values less than (200), partition p3 values less than MAXVALUE);
create table t_subpart_2(c1 int, c2 int, c3 longtext) partition by range(c1) subpartition by hash(c1) subpartitions 3 (partition p1 values less than (100), partition p2 values less than (200), partition p3 values less than (300));
create index local_index_t_subpart_2_c1 on t_subpart_2(c1);
create index global_index_t_subpart_2_c2 on t_subpart_2(c2) global partition by hash(c2) partitions 2;
set session _ENABLE_PARALLEL_DDL = 1;
alter table t_part_2 add partition (partition p2 values less than (400));
truncate table t_part_1;
# test basic read and write
insert into t_nonpart_2 values (1, 2, 3);
select * from t_nonpart_2;
c1	c2	c3
1	2	3
insert into t_part_2 values (1, 2, 3);
select * from t_part_2;
c1	c2	c3
1	2	3
insert into t_part_3 values (1, 2, 3);
select * from t_part_3;
c1	c2	c3
1	2	3
insert into t_part_4 values (1, 2, 3);
select * from t_part_4;
c1	c2	c3
1	2	3
insert into t_subpart_2 values (1, 2, 3);
select * from t_subpart_2;
c1	c2	c3
1	2	3
################################################
# 2. create tablet with tablegroup
# create tablegroup
create tablegroup tg_none sharding = 'NONE';
create tablegroup tg_part_one sharding = 'PARTITION';
create tablegroup tg_part_two sharding = 'PARTITION';
create tablegroup tg_adapt_one sharding = 'ADAPTIVE';
create tablegroup tg_adapt_two sharding = 'ADAPTIVE';
##
# 2.1. tablegroup sharding = 'NONE'
create table t_nonpart_in_tg_none_1(c1 int, c2 int, c3 longtext, index(c1) local, index(c2) global) tablegroup tg_none;
create table t_nonpart_in_tg_none_2(c1 int, c2 int, c3 longtext) tablegroup tg_none;
create index local_index_t_nonpart_in_tg_none_2_c1 on t_nonpart_in_tg_none_2(c1);
create index global_index_t_nonpart_in_tg_none_2_c2 on t_nonpart_in_tg_none_2(c2) global;
create table t_part_in_tg_none_1(c1 int, c2 int, c3 longtext, index(c1) local, index(c2) global) tablegroup tg_none partition by range(c1) (partition p0 values less than (100), partition p1 values less than (200));
create table t_subpart_in_tg_none_1(c1 int, c2 int, c3 longtext, index(c1) local, index(c2) global) tablegroup tg_none partition by range(c1) subpartition by hash(c1) subpartitions 3 (partition p1 values less than (100), partition p2 values less than (200), partition p3 values less than MAXVALUE);
create table t_part_like_in_tg_none_1 like t_part_in_tg_none_1;
alter table t_part_in_tg_none_1 add partition (partition p2 values less than (400));
truncate table t_subpart_in_tg_none_1;
##
# 2.2. tablegroup sharding = 'PARTITION'
create table t_part_in_tg_part_one_1(c1 int, c2 int, c3 longtext, index(c1) local, index(c2) global) tablegroup tg_part_one partition by hash(c1) partitions 3;
create table t_subpart_in_tg_part_two_1(c1 int, c2 int, c3 longtext, index(c1) local, index(c2) global) tablegroup tg_part_two partition by range(c1) subpartition by hash(c1) subpartitions 3 (partition p1 values less than (100), partition p2 values less than (200), partition p3 values less than MAXVALUE);
##
# 2.3. tablegroup sharding = 'ADAPTIVE'
create table t_part_in_tg_adapt_one_1(c1 int, c2 int, c3 longtext, index(c1) local, index(c2) global) tablegroup tg_adapt_one partition by hash(c1) partitions 3;
create table t_subpart_in_tg_adapt_two_1(c1 int, c2 int, c3 longtext, index(c1) local, index(c2) global) tablegroup tg_adapt_two partition by range(c1) subpartition by hash(c1) subpartitions 3 (partition p1 values less than (100), partition p2 values less than (200), partition p3 values less than MAXVALUE);
################################################
