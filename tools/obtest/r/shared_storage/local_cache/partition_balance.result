# 3. partition balance of all user tables and global indexes
alter table t_nonpart_1 tablegroup '';
alter table t_part_1 tablegroup '';
alter table t_subpart_1 tablegroup '';
alter table t_subpart_2 tablegroup '';
ob1.check_until_timeout select count(*) from CDB_OB_BALANCE_JOBS where tenant_id = $mysql_tenant_id, 1, 60;
ob1.check_until_timeout select count(*) from CDB_OB_BALANCE_JOBS where tenant_id = $mysql_tenant_id, 0, 120;
ob1.check_until_timeout select count(*) from (select * from __all_virtual_balance_group_ls_stat where tenant_id = $mysql_tenant_id group by balance_group_name having (max(tablet_group_count) - min(tablet_group_count) > 1)), 0, 60;
ob1.check_until_timeout select max(cnt) - min(cnt) <= 1 from (select sum(tablet_group_count) as cnt, ls_id from __all_virtual_balance_group_ls_stat where tenant_id = $mysql_tenant_id group by ls_id), 1, 60;
