create table t1 (c1 int, c2 int) partition by hash(c1) partitions 2;
insert into t1 values (1,1),(2,2);
ob1.check_until_timeout select count(*) c from __all_virtual_tablet_to_ls where table_id = $table_id, 2, 10;
ob1.check_until_timeout select count(*) from __all_virtual_proxy_schema where tenant_name = 'mysql' and database_name = 'test' and table_name = 't1' and tablet_id = $tablet_id_1 and svr_ip = '$svr_ip_1' and sql_port = '$sql_port_1', 1, 10;
ob1.check_until_timeout select count(*) from __all_virtual_proxy_schema where tenant_name = 'mysql' and database_name = 'test' and table_name = 't1' and tablet_id = $tablet_id_2 and svr_ip = '$svr_ip_2' and sql_port = '$sql_port_2', 1, 10;
ob1.check_until_timeout select count(*) from __all_virtual_proxy_schema where tenant_name = 'mysql' and database_name = 'test' and table_name = 't1' and tablet_id = 0 and svr_ip = '$svr_ip_1' and sql_port = '$sql_port_1', 1, 10;
ob1.check_until_timeout select count(*) from __all_virtual_proxy_schema where tenant_name = 'mysql' and database_name = 'test' and table_name = 't1' and tablet_id = 9999 and svr_ip = '$svr_ip_1' and sql_port = '$sql_port_1', 1, 10;
ob1.check_until_timeout select count(*) from __all_virtual_proxy_schema where (tenant_name, database_name, table_name, tablet_id) in (('mysql', 'test', 't1', $tablet_id_1), ('mysql', 'test', 't1', $tablet_id_2)), 6, 10;
select count(*) from oceanbase.__all_virtual_proxy_schema where tenant_name = 'mysql' and database_name = 'test' and table_name = 't1';
count(*)
3
select count(*) from oceanbase.__all_virtual_proxy_schema where tenant_name = 'sys' and database_name = 'test' and table_name = '__all_root_table' and tablet_id = 0;
