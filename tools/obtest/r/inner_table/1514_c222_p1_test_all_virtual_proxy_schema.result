0
create table t2 (c1 int, c2 varchar(10));
insert into t2 values (34, '34');
create view v2 as select * from t2;
SELECT tenant_name, database_name, table_name, table_type, part_num, complex_table_type, level1_decoded_db_name, level1_decoded_table_name,  level2_decoded_db_name,  level2_decoded_table_name FROM oceanbase.__all_virtual_proxy_schema WHERE tenant_name = 'mysql' AND database_name = 'test' AND table_name = 't2' AND tablet_id = 0 AND sql_port > 0 ORDER BY role ASC LIMIT 1;
