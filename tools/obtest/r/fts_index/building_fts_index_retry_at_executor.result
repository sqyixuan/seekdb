ob1=OBI(cluster=1:1,proxy_num=0,init_unit_cpu=2);
ob1.reboot;
ob1.mysql alter system set merger_check_interval='10s';
ob1.mysql alter system set enable_rebalance = 'false';
ob1.mysql alter system set resource_hard_limit=500;
ob1.mysql alter system set debug_sync_timeout = '100000s';
alter system set _enable_add_fulltext_index_to_existing_table = true;
create table t1(c1 int primary key, c2 varchar(255), c3 varchar(255));
insert into t1 values (0, "oceanbase", "oceanbase");
insert into t1 values (1, "oceanbase", "oceanbase");
insert into t1 values (2, "oceanbase", "oceanbase");
ob1.z1.obs0.mysql alter system set_tp tp_no = 545, error_code = 6231, frequency = 1;
alter table t1 add fulltext index idx0(c2);
