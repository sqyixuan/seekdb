ob1=OBI(cluster=1:1:1,proxy_num=0);
ob1.set extra_config=$mini_ob_config;
ob1.reboot;
ob1.mysql alter system set debug_sync_timeout = '1000s';
ob1.check_until_timeout select count(*) from oceanbase.__all_rootservice_job where job_status = 'SUCCESS', 2, 100;
create database msy;
use msy;
create table t1(pk int primary key, c1 int, c2 int, c3 int, c4 int);
create index il on t1(c1) local;
create index il1 on t1(c3) global;
create index il2 on t1(c4) global partition by hash(c4) partitions 3;
create table t2(pk int primary key, c1 int) partition by hash(pk) partitions 3;
create index il on t2(c1) local;
create table t3 (c1 int, c2 int, c3 int, c4 int, primary key(c1, c2)) partition by range(c1) subpartition by range(c2) (partition rp0 values less than (100) (subpartition rp0sp0 values less than (100)), partition rp1 values less than (200)  (subpartition rp1sp0 values less than (100), subpartition rp1sp1 values less than (200)));
create index il on t3(c2) local;
create index il1 on t3(c3) global;
create index il2 on t3(c4) global partition by hash(c4) partitions 3;
use oceanbase;
set @@session.ob_query_timeout = 1000000000;
CREATE RESOURCE UNIT unit_1 MAX_CPU 2, MEMORY_SIZE '2G';
CREATE RESOURCE POOL pool_1 UNIT = 'unit_1', UNIT_NUM = 1;
CREATE TENANT mysql RESOURCE_POOL_LIST = ('pool_1'), primary_zone='z1,z2' set ob_tcp_invited_nodes='%';
CREATE RESOURCE POOL pool_2 UNIT = 'unit_1', UNIT_NUM = 1;
CREATE TENANT oracle RESOURCE_POOL_LIST = ('pool_2'), primary_zone='z1' set ob_tcp_invited_nodes='%',ob_compatibility_mode='oracle', autocommit='on';;
CREATE RESOURCE POOL pool_3 UNIT = 'unit_1', UNIT_NUM = 1;
CREATE TENANT mysql2 RESOURCE_POOL_LIST = ('pool_3'), primary_zone = 'RANDOM' set ob_tcp_invited_nodes='%';
create user msy IDENTIFIED BY msy;
grant all on *.* to msy WITH GRANT OPTION;
grant dba to msy;
create table t1(pk int primary key, c1 int, c2 int, c3 int, c4 int);
create index il on t1(c1) local;
create index il1 on t1(c3) global;
create index il2 on t1(c4) global partition by hash(c4) partitions 3;
create table t2(pk int primary key, c1 int) partition by hash(pk) partitions 10;
create index il21 on t2(c1) local;
create table t3 (c1 int, c2 int, c3 int, c4 int, primary key(c1, c2)) partition by range(c1) subpartition by range(c2) (partition rp0 values less than (100) (subpartition rp0sp0 values less than (100)), partition rp1 values less than (200)  (subpartition rp1sp0 values less than (100), subpartition rp1sp1 values less than (200)));
create index il30 on t3(c2) local;
create index il31 on t3(c3) global;
create index il32 on t3(c4) global partition by hash(c4) partitions 3;
create database msy;
use msy;
create table t1(pk int primary key, c1 int, c2 int, c3 int, c4 int);
create index il on t1(c1) local;
create index il1 on t1(c3) global;
create index il2 on t1(c4) global partition by hash(c4) partitions 3;
create table t2(pk int primary key, c1 int) partition by hash(pk) partitions 10;
create index il on t2(c1) local;
create table t3 (c1 int, c2 int, c3 int, c4 int, primary key(c1, c2)) partition by range(c1) subpartition by range(c2) (partition rp0 values less than (100) (subpartition rp0sp0 values less than (100)), partition rp1 values less than (200)  (subpartition rp1sp0 values less than (100), subpartition rp1sp1 values less than (200)));
create index il on t3(c2) local;
create index il1 on t3(c3) global;
create index il2 on t3(c4) global partition by hash(c4) partitions 3;
