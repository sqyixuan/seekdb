ob1=OBI(cluster=2:2, proxy_num=0,asvr_num=1);
ob1.set extra_config=$mini_ob_config;
ob1.reboot;
ob1.mysql alter resource unit sys_unit_config memory_size='2G';
ob1.mysql alter tenant sys set primary_zone = 'z1';
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_core_meta_table where role = 1 and zone = 'z1', 1, 100;
CREATE RESOURCE UNIT large_unit MAX_CPU=2, MEMORY_SIZE='4G';
CREATE RESOURCE POOL pool UNIT large_unit, UNIT_NUM 2;
CREATE RESOURCE POOL pool_1 UNIT large_unit, UNIT_NUM 1;
ob1.mysql alter system set _backup_idle_time = '10s';
ob1.mysql alter system set merger_check_interval = '10s';
ob1.mysql alter system set enable_async_syslog=false;
ob1.mysql alter system set enable_rebalance = false;
ob1.mysql alter system set debug_sync_timeout = '100000s';
ob1.check_until_timeout select count(*) as cnt from oceanbase.DBA_OB_ARBITRATION_SERVICE where arbitration_service = "$arb_svr_ip:$arb_svr_port", 1, 5;
ob1.mysql CREATE TENANT oracle RESOURCE_POOL_LIST = ('pool'), primary_zone = "z1,z2" ,enable_arbitration_service = true set ob_tcp_invited_nodes='%', ob_compatibility_mode='oracle';
ob1.mysql alter system set log_storage_compress_all = true tenant = ALL;
create user mytest identified by "test";
grant connect to mytest;
GRANT SELECT on SYS.DBA_OB_ACCESS_POINT to mytest;
GRANT SELECT on SYS.GV$OB_UNITS to mytest;
GRANT SELECT on SYS.DBA_OB_TENANTS to mytest;
GRANT SELECT on SYS.GV$OB_PARAMETERS to mytest;
GRANT SELECT on SYS.GV$OB_LOG_STAT to mytest;
GRANT SELECT on SYS.DBA_OB_LS to mytest;
GRANT SELECT on SYS.DBA_OB_LS_HISTORY to mytest;
ob1.check_until_timeout SELECT count(*) FROM oceanbase.__all_tenant WHERE tenant_name='standby_oracle_tenant', 1, 100;
ob1.mysql alter tenant standby_oracle_tenant set enable_arbitration_service = true;
ob1.mysql alter tenant sys set enable_arbitration_service = true;
ob1.mysql alter tenant oracle set enable_arbitration_service = true;
ob1.check_until_timeout select count(*) as cnt from oceanbase.DBA_OB_TENANTS where tenant_id = $tenant_id and arbitration_service_status = "ENABLED", 1, 200;
ob1.check_until_timeout select count(*) as cnt from oceanbase.DBA_OB_TENANTS where tenant_id = $oracle_id and arbitration_service_status = "ENABLED", 1, 200;
ob1.check_until_timeout select count(*) as cnt from oceanbase.DBA_OB_TENANTS where tenant_id = 1 and arbitration_service_status = "ENABLED", 1, 200;
ob1.check_until_timeout select count(*) from oceanbase.DBA_OB_TENANTS where READABLE_SCN > $gts and tenant_name = 'standby_oracle_tenant', 1, 100;
ob1.mysql alter system set_tp tp_name=ERRSIM_GET_LS_READABLE_SCN_ERROR, error_code= 1234, frequency = 1 server = '$server_ip_port_1';
ob1.mysql alter system set_tp tp_name=ERRSIM_GET_LS_READABLE_SCN_ERROR, error_code= 1234, frequency = 1 server = '$server_ip_port_2';
ob1.mysql_p select count(*) from oceanbase.DBA_OB_TENANTS where READABLE_SCN > $gts and tenant_name = 'standby_oracle_tenant';
count(*)
0
ob1.mysql alter system stop zone 'z2';
ob1.check_until_timeout select count(*) from oceanbase.DBA_OB_TENANTS where READABLE_SCN > $gts and tenant_name = 'standby_oracle_tenant', 1, 100;
ob1.mysql alter system start zone 'z2';
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_log_stat where degraded_list !='', 0, 100;
ob1.mysql alter system set server_permanent_offline_time = '20s';
ob1.z1.obs0.force_stop;
ob1.z1.obs1.force_stop;
ob1.z2.obs0.check_until_timeout select count(*) > 1 from oceanbase.__all_virtual_ls_replica_task_history, 1, 50;
ob1.z2.obs0.check_until_timeout select count(*) > 1 from oceanbase.__all_virtual_ls_replica_task_history where task_id > '$task_id' and task_status = 'FAILED' and execute_result like "%OB_TIMEOUT%", 1, 40;
ob1.z2.obs0.check_until_timeout select count(*) from oceanbase.__all_virtual_log_stat where degraded_list ='' and tenant_id = $tenant_id, 0, 100;
ob1.z2.obs0.mysql alter system set_tp tp_name=ERRSIM_GET_LS_READABLE_SCN_ERROR, error_code= 1234, frequency = 0 server = '$server_ip_port_1';
ob1.z2.obs0.mysql alter system set_tp tp_name=ERRSIM_GET_LS_READABLE_SCN_ERROR, error_code= 1234, frequency = 0 server = '$server_ip_port_2';
ob1.z2.obs0.check_until_timeout select count(*) from oceanbase.__all_virtual_log_stat where degraded_list !='', 0, 30;
ob1.z1.obs0.nstart;
ob1.z1.obs1.nstart;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_ls_meta_table where member_list not like "%,%", 0, 200;
ob1.check_until_timeout select count(*) from oceanbase.V\$OB_LS_REPLICA_TASK_PLAN, 0, 100;
ob1.check_until_timeout select count(*) from oceanbase.DBA_OB_TENANTS where READABLE_SCN > $gts and tenant_name = 'standby_oracle_tenant', 1, 100;
ob1.mysql alter system set_tp tp_name=ERRSIM_GET_LS_READABLE_SCN_ERROR, error_code= 1234, frequency = 1 server = '$server_ip_port_1';
ob1.mysql alter system set_tp tp_name=ERRSIM_GET_LS_READABLE_SCN_ERROR, error_code= 1234, frequency = 1 server = '$server_ip_port_2';
ob1.mysql alter system stop zone 'z2';
ob1.check_until_timeout select count(*) from oceanbase.DBA_OB_TENANTS where READABLE_SCN > $gts and tenant_name = 'standby_oracle_tenant', 1, 100;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_log_stat where degraded_list ='' and tenant_id = $tenant_id, 0, 100;
ob1.mysql alter system migrate unit $unit_id destination = '$dest';
ob1.check_until_timeout select count(*) from oceanbase.__all_unit where migrate_from_svr_ip != '', 0, 100;
ob1.mysql alter system start zone 'z2';
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_log_stat where degraded_list !='', 0, 100;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_unit where tenant_id = $tenant_id, 2, 100;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_unit where tenant_id = $meta_tenant_id, 2, 100;
ob1.mysql alter resource tenant standby_oracle_tenant unit_num = 2;
ob1.mysql alter system set_tp tp_name=ERRSIM_GET_LS_READABLE_SCN_ERROR, error_code= 1234, frequency = 0 server = '$server_ip_port_1';
ob1.mysql alter system set_tp tp_name=ERRSIM_GET_LS_READABLE_SCN_ERROR, error_code= 1234, frequency = 0 server = '$server_ip_port_2';
ob1.z1.obs0.force_stop;
ob1.z1.obs1.force_stop;
ob1.z2.obs0.check_until_timeout select count(*) from oceanbase.__all_virtual_ls_meta_table where zone = 'z1', 0, 100;
ob1.z2.obs0.mysql alter system set_tp tp_name=ERRSIM_GET_LS_READABLE_SCN_ERROR, error_code= 1234, frequency = 1 server = '$server_ip_port_1';
ob1.z2.obs0.mysql alter system set_tp tp_name=ERRSIM_GET_LS_READABLE_SCN_ERROR, error_code= 1234, frequency = 1 server = '$server_ip_port_2';
ob1.z2.obs0.mysql alter system migrate replica ls=1 source='$src' destination='$dest' tenant ='standby_oracle_tenant';
ob1.z2.obs0.check_until_timeout select count(*) > 0 from oceanbase.__all_virtual_ls_replica_task where tenant_id = $tenant_id, 1, 30;
ob1.z2.obs0.check_until_timeout select count(*) > 0 from oceanbase.__all_virtual_ls_replica_task_history where task_status = 'FAILED' and execute_result like "%OB_MEMBER_CHANGE_FAILED%" and task_type = 'MIGRATE REPLICA' and task_id = '$task_id', 1, 100;
ob1.z2.obs0.check_until_timeout select count(*) from oceanbase.__all_virtual_ls_info where tenant_id = $tenant_id and ls_id = 1, 1, 100;
ob1.z2.obs0.mysql alter system set_tp tp_name=ERRSIM_GET_LS_READABLE_SCN_ERROR, error_code= 1234, frequency = 0 server = '$server_ip_port_1';
ob1.z2.obs0.mysql alter system set_tp tp_name=ERRSIM_GET_LS_READABLE_SCN_ERROR, error_code= 1234, frequency = 0 server = '$server_ip_port_2';
ob1.z1.obs0.start;
ob1.z1.obs1.start;
ob1.check_until_timeout select count(*) from oceanbase.__all_server where start_service_time = 0, 0, 100;
ob1.z2.obs0.check_until_timeout select count(*) from oceanbase.V\$OB_LS_REPLICA_TASK_PLAN, 0, 300;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_ls_meta_table where member_list not like "%,%", 0, 100;
