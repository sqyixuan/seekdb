insert into t1_dup_part values (5), (6), (7), (8);
insert into t1_dup_part values (9), (10), (21), (22);
alter system minor freeze tenant tenant_for_duplicate;
ob1.z1.obs0.check_log_until_success -c "succeed to release head data memtable";
ob1.z2.obs0.check_log_until_success -c "succeed to release head data memtable";
'prepare finished'
======================================================================
0. check duplicate log stream in meta table
======================================================================
ob1.check_until_timeout select count(*) as ls_cnt from oceanbase.CDB_OB_LS where tenant_id = $tenant_id and flag like "%DUPLICATE%", 1, 5;
ob1.check_until_timeout select ls_id from oceanbase.CDB_OB_LS where tenant_id = $tenant_id and flag like "%DUPLICATE%", $duplicate_ls_id, 5;
ob1.check_until_timeout select count(*) as ls_cnt from oceanbase.CDB_OB_LS where tenant_id = $tenant_id and flag not like "%DUPLICATE%", 3, 5;
check meta tenant has expected member_list and learner_list
ob1.check_until_timeout select count(*) as check_members_list from oceanbase.__all_virtual_log_stat where tenant_id = $meta_tenant_id and ls_id = $sys_ls_id and role like "%LEADER%" and (paxos_member_list like "%$z1_dst0%" or paxos_member_list like "%$z1_dst1%") and (paxos_member_list like "%$z2_dst0%" or paxos_member_list like "%$z2_dst1%") and (paxos_member_list not like "%$z3_dst0%" and paxos_member_list not like "%$z3_dst1%") and paxos_replica_num = 2 and learner_list = "", 1, 5;
ob1.check_until_timeout select count(*) as check_members_list from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id = $meta_tenant_id and ls_id = $sys_ls_id and role like "%LEADER%" and (member_list like "%$z1_dst0%" or member_list like "%$z1_dst1%") and (member_list like "%$z2_dst0%" or member_list like "%$z2_dst1%") and (member_list not like "%$z3_dst0%" and member_list not like "%$z3_dst1%") and learner_list = "", 1, 5;
check user tenant has expected member_list and learner_list
check user tenant sys ls
ob1.check_until_timeout select count(*) as check_members_list from oceanbase.__all_virtual_log_stat where tenant_id = $tenant_id and ls_id = $sys_ls_id and role like "%LEADER%" and (paxos_member_list like "%$z1_dst0%" or paxos_member_list like "%$z1_dst1%") and (paxos_member_list like "%$z2_dst0%" or paxos_member_list like "%$z2_dst1%") and (paxos_member_list not like "%$z3_dst0%" and paxos_member_list not like "%$z3_dst1%") and paxos_replica_num = 2 and learner_list = "", 1, 5;
ob1.check_until_timeout select count(*) as check_members_list from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id = $tenant_id and ls_id = $sys_ls_id and role like "%LEADER%" and (member_list like "%$z1_dst0%" or member_list like "%$z1_dst1%") and (member_list like "%$z2_dst0%" or member_list like "%$z2_dst1%") and (member_list not like "%$z3_dst0%" and member_list not like "%$z3_dst1%") and learner_list = "", 1, 5;
check user tenant normal_ls_id_min ls
ob1.check_until_timeout select count(*) as check_members_list from oceanbase.__all_virtual_log_stat where tenant_id = $tenant_id and ls_id = $normal_ls_id_min and role like "%LEADER%" and (paxos_member_list like "%$z1_dst0%" or paxos_member_list like "%$z1_dst1%") and (paxos_member_list like "%$z2_dst0%" or paxos_member_list like "%$z2_dst1%") and (paxos_member_list not like "%$z3_dst0%" and paxos_member_list not like "%$z3_dst1%") and paxos_replica_num = 2 and learner_list = "", 1, 5;
ob1.check_until_timeout select count(*) as check_members_list from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id = $tenant_id and ls_id = $normal_ls_id_min and role like "%LEADER%" and (member_list like "%$z1_dst0%" or member_list like "%$z1_dst1%") and (member_list like "%$z2_dst0%" or member_list like "%$z2_dst1%") and (member_list not like "%$z3_dst0%" and member_list not like "%$z3_dst1%") and learner_list = "", 1, 5;
check user tenant normal_ls_id_max ls
ob1.check_until_timeout select count(*) as check_members_list from oceanbase.__all_virtual_log_stat where tenant_id = $tenant_id and ls_id = $normal_ls_id_max and role like "%LEADER%" and (paxos_member_list like "%$z1_dst0%" or paxos_member_list like "%$z1_dst1%") and (paxos_member_list like "%$z2_dst0%" or paxos_member_list like "%$z2_dst1%") and (paxos_member_list not like "%$z3_dst0%" and paxos_member_list not like "%$z3_dst1%") and paxos_replica_num = 2 and learner_list = "", 1, 5;
ob1.check_until_timeout select count(*) as check_members_list from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id = $tenant_id and ls_id = $normal_ls_id_max and role like "%LEADER%" and (member_list like "%$z1_dst0%" or member_list like "%$z1_dst1%") and (member_list like "%$z2_dst0%" or member_list like "%$z2_dst1%") and (member_list not like "%$z3_dst0%" and member_list not like "%$z3_dst1%") and learner_list = "", 1, 5;
check user tenant duplicate_ls_id ls
ob1.check_until_timeout select count(*) as check_members_list from oceanbase.__all_virtual_log_stat where tenant_id = $tenant_id and ls_id = $duplicate_ls_id and role like "%LEADER%" and (paxos_member_list like "%$z1_dst0%" or paxos_member_list like "%$z1_dst1%") and (paxos_member_list like "%$z2_dst0%" or paxos_member_list like "%$z2_dst1%") and (paxos_member_list not like "%$z3_dst0%" and paxos_member_list not like "%$z3_dst1%") and paxos_replica_num = 2 and (learner_list like "%$z1_dst0%" or learner_list like "%$z1_dst1%") and (learner_list like "%$z2_dst0%" or learner_list like "%$z2_dst1%") and (learner_list not like "%$z3_dst0%" and learner_list not like "%$z3_dst1%"), 1, 5;
ob1.check_until_timeout select count(*) as check_members_list from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id = $tenant_id and ls_id = $duplicate_ls_id and role like "%LEADER%" and (member_list like "%$z1_dst0%" or member_list like "%$z1_dst1%") and (member_list like "%$z2_dst0%" or member_list like "%$z2_dst1%") and (member_list not like "%$z3_dst0%" and member_list not like "%$z3_dst1%") and (learner_list like "%$z1_dst0%" or learner_list like "%$z1_dst1%") and (learner_list like "%$z2_dst0%" or learner_list like "%$z2_dst1%") and (learner_list not like "%$z3_dst0%" and learner_list not like "%$z3_dst1%"), 1, 5;
=====================================================================
1. alter locality from FF to FFR
=====================================================================
ob1.mysql set ob_global_debug_sync = 'BEFORE_SEND_DRTASK_RPC wait_for signal execute 10000';
ALTER TENANT tenant_for_duplicate LOCALITY = 'F@z1,F@z2,R@z3';
ob1.mysql set ob_global_debug_sync = 'now signal signal';
ob1.mysql set ob_global_debug_sync = 'now signal signal';
ob1.mysql set ob_global_debug_sync = 'now signal signal';
ob1.mysql set ob_global_debug_sync = 'now signal signal';
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id = $tenant_id and ls_id != $duplicate_ls_id, 9, 120;
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id = $tenant_id and ls_id = $duplicate_ls_id, 4, 1;
ob1.check_until_timeout select count(*) from oceanbase.DBA_OB_TENANTS where tenant_id = $tenant_id and previous_locality is not NULL, 1, 1;
ob1.mysql set ob_global_debug_sync = 'now signal signal';
ob1.mysql set ob_global_debug_sync = 'now signal signal';
ob1.mysql set ob_global_debug_sync = 'BEFORE_SEND_DRTASK_RPC clear';
ob1.check_until_timeout select count(*) from oceanbase.DBA_OB_TENANTS where tenant_id = $tenant_id and previous_locality is NULL and locality like "%FULL{1}@z1, FULL{1}@z2, READONLY{1}@z3%", 1, 120;
check task generated
ob1.check_until_timeout select count(*) as task_cnt from oceanbase.DBA_OB_ROOTSERVICE_EVENT_HISTORY where module like "%disaster%" and value1 = $meta_tenant_id and value2 = $sys_ls_id and event like "%start_add_ls_replica%" and value6 like "%add non-paxos replica according to locality%", 1, 5;
ob1.check_until_timeout select count(*) as task_cnt from oceanbase.DBA_OB_ROOTSERVICE_EVENT_HISTORY where module like "%disaster%" and value1 = $tenant_id and value2 = $sys_ls_id and event like "%start_add_ls_replica%" and value6 like "%add non-paxos replica according to locality%", 1, 5;
ob1.check_until_timeout select count(*) as task_cnt from oceanbase.DBA_OB_ROOTSERVICE_EVENT_HISTORY where module like "%disaster%" and value1 = $tenant_id and value2 = $normal_ls_id_min and event like "%start_add_ls_replica%" and value6 like "%add non-paxos replica according to locality%", 1, 5;
