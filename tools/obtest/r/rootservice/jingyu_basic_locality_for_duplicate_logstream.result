ob1.check_until_timeout select count(*) as task_cnt from oceanbase.DBA_OB_ROOTSERVICE_EVENT_HISTORY where module like "%disaster%" and value1 = $tenant_id and value2 = $duplicate_ls_id and event like "%start_add_ls_replica%" and value4 like "%$z3_dst0%" and value6 like "%add non-paxos replica according to locality%", 1, 5;
ob1.check_until_timeout select count(*) as task_cnt from oceanbase.DBA_OB_ROOTSERVICE_EVENT_HISTORY where module like "%disaster%" and value1 = $tenant_id and value2 = $duplicate_ls_id and event like "%start_add_ls_replica%" and value4 like "%$z3_dst1%" and value6 like "%add non-paxos replica according to locality%", 1, 5;
check meta tenant has expected member_list and learner_list
