=====================================================================
create inital objects
=====================================================================
ob1=OBI(cluster=2:2:2,proxy_num=0,init_unit_cpu=0);
ob1.set extra_config=$mini_ob_config;
ob1.reboot;
ob1.mysql alter system set debug_sync_timeout = '1000s';
ob1.mysql ALTER SYSTEM SET enable_rebalance = 'false';
ob1.mysql ALTER SYSTEM SET enable_rereplication = 'true';
set @@session.ob_query_timeout = 200000000;
alter system set __min_full_resource_pool_memory=1073741824;
use oceanbase;
ob1.mysql CREATE RESOURCE POOL tenant_pool UNIT = "2c2g", UNIT_NUM = 2, ZONE_LIST = ('z1', 'z2', 'z3');
ob1.mysql CREATE TENANT tenant_for_duplicate RESOURCE_POOL_LIST=('tenant_pool'), LOCALITY = "F@z1, F@z2", PRIMARY_ZONE = "z1" SET ob_tcp_invited_nodes='%';
create table t1_no_pk (c1 int);
create table t1_dup_no_pk (c1 int) duplicate_scope = 'CLUSTER';
insert into t1_no_pk values (1), (2), (3);
insert into t1_dup_no_pk values (1), (2), (3);
select * from t1_no_pk order by c1 asc;
c1
1
2
3
select * from t1_dup_no_pk order by c1 asc;
c1
1
2
3
update t1_no_pk set c1=c1+10;
update t1_dup_no_pk set c1=c1+10;
select * from t1_no_pk order by c1 asc;
c1
11
12
13
select * from t1_dup_no_pk order by c1 asc;
c1
11
12
13
create table t1_pk (c1 int primary key);
create table t1_dup_pk (c1 int primary key) duplicate_scope = 'CLUSTER';
insert into t1_pk values (1), (2), (3);
insert into t1_dup_pk values (1), (2), (3);
select * from t1_pk order by c1 asc;
