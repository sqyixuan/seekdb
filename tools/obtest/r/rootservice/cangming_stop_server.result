ob1=OBI(cluster=1:1:2,proxy_num=0,locality=HZ:HZ:SH);
ob1.reboot;
ob1.check_until_timeout select count(*) from __all_server where start_service_time > 0,4,60;
ob1.mysql alter system set_tp tp_name = ERRSIM_CHECK_SERVER_MACHINE_ERROR, error_code = 4016, frequency = 1;
ob1.mysql alter system stop server '$z1_obs0_ip:$z1_obs0_port';
ob1.mysql alter system set_tp tp_name = ERRSIM_CHECK_SERVER_MACHINE_ERROR, error_code = 4016, frequency = 0;
ob1.mysql alter system start server '$z1_obs0_ip:$z1_obs0_port';
select count(*) from __all_server where stop_time = 0;
