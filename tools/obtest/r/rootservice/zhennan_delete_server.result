ob1=OBI(cluster=2:2:2,proxy_num=0);
ob1.set extra_config=$mini_ob_config;
ob1.reboot;
set @@session.ob_query_timeout = 1000000000;
ob1.mysql alter system set balancer_idle_time = '10s';
ob1.mysql alter system set enable_rebalance= false;
ob1.mysql alter system set server_permanent_offline_time = '60s';
CREATE RESOURCE UNIT unit_1 MAX_CPU 2, MEMORY_SIZE '2G';
CREATE RESOURCE POOL pool_1 UNIT = 'unit_1', UNIT_NUM = 1;
CREATE TENANT mysql RESOURCE_POOL_LIST = ('pool_1'), primary_zone = 'z1' set ob_tcp_invited_nodes = '%';
INSERT INTO __all_ls_meta_table (tenant_id, ls_id, svr_ip, svr_port, sql_port, role, member_list, proposal_id, replica_type, replica_status, restore_status, memstore_percent, unit_id, zone, data_size, required_size, gmt_modified) VALUES (1009, 1, '127.1.1.1', 24333, 24368, 2, '', 0, 0, 'NORMAL', 0, 100, 1001, 'z1', 0, 0, now(6));
INSERT INTO __all_ls_meta_table (tenant_id, ls_id, svr_ip, svr_port, sql_port, role, member_list, proposal_id, replica_type, replica_status, restore_status, memstore_percent, unit_id, zone, data_size, required_size, gmt_modified) VALUES (1011, 1, '127.1.1.1', 24333, 24368, 1, '127.1.1.1:1:1', 0, 0, 'NORMAL', 0, 100, 1001, 'z1', 0, 0, now(6));
ob1.check_until_timeout select count(*) from oceanbase.__all_ls_meta_table where tenant_id = 1009, 0, 100;
ob1.check_until_timeout select count(*) from oceanbase.__all_ls_meta_table where tenant_id = 1011, 0, 10;
INSERT INTO __all_ls_status (tenant_id, ls_id, init_member_list, b_init_member_list, status, ls_group_id, unit_group_id, primary_zone) VALUES (1001, 999, '', '', 'NORMAL', 1, 1, 'z1');
set @@session.ob_query_timeout = 10000000;
ERROR HY000: Tenant(1001) LS(999) has no leader, delete server not allowed
DELETE FROM __all_ls_status WHERE tenant_id = 1001 and ls_id = 999;
ob1.check_until_timeout select count(*) from oceanbase.__all_server where zone = "z2", 1, 300;
ERROR HY000: can not migrate out unit '2', no other available servers on zone 'z2', delete server not allowed
set @@session.ob_query_timeout = 10500000;
alter system set debug_sync_timeout = '10s';
ob1.mysql set ob_global_debug_sync = 'BEFORE_CHECK_ALL_LS_HAS_LEADER wait_for continue_signal';
ERROR HY000: check leader for all LS timeout, delete server not allowed
ob1.mysql set ob_global_debug_sync = 'now signal continue_signal';
ob1.z3.obs1.force_stop;
ob1.check_until_timeout(ob1.select select start_service_time from oceanbase.__all_server where svr_ip = '$z3_obs1_ip' and svr_port = $z3_obs1_port, 0, 20);
ob1.check_until_timeout select count(*) = $server_count from __all_server, 1, 120;
