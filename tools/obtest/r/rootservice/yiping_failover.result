ob1=OBI(cluster=1, proxy_num=0);
ob2=OBI(cluster=1, proxy_num=0);
ob1.z1.obs0.set extra_config = "cpu_count=16,memory_limit='30G',system_memory='7G',__min_full_resource_pool_memory='1073741824',cache_wash_threshold='1G',_ob_minor_merge_schedule_interval='3s'";
ob2.z1.obs0.set extra_config = "cpu_count=16,memory_limit='30G',system_memory='7G',__min_full_resource_pool_memory='1073741824',cache_wash_threshold='1G',_ob_minor_merge_schedule_interval='3s'";
ob1.force_stop;
ob1.clean_backup_dest;
ob1.reboot;
ob1.mysql alter resource unit sys_unit_config memory_size='2G';
use oceanbase;
CREATE RESOURCE UNIT small_unit MAX_CPU=2, MEMORY_SIZE='4G', LOG_DISK_SIZE='2G';
CREATE RESOURCE POOL small_pool UNIT small_unit, UNIT_NUM 1, ZONE_LIST ('z1');
ob1.mysql alter system set _backup_idle_time = '10s';
ob1.mysql alter system set merger_check_interval = '10s';
ob1.mysql alter system set enable_async_syslog=false;
ob1.mysql CREATE TENANT $backup_mysql_tenant RESOURCE_POOL_LIST = ('small_pool'), primary_zone = "z1" set ob_tcp_invited_nodes='%', ob_compatibility_mode='mysql';
set global wait_timeout = 288000;
create table t1(a int, b int, c int);
insert into t1(a, b) values(1, 1);
ob1.mysql alter system archivelog;
ob1.check_until_timeout select status from oceanbase.CDB_OB_ARCHIVELOG where tenant_id=$backup_mysql_tenant_id, DOING, 600;
ob1.mysql alter system backup database;
ob1.check_until_timeout select count(*) c from __all_backup_job_history where tenant_id = 1, 1, 600;
ob1.check_until_timeout select result from oceanbase.CDB_OB_BACKUP_JOB_HISTORY where tenant_id = $backup_mysql_tenant_id, 0, 10;
ob1.check_until_timeout select result from oceanbase.CDB_OB_BACKUP_TASK_HISTORY where tenant_id = $backup_mysql_tenant_id, 0, 10;
use oceanbase;
ob1.mysql alter tenant $backup_mysql_tenant set primary_zone = 'z1';
ob1.check_until_timeout select count(*)>=1 from oceanbase.__all_virtual_ls_status where status = 'NORMAL' and tenant_id = $backup_mysql_tenant_id, 1, 100;
ob1.check_until_timeout select floor(checkpoint_scn / 1000) > '$restore_checkpoint1' from CDB_OB_ARCHIVELOG, 1, 600;
ob1.check_until_timeout select floor(checkpoint_scn / 1000) > '$restore_checkpoint2' from CDB_OB_ARCHIVELOG, 1, 600;
ob2.reboot;
ob2.mysql alter resource unit sys_unit_config memory_size='2G';
CREATE RESOURCE UNIT small_unit MAX_CPU=2, MEMORY_SIZE='4G', LOG_DISK_SIZE='2G';
CREATE RESOURCE POOL small_pool_0 UNIT small_unit, UNIT_NUM 1, ZONE_LIST ('z1');
CREATE RESOURCE POOL small_pool_2 UNIT small_unit, UNIT_NUM 1, ZONE_LIST ('z1');
ob2.mysql alter system set enable_async_syslog=false;
ob2.mysql alter system restore $restore_mysql_tenant from '$restore_path' until time='$restore_checkpoint' with 'pool_list=small_pool_2&primary_zone=z1';
ob2.check_until_timeout SELECT status FROM __all_tenant WHERE tenant_id = 1001, NORMAL, 200;
ob2.check_until_timeout select count(*) from __all_virtual_ls_meta_table where tenant_id = 1002 and restore_status = 0, 2, 1200;
ob2.check_until_timeout select status FROM __all_tenant WHERE tenant_id = 1002, NORMAL, 200;
ob2.check_until_timeout select count(*) FROM __all_restore_job, 0, 200;
ob2.mysql ALTER SYSTEM RECOVER STANDBY TENANT $restore_mysql_tenant UNTIL UNLIMITED;
ob2.mysql alter system set debug_sync_timeout = '100000s';
ob2.mysql set ob_global_debug_sync = 'BLOCK_STANDBY_REFRESH_SCHEMA wait_for continue_standby_signal execute 10000';
create table t2(a int, b int, c int);
insert into t2(a, b) values(10, 10);
ob2.check_until_timeout select count(*) FROM oceanbase.dba_ob_tenants where tenant_id = $restore_mysql_tenant_id and SYNC_SCN >= $check_sync_scn, 1, 50;
alter system change tenant tenant_id = 1001;
select tenant_role from __all_tenant_info where tenant_id = 1002;
tenant_role
STANDBY
ob2.mysql alter system set debug_sync_timeout = '100000s';
ob2.mysql set ob_global_debug_sync = 'BEFORE_PREPARE_FLASHBACK wait_for continue_signal_f execute 10000';
ALTER SYSTEM ACTIVATE STANDBY;
ERROR HY000: Incorrect arguments to tenant name, should specify tenant name
set ob_query_timeout  = 10000000;
ALTER SYSTEM ACTIVATE STANDBY TENANT restore_mysql_tenant;
ob2.check_until_timeout select count(*) from __all_virtual_tenant_info where tenant_id = 1002 and switchover_status = 'PREPARE FLASHBACK' and tenant_role = 'STANDBY', 1, 5;
ob2.mysql alter system set_tp tp_name = ERRSIM_RECOVERY_LS_THREAD1, error_code = $restore_mysql_tenant_id, frequency = 1;
update t1 set a=2, b=2;
ob2.check_until_timeout select count(*) from oceanbase.__all_virtual_log_stat where role = 'LEADER' and tenant_id = 1002 and end_scn >= $primary_max_log_scn and ls_id != 1, 1, 400;
ob2.mysql set ob_global_debug_sync = 'now signal continue_signal_f';
ob2.mysql set ob_global_debug_sync = 'BEFORE_PREPARE_FLASHBACK clear';
ob2.mysql set ob_global_debug_sync = 'BEFORE_DO_FLASHBACK wait_for continue_signal_ff execute 10000';
ALTER SYSTEM ACTIVATE STANDBY;
ERROR HY000: Incorrect arguments to tenant name, should specify tenant name
set ob_query_timeout  = 5000000;
ALTER SYSTEM ACTIVATE STANDBY TENANT restore_mysql_tenant;
ob2.check_until_timeout select count(*) from __all_virtual_tenant_info where tenant_id = 1002 and switchover_status = 'FLASHBACK' and tenant_role = 'STANDBY' and recovery_until_scn < 4611686018427387903, 1, 5;
ob2.check_until_timeout select count(*) from __all_virtual_log_restore_source where tenant_id = 1002 and recovery_until_scn < 4611686018427387903, 1, 5;
ob2.mysql set ob_global_debug_sync = 'now signal continue_signal_ff';
ob2.mysql set ob_global_debug_sync = 'BEFORE_DO_FLASHBACK clear';
ob2.mysql alter system set_tp tp_name = ERRSIM_RECOVERY_LS_THREAD1, error_code = $restore_mysql_tenant_id, frequency = 0;
select * from t1;
a	b	c
1	1	NULL
