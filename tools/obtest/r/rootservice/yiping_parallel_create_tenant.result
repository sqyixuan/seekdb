============================================================
meta租户create_normal_tenant失败自动删除租户
============================================================
ob1.mysql alter system set_tp tp_name=ERRSIM_CREATE_META_NORMAL_TENANT_ERROR, error_code=4016, frequency = 1;
create tenant mysql resource_pool_list=('pool');
ERROR HY000: Internal error
select count(*) from dba_ob_tenants where tenant_id in (1013, 1014);
count(*)
0
ob1.mysql alter system set_tp tp_name=ERRSIM_CREATE_META_NORMAL_TENANT_ERROR, error_code=4016, frequency = 0;
ob1.check_until_timeout select count(*) from gv\$ob_units where tenant_id in ($meta_tenant_id, $user_tenant_id), 0, 600;
