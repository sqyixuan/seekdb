ob1=OBI(cluster=1:1:1,proxy_num=0);
ob1.reboot;
ob1.mysql alter tenant sys set primary_zone='z1';
ob1.check_until_timeout select role from oceanbase.__all_ls_meta_table where tenant_id=1 and ls_id=1 and zone='z1', 1, 40;
ob1.check_until_timeout select count(*)>0 from oceanbase.__all_rootservice_event_history where event='full_rootservice' and value1=0 and value2 like '%$ip:$port%' order by 1 desc, 1, 10;
ob1.mysql alter system set syslog_io_bandwidth_limit='300M';
ob1.mysql create resource unit box max_cpu 2, memory_size='6G';
ob1.mysql create resource pool pool unit = 'box', unit_num = 1;
ob1.mysql alter system set debug_sync_timeout = '100000s';
============================================================
正常创建租户
============================================================
ob1.mysql create tenant mysql resource_pool_list=('pool');
ob1.z1.obs0.check_rs_log_until_success -c 'succeed to advance user ls status for creating tenant.*tenant_id_.$user_tenant_id';
ob1.mysql drop tenant mysql force;
ob1.check_until_timeout select count(*) from gv\$ob_units where tenant_id in ($meta_tenant_id, $user_tenant_id), 0, 600;
============================================================
验证wait table writable不会hung住
============================================================
ob1.mysql set ob_global_debug_sync = 'BEFORE_CREATE_META_TENANT wait_for signal_create_meta_tenant$user_tenant_id execute 10000';
ob1.mysql set ob_global_debug_sync = 'BEFORE_CREATE_USER_TENANT wait_for signal_create_user_tenant$user_tenant_id execute 10000';
create tenant mysql resource_pool_list=('pool'), primary_zone='z2';
ob1.z1.obs0.check_rs_log_until_success -c 'meta table is not created.*user_tenant_id.$user_tenant_id';
ob1.mysql set ob_global_debug_sync = 'BEFORE_CREATE_META_TENANT clear';
ob1.mysql set ob_global_debug_sync = 'now signal signal_create_meta_tenant$user_tenant_id';
ob1.mysql set ob_global_debug_sync = 'BEFORE_CREATE_USER_TENANT clear';
ob1.mysql set ob_global_debug_sync = 'now signal signal_create_user_tenant$user_tenant_id';
ob1.mysql drop tenant mysql force;
ob1.check_until_timeout select count(*) from gv\$ob_units where tenant_id in ($meta_tenant_id, $user_tenant_id), 0, 600;
============================================================
三个线程顺序：meta user ls
============================================================
ob1.mysql set ob_global_debug_sync = 'BEFORE_CREATE_META_TENANT wait_for signal_create_meta_tenant$user_tenant_id execute 10000';
ob1.mysql set ob_global_debug_sync = 'BEFORE_CREATE_USER_TENANT wait_for signal_create_user_tenant$user_tenant_id execute 10000';
ob1.mysql set ob_global_debug_sync = 'BEFORE_CREATE_TENANT_FILL_USER_LS_INFO wait_for signal_fill_user_ls_info$user_tenant_id execute 10000';
create tenant mysql resource_pool_list=('pool'), primary_zone='z2';
ob1.mysql set ob_global_debug_sync = 'BEFORE_CREATE_META_TENANT clear';
ob1.mysql set ob_global_debug_sync = 'now signal signal_create_meta_tenant$user_tenant_id';
ob1.z1.obs0.check_rs_log_until_success -c 'STEP 2. finish create normal tenant.*tenant_id.$meta_tenant_id';
ob1.mysql set ob_global_debug_sync = 'BEFORE_CREATE_USER_TENANT clear';
ob1.mysql set ob_global_debug_sync = 'now signal signal_create_user_tenant$user_tenant_id';
ob1.z1.obs0.check_rs_log_until_success -c 'STEP 2. finish create normal tenant.*tenant_id.$user_tenant_id';
ob1.mysql set ob_global_debug_sync = 'BEFORE_CREATE_TENANT_FILL_USER_LS_INFO clear';
ob1.mysql set ob_global_debug_sync = 'now signal signal_fill_user_ls_info$user_tenant_id';
ob1.mysql drop tenant mysql force;
ob1.check_until_timeout select count(*) from gv\$ob_units where tenant_id in ($meta_tenant_id, $user_tenant_id), 0, 600;
============================================================
三个线程顺序：user meta ls
============================================================
ob1.mysql set ob_global_debug_sync = 'BEFORE_CREATE_META_TENANT wait_for signal_create_meta_tenant$user_tenant_id execute 10000';
ob1.mysql set ob_global_debug_sync = 'BEFORE_CREATE_USER_TENANT wait_for signal_create_user_tenant$user_tenant_id execute 10000';
ob1.mysql set ob_global_debug_sync = 'BEFORE_CREATE_TENANT_FILL_USER_LS_INFO wait_for signal_fill_user_ls_info$user_tenant_id execute 10000';
create tenant mysql resource_pool_list=('pool'), primary_zone='z2';
ob1.mysql set ob_global_debug_sync = 'BEFORE_CREATE_USER_TENANT clear';
ob1.mysql set ob_global_debug_sync = 'now signal signal_create_user_tenant$user_tenant_id';
ob1.z1.obs0.check_rs_log_until_success -c 'STEP 2. finish create normal tenant.*tenant_id.$user_tenant_id';
ob1.mysql set ob_global_debug_sync = 'BEFORE_CREATE_META_TENANT clear';
ob1.mysql set ob_global_debug_sync = 'now signal signal_create_meta_tenant$user_tenant_id';
ob1.z1.obs0.check_rs_log_until_success -c 'STEP 2. finish create normal tenant.*tenant_id.$meta_tenant_id';
ob1.mysql set ob_global_debug_sync = 'BEFORE_CREATE_TENANT_FILL_USER_LS_INFO clear';
ob1.mysql set ob_global_debug_sync = 'now signal signal_fill_user_ls_info$user_tenant_id';
ob1.mysql drop tenant mysql force;
ob1.check_until_timeout select count(*) from gv\$ob_units where tenant_id in ($meta_tenant_id, $user_tenant_id), 0, 600;
