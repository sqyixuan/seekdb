ob1.mysql alter system set_tp tp_name=ERRSIM_CREATE_USER_LS_ERROR, error_code=4002, frequency = 0;
ob1.check_until_timeout select count(*) from gv\$ob_units where tenant_id in ($meta_tenant_id, $user_tenant_id), 0, 600;
