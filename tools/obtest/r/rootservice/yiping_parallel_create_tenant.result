创建tablet失败时，创建user ls线程会快速失败
============================================================
ob1.mysql alter system set_tp tp_name=ERRSIM_CREATE_SYS_TABLETS_ERROR, error_code=4016, frequency = 1;
create tenant mysql resource_pool_list=('pool');
ERROR HY000: Internal error
select count(*) from dba_ob_tenants where tenant_id in (1023, 1024);
count(*)
0
ob1.z1.obs0.check_rs_log_until_success -c 'failed to check user tenant table writable.*OB_CANCELED.*user_tenant_id.$user_tenant_id';
ob1.mysql alter system set_tp tp_name=ERRSIM_CREATE_USER_NORMAL_TENANT_ERROR, error_code=4016, frequency = 0;
ob1.mysql alter system set_tp tp_name=ERRSIM_CREATE_USER_LS_ERROR, error_code=4002, frequency = 0;
