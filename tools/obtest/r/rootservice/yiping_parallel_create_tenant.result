ob1.mysql alter system set_tp tp_name=ERRSIM_CREATE_USER_NORMAL_TENANT_ERROR, error_code=4016, frequency = 0;
ob1.check_until_timeout select count(*) from gv\$ob_units where tenant_id in ($meta_tenant_id, $user_tenant_id), 0, 600;
============================================================
user租户create normal tenant前rs切主
============================================================
ob1.mysql set ob_global_debug_sync = 'BEFORE_CREATE_USER_NORMAL_TENANT wait_for signal_create_meta_tenant$user_tenant_id execute 10000';
ob1.mysql set ob_global_debug_sync = 'BEFORE_CHECK_CREATE_NORMAL_TENANT_RESULT wait_for signal_check$user_tenant_id execute 10000';
create tenant mysql resource_pool_list=('pool');
ob1.z1.obs0.check_rs_log_until_success -c 'STEP 2. finish create normal tenant.*tenant_id.$meta_tenant_id';
ob1.mysql alter tenant sys set primary_zone='z2';
ob1.check_until_timeout select role from __all_ls_meta_table where tenant_id=1 and ls_id=1 and zone='z2', 1, 600;
ob1.check_until_timeout select count(*) - $full_rootservice_count a from dba_ob_rootservice_event_history where event='full_rootservice', 1, 600;
ob1.mysql set ob_global_debug_sync = 'BEFORE_CREATE_USER_NORMAL_TENANT clear';
ob1.mysql set ob_global_debug_sync = 'now signal signal_create_meta_tenant$user_tenant_id';
ob1.z2.obs0.check_rs_log_until_success -c 'STEP 2. finish create normal tenant.*tenant_id.$user_tenant_id';
ob1.mysql alter tenant sys set primary_zone='z1';
ob1.check_until_timeout select role from __all_ls_meta_table where tenant_id=1 and ls_id=1 and zone='z1', 1, 600;
ob1.check_until_timeout select count(*) - $full_rootservice_count a from dba_ob_rootservice_event_history where event='full_rootservice', 1, 600;
ob1.mysql set ob_global_debug_sync = 'BEFORE_CHECK_CREATE_NORMAL_TENANT_RESULT clear';
ob1.mysql set ob_global_debug_sync = 'now signal signal_check$user_tenant_id';
ob1.mysql drop tenant mysql force;
ob1.check_until_timeout select count(*) from gv\$ob_units where tenant_id in ($meta_tenant_id, $user_tenant_id), 0, 600;
