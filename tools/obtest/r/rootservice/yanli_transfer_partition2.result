ob1=OBI(cluster=2:2,proxy_num=0);
ob1.set extra_config=$mini_ob_config;
ob1.reboot;
alter system set balancer_idle_time = '10s';
ob1.mysql alter system set debug_sync_timeout = '1000s';
ob1.mysql alter system set _transfer_start_trans_timeout = '10s';
set @@session.ob_query_timeout = 1000000000;
CREATE RESOURCE UNIT unit_1 MAX_CPU 1, MEMORY_SIZE '2G';
CREATE RESOURCE POOL pool_2 UNIT = 'unit_1', UNIT_NUM = 1, zone_list = ('z1');
CREATE TENANT mysql RESOURCE_POOL_LIST = ('pool_2'), primary_zone='z1' set ob_tcp_invited_nodes='%', autocommit='on';
alter system transfer partition table_id = 1, object_id= 1 to ls 1001 tenant = 'mysql';
ERROR HY000: Transfer partition of 'SYSTEM TABLE' is not allowed
alter system transfer partition table_id = 1, object_id= 1 to ls 1001 tenant = 'mysql';
ERROR HY000: Transfer partition of 'SYSTEM TABLE' is not allowed
alter system transfer partition table_id = 1, object_id= 1 to ls 1001 tenant = 'mysql';
ERROR HY000: Transfer partition of 'SYSTEM TABLE' is not allowed
ob1.mysql drop tenant mysql force;
CREATE RESOURCE POOL pool_1 UNIT = 'unit_1', UNIT_NUM = 2;
CREATE TENANT oracle RESOURCE_POOL_LIST = ('pool_1'), primary_zone='z1' set ob_tcp_invited_nodes='%',ob_compatibility_mode='oracle', autocommit='on';
ob1.mysql alter system set balancer_idle_time = '10s' tenant = 'oracle';
ob1.mysql alter system set _transfer_service_wakeup_interval = '5s' tenant = 'oracle';
ob1.mysql alter system set _transfer_task_retry_interval = '0' tenant='oracle';
set recyclebin=off;
ob1.mysql set ob_global_debug_sync = 'BEFORE_TENANT_BALANCE_SERVICE wait_for signal';
ob1.mysql set ob_global_debug_sync = 'now signal signal';
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_balance_job, 1, 30;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_balance_job_history, 1, 400;
ob1.mysql set ob_global_debug_sync = 'AFTER_TRANSFER_PROCESS_INIT_TASK_AND_BEFORE_NOTIFY_STORAGE wait_for signal1';
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_balance_job, 1, 100;
ob1.check_until_timeout select count(*) > 0 from oceanbase.__all_virtual_transfer_task, 1, 100;
ob1.mysql alter system set enable_transfer = false tenant = 'oracle';
ob1.mysql alter system set enable_rebalance = false tenant = 'oracle';
ob1.check_until_timeout select status from oceanbase.__all_virtual_balance_job, CANCELING, 100;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_balance_job, 0, 100;
ob1.mysql set ob_global_debug_sync = 'now signal signal1';
ob1.mysql alter system set enable_transfer = true tenant = 'oracle';
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_balance_job, 1, 100;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_balance_job, 0, 200;
select balance_strategy_name, job_type, target_unit_num, target_primary_zone_num, status, comment from oceanbase.__all_balance_job_history;
balance_strategy_name	job_type	target_unit_num	target_primary_zone_num	status	comment
ob1.mysql_p select distinct status from oceanbase.__all_virtual_transfer_partition_task_history;
status
COMPLETED
ob1.mysql alter system set enable_rebalance = true tenant = 'oracle';
ob1.mysql set ob_global_debug_sync = 'BEFORE_TENANT_BALANCE_SERVICE wait_for signal';
ob1.mysql set ob_global_debug_sync = 'BEFORE_PROCESS_AFTER_HAS_MEMBER_LIST wait_for signal1';
ob1.mysql alter tenant oracle set primary_zone = 'z1, z2';
ob1.mysql set ob_global_debug_sync = 'now signal signal';
ob1.check_until_timeout select count(*) >= 1 from oceanbase.__all_virtual_ls_status where status = 'CREATING', 1, 100;
ob1.mysql alter tenant oracle set primary_zone = 'z2';
ob1.check_until_timeout select status from oceanbase.__all_virtual_balance_job, CANCELING, 100;
ob1.mysql alter system set enable_rebalance = false tenant = 'oracle';
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_balance_job, 0, 100;
ob1.mysql_p select * from oceanbase.__all_virtual_balance_job, 0, 100;
ob1.mysql set ob_global_debug_sync = 'now signal signal1';
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_balance_job, 1, 100;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_balance_job, 0, 200;
ob1.mysql alter system set enable_rebalance = true tenant = 'oracle';
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_balance_job, 1, 100;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_balance_job, 0, 100;
ob1.mysql alter system set enable_rebalance = false tenant = 'oracle';
ob1.mysql set ob_global_debug_sync = 'BEFORE_TENANT_BALANCE_SERVICE wait_for signal';
ob1.mysql set ob_global_debug_sync = 'BEFORE_PROCESS_BALANCE_TASK_ALTER_LS wait_for signal1';
ob1.mysql set ob_global_debug_sync = 'now signal signal';
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_balance_task where task_type = 'LS_ALTER' and status = 'ALTER_LS', 1, 100;
ob1.mysql set ob_global_debug_sync = 'now signal signal1';
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_balance_job, 0, 100;
ob1.mysql set ob_global_debug_sync = 'BEFORE_TENANT_BALANCE_SERVICE wait_for signal3';
ob1.mysql_p select count(*) from oceanbase.__all_virtual_transfer_partition_task;
count(*)
10
ob1.mysql set ob_global_debug_sync = 'BEFORE_PROCESS_BALANCE_TASK_DROP_LS wait_for signal4';
ob1.mysql set ob_global_debug_sync = 'now signal signal3';
ob1.check_until_timeout select count(*) < 9 from oceanbase.__all_virtual_transfer_partition_task, 1, 100;
ob1.mysql set ob_global_debug_sync = 'AFTER_LOCK_ALL_BALANCE_JOB wait_for signal5';
ob1.mysql set ob_global_debug_sync = 'now signal signal4';
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_balance_job, 0, 200;
ob1.mysql_p select count(*) > 0 from oceanbase.__all_virtual_transfer_partition_task;
count(*) > 0
1
ob1.mysql set ob_global_debug_sync = 'now signal signal5';
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_balance_job_history where job_id > $balance_job_id, 1, 100;
ob1.mysql_p select balance_strategy_name, job_type, target_unit_num, target_primary_zone_num, status, comment from oceanbase.__all_virtual_balance_job_history;
balance_strategy_name	job_type	target_unit_num	target_primary_zone_num	status	comment
