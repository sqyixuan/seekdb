ob1=OBI(cluster=2:2:2, proxy_num=0, node_cpu_count=64, node_cpu_reserved=2);
ob1.reboot;
ob1.mysql alter system set enable_rebalance = 'false';
ob1.mysql alter system set balancer_idle_time = '10s';
ob1.mysql CREATE RESOURCE UNIT test_unit MAX_CPU 1, memory_size '4G';
ob1.mysql CREATE RESOURCE UNIT test_unit2 MAX_CPU 2, memory_size '4G';
CREATE RESOURCE POOL tt1_pool0 UNIT = 'test_unit', UNIT_NUM = 1, ZONE_LIST = ('z1', 'z2', 'z3');
CREATE RESOURCE POOL tt2_pool0 UNIT = 'test_unit', UNIT_NUM = 2, ZONE_LIST = ('z1', 'z2', 'z3');
CREATE RESOURCE POOL tt3_pool0 UNIT = 'test_unit', UNIT_NUM = 1, ZONE_LIST = ('z1', 'z2');
CREATE RESOURCE POOL not_grant UNIT = 'test_unit', UNIT_NUM = 2, ZONE_LIST = ('z1', 'z2', 'z3');
CREATE TENANT tt1 RESOURCE_POOL_LIST = ('tt1_pool0') set ob_tcp_invited_nodes='%';
CREATE TENANT tt2 RESOURCE_POOL_LIST = ('tt2_pool0') set ob_tcp_invited_nodes='%';
CREATE TENANT tt3 RESOURCE_POOL_LIST = ('tt3_pool0'), locality = "F@z1,F@z2" set ob_tcp_invited_nodes='%';
select resource_pool_id, name, unit_count, unit_config_id, zone_list, tenant_id, replica_type from oceanbase.__all_resource_pool where resource_pool_id != 1 order by resource_pool_id desc;
resource_pool_id	name	unit_count	unit_config_id	zone_list	tenant_id	replica_type
1004	not_grant	2	1001	z1;z2;z3	-1	0
1003	tt3_pool0	1	1001	z1;z2	1006	0
1002	tt2_pool0	2	1001	z1;z2;z3	1004	0
1001	tt1_pool0	1	1001	z1;z2;z3	1002	0
select unit_id, resource_pool_id, zone, status from oceanbase.__all_unit where resource_pool_id != 1 order by unit_id desc;
unit_id	resource_pool_id	zone	status
