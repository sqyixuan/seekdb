1001	1001	z1	ACTIVE
ALTER RESOURCE POOL tt1_pool0 SPLIT INTO ('tt1_pool0', 'tt1_pool1', 'tt1_pool2') ON ('z1', 'z2', 'z3');
ERROR HY000: resource pool 'tt1_pool0' exist
ALTER RESOURCE POOL tt1_pool0 SPLIT INTO ('tt1_pool1', 'tt1_pool1', 'tt1_pool2') ON ('z1', 'z2', 'z3');
ERROR HY000: Incorrect arguments to resource pool name
ALTER RESOURCE POOL tt1_pool0 SPLIT INTO ('tt1_pool1', 'tt1_pool2', 'tt1_pool3') ON ('z1', 'z1', 'z3');
ERROR HY000: Incorrect arguments to duplidate zones in corresponding zone vector
ALTER RESOURCE POOL tt1_pool0 SPLIT INTO ('tt1_pool1', 'tt1_pool2', 'tt1_pool3') ON ('z1', 'z2');
ERROR HY000: Incorrect arguments to split pool and zone count
ALTER RESOURCE POOL tt1_pool0 SPLIT INTO ('tt1_pool1', 'tt1_pool2', 'tt1_pool3') ON ('z1', 'z2', 'z3');
ALTER RESOURCE POOL tt2_pool0 SPLIT INTO ('tt2_pool1', 'tt2_pool2', 'tt2_pool3') ON ('z1', 'z2', 'z3');
ALTER RESOURCE POOL tt3_pool0 SPLIT INTO ('tt3_pool2', 'tt3_pool3') ON ('z1', 'z2');
ALTER RESOURCE POOL not_grant SPLIT INTO ('not_grant1', 'not_grant2', 'not_grant3') ON ('z1', 'z2', 'z3');
ALTER TENANT tt1 locality = "F@z1,F@z2,F@z3";
ob1.check_until_timeout select count(*) c from oceanbase.__all_tenant where tenant_id = $tenant_id and previous_locality != '', 0, 600;
ALTER TENANT tt1 locality = "F@z1,F@z2";
ob1.check_until_timeout select count(*) c from oceanbase.__all_tenant where tenant_id = $tenant_id and previous_locality != '', 0, 600;
ALTER TENANT tt1 resource_pool_list = ('tt1_pool1','tt1_pool2');
DROP RESOURCE POOL tt1_pool3;
ALTER TENANT tt3 locality = "F@z1,F@z2";
ob1.check_until_timeout select count(*) c from oceanbase.__all_tenant where tenant_id = $tenant_id and previous_locality != '', 0, 600;
ALTER TENANT tt3 resource_pool_list = ('tt3_pool2','tt3_pool3');
ALTER RESOURCE POOL not_grant1 unit_num = 1;
ALTER RESOURCE POOL not_grant2 unit_num = 1;
ALTER RESOURCE POOL not_grant3 unit_num = 1;
ob1.check_until_timeout select count(*) c from oceanbase.__all_unit where STATUS = 'DELETING', 0, 600;
