ob1=OBI(cluster=1:1:1, proxy_num=0,init_unit_cpu=0);
ob1.reboot;
ob1.mysql alter tenant sys set primary_zone = 'z1';
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_core_meta_table where role = 1 and zone ='z1', 1, 30;
'CASE 1'
ob1.z2.obs0.force_stop;
ob1.mysql_p select count(*) from oceanbase.__all_server where status='active';
count(*)
2
ob1.mysql_p select value like '%${rs_leader_addr}%' as in_list from oceanbase.__all_sys_parameter where name = 'rootservice_list';
in_list
1
ob1.mysql_p select value like '%${rs2_addr}%' as in_list from oceanbase.__all_sys_parameter where name = 'rootservice_list';
in_list
0
ob1.z2.obs0.start;
ob1.check_until_timeout select count(*) from oceanbase.__all_server where status='active', 3, 100;
ob1.mysql_p select value like '%${rs2_addr}%' as in_list from oceanbase.__all_sys_parameter where name = 'rootservice_list';
in_list
1
'CASE 2'
ob1.z1.obs0.force_stop;
ob1.z2.obs0.mysql_p select count(*) from oceanbase.__all_server where status='active';
count(*)
2
'rs leader changed'
ob1.z1.obs0.start;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_core_meta_table where role = 1 and zone ='z1', 1, 30;
ob1.check_until_timeout select count(*) from oceanbase.__all_server where status='active', 3, 100;
ob1.z2.obs0.mysql_p select value like '%${rs2_addr}%' as in_list from oceanbase.__all_sys_parameter where name = 'rootservice_list';
in_list
1
