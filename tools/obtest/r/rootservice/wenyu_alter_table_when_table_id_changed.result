ob1=OBI(cluster=1:1,proxy_num=0);
ob1.set extra_config=$mini_ob_config;
ob1.reboot;
CREATE RESOURCE UNIT unit_1 MAX_CPU 2, MEMORY_SIZE '4G';
CREATE RESOURCE POOL pool_1 UNIT = 'unit_1', UNIT_NUM = 1;
CREATE TENANT oracle RESOURCE_POOL_LIST = ('pool_1'), primary_zone='z1' set ob_tcp_invited_nodes='%', ob_compatibility_mode='oracle';
alter system set debug_sync_timeout = '1000s';
set ob_global_debug_sync = 'BEFORE_SEND_ALTER_TABLE wait_for signal execute 1';
alter system set _parallel_ddl_control = 'set_comment:off' tenant oracle;
create table t1 (col1 int);
comment on table t1 is 'TC';
drop table t1;
create table t1 (col1 int);
set ob_global_debug_sync = 'now signal signal';
select comments from DBA_TAB_COMMENTS where table_name = 'T1';
COMMENTS
TC
