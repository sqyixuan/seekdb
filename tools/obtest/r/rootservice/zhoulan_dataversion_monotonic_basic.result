ob1=OBI(cluster=1:1:1,oblog_version=current,proxy_num=0,asvr_num=1);
ob1.set cid=1;
ob2=OBI(cluster=1:1:1,oblog_version=current,proxy_num=0);
ob2.set cid=1;
ob3=OBI(cluster=1:1:1,oblog_version=current,proxy_num=0);
ob3.set cid=2;
ob1.reboot;
ob2.reboot;
ob3.reboot;
ob1.mysql create resource unit box1 max_cpu 2,memory_size 5368709120;
ob1.mysql create resource pool pool1 unit = 'box1', unit_num = 1;
ob1.mysql create tenant mysql resource_pool_list=('pool1'), locality='F@z1, F@z2, R@z3', primary_zone='RANDOM', enable_arbitration_service=true set ob_tcp_invited_nodes='%', ob_compatibility_mode='mysql';
alter system set syslog_level = 'rpc.obrpc:trace';
create user rep_user IDENTIFIED BY 'rep_user';
grant select on oceanbase.* TO rep_user;
create resource unit box2 max_cpu 2,memory_size 5368709120;
create resource pool pool2 unit = 'box2', unit_num = 1;
create resource unit box1 max_cpu 2,memory_size 5368709120;
create resource pool pool1 unit = 'box1', unit_num = 1;
create tenant mysql resource_pool_list=('pool1') set ob_tcp_invited_nodes='%', ob_compatibility_mode='mysql';
create resource unit box2 max_cpu 2,memory_size 5368709120;
create resource pool pool2 unit = 'box2', unit_num = 1;
