500147	t6_normal	p9	NULL	200098	1003
ob1.mysql set ob_global_debug_sync = 'BEFORE_LOCK_LS_WHEN_CREATE_TABLE wait_for signal_lock_create_table1 execute 10000';
create table t6(c1 int) partition by hash(c1) partitions 10;
alter system change tenant mysql;
update oceanbase.__all_ls set status = 'DROPPED' where ls_id = 1001;
ob1.mysql set ob_global_debug_sync = 'BEFORE_LOCK_LS_WHEN_CREATE_TABLE clear';
ob1.mysql set ob_global_debug_sync = 'now signal signal_lock_create_table1';
set ob_global_debug_sync = 'reset';
# no tablet on 1001
ob1.check_until_timeout select count(*) from oceanbase.DBA_OB_TABLE_LOCATIONS WHERE TABLE_NAME = 't6' AND ROLE = 'LEADER' and ls_id = 1001, 0, 3;
alter system change tenant mysql;
update oceanbase.__all_ls set status = 'NORMAL' where ls_id = 1001;
############################
# 7 test ls balance task transaction timeout
ob1.mysql alter system set debug_sync_timeout = 0;
ob1.check_until_timeout select count(*) from CDB_OB_BALANCE_JOBS, 0, 60;
# shrink can be executed when finish transfer task cost too much time
ob1.mysql alter system set internal_sql_execute_timeout = '30s';
ob1.mysql alter system set_tp tp_name = EN_FINISH_TRANSFER_TASK_COST_TOO_MUCH_TIME, error_code = 4012, frequency = 1;
ob1.mysql alter tenant mysql primary_zone = 'z1';
ob1.check_until_timeout select count(*) from CDB_OB_BALANCE_JOBS where tenant_id = $mysql_tenant_id and BALANCE_STRATEGY like "%LS balance by shrink%", 1, 60;
ob1.check_until_timeout select count(*) from CDB_OB_BALANCE_JOBS where tenant_id = $mysql_tenant_id, 0, 120;
# expand can be executed when finish transfer task cost too much time
ob1.mysql alter tenant mysql primary_zone = 'z1,z2';
ob1.check_until_timeout select count(*) from CDB_OB_BALANCE_JOBS where tenant_id = $mysql_tenant_id and BALANCE_STRATEGY like "%LS balance by expand%", 1, 60;
ob1.check_until_timeout select count(*) from CDB_OB_BALANCE_JOBS where tenant_id = $mysql_tenant_id, 0, 120;
