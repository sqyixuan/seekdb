ob1=OBI(cluster=1:1:1,proxy_num=0,init_unit_cpu=0);
ob1.set extra_config=$mini_ob_config;
ob1.reboot;
ob1.mysql alter system set debug_sync_timeout = '1000s';
ob1.mysql ALTER SYSTEM SET enable_rebalance = 'false';
ob1.mysql ALTER SYSTEM SET enable_rereplication = 'true';
=========================================
create mysql tenant with C replica
=========================================
set @@session.ob_query_timeout = 200000000;
alter system set __min_full_resource_pool_memory=1073741824;
use oceanbase;
ob1.mysql CREATE RESOURCE POOL tenant_pool UNIT = "2c2g", UNIT_NUM = 1, ZONE_LIST = ('z1', 'z2', 'z3');
ob1.mysql CREATE TENANT mysql RESOURCE_POOL_LIST=('tenant_pool'), LOCALITY = "F@z1, F@z2, C@z3", PRIMARY_ZONE = "z1;z2;z3" SET ob_tcp_invited_nodes='%';
======================================================
errsim and set role to follower in meta table
======================================================
ob1.mysql alter system set_tp tp_name = ERRSIM_NOT_UPDATE_LS_META_TABLE, error_code = 4002, frequency = 1;
alter system change tenant tenant_id = 1001;
check location cache is FFC
ob1.z1.obs0.check_log_until_success -c ".*dump tenant ls location caches.*tenant_id:1002, ls_id:{id:1001.*replica_type:\"COLUMNSTORE\".*";
update __all_ls_meta_table set role = 2 where ls_id = 1001;
check location cache is still FFC after meta_table has no leader
ob1.z1.obs0.sh cd $work_dir/ && rm -rf log/observer*;
ob1.z1.obs0.check_log_until_success -c ".*dump tenant ls location caches.*tenant_id:1002, ls_id:{id:1001.*replica_type:\"COLUMNSTORE\".*";
alter system change tenant tenant_id = 1;
ob1.mysql alter system set_tp tp_name = ERRSIM_NOT_UPDATE_LS_META_TABLE, error_code = 4002, frequency = 0;
ob1.check_until_timeout select count(*) as cnt from oceanbase.__all_virtual_ls_meta_table where tenant_id = $tenant_id and ls_id = 1001 and role = 1, 1, 20;
=====================================================================
errsim and remove C-replica from leanrer_list in meta table
=====================================================================
ob1.mysql alter system set_tp tp_name = ERRSIM_NOT_UPDATE_LS_META_TABLE, error_code = 4002, frequency = 1;
alter system change tenant tenant_id = 1001;
check location cache is FFC
ob1.z1.obs0.check_log_until_success -c ".*dump tenant ls location caches.*tenant_id:1002, ls_id:{id:1001.*replica_type:\"COLUMNSTORE\".*";
update __all_ls_meta_table set learner_list = "" where ls_id = 1001;
check location cache is still FFC when replica not in leader learner list
ob1.z1.obs0.sh cd $work_dir/ && rm -rf log/observer*;
ob1.z1.obs0.check_log_until_success -c ".*dump tenant ls location caches.*tenant_id:1002, ls_id:{id:1001.*replica_type:\"COLUMNSTORE\".*";
