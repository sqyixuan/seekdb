set @@session.recyclebin = on;
set @@session.ob_enable_truncate_flashback = on;
grant select on sys.tb_for_obj_priv_3 to user_for_obj_priv;
truncate table sys.tb_for_obj_priv_3;
create user column_priv_user;
create table column_priv_table(c1 int, c2 int);
grant select(c1) on column_priv_table to column_priv_user;
revoke select(c1) on column_priv_table from column_priv_user;
grant select(c2) on column_priv_table to column_priv_user;
drop table column_priv_table;
drop table sys.tb_for_obj_priv_3 purge;
ob1.mysql_p select is_deleted from oceanbase.__all_virtual_objauth_history where tenant_id = $oracle_tenant_id and obj_id = $obj_priv_tid_3 order by schema_version desc;
is_deleted
1
0
ob1.mysql_p select is_deleted from oceanbase.__all_virtual_objauth_history where tenant_id = $oracle_tenant_id and obj_id = $obj_priv_tid_3_new order by schema_version desc;
is_deleted
1
0
create table t_cg(c1 int, c2 int) with column group(all columns, each column);
alter table t_cg add index idx1(c1) with column group(all columns, each column);
drop table t_cg;
create table t_cg_2(c1 int, c2 int);
alter table t_cg_2 add column group(all columns, each column);
create table t_cg_3(c1 int, c2 int) with column group(all columns, each column);
alter table t_cg_3 drop column group(all columns, each column);
create concurrent_limiting_rule global_emergency_ccl_rule
ON test.`t1`
TO `%`@`%`
for select
filter by keyword(`t1`, `id=123`)
with max_concurrency = 100;
drop concurrent_limiting_rule global_emergency_ccl_rule;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_ccl_rule_history, 2, 60;
create table t_sens_1(a int, b int, c int);
create sensitive rule recycle_r1 on t_sens_1(b) using encryption;
drop sensitive rule recycle_r1;
drop table t_sens_1;
call DBMS_AI_SERVICE.CREATE_AI_MODEL('my_ai_model_1', '{"type": "dense_embedding", "model_name": "text-embedding-v1" }');
call DBMS_AI_SERVICE.DROP_AI_MODEL('my_ai_model_1');
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_ai_model_history, 2, 60;
set @@session.recyclebin = off;
set @@session.ob_enable_truncate_flashback = off;
ob1.mysql alter system set schema_history_recycle_interval = "10s";
ob1.mysql alter system set merger_check_interval='10s' tenant sys;
ob1.mysql alter system set merger_check_interval='10s' tenant all_user;
ob1.mysql alter system set merger_check_interval='10s' tenant all_meta;
ob1.mysql alter system set ob_compaction_schedule_interval='10s' tenant sys;
ob1.mysql alter system set ob_compaction_schedule_interval='10s' tenant all_user;
ob1.mysql alter system set ob_compaction_schedule_interval='10s' tenant all_meta;
ob1.mysql alter system major freeze tenant=sys;
ob1.mysql alter system major freeze tenant=all_user;
ob1.mysql alter system major freeze tenant=all_meta;
