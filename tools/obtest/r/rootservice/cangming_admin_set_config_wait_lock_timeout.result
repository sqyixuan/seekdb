ob1=OBI(cluster=1, proxy_num=0, init_unit_cpu=0);
ob1.reboot;
ob1.mysql alter system set debug_sync_timeout = '100000s';
ob1.mysql set ob_global_debug_sync = 'BEFORE_EXECUTE_ADMIN_SET_CONFIG wait_for signal1 execute 1';
set ob_query_timeout = 5000000;
ALTER SYSTEM SET server_permanent_offline_time = '1h';
ERROR HY000: Timeout
ob1.check_until_timeout select count(*) from oceanbase.__all_rootservice_event_history where module like 'root_service' and event like 'admin_set_config' and value2 like '%server_permanent_offline_time%', 0, 1;
ALTER SYSTEM SET server_permanent_offline_time = '2h';
ERROR HY000: Timeout
ALTER SYSTEM SET server_permanent_offline_time = '3h';
ERROR HY000: Timeout
ALTER SYSTEM SET server_permanent_offline_time = '4h';
ERROR HY000: Timeout
ob1.check_until_timeout select count(*) from oceanbase.__all_rootservice_event_history where module like 'root_service' and event like 'admin_set_config' and value2 like '%server_permanent_offline_time%', 3, 1;
ob1.mysql set ob_global_debug_sync = 'now signal signal1';
ob1.check_until_timeout select count(*) from oceanbase.__all_rootservice_event_history where module like 'root_service' and event like 'admin_set_config' and value2 like '%server_permanent_offline_time%', 4, 1;
ALTER SYSTEM SET server_permanent_offline_time = '5h';
ob1.check_until_timeout select count(*) from oceanbase.__all_rootservice_event_history where module like 'root_service' and event like 'admin_set_config' and value2 like '%server_permanent_offline_time%', 5, 1;
select module, event, value1 ret, value2 arg from oceanbase.__all_rootservice_event_history where module like 'root_service' and event like 'admin_set_config' and value2 like '%server_permanent_offline_time%' order by 1;
module	event	ret	arg
root_service	admin_set_config	-4012	{name:"server_permanent_offline_time", value:"2h", comment:"", zone:"", server:"0.0.0.0:0", tenant_name:"", exec_tenant_id:1, tenant_ids:[], want_to_set_tenant_config:false}
root_service	admin_set_config	-4012	{name:"server_permanent_offline_time", value:"3h", comment:"", zone:"", server:"0.0.0.0:0", tenant_name:"", exec_tenant_id:1, tenant_ids:[], want_to_set_tenant_config:false}
root_service	admin_set_config	-4012	{name:"server_permanent_offline_time", value:"4h", comment:"", zone:"", server:"0.0.0.0:0", tenant_name:"", exec_tenant_id:1, tenant_ids:[], want_to_set_tenant_config:false}
root_service	admin_set_config	-4012	{name:"server_permanent_offline_time", value:"1h", comment:"", zone:"", server:"0.0.0.0:0", tenant_name:"", exec_tenant_id:1, tenant_ids:[], want_to_set_tenant_config:false}
