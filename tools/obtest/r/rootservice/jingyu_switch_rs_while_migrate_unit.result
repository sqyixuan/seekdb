ob1.check_until_timeout SELECT COUNT(*) as cnt FROM oceanbase.CDB_OB_LS_LOCATIONS WHERE tenant_id = $meta_tenant_id AND role = "LEADER" AND member_list like "%$z2_dst0%", 0, 20;
