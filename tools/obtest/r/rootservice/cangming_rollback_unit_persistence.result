ob1=OBI(cluster=2,proxy_num=0);
ob1.reboot;
ob1.mysql CREATE RESOURCE UNIT 1c2g MAX_CPU 1, MEMORY_SIZE '2G';
ob1.mysql CREATE RESOURCE POOL pool1 UNIT='1c2g',UNIT_NUM=1,ZONE_LIST=('z1');
ob1.mysql alter system set_tp tp_name = ERRSIM_UNIT_PERSISTENCE_ERROR, error_code = 4016, frequency = 1;
CREATE TENANT IF NOT EXISTS test_tenant ZONE_LIST=('z1'), RESOURCE_POOL_LIST=('pool1');
ERROR HY000: Internal error
ob1.check_until_timeout select count(*) from __all_virtual_unit, $count, 180;
ob1.mysql alter system set_tp tp_name = ERRSIM_UNIT_PERSISTENCE_ERROR, error_code = 4016, frequency = 0;
CREATE TENANT IF NOT EXISTS test_tenant ZONE_LIST=('z1'), RESOURCE_POOL_LIST=('pool1');
ob1.mysql alter system set_tp tp_name = ERRSIM_UNIT_PERSISTENCE_ERROR, error_code = 4016, frequency = 1;
ALTER RESOURCE TENANT test_tenant  UNIT_NUM=2;
ERROR HY000: Internal error
ob1.check_until_timeout select count(*) from __all_virtual_unit, $count, 180;
ob1.mysql alter system set_tp tp_name = ERRSIM_UNIT_PERSISTENCE_ERROR, error_code = 4016, frequency = 0;
ob1.mysql ALTER RESOURCE TENANT test_tenant UNIT_NUM=2;
ob1.mysql DROP TENANT test_tenant FORCE;
ob1.z1.obs1.force_stop;
ob1.check_until_timeout select count(*) from __all_server where svr_ip='$dest_ip' and svr_port=$dest_port and status='INACTIVE',1,15;
ob1.mysql CREATE RESOURCE POOL pool2 UNIT='1c2g',UNIT_NUM=1,ZONE_LIST=('z1');
CREATE TENANT IF NOT EXISTS test_tenant2 ZONE_LIST=('z1'), RESOURCE_POOL_LIST=('pool2');
ob1.z1.obs1.start;
ob1.check_until_timeout select count(*) from __all_server where svr_ip='$dest_ip' and svr_port=$dest_port and status='ACTIVE' and start_service_time > 0,1,120;
ob1.check_until_timeout select count(*) from __all_virtual_unit where TENANT_ID = $tid, 1, 240;
ob1.mysql alter system set_tp tp_name = ERRSIM_UNIT_PERSISTENCE_ERROR, error_code = 4016, frequency = 1;
ERROR HY000: Internal error
ob1.check_until_timeout select count(*) from __all_virtual_unit where svr_ip='$dest_ip' and svr_port=$dest_port, 0, 180;
ob1.mysql alter system set_tp tp_name = ERRSIM_UNIT_PERSISTENCE_ERROR, error_code = 4016, frequency = 0;
ob1.mysql alter system migrate unit $uid destination '$dest_ip:$dest_port';
