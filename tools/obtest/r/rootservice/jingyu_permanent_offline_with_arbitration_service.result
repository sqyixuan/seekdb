ob1=OBI(cluster=1:1:1:1,proxy_num=0,init_unit_cpu=0,asvr_num=1);
ob1.set extra_config=$mini_ob_config;
ob1.reboot;
ob1.mysql alter system set debug_sync_timeout = '1000s';
ob1.mysql ALTER SYSTEM SET enable_rebalance = 'false';
ob1.mysql ALTER SYSTEM SET enable_rereplication = 'true';
ob1.check_until_timeout select count(*) as cnt from oceanbase.DBA_OB_ARBITRATION_SERVICE where arbitration_service = "$arb_svr_ip:$arb_svr_port", 1, 5;
=================================================
enable sys tenant arbitration service
=================================================
alter tenant sys set enable_arbitration_service = true;
ob1.check_until_timeout select count(*) as cnt from oceanbase.DBA_OB_TENANTS where tenant_id = $sys_tenant_id and arbitration_service_status = "ENABLED", 1, 200;
ob1.mysql alter system set server_permanent_offline_time = '20s';
==================================================
shut down observer in z4
==================================================
ob1.z4.obs0.force_stop;
ob1.check_until_timeout select count(*) as cnt from oceanbase.DBA_OB_SERVERS where zone = 'z4' and status = 'INACTIVE', 1, 30;
ob1.check_until_timeout select count(*) as cnt from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id = $sys_tenant_id and role = "LEADER" and member_list like "%$z4_dst0%", 0, 120;
ob1.check_until_timeout select paxos_replica_number from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id = $sys_tenant_id and role = "LEADER", 4, 10;
==================================================
shut down observer in z3
==================================================
ob1.z3.obs0.force_stop;
ob1.check_until_timeout select count(*) as cnt from oceanbase.DBA_OB_SERVERS where zone = 'z3' and status = 'INACTIVE', 1, 30;
ob1.check_until_timeout select count(*) as cnt from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id = $sys_tenant_id and role = "LEADER" and member_list like "%$z3_dst0%", 0, 120;
ob1.check_until_timeout select paxos_replica_number from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id = $sys_tenant_id and role = "LEADER", 3, 10;
==================================================
change locality from 4F to 2F
==================================================
alter tenant sys locality = 'F@z1,F@z2';
ob1.check_until_timeout select count(*) as cnt from oceanbase.DBA_OB_TENANTS where tenant_id = $sys_tenant_id and locality = "FULL{1}@z1, FULL{1}@z2" and previous_locality is null, 1, 200;
ob1.check_until_timeout select paxos_replica_number from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id = $sys_tenant_id and role = "LEADER", 2, 10;
==================================================
shut down observer in z2
==================================================
ob1.z2.obs0.force_stop;
ob1.check_until_timeout select count(*) as cnt from oceanbase.DBA_OB_SERVERS where zone = 'z2' and status = 'INACTIVE', 1, 30;
ob1.check_until_timeout select count(*) as cnt from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id = $sys_tenant_id and role = "LEADER" and member_list like "%$z2_dst0%", 0, 120;
ob1.check_until_timeout select paxos_replica_number from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id = $sys_tenant_id and role = "LEADER", 1, 10;
