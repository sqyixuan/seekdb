ob1=OBI(cluster=2:2:2,init_unit_cpu=0,proxy_num=0);
ob1.z1.obs0.set extra_config=$extra_conf;
ob1.z1.obs1.set extra_config=$extra_conf;
ob1.z2.obs0.set extra_config=$extra_conf;
ob1.z2.obs1.set extra_config=$extra_conf;
ob1.z3.obs0.set extra_config=$extra_conf;
ob1.z3.obs1.set extra_config=$extra_conf;
ob1.reboot;
ob1.mysql alter system set enable_rebalance='false';
ob1.mysql alter system set _transfer_start_trans_timeout = '60s';
ob1.mysql alter system set debug_sync_timeout = '1000s';
set @@session.ob_query_timeout = 1000000000;
# create mysql tenant
CREATE RESOURCE UNIT if not exists unit_1 MAX_CPU 2, MEMORY_SIZE='3G';
CREATE RESOURCE POOL if not exists pool_1 UNIT = 'unit_1', UNIT_NUM = 1;
CREATE TENANT mysql RESOURCE_POOL_LIST = ('pool_1'), primary_zone='z1', locality="F@z1, F@z2, F@z3" set ob_tcp_invited_nodes='%';
# create oracle tenant
CREATE RESOURCE POOL if not exists pool_2 UNIT = 'unit_1', UNIT_NUM = 1;
CREATE TENANT oracle RESOURCE_POOL_LIST = ('pool_2'), primary_zone='z1', locality="F@z1, F@z2, F@z3" set ob_tcp_invited_nodes='%', ob_compatibility_mode='oracle';
ob1.check_until_timeout select count(*) as cnt from oceanbase.__all_virtual_server_schema_info as a join oceanbase.__all_virtual_server_schema_info as b on a.tenant_id = b.tenant_id  where a.refreshed_schema_version != b.refreshed_schema_version, 0, 60;
# create not used pool
CREATE RESOURCE POOL if not exists pool_3 UNIT = 'unit_1', UNIT_NUM = 1;
# create table
create table t1(c1 int primary key) partition by hash(c1) partitions 10;
create table t1(c1 int primary key) partition by hash(c1) partitions 10;
# uint_num 1->2
# verify unit_num of meta tenant in DBA_OB_TENANTS
select tenant_id, unit_num from DBA_OB_TENANTS;
tenant_id	unit_num
1	1
1001	1
1002	1
1003	1
1004	1
alter resource tenant mysql unit_num = 2;
select tenant_id, unit_num from DBA_OB_TENANTS;
tenant_id	unit_num
1	1
1001	2
1002	2
1003	1
1004	1
alter resource tenant oracle unit_num = 2;
ob1.check_until_timeout select count(*) = 4 from DBA_OB_TENANTS where unit_num = 2 and tenant_id != 1, 1, 1;
ob1.mysql set ob_global_debug_sync = "AFTER_TRANSFER_PROCESS_INIT_TASK_AND_BEFORE_NOTIFY_STORAGE wait_for signal_lock_finish";
ob1.check_until_timeout select count(*) != 0 from oceanbase.__all_virtual_transfer_task where tenant_id = $mysql_tenant_id and status = 'START', 1, 120;
ob1.check_until_timeout select count(*) != 0 from oceanbase.__all_virtual_transfer_task where tenant_id = $oracle_tenant_id and status = 'START', 1, 120;
