ob1.mysql alter system set debug_sync_timeout = '100000s';
ob1.mysql set ob_global_debug_sync = 'BEFORE_UPDATE_RECOVERY_UNTIL_SCN wait_for continue_signal execute 10000';
ALTER SYSTEM RECOVER STANDBY TENANT restore_mysql_tenant UNTIL UNLIMITED;
