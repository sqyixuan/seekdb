ob1.check_until_timeout select count(*) from __all_virtual_log_restore_source where tenant_id = 1004 and recovery_until_scn = $cur_recovery_until_scn, 1, 5;
ob1.check_until_timeout select count(*) from __all_virtual_tenant_info where tenant_id = 1004 and recovery_until_scn != 4611686018427387903, 1, 5;
ob1.check_until_timeout select count(*) from __all_virtual_log_restore_source where tenant_id = 1004 and recovery_until_scn != 4611686018427387903, 1, 5;
ALTER SYSTEM RECOVER STANDBY TENANT restore_mysql_tenant UNTIL UNLIMITED;
