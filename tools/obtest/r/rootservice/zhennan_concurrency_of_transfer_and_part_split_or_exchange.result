ob1=OBI(cluster=1:1,init_unit_cpu=0,proxy_num=0);
ob1.z1.obs0.set extra_config=$extra_conf;
ob1.z2.obs0.set extra_config=$extra_conf;
ob1.reboot;
ob1.mysql alter system set _transfer_start_trans_timeout = '10s';
ob1.mysql alter system set debug_sync_timeout = '1000s';
ob1.mysql set @@session.ob_query_timeout = 1000000000;
ob1.mysql CREATE RESOURCE UNIT if not exists unit_1 MAX_CPU 2, MEMORY_SIZE='4G';
ob1.mysql CREATE RESOURCE POOL if not exists pool_1 UNIT = 'unit_1', UNIT_NUM = 1;
ob1.mysql CREATE TENANT mysql RESOURCE_POOL_LIST = ('pool_1'), primary_zone='z1', locality="F@z1, F@z2" set ob_tcp_invited_nodes='%';
ob1.check_until_timeout select count(*) as cnt from oceanbase.__all_virtual_server_schema_info as a join oceanbase.__all_virtual_server_schema_info as b on a.tenant_id = b.tenant_id  where a.refreshed_schema_version != b.refreshed_schema_version, 0, 60;

## prepare data
create table t_split (k int primary key, c1 int, c2 longtext) partition by range(k) (
partition p0 values less than (10),
partition p1 values less than (20)
);
create index t_local_idx_split on t_split(k);
select table_id, object_id, tablet_id, table_name, partition_name, ls_id from oceanbase.DBA_OB_TABLE_LOCATIONS where table_id > 500000 and role = 'LEADER';
table_id	object_id	tablet_id	table_name	partition_name	ls_id
