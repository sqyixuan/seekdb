##################### 1. split partition when transfer getting related table schema #####################

## 1.1 block transfer when transfer getting related table schema
ob1.mysql set ob_global_debug_sync = "BEFORE_TRANSFER_GET_RELATED_TABLE_SCHEMAS wait_for signal_get_related";
ob1.mysql alter system set _transfer_process_lock_tx_timeout = '1000s' tenant mysql;
ob1.mysql alter tenant mysql set primary_zone = 'z1,z2';
ob1.check_until_timeout select count(*) from CDB_OB_BALANCE_JOBS where tenant_id=$mysql_tenant_id, 1, 60;
ob1.check_until_timeout select count(*) from CDB_OB_TRANSFER_TASKS where tenant_id=$mysql_tenant_id, 1, 60;

## 1.2. split partition
alter table t_split reorganize partition p0 into(
partition p0_0 values less than (5),
partition p0_1 values less than (10)
);
ob1.check_until_timeout select count(*) from CDB_OB_TABLE_LOCATIONS where tenant_id=$mysql_tenant_id and table_name like '%AUX_LOB_META%' and data_table_id = $t_split_id and role = 'LEADER' and partition_name = 'p0_1', 1, 60;

## 1.3. verify transfer is correct
ob1.mysql set ob_global_debug_sync = "now signal signal_get_related";
ob1.check_until_timeout select count(*) from CDB_OB_TRANSFER_TASKS where tenant_id=$mysql_tenant_id, 0, 100;
ob1.check_until_timeout select count(*) from CDB_OB_TRANSFER_TASK_HISTORY where tenant_id=$mysql_tenant_id and tablet_list like "%$p1_tablet_id%$p1_lob_meta_tablet_id%", 1, 1;
