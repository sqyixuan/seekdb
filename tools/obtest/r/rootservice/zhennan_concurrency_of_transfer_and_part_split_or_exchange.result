##################### 2. split target partition after transfer adding table lock #####################

## 2.1 block transfer after transfer adding table lock
ob1.mysql set ob_global_debug_sync = "AFTER_TRANSFER_LOCK_TABLE_FOR_NORMAL_TABLE wait_for signal_target_split";
ob1.mysql alter system transfer partition table_id = $t_split_id, object_id=$p0_1_object_id to LS 1002 tenant mysql;
ob1.check_until_timeout select count(*) from CDB_OB_BALANCE_JOBS where tenant_id=$mysql_tenant_id, 1, 60;
ob1.check_until_timeout select count(*) from CDB_OB_TRANSFER_TASKS where tenant_id=$mysql_tenant_id, 1, 60;

## 2.2 split target partition
alter table t_split reorganize partition p0_1 into(
partition p0_1_0 values less than (8),
partition p0_1_1 values less than (10)
);

## 2.3. verify transfer is correct
ob1.mysql set ob_global_debug_sync = "now signal signal_target_split";
ob1.check_until_timeout select count(*) from CDB_OB_TRANSFER_TASKS where tenant_id=$mysql_tenant_id, 0, 100;
select src_ls, dest_ls, part_list, not_exist_part_list, lock_conflict_part_list, tablet_list, status, comment from oceanbase.DBA_OB_TRANSFER_TASK_HISTORY where task_id = 2;
src_ls	dest_ls	part_list	not_exist_part_list	lock_conflict_part_list	tablet_list	status	comment
1001	1002	NULL	500002:500015	NULL	NULL	COMPLETED	Task completed as no valid partition

##################### 3. split other partition after transfer adding table lock #####################

## 3.1 block transfer after transfer adding table lock
ob1.mysql set ob_global_debug_sync = "AFTER_TRANSFER_LOCK_TABLE_FOR_NORMAL_TABLE wait_for signal_other_split";
ob1.mysql alter system transfer partition table_id = $t_split_id, object_id=$p0_1_0_object_id to LS 1002 tenant mysql;
ob1.check_until_timeout select count(*) from CDB_OB_BALANCE_JOBS where tenant_id=$mysql_tenant_id, 1, 60;
ob1.check_until_timeout select count(*) from CDB_OB_TRANSFER_TASKS where tenant_id=$mysql_tenant_id, 1, 60;

## 3.2 split other partition
alter table t_split reorganize partition p0_0 into(
partition p0_0_0 values less than (3),
partition p0_0_1 values less than (5)
);

## 3.3. verify transfer is correct
ob1.mysql set ob_global_debug_sync = "now signal signal_other_split";
ob1.check_until_timeout select count(*) from CDB_OB_TRANSFER_TASKS where tenant_id=$mysql_tenant_id, 0, 100;
ob1.check_until_timeout select count(*) from CDB_OB_BALANCE_JOBS where tenant_id=$mysql_tenant_id, 0, 100;
ob1.check_until_timeout select count(*) from CDB_OB_TRANSFER_TASK_HISTORY where tenant_id=$mysql_tenant_id and task_id = $last_task_id and tablet_list like "%$p0_1_0_tablet_id%$p0_1_0_local_index_tablet_id%$p0_1_0_lob_meta_tablet_id%$p0_1_0_lob_piece_tablet_id%", 1, 1;
select src_ls, dest_ls, part_list, not_exist_part_list, lock_conflict_part_list, tablet_list, status, comment from oceanbase.DBA_OB_TRANSFER_TASK_HISTORY where task_id = 3;
src_ls	dest_ls	part_list	not_exist_part_list	lock_conflict_part_list	tablet_list	status	comment
1001	1002	500002:500022	NULL	NULL	200005:0,1152921504606846989:0,1152921504606846991:0,1152921504606846993:0	COMPLETED	

##################### 4. exchange partition tablet after transfer adding table lock #####################

## 4.1 prepare data
alter table t_split drop index t_local_idx_split;
create table t_ex_non_part (k int primary key, c1 int, c2 longtext);

## 4.2 block transfer after transfer adding table lock
ob1.mysql set ob_global_debug_sync = "BEFORE_TRANSFER_LOCK_TABLE_AND_PART wait_for signal_transfer";
ob1.mysql alter system transfer partition table_id = $t_split_id, object_id=$p1_object_id to LS 1001 tenant mysql;
ob1.check_until_timeout select count(*) from CDB_OB_BALANCE_JOBS where tenant_id=$mysql_tenant_id, 1, 60;
ob1.check_until_timeout select count(*) from CDB_OB_TRANSFER_TASKS where tenant_id=$mysql_tenant_id, 1, 60;
ob1.mysql set ob_global_debug_sync = "TABLE_LOCK_AFTER_LOCK_TABLE_BEFORE_LOCK_TABLET wait_for signal_exchange";
ob1.mysql set ob_global_debug_sync = "now signal signal_transfer";

## 4.3 try exchange target partition
alter table t_split exchange partition p1 with table t_ex_non_part WITHOUT VALIDATION;

## 4.4. verify transfer is correct
ob1.mysql set ob_global_debug_sync = "now signal signal_exchange";
ob1.check_until_timeout select count(*) from CDB_OB_TRANSFER_TASKS where tenant_id=$mysql_tenant_id, 0, 100;
ob1.check_until_timeout select count(*) from CDB_OB_BALANCE_JOBS where tenant_id=$mysql_tenant_id, 0, 100;
select src_ls, dest_ls, part_list, not_exist_part_list, lock_conflict_part_list, tablet_list, status, comment from oceanbase.DBA_OB_TRANSFER_TASK_HISTORY where task_id >= 4;
src_ls	dest_ls	part_list	not_exist_part_list	lock_conflict_part_list	tablet_list	status	comment
1002	1001	NULL	500002:500006	NULL	NULL	COMPLETED	Task completed as no valid partition

##################### 5. exchange target tablet after transfer adding table lock #####################

## 5.1 prepare data
create table t1 (c1 int primary key, c2 int);
create table t2 (c1 int primary key, c2 int)
partition by range(c1)
subpartition by hash(c1) subpartitions 2
(
partition p0 values less than (10),
Partition p1 values less than (MAXVALUE)
);
insert into t1 values (1, 10), (2, 20), (11, 110), (12, 120);

## 5.2 block transfer after transfer adding table lock
ob1.mysql set ob_global_debug_sync = "BEFORE_TRANSFER_LOCK_TABLE_AND_PART wait_for signal_transfer";
ob1.mysql alter system transfer partition table_id = $t2_table_id, object_id=$t2_sub_part_id_before to LS 1002 tenant mysql;
ob1.check_until_timeout select count(*) from CDB_OB_BALANCE_JOBS where tenant_id=$mysql_tenant_id, 1, 60;
ob1.check_until_timeout select count(*) from CDB_OB_TRANSFER_TASKS where tenant_id=$mysql_tenant_id, 1, 60;
ob1.mysql set ob_global_debug_sync = "TABLE_LOCK_AFTER_LOCK_TABLE_BEFORE_LOCK_TABLET wait_for signal_exchange";
ob1.mysql set ob_global_debug_sync = "now signal signal_transfer";

## 5.3 try exchange target tablet while part_id not changed
insert overwrite t2 partition (p0sp1) select * from t1 where c1 = 1;
ERROR HY000: Timeout, query has reached the maximum query timeout: 10000000(us), maybe you can adjust the session variable ob_query_timeout or query_timeout hint, and try again.
insert /*+ direct(true, 0, 'inc') enable_parallel_dml(2) parallel(2) */ into t2 partition (p0sp1) select * from t1 where c1 = 1;

## 5.4. verify transfer is correct
ob1.mysql set ob_global_debug_sync = "now signal signal_exchange";
ob1.check_until_timeout select count(*) from CDB_OB_TRANSFER_TASKS where tenant_id=$mysql_tenant_id, 0, 100;
ob1.check_until_timeout select count(*) from CDB_OB_BALANCE_JOBS where tenant_id=$mysql_tenant_id, 0, 100;
select src_ls, dest_ls, part_list, not_exist_part_list, lock_conflict_part_list, tablet_list, status, comment from oceanbase.DBA_OB_TRANSFER_TASK_HISTORY where task_id >= 5;
src_ls	dest_ls	part_list	not_exist_part_list	lock_conflict_part_list	tablet_list	status	comment
