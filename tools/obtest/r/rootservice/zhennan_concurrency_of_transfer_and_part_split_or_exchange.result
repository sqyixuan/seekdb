500003	500008	1152921504606846978	__AUX_LOB_META_500003_	p1	1001
500004	500009	1152921504606846979	__AUX_LOB_PIECE_500004_	p0	1001
500004	500010	1152921504606846980	__AUX_LOB_PIECE_500004_	p1	1001
