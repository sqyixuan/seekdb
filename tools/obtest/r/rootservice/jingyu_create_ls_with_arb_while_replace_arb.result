ob1=OBI(cluster=1:1:1, proxy_num=0, asvr_num=2);
ob1.z1.obs0.set extra_config=$extra_conf;
ob1.z2.obs0.set extra_config=$extra_conf;
ob1.z3.obs0.set extra_config=$extra_conf;
ob1.asvr1.set status=disable;
ob1.reboot;
ob1.asvr1.set status=enable;
ob1.asvr1.reboot;
ob1.mysql alter system set debug_sync_timeout = '1000s';
ob1.mysql ALTER SYSTEM SET enable_rebalance = 'false';
ob1.mysql ALTER SYSTEM SET enable_rereplication = 'true';
ob1.check_until_timeout select count(*) from DBA_OB_ARBITRATION_SERVICE where arbitration_service = "$arb_svr_ip:$arb_svr_port", 1, 30;
ob1.mysql CREATE RESOURCE UNIT unit_1 MAX_CPU 1, MEMORY_SIZE='2G';
ob1.mysql CREATE RESOURCE POOL pool_1 UNIT = 'unit_1', UNIT_NUM = 1, zone_list = ('z1', 'z2', 'z3');
ob1.mysql CREATE TENANT mysql RESOURCE_POOL_LIST = ('pool_1'),  locality='F@z1, F@z2', primary_zone='z1;z2', enable_arbitration_service=true set ob_tcp_invited_nodes='%';
ob1.check_until_timeout select count(*) from __all_virtual_log_stat where tenant_id=$mysql_tenant_id and role = 'LEADER' and arbitration_member like "%$arb_svr_ip:$arb_svr_port%", $ls_cnt, 30;
ob1.check_until_timeout select count(*) from __all_virtual_log_stat where tenant_id=$meta_tenant_id and role = 'LEADER' and arbitration_member like "%$arb_svr_ip:$arb_svr_port%", 1, 30;
ob1.mysql set ob_global_debug_sync = 'BEFORE_PROCESS_AFTER_HAS_MEMBER_LIST wait_for signal';
alter tenant mysql primary_zone='z1,z2';
ob1.check_until_timeout select max(ls_id) > $max_ls_id from oceanbase.__all_virtual_ls_status where tenant_id = $mysql_tenant_id, 1, 10;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_ls_status where tenant_id = $mysql_tenant_id and ls_id = $new_max_ls_id and init_member_list like "%$arb_svr_ip:$arb_svr_port%" and init_member_list like "%flag:0%", 1, 10;
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id = $mysql_tenant_id and ls_id = $new_max_ls_id and role = 'LEADER', 1, 60;
ERROR HY000: Timeout
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id = $mysql_tenant_id and ls_id = 1 and role = 'LEADER' and svr_ip like "%$z2_dst_ip0%" and svr_port = $z2_dst_port0, 1, 60;
ob1.mysql set ob_global_debug_sync = 'now signal signal';
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_log_stat where tenant_id = $meta_tenant_id and role = 'LEADER' and arbitration_member like "%$arb_svr_ip_2:$arb_svr_port_2%", 1, 30;
ob1.check_until_timeout select count(*) - 1 as ls_cnt from oceanbase.__all_virtual_log_stat where tenant_id = $mysql_tenant_id and role = 'LEADER' and arbitration_member like "%$arb_svr_ip_2:$arb_svr_port_2%", $ls_cnt, 30;
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_LS_ARB_REPLICA_TASK_HISTORY where tenant_id = $mysql_tenant_id and ls_id = $new_max_ls_id and task_type = "REMOVE REPLICA" and arbitration_service like "%$arb_svr_ip:$arb_svr_port%", 1, 10;
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_LS_ARB_REPLICA_TASK_HISTORY where tenant_id = $mysql_tenant_id and ls_id = $new_max_ls_id and task_type = "ADD REPLICA" and arbitration_service like "%$arb_svr_ip_2:$arb_svr_port_2%", 1, 10;
