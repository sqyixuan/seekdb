||               [MILESTONE] case 1: 配置项基本设置能力                  ||
========================================================================
ob1.check_until_timeout SELECT COUNT(*) FROM oceanbase.__all_virtual_tenant_parameter_stat WHERE name = "replica_parallel_migration_mode" and tenant_id = 1002 and value = 'auto', 6, 10;
ob1.check_until_timeout SELECT COUNT(*) FROM oceanbase.__all_virtual_tenant_parameter_stat WHERE name = "replica_parallel_migration_mode" and tenant_id = 1002 and value = 'on', 6, 10;
ob1.check_until_timeout SELECT COUNT(*) FROM oceanbase.__all_virtual_tenant_parameter_stat WHERE name = "replica_parallel_migration_mode" and tenant_id = 1002 and value = 'off', 6, 10;
ob1.check_until_timeout SELECT COUNT(*) FROM oceanbase.__all_virtual_tenant_parameter_stat WHERE name = "replica_parallel_migration_mode" and tenant_id = 1002 and value = 'auto', 6, 10;
