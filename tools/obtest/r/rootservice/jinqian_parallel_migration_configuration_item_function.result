ob1.check_until_timeout SELECT COUNT(*) FROM oceanbase.CDB_OB_LS_REPLICA_TASKS WHERE tenant_id = $standby_tenant_id and TARGET_REPLICA_SVR_IP = '$z2_obs1_ip' and TARGET_REPLICA_SVR_PORT = $z2_obs1_port, 1, 20;
