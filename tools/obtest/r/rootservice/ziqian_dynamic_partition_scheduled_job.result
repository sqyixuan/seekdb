ob1=OBI(cluster=1,proxy_num=0);
ob1.reboot;
set @@session.ob_query_timeout = 200000000;
alter system set __min_full_resource_pool_memory=1073741824;
use oceanbase;
CREATE RESOURCE POOL mysql_pool UNIT = '2c2g', UNIT_NUM = 1;
CREATE TENANT mysql RESOURCE_POOL_LIST = ('mysql_pool'), primary_zone = 'z1', locality='F@z1' set ob_tcp_invited_nodes='%';
CREATE RESOURCE POOL oracle_pool UNIT = '2c2g', UNIT_NUM = 1;
CREATE TENANT oracle RESOURCE_POOL_LIST = ('oracle_pool'), primary_zone = 'z1', locality='F@z1' set ob_tcp_invited_nodes='%', ob_compatibility_mode='oracle';
set NLS_DATE_FORMAT = 'YYYY-MM-DD HH24:MI:SS';
set NLS_TIMESTAMP_FORMAT = 'YYYY-MM-DD HH24:MI:SS.FF';
set NLS_TIMESTAMP_TZ_FORMAT = 'YYYY-MM-DD HH24:MI:SS.FF TZR TZD';
################################
case 1: mysql mode
################################
case 1.1: check dynamic partition scheduled job
select JOB_NAME, JOB_ACTION, REPEAT_INTERVAL, ENABLED, COMMENTS from OCEANBASE.DBA_SCHEDULER_JOBS where job_name = 'SCHEDULED_MANAGE_DYNAMIC_PARTITION_DAILY';
JOB_NAME	JOB_ACTION	REPEAT_INTERVAL	ENABLED	COMMENTS
SCHEDULED_MANAGE_DYNAMIC_PARTITION_DAILY	DBMS_PARTITION.MANAGE_DYNAMIC_PARTITION(null, 'DAY,WEEK,MONTH,YEAR')	FREQ=DAILY;INTERVAL=1	1	used to perform manage dynamic partition periodically
select JOB_NAME, JOB_ACTION, REPEAT_INTERVAL, ENABLED, COMMENTS from OCEANBASE.DBA_SCHEDULER_JOBS where job_name = 'SCHEDULED_MANAGE_DYNAMIC_PARTITION_HOURLY';
JOB_NAME	JOB_ACTION	REPEAT_INTERVAL	ENABLED	COMMENTS
SCHEDULED_MANAGE_DYNAMIC_PARTITION_HOURLY	DBMS_PARTITION.MANAGE_DYNAMIC_PARTITION(null, 'HOUR')	FREQ=HOURLY;INTERVAL=1	1	used to perform manage dynamic partition periodically
case 1.2: check set trigger time of dynamic partition scheduled job
select time(next_run_date) from oceanbase.dba_scheduler_jobs where job_name = 'SCHEDULED_MANAGE_DYNAMIC_PARTITION_DAILY';
time(next_run_date)
00:00:00.000000
CALL DBMS_SCHEDULER.SET_ATTRIBUTE('SCHEDULED_MANAGE_DYNAMIC_PARTITION_DAILY', 'START_DATE', '2099-01-01 01:00:00');
select time(next_run_date) from oceanbase.dba_scheduler_jobs where job_name = 'SCHEDULED_MANAGE_DYNAMIC_PARTITION_DAILY';
time(next_run_date)
01:00:00.000000
select next_run_date > now() as result from oceanbase.dba_scheduler_jobs where job_name = 'SCHEDULED_MANAGE_DYNAMIC_PARTITION_DAILY';
result
1
CALL DBMS_SCHEDULER.SET_ATTRIBUTE('SCHEDULED_MANAGE_DYNAMIC_PARTITION_DAILY', 'START_DATE', '1999-01-01 01:00:00');
ERROR HY000: Invalid argument
CALL DBMS_SCHEDULER.SET_ATTRIBUTE('SCHEDULED_MANAGE_DYNAMIC_PARTITION_HOURLY', 'START_DATE', '2099-01-01 01:00:00');
ERROR 0A000: the job set attribute not supported
CALL DBMS_SCHEDULER.SET_ATTRIBUTE('SCHEDULED_MANAGE_DYNAMIC_PARTITION_DAILY', 'START_DATE', '01:00:00');
ERROR 22007: Incorrect value
CALL DBMS_SCHEDULER.SET_ATTRIBUTE('SCHEDULED_MANAGE_DYNAMIC_PARTITION_DAILY', 'START_DATE', '2099-01-01 25:00:00');
ERROR 22007: Incorrect value
CALL DBMS_SCHEDULER.SET_ATTRIBUTE('SCHEDULED_MANAGE_DYNAMIC_PARTITION_DAILY', 'START_DATE');
ERROR 42000: Incorrect number of arguments
CALL DBMS_SCHEDULER.SET_ATTRIBUTE('SCHEDULED_MANAGE_DYNAMIC_PARTITION_DAILY', 'START_DATE', '');
ERROR HY000: Invalid argument
CALL DBMS_SCHEDULER.SET_ATTRIBUTE('SCHEDULED_MANAGE_DYNAMIC_PARTITION_DAILY', 'START_DATE', 'abc');
ERROR 22007: Incorrect value
CALL DBMS_SCHEDULER.SET_ATTRIBUTE('SCHEDULED_MANAGE_DYNAMIC_PARTITION_DAILY', 'START_DATE', '1234567');
ERROR 22007: Incorrect value
case 1.3: check disable dynamic partition scheduled job
CALL DBMS_SCHEDULER.DISABLE('SCHEDULED_MANAGE_DYNAMIC_PARTITION_DAILY');
CALL DBMS_SCHEDULER.DISABLE('SCHEDULED_MANAGE_DYNAMIC_PARTITION_HOURLY');
select JOB_NAME, JOB_ACTION, REPEAT_INTERVAL, ENABLED, COMMENTS from OCEANBASE.DBA_SCHEDULER_JOBS where job_name = 'SCHEDULED_MANAGE_DYNAMIC_PARTITION_DAILY';
JOB_NAME	JOB_ACTION	REPEAT_INTERVAL	ENABLED	COMMENTS
SCHEDULED_MANAGE_DYNAMIC_PARTITION_DAILY	DBMS_PARTITION.MANAGE_DYNAMIC_PARTITION(null, 'DAY,WEEK,MONTH,YEAR')	FREQ=DAILY;INTERVAL=1	0	used to perform manage dynamic partition periodically
select JOB_NAME, JOB_ACTION, REPEAT_INTERVAL, ENABLED, COMMENTS from OCEANBASE.DBA_SCHEDULER_JOBS where job_name = 'SCHEDULED_MANAGE_DYNAMIC_PARTITION_HOURLY';
JOB_NAME	JOB_ACTION	REPEAT_INTERVAL	ENABLED	COMMENTS
SCHEDULED_MANAGE_DYNAMIC_PARTITION_HOURLY	DBMS_PARTITION.MANAGE_DYNAMIC_PARTITION(null, 'HOUR')	FREQ=HOURLY;INTERVAL=1	0	used to perform manage dynamic partition periodically
case 1.4: check enable dynamic partition scheduled job
CALL DBMS_SCHEDULER.ENABLE('SCHEDULED_MANAGE_DYNAMIC_PARTITION_DAILY');
CALL DBMS_SCHEDULER.ENABLE('SCHEDULED_MANAGE_DYNAMIC_PARTITION_HOURLY');
select JOB_NAME, JOB_ACTION, REPEAT_INTERVAL, ENABLED, COMMENTS from OCEANBASE.DBA_SCHEDULER_JOBS where job_name = 'SCHEDULED_MANAGE_DYNAMIC_PARTITION_DAILY';
JOB_NAME	JOB_ACTION	REPEAT_INTERVAL	ENABLED	COMMENTS
SCHEDULED_MANAGE_DYNAMIC_PARTITION_DAILY	DBMS_PARTITION.MANAGE_DYNAMIC_PARTITION(null, 'DAY,WEEK,MONTH,YEAR')	FREQ=DAILY;INTERVAL=1	1	used to perform manage dynamic partition periodically
select JOB_NAME, JOB_ACTION, REPEAT_INTERVAL, ENABLED, COMMENTS from OCEANBASE.DBA_SCHEDULER_JOBS where job_name = 'SCHEDULED_MANAGE_DYNAMIC_PARTITION_HOURLY';
JOB_NAME	JOB_ACTION	REPEAT_INTERVAL	ENABLED	COMMENTS
SCHEDULED_MANAGE_DYNAMIC_PARTITION_HOURLY	DBMS_PARTITION.MANAGE_DYNAMIC_PARTITION(null, 'HOUR')	FREQ=HOURLY;INTERVAL=1	1	used to perform manage dynamic partition periodically
