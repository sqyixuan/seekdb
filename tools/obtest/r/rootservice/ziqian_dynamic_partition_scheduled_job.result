SCHEDULED_MANAGE_DYNAMIC_PARTITION_DAILY	DBMS_PARTITION.MANAGE_DYNAMIC_PARTITION(null, 'DAY,WEEK,MONTH,YEAR')	FREQ=DAILY;INTERVAL=1	1	used to perform manage dynamic partition periodically
select JOB_NAME, JOB_ACTION, REPEAT_INTERVAL, ENABLED, COMMENTS from SYS.DBA_SCHEDULER_JOBS where job_name = 'SCHEDULED_MANAGE_DYNAMIC_PARTITION_HOURLY';
