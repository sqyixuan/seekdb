case 2.2: check set trigger time of dynamic partition scheduled job
select TO_CHAR(next_run_date, 'HH24:MI:SS') from sys.dba_scheduler_jobs where job_name = 'SCHEDULED_MANAGE_DYNAMIC_PARTITION_DAILY';
TO_CHAR(NEXT_RUN_DATE,'HH24:MI:SS')
00:00:00
CALL DBMS_SCHEDULER.SET_ATTRIBUTE('SCHEDULED_MANAGE_DYNAMIC_PARTITION_DAILY', 'START_DATE', '2099-01-01 01:00:00');
select TO_CHAR(next_run_date, 'HH24:MI:SS') from sys.dba_scheduler_jobs where job_name = 'SCHEDULED_MANAGE_DYNAMIC_PARTITION_DAILY';
TO_CHAR(NEXT_RUN_DATE,'HH24:MI:SS')
01:00:00
select case when next_run_date > sysdate then 1 else 0 end as result from sys.dba_scheduler_jobs where job_name = 'SCHEDULED_MANAGE_DYNAMIC_PARTITION_DAILY';
