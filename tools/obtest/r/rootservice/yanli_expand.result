ob1=OBI(cluster=2:2:2,proxy_num=0);
ob1.set extra_config=$mini_ob_config;
ob1.reboot;
ob1.mysql alter system set debug_sync_timeout = '1000s';
ob1.mysql alter system set _transfer_start_trans_timeout = '60s';
ob1.mysql alter system set enable_rebalance = 'false';
set @@session.ob_query_timeout = 1000000000;
CREATE RESOURCE UNIT unit_1 MAX_CPU 1, MEMORY_SIZE '2G';
CREATE RESOURCE POOL pool_1 UNIT = 'unit_1', UNIT_NUM = 1;
CREATE TENANT mysql RESOURCE_POOL_LIST = ('pool_1'), primary_zone='z1' set ob_tcp_invited_nodes='%';
ob1.mysql alter system set ls_gc_delay_time = '0s' tenant='mysql';
ob1.mysql alter system set _transfer_task_retry_interval = '0s' tenant = 'mysql';
create table non_partition_0(pk int primary key);
create table non_partition_1(pk int primary key);
create table non_partition_2(pk int primary key);
create table non_partition_3(pk int primary key);
create table non_partition_4(pk int primary key);
create table non_partition_5(pk int primary key);
create table non_partition_6(pk int primary key);
create table non_partition_7(pk int primary key);
create table non_partition_8(pk int primary key);
create table non_partition_9(pk int primary key);
create table one_partition_0(pk int primary key) partition by hash(pk) partitions 10;
create table one_partition_1(pk int primary key) partition by hash(pk) partitions 10;
create table one_partition_2(pk int primary key) partition by hash(pk) partitions 10;
create table one_partition_3(pk int primary key) partition by hash(pk) partitions 10;
create table one_partition_4(pk int primary key) partition by hash(pk) partitions 10;
