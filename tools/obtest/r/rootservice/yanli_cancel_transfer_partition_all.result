ob1=OBI(cluster=2:2,proxy_num=0);
ob1.set extra_config=$mini_ob_config;
ob1.reboot;
alter system set balancer_idle_time = '10s';
ob1.mysql alter system set debug_sync_timeout = '1000s';
ob1.mysql alter system set _transfer_start_trans_timeout = '10s';
set @@session.ob_query_timeout = 1000000000;
CREATE RESOURCE UNIT unit_1 MAX_CPU 1, MEMORY_SIZE '2G';
CREATE RESOURCE POOL pool_2 UNIT = 'unit_1', UNIT_NUM = 2, zone_list = ('z1','z2');
CREATE TENANT mysql RESOURCE_POOL_LIST = ('pool_2'), primary_zone='z1, z2' set ob_tcp_invited_nodes='%', autocommit='on';
ob1.mysql alter system set balancer_idle_time = '10s' tenant = 'mysql';
ob1.mysql alter system set _transfer_service_wakeup_interval = '5s' tenant = 'mysql';
ob1.mysql alter system set _transfer_task_tablet_count_threshold = 8 tenant = 'mysql';
ob1.mysql alter system set partition_balance_schedule_interval = '0s' tenant = 'mysql';
set recyclebin=off;
create tablegroup tg sharding = 'NONE';
create table t1(c1 int primary key, c2 int, c3 longtext)  tablegroup = 'tg'partition by hash(c1) partitions 200;
create table t2(c1 int primary key, c2 int, c3 longtext)  tablegroup = 'tg'partition by hash(c1) partitions 4;
ob1.mysql set ob_global_debug_sync = 'BEFORE_TENANT_BALANCE_SERVICE wait_for signal';
ob1.mysql set ob_global_debug_sync = 'now signal signal';
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_balance_job, 1, 100;
ob1.check_until_timeout select count(*) > 0 from oceanbase.__all_virtual_transfer_task, 1, 20;
ob1.mysql set ob_global_debug_sync = 'BEFORE_PROCESS_BALANCE_TASK_TRANSFER_END wait_for signal2';
ob1.mysql_p select distinct status from oceanbase.__all_virtual_transfer_partition_task order by status;
status
DOING
INIT
WAITING
alter system cancel transfer partition all tenant = 'mysql';
ERROR HY000: Some tasks are already in DOING status, can not be canceled
ob1.mysql set ob_global_debug_sync = 'now signal signal2';
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_balance_job, 0, 200;
ob1.mysql_p select count(*) from  oceanbase.__all_virtual_transfer_partition_task;
count(*)
0
ob1.mysql_p select distinct status, comment from oceanbase.__all_virtual_transfer_partition_task_history where task_id > 0 order by status;
status	comment
CANCELED	Canceled in INIT status
CANCELED	Canceled in WAITING status
COMPLETED	Partition transfer to dest LS
set recyclebin=off;
create table t3(c1 int primary key, c2 int, c3 longtext)  partition by hash(c1) partitions 16;
ob1.mysql set ob_global_debug_sync = 'BEFORE_TENANT_BALANCE_SERVICE wait_for signal';
ob1.mysql set ob_global_debug_sync = 'BEFORE_PROCESS_BALANCE_TASK_TRANSFER_END wait_for signal2';
ob1.mysql set ob_global_debug_sync = 'now signal signal';
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_balance_job, 1, 100;
ob1.check_until_timeout select count(*) > 0 from oceanbase.__all_virtual_transfer_task, 1, 20;
ob1.mysql_p select status, count(*) from oceanbase.__all_virtual_transfer_partition_task group by status order by status;
status	count(*)
DOING	8
INIT	8
alter system cancel transfer partition all tenant = 'mysql';
ERROR HY000: Some tasks are already in DOING status, can not be canceled
ob1.mysql set ob_global_debug_sync = 'now signal signal2';
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_balance_job, 0, 200;
create table t4(c1 int primary key, c2 int, c3 longtext)  partition by hash(c1) partitions 16;
ob1.mysql set ob_global_debug_sync = 'BEFORE_TENANT_BALANCE_SERVICE wait_for signal';
ob1.mysql set ob_global_debug_sync = 'BEFORE_PROCESS_BALANCE_EXECUTE_WORK wait_for signal2';
ob1.mysql set ob_global_debug_sync = 'now signal signal';
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_balance_job, 1, 100;
ob1.mysql_p select status, count(*) from oceanbase.__all_virtual_transfer_partition_task group by status order by status;
status	count(*)
INIT	16
alter system cancel transfer partition all tenant = 'mysql';
ob1.mysql set ob_global_debug_sync = 'now signal signal2';
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_balance_job, 0, 200;
ob1.mysql_p select status from oceanbase.__all_virtual_balance_job_history;
status
COMPLETED
COMPLETED
COMPLETED
