create user oracle_user1 identified by SYS;
create table oracle_tt1(c1 int);
insert into oracle_tt1 values(1), (2), (3);
----- test rename user -----
create user user_to_rename;
rename user user_to_rename to user_to_rename_1;
drop user user_to_rename_1;
----- test drop user -----
drop user oracle_user1 cascade;
=======================================
test outline related DDL
=======================================
----- test create outline -----
create outline oracle_outline on select * from oracle_t1 where c1 = 1;
----- test alter outline -----
alter outline oracle_outline add select /*+max_concurrent(1)*/* from oracle_t1 where c1 = 1;
----- test drop outline -----
drop outline oracle_outline;
