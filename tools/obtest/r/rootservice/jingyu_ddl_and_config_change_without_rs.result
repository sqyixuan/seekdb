=======================================
test package related DDL
=======================================
----- test create package -----
CREATE PACKAGE my_debug1 IS   debug CONSTANT BOOLEAN := TRUE;   trace CONSTANT BOOLEAN := TRUE;   grade constant number := 1+8*9-14; END my_debug1;
----- test alter package -----
CREATE or replace PACKAGE my_debug1 IS   debug CONSTANT BOOLEAN := TRUE;   trace CONSTANT BOOLEAN := TRUE;   grade constant number := 1+8*9-14+14; END my_debug1;
alter package my_debug1 compile package;
----- test drop package -----
drop package my_debug1;
