----- test create trigger -----
create table oracle_t1(c1 int);
create table oracle_t2(c1 int);
expect 0 lines
select * from oracle_t1 order by c1 desc;
C1
expect 0 lines
select * from oracle_t2 order by c1 desc;
C1
create or replace trigger oracle_t1_trigger before insert on oracle_t1 for each row begin insert into oracle_t2 values (:new.c1); end;
insert into oracle_t1 values (1), (2), (3);
expect 3 lines
select * from oracle_t1 order by c1 desc;
C1
3
2
1
expect 3 lines
select * from oracle_t2 order by c1 desc;
C1
3
2
1
