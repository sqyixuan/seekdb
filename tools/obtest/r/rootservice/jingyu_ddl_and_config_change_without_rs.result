alter trigger oracle_t1_trigger rename to oracle_t1_trigger_new;
insert into oracle_t1 values (1), (2), (3);
expect 6 lines
select * from oracle_t1 order by c1 desc;
C1
3
3
2
2
1
1
expect 6 lines
select * from oracle_t2 order by c1 desc;
C1
3
3
2
2
1
1
----- test drop trigger -----
drop trigger oracle_t1_trigger_new;
insert into oracle_t1 values (1), (2), (3);
expect 9 lines
