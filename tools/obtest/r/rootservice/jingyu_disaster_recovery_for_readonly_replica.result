1001	MIGRATE REPLICA	LOW	INPROGRESS	3	READONLY	3	READONLY	migrate replica due to unit not match
ls_id	task_type	priority	task_status	target_paxos_replica_number	target_replica_type	source_paxos_replica_number	source_replica_type	comment
1	MIGRATE REPLICA	LOW	INPROGRESS	3	READONLY	3	READONLY	migrate replica due to unit not match
ob1.mysql set ob_global_debug_sync = 'now signal delete_migrate_drtask';
ob1.check_until_timeout SELECT COUNT(*) = 1 FROM oceanbase.DBA_OB_UNITS WHERE unit_id = $unit_id AND migrate_from_svr_ip is null, 1, 400;
ob1.check_until_timeout SELECT COUNT(*) = 0 FROM oceanbase.CDB_OB_LS_LOCATIONS WHERE tenant_id = $tenant_id AND role = "LEADER" AND learner_list NOT LIKE '%$z4_dst0%' AND learner_list LIKE '%$z4_dst1%', 1, 20;
ob1.check_until_timeout SELECT COUNT(*) = 1 FROM oceanbase.DBA_OB_UNIT_JOBS WHERE unit_id = $unit_id AND job_type = "MIGRATE_UNIT" AND job_status = "SUCCESS", 1, 20;
