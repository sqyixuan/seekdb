========================================================================
||          [MILESTONE] test permanent offline R-replica              ||
========================================================================
ob1.mysql alter system set server_permanent_offline_time = '20s';
ob1.mysql alter tenant sys set primary_zone = "z1";
ob1.check_until_timeout select count(*) c from oceanbase.CDB_OB_LS_LOCATIONS where role like "%LEADER%" and tenant_id = 1 and zone ='z3', 0, 60;
ob1.z3.obs0.force_stop;
ob1.check_until_timeout select count(*) = 1 from oceanbase.DBA_OB_SERVERS where svr_ip = '$z3_dst_ip0' and svr_port = $z3_dst_port0 and status != 'ACTIVE', 1, 30;
ob1.check_until_timeout select count(*) > 0 from oceanbase.DBA_OB_ROOTSERVICE_EVENT_HISTORY where (value1 = $tenant_id or value1 = $meta_tenant_id) and event = "finish_remove_ls_non_paxos_replica" and extra_info = "remove permanent offline replica", 1, 60;
ob1.check_until_timeout select count(*) as cnt from oceanbase.CDB_OB_LS_LOCATIONS where (tenant_id = $tenant_id or tenant_id = $meta_tenant_id) and role = "LEADER" and learner_list like '%$z3_cur%', 0, 60;
========================================================================
||             [MILESTONE] test arbitration service                   ||
========================================================================
ob1.check_until_timeout select count(*) as cnt from oceanbase.DBA_OB_ARBITRATION_SERVICE where ARBITRATION_SERVICE = "$arb_svr_ip:$arb_svr_port", 1, 5;
alter tenant tenant_for_readonly_replica set enable_arbitration_service = true;
ob1.check_until_timeout select count(*) as cnt from oceanbase.DBA_OB_TENANTS where tenant_id = $tenant_id and arbitration_service_status = "ENABLED", 1, 120;
ob1.check_until_timeout select count(*) as cnt from oceanbase.DBA_OB_TENANTS where tenant_id = $meta_tenant_id and arbitration_service_status = "ENABLED", 1, 120;
========================================================================
||    [MILESTONE] test remove R replica with arb service              ||
========================================================================
alter tenant tenant_for_readonly_replica locality = 'F@z1, F@z2';
ob1.check_until_timeout SELECT COUNT(*) AS cnt FROM oceanbase.DBA_OB_TENANT_JOBS WHERE tenant_id = $tenant_id AND job_type = "ALTER_TENANT_LOCALITY" AND sql_text LIKE "%F@z1, F@z2%" AND extra_info like "%FULL{1}@z1, FULL{1}@z2, READONLY{1}@z3%" AND job_status = "SUCCESS", 1, 20;
ob1.check_until_timeout SELECT COUNT(*) = 1 FROM oceanbase.DBA_OB_TENANTS WHERE tenant_id = $tenant_id AND previous_locality is null, 1, 20;
ob1.check_until_timeout select count(*) as cnt from oceanbase.CDB_OB_LS_LOCATIONS where (tenant_id = $tenant_id or tenant_id = $meta_tenant_id) and role = "LEADER" and learner_list != "", 0, 60;
