ob1.mysql set ob_global_debug_sync = 'now signal signal_migrate';
ob1.check_until_timeout SELECT COUNT(*) = 1 FROM oceanbase.DBA_OB_UNIT_JOBS WHERE unit_id = $unit_id AND job_type = "MIGRATE_UNIT" AND job_status = "INPROGRESS", 1, 20;
ob1.check_until_timeout select count(*) = $migrate_ls_cnt from oceanbase.CDB_OB_LS_REPLICA_TASKS, 1, 20;
ob1.check_until_timeout SELECT COUNT(*) = 2 FROM __ALL_VIRTUAL_LOG_STAT WHERE TENANT_ID=$tenant_id AND LEARNER_LIST LIKE '%$z4_dst0%' AND ROLE = 'LEADER', 1, 120;
ob1.z4.obs0.force_stop;
ob1.mysql set ob_global_debug_sync = 'now signal yyy_debug_sync_point';
ob1.mysql set ob_global_debug_sync = 'BEFORE_SEND_DRTASK_RPC wait_for signal_migrate';
ob1.z4.obs0.nstart;
ob1.check_until_timeout select count(*) from __all_server where status='INACTIVE' or start_service_time <= 0, 0, 120;
ob1.check_until_timeout SELECT COUNT(*) = 0 FROM __ALL_VIRTUAL_LOG_STAT WHERE TENANT_ID=$tenant_id AND LEARNER_LIST LIKE '%$z4_dst0%' AND ROLE = 'LEADER', 1, 120;
ob1.mysql set ob_global_debug_sync = 'now signal signal_migrate';
ls_id	task_type	priority	task_status	target_paxos_replica_number	target_replica_type	source_paxos_replica_number	source_replica_type	comment
