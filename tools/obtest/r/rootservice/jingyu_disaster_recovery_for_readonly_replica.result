ob1=OBI(cluster=1:1:1:2:1,proxy_num=0,init_unit_cpu=0,asvr_num=1);
ob1.set extra_config=$mini_ob_config;
ob1.reboot;
ob1.asvr0.set extra_config=$arb_extra_conf;
ob1.asvr1.set status=enable;
ob1.asvr1.reboot;
ob1.mysql alter system set debug_sync_timeout = '1000s';
ob1.mysql ALTER SYSTEM SET enable_rebalance = 'false';
ob1.mysql ALTER SYSTEM SET enable_rereplication = 'true';
========================================================================
||            [MILESTONE] create tenant with FFF                      ||
========================================================================
set @@session.ob_query_timeout = 200000000;
alter system set __min_full_resource_pool_memory=1073741824;
use oceanbase;
ob1.mysql CREATE RESOURCE POOL tenant_pool UNIT = "2c2g", UNIT_NUM = 1, ZONE_LIST = ('z1', 'z2', 'z3', 'z4', 'z5');
CREATE TENANT tenant_for_readonly_replica RESOURCE_POOL_LIST=('tenant_pool'), LOCALITY = "F@z1, F@z2, F@z3", PRIMARY_ZONE = "z1" SET ob_tcp_invited_nodes='%';
========================================================================
||          [MILESTONE] change tenant from FFF to FFFR                ||
========================================================================
ob1.mysql set ob_global_debug_sync = 'BEFORE_SEND_DRTASK_RPC wait_for signal';
ob1.mysql set ob_global_debug_sync = 'BEFORE_DELETE_DRTASK_FROM_INNER_TABLE wait_for signal_for_delete_drtask';
ob1.check_until_timeout SELECT COUNT(*) = 0 FROM oceanbase.CDB_OB_LS_LOCATIONS WHERE tenant_id = $meta_tenant_id AND role = "LEADER" AND learner_list != "", 1, 20;
ob1.check_until_timeout SELECT COUNT(*) = 0 FROM oceanbase.CDB_OB_LS_LOCATIONS WHERE tenant_id = $tenant_id AND role = "LEADER" AND learner_list != "", 1, 20;
ALTER TENANT tenant_for_readonly_replica LOCALITY = 'F@z1, F@z2, F@z3, R@z4';
select tenant_id, ls_id, task_type, priority, target_paxos_replica_number, target_replica_type, source_paxos_replica_number, source_replica_type, comment from oceanbase.V$OB_LS_REPLICA_TASK_PLAN;
tenant_id	ls_id	task_type	priority	target_paxos_replica_number	target_replica_type	source_paxos_replica_number	source_replica_type	comment
1001	1	ADD REPLICA	HIGH	3	READONLY	3	FULL	add non-paxos replica according to locality
1002	1	ADD REPLICA	HIGH	3	READONLY	3	FULL	add non-paxos replica according to locality
1002	1001	ADD REPLICA	HIGH	3	READONLY	3	FULL	add non-paxos replica according to locality
ob1.mysql set ob_global_debug_sync = 'now signal signal';
ob1.check_until_timeout SELECT COUNT(*) AS cnt FROM oceanbase.DBA_OB_TENANT_JOBS WHERE tenant_id = $tenant_id AND job_type = "ALTER_TENANT_LOCALITY" AND sql_text LIKE "%F@z1, F@z2, F@z3, R@z4%" AND extra_info like "%FULL{1}@z1, FULL{1}@z2, FULL{1}@z3%" AND job_status = "INPROGRESS", 1, 20;
ob1.check_until_timeout select count(*) = $ls_cnt + $meta_ls_cnt from oceanbase.CDB_OB_LS_REPLICA_TASKS, 1, 20;
select ls_id, task_type, priority, task_status, target_paxos_replica_number, target_replica_type, source_paxos_replica_number, source_replica_type, comment from oceanbase.DBA_OB_LS_REPLICA_TASKS;
ls_id	task_type	priority	task_status	target_paxos_replica_number	target_replica_type	source_paxos_replica_number	source_replica_type	comment
1	ADD REPLICA	HIGH	INPROGRESS	3	READONLY	3	FULL	add non-paxos replica according to locality
1001	ADD REPLICA	HIGH	INPROGRESS	3	READONLY	3	FULL	add non-paxos replica according to locality
alter system change tenant tenant_id = 1001;
select ls_id, task_type, priority, task_status, target_paxos_replica_number, target_replica_type, source_paxos_replica_number, source_replica_type, comment from oceanbase.DBA_OB_LS_REPLICA_TASKS;
ls_id	task_type	priority	task_status	target_paxos_replica_number	target_replica_type	source_paxos_replica_number	source_replica_type	comment
1	ADD REPLICA	HIGH	INPROGRESS	3	READONLY	3	FULL	add non-paxos replica according to locality
ob1.mysql set ob_global_debug_sync = 'now signal signal_for_delete_drtask';
ob1.check_until_timeout SELECT COUNT(*) = 1 FROM oceanbase.DBA_OB_TENANTS WHERE tenant_id = $tenant_id AND previous_locality is null, 1 ,500;
ob1.check_until_timeout SELECT COUNT(*) = 1 FROM oceanbase.DBA_OB_TENANTS WHERE tenant_id = $meta_tenant_id AND previous_locality is null, 1 ,500;
ob1.check_until_timeout SELECT COUNT(*) = 1 FROM oceanbase.DBA_OB_TENANT_JOBS WHERE tenant_id = $tenant_id AND job_type = "ALTER_TENANT_LOCALITY" AND sql_text LIKE "%F@z1, F@z2, F@z3, R@z4%" AND extra_info like "%FULL{1}@z1, FULL{1}@z2, FULL{1}@z3%" AND job_status = "SUCCESS", 1, 20;
ob1.check_until_timeout SELECT COUNT(*) = 0 FROM oceanbase.CDB_OB_LS_LOCATIONS WHERE tenant_id = $meta_tenant_id AND role = "LEADER" AND learner_list NOT LIKE "%$z4_dst0%" AND member_list LIKE "%$z4_dst0%", 1, 20;
ob1.check_until_timeout SELECT COUNT(*) = 0 FROM oceanbase.CDB_OB_LS_LOCATIONS WHERE tenant_id = $tenant_id AND role = "LEADER" AND learner_list NOT LIKE "%$z4_dst0%" AND member_list LIKE "%$z4_dst0%", 1, 20;
ob1.check_until_timeout SELECT COUNT(*) = 0 FROM oceanbase.CDB_OB_LS_REPLICA_TASKS, 1, 30;
