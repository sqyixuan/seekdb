ob1=OBI(cluster=1:1:1:1:1,proxy_num=0,init_unit_cpu=0,locality=HZ:HZ:SH:SH:SZ);
ob1.reboot;
ob1.mysql create resource unit test_unit max_cpu = 1, memory_size = '2G';
ob1.mysql create resource pool xx1 unit = 'test_unit', unit_num = 1, zone_list = ('z1', 'z2', 'z3', 'z4', 'z5');
ob1.mysql create tenant tt1 resource_pool_list('xx1'), primary_zone "z3" set ob_tcp_invited_nodes='%';
create table t0 (k int primary key, v int);
create table t1 (k int primary key, v int);
create table t2 (k int primary key, v int);
create table t3 (k int primary key, v int);
create table t4 (k int primary key, v int);
create table t5 (k int primary key, v int);
create table t6 (k int primary key, v int);
create table t7 (k int primary key, v int);
create table t8 (k int primary key, v int);
create table t9 (k int primary key, v int);
ob1.mysql_p select ls_id, zone from oceanbase.__all_virtual_ls_meta_table where role = 1 and tenant_id = $tenant_id;
ls_id	zone
1	z3
1001	z3
ob1.mysql_p select ls_id, zone from oceanbase.__all_virtual_ls_meta_table where role = 1 and tenant_id = $tenant_id;
ls_id	zone
1	z3
1001	z3
ob1.z3.obs0.force_stop;
SH
z4
ob1.mysql_p select ls_id, zone from oceanbase.__all_virtual_ls_meta_table where role = 1 and tenant_id = $tenant_id;
ls_id	zone
1	z4
1001	z4
ob1.z3.obs0.start;
ob1.check_until_timeout select count(*) from oceanbase.__all_server where zone = 'z3' and start_service_time > 0, 1, 30;
ob1.mysql_p select ls_id, zone from oceanbase.__all_virtual_ls_meta_table where role = 1 and tenant_id = $tenant_id;
ls_id	zone
1	z4
1001	z4
ob1.mysql alter tenant tt1 primary_zone "z4";
z4
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_ls_status where tenant_id = $tenant_id and primary_zone != 'z4', 0, 20;
ob1.mysql_p select ls_id, zone from oceanbase.__all_virtual_ls_meta_table where role = 1 and tenant_id = $tenant_id;
ls_id	zone
1	z4
1001	z4
