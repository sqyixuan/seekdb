select table_id, table_name, table_type, duplicate_scope from oceanbase.DBA_OB_TABLE_LOCATIONS where (table_id = 500002 or data_table_id = 500002) and role = 'LEADER' order by table_id;
table_id	table_name	table_type	duplicate_scope
