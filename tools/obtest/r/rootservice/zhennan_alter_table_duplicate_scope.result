TABLE_ID	TABLE_NAME	TABLE_TYPE	DUPLICATE_SCOPE
500002	ORA_T1	USER TABLE	NONE
500003	__AUX_LOB_META_500003_	LOB AUX TABLE	NONE
500004	__AUX_LOB_PIECE_500004_	LOB AUX TABLE	NONE
500005	__idx_500002_ORA_L_IDX_T1	INDEX	NONE
500006	__idx_500002_ORA_G_IDX_T1	INDEX	NONE
ob1.check_until_timeout select count(*) from CDB_OB_LS where tenant_id = $oracle_tenant_id and flag like "%duplicate%", 0, 3;
##########
# 1. normal table to duplicate table
alter table ora_t1 duplicate_scope = 'CLUSTER';
# 1.1. change schemas of priamry table and aux tables
ob1.check_until_timeout select count(*) from CDB_OB_TABLE_LOCATIONS where tenant_id = $oracle_tenant_id and (table_id = $ora_t1_tid or data_table_id = $ora_t1_tid) and role = 'LEADER' and duplicate_scope = 'CLUSTER', 5, 3;
select table_id, table_name, table_type, duplicate_scope from SYS.DBA_OB_TABLE_LOCATIONS where (table_id = 500002 or data_table_id = 500002) and role = 'LEADER' order by table_id;
TABLE_ID	TABLE_NAME	TABLE_TYPE	DUPLICATE_SCOPE
500002	ORA_T1	USER TABLE	CLUSTER
500003	__AUX_LOB_META_500003_	LOB AUX TABLE	CLUSTER
500004	__AUX_LOB_PIECE_500004_	LOB AUX TABLE	CLUSTER
500005	__idx_500002_ORA_L_IDX_T1	INDEX	CLUSTER
500006	__idx_500002_ORA_G_IDX_T1	INDEX	CLUSTER
# 1.2. create duplicate_ls in the same time
ob1.check_until_timeout select count(*) from CDB_OB_LS where tenant_id = $oracle_tenant_id and flag like "%duplicate%", 1, 3;
##
# 2. duplicate_scope table to normal table
alter table ora_t1 duplicate_scope = 'NONE';
# 2.1. change schemas of priamry table and aux tables
ob1.check_until_timeout select count(*) from CDB_OB_TABLE_LOCATIONS where tenant_id = $oracle_tenant_id and (table_id = $ora_t1_tid or data_table_id = $ora_t1_tid) and role = 'LEADER' and duplicate_scope = 'NONE', 5, 3;
select table_id, table_name, table_type, duplicate_scope from SYS.DBA_OB_TABLE_LOCATIONS where (table_id = 500002 or data_table_id = 500002) and role = 'LEADER' order by table_id;
TABLE_ID	TABLE_NAME	TABLE_TYPE	DUPLICATE_SCOPE
500002	ORA_T1	USER TABLE	NONE
500003	__AUX_LOB_META_500003_	LOB AUX TABLE	NONE
500004	__AUX_LOB_PIECE_500004_	LOB AUX TABLE	NONE
500005	__idx_500002_ORA_L_IDX_T1	INDEX	NONE
500006	__idx_500002_ORA_G_IDX_T1	INDEX	NONE
##########
# 3. duplicate_scope is conflicted with tablegroup
create tablegroup ora_tg;
create table ora_t2(c1 int) duplicate_scope = 'CLUSTER';
alter table ora_t2 tablegroup = 'ORA_TG';
ERROR 0A000: OBE-00600: internal error code, arguments: -4007, changing duplicate_scope of table in tablegroup is not supported
alter tablegroup ora_tg add ora_t2;
ERROR 0A000: OBE-00600: internal error code, arguments: -4007, duplicate table in tablegroup not supported
alter table ora_t2 duplicate_scope = 'CLUSTER' tablegroup = 'ORA_TG';
ERROR 0A000: OBE-00600: internal error code, arguments: -4007, changing duplicate_scope of table in tablegroup is not supported
alter table ora_t2 duplicate_scope = 'NONE' tablegroup = 'ORA_TG';
ERROR null: success
alter table ora_t2 duplicate_scope = 'CLUSTER';
ERROR 0A000: OBE-00600: internal error code, arguments: -4007, changing duplicate_scope of table in tablegroup is not supported
alter table ora_t2 duplicate_scope = 'CLUSTER' tablegroup = '';
ERROR null: success

