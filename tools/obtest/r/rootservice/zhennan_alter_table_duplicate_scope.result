ob1.mysql alter system set partition_balance_schedule_interval = '0s' tenant mysql;
# 4.1. prepare data
create tablegroup tg_none sharding = 'NONE';
create tablegroup tg_partition sharding = 'PARTITION';
create tablegroup tg_adaptive sharding = 'ADAPTIVE';
create table mys_normal_part_zero_1(c1 int, c2 int, c3 longtext, index(c1) local, index(c2) global);
create table mys_normal_part_one_1(c1 int, c2 int, c3 longtext, index(c1) local, index(c2) global) partition by hash(c1) partitions 2;
create table mys_normal_part_two_1(c1 int, c2 int, c3 longtext, index(c1) local, index(c2) global) partition by range(c1) subpartition by hash(c1) subpartitions 2 (partition p1 values less than (100), partition p2 values less than MAXVALUE);
create table mys_dup_part_zero_1(c1 int, c2 int, c3 longtext, index(c1) local, index(c2) global) duplicate_scope = 'cluster';
create table mys_dup_part_one_1(c1 int, c2 int, c3 longtext, index(c1) local, index(c2) global) duplicate_scope = 'cluster' partition by hash(c1) partitions 2;
create table mys_dup_part_two_1(c1 int, c2 int, c3 longtext, index(c1) local, index(c2) global) duplicate_scope = 'cluster' partition by range(c1) subpartition by hash(c1) subpartitions 2 (partition p1 values less than (100), partition p2 values less than MAXVALUE);
