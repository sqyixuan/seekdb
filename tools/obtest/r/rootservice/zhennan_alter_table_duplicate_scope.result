############ other tenant ##############
########################################
# duplicate table is not allowed in sys tenant
create table sys_t1(c1 int) duplicate_scope = 'CLUSTER';
ERROR 0A000: create duplicate table under sys or meta tenant not supported
create table sys_t1(c1 int) duplicate_scope = 'NONE';
alter table sys_t1 duplicate_scope = 'CLUSTER';
ERROR 0A000: not user tenant, alter table duplicate scope not supported
