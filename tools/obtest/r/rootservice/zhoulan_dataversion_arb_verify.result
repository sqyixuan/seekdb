ob1=OBI(cluster=1,oblog_version=current,proxy_num=0,asvr_num=1);
ob1.reboot;
alter system set syslog_level = 'rpc.obrpc:trace';
alter system set syslog_io_bandwidth_limit = '30G';
ob1.z1.obs0.sh_p cd $work_dir/log; grep "receive arb rpc" observer.log* | grep "src_cluster_id=-1" | wc -l | awk '{if (\$1 > 0) print 1}';
1
