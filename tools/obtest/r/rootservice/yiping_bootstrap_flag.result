ob1=OBI(cluster=1:1:1,proxy_num=0);
ob1.reboot;
ob1.$leader.obs0.check_rs_log_until_success -c 'do restart task success, finish restart';
ob1.mysql alter tenant sys set primary_zone='z2';
ob1.check_until_timeout select role from __all_ls_meta_table where tenant_id=1 and ls_id=1 and zone='z2', 1, 600;
ob1.z2.force_stop;
ob1.z2.nstart;
ob1.z2.obs0.check_log_until_success -c 'keep silence for safty' $z2_election_log_path/log/election.log*;
