ob1=OBI(cluster=1:1:1:1,proxy_num=0);
ob1.reboot;
ob1.mysql alter system set enable_rebalance = false;
set @@session.ob_query_timeout = 1000000000;
CREATE RESOURCE UNIT unit_1 MAX_CPU 1, MEMORY_SIZE '2G';
CREATE RESOURCE POOL pool_1 UNIT = 'unit_1', UNIT_NUM = 1;
CREATE TENANT mysql RESOURCE_POOL_LIST = ('pool_1'), primary_zone='z1', locality = 'F@z1, F@z2, F@z3, F@z4' set ob_tcp_invited_nodes='%';
ob1.mysql alter system set ls_gc_delay_time = '0s' tenant='mysql';
alter tenant mysql set primary_zone = RANDOM;
ob1.check_until_timeout SELECT COUNT(*) c FROM oceanbase.__all_virtual_ls_status where (tenant_id >= $tenant_id - 1 and tenant_id <= $tenant_id) and status = 'NORMAL', 6, 30;
SELECT l.tenant_id, l.ls_id, l.ls_group_id, l.unit_group_id, l.primary_zone, l.status, e.zone_priority FROM oceanbase.__all_virtual_ls_status as l join oceanbase.__all_virtual_ls_election_reference_info as e on l.tenant_id = e.tenant_id and l.ls_id = e.ls_id where l.tenant_id in (1002 - 1, 1002) order by l.tenant_id, l.ls_group_id, l.ls_id;
tenant_id	ls_id	ls_group_id	unit_group_id	primary_zone	status	zone_priority
1001	1	0	0	z1	NORMAL	z1;z2,z3,z4
1002	1	0	0	z1	NORMAL	z1;z2,z3,z4
1002	1001	1001	1001	z1	NORMAL	z1;z2,z3,z4
1002	1002	1001	1001	z2	NORMAL	z2;z1,z3,z4
1002	1003	1001	1001	z3	NORMAL	z3;z1,z2,z4
1002	1004	1001	1001	z4	NORMAL	z4;z1,z2,z3
alter tenant mysql set primary_zone = 'z2,z3';
ob1.check_until_timeout SELECT COUNT(*) c FROM oceanbase.__all_virtual_ls_status where (tenant_id >= $tenant_id - 1 and tenant_id <= $tenant_id) and status = 'NORMAL', 4, 30;
ob1.check_until_timeout SELECT COUNT(*) c FROM oceanbase.__all_virtual_ls_status where status != 'NORMAL', 0, 100;
ob1.check_until_timeout SELECT COUNT(*) c FROM oceanbase.__all_virtual_ls_status where tenant_id = $tenant_id and primary_zone = 'z1',0, 100;
ob1.check_until_timeout SELECT COUNT(*) c FROM oceanbase.__all_virtual_ls_status as l join oceanbase.__all_virtual_ls_election_reference_info as e on l.tenant_id = e.tenant_id and l.ls_id = e.ls_id where l.tenant_id = $tenant_id and primary_zone = 'z2' and l.ls_id != 1, 1, 20;
ob1.check_until_timeout SELECT COUNT(*) c FROM oceanbase.__all_virtual_ls_status as l join oceanbase.__all_virtual_ls_election_reference_info as e on l.tenant_id = e.tenant_id and l.ls_id = e.ls_id where l.tenant_id = $tenant_id and primary_zone = 'z3' and l.ls_id != 1, 1, 20;
SELECT l.tenant_id, l.ls_id, l.ls_group_id, l.unit_group_id, l.primary_zone, l.status, e.zone_priority FROM oceanbase.__all_virtual_ls_status as l join oceanbase.__all_virtual_ls_election_reference_info as e on l.tenant_id = e.tenant_id and l.ls_id = e.ls_id where l.tenant_id in (1002 - 1, 1002) order by l.tenant_id, l.ls_group_id, l.ls_id;
tenant_id	ls_id	ls_group_id	unit_group_id	primary_zone	status	zone_priority
1001	1	0	0	z2	NORMAL	z2;z3;z1,z4
1002	1	0	0	z2	NORMAL	z2;z3;z1,z4
1002	1001	1001	1001	z3	NORMAL	z3;z2;z1,z4
1002	1002	1001	1001	z2	NORMAL	z2;z3;z1,z4
alter tenant mysql set primary_zone = 'z2,z3,z1';
ob1.check_until_timeout SELECT COUNT(*) c FROM oceanbase.__all_virtual_ls_status as l join oceanbase.__all_virtual_ls_election_reference_info as e on l.tenant_id = e.tenant_id and l.ls_id = e.ls_id where l.tenant_id = $tenant_id and primary_zone = 'z1' and l.ls_id != 1, 1, 200;
SELECT l.tenant_id, l.ls_id, l.ls_group_id, l.unit_group_id, l.primary_zone, l.status, e.zone_priority FROM oceanbase.__all_virtual_ls_status as l join oceanbase.__all_virtual_ls_election_reference_info as e on l.tenant_id = e.tenant_id and l.ls_id = e.ls_id where l.tenant_id in (1002 - 1, 1002) order by l.tenant_id, l.ls_group_id, l.ls_id;
tenant_id	ls_id	ls_group_id	unit_group_id	primary_zone	status	zone_priority
1001	1	0	0	z2	NORMAL	z2;z1,z3;z4
1002	1	0	0	z2	NORMAL	z2;z1,z3;z4
1002	1001	1001	1001	z3	NORMAL	z3;z1,z2;z4
1002	1002	1001	1001	z2	NORMAL	z2;z1,z3;z4
1002	1005	1001	1001	z1	NORMAL	z1;z2,z3;z4
ob1.mysql drop tenant mysql;
