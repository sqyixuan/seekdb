'[CASE 4] [drop tenant to recyclebin & drop tenant force]'
set @@recyclebin = on;
create resource pool pool13 zone_list = ("z1"), unit = "1c2g", unit_num = 1;
create tenant t13 resource_pool_list = ("pool13") set ob_compatibility_mode = 'mysql' , ob_tcp_invited_nodes='%';
DROP TENANT t13;
DROP TENANT T13 FORCE;
ERROR HY000: Unknown tenant 'T13'
