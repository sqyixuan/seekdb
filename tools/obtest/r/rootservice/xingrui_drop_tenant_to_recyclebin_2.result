ob1=OBI(cluster=1, proxy_num = 0, init_unit_cpu = 0);
ob1.z1.obs0.set extra_config=$extra_conf;
ob1.reboot;
set @@session.ob_query_timeout = 200000000;
alter system set __min_full_resource_pool_memory=1073741824;
use oceanbase;
'[CASE 3] [purge tenant with original_name/object_name]'
set @@recyclebin = on;
create resource pool pool10 zone_list = ("z1"), unit = "1c2g", unit_num = 1;
create tenant t10 resource_pool_list = ("pool10") set ob_compatibility_mode = 'mysql' , ob_tcp_invited_nodes='%';
DROP TENANT t10;
select tenant_id, tenant_type, in_recyclebin from oceanbase.DBA_OB_TENANTS where (tenant_id = 1002 or tenant_id = 1002 - 1) order by tenant_id;
tenant_id	tenant_type	in_recyclebin
1001	META	NO
1002	USER	YES
select original_name, type from oceanbase.DBA_RECYCLEBIN where type = 'TENANT';
original_name	type
t10	TENANT
select tenant_id, is_deleted, status from oceanbase.__all_tenant_history where (tenant_id = 1002 or tenant_id = 1002 - 1) order by tenant_id, schema_version;
tenant_id	is_deleted	status
1001	0	CREATING
1001	0	NORMAL
1002	0	CREATING
1002	0	NORMAL
1002	0	NORMAL
