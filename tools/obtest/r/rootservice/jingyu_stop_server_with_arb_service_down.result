====================================================
alter tenant mysql from 2F1A to 4F1A
====================================================
ob1.mysql alter tenant mysql locality = "F@z1, F@z2, F@z3, F@z4";
ob1.check_until_timeout SELECT COUNT(*) AS cnt FROM oceanbase.CDB_OB_LS_LOCATIONS WHERE tenant_id = $mysql_tenant_id AND role = "LEADER" AND member_list LIKE "%$z3_dst0%" AND member_list LIKE "%$z4_dst0%", $ls_cnt, 200;
ob1.check_until_timeout SELECT COUNT(*) AS cnt FROM oceanbase.CDB_OB_LS_LOCATIONS WHERE tenant_id = $meta_tenant_id AND role = "LEADER" AND member_list LIKE "%$z3_dst0%" AND member_list LIKE "%$z4_dst0%", 1, 200;
ob1.check_until_timeout SELECT COUNT(*) AS cnt FROM oceanbase.DBA_OB_TENANTS WHERE tenant_id = $mysql_tenant_id AND previous_locality is null AND locality like "%FULL{1}@z1, FULL{1}@z2, FULL{1}@z3, FULL{1}@z4%", 1 ,30;
====================================================
test stop server with 1F1A down
====================================================
shut down server in zone3
ob1.mysql alter tenant sys set primary_zone = "z1;z2;z3";
ob1.check_until_timeout select count(*) c from oceanbase.CDB_OB_LS_LOCATIONS where role like "%LEADER%" and tenant_id = 1 and zone = 'z3', 0, 60;
ob1.z3.obs0.force_stop;
ob1.check_until_timeout select count(*) as cnt from oceanbase.DBA_OB_SERVERS where STATUS != "ACTIVE" and zone = "z3", 1, 60;
test stop server(F) with 1F1A down in 4F1A, expect OB_OP_NOT_ALLOW 4179
