ob1=OBI(cluster=1,proxy_num=0);
ob1.clean_backup_dest;
ob1.reboot;
ob2=OBI(cluster=1:1:1,proxy_num=0,version=4_3_5_1);
ob2.clean_backup_dest;
ob2.reboot;
ob2.mysql create resource unit box max_cpu 2, memory_size='6G';
ob2.mysql create resource pool pool unit = 'box', unit_num = 1;
ob2.mysql create tenant mysql replica_num = 1, resource_pool_list=('pool') set ob_tcp_invited_nodes='%';
create table a(x int, y varchar(10));
insert into a values (1, 'a'),(2, 'b'),(3, 'c');
select*from a;
x	y
1	a
2	b
3	c
ob1.mysql create resource unit box max_cpu 2, memory_size='6G';
ob1.mysql create resource pool pool unit = 'box', unit_num = 1;
$cluster.mysql alter system archivelog tenant=$tenant_name;
$cluster.check_until_timeout select status from oceanbase.CDB_OB_ARCHIVELOG where tenant_id=$tenant_id, DOING, 600;
$cluster.mysql_root ALTER SYSTEM BACKUP TENANT = $tenant_name;
$cluster.check_until_timeout select result from oceanbase.CDB_OB_BACKUP_JOB_HISTORY where tenant_id = $tenant_id, 0, 1000;
$cluster.check_until_timeout select result from oceanbase.CDB_OB_BACKUP_TASK_HISTORY where tenant_id = $tenant_id, 0, 1000;
$cluster.check_until_timeout select floor(checkpoint_scn / 1000) > '$restore_checkpoint1' from CDB_OB_ARCHIVELOG where tenant_id= $tenant_id, 1, 600;
$cluster.check_until_timeout select floor(checkpoint_scn / 1000) > '$restore_checkpoint2' from CDB_OB_ARCHIVELOG where tenant_id= $tenant_id, 1, 600;
$cluster2.check_until_timeout select status FROM oceanbase.__all_tenant WHERE tenant_name='$tenant_standby', NORMAL, 3600;
$cluster2.mysql ALTER SYSTEM RECOVER STANDBY TENANT $tenant_standby UNTIL UNLIMITED;
select*from a;
x	y
1	a
2	b
3	c
