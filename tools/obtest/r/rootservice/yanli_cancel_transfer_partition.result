ERROR 42501: Access denied
alter system cancel transfer partition all tenant = 'oracle';
ERROR 42501: Access denied
ob1.mysql set ob_global_debug_sync = 'BEFORE_PROCESS_BALANCE_TASK_CREATE_LS wait_for signal';
