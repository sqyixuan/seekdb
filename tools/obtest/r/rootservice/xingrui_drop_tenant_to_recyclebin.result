'[CASE 1.1] [drop tenant to recyclebin & purge recyclebin]'
create resource pool pool1 zone_list = ("z1"), unit = "1c2g", unit_num = 1;
create tenant t1 resource_pool_list = ("pool1") set ob_compatibility_mode = 'mysql' , ob_tcp_invited_nodes='%';
select tenant_id, tenant_type, in_recyclebin from oceanbase.DBA_OB_TENANTS where (tenant_id = 1002 or tenant_id = 1002 - 1) order by tenant_id;
tenant_id	tenant_type	in_recyclebin
1001	META	NO
1002	USER	NO
