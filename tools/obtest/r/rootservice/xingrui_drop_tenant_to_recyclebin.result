ob1=OBI(cluster=1, proxy_num = 0, init_unit_cpu = 0);
ob1.z1.obs0.set extra_config=$extra_conf;
ob1.reboot;
set @@session.ob_query_timeout = 200000000;
alter system set __min_full_resource_pool_memory=1073741824;
use oceanbase;
set @@recyclebin = on;
create table t1 (c1 int primary key, c2 int, c3 longtext, index i1(c2));
drop table t1;
create database db_to_drop;
drop database db_to_drop;
show recyclebin;
OBJECT_NAME	ORIGINAL_NAME	TYPE	CREATETIME
object_name	original_name	INDEX	drop_time
object_name	original_name	TABLE	drop_time
object_name	original_name	DATABASE	drop_time
purge recyclebin;
show recyclebin;
