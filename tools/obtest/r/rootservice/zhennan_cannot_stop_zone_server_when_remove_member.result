ob1=OBI(cluster=1:1:1,proxy_num=0,init_unit_cpu=0);
ob1.reboot;
ob1.mysql create resource unit test_unit max_cpu = 1, memory_size = '2G';
ob1.mysql create resource pool pool1 unit = 'test_unit', unit_num = 1, zone_list = ('z1', 'z2', 'z3');
ob1.mysql create tenant tt resource_pool_list=('pool1'), primary_zone = 'z1;z2,z3', locality = 'F@z1,F@z2,F@z3' set ob_tcp_invited_nodes='%';
ob1.check_until_timeout select count(*) = 1 from oceanbase.__all_zone where zone = 'z3' and name = 'status' and value != 2, 1, 60;
ob1.check_until_timeout select count(*) = 0 from oceanbase.__all_zone where zone = 'z3' and name = 'status' and value != 2, 1, 60;
ob1.check_until_timeout select count(*) = 1 from oceanbase.__all_server where svr_ip = '$svr_ip' and svr_port = $svr_port and stop_time > 0, 1, 60;
ob1.check_until_timeout select count(*) = 0 from oceanbase.__all_server where svr_ip = '$svr_ip' and svr_port = $svr_port and stop_time > 0, 1, 60;
ob1.mysql alter system set debug_sync_timeout = '1000s';
ob1.check_until_timeout select count(*) from gv\$ob_parameters where name = 'debug_sync_timeout' and value != '1000s', 0, 10;
ob1.mysql set ob_global_debug_sync = 'BEFORE_SEND_DRTASK_RPC wait_for continue_signal';
ob1.mysql alter tenant tt locality = 'F@z1,F@z2';
ob1.check_until_timeout select count(*) = 1 from __all_tenant where tenant_id = $tenant_id and previous_locality != '', 1, 30;
ob1.check_until_timeout select count(*) > 0 from __all_virtual_log_stat where tenant_id = $tenant_id and role = 'LEADER' and paxos_replica_num = 3, 1, 60;
ERROR HY000: Tenant(1001) locality is changing, stop zone not allowed
ERROR HY000: Tenant(1001) locality is changing, stop server not allowed
ob1.mysql set ob_global_debug_sync = 'now signal continue_signal';
ob1.check_until_timeout select count(*) = 0 from __all_tenant where tenant_id = $tenant_id and previous_locality != '', 1, 60;
ob1.check_until_timeout select count(*) > 0 from __all_virtual_log_stat where tenant_id = $tenant_id and role = 'LEADER' and paxos_replica_num = 2, 1, 120;
ob1.mysql set ob_global_debug_sync = 'BEFORE_SEND_DRTASK_RPC wait_for continue_signal';
ob1.mysql alter tenant tt locality = 'F@z1,F@z2,F@z3';
ob1.check_until_timeout select count(*) = 1 from __all_tenant where tenant_id = $tenant_id and previous_locality != '', 1, 30;
ob1.check_until_timeout select count(*) > 0 from __all_virtual_log_stat where tenant_id = $tenant_id and role = 'LEADER' and paxos_replica_num = 2, 1, 60;
ERROR HY000: Tenant(1001) locality is changing, stop zone not allowed
