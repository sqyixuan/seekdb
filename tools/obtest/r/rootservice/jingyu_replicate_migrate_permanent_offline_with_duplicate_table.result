===================================================================
operation in zone1
===================================================================
ob1.check_until_timeout select count(*) as ls_cnt from oceanbase.CDB_OB_LS where tenant_id = $tenant_id and flag like "%DUPLICATE%", 1, 5;
ob1.check_until_timeout select ls_id from oceanbase.CDB_OB_LS where tenant_id = $tenant_id and flag like "%DUPLICATE%", $duplicate_ls_id, 5;
ob1.mysql alter tenant tenant_for_permanent set primary_zone = "z2;z3;z1";
ob1.check_until_timeout select count(*) c from oceanbase.CDB_OB_LS_LOCATIONS where role like "%LEADER%" and tenant_id in ($tenant_id, $meta_tenant_id) and zone = 'z1', 0, 60;
ob1.check_until_timeout select count(*) as server_cnt from oceanbase.DBA_OB_SERVERS where status like "%INACTIVE%", 1, 30;
ob1.check_until_timeout select count(*) > 0 from oceanbase.DBA_OB_UNITS where unit_id = $unit_id_with_duplicate_f_in_z1 and migrate_from_svr_ip is NULL, 1, 120;
ob1.check_until_timeout select count(*) > 0 from oceanbase.DBA_OB_ROOTSERVICE_EVENT_HISTORY where module like "%disaster%" and value1 = $tenant_id and value2 = $duplicate_ls_id and event like "%finish_migrate_ls_replica%" and value5 like "%$z1_cur_free%" and value6 like "%ret:0%" and extra_info like "%replicate to unit task%", 1, 10;
ob1.check_until_timeout select count(*) > 0 from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id = $tenant_id and ls_id = $duplicate_ls_id and role like "%LEADER%" and member_list like "%$z1_cur_free%" and member_list not like "%$z1_full_dst%", 1, 10;
===================================================================
operation in zone2
===================================================================
ob1.mysql alter system set server_permanent_offline_time = '20s';
ob1.mysql alter tenant tenant_for_permanent set primary_zone = "z1;z3;z2";
ob1.check_until_timeout select count(*) c from oceanbase.CDB_OB_LS_LOCATIONS where role like "%LEADER%" and tenant_id in ($tenant_id, $meta_tenant_id) and zone = 'z2', 0, 60;
ob1.check_until_timeout select count(*) as server_cnt from oceanbase.DBA_OB_SERVERS where status like "%INACTIVE%", 2, 30;
ob1.check_until_timeout select count(*) > 0 from oceanbase.DBA_OB_ROOTSERVICE_EVENT_HISTORY where module like "%disaster%" and value1 = $tenant_id and value2 = $duplicate_ls_id and event like "%finish_remove_ls_paxos_replica%" and value5 like "%$z2_full_dst%" and value6 like "%ret:0%" and extra_info like "%remove permanent offline replica%", 1, 120;
ob1.check_until_timeout select count(*) > 0 from oceanbase.DBA_OB_ROOTSERVICE_EVENT_HISTORY where module like "%disaster%" and value1 = $tenant_id and value2 = $duplicate_ls_id and event like "%finish_type_transform_ls_replica%" and value4 like "%$z2_cur_free%" and value6 like "%ret:0%" and extra_info like "%type transform according to locality%", 1, 120;
ob1.check_until_timeout select count(*) > 0 from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id = $tenant_id and ls_id = $duplicate_ls_id and role like "%LEADER%" and member_list like "%$z2_cur_free%" and member_list not like "%$z2_full_dst%" and learner_list not like "%$z2_cur_free%", 1, 10;
ob1.check_until_timeout select count(*) as cnt from oceanbase.DBA_OB_SERVERS where zone like "%z2%" and start_service_time > 0, 2, 200;
ob1.check_until_timeout select count(*) as cnt from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id in ($tenant_id, $meta_tenant_id) and role like "%LEADER%" and (member_list like "%$z2_cur_free%" or member_list like "%$z2_full_dst%"), $ls_cnt, 120;
===================================================================
operation in zone3
===================================================================
ob1.mysql alter system set server_permanent_offline_time = '20s';
ob1.mysql alter tenant tenant_for_permanent set primary_zone = "z1;z2;z3";
ob1.check_until_timeout select count(*) c from oceanbase.CDB_OB_LS_LOCATIONS where role like "%LEADER%" and tenant_id in ($tenant_id, $meta_tenant_id) and zone = 'z3', 0, 60;
ob1.check_until_timeout select count(*) as server_cnt from oceanbase.DBA_OB_SERVERS where zone like "%z3%" and status like "%INACTIVE%", 1, 30;
ob1.check_until_timeout select count(*) > 0 from oceanbase.DBA_OB_ROOTSERVICE_EVENT_HISTORY where module like "%disaster%" and value1 = $tenant_id and value2 = $duplicate_ls_id and event like "%finish_type_transform_ls_replica%" and value5 like "%$z3_readonly_dst%" and value5 like "%replica_type:16%" and value6 like "%ret:0%" and extra_info like "%type transform according to locality%", 1, 120;
