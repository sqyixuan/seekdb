ob1=OBI(cluster=2:2:2,proxy_num=0,init_unit_cpu=0);
ob1.set extra_config=$mini_ob_config;
ob1.reboot;
ob1.mysql alter system set debug_sync_timeout = '1000s';
ob1.mysql alter system SET enable_rebalance = 'false';
ob1.mysql alter system SET enable_rereplication = 'true';
============================================================
create tenant and duplicate table
============================================================
set @@session.ob_query_timeout = 200000000;
alter system set __min_full_resource_pool_memory=1073741824;
use oceanbase;
ob1.mysql CREATE RESOURCE POOL tenant_pool UNIT = "2c2g", UNIT_NUM = 2, ZONE_LIST = ('z1', 'z2', 'z3');
ob1.mysql CREATE TENANT tenant_for_shrink_unit RESOURCE_POOL_LIST=('tenant_pool'), LOCALITY = "F@z1, F@z2, R@z3", PRIMARY_ZONE = "z1" SET ob_tcp_invited_nodes='%';
create table dup_t1(c1 int) duplicate_scope = 'cluster';
============================================================
get unit related infos
============================================================
============================================================
try shrink resource tenant
============================================================
ob1.mysql alter resource tenant tenant_for_shrink_unit UNIT_NUM = 1  delete unit_group ($unit_group_id);
ob1.check_until_timeout select count(*) as z1_full_replica_cnt from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id = $tenant_id and ls_id = $duplicate_ls_id and role like "%LEADER%" and member_list like "%$z1_dst0%" and (learner_list not like "%$z1_dst0%" and learner_list not like "%$z1_dst1%"), 1, 120;
ob1.check_until_timeout select count(*) as z3_readonly_replica from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id = $tenant_id and ls_id = $duplicate_ls_id and role like "%LEADER%" and (learner_list like "%$z3_dst0%" or learner_list like "%$z3_dst1%"), 1, 20;
