ob1.check_until_timeout select count(*) from oceanbase.DBA_OB_TENANTS where tenant_name = '$restore_mysql_tenant' and sync_scn > $check_sync_scn, 1, 30;
ob1.mysql alter system set debug_sync_timeout = '100000s';
ob1.mysql set ob_global_debug_sync = 'PREPARE_FLASHBACK_FOR_SWITCH_TO_PRIMARY wait_for continue_signal_3 execute 10000';
ob1.check_until_timeout select count(*) from oceanbase.DBA_OB_TENANTS where TENANT_NAME = '$restore_mysql_tenant' and tenant_role = 'STANDBY' and switchover_status = 'PREPARE SWITCHING TO PRIMARY', 1, 10;
ob1.mysql set ob_global_debug_sync = 'PREPARE_FLASHBACK_FOR_SWITCH_TO_PRIMARY clear';
ob1.mysql set ob_global_debug_sync = 'now signal continue_signal_3 execute 10000';
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_tenant_info where tenant_id = 1004 and switchover_epoch = $standby_switchover_epoch, 0, 20;
