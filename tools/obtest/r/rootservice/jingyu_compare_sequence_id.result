===========================================
switch RS to another zone
===========================================
make sure current RS on which zone
switch RS to another zone
==========================================
check schema refresh
==========================================
ob1.z1.obs0.check_log_until_success -c "sequence_id is not comparable or local schema is far behind, refresh all tenant schema(new_sequence_id={seq_id:.*, sys_leader_epoch:2, enable_new_seq_id:true}, local_sequence_id={seq_id:.*, sys_leader_epoch:1, enable_new_seq_id:true})";
ob1.z2.obs0.check_log_until_success -c "sequence_id is not comparable or local schema is far behind, refresh all tenant schema(new_sequence_id={seq_id:.*, sys_leader_epoch:2, enable_new_seq_id:true}, local_sequence_id={seq_id:.*, sys_leader_epoch:1, enable_new_seq_id:true})";
