ob1=OBI(cluster=1:1:3,proxy_num=0);
ob1.z3.obs1.set status=disable;
ob1.z3.obs2.set status=disable;
ob1.reboot;
ob1.z3.obs1.set status=enable;
ob1.z3.obs2.set status=enable;
ob1.z3.obs1.start;
ob1.z3.obs2.start;
ob1.z3.obs1.check_log_until_success -c "weak read service thread start";
ob1.z3.obs2.check_log_until_success -c "weak read service thread start";
ob1.z3.obs1.add;
ob1.z3.obs2.add;
ob1.check_until_timeout SELECT COUNT(*) c FROM DBA_OB_SERVERS WHERE START_SERVICE_TIME > 0, 5, 200;
ob1.source include/migrate.inc;
ob1.mysql alter system set server_permanent_offline_time ='20s';
ob1.mysql create table oceanbase.test(c1 int primary key, c2 int) partition by hash(c1) partitions 30;
ob1.mysql create table oceanbase.test2(c1 int primary key, c2 int) partition by hash(c1) partitions 30;
ob1.mysql create table oceanbase.test3(c1 int primary key, c2 int) partition by hash(c1) partitions 30;
ob1.mysql alter system migrate unit 3 destination '$dest_ip:$dest_port';
ob1.check_until_timeout select count(*) from __all_virtual_core_meta_table where svr_ip='$dest_ip' and svr_port=$dest_port, 1, 180;
ob1.z3.obs1.force_stop;
ob1.check_until_timeout  select count(*) from __all_unit where svr_ip = '$src_ip' and svr_port = $src_port and unit_id=3, 1, 180;
