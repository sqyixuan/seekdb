ob1=OBI(cluster=1:1:1,proxy_num=0,init_unit_num=1);
ob1.reboot;
ob1.mysql alter system set debug_sync_timeout = '1000000s';
ob1.mysql alter system set enable_auto_leader_switch = false;
ob1.mysql CREATE RESOURCE UNIT unit_1 MAX_CPU $cpu, MAX_MEMORY $memory, MAX_IOPS $iops, MAX_DISK_SIZE $disk, MAX_SESSION_NUM $session, MIN_CPU=1, MIN_MEMORY=$min_memory, MIN_IOPS=128;
ob1.mysql CREATE RESOURCE POOL pool_2 UNIT = 'unit_1', UNIT_NUM = 1, ZONE_LIST = ('z1', 'z2','z3');
ob1.mysql CREATE TENANT tenant_1 RESOURCE_POOL_LIST = ('pool_2'), locality='F@z1,F@z2,F@z3', primary_zone='z1;z2;z3' set ob_tcp_invited_nodes='%';
ob1.mysql set ob_global_debug_sync = 'BEFORE_BATCH_PROCESS_TASK wait_for signal';
create table t1(c1 int);
ob1.check_until_timeout select count(*) from __all_virtual_meta_table where table_id = $t1_id and role = 1 and is_previous_leader = 0, 0, 10;
insert into t1 value(1);
select * from test.t1;
c1
1
create table t2(c1 int) partition by hash(c1) partitions 1000;
ob1.check_until_timeout select count(*) from __all_virtual_meta_table where table_id = $t2_id and role = 1 and is_previous_leader = 0, 0, 10;
insert into t2 value(1);
insert into t2 value(2);
insert into t2 value(3);
select * from test.t2;
c1
1
2
3
update t2 set c1 = 3 where c1 = 2;
select * from test.t2;
c1
1
3
3
delete from t2 where c1 = 1;
select * from test.t2;
c1
3
3
create table t_hash_range (c1 int, c2 int, c3 int, c4 int)
partition by hash(c1)
subpartition by range(c2)
subpartition template
(
subpartition rsp0 values less than (100),
subpartition rsp1 values less than (200),
subpartition rsp2 values less than (300)
)
partitions 4;
ob1.check_until_timeout select count(*) from __all_virtual_meta_table where table_id = $t4_id and role = 1 and is_previous_leader = 0, 0, 10;
insert into t_hash_range value(10,20,30,40);
insert into t_hash_range value(20,30,40,50);
select * from test.t_hash_range;
c1	c2	c3	c4
20	30	40	50
10	20	30	40
update t_hash_range set c2 = 20 where c2 = 30;
delete from t_hash_range where c1 = 10;
select * from test.t_hash_range;
c1	c2	c3	c4
20	20	40	50
create table t_hash_range1 (c1 int, c2 int, c3 int, c4 int)
partition by hash(c1)
subpartition by range(c2)
(
partition hp0
(
subpartition hp0sp0 values less than (100),
subpartition hp0sp1 values less than (200)
),
partition hp1
(
subpartition hp1sp0 values less than (100),
subpartition hp1sp1 values less than (200),
subpartition hp1sp2 values less than (300)
),
partition hp2
(
subpartition hp2sp0 values less than (100),
subpartition hp2sp1 values less than (200),
subpartition hp2sp2 values less than (300)
),
partition hp3
(
subpartition hp3sp0 values less than (100),
subpartition hp3sp1 values less than (200),
subpartition hp3sp2 values less than (300)
)
);
ob1.check_until_timeout select count(*) from __all_virtual_meta_table where table_id = $t5_id and role = 1 and is_previous_leader = 0, 0, 10;
insert into t_hash_range1 value(60,70,80,90);
insert into t_hash_range1 value(70,80,90,100);
select * from test.t_hash_range1;
c1	c2	c3	c4
60	70	80	90
70	80	90	100
update t_hash_range1 set c2 = 20 where c2 = 70;
delete from t_hash_range1 where c1 = 60;
select * from test.t_hash_range1;
c1	c2	c3	c4
70	80	90	100
create table table_like like t1;
ob1.check_until_timeout select count(*) from __all_virtual_meta_table where table_id = $table_like_id and role = 1 and is_previous_leader = 0, 0, 10;
insert into table_like value(10);
insert into table_like value(20);
select * from test.table_like;
c1
10
20
update table_like set c1 = 5 where c1 = 10;
delete from table_like where c1 = 20;
select * from test.table_like;
c1
5
create table range_table (c1 int primary key, c2 int) partition by range(c1) (partition p0 values less than(10), partition p1 values less than(100));
ob1.check_until_timeout select count(*) from __all_virtual_meta_table where table_id = $range_table_id and role = 1 and is_previous_leader = 0, 0, 10;
alter table range_table add partition (partition p2 values less than (10000), partition p3 values less than (maxvalue));
ob1.check_until_timeout select count(*) from __all_virtual_meta_table where table_id = $range_table_id and role = 1 and is_previous_leader = 0, 0, 10;
insert into range_table value(500, 100);
insert into range_table value(200000, 200);
select * from test.range_table;
c1	c2
500	100
200000	200
update range_table set c1 = 6 where c1 = 500;
delete from range_table where c1 = 200000;
select * from test.range_table;
c1	c2
6	100
create index l_index_1 on t1(c1) local;
ob1.mysql alter system set _ob_ddl_timeout = '10s';
ob1.mysql set ob_query_timeout = 1000;
ob1.mysql set ob_trx_timeout = 1000;
create index g_index_1 on t_hash_range(c1) global;
ob1.check_until_timeout select count(*) from __all_virtual_meta_table where table_id = $t6_id and role = 1 and is_previous_leader = 0, 0, 10;
ob1.mysql set ob_global_debug_sync = 'now signal signal';
alter system set_tp tp_no = 360, error_code = 4016, frequency = 1;
alter system set_tp tp_no = 361, error_code = 4016, frequency = 1;
create tablegroup tg1 binding true partition by range (partition p0 values less than(100), partition p1 values less than(200));
create table t3(c1 int) tablegroup = 'tg1' partition by range(c1) (partition p0 values less than(100), partition p1 values less than(200));
