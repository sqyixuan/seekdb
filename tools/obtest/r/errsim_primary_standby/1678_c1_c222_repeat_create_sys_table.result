ob1=OBI(cluster=1, proxy_num = 0);
ob2=OBI(cluster=1:1:1, proxy_num = 0, leaderob=ob1);
ob1.reboot;
ob2.reboot;
ob1.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO STANDBY, 100;
ob1.mysql alter system set enable_sys_table_ddl = true;
ob2.mysql alter system set enable_sys_table_ddl = true;
ob2.mysql alter system set balancer_idle_time = '10s';
alter system set_tp tp_no = 82, error_code = 4013, frequency = 1;
ob1.mysql create table oceanbase.__test (c1 int primary key,c3 int) table_id = $table_id tablegroup = 'oceanbase';
ob2.check_until_timeout select count(*) from oceanbase.__all_root_table where table_id = $table_id, 3, 10;
ob2.mysql_p select member_list from oceanbase.__all_root_table where table_id = $table_id;
member_list



ob2.check_until_timeout select count(*) > 0 from oceanbase.__all_partition_member_list where table_id = $table_id, 1, 30;
ob2.z3.obs0.force_stop;
ob2.check_until_timeout select count(*) from __all_server where start_service_time > 0 and status = 'active', 2, 100;
ob2.mysql_p select count(*) from oceanbase.__all_partition_member_list where table_id = $table_id and member_list like '%$z3_addr%';
count(*)
1
alter system set_tp tp_no = 82, error_code = 4013, frequency = 0;
ob2.check_until_timeout select count(*) > 0 from oceanbase.__all_virtual_table where table_name = '__test', 1, 10;
ob2.check_until_timeout select count(*) > 0 from oceanbase.__all_root_table where table_id = $table_id and member_list !='', 1, 100;
ob2.mysql_p select member_list from oceanbase.__all_root_table where table_id = $table_id and zone = 'z3';
member_list

ob2.z3.obs0.start;
ob2.check_until_timeout select count(*) from __all_server where start_service_time > 0 and status = 'active', 3, 100;
ob2.check_until_timeout select count(*) > 0 from oceanbase.__all_root_table where table_id = $table_id and member_list like '%,%,%' and member_list like '%$z3_addr%', 1, 100;
insert into __test values (1,1);
alter system set_tp tp_no = 81, error_code = 4013, frequency = 1;
ob1.mysql create table oceanbase.__test1 (c1 int primary key,c3 int) table_id = $table_id tablegroup = 'oceanbase';
ob2.check_until_timeout select count(*) from oceanbase.__all_root_table where table_id = $table_id and member_list = '', 3, 20;
ob2.mysql_p select count(*)  from oceanbase.__all_partition_member_list where table_id = $table_id;
count(*)
0
select * from __test1;
ERROR 42S02: Table 'oceanbase.__test1' doesn't exist
alter system set_tp tp_no = 81, error_code = 4013, frequency = 0;
ob1.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO STANDBY, 100;
insert into __test1 values (1,1);
alter system set_tp tp_no = 100, error_code = 4013, frequency = 1;
ob1.mysql create table oceanbase.__test2 (c1 int primary key,c3 int) table_id = $table_id tablegroup = 'oceanbase';
ob2.check_until_timeout select count(*) from oceanbase.__all_root_table where table_id = $table_id, 3, 10;
ob2.mysql_p select count(*) from oceanbase.__all_partition_member_list where table_id = $table_id;
count(*)
1
select * from __test2;
ERROR 42S02: Table 'oceanbase.__test2' doesn't exist
ob2.z3.obs0.force_stop;
ob2.check_until_timeout select count(*) from __all_server where start_service_time > 0 and status = 'active', 2, 100;
alter system set_tp tp_no = 100, error_code = 4013, frequency = 0;
ob2.check_until_timeout select count(*) from oceanbase.__all_virtual_table where table_name = '__test2', 1, 100;
ob2.z3.obs0.start;
ob2.check_until_timeout select count(*) from __all_server where start_service_time > 0 and status = 'active', 3, 100;
ob1.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO STANDBY, 100;
insert into __test2 values (1,1);
alter system set_tp tp_no = 99, error_code = 4013, frequency = 1;
ob1.mysql create table oceanbase.__test4 (c1 int primary key,c3 int) table_id = $table_id tablegroup = 'oceanbase';
ob2.check_until_timeout select count(*) from oceanbase.__all_root_table where table_id = $table_id and role = 1, 1, 10;
ob2.mysql_p select count(*) from oceanbase.__all_partition_member_list where table_id = $table_id;
count(*)
1
select * from __test4;
ERROR 42S02: Table 'oceanbase.__test4' doesn't exist
alter system set_tp tp_no = 99, error_code = 4013, frequency = 0;
ob1.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO STANDBY, 100;
insert into __test4 values (1,1);
ob1.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO STANDBY, 100;
ob1.mysql alter system commit to switchover to physical standby;
ob2.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO PRIMARY, 100;
ob2.mysql alter system commit to switchover to primary;
