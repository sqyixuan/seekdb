db_p=OBI(cluster=1,proxy_num=0,role=primary);
db_p.reboot;
db_s=OBI(cluster=1,proxy_num=0,primary=db_p);
db_s.reboot;
========== Initialization ==========
db_p.check_until_timeout select count(*) from oceanbase.__all_virtual_server_stat where role = 'PRIMARY', 1, 30;
db_s.check_until_timeout select count(*) from oceanbase.__all_virtual_server_stat where role = 'STANDBY', 1, 30;
Initialization completed
========== Step 1: Write initial data on primary ==========
--- ddl ---
create table if not exists test_restart_ddl(id int primary key, name varchar(100), value int);
insert into test_restart_ddl values(1, 'ddl_init_1', 100);
insert into test_restart_ddl values(2, 'ddl_init_2', 200);
insert into test_restart_ddl values(3, 'ddl_init_3', 300);
--- fulltext ---
create table test_restart_fts(id int primary key, title varchar(200), content text, fulltext index fts_idx(title, content));
insert into test_restart_fts values(1, 'OceanBase Database', 'OceanBase is a distributed relational database system');
insert into test_restart_fts values(2, 'Cloud Computing', 'Cloud computing provides scalable resources on demand');
insert into test_restart_fts values(3, 'Data Security', 'Data security protects sensitive information from threats');
--- vector ---
create table test_restart_vec(id int primary key, name varchar(100), embedding vector(3));
create vector index vec_idx_restart on test_restart_vec(embedding) with (distance=l2, type=hnsw, lib=vsag);
insert into test_restart_vec values(1, 'vec_init_1', '[1.0, 2.0, 3.0]');
insert into test_restart_vec values(2, 'vec_init_2', '[4.0, 5.0, 6.0]');
insert into test_restart_vec values(3, 'vec_init_3', '[7.0, 8.0, 9.0]');
--- fork_table ---
create table test_restart_fork_src(c1 int primary key, c2 varchar(100), c3 int);
insert into test_restart_fork_src values(1, 'src_1', 100);
insert into test_restart_fork_src values(2, 'src_2', 200);
insert into test_restart_fork_src values(3, 'src_3', 300);
db_p.mysql fork table oceanbase.test_restart_fork_src to oceanbase.test_restart_fork_dst;
select count(*) from test_restart_fork_dst;
count(*)
3
Step 1 completed
