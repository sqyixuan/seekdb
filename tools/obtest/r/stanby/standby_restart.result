========== Step 3: Stop standby and write data on primary ==========
db_s.force_stop;
--- ddl ---
insert into test_restart_ddl values(4, 'ddl_extra_4', 400);
insert into test_restart_ddl values(5, 'ddl_extra_5', 500);
alter table test_restart_ddl add column extra_col varchar(100);
update test_restart_ddl set extra_col = 'modified' where id = 1;
create table test_restart_ddl_new(a int primary key, b varchar(100));
insert into test_restart_ddl_new values(1, 'new_1');
insert into test_restart_ddl_new values(2, 'new_2');
--- fulltext ---
insert into test_restart_fts values(4, 'Machine Learning', 'Machine learning enables intelligent pattern recognition');
insert into test_restart_fts values(5, 'Deep Learning', 'Deep learning uses neural networks for complex tasks');
--- vector ---
insert into test_restart_vec values(4, 'vec_extra_4', '[10.0, 11.0, 12.0]');
insert into test_restart_vec values(5, 'vec_extra_5', '[13.0, 14.0, 15.0]');
create table test_restart_vec_idx(id int primary key, label varchar(100), feat vector(4));
create vector index vec_idx_restart2 on test_restart_vec_idx(feat) with (distance=l2, type=hnsw, lib=vsag);
insert into test_restart_vec_idx values(1, 'idx_1', '[1.0, 0.0, 0.0, 0.0]');
insert into test_restart_vec_idx values(2, 'idx_2', '[0.0, 1.0, 0.0, 0.0]');
--- fork_table ---
insert into test_restart_fork_src values(4, 'src_4', 400);
insert into test_restart_fork_src values(5, 'src_5', 500);
insert into test_restart_fork_dst values(4, 'fork_4', 444);
db_p.mysql fork table oceanbase.test_restart_fork_src to oceanbase.test_restart_fork_dst2;
Step 3 completed
