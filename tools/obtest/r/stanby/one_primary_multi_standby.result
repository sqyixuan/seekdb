db_p=OBI(cluster=1,proxy_num=0,role=primary);
db_p.reboot;
db_s1=OBI(cluster=1,proxy_num=0,primary=db_p);
db_s1.reboot;
db_s2=OBI(cluster=1,proxy_num=0,primary=db_p);
db_s2.reboot;
========== Initialization: Verify One Primary Multi Standby Topology ==========
db_p.check_until_timeout select count(*) from oceanbase.__all_virtual_server_stat where role = 'PRIMARY', 1, 30;
db_s1.check_until_timeout select count(*) from oceanbase.__all_virtual_server_stat where role = 'STANDBY', 1, 30;
db_s2.check_until_timeout select count(*) from oceanbase.__all_virtual_server_stat where role = 'STANDBY', 1, 30;
db_s1.check_until_timeout select count(*) from oceanbase.__all_virtual_server_stat where log_restore_source like '%:$db_p_rpc_port', 1, 30;
db_s2.check_until_timeout select count(*) from oceanbase.__all_virtual_server_stat where log_restore_source like '%:$db_p_rpc_port', 1, 30;
Initialization completed: One primary multi standby topology verified (db_p -> db_s1, db_p -> db_s2)
========== Case 1: Verify Parallel Sync ==========
create table if not exists test_multi_standby(id int primary key, name varchar(100), value int);
insert into test_multi_standby values(1, 'init_data', 100);
insert into test_multi_standby values(2, 'init_data_2', 200);
db_s1.check_until_timeout select count(*) from test_multi_standby where id = 1, 1, 120;
db_s1.check_until_timeout select count(*) from test_multi_standby where id = 2, 1, 30;
db_s2.check_until_timeout select count(*) from test_multi_standby where id = 1, 1, 120;
db_s2.check_until_timeout select count(*) from test_multi_standby where id = 2, 1, 30;
select count(*) from test_multi_standby;
count(*)
2
select count(*) from test_multi_standby;
count(*)
2
Case 1 completed: Parallel sync verified (db_p -> db_s1, db_p -> db_s2)
========== Case 2: Verify Independent Sync Progress ==========
db_s1.check_until_timeout select count(*) from test_multi_standby where id = 3, 1, 120;
db_s1.check_until_timeout select count(*) from test_multi_standby where id = 4, 1, 30;
db_s2.check_until_timeout select count(*) from test_multi_standby where id = 3, 1, 120;
db_s2.check_until_timeout select count(*) from test_multi_standby where id = 4, 1, 30;
select role, sync_scn from oceanbase.__all_virtual_server_stat where role = 'PRIMARY';
role	sync_scn
