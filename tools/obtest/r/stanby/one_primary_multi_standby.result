Case 4 completed: Roundtrip switchover with multiple standbys verified
========== Case 5: Failover with Multiple Standbys ==========
db_s1.check_until_timeout select count(*) from test_multi_standby where id = 9, 1, 120;
db_s2.check_until_timeout select count(*) from test_multi_standby where id = 9, 1, 120;
ALTER SYSTEM ACTIVATE STANDBY;
db_s2.check_until_timeout select count(*) from oceanbase.__all_virtual_server_stat where role = 'PRIMARY', 1, 60;
insert into test_multi_standby values(10, 'after_failover', 1000);
db_p.check_until_timeout select count(*) from oceanbase.__all_virtual_server_stat where role = 'PRIMARY', 1, 30;
db_s1.check_until_timeout select count(*) from oceanbase.__all_virtual_server_stat where role = 'STANDBY', 1, 30;
select count(*) from test_multi_standby;
count(*)
10
select count(*) from test_multi_standby;
count(*)
9
select count(*) from test_multi_standby;
count(*)
9
Case 5 completed: Failover with multiple standbys verified
