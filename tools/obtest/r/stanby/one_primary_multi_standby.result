Case 2 completed: Independent sync progress verified for each standby
========== Case 3: Switchover with Multiple Standbys ==========
db_p.check_until_timeout select count(*) from oceanbase.__all_virtual_server_stat where log_restore_source like '%:$db_s1_rpc_port', 1, 30;
db_s2.check_until_timeout select count(*) from oceanbase.__all_virtual_server_stat where log_restore_source like '%:$db_s1_rpc_port', 1, 30;
insert into test_multi_standby values(5, 'before_switchover', 500);
db_s1.check_until_timeout select count(*) from test_multi_standby where id = 5, 1, 120;
db_s2.check_until_timeout select count(*) from test_multi_standby where id = 5, 1, 120;
ALTER SYSTEM SWITCHOVER TO STANDBY;
db_p.check_until_timeout select count(*) from oceanbase.__all_virtual_server_stat where role = 'STANDBY', 1, 60;
ALTER SYSTEM SWITCHOVER TO PRIMARY;
db_s1.check_until_timeout select count(*) from oceanbase.__all_virtual_server_stat where role = 'PRIMARY', 1, 60;
insert into test_multi_standby values(6, 'after_switchover', 600);
db_p.check_until_timeout select count(*) from test_multi_standby where id = 6, 1, 120;
db_s2.check_until_timeout select count(*) from test_multi_standby where id = 6, 1, 120;
select count(*) from test_multi_standby;
count(*)
6
select count(*) from test_multi_standby;
count(*)
6
select count(*) from test_multi_standby;
count(*)
6
Case 3 completed: Switchover with multiple standbys verified
========== Case 4: Roundtrip Switchover with Multiple Standbys ==========
db_s1.check_until_timeout select count(*) from oceanbase.__all_virtual_server_stat where log_restore_source like '%:$db_p_rpc_port', 1, 30;
db_s2.check_until_timeout select count(*) from oceanbase.__all_virtual_server_stat where log_restore_source like '%:$db_p_rpc_port', 1, 30;
insert into test_multi_standby values(7, 'before_roundtrip', 700);
db_p.check_until_timeout select count(*) from test_multi_standby where id = 7, 1, 120;
db_s2.check_until_timeout select count(*) from test_multi_standby where id = 7, 1, 120;
ALTER SYSTEM SWITCHOVER TO STANDBY;
db_s1.check_until_timeout select count(*) from oceanbase.__all_virtual_server_stat where role = 'STANDBY', 1, 60;
ALTER SYSTEM SWITCHOVER TO PRIMARY;
db_p.check_until_timeout select count(*) from oceanbase.__all_virtual_server_stat where role = 'PRIMARY', 1, 60;
insert into test_multi_standby values(8, 'after_roundtrip', 800);
db_s1.check_until_timeout select count(*) from test_multi_standby where id = 8, 1, 120;
db_s2.check_until_timeout select count(*) from test_multi_standby where id = 8, 1, 120;
select count(*) from test_multi_standby;
count(*)
8
select count(*) from test_multi_standby;
count(*)
8
select count(*) from test_multi_standby;
count(*)
