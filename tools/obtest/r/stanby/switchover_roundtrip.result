insert into test_switchover_fork_src values(5, 'src_5', 500);
insert into test_switchover_fork_dst values(4, 'fork_4', 444);
db_p.check_until_timeout select count(*) from oceanbase.__all_virtual_server_stat where role = 'STANDBY', 1, 60;
create table test_switchover_readonly_check(a int);
ERROR HY000: standby tenant is read only
Phase 3 completed: Primary successfully switched to standby
========== Phase 4: Second Switchover (Standby -> Primary) ==========
db_s.check_until_timeout select count(*) from oceanbase.__all_virtual_server_stat where role = 'PRIMARY', 1, 60;
