db_p=OBI(cluster=1,proxy_num=0,role=primary);
db_p.reboot;
db_s=OBI(cluster=1,proxy_num=0,primary=db_p);
db_s.reboot;
========== Initialization: Set log_restore_source for db_p ==========
db_p.check_until_timeout select count(*) from oceanbase.__all_virtual_server_stat where role = 'PRIMARY', 1, 30;
db_s.check_until_timeout select count(*) from oceanbase.__all_virtual_server_stat where role = 'STANDBY', 1, 30;
db_p.mysql alter system set ob_compaction_schedule_interval = '3s';
db_s.mysql alter system set ob_compaction_schedule_interval = '3s';
db_p.check_until_timeout select count(*) from oceanbase.__all_virtual_server_stat where log_restore_source like '%$db_s_svr_ip%', 1, 30;
Initialization completed: log_restore_source set for db_p
========== Phase 1: Initial Primary Operations ==========
--- ddl ---
create table if not exists test_switchover_ddl(id int primary key, name varchar(100), value int, create_time timestamp default current_timestamp);
insert into test_switchover_ddl values(1, 'test1', 100, current_timestamp);
insert into test_switchover_ddl values(2, 'test2', 200, current_timestamp);
insert into test_switchover_ddl values(3, 'test3', 300, current_timestamp);
--- fulltext ---
create table test_switchover_fts(id int primary key, title varchar(200), content text, fulltext index fts_idx(title, content));
insert into test_switchover_fts values(1, 'OceanBase Database', 'OceanBase is a distributed relational database');
insert into test_switchover_fts values(2, 'Cloud Computing', 'Cloud computing provides scalable resources');
insert into test_switchover_fts values(3, 'Data Security', 'Data security protects sensitive information');
--- vector ---
create table test_switchover_vec(id int primary key, name varchar(100), embedding vector(3));
create vector index vec_idx_switchover on test_switchover_vec(embedding) with (distance=l2, type=hnsw, lib=vsag);
insert into test_switchover_vec values(1, 'vec_1', '[1.0, 2.0, 3.0]');
insert into test_switchover_vec values(2, 'vec_2', '[4.0, 5.0, 6.0]');
insert into test_switchover_vec values(3, 'vec_3', '[7.0, 8.0, 9.0]');
--- fork_table ---
create table test_switchover_fork_src(c1 int primary key, c2 varchar(100), c3 int);
insert into test_switchover_fork_src values(1, 'src_1', 100);
insert into test_switchover_fork_src values(2, 'src_2', 200);
insert into test_switchover_fork_src values(3, 'src_3', 300);
db_p.mysql fork table oceanbase.test_switchover_fork_src to oceanbase.test_switchover_fork_dst;
select count(*) from test_switchover_fork_dst;
count(*)
3
db_p.check_until_timeout select count(*) from oceanbase.CDB_OB_MAJOR_COMPACTION where LAST_SCN != GLOBAL_BROADCAST_SCN, 1, 100;
Phase 1 completed: Initial primary operations done
