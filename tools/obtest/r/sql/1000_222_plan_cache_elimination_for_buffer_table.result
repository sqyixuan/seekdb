  0 - output([t1.c1], [t1.c2], [t2.d1]), filter(nil)
  1 - output([t1.c1], [t1.c2], [t2.d1]), filter(nil)
  2 - output([t1.c1], [t1.c2], [t2.d1]), filter(nil), 
