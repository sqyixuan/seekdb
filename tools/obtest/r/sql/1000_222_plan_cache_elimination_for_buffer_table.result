-------------------------------------
  0 - output([t3.e1], [t3.e2]), filter(nil)
  1 - output([t3.e2], [t3.e1]), filter(nil)
  2 - output([t3.e2], [t3.e1]), filter([t3.e2 < 100]), 
      access([t3.e2], [t3.e1]), partitions(p0)

