# 场景4
# 非全表扫描计划, 抽取出来的query range选择率> 0.8时, 小表变大表淘汰计划
USE PLAN_CACHE_BUFFER_TABLE;
set @@ob_query_timeout = 10000000;
USE PLAN_CACHE_BUFFER_TABLE;
create table t4 (c1 int, c2 int, c3 int, key idx_c1_c2(c1, c2), key idx_c2(c2))tablegroup='buffer_table_group';
# 插入100行数
USE PLAN_CACHE_BUFFER_TABLE;
set @@ob_query_timeout = 10000000;
USE PLAN_CACHE_BUFFER_TABLE;
explain select c1, c2 from t4 where c1 < 2 and c2 < 100;
Query Plan
======================================================
|ID|OPERATOR            |NAME         |EST. ROWS|COST|
------------------------------------------------------
|0 |EXCHANGE IN REMOTE  |             |9        |75  |
|1 | EXCHANGE OUT REMOTE|             |9        |74  |
|2 |  TABLE SCAN        |t4(idx_c1_c2)|9        |74  |
======================================================

Outputs & filters: 
-------------------------------------
  0 - output([t4.c1], [t4.c2]), filter(nil)
  1 - output([t4.c1], [t4.c2]), filter(nil)
  2 - output([t4.c1], [t4.c2]), filter([t4.c2 < 100]), 
      access([t4.c1], [t4.c2]), partitions(p0)

