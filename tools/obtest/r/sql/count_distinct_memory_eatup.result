ob1=OBI(cluster=1, proxy_num=0, init_unit_cpu=0);
ob1.reboot;
ob1.mysql alter system set large_query_threshold = '1s';
ob1.mysql alter system set enable_auto_leader_switch=false;
ob1.mysql alter system set resource_hard_limit = 500;
ob1.mysql drop tenant if exists xy_tenant_1 force;
ob1.mysql create resource unit if not exists xy_box_1 max_cpu 3, max_memory $memory, max_iops $iops, max_disk_size $disk, max_session_num $session, MIN_CPU= 2, MIN_MEMORY=$min_memory, MIN_IOPS=128;
ob1.mysql create resource pool if not exists xy_pool_1 unit = 'xy_box_1', unit_num = 1;
ob1.mysql create tenant if not exists xy_tenant_1 resource_pool_list('xy_pool_1') set ob_tcp_invited_nodes='%';
