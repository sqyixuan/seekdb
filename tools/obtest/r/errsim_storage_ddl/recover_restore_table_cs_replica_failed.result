set global wait_timeout = 288000
create table t0 (c0 int primary key, c1 char(100))
create table t1 (c1 int primary key,
c2 char(100) not null,
c3 char(50) unique,
c4 int check(c4>20),
c5 int,
c6 set ('abc', 'cde', 'def'),
c7 enum ('a', 'b', 'c'),
c8 char(100) generated always as (substr(c2, 1, 20)) virtual,
c9 char(100) generated always as (substr(c2, 1, 20)) stored,
CONSTRAINT t1_fk FOREIGN KEY(c1) REFERENCES t0 (c0))
create table t2 (c1 int,
c2 int,
c3 int,
c4 int,
c5 int,
CONSTRAINT t2_cst_pk PRIMARY KEY (c1),
constraint t2_cst_chk_1 check(c1=c2),
constraint t2_cst_chk_2 check(c1=c2),
constraint t2_cst_unique_1 unique(c3, c1),
constraint t2_cst_unique_2 unique(c4, c1),
constraint t2_OBCHECK_123456 check(c2=c3),
constraint t2_OBUNIQUE_123456 unique(c5, c1),
constraint t2_fk_1 FOREIGN KEY(c1) REFERENCES t0(c0),
constraint t2_fk_2 FOREIGN KEY(c1) REFERENCES t1(c1)) partition by hash(c1) partitions 3
CREATE TRIGGER recover_trig1 BEFORE insert on t2 FOR EACH ROW BEGIN insert into t0 values(5, "Mysql"); END
CREATE TRIGGER recover_trig2 BEFORE update on t2 FOR EACH ROW BEGIN update t0 set c1 = "Mysql 8.0" where c1 = "Mysql"; END
CREATE TRIGGER recover_trig3 BEFORE delete on t1 FOR EACH ROW BEGIN insert into t1 (c1, c2, c3, c4, c5, c6, c7) values (100, 'allen_bob ', 'trigger_insert', 30, 1, 'abc', 'a'); END
