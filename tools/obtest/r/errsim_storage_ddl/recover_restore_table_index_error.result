ob1=OBI(cluster=1, proxy_num=0);
ob1.z1.obs0.set extra_config = "cache_wash_threshold='1G',_ob_minor_merge_schedule_interval='3s'";
ob1.force_stop;
ob1.clean_backup_dest;
ob1.reboot;
ob1.mysql alter resource unit sys_unit_config memory_size='2G';
use oceanbase;
alter system set resource_hard_limit = 1000;
alter system set _restore_idle_time = '10s';
CREATE RESOURCE UNIT small_unit MAX_CPU=1, MEMORY_SIZE='4G';
CREATE RESOURCE POOL small_pool UNIT small_unit, UNIT_NUM 1, ZONE_LIST ('z1');
CREATE RESOURCE POOL small_pool_0 UNIT small_unit, UNIT_NUM 1, ZONE_LIST ('z1');
ob1.mysql alter system set _backup_idle_time = '10s';
ob1.mysql alter system set enable_async_syslog=false;
ob1.mysql CREATE TENANT $backup_oracle_tenant RESOURCE_POOL_LIST = ('small_pool'), primary_zone = "z1" set ob_tcp_invited_nodes='%', ob_compatibility_mode='mysql',lower_case_table_names=1;
set global wait_timeout = 288000;
===============================================================
====================     create table   =======================
===============================================================
use test;
create table t0 (c0 int primary key);
create table t1 (c1 int primary key,
c2 char(100) not null,
c3 char(50) unique,
c4 int check(c4>20),
c5 int,
c6 set ('abc', 'cde', 'def'),
c7 enum ('a', 'b', 'c'),
c8 char(100) generated always as (substr(c2, 1, 20)) virtual,
c9 char(100) generated always as (substr(c2, 1, 20)) stored,
CONSTRAINT t1_fk FOREIGN KEY(c1) REFERENCES t0 (c0));
insert into t0 values (1);
insert into t0 values (2);
insert into t0 values (3);
insert into t0 values (4);
insert into t1 (c1, c2, c3, c4, c5, c6, c7) values (1, 'allen ', '1234567890123', 30, 1, 'abc', 'a');
insert into t1 (c1, c2, c3, c4, c5, c6, c7) values (2, 'sam ', '2234567890123', 30, 2, 'cde', 'c');
insert into t1 (c1, c2, c3, c4, c5, c6, c7) values (3, 'billy ', '3234567890123', 30, 3, 'cde', 'b');
insert into t1 (c1, c2, c3, c4, c5, c6, c7) values (4, 'carl', '4234567890123', 30, 4, 'cde', 'a');
create index idx_test1 on t1(c1, c2);
create index idx_test2 on t1(c1, c5) global partition by hash(c1) partitions 3;
create index idx_test3 on t1(c3(10));
===============================================================
==============   backup and archive   =========================
===============================================================
use oceanbase;
ob1.mysql alter system archivelog;
ob1.check_until_timeout select status from oceanbase.CDB_OB_ARCHIVELOG where tenant_id=$backup_oracle_tenant_id, DOING, 600;
ob1.mysql alter system backup database;
ob1.check_until_timeout select count(*) from cdb_ob_backup_jobs, 0, 600;
ob1.check_until_timeout select checkpoint_scn > $restore_checkpoint1 from CDB_OB_ARCHIVELOG, 1, 600;
===============================================================
====================   recover table   ========================
===============================================================
create database recover_test;
use oceanbase;

turn on the error sim inject.
ob1.mysql alter system set_tp tp_no = 510, error_code = 6, frequency = 1;
ob1.mysql alter system set_tp tp_no = 511, error_code = 5840, frequency = 1;
ob1.mysql alter system recover table test.t0, test.t1 to tenant backup_oracle_tenant from '$restore_path' until scn = $restore_checkpoint1 with 'pool_list=small_pool_0&primary_zone=z1' remap table test.t0:recover_test.recover_restore_normal_table_t0,test.t1:recover_test.recover_restore_normal_table_t1;
ob1.check_until_timeout select status from cdb_ob_restore_history where tenant_id = 1 and restore_tenant_id = 1004, SUCCESS, 600;
ob1.check_until_timeout select count(*) from __all_virtual_recover_table_job, 0, 600;
use oceanbase;

turn off the error sim inject.
ob1.mysql alter system set_tp tp_no = 510, error_code = 6, frequency = 0;
ob1.mysql alter system set_tp tp_no = 511, error_code = 5840, frequency = 0;
select count(1) as unfinished_ddl_task_count from oceanbase.__all_virtual_ddl_task_status;
unfinished_ddl_task_count
0
select table_name, index_type, index_status from oceanbase.__all_virtual_table where data_table_id in (
select table_id from oceanbase.__all_virtual_table where table_name like '%recover_restore_normal_table%');
table_name	index_type	index_status
