alter tenant sys enable_arbitration_service = true;
ob1.check_until_timeout select count(*) from CDB_OB_LS_ARB_REPLICA_TASKS where tenant_id = $sys_tenant_id and task_type = 'ADD REPLICA', 1, 20;
