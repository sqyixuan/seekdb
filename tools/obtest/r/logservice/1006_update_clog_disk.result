alter system minor freeze tenant clog_update_disk;
ob1.z1.obs0.check_log_until_success -c "succeed to release head data memtable";
ob1.z3.obs1.check_log_until_success -c "succeed to release head data memtable";
insert into t1_no_pk values (4), (5), (6);
insert into t1_no_pk values (7), (8), (9);
insert into t1_no_pk values (10), (11), (12);
insert into t1_pk values (4), (5), (6);
insert into t1_pk values (7), (8), (9);
insert into t1_pk values (10);
insert into t1_part values (5), (6), (7), (8);
insert into t1_part values (9), (10), (21), (22);
alter system minor freeze tenant clog_update_disk;
ob1.z1.obs0.check_log_until_success -c "succeed to release head data memtable";
ob1.z3.obs1.check_log_until_success -c "succeed to release head data memtable";
'prepare finished'
ob1.mysql alter tenant sys set primary_zone = "z1";
ob1.check_until_timeout select count(*) from __all_virtual_core_meta_table where role = 1 and zone = 'z1', 1, 60;
ob1.mysql alter tenant sys set primary_zone = "z2";
ob1.check_until_timeout select count(*) from __all_virtual_core_meta_table where role = 1 and zone = 'z2', 1, 60;
ob1.mysql alter tenant sys set primary_zone = "z1";
ob1.check_until_timeout select count(*) from __all_virtual_core_meta_table where role = 1 and zone = 'z1', 1, 60;
ob1.z3.obs0.mysql alter system set log_disk_size = '10G';
ob1.z3.force_stop;
ob1.z3.start;
ob1.check_until_timeout select count(*) from oceanbase.__all_server a left join oceanbase.__all_virtual_server_schema_info b on a.svr_ip = b.svr_ip and a.svr_port = b.svr_port where b.svr_ip is null, 0, 120;
ob1.check_until_timeout select count(*) as cnt from oceanbase.__all_virtual_server_schema_info as a join oceanbase.__all_virtual_server_schema_info as b on a.tenant_id = b.tenant_id  where a.refreshed_schema_version != b.refreshed_schema_version or a.refreshed_schema_version % 8 != 0, 0, 180;
ob1.z3.obs0.mysql alter system set log_disk_size = '10G';
