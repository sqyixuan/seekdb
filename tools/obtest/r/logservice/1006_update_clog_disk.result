ob1=OBI(cluster=1:1:2, proxy_num=0);
ob1.z1.obs0.set extra_config=$extra_conf;
ob1.z2.obs0.set extra_config=$extra_conf;
ob1.z3.obs0.set extra_config=$extra_conf;
ob1.reboot;
set @@session.ob_query_timeout = 1000000000;
CREATE RESOURCE UNIT unit_1 MAX_CPU 1, MEMORY_SIZE '3G', LOG_DISK_SIZE '4G';
CREATE RESOURCE POOL pool_1 UNIT = 'unit_1', UNIT_NUM = 1, zone_list = ('z1', 'z2', 'z3');;
CREATE TENANT clog_update_disk RESOURCE_POOL_LIST = ('pool_1'), primary_zone='z1;z2;z3' set ob_tcp_invited_nodes='%';
ob1.check_until_timeout select count(*) as cnt from oceanbase.__all_virtual_server_schema_info as a join oceanbase.__all_virtual_server_schema_info as b on a.tenant_id = b.tenant_id  where a.refreshed_schema_version != b.refreshed_schema_version, 0, 60;
create table t1_no_pk (c1 int);
insert into t1_no_pk values (1), (2), (3);
select * from t1_no_pk;
c1
1
2
3
update t1_no_pk set c1=c1+10;
select * from t1_no_pk;
c1
11
12
13
create table t1_pk (c1 int primary key);
insert into t1_pk values (1), (2), (3);
select * from t1_pk;
c1
1
2
3
update t1_pk set c1=c1+10;
select * from t1_pk;
c1
