ob1=OBI(cluster=1:2:1:1, proxy_num=0, asvr_num=2);
ob1.z1.obs0.set extra_config=$extra_conf;
ob1.z2.obs0.set extra_config=$extra_conf;
ob1.z2.obs1.set extra_config=$extra_conf;
ob1.z3.obs0.set extra_config=$extra_conf;
ob1.z4.obs0.set extra_config=$extra_conf;
ob1.asvr0.set extra_config=$arb_extra_conf;
ob1.asvr1.set extra_config=$arb_extra_conf;
ob1.asvr1.set status=disable;
ob1.reboot;
ob1.asvr1.set status=enable;
ob1.asvr1.reboot;
ob1.mysql alter system set ls_gc_delay_time='10s' tenant=sys;
ob1.mysql alter system set ls_gc_delay_time='10s' tenant=all_user;
ob1.mysql alter system set ls_gc_delay_time='10s' tenant=all_meta;
ob1.mysql alter system set debug_sync_timeout = '1000s';
ob1.mysql ALTER SYSTEM SET enable_rebalance = 'false';
ob1.mysql ALTER SYSTEM SET enable_rereplication = 'true';
ob1.check_until_timeout select count(*) from DBA_OB_ARBITRATION_SERVICE where arbitration_service = "$arb_svr_ip:$arb_svr_port", 1, 30;
ob1.check_until_timeout select count(*) from __all_virtual_arbitration_service_status, 5, 10;
set @@session.ob_query_timeout = 1000000000;
CREATE RESOURCE UNIT unit_1 MAX_CPU 1, MEMORY_SIZE='2G';
CREATE RESOURCE POOL pool_1 UNIT = 'unit_1', UNIT_NUM = 1, zone_list = ('z1', 'z2', 'z3', 'z4');
CREATE TENANT mysql RESOURCE_POOL_LIST = ('pool_1'),  locality='F@z1, F@z2', primary_zone='z1;z2', enable_arbitration_service=true set ob_tcp_invited_nodes='%';
ob1.mysql alter system set ls_gc_delay_time='10s' tenant=sys;
ob1.mysql alter system set ls_gc_delay_time='10s' tenant=all_user;
ob1.mysql alter system set ls_gc_delay_time='10s' tenant=all_meta;
alter tenant sys enable_arbitration_service = true;
ob1.check_until_timeout select count(*) from __all_virtual_log_stat where tenant_id=$sys_tenant_id and arbitration_member like "%$arb_svr_ip:$arb_svr_port%", 4, 30;
alter tenant sys set locality = 'F@z1, F@z2';
ob1.check_until_timeout select count(*) from __all_tenant where previous_locality != '', 0, 60;
ob1.mysql alter tenant sys set primary_zone='z1';
ob1.asvr0.force_stop;
ob1.asvr0.nstart;
ob1.mysql alter system set arbitration_timeout='600s' tenant='mysql';
ob1.check_until_timeout select count(1) from __all_virtual_tenant_parameter_info where name like "%arbitration_timeout%" and tenant_id=$mysql_tenant_id and value != '600s', 0, 30;
$mysql_z2_obs.force_stop;
ob1.check_until_timeout select count(*) from oceanbase.DBA_OB_SERVERS where zone = 'z2' and status='INACTIVE',1,60;
ob1.check_until_timeout select count(*) from __all_virtual_log_stat where tenant_id=$mysql_tenant_id and degraded_list like "%$mysql_z2_obs_addr%", 0, 30;
ob1.mysql alter system set arbitration_timeout='30s' tenant='mysql';
ob1.check_until_timeout select count(1) from __all_virtual_tenant_parameter_info where name like "%arbitration_timeout%" and tenant_id=$mysql_tenant_id and value != '30s', 0, 30;
ob1.check_until_timeout select count(*) from __all_virtual_log_stat where tenant_id=$mysql_tenant_id and degraded_list not like "%$mysql_z2_obs_addr%", 0, 120;
ob1.check_until_timeout select count(*) from __all_virtual_log_stat where tenant_id=$mysql_tenant_id and role != 'LEADER', 0, 10;
ob1.check_until_timeout select count(*) from __all_virtual_log_stat where tenant_id=$sys_tenant_id and role = 'LEADER', 1, 60;
ob1.check_until_timeout select count(*)=$mysql_tenant_ls_cnt from __all_virtual_log_stat where tenant_id=$mysql_tenant_id and role = 'LEADER', 1, 60;
ob1.mysql alter system set arbitration_timeout='5s' tenant='mysql';
ob1.check_until_timeout select count(1) from __all_virtual_tenant_parameter_info where name like "%arbitration_timeout%" and tenant_id=$mysql_tenant_id and value != '5s', 0, 30;
ob1.mysql alter system set enable_rebalance = false;
ob1.mysql alter system set enable_rereplication = false;
ob1.check_until_timeout SELECT COUNT(*) = 1 FROM oceanbase.__all_rootservice_job WHERE unit_id = $unit_id AND job_type = "MIGRATE_UNIT" AND job_status = "INPROGRESS", 1, 30;
ob1.check_until_timeout SELECT COUNT(*) = 1 FROM oceanbase.__all_rootservice_job WHERE unit_id = $unit_id AND job_type = "MIGRATE_UNIT" AND job_status = "SUCCESS", 1, 120;
ob1.check_until_timeout SELECT COUNT(*) AS cnt FROM oceanbase.DBA_OB_UNITS WHERE UNIT_ID = $unit_id AND TENANT_ID = $mysql_tenant_id AND concat(svr_ip,':',svr_port) = '$z2_obs0_addr' , 1, 30;
ob1.check_until_timeout select count(*) from __all_virtual_log_stat where tenant_id=$mysql_tenant_id and degraded_list like "%$mysql_z2_obs_addr%", 0, 120;
ob1.mysql ALTER SYSTEM SET enable_rereplication = 'false';
$mysql_z2_obs.nstart;
ob1.check_until_timeout select count(*) from __all_virtual_log_stat where tenant_id=$mysql_tenant_id and degraded_list like "%$mysql_z2_obs_addr%", 0, 120;
ob1.check_until_timeout select count(*)=$mysql_tenant_ls_cnt from __all_virtual_log_stat where tenant_id=$mysql_tenant_id and role = 'LEADER', 1, 60;
ob1.check_until_timeout select count(*) from __all_virtual_ls_meta_table where tenant_id = $mysql_tenant_id and paxos_replica_number != 2, 0, 60;
ob1.check_until_timeout select count(*) from __all_virtual_log_stat where tenant_id = $mysql_tenant_id and paxos_replica_num != 2, 0, 120;
ob1.check_until_timeout select count(*) from __all_server where status='INACTIVE' or start_service_time <= 0, 0, 120;
ob1.mysql alter system stop server "$mysql_z2_obs_addr";
ob1.check_until_timeout select count(*)=$total_mysql_tenant_ls_cnt from __all_virtual_log_stat where tenant_id=$mysql_tenant_id and degraded_list like "%$mysql_z2_obs_addr%", 1, 120;
ob1.check_until_timeout select count(*)=$mysql_tenant_ls_cnt from __all_virtual_ha_diagnose where tenant_id=$mysql_tenant_id and palf_role like '%LEADER%' and arb_srv_info like '%STOPPED%', 1, 120;
ob1.mysql alter system start server "$mysql_z2_obs_addr";
ob1.check_until_timeout select count(*) from __all_virtual_log_stat where degraded_list like "%$mysql_z2_obs_addr%", 0, 120;
ob1.mysql alter system replace arbitration service "$arb_svr_ip:$arb_svr_port" with "$arb_svr_ip_2:$arb_svr_port_2";
ob1.check_until_timeout select count(*) from DBA_OB_ARBITRATION_SERVICE where previous_arbitration_service != "", 0, 120;
ob1.check_until_timeout select count(*) from DBA_OB_ARBITRATION_SERVICE where arbitration_service = "$arb_svr_ip_2:$arb_svr_port_2", 1, 120;
ob1.check_until_timeout select count(*) from __all_virtual_log_stat where tenant_id=$mysql_tenant_id and arbitration_member like "%$arb_svr_ip:$arb_svr_port%", 0, 120;
ob1.check_until_timeout select count(*) from DBA_OB_ARBITRATION_SERVICE where previous_arbitration_service != "", 0, 120;
ob1.z2.obs0.force_stop;
ob1.z2.obs1.force_stop;
ob1.check_until_timeout select count(*) from oceanbase.DBA_OB_SERVERS where zone = 'z2' and status='INACTIVE',2,60;
ob1.mysql alter system set enable_rebalance = true;
ob1.mysql alter system set enable_rereplication = true;
ob1.check_until_timeout select count(*) from __all_virtual_log_stat where paxos_member_list like "%$z2_obs0_addr%" or paxos_member_list like "%$z2_obs1_addr%", 0, 120;
ob1.z2.obs0.nstart;
ob1.z2.obs1.nstart;
ob1.check_until_timeout select count(*) from oceanbase.__all_server where zone = 'z2' and status='ACTIVE' and start_service_time > 0,2,600;
ob1.check_until_timeout select count(*) from __all_virtual_log_stat where paxos_member_list not like "%$z2_obs0_addr%" and paxos_member_list not like "%$z2_obs1_addr%",0,240;
ob1.check_until_timeout SELECT COUNT(DISTINCT concat(svr_ip,':',svr_port)) FROM __ALL_VIRTUAL_LOG_STAT WHERE TENANT_ID in ($mysql_tenant_id, $mysql_meta_tenant_id) AND CONCAT(svr_ip,':',svr_port) in ('$z2_obs0_addr', '$z2_obs1_addr'), 1, 300;
ob1.check_until_timeout select count(*) as task_cnt from oceanbase.V\$OB_LS_REPLICA_TASK_PLAN, 0, 20;
ob1.check_until_timeout select count(*) as cnt from oceanbase.CDB_OB_LS_REPLICA_TASKS, 0, 20;
ob1.z2.obs0.force_stop;
ob1.z2.obs1.force_stop;
ob1.check_until_timeout select count(*) from oceanbase.DBA_OB_SERVERS where zone = 'z2' and status='INACTIVE',2,60;
ob1.check_until_timeout select count(*) from __all_virtual_log_stat where tenant_id=$mysql_tenant_id and degraded_list like "", 0, 120;
ob1.check_until_timeout select count(*) from __all_tenant where previous_locality != '', 0, 600;
ob1.check_until_timeout select count(*) from __all_virtual_log_stat where tenant_id=$mysql_tenant_id and paxos_replica_num != 4, 0, 30;
ob1.z2.obs0.nstart;
ob1.z2.obs1.nstart;
ob1.check_until_timeout select count(*) from oceanbase.DBA_OB_SERVERS where zone = 'z2' and status='INACTIVE',0,60;
ob1.check_until_timeout select count(*) from __all_virtual_log_stat where tenant_id=$mysql_tenant_id and degraded_list not like "", 0, 120;
