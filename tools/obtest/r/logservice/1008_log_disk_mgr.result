ob1=OBI(cluster=1, proxy_num=0);
ob1.z1.obs0.set extra_config=,$extra_conf;
ob1.reboot;
ob1.check_until_timeout select count(*) as cnt from oceanbase.__all_virtual_server_schema_info as a join oceanbase.__all_virtual_server_schema_info as b on a.tenant_id = b.tenant_id  where a.refreshed_schema_version != b.refreshed_schema_version, 0, 60;
set @@session.ob_query_timeout = 1000000000;
CREATE RESOURCE UNIT unit_1 MAX_CPU 1, MEMORY_SIZE '3G', LOG_DISK_SIZE '10G';
CREATE RESOURCE POOL pool_1 UNIT = 'unit_1', UNIT_NUM = 1, zone_list = ('z1');
CREATE RESOURCE UNIT unit_2 MAX_CPU 1, MEMORY_SIZE '3G', LOG_DISK_SIZE '4G';
CREATE RESOURCE POOL pool_2 UNIT = 'unit_2', UNIT_NUM = 1, zone_list = ('z1');
CREATE TENANT log_disk_space_enough RESOURCE_POOL_LIST = ('pool_2'), primary_zone='z1;' set ob_tcp_invited_nodes='%';
ob1.check_until_timeout select count(*) as cnt from oceanbase.__all_virtual_server_schema_info as a join oceanbase.__all_virtual_server_schema_info as b on a.tenant_id = b.tenant_id  where a.refreshed_schema_version != b.refreshed_schema_version, 0, 60;
alter system set log_disk_size='4G';
ob1.check_until_timeout select count(1) from gv\$ob_servers where log_disk_capacity = '4G', 0, 10;
ob1.check_until_timeout select count(1) from gv\$ob_servers where log_disk_capacity < log_disk_assigned, 0, 10;
ob1.z1.obs0.set extra_config=,$extra_conf;
ob1.z1.obs0.force_stop;
ob1.z1.obs0.start;
ob1.check_until_timeout select count(*) as cnt from oceanbase.__all_virtual_server_schema_info as a join oceanbase.__all_virtual_server_schema_info as b on a.tenant_id = b.tenant_id  where a.refreshed_schema_version != b.refreshed_schema_version, 0, 60;
ob1.check_until_timeout select count(1) from gv\$ob_servers where log_disk_capacity = '4G', 0, 60;
ob1.check_until_timeout select count(1) from gv\$ob_servers where log_disk_capacity < log_disk_assigned, 0, 10;
