ob1=OBI(cluster=1:1:1, proxy_num=0);
ob1.z1.obs0.set extra_config=$extra_conf;
ob1.z2.obs0.set extra_config=$extra_conf;
ob1.z3.obs0.set extra_config=$extra_conf;
ob1.reboot;
ob1.mysql alter system set enable_rebalance='false';
set @@session.ob_query_timeout = 1000000000;
CREATE RESOURCE UNIT unit_1 MAX_CPU 2, MIN_CPU 1, MEMORY_SIZE 4294967296, LOG_DISK_SIZE 10737418240, MAX_IOPS 100000, MIN_IOPS 1024;
CREATE RESOURCE POOL pool_1 UNIT = 'unit_1', UNIT_NUM = 1, zone_list = ('z1', 'z2', 'z3');;
CREATE TENANT tenant_1 RESOURCE_POOL_LIST = ('pool_1'), primary_zone='z1;z2;z3' set ob_tcp_invited_nodes='%';
CREATE RESOURCE POOL pool_2 UNIT = 'unit_1', UNIT_NUM = 1, zone_list = ('z1', 'z2', 'z3');;
CREATE TENANT tenant_2 RESOURCE_POOL_LIST = ('pool_2'), primary_zone='z1;z2;z3' set ob_tcp_invited_nodes='%';
ob1.check_until_timeout select count(*) as cnt from oceanbase.__all_virtual_server_schema_info as a join oceanbase.__all_virtual_server_schema_info as b on a.tenant_id = b.tenant_id  where a.refreshed_schema_version != b.refreshed_schema_version, 0, 60;
alter system set log_disk_throttling_percentage=85;
alter system set log_disk_utilization_limit_threshold=85;
ERROR HY000: Incorrect arguments to log_disk_utilization_limit_threshold should be greater than log_disk_throttling_percentage when log_disk_throttling_percentage is not equal to 100
alter system set log_disk_utilization_limit_threshold=81;
ERROR HY000: Incorrect arguments to log_disk_utilization_limit_threshold should be greater than log_disk_throttling_percentage when log_disk_throttling_percentage is not equal to 100
alter system set log_disk_utilization_limit_threshold=90;
alter system set log_disk_throttling_percentage=97;
ERROR HY000: Incorrect arguments to log_disk_throttling_percentage should be equal to 100 or smaller than log_disk_utilization_limit_threshold
alter system set log_disk_throttling_percentage=100;
