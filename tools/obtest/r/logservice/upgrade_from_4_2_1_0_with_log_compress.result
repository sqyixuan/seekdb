ob1=OBI(cluster=1:1:1,proxy_num=0,version=4_2_1_0);
ob1.reboot;
ob1.z1.obs0.set extra_config=$extra_conf;
ob1.z2.obs0.set extra_config=$extra_conf;
ob1.z3.obs0.set extra_config=$extra_conf;
set @@session.ob_query_timeout = 1000000000;
ob1.mysql alter tenant sys primary_zone='z1';
CREATE RESOURCE UNIT unit_1 MAX_CPU 3, MEMORY_SIZE '15G', LOG_DISK_SIZE '5G';
CREATE RESOURCE POOL pool_1 UNIT = 'unit_1', UNIT_NUM = 1, zone_list = ('z1','z2','z3');
CREATE TENANT mysql RESOURCE_POOL_LIST = ('pool_1'), primary_zone='z1' set ob_tcp_invited_nodes='%';
ob1.check_until_timeout select count(*) as cnt from oceanbase.__all_virtual_server_schema_info as a join oceanbase.__all_virtual_server_schema_info as b on a.tenant_id = b.tenant_id  where a.refreshed_schema_version != b.refreshed_schema_version, 0, 60;
ob1.check_until_timeout select count(*) as cnt from oceanbase.__all_virtual_server_schema_info as a join oceanbase.__all_virtual_server_schema_info as b on a.tenant_id = b.tenant_id  where a.refreshed_schema_version != b.refreshed_schema_version, 0, 60;
ob1.upgrade_check_before;
ob1.upgrade_commond_for_server pre;
ob1.mysql alter system stop zone 'z1';
ob1.check_until_timeout select status from DBA_OB_ZONES where zone='z1',INACTIVE,20;
ob1.z1.force_stop;
ob1.z1.upgrade;
ob1.z1.nstart;
ob1.check_until_timeout select count(*) from oceanbase.__all_server where zone = 'z1' and (start_service_time <= 0 or status='INACTIVE'),0,120;
ob1.check_until_timeout select count(*) from oceanbase.__all_server a left join oceanbase.__all_virtual_server_schema_info b on a.svr_ip = b.svr_ip and a.svr_port = b.svr_port where b.svr_ip is null, 0, 120;
ob1.check_until_timeout select count(*) as cnt from oceanbase.__all_virtual_server_schema_info as a join oceanbase.__all_virtual_server_schema_info as b on a.tenant_id = b.tenant_id  where a.refreshed_schema_version != b.refreshed_schema_version or a.refreshed_schema_version % 8 != 0, 0, 180;
ob1.mysql alter system start zone 'z1';
ob1.check_until_timeout  select paxos_replica_num from GV\$OB_LOG_STAT where tenant_id = '1002' and ls_id = '1001', 3, 600;
ob1.check_until_timeout  select count(1) as unsync_cnt from GV\$OB_LOG_STAT where in_sync = 'NO',0,600;
ob1.check_until_timeout  select count(1) as unsync_cnt from GV\$OB_LOG_STAT where in_sync = 'NO',0,600;
ob1.check_until_timeout  select count(1) from GV\$OB_LOG_STAT a join __all_server b on a.svr_ip=b.svr_ip where b.zone='z1' and  a.tenant_id=1002 and ls_id=1001 and a.role='LEADER', 1, 600;
ob1.check_until_timeout  select count(1) from GV\$OB_LOG_STAT a join __all_server b on a.svr_ip=b.svr_ip where b.zone='z1' and  a.tenant_id=1 and ls_id=1 and a.role='LEADER', 1, 600;
ob1.check_until_timeout  select count(1) from __all_virtual_ls_meta_table a join __all_server b on a.svr_ip=b.svr_ip and a.svr_port = b.svr_port where b.zone='z1' and  a.tenant_id=1 and ls_id=1 and a.role=1, 1, 600;
set @@session.ob_query_timeout = 1000000000;
ob1.mysql alter system set enable_ddl = true;
ob1.mysql alter system set log_storage_compress_all = true tenant=mysql;
