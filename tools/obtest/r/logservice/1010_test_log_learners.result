ob1=OBI(cluster=1:1:1:1:1:1, proxy_num=0);
ob1.z1.obs0.set extra_config=$extra_conf;
ob1.z2.obs0.set extra_config=$extra_conf;
ob1.z3.obs0.set extra_config=$extra_conf;
ob1.z4.obs0.set extra_config=$extra_conf;
ob1.z5.obs0.set extra_config=$extra_conf;
ob1.z6.obs0.set extra_config=$extra_conf;
ob1.reboot;
set @@session.ob_query_timeout = 1000000000;
CREATE RESOURCE UNIT unit_1 MAX_CPU 1, MEMORY_SIZE='2G';
CREATE RESOURCE POOL pool_1 UNIT = 'unit_1', UNIT_NUM = 1, zone_list = ('z1', 'z2', 'z3', 'z4', 'z5', 'z6');
CREATE TENANT mysql RESOURCE_POOL_LIST = ('pool_1'),  locality='F@z1, R@z2, R@z3, F@z4, R@z5, R@z6', primary_zone='z1' set ob_tcp_invited_nodes='%';
ob1.check_until_timeout select count(*) as cnt from oceanbase.__all_virtual_server_schema_info as a join oceanbase.__all_virtual_server_schema_info as b on a.tenant_id = b.tenant_id  where a.refreshed_schema_version != b.refreshed_schema_version, 0, 60;
ob1.check_until_timeout select count(*) from __all_virtual_log_stat where in_sync=0, 0, 120;
ALTER SYSTEM ALTER ZONE z1 SET REGION 'beijing';
ALTER SYSTEM ALTER ZONE z2 SET REGION 'beijing';
ALTER SYSTEM ALTER ZONE z3 SET REGION 'beijing';
ALTER SYSTEM ALTER ZONE z4 SET REGION 'shanghai';
ALTER SYSTEM ALTER ZONE z5 SET REGION 'shanghai';
ALTER SYSTEM ALTER ZONE z6 SET REGION 'shanghai';
ob1.check_until_timeout select count(*) from DBA_OB_ZONES where zone like 'z1' and region like 'beijing', 1, 30;
ob1.check_until_timeout select count(*) from DBA_OB_ZONES where zone like 'z2' and region like 'beijing', 1, 30;
ob1.check_until_timeout select count(*) from DBA_OB_ZONES where zone like 'z3' and region like 'beijing', 1, 30;
ob1.check_until_timeout select count(*) from DBA_OB_ZONES where zone like 'z4' and region like 'shanghai', 1, 30;
ob1.check_until_timeout select count(*) from DBA_OB_ZONES where zone like 'z5' and region like 'shanghai', 1, 30;
ob1.check_until_timeout select count(*) from DBA_OB_ZONES where zone like 'z6' and region like 'shanghai', 1, 30;
ob1.check_until_timeout select count(*) from __all_virtual_ha_diagnose where svr_ip like '$z2_dst_ip0' and svr_port = $z2_dst_port0 and (parent like '$z1_dst0' or parent like '$z3_dst0'), $number_of_ls, 30;
ob1.check_until_timeout select count(*) from __all_virtual_ha_diagnose where svr_ip like '$z3_dst_ip0' and svr_port = $z3_dst_port0 and (parent like '$z1_dst0' or parent like '$z2_dst0'), $number_of_ls, 30;
ob1.check_until_timeout select count(*) from __all_virtual_ha_diagnose where svr_ip like '$z5_dst_ip0' and svr_port = $z5_dst_port0 and parent like '$z4_dst0', $number_of_ls, 30;
ob1.check_until_timeout select count(*) from __all_virtual_ha_diagnose where svr_ip like '$z6_dst_ip0' and svr_port = $z6_dst_port0 and parent like '$z4_dst0', $number_of_ls, 30;
ob1.check_until_timeout select count(*) from __all_virtual_ha_diagnose where parent like '$z1_dst0', $number_of_ls, 30;
ALTER SYSTEM ALTER ZONE z2 SET REGION 'tianjin';
ob1.check_until_timeout select count(*) from DBA_OB_ZONES where zone like 'z2' and region like 'tianjin', 1, 30;
ob1.check_until_timeout select count(*) from __all_virtual_ha_diagnose where svr_ip like '$z2_dst_ip0' and svr_port = $z2_dst_port0 and (parent like '$z1_dst0'), $number_of_ls, 30;
ob1.check_until_timeout select count(*) from __all_virtual_ha_diagnose where svr_ip like '$z3_dst_ip0' and svr_port = $z3_dst_port0 and (parent like '$z1_dst0'), $number_of_ls, 30;
alter system switch replica leader ls=1 server='11.124.5.20:39927' tenant='mysql';
alter system switch replica leader ls=1001 server='11.124.5.20:39927' tenant='mysql';
ob1.check_until_timeout select count(*) from __all_virtual_log_stat where tenant_id=$mysql_tenant_id and ls_id=1 and svr_ip like '$z4_dst_ip0' and svr_port = $z4_dst_port0 and role = 'LEADER', 1, 30;
ob1.check_until_timeout select count(*) from __all_virtual_log_stat where tenant_id=$mysql_tenant_id and ls_id=1001 and svr_ip like '$z4_dst_ip0' and svr_port = $z4_dst_port0 and role = 'LEADER', 1, 30;
ob1.check_until_timeout select count(*) from __all_virtual_ha_diagnose where tenant_id=$mysql_tenant_id and svr_ip like '$z5_dst_ip0' and svr_port = $z5_dst_port0 and (parent like '$z4_dst0' or parent like '$z6_dst0'), $number_of_mysql_tenant_ls, 30;
ob1.check_until_timeout select count(*) from __all_virtual_ha_diagnose where tenant_id=$mysql_tenant_id and svr_ip like '$z6_dst_ip0' and svr_port = $z6_dst_port0 and (parent like '$z4_dst0' or parent like '$z5_dst0'), $number_of_mysql_tenant_ls, 30;
ob1.check_until_timeout select count(*) from __all_virtual_ha_diagnose where tenant_id=$mysql_tenant_id and svr_ip like '$z2_dst_ip0' and svr_port = $z2_dst_port0 and parent like '$z4_dst0', $number_of_mysql_tenant_ls, 30;
ALTER TENANT mysql locality='F{1}@z1,R{1}@z2,F{1}@z3,F{1}@z4,R{1}@z5,R{1}@z6';
ob1.check_until_timeout select count(*) from __all_tenant where tenant_id=$mysql_tenant_id and previous_locality='', 1, 60;
ob1.check_until_timeout select count(*) from __all_virtual_ha_diagnose where tenant_id=$mysql_tenant_id and svr_ip like '$z3_dst_ip0' and svr_port = $z3_dst_port0 and parent like '', $number_of_mysql_tenant_ls, 30;
