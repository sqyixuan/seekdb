CREATE RESOURCE UNIT my_unit MAX_CPU 1, MAX_MEMORY 1073741824, MAX_IOPS 100000, MAX_DISK_SIZE 536870912, MAX_SESSION_NUM 64, MIN_CPU=1, MIN_MEMORY=1073741824, MIN_IOPS=128;
CREATE RESOURCE POOL my_pool UNIT = 'my_unit', UNIT_NUM = 1, ZONE_LIST = ('z1', 'z2','z3', 'z4', 'z5', 'z6', 'z7', 'z8', 'z9', 'z10');
CREATE TENANT tt1 RESOURCE_POOL_LIST = ('my_pool'), locality='F@z1, R@z2, F@z3, R@z4, F@z5, R@z6, F@z7, R@z8, F@z9, R@z10', primary_zone='z3,z4;z5,z6;z1,z2' set ob_tcp_invited_nodes='%';
ob1.destroy_client;
ob1.create_client tenant=tt1,user=root,passwd=,database=test;
create table t1(c1 int primary key);
insert into t1 values (1), (11), (111);
select * from t1;
c1
1
11
111
create table subpt2 (c1 int, c2 int, c3 int, primary key(c1, c2)) partition by key(c1) subpartition by range columns (c2) subpartition template (subpartition p0 values less than (10), subpartition p1 values less than (100) ) partitions 16;
ob1.destroy_client;
ob1.create_client tenant=sys,user=root,passwd=,database=oceanbase;
