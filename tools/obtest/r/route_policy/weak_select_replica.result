alter system set enable_max_availability_for_weak_consistency = true;
alter system set max_stale_time_for_weak_consistency = '1h';
alter system set balancer_idle_time = '10s';
alter system set server_data_copy_out_concurrency = 50;
alter system set server_data_copy_in_concurrency = 50;
alter system set data_copy_concurrency = 50;
select B.zone, B.replica_type from oceanbase.__all_virtual_table A, oceanbase.__all_root_table B where A.tenant_id=1 and A.table_name='__all_sys_variable' and A.table_id=B.table_id and B.partition_id=0 order by B.zone, B.replica_type;
zone	replica_type
z1	0
z3	0
z5	0
z7	0
z9	0
CREATE RESOURCE UNIT sys_unit2 MAX_CPU 1, MAX_MEMORY 1073741824, MAX_IOPS 100000, MAX_DISK_SIZE 536870912, MAX_SESSION_NUM 64, MIN_CPU=1, MIN_MEMORY=1073741824, MIN_IOPS=128;
CREATE RESOURCE POOL sys_pool2 UNIT = 'sys_unit2', UNIT_NUM = 1, ZONE_LIST = ('z2', 'z4', 'z6', 'z8', 'z10');
alter tenant sys resource_pool_list = ('sys_pool', 'sys_pool2');
alter tenant sys locality = 'F@z1, R@z2, F@z3, R@z4, F@z5, R@z6, F@z7, R@z8, F@z9, R@z10';
select primary_zone, zone_list, locality, replica_num, previous_locality from oceanbase.__all_tenant where tenant_id = 1;
primary_zone	zone_list	locality	replica_num	previous_locality
z1;z3	z1;z10;z2;z3;z4;z5;z6;z7;z8;z9	FULL{1}@z1, READONLY{1}@z10, READONLY{1}@z2, FULL{1}@z3, READONLY{1}@z4, FULL{1}@z5, READONLY{1}@z6, FULL{1}@z7, READONLY{1}@z8, FULL{1}@z9	-1	FULL{1}@z1, FULL{1}@z3, FULL{1}@z5, FULL{1}@z7, FULL{1}@z9
ob1.check_until_timeout select count(*) c from oceanbase.__all_tenant where tenant_id = 1 and previous_locality != '', 0, 200;
select B.zone, B.replica_type from oceanbase.__all_virtual_table A, oceanbase.__all_root_table B where A.tenant_id=1 and A.table_name='__all_sys_variable' and A.table_id=B.table_id and B.partition_id=0 order by B.zone, B.replica_type;
