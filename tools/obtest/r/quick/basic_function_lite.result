===============================================================
============     alter schema before restart   ================
===============================================================
test alter schema before restart begin
create table t_no_pk(a int, b int);
insert into t_no_pk values(1, 1), (2, 2);
alter table t_no_pk add x varchar(10) after a;
insert into t_no_pk values(3, 'hehe', 3);
alter table t_no_pk add y int;
insert into t_no_pk values(4, '666', 4, 4), (5, '888', 5, 5);
select * from t_no_pk;
a	x	b	y
1	NULL	1	NULL
2	NULL	2	NULL
3	hehe	3	NULL
4	666	4	4
5	888	5	5
drop table t_no_pk;
test alter schema before restart finish
===============================================================
=================     restart cluster    ======================
===============================================================
test restart cluster begin
create table t1_reboot (c1 int);
insert into t1_reboot values(1);
select count(*) as cnt from oceanbase.__all_virtual_server_stat where create_time != 0;
cnt
1
ob1.force_stop;
ob1.nstart;
ob1.check_until_timeout select count(*) as cnt from oceanbase.V\$OB_SERVER_STAT where start_service_time > $stop_tstamp_usec, 1, 180;
ob1.check_until_timeout select count(*) as cnt from oceanbase.__all_virtual_server_stat where create_time = $server_create_time, 1, 10;
ob1.check_until_timeout select count(*) as cnt from oceanbase.V\$OB_SERVER_STAT where time_to_usec(create_time) = $server_create_time, 1, 10;
ob1.check_until_timeout select count(*) > 0 from oceanbase.__all_virtual_server_schema_info, 1, 120;
ob1.check_until_timeout select count(*) as cnt from oceanbase.__all_virtual_server_schema_info as a join oceanbase.__all_virtual_server_schema_info as b where a.refreshed_schema_version != b.refreshed_schema_version or a.refreshed_schema_version % 8 != 0, 0, 180;
ob1.check_until_timeout select count(*) from __all_virtual_memory_info where mod_name like '%OB_MOD_DO_NOT_USE_ME%' and hold != 0, 0, 10;
select * from t1_reboot;
c1
1
test restart cluster finish
===============================================================
=================     tablet report    ========================
===============================================================
test tablet report begin
ob1.check_until_timeout select count(*) = $server_count * ($sys_table_count + $core_table_count) from oceanbase.__all_virtual_tablet_meta_table where tablet_id < $max_index_tablet_id, 1, 200;
create table sys_t1(c1 int);
ob1.check_until_timeout select count(*) = $server_count from oceanbase.__all_virtual_tablet_meta_table where tablet_id = $tablet_id, 1, 200;
create table sys_t2(c1 int) partition by hash(c1) partitions 3;
ob1.check_until_timeout select count(*) = $partition_num * $server_count from oceanbase.__all_virtual_tablet_meta_table where tablet_id in ($tablet_ids), 1, 200;
test tablet report finish
