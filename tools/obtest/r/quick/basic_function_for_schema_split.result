ob1=OBI(cluster=1:1:1,init_unit_cpu=2,proxy_num=1);
ob2=OBI(cluster=1:1,leaderob=ob1,proxy_num=0);
ob1.z1.obs0.set extra_config=__schema_split_mode=true;
ob1.z2.obs0.set extra_config=__schema_split_mode=true;
ob1.z3.obs0.set extra_config=__schema_split_mode=true;
ob2.z1.obs0.set extra_config=__schema_split_mode=true;
ob2.z2.obs0.set extra_config=__schema_split_mode=true;
ob1.reboot;
ob2.reboot;
ob1.mysql alter system set merger_switch_leader_duration_time = '10s';
ob1.mysql alter system set resource_hard_limit= 800;
ob1.source include/merge.inc;
ob1.source include/migrate.inc;
ob1.mysql alter system set enable_rebalance = 'true';
ob1.mysql alter system set enable_rereplication = 'true';
ob1.mysql alter system set balancer_idle_time = '10s';
ob1.mysql alter system set server_data_copy_in_concurrency = 20;
ob1.mysql alter system set server_data_copy_out_concurrency = 20;
alter system set balancer_idle_time = '10s';
alter system set server_data_copy_out_concurrency = 30;
alter system set server_data_copy_in_concurrency = 30;
alter system set data_copy_concurrency = 60;
set @@session.ob_query_timeout = 20000000;
ob1.mysql create resource unit box1 max_cpu 2, max_memory 2073741824, max_iops 100000, max_disk_size '5G', max_session_num 64, MIN_CPU=1, MIN_MEMORY=2073741824, MIN_IOPS=128;
ob1.mysql create resource pool pool1 unit = 'box1', unit_num = 1;
ob1.mysql create tenant oracle replica_num = 1, resource_pool_list=('pool1'), primary_zone = "z1;z2;z3" set ob_tcp_invited_nodes='%', ob_compatibility_mode='oracle';
set @@session.ob_query_timeout = 10000000;
ob1.mysql alter tenant oracle set variables autocommit='on';
create user obtest IDENTIFIED BY obtest;
grant all on *.* to obtest WITH GRANT OPTION;
create table t1(pk int primary key, c1 number);
insert into t1 values(1,1),(2,2);
delete from t1 where pk=1;
select * from t1;
PK	C1
2	2
ob2.check_until_timeout select count(*) from __all_virtual_meta_table where tenant_id = $tenant_id and status = 'REPLICA_STATUS_NORMAL', 2, 120;
select /*+ read_consistency(weak)*/* from t1;
PK	C1
2	2
ob1.mysql alter system minor freeze tenant = sys;
ob1.mysql alter system minor freeze tenant = all_user;
ob1.mysql alter system minor freeze tenant = all_meta;
ob1.check_until_timeout select count(1) from __all_virtual_memstore_info where is_active=0, 0, 60;
ob1.mysql alter system major freeze;
ob1.check_version 2;
ob2.check_version 2;
select * from obtest1 limit 20;
i1	i2	v3	v4	i5	d6	i7	i8
