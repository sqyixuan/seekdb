ob1.mysql alter tenant obtest locality='F@z1,F@z2,R@z3';
ob1.check_until_timeout select count(*) c from oceanbase.__all_tenant where tenant_id = $tenant_id and previous_locality != '', 0, 300;
ob1.check_until_timeout select count(*) c from oceanbase.__all_rootservice_job where job_status="SUCCESS", 1, 30;
ob1.mysql alter system set enable_auto_leader_switch = false;
ob1.z2.obs0.switch_partition sys:oceanbase:__all_root_table;
ob1.z2.obs0.switch_partition sys:oceanbase:__all_core_table;
ob1.z2.obs0.check_leader sys:oceanbase:__all_root_table;
ob1.z2.obs0.check_leader sys:oceanbase:__all_core_table;
ob1.mysql alter system set enable_auto_leader_switch = true;
select * from __all_root_table limit 1;
select * from __all_core_table limit 1;
ob1.force_stop;
ob1.nstart;
ob1.check_until_timeout SELECT CAST(COUNT(*) AS SIGNED) as cnt FROM __all_virtual_clog_stat WHERE is_in_sync = 0 and is_offline=0,0,600;
