ob1=OBI(cluster=1:1:1,proxy_num=0);
ob1.z1.obs0.set extra_config=$extra_conf;
ob1.z2.obs0.set extra_config=$extra_conf;
ob1.z3.obs0.set extra_config=$extra_conf;
===============================================================
====================     bootstrap   ==========================
===============================================================
test case for bootstrap begin
ob1.reboot;
ob1.mysql alter system set enable_rebalance='false';
test case for bootstrap finish
===============================================================
==================     create tenant   ========================
===============================================================
set @@session.ob_query_timeout = 1000000000;
CREATE RESOURCE UNIT if not exists unit_1 MAX_CPU 2, MEMORY_SIZE='2G';
CREATE RESOURCE POOL if not exists pool_1 UNIT = 'unit_1', UNIT_NUM = 1;
CREATE TENANT mysql RESOURCE_POOL_LIST = ('pool_1'), primary_zone='z1', locality='F@z1, F@z2, F@z3' set ob_tcp_invited_nodes='%';
ob1.check_until_timeout select count(*) as cnt from oceanbase.__all_virtual_server_schema_info as a join oceanbase.__all_virtual_server_schema_info as b on a.tenant_id = b.tenant_id  where a.refreshed_schema_version != b.refreshed_schema_version, 0, 60;
ob1.mysql alter system set _transfer_start_trans_timeout = '10s' tenant = 'mysql';
===============================================================
=========  empty cluster primary zone from 1 to 3   ===========
===============================================================
alter tenant mysql set primary_zone = 'RANDOM';
===============================================================
==========   empty cluster verify transfer    =================
===============================================================
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_balance_job_history where tenant_id = $mysql_tenant_id, 1, 300;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_balance_job where tenant_id = $mysql_tenant_id, 0, 60;
ob1.check_until_timeout select count(*) from oceanbase.CDB_OB_LS where tenant_id = $mysql_tenant_id and status != 'NORMAL', 0, 100;
