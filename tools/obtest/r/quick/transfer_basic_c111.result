===============================================================
=================     restart cluster    ======================
===============================================================
test restart cluster begin
ob1.force_stop;
ob1.nstart;
ob1.check_until_timeout select count(*) as cnt from oceanbase.__all_server where start_service_time <= $stop_tstamp_usec, 0 ,180;
ob1.check_until_timeout select count(*) from oceanbase.__all_server a left join oceanbase.__all_virtual_server_schema_info b on a.svr_ip = b.svr_ip and a.svr_port = b.svr_port where b.svr_ip is null, 0, 120;
ob1.check_until_timeout select count(*) as cnt from oceanbase.__all_virtual_server_schema_info as a join oceanbase.__all_virtual_server_schema_info as b on a.tenant_id = b.tenant_id  where a.refreshed_schema_version != b.refreshed_schema_version or a.refreshed_schema_version % 8 != 0, 0, 180;
ob1.check_until_timeout select count(*) from __all_virtual_memory_info where mod_name like '%OB_MOD_DO_NOT_USE_ME%' and hold != 0, 0, 10;
test restart cluster finish
===============================================================
==============     switch replica leader    ===================
===============================================================
test switch mysql replica leader begin
count(*)
0
ob1.check_until_timeout select count(*) from __all_virtual_ls_meta_table where tenant_id = '$mysql_tenant_id' and svr_ip = '$follower1_svr_ip' and svr_port='$follower1_svr_port' and ls_id = $ls_id and role = 1, 1, 6;
count(*)
1
ob1.check_until_timeout select count(*) from __all_virtual_ls_meta_table where tenant_id = '$mysql_tenant_id' and svr_ip = '$leader_svr_ip' and svr_port='$leader_svr_port' and ls_id = $ls_id and role = 1, 1, 6;
count(*)
1
create table if not exists t_for_switch (c1 int);
ob1.check_until_timeout select count(*) as cnt from oceanbase.__all_virtual_server_schema_info as a join oceanbase.__all_virtual_server_schema_info as b on a.tenant_id = b.tenant_id  where a.refreshed_schema_version != b.refreshed_schema_version, 0, 60;
begin;
insert into t_for_switch values (1);
ob1.check_until_timeout select count(*) from __all_virtual_ls_meta_table where tenant_id = '$mysql_tenant_id' and svr_ip = '$follower1_svr_ip' and svr_port='$follower1_svr_port' and ls_id = $ls_id and role = 1, 1, 6;
count(*)
1
commit;
select * from t_for_switch order by c1 asc;
c1
1
ob1.check_until_timeout select count(*) from __all_virtual_ls_meta_table where tenant_id = '$mysql_tenant_id' and svr_ip = '$leader_svr_ip' and svr_port='$leader_svr_port' and ls_id = $ls_id and role = 1, 1, 6;
count(*)
1
begin;
insert into t_for_switch values (2);
ob1.check_until_timeout select count(*) from __all_virtual_ls_meta_table where tenant_id = '$mysql_tenant_id' and svr_ip = '$follower1_svr_ip' and svr_port='$follower1_svr_port' and ls_id = $ls_id and role = 1, 1, 6;
count(*)
1
insert into t_for_switch values (3);
commit;
select * from t_for_switch order by c1 asc;
c1
1
