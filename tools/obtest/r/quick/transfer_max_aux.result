ob1=OBI(cluster=1:1,proxy_num=0);
ob1.reboot;
ob1.z1.obs0.set extra_config=$extra_conf;
ob1.z2.obs0.set extra_config=$extra_conf;
set @@session.ob_query_timeout = 1000000000;
alter system set _enable_add_fulltext_index_to_existing_table = true;
# create mysql tenant
CREATE RESOURCE UNIT if not exists unit_x MAX_CPU 2, MEMORY_SIZE='4G';
CREATE RESOURCE POOL if not exists pool_x UNIT = 'unit_x', UNIT_NUM = 1;
CREATE TENANT mysql RESOURCE_POOL_LIST = ('pool_x'), primary_zone='z1,z2', locality="F@z1,F@z2" set ob_tcp_invited_nodes='%';
set recyclebin = off;
create database d_transfer_max_aux_test;
# 1 verify that a partition with max vector hnsw index (now max aux tables) can be transferred
set @@session.ob_query_timeout = 1000000000;
# create table with 128 vec hnsw index
alter system set ob_vector_memory_limit_percentage = 44;
alter system set _transfer_start_trans_timeout = '3s';
# 2 verify that a partition with max vector ivfflat index (now max aux tables) can be transferred
set @@session.ob_query_timeout = 1000000000;
# create table with 128 vec ivfflat index
alter system set ob_vector_memory_limit_percentage = 44;
# 3 verify that a partition with max vector ivfsq8 index (now max aux tables) can be transferred
set @@session.ob_query_timeout = 1000000000;
# create table with 128 vec ivfsq8 index
alter system set ob_vector_memory_limit_percentage = 44;
# 4 verify that a partition with max vector ivfpq index (now max aux tables) can be transferred
set @@session.ob_query_timeout = 1000000000;
# create table with 128 vec ivfpq index
alter system set ob_vector_memory_limit_percentage = 44;
# 5 verify that a partition with max fts index can be transferred
set @@session.ob_query_timeout = 1000000000;
# create table with 128 fts index
# 6 verify that a partition with max multivalue index can be transferred
set @@session.ob_query_timeout = 1000000000;
# create table with 128 multivalue index
# alter primary_zone to trigger transfer task
alter tenant mysql primary_zone = 'z1';
ob1.check_until_timeout select count(*) from CDB_OB_BALANCE_JOBS where tenant_id = $mysql_tenant_id, 1, 60;
ob1.check_until_timeout select count(*) from CDB_OB_BALANCE_JOBS where tenant_id = $mysql_tenant_id, 0, 200;
# verify transfer success
select src_ls, dest_ls, tablet_count, status, result from oceanbase.DBA_OB_TRANSFER_TASK_HISTORY where part_list like '%500003%' and result = 0;
src_ls	dest_ls	tablet_count	status	result
1002	1001	390	COMPLETED	0
select src_ls, dest_ls, tablet_count, status, result from oceanbase.DBA_OB_TRANSFER_TASK_HISTORY where part_list like '%501173%' and result = 0;
src_ls	dest_ls	tablet_count	status	result
1002	1001	388	COMPLETED	0
select src_ls, dest_ls, tablet_count, status, result from oceanbase.DBA_OB_TRANSFER_TASK_HISTORY where part_list like '%502337%' and result = 0;
src_ls	dest_ls	tablet_count	status	result
1002	1001	516	COMPLETED	0
select src_ls, dest_ls, tablet_count, status, result from oceanbase.DBA_OB_TRANSFER_TASK_HISTORY where part_list like '%503885%' and result = 0;
src_ls	dest_ls	tablet_count	status	result
1002	1001	516	COMPLETED	0
select src_ls, dest_ls, tablet_count, status, result from oceanbase.DBA_OB_TRANSFER_TASK_HISTORY where part_list like '%505433%' and result = 0;
src_ls	dest_ls	tablet_count	status	result
1002	1001	262	COMPLETED	0
select src_ls, dest_ls, tablet_count, status, result from oceanbase.DBA_OB_TRANSFER_TASK_HISTORY where part_list like '%506219%' and result = 0;
src_ls	dest_ls	tablet_count	status	result
1002	1001	134	COMPLETED	0
drop database d_transfer_max_aux_test;
##
# 7 test _transfer_task_tablet_count_threshold
# limit 0 < _transfer_task_tablet_count_threshold <= OB_MAX_TRANSFER_BINDING_TABLET_CNT
set @@session.ob_query_timeout = 1000000000;
ob1.check_until_timeout select count(*) from CDB_OB_BALANCE_JOBS where tenant_id = $mysql_tenant_id, 0, 100;
alter system set _transfer_task_tablet_count_threshold = 0 tenant mysql;
ERROR HY000: Invalid config
alter system set _transfer_task_tablet_count_threshold = 519 tenant mysql;
ERROR HY000: Incorrect arguments to _transfer_task_tablet_count_threshold of tenant 1002, it cannot be greater than 518
alter system set _transfer_task_tablet_count_threshold = 518 tenant mysql;
set @@session.ob_query_timeout = 1000000000;
# create normal table with max transfer tablets
# alter primary_zone to trigger transfer task
alter tenant mysql primary_zone = 'z1,z2';
ob1.check_until_timeout select count(*) from CDB_OB_BALANCE_JOBS where tenant_id = $mysql_tenant_id, 1, 60;
ob1.check_until_timeout select count(*) from CDB_OB_BALANCE_JOBS where tenant_id = $mysql_tenant_id, 0, 200;
# verify transfer success
select src_ls, dest_ls, tablet_count, status, result from oceanbase.DBA_OB_TRANSFER_TASK_HISTORY where part_list like '%506621%' and result = 0;
src_ls	dest_ls	tablet_count	status	result
1001	1003	518	COMPLETED	0
drop tenants
set recyclebin = off;
drop tenant mysql force;
