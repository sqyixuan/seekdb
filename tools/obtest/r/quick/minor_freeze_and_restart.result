ob1=OBI(cluster=1:1:1, proxy_num=0, init_unit_cpu=1);
ob1.z1.obs0.set extra_config=_enable_defensive_check=0,$extra_conf;
ob1.z2.obs0.set extra_config=_enable_defensive_check=0,$extra_conf;
ob1.z3.obs0.set extra_config=_enable_defensive_check=0,$extra_conf;
ob1.force_stop;
ob1.reboot;
ob1.mysql alter system set enable_rebalance='false';
set @@session.ob_query_timeout = 1000000000;
CREATE RESOURCE UNIT unit_1 MAX_CPU 1, MAX_MEMORY 1073741824, MAX_IOPS 100000, MAX_DISK_SIZE 536870912, MAX_SESSION_NUM 64, MIN_CPU=1, MIN_MEMORY=1073741824, MIN_IOPS=128;
CREATE RESOURCE POOL pool_1 UNIT = 'unit_1', UNIT_NUM = 1;
CREATE TENANT mysql RESOURCE_POOL_LIST = ('pool_1'), primary_zone='z1' set ob_tcp_invited_nodes='%';
ob1.check_until_timeout select count(*) as cnt from oceanbase.__all_virtual_server_schema_info as a join oceanbase.__all_virtual_server_schema_info as b on a.tenant_id = b.tenant_id  where a.refreshed_schema_version != b.refreshed_schema_version, 0, 60;
create table t1_no_pk (c1 int);
