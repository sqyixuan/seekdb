ob1=OBI(cluster=1:1,proxy_num=0,init_unit_cpu=5);
ob1.reboot;
ob1.mysql alter system set enable_auto_leader_switch=false;
set ob_query_timeout=90000000;
set ob_trx_timeout=1200000000;
create database obtest;
use obtest;
create table t1(id1 int, id2 int) primary_zone='z1';
create table t2(id1 int, id2 int) primary_zone='z2';
desc t1;
Field	Type	Null	Key	Default	Extra
id1	int(11)	YES		NULL	
id2	int(11)	YES		NULL	
desc t2;
Field	Type	Null	Key	Default	Extra
id1	int(11)	YES		NULL	
id2	int(11)	YES		NULL	
start transaction;
insert into t1 values(1, 10);
insert into t2 values(2, 20);
update t1 set id2=11 where id1 = 1;
update t2 set id2=21 where id1 = 2;
ob1.z2.obs0.switch_partition obtest:obtest:t1;
ob1.z1.obs0.switch_partition obtest:obtest:t2;
select * from t1;
id1	id2
1	11
select * from t2;
id1	id2
2	21
update t1 set id2=12 where id1 = 1;
update t2 set id2=22 where id1 = 2;
select * from t1;
id1	id2
1	12
select * from t2;
id1	id2
2	22
ob1.z1.obs0.switch_partition obtest:obtest:t1;
ob1.z2.obs0.switch_partition obtest:obtest:t2;
select * from t1;
id1	id2
1	12
select * from t2;
id1	id2
2	22
update t1 set id2=13 where id1 = 1;
update t2 set id2=23 where id1 = 2;
select * from t1;
id1	id2
1	13
select * from t2;
id1	id2
2	23
commit;
select * from t1;
id1	id2
1	13
select * from t2;
id1	id2
2	23
start transaction;
update t1 set id2=14 where id1 = 1;
update t2 set id2=24 where id1 = 2;
select * from t1;
id1	id2
1	14
select * from t2;
id1	id2
2	24
ob1.z2.obs0.switch_partition obtest:obtest:t1;
ob1.z1.obs0.switch_partition obtest:obtest:t2;
commit;
select * from t1;
id1	id2
1	14
select * from t2;
id1	id2
2	24
start transaction;
update t1 set id2=15 where id1 = 1;
update t2 set id2=25 where id1 = 2;
select * from t1;
id1	id2
1	15
select * from t2;
id1	id2
2	25
ob1.z1.obs0.switch_partition obtest:obtest:t1;
ob1.z2.obs0.switch_partition obtest:obtest:t2;
rollback;
ob1.mysql alter system major freeze;
select * from t1;
id1	id2
1	14
select * from t2;
id1	id2
2	24
drop table t1;
drop table t2;
