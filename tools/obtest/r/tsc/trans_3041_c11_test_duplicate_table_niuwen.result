ob1=OBI(cluster=1:1:1,proxy_num=0,init_unit_cpu=5);
ob1.reboot;
ob1.mysql create resource pool rp1 unit = 'sys_unit_config', unit_num = 1, zone_list = ('z1', 'z2', 'z3');
ob1.mysql create tenant duplicate_tenant replica_num 3, primary_zone 'z1', resource_pool_list ('rp1'), locality = "F@z1,F@z2,F@z3" set ob_tcp_invited_nodes='%';
ob1.mysql alter system set enable_auto_leader_switch = false;
use test;
drop table if exists t1;
drop table if exists t2;
drop table if exists t1_dup;
drop table if exists t2_dup;
create table t1 (x int, y int);
create table t2 (x int, y int);
create table t1_dup (x int, y int) duplicate_scope = 'cluster';
create table t2_dup (x int, y int) duplicate_scope = 'cluster';
ob1.z1.obs0.switch_partition duplicate_tenant:test:t1;
ob1.z1.obs0.switch_partition duplicate_tenant:test:t2;
ob1.z1.obs0.switch_partition duplicate_tenant:test:t1_dup;
ob1.z1.obs0.switch_partition duplicate_tenant:test:t2_dup;
ob1.z1.obs0.check_leader duplicate_tenant:test:t1;
ob1.z1.obs0.check_leader duplicate_tenant:test:t2;
ob1.z1.obs0.check_leader duplicate_tenant:test:t1_dup;
ob1.z1.obs0.check_leader duplicate_tenant:test:t2_dup;
