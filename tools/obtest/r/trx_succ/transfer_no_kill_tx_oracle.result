explain basic insert into stu2 select * from stu1 ON DUPLICATE KEY UPDATE col2=1000;
Query Plan
============================================
|ID|OPERATOR               |NAME           |
--------------------------------------------
|0 |EXCHANGE IN REMOTE     |               |
|1 |└─EXCHANGE OUT REMOTE  |               |
|2 |  └─INSERT_UP          |               |
|3 |    └─SUBPLAN SCAN     |ANONYMOUS_VIEW1|
|4 |      └─TABLE FULL SCAN|stu1           |
============================================
Outputs & filters:
-------------------------------------
  0 - output(nil), filter(nil)
  1 - output(nil), filter(nil)
  2 - output(nil), filter(nil)
      columns([{stu2: ({stu2: (stu2.col1, stu2.col2)})}]), partitions(p0), 
      column_values([column_conv(INT,PS:(11,0),NOT NULL,ANONYMOUS_VIEW1.col1)], [column_conv(INT,PS:(11,0),NULL,ANONYMOUS_VIEW1.col2)]),
      update([stu2.col2=column_conv(INT,PS:(11,0),NULL,cast(1000, INT(-1, 0)))])
  3 - output([ANONYMOUS_VIEW1.col1], [ANONYMOUS_VIEW1.col2]), filter(nil), rowset=16
      access([ANONYMOUS_VIEW1.col1], [ANONYMOUS_VIEW1.col2])
  4 - output([stu1.col1], [stu1.col2]), filter(nil), rowset=16
      access([stu1.col1], [stu1.col2]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([stu1.col1]), range(MIN ; MAX)always true
insert into stu2 select * from stu1 ON DUPLICATE KEY UPDATE col2=1000;
commit;
