src_ls	dest_ls	part_list	part_count	not_exist_part_list	lock_conflict_part_list	table_lock_tablet_list	tablet_list	tablet_count	status	result	comment
1002	1001	500003:500003	1	NULL	NULL	NULL	200002:0	1	COMPLETED	0	
alter system change tenant mysql;
DELETE FROM oceanbase.__all_balance_job_history;
DELETE FROM oceanbase.__all_balance_task_history;
DELETE FROM oceanbase.__all_transfer_task_history;
alter system change tenant sys;
