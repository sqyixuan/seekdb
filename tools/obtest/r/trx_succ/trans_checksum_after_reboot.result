ob1=OBI(cluster=1:1,proxy_num=0,init_unit_cpu=5);
ob1.reboot;
ob1.mysql alter system minor freeze tenant obtest server = ('$ip1:$port1');
ob1.mysql alter system minor freeze tenant obtest server = ('$ip2:$port2');
ob1.z2.obs0.force_stop;
ob1.z2.start;
ob1.mysql alter system minor freeze tenant obtest server = ('$ip1:$port1');
ob1.mysql alter system minor freeze tenant obtest server = ('$ip2:$port2');
ob1.z2.obs0.force_stop;
