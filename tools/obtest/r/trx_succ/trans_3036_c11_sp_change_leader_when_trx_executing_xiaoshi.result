ob1=OBI(cluster=1:1,proxy_num=0,init_unit_cpu=5);
ob1.reboot;
ob1.mysql alter tenant obtest set primary_zone='z1';
ob1.check_until_timeout select count(1) from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id=$tenant_id and ls_id=$ls_id and SVR_IP='$ip0' and svr_port='$port0' and ROLE='LEADER', 1, 100;
set ob_query_timeout=90000000;
set ob_trx_timeout=1200000000;
create database obtest;
use obtest;
create table t1(id1 int, id2 int);
desc t1;
Field	Type	Null	Key	Default	Extra
id1	int(11)	YES		NULL	
id2	int(11)	YES		NULL	
start transaction;
insert into t1 values(1, 10);
update t1 set id2=11 where id1 = 1;
ob1.mysql alter tenant obtest set primary_zone='z2';
ob1.check_until_timeout select count(1) from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id=$tenant_id and ls_id=$ls_id and SVR_IP='$ip1' and svr_port='$port1' and ROLE='LEADER', 1, 100;
select * from t1;
id1	id2
1	11
update t1 set id2=12 where id1 = 1;
select * from t1;
id1	id2
1	12
ob1.mysql alter tenant obtest set primary_zone='z1';
ob1.check_until_timeout select count(1) from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id=$tenant_id and ls_id=$ls_id and SVR_IP='$ip0' and svr_port='$port0' and ROLE='LEADER', 1, 100;
select * from t1;
id1	id2
1	12
update t1 set id2=13 where id1 = 1;
select * from t1;
id1	id2
1	13
ob1.mysql alter tenant obtest set primary_zone='z2';
ob1.check_until_timeout select count(1) from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id=$tenant_id and ls_id=$ls_id and SVR_IP='$ip1' and svr_port='$port1' and ROLE='LEADER', 1, 100;
select * from t1;
id1	id2
1	13
update t1 set id2=14 where id1 = 1;
select * from t1;
id1	id2
1	14
commit;
select * from t1;
id1	id2
1	14
start transaction;
update t1 set id2=15 where id1 = 1;
ob1.mysql alter tenant obtest set primary_zone='z1';
ob1.check_until_timeout select count(1) from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id=$tenant_id and ls_id=$ls_id and SVR_IP='$ip0' and svr_port='$port0' and ROLE='LEADER', 1, 100;
commit;
select * from t1;
id1	id2
1	15
start transaction;
update t1 set id2=16 where id1 = 1;
ob1.mysql alter tenant obtest set primary_zone='z2';
ob1.check_until_timeout select count(1) from oceanbase.CDB_OB_LS_LOCATIONS where tenant_id=$tenant_id and ls_id=$ls_id and SVR_IP='$ip1' and svr_port='$port1' and ROLE='LEADER', 1, 100;
rollback;
select * from t1;
id1	id2
1	15
ob1.mysql alter system major freeze;
select * from t1;
id1	id2
1	15
drop table t1;
