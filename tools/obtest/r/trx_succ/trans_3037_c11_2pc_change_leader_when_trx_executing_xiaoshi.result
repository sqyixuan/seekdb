ob1=OBI(cluster=1:1,proxy_num=0,init_unit_cpu=5);
ob1.reboot;
set ob_query_timeout=90000000;
set ob_trx_timeout=1200000000;
create database obtest;
use obtest;
create table t1(id1 int, id2 int);
create table t2(id1 int, id2 int);
desc t1;
Field	Type	Null	Key	Default	Extra
id1	int(11)	YES		NULL	
id2	int(11)	YES		NULL	
desc t2;
Field	Type	Null	Key	Default	Extra
id1	int(11)	YES		NULL	
id2	int(11)	YES		NULL	
start transaction;
insert into t1 values(1, 10);
insert into t2 values(2, 20);
update t1 set id2=11 where id1 = 1;
update t2 set id2=21 where id1 = 2;
alter system switch replica leader ls=1001 server='11.124.5.40:29425' tenant='obtest';
ob1.check_until_timeout select count(1) from CDB_OB_table_LOCATIONS where tenant_id=$tenant_id  and ROLE='LEADER' and table_name='t1' and svr_ip='$svr_ip1' and svr_port='$svr_port1', 1, 100;
alter system switch replica leader ls=1002 server='11.124.5.40:29424' tenant='obtest';
ob1.check_until_timeout select count(1) from CDB_OB_table_LOCATIONS where tenant_id=$tenant_id  and ROLE='LEADER' and table_name='t2' and svr_ip='$svr_ip0' and svr_port='$svr_port0', 1, 100;
select * from t1;
id1	id2
1	11
select * from t2;
id1	id2
2	21
update t1 set id2=12 where id1 = 1;
update t2 set id2=22 where id1 = 2;
select * from t1;
id1	id2
1	12
select * from t2;
id1	id2
2	22
