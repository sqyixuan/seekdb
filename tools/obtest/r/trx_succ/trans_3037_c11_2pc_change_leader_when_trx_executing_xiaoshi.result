start transaction;
update t1 set id2=15 where id1 = 1;
update t2 set id2=25 where id1 = 2;
select * from t1;
id1	id2
1	15
select * from t2;
id1	id2
2	25
alter system switch replica leader ls=1001 server='11.124.5.40:29424' tenant='obtest';
ob1.check_until_timeout select count(1) from CDB_OB_table_LOCATIONS where tenant_id=$tenant_id  and ROLE='LEADER' and table_name='t1' and svr_ip='$svr_ip0' and svr_port='$svr_port0', 1, 100;
alter system switch replica leader ls=1002 server='11.124.5.40:29425' tenant='obtest';
ob1.check_until_timeout select count(1) from CDB_OB_table_LOCATIONS where tenant_id=$tenant_id  and ROLE='LEADER' and table_name='t2' and svr_ip='$svr_ip1' and svr_port='$svr_port1', 1, 100;
rollback;
ob1.mysql alter system major freeze tenant=sys;
ob1.mysql alter system major freeze tenant=all_user;
ob1.mysql alter system major freeze tenant=all_meta;
select * from t1;
