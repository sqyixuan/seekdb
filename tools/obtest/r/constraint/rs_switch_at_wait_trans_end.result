ob1=OBI(cluster=1:1:1,proxy_num=1,init_unit_cpu=1);
ob1.reboot;
ob1.create_client;
ob1.mysql alter system set merger_check_interval='10s';
ob1.mysql alter system set enable_rebalance = 'false';
ob1.mysql alter system set enable_auto_leader_switch='false';
ob1.mysql alter system set resource_hard_limit=500;
ob1.mysql alter system set debug_sync_timeout = '100000s';
ob1.mysql alter system set server_permanent_offline_time = '20s';
$leader_host.mysql set ob_global_debug_sync = 'CONSTRAINT_WAIT_TRANS_END wait_for signal execute 10000';
$leader_host.force_stop;
ob1.z2.obs0.mysql set ob_global_debug_sync = 'CONSTRAINT_WAIT_TRANS_END clear';
ob1.z2.obs0.mysql set ob_global_debug_sync = 'now signal signal';
