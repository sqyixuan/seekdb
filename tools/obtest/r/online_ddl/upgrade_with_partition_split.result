ob1.mysql alter system major freeze;
ob1.check_version $version;
ob1.mysql alter tenant obtest set rewrite_merge_version = $version;
alter table db1.t1 set progressive_merge_num = 3;
ob1.mysql alter system major freeze;
ob1.check_version $version;
create index idx_age on db1.t1(age) local;
ob1.check_until_timeout select index_status from oceanbase.__all_virtual_table where table_name like '%idx_age%', 2, 60;
alter table db1.t1 modify partition by range(id) (partition p0 values less than (5000), partition p1 values less than MAXVALUE);
ob1.mysql alter system major freeze;
ob1.check_version $version;
ob1.mysql alter system major freeze;
ob1.check_version $version;
ob1.mysql alter system major freeze;
ob1.check_version $version;
