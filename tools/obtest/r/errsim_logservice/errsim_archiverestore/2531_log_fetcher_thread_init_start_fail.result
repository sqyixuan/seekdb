ob1=OBI(cluster=1:1, proxy_num=0);
ob2=OBI(cluster=1:1, proxy_num=0);
ob1.reboot;
ob2.reboot;
create resource unit primary_unit max_cpu=4, memory_size='8G';
create resource pool primary_pool unit primary_unit, unit_num 1, zone_list ('z1','z2');
create tenant primary_tenant resource_pool_list=('primary_pool'), primary_zone='RANDOM' set ob_tcp_invited_nodes='%';
create user standby_user identified by 'standby';
GRANT SELECT on OCEANBASE.DBA_OB_ACCESS_POINT to standby_user;
GRANT SELECT on OCEANBASE.GV$OB_UNITS to standby_user;
GRANT SELECT on OCEANBASE.DBA_OB_TENANTS to standby_user;
GRANT SELECT on OCEANBASE.GV$OB_PARAMETERS to standby_user;
GRANT SELECT on OCEANBASE.GV$OB_LOG_STAT to standby_user;
GRANT SELECT on OCEANBASE.DBA_OB_LS to standby_user;
create resource unit standby_unit max_cpu=4, memory_size='8G';
create resource pool standby_pool unit standby_unit, unit_num 1, zone_list ('z1', 'z2');
ob2.check_until_timeout select time_to_usec(now(6)) - floor(sync_scn/1000) < 3 * 1000 * 1000 as not_sync from dba_ob_tenants where tenant_id=$standby_tenant_id, 1, 200;
alter system set_tp tp_name = LOG_ROUTE_TIMER_INIT_FAIL, error_code = 4013, frequency = 1;
alter system set_tp tp_name = LOG_ROUTE_HANDLER_INIT_FAIL, error_code = 4013, frequency = 1;
alter system set_tp tp_name = LOG_ROUTE_HANDLER_START_FAIL, error_code = 4013, frequency = 1;
alter system set_tp tp_name = LOG_FETCHER_STREAM_WORKER_INIT_FAIL, error_code = 4013, frequency = 1;
alter system set_tp tp_name = LOG_FETCHER_IDLE_POOL_START_FAIL, error_code = 4013, frequency = 1;
alter system set_tp tp_name = LOG_FETCHER_DEAD_POOL_START_FAIL, error_code = 4013, frequency = 1;
alter system set_tp tp_name = LOG_FETCHER_LSW_TIMER_START_FAIL, error_code = 4013, frequency = 1;
alter system set_tp tp_name = LOG_FETCHER_LSW_HANDLER_START_FAIL, error_code = 4013, frequency = 1;
ob2.mysql alter tenant standby_tenant primary_zone='RANDOM';
ob2.z2.obs0.check_log_until_success -c "ERRSIM: LOG_ROUTE_TIMER_INIT_FAIL";
alter system set_tp tp_name = LOG_ROUTE_TIMER_INIT_FAIL, error_code = 4013, frequency = 0;
ob2.check_until_timeout select time_to_usec(now(6)) - floor(sync_scn/1000) > 10 * 1000 * 1000 as not_sync from dba_ob_tenants where tenant_id=$standby_tenant_id, 1, 200;
ob2.z2.obs0.check_log_until_success -c "ERRSIM: LOG_ROUTE_HANDLER_INIT_FAIL";
alter system set_tp tp_name = LOG_ROUTE_HANDLER_INIT_FAIL, error_code = 4013, frequency = 0;
ob2.check_until_timeout select time_to_usec(now(6)) - floor(sync_scn/1000) > 10 * 1000 * 1000 as not_sync from dba_ob_tenants where tenant_id=$standby_tenant_id, 1, 200;
ob2.z2.obs0.check_log_until_success -c "ERRSIM: LOG_ROUTE_HANDLER_START_FAIL";
alter system set_tp tp_name = LOG_ROUTE_HANDLER_START_FAIL, error_code = 4013, frequency = 0;
ob2.check_until_timeout select time_to_usec(now(6)) - floor(sync_scn/1000) > 10 * 1000 * 1000 as not_sync from dba_ob_tenants where tenant_id=$standby_tenant_id, 1, 200;
ob2.z2.obs0.check_log_until_success -c "ERRSIM: LOG_FETCHER_STREAM_WORKER_INIT_FAIL";
alter system set_tp tp_name = LOG_FETCHER_STREAM_WORKER_INIT_FAIL, error_code = 4013, frequency = 0;
ob2.check_until_timeout select time_to_usec(now(6)) - floor(sync_scn/1000) > 10 * 1000 * 1000 as not_sync from dba_ob_tenants where tenant_id=$standby_tenant_id, 1, 200;
ob2.z2.obs0.check_log_until_success -c "ERRSIM: LOG_FETCHER_IDLE_POOL_START_FAIL";
alter system set_tp tp_name = LOG_FETCHER_IDLE_POOL_START_FAIL, error_code = 4013, frequency = 0;
ob2.check_until_timeout select time_to_usec(now(6)) - floor(sync_scn/1000) > 10 * 1000 * 1000 as not_sync from dba_ob_tenants where tenant_id=$standby_tenant_id, 1, 200;
ob2.z2.obs0.check_log_until_success -c "ERRSIM: LOG_FETCHER_DEAD_POOL_START_FAIL";
alter system set_tp tp_name = LOG_FETCHER_DEAD_POOL_START_FAIL, error_code = 4013, frequency = 0;
ob2.check_until_timeout select time_to_usec(now(6)) - floor(sync_scn/1000) > 10 * 1000 * 1000 as not_sync from dba_ob_tenants where tenant_id=$standby_tenant_id, 1, 200;
ob2.z2.obs0.check_log_until_success -c "ERRSIM: LOG_FETCHER_LSW_TIMER_START_FAIL";
alter system set_tp tp_name = LOG_FETCHER_LSW_TIMER_START_FAIL, error_code = 4013, frequency = 0;
ob2.check_until_timeout select time_to_usec(now(6)) - floor(sync_scn/1000) > 10 * 1000 * 1000 as not_sync from dba_ob_tenants where tenant_id=$standby_tenant_id, 1, 200;
ob2.z2.obs0.check_log_until_success -c "ERRSIM: LOG_FETCHER_LSW_HANDLER_START_FAIL";
alter system set_tp tp_name = LOG_FETCHER_LSW_HANDLER_START_FAIL, error_code = 4013, frequency = 0;
ob2.check_until_timeout select time_to_usec(now(6)) - floor(sync_scn/1000) < 3 * 1000 * 1000 as not_sync from dba_ob_tenants where tenant_id=$standby_tenant_id, 1, 200;
