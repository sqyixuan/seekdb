ob1=OBI(cluster = 2, proxy_num = 0);
ob2=OBI(cluster = 2, proxy_num = 0, leaderob=ob1);
ob1.force_stop;
ob2.force_stop;
ob1.reboot;
ob2.reboot;
alter system set balancer_idle_time = '10s';
alter system set server_data_copy_out_concurrency = 30;
alter system set server_data_copy_in_concurrency = 30;
alter system set data_copy_concurrency = 60;
alter system set enable_rebalance = false;
alter system set enable_rereplication = false;
ob2.check_until_timeout select count(*) from oceanbase.__all_ddl_operation where schema_version = $primary_schema_version, 1, 30;
ob2.check_until_timeout select count(*) from oceanbase.__all_cluster, 2, 20;
ob1.mysql CREATE RESOURCE POOL pool_1 UNIT = 'sys_unit_config', UNIT_NUM = 2, ZONE_LIST = ('z1');
ob1.mysql CREATE TENANT tt RESOURCE_POOL_LIST = ('pool_1'), primary_zone='z1' set ob_tcp_invited_nodes='%';
ob2.check_until_timeout select count(*) from oceanbase.__all_ddl_operation where schema_version = $primary_schema_version, 1, 30;
alter system ACTIVATE PHYSICAL STANDBY CLUSTER;
ERROR HY000: Failover is not allowed when primary cluster [cluster_id=1] is still alive
alter system set enable_rebalance = true;
alter system set enable_rereplication = true;
ob2.check_until_timeout select count(*) c from __all_root_table where tenant_id = 1001, $partition_cnt, 120;
ob2.mysql alter system set enable_rebalance = false;
ob1.mysql alter system set enable_rebalance = false;
ob1.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO STANDBY, 100;
ob2.check_until_timeout select count(*) from oceanbase.__all_virtual_ddl_operation where schema_version = $primary_schema_version, 1, 90;
ob1.mysql set ob_query_timeout=30000000;
alter system commit to switchover to physical standby;
alter system commit to switchover to primary;
ob2.force_stop;
set @@session.ob_query_timeout = 100000000;
alter system ACTIVATE PHYSICAL STANDBY CLUSTER;
