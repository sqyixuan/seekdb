ob1=OBI(cluster=1,init_unit_cpu=5,init_unit_num=1,init_unit_mem=5368709120,version=2_2_40,oblog_version=current,proxy_num=0);
ob2=OBI(cluster=1,leaderob=ob1,proxy_num=0,version=2_2_40);
ob3=OBI(cluster=1,leaderob=ob1,proxy_num=0,version=2_2_40);
ob1.z1.obs0.set extra_config=memory_chunk_cache_size=1G;
ob1.reboot;
set ob_query_timeout = 30000000;
CREATE RESOURCE UNIT unit_1 MAX_CPU 1, MAX_MEMORY 5368709120, MAX_IOPS 100000, MAX_DISK_SIZE 536870912, MAX_SESSION_NUM 64, MIN_CPU=1, MIN_MEMORY=5368709120, MIN_IOPS=128;
CREATE RESOURCE POOL pool_1 UNIT = 'unit_1', UNIT_NUM = 1, ZONE_LIST = ('z1');
CREATE TENANT tenant_1 RESOURCE_POOL_LIST = ('pool_1'), primary_zone='z1' set ob_tcp_invited_nodes='%';
ob1.z1.obs0.sh cd $work_dir/; ls -l {etc,etc2,etc3}/observer.conf*.bin;
ob1.mysql alter system set balancer_idle_time='10s';
ob1.mysql alter system set merger_check_interval='10s';
ob1.mysql alter system set resource_soft_limit=200;
ob1.mysql alter system set resource_hard_limit=200;
ob1.mysql alter system major freeze;
ob1.check_version 2;
ob1.check_until_timeout select info from __all_zone where zone='' and name='merge_status',IDLE,30;
ob2.reboot;
ob2.check_until_timeout select value from __all_zone where zone = '' and name = 'last_merged_version', 2, 480;
ob2.check_until_timeout select column_value from __all_core_table where table_name = '__all_global_stat' and column_name = 'standby_snapshot_frozen_version', 0, 3;
ob1.mysql alter system major freeze;
ob1.mysql alter system major freeze;
ob1.check_until_timeout select value from __all_zone where zone = '' and name = 'last_merged_version', 4, 360;
ob3.reboot;
ob3.check_until_timeout select value from __all_zone where zone = '' and name = 'last_merged_version', 4, 360;
ob3.check_until_timeout select column_value from __all_core_table where table_name = '__all_global_stat' and column_name = 'standby_snapshot_frozen_version', 2, 3;
ob2.check_until_timeout select value from __all_zone where zone = '' and name = 'last_merged_version', 4, 360;
ob1.check_until_timeout select info from __all_zone where zone='' and name='merge_status',IDLE,30;
ob2.check_until_timeout select info from __all_zone where zone='' and name='merge_status',IDLE,30;
ob3.check_until_timeout select info from __all_zone where zone='' and name='merge_status',IDLE,30;
ob1.upgrade_check_before;
ob1.mysql alter system begin upgrade;
ob1.upgrade_commond_for_server pre;
ob1.check_until_timeout select count(1) from __all_virtual_core_meta_table where role=1 and zone='z1',1,120;
ob1.check_until_timeout SELECT CAST(COUNT(*) AS SIGNED) as cnt FROM __all_virtual_clog_stat WHERE is_in_sync = 0 and is_offline=0,0,600;
ob1.z1.force_stop;
ob1.z1.upgrade;
ob1.z1.nstart;
ob1.check_until_timeout select count(1) from __all_virtual_core_meta_table where role=1 and zone='z1',1,120;
ob2.z1.force_stop;
ob2.z1.upgrade;
ob2.z1.nstart;
ob2.check_until_timeout select count(1) from __all_virtual_core_meta_table where role=1 and zone='z1',1,120;
ob3.z1.force_stop;
ob3.z1.upgrade;
ob3.z1.nstart;
ob3.check_until_timeout select count(1) from __all_virtual_core_meta_table where role=1 and zone='z1',1,120;
set @@session.ob_query_timeout = 60000000;
alter system upgrade virtual schema;
ob1.check_until_timeout select count(*) as cnt from oceanbase.__all_virtual_server_schema_info as a join oceanbase.__all_virtual_server_schema_info as b on a.tenant_id = b.tenant_id  where a.refreshed_schema_version != b.refreshed_schema_version, 0, 50;
select count(*) > 0 from oceanbase.__all_virtual_tenant_partition_meta_table;
count(*) > 0
0
ob1.upgrade_commond_for_server post;
ob1.mysql alter system end upgrade;
ob1.mysql alter system run job 'root_inspection';
ob1.upgrade_check_after;
ob1.mysql alter system major freeze;
ob1.check_until_timeout select value from __all_zone where zone = '' and name = 'last_merged_version', 5, 360;
ob2.check_until_timeout select value from __all_zone where zone = '' and name = 'last_merged_version', 5, 360;
ob3.check_until_timeout select value from __all_zone where zone = '' and name = 'last_merged_version', 5, 360;
