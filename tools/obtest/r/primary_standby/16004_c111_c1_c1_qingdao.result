ob1=OBI(cluster=1:1:1, proxy_num = 0);
ob2=OBI(cluster=1, proxy_num = 0, leaderob=ob1);
ob1.reboot;
ob1.mysql alter system set resource_hard_limit=900;
ob1.mysql alter system set resource_soft_limit=800;
ob1.mysql CREATE RESOURCE UNIT unit_$case_index MAX_CPU $cpu, MAX_MEMORY $memory, MAX_IOPS $iops, MAX_DISK_SIZE $disk, MAX_SESSION_NUM 64, MIN_CPU=1, MIN_MEMORY=$min_memory, MIN_IOPS=128;
ob1.mysql CREATE RESOURCE POOL pool_$case_index UNIT = 'unit_$case_index', UNIT_NUM = $unit_num, ZONE_LIST = ($zone_list);
ob1.mysql CREATE TENANT tenant_$case_index RESOURCE_POOL_LIST = ('pool_$case_index'), locality=$locality;
ob1.mysql alter tenant tenant_$case_index set variables ob_tcp_invited_nodes='%';
ob1.mysql create tablegroup pg binding = true;
create table t1(c1 int primary key, c2 int, c3 int);
create index il on t1(c2);
create index il1 on t1(c3) local;
create tablegroup pg binding = true;
create table t2222(c1 int primary key, c2 int) tablegroup ='pg';
ob1.mysql alter system major freeze;
ob1.check_version 2;
ob1.mysql alter system major freeze;
ob2.reboot;
ob2.check_until_timeout select count(*) from oceanbase.__all_tenant, 2, 100;
ob2.mysql_p select column_value from oceanbase.__all_core_table where table_name like "%global%" and column_name = 'standby_snapshot_frozen_version';
column_value
2
alter system set balancer_idle_time = '10s';
alter system set server_data_copy_out_concurrency = 30;
alter system set server_data_copy_in_concurrency = 30;
alter system set data_copy_concurrency = 60;
ob2.mysql set global ob_query_timeout = 100000000;
ob1.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO STANDBY, 600;
ob1.mysql alter system set resource_hard_limit=900;
ob1.mysql alter system set resource_soft_limit=800;
ob1.mysql CREATE RESOURCE UNIT unit_$case_index MAX_CPU $cpu, MAX_MEMORY $memory, MAX_IOPS $iops, MAX_DISK_SIZE $disk, MAX_SESSION_NUM 64, MIN_CPU=1, MIN_MEMORY=$min_memory, MIN_IOPS=128;
ob1.mysql CREATE RESOURCE POOL pool_$case_index UNIT = 'unit_$case_index', UNIT_NUM = $unit_num, ZONE_LIST = ($zone_list);
ob1.mysql CREATE TENANT tenant_$case_index RESOURCE_POOL_LIST = ('pool_$case_index'), locality=$locality;
ob1.mysql alter tenant tenant_$case_index set variables ob_tcp_invited_nodes='%';
ob1.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO STANDBY, 600;
ob1.check_version 3;
ob1.mysql alter system major freeze;
ob1.check_version 4;
ob1.force_stop;
ob2.mysql set global ob_query_timeout = 300000000;
ob2.mysql alter system set _mini_merge_concurrency = 16;
ob2.mysql alter system set _ob_minor_merge_schedule_interval = '3s';
ob2.mysql alter system ACTIVATE PHYSICAL STANDBY CLUSTER;
ob2.mysql alter system set _mini_merge_concurrency = 3;
ob2.mysql alter system set _ob_minor_merge_schedule_interval = '20s';
ob2.check_until_timeout select count(*) from oceanbase.__all_acquired_snapshot where snapshot_type = 2, 0, 200;
create table t2(c1 int primary key, c2 int, c3 int);
create database msy;
ob3=OBI(cluster=1, proxy_num = 0, leaderob=ob2);
ob3.reboot;
alter system set balancer_idle_time = '10s';
alter system set server_data_copy_out_concurrency = 30;
alter system set server_data_copy_in_concurrency = 30;
alter system set data_copy_concurrency = 60;
ob2.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO STANDBY, 600;
ob2.mysql_p select cluster_status from oceanbase.__all_virtual_cluster;
cluster_status
VALID
ob1.z1.obs0.nstart -m disabled_cluster;
ob1.z2.obs0.nstart -m disabled_cluster;
ob1.z3.obs0.nstart -m disabled_cluster;
ob1.check_until_timeout select count(*) from oceanbase.__all_server where status = 'ACTIVE', 3, 100;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_core_meta_table where role = 1, 1, 100;
ob1.mysql alter system convert to physical standby;
ob2.check_until_timeout select count(*) from oceanbase.__all_acquired_snapshot where snapshot_type = 2, 0, 200;
ob2.check_until_timeout select switchover_status from oceanbase.v\$ob_cluster, TO STANDBY, 60;
ob2.check_until_timeout select count(*) from oceanbase.__all_virtual_cluster where switchover_info like "SYNCED STANDBY CLUSTERS: 3", 1, 600;
create table t100(c1 int primary key);
create table t100(c1 int primary key);
ob2.mysql alter system major freeze;
ob2.check_version 6;
ob3.check_version 6;
ob3.force_stop;
ob1.force_stop;
ob2.mysql alter system ACTIVATE PHYSICAL STANDBY CLUSTER;
drop table t2;
drop database msy;
ob3.z1.obs0.nstart -m disabled_cluster;
ob3.check_until_timeout select count(*) from oceanbase.__all_server where status = 'ACTIVE', 1, 100;
ob3.check_until_timeout select count(*) from oceanbase.__all_virtual_core_meta_table where role = 1, 1, 100;
ob2.check_until_timeout select count(*) from oceanbase.__all_acquired_snapshot where snapshot_type = 2, 0, 200;
