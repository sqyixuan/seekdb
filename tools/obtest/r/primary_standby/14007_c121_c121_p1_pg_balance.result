create table test11(c1 int primary key, c2 int)  tablegroup='tpcc_group' partition by hash(c1) partitions 128;
create table test12(c1 int primary key, c2 int)  tablegroup='tpcc_group' partition by hash(c1) partitions 128;
ob1.check_until_timeout select count(*) from __all_unit where resource_pool_id = 1  and concat(svr_ip,":",svr_port) = '$svr', 0, 300;
ob2.check_until_timeout select count(*) from __all_unit where resource_pool_id = 1 and concat(svr_ip,":",svr_port) = '$svr2', 0, 300;
ob1.check_until_timeout select count(*) from __all_unit where migrate_from_svr_ip != '', 0, 900;
ob2.check_until_timeout select count(*) from __all_unit where migrate_from_svr_ip != '', 0, 900;
ob1.mysql alter system major freeze;
ob1.mysql alter system major freeze;
ob1.check_until_timeout select value from __all_zone where zone = '' and name = 'last_merged_version', 7, 700;
ob2.check_until_timeout select value from __all_zone where zone = '' and name = 'last_merged_version', 7, 700;
