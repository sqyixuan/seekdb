ob1=OBI(cluster=1,proxy_num=0);
ob2=OBI(cluster=1,leaderob=ob1,proxy_num=0);
ob1.reboot;
ob2.reboot;
ob1.mysql CREATE RESOURCE UNIT unit_1 MAX_CPU $cpu, MAX_MEMORY $memory, MAX_IOPS $iops, MAX_DISK_SIZE $disk, MAX_SESSION_NUM $session, MIN_CPU=1, MIN_MEMORY=$min_memory, MIN_IOPS=128;
ob1.mysql CREATE RESOURCE POOL pool_1 UNIT = 'unit_1', UNIT_NUM = 1, ZONE_LIST = ('z1');
ob1.mysql CREATE TENANT tenant_$case_index RESOURCE_POOL_LIST = ('pool_1'), primary_zone='z1' set ob_tcp_invited_nodes='%';
ob1.mysql alter system set debug_sync_timeout = '100000s';
alter system set balancer_idle_time = '10s';
alter system set server_data_copy_out_concurrency = 30;
alter system set server_data_copy_in_concurrency = 30;
alter system set data_copy_concurrency = 60;
ob2.mysql alter system set debug_sync_timeout = '100000s';
ob1.check_until_timeout select count(*) from v\$ob_cluster where switchover_status='TO STANDBY', 1, 360;
ob2.mysql alter system enable_rereplication = false;
create table t(c1 int primary key, c2 int) partition by hash(c1) partitions 10;
ob2.check_until_timeout select max(schema_version) from __all_virtual_ddl_operation where tenant_id = 1001, $schema_version, 30;
ob2.mysql set ob_global_debug_sync = 'END_PROCESS_USER_SCHEMA wait_for continue_signal';
create index t_index on t(c2) local;
ob2.check_until_timeout select count(*) from __all_virtual_clog_stat where table_id = $table_id, 0, 4;
ob2.mysql alter system enable_rereplication = true;
ob2.check_until_timeout select count(*) from __all_virtual_clog_stat where table_id = $table_id and is_in_sync = 1, 10, 60;
ob1.force_stop;
ob2.mysql set ob_global_debug_sync = 'now signal continue_signal';
set ob_query_timeout = 30000000;
alter system ACTIVATE PHYSICAL STANDBY CLUSTER;
ob2.z1.obs0.check_log_until_success -c "need to drop index(index_id=1100611139453778";
