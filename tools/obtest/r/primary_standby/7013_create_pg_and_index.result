ob1=OBI(cluster=1:1:1,proxy_num=0);
ob2=OBI(cluster=1:1:1,leaderob=ob1,proxy_num=0);
ob1.reboot;
ob2.reboot;
alter system set balancer_idle_time = '10s';
alter system set server_data_copy_out_concurrency = 30;
alter system set server_data_copy_in_concurrency = 30;
alter system set data_copy_concurrency = 60;
alter system set debug_sync_timeout = '1000s';
ob1.mysql alter system set resource_hard_limit=900;
ob1.mysql alter system set resource_soft_limit=800;
ob1.mysql CREATE RESOURCE UNIT unit_$case_index MAX_CPU $cpu, MAX_MEMORY $memory, MAX_IOPS $iops, MAX_DISK_SIZE $disk, MAX_SESSION_NUM 64, MIN_CPU=1, MIN_MEMORY=$min_memory, MIN_IOPS=128;
ob1.mysql CREATE RESOURCE POOL pool_$case_index UNIT = 'unit_$case_index', UNIT_NUM = $unit_num, ZONE_LIST = ($zone_list);
ob1.mysql CREATE TENANT tenant_$case_index RESOURCE_POOL_LIST = ('pool_$case_index'), locality=$locality;
ob1.mysql alter tenant tenant_$case_index set variables ob_tcp_invited_nodes='%';
set ob_query_timeout=100000000;
set recyclebin='off';
create table tb_basic(c1 int primary key, c2 int, c3 int);
create index  idx_basic_local on  tb_basic(c2);
create index  idx_basic_global on  tb_basic(c1, c3) partition by hash(c1) partitions 2;
create table tb_range(c1 int primary key, c2 int, c3 int) partition by range(c1) (partition p1 values less than (1000), partition p2 values less than (2000));
create index  idx_range_local on  tb_range(c2) local;
create table tb_range_hash(c1 int, c2 int, c3 int, primary key (c1, c2)) partition by range(c1) subpartition by hash(c2) subpartitions 2 (partition p1 values less than (1000), partition p2 values less than (2000));
create index  idx_range_hash_local on  tb_range_hash(c2) local;
create tablegroup  tg_basic binding = true;
create tablegroup  tg_range binding = true partition by range (partition p1 values less than (1000), partition p2 values less than (2000));
create tablegroup  tg_range_hash binding = true partition by range subpartition by hash subpartitions 2 (partition p1 values less than (1000), partition p2 values less than (2000));
create tablegroup  tg_logical_basic binding=false;
create tablegroup  tg_logical_range binding=false partition by range (partition p1 values less than (1000), partition p2 values less than (2000));
create tablegroup  tg_logical_range_hash binding=false partition by range subpartition by hash subpartitions 2 (partition p1 values less than (1000), partition p2 values less than (2000));
create tablegroup  tg_with_tb_basic binding = true;
create table tb_in_pg_basic(c1 int primary key, c2 int, c3 int) tablegroup 'tg_with_tb_basic';
create index  idx_in_pg_basic_local on  tb_in_pg_basic(c2) local;
create index  idx_in_pg_basic_global on  tb_in_pg_basic(c1, c3) partition by hash(c1) partitions 2;
create tablegroup  tg_with_tb_range binding = true partition by range (partition p1 values less than (1000), partition p2 values less than (2000));
create table tb_in_pg_range(c1 int primary key, c2 int, c3 int) tablegroup 'tg_with_tb_range' partition by range(c1) (partition p1 values less than (1000), partition p2 values less than (2000));
create index  idx_in_pg_range_local on  tb_in_pg_range(c2) local;
create index  idx_in_pg_range_global on  tb_in_pg_range(c1, c3) partition by hash(c1) partitions 2;
create tablegroup  tg_with_tb_range_hash binding = true partition by range subpartition by hash subpartitions 2 (partition p1 values less than (1000), partition p2 values less than (2000));
create table tb_in_pg_range_hash(c1 int, c2 int, c3 int, primary key(c1, c2)) tablegroup 'tg_with_tb_range_hash' partition by range(c1) subpartition by hash(c2) subpartitions 2 (partition p1 values less than (1000), partition p2 values less than (2000));
create index  idx_in_pg_range_hash_local on  tb_in_pg_range_hash(c2) local;
create index  idx_in_pg_range_hash_global on  tb_in_pg_range_hash(c1, c3) partition by hash(c1) partitions 2;
create tablegroup  tg_logical_with_tb_basic binding=false;
create table tb_in_tg_basic(c1 int primary key, c2 int, c3 int) tablegroup 'tg_logical_with_tb_basic';
create index  idx_in_tg_basic_local on  tb_in_tg_basic(c2) local;
create index  idx_in_tg_basic_global on  tb_in_tg_basic(c1, c3) partition by hash(c1) partitions 2;
create tablegroup  tg_logical_with_tb_range binding=false partition by range (partition p1 values less than (1000), partition p2 values less than (2000));
create table tb_in_tg_range(c1 int primary key, c2 int, c3 int) tablegroup 'tg_logical_with_tb_range' partition by range(c1) (partition p1 values less than (1000), partition p2 values less than (2000));
