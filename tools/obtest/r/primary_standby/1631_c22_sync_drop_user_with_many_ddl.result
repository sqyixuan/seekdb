ob1=OBI(cluster=1, proxy_num = 0);
ob2=OBI(cluster=1, proxy_num = 0, leaderob=ob1);
ob1.force_stop;
ob2.force_stop;
ob1.reboot;
ob1.mysql create user msy identified by 'wrewgdg';
ob1.mysql alter system set enable_sys_table_ddl = true;
ob1.mysql drop user msy;
ob2.reboot;
ob2.mysql alter system set enable_sys_table_ddl = false;
ob2.mysql alter system set enable_ddl = false;
ob2.check_until_timeout select count(*) > 0 from oceanbase.__all_virtual_user_history where user_name = 'msy', 1, 10;
ob2.check_until_timeout select count(*) from oceanbase.__all_virtual_ddl_operation where schema_version = $schema_version, 1, 3;
ob2.check_until_timeout select count(*) from oceanbase.__all_virtual_ddl_operation where schema_version > $schema_version, $count, 500;
ob2.check_until_timeout select count(*) from oceanbase.__all_virtual_ddl_operation where schema_version = $schema_version, 1, 3;
ob2.check_until_timeout select count(*) from oceanbase.__all_virtual_ddl_operation where schema_version = $schema_version, 1, 3;
