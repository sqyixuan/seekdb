ob1=OBI(cluster=1,proxy_num=0);
ob2=OBI(cluster=1,leaderob=ob1,proxy_num=0);
ob3=OBI(cluster=1,leaderob=ob1,proxy_num=0);
ob1.reboot;
ob1.mysql CREATE RESOURCE UNIT unit_1 MAX_CPU $cpu, MAX_MEMORY $memory, MAX_IOPS $iops, MAX_DISK_SIZE $disk, MAX_SESSION_NUM $session, MIN_CPU=1, MIN_MEMORY=$min_memory, MIN_IOPS=128;
ob1.mysql CREATE RESOURCE POOL pool_1 UNIT = 'unit_1', UNIT_NUM = 1, ZONE_LIST = ('z1');
ob1.mysql CREATE TENANT tenant_$case_index RESOURCE_POOL_LIST = ('pool_1'), primary_zone='z1' set ob_tcp_invited_nodes='%';
ob1.mysql alter system major freeze;
ob1.check_version 2;
ob1.mysql alter system major freeze;
ob1.check_version 3;
ob1.mysql alter system major freeze;
ob1.check_version 4;
ob2.reboot;
ob2.check_until_timeout select value from __all_zone where zone='' and name='last_merged_version', 4, 600;
ob1.mysql alter system major freeze;
ob1.check_version 5;
ob2.check_until_timeout select value from __all_zone where zone='' and name='last_merged_version', 5, 600;
ob2.check_until_timeout select column_value from __all_core_table where table_name = '__all_global_stat' and column_name = 'standby_snapshot_frozen_version', 4, 3;
ob2.check_until_timeout select count(*) from __all_core_table where table_name = '__all_freeze_info' and column_name = 'frozen_version' and column_value <= 4, 4, 3;
ob2.check_until_timeout select count(*) from __all_freeze_schema_version where frozen_version <= 4, 7, 3;
alter system set enable_sys_table_ddl = true;
alter table __all_tenant_meta_table add column test int id 49;
alter table __all_tenant_meta_table add column test2 int id 50;
alter system set enable_sys_table_ddl = true;
ob1.mysql alter system major freeze;
ob1.check_version 6;
ob2.check_version 6;
ob1.check_until_timeout select count(*) from __all_core_table where table_name like '%glob%' and column_name = 'standby_snapshot_frozen_version' and column_value !="-1", 1, 3;
ob2.check_until_timeout select count(*) from __all_core_table where table_name like '%glob%' and column_name = 'standby_snapshot_frozen_version' and column_value !="-1", 1, 3;
ob3.reboot;
ob3.z1.obs0.check_rs_log_until_success -c "check sys table schema failed";
