ob2.mysql set ob_global_debug_sync = 'BEFORE_PROCESS_USER_SCHEMA wait_for continue_signal';
alter table t2 add column c1 int default 100;
alter table t3 add column c1 int default 100;
insert into t2 values (5,5),(6,6);
insert into t3 values (5,5),(6,6);
insert into t4 values (5),(6);
ob2.check_until_timeout select min_log_service_ts > $t2_new_clog_ts from __all_virtual_partition_info where table_id=$tg1_id, 1, 120;
ob2.check_until_timeout select min_replay_engine_ts = $t2_new_clog_ts from __all_virtual_partition_info where table_id=$tg1_id, 1, 120;
set ob_read_consistency='weak';
