ob1=OBI(cluster=1:1:1,init_unit_cpu=0,proxy_num=0);
ob1.z1.obs0.set extra_config=_recyclebin_object_purge_frequency=2m;
ob1.z2.obs0.set extra_config=_recyclebin_object_purge_frequency=2m;
ob1.z3.obs0.set extra_config=_recyclebin_object_purge_frequency=2m;
ob1.reboot;
ob1.mysql alter system set resource_hard_limit=900;
ob1.mysql alter system set resource_soft_limit=800;
ob1.mysql alter system set debug_sync_timeout = '1000s';
ob1.mysql alter system set enable_auto_leader_switch = 'false';
ob1.mysql alter system set enable_rebalance = 'false';
ob1.mysql alter system set enable_rereplication = 'true';
ob1.mysql alter system set balancer_idle_time = '10s';
ob1.mysql alter system set server_data_copy_out_concurrency = 20;
ob1.mysql alter system set server_data_copy_in_concurrency = 20;
ob1.mysql alter system set _recyclebin_object_purge_frequency = '2m';
CREATE RESOURCE UNIT unit_1 MAX_CPU 1, MAX_MEMORY 1073741824, MAX_IOPS 100000, MAX_DISK_SIZE 536870912, MAX_SESSION_NUM 64, MIN_CPU=1, MIN_MEMORY=1073741824, MIN_IOPS=128;
CREATE RESOURCE POOL pool_1 UNIT = 'unit_1', UNIT_NUM = 1, ZONE_LIST = ('z1','z2','z3');
set @@session.ob_query_timeout = 20000000;
CREATE TENANT t_oracle RESOURCE_POOL_LIST = ('pool_1'), primary_zone = 'z1;z2,z3', locality='F@z1,F@z2,F@z3' set ob_tcp_invited_nodes='%', ob_compatibility_mode='oracle';
create user obtest IDENTIFIED BY "obtest";
grant all on *.* to obtest WITH GRANT OPTION;
grant dba to obtest;
CREATE RESOURCE POOL pool_2 UNIT = 'unit_1', UNIT_NUM = 1, ZONE_LIST = ('z1','z2','z3');
set @@session.ob_query_timeout = 20000000;
CREATE TENANT t_oracle2 RESOURCE_POOL_LIST = ('pool_2'), primary_zone = 'z1;z2,z3', locality='F@z1,F@z2,F@z3' set ob_tcp_invited_nodes='%', ob_compatibility_mode='oracle';
create user obtest IDENTIFIED BY "obtest";
grant all on *.* to obtest WITH GRANT OPTION;
grant dba to obtest;
CREATE RESOURCE POOL pool_3 UNIT = 'unit_1', UNIT_NUM = 1, ZONE_LIST = ('z1','z2','z3');
set @@session.ob_query_timeout = 20000000;
CREATE TENANT t_oracle3 RESOURCE_POOL_LIST = ('pool_3'), primary_zone = 'z1;z2,z3', locality='F@z1,F@z2,F@z3' set ob_tcp_invited_nodes='%', ob_compatibility_mode='oracle';
create user obtest IDENTIFIED BY "obtest";
grant all on *.* to obtest WITH GRANT OPTION;
grant dba to obtest;
