ob1.mysql create tablegroup ym_tg;
ob1.mysql create table ym_db.ym_tb(c1 int primary key, c2 int);
ob1.mysql create database ym_db_2;
ob1.mysql create tablegroup ym_tg_2;
ob1.mysql create table ym_db_2.ym_tb_2(c1 int primary key, c2 int);
