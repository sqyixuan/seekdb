CREATE TABLE IF NOT EXISTS test_vector_table (
id INT PRIMARY KEY COMMENT '主键ID',
vector_data VECTOR(4) COMMENT '4维向量数据'
)
PARTITION BY RANGE (id) (
PARTITION p_0_100 VALUES LESS THAN (100),
PARTITION p_100_200 VALUES LESS THAN (200),
PARTITION p_200_300 VALUES LESS THAN (300),
PARTITION p_max VALUES LESS THAN (MAXVALUE)
);
