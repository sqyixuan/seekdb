ob1=OBI(cluster=1:1:1, proxy_num=0, init_unit_cpu=2);
ob1.reboot;
ob1.mysql alter system set merger_check_interval='10s';
ob1.mysql alter system set enable_rebalance = 'false';
ob1.mysql alter system set resource_hard_limit=500;
ob1.mysql alter system set balancer_idle_time='10s';
ob1.mysql alter system set debug_sync_timeout = '100000s';
ob1.mysql alter system set enable_auto_leader_switch=false;
ob1.mysql alter system set _ob_minor_merge_schedule_interval = '3s';
alter system set _enable_parallel_minor_merge = 'true';
create table t1 (c1 int, c2 int) primary_zone = 'z1';
insert into t1 values (1,1);
insert into t1 values (2,2);
insert into t1 values (3,3);
ob1.mysql alter system minor freeze tenant = sys;
ob1.mysql alter system minor freeze tenant = all_user;
ob1.mysql alter system minor freeze tenant = all_meta;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table_mgr where table_type=0 and is_active=0 and table_id = $table_id, 0, 300;
insert into t1 values (4,4);
ob1.mysql alter system set skip_update_storage_info = true;
ob1.mysql alter system minor freeze tenant = sys;
ob1.mysql alter system minor freeze tenant = all_user;
ob1.mysql alter system minor freeze tenant = all_meta;
ob1.check_until_timeout select count(1) from oceanbase.__all_virtual_table_mgr where table_type=10 and svr_ip='$ip' and svr_port=$port and index_id = $table_id and max_log_id > $minor_log_ts, 1, 300;
ob1.z2.obs0.force_stop;
ob1.check_until_timeout select status from oceanbase.__all_server where zone='z2', inactive, 60;
ob1.z2.obs0.nstart;
ob1.check_until_timeout select status from oceanbase.__all_server where zone='z2', active, 60;
ob1.check_until_timeout select count(1) as c from oceanbase.__all_virtual_partition_store_info where readable_ts > $minor_snapshot and svr_ip = '$follower_ip' and svr_port = $follower_port and table_id = $table_id, 1, 60;
ob1.mysql alter system set skip_update_storage_info = false;
ob1.mysql alter system minor freeze tenant = sys;
ob1.mysql alter system minor freeze tenant = all_user;
ob1.mysql alter system minor freeze tenant = all_meta;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table_mgr where table_type=0 and is_active=0 and table_id = $table_id, 0, 300;
ob1.mysql alter system major freeze;
ob1.check_version 2;
