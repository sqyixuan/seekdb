ob1=OBI(cluster=3,proxy_num=0,init_unit_cpu=1, init_unit_num=1);
ob1.reboot;
ob1.mysql alter resource pool obtestpool unit_num 1;
ob1.mysql alter system set enable_rebalance=false;
ob1.mysql alter system set enable_ilog_recycle = false;
ob1.mysql alter system set ilog_flush_trigger_time='10s';
ob1.mysql alter system set migrate_concurrency = 0;
ob1.mysql alter system set server_permanent_offline_time = 40;
ob1.mysql alter resource pool obtestpool unit_num 2;
ob1.check_until_timeout select count(1) from __all_unit  a inner join __all_resource_pool b where  a.resource_pool_id=b.resource_pool_id and b.tenant_id=$tenant_id, 2, 60;
set ob_trx_timeout=100000000;
set ob_query_timeout=100000000;
drop table if exists tt;
create table tt(a int primary key) partition by hash(a) partitions 10;
count(*)
200
select count(*) from tt;
count(*)
401
$stop_addr.force_stop;
ob1.check_until_timeout select status from oceanbase.__all_server where svr_ip = "$stop_ip" and svr_port = "$stop_port", inactive, 6000;
ob1.check_until_timeout select count(*) from __all_rootservice_event_history where module = 'server_fast_recovery' and value1 like '%$stop_ip:$stop_port%' and value3 = '0', 1, 60000000;
ob1.check_until_timeout select count(*) from __all_rootservice_event_history where module = 'server_fast_recovery' and value1 like '%$stop_ip:$stop_port%' and event = 'finish_recovery', 1, 60000000;
ob1.check_until_timeout select count(*) from __all_virtual_meta_table where zone = "z1", $part_cnt, 60000000;
