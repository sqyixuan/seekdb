ob1=OBI(cluster=2:2:2,proxy_num=0,init_unit_cpu=2);
ob1.reboot;
ob1.mysql alter system set merger_check_interval='10s';
ob1.mysql alter system set enable_rebalance = 'false';
ob1.mysql alter system set resource_hard_limit=500;
ob1.mysql alter resource pool obtestpool unit_num 2;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_table_mgr where tenant_id=$tenant_id and table_type=0, 0, 60;
ob1.mysql alter system set_tp tp_no = 232, error_code = 4009, frequency = 1;
ob1.mysql alter system move replica partition_id = '0%0@$tablegroup_id' source = '$src_ip:$src_port' DESTINATION = '$dst_ip:$dst_port';
ob1.check_until_timeout select result from oceanbase.__all_virtual_partition_migration_status where table_id=$tablegroup_id and partition_idx=0, -4009, 20;
ob1.check_until_timeout select count(*) from oceanbase.__all_virtual_sys_task_status, 0, 30;
