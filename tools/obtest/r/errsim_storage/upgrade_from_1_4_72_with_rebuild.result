ob1=OBI(cluster=1:1:1,init_unit_cpu=5,init_unit_num=1,init_unit_mem=5368709120,version=1_4_72);
ob1.proxy0.set extra_config=syslog_level=debug;
ob1.reboot;
ob1.z1.obs0.sh cd $work_dir/; ls -l {etc,etc2,etc3}/observer.conf*.bin;
ob1.z2.obs0.sh cd $work_dir/; ls -l {etc,etc2,etc3}/observer.conf*.bin;
ob1.z3.obs0.sh cd $work_dir/; ls -l {etc,etc2,etc3}/observer.conf*.bin;
ob1.mysql alter system set balancer_idle_time='10s';
ob1.mysql alter system set merger_check_interval='10s';
ob1.mysql alter system set resource_soft_limit=200;
ob1.mysql alter system set resource_hard_limit=200;
alter proxyconfig set server_state_refresh_interval='1s';
ob1.mysql alter tenant sys set primary_zone='z1';
ob1.mysql alter tenant obtest set primary_zone='z1';
ob1.check_until_timeout select count(1) from __all_virtual_core_meta_table where role=1 and zone='z1',1,120;
ob1.check_until_timeout select count(1) from __all_virtual_server_stat,3,120;
create table table_for_rebuild(c1 int, c2 int) primary_zone='z1';
ob1.mysql alter system major freeze;
ob1.check_version 2;
ob1.check_until_timeout select info from __all_zone where zone='' and name='merge_status',IDLE,30;
ob1.upgrade_check_before;
ob1.mysql alter system begin upgrade;
ob1.upgrade_commond_for_server pre;
ob1.check_until_timeout select count(1) from __all_virtual_core_meta_table where role=1 and zone='z1',1,120;
ob1.check_until_timeout SELECT CAST(COUNT(*) AS SIGNED) as cnt FROM __all_virtual_clog_stat WHERE is_in_sync = 0 and is_offline=0,0,600;
set @saved_ob_query_timeout = @@session.ob_query_timeout;
set @@session.ob_query_timeout = 60000000;
alter system stop zone 'z3';
set @@session.ob_query_timeout = @saved_ob_query_timeout;
ob1.check_until_timeout select info from __all_zone where zone='z3' and name='status',INACTIVE,20;
ob1.check_until_timeout select leader_count from __all_virtual_server_stat where zone = 'z3',0,20;
ob1.z3.check_state_in_congest upgrade;
ob1.z3.stop;
ob1.z3.upgrade;
ob1.z3.nstart;
ob1.check_until_timeout select count(*) from oceanbase.__all_server where zone = 'z3' and (start_service_time<=0 or status='INACTIVE'),0,1000;
ob1.check_until_timeout SELECT CAST(COUNT(*) AS SIGNED) as cnt FROM __all_virtual_clog_stat WHERE is_in_sync = 0 and is_offline=0,0,600;
ob1.mysql alter system start zone 'z3';
ob1.check_until_timeout select count(1) from __all_virtual_server_stat,3,120;
ob1.z3.check_state_in_congest active;
alter system set trigger_rebuild_on_purpose=true;
$leader.block_net $follower_2;
insert into table_for_rebuild values(0,0);
insert into table_for_rebuild values(1,1);
insert into table_for_rebuild values(2,2);
insert into table_for_rebuild values(3,3);
insert into table_for_rebuild values(4,4);
insert into table_for_rebuild values(5,5);
insert into table_for_rebuild values(6,6);
insert into table_for_rebuild values(7,7);
insert into table_for_rebuild values(8,8);
insert into table_for_rebuild values(9,9);
insert into table_for_rebuild values(10,10);
insert into table_for_rebuild values(11,11);
insert into table_for_rebuild values(12,12);
insert into table_for_rebuild values(13,13);
insert into table_for_rebuild values(14,14);
insert into table_for_rebuild values(15,15);
insert into table_for_rebuild values(16,16);
insert into table_for_rebuild values(17,17);
insert into table_for_rebuild values(18,18);
insert into table_for_rebuild values(19,19);
ob1.mysql alter system minor freeze zone = 'z1';
ob1.mysql alter system minor freeze zone = 'z2';
leader.clean_net $follower_2;
select count(*) from __all_rootservice_event_history where module like 'balancer' and value1 like '%1099511677777%' and event like '%finish_rebuild_replica%';
count(*)
0
