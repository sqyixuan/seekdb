ob1=OBI(cluster=1,proxy_num=0,init_unit_cpu=2, init_unit_num=1);
ob1.z1.obs0.set extra_config=mark_and_sweep_interval='2s';
ob1.reboot;
ob1.mysql alter system set resource_hard_limit = 800;
ob1.mysql alter system set merger_switch_leader_duration_time=0;
ob1.mysql alter system set enable_auto_leader_switch = false;
ob1.mysql alter system set enable_rereplication = false;
ob1.mysql alter system set enable_rebalance = false;
ob1.mysql alter system set merge_thread_count=64;
ob1.mysql alter system set debug_sync_timeout = '100000s';
ob1.create_client tenant=obtest,user=root,passwd=,database=test;
ob1.mysql set ob_global_debug_sync = 'BEFORE_MAIN_SSTBALE_FINISH_TASK wait_for signal1';
ob1.mysql alter system major freeze;
ob1.mysql alter system set macro_block_builder_errsim_flag=4;
ob1.mysql set ob_global_debug_sync = 'now signal signal1';
ob1.z1.obs0.check_log_until_success -c "macro_block_builder_errsim_flag=4";
ob1.mysql alter system set macro_block_builder_errsim_flag=0;
ob1.check_version 2;
ob1.mysql_p select hold_count from oceanbase.__all_virtual_macro_block_marker_status;
hold_count
0
