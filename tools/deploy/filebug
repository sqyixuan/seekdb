def checkUserValidity(user_name):
  base_url="http://k.alibaba-inc.com/api/admin/users/search?auth=6edfcfe6f99d1f8016fbfe03ceae6207&user=";
  url=base_url+user_name
  res = urllib2.urlopen(url).read()
  result = json.loads(res)
  if len(result['users']) == 0:
    print 'Invalid user:%s' % user_name
    return False
  for value in result['users']:
    if value['nickname'].encode("utf-8") != user_name:
      print 'Invalid user:%s' % user_name
      return False
  return True

def checkUserListValidity(user_list):
  for user_name in user_list:
    if not checkUserValidity(user_name):
      return False
  print 'all users are valid!!!'
  return True

def saveTempfile(test_name, tempfile):
  save_file=test_name + '.filebug'
  shutil.copy(tempfile,save_file)

def getUsername():
  try:
    base_url="http://k.alibaba-inc.com/api/admin/users/search?auth=6edfcfe6f99d1f8016fbfe03ceae6207&user=";
    url=base_url+getpass.getuser()
    res = urllib2.urlopen(url).read()
    result = json.loads(res)
    user_name=''
    if len(result['users']) == 0:
      print 'Invalid user:%s' % user_name
      return '' 
    user_name = result['users'][0]['nickname'].encode("utf-8")
    return user_name
  except:
    print 'getUsername failed, Error:%s' % traceback.format_exc()
    return ''
    
