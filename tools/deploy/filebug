def get_mysqltest_log(case):
  try:
    case_log = ''
    log_dir = basedir + '/mysql_test/log/'
    file_list = os.listdir(log_dir)
    file_list.sort()
    file_name = file_list[-1]
    fp = file(log_dir+file_name, 'r')
    lines = fp.readlines()
    i = 0
    line_num = len(lines)
    case_format = "[ " + case + " ]"   
    while i < line_num and case_format not in lines[i]:
      i += 1
    if i == line_num:
      print 'get_mysqltest_log, case:%s not exist in log' % case
      return case_log
    i += 2
    line = lines[i]
    if 'mysqltest' in line and 'query' in line and 'failed' in line:
      case_log = line
    else:
      while '========================' not in line and \
        '<<<<<<<<<<<<<<<<<<<' not in line and line:
        case_log += line
        i += 1
        line = lines[i]
    fp.close()
    return case_log
  except:
    print 'get_mysqltest_log, Error:%s' % traceback.format_exc()
    return ''
  finally:
    fp.close()

def create_bug_content(case):
  cmd = "./deploy.py ob1.mysqltest testset=" + case
  (fd, path) = tempfile.mkstemp(suffix='.filebug',prefix=case,dir=basedir)
  fp = os.fdopen(fd, 'w')
  fp.write('[bug_title]:\n' )
  fp.write('[bug_author]:' + user_name + '\n')
  fp.write('[bug_owner]:\n')
  fp.write('[bug_type(1-功能测试、2-接口测试、7-性能测试、16-压力测试)]:2\n')
  fp.write('[bug_level(1-Blocker、2-Major、3-Normal、4-Trivial)]:3\n')
  fp.write('[bug_priority(1-Urgent、2-High、3-Medium、4-Low]:3\n')
  fp.write('[bug_version(1-oceanbase0.4、2-oceanbase0.5、3-obdatasource、4-filebug_test)]:2\n')
  content="==回归环境==\n接口测试\n==日志==\n" + get_mysqltest_log(case) + "\n==问题描述==\n" + cmd + "\n==自动化CASE==\n"+case+'.test\n'
  fp.write('[bug_description]:\n'+content)
  fp.close()
  return path


def filebug(case,create_type=1):
  level_dict = {"1":(87,'1-Blocker'),
                "2":(88,'2-Major'),
                "3":(89,'3-Normal'),
                "4":(90,'4-Trivial')
                }
  priority_dict = {"1":(94,'1-Urgent'),
                   "2":(95,'2-High'),
                   "3":(96,'3-Medium'),
                   "4":(97,'4-Low')
                  }
  type_dict = {"1":"1-功能测试","2":"2-接口测试","7":"7-性能测试","16":"16-压力测试"}
  
  version_dict = {"1":("65558","oceanbase0.4"),
                  "2":("65559","oceanbase0.5"),
                  "3":("68722","obdatasource"),
                  "4":("74414","filebug_test")
                  }
  
  if create_type == 1:
    path = create_bug_content(case)
  else:
    path = os.getcwd() +'/'+case

  editor = os.getenv('EDITOR', 'vim')
  print(editor, path)
  subprocess.call('%s %s' % (editor, path), shell=True)

  title,author,owner,type,levelId,priorityId,versionId,desc = '','','','','','','',''
  f=open(path, 'r')
  try:
    while 1:
      line = f.readline()
      if not line:
        break
      if(line.startswith('[bug_title]:') == True):
          title = line.partition(':')[-1].strip('\n')
      elif(line.startswith('[bug_author]:') == True):
          author = line.partition(':')[-1].strip()
          user_list.append(author)
      elif(line.startswith('[bug_owner]:') == True):
          owner = line.partition(':')[-1].strip()
          user_list.append(owner)
      elif(line.startswith('[bug_type') == True):
          value = line.partition(':')[-1].strip()
          if len(value) == 0:
            break
          type = type_dict[value]
      elif(line.startswith('[bug_level') == True):
          value = line.partition(':')[-1].strip()
          if len(value) == 0:
            break
          levelId = level_dict[value]
      elif(line.startswith('[bug_priority') == True):
          value = line.partition(':')[-1].strip()
          if len(value) == 0:
            break
          priorityId = priority_dict[value]
      elif(line.startswith('[bug_version') == True):
          value = line.partition(':')[-1].strip() 
          if len(value) == 0:
            break
          versionId = version_dict[value]
      elif(line.startswith('[bug_description]:') == True):
          desc = ''
      else:
          desc = desc + '\n' +line
    content_dict={'title':title,
          'author':author,
          'owner':owner,
          'type':type,
          'levelId':levelId,
          'priorityId':priorityId,
          'versionId':versionId,
          'desc':desc,
          'testname':case,
          'tempfile':path}
    submit(content_dict)
  except:
    print traceback.format_exc()
  finally:
    f.close()
    os.unlink(path)
    return


