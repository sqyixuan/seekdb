SET GLOBAL ob_query_timeout=10000000;
SET GLOBAL ob_trx_timeout=86400000000;
SET GLOBAL parallel_min_scan_time_threshold=1000;
SET GLOBAL ob_sql_work_area_percentage=5;
SET GLOBAL parallel_degree_policy='MANUAL';
SET GLOBAL collation_server='utf8mb4_general_ci';
SET GLOBAL collation_connection='utf8mb4_general_ci';
alter system set enable_record_trace_log=True;
alter system set max_syslog_file_count=0;
alter system set log_transport_compress_all=False;
alter system set direct_load_allow_fallback=True;
