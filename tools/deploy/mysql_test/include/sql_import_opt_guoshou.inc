CREATE OR REPLACE FUNCTION f_username (
    user_branch_no IN VARCHAR2
    ,user_userno IN VARCHAR2 ) RETURN VARCHAR2 AS retval VARCHAR2(64) ;
BEGIN
    SELECT  MAX(E.person_name) INTO retval
    FROM    au_company c , au_employee E LEFT
    JOIN    au_partyrelation p2
    ON      p2.partyid = E.ID LEFT
    JOIN    au_partyrelation p3
    ON      p3.partyid = p2.parent_partyid LEFT
    JOIN    au_partyrelation p4
    ON      p4.partyid = p3.parent_partyid
    WHERE   p4.partyid = c.ID
    AND     E.enable_status = '1'
    AND     c.company_no = CAST(user_branch_no AS VARCHAR2(10 CHAR))
    AND     E.person_no = CAST(user_userno AS VARCHAR2(10 CHAR))  ;
    RETURN retval  ;
END ;
//

CREATE OR REPLACE FUNCTION f_branch (
    abranch_no IN VARCHAR2 ) RETURN VARCHAR2 AS retval VARCHAR2(64) ;
BEGIN
    SELECT  MAX(company_name) INTO retval
    FROM    au_company
    WHERE   company_no = CAST(abranch_no AS VARCHAR2(10 CHAR))  ;
    RETURN retval  ;
END ;
//

