#########################################################################
############### SQL新增功能在SELECT语句中的测试模板 #####################
#########################################################################

####################### PREPATE TEST RESOURCE ###########################
--disable_warnings
drop database if exists select_db;
--enable_warnings
create database select_db;
use select_db;


########################################################################
#######################  TEST FOR PLAIN SELECT #########################
########################################################################

####################### TEST FOR scan ###########################
########   测试新添加功能使用不同scan方式时的正确性   ###########
### full scan -- get ###
## e.g. , select c1, c2, c3, level, connect_by_iscycle, connect_by_isleaf from troot start with c1 = 0 connect by nocycle prior c1 = c2 order siblings by c1;

### full scan -- range ###
## e.g. , select c1, c2, c3, level, connect_by_iscycle, connect_by_isleaf from troot start with c1 > 1 and c1 < 5 connect by nocycle prior c1 = c2 order siblings by c1;

### index scan -- get ###
## e.g. , select c1, c2, c3, level, connect_by_iscycle, connect_by_isleaf from troot start with c3 in (1,2,3,4) connect by nocycle prior c1 = c2 order siblings by c1;
### index scan -- range  ###
## e.g. , select c1, c2, c3, level, connect_by_iscycle, connect_by_isleaf from troot start with c3 > 0 connect by nocycle prior c1 = c2 order siblings by c1;


######################## TEST FOR view ###########################

### 测试新添加功能具有normal view时的正确性 ###
## e.g.,select c1, c2, c3, level, connect_by_iscycle, connect_by_isleaf from (select * from troot) tt start with c1 = 1 connect by nocycle prior c1 = c2 order siblings by c1 desc;

### 测试normal view中含有新添加功能的正确性 ###
## e.g.,select * from (select c1, c2, c3, level, connect_by_iscycle, connect_by_isleaf from troot start with c1 > 0 connect by nocycle prior c1 = c2 order siblings by c1 desc) tt where c1 < 10;

### 测试新添加功能具有materialed view时的正确性 ###

### 测试materialed view中含有新添加功能的正确性 ###


######################## TEST FOR join ###########################
########    测试新添加功能中含有Join时的正确性            ########
### join self ###
## e.g.,select a.id, a.p_id, level from t3 a join t3 b on a.id = b.id start with a.id = 1 connect by prior a.id = b.p_id order siblings by a.id;

### inner join ###
## e.g.,select t2.id, t3.id, t3.p_id, level from t2 join t3 on t2.f_id = t3.id start with t2.id = 1 connect by prior t2.id = t3.p_id order siblings by t2.id;

### outer join ###
## e.g.,select t2.id, t3.id, t3.p_id, level from t2 left join t3 on t2.f_id = t3.id start with t2.id = 1 connect by prior t2.id = t3.p_id order siblings by t2.id;

### nest loop join ###

### hash join ###

### merge join ###


######################## TEST FOR subplan ###########################
########    测试新添加功能中含有Subquery时的正确性           ########

### correlated subquery ###
## e.g,select * from t2 where f_id in (select 100 from troot start with c1 = 1 and id > 0 connect by nocycle prior c1 = c2);

### non-correlated subquery ###
## e.g,select * from t2 where id in (select c1 from troot start with c1 = 1 connect by nocycle prior c1 = c2) order by id;

########      测试subquery中含有添加功能的正确性             ########
### correlated subquery ###
##e.g,select c1, c2, level from troot where c1 > any(select id from t3 where troot.c1 > 1 ) start with c1 = 1 connect by nocycle prior c1 = c2;

### non-correlated subquery ###
##e.g,select c1, c2, level from troot where c1 > any(select id from t3 ) start with c1 = 1 connect by nocycle prior c1 = c2;


