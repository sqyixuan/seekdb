#########################################################################
############### SQL新增功能在DML语句中的测试模板 ########################
#########################################################################

####################### PREPATE TEST RESOURCE ###########################
--disable_warnings
drop database if exists dml_db;
--enable_warnings
create database dml_db;
use dml_db;



##########################################################################
#######################  TEST FOR DML STMT     ###########################
##########################################################################

