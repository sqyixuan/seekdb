####################### TEST FOR PLAN CHACHE  ###########################
########   测试新添加功能分别在plan cache开启和关闭时的正确性 ###########

######### test plan cache on #########
set @@ob_enable_plan_cache=on;

######### test plan cache off #########
alter system flush plan cache;
sleep 2;
set @@ob_enable_plan_cache=off;



#######################  TEST FOR REWRITE   ############################
########   测试新添加功能分别在rewrite开启和关闭时的正确性 ###########

################### test for transformer off #########################
set @@ob_enable_transformation=on;

######### test for view merge #########
#### in view ####
##e.g.,select * from (select c1, c2, c3, level, connect_by_iscycle, connect_by_isleaf from troot tt start with c1 = 1 connect by nocycle prior c1 = c2 order siblings by c1 desc) tt;

#### contain view ####
##e.g.select c1, c2, c3, level, connect_by_iscycle, connect_by_isleaf from (select * from troot) tt start with c1 = 1 connect by nocycle prior c1 = c2 order siblings by c1 desc;

######### test for where pullup #########
#### in where subquery ####
##e.g.select * from t2 where id in (select c1 from troot start with c1 = 1 connect by prior c1 = c2) order by id;

#### contain where subquery ####
##e.g.select c1, c2, level from troot where c1 in (select max(id) from t2) start with c1 = 1 connect by prior c1 = c2;

######### test for eliminate outer join #########
##e.g.select a.id, a.p_id, level from t3 a left join t3 b on a.id = b.id where b.id > 1 start with a.id = 1 connect by prior a.id = b.p_id order siblings by a.id;

######### test for any/all #########
#### in subquery ####
##e.g.select * from t2 where id > any(select c1 from troot start with c1 = 1 connect by prior c1 = c2) order by id;

#### in contain ####
##e.g.select c1, c2, level from troot where c1 > any(select id from t3) start with c1 = 1 connect by nocycle prior c1 = c2;

######### test for min/max #########
##e.g.select c1, c2, level from troot start with c1 = (select max(id) from t2) connect by prior c1 = c2;

######### test for limit push down #########
##e.g.select c1, c2, c3, level, connect_by_iscycle, connect_by_isleaf from (select * from troot) tt start with c1 = 1 connect by nocycle prior c1 = c2 limit 10;

