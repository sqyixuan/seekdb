#验证primary key comment
#无comment
create table jx_t1(c1 int primary key, c2 int);
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table jx_t1;

###comment在主键列上
create table jx_t2(c1 int primary key comment 'primary_key', c2 int);
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table jx_t2;
create table jx_t3(c1 int comment 'primary_key' primary key, c2 int);
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table jx_t3;


###comment在主键上
#单列主键
create table jx_t4(c1 int, primary key (c1) comment 'primary_key', c2 int);
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table jx_t4;
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
select pk_comment from oceanbase.__all_virtual_table where table_id=(select max(table_id) from oceanbase.__all_virtual_table where table_name = 'jx_t4');
connection default;
#多列主键
create table jx_t5(c1 int, c2 varchar(50), primary key (c1, c2) comment 'primary_key', c3 int);
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table jx_t5;
connection obsys;
select pk_comment from oceanbase.__all_virtual_table where table_id=(select max(table_id) from oceanbase.__all_virtual_table where table_name = 'jx_t5');
connection default;

#建view
create view v_jx_t5 as select * from jx_t5;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table v_jx_t5;
connection obsys;
select view_definition, pk_comment from oceanbase.__all_virtual_table where table_id=(select max(table_id) from oceanbase.__all_virtual_table where table_name = 'v_jx_t5');
connection default;

create table test1
(
field_name varchar(1) character set utf8 comment '字段的注释'
)DEFAULT CHARACTER SET = utf8 comment='表的注释';

drop table test1;

--disable_warnings
drop database jx_db;
--enable_warnings

