--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: zhenjiang.xzj
# owner group: STORAGE
# description: fix bug of rescan where query flag does not reset
--disable_abort_on_error
--disable_warnings
drop table if exists table2_bigint;
--enable_warnings
CREATE TABLE `table2_bigint` (
  `col_bigint_key` bigint(20) DEFAULT NULL,
  `col_bigint` bigint(20) DEFAULT NULL,
  `col_char_12` char(12) DEFAULT NULL,
  `pk` bigint(20) NOT NULL,
  `col_char_12_key` char(12) DEFAULT NULL,
  PRIMARY KEY (`pk`),
  KEY `idx1` (`col_bigint_key`) BLOCK_SIZE 16384,
  KEY `idx3` (`col_char_12_key`) BLOCK_SIZE 16384
) DEFAULT CHARSET = utf8mb4 COMPRESSION = 'lz4_1.0' REPLICA_NUM = 3 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 10;

insert into table2_bigint(col_bigint_key , col_bigint , col_char_12 , pk ,col_char_12_key ) values ( 108 ,       NULL ,NULL        ,  108 , 2),(1 ,       NULL , NULL        ,  -10 , 39),(122 ,       NULL , NULL        ,  122 , 4),(1 ,        -10 , NULL        , -100 , 5),(1 ,         -1 , NULL        ,   25 , 5 ),(1 ,       NULL , NULL        ,   99 , 50);

SELECT pk , col_bigint , col_char_12 ,col_char_12_key  FROM table2_bigint WHERE col_char_12_key BETWEEN CAST( 2 AS CHAR(100) ) AND CAST( 7 AS CHAR(100) ) ORDER BY col_char_12_key DESC, pk asc limit 2, 4;

drop table table2_bigint;
