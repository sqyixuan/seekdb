let $sql = create table t_u1(c1 varchar(1);
let $count = 509;
while($count >1)
{
 let $sql=$sql ,;
    let $sql=$sql  c$count varchar(1);
    dec $count;
}
let $sql=$sql, unique (c1;
let $co = 127;
while($co !=1)
{
    let $sql=$sql,c$co;
    dec $co;
}
let $sql =$sql ));
