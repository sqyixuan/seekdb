--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: jim.wjh
#owner group: sql2
#description: todo

#
#  分为创建表varchar  不是键值，是主键，是索引
#
#  每个又分为：超过单个varchar最大值（65536和4096两种），超过总行size最大值，超过最多列，键值超过键值列最大值，键值超过所有键值之和长度最大值
#
--disable_warnings
drop database if exists create_border;
--enable_warnings
create database create_border;
use create_border;

--disable_warnings
drop table if exists t4_;
--enable_warnings
#超过所有列的最大长度
#varchar 不是键值
--disable_warnings
drop table if exists t_0;
--enable_warnings
create table t_0(c1 varchar(65537));
create table t_01(c1 varchar(65536));
--error 1118
create table t4_(pk int primary key,c1 varchar(16384),c2 varchar(16384),c3 varchar(16384),c4 varchar(16384),c5 varchar(16384),c6 varchar(16384),c7 varchar(16384),c8 varchar(16384),c9 varchar(16384),c10 varchar(16384),c11 varchar(16384),c12 varchar(16384),c13 varchar(16384),c14 varchar(16384),c15 varchar(16384),c16 varchar(16384),c17 varchar(16384),c18 varchar(16384),c19 varchar(16384),c20 varchar(16384),c21 varchar(16384),c22 varchar(16384),c23 varchar(16384),c24 varchar(16384),c25 char);

let $sql = create table t_1(c1 varchar(4096);
let $count = 96;
while($count >1)
{
    let $sql=$sql ,;
    let $sql=$sql  c$count varchar(4096);
    dec $count;
}
let $sql=$sql );
--disable_warnings
drop table if exists t_1;
--enable_warnings
eval $sql;

let $sql_k = create table t_2(c1 varchar(4096);
let $count = 96;
while($count >1)
{
    let $sql_k=$sql_k ,;
    let $sql_k=$sql_k  c$count varchar(4096);
    dec $count;
}
let $sql_k=$sql_k, c100 varchar(1));
--disable_warnings
drop table if exists t_2;
--enable_warnings
--error 1118
eval $sql_k;

# 无主键表，创建表，除去3个隐藏列，最多有509列
let $sql_3 = create table t_3(c1 varchar(1);
let $count = 509;
while($count > 1)
{
    let $sql_3=$sql_3 ,;
    let $sql_3=$sql_3  c$count varchar(1);
    dec $count;
}
let $sql_3=$sql_3);
--disable_warnings
drop table if exists t_3;
--enable_warnings
eval $sql_3;

--echo // pk_inc + user_col(max count is 511) = 512
let $sql_4 = create table t_4(c1 varchar(1);
let $count = 512;
while($count > 1)
{
    let $sql_4=$sql_4 ,;
    let $sql_4=$sql_4  c$count varchar(1);
    dec $count;
}
let $sql_4=$sql_4);
--disable_warnings
drop table if exists t_p4;
--enable_warnings
eval $sql_4;

#创建重复的主键
--disable_warnings
drop table if exists t_5;
--enable_warnings
--error 1068
create table t_5(a varchar(10) primary key,b varchar(10) primary key);

#创建表，带有主键，最大边界
--disable_warnings
drop table if exists t_pk;
--enable_warnings
create table t_pk(c1 varchar(4096) primary key);
--disable_warnings
drop table if exists t_pk1;
--enable_warnings
--error 1071
create table t_pk1(c1 varchar(4097) primary key);
--error 1071
create table t_pk1(c1 varchar(65537) primary key);
let $sql = create table t_7(c1 varchar(4096) primary key;
let $count = 96;
while($count >1)
{
    let $sql=$sql ,;
    let $sql=$sql  c$count varchar(4096);
    dec $count;
}
let $sql=$sql );

--disable_warnings
drop table if exists t_7;
--enable_warnings
eval $sql;

let $sql_k = create table t_8(c1 varchar(4096) primary key;
let $count = 96;
while($count >1)
{
    let $sql_k=$sql_k ,;
    let $sql_k=$sql_k  c$count varchar(4096);
    dec $count;
}
let $sql_k=$sql_k, c100 varchar(1));
--disable_warnings
drop table if exists t_8;
--enable_warnings
--error 1118
eval $sql_k;


