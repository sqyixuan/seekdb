--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: bin.lb
# owner group: SQL2
# tags: index
# description:
#
#

--disable_query_log
--disable_warnings
drop table if exists t1;
--enable_warnings

--let $loop=100
while ($loop)
{
  create table t1(a bigint primary key);
  drop table if exists t1;
  --error 1146
  create index i1 on t1(a);
  dec $loop;
}

