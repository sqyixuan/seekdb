--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner : dachuan.sdc
# owner group : sql2
# description:
--disable_warnings
DROP DATABASE IF EXISTS hualong;
--enable_warnings
CREATE DATABASE hualong;
USE hualong;
--disable_warnings
DROP TABLE IF EXISTS src,dst;
--enable_warnings
CREATE TABLE src (c1 INT NOT NULL AUTO_INCREMENT, c2 CHAR(10) NULL, PRIMARY KEY(c1));
CREATE TABLE dst LIKE src;
SHOW TABLES;
let $ENGINE=`select variable_value from information_schema.global_variables where variable_name='STORAGE_ENGINE'`;
#--replace_result $ENGINE ENGINE " PAGE_CHECKSUM=0" ""
--source mysql_test/include/show_create_table_old_version.inc
SHOW CREATE TABLE dst;
DROP TABLE dst;
SHOW TABLES;
DROP TABLE src;
CREATE TABLE src (c1 INT NOT NULL AUTO_INCREMENT, c2 VARCHAR(10) NULL, PRIMARY KEY(c1));
CREATE TABLE dst LIKE src;
SHOW TABLES;
let $ENGINE=`select variable_value from information_schema.global_variables where variable_name='STORAGE_ENGINE'`;
#--replace_result $ENGINE ENGINE " PAGE_CHECKSUM=0" ""
--source mysql_test/include/show_create_table_old_version.inc
