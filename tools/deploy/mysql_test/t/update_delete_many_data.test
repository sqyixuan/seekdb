--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: yuchen.wyc
#owner group: SQL1
#description:本case是为了测试多数据的更新和删除能否正常执行
#--disable_parsing

--disable_query_log
--disable_result_log
--source mysql_test/include/index_quick_major.inc
--enable_query_log
--enable_result_log

--disable_warnings
drop table if exists sbtest;
--enable_warnings

--disable_query_log

CREATE TABLE sbtest (id INTEGER  NOT NULL , k integer  DEFAULT '0' NOT NULL, c char(120) DEFAULT '' NOT NULL, pad char(60) DEFAULT '' NOT NULL, PRIMARY KEY  (id) ) ;
--disable_query_log

--let $count=1
--let $prefix=0001
while($count < 21)
{ 
    --let $batch=10000
    --let $id=$count$prefix
    --let $stmt=replace INTO sbtest(id, k, c, pad) VALUES(1,0,' ','qqqqqqqqqqwwwwwwwwwweeeeeeeeeerrrrrrrrrrtttttttttt')
    while($batch)
    {
        --let $value=,($id,0,' ','qqqqqqqqqqwwwwwwwwwweeeeeeeeeerrrrrrrrrrtttttttttt')
        --let $stmt=$stmt$value
        dec $batch;
        inc $id;
        
    }
    eval $stmt;
    inc $count; 
}
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
--let $count=21
--let $prefix=0001
while($count < 41)
{ 
    --let $batch=10000
    --let $id=$count$prefix
    --let $stmt=replace INTO sbtest(id, k, c, pad) VALUES(1,0,' ','qqqqqqqqqqwwwwwwwwwweeeeeeeeeerrrrrrrrrrtttttttttt')
    while($batch)
    {
        --let $value=,($id,0,' ','qqqqqqqqqqwwwwwwwwwweeeeeeeeeerrrrrrrrrrtttttttttt')
        --let $stmt=$stmt$value
        dec $batch;
        inc $id;
        
    }
    eval $stmt;
    inc $count; 
}
#--enable_parsing
select count(*) from sbtest;
DELETE from sbtest where id <=41001 order by k  limit 41001;
DELETE from sbtest where id <=41001 order by k  limit 10;
select count(*) from sbtest;
--let $id=410001
while($id > 0)
{
    eval DELETE from sbtest where id in ($id,$id-1,$id-2,$id-3,$id-4,$id-5,$id+6,$id+7,$id+8) order by k  limit 10;
    dec $id;
    dec $id;
    dec $id;
    dec $id;
    dec $id;
    dec $id;
}
select count(*) from sbtest;
#drop table sbtest;
