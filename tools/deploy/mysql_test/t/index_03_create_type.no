####
--disable_query_log
--source mysql_test/include/index_quick_major.inc
--real_sleep 1
--disable_warnings
drop table if exists t1;
--enable_warnings
--enable_query_log

create table t1(c1 int primary key, c2 varchar(1024), c3 int);
create index i1 on t1(c2) storing(c3);

--error 1146
create index i1 on __all_server(cluster_id);
--error 1146
create index i2 on __all_table(table_id);

let $table_id = query_get_value(select table_id from oceanbase.__all_virtual_table  where table_name='t1', table_id, 1);
--disable_query_log
--error 1146
create index i4 on __3003__root__(table_id); 
--error 1146
create index i5 on __3003__meta__(table_id);
--enable_query_log

let $idx = query_get_value(select a.table_name from oceanbase.__all_virtual_table as a inner join (select * from oceanbase.__all_virtual_table where table_name='t1') b on a.data_table_id=b.table_id, table_name, 1);
--error 1146
eval create index i3 on $idx(c3);

drop table t1;
