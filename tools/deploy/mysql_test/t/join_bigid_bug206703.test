--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: bin.lb
# owner group: SQL1
# tags: join
# description:
#
--disable_query_log
--source mysql_test/include/index_quick_major.inc
sleep 2;
--enable_query_log

--disable_warnings
drop table if exists sbtest;
--enable_warnings

CREATE TABLE sbtest (id INTEGER  NOT NULL , k integer  DEFAULT '0' NOT NULL, c char(120) DEFAULT '' NOT NULL, pad char(60) DEFAULT '' NOT NULL, PRIMARY KEY  (id) ) ;

--let $count=1
--let $prefix=0001
while($count < 21)
{ 
    --let $batch=10000
    --let $id=$count$prefix
    --let $stmt=replace INTO sbtest(id, k, c, pad) VALUES($count,0,' ','qqqqqqqqqqwwwwwwwwwweeeeeeeeeerrrrrrrrrrtttttttttt')
    --disable_query_log
    --disable_result_log
    while($batch)
    {
        --let $value=,($id,0,' ','qqqqqqqqqqwwwwwwwwwweeeeeeeeeerrrrrrrrrrtttttttttt')
        --let $stmt=$stmt$value
        dec $batch;
        inc $id;
        
    }
    eval $stmt;
    inc $count; 
    --enable_result_log
    --enable_query_log
}
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
--let $count=21
--let $prefix=0001
while($count < 41)
{ 
    --let $batch=10000
    --let $id=$count$prefix
    --disable_result_log
    --disable_query_log
    --let $stmt=replace INTO sbtest(id, k, c, pad) VALUES($count,0,' ','qqqqqqqqqqwwwwwwwwwweeeeeeeeeerrrrrrrrrrtttttttttt')
    while($batch)
    {
        --let $value=,($id,0,' ','qqqqqqqqqqwwwwwwwwwweeeeeeeeeerrrrrrrrrrtttttttttt')
        --let $stmt=$stmt$value
        dec $batch;
        inc $id;
        
    }
    eval $stmt;
    inc $count; 
    --enable_result_log
}
--let $id=2500

#--disable_parsing
--disable_result_log
--disable_query_log
while($id )
{
    eval SELECT j1.* from sbtest as j1,sbtest as j2 where j1.id=j2.id and j1.id=$id and j2.id=$id;
    dec $id;
}
--enable_query_log
--enable_result_log
eval SELECT j1.* from sbtest as j1,sbtest as j2 where j1.id=j2.id and j1.id=$id and j2.id=$id;
