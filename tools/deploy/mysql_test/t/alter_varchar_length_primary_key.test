--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: bin.lb
# owner group: SQL2
# tags: alter
# description:
#
--disable_abort_on_error
--disable_warnings
drop table if exists t1,t2,t3,t4;
--enable_warnings
create table t1(pk varchar(10) primary key,i1 int, i2 int);
insert into t1 values('abbbbbbbbb',1,10),('aabbbbbbbb',2,10);

##无静态数据/长度改大
desc t1;
alter table t1 modify column pk varchar(20);
sleep 1;
desc t1;

#insert
select * from t1;
insert into t1 values('aaabbbbbbbbbbbb',3,15),('aaaabbbb',4,8);
insert into t1 values('aaaaab',5,6);

--error 1406
insert into t1 values('aaaaaabbbbbbbbbbbbbbbbbbb',6,25);
--error 1406
insert into t1 values('aaaaaaab',7,8),('aaaaaaa8bbbbbbbbbbbbb',8,21);

select * from t1;

#update
update t1 set pk='aaaaaaaaabbb',i1=9,i2=12 where pk='abbbbbbbbb';
update t1 set pk='aaaaaaaaaa',i1=10,i2=10 where pk='aabbbbbbbb';
--error 1406
update t1 set pk='aaaaaaaaaaabbbbbbbbbbb',i1=11,i2=22 where pk='aaabbbbbbbbbbbb';
select * from t1;

#delete alter major(无静态数据)
delete from t1 where pk='aaabbbbbbbbbbbb';
alter table t1 modify column pk varchar(30);
select * from t1;
insert into t1 values('aaabbbbbbbbbbbb',3,15);
select * from t1;

#delete major alter(有静态数据)
delete from t1 where pk='aaaabbbb';
alter table t1 modify column pk varchar(31);
select * from t1;
insert into t1 values('aaaabbbb',4,8);
select * from t1;

#replace
replace into t1 values('aaaaaaaaaaaabbbbbbbbbbb',12,23);
--error 1406
replace into t1 values('aaaaaaaaaaaaabbbbbbbbbbbbbbbbbbb',13,32);
select * from t1;
 
##有静态数据的情况下改大长度
desc t1;
alter table t1 modify column pk varchar(35);
sleep 1;
desc t1;

#insert 
insert into t1 values('aaaaaaaaaaaaaabbbbbbbbbbbbbbbbbb',14,32);
--error 1406
insert into t1 values('aaaaaaaaaaaaaaabbbbbbbbbbbbbbbbbbbbb',15,36);
insert into t1 values('aaaaaaaaaaaaaaaabbbb',16,20);
select * from t1;

#update
update t1 set pk='aaaaaaaaaaaaaaaaabbbbbbbbbbbbbbb',i1=17,i2=32 where pk='aaabbbbbbbbbbbb';
--error 1406
update t1 set pk='aaaaaaaaaaaaaaaaaabbbbbbbbbbbbbbbbbb',i1=18,i2=36 where pk='aaaabbbb';
update t1 set pk='aaaaaaaaaaaaaaaaaaab',i1=19,i2=20 where pk='aaaaab';
select * from t1;

#delete alter major(有静态数据)
delete from t1 where pk='aaaabbbb';
alter table t1 modify column pk varchar(40);
sleep 1;
select * from t1;
insert into t1 values('aaaabbbb',4,8);
select * from t1;

#replace
replace into t1 values('aaaaaaaaaaaaaaaaaaaabbbbbbbbbbbbbbb',20,35);
--error 1406
replace into t1 values('aaaaaaaaaaaaaaaaaaaaabbbbbbbbbbbbbbbbbbbb',21,41);
replace into t1 values('aaaaaaaaaaaaaaaaabbbbbbbbbbbbbbb',17,32);
select * from t1;
drop table t1;

##defalut value
create table t2(pk varchar(5) primary key default 'a' not null,i1 int,i2 int);
insert into t2 values('aa',2,2),('aaa',3,3);
insert into t2(i1,i2) values(1,1);
alter table t2 modify column pk varchar(6) default 'a' not null;
sleep 1;
select * from t2;
alter table t2 alter pk set default 'aaaaa';
sleep 1;
insert into t2(i1,i2) values(5,5);
select * from t2;
alter table t2 alter pk set default 'aaaaaa';
sleep 1;
select * from t2;
insert into t2(i1,i2) values(6,6);
select * from t2;
--error 1067
alter table t2 alter pk set default 'aaaaaaa';

select * from t2;
alter table t2 modify column pk varchar(7) default 'aaaaaa' not null;
--error 1062
insert into t2(i1,i2) values(6,6);
alter table t2 alter pk set default 'aaaaaaa';
sleep 1;
insert into t2(i1,i2) values(7,7);
--error 1067
alter table t2 alter pk set default 'aaaaaaaa';
select * from t2;
drop table t2;

#expire info （暂未实现，先修改result让这个case通过）
create table t3(pk varchar(5) primary key, i1 int, i2 int) EXPIRE_INFO ( pk = "aaaaa");
insert into t3 values('aa',2,2),('aaaa',4,4);
alter table t3 modify column pk varchar(6);
sleep 1;
insert into t3 values('aaaaa',5,5);
select * from t3;
select * from t3;

insert into t3 values('aaaaaa',6,6);
select * from t3;
alter table t3 set EXPIRE_INFO (pk="aaaaaa");
sleep 1;
select * from t3;

create table t4(pk varchar(5) primary key, i1 int, i2 int) EXPIRE_INFO (pk = "aaaaaa");
insert into t4 values('aaaaa',5,5);
alter table t4 modify column pk varchar(6);
sleep 1;
insert into t4 values('aaaaaa',6,6);
select * from t4;
select * from t4;

alter table t4 set EXPIRE_INFO (pk > "aaaaaa");
alter table t4 modify column pk varchar(8);
sleep 1;
insert into t4 values('aaaaaaa',7,7),('aaaaaaaa',8,8);
select * from t4;
select * from t4;

#长度改小
create table t1(pk varchar(20) primary key, i1 int, i2 int);
alter table t1 modify column pk varchar(10);

#边界值以及特殊值
desc t1;
alter table t1 modify column pk varchar(0);
desc t1;
alter table t1 modify column pk varchar(4096);
sleep 1;
desc t1;
--error 1071
alter table t1 modify column pk varchar(4097);
desc t1;
--error 1064
alter table t1 modify column pk varchar(-1);





