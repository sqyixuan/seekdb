# owner: dachuan.sdc
# owner group: SQL
# description: verify primary key constraint and unique key constraint

#use oceanbase;
use test;

--disable_warnings
#connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
#connection obsys;
drop table if exists wang_test;

--enable_warnings

###create table
create table wang_test(c1 int, c2 int, c3 int, c4 int, constraint primary key(c1), unique key(c1, c2), key(c2,c3)) partition by hash(c1);
select * from information_schema.table_constraints where table_name='wang_test';
drop table wang_test;

create table wang_test(c1 int, c2 int, c3 int, c4 int, constraint cons_name primary key(c1, c4), unique key(c1, c2), key(c2,c3)) partition by hash(c1);
select * from information_schema.table_constraints where table_name='wang_test';
drop table wang_test;

create table wang_test(c1 int, c2 int, c3 int, c4 int, unique key(c1, c2), constraint cons_name primary key(c1, c4), key(c2,c3)) partition by hash(c1);
select * from information_schema.table_constraints where table_name='wang_test';
drop table wang_test;

create table wang_test(c1 int, c2 int, c3 int, c4 int, constraint primary key(c1), constraint unique key(c1, c2), key(c2,c3)) partition by hash(c1);
select * from information_schema.table_constraints where table_name='wang_test';
drop table wang_test;

create table wang_test(c1 int, c2 int, c3 int, c4 int, constraint primary key(c1), constraint cons_name unique key(c1, c2), key(c2,c3)) partition by hash(c1);
select * from information_schema.table_constraints where table_name='wang_test';
drop table wang_test;

create table wang_test(c1 int, c2 int, c3 int, c4 int, constraint cons_name primary key(c1, c4), constraint unique key(c1, c2), key(c2,c3)) partition by hash(c1);
select * from information_schema.table_constraints where table_name='wang_test';
drop table wang_test;

create table wang_test(c1 int, c2 int, c3 int, c4 int, constraint cons_name primary key(c1, c4), constraint cons_name unique key(c1, c2), key(c2,c3)) partition by hash(c1);
select * from information_schema.table_constraints where table_name='wang_test';
drop table wang_test;

create table wang_test(c1 int, c2 int, c3 int, c4 int, constraint unique key(c1, c2), constraint cons_name primary key(c1, c4), key(c2,c3)) partition by hash(c1);
select * from information_schema.table_constraints where table_name='wang_test';
drop table wang_test;

create table wang_test(c1 int, c2 int, c3 int, c4 int, constraint cons_name unique key(c1, c2), constraint cons_name primary key(c1, c4), key(c2,c3)) partition by hash(c1);
select * from information_schema.table_constraints where table_name='wang_test';
drop table wang_test;

#negative case
--error 1061
create table wang_test(c1 int, c2 int, c3 int, c4 int, constraint cons_name unique key(c1, c2), constraint cons_name primary key(c1, c4), constraint cons_name unique key(c2,c3)) partition by hash(c1);

###alter table for unique key with constraint name
create table wang_test(c1 int, c2 int, c3 int, c4 int) partition by key(c1, c2);
alter table wang_test add constraint unique(c1, c2) local;
alter table wang_test add key(c2, c3) local;
select distinct * from information_schema.table_constraints where table_name='wang_test';

alter table wang_test add constraint cons_name unique(c1, c2) local;
alter table wang_test add key(c2, c3) local;
select distinct * from information_schema.table_constraints where table_name='wang_test';

--error 1061
alter table wang_test add constraint cons_name unique(c1, c2);
alter table wang_test add key(c2, c3) local;

--error 1061
alter table wang_test add constraint cons_name unique(c2, c3);

alter table wang_test add constraint unique(c1, c2) local;
select distinct * from information_schema.table_constraints where table_name='wang_test';

alter table wang_test add constraint primary key(c1, c2);

sleep 2;
drop table wang_test;
connection default;
