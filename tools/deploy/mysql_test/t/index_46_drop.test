--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: bin.lb
# owner group: SQL3
# description:
# tags:index
--disable_warnings
drop database if exists sch_index_46_drop;
create database sch_index_46_drop;
use sch_index_46_drop;

drop table if exists t1,t2,t3,t4,t5;
--enable_warnings
--source mysql_test/include/index_quick_major.inc
--real_sleep 1

#case 1
create table t1(pk int primary key, key1 int, key2 int, v3 varchar(20));
create index i1 on t1(key1);
insert into t1 values(1,5,2,'a'),(2,5,2,'b'),(4,5,2,'c');

sleep 1;
sleep 1;
--source mysql_test/include/check_all_idx_ok.inc

select * from t1 where key1>=1 and key1<6;
select /*+ index(t1 i1)*/ * from t1 where key1>=1 and key1<6;
drop index i1 on t1;
sleep 1;
select * from t1 where key1>=1 and key1<6;
select /*+ index(t1 i1)*/ * from t1 where key1>=1 and key1<6;
replace into t1 values(1,5,2,'aa');
select * from t1 where key1>=1 and key1<6;
select /*+ index(t1 i1)*/ * from t1 where key1>=1 and key1<6;
drop table t1;

#case 2
create table t2(pk int primary key, key1 int, key2 int, v3 varchar(20));
create index i1 on t2(key1);

--source mysql_test/include/check_all_idx_ok.inc

insert into t2 values(1,5,2,'a'),(2,5,2,'b'),(4,5,2,'c');
drop index i1 on t2;
sleep 1;
select * from t2 where key1>=1 and key1<6;
select /*+ index(t2 i1)*/ * from t2 where key1>=1 and key1<6;
replace into t2 values(1,5,2,'aa');
--real_sleep 12
create index i2 on t2(key1);
drop index i2 on t2;
sleep 1;
select * from t2 where key1>=1 and key1<6;
select /*+ index(t2 i1)*/ * from t2 where key1>=1 and key1<6;
create index i1 on t2(key1);

--source mysql_test/include/check_all_idx_ok.inc

replace into t2 values(1,5,2,'aaa');
select * from t2 where key1>=1 and key1<6;
select /*+ index(t2 i1)*/ * from t2 where key1>=1 and key1<6;
drop index i1 on t2;
sleep 1;
select * from t2 where key1>=1 and key1<6;
select /*+ index(t2 i1)*/ * from t2 where key1>=1 and key1<6;
--real_sleep 12
select * from t2 where key1>=1 and key1<6;
select /*+ index(t2 i1)*/ * from t2 where key1>=1 and key1<6;
drop table t2;

#case 3
--disable_warnings
drop table if exists t3;
--enable_warnings
create table t3(pk int primary key, key1 int, key2 int, v3 varchar(20));
create index i1 on t3(key1);
create index i2 on t3(key1,key2);

--source mysql_test/include/check_all_idx_ok.inc

insert into t3 values(1,5,2,'a'),(2,3,2,'b'),(4,1,2,'c');
select * from t3 where key1>=1 and key1<6 order by pk;
select /*+ index(t3 i1)*/ * from t3 where key1>=1 and key1<6;
select /*+ index(t3 i2)*/ * from t3 where key1>=1 and key1<6;
drop index i1 on t3;
select * from t3 where key1>=1 and key1<6 order by pk;
select /*+ index(t3 i1)*/ * from t3 where key1>=1 and key1<6 order by pk;
select /*+ index(t3 i2)*/ * from t3 where key1>=1 and key1<6;
--real_sleep 12
select * from t3 where key1>=1 and key1<6 order by pk;
select /*+ index(t3 i1)*/ * from t3 where key1>=1 and key1<6 order by pk;
select /*+ index(t3 i2)*/ * from t3 where key1>=1 and key1<6;
--replace_column 1 table_id
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
select t.table_id, t.table_name from oceanbase.__all_virtual_table t join oceanbase.__all_virtual_database d on t.database_id = d.database_id where t.table_name like 't_' and d.in_recyclebin = 0 and d.database_name = 'sch_index_46_drop';
disconnect obsys;
connection default;
drop table t3;
--replace_column 1 table_id
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
select t.table_id, t.table_name from oceanbase.__all_virtual_table t join oceanbase.__all_virtual_database d on t.database_id = d.database_id where t.table_name like 't_' and d.in_recyclebin = 0 and d.database_name = 'sch_index_46_drop';
disconnect obsys;
connection default;
#case4
