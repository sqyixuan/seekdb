--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: yuchen.wyc
# owner group: SQL1
# Test of functions index_21_trx_concu_default

####TITLE:并发事务中,dml操作default列,查询索引表、数据表、回表
--disable_query_log
--source mysql_test/include/index_quick_major.inc
--real_sleep 1
--disable_warnings
drop table if exists t1;
--enable_warnings
--enable_query_log

create table t1(c1 int primary key default 1 not null,
	            c2 int default 1 not null,
	            c3 int default 1,
	            c4 int);
create index i1 on t1(c2) storing(c3);

--disable_query_log
let $index_name = __idx_3003_i1;
--enable_query_log
--source mysql_test/include/check_all_idx_ok.inc

connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn2,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);

--enable_sorted_result

####CASE:insert replace操作利用default值
connection conn1;
set autocommit=0;
select c1,c2,c3 from t1 where c2>0 and c2<100;
select * from t1  where c1>0 and c1<100;
select * from t1 where c2>0 and c2<100;

connection conn2;
set autocommit=0;
insert into t1(c1) values(1);
replace into t1(c1) values(2);

insert into t1(c1,c2) values(3,3);
replace into t1(c1,c2) values(4,4);

insert into t1(c1,c3) values(5,5);
replace into t1(c1,c3) values(6,6);

insert into t1(c1,c4) values(7,7);
replace into t1(c1,c4) values(8,8);

insert into t1(c1, c2, c3) values(9,9,9);
replace into t1(c1,c2, c3) values(10,10,10);
commit;

connection conn1;
select c1,c2,c3 from t1 where c2>0 and c2<100;
select * from t1  where c1>0 and c1<100;
select * from t1 where c2>0 and c2<100;
commit;
select c1,c2,c3 from t1 where c2>0 and c2<100;
select * from t1  where c1>0 and c1<100;
select * from t1 where c2>0 and c2<100;

####CASE:insert replace不用default值
connection conn2;
insert into t1(c1, c2, c3, c4) values(11,11,11,11);
replace into t1(c1,c2, c3, c4) values(12,12,12,12);
commit;

connection conn1;
select c1,c2,c3 from t1 where c2>0 and c2<100;
select * from t1  where c1>0 and c1<100;
select * from t1 where c2>0 and c2<100;
commit;
select c1,c2,c3 from t1 where c2>0 and c2<100;
select * from t1  where c1>0 and c1<100;
select * from t1 where c2>0 and c2<100;

####CASE:replace 已有列
connection conn2;
replace into t1(c1) values(2);
replace into t1(c1,c2) values(4,40);
replace into t1(c1,c3) values(6,60);
replace into t1(c1,c4) values(8,80);
replace into t1(c1,c2,c3) values(10,100,100);
replace into t1(c1, c2, c3, c4) values(11,110,110,110);
commit;

connection conn1;
select c1,c2,c3 from t1 where c2>0 and c2<1000;
select * from t1  where c1>0 and c1<1000;
select * from t1 where c2>0 and c2<1000;
commit;
select c1,c2,c3 from t1 where c2>0 and c2<1000;
select * from t1  where c1>0 and c1<1000;
select * from t1 where c2>0 and c2<1000;

####CASE: update 已有列
connection conn2;
update t1 set c2=10 where c1=2;
update t1 set c2=41, c3=41, c4=41 where c1=4;
update t1 set c2=61, c3=61, c4=61 where c1=6;
update t1 set c2=81, c3=81, c4=81 where c1=8;
update t1 set c2=101, c3=101, c4=101 where c1=10;
update t1 set c4=null where c1=11;
commit;

connection conn1;
select c1,c2,c3 from t1 where c2>0 and c2<1000;
select * from t1  where c1>0 and c1<1000;
select * from t1 where c2>0 and c2<1000;
commit;
select c1,c2,c3 from t1 where c2>0 and c2<1000;
select * from t1  where c1>0 and c1<1000;
select * from t1 where c2>0 and c2<1000;

drop table t1;

