--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: yuchen.wyc
# owner group: SQL1
# description: OUR GOAL: Make all this simple and effective!
connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn2,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn1;
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(pk int primary key, a int);
insert into t1 values(1,1);
insert into t1 values(2,1);
set autocommit=0;
select * from t1;
select * from t1;
rollback;
connection conn1;
update t1 set a=2 where pk=1;
connection conn2;
#select now();
--error 1205
select * from t1 where pk=1 for update  wait 10; 
#select now();
--error 1205
select * from t1 where pk=1 for update  wait 5;
#select now();
--error 1205
select * from t1 where pk=1 for update  wait 0.000001;


connection conn1;
commit;
update t1 set a=2 where pk=1;
connection conn2;
send select * from t1 where pk=1 for update  wait 10;
connection conn1; 
sleep 8;
commit;


connection conn2;
reap;
connection conn1;
update t1 set a=2 where pk=1;
connection conn2;
send select * from t1 where pk=1 for update  wait 4;
connection conn1;
sleep 3;
commit;

                                                                                                                                                     
connection conn2;                                                                                                                                    
reap;        
