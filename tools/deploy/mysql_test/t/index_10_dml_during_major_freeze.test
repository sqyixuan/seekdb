--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: yibo.tyf
#owner group: sql1

####
--disable_query_log
--source mysql_test/include/index_quick_major.inc
--real_sleep 1
--disable_warnings
drop table if exists t1;
--enable_warnings
--enable_query_log

create table t1(c1 int primary key, c2 varchar(1024), c3 int, c4  timestamp(6) default "2012-01-01 12:00:00");
create index i1 on t1(c3) storing(c2);

--disable_query_log
let $i = 3000;
while($i>0)
{
    eval insert into t1(c1,c2,c3) values($i, 'a', $i);
    dec $i;
}
--enable_query_log

####CASE1: replace during major_freeze
--source mysql_test/include/majorfreeze.inc
--disable_query_log
let $i = 1000;
while($i>0)
{
    eval replace into t1 values($i, 'b', $i+1,'2013-12-10 00:00:00');
    dec $i;
}
--enable_query_log

let $index_name = __idx_3003_i1;
--source mysql_test/include/check_all_idx_ok.inc

select /*+ index(t1 i1) */ * from t1 where c3>=2 limit 5;
select /*+ index(t1 primary) */ * from t1 where c3>=2 limit 5;

####CASE2: update during major_freeze
create index i2 on t1(c3) storing(c4);
--source mysql_test/include/majorfreeze.inc
--disable_query_log
let $i = 2000;
while($i>1000)
{
    eval update t1 set c4='2013-12-10 01:01:01' where c1=$i;
    dec $i;
}
--enable_query_log

let $index_name = __idx_3003_i2;
--source mysql_test/include/check_all_idx_ok.inc

select /*+ index(t1 i2) */ c1,c3,c4 from t1 where c3 > 1000 limit 5;
select /*+ index(t1 primary) */ c1,c3,c4 from t1 where c3 > 1000 limit 5;

####CASE3: delete during major_freeze
create index i3 on t1(c2) storing(c3,c4);
--source mysql_test/include/majorfreeze.inc
--disable_query_log
let $i = 3000;
while($i>2000)
{
    eval delete from t1 where c1=$i;
    dec $i;
}
--enable_query_log

let $index_name = __idx_3003_i3;
--source mysql_test/include/check_all_idx_ok.inc

select /*+ index(t1 i3) */ count(*) from t1 where c2='a' and c3 > 3000;
select /*+ index(t1 primary) */ count(*) from t1 where c1 > 3000;

####CASE4: insert during major_freeze
create index i4 on t1(c2) storing(c3,c4);
--source mysql_test/include/majorfreeze.inc
--disable_query_log
let $i = 4000;
while($i>3000)
{
    eval insert into t1 values($i,'c', $i, '2013-12-10 02:02:02');
    dec $i;
}
--enable_query_log

let $index_name = __idx_3003_i4;
--source mysql_test/include/check_all_idx_ok.inc

select /*+ index(t1 i4) */ c1,c2,c3,c4 from t1 where c2='c' and c3 > 3000 limit 5;
select /*+ index(t1 primary) */ c1,c2,c3,c4 from t1 where c1 > 3000 limit 5;

select count(*) from t1 where c3 > 3000;
select count(*) from t1 where c1 > 0;


select /*+ index(t1 i1) */ * from t1 where c3>3000 limit 5;
select /*+ index(t1 i2) */ c1,c3,c4 from t1 where c3 > 3000 limit 5;
select /*+ index(t1 i3) */ c1,c2,c3,c4 from t1 where c2='c' and c3 > 2000 limit 5;
select /*+ index(t1 i4) */ c1,c2,c3,c4 from t1 where c2='c' and c3 > 2000 limit 5;
select /*+ index(t1 primary) */ c1,c3,c4 from t1 where c3 > 1000 limit 5;

#drop table t1;
--source mysql_test/include/wait_daily_merge.inc
