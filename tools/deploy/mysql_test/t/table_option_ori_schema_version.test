## alter table add index
connection default;
create table t6(c1 int primary key, c2 int, c3 varchar(50));
let $ret = query_get_value(select (a.ori_schema_version - max(b.schema_version)) ret from oceanbase.__all_ori_schema_version     a inner join oceanbase.__all_ddl_operation b where (0xfffff & a.table_id) = (select max(table_id) table_id from oceanbase.__all_table where table_name = 't6') and b.table_id = (0xfffff & a.table_id), ret, 1);
if ($ret)
{
  --echo failed: ori_schema_version is not equal to the last schema verion in __all_ddl_operation
}
connection default;
alter table t6 add index idx(c2);
#验证主表ori_schema_version
--echo verify ori_schema_version of data table
let $diff_cnt = query_get_value(select count(ori_schema_version)-1 diff_cnt from oceanbase.__all_ori_schema_version where (0xfffff&table_id) = (select max(table_id) table_id from oceanbase.__all_table where table_name='t6'), diff_cnt, 1);
if ($diff_cnt)
{
  --echo failed: ori_schema_version is not equal to the last ori schema verion
}
#验证索引表ori_schema_version
--echo verify ori_schema_version of index table
let $diff_cnt = query_get_value(select count(ori_schema_version)-1 diff_cnt from oceanbase.__all_ori_schema_version where (0xfffff&table_id) = (select max(table_id) table_id from oceanbase.__all_table where table_name='t6'), diff_cnt, 1);
if ($ret)
{
  --echo failed: ori_schema_version is not equal to the last schema verion in __all_ddl_operation
}

## truncate table
connection default;
create table t7(c1 int primary key, c2 int, c3 varchar(50), index idx(c2));
truncate table t7;
connection default;
alter table t7 drop column c3;
let $diff_cnt = query_get_value(select count(ori_schema_version)-1 diff_cnt from oceanbase.__all_ori_schema_version where (0xfffff&table_id) = (select max(table_id) table_id from oceanbase.__all_table where table_name='t7'), diff_cnt, 1);
if ($diff_cnt)
{
  --echo failed: ori_schema_version is not equal to the last ori schema verion
}

## create table like
connection default;
create table like_t7 like t7;
let $ret = query_get_value(select (a.ori_schema_version - max(b.schema_version)) ret from oceanbase.__all_ori_schema_version     a inner join oceanbase.__all_ddl_operation b where (0xfffff & a.table_id) = (select max(table_id) table_id from oceanbase.__all_table where table_name = 'like_t7') and b.table_id = (0xfffff & a.table_id), ret, 1);
if ($ret)
{
  --echo failed: ori_schema_version is not equal to the last schema verion in __all_ddl_operation
}
connection default;
alter table like_t7 add column c3 char(10);
let $diff_cnt = query_get_value(select count(ori_schema_version)-1 diff_cnt from oceanbase.__all_ori_schema_version where (0xfffff&table_id) = (select max(table_id) table_id from oceanbase.__all_table where table_name='like_t7'), diff_cnt, 1);
if ($diff_cnt)
{
  --echo failed: ori_schema_version is not equal to the last ori schema verion
}

connection default;
drop database jx_db;
