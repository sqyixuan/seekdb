#全局索引
connection default;
create table t5(c1 int primary key, c2 int, c3 varchar(50), index idx(c2) global, unique index(c3(10)) global);
let $ret = query_get_value(select (a.ori_schema_version - max(b.schema_version)) ret from oceanbase.__all_ori_schema_version     a inner join oceanbase.__all_ddl_operation b where (0xfffff & a.table_id) = (select max(table_id) table_id from oceanbase.__all_table where table_name = 't5') and b.table_id = (0xfffff & a.table_id), ret, 1);
if ($ret)
{
  --echo failed: ori_schema_version is not equal to the last schema verion in __all_ddl_operation
}
connection default;
alter table t5 add column c4 int;
let $diff_cnt = query_get_value(select count(ori_schema_version)-1 diff_cnt from oceanbase.__all_ori_schema_version where (0xfffff&table_id) = (select max(table_id) table_id from oceanbase.__all_table where table_name='t5'), diff_cnt, 1);
