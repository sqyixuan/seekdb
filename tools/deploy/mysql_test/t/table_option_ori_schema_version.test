# owner: dachuan.sdc
# owner group: SQL
# description: verify table option: ori_schema_version
#
--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
--disable_warnings
drop database if exists jx_db;
--enable_warnings

create database jx_db;
use jx_db;

## create table
create table t1(c1 int primary key, c2 int);
let $ret = query_get_value(select (a.ori_schema_version - max(b.schema_version)) ret from oceanbase.__all_ori_schema_version     a inner join oceanbase.__all_ddl_operation b where (0xfffff&a.table_id) = (select max(table_id) table_id from oceanbase.__all_table where table_name = 't1') and b.table_id = (0xfffff & a.table_id), ret, 1);
if ($ret)
{
  --echo failed: ori_schema_version is not equal to the last schema verion in __all_ddl_operation
}
connection default;

alter table t1 add column c3 int;

let $diff_cnt = query_get_value(select count(ori_schema_version)-1 diff_cnt from oceanbase.__all_ori_schema_version where (0xfffff&table_id) = (select max(table_id) table_id from oceanbase.__all_table where table_name='t1'), diff_cnt, 1);
if ($diff_cnt)
{
  --echo failed: ori_schema_version is not equal to the last ori schema verion
}
connection default;
create table t2(c1 int primary key, c2 int, index idx(c2));
let $ret = query_get_value(select (a.ori_schema_version - max(b.schema_version)) ret from oceanbase.__all_ori_schema_version     a inner join oceanbase.__all_ddl_operation b where (0xfffff & a.table_id) = (select max(table_id) table_id from oceanbase.__all_table where table_name = 't2') and b.table_id = (0xfffff & a.table_id), ret, 1);
if ($ret)
{
  --echo failed: ori_schema_version is not equal to the last schema verion in __all_ddl_operation
}
connection default;
alter table t2 add column c3 int;
let $diff_cnt = query_get_value(select count(ori_schema_version)-1 diff_cnt from oceanbase.__all_ori_schema_version where (0xfffff&table_id) = (select max(table_id) table_id from oceanbase.__all_table where table_name='t2'), diff_cnt, 1);
if ($diff_cnt)
{
  --echo failed: ori_schema_version is not equal to the last ori schema verion
}
connection default;
create table t3(c1 int primary key, c2 int, c3 varchar(50), index idx(c2), unique index(c3));
let $ret = query_get_value(select (a.ori_schema_version - max(b.schema_version)) ret from oceanbase.__all_ori_schema_version     a inner join oceanbase.__all_ddl_operation b where (0xfffff & a.table_id) = (select max(table_id) table_id from oceanbase.__all_table where table_name = 't3') and b.table_id = (0xfffff & a.table_id), ret, 1);
if ($ret)
{
  --echo failed: ori_schema_version is not equal to the last schema verion in __all_ddl_operation
}
connection default;
alter table t3 add column c4 int;
let $diff_cnt = query_get_value(select count(ori_schema_version)-1 diff_cnt from oceanbase.__all_ori_schema_version where (0xfffff&table_id) = (select max(table_id) table_id from oceanbase.__all_table where table_name='t3'), diff_cnt, 1);
if ($diff_cnt)
{
  --echo failed: ori_schema_version is not equal to the last ori schema verion
}

