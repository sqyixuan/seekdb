--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: dachuan.sdc
#owner group:sql2
#tags: privilege
#该case原本是在lowercase insensitive fs中使用的,OB都是在Linux下,因此注释掉have_case_insensitive测试grant对user的case sensitive
#

#-- source mysql_test/include/have_case_insensitive_file_system.inc
#-- source mysql_test/include/not_embedded.inc

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
#
# Bug#41049 does syntax "grant" case insensitive?
#
--disable_warnings
drop database if exists db1;
--enable_warnings
--error 0, 1396
drop user user_1;
--error 0, 1396
drop user USER_1;
create user user_1;
create user USER_1;

create database db1;
GRANT CREATE ON db1.* to user_1;
GRANT SELECT ON db1.* to USER_1;
--source mysql_test/include/check_schema_sync.inc
connect (con1,$OBMYSQL_MS0,user_1,,db1, $OBMYSQL_PORT);
CREATE TABLE t1(f1 int);
connection default;
connection con1;
--error 1142
SELECT * FROM t1;
connect (con2,$OBMYSQL_MS0,USER_1,,db1, $OBMYSQL_PORT);
SELECT * FROM t1;
--error 1142
CREATE TABLE t2(f1 int);

connection default;
disconnect con1;
disconnect con2;

connection obsys;
REVOKE ALL PRIVILEGES, GRANT OPTION FROM user_1;
REVOKE ALL PRIVILEGES, GRANT OPTION FROM USER_1;
DROP USER user_1;
DROP USER USER_1;
DROP DATABASE db1;
use test;
