--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: dachuan.sdc
# owner group: SQL3
# description: foobar
################################################################
# description: test all about charset and collation
################################################################
show collation;
show character set;
################################################################ variables about collation
# set names & set charset
show variables where variable_name like 'collation%' or variable_name like 'character_set%';
set names binary;
show variables where variable_name like 'collation%' or variable_name like 'character_set%';
set names utf8mb4 collate utf8mb4_bin;
show variables where variable_name like 'collation%' or variable_name like 'character_set%';
set character set utf8;
show variables where variable_name like 'collation%' or variable_name like 'character_set%';
set character_set_database = 'utf8';
set collation_database = 'utf8_general_ci';
set character set binary;
show variables where variable_name like 'collation%' or variable_name like 'character_set%';
--error 1115
set names kaka;
--error 1273
set names utf8 collate haha;
--error 1253
set names binary collate utf8mb4_general_ci;
# recovery the original
set names utf8 collate utf8mb4_general_ci;
--error 1231
set names utf16;
--error 1231
set names utf16 collate utf16_bin;
set names gb18030;
# recovery the original
set names utf8 collate utf8mb4_general_ci;
################################################################ DDL
# default charset&collation of database & table
--disable_warnings
drop table if exists t1;
--enable_warnings
--error 1115
create table t1 (c1 varchar(10) primary key) charset kaka;
--error 1273
create table t1 (c1 varchar(10) primary key) charset utf8, collate haha;
--error 1253
create table t1 (c1 varchar(10) primary key) charset binary, collate utf8mb4_general_ci;

create table t1 (c1 varchar(10) primary key, c2 varchar(10) character set binary, c3 varchar(10) character set utf8mb4 collate utf8mb4_bin) default character set utf8, collate utf8_general_ci;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;
--disable_warnings
drop database if exists db1;
--enable_warnings
--error 1115
create database db1 charset kaka;
--error 1273
create database db1 charset utf8 collate haha;
--error 1253
create database db1 charset binary collate utf8mb4_general_ci;
create database db1 DEFAULT CHARACTER SET utf8 COLLATE utf8_bin;
use db1;
# use database will also change character_set_database and collation_database automatically
show variables like '%database';
create table t2(c1 varchar(10) primary key);
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t2;

################################################################ expression
# string literal with collation
--error 1054
select _kaka 'abc';
--error 1273
select 'abc' collate haha;
--error 1064
select _binary 'abc' binary;

select _utf8 'abc' collate utf8_general_ci;
select _binary 'abc';

# expression charset & collation & coercibility
select charset(null);
select charset('abc');
select collation(X'42');
select collation(null);
select collation('abc');
select collation(X'42');
select coercibility(null);
select coercibility(1);
select coercibility(timestamp'2015-06-25 15:18:00');
select coercibility('abc');
select coercibility(X'42');
select coercibility(_utf8 'abc');
select coercibility(_utf8 'abc' collate utf8_general_ci);
select coercibility('abc' collate utf8_general_ci);
select coercibility(@@version_comment);
set @abc='abc';
select coercibility(@abc);
set @abc=_utf8 'abc' collate utf8_general_ci;
select coercibility(@abc);
select coercibility(substr('abc', 2));
select coercibility(upper('abc'));
select coercibility(lower('abc'));
select coercibility(version());
select coercibility(user());
select coercibility(hex('ab'));
select coercibility(unhex('ab'));
select coercibility(substring_index('abc', 'a', 1));
select coercibility(repeat('abc', 1));
select coercibility(md5('1234'));
select coercibility(effective_tenant());

use test;
insert into t1(c1) values ('abc');
select coercibility(c1), coercibility(c1 collate utf8_bin) from t1 where c1 collate utf8_general_ci = 'abc' collate utf8_general_ci;

drop table t1;
# create table t1( name varchar(20) )default charset = gbk;
# insert into t1 values('abc阿里123');
# select replace(t1.name, 'abc','阿') from t1;   

################################################################ DML
# compare with collation
--disable_warnings
drop table if exists coll_table;
--enable_warnings
create table coll_table(c1 varchar(10) collate utf8_general_ci, c2 varchar(10) collate utf8_bin, c3 varchar(10) collate utf8_general_ci, primary key(c1));
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table coll_table;
insert into coll_table value('a', 'A', 'A'), ('b', 'B', 'a'), ('c', 'a', 'B');
select * from coll_table;

# order by
select c2 from coll_table order by c2;
select c2 from coll_table order by c2 collate utf8_general_ci;
select c3 from coll_table order by c3;
select c3 from coll_table order by binary c3;
# AS
select c2 collate utf8_general_ci AS cc from coll_table order by cc;
# group by
--sorted_result
select c2, max(c3) from coll_table group by c2;
--sorted_result
select c2, max(c3) from coll_table group by c2 collate utf8_general_ci;
# aggregate function
select max(c2) from coll_table;
select max(c2 collate utf8_general_ci) from coll_table;
# distinct
select distinct c2 from coll_table;
select distinct c2 collate utf8_general_ci from coll_table;
# where
select * from coll_table where c1 > c3;
select * from coll_table where c1 > c2;
select * from coll_table where c2 collate utf8_general_ci > c3 collate utf8_general_ci;
select * from coll_table where c2 collate utf8_bin > c3 collate utf8_bin;
# having
select * from coll_table group by c2 having c2 = 'a' collate utf8_general_ci;
# union
(select c2 from coll_table) union (select c2 from coll_table);
(select c3 from coll_table) union (select c3 from coll_table);
(select c2 from coll_table) union (select c3 from coll_table);
# except
(select c2 from coll_table) except (select c3 from coll_table);
(select c2 from coll_table) except (select c3 from coll_table where c3 != binary 'a');

# functions
select  X'4125', X'4125' LIKE 'a%';

# cleanup
drop table coll_table;
drop database db1;
# drop default database will also change character_set_database and collation_database to the value of character_set_server and collation_server respectively
show variables like '%database';
