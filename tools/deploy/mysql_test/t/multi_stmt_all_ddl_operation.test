set @@session.explicit_defaults_for_timestamp=off;
#owner: dachuan.sdc
# owner group: sql
# description:
# To verify problems with multiple statements on __all_ddl_operation
#     1. Create table
#     2. Drop table
#     3. Alter table
#     4. truncate table
#     5. Create table like
#     6. flashback table
#     7. purge table
#     8. mixed cases
# tags: ddl
#

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
connection default;

--disable_warnings
#################################################
#Create t1;create t2;create t3;
drop table if exists wang_t1;
drop table if exists wang_t2;
drop table if exists wang_t3;
--enable_warnings

--enable_query_log
delimiter #;
create table wang_t1(c1 int);create table wang_t2(c1 int);create table wang_t3(c1 int);#
delimiter ;#
connection obsys;
--replace_regex /__recycle_\$_[0-9]*_[0-9]*/__recycle_$_1_1111/g
select operation_type, ddl_stmt_str from oceanbase.__all_virtual_ddl_operation where operation_type != 1503 order by gmt_create desc limit 3;
connection default;
insert into wang_t1 values(1);
insert into wang_t2 values(11);
insert into wang_t3 values(111);

drop table wang_t1;
drop table wang_t2;
drop table wang_t3;

#################################################
#drop t1;drop t2;drop t3;
--disable_warnings
drop table if exists wang_t1;
drop table if exists wang_t2;
drop table if exists wang_t3;
--enable_warnings
create table wang_t1(c1 int);
create table wang_t2(c1 char);
create table wang_t3(c1 varchar(50));
delimiter #;
drop table wang_t1; drop table wang_t2; drop table wang_t3;#

delimiter ;#
connection obsys;
--replace_regex /__recycle_\$_[0-9]*_[0-9]*/__recycle_$_1_1111/g
select operation_type, ddl_stmt_str from oceanbase.__all_virtual_ddl_operation where operation_type != 1503 order by gmt_create desc limit 3;
connection default;

#################################################
#add column c2;add column c3;drop column c2;
--disable_query_log
drop table if exists wang_t1;
--enable_query_log
create table wang_t1(c1 int);
delimiter #;
alter table wang_t1 add column c2 timestamp; alter table wang_t1 add column c3 tinyint; alter table wang_t1 drop column c2;#
delimiter ;#
connection obsys;
--replace_regex /__recycle_\$_[0-9]*_[0-9]*/__recycle_$_1_1111/g
select operation_type, ddl_stmt_str from oceanbase.__all_virtual_ddl_operation where operation_type != 1503 order by gmt_create desc limit 10;
connection default;

#################################################
#truncate t1;truncate t2;truncate t3;
--disable_warnings
drop table if exists wang_t1;
drop table if exists wang_t2;
drop table if exists wang_t3;
--enable_warnings
create table wang_t1(c1 int);
create table wang_t2(c1 char);
create table wang_t3(c1 varchar(50));
delimiter #;
truncate wang_t1 ; truncate wang_t2 ; truncate table wang_t3 ;#
delimiter ;#
connection obsys;
--replace_regex /__recycle_\$_[0-9]*_[0-9]*/__recycle_$_1_1111/g
select operation_type, ddl_stmt_str from oceanbase.__all_virtual_ddl_operation where operation_type != 1503 order by gmt_create desc limit 6;
connection default;

drop table wang_t1;
drop table wang_t2;
drop table wang_t3;

#################################################
#create like_t1;create like_t2;create like_t3;
--disable_warnings
drop table if exists wang_t1;
drop table if exists wang_t2;
drop table if exists wang_t3;
drop table if exists like_wang_t1;
drop table if exists like_wang_t2;
drop table if exists like_wang_t3;
--enable_warnings
create table wang_t1(c1 int);
create table wang_t2(c1 char);
create table wang_t3(c1 varchar(50));
delimiter #;
create table like_wang_t1 like wang_t1; create table like_wang_t2 like wang_t2; create table like_wang_t3 like wang_t3;#
delimiter ;#
connection obsys;
--replace_regex /__recycle_\$_[0-9]*_[0-9]*/__recycle_$_1_1111/g
select operation_type, ddl_stmt_str from oceanbase.__all_virtual_ddl_operation where operation_type != 1503 order by gmt_create desc limit 3;
connection default;

drop table wang_t1;
drop table wang_t2;
drop table wang_t3;
drop table like_wang_t1;
drop table like_wang_t2;
drop table like_wang_t3;

#################################################
#flashback table 
--disable_warnings
drop table if exists wang_dummy;
drop table if exists wang_t1;
drop table if exists wang_t2;
--enable_warnings

create table wang_t1(c1 int);
insert into wang_t1 values(1111);
create table wang_t2(c1 char);
insert into wang_t2 values('a');

drop table wang_t1;
drop table wang_t2;

connection obsys;
let $obj_wang_t1 = query_get_value(select object_name from oceanbase.__all_virtual_recyclebin where original_name = 'wang_t1' order by gmt_create desc limit 1, object_name, 1);
let $obj_wang_t2 = query_get_value(select object_name from oceanbase.__all_virtual_recyclebin where original_name = 'wang_t2' order by gmt_create desc limit 1, object_name, 1);
connection default;

delimiter #;
--disable_query_log
eval flashback table $obj_wang_t1 to before drop; create table wang_dummy(c1 bigint);#
eval flashback table $obj_wang_t2 to before drop; alter table wang_dummy add column c2 tinyint;#
--enable_query_log
delimiter ;#

connection obsys;
--replace_regex /__recycle_\$_[0-9]*_[0-9]*/__recycle_$_1_1111/g
select operation_type, ddl_stmt_str from oceanbase.__all_virtual_ddl_operation where operation_type != 1503 order by gmt_create desc limit 6;
connection default;
select * from wang_t1;
select * from wang_t2;

drop table wang_t1;
drop table wang_t2;
drop table wang_dummy;

#################################################
#purge table 
--disable_warnings
drop table if exists wang_dummy;
drop table if exists wang_t1;
drop table if exists wang_t2;
--enable_warnings

create table wang_t1(c1 int);
insert into wang_t1 values(1111);
create table wang_t2(c1 char);
insert into wang_t2 values('a');

drop table wang_t1;
drop table wang_t2;

connection obsys;
let $obj_wang_t1 = query_get_value(select object_name from oceanbase.__all_virtual_recyclebin where original_name = 'wang_t1' order by gmt_create desc limit 1, object_name, 1);
let $obj_wang_t2 = query_get_value(select object_name from oceanbase.__all_virtual_recyclebin where original_name = 'wang_t2' order by gmt_create desc limit 1, object_name, 1);
connection default;

delimiter #;
--disable_query_log
eval purge table $obj_wang_t1; create table wang_dummy(c1 bigint);#
eval purge table $obj_wang_t2; alter table wang_dummy add column c2 tinyint;#
--enable_query_log
delimiter ;#
connection obsys;
--replace_regex /__recycle_\$_[0-9]*_[0-9]*/__recycle_$_1_1111/g
select operation_type, ddl_stmt_str from oceanbase.__all_virtual_ddl_operation where operation_type != 1503 order by gmt_create desc limit 6;
connection default;

--disable_warnings
drop table if exists wang_t1;
drop table if exists wang_t2;
drop table if exists wang_dummy;
--enable_warnings

#################################################
#mixed cases 
--disable_warnings
drop table if exists wang_t1;
drop table if exists wang_t2;
drop table if exists wang_t3;
drop table if exists like_wang_t3;
--enable_warnings

delimiter #;
create table wang_t1(c1 int);alter table wang_t1 add column c2 varchar(50);alter table wang_t1 drop column c1;#
delimiter ;#
connection obsys;
--replace_regex /__recycle_\$_[0-9]*_[0-9]*/__recycle_$_1_1111/g
select operation_type, ddl_stmt_str from oceanbase.__all_virtual_ddl_operation where operation_type != 1503 order by gmt_create desc limit 8;
connection default;
insert into wang_t1 values('antFin');
drop table wang_t1;

delimiter #;
create table wang_t2(c1 int);alter table wang_t2 add column c2 varchar(50);truncate table wang_t2;#
delimiter ;#
connection obsys;
--replace_regex /__recycle_\$_[0-9]*_[0-9]*/__recycle_$_1_1111/g
select operation_type, ddl_stmt_str from oceanbase.__all_virtual_ddl_operation where operation_type != 1503 order by gmt_create desc limit 5;
connection default;
insert into wang_t2 values(111, 'antFin');
drop table wang_t2;

delimiter #;
create table wang_t3(c1 int);truncate table wang_t3;alter table wang_t3 add column c2 varchar(50); create table like_wang_t3 like wang_t3;#
delimiter ;#
connection obsys;
--replace_regex /__recycle_\$_[0-9]*_[0-9]*/__recycle_$_1_1111/g
select operation_type, ddl_stmt_str from oceanbase.__all_virtual_ddl_operation where operation_type != 1503 order by gmt_create desc limit 6;
connection default;
insert into wang_t3 values(111, 'antFin');
insert into like_wang_t3 values(111, 'antFin');

drop table wang_t3;
drop table like_wang_t3;
