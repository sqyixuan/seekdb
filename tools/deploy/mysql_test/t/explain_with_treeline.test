# owner: bin.lb
# owner group: sql3

--disable_warnings
drop table if exists t1,t2,t3;
--enable_warnings

create table t1 (c1 int);
create table t2 (c1 int);
create table t3 (c1 int);

explain select /*+ parallel(2) */ * from (select c1 from t1 union all select c1 from t2 union all select t1.c1 from t1, t2, t3 where t1.c1 = t2.c1 and t2.c1 = t3.c1);
explain pretty select /*+ parallel(2) */ * from (select c1 from t1 union all select c1 from t2 union all select t1.c1 from t1, t2, t3 where t1.c1 = t2.c1 and t2.c1 = t3.c1);
explain pretty_color select /*+ parallel(2) */ * from (select c1 from t1 union all select c1 from t2 union all select t1.c1 from t1, t2, t3 where t1.c1 = t2.c1 and t2.c1 = t3.c1);

explain basic select /*+ parallel(2) */ * from (select c1 from t1 union all select c1 from t2 union all select t1.c1 from t1, t2, t3 where t1.c1 = t2.c1 and t2.c1 = t3.c1);
explain basic pretty select /*+ parallel(2) */ * from (select c1 from t1 union all select c1 from t2 union all select t1.c1 from t1, t2, t3 where t1.c1 = t2.c1 and t2.c1 = t3.c1);
explain basic pretty_color select /*+ parallel(2) */ * from (select c1 from t1 union all select c1 from t2 union all select t1.c1 from t1, t2, t3 where t1.c1 = t2.c1 and t2.c1 = t3.c1);

drop table t1;
drop table t2;
drop table t3;
