--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: jingyan.kfy
# owner group: transaction
# description: foobar
####TITLE:多个事务更新同一行，查询索引表、数据表、回表
####
--disable_query_log
--source mysql_test/include/index_quick_major.inc
--real_sleep 1
--disable_warnings
drop table if exists t1;
--enable_warnings
--enable_query_log

create table t1(pk int primary key, a int, b int, c int, d int, e int);
create index i1 on t1(b,c) storing(d,e);

--disable_query_log
let $index_name = __idx_3003_i1;
--enable_query_log
--source mysql_test/include/check_all_idx_ok.inc

connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn2,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);

####CASE:多种DML操作同一行
insert into t1 values(1,1,1,1,1,1),(2,1,1,1,1,1),(3,1,1,1,1,1),(4,1,1,1,1,1);

connection conn1;
set autocommit=0;
--sorted_result
select pk, b from t1 where b between 0 and 1000;
--sorted_result
select pk, a, b from t1 where pk>0 and pk<10;
--sorted_result
select * from t1 where b>0 and b<1000;

#pk=1,2个事务均不更新
#pk=2,仅事务2更新
#pk=3~6,2个事务均更新
#pk=7，仅事务2新增
##
connection conn2;
set autocommit=0;
update t1 set a=pk+10, b=pk+10, c=pk+10, d=pk+10, e=pk+10 where pk=2;
update t1 set a=pk+10, b=pk+10, c=pk+10, d=pk+10, e=pk+10 where pk=3;
delete from t1 where pk=4;
insert into t1 values(5,1,1,1,1,1);
replace into t1 values(6,1,1,1,1,1);
replace into t1 values(7,1,1,1,1,1);
commit;
--sorted_result
select pk, b from t1 where b between 0 and 1000;
--sorted_result
select pk, a, b from t1 where pk>0 and pk<10;
--sorted_result
select * from t1 where b>0 and b<1000;

##
connection conn1;
update t1 set a=pk+100, b=pk+100, c=pk+100, d=pk+100, e=pk+100 where pk=3;
update t1 set a=pk+100, b=pk+100, c=pk+100, d=pk+100, e=pk+100 where pk=4;
update t1 set a=pk+100, b=pk+100, c=pk+100, d=pk+100, e=pk+100 where pk=5;
update t1 set a=pk+100, b=pk+100, c=pk+100, d=pk+100, e=pk+100 where pk=6;
--sorted_result
select pk, b from t1 where b between 0 and 1000;
--sorted_result
select pk, a, b from t1 where pk>0 and pk<10;
--sorted_result
select * from t1 where b>0 and b<1000;
commit;
--sorted_result
select pk, b from t1 where b between 0 and 1000;
--sorted_result
select pk, a, b from t1 where pk>0 and pk<10;
--sorted_result
select * from t1 where b>0 and b<1000;
commit;

connection conn2;
--sorted_result
select pk, b from t1 where b between 0 and 1000;
--sorted_result
select pk, a, b from t1 where pk>0 and pk<10;
--sorted_result
select * from t1 where b>0 and b<1000;
commit;
--sorted_result
select pk, b from t1 where b between 0 and 1000;
--sorted_result
select pk, a, b from t1 where pk>0 and pk<10;
--sorted_result
select * from t1 where b>0 and b<1000;
commit;

drop table t1;
