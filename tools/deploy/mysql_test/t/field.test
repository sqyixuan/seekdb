--disable_warnings
drop table if exists test;
--enable_warnings
create table test (a int, b int, c varchar(1024), d varchar(1024), e  timestamp(6) default "2012-01-01 12:00:00", f datetime(6), primary key(a, c, e));
--disable_query_log
select * from test;
insert into test values(-1, -2, 'a', 'b', '2013-11-30 11:06:00', '2013-11-29 11:06:00');
insert into test values(0, 1, 'b', 'c', '2013-11-21 11:06:01', '2013-11-29 11:06:01');
insert into test values(1, 3, 'c', 'd', '2013-12-29 11:06:02', '2013-11-29 11:06:02');
insert into test values(2, 0, 'd', 'd', '2013-11-29 11:06:03', '2013-11-29 11:06:03');
insert into test values(3, -3, 'e', 'g', '2013-10-29 11:06:04', '2013-11-29 11:06:04');
insert into test values(4, -4, 'f', 'g', '2013-12-29 11:06:05', '2013-11-29 11:06:05');
select field(a, b, c, d, e, f) from test;
show warnings;
select field(b, a, c, d, e, f) from test;
show warnings;
select field(c, a, b, d, e, f) from test;
show warnings;
select field(d, a, b, c, e, f) from test;
show warnings;
select field(e, a, b, c, d, f) from test;
show warnings;
select field(f, a, b, c, d, e) from test;
show warnings;
select field(2, a, b, c, d, e) from test;
show warnings;
select field(e, 2, b, c, d, f) from test;
show warnings;
select field(e, 2, date(2016-10-11), c, d, f) from test;
show warnings;

select * from test ORDER BY field(a, 0, 4, 5);
select * from test ORDER BY field(b, 0, 3, -4);
select * from test ORDER BY field(c, 'a', 'c', 'd');
select * from test ORDER BY field(d, 'b', 'e', 'f');
select * from test ORDER BY field(e, '2013-12-29 11:06:01', '2013-12-29 11:06:02', '2013-12-29 11:06:10');
select * from test ORDER BY field(f, '2013-11-29 11:06:01', '2013-12-29 11:06:02', '2013-11-29 11:06:05');
drop table test;

