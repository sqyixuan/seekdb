insert into tbl1 values (6,78,'tx23abc12','icagc1',-109.25,'2014-09-16 16:24:00',-13.531,1),(8,50,'vx23abc12','wcagc1',-85.85,'2014-09-10 16:20:21',93.131,1),(9,610,'ukx23abc12','pecagc1',-1.85,'2014-09-19 16:20:21',99.131,0),(10,42,'kx23abc12','ecagc1',-85.86,'2014-09-18 16:20:21',-99.131,1),(11,null,null,null,null,null,null,null);


connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn2,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);

connection conn1;
set autocommit=0;

connection conn2;
set autocommit=0;
#### =null궐싹，돤돕왕契
connection conn1;
select 1  from tbl1  where pk=null for update; 

connection conn2;
insert into  tbl1 values(100,102,'abdggc12','1agc1d',1.215,'2014-01-01 12:00:10',33.23,1);
connection conn1;
commit;
connection conn2;
commit;

update tbl1 set pk=12 where pk is null;
commit;
#### is null
connection conn1;
select  *  from tbl1  where pk is null for update; 

connection conn2;
insert into  tbl1 values(2015,104,'abdgsdgc12','as1agc1d',1.1215,'2016-01-01 12:00:10',43.123,1);
connection conn1;
commit;
connection conn2;
commit;

####in null
connection conn1;
select    *  from tbl1  where pk in (1,100,2,200,null) for update; 

connection conn2;
--error 1205,4012
update tbl1 set pk=200 where pk=100;
delete  from tbl1 where pk is null;
--error 1205,4012
update tbl1 set pk=21 where pk=2;
connection conn1;
commit;
connection conn2;
commit;


#### is not null(렷寮숩） and 랗늴법쫀
connection conn1;
select  *  from tbl1  where i5 is not null and pk>=5 and i1>500 for update; 

connection conn2;
insert into  tbl1 values(401,108,'adaadbdgsdgc12','abass1agc1d',1.6215,'2018-01-01 12:10:10',-63.123,1);
--error 1205,4012
update tbl1 set pk=29 where pk in (9,-9,-90,-100);
select * from tbl1 where pk=29 for update;
connection conn1;
commit;
connection conn2;
commit;
select * from tbl1;


#### is not null (寮숩） and 랗늴법쫀
connection conn1;
select  *  from tbl1  where pk is not null and pk in (-9,-90,-100,1,2,7,8,9) and i1>500 for update; 

connection conn2;
insert into  tbl1 values(405,108,'adaadbdgsdgc12','abass1agc1d',1.6215,'2018-01-01 12:10:10',-63.123,1);
update tbl1 set pk=30 where pk in (10,-9,-90,-100);
--error 1205,4012
update tbl1 set pk=31 where pk in (1,9,-90,-100);
select * from tbl1 where pk=30;
select * from tbl1 where pk=31;
connection conn1;
commit;
connection conn2;
commit;
select * from tbl1;

