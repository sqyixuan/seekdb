--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: link.zt
# owner group: SQL1
# tags: optimizer
# description: bug 
# pquery
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1 (v1 varchar(20), v2 varchar (20));
insert into t1 (v1, v2) values ('a', 'b');
explain basic select * from (select concat(concat(v1, '_'), v2) from (select distinct v1, v2 from t1) T) TT;
select * from (select concat(concat(v1, '_'), v2) from (select distinct v1, v2 from t1) T) TT;
drop table t1;

--disable_query_log
--disable_warnings
drop table if exists t1, t2, t3, v1;
drop view if exists t1, t2, t3, v1;
--enable_warnings

create table t1 (c1 varchar(10));
create view t2 as select 1;
create table t3(c1 int, c2 int);
insert into t1 values("11");
insert into t1 values(1), (1);


create view v1 as select cast(1 as number) c1;
--enable_query_log

# bug T11929870
--sorted_result
select * from t1 union distinct select * from t2;

# bug T12385638
select cte.c1 from (select c1 from t3 union all select c1 from t3)cte union all select t3.c1 from t3;

# bug T12912756
set @c='';
set @i=cast(1 as number);
# to be fixed: 
select * from (select @c as c1 limit 1) union select * from (select @i as c1 limit 1);

# bug T12946785
select * from v1 union distinct select * from t1;

--disable_query_log
drop table t1, t3;
drop view t2, v1;
--enable_query_log
