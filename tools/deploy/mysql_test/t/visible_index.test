--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

#owner: dachuan.sdc
#owner group: sql4
#description: test new feature of invisible index
#tags: optimizer, index 

--source mysql_test/include/index_quick_major.inc
# 新建数据库作为测试环境，以下三句勿删
--disable_warnings
drop database if exists db_index;
create database db_index;
use db_index;
--enable_warnings

##TODO:全文索引相关的case

##------------------test ddl operation--------------##
##test create table
create table t1(c1 int primary key, c2 int, c3 int, c4 varchar(16), key idx1(c1) visible, index idx2(c2) invisible, unique key idx3(c3) visible, unique index idx4(c1, c2) invisible, unique idx5(c2,c3));
#create table t2(a int primary key, b varchar(10), c int, fulltext i1(b, c) ctxcat(b));
#create table t3(a int primary key, b varchar(10), c int, fulltext i1(b, c) ctxcat(b) invisible);
sleep 1;
show index from t1;
select table_name, index_name, is_visible from  information_schema.statistics where table_name='t1' and table_schema='db_index';
create table t4(c1 int primary key, c2 int, key idx1(c2) invisible);

##test create index
create table t11(c1 int primary key, c2 int, c3 int, c4 varchar(16));
create index idx1 on t11(c2);
create unique index idx2 on t11(c2) visible;
create index idx3 on t11(c2) invisible;
show index from t11;

drop table t11;
##test alter table alter index
create table t21(c1 int primary key, c2 int, c3 int, c4 varchar(16), key(c2));
--error 1146
alter table t_not_exist alter index c2 invisible;
--error 1176
alter table t21 alter index  idx_not_exist visible;
#TODO(shuangcan): reopen this after fix drop index and alter index in one sql
--error 1176
#alter table t21 drop index c2, alter index c2 visible;
--error 1176
alter table t21 add index a(c2), alter index a visible;
--error 1176
alter table t21 rename t22, alter index a visible;

sleep 5;
show index from t21;
alter table t21 alter index c2 invisible;
sleep 1;
show index from t21;
--error 5564
alter table t21 alter index c2 invisible, alter index c2 visible;
sleep 1;
--error 5564
alter table t21 alter index c2 invisible, alter index c2 visible, alter index c2 invisible;
sleep 1;

drop table t21;
##-----------------test index selection in optimizer--------------##
connect (obsys,$OBMYSQL_MS0,root,,oceanbase,$OBMYSQL_PORT);
connection obsys;
alter system flush plan cache global;

connection default;

create table t31(c1 int primary key, c2 int, c3 int, c4 int, c5 int, key idx1(c2), unique key idx2(c2, c3, c4));
insert into t31 value (1, 4, 20, 1, 2), (2, 3, 19, 1, 2), (3, 2, 18, 1, 2), (4, 1, 17, 1, 2);
sleep 1;
show index from t31;

select c2 from t31 order by c2;
explain basic select c2 from t31;
select c2 from t31 order by c2;
select hit_count, statement from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'select c2 from t31 order by c2';

alter table t31 alter index idx1 invisible;
sleep 1;
show index from t31;
select c2 from t31;
explain basic select c2 from t31;
select hit_count, statement from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'select c2 from t31';


alter table t31 alter index idx2 invisible;
sleep 1;
show index from t31;
select c2 from t31;
explain basic select c2 from t31;
select hit_count, statement from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'select c2 from t31';

insert into t31 value (5, 0, 16, 1, 2), (6, -1,15, 1, 2);
create index t31_idx3 on t31(c2, c3);
sleep 1;
--source mysql_test/include/check_all_idx_ok.inc
show index from t31;

select c2 from t31 order by c2;
explain basic select c2 from t31;

alter table t31 alter index idx2 visible;
sleep 1;
show index from t31;
select c2 from t31 order by c2;
explain basic select c2 from t31;

alter table t31 alter index idx1 visible;
sleep 1;
show index from t31;
select c2 from t31 order by c2;
explain basic select c2 from t31;


drop table t31;
drop database db_index;
