--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: yibo.tyf
#owner group: sql1
# tags: optimizer
connect (my_obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection default;
set ob_enable_index_direct_select=1;

--disable_warnings
--disable_query_log
--source mysql_test/include/index_quick_major.inc
--real_sleep 1
--disable_warnings
drop table if exists test_table, `cb_loan_acctbal_01`;
--enable_warnings
--enable_query_log
--enable_warnings

create table test_table(id int primary key, name varchar(64), age int, description varchar(64));
create index test_index_table on test_table(age) storing(name);
create index test_index_table2 on test_table(name) storing(age);
replace into test_table (id, name, age, description) values (1,'name1',30,'rd'),(2,'name2',27,'rd'),(3,'name3',25,'rd'),(4,'name4',24,'rd');

connection my_obsys;
let $idx1 = query_get_value(select a.table_name from oceanbase.__all_virtual_table as a inner join (select * from oceanbase.__all_virtual_table where table_name='test_table' and tenant_id = (select tenant_id from oceanbase.__all_tenant where tenant_name = 'sys')) b on a.data_table_id=b.table_id order by a.table_id asc, table_name, 1);
let $idx2 = query_get_value(select a.table_name from oceanbase.__all_virtual_table as a inner join (select * from oceanbase.__all_virtual_table where table_name='test_table' and tenant_id = (select tenant_id from oceanbase.__all_tenant where tenant_name = 'sys')) b on a.data_table_id=b.table_id order by a.table_id asc, table_name, 2);
connection default;

--source mysql_test/include/check_all_idx_ok.inc


select * from test_table;
--disable_query_log
eval select * from $idx1;
--enable_query_log


--let $count = 30
while($count < 100)
{
  --let $stmt=insert into test_table(id, name, age, description) values ($count, 'name33', 330, 'rd2')
  eval $stmt;
  inc $count;
}

--disable_query_log
eval select * from $idx1;
eval select * from $idx2;
--enable_query_log


--let $count = 30
while($count < 100)
{
  --let $stmt=update test_table set name = 'name44', age = 440 where id = $count
  eval $stmt;
  inc $count;
}

--disable_query_log
eval select * from $idx1;
eval select * from $idx2;
--enable_query_log


--let $count = 30
while($count < 100)
{
  --let $stmt=delete from test_table where id = $count
  eval $stmt;
  inc $count;
}

--disable_query_log
eval select * from $idx1;
eval select * from $idx2;
--enable_query_log

drop table test_table;

CREATE TABLE `cb_loan_acctbal_01` ( `acctnbr` varchar(34) NOT NULL COMMENT '账号',  `balcatcd` varchar(4) NOT NULL COMMENT '余额类别代码',  `baltypcd` varchar(4) NOT NULL COMMENT '余额类型代码',  `preeffdate` date DEFAULT NULL COMMENT '上次生效日期',  `preamt` decimal(21, 5) DEFAULT '0.00000' COMMENT '上次金额',  `effdate` date NOT NULL COMMENT '余额生效日期',  `amt` decimal(21, 5) NOT NULL DEFAULT '0.00000' COMMENT '账户金额',  `mainttellerid` varchar(20) DEFAULT NULL COMMENT '维护柜员',  `maintbranchnbr` varchar(12) DEFAULT NULL COMMENT '维护机构',  `gmt_create` datetime(6) NOT NULL DEFAULT CURRENT_TIMESTAMP(6) COMMENT '维护日期',  `gmt_modified` datetime(6) NOT NULL DEFAULT CURRENT_TIMESTAMP(6) COMMENT '维护时间',  `oddfreqnextduedate` date DEFAULT NULL COMMENT '不规则还款频率的下次应收日期',  `nextrcvbnbr` bigint(20) DEFAULT NULL COMMENT '该账号的下个应收编号',  `nextratechangedate` date DEFAULT NULL COMMENT '下个利率变更日期',  PRIMARY KEY (`balcatcd`, `baltypcd`, `acctnbr`),  KEY `idx_acctbal_balcatcd_baltypcd_preeffdate` (`balcatcd`, `baltypcd`, `preeffdate`),  KEY `idx_acctbal_balcatcd_baltypcd_effdate` (`balcatcd`, `baltypcd`, `effdate`) );

--real_sleep 3

explain select /*+index(a idx_acctbal_balcatcd_baltypcd_effdate)*/ * from cb_loan_acctbal_01 a where (a.balcatcd, a.baltypcd) in (('NOTE', 'BAL'), ('NOTE', 'GINT'), ('ODP', 'GINT'), ('RCVB', 'INT'), ('RCVB', 'ODPI'))    and a.preeffdate <= '2017-10-16'    and '2017-10-16' < a.effdate;
set ob_enable_index_direct_select=0;
drop table if exists test_table, `cb_loan_acctbal_01`;
