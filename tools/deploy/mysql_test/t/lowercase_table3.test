--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

#owner: linlin.xll
#owner group: SQL1
#description:
#tags: inner_table
#
# Test of force of lower-case-table-names=0
# (User has case insensitive file system and wants to preserve case of
# table names)
#

connect (conn0,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn0;

--disable_warnings
#drop tenant if exists lower_case force;
#drop resource pool if exists test_resource_pool1;
#drop resource unit if exists test_resource_unit1;
--enable_warnings

#let $zone_count = 1;
#let $zone_name=query_get_value(select zone from oceanbase.__all_zone where zone != '' limit 1, zone, 1);
#--disable_query_log
#eval create resource unit test_resource_unit1 max_cpu 1, memory_size '2G';

#eval create resource pool test_resource_pool1 unit = 'test_resource_unit1', unit_num = 1, zone_list = ('$zone_name');
#eval CREATE TENANT lower_case REPLICA_NUM = $zone_count, RESOURCE_POOL_LIST = ('test_resource_pool1') set lower_case_table_names = 0, ob_tcp_invited_nodes='%';
--enable_query_log
--source mysql_test/include/check_tenant_sync.inc

##time to sync schema
let $__tenant_name__ = 'sys';
--source mysql_test/include/get_tenant_server.inc
connect (conn1,$TE_SERVER_IP,root,,*NO-ONE*,$TE_SERVER_PORT);
connection conn1;

show variables like 'lower_case_table_names';
#
# by using --lower-case-table-names=0
CREATE DATABASE if not exists test;
use test;
--disable_warnings
DROP TABLE IF EXISTS t1;
--enable_warnings
CREATE TABLE t1 (a INT);

#--error 1146
#SELECT * FROM T1;
SELECT * FROM t1;
DROP TABLE t1;
drop database test;
create database test;

connection conn0;
--disable_warnings
#drop tenant if exists lower_case force;
#drop resource pool if exists test_resource_pool1;
#drop resource unit if exists test_resource_unit1;
--enable_warnings
# End of 4.1 tests
