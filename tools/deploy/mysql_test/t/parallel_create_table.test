--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: bin.lb
# owner group: SQL2
# tags: ddl
# description:
#
--source mysql_test/include/index_quick_major.inc

--disable_warnings
drop table if exists t1,t2;
--enable_warnings


connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
send create table t1(pk int primary key,c1 int);

connect (conn2,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
send create table t2(pk int primary key,c1 int);



connection conn1;
reap;
connection conn2;
reap;


connection conn1;
send alter table t1 add column c2 int default 10;
connection conn2;
send alter table t1 add column c3 varchar(20) default 'english';

connection conn1;
reap;
connection conn2;
reap;


connection conn1;
send drop table t1;
connection conn2;
send drop table t2;


connection conn1;
reap;
connection conn2;
reap;
####多次并发创建/删除表
--disable_query_log
--let $cnt=200
while($cnt)
{

connection conn1;
send     create table t1(pk int primary key,c1 int,c2 varchar(20));
connection conn2;
send     create table t2(pk int primary key,c1 int,c2 varchar(20));

connection conn1;
reap;
connection conn2;
reap;

connection conn1;
send  create index idx1 on t1(c2);
connection conn2;
send  create index idx2 on t2(c1);

connection conn1;
reap;
connection conn2;
reap;

connection conn1;
send drop table t1;
connection conn2;
send drop table t2;


connection conn1;
reap;
connection conn2;
reap;

--dec  $cnt
}

--enable_query_log
sleep 5;
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc

####未完待续(并发创建索引，并发删除索引，并发删除表；一个在建表，一个在删表）


