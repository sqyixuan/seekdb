# 测试前缀索引show create table显示
--disable_warnings
drop table if exists jx_prefix_t1;
drop table if exists jx_prefix_t2;
drop table if exists jx_prefix_t3;
drop table if exists jx_prefix_t4;
--enable_warnings
create table jx_prefix_t1(c1 varchar(1000), index idx(c1(16)));
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table jx_prefix_t1;
let $create_stmt = query_get_value(show create table jx_prefix_t1, 'Create Table', 1);
#--disable_query_log
drop table jx_prefix_t1;
--source mysql_test/include/show_create_table_old_version_replica2.inc
eval $create_stmt;
#--enable_query_log
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table jx_prefix_t1;

create table jx_prefix_t2(c1 varchar(1000), unique index idx(c1(16)));
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table jx_prefix_t2;
let $create_stmt = query_get_value(show create table jx_prefix_t2, 'Create Table', 1);
#--disable_query_log
drop table jx_prefix_t2;
--source mysql_test/include/show_create_table_old_version_replica2.inc
eval $create_stmt;
#--enable_query_log
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table jx_prefix_t2;

create table jx_prefix_t3(buildpack_id int, c2 varchar(512), index idx(`buildpack_id`, `c2`(255)));
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table jx_prefix_t3;
let $create_stmt = query_get_value(show create table jx_prefix_t3, 'Create Table', 1);
#--disable_query_log
drop table jx_prefix_t3;
--source mysql_test/include/show_create_table_old_version_replica2.inc
eval $create_stmt;
#--enable_query_log
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table jx_prefix_t3;

create table jx_prefix_t4(buildpack_id int, c2 varchar(512), c3 varchar(512), index idx(c2(255), `buildpack_id`, `c3`(255)));
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table jx_prefix_t4;
let $create_stmt = query_get_value(show create table jx_prefix_t4, 'Create Table', 1);
