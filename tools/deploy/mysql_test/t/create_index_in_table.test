###写成unique key
--disable_warnings
DROP TABLE IF EXISTS table1_int;
--enable_warnings
CREATE TABLE table1_int (
col_int int,
col_bool bool,
pk int,
col_bool_unique_key bool,
col_int_unique_key int,
col_varchar_500 varchar(500),
col_char_20 char(20),
col_varchar_500_unique_key varchar(500),
col_timestamp timestamp NULL DEFAULT NULL,
col_char_20_unique_key char(20),
col_timestamp_unique_key timestamp NULL DEFAULT NULL,
/*Indices*/
primary key (pk),
unique key idx3(col_bool_unique_key ),
unique key idx1(col_int_unique_key ),
unique key idx9(col_varchar_500_unique_key ),
unique key idx7(col_char_20_unique_key ),
unique key idx5(col_timestamp_unique_key )) ;
