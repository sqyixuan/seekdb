#部分字段是索引，部分不是
--disable_warnings
DROP TABLE IF EXISTS table1_int;
--enable_warnings
CREATE TABLE table1_int (
col_int int,
col_bool bool,
pk int,
col_bool_index bool,
col_int_index int,
col_varchar_500 varchar(500),
col_char_20 char(20),
col_varchar_500_index varchar(500),
col_timestamp timestamp NULL DEFAULT NULL,
col_char_20_index char(20),
col_timestamp_index timestamp NULL DEFAULT NULL,
/*Indices*/
primary key (pk),
index idx3(col_bool_index ),
index idx1(col_int_index ),
index idx9(col_varchar_500_index ),
index idx7(col_char_20_index ),
index idx5(col_timestamp_index )) ;
--error 1264
INSERT INTO table1_int VALUES  (NULL, 1, 1, 31682, 9, 'there', 'fnyxowgqqxerm', NULL, '2000-12-25 08:41:43', 'would', '2000-03-11 21:51:55.051320') ;
alter table table1_int drop col_bool_index;
####use key;
--disable_warnings
DROP TABLE IF EXISTS table1_int;
--enable_warnings
CREATE TABLE table1_int (
col_int int,
col_bool bool,
pk int,
col_bool_key bool,
col_int_key int,
col_varchar_500 varchar(500),
col_char_20 char(20),
col_varchar_500_key varchar(500),
col_timestamp timestamp NULL DEFAULT NULL,
col_char_20_key char(20),
col_timestamp_key timestamp NULL DEFAULT NULL,
/*Indices*/
primary key (pk),
key idx3(col_bool_key ),
key idx1(col_int_key ),
key idx9(col_varchar_500_key ),
key idx7(col_char_20_key ),
key idx5(col_timestamp_key )) ;
INSERT INTO table1_int VALUES  (NULL, 1, 1, 0, 9, 'there', 'fnyxowgqqxerm', NULL, '2000-12-25 08:41:43', 'would', '2000-03-11 21:51:55.051320') ;
select * from table1_int;
##验证能否走到索引
--replace_regex /Plan signature: [0-9]*/Plan signature/
--disable_result_log
explain select * from table1_int where  col_bool_key='1';
--enable_result_log

###创建唯一索引
DROP TABLE /*! IF EXISTS*/ table1_int;
CREATE TABLE table1_int (
col_int int,
col_bool bool,
pk int,
col_bool_unique_index bool,
col_int_unique_index int,
col_varchar_500 varchar(500),
col_char_20 char(20),
col_varchar_500_unique_index varchar(500),
col_timestamp timestamp NULL DEFAULT NULL,
col_char_20_unique_index char(20),
col_timestamp_unique_index timestamp NULL DEFAULT NULL,
/*Indices*/
primary key (pk),
unique index idx3(col_bool_unique_index ),
unique index idx1(col_int_unique_index ),
unique index idx9(col_varchar_500_unique_index ),
unique index idx7(col_char_20_unique_index ),
unique index idx5(col_timestamp_unique_index )) ;
INSERT INTO table1_int VALUES  (NULL, 1, 1, 1, 9, 'there', 'fnyxowgqqxerm', NULL, '2000-12-25 08:41:43', 'would', '2000-03-11 21:51:55.051320') ;
select * from  table1_int;
--replace_column 3 indexname
show index from table1_int;
###全部为唯一索引字段
DROP TABLE /*! IF EXISTS*/ table1_int;
CREATE TABLE table1_int (
pk int,
col_bool_unique_index bool,
col_int_unique_index int,
col_char_20_unique_index char(20),
col_timestamp_unique_index timestamp NULL DEFAULT NULL,
col_varchar_500_unique_index varchar(500),
/*Indices*/
primary key (pk),
unique index idx1(col_bool_unique_index ),
unique index idx0(col_int_unique_index ),
unique index idx3(col_char_20_unique_index ),
unique index idx2(col_timestamp_unique_index ),
unique index idx4(col_varchar_500_unique_index )) ;
INSERT INTO table1_int VALUES  (1, 1, -22478848, 'ofmpdxvhqvfnyxowgqq', '2003-06-28 20:38:02.013113', '') ;
select * from  table1_int;
 --replace_column 3 indexname
