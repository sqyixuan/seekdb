###表中每个字段都建了多字段索引
--disable_warnings
DROP TABLE IF EXISTS table1_char_20_1;
--enable_warnings
CREATE TABLE table1_char_20_1 (
pk char(20),
col_bool_index bool,
col_int_index int,
col_char_20_index char(20),
col_timestamp_index timestamp NULL DEFAULT NULL,
col_varchar_500_index varchar(500),
/*Indices*/
primary key (pk),
index idx1(col_bool_index,col_int_index ),
index idx0(col_int_index ,col_char_20_index),
index idx3(col_char_20_index ,col_timestamp_index,pk),
index idx2(col_timestamp_index,pk ),
index idx4(pk,col_varchar_500_index )) ;
INSERT INTO table1_char_20_1 VALUES  (1, 1, -22478848, 'ofmpdxvhqvfnyxowgqq', '2003-06-28 20:38:02.013113', '') ;
--disable_warnings
DROP TABLE IF EXISTS table1_int_1;
--enable_warnings
CREATE TABLE table1_int_1 (
col_char_20_index char(20),
col_bool_index bool,
col_varchar_500_index varchar(500),
pk int,
col_int_index int,
col_timestamp_index timestamp NULL DEFAULT NULL,
/*Indices*/
index idx3(col_char_20_index ,pk),
index idx1(col_bool_index ,col_char_20_index),
index idx4(col_varchar_500_index ,pk),
primary key (col_char_20_index,col_varchar_500_index),
index idx0(col_int_index ,col_timestamp_index,pk),
index idx2(col_timestamp_index,col_varchar_500_index,pk )) ;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table table1_int_1;
INSERT INTO table1_int_1 VALUES  ('', 0, 'jof', 1, -9588, '2004-10-20 07:20:19') ;
select * from table1_int_1;
select * from table1_int_1 where col_varchar_500_index='jof'; 

###索引，唯一索引同时存在,同时加上default和null属性；
--disable_warnings
DROP TABLE IF EXISTS table1_int;
--enable_warnings
CREATE TABLE table1_int (
col_int_not_null_key int not null,
col_int int,
col_timestamp_unique_index timestamp NULL DEFAULT NULL,
col_timestamp_index timestamp NULL DEFAULT NULL,
col_int_index int,
col_char_20_unique_key char(20),
col_int_not_null_unique_index int not null,
col_int_not_null_unique_key int not null,
col_int_not_null int not null,
col_char_20_unique_index char(20),
pk int,
col_char_20 char(20),
col_char_20_not_null_unique_index char(20) not null,
col_timestamp_not_null_key timestamp  NULL DEFAULT NULL,
col_char_20_not_null char(20) not null,
col_timestamp_not_null_unique_key timestamp NULL DEFAULT NULL,
col_char_20_not_null_key char(20) not null,
col_int_key int,
col_int_unique_key int,
col_timestamp_not_null timestamp NULL DEFAULT NULL,
col_timestamp_not_null_index timestamp  NULL DEFAULT NULL,
col_timestamp_key timestamp NULL DEFAULT NULL,
col_timestamp_not_null_unique_index timestamp NULL DEFAULT NULL,
col_int_not_null_index int not null,
col_char_20_key char(20),
col_char_20_index char(20),
col_char_20_not_null_unique_key char(20) not null,
col_int_unique_index int,
col_timestamp_unique_key timestamp NULL DEFAULT NULL,
col_char_20_not_null_index char(20) not null,
col_timestamp timestamp NULL DEFAULT NULL,
/*Indices*/
key idx6(col_int_not_null_key ),
unique index idx13(col_timestamp_unique_index ),
index idx12(col_timestamp_index ),
index idx2(col_int_index ),
unique key idx24(col_char_20_unique_key ),
unique index idx8(col_int_not_null_unique_index ),
unique key idx9(col_int_not_null_unique_key ),
unique index idx23(col_char_20_unique_index ),
primary key (pk),
unique index idx28(col_char_20_not_null_unique_index ),
key idx16(col_timestamp_not_null_key ),
unique key idx19(col_timestamp_not_null_unique_key ),
key idx26(col_char_20_not_null_key ),
key idx1(col_int_key ),
unique key idx4(col_int_unique_key ),
index idx17(col_timestamp_not_null_index ),
key idx11(col_timestamp_key ),
unique index idx18(col_timestamp_not_null_unique_index ),
index idx7(col_int_not_null_index ),
key idx21(col_char_20_key ),
index idx22(col_char_20_index ),
unique key idx29(col_char_20_not_null_unique_key ),
unique index idx3(col_int_unique_index ),
unique key idx14(col_timestamp_unique_key ),
index idx27(col_char_20_not_null_index )) ;
