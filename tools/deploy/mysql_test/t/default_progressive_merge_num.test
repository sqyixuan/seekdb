--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner : zhenjiang.xzj
#owner group : storage
#tags: ddl

--disable_warnings
drop table if exists t1_modify_prog;
drop table if exists t2_modify_prog;
drop table if exists t3_modify_prog;
--enable_warnings
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
alter system set default_progressive_merge_num = 0 tenant = 'sys';
sleep 5;
disconnect obsys;
connection default;
create table t1_modify_prog (c1 int primary key);
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
alter system set default_progressive_merge_num = 5 tenant = 'sys';
sleep 5;
disconnect obsys;
connection default;
create table t2_modify_prog (c1 int primary key);
create table t3_modify_prog(c1 int primary key) progressive_merge_num = 10;
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;

let $t1_pm_num = query_get_value(select progressive_merge_num from oceanbase.__all_virtual_table where table_name = 't1_modify_prog', progressive_merge_num, 1);
echo $t1_pm_num;
let $t2_pm_num = query_get_value(select progressive_merge_num from oceanbase.__all_virtual_table where table_name = 't2_modify_prog', progressive_merge_num, 1);
echo $t2_pm_num;
let $t3_pm_num = query_get_value(select progressive_merge_num from oceanbase.__all_virtual_table where table_name = 't3_modify_prog', progressive_merge_num, 1);
echo $t3_pm_num;

alter system set default_progressive_merge_num = 0 tenant = 'sys';

disconnect obsys;
connection default;
drop table t1_modify_prog;
drop table t2_modify_prog;
drop table t3_modify_prog;
