--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: bin.lb
# owner group: SQL3
# description:
#
####
--disable_query_log
--source mysql_test/include/index_quick_major.inc
--real_sleep 1
--disable_warnings
drop table if exists t1;
--enable_warnings
--enable_query_log

#drop table if exist t1
create table t1(c1 int primary key, c2 varchar(1024), c3 int);
create index i1 on t1(c2) storing(c3);
--disable_query_log
let $i=1000;
while($i>0)
{
    eval insert into t1 values($i, 'a', $i);
    dec $i;
}
--enable_query_log

--source mysql_test/include/check_all_idx_ok.inc

select /*+ index(t1 i1) */ * from t1 where c2='a' limit 5;
select /*+ index(t1 primary) */ * from t1 where c1>0 limit 5;

create index i2 on t1(c2) storing(c3);
--source mysql_test/include/check_all_idx_ok.inc

--replace_column 3 indexname
show index from t1;
select /*+ index(t1 i1) */ * from t1 where c2='a' limit 5;
select /*+ index(t1 i2) */ * from t1 where c2='a' limit 5;
select /*+ index(t1 primary) */ * from t1 where c1>0 limit 5;

drop table t1;


