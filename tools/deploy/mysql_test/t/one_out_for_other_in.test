--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: bin.lb
# owner group: SQL2
# tags: dml
# description:
#
#####添加case：在同一行的计算过程中，不能引用本行的计算结果作为另一个表达式的输入
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (
c1 INT
, v1 VARCHAR(65536)
, v2 VARCHAR(65536)
, PRIMARY KEY(c1)
);
insert into t1 values(1,'abc','123');
insert into t1 values(2,'def','456');
select * from t1;
--sorted_result
select c1,v1 dc from t1 group by dc || 'kaka';
--sorted_result
select c1,v1 dc from t1 group by concat(dc,'kaka');
update t1 set v1=repeat(v1, 2), v2=repeat(v1, 2);
select * from t1;
--error 1054
select v1, v1 DD, DD||'kaka' KK, KK || 'haha' from t1;
--error 1054
select v1, v1 DD, concat(DD,'kaka') KK, concat(KK,'haha') from t1;
