# owner: yibo.tyf
# owner group: SQL
# description: verify table option: ori_schema_version
#
--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn2,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);

--let $count=1
while($count < 50)
{

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1(c1 int primary key, c2 int);
insert into t1 values(5,5);
connection conn1;
begin;
send select * from t1 where c1=1 when row_count(insert into t1 values(2,2),(1,1))=2;
--real_sleep 1
connection conn2;
begin;
send select * from t1 where c1=2 or c1=5 when row_count(replace into t1 values(1,10),(3,3),(4,4))=3;
connection conn1;
reap;
commit;
connection conn2;
reap;
commit;
inc $count;
}
