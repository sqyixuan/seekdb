# Get value must same with stored value.
# 
#
# owner: dachuan.sdc
# owner group: SQL2
# description:
# tags: datatype
--disable_query_log
--source mysql_test/include/index_quick_major.inc
--enable_query_log

--disable_warnings
drop table if exists case_insensitive_get;
--enable_warnings
create table case_insensitive_get (pk varchar(20) primary key);
insert into case_insensitive_get values('ABC');
select * from case_insensitive_get where pk='abc';
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
select * from case_insensitive_get where pk='abc';
