--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: zhanyue.zzy
#owner group: sql1

####test:one trx can not read dirty data;when commit,another trx can read
connect (conn0,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn2,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);

connection conn0;
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(pk int primary key, c1 int);
create index idx on t1(c1);
insert into t1 values(6,6),(7,7),(8,8);
--source mysql_test/include/check_all_idx_ok.inc

connection conn1;
set autocommit=0;

connection conn2;
set autocommit=0;

connection conn1;
insert into t1 values(1,1);

connection conn2;
insert into t1 values(2,2);
--error 1205,4012
replace into t1 values(1,2);
select * from t1;
update t1 set c1=c1+1 where pk=1;
update t1 set c1=c1+1 where pk in (1,3,5);
update t1 set c1=c1+1 where pk>=1 and pk<=5 ;
select * from t1;
--error 1062
insert into t1 values(2,2);
update t1 set c1=c1+2 where pk=2;
select * from t1;
update t1 set c1=c1+2 where c1 in (1,3,5);
select * from t1;
update t1 set c1=c1+2;
select * from t1;
delete from t1 where c1=1;
delete from t1 where pk=1;

connection conn1;
delete from t1 where pk=1;
--error 1205,4012
insert into t1 values(2,2);
insert into t1 values(3,3);
update t1 set pk=4 where pk<=5;
select * from t1;
select * from t1 where pk in (1,2,3,4,5);


connection conn2;
update t1 set c1=c1+1 where pk=1;
update t1 set c1=c1+1 where pk=3;
update t1 set c1=c1+1 where pk=4;
update t1 set c1=c1+1 where pk<5;
update t1 set c1=c1+1 where pk in (1,3,5);
select * from t1;
--error 1205,4012
replace into t1 values(3,3),(1,1);
select * from t1 where pk in (1,2,3,4,5);


connection conn1;
select * from t1;
select * from t1 where pk in (1,2,3,4,5);
commit;
connection conn2;
select * from t1;
select * from t1 where pk in (1,2,3,4,5);
update t1 set c1=c1+1 where pk in (1,3,4,5);
select * from t1 where pk in (1,2,3,4,5);
commit;

#####test:rollback test
connection conn1;
update t1 set pk=5 where pk=4;

connection conn2;
--error 1205,4012
update t1 set pk=5 where pk=4;
--error 1205,4012
update t1 set pk=5 where c1=4;


connection conn1;
rollback;

connection conn2;
select * from t1 where pk in (1,2,3,4,5);
select * from t1 ;
update t1 set pk=5 where pk=4;
select * from t1 where pk in (4,5) ;
commit;

select * from t1 ;
drop table t1;





