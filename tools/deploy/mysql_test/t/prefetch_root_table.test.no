--disable_warnings
drop table if exists prefetch_roottable_table;
--enable_warnings

create table prefetch_roottable_table(pk int primary key, extra int) replica_num=2;
let $table_id = query_get_value(select table_id from oceanbase.__all_virtual_table where table_name='prefetch_roottable_table', table_id, 1);
let $meta_table_name = query_get_value(select '__' '$table_id' '__meta__'  v, v, 1);

--disable_query_log
echo case 1: remove all tablet infos in user meta table of prefetch_roottable_table;
echo delete tablet infos;
eval delete from $meta_table_name;
eval select count(*) from $meta_table_name;
echo iterate root table start;
--disable_result_log
eval select * from __table_stat;
--enable_result_log
echo iterate root table finish;
eval select tablet_count from __table_stat where table_id=$table_id;
--disable_query_log
drop table prefetch_roottable_table;
