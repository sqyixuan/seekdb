--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: link.zt
#owner group: sql1

# read-only trx
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(pk varchar(20) primary key, sc int, sex varchar(2));
insert into t1 values('jun',90,'m'),('yu',90,'f'),('yang',90,'f'),('yi',90,'m'),('xuan',90,'f'),('?',50,'m');

connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
set autocommit=0;
connect (conn2,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
set autocommit=0;
connect (conn3,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
set autocommit=0;

connection conn1;
select sum(sc) as total from t1;

connection conn2;
update t1 set sc=90 where pk='?';

connection conn1;
select sum(sc) as total from t1 ;
--sorted_result
select avg(sc) as average from t1 group by sex;

connection conn2;
insert into  t1 values('v1',0,'m');
replace into  t1 values('v2',0,'f');
delete from t1 where pk='?';
update t1 set sc=sc/2 where pk='?';

connection conn1;
--sorted_result
select avg(sc) as average from t1 group by sex;
commit;

connection conn2;
commit;

connection conn1;
select * from t1;
select sum(sc) as total from t1;
--sorted_result
select avg(sc) as average from t1 group by sex;
commit;


drop table t1;
