--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: dachuan.sdc
#owner group: sql
#description:

--disable_warnings
drop database if exists test1;
create database test1;
use test1;
create table t1(c1 int);
create user nijia;
--enable_warnings

grant update on test1.t1 to nijia;
grant update on TEST1.t1 to nijia;

grant update on test1.t1 to nijia;
grant update on test1.T1 to nijia;

drop database if exists test1;
