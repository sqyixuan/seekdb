--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#### owner: yuchen.wyc
#### owner group: sql3
#### description: year
#####增加abs的case；
####abs 表达式
--disable_warnings
drop table if exists sb;
set @@time_zone = '+8:00';
select year(NULL);
select year("2010-01-01");
select year("2010-01-01 11:11:11");
select year("abc");
select year(1024);
select year(20240101);
select year(20240101112233);
select year(cast('2006-04-22 03:29:33' as datetime));
select year(cast('2006-04-22' as datetime));
set @@time_zone = '-2:00';
create table sb(a datetime, b timestamp);
insert into sb values("2010-12-31 23:59:59", "2010-12-31 23:59:59");
set @@time_zone = '+11:00';
select year(a) from sb;
select year(b) from sb;
set @@time_zone = '-6:00';
select year(a) from sb;
select year(b) from sb;
set @@time_zone = '+8:00';
insert into sb values("2010-12-31 23:59:59", "2010-12-31 23:59:59");
set @@time_zone = '+8:00';
select year(a) from sb;
select year(b) from sb;
set @@time_zone = '-11:00';
select year(a) from sb;
select year(b) from sb;
set @@time_zone = '+11:00';
select year(a) from sb;
select year(b) from sb;
## restore time zone
set @@time_zone = '+8:00';
drop table sb;
set @@sql_mode = '';
create table sb(a year);
insert into sb values(year("abc"));
insert into sb values(year("2010-01-01 11:11:11"));
insert into sb values(year(NULL));
insert into sb values(year(2014));
select * from sb;
drop table sb;


