--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: link.zt
#owner group: sql1

#--disable_abort_on_error
--disable_warnings
sleep 5;
drop database if exists db1;
drop database if exists alias;
create database db1 CHARACTER set 'utf8' ;
create database alias;
use db1;
create table db1t1(c1 int primary key, c2 int);
insert into db1t1 values(1,2);
drop database db1;
--error 1046
select * from db1t1;
--error 1049
use db1;
--error 1046
select * from db1t1;
create database db1;
use db1;
create table db1t1(c1 int primary key, c2 int);
select * from db1t1;

use alias;
# should drop nothing
--disable_warnings
DROP TABLE IF EXISTS a1,a2;
--enable_warnings

--enable_warnings
create table a1(rowkey_suffix int primary key, price int);
#--real_sleep 1
insert into a1 (rowkey_suffix, price) values (5, 1000);
insert into a1 (rowkey_suffix, price) values (6, 1001);
insert into a1 (rowkey_suffix, price) values (7, 1002);
insert into a1 (rowkey_suffix, price) values (8, 1003);
#--real_sleep 1
create table a2(rowkey_suffix2 int primary key, price int, count int);
#--real_sleep 1
insert into a2 (rowkey_suffix2, price, count) values (8, 1003, 4);
insert into a2 (rowkey_suffix2, price, count) values (6, 1002, 1);
insert into a2 (rowkey_suffix2, price, count) values (7, 1005, 2);
insert into a2 (rowkey_suffix2, price, count) values (5, 1001, 3);
--disable_warnings
drop database if exists namespace;
--enable_warnings
create database namespace;
use namespace;
#跨database访问
select price from alias.a1;
select a1.price from alias.a1;
#--error 1064
select .a1.price from alias.a1;
insert into alias.a1 (rowkey_suffix, price) values(1, 1);
insert into alias.a1 (rowkey_suffix, price) values(2, -1);
update alias.a1 set price=price+1 where rowkey_suffix>0;
delete from alias.a1 where price = 0;

use alias;
#ambigous
--error 1052
select rowkey_suffix, a2.price as rowkey_suffix from a1, a2 order by rowkey_suffix;
--error 1052
select rowkey_suffix, a2.price as rowkey_suffix from a1, a2 group by rowkey_suffix;
--error 1054
select rowkey_suffix, a2.price as cost from a1, a2 where cost > 0;
#real column
select rowkey_suffix, a2.price as rowkey_suffix from a1, a2 where rowkey_suffix > 0 order by 1, 2;
select a1.price, a2.price as rowkey_suffix from a1,a2 where rowkey_suffix > 6 order by 1, 2;
--disable_warnings
select a1.price, a2.price as rowkey_suffix from a1,a2 group by rowkey_suffix order by 1, 2;
--enable_warnings
#alias column
select a2.price as rowkey_suffix from a1,a2 order by rowkey_suffix desc;

##clear
drop database namespace;
drop database alias;
drop database db1;
