#### owner: bin.lb
#### group: storage2
#### tags: meta
#### description: test ob_sql_work_area_percentage system variable work

connect (sysc,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection sysc;
alter system set enable_sql_operator_dump = 'false';
let $zone_name=query_get_value(select zone from oceanbase.__all_zone where zone != '' limit 1, zone, 1);
create resource unit test_unit max_cpu 4, memory_size '2G';
--disable_query_log
eval create resource pool test_pool unit_num = 1, zone_list=('$zone_name'), unit = 'test_unit';
--enable_query_log
create tenant test_tenant resource_pool_list=('test_pool') set ob_tcp_invited_nodes='%';
--source mysql_test/include/check_tenant_sync.inc

let $__tenant_name__ = 'test_tenant';
--source mysql_test/include/get_tenant_server.inc
connect (con1,$TE_SERVER_IP, root@test_tenant,,*NO-ONE*,$TE_SERVER_PORT);
connection con1;
set ob_query_timeout = 100000000;

use test;
create table test_table (pk int, value int, str_val varchar(8192));
insert into test_table (pk, value, str_val) values (1, 2, 'xx');
insert into test_table (pk, value, str_val) values (2, 3, 'xx');
select * from test_table order by value desc;

let $cnt = 100;
let $i = 0;
let $str = 'aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa';

while ($i < $cnt)
{
  eval insert into test_table (pk, value, str_val) values ($i, $i, $str);
  inc $i;
}

connection con1;
set global ob_sql_work_area_percentage = 10;
sleep 15;
use test;
--error 4013
select a.str_val from test_table a, test_table b, test_table c order by a.str_val limit 800000,1;

set global ob_sql_work_area_percentage = 50;
sleep 15;
select a.str_val from test_table a, test_table b, test_table c order by a.str_val limit 800000,1;

connection sysc;
drop tenant test_tenant force;
drop resource pool test_pool;
drop resource unit test_unit;

alter system set enable_sql_operator_dump = 'true';
