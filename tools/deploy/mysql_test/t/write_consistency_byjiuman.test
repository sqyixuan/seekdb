--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: link.zt
#owner group: sql1

--disable_warnings
drop table if exists accounts;
--enable_warnings


create table accounts
(
   acc int primary key,
   amount int,
   pending int,
   cleared timestamp(6) default '2014-10-13 14:00:00' NULL
);

insert into accounts values(1,10,-2,NULL);
insert into accounts values(2,0,2,NULL);
insert into accounts values(3,0,0,timestamp'2014-10-13 14:00:00');


connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn2,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);

connection conn1;

set autocommit=0;
update accounts set pending = pending - 1, cleared = null where acc = 1;
update accounts set pending = pending + 1, cleared = null where acc = 3;
select * from accounts;

connection conn2;
set autocommit=0;
set session ob_query_timeout=500000000;
send update accounts set amount = amount + pending, pending = 0, cleared = timestamp'2014-10-13 14:20:00' where cleared is null;

connection conn1;
sleep 3;
commit;


connection conn2;
reap;
select * from accounts;
commit;


