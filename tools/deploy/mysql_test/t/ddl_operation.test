--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: bin.lb
# owner group: SQL2
# tags: ddl
# description:
#
--disable_warnings
set @@recyclebin = off;
set @@ob_enable_truncate_flashback = off;
drop database if exists db_dp;
drop tablegroup if exists tg;
--enable_warnings
create database db_dp;
use db_dp;

--source mysql_test/include/check_all_idx_ok.inc

connect (jx_obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection jx_obsys;
let $last_version = query_get_value(select schema_version from oceanbase.__all_virtual_ddl_operation order by schema_version desc limit 1, schema_version, 1);
connection default;
let $tid = query_get_value(select effective_tenant_id() x, x, 1);
--disable_warnings
drop database if exists db;
--enable_warnings
create database db;
use db;
#alter tenant sys set primary_zone='z1';
#create tablegroup tg;
create table t1(c1 int);
create table t2(c1 int primary key, c2 varchar(20) default 'default', c3 int, index(c2), unique index uidx(c3) comment 'index' block_size 16384)comment = 'table' block_size = 16384;
#alter tablegroup tg add table t1, t2;
alter table t1 add column c2 int;
create index idx on t1(c1);
let $index_name = idx;
--source mysql_test/include/check_idx_status.inc
drop index idx on t1;
###view
create view v as select * from t1;
create view v2 as select * from t2;
drop view v, v2;

alter table t1 rename to t11, comment = 'xxxxx';
rename table t2 to t21, t21 to t22, t22 to t23;
create table t3 like t23;
truncate table t23;
drop table t11, t23, t3;
#drop tablegroup tg;
drop database db;

connection jx_obsys;
--disable_query_log
--replace_regex /schema_version > [0-9]*/schema_version > last_version/g
eval select operation_type, ddl_stmt_str from oceanbase.__all_virtual_ddl_operation where schema_version > $last_version and ddl_stmt_str not like '%ob_all_proxy%' and database_id = (select max(database_id) from oceanbase.__all_virtual_database_history where database_name='db' and tenant_id = $tid order by schema_version desc limit 1); 
--enable_query_log
connection default;

# 不同session的ddl操作
--disable_warnings
drop database if exists db1;
--enable_warnings
create database db1;
use db1;
connect (conn1,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
set @@recyclebin = off;
use db1;
connect (conn2,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
set @@recyclebin = off;
use db1;
connect (conn3,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
set @@recyclebin = off;
use db1;
connection conn1;
--error 1051
drop table t1;
connection conn2;
create table t1(pk int primary key,c1 int);
connection conn1;
--error 1050
create table t1(pk int primary key,c1 int);
drop table t1;
connection conn2;
--error 1146
alter table t1 add column c2 varchar(50);
connection conn1;
create table t2(pk int primary key,c1 int);
connection conn2;
--error 1054
alter table t2 modify column c2 varchar(100);
connection conn3;
alter table t2 add column c2 varchar(50);
connection conn2;
alter table t2 modify column c2 varchar(100);
drop database db1;

#global index
connection default;
use test;
--disable_warnings
drop table if exists jx_t1;
drop table if exists jx_t2;
--enable_warnings
connection jx_obsys;
let $last_version = query_get_value(select schema_version from oceanbase.__all_virtual_ddl_operation order by schema_version desc limit 1, schema_version, 1);
connection default;
create table jx_t1(c1 int, c2 int, c3 int, c4 int, primary key(c1, c2)) partition by hash(c1)  subpartition by range columns(c2)  subpartition template ( subpartition p0 values less than (5),   subpartition p1 values less than (100)) partitions 2;
create index i1 on jx_t1(c3) global partition by hash(c3) partitions 2;
alter table jx_t1 rename index i1 to new_i1;
alter table jx_t1 alter index new_i1 invisible;
drop index new_i1 on jx_t1;

create table jx_t2(c1 int, c2 int, c3 int, c4 int, primary key(c1, c2)) partition by hash(c1)  subpartition by range columns(c2)  subpartition template ( subpartition p0 values less than (5),   subpartition p1 values less than (100)) partitions 2;
create index i2 on jx_t2(c3) global partition by hash(c3) partitions 2;
alter table jx_t2 drop index i2;

connection jx_obsys;
--disable_query_log
--replace_regex /schema_version > [0-9]*/schema_version > last_version/g
eval select operation_type, ddl_stmt_str from oceanbase.__all_virtual_ddl_operation where schema_version > $last_version and ddl_stmt_str not like '%ob_all_proxy%' and database_id = (select max(database_id) from oceanbase.__all_virtual_database_history where database_name='test' and tenant_id = $tid order by schema_version desc limit 1); 
--enable_query_log

connection default;
--disable_warnings
drop table if exists jx_t1;
drop table if exists jx_t2;
--enable_warnings
