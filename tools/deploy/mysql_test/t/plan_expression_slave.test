##bug:
CREATE TABLE t1 (a INT);
INSERT INTO t1 VALUES (1);
explain basic DELETE FROM t1 ORDER BY (SELECT a);
explain basic select * from t1, (select 1) as t3;
explain basic select * from t1, t1 as t3;

create table t2(a int);
insert into t2 values (1), (2);
explain basic select distinct @a:=min(t2.a) from t2, t2 as tt2 group by @b:=(select count(*) > tt2.a);
explain basic select distinct @a:=(select 1) from t2, t2 as tt2 group by @b:=(select count(*) > tt2.a);
explain basic select 1 from dual limit 1;



