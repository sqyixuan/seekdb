#owner: laibingzheng.lbz
#owner group: SQL1
#tags: dml, optimizer
#description: Test index with concurrent transactions with storing
####TITLE:单行事务和多行事务同时更新走索引的查询列,查询索引表、数据表，回表
####
--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_query_log
--source mysql_test/include/index_quick_major.inc
--real_sleep 1
--disable_warnings
drop table if exists t1;
--enable_warnings
--enable_query_log

create table t1(pk int primary key, a int, b int, c int, d int);
create index i1 on t1(b) storing(c,d);

--disable_query_log
let $index_name = __idx_3003_i1;
--enable_query_log
--source mysql_test/include/check_all_idx_ok.inc

connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn2,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn3,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);

####CASE:单行事务和多行事务同时更新，事务均提交,事务1可重复读
insert into t1 values(1,1,1,1,1),(2,1,1,1,1);

connection conn1;
set autocommit=0;
select pk, b, c, d from t1 where b>=1 and b<=1;
select * from t1 where pk>0 and pk<10 and b=1;
select * from t1 where b=1;

connection conn2;
set autocommit=0;
update t1 set a=10, b=10, c=10, d=10 where pk=1;
delete from t1 where pk=2;
commit;

connection conn3;
insert into t1(pk,a ,b, c, d) values(3,1,1,1,1);

connection conn1;
select pk, b, c, d from t1 where b>0 and b<100;
select * from t1 where pk>0 and pk<10;
select * from t1 where b>0 and b<100;
commit;
select pk, b, c, d from t1 where b>0 and b<100;
select * from t1 where pk>0 and pk<10;
select * from t1 where b>0 and b<100;

####CASE:多行事务回滚,单行事务提交,查询数据表、索引表、回表
connection conn2;
set autocommit=0;
update t1 set a=30, b=30, c=30, d=30 where pk=3;
insert into t1 values(4,1,1,1,1);
rollback;

connection conn3;
delete from t1 where pk=4;

connection conn1;
select pk, b, c, d from t1 where b>0 and b<100;
select * from t1 where pk>0 and pk<10;
select * from t1 where b>0 and b<100;
commit;
select pk, b, c, d from t1 where b>0 and b<100;
select * from t1 where pk>0 and pk<10;
select * from t1 where b>0 and b<100;

drop table t1;
