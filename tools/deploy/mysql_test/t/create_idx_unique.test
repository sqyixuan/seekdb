--source mysql_test/include/check_all_idx_ok.inc
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
let $sql = select table_name from oceanbase.__all_virtual_table where data_table_id = (select table_id from oceanbase.__all_virtual_table where table_name='t1' order by schema_version desc limit 1);
let $idx1 = query_get_value($sql, table_name, 1);
connection default;
select * from t1;
--echo select idx data of t1
--disable_query_log
set @@session.ob_enable_index_direct_select = 1;
eval select * from  $idx1;
--enable_query_log
#drop table t1;
