--source mysql_test/include/index_quick_major.inc
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1 (a int, b int, unique index idx (a, b));
drop table t1;
create table t1 (a int, b int primary key);
create unique index idx1 on t1(a);
--replace_column 3 idx_name
--source mysql_test/include/check_all_idx_ok.inc
show index from t1;
--error 1062
insert into t1 values(3,5),(4,6),(1,1),(5,2),(2,3),(2,4);
select * from t1;
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/check_all_idx_incons.inc
--source mysql_test/include/wait_daily_merge.inc
select * from t1;
--echo test:insert dup data between two major
drop table t1;
create table t1 (a int, b int primary key);
create unique index idx1 on t1(a);
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/check_all_idx_ok_unq.inc
--error 1062
insert into t1 values(3,5),(3,6),(1,1),(1,2),(2,3),(2,4);
drop table t1;
create table t1 (a int, b int primary key);
create unique index idx1 on t1(a);
insert into t1 values(3,5),(4,6);
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/check_all_idx_ok_unq.inc
--error 1062
