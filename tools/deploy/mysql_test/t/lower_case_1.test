--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

#owner: linlin.xll
#owner group: SQL1
#description:
##lower_case_table_names = 1:stored as lowercase letters, and comparisions are case insensitive
#tags: inner_table

connect (conn0,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn0;

--disable_warnings
#drop tenant if exists tt1 force;
#drop resource pool if exists test_resource_pool1;
#drop resource unit if exists test_resource_unit;
--enable_warnings

--disable_query_log
#eval create resource unit test_resource_unit max_cpu 1, memory_size '2G';

#let $zone_name=query_get_value(select zone from oceanbase.__all_zone where zone != '' limit 1, zone, 1);

--replace_column 1 create_time 2 modify_time 3 unit_config_id
#select * from oceanbase.__all_unit_config where name='test_resource_unit';

--disable_query_log
#eval create resource pool test_resource_pool1 unit = 'test_resource_unit', unit_num = 1, zone_list=('$zone_name');

--replace_column 1 create_time 2 modify_time 3 resource_pool_id 6 unit_config_id 7 zone
#select * from oceanbase.__all_resource_pool where name='test_resource_pool1';

#eval create tenant tt1 replica_num = 1, primary_zone='$zone_name', resource_pool_list=('test_resource_pool1') set lower_case_table_names = 1, ob_tcp_invited_nodes='%';
--source mysql_test/include/check_tenant_sync.inc
--enable_query_log
--replace_column 1 create_time 2 modify_time 3 tenant_id 6 zone 7 zone 13 locality 14 logonly_replica_num 15 previous_locality 16 storage_format_version 17 storage_format_work_version
#select * from oceanbase.__all_tenant where tenant_name='tt1';

##time to sync schema
let $__tenant_name__ = 'sys';
--source mysql_test/include/get_tenant_server.inc
connect (conn1,$TE_SERVER_IP,root,,*NO-ONE*,$TE_SERVER_PORT);
connection conn1;

select effective_tenant();
select current_user();
#select user();
#select session_user();
#select system_user();
select substring_index(user(), '@', 1);
select substring_index(session_user(), '@', 1);
select substring_index(system_user(), '@', 1);
show variables like 'lower_case_table_names';

--disable_warnings
drop database if exists yyy;
drop database if exists Yyy;
--enable_warnings

##(1) DATABASE NAMES,TABLE NAMES AND TABLE ALIAS NAMES --- only database name , table names and table alias names are affected by lower_case_table_names:stored as lowercase letters, and comparisions are case insensitive

create database Yyy;
--error 1007
create database yyy;
show databases;

use yyy;
create table T_table(c1 int primary key, c2 int);
--error 1050
create table t_table(c1 int primary key, c2 int);
show tables;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t_table;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table T_table;
select * from t_table;
select * from T_TABLE;
create table join_table(c1 int primary key, c2 int);
--error 1066
select * from t_table c join join_table C order by c.c1;
drop table t_table;

##(2)INDEX NAMES,COLUMN NAMES AND COLUMN ALIAS NAMES --- index name, column names and column alias names are not affected by lower_case_table_names:stored as origin letters, and comparisions are case insensitive
--error 1060
create table t_column(c1 int primary key, C1 int);
create table t_column(c1 int primary key, C2 int);

##--error 1052
##select c1 a, C2 A from t_column order by a;
select c1, c2 from t_column;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t_column;

create index IDX on t_column(c2);
--error 1061
create index idx on t_column(c2);
show index from t_column;
drop table t_column;

##(3) USER NAMES AND OTHER NAMES --- user names and other names are not affected by lower_case_table_names.They are always stored as origin letters adn comparisions are case sensitive

CREATE USER yyy;
CREATE USER YYY;
drop user yyy, YYY;
drop database yyy;

connection conn1;
--disable_warnings
drop tablegroup if exists t_group;
drop tablegroup if exists T_group;
--enable_warnings
--enable_query_log
create tablegroup t_group;
create tablegroup T_group;
use test;
--error 5151
create table test_tg(c1 int primary key) tablegroup 'T_GROUP';
create table test_tg(c1 int primary key) tablegroup 'T_group';

drop table test_tg;
drop tablegroup t_group;
drop tablegroup T_group;

set ob_enable_index_direct_select=1;
create table test_index(c1 int primary key, c2 int, key idx1(c2));

connection conn0;
let $index_table_name=query_get_value(select table_name from oceanbase.__all_virtual_table where data_table_id in (select table_id from oceanbase.__all_virtual_table where table_name='test_index'), table_name, 1);

connection conn1;
--disable_query_log
eval select * from $index_table_name;
--enable_query_log
drop table test_index;
connection conn0;
#drop tenant tt1 force;
#drop resource pool test_resource_pool1;
#drop resource unit test_resource_unit;
