--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: yuchen.wyc
#owner group: sql1
connect (my_obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection default;
set ob_enable_index_direct_select=1;

--source mysql_test/include/index_quick_major.inc
#test:不加索引的场景
--disable_warnings
drop table if exists testupdate;
--enable_warnings
create table testupdate(pk int primary key,c1 int) partition by hash(pk) partitions 5;
create index idx on testupdate(c1);
insert into testupdate values(1,1);
update testupdate set pk=3 where pk=1;
update testupdate set pk=4,c1=c1+1 where pk=3;
select * from testupdate;
#test:加索引
--disable_warnings
drop table if exists testupdate;
--enable_warnings
create table testupdate(pk int primary key,c1 int) partition by hash(pk) partitions 5;
create index idx1 on testupdate(c1);
--source mysql_test/include/check_all_idx_ok.inc
connection my_obsys;
let $idx11 = query_get_value(select a.table_name from oceanbase.__all_virtual_table as a inner join (select * from oceanbase.__all_virtual_table where table_name='testupdate' and tenant_id = (select tenant_id from oceanbase.__all_tenant where tenant_name = 'sys')) b on a.data_table_id=b.table_id, table_name, 1);
connection default;
insert into testupdate values(1,1);
update testupdate set pk=3 where pk=1;
update testupdate set pk=4,c1=c1+1 where pk=3;
select * from testupdate;
--disable_query_log
eval select * from  $idx11;
--enable_query_log
#test:加唯一索引
--disable_warnings
drop table if exists testupdate;
--enable_warnings
create table testupdate(pk int primary key,c1 int) partition by hash(pk) partitions 5;
create unique index idx1 on testupdate(c1) global;
--source mysql_test/include/check_all_idx_ok.inc
connection my_obsys;
let $idx12 = query_get_value(select a.table_name from oceanbase.__all_virtual_table as a inner join (select * from oceanbase.__all_virtual_table where table_name='testupdate' and tenant_id = (select tenant_id from oceanbase.__all_tenant where tenant_name = 'sys')) b on a.data_table_id=b.table_id, table_name, 1);
connection default;
insert into testupdate values(1,1);
update testupdate set pk=3 where pk=1;
update testupdate set pk=4,c1=c1+1 where pk=3;
select * from testupdate;
--disable_query_log
eval select * from  $idx12;
--enable_query_log
set ob_enable_index_direct_select=0;
