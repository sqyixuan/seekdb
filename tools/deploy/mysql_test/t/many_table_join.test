while($i < 1000)
{
  eval select /*+use_nl(t, t1, t2, t3, t4, t5, t6, t7, t8, t9)*/* from t left join t1 on t.c3=t1.c1 left join t2 on t.c3=t2.c1 left join  t3 on t.c3=t3.c1  left join  t4 on t.c3=t4.c1 left join  t5 on t.c3=t5.c1 left join  t6 on t.c3=t6.c1 left join  t7 on t.c3=t7.c1 left join  t8 on t.c3=t8.c1  left join  t9 on t.c3=t9.c1;
  inc $i;
}
