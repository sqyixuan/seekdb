--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

#owner: linlin.xll
#owner group: SQL1
#description:
#tags:executor, sys_vars 

## interm_result_memory_limit : test interm result memory limit in work area

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;

#--disable_warnings
#drop tenant if exists interm_result_test force;
#drop resource pool if exists test_resource_pool1;
#drop resource unit if exists test_resource_unit1;
#--enable_warnings

#--disable_query_log
#eval create resource unit test_resource_unit1 max_cpu 1, memory_size '2G';

#--disable_query_log
#let $zone_name=query_get_value(select zone from oceanbase.__all_zone where zone != '' limit 1, zone, 1);

#--disable_query_log
#eval create resource pool test_resource_pool1 unit='test_resource_unit1', unit_num = 1, zone_list=('$zone_name') ;

#--disable_query_log
#eval create tenant interm_result_test replica_num=1, zone_list=('$zone_name'), primary_zone='$zone_name', resource_pool_list=('test_resource_pool1') set ob_tcp_invited_nodes='%';
--source mysql_test/include/check_tenant_sync.inc

--enable_query_log

disconnect obsys;
let $__tenant_name__ = 'sys';
#--source mysql_test/include/get_tenant_server.inc
connect (conn1, $OBMYSQL_MS0, root, , *NO-ONE*, $OBMYSQL_PORT);
connection conn1;

drop database test;
create database test;
use test;

--disable_warnings
drop table if exists test_part;
--enable_warnings

create table test_part(col int, col1 varchar(262144)) partition by range (col) (partition p01 values less than (2), partition p02 values less than (3), partition p03 values less than (4));

show tables;

## prepare data
let $row_num=1;

--disable_query_log
while($row_num < 200) {
  eval insert into test_part value (1, repeat('1', 262144));
  eval insert into test_part value (2, repeat('2', 262144));
  eval insert into test_part value (3, repeat('3', 262144));
  inc $row_num;
}
--enable_query_log

## wait variable work_area valid
sleep 10;

#--error 4013
#select * from test_part;

set global ob_sql_work_area_percentage=20;

## wait variable work_area valid.
sleep 10;

--disable_query_log
let $value = query_get_value(select * from test_part, col, 1);
echo $value;
--enable_query_log

## clear
drop table test_part;

disconnect conn1;
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
--enable_query_log

##clear
#drop tenant interm_result_test force;
#drop resource pool test_resource_pool1;
#drop resource unit test_resource_unit1;


