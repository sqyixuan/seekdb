--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: link.zt
#owner group: SQL1
#description: This case is to test update, delete statements with order by, limit
connect (my_obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection default;

#####test:update,delete stat:qaic or dynamic date
--disable_abort_on_error
--disable_warnings
--disable_query_log
--disable_result_log
drop table if exists t1; 
--source mysql_test/include/index_quick_major.inc
#alter system set min_drop_cache_wait_time='10s' server_type=chunkserver;
--enable_query_log
--enable_result_log
--enable_warnings

--real_sleep 2 

create table t1 (pk1 int,pk2 int, i1 int, v1 varchar(20),primary key(i1,pk2), index idx1(pk1));
insert into t1 values(1,1,1,'a'),(2,2,2,'b'),(3,3,3,'c'),(4,4,4,'d'),(5,5,5,'e');
connection my_obsys;
let $idx1 = query_get_value(select a.table_name from oceanbase.__all_virtual_table as a inner join (select * from oceanbase.__all_virtual_table where table_name='t1') b on a.data_table_id=b.table_id, table_name, 1);
connection default;

##只有动态数据的更新
####test:update part primary key
update t1 set pk1=4 where pk1=1;
update t1 set pk1=6,v1='d' where pk1=3;
select * from t1;
update t1 set pk1=4 where pk1<15 order by pk2 limit 2;
select * from t1;
update t1 set pk1=8 where pk1<15 order by pk2 asc  limit 2;
select * from t1;
update t1 set pk1=7 where pk1<15 order by pk2 limit 2;
select * from t1;
update t1 set pk1=6,v1='d' where pk1=3 order by pk2 limit 0;
select * from t1;
####test:update not primary key
update t1 set v1=4 where pk1<15 order by pk2 limit 2;
select * from t1;
update t1 set v1=8 where pk1<15 order by pk2 asc  limit 2;
select * from t1;
update t1 set v1=7 where pk1<15 order by pk2 limit 2;
select * from t1;
update t1 set pk1=6,v1='d' where pk1=3 order by pk2 limit 0;
select * from t1;

--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc

##只有静态数据的更新
update t1 set pk1=1 where pk1<=4 order by pk2 limit 1;
select * from t1;
update t1 set pk1=3 where pk1>=6 order by pk1, pk2 limit 2;
select * from t1;
update t1 set pk1=-1 where (pk2,i1) in ((4,1),(5,2),(6,3),(2,3)) order by i1 limit 5;
select * from t1;
update t1 set pk1=-1 where (pk2,i1) in ((1,1),(1,2),(2,2),(3,3)) order by pk2  asc limit 5;
select * from t1;
update t1 set pk1=-1 where (pk2,i1) in ((1,1),(1,2),(2,2),(3,3)) order by i1 asc limit 2;
select * from t1;
--disable_query_log
eval update /*index($idx1)*/ t1 set pk1=-2 where (pk2,i1) in ((4,4),(4,5),(5,5),(6,6)) order by i1 desc limit 2;
--enable_query_log
select * from t1;

##动静态都存在
update t1 set pk1=4,v1='e' where pk2=1;
update t1 set pk1=5,v1='f' where pk2=2;
update t1 set pk1=6,v1='g' where pk2=3;
update t1 set pk1=-1 where (pk2,i1) in ((1,1),(1,2),(2,2),(3,3)) order by pk2  asc limit 5;
select * from t1;
update t1 set pk1=-1 where (pk2,i1) in ((1,1),(1,2),(5,5),(3,3)) order by i1 asc limit 2;
select * from t1;
update t1 set pk1=pk2+1,pk2=pk1+1 where (pk1,i1) in ((1,1),(1,2),(2,2),(2,3)) limit 2;
update t1 set pk1=pk1+1-1 where (pk2,i1) in ((1,1),(1,2),(2,2),(2,3)) limit 2;
select * from t1;


--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc

 replace into t1 values(1,1,1,'a'),(2,2,2,'b'),(3,3,3,'c'),(4,4,14,'d'),(5,5,5,'e');
update t1 set pk1=-2 where (pk1,pk2,i1) in ((2,2,2),(1,1,1),(2,2,3),(1,1,2),(3,3,3),(3,3,4),(4,4,5),(5,5,6)) order by pk2 limit 10;
--disable_query_log
eval delete  /*index($idx1)*/ /*delete t1*/ from t1  where (pk2,i1) in ((4,4),(4,5),(5,5),(6,6)) order by i1 desc limit 2;
--enable_query_log
select * from t1;
--enable_abort_on_error
