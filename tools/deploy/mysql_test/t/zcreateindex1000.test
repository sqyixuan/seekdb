#
let $cnt=50;
while($cnt) 
{
     eval  create table ttl$cnt(i1 int, v2 varchar(80), i3 char(20),i4 float, d4 datetime(6),i5 decimal(5,3), primary key(i1));
    let $cnt2=20;
    while ($cnt2)
    {
     eval  create index ttlidx_1$cnt2 on ttl$cnt(i1);
     eval  create index ttlidx_2$cnt2 on ttl$cnt(v2);
     eval  create index ttlidx_3$cnt2 on ttl$cnt(i3);
     eval  create index ttlidx_4$cnt2 on ttl$cnt(i4);
     eval  create index ttlidx_5$cnt2 on ttl$cnt(d4);
    dec $cnt2;
}
    dec $cnt;
}
--disable_query_log
