--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: yibo.tyf
#owner group: sql1

--disable_warnings
drop table if exists t1;
--enable_warnings
--source mysql_test/include/index_quick_major.inc
--real_sleep 2 

create table t1(pk1 int, pk2 int, key1 int, key2 int, key3 int, key4 int, key5 int, key6 int, key7 int, key8 int, key9 int, primary key(pk1, pk2));

create index i1 on t1(key1,key2) storing(key9);
create index i2 on t1(key3,key4,key5) storing(key9);
create index i3 on t1(key2,key3,key4);
create index i4 on t1(key6);
create index i5 on t1(key7,key8);
create index i6 on t1(key1,pk2);

--source mysql_test/include/check_all_idx_ok.inc

insert into t1 values
(1,2,2,2,3,4,5,6,7,8,9),
(2,2,3,3,3,4,5,6,7,8,9),
(3,4,1,2,3,4,5,6,7,8,9),
(4,4,1,2,3,4,5,6,7,8,9),
(5,6,1,2,3,4,5,6,7,8,9),
(6,7,2,3,4,5,6,7,8,9,10),
(8,9,1,3,5,7,9,7,8,3,1);

##index get 1

#i2
select * from t1 where key1=1 and key2=2 and key3=3 and key4=4 and key5=5;
select avg(key6) from t1 where key1=1 and key2=2 and key3=3 and key4=4 and key5=5;
select min(key6) from t1 where key1=1 and key2=2 and key3=3 and key4=4 and key5=5;
select max(key6) from t1 where key1=1 and key2=2 and key3=3 and key4=4 and key5=5;
select sum(key6) from t1 where key1=1 and key2=2 and key3=3 and key4=4 and key5=5;
select distinct key6,key7 from t1 where key1=1 and key2=2 and key3=3 and key4=4 and key5=5;

##index get 2

#i1 
select * from t1 where pk2=2 and key1=2 and key2=2;
select avg(key3) from t1 where pk2=2 and key1=2 and key2=2;
select min(key3) from t1 where pk2=2 and key1=2 and key2=2;
select max(key3) from t1 where pk2=2 and key1=2 and key2=2;
select sum(key3) from t1 where pk2=2 and key1=2 and key2=2;
select distinct key3,key4 from t1 where pk2=2 and key1=2 and key2=2;

#i1
select * from t1 where (key1,pk2) in ((1,2),(1,1)) and (key1,key2) in ((3,4),(3,3));
select avg(key6) from t1 where (key1,pk2) in ((1,2),(1,1)) and (key1,key2) in ((3,4),(3,3));
select min(key6) from t1 where (key1,pk2) in ((1,2),(1,1)) and (key1,key2) in ((3,4),(3,3));
select max(key6) from t1 where (key1,pk2) in ((1,2),(1,1)) and (key1,key2) in ((3,4),(3,3));
select sum(key6) from t1 where (key1,pk2) in ((1,2),(1,1)) and (key1,key2) in ((3,4),(3,3));
select distinct key6 from t1 where (key1,pk2) in ((1,2),(1,1)) and (key1,key2) in ((3,4),(3,3));

##index get 3
#i5
select * from t1 where key1=1 and key2=2 and key7=8 and key8=9 order by key7;
select avg(key6) from t1 where key1=1 and key2=2 and key7=8 and key8=9 order by key7;
select min(key6) from t1 where key1=1 and key2=2 and key7=8 and key8=9 order by key7;
select max(key6) from t1 where key1=1 and key2=2 and key7=8 and key8=9 order by key7;
select sum(key6) from t1 where key1=1 and key2=2 and key7=8 and key8=9 order by key7;
select distinct key6 from t1 where key1=1 and key2=2 and key7=8 and key8=9 order by key7;

##index get 4
#i1
select * from t1 where key1=1 and key2=2 and key7=8 and key8=9 order by key1,key7;
select avg(key6) from t1 where key1=1 and key2=2 and key7=8 and key8=9 order by key1,key7;
select min(key6) from t1 where key1=1 and key2=2 and key7=8 and key8=9 order by key1,key7;
select max(key6) from t1 where key1=1 and key2=2 and key7=8 and key8=9 order by key1,key7;
select sum(key6) from t1 where key1=1 and key2=2 and key7=8 and key8=9 order by key1,key7;
select distinct key6 from t1 where key1=1 and key2=2 and key7=8 and key8=9 order by key1,key7;

#i1
select * from t1 where key1=1 and key2=2 and key7=8 and key8=9;
select avg(key6) from t1 where key1=1 and key2=2 and key7=8 and key8=9;
select min(key6) from t1 where key1=1 and key2=2 and key7=8 and key8=9;
select max(key6) from t1 where key1=1 and key2=2 and key7=8 and key8=9;
select sum(key6) from t1 where key1=1 and key2=2 and key7=8 and key8=9;
select distinct key6 from t1 where key1=1 and key2=2 and key7=8 and key8=9;


--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc

replace into t1 values
(1,2,2,2,3,4,5,6,7,8,10),
(2,2,3,3,3,4,5,6,7,8,10),
(3,4,1,2,3,4,5,6,7,8,10),
(4,4,1,2,3,4,5,6,7,8,10),
(5,6,1,2,3,4,5,6,7,8,10),
(6,7,2,3,4,5,6,7,8,9,11),
(8,9,1,3,5,7,9,7,8,3,2);


##index get 1

#i2
select * from t1 where key1=1 and key2=2 and key3=3 and key4=4 and key5=5;
select avg(key6) from t1 where key1=1 and key2=2 and key3=3 and key4=4 and key5=5;
select min(key6) from t1 where key1=1 and key2=2 and key3=3 and key4=4 and key5=5;
select max(key6) from t1 where key1=1 and key2=2 and key3=3 and key4=4 and key5=5;
select sum(key6) from t1 where key1=1 and key2=2 and key3=3 and key4=4 and key5=5;
select distinct key6,key7 from t1 where key1=1 and key2=2 and key3=3 and key4=4 and key5=5;

##index get 2

#i1 
select * from t1 where pk2=2 and key1=2 and key2=2;
select avg(key3) from t1 where pk2=2 and key1=2 and key2=2;
select min(key3) from t1 where pk2=2 and key1=2 and key2=2;
select max(key3) from t1 where pk2=2 and key1=2 and key2=2;
select sum(key3) from t1 where pk2=2 and key1=2 and key2=2;
select distinct key3,key4 from t1 where pk2=2 and key1=2 and key2=2;

#i1
select * from t1 where (key1,pk2) in ((1,2),(1,1)) and (key1,key2) in ((3,4),(3,3));
select avg(key6) from t1 where (key1,pk2) in ((1,2),(1,1)) and (key1,key2) in ((3,4),(3,3));
select min(key6) from t1 where (key1,pk2) in ((1,2),(1,1)) and (key1,key2) in ((3,4),(3,3));
select max(key6) from t1 where (key1,pk2) in ((1,2),(1,1)) and (key1,key2) in ((3,4),(3,3));
select sum(key6) from t1 where (key1,pk2) in ((1,2),(1,1)) and (key1,key2) in ((3,4),(3,3));
select distinct key6 from t1 where (key1,pk2) in ((1,2),(1,1)) and (key1,key2) in ((3,4),(3,3));

##index get 3
#i5
select * from t1 where key1=1 and key2=2 and key7=8 and key8=9 order by key7;
select avg(key6) from t1 where key1=1 and key2=2 and key7=8 and key8=9 order by key7;
select min(key6) from t1 where key1=1 and key2=2 and key7=8 and key8=9 order by key7;
select max(key6) from t1 where key1=1 and key2=2 and key7=8 and key8=9 order by key7;
select sum(key6) from t1 where key1=1 and key2=2 and key7=8 and key8=9 order by key7;
select distinct key6 from t1 where key1=1 and key2=2 and key7=8 and key8=9 order by key7;

##index get 4
#i1
select * from t1 where key1=1 and key2=2 and key7=8 and key8=9 order by key1,key7;
select avg(key6) from t1 where key1=1 and key2=2 and key7=8 and key8=9 order by key1,key7;
select min(key6) from t1 where key1=1 and key2=2 and key7=8 and key8=9 order by key1,key7;
select max(key6) from t1 where key1=1 and key2=2 and key7=8 and key8=9 order by key1,key7;
select sum(key6) from t1 where key1=1 and key2=2 and key7=8 and key8=9 order by key1,key7;
select distinct key6 from t1 where key1=1 and key2=2 and key7=8 and key8=9 order by key1,key7;

#i1
select * from t1 where key1=1 and key2=2 and key7=8 and key8=9;
select avg(key6) from t1 where key1=1 and key2=2 and key7=8 and key8=9;
select min(key6) from t1 where key1=1 and key2=2 and key7=8 and key8=9;
select max(key6) from t1 where key1=1 and key2=2 and key7=8 and key8=9;
