#owner: dingjincheng.djc
#owner group: SQL1
--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
####TITLE:update delete using one of rowkey,compound
--disable_warnings
drop table if exists t1,t2;
--enable_warnings

create table t1(pk1 int, pk2 int, c1 int, c2 int, primary key(pk1,pk2));
insert into t1(pk1,pk2,c1,c2) values(0,0,0,0),(0,1,0,0),(0,2,0,0),(0,3,0,0),(1,0,0,0),(1,1,0,0),(1,2,0,0),(1,3,0,0);
create table t2(pk1 int, pk2 int, c1 int, c2 int, primary key(pk1,pk2));
insert into t2(pk1,pk2,c1,c2) values(0,0,0,0),(0,1,0,0),(0,2,0,0),(0,3,0,0),(1,0,0,0),(1,1,0,0),(1,2,0,0),(1,3,0,0);

########CASE: select + update
select * from t1 when row_count(update t1 set c1=c1+1, c2=c2+1 where pk1=0)=4;
select c1,c2 from t1 where pk1=1 when row_count(update t1 set c1=c1+1, c2=c2+1 where pk1=1)=4;
--error 5064
select c1,c2 from t1 where pk1=1 when row_count(update t1 set c1=c1+1, c2=c2+1 where pk1=1)=1;
select * from t1;

########CASE: select + update + update
replace into t1(pk1,pk2,c1,c2) values(0,0,0,0),(0,1,0,0),(0,2,0,0),(0,3,0,0),(1,0,0,0),(1,1,0,0),(1,2,0,0),(1,3,0,0);
select * from t1 where pk1=1 when row_count(update t1 set c1=c1+1, c2=c2+1 where pk1=1 when row_count(update t1 set c1=c1+1, c2=c2+1 where pk1=1)=4)=4;
select c1,c2 from t1 where pk1=0 when row_count(update t1 set c1=c1+1, c2=c2+1 where pk1=0 when row_count(update t1 set c1=c1+1, c2=c2+1 where pk1=0)=4)=4;

--error 5064
select * from t1 where pk1=1 when row_count(update t1 set c1=c1+1, c2=c2+1 where pk1=1 when row_count(update t1 set c1=c1+1, c2=c2+1 where pk1=1)=3)=4;
--error 5064
select * from t1 where pk1=1 when row_count(update t1 set c1=c1+1, c2=c2+1 where pk1=1 when row_count(update t1 set c1=c1+1, c2=c2+1 where pk1=1)=4)=3;
select * from t1;

########CASE: select + update t1 + update t2
replace into t1(pk1,pk2,c1,c2) values(0,0,0,0),(0,1,0,0),(0,2,0,0),(0,3,0,0),(1,0,0,0),(1,1,0,0),(1,2,0,0),(1,3,0,0);
select * from t1 where pk1=0 when row_count(update t2 set c1=c1+1, c2=c2+1 where pk1=0 when row_count(update t1 set c1=c1+1, c2=c2+1 where pk1=0)=4)=4;
select * from t1;
select * from t2;
select c1,c2 from t2 where pk1=1 when row_count(update t2 set c1=c1+1, c2=c2+1 where pk1=1 when row_count(update t1 set c1=c1+1, c2=c2+1 where pk1=1)=4)=4;
select * from t1;
select * from t2;

--error 5064
select * from t1 where pk1=1 when row_count(update t2 set c1=c1+1, c2=c2+1 where pk1=1 when row_count(update t1 set c1=c1+1, c2=c2+1 where pk1=1)=4)=1;
--error 5064
select * from t1 where pk1=1 when row_count(update t2 set c1=c1+1, c2=c2+1 where pk1=1 when row_count(update t1 set c1=c1+1, c2=c2+1 where pk1=1)=1)=4;
select * from t1;
select * from t2;

########CASE: select + update + delete
replace into t1(pk1,pk2,c1,c2) values(0,0,0,0),(0,1,0,0),(0,2,0,0),(0,3,0,0),(1,0,0,0),(1,1,0,0),(1,2,0,0),(1,3,0,0);
replace into t2(pk1,pk2,c1,c2) values(0,0,0,0),(0,1,0,0),(0,2,0,0),(0,3,0,0),(1,0,0,0),(1,1,0,0),(1,2,0,0),(1,3,0,0);
--error 5064
select c1, c2 from t1 when row_count(update t1 set c1=c1+1, c2=c2+1 where pk1=1 when row_count(delete from t1 where pk1=0)=4)=1;
--error 5064
select c1, c2 from t1 when row_count(update t1 set c1=c1+1, c2=c2+1 where pk1=1 when row_count(delete from t1 where pk1=0)=1)=4;
--error 5064
select c1, c2 from t1 when row_count(update t1 set c1=c1+1, c2=c2+1 where pk1=1 when row_count(delete from t2 where pk1=0)=4)=1;
--error 5064
select c1, c2 from t1 when row_count(update t1 set c1=c1+1, c2=c2+1 where pk1=1 when row_count(delete from t2 where pk1=0)=1)=4;
select * from t1;
select * from t2;

select c1, c2 from t1 where pk1=0 when row_count(update t1 set c1=c1+1, c2=c2+1 where pk1=0 when row_count(delete from t2 where pk1=0)=4)=4;
select * from t1;
select * from t2;
select pk1, pk2, c1, c2 from t1 where pk1=0 when row_count(update t1 set c1=c1+1, c2=c2+1 where pk1=0 when row_count(delete from t2 where pk1=1)=4)=4;
select * from t1;
select * from t2;
select * from t1 where pk1=1 when row_count(update t1 set c1=c1+1, c2=c2+1 where pk1=1 when row_count(delete from t1 where pk1=0)=4)=4;
select * from t1;
select * from t2;

########CASE: update + insert, update + replace
replace into t1(pk1,pk2,c1,c2) values(0,0,0,0),(0,1,0,0),(0,2,0,0),(0,3,0,0),(1,0,0,0),(1,1,0,0),(1,2,0,0),(1,3,0,0);
replace into t2(pk1,pk2,c1,c2) values(0,0,0,0),(0,1,0,0),(0,2,0,0),(0,3,0,0),(1,0,0,0),(1,1,0,0),(1,2,0,0),(1,3,0,0);
#new rows
update t1 set c1=4, c2=4 where pk1=2 when row_count(insert into t1(pk1,pk2,c1,c2) values(2,0,0,0),(2,1,0,0))=2;
select * from t1;
update t1 set c1=3, c2=3 where pk1=2 when row_count(insert into t1(pk1,pk2,c1,c2) values(2,2,0,0),(2,3,0,0))=2;
--error 5064
update t1 set c1=5, c2=5 where pk1=3 when row_count(insert into t1(pk1,pk2,c1,c2) values(3,0,0,0),(3,1,0,0))=1;
select * from t1;

--error 1062
update t1 set c1=2, c2=2 where pk1=2 when row_count(insert into t1(pk1,pk2,c1,c2) values(2,0,0,0),(2,1,0,0))=2;
update t1 set c1=4, c2=4 where pk1=2 when row_count(replace into t1(pk1,pk2,c1,c2) values(2,2,0,0),(2,3,0,0))=2;
select * from t1;

#old rows
--error 5064
update t1 set c1=6, c2=6 where pk1=0 when row_count(insert into t1(pk1,pk2,c1,c2) values(3,0,0,0),(3,1,0,0))=1;
--error 5064
update t1 set c1=7, c2=7 where pk1=1 when row_count(replace into t1(pk1,pk2,c1,c2) values(3,2,0,0),(3,3,0,0))=1;
--error 5064
update t1 set c1=8, c2=8 where pk1=0 when row_count(insert into t2(pk1,pk2,c1,c2) values(3,0,0,0),(3,1,0,0))=1;
--error 5064
update t1 set c1=9, c2=9 where pk1=1 when row_count(replace into t2(pk1,pk2,c1,c2) values(3,2,0,0),(3,3,0,0))=1;
select * from t1;
select * from t2;

update t1 set c1=6, c2=6 where pk1=0 when row_count(insert into t1(pk1,pk2,c1,c2) values(3,0,0,0),(3,1,0,0))=2;
update t1 set c1=7, c2=7 where pk1=1 when row_count(replace into t1(pk1,pk2,c1,c2) values(3,2,0,0),(3,3,0,0))=2;
select * from t1;
update t1 set c1=8, c2=8 where pk1=0 when row_count(insert into t2(pk1,pk2,c1,c2) values(3,0,0,0),(3,1,0,0))=2;
update t1 set c1=9, c2=9 where pk1=1 when row_count(replace into t2(pk1,pk2,c1,c2) values(3,2,0,0),(3,3,0,0))=2;
select * from t1;
select * from t2;

########CASE: update + update
delete from t1;
delete from t2;
replace into t1(pk1,pk2,c1,c2) values(0,0,0,0),(0,1,0,0),(0,2,0,0),(0,3,0,0),(1,0,0,0),(1,1,0,0),(1,2,0,0),(1,3,0,0);
replace into t2(pk1,pk2,c1,c2) values(0,0,0,0),(0,1,0,0),(0,2,0,0),(0,3,0,0),(1,0,0,0),(1,1,0,0),(1,2,0,0),(1,3,0,0);
update t1 set c1=c1+1, c2=c2+1 where pk1=1 when row_count(update t1 set c1=c1+1, c2=c2+1 where pk1=0)=4;
select * from t1;
update t1 set c1=c1+1, c2=c2+1 where pk1=0 when row_count(update t1 set c1=c1+1, c2=c2+1 where pk1=0)=4;
