--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

#owner: linlin.xll
#owner group: SQL1
#description:
#tags: optimizer, inner_table

use oceanbase;
##--replace_regex /partitions(p\[[0-9]*-[0-9]*\])/partitions(p\[\])/g
--replace_regex /partitions([^)]*)/partitions(pxx)/g
--replace_regex /\('[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+' *, *[0-9]+\)(, \('[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+' *, *[0-9]+\))*/IP_MASK, PORT_MASK/g
#--replace_regex /[('[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+' *, *[0-9]+),*]+/IP_MASK, PORT_MASK/g
explain basic select gvcnt=vcnt from (select count(*) as gvcnt from gv$sesstat where SVR_IP=host_ip() and SVR_PORT=rpc_port()) as gv_view join (select count(*) as vcnt from v$sesstat) as v_view;
use test;

