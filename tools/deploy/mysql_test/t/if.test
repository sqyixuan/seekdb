--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: link.zt
#owner group: sql1


# Testing of CASE
#
--enable_abort_on_error


--disable_warnings
drop table if exists a1, a2,t1,t2;
--enable_warnings

select if(null, 1, 2);
select if(null, null, 2);
select if(null, 1, null);
select if(null, null, null);
select if(1, null, 2);
select if(1, 1, null);
select if(0, null, 2);
select if(0, 1, null);

select if(1, 1, 2);
select if('1', 1, 2);
select if(0, 1, 2);
select if('0', 1, 2);
select if('a', 1, 2);
select if('123abc', 1, 2);
select if('0.0123df', 1, 2);
select if(0.11, 1, 2);
select if(0.00001, 1, 2);
select if(5%0, 1, 2);
select if(0.0001<>1, 1, 2);
select if(0.0001<>0, 1, 2);
select if(1>2, 2, 3);
select if(1<2, 'yes', 'no');
