--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: yibo.tyf
#owner group: sql1

--disable_warnings
drop table if exists t1; 
--enable_warnings
--source mysql_test/include/index_quick_major.inc
--real_sleep 1

####CASE: multi rowkeys
create table t1(pk1 int, pk2 int, key1 int, key2 int, key3 int, key4 int, key5 int, key6 int, key7 int, key8 int, key9 int, primary key(pk1, pk2));

create index i1 on t1(key1,key2) storing(key9);
create index i2 on t1(key3,key4,key5);
create index i4 on t1(key6);
create index i5 on t1(key7,key8) storing(key9);
create index i6 on t1(key2,pk2);

--source mysql_test/include/check_all_idx_ok.inc

insert into t1 values
(1,2,2,2,3,4,5,6,7,6,9),
(1,5,2,2,3,4,5,6,7,4,1),
(1,4,2,2,3,4,5,2,7,8,9),
(1,3,2,2,3,4,5,6,7,2,9),
(2,3,2,2,3,4,4,4,7,2,9),
(3,3,2,2,3,4,4,5,7,2,9),
(1,6,2,6,3,4,5,2,7,2,1),
(1,1,2,3,3,4,5,6,7,2,9),
(1,8,2,8,3,4,5,2,7,1,9),
(1,9,2,8,3,4,5,6,7,7,9);
##cover index get + cover index scan
#i1
select count(*) from t1 where key1=2 and key2=2 and key7=7 and key8<8 and key8>0;
select sum(key9) from t1 where key1=2 and key2=2 and key7=7 and key8<8 and key8>0;
select avg(key9) from t1 where key1=2 and key2=2 and key7=7 and key8<8 and key8>0;
select min(key9) from t1 where key1=2 and key2=2 and key7=7 and key8<8 and key8>0;
select max(key9) from t1 where key1=2 and key2=2 and key7=7 and key8<8 and key8>0;
select distinct key9 from t1 where pk1=2 and pk2>3 and pk2<=6 and key1=2 and key2>2 and key2<6;

#t1
select count(*) from t1 where pk1=1 and pk2=2 and key1<3 and key1>0;
