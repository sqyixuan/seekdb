##full scan --> cover index scan
select count(*) from t1;
select pk1,key1 from t1 where key1>1;
select pk1,key2 from t1 where key2>1 order by key2;
select count(*) from t1 where key2>2;


##full scan
select * from t1;
select * from t1 where key1>1;
select * from t1 where key1<10;
select * from t1 where key1>0 and key2>0 order by pk1, pk2;
select * from t1 where key1<10 and key2<10 order by pk1, pk2;

####CASE singel rowkey
--disable_warnings
drop table if exists t1;
--enable_warnings
--real_sleep 3
create table t1(pk int primary key ,c1 int, c2 int);
create index i1 on t1(c1);
insert into t1 values(1,9,6),(2,8,5),(3,7,7),(4,6,4),(5,5,8);

--source mysql_test/include/check_all_idx_ok.inc
select * from t1 where pk < 10;
select * from t1 where pk > 0;
select * from t1 where pk > 0 and pk < 10;
select * from t1 where c1 < 10;
select pk,c1 from t1 where c1 < 10;
select * from t1 where c1 > 0;
select pk,c1 from t1 where c1 > 0;
select * from t1 where c1 > 0 and pk < 10;
select pk,c1 from t1 where c1 > 0 and pk < 10;
