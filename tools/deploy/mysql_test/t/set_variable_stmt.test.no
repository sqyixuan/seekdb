set @@global.autocommit=1;
--error 1231
set @@global.autocommit='1';
--error 1231
set @@session.autocommit='1';

--echo test ob_read_consistency
set ob_read_consistency='static';
show variables like 'ob_read_consistency';
set ob_read_consistency='frozen';
show variables like 'ob_read_consistency';
set ob_read_consistency='weak';
show variables like 'ob_read_consistency';
set ob_read_consistency='strong';
show variables like 'ob_read_consistency';
--error 4002
set ob_read_consistency='kaka';
