--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: yuchen.wyc
# owner group: SQL1
# description: OUR GOAL: Make all this simple and effective!
####test:update para,加锁变化，增加一些case；
####test：update 2个事务同时更新一行
--disable_query_log
--source mysql_test/include/index_quick_major.inc
--real_sleep 2
--disable_warnings
drop table if exists t1; 
--enable_warnings
--enable_query_log
create table t1(pk int primary key, a int, b int, c varchar(1024));
create index i1 on t1(b) storing(c);

--source mysql_test/include/check_all_idx_ok.inc

insert into t1 values(1,1,1,'a');
connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn2,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn1;
set autocommit=0;
update t1 set a=3 where pk=1;


connection conn2;
set autocommit=0;
--error 1205,4012
update t1 set a=5 where pk=1;
commit;


connection conn1;
commit;
#####tests: select for update 后，2个事务并发的情况
insert into t1 values(2,2,2,'b'),(3,3,3,'c'),(5,5,5,'e');
connection conn1;
set autocommit=0;
select * from t1 where pk<6 for update;


connection conn2;
set autocommit=0;
insert into t1 values(4,4,4,'d');
update t1 set pk=10 where pk=3;
connection conn1;
commit;
connection conn2;
commit;
select * from t1;
