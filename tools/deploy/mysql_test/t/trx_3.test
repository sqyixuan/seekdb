--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: yuchen.wyc
# owner group: SQL1
# description: OUR GOAL: Make all this simple and effective!
--disable_warnings
drop table if exists t1,t2,t3,t4;
--enable_warnings


###
# insert within trx
##
create table t1(pk int primary key, a int);

connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn2,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn3,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn4,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);

connection conn1;
begin;
insert into t1 values(1,1);
insert into t1 values(2,1),(4,1);
select * from t1;

connection conn2;
begin;
insert into t1 values(3,1);
select * from t1;
--error 1205,4012
insert into t1 values(2,1),(4,1);
ROLLBACK;


connection conn1;
commit;

connection conn3;
select * from t1;

connection conn4;
begin;
--error 1062
insert into t1 values(1,1);
ROLLBACK;

drop table t1;



create table t1(pk varchar(1024) primary key, a varchar(1024));

insert into t1 values('1','1'),('0','1');

connection conn1;
begin;
insert into t1 values('2','1'),('3','1');

connection conn2;
begin;
insert into t1 values('4','1'),('5','1');

connection conn3;
begin;
--error 1205,4012
insert into t1 values('6','1'),('5','1');
select * from t1;
ROLLBACK;

connection conn1;
commit;
connection conn2;
commit;

select * from t1;
