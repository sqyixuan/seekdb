--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

#owner: linlin.xll
#owner group: SQL4
#description: 本case是为了测试除简单操作符之外的复杂一些的运算的优先级，是parser_precedence.test的补充
#tags: optimizer 

## this is supplement to parser_precedence.test
##test || when pipe_as_concat is disabled
##--disable_abort_on_error

select 0 between -2 and -1 || 0, (0 between -2 and -1) || 0,  0 between -2 and (-1 || 0);
select 0 || 5 between 1 and 4 , 0 || (5 between 1 and 4), (0 || 5) between 1 and 4;
select 0 not between -2 and -1 || 0, (0 not between -2 and -1) || 0,  0 not between -2 and (-1 || 0);
select 0 || 5 not between 1 and 4, 0 || (5 not between 1 and 4), (0 || 5) not between 1 and 4;
select 1 like 3 || 0, (1 like 3) || 0, 1 like (3 || 0);
select 1 || 0 like 0, 1 || (0 like 0), (1 || 0) like 0;
select 1 not like 3 || 0, (1 not like 3) || 0, 1 not like (3 || 0);
select 0 || 2 not like 1, 0 || (2 not like 1), (0 || 2) not like 1;
--error 1064
select 1 is (false || 1);
select 1 || 0 is false, 1 || (0 is false), (1 || 0) is false;
--error 1064
select 1 is not (false || 1);
select 1 || 0 is not true, 1 || (0 is not true), (1 || 0) is not true;
select 1 in (2) || 0, (1 in (2)) || 0, 1 in ((2) or 0);
select 2 || 0 in (0), 2 || (0 in (0)), (2 || 0) in (0);
select 1 not in (2) || 0, (1 not in (2)) || 0, 1 not in ((2) || 0);
select 0 || 7 not in (7), 0 || (7 not in (7)), (0 || 7) not in (7);
select 'David_' LIKE 'David0_' ESCAPE 1 || 1 as or_op_origin, ('David_' LIKE 'David0_' ESCAPE 1) || 1 as or_op_sec, 'David_' LIKE 'David0_' ESCAPE (1 || 1) as or_op_first;

##test not when high not precedence  is disabled
--error 1064
select !not 1;
select not 2 + 3, not 2 || 3, not 2 and 3, not 1 | 4, not 1 & 4, not 2 > 3,  not 1 like '0', not 1 is false, not 3 in (3, 0), not '11' rlike '%1', not 0 between -2 and 1;
select (not 2) + 3, (not 2) || 3, (not 2) and 3, (not 1) | 4, (not 1) & 4, (not 2) > 3,  (not 1) like '0', (not 1) is false, (not 3) in (3, 0), (not '11') rlike '%1', (not 0) between -2 and 1;
select not 0 * 2, not 2 / 2, not 2 DIV 2, not 4 ^ 4;
select (not 0) * 2, (not 2) / 2, (not 2) DIV 2, (not 4) ^ 4;

## test binary
--enable_metadata
select binary '123' * 4;
select (binary '123') * 4;
select binary ('123' * 4);
--disable_metadata

## enable sql_mode :PIPES_AS_CONCAT and HIGH_NOT_PRECEDENCE
let $variable_env = query_get_value(select @@session.sql_mode, @@session.sql_mode,1);
set @@session.sql_mode='PIPES_AS_CONCAT,HIGH_NOT_PRECEDENCE';
#test pipe as concat

select 1 || 2 && 0, 1 or 2 and 0, '2' || '4', 2 || 4;
select 1 ^ 2 || 4;
select !not 1;
select not 2 + 3, not 2 || 3, not 2 and 3, not 1 | 4, not 1 & 4, not 2 > 3,  not 1 like '0', not 1 is false, not 3 in (3, 0), not '11' rlike '%1', not 0 between -2 and 1;
select (not 2) + 3, (not 2) || 3, (not 2) and 3, (not 1) | 4, (not 1) & 4, (not 2) > 3,  (not 1) like '0', (not 1) is false, (not 3) in (3, 0), (not '11') rlike '%1', (not 0) between -2 and 1;
select not 0 * 2, not 2 / 2, not 2 DIV 2, not 4 ^ 4;
select (not 0) * 2, (not 2) / 2, (not 2) DIV 2, (not 4) ^ 4;
select not true is not unknown;

##  test precedence of escape
select 'David_' LIKE 'David0_' ESCAPE 0 or 1 as or_op_sec, 'David_' LIKE 'David0_' ESCAPE (0 or 1) as or_op_first, 'David_' LIKE 'David0_' ESCAPE 1 and 0 as and_op_sec, 'David_' LIKE 'David0_' ESCAPE (0 and 1) as and_op_first;
select 'David_' LIKE 'David0_' ESCAPE 1 && 0 as and_op_sec, 'David_' LIKE 'David0_' ESCAPE (0 && 1) as and_op_first;
select 'David_' LIKE 'David1_' ESCAPE  5 > 2 as GT_first,  ('David_' LIKE 'David|_' ESCAPE 5 ) > 2 as GT_second, 'David_' LIKE 'David1_' ESCAPE  (5 > 2) as GT_first;
--error 1064
select 'David_' LIKE 'David1_' ESCAPE 1 | 3 as or_first;
select 'David_' LIKE 'David1_' ESCAPE (1 | 3) as or_first,  ('David_' LIKE 'David1_' ESCAPE 1) | 3 as or_second;
--error 1064
select 'David_' LIKE 'David0_' ESCAPE 1 & 0 as and_first;
select 'David_' LIKE 'David0_' ESCAPE (1 & 0) as and_first, ('David_' LIKE 'David0_' ESCAPE 1) & 0 as and_sec;
--error 1064
SELECT 'David_' LIKE 'David1_' ESCAPE  1 + 4 as add_first;
select 'David_' LIKE 'David1_' ESCAPE  (1 + 4) as add_first, ('David_' LIKE 'David|_' ESCAPE 1 ) + 4 as add_second;
--error 1064
select 'David_' LIKE 'David1_' ESCAPE 3 - 2 as minus_first;
select 'David_' LIKE 'David1_' ESCAPE (3 - 2) as minus_first, ('David_' LIKE 'David1_' ESCAPE 3) - 2 as minus_second;
--error 1064
select 'David_' LIKE 'David1_' ESCAPE 1 * 7 as multi_first;
select 'David_' LIKE 'David1_' ESCAPE (1 * 7) as multi_first, ('David_' LIKE 'David1_' ESCAPE 1) * 7 as multi_sec;
--error 1064
select 'David_' LIKE 'David3_' ESCAPE 6 / 2 as div_first;
--error 1210
select 'David_' LIKE 'David3_' ESCAPE (6 / 2) as div_first;
select ('David_' LIKE 'David3_' ESCAPE 6) / 2 as div_sencord;
select 'David_' LIKE 'David|_' ESCAPE '' || '|' as concat_first, 'David_' LIKE 'David|_' ESCAPE ('' || '|') as concat_first, ('David_' LIKE 'David|_' ESCAPE '') || '|' as concat_second;
--error 1064
select 'David_' LIKE 'David0_' ESCAPE 3 ^ 2 as xxor_first;
select 'David_' LIKE 'David0_' ESCAPE (3 ^ 2) as xxor_first, ('David_' LIKE 'David0_' ESCAPE 3) ^ 2 as xxor_sencord;


## test precedence of between
select -1 between -2 and 0 between -1 and 1 and 0,   -1 between -2 and (0 between -1 and 1 and 0), (-1 between -2 and 0) between -1 and 1 and 0 , -1 between -2 and (0 between -1 and 1) and 0;
select 5 between 1 and 7 && 1, (5 between 1 and 7) && 1, 5 between 1 and (7 && 1), 5 between 1 and 7 and 1, (5 between 1 and 7) and 1, 5 between 1 and (7 and 1), 0 between -2 and -1 or 0, (0 between -2 and -1) or 0, 0 between -2 and (-1 or 0);
select 1 between -2 and 3 >2, 1 between -2 and (3 >2), (1 between -2 and 3) >2, 1 between -2 and 3 = 3, 1 between -2 and (3 = 3), (1 between -2 and 3)  = 3;
select 1 between -2 and -1 like '-1', 1 between -2 and (-1 like '-1'), (1 between -2 and -1) like '-1', 1 between -2 and -1 rlike '1', 1 between -2 and (-1 rlike '1'), (1 between -2 and -1) rlike '1';
select 2 between -2 and 3 is true, 2 between -2 and (3 is true), (2 between -2 and 3) is true, 1 between -2 and -1 in (0), 1 between -2 and (-1 in (0)), (1 between -2 and -1) in (0);
select 1 between -2 and -1 not like '-1', 1 between -2 and (-1 not like '-1'), (1 between -2 and -1) not like '-1', 1 between -2 and -1 not rlike '1', 1 between -2 and (-1 not rlike '1'), (1 between -2 and -1) not rlike '1';
select 2 between -2 and 3 is not false, 2 between -2 and (3 is not false), (2 between -2 and 3) is not false, 1 between -2 and -1 not in (0), 1 between -2 and (-1 not in (0)), (1 between -2 and -1) not in (0);
select 5 between -3 and 1 | 4, 5 between -3 and (1 | 4), (5  between -3 and 1) | 4, 3 between -3 and 3 & 1, 3  between -3 and (3 & 1), (3  between -3 and 3) & 1;
select 5 between -3 and 1 + 4, 5 between -3 and (1 + 4), (5  between -3 and 1) + 4, 3 between -3 and 3 - 2, 3  between -3 and (3 - 2), (3  between -3 and 3) - 2;
select 5 between -3 and 1 * 5, 5 between -3 and (1 * 5), (5  between -3 and 1) * 5, 3 between -3 and 9 / 3, 3 between -3 and (9 / 3), (3  between -3 and 9) / 3;
select 5 between -3 and 22 % 10, 5  between -3 and (22 % 10), (5 between -3 and 22) % 10, 5 between -3 and 22 MOD 10, 5 between -3 and (22 MOD 10), (5 between -3 and 22) MOD 10;
select 3 between -3 and 9 DIV 3, 3 between -3 and (9 DIV 3), (3 between -3 and 9) DIV 3;
select 5 between -3 and 1 ^ 5, 5 between -3 and (1 ^ 5), (5  between -3 and 1) ^ 5, 5 between -3 and 6 || 2, 5 between -3 and (6 || 2), (5 between -3 and 6) || 2;

select 1 && 5 between 1 and 4, 1 && (5 between 1 and 4), (1 && 5) between 1 and 4, 1 and 5 between 1 and 4, 1 and (5 between 1 and 4), (1 and 5) between 1 and 4, 0 or 5 between 1 and 4 , 0 or (5 between 1 and 4), (0 or 5) between 1 and 4;
select 2 > 4 between 1 and 5, (2 > 4) between 1 and 5 , 2 > (4 between 1 and 5), 1 = 3 between 2 and 4, (1 = 3) between 2 and 4, 1 = (3 between 2 and 4);
--error 1064
select 1 like 3 between 2 and 4;
--error 1064
select 1 rlike 3 between 2 and 4;
select (1 like 3) between 2 and 4 , 1 like (3 between 2 and 4), (1 rlike 3) between 2 and 4 , 1 rlike (3 between 2 and 4);
--error 1064
select 1 not like 3 between 2 and 4;
--error 1064
select 1 not rlike 3 between 2 and 4;
select (1 not like 5) between 2 and 4 , 1 not like (5 between 2 and 4), (1 not rlike 5) between 2 and 4 , 1 not rlike (5 between 2 and 4);
--error 1064
select 0 is not true between -2 and -1;
--error 1064
select 0 is not (true  between -2 and -1);
select (0 is not true) between -2 and -1;

select 1 | 5  between -3 and 1, (1 | 5)  between -3 and 1, 1 | (5  between -3 and 1),  1 & 3  between -3 and 2, (1 & 3) between -3 and 2, 1 & (3  between -3 and 2);
select 1 + 5  between -3 and 1, (1 + 5) between -3 and 1, 1 + (5  between -3 and 1), 3 - 2 between -3 and 3, (3 - 2) between -3 and 3, 3 - (2  between -3 and 3);
select 2 * 5  between -3 and 6, (2 * 5)  between -3 and 6, 2 * (5  between -3 and 6),  10 / 2  between 1 and 4, (10 / 2) between 1 and 4, 10 / (2  between 1 and 4);
select 2 % 5  between -3 and 4, (2 % 5) between -3 and 4, 2 % (5  between -3 and 4), 2 MOD 5  between -3 and 4, (2 MOD 5) between -3 and 4, 2 MOD (5  between -3 and 4);
select 10 DIV 2 between 1 and 4, (10 DIV 2) between 1 and 4, 10 DIV (2  between 1 and 4);
select 2 ^ 5  between -3 and 6, (2 ^ 5)  between -3 and 6, 2 ^ (5  between -3 and 6), 2 || 5  between -3 and 6, (2 || 5) between -3 and 6, 2 || (5  between -3 and 6);

select 5 not between 1 and 7 && 1, (5 not between 1 and 7) && 1, 5 not between 1 and (7 && 1), 5 not between 1 and 7 and 1, (5 not between 1 and 7) and 1, 5 not between 1 and (7 and 1), 0 not between -2 and -1 or 0, (0 not between -2 and -1) or 0,  0 not between -2 and (-1 or 0);
select 1 not between -2 and 2 > 3, (1 not between -2 and 2) > 3, 1 not between -2 and (2 > 3), 1 not between 4 and 5 = 5, 1 not between 4 and (5 = 5), (1 not between 4 and 5)  = 5;
select 0 not between -2 and 4 like '0', 0 not between -2 and (4 like '0'), (0 not between -2 and 1) like '0', 1 not between -2 and -1 rlike '%1', 1 not between -2 and (-1 rlike '%1'), (1 not between -2 and -1) rlike '%1';
select 2 not between -2 and 3 is true, 2 not between -2 and (3 is true), (2 not between -2 and 3) is true, 1 not between -2 and -1 in (0), 1 not between -2 and (-1 in (0)), (1 not between -2 and -1) in (0);
select 0 not between -2 and 4 not like '4', 0 not between -2 and (4 not like '4'), (0 not between -2 and 1) not like '4', 1 not between -2 and -1 not rlike '%1', 1 not between -2 and (-1  not rlike '%1'), (1 not between -2 and -1) not rlike '%1';
select 2 not between -2 and 3 is true, 2 not between -2 and (3 is true), (2 not between -2 and 3) is true, 1 not between -2 and -1 in (0), 1 not between -2 and (-1 in (0)), (1 not between -2 and -1) in (0);
select 5 not between -3 and 1 | 4, 5 not between -3 and (1 | 4), (5 not between -3 and 1) | 4, 3 not between -3 and 3 & 1, 3  not between -3 and (3 & 1), (3 not between -3 and 3) & 1;
select 5 not between -3 and 1 + 4, 5 not between -3 and (1 + 4), (5 not between -3 and 1) + 4, 3 not between -3 and 3 - 2, 3 not between -3 and (3 - 2), (3 not between -3 and 3) - 2;
select 5 not between -3 and 1 * 5, 5 not between -3 and (1 * 5), (5 not between -3 and 1) * 5, 3 not between -3 and 9 / 3, 3 not between -3 and (9 / 3), (3 not between -3 and 9) / 3;
select 5 not between -3 and 11 % 5, 5 not between -3 and (11 % 5), (5 not between -3 and 11) % 5;
select 3 not between -3 and 9 DIV 3, 3 not between -3 and (9 DIV 3), (3 not between -3 and 9) DIV 3;
select 5 not between -3 and 1 ^ 5, 5 not between -3 and (1 ^ 5), (5  not between -3 and 1) ^ 5,  5 not between -3 and 6 || 2,5 not between -3 and (6 || 2), (5  not between -3 and 6) || 2;

select 1 and 5 not between 1 and 4, 1 and (5 not between 1 and 4), (1 and 5) not between 1 and 4, 1 && 5 not between 1 and 4, 1 && (5 not between 1 and 4), (1 && 5) not between 1 and 4, 0 or 5 not between 1 and 4, 0 or (5 not between 1 and 4), (0 or 5) not between 1 and 4;
select 4 > 2 not between 1 and 5, (4 > 2) not between 1 and 5 , 4 > (2 not between 1 and 5), 5 = 5 not between 2 and 4, (5 = 5) not between 2 and 4, 5 = (5 not between 2 and 4);
--error 1064
select 1 like 3 not between 2 and 4;
--error 1064
select 1 rlike 3 not between 2 and 4;
--error 1064
select 0 is 1 not between -2 and -1;
--error 1064
select 0 is (1  not between -2 and -1);
--error 1064
select 1 not like 3 not between 2 and 4;
--error 1064
select 1 not rlike 3 not between 2 and 4;
--error 1064
select 0 is not 1 not between -2 and -1;
--error 1064
select 0 is not (1  not between -2 and -1);
select 2 | 5 not between -3 and 1, (2 | 5) not between -3 and 1, 2 | (5  not between -3 and 1), 1 & 3  not between -3 and 2, (1 & 3)  not between -3 and 2, 1 & (3  not between -3 and 2);
select 1 + 5 not between -3 and 1, (1 + 5) not between -3 and 1, 1 + (5  not between -3 and 1), 3 - 2 not between -3 and 3,  (3 - 2) not between -3 and 3, 3 - (2  not between -3 and 3);
select 2 * 5 not between -3 and 6, (2 * 5) not between -3 and 6, 2 * (5  not between -3 and 6), 10 / 2  not between 1 and 4, (10 / 2)  not between 1 and 4,  10 / (2  not between 1 and 4);
select 2 % 5 not between -3 and 6, (2 % 5) not between -3 and 6, 2 % (5 not between -3 and 6), 2 MOD 5 not between -3 and 6, (2 MOD 5) not between -3 and 6, 2 MOD (5 not between -3 and 6);
select 10 DIV 2 not between 1 and 4, 10 DIV 2 not between 1 and 4, 10 DIV (2 not between 1 and 4);
select 2 ^ 5  not between -3 and 6, (2 ^ 5)  not between -3 and 6, 2 ^ (5  not between -3 and 6),  2 || 5 not between -3 and 6, (2 || 5) not between -3 and 6, 2 || (5 not between -3 and 6);

## test precedence of like
select 1 like 3 or 0, (1 like 3) or 0, 1 like (3 or 0),  1 like 3 and 1, (1 like 3) and 1, 1 like (3 and 1), 1 like 3 && 1, (1 like 3) && 1, 1 like (3 && 1);
select 1 like 3 > 0, (1 like 3) > 0, 1 like (3 > 0), 1 like 3 = 3, (1 like 3) = 3, 1 like (3 = 3);
--error 1064
select 1 like 3 rlike 0;
select 1 like (3 rlike 0), (1 like 3) rlike 0;
--error 1064
select 1 like 3 not rlike 0;
select 1 like (3 not rlike 0), (1 like 3) not rlike 0;
--error 1064
select 1 like 3 is ture;
--error 1064
select (1 like 3) is ture;
select 1 like (3 is true);
--error 1064
select 1 like 3 is not ture;
--error 1064
select (1 like 3) is not ture;
select 1 like (3 is not true);
--error 1064
select 1 like 3 in (3);
select (1 like 3) in (3), 1 like (3 in (3));
--error 1064
select 1 like 3 not in (3);
select (1 like 3) not in (3), 1 like (3 not in (3));
--error 1064
select 1 like 0 | 3;
select 1 like (0 | 3), (1 like 0) | 3;
--error 1064
select 1 like 3 & 1;
select (1 like 3) & 1, 1 like (3 & 1);
--error 1064
select 1 like 0 + 3;
select (1 like 0) + 3, 1 like (0 + 3);
--error 1064
select 1 like 3 - 1;
select 1 like (3 - 1), (1 like 3) - 1;
--error 1064
select 1 like 1 * 3;
select 1 like (1 * 3), (1 like 1) * 3;
--error 1064
select 3 like 6 / 2;
## here is not true
select 3 like (6 / 2), (3 like 6) / 2;
--error 1064
select 1 like 1 ^ 3;
select 1 like (1 ^ 3), (1 like 1) ^ 3;
select 3 like 3 || 2, 3 like (3 || 2), (3 like 3) || 2;

select 1 or 0 like 0, 1 or (0 like 0), (1 or 0) like 0,  1 and 4 like 1, 1 and (4 like 1), (1 and 4) like 1, 1 && 4 like 1, 1 && (4 like 1), (1 && 4) like 1;
select 0 < 2 like 1, (0 < 2) like 1, 0 < (2 like 1), 1 = 3 like 3, (1 = 3) like 3, 1 = (3 like 3);
--error 1064
select 1 rlike 3 like 3;
select (1 rlike 3) like 3, 1 rlike (3 like 3);
--error 1064
select 1 not rlike 3 like 3;
select (0 not rlike 3) like 3, 0 not rlike (3 like 3);
--error 1064
select 1 is false like 7;
--error 1064
select 1 is (true like 3);
--error 1064
select 1 is (true like 3);
select (1 is true) like 3;
--error 1064
select 1 is not (true like 3);
--error 1064
select 1 is not (true like 3);
select (1 is not true) like 3;

--error 1064
select 3 in (3) like 3;
select (3 in (3)) like 1, 3 in ((3) like 1);
select 1 | 3 like 2, (1 | 3) like 2, 1 | (3 like 2), 1 & 3 like 3, (1 & 3) like 3, 1 & (3 like 3);
select 3 + 1 like 0, (3 + 1) like 0, 3 + (1 like 0), 3 - 1 like 3, (3 - 1) like 3, 3 - (1 like 3);
select 3 * 1 like 1, (3 * 1) like 1, 3 * (1 like 1), 6 / 2 like 2, (6 / 2) like 2, 6 / (2 like 2);
select 3 % 6 like 3, (3 % 6) like 3, 3 % (6 like 3), 3 MOD 6 like 3, (3 MOD 6) like 3, 3 MOD (6 like 3);
select 6 DIV 2 like 2, (6 DIV 2) like 2, 6 DIV (2 like 2);
select 3 ^ 1 like 1, (3 ^ 1) like 1, 3 ^ (1 like 1), 2 || 3 like 3, (2 || 3) like 3, 2 || (3 like 3);

select 1 not like 3 or 0, (1 not like 3) or 0, 1 not like (3 or 0),  1 not like 3 and 1, (1 not like 3) and 1, 1 not like (3 and 1);
select 1 not like 3 > 0, (1 not like 3) > 0, 1 not like (3 > 0), 3 not like 3 = 1, (3 not like 3) = 1, 3 not like (3 = 3);
--error 1064
select 1 not like 3 rlike 0;
select (1 not like 3) rlike 0, 1 not like (3 rlike 0);
--error 1064
select 1 not like 3 not rlike 0;
select (1 not like 3) not rlike 0, 1 not like (3 not rlike 0);
--error 1064
select 1 not like 3 is ture;
--error 1064
select (1 not like 3) is ture;
select 1 not like (3 is true);
--error 1064
select 1 not like 3 is not ture;
--error 1064
select (1 not like 3) is not ture;
select 1 not like (3 is not true);
--error 1064
select 1 not like 3 in (3);
select (3 not like 3) in (3), 3 not like (3 in (3));
--error 1064
select 1 not like 3 not in (3);
select (3 not like 2) not in (1), 3 not like (2 not in (1));
--error 1064
select 1 not like 0 | 3;
select (1 not like 0) | 3, 1 not like (0 | 3);
--error 1064
select 1 not like 0 & 3;
select (1 not like 3) & 1, 1 not like (3 & 1);
--error 1064
select 1 not like 0 + 3;
select (1 not like 0) + 3, 1 not like (0 + 3);
--error 1064
select 1 not like 3 - 1;
select (1 not like 3) - 1, 1 not like (3 - 1);
--error 1064
select 1 not like 1 * 3;
select (1 not like 1) * 3, 1 not like (1 * 3);
--error 1064
select 3 not like 6 / 2;
select (3 not like 6) / 2, 3 not like (6 / 2);
--error 1064
select 1 not like 1 ^ 3;
select (1 not like 1) ^ 3, 1 not like (1 ^ 3);
select 3 not like 3 || 2, 3 not like (3 || 2), (3 not like 3) || 2;

select 0 or 3 not like 1, 0 or (3 not like 1), (0 or 3) not like 1, 1 and 4 not like 1, 1 and (4 not like 1), (1 and 4) not like 1, 1 && 4 not like 1, 1 && (4 not like 1), (1 && 4) not like 1;
select 0 < 2 not like 1, (0 < 2) not like 1, 0 < (2 not like 1), 1 = 3 not like 3, (1 = 3) not like 3, 1 = (3 not like 3);
--error 1064
select 1 rlike 3 not like 3;
select (1 rlike 3) not like 3, 1 rlike (3 not like 3);
--error 1064
select 1 not rlike 3 not like 3;
select (0 not rlike 3) not like 0, 0 not rlike (3 not like 0);
--error 1064
select 1 is false not like 7;
--error 1064
select 1 is (true not like 3);
select (1 is true) not like 3;
--error 1064
select 1 is not false not like 7;
--error 1064
select 1 is not (true not like 3);
select (1 is not true) not like 3;
--error 1064
select 3 in (3) not like 3;
select (3 in (3)) not like 3, 3 in ((3) not like 3);

select 2 | 3 not like 2, (2 | 3) not like 2, 2 | (3 not like 2), 2 & 3 not like 3, (2 & 3) not like 3, 2 & (3 not like 3);
select 3 + 1 not like 0, (3 + 1) not like 0, 3 + (1 not like 0), 3 - 1 not like 3, (3 - 1) not like 3, 3 - (1 not like 3);
select 3 * 1 not like 1, (3 * 1) not like 1, 3 * (1 not like 1), 6 / 2 not like 2, (6 / 2) not like 2, 6 / (2 not like 2);
select 3 % 1 not like 1, (3 % 1) not like 1, 3 % (1 not like 1), 3 MOD 1 not like 1, (3 MOD 1) not like 1, 3 MOD (1 not like 1);
select 6 DIV 2 not like 2, (6 DIV 2) not like 2, 6 DIV (2 not like 2);
select 3 ^ 1 not like 1, (3 ^ 1) not like 1, 3 ^ (1 not like 1), 2 || 3 not like 3, (2 || 3) not like 3, 2 || (3 not like 3);

## test precedence of rlike
select 1 rlike 3 or 0, (1 rlike 3) or 0, 1 rlike (3 or 0),  1 rlike 3 and 1, (1 rlike 3) and 1, 1 rlike (3 and 1), 1 rlike 3 && 1, (1 rlike 3) && 1, 1 rlike (3 && 1);
select 1 rlike 3 > 0, (1 rlike 3) > 0, 1 rlike (3 > 0), 1 rlike 3 = 3, (1 rlike 3) = 3, 1 rlike (3 = 3);
--error 1064
select 1 rlike 3 rlike 0;
select 1 rlike (3 rlike 0), (1 rlike 3) rlike 0;
--error 1064
select 1 rlike 3 not rlike 0;
select 1 rlike (3 not rlike 0), (1 rlike 3) not rlike 0;
--error 1064
select 1 rlike 3 is ture;
--error 1064
select (1 rlike 3) is ture;
select 1 rlike (3 is true);
--error 1064
select 1 rlike 3 is not ture;
--error 1064
select (1 rlike 3) is not ture;
select 1 rlike (3 is not true);
--error 1064
select 1 rlike 3 in (3);
select (1 rlike 3) in (3), 1 rlike (3 in (3));
--error 1064
select 1 rlike 3 not in (3);
