####bug:
####after rename col,the comment on this col is lost
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(pk int primary key , c1 varchar(20) comment '列1') ;
desc t1;
--error 1064
alter table t1 rename c1 to col1;
sleep 1;
desc t1;
