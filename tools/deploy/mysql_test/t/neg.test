####test:连续执行多次
--disable_query_log
let $loop=50;
while  ($loop)
{

  select neg(pk-100) from tbl1 where pk=10;
  SELECT neg(-10);
  eval select neg(0-$loop * 133 *2);
  dec $loop;
}
--enable_query_log
drop table tbl1;
