--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: link.zt
#owner group: sql1

#####增加neg的case；
####neg 表达式
select neg(1+2+3-4-1-2+5-5);
select neg(neg(1+2+3-4-1-2+5-5)-neg(-3));
select neg(true and false);
select neg(true and true);
select neg(false or true);
select neg(false or false);
##包含字符相关的函数
select neg(length('aggfagdf')-length('35q45q45tdgtsrfg'));
select neg(length(substr('35q45q45tdgtsrfg',1,5)));  
select neg(0-length(substr('35q45q45tdgtsrfg',1,5))); 
##包含时间相关的函数
select neg(time_to_usec(now())-time_to_usec(DATE_ADD(current_timestamp(), INTERVAL 5 DAY))); 
select neg(time_to_usec(now())-time_to_usec(DATE_ADD(current_timestamp(), INTERVAL -5 DAY))); 
##对十六进行进行neg
select neg(hex('0x3'));
select neg(hex('0X3'));
##运算
select neg(-2) * -2;
###加别名
SELECT neg(1.0) AS "1.0的绝对值",neg(0.0) AS "0.0的绝对值",neg(-1.0) AS "-1.0的绝对值";
###from dual
SELECT neg(-17.36)   from dual;
SELECT neg(null)   from dual;

####neg 隐式类型转换
select neg('1');
select neg('100');
select neg('-100');
select neg('-100.001');
select neg(cast(-1.21 as decimal(10,5)));
select neg(cast(-1.21 as char(1024)));
select neg(cast(-1.21 as decimal(5,3)));
select neg(cast(-1.21 as numeric));
select neg(true);
select neg(false);
select neg(true);
select neg(true);
select neg(false);
select neg(ROW(1,2)<ROW(1, 3));
select neg(date'2014-10-09 10:00:00');

####neg 不合法类型
select neg('-abcd');
select neg('2014-10-09 10:00:00');
####neg 合法类型，科学计数法
select neg(10e1);
####neg,不合法的参数个数
--error 1582
select neg(1,-2);
####test边界值
SELECT neg(-9223372036854775808);
select neg(10/0);
select neg(-9999999999999999999999);
select neg(9999999999999999999999);

####test:测试对表的操作
--source mysql_test/include/index_quick_major.inc
--disable_warnings
drop table if exists tbl1;
--enable_warnings
create table tbl1 (pk int,i1 int, v2 varchar(80), i3 char(20),i4 float, d4 datetime(6),i5 decimal(5,3),i6 bool, primary key(pk));
insert into tbl1 values(1,1,'abc12','1agc',1.25,'2014-01-01 12:00:00',23.23,1),
                       (2,10,'23abc12','4agc1',-0.25,'2015-11-01 12:00:00',-23.230,0),
                       (-3,201,'xx23abc12','cagc1',-2.25,'2015-11-21 11:20:10',3.231,1),
                       (4,80,'zx23abc12','zcagc1',2.25,'2013-01-21 11:20:10',-3.231,1),
                       (-5,53,'cx23abc12','rcagc1',109.25,'2016-01-22 11:20:10',-13.131,0),
                       (6,78,'tx23abc12','icagc1',-109.25,'2014-09-16 16:24:00',-13.531,1),
                       (7,-400,'yx23abc12','ocagc1',85.85,'2014-09-17 16:20:21',-93.131,0),
                       (-8,50,'vx23abc12','wcagc1',-85.85,'2014-09-10 16:20:21',93.131,1),
                       (9,-610000,'ukx23abc12','pecagc1',-1.85,'2014-09-19 16:20:21',99.131,0),
                       (-10,-42,'kx23abc12','ecagc1',-85.86,'2014-09-18 16:20:21',-99.131,1),
                       (11,null,null,null,null,null,null,null);
create unique index idx_1 on tbl1(i1);
--source mysql_test/include/check_all_idx_ok.inc
select neg(pk),neg(i1),neg(i4),neg(i5) from tbl1;
select i1-i4,neg(i1-i4) from tbl1; 
select * from tbl1 where neg(i1-i4)<100;
select * from tbl1 where neg(i1-i4)<0;
update tbl1 set i1=neg(i1);
update tbl1 set i1=neg(i1)-100;
select neg(i1)-i1 from tbl1; 
select neg(count(*)) from tbl1;
select neg(max(i1)-min(i1)) from tbl1;
select neg(max(i1)-min(i1)) from tbl1;
select neg(min(i1)-max(i1)) from tbl1;  
select * from tbl1 where neg(pk)=neg(-10);
select CASE neg(i1)  when 10  then 'true' else 'false' END from tbl1;
select CASE neg(i1)  when 90  then 'true' else 'false' END from tbl1; 
select  distinct neg(i5) from tbl1; 
select  distinct neg(i5) as dis from tbl1;
select neg(pk-100) from tbl1;
