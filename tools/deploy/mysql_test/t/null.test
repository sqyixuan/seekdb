--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: bin.lb
# owner group: SQL2
# tags: dml
# description:
#
--disable_warnings
drop table if exists t1,t2,t3,t4;
--enable_warnings

create table t1(pk int primary key,extra int);

insert into t1(pk) values(1),(2);
select * from t1;

insert into t1(pk,extra) values(3,NULL),(4,NULL);
select * from t1;

insert into t1(pk,extra) values(5,NULL);
select * from t1;


select * from t1 where extra = NULL;
select * from t1 where extra != NULL;
select * from t1 where extra is NULL;
select * from t1 where extra is not NULL;
select * from t1 where pk is NULL;
select * from t1 where pk = NULL;
select * from t1 where pk != NULL;
select * from t1 where pk is not  NULL;

select * from t1 where pk in (NULL);
select * from t1 where pk in (NULL,1);


select * from t1 where null > null;
select * from t1 where null < null;
select * from t1 where null = null;
select * from t1 where null > 1;
select * from t1 where null < 1;
select * from t1 where null is null;


update t1 set extra=1 where pk = NULL;
select * from t1;
update t1 set extra=1 where pk != NULL;
select * from t1;
update t1 set extra=1 where pk is NULL;
select * from t1;
update t1 set extra=1 where pk is not NULL;
select * from t1;

delete from t1 where pk = NULL;
select * from t1;

delete from t1 where pk != NULL;
select * from t1;
delete from t1 where pk is NULL;
select * from t1;
delete from t1 where pk is not NULL;
select * from t1;

drop table t1;

####增加一列非空属性列，并通过修改列属性使得默认值变为null
--disable_warnings
drop table if exists test;
--enable_warnings
create table test(a int  primary key,b int );
insert into test values(1,null),(2,null);
alter table test add column   c3  int not null default 0;
sleep 1;
select * from test;
--error 1067
alter table test alter   c3 set  default null;
sleep 1;
select * from test;
select * from test where c3 is null;
alter table test add column   c4  varchar(20) not null default 'abc';
sleep 1;
select * from test;
--error 1067
alter table test alter  c3 set  default null;
sleep 1;
--error 1067
alter table test alter  c4 set  default null;
sleep 1;
alter table test alter  c3 set  default 1;
alter table test add column c5 varchar(20);
select * from test where c4 is null;
create index idx1 on test(c3);
create index idx2 on test(c4);
create index idx3 on test(c5);
--source mysql_test/include/check_all_idx_ok.inc
####this is a bug BUG
update test set c3=4 where c3 is null;
select * from test;
update test set b= 4 where b is null;
####this is a bug BUG
update test set c5='hello'  where c5 is null;
select * from test;
drop table test;
