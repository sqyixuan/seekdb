--enable_query_log

replace into t1 values(1,1,1,1,1),(1,2,1,1,1),(1,3,2,1,1),(1,4,2,1,1),(2,5,3,1,1),(2,6,3,1,1),(2,7,4,1,1),(2,8,4,1,1);
delete from t1 where b=1;
select * from t1;
--disable_query_log
eval select * from $idx11;
eval select * from $idx12;
eval select * from $idx13;
eval select * from $idx14;
--enable_query_log

drop table t1;
