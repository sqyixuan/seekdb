drop table if exists tt;
create table tt (x char(6));
insert into tt values(0xE6B189E5AD97);
select hex(x) from tt;
replace into tt values(0xE6B189E5AD);
select hex(x) from tt;
replace into tt values(0xE6B189E5AD);
select hex(x) from tt;
insert into tt values(0xE6B18);
select hex(x) from tt;
replace into tt values(0xE6B1);
select hex(x) from tt;
drop table tt;
