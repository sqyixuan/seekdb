--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: shouju.zyp 
# owner group: SQL2
# tags: ddl
# description:
#

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);

connection obsys;

alter system set enable_sys_table_ddl = true;
sleep 2;
use oceanbase;

#modify __all_column
desc __all_column;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table __all_column;

--disable_query_log
let $column_id = query_get_value(select (max_used_column_id + 1) as column_id from oceanbase.__all_virtual_core_all_table where table_name = "__all_column", column_id, 1);
eval alter table __all_column add column c1 int id $column_id;

let $column_id = query_get_value(select (max_used_column_id + 1) as column_id from oceanbase.__all_virtual_core_all_table where table_name = "__all_column", column_id, 1);
eval alter table __all_column add column c2 varchar(100) id $column_id;

let $column_id = query_get_value(select (max_used_column_id + 1) as column_id from oceanbase.__all_virtual_core_all_table where table_name = "__all_column", column_id, 1);
eval alter table __all_column add column c3 int default 100 id $column_id;

let $column_id = query_get_value(select (max_used_column_id + 1) as column_id from oceanbase.__all_virtual_core_all_table where table_name = "__all_column", column_id, 1);
eval alter table __all_column add column c4 varchar(100) default 'kaka' id $column_id;
--enable_query_log

desc __all_column;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table __all_column;

select count(1)>1 from __all_core_table where table_name = '__all_column' and column_name = 'c1';
select count(1)>1 from __all_core_table where table_name = '__all_column' and column_name = 'c2';
select count(1)>1 from __all_core_table where table_name = '__all_column' and column_name = 'c3';
select count(1)>1 from __all_core_table where table_name = '__all_column' and column_name = 'c4';

alter system set enable_sys_table_ddl = false;
