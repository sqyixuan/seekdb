delete from timeout_000 where ((trade_no = '1111') AND (paytype = 'payt') AND ((gmt_occur is null) or (gmt_occur < now())));
update timeout_remind_000 set end_time=date_add(end_time,INTERVAL -60 SECOND) ,action='d' , status='u', gmt_modified=current_timestamp() where trade_no='11111';
update timeout_long_000 set user_id='userId', paytype='paytype', end_time=current_timestamp(), action='ac', parameter='parameter', status='s', action_type='actionType', PRIOR_LEVEL='priorLevel', gmt_modified=current_timestamp() where ((trade_no = 'tradeNo') AND (paytype = 'paytype'));




