# owner group: sql1
# tags: optimizer
# description:
#

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
drop database if exists hualong;
--enable_warnings
create database hualong;
use hualong;

create table t_abc (a int primary key, b int, c int, index idx_b(b), unique idx_c(c));
insert into t_abc values (1, 1, 10), (11, 1, 100), (111, 1, 1000), (2, 2, 20), (22, 2, 200), (222, 2, 2000), (3, NULL, NULL), (33, NULL, NULL), (333, NULL, NULL);
create table t_xyz (x int primary key, y int, z int, index idx_y(y), unique idx_z(z)); 
insert into t_xyz values (1, 1, 10), (11, 1, 100), (111, 1, 1000), (2, 2, 20), (22, 2, 200), (222, 2, 2000), (3, NULL, NULL), (33, NULL, NULL), (333, NULL, NULL);

--echo 
--echo ---------------------------------------------------
## primary key so can trans to inner join
let $query = select * from t_abc where b in (select x from t_xyz) order by a;
let $no_rewrite_query = select /*+no_rewrite()*/ * from t_abc where b in (select x from t_xyz) order by a;
eval explain $query;
eval explain $no_rewrite_query;
eval $query;
eval $no_rewrite_query;


--echo 
--echo ---------------------------------------------------
## unique key, so can trans to inner join
let $query = select * from t_abc where b in (select z from t_xyz) order by a;
let $no_rewrite_query = select /*+no_rewrite()*/ * from t_abc where b in (select z from t_xyz) order by a; 
eval explain $query;
eval explain $no_rewrite_query;
eval $query;
eval $no_rewrite_query;


--echo 
--echo ---------------------------------------------------
let $query = select * from t_abc where b in (select distinct b from t_xyz) order by a;
let $no_rewrite_query = select /*+no_rewrite()*/ * from t_abc where b in (select distinct b from t_xyz) order by a;
eval explain $query;
eval explain $no_rewrite_query;
eval $query;
eval $no_rewrite_query;

--echo 
--echo ---------------------------------------------------
let $query = select * from t_abc where b in (select distinct b from t_xyz) order by a;
let $no_rewrite_query = select /*+no_rewrite()*/ * from t_abc where b in (select distinct b from t_xyz) order by a;
eval explain $query;
eval explain $no_rewrite_query;
eval $query;
eval $no_rewrite_query;

--echo
--echo ---------------------------------------------------
let $query = select * from t_abc where b in (select distinct a + y from t_xyz) order by a;
let $no_rewrite_query = select /*+no_rewrite()*/ * from t_abc where b in (select distinct a + y from t_xyz) order by a;
eval explain $query;
eval explain $no_rewrite_query;
eval $query;
eval $no_rewrite_query;

--echo
--echo ---------------------------------------------------
let $query = select * from t_abc where 1 in (select x from t_xyz) order by a;
let $no_rewrite_query = select /*+no_rewrite()*/ * from t_abc where 1 in (select x from t_xyz) order by a;
eval explain $query;
eval explain $no_rewrite_query;
eval $query;
eval $no_rewrite_query;

--echo
--echo ---------------------------------------------------
let $query = select * from t_abc where a in (select y from t_xyz group by y) order by a;
let $no_rewrite_query = select /*+no_rewrite()*/ * from t_abc where a in (select y from t_xyz group by y) order by a;
eval explain $query;
eval explain $no_rewrite_query;
eval $query;
eval $no_rewrite_query;

--echo
--echo ---------------------------------------------------
let $query = select * from t_abc where a in (select x from t_xyz where a = 1 and y = 100) order by a;
let $no_rewrite_query = select /*+no_rewrite()*/ * from t_abc where a in (select x from t_xyz where a = 1 and y = 100) order by a;
eval explain $query;
eval explain $no_rewrite_query;
eval $query;
eval $no_rewrite_query;

--echo
--echo ---------------------------------------------------
let $query = select * from t_abc where a in (select x from t_xyz where a = y and z < 100) order by a;
let $no_rewrite_query = select /*+no_rewrite()*/ * from t_abc where a in (select x from t_xyz where a = y and z < 100) order by a;
eval explain $query;
eval explain $no_rewrite_query;
eval $query;
eval $no_rewrite_query;






##子表带join
#explain select * from t1 where t1.c1 in (select a + x from t2 join t3 on a = x);

##外层不是一列
#explain select * from t1, t3 where c1 + x in (select a from t2);

###左手包含列，右手的select包含子查询的列，或者contion包含当前层和上一层的条件
#explain select * from t1 where c1 in (select a + c1 from t2);
#explain select * from t1 where c1 = any (select 1 from t2 where t1.c1 = t2.a);

#explain select * from t1 where c1 in (select 1 from t2 where t1.c1 = t2.a);
#explain select * from t1 where c1 = any (select 1 from t2 where t1.c1 = t2.a);

###左手不包含列，右手的select或condition包含当前层和上一层的条件
#explain select * from t1 where 1 in (select a + c1 from t2);
#explain select * from t1 where 1 in (select 1+1 from t2 where t1.c1 = t2.a);

##exist 子查询必须有相关的连接条件
#explain select * from t1 where exists (select t2.b from t2 where t1.c1 = t2.a);

### 子查询
#explain select * from t1 where c1 in (select a from (select * from t2) as v );
#explain select * from t1 where c1 in (select x from (select a + 1 as x from t2) as v);

#explain select * from t1 where c1 in (select distinct a from (select * from t2));



set @@recyclebin = 'off';
drop database hualong;
