--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner : zhenjiang.xzj
#owner group : storage
#tags: query

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1 (c1 int primary key, c2 text, c3 varchar(30), c4 int);
insert into t1 values(1, "22", "3333", 4444);
select c4 from t1 where c1 = 1;

drop table t1;
