--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner : dachuan.sdc
#owner group: sql2
#description: todo

--source mysql_test/include/index_quick_major.inc
--disable_warnings
drop table if exists t1; 
--enable_warnings
create table t1 (a int, b int primary key);
create unique index idx1 on t1(a);
--replace_column 3 idx_name
--source mysql_test/include/check_all_idx_ok.inc
show index from t1;
select * from t1; 
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/check_all_idx_ok_unq.inc
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/check_all_idx_ok.inc
--source mysql_test/include/wait_daily_merge.inc
insert into t1 values(3,5);
--error 1062 
insert into t1 values(3,6),(1,1),(1,2),(2,3),(2,4);
--error 1062 
insert into t1 values(4,5);
delete from t1; 
--disable_query_log
--let $loop=5000
while  ($loop)
{
  eval replace into t1 values($loop,$loop);
  dec $loop;
}
--enable_query_log
select count(*) from t1;
--disable_query_log
--let $loop=5000
while  ($loop)
{
  eval update  t1 set a=$loop+5001 where b=$loop;
  dec $loop;
}
--enable_query_log
select count(*) from t1;
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
select count(*) from t1;
select * from t1 limit 1;
