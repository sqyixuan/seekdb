--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
let $a=1000;
--disable_query_log
while($a)
{
   eval insert into t1(a0,c1) values($a,'$a');
   dec $a;
}
--enable_query_log

