--let $head =create table t1(a0 int 
--let $sql =
--let $column=100

--let $x=, c
--let $y= int default 0 
while($column)
{

    --let $sql=$sql$x$column $y
    dec $column;
}
 --let $column2=68
 --let $z=)
 --let $prik=,primary key(a0
 --let $sql=$sql$prik
while($column2)
{

    --let $sql=$sql$x$column2
    dec $column2;
}
--let $sql=$sql$z
