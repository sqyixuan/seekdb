--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: dachuan.sdc
#owner group: sql2
#description: todo


--disable_warnings
drop database if exists db_create;
create database db_create;
use db_create;
--enable_warnings

# test for tablet_size
--disable_warnings
drop table if exists t1;
--enable_warnings

connect (obsys,$OBMYSQL_MS0,admin@sys,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
let $tablet_size = query_get_value("select substring_index(value,'M',1) * (1 << 20) as tablet_size from oceanbase.__all_virtual_sys_parameter_stat where name = 'tablet_size'", tablet_size, 1);
echo $tablet_size;

connection default;
create table t1(c1 int);
create index idx on t1(c1);

connection obsys;
let $index_tablet_size = query_get_value("select tbidx.tablet_size from oceanbase.__all_virtual_database as db inner join oceanbase.__all_virtual_table as tb on db.database_id = tb.database_id inner join oceanbase.__all_virtual_table as tbidx on tbidx.data_table_id = tb.table_id where tb.table_name='t1' and db.database_name='db_create'", tablet_size, 1);

echo $index_tablet_size;

connection default;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;

connection obsys;
let $value = query_get_value("select tablet_size from oceanbase.__all_virtual_database as db, oceanbase.__all_virtual_table as tb where db.database_name='db_create' and tb.table_name='t1' and db.database_id = tb.database_id", tablet_size, 1);
echo $value;

connection default;
--error 4147
alter table t1 tablet_size = 323232137;

alter table t1 tablet_size = 134217728;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;

connection obsys;
let $value = query_get_value("select tablet_size from oceanbase.__all_virtual_database as db, oceanbase.__all_virtual_table as tb where db.database_name='db_create' and tb.table_name='t1' and db.database_id = tb.database_id", tablet_size, 1);
echo $value;
let $value = query_get_value("select tbidx.tablet_size from oceanbase.__all_virtual_database as db inner join oceanbase.__all_virtual_table as tb on db.database_id = tb.database_id inner join oceanbase.__all_virtual_table as tbidx on tbidx.data_table_id = tb.table_id where tb.table_name='t1' and db.database_name='db_create'", tablet_size, 1);
echo $value;

connection default;
alter table t1 tablet_size = 268435456;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;

connection obsys;
let $value = query_get_value("select tablet_size from oceanbase.__all_virtual_database as db, oceanbase.__all_virtual_table as tb where db.database_name='db_create' and tb.table_name='t1' and db.database_id = tb.database_id", tablet_size, 1);
echo $value;
let $value = query_get_value("select tbidx.tablet_size from oceanbase.__all_virtual_database as db inner join oceanbase.__all_virtual_table as tb on db.database_id = tb.database_id inner join oceanbase.__all_virtual_table as tbidx on tbidx.data_table_id = tb.table_id where tb.table_name='t1' and db.database_name='db_create'", tablet_size, 1);
echo $value;

connection default;
alter table t1 tablet_size = 0;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;

connection obsys;
let $value = query_get_value("select tablet_size from oceanbase.__all_virtual_database as db, oceanbase.__all_virtual_table as tb where db.database_name='db_create' and tb.table_name='t1' and db.database_id = tb.database_id", tablet_size, 1);
echo $value;
let $value = query_get_value("select tbidx.tablet_size from oceanbase.__all_virtual_database as db inner join oceanbase.__all_virtual_table as tb on db.database_id = tb.database_id inner join oceanbase.__all_virtual_table as tbidx on tbidx.data_table_id = tb.table_id where tb.table_name='t1' and db.database_name='db_create'", tablet_size, 1);
echo $value;

connection default;
--disable_warnings
drop table if exists wang_t1;
--enable_warnings

connection obsys;
alter system set taBLEt_size = '4m';
connection default;

sleep 3;
create table wang_t1(c1 int);
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table wang_t1;

alter table wang_t1 tablet_size = 134217728;
sleep 3;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table wang_t1;
drop table wang_t1;

connection obsys;
alter system set tablet_size= '4M';
connection default;
sleep 3;
create table wang_t1(c1 int) tablet_size=8388608; # tablet_size=8M
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table wang_t1;
drop table wang_t1;
create table wang_t1(c1 int); # tablet_size=8M
sleep 3;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table wang_t1;

#reset the dufalut value
connection obsys;
alter system set tablet_size= '128M';
connection default;

--disable_warnings
drop table if exists wang_t1;
drop database if exists db_create;
--enable_warnings
