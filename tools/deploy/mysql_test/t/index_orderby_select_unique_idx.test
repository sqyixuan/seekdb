select pk1, pk2, c1 from t1 where pk1>-1 and pk1<2 order by pk1, pk2;
select pk1, pk2, c1 from t1 where pk1>-1 and pk1<2 order by pk1 asc, pk2 asc;
select pk1, pk2, c1 from t1 where pk1>=0 and pk1<=1 order by pk1, pk2 limit 4;
select pk1, pk2, c1 from t1 where pk1>=0 and pk1<=0 order by pk1, pk2 limit 4;
select pk1, pk2, c1 from t1 where pk1>0 and pk1<1 order by pk1, pk2;

