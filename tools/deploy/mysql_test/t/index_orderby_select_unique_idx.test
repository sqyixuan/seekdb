--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: yibo.tyf
#owner group: sql1
# tags: optimizer

####TITEL: test index with order by
--disable_query_log
source mysql_test/include/index_quick_major.inc;
--real_sleep 10
--disable_warnings
drop table if exists t1;
--enable_warnings
--enable_query_log

create table t1(pk1 int, pk2 varchar(10), c1 int, c2 int, c3 varchar(20), c4  timestamp(6) default "2012-01-01 12:00:00", c5 int, primary key(pk1, pk2));
create unique index i1 on t1(c1);
create unique index i2 on t1(c2);
create unique index i3 on t1(c1,c2);
create unique index i4 on t1(c2, c3, c4);
create unique index i5 on t1(c2, c3) storing(c1);

insert into t1(pk1, pk2, c1, c2, c3, c4, c5) values
(0,'0',0,0,'0','2014-11-03 08:00:00',0),
(0,'1',10,1,'-10','2014-11-03 08:00:01',0),
(0,'2',1,2,'1','2014-11-03 08:00:03',1),
(0,'3',-1,3,'-1','2014-11-03 08:00:04',1);

--source mysql_test/include/check_all_idx_ok.inc

insert into t1(pk1, pk2, c1, c2, c3, c4, c5) values
(1,'0',2,10,'2','2014-11-03 08:00:05',2),
(1,'1',-2,-1,'-2','2014-11-03 08:00:05',2),
(1,'2',3,-2,'3','2014-11-03 08:00:05',3),
(1,'3',-3,-3,'-3','2014-11-03 08:00:05',3);

#### case 1: hint
# case 1-1, order by pk, optimized;
echo case 1-1, order by pk, optimized;
select /*+index(t1 primary)*/ pk1, pk2, c1 from t1 order by pk1;
select /*+index(t1 primary)*/ pk1, pk2, c1 from t1 order by pk1, pk2;
select /*+index(t1 primary)*/ pk1, pk2, c1 from t1 order by pk1 limit 4;
select /*+index(t1 primary)*/ pk1, pk2, c1 from t1 order by pk1, pk2 limit 5;

