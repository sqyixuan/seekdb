# owner: xiaoyi.xy
# owner group: SQL3
# comment: this case is marked as expired in filter.py

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
####TITLE: expire
--disable_query_log
--source mysql_test/include/index_quick_major.inc
--real_sleep 1
--enable_query_log



####CASE
--disable_warnings
drop table if exists t1, t2;
--enable_warnings
# int default 0
create table t1(pk int primary key, c1 int, c2 int default 0) EXPIRE_INFO ( pk < 100);
# timestamp default now()
create table t2(pk int primary key, c1 int, c2 timestamp default now()) EXPIRE_INFO ( pk < 100);

sleep 1;

--echo insert 1000 rows to ups
--let $count=1
--disable_query_log
while($count < 1001)
{
  eval insert into t1 (pk,c1) values($count,$count);
  eval insert into t2 (pk,c1) values($count,$count);
  inc $count;
}
--enable_query_log

--source mysql_test/include/majorfreeze.inc

--disable_query_log
--let $count=1
while($count < 101)
{
 eval update t1 set pk=$count+1000,c1=$count+1000 where pk = $count;
 eval update t2 set pk=$count+1000,c1=$count+1000 where pk = $count;
 inc $count;
}
--enable_query_log


# select before cs start freeze
select pk, c1, c2 from t1 where pk<=100 limit 10;
--replace_column 3 createtime
select pk, c1, c2 from t2 where pk<=100 limit 10;

--source mysql_test/include/wait_daily_merge.inc

# select after freeze
select pk, c1, c2 from t1 where pk<=100 limit 10;
--replace_column 3 createtime
select pk, c1, c2 from t2 where pk<=100 limit 10;
select count(*) from t1;
select count(*) from t2;

####КЯВЂЦкМфаоИФЪ§ОнБэЕФЭЌЪБаоИФЫїв§Бэ
###ДДНЈЫїв§ЃЌВЂЪЙЦфЩњаЇ

--disable_query_log
--enable_query_log

create index idx on t1(c1);
create index idx on t2(c1);
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/check_all_idx_ok.inc

###аоИФЙ§ЦкЬѕМў
alter table t1 set  EXPIRE_INFO ( pk <= 400 );
alter table t2 set  EXPIRE_INFO ( pk <= 400 );
sleep 1;
--disable_query_log
--enable_query_log

--source mysql_test/include/majorfreeze.inc


--disable_query_log
--let $count=101
while($count < 501)
{
 eval update t1 set pk=$count+1000, c1=$count+1000 where pk = $count;
 eval update t2 set pk=$count+1000,c1=$count+1000 where pk = $count;
 inc $count;
}
--enable_query_log


# select before cs start freeze
select pk, c1, c2 from t1 where pk<=500 limit 10;
--replace_column 3 createtime
select pk, c1, c2 from t2 where pk<=500 limit 10;

--source mysql_test/include/wait_daily_merge.inc

# select after freeze
select pk, c1, c2 from t1 where pk<=500 limit 10;
--replace_column 3 createtime
select pk, c1, c2 from t2 where pk<=100 limit 10;
select pk, c1, c2 from t1 where (c1,pk) in ((1410,1410),(1420,420),(1450,1450));
--replace_column 3 createtime
select pk, c1, c2 from t2 where (c1,pk) in ((1410,1410),(1420,1420),(1450,1450));
select count(*) from t1;
select count(*) from t2;
drop index idx on t1;
drop index idx on t2;
####ВтЪдЮЈвЛЫїв§ЕФЧщПі
create unique index idx on t1(c1);
create unique index idx on t2(c1);
--disable_query_log
--enable_query_log
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/check_all_idx_ok_unq.inc
--disable_query_log
--enable_query_log
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/check_all_idx_ok.inc

###аоИФЙ§ЦкЬѕМў
alter table t1 set  EXPIRE_INFO ( pk <= 900 );
alter table t2 set  EXPIRE_INFO ( pk <= 900 );
sleep 1;
--disable_query_log
--enable_query_log
--source mysql_test/include/majorfreeze.inc


--disable_query_log
--let $count=501
while($count < 1001)
{
 eval update t1 set pk=$count+1000, c1=$count+1000 where pk = $count;
 eval update t2 set pk=$count+1000,c1=$count+1000 where pk = $count;
 inc $count;
}
--enable_query_log


# select before cs start freeze
select pk, c1, c2 from t1 where pk<=900 limit 10;
--replace_column 3 createtime
select pk, c1, c2 from t2 where pk<=900 limit 10;

--source mysql_test/include/wait_daily_merge.inc

# select after freeze
select pk, c1, c2 from t1 where pk<=900 limit 10;
--replace_column 3 createtime
select pk, c1, c2 from t2 where pk<=900 limit 10;
select pk, c1, c2 from t1 where (c1,pk) in ((1810,1810),(1820,1820),(1850,1850));
--replace_column 3 createtime
select pk, c1, c2 from t2 where (c1,pk) in ((1810,1810),(1820,1820),(1850,1850));
select count(*) from t1;
select count(*) from t2;
###аоИФЙ§ЦкЬѕМў,ЭЌЪБаоИФЪ§ОнЃЌШУд­РДВЛТњзуЙ§ЦкЬѕМўЕФЪ§ОнЯждкТњзуЙ§ЦкЬѕМў
alter table t1 set  EXPIRE_INFO ( pk <= 2000 and pk >=1901 );
alter table t2 set  EXPIRE_INFO ( pk <= 2000 and pk>=1901 );
sleep 1;
--disable_query_log
--enable_query_log
--source mysql_test/include/majorfreeze.inc


--disable_query_log
--let $count=901
while($count < 1001)
{
 eval update t1 set pk=$count+1000, c1=$count+1000 where pk = $count;
 eval update t2 set pk=$count+1000,c1=$count+1000 where pk = $count;
 inc $count;
}
--enable_query_log


# select before cs start freeze
select pk, c1, c2 from t1 where pk<=2000 and pk>=1900 limit 10;
--replace_column 3 createtime
select pk, c1, c2 from t2 where pk<=2000 and pk>=1900 limit 10;

--source mysql_test/include/wait_daily_merge.inc

# select after freeze
select pk, c1, c2 from t1 where pk<=2000 and pk>=1900 limit 10;
--replace_column 3 createtime
select pk, c1, c2 from t2 where pk=2000 and pk>=1900  limit 10;
select pk, c1, c2 from t1 where (c1,pk) in ((1910,1910),(1920,1920),(1950,1950));
--replace_column 3 createtime
select pk, c1, c2 from t2 where (c1,pk) in ((1910,1910),(1920,1920),(1950,1950));
select count(*) from t1;
select count(*) from t2;
