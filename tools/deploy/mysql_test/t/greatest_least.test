--disable_warnings
drop table if exists t3;  
--enable_warnings
create table t3 (c1 int, c2 int, c3 varchar(124), c4 varchar(124), c5  timestamp(6) default "2012-01-01 12:00:00", c6 datetime(6), primary key(c1, c3, c5));
--disable_query_log
select * from t3;
insert into t3 values(-1, -2, 'a', 'b', '2013-11-30 11:06:00', '2013-11-29 11:06:00');
insert into t3 values(0, 1, 'b', 'c', '2013-11-21 11:06:01', '2013-11-29 11:06:01');
insert into t3 values(1, 3, 'c', 'd', '2013-12-29 11:06:02', '2013-11-29 11:06:02');
insert into t3 values(2, 0, 'd', 'd', '2013-11-29 11:06:03', '2013-11-29 11:06:03');
