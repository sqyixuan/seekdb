* 5 + 2 AS CHAR(20) ) , '-06-19 01:00:00.000003') , DATE_SUB( LEAST( COALESCE( CONCAT( CAST( 1975 + 0 * 5 + 1 AS CHAR(20) ) , '-06-19 01:00:00.000003') , CONCAT( CAST( 1975 + 2 * 5 + 3 AS CHAR(20) ) , '-06-19 01:00:00.000003') , '1980-06-15 10:00:00.000001' ) , CONCAT( CAST( 2000 + 6 * 3 AS CHAR(20) ) , '-06-15 01:00:00.000003') ) , INTERVAL '01 05:05:05.000005' DAY_MICROSECOND ) ) ) , DATE_ADD( DATE_SUB( CONCAT( CAST( 1975 + 1 * 5 + 2 AS CHAR(20) ) , '-06-19 01:00:00.000003') , INTERVAL '01 05:05' DAY_MINUTE ) , INTERVAL '01 05:05:05.000005' DAY_MICROSECOND ) ) , LEAST( COALESCE( CONCAT( CAST( 1975 + 2 * 5 + 1 AS CHAR(20) ) , '-06-19 01:00:00.000003') , CONCAT( CAST( 1975 + 2 * 5 + 3 AS CHAR(20) ) , '-06-19 01:00:00.000003') , CONCAT( CAST( 1975 + 4 * 5 + 2 AS CHAR(20) ) , '-06-19 01:00:00.000003') ) , GREATEST( DATE_SUB( GREATEST( CONCAT( CAST( 2000 + 1 * 3 AS CHAR(20) ) , '-06-15 01:00:00.000003') , CONCAT( CAST( 1975 + 3 * 5 + 1 AS CHAR(20) ) , '-06-19 01:00:00.000003') ) , INTERVAL '1-01' YEAR_MONTH ) , DATE_ADD( CONCAT( CAST( 1975 + 7 * 5 + 2 AS CHAR(20) ) , '-06-19 01:00:00.000003') , INTERVAL '05:05.000005' MINUTE_MICROSECOND ) ) ) ) ) ) , DATE_SUB( '1980-06-15 10:00:00.000001' , INTERVAL '01 05:05:05.000005' DAY_MICROSECOND ) ) , INTERVAL '01 05:05' DAY_MINUTE ) , LEAST( DATE_ADD( GREATEST( CONCAT( CAST( 1975 + 0 * 5 + 3 AS CHAR(20) ) , '-06-19 01:00:00.000003') , DATE_ADD( DATE_SUB( DATE_SUB( DATE_SUB( DATE_SUB( '1980-06-15 10:00:00.000001' , INTERVAL '05:05' HOUR_MINUTE ) , INTERVAL '05:05:05' HOUR_SECOND ) , INTERVAL 1 QUARTER ) , INTERVAL '5.000005' SECOND_MICROSECOND ) , INTERVAL '01 05:05' DAY_MINUTE ) ) , INTERVAL '05:05.000005' MINUTE_MICROSECOND ) , CONCAT( CAST( 1975 + 1 * 5 + 2 AS CHAR(20) ) , '-06-19 01:00:00.000003') , DATE_ADD( DATE_ADD( DATE_SUB( GREATEST( CONCAT( CAST( 1975 + 9 * 5 + 3 AS CHAR(20) ) , '-06-19 01:00:00.000003') , CONCAT( CAST( 1975 + 4 * 5 + 3 AS CHAR(20) ) , '-06-19 01:00:00.000003') ) , INTERVAL '1-01' YEAR_MONTH ) , INTERVAL '01 05' DAY_HOUR ) , INTERVAL '1-01' YEAR_MONTH ) , DATE_SUB( DATE_SUB( '1980-06-15 10:00:00.000001' , INTERVAL '01 05:05:05.000005' DAY_MICROSECOND ) , INTERVAL '01 05' DAY_HOUR ) , GREATEST( CONCAT( CAST( 1975 + 4 * 5 + 3 AS CHAR(20) ) , '-06-19 01:00:00.000003') , GREATEST( CONCAT( CAST( 2000 + 3 * 3 AS CHAR(20) ) , '-06-15 01:00:00.000003') , CONCAT( CAST( 1975 + 8 * 5 + 2 AS CHAR(20) ) , '-06-19 01:00:00.000003') ) , CONCAT( CAST( 1975 + 9 * 5 + 1 AS CHAR(20) ) , '-06-19 01:00:00.000003') ) , CONCAT( CAST( 1975 + 6 * 5 + 2 AS CHAR(20) ) , '-06-19 01:00:00.000003') ) ) , '%e' ) ) , 1 , 20 ) ) , CONCAT( CAST( 1975 + 3 * 5 + 1 AS CHAR(20) ) , '-06-19 01:00:00.000003') , SUBSTR( CAST( ( ( ROUND( EXTRACT( MICROSECOND FROM CONCAT( CAST( 1975 + 7 * 5 + 3 AS CHAR(20) ) , '-06-19 01:00:00.000003') ) + 1 ) * 2 - 1 ) ) AS CHAR(100) ) , 1 , 20 ) );

drop table table0_bigint;

## 
--disable_warnings
drop table if exists t0;
--enable_warnings
CREATE TABLE `t0` (`c0` varchar(500) DEFAULT NULL COMMENT 'asdf');
SELECT 1 FROM t0 WHERE LEAST((! ((1 > (t0.c0 IS NOT FALSE)) IS NOT FALSE)), 1);
drop table t0;


create table t0(c1 int, c2 float, c3 number, c4 varchar(10), c5 datetime);
insert into t0 values(0, 0, 0, '0', NULL);
insert into t0 values(123, 123, 123.5, 'a', '2020-07-01 10:00:00');
insert into t0 values(-123, -123, -123.5, 'a', '2020-07-02 10:00:00');
select greatest(null,null) from t0;
select greatest(null, c1) from t0;
select greatest(null, c2) from t0;
select greatest(null, c3) from t0;
select greatest(null, c4) from t0;
select greatest(null, c5) from t0;
select greatest(abs(null), c1) from t0;
select greatest(abs(null), c2) from t0;
select greatest(abs(null), c3) from t0;
select greatest(abs(null), c4) from t0;
select greatest(abs(null), c5) from t0;
select greatest(0, c1) from t0;
select greatest(0, c2) from t0;
select greatest(0, c3) from t0;
select greatest(0, c4) from t0;
select greatest(0, c5) from t0;
select greatest(abs(0), c1) from t0;
select greatest(abs(0), c2) from t0;
select greatest(abs(0), c3) from t0;
select greatest(abs(0), c4) from t0;
select greatest(abs(0), c5) from t0;
select greatest('0', c1) from t0;
select greatest('0', c2) from t0;
select greatest('0', c3) from t0;
select greatest('0', c4) from t0;
select greatest('0', c5) from t0;
select greatest(cast(0 as char), c1) from t0;
select greatest(cast(0 as char), c2) from t0;
select greatest(cast(0 as char), c3) from t0;
select greatest(cast(0 as char), c4) from t0;
select greatest(cast(0 as char), c5) from t0;
drop table t0;


--echo bugfix: 
create table t0(a varchar(20),b date,c time,d datetime,e timestamp);
insert into t0 values('快递','2020-01-12','23:59:59','2020-01-23 21:29:31','2020-01-13 21:29:31'),
  ('fsf231','2019-01-12','21:00:00','2018-11-13 17:16:25','2015-07-05 20:18:18'),
  ('3可可粉','2019-05-23','11:29:29','2012-12-19 01:59:03','2008-05-13 10:25:19');
--echo 这里与mysql结果有不同是符合预期的，是由于比较类型的不同。
select a,b,least(a,b) from t0;
select a,c,least(a,c) from t0;
select a,d,least(a,d) from t0;
select a,e,least(a,e) from t0;

drop table t0;

create table t0(a enum('123','456'));
insert into t0 values(1);
select LEAST(a, '2001-01-02 00:00:00.1') + 0 AS a FROM t0;
drop table t0;