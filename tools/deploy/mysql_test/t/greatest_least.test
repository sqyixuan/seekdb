select least(c3,c4) from t3;
select least(c4,c5) from t3;
select least(c5,c6) from t3;
select least(c6,c6) from t3;

# 
set ob_query_timeout=3000000;
--disable_warnings
DROP TABLE  IF EXISTS table0_bigint; 
--enable_warnings
CREATE TABLE table0_bigint (
col_bigint_index bigint,
pk bigint,
col_char_20_unique_index char(20),
col_char_20 char(20),
col_timestamp_6 timestamp(6) NULL DEFAULT NULL,
col_bigint bigint,
col_timestamp_6_index timestamp(6) NULL DEFAULT NULL,
col_char_20_index char(20),
col_timestamp_6_unique_index timestamp(6) NULL DEFAULT NULL,
col_bigint_unique_index bigint,
/*Indices*/
index idx1(pk, col_bigint_index ),
primary key (pk) ,
unique index idx5(pk, col_char_20_unique_index ),
index idx7(pk, col_timestamp_6_index ),
index idx4(pk, col_char_20_index ),
unique index idx8(pk, col_timestamp_6_unique_index ),
unique index idx2(pk, col_bigint_unique_index ));

