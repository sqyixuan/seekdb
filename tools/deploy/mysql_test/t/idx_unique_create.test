--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: bin.lb
# owner group: SQL3
# description:
#
--disable_query_log
--source mysql_test/include/index_quick_major.inc
sleep 2;
--enable_query_log
--echo merge happens
--disable_warnings
drop table if exists tbl1,tbl2;
--enable_warnings
create table tbl1 (i1 int, v2 varchar(80), i3 char(20),i4 float, d4 datetime(6),i5 decimal(5,3), primary key(i3));
####case:create unique index on diff type column
create  unique index idx1 on tbl1(i1);
create  unique index idx2 on tbl1(v2);
create  unique index idx3 on tbl1(i3);
create  unique index idx5 on tbl1(d4);
--source mysql_test/include/check_all_idx_ok.inc
insert into tbl1 values(1,'now','haha1',1.6256,'2014-05-04 12:00:00',-10.235);
--error 1062
insert into tbl1 values(2,'now','haha1',2.6256,'2014-05-04 12:00:00',-10.235);
alter table  tbl1  alter  column v2 set  default 'aaa'; 
sleep 1;
--error 1064
alter table  tbl1  alter  column v1 set  null; 
sleep 1;
--error 1064
alter table  tbl1  alter  column i4 set  not null; 
sleep 1;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table tbl1;
drop index  idx1 on tbl1;
drop index  idx2 on tbl1;
drop index  idx3 on tbl1;
drop index  idx5 on tbl1;
sleep 1;
create  unique index idx1 on tbl1(i1,i3);
create  unique index idx2 on tbl1(v2,i3);
create  unique index idx3 on tbl1(i3);
create  unique index idx5 on tbl1(d4,i3);
--source mysql_test/include/check_all_idx_ok_unq.inc
select * from tbl1;
delete from tbl1;
select * from tbl1;
--source mysql_test/include/check_all_idx_ok.inc
insert into tbl1 values(1,'now','haha1',1.6256,'2014-05-04 12:00:00',-10.235);
--error 1062
insert into tbl1 values(2,'now','haha1',2.6256,'2014-05-04 12:00:00',-10.235);
drop index  idx1 on tbl1;
drop index  idx2 on tbl1;
drop index  idx3 on tbl1;
drop index  idx5 on tbl1;
sleep 1;
create   index idx1 on tbl1(i1,i3);
create   index idx2 on tbl1(v2,i3);
create   index idx3 on tbl1(i3);
create   index idx4 on tbl1(i3);
create   index idx5 on tbl1(d4,i3);
create   index idx6 on tbl1(i3);
sleep 1;
delete from tbl1;
sleep 1;
--source mysql_test/include/check_all_idx_ok.inc
insert into tbl1 values(1,'now','haha1',1.6256,'2014-05-04 12:00:00',-10.235);
insert into tbl1 values(1,'now','haha2',2.6256,'2014-05-04 12:00:00',-10.235);
select * from tbl1;
