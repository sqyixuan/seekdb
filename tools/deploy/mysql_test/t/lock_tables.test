#owner: dachuan.sdc
#owner group: sql2
#description:

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#### description: lock tables和unlock tables为了兼容mysqldump的空实现
#### 解锁
UNLOCK TABLES;
#### 加锁
LOCK TABLES t1 READ;
LOCK TABLES t1 READ LOCAL;
LOCK TABLES t1 WRITE;
LOCK TABLES t1 LOW_PRIORITY WRITE;
LOCK TABLES t1 as t2 READ;
LOCK TABLES t1 as t2 READ, t3 as t4 WRITE;
LOCK TABLES t1 as t2 READ, t3 as t4 WRITE, t5 LOW_PRIORITY WRITE;
LOCK TABLE t1 READ;
LOCK TABLE t1 as t2 READ;
