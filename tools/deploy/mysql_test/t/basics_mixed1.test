--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
##owner: link.zt
##owner group: sql1
##description: 测试非admin权限下进行information schema操作，原作者: 青萧


--disable_info
--disable_metadata

--disable_query_log
--disable_result_log

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
--error 0,5157
drop tenant xy_tenant_1 force;

--disable_query_log
#call oceanbase.create_mysql_tenant_mini('xy_tenant_1');
--source mysql_test/include/check_tenant_sync.inc
--enable_query_log

connect (conn1,$OBMYSQL_MS0,root,,*NO-ONE*,$OBMYSQL_PORT);

###test body
USE information_schema;
#--error 0,1044
drop table if exists t1;
#--error 1044
CREATE TABLE t1 (f1 INT, f2 INT, f3 INT);

--error 4179
drop view if exists tables;
--error 0,1050
CREATE VIEW tables AS SELECT 'garbage';

#--error 1044
drop view if exists v1;
#--error 1044
CREATE VIEW v1 AS SELECT 'garbage';

## Hit on existing INFORMATION_SCHEMA table
--error 4179
drop view if exists information_schema.tables;
--error 0,1050
CREATE VIEW information_schema.tables AS SELECT 'garbage';
#### login using admin acount
