--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: bin.lb
# owner group: SQL2
# tags: dml
# description:
#
--disable_warnings
drop table if exists t1;
--enable_warnings


#
# Bug#11299 'prepared statement makes wrong SQL syntax in binlog which stops
# replication': check that errouneous queries with placeholders are not
# allowed
#

create table t1 (a int primary key, b int);

--error 1064
prepare stmt from 'select ??';
prepare stmt from 'select ?FROM t1';
--error 1064
prepare stmt from 'select FROM t1 WHERE?=1';
--error 1064
prepare stmt from 'update t1 set @a=a+?WHERE 1';


--error 1064
select ?;
--error 1064
select ??;


--error 1064
select ? from t1;

drop table t1;


--error 1064
select ?;

--error 1109
show fields from information_schema.table_names;

--error 1072
create table t1(c1 int, primary key(c2));
--disable_warnings
drop table if exists t45;
--enable_warnings
create table t45( v1 varchar(5)) EXPIRE_INFO (v1='aaaaa');
alter table t45 modify column v1 varchar(6);
drop table t45;

--error 1486
create table t1(a timestamp, b int) partition by hash( 1 ) partitions 4;

--disable_warnings
drop table if exists t1,t2,t3;
--enable_warnings
create table t1(c1 int, c2 int);
create table t2(c1 int, c2 int);
create table t3(c1 int, c2 int);
--error 1054
select * from t1 join t2 using (b) join t3 using (c);
--error 1054
select * from t1 join t2 on (t1.b=t2.b) join t3 on (t1.c=t2.c);
--error 1054
select * from t1 join t2 using (c1) join t3 using (c);
--error 1054
select * from t1 join t2 on (t1.c=t2.c) join t3 using (c1);
--error 1054
select * from t1 join t2 on (t1.c=t2.c) join t3 using (a);
--error 1052
select * from t1 join t2 on (c1=t2.c1);
--disable_warnings
drop table if exists t1,t2,t3;
--enable_warnings
CREATE TABLE t1 (pk int primary key, a int not null, b char (10) not null);
insert into t1 values(1,1,'a'),(2,2,'b'),(3,3,'c'),(4,3,'c');
CREATE TABLE t2 (pk int primary key, a int not null, b char (10) not null);
insert into t2 values (1,3,'c'),(2,4,'d'),(3,5,'f'),(4,6,'e');
--error 1250
(select a,b from t1 limit 2)  union all (select a,b from t2 order by a limit 1) order by t1.b;
drop table t1,t2;

CREATE TABLE t1 (pk int primary key, a INT, b INT, c INT DEFAULT 0);
--error 1054
select * from t1 group by 0;
drop table t1;
CREATE TABLE t1 (n int primary key, m int);
INSERT INTO t1(n) VALUES (1);
SELECT n+1 AS n FROM t1 GROUP BY n;
--sorted_result
select n as n from t1 group by n;
--sorted_result
select m as n from t1 group by n;
--sorted_result
select t1.n as n from t1 group by n;
--sorted_result
select n +1 as n from t1 group by n+1;
drop table t1;
--error 1054
select 1 from  (select 2) a order by 0;
create table t1 (c1 int, c2 int);
--error 1054
select * from t1 order by 4;
