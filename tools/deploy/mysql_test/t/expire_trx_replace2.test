###在合并期间将原来不满足过期条件的数据修改为满足过期条件的
alter table t1 set  EXPIRE_INFO ( c1 <= 500 );
alter table t2 set  EXPIRE_INFO ( c1 <= 500 );
sleep 1;
--disable_query_log
--enable_query_log
--source mysql_test/include/majorfreeze.inc


--disable_query_log
--let $count=1
while($count < 1001)
{
 eval replace into t1(pk,c1) values ($count,$count);
 eval replace into t2(pk,c1) values ($count,$count);
 inc $count;
}
--enable_query_log


# select before cs start freeze
select pk, c1, c2 from t1 where pk<=500 limit 10;
--replace_column 3 createtime
select pk, c1, c2 from t2 where pk<=500 limit 10;

--source mysql_test/include/wait_daily_merge.inc

# select after freeze
select pk, c1, c2 from t1 where pk<=500 limit 10;
--replace_column 3 createtime
select pk, c1, c2 from t2 where pk<=500 limit 10;
select count(*) from t1;
select count(*) from t2;

