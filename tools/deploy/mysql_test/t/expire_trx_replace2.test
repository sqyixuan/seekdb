# owner: xiaoyi.xy
# owner group: SQL3
# comment: this case is marked as expired in filter.py

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
####TITLE: expire,在合并过程中将满足合并条件的数据修改为不满足合并条件的数据
###非rowkey为过期条件，冻结后合并前修改数据将满足合并条件的数据修改成不满足合并条件的，合并时数据仍然会被过期掉；
--disable_query_log
--source mysql_test/include/index_quick_major.inc
--real_sleep 1
--enable_query_log



####CASE
--disable_warnings
drop table if exists t1, t2;
--enable_warnings
# int default 0
create table t1(pk int primary key, c1 int, c2 int default 0) EXPIRE_INFO ( c1 < 100);
# timestamp default now()
create table t2(pk int primary key, c1 int, c2 timestamp default now()) EXPIRE_INFO ( c1 < 100);

sleep 1;

--echo insert 1000 rows to ups
--let $count=1
--disable_query_log
while($count < 1001)
{
  eval insert into t1 (pk,c1) values($count,$count);
  eval insert into t2 (pk,c1) values($count,$count);
  inc $count;
}
--enable_query_log

--source mysql_test/include/majorfreeze.inc

--disable_query_log
--let $count=1
while($count < 101)
{
 eval replace into t1(pk,c1) values ($count,$count+1000);
 eval replace into t2(pk,c1) values ($count,$count+1000);
 inc $count;
}
--enable_query_log


# select before cs start freeze
select pk, c1, c2 from t1 where c1<100 limit 10;
--replace_column 3 createtime
select pk, c1, c2 from t2 where c1<100 limit 10;

--source mysql_test/include/wait_daily_merge.inc

# select after freeze
select pk, c1, c2 from t1 where pk<=100 limit 10;
--replace_column 3 createtime
select pk, c1, c2 from t2 where pk<=100 limit 10;
select count(*) from t1;
select count(*) from t2;

####合并期间修改数据表的同时修改索引表
###创建索引，并使其生效

create index idx on t1(c1);
create index idx on t2(c1);
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/check_all_idx_ok.inc

###修改过期条件
alter table t1 set  EXPIRE_INFO ( c1 <= 400 );
alter table t2 set  EXPIRE_INFO ( c1 <= 400 );
sleep 1;

--disable_query_log
--enable_query_log
--source mysql_test/include/majorfreeze.inc


--disable_query_log
--let $count=101
while($count < 501)
{
 eval replace into t1(pk,c1) values ($count,$count+1000);
 eval replace into t2 (pk,c1) values ($count,$count+1000);
 inc $count;
}
--enable_query_log


# select before cs start freeze
select pk, c1, c2 from t1 where c1<=400 limit 10;
--replace_column 3 createtime
select pk, c1, c2 from t2 where c1<=400 limit 10;

--source mysql_test/include/wait_daily_merge.inc

# select after freeze
select pk, c1, c2 from t1 where c1<=400 limit 10;
--replace_column 3 createtime
select pk, c1, c2 from t2 where c1<=400 limit 10;
select pk, c1, c2 from t1 where (c1,pk) in ((410,1410),(420,420),(450,1450));
--replace_column 3 createtime
select pk, c1, c2 from t2 where (c1,pk) in ((410,1410),(420,1420),(450,1450));
select count(*) from t1;
select count(*) from t2;
drop index idx on t1;
drop index idx on t2;
####测试唯一索引的情况
create unique index idx on t1(c1);
create unique index idx on t2(c1);
--disable_query_log
--enable_query_log
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/check_all_idx_ok_unq.inc
--disable_query_log
--enable_query_log
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/check_all_idx_ok.inc

