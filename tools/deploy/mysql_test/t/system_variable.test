--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: bin.lb
# owner group: SQL2
# description: 系统变量的测试
let $zone_count = 1;
let $unit_num = 1;

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
let $zone1 = query_get_value(select distinct zone from oceanbase.__all_zone where zone != '' limit 2, zone, 1); 
let $zone2 = query_get_value(select distinct zone from oceanbase.__all_zone where zone != '' limit 2, zone, 2); 
--disable_warnings
eval CREATE RESOURCE UNIT if not exists config_ym MAX_CPU=1, MEMORY_SIZE='2G';
--disable_query_log
eval CREATE RESOURCE POOL if not exists pool_ym UNIT='config_ym', UNIT_NUM=$unit_num, ZONE_LIST=('$zone1', '$zone2');
set @@session.ob_query_timeout = 20000000;
eval CREATE TENANT if not exists tt_ym REPLICA_NUM = $zone_count, RESOURCE_POOL_LIST = ('pool_ym'), primary_zone = "$zone1" set ob_tcp_invited_nodes='%';
set @@session.ob_query_timeout = 10000000;
--enable_query_log
--enable_warnings
--source mysql_test/include/check_tenant_sync.inc
connect (obym,$OBMYSQL_MS0,root@tt_ym,,test,$OBMYSQL_PORT);
connection obym;
# 修改sql_mode为非严格模式，使后面的某些地方报warning而不是error
set @saved_sql_mode = @@session.sql_mode;
set sql_mode = '';

