# 新增系统变量之后，set语句的兼容
--echo ======== test for compatibility after add a new system variable =========
--error 1193
set test_new_sys_var_name = 1;
--error 1193
set global test_new_sys_var_name = 2;
connect (var_obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
let $schema_version = query_get_value(select schema_version from oceanbase.__all_tenant_history where tenant_id=1 order by schema_version desc limit 1, schema_version,1);
insert into oceanbase.__all_sys_variable(tenant_id, zone, name, data_type, value, info, flags, min_val, max_val) values(0, '', 'test_new_sys_var_name', 1, '0', '', 100, '', '');
--disable_query_log
eval insert into oceanbase.__all_sys_variable_history(tenant_id, zone, name, schema_version, data_type, value, info, flags, min_val, max_val, is_deleted) values(0, '', 'test_new_sys_var_name', $schema_version, 1, '0', '', 100, '', '', 0);
--enable_query_log
set test_new_sys_var_name = 1;
set global test_new_sys_var_name = 2;
show session variables like 'test_new_sys_var_name';
show global variables like 'test_new_sys_var_name';
set @test_user_var = 1;
select @test_user_var;
set @@test_new_sys_var_name = 4, @test_user_var = 5;
select @test_user_var;
set @@test_new_sys_var_name = 1;
set @@global.test_new_sys_var_name = default;
set @@session.test_new_sys_var_name = 3;
set test_new_sys_var_name = 1;
set global test_new_sys_var_name = 2;
set session test_new_sys_var_name = default;
delete from oceanbase.__all_sys_variable where tenant_id = 0 and zone = '' and name = 'test_new_sys_var_name';
delete from oceanbase.__all_sys_variable_history where tenant_id = 0 and zone = '' and name = 'test_new_sys_var_name';
--error 1193
set test_new_sys_var_name = 1;
--error 1193
set global test_new_sys_var_name = 2;

