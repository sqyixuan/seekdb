# ob_interm_result_mem_limit
--disable_warnings
drop table if exists tbl_test_irl;
--enable_warnings
create table tbl_test_irl (c1 int primary key, c2 varchar(10000)) partition by hash(c1) partitions 3;
--let $insert_str1=''
--let $loop1=1024
while ($loop1)
{
  eval insert into tbl_test_irl values ($loop1, $insert_str1);
  dec $loop1;
}
select * from tbl_test_irl order by c1;
show variables like 'ob_interm_result_mem_limit';
set ob_interm_result_mem_limit = 2;
show variables like 'ob_interm_result_mem_limit';
select * from tbl_test_irl order by c1;
set ob_interm_result_mem_limit = default;
show variables like 'ob_interm_result_mem_limit';
select * from tbl_test_irl order by c1;
drop table tbl_test_irl;

