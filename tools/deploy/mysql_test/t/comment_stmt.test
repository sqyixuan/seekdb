--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

#owner: linlin.xll
#owner group: SQL4
#description: test of comment 
#tags: dml, parser

let $comment = -- comment test;
eval $comment;
let $comment = #comment test;
eval $comment;
/*fasdfasf*/;

--disable_warnings
drop table if exists t1;
--enable_warnings

create table /*fdasfasf*/ t1 (c1 int);
select /*+fadsf*/ 1;
##select /*+fadsf*/ 1;-- fasdfsa;
select /*+fadsf*/ 1;#fadsfasf
select * from t1;/*fadsfas*/;
select 1 /*+fdasfsf*/;

drop table if exists t1;
## empty query is test in deploy. and comment of this stype "#fdasfasf" is also tested in deploy
