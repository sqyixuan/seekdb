--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: yuchen.wyc
# owner group: SQL1
# description: OUR GOAL: Make all this simple and effective!
####TITLE:单个事务中更新索引列和非索引列,查询分别为索引表、数据表、回表
####
--disable_query_log
--source mysql_test/include/index_quick_major.inc
--real_sleep 1
--disable_warnings
drop table if exists t1;
--enable_warnings
--enable_query_log

create table t1(pk int primary key, a int, b int, c int);
insert into t1 values(1,1,1,1),(2,1,1,1);
create index i1 on t1(b) storing(c);

let $index_name = __idx_3003_i1;
--source mysql_test/include/check_all_idx_ok.inc

connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn1;
set autocommit=0;

####CASE1 单个事务中update
--echo CASE1
select /*+index(t1 i1)*/ * from t1 where b=1;
update t1 set a=a+1,b=b+1,c=c+1 where pk = 1;
select /*+index(t1 i1)*/ pk, b, c from t1 where b = 2;
select /*+index(t1 primary)*/ * from t1 where pk = 1;
select /*+index(t1 i1)*/* from t1 where b = 2;
rollback;
select /*+index(t1 i1)*/pk, b, c from t1 where b = 1;
select /*+index(t1 primary)*/* from t1 where pk = 1;
select /*+index(t1 i1)*/* from t1 where b = 1;


update t1 set a=a+1,b=b+1,c=c+1 where pk = 1;
select /*+index(t1 i1)*/pk, b, c from t1 where b = 2;
select /*+index(t1 primary)*/* from t1 where pk = 1;
select /*+index(t1 i1)*/* from t1 where b = 2;
commit;
select /*+index(t1 i1)*/pk, b, c from t1 where b = 2;
select /*+index(t1 primary)*/* from t1 where pk = 1;
select /*+index(t1 i1)*/* from t1 where b = 2;

####CASE2 单个事务中replace
--echo CASE2
replace into t1(pk, a, b,c) values(2,2,2,2);
replace into t1(pk, a, b,c) values(3,1,1,1);
select /*+index(t1 i1)*/pk, b, c from t1 where b>=0 and b<=10;
select /*+index(t1 primary)*/* from t1 where pk>=0 and pk<=10;
select /*+index(t1 i1)*/* from t1 where b>=0 and b<=10;
commit;
select /*+index(t1 i1)*/pk, b, c from t1 where b>=0 and b<=10;
select /*+index(t1 primary)*/* from t1 where pk>=0 and pk<=10;
select /*+index(t1 i1)*/* from t1 where b>=0 and b<=10;

replace into t1 values(2,3,3,3);
replace into t1 values(4,1,1,1);
select /*+index(t1 i1)*/pk, b, c from t1 where b>=0 and b<=10;
select /*+index(t1 primary)*/* from t1 where pk>=0 and pk<=10;
select /*+index(t1 i1)*/* from t1 where b>=0 and b<=10;
rollback;
select /*+index(t1 i1)*/pk, b, c from t1 where b>=0 and b<=10;
select /*+index(t1 primary)*/* from t1 where pk>=0 and pk<=10;
select /*+index(t1 i1)*/* from t1 where b>=0 and b<=10;

####CASE3 单个事务中delete
--echo CASE3
replace into t1 values(4,1,1,1);
commit;
delete from t1 where pk = 4;
select /*+index(t1 i1)*/pk, b, c from t1 where b>=0 and b<=10;
select /*+index(t1 primary)*/* from t1 where pk>=0 and pk<=10;
select /*+index(t1 i1)*/* from t1 where b>=0 and b<=10;
rollback;
select /*+index(t1 i1)*/pk, b, c from t1 where b>=0 and b<=10;
select /*+index(t1 primary)*/* from t1 where pk>=0 and pk<=10;
select /*+index(t1 i1)*/* from t1 where b>=0 and b<=10;

delete from t1 where pk = 4;
select /*+index(t1 i1)*/pk, b, c from t1 where b>=0 and b<=10;
select /*+index(t1 primary)*/* from t1 where pk>=0 and pk<=10;
select /*+index(t1 i1)*/* from t1 where b>=0 and b<=10;
commit;
select /*+index(t1 i1)*/pk, b, c from t1 where b>=0 and b<=10;
select /*+index(t1 primary)*/* from t1 where pk>=0 and pk<=10;
select /*+index(t1 i1)*/* from t1 where b>=0 and b<=10;

####CASE4 单个事务中insert
--echo CASE4
insert into t1 values(5,1,1,1);
select /*+index(t1 i1)*/pk, b, c from t1 where b>=0 and b<=10;
select /*+index(t1 primary)*/* from t1 where pk>=0 and pk<=10;
select /*+index(t1 i1)*/* from t1 where b>=0 and b<=10;
rollback;
select /*+index(t1 i1)*/pk, b, c from t1 where b>=0 and b<=10;
select /*+index(t1 primary)*/* from t1 where pk>=0 and pk<=10;
select /*+index(t1 i1)*/* from t1 where b>=0 and b<=10;

insert into t1 values(5,1,1,1);
select /*+index(t1 i1)*/pk, b, c from t1 where b>=0 and b<=10;
select /*+index(t1 primary)*/* from t1 where pk>=0 and pk<=10;
select /*+index(t1 i1)*/* from t1 where b>=0 and b<=10;
commit;
select /*+index(t1 i1)*/pk, b, c from t1 where b>=0 and b<=10;
select /*+index(t1 primary)*/* from t1 where pk>=0 and pk<=10;
select /*+index(t1 i1)*/* from t1 where b>=0 and b<=10;

drop table t1;
