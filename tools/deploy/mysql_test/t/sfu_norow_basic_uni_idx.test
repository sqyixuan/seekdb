--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: yuchen.wyc
# owner group: sql4
# description: select for update带unique索引测试集
#--disable_abort_on_error
--disable_query_log
--source mysql_test/include/index_quick_major.inc
sleep 2;
--enable_query_log
--disable_warnings
drop table if exists tbl1,tbl2;
--enable_warnings
create table tbl1 (
  pk int,
  i1 int, 
  v2 varchar(80), 
  i3 char(20),
  i4 float, 
  d4 datetime(6),
  i5 decimal(5,3),
  i6 bool, 
  primary key(pk), 
  unique index idx1(i1),
  unique index idx2(v2),
  unique index idx4(i3, i1));
####一半静态数据，一半动态数据
