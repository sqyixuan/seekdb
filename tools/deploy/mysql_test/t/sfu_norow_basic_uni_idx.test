connection conn1;
set autocommit=0;

connection conn2;
set autocommit=0;
###2个事务，一个事务用锁住所有行,另外一个事务操作不存在的行
connection conn1;
select * from tbl1 for update; 


connection conn2;
insert into tbl1 values(13,-132,'now','haha13',-1.6256,'2014-05-14 12:00:00',-1.235,0);
##update 不存在的行；
update tbl1 set v2='34' where pk=14; 
update tbl1 set v2='34' where pk in (16,17+18,100+5); 
update tbl1 set v2='34' where pk >=100 and pk<=150; 
update tbl1 set v2='34' where pk >100; 
update tbl1 set v2='34' where i1=14; 
update tbl1 set v2='34' where i1 in (16,17+18,100+5); 
update tbl1 set v2='34' where i1 >=100 and i1<=150; 
update tbl1 set v2='34' where i1 >2000; 
update tbl1 set v2='34' where pk >2000; 
update tbl1 set v2='34' where i4>=1000; 
update tbl1 set v2='34' where i4>=1000; 
update tbl1 set i1='34' where v2 in ('a16','17+18','100+5'); 
select count(*) from tbl1 where v2 in ('a16','17+18','100+5'); 
update tbl1 set i1='34' where v2 >='z100' and v2<='z101'; 
select avg(pk) from tbl1 where v2 >='z100' and v2<='z101'; 
update tbl1 set i1='34' where v2 >'zzzzzzzzzz'; 
update tbl1 set i1='34' where v2 ='z100'; 
select * from tbl1;


connection conn1;
update tbl1 set pk=0 where pk=1;
select * from tbl1;
commit;

connection conn2;
commit;

