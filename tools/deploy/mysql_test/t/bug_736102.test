--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: link.zt
#owner group: sql1
#tags: optimizer, replace

--disable_warnings
drop table if exists test_1;
--enable_warnings
--source mysql_test/include/index_quick_major.inc

create table test_1 (id int primary key, name varchar(1024), addr varchar(1024), birthday  timestamp(6) default "2012-01-01 12:00:00", money int, score float) ;

create index i1 on test_1(money);
Set @@session.ob_query_timeout = 10000000;
--source mysql_test/include/majorfreeze.inc
let $index_name = __idx_3003_i1;
--source mysql_test/include/check_all_idx_ok.inc

let $i = 0;
while($i < 10000)
{
   eval  replace into test_1 values($i,$i,$i,'2010-09-01',101,$i.$i);
   inc $i;
}

let $i = 10000;
while($i < 20000)
{
   eval  replace into test_1 values($i,$i,$i,'2010-09-01',103,$i.$i);
   inc $i;
}


select * from test_1 where money between 100 and 110;
Set @@session.ob_query_timeout = 1000000;
select * from test_1 where (id,name) in ((1,'1'),(2,'2'));
select * from test_1 where (name,id) in (('1',1),('2',2));
--replace_regex /Plan signature: [0-9]*/Plan signature/
--disable_result_log
explain select * from test_1 where (name,id) in  ((1,'1'),(2,'2'));
--enable_result_log
--replace_regex /Plan signature: [0-9]*/Plan signature/
--disable_result_log
explain select * from test_1 where (id,name) in  ((1,'1'),(2,'2'));   
--enable_result_log



####аТдіЪТЮёЙ§ЦкЕФБэЃЌЙ§ЦкЪ§ОнНЯЖрЃЌдкКЯВЂЕФЙ§ГЬжаЃЌЩОГ§Бэ
alter table test_1 set expire_info (money<=40000);
sleep 1;
Set @@session.ob_query_timeout = 10000000;
--source mysql_test/include/majorfreeze.inc
sleep 2;
#drop table test_1;
--source mysql_test/include/wait_daily_merge.inc

