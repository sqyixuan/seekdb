# owner: link.zt
# owner group: SQL1
# tags: optimizer
# description:
#
# Test file for eliminating redundant distinct operator.
--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
drop table if exists t_pk, t_pk_multi, t_uniq, t_uniq_multi, t_group_by, t_group_by_pk, t_distinct, t_join_1, t_join_2, t_uniq_not_null;
--enable_warnings

# t_pk is used to test 'primary key' case.
create table t_pk (c1 int, c2 int, c3 int, primary key(c1));
# t_pk_multi is used to test 'multi-column primary key' case.
create table t_pk_multi (c1 int, c2 int, c3 int, primary key(c1, c2));

# test select primary key
explain select distinct c2, c3 from t_pk;

explain select distinct c1 from t_pk;
explain select distinct c1, c2 from t_pk;
explain select distinct c1, c2, c3 from t_pk;

explain select distinct c1, c2 from t_pk_multi;
explain select distinct c1, c2, c3 from t_pk_multi;


# t_uniq is used to test 'unique key' case.
create table t_uniq (c1 int, c2 int, c3 int, unique key (c1));

# t_uniq_multi is used to test 'multi-column unique key' case.
create table t_uniq_multi (c1 int, c2 int, c3 int, unique key (c1, c2));

# test select unique key
explain select distinct c1 from t_uniq;
explain select distinct c1, c2 from t_uniq;
explain select distinct c1, c2, c3 from t_uniq;

explain select distinct c1, c2 from t_uniq_multi;
explain select distinct c1, c2, c3 from t_uniq_multi;


# t_group_by is used to test 'group by' case.
create table t_group_by (c1 int, c2 int, c3 int, c4 int);


# single column base case
explain select distinct c1 from t_group_by group by c1;
explain select distinct c1, avg(c2) from t_group_by group by c1;
explain select distinct sum(c2), avg(c3), c1 from t_group_by group by c1;
explain select distinct avg(c2), max(c3), min(c4) from t_group_by group by c1;

# multi-column base case
explain select distinct c1, c2 from t_group_by group by c1, c2;
explain select distinct c2, c1 from t_group_by group by c1, c2;
explain select distinct c1, c2, avg(c3) from t_group_by group by c1, c2;
explain select distinct c1, c2, sum(c3), count(c4) from t_group_by group by c1, c2;
explain select distinct c2, sum(c3), c1 from t_group_by group by c1, c2;

explain select distinct sum(c3), count(c4) from t_group_by group by c1, c2;
explain select distinct c2, sum(c3), count(c4) from t_group_by group by c1, c2;
explain select distinct c2 from t_group_by group by c1, c2;

# with duplicate
explain select distinct c1, c2, c1 from t_group_by group by c1, c2;

# with expression
explain select distinct c1+3, c2+5 from t_group_by group by c1, c2;
explain select distinct c1*0, c2+5 from t_group_by group by c1, c2;

# t_group_by_pk is used to test 'primary key mixed with group by' case.
create table t_group_by_pk (c1 int, c2 int, c3 int, c4 int, primary key(c4));

explain select distinct avg(c1), c3, c4 from t_group_by_pk group by c3, c4;

explain select distinct c4 from t_group_by_pk group by c3, c4;
explain select distinct avg(c1), c2, c4 from t_group_by_pk group by c3, c4;

# t_distinct is used to test 'distinct' case.
# for now, the redundant distinct operator cannot be removed in this case.
create table t_distinct (c1 int, c2 int, c3 int, c4 int, primary key(c4));

explain select distinct c1, c2 from (select distinct c1, c2 from t_distinct);

explain select distinct c1, c2 from (select c1, c2, c3 from t_distinct group by c1, c2);

# t_join_1, t_join_2 is used to test 'unique-columns after join'
# fro now, the redundant distinct operator cannnot be removed in this case.

create table t_join_1(pk_1 int, c2 int, c3 int, primary key(pk_1));
create table t_join_2(pk_2 int, c2 int, c3 int, primary key(pk_2));

explain select distinct pk_1 from t_join_1, t_join_2 where pk_1 = pk_2;

# t_uniq_not_null is used to test 'unique key not null' case.
create table t_uniq_not_null (c1 int not null, c2 int, c3 int, unique key (c1));

# test select unique key not null
explain select distinct c1 from t_uniq_not_null;
explain select distinct c1, c2 from t_uniq_not_null;
explain select distinct c1, c2, c3 from t_uniq_not_null;

# test group by with roll up(group by cannot be removed when rollup provided)
explain select c1 from t_pk group by c1 with rollup;
explain select c1 from t_pk group by c1,c2 with rollup;
explain select c1,c2 from t_pk_multi group by c1,c2 with rollup;

# test group by (group by can be removed when no rollup)
explain select c1 from t_pk group by c1;
explain select c1 from t_pk group by c1,c2;
explain select c1,c2 from t_pk_multi group by c1,c2;

drop table t_pk, t_pk_multi, t_uniq, t_uniq_multi, t_group_by, t_group_by_pk, t_distinct, t_join_1, t_join_2, t_uniq_not_null;
