create table t1(pk1 int, pk2 int, key1 int, key2 int, key3 int, key4 int, key5 int, key6 int, key7 int, key8 int, key9 int,primary key(pk1, pk2),index i1 (key1,key2) storing(key9),index i2 (key3,key4,key5) storing(key9),key i4 (key6),key i5 (key7,key8) storing(key9),index i6 (key1,pk2) storing(key9));

insert into t1 values
(1,2,2,2,3,4,5,6,7,8,9),
(2,2,3,3,3,4,5,6,7,8,9),
(3,4,1,2,3,4,5,6,7,8,9),
(4,4,1,2,3,4,5,6,7,8,9),
