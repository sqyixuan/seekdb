--result_format 3
--explain_protocol 1

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: link.zt
# owner group: sql1
# tags: optimizer
# description: 测试在右表为全表扫描时不生成NL的机制

--disable_warnings
DROP DATABASE IF EXISTS NL_RIGHT_FULL_SCAN;
--enable_warnings
CREATE DATABASE NL_RIGHT_FULL_SCAN;
USE NL_RIGHT_FULL_SCAN;

create table T1 (c1 int, c2 int);
create table T2 (d1 int, d2 int, d3 int, index idx_d3(d3));
create table T3 (d1 int, d2 int key);
create table T4 (d1 int key, d2 int);
create table T5 (d1 int, d2 int, index idx_d1(d1));
insert into T1 values (1, 2);

--echo # 场景1
--echo # 表T1共1行，且有过滤条件c2 = 5，估计出的行数
--echo # 远小于1，NL是更优计划。但是右表是全表扫描
--echo # 所以禁止NL路径
explain select /*+ leading(T1 T2) index(T2 idx_d3) */* from T1, T2 where c1 = d1 and c2 = 5;
explain select /*+ leading(T1 T2) use_nl(T1 T2) index(T2 idx_d3) */* from T1, T2 where c1 = d1 and c2 = 5;
explain select /*+ leading(T1 T2) use_hash(T1 T2) index(T2 idx_d3) */* from T1, T2 where c1 = d1 and c2 = 5;

--echo # 场景1(2)
--echo # 表T1共1行，且有过滤条件c2 = 5，估计出的行数
--echo # 远小于1，NL是更优计划。但是右表是全表扫描
--echo # 所以禁止NL路径
explain select /*+ leading(T1 T2) index(T2 idx_d3) */* from T1, T2 where c1 = d1 and c2 = 5 and d2 > 5;
explain select /*+ leading(T1 T2) use_nl(T1 T2) index(T2 idx_d3) */* from T1, T2 where c1 = d1 and c2 = 5 and d2 > 5;
explain select /*+ leading(T1 T2) use_hash(T1 T2) index(T2 idx_d3) */* from T1, T2 where c1 = d1 and c2 = 5 and d2 > 5;

--echo # 场景2
--echo # 表T1共1行，且有过滤条件c2 = 5，估计出的行数
--echo # 远小于1，NL是更优计划。右表T3带有range
--echo # 不禁止NL路径
explain select /*+ leading(T1 T3) */* from T1, T3 where c1 = d1 and c2 = 5 and d2 = 5;
explain select /*+ leading(T1 T3) use_nl(T1 T3) */* from T1, T3 where c1 = d1 and c2 = 5 and d2 = 5;
explain select /*+ leading(T1 T3) use_hash(T1 T3) */* from T1, T3 where c1 = d1 and c2 = 5 and d2 = 5;

--echo # 场景2(2)
--echo # 表T1共1行，且有过滤条件c2 = 5，估计出的行数
--echo # 远小于1，NL是更优计划。右表T3带有range
--echo # 不禁止NL路径
explain select /*+ leading(T1 T3) */* from T1, T3 where c1 = d1 and c2 = 5 and d2 > 5;
explain select /*+ leading(T1 T3) use_nl(T1 T3) */* from T1, T3 where c1 = d1 and c2 = 5 and d2 > 5;
explain select /*+ leading(T1 T3) use_hash(T1 T3) */* from T1, T3 where c1 = d1 and c2 = 5 and d2 > 5;

--echo # 场景3
--echo # 表T1共1行，且有过滤条件c2 = 5，估计出的行数
--echo # 远小于1，NL是更优计划。右表T4带有下推的主键range
--echo # 不禁止NL路径
explain select /*+ leading(T1 T4) */* from T1, T4 where c1 = d1 and c2 = 5;
explain select /*+ leading(T1 T4) use_nl(T1 T4) */* from T1, T4 where c1 = d1 and c2 = 5;
explain select /*+ leading(T1 T4) use_hash(T1 T4) */* from T1, T4 where c1 = d1 and c2 = 5;

--echo # 场景4
--echo # 表T1共1行，且有过滤条件c2 = 5，估计出的行数
--echo # 远小于1，NL是更优计划。右表T5带有下推的索引range
--echo # 不禁止NL路径
explain select /*+ leading(T1 T5) index(T5 idx_d1) */* from T1, T5 where c1 = d1 and c2 = 5;
explain select /*+ leading(T1 T5) use_nl(T1 T5) index(T5 idx_d1) */* from T1, T5 where c1 = d1 and c2 = 5;
explain select /*+ leading(T1 T5) use_hash(T1 T5) index(T5 idx_d1) */* from T1, T5 where c1 = d1 and c2 = 5;

--echo # 场景5
--echo # 表T1共1行，且有过滤条件c2 = 5，估计出的行数
--echo # 远小于1，只能生成NL计划。不禁止NL路径
explain select /*+ leading(T1 T2) */* from T1, T2 where c1 < d1 and c2 = 5;
explain select /*+ leading(T1 T2) */* from T1, T2 where c1 != d1 and c2 = 5;
explain select /*+ leading(T1 T2) */* from T1, T2 where c1 + d1 = 6 and c2 = 5;

USE NL_RIGHT_FULL_SCAN;
--disable_warnings
DROP DATABASE IF EXISTS NL_RIGHT_FULL_SCAN;
--enable_warnings
