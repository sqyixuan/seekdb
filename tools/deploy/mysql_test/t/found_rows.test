--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: peihan.dph
# owner group: SQL3
# description: 本case是为了测试found_rows函数在各种语境下的表现
#tags: optimizer, found_rows

--disable_abort_on_error
--disable_warnings
drop database if exists found_rows;
create database found_rows;
use found_rows;

###
#查询中带有limit x,y时found_rows的行为和mysql不一致
#
###
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1 (name varchar(255));
insert into t1 values ('test1'), ('test2'), ('test2'), ('test4'); 
select * from t1 limit 2,2;
select found_rows();
--disable_warnings
drop table if exists t1;
--enable_warnings

###
#union中带有limit的时候，found_rows表现和mysql不一致
#
###
--disable_warnings
drop table if exists t1; 
--enable_warnings
create table t1 (name varchar(255));
insert into t1 values ('test1'), ('test2'), ('test3'), ('test4'), ('test5'); 
--disable_warnings
drop table if exists t2; 
--enable_warnings
create table t2 (name varchar(255));
insert into t2 values ('test1'), ('test3'), ('test5'), ('test7'), ('test9');
(select SQL_CALC_FOUND_ROWS * from t1 limit 2) union all (select * from t2) limit 3;
select found_rows();  
drop table t1;

create table test2(c1 int primary key auto_increment, c2 timestamp);
create table test(c1 int primary key auto_increment);
insert into test values(),(),(),();
insert into test values(),(),(),();
insert into test2 values(),(),(),();

select c1 from (select sql_calc_found_Rows c1 from test2) tt;
select sql_calc_found_rows c1 from (select c1  from test2) tt;
select found_Rows();
select sql_calc_found_rows c1 from (select c1  from test2) tt limit 3;
select found_Rows();
select c1 from (select sql_calc_found_Rows c1 from test2) tt;
(select sql_calc_found_rows c1 from test) except (select c1 from test2) limit 2;
select found_Rows();
(select c1 from test) except (select c1 from test2) limit 12;
select found_Rows();

select sql_calc_found_rows * from test union all select sql_calc_found_rows * from test2;
select * from test union all select sql_calc_found_rows * from test2;

select * from test where c1 in (select sql_calc_found_rows c1 from test);
select sql_calc_found_rows * from test where c1 in(select c1 from test) limit 2;
select found_Rows();
select sql_calc_found_rows * from test where c1 in(select c1 from test) limit 12;
select found_Rows();
(select c1 from test) except (select c1 from test2) limit 2;
select sql_calc_found_rows test.c1 from test join (select test.c1,test3.c1 as c2 from test join test3 on test.c1 = test3.c1) tt on test.c1 = tt.c1 limit 2;
select found_Rows();
select test.c1 from test join (select test.c1,test3.c1 as c2 from test join test3 on test.c1 = test3.c1) tt on test.c1 = tt.c1 limit 2;
select found_Rows();
select row_count();
--disable_warnings
insert into test values(),(),(),();
select row_count();

drop table test;
drop table test2;
create table test(c1 int primary key);
insert into test values(1),(2),(3),(4),(5),(6),(7);
select * from test;
insert into test values(8);
create table tt(c1 int);
drop table tt;
select found_Rows();
select found_Rows();
insert into test values(9);
select found_Rows();
--disable_result_log
explain select found_Rows();
--enable_result_log
select found_Rows();
--disable_result_log
explain insert into test values(1);
--enable_result_log
select found_Rows();
--disable_result_log
explain select found_Rows();
--enable_result_log
--disable_result_log
explain insert into test values(1);
--enable_result_log
select found_Rows();

######
#
# 函数found_rows()在limit m,n当m+n>总行数时，结果不对
#####
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(c1 int);
insert into t1 values(1),(2),(1),(4),(5),(3),(2);
select * from t1 limit 3,1;
select found_rows();
select * from t1 limit 3,2;
select found_rows();

####
# 带 limit n的形式
####
select * from t1 limit 3;
select found_rows();
select * from t1 limit 30;
select found_rows();
select * from t1 limit 0,2;
select found_rows();
select * from t1 limit 2, 2;
select found_rows();
select * from t1 limit 2, 20;
select found_rows();
select * from t1 limit 12, 20;
select found_rows();
select * from t1 limit 2 offset 4;
select found_rows();
select * from t1 limit 2, 4;
select found_rows();

select sql_calc_found_rows * from t1 limit 3;
select found_rows();
select sql_calc_found_rows * from t1 limit 30;
select found_rows();
select sql_calc_found_rows * from t1 limit 2, 2;
select found_rows();
select sql_calc_found_rows * from t1 limit 2, 20;
select found_rows();
select sql_calc_found_rows * from t1 limit 12, 20;
select found_rows();
select sql_calc_found_rows * from t1 limit 2 offset 4;
select found_rows();
select sql_calc_found_rows * from t1 limit 2, 4;
select found_rows();
select found_rows();
insert into t1 values(3),(2),(9);
select found_rows();
select sql_calc_found_rows * from t1 limit 2 offset 4;
set @@session.sql_mode = '';
select found_rows();
drop table t1;
drop database found_rows;
