--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: nijia.nj
# owner group: SQL1
# description: sql限流，仅测语法
#
let $zone_count = 1;
let $unit_num = 1;

# mysql
connect (ob_sys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection ob_sys;
let $zone1 = query_get_value(select distinct zone from oceanbase.__all_zone where zone != '' limit 2, zone, 1); 
--disable_warnings
#eval CREATE RESOURCE UNIT if not exists config_mysql MAX_CPU=1, MEMORY_SIZE='2G';
--disable_query_log
#eval CREATE RESOURCE POOL if not exists pool_mysql UNIT='config_mysql', UNIT_NUM=$unit_num, ZONE_LIST=('$zone1');
set @@session.ob_query_timeout = 20000000;
#eval CREATE TENANT if not exists tt_mysql REPLICA_NUM = $zone_count, RESOURCE_POOL_LIST = ('pool_mysql'), primary_zone = "$zone1" set ob_tcp_invited_nodes='%';
set @@session.ob_query_timeout = 10000000;
--enable_query_log
--enable_warnings
--source mysql_test/include/check_tenant_sync.inc
let $__tenant_name__ = 'sys';
--source mysql_test/include/get_tenant_server.inc
connect (obmysql, $TE_SERVER_IP, root,,*NO-ONE*, $TE_SERVER_PORT);
connection obmysql;
alter system enable sql throttle for priority <= 100 using queue_time=100;
alter system enable sql throttle for priority <= 100 using rt=100;
show global variables like '%sql_throttle%';
alter system disable sql throttle;
show global variables like '%sql_throttle%';

connection ob_sys;
--disable_query_log
#DROP TENANT if exists tt_mysql FORCE;
#DROP RESOURCE POOL if exists pool_mysql;
#DROP RESOURCE UNIT if exists config_mysql;
--enable_query_log

