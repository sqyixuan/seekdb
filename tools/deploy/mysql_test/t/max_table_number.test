--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: peihan.dph
# owner group: SQL2
# description:
#
let $cnt=200;
--disable_warnings
while($cnt)
{
   eval drop table if exists tmaxnum_$cnt;
   eval create table tmaxnum_$cnt (c1 int primary key);
   dec $cnt;
}
--enable_warnings
--sorted_result
show tables like 'tmaxnum__%' escape '_';
