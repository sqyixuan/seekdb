--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

#owner:linlin.xll
#owner group: SQL1
#description: case transferred from mysql。
#tags: inner_table

--echo #
--echo # Bug#46941 crash with lower_case_table_names=2 and
--echo #           foreign data dictionary confusion
--echo #

connect (conn0,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn0;

--disable_warnings
#drop tenant if exists lower_case force;
#drop resource pool if exists lower_pool1;
#drop resource unit if exists lower_box1;
drop database if exists XY;
--enable_warnings

let $zone_count = 1;
#drop resource pool if exists lower_pool1;
#drop resource unit if exists lower_box1;
--disable_query_log
#eval create resource unit lower_box1 max_cpu 1, memory_size '2G';

#eval create resource pool lower_pool1 unit = 'lower_box1', unit_num = 1, zone_list = ('$zone_name');
#eval CREATE TENANT lower_case REPLICA_NUM = $zone_count, RESOURCE_POOL_LIST = ('lower_pool1') set lower_case_table_names = 2, ob_tcp_invited_nodes='%';
--enable_query_log
--source mysql_test/include/check_tenant_sync.inc

##time to sync schema
let $__tenant_name__ = 'sys';
--source mysql_test/include/get_tenant_server.inc
connect (conn1,$TE_SERVER_IP,root,,*NO-ONE*,$TE_SERVER_PORT);
connection conn1;

show variables like 'lower_case_table_names';
--enable_warnings

CREATE DATABASE XY;
USE XY;

#
# Logs are disabled, since the number of creates tables
# and subsequent select statements may vary between
# versions
#
--disable_query_log
--disable_result_log

let $i = 10;

while ($i)
{
  eval CREATE TABLE XY.T_$i (a INT NOT NULL, b INT NOT NULL, c INT NOT NULL, d INT, primary key(a, b), unique(b));
  dec $i;
}

let $i = 10;
while ($i)
{
  eval SELECT * FROM XY.T_$i LIMIT 1;
  dec $i;
}

DROP DATABASE XY;
CREATE DATABASE XY;
USE XY;
eval CREATE TABLE XY.T_$tcs (a INT NOT NULL, b INT NOT NULL, c INT NOT NULL, d INT, PRIMARY KEY(a, b), UNIQUE(b));
#
# The bug causes this SELECT to err
eval SELECT * FROM XY.T_$tcs LIMIT 1;

--enable_query_log
--enable_result_log
DROP DATABASE XY;
--disable_warnings
create database if not exists TEST;
--enable_warnings
USE TEST;

--echo #
--echo # Bug55222 Mysqldump table names case bug in REFERENCES clause
--echo # InnoDB did not handle lower_case_table_names=2 for
--echo # foreign_table_names and referenced_table_names.
--echo #

SHOW VARIABLES LIKE 'lower_case_table_names';

--disable_warnings
DROP TABLE IF EXISTS `Table2`;
DROP TABLE IF EXISTS `Table1`;
--disable_warnings

CREATE TABLE `Table1`(c1 INT PRIMARY KEY);

CREATE TABLE `Table2`(c1 INT PRIMARY KEY, c2 INT);

--source mysql_test/include/show_create_table_old_version.inc
query_vertical SHOW CREATE TABLE `Table2`;
DROP TABLE `Table2`;
DROP TABLE `Table1`;

--disable_warnings
DROP TABLE IF EXISTS Product_Order;
DROP TABLE IF EXISTS Product;
DROP TABLE IF EXISTS Customer;
--enable_warnings

CREATE TABLE Product (Category INT NOT NULL, Id INT NOT NULL, Price DECIMAL, PRIMARY KEY(Category, Id));

CREATE TABLE Customer (Id INT NOT NULL, PRIMARY KEY (Id));

CREATE TABLE Product_Order (No INT NOT NULL AUTO_INCREMENT, Product_Category INT NOT NULL, Product_Id INT NOT NULL, Customer_Id INT NOT NULL, PRIMARY KEY(No), INDEX (Product_Category, Product_Id), INDEX (Customer_Id));


--source mysql_test/include/show_create_table_old_version.inc
query_vertical SHOW CREATE TABLE Product_Order;
--source mysql_test/include/show_create_table_old_version.inc
query_vertical SHOW CREATE TABLE Product;
--source mysql_test/include/show_create_table_old_version.inc
query_vertical SHOW CREATE TABLE Customer;
DROP TABLE Product_Order;
DROP TABLE Product;
DROP TABLE Customer;



connection conn0;
--disable_warnings
#drop tenant if exists lower_case force;
#drop resource pool if exists lower_pool1;
#drop resource unit if exists lower_box1;
drop database if exists XY;
--enable_warnings
