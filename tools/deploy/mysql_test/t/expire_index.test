# owner: xiaoyi.xy
# owner group: SQL3
# comment: this case is marked as expired in filter.py

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
###TITLE:EXPIRE_INFO with index

--disable_query_log
--source mysql_test/include/index_quick_major.inc 
--real_sleep 1
--disable_warnings
drop table if exists t1,t2,t3,t4,t5;
--enable_warnings
--enable_query_log
create table t1 (c1 int primary key, c2 varchar(1024), c3 int) EXPIRE_INFO=(c2 = 'a'),EXPIRE_INFO=(c1 = 'a');
drop table t1;
create table t1 (c1 int primary key, c2 varchar(1024), c3 int) EXPIRE_INFO=(c2 = 'a');
--error 1064
create index t11 on t1 (c2) EXPIRE_INFO=(c2 = 'a');
insert into t1 values(1,'a',1),(2,'b',2),(3,'b',3),(4,'a',4);
insert into t1(c1) values(5);

create table t2 (c1 int primary key, c2  timestamp(6) default "2012-01-01 12:00:00", c3 int) EXPIRE_INFO=(c2 = '2013-12-12 00:00:00' or c2 is null);
insert into t2 values(1,'2013-12-12 00:00:00',1),(2,'2013-12-12 00:00:01',2);
insert into t2(c1) values(3);

####CASE: index with varchar as expire condition
create index t11 on t1 (c2);
create index t12 on t1 (c2) storing(c3);
create index t13 on t1 (c3);
create index t14 on t1 (c3) storing(c2);

let $idx11 = query_get_value(select a.table_name from oceanbase.__all_virtual_table as a inner join (select * from oceanbase.__all_virtual_table where table_name='t1') b on a.data_table_id=b.table_id order by a.table_id, table_name, 1);
let $idx12 = query_get_value(select a.table_name from oceanbase.__all_virtual_table as a inner join (select * from oceanbase.__all_virtual_table where table_name='t1') b on a.data_table_id=b.table_id order by a.table_id, table_name, 2);
let $idx13 = query_get_value(select a.table_name from oceanbase.__all_virtual_table as a inner join (select * from oceanbase.__all_virtual_table where table_name='t1') b on a.data_table_id=b.table_id order by a.table_id, table_name, 3);
let $idx14 = query_get_value(select a.table_name from oceanbase.__all_virtual_table as a inner join (select * from oceanbase.__all_virtual_table where table_name='t1') b on a.data_table_id=b.table_id order by a.table_id, table_name, 4);


####CASE: index with timestamp as expire condition
create index t21 on t2 (c2);
create index t22 on t2 (c2) storing(c3);
create index t23 on t2 (c3);
create index t24 on t2 (c3) storing(c2);

let $idx21 = query_get_value(select a.table_name from oceanbase.__all_virtual_table as a inner join (select * from oceanbase.__all_virtual_table where table_name='t2') b on a.data_table_id=b.table_id order by a.table_id, table_name, 1);
let $idx22 = query_get_value(select a.table_name from oceanbase.__all_virtual_table as a inner join (select * from oceanbase.__all_virtual_table where table_name='t2') b on a.data_table_id=b.table_id order by a.table_id, table_name, 2);
let $idx23 = query_get_value(select a.table_name from oceanbase.__all_virtual_table as a inner join (select * from oceanbase.__all_virtual_table where table_name='t2') b on a.data_table_id=b.table_id order by a.table_id, table_name, 3);
let $idx24 = query_get_value(select a.table_name from oceanbase.__all_virtual_table as a inner join (select * from oceanbase.__all_virtual_table where table_name='t2') b on a.data_table_id=b.table_id order by a.table_id, table_name, 4);

--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/check_all_idx_ok.inc
--source mysql_test/include/wait_daily_merge.inc


insert into t1 values(6,'a',6),(7,'b',7);
insert into t2 values(4,'2013-12-12 00:00:00',4),(5,'2013-12-12 00:00:01',5);

select * from t1;
--disable_query_log
eval select * from $idx11;
eval select * from $idx12;
eval select * from $idx13;
eval select * from $idx14;
--enable_query_log

select * from t2;
--disable_query_log
eval select * from $idx21;
eval select * from $idx22;
eval select * from $idx23;
eval select * from $idx24;
--enable_query_log

--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
--source mysql_test/include/wait_daily_merge.inc

select * from t1;
--disable_query_log
eval select * from $idx11;
eval select * from $idx12;
eval select * from $idx13;
eval select * from $idx14;
--enable_query_log

select * from t2;
--disable_query_log
eval select * from $idx21;
eval select * from $idx22;
eval select * from $idx23;
eval select * from $idx24;
--enable_query_log

