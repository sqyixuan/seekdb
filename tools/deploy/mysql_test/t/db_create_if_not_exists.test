--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: dachuan.sdc
#owner group : sql2
--disable_warnings
DROP DATABASE IF EXISTS d2;
CREATE DATABASE d2;
CREATE DATABASE IF NOT EXISTS d2;
SHOW DATABASES like 'd2';
USE d2;
DROP DATABASE d2;
DROP DATABASE IF EXISTS d2;
CREATE SCHEMA d2;
CREATE SCHEMA IF NOT EXISTS d2;
SHOW DATABASES like 'd2';
USE d2;
DROP SCHEMA d2;
DROP SCHEMA IF EXISTS d2;
--enable_warnings

