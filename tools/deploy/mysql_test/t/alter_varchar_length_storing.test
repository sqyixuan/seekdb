sleep 1;
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
insert into t1 values(3,'aaabbbbbbbbbbbbbbbbbbbb',12);
select * from t1;

--disable_query_log
eval select * from $idx11;
--enable_query_log

