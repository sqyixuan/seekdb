select * from t1;

--disable_query_log
eval select * from $idx11;
--enable_query_log

#update
update t1 set v1='aaaabbbbbbbbbbbbbbbbbbbbb',v2=15 where pk=4;
--error 1406
update t1 set v1='aaabbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb',v2=12 where pk=3;
update t1 set v1='aaaaaab',v2=7 where pk=6;

select * from t1;
--disable_query_log
