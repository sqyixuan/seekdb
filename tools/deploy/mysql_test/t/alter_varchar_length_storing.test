--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: bin.lb
# owner group: SQL2
# tags: alter
# description:
#
--disable_warnings
drop table if exists t1,t2,t3,t4;
--enable_warnings
create table t1(pk int primary key, v1 varchar(10), v2 varchar(10));
create index idx_t1 on t1(v2) storing(v1);
insert into t1 values(1,'abbbbbb',6),(2,'aabbbbbbbb',10);

let $ten_id = query_get_value(select effective_tenant_id() x, x, 1);

--source mysql_test/include/index_quick_major.inc
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
--source mysql_test/include/check_all_idx_ok.inc
connect (sysc,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection sysc;
let $idx11 = query_get_value(select a.table_name from oceanbase.__all_virtual_table as a inner join (select * from oceanbase.__all_virtual_table where table_name='t1') b on a.data_table_id=b.table_id and a.tenant_id = $ten_id, table_name, 1);
connection default;

set ob_enable_index_direct_select=1;

##长度改大，无静态数据
desc t1;
--disable_query_log
--enable_query_log
alter table t1 modify column v1 varchar(20);
sleep 1;
desc t1;
--disable_query_log
--enable_query_log

#insert 
insert into t1 values(3,'aaabbbbbbbbb',12),(4,'aaaabbbbbbbbbbb',15);
--error 1406
insert into t1 values(5,'aaaaabbbbbbbbbbbbbbbb',21);
insert into t1 values(6,'aaaaaab',7);

select * from t1;

--disable_query_log
eval select * from $idx11;
--enable_query_log


#replace
replace into t1 values(1,'abbbbbbbbbbbbbbbbbbb',6),(7,'aaaaaaabbbbbbbbbbb',18);
--error 1406
replace into t1 values(2,'aabbbbbbbbbbbbbbbbbbbb',22);
replace into t1 values(3,'aaabbbbb',12);

select * from t1;
--disable_query_log
eval select * from $idx11;
--enable_query_log


#update
update t1 set v1='aabbbbbbbbbbbbbb' where pk=2;
update t1 set v1='aaaaaaaabbbbbbb'  where pk=8;
--error 1406
update t1 set v1='aaaaaaabbbbbbbbbbbbbb' where pk=7;
update t1 set v1='aaaab'  where pk=4;
select * from t1;

--disable_query_log
eval select * from $idx11;
--enable_query_log

#delete alter major(无静态数据)
delete from t1 where pk=1;
alter table t1 modify column v1 varchar(22);
sleep 1;
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
insert into t1 values(1,'abbbbbbbbbbbbbbbbbbbbb',6);
select * from t1;

--disable_query_log
eval select * from $idx11;
--enable_query_log

