#长度改小
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(pk varchar(1) primary key, v1 varchar(10), v2 varchar(10));
create index idx_t1 on t1(v2) storing(v1);
--disable_query_log
connection sysc;
let $idx11 = query_get_value(select a.table_name from oceanbase.__all_virtual_table as a inner join (select * from oceanbase.__all_virtual_table where table_name='t1') b on a.data_table_id=b.table_id and a.tenant_id = $ten_id, table_name, 1);
connection default;
--enable_query_log

--source mysql_test/include/index_quick_major.inc
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
--source mysql_test/include/check_all_idx_ok.inc

--error 1235
alter table t1 modify column v1 varchar(5);

#边界值和特殊值
desc t1;
--disable_query_log
--enable_query_log
--error 1235
alter table t1 modify column v1 varchar(0);
sleep 1;
desc t1;
--disable_query_log
--enable_query_log
--error 1064
alter table t1 modify column v1 varchar(-1);
sleep 1;
desc t1;
--disable_query_log
--enable_query_log
alter table t1 modify column v1 varchar(65535);
sleep 1;
desc t1;
--disable_query_log
--enable_query_log
alter table t1 modify column v1 varchar(65535);
sleep 1;
drop table t1;

create table t1(pk varchar(4096) primary key, v1 varchar(65535),v2 varchar(65535),v3 varchar(65535), v4 varchar(65535), i1 int, v5 varchar(65535),v6 varchar(4096));
create index idx_t1 on t1(i1) storing(v6);
--error 1118
alter table t1 modify column v6 varchar(65535);
drop table t1;

#expire
create table t2(pk int primary key, v1 varchar(5), v2 varchar(10)) EXPIRE_INFO (v1='aaaaa');
create index idx_t2 on t2(v2) storing(v1);
connection sysc;
let $idx21 = query_get_value(select a.table_name from oceanbase.__all_virtual_table as a inner join (select * from oceanbase.__all_virtual_table where table_name='t2') b on a.data_table_id=b.table_id and a.tenant_id = $ten_id, table_name, 1);
connection default;

insert into t2 values(1,'aaaaa',5),(2,'aaaa',4);
alter table t2 modify column v1 varchar(6);
sleep 1;
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/check_all_idx_ok.inc
select * from t2;
--disable_query_log
eval select * from $idx21;
--enable_query_log

insert into t2 values(3,'aaaaaa',6);
--error 1406
insert into t2 values(4,'aaaaaaa',7);
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
select * from t2;

--disable_query_log
eval select * from $idx21;
--enable_query_log

alter table t2 set EXPIRE_INFO (v1='aaaaaa');
sleep 1;
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
select * from t2;

--disable_query_log
eval select * from $idx21;
--enable_query_log

create table t3(pk int primary key, v1 varchar(5), v2 varchar(10)) EXPIRE_INFO (v1 = 'aaaaaa');
create index idx_t3 on t3(v2) storing(v1);
connection sysc;
let $idx31 = query_get_value(select a.table_name from oceanbase.__all_virtual_table as a inner join (select * from oceanbase.__all_virtual_table where table_name='t3') b on a.data_table_id=b.table_id and a.tenant_id = $ten_id, table_name, 1);
connection default;
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/check_all_idx_ok.inc
insert into t3 values(1,'aaaaa',5);
alter table t3 modify column v1 varchar(6);
sleep 1;
insert into t3 values(2,'aaaaaa',6);
select * from t3;

--disable_query_log
eval select * from $idx31;
--enable_query_log

--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
select * from t3;

--disable_query_log
eval select * from $idx31;
--enable_query_log

alter table t3 set EXPIRE_INFO (v1 > 'aaaaaa');
alter table t3 modify column v1 varchar(8);
insert into t3 values(3,'aaaaaaa',7),(4,'aaaaaaaa',8);
select * from t3;

--disable_query_log
eval select * from $idx31;
--enable_query_log

--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
select * from t3;

--disable_query_log
eval select * from $idx31;
--enable_query_log

##defalut value
create table t4(pk int primary key, v1 varchar(5) default 'aa' not null, v2 varchar(10));
create index idx_t4 on t4(v2) storing(v1);
connection sysc;
let $idx41 = query_get_value(select a.table_name from oceanbase.__all_virtual_table as a inner join (select * from oceanbase.__all_virtual_table where table_name='t4') b on a.data_table_id=b.table_id and a.tenant_id = $ten_id, table_name, 1);
connection default;
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
--source mysql_test/include/check_all_idx_ok.inc

insert into t4 values(1,'aa',2),(2,'aaa',3);
insert into t4(pk,v2) values(3,2);
alter table t4 modify column v1 varchar(6) default 'aa' not null;
select * from t4;

--disable_query_log
eval select * from $idx41;
--enable_query_log

alter table t4 alter v1 set default 'aaaaa';
sleep 1;
insert into t4(pk,v2) values(4,2);
select * from t4;

--disable_query_log
eval select * from $idx41;
--enable_query_log

alter table t4 alter v1 set default 'aaaaaa';
sleep 1;
select * from t4;

--disable_query_log
eval select * from $idx41;
--enable_query_log


insert into t4(pk,v2) values(5,6);
select * from t4;

--disable_query_log
eval select * from $idx41;
--enable_query_log

--error 1067
alter table t4 alter v1 set default 'aaaaaaa';

--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/check_all_idx_ok.inc
--source mysql_test/include/wait_daily_merge.inc

select * from t4;

--disable_query_log
eval select * from $idx41;
--enable_query_log

alter table t4 modify column v1 varchar(7) default 'aaaaaa' not null;
sleep 1;
insert into t4(pk,v2) values(6,6);
alter table t4 alter v1 set default 'aaaaaaa';
sleep 1;
insert into t4(pk,v2) values(7,7);
--error 1067
alter table t4 alter v1 set default 'aaaaaaaa';
select * from t4;

--disable_query_log
eval select * from $idx41;
--enable_query_log

drop table t4;
 



