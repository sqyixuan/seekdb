--disable_query_log
--source mysql_test/include/index_quick_major.inc
--real_sleep 1
--disable_warnings
drop table if exists test_8760651;
--enable_warnings
--enable_query_log

create table test_8760651(pk int primary key, n1 int, n2 int);
insert into test_8760651(pk, n1, n2) values(1,1,1), (2,2,2), (3,3,3), (4,4,4), (5,5,5);
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc


alter table test_8760651 add n3 varchar(10) default 'way';
create index i1 on test_8760651(n3);
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
--real_sleep 2
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
select t2.index_status from oceanbase.__all_virtual_table t1, oceanbase.__all_virtual_table t2 where t1.table_name = 'test_8760651' and t2.data_table_id = t1.table_id;
disconnect obsys;
