--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: yibo.tyf
#owner group: sql1


--echo #
--echo # Bug#13723054 CRASH WITH MIN/MAX AFTER QUICK_GROUP_MIN_MAX_SELECT::NEXT_MIN
--echo #

--disable_warnings
drop table if exists t1;
--enable_warnings

CREATE TABLE t1(b VARCHAR(255), c INT,
                KEY(b, c));
INSERT INTO t1(b, c) VALUES ('a', 0), ('a', null), ('a', 0),
                               ('a', null), ('a', 0);

#-- disable_result_log
#ANALYZE TABLE t1;
#-- enable_result_log

SELECT MIN(c) FROM t1 GROUP BY b;
#EXPLAIN SELECT MIN(c) FROM t1 GROUP BY b;

DROP TABLE t1;


