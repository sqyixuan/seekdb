--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: yuchen.wyc
# owner group: SQL1
#description: Test index with kay ranges
####TITEL:
####table with index,
####update range and delete range are used in trx
####idxkeys are used as where condition
--disable_query_log
--source mysql_test/include/index_quick_major.inc
--real_sleep 1
--disable_warnings
drop table if exists t1;
--enable_warnings
set global ob_enable_index_direct_select =1;
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
alter system set merger_check_interval = '10s' tenant sys;
alter system set merger_check_interval = '10s' tenant all_user;
alter system set merger_check_interval = '10s' tenant all_meta;
disconnect obsys;
connection default;
--enable_query_log

connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (trx1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (trx2,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);

connection conn1;
create table t1(pk1 int, c1 int, c2 int, c3 int, primary key(pk1));
connection conn1;
create index i1 on t1(c1,c2) storing(c3);
let $idx1 = query_get_value(select a.table_name from oceanbase.__all_table as a inner join (select * from oceanbase.__all_table where table_name='t1' and database_id=(select database_id from oceanbase.__all_database where database_name='test')) b on a.data_table_id=b.table_id, table_name, 1);
connection default;

insert into t1(pk1,c1,c2,c3) values(1,1,1,1);
insert into t1(pk1,c1,c2,c3) values(2,1,1,1);
insert into t1(pk1,c1,c2,c3) values(3,1,2,1);
insert into t1(pk1,c1,c2,c3) values(4,1,2,1);
insert into t1(pk1,c1,c2,c3) values(5,2,3,1);
insert into t1(pk1,c1,c2,c3) values(6,2,3,1);
insert into t1(pk1,c1,c2,c3) values(7,2,4,1);
insert into t1(pk1,c1,c2,c3) values(8,2,4,1);


--source mysql_test/include/check_all_idx_ok.inc

select * from t1;
--disable_query_log
set ob_enable_index_direct_select=1;
eval select * from $idx1;
--enable_query_log

####CASE: =, > ,>=, <, <=, 5048
connection trx1;
set autocommit=0;

connection trx2;
set autocommit=0;
update t1 set c3=c3+1 where c1=1 and c2=1;
update t1 set c3=c3+1 where c1=1 and c2>1 and c2<=2;
update t1 set c3=c3+1 where c1>1 and c1<3 and c2=3;
update t1 set c3=c3+1 where c1>=2 and c1<=3 and c2>3 and c2<=4;
select * from t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log

connection trx1;
select * from t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log

connection trx2;
commit;
delete from t1 where c1=1 and c2=1;
delete from t1 where c1=1 and c2>1 and c2<=2;
delete from t1 where c1>1 and c1<3 and c2=3;
delete from t1 where c1>=2 and c1<=3 and c2>3 and c2<=4;
select * from t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log

connection trx1;
select * from t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log
--error 1205,4012
update t1 set c3=c3+1 where c1=1 and c2=1;
--error 1205,4012
delete from t1 where c1=1 and c2=1;

connection trx2;
commit;
insert into t1(pk1,c1,c2,c3) values(1,1,1,1);
replace into t1(pk1,c1,c2,c3) values(2,1,1,1);
select * from t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log

connection trx1;
select * from t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log
--error 1205,4012
insert into t1(pk1,c1,c2,c3) values(1,1,1,1);
--error 1205,4012
replace into t1(pk1,c1,c2,c3) values(2,1,1,1);

update t1 set c3=c3+1 where pk1=1;
delete from t1 where pk1=2;

update t1 set c3=c3+1 where c1=1 and c2=1;
delete from t1 where c1=1 and c2=1;
select * from t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log

connection trx2;
select * from t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log
commit;

connection trx1;
select * from t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log
update t1 set c3=c3+1 where c1=1 and c2=1;
select * from t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log
commit;
select * from t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log
commit;

####CASE: =, 5048
connection conn1;
delete from t1;
insert into t1(pk1,c1,c2,c3) values (1,1,1,1),(2,1,1,1),(3,1,2,1),(4,1,2,1),(5,2,3,1),(6,2,3,1),(7,2,4,1),(8,2,4,1);
select * from t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log

connection trx1;
update t1 set c3=c3+1 where c1=1 and c2=1;
select * from t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log
delete from t1 where c1=1 and c2=2;
select * from t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log
insert into t1(pk1,c1,c2,c3) values (9,3,5,1);
replace into t1(pk1,c1,c2,c3) values (10,3,5,1);

connection trx2;
select * from t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log
--error 1205,4012
update t1 set c3=c3+1 where c1=1 and c2=1;
--error 1205,4012
update t1 set c3=c3+1 where c1=1 and c2=2;
--error 1205,4012
update t1 set c3=c3+1 where pk1=1;
--error 1205,4012
delete from t1 where c1=1 and c2=1;
--error 1205,4012
delete from t1 where c1=1 and c2=2;
--error 1205,4012
delete from t1 where pk1=1;

update t1 set c3=c3+1 where c1=3 and c2=5;
delete from t1 where c1=3 and c2=5;
select * from t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log

connection trx1;
commit;

connection trx2;
select * from t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log
update t1 set c3=c3+1 where c1=3 and c2=5;
select * from t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log
delete from t1 where c1=3 and c2=5;
select * from t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log

update t1 set c3=c3+1 where c1=3 and c2=5;
select * from t1 where c1=3 and c2=5;
--disable_query_log
eval select * from $idx1 where c1=3 and c2=5;
--enable_query_log


connection trx1;
--error 1205,4012
insert into t1(pk1,c1,c2,c3) values (9,3,5,1);
--error 1205,4012
replace into t1(pk1,c1,c2,c3) values (10,3,5,1);
select * from t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log

connection trx2;
commit;

connection trx1;
select * from t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log
commit;
select * from t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log
commit;

####CASE: is null, is not null, 5048
connection conn1;
delete from t1;
insert into t1(pk1,c1,c2,c3) values (1,1,NULL,1),(2,1,NULL,1),(3,1,1,1),(4,1,1,1),(5,2,NULL,1),(6,2,NULL,1),(7,2,1,1),(8,2,1,1);
select * from t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log

connection trx1;
update t1 set c3=c3+1 where c1=1 and c2 is NULL;
select * from t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log
delete from t1 where c1=1 and c2 is not NULL;
select * from t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log

connection trx2;
--error 1205,4012
update t1 set c3=c3+1 where c1=1 and c2 is NULL;
--error 1205,4012
delete from t1 where c1=1 and c2 is not NULL;
--error 1205,4012
insert into t1(pk1) values(1);
--error 1205,4012
replace into t1(pk1) values(1);
select * from t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log

connection trx1;
insert into t1(pk1,c1,c2,c3) values (100,NULL,NULL,1);
select * from t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log
commit;
update t1 set c3=c3+1 where c1 is null and c2 is null;

connection trx2;
--error 1205,4012
update t1 set c3=c3+1 where c1 is null and c2 is null;
--error 1205,4012
delete from t1 where c1 is null and c2 is null;
select * from t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log
commit;

connection trx1;
select * from t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log
commit;

connection trx1;
set autocommit=1;
connection trx2;
set autocommit=1;
drop table t1;
set global ob_enable_index_direct_select =0;
