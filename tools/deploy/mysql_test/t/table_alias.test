--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: bin.lb
# owner group: SQL2
# tags: dml
# description:
#
--disable_warnings
drop table if exists student, tab1, tab2;
--enable_warnings

create table student(id int primary key, name varchar(90));
insert into student values(1, 'zhangfei'),(2, 'guanyu');

--error 1054
select st1.id from student as st1, student as st2 where student.id = st2.id;

select st2.id from student , student st2 where student.id = st2.id;

drop table student;

create table tab1(c1 int primary key, c2 int);
create table tab2(c1 int primary key, c2 int);
insert into tab1 values(1,2);
insert into tab2 values(1,99);

select tab1.c2 from tab1 tab2, tab2 tab1 where tab1.c1=tab2.c1; 

drop table tab1, tab2;
