replace into t2(pk1,pk2,c1,c2) values(0,0,0,0),(0,1,0,0),(0,2,0,0),(0,3,0,0),(1,0,0,0),(1,1,0,0),(1,2,0,0),(1,3,0,0);
--error 5064
delete from t1 where pk1=1 when row_count(delete from t1 where pk1=0)=1;
--error 5064
delete from t2 where pk1=1 when row_count(delete from t1 where pk1=0)=1;
select * from t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log
select * from t2;
--disable_query_log
eval select * from $idx2;
--enable_query_log

