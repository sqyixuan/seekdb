--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: ryan.ly
#owner group: sql1
#tags: optimizer
#description: check self join, only used for check plan info, can not be used for mysqltest as explan extended will always be different.

--disable_query_log
--disable_result_log
--source mysql_test/include/index_quick_major.inc
--enable_query_log
--enable_result_log

--disable_warnings
drop table if exists a,b,c,d,pa,pb,pc;
--enable_warnings
Create table A(a1 int primary key, a2 int, a3 int);
Create table B(b1 int, b2 int, b3 int,b4 int,b5 int,primary key(b1,b2,b3));
Create table PA(a1 int primary key, a2 int, a3 int) partition by key(a1) partitions 4;
Create table PB(b1 int, b2 int, b3 int,b4 int,b5 int, primary key(b1,b2,b3)) partition by key(b1) partitions 4;

explain extended select /*+use_nl(a t)*/* from a,a t where a.a1=t.a1;
explain extended select /*+use_nl(a t)*/* from a,a t where a.a1=t.a2;
explain extended select /*+use_nl(a t)*/* from a,a t where a.a2=t.a1;
explain extended select /*+use_nl(a t)*/* from a,a t where a.a2=t.a2;
explain extended select /*+use_nl(a t)*/* from a,(select * from a order by a1 limit 1) t where a.a1=t.a1;
explain extended select /*+use_nl(a t)*/* from a,(select * from a group by a1 order by a1 limit 1) t where a.a1=t.a1;
explain extended select /*+use_nl(a t)*/* from a,(select * from a group by a2 order by a2 limit 1) t where a.a1=t.a1;
explain extended select /*+use_nl(a t)*/* from a,(select a.a1 from a, a t1 order by a.a2 limit 1) t where a.a1=t.a1;
explain extended select /*+use_nl(a t)*/* from a,(select t1.a1 from a, a t1 order by a.a2 limit 1) t where a.a1=t.a1;
explain extended select /*+use_nl(a t)*/* from a,(select t1.a2 as a1 from a, a t1 order by a.a2 limit 1) t where a.a1=t.a1;
explain extended select /*+use_nl(a t)*/* from a,(select a.a1 from a left join a t1 on a.a2=t1.a2 order by t1.a2 limit 1) t where a.a1=t.a1;
explain extended select /*+use_nl(a t)*/* from a,(select a.a1 from a right join a t1 on a.a2=t1.a2 order by t1.a2 limit 1) t where a.a1=t.a1;
explain extended select /*+use_nl(a t)*/* from a,(select t1.a1 from a right join a t1 on a.a2=t1.a2 order by t1.a2 limit 1) t where a.a1=t.a1;
explain extended select /*+use_nl(a t)*/* from a,(select t1.a1 from a right join (select * from a group by a2 order by a3 limit 1) t1 on a.a2=t1.a2 order by a.a2 limit 1) t where a.a1=t.a1;
explain extended select /*+use_nl(b t)*/* from b, (select * from b order by b3 limit 1) t where b.b1=t.b1;
explain extended select /*+use_nl(b t)*/* from b, (select * from b order by b3 limit 1) t where b.b1=t.b1 and t.b2=b.b2 and t.b3=b.b3;
explain extended select /*+use_nl(b t)*/* from b, (select * from b order by b3 limit 1) t where b.b1=t.b1 and t.b2=b.b2 and t.b3=b.b3 and t.b3=b.b3;
explain extended select /*+use_nl(b t)*/* from b, (select * from b order by b3 limit 1) t where b.b1=t.b1 and t.b2=b.b2 and t.b3=b.b3 and t.b3=1 and b.b3=2;
explain extended select /*+use_nl(b t)*/* from b, (select * from b order by b3 limit 1) t where b.b1=t.b1 and t.b2=1 and t.b3=2;
explain extended select /*+use_nl(b t)*/* from b, (select * from b order by b3 limit 1) t where b.b1=t.b1 and t.b2=1 and t.b3=1 and b.b2=2 and b.b3=2;
explain extended select /*+use_nl(b t)*/* from b, (select * from a right join (select * from b group by b2 order by b3 limit 2) v on a1=b1 order by b3 limit 1) t where b.b1=t.b1 and  t.b2=b.b2 and t.b3=b.b3 and t.b3=b.b3;
explain extended select /*+use_nl(b t)*/* from b, (select * from a left join (select * from b group by b2 order by b3 limit 2) v on a1=b1 order by b3 limit 1) t where b.b1=t.b1 and  t.b2=b.b2 and t.b3=b.b3;
explain extended select /*+use_nl(b t)*/* from b, (select * from a right join (select * from b group by b2 order by b3 limit 2) v on a1=b1 order by b3 limit 1) t where b.b1=t.b1 and  t.b2=b.b2 and t.b3=b.b3;
explain extended select /*+use_nl(b t)*/* from b, (select * from a right join b on a1=b1 order by b3 limit 1) t where b.b1=t.b1 and  t.b2=b.b2 and t.b3=b.b3;
explain extended select /*+use_nl(b t)*/* from b, (select * from a left join b on a1=b1 order by b3 limit 1) t where b.b1=t.b1 and  t.b2=b.b2 and t.b3=b.b3;
explain extended select /*+use_nl(pa t)*/* from pa,pa t where pa.a1=t.a2;
explain extended select /*+use_nl(pa t)*/* from pa,pa t where pa.a2=t.a1;
explain extended select /*+use_nl(pa t)*/* from pa,pa t where pa.a2=t.a2;
explain extended select /*+use_nl(pa t)*/* from pa,pa t where pa.a1=t.a1;
explain extended select /*+use_nl(pa t)*/* from pa,(select * from pa order by a1 limit 1) t where pa.a1=t.a1;
explain extended select /*+use_nl(pa t)*/* from pa,(select * from pa group by a1 limit 1) t where pa.a1=t.a1;
explain extended select /*+use_nl(pa t)*/* from pa,(select * from pa group by a1 order by a1 limit 1) t where pa.a1=t.a1;
explain extended select /*+use_nl(pa t)*/* from pa,(select * from pa group by a2 order by a2 limit 1) t where pa.a1=t.a1;
explain extended select /*+use_nl(pa t)*/* from pa,(select pa.a1 from pa, pa t1 order by pa.a2 limit 1) t where pa.a1=t.a1;
explain extended select /*+use_nl(pa t)*/* from pa,(select t1.a1 from pa, pa t1 order by t1.a2 limit 1) t where pa.a1=t.a1;
explain extended select /*+use_nl(pa t)*/* from pa,(select t1.a2 as a1 from pa, pa t1 order by t1.a2 limit 1) t where pa.a1=t.a1;
explain extended select /*+use_nl(pa t)*/* from pa,(select pa.a1 from pa left join pa t1 on pa.a2=t1.a2 order by t1.a2 limit 1) t where pa.a1=t.a1;
explain extended select /*+use_nl(pa t)*/* from pa,(select pa.a1 from pa right join pa t1 on pa.a2=t1.a2 order by t1.a2 limit 1) t where pa.a1=t.a1;
explain extended select /*+use_nl(pa t)*/* from pa,(select t1.a1 from pa right join pa t1 on pa.a2=t1.a2 order by pa.a2 limit 1) t where pa.a1=t.a1;
explain extended select /*+use_nl(pa t)*/* from pa,(select t1.a1 from pa right join (select * from pa group by a2 order by a3 limit 1) t1 on pa.a2=t1.a2 order by t1.a2 limit 1) t where pa.a1=t.a1;
explain extended select /*+use_nl(pa t)*/* from pa,(select t1.a1 from pa right join (select * from pa group by a1) t1 on pa.a1=t1.a1 group by t1.a1) t where pa.a1=t.a1;
explain extended select /*+use_nl(pb t)*/* from pb, (select * from pb order by b3 limit 1) t where pb.b1=t.b1;
explain extended select /*+use_nl(pb t)*/* from pb, (select * from pb order by b3 limit 1) t where pb.b1=t.b1 and t.b2=pb.b2 and t.b3=pb.b3;
explain extended select /*+use_nl(pb t)*/* from pb, (select * from pb order by b3 limit 1) t where pb.b1=t.b1 and t.b2=pb.b2 and t.b3=pb.b3 and t.b3=pb.b3;
explain extended select /*+use_nl(pb t)*/* from pb, (select * from pb order by b3 limit 1) t where pb.b1=t.b1 and t.b2=pb.b2 and t.b3=pb.b3 and t.b3=1 and pb.b3=2;
explain extended select /*+use_nl(pb t)*/* from pb, (select * from b order by b3 limit 1) t where pb.b1=t.b1 and t.b2=1 and t.b3=2;
explain extended select /*+use_nl(pb t)*/* from pb, (select * from b order by b3 limit 1) t where pb.b1=t.b1 and t.b2=1 and t.b3=1 and pb.b2=2 and pb.b3=2;
explain extended select /*+use_nl(pb t)*/* from pb, (select * from pa right join (select * from pb group by b2 order by b3 limit 2) v on a1=b1 order by b3 limit 1) t where pb.b1=t.b1 and  t.b2=pb.b2 and t.b3=pb.b3 and t.b3=pb.b3;
explain extended select /*+use_nl(pb t)*/* from pb, (select * from pa left join (select * from pb group by b2 order by b3 limit 2) v on a1=b1 order by b3 limit 1) t where pb.b1=t.b1 and  t.b2=pb.b2 and t.b3=pb.b3;
explain extended select /*+use_nl(pb t)*/* from pb, (select * from pa right join (select * from pb group by b2 order by b3 limit 2) v on a1=b1 order by b3 limit 1) t where pb.b1=t.b1 and  t.b2=pb.b2 and t.b3=pb.b3;
explain extended select /*+use_nl(pb t)*/* from pb, (select * from pa right join pb on a1=b1 order by b3 limit 1) t where pb.b1=t.b1 and  t.b2=pb.b2 and t.b3=pb.b3;
explain extended select /*+use_nl(pb t)*/* from pb, (select * from pa left join pb on a1=b1 order by b3 limit 1) t where pb.b1=t.b1 and  t.b2=pb.b2 and t.b3=pb.b3;

Drop table A;
Drop table B;
Drop table PA;
Drop table PB;
