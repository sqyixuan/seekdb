--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: linlin.xll
#owner group: sql1
#description: test ps bug

--result_format 4

--disable_query_log
--disable_result_log
--source mysql_test/include/index_quick_major.inc
--enable_query_log
--enable_result_log

--disable_warnings
drop table if exists a;
drop table if exists b;
--enable_warnings

create table a(a varchar(100), b int);
create table b(a varchar(100), b int);

prepare stmt from "insert into a values('a', 1);";
execute stmt;
select * from a;

prepare stmt from "insert into b values('b', 1);";
execute stmt;
select * from a;
select * from b;

prepare stmt from "insert into a values(?,?);";

set @x = 'a1'; set @y = 1;

--error 1210
execute stmt;

--error 1210
execute stmt using @x;

execute stmt using @x, @y;

select * from a;

deallocate prepare stmt;

prepare stmt from "insert into b values('b1', 1);";

execute stmt;

select * from b;

deallocate prepare stmt;

--error 1243
execute stmt;

drop table a;

drop table b;


