--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#####bug:
###
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(c1 int, c2 int, c3 int, primary key(c1)) expire_info=c1<100 ;
sleep 1;

create index i1 on t1(c2);
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/check_all_idx_ok.inc
replace into t1 values(1,11,111);

let $idx11 = query_get_value(select a.table_name from oceanbase.__all_virtual_table as a inner join (select * from oceanbase.__all_virtual_table where table_name='t1') b on a.data_table_id=b.table_id, table_name, 1);

--disable_query_log
--enable_query_log

--source mysql_test/include/majorfreeze.inc
update t1 set c3=222 where c1=1;
--source mysql_test/include/wait_daily_merge.inc
select * from t1;


--disable_query_log
eval select * from $idx11;
--enable_query_log

