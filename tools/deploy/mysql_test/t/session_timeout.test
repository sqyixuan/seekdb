--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner:link.zt
#owner group: sql1

--disable_warnings
drop table if exists session_timeout_table;
--enable_warnings


--echo set timeout to 10s
connect (conn3,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);

set wait_timeout = 5;
create table session_timeout_table(c1 int primary key, c2 int);
insert into session_timeout_table values(1,1);
insert into session_timeout_table values(2,2);
insert into session_timeout_table values(3,3);
disconnect conn3;

--echo create 2 sessions
connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);


connection conn1;
set interactive_timeout = 1;
--echo interactive_timeout not effective
begin;
insert into session_timeout_table values(4,4);
--real_sleep 3
insert into session_timeout_table values(5,5);
--real_sleep 3
insert into session_timeout_table values(6,6);
--real_sleep 3
commit;

select * from session_timeout_table;

#session mgr check session every 100s
--echo wait_timeout
set wait_timeout = 5;
begin;
insert into session_timeout_table values(11,11);
--real_sleep 110
--error 2013
insert into session_timeout_table values(12,12);
--error 2006
commit;

--error 2006
select * from session_timeout_table;
