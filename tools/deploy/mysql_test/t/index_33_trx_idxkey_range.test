--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: jingyan.kfy
#owner group: transaction

####TITEL:
####table with index, 
####update range and delete range scan
####idx are used as where condition

--disable_query_log
--source mysql_test/include/index_quick_major.inc
connect (sys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection sys;
--real_sleep 1
set global ob_enable_index_direct_select =1;
alter system set merger_check_interval = '10s' tenant sys;
alter system set merger_check_interval = '10s' tenant all_user;
alter system set merger_check_interval = '10s' tenant all_meta;
--enable_query_log

connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (trx1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (trx2,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);

connection conn1;
--disable_warnings
drop table if exists index_33_trx_idxkey_range_t1;
--enable_warnings
create table index_33_trx_idxkey_range_t1(pk1 int, pk2 int, c1 int, c2 int, primary key(pk1,pk2));
connection conn1;
insert into index_33_trx_idxkey_range_t1(pk1,pk2,c1,c2) values(1,1,1,1);
insert into index_33_trx_idxkey_range_t1(pk1,pk2,c1,c2) values(2,2,1,1);
insert into index_33_trx_idxkey_range_t1(pk1,pk2,c1,c2) values(3,3,1,1);
insert into index_33_trx_idxkey_range_t1(pk1,pk2,c1,c2) values(4,4,1,1);
insert into index_33_trx_idxkey_range_t1(pk1,pk2,c1,c2) values(5,5,2,1);
insert into index_33_trx_idxkey_range_t1(pk1,pk2,c1,c2) values(6,6,2,1);
insert into index_33_trx_idxkey_range_t1(pk1,pk2,c1,c2) values(7,7,2,1);
insert into index_33_trx_idxkey_range_t1(pk1,pk2,c1,c2) values(8,8,2,1);

create index i1 on index_33_trx_idxkey_range_t1(c1);

connection sys;
let $idx1 = query_get_value(select a.table_name from oceanbase.__all_virtual_table as a inner join (select * from oceanbase.__all_virtual_table where table_name='index_33_trx_idxkey_range_t1') b on a.data_table_id=b.table_id, table_name, 1);

--disable_query_log
connection conn1;
let $index_name = __idx_3003_i1;
--enable_query_log
--source mysql_test/include/check_all_idx_ok.inc
connection conn1;

select * from index_33_trx_idxkey_range_t1;
--disable_query_log
set ob_enable_index_direct_select =1;
eval select * from $idx1;
--enable_query_log

####CASE: =
connection trx1;
set autocommit=0;

connection trx2;
set autocommit=0;
update index_33_trx_idxkey_range_t1 set c2=c2+1 where c1=1;
select * from index_33_trx_idxkey_range_t1;
--disable_query_log
set ob_enable_index_direct_select =1;
eval select * from $idx1;
--enable_query_log

connection trx1;
select * from index_33_trx_idxkey_range_t1;
--disable_query_log
set ob_enable_index_direct_select =1;
eval select * from $idx1;
--enable_query_log

connection trx2;
update index_33_trx_idxkey_range_t1 set c2=c2+1 where c1=2;
select * from index_33_trx_idxkey_range_t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log
commit;

connection trx1;
select * from index_33_trx_idxkey_range_t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log
commit;

####CASE: >, <
connection conn1;
delete from index_33_trx_idxkey_range_t1;
insert into index_33_trx_idxkey_range_t1(pk1,pk2,c1,c2) values (1,1,1,1),(2,2,2,1),(3,3,3,1),(4,4,4,1),(5,5,5,1),(6,6,6,1),(7,7,7,1),(8,8,8,1);
select * from index_33_trx_idxkey_range_t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log

connection trx1;

connection trx2;
update index_33_trx_idxkey_range_t1 set c2=c2+1 where c1>1;
select * from index_33_trx_idxkey_range_t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log

connection trx1;
select * from index_33_trx_idxkey_range_t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log

connection trx2;
update index_33_trx_idxkey_range_t1 set c2=c2+1 where c1<8;
select * from index_33_trx_idxkey_range_t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log
commit;

connection trx1;
select * from index_33_trx_idxkey_range_t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log
commit;

####CASE: >=, <=
connection conn1;
delete from index_33_trx_idxkey_range_t1;
insert into index_33_trx_idxkey_range_t1(pk1,pk2,c1,c2) values (1,1,1,1),(2,2,2,1),(3,3,3,1),(4,4,4,1),(5,5,5,1),(6,6,6,1),(7,7,7,1),(8,8,8,1);
select * from index_33_trx_idxkey_range_t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log

connection trx1;
update index_33_trx_idxkey_range_t1 set c2=c2+1 where c1>=5;
select * from index_33_trx_idxkey_range_t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log

connection trx2;
select * from index_33_trx_idxkey_range_t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log
delete from index_33_trx_idxkey_range_t1 where c1<=4;

connection trx1;
--error 1205,4012
update index_33_trx_idxkey_range_t1 set c2=c2+1 where c1<=8;
select * from index_33_trx_idxkey_range_t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log
commit;

connection trx2;
select * from index_33_trx_idxkey_range_t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log
update index_33_trx_idxkey_range_t1 set c2=c2+1 where c1<=8;
select * from index_33_trx_idxkey_range_t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log
commit;
select * from index_33_trx_idxkey_range_t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log
commit;

####CASE: idx using =, and rowkey using >, >=, <, <=
connection conn1;
delete from index_33_trx_idxkey_range_t1;
replace into index_33_trx_idxkey_range_t1(pk1,pk2,c1,c2) values (1,1,1,1),(2,2,1,1),(3,3,1,1),(4,4,1,1),(5,5,1,1),(6,6,1,1),(7,7,1,1),(8,8,1,1);
select * from index_33_trx_idxkey_range_t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log

connection trx1;

connection trx2;
update index_33_trx_idxkey_range_t1 set c2=c2+1 where c1=1 and pk1<5;
select * from index_33_trx_idxkey_range_t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log
delete from index_33_trx_idxkey_range_t1 where c1=1 and pk1<=2;
select * from index_33_trx_idxkey_range_t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log
commit;

connection trx1;
update index_33_trx_idxkey_range_t1 set c2=c2+1 where c1=1 and pk1>=5;
select * from index_33_trx_idxkey_range_t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log
delete from index_33_trx_idxkey_range_t1 where c1=1 and pk1>6;
select * from index_33_trx_idxkey_range_t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log
commit;
select * from index_33_trx_idxkey_range_t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log
commit;


####CASE: write with same rows, 5048
connection conn1;
delete from index_33_trx_idxkey_range_t1;
insert into index_33_trx_idxkey_range_t1(pk1,pk2,c1,c2) values (1,1,1,1),(2,2,1,1),(3,3,1,1),(4,4,1,1),(5,5,1,1),(6,6,1,1),(7,7,1,1),(8,8,1,1);
