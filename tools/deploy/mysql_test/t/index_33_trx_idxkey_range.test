--enable_query_log

connection trx1;
--error 1205,4012
update index_33_trx_idxkey_range_t1 set c2=c2+1 where c1=1 and pk1<5;
--error 1205,4012
update index_33_trx_idxkey_range_t1 set c2=c2+1 where pk1>0;
--error 1205,4012
delete from index_33_trx_idxkey_range_t1 where c1=1 and pk1<5;
--error 1205,4012
delete from index_33_trx_idxkey_range_t1 where pk1>6;
--error 1205,4012
insert into index_33_trx_idxkey_range_t1(pk1,pk2,c1,c2) values (1,1,1,1);
--error 1205,4012
replace into index_33_trx_idxkey_range_t1(pk1,pk2,c1,c2) values (1,1,1,1);
select * from index_33_trx_idxkey_range_t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log

connection trx2;
select * from index_33_trx_idxkey_range_t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log
update index_33_trx_idxkey_range_t1 set c2=c2+1 where c1=1;
select * from index_33_trx_idxkey_range_t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log
commit;

connection trx1;
select * from index_33_trx_idxkey_range_t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log
update index_33_trx_idxkey_range_t1 set c2=c2+1 where c1=1 and pk1<5;
select * from index_33_trx_idxkey_range_t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log
update index_33_trx_idxkey_range_t1 set c2=c2+1 where pk1>0;
select * from index_33_trx_idxkey_range_t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log
delete from index_33_trx_idxkey_range_t1 where c1=1 and pk1<5;
select * from index_33_trx_idxkey_range_t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log
insert into index_33_trx_idxkey_range_t1(pk1,pk2,c1,c2) values (1,1,1,1);
select * from index_33_trx_idxkey_range_t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log
replace into index_33_trx_idxkey_range_t1(pk1,pk2,c1,c2) values (1,1,1,2);
select * from index_33_trx_idxkey_range_t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log
commit;
select * from index_33_trx_idxkey_range_t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log
commit;

connection trx1;
set autocommit=1;
connection trx2;
set autocommit=1;
drop table index_33_trx_idxkey_range_t1;
set global ob_enable_index_direct_select =0;
