--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: peihan.dph
# owner group: SQL3
# description:
# tags:dml, datatype
--source mysql_test/include/index_quick_major.inc
--real_sleep 2 

--disable_warnings
drop table if exists t1,t2;
--enable_warnings
create table if not exists t1(pk int primary key, v1 varchar, i1 int, t1  timestamp(6) default "2012-01-01 12:00:00");
##insert 
insert into t1 values(1,decode('1',1,'a',0,1),decode(2,2,1,1,2),decode(date_format('2014-10-20 10:10:10','%Y-%m-%d'),'2014-10-20','2014-10-21')),(2,decode(0,1,'a',0,1),decode(1,2,1,1,2),decode(date_format('2014-10-20 10:10:10','%Y-%m-%d'),'2014-10-21','2014-10-21')),(decode(3,'3',4),decode(2,1,'a',0,1),decode(3,2,1,1,2),decode(date_format('2014-10-20 10:10:10','%Y-%m-%d'),'2014-10-21','2014-10-21'));
select * from t1;										
										
##replace
replace into t1 values(2,decode('1',1,'a',0,1),decode(2,2,1,1,2),decode(date_format('2014-10-20 10:10:10','%Y-%m-%d'),'2014-10-20','2014-10-21')),(3,decode(0,1,'a',0,1),decode(1,2,1,1,2),decode(date_format('2014-10-20 10:10:10','%Y-%m-%d'),'2014-10-21','2014-10-21')),(decode(4,'4',1),decode(0,1,'a',0,1),decode(1,2,1,1,2),decode(date_format('2014-10-20 10:10:10','%Y-%m-%d'),'2014-10-21','2014-10-21'));
select pk,v1,i1 from t1;
drop table t1;

create table if not exists t1(
pk1 int, 
pk2 varchar(16384), 
i1 int, 
i2 int, 
v1 varchar, 
v2 varchar,
t1  timestamp(6) default "2012-01-01 12:00:00",
t2  timestamp(6) default "2012-01-01 12:00:00", 
n1 numeric, 
n2 numeric(8,5),
b1 bool,
b2 bool,
primary key(pk1,pk2));

insert into t1 values
(1,'a',1,4,'aa','abcd','2014-10-17 12:11:11','2014-10-17 11:49:10',1.2,0.2345,1,0),
(1,'b',1,3,'bb','abcdef','2014-10-18 12:12:12','2014-10-17 11:39:10',1.3,1.2346,0,1),
(2,'c',2,3,'bb','bbq','2014-10-17 13:13:13','2014-10-17 11:49:10',2.2,1.4567,1,1),
(2,'b',2,4,'aa','beark','2014-10-18 14:14:14','2014-10-17 11:29:10',1.3,3.2345,0,0),
(3,'a',3,4,'cc','away','2014-10-18 15:14:16','2014-10-17 11:39:10',1.2,1.4567,1,0),
(3,'c',3,3,'aa','bcdef','2014-10-17 17:14:14','2014-10-17 11:29:10',1.3,2.2345,0,1),
(4,1,3,2,5,1,'2014-10-20 14:13:12','2014-10-20 11:29:10',2.2,3.3,0,0),
(1,-1,-1,1,-3,2,'2014-10-17 17:13:14','2014-10-20 11:29:10',-1.6,-0.1,1,1),
(1,-2,4,1,2,2,'2014-10-17 16:16:16','2014-10-20 11:29:10',-1.6,-0.1,1,1),
(1,-3,-3,1,-2,1,'2014-10-20 15:15:15','2014-10-20 11:29:10',-1.6,0.23,0,1);

##update(decode in set)
select pk1,i1,v1,v2 from t1 where pk1=2;
--affect_rows 2
update t1 set i1=decode(v1>v2,TRUE,i2,i1) where pk1=2;
select pk1,i1,v1,v2 from t1 where pk1=2;

#含varchar和int之间的隐式转换
select pk1,pk2,i1,i2,v1,v2 from t1 where pk1=1 and pk2 in ('-1','-2','-3');
--affect_rows 3
update t1 set i2=decode(i1+i2-3>=i2,TRUE,v1,FALSE,v2) where pk1=1 and pk2 in ('-1','-2','-3');
select pk1,pk2,i1,i2,v1,v2 from t1 where pk1=1 and pk2 in ('-1','-2','-3');

#更新主键
select pk1,pk2 from t1 where pk1=1;
--affect_rows 1
update t1 set pk1=decode(0,'1',1,2) where pk1=1 and pk2='-1';
select pk1,pk2 from t1 where pk1=1;

select pk1,pk2 from t1 where pk1=2;
--affect_rows 1
update t1 set pk2=decode(1,'1',0,-1) where pk1=2 and pk2='b';
select pk1,pk2 from t1 where pk1=2;

##update(decode in where)
select pk1,pk2,i1,i2 from t1 where i1=decode(sign((i1+i2)*0.5-i1),1,i1,-1,i2,0,i1-i2);
select pk1,pk2,i1,i2 from t1 where i1=decode(sign((i1+i2)*0.5-i1),1,i1,-1,i2,0,i1-i2) and pk1>=3;
--affect_rows 1
update t1 set pk2='2' where i1=decode(sign((i1+i2)*0.5-i1),1,i1,-1,i2,0,i1-i2) and pk1>=3;
select pk1,pk2,i1,i2 from t1 where i1=decode(sign((i1+i2)*0.5-i1),1,i1,-1,i2,0,i1-i2) and pk1>=3;

--error 5085
update t1 set i1=i2 where pk1<2 and i2 in (decode(v1>v2,true,cast(v1 as signed int),cast(v2 as signed int)), decode(n1>n2,true,cast(n1 as signed int),cast(n2+1 as signed int)));
select  i1,i2,pk1,n1,n2 from t1 where pk1<2;

select pk1,pk2,t1,t2,i1,i2 from t1  where pk1=decode(date_format(t1,'%Y-%m-%d'),date_format(t2,'%Y-%m-%d'),i1,i2);
update t1 set t1=date_format(t1,'%Y-%m-%d') where pk1=decode(date_format(t1,'%Y-%m-%d'),date_format(t2,'%Y-%m-%d'),i1,i2);
select pk1,pk2,t1,t2,i1,i2 from t1  where pk1=decode(date_format(t1,'%Y-%m-%d'),date_format(t2,'%Y-%m-%d'),i1,i2);

##delete
select pk1,i1,i2 from t1 where pk1=i1 or pk1=i2;
--affect_rows 4 
delete from t1 where pk1=decode((i2%i1)>0,true,i1,i2);
select pk1,i1,i2 from t1 where pk1=i1 or pk1=i2;

select pk1,i1,i2 from t1 where pk1 in (decode(i1<>i2,'1',i1-2,i2-2),decode(i1=i2,'1',i2-1,i1));
delete from t1 where pk1 in (decode(i1<>i2,'1',i1-2,i2-2),decode(i1=i2,'1',i2-1,i1));
select pk1,i1,i2 from t1 where pk1 in (decode(i1<>i2,'1',i1-2,i2-2),decode(i1=i2,'1',i2-1,i1));

##compound
select pk1,decode(0,2,100,200), sign(pk1)<>-1 from t1 where pk1=4 for update  when row_count(update t1 set pk1=decode(0,2,100,200) where sign(pk1)<>-1) = 3;
select pk1,i1,i2,decode(sign(pk2),-1,i1-3,i2),decode(i1-i2>0,true,i1,false,i2) from t1 where pk1=decode(sign(pk2),-1,i1-3,i2) for update when row_count(update t1 set i1=2 where pk1=decode(i1-i2>0,true,i1,false,i2)) = 0; 
insert into t1(pk1,pk2) values(5,5) when row_count(update t1 set i1=4 where pk1>0 when row_count(delete from t1 where pk1=decode(cast(pk2 as signed int)-i2<>0,true,2,3))=0)=3;


##expire_info
create table t2(pk int primary key, c1 varchar(10), i1 int) expire_info (c1=decode(pk>i1,'1','a','b'));
insert into t2 values(1,'a',-1),(2,'b',3),(3,'c',4);
select * from t2;

--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc

select * from t2;

##expire_info,with index
--disable_warnings
drop table if exists t3;
--enable_warnings
create table t3(pk int primary key, c1 varchar(10), i1 int) expire_info (c1=decode(pk>i1,'1','a','b'));
create index idx1 on t3(c1);
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/check_all_idx_ok.inc
let $idx11 = query_get_value(select a.table_name from oceanbase.__all_virtual_table as a inner join (select * from oceanbase.__all_virtual_table where table_name='t3') b on a.data_table_id=b.table_id, table_name, 1);

insert into t3 values(1,'a',-1),(2,'b',3),(3,'c',4);
select * from t3;

--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc

select * from t3;
--disable_query_log
eval select * from $idx11;
--enable_query_log

##expire_info,with unique index
--disable_warnings
drop table if exists t4;
--enable_warnings
create table t4(pk int primary key, c1 varchar(10), i1 int) expire_info (c1=decode(pk>i1,'1','a','b'));
create unique index idx1 on t4(c1);
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/check_all_idx_ok_unq.inc
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/check_all_idx_ok.inc
let $idx12 = query_get_value(select a.table_name from oceanbase.__all_virtual_table as a inner join (select * from oceanbase.__all_virtual_table where table_name='t4') b on a.data_table_id=b.table_id, table_name, 1);
insert into t4 values(1,'a',-1),(2,'b',3),(3,'c',4);
select * from t4;


--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc

select * from t4;

--disable_query_log
eval select * from $idx12;
--enable_query_log
