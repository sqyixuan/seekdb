--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: jingyan.kfy
#owner group: sql1

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1(id int primary key, f1 varchar(65536));

--let $

--let $value=1
--let $insert_sql=replace into t1 values(1,'$value$byte')
--let $rows=2
while($rows < 32)
{
     --let $value=$value$byte
     --let $insert_sql=$insert_sql,($rows,'$value')
     inc $rows;
}
eval $insert_sql;
delete from t1;
--let $insert_sql=replace into t1 values(1,'$value$byte')
while($rows < 100)
{
     --let $value=$value$byte
     --let $insert_sql=$insert_sql,($rows,'$value')
     inc $rows;
}
--error 1406
eval $insert_sql;
