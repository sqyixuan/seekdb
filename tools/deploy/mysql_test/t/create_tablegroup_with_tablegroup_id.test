--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

#owner: zhaoziqian.zzq 
#owner group: rs
#description: test create tablegroup with tablegroup_id

connect (conn_mysql,$OBMYSQL_MS0,root,,*NO-ONE*,$OBMYSQL_PORT);
connection conn_mysql;

--disable_warnings
eval create user if not exists __oceanbase_inner_drc_user;
--enable_warnings
grant all privileges on *.* to __oceanbase_inner_drc_user;
--source mysql_test/include/check_schema_sync.inc
connect (conn_drc,$OBMYSQL_MS0,__oceanbase_inner_drc_user,,*NO-ONE*,$OBMYSQL_PORT);

let $index = 0;

# only __oceanbase_inner_drc_user can create tablegroup with max_used_part_id
inc $index;
connection conn_mysql;
--error 1064
create tablegroup tg_1 tablegroup_id = -1;
--error 1064
create tablegroup tg_1 tablegroup_id = 100;
--error 1064
create tablegroup tg_1 tablegroup_id = 1649267442851;

--disable_warnings
eval drop tablegroup if exists tg_with_tablegroup_id_$index;
--enable_warnings

eval create tablegroup tg_with_tablegroup_id_$index;

--error 1064
alter tablegroup tg_with_tablegroup_id_$index set tablegroup_id = -1;
--error 1064
alter tablegroup tg_with_tablegroup_id_$index set tablegroup_id = 100;
--error 1064
alter tablegroup tg_with_tablegroup_id_$index set tablegroup_id = 1649267442851;

--disable_warnings
eval drop tablegroup if exists tg_with_tablegroup_id_$index;
--enable_warnings

# use __oceanbase_inner_drc_user
inc $index;
connection conn_drc;

# tablegroup_id invalid
--error 1064
create tablegroup tg_1 tablegroup_id = -1;

--disable_warnings
eval drop tablegroup if exists tg_with_tablegroup_id_$index;
--enable_warnings

eval create tablegroup tg_with_tablegroup_id_$index;
connect (conn_sys,$OBMYSQL_MS0,root@sys,,*NO-ONE*,$OBMYSQL_PORT);
connection conn_sys;
let $pure_tablegroup_id = query_get_value(select (tablegroup_id & 0x7fffffffff) as tablegroup_id from oceanbase.__all_virtual_tablegroup where tablegroup_name = "tg_with_tablegroup_id_$index", tablegroup_id, 1);
connection conn_drc;

# alter tablegroup with tablegroup_id not supported
--error 1064
alter tablegroup tg_with_tablegroup_id_$index set tablegroup_id = -1;
--error 1064
alter tablegroup tg_with_tablegroup_id_$index set tablegroup_id = 100;
--error 1064
alter tablegroup tg_with_tablegroup_id_$index set tablegroup_id = 1649267442851;

--disable_warnings
eval drop tablegroup if exists tg_with_tablegroup_id_$index;
--enable_warnings

# 创建2.0之前创建的tablegroup，tablegroup_id第40位为0
inc $index;
inc $pure_tablegroup_id;
connection conn_drc;
--disable_warnings
eval drop tablegroup if exists tg_with_tablegroup_id_$index;
--enable_warnings
eval create tablegroup tg_with_tablegroup_id_$index tablegroup_id = 100;
connection conn_sys;
--replace_regex /"[0-9]*"/"1"/g
eval select count(*) from oceanbase.__all_virtual_tablegroup where (tablegroup_id & 0x7fffffffff) = "$pure_tablegroup_id" and (tablegroup_id >> 39) & 0x1 = 0;
connection conn_drc;
--disable_warnings
eval drop tablegroup if exists tg_with_tablegroup_id_$index;
--enable_warnings

# 创建2.0之后创建的tablegroup，tablegroup_id第40位为0
inc $index;
inc $pure_tablegroup_id;
connection conn_drc;
--disable_warnings
eval drop tablegroup if exists tg_with_tablegroup_id_$index;
--enable_warnings
eval create tablegroup tg_with_tablegroup_id_$index tablegroup_id = 1649267442851;
connection conn_sys;
--replace_regex /"[0-9]*"/"1"/g
eval select count(*) from oceanbase.__all_virtual_tablegroup where (tablegroup_id & 0x7fffffffff) = "$pure_tablegroup_id" and (tablegroup_id >> 39) & 0x1 = 0;
connection conn_drc;
--disable_warnings
eval drop tablegroup if exists tg_with_tablegroup_id_$index;
--enable_warnings

###########
set @@recyclebin = on;
--disable_warnings
drop user __oceanbase_inner_drc_user;
--enable_warnings
connection conn_sys;
