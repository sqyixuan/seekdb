--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: bin.lb
# owner group: SQL2
# tags: ddl
# description:
#
# author : jingqian
# test case about tenant, database, tablegroup, table
# TODO(jingqian): move it to obtest

let $zone_count = 1;
let $unit_num = 1;
let $count = 5;

connect (sysc,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection sysc;
let $zone = query_get_value(select zone from oceanbase.dba_ob_zones, zone, 1);

# create tenant
--disable_warnings
#drop tenant if exists t1 force;
#eval CREATE RESOURCE UNIT if not exists config MAX_CPU=1, MEMORY_SIZE='2G';

#--replace_regex /ZONE_LIST=\(.*\)/ZONE_LIST=('test')/
#eval CREATE RESOURCE POOL if not exists pool UNIT='config', UNIT_NUM = $unit_num, ZONE_LIST=('$zone');
#--enable_warnings

#let $pool_list = 'pool';

#eval CREATE TENANT t1 REPLICA_NUM = $zone_count, RESOURCE_POOL_LIST = ($pool_list) set ob_tcp_invited_nodes='%';
#--replace_column 1 create_time 2 modify_time 3 unit_config_id
#select * from oceanbase.__all_unit_config where name = 'config';
#--replace_column 1 create_time 2 modify_time 3 resource_pool_id 6 unit_config_id 7 test 8 tenant_id
#select * from oceanbase.__all_resource_pool where name = 'pool';
#--replace_column 1 create_time 2 modify_time 3 tenant_id 5 zonn_list 6 primary_zone 10 locality
#select * from oceanbase.__all_tenant where tenant_name="t1";

--source mysql_test/include/check_tenant_sync.inc
let $__tenant_name__ = 'sys';
--source mysql_test/include/get_tenant_server.inc

connect (conn1,$TE_SERVER_IP,root,,*NO-ONE*,$TE_SERVER_PORT);

use oceanbase;

# database
create database test_db;
--error 1007
create database test_db;
--disable_warnings
create database if not exists test_db;
--enable_warnings
drop database test_db;
--error 1008
drop database test_db;
--disable_warnings
drop database if exists test_db;
--enable_warnings
create database test_db;
let $i = 1;
while ($i <= $count)
{
  eval create database test_db$i;
  inc $i;
}
#show databases;
let $i = 1;
while ($i <= $count)
{
  eval drop database test_db$i;
  inc $i;
}
#show databases;

# tablegroup
create tablegroup test_tg;
--error 5159
create tablegroup test_tg;
--disable_warnings
create tablegroup if not exists test_tg;
--enable_warnings
drop tablegroup test_tg;
--error 5151
drop tablegroup test_tg;
--disable_warnings
drop tablegroup if exists test_tg;
--enable_warnings
let $i = 1;
while ($i <= $count)
{
  eval create tablegroup test_tg$i;
  inc $i;
}
--source mysql_test/include/check_schema_sync.inc
connection conn1;
show tablegroups;
let $i = 1;
while ($i <= $count)
{
  eval drop tablegroup test_tg$i;
  inc $i;
}
--source mysql_test/include/check_schema_sync.inc
connection conn1;
show tablegroups;

# table
use test_db;
create table t1(pk int, value int, primary key(pk));
connection conn1;
create table t2(pk int, value int, primary key(pk));
connection conn1;
insert into t1 values(1, 1);
insert into t2 values(1, 1);
select * from t1;
select * from t2;
--error 1050
create table t1(pk int, value int, primary key(pk));
--error 1050
create table t2(pk int, value int, primary key(pk));
drop table t1, t2;
create table t1(pk int, value int, primary key(pk));
connection conn1;
create table t2(pk int, value int, primary key(pk));
connection conn1;
drop database test_db;

create database test_db;
use test_db;
let $i = 1;
while ($i <= $count)
{
  eval create table t$i(pk int, value int, primary key(pk));
  inc $i;
}
show tables;
let $i = 1;
while ($i <= $count)
{
  eval drop table t$i;
  inc $i;
}
show tables;
drop database test_db;

connect (conn2,$OBMYSQL_MS0,root@sys,,*NO-ONE*,$OBMYSQL_PORT);
#drop tenant t1 force;
#drop resource pool pool;
#drop resource unit config;

connection default;
set recyclebin = off;

# database default tablegroup
create tablegroup tg_test;
create database db_tg default tablegroup tg_test;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create database db_tg;
use db_tg;
create table t1(c1 int key);
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;
alter database db_tg default tablegroup null;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create database db_tg;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;
create table t2(c1 int key);
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t2;
alter database db_tg default tablegroup = tg_test;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create database db_tg;
create table t3(c1 int key);
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t3;
--error 4615
drop tablegroup tg_test;

drop database db_tg;
drop tablegroup tg_test;
