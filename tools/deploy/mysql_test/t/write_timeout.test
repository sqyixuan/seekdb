--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: yuchen.wyc
# owner group: SQL3
# description: OUR GOAL: Make all this simple and effective!
--disable_warnings
drop table if exists t1;
--enable_warnings

set ob_query_timeout=120000000;
create table t1 (c1 int, c2 int, primary key(c1, c2), c3 int);

set ob_query_timeout=1;
--error 4012 
replace into t1 values(1,1,1);
--error 4012
insert into t1 values(2,2,2);
--error 4012
update t1 set c3=2 where c1=1 and c2=1;
--error 4012
delete from t1 where c1=1 and c2=1;

set ob_query_timeout=120000000;
drop table t1;

set ob_query_timeout=2500000000;
create table t1 (c1 int, c2 int, primary key(c1, c2), c3 int);

replace into t1 values(1,1,1);
insert into t1 values(2,2,2);
update t1 set c3=2 where c1=1 and c2=1;
delete from t1 where c1=1 and c2=1;

drop table t1;
