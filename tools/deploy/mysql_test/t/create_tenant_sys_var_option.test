--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

#owner: linlin.xll
#owner group: SQL1
#description:
#tags:ddl, sys_vars

##lower_case_table_names = 1:stored as lowercase letters, and comparisions are case insensitive

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;

--disable_warnings
drop tenant if exists tt1 force;
drop resource pool if exists test_resource_pool1;
drop resource unit if exists test_resource_unit;
--enable_warnings

--disable_query_log
create resource unit test_resource_unit max_cpu 1, memory_size '2G';
--enable_query_log

let $zone_name=query_get_value(select zone from oceanbase.__all_zone where zone != '' limit 1, zone, 1);

--replace_column 1 create_time 2 modify_time 3 unit_config_id
select * from oceanbase.__all_unit_config where name='test_resource_unit';

--disable_query_log
eval create resource pool test_resource_pool1 unit = 'test_resource_unit', unit_num = 1, zone_list=('$zone_name');


--error 1064
eval create tenant tt1 replica_num = 1, primary_zone='$zone_name', resource_pool_list=('test_resource_pool1') set @lower_case_table_names = 0, ob_tcp_invited_nodes='%';
--error 1064
eval create tenant tt1 replica_num = 1, primary_zone='$zone_name', resource_pool_list=('test_resource_pool1') set @@lower_case_table_names = 0, ob_tcp_invited_nodes='%';
--error 1193
eval create tenant tt1 replica_num = 1, primary_zone='$zone_name', resource_pool_list=('test_resource_pool1') set unknown_sys_vr = 0, ob_tcp_invited_nodes='%';
--error 1228
eval create tenant tt1 replica_num = 1, primary_zone='$zone_name', resource_pool_list=('test_resource_pool1') set last_insert_id = 2016, ob_tcp_invited_nodes='%';
--error 1231
eval create tenant tt1 replica_num = 1, primary_zone='$zone_name', resource_pool_list=('test_resource_pool1') set read_only = "adag", ob_tcp_invited_nodes='%';
--error 1054
eval create tenant tt1 replica_num = 1, primary_zone='$zone_name', resource_pool_list=('test_resource_pool1') set read_only = c1 + 1, ob_tcp_invited_nodes='%';
eval create tenant tt1 replica_num = 1, primary_zone='$zone_name', resource_pool_list=('test_resource_pool1') set lower_case_table_names = 1+1, read_only = ON, ob_query_timeout= length("adggd") + 1 , ob_enable_plan_cache= OFF, ob_compatibility_mode = ORACLE, ob_tcp_invited_nodes='%';
--source mysql_test/include/check_tenant_sync.inc

let $tenant_id=query_get_value(select tenant_id from oceanbase.__all_tenant where tenant_name = 'tt1' limit 1, tenant_id, 1);

eval select name, value from oceanbase.__all_virtual_sys_variable where tenant_id= $tenant_id and name='read_only';
eval select name, value from oceanbase.__all_virtual_sys_variable where tenant_id= $tenant_id and name='lower_case_table_names';
eval select name, value from oceanbase.__all_virtual_sys_variable where tenant_id= $tenant_id and name='ob_query_timeout';
eval select name, value from oceanbase.__all_virtual_sys_variable where tenant_id= $tenant_id and name='ob_enable_plan_cache';
eval select name, value from oceanbase.__all_virtual_sys_variable where tenant_id= $tenant_id and name='ob_compatibility_mode';

drop tenant if exists tt1 force;
--source mysql_test/include/check_tenant_sync.inc
drop resource pool if exists test_resource_pool1;
drop resource unit if exists test_resource_unit;

connection default;

