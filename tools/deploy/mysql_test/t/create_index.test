--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner : dachuan.sdc
#owner group: sql2
#description: todo

--disable_warnings
drop table if exists t;
--enable_warnings
create table t (c1 int, c2 int, c3 int, c4 int, c5 int, primary key(c1, c2, c3));

set ob_enable_index_direct_select=1;


connect (obsys1,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys1;
alter system set merger_check_interval = '10s' tenant sys;
alter system set merger_check_interval = '10s' tenant all_user;
alter system set merger_check_interval = '10s' tenant all_meta;
disconnect obsys1;
connection default;

create index t_c4 on t (c4) storing(c5);

connect (obsys1,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys1;
let $idx1 = query_get_value(select a.table_name from oceanbase.__all_virtual_table as a inner join (select * from oceanbase.__all_virtual_table where table_name='t') b on a.data_table_id=b.table_id order by a.table_id, table_name, 1);
disconnect obsys1;
connection default;

--real_sleep 1
--disable_query_log
eval select * from $idx1;
--enable_query_log
--error 1060
create index t_c2d on t (c2, c2) storing(c4);
create index t_c5 on t(c5);
--real_sleep 1

connect (obsys1,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys1;
let $idx3 = query_get_value(select a.table_name from oceanbase.__all_virtual_table as a inner join (select * from oceanbase.__all_virtual_table where table_name='t') b on a.data_table_id=b.table_id order by a.table_id, table_name, 2);
disconnect obsys1;
connection default;

--disable_query_log
eval select * from $idx3; 
--enable_query_log
drop table t;
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1 (c1 int primary key, c2 varchar(10), c3 int);
create table t(c1 int primary key) PROGRESSIVE_MERGE_NUM=10;
--error 1064
create index t13 on t1 (c2) PROGRESSIVE_MERGE_NUM=10;

--disable_warnings
drop table if exists t1,t,t13;
--enable_warnings

--disable_warnings
drop database if exists jx_db;
drop database if exists jx_db2;
--enable_warnings
create database jx_db;
create database jx_db2;
use jx_db;
create table jx_t1(c1 int primary key, c2 varchar(50));
--error ER_BAD_DB_ERROR
create index tmp_db.idx on jx_t1(c2);
--error ER_NOT_SUPPORTED_YET
create index jx_db2.idx on jx_t1(c2);

create index jx_db.idx on jx_t1(c2);
--source mysql_test/include/check_all_idx_ok.inc
show index from jx_t1;
drop database jx_db;
drop database jx_db2;
