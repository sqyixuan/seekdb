--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
drop database if exists db_create;
create database db_create;
use db_create;
--enable_warnings


--echo ===============================================
connect (obsys1,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys1;
alter system set default_compress_func = 'lz4_1.0';
sleep 5;
--replace_column 1 zone1 3 server_ip 4 server_port
show parameters where svr_ip = host_ip() and name = 'default_compress_func' and svr_port = rpc_port();
connection default;
--disable_warnings
drop table if exists compress_table;
--enable_warnings
CREATE TABLE compress_table (c1 int primary key, c2 varchar(500), c3 float, index i1 (c1), index i2 (c2), unique index i2_u (c2));

--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table compress_table;

--echo ===============================================
connection obsys1;
alter system set default_compress_func = 'snappy_1.0';
sleep 5;
--replace_column 1 zone1 3 server_ip 4 server_port
show parameters where svr_ip = host_ip() and name = 'default_compress_func' and svr_port = rpc_port();
alter system set default_compress_func = 'lz4_1.0';
sleep 5;
--replace_column 1 zone1 3 server_ip 4 server_port
show parameters where svr_ip = host_ip() and name = 'default_compress_func' and svr_port = rpc_port();
alter system set default_compress_func = 'none';
sleep 5;
--replace_column 1 zone1 3 server_ip 4 server_port
show parameters where svr_ip = host_ip() and name = 'default_compress_func' and svr_port = rpc_port();
alter system set default_compress_func = 'zstd_1.0';
sleep 5;
--replace_column 1 zone1 3 server_ip 4 server_port
show parameters where svr_ip = host_ip() and name = 'default_compress_func' and svr_port = rpc_port();
