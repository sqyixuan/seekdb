--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: yuchen.wyc
#owner group: sql1
#tags: ddl, optimizer
#description:

--disable_query_log
--disable_result_log
--source mysql_test/include/index_quick_major.inc
--enable_query_log
--enable_result_log

--disable_warnings
drop table if exists t, t1, xf, xf2, xf3, xf4, xf5, xf6;
--enable_warnings

create table t1(a int primary key, b int as (a+1));
--error 3105
insert into t1 values(1, 1);
insert into t1 values(1, default);
select * from t1;
--error 1062
insert into t1(a) values(1);
select * from t1;
--error 1364
insert into t1 values();
select * from t1;
insert into t1 values(1, default) on duplicate key update a=3;
select * from t1;
insert into t1 values(1, default) on duplicate key update b=default;
select * from t1;
--error 3105
insert into t1 values(1, default) on duplicate key update b=2;
select * from t1;
--error 1235
alter table t1 modify b int;
--error 1235
alter table t1 change b c int;
drop table t1;

#测试生成列是否能够被修改定义
create table t1(a int primary key, b int);
--error 1235
alter table t1 modify b int as (a+1);
drop table t1;
create table t1(a int primary key, b int as (a+1));
--error 1235
alter table t1 modify b int;
--error 1235
alter table t1 change b c int;
--error 1235
alter table t1 alter column b set default 1;
drop table t1;
create table t1(a int primary key, b int as (a+1));
--error 1235
alter table t1 modify b int as (a+2);
drop table t1;

create table t(pk int primary key, a int);
insert into t values(1,1);
alter table t add column b int as(a+1);
select * from t;
create index idx on t(b);
--source mysql_test/include/check_all_idx_ok.inc
explain basic select /*+index(t primary)*/* from t;
select /*+index(t primary)*/* from t;
explain basic select /*+index(t idx)*/* from t;
select /*+index(t idx)*/* from t;
drop table t;

create table t(a int, b int, c int as (a+b));
insert into t values();
drop table t;

set sql_mode=PAD_CHAR_TO_FULL_LENGTH;
create table t(pk int primary key, a char(5));
insert into t values(1,'a');
alter table t add column b char(10) as(concat(a, '1'));
select * from t;
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
select * from t;
drop table t;

set sql_mode=PAD_CHAR_TO_FULL_LENGTH;
create table t(pk int primary key, a char(5));
insert into t values(1,'a');
alter table t add column b char(10) as(concat(a, '1')) stored;
select * from t;
let $__version_1__ = select version from __all_virtual_memstore_info where table_id in (select table_id from __all_virtual_table where table_name like 't') and is_active=1;
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
let $__i__ = 6;
while ($__i__ > 0)
{
  sleep 1;
  dec $__i__;
  let $__version_2__ = select version from __all_virtual_memstore_info where table_id in (select table_id from __all_virtual_table where table_name like 't') and is_active=1;
  let $__mem_cnt__ = select count(1) from __all_virtual_memstore_info where table_id in (select table_id from __all_virtual_table where table_name like 't');
  if ($__version_2__ != $__version_1__)
  {
    if (1 == $__mem_cnt__)
    {
      let $__i__ = -5;
    }
  }
}
select * from t;
drop table t;

create table t(a int,b varchar(100),c varchar(100)) progressive_merge_num=2;
insert into t values (1,'aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa','bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb');
insert into t select * from t;
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
alter table t add column gen int as(a+1) stored;
create index idx on t(gen);
--source mysql_test/include/check_all_idx_ok.inc
show index from t;
explain basic select /*+index(t primary)*/* from t;
select /*+index(t primary)*/* from t;
explain basic select /*+index(t idx)*/* from t;
select /*+index(t idx)*/* from t;
drop table t;

create table t(pk int primary key, a int);
insert into t values(1,1);
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
alter table t add column gen int as(a+1) stored;
create index idx on t(gen);
--source mysql_test/include/check_all_idx_ok.inc
show index from t;
explain basic select /*+index(t primary)*/* from t;
select /*+index(t primary)*/* from t;
explain basic select /*+index(t idx)*/* from t;
select /*+index(t idx)*/* from t;
drop table t;

create table t(a int as (1+1));
insert into t values(default);
select * from t;
drop table t;

create table t(a int, b int as (a+1));
insert into t values(1, default);
select * from t;
drop table t;

create table t(a int, b int);
insert into t values(1, a+1);
select * from t;
drop table t;

