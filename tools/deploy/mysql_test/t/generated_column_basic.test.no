create table t(a int, b varchar(25), c datetime, d varchar(100) default null, v_column varchar(20) generated always as (substr(b, 3)) virtual, primary key(a,b,c)) partition by key(v_column) subpartition by range columns(c) subpartition template (
subpartition p20170101 values less than('2017-01-01 00:00:00'),
subpartition p20170701 values less than('2017-07-01 00:00:00'),
subpartition p20180101 values less than('2018-01-01 00:00:00')) partitions 3;
insert into t(a,b,c) values(1, 'asdfadsfasdfdsa', '2016-09-28 00:00:00');
select * from t;
select * from t where b like 'asdasdfadfasdfdasf';
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
--error 1526
insert into t(a,b,c) values(2, 'asdfadsfasddsa', '2018-09-28 00:00:00');
insert into t(a,b,c) values(3, 'asdfadsfasdsa', '2017-02-28 00:00:00');
insert into t(a,b,c) values(4, 'asdfadsfasda', '2017-04-28 00:00:00');
insert into t(a,b,c) values(5, 'asdfadsfasd', '2017-09-28 00:00:00');
update t set d='2017-09-28 00:08:00' where a=5 and b='a' and c='2018-09-28';
replace /*+USE_PLAN_CACHE(NONE)*/ into t(b,c) values('dddddddddd','2017-09-28 00:00:00');
insert into t(a,b,c) values(5, 'bbbbbbbbbb','2017-02-28 00:00:00') on duplicate key update d='ssssssss';
delete from t where a=5 and b='a' and c='2018-09-28';
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
replace /*+USE_PLAN_CACHE(NONE)*/ into t(b,c) values('dddddddddd','2017-09-28 00:00:00');
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
