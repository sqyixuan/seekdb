--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
# owner: bin.lb
# owner group: SQL3
# description:
# tags: ddl
--source mysql_test/include/index_quick_major.inc
--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1(pk int primary key , c1 int, c2 varchar(1024), c3 int);
create index index1 on t1(c1);

--disable_query_log

## 1000 * 3000 > 2m
## should be more than 2M

let $cnt=3000;
while($cnt)
{
  eval insert into t1(pk,c1,c2,c3) values($cnt, 1, '', $cnt);
  dec $cnt;
}
--enable_query_log


--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc

alter table t1 add column c4 int default NULL;
sleep 1;
select /*+ index(t1 index1) */ pk, c1, c4 from t1 where c1 = 1 and c3>2998;







