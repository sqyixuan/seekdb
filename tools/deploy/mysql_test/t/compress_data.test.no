--disable_query_log
--echo select from oceanbase.__all_virtual_partition_sstable_merge_info
let $version = query_get_value(select max(version) as version from oceanbase.__all_virtual_partition_sstable_merge_info, version, 1);
eval select tenant_id,partition_id,table_type,occupy_size,macro_block_count from oceanbase.__all_virtual_partition_sstable_merge_info where (table_id = $table_id or major_table_id = $table_id) and (version >= $version-1) order by version desc, table_id;
--enable_query_log
--echo "[===========================]"
--echo ""

ALTER TABLE compress_table set COMPRESSION = 'none';

--echo "[== start of 6th merge ==]"
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/index_quick_major.inc
--source mysql_test/include/wait_daily_merge.inc
connection ob_sys_muwei;
