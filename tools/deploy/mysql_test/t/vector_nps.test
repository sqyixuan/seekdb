--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
--disable_warnings
drop table if exists t3;
--enable_warnings

create table t3 (c1 int, c2 int, c3 varchar(1024), c4 varchar(1024), c5  timestamp(6) default "2012-01-01 12:00:00", c6 datetime(6), primary key(c1, c3, c5));
