--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: chaser.ch
#owner group: sql1
# tags: optimizer
#distinct with partial join

--disable_warnings
drop table if exists t1, t2, t3, t4;
--enable_warnings
create table t1(a int, b int);
create table t2(c int, d int);
create table t3(e int, f int);
create table t4(g int, h int);
# eliminate tables which is uncorrelated with distinct
explain  select distinct a from t1,t2;
explain  select distinct c from t1,t2,t3;
explain  select distinct a,d,g from t1,t2,t3,t4;
explain  select distinct a from t1,t2,t3 where b=d;
explain  select distinct a,g from t1,t2,t3,t4 where b=d;
explain  select distinct c from t1,t2,t3,t4 where a=e;
explain  select * from t1, (select distinct c from t2,t3) where a=c;
explain  select * from t1, (select distinct c from t2,t3,t4 where d=g) where a=c;
explain  select distinct a from t1, (select distinct c from t2,t3,t4 where d=g) where a=1;
explain  select distinct a from t1 where b in (select distinct c from t1,t2 where d>1);
explain  select distinct a from t1 where exists (select distinct c from t1,t2,t3 where d>1 and f=d);
explain  select distinct a from t1,t2 where b in (select distinct c from t2,t3 where d in (select distinct e from t3,t4));
explain  (select distinct a from t1,t2) union (select distinct c from t2 where exists (select distinct e from t3,t4));
explain  (select distinct a from t1,t2) intersect (select distinct c from t2,(select distinct e from t3,t4) where c > 1);

# agggrate imply the distinct
explain  select max(a) from t1,t2;
explain  select max(a), min(c) from t1,t2,t3;
explain  select count(distinct g), max(d), min(a) from t1,t2,t3,t4;
explain  select sum(distinct a) from t1,t2,t3 where b=d;
explain  select max(a) from t1,t2,t3,t4 where b=d;
explain  select avg(distinct c) from t1,t2,t3,t4 where a=e;
explain  select * from t1, (select min(d) as x from t2,t3) where a=x;
explain  select * from t1, (select count(distinct h)as x from t2,t3,t4 where d=g) where a=x;
explain  select min(b) from t1, (select count(distinct h)as x from t2,t3,t4 where d=g) where a=1;
explain  select distinct a from t1 where b>(select sum(distinct c) from t1,t2 where d>1);
explain  select distinct a from t1 where b>(select avg(distinct d) from t1,t2,t3 where d>1 and f=d);
explain  select max(a) from t1,t2 where b > (select min(c) from t2,t3 where d < (select sum(distinct e) from t3,t4));
explain  (select count(distinct a) from t1,t2) union (select max(c) from t2 where d>(select avg(distinct e) from t3,t4));
# distinct and aggrate mix
explain  (select max(a) from t1, t2) minus (select distinct e from t3,t4);
explain  select sum(distinct b) from t1, (select distinct c from t2, t3) where a = c;
explain  select distinct a from t1, t2 where b > (select max(e) from t3, t4);
explain  select count(distinct a) from t1,t2 where b in (select distinct c from t2,t3 where d < (select max(e) from t3,t4));

#some condition which cannot apply optimization
explain  select distinct a, c from t1,t2;
explain  select distinct a from t1,t2,t3 where c=e;
explain  select distinct a + d - e from t1,t2,t3;
explain  select avg(b) from t1, t2;
explain  select max(a), sum(b) from t1, t2;
explain  select max(a+c) from t1, t2;
### set condition
explain  select distinct a, e from ((select a from t1) union (select c from t2)), t3;
### ansi join condition
explain  select distinct a from t3, t1 join t2 on b=d;

--disable_warnings
drop table if exists t1, t2, t3, t4;
--enable_warnings
