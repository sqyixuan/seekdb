#new rows
--error 1062
update t1 set c1=4, c2=4 where idx=2 when row_count(insert into t1(idx,pk,c1,c2) values(2,0,0,0),(2,1,0,0))=2;
--error 1062
update t1 set c1=3, c2=3 where idx=2 when row_count(insert into t1(idx,pk,c1,c2) values(2,2,0,0),(2,3,0,0))=2;
--error 5064
update t1 set c1=5, c2=5 where idx=3 when row_count(insert into t1(idx,pk,c1,c2) values(2,8,0,0),(2,9,0,0))=1;
select * from t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log

update t1 set c1=2, c2=2 where idx=2 when row_count(insert into t1(idx,pk,c1,c2) values(2,8,0,0),(2,9,0,0))=2;
update t1 set c1=3, c2=3 where idx=2 when row_count(replace into t1(idx,pk,c1,c2) values(2,10,0,0),(2,11,0,0))=2;
select * from t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log

