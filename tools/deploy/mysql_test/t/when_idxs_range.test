########CASE: delete + update
replace into t1(idx,pk,c1,c2) values(0,0,0,0),(0,1,0,0),(0,2,0,0),(0,3,0,0),(1,4,0,0),(1,5,0,0),(1,6,0,0),(1,7,0,0);
replace into t2(idx,pk,c1,c2) values(0,0,0,0),(0,1,0,0),(0,2,0,0),(0,3,0,0),(1,4,0,0),(1,5,0,0),(1,6,0,0),(1,7,0,0);
--error 5064
delete from t1 where idx=1 when row_count(update t1 set c1=c1+1, c2=c2+1 where idx=0)=3;
--error 5064
delete from t2 where idx=1 when row_count(update t1 set c1=c1+1, c2=c2+1 where idx=0)=3;
select * from t1;
