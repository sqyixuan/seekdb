#owner: zhanyue.zzy
#owner group: SQL1
--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
####TITLE:with multi indexs table, update delete using one of idxs,compound
--disable_query_log
--source mysql_test/include/index_quick_major.inc
--real_sleep 1
--disable_warnings
drop table if exists t1,t2;
--enable_warnings
--enable_query_log

create table t1(pk int, idx int, c1 int, c2 int, primary key(pk));
create table t2(pk int, idx int, c1 int, c2 int, primary key(pk));
create index i1 on t1(idx,c1);
create index i2 on t2(idx,c1);
let $idx1 = query_get_value(select a.table_name from oceanbase.__all_virtual_table as a inner join (select * from oceanbase.__all_virtual_table where table_name='t1') b on a.data_table_id=b.table_id, table_name, 1);
let $idx2 = query_get_value(select a.table_name from oceanbase.__all_virtual_table as a inner join (select * from oceanbase.__all_virtual_table where table_name='t2') b on a.data_table_id=b.table_id, table_name, 1);


insert into t1(idx,pk,c1,c2) values(0,0,0,0),(0,1,0,0),(0,2,0,0),(0,3,0,0),(1,4,0,0),(1,5,0,0),(1,6,0,0),(1,7,0,0);
insert into t2(idx,pk,c1,c2) values(0,0,0,0),(0,1,0,0),(0,2,0,0),(0,3,0,0),(1,4,0,0),(1,5,0,0),(1,6,0,0),(1,7,0,0);

--source mysql_test/include/check_all_idx_ok.inc

########CASE: select + update
--error 5064
select c1,c2 from t1 where idx=1 when row_count(update t1 set c1=c1+1, c2=c2+1 where idx=1)=1;
select * from t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log

select * from t1 when row_count(update t1 set c1=c1+1, c2=c2+1 where idx=0)=4;
select c1,c2 from t1 where idx=1 when row_count(update t1 set c1=c1+1, c2=c2+1 where idx=1)=4;
select * from t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log

########CASE: select + update + update
replace into t1(idx,pk,c1,c2) values(0,0,0,0),(0,1,0,0),(0,2,0,0),(0,3,0,0),(1,4,0,0),(1,5,0,0),(1,6,0,0),(1,7,0,0);
select * from t1 where idx=1 when row_count(update t1 set c1=c1+1, c2=c2+1 where idx=1 when row_count(update t1 set c1=c1+1, c2=c2+1 where idx=1)=4)=4;
select c1,c2 from t1 where idx=0 when row_count(update t1 set c1=c1+1, c2=c2+1 where idx=0 when row_count(update t1 set c1=c1+1, c2=c2+1 where idx=0)=4)=4;
select * from t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log

--error 5064
select * from t1 where idx=1 when row_count(update t1 set c1=c1+1, c2=c2+1 where idx=1 when row_count(update t1 set c1=c1+1, c2=c2+1 where idx=1)=3)=4;
--error 5064
select * from t1 where idx=1 when row_count(update t1 set c1=c1+1, c2=c2+1 where idx=1 when row_count(update t1 set c1=c1+1, c2=c2+1 where idx=1)=4)=3;
select * from t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log

########CASE: select + update t1 + update t2
replace into t1(idx,pk,c1,c2) values(0,0,0,0),(0,1,0,0),(0,2,0,0),(0,3,0,0),(1,4,0,0),(1,5,0,0),(1,6,0,0),(1,7,0,0);
select * from t1 where idx=0 when row_count(update t2 set c1=c1+1, c2=c2+1 where idx=0 when row_count(update t1 set c1=c1+1, c2=c2+1 where idx=0)=4)=4;
select * from t1;
--disable_query_log
eval select * from $idx1;
select * from t2;
eval select * from $idx2;
--enable_query_log
select c1,c2 from t2 where idx=1 when row_count(update t2 set c1=c1+1, c2=c2+1 where idx=1 when row_count(update t1 set c1=c1+1, c2=c2+1 where idx=1)=4)=4;
select * from t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log
select * from t2;
--disable_query_log
eval select * from $idx2;
--enable_query_log

--error 5064
select * from t1 where idx=1 when row_count(update t2 set c1=c1+1, c2=c2+1 where idx=1 when row_count(update t1 set c1=c1+1, c2=c2+1 where idx=1)=4)=1;
--error 5064
select * from t1 where idx=1 when row_count(update t2 set c1=c1+1, c2=c2+1 where idx=1 when row_count(update t1 set c1=c1+1, c2=c2+1 where idx=1)=1)=4;
