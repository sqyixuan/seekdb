select * from t2;
--disable_query_log
eval select * from $idx2;
--enable_query_log
delete from t2 where idx=1 when row_count(replace into t1(idx,pk,c1,c2) values(2,11,1,1))=1;
select * from t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log
select * from t2;
--disable_query_log
eval select * from $idx2;
--enable_query_log

