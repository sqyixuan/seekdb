delete from t1 where idx=1 when row_count(delete from t1 where idx=0)=1;
--error 5064
delete from t2 where idx=1 when row_count(delete from t1 where idx=0)=1;
select * from t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log
select * from t2;
--disable_query_log
eval select * from $idx2;
--enable_query_log

