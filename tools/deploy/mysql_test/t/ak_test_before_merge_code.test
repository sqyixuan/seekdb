# owner: yongle.xh
# owner group: storage ha
# description: ak test before merge code

# simple test for create table\insert\update\create index\ drop table\drop index
--disable_warnings
drop table if exists t1;
drop table if exists t2;
--enable_warnings
create table t1 (a int, b int, unique index idx (a, b));
create table t2 (a int, b int, unique index idx (a, b));

insert into t1 values(1,1);

--error 1062
insert into t1 values(1,1);

create unique index idx1 on t1(a);
--source mysql_test/include/check_all_idx_ok.inc

create index idx2 on t1(b) local;
--source mysql_test/include/check_all_idx_ok.inc

insert into t1 values(2,2);

--error 1062
insert into t1 values(2,3);
select * from t1;

update t1 set b = 10 where a = 2;
delete from t1 where a  = 1;

drop index idx1 on t1;
drop table t2;

# simple test for daily merge
--source mysql_test/include/tenant_major_freeze.inc
--source mysql_test/include/wait_tenant_major_merge.inc

drop table t1;
