# 

--result_format 4

--disable_warnings
drop table if exists t1,t2;
--enable_warnings

create table t1 (c1 varchar(20) collate utf8mb4_general_ci primary key, c2 varchar(20) collate utf8mb4_general_ci) partition by key(c1) partitions 8;
create table t2 (c1 varchar(20) collate utf8mb4_bin primary key, c2 varchar(20) collate utf8mb4_bin) partition by key(c1) partitions 8;

insert into t1 values ('a', 'a'), ('B', 'B'), ('c', 'c');
insert into t2 values ('a', 'a'), ('B', 'B'), ('c', 'c');

explain select * from t1, t2 where t1.c1 = t2.c2;
--sorted_result
select * from t1, t2 where t1.c1 = t2.c2;

explain select * from t1, t2 where t1.c1 = t2.c1;
--sorted_result
select * from t1, t2 where t1.c1 = t2.c1;

--sorted_result
select * from t1, t2 where t1.c2 = t2.c2;

--echo #
DROP TABLE IF EXISTS t2;
DROP TABLE IF EXISTS t1;
CREATE TABLE t1(c0 INT,c1 CHAR(10))
PARTITION BY LIST COLUMNS(c1)
(PARTITION l1 VALUES IN('A','中文','COL','NAL','AB',''),
 PARTITION l2 VALUES IN('10','12','$ % &','$%&','文')
);
CREATE TABLE t2(c0 INT,c1 CHAR(10))
PARTITION BY LIST COLUMNS(c1)
(PARTITION l1 VALUES IN('AB','中','test 1','中guo','$&'),
 PARTITION l2 VALUES IN('10','12','$ % &','ABC','mars','13','')
 );



explain SELECT * FROM t1 WHERE c1 IN (SELECT c1 FROM t2 WHERE c1 <>ALL (SELECT c1 FROM t1)) ORDER BY 1,2;
drop table t1;
drop table t2;