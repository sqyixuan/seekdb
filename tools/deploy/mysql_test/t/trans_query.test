--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: link.zt
# owner group: SQL3
# description: OUR GOAL: Make all this simple and effective!

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1 (a int primary key, b int);

begin;
replace into t1 values (1, 2);
select * from t1;
rollback;

select * from t1;

set autocommit = 0;
select * from t1;
replace into t1 values (2, 3);
select * from t1;
set autocommit = 1;

select * from t1;


set autocommit = 0;
update t1 set b = 4 where a = 2;
select * from t1;
rollback;

select * from t1;
commit;

update t1 set b = 4 where a = 2;
select * from t1;
set autocommit = 1;
set autocommit = 0;
select * from t1;
rollback;
select * from t1;

connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn2,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);

connection conn1;
begin;
select * from t1;

connection conn2;
replace into t1 values (5, 5);

connection conn1;
select * from t1;
rollback;

