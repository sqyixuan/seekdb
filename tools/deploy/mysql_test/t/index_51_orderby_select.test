#### 功能限制：union join等多set的order by优化不支持。
#### case 8 join
# case 8-1, single set order by pk;
echo case 8-1, single set order by pk;
--sorted_result
select t1.pk1, t2.pk2, t1.c1, t2.c2 from t1, (select pk1, pk2, c2 from t1 where pk1=0 order by pk1, pk2) as t2 where t1.pk1=0 and t1.pk1=t2.pk1;
--sorted_result
select t1.pk1, t1.pk2, t1.c1, t2.c2 from (select pk1, pk2, c1 from t1 where pk1=0 order by pk1) as t1 left join (select pk1, pk2, c2 from t1) as t2 on t1.pk1=t2.pk1;
--sorted_result
select * from (select pk1, pk2, c1 from t1 where pk1=0) as t1 left join (select pk1, pk2, c2 from t1 order by pk1, pk2) as t2 on t1.pk1=t2.pk1;

# case 8-2, multi sets order by pk;
echo case 8-2, multi sets order by pk;
--sorted_result
select t1.pk1, t1.pk2, t1.c1, t2.c2 from (select pk1, pk2, c1 from t1 where pk1=0 order by pk1) as t1 left join (select pk1, pk2, c2 from t1 order by pk1, pk2) as t2 on t1.pk1=t2.pk1 order by 1, 2, 3, 4;
--sorted_result
select * from (select pk1, pk2, c1 from t1 where pk1=0 order by pk1) as t1 left join (select pk1, pk2, c2 from t1 order by pk1, pk2) as t2 on t1.pk1=t2.pk1;
--sorted_result
select t1.pk1, t2.pk2, t1.c1, t2.c2 from (select * from t1 order by pk1, pk2) as t1, (select pk1, pk2, c2 from t1 where pk1=0 order by pk1, pk2) as t2 where t1.pk1=0 and t1.pk1=t2.pk1 order by 1, 2, 3, 4;
--sorted_result
select * from (select t1.pk1, t1.pk2, t1.c1, t2.c2 from (select pk1, pk2, c1 from t1 where pk1=0 order by pk1) as t1 left join (select pk1, pk2, c2 from t1 order by pk1, pk2) as t2 on t1.pk1=t2.pk1) as t3 order by pk1, pk2;

# case 8-3, single set order by index;
echo case 8-3, single set order by index;
--sorted_result
select t1.pk1, t1.pk2, t1.c1, t2.c2 from (select pk1, pk2, c1 from t1 where c1=0 order by c1) as t1 left join (select pk1, pk2, c2 from t1 where c1>=0 and c1<=1) as t2 on t1.c1=t2.c2;
--sorted_result
select * from (select pk1, pk2, c1 from t1 where c1>-1 and c1<2 and c2=0) as t1 left join (select pk1, pk2, c1 from t1 where c1=0 and c2=2 order by c1, c2) as t2 on t1.c1=t2.c1 and t1.c1=t2.c1;

# case 8-4, multi sets order by index;
echo case 8-4, multi sets order by index;
--sorted_result
select t1.pk1, t1.pk2, t1.c1, t2.c2 from (select pk1, pk2, c1 from t1 where c1=0 order by c1) as t1 left join (select pk1, pk2, c2 from t1 where c1>=0 and c1<=1 order by c1) as t2 on t1.c1=t2.c2;
--sorted_result
select * from (select pk1, pk2, c1 from t1 where c1>-1 and c1<2 and c2=0 order by c1) as t1 left join (select pk1, pk2, c1 from t1 where c1=0 and c2=2 order by c1, c2) as t2 on t1.c1=t2.c1 and t1.c1=t2.c1;
--sorted_result
select * from (select t1.pk1, t1.pk2, t2.c1 from (select pk1, pk2, c1 from t1 where c1=0 order by c1) as t1 left join (select pk1, pk2, c1 from t1  where c1>=0 and c1<=1 order by c1) as t2 on t1.c1=t2.c1) as t3 order by c1;

#### case 9 union
# case 9-1, single set order by pk;
echo case 9-1, single set order by pk;
(select * from t1 where pk1=0 order by pk1) union (select * from t1 where pk1=1 and pk2>='0' and pk2<='3');
(select pk1, pk2 from t1 where pk1=0) union all (select pk1, pk2 from t1 where pk1=1 and pk2>='0' and pk2<='3' order by pk1, pk2);

# case 9-2, multi sets order by pk;
echo case 9-2, multi sets order by pk;
(select * from t1 where pk1=0 order by pk1) union (select * from t1 where pk1=1 and pk2>='0' and pk2<='3' order by pk1, pk2);
(select * from t1 where pk1>-1 and pk1<=0 order by pk1, pk2) union (select * from t1 where pk1>0 and pk1<=1 and pk2>='0' and pk2<='3' order by pk1);
(select pk1, pk2 from t1 where pk1=0 order by pk1) union all (select pk1, pk2 from t1 where pk1=1 and pk2>='0' and pk2<='3' order by pk1, pk2);
(select * from t1 where pk1>-1 and pk1<=2 order by pk1) union all (select * from t1 where pk1>=0 and pk1<=1 and pk2='0' order by pk1, pk2);

# case 9-3, single set order by index;
echo case 9-3, single set order by index;
(select pk1, pk2, c2 from t1 where c2>-1 and c2<=0 order by c2) union (select pk1, pk2, c2 from t1 where c2=1);
(select * from t1 where c1>=0 and c1<=1 and c2>='0' and c2<='1') union (select * from t1 where c1>=0 and c1<=1 and c2>='0' and c2<='3' order by c1, c2); 
(select * from t1 where c1>=0 and c1<=1 and c2>='0' and c2<='1') union all (select * from t1 where c1>=0 and c1<=1 and c2>='0' and c2<='3' order by c1, c2); 
(select * from t1 where c1>=0 and c1<=1 and c2>='0' and c2<='1') union all (select * from t1 where c1>=0 and c1<=1 and c2>='2' and c2<='3' order by c1, c2); 

# case 9-4, multi sets order by index;
echo case 9-4, multi sets order by index;
(select pk1, pk2, c2 from t1 where c2>-1 and c2<=0 order by c2) union (select pk1, pk2, c2 from t1 where c2=1 order by c2);
(select * from t1 where c1>=0 and c1<=1 and c2>='0' and c2<='1' order by c1) union (select * from t1 where c1>=0 and c1<=1 and c2>='0' and c2<='3' order by c1, c2); 
(select * from t1 where c1>=0 and c1<=1 and c2>='0' and c2<='1' order by c1) union all (select * from t1 where c1>=0 and c1<=1 and c2>='0' and c2<='3' order by c1, c2); 

