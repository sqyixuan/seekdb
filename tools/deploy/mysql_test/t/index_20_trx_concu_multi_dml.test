--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: yuchen.wyc
# owner group: SQL1
#description: Test index with transaction and multiple concurrent DMLs
####TITLE:事务1多种DML操作，多次提交，事务2读，查询索引表、数据表、回表
####
--disable_query_log
--source mysql_test/include/index_quick_major.inc
--real_sleep 1
--disable_warnings
drop table if exists t1;
--enable_warnings
--enable_query_log

create table t1(pk int primary key, a int, b int, c int, d int);
create index i1 on t1(b, c) storing(d);


--source mysql_test/include/check_all_idx_ok.inc

connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn2,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);

####CASE:事务1多种dml操作，多次提交，事务2读
connection conn1;
set autocommit=0;
insert into t1(pk, a, b, c, d) values(1,1,1,1,1),(2,1,1,1,1),(3,1,1,1,1);
commit;

connection conn2;
set autocommit=0;
select pk, b, c, d from t1 where b>0 and b<10;
select * from t1 where pk>0 and pk<10;
select /*+index(t1 i1)*/ * from t1 where b>0 and b<10;

####insert
connection conn1;
insert into t1(pk,a ,b, c, d) values(4,1,1,1,1);
commit;

connection conn2;
select pk, b, c, d from t1 where b>0 and b<10;
select * from t1 where pk>0 and pk<10;
select /*+index(t1 i1)*/ * from t1 where b>0 and b<10;

####replace
connection conn1;
delete from t1 where pk=1;
replace into t1(pk,a ,b, c, d) values(1, 2, 2, 2, 2);
commit;

connection conn2;
select pk, b, c, d from t1 where b>0 and b<10;
select * from t1 where pk>0 and pk<10;
select /*+index(t1 i1)*/ * from t1 where b>0 and b<10;

####update
connection conn1;
update t1 set a=2, b=2, c=2, d=2 where pk=2;
commit;

connection conn2;
select pk, b, c, d from t1 where b>0 and b<10;
select * from t1 where pk>0 and pk<10;
select /*+index(t1 i1)*/ * from t1 where b>0 and b<10;

####delete
connection conn1;
delete from t1 where pk=3;
commit;

connection conn2;
select pk, b, c, d from t1 where b>0 and b<10;
select * from t1 where pk>0 and pk<10;
select /*+index(t1 i1)*/ * from t1 where b>0 and b<10;
commit;

#### trans 2 commit, then select
select pk, b, c, d from t1 where b>0 and b<10;
select * from t1 where pk>0 and pk<10;
select /*+index(t1 i1)*/ * from t1 where b>0 and b<10;

#drop table t1;
