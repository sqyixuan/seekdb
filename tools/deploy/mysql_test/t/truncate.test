drop table if exists test1;
create table test1(c1 decimal(40,10), c2 double, c3 bigint, c4 decimal);
insert into test1 values(20191203060000, 6.5, 6, 6);
insert into test1 values(20191203060000, 6.5, 7, 7);

select c3,c4,truncate(c1, c2), truncate(c1, c3), truncate(c1, c4) from test1;
