--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: dachuan.sdc
# owner group: SQL3
# description: 本case是为了测试自增列在mysql中判断is null的特殊处理

--disable_warnings
drop table if exists test;
--enable_warnings

create table test(c1 int auto_increment primary key);
insert into test values(),(),();
select * from test where c1 is null;

drop table test;
set sql_auto_is_null = 1;
create table test(c1 int auto_increment primary key);
insert into test values(),(),();
select * from test where c1 is null;


