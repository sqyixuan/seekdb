connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn1;
set global max_allowed_packet=default;
disconnect conn1;
connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn1;
--disable_query_log
set sql_mode = 'STRICT_ALL_TABLES,NO_ZERO_IN_DATE';
--enable_query_log
