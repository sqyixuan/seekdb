#owner: nijia.nj
#owner group: sql1
#description: 

--disable_result_log
show parameters like '%timeout%';
show parameters where zone='zone1' and 1 = 1;
--enable_result_log

connect(conn1, $OBMYSQL_MS0, admin, $OBMYSQL_PWD, test, $OBMYSQL_PORT);
connection conn1;

alter system set memory_limit='0M';

# Don't support memory_limit < 1G, by nijia.nj
--error 4147
alter system set memory_limit='900M';

# alter system set memory_limit='8G';
# alter system set memory_limit='10G';
--real_sleep 5

# do something you like
# alter system set memory_limit='15G';
