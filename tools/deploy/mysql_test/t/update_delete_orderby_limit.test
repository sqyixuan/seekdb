#owner: link.zt
#owner group: SQL1
--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
####TITLE: range update
# tags: optimizer
--disable_warnings
drop table if exists t1;
--enable_warnings


####CASE: single rowkey, using rowkey, >,>=,<,<=
create table t1 (a int, b int, c int, primary key (a, b));
insert into t1(a,b,c) values(1,1,1),(2,2,2),(3,3,3),(4,4,4);
select * from t1;
update t1 set b=2 where a>0 limit 1;
select * from t1;
update t1 set b=11 where a>0 limit 1,1;
select * from t1;
update t1 set b=2 where a>0 limit 2;
select * from t1;
update t1 set b=21 where a>0 limit 2,1;
select * from t1;
update t1 set b='30' where a>0 limit 0,3;
select * from t1;
update t1 set b=2 where a>0 limit 3;
select * from t1;
update t1 set b=2 where a>0 limit 4;
select * from t1;
####test:limit is large than actual rows
update t1 set b=10 where a>0 limit 10;
select * from t1;
delete from t1 where a>0 limit 10;
select * from t1;
delete from t1 where a>0 limit 1000;
select * from t1;
delete from t1 where a>0 limit 0,1000;
insert into t1(a,b,c) values(1,1,1),(2,2,2),(3,3,3),(4,4,4);
select * from t1;
update t1 set b=2 where a>0 order by a desc limit 1;
select * from t1;
####test use alias 
update t1 test set test.b=2 where test.a>0 order by test.a desc limit 2;
select * from t1;
update t1 set b=2 where a>0 order by a desc limit 0,3;
select * from t1;
update t1 set b=2 where a>0 order by a desc limit 4;
select * from t1;
delete from t1 where a>0 order by a limit 1;
select * from t1;
delete from t1 where a>0 order by a limit 1;
select * from t1;
delete from t1 where a>0 order by a limit 1;
select * from t1;
delete from t1 where a>0 order by a limit 1;
select * from t1;
delete from t1 where a>0 order by a limit 1;
select * from t1;
#insert into t1(a,b,c) values(1,1,1),(2,2,2),(3,3,3),(4,4,4);
insert into t1(a,b,c) values(1,1,1),(2,2,2),(3,3,3),(4,4,4);
select * from t1;
--error 1064
delete from t1 where a>0 order by a desc limit -1;
delete from t1 where a>0 order by a desc limit 1;
select * from t1;
delete from t1 where a>0 order by a desc limit 1;
select * from t1;
delete from t1 where a>0 order by a desc limit 1;
select * from t1;
delete from t1 where a>0 order by a desc limit 1;
select * from t1;
--error 1064
delete from t1 where a>0 order by a desc limit null;
select * from t1;

# test prepare, update
delete from t1 where 1;
insert into t1(a,b,c) values(1,1,1),(2,2,2),(3,3,3),(4,4,4);
prepare stmt1 from  update t1 set b=? where a>? limit ?;
set @a=1001;
set @b=0;
set @c=3;
select * from t1;
execute stmt1 using @a,@b,@c;
execute stmt1 using @a,@c,@b;
select * from t1;


# test prepare,update+order by
delete from t1 where 1;
insert into t1(a,b,c) values(1,1,1),(2,2,2),(3,3,3),(4,4,4);
prepare stmt1 from  update t1 set b=? where a in (?,?)  order by a limit ?;
set @a=1001;
set @b=0;
set @d=1;
set @c=3;
select * from t1;
execute stmt1 using @a,@b,@d,@c;
select * from t1;
execute stmt1 using @a,@c,@d,@b;
select * from t1;

# test prepare,update+order by +desc
delete from t1 where 1;
insert into t1(a,b,c) values(1,1,1),(2,2,2),(3,3,3),(4,4,4);
prepare stmt1 from  update t1 set b=? where a in (?,?)  order by a desc  limit ?;
set @a=1001;
set @b=0;
set @d=1;
set @c=3;
select * from t1;
execute stmt1 using @a,@b,@d,@c;
execute stmt1 using @a,@c,@d,@b;
select * from t1;


# test when
select * from t1;
update t1 set b=5 where a>0 limit 2 when row_count(insert into t1 values(5,5,5))=1;
select * from t1;
update t1 set b=5 where a>0 order by a desc limit 2 when row_count(insert into t1 values(6,6,6))=1;
select * from t1;
update t1 set b=5 where a>0 order by a desc limit 2 when row_count(update t1 set b=5 where a>0 limit 2)=2;
select * from t1;
prepare stmt2 from update t1 set b=5 where a>0 order by a desc limit 2 when row_count(update t1 set b=5 where a>0 order by a desc limit ?)=?;
set @a=1;
set @b=1;
execute stmt2 using @a, @b;
select * from t1;
set @a=1;
set @b=1;
execute stmt2 using @a, @b;
select * from t1;

select * from t1;
--replace_regex /Plan signature: [0-9]*/Plan signature/
--disable_result_log
explain delete from t1 where a>0 order by a desc limit 1;
--enable_result_log
--replace_regex /Plan signature: [0-9]*/Plan signature/
--disable_result_log
explain update t1 set b=10  where a>0 order by a desc limit 1;
--enable_result_log
--replace_regex /Plan signature: [0-9]*/Plan signature/
--disable_result_log
explain update t1 set b=10  where a>0;
--enable_result_log
select * from t1;
