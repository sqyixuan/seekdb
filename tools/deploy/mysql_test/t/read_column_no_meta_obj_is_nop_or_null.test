# owner: muwei.ym 
# owner group: STORAGE
# description: issue/16264643

--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1 (c1 int primary key, c2 int, c3 varchar(2048)) compression='none';

--disable_query_log
--disable_result_log

--let $count = 0
while($count < 2100)
{
  --let $stmt=INSERT INTO t1 VALUES ($count, $count, repeat('a', 2048))
  eval $stmt;
  inc $count;
}

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
let $__table_id__=query_get_value(select /*+QUERY_TIMEOUT(10000000000)*/ table_id from oceanbase.__all_virtual_table where table_name='t1', table_id, 1);
disconnect obsys;
connection default;

--enable_query_log
--enable_result_log

--source mysql_test/include/minorfreeze.inc
--source mysql_test/include/wait_minor_merge.inc

update t1 set c3 = NULL where c1 = 1000;
alter table t1 add column c4 int;

--source mysql_test/include/minorfreeze.inc
--source mysql_test/include/wait_minor_merge.inc

