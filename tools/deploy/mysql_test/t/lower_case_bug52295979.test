#create database inforMation_Schema;
#--error 1044
#create database INFORMATION_SCHEMA;
#--error 1044
#create database information_schema;
#--error 1044
#drop database INFORMATION_SCHEMA;
#--error 1044
#drop database information_schema;

connection conn0;
#drop tenant tt1 force;
#drop resource pool if exists test_resource_pool1;
#drop resource unit if exists test_resource_unit1;
