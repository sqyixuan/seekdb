select /*+no_use_px,index(tpart l_c2)*/ * FROM tpart SAMPLE BLOCK (0.4) SEED(12345);
alter system set minor_compact_trigger = 2;

USE SAMPLE_SCAN;
drop database SAMPLE_SCAN;
