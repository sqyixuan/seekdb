select /*+no_use_px,index(tpart g_c1)*/ * FROM tpart SAMPLE BLOCK (0.4) SEED(12345);

select /*+no_use_px,index(tpart l_c2)*/ COUNT(*) FROM tpart SAMPLE  (0.4) SEED(12345);
select /*+no_use_px,index(tpart l_c2)*/ * FROM tpart SAMPLE  (0.4) SEED(12345);
select /*+no_use_px,index(tpart l_c2)*/ * FROM tpart SAMPLE  (0.4) SEED(12345);

select /*+no_use_px,index(tpart l_c2)*/ COUNT(*) FROM tpart SAMPLE BLOCK (0.4) SEED(12345);
