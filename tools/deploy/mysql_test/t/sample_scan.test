select /*+no_use_px*/ * FROM t1 SAMPLE BLOCK INCR (3) SEED (23333);
EXPLAIN select /*+no_use_px*/ * FROM t1 SAMPLE BLOCK INCR (10) SEED (23333);
select /*+no_use_px*/ * FROM t1 SAMPLE BLOCK INCR (10) SEED (23333);
EXPLAIN select /*+no_use_px*/ * FROM t1 SAMPLE BLOCK INCR (20) SEED (23333);
select /*+no_use_px*/ * FROM t1 SAMPLE BLOCK INCR (20) SEED (23333);

--echo # base data
EXPLAIN select /*+no_use_px*/ * FROM t1 SAMPLE BASE (3) SEED (23333);
select /*+no_use_px*/ * FROM t1 SAMPLE BASE (3) SEED (23333);
EXPLAIN select /*+no_use_px*/ * FROM t1 SAMPLE BASE (10) SEED (23333);
select /*+no_use_px*/ * FROM t1 SAMPLE BASE (10) SEED (23333);
