# sample with sample scan on global index
SELECT /*+NO_USE_PX*/ col0 FROM (SELECT col0, bucket, ROW_NUMBER() OVER (PARTITION BY bucket ORDER BY col0) rn FROM (SELECT col0, NTILE(65) OVER (ORDER BY col0) bucket FROM (SELECT /*+index(tt i1)*/ `pk` AS col0 FROM `tt` SAMPLE BLOCK(10) LIMIT 200000) a) b) c WHERE rn = 1 GROUP BY col0 ORDER BY col0;

select /*+no_use_px,index(tpart g_c1)*/ COUNT(*) FROM tpart SAMPLE (0.4) SEED(12345);
select /*+no_use_px,index(tpart g_c1)*/ * FROM tpart SAMPLE (0.4) SEED(12345);
select /*+no_use_px,index(tpart g_c1)*/ * FROM tpart SAMPLE (0.4) SEED(12345);

