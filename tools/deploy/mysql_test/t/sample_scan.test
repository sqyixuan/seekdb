select /*+no_use_px*/ * FROM t1 SAMPLE (80) SEED (23333);
EXPLAIN select /*+no_use_px*/ * FROM t1 SAMPLE (99) SEED (23333);

EXPLAIN select /*+no_use_px*/ * FROM t1 SAMPLE BLOCK (3) SEED (23333);
select /*+no_use_px*/ * FROM t1 SAMPLE BLOCK (3) SEED (23333);
EXPLAIN select /*+no_use_px*/ * FROM t1 SAMPLE BLOCK (10) SEED (23333);
select /*+no_use_px*/ * FROM t1 SAMPLE BLOCK (10) SEED (23333);
