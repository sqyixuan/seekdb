# sample
select /*+no_use_px*/ * FROM empty_1 SAMPLE (3);

# sample block
select /*+no_use_px*/ * FROM empty_1 SAMPLE BLOCK (3);

# sample with seed
select /*+no_use_px*/ * FROM empty_2 SAMPLE (3) SEED(12345);

# sample with seed
select /*+no_use_px*/ * FROM empty_1 SAMPLE (3.1415926) SEED(12345);

# sample with multi-tables; 
select /*+no_use_px*/ * FROM empty_1 SAMPLE (3.1415926) SEED(12345), empty_2;

# sample with multi-tables; 
select /*+no_use_px*/ * FROM empty_1 SAMPLE (3.1415926) SEED(12345), empty_2 SAMPLE BLOCK (6.66) SEED(45678);

select /*+no_use_px*/ COUNT(*) FROM t1 SAMPLE (0.000001) SEED(23);
select /*+no_use_px*/ * FROM t1 SAMPLE (0.000001) SEED(23);
select /*+no_use_px*/ COUNT(*) FROM t1 SAMPLE (3.1415926) SEED(233);
select /*+no_use_px*/ * FROM t1 SAMPLE (3.1415926) SEED(233);
select /*+no_use_px*/ COUNT(*) FROM t1 SAMPLE (10) SEED(2333);
select /*+no_use_px*/ * FROM t1 SAMPLE (10) SEED(2333);
select /*+no_use_px*/ COUNT(*) FROM t1 SAMPLE (99) SEED(23333);
select /*+no_use_px*/ * FROM t1 SAMPLE (99) SEED(23333);
select /*+no_use_px*/ * FROM t1 SAMPLE (40) SEED(2333) join t1 SAMPLE (20) SEED(2233) t2 where t1.c1 = t2.c1;

select /*+no_use_px*/ COUNT(*) FROM t1 SAMPLE (0.4) SEED(12345);
select /*+no_use_px*/ * FROM t1 SAMPLE (0.4) SEED(12345);
select /*+no_use_px*/ * FROM t1 SAMPLE (0.4) SEED(12345);

create table t2(c1 int, c2 int, primary key(c1)) partition by hash(c1) partitions 8;
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc

--disable_query_log
