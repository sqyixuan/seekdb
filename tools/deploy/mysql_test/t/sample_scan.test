select /*+no_use_px*/ * FROM t1 SAMPLE BLOCK (80) SEED (23333);
EXPLAIN select /*+no_use_px*/ * FROM t1 SAMPLE BLOCK (99) SEED (23333);

--echo # incremental data
EXPLAIN select /*+no_use_px*/ * FROM t1 SAMPLE INCR (3) SEED (23333);
select /*+no_use_px*/ * FROM t1 SAMPLE INCR (3) SEED (23333);
EXPLAIN select /*+no_use_px*/ * FROM t1 SAMPLE INCR (10) SEED (23333);
