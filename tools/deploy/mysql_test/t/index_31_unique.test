--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: bin.lb
# owner group: SQL3
# description:
#
####TITLE:unique索引
--disable_query_log
--source mysql_test/include/index_quick_major.inc
--real_sleep 1
--disable_warnings
drop table if exists t1,t2;
--enable_warnings
--enable_query_log

####CASE:单列unique索引
create table t1(c1 int primary key, c2 varchar(1024), c3 int, c4 int);
create unique index i11 on t1(c2);
create unique index i12 on t1(c3) storing(c2, c4);
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
let $idx1 = query_get_value(select a.table_name from oceanbase.__all_virtual_table as a inner join (select * from oceanbase.__all_virtual_table where table_name='t1') b on a.data_table_id=b.table_id and a.table_name like '%i11',table_name, 1);
let $idx2 = query_get_value(select a.table_name from oceanbase.__all_virtual_table as a inner join (select * from oceanbase.__all_virtual_table where table_name='t1') b on a.data_table_id=b.table_id and a.table_name like '%i12',table_name, 1);
disconnect obsys;
connection default;
#静态数据
insert into t1 values(1,'a',1, 1);

#unique索引需要2次每日合并
--source mysql_test/include/check_all_idx_ok.inc
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
select table_name, index_status from oceanbase.__all_virtual_table where table_name like '%idx_i1%';
disconnect obsys;
connection default;
#动态数据
insert into t1 values(2,'b',2, 2);

####CASE: insert和静态数据/动态数据相同的值
--error 1062
insert into t1 values(3,'a',3, 3);
insert into t1 values(3,'c',3, 3);

--error 1062
insert into t1 values(4,'d','2',4);
insert into t1 values(4,'d','4',4);

select * from t1;

--disable_query_log
set ob_enable_index_direct_select = 1;
eval select * from $idx1;
eval select * from $idx2;
--enable_query_log

####CASE: replace和静态数据/动态数据相同的值
replace into t1 values(5,'a',5, 5);
replace into t1 values(5,'f',5, 5);

--error 1062
insert into t1 values(6,'g','2',6);
insert into t1 values(6,'g','6',6);

select * from t1;
--disable_query_log
eval select * from $idx1;
eval select * from $idx2;
--enable_query_log

####CASE: update 和静态数据，动态数据相同的值
insert into t1 values(7,'h',30, 7);
replace into t1 values(8,'i',8, 8);
update t1 set c2='a' where c1=7;
select * from t1;
--error 1062
update t1 set c3='2' where c1=8;

update t1 set c2='aa' where c1=7;
update t1 set c3=22 where c1=8;

select * from t1;
--disable_query_log
eval select * from $idx1;
eval select * from $idx2;
--enable_query_log

