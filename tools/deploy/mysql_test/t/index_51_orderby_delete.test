--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: yibo.tyf
#owner group: sql1
# tags: optimizer

####TITEL: test index with order by
--disable_query_log
source mysql_test/include/index_quick_major.inc;
--real_sleep 10
--disable_warnings
drop table if exists t1;
--enable_warnings
--enable_query_log

create table t1(pk1 int, pk2 varchar(10), c1 int, c2 int, c3 varchar(20), c4  timestamp(6) default "2012-01-01 12:00:00", c5 int, primary key(pk1, pk2));
create index i1 on t1(c1);
create index i2 on t1(c2);
create index i3 on t1(c1,c2);
create index i4 on t1(c2, c3, c4);
create index i5 on t1(c2, c3) storing(c1);
create index i6 on t1(c3);

insert into t1(pk1, pk2, c1, c2, c3, c4, c5) values
(0,'0',0,0,'0','2014-11-03 08:00:00',0),(0,'1',0,0,'0','2014-11-03 08:00:00',0),
(0,'2',1,0,'1','2014-11-03 08:00:01',0),(0,'3',1,0,'1','2014-11-03 08:00:01',0);

--source mysql_test/include/check_all_idx_ok.inc

insert into t1(pk1, pk2, c1, c2, c3, c4, c5) values
(1,'0',2,1,'2','2014-11-03 08:00:02',0),(1,'1',2,1,'2','2014-11-03 08:00:02',0),
(1,'2',3,1,'3','2014-11-03 08:00:03',0),(1,'3',3,1,'3','2014-11-03 08:00:03',0);

select * from t1;
set autocommit=0;

#### case 1: use t1
# case 1-1, use t1, optimized
echo case 1-1, use t1, optimized;
--replace_regex /Plan signature: [0-9]*/Plan signature/
--disable_result_log
explain delete from t1 where pk1=0 and pk2<='4' order by pk2;
--enable_result_log
--replace_regex /Plan signature: [0-9]*/Plan signature/
--disable_result_log
explain delete from t1 where pk1=0 and pk2<='4' order by pk1, pk2;
--enable_result_log
--replace_regex /Plan signature: [0-9]*/Plan signature/
--disable_result_log
explain delete from t1 where pk1=0 and pk2<='4' order by pk2 limit 2;
--enable_result_log
--replace_regex /Plan signature: [0-9]*/Plan signature/
--disable_result_log
explain delete from t1 where pk1=0 and pk2<='4' order by pk1, pk2 limit 2;
--enable_result_log

delete from t1 where pk1=0 and pk2<='4' order by pk2;
delete from t1 where pk1=0 and pk2<='4' order by pk1, pk2;
delete from t1 where pk1=0 and pk2<='4' order by pk2 limit 2;
delete from t1 where pk1=0 and pk2<='4' order by pk1, pk2 limit 2;
select * from t1;
rollback;

# case 1-1, use t1, non-optimized
echo case 1-1, use t1, non-optimized;
--replace_regex /Plan signature: [0-9]*/Plan signature/
--disable_result_log
explain delete from t1 where pk1=1 and pk2>='0' order by pk2 desc;
--enable_result_log
--replace_regex /Plan signature: [0-9]*/Plan signature/
--disable_result_log
explain delete from t1 where pk1=1 and pk2 in('0','1') order by pk2;
--enable_result_log
--replace_regex /Plan signature: [0-9]*/Plan signature/
--disable_result_log
explain delete from t1 where pk1=1 and pk2>='0' order by pk2 desc limit 2;
--enable_result_log
--replace_regex /Plan signature: [0-9]*/Plan signature/
--disable_result_log
explain delete from t1 where pk1=1 and pk2 in('0','1') order by pk2 limit 2;
--enable_result_log

delete from t1 where pk1=1 and pk2>='0' order by pk2 desc;
delete from t1 where pk1=1 and pk2 in('0','1') order by pk2;
delete from t1 where pk1=1 and pk2>='0' order by pk2 desc limit 2;
delete from t1 where pk1=1 and pk2 in('0','1') order by pk2 limit 2;
select * from t1;
rollback;

#### case 2: use i4, index cols
# case 2-1: use i4, optimized;
echo case 2-1: use i4, optimized;
echo case 2: use i4, index cols;
--replace_regex /Plan signature: [0-9]*/Plan signature/
--disable_result_log
explain delete from t1 where c2=1 and c3='2' and c4>'2014-11-03 08:00:00' order by c4;
--enable_result_log
--replace_regex /Plan signature: [0-9]*/Plan signature/
--disable_result_log
explain delete from t1 where c2=1 and c3>='2' and c4>'2014-11-03 08:00:00' order by c3, c4;
--enable_result_log
--replace_regex /Plan signature: [0-9]*/Plan signature/
--disable_result_log
explain delete from t1 where c2=1 and c3='2' and c4>'2014-11-03 08:00:00' order by c4 limit 3;
--enable_result_log
--replace_regex /Plan signature: [0-9]*/Plan signature/
--disable_result_log
explain delete from t1 where c2=1 and c3>='2' and c4>'2014-11-03 08:00:00' order by c3, c4 limit 3;
--enable_result_log

delete from t1 where c2=1 and c3='2' and c4>'2014-11-03 08:00:00' order by c4;
delete from t1 where c2=1 and c3>='2' and c4>'2014-11-03 08:00:00' order by c3, c4;
delete from t1 where c2=1 and c3='2' and c4>'2014-11-03 08:00:00' order by c4 limit 3;
delete from t1 where c2=1 and c3>='2' and c4>'2014-11-03 08:00:00' order by c3, c4 limit 3;
select * from t1;
rollback;

# case 2-2: use i4, non-optimized;
echo case 2-2: use i4, non-optimized;
--replace_regex /Plan signature: [0-9]*/Plan signature/
--disable_result_log
explain delete from t1 where c2=1 and c3 in('2','3') and c4>'2014-11-03 08:00:00' order by c4;
--enable_result_log
--replace_regex /Plan signature: [0-9]*/Plan signature/
--disable_result_log
explain delete from t1 where c2=1 and c3='2' and (c4='2014-11-03 08:00:00' or c4='2014-11-03 08:00:01') order by c4;
--enable_result_log
--replace_regex /Plan signature: [0-9]*/Plan signature/
--disable_result_log
explain delete from t1 where c2=1 and c3 in('2','3') and c4>'2014-11-03 08:00:00' order by c4 limit 4;
--enable_result_log
--replace_regex /Plan signature: [0-9]*/Plan signature/
--disable_result_log
explain delete from t1 where c2=1 and c3='2' and (c4='2014-11-03 08:00:00' or c4='2014-11-03 08:00:01') order by c4 limit 4;
--enable_result_log

delete from t1 where c2=1 and c3 in('2','3') and c4>'2014-11-03 08:00:00' order by c4;
delete from t1 where c2=1 and c3='2' and (c4='2014-11-03 08:00:00' or c4='2014-11-03 08:00:01') order by c4;
delete from t1 where c2=1 and c3 in('2','3') and c4>'2014-11-03 08:00:00' order by c4 limit 4;
delete from t1 where c2=1 and c3='2' and (c4='2014-11-03 08:00:00' or c4='2014-11-03 08:00:01') order by c4 limit 4;

select * from t1;
rollback;

#### case 3: cover index
#case 3-1: cover index, optimized;
echo case 3-1: cover index, optimized;
--replace_regex /Plan signature: [0-9]*/Plan signature/
--disable_result_log
explain delete from t1 order by pk1;
--enable_result_log
--replace_regex /Plan signature: [0-9]*/Plan signature/
--disable_result_log
explain delete from t1 order by pk1, pk2;
--enable_result_log
delete from t1 order by pk1, pk2;
select * from t1;
rollback;

#case 3-2: cover index, non-optimized;
echo case 3-2: cover index, non-optimized;
--replace_regex /Plan signature: [0-9]*/Plan signature/
--disable_result_log
explain delete from t1 order by c2;
--enable_result_log
--replace_regex /Plan signature: [0-9]*/Plan signature/
--disable_result_log
explain delete from t1 order by c2, c3, c4;
--enable_result_log
delete from t1 order by c2, c3, c4;
select * from t1;
rollback;

#case 3-3: cover index + limit, optimized;
echo case 3-3: cover index + limit, optimized;
--replace_regex /Plan signature: [0-9]*/Plan signature/
--disable_result_log
explain delete from t1 order by pk1 limit 1;
--enable_result_log
--replace_regex /Plan signature: [0-9]*/Plan signature/
--disable_result_log
explain delete from t1 order by pk1, pk2 limit 2;
--enable_result_log
delete from t1 order by pk1 limit 1;
delete from t1 order by pk1, pk2 limit 2;
select * from t1;
rollback;

#case 3-4: cover index + limit, non-optimized;
echo case 3-4: cover index + limit, non-optimized;
--replace_regex /Plan signature: [0-9]*/Plan signature/
--disable_result_log
explain delete from t1 order by c2 limit 3;
--enable_result_log
--replace_regex /Plan signature: [0-9]*/Plan signature/
--disable_result_log
explain delete from t1 order by c2, c3, c4 limit 4;
--enable_result_log
delete from t1 order by c2 limit 3;
delete from t1 order by c2, c3, c4 limit 4;
select * from t1;
rollback;

#### case 4: multiget, non-optimized
#case 4-1: multiget, non-optimized;
echo case 4-1: multiget, non-optimized;
--replace_regex /Plan signature: [0-9]*/Plan signature/
--disable_result_log
explain delete from t1 where pk1=0 or pk1=1 order by pk1;
--enable_result_log
--replace_regex /Plan signature: [0-9]*/Plan signature/
--disable_result_log
explain delete from t1 where (pk1,pk2) in ((0,'0'),(0,'1')) order by pk1;
--enable_result_log
--replace_regex /Plan signature: [0-9]*/Plan signature/
--disable_result_log
explain delete from t1 where (pk1,pk2) in ((0,'2'),(0,'3'))  order by pk1, pk2;
--enable_result_log
--replace_regex /Plan signature: [0-9]*/Plan signature/
--disable_result_log
explain delete from t1 where c2=0 or c2=1 order by c2;
--enable_result_log
--replace_regex /Plan signature: [0-9]*/Plan signature/
--disable_result_log
explain delete from t1 where c2=0 or c2=1 order by pk1;
--enable_result_log
--replace_regex /Plan signature: [0-9]*/Plan signature/
--disable_result_log
explain delete from t1 where (c2,c3) in ((1,'2'),(1,'3')) order by c2, c3;
--enable_result_log

delete from t1 where pk1=0 or pk1=1 order by pk1;
delete from t1 where (pk1,pk2) in ((0,'0'),(0,'1')) order by pk1;
delete from t1 where (pk1,pk2) in ((0,'2'),(0,'3'))  order by pk1, pk2;
delete from t1 where c2=0 or c2=1 order by c2;
delete from t1 where c2=0 or c2=1 order by pk1;
delete from t1 where (c2,c3) in ((1,'2'),(1,'3')) order by c2, c3;
select * from t1;
rollback;

#case 4-2: multiget + limit, non-optimized;
echo case 4-2: multiget + limit, non-optimized;
--replace_regex /Plan signature: [0-9]*/Plan signature/
--disable_result_log
explain delete from t1 where pk1=0 or pk1=1 order by pk1 limit 2;
--enable_result_log
--replace_regex /Plan signature: [0-9]*/Plan signature/
--disable_result_log
explain delete from t1 where (pk1,pk2) in ((0,'0'),(0,'1')) order by pk1 limit 3;
--enable_result_log
--replace_regex /Plan signature: [0-9]*/Plan signature/
--disable_result_log
explain delete from t1 where (pk1,pk2) in ((0,'2'),(0,'3'))  order by pk1, pk2 limit 4;
--enable_result_log
--replace_regex /Plan signature: [0-9]*/Plan signature/
--disable_result_log
explain delete from t1 where c2=0 or c2=1 order by c2 limit 5;
--enable_result_log
--replace_regex /Plan signature: [0-9]*/Plan signature/
--disable_result_log
explain delete from t1 where c2=0 or c2=1 order by pk1 limit 6;
--enable_result_log
--replace_regex /Plan signature: [0-9]*/Plan signature/
--disable_result_log
explain delete from t1 where (c2,c3) in ((1,'2'),(1,'3')) order by c2, c3 limit 7;
--enable_result_log

delete from t1 where pk1=0 or pk1=1 order by pk1 limit 2;
delete from t1 where (pk1,pk2) in ((0,'0'),(0,'1')) order by pk1 limit 3;
delete from t1 where (pk1,pk2) in ((0,'2'),(0,'3'))  order by pk1, pk2 limit 4;
delete from t1 where c2=0 or c2=1 order by c2 limit 5;
delete from t1 where c2=0 or c2=1 order by pk1 limit 6;
delete from t1 where (c2,c3) in ((1,'2'),(1,'3')) order by c2, c3 limit 7;
select * from t1;
rollback;

#### case 5: col like str
