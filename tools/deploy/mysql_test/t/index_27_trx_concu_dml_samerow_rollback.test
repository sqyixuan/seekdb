--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: dachuan.sdc
# owner group: SQL3
# description: OUR GOAL: Make all this simple and effective!
####TITLE:多个事务更新同一行，事务1提交，事务2更新，验证可重复读,查询索引表、数据表、回表
####
--disable_query_log
--source mysql_test/include/index_quick_major.inc
--real_sleep 1
--disable_warnings
drop table if exists t1;
--enable_warnings
--enable_query_log


create table t1(pk int primary key, a int, b int);
create index i1 on t1(b);

--disable_query_log
let $index_name = __idx_3003_i1;
--enable_query_log
--source mysql_test/include/check_all_idx_ok.inc

connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn2,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);

####CASE:多种DML操作同一行,其中1个事务回滚，验证事务可重复读
insert into t1(pk, a, b) values(1,1,1),(2,1,1);

connection conn1;
set autocommit=0;
select pk, b from t1 where b between 0 and 1000;
select pk, a, b from t1 where pk>0 and pk<10;
select * from t1 where b>0 and b<1000;

connection conn2;
set autocommit=0;
update t1 set a=10, b=10 where pk=1;
delete from t1 where pk=2;
insert into t1 values(3,1,1);
replace into t1 values(4,1,1);
rollback;

connection conn1;
update t1 set a=a+100, b=b+100 where pk=1;
update t1 set a=a+100, b=b+100 where pk=2;
update t1 set a=a+100, b=b+100 where pk=3;
update t1 set a=a+100, b=b+100 where pk=4;
select pk, b from t1 where b between 0 and 1000;
select pk, a, b from t1 where pk>0 and pk<10;
select * from t1 where b>0 and b<1000;
commit;

connection conn1;
select pk, b from t1 where b between 0 and 1000;
select pk, a, b from t1 where pk>0 and pk<10;
select * from t1 where b>0 and b<1000;

drop table t1;
