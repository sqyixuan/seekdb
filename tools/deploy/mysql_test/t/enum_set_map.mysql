##################-----abs_result_map----##################
##result type is double
create table test_abs as select abs(c_enum), abs(c_set) from test_enum1;
desc test_abs;
drop table test_abs;

##################-----round_result_map----##################
create table test_ceil as select ceil(c_enum), ceil(c_set),ceil(c_bit), ceil(c_ubigint), round(c_enum), round(c_set),round(c_bit), round(c_ubigint) from test_enum1;
desc test_ceil;
drop table test_ceil;


##################-----fun_not_cal_map----##################
##numberic_value
create table test_not(c1 int, c_enum enum("true", "1", "false", "0"), c_set set("true", "1", "false", "0"));
insert into test_not value (1,1,1),(2,2,2),(3,3,4),(4,4,8);
select c_enum, !c_enum, c_set, !c_set from test_not;
drop table test_not;

