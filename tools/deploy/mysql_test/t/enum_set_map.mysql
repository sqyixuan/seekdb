drop database test_enum_set;
create database test_enum_set;
use test_enum_set;
#----------------------------------------enum------------------------------------------------------------------#
####if enum is expr2, then it will be type VARCHAR except text type,  longtext for texttype
###

create table test_enum1(c_tinyint tinyint, c_smallint smallint, c_mint mediumint, c_int int, c_bigint bigint, c_utinyint tinyint unsigned, c_usmallint smallint  unsigned, c_umint mediumint unsigned, c_uint int unsigned, c_ubigint bigint unsigned, c_float float, c_double double, c_ufloat float unsigned, c_udouble double unsigned, c_dec decimal, c_udec decimal unsigned, c_datetime datetime, c_timestamp timestamp, c_date date, c_time time, c_year year, c_varchar varchar(16), c_char char(16), /* c_tinytext tinytext, c_text text, c_mtext mediumtext, c_ltext longtext,*/ c_bit bit(16), c_enum enum('a', 'b', 'c'), c_set set('a', 'b', 'c'), c_enum_t enum('a', 'b', 'c'));
insert into test_enum1 (c_enum_t) value(1);

select ifnull(null, c_enum_t), 1 in (ifnull(null, c_enum_t)), 'a' in (ifnull(null, c_enum_t)), c_enum_t+1-1, c_enum_t from test_enum1;
select ifnull(c_tinyint, c_enum_t), 1 in (ifnull(c_tinyint, c_enum_t)), 'a' in (ifnull(c_tinyint, c_enum_t)), c_enum_t+1-1, c_enum_t from test_enum1;
select ifnull(c_smallint, c_enum_t), 1 in (ifnull(c_smallint, c_enum_t)), 'a' in (ifnull(c_smallint, c_enum_t)), c_enum_t+1-1, c_enum_t from test_enum1;
select ifnull(c_mint, c_enum_t), 1 in (ifnull(c_mint, c_enum_t)), 'a' in (ifnull(c_mint, c_enum_t)), c_enum_t+1-1, c_enum_t from test_enum1;
select ifnull(c_int, c_enum_t), 1 in (ifnull(c_int, c_enum_t)), 'a' in (ifnull(c_int, c_enum_t)), c_enum_t+1-1, c_enum_t from test_enum1;
select ifnull(c_bigint, c_enum_t), 1 in (ifnull(c_bigint, c_enum_t)), 'a' in (ifnull(c_bigint, c_enum_t)), c_enum_t+1-1, c_enum_t from test_enum1;
select ifnull(c_utinyint, c_enum_t), 1 in (ifnull(c_utinyint, c_enum_t)), 'a' in (ifnull(c_utinyint, c_enum_t)), c_enum_t+1-1, c_enum_t from test_enum1;
select ifnull(c_usmallint, c_enum_t), 1 in (ifnull(c_usmallint, c_enum_t)), 'a' in (ifnull(c_usmallint, c_enum_t)), c_enum_t+1-1, c_enum_t from test_enum1;
