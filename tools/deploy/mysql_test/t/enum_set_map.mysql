create database test_enum_set;
use test_enum_set;

### varchar
create table test_tinyint(c1 int, c2 tinyint);
create table test_smallint(c1 int, c2 smallint);
create table test_mediumint(c1 int, c2 mediumint);
create table test_int(c1 int, c2 int);
create table test_bigint(c1 int, c2 bigint);

create table test_utinyint(c1 int, c2 tinyint unsigned);
create table test_usmallint(c1 int, c2 smallint unsigned);
create table test_umediumint(c1 int, c2 mediumint unsigned);
create table test_uint(c1 int, c2 int unsigned);
create table test_ubigint(c1 int, c2 bigint unsigned);

create table test_float(c1 int, c2 float);
create table test_double(c1 int, c2 double);

create table test_ufloat(c1 int, c2 float unsigned);
create table test_udouble(c1 int, c2 double unsigned);

create table test_number(c1 int, c2 decimal);
create table test_unumber(c1 int, c2 decimal unsigned);

create table test_datetime(c1 int, c2 datetime);
create table test_timestamp(c1 int, c2 timestamp);
create table test_date(c1 int, c2 date);
create table test_time(c1 int, c2 time);
create table test_year(c1 int, c2 year);

create table test_varchar(c1 int, c2 varchar(32));
create table test_char(c1 int, c2 char(32));


