desc test_arith_result_map;

drop table test_arith_result_map;
create table test_arith_result_map as select null+c_enum_t, c_tinyint+c_enum_t, c_smallint+c_enum_t, c_mint+c_enum_t, c_int+c_enum_t, c_bigint+c_enum_t, c_utinyint+c_enum_t, c_usmallint+c_enum_t, c_umint+c_enum_t, c_uint+c_enum_t, c_ubigint+c_enum_t, c_float+c_enum_t, c_double+c_enum_t, c_ufloat+c_enum_t, c_udouble+c_enum_t, c_dec+c_enum_t, c_udec+c_enum_t, c_datetime+c_enum_t, c_timestamp+c_enum_t, c_date +c_enum_t, c_time+c_enum_t, c_year+c_enum_t, c_varchar+c_enum_t, c_char+c_enum_t, /*c_tinytext+c_enum_t, c_text+c_enum_t, c_mtext+c_enum_t, c_ltext+c_enum_t,*/ c_bit+c_enum_t, c_enum+c_enum_t, c_set+c_enum_t from test_enum1;
