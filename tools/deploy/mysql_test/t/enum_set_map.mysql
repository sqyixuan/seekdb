create table test_mod_map as select null%c_set_t, c_tinyint%c_set_t, c_smallint%c_set_t, c_mint%c_set_t, c_int%c_set_t, c_bigint%c_set_t, c_utinyint%c_set_t, c_usmallint%c_set_t, c_umint%c_set_t, c_uint%c_set_t, c_ubigint%c_set_t, c_float%c_set_t, c_double%c_set_t, c_ufloat%c_set_t, c_udouble%c_set_t, c_dec%c_set_t, c_udec%c_set_t, c_datetime%c_set_t, c_timestamp%c_set_t, c_date %c_set_t, c_time%c_set_t, c_year%c_set_t, c_varchar%c_set_t, c_char%c_set_t, /*c_tinytext%c_set_t, c_text%c_set_t, c_mtext%c_set_t, c_ltext%c_set_t,*/ c_bit%c_set_t, c_enum%c_set_t, c_set%c_set_t from test_set1;
desc test_mod_map;

