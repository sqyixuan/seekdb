--source mysql_test/include/backup_spm_var.inc
--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: yuchen.wyc
# owner group: SQL3
# description: 并发replace 
####
--disable_query_log
--source mysql_test/include/index_quick_major.inc
--real_sleep 1
--disable_warnings
drop table if exists test; 
--enable_warnings
--enable_query_log

create table test(pk int primary key, c1 int); 
create unique index i1 on test(c1);       
--source mysql_test/include/check_all_idx_ok.inc

insert into test(pk, c1) values(0,1),(1,2); 
select * from test;

#### case 1, diff rows modify to same value
connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn2,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);

connection conn1;
set autocommit=0;
replace into test(pk, c1) values(0,3); 
select * from test;

connection conn2;
set autocommit=0;
set session ob_query_timeout=500000000;
send replace into test(pk, c1) values(1,3); 

connection conn1;
select * from test;
commit;

connection conn2;
reap;
select * from test;
commit;
select * from test;
select /*+index(test i1)*/ * from test;
commit;

#### case 2, same row modify to diff values
connection conn1;
replace into test(pk, c1) values(0,1),(1,2); 
select * from test;
commit;

connection conn1;
replace into test(pk, c1) values(0,3); 

connection conn2;
send replace into test(pk, c1) values(0,4); 

connection conn1;
commit;

connection conn2;
reap;
commit;

select * from test;
select /*+index(test i1)*/ * from test;
commit;

connection default;
--source mysql_test/include/recover_spm_var.inc
