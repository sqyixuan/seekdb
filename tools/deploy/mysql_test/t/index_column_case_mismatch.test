--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: zhenjiang.xzj
# owner group: storage
# description:

--disable_info
--disable_metadata
--disable_warnings
create database if not exists test;
use test;
drop table if exists t1;
--enable_warnings

create table t1 (c1 varchar(10) primary key, c2 int ,c3 varchar(100), c4 varchar(100));
insert into t1 (c1,c2,c3) values ("H", 1, "hello");
delete from t1 where c1 = "H";
insert into t1 (c1,c2,c3) values ("h", 10, "world");
create unique index ui on t1 (c1, c2 ,c4);
--source mysql_test/include/check_all_idx_ok.inc
select c1 ,c2,c4 from t1;
