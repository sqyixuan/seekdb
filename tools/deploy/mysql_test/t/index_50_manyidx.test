--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: bin.lb
# owner group: SQL3
# description:
# tags: ddl, index
#
--disable_warnings
drop table if exists ttl;
--enable_warnings
create table ttl(i1 int, v2 varchar(80), i3 char(20),i4 float, d4 datetime(6),i5 decimal(5,3), primary key(i1));
    let $cnt2=25;
    while ($cnt2)
    {
    eval create index ttlidx_1$cnt2 on ttl(i1);
    eval create index ttlidx_2$cnt2 on ttl(v2);
    eval create index ttlidx_3$cnt2 on ttl(i3);
    eval create index ttlidx_4$cnt2 on ttl(i3);
    eval create index ttlidx_5$cnt2 on ttl(d4);
    dec $cnt2;
}
 create index ttlidx_126 on ttl(i1);
 create index ttlidx_127cnt2 on ttl(v2);
 create index ttlidx_128cnt2 on ttl(i3);
--error 1069
 create index ttlidx_129cnt2 on ttl(i3);
--disable_query_log
--source mysql_test/include/index_quick_major.inc
--real_sleep 1
--enable_query_log
--echo merge happens
--source mysql_test/include/check_all_idx_ok.inc
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
select count(*)  from oceanbase.__all_virtual_table where table_name like '__idx_%' and index_status!=2;
disconnect obsys;
connection default;
--disable_query_log
     let $cnt4=100;
     while ($cnt4)
{
eval insert into ttl values($cnt4,'now','haha',1.6256,'2014-05-04 12:00:00',-10.235);
dec $cnt4;
}
--enable_query_log
select * from ttl limit 1;
select * from ttl where i1=1;
update ttl set i1=400 where i1=10;
delete from ttl where i1=11;
delete from ttl where i1>=11 and i1<=20;
select * from ttl where i1>=11 and i1<=20;
select * from ttl where i1>=21 and i1<=30;
