--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: link.zt
# owner group: SQL1
# tags: optimizer
# description: 

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1(a int, b int, c int, key idx_b(b), key idx_c(c));
# test comment before hint
explain select * from t1 where b = 1;
explain select /*+index(t1 idx_c)*/* from t1 where b = 1;
explain select /*abcd*/ /*+index(t1 idx_c)*/* from t1 where b = 1;
--error 1064
explain select /*ab*/cd*/ /*+index(t1 idx_c)*/* from t1 where b = 1;
explain select /*ab*cd*/ /*+index(t1 idx_c)*/* from t1 where b = 1;
explain select /*ab/cd*/ /*+index(t1 idx_c)*/* from t1 where b = 1;
explain select /*ab*/ /*cd*/ /*+index(t1 idx_c)*/* from t1 where b = 1;
explain select /*ab/*+index(t1 idx_c)*/* from t1 where b = 1;

# test comment after hint
explain select /*+index(t1 idx_c)*/ /*abc*/* from t1 where b = 1;
explain select /*+index(t1 idx_c)*/ /*ab*c*/* from t1 where b = 1;
explain select /*+index(t1 idx_c)*/ /*ab/c*/* from t1 where b = 1;
explain select /*+index(t1 idx_c)*/ /*abc*/ /*abcd*/* from t1 where b = 1;
--error 1064
explain select /*+index(t1 idx_c)*/ /*a*/bc*/ /*abcd*/* from t1 where b = 1;

#test comment before and after hint
explain select /*abcd*/ /*+index(t1 idx_c)*/ /*abc*/* from t1 where b = 1;
explain select /*abcd*/ /*abcd*/ /*+index(t1 idx_c)*/ /*abc*/ /*abcd*/* from t1 where b = 1;
--error 1064
explain select /*ab*/cd*/ /*abcd*/ /*+index(t1 idx_c)*/ /*abc*/ /*abcd*/* from t1 where b = 1;
#test space between multiple hint
#hint works
explain select /*abcd*/ /*+index(t1 idx_c)*/* from t1 where b = 1;
explain select /*abcd*//*abcd*/ /*+index(t1 idx_c)*/* from t1 where b = 1;
explain select /*+index(t1 idx_c)*//*abcd*/* from t1 where b = 1;
explain select /*+index(t1 idx_c)*/ /*abcd*/* from t1 where b = 1;
#hint works in here, but will not work in mysql client
explain select /*abcd*//*+index(t1 idx_c)*/* from t1 where b = 1;
explain select /*abcd*//*abcd*//*+index(t1 idx_c)*/* from t1 where b = 1;

#test comment and hint in subqueries
explain select r.a from (select /*abcd*/ /*+index(t1 idx_c)*/* from t1 where b = 1 group by a) as r;
explain select r.a from (select /*abcd*//*abcd*/ /*+index(t1 idx_c)*/* from t1 where b = 1 group by a) as r;
explain select r.a from (select /*+index(t1 idx_c)*//*abcd*/* from t1 where b = 1 group by a) as r;
explain select r.a from (select /*+index(t1 idx_c)*/ /*abcd*/* from t1 where b = 1 group by a) as r;
#hint works in here, but will not work in mysql client
explain select r.a from (select /*abcd*//*+index(t1 idx_c)*/* from t1 where b = 1 group by a) as r;
explain select r.a from (select /*abcd*//*abcd*//*+index(t1 idx_c)*/* from t1 where b = 1 group by a) as r;

