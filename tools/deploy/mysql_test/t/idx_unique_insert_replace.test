--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: dachuan.sdc
# owner group: SQL3
# description: 本case是为了加上唯一索引后的insert/replace语句；
# 好奇：为什么NULL值不会引起唯一索引冲突(同mysql)

####test:bug 1043200
connect (admin,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection admin;
alter system set merger_check_interval= '10s';
--disable_warnings
connection default;
drop table if exists test;
--enable_warnings
create table test(pk1 int primary key, c1 int , c2 int);
create unique index i1 on test(c2);
--source mysql_test/include/check_all_idx_ok_unq.inc
--source mysql_test/include/check_all_idx_ok.inc

connection admin;

let $idx1 = query_get_value(select a.table_name from oceanbase.__all_virtual_table as a inner join (select * from oceanbase.__all_virtual_table where table_name='test') b on a.data_table_id=b.table_id, table_name, 1);

connection default;

insert into test(pk1, c1) values(0,0);
insert into test(pk1, c1) values(1,1);
replace into test(pk1, c1) values(1,1);    
select * from test;
--disable_query_log
set ob_enable_index_direct_select=1;
eval select * from $idx1;
--enable_query_log
