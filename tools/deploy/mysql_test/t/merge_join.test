--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
##test primary key
# owner: link.zt
# owner group: sql1
# tags: optimizer
# description: merge join test case

--disable_warnings
drop table if exists BB, C, t1, t2, t3, t4, t7, t8, t9, t10, t11, t12;
--enable_warnings

CREATE TABLE `BB` (
    `col_datetime` datetime DEFAULT NULL,
    `pk` int(11) NOT NULL,
    `col_varchar_20_key` varchar(20) DEFAULT NULL,
    `col_varchar_10_key` varchar(10) DEFAULT NULL,
    `col_int_key` int(11) DEFAULT NULL,
    `col_varchar_20` varchar(20) DEFAULT NULL,
    `col_date` date DEFAULT NULL,
    `col_date_key` date DEFAULT NULL,
    `col_varchar_10` varchar(10) DEFAULT NULL,
    `col_int` int(11) DEFAULT NULL,
    `col_datetime_key` datetime DEFAULT NULL,
    PRIMARY KEY (`pk`),
    KEY `idx5` (`col_varchar_20_key`) BLOCK_SIZE 16384,
    KEY `idx3` (`col_varchar_10_key`) BLOCK_SIZE 16384,
    KEY `idx1` (`col_int_key`) BLOCK_SIZE 16384,
    KEY `idx7` (`col_date_key`) BLOCK_SIZE 16384,
    KEY `idx9` (`col_datetime_key`) BLOCK_SIZE 16384 )
DEFAULT CHARSET = utf8mb4 COMPRESSION = 'lz4_1.0' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 10;

CREATE TABLE `C` (
    `col_varchar_20_key` varchar(20) DEFAULT NULL,
    `col_datetime` datetime DEFAULT NULL,
    `col_int` int(11) DEFAULT NULL,
    `col_date` date DEFAULT NULL,
    `pk` int(11) NOT NULL,
    `col_datetime_key` datetime DEFAULT NULL,
    `col_varchar_20` varchar(20) DEFAULT NULL,
    `col_varchar_10_key` varchar(10) DEFAULT NULL,
    `col_varchar_10` varchar(10) DEFAULT NULL,
    `col_int_key` int(11) DEFAULT NULL,
    `col_date_key` date DEFAULT NULL,
    PRIMARY KEY (`pk`),
    KEY `idx5` (`col_varchar_20_key`) BLOCK_SIZE 16384,
    KEY `idx9` (`col_datetime_key`) BLOCK_SIZE 16384,
    KEY `idx3` (`col_varchar_10_key`) BLOCK_SIZE 16384,
    KEY `idx1` (`col_int_key`) BLOCK_SIZE 16384,
    KEY `idx7` (`col_date_key`) BLOCK_SIZE 16384 ) DEFAULT CHARSET = utf8mb4 COMPRESSION = 'lz4_1.0' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 10;

--echo # bug 13617288
explain SELECT /*+ use_merge(OUTR)*/ COUNT(DISTINCT OUTR . `col_int_key` ) AS X FROM C AS OUTR2 LEFT JOIN C AS OUTR ON ( OUTR2 . `col_varchar_10_key` > OUTR . `col_varchar_10_key` ) WHERE OUTR . `pk` IN ( SELECT DISTINCT INNR . `pk` AS Y FROM BB AS INNR WHERE INNR . `col_int_key` = INNR . `pk` AND NOT OUTR . `pk` IS NULL ORDER BY INNR . `col_int_key` ) AND OUTR . `col_varchar_10_key` IS NOT NULL ORDER BY OUTR . `col_int` , OUTR . `pk`;

create table t1 (c1 int, c2 int, primary key(c1, c2));
create table t2 (d1 int);

explain select /*+ use_merge(t1 t2) */ * from t1, t2 where c1 = d1 and c1 = c2;

--echo # bug 14255747
create table t3 (a int, b int, c int, primary key (a, b));
create table t4 (a int, b int, c int, primary key (a, b));

create table t7 (a int, b int, c int, d int, primary key (a, b, c)) partition by hash(a) partitions 4;
create table t8 (a int, b int, c int, d int, primary key (a, b, c)) partition by hash(a) partitions 4;

--echo # left  ordering: (t5.a, t5.b)
--echo # right ordering: (t6.a, t6.b)
--echo # sort both sides.
explain select /*+ use_merge(t5 t6) */ * from t3 as t5, t3 as t6 where t5.b = t6.b;

--echo # left  ordering: (t5.a, t5.b)
--echo # right ordering: (t6.a, t6.b)
--echo # no need to sort.
explain select /*+ use_merge(t5 t6) */ * from t3 as t5, t3 as t6 where t5.a = t6.a;

--echo # left  ordering: (t5.a, t5.b)
--echo # right ordering: (t6.a, t6.b)
--echo # need ordering : (a, c)
--echo # sort both sides.
explain select /*+ leading(t5 t6) use_merge(t5 t6) */ * from t3 as t5, t3 as t6 where t5.a = t6.a and t5.c = t6.c;

--echo # left  ordering: (t5.a, t5.b)
--echo # right ordering: (t6.a, t6.b)
--echo # need ordering : (a, c[C])
--echo # no need to sort.
explain select /*+ leading(t5 t6) use_merge(t5 t6) */ * from t3 as t5, t3 as t6 where t5.a = t6.a and t5.c = t6.c and t5.c = 3;

--echo # left  ordering: (t5.a, t5.b)
--echo # right ordering: (t6.a, t6.b)
--echo # need ordering : (a, c)
--echo # sort both sides
explain select /*+ leading(t5 t6) use_merge(t5 t6) */ * from t3 as t5, t3 as t6 where t5.a = t6.a and t5.c = t6.c;

--echo # left  ordering: (t5.a[C], t5.b)
--echo # right ordering: (t6.a[C], t6.b)
--echo # no need to sort
explain select /*+ use_merge(t5 t6) */ * from t3 as t5, t3 as t6 where t5.a = 1 and t6.a = 1 and t5.b = t6.b;

--echo # left  ordering: (t7.a[C], t7.b[C], t7.c)
--echo # right ordering: (t8.a[C], t8.b[C], t8.c)
--echo # no need to sort
explain select /*+ use_merge(t7 t8) */ * from t7, t8 where t7.a = 1 and t8.a = 1 and t7.b = t8.b;

--echo # left  ordering: (t7.a, t7.b[C], t7.c)
--echo # right ordering: (t8.a, t8.b[C], t8.c)
--echo # no need to sort
explain select /*+ use_merge(t7 t8) */ * from t7, t8 where t7.b = 1 and t8.b = 1 and t7.a = t8.a and t7.c = t8.c;

--echo # left  ordering: (t3.a[C], t3.b)
--echo # right ordering: (t4.a, t4.b)
--echo # sort t4
explain select /*+ leading(t3 t4) use_merge(t3 t4) */ * from t3, t4 where t3.a = 1 and t3.b = t4.b;

--echo # left  ordering: (t7.a, t7.b[C], t7.c)
--echo # right ordering: (t8.a, t8.b[C], t8.c)
--echo # left outer join can be transformed to inner join, no need to sort
explain select /*+ use_merge(t7 t8) */ * from t7 left join t8 on t7.b = t8.b where t7.b = 1 and t8.b = 1;

--echo # left  ordering: (t7.a, t7.b[C], t7.c)
--echo # right ordering: (t8.a, t8.b[C], t8.c)
--echo # left outer join can be transformed to inner join, no need to sort
explain select /*+ use_merge(t7 t8) */ * from t7 left join t8 on t7.b = t8.b where t7.b = 1 and t8.b = 2;

--echo # left  ordering: (t7.a, t7.b[C], t7.c)
--echo # right ordering: (t8.a, t8.b[DEDUCE -> C], t8.c)
--echo # left outer join, no need to sort
explain select /*+ use_merge(t7 t8) */ * from t7 left join t8 on t7.b = t8.b where t7.b = 1 and t8.b is NULL;

--echo # left  ordering: (t7.a, t7.b[DEDUCE -> C], t7.c)
--echo # right ordering: (t8.a, t8.b[C], t8.c)
--echo # right outer join, no need to sort
explain select /*+ use_merge(t7 t8) */ * from t7 right join t8 on t7.b = t8.b where t7.b is NULL and t8.b = 5;

--echo # left  ordering: (t7.a, t7.b, t7.c)
--echo # right ordering: (t8.a, t8.b, t8.c)
--echo # full outer join, sort both sides
explain select /*+ use_merge(t7 t8) */ * from t7 right join t8 on t7.b = t8.b where t7.b is NULL and t8.b is NULL;

create table t9 (a int, b int, c int, d int, primary key (a, b, c)) partition by hash(a) partitions 4;
create table t10 (a int, b int, c int, d int, primary key (a, b, c)) partition by hash(a) partitions 9;

--echo # left  ordering: (t9.a[C], t9.b[C], t9.c)
--echo # right ordering: (t10.a[C], t10.b[C], t10.c)
--echo # no need to sort
explain select /*+ use_merge(t9 t10) */ * from t9, t10 where t9.a = 1 and t10.a = 1 and t9.b = t10.b;

--echo # left  ordering: (t9.a, t9.b[C], t9.c)
--echo # right ordering: (t10.a, t10.b[C], t10.c)
--echo # no need to sort
explain select /*+ use_merge(t9 t10) */ * from t9, t10 where t9.b = 1 and t10.b = 1 and t9.a = t10.a and t9.c = t10.c;

--echo # left  ordering: (t3.a[C], t3.b)
--echo # right ordering: (t4.a, t4.b)
--echo # sort t4
explain select /*+ leading(t3 t4) use_merge(t3 t4) */ * from t3, t4 where t3.a = 1 and t3.b = t4.b;

--echo # left  ordering: (t9.a, t9.b[C], t9.c)
--echo # right ordering: (t10.a, t10.b[C], t10.c)
--echo # left outer join can be transformed to inner join, no need to sort
explain select /*+ use_merge(t9 t10) */ * from t9 left join t10 on t9.b = t10.b where t9.b = 1 and t10.b = 1;

--echo # left  ordering: (t9.a, t9.b[C], t9.c)
--echo # right ordering: (t10.a, t10.b[C], t10.c)
--echo # left outer join can be transformed to inner join, no need to sort
explain select /*+ use_merge(t9 t10) */ * from t9 left join t10 on t9.b = t10.b where t9.b = 1 and t10.b = 2;

--echo # left  ordering: (t9.a, t9.b[C], t9.c)
--echo # right ordering: (t10.a, t10.b[DEDUCE -> C], t10.c)
--echo # left outer join, sort t10
explain select /*+ use_merge(t9 t10) */ * from t9 left join t10 on t9.b = t10.b where t9.b = 1 and t10.b is NULL;

--echo # left  ordering: (t9.a, t9.b, t9.c)
--echo # right ordering: (t10.a, t10.b, t10.c)
--echo # right outer join, sort t9
explain select /*+ use_merge(t9 t10) */ * from t9 right join t10 on t9.b = t10.b where t9.b is NULL and t10.b = 5;

--echo # left  ordering: (t9.a, t9.b, t9.c)
--echo # right ordering: (t10.a, t10.b, t10.c)
--echo # full outer join, sort both sides
explain select /*+ use_merge(t9 t10) */ * from t9 right join t10 on t9.b = t10.b where t9.b is NULL and t10.b is NULL;

create table t11 (a int, b int, c int, d int, primary key (a, b, c)) partition by hash(a) partitions 4;
create table t12 (a int, b int, c int, d int, primary key (a, b, c)) partition by hash(a) partitions 9;

--echo # left  ordering: (t11.a[C], t11.b[C], t11.c)
--echo # right ordering: (t12.a[C], t12.b[C], t12.c)
--echo # no need to sort
explain select /*+ use_merge(t11 t12) */ * from t11, t12 where t11.a = 1 and t12.a = 1 and t11.b = t12.b;

--echo # left  ordering: (t11.a, t11.b[C], t11.c)
--echo # right ordering: (t12.a, t12.b[C], t12.c)
--echo # no need to sort
explain select /*+ use_merge(t11 t12) */ * from t11, t12 where t11.b = 1 and t12.b = 1 and t11.a = t12.a and t11.c = t12.c;

--echo # left  ordering: (t3.a[C], t3.b)
--echo # right ordering: (t4.a, t4.b)
--echo # sort t4
explain select /*+ leading(t3 t4) use_merge(t3 t4) */ * from t3, t4 where t3.a = 1 and t3.b = t4.b;

--echo # left  ordering: (t11.a, t11.b[C], t11.c)
--echo # right ordering: (t12.a, t12.b[C], t12.c)
--echo # left outer join can be transformed to inner join, no need to sort
explain select /*+ use_merge(t11 t12) */ * from t11 left join t12 on t11.b = t12.b where t11.b = 1 and t12.b = 1;

--echo # left  ordering: (t11.a, t11.b[C], t11.c)
--echo # right ordering: (t12.a, t12.b[C], t12.c)
--echo # left outer join can be transformed to inner join, no need to sort
explain select /*+ use_merge(t11 t12) */ * from t11 left join t12 on t11.b = t12.b where t11.b = 1 and t12.b = 2;

--echo # left  ordering: (t11.a, t11.b[C], t11.c)
--echo # right ordering: (t12.a, t12.b[DERIVE -> C], t12.c)
--echo # left outer join, no need to sort
explain select /*+ use_merge(t11 t12) */ * from t11 left join t12 on t11.b = t12.b where t11.b = 1 and t12.b is NULL;

--echo # left  ordering: (t11.a, t11.b[DERIVE -> C], t11.c)
--echo # right ordering: (t12.a, t12.b[C], t12.c)
--echo # right outer join, no need to sort
explain select /*+ use_merge(t11 t12) */ * from t11 right join t12 on t11.b = t12.b where t11.b is NULL and t12.b = 5;

--echo # left  ordering: (t11.a, t11.b, t11.c)
--echo # right ordering: (t12.a, t12.b, t12.c)
--echo # full outer join, sort both sides
explain select /*+ use_merge(t11 t12) */ * from t11 right join t12 on t11.b = t12.b where t11.b is NULL and t12.b is NULL;

--disable_warnings
drop table if exists BB, C, t1, t2, t3, t4, t5, t7, t8, t9, t10, t11, t12;
--enable_warnings

create table T1 (T1c1 INTEGER(127) ,T1c2 TIME,T1c3 YEAR(4) , primary key(T1c2)) ;
create table T2 (T2c1 TINYINT(127) ,T2c2 MEDIUMINT(127) ,T2c3 VARCHAR(86) ,T2c4 CHAR(152) ,T2c5 TIME, primary key(T2c1)) ;
create table T3 (T3c1 TIME,T3c2 INT(127) ,T3c3 CHAR(152) ,T3c4 BIGINT(127) ,T3c5 CHAR(152) ,T3c6 MEDIUMINT(127) ,T3c7 BIGINT(127) ,T3c8 TINYINT(127) ,T3c9 TINYINT(127) , unique(T3c2), foreign key(T3c8)  references T2 (T2c1), foreign key(T3c9)  references T2 (T2c1)) PARTITION BY HASH(T3c2) PARTITIONS 5;
create table T4 (T4c1 TIME,T4c2 TIME as (T4c1) virtual ,T4c3 DECIMAL(64,20) ,T4c4 YEAR(4) ,T4c5 TINYINT(127) ,T4c6 NUMERIC(64,27) ,T4c7 YEAR(4) ,T4c8 MEDIUMINT(127) ,T4c9 SMALLINT(127) ,T4c10 MEDIUMINT(127) ,T4c11 TIME,T4c12 DATE,T4c13 DECIMAL(64,8) ,T4c14 TIME,T4c15 CHAR(152) ,T4c16 INT(127) , primary key(T4c1)) ;
create table T5 (T5c1 DATE,T5c2 TIME,T5c3 MEDIUMINT(127) ,T5c4 INT(127) , primary key(T5c1)) ;

INSERT IGNORE INTO T1(T1c1,T1c2,T1c3) values (18594,'16:26:4',1976);
