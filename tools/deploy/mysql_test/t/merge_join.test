INSERT IGNORE INTO T4(T4c1,T4c3,T4c4,T4c5,T4c6,T4c7,T4c8,T4c9,T4c10,T4c11,T4c12,T4c13,T4c14,T4c15,T4c16) values ('1:2:7',38660.01,1970,95,685.90000000000,1961,15238,26085,21369,'4:25:12',date'2003-11-4',27838.38514673,'8:50:43','nN',25924);
INSERT IGNORE INTO T5(T5c1,T5c2,T5c3,T5c4) values (date'2050-8-24','8:28:28',27255,25924);

select  /*+
      LEADING(@"SEL$0208448F" ("test"."t5"@"SEL$1" ("test"."t4"@"SEL$1" ("test"."t1"@"SEL$1" ("test"."t2"@"SEL$1" "test"."t3"@"SEL$1")))))
      USE_MERGE(@"SEL$0208448F" ("test"."t3"@"SEL$1" "test"."t2"@"SEL$1" "test"."t1"@"SEL$1"))
*/ T1c1,T1c2,T1c3,T2c1,T2c2,T2c3,T2c4,T2c5,T3c1,T3c2,T3c3,T3c4,T3c5,T3c6,T3c7,T3c8,T3c9,T4c1,T4c2,T4c3,T4c4,T4c5,T4c6,T4c7,T4c8,T4c9,T4c10,T4c11,T4c12,T4c13,T4c14,T4c15,T4c16,T5c1,T5c2,T5c3,T5c4 from T1,T2,T3,T4,T5 where T2c5 = T1c2 AND T3c8 = T2c1 AND T3c9 = T2c1 AND T4c16 = T3c2 AND T5c4 = T3c2;

explain select  /*+
      LEADING(@"SEL$0208448F" ("test"."t5"@"SEL$1" ("test"."t4"@"SEL$1" ("test"."t1"@"SEL$1" ("test"."t2"@"SEL$1" "test"."t3"@"SEL$1")))))
      USE_MERGE(@"SEL$0208448F" ("test"."t3"@"SEL$1" "test"."t2"@"SEL$1" "test"."t1"@"SEL$1"))
*/ T1c1,T1c2,T1c3,T2c1,T2c2,T2c3,T2c4,T2c5,T3c1,T3c2,T3c3,T3c4,T3c5,T3c6,T3c7,T3c8,T3c9,T4c1,T4c2,T4c3,T4c4,T4c5,T4c6,T4c7,T4c8,T4c9,T4c10,T4c11,T4c12,T4c13,T4c14,T4c15,T4c16,T5c1,T5c2,T5c3,T5c4 from T1,T2,T3,T4,T5 where T2c5 = T1c2 AND T3c8 = T2c1 AND T3c9 = T2c1 AND T4c16 = T3c2 AND T5c4 = T3c2;

drop table if exists t1, t2, t3, t4, t5;