let $query_stmt=show character set;
--source mysql_test/include/found_rows.inc
let $query_stmt=show collation;
--source mysql_test/include/found_rows.inc
let $query_stmt=show collation where `Default`='Yes';
--source mysql_test/include/found_rows.inc
let $query_stmt=show columns from test;
--source mysql_test/include/found_rows.inc
##let $query_stmt=show CONTRIBUTORS;
##--source mysql_test/include/found_rows.inc
let $query_stmt=show create database found_rows;
--source mysql_test/include/found_rows.inc
let $query_stmt=show create schema found_rows;
--source mysql_test/include/found_rows.inc

