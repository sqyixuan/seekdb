--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: peihan.dph
# owner group: SQL3
# description: 本case是为了测试各种show语句对found_rows的影响；
# 在OB实现中，所有的show语句在resolve完以后都变成select语句了；
# 但是在mysql中，有部分show语句不是以select的方式完成的，比如show warnings/show errors等；

# 在OB实现中，所有的show语句在resolve完以后都变成select语句了；
# 但是在mysql中，有部分show语句不是以select的方式完成的，比如show warnings/show errors等；

#tags: found_rows

--disable_warnings
drop database if exists found_rows;
drop table if exists test;
--enable_warnings
--disable_query_log
create database found_rows;
use found_rows;
create table test(c1 int, c2 int);
--enable_query_log
create table test2(c1 int, c2 int);
--disable_query_log
insert into test values(1,2),(2,3),(3,4),(4,5);
--disable_query_log
--disable_result_log
select * from test;
select found_rows();
--enable_result_log
let $select_example=select * from test;
let $expect=4;

let $query_stmt=show databases;
--source mysql_test/include/found_rows.inc
let $query_stmt=show create table test;
--source mysql_test/include/found_rows.inc
let $query_stmt=show tables;
--source mysql_test/include/found_rows.inc

#create trigger tr after insert on test for each row delete from test;
#let $query_stmt=show create TRIGGER tr;
