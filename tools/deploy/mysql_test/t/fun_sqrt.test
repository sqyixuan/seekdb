--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: link.zt
# owner group: SQL1
# Test of sqrt function


#### sqrt 表达式
select sqrt(4);
select sqrt(16);
select sqrt(1);
select sqrt(1.44);
select sqrt(0.04);
select sqrt(0.09);
select sqrt(0);
select sqrt(100.0);
select sqrt(1.2);
select sqrt(-1);
select sqrt(sqrt(16));
select sqrt(sqrt(sqrt(256)));
select sqrt(sqrt(3) * sqrt(3) * sqrt(3) * sqrt(3));
select sqrt(true);
select sqrt(null);

### 包含字符相关的函数
select sqrt(length('aggfagdf')-length('35q45q45tdgtsrfg'));
select sqrt(length(substr('35q45q45tdgtsrfg',1,5)));
select sqrt(0-length(substr('35q45q45tdgtsrfg',1,5))); 

##对十六进行进行sqrt
select sqrt(hex('0x3'));
select sqrt(hex('0X3'));

##运算
select sqrt(2) * -2;
###加别名
SELECT sqrt(1.0) AS "1.0的平方根",sqrt(0.0) AS "0.0的平方根",sqrt(-1.0) AS "-1.0的平方根";
###from dual
SELECT sqrt(17.36) from dual;
SELECT sqrt(-10) from dual;

####sqrt 类型转换
select sqrt('1');
select sqrt('100');
select sqrt('-100');
select sqrt('-100.001');
select sqrt(cast(1.21 as decimal(10,5)));
select sqrt(cast(1.21 as char(10)));
select sqrt(cast(1.21 as decimal(5,3)));
select sqrt(true);
select sqrt(true);
select sqrt(false);
select sqrt(ROW(1,2)<ROW(1, 3));

####sqrt 不合法类型
## ob 暂时不抛出warnings
select sqrt('abcd');
select sqrt('2014-10-09 10:00:00');
select sqrt(10e1);

### sqrt 不合法的参数个数
--error 1582 
select sqrt(1,-2);
--error 1241
select sqrt(ROW(1,2));

#### 边界值
select sqrt(10/0);
select sqrt(-9223372036854775808);
select sqrt(-9999999999999999999999);
select sqrt(9999999999999999999999);
select sqrt(repeat('1',100));
select sqrt(repeat('1',46));
select sqrt(0-repeat('1',46));

#### 表相关
--disable_warnings
drop table if exists tbl1;
--enable_warnings
create table tbl1 (i1 int, v2 varchar(80), i3 char(20),i4 float, d4 datetime(6),i5 decimal(5,3), primary key(i1));

insert into tbl1 values(1,'now','haha1',1.6256,'2014-05-04 12:00:00',-10.235);
insert into tbl1 values(2,'now','haha2',-1.6256,'2014-05-04 12:00:00',1.243);
insert into tbl1 values(3,'now','haha3',1.156,'2014-05-04 12:00:00',-1.45);
insert into tbl1 values(4,'now','haha1',5.9256,'2014-05-04 12:00:00',3.45);
insert into tbl1 values(5,'now1','haha2',1.2356,'2014-05-04 12:00:00',-0.25);
insert into tbl1 values(6,'now2','haha3',-10.4256,'2014-05-04 12:00:00',0.253);
insert into tbl1 values(7,'now3','haha4',0.6256,'2014-05-04 12:00:00',1.677);

select sqrt(i4) from tbl1;
select * from tbl1 where sqrt(i4) <= 2;
select sqrt(i1/10*8),i1/10*8 from tbl1;
select * from tbl1 order by sqrt(i4);
select * from tbl1 order by sqrt(i4) desc;

--disable_warnings
drop table if exists tbl2;
--enable_warnings
create table tbl2 (i1 int, v2 varchar(80), primary key(i1));

insert into tbl2 values(1,'1');
insert into tbl2 values(2,'2.5');
insert into tbl2 values(3,'-3.2');

select sqrt(v2) from tbl2;


