select sqrt(pk), sqrt(c1), sqrt(c2), sqrt(c3), sqrt(c4), sqrt(c5), sqrt(c6), sqrt(c7), sqrt(c8), sqrt(c9), sqrt(c10), sqrt(c11), sqrt(c12), sqrt(c13), sqrt(c14), sqrt(c15), sqrt(c16), sqrt(c22), sqrt(c23), sqrt(c24), sqrt(c25) from test;

