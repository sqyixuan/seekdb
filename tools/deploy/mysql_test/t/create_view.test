connection default;
create view v3 as select c1, c2 from t1;
connection obsys;
eval select table_name, view_definition, view_check_option, view_is_updatable from oceanbase.__all_virtual_table where table_name='v3' order by schema_version desc limit 1; 
connection default;
create view v4 as select c1, c2, c3, c4 + 1 from t1;
