--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: link.zt
# owner group: SQL1
# 验证bug16451473的修改, 为minus/except/intersect的结果正确性验证

--disable_warnings
drop database if exists set_operation_bug_db;
--enable_warnings
create database set_operation_bug_db;
use set_operation_bug_db;

--result_format 4

create table s1(c int);
create table s2(d int);
insert into s1 values(null);
commit;
--echo #1 最简重现
# 1 row, was 0
select * from s1 except select * from s2;
# 1 row, was 0
select * from s1 minus select * from s2;
insert into s2 values(null);
# 1 row, was 0
select * from s1 intersect select * from s2;
# 1 row
select * from s1 union select * from s2;
# 2 rows
select * from s1 union all select * from s2;

--echo #2, 数据稍微复杂一些
create table t11(c1 int, c2 int, c3 int);
create table t22(d1 int, d2 int, d3 int);
insert into t11 values (null,null,null);
insert into t11 values (null,null,null);
insert into t11 values (1,2,3);
insert into t11 values (1,2,3);
insert into t11 values (11,22,33);
insert into t11 values (10,20,30);
insert into t22 values (null, 2, null);
insert into t22 values (10,20,30);
insert into t22 values (20,20,30);
insert into t22 values (4, 5, 6);
insert into t22 values (11,20,30);
insert into t22 values (1,null,null);
commit;

# 3 rows
select * from t11 minus select * from t22 order by 1,2,3;

# 5 rows
select * from t22 except select * from t11 order by 1,2,3;

# 0 row
select c1 from t11 minus select d1 from t22;

# 1 row
select c1 from t11 minus select d1 from t22 where d1 is not null;

# 6 rows
select c1 from t11 union select d1 from t22 where d1 is not null order by 1;

#3 ,22
select count(*), sum(c1) from (select c1 from t11 intersect select d1 from t22 where d1 is not null);

--echo #3, 数据类型较复杂
create table ta1(c1 char(20), c2 number(10), c3 float, c4 int, c5 varchar(100));
insert into ta1 values('1111#', 4444.55, 1.2, 111, '2018-8-1 14:05.00');
insert into ta1 values('1111#', 4444.55, 1.2, 111, '2018-8-1 14:05.00');
insert into ta1 values('2222#', 4444.66, 12, 1, '2018-6-1 14:05.00');
insert into ta1 values('', 4444.55, 1.2, 5, '2018-3-1 14:05.00');
insert into ta1 values('', 4444.55, 1.2, 5, '2018-3-1 14:05.00');
insert into ta1 values('', null, 1.2, 8, null);
insert into ta1 values('', null, 1.2, 18, null);
insert into ta1 values('x', null, 12, 58, null);
insert into ta1 values(null, null, null, null, null);
insert into ta1 values(null, null, null, null, null);
commit;

select * from ta1 x minus select * from ta1 y;
select * from ta1 x minus select * from ta1 y where c4 < 58 or c4 is null;
select * from ta1 x where length(c1)+c2+c3+c4 is null or c5 is null minus select * from ta1 y ;
select * from ta1 x where c2+c3+c4 is not null minus select * from ta1 y where c2+c3+c4 is not null;

select * from (
(select * from ta1 x intersect select * from ta1 y) union all
(select * from ta1 x intersect select * from ta1 y where c4 < 58 or c4 is null 
  minus
select * from ta1 x where length(c1)+c2+c3+c4 is null or c5 is null intersect select * from ta1 y) 
 minus
(select * from ta1 x where c2+c3+c4 is not null union select * from ta1 y where c2+c3+c4 is not null)
)
order by 1,2,3,4,5;

drop database set_operation_bug_db;
