# owner: xiaoyi.xy
# owner group: SQL3


--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
set @@recyclebin = on;
--enable_query_log

create database if not exists drop_index_test;
use drop_index_test;
--disable_warnings
drop table if exists test;
--enable_warnings

purge recyclebin;

# 执行创建表，创建索引test1_index和test2_index，将test1_index放入回收站，主要测试是否成功设置INVISIBLE，放入回收站是否成功
--echo // 执行创建表，创建索引test1_index和test2_index，将test1_index放入回收站，主要测试是否成功设置INVISIBLE，放入回收站是否成功
create table test(c1 int primary key, c2 int, c3 int);
show index from test;
create index test1_index on test(c2);
create index test2_index on test(c3);
--source mysql_test/include/check_all_idx_ok.inc
show index from test;
drop index test1_index on test;
--source mysql_test/include/check_all_idx_ok.inc
show index from test;
select count(*) FROM oceanbase.DBA_RECYCLEBIN;

# 执行flashback操作，查看flashback后的index是否为visible
# --echo // 执行flashback操作，查看flashback后的index是否为visible
# let $name = query_get_value(select OBJECT_NAME FROM oceanbase.DBA_RECYCLEBIN, OBJECT_NAME, 1);
# --echo // flashback index test1_index to before drop;
# --disable_query_log
# eval flashback index $name to before drop;
# --enable_query_log
# show index from test;

# 执行purge操作，查看puerge操作是否正常
# --echo // 执行purge操作，查看puerge操作是否正常
# drop index test1_index on test;
# let $name = query_get_value(select OBJECT_NAME FROM oceanbase.DBA_RECYCLEBIN, OBJECT_NAME, 1);
# --echo // purge index test1_index;
# --disable_query_log
# eval purge index $name;
# --enable_query_log
# show recyclebin;
create index test1_index on test(c2);
--source mysql_test/include/check_all_idx_ok.inc
show index from test;

# 先drop index，再drop table，然后查看flashback是否正常
--echo // 先drop index，再drop table，然后查看flashback是否正常
drop index test1_index on test;
drop table test;
show tables;
let $name = query_get_value(select MAX(OBJECT_NAME) OBJECT_NAME FROM oceanbase.DBA_RECYCLEBIN where TYPE = 'TABLE' and ORIGINAL_NAME = 'test', OBJECT_NAME, 1);
--echo // flashback table test to before drop;
--disable_query_log
eval flashback table $name to before drop;
--enable_query_log
--source mysql_test/include/check_all_idx_ok.inc
show index from test;
select count(*) FROM oceanbase.DBA_RECYCLEBIN;

# index1_test在回收站，drop table，然后purge table查看是否清除干净
--echo // index1_test在回收站，drop table，然后purge table查看是否清除干净
drop table test;
let $name = query_get_value(select MAX(OBJECT_NAME) OBJECT_NAME FROM oceanbase.DBA_RECYCLEBIN where TYPE = 'TABLE' and ORIGINAL_NAME = 'test', OBJECT_NAME, 1);
--echo // purge table test; 
--disable_query_log
eval purge table $name;
--enable_query_log
show tables;
show recyclebin;

# 先drop index，再truncate table，查看是否显示正常
--echo // 先drop index，再truncate table，查看是否显示正常
create table test(c1 int primary key, c2 int, c3 int);
create index test1_index on test(c2);
create index test2_index on test(c3);
insert into test values(1, 2, 3);
insert into test values(2, 3, 4);
insert into test values(3, 4, 5);
drop index test1_index on test;
truncate table test;
--source mysql_test/include/check_all_idx_ok.inc
show index from test;
# 回收站中应该显示两个被drop的index和一个table
select count(*) FROM oceanbase.DBA_RECYCLEBIN;
drop table test;
purge recyclebin;
show tables;
show recyclebin;

# 关闭ob_enable_truncate_flashback，看tuncate table的行为
--echo // 关闭ob_enable_truncate_flashback，看tuncate table的行为
set @@ob_enable_truncate_flashback = off;
create table test(c1 int primary key, c2 int, c3 int);
create index test1_index on test(c2);
create index test2_index on test(c3);
drop index test1_index on test;
truncate table test;
--source mysql_test/include/check_all_idx_ok.inc
show index from test;
select count(*) FROM oceanbase.DBA_RECYCLEBIN;
drop table test;
purge recyclebin;

# 测试表和对应的索引表都在回收站中，是否可以flashback index
--echo // 测试表和对应的索引表都在回收站中，是否可以flashback index
create table test(c1 int primary key, c2 int, c3 int);
create index test1_index on test(c2);
create index test2_index on test(c3);
drop index test1_index on test;
# let $name = query_get_value(select OBJECT_NAME FROM oceanbase.DBA_RECYCLEBIN, OBJECT_NAME, 1);
drop table test;
# --echo // flashback index test1_index to before drop;
# --disable_query_log
# --error 4179
# eval flashback index $name to before drop;
# --enable_query_log
purge recyclebin;

# 先设置index为INVISIBLE，再drop index，flashback index
# --echo // 先设置index为INVISIBLE，再drop index，flashback index
# create table test(c1 int primary key, c2 int, c3 int);
# create index test1_index on test(c2);
# alter table test alter index test1_index invisible;
# show index from test;
# drop index test1_index on test;
# let $name = query_get_value(select OBJECT_NAME FROM oceanbase.DBA_RECYCLEBIN, OBJECT_NAME, 1);
# --echo // flashback index test1_index to before drop;
# --disable_query_log
# eval flashback index $name to before drop;
# --enable_query_log
# show index from test;
# drop table test;
# purge recyclebin;

# 创建unique属性的索引，然后执行drop index
create table test(c1 int primary key, c2 int, unique index idx(c2));
insert into test(c1, c2) values(1, 1);
drop index idx on test;
insert into test(c1, c2) values(2, 1);
show recyclebin;
--source mysql_test/include/check_all_idx_ok.inc
show index from test;
select * from test;
select * from test where c2 = 1;
drop table test;
purge recyclebin;

# 单独drop index，然后purge recyclebin，看是否删除回收站中的索引
create table test(c1 int, c2 int, c3 int);
create index test_index on test(c2);
drop index test_index on test;
select count(*) FROM oceanbase.DBA_RECYCLEBIN;
purge recyclebin;
select count(*) FROM oceanbase.DBA_RECYCLEBIN;
drop table test;
purge recyclebin;

# 先drop index，然后drop table，最后purge recyclebin
create table test(c1 int, c2 int, c3 int);
create index test_index on test(c2);
drop index test_index on test;
drop table test;
purge recyclebin;
select count(*) FROM oceanbase.DBA_RECYCLEBIN;

# 测试rename对索引的更改
create table t1(c1 int, index idx(c1));
drop index idx on t1;
alter table t1 rename to t2;
drop table t2;

create table t3(c1 int, index idx(c1));
drop index idx on t3;
rename table t3 to t4;
drop table t4;
select count(*) FROM oceanbase.DBA_RECYCLEBIN;
purge recyclebin;
select count(*) FROM oceanbase.DBA_RECYCLEBIN;

