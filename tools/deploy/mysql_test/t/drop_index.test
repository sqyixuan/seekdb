# 创建unique属性的索引，然后执行alter table drop index
create table test(c1 int primary key, c2 int, unique index idx(c2));
insert into test(c1, c2) values(1, 1);
alter table test drop index idx;
insert into test(c1, c2) values(2, 1);
show recyclebin;
--source mysql_test/include/check_all_idx_ok.inc
show index from test;
select * from test;
select * from test where c2 = 1;
drop table test;
purge recyclebin;

# 测试前缀索引
create table t1(c1 varchar(10));
create index idx on t1(c1(3));
insert into t1 values('hello');
drop index idx on t1;
insert into t1 values('nice');
# --echo // 执行flashback操作，查看flashback后的index是否为visible
# let $name = query_get_value(select OBJECT_NAME FROM oceanbase.DBA_RECYCLEBIN, OBJECT_NAME, 1);
# --echo // flashback index test1_index to before drop;
# --disable_query_log
# eval flashback index $name to before drop;
# --enable_query_log
insert into t1 values('world');
drop table t1;
purge recyclebin;

# 测试每日合并
create table t1(c1 varchar(10));
create index idx on t1(c1);
insert into t1 values('hello');
drop index idx on t1;
insert into t1 values('nice');
# --echo // 执行flashback操作，查看flashback后的index是否为visible
# let $name = query_get_value(select OBJECT_NAME FROM oceanbase.DBA_RECYCLEBIN, OBJECT_NAME, 1);
# --echo // flashback index test1_index to before drop;
# --disable_query_log
# eval flashback index $name to before drop;
# --enable_query_log
insert into t1 values('world');
--source mysql_test/include/check_all_idx_ok.inc
drop table t1;
purge recyclebin;

# 测试flashback index重命名
create table t1(c1 int, index idx(c1));
drop index idx on t1;
# let $name = query_get_value(select OBJECT_NAME FROM oceanbase.DBA_RECYCLEBIN, OBJECT_NAME, 1);
# --echo // flashback index idex to before drop rename to myindex;
# --disable_query_log
# eval flashback index $name to before drop rename to myindex;
# --enable_query_log
# show index from t1;
# drop index myindex on t1;
drop table t1;
purge recyclebin;

set @@ob_enable_truncate_flashback=on;
create table t1(c1 int, index idx(c1));
drop index idx on t1;
create index idx on t1(c1);
truncate table t1;
drop table t1;
select count(*) FROM oceanbase.DBA_RECYCLEBIN;
purge recyclebin;

set @@session.ob_enable_truncate_flashback=off;
create table t1(c1 int, index idx(c1));
drop index idx on t1;
create index idx on t1(c1);
truncate table t1;
drop table t1;
select count(*) FROM oceanbase.DBA_RECYCLEBIN;
purge recyclebin;

drop database drop_index_test;
set @@recyclebin = off;
