--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner : jim.wjh
#owner group: sql2
#description: test whether show create stmt can be executed or not
--disable_warnings
drop database if exists db_show_create;
--enable_warnings
create database db_show_create;
use db_show_create;

#
##show create tenant
#
--disable_query_log
--disable_result_log
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;

select @@recyclebin into @recyclebin_value;
set recyclebin = off;

#drop tenant if exists jx_t1;
#--source mysql_test/include/wait_drop_tenant.inc
#drop resource pool if exists jx_pool1;
#drop resource unit if exists jx_unit1;
#CREATE RESOURCE UNIT jx_unit1 max_cpu 1, memory_size '1G';
let $zone_name=query_get_value(select zone from oceanbase.__all_zone where zone != '' limit 1, zone, 1);
#eval CREATE RESOURCE POOL jx_pool1 unit='jx_unit1', unit_num=1, zone_list=('$zone_name');
#eval CREATE TENANT IF NOT EXISTS jx_t1 charset='utf8mb4', primary_zone='$zone_name', resource_pool_list=('jx_pool1') set ob_tcp_invited_nodes='%';
--source mysql_test/include/check_tenant_sync.inc
let $create_stmt = query_get_value(show create tenant sys, 'Create Tenant', 1);
#drop tenant jx_t1;
#--source mysql_test/include/wait_drop_tenant.inc
--enable_query_log
--enable_result_log
--source mysql_test/include/show_create_table_old_version_replica2.inc
#eval $create_stmt;
#变更read only
set @@global.read_only = on;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create tenant sys;
let $create_stmt = query_get_value(show create tenant sys, 'Create Tenant', 1);
#drop tenant jx_t1;
#--source mysql_test/include/wait_drop_tenant.inc
#创建read only tenant
--source mysql_test/include/show_create_table_old_version_replica2.inc
#eval $create_stmt;
--source mysql_test/include/show_create_table_old_version_replica2.inc
--sleep 2
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create tenant sys;
--disable_query_log
--disable_result_log
#clear
#drop tenant jx_t1;
#drop resource pool jx_pool1;
#drop resource unit jx_unit1;
set recyclebin = @recyclebin_value;
disconnect obsys;
connection default;
--enable_query_log
--enable_result_log

#
##show create database
#
--disable_warnings
drop database if exists test1;
--enable_warnings
create database test1;
let $create_stmt = query_get_value(show create database test1, 'Create Database', 1);
#--disable_query_log
drop database test1;
--source mysql_test/include/show_create_table_old_version_replica2.inc
eval $create_stmt;
alter database test1 read only;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create database test1;
let $create_stmt = query_get_value(show create database test1, 'Create Database', 1);
drop database test1;
#创建read only库
--source mysql_test/include/show_create_table_old_version_replica2.inc
eval $create_stmt;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create database test1;
#--enable_query_log

#
##show create table
#
create table t1(c1 int, c2 double, c3 timestamp) charset=utf8mb4, collate = utf8mb4_general_ci, PROGRESSIVE_MERGE_NUM = 3, BLOCK_SIZE = 16384, USE_BLOOM_FILTER = false, comment = 'this is a table', auto_increment = 1 expire_info = (c1 > 100);
let $create_stmt = query_get_value(show create table t1, 'Create Table', 1);
#--disable_query_log
drop table t1;
--source mysql_test/include/show_create_table_old_version_replica2.inc
eval $create_stmt;
alter table t1 read only;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;
let $create_stmt = query_get_value(show create table t1, 'Create Table', 1);
drop table t1;
--source mysql_test/include/show_create_table_old_version_replica2.inc
eval $create_stmt;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;
#--enable_query_log

create table t_range(c1 int primary key) partition by range(c1) (partition p0 values less than(100) id 100, partition p1 values less than(200) id 200, partition p2 values less than (300) id 300);
#let $create_stmt = query_get_value(show create table t_range, 'Create Table', 1);
#--disable_query_log
#drop table t_range;
#--source mysql_test/include/show_create_table_old_version_replica2.inc
#eval $create_stmt;
#drop table t_range;
#--enable_query_log


#
##show create view
#
create table t2(c1 int);
create view v as select * from t2;
let $create_stmt = query_get_value(show create view v, 'Create View', 1);
--disable_query_log
drop view v;
--enable_query_log
--source mysql_test/include/show_create_table_old_version_replica2.inc
eval $create_stmt;

#
## drop index then show create table
#
create table jx_t1(c1 int primary key, c2 int, c3 int, index idx1(c2), unique index uk2(c3));
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table jx_t1;
drop index idx1 on jx_t1;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table jx_t1;
drop index uk2 on jx_t1;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table jx_t1;

create table jx_t2(c1 int primary key, c2 int, c3 int, index idx1(c2), unique index uk2(c3));
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table jx_t2;
alter table jx_t2 drop index idx1; 
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table jx_t2;
alter table jx_t2 drop index uk2; 
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table jx_t2;

set @@character_set_client = gbk;
set @@collation_connection = binary;
--disable_warnings
drop view if exists v;
--enable_warnings
create view v as select 1 from dual;
show create view v;
set @@character_set_client = utf8mb4;
set @@collation_connection = utf8mb4_general_ci;
show create view v;


#
## show create materialized view
#

create table t1_for_mv (c1 int, c2 int);
create materialized view mv1 partition by hash(c1) partitions 5 as select * from t1_for_mv;

let $create_stmt = query_get_value(show create table mv1, 'Create View', 1);
drop materialized view mv1;
--source mysql_test/include/show_create_table_old_version_replica2.inc
eval $create_stmt;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table mv1;

drop database if exists db_show_create;
