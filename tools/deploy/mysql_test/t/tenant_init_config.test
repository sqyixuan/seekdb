#owner: fanfangzhou.ffz 
#owner group: RS
#tags: rs
#description:
# test the value of _parallel_ddl_control of a new created tenant

--source mysql_test/include/check_before_create_2g_tenant.inc

connect (sys,$OBMYSQL_MS0,root,,oceanbase,$OBMYSQL_PORT);
--disable_query_log
--disable_warnings
--disable_result_log
--disable_abort_on_error
drop tenant tt1 force;
drop resource pool tenant_tt1_pool;
drop resource unit tenant_tt1_unit;
--enable_query_log
--enable_warnings
--enable_result_log
--enable_abort_on_error


let $sys_id = query_get_value(select tenant_id from __all_tenant where tenant_name='sys', tenant_id, 1);
eval select name, value from __all_virtual_tenant_parameter_stat where name like '%enable_mysql_compatible_dates%' and tenant_id = $sys_id limit 1;

#create resource unit if not exists tenant_tt1_unit max_cpu=1,memory_size='2G';
#create resource pool if not exists tenant_tt1_pool unit='tenant_tt1_unit', unit_num=1;
#create tenant if not exists tt1 RESOURCE_POOL_LIST=('tenant_tt1_pool')
--error 1229
set ob_tcp_invited_nodes='%', ob_compatibility_mode='mysql';

let $tt1_id = query_get_value(select tenant_id from __all_tenant where tenant_name='sys', tenant_id, 1);
--disable_query_log
eval select name, value from __all_virtual_tenant_parameter_stat where name like '%parallel_ddl_control%' and tenant_id = $tt1_id limit 1;
eval select name, value from __all_virtual_tenant_parameter_stat where name like '%enable_ddl_worker_isolation%' and tenant_id = $tt1_id limit 1;
eval select name, value from __all_virtual_tenant_parameter_stat where name like '%enable_mysql_compatible_dates%' and tenant_id = $tt1_id limit 1;
eval select name, value from __all_virtual_tenant_parameter_stat where name like '%_ob_immediate_row_conflict_check%' and tenant_id = $tt1_id limit 1;
--enable_query_log

--disable_query_log
--disable_warnings
--disable_result_log
--disable_abort_on_error
#drop tenant tt1 force;
#drop resource pool tenant_tt1_pool;
#drop resource unit tenant_tt1_unit;
--enable_query_log
--enable_warnings
--enable_result_log
--enable_abort_on_error
