--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: dachuan.sdc
# owner group: SQL3
# description: 表中只有主键，进行dml操作 
--disable_abort_on_error

--disable_warnings
drop table if exists t1;
--enable_warnings

#alter system set min_drop_cache_wait_time='10s' server_type=chunkserver;
--real_sleep 2 
create table t1(pk int primary key);

insert into t1 values(1),(2),(4),(3);
insert into t1 values(0);
insert into t1 values(5),(6),(8),(7);


delete from t1 where pk = 2;
delete from t1 where pk = 1;
delete from t1 where pk = 5;

select * from t1;


insert into t1 values(100),(200),(101);
insert into t1 values(102);
insert into t1 values(104),(103);
insert into t1 values(2);


delete from t1 where pk=0;
delete from t1 where pk=7;
delete from t1 where pk=103;

select * from t1;

insert into t1 values(0),(7);
insert into t1 values(307),(103);
insert into t1 values(300),(305),(301);
insert into t1 values(302);
insert into t1 values(304),(303);

delete from t1 where pk=4;
delete from t1 where pk=200;
delete from t1 where pk=300;
select * from t1;

drop table t1;
