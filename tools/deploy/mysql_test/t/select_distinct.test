#owner:link.zt
#owner group: sql1
#tags: optimizer, distinct
#test select distinct
#author link.zt

--disable_warnings
drop table if exists t1, t2, t_idx;
--enable_warnings

create table t1 (c1 int, c2 int);
insert into t1 values(1, 2), (1, 3), (1, 2), (1, 3), (2, 3), (2, 2);

explain select/*+use_hash_aggregation use_hash_distinct*/ distinct c1 from t1;
explain select/*+use_hash_aggregation use_hash_distinct*/ unique(c1) from t1;
explain select/*+no_use_hash_aggregation no_use_hash_distinct*/ distinct c1 from t1;
explain select/*+no_use_hash_aggregation no_use_hash_distinct*/ unique(c1) from t1;
explain select distinct c1 from t1;
explain select unique(c1) from t1;

explain select/*+use_hash_aggregation*/ distinct c1, c2 from t1;
explain select/*+use_hash_aggregation*/ unique(c1), c2 from t1;
explain select/*+no_use_hash_aggregation no_use_hash_distinct*/ distinct c1, c2 from t1;
explain select/*+no_use_hash_aggregation no_use_hash_distinct*/ unique(c1), c2 from t1;
explain select distinct c1, c2 from t1;
explain select unique(c1), c2 from t1;

explain select/*+use_hash_aggregation*/ distinct c1 from t1 group by c1;
explain select/*+use_hash_aggregation*/ unique(c1) from t1 group by c1;
explain select/*+no_use_hash_aggregation no_use_hash_distinct*/ distinct c1 from t1 group by c1;
explain select/*+no_use_hash_aggregation no_use_hash_distinct*/ unique(c1) from t1 group by c1;
explain select/*+use_hash_aggregation*/ distinct c1 from t1 group by c2;
explain select/*+use_hash_aggregation*/ unique(c1) from t1 group by c2;
explain select/*+no_use_hash_aggregation no_use_hash_distinct*/ distinct c1 from t1 group by c2;
explain select/*+no_use_hash_aggregation no_use_hash_distinct*/ unique(c1) from t1 group by c2;

select/*+use_hash_aggregation*/ distinct c1 from t1;
select/*+use_hash_aggregation*/ unique(c1) from t1;
select/*+no_use_hash_aggregation no_use_hash_distinct*/ distinct c1 from t1;
select/*+no_use_hash_aggregation no_use_hash_distinct*/ unique(c1) from t1;
select distinct c1 from t1;
select unique(c1) from t1;

select/*+use_hash_aggregation*/ distinct c1, c2 from t1;
select/*+use_hash_aggregation*/ unique(c1), c2 from t1;
select/*+no_use_hash_aggregation no_use_hash_distinct*/ distinct c1, c2 from t1;
select/*+no_use_hash_aggregation no_use_hash_distinct*/ unique(c1), c2 from t1;
select distinct c1, c2 from t1;
select unique(c1), c2 from t1;

select/*+use_hash_aggregation*/ distinct c1 from t1 group by c1;
select/*+use_hash_aggregation*/ unique(c1) from t1 group by c1;
select/*+no_use_hash_aggregation no_use_hash_distinct*/ distinct c1 from t1 group by c1;
select/*+no_use_hash_aggregation no_use_hash_distinct*/ unique(c1) from t1 group by c1;
select/*+use_hash_aggregation*/ distinct c1 from t1 group by c2;
select/*+use_hash_aggregation*/ unique(c1) from t1 group by c2;
select/*+no_use_hash_aggregation no_use_hash_distinct*/ distinct c1 from t1 group by c2;
select/*+no_use_hash_aggregation no_use_hash_distinct*/ unique(c1) from t1 group by c2;

create table t2 (c1 int, c2 int) partition by hash(c1) partitions 3;
insert into t2 values(1, 2);
insert into t2 values(2, 3);
insert into t2 values(3, 5);
insert into t2 values(1, 2);
insert into t2 values(2, 3);
insert into t2 values(3, 5);

explain select/*+use_hash_aggregation*/ distinct c1 from t2;
explain select/*+use_hash_aggregation*/ unique(c1) from t2;
explain select/*+no_use_hash_aggregation no_use_hash_distinct*/ distinct c1 from t2;
explain select/*+no_use_hash_aggregation no_use_hash_distinct*/ unique(c1) from t2;
explain select distinct c1 from t2;
explain select unique(c1) from t2;

explain select/*+use_hash_aggregation*/ distinct c2 from t2;
explain select/*+use_hash_aggregation*/ unique(c2) from t2;
explain select/*+no_use_hash_aggregation no_use_hash_distinct*/ distinct c2 from t2;
explain select/*+no_use_hash_aggregation no_use_hash_distinct*/ unique(c2) from t2;
explain select distinct c2 from t2;
explain select unique(c2) from t2;

explain select/*+use_hash_aggregation*/ distinct c1, c2 from t2;
explain select/*+use_hash_aggregation*/ unique(c1), c2 from t2;
explain select/*+no_use_hash_aggregation no_use_hash_distinct*/ distinct c1, c2 from t2;
explain select/*+no_use_hash_aggregation no_use_hash_distinct*/ unique(c1), c2 from t2;
explain select distinct c1, c2 from t2;
explain select unique(c1), c2 from t2;

select/*+use_hash_aggregation*/ distinct c1 from t2;
select/*+use_hash_aggregation*/ unique(c1) from t2;
select/*+no_use_hash_aggregation no_use_hash_distinct*/ distinct c1 from t2;
select/*+no_use_hash_aggregation no_use_hash_distinct*/ unique(c1) from t2;
select distinct c1 from t2;
select unique(c1) from t2;

select/*+use_hash_aggregation*/ distinct c2 from t2;
select/*+use_hash_aggregation*/ unique(c2) from t2;
select/*+no_use_hash_aggregation no_use_hash_distinct*/ distinct c2 from t2;
select/*+no_use_hash_aggregation no_use_hash_distinct*/ unique(c2) from t2;
select distinct c2 from t2;
select unique(c2) from t2;

select/*+use_hash_aggregation*/ distinct c1, c2 from t2;
select/*+use_hash_aggregation*/ unique(c1), c2 from t2;
select/*+no_use_hash_aggregation no_use_hash_distinct*/ distinct c1, c2 from t2;
select/*+no_use_hash_aggregation no_use_hash_distinct*/ unique(c1), c2 from t2;
select distinct c1, c2 from t2;
select unique(c1), c2 from t2;

create table t_idx(c1 int, c2 int, c3 int, c4 int, primary key(c1), key tc2(c2));

explain select distinct c1 from t_idx order by c2 limit 10;
explain select unique(c1) from t_idx order by c2 limit 10;

drop table t1, t2, t_idx;

