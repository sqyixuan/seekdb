#owner: link.zt
#owner group: SQL1
--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
--disable_warnings
drop table if exists t1; 
--enable_warnings
create table t1 (k int, v1 int, v2 varchar, primary key(k)) ;
replace into t1 (k, v1, v2) values ( 1, 1, 'a');
replace into t1 (k, v1) values ( 2, 2);
select * from t1 where k in (2);
select * from t1 where k in (1, 2);
select * from t1 where k in (2);
select * from t1 where k in (1, 2);
select * from t1 where k<=3;
