select * from t1 order by pk1, pk2;
--disable_query_log
eval select * from $idx1;
--enable_query_log

connection trx1;

connection trx2;
update t1 set c1=c1+1, c2=c2+1 where (pk1,pk2)=(1,1) or (pk1,pk2)=(2,2) or (pk1,pk2)=(3,3) or (pk1,pk2)=(4,4);
select * from t1 order by pk1, pk2;
--disable_query_log
eval select * from $idx1;
--enable_query_log
delete from t1 where (pk1,pk2)=(1,1) or (pk1,pk2)=(2,2);
select * from t1 order by pk1, pk2;
--disable_query_log
eval select * from $idx1;
--enable_query_log
commit;

connection trx1;
update t1 set c1=c1+1, c2=c2+1 where (pk1,pk2)=(1,1) or (pk1,pk2)=(2,2) or (pk1,pk2)=(3,3) or (pk1,pk2)=(4,4);
update t1 set c1=c1+1, c2=c2+1 where 
        (pk1,pk2)=(1,1) or (pk1,pk2)=(2,2) or (pk1,pk2)=(3,3) or (pk1,pk2)=(4,4) or
        (pk1,pk2)=(5,5) or (pk1,pk2)=(6,6) or (pk1,pk2)=(7,7) or (pk1,pk2)=(8,8);
select * from t1 order by pk1, pk2;
--disable_query_log
eval select * from $idx1;
--enable_query_log
delete from t1 where (pk1,pk2)=(1,1) or (pk1,pk2)=(2,2);
commit;
select * from t1 order by pk1, pk2;
--disable_query_log
eval select * from $idx1;
--enable_query_log
commit;


####CASE: write with same rows, 5048
connection conn1;
replace into t1(pk1,pk2,c1,c2) values (1,1,1,1),(2,2,1,1),(3,3,1,1),(4,4,1,1),(5,5,1,1),(6,6,1,1),(7,7,1,1),(8,8,1,1);
select * from t1 order by pk1, pk2;
--disable_query_log
eval select * from $idx1;
--enable_query_log

connection trx1;
#exist rows
update t1 set c1=c1+1, c2=c2+1 where (pk1,pk2)=(1,1) or (pk1,pk2)=(2,2) or (pk1,pk2)=(3,3) or (pk1,pk2)=(4,4);
delete from t1 where (pk1,pk2)=(5,5) or (pk1,pk2)=(6,6) or (pk1,pk2)=(7,7) or (pk1,pk2)=(8,8);
#non exist rows
update t1 set c1=c1+1, c2=c2+1 where (pk1,pk2)=(9,9) or (pk1,pk2)=(10,10);
delete from t1 where (pk1,pk2)=(11,11) or (pk1,pk2)=(12,12);
select * from t1 order by pk1, pk2;
--disable_query_log
eval select * from $idx1;
--enable_query_log

connection trx2;
set ob_query_timeout=1000000;
#exist rows
--error 1205,4012
update t1 set c1=c1+1, c2=c2+1 where (pk1,pk2)=(1,1) or (pk1,pk2)=(2,2) or (pk1,pk2)=(3,3) or (pk1,pk2)=(4,4);
--error 1205,4012
update t1 set c1=c1+1, c2=c2+1 where (pk1,pk2)=(1,1);
--error 1205,4012
update t1 set c1=c1+1, c2=c2+1 where (pk1,pk2)=(4,4);
--error 1205,4012
update t1 set c1=c1+1, c2=c2+1 where (pk1,pk2)=(5,5) or (pk1,pk2)=(6,6);
--error 1205,4012
delete from t1 where (pk1,pk2)=(1,1) or (pk1,pk2)=(2,2) or (pk1,pk2)=(3,3) or (pk1,pk2)=(4,4);
--error 1205,4012
delete from t1 where (pk1,pk2)=(1,1);
--error 1205,4012
delete from t1 where (pk1,pk2)=(4,4);
--error 1205,4012
delete from t1 where (pk1,pk2)=(5,5) or (pk1,pk2)=(6,6);
--error 1205,4012
replace into t1(pk1,pk2,c1,c2) values (1,1,1,1);
--error 1205,4012
insert  into t1(pk1,pk2,c1,c2) values (1,1,1,1);
#non exist rows
update t1 set c1=c1+1, c2=c2+1 where (pk1,pk2)=(9,9) or (pk1,pk2)=(10,10);
delete from t1 where (pk1,pk2)=(11,11) or (pk1,pk2)=(12,12);
replace into t1(pk1,pk2,c1,c2) values (9,9,1,1);
insert into t1(pk1,pk2,c1,c2) values (10,10,1,1);
replace into t1(pk1,pk2,c1,c2) values (11,11,1,1);
insert into t1(pk1,pk2,c1,c2) values (12,12,1,1);
select * from t1 order by pk1, pk2;
--disable_query_log
eval select * from $idx1;
--enable_query_log

connection trx1;
select * from t1 order by pk1, pk2;
--disable_query_log
eval select * from $idx1;
--enable_query_log
update t1 set c1=c1+1, c2=c2+1 where (pk1,pk2)=(9,9) or (pk1,pk2)=(10,10);
delete from t1 where (pk1,pk2)=(11,11) or (pk1,pk2)=(12,12);
select * from t1 order by pk1, pk2;
--disable_query_log
eval select * from $idx1;
--enable_query_log
commit;

connection trx2;
select * from t1 order by pk1, pk2;
--disable_query_log
eval select * from $idx1;
--enable_query_log
update t1 set c1=c1+1, c2=c2+1 where (pk1,pk2)=(9,9) or (pk1,pk2)=(10,10) or (pk1,pk2)=(11,11) or (pk1,pk2)=(12,12);
select * from t1 order by pk1, pk2;
--disable_query_log
