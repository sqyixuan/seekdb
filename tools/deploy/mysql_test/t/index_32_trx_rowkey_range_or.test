--enable_query_log
commit;
select * from t1 order by pk1, pk2;
--disable_query_log
eval select * from $idx1;
--enable_query_log
commit;


connection trx1;
set autocommit=1;
connection trx2;
set autocommit=1;
drop table t1;
set global ob_enable_index_direct_select =0;
