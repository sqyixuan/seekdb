--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: chaser.ch
# owner group: storage2
# tags: ddl
# description:
#
--disable_warnings
drop table if exists stfmt_t1,stfmt_t2,stfmt_t3,stfmt_t4,stfmt_t5,stfmt_t6,stfmt_t7;
--enable_warnings

# test create table with row_format option
create table stfmt_t1(a int, b varchar(100)) compression = 'lz4_1.0';
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table stfmt_t1;
--error 1064
create table stfmt_t2(a int, b varchar(100)) compression = 'lz4_1.0' row_format = 'redundant';
--error 1064
create table stfmt_t2(a int, b varchar(100)) compression = 'lz4_1.0' row_format = whocares;
--error 1064
create table stfmt_t2(a int, b varchar(100)) compression = 'lz4_1.0' row_format;
--error 1064
create table stfmt_t2(a int, b varchar(100)) compression = 'lz4_1.0' row_format=;
--error 1064
create table stfmt_t2(a int, b varchar(100)) compression = 'lz4_1.0' REDUNDANT;
create table stfmt_t2(a int, b varchar(100)) compression = 'none' row_format = REDUNDANT;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table stfmt_t2;
create table stfmt_t3(a int, b varchar(100)) row_format CoMpAcT compression = 'zstd_1.0';
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table stfmt_t3;
create table stfmt_t4(a int, b varchar(100)) compression = 'lz4_1.0' row_format= dynamic;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table stfmt_t4;
create table stfmt_t5(a int, b varchar(100)) row_format COMPRESSED compression = 'zstd_1.0';
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table stfmt_t5;
create table stfmt_t6(a int, b varchar(100)) row_format =default compression = 'zstd_1.0';
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table stfmt_t6;
create table stfmt_t7(a int, b varchar(100)) row_format =condensed compression = 'zstd_1.0';
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table stfmt_t7;

connect (obsys_stfmt,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,oceanbase,$OBMYSQL_PORT);
connection obsys_stfmt;
select table_name, compress_func_name, row_store_type, store_format from __all_virtual_table where table_name like "stfmt_t%" order by table_name asc;

connection default;
insert into stfmt_t1 values(1, repeat('a', 25));
--let $loop=3
while($loop > 0)
{
  insert into stfmt_t2 select * from stfmt_t1;
  insert into stfmt_t3 select * from stfmt_t1;
  insert into stfmt_t4 select * from stfmt_t1;
  insert into stfmt_t5 select * from stfmt_t1;
  insert into stfmt_t6 select * from stfmt_t1;
  insert into stfmt_t7 select * from stfmt_t1;
  insert into stfmt_t1 select * from stfmt_t1;
  dec $loop;
}
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc

drop table stfmt_t1,stfmt_t2,stfmt_t3,stfmt_t4,stfmt_t5,stfmt_t6,stfmt_t7;

# test create table with system default parameters
connection obsys_stfmt;
--error 4147
alter system set default_row_format='archive';
--error 4147
alter system set default_row_format='whocares';

alter system set default_row_format='redundant';
--real_sleep 3
