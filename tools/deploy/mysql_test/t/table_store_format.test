drop table stfmt_t1,stfmt_t2,stfmt_t3,stfmt_t4,stfmt_t5;

# test alter table with row_format option
create table stfmt_t1(a int, b varchar(100)) compression = 'lz4_1.0';
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table stfmt_t1;
--error 1064
alter table stfmt_t1 set row_format=nocompress;
--error 1064
alter table stfmt_t1 row_format whocares;
alter table stfmt_t1 row_format=redundant;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table stfmt_t1;
alter table stfmt_t1 row_format COMpact;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table stfmt_t1;
alter table stfmt_t1 set row_format DYNAMIC;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table stfmt_t1;
alter table stfmt_t1 set row_format= comPRESSed;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table stfmt_t1;
alter table stfmt_t1 set row_format= CONdenSed;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table stfmt_t1;

connection obsys_stfmt;
select table_name, compress_func_name, row_store_type, store_format from __all_virtual_table where table_name like "stfmt_t%" order by table_name asc;

connection default;
drop table stfmt_t1;

# test index option with row_format option
create table stfmt_t1(a int, b varchar(100), key i1_stfmt1 (b) local, key i2_stfmt1 (a) global) compression = 'lz4_1.0';
create index i3_stfmt1 on stfmt_t1 (a, b);
create table stfmt_t2(a int, b varchar(100), key i1_stfmt2 (b) local, key i2_stfmt2 (a) global) compression = 'lz4_1.0' row_format = REDUNDANT;
create index i3_stfmt1 on stfmt_t2 (a, b);
create table stfmt_t3(a int, b varchar(100), key i1_stfmt3 (b) local, key i2_stfmt3 (a) global) compression = 'lz4_1.0' row_format = REDUNDANT;
create index i3_stfmt1 on stfmt_t3 (a, b);
connection obsys_stfmt;
select right(table_name, 9), compress_func_name, row_store_type, store_format from __all_virtual_table where table_name like "%stfmt%" order by table_name asc;
connection default;
alter table stfmt_t1 set row_format = compact;
alter table stfmt_t2 set row_format = compressed;
alter table stfmt_t3 set row_format = condensed;
connection obsys_stfmt;
select right(table_name, 9), compress_func_name, row_store_type, store_format from __all_virtual_table where table_name like "%stfmt%" order by table_name asc;
connection default;
drop table stfmt_t1, stfmt_t2, stfmt_t3;

disconnect obsys_stfmt;
