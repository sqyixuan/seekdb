--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: shanyan.g
# owner group: transaction
# description: 测试发起合并的时候会把未结束的事务强制kill掉的功能
--echo test server kill trans will call rollback
--source mysql_test/include/index_quick_major.inc
--disable_warnings
drop table if exists test;
--enable_warnings
create table test(c1 int , c2 varchar(1024), c3 int, c4 varchar(1024), c5  timestamp(6) default "2012-01-01 12:00:00", c6 int, primary key(c1));
insert into test values(1,'a',1,'a','2013-12-03 00:00:00',1), (2,'b',2,'b','2013-12-03 00:00:00',2);
insert into test values(3,'a',1,'a','2013-12-03 00:00:00',1), (4,'b',2,'b','2013-12-03 00:00:00',2);
select * from test;
set  autocommit=0;
insert into test values(5,'a',1,'a','2013-12-03 00:00:00',1);
#--source mysql_test/include/majorfreeze.inc
#--source mysql_test/include/wait_daily_merge.inc
sleep 1;
select * from test;
commit;
insert into test values(6,'a',1,'a','2013-12-03 00:00:00',1);
#--source mysql_test/include/majorfreeze.inc
#--source mysql_test/include/wait_daily_merge.inc
sleep 1;
select * from test;
rollback;
select * from test;
set  autocommit=1;
