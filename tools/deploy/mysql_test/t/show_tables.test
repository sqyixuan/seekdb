--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: linlin.xll
# owner group: SQL4
# description: test for show tables and show table status
# login using sys tenant

--disable_warnings
drop database if exists db1;
use test;

drop table if exists bin_wei_t1,bin_wei_t2,bin_wei_t3,bin_wei_t4,t_comment;
drop view if exists view_t1,view_t2;
--enable_warnings


## create table in db1;
create database db1;
use db1;
create table db1_t1(c1 varchar(10) primary key, c2 varchar(10));
create table db1_t2(c1 varchar(10) primary key, c2 varchar(10));
create table db1_t3(c1 varchar(10) primary key, c2 varchar(10));


## create table in test;
use test;
create table bin_wei_t1(c1 varchar(10) primary key, c2 varchar(10));
create table bin_wei_t2(c1 varchar(10) primary key, c2 varchar(10));
create table bin_wei_t3(c1 varchar(10) primary key, c2 varchar(10));
create table bin_wei_t4(c1 varchar(10) primary key, c2 varchar(10));

## create view
create view view_t1 as select c1, c2 from bin_wei_t1;
create view view_t2 as select c1, c2 from bin_wei_t2;

## show tables with database name
show full tables in information_schema where tables_in_information_schema = 'columns';
show full tables in db1 where tables_in_db1 like 'bin%';
show full tables from db1 where tables_in_db1 like 'bin%';
show tables in db1 where tables_in_db1 like 'bin%';
show tables from db1 where tables_in_db1 like 'bin%';

## show tables with like
show full tables like 'bin%';
show tables like "bin%";
show tables in db1 like 'bin%';
show tables like '%';
show full tables like '%';

## show tables with where condition
show full tables where table_type = 'BASE TABLE' and tables_in_test = 'bin_wei_t1';
show full tables where table_type like '%VIEW%' and tables_in_test = 'bin_wei_t1';
show full tables where table_type in ('VIEW') and tables_in_test = 'bin_wei_t1';
show full tables where tables_in_test = 'bin_wei_t1';
show full tables where tables_in_test like 'bin%';
show full tables where tables_in_test in ('bin_wei_t1', 'bin_wei_t2');
#show full tables where 'a' < tables_in_test;
show full tables where 'bin_wei_t4' = tables_in_test or tables_in_test like 'view%';
show full tables where tables_in_test in (case 'a' when 'a' then 'bin_wei_t4' else 'bin_wei_t1' end);
show full tables where tables_in_test like concat(tables_in_test, '%') and tables_in_test = 'bin_wei_t1';

#show table status
--replace_column 3 version 17 create_option 12 create_time 13 update_time
show table status like 'bin%';
--replace_column 3 version 17 create_option 12 create_time 13 update_time
show table status in db1 like 'bin%';
--replace_column 3 version 17 create_option 12 create_time 13 update_time
show table status where name = 'bin_wei_t1';
--replace_column 3 version 17 create_option 12 create_time 13 update_time
show table status where name like 'bin%';
--replace_column 3 version 17 create_option 12 create_time 13 update_time
show table status where name in ('bin_wei_t1', 'bin_wei_t2');
--replace_column 3 version 17 create_option 12 create_time 13 update_time
show table status where 'bin_wei_t4' = name or name like 'view%';
--replace_column 3 version 17 create_option 12 create_time 13 update_time
show table status where name in (case 'a' when 'a' then 'bin_wei_t4' else 'bin_wei_t1' end);
--replace_column 3 version 17 create_option 12 create_time 13 update_time
show table status where name like concat('bin_wei_t1', '%');

#test for max table comment(4096)
create table t_comment (c1 int) comment = '';
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t_comment;
--replace_column 3 version 17 create_option 12 create_time 13 update_time
show table status like 't_comment';

drop table bin_wei_t1,bin_wei_t2,bin_wei_t3,bin_wei_t4,t_comment;
drop view view_t1,view_t2;
