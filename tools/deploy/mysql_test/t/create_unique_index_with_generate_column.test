--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner : zhenjiang.xzj
#owner group : storage 
#tags: ddl 

--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1 (c1 int, c2 int, c3 varchar(20), c4 varchar(20), c5 varchar(20) generated always as (substr(c3, 1, 10)) virtual, c6 varchar(20) generated always as (substr(c4, 1, 10)) stored , primary key(c1, c2));
insert into t1 (c1, c2, c3, c4) values (1, 1, 'a', 'b');
create unique index u1 on t1 (c5);
create unique index u2 on t1(c4(2));
--source mysql_test/include/check_all_idx_ok.inc

# oceanbase mysql模式下, 对于无主键表, local 唯一索引必须包含分区键(如果分区键是生成列, 必须完整包含该生成列), 否则创建失败。
--disable_warnings
drop table if exists t5;
--enable_warnings
create table t5(c1 int, c2 int, c3 int as (c1 + c2) virtual) partition by hash(c3) partitions 4;
create unique index t5_idx_01 on t5(c1,c3) local;
create unique index t5_idx_02 on t5(c1,c3) global;
create unique index t5_idx_03 on t5(c1) global;
create unique index t5_idx_04 on t5(c2) global;
create unique index t5_idx_05 on t5(c3) global;
--error 1503
create unique index t5_idx_06 on t5(c1) local;
--error 1503
create unique index t5_idx_07 on t5(c2) local;
create unique index t5_idx_08 on t5(c3) local;
--error 1503
create unique index t5_idx_09 on t5(c1,c2) local;
create unique index t5_idx_10 on t5(c2,c3) local;
drop table t5;