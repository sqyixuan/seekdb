--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: dachuan.sdc
# owner group: SQL2
# description:
#
--disable_warnings
drop table if exists t1;
--enable_warnings
--source mysql_test/include/wait_daily_merge.inc

#test normally
create table t1(c1 int primary key default 1 not null,
	c2 varchar(20) default 'aaa',
	c3 float default 1.01 not null,
	c4 double default 2.111345 not null,
	c5 timestamp default '2013-12-02 11:56:00.0',
	c6 datetime default '2013-12-02');
desc t1;
insert into t1 values(1, 'a', 2.02, 2.456, usec_to_time(6), usec_to_time(9)), (2, 'b', 9.1111, 3.45678, '2013-09-08 11:45:56.09', '2013-09-08');
select * from t1;
--disable_warnings
drop table if exists t1,t2,t3,t4;
--enable_warnings
--error 1067
create table t2(c1 int primary key default 'a' not null,
        c2 varchar(20) default 1234,
        c3 float default 1.01 not null,
        c4 double default 2.111345 not null,
        c5 timestamp default '2013-12-02 11:56:00.0',
        c6 datetime default '2013-12-02');
--error 1067
create table t3 (c3 float default 'abcd' not null);
--error 1064
create table t4(a int primary key,b timestamp default usec_to_time(1243354325435));
--error 1067
create table t4(a int primary key,b timestamp default 1243354325435);  

#test insert default value
create table t1(c1 int primary key default 1 not null,
	c2 varchar(20) default 'aaa',
	c3 float default 1.01 not null,
	c4 double default 2.111345 not null,
	c5 timestamp default '2013-12-02 11:56:00.0',
	c6 datetime default '2013-12-02');
desc t1;
insert into t1(c1) values(1), (2), (3), (4);
select * from t1;
--disable_warnings
drop table if exists t1;
--enable_warnings

#test alter default value
create table t1(c1 int primary key default 1 not null,
	c2 varchar(20) default 'aaa',
	c3 float default 1.01 not null,
	c4 double default 2.111345 not null,
	c5 timestamp default '2013-12-02 11:56:00.0');
desc t1;
alter table t1 add c6 datetime default '2013-12-02' not null;
sleep 1;
desc t1;
insert into t1(c1) values(1), (2), (3);
select * from t1;
--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1(c1 int primary key default 1 not null,
	c2 varchar(20) default 'aaa',
	c3 float default 1.01 not null,
	c4 double default 2.111345 not null,
	c5 timestamp default '2013-12-02 11:56:00.0');
desc t1;
alter table t1 add c6 datetime default '2013-12-02' not null;
sleep 1;
desc t1;
alter table t1 alter c1 set default 3;
sleep 1;
desc t1;
alter table t1 alter c1 drop default;
sleep 1;
desc t1;
--error 1064
alter table t1 alter c1 drop not null;
sleep 1;
desc t1;
--error 1064
alter table t1 alter c2 set not null;
desc t1;
--error 1064
alter table t1 alter c3 drop not null;
sleep 1;
desc t1;
alter table t1 alter c2 set default 'aa';
sleep 1;
desc t1;
alter table t1 alter c2 drop default;
sleep 1;
desc t1;
alter table t1 drop c2;
sleep 1;
desc t1;
alter table t1 add c2 varchar(10) default '';
sleep 1;
desc t1;
--disable_warnings
drop table if exists t1;
--enable_warnings
#test default now()
#not allow to use default now() for other column type
--error 1067
create table t1(c1 int primary key, c2 int default now());
#success
create table t1(c1 int primary key, c2 timestamp default now(), c3 timestamp default current_timestamp());
desc t1;
insert into t1(c1) values(1), (2), (3);
select c1, time_to_usec(c2) - time_to_usec(c3) from t1;

replace into t1(c1) values(4);
select c1, time_to_usec(c2) - time_to_usec(c3) from t1;

replace into t1(c1, c2) values(5, now()), (6, current_timestamp());
select c1, time_to_usec(c2) - time_to_usec(c3) from t1;

delete from t1;
replace into t1(c1) values(3), (4);
replace into t1(c1) values(1), (2);
select alias1.c2=alias2.c2 from (select c2 from t1 where c1=1 or c1 = 2) as alias1, (select c2 from t1 where c1=3 or c1=4) as alias2 where alias1.c2=alias2.c2;

#test alter table default now()
#alter table t1 alter c2 drop default;
#sleep 1;
#desc t1;
#alter table t1 alter c2 set default current_timestamp();
#sleep 1;
#desc t1;
--disable_warnings
drop table if exists t1;
--enable_warnings
#test bug: create table, the default length of varchar is 0, expected 65536
create table t1(c1 int primary key default 1 not null,
	c2 varchar(1024),
	c3 char);
desc t1;
--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1(c1 int primary key default 1 not null,
	c2 varchar(20) default 'aaa',
	c3 float default 1.01 not null,
	c4 double default 2.111345 not null,
	c5 timestamp default '2013-12-02 11:56:00.0',
	c6 datetime default '2013-12-02');
desc t1;
replace into t1(c1) values(1);
replace into t1(c1) values(2);
select * from t1;
alter table t1 alter c2 set default 'bbb';
sleep 1;
select * from t1;
#execute a daily merge
##alter system set min_drop_cache_wait_time='10s' server_type=chunkserver;
--real_sleep 1

--echo merge
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
select * from t1;
alter table t1 alter c2 set default 'ccc';
sleep 1;
select * from t1;
replace into t1(c1) values(1);
replace into t1(c1) values(3);
select * from t1;
--disable_warnings
drop table if exists t1;
--enable_warnings
