--disable_warnings
drop table if exists t_float;
drop table if exists t_double;
--enable_warnings

# float default value
create table t_float(c1 float(2,0) default '12.2222');
insert into t_float values (default);
select * from t_float;
drop table t_float;
--error 1067
create table t_float(c1 float(2,0) default '120.2222');
create table t_float(c2 int);
insert into t_float values(1);
--error 1067
alter table t_float add column c1 float(2,0) default '120.222222';
alter table t_float add column c1 float(2,0) default '12.222222';
select * from t_float;
drop table t_float;

# double default value
create table t_double(c1 double(2,0) default '12.2222');
insert into t_double values (default);
select * from t_double;
drop table t_double;
--error 1067
create table t_double(c1 double(2,0) default '120.2222');
create table t_double(c2 int);
insert into t_double values(1);
--error 1067
alter table t_double add column c1 double(2,0) default '120.222222';
alter table t_double add column c1 double(2,0) default '12.222222';
select * from t_double;
drop table t_double;
