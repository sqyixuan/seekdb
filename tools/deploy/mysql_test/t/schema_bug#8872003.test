--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: zhaoziqian.zzq 
#description: reboot模式下跑

#
## 
#

--disable_query_log
--disable_result_log

connect (obsys2,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys2;

#
## create tenant
#
#drop tenant if exists t1 force;
#drop resource pool if exists pool22;
#drop resource unit if exists unit22;
#--disable_query_log
#CREATE RESOURCE UNIT unit22 max_cpu 1, memory_size '2G';
#let $zone_name=query_get_value(select zone from oceanbase.__all_zone where zone != '' limit 1, zone, 1);
#eval CREATE RESOURCE POOL pool22 unit='unit22', unit_num=1, zone_list=('$zone_name');
#eval CREATE TENANT IF NOT EXISTS t1 charset='utf8mb4', primary_zone='$zone_name', resource_pool_list=('pool22') set ob_tcp_invited_nodes='%';
--enable_query_log
--source mysql_test/include/check_tenant_sync.inc

#
## create table under tenant 
#
let $__tenant_name__ = 'sys';
--source mysql_test/include/get_tenant_server.inc
--disable_query_log
--disable_result_log
connect(conn1,$OBMYSQL_MS0,root@sys,,,$OBMYSQL_PORT);
drop table if exists test;
create table test.test(c1 int);

connect(conn7,$OBMYSQL_MS0,root@sys,,,$OBMYSQL_PORT);
alter system suspend merge;
sleep 2;
--source mysql_test/include/majorfreeze.inc
#ddl冲掉cache
let $cnt=65;
while($cnt)
{
  eval drop table if exists test.t$cnt;
  eval create table test.t$cnt(i1 int);
  dec $cnt;
}
#构造前向回滚的基线
connection obsys2;
alter system resume merge;
sleep 2;
--source mysql_test/include/wait_daily_merge.inc
--disable_query_log
--disable_result_log


connect(conn3,$TE_SERVER_IP,root,,,$TE_SERVER_PORT);
set @@recyclebin = off;
drop table test.test;
connect(conn4,$OBMYSQL_MS0,root@sys,,,$OBMYSQL_PORT);
#drop tenant t1 force;
#drop resource pool pool22;
#drop resource unit unit22;
connect(conn5,$OBMYSQL_MS0,root@sys,,,$OBMYSQL_PORT);
alter system suspend merge;
sleep 2;
--source mysql_test/include/majorfreeze.inc

#ddl冲掉cache, 为了能走前向分支, 这里sleep足够长时间
sleep 20;
let $cnt=65;
while($cnt)
{
  eval drop table test.t$cnt;
  eval create table test.t$cnt(i1 int);
  dec $cnt;
}

connection obsys2;
alter system resume merge;
drop database test;
create database test;
sleep 2;

echo 'test';
--source mysql_test/include/wait_daily_merge.inc

--enable_query_log
--enable_result_log
