--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
drop database if exists db_create;
create database db_create;
use db_create;
--enable_warnings

CREATE TABLE compress_table (c1 int primary key, c2 int, c3 int, index i1 (c1), unique index i2 (c2)) COMPRESSION = 'lz4_1.0';

insert into compress_table values (1,1,1);
insert into compress_table values (2,2,2);
insert into compress_table values (3,3,3);
select * from compress_table;

--source mysql_test/include/index_quick_major.inc
--source mysql_test/include/wait_daily_merge.inc

CREATE INDEX i3 ON compress_table(c3);
ALTER TABLE compress_table ADD INDEX i123 (c1, c2, c3);

insert into compress_table values (4,4,4);
insert into compress_table values (5,5,5);
insert into compress_table values (6,6,6);
ALTER TABLE compress_table set COMPRESSION = 'none';

--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table compress_table;

--source mysql_test/include/index_quick_major.inc
--source mysql_test/include/wait_daily_merge.inc

ALTER TABLE compress_table set COMPRESSION = 'lz4_1.0';

TRUNCATE TABLE compress_table;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table compress_table;

--source mysql_test/include/index_quick_major.inc
--source mysql_test/include/wait_daily_merge.inc

drop database db_create;
