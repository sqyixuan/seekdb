--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: yuchen.wyc
# owner group: sql4
# tags: optimizer
# description: foobar
####TITEL: query_with_precast
--disable_warnings
drop table if exists t1; 
--enable_warnings
create table t1(a int, b int);
--let $count=1
while($count < 101)
{
  --let $stmt=INSERT INTO t1 VALUES($count, $count-1)
  eval $stmt;
  inc $count;
}

--let $query=select * from t1 where a='2'
eval explain extended_noaddr $query;
eval $query;

--let $query=select * from t1 where a<='2'
eval explain extended_noaddr $query;
eval $query;

--let $query=select * from t1 where a>1
eval explain extended_noaddr $query;
eval $query;

--let $query=select * from t1 where a+'1'<6
eval explain extended_noaddr $query;
eval $query;

--let $query=select * from t1 where a+1.1<6.1
eval explain extended_noaddr $query;
eval $query;

--let $query=select * from t1 where a+now()<now() + 6
eval explain extended_noaddr $query;
eval $query;

--let $query=select * from t1 where a-'1'=b
eval explain extended_noaddr $query;
eval $query;

--let $query=select * from t1 where a+'1'<b
eval explain extended_noaddr $query;
eval $query;

--let $query=select * from t1 where a*'1'=5
eval explain extended_noaddr $query;
eval $query;

--let $query=select * from t1 where a/'1'=5
eval explain extended_noaddr $query;
eval $query;

--let $query=select * from t1 where a mod '5'=4
eval explain extended_noaddr $query;
eval $query;

--let $query=select * from t1 where a <=>'5'
eval explain extended_noaddr $query;
eval $query;

--let $query=select * from t1 where a between '1' and '10'
eval explain extended_noaddr $query;
eval $query;

drop table t1;

create table t1(a datetime, b int);
--let $count=0
while($count < 60)
{
  --let $stmt=INSERT INTO t1 VALUES(cast('1990-01-01 00:00:00' as datetime)+$count, $count)
  eval $stmt;
  inc $count;
}

--let $query=select * from t1 where a>1 and b=1
eval explain extended_noaddr $query;
eval $query;

--let $query=select * from t1 where a<=19900102000000
eval explain extended_noaddr $query;
eval $query;

--let $query=select * from t1 where a<19900102000000
eval explain extended_noaddr $query;
eval $query;

--let $query=select * from t1 where a>=19900102000000 and a<=19900104000000
eval explain extended_noaddr $query;
eval $query;

--let $query=select * from t1 where a+1.1>b
eval explain extended_noaddr $query;
eval $query;

--let $query=select * from t1 where a=19900101000001
eval explain extended_noaddr $query;
eval $query;

--let $query=select * from t1 where a+10>'1990-01-01 00:00:30'
eval explain extended_noaddr $query;
eval $query;

--let $query=select * from t1 where a-10>'1990-01-01 00:00:30'
eval explain extended_noaddr $query;
eval $query;

--let $query=select * from t1 where a*10>'1990-01-01 00:00:30'
eval explain extended_noaddr $query;
eval $query;

--let $query=select * from t1 where a/10>'1990-01-01 00:00:30'
eval explain extended_noaddr $query;
eval $query;

--let $query=select * from t1 where a%10>'1990-01-01 00:00:30'
eval explain extended_noaddr $query;
eval $query;

drop table t1;
