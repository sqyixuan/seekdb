# tags: optimizer
# description:
#
# note: normal cases are covered in group_min_max.test
## Initialization
--disable_warnings
drop table if exists t1,t2,t3, t_empty, t_distinct, LINEITEM;
--enable_warnings

# basic test
create table t1 (c1 int, c2 bigint, c3 float);
insert into t1 values(1, 2, 3.5), (-3, 2, 4.5), (7, 5, 2.0), (9, 4, -0.5);
select avg(c1) from t1;
explain select avg(c1) from t1;
select avg(c2) from t1;
explain select avg(c2) from t1;
select avg(c3) from t1;
explain select avg(c3) from t1;

# avg for distinct
create table t_distinct (c1 int, c2 bigint, c3 float);
insert into t_distinct values(1, 2, 3.5), (-3, 2, 4.5), (1, 5, -0.5), (9, 4, -0.5);
select avg(c1), avg(distinct c1) from t_distinct;
explain select avg(distinct c1) from t_distinct;
select avg(c2), avg(distinct c2) from t_distinct;
explain select avg(distinct c2) from t_distinct;
select avg(c3), avg(distinct c3) from t_distinct;
explain select avg(distinct c3) from t_distinct;

# avg for empty table
create table t_empty(c1 int, c2 int, c3 int);
select avg(c1) from t_empty;
select avg(distinct c1) from t_empty;
select avg(distinct c3) from t_empty;

# avg for table whos rows are all NULL rows
create table t2 (c1 int, c2 int, c3 varchar(255));
insert into t2 values(NULL, 0, '123'), (NULL, 1, '321'), (NULL, 3, '123321');
select avg(c1) from t2;

# avg for table contains NULL rows
create table t3 (c1 int, c2 bigint, c3 float);
insert into t3 values(1, NULL, 3.5), (-3, 2, 4.5), (NULL, 5, 2.0), (9, 4, -0.5);
select avg(c1), avg(c2), avg(c3) from t3;

# tpch case
CREATE TABLE `LINEITEM` (
    `L_ORDERKEY` bigint(20) NOT NULL,
    `L_PARTKEY` bigint(20) NOT NULL,
    `L_SUPPKEY` bigint(20) NOT NULL,
    `L_LINENUMBER` bigint(20) NOT NULL,
    `L_QUANTITY` decimal(15,2) NOT NULL,
    `L_EXTENDEDPRICE` decimal(15,2) NOT NULL,
    `L_DISCOUNT` decimal(15,2) NOT NULL,
    `L_TAX` decimal(15,2) NOT NULL,
    `L_RETURNFLAG` char(1) NOT NULL,
    `L_LINESTATUS` char(1) NOT NULL,
    `L_SHIPDATE` date NOT NULL,
    `L_COMMITDATE` date NOT NULL,
    `L_RECEIPTDATE` date NOT NULL,
    `L_SHIPINSTRUCT` char(25) NOT NULL,
    `L_SHIPMODE` char(10) NOT NULL,
    `L_COMMENT` varchar(44) NOT NULL,
    PRIMARY KEY (`L_ORDERKEY`, `L_LINENUMBER`),
    KEY `index_1` (`L_ORDERKEY`) BLOCK_SIZE 16384,
    KEY `index_2` (`L_PARTKEY`, `L_SUPPKEY`) BLOCK_SIZE 16384
);
explain select
          l_returnflag,
          l_linestatus,
          sum(l_quantity) as sum_qty,
          sum(l_extendedprice) as sum_base_price,
          sum(l_extendedprice * (1 - l_discount)) as sum_disc_price,
          sum(l_extendedprice * (1 - l_discount) * (1 + l_tax)) as sum_charge,
          avg(l_quantity) as avg_qty,
          avg(l_extendedprice) as avg_price,
          avg(l_discount) as avg_disc,
          count(*) as count_order
          from
          lineitem
          where
          l_shipdate <= date '1998-12-01' - interval '90' day
          group by
          l_returnflag,
          l_linestatus
          order by
          l_returnflag,
          l_linestatus;

--disable_warnings
drop table t1,t2,t3,t_empty,t_distinct, LINEITEM;
--enable_warnings
