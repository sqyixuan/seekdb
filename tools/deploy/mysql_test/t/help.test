--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: dachuan.sdc
# owner group: SQL4
# description: test help result

connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);

--disable_result_log
# topic
### topic_count == 1
help 'HEX';
help 'CREATE USER';
help 'FLOAT(p)';
help '+';
help 'LOCK/UNLOCK';
help 'ST%';
help 'SHOW%';

### topic_count > 1
help '%TABLE%';
help '%s';
help 'A%';

# keyword
help 'BOOL';
help 'BINARY';
help '!=';
help 'Splicing';
help 'LOCK';

# category
## category_count == 1
help 'Contents';
help 'Functions';
help 'String Functions';
help 'Data Definition';
help 'Utility';

# like_pattern
help 'C%';
help '%';
help 'FLOA_';
help '_IME';
help 'CURRENT_TIME';

#found nothing
help '1';
help 'abcd';
help '?';
help '***%';
help 'ab_*';
