select avg(pk1) from t1 where key1<8 and key1>0 and key7<8 and key7>0 order by key1,key7;
select min(pk1) from t1 where key1<8 and key1>0 and key7<8 and key7>0 order by key1,key7;
select max(pk1) from t1 where key1<8 and key1>0 and key7<8 and key7>0 order by key1,key7;
select sum(pk1) from t1 where key1<8 and key1>0 and key7<8 and key7>0 order by key1,key7;
select distinct key9,pk1 from t1 where key1<8 and key1>0 and key7<8 and key7>0 order by key1,key7;
select key9,pk1 from t1 where key1<8 and key1>0 and key7<8 and key7>0 order by key1,key7;

select key9,pk1 from t1 where key1<8 and key1>0 and key7<8 and key7>8 order by key1,key7;
select sum(key9) from t1 where key1<8 and key1>0 and key7<8 and key7>8 order by key1,key7;


