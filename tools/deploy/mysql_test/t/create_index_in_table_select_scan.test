select * from t1 where pk1=pk2 and pk2>2;
select * from t1 where pk1>pk2 and pk2>2;
select * from t1 where pk1<pk2 and pk2>2;
select * from t1 where key1=key2 and key2<2;
select * from t1 where key1<key2 and key2<2;
select * from t1 where key1>key2 and key2>=2;
select * from t1 where key1>key2 and key2<=2;
select * from t1 where pk1<pk2 and pk2>2;

