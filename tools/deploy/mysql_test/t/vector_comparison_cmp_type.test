##test relation operator
## =
set @@session.collation_connection='utf8_general_ci';
set @@session.character_set_client='utf8';
set @@session.character_set_connection='utf8';
set @@session.character_set_database='utf8';
set @@session.character_set_server='utf8';
set @@session.character_set_results='utf8';

select (1, "abc", 3) = (1, "Abc", 3);
select (1, "abc", 3) = (1, "Abc" collate utf8_bin, 3);
## !=
select (1, "abc", 3) != (1, "Abc", 3);
select (1, "abc", 3) != (1, "Abc" collate utf8_bin, 3);
## >
select (1, "abc", 3) > (1, "Abc" collate utf8_bin, 3);
select (1, "abc", 3) > (1, "Abc", 3);
## >=
select (1, "abc", 3) >= (1, "Cbc" collate utf8_bin, 3);
select (1, "abc", 3) >= (1, "Cbc", 3);
## < 
select (1, "Abc", 3) < (1, "abc" collate utf8_bin, 3);
select (1, "Abc", 3) < (1, "abc", 3);
## <= 
select (1, "Cbc", 3) <= (1, "abc" collate utf8_bin, 3);
select (1, "Cbc", 3) <= (1, "abc", 3);
## <=> 
select (1, "abc", 3) <=> (1, "Abc", 3);
select (1, "abc", 3) <=> (1, "Abc" collate utf8_bin, 3);
## in 
select (1, "abc", 3) in ((1, "bbc", 3), (1, "Abc" collate utf8_bin, 3));
select (1, "abc", 3) in ((1, "bbc", 3), (2, "Abc", 3));
## not in
select (1, "abc", 3) not in ((1, "bbc", 3), (1, "Abc" collate utf8_bin, 3));
select (1, "abc", 3) not in ((1, "bbc", 3), (1, "Abc", 3));
#

##subquery related
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1 (c1 int, c2 varchar(64) charset utf8 collate utf8_bin, c3 int);
insert into t1 value (1, "Abc", 3),( 2, "ABC", 3);
## =
select "Abc" = any(select c2 from t1);
select "Abc" = all(select c2 from t1);
select "Abc" = (select c2 from t1 where c1 = 1);

select (1, "Abc", 3) = (select * from t1 where c1 = 1);
select (2, "Abc", 3) = (select * from t1 where c1 = 2);
select (2, "ABC", 3) = any(select * from t1);
select (2, "Abc", 3) = any(select * from t1);
select (2, "ABC", 3) = all(select * from t1);
## !=
select "Abc" != (select c2 from t1 where c1 = 1);
select "Abc" != any(select c2 from t1);
select "Abc" != all(select c2 from t1);

select (1, "Abc", 3) != (select * from t1 where c1 = 1);
select (2, "Abc", 3) != (select * from t1 where c1 = 2);
select (1, "Abc", 3) != any(select * from t1);
select (2, "ABC", 3) != any(select * from t1);
select (2, "ABC", 3) != all(select * from t1);
select (2, "Abc", 3) != all(select * from t1);
## > 
select "Abc" > (select c2 from t1 where c1 = 1);
select "Abc" > any(select c2 from t1);
select "Abc" > all(select c2 from t1);

select (1, "Abc", 3) > (select * from t1 where c1 = 1);
select (1, "abc", 3) > (select * from t1 where c1 = 1);
--error 1241
select (2, "abc", 3) > all(select * from t1);
--error 1241
select (1, "abc", 3) > any(select * from t1);
## >= 
select "Abc" >= (select c2 from t1 where c1 = 1);
select "Abc" >= any(select c2 from t1);
select "Abc" >= all(select c2 from t1);

select (1, "Abc", 3) >= (select * from t1 where c1 = 1);
select (1, "ABc", 3) >= (select * from t1 where c1 = 1);
--error 1241
select (1, "Abc", 3) >= any(select * from t1);
--error 1241
select (2, "abc", 3) >= all(select * from t1);
## < 
select "Abc" < (select c2 from t1 where c1 = 1);
select "Abc" < all(select c2 from t1);
select "Abc" < any(select c2 from t1);

select (1, "Abc", 3) < (select * from t1 where c1 = 1);
select (1, "ABc", 3) < (select * from t1 where c1 = 1);
--error 1241
select (1, "abc", 3) < all(select * from t1);
--error 1241
select (2, "ABc", 3) < any(select * from t1);
## <= 
select "abc" <= (select c2 from t1 where c1 = 1);
select "abc" <= any(select c2 from t1);
select "abc" <= all(select c2 from t1);

select (1, "abc", 3) <= (select * from t1 where c1 = 1);
select (1, "ABc", 3) <= (select * from t1 where c1 = 1);
--error 1241
--error 1241
--error 1241
select (1, "abc", 3) <= all(select * from t1);
--error 1241
select (2, "ABC", 3) <= any(select * from t1);
#<=>
select "Abc" <=> (select c2 from t1 where c1 = 1);
--error 1064
select "Abc" <=> any(select c2 from t1);
--error 1064
select "Abc" <=> all(select c2 from t1);

select (1, "Abc", 3) <=> (select * from t1 where c1 = 1);
select (2, "Abc", 3) <=> (select * from t1 where c1 = 2);
--error 1064
select (1, "Abc", 3) <=> any(select * from t1 where c1 = 1);
--error 1064
select (2, "Abc", 3) <=> all(select * from t1 where c1 = 2);
#in
select "Abc" in (select c2 from t1);
--error 1064
select "Abc" in any(select c2 from t1);
--error 1064
select "Abc" in all(select c2 from t1);

select (2, "Abc", 3) in (select * from t1);
select (2, "ABC", 3) in (select * from t1);
--error 1064
select (2, "Abc", 3) in all(select * from t1);
--error 1064
select (2, "ABC", 3) in any(select * from t1);
#not in
select "Abc" not in (select c2 from t1);
--error 1064
select "Abc" not in any(select c2 from t1);
--error 1064
select "Abc" not in all(select c2 from t1);

select (2, "Abc", 3) not in (select * from t1);
--error 1064
select (2, "Abc", 3) not in all(select * from t1);
--error 1064
select (2, "ABC", 3) not in any(select * from t1);

--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1 (c1 int, c2 varchar(64) charset utf8 collate utf8_general_ci, c3 int);
insert into t1 value (1, "Abc", 3),( 2, "ABC", 3);
## =
select "Abc" = any(select c2 from t1);
select "Abc" = all(select c2 from t1);
select "Abc" = (select c2 from t1 where c1 = 1);
select "Abc" = (select c2 from t1 where c1 = 2);

select ("Abc", 3) = (select c2,c3 from t1 where c1 = 1);
select ("Abc", 3) = (select c2,c3 from t1 where c1 = 2);
select ("aBC", 3) = any(select c2,c3 from t1);
select ("aBCd", 3) = any(select c2,c3 from t1);
select ("Abc", 3) = any(select c2,c3 from t1);
select ("ABC", 3) = all(select c2,c3 from t1);
## !=
select "Abc" != (select c2 from t1 where c1 = 1);
select "Abc" != (select c2 from t1 where c1 = 2);
select "Abc" != any(select c2 from t1);
select "Abc" != all(select c2 from t1);
select "Abd" != all(select c2 from t1);

select ("Abc", 3) != (select c2,c3 from t1 where c1 = 1);
select ("Abc", 3) != (select c2,c3 from t1 where c1 = 2);
select ("Abc", 3) != any(select c2,c3 from t1);
select ("ABC", 3) != any(select c2,c3 from t1);
select ("ABC", 3) != all(select c2,c3 from t1);
## > 
select "Abc" > (select c2 from t1 where c1 = 1);
select "Abc" > any(select c2 from t1);
select "Abc" > all(select c2 from t1);

select ("Abc", 3) > (select c2,c3 from t1 where c1 = 1);
select ("abc", 3) > (select c2,c3 from t1 where c1 = 1);
## >= 
select "Abc" >= (select c2 from t1 where c1 = 1);
select "Abc" >= any(select c2 from t1);
select "Abc" >= all(select c2 from t1);
select "bbc" >= all(select c2 from t1);

select ("Abc", 3) >= (select c2,c3 from t1 where c1 = 1);
select ("ABc", 3) >= (select c2,c3 from t1 where c1 = 1);
##<
select "Abc" < (select c2 from t1 where c1 = 1);
select "Abc" < all(select c2 from t1);
select "Abc" < any(select c2 from t1);

select ("Abc", 3) < (select c2,c3 from t1 where c1 = 1);
select ("Bbc", 3) < (select c2,c3 from t1 where c1 = 1);
## <= 
select "abc" <= (select c2 from t1 where c1 = 1);
select "abb" <= (select c2 from t1 where c1 = 1);
select "abc" <= any(select c2 from t1);
select "1bc" <= all(select c2 from t1);

select ("abc", 3) <= (select c2,c3 from t1 where c1 = 1);
select ("DBc", 3) <= (select c2,c3 from t1 where c1 = 1);
#<=>
select "Abc" <=> (select c2 from t1 where c1 = 1);
select ("abc", 3) <=> (select c2,c3 from t1 where c1 = 2);
#in
select "Abc" in (select c2 from t1);
select "ABC" in (select c2 from t1);

select ("Abc", 3) in (select c2,c3 from t1);
select ("ABC", 3) in (select c2,c3 from t1);
#not in
select "Abc" not in (select c2 from t1);

select ("Abc", 3) not in (select c2,c3 from t1);
select ("bbc", 3) not in (select c2,c3 from t1);

drop table if exists t1;
create table t1 (c1 int, c2 int, c3 varchar(64) charset utf8 collate utf8_bin, c4 varchar(64) charset utf8 collate utf8_bin);
insert into t1 value (1, 1, "Abc", "Abc"), (1, 1, "Abc", "ABc"), (1, 1, "ABC", "Abc"),  (1, 1, "1BC", "Abc");
select * from t1 where (c1, c3) = (c2, c4);
select * from t1 where (1, c3) = (c2, c4);
select * from t1 where (c1, c3) = (1, c4);
select * from t1 where (1, c3) = (1, c4);
select * from t1 where (c1, c3) != (c2, c4);
select * from t1 where (1, c3) != (c2, c4);
select * from t1 where (c1, c3) != (1, c4);
select * from t1 where (1, c3) != (1, c4);
select * from t1 where (c1, c3) > (c2, c4);
select * from t1 where (1, c3) > (c2, c4);
select * from t1 where (c1, c3) > (1, c4);
select * from t1 where (1, c3) > (1, c4);
select * from t1 where (c1, c3) >= (c2, c4);
select * from t1 where (1, c3) >= (c2, c4);
select * from t1 where (c1, c3) >= (1, c4);
select * from t1 where (1, c3) >= (1, c4);
select * from t1 where (c1, c3) < (c2, c4);
select * from t1 where (1, c3) < (c2, c4);
select * from t1 where (c1, c3) < (1, c4);
select * from t1 where (1, c3) < (1, c4);
select * from t1 where (c1, c3) <= (c2, c4);
select * from t1 where (1, c3) <= (c2, c4);
select * from t1 where (c1, c3) <= (1, c4);
select * from t1 where (1, c3) <= (1, c4);
select * from t1 where (c1, c3) in ((c2, c4));
select * from t1 where (1, c3) in ((c2, c4));
select * from t1 where (c1, c3) in ((1, c4));
select * from t1 where (1, c3) in ((1, c4));
select * from t1 where (c1, c3) not in ((c2, c4));
select * from t1 where (1, c3) not in ((c2, c4));
select * from t1 where (c1, c3) not in ((1, c4));
select * from t1 where (1, c3) not in ((1, c4));
select * from t1 where (1, c3) not in ((1, c4), (2, c4));
select * from t1 where (1, c3) in ((1, c4), (2,c4));

drop table t1;
create table t1 (c1 int, c2 int, c3 varchar(64) charset utf8 collate utf8_general_ci, c4 varchar(64) charset utf8 collate utf8_general_ci);
insert into t1 value (1, 1, "Abc", "Abc"), (1, 1, "Abc", "ABc"), (1, 1, "ABC", "Abc"),  (1, 1, "1BC", "Abc");
