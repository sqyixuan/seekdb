--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

#owner: shanyan.g
#it's to test sys parameter weak_read_version_refresh_interval equals 0
#

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);

##修改配置项
connection obsys;
alter system set weak_read_version_refresh_interval = '50ms';
alter system set enable_monotonic_weak_read = true tenant = sys;
alter system set enable_monotonic_weak_read = true tenant = all_user;
alter system set enable_monotonic_weak_read = true tenant = all_meta;


connection conn1;
use test;
--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1(a int, b int);
insert into t1 values(1,0);
sleep 5;

select /*+read_consistency(weak)*/ * from t1 where a = 1;

connection obsys;
alter system set enable_monotonic_weak_read = false tenant = sys;
alter system set enable_monotonic_weak_read = false tenant = all_user;
alter system set enable_monotonic_weak_read = false tenant = all_meta;
sleep 5;


connection conn1;
use test;
update t1 set b = 1 where a = 1;
sleep 5;
select /*+read_consistency(weak)*/ * from t1 where a = 1;

connection obsys;
alter system set weak_read_version_refresh_interval = '50ms';
sleep 5;

connection conn1;
use test;
select /*+read_consistency(weak)*/ * from t1 where a = 1;

drop table if exists t1;
