--disable_warnings
DROP TABLE IF EXISTS t2;
DROP TABLE IF EXISTS t8;
--enable_warnings
CREATE TABLE t2(c1 int(83) DEFAULT NULL, c2 smallint(115) DEFAULT NULL) DEFAULT CHARSET = utf8mb4 COLLATE = utf8mb4_bin;
CREATE TABLE t8(c1 int(87) DEFAULT NULL) DEFAULT CHARSET = utf8mb4 COLLATE = utf8mb4_bin; 
INSERT INTO t8 VALUES (0),(1020);
INSERT INTO t2 VALUES (0, 442), (754, 1020);
SELECT A33.c1, A105.c1, A105.c2 FROM t8 A33 , t2 A105 WHERE A33.c1 = A105.c2 AND  A33.c1 = A105.c1 ORDER BY A33.c1, A105.c1;
DROP TABLE t2;
DROP TABLE t8;
