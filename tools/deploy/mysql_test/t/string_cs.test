# description: 字符串大小写+major freeze 组合的功能测试用例

--disable_warnings
drop table if exists t1;
--enable_warnings


create table t1 (pk varchar(20) primary key);
insert into t1 values('ABC');
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
select * from t1 where pk='abc';


select * from t1 where pk='abc';

