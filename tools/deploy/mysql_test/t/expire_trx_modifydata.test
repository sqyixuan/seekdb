# owner: xiaoyi.xy
# owner group: SQL3
# comment: this case is marked as expired in filter.py

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
####TITLE: expire
--disable_query_log
--source mysql_test/include/index_quick_major.inc
--real_sleep 1
--enable_query_log


--let $ip ='' 
--let $port ='' 
####CASE
--disable_warnings
drop table if exists t1, t2;
--enable_warnings
# int default 0
create table t1(pk int primary key, c1 int, c2 int default 0) EXPIRE_INFO ( pk < 10);
# timestamp default now()
create table t2(pk int primary key, c1 int, c2 timestamp default now()) EXPIRE_INFO ( pk < 10);

replace into t1(pk,c1) values(0,0);
replace into t2(pk,c1) values(0,0);

--source mysql_test/include/majorfreeze.inc

update t1 set c1=10 where pk = 0;
update t2 set c1=10 where pk = 0;

# select before cs start freeze
select pk, c1, c2 from t1 where pk=0;
--replace_column 3 createtime
select pk, c1, c2 from t2 where pk=0;

--source mysql_test/include/wait_daily_merge.inc

# select after freeze
select pk, c1, c2 from t1 where pk=0;
--replace_column 3 createtime
select pk, c1, c2 from t2 where pk=0;


--source mysql_test/include/wait_daily_merge.inc
####case:modify index columns
create index idx1 on t1(c1);

replace into t1(pk,c1) values(1,1);
replace into t2(pk,c1) values(1,1);

--disable_query_log
--enable_query_log
--source mysql_test/include/majorfreeze.inc

update t1 set c1=11 where pk = 1;
update t2 set c1=11 where pk = 1;

# select before cs start freeze
select pk, c1, c2 from t1 where pk=1;
--replace_column 3 createtime
select pk, c1, c2 from t2 where pk=1;

--source mysql_test/include/wait_daily_merge.inc

# select after freeze
select pk, c1, c2 from t1 where pk=1;
--replace_column 3 createtime

####case:modify unique index columns
drop index idx1 on t1;
create unique index idx1 on t1(c1);

replace into t1(pk,c1) values(3,3);
replace into t2(pk,c1) values(3,3);

--disable_query_log
--enable_query_log
--source mysql_test/include/majorfreeze.inc

update t1 set c1=11 where pk = 3;
update t2 set c1=11 where pk = 3;

# select before cs start freeze
select pk, c1, c2 from t1 where pk=3;
--replace_column 3 createtime
select pk, c1, c2 from t2 where pk=3;

--source mysql_test/include/check_all_idx_ok_unq.inc
--disable_query_log
--enable_query_log
--source mysql_test/include/majorfreeze.inc

update t1 set c1=13 where pk = 3;
update t2 set c1=13 where pk = 3;

--source mysql_test/include/check_all_idx_ok.inc
# select before cs start freeze
select pk, c1, c2 from t1 where pk=3;
--replace_column 3 createtime
select pk, c1, c2 from t2 where pk=3;

--disable_query_log
--enable_query_log
--source mysql_test/include/majorfreeze.inc
update t1 set c1=14 where pk = 3;
update t2 set c1=14 where pk = 3;

--source mysql_test/include/wait_daily_merge.inc

# select after freeze
select pk, c1, c2 from t1 where pk=3;
--replace_column 3 createtime
select pk, c1, c2 from t2 where pk=3;

#drop table t1, t2;


