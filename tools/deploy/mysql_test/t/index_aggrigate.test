--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

#owner: linlin.xll 
#owner group: SQL4
#description: Test index with aggregate functions
#tags: index

--source mysql_test/include/index_quick_major.inc
--real_sleep 1

--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(pk int primary key, a1 varchar(10) not null, a2 varchar(10));
create index i1 on t1(a1) storing(a2);
create index i2 on t1(a1,a2);

insert into t1 values
(1,'d','d4'),
(2,'d','d3'),
(3,'d','d2'),
(4,'d','d1'),
(5,'c','c1'),
(6,'c','c2'),
(7,'c','c3'),
(8,'c','c4'),
(9,'b','b2'),
(10,'b','b3'),
(11,'b','b1'),
(12,'b','b4'),
(13,'a','a4'),
(14,'a','a2'),
(15,'a','a3'),
(16,'a','a1')
;
--source mysql_test/include/check_all_idx_ok.inc

insert into t1 values
(17,'a','a1'),
(18,'b','b1'),
(19,'c','c1'),
(20,'d','d1');

# use i1
select a1,min(a2) from t1 group by a1 order by a1;
select /*+ index(t1 primary) */  a1,min(a2) from t1 group by a1 order by a1;
select a1,max(a2) from t1 group by a1 order by a1;
select /*+ index(t1 primary) */  a1,max(a2) from t1 group by a1 order by a1;



insert into t1 values(21,'a',NULL);
select a1,min(a2) from t1 group by a1 order by a1;
select /*+ index(t1 primary) */  a1,min(a2) from t1 group by a1 order by a1;
select a1,max(a2) from t1 group by a1 order by a1;
select /*+ index(t1 primary) */  a1,max(a2) from t1 group by a1 order by a1;

insert into t1 values(22,'c',NULL);
select a1,min(a2) from t1 group by a1 order by a1;
select /*+ index(t1 primary) */  a1,min(a2) from t1 group by a1 order by a1;
select a1,max(a2) from t1 group by a1 order by a1;
select /*+ index(t1 primary) */  a1,max(a2) from t1 group by a1 order by a1;

--error 1048
insert into t1 values(23,NULL,'a');
--error 1048
insert into t1 values(24,NULL,'b');
--error 1048
insert into t1 values(25,NULL,'c');
--error 1048
insert into t1 values(26,NULL,'d');

select a1,min(a2) from t1 where a1 is not NULL group by a1 order by a1;
select /*+ index(t1 primary) */  a1,min(a2) from t1 where a1 is not null group by a1 order by a1;
select a1,max(a2) from t1 where a1 is not null group by a1 order by a1;
select /*+ index(t1 primary) */  a1,max(a2) from t1 where a1 is not null group by a1 order by a1;

select a1,min(a2) from t1 group by a1 order by a1;
select /*+ index(t1 primary) */  a1,min(a2) from t1 group by a1 order by a1;
select a1,max(a2) from t1 group by a1 order by a1;
select /*+ index(t1 primary) */  a1,max(a2) from t1 group by a1 order by a1;


select sum(pk),a1||'&'||a2 from t1 group by a1,a2 order by a1,a2;
select /*+ index(t1 primary) */ sum(pk),a1||'&'||a2 from t1 group by a1,a2 order by a1,a2;
select sum(pk) as total,a1||'&'||a2 from t1 group by a1,a2 having total > 10 order by a1,a2;
select /*+ index(t1 primary) */ sum(pk) as total,a1||'&'||a2 from t1 group by a1,a2 having total > 10 order by a1,a2;

select a1,max(a2) from t1 where pk>=10 group by a1 order by a1 desc;
select /*+ index(t1 primary) */ a1,max(a2) from t1 where pk>=10 group by a1 order by a1 desc;

