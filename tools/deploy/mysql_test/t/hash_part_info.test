--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: zhaoziqian.zzq
# owner group: rs
# description:
# tags: ddl
#

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection default;
### 一级hash
--disable_warnings
drop table if exists tt;
--enable_warnings
let $tenant_id = `select effective_tenant_id()`;
create table tt(id int primary key, name char(20)) partition by hash(id) partitions 3;
connection obsys;
let $table_id = query_get_value(select table_id from oceanbase.__all_virtual_table where tenant_id = $tenant_id and table_name='tt', table_id, 1);
--disable_query_log
--replace_column 1 tenant_id 2 table_id 3 part_id 4 create_time 5 modify_time 7 schema_version 30 tablet_id
eval select * from oceanbase.__all_virtual_part where tenant_id = $tenant_id and  table_id=$table_id;
--enable_query_log
connection default;

### 一级range，二级hash
--disable_warnings
drop table if exists tt;
--enable_warnings

create table tt(id int primary key, name char(20)) partition by range(id) subpartition by hash(id) subpartitions 3 (partition p0 values less than (1), partition p1 values less than (10));
connection obsys;
let $table_id = query_get_value(select table_id from oceanbase.__all_virtual_table where tenant_id = $tenant_id and table_name='tt', table_id, 1);
--disable_query_log
--replace_column 1 tenant_id 2 table_id 3 part_id 4 create_time 5 modify_time 7 schema_version 30 tablet_id
eval select * from oceanbase.__all_virtual_part where tenant_id = $tenant_id and table_id=$table_id;
--replace_column 1 tenant_id 2 table_id 4 create_time 5 modify_time 7 schema_version
eval select * from oceanbase.__all_virtual_def_sub_part where tenant_id = $tenant_id and table_id=$table_id;
--enable_query_log
connection default;


### 一级hash，二级range
--disable_warnings
drop table if exists tt;
--enable_warnings

create table tt(id int primary key, name char(20)) partition by hash(id) subpartition by range(id) subpartition template (subpartition p0 values less than (1), subpartition p1 values less than(10)) partitions 3;
connection obsys;
let $table_id = query_get_value(select table_id from oceanbase.__all_virtual_table where tenant_id = $tenant_id and table_name='tt', table_id, 1);
--disable_query_log
--replace_column 1 tenant_id 2 table_id 3 part_id 4 create_time 5 modify_time 7 schema_version 30 tablet_id
eval select * from oceanbase.__all_virtual_part where tenant_id = $tenant_id and table_id=$table_id;
--replace_column 1 tenant_id 2 table_id 4 create_time 5 modify_time 7 schema_version
eval select * from oceanbase.__all_virtual_def_sub_part where tenant_id = $tenant_id and table_id=$table_id;
--enable_query_log
connection default;
