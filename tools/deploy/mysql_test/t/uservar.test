--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#### owner: yuchen.wyc
#### owner group: sql3
#### description: 用户变量测试
use test;
--disable_warnings
drop table if exists sb,sc,sd,se,sf,sg,sh,si,sj;
--enable_warnings
create table sb (a int primary key, b int);
insert into sb values(1,100);
insert into sb values(2,101);
insert into sb values(3,1003);
insert into sb values(4,1004);
insert into sb values(5,300000);
set @a=2;
set @b=3;
select @a:=@a+@b+b from sb;
select @a;
create table sc(a int primary key, b varchar(123), c int, d double);
set @a:=2;
set @b:="helloworld";
set @c=2.5;
insert into sc values(1,@b,@a,@c);
insert into sc values(2,@b,@c,@a);
insert into sc values(3,concat(@b,"helloworld"),@a,@c);
select * from sc;
update sc set c=@a;
update sc set d=@c;
select * from sc;
select coalesce(@b);
select cast(@c as signed int);
create table sd(a int);
insert into sd values(5),(4),(4),(3),(2),(2),(2),(1);
insert into sd values(@ghost:=12345);
select @ghost;
select * from sd;
create table se(a int primary key, b timestamp,c datetime(5));
set @a = timestamp'2003-01-01 23:00:00';
select @b:= cast('2003-01-01 23:00:00' as datetime);
insert into se values(1,@a,@b);
select * from se;
create table sf(a decimal(31,21));
insert into sf values(0);
select (@v:=a) <> (@v:=1) from sf;
################################################################
create table sg(a int);
insert into sg values (1), (2);
select distinct @a:=min(sg.a) from sg, sg as t2
group by @b:=(select count(*) > t2.a);
################################################################
--error 1525
set @a = timestamp'2003-01-01 24:00:00';
--error 1525
set @a = time'99:99:99';
#用户变量的序列化和反序列化
create table si (a int primary key) partition by hash(a) partitions 2;
insert into si values(0);
insert into si values(1);
insert into si values(2);
select a, @uv from si order by a;
set @uv = 9;
select a, @uv from si order by a;
##test for coercibility. Const & Column
select @helloworld, coercibility(@helloworld);                                                                                                                                               
set @v1=null, @v2=1, @v3=1.1, @v4=now();
# select coercibility(@v1),coercibility(@v2),coercibility(@v3),coercibility(@v4:=now());
# coercibility(@v1)	coercibility(@v2)	coercibility(@v3)	coercibility(@v4:=now())
#-2	2	2	2
#+2	2	5	2
# 用户变量无赋值时允许预计算提交后, @v3会进行预计算, 计算出的obj的collation level = 2
# 预计算的结果保存到params中时会进行一次obj的深拷. 对于number类型深拷后会将collation level设为默认值5
# 这样做其实是有问题的, 但是改动obj的深拷涉及的面太广, 暂时先覆盖case, 如果发现其它的bad case再修改obj的深拷函数
select coercibility(@v1),coercibility(@v2),coercibility(@v3),coercibility(@v4);
select @v1:=null, @v2:=1, @v3:=1.1;
select coercibility(@v1),coercibility(@v2),coercibility(@v3),coercibility(@v4:=now());
select coercibility(@v1:=null),coercibility(@v2:=1),coercibility(@v3:=1.1),coercibility(@v4:=now());
create table sj(a bigint,b decimal(5,3),c datetime, d time);
insert into sj values(1,2.5,"2010-01-01 11:11:11", "12:34:45.5");
select @v1:=a, @v2:=b, @v3:=c, @v4:=d from sj;
select coercibility(@v1),coercibility(@v2),coercibility(@v3),coercibility(@v4);
drop table if exists sb,sc,sd,se,sf,sg,si,sj;

#https://dev.mysql.com/doc/refman/5.7/en/user-variables.html
#User variables are written as @var_name, where the variable name var_name consists of alphanumeric characters, ., _, and $. 
#A user variable name can contain other characters if you quote it as a string or identifier 
#(for example, @'my-var', @"my-var", or @`my-var`).
#Note: ob support unquoted var_name consists of alphanumeric characters, ., _, and $,
#      support quoted var_name consists of alphanumeric characters, ., _, $, /, %', ", and `.

set @a.b=1, @c_d=2, @e$f=3;
select @a.b, @c_d, @e$f;
--error 1064
set @a~b=1;
--error 1064
set @a@b=1;
--error 1064
set @a!b=1;
--error 1064
set @a%b=1;
--error 1064
set @a^b=1;
--error 1064
set @a&b=1;
--error 1064
set @a*b=1;
--error 1064
set @a-b=1;
--error 1064
set @a+b=1;
--error 1064
set @a/b=1;
--error 1054
set @a=b=1;
--error 1064
set @a[b=1;
--error 1064
set @a(b=1;
--error 1064
set @a{b=1;
--error 1064
set @a|b=1;
--error 1064
set @a<b=1;

select @'a/b', @'a%b', @'a"b', @'a`b', @"a'b";
set @'a/b'=1, @'a%b'=2, @'a"b'=3, @'a`b'=4, @"a'b"=5;
select @'a/b', @'a%b', @'a"b', @'a`b', @"a'b";

select @a1, @'a1', @"a1", @`a1`, @a2, @'a2', @"a2", @`a2`, @a3, @'a3', @"a3", @`a3`, @a4,@'a4', @"a4", @`a4`;
set @a1=1, @'a2'=2, @"a3"=3, @`a4`=4;
select @a1, @'a1', @"a1", @`a1`, @a2, @'a2', @"a2", @`a2`, @a3, @'a3', @"a3", @`a3`, @a4,@'a4', @"a4", @`a4`;
