# owner: yuchen.wyc
# owner group: SQL3
# description: group_concat函数的简单测试

--disable_warnings
drop table if exists t1, t2;
--enable_warnings

#
# Bug#10201
#
create table t1 (a varchar(255) character set utf8mb4 collate utf8mb4_general_ci,
                 b varchar(255) character set utf8mb4);
insert into t1 values ('xxx','yyy');
select collation(a) from t1;
select collation(group_concat(a)) from t1;
#create table t2 select group_concat(a) as a from t1;
#show create table t2;
select collation(group_concat(a,_utf8mb4'test')) from t1;
--error 1300
select collation(group_concat(a,_utf8mb4 0xC1C2)) from t1;
#--error 1267
select collation(group_concat(a,b)) from t1;
drop table t1;
#drop table t2;

