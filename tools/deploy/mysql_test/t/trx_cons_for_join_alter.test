connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn2,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);

connection conn1;
set autocommit=0;

connection conn2;
set autocommit=0;

###2个事务同时修改一行，一个事务先提交,更新主键
connection conn1;
update tbl1 set  i3='abc' where i3='haha1'; 

connection conn2;
select * from  tbl1  where i3='haha1'; 

connection conn1;
commit;

connection conn2;
select * from  tbl1  where i1='1'; 
commit;

###2个事务同时修改一行，一个事务先提交,更新索引
connection conn1;
update tbl1 set  i1=100 where i3='haha2'; 

connection conn2;
select * from  tbl1  where i3='haha2'; 

connection conn1;
commit;

connection conn2;
select * from  tbl1  where i3='haha2'; 
commit;


###2个事务,1个事务修改a行，读b行，另外一个事务读a行，修改b行
connection conn1;
select * from tbl1 where i3 in ('haha4','haha5');
update tbl1 set  i1=400 where i3='haha4'; 
select * from tbl1 where i3='haha5'; 
select * from tbl1 where i3 in ('haha4','haha5');

connection conn2;
select * from tbl1 where i3 in ('haha4','haha5');
select * from tbl1 where i3='haha4'; 
update tbl1 set  i1=500 where i3='haha5'; 

connection conn1;
commit;
select * from tbl1 where i3 in ('haha4','haha5');

connection conn2;
commit;
select * from tbl1 where i3 in ('haha4','haha5');




###2个事务,1个事务修改a行，读b行，另外一个事务读a行，修改b行,在复合语句中
connection conn1;
select * from tbl1 where i3 in ('haha4','haha5');
update tbl1 set  i1=1400 where i3='haha4'; 
select * from tbl1 where i3='haha5';  

connection conn2;
select * from tbl1 where i3 in ('haha4','haha5');
update tbl1 set  i1=500 where i3='haha5'; 
select * from tbl1 where i3='haha4'; 

connection conn1;
commit;
select * from tbl1 where i3 in ('haha4','haha5');

connection conn2;
commit;
select * from tbl1 where i3 in ('haha4','haha5');
select i1,i3 from tbl1 order by 1, 2;
