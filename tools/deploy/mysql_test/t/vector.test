#bug  
--disable_warnings
drop table if exists test_t;
--enable_warnings
CREATE TABLE test_t (
gm_create  datetime default now() 
, gm_modify  datetime default now()
, table_id INT 
, endkey_16 INT
, endkey_17 INT
, endkey_18 VARCHAR(4056)
, ip VARCHAR(30) 
, port INT 
, startkey_16 INT
, startkey_17 INT
, startkey_18 VARCHAR(65536)
, cluster_id INT 
, data_version INT 
, checksum INT 
, row_checksum INT 
, column_checksum VARCHAR(2048) 
, row_count INT 
, data_size INT 
, status INT 
, PRIMARY KEY(table_id, endkey_16, endkey_17, endkey_18, ip, port)
) DEFAULT CHARSET = 'utf8', USE_BLOOM_FILTER = FALSE;


insert into test_t(table_id, endkey_16, endkey_17, endkey_18, ip, port) values(3003, 1,2,'from tablet 1','10.232.36.32', 47081);
insert into test_t(table_id, endkey_16, endkey_17, endkey_18, ip, port) values(3003, 4,5,'from tablet 2','10.232.36.32', 47081);
insert into test_t(table_id, endkey_16, endkey_17, endkey_18, ip, port) values(3003, 7,8,'from tablet 3','10.232.36.32', 47081);

--replace_column 1 time 2 time
select * from test_t where data_version is null AND ip = '10.232.36.32' and ROW(table_id, endkey_16,endkey_17,endkey_18, ip, port) >= (3003, 1,2,'from tablet 1', '10.232.36.32', 47081) and ROW(table_id, endkey_16,endkey_17,endkey_18, ip, port) <= (3003, 4,5,'from tablet 2', '10.232.36.32', 47081);

--disable_warnings
drop table if exists test1;
