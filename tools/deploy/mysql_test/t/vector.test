#link cases
--echo link
--echo and
select * from t3 where (c1, c2) > (0,1) and (c3, c4) < ('f','e');
select * from t3 where (c3, c4) >= ('a','b') and (c5, c6) <= ('2013-11-29 11:06:03','2013-11-29 11:06:04');
select * from t3 where (c3, c4) != ('c','c') and (c1, c6) = (-1,'2013-11-29 11:06:00');

select * from t3 where (c1, c2) > (2,3) and (c3, c4) < ('b','e');
select * from t3 where (c3, c4) >= ('e','f') and (c5, c6) <= ('2013-11-29 11:06:03','2013-11-29 11:06:04');
select * from t3 where (c3, c4) != ('c','c') and (c1, c6) = (1,'2013-11-29 11:06:00');

select * from t3 where (c1, c2) >= (0,1) and (c3,c6) >= ('d','2013-11-29 11:06:04');
select * from t3 where (c1, c2) <= (0,1) and (c3,c6) <= ('d','2013-11-29 11:06:04');
select * from t3 where (c1, c2) <= (2,2) and (c3,c4) >= ('d','d');

--echo or
select * from t3 where (c1, c2) < (0,1) or (c3, c4) > ('f','e');
select * from t3 where (c3, c4) <= ('c','b') or (c5, c6) >= ('2013-11-29 11:06:04','2013-11-29 11:06:05');
select * from t3 where (c3, c4) != ('c','c') or (c1, c6) = (-1,'2013-11-29 11:06:00');


select * from t3 where (c1, c2) < (-2,-2) or (c3, c4) > ('f','e');
select * from t3 where (c1, c2) < (0,1) or (c5, c6) > ('2013-11-29 11:06:05','2013-11-29 11:06:06');
select * from t3 where (c3, c4) < ('a','a') or (c5, c6) > ('2013-11-29 11:06:07','2013-11-29 11:06:07');
select * from t3 where (c3, c4) < ('e','f') or (c5, c6) > ('2013-11-29 11:06:01','2013-11-29 11:06:02');
select * from t3 where (c3, c4) != ('c','c') or (c1, c2) != (0,0);
select * from t3 where (c3, c4) != ('c','c') or (c1, c2) = (0,0);
select * from t3 where (c3, c4) != ('c','c') or (c1, c2) = (1,1);

--echo in
select * from t3 where (c1, c2) >= (-1,-1) and (c3,c4,c5) in (('a','a','2013-11-29 11:06:00'), ('b','b','2013-11-29 11:06:01'), ('c','c','2013-11-29 11:06:02'));
select * from t3 where (c1, c2) >= (-1,-1) and (c3,c4,c5) in (('a','a','2013-11-29 11:06:00'), ('b','b','2013-11-29 11:06:01'), ('c','c','2013-11-29 11:06:02'), ('e','e','2013-11-29 11:06:04')) and (c4,c6) <= ('b','2013-11-29 11:06:03');
select * from t3 where (c1, c2) >= (-1,-1) and (c3,c4,c5) in (('b','a','2013-11-29 11:06:00'));
select * from t3 where (c1,c2) <= (-1,-1) or (c3,c4) >= ('c','c') and (c5,c6) < ('2013-11-29 11:06:05','2013-11-29 11:06:05') and (c2,c3,c4) in ((-1,'a','a'), (1,'c','c')) and (c3,c4,c5) not in (('c','2013-11-29 11:06:02','2013-11-29 11:06:02'));

