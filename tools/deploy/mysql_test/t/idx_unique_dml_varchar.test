--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
--source mysql_test/include/index_quick_major.inc
#case:int as idx
--disable_warnings
drop table if exists tbl1;
--enable_warnings
create table tbl1 (pk int,i1 int, v2 varchar(80), i3 char(20),i4 float, d4 datetime(6),i5 decimal(5,3),i6 bool, primary key(pk));
replace into tbl1 values(1,1,'abc12','1agc',1.25,'2014-01-01 12:00:00',23.23,1),
                       (2,10,'23abc12','4agc1',-0.25,'2015-11-01 12:00:00',-23.230,0),
                       (3,201,'xx23abc12','cagc1',-2.25,'2015-11-21 11:20:10',3.231,1),
                       (4,80,'zx23abc12','zcagc1',2.25,'2013-01-21 11:20:10',-3.231,1),
                       (5,53,'cx23abc12','rcagc1',109.25,'2016-01-22 11:20:10',-13.131,0),
                       (6,78,'tx23abc12','icagc1',-109.25,'2014-09-16 16:24:00',-13.531,1),
                       (7,400,'yx23abc12','ocagc1',85.85,'2014-09-17 16:20:21',-93.131,0),
                       (8,50,'vx23abc12','wcagc1',-85.85,'2014-09-10 16:20:21',93.131,1),
                       (9,610,'ukx23abc12','pecagc1',-1.85,'2014-09-19 16:20:21',99.131,0),
                       (10,42,'kx23abc12','ecagc1',-85.86,'2014-09-18 16:20:21',-99.131,1),
                       (11,null,null,null,null,null,null,null);
create unique index idx_2 on tbl1(v2);
create unique index idx_7 on tbl1(i1,v2,i3,d4,i6);
--source mysql_test/include/check_all_idx_ok.inc
select date_sub(null, INTERVAL -6 DAY);  
select * from tbl1;
update  tbl1 set v2=concat(v2,'abc');
update  tbl1 set v2=substr(v2,1,10);
update  tbl1 set i3=concat(v2,'abc');
update  tbl1 set i3=substr(v2,1,10);
--error 1062
update  tbl1 set v2='abcd';
update  tbl1 set v2='abcd' where pk=1;
update  tbl1 set v2='abcd' where pk=1;
update  tbl1 set v2='abcd' where pk=1;
update  tbl1 set v2='abcd' where pk=1;
update  tbl1 set v2='abcd' where pk=1;
update  tbl1 set v2='abc12' where pk=2;

#update  tbl1 set d4=date_sub(d4, INTERVAL -6 DAY) ;
update  tbl1 set d4=date_sub(d4, INTERVAL -6 DAY) where d4 is not null;
#update  tbl1 set d4=date_add(d4, INTERVAL -6 DAY) ;
update  tbl1 set d4=date_add(d4, INTERVAL -6 DAY) where d4 is not null;
update  tbl1 set i5=i5+0.05;
update  tbl1 set i5=i5-0.05;
update  tbl1 set i6=i6 and 1;
select * from  tbl1 where v2>'a' and v2<'z';
select * from  tbl1 where v2>nvl('a','abc') and v2<'z';
select * from  tbl1 where v2>nvl(null,'abc') and v2<nvl(null,'z');
select * from  tbl1 where v2>concat('a','b') and v2<'z';
select * from  tbl1 where v2>=concat('a','b') and v2<'z';
select * from  tbl1 where v2>=concat('a','b') and v2<concat('z','z');
select * from  tbl1 where v2>=concat('a','b') and v2<=concat('z','z');
select * from  tbl1 where v2>=lower('ab') and v2<=upper('zz');
select * from  tbl1 where v2>=lower('ab') and v2<=lower('zz'); 
select * from  tbl1 where v2>=substr('abc12',1,3) and v2<=substr('zx23abc12',1,10);
select * from  tbl1 where v2>=concat(substr('abc12',1,3),'22') and v2<=substr('zx23abc12',1,10);
update   tbl1 set i1=i1+1-1 where v2>=concat(substr('abc12',1,3),'22') and v2<=substr('zx23abc12',1,10);
select * from  tbl1 where v2>=trim(both 'abc' FROM 'abcadfaabc') and  v2<=trim('_' from '_zholiday_');
update  tbl1 set v2=lower(upper(v2)) where v2>=trim(both 'abc' FROM 'abcadfaabc') and  v2<=trim('_' from '_zholiday_');
select * from tbl1;
update  tbl1 set v2=lower(upper(lower(v2))) where v2>=trim(both 'abc' FROM 'abcadfaabc') and  v2<=trim('_' from '_zholiday_');
select * from tbl1;
select * from  tbl1 where v2>=concat(trim(both 'abc' FROM 'abcadfaabc'),'a') and  v2<=concat(trim('_' from '_zholiday_'),'b');
prepare stmt1 from select * from tbl1 where v2>=concat(trim(both ? FROM 'abcadfaabc'),?) and  v2<=concat(trim('_' from '_zholiday_'),?);
set @a='abc';
set @b='a';
set @c='b';
execute stmt1 using @a, @b,@c;
select v2,pk  from tbl1 where v2>='a';  
select * from  tbl1 where v2 between 'a' and 'z';
select v2,pk  from tbl1 where v2>='a';  
select * from  tbl1 where v2 between 'a' and 'z';
select * from  tbl1 where v2 between nvl('a','ab') and nvl('z','zz');
select * from  tbl1 where v2 between  concat('a','b') and 'z';
select * from  tbl1 where v2 between   concat('a','b') and 'z';
select * from  tbl1 where v2 between  concat('a','b') and concat('z','z');
select * from  tbl1 where v2  between concat('a','b') and concat('z','z');
select * from  tbl1 where v2  between lower('ab') and upper('zz');
select * from  tbl1 where v2  between lower('ab') and lower('zz'); 
select * from  tbl1 where v2  between  substr('abc12',1,3) and substr('zx23abc12',1,10);
select * from  tbl1 where v2  between  concat(substr('abc12',1,3),'22') and substr('zx23abc12',1,10);
update  tbl1  set v2=lower(upper(lower(v2))) where v2  between  concat(substr('abc12',1,3),'22') and substr('zx23abc12',1,10);
select * from  tbl1 where v2  between trim(both 'abc' FROM 'abcadfaabc') and  trim('_' from '_zholiday_');
select * from  tbl1 where v2  between trim(both 'abc' FROM 'abcadfaabc') and  nvl(trim('_' from '_zholiday_'),'a');
select * from  tbl1 where v2>=coalesce(null,'abc','cde') and v2<coalesce(null,null,'varchar'); 
select *  from tbl1 where concat(v2,'a')>='a' and v2<='x'; 
