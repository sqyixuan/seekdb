--disable_warnings
drop table if exists nt,nt2;
--enable_warnings
create table nt (t1 decimal, t2 int, t3 int, primary key(t2));
create table nt1 (t1 decimal, t2 int, t3 int, primary key(t2));
create table nt2 (t1 decimal, t2 int, t3 int, primary key(t2,t3));
create index i1 on nt (t2, t3, split key(t2,t3));
create index i2 on nt2 (t2, split key(t2));
create index i2 on nt (t2, t3, split key(t3));
desc nt;
--source mysql_test/include/show_create_table_old_version.inc
show create table nt;
--disable_query_log
--source mysql_test/include/index_quick_major.inc
--real_sleep 1
--enable_query_log
--echo merge happens
--source mysql_test/include/majorfreeze.inc;
let $index_name = __idx_3006_i2;
--source mysql_test/include/check_all_idx_ok.inc
let $cnt=1000;
--disable_query_log
while($cnt)
{
eval insert into nt values($cnt,$cnt,$cnt);
eval insert into nt2 values($cnt,$cnt,$cnt);
dec $cnt;
}
--enable_query_log
--source mysql_test/include/majorfreeze.inc;
sleep 1;
let $index_name = __idx_3003_i1;
--source mysql_test/include/wait_daily_merge.inc
select * from nt where t1<=10;
select * from nt where t2<=10 and t3<=15;
