--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: dachuan.sdc
#owner group : sql2
#tags: ddl
connect (obsys1,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);

connection obsys1;
--disable_warnings
--disable_query_log
#call oceanbase.create_mysql_tenant_mini('tenant_test');
--source mysql_test/include/check_tenant_sync.inc
--enable_query_log
--enable_warnings

disconnect obsys1;
--echo connect(con1, localhost, root@tenant_test,,test);
let $__tenant_name__ = 'sys';
--source mysql_test/include/get_tenant_server.inc

connect (con1,$TE_SERVER_IP, root,,*NO-ONE*,$TE_SERVER_PORT);

--disable_warnings
DROP DATABASE IF EXISTS d6;
--enable_warnings
CREATE DATABASE d6;
#SHOW DATABASES ;
--error 1064
USE DATABASE nond6;
DROP DATABASE d6;
#SHOW DATABASES ;
connect (obsys1,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys1;

--disable_query_log
#call oceanbase.drop_tenant_force('tenant_test');
--enable_query_log
disconnect obsys1;
