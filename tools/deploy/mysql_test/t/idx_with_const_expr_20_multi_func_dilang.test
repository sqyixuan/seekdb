--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: dachuan.sdc
# owner group: SQL3
# description: 本case是为了测试加上索引后的一些函数运算和比较运算
# tags: cost

##
## Table cleaning
##
#
--disable_warnings
drop table if exists t1,t2;
--enable_warnings

#--source mysql_test/include/index_quick_major.inc
#
##
## Tests to check query_range with const expression with combination of multiple functions and operations
##
#
## Create database schema
#create table t1(
#  a1 char(3) primary key,
#  a2 int,
#  a3 char(3),
#  a4 float,
#  a5 datetime, index(a2), index(a3), index(a5)
#);
create table t1(
    a1 char(3) primary key,
    a2 int,
    a3 char(3),
    a4 float,
    a5 datetime
    );

  create table t2(
      a1 char(3) primary key,
      a2 char(17),
      a3 char(2),
      a4 char(3)
      );
#
