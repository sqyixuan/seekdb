# >>> Not supported(2014.9.17 - OceanBase 0.5.1.3 (r25917M) (Built Sep 16 2014 19:46:06)): int_column >= (expr with / or round(), type is numeric) will not go through index on int_column

## Test functions and operations on int
# - function floor() and ceil() are not supported on 051, while supported on 052 - 2014.9.16
#select * from t1 where a2>=ceil(0.50001) + floor(0.005) and a2<=round(10.087) - floor(1.035);
--replace_column 5 timestamp
select * from t1 where a2>=round(0.50001) + round(0.005) and a2<=round(10.087) - round(1.035);
--replace_column 5 timestamp
select * from t1 where a2>=1-(9-8)+(3*5)-45/3 and a2<=100%55-35;

--replace_column 5 timestamp
select * from t1 where round(0.50001) + round(0.005)<=a2 and round(10.087) - round(1.035)>=a2;
--replace_column 5 timestamp
select * from t1 where 1-(9-8)+(3*5)-45/3<=a2 and 100%55-35>=a2;

--replace_column 5 timestamp
select * from t1 where a2>length('abc')-3 and a2<length('ab')*5;

## Test functions and operations on varchar

--replace_column 5 timestamp
select * from t1 where a3>=concat('D', 'EE') and a3<=concat('M', 'PP');
--replace_column 5 timestamp
select * from t1 where a3>=concat(substr('ABCDE',4,1), substr('CCDDEE',5,2)) and a3<=concat(substr('LMNOP',2,1), substr('OOPPQQ',3,2));
--replace_column 5 timestamp
select * from t1 where a3>=concat(trim('  D  '), trim('  EE   ')) and a3<=concat(trim('  M  '), trim('  PP    '));
--replace_column 5 timestamp
select * from t1 where a3>=upper(concat(trim('  d  '), trim('  Ee   '))) and a3<=upper(concat(trim('  m  '), trim('  PP    ')));
--replace_column 5 timestamp
select * from t1 where a3>=upper(concat(trim('  d  '), trim('  Ee   '))) and a3<=lower(concat(trim('  m  '), trim('  PP    ')));
--replace_column 5 timestamp
select * from t1 where a3>=concat(upper(substr('abcde',4,1)), upper(substr('ccddee',5,2))) and a3<=concat(upper(substr('lmnop',2,1)), upper(substr('ooppqq',3,2)));

## Test functions and operations on numeric

--replace_column 5 timestamp
select * from t1 where a4>=0.75/10+round(1.001)-1 and a4<=0.2*0.4+4%2;

## Test functions and operations on timestamp

select a1,a2,a3,a4 from t1 where a5>=date_add(now(), interval -60 minute) and a5<=date_add(current_timestamp(), interval -10 second);
select a1,a2,a3,a4 from t1 where a5>=date_add(current_timestamp(), interval -60 minute) and a5<=date_add(current_timestamp(), interval -10 second);
select a1,a2,a3,a4 from t1 where a5>=date_add(current_timestamp(), interval -60 minute) and a5<=date_add(now(), interval -10 second);

select a1,a2,a3,a4 from t1 where a5>=date_sub(now(), interval 60 minute) and a5<=date_sub(current_timestamp(), interval -10 second);
select a1,a2,a3,a4 from t1 where a5>=date_sub(current_timestamp(), interval 60 minute) and a5<=date_sub(current_timestamp(), interval -10 second);
select a1,a2,a3,a4 from t1 where a5>=date_sub(current_timestamp(), interval 60 minute) and a5<=date_sub(now(), interval -10 second);

select a1,a2,a3,a4 from t1 where a5>=date_add(now(), interval -60 minute) and a5<=date_sub(current_timestamp(), interval 10 second);
select a1,a2,a3,a4 from t1 where a5>=date_add(current_timestamp(), interval -60 minute) and a5<=date_sub(current_timestamp(), interval 10 second);
select a1,a2,a3,a4 from t1 where a5>=date_add(current_timestamp(), interval -60 minute) and a5<=date_sub(now(), interval 10 second);


