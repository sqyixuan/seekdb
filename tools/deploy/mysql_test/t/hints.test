create table t1(a int) consistent_mode = static;
--error 1064
create table t1(a int) consistent_mode = weak;
--error 1064
create table t1(a int) consistent_mode = strong;


--disable_warnings
drop table if exists t2;
--enable_warnings
create table t2 (c1 int primary key, c2 int) partition by hash(c1) partitions 5;
insert into t2 values(0,0),(5,5),(10,10);
insert into t2 values(1,1),(6,6),(11,11);
insert into t2 values(2,2),(7,7),(12,12);
insert into t2 values(3,3),(8,8),(13,13);
insert into t2 values(4,4),(9,9),(14,14);
select * from t2 order by c1;
