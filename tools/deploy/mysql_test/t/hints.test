--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: link.zt
#owner group: sql1
# tags: optimizer, outline

--disable_warnings
drop table if exists t;
--enable_warnings
create table t (c1 int primary key, c2 int);
insert into t values(1,2),(3,4),(5,6);

select @@session.ob_query_timeout;
set @saved_ob_query_timeout = @@session.ob_query_timeout;
select * from t;
--error 4012
select /*+ QUERY_TIMEOUT(1)*/ * from t;
set @@session.ob_query_timeout = 1;
--error 4012
select * from t;
set @@session.ob_query_timeout = @saved_ob_query_timeout;
select * from t;

#select /*+client(obdatasource) client_version(1.2.0) mysql_driver(5.1)*/ 'client_version';
sleep 2;
select /*+ read_consistency(weak)*/ * from t;
select /*+ read_consistency(weak)*/ * from t where c1=1;
select /*+ read_consistency(strong)*/ * from t where c1=1;
select  /*+ READ_CONSISTENCY(STRONG)*/ * from t;
select  /*+ READ_CONSISTENCY(WEAK)*/ * from t;
select  /*+ READ_CONSISTENCY(FROZEN)*/ * from t;
select  /*+ READ_CONSISTENCY(STATIC)*/ * from t;
select /*+ read_static=true*/ * from t;

update /*+ hotspot */ t set c2 = 1 where c1=1;
update t set c2=3 where c1=3;
update /*+ hotspot */ t set c2 = 1 where c1 = 1;
update /*+ hotspot */ t set c2=3 where c1=3;
update t set c2 = 1 where c1 = 1;

drop table t;

#fix bug issue-20059914
--disable_warnings
drop table if exists t;
drop table if exists tt;
--enable_warnings
create table t(a int, b int, c int);
create table tt(a int, b int, c int);

insert into t values(1,2,3),(2,3,4);
explain outline insert /*+FROZEN_VERSION(1070)*/into tt select * from t;
explain outline insert into tt select /*+FROZEN_VERSION(1070)*/* from t;

drop table t;
drop table tt;

