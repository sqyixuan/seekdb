select /*+parallel(1)*/ * from t2 order by c1;
select /*+parallel(3)*/ * from t2 order by c1;
select /*+parallel(129)*/ * from t2 order by c1;
select /*+parallel(128)*/ * from t2 order by c1;
select * from t2 order by c1;
select /*+parallel(0)*/ * from t2 order by c1;
select /*+parallel(1)*/ * from t2 order by c1;
select /*+parallel(3)*/ * from t2 order by c1;
select /*+parallel(129)*/ * from t2 order by c1;
select /*+parallel(128)*/ * from t2 order by c1;

# BUG T12946785
--disable_query_log
--disable_warnings
drop table if exists rpt_dim_bpp4p_timeup_item, rpt_bpp4p_timeup_adgroup;
CREATE TABLE `rpt_dim_bpp4p_timeup_item` (
 `custid` bigint(20) NOT NULL COMMENT 'custid',
 `memberid` bigint(20) NOT NULL COMMENT 'memberid',
 `itemid` bigint(20) NOT NULL COMMENT '宝贝id',
 `itemdate` date DEFAULT NULL COMMENT '上架日期',
 `p4pdate` date DEFAULT NULL COMMENT '直通车开始推广日期，未上车为空',
 `thedate` date DEFAULT NULL COMMENT '更新日期',
 PRIMARY KEY (`custid`, `memberid`, `itemid`),
 KEY `idx_custid_itemdate_p4pdate` (`custid`, `itemdate`, `p4pdate`) BLOCK_SIZE 16384
);
CREATE TABLE `rpt_bpp4p_timeup_adgroup` (
 `thedate` date NOT NULL COMMENT '日期',
 `custid` bigint(20) NOT NULL COMMENT '客户ID',
 `memberid` bigint(20) NOT NULL COMMENT '广告主ID',
 `campaignid` bigint(20) NOT NULL COMMENT '推广计划id',
 `adgroupid` bigint(20) NOT NULL COMMENT '推广组id',
 `itemid` bigint(20) DEFAULT NULL COMMENT '宝贝 id',
 `p4pdate` date DEFAULT NULL COMMENT '上车日期',
 `potentialindex` bigint(20) DEFAULT NULL COMMENT '潜力指数',
 `impression1d` bigint(20) DEFAULT NULL COMMENT '广告展现量',
 `validclickcnt1d` bigint(20) DEFAULT NULL COMMENT '有效点击',
 `validprice1d` bigint(20) DEFAULT NULL COMMENT '有效消耗',
 `ranksum1d` bigint(20) DEFAULT NULL COMMENT '排名总和',
 `finclickcnt1d` bigint(20) DEFAULT NULL COMMENT '财务点击',
 `finprice1d` bigint(20) DEFAULT NULL COMMENT '财务消耗',
 `finclickuv1d` bigint(20) DEFAULT NULL COMMENT '财务点击uv',
 `finclicknewuv1d` bigint(20) DEFAULT NULL COMMENT '财务点击新客uv',
 `ealipaycnt15d` bigint(20) DEFAULT NULL COMMENT '15天累计ALIPAY成交笔数',
 `ealipayamt15d` bigint(20) DEFAULT NULL COMMENT '15天累计ALIPAY成交金额',
 `eitemcollcnt15d` bigint(20) DEFAULT NULL COMMENT '15天累计收藏宝贝数',
 `ecartcnt15d` bigint(20) DEFAULT NULL COMMENT '15天累计宝贝放购物车数',
 `esearchpv15d` bigint(20) DEFAULT NULL COMMENT '自然流量曝光',
 PRIMARY KEY (`custid`, `thedate`, `memberid`, `campaignid`, `adgroupid`)
) DEFAULT CHARSET = utf8mb4 COMPRESSION = 'lz4_1.0' REPLICA_NUM = 3 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 10 COMMENT = '直通车adgroup数据：定时上架 vs 普通上架'
partition by range columns(thedate) subpartition by hash(custid) subpartitions 4
(partition p20170605 values less than ('2017-06-05'),
partition p20170612 values less than ('2017-06-12'),
partition p20170619 values less than ('2017-06-19'),
partition p20170626 values less than ('2017-06-26'),
partition p20170703 values less than ('2017-07-03'),
partition p20170710 values less than ('2017-07-10'),
partition p20170717 values less than ('2017-07-17'),
partition p20170724 values less than ('2017-07-24'),
partition p20170731 values less than ('2017-07-31'),
partition p20170807 values less than ('2017-08-07'),
partition p20170814 values less than ('2017-08-14'),
partition p20170821 values less than ('2017-08-21'),
partition p20170828 values less than ('2017-08-28'),
partition p20170904 values less than ('2017-09-04'),
partition p20170911 values less than ('2017-09-11'),
partition p20170918 values less than ('2017-09-18'),
partition p20170925 values less than ('2017-09-25'),
partition p20171002 values less than ('2017-10-02'),
partition p20171009 values less than ('2017-10-09'),
partition p20171016 values less than ('2017-10-16'),
partition p20171023 values less than ('2017-10-23'),
partition p20171030 values less than ('2017-10-30'),
partition p20171106 values less than ('2017-11-06'),
partition p20171113 values less than ('2017-11-13'),
partition p20171120 values less than ('2017-11-20'));
--enable_query_log
--enable_warnings
--sleep 3

explain select /*+ read_consistency(weak), use_hash(t1 t2)*/ t1.thedate as thedate, round(sum(if(t2.is_time=0, esearchpv15d, 0))/sum(if(t2.is_time=0, 1, 0)),0) as esearchpv15d, round(sum(if(t2.is_time=0, ecartcnt15d, 0))/sum(if(t2.is_time=0, 1, 0)),0) as ecartcnt15d, round(sum(if(t2.is_time=0, eitemcollcnt15d, 0))/sum(if(t2.is_time=0, 1, 0)),0) as eitemcollcnt15d, round(sum(if(t2.is_time=1, esearchpv15d, 0))/sum(if(t2.is_time=1, 1, 0)),0) as tesearchpv15d, round(sum(if(t2.is_time=1, ecartcnt15d, 0))/sum(if(t2.is_time=1, 1, 0)),0) as tecartcnt15d, round(sum(if(t2.is_time=1, eitemcollcnt15d, 0))/sum(if(t2.is_time=1, 1, 0)),0) as teitemcollcnt15d, round((sum(if(t2.is_time=0, finprice1d, 0))/100)/sum(if(t2.is_time=0, finclickcnt1d, 0)),2) as avgcost, round((sum(if(t2.is_time=1, finprice1d, 0))/100)/sum(if(t2.is_time=1, finclickcnt1d, 0)),2) as tavgcost, sum(if(t2.is_time=0, finprice1d, 0)) as finprice1d, sum(if(t2.is_time=0, finclickcnt1d, 0)) as finclickcnt1d, sum(if(t2.is_time=1, finprice1d, 0)) as tfinprice1d, sum(if(t2.is_time=1, finclickcnt1d, 0)) as tfinclickcnt1d from rpt_bpp4p_timeup_adgroup t1 join ( select custid,itemid, if(itemdate='2017-11-10 00:00:00', 1, if(itemdate is null, 0 , -1)) as is_time from rpt_dim_bpp4p_timeup_item where custid=1103742813 and p4pdate in ( ('2017-10-27 00:00:00') ) ) t2 on t1.custid=t2.custid and t1.itemid=t2.itemid where t1.custid =1103742813 and t2.is_time in(0,1) and thedate >= '2017-10-27 00:00:00' and thedate <= '2017-11-17 00:00:00' group by thedate order by thedate;

explain select /*+ read_consistency(weak), use_hash(t1 t2) index(rpt_dim_bpp4p_timeup_item idx_custid_itemdate_p4pdate) */ t1.thedate as thedate, round(sum(if(t2.is_time=0, esearchpv15d, 0))/sum(if(t2.is_time=0, 1, 0)),0) as esearchpv15d, round(sum(if(t2.is_time=0, ecartcnt15d, 0))/sum(if(t2.is_time=0, 1, 0)),0) as ecartcnt15d, round(sum(if(t2.is_time=0, eitemcollcnt15d, 0))/sum(if(t2.is_time=0, 1, 0)),0) as eitemcollcnt15d, round(sum(if(t2.is_time=1, esearchpv15d, 0))/sum(if(t2.is_time=1, 1, 0)),0) as tesearchpv15d, round(sum(if(t2.is_time=1, ecartcnt15d, 0))/sum(if(t2.is_time=1, 1, 0)),0) as tecartcnt15d, round(sum(if(t2.is_time=1, eitemcollcnt15d, 0))/sum(if(t2.is_time=1, 1, 0)),0) as teitemcollcnt15d, round((sum(if(t2.is_time=0, finprice1d, 0))/100)/sum(if(t2.is_time=0, finclickcnt1d, 0)),2) as avgcost, round((sum(if(t2.is_time=1, finprice1d, 0))/100)/sum(if(t2.is_time=1, finclickcnt1d, 0)),2) as tavgcost, sum(if(t2.is_time=0, finprice1d, 0)) as finprice1d, sum(if(t2.is_time=0, finclickcnt1d, 0)) as finclickcnt1d, sum(if(t2.is_time=1, finprice1d, 0)) as tfinprice1d, sum(if(t2.is_time=1, finclickcnt1d, 0)) as tfinclickcnt1d from rpt_bpp4p_timeup_adgroup t1 join ( select custid,itemid, if(itemdate='2017-11-10 00:00:00', 1, if(itemdate is null, 0 , -1)) as is_time from rpt_dim_bpp4p_timeup_item where custid=1103742813 and p4pdate in ( ('2017-10-27 00:00:00') ) ) t2 on t1.custid=t2.custid and t1.itemid=t2.itemid where t1.custid =1103742813 and t2.is_time in(0,1) and thedate >= '2017-10-27 00:00:00' and thedate <= '2017-11-17 00:00:00' group by thedate order by thedate;

select /*+TRANS_PARAM('enable_early_lock_release' 'true')*/* from t2;
