#owner: zhanyue.zzy
#owner group: SQL1
--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
####case:唯一索引的更新加compond语句；
--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1(pk int primary key, i1 int, v1 varchar(20));
create unique index idx1 on t1(pk,v1);
--source mysql_test/include/check_all_idx_ok.inc

#insett+update
#单行
replace into t1 values(1,1,'a'),(2,2,'b'),(3,3,'c');
insert into t1 values(1,1,'a') when row_count(update t1 set pk=4 where pk=1) = 1;
--error 1062
insert into t1 values(2,2,'b') when row_count(update t1 set pk=3 where pk=2) = 1;
select * from t1;
--error 1062
insert into t1 values(5,5,'e') when row_count(update t1 set pk=5 where pk=3) = 1;
select * from t1;

#多行
delete from t1 where pk<10;
replace into t1 values(1,1,'a'),(2,2,'b'),(3,3,'c');
insert into t1 values(2,2,'b') when row_count(update t1 set pk=4 where pk>1 and pk<3)=1;
--error 1062
insert into t1 values(3,3,'c') when row_count(update t1 set pk=5 where pk>3 and pk<6)=1;
--error 1062
insert into t1 values(7,7,'a') when row_count(update t1 set pk=7 where pk>1 and pk<3)=1;
select * from t1;

#updatet+insert
#单行
delete from t1 where pk<10;
replace into t1 values(1,1,'a'),(2,2,'b'),(3,3,'c'); 
insert into t1 values(4,4,'d');
update t1 set pk=5 where pk=4 ;
--error 1062
insert into t1 values(5,5,'e');
--error 1062
update t1 set pk=2 where pk=5;
--error 1062
update t1 set pk=6 where pk=1 when row_count(insert into t1 values(6,6,'f'))=1;
select * from t1;

#多行
delete from t1 where pk<10;
replace into t1 values(1,1,'a'),(2,2,'b'),(3,3,'c');
--error 1062
update t1 set pk=4 where pk>=3 and pk<5 when row_count(insert into t1 values(4,4,'d'));
update t1 set pk=4 where pk>=3 and pk<5 when row_count(insert into t1 values(5,5,'e'));
--error 1062
update t1 set pk=6 where pk>=1 and pk<3 when row_count(insert into t1 values(7,7,'f'));
--error 1062
update t1 set pk=8 where pk>=3 and pk<5 when row_count(insert into t1 values(4,4,'d'));
select * from t1;

#select...insert...update
delete from t1 where pk<10;
replace into t1 values(1,1,'a'),(2,2,'b'),(3,3,'c');
#单行
select * from t1 where pk=1 when row_count(insert into t1 values(1,1,'b') when row_count(update t1 set pk=4 where pk=1) = 1)=1;
--error 1062
select * from t1 where pk=3 when row_count(insert into t1 values(2,2,'c') when row_count(update t1 set pk=3 where pk=2) = 1)=1;
--error 1062
select * from t1 where pk=6 when row_count(insert into t1 values(6,6,'c') when row_count(update t1 set pk=6 where pk=2) = 1)=3;
#多行
delete from t1 where pk<10;
replace into t1 values(1,1,'a'),(2,2,'b'),(3,3,'c');
select * from t1 where pk=2 when row_count(insert into t1 values(2,2,'c') when row_count(update t1 set pk=4 where pk>1 and pk<3) = 1)=1;
--error 1062
select * from t1 where pk=2 when row_count(insert into t1 values(2,2,'c') when row_count(update t1 set pk=3 where pk>1 and pk<3) = 1)=1;
--error 1062
select * from t1 where pk=2 when row_count(insert into t1 values(2,2,'c') when row_count(update t1 set pk=6 where pk>2 and pk<6) = 2)=1;

#select...update...insert
#单行
delete from t1 where pk<10;
replace into t1 values(1,1,'a'),(2,2,'b'),(3,3,'c');
insert into t1 values(4,4,'d');
select * from t1 where pk=2 when row_count(update t1 set pk=5 where pk=4) =1;
insert into t1 values(4,4,'d');
--error 1062
select * from t1 where pk=2 when row_count(update t1 set pk=3 where pk=4) =1;
--error 1062
insert into t1 values(4,4,'d');
--error 1062
select * from t1 where pk=2 when row_count(update t1 set pk=5 where pk=4) =1;
--error 1062
select * from t1 where pk=2 when row_count(update t1 set pk=6 where pk=3 when row_count(insert into t1 values(6,6,'d')) =1) =1;

#多行
delete from t1 where pk<10;
replace into t1 values(1,1,'a'),(2,2,'b'),(3,3,'c');
--error 5064
select * from t1 where pk=2 when row_count(update t1 set pk=5 where pk>3 and pk<5 when row_count(insert into t1 values(4,4,'d')) =1) =1;
select * from t1;
--error 5064
select * from t1 where pk=2 when row_count(update t1 set pk=6 where pk>=3 and pk<5 when row_count(insert into t1 values(7,7,'d')) =1) =2;
select * from t1 where pk=2 when row_count(update t1 set pk=6 where pk>=3 and pk<5 when row_count(insert into t1 values(4,4,'d')) =1) =1;

#update...delete...update
#单行
delete from t1 where pk<10;
replace into t1 values(1,1,'a'),(2,2,'b'),(3,3,'c'),(4,4,'d'),(5,5,'e');
#update t1 pk=11 where pk=1 when row_count(delete from t1 where pk=11 when row_count(update t1 set pk=11 where pk=1))=1)=1;
#update t1 pk=2 where pk=12 when row_count(delete from t1 where pk=2 when row_count(update t1 set pk=12 where pk=2)=1)=1;
#update t1 pk=13 where pk=3 when row_count(delete from t1 where pk=3 when row_count(update t1 set pk=13 where pk=3)=1)=1;
#update t1 pk=15 where pk=5 when row_count(delete from t1 where pk=14 when row_count(update t1 set pk=14 where pk=4)=1)=1;
select * from t1;

#多行
delete from t1 where pk<20;
replace into t1 values(1,1,'a'),(2,2,'b'),(3,3,'c'),(4,4,'d'),(5,5,'e');
#update t1 pk=15 where pk>=5 when row_count(delete from t1 where pk=11 when row_count(update t1 set pk=11 where pk>=1 and pk<2)=1)=1;
#update t1 pk=16 where pk>5 when row_count(delete from t1 where pk=11 when row_count(update t1 set pk=11 where pk>1 and pk<4)=2)=1;
#update t1 pk=13 where pk>2 and pk<=4 when row_count(delete from t1 where pk=13 when row_count(update t1 set pk=13 where pk=3)=1)=1;
select * from t1;















