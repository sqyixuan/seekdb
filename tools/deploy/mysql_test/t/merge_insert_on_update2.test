--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: dachuan.sdc
# owner group: SQL3
# description:  验证insert on duplicate key的更新功能

--disable_warnings
drop table if exists sbtest;
--enable_warnings

--real_sleep 1
CREATE TABLE sbtest (id INTEGER  NOT NULL, name varchar(1024), whenn datetime(6),  k integer  DEFAULT '0' NOT NULL,pad char(60) DEFAULT '' NOT NULL, whenn1 datetime(6), stat1 bool, PRIMARY KEY  (id,name,whenn) ) ;

--echo insert 100 rows to ups;
--let $count=1
while($count < 101)
{ 
    --let $stmt=INSERT INTO sbtest(id, name, whenn, k, pad, whenn1) VALUES($count,'junyue','2013-1-6 14:44:00', 1,'qqqqqqqqqqwwwwwwwwwweeeeeeeeeerrrrrrrrrrtttttttttt', '2013-1-7 14:44:00') on duplicate key update k = id;
    eval $stmt;
    inc $count; 
}

--echo merge
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc

--echo insert another 100 rows to ups

--let $count=101
while($count < 201)
{ 
    --let $stmt=INSERT INTO sbtest(id, name, whenn, k, pad, whenn1) VALUES($count,'junyue','2013-1-6 14:44:00', 1,'qqqqqqqqqqwwwwwwwwwweeeeeeeeeerrrrrrrrrrtttttttttt', '2013-1-7 14:44:00') on duplicate key update k = id;
    eval $stmt;
    inc $count; 
}

--echo merge
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc

--echo insert another 100 rows to ups
--let $count=201
while($count < 301)
{ 
  --let $stmt=INSERT INTO sbtest(id, name, whenn, k, pad, whenn1) VALUES($count,'junyue','2013-1-6 14:44:00', 1,'qqqqqqqqqqwwwwwwwwwweeeeeeeeeerrrrrrrrrrtttttttttt', '2013-1-7 14:44:00') on duplicate key update k = id;
  eval $stmt;
  inc $count; 
}

# update 
  --let $count=1
while($count < 101)
{
  eval insert into sbtest(name, id, whenn, k, pad, whenn1) VALUES('junyue', $count, '2013-1-6 14:44:00', 1,'qqqqqqqq', '2013-1-7 14:44:00') on duplicate key update k = id + 1000;
  inc $count; 
}
  --let $count=101
while($count < 201)
{
  eval insert into sbtest(k, pad, whenn1, whenn, id, name) VALUES(1,'qqqqqqqq', '2013-1-7 14:44:00', '2013-1-6 14:44:00', $count,'junyue') on duplicate key update k = id + 1000;
  inc $count; 
}
  --let $count=201
while($count < 301)
{
  eval insert into sbtest(id, name , whenn, k, pad, whenn1) VALUES($count,'junyue','2013-1-6 14:44:00', 1,'qqqqqqqq', '2013-1-7 14:44:00') on duplicate key update k = id + 1000;
  inc $count; 
}

--echo merge
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc

  --let $count=1
while($count < 101)
{
  eval select * from sbtest where id = $count; 
  inc $count; 
}
  --let $count=101
while($count < 201)
{
  eval select * from sbtest where id = $count;
  inc $count; 
}
  --let $count=201
while($count < 301)
{
  eval select * from sbtest where id = $count;
  inc $count; 
}
insert into sbtest(id, name , whenn, k, pad, whenn1) VALUES(301,'junyue','2013-1-6 14:44:00', 1,'qqqqqqqq', '2013-1-7 14:44:00') on duplicate key  update k = id;


drop table sbtest;
