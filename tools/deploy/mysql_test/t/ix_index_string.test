--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
##owner: dachuan.sdc
###owner group: SQL1
###tags: ddl
#description:case trans from mysql
--disable_warnings
DROP TABLE IF EXISTS t2;
--enable_warnings
CREATE TABLE t2(c1 CHAR(50) NULL);
CREATE INDEX i1 ON t2(c1);
SHOW TABLES like 't2'; 
let $ENGINE=`select variable_value from information_schema.global_variables where variable_name='STORAGE_ENGINE'`;
#--replace_result $ENGINE ENGINE " PAGE_CHECKSUM=0" ""
 --source mysql_test/include/show_create_table_old_version.inc
 show create table t2; DROP TABLE t2; SHOW TABLES like 't2';
