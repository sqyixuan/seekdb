--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: yibo.tyf
#owner group: sql1
# tags: optimizer

####TITEL: test index with order by
--disable_query_log
source mysql_test/include/index_quick_major.inc;
--real_sleep 10
--disable_warnings
drop table if exists t1,t2;
--enable_warnings
--enable_query_log

create table t1(pk1 int, c1 int, c2 int, c3 int, primary key(pk1));
create table t2(pk1 int, c1 varchar(20), c2 varchar(20), primary key(pk1));
create unique index i1 on t1(c2);
create unique index i2 on t1(c1, c2);
create unique index i3 on t2(c1);

insert into t1(pk1, c1, c2, c3) values
(0,0,0,0),
(1,0,1,0);

insert into t2 values
(1,'xxxc','a'),
(2,'xxxb','a'),
(3,'xxxa','a'),
(4,'yyyy','a');

--source mysql_test/include/check_all_idx_ok.inc

insert into t1(pk1, c1, c2, c3) values
(2,1,2,1),
(3,1,3,1);

#### case 1: select
# case 1-1, optimized;
echo case 1-1, optimized;
select * from t1 where c2=0 order by c2;
select * from t1 where c1=0 order by c1;
select * from t1 where c1=0 order by c2;
select * from t1 where c1=0 order by c1, c2;
select * from t1 where c1=0 and c2>0 order by c2;
select * from t1 where c1=0 and c2>0 order by c1, c2;

select * from t1 where c2=0 order by c2 limit 2;
select * from t1 where c1=0 order by c1 limit 3;
select * from t1 where c1=0 order by c2 limit 4;
select * from t1 where c1=0 order by c1, c2 limit 5;
select * from t1 where c1=0 and c2>0 order by c2 limit 6;
select * from t1 where c1=0 and c2>0 order by c1, c2 limit 7;

