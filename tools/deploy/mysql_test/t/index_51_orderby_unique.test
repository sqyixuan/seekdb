--enable_result_log

update t1 set c1=c1, c2=c2*10, c3=c3*10 where c1=0 and c2<1 order by c2;
update t1 set c1=c1, c2=c2*10, c3=c3*10 where c1>=0 and c1<1 and c2>0 order by c1, c2;
update t1 set c1=c1, c2=c2*10, c3=c3*10 where c1=0 and c2<0 order by c2 limit 3;
update t1 set c1=c1, c2=c2*10, c3=c3*10 where c1>=0 and c1<=1 order by c1, c2 limit 3;
select * from t1;

