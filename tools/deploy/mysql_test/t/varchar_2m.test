--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: dachuan.sdc
#owner group : SQL1
#description : 长varchar
--disable_warnings
drop table if exists t1;
--enable_warnings

#1.5M每行
create table t1(pk varchar(20) primary key, c1 varchar(65536),c2 varchar(65536),c3 varchar(65536),c4 varchar(65536),c5 varchar(65536),c6 varchar(65516));

--disable_query_log
let $cnt=100;
while($cnt)
{
  eval insert into t1 values('$cnt',repeat('a',65536),repeat('b',65536),repeat('c',65536),repeat('d',65536),repeat('e',65536),repeat('f',65516));
  dec $cnt;
}
--enable_query_log

select pk,length(c1),length(c2),length(c3),length(c4),length(c5),length(c6) from t1;

drop table t1;
