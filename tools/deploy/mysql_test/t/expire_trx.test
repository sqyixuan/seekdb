# owner: xiaoyi.xy
# owner group: SQL3
# comment: this case is marked as expired in filter.py

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
--disable_abort_on_error
####TITLE: expire
--disable_query_log
--source mysql_test/include/index_quick_major.inc
--real_sleep 1
--enable_query_log


####CASE
--echo case 1 : varchar
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(c0 int primary key,c1 varchar(1024)) EXPIRE_INFO ( c1 = 'd');
insert into t1 values(1,'i'),(2,'s'),(3,'D');
select c0,c1 from t1;
update t1 set c1='d' where c0=1;
update t1 set c1='d' where c0=2;
select c0,c1 from t1;

--echo merge happens
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc

select c0,c1 from t1;
drop table t1;

####CASE
--echo case 2 : expire row
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(c0 int primary key,c1 int) EXPIRE_INFO =(c1 < 0);
insert into t1 values(1,1),(2,1),(3,1);
select c0,c1 from t1;

update t1 set c1=-1 where c0=1;
select c0,c1 from t1;

--echo merge happens
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc

select c0,c1 from t1;
drop table t1;

####CASE
--echo case 3 : int + rows
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(c0 int primary key,c1 int) EXPIRE_INFO ( c1 < 0);
insert into t1 values(1,1),(2,1),(3,1);
select c0,c1 from t1;

update t1 set c1=-1 where c0=1;
update t1 set c1=-1 where c0=2;
update t1 set c1=-1 where c0=3;
select c0,c1 from t1;

--disable_query_log
--enable_query_log
--echo merge happens
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc

select c0,c1 from t1;
drop table t1;

