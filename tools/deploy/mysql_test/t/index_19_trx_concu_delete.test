--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: jingyan.kfy
# owner group: transaction
# description: foobar
# tags: cost
####TITLE:并发事务同时delete操作，查询索引表、数据表、回表
####
--disable_query_log
--source mysql_test/include/index_quick_major.inc
--real_sleep 1
--disable_warnings
drop table if exists t1;
--enable_warnings
--enable_query_log

create table t1(pk int primary key, a int, b int, c varchar(1024));
create index i1 on t1(b) storing(c);

--source mysql_test/include/check_all_idx_ok.inc

connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn2,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
insert into t1 values(1,1,1,'a'),(2,1,1,'a');
replace into t1 values(3,1,1,'a'),(4,1,1,'a');

####CASE:并发事务delete，无锁冲突，commit
--echo CASE1
connection conn1;
set autocommit=0;
delete from t1 where pk=1;
delete from t1 where pk=2;

connection conn2;
set autocommit=0;
delete from t1 where pk=3;
delete from t1 where pk=4;
select pk, b, c from t1 where b>0 and b<10;
select pk, a, b from t1 where pk>0 and pk<10;
select * from t1 where b>0 and b<10;

connection conn1;
select pk, b, c from t1 where b>0 and b<10;
select pk, a, b from t1 where pk>0 and pk<10;
select * from t1 where b>0 and b<10;
commit;
select pk, b, c from t1 where b>0 and b<10;
select pk, a, b from t1 where pk>0 and pk<10;
select * from t1 where b>0 and b<10;
commit;

connection conn2;
select pk, b, c from t1 where b>0 and b<10;
select pk, a, b from t1 where pk>0 and pk<10;
select * from t1 where b>0 and b<10;
commit;
select pk, b, c from t1 where b>0 and b<10;
select pk, a, b from t1 where pk>0 and pk<10;
select * from t1 where b>0 and b<10;
commit;

####CASE:并发事务delete，有锁冲突，commit
--echo CASE2
connection conn1;
set autocommit=0;
replace into t1 values(1,1,1,'a'),(2,1,1,'a');
commit;
delete from t1 where pk=1;

connection conn2;
set autocommit=0;
delete from t1 where pk=2;
--error 1205,4012
delete from t1 where pk=1;
--error 1205,4012
update t1 set b=4 where pk=1;
--error 1205,4012
insert into t1 values(1,2,2,'b');
--error 1205,4012
replace into t1 values(1,3,3,'c');
select pk, b, c from t1 where b>0 and b<10;
select pk, a, b from t1 where pk>0 and pk<10;
select * from t1 where b>0 and b<10;

connection conn1;
select pk, b, c from t1 where b>0 and b<10;
select pk, a, b from t1 where pk>0 and pk<10;
select * from t1 where b>0 and b<10;
commit;
select pk, b, c from t1 where b>0 and b<10;
select pk, a, b from t1 where pk>0 and pk<10;
select * from t1 where b>0 and b<10;
commit;

connection conn2;
select pk, b, c from t1 where b>0 and b<10;
select pk, a, b from t1 where pk>0 and pk<10;
select * from t1 where b>0 and b<10;
commit;
select pk, b, c from t1 where b>0 and b<10;
select pk, a, b from t1 where pk>0 and pk<10;
select * from t1 where b>0 and b<10;
commit;

####CASE:并发事务，事务1 delete，事务2 做其他dml，无锁冲突
--echo CASE3
connection conn1;
set autocommit=0;
replace into t1 values(1,1,1,'a'),(2,1,1,'a'),(3,1,1,'a');
commit;
delete from t1 where pk=1;

connection conn2;
set autocommit=0;
delete from t1 where pk=2;
update t1 set a=a+1, b=b+1, c='b' where pk=3;
replace into t1 values(3,3,3,'c');
insert into t1 values(4,1,1,'a');
select pk, b, c from t1 where b>0 and b<10;
select pk, a, b from t1 where pk>0 and pk<10;
select * from t1 where b>0 and b<10;

connection conn1;
select pk, b, c from t1 where b>0 and b<10;
select pk, a, b from t1 where pk>0 and pk<10;
select * from t1 where b>0 and b<10;
commit;
select pk, b, c from t1 where b>0 and b<10;
select pk, a, b from t1 where pk>0 and pk<10;
select * from t1 where b>0 and b<10;
commit;

connection conn2;
select pk, b, c from t1 where b>0 and b<10;
select pk, a, b from t1 where pk>0 and pk<10;
select * from t1 where b>0 and b<10;
commit;
select pk, b, c from t1 where b>0 and b<10;
select pk, a, b from t1 where pk>0 and pk<10;
select * from t1 where b>0 and b<10;
commit;

####CASE: 多个事务delete,事务1 commit，事物2 rollback
--echo CASE4
connection conn1;
set autocommit=0;
replace into t1 values(5,1,1,'a'),(6,1,1,'a');
commit;
delete from t1 where pk=5;

connection conn2;
set autocommit=0;
delete from t1 where pk=6;
select pk, b, c from t1 where b>0 and b<10;
select pk, a, b from t1 where pk>0 and pk<10;
select * from t1 where b>0 and b<10;

connection conn1;
select pk, b, c from t1 where b>0 and b<10;
select pk, a, b from t1 where pk>0 and pk<10;
select * from t1 where b>0 and b<10;
commit;
select pk, b, c from t1 where b>0 and b<10;
select pk, a, b from t1 where pk>0 and pk<10;
select * from t1 where b>0 and b<10;

connection conn2;
select pk, b, c from t1 where b>0 and b<10;
select pk, a, b from t1 where pk>0 and pk<10;
select * from t1 where b>0 and b<10;
rollback;
select pk, b, c from t1 where b>0 and b<10;
select pk, a, b from t1 where pk>0 and pk<10;
select * from t1 where b>0 and b<10;

drop table t1;
