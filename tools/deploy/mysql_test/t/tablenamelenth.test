--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: xiaoyi.xy
# owner group: SQL2
# description:
#
####test table name length
--disable_warnings
drop table if exists test;
--enable_warnings
create table test(a int primary key);
select * from test;


--error 1103
drop table if exists  ;
####表名过长
--error 1103
create table (a int primary key);
--error 1059
drop table if exists testadgdgfdggggggggggggggggggggggggggggggjfasdladgfdsdssssssssssssssssssssssssssdffffffffffffffffffffffffffffgggggggggggggggfffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffff;
--error 1059
create table testadgdgfdggggggggggggggggggggggggggggggjfasdladgfdsdssssssssssssssssssssssssssdffffffffffffffffffffffffffffgggggggggggggggfffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffffff(a int primary key);


#
######## 表名错误边界测试
#
--error 1103
create table aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaasxxxxxxxx(a int primary key);
--error 1103
drop table if exists aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaasxxxxxxxx;
## 再减一个字符，就换了一个错误码
--error 1059
create table aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaasxxxxxxx(a int primary key);
--error 1059
drop table if exists aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaasxxxxxxx;
## 最后的边界
--error 1059
drop table if exists  bbbbbbbbbbbbbbbbbbbbbbbbaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa;
## success
--disable_warnings
drop table if exists  bbbbbbbbbbbbbbbbbbbbbbbbaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa;
--enable_warnings
create table bbbbbbbbbbbbbbbbbbbbbbbbaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa(a int primary key);
--disable_warnings
drop table if exists  bbbbbbbbbbbbbbbbbbbbbbbbaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa;
--enable_warnings

