##case:replace many times
--disable_query_log
--let $loop=500
while  ($loop)
{
  replace into tbl1 values(21,'now','haha21',1.6256,'2014-05-04 12:00:00',-10.235);
  dec $loop;
}
--enable_query_log
####case:update many times
--disable_query_log
--let $loop=2000
while  ($loop)
{
  update tbl1 set i1=200 where i3='haha2';
  dec $loop;
}
--enable_query_log
####case:type convert
update tbl1 set i1='24' where i3='haha2'; 
delete from tbl1 where i1=1000;
delete from tbl1 where i1='1000';
