--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: bin.lb
# owner group: SQL3
# description:
# tags: ddl, timeout
--require mysql_test/r/2ups.require

select svr_type from oceanbase.__all_server where svr_type=4;

--disable_warnings
drop table if exists t1,t2;
--enable_warnings

create table t1(pk int primary key, a int);

insert into t1 values(1, 0),(2,0),(0,0);

if($NEW_MASTER_UPS_IP == None)
{
    --echo two update servers are required
    --exit
}
alter system switch updateserver master;
--error 38
insert into t1 values(3, 0),(5,0),(4,0);

--real_sleep 1
insert into t1 values(3, 0),(5,0),(4,0);
--error S42000
insert into t1 values(1, 0),(2,0),(0,0);

drop table t1;
