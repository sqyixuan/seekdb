#owner: link.zt
#owner group: sql1
#description: Test union stack overflow
#Test union stack overflow
#tags: dml,executor 
--disable_abort_on_error
--disable_warnings
drop table if exists seller;
--enable_warnings

set ob_query_timeout = 300000000;
set ob_trx_timeout = 300000000;

create table seller(seller_id bigint primary key, status int);
insert into seller values(10000000,2);

let $cnt= 1000;
let $num = 10000000;
let $sql=select a.seller_id from seller a inner join ( select 9999999 as seller_id ;
while($cnt > 0)
{
  let $sql=$sql union all select $num as seller_id;
  dec $cnt;
  inc $num;
}
let $sql=$sql ) b on a.seller_id = b.seller_id where a.status = 2;
--disable_query_log
eval $sql;
--enable_query_log

let $cnt= 500;
let $num = 10000000;
let $sql=select a.seller_id from seller a inner join ( select 9999999 as seller_id, 0 as c1, 0 as c2, 0 as c3, 0 as c4, 0 as c5, 0 as c6, 0 as c7, 0 as c8, 0 as c9, 0 as c10, 0 c11, 0 c12, 0 c13, 0 c14, 0 c15, 0 c16, 0 c17, 0 c18, 0 c19, 0 c20;
while($cnt > 0)
{
  let $sql=$sql union all select $num as seller_id, $num as c1, $num as c2, $num as c3, $num as c4, $num as c5, $num as c6, $num as c7, $num as c8, $num as c9, $num as c10, $num c11, $num c12, $num c13, $num c14, $num c15, $num c16, $num c17, $num c18, $num c19, $num c20;
  dec $cnt;
  inc $num;
}
let $sql=$sql ) b on a.seller_id = b.seller_id where a.status = 2;
--disable_query_log
eval $sql;
--enable_query_log

