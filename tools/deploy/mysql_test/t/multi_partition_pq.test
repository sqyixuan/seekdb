select /*+ parallel(16) */ count(*) from t1 where c1 in (1, 1000, 20000, 25000, 30000, 50000, 90000, 99999);
select /*+ parallel(64) */ count(*) from t1 where c1 in (1, 1000, 20000, 25000, 30000, 50000, 90000, 99999);
select /*+ parallel(2) */ count(*) from t1 where c1 in (1, 1000, 20000, 25000, 30000, 50000, 90000, 99999) or (c1 > 30001 and c1 < 40000);
select /*+ parallel(4) */ count(*) from t1 where c1 in (1, 1000, 20000, 25000, 30000, 50000, 90000, 99999) or (c1 > 30001 and c1 < 40000);
select /*+ parallel(9) */ count(*) from t1 where c1 in (1, 1000, 20000, 25000, 30000, 50000, 90000, 99999) or (c1 > 30001 and c1 < 40000);
select /*+ parallel(16) */ count(*) from t1 where c1 in (1, 1000, 20000, 25000, 30000, 50000, 90000, 99999) or (c1 > 30001 and c1 < 40000);
select /*+ parallel(64) */ count(*) from t1 where c1 in (1, 1000, 20000, 25000, 30000, 50000, 90000, 99999) or (c1 > 30001 and c1 < 40000);

select /*+ parallel(4) */ count(*) from t1_p where c1 in (1, 1000, 20000, 25000, 30000, 50000, 90000, 99999);
select /*+ parallel(8) */ count(*) from t1_p where c1 in (1, 1000, 20000, 25000, 30000, 50000, 90000, 99999);
select /*+ parallel(15) */ count(*) from t1_p where c1 in (1, 1000, 20000, 25000, 30000, 50000, 90000, 99999);
select /*+ parallel(16) */ count(*) from t1_p where c1 in (1, 1000, 20000, 25000, 30000, 50000, 90000, 99999);
select /*+ parallel(64) */ count(*) from t1_p where c1 in (1, 1000, 20000, 25000, 30000, 50000, 90000, 99999);
select /*+ parallel(2) */ count(*) from t1_p where c1 in (1, 1000, 20000, 25000, 30000, 50000, 90000, 99999) or (c1 > 30001 and c1 < 40000);
select /*+ parallel(4) */ count(*) from t1_p where c1 in (1, 1000, 20000, 25000, 30000, 50000, 90000, 99999) or (c1 > 30001 and c1 < 40000);
select /*+ parallel(9) */ count(*) from t1_p where c1 in (1, 1000, 20000, 25000, 30000, 50000, 90000, 99999) or (c1 > 30001 and c1 < 40000);
select /*+ parallel(16) */ count(*) from t1_p where c1 in (1, 1000, 20000, 25000, 30000, 50000, 90000, 99999) or (c1 > 30001 and c1 < 40000);
select /*+ parallel(64) */ count(*) from t1_p where c1 in (1, 1000, 20000, 25000, 30000, 50000, 90000, 99999) or (c1 > 30001 and c1 < 40000);

explain extended_noaddr select /*+ parallel(2) */ * from t1 where c1 in (1, 10000, 50000, 90000);
select /*+ parallel(2) */ * from t1 where c1 in (1, 100000, 500000, 900000);
explain extended_noaddr select /*+ parallel(2) */ * from t1_p where c1 in (1, 10000, 50000, 90000);
select /*+ parallel(2) */ * from t1_p where c1 in (1, 100000, 500000, 900000);

## secondary index
explain extended_noaddr select /*+ parallel(2) */ count(*) from t1 where c2 in (1, 100000, 500000, 900000);
select /*+ parallel(2) */ count(*) from t1 where c2 in (1, 100000, 500000, 900000);
select count(*) from t1 where c2 in (1, 100000, 500000, 900000);

explain extended_noaddr select /*+ parallel(2) */ count(*) from t1_p where c2 in (1, 100000, 500000, 900000);
select /*+ parallel(2) */ count(*) from t1_p where c2 in (1, 100000, 500000, 900000);
select count(*) from t1_p where c2 in (1, 100000, 500000, 900000);

explain extended_noaddr select /*+ parallel(2) */ count(*) from t1 where (c2 > '1' and c2 < '2') or (c2 > '6' and c2 < '7') or (c2 > '8' and c2 < '9') ;
select /*+ parallel(2) */ count(*) from t1 where (c2 > '1' and c2 < '2') or (c2 > '6' and c2 < '7') or (c2 > '8' and c2 < '9') ;
select count(*) from t1 where (c2 > '1' and c2 < '2') or (c2 > '6' and c2 < '7') or (c2 > '8' and c2 < '9') ;

explain extended_noaddr select /*+ parallel(2) */ count(*) from t1_p where (c2 > '1' and c2 < '2') or (c2 > '6' and c2 < '7') or (c2 > '8' and c2 < '9') ;
select /*+ parallel(2) */ count(*) from t1_p where (c2 > '1' and c2 < '2') or (c2 > '6' and c2 < '7') or (c2 > '8' and c2 < '9') ;
select count(*) from t1_p where (c2 > '1' and c2 < '2') or (c2 > '6' and c2 < '7') or (c2 > '8' and c2 < '9') ;

## multi-table, parallelism disabled at the moment
explain extended_noaddr select /*+ parallel(2) use_nl(a b) */ * from t1 a, t1 b where a.c1 in (1, 1000, 20000, 25000, 30000, 50000, 90000, 99999) and a.c1 = b.c1;
explain extended_noaddr select /*+ parallel(2) use_nl(a b) */ * from t1_p a, t1_p b where a.c1 in (1, 1000, 20000, 25000, 30000, 50000, 90000, 99999) and a.c1 = b.c1;

## parallelism must be specified
explain extended_noaddr select /*+ parallel */ * from t1;
explain extended_noaddr select /*+ parallel */ * from t1_p;

# virtual table is not supported
explain extended_noaddr select /*+ parallel(2) */ * from oceanbase.V$OB_PLAN_CACHE_STAT;

## empty table, nothing to parallelize
explain extended_noaddr select /*+ parallel(2) */ * from t2;
select /*+ parallel(2) */ * from t2;

#TODO(叶提)：需要处理一下分区内并行的task order
explain extended_noaddr select /*+ parallel(2) */* from t1 order by c1 desc;

## clean up
drop table t1;
drop table t2;
drop table t1_p;
drop database multi_partition_pq;

