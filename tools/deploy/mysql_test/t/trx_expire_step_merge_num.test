# owner: xiaoyi.xy
# owner group: SQL3
# comment: this case is marked as expired in filter.py

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
--source mysql_test/include/index_quick_major.inc
--disable_warnings
drop table if exists tbl1,tbl2;
--enable_warnings

create table tbl1 (i1 int, v2 varchar(80), i3 char(20),i4 float, d4 datetime(6),i5 decimal(5,3), primary key(i1)) progressive_merge_num=3;
create table tbl2 (i1 int, v2 varchar(80), i3 char(20),i4 float, d4 datetime(6), i5 decimal(5,3), primary key(i1)) progressive_merge_num=5;
insert into tbl1 values(1,'now','haha',1.6256,'2014-05-04 12:00:00',-10.235);
insert into tbl1 values(2,'now','haha',-1.6256,'2014-05-04 12:00:00',1.243);
insert into tbl1 values(3,'now','haha',1.656,'2014-05-04 12:00:00',-1.45);
insert into tbl2 values(1,'now','haha',1.6256,'2014-05-04 12:00:00',3.45);
insert into tbl2 values(2,'now1','haha',1.6256,'2014-05-04 12:00:00',-0.25);
insert into tbl2 values(3,'now2','haha',1.6256,'2014-05-04 12:00:00',0.253);
insert into tbl2 values(4,'now3','haha',1.6256,'2014-05-04 12:00:00',1.677);
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
let $tbl_id1 = query_get_value(select table_id from  oceanbase.__all_virtual_table where table_name='tbl1', table_id, 1);
let $tbl_id2 = query_get_value(select table_id from  oceanbase.__all_virtual_table where table_name='tbl2', table_id, 1);
eval select  step_merge_start_version,step_merge_end_version from __chunkserver_tablet_dump where table_id=$tbl_id1;
eval select  step_merge_start_version,step_merge_end_version from __chunkserver_tablet_dump where table_id=$tbl_id2;
alter table  tbl1  add column c2 char(90);  
sleep 1;
insert into tbl1 values(4,'now','haha',1.6256,'2014-05-04 12:00:00',-10.235,'ab');
insert into tbl1 values(5,'now','haha',1.6256,'2014-05-04 12:00:00',-10.235,'ab');
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
eval select  step_merge_start_version,step_merge_end_version from __chunkserver_tablet_dump where table_id=$tbl_id1;
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
eval select  step_merge_start_version,step_merge_end_version from __chunkserver_tablet_dump where table_id=$tbl_id1;
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
eval select  step_merge_start_version,step_merge_end_version from __chunkserver_tablet_dump where table_id=$tbl_id1;
alter table tbl1 set progressive_merge_num=1;
sleep 1;
alter table  tbl1 drop  column c2 ;
sleep 1;
insert into tbl1 values(6,'now','haha',1.6256,'2014-05-04 12:00:00',-10.235);
insert into tbl1 values(7,'now','haha',1.6256,'2014-05-04 12:00:00',-10.235);
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
eval select  step_merge_start_version,step_merge_end_version from __chunkserver_tablet_dump where table_id=$tbl_id1;
--disable_parsing
--let $loop=3

while($loop)
{
--disable_warnings
drop table if exists tbl3;
--enable_warnings
create table tbl3 (i1 int, v2 varchar(80), i3 char(20),i4 float, d4 datetime(6), i5 decimal(5,3), primary key(i1)) progressive_merge_num=5,EXPIRE_INFO (d4<date_add(merging_frozen_time(),interval -15 minute));
--disable_query_log
begin;
let $i=0;
while($i < 10000)
{
    eval insert into tbl3 values($i,'1ab_a','$i',1.656, date_add(now(), INTERVAL -$i second),-1.345);
    inc $i;
}
commit;
--enable_query_log
alter table tbl3 alter column v2 set  default 'hello';
sleep 1;
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
--echo 1st freeze
select count(*) from  tbl3;
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
select count(*) from  tbl3;
--echo 2st freeze
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
select count(*) from  tbl3;
--echo 3st freeze
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
select count(*) from  tbl3;
--echo 4st freeze
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
--echo 5st freeze
select count(*) from  tbl3;
dec $loop;
}
 --enable_parsing
