--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

#owner: linlin.xll
#owner group: SQL1
#description: foobar
#tags: optimizer 

#set @@session.ob_enable_transformation = 0;
--disable_warnings
drop database if exists yts_db;
--enable_warnings
create database yts_db;
use yts_db;

--disable_warnings
drop table if exists agg_table,agg_table_1,agg_pt_table,type_table;
--enable_warnings
create table agg_table (c1 int, c2 int, c3 int, c4 int, c5 int, primary key (c2,c3), key(c5, c4), unique key(c3, c5));
create table agg_table_1(c1 int, c2 int primary key, c3 int);
create table agg_pt_table (c1 int , c2 int primary key) partition by hash (c2) partitions 3;

--echo ## NULL test
select max(c2) from agg_table;
select max(c3) from agg_table;
select min(c2) from agg_table;
select min(c3) from agg_table;
select max(c2) from agg_pt_table;
select min(c2) from agg_pt_table;


--echo ## insert values into agg_table
insert into agg_table values
(1,1,1,1,1),
(1,2,2,2,2),
(1,4,4,4,4),
(1,5,5,5,5),
(1,9,9,9,9),
(1,3,3,3,3),
(1,6,6,6,6),
(1,10,10,10,10),
(1,7,7,7,7),
(1,8,8,8,8);

--echo ## insert values into agg_table_1
insert into agg_table_1 values
(1,1,1),
(1,2,2),
(1,4,4),
(1,5,5),
(1,9,9),
(1,3,3),
(1,6,6),
(1,10,10),
(1,7,7),
(1,8,8),
(1,11,11),
(1,12,12);

--echo insert valeus into app_pt_table
insert into agg_pt_table values (1,1);
insert into agg_pt_table values (1,2);
insert into agg_pt_table values (1,3);
insert into agg_pt_table values (1,4);
insert into agg_pt_table values (1,5);
insert into agg_pt_table values (1,6);
insert into agg_pt_table values (1,7);
insert into agg_pt_table values (1,8);
insert into agg_pt_table values (1,9);
insert into agg_pt_table values (1,10);
insert into agg_pt_table values (1,11);
insert into agg_pt_table values (1,12);


--echo ## simple test
select max(c2) from agg_table;
select max(c3) from agg_table;
select min(c2) from agg_table;
select min(c3) from agg_table;

--echo ## index test;
select max(c4) from agg_table;
select max(c3) from agg_table;
select min(c4) from agg_table;
select min(c3) from agg_table;

--echo ## const prefix index
select max(c4) from agg_table where c5 = 1;
select max(c4) from agg_table where c5 is TRUE;
select max(c4) from agg_table where c5 = 1 and c1 = 1;

--echo ## alias test
select max(c2) as max from agg_table;
select max(c3) as max from agg_table;
select min(c2) as min from agg_table;
select min(c3) as min from agg_table;

--echo ## condition test
select max(c2) as max from agg_table where c2 < 5;
select max(c2) as max from agg_table where c3 < 5;

--echo ## having test
select min(c2) as min from agg_table having min(c2) < 5;
select min(c3) as min from agg_table having (select 10 from dual) > min(c3);
select max(c2) as max from agg_table having false;
select max(c3) as max from agg_table having true;

--echo ## multi partition table
select max(c2) from agg_pt_table;
select min(c2) from agg_pt_table;
select c2 from agg_pt_table partition(p1);
select max(c2) from agg_pt_table partition(p1);
select min(c2) from agg_pt_table partition(p1);

--echo ## with some constant expressions
select 5, max(c2) from agg_table;
select max(c3), 5 from agg_table;
select 5, min(c2) from agg_table;
select min(c3), 5 from agg_table;
select 5, 5, min(c2), floor(5) from agg_table;
select abs(-55), max(c3), 3 + 2, 5 from agg_table;

--echo ## subquery test
select * from (select max(c2) as max from agg_table) as tmp_table;
## multi partition bug
## select min(agg_pt_table.c2) from agg_pt_table where agg_pt_table.c2 > (select max(agg_table.c2) from agg_table);
## select min(agg_pt_table.c2) from agg_pt_table where agg_pt_table.c2 > (select distinct 10 from agg_table);
select min(c2) from agg_table where c2 > (select 8);
select min(c2) from agg_table_1 where c2 > (select max(agg_table.c2) from agg_table) ;
select min(agg_pt_table.c2) from agg_pt_table where agg_pt_table.c2 > 10;
select * from agg_pt_table where agg_pt_table.c2 > (select max(c2) from agg_table);

--echo ## test for different type column
create table type_table(c0 int primary key, c1 float , c2 decimal(10,5) , c3 datetime , c4 varchar(10) unique key, key(c1, c2), key (c2, c3), key(c3, c4), key(c4,c1));
insert into type_table values
(1, 1.1, 1.1, '1990-01-01 00:00:00', '1.1'),
(2, 2.2, 2.2, '1990-02-02 00:00:00', '2.2'),
(3, 3.3, 3.3, '1990-03-03 00:00:00', '3.3'),
(4, 4.4, 4.4, '1990-04-04 00:00:00', '4.4'),
(5, 5.5, 5.5, '1990-05-05 00:00:00', '5.5');
select max(c1) from type_table;
select max(c2) from type_table;
select max(c3) from type_table;
select max(c4) from type_table;

--echo ## others
SELECT 1 FROM agg_pt_table WHERE 1 = (SELECT MIN(agg_pt_table.c2) FROM agg_table);

--echo ## test normal any/all
select * from agg_table_1 where c2 > any (select c2 from agg_table);
select * from agg_table_1 where c2 > all (select c2 from agg_table);
select * from agg_table_1 where c2 < any (select c2 from agg_table);
select * from agg_table_1 where c2 < all (select c2 from agg_table);
select * from agg_table_1 group by c2 > any (select c2 from agg_table);
select * from agg_table_1 group by c2 > all (select c2 from agg_table);
select * from agg_table_1 group by c2 < any (select c2 from agg_table);
select * from agg_table_1 group by c2 < all (select c2 from agg_table);
select * from agg_table_1 having c2 > any (select c2 from agg_table);
select * from agg_table_1 having c2 > all (select c2 from agg_table);
select * from agg_table_1 having c2 < any (select c2 from agg_table);
select * from agg_table_1 having c2 < all (select c2 from agg_table);
select * from agg_table_1 order by c2 > any (select c2 from agg_table);
select * from agg_table_1 order by c2 > all (select c2 from agg_table);
select * from agg_table_1 order by c2 < any (select c2 from agg_table);
select * from agg_table_1 order by c2 < all (select c2 from agg_table);

--echo ## test empty any/all
select * from agg_table_1 where c2 > any (select c2 from agg_table where false);
select * from agg_table_1 where c2 > all (select c2 from agg_table where false);
select * from agg_table_1 where c2 < any (select c2 from agg_table where false);
select * from agg_table_1 where c2 < all (select c2 from agg_table where false);
select * from agg_table_1 group by c2 > any (select c2 from agg_table where false);
select * from agg_table_1 group by c2 > all (select c2 from agg_table where false);
select * from agg_table_1 group by c2 < any (select c2 from agg_table where false);
select * from agg_table_1 group by c2 < all (select c2 from agg_table where false);
select * from agg_table_1 having c2 > any (select c2 from agg_table where false);
select * from agg_table_1 having c2 > all (select c2 from agg_table where false);
select * from agg_table_1 having c2 < any (select c2 from agg_table where false);
select * from agg_table_1 having c2 < all (select c2 from agg_table where false);
select * from agg_table_1 order by c2 > any (select c2 from agg_table where false);
select * from agg_table_1 order by c2 > all (select c2 from agg_table where false);
select * from agg_table_1 order by c2 < any (select c2 from agg_table where false);
select * from agg_table_1 order by c2 < all (select c2 from agg_table where false);
--disable_warnings

--echo ## test for NULL value any/all
--disable_warnings
drop table if exists null_t1,null_t2,null_t3;
create table null_t1 (c1 int primary key);
create table null_t2 (c2 int ,index(c2));
create table null_t3 (c3 int ,index(c3));
insert into null_t1 values(1),(10);
insert into null_t2 values(5),(NULL),(NULL);
insert into null_t3 values(NULL),(NULL),(NULL);
select * from null_t1 where c1 > any (select c2 from null_t2);
select * from null_t1 where c1 < any (select c2 from null_t2);
select * from null_t1 where c1 > any (select c3 from null_t3);
select * from null_t1 where c1 < any (select c3 from null_t3);



--disable_warnings
drop table if exists null_t1, null_t2, null_t3;
select max(1) from agg_table order by 1;
select max(1 + 2) from agg_table order by c1;
select * from agg_table_1 where c1 = (select max(agg_table_1.c1) from agg_table order by c1);

select max(1) from agg_table group by c1 order by 1;
select max(1 + 2) from agg_table group by c2 order by 1;
select * from agg_table_1 where c1 = (select max(agg_table_1.c1) from agg_table group by c1 order by 1);

--enable_warnings
set @@session.ob_enable_transformation = 1;

drop database yts_db;
