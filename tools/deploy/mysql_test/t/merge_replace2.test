{ 
    --let $stmt=REPLACE INTO sbtest(id, name, whenn, k, pad, whenn1) VALUES($count,'yulan','2013-1-6 14:44:00', 1,'qqqqqqqqqqwwwwwwwwwweeeeeeeeeerrrrrrrrrrtttttttttt', '2013-1-7 14:44:00')
    eval $stmt;
    inc $count; 
}

