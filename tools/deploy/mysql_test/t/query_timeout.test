--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner:link.zt
#owner group: sql1


--disable_warnings
drop table if exists query_timeout_t;
--enable_warnings
create table query_timeout_t (c1 int, c2 int, primary key(c1, c2), c3 int);
insert into query_timeout_t values (1, 2, 3);
--echo set query timeout to 50us
set ob_query_timeout=50;
--error SHY000,S25000
select * from query_timeout_t;

--echo set query timeout to 5s
set ob_query_timeout=5000000;
--disable_warnings
drop table if exists query_timeout_t;
--enable_warnings
create table query_timeout_t(c1 int primary key, c2 int);
replace into query_timeout_t values(1,1);

--echo set query timeout to 500ms
set ob_query_timeout=500000;

select * from query_timeout_t where c1=1;
select count(*) from query_timeout_t;
select * from query_timeout_t union select * from query_timeout_t;
update query_timeout_t set c2=2 where c1=1;

--echo set query timeout to 200ms
set ob_query_timeout=200000;

select * from query_timeout_t where c1=1;
select count(*) from query_timeout_t;
select * from query_timeout_t union select * from query_timeout_t;
update query_timeout_t set c2=2 where c1=1;

--echo set query timeout to 10us
set ob_query_timeout=10;
--error SHY000,S25000
select count(*) from query_timeout_t;
--error SHY000,S25000
select * from query_timeout_t union select * from query_timeout_t;

#set query timeout to 1.5s.@TODO dec query_timeout after schema reconsitution
set ob_query_timeout=1500000;
drop table query_timeout_t;

set ob_query_timeout=1;
set ob_query_timeout=10000000;
