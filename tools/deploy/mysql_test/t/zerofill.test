--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: xiaoyi.xy
# owner group: SQL3
# description: meta

--disable_warnings
drop table if exists t1;
create table t1 (i int primary key, j int zerofill);
insert into t1 values (1,1), (9,9), (99,99);
--enable_warnings

SELECT upper(i), upper(j), upper(i+j) FROM t1;
SELECT conv(j, '16', '10'), conv(-17, 10, -16) FROM t1;
SELECT INSERT(j, 3, 3, 'What'), insert(i, 3, 3, 'What') FROM t1;
SELECT Lower(j), Lower(i), Lower(i+j) FROM t1;
SELECT  md5(i) , md5(j) FROM t1; 
SELECT rpad(i, 23, j), rpad(i, 23, i), rpad(j, 23, j) FROM t1;
SELECT quote(i), quote(j), quote(3) FROM t1;
SELECT repeat(j, 3), repeat(i, 3) FROM t1;
SELECT replace(j, i, j), replace(i, j, i) FROM t1;
SELECT reverse(j), reverse(i) FROM t1;
SELECT right(i, 3), right(j, 3) FROM t1;
SELECT substr(j, 1, 9), substr(i, 1, 9) FROM t1;
SELECT trim(BOTH '1' FROM j), trim(BOTH 1 FROM i) FROM t1;
SELECT SUBSTRING_INDEX(j, '0', -2), SUBSTRING_INDEX(i, '0', -2) FROM t1;
SELECT hex(unhex(j)), hex(unhex(i)) FROM t1;

drop table if exists t1;
# SELECT concat(i,j), concat_ws(j, i, 'x', j) FROM t1;

# bug: 
create table t1 (c1 int zerofill, c2 mediumtext, c3 mediumtext charset utf16);
insert into t1 values (1, '1', '1');
insert into t1 values (10000000, 'c2', 'c3');
select c1 from t1 union select c3 from t1;
select c1 from t1 union select c2 from t1;
select c1 + c2, c1 + c3 from t1 where c1=1;
select * from t1 where c1 = c3 and c1 = c2;
select c1 from t1 union select c3 from t1 union select c2 from t1;