#owner:link.zt
#owner group: sql1
#tags: optimizer, privilege
#test create grant revoke
#但generated_table中有外层stmt没有引用到的select item就删除这些select item.
#author link.zt
#

use test;
--disable_warnings
drop table if exists table2_bigint;
drop table if exists table100_bigint;
drop view if exists vtable2_bigint_1;
drop view if exists vtable100_bigint_0;
--enable_warnings

CREATE TABLE table2_bigint (
    col_char_20 char(20),
    col_timestamp_6 timestamp(6) NULL DEFAULT NULL,
    col_decimal_20_0_signed decimal(20,0) signed,
    col_bigint bigint,
    col_decimal_20_0_unsigned decimal(20,0) unsigned,
    col_bigint_unsigned bigint unsigned,
    col_decimal_20_0 decimal(20,0),
    pk bigint,
    col_bigint_signed bigint signed,
    primary key (pk)) ;

INSERT INTO table2_bigint VALUES  ('m', '2007-01-11 07:29:39.057612', 2, 1, 28629, 82, 0, 1, 9) ;

drop table if exists table100_bigint;

CREATE TABLE table100_bigint (
    col_char_20 char(20),
    col_bigint bigint,
    col_decimal_20_0_signed decimal(20,0) signed,
    col_decimal_20_0 decimal(20,0),
    col_bigint_unsigned bigint unsigned,
    col_timestamp_6 timestamp(6) NULL DEFAULT NULL,
    pk bigint,
    col_bigint_signed bigint signed,
    col_decimal_20_0_unsigned decimal(20,0) unsigned,
    primary key (pk));

INSERT INTO table100_bigint VALUES    (NULL, 183, 2, 36138, 6, '2000-04-06 03:41:02.023133', 60, NULL, 0) ,   (NULL, 48, 1, 0, NULL, '2003-11-15 00:25:28.027705', 65, 19406, 0) ,  ('s', 42534, 2, 9, 10520, '2005-12-09 23:03:19.034968', 66, 58451, NULL);

CREATE OR REPLACE  VIEW vtable2_bigint_1 AS SELECT * FROM table2_bigint;

CREATE OR REPLACE  VIEW vtable100_bigint_0 AS SELECT * FROM table100_bigint;

SELECT  X.col_decimal_20_0_signed, Y.col_decimal_20_0_signed, X.pk, Y.pk FROM vtable2_bigint_1 AS X LEFT OUTER JOIN vtable100_bigint_0 AS Y ON X . col_decimal_20_0_signed = Y . col_decimal_20_0_signed;

SELECT  X.col_decimal_20_0_signed, Y.col_decimal_20_0_signed, X.pk, Y.pk FROM vtable2_bigint_1 AS X LEFT OUTER JOIN vtable100_bigint_0 AS Y ON X . col_decimal_20_0_signed = Y . col_decimal_20_0_signed ORDER BY Y . col_bigint_unsigned;

drop table table2_bigint, table100_bigint;
drop view vtable2_bigint_1, vtable100_bigint_0;


--disable_warnings
drop table if exists t;
--enable_warnings

create table t(c1 int, c2 int, c3 int, primary key(c1), key t_c2(c2));

--disable_query_log
--let $i=1
while($i < 501)
{
  eval insert into t values($i,500 - $i,$i);
  inc $i;
}
--enable_query_log
explain select ta.c2 from (select * from t limit 300) ta;
select ta.c2 from (select * from t limit 300) ta;
drop table t;
