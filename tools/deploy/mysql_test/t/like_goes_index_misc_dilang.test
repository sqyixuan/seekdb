--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: yuchen.wyc
#owner group: sql4
#description: Test like goes index related misc functions
# tags: cost

##
## Test str_col like 'xxx%' goes index misc functions, such as JOIN, UNION, 回表、不回表
##
--disable_abort_on_error

# Prepare data
--echo -- Prepare data
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1 (a bigint primary key, b char(20), c char(20), key i1(b) , key i2(c));
insert into t1 values(1,'aaaa','aaaa'),(2,'xxxc','xxxb'),(3,'xxxb','xxxc'),(4,'xxxa','xxxa'),(5,'yyym','yyym'),(6,'yyyd','yyyd'),(7,'yyyf','yyyf'),(8,'zzzz','zzzz');
--disable_warnings
drop table if exists t2;
--enable_warnings
create table t2 (a bigint primary key, b char(20), c char(20), key i1(b) , key i2(c));
insert into t2 values(1,'aaaa','aaaa'),(2,'xxxc','xxxb'),(3,'xxxb','xxxc'),(4,'xxxa','xxxa'),(5,'yyym','yyym'),(6,'yyyd','yyyd'),(7,'yyyf','yyyf'),(8,'zzzz','zzzz');

# Test UNION
--echo -- Test UNION
(SELECT * FROM t1 WHERE b LIKE 'xxx%' LIMIT 2) UNION (SELECT * FROM t1 WHERE b LIKE 'yyy%' ESCAPE '_' LIMIT 2);
(SELECT * FROM t1 WHERE b LIKE 'yyy%' LIMIT 2) UNION (SELECT * FROM t1 WHERE b LIKE 'xxx%' ESCAPE '_' LIMIT 2);

(SELECT * FROM t1 WHERE b LIKE 'xxx%' LIMIT 2) UNION ALL (SELECT * FROM t1 WHERE b LIKE 'yyy%' ESCAPE '_' LIMIT 2);
(SELECT * FROM t1 WHERE b LIKE 'yyy%' LIMIT 2) UNION ALL (SELECT * FROM t1 WHERE b LIKE 'xxx%' ESCAPE '_' LIMIT 2);

(SELECT * FROM t1 WHERE b LIKE 'xxx%' LIMIT 2) UNION DISTINCT (SELECT * FROM t1 WHERE b LIKE 'yyy%' ESCAPE '_' LIMIT 2);
(SELECT * FROM t1 WHERE b LIKE 'yyy%' LIMIT 2) UNION DISTINCT (SELECT * FROM t1 WHERE b LIKE 'xxx%' ESCAPE '_' LIMIT 2);

# Test JOIN
--echo -- Test JOIN
--replace_regex /Plan signature: [0-9]*/Plan signature/
--disable_result_log
EXPLAIN SELECT * FROM t1 JOIN t1 as a1 on t1.a=a1.a WHERE t1.b LIKE 'xxx%';
--enable_result_log
--replace_regex /Plan signature: [0-9]*/Plan signature/
--disable_result_log
EXPLAIN SELECT * FROM t1 JOIN t2 on t1.b=t2.b WHERE t1.b LIKE 'xxx%' AND t2.b LIKE 'yyy%';
--enable_result_log

--replace_regex /Plan signature: [0-9]*/Plan signature/
--disable_result_log
EXPLAIN SELECT * FROM t1 LEFT JOIN t1 as a1 on t1.a=a1.a WHERE t1.b LIKE 'xxx%';
--enable_result_log
--replace_regex /Plan signature: [0-9]*/Plan signature/
--disable_result_log
EXPLAIN SELECT * FROM t1 LEFT JOIN t2 on t1.b=t2.b WHERE t1.b LIKE 'xxx%' AND t2.b LIKE 'yyy%';
--enable_result_log

--replace_regex /Plan signature: [0-9]*/Plan signature/
--disable_result_log
EXPLAIN SELECT * FROM t1 RIGHT JOIN t1 as a1 on t1.a=a1.a WHERE t1.b LIKE 'xxx%';
--enable_result_log
--replace_regex /Plan signature: [0-9]*/Plan signature/
--disable_result_log
EXPLAIN SELECT * FROM t1 RIGHT JOIN t2 on t1.b=t2.b WHERE t1.b LIKE 'xxx%' AND t2.b LIKE 'yyy%';
--enable_result_log

# 回表、不回表
--echo -- 回表、不回表
SELECT b,a FROM t1 WHERE b LIKE 'xxx%';
SELECT b FROM t1 WHERE b LIKE 'xxx%';
SELECT a FROM t1 WHERE b LIKE 'xxx%';
SELECT * FROM t1 WHERE b LIKE 'xxx%';
SELECT c,b,a FROM t1 WHERE b LIKE 'xxx%';
--replace_regex /Plan signature: [0-9]*/Plan signature/
--disable_result_log
EXPLAIN SELECT COUNT(*) FROM t1 WHERE b like '%';
--enable_result_log
--replace_regex /Plan signature: [0-9]*/Plan signature/
--disable_result_log
EXPLAIN SELECT COUNT(*) FROM t1 WHERE b like '_';
--enable_result_log
--replace_regex /Plan signature: [0-9]*/Plan signature/
--disable_result_log
EXPLAIN SELECT COUNT(*) FROM t1 WHERE b like '%' ESCAPE 'a';
--enable_result_log
--replace_regex /Plan signature: [0-9]*/Plan signature/
--disable_result_log
EXPLAIN SELECT COUNT(*) FROM t1 WHERE b like '%a';
--enable_result_log
--replace_regex /Plan signature: [0-9]*/Plan signature/
--disable_result_log
EXPLAIN SELECT COUNT(*) FROM t1 WHERE b like '%a' ESCAPE 'a';
--enable_result_log
--replace_regex /Plan signature: [0-9]*/Plan signature/
--disable_result_log
EXPLAIN SELECT COUNT(*) FROM t1 WHERE b like 'a%';
--enable_result_log
--replace_regex /Plan signature: [0-9]*/Plan signature/
--disable_result_log
EXPLAIN SELECT COUNT(*) FROM t1 WHERE b like '%a%';
--enable_result_log
--replace_regex /Plan signature: [0-9]*/Plan signature/
--disable_result_log
EXPLAIN SELECT COUNT(*) FROM t1 WHERE b not like '%';
--enable_result_log
--replace_regex /Plan signature: [0-9]*/Plan signature/
--disable_result_log
EXPLAIN SELECT COUNT(*) FROM t1 WHERE b not like '%' ESCAPE 'a';
--enable_result_log
--replace_regex /Plan signature: [0-9]*/Plan signature/
--disable_result_log
EXPLAIN SELECT COUNT(a) FROM t1 WHERE b like '%';
--enable_result_log
--replace_regex /Plan signature: [0-9]*/Plan signature/
--disable_result_log
EXPLAIN SELECT COUNT(a) FROM t1 WHERE b like '_';
--enable_result_log
--replace_regex /Plan signature: [0-9]*/Plan signature/
--disable_result_log
EXPLAIN SELECT COUNT(a) FROM t1 WHERE b like '%' ESCAPE 'a';
--enable_result_log
--replace_regex /Plan signature: [0-9]*/Plan signature/
--disable_result_log
EXPLAIN SELECT COUNT(a) FROM t1 WHERE b like '%a';
--enable_result_log
--replace_regex /Plan signature: [0-9]*/Plan signature/
--disable_result_log
EXPLAIN SELECT COUNT(a) FROM t1 WHERE b like '%a' ESCAPE 'a';
--enable_result_log
--replace_regex /Plan signature: [0-9]*/Plan signature/
--disable_result_log
EXPLAIN SELECT COUNT(a) FROM t1 WHERE b like 'a%';
--enable_result_log
--replace_regex /Plan signature: [0-9]*/Plan signature/
--disable_result_log
EXPLAIN SELECT COUNT(a) FROM t1 WHERE b like '%a%';
--enable_result_log
--replace_regex /Plan signature: [0-9]*/Plan signature/
--disable_result_log
EXPLAIN SELECT COUNT(a) FROM t1 WHERE b not like '%';
--enable_result_log
--replace_regex /Plan signature: [0-9]*/Plan signature/
--disable_result_log
EXPLAIN SELECT COUNT(a) FROM t1 WHERE b not like '%' ESCAPE 'a';
--enable_result_log

# 测试from 子查询里面含有col like ‘xxx%’能走到索引
--echo -- 测试from 子查询里面含有col like ‘xxx%’能走到索引
SELECT * from (SELECT * FROM t1 WHERE b like 'xxx%') as t;
SELECT * from (SELECT * FROM t1 WHERE b like 'xxx%' or b like 'yyy%') as t where t.b like 'yyy%';
SELECT * from (SELECT * FROM t1) as t where t.b like 'yyy%';

# 与group by和order by(desc,asc)，limit以及聚合函数一起使用
--echo -- 与group by和order by(desc,asc)，limit以及聚合函数一起使用
SELECT * FROM t1 where b like 'xxx%' GROUP BY b;
SELECT * FROM t1 where b like 'xxx%' order by b;
SELECT * FROM t1 where b like 'xxx%' order by a;
SELECT * FROM t1 where b like 'xxx%' order by b ASC;
SELECT * FROM t1 where b like 'xxx%' order by a ASC;
SELECT * FROM t1 where b like 'xxx%' order by b DESC;
SELECT * FROM t1 where b like 'xxx%' order by a DESC;
SELECT * FROM t1 where b like 'xxx%' LIMIT 2;

# 和hint连用，比如col like xxx%策略上可以走索引，加hint指定另外一个索引；
--echo -- 和hint连用，比如col like xxx%策略上可以走索引，加hint指定另外一个索引；
SELECT /*+ INDEX(t1 i2) */ * FROM t1 WHERE b like 'xxx%';
SELECT /*+ INDEX(t1 i2) */ * FROM t1 WHERE b like 'xxx%' LIMIT 2;
SELECT /*+ INDEX(t1 i1) */ * FROM t1 WHERE c like 'xxx%';
SELECT /*+ INDEX(t1 i1) */ * FROM t1 WHERE c like 'xxx%' LIMIT 2;
SELECT /*+ INDEX(t1 i2) */ * FROM t1 WHERE b not like 'xxx%';
SELECT /*+ INDEX(t1 i2) */ * FROM t1 WHERE b not like 'xxx%' LIMIT 2;
SELECT /*+ INDEX(t1 i1) */ * FROM t1 WHERE c not like 'xxx%';
SELECT /*+ INDEX(t1 i1) */ * FROM t1 WHERE c not like 'xxx%' LIMIT 2;

# alias of table
--echo -- alias of table
SELECT b,a FROM t1 as tt1 WHERE b LIKE 'xxx%';
SELECT b FROM t1 as tt1 WHERE b LIKE 'xxx%';
SELECT a FROM t1 as tt1 WHERE b LIKE 'xxx%';
SELECT * FROM t1 as tt1 WHERE b LIKE 'xxx%';
SELECT c,b,a FROM t1 as tt1 WHERE b LIKE 'xxx%';


## with X'...' =======================
--echo -- with X'...' =======================
# Test UNION
--echo -- Test UNION
(SELECT * FROM t1 WHERE b LIKE X'78787825' LIMIT 2) UNION (SELECT * FROM t1 WHERE b LIKE X'79797925' ESCAPE '_' LIMIT 2);
(SELECT * FROM t1 WHERE b LIKE X'79797925' LIMIT 2) UNION (SELECT * FROM t1 WHERE b LIKE X'78787825' ESCAPE '_' LIMIT 2);

(SELECT * FROM t1 WHERE b LIKE X'78787825' LIMIT 2) UNION ALL (SELECT * FROM t1 WHERE b LIKE X'79797925' ESCAPE '_' LIMIT 2);
(SELECT * FROM t1 WHERE b LIKE X'79797925' LIMIT 2) UNION ALL (SELECT * FROM t1 WHERE b LIKE X'78787825' ESCAPE '_' LIMIT 2);

(SELECT * FROM t1 WHERE b LIKE X'78787825' LIMIT 2) UNION DISTINCT (SELECT * FROM t1 WHERE b LIKE X'79797925' ESCAPE '_' LIMIT 2);
(SELECT * FROM t1 WHERE b LIKE X'79797925' LIMIT 2) UNION DISTINCT (SELECT * FROM t1 WHERE b LIKE X'78787825' ESCAPE '_' LIMIT 2);

