# 测试from 子查询里面含有col like ‘xxx%’能走到索引
--echo -- 测试from 子查询里面含有col like ‘xxx%’能走到索引
SELECT * from (SELECT * FROM t1 WHERE b like X'78787825') as t;
SELECT * from (SELECT * FROM t1 WHERE b like X'78787825' or b like X'79797925') as t where t.b like X'79797925';
SELECT * from (SELECT * FROM t1) as t where t.b like X'79797925';

# 与group by和order by(desc,asc)，limit以及聚合函数一起使用
--echo -- 与group by和order by(desc,asc)，limit以及聚合函数一起使用
SELECT * FROM t1 where b like X'78787825' GROUP BY b;
SELECT * FROM t1 where b like X'78787825' order by b;
SELECT * FROM t1 where b like X'78787825' order by a;
SELECT * FROM t1 where b like X'78787825' order by b ASC;
SELECT * FROM t1 where b like X'78787825' order by a ASC;
SELECT * FROM t1 where b like X'78787825' order by b DESC;
SELECT * FROM t1 where b like X'78787825' order by a DESC;
SELECT * FROM t1 where b like X'78787825' LIMIT 2;

# 和hint连用，比如col like xxx%策略上可以走索引，加hint指定另外一个索引；
--echo -- 和hint连用，比如col like xxx%策略上可以走索引，加hint指定另外一个索引；
SELECT /*+ INDEX(t1 i2) */ * FROM t1 WHERE b like X'78787825';
SELECT /*+ INDEX(t1 i2) */ * FROM t1 WHERE b like X'78787825' LIMIT 2;
SELECT /*+ INDEX(t1 i1) */ * FROM t1 WHERE c like X'78787825';
SELECT /*+ INDEX(t1 i1) */ * FROM t1 WHERE c like X'78787825' LIMIT 2;
SELECT /*+ INDEX(t1 i2) */ * FROM t1 WHERE b not like X'78787825';
SELECT /*+ INDEX(t1 i2) */ * FROM t1 WHERE b not like X'78787825' LIMIT 2;
SELECT /*+ INDEX(t1 i1) */ * FROM t1 WHERE c not like X'78787825';
SELECT /*+ INDEX(t1 i1) */ * FROM t1 WHERE c not like X'78787825' LIMIT 2;

# alias of table
--echo -- alias of table
SELECT b,a FROM t1 as tt1 WHERE b LIKE X'78787825';
SELECT b FROM t1 as tt1 WHERE b LIKE X'78787825';
SELECT a FROM t1 as tt1 WHERE b LIKE X'78787825';
