--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: yuchen.wyc
# owner group: sql4
# tags: optimizer
# description: foobar
####TITEL: query_with_precast
--disable_warnings
drop table if exists t1; 
--enable_warnings
create table t1(a int, b int, primary key(a, b));
--let $count=1
while($count < 6)
{
  --let $stmt=INSERT INTO t1 VALUES($count, $count-1)
  eval $stmt;
  inc $count;
}

--let $query=select count(*) from t1 group by a, b
eval explain extended_noaddr $query;
eval $query;

--let $query=select count(*) from t1 group by b, a
eval explain extended_noaddr $query;
eval $query;

--let $query=select distinct b, a from t1
eval explain extended_noaddr $query;
eval $query;

--let $query=select count(*) from t1 group by a
eval explain extended_noaddr $query;
eval $query;

--let $query=select distinct a from t1
eval explain extended_noaddr $query;
eval $query;

--let $query=select count(*) from t1 where a=1 group by b
eval explain extended_noaddr $query;
eval $query;

--let $query=select distinct b from t1 where b=1
eval explain extended_noaddr $query;
eval $query;

--let $query=select distinct b from t1 where a=1
eval explain extended_noaddr $query;
eval $query;

--let $query=select distinct b, a from t1 where b=1
eval explain extended_noaddr $query;
eval $query;

drop table t1;
create table t1(a int, b int, c int, primary key(a, b, c));
--let $count=1
while($count < 6)
{
  --let $stmt=INSERT INTO t1 VALUES($count, $count-1, $count+1)
  eval $stmt;
  inc $count;
}

--let $query=select count(*) from t1 group by a, c, b
eval explain extended_noaddr $query;
eval $query;

--let $query=select distinct a, c, b from t1
eval explain extended_noaddr $query;
eval $query;

--let $query=select count(*) from t1 where b=1 group by a, c
eval explain extended_noaddr $query;
eval $query;

--let $query=select distinct a, c from t1 where b=1
eval explain extended_noaddr $query;
eval $query;

--let $query=select count(*) from t1 where a=1 group by b, c
eval explain extended_noaddr $query;
eval $query;

--let $query=select distinct b, c from t1 where a=1
eval explain extended_noaddr $query;
eval $query;

--let $query=select distinct a from t1 where a=1
eval explain extended_noaddr $query;
eval $query;

--let $query=select count(*) from t1 where b=1 and c=3 group by a
eval explain extended_noaddr $query;
eval $query;

drop table t1;
