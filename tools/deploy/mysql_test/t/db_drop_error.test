--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: dachuan.sdc
#owner group : sql2
--disable_warnings
DROP DATABASE IF EXISTS d5;
--enable_warnings
CREATE DATABASE d5;
SHOW DATABASES WHERE `Database` LIKE '%d5%';
--error 1008
DROP DATABASE nond5;
DROP DATABASE d5;
SHOW DATABASES WHERE `Database` LIKE '%d5%';

