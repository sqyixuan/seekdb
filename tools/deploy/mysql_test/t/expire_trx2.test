# owner: xiaoyi.xy
# owner group: SQL3
# comment: this case is marked as expired in filter.py

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
--disable_abort_on_error
####TITLE: expire
--disable_query_log
--source mysql_test/include/index_quick_major.inc
--real_sleep 1
--enable_query_log


--echo case 8:some expr with merging_frozen_time
--disable_warnings
drop table if exists t16;
--enable_warnings
create table t16(c0 int primary key,c1 timestamp) EXPIRE_INFO (c1 < date_add(merging_frozen_time(),interval 30 second));
--error 5113 
select merging_frozen_time();
insert into t16 values(1, now());
insert into t16 values(2, now());
insert into t16 values(3, now());
insert into t16 values(4, date_add(now(), INTERVAL 5 second ));
insert into t16 values(5, date_add(now(), INTERVAL 6 second ));
--disable_query_log
sleep 3;
--enable_query_log
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
--replace_column 2 time
select * from t16;
insert into t16 values(7, date_add(now(), INTERVAL 35 second ));
insert into t16 values(8, date_add(now(), INTERVAL 30 second ));
insert into t16 values(9, date_add(now(), INTERVAL 32 second ));
insert into t16 values(10, date_add(now(), INTERVAL 32 DAY ));
insert into t16 values(11, date_add(now(), INTERVAL -32 DAY ));
--disable_query_log
--enable_query_log
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
--replace_column 2 time
select * from t16;
alter table t16 set EXPIRE_INFO (c0>1);
sleep 1;
insert into t16 values(17, date_add(now(), INTERVAL 35 second ));
insert into t16 values(8, date_add(now(), INTERVAL 30 second ));
insert into t16 values(11, date_add(now(), INTERVAL 32 second ));
insert into t16 values(-9, date_add(now(), INTERVAL 32 second ));
--disable_query_log
sleep 3;
--enable_query_log
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
--replace_column 2 time
select * from t16;
alter table t16 set EXPIRE_INFO (c0<1 or c1 < date_add(merging_frozen_time(),interval -1 HOUR));
sleep 1;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t16;
--error 1064
alter table t16 set EXPIRE_INFO (0<1);
alter table t16 set EXPIRE_INFO (0<1 or c1 < date_add(merging_frozen_time(),interval -1 HOUR));
sleep 1;
alter table t16 set EXPIRE_INFO (c0<1 or  c1 < date_add(merging_frozen_time(),interval -1 HOUR));
sleep 1;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t16;
insert into t16 values(19, date_add(now(), INTERVAL -1 hour ));
insert into t16 values(18, date_add(now(), INTERVAL 1 hour ));
insert into t16 values(-18, date_add(now(), INTERVAL 1 hour ));
--disable_query_log
sleep 3;
--enable_query_log
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
--replace_column 2 time
select * from t16;
alter table t16 set EXPIRE_INFO (NULL);
sleep 1;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t16;
insert into t16 values(28, date_add(now(), INTERVAL 1 hour ));
insert into t16 values(29, date_add(now(), INTERVAL 1 hour ));
--disable_query_log
sleep 3;
--enable_query_log
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
--replace_column 2 time
select * from t16;
alter table t16 set EXPIRE_INFO ( c1 < date_add(merging_frozen_time(),interval -1 minute));
sleep 1;
insert into t16 values(39, date_add(now(), INTERVAL 1 minute ));
insert into t16 values(38, date_add(now(), INTERVAL 1 minute ));
--disable_query_log
--enable_query_log
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
select c0 from t16;
update t16 set c0 =100 where c0=29;
select c0 from t16;
alter table t16 set EXPIRE_INFO ( date_add(c1,interval -1 minute)<merging_frozen_time());
sleep 2;
insert into t16 values(40, date_add(now(), INTERVAL -2 minute ));
insert into t16 values(41, date_add(now(), INTERVAL -2 minute ));
--disable_query_log
sleep 3;
--enable_query_log
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
select c0 from t16;

##case 9:expire info fro datetime default now()
--disable_warnings
drop table if exists t17;
--enable_warnings
create table t17( a int primary key,c16 datetime default now(),c17 datetime default now())EXPIRE_INFO (c17<merging_frozen_time());
insert into t17(a) values(1),(2),(3),(4),(5),(6);
--disable_query_log
sleep 3;
--enable_query_log
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
--replace_column 2 time 3 time
select * from t17;
alter table t17 set EXPIRE_INFO (c17>merging_frozen_time());
sleep 1;
insert into t17(a) values(1),(2),(3),(4),(5),(6);
--disable_query_log
sleep 3;
--enable_query_log
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
--replace_column 2 time 3 time
select * from t17;
sleep 5;
select a from t17;
update t17 set a=11 where a=1;
select a from t17;
##case 10:usec time
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(c1 int primary key, c2 int);
alter table t1 set EXPIRE_INFO (c2>0);
sleep 2;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;
drop table t1;

--disable_warnings
drop table if exists test;
--enable_warnings
create table test(a int,b int,c datetime primary key) EXPIRE_INFO (a>time_to_usec(merging_frozen_time()));
insert into test values(1,1,'2014-08-21 15:00:00');
insert into test values(2,2,'2014-08-20 13:00:00');
--disable_query_log
--enable_query_log
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
select a,b from test;
--disable_warnings
drop table if exists test11;
--enable_warnings
create table test11 (i2 varchar(1024) primary key) EXPIRE_INFO (                                                                                                        i2='^');
create table test11 (i2 varchar(1024) primary key);
alter table test11 set EXPIRE_INFO (                                                                                                                                   i2='');
