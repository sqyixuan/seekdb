--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: yuchen.wyc
# owner group: SQL1
#description: Test index with key ranges and OR operator
####TITEL:
####table with index, 
####update range and delete range are used in trx
####idxkeys are used as where condition
--disable_query_log
--source mysql_test/include/index_quick_major.inc
--real_sleep 1
--disable_warnings
drop table if exists t1;
--enable_warnings
set global ob_enable_index_direct_select =1;
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
alter system set merger_check_interval = '10s' tenant sys;
alter system set merger_check_interval = '10s' tenant all_user;
alter system set merger_check_interval = '10s' tenant all_meta;
disconnect obsys;
connection default;
--enable_query_log

connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (trx1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (trx2,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);

connection conn1;
create table t1(pk1 int, c1 int, c2 int, c3 int, primary key(pk1));
insert into t1(pk1,c1,c2,c3) values(1,1,1,1);
insert into t1(pk1,c1,c2,c3) values(2,2,2,1);
insert into t1(pk1,c1,c2,c3) values(3,3,3,1);
insert into t1(pk1,c1,c2,c3) values(4,4,4,1);
insert into t1(pk1,c1,c2,c3) values(5,5,5,1);
insert into t1(pk1,c1,c2,c3) values(6,6,6,1);
insert into t1(pk1,c1,c2,c3) values(7,7,7,1);
insert into t1(pk1,c1,c2,c3) values(8,8,8,1);

create index i1 on t1(c1,c2) storing(c3);
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
let $idx1 = query_get_value(select a.table_name from oceanbase.__all_virtual_table as a inner join (select * from oceanbase.__all_virtual_table where table_name='t1') b on a.data_table_id=b.table_id, table_name, 1);
disconnect obsys;
connection default;

--source mysql_test/include/check_all_idx_ok.inc

select * from t1;
--disable_query_log
set ob_enable_index_direct_select=1;
eval select * from $idx1;
--enable_query_log

####CASE: trx1 read, trx2 write
connection trx1;
set autocommit=0;

connection trx2;
set autocommit=0;
update t1 set c3=c3+1 where (c1,c2)=(1,1) or (c1,c2)=(2,2);
delete from t1 where (c1,c2)=(3,3) or (c1,c2)=(4,4) or (c1,c2)=(5,6) or (c1,c2)=(7,8);
select * from t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log

connection trx1;
select * from t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log

connection trx2;
commit;
update t1 set c3=c3+1 where (c1,c2)=(5,5) or (c1,c2)=(6,6);
delete from t1 where (c1,c2)=(7,7) or (c1,c2)=(8,8) or (c1,c2)=(5,6) or (c1,c2)=(7,8);

connection trx1;
select * from t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log

connection trx2;
commit;
update t1 set c3=c3+1 where 
       (c1,c2)=(7,7) or (c1,c2)=(8,8) or (c1,c2)=(5,5) or (c1,c2)=(6,6) or
       (c1,c2)=(1,1) or (c1,c2)=(2,2) or (c1,c2)=(3,3) or (c1,c2)=(4,4);

connection trx1;
select * from t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log

connection trx2;
commit;

connection trx1;
select * from t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log
commit;

####CASE: both of trx1 and trx read and write, different rows
connection conn1;
delete from t1;
replace into t1(pk1,c1,c2,c3) values (1,1,1,1),(2,2,2,1),(3,3,3,1),(4,4,4,1),(5,5,5,1),(6,6,6,1),(7,7,7,1),(8,8,8,1);
select * from t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log

connection trx1;
update t1 set c3=c3+1 where (c1,c2)=(1,1) or (c1,c2)=(2,2) or (c1,c2)=(3,3) or (c1,c2)=(4,4);
select * from t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log

connection trx2;
update t1 set c3=c3+1 where (c1,c2)=(7,7) or (c1,c2)=(8,8) or (c1,c2)=(5,5) or (c1,c2)=(6,6);
select * from t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log
commit;

connection trx1;
select * from t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log
commit;

####CASE: write with same rows, but trx has commit
connection conn1;
delete from t1;
replace into t1(pk1,c1,c2,c3) values (1,1,1,1),(2,2,2,1),(3,3,3,1),(4,4,4,1),(5,5,5,1),(6,6,6,1),(7,7,7,1),(8,8,8,1);
select * from t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log

connection trx1;

connection trx2;
update t1 set c3=c3+1 where 
       (c1,c2)=(7,7) or (c1,c2)=(8,8) or (c1,c2)=(5,5) or (c1,c2)=(6,6) or
       (c1,c2)=(1,1) or (c1,c2)=(2,2) or (c1,c2)=(3,3) or (c1,c2)=(4,4);
select * from t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log
commit;

connection trx1;
update t1 set c3=c3+1 where 
       (c1,c2)=(7,7) or (c1,c2)=(8,8) or (c1,c2)=(5,5) or (c1,c2)=(6,6) or
       (c1,c2)=(1,1) or (c1,c2)=(2,2) or (c1,c2)=(3,3) or (c1,c2)=(4,4);
select * from t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log
commit;

connection trx2;
delete from t1 where 
       (c1,c2)=(7,7) or (c1,c2)=(8,8) or (c1,c2)=(5,5) or (c1,c2)=(6,6) or
       (c1,c2)=(1,1) or (c1,c2)=(2,2) or (c1,c2)=(3,3) or (c1,c2)=(4,4);
select * from t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log
commit;

connection trx1;
select * from t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log
delete from t1 where 
       (c1,c2)=(7,7) or (c1,c2)=(8,8) or (c1,c2)=(5,5) or (c1,c2)=(6,6) or
       (c1,c2)=(1,1) or (c1,c2)=(2,2) or (c1,c2)=(3,3) or (c1,c2)=(4,4);
select * from t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log
commit;

####CASE: write with same rows, 5048
connection conn1;
delete from t1;
replace into t1(pk1,c1,c2,c3) values (1,1,1,1),(2,2,2,1),(3,3,3,1),(4,4,4,1),(5,5,5,1),(6,6,6,1),(7,7,7,1),(8,8,8,1);
select * from t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log

connection trx1;
update t1 set c3=c3+1 where 
       (c1,c2)=(7,7) or (c1,c2)=(8,8) or (c1,c2)=(5,5) or (c1,c2)=(6,6) or
       (c1,c2)=(1,1) or (c1,c2)=(2,2) or (c1,c2)=(3,3) or (c1,c2)=(4,4);
select * from t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log

connection trx2;
--error 1205,4012
update t1 set c3=c3+1 where c1 in (1,2);
--error 1205,4012
delete from t1 where c1 in (3,4);
--error 1205,4012
update t1 set c3=c3+1 where (c1,c2)=(1,1) or (c1,c2)=(2,2) or (c1,c2)=(3,3) or (c1,c2)=(4,4);
--error 1205,4012
delete from t1 where (c1,c2)=(1,1) or (c1,c2)=(2,2) or (c1,c2)=(3,3) or (c1,c2)=(4,4);
--error 1205,4012
delete from t1;
--error 1205,4012
update t1 set c3=c3+1;

select * from t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log

connection trx1;
select * from t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log
commit;

connection trx2;
select * from t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log
commit;

connection trx1;
set autocommit=1;
connection trx2;
set autocommit=1;
drop table t1;
set global ob_enable_index_direct_select =0;
