--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: jingyan.kfy
#owner group: transaction

####TITEL:
####table with index, 
####update range and delete range are used in trx
####idx kwy are used as where condition
--disable_query_log
--source mysql_test/include/index_quick_major.inc
connect (sys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection sys;
--real_sleep 1
set global ob_enable_index_direct_select =1;
alter system set merger_check_interval = '10s' tenant sys;
alter system set merger_check_interval = '10s' tenant all_user;
alter system set merger_check_interval = '10s' tenant all_meta;
--enable_query_log

connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (trx1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (trx2,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);

connection conn1;
--disable_warnings
drop table if exists index_33_trx_idxkey_range_in_t1;
--enable_warnings
create table index_33_trx_idxkey_range_in_t1(pk1 int, pk2 int, c1 int, c2 int, primary key(pk1,pk2));
insert into index_33_trx_idxkey_range_in_t1(pk1,pk2,c1,c2) values(1,1,1,1);
insert into index_33_trx_idxkey_range_in_t1(pk1,pk2,c1,c2) values(2,2,1,1);
insert into index_33_trx_idxkey_range_in_t1(pk1,pk2,c1,c2) values(3,3,2,1);
insert into index_33_trx_idxkey_range_in_t1(pk1,pk2,c1,c2) values(4,4,2,1);
insert into index_33_trx_idxkey_range_in_t1(pk1,pk2,c1,c2) values(5,5,3,1);
insert into index_33_trx_idxkey_range_in_t1(pk1,pk2,c1,c2) values(6,6,3,1);
insert into index_33_trx_idxkey_range_in_t1(pk1,pk2,c1,c2) values(7,7,4,1);
insert into index_33_trx_idxkey_range_in_t1(pk1,pk2,c1,c2) values(8,8,4,1);

create index i1 on index_33_trx_idxkey_range_in_t1(c1) storing(c2);
# sleep 10s
sleep 10;
connection sys;
let $idx1 = query_get_value(select a.table_name from oceanbase.__all_virtual_table as a inner join (select * from oceanbase.__all_virtual_table where table_name='index_33_trx_idxkey_range_in_t1') b on a.data_table_id=b.table_id, table_name, 1);
--disable_query_log
connection conn1;
--enable_query_log
--source mysql_test/include/check_all_idx_ok.inc
--source mysql_test/include/check_schema_sync.inc
connection conn1;

select * from index_33_trx_idxkey_range_in_t1;
--disable_query_log
set ob_enable_index_direct_select =1;
eval select * from $idx1;
--enable_query_log

####CASE: trx1 read, trx2 write and select
connection trx1;
set autocommit=0;

connection trx2;
set autocommit=0;
update index_33_trx_idxkey_range_in_t1 set c2=c2+1 where c1 in (1,2,3,4);
select * from index_33_trx_idxkey_range_in_t1;
--disable_query_log
set ob_enable_index_direct_select =1;
eval select * from $idx1;
--enable_query_log
delete from index_33_trx_idxkey_range_in_t1 where c1 in (1,2);
select * from index_33_trx_idxkey_range_in_t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log

connection trx1;
select * from index_33_trx_idxkey_range_in_t1;
--disable_query_log
set ob_enable_index_direct_select =1;
eval select * from $idx1;
--enable_query_log

connection trx2;
commit;

connection trx1;
select * from index_33_trx_idxkey_range_in_t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log
commit;
select * from index_33_trx_idxkey_range_in_t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log
commit;

####CASE: both of trx1 and trx read and write, different rows
connection conn1;
delete from index_33_trx_idxkey_range_in_t1;
replace into index_33_trx_idxkey_range_in_t1(pk1,pk2,c1,c2) values (1,1,1,1),(2,2,1,1),(3,3,2,1),(4,4,2,1),(5,5,3,1),(6,6,3,1),(7,7,4,1),(8,8,4,1);
select * from index_33_trx_idxkey_range_in_t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log

connection trx1;
update index_33_trx_idxkey_range_in_t1 set c2=c2+1 where c1 in (1,2);
select * from index_33_trx_idxkey_range_in_t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log

connection trx2;
select * from index_33_trx_idxkey_range_in_t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log
delete from index_33_trx_idxkey_range_in_t1 where c1 in (3,4);

connection trx1;
select * from index_33_trx_idxkey_range_in_t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log
commit;

connection trx2;
select * from index_33_trx_idxkey_range_in_t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log
commit;
select * from index_33_trx_idxkey_range_in_t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log
commit;

####CASE: write with same rows, but trx2 has commit
connection conn1;
delete from index_33_trx_idxkey_range_in_t1;
replace into index_33_trx_idxkey_range_in_t1(pk1,pk2,c1,c2) values (1,1,1,1),(2,2,1,1),(3,3,2,1),(4,4,2,1),(5,5,3,1),(6,6,3,1),(7,7,4,1),(8,8,4,1);
select * from index_33_trx_idxkey_range_in_t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log

connection trx1;

connection trx2;
update index_33_trx_idxkey_range_in_t1 set c2=c2+1 where c1 in (1,2,3,4);
select * from index_33_trx_idxkey_range_in_t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log
delete from index_33_trx_idxkey_range_in_t1 where c1 in (1,2);
select * from index_33_trx_idxkey_range_in_t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log
commit;

connection trx1;
update index_33_trx_idxkey_range_in_t1 set c2=c2+1 where c1 in (1,2,3,4);
select * from index_33_trx_idxkey_range_in_t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log
delete from index_33_trx_idxkey_range_in_t1 where c1 in (3,4);
select * from index_33_trx_idxkey_range_in_t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log
commit;
select * from index_33_trx_idxkey_range_in_t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log
commit;


####CASE: write with same rows, 5048
connection conn1;
delete from index_33_trx_idxkey_range_in_t1;
replace into index_33_trx_idxkey_range_in_t1(pk1,pk2,c1,c2) values (1,1,1,1),(2,2,1,1),(3,3,2,1),(4,4,2,1),(5,5,3,1),(6,6,3,1),(7,7,4,1),(8,8,4,1);
select * from index_33_trx_idxkey_range_in_t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log

connection trx1;
# exist rows
delete from index_33_trx_idxkey_range_in_t1 where c1 in (1,2);
replace into index_33_trx_idxkey_range_in_t1(pk1,pk2,c1,c2) values (1,1,1,1),(2,2,1,1);
insert  into index_33_trx_idxkey_range_in_t1(pk1,pk2,c1,c2) values (3,3,2,1),(4,4,2,1);
update index_33_trx_idxkey_range_in_t1 set c2=c2+1 where c1 in (1,2,3,4);
# new rows
replace into index_33_trx_idxkey_range_in_t1(pk1,pk2,c1,c2) values (9,9,5,1);
insert  into index_33_trx_idxkey_range_in_t1(pk1,pk2,c1,c2) values (10,10,5,1);
select * from index_33_trx_idxkey_range_in_t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log

connection trx2;
set ob_query_timeout=1000000;
--error 1205,4012
update index_33_trx_idxkey_range_in_t1 set c2=c2+1 where c1 in (1,2,3,4);
--error 1205,4012
delete from index_33_trx_idxkey_range_in_t1 where c1 in (1,2,3,4);
--error 1205,4012
replace into index_33_trx_idxkey_range_in_t1(pk1,pk2,c1,c2) values (1,1,1,1);
--error 1205,4012
insert into index_33_trx_idxkey_range_in_t1(pk1,pk2,c1,c2) values (1,1,1,1);
--error 1205,4012
update index_33_trx_idxkey_range_in_t1 set c2=c2+1 where c1 in (1,2);
--error 1205,4012
delete from index_33_trx_idxkey_range_in_t1 where c1 in (1,2);

update index_33_trx_idxkey_range_in_t1 set c2=c2+1 where (pk1,pk2) in ((9,9),(10,10));
delete from index_33_trx_idxkey_range_in_t1 where (pk1,pk2) in ((9,9),(10,10));

update index_33_trx_idxkey_range_in_t1 set c2=c2+1 where c1 in (5);
select * from index_33_trx_idxkey_range_in_t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log
delete from index_33_trx_idxkey_range_in_t1 where c1 in(5);
select * from index_33_trx_idxkey_range_in_t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log

connection trx1;
select * from index_33_trx_idxkey_range_in_t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log
commit;

connection trx2;
select * from index_33_trx_idxkey_range_in_t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log
update index_33_trx_idxkey_range_in_t1 set c2=c2+1 where c1 in (5);
select * from index_33_trx_idxkey_range_in_t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log
commit;
select * from index_33_trx_idxkey_range_in_t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log
commit;

connection trx1;
set autocommit=1;
connection trx2;
set autocommit=1;
drop table index_33_trx_idxkey_range_in_t1;
set global ob_enable_index_direct_select =0;
