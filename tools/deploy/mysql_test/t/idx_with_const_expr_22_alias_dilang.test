--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: dachuan.sdc
# owner group: SQL3
# description: 测试带别名的列的比较运算

##
## Table cleaning
##
#
--disable_warnings
drop table if exists t1,t2;
--enable_warnings

--source mysql_test/include/index_quick_major.inc
#
##
## Test alias on column and table, with const expression
##
#
## Create database schema
create table t1(
  a1 char(3) primary key,
  a2 int,
  a3 char(3),
  a4 float,
  a5 datetime
);
create table t2(
  a1 char(3) primary key,
  a2 char(17),
  a3 char(2),
  a4 char(3)
);
#
## Populate table t1
insert into t1 values('AME',0,'SEA',0.100,date'1942-02-19');
insert into t1 values('HBR',1,'SEA',0.085,date'1948-03-05');
insert into t1 values('BOT',2,'SEA',0.085,date'1951-11-29');
insert into t1 values('BMC',3,'SEA',0.085,date'1958-09-08');
insert into t1 values('TWU',0,'LAX',0.080,date'1969-10-05');
insert into t1 values('BDL',0,'DEN',0.080,date'1960-11-27');
insert into t1 values('DTX',1,'NYC',0.080,date'1961-05-04');
insert into t1 values('PLS',1,'WDC',0.075,date'1949-01-02');
insert into t1 values('ZAJ',2,'CHI',0.075,date'1960-06-15');
insert into t1 values('VVV',2,'MON',0.075,date'1959-06-28');
insert into t1 values('GTM',3,'DAL',0.070,date'1977-09-23');
insert into t1 values('SSJ',null,'CHI',null,date'1974-03-19');
insert into t1 values('KKK',3,'ATL',null,null);
insert into t1 values('XXX',null,'MIN',null,null);
insert into t1 values('WWW',1,'LED',null,null);
insert into t1 values('GG3',3,'DD3',0.051,now());
insert into t1 values('GG2',3,'DD2',0.052,now());
insert into t1 values('GG1',3,'DD1',0.053,now());
insert into t1 values('CC3',4,'GTM',0.053,now());
insert into t1 values('CC2',4,'BDL',0.053,now());
insert into t1 values('CC1',4,'TWU',0.053,now());
#
# Populate table t2
insert into t2 values('TKF','Seattle','WA','AME');
insert into t2 values('LCC','Los Angeles','CA','TWU');
insert into t2 values('DEN','Denver','CO','BDL');
insert into t2 values('SDC','San Diego','CA','TWU');
insert into t2 values('NOL','New Orleans','LA','GTM');
insert into t2 values('LAK','Los Angeles','CA','TWU');
insert into t2 values('AAA','AAA','AA','AME');

## Create index i1 for t1
create index i2 on t1(a2);
create index i3 on t1(a3);
create index i5 on t1(a5);

## Create index j4 for t2
create index j4 on t2(a4);

--source mysql_test/include/check_all_idx_ok.inc     

# >>> Not supported(2014.9.17 - OceanBase 0.5.1.3 (r25917M) (Built Sep 16 2014 19:46:06)): int_column >= (expr with / or round(), type is numeric) will not go through index on int_column

## Test alias on column name
select a1, a2*2+1 as b2 from t1 where a2>=1-1 and a2<=round(9.0/2.0)*2 order by a1;
select a1, a2*2+1 as b2, a3 from t1 where a2>=1-1 and a2<=round(9.0/2.0)*2 order by a1;
select a1, a2*2+1 as b2 from t1 where a2>=1-(9-8)+(3*5)-45/3 and a2<=100%55-35 order by a1;
select a1, a2*2+1 as b2, a3 from t1 where a2>=1-(9-8)+(3*5)-45/3 and a2<=100%55-35 order by a1;

select a1, a2 as b2, a3 from t1 where a2>=0 and a2<=10 order by a1;
select a1, a2 as b2, a3 from t1 where a2>=1-1 and a2<=round(9.0/2.0)*2 order by a1;
select a1, a2 as b2, a3 from t1 where a2>=1-(9-8)+(3*5)-45/3 and a2<=100%55-35 order by a1;

select t1.a1 as t1a1, t2.a1 as t2a1, t1.a3 as t1a3, t2.a4 as t2a4 from t1,t2 where t1.a1=t2.a4 order by t1.a1,t2.a1;
select t1.a1 as t1a1, t2.a1 as t2a1, t1.a3 as t1a3, t2.a4 as t2a4 from t1,t2 where t1.a3>'AB' and t1.a1=t2.a4 order by t1.a1,t2.a1;
select t1.a1 as t1a1, t2.a1 as t2a1, t1.a3 as t1a3, t2.a4 as t2a4 from t1,t2 where t1.a3>concat('A','B') and t1.a1=t2.a4 order by t1.a1,t2.a1;

## Test alias on table name

select a.a1, b.a1, a.a3, b.a4 from t1 as a,t2 as b where a.a1=b.a4 order by a.a1;
select a.a1, b.a1, a.a3, b.a4 from t1 as a,t2 as b where a.a3>'AB' and a.a1=b.a4 order by a.a1,b.a1;
select a.a1, b.a1, a.a3, b.a4 from t1 as a,t2 as b where a.a3>concat('A','B') and a.a1=b.a4 order by a.a1,b.a1;

