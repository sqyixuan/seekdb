--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: bin.lb
# owner group: SQL3
# description:
#
 ####
--disable_query_log
#--source mysql_test/include/index_quick_major.inc
#--real_sleep 1
sleep 5;
--disable_warnings
drop table if exists t1,t2,t3,t4;
--enable_warnings
--enable_query_log

####CASE:关闭修改系统表的开关，不允许创建索引表指定id
create table t1(c1 int, c2 char(255), c3 int, c4 varchar(1024), primary key(c1,c2));

#set ob_disable_create_sys_table=true; 
#sleep 5;

--error 1064
create index i1 on t1(c3) table_id=1700;
--error 1064
create index i2 on t1(c3) table_id=3037;
--error 1064
create index i3 on t1(c3) table_id=999;
create index _i4_ on t1(c3);
--source mysql_test/include/check_all_idx_ok.inc
show index from t1;

--error 1235
create table t2(c1 int, c2 char(255), c3 int, c4 varchar(1024), primary key(c1,c2)) table_id=4000;
--disable_warnings
drop table if exists t2;
--enable_warnings
create table t3(c1 int, c2 char(255), c3 int, c4 varchar(1024), primary key(c1,c2));

####CASE：运行修改系统表，创建索引表不允许指定id
sleep 5;
--error 1064
create index i5 on t1(c3) table_id=998;

create index _i8_ on t1(c3);
--source mysql_test/include/check_all_idx_ok.inc
--replace_column 3 indexname
show index from t1;

create table t4(c1 int, c2 char(255), c3 int, c4 varchar(1024), primary key(c1,c2));

#show all tables;

--disable_warnings
drop table if exists t1,t2,t3,t4;
--enable_warnings
