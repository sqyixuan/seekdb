--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: yuchen.wyc
# owner group: SQL3
# description: 本case是为了测试values在不同stmt中的表现

--disable_warnings
drop table if exists test;
--enable_warnings

create table test(c1 int primary key, c2 int);
insert into test values(1,2);

select values(c1) from test;
--error 1048
update test set c1 = values(c1);
update test set c2 = values(c2);
select * from test;
insert into test values(1,3) on duplicate key  update c2 = values(c2);
select * from test;

