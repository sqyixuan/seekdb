--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: bin.lb
# owner group: SQL2
# tags: alter
# description:
#
--source mysql_test/include/index_quick_major.inc
--disable_warnings
drop table if exists t1,t2,t3,t4;
--enable_warnings
create table t1(pk int primary key, v1 varchar(10), v2 varchar(10));
insert into t1 values(1,'abbbbbb',6),(2,'aabbbbbbbb',10);

--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/check_all_idx_ok.inc

##长度改大，无静态数据
desc t1;
alter table t1 modify column v1 varchar(20);
sleep 1;
desc t1;

#insert 
insert into t1 values(3,'aaabbbbbbbbb',12),(4,'aaaabbbbbbbbbbb',15);
--error 1406
insert into t1 values(5,'aaaaabbbbbbbbbbbbbbbb',21);
insert into t1 values(6,'aaaaaab',7);

select * from t1;

#replace
replace into t1 values(1,'abbbbbbbbbbbbbbbbbbb',20),(7,'aaaaaaabbbbbbbbbbb',18);
--error 1406
replace into t1 values(2,'aabbbbbbbbbbbbbbbbbbbb',22);
replace into t1 values(3,'aaabbbbb',8);

select * from t1;

#update
update t1 set v1='aabbbbbbbbbbbbbb',v2=16 where pk=2;
update t1 set v1='aaaaaaaabbbbbbb',v2=15 where pk=8;
--error 1406
update t1 set v1='aaaaaaabbbbbbbbbbbbbb',v2=21 where pk=7;
update t1 set v1='aaaab',v2=5 where pk=4;
select * from t1;

#delete alter major(无静态数据)
delete from t1 where pk=1;
alter table t1 modify column v1 varchar(22);
sleep 1;
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
insert into t1 values(1,'abbbbbbbbbbbbbbbbbbbbb',21);
select * from t1;

#delete alter major(有静态数据)
delete from t1 where pk=3;
alter table t1 modify column v1 varchar(23);
sleep 1;
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
insert into t1 values(3,'aaabbbbbbbbbbbbbbbbbbbb',23);
select * from t1;

#delete major alter(有静态数据)
delete from t1 where pk=6;
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
alter table t1 modify column v1 varchar(24);
insert into t1 values(6,'aaaaaabbbbbbbbbbbbbbbbbb',24);
select * from t1;

 
#长度改大（有静态数据）
desc t1;
alter table t1 modify column v1 varchar(35);
sleep 1;
desc t1;

#insert 
insert into t1 values(8,'aaaaaaaabbbbbbbbbbbbbbbbb',25),(9,'aaaaaaaaabbbbbbbbbbbbbbbbb',26);
--error 1406
insert into t1 values(10,'aaaaaaaaaabbbbbbbbbbbbbbbbbbbbbbbbbb',36);
insert into t1 values(11,'aaaaaaaaaaabbbbbbbbbbb',22);
select * from t1;

#replace
replace into t1 values(1,'abbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb',33);
--error 1406
replace into t1 values(2,'aabbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb',36);
replace into t1 values(3,'aaabbbbbbbbbbbbbbbbb',20);

select * from t1;

#update
update t1 set v1='aaaabbbbbbbbbbbbbbbbbbbbb',v2=25 where pk=4;
--error 1406
update t1 set v1='aaabbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb',v2=36 where pk=3;
update t1 set v1='aaaaaab',v2=7 where pk=6;

select * from t1;

#delete major alter(无静态数据)
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(pk int primary key, v1 varchar(10), v2 varchar(10));
insert into t1 values(1,'abbbbbb',6),(2,'aabbbbbbbb',10);

--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/check_all_idx_ok.inc

delete from t1 where pk=1;
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
alter table t1 modify column v1 varchar(15);
insert into t1 values(1,'abbbbbbbbbbbbb',14);
select * from t1;

#长度改小
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(pk varchar(1) primary key, v1 varchar(10), v2 varchar(10));

--source mysql_test/include/index_quick_major.inc
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc

--error 1235
alter table t1 modify column v1 varchar(5);

#边界值和特殊值
desc t1;
--error 1235
alter table t1 modify column v1 varchar(0);
desc t1;
--error 1064
alter table t1 modify column v1 varchar(-1);
desc t1;
alter table t1 modify column v1 varchar(65535);
sleep 1;
desc t1;
alter table t1 modify column v1 varchar(65535);
drop table t1;

create table t1(pk varchar(20) primary key, i1 int, i2 int);
--error 1071 
alter table t1 modify column pk varchar(65537);

create table t2(pk1 varchar(20),pk2 varchar(1024), v1 varchar(20), i2 int , primary key(pk1,pk2));
--error 1071
alter table t2 modify column pk1 varchar(65537);

create table t3(pk varchar(4096) primary key, v1 varchar(65535), v2 varchar(1), v3 varchar(1),v4 varchar(1), v5 varchar(1),v6 varchar(1));
alter table t3 modify column v5 varchar(65535);

create table t4(pk varchar(20) primary key, v1 varchar(20), i2 int);
alter table t4 modify column v1 varchar(65535);

drop table t3;
drop table t1,t2,t4;

#expire
create table t2(pk int primary key, v1 varchar(5), v2 varchar(10)) EXPIRE_INFO (v1='aaaaa');
insert into t2 values(1,'aaaaa',5),(2,'aaaa',4);
alter table t2 modify column v1 varchar(6);
sleep 1;
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/index_quick_major.inc

select * from t2;

insert into t2 values(3,'aaaaaa',6);
--error 1406
insert into t2 values(4,'aaaaaaa',7);
sleep 6;
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
select * from t2;
alter table t2 set EXPIRE_INFO (v1='aaaaaa');
sleep 1;
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
select * from t2;
drop table t2;

create table t3(pk int primary key, v1 varchar(5), v2 varchar(10)) EXPIRE_INFO (v1 = 'aaaaaa');
insert into t3 values(1,'aaaaa',5);
alter table t3 modify column v1 varchar(6);
insert into t3 values(2,'aaaaaa',6);
select * from t3;
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
select * from t3;

alter table t3 set EXPIRE_INFO (v1 > 'aaaaaa');
alter table t3 modify column v1 varchar(8);
insert into t3 values(3,'aaaaaaa',7),(4,'aaaaaaaa',8);
select * from t3;
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
select * from t3;
drop table t3;

##defalut value
create table t4(pk int primary key, v1 varchar(5) default 'aa' not null, v2 varchar(10));

insert into t4 values(1,'aa',2),(2,'aaa',3);
insert into t4(pk,v2) values(3,2);
alter table t4 modify column v1 varchar(6) default 'aa' not null;
sleep 1;
select * from t4;
alter table t4 alter v1 set default 'aaaaa';
sleep 1;
insert into t4(pk,v2) values(4,2);
select * from t4;
alter table t4 alter v1 set default 'aaaaaa';
sleep 1;
select * from t4;
insert into t4(pk,v2) values(5,6);
select * from t4;
--error 1067
alter table t4 alter v1 set default 'aaaaaaa';

--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
select * from t4;
alter table t4 modify column v1 varchar(7) default 'aaaaaa' not null;
insert into t4(pk,v2) values(6,6);
alter table t4 alter v1 set default 'aaaaaaa';
sleep 1;
insert into t4(pk,v2) values(7,7);
--error 1067
alter table t4 alter v1 set default 'aaaaaaaa';
select * from t4;
drop table t4;
 
