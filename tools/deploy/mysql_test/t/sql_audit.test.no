connect (conn5,$OBMYSQL_MS0, user5, user5, test, $OBMYSQL_PORT);
connect (conn6,$OBMYSQL_MS0, user6, user6, test, $OBMYSQL_PORT);

connection conn1;
alter system set obmysql_record_all_request='True' server_type=mergeserver;
--real_sleep 5

#__ob_server
connection conn2;
insert into __all_server (cluster_id, svr_type, svr_ip, svr_port, inner_port) values (9, 'type', '127.0.0.1', 1234, 1234);
update __all_server set svr_ip='255.255.255.255' where cluster_id=9;
select count(*) from oceanbase.__all_server;
delete from oceanbase.__all_server where svr_type='type';

begin;
insert into __all_server (cluster_id, svr_type, svr_ip, svr_port, inner_port) values (9, 'type', '127.0.0.1', 1234, 1234);
update __all_server set svr_ip='255.255.255.255' where cluster_id=9;
select count(*) from oceanbase.__all_server;
delete from oceanbase.__all_server where svr_type='type';
rollback;

create table t1(c1 int primary key);
drop table t1;

select username, sql, params, request_type, status, affected_row from oceanbase.__all_audit_statement where request_type != 129 and request_type != 130 order by request_timestamp;


create table t1 (c1 int primary key);

#__ob_daily_merge_server
connection conn3;
insert into t1 values(1);
update t1 set c1 = 2;
select * from t1;
delete from t1;

begin;
insert into t1 values(1);
update t1 set c1 = 2;
select * from t1;
delete from t1;
commit;

connection conn1;
drop table t1;

select username, sql, params, request_type, status, affected_row from oceanbase.__all_audit_statement where request_type != 129 and request_type != 130 order by request_timestamp;
create table t1 (c1 int primary key);


#admin
#syntax analyze fail
--disable_abort_on_error
--disable_result_log
ssss;
master;
user;
--enable_result_log
--enable_abort_on_error
select username, sql, params, request_type, status, affected_row from oceanbase.__all_audit_statement where request_type != 129 and request_type != 130 order by request_timestamp;

#alter&&DDL
create table t2 (c1 int primary key);
select username, sql, params, request_type, status, affected_row from oceanbase.__all_audit_statement order by request_timestamp desc limit 1;

--disable_result_log
help 'alter table';
--enable_result_log
select username, sql, params, request_type, status, affected_row from oceanbase.__all_audit_statement order by request_timestamp desc limit 1;

alter table t2 rename to t3;
select username, sql, params, request_type, status, affected_row from oceanbase.__all_audit_statement order by request_timestamp desc limit 1;

alter table t3 set COMPRESSION = 'none';
select username, sql, params, request_type, status, affected_row from oceanbase.__all_audit_statement order by request_timestamp desc limit 1;

alter system switch rootserver master;
select username, sql, params, request_type, status, affected_row from oceanbase.__all_audit_statement order by request_timestamp desc limit 1;

alter system reload cluster;
select username, sql, params, request_type, status, affected_row from oceanbase.__all_audit_statement order by request_timestamp desc limit 1;


#error sql
--disable_abort_on_error
--disable_result_log
insert into t1 values(1),(1);
--enable_result_log
select username, sql, params, request_type, status, affected_row from oceanbase.__all_audit_statement order by request_timestamp desc limit 1;

--disable_result_log
select * from t1,t3;
--enable_result_log
select username, sql, params, request_type, status, affected_row from oceanbase.__all_audit_statement order by request_timestamp desc limit 1;

--disable_result_log
select t1 from t1;
--enable_result_log
select username, sql, params, request_type, status, affected_row from oceanbase.__all_audit_statement order by request_timestamp desc limit 1;
--enable_abort_on_error

#update pk
insert into t3 values (1);
select username, sql, params, request_type, status, affected_row from oceanbase.__all_audit_statement order by request_timestamp desc limit 1;

update t3 set c1=2 where c1=1;
select username, sql, params, request_type, status, affected_row from oceanbase.__all_audit_statement order by request_timestamp desc limit 1;

grant all privileges on t3 to 'user4';
select username, sql, params, request_type, status, affected_row from oceanbase.__all_audit_statement order by request_timestamp desc limit 1;

grant all privileges on t3 to 'user5';
select username, sql, params, request_type, status, affected_row from oceanbase.__all_audit_statement order by request_timestamp desc limit 1;
--real_sleep 3

connection conn4;
connection conn5;

#TSC
connection conn4;
begin;
select * from t3 where c1=2 for update wait 5;

connection conn5;
begin;
send update t3 set c1=3 where c1=2;
--real_sleep 2

connection conn4;
rollback;

connection conn5;
reap;
commit;

connection conn1;
select * from t3;
select username, sql, params, request_type, status, affected_row from oceanbase.__all_audit_statement order by request_timestamp desc limit 7;

