alter system set obmysql_record_all_request='false' server_type=mergeserver;
--real_sleep 5
--disable_warnings
drop table if exists t1,t2,t3,t4;
--enable_warnings

create user 'user4' identified by 'user4';
create user 'user5' identified by 'user5';
create user 'user6' identified by 'user6';
--real_sleep 3

connect (conn1,$OBMYSQL_MS0, admin, admin, test,$OBMYSQL_PORT);
connect (conn2,$OBMYSQL_MS0, __ob_server, admin, test,$OBMYSQL_PORT);
connect (conn3,$OBMYSQL_MS0, __ob_daily_merge_server, admin, test,$OBMYSQL_PORT);

