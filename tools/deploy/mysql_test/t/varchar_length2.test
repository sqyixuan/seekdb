--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: dachuan.sdc
# owner group: SQL2
# description:
#
set global  max_allowed_packet=3145728;                                                                                                                                
connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
--disable_warnings
drop table if exists t1, t2, t3, t4, t5;
--enable_warnings

# default length of varchar type
create table t1 (v1 varchar(1024) primary key, v2 varchar(1024));
show columns from t1;

--error 1071
create table t2 (v1 varchar(1025), v2 varchar(261120), primary key(v1, v2));
create table t2 (v1 varchar(1024), v2 varchar(2096), primary key(v1, v2));
--error 1074
create table t4 (c1 int primary key, v2 varchar(262145));
create table t4 (c1 int primary key, v2 varchar(65535));
--error 1074
create table t5 (v1 varchar(262145) primary key, v2 varchar(1572864));
--error 1071
create table t5 (v1 varchar(65535) primary key, v2 varchar(65535), v3 varchar(65535), v4 varchar(65535), v5 varchar(65535), v6 varchar(65535), v7 varchar(1));
create table t5 (v1 varchar(4096) primary key, v2 varchar(65535), v3 varchar(65535), v4 varchar(65535), v5 varchar(65535), v6 varchar(65535));

create table t3 (v1 varchar(4096) primary key);
--let $head=insert into t3 values ('
--let $sixteenbytes=0123456789ABCDEF
--let $body=
--let $tail=')
--let $i=256

while($i)
{
	--let $body=$body$sixteenbytes
	dec $i;
}
--disable_query_log
eval $head$body$tail;
--enable_query_log
select length(v1) from t3;

--let $head2=insert into t5(v1, v2, v3, v4, v5) values ('
--disable_query_log
eval $head2$body', '$body', '$body', '$body', '$body$tail;
--enable_query_log
select length(v1), length(v2), length(v3), length(v4), length(v5), length(v6) from t5;

--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc

select length(v1) from t3;

# alter table check
--error 1074
alter table t3 add column v2 varchar(262145);
alter table t3 add column v2 varchar(65535);
alter table t3 add column v3 varchar(65535);
alter table t3 add column v4 varchar(65535);
alter table t3 add column v5 varchar(65535);
alter table t3 add column v6 varchar(65535);
--error 1118
alter table t3 add column v7 varchar(245760);
alter table t3 add column v8 varchar(1);
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t3;

--error 1071
create index i1 on t3(v2);

# cleanup
--disable_warnings
drop table if exists t1, t2, t3, t4, t5;
--enable_warnings
set global  max_allowed_packet=1048576; 
