--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: bin.lb
#owner group:sql2
# tags: optimizer, join
#description:this case is use for test online use of ob1.0

--disable_warnings
drop table if exists t,b;
--enable_warnings


create table t(x int primary key, c int, c1 int);
create table b(x int primary key, c int);

insert into t values(1,2,1),(2,2,2),(3,3,3);
insert into b values(1,99),(2,98),(3,97);

--sorted_result
select a.c1 as a_c, b.c as b_c from (select c, sum(c1) as c1 from t group by c) a left join b on a.c = b.x ;

insert into t values(4,2,1),(6,2,2),(8,3,3);
insert into b values(5,99),(7,98),(9,97);
--sorted_result
select a.c1 as a_c, b.c as b_c from (select c, sum(c1) as c1 from t group by c) a left join b on a.c = b.x ;
--replace_regex /Plan signature: [0-9]*/Plan signature/
--disable_result_log
--sorted_result
explain select a.c1 as a_c, b.c as b_c from (select c, sum(c1) as c1 from t group by c) a left join b on a.c = b.x ;
--enable_result_log
--sorted_result
select a.c1 as a_c, b.c as b_c from  b  left join (select c, sum(c1) as c1 from t group by c) a  on a.c = b.x ;
--replace_regex /Plan signature: [0-9]*/Plan signature/
--disable_result_log
--sorted_result
explain select a.c1 as a_c, b.c as b_c from  b  left join (select c, sum(c1) as c1 from t group by c) a  on a.c = b.x ;
--enable_result_log
