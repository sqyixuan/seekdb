--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: bin.lb
# owner group: SQL2
# tags: index
# description:
#
# major freeze到合并完成要1分钟左右，case运行时间超过1小时，暂时禁掉。
#
--source mysql_test/include/index_quick_major.inc

let $cnt=74;
--disable_query_log
--disable_warnings
while($cnt) 
{
eval drop table if exists ttl$cnt;
eval  create table ttl$cnt(i1 int, v2 varchar(80), i3 char(20),i4 float, d4 datetime(6),i5 decimal(5,3), primary key(i1));
eval  create index ttlidx_1 on ttl$cnt(i1);
eval  create index ttlidx_2 on ttl$cnt(v2);
sleep 1;
--source mysql_test/include/majorfreeze.inc;
##--source mysql_test/include/check_all_idx_ok.inc
--source mysql_test/include/wait_daily_merge.inc
dec $cnt;
}
--enable_warnings
--enable_query_log
show tables like 'ttl%';
--disable_query_log
let $cnt5=74;
while ($cnt5)
{
eval drop table  ttl$cnt5;
dec $cnt5;
}
--enable_query_log
sleep 3;
show tables like 'ttl%';
