--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: bin.lb
# owner group: SQL3
# description:
#
--disable_query_log
--source mysql_test/include/index_quick_major.inc
--real_sleep 2 
--enable_query_log
####case set merge step ,index,expire info at the same time 
--disable_warnings
drop table if exists tbl1,tbl2,tbl3;
--enable_warnings
create table tbl1 (i1 int, v2 varchar(80), i3 char(20),i4 float, d4 datetime(6),i5 decimal(5,3), primary key(i1)) progressive_merge_num=3,EXPIRE_INFO ((i1<=10));
create  unique index idx1 on tbl1(v2);
####alter table tbl1 set expire_info=(null));
sleep 1;
####case:unique index with merge step`
--error 1061
create  unique index idx1 on tbl1(v2);
insert into tbl1 values(1,'now','haha',1.6256,'2014-05-04 12:00:00',-10.235);
insert into tbl1 values(2,'now1','haha',1.6256,'2014-05-04 12:00:00',-10.235);
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/check_all_idx_ok_unq.inc
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/check_all_idx_ok.inc
alter table  tbl1  alter  column v2 set  default 'aaa'; 
sleep 1;
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
--error 1062
insert into tbl1 values(3,'now1','haha',1.6256,'2014-05-04 12:00:00',-10.235);
select * from tbl1;
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
insert into tbl1 values(4,'now4','haha',1.6256,'2014-05-04 12:00:00',-10.235);
select * from tbl1;
####case:unique with expire info,insert expire data
create table tbl2 (i1 int, v2 varchar(80), i3 char(20),i4 float, d4 datetime(6),i5 decimal(5,3), primary key(i1)) EXPIRE_INFO ((i1<=10));
create  unique index idx21 on tbl1(v2);
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/check_all_idx_ok_unq.inc
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/check_all_idx_ok.inc
