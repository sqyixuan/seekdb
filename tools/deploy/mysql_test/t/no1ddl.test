, currency_code VARCHAR(8) COMMENT '币种'
, clear_date VARCHAR(8) COMMENT '结清日期'
, status VARCHAR(32) COMMENT '状态:放款中LENDING 正常NORMAL,逾期OVD,结清CLEAR,核销WRITEOFF'
, total_term INT COMMENT '总期次'
, install_start_date VARCHAR(8) COMMENT '分期开始日期'
, install_total_term INT COMMENT '分期总期次'
, install_prin_amt INT COMMENT '分期本金'
, back_int_total_amt INT NOT NULL COMMENT '退息总额'
, prin_grace_end_date VARCHAR(8) COMMENT '本金宽限到期日'
, int_grace_end_date VARCHAR(8) COMMENT '利息宽限到期日'
, grace_type VARCHAR(32) COMMENT '宽限类型'
, int_recover_type VARCHAR(32) COMMENT '宽限后利息恢复类型'
, ovd_days INT COMMENT '逾期天数'
, ovd_terms INT NOT NULL COMMENT '逾期期数'
, prin_ovd_days INT COMMENT '本金逾期天数'
, int_ovd_days INT COMMENT '利息逾期天数'
