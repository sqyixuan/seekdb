, pre_charge_no VARCHAR(64) COMMENT '预计费单号'
, charge_amount INT COMMENT '收费金额'
, charge_currency VARCHAR(8) COMMENT '收费币种'
, PRIMARY KEY(tnt_inst_id, order_id)
) COMMENT = '冻结单据(分库分表)', DEFAULT CHARSET = 'utf8';
