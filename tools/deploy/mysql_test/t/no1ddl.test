CREATE TABLE af_extension_field_cfg (
gmt_create TIMESTAMP NOT NULL COMMENT '创建时间'
, gmt_modified TIMESTAMP NOT NULL COMMENT '修改时间'
, pd_code VARCHAR(20) NOT NULL COMMENT '产品码'
, tnt_inst_id VARCHAR(8) NOT NULL COMMENT '租户ID'
, field_name VARCHAR(32) NOT NULL COMMENT '域名称'
, property_name VARCHAR(32) NOT NULL COMMENT '属性名称'
, asset_tool_name VARCHAR(32) NOT NULL COMMENT '资产工具名称'
, null_flag VARCHAR(32) NOT NULL COMMENT '是否为空'
, control_env VARCHAR(32) NOT NULL COMMENT '环境'
, creator VARCHAR(64) NOT NULL COMMENT '创建者'
, operator VARCHAR(64) NOT NULL COMMENT '操作者'
, PRIMARY KEY(tnt_inst_id, pd_code, field_name, property_name, control_env, asset_tool_name)
)COMMENT = '扩展字段管控表', DEFAULT CHARSET = 'utf8';

CREATE TABLE af_asset_tool_service_cfg (
gmt_create TIMESTAMP NOT NULL COMMENT '创建时间'
, gmt_modified TIMESTAMP NOT NULL COMMENT '修改时间'
, tnt_inst_id VARCHAR(8) NOT NULL COMMENT '租户机构ID'
, asset_tool_service_key VARCHAR(32) NOT NULL COMMENT '资产工具名称'
, service_url VARCHAR(1024) NOT NULL COMMENT '调用地址url'
, action VARCHAR(32) NOT NULL COMMENT '指令操作类型'
, unique_id VARCHAR(64) NOT NULL COMMENT '服务唯一标识'
, action_group VARCHAR(32) COMMENT '原子活动标识'
, business_source_stm VARCHAR(32) NOT NULL COMMENT '来源系统'
, time_out INT NOT NULL DEFAULT 0 COMMENT '服务调用超时时间（ms）'
, PRIMARY KEY(tnt_inst_id, asset_tool_service_key, action, unique_id, business_source_stm)
) COMMENT = '下游资产工具调用地址配置', DEFAULT CHARSET = 'utf8';

CREATE TABLE af_message_recover (
gmt_create TIMESTAMP NOT NULL COMMENT '创建时间'
, gmt_modified TIMESTAMP NOT NULL COMMENT '修改时间'
, order_id VARCHAR(64) COMMENT '单据ID'
, pd_seq_no VARCHAR(64) NOT NULL COMMENT '上层业务流水号'
, request_id VARCHAR(32) NOT NULL COMMENT '上层业务请求ID'
, tnt_inst_id VARCHAR(8) NOT NULL COMMENT '租户ID'
, message_type VARCHAR(32) NOT NULL COMMENT '消息类型  1为受理类 2为结果类'
, env VARCHAR(16) NOT NULL COMMENT '消息环境: 1为线上 2为预发'
, error_cntxt VARCHAR(1024) COMMENT '错误信息'
, PRIMARY KEY(tnt_inst_id, pd_seq_no, request_id, message_type)
) COMMENT = '消息定时重试任务表', DEFAULT CHARSET = 'utf8';

CREATE TABLE af_credit_out_pay_order_000 (
gmt_create TIMESTAMP NOT NULL COMMENT '创建时间'
, gmt_modified TIMESTAMP NOT NULL COMMENT '修改时间'
, order_id VARCHAR(64) NOT NULL COMMENT '单据ID'
, fund_detail_id VARCHAR(64) NOT NULL COMMENT '单据详情ID'
, tnt_inst_id VARCHAR(8) NOT NULL COMMENT '租户ID'
, status VARCHAR(32) NOT NULL COMMENT '任务状态'
, accept_msg VARCHAR(65535) NOT NULL COMMENT '金融网关报文'
, receipt_msg VARCHAR(65535) COMMENT '金融网关回复报文'
, env VARCHAR(32) NOT NULL COMMENT '环境:预发or线上'
, gmt_send TIMESTAMP COMMENT '金融网关发送时间'
, gmt_receipt TIMESTAMP COMMENT '金融网关回执时间'
, event_cntxt VARCHAR(1024) COMMENT '事件上下文'
, PRIMARY KEY(tnt_inst_id, order_id, fund_detail_id)
) COMMENT = '支付流出任务(分库分表)', DEFAULT CHARSET = 'utf8';
CREATE TABLE crt_accounting_code (
tnt_inst_id VARCHAR(8) NOT NULL COMMENT '租户ID'
, accounting_code VARCHAR(10) NOT NULL COMMENT '核算码'
, recon_inst VARCHAR(32) NOT NULL COMMENT '核算机构'
, operator VARCHAR(32) NOT NULL COMMENT '操作员'
, gmt_create TIMESTAMP NOT NULL COMMENT '创建时间'
, gmt_modified TIMESTAMP NOT NULL COMMENT '最后修改时间'
, memo VARCHAR(256) COMMENT '备注'
, PRIMARY KEY(tnt_inst_id, accounting_code, recon_inst)
)  COMMENT = '核算码表', DEFAULT CHARSET = 'utf8';

CREATE TABLE crt_accounting_code_checker (
tnt_inst_id VARCHAR(8) NOT NULL COMMENT '租户ID'
, recon_inst VARCHAR(32) NOT NULL COMMENT '核算机构'
, accounting_code VARCHAR(10) NOT NULL COMMENT '核算码'
, checker VARCHAR(64) NOT NULL COMMENT '校验器'
, priority VARCHAR(2) NOT NULL COMMENT '优先级'
, enable VARCHAR(1) NOT NULL COMMENT '是否生效'
, operator VARCHAR(32) NOT NULL COMMENT '创建操作员'
, gmt_create TIMESTAMP NOT NULL COMMENT '创建时间'
, gmt_modified TIMESTAMP NOT NULL COMMENT '最后修改时间'
, memo VARCHAR(256) COMMENT '备注'
, PRIMARY KEY(tnt_inst_id, recon_inst, accounting_code, checker)
)  COMMENT = '核算码校验表', DEFAULT CHARSET = 'utf8';

CREATE TABLE crt_cache_manager (
tnt_inst_id VARCHAR(8) NOT NULL COMMENT '租户ID'
, server_ip VARCHAR(16) NOT NULL COMMENT '服务器ip'
, server_name VARCHAR(64) NOT NULL COMMENT '服务器名称'
, cache_name VARCHAR(64) NOT NULL COMMENT '缓存名称'
, status VARCHAR(16) NOT NULL COMMENT '状态'
, operator VARCHAR(32) NOT NULL COMMENT '操作员'
, gmt_create TIMESTAMP NOT NULL COMMENT '创建时间'
, gmt_modified TIMESTAMP NOT NULL COMMENT '更新时间'
, memo VARCHAR(256) COMMENT '备注'
, PRIMARY KEY(tnt_inst_id, server_ip, server_name, cache_name)
)  COMMENT = '缓存管理表', DEFAULT CHARSET = 'utf8';

CREATE TABLE crt_category_code (
tnt_inst_id VARCHAR(8) NOT NULL COMMENT '租户ID'
, recon_inst VARCHAR(32) NOT NULL COMMENT '核算机构'
, category_code VARCHAR(14) NOT NULL COMMENT '归类码'
, category_code_name VARCHAR(64) NOT NULL COMMENT '归类码名称'
, title_scope VARCHAR(1) NOT NULL COMMENT '表内表外属性'
, balance_direction VARCHAR(3) NOT NULL COMMENT '余额方向'
, operator VARCHAR(32) NOT NULL COMMENT '操作员'
, gmt_create TIMESTAMP NOT NULL COMMENT '创建时间'
, gmt_modified TIMESTAMP NOT NULL COMMENT '最后修改时间'
, memo VARCHAR(256) COMMENT '备注'
, PRIMARY KEY(tnt_inst_id, recon_inst, category_code)
)  COMMENT = '归类码表', DEFAULT CHARSET = 'utf8';

CREATE TABLE crt_daily_cut_log (
tnt_inst_id VARCHAR(8) NOT NULL COMMENT '租户ID'
, recon_inst VARCHAR(32) NOT NULL COMMENT '核算机构'
, cut_date VARCHAR(8) NOT NULL COMMENT '日切日期'
, currency VARCHAR(3) NOT NULL COMMENT '币种'
, task_name VARCHAR(64) NOT NULL COMMENT '子任务名称'
, task_status VARCHAR(1) NOT NULL COMMENT '任务状态'
, gmt_start TIMESTAMP NOT NULL COMMENT '日切开始时间'
, gmt_finish TIMESTAMP NOT NULL COMMENT '日切结束时间'
, PRIMARY KEY(tnt_inst_id, recon_inst, cut_date, currency, task_name)
)  COMMENT = '日切日志表', DEFAULT CHARSET = 'utf8';

CREATE TABLE crt_main_accounting_code (
tnt_inst_id VARCHAR(8) NOT NULL COMMENT '租户ID'
, main_accounting_code VARCHAR(3) NOT NULL COMMENT '核算主码'
, recon_inst VARCHAR(32) NOT NULL COMMENT '核算机构'
, main_accounting_desc VARCHAR(64) NOT NULL COMMENT '核算主码描述'
, operator VARCHAR(32) NOT NULL COMMENT '创建操作员'
, gmt_create TIMESTAMP NOT NULL COMMENT '创建时间'
, gmt_modified TIMESTAMP NOT NULL COMMENT '最后修改时间'
, memo VARCHAR(256) COMMENT '备注'
, PRIMARY KEY(tnt_inst_id, main_accounting_code, recon_inst)
)  COMMENT = '核算主码表', DEFAULT CHARSET = 'utf8';

CREATE TABLE crt_main_accounting_code_checker (
tnt_inst_id VARCHAR(8) NOT NULL COMMENT '租户ID'
, main_accounting_code VARCHAR(3) NOT NULL COMMENT '核算主码'
, recon_inst VARCHAR(32) NOT NULL COMMENT '核算机构'
, checker VARCHAR(64) NOT NULL COMMENT '检查器'
, priority VARCHAR(2) NOT NULL COMMENT '优先级'
, operator VARCHAR(32) NOT NULL COMMENT '操作员'
, gmt_create TIMESTAMP NOT NULL COMMENT '创建时间'
, gmt_modified TIMESTAMP NOT NULL COMMENT '最后修改时间'
, memo VARCHAR(256) COMMENT '备注'
, PRIMARY KEY(tnt_inst_id, main_accounting_code, recon_inst, checker)
)  COMMENT = '检查器配置表', DEFAULT CHARSET = 'utf8';

CREATE TABLE crt_main_accounting_code_processor (
tnt_inst_id VARCHAR(8) NOT NULL COMMENT '租户ID'
, main_accounting_code VARCHAR(3) NOT NULL COMMENT '核算主码'
, recon_inst VARCHAR(32) NOT NULL COMMENT '核算机构'
, reserve_processor VARCHAR(64) NOT NULL COMMENT '预处理器'
, finish_processor VARCHAR(64) NOT NULL COMMENT '完结处理器'
, operator VARCHAR(32) NOT NULL COMMENT '创建操作员'
, gmt_create TIMESTAMP NOT NULL COMMENT '创建时间'
, gmt_modified TIMESTAMP NOT NULL COMMENT '最后修改时间'
, memo VARCHAR(256) COMMENT '备注'
, PRIMARY KEY(tnt_inst_id, main_accounting_code, recon_inst)
)  COMMENT = '处理器配置表', DEFAULT CHARSET = 'utf8';

CREATE TABLE crt_account_info_000 (
tnt_inst_id VARCHAR(8) NOT NULL COMMENT '租户ID'
, account_no VARCHAR(20) NOT NULL COMMENT '交易账号'
, account_type VARCHAR(64) NOT NULL COMMENT '账号类型'
, account_alias VARCHAR(64) COMMENT '账号别名'
, account_status VARCHAR(1) NOT NULL COMMENT '账户状态，T-正常，B-冻结，C-销户'
, life_cycle_status VARCHAR(1) NOT NULL COMMENT '账号生命周期状态'
, recon_inst VARCHAR(32) NOT NULL COMMENT '核算机构'
, currency VARCHAR(3) NOT NULL COMMENT '币种'
, operator VARCHAR(32) COMMENT '操作员'
, unique_id VARCHAR(64) NOT NULL COMMENT '账号与业务单据的唯一映射号'
, gmt_create TIMESTAMP NOT NULL COMMENT '创建时间'
, gmt_modified TIMESTAMP NOT NULL COMMENT '最后修改时间'
, memo VARCHAR(256) COMMENT '备注'
, PRIMARY KEY(tnt_inst_id, account_no)
)  COMMENT = '账户表', DEFAULT CHARSET = 'utf8';
create unique index idx_uk_unique_id on crt_account_info_000 (tnt_inst_id,unique_id);

CREATE TABLE crt_fccredittrans_sequence_000 (
name VARCHAR(64) NOT NULL COMMENT 'sequence名称'
, value INT NOT NULL COMMENT 'sequence当前值'
, min_value INT NOT NULL COMMENT '最小值'
, max_value INT NOT NULL COMMENT '最大值'
, step INT NOT NULL COMMENT '步长'
, gmt_create TIMESTAMP NOT NULL COMMENT '创建时间'
, gmt_modified TIMESTAMP NOT NULL COMMENT '最后修改时间'
, PRIMARY KEY(name)
)  COMMENT = 'sequence表', DEFAULT CHARSET = 'utf8';


CREATE TABLE crt_business_action_000 (
action_id VARCHAR(128) NOT NULL COMMENT '原子业务活动Id'
, tx_id VARCHAR(128) NOT NULL COMMENT '事务号'
, name VARCHAR(64) NOT NULL COMMENT '原子业务活动名称'
, state VARCHAR(16) NOT NULL COMMENT '原子业务活动状态'
, context VARCHAR(60000) COMMENT '原子业务活动请求上下文'
, gmt_create TIMESTAMP NOT NULL COMMENT '创建时间'
, gmt_modified TIMESTAMP NOT NULL COMMENT '最近修改时间'
, PRIMARY KEY(action_id)
)  COMMENT = '贷记账务分支事务表', DEFAULT CHARSET = 'utf8';

CREATE TABLE crt_product_code_mapping (
tnt_inst_id VARCHAR(8) NOT NULL COMMENT '租户ID'
, product_code VARCHAR(20) NOT NULL COMMENT '产品码'
, event_code VARCHAR(8) NOT NULL COMMENT '事件码'
, balance_type VARCHAR(18) NOT NULL COMMENT '余额类型'
, recon_inst VARCHAR(32) NOT NULL COMMENT '核算机构'
, accounting_code VARCHAR(10) NOT NULL COMMENT '核算码'
, operator VARCHAR(32) NOT NULL COMMENT '创建操作员'
, gmt_create TIMESTAMP NOT NULL COMMENT '创建时间'
, gmt_modified TIMESTAMP NOT NULL COMMENT '最后修改时间'
, memo VARCHAR(256) COMMENT '备注'
, PRIMARY KEY(tnt_inst_id, product_code, event_code, balance_type, recon_inst)
)  COMMENT = '产品码映射表', DEFAULT CHARSET = 'utf8';

CREATE TABLE crt_accounting_code_rule_mapping (
tnt_inst_id VARCHAR(8) NOT NULL COMMENT '租户ID'
, accounting_code VARCHAR(10) NOT NULL COMMENT '核算码'
, recon_inst VARCHAR(32) NOT NULL COMMENT '核算机构'
, trans_rule_code VARCHAR(20) NOT NULL COMMENT '规则主键ID'
, operator VARCHAR(32) NOT NULL COMMENT '操作员'
, memo VARCHAR(256) COMMENT '备注'
, gmt_create TIMESTAMP NOT NULL COMMENT '创建时间'
, gmt_modified TIMESTAMP NOT NULL COMMENT '最后修改时间'
, PRIMARY KEY(tnt_inst_id, accounting_code, recon_inst, trans_rule_code)
)  COMMENT = '核算码规则映射表', DEFAULT CHARSET = 'utf8';

CREATE TABLE crt_category_rule (
tnt_inst_id VARCHAR(8) NOT NULL COMMENT '租户ID'
, recon_inst VARCHAR(32) NOT NULL COMMENT '核算机构'
, category_rule_value VARCHAR(256) NOT NULL COMMENT '归类规则属性集合'
, main_account_type VARCHAR(30) NOT NULL COMMENT '一级账户类型'
, rule_id VARCHAR(32) NOT NULL COMMENT '规则编码'
, account_type VARCHAR(30) NOT NULL COMMENT '二级账户类型'
, category_code VARCHAR(14) NOT NULL COMMENT '归类码'
, operator VARCHAR(32) NOT NULL COMMENT '操作员'
, memo VARCHAR(256) COMMENT '备注'
, gmt_create TIMESTAMP NOT NULL COMMENT '创建时间'
, gmt_modified TIMESTAMP NOT NULL COMMENT '最后修改时间'
, PRIMARY KEY(tnt_inst_id, recon_inst, category_rule_value, main_account_type, rule_id)
)  COMMENT = '归类码规则表', DEFAULT CHARSET = 'utf8';

CREATE TABLE crt_trans_rule (
tnt_inst_id VARCHAR(8) NOT NULL COMMENT '租户ID'
, trans_rule_code VARCHAR(20) NOT NULL COMMENT '规则主键ID'
, recon_inst VARCHAR(32) NOT NULL COMMENT '核算机构'
, ctrl_property_name VARCHAR(128) NOT NULL COMMENT '限制属性名'
, ctrl_property_value_list VARCHAR(128) NOT NULL COMMENT '限制属性值'
, ctrl_model VARCHAR(2) NOT NULL COMMENT '限制模式 W-白名单 B-黑名单'
, memo VARCHAR(256) COMMENT '备注'
, operator VARCHAR(32) NOT NULL COMMENT '创建操作员'
, gmt_create TIMESTAMP NOT NULL COMMENT '创建时间'
, gmt_modified TIMESTAMP NOT NULL COMMENT '最后修改时间'
, PRIMARY KEY(tnt_inst_id, trans_rule_code, recon_inst, ctrl_property_name)
)  COMMENT = '交易规则表', DEFAULT CHARSET = 'utf8';

CREATE TABLE crt_account_log_000 (
tnt_inst_id VARCHAR(8) NOT NULL COMMENT '租户ID'
, account_log_id VARCHAR(64) NOT NULL COMMENT '账户明细主键'
, account_no VARCHAR(20) NOT NULL COMMENT '交易账号'
, balance_type VARCHAR(18) NOT NULL COMMENT '余额类型'
, other_account_no VARCHAR(20) COMMENT '交易对方账号'
, other_recon_inst VARCHAR(32) COMMENT '交易对方机构'
, accounting_code VARCHAR(10) NOT NULL COMMENT '核算码'
, recon_inst VARCHAR(32) NOT NULL COMMENT '核算机构'
, product_code VARCHAR(20) NOT NULL COMMENT '产品码'
, event_code VARCHAR(8) NOT NULL COMMENT '事件码'
, order_no VARCHAR(128) COMMENT '业务单据号'
, out_biz_no VARCHAR(128) COMMENT '外部单据号'
, exchange_no VARCHAR(128) NOT NULL COMMENT '资产交换单据号'
, trans_amount INT NOT NULL COMMENT '交易金额'
, balance INT NOT NULL COMMENT '交易后最新余额'
, currency VARCHAR(3) NOT NULL COMMENT '币种'
, trans_dt TIMESTAMP NOT NULL COMMENT '交易时间'
, out_dt TIMESTAMP NOT NULL COMMENT '外部业务发生日期'
, gmt_exchange TIMESTAMP NOT NULL COMMENT '资产交换时间'
, is_red VARCHAR(1) NOT NULL COMMENT '是否红字'
, is_delete VARCHAR(1) NOT NULL COMMENT '是否购销'
, operator VARCHAR(32) COMMENT '操作员'
, memo VARCHAR(256) COMMENT '备注'
, trans_log_id VARCHAR(64) NOT NULL COMMENT '记账凭证主键'
, orig_trans_log_id VARCHAR(32) COMMENT '原始记账凭证主键'
, gmt_create TIMESTAMP NOT NULL COMMENT '创建时间'
, gmt_modified TIMESTAMP NOT NULL COMMENT '最后修改时间'
, PRIMARY KEY(tnt_inst_id, account_log_id)
)  COMMENT = '账务变动明细表', DEFAULT CHARSET = 'utf8';

CREATE TABLE crt_trans_info_000 (
tnt_inst_id VARCHAR(8) NOT NULL COMMENT '租户ID'
, trans_info_id VARCHAR(32) NOT NULL COMMENT '分支事务编号'
, tx_id VARCHAR(128) NOT NULL COMMENT '事务ID'
, system_transaction_id VARCHAR(128) NOT NULL COMMENT '分布式事务系统唯一约束号'
, account_no VARCHAR(20) NOT NULL COMMENT '交易账号'
, balance_type VARCHAR(18) NOT NULL COMMENT '余额类型'
, other_account_no VARCHAR(20) COMMENT '交易对方账号'
, other_recon_inst VARCHAR(32) COMMENT '交易对方机构'
, recon_inst VARCHAR(32) NOT NULL COMMENT '对方机构'
, accounting_code VARCHAR(16) NOT NULL COMMENT '核算码'
, product_code VARCHAR(20) NOT NULL COMMENT '产品码'
, event_code VARCHAR(8) NOT NULL COMMENT '事件码'
, order_no VARCHAR(128) COMMENT '业务单据号'
, out_biz_no VARCHAR(128) COMMENT '外部单据号'
, exchange_no VARCHAR(128) NOT NULL COMMENT '资产交换单据号'
, trans_amount INT NOT NULL COMMENT '交易金额'
, currency VARCHAR(3) NOT NULL COMMENT '币种'
, trans_dt TIMESTAMP NOT NULL COMMENT '交易时间'
, out_dt TIMESTAMP NOT NULL COMMENT '外部业务发生日期'
, gmt_exchange TIMESTAMP NOT NULL COMMENT '资产交换时间'
, operator VARCHAR(32) COMMENT '操作员'
, memo VARCHAR(256) COMMENT '备注'
, trans_log_id VARCHAR(64) NOT NULL COMMENT '记账凭证主键'
, orig_trans_log_id VARCHAR(32) COMMENT '原始记账凭证主键'
, voucher_id VARCHAR(64) COMMENT '凭证号'
, unique_id VARCHAR(64) COMMENT '唯一标识号'
, gmt_create TIMESTAMP NOT NULL COMMENT '创建时间'
, gmt_modified TIMESTAMP NOT NULL COMMENT '最后修改时间'
, PRIMARY KEY(tnt_inst_id, trans_info_id)
)  COMMENT = '交易信息表', DEFAULT CHARSET = 'utf8';
create index idx_tnt_inst_id_account_no on crt_trans_info_000 (tnt_inst_id,account_no);

CREATE TABLE crt_account_balance_000 (
tnt_inst_id VARCHAR(8) NOT NULL COMMENT '租户ID'
, account_no VARCHAR(20) NOT NULL COMMENT '交易账号'
, balance_type VARCHAR(18) NOT NULL COMMENT '余额类型'
, recon_inst VARCHAR(32) NOT NULL COMMENT '核算机构'
, account_balance INT NOT NULL COMMENT '余额'
, system_amount INT NOT NULL COMMENT '系统金额'
, previous_balance INT NOT NULL COMMENT '上期期末金额'
, previous_date VARCHAR(8) NOT NULL COMMENT '上期日期'
, accrued_status VARCHAR(1) NOT NULL COMMENT '应计状态'
, freeze_mode VARCHAR(2) NOT NULL COMMENT '冻结模式'
, last_trans_date TIMESTAMP NOT NULL COMMENT '最后交易时间'
, currency VARCHAR(3) NOT NULL COMMENT '币种'
, direction VARCHAR(3) NOT NULL COMMENT '余额方向'
, category_code VARCHAR(14) NOT NULL COMMENT '归类码'
, category_rule_id VARCHAR(32) NOT NULL COMMENT '归类规则ID'
, gmt_create TIMESTAMP NOT NULL COMMENT '创建时间'
, gmt_modified TIMESTAMP NOT NULL COMMENT '最后修改时间'
, PRIMARY KEY(tnt_inst_id, account_no, balance_type)
)  COMMENT = '账户余额表', DEFAULT CHARSET = 'utf8';

CREATE TABLE crt_account_daily_000 (
tnt_inst_id VARCHAR(8) NOT NULL COMMENT '租户ID'
, account_no VARCHAR(20) NOT NULL COMMENT '交易账号'
, balance_type VARCHAR(18) NOT NULL COMMENT '余额类型'
, account_date VARCHAR(8) NOT NULL COMMENT '会计日'
, recon_inst VARCHAR(32) NOT NULL COMMENT '核算机构'
, currency VARCHAR(3) NOT NULL COMMENT '币种'
, today_out_amount INT NOT NULL COMMENT '今日流出总金额'
, today_in_amount INT NOT NULL COMMENT '今日流入总金额'
, today_out_count INT NOT NULL COMMENT '当日资金流入笔数'
, today_in_count INT NOT NULL COMMENT '当日资金流出笔数'
, closing_balance INT NOT NULL COMMENT '余额'
, gmt_create TIMESTAMP NOT NULL COMMENT '创建时间'
, gmt_modified TIMESTAMP NOT NULL COMMENT '最后修改时间'
, PRIMARY KEY(tnt_inst_id, account_no, balance_type, account_date)
)  COMMENT = '账户日变动表', DEFAULT CHARSET = 'utf8';

CREATE TABLE crt_manage_log_000 (
tnt_inst_id VARCHAR(8) NOT NULL COMMENT '租户ID'
, manage_log_id VARCHAR(64) NOT NULL COMMENT '管理日志主键'
, recon_inst VARCHAR(32) NOT NULL COMMENT '核算机构'
, account_no VARCHAR(20) NOT NULL COMMENT '交易账号'
, operate_type VARCHAR(32) NOT NULL COMMENT '操作类型'
, operator VARCHAR(32) COMMENT '操作员'
, content VARCHAR(1024) NOT NULL COMMENT '日志内容'
, memo VARCHAR(256) COMMENT '备注'
, gmt_create TIMESTAMP NOT NULL COMMENT '创建时间'
, gmt_modified TIMESTAMP NOT NULL COMMENT '最后修改时间'
, PRIMARY KEY(tnt_inst_id, manage_log_id)
)  COMMENT = '账务管理日志表', DEFAULT CHARSET = 'utf8';

CREATE TABLE crt_main_transaction_000 (
tnt_inst_id VARCHAR(8) NOT NULL COMMENT '租户ID'
, system_transaction_id VARCHAR(128) NOT NULL COMMENT '分布式事务唯一约束号'
, tx_id VARCHAR(128) NOT NULL COMMENT '事务号'
, status VARCHAR(1) NOT NULL COMMENT '主事务状态 C-已提交，P-准备状态'
, gmt_create TIMESTAMP NOT NULL COMMENT '创建时间'
, gmt_modified TIMESTAMP NOT NULL COMMENT '最后修改时间'
, PRIMARY KEY(tnt_inst_id, system_transaction_id, tx_id)
)  COMMENT = '主事务表', DEFAULT CHARSET = 'utf8';

CREATE TABLE crt_trans_log_000 (
tnt_inst_id VARCHAR(8) NOT NULL COMMENT '租户ID'
, trans_log_id VARCHAR(64) NOT NULL COMMENT '记账凭证主键'
, recon_inst VARCHAR(32) NOT NULL COMMENT '机构'
, accounting_code VARCHAR(10) NOT NULL COMMENT '核算码'
, exchange_no VARCHAR(128) NOT NULL COMMENT '资产交换支付单号'
, account_no VARCHAR(20) NOT NULL COMMENT '交易账号'
, balance_type VARCHAR(18) NOT NULL COMMENT '余额类型'
, other_account_no VARCHAR(20) COMMENT '交易对方账号'
, other_recon_inst VARCHAR(32) COMMENT '对方机构ID'
, product_code VARCHAR(20) NOT NULL COMMENT '产品码'
, event_code VARCHAR(8) NOT NULL COMMENT '事件码'
, order_no VARCHAR(128) COMMENT '业务单据号'
, out_biz_no VARCHAR(128) COMMENT '外部单据号'
, trans_amount INT NOT NULL COMMENT '交易金额'
, currency VARCHAR(3) NOT NULL COMMENT '币种'
, trans_dt TIMESTAMP NOT NULL COMMENT '交易时间'
, out_dt TIMESTAMP NOT NULL COMMENT '外部业务发生日期'
, gmt_exchange TIMESTAMP NOT NULL COMMENT '资产交换时间'
, operator VARCHAR(32) COMMENT '操作员'
, memo VARCHAR(256) COMMENT '备注'
, orig_trans_log_id VARCHAR(32) COMMENT '原始记账凭证主键'
, voucher_id VARCHAR(32) COMMENT '凭证号'
, gmt_create TIMESTAMP NOT NULL COMMENT '创建时间'
, gmt_modified TIMESTAMP NOT NULL COMMENT '最后修改时间'
, PRIMARY KEY(tnt_inst_id, trans_log_id)
)  COMMENT = '记账凭证表', DEFAULT CHARSET = 'utf8';

CREATE TABLE crt_system_money_manager_000 (
tnt_inst_id VARCHAR(8) NOT NULL COMMENT '租户ID'
, system_transaction_id VARCHAR(128) NOT NULL COMMENT '分布式事务唯一约束号'
, account_no VARCHAR(20) NOT NULL COMMENT '交易账号'
, balance_type VARCHAR(18) NOT NULL COMMENT '余额类型'
, reserve_type VARCHAR(10) NOT NULL COMMENT '预处理类型'
, tx_id VARCHAR(128) NOT NULL COMMENT '事务号'
, amount INT NOT NULL COMMENT '系统金额'
, currency VARCHAR(3) NOT NULL COMMENT '币种'
, gmt_create TIMESTAMP NOT NULL COMMENT '创建时间'
, gmt_modified TIMESTAMP NOT NULL COMMENT '最后修改时间'
, PRIMARY KEY(tnt_inst_id, system_transaction_id, account_no, balance_type, reserve_type, tx_id)
)  COMMENT = '系统金额管理表', DEFAULT CHARSET = 'utf8';

CREATE TABLE crt_system_param (
tnt_inst_id VARCHAR(8) NOT NULL COMMENT '租户ID'
, recon_inst VARCHAR(32) NOT NULL COMMENT '核算机构'
, sys_code VARCHAR(32) NOT NULL COMMENT '系统参数代码'
, sys_value VARCHAR(1024) NOT NULL COMMENT '系统参数值'
, operator VARCHAR(32) NOT NULL COMMENT '操作员'
, memo VARCHAR(256) COMMENT '备注'
, gmt_create TIMESTAMP NOT NULL COMMENT '创建时间'
, gmt_modified TIMESTAMP NOT NULL COMMENT '更新时间'
, PRIMARY KEY(tnt_inst_id, recon_inst, sys_code)
)  COMMENT = '系统参数表', DEFAULT CHARSET = 'utf8';
CREATE TABLE loc_arg_repay_instruction_000 (
id VARCHAR(64) NOT NULL COMMENT '主键'
, tnt_inst_id VARCHAR(8) NOT NULL COMMENT '租户号'
, ip_id VARCHAR(32) NOT NULL COMMENT '参与者号'
, ip_role_id VARCHAR(32) NOT NULL COMMENT '参与者角色ID'
, argmnt_no VARCHAR(64) NOT NULL COMMENT '合约号'
, account_no VARCHAR(64) NOT NULL COMMENT '分户号'
, currency_code VARCHAR(8) COMMENT '币种'
, prod_code VARCHAR(20) COMMENT '产品码'
, repay_divide_mode VARCHAR(32) COMMENT '还款入账规则 FORWARD:正向  REVERSE：反向 SPECIFIED：指定金额'
, repay_future_mode VARCHAR(1) COMMENT '未来期次本金入账规则: 1 减少每月还款额 2 缩期'
, org_code VARCHAR(32) COMMENT '机构号'
, settle_date VARCHAR(8) COMMENT '会计时间—发起者生成的时间.没有时分秒的记账日期'
, finish_time TIMESTAMP COMMENT '交易时间-本系统完成此交易的时间.有时分秒的'
, request_id VARCHAR(64) NOT NULL COMMENT '单次调用的单据号'
, out_biz_no VARCHAR(64) NOT NULL COMMENT '贷款业务平台流水号,用于串连整个业务'
, seq_no VARCHAR(64) NOT NULL COMMENT '业务流水号，本系统发生业务的流水号'
, upper_event_code VARCHAR(8) NOT NULL COMMENT '上层事件码，由贷款业务平台产生'
, event_code VARCHAR(8) NOT NULL COMMENT '本系统事件码'
, memo VARCHAR(765) COMMENT '备注'
, status_before VARCHAR(32) COMMENT '交易前合约状态(正常,逾期,结清)'
, status_after VARCHAR(32) COMMENT '交易后合约状态(正常,逾期,结清)'
, asset_class_before VARCHAR(1) COMMENT '交易前五级分类状态 1:正常 2：关注 3：次级 4：可疑 5：损失'
, asset_class_after VARCHAR(1) COMMENT '交易后五级分类状态 1:正常 2：关注 3：次级 4：可疑 5：损失'
, accrued_status_before VARCHAR(32) COMMENT '交易前应计状态 0:应计 1：非应计'
, accrued_status_after VARCHAR(32) COMMENT '交易后应计状态 0:应计 1：非应计'
, total_amt INT NOT NULL COMMENT '总发生金额(单位分)'
, prin_amt INT NOT NULL COMMENT '正常本金发生额(单位分)'
, ovd_prin_amt INT NOT NULL COMMENT '逾期本金发生额(单位分)'
, int_amt INT NOT NULL COMMENT '正常利息发生额(单位分)'
, ovd_int_amt INT NOT NULL COMMENT '逾期利息发生额(单位分)'
, ovd_prin_pena_amt INT NOT NULL COMMENT '逾期本金罚息发生额(单位分)'
, ovd_int_pena_amt INT NOT NULL COMMENT '逾期利息罚息发生额(单位分)'
, prin_bal INT NOT NULL COMMENT '正常本金余额(单位分)'
, ovd_prin_bal INT NOT NULL COMMENT '逾期本金余额(单位分)'
, int_bal INT NOT NULL COMMENT '正常利息余额(单位分)'
, ovd_int_bal INT NOT NULL COMMENT '逾期利息余额(单位分)'
, ovd_prin_pena_bal INT NOT NULL COMMENT '逾期本金罚息余额(单位分)'
, ovd_int_pena_bal INT NOT NULL COMMENT '逾期利息罚息余额(单位分)'
, available VARCHAR(10) NOT NULL COMMENT 'Y:可用 N：不可用 一阶段提交时不可用 二阶段提交后改为可用'
, gmt_create TIMESTAMP NOT NULL COMMENT '创建时间'
, gmt_modified TIMESTAMP NOT NULL COMMENT '修改时间'
, PRIMARY KEY(tnt_inst_id, id)
)  COMMENT = '贷款核心合约还款流水表', DEFAULT CHARSET = 'utf8';
create index idx_arg_repay_seqno on loc_arg_repay_instruction_000 (tnt_inst_id,seq_no);
create index idx_arg_repay_otno on loc_arg_repay_instruction_000 (tnt_inst_id,out_biz_no);
create unique index uk_arg_repay_req_evcd on loc_arg_repay_instruction_000 (tnt_inst_id,request_id,event_code);

CREATE TABLE loc_istmnt_info_000 (
tnt_inst_id VARCHAR(8) NOT NULL COMMENT '租户号'
, ip_id VARCHAR(32) NOT NULL COMMENT '参与者号'
, ip_role_id VARCHAR(32) NOT NULL COMMENT '参与者角色ID'
, argmnt_no VARCHAR(64) NOT NULL COMMENT '合约号'
, account_no VARCHAR(64) NOT NULL COMMENT '分户帐号'
, currency_code VARCHAR(8) COMMENT '币种'
, org_code VARCHAR(32) COMMENT '机构号'
, settled_int INT NOT NULL DEFAULT 0 COMMENT '已结利息，该字段目前＝未还＋已还＋减免'
, term_no INT NOT NULL COMMENT '期次号'
, term_start_date VARCHAR(8) NOT NULL COMMENT '本期开始日'
, term_end_date VARCHAR(8) NOT NULL COMMENT '本期到期日'
, prin_bal INT NOT NULL COMMENT '当期本金余额,单位分'
, int_bal INT NOT NULL COMMENT '当期利息余额,单位分'
, ovd_prin_pena_bal INT NOT NULL COMMENT '当期本罚余额,单位分'
, ovd_int_pena_bal INT NOT NULL COMMENT '当期利罚余额,单位分'
, paid_prin INT NOT NULL COMMENT '已还当期本金,单位分'
, paid_future_prin INT NOT NULL COMMENT '已还未来期本金,单位分'
, paid_int INT NOT NULL COMMENT '已还当期利息,单位分'
, paid_ovd_prin_pena INT NOT NULL COMMENT '已还当期本罚,单位分'
, paid_ovd_int_pena INT NOT NULL COMMENT '已还当期利罚,单位分'
, status VARCHAR(32) NOT NULL COMMENT '状态 正常NORMAL、逾期OVD、结清CLEAR'
, clear_date VARCHAR(8) COMMENT '本期结清日期'
, prin_ovd_days INT NOT NULL COMMENT '本金逾期天数'
, int_ovd_days INT NOT NULL COMMENT '利息逾期天数'
, grace_ovd_prin_pena_bal INT COMMENT '宽限内新增本罚'
, grace_ovd_int_pena_bal INT COMMENT '宽限内新增利罚'
, grace_prin_ovd_days INT COMMENT '宽限内新增本金逾期天数'
, grace_int_ovd_days INT COMMENT '宽限内利息逾期天数'
, gmt_create TIMESTAMP NOT NULL COMMENT '创建时间'
, gmt_modified TIMESTAMP NOT NULL COMMENT '修改时间'
, PRIMARY KEY(tnt_inst_id, argmnt_no, term_no)
)  COMMENT = '贷款核心分期信息表', DEFAULT CHARSET = 'utf8';
