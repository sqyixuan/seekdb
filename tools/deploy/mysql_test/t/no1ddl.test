CREATE TABLE loc_istmnt_info_pre_000 (
id VARCHAR(64) NOT NULL COMMENT 'id'
, seq_no VARCHAR(64) NOT NULL COMMENT '登记当前预处理的流水号'
, tnt_inst_id VARCHAR(8) NOT NULL COMMENT '租户号'
, ip_id VARCHAR(32) NOT NULL COMMENT '参与者号'
, ip_role_id VARCHAR(32) NOT NULL COMMENT '参与者角色ID'
, argmnt_no VARCHAR(64) NOT NULL COMMENT '合约号'
, account_no VARCHAR(64) NOT NULL COMMENT '分户帐号'
, org_code VARCHAR(32) COMMENT '机构号'
, term_no INT NOT NULL COMMENT '期次号'
, term_start_date VARCHAR(8) NOT NULL COMMENT '本期开始日'
, term_end_date VARCHAR(8) NOT NULL COMMENT '本期到期日'
, prin_bal INT NOT NULL COMMENT '当期本金余额,单位分'
, int_bal INT NOT NULL COMMENT '当期利息余额,单位分'
, ovd_prin_pena_bal INT NOT NULL COMMENT '当期本罚余额,单位分'
, ovd_int_pena_bal INT NOT NULL COMMENT '当期利罚余额,单位分'
, paid_prin INT NOT NULL COMMENT '已还当期本金,单位分'
, paid_future_prin INT NOT NULL COMMENT '已还未来期本金,单位分'
, paid_int INT NOT NULL COMMENT '已还当期利息,单位分'
, paid_ovd_prin_pena INT NOT NULL COMMENT '已还当期本罚,单位分'
, paid_ovd_int_pena INT NOT NULL COMMENT '已还当期利罚,单位分'
, status VARCHAR(32) NOT NULL COMMENT '状态 NORMAL正常 OVD 逾期  CLEAR结清'
, clear_date VARCHAR(8) COMMENT '本期结清日期'
, prin_ovd_days INT NOT NULL COMMENT '本金逾期天数'
, int_ovd_days INT NOT NULL COMMENT '利息逾期天数'
, currency_code VARCHAR(8) COMMENT '币种'
, grace_ovd_prin_pena_bal INT COMMENT '宽限期内逾期本金罚息'
, grace_ovd_int_pena_bal INT COMMENT '宽限期内逾期利息罚息'
, grace_prin_ovd_days INT COMMENT '宽限期内本金逾期天数'
, grace_int_ovd_days INT COMMENT '宽限期内利息逾期天数'
, settled_int INT NOT NULL DEFAULT 0 COMMENT '已结利息，该字段目前＝未还＋已还＋减免'
, gmt_create TIMESTAMP NOT NULL COMMENT '创建时间'
, gmt_modified TIMESTAMP NOT NULL COMMENT '修改时间'
, action VARCHAR(1) NOT NULL COMMENT '提交操作（I：插入，U：更新，D：删除）'
, PRIMARY KEY(tnt_inst_id, id)
)  COMMENT = '贷款核心分期预处理表', DEFAULT CHARSET = 'utf8';
