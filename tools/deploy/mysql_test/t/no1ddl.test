, int_ovd_days INT COMMENT '利息逾期天数'
, asset_class VARCHAR(1) COMMENT '五级分类 1:正常 2：关注 3：次级 4：可疑 5：损失'
, asset_class_adj_flag VARCHAR(32) COMMENT '五级分类人工调整标记 0:系统 1：人工'
, accrued_status VARCHAR(32) COMMENT '应计状态 0:应计 1：非应计'
, accrued_status_adj_flag VARCHAR(32) COMMENT '应计状态人工调整标记 0:系统 1：人工'
, force_deduct_flag VARCHAR(32) COMMENT '强制扣款标记  0:非强制 1：强制'
, available VARCHAR(32) COMMENT '记录可用标记 Y:可用  N 不可用'
, encash_amt INT COMMENT '初始放款金额'
, grace_prin_ovd_days INT COMMENT '宽限期内新增本金逾期天数'
, grace_int_ovd_days INT COMMENT '宽限期内新增利息逾期天数'
, bak_opt_type VARCHAR(8) NOT NULL COMMENT '备份类型:ADD 新增  UPDATE 修改'
, event_code VARCHAR(8) NOT NULL COMMENT '本系统事件码'
, upper_event_code VARCHAR(8) COMMENT '上层系统事件码'
, gmt_create TIMESTAMP NOT NULL COMMENT '创建时间'
, gmt_modified TIMESTAMP NOT NULL COMMENT '修改时间'
, PRIMARY KEY(tnt_inst_id, id)
)  COMMENT = '合约控制备份表', DEFAULT CHARSET = 'utf8';
create index idx_loc_arg_ctrl_bak_tnt_seq on loc_arg_ctrl_info_bak_000 (tnt_inst_id, seq_no, id);
create index idx_loc_arg_ctrl_bak_tnt_otno on loc_arg_ctrl_info_bak_000 (tnt_inst_id, out_biz_no, id);

CREATE TABLE loc_branch_tx_000 (
status VARCHAR(1) NOT NULL COMMENT '状态(P-处理中,S-已完成)'
, action_id VARCHAR(128) NOT NULL COMMENT '业务活动id'
, system_tx_id VARCHAR(128) NOT NULL COMMENT '主事务号'
, event_code VARCHAR(8) NOT NULL COMMENT '本系统的事件编码'
, instruction_id VARCHAR(64) COMMENT '流水id'
, ip_id VARCHAR(32) NOT NULL COMMENT '客户号(分库用)'
, tnt_inst_id VARCHAR(8) NOT NULL COMMENT '租户号'
, gmt_create TIMESTAMP NOT NULL COMMENT '创建时间'
, gmt_modified TIMESTAMP NOT NULL COMMENT '修改时间'
, request_id VARCHAR(64) NOT NULL COMMENT '业务幂等单号'
, PRIMARY KEY(tnt_inst_id, system_tx_id, action_id)
)  COMMENT = '贷款核心分布式事务原子业务活动表', DEFAULT CHARSET = 'utf8';
create unique index uk_request_id on loc_branch_tx_000 (tnt_inst_id, request_id);

--source mysql_test/include/check_all_idx_ok.inc

