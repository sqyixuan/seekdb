, status VARCHAR(1) NOT NULL COMMENT '任务状态，I标识未完成，C标识已完成'
, total_count INT NOT NULL DEFAULT 0 COMMENT '任务数据总量'
, start_time TIMESTAMP NOT NULL COMMENT '任务开始时间'
, end_time TIMESTAMP COMMENT '任务结束时间'
, gmt_create TIMESTAMP NOT NULL COMMENT '创建时间'
, gmt_modified TIMESTAMP NOT NULL COMMENT '修改时间'
, PRIMARY KEY(tnt_inst_id, task_date, task_name)
)  COMMENT = '贷款核心主任务表', DEFAULT CHARSET = 'utf8';

CREATE TABLE loc_sub_daily_task (
db INT NOT NULL COMMENT '分库编号'
