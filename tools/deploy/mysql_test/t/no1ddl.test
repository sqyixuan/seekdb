CREATE TABLE af_bns_product_control (
gmt_create TIMESTAMP NOT NULL COMMENT '创建时间'
, gmt_modified TIMESTAMP NOT NULL COMMENT '修改时间'
, pd_code VARCHAR(20) NOT NULL COMMENT '产品码'
, tnt_inst_id VARCHAR(8) NOT NULL COMMENT '租户ID'
, service_name VARCHAR(32) NOT NULL COMMENT '服务名'
, business_source_stm VARCHAR(32) NOT NULL COMMENT '来源系统'
, asset_tool_name VARCHAR(32) NOT NULL COMMENT '支付工具名称'
, control_env VARCHAR(32) NOT NULL COMMENT '环境:线上or预发'
, status VARCHAR(32) NOT NULL COMMENT '生效状态: 生效、失效'
, creator VARCHAR(64) NOT NULL COMMENT '创建者'
, operator VARCHAR(64) NOT NULL COMMENT '操作者'
, memo VARCHAR(256) COMMENT '备注'
, asset_belong VARCHAR(32) NOT NULL COMMENT '资产归属'
, PRIMARY KEY(tnt_inst_id, pd_code, service_name, business_source_stm, control_env, asset_tool_name)
) COMMENT = '业务管控表', DEFAULT CHARSET = 'utf8';

CREATE TABLE af_common_stm_parm_cfg (
gmt_create TIMESTAMP NOT NULL COMMENT '创建时间'
, gmt_modified TIMESTAMP NOT NULL COMMENT '修改时间'
, tnt_inst_id VARCHAR(8) NOT NULL COMMENT '租户ID'
, stm_key VARCHAR(64) NOT NULL COMMENT '系统参数键'
, stm_value VARCHAR(1024) NOT NULL COMMENT '系统参数值'
, memo VARCHAR(256) COMMENT '描述'
, creator VARCHAR(64) NOT NULL COMMENT '创建者'
, operator VARCHAR(64) NOT NULL COMMENT '操作者'
, PRIMARY KEY(tnt_inst_id, stm_key)
) COMMENT = '通用系统参数配置表', DEFAULT CHARSET = 'utf8';

CREATE TABLE af_local_schedule_task_cfg (
gmt_create TIMESTAMP NOT NULL COMMENT '创建时间'
, gmt_modified TIMESTAMP NOT NULL COMMENT '修改时间'
, tnt_inst_id VARCHAR(8) NOT NULL COMMENT '租户ID'
, scheduler_name VARCHAR(64) NOT NULL COMMENT '时间任务名称'
, scheduler_group VARCHAR(64) NOT NULL COMMENT '时间任务组名称'
, execute_object VARCHAR(64) NOT NULL COMMENT '执行任务bean'
, trigger_name VARCHAR(64) NOT NULL COMMENT '触发器名称'
, trigger_group VARCHAR(64) NOT NULL COMMENT '触发器组名'
, scheduler_expression VARCHAR(64) NOT NULL COMMENT '时间表达式'
, execute_method VARCHAR(64) NOT NULL COMMENT '执行方法'
, status VARCHAR(16) NOT NULL COMMENT '状态'
, operator VARCHAR(32) NOT NULL COMMENT '操作人'
, creator VARCHAR(32) NOT NULL COMMENT '创建人'
, PRIMARY KEY(tnt_inst_id, scheduler_name, scheduler_group)
) COMMENT = '本地时间任务配置表', DEFAULT CHARSET = 'utf8';

CREATE TABLE af_money_strategy_cfg (
gmt_create TIMESTAMP NOT NULL COMMENT '创建时间'
, gmt_modified TIMESTAMP NOT NULL COMMENT '修改时间'
, money_strategy_name VARCHAR(32) NOT NULL COMMENT '资金策略名称'
, asset_tool_name VARCHAR(32) NOT NULL COMMENT '资产工具名称'
, asset_tool_priority VARCHAR(32) NOT NULL COMMENT '资金工具优先级'
, status VARCHAR(16) NOT NULL COMMENT '生效状态'
, memo VARCHAR(256) COMMENT '备注'
, control_env VARCHAR(16) NOT NULL COMMENT '环境标识'
, creator VARCHAR(64) NOT NULL COMMENT '创建者'
, operator VARCHAR(64) NOT NULL COMMENT '操作者'
, tnt_inst_id VARCHAR(8) NOT NULL COMMENT '租户ID'
, PRIMARY KEY(tnt_inst_id, money_strategy_name, asset_tool_name)
) COMMENT = '资金策略配置', DEFAULT CHARSET = 'utf8';

CREATE TABLE af_refund_mode_strategy_cfg (
gmt_create TIMESTAMP NOT NULL COMMENT '创建时间'
, gmt_modified TIMESTAMP NOT NULL COMMENT '修改时间'
, refund_mode_strategy_name VARCHAR(32) NOT NULL COMMENT '资金策略名称'
, asset_tool_name VARCHAR(32) NOT NULL COMMENT '资产工具名称'
, target_asset_tool_name VARCHAR(32) NOT NULL COMMENT '目标支付工具名称'
, status VARCHAR(16) NOT NULL COMMENT '生效状态'
, memo VARCHAR(256) COMMENT '备注'
, control_env VARCHAR(16) NOT NULL COMMENT '环境标识'
, creator VARCHAR(64) NOT NULL COMMENT '创建者'
, operator VARCHAR(64) NOT NULL COMMENT '操作者'
, tnt_inst_id VARCHAR(8) NOT NULL COMMENT '租户ID'
, PRIMARY KEY(tnt_inst_id, refund_mode_strategy_name, asset_tool_name)
) COMMENT = '退款资金策略配置', DEFAULT CHARSET = 'utf8';

CREATE TABLE af_retry_task_cfg (
gmt_create TIMESTAMP NOT NULL COMMENT '创建时间'
, gmt_modified TIMESTAMP NOT NULL COMMENT '修改时间'
, pd_code VARCHAR(20) NOT NULL COMMENT '产品码'
, tnt_inst_id VARCHAR(8) NOT NULL COMMENT '租户ID'
, service_type VARCHAR(32) NOT NULL COMMENT '服务类型'
, business_source_stm VARCHAR(32) NOT NULL COMMENT '业务来源系统'
, retry VARCHAR(32) NOT NULL COMMENT '调用失败之后,是否进行重试(是/否)'
, control_env VARCHAR(16) NOT NULL COMMENT '环境:线上or预发'
, status VARCHAR(16) NOT NULL COMMENT '生效状态:生效、失效'
, creator VARCHAR(64) NOT NULL COMMENT '创建者'
, operator VARCHAR(64) NOT NULL COMMENT '操作者'
, memo VARCHAR(256) COMMENT '备注'
, retry_interval VARCHAR(64) NOT NULL COMMENT '重试间隔'
, PRIMARY KEY(tnt_inst_id, pd_code, business_source_stm, service_type)
) COMMENT = '重试任务配置表', DEFAULT CHARSET = 'utf8';

CREATE TABLE af_schedule_task_split_cfg (
gmt_create TIMESTAMP NOT NULL COMMENT '创建时间'
, gmt_modified TIMESTAMP NOT NULL COMMENT '修改时间'
, task_name VARCHAR(64) NOT NULL COMMENT '任务名称'
, tnt_inst_id VARCHAR(8) NOT NULL COMMENT '租户ID'
, begin_time INT NOT NULL COMMENT '开始时间'
, end_time INT NOT NULL COMMENT '结束时间'
, begin_time_attr VARCHAR(16) NOT NULL COMMENT '开始时间单位'
, end_time_attr VARCHAR(16) NOT NULL COMMENT '结束时间单位'
, split_name VARCHAR(32) COMMENT '分片名称'
, maximum_execute_number INT NOT NULL COMMENT '单次最大载入个数'
, memo VARCHAR(256) COMMENT '备注'
, creator VARCHAR(64) COMMENT '创建者'
, operator VARCHAR(64) NOT NULL COMMENT '操作者'
, status VARCHAR(16) NOT NULL COMMENT '状态'
, control_env VARCHAR(16) NOT NULL COMMENT '环境标识'
, PRIMARY KEY(tnt_inst_id, task_name)
) COMMENT = '定时任务时间分片任务表', DEFAULT CHARSET = 'utf8';

CREATE TABLE af_strategy_mapping (
gmt_create TIMESTAMP NOT NULL COMMENT '创建时间'
, gmt_modified TIMESTAMP NOT NULL COMMENT '修改时间'
, strategy_name VARCHAR(32) NOT NULL COMMENT '策略名称'
, pd_code VARCHAR(20) NOT NULL COMMENT '上次业务流水号'
, service_type VARCHAR(32) NOT NULL COMMENT '服务类型'
, asset_belong VARCHAR(32) NOT NULL COMMENT '资金归属'
, money_strategy_name VARCHAR(32) NOT NULL COMMENT '资金策略名称'
, refund_mode_strategy_name VARCHAR(32) COMMENT '退款资金策略名称'
, status VARCHAR(16) NOT NULL COMMENT '是否生效'
, control_env VARCHAR(16) NOT NULL COMMENT '环境标识'
, creator VARCHAR(64) NOT NULL COMMENT '创建者'
, operator VARCHAR(64) NOT NULL COMMENT '操作者'
, memo VARCHAR(256) COMMENT '备注'
, tnt_inst_id VARCHAR(8) NOT NULL COMMENT '租户ID'
, PRIMARY KEY(tnt_inst_id, strategy_name, pd_code, service_type, asset_belong, money_strategy_name)
) COMMENT = '策略映射表', DEFAULT CHARSET = 'utf8';

CREATE TABLE af_freeze_retry_task_000 (
gmt_create TIMESTAMP NOT NULL COMMENT '创建时间'
, gmt_modified TIMESTAMP NOT NULL COMMENT '修改时间'
, order_id VARCHAR(64) NOT NULL COMMENT '单据ID'
, tnt_inst_id VARCHAR(8) NOT NULL COMMENT '租户ID'
, retry_count INT NOT NULL COMMENT '重试次数'
, status VARCHAR(16) NOT NULL COMMENT '状态: 初始、待重试、完成'
, retry_interval VARCHAR(64) COMMENT '重试间隔'
, gmt_schedule TIMESTAMP COMMENT '下次重试时间'
, PRIMARY KEY(tnt_inst_id, order_id)
) COMMENT = '冻结重试任务表(分库分表)', DEFAULT CHARSET = 'utf8';

CREATE TABLE af_lock_unique_000 (
gmt_create TIMESTAMP NOT NULL COMMENT '创建时间'
, tnt_inst_id VARCHAR(8) NOT NULL COMMENT '租户ID'
, lock_id VARCHAR(64) NOT NULL COMMENT '锁定单号'
, order_id VARCHAR(64) NOT NULL COMMENT '当前单号'
, order_type VARCHAR(32) NOT NULL COMMENT '当前单号类型'
, gmt_modified TIMESTAMP NOT NULL COMMENT '修改时间'
, PRIMARY KEY(tnt_inst_id, lock_id)
) COMMENT = '单据上锁表(分库分表)', DEFAULT CHARSET = 'utf8';

CREATE TABLE af_pay_detail_summary_000 (
gmt_create TIMESTAMP NOT NULL COMMENT '创建时间'
, gmt_modified TIMESTAMP NOT NULL COMMENT '修改时间'
, order_id VARCHAR(64) NOT NULL COMMENT '订单号'
, tnt_inst_id VARCHAR(8) NOT NULL COMMENT '租户ID'
, amount INT NOT NULL COMMENT '金额'
, currency VARCHAR(8) NOT NULL COMMENT '币种'
, debit_detail_id VARCHAR(64) NOT NULL COMMENT '借记详情ID'
, debit_asset_tool_name VARCHAR(32) NOT NULL COMMENT '借记工具服务名'
, credit_detail_id VARCHAR(64) NOT NULL COMMENT '贷记详情ID'
, credit_asset_tool_name VARCHAR(32) NOT NULL COMMENT '贷记工具服务名'
, PRIMARY KEY(tnt_inst_id, order_id, debit_detail_id, credit_detail_id)
)COMMENT = '支付详情关联表(分库分表)', DEFAULT CHARSET = 'utf8';

CREATE TABLE af_pay_fund_detail_000 (
gmt_create TIMESTAMP NOT NULL COMMENT '创建时间'
, gmt_modified TIMESTAMP NOT NULL COMMENT '修改时间'
, fund_detail_id VARCHAR(64) NOT NULL COMMENT '详情单ID'
, tnt_inst_id VARCHAR(8) NOT NULL COMMENT '租户ID'
, order_id VARCHAR(64) NOT NULL COMMENT '主单据号'
, account_no VARCHAR(32) COMMENT '交易内标'
, asset_tool_name VARCHAR(32) NOT NULL COMMENT '资产工具名称'
, amount INT NOT NULL COMMENT '资金'
, currency VARCHAR(8) NOT NULL COMMENT '币种'
, action VARCHAR(32) NOT NULL COMMENT '指令操作类型'
, freeze_inf VARCHAR(1024) COMMENT '冻结信息'
, fund_detail_ext VARCHAR(2048) COMMENT '详情单扩展信息'
, priority VARCHAR(16) COMMENT '指令优先级'
, memo VARCHAR(256) COMMENT '备注'
, status VARCHAR(16) NOT NULL COMMENT '详情单状态'
, asset_belong VARCHAR(32) NOT NULL COMMENT '资金归属方'
, parent_detail_id VARCHAR(64) COMMENT '父详情单ID'
, result_ext VARCHAR(1024) COMMENT '返回结果扩展信息'
, reverse_cntxt VARCHAR(1024) COMMENT '冲正扩展信息'
, receipt_cntxt VARCHAR(1024) COMMENT '金融网关报文'
, exn_inf VARCHAR(2048) COMMENT '透传黑盒大字段'
, asset_tool_id VARCHAR(64) COMMENT '下层核心返回流水号'
, txn_date TIMESTAMP COMMENT '记账日期'
, finance_message VARCHAR(2048) COMMENT '金融网关报文'
, direction VARCHAR(32) COMMENT '业务流向'
, ip_id VARCHAR(32) COMMENT '参与者角色'
, ip_type VARCHAR(32) COMMENT '参与者客户类型'
, inr_inst_id VARCHAR(32) COMMENT '参与者所属机构ID'
, ip_role_id VARCHAR(32) COMMENT '参与者角色ID'
, PRIMARY KEY(tnt_inst_id, fund_detail_id)
) COMMENT = '支付资金明细(分库分表)', DEFAULT CHARSET = 'utf8';

create index idx_tntinstid_orderid on af_pay_fund_detail_000 (tnt_inst_id,order_id);
CREATE TABLE af_pay_retry_task_000 (
gmt_create TIMESTAMP NOT NULL COMMENT '创建时间'
, gmt_modified TIMESTAMP NOT NULL COMMENT '修改时间'
, order_id VARCHAR(64) NOT NULL COMMENT '单据ID'
, tnt_inst_id VARCHAR(8) NOT NULL COMMENT '租户ID'
, retry_count INT NOT NULL COMMENT '重试次数'
, status VARCHAR(16) NOT NULL COMMENT '状态: 初始、待重试、完成'
, retry_interval VARCHAR(64) COMMENT '重试间隔'
, gmt_schedule TIMESTAMP COMMENT '下次重试时间'
, PRIMARY KEY(tnt_inst_id, order_id)
) COMMENT = '支付重试任务表(分库分表)', DEFAULT CHARSET = 'utf8';

CREATE TABLE af_refund_detail_summary_000 (
gmt_create TIMESTAMP NOT NULL COMMENT '创建时间'
, gmt_modified TIMESTAMP NOT NULL COMMENT '修改时间'
, order_id VARCHAR(64) NOT NULL COMMENT '订单号'
, tnt_inst_id VARCHAR(8) NOT NULL COMMENT '租户ID'
, amount INT NOT NULL COMMENT '金额'
, currency VARCHAR(8) NOT NULL COMMENT '币种'
, debit_detail_id VARCHAR(64) NOT NULL COMMENT '借记详情ID'
, debit_asset_tool_name VARCHAR(32) NOT NULL COMMENT '借记工具服务名'
, credit_detail_id VARCHAR(64) NOT NULL COMMENT '贷记详情ID'
, credit_asset_tool_name VARCHAR(32) NOT NULL COMMENT '贷记工具服务名'
, PRIMARY KEY(tnt_inst_id, order_id, debit_detail_id, credit_detail_id)
) COMMENT = '退款详情关联表(分库分表)', DEFAULT CHARSET = 'utf8';

CREATE TABLE af_refund_fund_detail_000 (
gmt_create TIMESTAMP NOT NULL COMMENT '创建时间'
, gmt_modified TIMESTAMP NOT NULL COMMENT '修改时间'
, fund_detail_id VARCHAR(64) NOT NULL COMMENT '详情单ID'
, tnt_inst_id VARCHAR(8) NOT NULL COMMENT '租户ID'
, pay_fund_detail_id VARCHAR(64) NOT NULL COMMENT '支付资金详情'
, order_id VARCHAR(64) NOT NULL COMMENT '主单据号'
, account_no VARCHAR(32) NOT NULL COMMENT '交易内标'
, asset_tool_name VARCHAR(32) NOT NULL COMMENT '资产工具名称'
, amount INT NOT NULL COMMENT '资金'
, currency VARCHAR(8) NOT NULL COMMENT '币种'
, action VARCHAR(32) NOT NULL COMMENT '指令操作类型'
, freeze_inf VARCHAR(1024) COMMENT '冻结信息'
, fund_detail_ext VARCHAR(2048) COMMENT '详情单扩展信息'
, priority VARCHAR(16) COMMENT '指令优先级'
, memo VARCHAR(256) COMMENT '备注'
, status VARCHAR(16) NOT NULL COMMENT '详情单状态'
, asset_belong VARCHAR(32) NOT NULL COMMENT '资金归属方'
, parent_detail_id VARCHAR(64) COMMENT '父详情单ID'
, result_ext VARCHAR(1024) COMMENT '返回结果扩展信息'
, reverse_cntxt VARCHAR(1024) COMMENT '冲正扩展信息'
, receipt_cntxt VARCHAR(1024) COMMENT '金融网关报文'
, exn_inf VARCHAR(2048) COMMENT '透传黑盒大字段'
, asset_tool_id VARCHAR(64) COMMENT '下层核心返回流水号'
, txn_date TIMESTAMP COMMENT '记账日期'
, ip_id VARCHAR(32) COMMENT '参与者ID'
, ip_type VARCHAR(32) COMMENT '参与者客户类型'
, inr_inst_id VARCHAR(32) COMMENT '参与者所属机构ID'
, ip_role_id VARCHAR(32) COMMENT '参与者角色ID'
, PRIMARY KEY(tnt_inst_id, fund_detail_id)
) COMMENT = '退款资金明细(分库分表)', DEFAULT CHARSET = 'utf8';

CREATE TABLE af_bns_unique_000 (
gmt_create TIMESTAMP NOT NULL COMMENT '创建时间'
, pd_seq_no VARCHAR(64) NOT NULL COMMENT '上层业务流水号'
, tnt_inst_id VARCHAR(8) NOT NULL COMMENT '租户ID'
, gmt_modified TIMESTAMP NOT NULL COMMENT '修改时间'
, PRIMARY KEY(tnt_inst_id, pd_seq_no)
) COMMENT = '业务幂等控制(分库分表)', DEFAULT CHARSET = 'utf8';

CREATE TABLE af_freeze_fund_detail_000 (
gmt_create TIMESTAMP NOT NULL COMMENT '创建时间'
, gmt_modified TIMESTAMP NOT NULL COMMENT '修改时间'
, fund_detail_id VARCHAR(64) NOT NULL COMMENT '详情单ID'
, tnt_inst_id VARCHAR(8) NOT NULL COMMENT '租户ID'
, order_id VARCHAR(64) NOT NULL COMMENT '主单据号'
, account_no VARCHAR(32) NOT NULL COMMENT '交易内标'
, asset_tool_name VARCHAR(32) NOT NULL COMMENT '资产工具名称'
, amount INT NOT NULL COMMENT '资金'
, currency VARCHAR(8) NOT NULL COMMENT '币种'
, action VARCHAR(32) NOT NULL COMMENT '指令操作类型'
, fund_detail_ext VARCHAR(2048) COMMENT '详情单扩展信息'
, priority VARCHAR(8) COMMENT '指令优先级'
, memo VARCHAR(256) COMMENT '备注'
, status VARCHAR(16) NOT NULL COMMENT '详情单状态'
, result_ext VARCHAR(1024) COMMENT '返回结果扩展信息'
, reverse_cntxt VARCHAR(1024) COMMENT '冲正扩展信息'
, exn_inf VARCHAR(2048) COMMENT '透传黑盒大字段'
, asset_tool_id VARCHAR(64) COMMENT '下层核心返回流水号'
, txn_date TIMESTAMP COMMENT '记账日期'
