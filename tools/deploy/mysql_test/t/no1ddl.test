CREATE TABLE loc_arg_acct_instruction_000 (
id VARCHAR(64) NOT NULL COMMENT '主键ID'
, tnt_inst_id VARCHAR(8) NOT NULL COMMENT '主键租户号'
, ip_id VARCHAR(32) NOT NULL COMMENT '参与者ID'
, ip_role_id VARCHAR(32) NOT NULL COMMENT '参与者角色ID'
, argmnt_no VARCHAR(64) NOT NULL COMMENT '合约号'
, account_no VARCHAR(64) NOT NULL COMMENT '分户号'
, org_code VARCHAR(32) COMMENT '机构号'
, prod_code VARCHAR(20) NOT NULL COMMENT '产品号'
, currency_code VARCHAR(8) COMMENT '币种'
, settle_date VARCHAR(8) COMMENT '会计时间—发起者生成的时间.没有时分秒的记账日期'
, finish_time TIMESTAMP COMMENT '交易时间-本系统完成此交易的时间.有时分秒的,'
, request_id VARCHAR(64) NOT NULL COMMENT '单次调用的单据号'
, out_biz_no VARCHAR(64) COMMENT '贷款业务平台流水号,用于串连整个业务'
, seq_no VARCHAR(64) COMMENT '业务流水号，本系统发生业务的流水号'
, upper_event_code VARCHAR(8) COMMENT '上层事件码，由贷款业务平台产生'
, event_code VARCHAR(8) NOT NULL COMMENT '本系统事件码'
, memo VARCHAR(765) COMMENT '备注'
, status_before VARCHAR(32) COMMENT '交易前合约状态(放款中LENDING 正常NORMAL,逾期OVD,结清CLEAR,核销WRITEOFF)'
, status_after VARCHAR(32) COMMENT '交易后合约状态(放款中LENDING 正常NORMAL,逾期OVD,结清CLEAR,核销WRITEOFF)'
, asset_class_before VARCHAR(1) COMMENT '交易前五级分类状态 1:正常 2：关注 3：次级 4：可疑 5：损失'
, asset_class_after VARCHAR(1) COMMENT '交易后五级分类状态 1:正常 2：关注 3：次级 4：可疑 5：损失'
, accrued_status_before VARCHAR(32) COMMENT '交易前应计状态 0:应计 1：非应计'
, accrued_status_after VARCHAR(32) COMMENT '交易后应计状态 0:应计 1：非应计'
, total_amt INT NOT NULL COMMENT '总发生金额(单位分)'
, prin_amt INT NOT NULL COMMENT '正常本金发生额(单位分)'
, ovd_prin_amt INT NOT NULL COMMENT '逾期本金发生额(单位分)'
, int_amt INT NOT NULL COMMENT '正常利息发生额(单位分)'
, ovd_int_amt INT NOT NULL COMMENT '逾期利息发生额(单位分)'
, ovd_prin_pena_amt INT NOT NULL COMMENT '逾期本金罚息发生额(单位分)'
, ovd_int_pena_amt INT NOT NULL COMMENT '逾期利息罚息发生额(单位分)'
, prin_bal INT NOT NULL COMMENT '正常本金余额(单位分)'
, ovd_prin_bal INT NOT NULL COMMENT '逾期本金余额(单位分)'
, int_bal INT NOT NULL COMMENT '正常利息余额(单位分)'
, ovd_int_bal INT NOT NULL COMMENT '逾期利息余额(单位分)'
, ovd_prin_pena_bal INT NOT NULL COMMENT '逾期本金罚息余额(单位分)'
, ovd_int_pena_bal INT NOT NULL COMMENT '逾期利息罚息余额(单位分)'
, context VARCHAR(6000) COMMENT '外部请求参数内容'
, available VARCHAR(1) NOT NULL COMMENT 'Y:可用 N:不可用  一阶段提交时不可用 二阶段提交后改为可用'
, gmt_create TIMESTAMP NOT NULL COMMENT '创建时间'
, gmt_modified TIMESTAMP NOT NULL COMMENT '修改时间'
, PRIMARY KEY(tnt_inst_id, id)
)  COMMENT = '贷款核心合约控制信息流水表', DEFAULT CHARSET = 'utf8';
create index idx_loc_arg_acct_tnt_reqid on loc_arg_acct_instruction_000 (tnt_inst_id, request_id, event_code);
create index idx_loc_arg_acct_tnt_seq on loc_arg_acct_instruction_000 (tnt_inst_id, seq_no, id);
create index idx_loc_arg_acct_tnt_otno on loc_arg_acct_instruction_000 (tnt_inst_id, out_biz_no, id);
create index idx_arg_acct_arg_stdt on loc_arg_acct_instruction_000 (tnt_inst_id, argmnt_no, settle_date, event_code, id);

