--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: link.zt
# owner group: SQL4
# description: test for set stmt
# bug : #6600806

--disable_abort_on_error

connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn2,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn1;
# invalid systerm variables
set a=1;
set global a=1;
set b=str;
set c='str';
set a;
set a=;
set =;

# user variables
set @a=1;
select @a;
set @b=str;
set @c='str';
select @c;

set @a;
set @b=1;
select @b;
set @a=@b;
select @a;

# expression

set @a=1;
select @a;
set @b='str';
select @b;
set @c=@a+@b;
select @c;
set @b=2;
set @c=@a+@b;
select @c;
set @c=@a/@b;
select @c;
set @c=@a-@b;
select @c;
set @c=@a*@b;
select @c;
set @c=@c/0;
select @c;

set @a=100;
set @a=@a%100;
select @a;
# keyword
set @status=1;


# systerm variables
--echo conn1
set max_allowed_packet=2048000;
show variables like '%ob_read_consistency%';
set ob_read_consistency=1;
show variables like '%max_allowed_packet%';
show variables like '%ob_read_consistency%';

connection conn2;
--echo conn2
show variables like '%max_allowed_packet%';
show variables like '%ob_read_consistency%';


--echo conn1
connection conn1;
set global max_allowed_packet=2048000;
set global ob_read_consistency=1;
show variables like '%max_allowed_packet%';
show variables like '%ob_read_consistency%';

--echo conn2
connection conn2;
show variables like '%max_allowed_packet%';
show variables like '%ob_read_consistency%';

--echo create conn3
connect (conn3,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn3;
show variables like '%max_allowed_packet%';
show variables like '%ob_read_consistency%';


## add bugfix:
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(c1 varchar(20) primary key, c2 int);
replace into t1 values('s1',1);
set @a='s1';
update t1 set c2=0 where c1=@a;
drop table t1;

--echo for autocommit
set autocommit=on;
show variables like 'autocommit';
set autocommit=off;
show variables like 'autocommit';
set @@autocommit=on;
show variables like 'autocommit';
set @@autocommit=off;
show variables like 'autocommit';
set "autocommit"=on;
show variables like 'autocommit';
set "autocommit"=off;
show variables like 'autocommit';
set session autocommit=on;
show variables like 'autocommit';
set session autocommit=off;
show variables like 'autocommit';
set @@session.autocommit=off;
show variables like 'autocommit';
set @@session.autocommit=on;
show variables like 'autocommit';
set global autocommit=on;
show global variables like 'autocommit';
set global autocommit=off;
show global variables like 'autocommit';
set @@global.autocommit=on;
show global variables like 'autocommit';
set @@global.autocommit=off;
show global variables like 'autocommit';

##func
set @f=false;
set @e=upper('hello');
select @e;
select @f;
set @first_var= cast(NULL as CHAR);
select @first_var;
set @xml= '<entry><id>pt10</id><pt>10</pt></entry><entry><id>pt50</id><pt>50</pt></entry>';
select @xml;

set @str1 = 'select ?';
select @str1;
set @param1='%%';
select @param1;
set global max_allowed_packet=16777216;
set global ob_read_consistency='STRONG';
set global autocommit=on;

set version_com='fdsadg';
set session version_com='fdsadg';
set global version_com='fdsadg';
set version_comment='fdsadg';
set session version_comment='fdsadg';
set global version_comment='fdsadg';


--echo conn4
--error 4170
set @@ob_log_level='disable';
set @@ob_log_level='disabled';
--error 4170
set @@global.ob_log_level='disable';
set @@global.ob_log_level='disabled';
show variables like '%ob_log_level%';

