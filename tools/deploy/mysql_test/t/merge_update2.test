--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: dachuan.sdc
# owner group: SQL3
# description: 插入，合并，更新，验证 

--disable_warnings
drop table if exists sbtest;
--enable_warnings
#alter system set min_drop_cache_wait_time='10s' server_type=chunkserver;
--real_sleep 1

CREATE TABLE sbtest (id INTEGER  NOT NULL, name varchar(1024), whenn datetime(6),  k integer  DEFAULT '0' NOT NULL,pad char(60) DEFAULT '' NOT NULL, whenn1 datetime(6), stat1 bool, PRIMARY KEY  (id,name,whenn) ) ;

--echo insert 100 rows to ups
--let $count=1
while($count < 101)
{ 
    --let $stmt=INSERT INTO sbtest(id, name, whenn, k, pad, whenn1) VALUES($count,'junyue','2013-1-6 14:44:00', 1,'qqqqqqqqqqwwwwwwwwwweeeeeeeeeerrrrrrrrrrtttttttttt', '2013-1-7 14:44:00')
    eval $stmt;
    inc $count; 
}

