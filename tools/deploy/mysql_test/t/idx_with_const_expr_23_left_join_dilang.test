## Create index i1 for t1
create index i2 on t1(a2);
#create index i3 on t1(a3);
#create index i4 on t1(a4);
create index i5 on t1(a5);

## Create index j4 for t2
#create index j4 on t2(a4);

--source mysql_test/include/check_all_idx_ok.inc

## Test left join 

--replace_column 5 timestamp
--sorted_result
select * from t1 left join t2 on t1.a3=t2.a4 order by t1.a1,t1.a2,t1.a3,t2.a2,t2.a3,t2.a4; 
--replace_column 5 timestamp
--sorted_result
select * from t1 left join t2 on t1.a3=t2.a4 where t1.a2>=0 and t1.a2<=6 order by t1.a1,t1.a2,t1.a3,t2.a2,t2.a3,t2.a4; 
--replace_column 5 timestamp
--sorted_result
select * from t1 left join t2 on t1.a3=t2.a4 where t1.a2>=1-(9-8)+(3*5)-45/3 and t1.a2<=100%55-35 order by t1.a1,t1.a2,t1.a3,t2.a2,t2.a3,t2.a4; 

--replace_column 5 timestamp
--replace_regex /Plan signature: [0-9]*/Plan signature/
--disable_result_log
explain select * from t1 left join t2 on t1.a3=t2.a4; 
--enable_result_log
--replace_column 5 timestamp
--replace_regex /Plan signature: [0-9]*/Plan signature/
--disable_result_log
explain select * from t1 left join t2 on t1.a3=t2.a4 where t1.a2>=0 and t1.a2<=6; 
--enable_result_log
--replace_column 5 timestamp
--replace_regex /Plan signature: [0-9]*/Plan signature/
--disable_result_log
explain select * from t1 left join t2 on t1.a3=t2.a4 where t1.a2>=1-(9-8)+(3*5)-45/3 and t1.a2<=100%55-35; 
--enable_result_log

