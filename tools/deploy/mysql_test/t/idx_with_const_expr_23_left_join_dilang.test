##
## Table cleaning
##
#
--disable_warnings
drop table if exists t1,t2;
--enable_warnings

--source mysql_test/include/index_quick_major.inc
#
##
## Test left join with const expression
##
#
## Create database schema
create table t1(
  a1 char(3) primary key,
  a2 int,
  a3 char(3),
  a4 float,
  a5 datetime
);
create table t2(
  a1 char(3) primary key,
  a2 char(17),
  a3 char(2),
  a4 char(3)
);
#
## Populate table t1
insert into t1 values('AME',0,'SEA',0.100,date'1942-02-19');
