--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner:dachuan.sdc
# owner group: SQL3
# tags: px


--disable_query_log
--result_format 4
--enable_sorted_result


--disable_warnings
drop database if exists virtual_worker_stat;
--enable_warnings
create database virtual_worker_stat;
use virtual_worker_stat;

create table t1(v int primary key) partition by hash(v) partitions 50;
insert into t1 values (11), (10), (12), (13), (14);

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
let $svr_ip_1 = query_get_value(select svr_ip from oceanbase.__all_server order by id, svr_ip, 1);
let $svr_port_1 = query_get_value(select inner_port from oceanbase.__all_server order by id, inner_port, 1);


###当并行度为4和12时执行px query时，通过虚拟表查看px_worker信息
###需要两个连接来完成。

connection default;
set ob_query_timeout = 100000000;
use virtual_worker_stat;
--send select /*+ use_px parallel(4) */sleep(v) from t1;
sleep 2;
connection obsys;
--enable_query_log
select qc_id, worker_id, dfo_id from oceanbase.__all_virtual_px_worker_stat;
connection default;
--disable_query_log
--reap

#--------------分割线
--send select /*+ use_px parallel(3) */sleep(v) from t1;
sleep 2;
connection obsys;
--enable_query_log
select qc_id, worker_id, dfo_id from oceanbase.__all_virtual_px_worker_stat;
connection default;
--disable_query_log
--reap

connection default;
