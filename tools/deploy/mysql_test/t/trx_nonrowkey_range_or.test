--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: yuchen.wyc
# owner group: sql4
# description: non_rowkey range or  update
--disable_warnings
drop table if exists t1;
--enable_warnings

connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (trx1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (trx2,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);

connection conn1;
create table t1(pk1 int, pk2 int, c1 int, c2 int, primary key(pk1,pk2));
insert into t1(pk1,pk2,c1,c2) values(1,1,1,1);
insert into t1(pk1,pk2,c1,c2) values(2,2,2,1);
insert into t1(pk1,pk2,c1,c2) values(3,3,3,1);
insert into t1(pk1,pk2,c1,c2) values(4,4,4,1);
insert into t1(pk1,pk2,c1,c2) values(5,5,5,1);
insert into t1(pk1,pk2,c1,c2) values(6,6,6,1);
insert into t1(pk1,pk2,c1,c2) values(7,7,7,1);
insert into t1(pk1,pk2,c1,c2) values(8,8,8,1);
select * from t1;

####CASE: write with same rows using single col condition, 5048
connection trx1;
set autocommit=0;
delete from t1 where pk1=1 or pk1=2;
select * from t1;
update t1 set c2=c2+1 where pk1=1 or pk1=2 or pk1=3 or pk1=4;
select * from t1;

connection trx2;
set autocommit=0;
select * from t1;
--error 1205,4012
update t1 set c2=c2+1 where pk2=1 or pk2=2 or pk2=3 or pk2=4;
select * from t1;
--error 1205,4012
delete from t1 where pk2=1 or pk2=2 or pk2=3 or pk2=4;
delete from t1 where pk1=5 or pk1=6;
select * from t1;
update t1 set c2=c2+1 where pk2=5 or pk2=6 or pk2=7 or pk2=8;
select * from t1;
commit;
select * from t1;
commit;

connection trx1;
select * from t1;
update t1 set c2=c2+1 where pk2=5 or pk2=6 or pk2=7 or pk2=8;
select * from t1;
commit;
select * from t1;
commit;

####CASE: write with same rows using cols condition, 5048
connection conn1;
replace into t1(pk1,pk2,c1,c2) values (1,1,1,1),(2,2,2,1),(3,3,3,1),(4,4,4,1),(5,5,5,1),(6,6,6,1),(7,7,7,1),(8,8,8,1);
select * from t1;

connection trx1;
delete from t1 where (pk1,c1)=(1,1) or (pk1,c1)=(2,2);
select * from t1;
update t1 set c2=c2+1 where (pk1,c1)=(1,1) or (pk1,c1)=(2,2) or (pk1,c1)=(3,3) or (pk1,c1)=(4,4);
select * from t1;

connection trx2;
--error 1205,4012
delete from t1 where (pk1,c1)=(1,1) or (pk1,c1)=(2,2) or (pk1,c1)=(5,5) or (pk1,c1)=(6,6);
select * from t1;
--error 1205,4012
delete from t1 where (pk2,c1)=(1,1) or (pk2,c1)=(2,2) or (pk2,c1)=(5,5) or (pk2,c1)=(6,6);
select * from t1;
--error 1205,4012
delete from t1 where (pk1,c1)=(3,3) or (pk1,c1)=(4,4) or (pk1,c1)=(5,5) or (pk1,c1)=(6,6);
select * from t1;
--error 1205,4012
update t1 set c2=c2+1 where (pk1,c1)=(1,1) or (pk1,c1)=(2,2) or (pk1,c1)=(5,5) or (pk1,c1)=(6,6);
select * from t1;
update t1 set c2=c2+1 where (pk1,c1)=(5,5) or (pk1,c1)=(6,6) or (pk1,c1)=(7,7) or (pk1,c1)=(8,8);
select * from t1;
delete from t1 where (pk1,c1)=(5,5) or (pk1,c1)=(6,6);
select * from t1;

connection trx1;
select * from t1;
--error 1205,4012
delete from t1 where (pk1,c1)=(5,5) or (pk1,c1)=(6,6);
select * from t1;
--error 1205,4012
delete from t1 where (pk2,c1)=(7,7) or (pk2,c1)=(8,8);
select * from t1;
--error 1205,4012
update t1 set c2=c2+1 where (pk1,c1)=(1,1) or (pk1,c1)=(2,2) or (pk1,c1)=(5,5) or (pk1,c1)=(6,6);
select * from t1;
commit;
select * from t1;
commit;

connection trx2;
select * from t1;
commit;
select * from t1;
commit;

####CASE: write with same rows using and+or condition, 5048
connection conn1;
replace into t1(pk1,pk2,c1,c2) values (1,1,1,1),(2,2,2,1),(3,3,3,1),(4,4,4,1),(5,5,5,1),(6,6,6,1),(7,7,7,1),(8,8,8,1);
select * from t1;

connection trx1;
update t1 set c2=c2+1 where ( (pk1,c1) in ((1,1),(2,2),(3,3),(4,4)) and  pk2 in (1,2) ) or (pk1,c1)=(5,5) or (pk1,c1)=(6,6);
select * from t1;
delete from t1 where ( (pk1,c1) in ((1,1),(2,2),(3,3),(4,4)) and  pk2 in (3,4) ) or (pk1,c1)=(7,7) or (pk1,c1)=(8,8);
select * from t1;

connection trx2;
--error 1205,4012
update t1 set c1=c1+1, c2=c2+1 where pk2=1 or pk2=2 or pk2=3 or pk2=4 or pk2=5 or pk2=6;
select * from t1;
--error 1205,4012
delete from t1 where pk2=1 or pk2=2 or pk2=3 or pk2=4 or pk2=5 or pk2=6;
select * from t1;

connection trx1;
select * from t1;
commit;
delete from t1 where ( (pk1,c1) in ((1,1),(2,2),(3,3),(4,4)) and  pk2 in (3,4) ) or (pk1,c1)=(7,7) or (pk1,c1)=(8,8);
select * from t1;

connection trx2;
select * from t1;
delete from t1 where ( (pk1,c1) in ((1,1),(2,2),(3,3),(4,4)) and  pk2 in (3,4) ) or (pk1,c1)=(7,7) or (pk1,c1)=(8,8);
select * from t1;
commit;

connection trx1;
select * from t1;
commit;
select * from t1;
commit;
