# description: test for __all_virtual_replay_stat
#
connect (conn1,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn1;
select tenant_id, table_name from oceanbase.__all_virtual_table where table_name = '__all_virtual_replay_stat' and tenant_id = 1;
use oceanbase;
desc __all_virtual_replay_stat;
--replace_column 1 tenant_id 2 svr_ip 3 svr_port 4 ls_id 5 role 6 end_lsn 7 enabled 8 unsubmitted_lsn 9 unsubmitted_log_scn 10 pending_cnt
select * from __all_virtual_replay_stat limit 1;
