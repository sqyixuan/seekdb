--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: link.zt
#owner group: sql1

connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn1;
set @c = repeat(' ', 256);
select @c;
select cast(repeat('1',5) as signed int);
select cast(repeat('1',10) as signed int);
--error 1301
select length(repeat('a',100000000)),length(repeat('a',1000*64));
select length(repeat('a',10000)),length(repeat('a',100*64)),length(repeat('a',65535));
select length(repeat('a',1000)),length(concat(repeat('a',320),repeat('b',32000)));
select repeat('hello', -1);
select repeat('hello', -2);
select repeat('hello', -100);
select repeat('hello', 0);
select repeat('hello', -4294967295);
--error 1301
select repeat('hello', 4294967295);
select length(repeat('h', 65535));
select length(repeat('h', 65536));
select length(repeat('h', 65537));
select repeat('h', 10.1);
select repeat('h', -10.1);
select repeat('h', 1.1);
select repeat('h', 'abc');
select repeat(1,10);
select repeat(substr('abcd',2),1);
select repeat(substr('abcd',2),2);
select repeat(substr('abcd',1,2),2);
select length(repeat(0xa1,215)), length(repeat(0x1a, 310));
select repeat('ab',5+5),repeat('ab',-1),repeat('a',0);
select repeat('a',3*10+3-2);
select length(repeat('a',3*10+3-2));
##with null
select repeat(null,1);
select repeat(null,2);
select repeat(null,3);
select repeat(3,null);
select repeat(null,null);
--disable_warnings
drop table if exists t1;
--enable_warnings

CREATE TABLE t1 (a int auto_increment primary key not null, b varchar(20000)) ;

--disable_query_log
let $1= 303;
while ($1)
{
eval   INSERT INTO t1 values($1,repeat('a',200));
  dec $1;
}
--enable_query_log
select a,length(b) from t1 limit 1;

DELETE FROM t1 WHERE a=1 or a=5;
select * from t1 WHERE a=1 or a=5;

INSERT INTO t1 values(500,repeat('a',600));

UPDATE t1 SET b=repeat('a', 800) where a=10;
select length(b) from t1  where a=10;

DELETE FROM t1 WHERE a=2 or a=6;
select *  FROM t1 WHERE a=2 or a=6;
UPDATE t1 SET b=repeat('a', 600) where a=11;
select a,length(b) from t1 where a=11;
select count(*) from t1 where b=repeat('a',200);
select count(*) from t1 where b=repeat('a',600);
select count(*) from t1 where b=repeat('a',800);
select a,length(b)  from t1 where b in (repeat('a',800),repeat('a',600));
delete from t1;
INSERT INTO t1 values(6,'adgafdgafdg'),(7,'agfadgfdgadgf'),(1,'ab'),(2,'cd');
select repeat(b,3) from t1 ;
select repeat(b,1) from t1 ;
select repeat(b,1) as abc from t1 order by abc;
select concat(repeat(b,2),'abcd') from t1 ;
select length(b),a from t1;
select repeat(b,a) as abc from t1;
select length(repeat(b,a)) as abc from t1;
select length(repeat(b,a)) as abc from t1 order by abc;
select length(repeat(b,a+10)) as abc from t1 order by abc;
--disable_warnings
drop table if exists t2;
--enable_warnings
CREATE TABLE t2 (a int  primary key not null, b varchar(256)) ;
--error 1406
iNSERT INTO t2 VALUES (0,REPEAT('a', 1024));
iNSERT INTO t2 VALUES (2,REPEAT('a', 256));
select length(b),a from t2;
insert into t2 values (1, concat(repeat('1', 200), '2'));
select length(b),a from t2;
select length(repeat(b,a)) as abc from t2;
select length(repeat(b,a)) as abc from t2 order by abc;
#drop table t1;

drop table t1;
drop table t2;
create table t1 (
  col_varchar    varchar(1),
  col_varbinary  varbinary(1),
  col_char       char(1), 
  col_binary     binary(1),
  col_tinytext   tinytext,
  col_tinyblob   tinyblob,
  col_mediumtext mediumtext,
  col_mediumblob mediumblob,
  col_text       text,
  col_blob       blob,
  col_count      bigint);
insert into t1 values ('a', 'a', 'a', 'a', 'a', 'a', 'a', 'a', 'a', 'a', 1048576);
create table t2 as
select repeat('a',    512),
       repeat('a',    513),
       repeat('a',  21845),
       repeat('a',  21846),
       repeat(col_varchar, '512'),
       repeat(col_varchar, '513'),
       repeat(col_varchar, 65535),
       repeat(col_varchar, 65536),
       repeat(col_varbinary, '512'),
       repeat(col_varbinary, '513'),
       repeat(col_varbinary, 65535),
       repeat(col_varbinary, 65536),
       repeat(col_char, '512'),
       repeat(col_char, '513'),
       repeat(col_char, 65535),
       repeat(col_char, 65536),
       repeat(col_binary, '512'),
       repeat(col_binary, '513'),
       repeat(col_binary, 65535),
       repeat(col_binary, 65536),
       repeat(col_tinytext,   2),
       repeat(col_tinytext,   3),
       repeat(col_tinytext, 257),
       repeat(col_tinytext, 258),
       repeat(col_tinyblob,   2),
       repeat(col_tinyblob,   3),
       repeat(col_tinyblob, 257),
       repeat(col_tinyblob, 258),
       repeat(col_mediumtext, 1),
       repeat(col_mediumblob, 1),
       repeat(col_text, 1),
       repeat(col_text, 2),
       repeat(col_blob, 1),
       repeat(col_blob, 2),
       repeat('a', col_count),
       repeat(col_varchar, col_count),
       repeat(col_varbinary, col_count),
       repeat(col_char, col_count),
       repeat(col_binary, col_count),
       repeat(col_tinytext, col_count),
       repeat(col_tinyblob, col_count),
       repeat(col_mediumtext, col_count),
       repeat(col_mediumblob, col_count),
       repeat(col_text, col_count),
       repeat(col_blob, col_count),
       repeat(NULL,NULL),
       repeat('aa', NULL),
       repeat(NULL, 1),
       repeat('aa', 1),
       repeat(col_char, NULL),
       repeat(col_binary, NULL),
       repeat(col_varchar, NULL),
       repeat(col_varbinary, NULL),
       repeat(col_tinytext, NULL),
       repeat(col_tinyblob, NULL),
       repeat(col_mediumtext, NULL),
       repeat(col_mediumblob, NULL),
       repeat(col_text, NULL),
       repeat(col_blob, NULL),
       repeat(NULL, col_count)
from t1;
desc t2;

drop table t1;
drop table t2;

