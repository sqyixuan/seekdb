--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: yuzhong.zhao 
# owner group: storage
# description:
#

# tags: multiget after ddl

--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1 (c1 int primary key, c2 int(11), c3 int default NULL);
insert into t1 values(1, 1, 1);
insert into t1 values(2, 2, 2);
insert into t1 values(3, 3, 3);

--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc


# multiget with a row from io
select c3, c2 from t1 where c1 in (1,2,3);

#multiget with a row from row cache
select c3, c2 from t1 where c1 in (1,2,3);

#ddl operater
alter table t1 change column c2 c2 int(64);

#multiget after ddl from row cache
select c3, c2 from t1 where c1 in (1,2,3);

#flush kvcachec
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
alter system flush kvcache;
disconnect obsys;
connection default;

#multiget after ddl from io
select c3, c2 from t1 where c1 in (1,2,3);
