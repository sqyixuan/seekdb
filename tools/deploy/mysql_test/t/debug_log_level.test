#owner:link.zt
#owner group: sql1
#author link.zt
#只是用来测试debug日志级别下的日志安全性

set @@ob_log_level='debug';
--disable_warnings
drop table if exists debug_t, debug_t1;
--enable_warnings
create table debug_t(c1 int, c2 int);
create table debug_t1(c1 int primary key, c2 varchar(10));

insert into debug_t values(1, 2), (2, 3);
insert into debug_t1 values(1, '12'), (2, '34');
select * from debug_t where c1 > 1 and c1 < 2;
select * from debug_t where c1 = 1;
select * from debug_t where c1 = 1 or c1 = 2;
select * from debug_t where c1 = 1 or c2 = 2;
select * from debug_t, debug_t1 where debug_t.c1 = debug_t1.c1;
select * from debug_t left join debug_t1 on debug_t.c1 = debug_t1.c1;

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
alter system set syslog_level='debug';
connection default;
insert into debug_t1 values(3, '12'), (4, '34');
select * from debug_t1 where c1 > 1 and c1 < 3;
select * from debug_t1 where c1 = 1;
select * from debug_t, debug_t1 where debug_t.c1 = debug_t1.c1;
show tables like "debug_%";

set @@ob_log_level='disabled';
connection obsys;
alter system set syslog_level='info';
connection default;
drop table debug_t, debug_t1;
disconnect obsys;
