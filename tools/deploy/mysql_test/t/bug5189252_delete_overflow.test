--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: dachuan.sdc
#owner group: sql1
#tags: create_table, insert
#description:

--disable_abort_on_error
--disable_warnings
drop table if exists t1;
--enable_warnings

--let $const=12
set @@session.sql_mode='';
--let $create_sql=create table t1(pk int primary key
--let $select_sql=select pk
--let $field=$const
while($field)
{
   --let $create_sql=$create_sql , f$field varchar(1053)
   --let $select_sql=$select_sql , substr(f$field,0,5)
   dec $field;
}
--let $create_sql=$create_sql )
--let $select_sql=$select_sql from t1
eval $create_sql;
--let $insert_sql=replace into t1 values(1

--let $value=1
--let $kb=62
--let $
while($kb)
{
    --let $value=$value$byte
    dec $kb;
}

--let $field=$const
while($field)
{
    --let $insert_sql=$insert_sql , '$value'
    dec $field;
}
--let $insert_sql=$insert_sql )
eval $insert_sql;
--disable_query_log
eval $insert_sql;
eval $insert_sql;
delete from t1 where pk=1;
eval $select_sql;
drop table t1;
