--real_sleep 1
select table_name,table_id,table_type,load_type,table_def_type,rowkey_column_num,column_num,max_used_column_id,create_mem_version,max_rowkey_length,compress_func_name,is_use_bloomfilter,merge_write_sstable_version,is_pure_update_table,rowkey_split,expire_condition from oceanbase.__all_virtual_table where table_id<1000;

select table_id,column_name,table_name,column_id,rowkey_id,length_in_rowkey,order_in_rowkey,join_table_id,join_column_id,data_type,data_length,data_precision,data_scale,nullable from oceanbase.__all_virtual_column where table_id<1000;

select left_table_id,left_column_id,right_table_id,right_column_id,left_table_name,left_column_name,left_column_name,right_table_name,right_column_name from oceanbase.__all_join_info;

select distinct svr_type from oceanbase.__all_server;

#select * from oceanbase.__all_server_stat;

select cluster_id,svr_type,name,section,data_type,value,value_strict,info from oceanbase.__all_sys_parameter where name !='ups_white_list' and name!='rootservice_list';
select cluster_id,svr_type,name,section,data_type,value_strict,info from oceanbase.__all_sys_parameter where name !='ups_white_list';

--replace_column 4 value
select cluster_id,name,data_type,value from oceanbase.__all_sys_param;

--replace_column 4 value
select cluster_id,name,data_type,value,info from oceanbase.__all_sys_stat;

select user_id,table_id,priv_all,priv_alter,priv_create,priv_create_user,priv_delete,priv_drop,priv_grant_option,priv_insert,priv_update,priv_select,priv_replace from oceanbase.__all_virtual_table_privilege where table_id<1000;

select event_type,event_int_param,extra from oceanbase.__all_trigger_event limit 10;
select user_name,user_id,pass_word,info,priv_all,priv_alter,priv_create,priv_create_user,priv_delete,priv_drop,priv_grant_option,priv_insert,priv_update,priv_select,priv_replace,is_locked from oceanbase.__all_user;
