--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: dachuan.sdc
# owner group: SQL2
# description:
#
--disable_warnings
drop table if exists t1,t2;
--enable_warnings
--error 1074
create table t1 (toolong varchar(262145) primary key);
create table t2 (toolong varchar(4096) primary key);
create table t1 (v5 varchar(5) primary key, v0 varchar(0), v varchar(1024), v65536 varchar(65536),v20 char(20),v50 char(50));
desc t1;

# insert
insert into t1 values (12345, '', 'abc', 'def','2354435345','w3r5wt4eter');
--error 1406
insert into t1 values ('123456', '', 'abc', 'def','dagdafgfdgag','dagfgfgafgfa');
--error 1406
insert into t1 values ('12346', '1', 'abc', 'def','agafdgfdgafdgfag','adgfgfgfdgafgg');
--error 1406
replace into t1 values ('12346', '1', 'abc', 'def','dagfdgfdagfagaggag','dagadgfagfgfggfga');
--error 1406
replace into t1 values ('12346', '', 'abc', 'def','dagfgfgfaddgadfgdfgfdagfda','afdgafgafgfg');
--error 1406
replace into t1 values ('12346', '', 'abc', 'def','dagfgfgfaddgadfgdfgfdagfda','afdgafgafgfgadgafgafgfdgafgfgafdggfdsgfdgfdsgfdsgsgfgrdagfdgfd');
replace into t1 values ('12346', '', 'abc', 'def','dagfgfgfaddgadfgdf','afdgafgafgfg');
--error 1406
update t1 set v0 = '1' where v5 = '12345';
update t1 set v0 = '' where v5 = '12345';
--error 1406
update t1 set v5 = '123456' where v5 = '12345';
update t1 set v5 = '11111' where v5 = '12345';
select * from t1;
--disable_query_log
--disable_result_log
let $cnt=500;
while($cnt)
{
eval replace into t1 values ($cnt, '', 'abc', 'def','dagfgfgfaddgadfgdf','afdgafgafgfg');
dec $cnt;
}
--enable_query_log
--enable_result_log
alter table t1 drop v50;
sleep 1;
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
select * from t1 limit 450,470;
alter table t1 add v60 varchar(60);
sleep 1;
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
--error 1406
insert into t1 values ('1346', '1', 'abc', 'def','agaafdgfag','adgfgafgg');
desc t1;
drop table t1;
