# owner: dachuan.sdc
# owner group: SQL2
# description:
# tags: ddl

--disable_query_log
--disable_warnings
set @@session.explicit_defaults_for_timestamp=off;
set @@recyclebin = off;
drop database if exists jx_db;
--enable_query_log
--enable_warnings

create database jx_db;
use jx_db;

create table t1 (c1 int primary key);

alter table t1 comment = 'table t1';
alter table t1 set comment = 'table t1';

alter database jx_db set charset = 'utf8mb4';
alter database jx_db charset = 'utf8mb4';

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;

alter system set enable_sys_table_ddl = true;
alter system enable_sys_table_ddl = false;
connection default;

drop database jx_db;

