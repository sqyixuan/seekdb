# owner: rongxuan.lc
# description: 本case是为了测试: enable_ddl;

connect (obsys2,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys2;
alter system set enable_upgrade_mode = true;
sleep 1;
alter system set enable_ddl = false;
sleep 1;

connection default;
--error 4179
create table test(c1 int primary key);
--error 4179
create database tt;

connection obsys2;
alter system set enable_ddl = true;
sleep 1;

connection default;
--disable_warnings
drop table if exists t;
--enable_warnings
create table t(c1 int primary key);

connection obsys2;
alter system set enable_upgrade_mode = false;
