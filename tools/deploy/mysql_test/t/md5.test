--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: link.zt
#owner group: sql1

#null
select md5(NULL);

#empty
select md5('');

#single char with case sensitive
select md5('a');
select md5('A');
select md5('0');
select md5('1');
select md5('@');
select md5('#');
select md5(' ');

#normal english word
select md5('abcdefg');
select md5('abcdefg ');
select md5('Good morning');
select md5('Good evening');

#ip like
select md5('255.255.255.255');
select md5('192.168.1.100');
select md5('30.32.204.180');

#email like
select md5('emily@163.com');
select md5('mike@sohu.com');
select md5('joey@sina.com');

#chinese word
select md5('阿里巴巴');
select md5('阿里巴巴 ');
select md5('淘宝');
select md5('淘宝 ');

#wrong type (not varchar)
select md5(0);
select md5(100);
select md5(3.1415);
select md5(TRUE);
select md5(cast("2010-10-01 12:34:56" as datetime));
