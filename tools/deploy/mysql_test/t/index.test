--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: bin.lb
# owner group: SQL2
# tags: optimizer, index
# description:
#
--disable_info
--disable_metadata
connect (sysc,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection sysc;
alter system set merger_check_interval= '10s';
connection default;
--disable_warnings
create database if not exists test;
use test;
drop table if exists t3;
--enable_warnings
create table t3(c1 bigint primary key, c2 bigint, v1 varchar(128), v2 varchar(64));
create index t3_idx1 on t3(v2, c2) storing(v1);
create unique index t3_idx2 on t3(c2);

# dml before major freeze
insert into t3 values(1, 11, 'aaa1', 'aaaa1');
insert into t3 values(2, 22, 'aaa2', 'aaaa2');
insert into t3 values(3, 33, 'aaa3', 'aaaa3');
insert into t3 values(4, 44, 'aaa4', 'aaaa4');
update t3 set c2=2222 where c1=2;
update t3 set c2=1111, v2='aaaaaa' where c1=1;
delete from t3 where c2<55555;

# do major freeze
let $index_name = t3_idx1;

# without index ready

--enable_query_log
--enable_result_log

#--replace_regex /Plan signature: [0-9]*/Plan signature/
--disable_result_log
#explain select /*+index(t3 t3_idx1)*/ * from t3;
--enable_result_log

insert into t3 values(1, 11, 'aaa1', 'aaaa1');
insert into t3 values(2, 22, 'aaa2', 'aaaa2');
insert into t3 values(3, 33, 'aaa3', 'aaaa3');
insert into t3 values(4, 44, 'aaa4', 'aaaa4');
#--replace_regex /Plan signature: [0-9]*/Plan signature/
--disable_result_log
#explain select /*+index(t3 t3_idx1)*/ * from t3 where v1 like 'aaa%';
--enable_result_log
select /*+index(t3 t3_idx1)*/ * from t3 where v1 like 'aaa%';

update t3 set v2='aaaaaaaaaaa' where v1 in ('aaa2', 'aaa4');
#--replace_regex /Plan signature: [0-9]*/Plan signature/
--disable_result_log
#explain select /*+index(t3 t3_idx1)*/ * from t3 where v2 like '%aaaaaaaaa%';
--enable_result_log
select /*+index(t3 t3_idx1)*/ * from t3 where v2 like '%aaaaaaaaa%';

delete from t3;

# wait index ready
--source mysql_test/include/check_all_idx_ok.inc
show index from t3;
#--replace_regex /Plan signature: [0-9]*/Plan signature/
--disable_result_log
#explain select /*+index(t3 t3_idx1)*/ * from t3;
--enable_result_log

insert into t3 values(1, 11, 'aaa1', 'aaaa1');
insert into t3 values(2, 22, 'aaa2', 'aaaa2');
insert into t3 values(3, 33, 'aaa3', 'aaaa3');
insert into t3 values(4, 44, 'aaa4', 'aaaa4');
#--replace_regex /Plan signature: [0-9]*/Plan signature/
--disable_result_log
#explain select /*+index(t3 t3_idx1)*/ * from t3 where v1 like 'aaa%';
--enable_result_log
select /*+index(t3 t3_idx1)*/ * from t3 where v1 like 'aaa%';

update t3 set v2='aaaaaaaaaaa' where v1 in ('aaa2', 'aaa4');
#--replace_regex /Plan signature: [0-9]*/Plan signature/
--disable_result_log
#explain select /*+index(t3 t3_idx1)*/ * from t3 where v2 like '%aaaaaaaaa%';
--enable_result_log
--sorted_result
select /*+index(t3 t3_idx1)*/ * from t3;

delete from t3 where v2 in ('aaaaaaaaaaa', 'dddddddddd') and v1  like 'aa%2%';
#--replace_regex /Plan signature: [0-9]*/Plan signature/
--disable_result_log
#explain select /*+index(t3 t3_idx1)*/ * from t3;
--enable_result_log
select /*+index(t3 t3_idx1)*/ * from t3;


## unique test
show index from t3;
#--replace_regex /Plan signature: [0-9]*/Plan signature/
--disable_result_log
#explain select /*+index(t3 t3_idx2)*/ * from t3 where c2<555555;
--enable_result_log
select /*+index(t3 t3_idx2)*/ * from t3 where c2<555555;

--source mysql_test/include/check_all_idx_ok.inc
show index from t3;

--error 1062
insert into t3 values(10, 11, 'aaa1', 'aaaa1');
insert into t3 values(2, 22, 'aaa2', 'aaaa2');
--error 1062
insert into t3 values(30, 33, 'aaa3', 'aaaa3');
--error 1062
insert into t3 values(40, 44, 'aaa4', 'aaaa4');

#--replace_regex /Plan signature: [0-9]*/Plan signature/
--disable_result_log
#explain select /*+index(t3 t3_idx2)*/ * from t3 where v1 like 'aaa%';
--enable_result_log
select /*+index(t3 t3_idx2)*/ * from t3 where v1 like 'aaa%';

--error 1062
update t3 set v2='aaaaaaaaaaa', v1='vvvvvvvv111111', c2=5555 where v1 in ('aaa2', 'aaa4');
update t3 set v2='aaaaaaaaaaa', v1='vvvvvvvv111111', c2=2222222  where v1 in ('aaa2', 'aaa4') and c2=22;
#--replace_regex /Plan signature: [0-9]*/Plan signature/
--disable_result_log
#explain select /*+index(t3 t3_idx2)*/ * from t3 where c2 in (11, 22, 55555, 2222222);
--enable_result_log
select /*+index(t3 t3_idx2)*/ * from t3 where c2 in (11, 22, 55555, 2222222);

delete from t3 where v1  like 'aa%' and c2 < 55555;
#--replace_regex /Plan signature: [0-9]*/Plan signature/
--disable_result_log
#explain select /*+index(t3 t3_idx2)*/ * from t3;
--enable_result_log
select /*+index(t3 t3_idx2)*/ * from t3;


--disable_warnings
drop table if exists t3;
--enable_warnings

--disable_warnings
drop table if exists test;
--enable_warnings
create table test(c1 int , c2 int, c3 varchar(50), c4 varchar(50), c5 int , c6 double, c7 int, primary key(c1, c2, c3));
--error 1072
create index idx1 on test(c8);
--error 1089
create index test_idx on test (c3(60));
--error 1089
create index test_idx2 on test (c1(10), c3);
create index test_idx3 on test (c1, c3(20));
drop index test_idx3 on test;
create view test_v as select c1,c2,c3 from test;
--error 1347
create index test_idx3 on test_v(c1) global;
--error 1347
drop view test;
--error 1051
drop table test_v;
drop view test_v;
drop table test;
--error 1146
create index test_idx3 on test(c1, c3);

--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(c1 int primary key, c2 int, c3 int, index idx(c2), unique uidx(c3));
let $tenant_id = `select effective_tenant_id()`;
connection sysc;
--disable_query_log
eval select column_name, rowkey_position, index_position from oceanbase.__all_virtual_column a inner join oceanbase.__all_virtual_table b left join oceanbase.__all_virtual_database c on b.tenant_id = c.tenant_id and b.database_id = c.database_id inner join oceanbase.__all_virtual_table d on b.tenant_id = d.tenant_id and b.data_table_id = d.table_id where a.tenant_id = b.tenant_id and a.tenant_id = $tenant_id and a.table_id = b.table_id and d.table_name = 't1' and c.database_name = 'test' order by column_name,rowkey_position, index_position;
--enable_query_log
connection default;
--disable_warnings
drop table if exists t2;
--enable_warnings
create table t2(c1 int, c2 int, c3 int, index idx(c2), unique uidx(c3));
connection sysc;
--disable_query_log
eval select column_name, rowkey_position, index_position from oceanbase.__all_virtual_column a inner join oceanbase.__all_virtual_table b left join oceanbase.__all_virtual_database c on b.tenant_id = c.tenant_id and b.database_id = c.database_id inner join oceanbase.__all_virtual_table d on b.tenant_id = d.tenant_id and b.data_table_id = d.table_id where a.tenant_id = b.tenant_id and a.tenant_id = $tenant_id and a.table_id = b.table_id and d.table_name = 't2' and c.database_name = 'test' order by column_name,rowkey_position, index_position;
--enable_query_log
connection default;

#copy_file  var/log/index.reject var/log/index.reject.bak;
#cat_file var/log/index.reject.bak;

--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(c1 double primary key);
insert into t1 values('-0.0');
delete from t1;
insert into t1 values('0.0');
select * from t1;
drop table t1;

create table t1(c1 float primary key);
insert into t1 values('-0.0');
delete from t1;
insert into t1 values('0.0');
select * from t1;
drop table t1;
