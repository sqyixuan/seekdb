--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: dachuan.sdc
#owner group:sql1
#description:case trans from mysql
--disable_warnings
DROP TABLE IF EXISTS t8;
--enable_warnings
CREATE TABLE t8(c1 INTEGER NOT NULL);
CREATE INDEX i1 ON t8(c1);
DROP INDEX i1 ON t8;
DROP TABLE t8; 
SHOW TABLES like 't8';

