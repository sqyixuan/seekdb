# Test of functions bug6225432_union_missing_data
--disable_warnings
DROP TABLE IF EXISTS t1;
--enable_warnings
CREATE TABLE t1 ( a timestamp , pk bigint primary key) ;
INSERT INTO t1 VALUES  (  '2000-08-16 05:05:15.011832', 1) ,  (  '2007-04-08 11:15:41.027416', 2) ,  (  '2006-10-12 19:52:02.024872', 3) ,  (  '2008-05-07 04:40:10.050964', 4)   ;
( SELECT pk FROM t1 WHERE a  <= '2022-06-15 00:54:54.999998'  ) UNION  ( SELECT 1 ) ;
SELECT pk FROM t1 WHERE a <= '2022-06-15 00:54:54.999998' ;

