let $query = FROM t1 WHERE key4>10 and key4<14 and key5>12 and key5<18 and key6>2 and key6 is NULL; 
--disable_result_log
#eval EXPLAIN SELECT COUNT(*) $query;
--enable_result_log
eval SELECT COUNT(*) $query;
--disable_result_log
#eval EXPLAIN SELECT * $query;
