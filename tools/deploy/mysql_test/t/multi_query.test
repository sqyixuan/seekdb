#description: Multi-query test
delimiter |;
--disable_warnings
drop table if exists t1|
--enable_warnings
create table t1 (i int);select * from t1; insert into t1 values (3);select * from t1;|
# GV$OB_SQL_AUDIT should record single statement query text
# bug 
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT)|
connection obsys|
alter system set enable_sql_audit = 1|
disconnect obsys|
connection default|
select * from t1 where i=2;select * from t1 where i=3|
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT)|
connection obsys|
select /*not me*/query_sql,ret_code from oceanbase.GV$OB_SQL_AUDIT where query_sql like '%from t1 where i=%' and query_sql not like '%not me%' limit 2|
alter system set enable_sql_audit = 0|
disconnect obsys|
connection default|
drop table t1|

select 1;select 2;select 3|
select 1;select 2|
select 1|
