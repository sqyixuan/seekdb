--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: link.zt
# owner group: SQL1
# Test of xor function


#### xor 表达式

select 1 xor 1;
select 1 xor 0;
select 0 xor 1;
select 0 xor 0;

select 10 xor 9;
select 10 xor 10;

select 10 xor null;
select null xor 10;

select -1 xor 0;
select -1 xor -1;
select -1 xor -10;

select 1 xor 1 xor 1 xor 1 xor 1;
select 1 xor 0 xor 1 xor 0 xor 1;
select 1 xor 2 xor 3 xor 4 xor 5 xor 6;
select 1 xor 2 xor 3 xor 4 xor 5;
select 1 xor 2 xor null xor 4 xor 5;

select true xor false;
select false xor false;

select '1' xor '0';
select '0' xor '0';

### 计算优先级 

select 0 * 1 xor 1;
select 0 * (1 xor 1);
select 1 xor 1 * 0;
select (1 xor 1) * 0;

select -10 + 10 xor 1;
select -10 + (10 xor 1);
select 0 xor 10 - 10;
select (0 xor 10) - 10;

### xor 边界值
select 0.00 xor -0.00;

# ob 暂时不支持抛出warnings
select 999999999999999999999999999999999999999999999.499999999 xor 999999999999999999999999999999999999999999999.500000001; 

select 0.9999999999999999999999999999999999999999999999999 xor 1;
select 0.00000000000000000000000000000000000000000000001 xor 0;
