--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

#owner: linlin.xll
#owner group: SQL1
#description:
#tags: optimizer, plan_cache, dml

--disable_warnings
drop table if exists t1, t2, t3, t4;
--enable_warnings
create table t1(a1 int, a2 int, a3 int);
create table t2(b1 int, b2 int, b3 int);
create table t3(c1 int, c2 int, c3 int);
create table t4(id int primary key,c1 int not null, c2 int not null, c3 int unique, c4 int, c5 int, unique key (c1,c2));


##set sql mode--ONLY_FULL_GROUP_BY on
--error 1231
set @@session.sql_mode='STRICT_ALL_TABLES, ONLY_FULL_GROUP_BY';
set @@session.sql_mode='STRICT_ALL_TABLES,ONLY_FULL_GROUP_BY';
select @@session.sql_mode; 

##case 1: switch use_plan_cache off
set @@session.ob_enable_plan_cache=0;

select t1.a1, count(t2.b1) from t1,t2 where t2.b1 = t1.a1 group by t2.b1 order by t2.b1;
select max(a1+1), a2 from t1 group by a2 having a2+min(a1) order by a2,count(a1);
select instr(a1,'2') from t1 group by a1 having a1+1 order by a1+2;
--error 1055
select instr(a1,'2') from t1 group by a2 having a2+1 order by max(a1);
--error 1055
select a1, (select a2 from t2 group by a2 having t1.a2) from t1 group by a1;
--error 1055
select a1, max(a2) from t1 group by a2;
--error 1055
select max(a2) from t1 group by a2 order by a1+a2;
--error 1055
select * from t1 group by a2;
--error 1055
select a1+1 from t1 group by a1+2;
select a1+1 from t1 group by a1+1;
select 1 from t1 group by a1+1 order by a1+1;
--error 1055
select 1 from t1 group by a1+1 order by a1+2;
select a1+1 as a from t1 group by a order by a+1;
--error 1055
select a1+1 as a from t1 group by a order by a1+2;
select a1 as a from t1 group by a1 order by  a+2;
select instr(a1,'') as a from t1 group by a1 order by  instr(a1, 1);
--error 0,1055
select a1 && (a2+1) from t1 group by a1, a2+1;
##mysql 5.6 does not support this ,but mysql 5.7 does
select a1 as a from t1 group by a having a;
select a1 as a from t1 group by a order by a1+1;

select a1+1 from t1 group by a1+1 order by a1+1;
select a1+a2 as a from t1 group by a order by  a1+a2;
select a1+a2 as a from t1 group by a1+a2;
##mysql will return error, it's her bug
select a3 from t1 group by a1&&a2, a3 order by a1&&a2;

--error 0,1055
select a1+a2 as a from t1 group by a order by  a1+a2+1;
##group by column offset
--error 0,1055
select a1+a2 as a from t1 group by 1 order by  a1+a2+1;
select a1+a2 as a from t1 group by 1 order by  a1+a2;
select a1, a2 from t1 group by 1,2 order by a1+a2+1;
select a1, max(a2) from t1 group by 1 order by a1+1;

##view related
--disable_warnings
drop view if exists v1;
--enable_warnings
create view v1 as select a1 as a, a2 as b from t1;
select a from v1 group by a;
--error 1055
select a from v1 group by b;
select a+b from v1 group by a+b order by a+b;
--error 1055
select a+b from v1 group by a order by a+b;

##with no group by node
##mysql 5.6 will return err:ERROR 1463 (42000): Non-grouping field 'a1' is used in HAVING clause, but mysql 5.7 is same with us
select a1, a2 from t1 having instr(a1, '1') order by a1+a2;
--error 1140
select a1, max(a2) from t1 having instr(a1, '1') order by a1+a2;
--error 1140
select count(*), a1 from t1;
--error 1140
select *, count(a1) from t1;
--error 1140
select a1, count(distinct a2) from t1;

##sub_query
select a2, (select a1 from t1)  from t1 group by a2;
select a2, (select a1 from t1) as a from t1 group by a2 having a order by a;
--error 1055
select a2, (select a1 from t1 group by a2) as a from t1 group by a2;
select a+b from (select a1 as a, a2 as b from t1)  as vv group by a, b;
--error 1055
select a+b from (select a1 as a, a2 as b from t1)  as vv group by a;
--error 1055
select a from (select a1 as a, a2 as b from t1)  as vv group by a order by b;
--error 1055
select a2, (select a1 from t1 group by a2)  from t1 group by a2;
--error 1055
select (select a1 from t2 where t1.a2=1), a2 from t1  group by a2;
--error 1055
select (select a1 from t2 where (select a2 from t3) >1 ) from t1 group by a1;
--error 1055
select  1 from t1 where (select a1 from t2 where (select a2 from t3) >1 ) group by a1 order by (select a3 from t3);
--error 1055
select 1 from t1 where (select (select b1 from t3) from t2 group by b2) group by a1;
select 1 from t1 where (select a1 from t2 where (select a2 from t3) >1 ) group by a1;

--error 1055
select 1 from t1 as t1_outer where (select a1 from t1 as t1_inner group by t1_inner.a2)  group by a3;
select 1 from t1 as t1_outer where (select t1_outer.a1 from t1 as t1_inner group by t1_inner.a2 limit 1)  group by a3;

--error 1055
select (select a1 from t2 having a2) from t1 group by a1;
explain basic select (select sum(t1_outer.a1) from t1 as t1_inner limit 1)   from t1 as t1_outer group by t1_outer.a2;
select (select sum(t1_outer.a1)+t1_inner.a1 from t1 as t1_inner limit 1)   from t1 as t1_outer group by t1_outer.a2;
select (select b1 from t2 where t1.a1=1), a2 from t1  where a1=1 group by a2;
select sum((select a2 from t2)) from t1 group by a1;

--error 1140
select *, max(a1)+1 from t1;
--error 1140
select count(*) + 1, (select a1 from t2) from t1;
--error 1140
select (select count(a1)+b1 from t2 having count(*)) from  t1;
--error 1140
select a1, (select sum(a2) from t2) from t1;
##TODO:has bug now
##--error 1140
##select  (select sum(a2) from t2 order by a1) from t1;
--error 1140
select (select t1_outer.a1 from t1 as t1_inner group by a2 limit 1) ,sum(a1)  from t1 as t1_outer;
--error 1140
select t1.a1 from t1 group by t1.a1   having t1.a1 in (select t2.b1 from t2 order by t2.b1, sum(t2.b2));
select a1 ,(select a2 from t2 group by b1) from t1 group by a1,a2;

##case when 
--error 1055
select case when a1>=0 then 'positive' else 'negative' end from t1  group by a2;
select case when avg(a1)>=0 then 'positive' else 'negative' end from t1 group by a2;
select case when (avg(a1) + a2)>=0 then 'positive' else 'negative' end from t1 group by a2;
--error 1055
select case when (avg(a1) + a3)>=0 then 'positive' else 'negative' end from t1 group by a2;
--error 1055
select case when (select a1 from t2) >=0 then 'positive' else 'negative' end from t1 group by a2;
select case when (select a2 from t2) >=0 then 'positive' else 'negative' end from t1 group by a2;
--error 1055
select case when (select a2 from t2) >=0 then (select a1 from t2) else 'negative' end from t1 group by a2;
select case when (select a2 from t2) >=0 then (select a2 from t2) else 'negative' end from t1 group by a2;
select case when (select a2 from t2) >=0 then (select b2 from t2) else 'negative' end from t1 group by a2;
--error 1055
select case when (select a2 from t2) >=0 then (select b2 from t2 group by b1) else 'negative' end from t1 group by a2;
select a1 from t1 group by 1;
select a1 from t1 group by 1 order by 1;
select max(a1) from t1 order by 1;

select a1+1 as c, sum(a2) from t1 group by c order by c;
select a1+1, 1+1 from t1 group by a1+1, 1+1;
select a1+1 from t1 group by a1+1;
select t1.a1, count(t2.b1) from t1,t2 where t2.b1 = t1.a1 group by t2.b1 order by t2.b1;
select sum(a2) s from t1 group by a1 having s <> 0 order by s;
####equivalent deduction in where clause
select t1.a1,t2.b1 from t1,t2 where t1.a1=t2.b1 group by t1.a1;
#

#normal group by
select sum(c3),c4 from t4 group by id;
select sum(c3),c4 from t4 where id = c5 group by c5;
--error 1055
select sum(c3),c4 from t4 where id + c5 = 1 group by c5;
select sum(c3),c4 from t4 group by c1, c2;
select sum(c3),c4 from t4 where c2 = c5 group by c1, c5;
--error 1055
select sum(c3),c4 from t4 group by c3;
select sum(c3),c4 from t4 where c3 is not null group by c3;
select sum(c3),c4 from t4 where c3 > c5 + 1 group by c3;
--error 0,1055
select sum(c3),c2 from t4 where id = c5 + 1 group by c5 + 1;
--error 0,1055
select sum(c3),c2 from t4 where id = c5 + c4 group by c5 + c4;

select sum(t4.c3), t4.c2 from t3, t4 group by t4.id;
--error 1055
select sum(t4.c3), t3.c2 from t3, t4 group by t4.id;
select sum(t4.c3), t4.c2 from t3, t4 where t4.id = t3.c1 group by t3.c1;
## successed in MySQL, OB not support now
--error 1055
select sum(t4.c3), t4.c2 from t3 left join t4 on t4.id = t3.c1 group by t3.c1;
--error 1055
select sum(t4.c3), t4.c2 from t3 right join t4 on t4.id = t3.c1 group by t3.c1;

select sum(c1),c4 from t4 where c4 = c5 group by c5;
select sum(c1),c4 from t4 where c4 = c2 and c2 = c5 group by c5;
select sum(c1),c4 + 1 from t4 where c4 = c5 group by c5;
--error 0,1055
select sum(c1),c4 + 1 from t4 where c4 + 1 = c5 group by c5;
--error 0,1055
select sum(c1),c3 from t4 where c4+c5 = c3 group by c4+c5;
select sum(c1),c4+c5 from t4 where c4+c5 = c3 group by c4+c5;

select sum(c1),c4 from t4 where c4 = 3 group by c5;
select sum(c1),c4 from t4 where c3 = 3 and c3 = c4 group by c5;

select c1+1 as b from t4 group by c1+1;
select c1+1 as b from t4 group by c1+1 order by c1+1;
## MySQL exec failed
select c1+1 as b from t4 group by c1+1 order by (c1+1)+1;
select c1+1 as b from t4 group by c1+1 order by b+1;
select c1+1 as b from t4 group by c1 order by b+1;

#scalar group by
select sum(c1),c4 from t4 where c4 = 3;
select sum(c1),c4 from t4 where c3 = 3 and c3 = c4;
select sum(c1),c4 from t4 where c3 = 3 + 1 and c3 = c4;
--error 1140
select sum(c1),c4 from t4 where c4 + 1 = 3;
--error 0,1140
select sum(c1),c4 + c5 from t4 where c4 + c5 = 3;
--error 0,1140
select sum(c1),c4 from t4 where c3 + 1 = 3 and c3 + 1 = c4;
select sum(c3),c4 from t4 where id = 1;
select sum(c3),c4 from t4 where c1 = 1 and c2 = 2;
select sum(c5),c4 from t4 where c3 = 2;
select sum(t4.c3), t4.c2 from t3, t4 where t4.id = 1;
--error 1140
select sum(t4.c3), t3.c2 from t3, t4 where t4.id = 1;

# select sub_query
select (select t4_inner.c2 from t4 as t4_inner limit 1) from t4 as t4_outer group by t4_outer.c1;
--error 1055
select (select t4_outer.c2 from t4 as t4_inner limit 1) from t4 as t4_outer group by t4_outer.c1;
select (select sum(t4_outer.c2) from t4 as t4_inner limit 1) from t4 as t4_outer group by t4_outer.c1;
select (select any_value(t4_outer.c2) from t4 as t4_inner limit 1) from t4 as t4_outer group by t4_outer.c1;

#recover the enviroment
set @@session.sql_mode='STRICT_ALL_TABLES';
select @@session.sql_mode; 
set @@session.ob_enable_plan_cache=1;

#drop table if exists t1, t2, t3, t4;
