--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

#owner: linlin.xll
#owner group: SQL4
#description:
#tags: inner_table
##lower_case_table_names = 0:stored as origin letters, and comparisions are case sensitive

connect (conn0,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn0;

--disable_warnings
drop tenant if exists tt1 force;
drop resource pool if exists test_resource_pool1;
drop resource unit if exists test_resource_unit1;
--enable_warnings

#--disable_query_log
#eval create resource unit test_resource_unit1 max_cpu 1, memory_size '2G';
#--enable_query_log

#let $zone_name=query_get_value(select zone from oceanbase.__all_zone where zone != '' limit 1, zone, 1);

#--disable_query_log
#eval create resource pool test_resource_pool1 unit = 'test_resource_unit1', unit_num = 1, zone_list = ('$zone_name');
#--enable_query_log

#--disable_query_log
#eval create tenant tt1 replica_num = 1, primary_zone='$zone_name', resource_pool_list=('test_resource_pool1') set lower_case_table_names = 0, ob_tcp_invited_nodes='%';
#--source mysql_test/include/check_tenant_sync.inc
#--enable_query_log

##time to sync schema
let $__tenant_name__ = 'sys';
--source mysql_test/include/get_tenant_server.inc
connect (conn1,$TE_SERVER_IP,root,,*NO-ONE*,$TE_SERVER_PORT);
connection conn1;

select effective_tenant();
select current_user();

select substring_index(user(), '@', 1);
select substring_index(session_user(), '@', 1);
select substring_index(system_user(), '@', 1);
show variables like 'lower_case_table_names';

--disable_warnings
drop database if exists yyy;
drop database if exists Yyy;
--enable_warnings

##(1) DATABASE NAMES,TABLE NAMES AND TABLE ALIAS NAMES --- only database name , table names and table alias names are affected by lower_case_table_names:stored as origin letters, and comparisions are case sensitive

create database yyy;
#create database Yyy;
#show databases;
#drop database Yyy;

use yyy;
create table t_table(c1 int primary key, c2 int);
#create table T_table(c1 int primary key, c2 int);
show tables;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t_table;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table T_table;
select * from t_table;
#--error 1146
#select * from T_TABLE;
#select * from t_table c join T_table C order by c.c1;
drop table t_table;

##(2)INDEX NAMES,COLUMN NAMES AND COLUMN ALIAS NAMES --- index name, column names and column alias names are not affected by lower_case_table_names:stored as origin letters, and comparisions are case insensitive
--error 1060
create table t_column(c1 int primary key, C1 int);
create table t_column(c1 int primary key, C2 int);

--error 1052
select c1 a, C2 A from t_column order by a;
select c1, c2 from t_column;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t_column;

create index IDX on t_column(c2);
--error 1061
create index idx on t_column(c2);
show index from t_column;
drop table t_column;

##(3) USER NAMES AND OTHER NAMES --- user names and other names are not affected by lower_case_table_names.They are always stored as origin letters adn comparisions are case sensitive

CREATE USER yyy;
CREATE USER YYY;
drop user yyy, YYY;
drop database yyy;

#connection conn0;
#drop tenant tt1 force;
