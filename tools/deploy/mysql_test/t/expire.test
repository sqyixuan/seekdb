# owner: xiaoyi.xy
# owner group: SQL3
# comment: this case is marked as expired in filter.py

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
--disable_abort_on_error
####TITLE: expire
--disable_query_log
--source mysql_test/include/index_quick_major.inc
--real_sleep 1
--enable_query_log


####CASE
--echo case 1 : varchar
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(c0 int primary key,c1 varchar(1024)) EXPIRE_INFO ( c1 = 'd');
insert into t1 values(1,'i'),(2,'s'),(3,'D');
select c0,c1 from t1;
update t1 set c1='d' where c0=1;
update t1 set c1='d' where c0=2;
select c0,c1 from t1;

--echo merge happens
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
--real_sleep  5

select c0,c1 from t1;
drop table t1;

####CASE
--echo case 2 : expire row
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(c0 int primary key,c1 int) EXPIRE_INFO  =( c1 < 0);
insert into t1 values(1,1),(2,1),(3,1);
select c0,c1 from t1;

update t1 set c1=-1 where c0=1;
select c0,c1 from t1;

--echo merge happens
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
--real_sleep  5

select c0,c1 from t1;
drop table t1;

####CASE
--echo case 3 : int + rows
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(c0 int primary key,c1 int) EXPIRE_INFO ( c1 < 0);
insert into t1 values(1,1),(2,1),(3,1);
select c0,c1 from t1;

update t1 set c1=-1 where c0=1;
update t1 set c1=-1 where c0=2;
update t1 set c1=-1 where c0=3;
select c0,c1 from t1;

--echo merge happens
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
--real_sleep  5

select c0,c1 from t1;
drop table t1;

####CASE
--echo case 4 : all expire
--disable_warnings
drop table if exists t1;
--enable_warnings
#create table  t1(c0 int primary key,c1 datetime default now()) EXPIRE_INFO (c1 > 0);
create table t1(c0 int primary key,c1 datetime default now()) EXPIRE_INFO (cast(c1 as signed int) > 0);
drop table t1;
create table t1(c0 int primary key,c1 datetime default now()) EXPIRE_INFO (TIME_TO_USEC(c1) > 0);
insert into t1(c0) values(1),(2),(3);
--replace_column 2 time
select c0,c1 from t1;
--real_sleep  5

--echo merge happens
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
--real_sleep  5

select c0,c1 from t1;
drop table t1;

####CASE
--echo case 5: no expire
--disable_warnings
drop table if exists t1;
--enable_warnings
#create table  t1(c0 int primary key,c1 datetime default now()) EXPIRE_INFO (c1 < 0);
--error 5083
create table t1(c0 int primary key,c1 datetime default now()) EXPIRE_INFO (cast(c1 as signed int) < 0);
create table t1(c0 int primary key,c1 datetime default now()) EXPIRE_INFO (TIME_TO_USEC(c1) < 0);
insert into t1(c0) values(1),(2),(3);
--replace_column 2 time
select c0,c1 from t1;

--echo merge happens
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
--real_sleep  5
--replace_column 2 time
select c0,c1 from t1;
drop table t1;

####CASE
--echo case 6: expression test
--disable_warnings
drop table if exists t1,t2,t3,t4,t5,t6,t7,t8,t9,t10,t11,t12,t13,t14,t15;
--enable_warnings
create table t1(c0 int primary key,c1 int) EXPIRE_INFO (c0 > c1);
insert into t1 values(1,1),(100,0),(0,1);

create table t2(c0 int primary key,c1 int) EXPIRE_INFO (c0 = c1);
insert into t2 values(1,1),(100,0),(0,1);

create table t3(c0 int primary key,c1 int) EXPIRE_INFO (c0 != c1);
insert into t3 values(1,1),(100,0),(0,1);

create table t4(c0 int primary key,c1 int) EXPIRE_INFO (c0 < c1);
insert into t4 values(1,1),(100,0),(0,1);

create table t5(c0 int primary key,c1 int) EXPIRE_INFO (c0 >= c1);
insert into t5 values(1,1),(100,0),(0,1);

create table t6(c0 int primary key,c1 int) EXPIRE_INFO (c0 <= c1);
insert into t6 values(1,1),(100,0),(0,1);

create table t7(c0 int primary key,c1 int) EXPIRE_INFO (c0 + c1 > 100);
insert into t7 values(100,1),(1,100),(0,1);

create table t8(c0 int primary key,c1 int) EXPIRE_INFO (c0 - c1 > 0);
insert into t8 values(100,1),(1,100),(0,1);

create table t9(c0 int primary key,c1 int) EXPIRE_INFO (c0 + c1 = 100);
insert into t9 values(100,0),(0,100),(10,1);

create table t10(c0 int primary key,c1 int, c2 int) EXPIRE_INFO (c0 + c1 + c2 = 100);
insert into t10 values(100,0,0),(10,100,0),(0,1,101);
--error 5008
alter table t10 drop c2;

create table t11(c0 int primary key,c1 int, c2 int) EXPIRE_INFO (c0 + c1  > c2);
insert into t11 values(100,0,0),(10,100,100),(0,1,100);
--error 5008
alter table t11 drop c2;
--error 5057
alter table t11 drop c0;

create table t12(c0 int primary key,c1 double) EXPIRE_INFO (c1 > 1.5);
insert into t12 values(1,1),(2,2),(3,2.6);

create table t13(c0 int primary key,c1 timestamp) EXPIRE_INFO (c1 > '2012-10-01 23:00:00');
insert into t13 values(1,'2012-10-01 23:00:00'),(2,'2012-10-01 23:00:01'),(3,'2012-11-01 23:00:00');
alter table t13 alter c1  set default '2050-01-01 00:00:00';

create table t14(c0 int primary key,c1 datetime default now()) EXPIRE_INFO (c1 > '2014-01-01 00:00:00' and TIME_TO_USEC(c1) != 0);
insert into t14(c0) values(1),(2),(3);

create table t15(c0 int primary key,c1 datetime default now()) EXPIRE_INFO (c1 < '2050-01-01 00:00:00');
insert into t15(c0) values(1),(2);
alter table t15 alter c1 drop not null;
sleep 1;
alter table t15 alter c1  set default '2050-01-01 00:00:00';
sleep 1;

--echo merge happens
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
--real_sleep  5

--let $id=12
while($id > 0)
{
    eval select c0,c1 from t$id;
    dec $id;
}

select c0,c1 from t13;
--replace_column 2 time
select c0,c1 from t14;
--replace_column 2 time
select c0,c1 from t15;

--echo case 7: function MERGING_FROZEN_TIME() system function test
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(c1 int primary key, c2 timestamp) expire_info (c2<merging_frozen_time());
insert into t1 values(1, now());
insert into t1 values(2, now());
insert into t1 values(3, now());
insert into t1 values(4, date_add(now(), INTERVAL 5 DAY));
insert into t1 values(5, date_add(now(), INTERVAL 6 DAY));
--replace_column 2 time
select c1, c2 from t1;
--echo merge happens
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
--real_sleep 5
--replace_column 2 time
select c1, c2 from t1;

#分开删除主要防止ms 超时
drop table t1,t2,t3,t4,t5;
drop table t6,t7,t8,t9,t10;
drop table t11,t12,t13,t14,t15;
--echo case 8:some expr with merging_frozen_time
--disable_warnings
drop table if exists t16;
--enable_warnings
create table t16(c0 int primary key,c1 timestamp) EXPIRE_INFO (c1 < date_add(merging_frozen_time(),interval 30 second));
--error 5113 
select merging_frozen_time();
insert into t16 values(1, now());
insert into t16 values(2, now());
insert into t16 values(3, now());
insert into t16 values(4, date_add(now(), INTERVAL 5 second ));
insert into t16 values(5, date_add(now(), INTERVAL 6 second ));
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
--replace_column 2 time
select * from t16;
insert into t16 values(7, date_add(now(), INTERVAL 35 second ));
insert into t16 values(8, date_add(now(), INTERVAL 30 second ));
insert into t16 values(9, date_add(now(), INTERVAL 32 second ));
insert into t16 values(10, date_add(now(), INTERVAL 32 DAY ));
insert into t16 values(11, date_add(now(), INTERVAL -32 DAY ));
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
--replace_column 2 time
select * from t16;
alter table t16 set expire_info (c0>1);
sleep 1;
insert into t16 values(17, date_add(now(), INTERVAL 35 second ));
insert into t16 values(8, date_add(now(), INTERVAL 30 second ));
insert into t16 values(11, date_add(now(), INTERVAL 32 second ));
insert into t16 values(-9, date_add(now(), INTERVAL 32 second ));
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
--replace_column 2 time
select * from t16;
alter table t16 set expire_info (c0<1 or c1 < date_add(merging_frozen_time(),interval -1 HOUR));
sleep 1;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t16;
--error 1064
alter table t16 set expire_info (0<1);
alter table t16 set expire_info (0<1 or c1 < date_add(merging_frozen_time(),interval -1 HOUR));
sleep 1;
alter table t16 set expire_info (c0<1 or  c1 < date_add(merging_frozen_time(),interval -1 HOUR));
sleep 1;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t16;
insert into t16 values(19, date_add(now(), INTERVAL -1 hour ));
insert into t16 values(18, date_add(now(), INTERVAL 1 hour ));
insert into t16 values(-18, date_add(now(), INTERVAL 1 hour ));
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
--replace_column 2 time
select * from t16;
alter table t16 set expire_info (NULL);
sleep 1;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t16;
insert into t16 values(28, date_add(now(), INTERVAL 1 hour ));
insert into t16 values(29, date_add(now(), INTERVAL 1 hour ));
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
--replace_column 2 time
select * from t16;
alter table t16 set expire_info ( c1 < date_add(merging_frozen_time(),interval -1 minute));
sleep 1;
insert into t16 values(39, date_add(now(), INTERVAL 1 minute ));
insert into t16 values(38, date_add(now(), INTERVAL 1 minute ));
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
select c0 from t16;
update t16 set c0 =100 where c0=29;
select c0 from t16;
alter table t16 set expire_info ( date_add(c1,interval -1 minute)<merging_frozen_time());
sleep 2;
insert into t16 values(40, date_add(now(), INTERVAL -2 minute ));
insert into t16 values(41, date_add(now(), INTERVAL -2 minute ));
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
select c0 from t16;

##case 9:expire info fro datetime default now()
--disable_warnings
drop table if exists t17;
--enable_warnings
create table t17( a int primary key,c16 datetime default now(),c17 datetime default now())expire_info (c17<merging_frozen_time());
insert into t17(a) values(1),(2),(3),(4),(5),(6);
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
--replace_column 2 time 3 time
select * from t17;
alter table t17 set expire_info (c17>merging_frozen_time());
sleep 1;
insert into t17(a) values(1),(2),(3),(4),(5),(6);
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
--replace_column 2 time 3 time
select * from t17;
sleep 5;
select a from t17;
update t17 set a=11 where a=1;
select a from t17;
##case 10:usec time
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(c1 int primary key, c2 int);
alter table t1 set expire_info (c2>0);
sleep 2;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;
drop table t1;

--disable_warnings
drop table if exists test;
--enable_warnings
create table test(a int,b int,c datetime primary key) expire_info (a>time_to_usec(merging_frozen_time()));
insert into test values(1,1,'2014-08-21 15:00:00');
insert into test values(2,2,'2014-08-20 13:00:00');
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
select a,b from test;

