--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: zhanyue.zzy
#owner group: sql1

####case:建唯一索引之后，在第一合并之后插入数据，再进行第二次合并
--source mysql_test/include/index_quick_major.inc
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1 (a int, b int primary key);
create unique index idx1 on t1(a);
--source mysql_test/include/check_all_idx_ok.inc
--disable_query_log
--let $loop=1000
while  ($loop)
{
  eval insert into t1 values($loop,$loop);
  dec $loop;
}
--enable_query_log
--source mysql_test/include/check_all_idx_ok.inc
select count(*) from t1;
####case: drop unique index,after insert same data
drop index idx1 on t1;
sleep 10;
--disable_query_log
--let $loop=1000
while  ($loop)
{
  eval insert into t1 values($loop,$loop+1001);
  dec $loop;
}
--enable_query_log
select count(*) from t1;
--error 1062
insert into t1 values(1,1);
