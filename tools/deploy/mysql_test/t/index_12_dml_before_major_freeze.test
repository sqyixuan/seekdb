--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: yibo.tyf
#owner group: sql1

####
--disable_query_log
--source mysql_test/include/index_quick_major.inc
--real_sleep 1
--disable_warnings
drop table if exists t1;
--enable_warnings
--enable_query_log

#drop table if exist t1
create table t1(c1 int primary key, c2 varchar(1024), c3 int, c4  timestamp(6) default "2012-01-01 12:00:00");

--disable_query_log
let $i = 3000;
while($i>0)
{
    eval insert into t1(c1,c2,c3) values($i, 'a', $i);
    dec $i;
}

let $i = 1000;
while($i>0)
{
    eval replace into t1 values($i, 'b', $i+1,'2013-12-10 00:00:00');
    dec $i;
}

let $i = 2000;
while($i>1000)
{
    eval update t1 set c3=c3+1, c4='2013-12-10 01:01:01' where c1=$i;
    dec $i;
}

let $i = 3000;
while($i>2000)
{
    eval delete from t1 where c1=$i;
    dec $i;
}

let $i = 4000;
while($i>3000)
{
    eval insert into t1 values($i,'c', $i, '2013-12-10 02:02:02');
    dec $i;
}
--enable_query_log

####CASE1: dml table before major_freeze
create index i1 on t1(c2) storing(c3,c4);
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
--source mysql_test/include/check_all_idx_ok.inc

select /*+ index(t1 i1) */ c1,c2,c3,c4 from t1 where c2='a' and c3 > 1000 limit 5;
select /*+ index(t1 primary) */ c1,c2,c3,c4 from t1 where c1 > 1000 limit 6;
select count(*) from t1 where c3 > 3000;
select count(*) from t1 where c1 > 0;

drop table t1;


