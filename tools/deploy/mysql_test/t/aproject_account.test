select
'' as mini_account_no,
'' as account_type,
'156' as currency,
'' as balance,
'' as status,
'' as system_amount,
'' as gmt_create,
'' as gmt_modified,
'' as previous_trans_date,
'' as gmt_last_trans,
      category_code,
'' as recon_inst,
'' as migration_status,
sum(
     decode(date_format(gmt_last_trans, '%Y%m%d'),'20141021',previous_balance, balance)
   ) previous_balance
from mini_account
     where substr(mini_account_no,7,2)='AC' and category_code in (1,3,4,5,6)
--sorted_result
     group by category_code;

select category_code ,decode(date_format(gmt_last_trans, '%Y%m%d'),'20141021',previous_balance, balance) previous_balance from mini_account where substr(mini_account_no,7,2)='AC' and category_code in (1,3,4,5,6);

