select * from
(
  select T1.* from
  (
    select id, regist_file_id, detail_file_path, status, table_suffix, inst_date, gmt_create, gmt_modified
    from IST_INCOME_FILE_DETAIL
    where gmt_create >= '2013-12-12 15:00:01' and status = 'S' and table_suffix = 'trade' order by inst_date
  )T1
)T2 limit 4;



--disable_warnings
drop table if exists mini_account;
--enable_warnings
create table mini_account
(
  mini_account_no  varchar(28),
  account_type  varchar(10),
  currency  varchar(10),
  balance  int,
  previous_balance  int,
  status  varchar(10),
  system_amount  int,
  gmt_create  TIMESTAMP(6) default "2012-01-01 12:00:00",
  gmt_modified  TIMESTAMP(6) default "2012-01-01 12:00:00",
  previous_trans_date  TIMESTAMP(6) default "2012-01-01 12:00:00",
  gmt_last_trans  TIMESTAMP(6) default "2012-01-01 12:00:00",
  category_code  int,
  recon_inst  int,
  migration_status  int,
  primary key (mini_account_no)
);

