--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

#owner: linlin.xll
#owner group: SQL1
#description: test elimination of not
#
#Test negation elimination
#
#tags: funcs

--result_format 4

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1(col1 bool, col2 tinyint, col3 smallint, col4 MEDIUMINT, col5 int,
                col6 BIGINT, col7 DECIMAL, col8 FLOAT, col9 datetime, col10 time,
                col11 varchar(20), col12 varbinary(21), col13 char, col14 BINARY);

insert into t1 values(NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL);
insert into t1 values(1, 1, 1, 1, 1, 1, 1, 1, '1970-01-02', 1, 1, 1, 1, 1);
insert into t1 values(0, 0, 0, 0, 0, 0, 0, 0, '1970-01-01', 0, 0, 0, 0, 0);

select col1, not(not(col1)) from t1;
select col2, not(not(col2)) from t1;
select col3, not(not(col3)) from t1;
select col4, not(not(col4)) from t1;
select col5, not(not(col5)) from t1;
select col6, not(not(col6)) from t1;
select col7, not(not(col7)) from t1;
select col8, not(not(col8)) from t1;
select col9, not(not(col9)) from t1;
select col10, not(not(col10)) from t1;
select col11, not(not(col11)) from t1;
select col12, not(not(col12)) from t1;
select col13, not(not(col13)) from t1;
select col14, not(not(col14)) from t1;

select col1, not(not(col1)) from t1 where not(not(col1));
select col2, not(not(col2)) from t1 where not(not(col2));
select col3, not(not(col3)) from t1 where not(not(col3));
select col4, not(not(col4)) from t1 where not(not(col4));
select col5, not(not(col5)) from t1 where not(not(col5));
select col6, not(not(col6)) from t1 where not(not(col6));
select col7, not(not(col7)) from t1 where not(not(col7));
select col8, not(not(col8)) from t1 where not(not(col8));
select col9, not(not(col9)) from t1 where not(not(col9));
select col10, not(not(col10)) from t1 where not(not(col10));
select col11, not(not(col11)) from t1 where not(not(col11));
select col12, not(not(col12)) from t1 where not(not(col12));
select col13, not(not(col13)) from t1 where not(not(col13));
select col14, not(not(col14)) from t1 where not(not(col14));

drop table t1;

