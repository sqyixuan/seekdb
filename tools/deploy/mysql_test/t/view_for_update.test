#owner:link.zt
#owner group: SQL1
#description: table in generated table not locked in MySQL. But old version OceanBase may locked the table as rewrite.
#And view if mergable, as in MySQL, you can update or insert date to the view. MySQL also locked the view(main_select_tables in view). But in OceanBase, view not support update or insert, so not locked the view.
#If you want to change this action, tell me(link.zt). I add for_update variable in TableItem, you can change the action in resolver.

--disable_warnings
drop table if exists t1, t2;
drop view if exists t_v;
--enable_warnings
--enable_query_log
create table t1(c1 int primary key);
insert into t1 values(1), (2);

create table t2(c1 int primary key);
insert into t2 values(1), (2);

create view t_v as select * from t1;

connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn2,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn1;
begin;
select * from t_v for update;

connection conn2;
begin;
select * from t1 for update;
commit;

connection conn1;
commit;

begin;
select * from (select * from t1) ta for update;

connection conn2;
begin;
select * from t1 for update;
commit;


connection conn1;
commit;

begin;
select * from t1 for update;


connection conn2;
begin;
--error 1205,4012
select * from t1 for update wait 0.1;
--error 1205,4012
select * from t2 join t1 on t1.c1 = t2.c1 for update wait 0.1;
commit;

connection conn1;
commit;

drop table t1, t2;
drop view t_v;
