--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: bin.lb
# owner group: SQL2
# tags: meta
# description:
#

--disable_warnings
--enable_warnings
let $cnt=405;

while($cnt)
{

  eval  create table tt_$cnt (pk int primary key, c1 int,c3 decimal(5,2),c4 numeric default 1.11,c5 varchar(20));
  dec $cnt;
}

let $cnt=1;

while($cnt<=405)
{

  eval alter table tt_$cnt  add column v6 varchar(50);
  eval alter table tt_$cnt  drop column v6;
  inc $cnt;
}

let $cnt=205;
while($cnt)
{

  eval alter table tt_$cnt  add column v7 varchar(50);
  dec $cnt;
}

let $cnt=404;

while($cnt)
{

  eval alter table tt_$cnt  add column v8 varchar(50);
  eval alter table tt_$cnt  drop column v8;
  dec $cnt;
}

let $cnt=205;
while($cnt)
{

  eval alter table tt_$cnt  add column v9 varchar(50);
  dec $cnt;
}


let $cnt=404;
while($cnt)
{

  eval drop table tt_$cnt;
  dec $cnt;
}
sleep 3;

--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table  tt_405;
drop table tt_405;
