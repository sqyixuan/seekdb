#owner: link.zt
#owner group: SQL1
--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(pk int primary key, c1 int);
connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn2,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);

connection conn1;
set autocommit=0;

connection conn2;
set autocommit=0;

connection conn1;
insert into t1 values(1,1);

connection conn2;
update t1 set c1=c1+1 where pk=1 when row_count(insert into t1 values(2,2))=1;
select * from t1;
update t1 set c1=c1+2 where pk=3 when row_count(insert into t1 values(0,0))=1;
select * from t1;

connection conn1;
commit;
connection conn2;
commit;

#####test :addd update/delete  limit 
select * from t1;
connection conn1;
set autocommit=0;
update t1 set c1=c1+1 where pk>=1 limit 1 when row_count(insert into t1 values(3,3))=1;
select * from t1;
update t1 set c1=c1+1 where pk>=1 limit 2 when row_count(insert into t1 values(6,6))=1;
select * from t1;
update t1 set c1=c1+1 where pk>=1 order by c1  limit 2 when row_count(insert into t1 values(26,26))=1;
select * from t1;
update t1 set c1=c1+1 where pk>=1 order by c1 asc  limit 2 when row_count(insert into t1 values(7,7))=1;
select * from t1;
update t1 set c1=c1+1 where pk>=1 order by c1 desc  limit 2 when row_count(insert into t1 values(8,8))=1;
select * from t1;
--error 1062
delete from t1  where pk>=1 limit 2 when row_count(insert into t1 values(6,6))=1;
select * from t1;
delete from t1  where pk>=1 order by c1 asc limit 2 when row_count(insert into t1 values(16,16))=1;
select * from t1;
delete from  t1  where pk>=1 limit 10 when row_count(insert into t1 values(17,17))=1;
select * from t1;


commit;
select * from t1;
