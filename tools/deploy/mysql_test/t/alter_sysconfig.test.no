#let $RS_IP = query_get_value(SELECT * FROM __all_server where svr_type= 'rootserver',svr_ip, 1);
#let $RS_PORT = query_get_value(SELECT * FROM __all_server where svr_type= 'rootserver', svr_port, 1);

#Set balance_tolerance_count=1 by ip and port
--disable_query_log
eval ALTER SYSTEM SET balance_tolerance_count=1 SERVER_TYPE = ROOTSERVER SERVER_IP= '$RS0_IP' SERVER_PORT = $RS0_PORT;
--enable_query_log
sleep 1;
let $balance_tolerance_count = query_get_value(show parameters like 'balance_tolerance_count', value, 1);
if ($balance_tolerance_count == 1)
{
--echo ok
}

#Set balance_tolerance_count=2 by cluster id
--disable_query_log
eval ALTER SYSTEM SET balance_tolerance_count=2 SERVER_TYPE = ROOTSERVER CLUSTER=0;
--enable_query_log
sleep 1;
let $balance_tolerance_count = query_get_value(show parameters like 'balance_tolerance_count', value, 1);
if ($balance_tolerance_count == 2)
{
--echo ok
}

#Set balance_tolerance_count=3 by no condition
--disable_query_log
ALTER SYSTEM SET balance_tolerance_count=3 SERVER_TYPE = ROOTSERVER;
--enable_query_log
sleep 1;
let $balance_tolerance_count = query_get_value(show parameters like 'balance_tolerance_count', value, 1);
if ($balance_tolerance_count == 3)
{
--echo ok
}

#Set balance_tolerance_count=2 by error port
inc $RS0_PORT;
--disable_query_log
eval ALTER SYSTEM SET balance_tolerance_count=1 SERVER_TYPE = ROOTSERVER SERVER_IP= '0.0.0.0' SERVER_PORT = $RS0_PORT;
--enable_query_log
sleep 1;
let $balance_tolerance_count = query_get_value(show parameters like 'balance_tolerance_count', value, 1);
if ($balance_tolerance_count != 2)
{
--echo ok
}
  
