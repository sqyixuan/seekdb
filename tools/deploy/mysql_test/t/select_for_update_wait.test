--disable_warnings
drop table if exists testalias;
--enable_warnings
create table testalias(a int primary key,b varchar(20));
let $1=50;
disable_query_log;
while ($1)
{
 eval insert into testalias(a, b) values($1, 'abcd');
 dec $1;
}
select * from  testalias  for update wait 1;
select * from  testalias  a  for update wait 1;
select * from  testalias  a where a=10  for update wait 1;
select * from  testalias  a where a>=10 and a<=20  for update wait 1;
update testalias set a=1001 where a=15;
