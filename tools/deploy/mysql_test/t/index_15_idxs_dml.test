--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: yibo.tyf
#owner group: sql1

####TITLE:多张索引表，dml
####
set ob_enable_index_direct_select=1;
connect (my_obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection default;

--disable_query_log
--source mysql_test/include/index_quick_major.inc
--real_sleep 1
--disable_warnings
drop table if exists t1,t2;
--enable_warnings
--enable_query_log

create table t1(pk1 int, pk2 int, a int, b int, c int, primary key(pk1, pk2));
create table t2(pk1 int, nonpk int, a int, b int, c int, primary key(pk1));

create index i1 on t1(a) storing(c);
create index i2 on t1(b);
create index i3 on t1(c);
create index i4 on t1(a,b);

create index i1 on t2(a) storing(c);
create index i2 on t2(b);
create index i3 on t2(c);
create index i4 on t2(a,b);

let $t_db=oceanbase.__all_database;
let $db_id = query_get_value(select database_id from \$t_db where database_name='test', database_id, 1);

let $idx11 = query_get_value(select a.table_name from oceanbase.__all_table as a inner join (select * from oceanbase.__all_table where table_name='t1' and database_id=$db_id) b on a.data_table_id=b.table_id order by a.table_id, table_name, 1);
let $idx12 = query_get_value(select a.table_name from oceanbase.__all_table as a inner join (select * from oceanbase.__all_table where table_name='t1' and database_id=$db_id) b on a.data_table_id=b.table_id order by a.table_id, table_name, 2);
let $idx13 = query_get_value(select a.table_name from oceanbase.__all_table as a inner join (select * from oceanbase.__all_table where table_name='t1' and database_id=$db_id) b on a.data_table_id=b.table_id order by a.table_id, table_name, 3);
let $idx14 = query_get_value(select a.table_name from oceanbase.__all_table as a inner join (select * from oceanbase.__all_table where table_name='t1' and database_id=$db_id) b on a.data_table_id=b.table_id order by a.table_id, table_name, 4);

let $idx21 = query_get_value(select a.table_name from oceanbase.__all_table as a inner join (select * from oceanbase.__all_table where table_name='t2' and database_id=$db_id) b on a.data_table_id=b.table_id order by a.table_id, table_name, 1);
let $idx22 = query_get_value(select a.table_name from oceanbase.__all_table as a inner join (select * from oceanbase.__all_table where table_name='t2' and database_id=$db_id) b on a.data_table_id=b.table_id order by a.table_id, table_name, 2);
let $idx23 = query_get_value(select a.table_name from oceanbase.__all_table as a inner join (select * from oceanbase.__all_table where table_name='t2' and database_id=$db_id) b on a.data_table_id=b.table_id order by a.table_id, table_name, 3);
let $idx24 = query_get_value(select a.table_name from oceanbase.__all_table as a inner join (select * from oceanbase.__all_table where table_name='t2' and database_id=$db_id) b on a.data_table_id=b.table_id order by a.table_id, table_name, 4);

connection default;


--source mysql_test/include/check_all_idx_ok.inc

###############multi rowkeys
####CASE: insert
insert into t1 values(1,1,1,1,1),(1,2,1,1,1);
insert into t1 values(1,3,2,1,1),(1,4,2,1,1);
insert into t1 values(2,5,3,1,1),(2,6,3,1,1);
insert into t1 values(2,7,4,1,1),(2,8,4,1,1);

####CASE: one of rowkeys, update
--echo CASE:
update t1 set a=a+1,b=b+1,c=c+1 where pk1 = 1;
select * from t1;

--disable_query_log
eval select * from $idx11;
eval select * from $idx12;
eval select * from $idx13;
eval select * from $idx14;
--enable_query_log


####CASE:replace
replace into t1 values(1,1,1,1,1),(1,2,1,1,1),(1,3,2,1,1),(1,4,2,1,1),(2,5,3,1,1),(2,6,3,1,1),(2,7,4,1,1),(2,8,4,1,1);
select * from t1;
--disable_query_log
eval select * from $idx11;
eval select * from $idx12;
eval select * from $idx13;
eval select * from $idx14;
--enable_query_log

####CASE:one of rowkeys, delete
delete from t1 where pk1 = 1;
select * from t1;
--disable_query_log
eval select * from $idx11;
eval select * from $idx12;
eval select * from $idx13;
eval select * from $idx14;
--enable_query_log

#drop table t1;

###############single rowkeys
####CASE: insert
insert into t2 values(1,1,1,1,1),(2,2,1,1,1);
insert into t2 values(3,3,2,1,1),(4,4,2,1,1);
insert into t2 values(5,5,3,1,1),(6,6,3,1,1);
insert into t2 values(7,7,4,1,1),(8,8,4,1,1);

####CASE: update
--echo CASE:
update t2 set a=a+1,b=b+1,c=c+1 where pk1 = 1;
select * from t2;
--disable_query_log
eval select * from $idx21;
eval select * from $idx22;
eval select * from $idx23;
eval select * from $idx24;
--enable_query_log


####CASE:replace
replace into t2 values(1,1,1,1,1),(2,2,1,1,1),(3,3,2,1,1),(4,4,2,1,1),(5,5,3,1,1),(6,6,3,1,1),(7,7,4,1,1),(8,8,4,1,1);
select * from t2;
--disable_query_log
eval select * from $idx21;
eval select * from $idx22;
eval select * from $idx23;
eval select * from $idx24;
--enable_query_log

####CASE:delete
delete from t2 where pk1 = 1;
select * from t2;
--disable_query_log
eval select * from $idx21;
eval select * from $idx22;
eval select * from $idx23;
eval select * from $idx24;
--enable_query_log

#drop table t2;
set ob_enable_index_direct_select=0;
