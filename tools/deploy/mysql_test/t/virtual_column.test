--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: yuchen.wyc
# owner group: SQL1
# tags: ddl, alter
--result_format 4
--disable_query_log
--disable_result_log
--source mysql_test/include/index_quick_major.inc
--enable_query_log
--enable_result_log

--disable_warnings
drop table if exists t, t1;
--enable_warnings

set sql_mode=PAD_CHAR_TO_FULL_LENGTH;
create table t(pk int primary key, a char(5));
insert into t values(1,'a');
alter table t add column b char(10) as(concat(a, '1'));
alter table t add column c char(10) as(concat(a, '2'));
alter table t add column d char(10);
alter table t add column e char(10);
alter table t add column f char(10) as(concat(a, '3'));
alter table t add column g char(10) as(concat(a, '4'));
alter table t add column h char(10) as(concat(a, '5'));
alter table t add column i char(10);
alter table t add column j char(10) as(concat(a, '6'));
alter table t add column k char(10);
alter table t add column l char(10);
alter table t add column m char(10) as(concat(a, '7'));

select * from t;
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
select * from t;
drop table t;
