--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: bin.lb
# owner group: SQL2
# tags: ddl
# description:
#
#--disable_abort_on_error
--disable_query_log
--source mysql_test/include/index_quick_major.inc
sleep 2;
--enable_query_log

--disable_warnings
drop table if exists t1;
--enable_warnings
--let $loop=3

while($loop)
{
sleep 5;
#
### 100 columns
###
#
--let $head = create table t1(pk int primary key
--let $sql =
--let $column=100

--let $x=, c
--let $y= varchar(20)
while($column)
{

    --let $sql=$sql$x$column $y
    dec $column;
}
--let $z=)
eval $head$sql$z;
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
let $a=1000;
--disable_query_log
while($a)
{
   eval insert into t1(pk,c1) values($a,'$a');
   dec $a;
}
--enable_query_log

--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
select c1 from t1;
select * from t1;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;
drop table t1;

sleep 5;


#
### 512 columns will succeed
###
#
--let $head = create table t1(pk int primary key
--let $sql =
--let $column=511

--let $x=, c
--let $y= varchar(20)
while($column)
{

    --let $sql=$sql$x$column $y
    dec $column;
}
--let $z=)
eval $head$sql$z;
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc

let $a=1000;
--disable_query_log
while($a)
{
   eval insert into t1(pk,c1) values($a,'$a');
   dec $a;
}
--enable_query_log

--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc

select c1 from t1;
select * from t1;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;
drop table t1;
sleep 5;


#
### 513 columns will fail
###
#
--let $head = create table t1(pk int primary key
--let $sql =
--let $column=512

--let $x=, c
--let $y= varchar(20)
while($column)
{

    --let $sql=$sql$x$column $y
    dec $column;
}
--let $z=)
--error 1117 
eval $head$sql$z;
--error 1146
--source mysql_test/include/show_create_table_old_version.inc
--error 1146
show create table t1;
--disable_warnings
drop table if exists t1;
--enable_warnings

dec $loop;
}
--disable_warnings
drop table if exists t1;
--enable_warnings
