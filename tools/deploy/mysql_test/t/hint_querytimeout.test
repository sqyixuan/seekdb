--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: link.zt
#owner group: sql1

connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);

--disable_warnings
drop table if exists hint_querytimeout_table;
--enable_warnings
create table hint_querytimeout_table(pk int primary key);
insert into hint_querytimeout_table values (1),(2),(3);

--error SHY000,S25000
select /*+ QUERY_TIMEOUT (1) */ count(*) from hint_querytimeout_table;

set ob_query_timeout=1500000;
--error SHY000,S25000
select /*+ QUERY_TIMEOUT (100) */ count(*) from hint_querytimeout_table;
drop table hint_querytimeout_table;
##test invalid hint
select /*+ CLIENT_VERSION 1.1.1 */ 1;
select /*+ mysql_driver 1.1.1 */ 1;
select /*+ adb 1.1.1fsdafasdf */ 1;
