--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: zhenjiang.xzj
#owner group: storage
#description: test unique index checking

--disable_warnings
drop table if exists t;
--enable_warnings
create table t (c1 int, c2 int, c3 int, c4 int, c5 int, primary key(c1, c2, c3));

set ob_enable_index_direct_select=1;

--source mysql_test/include/index_quick_major.inc


connect (obsys1,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys1;
disconnect obsys1;
connection default;

create unique index t_c4 on t (c4, c5);
--source mysql_test/include/check_all_idx_ok.inc
insert into t values(1,1,1,2,2);
insert into t values(3,2,2,NULL,2);
insert into t values(5,2,2,NULL,2);
insert into t values(4,2,2,NULL,NULL);
insert into t values(6,2,2,NULL,NULL);
--error 1062
insert into t values(7,2,2,2,2);
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
insert into t values(8,2,2,NULL,NULL);
--error 1062
insert into t values(9,2,2,2,2);
