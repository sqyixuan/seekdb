# owner: muwei.ym 
# owner group: STORAGE
# description: issue/16264643

--disable_warnings
drop table if exists test_meta_table_data_size;
--enable_warnings
create table test_meta_table_data_size (c1 int primary key, c2 int, c3 varchar(2048), index i2 (c2)) compression='none';

--disable_query_log
--disable_result_log

--let $count = 0
while($count < 1001)
{
  --let $stmt=INSERT INTO test_meta_table_data_size VALUES ($count, $count, repeat('a', 2048))
  eval $stmt;
  inc $count;
}

connect (obsys1,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys1;
let $__table_id__ = query_get_value(select table_id from oceanbase.__all_virtual_table where table_name = 'test_meta_table_data_size', table_id, 1);
let $__tenant_id__ = query_get_value(select tenant_id from oceanbase.__all_virtual_table where table_name = 'test_meta_table_data_size', tenant_id, 1);
let $__tablet_id__ = query_get_value(select tablet_id from oceanbase.__all_virtual_tablet_to_ls where table_id = (select table_id from oceanbase.__all_virtual_table where table_name = 'test_meta_table_data_size') limit 1, tablet_id, 1);
disconnect obsys1;
connection default;

--enable_query_log
--enable_result_log

--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc

--disable_query_log
connect (obsys1,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys1;
let $data_size = query_get_value(select data_size from oceanbase.__all_virtual_tablet_meta_table where tablet_id = $__tablet_id__ and tenant_id = $__tenant_id__ limit 1, data_size, 1);
--enable_query_log
if ($data_size != 0)
{
  --echo success to update meta table
}
disconnect obsys1;
connection default;
--enable_query_log

update test_meta_table_data_size set c3 = NULL where c1 = 1000;

--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc

--disable_query_log
connect (obsys1,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys1;
let $cur_data_size = query_get_value(select data_size from oceanbase.__all_virtual_tablet_meta_table where tablet_id = $__tablet_id__ and tenant_id = $__tenant_id__ limit 1, data_size, 1);
--enable_query_log
if ($data_size != $cur_data_size)
{
  --echo success to update meta table
}
disconnect obsys1;
connection default;
--enable_query_log

--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc

--disable_query_log
connect (obsys1,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys1;
let $new_data_size = query_get_value(select data_size from oceanbase.__all_virtual_tablet_meta_table where tablet_id = $__tablet_id__ and tenant_id = $__tenant_id__ limit 1, data_size, 1);
--enable_query_log
if ($new_data_size == $cur_data_size)
{
  --echo success to update meta table
}
connection default;
--enable_query_log
