--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: yuchen.wyc
# owner group: sql4
# description: foobar
####TITEL: non_rowkey update and delete using scan
--disable_warnings
drop table if exists t1;
--enable_warnings

connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (trx1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (trx2,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);

connection conn1;
create table t1(pk1 int, pk2 int, c1 int, c2 int, primary key(pk1,pk2));
insert into t1(pk1,pk2,c1,c2) values(1,1,1,1);
insert into t1(pk1,pk2,c1,c2) values(1,2,2,1);
insert into t1(pk1,pk2,c1,c2) values(2,3,3,1);
insert into t1(pk1,pk2,c1,c2) values(2,4,4,1);
insert into t1(pk1,pk2,c1,c2) values(3,5,5,1);
insert into t1(pk1,pk2,c1,c2) values(3,6,6,1);
insert into t1(pk1,pk2,c1,c2) values(4,7,7,1);
insert into t1(pk1,pk2,c1,c2) values(4,8,8,1);
select * from t1;

####CASE: =, >, <, just using one of rowkeys
connection trx1;
set autocommit=0;
delete from t1 where pk1=1;
select * from t1;
update t1 set c2=c2+1 where pk1>=1 and pk1<=2;
select * from t1;

connection trx2;
set autocommit=0;
select * from t1;
--error 1205,4012
update t1 set c2=c2+1 where pk1>0 and pk1<5;
select * from t1;
--error 1205,4012
delete from t1 where pk1>=1 and pk1<=4;
select * from t1;
update t1 set c2=c2+1 where pk1=3;
select * from t1;
update t1 set c2=c2+1 where pk1=4;
select * from t1;

connection trx1;
select * from t1;
--error 1205,4012
update t1 set c2=c2+1 where pk1>0 and pk1<5;
select * from t1;
--error 1205,4012
delete from t1 where pk1=3;
select * from t1;
commit;
select * from t1;
commit;

connection trx2;
select * from t1;
update t1 set c2=c2+1 where pk1>0 and pk1<5;
select * from t1;
delete from t1 where pk1=4;
select * from t1;
commit;
select * from t1;
commit;

####CASE: =, >, >=,  <,  <=, one of rowkeys + non_rowkey
connection conn1;
delete from t1;
insert into t1(pk1,pk2,c1,c2) values (1,1,1,1),(1,2,1,1),(1,3,2,1),(1,4,2,1),(2,5,3,1),(2,6,3,1),(2,7,4,1),(2,8,4,1);
select * from t1;

connection trx1;
delete from t1 where pk1=1 and c1=1;
select * from t1;
update t1 set c2=c2+1 where pk1=1 and c1<3;
select * from t1;

connection trx2;
--error 1205,4012
delete from t1 where pk1=1;
--error 1205,4012
delete from t1 where (pk1,c1)>=(1,1) and pk2>=1;
--error 1205,4012
update t1 set c2=c2+1 where pk1=1;
--error 1205,4012
update t1 set c2=c2+1 where (pk1,c1)>=(1,1) and (pk1,c1)<=(2,2);

update t1 set c2=c2+1 where pk1=2 and c1=3;
select * from t1;
delete from t1 where pk1=2 and c1=4;
select * from t1;

connection trx1;
select * from t1;
--error 1205,4012
delete from t1 where pk1=2 and c1=3;
--error 1205,4012
delete from t1 where pk1=2 and c1=4;
--error 1205,4012
update t1 set c2=c2+1 where pk1=2 and c1=3;
--error 1205,4012
update t1 set c2=c2+1 where pk1=2 and c1=4;
--error 1205,4012
insert into t1(pk1,pk2,c1,c2) values (2,5,3,10);
--error 1205,4012
replace into t1(pk1,pk2,c1,c2) values (2,5,3,10);

insert into t1(pk1,pk2,c1,c2) values (2,9,3,1);
replace into t1(pk1,pk2,c1,c2) values (2,10,3,1);
select * from t1;
commit;
select * from t1;
commit;

connection trx2;
select * from t1;
commit;
select * from t1;
commit;

connection trx1;
set autocommit=1;
connection trx2;
set autocommit=1;
drop table t1;
