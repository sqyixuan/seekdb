--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: dachuan.sdc
#owner group: sql2
#description: new account name(username@hostname) 
# https://dev.mysql.com/doc/refman/5.7/en/account-names.html

--disable_warnings
drop table if exists t1,t2,t3,t4;
--enable_warnings

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);

connection obsys;
select user_name, host, passwd, is_locked from oceanbase.__all_virtual_user where user_name like "nu%" order by user_name;
connection default;


create user 'nu1'@'%' identified by 'pass1';
create user 'nu2'@"0.0.0.0/0.0.0.0" identified by 'pass2', `nu3`@`0.0.0.0/0` identified by 'pass3';
create user nu4@`%%%` identified by 'pass4', nu5@`192.168.1.__` identified by 'pass5';
connection obsys;
select user_name, host, passwd, is_locked from oceanbase.__all_virtual_user where user_name like "nu%" order by user_name;
connection default;
--real_sleep 1
set password for nu1 = password('new_password');
--error 1133
set password for nu2 = password('new_password');
--error 1133
set password for nu2@"0.0.0.0" = password('new_password');
set password for nu2@"0.0.0.0/0.0.0.0" = password('new_password');
alter user nu3@"0.0.0.0/0" IDENTIFIED BY 'new_password';
--error 1396
alter user nu4 account lock;
--real_sleep 1
alter user nu4@`%%%` account lock;
--real_sleep 1
connection obsys;
select user_name, host, passwd, is_locked from oceanbase.__all_virtual_user where user_name like "nu%" order by user_name;
connection default;

alter user nu5@`192.168.1.__` account unlock;
rename user nu1 to nu11;
--error 1396
rename user nu11 to nu11;
--error 1396
rename user nu2@"0.0.0.0/0.0.0.0" to nu3@"0.0.0.0/0";
rename user nu2@"0.0.0.0/0.0.0.0" to nu2@"0.0.0.0/0";
--real_sleep 1
connection obsys;
select user_name, host, passwd, is_locked from oceanbase.__all_virtual_user where user_name like "nu%" order by user_name;
connection default;


rename user nu11 to nu1;
rename user nu2@"0.0.0.0/0" to nu2@"0.0.0.0/0.0.0.0";
--real_sleep 1
--sorted_result
show grants for nu1;
grant select on *.* to nu1;
--real_sleep 1
--sorted_result
show grants for nu1;

--error 1133
show grants for nu2@`0.0.0.0/0`;
show grants for nu2@`0.0.0.0/0.0.0.0`;
grant select on oceanbase.* to nu2@"0.0.0.0/0.0.0.0";
--real_sleep 1
--sorted_result
show grants for nu2@`0.0.0.0/0.0.0.0`;

revoke select on oceanbase.* from nu2@"0.0.0.0/0.0.0.0";
--real_sleep 1
--sorted_result
show grants for nu2@`0.0.0.0/0.0.0.0`;


drop user nu1;
drop user nu2@'0.0.0.0/0.0.0.0', nu3@`0.0.0.0/0`, nu5@`192.168.1.__`;
--error 1396
drop user nu4;
drop user nu4@'%%%';

--real_sleep 1
connection obsys;
select user_name, host, passwd, is_locked from oceanbase.__all_virtual_user where user_name like "nu%" order by user_name;
connection default;
