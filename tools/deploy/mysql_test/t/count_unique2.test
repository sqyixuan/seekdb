--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

#owner: linlin.xll
#owner group: SQL1
#description:
#tags: distinct

--disable_warnings
drop table if exists t1;
--enable_warnings
#
create table t1(pk int primary key, n1 int, n2 int, s char(20), vs varchar(20), t varchar(256));
insert into t1 values (1,1,11, 'one','eleven', 'eleven'),
 (2,1,11, 'one','eleven', 'eleven'),
 (3,2,11, 'two','eleven', 'eleven'),
 (4,2,12, 'two','twevle', 'twelve'),
 (5,2,13, 'two','thirteen', 'foo'),
 (6,2,13, 'two','thirteen', 'foo'),
 (7,2,13, 'two','thirteen', 'bar'),
 (8,NULL,13, 'two','thirteen', 'bar'),
 (9,2,NULL, 'two','thirteen', 'bar'),
 (10,2,13, NULL,'thirteen', 'bar'),
 (11,2,13, 'two',NULL, 'bar'),
 (12,2,13, 'two','thirteen', NULL);
#
select unique n1 from t1;
select count(unique n1) from t1;
#
select unique n2 from t1;
select count(unique n2) from t1;
#
select unique s from t1;
select count(unique s) from t1;
#
select unique vs from t1;
select count(unique vs) from t1;
#
select unique t from t1;
select count(unique t) from t1;
#
select unique n1,n2 from t1;
select count(unique n1,n2) from t1;
#
select unique n1,s from t1;
select count(unique n1,s) from t1;
#
select unique s,n1,vs from t1;
select count(unique s,n1,vs) from t1;
#
select unique s,t from t1;
#select count(unique s,t) from t1;
#
select count(unique n1), count(unique n2) from t1;
#
--sorted_result
select count(unique n2), n1 from t1 group by n1;

--disable_warnings
drop table if exists a, b;
--enable_warnings
create table a(a1 int, a2 int, a3 int);
create table b(b1 int, b2 int);
insert into a value (1,22, 1), (1,22, 2), (3,44, 2),(1,55,4);
insert into b value (1,2),(3,4),(1,5);

select a1 from a where a2 > (select count(unique a1, b1) from b);
select count(*) from a;
select count(all *) from a;
select count(a1) from a;
select count(all a1) from a;
select count(1) from a;
select count(unique 1) from a;
--error 1064
select count(a1, a2) from a;
select count(unique a1) from a;
select count(unique a1, a2) from a;
select count(unique a1, a2, a3) from a;
select count(unique a1, null) from a;
select count(unique null, a1) from a;
select count(unique null, 1);
select count(unique 1, null);
insert into a value (1, null,2),(1, 2 ,null),(null, 1 ,2);
select count(*) from a;
select count(1) from a;
select count(unique 1) from a;

select a1 from a where "acd" > (select group_concat(unique a1, b1) from b);

--disable_warnings
drop table if exists a, b;
--enable_warnings
--disable_warnings
drop table if exists t1;
--enable_warnings
