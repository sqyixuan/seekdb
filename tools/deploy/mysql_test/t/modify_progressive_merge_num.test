--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner : zhenjiang.xzj
#owner group : storage
#tags: ddl

--disable_warnings
drop table if exists t1_modify_prog;
--enable_warnings
create table t1_modify_prog (c1 int, c2 int, c3 varchar(20), c4 varchar(20), c5 varchar(20) generated always as (substr(c3, 1, 10)) virtual, c6 varchar(20) generated always as (substr(c4, 1, 10)) stored , primary key(c1, c2));
insert into t1_modify_prog (c1, c2, c3, c4) values (1, 1, 'a', 'b');
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
# modify back to 0
alter system set enable_sys_table_ddl = true;
sleep 3;
set ob_query_timeout=1000000000000000;
alter tenant all set progressive_merge_num = 0;
sleep 3;
let $user_progressive_merge_num = query_get_value(select progressive_merge_num from oceanbase.__all_virtual_table where table_name = 't1_modify_prog', progressive_merge_num, 1);
echo $user_progressive_merge_num;
let $sys_progressive_merge_num = query_get_value(select progressive_merge_num from oceanbase.__all_virtual_table where table_name = '__all_column_history', progressive_merge_num, 1);
echo $sys_progressive_merge_num;
#test modify to 2
alter tenant sys set progressive_merge_num = 2;
sleep 3;
let $user_progressive_merge_num = query_get_value(select progressive_merge_num from oceanbase.__all_virtual_table where table_name = 't1_modify_prog', progressive_merge_num, 1);
echo $user_progressive_merge_num;
let $sys_progressive_merge_num = query_get_value(select progressive_merge_num from oceanbase.__all_virtual_table where table_name = '__all_column_history', progressive_merge_num, 1);
echo $sys_progressive_merge_num;
# modify to 0
alter tenant all set progressive_merge_num = 2;
sleep 3;
let $sys_progressive_merge_num = query_get_value(select progressive_merge_num from oceanbase.__all_virtual_table where table_name = '__all_column_history', progressive_merge_num, 1);
echo $sys_progressive_merge_num;
# modify back to 0
alter tenant all set progressive_merge_num = 0;
sleep 3;
let $user_progressive_merge_num = query_get_value(select progressive_merge_num from oceanbase.__all_virtual_table where table_name = 't1_modify_prog', progressive_merge_num, 1);
echo $user_progressive_merge_num;
let $sys_progressive_merge_num = query_get_value(select progressive_merge_num from oceanbase.__all_virtual_table where table_name = '__all_column_history', progressive_merge_num, 1);
echo $sys_progressive_merge_num;
let $table_id = query_get_value(select table_id from oceanbase.__all_virtual_table where table_name = 't1_modify_prog', table_id, 1);
disconnect obsys;
connection default;

drop table t1_modify_prog;
sleep 3;
# test table in recyclebin
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
set ob_query_timeout=1000000000000000;
alter tenant sys set progressive_merge_num = 2;
sleep 3;
let $user_progressive_merge_num = query_get_value(select progressive_merge_num from oceanbase.__all_virtual_table where table_id = '$table_id', progressive_merge_num, 1);
echo $user_progressive_merge_num;
