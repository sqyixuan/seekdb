--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: yuchen.wyc
# owner group: sql4
# description: range or 
--disable_warnings
drop table if exists t1;
--enable_warnings

connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (trx1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (trx2,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);

connection conn1;
create table t1(pk1 int, pk2 int, c1 int, c2 int, primary key(pk1,pk2));
insert into t1(pk1,pk2,c1,c2) values(1,1,1,1);
insert into t1(pk1,pk2,c1,c2) values(2,2,1,1);
insert into t1(pk1,pk2,c1,c2) values(3,3,1,1);
insert into t1(pk1,pk2,c1,c2) values(4,4,1,1);
insert into t1(pk1,pk2,c1,c2) values(5,5,1,1);
insert into t1(pk1,pk2,c1,c2) values(6,6,1,1);
insert into t1(pk1,pk2,c1,c2) values(7,7,1,1);
insert into t1(pk1,pk2,c1,c2) values(8,8,1,1);
select * from t1;

####CASE: trx1 read, trx2 write and select
connection trx1;
set autocommit=0;

connection trx2;
set autocommit=0;
delete from t1 where (pk1,pk2)=(5,5) or (pk1,pk2)=(6,6) or (pk1,pk2)=(7,8);
select * from t1;
update t1 set c1=2, c2=2 where (pk1,pk2)=(1,1) or (pk1,pk2)=(2,2) or (pk1,pk2)=(5,5) or (pk1,pk2)=(6,6);
select * from t1;

connection trx1;
select * from t1;

connection trx2;
update t1 set c1=c1+1, c2=c2+1 where (pk1,pk2)=(3,3) or (pk1,pk2)=(4,4);
select * from t1;
delete from t1 where (pk1,pk2)=(7,7) or (pk1,pk2)=(8,8);
select * from t1;
commit;
select * from t1;
commit;

connection trx1;
select * from t1;
commit;
select * from t1;
commit;

####CASE: both of trx1 and trx read and write, different rows
connection conn1;
replace into t1(pk1,pk2,c1,c2) values (1,1,1,1),(2,2,1,1),(3,3,1,1),(4,4,1,1),(5,5,1,1),(6,6,1,1),(7,7,1,1),(8,8,1,1);
select * from t1;

connection trx1;
update t1 set c1=2, c2=2 where (pk1,pk2)=(1,1) or (pk1,pk2)=(2,2) or (pk1,pk2)=(3,4);
select * from t1;
delete from t1 where (pk1,pk2)=(3,3) or (pk1,pk2)=(4,4);
select * from t1;

connection trx2;
update t1 set c1=c1+1, c2=c2+1 where (pk1,pk2)=(5,5) or (pk1,pk2)=(6,6);
select * from t1;
delete from t1 where (pk1,pk2)=(7,7) or (pk1,pk2)=(8,8);
select * from t1;
commit;
select * from t1;
commit;

connection trx1;
select * from t1;
commit;

####CASE: write with same rows, but trx2 has commit
connection conn1;
replace into t1(pk1,pk2,c1,c2) values (1,1,1,1),(2,2,1,1),(3,3,1,1),(4,4,1,1),(5,5,1,1),(6,6,1,1),(7,7,1,1),(8,8,1,1);
select * from t1;

connection trx1;

connection trx2;
update t1 set c1=c1+1, c2=c1+1 where (pk1,pk2)=(1,1) or (pk1,pk2)=(2,2) or (pk1,pk2)=(3,3) or (pk1,pk2)=(4,4);
select * from t1;
delete from t1 where (pk1,pk2)=(5,5) or (pk1,pk2)=(6,6);
select * from t1;
commit;

connection trx1;
update t1 set c1=c1+1, c2=c2+1 where (pk1,pk2)=(1,1) or (pk1,pk2)=(2,2) or (pk1,pk2)=(3,3) or (pk1,pk2)=(4,4);
update t1 set c1=c1+1, c2=c2+1 where (pk1,pk2)=(5,5) or (pk1,pk2)=(6,6) or (pk1,pk2)=(7,7) or (pk1,pk2)=(8,8);
select * from t1;
commit;
select * from t1;
commit;


####CASE: write with same rows, 5048
connection conn1;
replace into t1(pk1,pk2,c1,c2) values (1,1,1,1),(2,2,1,1),(3,3,1,1),(4,4,1,1),(5,5,1,1),(6,6,1,1),(7,7,1,1),(8,8,1,1);
select * from t1;

connection trx1;

connection trx2;
update t1 set c1=c1+1, c2=c2+1 where (pk1,pk2)=(1,1) or (pk1,pk2)=(2,2);
select * from t1;
delete from t1 where (pk1,pk2)=(3,3) or (pk1,pk2)=(4,4);
select * from t1;

connection trx1;
--error 1205,4012
update t1 set c1=c1+1, c2=c2+1 where
	(pk1,pk2)=(1,1) or (pk1,pk2)=(2,2) or (pk1,pk2)=(3,3) or (pk1,pk2)=(4,4) or
        (pk1,pk2)=(5,5) or (pk1,pk2)=(6,6) or (pk1,pk2)=(7,7) or (pk1,pk2)=(8,8);
select * from t1;
--error 1205,4012
delete from t1 where
	(pk1,pk2)=(1,1) or (pk1,pk2)=(2,2) or (pk1,pk2)=(3,3) or (pk1,pk2)=(4,4) or
        (pk1,pk2)=(5,5) or (pk1,pk2)=(6,6) or (pk1,pk2)=(7,7) or (pk1,pk2)=(8,8);
select * from t1;

update t1 set c1=c1+1, c2=c2+1 where (pk1,pk2)=(5,5) or (pk1,pk2)=(6,6);
select * from t1;
delete from t1 where (pk1,pk2)=(7,7) or (pk1,pk2)=(8,8);
select * from t1;

connection trx2;
--error 1205,4012
delete from t1 where (pk1,pk2)=(5,5) or (pk1,pk2)=(6,6);
select * from t1;
--error 1205,4012
delete from t1 where (pk1,pk2)=(7,7) or (pk1,pk2)=(8,8);
select * from t1;
commit;
select * from t1;
commit;

connection trx1;
select * from t1;
update t1 set c1=c1+1, c2=c2+1 where
	(pk1,pk2)=(1,1) or (pk1,pk2)=(2,2) or (pk1,pk2)=(3,3) or (pk1,pk2)=(4,4) or
        (pk1,pk2)=(5,5) or (pk1,pk2)=(6,6) or (pk1,pk2)=(7,7) or (pk1,pk2)=(8,8);
select * from t1;
commit;
select * from t1;
commit;
