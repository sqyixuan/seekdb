# owner: rongxuan.lc
# owner group: SQL3
# description: 本case是为了测试phy_plan的内存统计


--disable_warnings
drop tenant if exists tt1 force;
drop resource pool if exists pool1;
drop resource unit if exists box1;
--enable_warnings

let $cpu = 1;
let $memory = 1073741824;
let $min_memory = 536870912;
let $disk = 536870912;
let $iops = 100000;
let $session = 64;

eval create resource unit box1 max_cpu $cpu, max_memory $memory, max_iops $iops, max_disk_size $disk, max_session_num $session, MIN_CPU=1, MIN_MEMORY=$min_memory, MIN_IOPS=1;

let $zone_name=query_get_value(select zone from oceanbase.__all_zone where zone != '' limit 1, zone, 1);

--replace_column 1 create_time 2 modify_time 3 unit_config_id
select * from oceanbase.__all_unit_config where name='box1';

--disable_query_log
eval create resource pool pool1 unit = 'box1', unit_num = 1, zone_list=('$zone_name');
eval create tenant tt1 replica_num = 1, primary_zone='$zone_name', resource_pool_list=('pool1') set lower_case_table_names = 2;
--source mysql_test/include/check_tenant_sync.inc

let $tenant_id=query_get_value(select tenant_id from oceanbase.__all_tenant where tenant_name = 'tt1' limit 1, tenant_id, 1);
connect (conn_sys,$OBMYSQL_MS0,root@tt1,,*NO-ONE*,$OBMYSQL_PORT);
create database tt;
use tt;
create table test_plan(c1 int primary key, c2 int, c3 int, c4 int);
insert into test_plan values(1,1,1,1);
select * from test_plan;
use oceanbase;
select count(*) from V$OB_PLAN_CACHE_PLAN_STAT where statement like '%test_plan%';
use tt;
set ob_enable_plan_cache = false;
alter system flush plan cache;
use oceanbase;
select count(*) from V$OB_PLAN_CACHE_PLAN_STAT where statement like '%test_plan%';
connect (conn_sys2,$OBMYSQL_MS0,root,,*NO-ONE*,$OBMYSQL_PORT);
drop tenant if exists tt1 force;
drop resource pool if exists pool1;
drop resource unit if exists box1;
