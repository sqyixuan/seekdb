--disable_warnings
drop table if exists t1,t2;
--enable_warnings
#
create table t1 (c1 int, c2 int, c3 int, primary key(c1));
create table t2 (c1 int, c2 int, c3 int, primary key(c1));
#
replace into t1 values(1,1,1),(2,2,2),(3,3,3);
replace into t2 values(3,3,3),(4,4,4),(5,5,5);
#
select t11.c11 as c111 from (select c1 as c11, c2 from t1) t11 join t2 on t11.c2=t2.c2;
--sorted_result
select t11.c11 as c111 from (select c1 as c11, c2 from t1) t11 left join t2 on t11.c2=t2.c2;
--replace_regex /Plan signature: [0-9]*/Plan signature/
--disable_result_log
explain select t11.c11 as c111 from (select c1 as c11, c2 from t1) t11 left join t2 on t11.c2=t2.c2;
--enable_result_log
select t11.c11 as c111 from (select c1 as c11, c2 from t1) t11 right join t2 on t11.c2=t2.c2;
replace into t1 values(4,4,3),(5,5,4),(6,6,5);
--sorted_result
select t11.c11 as c111,t2.c1 from (select c1 as c11, c2 from t1) t11 left join t2 on t11.c2=t2.c2;
#alias for func
--disable_warnings
drop table if exists test;
--enable_warnings
create table test(a int,b varchar(40),c  timestamp(6) default "2012-01-01 12:00:00",d datetime(6),e float,primary key(a));
insert into test values(1,'abcd','1970-01-01 00:00:00','1970-12-01 00:00:00',1.35);
insert into test values(2,'abcd','1970-01-01 00:00:00','1970-12-01 00:00:00',1.35);
--replace_column 1 time
select current_timestamp() as b from test;
--replace_column 1 time
select current_timestamp() as b from test;
--replace_column 1 time
select now() as b from test;
select str_to_date('04 /30/2004', '%m /%d/%Y') as tm from test;
select str_to_date('04/30 /2004', '%m /%d /%Y') as tm from test;
select str_to_date('04/30/2004 ', '%m/%d/%Y ') as tm from test;
select concat(b,'abc') as te  from test;
select 'true' as found from test;
select distinct substring(b,1,3) as a from test order by a limit 10;
select distinct concat(b,b) as namn from test;
select distinct concat(b,b) as namn from test a;
select distinct concat(a.b,a.b) as namn from test a;
--replace_column 1 time
select date_add(now(),INTERVAL 5 DAY) as tm from test;
--replace_column 1 time
select date_add(current_timestamp(),INTERVAL 5 DAY) as tm from test;
--replace_column 1 time
select date_add(c,INTERVAL 5 DAY) as tm from test;
select date_add(d,INTERVAL 5 DAY) as tm from test;
--replace_column 1 time
select EXTRACT(DAY FROM NOW()) as a;
--replace_column 1 time
select now() as abcd;
--replace_column 1 time
select EXTRACT(DAY FROM NOW()) as a from test;
--replace_column 1 time
select EXTRACT(DAY FROM current_timestamp()) as a from test;
select STR_TO_DATE('2014-01-10', '%Y-%m-%d') as abcd;
select STR_TO_DATE('2014-01-10', '%Y-%m-%d') as abcd from test;
--replace_column 1 time
select DATE_FORMAT(now(), '%Y/%m/%D') as abcd;
--replace_column 1 time
select DATE_FORMAT(current_timestamp(), '%Y/%m/%D') as abcd;
--replace_column 1 time
select DATE_FORMAT(now(), '%Y/%m/%D') as abcd from test;
--replace_column 1 time
select DATE_FORMAT(current_timestamp(), '%Y/%m/%D') as abcd from test;
--replace_column 1 time
select time_to_usec(now()) as now from test;
--replace_column 1 time
select time_to_usec(current_timestamp()) as now from test;
--replace_column 1 time
select usec_to_time(time_to_usec(now())) as tm from test;
--replace_column 1 time
select usec_to_time(time_to_usec(current_timestamp())) as tm from test;
