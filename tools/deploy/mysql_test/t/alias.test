insert into a2 select a1.* as 'with_alias' from a1;
--error 1064
insert into a2 select a1.* as 'with_alias', rowkey_suffix as 'x', price as 'z' from a1;

--error 1064
insert into a2 select a1.* as 'with_alias' from a1;
