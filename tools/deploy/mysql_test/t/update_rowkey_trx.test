replace into t1 values(1,1,'a'),(2,2,'b'),(3,3,'c'),(4,4,'d'),(5,5,'e');
set autocommit=0;
update t1 set pk=11 where pk=1;

connection conn2;
set autocommit=0;
--error 1205,4012
update t1 set i1=2,v1='aa' where pk=1;

connection conn1;
rollback;
set autocommit=1;

connection conn2;
commit;
set autocommit=1;

select * from t1;

