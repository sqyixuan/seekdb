##conn1 conn2同时更新一行,conn1 commit,conn2 commit
connection conn1;
delete from t1 where pk<20;
replace into t1 values(1,1,'a'),(2,2,'b'),(3,3,'c'),(4,4,'d'),(5,5,'e');
connection conn1;
set autocommit=0;
send update t1 set pk=12 where pk=2;

connection conn2;
set autocommit=0;
--real_sleep 1
send update t1 set i1=22,v1='bb' where pk=2;

connection conn1;
reap;
commit;
set autocommit=1;

connection conn2;
reap;
commit;
set autocommit=1;
select * from t1;

##conn1 conn2同时更新一行,conn1 rollback,conn2 commit
connection conn1;
delete from t1 where pk<20;
replace into t1 values(1,1,'a'),(2,2,'b'),(3,3,'c'),(4,4,'d'),(5,5,'e');
connection conn1;
set autocommit=0;
send update t1 set pk=12 where pk=2;

connection conn2;
set autocommit=0;
sleep 1;
send update t1 set i1=22,v1='bb' where pk=2;

connection conn1;
reap;
rollback;
set autocommit=1;

connection conn2;
reap;
commit;
set autocommit=1;
select * from t1;

##conn1 update,conn2 delete，conn1提交后conn2使用更新后的值，提交
connection conn1;
delete from t1 where pk<20;
replace into t1 values(1,1,'a'),(2,2,'b'),(3,3,'c'),(4,4,'d'),(5,5,'e');
connection conn1;
set autocommit=0;
send update t1 set pk=12 where pk=2;

connection conn2;
set autocommit=0;
sleep 1;
--error 1205,4012
delete from t1 where pk=2;

connection conn1;
reap;
commit;
set autocommit=1;

connection conn2;
update t1 set i1=12,v1='12b' where pk=12;
commit;
set autocommit=1;
select * from t1;

##conn1 update,conn2 delete，conn1回滚后conn2使用更新后的值，提交
connection conn1;
delete from t1 where pk<20;
replace into t1 values(1,1,'a'),(2,2,'b'),(3,3,'c'),(4,4,'d'),(5,5,'e');
connection conn1;
set autocommit=0;
send update t1 set pk=12 where pk=2;

connection conn2;
set autocommit=0;
sleep 1;
--error 1205,4012
delete from t1 where pk=2;

connection conn1;
reap;
rollback;
set autocommit=1;

connection conn2;
update t1 set i1=12,v1='12b' where pk=12;
commit;
set autocommit=1;

select * from t1;

