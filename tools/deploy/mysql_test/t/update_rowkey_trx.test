send update t1 set pk=7 where pk=6 ;

connection conn2;
set autocommit=0;
sleep 1;
send insert into t1 values(6,6,'f');

connection conn1;
reap;
commit;
set autocommit=1;

connection conn2;
reap;
commit;
set autocommit=1;

select * from t1;

