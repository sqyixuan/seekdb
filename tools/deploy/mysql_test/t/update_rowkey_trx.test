--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: link.zt
#owner group: sql1

connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn2,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);

#更新主键a->b,更新b行。commit
connection conn1;
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(pk int primary key, i1 int, v1 varchar(20));
replace into t1 values(1,1,'a'),(2,2,'b'),(3,3,'c'),(4,4,'d'),(5,5,'e');

set autocommit=0;
update t1 set pk=11 where pk=1;
select * from t1;
update t1 set i1=11,v1='11a' where pk=11;
commit;
select * from t1;
set autocommit=1;

#更新主键a->b,更新b行。rollback
connection conn1;
set autocommit=0;
update t1 set pk=12 where pk=2;
select * from t1;
update t1 set i1=12,v1='12a' where pk=12;
rollback;
select * from t1;
set autocommit=1;

#更新主键a->b(b存在),删除b，更新主键a->b，更新b行。commit
connection conn1;
set autocommit=0;
--error 1062
update t1 set pk=4 where pk=3;
delete from t1 where pk=4;
select * from t1;
update t1 set pk=4 where pk=3;
update t1 set i1=4,v1='4d' where pk=4;
commit;
select * from t1;
set autocommit=1;

#更新主键a->b(b存在),删除b，更新主键a->b，更新b行。rollback
connection conn1;
set autocommit=0;
--error 1062
update t1 set pk=5 where pk=4;
delete from t1 where pk=5;
select * from t1;
update t1 set pk=5 where pk=4;
update t1 set i1=5,v1='5e' where pk=5;
rollback;
select * from t1;
set autocommit=1;

#conn1 update a->b,conn2 use a,conn1 commit,conn2 commit
connection conn1;
delete from t1 where pk<20;
replace into t1 values(1,1,'a'),(2,2,'b'),(3,3,'c'),(4,4,'d'),(5,5,'e');
connection conn1;
set autocommit=0;
update t1 set pk=11 where pk=1;

connection conn2;
set autocommit=0;
--error 1205,4012
update t1 set i1=2,v1='aa' where pk=1;

connection conn1;
commit;
set autocommit=1;

connection conn2;
commit;
set autocommit=1;

select * from t1;

