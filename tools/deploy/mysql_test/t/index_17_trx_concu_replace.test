--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: jingyan.kfy
# owner group: transaction
# description: foobar
# tags: cost
####TITLE:并发事务同时replace操作，查询索引表、数据表、回表
####
--disable_query_log
--source mysql_test/include/index_quick_major.inc
--real_sleep 1
--disable_warnings
drop table if exists t1;
--enable_warnings
--enable_query_log

create table t1(pk int primary key, a int, b int, c varchar(1024));
create index i1 on t1(b) storing(c);

--source mysql_test/include/check_all_idx_ok.inc

connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn2,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);

####CASE:并发事务replace，无锁冲突，commit
connection conn1;
set autocommit=0;
replace into t1 values(1,1,1,'a');

connection conn2;
set autocommit=0;
replace into t1 values(2,1,1,'a');
--sorted_result
select pk, b, c from t1 where b>0 and b<10;
--sorted_result
select pk, a, b from t1 where pk>0 and pk<10;
--sorted_result
select * from t1 where b>0 and b<10;

connection conn1;
--sorted_result
select pk, b, c from t1 where b>0 and b<10;
--sorted_result
select pk, a, b from t1 where pk>0 and pk<10;
--sorted_result
select * from t1 where b>0 and b<10;
commit;
--sorted_result
select pk, b, c from t1 where b>0 and b<10;
--sorted_result
select pk, a, b from t1 where pk>0 and pk<10;
--sorted_result
select * from t1 where b>0 and b<10;
commit;

connection conn2;
--sorted_result
select pk, b, c from t1 where b>0 and b<10;
--sorted_result
select pk, a, b from t1 where pk>0 and pk<10;
--sorted_result
select * from t1 where b>0 and b<10;
commit;
--sorted_result
select pk, b, c from t1 where b>0 and b<10;
--sorted_result
select pk, a, b from t1 where pk>0 and pk<10;
--sorted_result
select * from t1 where b>0 and b<10;
commit;

####CASE:并发事务replace，有锁冲突，commit
connection conn1;
set autocommit=0;
replace into t1 values(3,1,1,'a');

connection conn2;
set autocommit=0;
replace into t1 values(4,1,1,'a');
delete from t1 where pk=3;
update t1 set b=4 where pk=3;
--error 1205,4012
insert into t1 values(3,1,1,'a');
--error 1205,4012
replace into t1 values(3,1,1,'c');
--sorted_result
select pk, b, c from t1 where b>0 and b<10;
--sorted_result
select pk, a, b from t1 where pk>0 and pk<10;
--sorted_result
select * from t1 where b>0 and b<10;

connection conn1;
--sorted_result
select pk, b, c from t1 where b>0 and b<10;
--sorted_result
select pk, a, b from t1 where pk>0 and pk<10;
--sorted_result
select * from t1 where b>0 and b<10;
commit;
--sorted_result
select pk, b, c from t1 where b>0 and b<10;
--sorted_result
select pk, a, b from t1 where pk>0 and pk<10;
--sorted_result
select * from t1 where b>0 and b<10;
commit;

connection conn2;
--sorted_result
select pk, b, c from t1 where b>0 and b<10;
--sorted_result
select pk, a, b from t1 where pk>0 and pk<10;
--sorted_result
select * from t1 where b>0 and b<10;
commit;
--sorted_result
select pk, b, c from t1 where b>0 and b<10;
--sorted_result
select pk, a, b from t1 where pk>0 and pk<10;
--sorted_result
select * from t1 where b>0 and b<10;
commit;

####CASE:并发事务，事务1 replace，事务2 做其他dml，无锁冲突
connection conn1;
set autocommit=0;
replace into t1 values(5,1,1,'a'),(6,1,1,'a'),(7,1,1,'a');
commit;
replace into t1 values(7,2,2,'b');

connection conn2;
set autocommit=0;
delete from t1 where pk=5;
update t1 set a=a+1, b=b+1, c='b' where pk=6;
replace into t1 values(8,1,1,'a');
--sorted_result
select pk, b, c from t1 where b>0 and b<10;
--sorted_result
select pk, a, b from t1 where pk>0 and pk<10;
--sorted_result
select * from t1 where b>0 and b<10;

connection conn1;
--sorted_result
select pk, b, c from t1 where b>0 and b<10;
--sorted_result
select pk, a, b from t1 where pk>0 and pk<10;
--sorted_result
select * from t1 where b>0 and b<10;
commit;
--sorted_result
select pk, b, c from t1 where b>0 and b<10;
--sorted_result
select pk, a, b from t1 where pk>0 and pk<10;
--sorted_result
select * from t1 where b>0 and b<10;
commit;

connection conn2;
--sorted_result
select pk, b, c from t1 where b>0 and b<10;
--sorted_result
select pk, a, b from t1 where pk>0 and pk<10;
--sorted_result
select * from t1 where b>0 and b<10;
commit;
--sorted_result
select pk, b, c from t1 where b>0 and b<10;
--sorted_result
select pk, a, b from t1 where pk>0 and pk<10;
--sorted_result
select * from t1 where b>0 and b<10;
commit;

####CASE: 多个事务replace,事务1 commit，事物2 rollback
connection conn1;
set autocommit=0;
replace into t1 values(8,2,2,'b'),(9,2,2,'b');
commit;
replace into t1 values(8,3,3,'c');

connection conn2;
set autocommit=0;
replace into t1 values(9,3,3,'c');
--sorted_result
select pk, b, c from t1 where b>0 and b<10;
--sorted_result
select pk, a, b from t1 where pk>0 and pk<10;
--sorted_result
select * from t1 where b>0 and b<10;

connection conn1;
--sorted_result
select pk, b, c from t1 where b>0 and b<10;
--sorted_result
select pk, a, b from t1 where pk>0 and pk<10;
--sorted_result
select * from t1 where b>0 and b<10;
commit;
--sorted_result
select pk, b, c from t1 where b>0 and b<10;
--sorted_result
select pk, a, b from t1 where pk>0 and pk<10;
--sorted_result
select * from t1 where b>0 and b<10;
commit;

connection conn2;
--sorted_result
select pk, b, c from t1 where b>0 and b<10;
--sorted_result
select pk, a, b from t1 where pk>0 and pk<10;
--sorted_result
select * from t1 where b>0 and b<10;
rollback;
--sorted_result
select pk, b, c from t1 where b>0 and b<10;
--sorted_result
select pk, a, b from t1 where pk>0 and pk<10;
--sorted_result
select * from t1 where b>0 and b<10;

drop table t1;
