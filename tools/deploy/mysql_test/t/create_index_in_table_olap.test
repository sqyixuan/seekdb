select * from ob_custname;
select * from ob_custid;
select * from ob_campaign; 
select * from ob_adgroup;
select * from ob_bidword;
###test expire info
sleep 20;
alter table ob_custname set expire_info = (gmt_create < date_sub(merging_frozen_time(), INTERVAL  1 DAY )),set progressive_merge_num=1;
alter table ob_custid   set expire_info = (gmt_create < date_sub(merging_frozen_time(), INTERVAL 1 DAY )),set progressive_merge_num=1;
alter table ob_campaign set expire_info = (gmt_create < date_sub(merging_frozen_time(), INTERVAL 1 DAY));
alter table ob_adgroup  set expire_info = (gmt_create < date_sub(merging_frozen_time(), INTERVAL 1 DAY)),set progressive_merge_num=1;
alter table ob_bidword  set expire_info = (gmt_create < date_sub(merging_frozen_time(), INTERVAL 1 DAY));
#--error 1235
###bug bug bug of 1.0
alter table ob_custname  set  progressive_merge_num=5;
###create table with index and expire info
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(c0 int primary key,c1 varchar(1024),index idx(c1)) EXPIRE_INFO  (c1 = 'd');

drop database create_index_in_table_olap;
