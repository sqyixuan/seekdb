# owner:yongle.xh
# owner group:storage
# tags: datatype

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;

--disable_query_log
--disable_result_log
--source mysql_test/include/index_quick_major.inc
--enable_query_log
--enable_result_log

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1(pk int primary key , c1 decimal(27), c2 varchar(1024));


--disable_query_log

## 1000 * 3000 > 2m
## should be more than 2M

let $cnt=3000;
while($cnt)
{
  eval insert into t1(pk,c1,c2) values($cnt, 1, '');
  dec $cnt;
}
--enable_query_log

select pk, c1 from t1 where pk > 2990;


alter table t1 add column c3 decimal(20,10) NOT NULL default 0.7000000007;
eval insert into t1(pk,c1,c2,c3) values(3001, 1, '111', 2);

--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc

select pk, c1, c3 from t1 where pk > 2990;

create index index1 on t1(c3, c1, pk);
--source mysql_test/include/check_all_idx_ok.inc
show index from t1;
select pk, c1, c3 from t1 where pk > 2990;






