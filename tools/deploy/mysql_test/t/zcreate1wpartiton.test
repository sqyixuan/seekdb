--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
##owner: link.zt
##owner group: SQL1
###tags: ddl, dml 
set @@ob_query_timeout=15000000;
let $cnt=3;

while($cnt) 
{

    --disable_warnings
    eval drop table if exists tt_$cnt; 
    --enable_warnings
    eval create table tt_$cnt (pk int primary key, c1 int)partition by hash(pk) partitions 50;
    dec $cnt;
}
let $cnt=3;

while($cnt) 
{

    eval replace into tt_$cnt values(1,1);
    dec $cnt;
}

let $cnt=3;

while($cnt) 
{

    eval select * from tt_$cnt;
    dec $cnt;
}

#set @@global.ob_query_timeout=900000000;
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
let $cnt=3;

while($cnt) 
{

    eval select * from tt_$cnt;
    dec $cnt;
}
