--disable_warnings
drop table if exists t1,t2;
--enable_warnings

create table t1 (c1 int primary key, c2 int);
insert into t1 values(1,0),(2,0),(3,0);

--echo check get
--disable_result_log
explain select * from t1 where c1=1;
--enable_result_log
--disable_result_log
explain select * from t1 where c1=1 and c1=2;
--enable_result_log

--disable_result_log
explain select * from t1 where c1=1 and c2=0;
--enable_result_log
--disable_result_log
explain select * from t1 where c1=1 and c2=0;
--enable_result_log
--disable_result_log
explain select * from t1 where c1=1 and c2 > 0;
--enable_result_log
--disable_result_log
explain select * from t1 where c1=1 and c2 < 0;
--enable_result_log
--disable_result_log
explain select * from t1 where c1=1 and c2 != 0;
--enable_result_log
--disable_result_log
explain select * from t1 where c1=1 and c2 >= 0;
--enable_result_log
--disable_result_log
explain select * from t1 where c1=1 and c2 <= 0;
--enable_result_log


--echo check multiget
--disable_result_log
explain select * from t1 where c1=1 or c1=2;
--enable_result_log
--disable_result_log
explain select * from t1 where c1 in (1,2,3);
--enable_result_log
--disable_result_log
explain select * from t1 where c1 in (1);
--enable_result_log
--disable_result_log
explain select * from t1 where (c1,c2) in ((1,0));
--enable_result_log
--disable_result_log
explain select * from t1 where (c1,c2) in ((1,0),(1,1));
--enable_result_log
--disable_result_log
explain select * from t1 where (c2,c1) in ((0,1),(1,1));
--enable_result_log
--disable_result_log
explain select * from t1 where (c2,c1) in ((0,1));
--enable_result_log

--echo check scan
--disable_result_log
explain select * from t1;
--enable_result_log
--disable_result_log
explain select * from t1 where c1 > 0;
--enable_result_log
--disable_result_log
explain select * from t1 where c1 > 0 and c1 < 2;
--enable_result_log
--disable_result_log
explain select * from t1 where c1 != 1;
--enable_result_log
--disable_result_log
explain select * from t1 where c1 between 0 and 2;
--enable_result_log
--disable_result_log
explain select * from t1 where c1 between 0 and 200;
--enable_result_log
--disable_result_log
explain select * from t1 where c1 > 0 limit 1;
--enable_result_log
--disable_result_log
explain select * from t1 where c1 > 0 and c1 < 2 limit 1;
--enable_result_log
--disable_result_log
explain select * from t1 where c1 != 1 limit 1;
--enable_result_log
--disable_result_log
explain select * from t1 where c1 between 0 and 2 limit 1;
--enable_result_log
--disable_result_log
explain select * from t1 where c1 between 0 and 200 limit 1;
--enable_result_log
--disable_result_log
explain select * from t1 limit 1;
--enable_result_log
--disable_result_log
explain select * from t1 limit 1,1;
--enable_result_log

--disable_result_log
explain select * from t1 limit 1000;
--enable_result_log
--disable_result_log
explain select * from t1 limit 1000,10;
--enable_result_log

--disable_result_log
explain select * from t1 where 1 = 0;
--enable_result_log
--disable_result_log
explain select * from t1 where false;
--enable_result_log

--echo check join
create table t2 (c1 int primary key, c2 int);
--disable_result_log
explain select t1.c2, t2.c2 from t1, t2 where t2.c1 = t1.c1;
--enable_result_log
--disable_result_log
explain select t1.c2, t2.c2 from t1, t2 where t2.c1 = t1.c1 and t1.c2=0;
--enable_result_log
--disable_result_log
explain select t1.c2, t2.c2 from t1, t2 where t2.c1 = t1.c1 and t1.c2=0 and t2.c2=0;
--enable_result_log
--disable_result_log
explain select t1.c2, t2.c2 from t1, t2 where t2.c1 = t1.c1 and t1.c1=0 and t2.c1=0;
--enable_result_log
--disable_result_log
explain select t1.c2, t2.c2 from t1, t2 where t2.c1 = t1.c1 and t1.c1=0;
--enable_result_log



drop table t1;

create table t1 (c1 int, c2 int, c3 int, primary key(c1,c2));
insert into t1 values(1,1,0),(2,2,0),(3,3,0);

--echo check get

--disable_result_log
explain select * from t1 where c1=1 and c2=1;
--enable_result_log
--disable_result_log
explain select * from t1 where c2=1 and c1=1;
--enable_result_log

--disable_result_log
explain select * from t1 where c1=1 and c2=1 and c3=0;
--enable_result_log
--disable_result_log
explain select * from t1 where c1=1 and c2=1 and c3>0;
--enable_result_log
--disable_result_log
explain select * from t1 where c1=1 and c2=1 and c3<0;
--enable_result_log
--disable_result_log
explain select * from t1 where c1=1 and c2=1 and c3!=0;
--enable_result_log

--echo check multiget

--disable_result_log
explain select * from t1 where (c1,c2) in ((1,1));
--enable_result_log
--disable_result_log
explain select * from t1 where (c1,c2) in ((1,1),(2,2));
--enable_result_log
--disable_result_log
explain select * from t1 where (c2,c1) in ((1,1));
--enable_result_log
--disable_result_log
explain select * from t1 where (c2,c1) in ((1,1),(2,2));
--enable_result_log
--disable_result_log
explain select * from t1 where (c1=1 and c2=1) or (c1=2 and c2=2);
--enable_result_log

--echo check scan
--disable_result_log
explain select * from t1 where c1=1;
--enable_result_log
--disable_result_log
explain select * from t1 where c2=1;
--enable_result_log
--disable_result_log
explain select * from t1 where c3=1;
--enable_result_log
--disable_result_log
explain select * from t1 where c1=1 and c3=0;
--enable_result_log
--disable_result_log
explain select * from t1 where c2=1 and c3=0;
--enable_result_log
--disable_result_log
explain select * from t1;
--enable_result_log

--disable_result_log
explain select * from t1 where c1=1 limit 1;
--enable_result_log
--disable_result_log
explain select * from t1 where c2=1 limit 1;
--enable_result_log
--disable_result_log
explain select * from t1 where c3=1 limit 1;
--enable_result_log

--disable_result_log
explain select * from t1 limit 1;
--enable_result_log
--disable_result_log
explain select * from t1 limit 1,10;
--enable_result_log
--disable_result_log
explain select * from t1 limit 1000,10;
--enable_result_log


--disable_result_log
explain select * from t1 where c1 in (1,2,3);
--enable_result_log
--disable_result_log
explain select * from t1 where c2 in (1,2,3);
--enable_result_log
--disable_result_log
explain select * from t1 where c3 in (1,2,3);
--enable_result_log
--disable_result_log
explain select * from t1 where (c1,c3) in ((1,0),(2,0));
--enable_result_log
