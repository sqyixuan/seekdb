--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
--disable_abort_on_errot
# owner: peihan.dph
# owner group: SQL3
# description:
# tags:ddl
--disable_query_log
--source mysql_test/include/index_quick_major.inc
##alter system set min_drop_cache_wait_time='10s' server_type=chunkserver;
alter system set  switch_flow_percent_strategy = '1:1s;10:1s;30:1s;60:1s' server_type=rootserver;

--real_sleep 3
--disable_warnings
drop table if exists t1, t2;
--enable_warnings
--enable_query_log

create table t1(pk int primary key, a int);
create table t2(pk int primary key, a int);

insert into t1 values(1,1),(2,1),(3,2),(4,2);
insert into t2 values(1,1),(2,2),(3,3),(4,4);

prepare stmt from select * from t1, t2 where t1.pk = t2.a and t1.pk > 1 and t1.pk < 4;
execute stmt;
execute stmt;
create index iloveidx on t2(a);

--source mysql_test/include/check_all_idx_ok.inc


execute stmt;
execute stmt;
execute stmt;


drop table t1, t2;


