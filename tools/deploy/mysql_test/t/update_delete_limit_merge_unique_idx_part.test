--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: link.zt
#owner group: sql1

#####test:update,delete static or dynamic date
###use muti cols index,and update part
--disable_warnings
drop table if exists t1; 
--enable_warnings

#alter system set min_drop_cache_wait_time='10s' server_type=chunkserver;
--real_sleep 2 

create table t1 (pk1 int,pk2 int, i1 int, v1 varchar(20),primary key(i1,pk2));
create index  idx1 on t1(pk1,v1);
--source mysql_test/include/check_all_idx_ok.inc
insert into t1 values(1,1,1,'a'),(2,2,2,'b'),(3,3,3,'c'),(4,4,4,'d'),(5,5,5,'e');

##只有动态数据的更新
####test:update part primary key
update t1 set pk1=4 where pk1=1;
update t1 set pk1=6,v1='d' where pk1=3;
select * from t1;
update t1 set pk1=4 where pk1<15 limit 2;
select * from t1;
update t1 set pk1=8 where pk1<15 order by pk2 asc  limit 2;
select * from t1;
update t1 set pk1=7 where pk1<15 order by pk2 limit 1;
select * from t1;
update t1 set pk1=6,v1='d' where pk1=3 limit 0;
select * from t1;
####test:update not primary key
update t1 set v1=4 where pk1<15 limit 2;
select * from t1;
update t1 set v1=8 where pk1<15 order by pk2 asc  limit 2;
select * from t1;
update t1 set v1=7 where pk1<15 order by pk2 limit 1;
select * from t1;
update t1 set pk1=6,v1='d' where pk1=3 limit 0;
select * from t1;

--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc

##只有静态数据的更新
update t1 set pk1=1 where pk1<=4 limit 1;
select * from t1;
update t1 set pk1=3 where pk1>=6 limit 2;
select * from t1;
update t1 set pk1=-1 where (pk2,i1) in ((4,1),(5,2),(6,3),(2,3)) order by i1 limit 5;
select * from t1;
update t1 set pk1=-1 where (pk2,i1) in ((1,1),(1,2),(2,2),(3,3)) order by pk2  asc limit 5;
select * from t1;
update t1 set pk1=-1 where (pk2,i1) in ((1,1),(1,2),(2,2),(3,3)) order by i1 asc limit 2;
select * from t1;
update t1 set pk1=-2 where (pk2,i1) in ((4,4),(4,5),(5,5),(6,6)) order by i1 desc limit 2;
select * from t1;

##动静态都存在
update t1 set pk1=4,v1='e' where pk2=1;
update t1 set pk1=5,v1='f' where pk2=2;
update t1 set pk1=6,v1='g' where pk2=3;
update t1 set pk1=-1 where (pk2,i1) in ((1,1),(1,2),(2,2),(3,3)) order by pk2  asc limit 5;
select * from t1;
update t1 set pk1=-1 where (pk2,i1) in ((1,1),(1,2),(5,5),(3,3)) order by i1 asc limit 2;
select * from t1;
update t1 set pk1=pk2+1,pk2=pk1+1 where (pk1,i1) in ((1,1),(1,2),(2,2),(2,3)) limit 2;
update t1 set pk1=pk1+1-1 where (pk2,i1) in ((1,1),(1,2),(2,2),(2,3)) limit 2;
select * from t1;


--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc

replace into t1 values(1,1,1,'a'),(2,2,2,'b'),(3,3,3,'c'),(4,4,14,'d'),(5,5,5,'e');
update t1 set pk1=-2 where (pk1,pk2,i1) in ((2,2,2),(1,1,1),(2,2,3),(1,1,2),(3,3,3),(3,3,4),(4,4,5),(5,5,6));
select * from t1;








