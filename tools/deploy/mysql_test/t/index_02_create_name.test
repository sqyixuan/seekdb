--result_format 4
--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
set @@ob_enable_index_direct_select=on;
--enable_query_log
# owner: bin.lb
# owner group: SQL3
# description:
# tags:index,ddl
####
--disable_query_log
--source mysql_test/include/index_quick_major.inc
--real_sleep 2 
--disable_warnings
drop database if exists idx_create_name;
create database idx_create_name;
use idx_create_name;
drop table if exists t1,t2,t3;
--enable_warnings
--enable_query_log
set @@ob_enable_index_direct_select = 1;

create table t1(c1 int primary key, c2 varchar(1024), c3 int);
create table t2(c1 int , c2 varchar(1024), c3 int, c4 varchar(1024), c5  timestamp(6) default "2012-01-01 12:00:00", c6 int, primary key(c1, c2));
create table t3(c1 int primary key, c2 varchar(1024), c3 int);

####CASE:using same name, then drop index, then create
create index i1 on t1(c2,c3);
--error 1061
create index i1 on t1(c2,c3);
drop index i1 on t1;
sleep 20;
create index i1 on t1(c2,c3);
drop index i1 on t1;
sleep 1;
show index from t1;
sleep 2;
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
create index i1 on t1(c2,c3);
####CASE:using name of other table
create index t1 on t1(c3);
create index t2 on t1(c1,c2,c3);
create index i1 on t2(c3,c4) storing(c5);
create index test_ on t2(c3,c4);
sleep 2;
--source mysql_test/include/check_all_idx_ok.inc
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
let $idx1 = query_get_value(select a.table_name from oceanbase.__all_virtual_table as a inner join (select * from oceanbase.__all_virtual_table where table_name='t1' and database_id = (select database_id from oceanbase.__all_virtual_database where database_name = 'idx_create_name')) b on a.data_table_id=b.table_id  order by a.table_id, table_name, 1);
let $idx2 = query_get_value(select a.table_name from oceanbase.__all_virtual_table as a inner join (select * from oceanbase.__all_virtual_table where table_name='t1' and database_id = (select database_id from oceanbase.__all_virtual_database where database_name = 'idx_create_name')) b on a.data_table_id=b.table_id  order by a.table_id, table_name, 2);
let $idx3 = query_get_value(select a.table_name from oceanbase.__all_virtual_table as a inner join (select * from oceanbase.__all_virtual_table where table_name='t2' and database_id = (select database_id from oceanbase.__all_virtual_database where database_name = 'idx_create_name')) b on a.data_table_id=b.table_id  order by a.table_id, table_name, 1);
disconnect obsys;
connection default;

--disable_query_log
eval select * from $idx1;
eval select * from $idx2;
eval select * from $idx3;
--enable_query_log

#select * from  __idx_3003_t1;
#select * from  __idx_3006_i1;
#select * from  __idx_3006_test_;

--replace_column 3 indexname
show index from t1;
--replace_column 3 indexname
show index from t2;
--replace_column 3 indexname
show index from t3;

####CASE:create index with spec char
create index $i1 on t2(c3,c4);

drop table t1;
drop table t2;
drop table t3;
