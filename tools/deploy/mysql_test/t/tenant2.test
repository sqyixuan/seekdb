--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: bin.lb
# owner group: SQL2
# tags: ddl
# description:
#
--disable_info
--disable_metadata

connect (sysc,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection sysc;


select effective_tenant();
select current_user();
#select user();
#select session_user();
#select system_user();
select substring_index(user(), '@', 1);
select substring_index(session_user(), '@', 1);
select substring_index(system_user(), '@', 1);
show charset;
show character set;
show collation;
select @@session.autocommit;
set @@session.autocommit = 'OFF';
select @@session.autocommit;
set @@session.autocommit = 'ON';
select @@session.autocommit;
--error 1231
set @@session.autocommit = 'aaa';

--disable_warnings
#drop tenant if exists tt1 force;
#drop resource pool if exists pool__1;
#drop resource unit if exists box__1;
--disable_query_log
#eval create resource unit box__1 max_cpu 1, memory_size '2G';
#eval create resource unit if not exists box__1 max_cpu 1, memory_size '2G';
let $zone_name=query_get_value(select zone from oceanbase.__all_zone where zone != '' limit 1, zone, 1);
--replace_column 1 create_time 2 modify_time 3 unit_config_id
select * from oceanbase.__all_unit_config where name='box__1';

--disable_query_log
#eval create resource pool pool__1 unit = 'box__1', unit_num = 1, zone_list = ('$zone_name');
#eval create resource pool if not exists pool__1 unit = 'box__1', unit_num = 1, zone_list = ('$zone_name');
--replace_column 1 create_time 2 modify_time 3 resource_pool_id 6 unit_config_id 7 zone
select * from oceanbase.__all_resource_pool where name='pool__1';

--enable_warnings
#eval create tenant tt1 replica_num = 1, primary_zone='$zone_name', resource_pool_list=('pool__1') set ob_tcp_invited_nodes='%';
--source mysql_test/include/check_tenant_sync.inc
--enable_query_log
select tenant_name from oceanbase.__all_tenant where tenant_name='sys';
let $__tenant_name__ = 'sys';
--source mysql_test/include/get_tenant_server.inc
connect (conn1,$TE_SERVER_IP,root,,*NO-ONE*,$TE_SERVER_PORT);

select effective_tenant();
select current_user();
#select user();
#select session_user();
#select system_user();
select substring_index(user(), '@', 1);
select substring_index(session_user(), '@', 1);
select substring_index(system_user(), '@', 1);
show charset;
show character set;
show collation;
select @@session.autocommit;
set @@session.autocommit = 'OFF';
select @@session.autocommit;
set @@session.autocommit = 'ON';
select @@session.autocommit;
--error 1231
set @@session.autocommit = 'aaa';

connection conn1;
--disable_warnings
drop database if exists test1;
drop database if exists test2;
--enable_warnings
create database test1;
show databases like "test1";
use test1;
select database();

create table t1tenant1(c1 bigint primary key, c2 bigint);
create index t1tenant1_idx1 on t1tenant1(c2, c1);
show tables;
sleep 3;
show columns from t1tenant1;
connect (conn2,$TE_SERVER_IP,root@sys,,*NO-ONE*,$TE_SERVER_PORT);
connection conn2;
--source mysql_test/include/check_all_idx_ok.inc
connection conn1;
show index from t1tenant1;
show index from t1tenant1 where Column_name = 'c1';
insert into t1tenant1 values (1, 2);
select * from t1tenant1;

create database test2;
use test2;
show columns from test1.t1tenant1;
show index from test1.t1tenant1;

create table t1_in_test2(c1 bigint primary key, c2 bigint);
connection conn1;
create table t2_in_test2(c1 bigint primary key, c2 bigint);
connection conn1;

show tables from test1;
show tables in test1;
show tables from test2;
show tables in test2;
show tables from test2 like 't2_in_test2';
show tables in test2 like 't2_in_test2';

# login using sys tenant
