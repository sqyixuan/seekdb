#bugfix: 
CREATE TABLE `t1` (
  `c1` int(11) DEFAULT NULL,
  `c2` int(11) DEFAULT NULL,
  `c3` int(11) GENERATED ALWAYS AS ((`c2` + `c2`)) VIRTUAL NOT NULL
) DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 3 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0 WITH COLUMN GROUP(each column);
SELECT /*+ no_rewrite */ c1,c2,c3 FROM t1 ORDER BY c3 DESC LIMIT 1;
SELECT /*+ no_rewrite */ c1,c3 FROM t1 ORDER BY c3 DESC LIMIT 1;
SELECT /*+ no_rewrite */ c2,c3 FROM t1 ORDER BY c3 DESC LIMIT 1;
drop table t1;