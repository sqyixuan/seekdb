--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: sean.yyj
#owner group: sql2


connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn1;

--disable_warnings
--error 0, 1396
drop user 'up101';
--error 0, 1051
drop table t3;
--enable_warnings


create user 'up101' identified by 'pass1';
grant create on * to 'up101';

--source mysql_test/include/check_schema_sync.inc
connect (conn2,$OBMYSQL_MS0,up101,pass1,test,$OBMYSQL_PORT);
connection conn2;
create  table t3(a int primary key, b int);

connection conn1;
revoke drop on * from 'up101';
--source mysql_test/include/check_schema_sync.inc

connection conn2;
--error 1142
drop table t3;

connection conn1;
drop table t3;
drop user 'up101';
