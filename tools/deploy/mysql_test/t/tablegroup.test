--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: zhaoziqian.zzq
# owner group: RS 
# description:

set @@recyclebin = on;
show session variables like 'recyclebin';

--disable_warnings
drop database if exists hualong;
drop tablegroup if exists tg1;
drop tablegroup if exists tg2;
drop tablegroup if exists tg3;
--enable_warnings
create database hualong;
use hualong;
create table t1 (c1 int primary key);
create tablegroup tg1;

--error 5151
alter table t1 set tablegroup='not_exist_tablegroup';

alter table t1 set tablegroup = 'tg1';
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;
--error 4615
drop tablegroup tg1;
alter table t1 drop tablegroup;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;
drop tablegroup tg1;

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
alter tenant sys set primary_zone='zone1';
connection default;

create tablegroup tg2;
create table t2 (c1 int primary key);
create table t3 (c1 int primary key);
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t2;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t3;
alter tablegroup tg2 add table t2, t3;
sleep 1;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t2;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t3;
alter table t2 drop tablegroup;
alter table t3 drop tablegroup;

purge recyclebin;
create table t4(c1 int primary key);
let $current_tenant_id = query_get_value(select effective_tenant_id() x, x, 1);
connection obsys;
--disable_query_log
let $table_id = query_get_value(select table_id from oceanbase.__all_virtual_table where tenant_id = $current_tenant_id and table_name = 't4' and database_id = (select database_id from oceanbase.__all_virtual_database where tenant_id = $current_tenant_id and database_name ='hualong'), table_id, 1);
--enable_query_log
connection default;
alter tablegroup tg2 add table t4;
drop table t4;
connection obsys;
--disable_query_log
eval select tablegroup_id from oceanbase.__all_virtual_table where tenant_id = $current_tenant_id and table_id = $table_id;
let $object_name = query_get_value(select object_name from oceanbase.__all_virtual_recyclebin where tenant_id = $current_tenant_id, object_name, 1);
connection default;
eval flashback table $object_name to before drop;
connection obsys;
eval select tablegroup_id from oceanbase.__all_virtual_table where tenant_id = $current_tenant_id and table_id = $table_id;
--enable_query_log
connection default;
--enable_query_log
alter table t4 drop tablegroup;
drop tablegroup tg2;
purge recyclebin;

set @@recyclebin = off;
show session variables like 'recyclebin';
