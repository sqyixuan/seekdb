select key6 from t1 where key1=6 and key2>2 and key2<6 and key8=8 and key7>4 and key7<10 order by key7;
select sum(key6) from t1 where key1=6 and key2>2 and key2<6 and key8=8 and key7>4 and key7<10 order by key7;

