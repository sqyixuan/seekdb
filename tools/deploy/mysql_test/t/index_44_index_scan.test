--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: yibo.tyf
#owner group: sql1
# tags: optimizer

--disable_warnings
drop table if exists t1, t2;
--enable_warnings
--source mysql_test/include/index_quick_major.inc
--source mysql_test/include/backup_spm_var.inc
--real_sleep 2 

create table t1(pk1 int, pk2 int, key1 int, key2 int, key3 int, key4 int, key5 int, key6 int, key7 int, key8 int, key9 int, primary key(pk1, pk2));

create index i1 on t1(key1,key2) storing(key9);
create index i2 on t1(key3,key4,key5) storing(key9);
create index i4 on t1(key6);
create index i5 on t1(key7,key8);

--source mysql_test/include/check_all_idx_ok.inc

insert into t1 values
(1,2,2,2,3,4,5,6,8,7,9),
(3,2,4,4,3,5,5,6,8,5,9),
(4,2,6,4,3,6,5,6,7,8,10),
(3,1,8,8,3,5,5,6,8,8,9),
(3,3,6,6,3,3,5,2,8,8,9),
(4,1,6,4,3,9,10,7,9,8,10),
(2,4,2,4,3,4,5,6,8,7,9),
(2,5,2,4,2,2,2,3,2,2,2),
(3,4,3,4,3,5,5,6,8,5,9);

##index scan 1
#i2
select * from t1 where key1<4 and key3=3 and key4>4 and key4<6;
select avg(key6) from t1 where key1<4 and key3=3 and key4>4 and key4<6;
select min(key6) from t1 where key1<4 and key3=3 and key4>4 and key4<6;
select max(key6) from t1 where key1<4 and key3=3 and key4>4 and key4<6;
select sum(key6) from t1 where key1<4 and key3=3 and key4>4 and key4<6;
select distinct key6 from t1 where key1<4 and key3=3 and key4>4 and key4<6;

select sum(key3) from t1 where key1<4 and key1>0 and key3=3 and key4>4 and key4<4;


##index scan 2
#i1
select * from t1 where key1=6 and key2>=4 and key2<=6 and key3=3 and key4>3 and key4<10;
select avg(key6) from t1 where key1=6 and key2>=4 and key2<=6 and key3=3 and key4>3 and key4<10;
select min(key6) from t1 where key1=6 and key2>=4 and key2<=6 and key3=3 and key4>3 and key4<10;
select max(key6) from t1 where key1=6 and key2>=4 and key2<=6 and key3=3 and key4>3 and key4<10;
select sum(key6) from t1 where key1=6 and key2>=4 and key2<=6 and key3=3 and key4>3 and key4<10;
select distinct key6 from t1 where key1=6 and key2>=4 and key2<=6 and key3=3 and key4>3 and key4<10;

select sum(key6) from t1 where key1=6 and key2>=4 and key2<=6 and key3=3 and key4>3 and key4<3;
#i1
select * from t1 where key1=6 and key2 BETWEEN 2 and 6 and key3=3 and key4 BETWEEN 3 and 10;
select avg(key6) from t1 where key1=6 and key2 BETWEEN 2 and 6 and key3=3 and key4 BETWEEN 3 and 10;
select min(key6) from t1 where key1=6 and key2 BETWEEN 2 and 6 and key3=3 and key4 BETWEEN 3 and 10;
select max(key6) from t1 where key1=6 and key2 BETWEEN 2 and 6 and key3=3 and key4 BETWEEN 3 and 10;
select sum(key6) from t1 where key1=6 and key2 BETWEEN 2 and 6 and key3=3 and key4 BETWEEN 3 and 10;
select distinct key6 from t1 where key1=6 and key2 BETWEEN 2 and 6 and key3=3 and key4 BETWEEN 3 and 10;

select sum(key6) from t1 where key1=6 and key2 BETWEEN 2 and 6 and key3=3 and key4 BETWEEN 3 and 3;

##index get 3
#i5
select * from t1 where key1=6 and key2>2 and key2<6 and key8=8 and key7>4 and key7<10 order by key7;
select avg(key6) from t1 where key1=6 and key2>2 and key2<6 and key8=8 and key7>4 and key7<10 order by key7;
select min(key6) from t1 where key1=6 and key2>2 and key2<6 and key8=8 and key7>4 and key7<10 order by key7;
