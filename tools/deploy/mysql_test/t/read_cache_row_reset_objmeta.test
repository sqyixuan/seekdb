--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: muwei.ym
# owner group: storage
# description:
# 
#

# tags: multiget

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1 (c1 int primary key, c2 int, c3 int default NULL);
insert into t1 values(1, 1, 1);
insert into t1 values(2, 2, NULL);
insert into t1 values(3, 3, 3);

--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc

# load the second row into row cache
select * from t1 where c1 = 2;

# multiget with a row from rowcache in middle
select c3, c2 from t1 where c1 in (1,2,3);

