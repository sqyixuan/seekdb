# setup
set autocommit=1;
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1 (c1 int primary key, c2 int);
--disable_query_log
let orig_trans_count = query_get_value(`select name, value from (select * from oceanbase.__all_server_stat) T where T.name in ('multi_stmt_trans_count') and T.svr_ip='$OBMYSQL_MS0' and T.svr_port=$OBMYSQL_PORT`, value, 1);
let orig_stmt_count = query_get_value(`select name, value from (select * from oceanbase.__all_server_stat) T where T.name in ('multi_stmt_trans_stmt_count') and T.svr_ip='$OBMYSQL_MS0' and T.svr_port=$OBMYSQL_PORT`, value, 1);
--enable_query_log
################################################################
set autocommit = 0;
insert into t1 values (1, 2);
insert into t1 values (2, 3);
set autocommit = 1;
--disable_query_log
let trans_count = query_get_value(`select name, value from (select * from oceanbase.__all_server_stat) T where T.name in ('multi_stmt_trans_count') and T.svr_ip='$OBMYSQL_MS0' and T.svr_port=$OBMYSQL_PORT`, value, 1);
let stmt_count = query_get_value(`select name, value from (select * from oceanbase.__all_server_stat) T where T.name in ('multi_stmt_trans_stmt_count') and T.svr_ip='$OBMYSQL_MS0' and T.svr_port=$OBMYSQL_PORT`, value, 1);
--enable_query_log
perl;
$incr_trans = $ENV{trans_count} - $ENV{orig_trans_count};
#print "$incr_trans\n";
$incr_stmt = $ENV{stmt_count} - $ENV{orig_stmt_count};
#print "$incr_stmt\n"
EOF
let orig_trans_count = $trans_count;
let orig_stmt_count = $stmt_count;
################################################################
insert into t1 values (3, 4);
--disable_query_log
let trans_count = query_get_value(`select name, value from (select * from oceanbase.__all_server_stat) T where T.name in ('multi_stmt_trans_count') and T.svr_ip='$OBMYSQL_MS0' and T.svr_port=$OBMYSQL_PORT`, value, 1);
let stmt_count = query_get_value(`select name, value from (select * from oceanbase.__all_server_stat) T where T.name in ('multi_stmt_trans_stmt_count') and T.svr_ip='$OBMYSQL_MS0' and T.svr_port=$OBMYSQL_PORT`, value, 1);
--enable_query_log
perl;
$incr_trans = $ENV{trans_count} - $ENV{orig_trans_count};
#print "$incr_trans\n";
$incr_stmt = $ENV{stmt_count} - $ENV{orig_stmt_count};
#print "$incr_stmt\n"
EOF
let orig_trans_count = $trans_count;
let orig_stmt_count = $stmt_count;
################################################################
set autocommit = 0;
insert into t1 values (5, 2);
insert into t1 values (6, 3);
rollback;
--disable_query_log
let trans_count = query_get_value(`select name, value from (select * from oceanbase.__all_server_stat) T where T.name in ('multi_stmt_trans_count') and T.svr_ip='$OBMYSQL_MS0' and T.svr_port=$OBMYSQL_PORT`, value, 1);
let stmt_count = query_get_value(`select name, value from (select * from oceanbase.__all_server_stat) T where T.name in ('multi_stmt_trans_stmt_count') and T.svr_ip='$OBMYSQL_MS0' and T.svr_port=$OBMYSQL_PORT`, value, 1);
--enable_query_log
perl;
$incr_trans = $ENV{trans_count} - $ENV{orig_trans_count};
#print "$incr_trans\n";
$incr_stmt = $ENV{stmt_count} - $ENV{orig_stmt_count};
#print "$incr_stmt\n"
EOF
let orig_trans_count = $trans_count;
let orig_stmt_count = $stmt_count;
################################################################
set autocommit = 0;
insert into t1 values (5, 2);
insert into t1 values (6, 3);
commit;
--disable_query_log
let trans_count = query_get_value(`select name, value from (select * from oceanbase.__all_server_stat) T where T.name in ('multi_stmt_trans_count') and T.svr_ip='$OBMYSQL_MS0' and T.svr_port=$OBMYSQL_PORT`, value, 1);
let stmt_count = query_get_value(`select name, value from (select * from oceanbase.__all_server_stat) T where T.name in ('multi_stmt_trans_stmt_count') and T.svr_ip='$OBMYSQL_MS0' and T.svr_port=$OBMYSQL_PORT`, value, 1);
--enable_query_log
perl;
$incr_trans = $ENV{trans_count} - $ENV{orig_trans_count};
#print "$incr_trans\n";
$incr_stmt = $ENV{stmt_count} - $ENV{orig_stmt_count};
#print "$incr_stmt\n"
EOF
let orig_trans_count = $trans_count;
let orig_stmt_count = $stmt_count;

# tear down
drop table t1;
