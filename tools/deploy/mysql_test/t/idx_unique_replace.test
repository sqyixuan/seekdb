connect (admin,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);

--disable_query_log
--source mysql_test/include/index_quick_major.inc

sleep 2;
--enable_query_log
--echo merge happens
--disable_warnings
drop table if exists tbl1,t1;
--enable_warnings
create table tbl1 (i1 int, v2 varchar(80), i3 char(20),i4 float, d4 datetime(6),i5 decimal(5,3), primary key(i3));
create  unique index idx1 on tbl1(i1);
create table t1(pk int primary key, c1 int, c2 int);
create unique index i1 on t1(c2);  


insert into tbl1 values(1,'now','haha1',1.6256,'2014-05-04 12:00:00',-10.235);
replace into tbl1(v2,i3,i4) values('dgafdg','efg',-1.25);
select * from tbl1;
update tbl1 set i1=1 where i1=100 ;
update tbl1 set i1=1 where i1='100' ;
insert into t1(pk, c1, c2) values(0,0,0);
select * from t1;
replace into t1(pk, c1) values(0,1);
connection admin;

let $idx1 = query_get_value(select table_name from oceanbase.__all_virtual_table where table_name like '__idx_%_i1' and tenant_id = 1002 order by table_id desc , table_name, 1);

connection default;

select * from t1;
