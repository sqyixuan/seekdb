--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: luofan.zp
# owner group: SQL3
# description: 本case是为了测试多partition时insert的表现；
# tags: optimizer

--disable_warnings
drop table if exists test;
--enable_warnings

create table test (c1 int , c2 char(5), c3 timestamp, c4 int) partition by hash(c4) partitions 4;

#单partition插入,单行插入
insert into test values(1, 'li', now(), 1);
insert into test values(2, 'bi', now(), 2);
insert into test values(3, 'fi', now(), 3);
insert into test values(4, 'zi', now(), 4);
select c1,c2,c4 from test order by c1;

#单partition,多行插入
insert into test values(5,'li', now(), 5), (9, 'li', now(), 9),(13, 'li', now(), 13);
insert into test values(6,'li', now(), 6), (10, 'li', now(), 10),(14, 'li', now(), 14);
insert into test values(7,'li', now(), 7), (11, 'li', now(), 11),(15, 'li', now(), 15);
insert into test values(8,'li', now(), 8), (12, 'li', now(), 12),(16, 'li', now(), 16);
select c1,c2,c4 from test order by c1, c2;

#parition内不冲突,partition之间冲突
insert into test values(2, 'confl', now(), 1), (3, 'confl', now(), 5), (4, 'confl', now(), 9);
insert into test values(1, 'confl', now(), 2), (3, 'confl', now(), 2), (4, 'confl', now(), 2);
insert into test values(1, 'confl', now(), 3), (2, 'confl', now(), 3), (4, 'confl', now(), 3);
insert into test values(1, 'confl', now(), 4), (2, 'confl', now(), 4), (3, 'confl', now(), 4);
select c1,c2,c4 from test order by c1, c2;

#partition内冲突
#--error 1062
insert into test values(2, 'error', now(), 13);
#--error 1062
insert into test values(3, 'error', now(), 5);
#--error 1062
insert into test values(4, 'error', now(), 9);
select c1,c2,c4 from test order by c1, c2;
#多行跨partition插入
insert into test values(19, 'warn', now(), 8), (20, 'warn', now(), 9), (21, 'warn', now(), 10);
select c1,c2,c4 from test order by c1, c2;
drop table test;
create table test (t datetime not null, a int, primary key (t)) partition by key(t) partitions 38;
replace into test values ('2016-1-1 1:1:1.011212', 1);
replace into test values ('2016-1-1 1:1:1.012111', 1);
select * from test;
drop table test;
create table test (u binary(12), t binary(123), primary key (t)) partition by key(t) partitions 38;
replace into test values ('hello', concat(u, "world"));
replace into test values ('hello ', concat(u, "world"));
select hex(u), hex(t) from test order by u;
drop table test;
# 测试insert的计划生成
create table test(c1 int, c2 int) partition by hash(c1) partitions 3;
--explain_protocol 1
insert into test values(1, 2), (2, 3), (3, 4), (4, 5);
--explain_protocol 0
--disable_warnings
drop table if exists test1;
--enable_warnings
create table test1(c1 int, c2 int);
insert into test1 values(1, 2), (2, 3), (3, 4), (4, 5);
--explain_protocol 1
insert into test select c1, c2 from test1;
--explain_protocol 0
drop table test;
drop table test1;
