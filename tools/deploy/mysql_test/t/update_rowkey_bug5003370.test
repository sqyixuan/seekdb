#owner: link.zt
#owner group: SQL1
--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
####
--disable_query_log
--disable_warnings
drop table if exists obupdaterowkey;
--enable_warnings
--enable_query_log


create table obupdaterowkey(pk1 int, pk2 int, pk3 int, pksum int, pksum_grp int, c1 varchar(1024), gmt_create datetime default now(), gmt_modify datetime default now(), primary key(pk1, pk2, pk3)) ;
create index obupdaterowkey1 on obupdaterowkey(pk3);
create index obupdaterowkey2 on obupdaterowkey(pksum);
create index obupdaterowkey3 on obupdaterowkey(pk1, pk2);

--disable_query_log
--disable_result_log
let $char='aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa';
let $trx_row_num=5;
let $i=0;
while($i<10)
{
        let $pk1= $i;
	let $pksum = math($i/$trx_row_num);
        let $pk2 = math($pksum - $pk1);
        let $pk3 = math($pksum%2==0? $pksum : 0-$pksum);
        let $pksum_grp = math($i % $trx_row_num);
        eval insert into obupdaterowkey(pk1, pk2, pk3, pksum, pksum_grp, c1) values($pk1, $pk2, $pk3, $pksum, $pksum_grp, $char);
        inc $i;
}
sleep 1;
--enable_result_log
--enable_query_log

select count(*) from obupdaterowkey;
connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);

connection conn1;
set autocommit=0;

update obupdaterowkey set pk1=3, pk3=1 where pk1=5 and pk2=-4 and pk3 in (1,-1);
update obupdaterowkey set pk1=4, pk3=1 where pk1=6 and pk2=-5 and pk3 in (1,-1);
update obupdaterowkey set pk1=5, pk3=1 where pk1=7 and pk2=-6 and pk3 in (1,-1);
update obupdaterowkey set pk1=6, pk3=1 where pk1=8 and pk2=-7 and pk3 in (1,-1);
update obupdaterowkey set pk1=7, pk3=1 where pk1=9 and pk2=-8 and pk3 in (1,-1);
select count(*) from obupdaterowkey;
commit;
select count(*) from obupdaterowkey;
commit;

update obupdaterowkey set pk1=5, pk3=-1 where pk1=3 and pk2=-4 and pk3 in (1,-1);
update obupdaterowkey set pk1=6, pk3=-1 where pk1=4 and pk2=-5 and pk3 in (1,-1);
update obupdaterowkey set pk1=7, pk3=-1 where pk1=5 and pk2=-6 and pk3 in (1,-1);
update obupdaterowkey set pk1=8, pk3=-1 where pk1=6 and pk2=-7 and pk3 in (1,-1);
update obupdaterowkey set pk1=9, pk3=-1 where pk1=7 and pk2=-8 and pk3 in (1,-1);
select count(*) from obupdaterowkey;
commit;
select count(*) from obupdaterowkey;
commit;

