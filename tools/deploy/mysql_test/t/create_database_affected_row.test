--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: peihan.dph
# owner group: SQL3
# description: 本case是为了测试create database/drop database时的affected row

--disable_warnings
drop database if exists d1;
drop database if exists d2;
--enable_warnings

create database d1;
--disable_warnings
create database if not exists d1;
--enable_warnings
use d1;
drop database d1;

create database d2;
use d2;
create table t(c1 int);
create table t2(c1 int);
create table t3(c1 int);
drop database d2;
--disable_warnings
drop database if exists d2;
--enable_warnings

