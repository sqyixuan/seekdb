--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: peihan.dph
# owner group: SQL3
# description: 本case是从mysqltest中摘出来的乱七八糟关于found_rows的测试
#tags: found_rows
--disable_warnings
drop table if exists test;
--enable_warnings
create table test(c1 int auto_increment primary key, c2 int, c3 int);
insert into test values(),(),(),();
#select hex(concat(found_rows()));
#select found_rows();
SELECT * FROM test;
select count(*) from test;
select found_rows();
select count(*) from test limit 2,3;
select found_rows();
select SQL_CALC_FOUND_ROWS count(*) from test limit 2,3;
select found_rows();

insert into test values(50,3,3);
select count(*) from test;
select found_rows();
select count(*) from test limit 2,3;
select found_rows();
select SQL_CALC_FOUND_ROWS count(*) from test limit 2,3;
select found_rows();

