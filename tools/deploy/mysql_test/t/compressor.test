#	dec $cnt;
#}

let $cnt=150;
while($cnt >= 50)
{
    eval replace into t4 values($cnt,'$cnt$cnt$cnt$cnt$cnt$cnt$cnt$cnt$cnt','$cnt$cnt$cnt$cnt$cnt$cnt$cnt$cnt$cnt$cnt$cnt$cnt');
    dec $cnt;
}

let $cnt=150;
while($cnt >= 50)
{
    eval replace into t5 values($cnt,'$cnt$cnt$cnt$cnt$cnt$cnt$cnt$cnt$cnt','$cnt$cnt$cnt$cnt$cnt$cnt$cnt$cnt$cnt$cnt$cnt$cnt');
    dec $cnt;
}

--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
#--source mysql_test/include/wait_daily_merge.inc

select * from t1;
select * from t1 where c1=1;
select * from t1 where c1=100;

select * from t2;
select * from t2 where c1=1;
select * from t2 where c1=100;

