--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: bin.lb
# owner group: SQL2
# tags: ddl
# description:
#
--disable_query_log
--source mysql_test/include/index_quick_major.inc
--real_sleep 1
--disable_warnings
drop table if exists t1,t2,t3,t4,t5;
--enable_warnings
--enable_query_log

create table t1(c1 int primary key, c2 varchar(65536), c3 varchar(65536));
create table t2(c1 int primary key, c2 varchar(65536), c3 varchar(65536)) COMPRESSION='snappy_1.0';
#create table t3(c1 int primary key, c2 varchar(65536), c3 varchar(65536)) COMPRESSION='lzo_1.0';
create table t4(c1 int primary key, c2 varchar(65536), c3 varchar(65536)) COMPRESSION='lz4_1.0';
create table t5(c1 int primary key, c2 varchar(65536), c3 varchar(65536)) COMPRESSION='zstd_1.0';

let $cnt=100;
while($cnt)
{
	eval insert into t1 values($cnt,'$cnt$cnt$cnt$cnt$cnt$cnt$cnt$cnt','$cnt$cnt$cnt$cnt$cnt$cnt$cnt$cnt$cnt$cnt$cnt');
	dec $cnt;
}

let $cnt=100;
while($cnt)
{
	eval insert into t2 values($cnt,'$cnt$cnt$cnt$cnt$cnt$cnt$cnt$cnt','$cnt$cnt$cnt$cnt$cnt$cnt$cnt$cnt$cnt$cnt$cnt');
	dec $cnt;
}

#let $cnt=100;
#while($cnt)
#{
#	eval insert into t3 values($cnt,'$cnt$cnt$cnt$cnt$cnt$cnt$cnt$cnt','$cnt$cnt$cnt$cnt$cnt$cnt$cnt$cnt$cnt$cnt$cnt');
#	dec $cnt;
#}

let $cnt=100;
while($cnt)
{
    eval insert into t4 values($cnt,'$cnt$cnt$cnt$cnt$cnt$cnt$cnt$cnt','$cnt$cnt$cnt$cnt$cnt$cnt$cnt$cnt$cnt$cnt$cnt');
    dec $cnt;
}

let $cnt=100;
while($cnt)
{
    eval insert into t5 values($cnt,'$cnt$cnt$cnt$cnt$cnt$cnt$cnt$cnt','$cnt$cnt$cnt$cnt$cnt$cnt$cnt$cnt$cnt$cnt$cnt');
    dec $cnt;
}

--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
#--source mysql_test/include/wait_daily_merge.inc
sleep 20;

select * from t1;
select * from t1 where c1=1;
select * from t1 where c1=100;

select * from t2;
select * from t2 where c1=1;
select * from t2 where c1=100;

#select * from t3;
#select * from t3 where c1=1;
#select * from t3 where c1=100;

select * from t4;
select * from t4 where c1=1;
select * from t4 where c1=100;

select * from t5;
select * from t5 where c1=1;
select * from t5 where c1=100;

alter table t1 set COMPRESSION = 'zstd_1.0';
alter table t2 set COMPRESSION = 'zstd_1.0';
#alter table t3 set COMPRESSION = 'zstd_1.0';
alter table t4 set COMPRESSION = 'zstd_1.0';
alter table t5 set COMPRESSION = 'snappy_1.0';

let $cnt=150;
while($cnt >= 50)
{
	eval replace into t1 values($cnt,'$cnt$cnt$cnt$cnt$cnt$cnt$cnt$cnt$cnt','$cnt$cnt$cnt$cnt$cnt$cnt$cnt$cnt$cnt$cnt$cnt$cnt');
	dec $cnt;
}

let $cnt=150;
while($cnt >= 50)
{
	eval replace into t2 values($cnt,'$cnt$cnt$cnt$cnt$cnt$cnt$cnt$cnt$cnt','$cnt$cnt$cnt$cnt$cnt$cnt$cnt$cnt$cnt$cnt$cnt$cnt');
	dec $cnt;
}

