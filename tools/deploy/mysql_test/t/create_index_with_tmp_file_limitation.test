#owner : wendongbodongbo.wdb
#owner group: storage
#description: 测试配置项temporary_file_max_disk_size能否限制临时文件落盘(设置后需要10s生效)

set ob_query_timeout = 1000000000;
--disable_warnings
drop table if exists test_create_index;
drop sequence if exists s1;
--enable_warnings

create table test_create_index(c1 int, c2 varchar(1024), c3 varchar(1024), c4 varchar(1024), c5 varchar(1024));
create sequence s1 cache 1000000 noorder;
insert into test_create_index select s1.nextval c1, randstr(1024, random()) c2, randstr(1024, random()) c3, randstr(1024, random()) c4, randstr(1024, random()) c5 from table(generator(100000));

alter system set _temporary_file_io_area_size = 0;
alter system set temporary_file_max_disk_size = '1M';
select sleep(10);
--error 9135
create index i1 on test_create_index (c1, c2, c3, c4, c5);

alter system set _temporary_file_io_area_size = 30;
alter system set temporary_file_max_disk_size = '512GB';
select sleep(10);
create index i1 on test_create_index (c1, c2, c3, c4, c5);

alter system set _temporary_file_io_area_size = 1;
alter system set temporary_file_max_disk_size = '10M';
select sleep(10);
drop index i1 on test_create_index;
--error 9135
create index i1 on test_create_index (c1, c2, c3, c4, c5);

drop table test_create_index;
alter system set temporary_file_max_disk_size = '0M';
alter system set _temporary_file_io_area_size = 1;

