--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

#owner: linlin.xll
#owner group:
#description: 处理添加新列时默认值处理错误问题
#tags: ddl

--disable_warnings
drop table if exists test;
--enable_warnings

select @@sql_mode;

create table test(col1 int);
insert into test values(1);
alter table test add column col2 char not null;
alter table test add column col3 varchar(10) not null;
alter table test add column col4 varbinary(10) not null;

alter table test add column col5 char not null default '';
alter table test add column col6 varchar(10) not null default '';
alter table test add column col7 varbinary(10) not null default '';

alter table test add column col8 char not null default 'n';
alter table test add column col9 varchar(10) not null default 'nvl';
alter table test add column col10 varbinary(10) not null default 'nvl';

alter table test add column col11 char default NULL;
alter table test add column col12 varchar(10) default NULL;
alter table test add column col13 varbinary(10) default NULL;

alter table test add column col14 char;
alter table test add column col15 varchar(10);
alter table test add column col16 varbinary(10);

select * from test;

drop table test;



