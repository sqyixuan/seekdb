#owner: yibo.tyf
#owner group: SQL1
--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
####TITLE:并发事务compound子句
--disable_query_log
--source mysql_test/include/index_quick_major.inc
--real_sleep 1
--disable_warnings
drop table if exists t1;
--enable_warnings
--enable_query_log

create table t1 (pk int primary key, key1 int, v1 varchar(50), t1  timestamp(6) default "2012-01-01 12:00:00");
create index i1 on t1(key1) storing(v1);

--source mysql_test/include/check_all_idx_ok.inc
select * from t1;
let $idx = query_get_value(select a.table_name from oceanbase.__all_virtual_table as a inner join (select * from oceanbase.__all_virtual_table where table_name='t1') b on a.data_table_id=b.table_id, table_name, 1);
--disable_query_log
eval select * from $idx;
--enable_query_log


connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn2,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);

####CASE: 事务2 compoud子句更新，事务1读
connection conn1;
set autocommit=0;
insert into t1 values(1,1,'a','2013-12-10'),(2,2,'b','2013-12-11'),(3,3,'c','2013-12-12'),(4,4,'d','2013-12-13');
commit;

## 事务1 select
prepare trx1stmt1 from select key1, v1 from t1 where key1>? and key1<?;
prepare trx1stmt2 from select * from t1 where pk>? and pk<?;
prepare trx1stmt3 from select * from t1 where key1>? and key1<?;
set @s11=0;
set @s12=100;
execute trx1stmt1 using @s11, @s12;
execute trx1stmt2 using @s11, @s12;
execute trx1stmt3 using @s11, @s12;

## 事务2 update compound未提交
connection conn2;
set autocommit=0;
prepare trx2stmt1 from select * from t1 where pk=? for update when row_count(update t1 set v1=? where pk=? when row_count(insert into t1 values(?,?,?,?)) =1) = 1;
prepare trx2utmt1 from update t1 set v1=? where pk=? when row_count(insert into t1 values(?,?,?,?))=0;

set @s1=1;
set @s2='when-select-update-insert1';
set @s3=5;
set @s4='when-select-update-insert2';
set @s5='2013-12-16';
execute trx2stmt1 using @s1,@s2,@s1,@s3,@s3,@s4,@s5;

set @u1='when-update-insert1';
set @u2=2;
set @u3='when-update-insert2';
set @u4='2013-12-16';
--error 1062
execute trx2utmt1 using @u1,@u2,@u2,@u2,@u3,@u4;

##事务1 select
connection conn1;
execute trx1stmt1 using @s11, @s12;
execute trx1stmt2 using @s11, @s12;
execute trx1stmt3 using @s11, @s12;

##事务2 提交
connection conn2;
commit;

## 事务1 select 
connection conn1;
execute trx1stmt1 using @s11, @s12;
execute trx1stmt2 using @s11, @s12;
execute trx1stmt3 using @s11, @s12;
commit;

## 事务1 提交后，可读取到最新数据
execute trx1stmt1 using @s11, @s12;
execute trx1stmt2 using @s11, @s12;
execute trx1stmt3 using @s11, @s12;
commit;
## 索引表和数据表一致性验证
--disable_query_log
eval select * from $idx;
--enable_query_log

select * from t1;
commit;
drop table t1;

