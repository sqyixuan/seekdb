connect (obsys,$OBMYSQL_MS0,root,,oceanbase,$OBMYSQL_PORT);
connection obsys;
alter system set enable_sys_table_ddl = true;
set @@session.ob_query_timeout = 100000000;
alter system upgrade virtual schema;
--disable_warnings
drop view oceanbase.v$ob_memstore;
--enable_warnings

--source mysql_test/include/check_schema_sync.inc
connection obsys;
--error 1146
select * from oceanbase.v$ob_memstore limit 1;

connection obsys;
set @@session.ob_query_timeout = 100000000;
alter system upgrade virtual schema;
alter system set enable_sys_table_ddl = false;
