--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: zhanyue.zzys
##owner group: sql1
#tags: optimizer, update
##description: Test like operator goes index

##
## Test str_col like 'xxx%' goes index
##

let $loop=1;
# 1 -- select
# 2 -- select for update
# 3 -- update .. limit
# 4 -- delete .. limit
set sql_mode="";
while($loop <= 4)
{
	let $flag_prepare = 0;
	let $flag_verify = 0;
	let $dml_head = ;
	let $dml_tail = ;
	let $dml_prepare = ;
	let $dml_verify = ;
  if ( $loop == 1 )
	{
		--echo -- ========================= SELECT ====================================================================================
		let $dml_head = SELECT * FROM t1;
		# Prepare data
		--disable_warnings
		drop table if exists t1;
		--enable_warnings
		create table t1 (a bigint primary key, b char(100) , c char(100) , d char(100) , e char(100) ,  key i1(b) , unique index i2(c,d,e));
		insert into t1 values(1,'aaaa','aaaa','aaaa','aaaa'),(2,'xxxc','xxxb','xxxb','xxxb'),(3,'xxxb','xxxc','xxxc','xxxc'),(4,'xxxa','xxxa','xxxa','xxxa'),(5,'zzzz','zzzz','zzzz','zzzz'),(6,NULL,NULL,'xxxa','xxxa'),(7,'zxxx','zxxx','zxxx','zxxx'),(8,'axxx','axxx','axxx','axxx'),(9,'zaaz','zaaz','zaaz','zaaz'),(10,'zbbz','zbbz','zbbz','zbbz');
	}
	if ( $loop == 2 )
	{
		--echo -- ========================= SELECT FOR UPDATE ====================================================================================
		let $dml_head = SELECT * FROM t1;
#bug! bug! bug! 
#		let $dml_tail = FOR UPDATE;
		# Prepare data
		drop table if exists t1;
		create table t1 (a bigint primary key, b char(100) , c char(100) , d char(100) , e char(100) ,  key i1(b) , unique index i2(c,d,e) , index i3(c));
		insert into t1 values(1,'aaaa','aaaa','aaaa','aaaa'),(2,'xxxc','xxxb','xxxb','xxxb'),(3,'xxxb','xxxc','xxxc','xxxc'),(4,'xxxa','xxxa','xxxa','xxxa'),(5,'zzzz','zzzz','zzzz','zzzz'),(6,NULL,NULL,'xxxa','xxxa'),(7,'zxxx','zxxx','zxxx','zxxx'),(8,'axxx','axxx','axxx','axxx'),(9,'zaaz','zaaz','zaaz','zaaz'),(10,'zbbz','zbbz','zbbz','zbbz');
	}
	if ( $loop == 3 )
	{
		--echo -- ========================= UPDATE ... LIMIT ====================================================================================
		let $dml_head = UPDATE t1 SET b=CONCAT(b,'_update');
		let $dml_tail = LIMIT 2;
		let $dml_prepare = replace into t1 values(1,'aaaa','aaaa','aaaa','aaaa'),(2,'xxxc','xxxb','xxxb','xxxb'),(3,'xxxb','xxxc','xxxc','xxxc'),(4,'xxxa','xxxa','xxxa','xxxa'),(5,'zzzz','zzzz','zzzz','zzzz'),(6,NULL,NULL,'xxxa','xxxa'),(7,'zxxx','zxxx','zxxx','zxxx'),(8,'axxx','axxx','axxx','axxx'),(9,'zaaz','zaaz','zaaz','zaaz'),(10,'zbbz','zbbz','zbbz','zbbz');
		let $dml_verify = SELECT * FROM t1;
		let $flag_verify = 1;
		let $flag_prepare = 1;
	}
	if ( $loop == 4 )
