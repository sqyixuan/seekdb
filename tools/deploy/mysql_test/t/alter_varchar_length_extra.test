--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: bin.lb
# owner group: SQL2
# tags: alter
# description:
#
##TEST 1
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(pk1 varchar(10) not null, 
				pk2 varchar(10) default 'a',
				pk3 varchar(10) default 'aa' not null, 
				v1 varchar(10) default 'aaa', 
				v2 varchar(10) not null, 
				v3 varchar(10) default 'aaaa' not null,
				primary key(pk1,pk2,pk3));

insert into t1(pk1,pk3,v1,v2,v3) values('a','cc','ddd','eeee','fffff');
insert into t1(pk1,pk2,v1,v2,v3) values('a1','bb1','ddd1','eeee1','fffff1'),('a2','aaaa','aaa','eeee2','fffff2');
insert into t1(pk1,v2) values('a3','eeee3');

select * from t1;
desc t1;

alter table t1 modify column pk1 varchar(11);
sleep 1;
desc t1;

alter table t1 modify column v2 varchar(11) not null;
sleep 1;
desc t1;

alter table t1 modify column pk2 varchar(11);
sleep 1;
desc t1;
alter table t1 alter pk2 set default 'a';
sleep 1;
desc t1;
alter table t1 modify column pk2 varchar(11) default 'a';
sleep 1;
desc t1;

alter table t1 modify column pk3 varchar(11);
sleep 1;
desc t1;

alter table t1 modify column v3 varchar(11) not null;
sleep 1;
desc t1;
alter table t1 alter v3 set default 'aaaa';
sleep 1;
desc t1;
alter table t1 modify column pk2 varchar(11) default 'aaaa';
sleep 1;
desc t1;

drop table t1;

##TEST 2
create table t1(pk varchar(10) primary key, v1 varchar(10), v2 varchar(10));
create index idx_t1 on t1(v2);
--let $cnt=1
while($cnt<=20)
{
	eval alter table t1 modify column pk varchar(1$cnt);
	sleep 1;
	desc t1;
	inc $cnt;
}

--let $cnt=1
while($cnt<=20)
{
	eval alter table t1 modify column v1 varchar(1$cnt);
	sleep 1;
	desc t1;
	inc $cnt;
}

--let $cnt=1
while($cnt<=20)
{
	eval alter table t1 modify column v2 varchar(1$cnt);
	sleep 1;
	desc t1;
	inc $cnt;
}


