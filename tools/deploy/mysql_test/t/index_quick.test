--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: bin.lb
# owner group: SQL3
# description:
# tags: index, ddl
--disable_query_log
--source mysql_test/include/index_quick_major.inc
--real_sleep 1
--disable_warnings
drop table if exists t1;
--enable_warnings
--enable_query_log

set @@ob_enable_index_direct_select = 1;

create table t1(id int primary key, name varchar(64), age int, description varchar(64));
create index i1 on t1(age) storing(name);
create index i2 on t1(name) storing(age);
replace into t1 (id, name, age, description) values (1,'name1',30,'rd'),(2,'name2',27,'rd'),(3,'name3',25,'rd'),(4,'name4',24,'rd');

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
let $data_table_id = query_get_value(select * from oceanbase.__all_virtual_table where table_name = 't1', table_id, 1);
let $index_1 = query_get_value(select * from oceanbase.__all_virtual_table where table_type = 5 and data_table_id = $data_table_id, table_name, 1);
let $index_2 = query_get_value(select * from oceanbase.__all_virtual_table where table_type = 5 and data_table_id = $data_table_id, table_name, 2);
disconnect obsys;
connection default;

select * from t1;


--source mysql_test/include/check_all_idx_ok.inc
--disable_query_log
set ob_enable_index_direct_select=1;
eval select * from $index_1;
eval select * from $index_2;
--enable_query_log

--let $count = 30
while($count < 35)
{
  --let $stmt=insert into t1(id, name, age, description) values ($count, 'name33', 330, 'rd2')
  eval $stmt;
  inc $count;
}

--disable_query_log
eval select * from $index_1;
eval select * from $index_2;
--enable_query_log
create index i3 on t1(age) storing(name);
create index i4 on t1(name) storing(age);

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
let $index_3 = query_get_value(select * from oceanbase.__all_virtual_table where table_type = 5 and data_table_id = $data_table_id , table_name, 3);
let $index_4 = query_get_value(select * from oceanbase.__all_virtual_table where table_type = 5 and data_table_id = $data_table_id, table_name, 4);
disconnect obsys;
connection default;
#bug 651240   by design
--disable_query_log
#--error 1082
#eval select * from $index_3;
#--error 1082
#eval select * from $index_4;
--enable_query_log

--source mysql_test/include/check_all_idx_ok.inc

--disable_query_log
set ob_enable_index_direct_select=1;
eval select * from $index_3;
eval select * from $index_4;
--enable_query_log
--let $count = 40
while($count < 45)
{
  --let $stmt=replace into t1(id, name, age, description) values ($count, 'name33', 330, 'rd2')
  eval $stmt;
  inc $count;
}
--disable_query_log
eval select * from $index_3;
eval select * from $index_4;
--enable_query_log

drop table t1;
