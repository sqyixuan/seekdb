--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: link.zt
#owner group: sql1

--source mysql_test/include/index_quick_major.inc
--real_sleep 5
--enable_query_log
--source  mysql_test/include/a_trade_schema_drop.inc
--source  mysql_test/include/a_trade_schema_create.inc
--echo merge happens
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
--source mysql_test/include/check_all_idx_during_major_freeze_ok.inc
insert into business_activity_000(tx_id,state,account_trans_state,gmt_create,gmt_modified) values ('001001-2012091400001000440001838118', 'I', 'I', now(),now());
select tx_id,state,account_trans_state from business_activity_000 where (tx_id ='001001-2012091400001000440001838118');
select /* QUERY_TIMEOUT(15000000) */ count(*) from business_activity_async_000 where ((state = 'I') AND (gmt_create < date_sub(current_timestamp(), INTERVAL 1 MINUTE) and gmt_modified >= date_sub(current_timestamp(), INTERVAL 6 MINUTE)));
delete from business_activity_async_000 where (state = 'I' AND (gmt_create < date_sub(current_timestamp(), INTERVAL 120 MINUTE) and gmt_create >= date_sub(current_timestamp(), INTERVAL 125 MINUTE) ) );
select tx_id,state,account_trans_state,context from business_activity_000 where (tx_id = '001001-2012091400001000440001838118') for update nowait;
update business_activity_000 set state='I', gmt_modified=NOW() where (tx_id ='001001-2012091400001000440001838118');
select /* QUERY_TIMEOUT(15000000) */ tx_id,state,account_trans_state,context from business_activity_000  where (state IN ('I', 'C','U')) AND (gmt_modified < date_sub(current_timestamp(), INTERVAL 1 MINUTE) and gmt_modified >= date_sub(current_timestamp(), INTERVAL 6 MINUTE))  limit  100;
select /* QUERY_TIMEOUT(15000000) */ count(*) from business_activity_000 where ((state IN ('I', 'C','U')) AND (gmt_create < date_sub(current_timestamp(), INTERVAL 1 MINUTE)  and gmt_modified >= date_sub(current_timestamp(), INTERVAL 6 MINUTE)));
select /* QUERY_TIMEOUT(15000000) */ count(*) from business_activity_000 where ((state IN ('I', 'C','U')) AND (gmt_create < date_sub(current_timestamp(), INTERVAL -1 MINUTE)  and gmt_modified >= date_sub(current_timestamp(), INTERVAL 6 MINUTE)));


