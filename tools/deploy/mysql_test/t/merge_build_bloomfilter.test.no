--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: zhonghuai.hyk
# owner group: storage
# description: 测试合并时自适应主键前缀空读构建对应的bloomfilter

connect (my_obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection default;

let $query_check12 = select a.table_name, b.partition_id, b.rowkey_prefix_access_info from oceanbase.__all_virtual_table a, oceanbase.__all_virtual_partition_table_store_stat b where a.table_id = b.table_id and a.table_name in('t_bloom_1', 't_bloom_2') order by 1;
let $query_check3  = select a.table_name, b.partition_id, b.rowkey_prefix_access_info from oceanbase.__all_virtual_table a, oceanbase.__all_virtual_partition_table_store_stat b where a.table_id = b.table_id and a.table_name in('t_bloom_3') order by 1;
let $query_check4  = select a.table_name, b.partition_id, b.rowkey_prefix_access_info from oceanbase.__all_virtual_table a, oceanbase.__all_virtual_partition_table_store_stat b where a.table_id = b.table_id and a.table_name in('t_bloom_4') order by 1;

--disable_query_log
--source mysql_test/include/index_quick_major.inc
--real_sleep 1
--disable_warnings
drop table if exists t_bloom_1;
drop table if exists t_bloom_2;
--enable_warnings
--enable_query_log

##prepare base sstable
--echo **** prepare base sstable
# default close bloomfilter, control group
create table t_bloom_1 (
  c1 int,
  c2 int,
  c3 int,
  c4 int,
  c5 int,
  primary key (c1, c2, c3, c4)
) progressive_merge_num = 1;

# open bloomfilter, single/muti insert, rowkey_prefix=4
create table t_bloom_2 (
  c1 int,
  c2 int,
  c3 int,
  c4 int,
  c5 int,
  primary key (c1, c2, c3, c4)
) progressive_merge_num = 1  use_bloom_filter = true;

# open bloomfilter, muti insert, rowkey_prefix=3
create table t_bloom_3 (
  c1 int,
  c2 int,
  c3 int,
  c4 int,
  c5 int,
  primary key (c1, c2, c3, c4)
) progressive_merge_num = 1  use_bloom_filter = true;

# open bloomfilter, scan, rowkey_prefix=2
create table t_bloom_4 (
  c1 int,
  c2 int,
  c3 int,
  c4 int,
  c5 int,
  primary key (c1, c2, c3, c4)
) progressive_merge_num = 1  use_bloom_filter = true;

insert into t_bloom_1 values (1,1,1,1,1), (9999999,1,1,1,1);
insert into t_bloom_2 values (1,1,1,1,1), (9999999,1,1,1,1);
insert into t_bloom_3 values (1,1,1,1,1), (9999999,1,1,1,1);
insert into t_bloom_4 values (1,1,1,1,1), (9999999,1,1,1,1);
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc


--echo **** prepare empty read
--disable_result_log
--disable_query_log
#prepare empty read to trigger the building of bloom filter
let $pkey=0;
while($pkey < 110)
{
  eval insert into t_bloom_1 values (521,$pkey,1,1,1);
  eval insert into t_bloom_2 values (521,$pkey,1,1,1);
  eval insert into t_bloom_3 values (531,$pkey,1,1,1), (531,$pkey,1,2,1), (531,$pkey,1,3,1), (531,$pkey,1,4,1);
  eval select * from t_bloom_4 where c1 = 541 and c2 = $pkey;
  inc $pkey;
}
--real_sleep 1
while($pkey < 120)
{
  eval insert into t_bloom_1 values (521,$pkey,1,1,1);
  eval insert into t_bloom_2 values (521,$pkey,1,1,1);
  eval insert into t_bloom_3 values (531,$pkey,1,1,1), (531,$pkey,1,2,1), (531,$pkey,1,3,1), (531,$pkey,1,4,1);
  eval select * from t_bloom_4 where c1 = 541 and c2 = $pkey;
  inc $pkey;
}
--enable_query_log
--enable_result_log

--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc

#test1, single insert : t_bloom_2 has bloomfilter with rowkey_prefix=4
connection default;
insert into t_bloom_1 values (522,1,1,1,1);
insert into t_bloom_2 values (522,1,1,1,1);
connection my_obsys;
eval $query_check12;

#test2, muti insert: t_bloom_2 has bloomfilter with rowkey_prefix=4
connection default;
insert into t_bloom_1 values (523,2,1,1,1), (524,2,1,1,1), (525,2,1,1,1), (526,2,1,1,1);
insert into t_bloom_2 values (523,2,1,1,1), (524,2,1,1,1), (525,2,1,1,1), (526,2,1,1,1);
connection my_obsys;
eval $query_check12;

#test3, muti insert: t_bloom_3 has bloomfilter with rowkey_prefix=3
connection default;
insert into t_bloom_3 values (532,1,1,1,1), (532,1,1,2,1), (532,1,1,3,1), (532,1,1,4,1);
connection my_obsys;
eval $query_check3;


#test4, scan: t_bloom_4 has bloomfilter with rowkey_prefix=2
connection default;
select * from t_bloom_4 where c1 = 542 and c2 = 1;
connection my_obsys;
eval $query_check4;

connection default;
drop table t_bloom_1;
drop table t_bloom_2;
drop table t_bloom_3;
drop table t_bloom_4;