(0xffffffffffff8000, 0xffffffff, 0xffffff, 0xffff, 0xff, 9),
(0xffffffffffff7FFF, 0xffffffff, 0xffffff, 0xffff, 0xff, 10),
(0xffffffff80000000, 0xffffffff, 0xffffff, 0xffff, 0xff, 11),
(0xffffffff7FFFFFFF, 0xffffffff, 0xffffff, 0xffff, 0xff, 12);

