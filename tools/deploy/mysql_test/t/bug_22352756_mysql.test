--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: dachuan.sdc
# owner group: sql2
# tags: ddl
# desc: 使用查询建表，且查询语句中列的类型是枚举时，建表出错
# issue: 

--disable_warnings
drop table if exists t1, t2, t3, t4, t5, t6;
--enable_warnings

create table t1 (c1 enum('dog', 'cat'), c2 set('book', 'notebook'));
insert into t1 values ('dog', 'book');
insert into t1 values ('cat', 'book,notebook');
insert into t1 values ('cat', '');

create table t2 as select c1 from t1;
desc t2;
select * from t2;

--echo

create table t3 as select c2 from t1;
desc t3;
select * from t3;

--echo

create table t4 as select * from t1;
desc t4;
select * from t4;

--echo

create table t5 (c1 int) as select * from t1;
desc t5;
select * from t5;

--echo

create table t6 (c0 int) as select * from t1;
desc t6;
select * from t6;
