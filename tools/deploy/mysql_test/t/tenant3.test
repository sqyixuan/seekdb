--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner : yuchen.wyc
#owner group : sql1

--disable_warnings
connect (my_obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection my_obsys;
drop tenant if exists tt1 force;
eval create resource unit if not exists box_ym max_cpu 1, memory_size '1G';
let $zone_name=query_get_value(select zone from oceanbase.__all_zone where zone != '' limit 1, zone, 1);
eval create resource pool if not exists pool_ym unit = 'box_ym', unit_num = 1, zone_list = ('$zone_name');
eval create tenant tt1 replica_num = 1, primary_zone='$zone_name', resource_pool_list=('pool_ym') set ob_tcp_invited_nodes='%';
--source mysql_test/include/check_tenant_sync.inc
--enable_warnings

let $__tenant_name__ = 'tt1';
--source mysql_test/include/get_tenant_server.inc
connect (conn1,$TE_SERVER_IP,root@tt1,,*NO-ONE*,$TE_SERVER_PORT);

show tenant;
show databases;
use test;
create table t1(c1 int,c2 int);
connection conn1;
show tables;
insert into t1 values(1,1),(2,2),(3,3);
select * from t1;
create database rtt;
show databases;
connection my_obsys;
drop tenant tt1 force;
eval create tenant `tenant\1a'bbb` replica_num = 1, primary_zone='$zone_name', resource_pool_list=('pool_ym') set ob_tcp_invited_nodes='%';
select tenant_name from oceanbase.__all_tenant order by tenant_id desc limit 1;
drop tenant `tenant\1a'bbb` force;
eval create tenant tt1 replica_num = 1, primary_zone='$zone_name', resource_pool_list=('pool_ym'),comment='aaaaaaaa' set ob_tcp_invited_nodes='%';
--source mysql_test/include/check_tenant_sync.inc
select info from oceanbase.__all_tenant where tenant_name='tt1';
alter tenant tt1 comment 'bbbb';
select info from oceanbase.__all_tenant where tenant_name='tt1';
drop tenant tt1 force;
drop resource pool pool_ym;
drop resource unit box_ym;

eval create resource unit `unit\1aaa'bbbb` max_cpu 1, memory_size '1G';
select name from oceanbase.__all_unit_config order by unit_config_id desc limit 1;
drop resource unit `unit\1aaa'bbbb`;
eval create resource unit box_ym max_cpu 1, memory_size '1G';
let $zone_name=query_get_value(select zone from oceanbase.__all_zone where zone != '' limit 1, zone, 1);
eval create resource pool `pool\1aaabbb` unit = 'box_ym', unit_num = 1, zone_list = ('$zone_name');
select name from oceanbase.__all_resource_pool order by resource_pool_id desc limit 1;
drop resource pool `pool\1aaabbb`;
drop resource unit box_ym;
use test;
create table `tesa\1aa` (c1 int,c2 int);
show tables like '%tesa%';
drop table `tesa\1aa`;
create table t1 (c1 int,c2 int);
insert into t1 values(1,1);
select * from t1;
alter table t1 change c2 `aaa\1bb'cc` int;
select * from t1;
drop table t1;
#drop resource pool `pool\1aaabbb`;
#drop resource unit `unit\1aaa'bbbb`;
