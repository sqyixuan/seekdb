--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: peihan.dph
# owner group: SQL3
# description: 本case是为了测试各种ddl/dml语句对found_rows的影响；
#tags:found_rows

--disable_warnings
drop database if exists found_rows;
drop table if exists test, test2;
--enable_warnings
--disable_query_log
create database found_rows;
use found_rows;
create table test(c1 int, c2 int);
--enable_query_log
create table test2(c1 int, c2 int);
insert into test values(1,2),(2,3),(3,4),(4,5);
--disable_query_log
--disable_result_log
select * from test;
select found_rows();
--enable_result_log
let $select_example=select * from test;
let $expect=4;

let $query_stmt=alter table test add column c3 int;
--source mysql_test/include/found_rows2.inc

let $query_stmt=create view v as select * from test;
--source mysql_test/include/found_rows2.inc
#let $query_stmt=alter view v as select c1,c2 from test;
#--source mysql_test/include/found_rows2.inc

#let $query_stmt=create trigger tr after insert on test for each row delete from test;
#--source mysql_test/include/found_rows2.inc
let $query_stmt=create database if not exists found_rows2;
--source mysql_test/include/found_rows2.inc

let $query_stmt=drop database found_rows2;
--source mysql_test/include/found_rows2.inc
#let $query_stmt=create event if not exists ev on schedule AT CURRENT_TIMESTAMP + INTERVAL 1 HOUR DO update test set c2 = c2 + 1;
#--source mysql_test/include/found_rows2.inc
#let $query_stmt=drop event ev;
#--source mysql_test/include/found_rows2.inc


#let $query_stmt=create function func (s char(20)) returns char(50) deterministic return concat('Hellp', s, '!');
#--source mysql_test/include/found_rows2.inc
#let $query_stmt=drop function func;
#--source mysql_test/include/found_rows2.inc

let $query_stmt=create index idx on test(c2);
--source mysql_test/include/found_rows2.inc
let $query_stmt=drop index idx on test;
--source mysql_test/include/found_rows2.inc
let $query_stmt=drop table test2;
--source mysql_test/include/found_rows2.inc
#let $query_stmt=drop trigger tr;
#--source mysql_test/include/found_rows2.inc
create table test2(c2 int);
--disable_query_log
let $query_stmt=rename table test2 to tt;
--source mysql_test/include/found_rows2.inc
let $query_stmt=truncate table tt;
--source mysql_test/include/found_rows2.inc
####################
#dml语句的影响；
#
################
let $query_stmt=delete from tt;
--source mysql_test/include/found_rows2.inc
#let $query_stmt=do sleep(5);
#--source mysql_test/include/found_rows2.inc
#select * from test;
#do sleep(5);
#select found_rows();

let $query_stmt=insert into tt values(3),(2);
--source mysql_test/include/found_rows2.inc
let $query_stmt=replace into tt values(3),(2),(4);
--source mysql_test/include/found_rows2.inc
let $query_stmt=select * from tt;
--source mysql_test/include/found_rows2.inc
let $query_stmt=SELECT * FROM test WHERE c1 in (SELECT c1 FROM tt);
--source mysql_test/include/found_rows2.inc
let $query_stmt=update tt set c2 = c2 + 3;
--source mysql_test/include/found_rows2.inc


###############
##
##TRANSACTION AND LOCKING
##
##############
let $query_stmt=start transaction;
--source mysql_test/include/found_rows2.inc
let $query_stmt=commit;
--source mysql_test/include/found_rows2.inc
let $query_stmt=start transaction;
--source mysql_test/include/found_rows2.inc
let $query_stmt=rollback;
--source mysql_test/include/found_rows2.inc
let $query_stmt=set transaction read only;
--source mysql_test/include/found_rows2.inc
let $query_stmt=commit;
--source mysql_test/include/found_rows2.inc
