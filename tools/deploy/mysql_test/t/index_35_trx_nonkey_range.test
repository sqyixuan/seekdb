--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: laibingzheng.lbz
#owner group: SQL1
#tags: dml, insert
#description: Test index without key range
####TITEL:
####table with index, 
####update range and delete range scan
####one of rowkey or idxs are used aswhere condition

--disable_query_log
--source mysql_test/include/index_quick_major.inc
--real_sleep 1
--disable_warnings
drop table if exists t1;
--enable_warnings
set global ob_enable_index_direct_select =1;
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
alter system set merger_check_interval = '10s' tenant sys;
alter system set merger_check_interval = '10s' tenant all_user;
alter system set merger_check_interval = '10s' tenant all_meta;
alter system set _lcl_op_interval = '0ms';
disconnect obsys;
connection default;
--enable_query_log

connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (trx1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (trx2,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);

connection conn1;
create table t1(pk1 int, pk2 int, c1 int, c2 int, primary key(pk1,pk2));
insert into t1(pk1,pk2,c1,c2) values(1,1,1,1);
insert into t1(pk1,pk2,c1,c2) values(1,2,1,1);
insert into t1(pk1,pk2,c1,c2) values(1,3,1,1);
insert into t1(pk1,pk2,c1,c2) values(1,4,1,1);
insert into t1(pk1,pk2,c1,c2) values(1,5,2,1);
insert into t1(pk1,pk2,c1,c2) values(1,6,2,1);
insert into t1(pk1,pk2,c1,c2) values(1,7,2,1);
insert into t1(pk1,pk2,c1,c2) values(1,8,2,1);

create index i1 on t1(c1,c2);
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
let $idx1 = query_get_value(select a.table_name from oceanbase.__all_virtual_table as a inner join (select * from oceanbase.__all_virtual_table where table_name='t1') b on a.data_table_id=b.table_id, table_name, 1);
disconnect obsys;
connection default;


--source mysql_test/include/check_all_idx_ok.inc

connection conn1;
select * from t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log

####CASE: =
connection trx1;
set autocommit=0;
update t1 set c2=c2+1 where pk1=1;
select * from t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log

connection trx2;
set autocommit=0;
--error 1205,4012
update t1 set c2=c2+1 where c1=1;
select * from t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log

connection trx1;
select * from t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log
update t1 set c2=c2+1 where c1=1;
select * from t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log
commit;

connection trx2;
select * from t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log
update t1 set c2=c2+1 where c1=1;
update t1 set c2=c2+1 where c1=2;
select * from t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log
commit;

####CASE: >, <
connection conn1;
delete from t1;
insert into t1(pk1,pk2,c1,c2) values (1,1,1,1),(2,2,2,1),(3,3,3,1),(4,4,4,1),(5,5,5,1),(6,6,6,1),(7,7,7,1),(8,8,8,1);
select * from t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log

connection trx1;
update t1 set c2=c2+1 where pk1<5;
select * from t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log

connection trx2;
update t1 set c2=c2+1 where c1>4;
select * from t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log
--error 1205,4012
update t1 set c2=c2+1 where pk1<5;

connection trx1;
select * from t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log
--error 1205,4012
update t1 set c2=c2+1 where pk1>4;
commit;
select * from t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log
commit;

connection trx2;
select * from t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log
update t1 set c2=c2+1 where pk1<5;
select * from t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log
commit;
select * from t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log
commit;

####CASE: pk and idx scan, 5048
connection conn1;
delete from t1;
insert into t1(pk1,pk2,c1,c2) values (1,1,1,1),(1,2,2,1),(1,3,3,1),(1,4,4,1),(2,5,5,1),(2,6,6,1),(2,7,7,1),(2,8,8,1);
select * from t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log

connection trx1;
update t1 set c2=c2+1 where pk1=1 and c1<=4;
select * from t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log

connection trx2;
--error 1205,4012
update t1 set c2=c2+1 where pk1=1 and c1<=4;
--error 1205,4012
update t1 set c2=c2+1 where pk1=1 and c1>=1;
--error 1205,4012
delete from t1 where pk1=1 and c1<=4;
--error 1205,4012
delete from t1 where pk1=1 and c1>=1;
--error 1205,4012
update t1 set c2=c2+1 where c1=1;
--error 1205,4012
delete from t1 where c1=1;

update t1 set c2=c2+1 where c1>=4 and pk1=2;
select * from t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log

connection trx1;
--error 1205,4012
update t1 set c2=c2+1 where c1>=4;
--error 1205,4012
update t1 set c2=c2+1 where c1<=8;
--error 1205,4012
update t1 set c2=c2+1 where pk1=2;
select * from t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log
commit;

connection trx2;
select * from t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log
update t1 set c2=c2+1 where pk1=1 and c1<=4;
select * from t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log
update t1 set c2=c2+1 where pk1=1 and c1>=1;
select * from t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log
delete from t1 where pk1=1 and c1<=4;
select * from t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log
commit;
select * from t1;
--disable_query_log
eval select * from $idx1;
--enable_query_log
commit;

connection trx1;
set autocommit=1;
connection trx2;
set autocommit=1;
drop table t1;
set global ob_enable_index_direct_select =0;
