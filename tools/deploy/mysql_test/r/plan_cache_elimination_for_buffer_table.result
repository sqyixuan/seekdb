USE PLAN_CACHE_BUFFER_TABLE;
# 场景4
# 非全表扫描计划, 抽取出来的query range选择率> 0.8时, 小表变大表淘汰计划
create table t4 (c1 int, c2 int, c3 int, key idx_c1_c2(c1, c2), key idx_c2(c2));
# 插入100行数
explain select c1, c2 from t4 where c1 < 2 and c2 < 100;
