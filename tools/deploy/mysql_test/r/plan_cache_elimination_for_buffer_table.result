# 场景3（和场景1类似，不过这次对比的是两个索引）
# 表T3有一个建立在(e1,e2)上的索引和一个建立在e2上的索引
# SELECT e1, e2 FROM T1 WHERE e2 < 100
# 在表的行数较少时，由于索引idx_e1_e2扫描不需要回表
# 优化器会认为走主表是个更好的选择
# 随着表T3的数据插入，索引全表的扫描越来越大
# 这个时候带有range的e2索引扫描实际上是更好的选择
set @@ob_query_timeout = 10000000;
create table T3(e1 int, e2 int, e3 int,  index idx_e1_e2(e1, e2), index idx_e2(e2));
#执行本条语句，走(e1,e2)的计划写入plan cache
explain select e1, e2 from T3 where e2 < 100;
