result_format: 4
use oceanbase;

drop table if exists my_tab;
drop procedure if exists my_proc;
drop function if exists my_func;
drop database if exists my_db;
create table my_tab(col varchar(50));


create procedure my_proc()
begin
  insert into my_tab values(concat("my_proc exec with db = ", database()));
end|

create function my_func() returns int
begin
  insert into my_tab values(concat("my_func exec with db = ", database()));
  return 1;
end|


call my_proc();
select my_func();
+-----------+
| my_func() |
+-----------+
|         1 |
+-----------+
select * from my_tab;
+----------------------------------+
| col                              |
+----------------------------------+
| my_proc exec with db = oceanbase |
| my_func exec with db = oceanbase |
+----------------------------------+

create database my_db;
use my_db;
call oceanbase.my_proc();
select oceanbase.my_func();
+---------------------+
| oceanbase.my_func() |
+---------------------+
|                   1 |
+---------------------+
select * from oceanbase.my_tab;
+----------------------------------+
| col                              |
+----------------------------------+
| my_proc exec with db = oceanbase |
| my_func exec with db = oceanbase |
| my_proc exec with db = oceanbase |
| my_func exec with db = oceanbase |
+----------------------------------+

use oceanbase;
drop procedure my_proc;
drop function my_func;
drop table my_tab;
drop database my_db;

