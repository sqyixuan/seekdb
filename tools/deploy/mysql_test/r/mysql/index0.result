create database if not exists test;
use test;
drop table if exists t3;
create table t3(c1 bigint primary key, c2 bigint, v1 varchar(128), v2 varchar(64));
create index t3_idx1 on t3(v2, c2) storing(v1);
create unique index t3_idx2 on t3(c2);
