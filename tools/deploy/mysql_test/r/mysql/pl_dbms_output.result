drop tenant if exists ora_tt force;
drop resource pool if exists pool1;
drop resource unit if exists box1;
create resource unit box1 max_cpu 1, max_memory 1073741824, max_iops 100000, max_disk_size 536870912, max_session_num 64, MIN_CPU=1, MIN_MEMORY=1073741824, MIN_IOPS=128;
## 功能: 获取指定租户的ip&port
## 用法:
## 模板:


use test;

set @@ob_query_timeout=1000000000;

create package dbms_output as
  procedure enable(buffer_size integer);
  procedure disable;
  procedure put(a varchar);
  procedure put_line(a varchar);
  procedure new_line;
  procedure get_line(line out varchar, status out integer);
end;//
create package body dbms_output as
  enabled         boolean default false;
  get_in_progress boolean default true;
  type char_arr   is table of varchar(32767);
  buf             char_arr;
  buf_size        integer default 20000;
  bufleft         integer default -1;
  linebuflen      integer default 0;
  putidx          integer default 1;
  getidx          integer default 1;
  
  procedure enable(buffer_size integer) is
  begin
    enabled := true;
    if buffer_size < 2000 then
      buf_size := 2000;
    elsif buffer_size > 1000000 then
      buf_size := 1000000;
    elsif buffer_size is null then
      buf_size := -1; 
    else
      buf_size := buffer_size;
    end if;
    bufleft := buf_size;
  end;
  
  procedure disable is
  begin
    enabled := false; 
    putidx := 1; 
    get_in_progress := true;  
  end;
  
  procedure put_init is
  begin
    putidx := 1;
    buf.extend;
    buf(putidx) := '';
    linebuflen := 0;
    bufleft := buf_size;
    get_in_progress := false;
  end;
  
  procedure put(a varchar) is
    strlen integer;
  begin
    if enabled then
      if get_in_progress then
        put_init;
      end if;

      strlen := nvl(length(a), 0);
      if (strlen + linebuflen) > 32767 then
        linebuflen := 0;
      end if;

      if buf_size <> -1 then   
        bufleft := bufleft - strlen;
      end if;
	 
      buf(putidx) := concat(buf(putidx), a);
      linebuflen := linebuflen + strlen;
    end if;
  end;
  
  procedure put_line(a varchar) is
  begin
    if enabled then
      put(a);
      new_line;
    end if;
  end;
  
  procedure new_line is
  begin
    if enabled then
      if get_in_progress then
        put_init;
      end if;
      linebuflen := 0;
      putidx := putidx + 1;
      buf.extend;
      buf(putidx) := '';
    end if;
  end;
  
  procedure get_line(line out varchar, status out integer) is
  begin
    if not enabled then
      status := 1;
    else 
    begin
     if not get_in_progress then
	   get_in_progress := true;
	   if (linebuflen > 0) and (putidx = 1) then
	     status := 1;
	   end if;
	   getidx := 1;
     end if;
	 if getidx <= putidx then
	   line := buf(getidx);
	   getidx := getidx + 1;
	   status := 0;
	 else 
	   status := 1;
	 end if;
    end;
	end if;  
  end;
end;//
call dbms_output.enable(1000);
call dbms_output.put_line('test');
call dbms_output.get_line('', 0);
+------+--------+
| line | status |
+------+--------+
| test |      0 |
+------+--------+
call dbms_output.get_line('', 0);
+------+--------+
| line | status |
+------+--------+
|      |      0 |
+------+--------+
call dbms_output.get_line('', 0);
+------+--------+
| line | status |
+------+--------+
|      |      1 |
+------+--------+
drop package dbms_output;

