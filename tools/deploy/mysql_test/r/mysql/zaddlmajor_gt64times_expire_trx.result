create table ttl2(i1 int, v2 varchar(80), i3 char(20),i4 float, d4 datetime(6),i5 decimal(5,3), primary key(i1)) expire_info v2>='abc',enable_transaction_expire=true;
create index ttlidx_1 on ttl2(i1);
alter system major freeze tenant = sys;
alter system major freeze tenant = all_user;
alter system major freeze tenant = all_meta;
drop table if exists ttl1;
create table ttl1(i1 int, v2 varchar(80), i3 char(20),i4 float, d4 datetime(6),i5 decimal(5,3), primary key(i1)) expire_info v2>='abc',enable_transaction_expire=true;
create index ttlidx_1 on ttl1(i1);
alter system major freeze tenant = sys;
alter system major freeze tenant = all_user;
alter system major freeze tenant = all_meta;
show tables like 'ttl%';
