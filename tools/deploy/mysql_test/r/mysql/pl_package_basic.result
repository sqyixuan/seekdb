create table obtabletest (a decimal(6,2), b decimal(6,2));
create or replace package obpackagetest as
  type tab_type is table of decimal(6,2);
  v_tab tab_type;
end;
/
begin
  obpackagetest.v_tab.extend;
  obpackagetest.v_tab(1) := 1000.23;
  obpackagetest.v_tab.extend;
  obpackagetest.v_tab(2) := 1001.23;
  insert into obtabletest values(obpackagetest.v_tab(1), obpackagetest.v_tab(2));
end;
/
select * from obtabletest;
+---------+---------+
| a       | b       |
+---------+---------+
| 1000.23 | 1001.23 |
+---------+---------+
drop table obtabletest;
drop package obpackagetest;

create table obtabletest (a decimal(6,2), b varchar(10));
create or replace package obpackagetest as
  type typ_rec is record (x decimal(6,2), y varchar2(10));
  type tab_type is table of typ_rec;
  v_tab tab_type;
end;
/
begin
  obpackagetest.v_tab.extend;
  obpackagetest.v_tab(1).x := 1000.23;
  obpackagetest.v_tab(1).y := 'test1';
  obpackagetest.v_tab.extend;
  obpackagetest.v_tab(2).x := 1001.23;
  obpackagetest.v_tab(2).y := 'test2';
  insert into obtabletest values(obpackagetest.v_tab(1).x, obpackagetest.v_tab(1).y);
  insert into obtabletest values(obpackagetest.v_tab(2).x, obpackagetest.v_tab(2).y);
end;
/
select * from obtabletest;
+---------+-------+
| a       | b     |
+---------+-------+
| 1000.23 | test1 |
| 1001.23 | test2 |
+---------+-------+
drop table obtabletest;
drop package obpackagetest;

create table a(a1 bigint);
insert into a values(1);
insert into a values(2);
create table b(b1 bigint);
create or replace package obpackagetest as
  type tab_type is table of bigint;
  v_tab tab_type;
end;
/
declare
  cursor c is select a1 from a;
begin
  open c;
  fetch c bulk collect into obpackagetest.v_tab limit 1000;
  insert into b values(obpackagetest.v_tab(1));
  insert into b values(obpackagetest.v_tab(2));
  close c;
end;
/
select * from b;
+------+
| b1   |
+------+
|    1 |
|    2 |
+------+
drop table a;
drop table b;
drop package obpackagetest;

create table a(a1 decimal(6,2));
insert into a values(1000.23);
insert into a values(1001.23);
