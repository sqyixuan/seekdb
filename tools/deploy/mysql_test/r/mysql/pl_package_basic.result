+---------+-------+
| 1000.23 | test1 |
| 1001.23 | test2 |
| 1000.23 | test1 |
| 1001.23 | test2 |
+---------+-------+
drop table obtabletest;
drop package obpackagetest;

create table obtabletest (a varchar(10), b int);
create or replace package obpackagetest as
  type typ_rec is record (x varchar2(10), y int);
end;
/
declare
  res obpackagetest.typ_rec;
begin
  res.x := 'test1';
  res.y := 1;
  insert into obtabletest values(res.x, res.y);
end;
/
select * from obtabletest;
