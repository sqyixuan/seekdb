| a     | b    |
+-------+------+
| test1 |    1 |
+-------+------+
drop table obtabletest;
drop package obpackagetest;

create table obtabletest (a varchar(10), b varchar(10));
create or replace package obpackagetest as
  type tab_type is table of varchar2(10);
end;
/
declare 
  v_tab obpackagetest.tab_type;
begin
  v_tab.extend;
  v_tab(1) := 'test1';
  v_tab.extend;
  v_tab(2) := 'test2';
  insert into obtabletest values(v_tab(1), v_tab(2));
end;
/
select * from obtabletest;
+-------+-------+
| a     | b     |
+-------+-------+
| test1 | test2 |
+-------+-------+
drop table obtabletest;
drop package obpackagetest;

create table obtabletest (a varchar(10));
create or replace package obpackagetest as
  x varchar2(10);
end;
/
create or replace package body obpackagetest as
begin
  x := 'test';
end;
/
begin
  insert into obtabletest values(obpackagetest.x);
end;
/
select * from obtabletest;
