| a    |
+------+
| test |
+------+
drop table obtabletest;
drop package obpackagetest;

##function related case##
create or replace package obpackagetest as
  function test1 return varchar2;
  function test2(str varchar2) return varchar2; 
  function test3(str1 varchar2, str2 varchar2) return varchar2; 
end;
/
create or replace package body obpackagetest as
  function test1 return varchar2 is
  begin
    return 'test1';
  end;
  function test2(str varchar2) return varchar2 is
  begin
    return str;
  end;
  function test3(str1 varchar2, str2 varchar2) return varchar2 is
  begin
    return concat(str1,str2);
  end;
end;
/
select obpackagetest.test1();
+-----------------------+
| obpackagetest.test1() |
+-----------------------+
| test1                 |
+-----------------------+
select obpackagetest.test2('test2');
+------------------------------+
| obpackagetest.test2('test2') |
+------------------------------+
| test2                        |
+------------------------------+
select obpackagetest.test3('test','3');
+---------------------------------+
| obpackagetest.test3('test','3') |
+---------------------------------+
| test3                           |
+---------------------------------+
drop package obpackagetest;

create or replace package obpackagetest as
  function test return varchar2;
  function test(str varchar2) return varchar2; 
  function test(i int) return int; 
end;
/
create or replace package body obpackagetest as
  function test return varchar2 is
  begin
    return 'test';
  end;
  function test(str varchar2) return varchar2 is
  begin
    return str;
  end;
  function test(i int) return int is 
  begin
    return i;
  end;
end;
/
select obpackagetest.test();
+----------------------+
| obpackagetest.test() |
+----------------------+
| test                 |
+----------------------+
select obpackagetest.test('test overload');
+-------------------------------------+
| obpackagetest.test('test overload') |
+-------------------------------------+
| test overload                       |
+-------------------------------------+
select obpackagetest.test(1);
+-----------------------+
| obpackagetest.test(1) |
+-----------------------+
| 1                     |
+-----------------------+
drop package obpackagetest;

create or replace package obpackagetest as
  function test return varchar2;
  function test return int;
end;
/
create or replace package body obpackagetest as
  function test return varchar2 is
  begin
    return 'package function';
  end;
  function test return int is
  begin
    return 1;
  end;
end;
/
select obpackagetest.test();
+----------------------+
| obpackagetest.test() |
+----------------------+
| package function     |
+----------------------+
drop package obpackagetest;

create or replace package obpackagetest as
  function test return varchar2;
end;
