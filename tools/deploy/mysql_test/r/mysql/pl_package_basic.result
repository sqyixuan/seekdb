create table a(a1 bigint);
insert into a values(-1);
create function abs(i int) return int is
begin
  return i+2;
end;
/
create or replace package obpackagetest as
  TYPE tab_type IS TABLE OF bigint;
  abs tab_type;
  procedure p(x bigint);
end;
/
create or replace package body obpackagetest as
  function abs(i int) return int is
  begin
    return i+1;
  end;
  
  procedure p(x bigint) is
    cursor c is select a1 from a;
  begin 
    open c;
    fetch c bulk collect into abs limit 1000;
    x := abs(1);
    insert into a values(x);
    close c;
  end;
end;
/
call obpackagetest.p(1);
select * from a;
+------+
| a1   |
+------+
|   -1 |
|   -1 |
+------+
drop package obpackagetest;
drop function abs;
drop table a;

