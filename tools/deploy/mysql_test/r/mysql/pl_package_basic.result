create table obtabletest (a varchar(10), b varchar(10));
create or replace package obpackagetest as
  type tab_type is table of varchar2(10);
  v_tab tab_type;
  procedure p;
end;
/
create or replace package body obpackagetest as
  procedure p is
  begin
    v_tab.extend;
    v_tab(1) := 'test1';
    v_tab.extend;
    v_tab(1+1) := 'test2';
    insert into obtabletest values(v_tab(1), v_tab(2));
  end;
end;
/
call obpackagetest.p();
select * from obtabletest;
+-------+-------+
| a     | b     |
+-------+-------+
| test1 | test2 |
+-------+-------+
drop table obtabletest;
drop package obpackagetest;

create table obtabletest (a varchar(10), b varchar(10));
create or replace package obpackagetest as
  tab_idx integer;
  type tab_type is table of varchar2(10);
  v_tab tab_type;
  procedure p;
end;
/
create or replace package body obpackagetest as
  procedure p is
  begin
    v_tab.extend;
    tab_idx := 1;
    v_tab(tab_idx) := 'test1';
    tab_idx := 2;
    v_tab.extend;
    v_tab(tab_idx) := 'test2';
    insert into obtabletest values(v_tab(tab_idx), v_tab(tab_idx));
  end;
end;
/
call obpackagetest.p();
select * from obtabletest;
+-------+-------+
| a     | b     |
+-------+-------+
| test2 | test2 |
+-------+-------+
