drop table if exists new_default_value_t1;
drop table if exists new_default_value_t2;
drop table if exists new_default_value_t3;
drop table if exists new_default_value_t4;
result_format: 4
#### 测试__all_column表中是否有orig_default_value_v2和cur_default_value_v2列

desc oceanbase.__all_column;
+-----------------------------+-------------------+------+-----+----------------------+--------------------------------+
| Field                       | Type              | Null | Key | Default              | Extra                          |
+-----------------------------+-------------------+------+-----+----------------------+--------------------------------+
| gmt_create                  | timestamp(6)      | YES  |     | CURRENT_TIMESTAMP(6) |                                |
| gmt_modified                | timestamp(6)      | YES  |     | CURRENT_TIMESTAMP(6) | ON UPDATE CURRENT_TIMESTAMP(6) |
| tenant_id                   | bigint(20)        | NO   | PRI | NULL                 |                                |
| table_id                    | bigint(20)        | NO   | PRI | NULL                 |                                |
| column_id                   | bigint(20)        | NO   | PRI | NULL                 |                                |
| column_name                 | varchar(128)      | NO   | MUL |                      |                                |
| rowkey_position             | bigint(20)        | NO   |     | 0                    |                                |
| index_position              | bigint(20)        | NO   |     | NULL                 |                                |
| order_in_rowkey             | bigint(20)        | NO   |     | NULL                 |                                |
| partition_key_position      | bigint(20)        | NO   |     | NULL                 |                                |
| data_type                   | bigint(20)        | NO   |     | NULL                 |                                |
| data_length                 | bigint(20)        | NO   |     | NULL                 |                                |
| data_precision              | bigint(20)        | YES  |     | NULL                 |                                |
| data_scale                  | bigint(20)        | YES  |     | NULL                 |                                |
| zero_fill                   | bigint(20)        | NO   |     | NULL                 |                                |
| nullable                    | bigint(20)        | NO   |     | NULL                 |                                |
| on_update_current_timestamp | bigint(20)        | NO   |     | NULL                 |                                |
| autoincrement               | bigint(20)        | NO   |     | NULL                 |                                |
| is_hidden                   | bigint(20)        | NO   |     | 0                    |                                |
| collation_type              | bigint(20)        | NO   |     | NULL                 |                                |
| orig_default_value          | varchar(262144)   | YES  |     | NULL                 |                                |
| cur_default_value           | varchar(262144)   | YES  |     | NULL                 |                                |
| comment                     | longtext          | YES  |     | NULL                 |                                |
| schema_version              | bigint(20)        | NO   |     | NULL                 |                                |
| column_flags                | bigint(20)        | NO   |     | 0                    |                                |
| prev_column_id              | bigint(20)        | NO   |     | -1                   |                                |
| extended_type_info          | varbinary(65536)  | YES  |     | NULL                 |                                |
| orig_default_value_v2       | varbinary(262144) | YES  |     | NULL                 |                                |
| cur_default_value_v2        | varbinary(262144) | YES  |     | NULL                 |                                |
| srs_id                      | bigint(20)        | NO   |     | -32                  |                                |
| udt_set_id                  | bigint(20)        | NO   |     | 0                    |                                |
| sub_data_type               | bigint(20)        | NO   |     | 0                    |                                |
| skip_index_attr             | bigint(20)        | NO   |     | 0                    |                                |
| lob_chunk_size              | bigint(20)        | NO   |     | 262144               |                                |
| local_session_vars          | longtext          | YES  |     | NULL                 |                                |
+-----------------------------+-------------------+------+-----+----------------------+--------------------------------+


## 测试aone缺陷
create table new_default_value_t1(c1 varbinary(64) default b'1111111111111111111111111111111111111111111111111111111111111111');
insert into new_default_value_t1 values(default);
select hex(c1) from new_default_value_t1;
+------------------+
| hex(c1)          |
+------------------+
| FFFFFFFFFFFFFFFF |
+------------------+


+---------------------------+
| hex(cur_default_value_v2) |
+---------------------------+
| FFFFFFFFFFFFFFFF          |
+---------------------------+

## 测试int类型的default值
create table new_default_value_t2(c1 int default 10, c2 int);
insert into new_default_value_t2(c2) values(1);
insert into new_default_value_t2(c2) values(2);
insert into new_default_value_t2 values(default, 3);
insert into new_default_value_t2 values(20, 3);
select * from new_default_value_t2;
+------+------+
| c1   | c2   |
+------+------+
|   10 |    1 |
|   10 |    2 |
|   10 |    3 |
|   20 |    3 |
+------+------+


+-------------+--------------------+-------------------+-----------------------+----------------------+
| column_name | orig_default_value | cur_default_value | orig_default_value_v2 | cur_default_value_v2 |
+-------------+--------------------+-------------------+-----------------------+----------------------+
| c1          | NULL               | NULL              | NULL                  | 10                   |
+-------------+--------------------+-------------------+-----------------------+----------------------+

## 测试varchar类型的default值
create table new_default_value_t3(c1 varchar(10) default 'hello', c2 int);
insert into new_default_value_t3(c2) values(1);
insert into new_default_value_t3(c2) values(2);
insert into new_default_value_t3 values(default, 3);
insert into new_default_value_t3 values('world', 4);
select * from new_default_value_t3;
+-------+------+
| c1    | c2   |
+-------+------+
| hello |    1 |
| hello |    2 |
| hello |    3 |
| world |    4 |
+-------+------+


+-------------+--------------------+-------------------+-----------------------+----------------------+
| column_name | orig_default_value | cur_default_value | orig_default_value_v2 | cur_default_value_v2 |
+-------------+--------------------+-------------------+-----------------------+----------------------+
| c1          | NULL               | NULL              | NULL                  | hello                |
+-------------+--------------------+-------------------+-----------------------+----------------------+

## 测试生成列默认值
create table new_default_value_t4(c1 int default 10, c2 int, c3 int GENERATED ALWAYS AS (c1 * c2));
insert into new_default_value_t4(c1, c2) values(2, 3);
insert into new_default_value_t4(c2) values (5);
select * from new_default_value_t4;
+------+------+------+
| c1   | c2   | c3   |
+------+------+------+
|    2 |    3 |    6 |
|   10 |    5 |   50 |
+------+------+------+

drop table new_default_value_t1;
drop table new_default_value_t2;
drop table new_default_value_t3;
drop table new_default_value_t4;
