alter system set log_transport_compress_func= 'stream_zstd_1.3.8';
begin;
insert into t3 values(5, 55, 'aaa5', repeat('aaaaaaaaaaa5', 5*1024));
insert into t3 values(6, 66, 'aaa6', repeat('aaaaaaaaaaa6', 5*1024));
insert into t3 values(7, 77, 'aaa7', repeat('aaaaaaaaaaa7', 5*1024));
commit;
select * from t3 where c1 < 5;
