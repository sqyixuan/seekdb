alter system set merger_check_interval= '10s';
alter system set log_transport_compress_all=true;
create database if not exists test;
use test;
drop table if exists t3;
create table t3(c1 bigint primary key, c2 bigint, v1 varchar(128), v2 varchar(65536), index(v1, c2));
select * from t3 where c1 != 5;
c1	c2	v1	v2
alter system set log_transport_compress_func= 'stream_zstd_1.0';
insert into t3 values(1, 11, 'aaa1', 'aaaa1');
insert into t3 values(2, 22, 'aaa2', 'aaaa2');
insert into t3 values(3, 33, 'aaa3', 'aaaa3');
insert into t3 values(4, 44, 'aaa4', 'aaaa4');
insert into t3 values(5, 55, 'aaa5', repeat('aaaaaaaaaaa5', 5*1024));
update t3 set c2=2222 where c1=2;
update t3 set c2=1111, v2='aaaaaa' where c1=1;
select * from t3 where c1 != 5;
c1	c2	v1	v2
1	1111	aaa1	aaaaaa
2	2222	aaa2	aaaa2
3	33	aaa3	aaaa3
4	44	aaa4	aaaa4
delete from t3 where c2<55555;
select * from t3 where c1 != 5;
c1	c2	v1	v2
