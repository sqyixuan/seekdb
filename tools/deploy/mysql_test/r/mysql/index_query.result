drop table if exists t;
alter system set check_tablet_available_interval='3s' server_type=chunkserver;
alter system set index_builder_thread_num='10' server_type=chunkserver;
alter system set check_async_task_interval='3s' server_type=rootserver;
create table t (k1 int, k2 int, v1 int, v2 int, v3 int, v4 int, v5 int, s1 varchar(1024), s2 varchar(1024), s3 varchar(1024), s4 varchar(1024), s5 varchar(1024), s6 varchar(1024), primary key (k1, k2));
create index i1 on t (v1, v2) storing (v3, v4);
create index i2 on t (v3);
create index i3 on t (s1, s2, s3);
create index i4 on t (v4, v3);
create index i5 on t (v5, k2);
create index i6 on t (k1) storing (s5, s6);
alter system major freeze tenant = sys;
alter system major freeze tenant = all_user;
alter system major freeze tenant = all_meta;
explain select s4 from t where (k1, k2) in ((1, 1));
