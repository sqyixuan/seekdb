  `data_table_id` bigint(20) DEFAULT NULL,
  `index_status` bigint(20) DEFAULT NULL,
  `tablegroup_id` bigint(20) DEFAULT NULL,
  `progressive_merge_num` bigint(20) DEFAULT NULL,
  `index_type` bigint(20) DEFAULT NULL,
  `part_level` bigint(20) DEFAULT NULL,
  `part_func_type` bigint(20) DEFAULT NULL,
  `part_func_expr` varchar(4096) DEFAULT NULL,
  `part_num` bigint(20) DEFAULT NULL,
  `sub_part_func_type` bigint(20) DEFAULT NULL,
  `sub_part_func_expr` varchar(4096) DEFAULT NULL,
  `sub_part_num` bigint(20) DEFAULT NULL,
  `view_definition` longtext DEFAULT NULL,
  `view_check_option` bigint(20) DEFAULT NULL,
  `view_is_updatable` bigint(20) DEFAULT NULL,
  `index_using_type` bigint(20) DEFAULT '0',
  `parser_name` varchar(128) DEFAULT NULL,
  `index_attributes_set` bigint(20) DEFAULT '0',
  `tablet_size` bigint(20) DEFAULT '134217728',
