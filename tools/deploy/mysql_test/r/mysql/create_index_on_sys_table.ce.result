explain basic SELECT table_id, schema_version, table_type FROM (SELECT TABLE_ID, SCHEMA_VERSION, TABLE_TYPE, IS_DELETED, ROW_NUMBER() OVER (PARTITION BY TABLE_ID ORDER BY SCHEMA_VERSION DESC) AS RN FROM oceanbase.__all_table_history WHERE TENANT_ID = 1 AND DATA_TABLE_ID = 1 AND SCHEMA_VERSION <= 100) V WHERE RN = 1 and IS_DELETED = 0 ORDER BY TABLE_ID;
Query Plan
========================================================
|ID|OPERATOR              |NAME                        |
--------------------------------------------------------
|0 |SORT                  |                            |
|1 |└─SUBPLAN SCAN        |V                           |
|2 |  └─WINDOW FUNCTION   |                            |
|3 |    └─TABLE RANGE SCAN|__all_table_history(Reverse)|
========================================================
Outputs & filters:
-------------------------------------
  0 - output([V.TABLE_ID], [V.SCHEMA_VERSION], [V.TABLE_TYPE]), filter(nil)
      sort_keys([V.TABLE_ID, ASC])
  1 - output([V.TABLE_ID], [V.SCHEMA_VERSION], [V.TABLE_TYPE]), filter([V.IS_DELETED = 0])
      access([V.TABLE_ID], [V.SCHEMA_VERSION], [V.TABLE_TYPE], [V.IS_DELETED])
  2 - output([__all_table_history.table_id], [__all_table_history.schema_version], [__all_table_history.table_type], [__all_table_history.is_deleted]), filter([T_WIN_FUN_ROW_NUMBER() 
      = 1])
      win_expr(T_WIN_FUN_ROW_NUMBER()), partition_by([__all_table_history.table_id]), order_by([__all_table_history.schema_version, DESC]), window_type(RANGE),
       upper(UNBOUNDED PRECEDING), lower(UNBOUNDED FOLLOWING)
  3 - output([__all_table_history.table_id], [__all_table_history.schema_version], [__all_table_history.table_type], [__all_table_history.is_deleted]), filter([__all_table_history.data_table_id 
      = 1], [__all_table_history.schema_version <= 100])
      access([__all_table_history.table_id], [__all_table_history.schema_version], [__all_table_history.data_table_id], [__all_table_history.table_type],
       [__all_table_history.is_deleted]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false,false], 
      range_key([__all_table_history.tenant_id], [__all_table_history.table_id], [__all_table_history.schema_version]), range(1,MIN,MIN ; 1,MAX,MAX), 
      range_cond([__all_table_history.tenant_id = 1])
