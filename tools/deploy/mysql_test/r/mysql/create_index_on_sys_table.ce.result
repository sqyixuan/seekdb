  `index_column_num` bigint(20) DEFAULT NULL,
  `max_used_column_id` bigint(20) DEFAULT NULL,
  `autoinc_column_id` bigint(20) DEFAULT NULL,
  `auto_increment` bigint(20) unsigned DEFAULT '1',
  `read_only` bigint(20) DEFAULT NULL,
  `rowkey_split_pos` bigint(20) DEFAULT NULL,
  `compress_func_name` varchar(128) DEFAULT NULL,
  `expire_condition` varchar(4096) DEFAULT NULL,
  `is_use_bloomfilter` bigint(20) DEFAULT NULL,
  `comment` varchar(4096) DEFAULT '',
