  `duplicate_scope` bigint(20) DEFAULT '0',
  `progressive_merge_round` bigint(20) DEFAULT '0',
  `storage_format_version` bigint(20) DEFAULT '2',
  `table_mode` bigint(20) DEFAULT '0',
  `encryption` varchar(128) DEFAULT '',
  `tablespace_id` bigint(20) DEFAULT '-1',
  `sub_part_template_flags` bigint(20) DEFAULT '0',
