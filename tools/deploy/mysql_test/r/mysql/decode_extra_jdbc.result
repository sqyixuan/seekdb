drop table t1;
create table if not exists t1(
pk1 int,
pk2 varchar(16384),
i1 int,
i2 int,
v1 varchar,
v2 varchar,
t1  timestamp(6) default "2012-01-01 12:00:00",
t2  timestamp(6) default "2012-01-01 12:00:00",
n1 numeric,
n2 numeric(8,5),
b1 bool,
b2 bool,
primary key(pk1,pk2));
