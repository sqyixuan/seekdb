drop table if exists t1;
create table t1 (c1 int, c2 int, c3 varchar(20), c4 varchar(20), c5 varchar(20) generated always as (substr(c3, 1, 10)) virtual, c6 varchar(20) generated always as (substr(c4, 1, 10)) stored , primary key(c1, c2));
insert into t1 (c1, c2, c3, c4) values (1, 1, 'a', 'b');
select c1, c2 from t1 where c1 = 1 and c2 = 1;
c1	c2
1	1
delete from t1 where c1 = 1 and c2 = 1;
alter system major freeze tenant = sys;
alter system major freeze tenant = all_user;
alter system major freeze tenant = all_meta;
select c1, c2 from t1 where c1 = 1 and c2 = 1;
c1	c2
drop table t1;
