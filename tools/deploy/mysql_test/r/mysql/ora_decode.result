create view user_tab_columns1 as select table_name,column_name,case concat(data_type,nullif(datetime_precision,'')) when 'varchar' then 'varchar2' else data_type end as data_type,ora_decode(trim(data_type),'varchar',character_maximum_length,'char',character_maximum_length,'decimal',22,'longlob',4000) as data_length,numeric_precision as data_precision,numeric_scale data_scale from information_schema.columns where table_schema='eesdb';
