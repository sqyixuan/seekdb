set @@ob_enable_index_direct_select = 1;
create table t1(id int primary key, name varchar(64), age int, description varchar(64));
create index i1 on t1(age) storing(name);
create index i2 on t1(name) storing(age);
replace into t1 (id, name, age, description) values (1,'name1',30,'rd'),(2,'name2',27,'rd'),(3,'name3',25,'rd'),(4,'name4',24,'rd');
select * from t1;
