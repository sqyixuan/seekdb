drop table if exists t1;
create table t1 (a bigint primary key, b char(20), index i1(b));
insert into t1 values(1,9);
select * from t1 where false or (b <='d' and (b in (repeat('',1),repeat('9',1),'headgxbib')));
a	b
1	9
select * from t1 where false or (b <='d' and (b in (repeat('',1),'9','headgxbib')));
a	b
1	9
select * from t1 where ((a>0) and (a in (abs(2),abs(1)))) or ((a in (abs(-1),abs(2))) and (a in (abs(2),abs(1))));
a	b
1	9
