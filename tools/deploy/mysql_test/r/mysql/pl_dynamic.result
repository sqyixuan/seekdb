use test;

## bug 16739130 execute not call get_next
drop function if exists my_func_1;
drop function if exists my_func_2;
create function my_func_1() returns int return 10;
create function my_func_2() returns int return my_func_1();
prepare stmt from "select my_func_2()";
execute stmt;
execute stmt;
drop function my_func_1;
execute stmt;
ERROR 42000: FUNCTION my_func_1 does not exist
deallocate prepare stmt;
drop function my_func_2;

drop table if exists my_tab;
drop procedure if exists my_proc;
create table my_tab(col int);
insert into my_tab values(10);
create procedure my_proc()
begin
  set @v = 0;
  prepare stmt from 'select * from my_tab into @v';
  execute stmt;
  insert into my_tab values(@v);
  deallocate prepare stmt;
end |
call my_proc();
select * from my_tab;
+------+
| col  |
+------+
|   10 |
|   10 |
+------+

drop table my_tab;
drop procedure my_proc;

drop table if exists my_tab;
drop procedure if exists my_proc;
create table my_tab(col int);
create procedure my_proc()
begin
  prepare stmt from 'select * from my_tab;';
  execute stmt;
  deallocate prepare stmt;
end |
call my_proc();
drop table my_tab;
call my_proc();
