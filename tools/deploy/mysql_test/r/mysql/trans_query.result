drop table if exists t1;
create table t1 (a int primary key, b int);
begin;
replace into t1 values (1, 2);
select * from t1;
a	b
1	2
rollback;
select * from t1;
a	b
set autocommit = 0;
select * from t1;
a	b
replace into t1 values (2, 3);
select * from t1;
a	b
2	3
set autocommit = 1;
select * from t1;
a	b
2	3
set autocommit = 0;
update t1 set b = 4 where a = 2;
select * from t1;
a	b
2	4
rollback;
select * from t1;
a	b
2	3
commit;
update t1 set b = 4 where a = 2;
select * from t1;
a	b
2	4
set autocommit = 1;
set autocommit = 0;
select * from t1;
a	b
2	4
rollback;
select * from t1;
a	b
2	4
begin;
select * from t1;
a	b
2	4
replace into t1 values (5, 5);
select * from t1;
a	b
2	4
5	5
rollback;
