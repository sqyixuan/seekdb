create table t1(pk int primary key, a int, b int);
create index i1 on t1(b);
insert into t1(pk, a, b) values(1,1,1),(2,1,1);
set autocommit=0;
select pk, b from t1 where b between 0 and 1000;
pk	b
1	1
2	1
select pk, a, b from t1 where pk>0 and pk<10;
pk	a	b
1	1	1
2	1	1
select * from t1 where b>0 and b<1000;
pk	a	b
1	1	1
2	1	1
set autocommit=0;
update t1 set a=10, b=10 where pk=1;
delete from t1 where pk=2;
insert into t1 values(3,1,1);
replace into t1 values(4,1,1);
rollback;
update t1 set a=a+100, b=b+100 where pk=1;
update t1 set a=a+100, b=b+100 where pk=2;
update t1 set a=a+100, b=b+100 where pk=3;
update t1 set a=a+100, b=b+100 where pk=4;
select pk, b from t1 where b between 0 and 1000;
pk	b
1	101
2	101
select pk, a, b from t1 where pk>0 and pk<10;
pk	a	b
1	101	101
2	101	101
select * from t1 where b>0 and b<1000;
pk	a	b
1	101	101
2	101	101
commit;
select pk, b from t1 where b between 0 and 1000;
pk	b
1	101
2	101
select pk, a, b from t1 where pk>0 and pk<10;
pk	a	b
1	101	101
2	101	101
select * from t1 where b>0 and b<1000;
pk	a	b
1	101	101
2	101	101
drop table t1;
