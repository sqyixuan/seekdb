#### Case 56: test recursion call
drop function if exists my_func|
create function my_func(val int)
returns int
begin
  if (val > 1) then
    set val = my_func(val - 1);
  end if;
  return val;
end|

select my_func(1);
+------------+
| my_func(1) |
+------------+
|          1 |
+------------+
select my_func(2);
ERROR HY000: Recursive stored functions are not allowed.

drop function my_func|
create function my_func(val int)
returns int
begin
  if (val > 0) then
    set val = val - 1;
    call my_proc(val);
  end if;
  return val;
end|

drop procedure if exists my_proc|
create procedure my_proc(val int)
begin
  if (val > 0) then
    set val = my_func(val);
  end if;
end|

set max_sp_recursion_depth = 0|
call my_proc(1)|
ERROR HY000: Recursive limit 0 (as set by the max_sp_recursion_depth variable) was exceeded for routine
set max_sp_recursion_depth = 10|
call my_proc(1)|
set max_sp_recursion_depth = 0|

drop function my_func;
drop procedure my_proc;

