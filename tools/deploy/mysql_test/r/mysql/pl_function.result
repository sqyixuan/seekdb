#### Case 25:
drop function if exists bug10100f|
drop procedure if exists bug10100p|
drop procedure if exists bug10100t|
drop procedure if exists bug10100pt|
drop procedure if exists bug10100pv|
## drop procedure if exists bug10100pd|
drop procedure if exists bug10100pc|
create function bug10100f(prm int) returns int
begin
  if prm > 1 then
    return prm * bug10100f(prm - 1);
  end if;
  return 1;
end|
create procedure bug10100p(prm int, inout res int)
begin
  set res = res * prm;
  if prm > 1 then
    call bug10100p(prm - 1, res);  
  end if;
end|
create procedure bug10100t(prm int)
begin
  declare res int;
  set res = 1;
  call bug10100p(prm, res);
  select res;
end|

drop table if exists t3|
drop view if exists v1|
create table t3 (a int)|
insert into t3 values (0)|

create view v1 as select a from t3|

create procedure bug10100pt(level int, lim int)
  begin
  if level < lim then
    update t3 set a=level;
    call bug10100pt(level+1, lim);
  else
    select * from t3;
  end if;
end|

create procedure bug10100pv(level int, lim int)
begin
  if level < lim then
    update v1 set a=level;
    call bug10100pv(level+1, lim);
  else
    select * from v1;
  end if;
end|

create procedure bug10100pc(level int, lim int)
begin
  declare lv int;
  declare c cursor for select a from t3;
  open c;
  if level < lim then
    select level;
    fetch c into lv;
    select lv;
    update t3 set a=level+lv;
    call bug10100pc(level+1, lim);
  else
    select * from t3;
  end if;
  close c;
end|

set @@max_sp_recursion_depth=4|
select @@max_sp_recursion_depth|
+--------------------------+
| @@max_sp_recursion_depth |
+--------------------------+
|                        4 |
+--------------------------+
select bug10100f(3)|
ERROR HY000: Recursive stored functions are not allowed.
select bug10100f(6)|
ERROR HY000: Recursive stored functions are not allowed.
call bug10100t(5)|
call bug10100pt(1,5)|
call bug10100pv(1,5)|
ERROR 0A000: DML operation with View/Virtual Table/Temporary Table not supported
update t3 set a=1|
select * from t3|
+------+
| a    |
+------+
|    1 |
+------+
update t3 set a=1|
call bug10100pc(1,5)|
select * from t3|
+------+
| a    |
+------+
|   11 |
+------+
set @@max_sp_recursion_depth=0|
select @@max_sp_recursion_depth|
+--------------------------+
| @@max_sp_recursion_depth |
+--------------------------+
|                        0 |
+--------------------------+
call bug10100t(5)|
ERROR HY000: Recursive limit 0 (as set by the max_sp_recursion_depth variable) was exceeded for routine

drop function bug10100f|
drop procedure bug10100p|
drop procedure bug10100t|
drop procedure bug10100pt|
drop procedure bug10100pv|
