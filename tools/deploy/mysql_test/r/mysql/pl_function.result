  declare x int default 0;
  declare continue handler for sqlstate '42S02'
  begin
    set x= x+1000;
  end;
  case (select 1 from no_such_view limit 1)
    when 1 then set x= x+1;
    when 2 then set x= x+2;
    else set x= x+100;
  end case;
  set x=x + 500;
  return x;
end|
