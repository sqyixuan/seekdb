## 模板:


use test;

set @@ob_query_timeout=1000000000;


DROP PACKAGE DBMS_DEBUG ;//
ERROR 42000: PACKAGE 'test.DBMS_DEBUG' does not exist
CREATE PACKAGE DBMS_DEBUG AS

    retry_on_timeout INTEGER DEFAULT 0;
    continue_on_timeout INTEGER DEFAULT 1;
    nodebug_on_timeout INTEGER DEFAULT 2;
    abort_on_timeout INTEGER DEFAULT 3;

    default_timeout INTEGER DEFAULT 3600;

    PROCEDURE probe_version(major OUT INTEGER,
                            minor OUT INTEGER);

    PROCEDURE set_timeout(timeout IN OUT INTEGER);

    PROCEDURE initialize(debug_session_id IN OUT VARCHAR,
                         diagnostices IN INTEGER,
                         debug_role IN VARCHAR,
                         debug_role_pwd IN VARCHAR);

    PROCEDURE debug_on(no_client_side_plsql_engine IN BOOLEAN,
                       immediate_ IN BOOLEAN);

    PROCEDURE debug_off;

    PROCEDURE set_timeout_behaviour(behaviour_ IN INTEGER);

    PROCEDURE get_timeout_behaviour(behaviour_ OUT INTEGER);

    PROCEDURE attach_session(debug_session_id IN VARCHAR,
                             diagnostices IN INTEGER);

    PROCEDURE print_backtrace(listing IN OUT VARCHAR);

    PROCEDURE continue_target(breakflags IN INTEGER,
                              info_requested IN INTEGER,
                              status OUT INTEGER);

    PROCEDURE set_breakpoint(func_name IN VARCHAR,
                             line_ IN INTEGER,
                             breakpoint OUT INTEGER,
                             fuzzy IN INTEGER,
                             iterations IN INTEGER,
                             status OUT INTEGER);

    PROCEDURE delete_breakpoint(breakpoint IN INTEGER,
                                status OUT INTEGER);

    PROCEDURE disable_breakpoint(breakpoint IN INTEGER,
                                 status OUT INTEGER);

    PROCEDURE enable_breakpoint(breakpoint IN INT,
                                status OUT INTEGER);

    PROCEDURE show_breakpoints(listing IN OUT VARCHAR);

    PROCEDURE get_value(variable_name IN VARCHAR,
                        frame_ IN INT,
                        scalar_value OUT VARCHAR,
                        format_ IN VARCHAR);

    PROCEDURE detach_session;
END ;//

CREATE PACKAGE BODY DBMS_DEBUG IS

    VERSION_MAJOR INTEGER DEFAULT 1;
    VERSION_MINOR INTEGER DEFAULT 0;

    timeout_behaviour INTEGER DEFAULT 0;

    PROCEDURE probe_version(major OUT INTEGER,
                            minor OUT INTEGER)
    IS
    BEGIN
        major := VERSION_MAJOR;
        minor := VERSION_MINOR;
    END;

    PROCEDURE set_timeout(timeout IN OUT INTEGER)
    IS
        ret INTEGER DEFAULT 0;
    BEGIN
        IF (TIMEOUT = 0) THEN
            default_timeout := 3600;
        ELSE
            default_timeout := timeout;
        END IF;
        ret := pdb_set_timeout(default_timeout);
    END;

    PROCEDURE initialize(debug_session_id IN OUT VARCHAR,
                         diagnostices IN INTEGER,
                         debug_role IN VARCHAR,
                         debug_role_pwd IN VARCHAR)
    IS
        id BIGINT;
    BEGIN 
        id := pdb_initialize();
        debug_session_id := id;
    END;

    PROCEDURE debug_on(no_client_side_plsql_engine IN BOOLEAN,
                       immediate_ IN BOOLEAN)
    IS
        ret INTEGER;
    BEGIN
        ret := pdb_debug_on();
    END;

    PROCEDURE debug_off
    IS
        ret INTEGER;
    BEGIN
        ret := pdb_debug_off();
    END;

    PROCEDURE set_timeout_behaviour(behaviour_ IN INTEGER)
    IS
        unimplemented EXCEPTION;
        ret INTEGER;
    BEGIN
        IF (behaviour_ < retry_on_timeout) OR (behaviour_ > abort_on_timeout) THEN
            raise unimplemented;
        END IF;
        timeout_behaviour := behaviour_;
        ret := pdb_set_timeout_behaviour(timeout_behaviour);
    END;

    PROCEDURE get_timeout_behaviour(behaviour_ OUT INTEGER)
    IS
    BEGIN
        behaviour_ := timeout_behaviour;
    END;

    PROCEDURE attach_session(debug_session_id IN VARCHAR,
                             diagnostices IN INTEGER)
    IS
        ret INTEGER;
        debug_id INTEGER;
    BEGIN
        debug_id := debug_session_id;
        ret := pdb_attach_session(debug_id);
    END;

    PROCEDURE print_backtrace(listing IN OUT VARCHAR)
    IS
    BEGIN
        listing := pdb_print_backtrace();
    END;

    PROCEDURE continue_target(breakflags IN INTEGER,
                              info_requested IN INTEGER,
                              status OUT INTEGER)
    IS
        ret INTEGER;
    BEGIN
        status := 0;
        ret := pdb_continue(breakflags);
    END;

    PROCEDURE set_breakpoint(func_name IN VARCHAR,
                             line_ IN INTEGER,
                             breakpoint OUT INTEGER,
                             fuzzy IN INTEGER,
                             iterations IN INTEGER,
                             status OUT INTEGER)
    IS
    BEGIN
        status := 0;
        breakpoint := pdb_set_breakpoint(func_name, line_);
    END;

    PROCEDURE delete_breakpoint(breakpoint IN INTEGER,
                                status OUT INTEGER)
    IS
    BEGIN
        status := pdb_delete_breakpoint(breakpoint);
    END;

    PROCEDURE disable_breakpoint(breakpoint IN INTEGER,
                                 status OUT INTEGER)
    IS
    BEGIN
        status := pdb_disable_breakpoint(breakpoint);
    END;

    PROCEDURE enable_breakpoint(breakpoint IN INT,
                                status OUT INTEGER)
    IS
    BEGIN
        status := pdb_enable_breakpoint(breakpoint);
    END;

    PROCEDURE show_breakpoints(listing IN OUT VARCHAR)
    IS
    BEGIN
        listing := pdb_show_breakpoints();
    END;

    PROCEDURE get_value(variable_name IN VARCHAR,
                        frame_ IN INT,
                        scalar_value OUT VARCHAR,
                        format_ IN VARCHAR)
    IS
    BEGIN
        scalar_value := pdb_get_value(variable_name, frame_);
    END;

    PROCEDURE detach_session
    IS
        ret INTEGER;
    BEGIN
        ret := pdb_detach_session();
    END;
END DBMS_DEBUG ;//


DROP PACKAGE DBMS_DEBUG;

