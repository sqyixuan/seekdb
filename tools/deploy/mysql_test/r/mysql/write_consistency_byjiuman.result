drop table if exists accounts;
create table accounts
(
acc int primary key,
amount int,
pending int,
cleared timestamp(6) default '2014-10-13 14:00:00' NULL
);
insert into accounts values(1,10,-2,NULL);
insert into accounts values(2,0,2,NULL);
insert into accounts values(3,0,0,timestamp'2014-10-13 14:00:00');
set autocommit=0;
update accounts set pending = pending - 1, cleared = null where acc = 1;
update accounts set pending = pending + 1, cleared = null where acc = 3;
select * from accounts;
acc	amount	pending	cleared
1	10	-3	NULL
2	0	2	NULL
3	0	1	NULL
set autocommit=0;
set session ob_query_timeout=500000000;
update accounts set amount = amount + pending, pending = 0, cleared = timestamp'2014-10-13 14:20:00' where cleared is null;
commit;
select * from accounts;
acc	amount	pending	cleared
1	7	0	2014-10-13 14:20:00.000000
2	2	0	2014-10-13 14:20:00.000000
3	1	0	2014-10-13 14:20:00.000000
commit;
