create table t1(c1 int primary key, c2 varchar(100), c3 int, c4 int, c5 int);
insert into t1 values(1,'a',3, 1, 1);
insert into t1 values(2,'b',2, 2, 2);
insert into t1 values(3,'c',1, 3, 3);
create unique index i11 on t1(c2) storing(c4);
create unique index i12 on t1(c4) storing(c2,c3);
create unique index i13 on t1(c5) storing(c2);
create unique index i14 on t1(c2,c3);
create unique index i15 on t1(c2,c4) storing(c3);
create unique index i16 on t1(c2,c5) storing(c3);
insert into t1 values(4,'d',4, 4, 4);
select * from t1;
c1	c2	c3	c4	c5
1	a	3	1	1
2	b	2	2	2
3	c	1	3	3
4	d	4	4	4
