create table t1(pk int primary key, a int, b int, c int);
insert into t1 values(1,1,1,1),(2,1,1,1);
create index i1 on t1(b) storing(c);
set autocommit=0;
CASE1
select /*+index(t1 i1)*/ * from t1 where b=1;
pk	a	b	c
1	1	1	1
2	1	1	1
update t1 set a=a+1,b=b+1,c=c+1 where pk = 1;
select /*+index(t1 i1)*/ pk, b, c from t1 where b = 2;
pk	b	c
1	2	2
select /*+index(t1 primary)*/ * from t1 where pk = 1;
pk	a	b	c
1	2	2	2
select /*+index(t1 i1)*/* from t1 where b = 2;
pk	a	b	c
1	2	2	2
rollback;
