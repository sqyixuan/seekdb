drop table if exists test;
create table test(a int  primary key,b int );
insert into test values(1,null),(2,null);
alter table test add column   c3  int not null default 0;
select * from test;
a	b	c3
1	NULL	0
2	NULL	0
alter table test alter   c3 set  default null;
ERROR 42000: Invalid default value for 'c3'
select * from test;
a	b	c3
1	NULL	0
2	NULL	0
select * from test where c3 is null;
a	b	c3
alter table test add column   c4  varchar(20) not null default 'abc';
select * from test;
a	b	c3	c4
1	NULL	0	abc
2	NULL	0	abc
alter table test alter  c3 set  default null;
ERROR 42000: Invalid default value for 'c3'
alter table test alter  c4 set  default null;
ERROR 42000: Invalid default value for 'c4'
alter table test alter  c3 set  default 1;
alter table test add column c5 varchar(20);
select * from test where c4 is null;
a	b	c3	c4	c5
create index idx1 on test(c3);
create index idx2 on test(c4);
create index idx3 on test(c5);
update test set c3=4 where c3 is null;
select * from test;
a	b	c3	c4	c5
1	NULL	0	abc	NULL
2	NULL	0	abc	NULL
update test set b= 4 where b is null;
update test set c5='hello'  where c5 is null;
select * from test;
a	b	c3	c4	c5
1	4	0	abc	hello
2	4	0	abc	hello
drop table test;
