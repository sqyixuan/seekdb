#
# Bug #13531865
# TEST_IF_SKIP_SORT_ORDER() INCORRECTLY SKIP FILESORT IF
# 'TYPE' IS REF_OR_NULL
#
#
CREATE TABLE t1 (
a INT,
c INT,
UNIQUE KEY a_c (a,c),
KEY (a));
INSERT INTO t1 VALUES (1,10), (2,NULL), (2,10);
# Using 'KEY a_c' for order-by opt, would have required
# REF_OR_NULL access which never can be order_by skipped.
# -> Keep initial REF on 'KEY a' selected by cond. optimizer
EXPLAIN 
SELECT c FROM t1 WHERE a=2 AND (c=10 OR c IS NULL);
Query Plan
===================================================
|ID|OPERATOR        |NAME   |EST.ROWS|EST.TIME(us)|
---------------------------------------------------
|0 |TABLE RANGE SCAN|t1(a_c)|2       |5           |
===================================================
Outputs & filters:
-------------------------------------
  0 - output([t1.c]), filter(nil), rowset=16
      access([t1.c]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t1.a], [t1.c], [t1.shadow_pk_0]), range(2,10,MIN ; 2,10,MAX), (2,NULL,MIN ; 2,NULL,MAX), 
      range_cond([t1.a = 2], [t1.c = 10 OR t1.c IS NULL])
