-- Prepare data
drop table if exists t1;
create table t1 (a bigint primary key, b char(20), c char(20), key i1(b) , key i2(c));
insert into t1 values(1,'aaaa','aaaa'),(2,'xxxc','xxxb'),(3,'xxxb','xxxc'),(4,'xxxa','xxxa'),(5,'yyym','yyym'),(6,'yyyd','yyyd'),(7,'yyyf','yyyf'),(8,'zzzz','zzzz');
drop table if exists t2;
create table t2 (a bigint primary key, b char(20), c char(20), key i1(b) , key i2(c));
insert into t2 values(1,'aaaa','aaaa'),(2,'xxxc','xxxb'),(3,'xxxb','xxxc'),(4,'xxxa','xxxa'),(5,'yyym','yyym'),(6,'yyyd','yyyd'),(7,'yyyf','yyyf'),(8,'zzzz','zzzz');
-- Test UNION
(SELECT * FROM t1 WHERE b LIKE 'xxx%' LIMIT 2) UNION (SELECT * FROM t1 WHERE b LIKE 'yyy%' ESCAPE '_' LIMIT 2);
a	b	c
4	xxxa	xxxa
3	xxxb	xxxc
6	yyyd	yyyd
7	yyyf	yyyf
(SELECT * FROM t1 WHERE b LIKE 'yyy%' LIMIT 2) UNION (SELECT * FROM t1 WHERE b LIKE 'xxx%' ESCAPE '_' LIMIT 2);
a	b	c
4	xxxa	xxxa
3	xxxb	xxxc
6	yyyd	yyyd
7	yyyf	yyyf
(SELECT * FROM t1 WHERE b LIKE 'xxx%' LIMIT 2) UNION ALL (SELECT * FROM t1 WHERE b LIKE 'yyy%' ESCAPE '_' LIMIT 2);
a	b	c
4	xxxa	xxxa
3	xxxb	xxxc
6	yyyd	yyyd
7	yyyf	yyyf
(SELECT * FROM t1 WHERE b LIKE 'yyy%' LIMIT 2) UNION ALL (SELECT * FROM t1 WHERE b LIKE 'xxx%' ESCAPE '_' LIMIT 2);
a	b	c
6	yyyd	yyyd
7	yyyf	yyyf
4	xxxa	xxxa
3	xxxb	xxxc
(SELECT * FROM t1 WHERE b LIKE 'xxx%' LIMIT 2) UNION DISTINCT (SELECT * FROM t1 WHERE b LIKE 'yyy%' ESCAPE '_' LIMIT 2);
a	b	c
4	xxxa	xxxa
3	xxxb	xxxc
6	yyyd	yyyd
7	yyyf	yyyf
(SELECT * FROM t1 WHERE b LIKE 'yyy%' LIMIT 2) UNION DISTINCT (SELECT * FROM t1 WHERE b LIKE 'xxx%' ESCAPE '_' LIMIT 2);
a	b	c
4	xxxa	xxxa
3	xxxb	xxxc
6	yyyd	yyyd
7	yyyf	yyyf
-- Test JOIN
EXPLAIN SELECT * FROM t1 JOIN t1 as a1 on t1.a=a1.a WHERE t1.b LIKE 'xxx%';
EXPLAIN SELECT * FROM t1 JOIN t2 on t1.b=t2.b WHERE t1.b LIKE 'xxx%' AND t2.b LIKE 'yyy%';
EXPLAIN SELECT * FROM t1 LEFT JOIN t1 as a1 on t1.a=a1.a WHERE t1.b LIKE 'xxx%';
EXPLAIN SELECT * FROM t1 LEFT JOIN t2 on t1.b=t2.b WHERE t1.b LIKE 'xxx%' AND t2.b LIKE 'yyy%';
EXPLAIN SELECT * FROM t1 RIGHT JOIN t1 as a1 on t1.a=a1.a WHERE t1.b LIKE 'xxx%';
EXPLAIN SELECT * FROM t1 RIGHT JOIN t2 on t1.b=t2.b WHERE t1.b LIKE 'xxx%' AND t2.b LIKE 'yyy%';
