##    模拟TPCH-Q6
CREATE TABLE LINEITEM (L_ORDERKEY BIGINT NOT NULL,L_PARTKEY BIGINT NOT NULL,L_SUPPKEY BIGINT NOT NULL,L_LINENUMBER INTEGER,L_QUANTITY DECIMAL,L_EXTENDEDPRICE DECIMAL,L_DISCOUNT DECIMAL,L_SHIPDATE DATE,PRIMARY KEY (L_ORDERKEY, L_LINENUMBER)
) partition by key(L_ORDERKEY, L_LINENUMBER) partitions 4;

insert into LINEITEM values(1,1,1,1,1,1,1,'1000-01-01');
insert into LINEITEM values(2,2,2,2,2,2,2,'1001-01-01');
insert into LINEITEM values(3,3,3,3,3,3,3,'1002-01-01');
insert into LINEITEM values(4,4,4,4,4,4,4,'1003-01-01');
insert into LINEITEM values(5,5,5,5,5,5,5,'1004-01-01');
insert into LINEITEM values(6,6,6,6,6,6,6,'1005-01-01');
insert into LINEITEM values(7,7,7,7,7,7,7,'1005-01-01');
insert into LINEITEM values(8,8,8,8,8,8,8,'1005-01-01');
insert into LINEITEM values(9,9,9,9,9,9,9,'1005-01-01');

set ob_enable_trace_log = true;

select /*+use_px parallel(3)*/ * 
from
lineitem
where
l_shipdate >= '1000-01-01'
and l_shipdate < '1010-01-01' + interval '1' year
and l_discount between 1- 0.01 and 12 + 0.01
and l_quantity < 10;
+------------+-----------+-----------+--------------+------------+-----------------+------------+------------+
| L_ORDERKEY | L_PARTKEY | L_SUPPKEY | L_LINENUMBER | L_QUANTITY | L_EXTENDEDPRICE | L_DISCOUNT | L_SHIPDATE |
+------------+-----------+-----------+--------------+------------+-----------------+------------+------------+
|          1 |         1 |         1 |            1 |          1 |               1 |          1 | 1000-01-01 |
|          2 |         2 |         2 |            2 |          2 |               2 |          2 | 1001-01-01 |
|          3 |         3 |         3 |            3 |          3 |               3 |          3 | 1002-01-01 |
|          4 |         4 |         4 |            4 |          4 |               4 |          4 | 1003-01-01 |
|          5 |         5 |         5 |            5 |          5 |               5 |          5 | 1004-01-01 |
|          6 |         6 |         6 |            6 |          6 |               6 |          6 | 1005-01-01 |
