case 1 : varchar
drop table if exists t1;
create table t1(c0 int primary key,c1 varchar(1024)) EXPIRE_INFO ( c1 = 'd',enable_transaction_expire=true);
insert into t1 values(1,'i'),(2,'s'),(3,'D');
select c0,c1 from t1;
c0	c1
1	i
2	s
3	D
update t1 set c1='d' where c0=1;
update t1 set c1='d' where c0=2;
select c0,c1 from t1;
c0	c1
1	d
2	d
3	D
merge happens
alter system major freeze tenant = sys;
alter system major freeze tenant = all_user;
alter system major freeze tenant = all_meta;
select c0,c1 from t1;
c0	c1
3	D
drop table t1;
case 2 : expire row
drop table if exists t1;
create table t1(c0 int primary key,c1 int) EXPIRE_INFO =( c1 < 0,enable_transaction_expire=true);
insert into t1 values(1,1),(2,1),(3,1);
select c0,c1 from t1;
c0	c1
1	1
2	1
3	1
update t1 set c1=-1 where c0=1;
select c0,c1 from t1;
c0	c1
1	-1
2	1
3	1
merge happens
alter system major freeze tenant = sys;
alter system major freeze tenant = all_user;
alter system major freeze tenant = all_meta;
select c0,c1 from t1;
c0	c1
2	1
3	1
drop table t1;
case 3 : int + rows
drop table if exists t1;
create table t1(c0 int primary key,c1 int) EXPIRE_INFO ( c1 < 0,enable_transaction_expire=true);
insert into t1 values(1,1),(2,1),(3,1);
select c0,c1 from t1;
c0	c1
1	1
2	1
3	1
update t1 set c1=-1 where c0=1;
update t1 set c1=-1 where c0=2;
update t1 set c1=-1 where c0=3;
select c0,c1 from t1;
c0	c1
1	-1
2	-1
3	-1
merge happens
alter system major freeze tenant = sys;
alter system major freeze tenant = all_user;
alter system major freeze tenant = all_meta;
select c0,c1 from t1;
c0	c1
drop table t1;
