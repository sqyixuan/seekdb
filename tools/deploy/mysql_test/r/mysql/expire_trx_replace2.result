drop table if exists t1, t2;
create table t1(pk int primary key, c1 int, c2 int default 0) EXPIRE_INFO ( c1 < 100,enable_transaction_expire=true);
create table t2(pk int primary key, c1 int, c2 timestamp default now()) EXPIRE_INFO ( c1 < 100,enable_transaction_expire=true);
alter system set merge_delay_interval='30s' server_type=chunkserver;
alter system set merge_delay_for_lsync='30s' server_type=chunkserver;
insert 1000 rows to ups
alter system major freeze tenant = sys;
alter system major freeze tenant = all_user;
alter system major freeze tenant = all_meta;
select pk, c1, c2 from t1 where c1<100 limit 10;
pk	c1	c2
select pk, c1, c2 from t2 where c1<100 limit 10;
pk	c1	c2
select pk, c1, c2 from t1 where pk<=100 limit 10;
pk	c1	c2
100	1100	0
select pk, c1, c2 from t2 where pk<=100 limit 10;
pk	c1	c2
100	1100	createtime
select count(*) from t1;
count(*)
901
select count(*) from t2;
count(*)
901
create index idx on t1(c1);
create index idx on t2(c1);
