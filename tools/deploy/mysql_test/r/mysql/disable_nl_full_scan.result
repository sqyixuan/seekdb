      is_index_back=true, is_global_index=false, 
      range_key([t2.d3], [t2.__pk_increment]), range(MIN,MIN ; MAX,MAX)always true
explain select /*+ leading(T1 T2) use_nl(T1 T2) index(T2 idx_d3) */* from T1, T2 where c1 = d1 and c2 = 5;
