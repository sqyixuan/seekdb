result_format: 3
explain_protocol: 1
DROP DATABASE IF EXISTS NL_RIGHT_FULL_SCAN;
CREATE DATABASE NL_RIGHT_FULL_SCAN;
USE NL_RIGHT_FULL_SCAN;
create table T1 (c1 int, c2 int);
create table T2 (d1 int, d2 int, d3 int, index idx_d3(d3));
create table T3 (d1 int, d2 int key);
create table T4 (d1 int key, d2 int);
create table T5 (d1 int, d2 int, index idx_d1(d1));
EXPLAIN BASIC insert into T1 values (1, 2);
Query Plan
============================
|ID|OPERATOR          |NAME|
----------------------------
|0 |DISTRIBUTED INSERT|    |
|1 |└─EXPRESSION      |    |
============================
Outputs & filters:
-------------------------------------
  0 - output(nil), filter(nil)
      columns([{t1: ({t1: (t1.__pk_increment, t1.c1, t1.c2)})}]), 
      column_values([T_HIDDEN_PK], [column_conv(INT,PS:(11,0),NULL,__values.c1)], [column_conv(INT,PS:(11,0),NULL,__values.c2)])
  1 - output([__values.c1], [__values.c2]), filter(nil)
      values({1, 2})
insert into T1 values (1, 2);
# 场景1
# 表T1共1行，且有过滤条件c2 = 5，估计出的行数
# 远小于1，NL是更优计划。但是右表是全表扫描
# 所以禁止NL路径
explain select /*+ leading(T1 T2) index(T2 idx_d3) */* from T1, T2 where c1 = d1 and c2 = 5;
