create view v6 as ( SELECT col_bigint,col_char_20,col_decimal_20_0,col_timestamp_6,pk FROM table1_bigint WHERE SUBSTR( col_char_20 , 2 , 5 ) > TRIM( SUBSTR( CONCAT( SUBSTRING( 'e' , 1, 20) , HEX( SUBSTRING( 'o' , 1, 20) ) ) , 1 , 20 ) ) ORDER BY pk  , 5  , pk ASC LIMIT 9 , 4 ) UNION ALL ( SELECT col_bigint,col_char_20,col_decimal_20_0,col_timestamp_6,pk FROM table1_bigint WHERE col_char_20 IS NULL OR ( col_char_20 in ( 'x' ) AND  ( UPPER( TRIM( SUBSTR( CONCAT(SUBSTR( 'so' , 1, 20) , SUBSTRING( 'dsoer' , 1, 20) ) , 1 , 20 ) ) ) LIKE UPPER( '%a%' ) ESCAPE 'c' ) ) OR ( col_char_20 in ( 'x' ) && NOT ( col_char_20 IN (TRIM( SUBSTRING( TRIM( LEADING SUBSTR( 'jds' , 1, 20) FROM TRIM( SUBSTR( SUBSTRING( 'r' , 1, 20) , 1 , 20 ) ) ) , 1 , 20 ) ) , TRIM( SUBSTRING( REPEAT( SUBSTRING( 'qrjdso' , 1, 20) , 4 + 1 ) , 1 , 20 ) ) , TRIM( SUBSTR( COALESCE( SUBSTR( 'i' , 1, 20) , SUBSTR( 'e' , 1, 20) , SUBSTRING( 'rei' , 1, 20) ) , 1 , 20 ) )) ) ) ORDER BY pk DESC , 2 ASC , 5  , pk ASC LIMIT 40 , 4 ) ORDER BY col_bigint,col_char_20,col_decimal_20_0,col_timestamp_6,pk;
