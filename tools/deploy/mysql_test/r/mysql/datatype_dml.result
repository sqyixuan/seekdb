drop table if exists t;
create table t(
id            int primary key auto_increment,
col_int8      tinyint,
col_int16     smallint,
col_int24     mediumint,
col_int32     int,
col_int64     bigint,
col_uint8     tinyint unsigned,
col_uint16    smallint unsigned,
col_uint24    mediumint unsigned,
col_uint32    int unsigned,
col_uint64    bigint unsigned,
col_float     float,
col_double    double,
col_ufloat    float unsigned,
col_udouble   double unsigned,
col_decimal   decimal(20, 2),
col_udecimal  decimal(20, 4) unsigned,
col_datetime  datetime(2),
col_timestamp timestamp(3),
col_date      date,
col_time      time(4),
col_year      year(4),
col_varchar   varchar(6),
col_char      char(5),
col_varbinary varbinary(5),
col_binary    binary(4)
);
