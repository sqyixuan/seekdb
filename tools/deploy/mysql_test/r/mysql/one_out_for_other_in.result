drop table if exists t1;
CREATE TABLE t1 (
c1 INT
, v1 VARCHAR(65536)
, v2 VARCHAR(65536)
, PRIMARY KEY(c1)
);
insert into t1 values(1,'abc','123');
insert into t1 values(2,'def','456');
select * from t1;
c1	v1	v2
1	abc	123
2	def	456
select c1,v1 dc from t1 group by dc || 'kaka';
c1	dc
1	abc
Warnings:
Warning	1292	Truncated incorrect DOUBLE value: 'abc'
Warning	1292	Truncated incorrect DOUBLE value: 'def'
Warning	1292	Truncated incorrect DOUBLE value: 'kaka'
select c1,v1 dc from t1 group by concat(dc,'kaka');
c1	dc
1	abc
2	def
update t1 set v1=repeat(v1, 2), v2=repeat(v1, 2);
select * from t1;
c1	v1	v2
1	abcabc	abcabcabcabc
2	defdef	defdefdefdef
select v1, v1 DD, DD||'kaka' KK, KK || 'haha' from t1;
ERROR 42S22: Unknown column 'DD' in 'field list'
select v1, v1 DD, concat(DD,'kaka') KK, concat(KK,'haha') from t1;
ERROR 42S22: Unknown column 'DD' in 'field list'
