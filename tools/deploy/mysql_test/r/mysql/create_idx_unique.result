t1	0	idx_name	1	a	A	NULL	NULL	NULL	YES	BTREE	available		YES	NULL
insert into t1 values(3,5),(4,6),(1,1),(5,2),(2,3),(2,4);
ERROR 23000: Duplicate entry '2' for key 'idx1'
select * from t1;
