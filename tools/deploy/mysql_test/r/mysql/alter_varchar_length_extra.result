pk1	varchar(10)	NO	PRI	NULL	
pk2	varchar(10)	NO	PRI	a	
pk3	varchar(10)	NO	PRI	aa	
v1	varchar(10)	YES		aaa	
v2	varchar(10)	NO		NULL	
v3	varchar(10)	NO		aaaa	
