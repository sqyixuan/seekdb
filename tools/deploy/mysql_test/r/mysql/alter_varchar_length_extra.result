drop table if exists t1;
create table t1(pk1 varchar(10) not null, 
pk2 varchar(10) default 'a',
pk3 varchar(10) default 'aa' not null, 
v1 varchar(10) default 'aaa', 
v2 varchar(10) not null, 
v3 varchar(10) default 'aaaa' not null,
primary key(pk1,pk2,pk3));
insert into t1(pk1,pk3,v1,v2,v3) values('a','cc','ddd','eeee','fffff');
insert into t1(pk1,pk2,v1,v2,v3) values('a1','bb1','ddd1','eeee1','fffff1'),('a2','aaaa','aaa','eeee2','fffff2');
insert into t1(pk1,v2) values('a3','eeee3');
select * from t1;
pk1	pk2	pk3	v1	v2	v3
a	a	cc	ddd	eeee	fffff
a1	bb1	aa	ddd1	eeee1	fffff1
a2	aaaa	aa	aaa	eeee2	fffff2
a3	a	aa	aaa	eeee3	aaaa
desc t1;
