test server kill trans will call rollback
set ob_enable_index_direct_select=1;
alter system set merger_check_interval = '10s' tenant sys;
alter system set merger_check_interval = '10s' tenant all_user;
alter system set merger_check_interval = '10s' tenant all_meta;
drop table if exists test;
create table test(c1 int , c2 varchar(1024), c3 int, c4 varchar(1024), c5  timestamp(6) default "2012-01-01 12:00:00", c6 int, primary key(c1));
insert into test values(1,'a',1,'a','2013-12-03 00:00:00',1), (2,'b',2,'b','2013-12-03 00:00:00',2);
insert into test values(3,'a',1,'a','2013-12-03 00:00:00',1), (4,'b',2,'b','2013-12-03 00:00:00',2);
select * from test;
c1	c2	c3	c4	c5	c6
1	a	1	a	2013-12-03 00:00:00.000000	1
2	b	2	b	2013-12-03 00:00:00.000000	2
3	a	1	a	2013-12-03 00:00:00.000000	1
4	b	2	b	2013-12-03 00:00:00.000000	2
set  autocommit=0;
insert into test values(5,'a',1,'a','2013-12-03 00:00:00',1);
select * from test;
c1	c2	c3	c4	c5	c6
1	a	1	a	2013-12-03 00:00:00.000000	1
2	b	2	b	2013-12-03 00:00:00.000000	2
3	a	1	a	2013-12-03 00:00:00.000000	1
4	b	2	b	2013-12-03 00:00:00.000000	2
5	a	1	a	2013-12-03 00:00:00.000000	1
commit;
insert into test values(6,'a',1,'a','2013-12-03 00:00:00',1);
select * from test;
c1	c2	c3	c4	c5	c6
1	a	1	a	2013-12-03 00:00:00.000000	1
2	b	2	b	2013-12-03 00:00:00.000000	2
3	a	1	a	2013-12-03 00:00:00.000000	1
4	b	2	b	2013-12-03 00:00:00.000000	2
5	a	1	a	2013-12-03 00:00:00.000000	1
6	a	1	a	2013-12-03 00:00:00.000000	1
rollback;
select * from test;
c1	c2	c3	c4	c5	c6
1	a	1	a	2013-12-03 00:00:00.000000	1
2	b	2	b	2013-12-03 00:00:00.000000	2
3	a	1	a	2013-12-03 00:00:00.000000	1
4	b	2	b	2013-12-03 00:00:00.000000	2
5	a	1	a	2013-12-03 00:00:00.000000	1
set  autocommit=1;
