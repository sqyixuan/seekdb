set @@ob_query_timeout=15000000;
drop table if exists tt_3;
create table tt_3 (pk int primary key, c1 int)partition by hash(pk) partitions 50;
drop table if exists tt_2;
create table tt_2 (pk int primary key, c1 int)partition by hash(pk) partitions 50;
drop table if exists tt_1;
create table tt_1 (pk int primary key, c1 int)partition by hash(pk) partitions 50;
replace into tt_3 values(1,1);
replace into tt_2 values(1,1);
replace into tt_1 values(1,1);
select * from tt_3;
pk	c1
1	1
select * from tt_2;
pk	c1
1	1
select * from tt_1;
pk	c1
1	1
