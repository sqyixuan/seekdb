drop table if exists t1;
create table t1 (c1 int zerofill, c2 mediumtext, c3 mediumtext charset utf16);
insert into t1 values (1, '1', '1');
insert into t1 values (10000000, 'c2', 'c3');
select c1 from t1 union select c3 from t1;
c1
0000000001
0010000000
1
c3
select c1 from t1 union select c2 from t1;
c1
0000000001
0010000000
1
c2
select c1 + c2, c1 + c3 from t1 where c1=1;
c1 + c2	c1 + c3
2	2
select * from t1 where c1 = c3 and c1 = c2;
c1	c2	c3
0000000001	1	1
