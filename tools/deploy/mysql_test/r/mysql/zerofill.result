drop table if exists t1;
create table t1 (i int primary key, j int zerofill);
insert into t1 values (1,1), (9,9), (99,99);
SELECT upper(i), upper(j), upper(i+j) FROM t1;
upper(i)	upper(j)	upper(i+j)
1	0000000001	2
9	0000000009	18
99	0000000099	198
SELECT conv(j, '16', '10'), conv(-17, 10, -16) FROM t1;
conv(j, '16', '10')	conv(-17, 10, -16)
1	-11
9	-11
153	-11
SELECT INSERT(j, 3, 3, 'What'), insert(i, 3, 3, 'What') FROM t1;
