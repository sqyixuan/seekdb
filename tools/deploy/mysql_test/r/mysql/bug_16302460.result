drop table if exists t1;
create table t1(col1 bool, col2 tinyint, col3 smallint, col4 MEDIUMINT, col5 int,
                col6 BIGINT, col7 DECIMAL, col8 FLOAT, col9 datetime, col10 time,
                col11 varchar(20), col12 varbinary(21), col13 char, col14 BINARY);

insert into t1 values(NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL);
