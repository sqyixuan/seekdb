show variables like 'ob_query_timeout';
Variable_name	Value
ob_query_timeout	10000000
set ob_enable_index_direct_select=1;
alter system set merger_check_interval = '10s' tenant sys;
alter system set merger_check_interval = '10s' tenant all_user;
alter system set merger_check_interval = '10s' tenant all_meta;
drop table if exists t1,t2;
create table t1(pk1 int , pk2 varchar(1024), pk3 datetime(6), a int, b varchar(1024), c datetime(6), primary key(pk1,pk2,pk3));
insert into t1 values(1,'conn1','2018-12-12 12:00:00',400, 'r400','2018-12-12 12:00:00' );
insert into t1 values(2,'conn2','2016-12-12 12:00:00',300, 'r300','2016-12-12 12:00:00' );
insert into t1 values(3,'conn3','2014-12-12 12:00:00',200, 'r200','2014-12-12 12:00:00' );
insert into t1 values(4,'conn4','2012-12-12 12:00:00',100, 'r100','2012-12-12 12:00:00' );
create index i1 on t1(a);
create index i2 on t1(b);
create index i3 on t1(c);
begin;
select * from t1 where c>=date_sub('2012-12-12 12:00:00.000000', interval 1 minute) and c<=date_add('2012-12-12 12:00:00.000000', interval 100 year) for update;
pk1	pk2	pk3	a	b	c
4	conn4	2012-12-12 12:00:00.000000	100	r100	2012-12-12 12:00:00.000000
3	conn3	2014-12-12 12:00:00.000000	200	r200	2014-12-12 12:00:00.000000
2	conn2	2016-12-12 12:00:00.000000	300	r300	2016-12-12 12:00:00.000000
1	conn1	2018-12-12 12:00:00.000000	400	r400	2018-12-12 12:00:00.000000
update t1 set a=a+1 where pk1=4 and pk2='conn4' and pk3='2012-12-12 12:00:00.000000';
begin;
select * from t1 where c>=date_sub('2012-12-12 12:00:00.000000', interval 1 minute) and c<=date_add('2012-12-12 12:00:00.000000', interval 100 year) for update;
commit;
pk1	pk2	pk3	a	b	c
4	conn4	2012-12-12 12:00:00.000000	101	r100	2012-12-12 12:00:00.000000
3	conn3	2014-12-12 12:00:00.000000	200	r200	2014-12-12 12:00:00.000000
2	conn2	2016-12-12 12:00:00.000000	300	r300	2016-12-12 12:00:00.000000
1	conn1	2018-12-12 12:00:00.000000	400	r400	2018-12-12 12:00:00.000000
update t1 set b='abc' where pk1 = 4 and pk2 = 'conn4' and pk3 = '2012-12-12 12:00:00';
commit;
select * from t1;
pk1	pk2	pk3	a	b	c
1	conn1	2018-12-12 12:00:00.000000	400	r400	2018-12-12 12:00:00.000000
2	conn2	2016-12-12 12:00:00.000000	300	r300	2016-12-12 12:00:00.000000
3	conn3	2014-12-12 12:00:00.000000	200	r200	2014-12-12 12:00:00.000000
4	conn4	2012-12-12 12:00:00.000000	101	abc	2012-12-12 12:00:00.000000
select * from t1 where a>=9*10+11-1 and a<=(199%100+1)*10 for update;
pk1	pk2	pk3	a	b	c
4	conn4	2012-12-12 12:00:00.000000	101	abc	2012-12-12 12:00:00.000000
3	conn3	2014-12-12 12:00:00.000000	200	r200	2014-12-12 12:00:00.000000
2	conn2	2016-12-12 12:00:00.000000	300	r300	2016-12-12 12:00:00.000000
1	conn1	2018-12-12 12:00:00.000000	400	r400	2018-12-12 12:00:00.000000
select * from t1 where b>=concat('a','aa') and b<=concat('r',cast(900*10 as char(1024))) for update;
pk1	pk2	pk3	a	b	c
4	conn4	2012-12-12 12:00:00.000000	101	abc	2012-12-12 12:00:00.000000
3	conn3	2014-12-12 12:00:00.000000	200	r200	2014-12-12 12:00:00.000000
2	conn2	2016-12-12 12:00:00.000000	300	r300	2016-12-12 12:00:00.000000
