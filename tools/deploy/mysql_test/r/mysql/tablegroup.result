Table	Create Table
t3	CREATE TABLE `t3` (
  `c1` int(11) NOT NULL,
  PRIMARY KEY (`c1`)
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 COMPRESSION = 'lz4_1.0' REPLICA_NUM = NUM BLOCK_SIZE = SIZE USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = SIZE PCTFREE = 10 TABLEGROUP = 'tg2'
alter table t2 drop tablegroup;
alter table t3 drop tablegroup;
purge recyclebin;
create table t4(c1 int primary key);
alter tablegroup tg2 add table t4;
drop table t4;
