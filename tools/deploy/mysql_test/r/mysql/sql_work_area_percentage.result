alter system set enable_sql_operator_dump = 'false';
create resource unit test_unit max_cpu 4, max_memory '768M', min_memory '768M', max_iops=100000, max_disk_size=536870912, MAX_SESSION_NUM=64;
create tenant test_tenant resource_pool_list=('test_pool') set ob_tcp_invited_nodes='%';
set ob_query_timeout = 100000000;
use test;
create table test_table (pk int, value int, str_val varchar(8192));
insert into test_table (pk, value, str_val) values (1, 2, 'xx');
insert into test_table (pk, value, str_val) values (2, 3, 'xx');
select * from test_table order by value desc;
