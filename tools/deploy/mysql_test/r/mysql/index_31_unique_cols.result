result_format: 4
####TITLE:unique索引
####CASE:多列unique索引
create table index_31_unique_cols_t1(c1 int, c2 int, c3 int, c4 varchar(200), primary key(c1, c2));
create unique index index_31_unique_cols_i11 on index_31_unique_cols_t1(c3,c4);
create unique index index_31_unique_cols_i12 on index_31_unique_cols_t1(c2,c3) storing(c4);

insert into index_31_unique_cols_t1 values(1,1,1,'a');

insert into index_31_unique_cols_t1 values(2,2,2,'b');

####CASE: insert和静态数据/动态数据相同的值
insert into index_31_unique_cols_t1 values(3,3,1,'a');
ERROR 23000: Duplicate entry '1-a' for key 'index_31_unique_cols_i11'
insert into index_31_unique_cols_t1 values(3,1,1,'b');
ERROR 23000: Duplicate entry '1-1' for key 'index_31_unique_cols_i12'
insert into index_31_unique_cols_t1 values(3,1,1,'a');
ERROR 23000: Duplicate entry '1-a' for key 'index_31_unique_cols_i11'
insert into index_31_unique_cols_t1 values(3,3,2,'b');
ERROR 23000: Duplicate entry '2-b' for key 'index_31_unique_cols_i11'
insert into index_31_unique_cols_t1 values(3,2,2,'a');
ERROR 23000: Duplicate entry '2-2' for key 'index_31_unique_cols_i12'
insert into index_31_unique_cols_t1 values(3,2,2,'b');
ERROR 23000: Duplicate entry '2-b' for key 'index_31_unique_cols_i11'

insert into index_31_unique_cols_t1 values(3,1,2,'a');
insert into index_31_unique_cols_t1 values(4,2,1,'b');

select * from index_31_unique_cols_t1;
+----+----+------+------+
| c1 | c2 | c3   | c4   |
+----+----+------+------+
|  1 |  1 |    1 | a    |
|  2 |  2 |    2 | b    |
|  3 |  1 |    2 | a    |
|  4 |  2 |    1 | b    |
+----+----+------+------+
+----+----+------+------+
| c1 | c2 | c3   | c4   |
+----+----+------+------+
|  1 |  1 |    1 | a    |
|  4 |  2 |    1 | b    |
|  3 |  1 |    2 | a    |
|  2 |  2 |    2 | b    |
+----+----+------+------+
+----+----+------+------+
| c1 | c2 | c3   | c4   |
+----+----+------+------+
|  1 |  1 |    1 | a    |
|  3 |  1 |    2 | a    |
|  4 |  2 |    1 | b    |
|  2 |  2 |    2 | b    |
+----+----+------+------+
delete  from index_31_unique_cols_t1 where c1 in(3,4);

####CASE: replace和静态数据/动态数据相同的值
replace into index_31_unique_cols_t1 values(3,3,1,'a');
replace into index_31_unique_cols_t1 values(3,1,1,'b');
replace into index_31_unique_cols_t1 values(3,1,1,'a');
replace into index_31_unique_cols_t1 values(3,3,2,'b');
replace into index_31_unique_cols_t1 values(3,2,2,'a');
replace into index_31_unique_cols_t1 values(3,2,2,'b');

replace into index_31_unique_cols_t1(c1,c2,c3) values(3,1,1);
replace into index_31_unique_cols_t1(c1,c2,c3,c4) values(3,1,1,'a');
replace into index_31_unique_cols_t1(c1,c2,c3,c4) values(3,1,1,'b');
replace into index_31_unique_cols_t1(c1,c2,c3) values(3,2,2);
replace into index_31_unique_cols_t1(c1,c2,c3,c4) values(3,2,2,'b');
replace into index_31_unique_cols_t1(c1,c2,c3,c4) values(3,2,2,'b');

replace into index_31_unique_cols_t1(c1,c2,c3) values(1,1,2);
replace into index_31_unique_cols_t1(c1,c2,c4) values(1,6,'a');

select * from index_31_unique_cols_t1;
+----+----+------+------+
| c1 | c2 | c3   | c4   |
+----+----+------+------+
|  1 |  1 |    2 | NULL |
|  1 |  6 | NULL | a    |
|  3 |  1 |    1 | b    |
|  3 |  2 |    2 | b    |
+----+----+------+------+
+----+----+------+------+
| c1 | c2 | c3   | c4   |
+----+----+------+------+
|  1 |  6 | NULL | a    |
|  3 |  1 |    1 | b    |
|  1 |  1 |    2 | NULL |
|  3 |  2 |    2 | b    |
+----+----+------+------+
+----+----+------+------+
| c1 | c2 | c3   | c4   |
+----+----+------+------+
|  3 |  1 |    1 | b    |
|  1 |  1 |    2 | NULL |
|  3 |  2 |    2 | b    |
|  1 |  6 | NULL | a    |
+----+----+------+------+
replace into index_31_unique_cols_t1(c1,c2,c3,c4) values(1,1,1,'a');

select * from index_31_unique_cols_t1;
+----+----+------+------+
| c1 | c2 | c3   | c4   |
+----+----+------+------+
|  1 |  1 |    1 | a    |
|  1 |  6 | NULL | a    |
|  3 |  2 |    2 | b    |
+----+----+------+------+
+----+----+------+------+
| c1 | c2 | c3   | c4   |
+----+----+------+------+
|  1 |  6 | NULL | a    |
|  1 |  1 |    1 | a    |
|  3 |  2 |    2 | b    |
+----+----+------+------+
+----+----+------+------+
| c1 | c2 | c3   | c4   |
+----+----+------+------+
|  1 |  1 |    1 | a    |
|  3 |  2 |    2 | b    |
|  1 |  6 | NULL | a    |
+----+----+------+------+
replace into index_31_unique_cols_t1(c1,c2,c3) values(2,2,1);
replace into index_31_unique_cols_t1(c1,c2,c4) values(2,7,'b');

select * from index_31_unique_cols_t1;
+----+----+------+------+
| c1 | c2 | c3   | c4   |
+----+----+------+------+
|  1 |  1 |    1 | a    |
|  1 |  6 | NULL | a    |
|  2 |  2 |    1 | NULL |
|  2 |  7 | NULL | b    |
|  3 |  2 |    2 | b    |
+----+----+------+------+
+----+----+------+------+
| c1 | c2 | c3   | c4   |
+----+----+------+------+
|  1 |  6 | NULL | a    |
|  2 |  7 | NULL | b    |
|  2 |  2 |    1 | NULL |
|  1 |  1 |    1 | a    |
|  3 |  2 |    2 | b    |
+----+----+------+------+
+----+----+------+------+
| c1 | c2 | c3   | c4   |
+----+----+------+------+
|  1 |  1 |    1 | a    |
|  2 |  2 |    1 | NULL |
|  3 |  2 |    2 | b    |
|  1 |  6 | NULL | a    |
|  2 |  7 | NULL | b    |
+----+----+------+------+
replace into index_31_unique_cols_t1(c1,c2,c3,c4) values(2,2,2,'b');

select * from index_31_unique_cols_t1;
+----+----+------+------+
| c1 | c2 | c3   | c4   |
+----+----+------+------+
|  1 |  1 |    1 | a    |
|  1 |  6 | NULL | a    |
|  2 |  2 |    2 | b    |
|  2 |  7 | NULL | b    |
+----+----+------+------+
+----+----+------+------+
| c1 | c2 | c3   | c4   |
+----+----+------+------+
|  1 |  6 | NULL | a    |
|  2 |  7 | NULL | b    |
|  1 |  1 |    1 | a    |
|  2 |  2 |    2 | b    |
+----+----+------+------+
+----+----+------+------+
| c1 | c2 | c3   | c4   |
+----+----+------+------+
|  1 |  1 |    1 | a    |
|  2 |  2 |    2 | b    |
|  1 |  6 | NULL | a    |
|  2 |  7 | NULL | b    |
+----+----+------+------+
replace into index_31_unique_cols_t1 values(3,1,2,'a');
replace into index_31_unique_cols_t1 values(4,2,1,'b');

delete  from index_31_unique_cols_t1 where c1 in(3,4);

####CASE: update 和静态数据，动态数据相同的值
insert into index_31_unique_cols_t1 values(3,3,3,'c');
replace into index_31_unique_cols_t1 values(4,4,4,'d');
update index_31_unique_cols_t1 set c3=1, c4='a' where c1=3;
ERROR 23000: Duplicate entry '1-a' for key 'index_31_unique_cols_i11'
update index_31_unique_cols_t1 set c2=1, c3=1 where c1=3;
ERROR 23000: Duplicate entry '1-1' for key 'index_31_unique_cols_i12'
update index_31_unique_cols_t1 set c2=1, c3=1, c4='a' where c1=3;
ERROR 23000: Duplicate entry '1-a' for key 'index_31_unique_cols_i11'

update index_31_unique_cols_t1 set c3=2, c4='b' where c1=3;
ERROR 23000: Duplicate entry '2-b' for key 'index_31_unique_cols_i11'
update index_31_unique_cols_t1 set c2=2, c3=2 where c1=3;
ERROR 23000: Duplicate entry '2-2' for key 'index_31_unique_cols_i12'
update index_31_unique_cols_t1 set c2=2, c3=2, c4='b' where c1=3;
ERROR 23000: Duplicate entry '2-b' for key 'index_31_unique_cols_i11'

update index_31_unique_cols_t1 set c3=3, c4='c' where c1=1;
ERROR 23000: Duplicate entry '3-c' for key 'index_31_unique_cols_i11'
update index_31_unique_cols_t1 set c2=3, c3=3 where c1=1;
ERROR 23000: Duplicate entry '1-3' for key 'PRIMARY'
update index_31_unique_cols_t1 set c2=3, c3=3, c4='c' where c1=1;
ERROR 23000: Duplicate entry '1-3' for key 'PRIMARY'

update index_31_unique_cols_t1 set c2=1 where c1=3;
update index_31_unique_cols_t1 set c3=2 where c1=3;
update index_31_unique_cols_t1 set c4='a' where c1=3;
update index_31_unique_cols_t1 set c2=2, c3=1, c4='b' where c1=4;
update index_31_unique_cols_t1 set c2=2, c3=1 where c1=4;
update index_31_unique_cols_t1 set c3=1, c4='b' where c1=4;

select * from index_31_unique_cols_t1;
+----+----+------+------+
| c1 | c2 | c3   | c4   |
+----+----+------+------+
|  1 |  1 |    1 | a    |
|  1 |  6 | NULL | a    |
|  2 |  2 |    2 | b    |
|  2 |  7 | NULL | b    |
|  3 |  1 |    2 | a    |
|  4 |  2 |    1 | b    |
+----+----+------+------+
+----+----+------+------+
| c1 | c2 | c3   | c4   |
+----+----+------+------+
|  1 |  6 | NULL | a    |
|  2 |  7 | NULL | b    |
|  1 |  1 |    1 | a    |
|  4 |  2 |    1 | b    |
|  3 |  1 |    2 | a    |
|  2 |  2 |    2 | b    |
+----+----+------+------+
+----+----+------+------+
| c1 | c2 | c3   | c4   |
+----+----+------+------+
|  1 |  1 |    1 | a    |
|  3 |  1 |    2 | a    |
|  4 |  2 |    1 | b    |
|  2 |  2 |    2 | b    |
|  1 |  6 | NULL | a    |
|  2 |  7 | NULL | b    |
+----+----+------+------+
delete  from index_31_unique_cols_t1 where c1 in(3,4);
drop table if exists index_31_unique_cols_t1;
