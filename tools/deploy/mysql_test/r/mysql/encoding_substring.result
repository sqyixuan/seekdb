drop table if exists bct_m_task;
create table if not exists `bct_m_task` (
`mbrON` varchar(60) not null,
`corprON` varchar(60) not null,
`xON` varchar(60) not null,
`xONm` varchar(256) not null,
`prodCd` varchar(40) not null,
`prodNm` varchar(128) not null,
`svrProderCd` varchar(40) comment '001-百行 002-互金协会',
`xSer` varchar(32) not null comment '第一次录入业务时的交易流水号',
`xDt` varchar(10) not null comment '第一次录入业务时的系统日期',
`smtAudXSer` varchar(32),
`audXSer` varchar(32),
`smtXSer` varchar(32),
`xUCd` varchar(40) not null,
`xUNm` varchar(128) not null,
`audUCd` varchar(40),
`audUNm` varchar(128),
`smtUCd` varchar(40),
`smtUNm` varchar(128),
`cerAutnN` varchar(60) comment 'SQS+3位节点号+14位时间+5位顺序号',
`cerAutnFPath` varchar(256),
`cerAutnFMd5` varchar(32),
`prodTyp` varchar(16) not null comment '01：征信报告 02：数据报送 03：核检核查 04：查询类 05：企业类',
`dataRptTyp` varchar(16) comment '产品类型为“02：数据报送”时，必填
            01：A1-贷款申请信息 02：D2-非循环贷款账户数据
            03：D3-非循环贷款贷后数据 04：D4-非循环贷款展期数据
            05：X3-循环贷款账户数据 06：X4-循环贷款合并账单数据
            07：循环贷款合并账单还款数据 08：循环贷款非合并账单数据
            09：循环贷款非合并账单还款数据',
`dataSrcFlg` char(1) comment '1：单笔 2：文件；产品类型为“02：数据报送”时，必填',
`entrgDm` varchar(20) not null,
`smtAudDm` varchar(20),
`audDm` varchar(20),
`smtDm` varchar(20),
`rtnDm` varchar(20) comment '数据报送异步结果返回的日时，其他交易为同步结果返回的日时',
`nm` varchar(256) comment '企业类任务，存储企业名称',
`crdlsNo` varchar(64),
`crdlsTyp` varchar(2),
`phnNo` varchar(32),
`bizSta` varchar(8) not null comment '0：初始状态 1：待审核 2：已审核（状态可以提交任务）
            3：退回（状态可以修改、删除） 4：已提交 5：结果已返回
            9：异步处理中',
`audRslt` varchar(8) comment 'Y：通过 N：退回',
`audDesc` varchar(128),
`nisReqSer` varchar(32) comment '数据报送类的，记录最新提交信息交换平台成功的请求流水号',
`nisRespSer` varchar(32) comment '数据报送类的，记录最新提交信息交换平台成功的响应流水号',
`rtnCd` varchar(40) comment '调用产品云接口的返回码',
`rtnInfo` varchar(1024) comment '调用产品云接口的返回信息',
`qryRsltSta` varchar(8) comment '0-未查得 1-已查得',
`rsltFlg` char(1) comment '0：未知 1：正确  2：错误，数据报送结果',
`rsltErrTyp` varchar(16) comment 'inputerror-格式校验错误 logicerror-逻辑校验错误',
`rptTms` bigint(20),
`reqXData` varchar(230400) comment '交易记录请求报文中的body内容，加密保存            新增、修改页面中的保存/提交审核操作时需要保存',
`rtnXData` varchar(4096) comment '交易记录响应报文中的body内容，加密保存；产品类型为01、05时的提交操作时要保存；其他产品类型不保存',
`upldFNm` varchar(256) comment '产品类型为“02：数据报送”且数据来源标志为“2：文件”时，必填；包括路径；前端与后台使用共享盘',
`upldFMd5` varchar(32),
`lclRptFNm` varchar(256) comment '根据设计约定，生成的数据上报文件本地存储名称及路径；',
`rptFNm` varchar(256) comment '根据信息交换平台约定的文件名及文件格式，生成数据报送文件名称，包括路径；推送到gofast文件服务器上的路径；',
`rsltFNm` varchar(256) comment '放在前端与后台的共享盘上',
`rsltFMd5` varchar(32),
`regDm` varchar(20) comment '格式：yyyy-MM-dd HH:mm:ss',
`modDm` varchar(20) comment '格式：yyyy-MM-dd HH:mm:ss',
`delFlg` char(1) not null comment '0-未删除 1-已删除',
`shortRmk` varchar(128),
`midRmk` varchar(256),
`longRmk` varchar(512),
PRIMARY KEY (`xSer`)
)block_size=131072
default charset=utf8mb4
default collate=utf8mb4_general_ci;
CREATE INDEX `BCT_M_TASK_IDX1` ON `bct_m_task` (`xON` ASC, `prodCd` ASC, `xDt` ASC, `xUCd` ASC, `entrgDm` ASC) GLOBAL;
