drop database if exists hualong;
create database hualong;
use hualong;
create table t_abc (a int primary key, b int, c int, index idx_b(b), unique idx_c(c));
insert into t_abc values (1, 1, 10), (11, 1, 100), (111, 1, 1000), (2, 2, 20), (22, 2, 200), (222, 2, 2000), (3, NULL, NULL), (33, NULL, NULL), (333, NULL, NULL);
create table t_xyz (x int primary key, y int, z int, index idx_y(y), unique idx_z(z));
insert into t_xyz values (1, 1, 10), (11, 1, 100), (111, 1, 1000), (2, 2, 20), (22, 2, 200), (222, 2, 2000), (3, NULL, NULL), (33, NULL, NULL), (333, NULL, NULL);

