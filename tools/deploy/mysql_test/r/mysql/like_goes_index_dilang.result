EXPLAIN SELECT * FROM t1 WHERE b like REPEAT('x' , 3) ;
EXPLAIN SELECT * FROM t1 WHERE b like SUBSTR('%xxx%',2,4) ;
EXPLAIN SELECT * FROM t1 WHERE b like UPPER('xxx%') ;
EXPLAIN SELECT * FROM t1 WHERE b like LOWER('XXX%') ;
