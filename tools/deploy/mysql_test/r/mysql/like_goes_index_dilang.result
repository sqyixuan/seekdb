2	xxxc	xxxb	xxxb	xxxb
3	xxxb	xxxc	xxxc	xxxc
4	xxxa	xxxa	xxxa	xxxa
EXPLAIN SELECT * FROM t1 WHERE b like REPEAT('x' , 3) ;
EXPLAIN SELECT * FROM t1 WHERE b like SUBSTR('%xxx%',2,4) ;
EXPLAIN SELECT * FROM t1 WHERE b like UPPER('xxx%') ;
EXPLAIN SELECT * FROM t1 WHERE b like LOWER('XXX%') ;
-- 通过and/or连接多个like表达式
SELECT * FROM t1 WHERE b like 'xxx%' and b like 'yyy%' ;
a	b	c	d	e
SELECT * FROM t1 WHERE b like 'xxx%' ESCAPE 'x' or b like 'xxx%' ;
a	b	c	d	e
2	xxxc	xxxb	xxxb	xxxb
3	xxxb	xxxc	xxxc	xxxc
4	xxxa	xxxa	xxxa	xxxa
SELECT * FROM t1 WHERE b like 'xxx%' ESCAPE 'a' or b like 'xxx%' and b not like 'yyy%' ;
a	b	c	d	e
2	xxxc	xxxb	xxxb	xxxb
3	xxxb	xxxc	xxxc	xxxc
4	xxxa	xxxa	xxxa	xxxa
SELECT * FROM t1 WHERE b != 'xxxx' and b like 'xxx%' ;
a	b	c	d	e
2	xxxc	xxxb	xxxb	xxxb
3	xxxb	xxxc	xxxc	xxxc
4	xxxa	xxxa	xxxa	xxxa
SELECT * FROM t1 WHERE b = 'xxxx' or b like 'xxx%' ;
a	b	c	d	e
2	xxxc	xxxb	xxxb	xxxb
3	xxxb	xxxc	xxxc	xxxc
4	xxxa	xxxa	xxxa	xxxa
