-- col like col_str2中col_str2是concat、substr、upper、lower等字符串函数的输出
SELECT * FROM t1 WHERE CONCAT(b,'ccc') like 'xxx%' ;
a	b	c	d	e
2	xxxc	xxxb	xxxb	xxxb
3	xxxb	xxxc	xxxc	xxxc
4	xxxa	xxxa	xxxa	xxxa
SELECT * FROM t1 WHERE REPEAT(b,5) like 'xxx%' ESCAPE 'x' ;
a	b	c	d	e
SELECT * FROM t1 WHERE LOWER(b) like 'xxx%' ESCAPE 'a' ;
a	b	c	d	e
2	xxxc	xxxb	xxxb	xxxb
3	xxxb	xxxc	xxxc	xxxc
4	xxxa	xxxa	xxxa	xxxa
SELECT * FROM t1 WHERE SUBSTR(b,1,4) like 'xxx%' ESCAPE 'a' ;
