drop table t1;
create table t1 (c1 datetime primary key, c2 datetime(6), c3 datetime(6), c4 datetime(6), c5 datetime(6), c6 datetime(6), c7 datetime(6), c8 datetime(6), c9 datetime(6), c10 datetime(6), c11 datetime(6), c12 datetime(6), c13 datetime(6), c14 datetime(6), c15 datetime(6), c16 datetime(6), c17 datetime(6), c18 datetime(6), c19 datetime(6), c20 datetime(6));
insert into t1 values(current_timestamp(), current_time(),now(),now(),now(),now(),now(),now(),now(),now(),now(),now(),now(),now(),now(),now(),now(),now(),now(),now());
prepare stmt1 from insert into t1 values(?, now(),now(),now(),now(),now(),now(),now(),now(),now(),now(),now(),now(),now(),?,now(),now(),now(),now(),now());
prepare stmt2 from select c1, c15 from t1 where c1=?;
set @a = timestamp'2003-01-01 24:00:00';
set @b = timestamp'2013-02-07 23:00:01';
execute stmt1 using @a, @b;
execute stmt2 using @a;
c1	c15
2003-01-02 00:00:00	2013-02-07 23:00:01
