create database jx_db;
use jx_db;
create table t1 (c1 int primary key);
alter table t1 comment = 'table t1';
alter table t1 set comment = 'table t1';
alter database jx_db set charset = 'utf8mb4';
alter database jx_db charset = 'utf8mb4';
alter system set enable_sys_table_ddl = true;
alter system enable_sys_table_ddl = false;
