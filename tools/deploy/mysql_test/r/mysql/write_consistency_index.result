create table test(pk int primary key, c1 int);
create unique index i1 on test(c1);
insert into test(pk, c1) values(0,1),(1,2);
select * from test;
pk	c1
0	1
1	2
set autocommit=0;
update test set c1=c1-1 where pk>=0;
select * from test;
pk	c1
0	0
1	1
set autocommit=0;
set session ob_query_timeout=500000000;
update test set c1=c1 where pk>=0;
commit;
select * from test;
pk	c1
0	0
1	1
commit;
select * from test;
pk	c1
0	0
1	1
commit;
select * from test;
pk	c1
0	0
1	1
commit;
