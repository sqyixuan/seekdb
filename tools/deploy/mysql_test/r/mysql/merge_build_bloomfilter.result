**** prepare base sstable
create table t_bloom_1 (
c1 int,
c2 int,
c3 int,
c4 int,
c5 int,
primary key (c1, c2, c3, c4)
) progressive_merge_num = 1;
create table t_bloom_2 (
c1 int,
c2 int,
c3 int,
c4 int,
c5 int,
primary key (c1, c2, c3, c4)
) progressive_merge_num = 1  use_bloom_filter = true;
create table t_bloom_3 (
c1 int,
c2 int,
c3 int,
c4 int,
c5 int,
primary key (c1, c2, c3, c4)
) progressive_merge_num = 1  use_bloom_filter = true;
create table t_bloom_4 (
c1 int,
c2 int,
c3 int,
c4 int,
c5 int,
primary key (c1, c2, c3, c4)
) progressive_merge_num = 1  use_bloom_filter = true;
