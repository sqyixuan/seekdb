drop table if exists tbl1,tbl2;
create table tbl1 (
pk int,
i1 int, 
v2 varchar(80), 
i3 char(20),
i4 float, 
d4 datetime(6),
i5 decimal(5,3),
i6 bool, 
primary key(pk), 
unique index idx1(i1),
unique index idx2(v2),
unique index idx4(i3, i1));
