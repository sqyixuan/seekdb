alter system enable sql throttle for priority <= 100 using queue_time=100;
alter system enable sql throttle for priority <= 100 using rt=100;
show global variables like '%sql_throttle%';
Variable_name	Value
sql_throttle_cpu	-1
sql_throttle_current_priority	100
sql_throttle_io	-1
sql_throttle_logical_reads	-1
sql_throttle_network	-1
sql_throttle_priority	100
sql_throttle_rt	100
alter system disable sql throttle;
show global variables like '%sql_throttle%';
Variable_name	Value
sql_throttle_cpu	-1
sql_throttle_current_priority	100
sql_throttle_io	-1
sql_throttle_logical_reads	-1
sql_throttle_network	-1
sql_throttle_priority	-1
sql_throttle_rt	-1
