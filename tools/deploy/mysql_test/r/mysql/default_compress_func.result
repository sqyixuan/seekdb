drop database if exists db_create;
create database db_create;
use db_create;
===============================================
alter system set default_compress_func = 'lz4_1.0';
show parameters where svr_ip = host_ip() and name = 'default_compress_func' and svr_port = rpc_port();
zone	svr_type	svr_ip	svr_port	name	data_type	value	info	section	scope	source	edit_level	default_value	isdefault
zone1	observer	server_ip	server_port	default_compress_func	STRING	lz4_1.0	default compress function name for create new table, values: none, lz4_1.0, snappy_1.0, zstd_1.0, zstd_1.3.8	OBSERVER	CLUSTER	DEFAULT	DYNAMIC_EFFECTIVE	zstd_1.3.8	0
drop table if exists compress_table;
CREATE TABLE compress_table (c1 int primary key, c2 varchar(500), c3 float, index i1 (c1), index i2 (c2), unique index i2_u (c2));
show create table compress_table;
Table	Create Table
compress_table	CREATE TABLE `compress_table` (
  `c1` int(11) NOT NULL,
  `c2` varchar(500) DEFAULT NULL,
  `c3` float DEFAULT NULL,
  PRIMARY KEY (`c1`),
  UNIQUE KEY `i2_u` (`c2`) BLOCK_SIZE 16384 LOCAL,
  KEY `i1` (`c1`) BLOCK_SIZE 16384 LOCAL,
  KEY `i2` (`c2`) BLOCK_SIZE 16384 LOCAL
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 COMPRESSION = 'lz4_1.0' REPLICA_NUM = NUM BLOCK_SIZE = SIZE USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = SIZE PCTFREE = 10
