update /*+ hotspot*/ t1 set c2='aaad' where c2='aaaa';
select * from t1;
c1	c2
0	zzzz
1	aaac
2	aaad
3	aaad
set @a='aaae';
prepare stmt0 from update /*+ hotspot */ t1 set c2=? where c1=1;
prepare stmt1 from update /*+ hotspot */ t1 set c2='aaaf' where c2=?;
execute stmt0 using @a;
select * from t1;
c1	c2
0	zzzz
1	aaae
2	aaad
3	aaad
execute stmt1 using @a;
select * from t1;
c1	c2
0	zzzz
1	aaaf
2	aaad
3	aaad
set @a='aaaf';
execute stmt0 using @a;
select * from t1;
