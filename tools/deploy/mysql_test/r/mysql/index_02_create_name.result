result_format: 4
####
set @@ob_enable_index_direct_select = 1;

create table t1(c1 int primary key, c2 varchar(1024), c3 int);
create table t2(c1 int , c2 varchar(1024), c3 int, c4 varchar(1024), c5  timestamp(6) default "2012-01-01 12:00:00", c6 int, primary key(c1, c2));
create table t3(c1 int primary key, c2 varchar(1024), c3 int);

####CASE:using same name, then drop index, then create
create index i1 on t1(c2,c3);
create index i1 on t1(c2,c3);
ERROR 42000: Duplicate key name 'i1'
drop index i1 on t1;
create index i1 on t1(c2,c3);
drop index i1 on t1;
show index from t1;
Table	Non_unique	Key_name	Seq_in_index	Column_name	Collation	Cardinality	Sub_part	Packed	Null	Index_type	Comment	Index_comment	Visible	Expression
t1	0	PRIMARY	1	c1	A	NULL	NULL	NULL		BTREE	available		YES	NULL
alter system major freeze tenant = sys;
alter system major freeze tenant = all_user;
alter system major freeze tenant = all_meta;
create index i1 on t1(c2,c3);
####CASE:using name of other table
create index t1 on t1(c3);
create index t2 on t1(c1,c2,c3);
create index i1 on t2(c3,c4) storing(c5);
create index test_ on t2(c3,c4);

