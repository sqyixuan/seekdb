DROP TABLE IF EXISTS t2;
DROP TABLE IF EXISTS t1;
CREATE TABLE t1(c0 INT,c1 CHAR(10))
PARTITION BY LIST COLUMNS(c1)
(PARTITION l1 VALUES IN('A','中文','COL','NAL','AB',''),
 PARTITION l2 VALUES IN('10','12','$ % &','$%&','文')
);
CREATE TABLE t2(c0 INT,c1 CHAR(10))
PARTITION BY LIST COLUMNS(c1)
(PARTITION l1 VALUES IN('AB','中','test 1','中guo','$&'),
 PARTITION l2 VALUES IN('10','12','$ % &','ABC','mars','13','')
 );


explain SELECT * FROM t1 WHERE c1 IN (SELECT c1 FROM t2 WHERE c1 <>ALL (SELECT c1 FROM t1)) ORDER BY 1,2;
