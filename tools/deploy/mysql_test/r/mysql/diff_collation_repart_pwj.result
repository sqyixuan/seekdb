result_format: 4
drop table if exists t1,t2;
create table t1 (c1 varchar(20) collate utf8mb4_general_ci primary key, c2 varchar(20) collate utf8mb4_general_ci) partition by key(c1) partitions 8;
create table t2 (c1 varchar(20) collate utf8mb4_bin primary key, c2 varchar(20) collate utf8mb4_bin) partition by key(c1) partitions 8;

insert into t1 values ('a', 'a'), ('B', 'B'), ('c', 'c');
insert into t2 values ('a', 'a'), ('B', 'B'), ('c', 'c');

explain select * from t1, t2 where t1.c1 = t2.c2;
