prepare trx2stmt1 from select * from t1 where pk=? for update when row_count(update t1 set v1=? where pk=? when row_count(insert into t1 values(?,?,?,?)) =1) = 1;
prepare trx2utmt1 from update t1 set v1=? where pk=? when row_count(insert into t1 values(?,?,?,?))=0;
set @s1=1;
set @s2='when-select-update-insert1';
set @s3=5;
set @s4='when-select-update-insert2';
set @s5='2013-12-16';
execute trx2stmt1 using @s1,@s2,@s1,@s3,@s3,@s4,@s5;
