drop table if exists t1,t2,t3,t4;
create table t1(pk int primary key, a int);
insert into t1 values(1,1);
insert into t1 values(2,1);
-- conn1 update row1 to  +1
begin;
update t1 set a=a+1 where pk = 1;
-- conn2 update row2 to  +1, then update row1 to +1
begin;
update t1 set a=a+1 where pk = 2;
update t1 set a=a+1 where pk = 1;
Got one of the listed errors
ROLLBACK;
--expect (1,2),(2,1)
commit;
select * from t1;
pk	a
1	2
2	1
drop table t1;
###################
create table t1(pk varchar(1024) primary key, a varchar(1024));
insert into t1 values('1','1');
insert into t1 values('2','1');
-- conn1 update row1 to  '2'
begin;
update t1 set a='2' where pk = '1';
-- conn2 update row2 to  '2', then update row1 to '3'
begin;
update t1 set a='2' where pk = '2';
update t1 set a='3' where pk = '1';
Got one of the listed errors
ROLLBACK;
commit;
--expect ('1','2'),('2','1')
select * from t1;
pk	a
1	2
2	1
drop table t1;
###################
create table t1(pk int primary key, aint1 int, aint2 int, aint3 int, aint4 int);
insert into t1 values(1, 1, 1, -1, -1);
insert into t1 values(2, 2, 2, -2, -2);
insert into t1 values(3, 3, 3, -3, -3);
insert into t1 values(4, 4, 4, -4, -4);
insert into t1 values(5, 5, 5, -5, -5);
select sum(aint1+aint2+aint3+aint4) as mysum from t1;
mysum
0
begin;
update t1 set aint1=aint1+1 where pk=1;
update t1 set aint3=aint3-1 where pk=3;
update t1 set aint3=aint3-1 where pk=1;
update t1 set aint1=aint1+1 where pk=3;
commit;
begin;
update t1 set aint1=aint1+1 where pk=2;
update t1 set aint1=aint1+1 where pk=4;
update t1 set aint3=aint3-1 where pk=4;
update t1 set aint3=aint3-1 where pk=2;
begin;
update t1 set aint1=aint1+1 where pk=5;
update t1 set aint3=aint3-1 where pk=5;
update t1 set aint3=aint3-1 where pk=1;
update t1 set aint1=aint1+1 where pk=1;
begin;
update t1 set aint3=aint3-1 where pk=3;
update t1 set aint1=aint1+1 where pk=3;
update t1 set aint1=aint1+1 where pk=2;
Got one of the listed errors
update t1 set aint3=aint3-1 where pk=2;
Got one of the listed errors
ROLLBACK;
commit;
commit;
select * from t1;
pk	aint1	aint2	aint3	aint4
1	3	1	-3	-1
2	3	2	-3	-2
3	4	3	-4	-3
4	5	4	-5	-4
5	6	5	-6	-5
drop table t1;
###################
create table t1(f1 int, f2 int, a int, primary key(f1,f2));
insert into t1 values(1,1,1);
insert into t1 values(1,2,1);
insert into t1 values(2,1,1);
insert into t1 values(2,2,1);
begin;
update t1 set a=a+1 where f1=1 and f2=1;
update t1 set a=a+1 where f1=2 and f2=1;
begin;
update t1 set a=a+1 where f1=1 and f2=2;
update t1 set a=a+1 where f1=2 and f2=2;
commit;
commit;
--expect (1,1,2),(1,2,2),(2,1,2),(2,2,2)
select * from t1;
f1	f2	a
1	1	2
1	2	2
2	1	2
2	2	2
begin;
update t1 set a=a+1 where f1=1 and f2=1;
update t1 set a=a+1 where f1=2 and f2=2;
begin;
update t1 set a=a+1 where f1=2 and f2=1;
begin;
update t1 set a=a+1 where f1=1 and f2=2;
update t1 set a=a+1 where f1=1 and f2=1;
Got one of the listed errors
ROLLBACK;
commit;
commit;
--expect (1,1,3),(1,2,2),(2,1,3),(2,2,3)
select * from t1;
f1	f2	a
1	1	3
1	2	2
2	1	3
2	2	3
--rowkey is not required
begin;
update t1 set a=a+1 where f1=1;
ROLLBACK;
--expect (1,1,3),(1,2,2),(2,1,3),(2,2,3)
select * from t1;
f1	f2	a
1	1	3
1	2	2
2	1	3
2	2	3
drop table t1;
###################
create table t1(f1 int, f2 varchar(1024), a int, primary key(f1,f2));
insert into t1 values(1,'1',1);
insert into t1 values(1,'2',1);
insert into t1 values(2,'1',1);
insert into t1 values(2,'2',1);
begin;
update t1 set a=a+1 where f1=1 and f2='1';
update t1 set a=a+1 where f1=2 and f2='1';
begin;
update t1 set a=a+1 where f1=1 and f2='2';
update t1 set a=a+1 where f1=2 and f2='2';
commit;
commit;
--expect (1,'1',2),(1,'2',2),(2,'1',2),(2,'2',2)
select * from t1;
f1	f2	a
1	1	2
1	2	2
2	1	2
2	2	2
begin;
update t1 set a=a+1 where f1=1 and f2='1';
update t1 set a=a+1 where f1=2 and f2='2';
begin;
update t1 set a=a+1 where f1=2 and f2='1';
begin;
update t1 set a=a+1 where f1=1 and f2='2';
update t1 set a=a+1 where f1=1 and f2='1';
Got one of the listed errors
ROLLBACK;
commit;
commit;
--expect (1,'1',3),(1,'2',2),(2,'1',3),(2,'2',3)
select * from t1;
f1	f2	a
1	1	3
1	2	2
2	1	3
2	2	3
--rowkey is not required
begin;
update t1 set a=a+1 where f1=1;
ROLLBACK;
--expect (1,'1',3),(1,'2',2),(2,'1',3),(2,'2',3)
select * from t1;
f1	f2	a
1	1	3
1	2	2
2	1	3
2	2	3
drop table t1;
################### update more columns
create table t1(f1 int, f2 varchar(1024), a int, b int, primary key(f1,f2));
insert into t1 values(1,'1',1,0);
insert into t1 values(1,'2',1,0);
insert into t1 values(2,'1',1,0);
insert into t1 values(2,'2',1,0);
begin;
update t1 set a=a+1,b=b-1 where f1=1 and f2='1';
update t1 set a=a+1,b=b-1 where f1=2 and f2='1';
begin;
update t1 set a=a+1,b=b-1 where f1=1 and f2='2';
update t1 set a=a+1,b=b-1 where f1=2 and f2='2';
commit;
commit;
--expect (1,'1',2,-1),(1,'2',2,-1),(2,'1',2,-1),(2,'2',2,-1)
select * from t1;
f1	f2	a	b
1	1	2	-1
1	2	2	-1
2	1	2	-1
2	2	2	-1
begin;
update t1 set a=a+1,b=b-1 where f1=1 and f2='1';
update t1 set a=a+1,b=b-1 where f1=2 and f2='2';
begin;
update t1 set a=a+1,b=b-1 where f1=2 and f2='1';
begin;
update t1 set a=a+1,b=b-1 where f1=1 and f2='2';
update t1 set a=a+1,b=b-1 where f1=1 and f2='1';
Got one of the listed errors
ROLLBACK;
commit;
commit;
--expect (1,'1',3,-2),(1,'2',2,-1),(2,'1',3,-2),(2,'2',3,-2)
select * from t1;
f1	f2	a	b
1	1	3	-2
1	2	2	-1
2	1	3	-2
2	2	3	-2
drop table t1;
