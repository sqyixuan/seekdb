drop table if exists pmt_apply_ord_003;
CREATE TABLE `pmt_apply_ord_003` (
`apply_id_prefix` varchar(1) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '准备单ID前缀',
`apply_id` varchar(64) COLLATE utf8mb4_bin NOT NULL COMMENT '准备单ID',
`request_id` varchar(64) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '支付准备请求ID',
`biz_no` varchar(64) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '业务号',
`original_biz_no` varchar(64) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '原始业务单据号',
`biz_action_no` varchar(128) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '业务操作流水号',
`biz_product` varchar(32) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '一级业务标识',
`biz_mode` varchar(32) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '二级业务标识',
`biz_action_type` varchar(32) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '三级业务标识',
`partner_biz_no` varchar(128) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '外部商户流水号',
`partner_id` varchar(32) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '外部商户ID',
`payer_id` varchar(32) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '付款方ID',
`payer_id_type` varchar(32) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '付款方类型',
`sharding_id` varchar(32) COLLATE utf8mb4_bin DEFAULT NULL COMMENT 'LDC路由ID',
`amount` decimal(16,0) DEFAULT NULL COMMENT '申请金额',
`real_amount` decimal(16,0) DEFAULT NULL COMMENT '真实金额',
`currency` varchar(4) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '金额币种',
`status` varchar(6) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '准备单状态',
`trans_status` varchar(6) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '分布式事务状态',
`tx_id` varchar(128) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '分布式事务ID',
`gmt_create` datetime(6) DEFAULT NULL COMMENT '创建时间',
`gmt_modified` datetime(6) DEFAULT NULL COMMENT '修改时间',
`gmt_bizdate` datetime(6) DEFAULT NULL COMMENT '业务发生时间',
`gmt_payment` datetime(6) DEFAULT NULL COMMENT '支付申请时间',
`pay_terminal` varchar(6) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '支付终端类型',
`payment_extra` varchar(2048) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '准备单扩展字段',
`memo` varchar(128) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '准备单备注信息',
`biz_process_id` varchar(64) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '统一上下文ID',
`pay_error_code` varchar(128) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '支付错误码',
`inst_error_code` varchar(64) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '机构错误码',
`cmpt_error_code` varchar(64) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '兼容错误码',
`attached_item` varchar(2048) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '支付准备关联单据序列化信息',
`main_id` varchar(64) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '关联总单ID',
`merge_type` varchar(64) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '合并单据类型',
`related_payment_id` varchar(64) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '关联总单ID',
`out_biz_context` varchar(4096) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '外围业务上下文信息',
`env_context` varchar(2048) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '环境上下文信息',
`sec_context` varchar(6144) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '安全信息',
`biz_pd_code` varchar(21) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '业务产品码',
`biz_ev_code` varchar(8) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '业务事件码',
`pd_code` varchar(21) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '本层产品码',
`ev_code` varchar(8) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '本层事件码',
`cnl_pd_code` varchar(21) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '端产品码',
`cnl_ev_code` varchar(8) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '端事件码',
`cnl_no` varchar(64) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '端流水号',
`partition_id` varchar(2) COLLATE utf8mb4_bin GENERATED ALWAYS AS (substr(`apply_id`,18,2)) VIRTUAL,
PRIMARY KEY (`apply_id`),
KEY `idx_main_id` (`main_id`) LOCAL  BLOCK_SIZE 16384,
CONSTRAINT `cst` CHECK ((`partition_id` = substr(`main_id`,18,2)))
) COMMENT = '支付准备单数据表'
