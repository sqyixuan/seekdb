drop table if exists t11;
create table t11(c1 int , c2 timestamp(6) default '2012-10-11 10:12:22.001', c3 timestamp(5) default '2012-10-11 10:12:22', c4 datetime(6) default '2012-10-11 10:12:22.003', c5 datetime default '2012-10-11 10:12:22');
show create table t11;
Table	Create Table
t11	CREATE TABLE `t11` (
  `c1` int(11) DEFAULT NULL,
  `c2` timestamp(6) NOT NULL DEFAULT '2012-10-11 10:12:22.001000',
  `c3` timestamp(5) NOT NULL DEFAULT '2012-10-11 10:12:22.00000',
  `c4` datetime(6) DEFAULT '2012-10-11 10:12:22.003000',
