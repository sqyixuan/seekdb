create table table_numeric (
c1 tinyint primary key,
c2 smallint,
c3 mediumint,
c4 int,
c5 bigint,
c6 float,
c7 double,
c8 tinyint unsigned,
c9 smallint unsigned,
c10 mediumint unsigned,
c11 int unsigned,
c12 bigint unsigned,
c13 float unsigned default '3.14',
c14 double unsigned default 2.111345,
c15 float(10,5) default 66.66,
c16 double(10,5) default 66,
c17 float(10,5) unsigned default 66.66,
c18 double(10,5) unsigned default 66
);
create table table_string (
c1 char primary key,
c2 varchar(10) default 'abcdef',
c3 binary,
c4 varbinary(10),
c5 char(10),
c6 binary(10)
);
create table table_datetime (
c1 datetime primary key default '0000-00-00 00:00:00',
c2 timestamp,
c3 date,
c4 year,
c5 time,
c6 timestamp default '2013-06-20'
);
create table table_number(
c1 decimal primary key,
c2 decimal unsigned,
c3 decimal(10,5),
c4 decimal(10,5) unsigned,
c5 decimal(10,5) not null default 22.12,
c6 decimal(10,5) not null default 22.123456
);
create table table_timestamp(
c1 timestamp(6) not null default '2012-10-12'
);
create view view_string  as select * from table_string;
create view view_number  as select * from table_number;
