### test for bit column ####
drop table if exists bit_table;
create table bit_table(c1 bit(32), c2 bit(64) default b'0', c3 bit(16) default b'11111111');
desc bit_table;
Field	Type	Null	Key	Default	Extra
c1	bit(32)	YES		NULL	
c2	bit(64)	YES		b'0'	
c3	bit(16)	YES		b'11111111'	
show create table bit_table;
Table	Create Table
bit_table	CREATE TABLE `bit_table` (
  `c1` bit(32) DEFAULT NULL,
  `c2` bit(64) DEFAULT b'0',
  `c3` bit(16) DEFAULT b'11111111'
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 COMPRESSION = 'lz4_1.0' REPLICA_NUM = NUM BLOCK_SIZE = SIZE USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = SIZE PCTFREE = 10
