  `skip_index_attr` bigint(20) NOT NULL DEFAULT '0',
  `lob_chunk_size` bigint(20) NOT NULL DEFAULT '262144',
  `local_session_vars` longtext DEFAULT NULL,
  PRIMARY KEY (`tenant_id`, `table_id`, `column_id`),
  KEY `idx_tb_column_name` (`table_id`, `column_name`) BLOCK_SIZE 16384 LOCAL,
  KEY `idx_column_name` (`column_name`) BLOCK_SIZE 16384 LOCAL
