drop table test;
create table test (t datetime not null, a int, primary key (t)) partition by key(t) partitions 38;
replace into test values ('2016-1-1 1:1:1.011212', 1);
replace into test values ('2016-1-1 1:1:1.012111', 1);
select * from test;
t	a
2016-01-01 01:01:01	1
drop table test;
create table test (u binary(12), t binary(123), primary key (t)) partition by key(t) partitions 38;
replace into test values ('hello', concat(u, "world"));
replace into test values ('hello ', concat(u, "world"));
select hex(u), hex(t) from test order by u;
hex(u)	hex(t)
