avg(c1)	avg(c2)	avg(c3)
2.3333	3.6667	2.375
CREATE TABLE `LINEITEM` (
`L_ORDERKEY` bigint(20) NOT NULL,
`L_PARTKEY` bigint(20) NOT NULL,
`L_SUPPKEY` bigint(20) NOT NULL,
`L_LINENUMBER` bigint(20) NOT NULL,
`L_QUANTITY` decimal(15,2) NOT NULL,
`L_EXTENDEDPRICE` decimal(15,2) NOT NULL,
`L_DISCOUNT` decimal(15,2) NOT NULL,
`L_TAX` decimal(15,2) NOT NULL,
`L_RETURNFLAG` char(1) NOT NULL,
`L_LINESTATUS` char(1) NOT NULL,
`L_SHIPDATE` date NOT NULL,
`L_COMMITDATE` date NOT NULL,
`L_RECEIPTDATE` date NOT NULL,
`L_SHIPINSTRUCT` char(25) NOT NULL,
`L_SHIPMODE` char(10) NOT NULL,
`L_COMMENT` varchar(44) NOT NULL,
PRIMARY KEY (`L_ORDERKEY`, `L_LINENUMBER`),
KEY `index_1` (`L_ORDERKEY`) BLOCK_SIZE 16384,
KEY `index_2` (`L_PARTKEY`, `L_SUPPKEY`) BLOCK_SIZE 16384
);
explain select
l_returnflag,
l_linestatus,
sum(l_quantity) as sum_qty,
sum(l_extendedprice) as sum_base_price,
sum(l_extendedprice * (1 - l_discount)) as sum_disc_price,
sum(l_extendedprice * (1 - l_discount) * (1 + l_tax)) as sum_charge,
avg(l_quantity) as avg_qty,
avg(l_extendedprice) as avg_price,
avg(l_discount) as avg_disc,
count(*) as count_order
from
lineitem
where
l_shipdate <= date '1998-12-01' - interval '90' day
group by
l_returnflag,
l_linestatus
order by
l_returnflag,
l_linestatus;
Query Plan
=======================================================
|ID|OPERATOR           |NAME    |EST.ROWS|EST.TIME(us)|
-------------------------------------------------------
|0 |MERGE GROUP BY     |        |1       |3           |
|1 |└─SORT             |        |1       |3           |
|2 |  └─TABLE FULL SCAN|lineitem|1       |3           |
=======================================================
Outputs & filters:
-------------------------------------
  0 - output([lineitem.L_RETURNFLAG], [lineitem.L_LINESTATUS], [T_FUN_SUM(lineitem.L_QUANTITY)], [T_FUN_SUM(lineitem.L_EXTENDEDPRICE)], [T_FUN_SUM(lineitem.L_EXTENDEDPRICE 
      * cast(1, DECIMAL_INT(16, 2)) - lineitem.L_DISCOUNT)], [T_FUN_SUM(lineitem.L_EXTENDEDPRICE * cast(1, DECIMAL_INT(16, 2)) - lineitem.L_DISCOUNT * cast(1,
       DECIMAL_INT(16, 2)) + lineitem.L_TAX)], [cast(cast(T_FUN_SUM(lineitem.L_QUANTITY), DECIMAL_INT(69, 34)) / cast(T_FUN_COUNT(lineitem.L_QUANTITY), DECIMAL_INT(20,
       0)), DECIMAL(19, 6))], [cast(cast(T_FUN_SUM(lineitem.L_EXTENDEDPRICE), DECIMAL_INT(69, 34)) / cast(T_FUN_COUNT(lineitem.L_EXTENDEDPRICE), DECIMAL_INT(20,
       0)), DECIMAL(19, 6))], [cast(cast(T_FUN_SUM(lineitem.L_DISCOUNT), DECIMAL_INT(69, 34)) / cast(T_FUN_COUNT(lineitem.L_DISCOUNT), DECIMAL_INT(20, 0)), DECIMAL(19,
       6))], [T_FUN_COUNT(*)]), filter(nil), rowset=16
      group([lineitem.L_RETURNFLAG], [lineitem.L_LINESTATUS]), agg_func([T_FUN_SUM(lineitem.L_QUANTITY)], [T_FUN_SUM(lineitem.L_EXTENDEDPRICE)], [T_FUN_SUM(lineitem.L_EXTENDEDPRICE 
      * cast(1, DECIMAL_INT(16, 2)) - lineitem.L_DISCOUNT)], [T_FUN_SUM(lineitem.L_EXTENDEDPRICE * cast(1, DECIMAL_INT(16, 2)) - lineitem.L_DISCOUNT * cast(1,
       DECIMAL_INT(16, 2)) + lineitem.L_TAX)], [T_FUN_COUNT(*)], [T_FUN_COUNT(lineitem.L_QUANTITY)], [T_FUN_COUNT(lineitem.L_EXTENDEDPRICE)], [T_FUN_SUM(lineitem.L_DISCOUNT)],
       [T_FUN_COUNT(lineitem.L_DISCOUNT)])
  1 - output([lineitem.L_RETURNFLAG], [lineitem.L_LINESTATUS], [lineitem.L_EXTENDEDPRICE], [lineitem.L_DISCOUNT], [lineitem.L_QUANTITY], [lineitem.L_TAX]), filter(nil), rowset=16
      sort_keys([lineitem.L_RETURNFLAG, ASC], [lineitem.L_LINESTATUS, ASC])
  2 - output([lineitem.L_RETURNFLAG], [lineitem.L_LINESTATUS], [lineitem.L_QUANTITY], [lineitem.L_EXTENDEDPRICE], [lineitem.L_DISCOUNT], [lineitem.L_TAX]), filter([lineitem.L_SHIPDATE 
      <= date_sub('1998-12-01', '90', 4)]), rowset=16
      access([lineitem.L_SHIPDATE], [lineitem.L_RETURNFLAG], [lineitem.L_LINESTATUS], [lineitem.L_QUANTITY], [lineitem.L_EXTENDEDPRICE], [lineitem.L_DISCOUNT],
       [lineitem.L_TAX]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([lineitem.L_ORDERKEY], [lineitem.L_LINENUMBER]), range(MIN,MIN ; MAX,MAX)always true
drop table t1,t2,t3,t_empty,t_distinct, LINEITEM;
