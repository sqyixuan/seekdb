drop table if exists t1,t2,t3, t_empty, t_distinct, LINEITEM;
create table t1 (c1 int, c2 bigint, c3 float);
insert into t1 values(1, 2, 3.5), (-3, 2, 4.5), (7, 5, 2.0), (9, 4, -0.5);
select avg(c1) from t1;
avg(c1)
3.5000
explain select avg(c1) from t1;
