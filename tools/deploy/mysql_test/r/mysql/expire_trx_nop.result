drop table if exists t1;
create table t1(c1 int, c2 int, c3 int, primary key(c1)) expire_info=c1<100 );
alter table t1 set  enable_transaction_expire=true;
create index i1 on t1(c2);
alter system major freeze tenant = sys;
alter system major freeze tenant = all_user;
alter system major freeze tenant = all_meta;
replace into t1 values(1,11,111);
alter system set merge_delay_interval='10s' server_type=chunkserver;
alter system set merge_delay_for_lsync='10s' server_type=chunkserver;
alter system major freeze tenant = sys;
alter system major freeze tenant = all_user;
alter system major freeze tenant = all_meta;
update t1 set c3=222 where c1=1;
select * from t1;
c1	c2	c3
c1	c2
