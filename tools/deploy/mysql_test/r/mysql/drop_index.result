drop table test;
purge recyclebin;
create table t1(c1 varchar(10));
create index idx on t1(c1(3));
insert into t1 values('hello');
drop index idx on t1;
insert into t1 values('nice');
insert into t1 values('world');
drop table t1;
purge recyclebin;
create table t1(c1 varchar(10));
create index idx on t1(c1);
insert into t1 values('hello');
drop index idx on t1;
insert into t1 values('nice');
insert into t1 values('world');
drop table t1;
purge recyclebin;
create table t1(c1 int, index idx(c1));
drop index idx on t1;
drop table t1;
purge recyclebin;
set @@ob_enable_truncate_flashback=on;
create table t1(c1 int, index idx(c1));
drop index idx on t1;
create index idx on t1(c1);
truncate table t1;
drop table t1;
select count(*) FROM oceanbase.DBA_RECYCLEBIN;
count(*)
2
purge recyclebin;
set @@session.ob_enable_truncate_flashback=off;
create table t1(c1 int, index idx(c1));
drop index idx on t1;
create index idx on t1(c1);
truncate table t1;
drop table t1;
select count(*) FROM oceanbase.DBA_RECYCLEBIN;
count(*)
2
purge recyclebin;
drop database drop_index_test;
set @@recyclebin = off;
