select host_ip(),rpc_port(),mysql_port();
select length(host_ip())>7, rpc_port()>1024, mysql_port()>1024, int2ip(ip2int(host_ip())) = host_ip();
length(host_ip())>7	rpc_port()>1024	mysql_port()>1024	int2ip(ip2int(host_ip())) = host_ip()
1	1	1	1
select host_ip() is not null, rpc_port() is not null, mysql_port() is not null;
host_ip() is not null	rpc_port() is not null	mysql_port() is not null
1	1	1
select count(host_ip()), count(rpc_port()), count(mysql_port());
count(host_ip())	count(rpc_port())	count(mysql_port())
1	1	1
select count(1) from oceanbase.__all_server where svr_ip=host_ip() and svr_port=rpc_port() and inner_port=mysql_port();
