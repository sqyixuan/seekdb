+-----+------+-----------+--------+--------+----------------------------+---------+------+
select * from tbl1 where abs(i1-i4)<0;
+----+------+------+------+------+------+------+------+
| pk | i1   | v2   | i3   | i4   | d4   | i5   | i6   |
+----+------+------+------+------+------+------+------+
+----+------+------+------+------+------+------+------+
select abs(i1) as abc from tbl1 where abs(i1)<100;
+------+
| abc  |
+------+
|    1 |
|   10 |
|   42 |
|   50 |
|   53 |
|   78 |
|   80 |
+------+
select  abs(i1*3-i4) as abc ,i1*3-i4  from tbl1 where abs(i1*3-i4)<100;
+-------------------+--------------------+
| abc               | i1*3-i4            |
+-------------------+--------------------+
|              1.75 |               1.75 |
|             30.25 |              30.25 |
|             49.75 |              49.75 |
| 40.13999938964844 | -40.13999938964844 |
+-------------------+--------------------+
select  abs(i1*3-i4) as abc ,i1*3-i4  from tbl1 where abs(i1*3-i4)<100 order by abs(i1*3-i4);
+-------------------+--------------------+
| abc               | i1*3-i4            |
+-------------------+--------------------+
|              1.75 |               1.75 |
|             30.25 |              30.25 |
| 40.13999938964844 | -40.13999938964844 |
|             49.75 |              49.75 |
+-------------------+--------------------+
select distinct abs(i1*3-i4) as abc ,i1*3-i4  from tbl1 where  abs(i1*3-i4)<100 order by  abs(i1*3-i4);
+-------------------+--------------------+
| abc               | i1*3-i4            |
+-------------------+--------------------+
|              1.75 |               1.75 |
|             30.25 |              30.25 |
| 40.13999938964844 | -40.13999938964844 |
|             49.75 |              49.75 |
+-------------------+--------------------+
update tbl1 set i1=abs(i1);
update tbl1 set i1=abs(i1)-100;
select abs(i1)-i1 from tbl1;
