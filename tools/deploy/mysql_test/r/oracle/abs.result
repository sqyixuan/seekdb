result_format: 4
#### owner: yuchen.wyc
#### owner group: sql3
#### description: 用于计算绝对值
#####增加abs的case；
####abs 表达式
select abs(1+2+3-4-1-2+5-5);
+----------------------+
| abs(1+2+3-4-1-2+5-5) |
+----------------------+
|                    1 |
+----------------------+
select abs(abs(1+2+3-4-1-2+5-5)-abs(-3));
+-----------------------------------+
| abs(abs(1+2+3-4-1-2+5-5)-abs(-3)) |
+-----------------------------------+
|                                 2 |
+-----------------------------------+
select abs(true and false);
+---------------------+
| abs(true and false) |
+---------------------+
|                   0 |
+---------------------+
select abs(true and true);
+--------------------+
| abs(true and true) |
+--------------------+
|                  1 |
+--------------------+
select abs(false or true);
+--------------------+
| abs(false or true) |
+--------------------+
|                  1 |
+--------------------+
##包含字符相关的函数
select abs(length('aggfagdf')-length('35q45q45tdgtsrfg'));
+----------------------------------------------------+
| abs(length('aggfagdf')-length('35q45q45tdgtsrfg')) |
+----------------------------------------------------+
|                                                  8 |
+----------------------------------------------------+
select abs(length(substr('35q45q45tdgtsrfg',1,5)));
+---------------------------------------------+
| abs(length(substr('35q45q45tdgtsrfg',1,5))) |
+---------------------------------------------+
|                                           5 |
+---------------------------------------------+
select abs(0-length(substr('35q45q45tdgtsrfg',1,5)));
+-----------------------------------------------+
| abs(0-length(substr('35q45q45tdgtsrfg',1,5))) |
+-----------------------------------------------+
|                                             5 |
+-----------------------------------------------+
##包含时间相关的函数
select abs(time_to_usec(now())-time_to_usec(DATE_ADD(current_timestamp(), INTERVAL 5 DAY)));
+--------------------------------------------------------------------------------------+
| abs(time_to_usec(now())-time_to_usec(DATE_ADD(current_timestamp(), INTERVAL 5 DAY))) |
+--------------------------------------------------------------------------------------+
|                                                                         432000000000 |
+--------------------------------------------------------------------------------------+
select abs(time_to_usec(now())-time_to_usec(DATE_ADD(current_timestamp(), INTERVAL -5 DAY)));
+---------------------------------------------------------------------------------------+
| abs(time_to_usec(now())-time_to_usec(DATE_ADD(current_timestamp(), INTERVAL -5 DAY))) |
+---------------------------------------------------------------------------------------+
|                                                                          432000000000 |
+---------------------------------------------------------------------------------------+
##对十六进行进行abs
select abs(hex('0x3'));
+-----------------+
| abs(hex('0x3')) |
+-----------------+
|          307833 |
+-----------------+
select abs(hex('0X3'));
+-----------------+
| abs(hex('0X3')) |
+-----------------+
|          305833 |
+-----------------+
##运算
select abs(-2) * -2;
+--------------+
| abs(-2) * -2 |
+--------------+
|           -4 |
+--------------+
###加别名
SELECT ABS(1.0) AS "1.0的绝对值",ABS(0.0) AS "0.0的绝对值",ABS(-1.0) AS "-1.0的绝对值";
+-----------------+-----------------+------------------+
| 1.0的绝对值 | 0.0的绝对值 | -1.0的绝对值 |
+-----------------+-----------------+------------------+
|             1.0 |             0.0 |              1.0 |
+-----------------+-----------------+------------------+
###from dual
SELECT ABS(-17.36)   from dual;
+-------------+
| ABS(-17.36) |
+-------------+
|       17.36 |
+-------------+
SELECT ABS(null)   from dual;
+-----------+
| ABS(null) |
+-----------+
|      NULL |
+-----------+

####abs 隐式类型转换
select abs('1');
+----------+
| abs('1') |
+----------+
|        1 |
+----------+
select abs('100');
+------------+
| abs('100') |
+------------+
|        100 |
+------------+
select abs('-100');
+-------------+
| abs('-100') |
+-------------+
|         100 |
+-------------+
select abs('-100.001');
+-----------------+
| abs('-100.001') |
+-----------------+
|         100.001 |
+-----------------+
select abs(cast(-1.21 as decimal(10,5)));
+-----------------------------------+
| abs(cast(-1.21 as decimal(10,5))) |
+-----------------------------------+
|                           1.21000 |
+-----------------------------------+
select abs(cast(-1.21 as char(10)));
+------------------------------+
| abs(cast(-1.21 as char(10))) |
+------------------------------+
|                         1.21 |
+------------------------------+
select abs(cast(-1.21 as decimal(5,3)));
+----------------------------------+
| abs(cast(-1.21 as decimal(5,3))) |
+----------------------------------+
|                            1.210 |
+----------------------------------+
select abs(cast(-1.21 as numeric));
+-----------------------------+
| abs(cast(-1.21 as numeric)) |
+-----------------------------+
|                           1 |
+-----------------------------+
select abs(true);
+-----------+
| abs(true) |
+-----------+
|         1 |
+-----------+
select abs(true);
+-----------+
| abs(true) |
+-----------+
|         1 |
+-----------+
select abs(false);
+------------+
| abs(false) |
+------------+
|          0 |
+------------+
select abs(ROW(1,2)<ROW(1, 3));
+-------------------------+
| abs(ROW(1,2)<ROW(1, 3)) |
+-------------------------+
|                       1 |
+-------------------------+

####abs 不合法类型
select abs('-abcd');
+--------------+
| abs('-abcd') |
+--------------+
|            0 |
+--------------+
Warnings:
Warning	1292	Truncated incorrect DOUBLE value: '-abcd'
select abs('2014-10-09 10:00:00');
+----------------------------+
| abs('2014-10-09 10:00:00') |
+----------------------------+
|                       2014 |
+----------------------------+
Warnings:
Warning	1292	Truncated incorrect DOUBLE value: '2014-10-09 10:00:00'
select abs(10e1);
+-----------+
| abs(10e1) |
+-----------+
|       100 |
+-----------+
####abs,不合法的参数个数
select abs(1,-2);
ERROR 42000: Incorrect parameter count in the call to native function 'abs'
select abs(ROW(1,2));
ERROR 21000: Operand should contain 1 column(s)

####test边界值
select abs(10/0);
+-----------+
| abs(10/0) |
+-----------+
|      NULL |
+-----------+
SELECT ABS(-9223372036854775808);
+---------------------------+
| ABS(-9223372036854775808) |
+---------------------------+
|       9223372036854775808 |
+---------------------------+
select abs(-9999999999999999999999);
+------------------------------+
| abs(-9999999999999999999999) |
+------------------------------+
|       9999999999999999999999 |
+------------------------------+
select abs(9999999999999999999999);
+-----------------------------+
| abs(9999999999999999999999) |
+-----------------------------+
|      9999999999999999999999 |
+-----------------------------+
select abs(repeat('1',100));
+----------------------+
| abs(repeat('1',100)) |
+----------------------+
| 1.111111111111111e99 |
+----------------------+
select abs(repeat('1',46));
+-----------------------+
| abs(repeat('1',46))   |
+-----------------------+
| 1.1111111111111112e45 |
+-----------------------+
select abs(0-repeat('1',46));
+-----------------------+
| abs(0-repeat('1',46)) |
+-----------------------+
| 1.1111111111111112e45 |
+-----------------------+
####test:测试对表的操作
set ob_enable_index_direct_select=1;
alter system set merger_check_interval = '10s' tenant sys;
alter system set merger_check_interval = '10s' tenant all_user;
alter system set merger_check_interval = '10s' tenant all_meta;
drop table if exists tbl1;
create table tbl1 (pk int,i1 int, v2 varchar(80), i3 char(20),i4 float, d4 datetime(6),i5 decimal(5,3),i6 bool, primary key(pk));
insert into tbl1 values(1,1,'abc12','1agc',1.25,'2014-01-01 12:00:00',23.23,1),
                       (2,10,'23abc12','4agc1',-0.25,'2015-11-01 12:00:00',-23.230,0),
                       (-3,201,'xx23abc12','cagc1',-2.25,'2015-11-21 11:20:10',3.231,1),
                       (4,80,'zx23abc12','zcagc1',2.25,'2013-01-21 11:20:10',-3.231,1),
                       (-5,53,'cx23abc12','rcagc1',109.25,'2016-01-22 11:20:10',-13.131,0),
                       (6,78,'tx23abc12','icagc1',-109.25,'2014-09-16 16:24:00',-13.531,1),
                       (7,-400,'yx23abc12','ocagc1',85.85,'2014-09-17 16:20:21',-93.131,0),
                       (-8,50,'vx23abc12','wcagc1',-85.85,'2014-09-10 16:20:21',93.131,1),
                       (9,-610000,'ukx23abc12','pecagc1',-1.85,'2014-09-19 16:20:21',99.131,0),
                       (-10,-42,'kx23abc12','ecagc1',-85.86,'2014-09-18 16:20:21',-99.131,1),
                       (11,null,null,null,null,null,null,null);
create unique index idx_1 on tbl1(i1);
alter system major freeze tenant = sys;
alter system major freeze tenant = all_user;
alter system major freeze tenant = all_meta;
##
alter system major freeze tenant = sys;
alter system major freeze tenant = all_user;
alter system major freeze tenant = all_meta;
select abs(pk),abs(i1),abs(i4),abs(i5) from tbl1;
