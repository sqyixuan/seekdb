set sql_mode='';
drop table if exists dt;
create table dt(id int primary key auto_increment, str_val varchar(100), dt_val datetime(3), ts_val timestamp(3) default '2012-12-12 00:00:00', d_val date, t_val time(3));
show create table dt;
Table	Create Table
dt	CREATE TABLE `dt` (
  `id` int(11) NOT NULL AUTO_INCREMENT,
  `str_val` varchar(100) DEFAULT NULL,
  `dt_val` datetime(3) DEFAULT NULL,
  `ts_val` timestamp(3) NOT NULL DEFAULT '2012-12-12 00:00:00.000',
  `d_val` date DEFAULT NULL,
  `t_val` time(3) DEFAULT NULL,
  PRIMARY KEY (`id`)
) AUTO_INCREMENT = 1 AUTO_INCREMENT_MODE = 'ORDER' DEFAULT CHARSET = utf8mb4 COMPRESSION = 'lz4_1.0' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 10
