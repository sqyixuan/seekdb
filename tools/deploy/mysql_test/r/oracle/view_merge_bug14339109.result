DROP DATABASE IF EXISTS opt;
create database opt;
use opt;
create table EMP (
EMPno  integer,
SAL integer,
DEPTNO integer
) ;
create table DEPT(
DEPTNO integer,
DNAME char(45)
) ;
insert into EMP values (0, 0 , 0);
insert into EMP values (1, 5000 , 0);
insert into EMP values (2, 0 , 1);
insert into EMP values (3, 4400 , 2);
insert into EMP values (4, 4500 , 3);
insert into DEPT values (0, 'A');
insert into DEPT values (1, 'B');
insert into DEPT values (2, 'C');
insert into DEPT values (3, 'D');
insert into DEPT values (4, 'E');
insert into DEPT values (5, 'F');
result_format: 4
explain_protocol: 2
EXPLAIN select
V.dname, V.subq_col
from
  ( select
   ( select max(e.sal)
   from ( select * from emp ) e
    where e.deptno = d.deptno) subq_col,
   d.dname dname
   from ( select * from dept ) d
  ) V
where V.subq_col < 5000
and V.subq_col > 0
order by 1, 2;
Query Plan
===========================================
|ID|OPERATOR          |NAME|EST. ROWS|COST|
-------------------------------------------
|0 |SORT              |    |3        |273 |
|1 | SUBPLAN SCAN     |V   |3        |266 |
|2 |  SUBPLAN FILTER  |    |6        |264 |
|3 |   TABLE SCAN     |dept|6        |38  |
|4 |   SCALAR GROUP BY|    |1        |38  |
|5 |    TABLE SCAN    |emp |1        |38  |
===========================================

Outputs & filters: 
-------------------------------------
  0 - output([V.dname], [V.subq_col]), filter(nil), sort_keys([V.dname, ASC], [V.subq_col, ASC])
  1 - output([V.subq_col], [V.dname]), filter([V.subq_col < 5000], [V.subq_col > 0]), 
      access([V.subq_col], [V.dname])
  2 - output([subquery(1)], [dept.DNAME]), filter(nil), 
      exec_params_([dept.DEPTNO]), onetime_exprs_(nil), init_plan_idxs_(nil)
  3 - output([dept.DEPTNO], [dept.DNAME]), filter(nil), 
      access([dept.DEPTNO], [dept.DNAME]), partitions(p0)
  4 - output([T_FUN_MAX(emp.SAL)]), filter(nil), 
      group(nil), agg_func([T_FUN_MAX(emp.SAL)])
  5 - output([emp.SAL]), filter([emp.DEPTNO = ?]), 
      access([emp.SAL], [emp.DEPTNO]), partitions(p0)

