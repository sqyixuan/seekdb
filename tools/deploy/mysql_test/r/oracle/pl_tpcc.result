CREATE PROCEDURE oceanbase_rowid_from_clast(
    in_c_w_id IN int,
    in_c_d_id IN int,
    in_c_last IN varchar,
    out_c_id OUT int
    )
    IS
        TYPE int32_array IS TABLE OF int;
        rowArr int32_array;
        rowIdx int;
        rowCnt int;
    BEGIN
        #-- Clause 2.5.2.2 Case 2, customer selected based on c_last.
        SELECT c_id
            FROM bmsql_customer
            WHERE c_w_id = in_c_w_id AND c_d_id = in_c_d_id AND c_last = in_c_last
            ORDER BY c_first
            BULK COLLECT INTO rowArr;

        rowCnt := rowArr.COUNT;
        rowIdx := (rowCnt + 1 )/ 2;
        out_c_id := rowArr(rowIdx);
    END//


CREATE PROCEDURE oceanbase_proc_stock_level(
    in_w_id IN int,
    in_d_id IN int,
    in_threshold IN int
    )
    IS 
        out_low_stock int;
        next_o_id int;
    BEGIN        
        #-- Selects and counts the number of recently sold items that have
        #-- a stock level below the specified threshold.
        SELECT d_next_o_id FROM bmsql_district WHERE d_w_id = in_w_id AND d_id = in_d_id INTO next_o_id;
        SELECT  COUNT(DISTINCT (s_i_id)) AS low_stock 
            FROM bmsql_order_line, bmsql_stock 
            WHERE ol_w_id = in_w_id AND ol_d_id = in_d_id AND ol_o_id < next_o_id AND ol_o_id >= next_o_id - 20 AND s_w_id = in_w_id AND s_i_id = ol_i_id AND s_quantity < in_threshold
            INTO out_low_stock;
    END//

CREATE PROCEDURE oceanbase_proc_new_order(
    in_w_id IN int,
    in_d_id IN int,
    in_c_id IN int,
    in_ware_cnt IN int,
    in_ol_cnt IN int,
    in_rand_ci_id IN int
    )
    IS 
        TYPE int_array IS TABLE OF int;
        TYPE bigint_array IS TABLE OF bigint;
        TYPE num_array IS TABLE OF DECIMAL(6,2);
        TYPE price_array IS TABLE OF DECIMAL(5,2);
        TYPE varchar24_array IS TABLE OF varchar(24);
        TYPE char_array IS TABLE OF char(1);
        TYPE rec1 IS RECORD(name varchar(24),
                            price DECIMAL(5,2),
                            data varchar(50));
        TYPE rec2 IS RECORD(quantity DECIMAL(4,0),
                            s_data varchar(50),
                            s_dist1 char(24),
                            s_dist2 char(24),
                            s_dist3 char(24),
                            s_dist4 char(24),
                            s_dist5 char(24),
                            s_dist6 char(24),
                            s_dist7 char(24),
                            s_dist8 char(24),
                            s_dist9 char(24),
                            s_dist10 char(24)
                            );
        in_ol_supply_w_id int_array;
        in_ol_i_id int_array;
        in_ol_quantity int_array;
        out_ol_amount num_array;
       	out_i_name varchar24_array;
        out_i_price price_array;
        out_s_quantity int_array;
        out_brand_generic char_array;
        out_w_tax DECIMAL(4,4);
        out_d_tax DECIMAL(4,4);
        out_o_id int;
        out_o_entry_d timestamp;
        out_ol_cnt bigint;
        out_total_amount int;
       	out_c_last varchar(64);
        out_c_credit varchar(64);
        out_c_discount DECIMAL(4,4);

        var_all_local bigint default 1;
        var_x bigint;
        var_y bigint;
        var_tmp bigint;
        var_seq bigint_array;
        var_seq_x bigint;
        var_seq_y bigint;
        var_item_row rec1;
        var_stock_row rec2;
        insert_string varchar(1024);
        s_dist varchar(24);
        not_found EXCEPTION;
        PRAGMA EXCEPTION_INIT(not_found, -4026);

        #-- construct in_ol_supply_w_id  in_ol_i_id in_ol_quantity
        var_rand bigint;
    BEGIN
        var_x := 1;
        in_ol_i_id.EXTEND(in_ol_cnt);
        in_ol_supply_w_id.EXTEND(in_ol_cnt);
        in_ol_quantity.EXTEND(in_ol_cnt);
        WHILE var_x <= in_ol_cnt LOOP
        BEGIN
            in_ol_i_id(var_x) := mod((round(rand() * 8192) | round(rand() * 100000) + in_rand_ci_id), 100000) + 1;
            in_ol_quantity(var_x) := (round(rand() *  100) + 1) / 10;
            var_rand := round(rand() *  in_ware_cnt) + 1;
            IF var_rand > 99 THEN
                in_ol_supply_w_id(var_x) := in_w_id;
            ELSE
                in_ol_supply_w_id(var_x) := in_w_id;
            END IF;
            var_x := var_x + 1;
        END;
        END LOOP;
        var_rand := round(rand() *  100) + 1;
        IF var_rand > 99 THEN
        	var_x := var_rand;
        END IF;

        #-- The o_entry_d is now.
        out_o_entry_d := CURRENT_TIMESTAMP;
        out_total_amount := 0.00;

        #-- When processing the order lines we must select the STOCK rows
        #-- FOR UPDATE. This is because we must perform business logic
        #-- (the juggling with the S_QUANTITY) here in the application
        #-- and cannot do that in an atomic UPDATE statement while getting
        #-- the original value back at the same time (UPDATE ... RETURNING
        #-- may not vendor neutral). This can lead to possible deadlocks
        #-- if two transactions try to lock the same two stock rows in
        #-- opposite order. To avoid that we process the order lines in
        #-- the order of the order of ol_supply_w_id, ol_i_id.
        out_ol_cnt := 0;

        var_x := 1;
        var_seq.EXTEND(in_ol_i_id.COUNT);
        WHILE var_x <= in_ol_i_id.COUNT LOOP
        BEGIN
            IF in_ol_i_id(var_x) IS NOT NULL AND in_ol_i_id(var_x) <> 0 THEN
                out_ol_cnt := out_ol_cnt + 1;
                var_seq(var_x) := var_x;
                IF in_ol_supply_w_id(var_x) <> in_w_id THEN
                    var_all_local := 0;
                END IF;
            END IF;
            var_x := var_x + 1;
        END;
        END LOOP;

        var_x := 1;
        WHILE var_x <= out_ol_cnt - 1 LOOP
        BEGIN
            var_y := var_x + 1;
            WHILE var_y <= out_ol_cnt LOOP
            BEGIN
                var_seq_x := var_seq(var_x);
                var_seq_y := var_seq(var_y);
                IF in_ol_supply_w_id(var_seq_y) < in_ol_supply_w_id(var_seq_x) THEN
                    var_tmp := var_seq_x;
                    var_seq(var_x) := var_seq_y;
                    var_seq(var_y) := var_tmp;
                ELSIF in_ol_supply_w_id(var_seq_y) = in_ol_supply_w_id(var_seq_x) AND in_ol_i_id(var_seq_y) < in_ol_i_id(var_seq_x) THEN
                    var_tmp := var_seq_x;
                    var_seq(var_x) := var_seq_y;
                    var_seq(var_y) := var_tmp;
                END IF;
                var_y := var_y + 1;
            END;
            END LOOP;
            var_x := var_x + 1;
        END;
        END LOOP;

        #-- Retrieve the required data from DISTRICT
        SELECT d_tax, d_next_o_id
            FROM bmsql_district
            WHERE d_w_id = in_w_id AND d_id = in_d_id
            FOR UPDATE
            INTO out_d_tax, out_o_id;

        #-- Retrieve the required data for CUSTOMER and WAREHOUSE
        SELECT w_tax, c_last, c_credit, c_discount
            FROM bmsql_customer
                JOIN bmsql_warehouse ON (w_id = c_w_id)
            WHERE c_w_id = in_w_id AND c_d_id = in_d_id AND c_id = in_c_id
            INTO out_w_tax, out_c_last, out_c_credit, out_c_discount;

        #-- Update the district bumping the D_NEXT_O_ID
        UPDATE bmsql_district
            SET d_next_o_id = d_next_o_id + 1
            WHERE d_w_id = in_w_id AND d_id = in_d_id;

        #-- Insert the ORDER row
        INSERT INTO bmsql_oorder (o_id, o_d_id, o_w_id, o_c_id,	o_entry_d, o_ol_cnt, o_all_local)
        VALUES (out_o_id, in_d_id, in_w_id, in_c_id, out_o_entry_d, out_ol_cnt, var_all_local);

        #-- Insert the NEW_ORER row
        INSERT INTO bmsql_new_order (no_o_id, no_d_id, no_w_id)
        VALUES (out_o_id, in_d_id, in_w_id);

        #-- Per ORDER_LINE
        var_x := 1;
        out_i_name.EXTEND(out_ol_cnt);
        out_i_price.EXTEND(out_ol_cnt);
        out_s_quantity.EXTEND(out_ol_cnt);
        out_ol_amount.EXTEND(out_ol_cnt);
        out_brand_generic.EXTEND(out_ol_cnt);
        WHILE var_x <= out_ol_cnt LOOP
        DECLARE
            current_supply_w_id int;
            current_i_id int;
            current_quantity int;
            quantity_to_set DECIMAL(4,0);
        BEGIN
            #-- We process the lines in the sequence ordered by warehouse, item.
            var_y := var_seq(var_x);
            current_supply_w_id := in_ol_supply_w_id(var_y);
            current_i_id := in_ol_i_id(var_y);
            current_quantity := in_ol_quantity(var_y);

            SELECT i_name, i_price, i_data
                 FROM bmsql_item
                 WHERE i_w_id = 1 AND i_id = in_ol_i_id(var_y)
                 INTO var_item_row;

            #-- Found ITEM
            out_i_name(var_y) := var_item_row.name;
            out_i_price(var_y) := var_item_row.price;

            SELECT s_quantity, s_data, s_dist_01, s_dist_02,
                   s_dist_03, s_dist_04, s_dist_05, s_dist_06,
                   s_dist_07, s_dist_08, s_dist_09, s_dist_10
                  FROM bmsql_stock
                  WHERE s_w_id = current_supply_w_id
                  AND s_i_id = current_i_id
                  FOR UPDATE
                 INTO var_stock_row;

            out_s_quantity(var_y) := var_stock_row.quantity;
            out_ol_amount(var_y) := out_i_price(var_y) * in_ol_quantity(var_y);
            IF var_item_row.data LIKE '%ORIGINAL%' AND var_stock_row.s_data LIKE '%ORIGINAL%' THEN
                out_brand_generic(var_y) := 'B';
            ELSE
                out_brand_generic(var_y) := 'G';
            END IF;
            out_total_amount := out_total_amount + out_ol_amount(var_y) * (1.0 - out_c_discount) * (1.0 + out_w_tax + out_d_tax);

            #-- Update the STOCK row.
            IF in_w_id <> current_supply_w_id THEN
                UPDATE bmsql_stock SET
                        s_quantity = quantity_to_set,
                        s_ytd = s_ytd + current_quantity,
                        s_order_cnt = s_order_cnt + 1,
                        s_remote_cnt = s_remote_cnt + 1
                WHERE s_w_id = current_supply_w_id
                          AND s_i_id = current_i_id;
            ELSE
                UPDATE bmsql_stock SET
                        s_quantity = quantity_to_set,
                        s_ytd = s_ytd + current_quantity,
                        s_order_cnt = s_order_cnt + 1,
                        s_remote_cnt = s_remote_cnt + 0
                WHERE s_w_id = current_supply_w_id
                          AND s_i_id = current_i_id;
            END IF;
            var_x := var_x + 1;
        END;
        END LOOP;

        #-- Insert the ORDER_LINE row.
        insert_string := 'INSERT INTO bmsql_order_line (ol_o_id, ol_d_id, ol_w_id, ol_number, ol_i_id, ol_supply_w_id, ol_quantity, ol_amount, ol_dist_info) VALUES ';
        
        var_x := 1;
        WHILE var_x <= out_ol_cnt LOOP
        BEGIN
            var_y := var_seq(var_x);
            insert_string := CONCAT(insert_string, '(',
                                       CAST(out_o_id AS CHAR), ',',
                                       CAST(in_d_id AS CHAR), ',',
                                       CAST(in_w_id AS CHAR), ',',
                                       CAST(var_y AS CHAR), ',',
                                       CAST(in_ol_i_id(var_y) AS CHAR), ',',
                                       CAST(in_ol_supply_w_id(var_y) AS CHAR), ',',
                                       CAST(in_ol_quantity(var_y) AS CHAR), ',',
                                       CAST(out_ol_amount(var_y) AS CHAR), ',',
                                       '\'',s_dist, '\')'
                                       );
            IF var_x < out_ol_cnt THEN
              insert_string := CONCAT(insert_string, ',');
            END IF; 
            var_x := var_x + 1;
        END;
        END LOOP;
        EXECUTE IMMEDIATE insert_string;
    END//

CREATE PROCEDURE oceanbase_proc_delivery_bg(
    in_w_id IN int,
    in_o_carrier_id IN int,
    in_ol_delivery_d IN timestamp
    )
    IS
        TYPE int_array IS TABLE OF int;
        TYPE bigint_array IS TABLE OF bigint;
        TYPE num_array IS TABLE OF DECIMAL(12,2);

        out_delivered_o_id int_array;

        sums num_array;
        var_d_id int_array;
        var_o_c_id int_array;
        d_id_si int;
        no_o_id_si int;
        var_dist bigint_array;
        var_x bigint;
        i bigint;
        order_count bigint;
        o_c_id_si int;
        sum_si DECIMAL(12,2);
        cur_time_local timestamp;
    BEGIN
        var_x := 1;
        WHILE var_x <= 10 LOOP
        BEGIN
            var_dist.EXTEND;
            var_dist(var_x) := var_x;
            var_x := var_x + 1;
        END;
        END LOOP;

        order_count := 0;
        i := 1;
        WHILE i <= 10 LOOP
        BEGIN 
            no_o_id_si := -1;
            SELECT no_d_id, no_o_id FROM bmsql_new_order
                WHERE no_d_id = var_dist(i) AND no_w_id = in_w_id ORDER BY no_o_id ASC LIMIT 1
                FOR UPDATE
                INTO d_id_si, no_o_id_si;
            IF no_o_id_si > 0 THEN
              var_d_id.EXTEND;
              out_delivered_o_id.EXTEND;
              order_count := order_count + 1;
              var_d_id(order_count) := d_id_si;
              out_delivered_o_id(order_count) := no_o_id_si;
              DELETE FROM bmsql_new_order 
                 WHERE no_d_id = d_id_si AND no_w_id = in_w_id AND no_o_id = no_o_id_si;
            END IF;
            i := i + 1;
        END;
        END LOOP;
        
        i := 1;
        WHILE i <= order_count LOOP
        BEGIN
            SELECT o_c_id FROM bmsql_oorder
                WHERE o_id = out_delivered_o_id(i) AND o_d_id = var_d_id(i) AND o_w_id = in_w_id
                FOR UPDATE
                INTO o_c_id_si;
            var_o_c_id.EXTEND;
            var_o_c_id(i) := o_c_id_si;
            UPDATE bmsql_oorder SET o_carrier_id = in_o_carrier_id
                WHERE o_id = out_delivered_o_id(i) AND o_d_id = var_d_id(i) AND o_w_id = in_w_id;
            i := i + 1;
        END;
        END LOOP;

        i := 1;
        WHILE i <= order_count LOOP
        BEGIN
            SELECT sum(ol_amount) FROM bmsql_order_line
                WHERE ol_w_id = in_w_id
                    AND ol_d_id = var_d_id(i)
                    AND ol_o_id = out_delivered_o_id(i)
              FOR UPDATE
              INTO sum_si;
            sums.EXTEND;
            sums(i) := sum_si;
            cur_time_local := CURRENT_TIMESTAMP;
            UPDATE bmsql_order_line SET ol_delivery_d = cur_time_local 
                WHERE ol_w_id = in_w_id
                    AND ol_d_id = var_d_id(i)
                    AND ol_o_id = out_delivered_o_id(i);
            i := i + 1;
        END;
        END LOOP;

        i := 1;
        WHILE i <= order_count LOOP
        BEGIN
            UPDATE bmsql_customer SET c_balance = c_balance + sums(i), c_delivery_cnt = c_delivery_cnt + 1
                WHERE c_w_id = in_w_id
                    AND c_d_id = var_d_id(i)
                    AND c_id = var_o_c_id(i);
            i := i + 1;
        END;
        END LOOP;
    END//


CREATE PROCEDURE oceanbase_proc_payment_clast(
    in_w_id IN int,
    in_d_id IN int,
    in_c_id IN OUT int,
    in_c_d_id IN int,
    in_c_w_id IN int,
    in_c_last IN OUT varchar,
    in_h_amount IN DECIMAL,
    out_w_name OUT varchar,
    out_w_street_1 OUT varchar,
    out_w_street_2 OUT varchar,
    out_w_city OUT varchar,
    out_w_state OUT varchar,
    out_w_zip OUT varchar,
    out_d_name OUT varchar,
    out_d_street_1 OUT varchar,
    out_d_street_2 OUT varchar,
    out_d_city OUT varchar,
    out_d_state OUT varchar,
    out_d_zip OUT varchar,
    out_c_first OUT varchar,
    out_c_middle OUT varchar,
    out_c_street_1 OUT varchar,
    out_c_street_2 OUT varchar,
    out_c_city OUT varchar,
    out_c_state OUT varchar,
    out_c_zip OUT varchar,
    out_c_phone OUT varchar,
    out_c_since OUT timestamp,
    out_c_credit OUT varchar,
    out_c_credit_lim OUT DECIMAL,
    out_c_discount OUT DECIMAL,
    out_c_balance OUT DECIMAL,
    out_c_data OUT varchar,
    out_h_date OUT timestamp
    )
    IS
        row_id int;
    BEGIN
        out_h_date := CURRENT_TIMESTAMP; 

        #-- Update and Select the WAREHOUSE
        UPDATE bmsql_warehouse
            SET w_ytd = w_ytd + in_h_amount
            WHERE w_id = in_w_id;
        SELECT w_name, w_street_1, w_street_2, w_city, w_state, w_zip FROM bmsql_warehouse
            WHERE w_id = in_w_id
            INTO out_w_name, out_w_street_1, out_w_street_2, out_w_city, out_w_state, out_w_zip;

        oceanbase_rowid_from_clast(in_c_w_id, in_c_d_id, in_c_last, row_id);

        #-- Update and Select the DISTRICT
        UPDATE bmsql_district
            SET d_ytd = d_ytd + in_h_amount
            WHERE d_w_id = in_w_id AND d_id = in_d_id;
        SELECT d_name, d_street_1, d_street_2, d_city, d_state, d_zip FROM bmsql_district
            WHERE d_w_id = in_w_id AND d_id = in_d_id
            INTO out_d_name, out_d_street_1, out_d_street_2, out_d_city, out_d_state, out_d_zip;

        #-- Update and Select the CUSTOMER
        UPDATE bmsql_customer
            SET c_balance = c_balance - in_h_amount,
            c_ytd_payment = c_ytd_payment + in_h_amount,
                    c_payment_cnt = c_payment_cnt + 1
            WHERE c_id = row_id AND c_w_id = in_w_id AND c_d_id = in_d_id;
        SELECT c_id, c_first, c_middle, c_last, c_street_1,
                  c_street_2, c_city, c_state, c_zip,
                  c_phone, c_since, c_credit, c_credit_lim,
              c_discount, c_balance FROM bmsql_customer
            WHERE c_id = row_id AND c_w_id = in_w_id AND c_d_id = in_d_id
            INTO in_c_id, out_c_first, out_c_middle, in_c_last,
                 out_c_street_1, out_c_street_2, out_c_city,
                 out_c_state, out_c_zip, out_c_phone, out_c_since,
                 out_c_credit, out_c_credit_lim, out_c_discount,
                 out_c_balance;

        out_c_balance := out_c_balance - in_h_amount;
        out_c_data := ' ';

        #-- Customer with bad credit, need to do the C_DATA work.
        IF out_c_credit = 'BC' THEN
        BEGIN
            UPDATE bmsql_customer
                SET c_data = SUBSTR(CONCAT('C_ID=', CAST(in_c_id AS CHAR), 
                                           ' C_D_ID=', CAST(in_c_d_id AS CHAR), 
                                           ' C_W_ID=', CAST(in_c_w_id AS CHAR), 
                                           ' D_ID=', CAST(in_d_id AS CHAR),
                                           ' W_ID=', CAST(in_w_id AS CHAR),
                                           ' H_AMOUNT=', ROUND(in_h_amount,2)), 1, 500)
                WHERE c_id = row_id AND c_w_id = in_w_id AND c_d_id = in_d_id;
            SELECT c_data FROM bmsql_customer
                WHERE c_id = row_id AND c_w_id = in_w_id AND c_d_id = in_d_id
                INTO out_c_data;
        END;
        END IF;

        #-- Insert the HISTORY row
        INSERT INTO bmsql_history (
            h_c_id, h_c_d_id, h_c_w_id, h_d_id, h_w_id, h_date, h_amount, h_data)
        VALUES (
            in_c_id, in_c_d_id, in_c_w_id, in_d_id, in_w_id,
            out_h_date, in_h_amount, CONCAT(out_w_name, '    ', out_d_name));
    END//


CREATE PROCEDURE oceanbase_proc_payment_cid(
    in_w_id IN int,
    in_d_id IN int,
    in_c_id IN OUT int,
    in_c_d_id IN int,
    in_c_w_id IN int,
    in_c_last IN OUT varchar,
    in_h_amount IN DECIMAL,
    out_w_name OUT varchar,
    out_w_street_1 OUT varchar,
    out_w_street_2 OUT varchar,
    out_w_city OUT varchar,
    out_w_state OUT varchar,
    out_w_zip OUT varchar,
    out_d_name OUT varchar,
    out_d_street_1 OUT varchar,
    out_d_street_2 OUT varchar,
    out_d_city OUT varchar,
    out_d_state OUT varchar,
    out_d_zip OUT varchar,
    out_c_first OUT varchar,
    out_c_middle OUT varchar,
    out_c_street_1 OUT varchar,
    out_c_street_2 OUT varchar,
    out_c_city OUT varchar,
    out_c_state OUT varchar,
    out_c_zip OUT varchar,
    out_c_phone OUT varchar,
    out_c_since OUT timestamp,
    out_c_credit OUT varchar,
    out_c_credit_lim OUT DECIMAL,
    out_c_discount OUT DECIMAL,
    out_c_balance OUT DECIMAL,
    out_c_data OUT varchar,
    out_h_date OUT timestamp
    )
    IS
    BEGIN
        out_h_date := CURRENT_TIMESTAMP; #-- TODO:@ryan.ly

        #-- Update and Select the WAREHOUSE
        UPDATE bmsql_warehouse
            SET w_ytd = w_ytd + in_h_amount
            WHERE w_id = in_w_id;
        SELECT w_name, w_street_1, w_street_2, w_city, w_state, w_zip FROM bmsql_warehouse
            WHERE w_id = in_w_id
            INTO out_w_name, out_w_street_1, out_w_street_2, out_w_city, out_w_state, out_w_zip;

        #-- Update and Select the DISTRICT
        UPDATE bmsql_district
            SET d_ytd = d_ytd + in_h_amount
            WHERE d_w_id = in_w_id AND d_id = in_d_id;
        SELECT d_name, d_street_1, d_street_2, d_city, d_state, d_zip FROM bmsql_district
            WHERE d_w_id = in_w_id AND d_id = in_d_id
            INTO out_d_name, out_d_street_1, out_d_street_2, out_d_city, out_d_state, out_d_zip;

        #-- Update and Select the CUSTOMER
        UPDATE bmsql_customer
            SET c_balance = c_balance - in_h_amount,
            c_ytd_payment = c_ytd_payment + in_h_amount,
                c_payment_cnt = c_payment_cnt + 1
            WHERE c_w_id = in_c_w_id AND c_d_id = in_c_d_id AND c_id = in_c_id;
        SELECT c_first, c_middle, c_last, c_street_1,
                  c_street_2, c_city, c_state, c_zip,
              c_phone, c_since, c_credit, c_credit_lim,
            c_discount, c_balance
            FROM bmsql_customer
            WHERE c_w_id = in_c_w_id AND c_d_id = in_c_d_id AND c_id = in_c_id
            INTO out_c_first, out_c_middle, in_c_last,
                 out_c_street_1, out_c_street_2, out_c_city,
                 out_c_state, out_c_zip, out_c_phone, out_c_since,
                 out_c_credit, out_c_credit_lim, out_c_discount,
                 out_c_balance;

        out_c_balance := out_c_balance - in_h_amount;
        out_c_data := ' ';

        #-- Customer with bad credit, need to do the C_DATA work.
        IF out_c_credit = 'BC' THEN
        BEGIN
            UPDATE bmsql_customer
                SET c_data = SUBSTR(CONCAT('C_ID=', CAST(in_c_id AS CHAR),
                                           ' C_D_ID=', CAST(in_c_d_id AS CHAR),
                                           ' C_W_ID=', CAST(in_c_w_id AS CHAR),
                                           ' D_ID=', CAST(in_d_id AS CHAR),
                                           ' W_ID=', CAST(in_w_id AS CHAR),
                                           ' H_AMOUNT=', ROUND(in_h_amount,2)), 1, 500)
                WHERE c_w_id = in_c_w_id AND c_d_id = in_c_d_id AND c_id = in_c_id;
            SELECT c_data FROM bmsql_customer
                WHERE c_w_id = in_c_w_id AND c_d_id = in_c_d_id AND c_id = in_c_id
                INTO out_c_data;
        END;
        END IF;

        #-- Insert the HISTORY row
        INSERT INTO bmsql_history (
            h_c_id, h_c_d_id, h_c_w_id, h_d_id, h_w_id, h_date, h_amount, h_data)
        VALUES (
            in_c_id, in_c_d_id, in_c_w_id, in_d_id, in_w_id,
            out_h_date, in_h_amount, CONCAT(out_w_name, '    ', out_d_name));
    END//


CREATE PROCEDURE oceanbase_proc_payment(
    in_w_id IN int,
    in_d_id IN int,
    in_c_id IN OUT int,
    in_c_d_id IN int,
    in_c_w_id IN int,
    in_c_last IN OUT varchar,
    in_h_amount IN DECIMAL
    )
    IS
        out_w_name varchar(64);
        out_w_street_1 varchar(64);
        out_w_street_2 varchar(64);
        out_w_city varchar(64);
        out_w_state varchar(64);
        out_w_zip varchar(64);
        out_d_name varchar(64);
        out_d_street_1 varchar(64);
        out_d_street_2 varchar(64);
        out_d_city varchar(64);
        out_d_state varchar(64);
        out_d_zip varchar(64);
        out_c_first varchar(64);
        out_c_middle varchar(64);
        out_c_street_1 varchar(64);
        out_c_street_2 varchar(64);
        out_c_city varchar(64);
        out_c_state varchar(64);
        out_c_zip varchar(64);
        out_c_phone varchar(64);
        out_c_since timestamp;
        out_c_credit varchar(64);
        out_c_credit_lim DECIMAL(6,2);
        out_c_discount DECIMAL(6,2);
        out_c_balance DECIMAL(6,2);
        out_c_data varchar(64);
        out_h_date timestamp;
    BEGIN
        IF in_c_last is NOT NULL THEN
            oceanbase_proc_payment_clast(in_w_id, in_d_id, in_c_id, in_c_d_id, in_c_w_id, in_c_last, in_h_amount,
                                out_w_name, out_w_street_1, out_w_street_2, out_w_city, out_w_state, out_w_zip,
                                out_d_name, out_d_street_1, out_d_street_2, out_d_city, out_d_state, out_d_zip,
                                    out_c_first, out_c_middle, out_c_street_1, out_c_street_2, out_c_city, out_c_state,
                                    out_c_zip, out_c_phone, out_c_since, out_c_credit, out_c_credit_lim, out_c_discount,
                                        out_c_balance, out_c_data, out_h_date);
        ELSE
            oceanbase_proc_payment_cid(in_w_id, in_d_id, in_c_id, in_c_d_id, in_c_w_id, in_c_last, in_h_amount,
                                out_w_name, out_w_street_1, out_w_street_2, out_w_city, out_w_state, out_w_zip,
                                out_d_name, out_d_street_1, out_d_street_2, out_d_city, out_d_state, out_d_zip,
                                    out_c_first, out_c_middle, out_c_street_1, out_c_street_2, out_c_city, out_c_state,
                                    out_c_zip, out_c_phone, out_c_since, out_c_credit, out_c_credit_lim, out_c_discount,
                                        out_c_balance, out_c_data, out_h_date);
        END IF;
    END//


CREATE PROCEDURE oceanbase_proc_order_status(
    in_w_id IN int,
    in_d_id IN int,
    in_c_id IN OUT int,
    in_c_last IN OUT varchar
    ) 
    IS
      TYPE int_array IS TABLE OF int;
      TYPE num_array IS TABLE OF DECIMAL(6,2);
      TYPE varchar16_array IS TABLE OF varchar(16);
      TYPE timestamp_array IS TABLE OF timestamp;
      TYPE rec3 IS RECORD(ol_i_id integer,
                          ol_supply_w_id integer,
                          ol_quantity DECIMAL(2,0),
                          ol_amount DECIMAL(6,2),
                          ol_delivery_d timestamp
                          );
      TYPE table3 IS TABLE OF rec3;

      out_c_first varchar(64);
      out_c_middle varchar(64);
      out_c_balance DECIMAL(12,2);
      out_o_id int;
      out_o_entry_d timestamp;
      out_o_carrier_id int;
      out_ol_supply_w_id int_array;
      out_ol_i_id int_array;
      out_ol_quantity int_array;
      out_ol_amount num_array;
      out_ol_delivery_d varchar16_array;

      var_ol_delivery_d timestamp_array;
      v_order_line_table table3;
      v_order_line_check bigint;
      v_ol_idx bigint default 1;
      var_cnt bigint;
      CURSOR cursor_1 is
            SELECT ol_i_id, ol_supply_w_id, ol_quantity,
                   ol_amount, ol_delivery_d
                FROM bmsql_order_line
                WHERE ol_w_id = in_w_id AND ol_d_id = in_d_id AND ol_o_id = out_o_id
                ORDER BY ol_w_id, ol_d_id, ol_o_id, ol_number;
      not_found EXCEPTION;
      PRAGMA EXCEPTION_INIT(not_found, -4026);
    BEGIN
        out_ol_supply_w_id.EXTEND(15);
        out_ol_i_id.EXTEND(15);
        out_ol_quantity.EXTEND(15);
        out_ol_amount.EXTEND(15);
        out_ol_delivery_d.EXTEND(15);
        var_ol_delivery_d.EXTEND(15);

        IF in_c_last IS NOT NULL THEN
        #-- If C_LAST is given instead of C_ID (60%), determine the C_ID and
        #-- Select the CUSTOMER using the ROWID.
        BEGIN
            oceanbase_rowid_from_clast(in_w_id, in_d_id, in_c_last, in_c_id);
            SELECT c_first, c_middle, c_balance
                FROM bmsql_customer
                WHERE c_w_id = in_w_id AND c_d_id = in_d_id AND c_id = in_c_id
                INTO out_c_first, out_c_middle, out_c_balance;
        END;
        ELSE
            #-- If C_ID is given instead of C_LAST, select the CUSTOMER.
            SELECT c_first, c_middle, c_last, c_balance
                FROM bmsql_customer
                WHERE c_w_id = in_w_id AND c_d_id = in_d_id AND c_id = in_c_id
                INTO out_c_first, out_c_middle, in_c_last, out_c_balance;
        END IF;

        #-- Select the last ORDER for this customer.
        SELECT o_id, o_entry_d, coalesce(o_carrier_id, -1)
            FROM bmsql_oorder
            WHERE o_w_id = in_w_id AND o_d_id = in_d_id AND o_c_id = in_c_id ORDER BY o_id DESC LIMIT 1
            INTO out_o_id, out_o_entry_d, out_o_carrier_id;

        v_order_line_check := 1;

        OPEN cursor_1;
        FETCH cursor_1 BULK COLLECT INTO v_order_line_table;

        WHILE v_ol_idx <= v_order_line_table.COUNT LOOP
        BEGIN
            out_ol_i_id(v_ol_idx) := v_order_line_table(v_ol_idx).ol_i_id;
            out_ol_supply_w_id(v_ol_idx) := v_order_line_table(v_ol_idx).ol_supply_w_id;
            out_ol_quantity(v_ol_idx) := v_order_line_table(v_ol_idx).ol_quantity;
            out_ol_amount(v_ol_idx) := v_order_line_table(v_ol_idx).ol_amount;
            var_ol_delivery_d(v_ol_idx) := v_order_line_table(v_ol_idx).ol_delivery_d;
            v_ol_idx := v_ol_idx + 1;
        END;
        END LOOP;

        CLOSE cursor_1;

        WHILE v_ol_idx < 16 LOOP
        BEGIN
            out_ol_i_id (v_ol_idx) := 0;
            out_ol_supply_w_id(v_ol_idx) := 0;
            out_ol_quantity(v_ol_idx) := 0;
            out_ol_amount(v_ol_idx) := 0.0;
            var_ol_delivery_d(v_ol_idx) := NULL;
            v_ol_idx := v_ol_idx + 1;
        END;
        END LOOP;

        var_cnt := 1;
        WHILE var_cnt <= 15 LOOP
        BEGIN
            out_ol_delivery_d(var_cnt) := DATE_FORMAT(var_ol_delivery_d(var_cnt), '%Y-%m-%d');
            var_cnt := var_cnt + 1;
        END;
        END LOOP;
    EXCEPTION
        WHEN not_found THEN v_order_line_check := 0; 
    END//

