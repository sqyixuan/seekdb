CREATE TABLE t1 (a varchar(10));
INSERT INTO t1 VALUES ('abc'), ('xyz');
SELECT a, CONCAT(a,' ',a) AS c FROM t1
HAVING RIGHT(c,LENGTH(c)-INSTR(REVERSE(c)," ")) = a;
a	c
abc	abc abc
xyz	xyz xyz
SELECT a, CONCAT(a,' ',a) AS c FROM t1
HAVING RIGHT(CONCAT(a,' ',a),
LENGTH(CONCAT(a,' ',a))-
INSTR(REVERSE(CONCAT(a,' ',a))," ")) = a;
a	c
abc	abc abc
xyz	xyz xyz
DROP TABLE t1;
CREATE TABLE t1 (s varchar(10));
INSERT INTO t1 VALUES ('yadda'), ('yaddy');
SELECT s FROM t1 WHERE TRIM(s) > 'ab';
s
yadda
yaddy
SELECT s FROM t1 WHERE TRIM('y' FROM s) > 'ab';
s
yadda
yaddy
SELECT s FROM t1 WHERE TRIM(LEADING 'y' FROM s) > 'ab';
s
yadda
yaddy
SELECT s FROM t1 WHERE TRIM(TRAILING 'y' FROM s) > 'ab';
s
yadda
yaddy
SELECT s FROM t1 WHERE TRIM(BOTH 'y' FROM s) > 'ab';
s
yadda
yaddy
DROP TABLE t1;
create table t1 (c varchar(40));
insert into t1 values ('y,abc'),('y,abc');
select c, substring_index(lcase(c), @q:=',', -1) as res from t1;
c	res
y,abc	abc
y,abc	abc
drop table t1;
