DROP TABLE t1;
create table t1(c1 varchar(128) CHARACTER SET utf8mb4 COLLATE utf8mb4_bin NOT NULL, c2 varchar(128) CHARACTER SET utf8mb4 COLLATE utf8mb4_general_ci NOT NULL, key c12 (c1,c2));
explain select /*+index(t1 c12)*/* from t1 where c1="a" order by c2;
