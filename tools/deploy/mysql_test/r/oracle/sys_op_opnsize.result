result_format: 3
# Test file for sys_op_opnisze, which is used to estimate length of expression(column in most cases) in bytes
# basic test
select sys_op_opnsize(3);
+-------------------+
| sys_op_opnsize(3) |
+-------------------+
|                16 |
+-------------------+
select sys_op_opnsize(-500);
+----------------------+
| sys_op_opnsize(-500) |
+----------------------+
|                   16 |
+----------------------+
select sys_op_opnsize(123456789);
+---------------------------+
| sys_op_opnsize(123456789) |
+---------------------------+
|                        16 |
+---------------------------+
select sys_op_opnsize(7.58999);
+-------------------------+
| sys_op_opnsize(7.58999) |
+-------------------------+
|                      24 |
+-------------------------+
select sys_op_opnsize(-5.34261984);
+-----------------------------+
| sys_op_opnsize(-5.34261984) |
+-----------------------------+
|                          24 |
+-----------------------------+
select sys_op_opnsize("");
+--------------------+
| sys_op_opnsize("") |
+--------------------+
|                 16 |
+--------------------+
select sys_op_opnsize("abcdefg");
+---------------------------+
| sys_op_opnsize("abcdefg") |
+---------------------------+
|                        23 |
+---------------------------+
select sys_op_opnsize("ABCDEFGHIJKLMNOPQ");
+-------------------------------------+
| sys_op_opnsize("ABCDEFGHIJKLMNOPQ") |
+-------------------------------------+
|                                  33 |
+-------------------------------------+
drop table if exists t1, t2, t3, t4, t5, t6, t7, t8, t9;
# test integer type
create table t1 (c1 tinyint, c2 smallint, c3 mediumint, c4 int, c5 bigint);
insert into t1 values (0, 1, 2, 3, 4);
insert into t1 values (10, 20, 30, 40, 50);
insert into t1 values (100, 20000, 5000000, 123456789, 12345678910123);
insert into t1 values (-100, -20000, -5000000, -123456789, -12345678910123);
select c1, sys_op_opnsize(c1) as size_c1,
       c2, sys_op_opnsize(c2) as size_c2,
       c3, sys_op_opnsize(c3) as size_c3,
       c4, sys_op_opnsize(c4) as size_c4,
       c5, sys_op_opnsize(c5) as size_c5 from t1;
+------+---------+--------+---------+----------+---------+------------+---------+-----------------+---------+
| c1   | size_c1 | c2     | size_c2 | c3       | size_c3 | c4         | size_c4 | c5              | size_c5 |
+------+---------+--------+---------+----------+---------+------------+---------+-----------------+---------+
|    0 |      16 |      1 |      16 |        2 |      16 |          3 |      16 |               4 |      16 |
|   10 |      16 |     20 |      16 |       30 |      16 |         40 |      16 |              50 |      16 |
|  100 |      16 |  20000 |      16 |  5000000 |      16 |  123456789 |      16 |  12345678910123 |      16 |
| -100 |      16 | -20000 |      16 | -5000000 |      16 | -123456789 |      16 | -12345678910123 |      16 |
+------+---------+--------+---------+----------+---------+------------+---------+-----------------+---------+
# test decimal type
create table t2 (c1 float, c2 double, c3 decimal(30, 9));
insert into t2 values (3, 3, 3);
insert into t2 values (1.11111, 1.11111, 1.11111);
insert into t2 values (9999.11111111, 99999.11111111, 99999.11111111);
insert into t2 values (9999.11111111, 9999999999.11111111, 99999999.11111111);
select c1, sys_op_opnsize(c1) as size_c1,
       c2, sys_op_opnsize(c2) as size_c2,
       c3, sys_op_opnsize(c3) as size_c3 from t2;
+---------+---------+------------------+---------+--------------------+---------+
| c1      | size_c1 | c2               | size_c2 | c3                 | size_c3 |
+---------+---------+------------------+---------+--------------------+---------+
|       3 |      16 |                3 |      16 |        3.000000000 |      20 |
| 1.11111 |      16 |          1.11111 |      16 |        1.111110000 |      24 |
| 9999.11 |      16 |   99999.11111111 |      16 |    99999.111111110 |      24 |
| 9999.11 |      16 | 9999999999.11111 |      16 | 99999999.111111110 |      24 |
+---------+---------+------------------+---------+--------------------+---------+
create table t3 (c1 decimal(5, 2), c2 decimal(7, 2),
                 c3 decimal (10, 2), c4 decimal (10, 6),
                 c5 decimal (30, 10), c6 decimal (35, 10));
insert into t3 values (1.1, 2345.6, 1234.1, 126.12345, 1278.12678, 345678910.123456780);
insert into t3 values (1.1, 2.6, 1.1, 1.12345, 1.12345678, 33333777771.125678910);
insert into t3 values (1.1, 2345.6, 1234.1, 126.1, 12345678.11223445, 1234567891123440124.112345678);
select c3, sys_op_opnsize(c3) as size_c3,
       c4, sys_op_opnsize(c4) as size_c4,
       c5, sys_op_opnsize(c5) as size_c5,
       c6, sys_op_opnsize(c6) as size_c6
       from t3;
+---------+---------+------------+---------+---------------------+---------+--------------------------------+---------+
| c3      | size_c3 | c4         | size_c4 | c5                  | size_c5 | c6                             | size_c6 |
+---------+---------+------------+---------+---------------------+---------+--------------------------------+---------+
| 1234.10 |      24 | 126.123450 |      24 |     1278.1267800000 |      24 |           345678910.1234567800 |      24 |
|    1.10 |      24 |   1.123450 |      24 |        1.1234567800 |      24 |         33333777771.1256789100 |      28 |
| 1234.10 |      24 | 126.100000 |      24 | 12345678.1122344500 |      24 | 1234567891123440124.1123456780 |      32 |
+---------+---------+------------+---------+---------------------+---------+--------------------------------+---------+
# test string type
create table t4 (c1 varchar(16), c2 char(64), c3 varchar(128), c4 varchar(256));
insert into t4 values (repeat('a', 1), repeat('b', 6), repeat('c', 1), repeat('d', 2));
insert into t4 values (repeat('a', 13), repeat('b', 63), repeat('c', 127), repeat('d', 255));
insert into t4 values (repeat('a', 10), repeat('b', 43), repeat('c', 107), repeat('d', 225));
insert into t4 values (repeat('a', 5), repeat('b', 33), repeat('c', 10), repeat('d', 25));
select sys_op_opnsize(c1) as size_c1,
       sys_op_opnsize(c2) as size_c2,
       sys_op_opnsize(c3) as size_c3,
       sys_op_opnsize(c4) as size_c4
       from t4;
+---------+---------+---------+---------+
| size_c1 | size_c2 | size_c3 | size_c4 |
+---------+---------+---------+---------+
|      17 |      22 |      17 |      18 |
|      29 |      79 |     143 |     271 |
|      26 |      59 |     123 |     241 |
|      21 |      49 |      26 |      41 |
+---------+---------+---------+---------+
create table t5 (c1 varchar(65536), c2 int);
insert into t5 values (repeat('a', 1), 1);
insert into t5 values (repeat('a', 65000), 1);
insert into t5 values (repeat('a', 32000), 1);
insert into t5 values (repeat('a', 10000), 1);
insert into t5 values (repeat('a', 5000), 1);
insert into t5 values (repeat('a', 3200), 1);
insert into t5 values (repeat('b', 1), 2);
insert into t5 values (repeat('b', 6500), 2);
insert into t5 values (repeat('b', 3200), 2);
insert into t5 values (repeat('b', 100), 2);
insert into t5 values (repeat('b', 50), 2);
insert into t5 values (repeat('b', 3), 2);
select c2, avg(sys_op_opnsize(c1)) as avg_col_size from t5 group by c2;
+------+--------------+
| c2   | avg_col_size |
+------+--------------+
|    2 |    1658.3333 |
|    1 |   19216.1667 |
+------+--------------+
# test date/time type
create table t6 (c1 date, c2 datetime, c3 timestamp, c4 time, c5 year);
insert into t6 values ('2018-01-01', '2018-01-01 00:00:01', '2018-01-01 00:00:01', '12:00:00', '2018');
insert into t6 values ('2018-02-02', '1901-01-01 00:00:01', '2000-11-01 00:23:01', '12:00:59', '18');
insert into t6 values ('1999-12-22', '1901-01-05 05:59:59', '2010-05-01 11:23:59', '00:57:58', '2000');
insert into t6 values ('1997-10-10', '1900-03-15 05:52:55', '2110-05-09 09:23:03', '00:17:28', '2030');
insert into t6 values ('1992-08-02', '1998-01-15 02:42:35', '2190-05-19 03:23:03', '07:17:28', '2050');
select sys_op_opnsize(c1) as size_c1,
       sys_op_opnsize(c2) as size_c2,
       sys_op_opnsize(c3) as size_c3,
       sys_op_opnsize(c4) as size_c4,
       sys_op_opnsize(c5) as size_c5
       from t6;
+---------+---------+---------+---------+---------+
| size_c1 | size_c2 | size_c3 | size_c4 | size_c5 |
+---------+---------+---------+---------+---------+
|      16 |      16 |      16 |      16 |      16 |
|      16 |      16 |      16 |      16 |      16 |
|      16 |      16 |      16 |      16 |      16 |
|      16 |      16 |      16 |      16 |      16 |
|      16 |      16 |      16 |      16 |      16 |
+---------+---------+---------+---------+---------+
# test enum/set type
create table t7 (c1 enum('apple', 'xiaomi', 'meizu', 'samsung', 'huawei', 'averyveryveryveryveryveryveryveryveryverylongname'),
                 c2 set('apple', 'xiaomi', 'meizu', 'samsung', 'huawei', 'averyveryveryveryveryveryveryveryveryverylongname'));
insert into t7 values ('apple', 'apple');
insert into t7 values ('xiaomi', 'apple,xiaomi');
insert into t7 values ('meizu', '');
insert into t7 values ('samsung', 'xiaomi,meizu,samsung,huawei');
insert into t7 values ('averyveryveryveryveryveryveryveryveryverylongname', 'xiaomi,meizu,samsung,huawei,averyveryveryveryveryveryveryveryveryverylongname');
select c1, sys_op_opnsize(c1) as size_c1,
       c2, sys_op_opnsize(c2) as size_c2
       from t7;
+---------------------------------------------------+---------+-------------------------------------------------------------------------------+---------+
| c1                                                | size_c1 | c2                                                                            | size_c2 |
+---------------------------------------------------+---------+-------------------------------------------------------------------------------+---------+
| apple                                             |      16 | apple                                                                         |      16 |
| xiaomi                                            |      16 | apple,xiaomi                                                                  |      16 |
| meizu                                             |      16 |                                                                               |      16 |
| samsung                                           |      16 | xiaomi,meizu,samsung,huawei                                                   |      16 |
| averyveryveryveryveryveryveryveryveryverylongname |      16 | xiaomi,meizu,samsung,huawei,averyveryveryveryveryveryveryveryveryverylongname |      16 |
+---------------------------------------------------+---------+-------------------------------------------------------------------------------+---------+
# test binary type
create table t8 (c1 varbinary(16), c2 binary(64), c3 varbinary(128), c4 varbinary(256));
insert into t8 values (repeat('a', 1), repeat('b', 6), repeat('c', 1), repeat('d', 2));
insert into t8 values (repeat('a', 13), repeat('b', 63), repeat('c', 127), repeat('d', 255));
insert into t8 values (repeat('a', 10), repeat('b', 43), repeat('c', 107), repeat('d', 225));
insert into t8 values (repeat('a', 5), repeat('b', 33), repeat('c', 10), repeat('d', 25));
select sys_op_opnsize(c1) as size_c1,
       sys_op_opnsize(c2) as size_c2,
       sys_op_opnsize(c3) as size_c3,
       sys_op_opnsize(c4) as size_c4
       from t8;
+---------+---------+---------+---------+
| size_c1 | size_c2 | size_c3 | size_c4 |
+---------+---------+---------+---------+
|      17 |      80 |      17 |      18 |
|      29 |      80 |     143 |     271 |
|      26 |      80 |     123 |     241 |
|      21 |      80 |      26 |      41 |
+---------+---------+---------+---------+
# test bit type
create table t9 (c1 bit(8), c2 bit(32), c3 bit(64));
insert into t9 values (b'0', b'0', b'0');
insert into t9 values (b'010', b'010', b'010');
insert into t9 values (b'101', b'101', b'101');
insert into t9 values (b'11010', b'11010', b'11010');
select sys_op_opnsize(c1) as size_c1,
       sys_op_opnsize(c2) as size_c2,
       sys_op_opnsize(c3) as size_c3
       from t9;
+---------+---------+---------+
| size_c1 | size_c2 | size_c3 |
+---------+---------+---------+
|      16 |      16 |      16 |
|      16 |      16 |      16 |
|      16 |      16 |      16 |
|      16 |      16 |      16 |
+---------+---------+---------+
# test expression
select sys_op_opnsize(c1) as nc1, sys_op_opnsize(abs(c1)) as nc2, sys_op_opnsize(pow(c1, 2)) as nc3 from t1;
+------+------+------+
| nc1  | nc2  | nc3  |
+------+------+------+
|   16 |   16 |   16 |
|   16 |   16 |   16 |
|   16 |   16 |   16 |
|   16 |   16 |   16 |
+------+------+------+
select sys_op_opnsize(pow(c1,2) * pow(c1, 2)) as nc1, sys_op_opnsize(abs(c1) * round(abs(c1), 0)) as nc2, sys_op_opnsize(ceil(c1)) as nc3 from t3;
+------+------+------+
| nc1  | nc2  | nc3  |
+------+------+------+
|   16 |   24 |   16 |
|   16 |   24 |   16 |
|   16 |   24 |   16 |
+------+------+------+
drop table if exists t1, t2, t3, t4, t5, t6, t7, t8, t9;
