drop table t1, t2, t3, t4, t5, t6, t7;
drop table if exists cs_customer;
CREATE TABLE `cs_customer`(
`customer_id` varchar(24) COLLATE utf8mb4_bin NOT NULL,
`name` varchar(192) COLLATE utf8mb4_bin NOT NULL,
`national` varchar(5) COLLATE utf8mb4_bin NOT NULL,
`cert_type` varchar(30) COLLATE utf8mb4_bin NOT NULL,
`cert_no` varchar(96) COLLATE utf8mb4_bin NOT NULL,
`type` varchar(1) COLLATE utf8mb4_bin NOT NULL,
`cert_from` varchar(30) COLLATE utf8mb4_bin NOT NULL,
`cert_status` varchar(1) COLLATE utf8mb4_bin NOT NULL,
`open_status` varchar(1) COLLATE utf8mb4_bin NOT NULL,
`enable_status` varchar(1) COLLATE utf8mb4_bin NOT NULL,
`gmt_create` timestamp(6) NOT NULL,
`gmt_modified` timestamp(6) NOT NULL,
`memo` varchar(384) COLLATE utf8mb4_bin DEFAULT NULL NULL,
`ext_flag` varchar(1) COLLATE utf8mb4_bin DEFAULT NULL,
`corp_sub_type` varchar(24) COLLATE utf8mb4_bin DEFAULT NULL,
PRIMARY KEY (`customer_id`),
UNIQUE KEY `uk_certno_name` (`cert_no`, `name`),
KEY `idx_name` (`name`)
);
explain select CUSTOMER_ID, NAME, NATIONAL, CERT_TYPE, CERT_NO, TYPE, CERT_FROM, CERT_STATUS, OPEN_STATUS, ENABLE_STATUS, GMT_CREATE, GMT_MODIFIED, MEMO ,EXT_FLAG,CORP_SUB_TYPE
from cs_customer          
where (name = "1" OR name = "2") AND cert_type = "3" AND (cert_no = "4" OR cert_no = "5");
Query Plan
==========================================================
|ID|OPERATOR  |NAME                       |EST. ROWS|COST|
----------------------------------------------------------
|0 |TABLE SCAN|cs_customer(uk_certno_name)|1        |331 |
==========================================================

Outputs & filters: 
-------------------------------------
  0 - output([cs_customer.customer_id], [cs_customer.name], [cs_customer.national], [cs_customer.cert_type], [cs_customer.cert_no], [cs_customer.type], [cs_customer.cert_from], [cs_customer.cert_status], [cs_customer.open_status], [cs_customer.enable_status], [cs_customer.gmt_create], [cs_customer.gmt_modified], [cs_customer.memo], [cs_customer.ext_flag], [cs_customer.corp_sub_type]), filter([cs_customer.cert_type = '3']), 
      access([cs_customer.name], [cs_customer.cert_type], [cs_customer.cert_no], [cs_customer.customer_id], [cs_customer.national], [cs_customer.type], [cs_customer.cert_from], [cs_customer.cert_status], [cs_customer.open_status], [cs_customer.enable_status], [cs_customer.gmt_create], [cs_customer.gmt_modified], [cs_customer.memo], [cs_customer.ext_flag], [cs_customer.corp_sub_type]), partitions(p0)

drop table if exists astc_asset_balance_fa_00;
CREATE TABLE `astc_asset_balance_fa_00` (
`id` varchar(28) NOT NULL,
`accounting_id` varchar(28) NOT NULL,
`accounting_type` varchar(32) NOT NULL,
`balance_type` varchar(32) NOT NULL,
`balance` bigint(15) NOT NULL,
`currency` varchar(8) NOT NULL,
`freeze_amount` bigint(15) NOT NULL,
`in_amount` bigint(15) NOT NULL,
`out_amount` bigint(15) NOT NULL,
`cancel_amount` bigint(15) NOT NULL,
`sys_rf_amount` bigint(15) NOT NULL,
`sys_bu_amount` bigint(15) NOT NULL,
`prev_balance` bigint(15) NOT NULL,
`prev_trans_date` varchar(8) NOT NULL,
`gmt_last_trans` timestamp(6) NOT NULL,
`gmt_create` timestamp(6) NOT NULL,
`gmt_modified` timestamp(6) NOT NULL,
`user_id` varchar(16) NOT NULL,
`product_channel` varchar(32) DEFAULT NULL,
PRIMARY KEY (`id`),
UNIQUE KEY `IDX_astc_asset_balance_AB_FA_00` (`accounting_id`, `balance_type`) BLOCK_SIZE 16384,
KEY `idx_astc_asset_balance_ub_fa_00` (`user_id`, `balance_type`, `accounting_id`) BLOCK_SIZE 16384,
KEY `idx_aid_bt_b` (`accounting_id`, `balance_type`, `balance`) BLOCK_SIZE 16384
);
explain select accounting_id, balance_type, balance from astc_asset_balance_fa_00 
where 1=1 and accounting_id in('2015101900034001767600726113', '2015102000034001767600728075', '2015102000034001767600728285', '2015102000034001767600728291', '2015102000034001767600732082', '2015102000034001767600732085')   
and balance_type in('UNIT', 'P_AMOUNT', 'R_NA_AMOUNT');
