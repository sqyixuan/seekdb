2	3	3	3	3
insert into test (c1,c2,c3) values(4,4,4) on duplicate key update c5=c4+1;
ERROR 42000: Column should not be null(col_index=4)
select * from test;
c1	c2	c3	c4	c5
1	2	2	NULL	2
2	3	3	3	3
