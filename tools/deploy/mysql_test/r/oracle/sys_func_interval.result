# test calc expr
SELECT INTERVAL(4, 3, 0, 0, 0, 0, 0, 8, 3, -3, 0 -6);
+-----------------------------------------------+
| INTERVAL(4, 3, 0, 0, 0, 0, 0, 8, 3, -3, 0 -6) |
+-----------------------------------------------+
|                                            10 |
+-----------------------------------------------+
SELECT INTERVAL(4, 3, NULL, 0, 0, 0, 0, 8, 3, -3, 0-6);
+-------------------------------------------------+
| INTERVAL(4, 3, NULL, 0, 0, 0, 0, 8, 3, -3, 0-6) |
+-------------------------------------------------+
|                                               6 |
+-------------------------------------------------+
SELECT INTERVAL(4-0, 3, NULL, 0, 0, 0, 0, 8, 3, -3, 0-6);
+---------------------------------------------------+
| INTERVAL(4-0, 3, NULL, 0, 0, 0, 0, 8, 3, -3, 0-6) |
+---------------------------------------------------+
|                                                 6 |
+---------------------------------------------------+
SELECT INTERVAL(999, 35, NULL, -9999, 333, -333, NULL, 1, 1, 1, 1);
+-------------------------------------------------------------+
| INTERVAL(999, 35, NULL, -9999, 333, -333, NULL, 1, 1, 1, 1) |
+-------------------------------------------------------------+
|                                                          10 |
+-------------------------------------------------------------+
SELECT INTERVAL(3-0+0-0, 3, 4+5, 0-6);
+--------------------------------+
| INTERVAL(3-0+0-0, 3, 4+5, 0-6) |
+--------------------------------+
|                              1 |
+--------------------------------+
SELECT INTERVAL('3', '5', '7', '9');
+------------------------------+
| INTERVAL('3', '5', '7', '9') |
+------------------------------+
|                            0 |
+------------------------------+
#warnings
