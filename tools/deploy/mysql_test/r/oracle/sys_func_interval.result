# Test file for interval(), which is used to return 0 if N < N1, 1 if N < N2 and so on or -1 if N is NULL
result_format: 4
# basic test
SELECT INTERVAL(23, 1, 15, 17, 30, 44, 200);
+--------------------------------------+
| INTERVAL(23, 1, 15, 17, 30, 44, 200) |
+--------------------------------------+
|                                    3 |
+--------------------------------------+
SELECT INTERVAL(10, 1, 10, 100, 1000);
+--------------------------------+
| INTERVAL(10, 1, 10, 100, 1000) |
+--------------------------------+
|                              2 |
+--------------------------------+
SELECT INTERVAL(22, 23, 30, 44, 200);
+-------------------------------+
| INTERVAL(22, 23, 30, 44, 200) |
+-------------------------------+
|                             0 |
+-------------------------------+

SELECT INTERVAL(-4, -9);
+------------------+
| INTERVAL(-4, -9) |
+------------------+
|                1 |
+------------------+
SELECT INTERVAL(-43209569320, -9, 0);
+-------------------------------+
| INTERVAL(-43209569320, -9, 0) |
+-------------------------------+
|                             0 |
+-------------------------------+
SELECT INTERVAL((5+3*4), -9, 0);
+--------------------------+
| INTERVAL((5+3*4), -9, 0) |
+--------------------------+
|                        2 |
+--------------------------+
SELECT INTERVAL((3+4), 7, (5+3)-1);
+-----------------------------+
| INTERVAL((3+4), 7, (5+3)-1) |
+-----------------------------+
|                           2 |
+-----------------------------+

SELECT INTERVAL(INTERVAL(3, 4, 5), INTERVAL(NULL, 3, 5), INTERVAL(NULL, NULL, NULL), INTERVAL(3+4, 2, 3, 5, 7));
+----------------------------------------------------------------------------------------------------------+
| INTERVAL(INTERVAL(3, 4, 5), INTERVAL(NULL, 3, 5), INTERVAL(NULL, NULL, NULL), INTERVAL(3+4, 2, 3, 5, 7)) |
+----------------------------------------------------------------------------------------------------------+
|                                                                                                        2 |
+----------------------------------------------------------------------------------------------------------+
SELECT INTERVAL(INTERVAL(3, 4, 5), -5, INTERVAL(NULL, 3, 5), INTERVAL(NULL, NULL, NULL), INTERVAL(3+4, 2, 3, 5, 7));
+--------------------------------------------------------------------------------------------------------------+
| INTERVAL(INTERVAL(3, 4, 5), -5, INTERVAL(NULL, 3, 5), INTERVAL(NULL, NULL, NULL), INTERVAL(3+4, 2, 3, 5, 7)) |
+--------------------------------------------------------------------------------------------------------------+
|                                                                                                            3 |
+--------------------------------------------------------------------------------------------------------------+
SELECT INTERVAL(NOW(),INTERVAL(3, 4, 5), -5, INTERVAL(NULL, 3, 5), INTERVAL(NULL, NULL, NULL), INTERVAL(3+4, 2, 3, 5, 7));
+--------------------------------------------------------------------------------------------------------------------+
| INTERVAL(NOW(),INTERVAL(3, 4, 5), -5, INTERVAL(NULL, 3, 5), INTERVAL(NULL, NULL, NULL), INTERVAL(3+4, 2, 3, 5, 7)) |
+--------------------------------------------------------------------------------------------------------------------+
|                                                                                                                  5 |
+--------------------------------------------------------------------------------------------------------------------+
SELECT INTERVAL(NOW(), NOW(), NOW(), NOW() + 1);
+------------------------------------------+
| INTERVAL(NOW(), NOW(), NOW(), NOW() + 1) |
+------------------------------------------+
|                                        2 |
+------------------------------------------+

# test NULL: (n_param < 8) && ordered 
SELECT INTERVAL(NULL, 9);
+-------------------+
| INTERVAL(NULL, 9) |
+-------------------+
|                -1 |
+-------------------+
SELECT INTERVAL(3, NULL);
+-------------------+
| INTERVAL(3, NULL) |
+-------------------+
|                 1 |
+-------------------+
SELECT INTERVAL(NULL, NULL, NULL);
+----------------------------+
| INTERVAL(NULL, NULL, NULL) |
+----------------------------+
|                         -1 |
+----------------------------+
SELECT INTERVAL(0, NULL, NULL, 3);
+----------------------------+
| INTERVAL(0, NULL, NULL, 3) |
+----------------------------+
|                          2 |
+----------------------------+
SELECT INTERVAL(0, NULL, NULL, -3, 5);
+--------------------------------+
| INTERVAL(0, NULL, NULL, -3, 5) |
+--------------------------------+
|                              3 |
+--------------------------------+

# test NULL: (n_param < 8) && disordered 
SELECT INTERVAL(NULL, 9, 5, 2);
+-------------------------+
| INTERVAL(NULL, 9, 5, 2) |
+-------------------------+
|                      -1 |
+-------------------------+
SELECT INTERVAL(0, NULL, NULL, -3);
+-----------------------------+
| INTERVAL(0, NULL, NULL, -3) |
+-----------------------------+
|                           3 |
+-----------------------------+
SELECT INTERVAL(0, NULL, NULL, 10, NULL, -3, 5);
+------------------------------------------+
| INTERVAL(0, NULL, NULL, 10, NULL, -3, 5) |
+------------------------------------------+
|                                        2 |
+------------------------------------------+

# test NULL : (n_param >= 8) && ordered
SELECT INTERVAL(NULL, 9, 10, 100, 111, 11112, 3333, 4444);
+----------------------------------------------------+
| INTERVAL(NULL, 9, 10, 100, 111, 11112, 3333, 4444) |
+----------------------------------------------------+
|                                                 -1 |
+----------------------------------------------------+
SELECT INTERVAL(NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL);
+----------------------------------------------------------------+
| INTERVAL(NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL) |
+----------------------------------------------------------------+
|                                                             -1 |
+----------------------------------------------------------------+
SELECT INTERVAL(0, NULL, NULL, NULL, NULL, NULL, 2, 3);
+-------------------------------------------------+
| INTERVAL(0, NULL, NULL, NULL, NULL, NULL, 2, 3) |
+-------------------------------------------------+
|                                               5 |
+-------------------------------------------------+

# test NULL : (n_param >= 8) && disordered
SELECT INTERVAL(4, 3, 0, 0, 0, 0, 0, 8, 3, -3, NULL -6);
+--------------------------------------------------+
| INTERVAL(4, 3, 0, 0, 0, 0, 0, 8, 3, -3, NULL -6) |
+--------------------------------------------------+
|                                                6 |
+--------------------------------------------------+
SELECT INTERVAL(NULL, 4, 3, 0, 0, 0, 0, 0, 8, 3, -3, NULL, -6);
+---------------------------------------------------------+
| INTERVAL(NULL, 4, 3, 0, 0, 0, 0, 0, 8, 3, -3, NULL, -6) |
+---------------------------------------------------------+
|                                                      -1 |
+---------------------------------------------------------+
SELECT INTERVAL(999, NULL, -9999, '2019', -333, NULL, now(), 1, 1, 1, 1);
+-------------------------------------------------------------------+
| INTERVAL(999, NULL, -9999, '2019', -333, NULL, now(), 1, 1, 1, 1) |
+-------------------------------------------------------------------+
|                                                                 2 |
+-------------------------------------------------------------------+

# test INTEGER TYPE : (n_param < 8) && ordered
SELECT INTERVAL(2, 9, 10);
+--------------------+
| INTERVAL(2, 9, 10) |
+--------------------+
|                  0 |
+--------------------+
SELECT INTERVAL(10, 3, 6, 8, 10, 15);
+-------------------------------+
| INTERVAL(10, 3, 6, 8, 10, 15) |
+-------------------------------+
|                             4 |
+-------------------------------+
SELECT INTERVAL(0,  -3, -6, 99999999);
+--------------------------------+
| INTERVAL(0,  -3, -6, 99999999) |
+--------------------------------+
|                              2 |
+--------------------------------+
SELECT INTERVAL(-32845890, -9999, 9999, 32768);
+-----------------------------------------+
| INTERVAL(-32845890, -9999, 9999, 32768) |
+-----------------------------------------+
|                                       0 |
+-----------------------------------------+

# test INTEGER TYPE: (n_param < 8) && disordered
SELECT INTERVAL(90, 4, 100, 3, 65);
+-----------------------------+
| INTERVAL(90, 4, 100, 3, 65) |
+-----------------------------+
|                           1 |
+-----------------------------+
SELECT INTERVAL(3, 3, 3, 3, 90, 5, 6);
+--------------------------------+
| INTERVAL(3, 3, 3, 3, 90, 5, 6) |
+--------------------------------+
|                              3 |
+--------------------------------+
SELECT INTERVAL(5, 100, 4, 7, 90);
+----------------------------+
| INTERVAL(5, 100, 4, 7, 90) |
+----------------------------+
|                          0 |
+----------------------------+

# test INTEGER TYPE: (n_param >= 8) && ordered
SELECT INTERVAL(0, 9, 10, 100, 111, 11112, 3333, 4444);
+-------------------------------------------------+
| INTERVAL(0, 9, 10, 100, 111, 11112, 3333, 4444) |
+-------------------------------------------------+
|                                               0 |
+-------------------------------------------------+
SELECT INTERVAL(0, NULL, 10, 100, 111, 11112, 3333, 4444);
+----------------------------------------------------+
| INTERVAL(0, NULL, 10, 100, 111, 11112, 3333, 4444) |
+----------------------------------------------------+
|                                                  1 |
+----------------------------------------------------+

# test INTERGER TYPE: (n_param >= 8) && disordered
SELECT INTERVAL(4, 3, 0, 0, 0, 0, 0, 8, 3, -3, 0 -6);
+-----------------------------------------------+
| INTERVAL(4, 3, 0, 0, 0, 0, 0, 8, 3, -3, 0 -6) |
+-----------------------------------------------+
|                                            10 |
+-----------------------------------------------+
SELECT INTERVAL(4, 3, NULL, 0, 0, 0, 0, 8, 3, -3, 0 -6);
+--------------------------------------------------+
| INTERVAL(4, 3, NULL, 0, 0, 0, 0, 8, 3, -3, 0 -6) |
+--------------------------------------------------+
|                                                6 |
+--------------------------------------------------+
SELECT INTERVAL(999, 35, NULL, -9999, 333, -333, NULL, 1, 1, 1, 1);
+-------------------------------------------------------------+
| INTERVAL(999, 35, NULL, -9999, 333, -333, NULL, 1, 1, 1, 1) |
+-------------------------------------------------------------+
|                                                          10 |
+-------------------------------------------------------------+

drop table if exists TEST_INTERVAL;

# test DECIMAL TYPE: prepare
CREATE TABLE TEST_INTERVAL(C1 DECIMAL(15, 10), C2 DECIMAL(20, 10), C3 DECIMAL(30, 10), C4 DECIMAL(40, 20), C5 DECIMAL(50, 25), C6 DECIMAL(60, 30), C7 DECIMAL, C8 DECIMAL(60, 10), C9 DECIMAL(30, 10), C10 DECIMAL);

INSERT INTO TEST_INTERVAL VALUES(NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL);
INSERT INTO TEST_INTERVAL VALUES(NULL, NULL, NULL, 4, 5, 6, 7, 8, 9, 10);
INSERT INTO TEST_INTERVAL VALUES(NULL, NULL, - 5, -9, 5, 6, 7, 8, 9, 10);
INSERT INTO TEST_INTERVAL VALUES(-3, NULL, 3, 4, 5, 6, 7, 8, 9, 10);
INSERT INTO TEST_INTERVAL VALUES(1.2, 1.3, 1.4, 1.5, 1.6, 1.7, 1.8, 1.9, 2.0, 2.1);
INSERT INTO TEST_INTERVAL VALUES(NULL, 1.3, 1.4, 1.5, 1.6, 1.7, 1.8, 1.9, 2.0, 2.1);
INSERT INTO TEST_INTERVAL VALUES(NULL, NULL, 1.4, 1.5, 1.6, 1.7, 1.8, 1.9, 2.0, 2.1);

# test DECIMAL: (n_param < 8) && ordered
SELECT INTERVAL(C1, C2) FROM TEST_INTERVAL;
+------------------+
| INTERVAL(C1, C2) |
+------------------+
|               -1 |
|               -1 |
|               -1 |
|                1 |
|                0 |
|               -1 |
|               -1 |
+------------------+
SELECT INTERVAL(C1, C2, C3, C4, C5) FROM TEST_INTERVAL;
+------------------------------+
| INTERVAL(C1, C2, C3, C4, C5) |
+------------------------------+
|                           -1 |
|                           -1 |
|                           -1 |
|                            1 |
|                            0 |
|                           -1 |
|                           -1 |
+------------------------------+
SELECT INTERVAL(C1 - 0, C2 + 0, C3 + 1, C4 + C4, C5 + C5 + 10, 99999) FROM TEST_INTERVAL;
+----------------------------------------------------------------+
| INTERVAL(C1 - 0, C2 + 0, C3 + 1, C4 + C4, C5 + C5 + 10, 99999) |
+----------------------------------------------------------------+
|                                                             -1 |
|                                                             -1 |
|                                                             -1 |
|                                                              1 |
|                                                              0 |
|                                                             -1 |
|                                                             -1 |
+----------------------------------------------------------------+

# test DECIMAL: (n_param >= 8) && ordered
SELECT INTERVAL(C1, C2, C3, C4, C5, C6, C7, C8, C9, C10) FROM TEST_INTERVAL;
+---------------------------------------------------+
| INTERVAL(C1, C2, C3, C4, C5, C6, C7, C8, C9, C10) |
+---------------------------------------------------+
|                                                -1 |
|                                                -1 |
|                                                -1 |
|                                                 1 |
|                                                 0 |
|                                                -1 |
|                                                -1 |
+---------------------------------------------------+
SELECT INTERVAL(C5, C2, C3, C4, C5, C5, C5, C5, C5, C5, C5, C6, C7, C8, C9, C10) FROM TEST_INTERVAL;
+---------------------------------------------------------------------------+
| INTERVAL(C5, C2, C3, C4, C5, C5, C5, C5, C5, C5, C5, C6, C7, C8, C9, C10) |
+---------------------------------------------------------------------------+
|                                                                        -1 |
|                                                                        10 |
|                                                                        10 |
|                                                                        10 |
|                                                                        10 |
|                                                                        10 |
|                                                                        10 |
+---------------------------------------------------------------------------+
SELECT INTERVAL(C9, C2, C3, C4, C5, C5, C6, C6, C6, C7, C8, C9, C10) FROM TEST_INTERVAL;
+---------------------------------------------------------------+
| INTERVAL(C9, C2, C3, C4, C5, C5, C6, C6, C6, C7, C8, C9, C10) |
+---------------------------------------------------------------+
|                                                            -1 |
|                                                            11 |
|                                                            11 |
|                                                            11 |
|                                                            12 |
|                                                            12 |
|                                                            12 |
+---------------------------------------------------------------+
SELECT INTERVAL(C9 - 2 , C2, C3, C4, C5, C5, C6 + 0, C6, C6, C7, C8, C9, C10, '3') FROM TEST_INTERVAL;
+-----------------------------------------------------------------------------+
| INTERVAL(C9 - 2 , C2, C3, C4, C5, C5, C6 + 0, C6, C6, C7, C8, C9, C10, '3') |
+-----------------------------------------------------------------------------+
|                                                                          -1 |
|                                                                           9 |
|                                                                           9 |
|                                                                           9 |
|                                                                           0 |
|                                                                           0 |
|                                                                           1 |
+-----------------------------------------------------------------------------+

