# Bug #50946: fast index creation still seems to copy the table
#
CREATE TABLE t1 (a INT(100) NOT NULL);
INSERT INTO t1 VALUES (1), (0), (2);
ALTER TABLE t1 ADD INDEX a(a);
SHOW CREATE TABLE t1;
