alter system set merger_check_interval= '10s';
create database if not exists test;
use test;
drop table if exists t3;
create table t3(c1 bigint primary key, c2 bigint, v1 varchar(128), v2 varchar(64));
create index t3_idx1 on t3(v2, c2) storing(v1);
create unique index t3_idx2 on t3(c2);
insert into t3 values(1, 11, 'aaa1', 'aaaa1');
insert into t3 values(2, 22, 'aaa2', 'aaaa2');
insert into t3 values(3, 33, 'aaa3', 'aaaa3');
insert into t3 values(4, 44, 'aaa4', 'aaaa4');
update t3 set c2=2222 where c1=2;
update t3 set c2=1111, v2='aaaaaa' where c1=1;
delete from t3 where c2<55555;
insert into t3 values(1, 11, 'aaa1', 'aaaa1');
insert into t3 values(2, 22, 'aaa2', 'aaaa2');
insert into t3 values(3, 33, 'aaa3', 'aaaa3');
insert into t3 values(4, 44, 'aaa4', 'aaaa4');
select /*+index(t3 t3_idx1)*/ * from t3 where v1 like 'aaa%';
c1	c2	v1	v2
1	11	aaa1	aaaa1
2	22	aaa2	aaaa2
3	33	aaa3	aaaa3
4	44	aaa4	aaaa4
update t3 set v2='aaaaaaaaaaa' where v1 in ('aaa2', 'aaa4');
select /*+index(t3 t3_idx1)*/ * from t3 where v2 like '%aaaaaaaaa%';
c1	c2	v1	v2
2	22	aaa2	aaaaaaaaaaa
4	44	aaa4	aaaaaaaaaaa
