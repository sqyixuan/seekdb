drop table if exists t1;
create table t1(pk int primary key, c1 int);
set autocommit=0;
set autocommit=0;
insert into t1 values(1,1);
update t1 set c1=c1+1 where pk=1 when row_count(insert into t1 values(2,2))=1;
select * from t1;
pk	c1
2	2
update t1 set c1=c1+2 where pk=3 when row_count(insert into t1 values(0,0))=1;
select * from t1;
pk	c1
0	0
2	2
commit;
commit;
select * from t1;
pk	c1
