select convert(123.23456789 , decimal(38,2));
convert(123.23456789 , decimal(38,2))
123.23
select convert('abc', char);
convert('abc', char)
abc
select convert('abc', binary);
convert('abc', binary)
abc
select convert('asas' using utf8);
convert('asas' using utf8)
asas
select convert('1234' using utf8);
convert('1234' using utf8)
1234
select convert(binary '1234' using utf8);
convert(binary '1234' using utf8)
1234
