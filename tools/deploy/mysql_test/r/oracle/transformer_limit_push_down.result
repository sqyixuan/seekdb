drop table if exists t1;
create table t1 (v1 varchar(20), v2 varchar (20));
insert into t1 (v1, v2) values ('a', 'b');
explain basic select * from (select concat(concat(v1, '_'), v2) from (select distinct v1, v2 from t1) T) TT;
Query Plan
========================
|ID|OPERATOR      |NAME|
------------------------
|0 |SUBPLAN SCAN  |T   |
|1 | HASH DISTINCT|    |
|2 |  TABLE SCAN  |t1  |
========================

Outputs & filters: 
-------------------------------------
  0 - output([concat(concat(T.v1, '_'), T.v2)]), filter(nil), 
      access([T.v1], [T.v2])
  1 - output([t1.v1], [t1.v2]), filter(nil), 
      distinct([t1.v1], [t1.v2])
  2 - output([t1.v1], [t1.v2]), filter(nil), 
      access([t1.v1], [t1.v2]), partitions(p0)

select * from (select concat(concat(v1, '_'), v2) from (select distinct v1, v2 from t1) T) TT;
concat(concat(v1, '_'), v2)
a_b
