alter system major freeze tenant = all_user;
alter system major freeze tenant = all_meta;
select a.macro_block_count - a.use_old_macro_block_count as rewrite_macro_block_cnt from oceanbase.__all_virtual_partition_sstable_merge_info a, oceanbase.__all_virtual_table b where b.table_name='t1' and a.table_id=b.table_id order by a.version desc limit 1;
rewrite_macro_block_cnt
0
alter table t1 set progressive_merge_num=1;
alter system major freeze tenant = sys;
alter system major freeze tenant = all_user;
alter system major freeze tenant = all_meta;
select a.use_old_macro_block_count as reuse_macro_block_cnt from oceanbase.__all_virtual_partition_sstable_merge_info a, oceanbase.__all_virtual_table b where b.table_name='t1' and a.table_id=b.table_id order by a.version desc limit 1;
reuse_macro_block_cnt
