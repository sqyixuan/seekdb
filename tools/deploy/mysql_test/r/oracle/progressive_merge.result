create table t1(id int primary key, name varchar(65535), age int, description varchar(65535)) progressive_merge_num=10 tablet_size=104857600 compression='none';
alter system major freeze tenant = sys;
alter system major freeze tenant = all_user;
alter system major freeze tenant = all_meta;
alter table t1 add column(c1 int);
alter system major freeze tenant = sys;
alter system major freeze tenant = all_user;
alter system major freeze tenant = all_meta;
select (a.macro_block_count - a.use_old_macro_block_count)/a.macro_block_count < 1.0/9 as high_ratio, (a.macro_block_count - a.use_old_macro_block_count)/a.macro_block_count > 1.0/11 as low_ratio from oceanbase.__all_virtual_partition_sstable_merge_info a, oceanbase.__all_virtual_table b where b.table_name='t1' and a.table_id=b.table_id order by a.version desc limit 1;
high_ratio	low_ratio
1	1
alter table t1 set progressive_merge_num=5;
alter system major freeze tenant = sys;
alter system major freeze tenant = all_user;
alter system major freeze tenant = all_meta;
select (a.macro_block_count - a.use_old_macro_block_count)/a.macro_block_count < 1.0/4 as high_ratio, (a.macro_block_count - a.use_old_macro_block_count)/a.macro_block_count > 1.0/6 as low_ratio from oceanbase.__all_virtual_partition_sstable_merge_info a, oceanbase.__all_virtual_table b where b.table_name='t1' and a.table_id=b.table_id order by a.version desc limit 1;
high_ratio	low_ratio
1	1
alter table t1 set progressive_merge_num=15;
alter system major freeze tenant = sys;
alter system major freeze tenant = all_user;
alter system major freeze tenant = all_meta;
select (a.macro_block_count - a.use_old_macro_block_count)/a.macro_block_count < 1.0/14 as high_ratio from oceanbase.__all_virtual_partition_sstable_merge_info a, oceanbase.__all_virtual_table b where b.table_name='t1' and a.table_id=b.table_id order by a.version desc limit 1;
high_ratio
1
