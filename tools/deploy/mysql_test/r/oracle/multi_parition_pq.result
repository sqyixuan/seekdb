create database multi_partition_pq;
use multi_partition_pq;
alter system  enable_micro_block_encoding=False;
create table t1(c1 int not null auto_increment comment 'ID', c2 varchar(1000),  primary key(c1), index t1_c2(c2)) COMPRESSION = 'NONE';
create table t2(c1 int primary key, c2 varchar(1000));
create table t1_p(c1 int not null, c2 varchar(1000),  primary key(c1), index t1_c2(c2) local) COMPRESSION = 'NONE' partition by range columns(c1) (partition p0 values less than (20000), partition p1 values less than (35000), partition p2 values less than (50000), partition p3 values less than (MAXVALUE));
explain extended_noaddr select /*+ parallel(2) */ count(*) from t1;
Query Plan
==============================================
|ID|OPERATOR            |NAME|EST. ROWS|COST |
----------------------------------------------
|0 |SCALAR GROUP BY     |    |1        |57637|
|1 | EXCHANGE IN DISTR  |    |1        |57636|
|2 |  EXCHANGE OUT DISTR|    |1        |57636|
|3 |   MERGE GROUP BY   |    |1        |57636|
|4 |    GRANULE ITERATOR|    |101241   |38298|
|5 |     TABLE SCAN     |t1  |101241   |38298|
==============================================

Outputs & filters: 
-------------------------------------
  0 - output([T_FUN_COUNT_SUM(T_FUN_COUNT(*))]), filter(nil), 
      group(nil), agg_func([T_FUN_COUNT_SUM(T_FUN_COUNT(*))])
  1 - output([T_FUN_COUNT(*)]), filter(nil)
  2 - output([T_FUN_COUNT(*)]), filter(nil)
  3 - output([T_FUN_COUNT(*)]), filter(nil), 
      group(nil), agg_func([T_FUN_COUNT(*)])
  4 - output([t1.c1]), filter(nil)
  5 - output([t1.c1]), filter(nil), 
      access([t1.c1]), partitions(p0), 
      is_index_back=false, 
      range_key([t1.c1]), range(MIN ; MAX)always true, 
      split_ranges((MIN ; MAX)always true), split_pos=(0)

