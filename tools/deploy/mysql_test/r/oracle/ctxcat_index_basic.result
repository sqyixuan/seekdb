CREATE TABLE `spi_node_export_field`( `id` int(11) NOT NULL AUTO_INCREMENT, `name` varchar(200) NOT NULL COMMENT '导出的字段名称', `zh_name` varchar(200) NOT NULL, `en_name` varchar(200) NOT NULL, `value_type` varchar(200) NOT NULL, `value_placeholder` text DEFAULT NULL, `field_paths` mediumtext DEFAULT NULL, `zh_description` mediumtext DEFAULT NULL, `en_description` mediumtext DEFAULT NULL, `available_tenant_ids` mediumtext DEFAULT NULL, `created_time` datetime(3) NOT NULL, `modified_time` datetime(3) NOT NULL, PRIMARY KEY (`id`), UNIQUE KEY `name` (`name`) BLOCK_SIZE 16384, UNIQUE KEY `spi_node_export_field_name_uindex` (`name`) BLOCK_SIZE 16384, FULLTEXT KEY `spi_node_export_field_available_tenant_ids_index` (`available_tenant_ids`) CTXCAT(`available_tenant_ids`));
select `id`,`name`, zh_name, en_name, value_type, value_placeholder, field_paths, zh_description, en_description, available_tenant_ids, created_time, modified_time from spi_node_export_field WHERE (available_tenant_ids is null or MATCH (available_tenant_ids) AGAINST('"0000000001"' IN BOOLEAN MODE));
id	name	zh_name	en_name	value_type	value_placeholder	field_paths	zh_description	en_description	available_tenant_ids	created_time	modified_time
drop table spi_node_export_field;
