drop table if exists t_refered,t_h5_r4_int_int_datetime;
create table t_refered(a int, aa bigint, b int unsigned, bb bigint unsigned, c datetime, d date, e timestamp,  primary key (a));
create table t_h5_r4_int_int_datetime(a int, b int, c datetime, primary key (a, b, c));
