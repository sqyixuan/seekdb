PROPAGATION          VARCHAR(1),
CONTEXT              VARCHAR(2048),
PRIMARY KEY (TX_ID)
)DEFAULT CHARSET = 'utf8';
CREATE TABLE if not exists EXTERFACE_INVOKE_000
(
ID           int         NOT NULL,
