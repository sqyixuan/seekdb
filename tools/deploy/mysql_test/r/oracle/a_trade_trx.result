GMT_RETURN   TIMESTAMP(6) default "2012-01-01 12:00:00" NULL,
PRIMARY KEY(TARGET_TYPE, TARGET, PARTNER_ID)
)DEFAULT CHARSET = 'utf8';
CREATE INDEX EXTERFACE_INVOKE_000_ID_IND ON EXTERFACE_INVOKE_000(ID);
