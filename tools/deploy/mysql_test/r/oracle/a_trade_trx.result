GMT_OCCUR     TIMESTAMP(6) default "2012-01-01 12:00:00" NULL,
PRIMARY KEY (JOB_ID, TRADE_NO, ACTION_TYPE)
) DEFAULT CHARSET = 'utf8';
CREATE TABLE if not exists TIMEOUT_LONG_000 
(
JOB_ID        varchar(32)   NOT NULL,
TRADE_NO      varchar(64),
USER_ID       varchar(128),
