alter system set merger_check_interval= '10s';
create database if not exists test;
use test;
drop table if exists t1;
create table t1 (c1 varchar(40) primary key, c2 int ,c3 varchar(100), c4 varchar(100), `c1_gen` varchar(20) GENERATED ALWAYS AS (substr(`c1`,10,20)) VIRTUAL);
insert into t1 (c1,c2,c3) values ("HHHHHHHHHHHHHHHHHHHH", 1, "hello");
delete from t1 where c1 = "HHHHHHHHHHHHHHHHHHHH";
insert into t1 (c1,c2,c3) values ("hhhhhhhhhhhhhhhhhhhh", 10, "world");
create unique index ui on t1 (c1, c2 ,c4, c1_gen);
select c1 ,c2,c4, c1_gen from t1;
c1	c2	c4	c1_gen
hhhhhhhhhhhhhhhhhhhh	10	NULL	hhhhhhhhhhh
