create table t1(a varchar(10) collate utf8mb4_general_ci, 
cond1 varchar(10) collate utf8mb4_bin, 
cond2 varchar(10) collate utf8mb4_general_ci, 
val1 varchar(10) collate utf8mb4_bin,
val2 varchar(10) collate utf8mb4_bin);
