drop table if exists t1;
CREATE TABLE t1(b VARCHAR(255), c INT,
KEY(b, c));
INSERT INTO t1(b, c) VALUES ('a', 0), ('a', null), ('a', 0),
('a', null), ('a', 0);
SELECT MIN(c) FROM t1 GROUP BY b;
MIN(c)
0
DROP TABLE t1;
