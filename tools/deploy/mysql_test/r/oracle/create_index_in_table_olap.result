drop database if exists create_index_in_table_olap;
create database create_index_in_table_olap;
use create_index_in_table_olap;
drop table if exists  ob_custname;
drop table if exists  ob_custid;
drop table if exists  ob_campaign;
drop table if exists  ob_adgroup;
drop table if exists  ob_bidword;
drop table if exists  tt;
drop table if exists  kk;
CREATE TABLE IF NOT EXISTS ob_custname(
id int,
custid int,
custname varchar(65535),
gmt_create timestamp default now(),
gmt_modify timestamp default now(),
PRIMARY KEY (custid),
unique index idx_custname(custid,id,gmt_create)
) COMPRESSION='zstd_1.0' ;
CREATE TABLE IF NOT EXISTS ob_custid(
custid int,
thedate  timestamp(6) default "2012-01-01 12:00:00",
cost int,
gmt_create timestamp default now(),
gmt_modify timestamp default now(),
PRIMARY KEY (custid,thedate),
unique index idx_custid(gmt_create,thedate,custid),
index idx_custid2(gmt_create,cost,thedate)
) COMPRESSION='zstd_1.0' ;
CREATE TABLE IF NOT EXISTS ob_campaign(
custid int,
campid int,
thedate  timestamp(6) default "2012-01-01 12:00:00",
campstr varchar(65535),
shopid int,
c1 int,
c2 int,
c3 int,
c4 int,
c5 int,
gmt_create timestamp default now(),
gmt_modify timestamp default now(),
PRIMARY KEY (custid,thedate,campid),
unique index idx_campaign1(gmt_create,custid, thedate,campid),
unique index idx_campaign2(shopid,c1,custid, thedate,campid,gmt_create)
) COMPRESSION='zstd_1.0' ;
CREATE TABLE IF NOT EXISTS ob_adgroup(
custid int,
campid int,
adgrpid int,
thedate  timestamp(6) default "2012-01-01 12:00:00",
adgrpstr varchar(65535),
shopid int,
auctionid int,
c1 int,
c2 int,
c3 int,
c4 int,
c5 int,
gmt_create timestamp default now(),
gmt_modify timestamp default now(),
PRIMARY KEY (custid,thedate,campid,adgrpid),
index idx_adgroup(c1,c2,c5,gmt_create)
) COMPRESSION='zstd_1.0' ;
CREATE TABLE IF NOT EXISTS ob_bidword(
custid int,
campid int,
adgrpid int,
bidwordid int,
thedate  timestamp(6) default "2012-01-01 12:00:00",
bidwordstr varchar(65535),
shopid int,
auctionid int,
memberid int,
c1 int,
c2 int,
c3 int,
c4 int,
c5 int,
c6 int,
c7 int,
c8 int,
c9 int,
c10 int,
dec1 decimal(16,6),
dec2 decimal(16,6),
dec3 decimal(16,6),
dec4 decimal(16,6),
dec5 decimal(16,6),
dec6 decimal(16,6),
dec7 decimal(16,6),
dec8 decimal(16,6),
dec9 decimal(16,6),
dec10 decimal(16,6),
gmt_create timestamp default now(),
gmt_modify timestamp default now(),
PRIMARY KEY (custid,campid,adgrpid,bidwordid,thedate),
unique index idx_bidword1(gmt_create,custid, thedate, campid, adgrpid, bidwordid),
unique index idx_bidword2(gmt_create,shopid,custid, thedate, campid, adgrpid, bidwordid),
index idx_bidword3(gmt_create,c1,c2,c3),
index idx_bidword4(gmt_create,c1,c2,c3),
index idx_bidword5(gmt_create,shopid,c1,c2,c3,c6)
) COMPRESSION='zstd_1.0' ;
CREATE TABLE IF NOT EXISTS OBOLAP(
pid int,
tid int,
row_num int,
PRIMARY KEY (pid, tid)
) COMPRESSION='zstd_1.0' ;
create table tt(
id bigint not null primary key,
age int default 0,
vch varchar(256),
gmt_create datetime default null,
num1 decimal(10,3),
num2 decimal(10,3)
) COMPRESSION='zstd_1.0';
create table kk(
id bigint not null primary key,
age int default 0,
vch varchar(256),
gmt_create datetime default null,
num1 decimal(10,3),
num2 decimal(10,3)
) COMPRESSION='zstd_1.0';
show create table ob_custname;
Table	Create Table
ob_custname	CREATE TABLE `ob_custname` (
  `id` int(11) DEFAULT NULL,
  `custid` int(11) NOT NULL,
  `custname` varchar(65535) DEFAULT NULL,
  `gmt_create` timestamp NOT NULL DEFAULT CURRENT_TIMESTAMP,
  `gmt_modify` timestamp NOT NULL DEFAULT CURRENT_TIMESTAMP,
  PRIMARY KEY (`custid`),
  UNIQUE KEY `idx_custname` (`custid`, `id`, `gmt_create`) BLOCK_SIZE 16384
) DEFAULT CHARSET = utf8mb4 COMPRESSION = 'zstd_1.0' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 10
show create table ob_custid;
Table	Create Table
ob_custid	CREATE TABLE `ob_custid` (
  `custid` int(11) NOT NULL,
  `thedate` timestamp(6) NOT NULL DEFAULT '2012-01-01 12:00:00.000000',
  `cost` int(11) DEFAULT NULL,
  `gmt_create` timestamp NOT NULL DEFAULT CURRENT_TIMESTAMP,
  `gmt_modify` timestamp NOT NULL DEFAULT CURRENT_TIMESTAMP,
  PRIMARY KEY (`custid`, `thedate`),
  UNIQUE KEY `idx_custid` (`gmt_create`, `thedate`, `custid`) BLOCK_SIZE 16384,
  KEY `idx_custid2` (`gmt_create`, `cost`, `thedate`) BLOCK_SIZE 16384
) DEFAULT CHARSET = utf8mb4 COMPRESSION = 'zstd_1.0' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 10
show create table ob_campaign;
Table	Create Table
ob_campaign	CREATE TABLE `ob_campaign` (
  `custid` int(11) NOT NULL,
  `campid` int(11) NOT NULL,
  `thedate` timestamp(6) NOT NULL DEFAULT '2012-01-01 12:00:00.000000',
  `campstr` varchar(65535) DEFAULT NULL,
  `shopid` int(11) DEFAULT NULL,
  `c1` int(11) DEFAULT NULL,
  `c2` int(11) DEFAULT NULL,
  `c3` int(11) DEFAULT NULL,
  `c4` int(11) DEFAULT NULL,
  `c5` int(11) DEFAULT NULL,
  `gmt_create` timestamp NOT NULL DEFAULT CURRENT_TIMESTAMP,
  `gmt_modify` timestamp NOT NULL DEFAULT CURRENT_TIMESTAMP,
  PRIMARY KEY (`custid`, `thedate`, `campid`),
  UNIQUE KEY `idx_campaign1` (`gmt_create`, `custid`, `thedate`, `campid`) BLOCK_SIZE 16384,
  UNIQUE KEY `idx_campaign2` (`shopid`, `c1`, `custid`, `thedate`, `campid`, `gmt_create`) BLOCK_SIZE 16384
) DEFAULT CHARSET = utf8mb4 COMPRESSION = 'zstd_1.0' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 10
show create table ob_adgroup;
Table	Create Table
ob_adgroup	CREATE TABLE `ob_adgroup` (
  `custid` int(11) NOT NULL,
  `campid` int(11) NOT NULL,
  `adgrpid` int(11) NOT NULL,
  `thedate` timestamp(6) NOT NULL DEFAULT '2012-01-01 12:00:00.000000',
  `adgrpstr` varchar(65535) DEFAULT NULL,
  `shopid` int(11) DEFAULT NULL,
  `auctionid` int(11) DEFAULT NULL,
  `c1` int(11) DEFAULT NULL,
  `c2` int(11) DEFAULT NULL,
  `c3` int(11) DEFAULT NULL,
  `c4` int(11) DEFAULT NULL,
  `c5` int(11) DEFAULT NULL,
  `gmt_create` timestamp NOT NULL DEFAULT CURRENT_TIMESTAMP,
  `gmt_modify` timestamp NOT NULL DEFAULT CURRENT_TIMESTAMP,
  PRIMARY KEY (`custid`, `thedate`, `campid`, `adgrpid`),
  KEY `idx_adgroup` (`c1`, `c2`, `c5`, `gmt_create`) BLOCK_SIZE 16384
) DEFAULT CHARSET = utf8mb4 COMPRESSION = 'zstd_1.0' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 10
show create table ob_bidword;
Table	Create Table
ob_bidword	CREATE TABLE `ob_bidword` (
  `custid` int(11) NOT NULL,
  `campid` int(11) NOT NULL,
  `adgrpid` int(11) NOT NULL,
  `bidwordid` int(11) NOT NULL,
  `thedate` timestamp(6) NOT NULL DEFAULT '2012-01-01 12:00:00.000000',
  `bidwordstr` varchar(65535) DEFAULT NULL,
  `shopid` int(11) DEFAULT NULL,
  `auctionid` int(11) DEFAULT NULL,
  `memberid` int(11) DEFAULT NULL,
  `c1` int(11) DEFAULT NULL,
  `c2` int(11) DEFAULT NULL,
  `c3` int(11) DEFAULT NULL,
  `c4` int(11) DEFAULT NULL,
  `c5` int(11) DEFAULT NULL,
  `c6` int(11) DEFAULT NULL,
  `c7` int(11) DEFAULT NULL,
  `c8` int(11) DEFAULT NULL,
  `c9` int(11) DEFAULT NULL,
  `c10` int(11) DEFAULT NULL,
  `dec1` decimal(16,6) DEFAULT NULL,
  `dec2` decimal(16,6) DEFAULT NULL,
  `dec3` decimal(16,6) DEFAULT NULL,
  `dec4` decimal(16,6) DEFAULT NULL,
  `dec5` decimal(16,6) DEFAULT NULL,
  `dec6` decimal(16,6) DEFAULT NULL,
  `dec7` decimal(16,6) DEFAULT NULL,
  `dec8` decimal(16,6) DEFAULT NULL,
  `dec9` decimal(16,6) DEFAULT NULL,
  `dec10` decimal(16,6) DEFAULT NULL,
  `gmt_create` timestamp NOT NULL DEFAULT CURRENT_TIMESTAMP,
  `gmt_modify` timestamp NOT NULL DEFAULT CURRENT_TIMESTAMP,
  PRIMARY KEY (`custid`, `campid`, `adgrpid`, `bidwordid`, `thedate`),
  UNIQUE KEY `idx_bidword1` (`gmt_create`, `custid`, `thedate`, `campid`, `adgrpid`, `bidwordid`) BLOCK_SIZE 16384,
  UNIQUE KEY `idx_bidword2` (`gmt_create`, `shopid`, `custid`, `thedate`, `campid`, `adgrpid`, `bidwordid`) BLOCK_SIZE 16384,
  KEY `idx_bidword3` (`gmt_create`, `c1`, `c2`, `c3`) BLOCK_SIZE 16384,
  KEY `idx_bidword4` (`gmt_create`, `c1`, `c2`, `c3`) BLOCK_SIZE 16384,
  KEY `idx_bidword5` (`gmt_create`, `shopid`, `c1`, `c2`, `c3`, `c6`) BLOCK_SIZE 16384
) DEFAULT CHARSET = utf8mb4 COMPRESSION = 'zstd_1.0' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 10
