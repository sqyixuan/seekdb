alter table ob_bidword  set expire_info = (gmt_create < date_sub(merging_frozen_time(), INTERVAL 1 DAY));
alter table ob_custname  set  progressive_merge_num=5;
drop table if exists t1;
create table t1(c0 int primary key,c1 varchar(1024),index idx(c1)) EXPIRE_INFO  (c1 = 'd');
drop database create_index_in_table_olap;
