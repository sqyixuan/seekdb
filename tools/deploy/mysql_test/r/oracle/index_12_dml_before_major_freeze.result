create table t1(c1 int primary key, c2 varchar(1024), c3 int, c4  timestamp(6) default "2012-01-01 12:00:00");
create index i1 on t1(c2) storing(c3,c4);
alter system major freeze tenant = sys;
alter system major freeze tenant = all_user;
alter system major freeze tenant = all_meta;
select /*+ index(t1 i1) */ c1,c2,c3,c4 from t1 where c2='a' and c3 > 1000 limit 5;
c1	c2	c3	c4
1001	a	1002	2013-12-10 01:01:01.000000
1002	a	1003	2013-12-10 01:01:01.000000
1003	a	1004	2013-12-10 01:01:01.000000
1004	a	1005	2013-12-10 01:01:01.000000
1005	a	1006	2013-12-10 01:01:01.000000
select /*+ index(t1 primary) */ c1,c2,c3,c4 from t1 where c1 > 1000 limit 6;
c1	c2	c3	c4
1001	a	1002	2013-12-10 01:01:01.000000
1002	a	1003	2013-12-10 01:01:01.000000
1003	a	1004	2013-12-10 01:01:01.000000
1004	a	1005	2013-12-10 01:01:01.000000
1005	a	1006	2013-12-10 01:01:01.000000
1006	a	1007	2013-12-10 01:01:01.000000
select count(*) from t1 where c3 > 3000;
count(*)
1000
select count(*) from t1 where c1 > 0;
count(*)
3000
drop table t1;
