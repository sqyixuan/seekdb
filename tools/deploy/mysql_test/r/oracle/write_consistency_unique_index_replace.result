create table test(pk int primary key, c1 int);
create unique index i1 on test(c1);
alter system major freeze tenant = sys;
alter system major freeze tenant = all_user;
alter system major freeze tenant = all_meta;
alter system major freeze tenant = sys;
alter system major freeze tenant = all_user;
alter system major freeze tenant = all_meta;
insert into test(pk, c1) values(0,1),(1,2);
select * from test;
pk	c1
0	1
1	2
set autocommit=0;
replace into test(pk, c1) values(0,3);
select * from test;
pk	c1
0	3
1	2
set autocommit=0;
set session ob_query_timeout=500000000;
replace into test(pk, c1) values(1,3);
select * from test;
pk	c1
0	3
1	2
commit;
select * from test;
pk	c1
1	3
commit;
select * from test;
pk	c1
1	3
select /*+index(test i1)*/ * from test;
pk	c1
1	3
commit;
replace into test(pk, c1) values(0,1),(1,2);
select * from test;
pk	c1
0	1
1	2
commit;
replace into test(pk, c1) values(0,3);
replace into test(pk, c1) values(0,4);
commit;
commit;
select * from test;
pk	c1
0	4
1	2
select /*+index(test i1)*/ * from test;
pk	c1
1	2
0	4
commit;
