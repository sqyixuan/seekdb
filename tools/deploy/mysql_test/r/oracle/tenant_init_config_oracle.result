create resource unit if not exists tenant_tt1_unit max_cpu=1,memory_size='2G';
create resource pool if not exists tenant_tt1_pool unit='tenant_tt1_unit', unit_num=1;
create tenant if not exists tt1 RESOURCE_POOL_LIST=('tenant_tt1_pool')
set ob_tcp_invited_nodes='%', ob_compatibility_mode='oracle';
name	value
_parallel_ddl_control	TRUNCATE_TABLE:ON, SET_COMMENT:ON, CREATE_INDEX:ON, DROP_TABLE:ON
name	value
_enable_ddl_worker_isolation	False
name	value
_enable_mysql_compatible_dates	True
name	value
_ob_immediate_row_conflict_check	False
