create table t1(c1 int primary key default 1 not null,
c2 int default 1 not null,
c3 int default 1,
c4 int);
create index i1 on t1(c2) storing(c3);
set autocommit=0;
select c1,c2,c3 from t1 where c2>0 and c2<100;
