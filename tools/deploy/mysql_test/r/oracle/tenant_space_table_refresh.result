drop tenant if exists t1 force;
drop resource pool if exists pool1;
drop resource unit if exists unit1;
CREATE RESOURCE UNIT unit1 max_cpu 1, max_memory '1G', max_iops 100000,max_disk_size '10G', max_session_num 64, MIN_CPU=1, MIN_MEMORY='1G', MIN_IOPS=128;
CREATE RESOURCE POOL pool1 unit='unit1', unit_num=1, zone_list=('zone1');
CREATE TENANT IF NOT EXISTS t1 charset='utf8mb4', primary_zone='zone1', resource_pool_list=('pool1') set ob_tcp_invited_nodes='%';
alter system set enable_sys_table_ddl = true;
drop view oceanbase.V$OB_MEMORY;
select * from oceanbase.V$OB_MEMORY limit 0;
ERROR 42S02: Table 'oceanbase.V$OB_MEMORY' doesn't exist
create view `oceanbase`.`V$OB_MEMORY` table_id = 21017 as                                       SELECT                                                           TENANT_ID, CONTEXT, COUNT, USED, ALLOC_COUNT, FREE_COUNT FROM                                                             oceanbase.GV$OB_MEMORY                                      WHERE                                                                IP=HOST_IP()                                             AND                                                              PORT=RPC_PORT()                                      ;
select * from oceanbase.V$OB_MEMORY limit 0;
TENANT_ID	CONTEXT	COUNT	USED	ALLOC_COUNT	FREE_COUNT
alter system set enable_sys_table_ddl = false;
drop tenant t1 force;
drop resource pool pool1;
drop resource unit unit1;
