drop table if exists session_timeout_table;
set timeout to 10s
set wait_timeout = 5;
create table session_timeout_table(c1 int primary key, c2 int);
insert into session_timeout_table values(1,1);
insert into session_timeout_table values(2,2);
insert into session_timeout_table values(3,3);
create 2 sessions
set interactive_timeout = 1;
interactive_timeout not effective
begin;
insert into session_timeout_table values(4,4);
insert into session_timeout_table values(5,5);
insert into session_timeout_table values(6,6);
commit;
select * from session_timeout_table;
