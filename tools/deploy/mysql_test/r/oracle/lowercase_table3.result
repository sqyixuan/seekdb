drop tenant if exists lower_case force;
drop resource pool if exists test_resource_pool1;
drop resource unit if exists test_resource_unit1;
create resource unit test_resource_unit1 max_cpu 1, max_memory 1073741824, max_iops 100000, max_disk_size 536870912, max_session_num 64, MIN_CPU=1, MIN_MEMORY=1073741824, MIN_IOPS=128;
CREATE TENANT lower_case REPLICA_NUM = 1, RESOURCE_POOL_LIST = ('test_resource_pool1') set lower_case_table_names = 0, ob_tcp_invited_nodes='%';
show variables like 'lower_case_table_names';
Variable_name	Value
lower_case_table_names	0
CREATE DATABASE if not exists test;
Warnings:
Note	1007	Can't create database 'test'; database exists
use test;
DROP TABLE IF EXISTS t1,T1;
CREATE TABLE t1 (a INT);
SELECT * FROM T1;
ERROR 42S02: Table 'test.T1' doesn't exist
SELECT * FROM t1;
a
DROP TABLE t1;
drop database test;
drop tenant if exists lower_case force;
drop resource pool if exists test_resource_pool1;
drop resource unit if exists test_resource_unit1;
