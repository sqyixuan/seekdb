drop database if exists db_for_pad;
create database db_for_pad;
use db_for_pad;
drop table if exists t1;
create table t1 (c1 binary(255));
insert into t1 values('a');
select length(c1) from t1;
length(c1)
255
select length(substr(c1,1,10)) from t1;
length(substr(c1,1,10))
10
drop table if exists t1;
drop table if exists t2;
CREATE TABLE t2(c1 BINARY(10) NOT NULL PRIMARY KEY);
INSERT INTO t2 (c1) VALUES('a'),('aaa'),('b'),('bb'),('bbb'),('c');
select length(c1) from t2;
length(c1)
10
10
10
10
10
10
drop table if exists t2;
drop table if exists t3;
create table t3 (s1 binary(3),id int primary key auto_increment);
insert into t3 (s1) values (0x61), (0x6120), (0x612020);
select hex(s1) from t3;
hex(s1)
610000
612000
612020
drop table if exists t3;
drop table if exists t4;
create table t4 (c1 char(20) primary key);
insert into t4 values('   xxx   ');
set @org_mode=@@sql_mode;
set sql_mode='pad_char_to_full_length';
select c1, length(c1) from t4 where c1 = '   xxx';
c1	length(c1)
   xxx              	20
set sql_mode='STRICT_ALL_TABLES';
select c1, length(c1) from t4 where c1 = '   xxx';
c1	length(c1)
   xxx	6
set @@sql_mode=@org_mode;
drop table if exists t4;
drop database if exists db_for_pad;
