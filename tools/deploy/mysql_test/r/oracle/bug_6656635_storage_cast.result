set ob_enable_index_direct_select=1;
alter system set merger_check_interval = '10s' tenant sys;
alter system set merger_check_interval = '10s' tenant all_user;
alter system set merger_check_interval = '10s' tenant all_meta;
drop table if exists table_obj_cast_int;
CREATE TABLE table_obj_cast_int (
c1 bigint unsigned
, c2 int unsigned
, c3 mediumint unsigned
, c4 smallint unsigned
, c5 tinyint unsigned
, pk int
, PRIMARY KEY(pk)
);
insert into table_obj_cast_int values
(0xffffffffffffffff, 0xffffffff, 0xffffff, 0xffff, 0xff, 1),
