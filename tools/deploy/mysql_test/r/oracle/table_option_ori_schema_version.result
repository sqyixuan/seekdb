drop database if exists jx_db;
create database jx_db;
use jx_db;
create table t1(c1 int primary key, c2 int);
alter table t1 add column c3 int;
create table t2(c1 int primary key, c2 int, index idx(c2));
alter table t2 add column c3 int;
create table t3(c1 int primary key, c2 int, c3 varchar(50), index idx(c2), unique index(c3));
alter table t3 add column c4 int;
create table t4(c1 int primary key, c2 int, c3 varchar(50), index idx(c2), unique index(c3(10)));
alter table t4 add column c4 int;
create table t5(c1 int primary key, c2 int, c3 varchar(50), index idx(c2) global, unique index(c3(10)) global);
alter table t5 add column c4 int;
create table t6(c1 int primary key, c2 int, c3 varchar(50));
alter table t6 add index idx(c2);
verify ori_schema_version of data table
verify ori_schema_version of index table
create table t7(c1 int primary key, c2 int, c3 varchar(50), index idx(c2));
truncate table t7;
alter table t7 drop column c3;
create table like_t7 like t7;
alter table like_t7 add column c3 char(10);
drop database jx_db;
