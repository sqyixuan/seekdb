-1	2	2	f
-1	3	3	g
update t1 set pk1=-1 where (pk2,i1) in ((1,1),(1,2),(5,5),(3,3)) order by i1 asc limit 2;
select * from t1;
pk1	pk2	i1	v1
-2	4	4	4
-2	5	5	4
-1	1	1	e
-1	2	2	f
-1	3	3	g
update t1 set pk1=pk2+1,pk2=pk1+1 where (pk1,i1) in ((1,1),(1,2),(2,2),(2,3)) limit 2;
update t1 set i1=i1+1-1 where (pk2,i1) in ((1,1),(1,2),(2,2),(2,3)) limit 2;
select * from t1;
pk1	pk2	i1	v1
-2	4	4	4
-2	5	5	4
