drop table if exists t1;
create table t1 (pk1 int,pk2 int, i1 int, v1 varchar(20),primary key(pk1,pk2));
insert into t1 values(1,1,1,'a'),(2,2,2,'b'),(3,3,3,'c'),(4,4,4,'d'),(5,5,5,'e');
update t1 set pk1=4 where pk1=1;
update t1 set pk1=6,v1='d' where pk1=3;
select * from t1;
pk1	pk2	i1	v1
2	2	2	b
4	1	1	a
4	4	4	d
5	5	5	e
6	3	3	d
update t1 set pk1=4 where pk1<15 limit 2;
select * from t1;
pk1	pk2	i1	v1
4	1	1	a
4	2	2	b
4	4	4	d
5	5	5	e
6	3	3	d
update t1 set pk1=8 where pk1<15 order by pk2 asc  limit 2;
select * from t1;
pk1	pk2	i1	v1
4	4	4	d
5	5	5	e
6	3	3	d
8	1	1	a
8	2	2	b
update t1 set pk1=7 where pk1<15 order by pk2 limit 2,1;
select * from t1;
pk1	pk2	i1	v1
4	4	4	d
5	5	5	e
7	3	3	d
8	1	1	a
8	2	2	b
update t1 set pk1=6,v1='d' where pk1=3 limit 0;
select * from t1;
pk1	pk2	i1	v1
4	4	4	d
5	5	5	e
7	3	3	d
8	1	1	a
8	2	2	b
update t1 set v1=4 where pk1<15 limit 2;
select * from t1;
pk1	pk2	i1	v1
4	4	4	4
5	5	5	4
7	3	3	d
8	1	1	a
8	2	2	b
update t1 set v1=8 where pk1<15 order by pk2 asc  limit 2;
select * from t1;
pk1	pk2	i1	v1
4	4	4	4
5	5	5	4
7	3	3	d
8	1	1	8
8	2	2	8
update t1 set v1=7 where pk1<15 order by pk2 limit 2,1;
select * from t1;
pk1	pk2	i1	v1
4	4	4	4
5	5	5	4
7	3	3	7
8	1	1	8
8	2	2	8
update t1 set pk1=6,v1='d' where pk1=3 limit 0;
select * from t1;
pk1	pk2	i1	v1
4	4	4	4
5	5	5	4
7	3	3	7
8	1	1	8
8	2	2	8
alter system major freeze tenant = sys;
alter system major freeze tenant = all_user;
alter system major freeze tenant = all_meta;
update t1 set pk1=1 where pk1<=4 limit 1;
select * from t1;
pk1	pk2	i1	v1
1	4	4	4
5	5	5	4
7	3	3	7
8	1	1	8
8	2	2	8
update t1 set pk1=3 where pk1>=6 limit 2;
select * from t1;
pk1	pk2	i1	v1
1	4	4	4
3	1	1	8
3	3	3	7
5	5	5	4
8	2	2	8
update t1 set pk1=-1 where (pk2,i1) in ((4,1),(5,2),(6,3),(2,3)) order by i1 limit 5;
select * from t1;
pk1	pk2	i1	v1
1	4	4	4
3	1	1	8
3	3	3	7
5	5	5	4
8	2	2	8
update t1 set pk1=-1 where (pk2,i1) in ((1,1),(1,2),(2,2),(3,3)) order by pk2  asc limit 5;
select * from t1;
pk1	pk2	i1	v1
-1	1	1	8
-1	2	2	8
-1	3	3	7
1	4	4	4
5	5	5	4
update t1 set pk1=-1 where (pk2,i1) in ((1,1),(1,2),(2,2),(3,3)) order by i1 asc limit 2;
select * from t1;
pk1	pk2	i1	v1
-1	1	1	8
-1	2	2	8
-1	3	3	7
1	4	4	4
5	5	5	4
update t1 set pk1=-2 where (pk2,i1) in ((4,4),(4,5),(5,5),(6,6)) order by i1 desc limit 2;
select * from t1;
pk1	pk2	i1	v1
-2	4	4	4
-2	5	5	4
-1	1	1	8
-1	2	2	8
-1	3	3	7
update t1 set pk1=4,v1='e' where pk2=1;
update t1 set pk1=5,v1='f' where pk2=2;
update t1 set pk1=6,v1='g' where pk2=3;
update t1 set pk1=-1 where (pk2,i1) in ((1,1),(1,2),(2,2),(3,3)) order by pk2  asc limit 5;
