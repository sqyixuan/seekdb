drop table if exists t1,t2,t3,tnull;
create table t1(a int primary key, b int, c int);
create table t2 (a double primary key, b double, c double);
create table t3(a varchar(10) primary key, b varchar(10), c varchar(10));
create table tnull(a int primary key, b int, c int);
alter system major freeze tenant = sys;
alter system major freeze tenant = all_user;
alter system major freeze tenant = all_meta;
explain_protocol: 2
result_format: 4
EXPLAIN select 1 union select 2 union select 3;
Query Plan
==============================================
|ID|OPERATOR             |NAME|EST. ROWS|COST|
----------------------------------------------
|0 |MERGE UNION DISTINCT |    |3        |3   |
|1 | MERGE UNION DISTINCT|    |2        |1   |
|2 |  EXPRESSION         |    |1        |1   |
|3 |  EXPRESSION         |    |1        |1   |
|4 | EXPRESSION          |    |1        |1   |
==============================================

Outputs & filters: 
-------------------------------------
  0 - output([UNION(UNION(1, 2), 3)]), filter(nil)
  1 - output([UNION(1, 2)]), filter(nil)
  2 - output([1]), filter(nil)
      values({1})
  3 - output([2]), filter(nil)
      values({2})
  4 - output([3]), filter(nil)
      values({3})

select 1 union select 2 union select 3;
