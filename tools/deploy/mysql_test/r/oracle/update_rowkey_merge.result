drop table if exists t1;
create table t1 (pk1 int,pk2 int, i1 int, v1 varchar(20),primary key(pk1,pk2));
insert into t1 values(1,1,1,'a'),(2,2,2,'b'),(3,3,3,'c'),(4,4,4,'d'),(5,5,5,'e');
update t1 set pk1=4 where pk1=1;
update t1 set pk1=6,v1='d' where pk1=3;
select * from t1;
pk1	pk2	i1	v1
2	2	2	b
4	1	1	a
4	4	4	d
5	5	5	e
6	3	3	d
alter system major freeze tenant = sys;
alter system major freeze tenant = all_user;
alter system major freeze tenant = all_meta;
update t1 set pk1=1 where pk1=4;
update t1 set pk1=3 where pk1=6;
update t1 set pk1=-1 where (pk2,i1) in ((4,1),(5,2),(6,3),(2,3));
update t1 set pk1=-1 where (pk2,i1) in ((1,1),(1,2),(2,2),(2,3));
update t1 set pk1=-2 where (pk2,i1) in ((4,4),(4,5),(5,5),(5,6));
select * from t1;
pk1	pk2	i1	v1
-2	4	4	d
-2	5	5	e
-1	1	1	a
-1	2	2	b
3	3	3	d
update t1 set pk1=4,v1='e' where pk1=1;
update t1 set pk1=5,v1='f' where pk1=2;
update t1 set pk1=6,v1='g' where pk1=3;
update t1 set pk2=-1 where (pk1,i1) in ((1,1),(1,2),(2,2),(2,3));
update t1 set pk2=-1 where (pk1,i1) in ((-2,1),(1,2),(-2,2),(5,5));
select * from t1;
pk1	pk2	i1	v1
-2	4	4	d
-2	5	5	e
-1	1	1	a
-1	2	2	b
6	3	3	g
alter system major freeze tenant = sys;
alter system major freeze tenant = all_user;
alter system major freeze tenant = all_meta;
insert into t1 values(1,1,1,'a'),(2,2,2,'b'),(3,3,3,'c'),(4,4,4,'d'),(5,5,5,'e');
update t1 set pk1=-2 where (pk1,pk2,i1) in ((2,2,2),(1,1,1),(2,2,3),(1,1,2),(3,3,3),(3,3,4),(4,4,5),(5,5,6));
select * from t1;
pk1	pk2	i1	v1
-2	1	1	a
-2	2	2	b
-2	3	3	c
-2	4	4	d
-2	5	5	e
-1	1	1	a
-1	2	2	b
4	4	4	d
5	5	5	e
6	3	3	g
