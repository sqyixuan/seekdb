drop table if exists ttl;
create table ttl(i1 int, v2 varchar(80), i3 char(20),i4 float, d4 datetime(6),i5 decimal(5,3), primary key(i1));
create index ttlidx_1 on ttl(i1);
create index ttlidx_2 on ttl(v2);
alter system major freeze tenant = sys;
alter system major freeze tenant = all_user;
alter system major freeze tenant = all_meta;
