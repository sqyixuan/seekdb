create table obtabletest (a varchar(10), b varchar(10));
create package obpackagetest as
declare type tab_type is table of varchar(10);
declare v_tab tab_type;
procedure p();
end;//
create package body obpackagetest as
procedure p() is
begin
do v_tab.extend;
set v_tab(1) = 'test1';
do v_tab.extend;
set v_tab(2) = 'test2';
insert into obtabletest values(v_tab(1), v_tab(2));
end;
end;//
call obpackagetest.p();
select * from obtabletest;
+-------+-------+
| a     | b     |
+-------+-------+
| test1 | test2 |
+-------+-------+
drop table obtabletest;
drop package obpackagetest;

create table obtabletest (a varchar(10), b varchar(10));
create package obpackagetest as
declare tab_idx integer;
declare type tab_type is table of varchar(10);
declare v_tab tab_type;
procedure p();
end;//
create package body obpackagetest as
procedure p() is
begin
do v_tab.extend;
set tab_idx = 1;
set v_tab(tab_idx) = 'test1';
set tab_idx = 2;
do v_tab.extend;
set v_tab(tab_idx) = 'test2';
insert into obtabletest values(v_tab(tab_idx), v_tab(tab_idx));
end;
end;//
call obpackagetest.p();
select * from obtabletest;
+-------+-------+
| a     | b     |
+-------+-------+
| test2 | test2 |
+-------+-------+
drop table obtabletest;
drop package obpackagetest;

