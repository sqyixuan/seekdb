create table a(a1 bigint);
insert into a values(1);
insert into a values(2);
create table b(b1 bigint);
create package obpackagetest as
declare type tab_type is table of bigint;
declare v_tab tab_type;
end;//
do
begin
declare c cursor for select a1 from a;
open c;
fetch c bulk collect into obpackagetest.v_tab limit 1000;
insert into b values(obpackagetest.v_tab(1));
insert into b values(obpackagetest.v_tab(2));
close c;
end//
select * from b;
+------+
| b1   |
+------+
|    1 |
|    2 |
+------+
drop table a;
drop table b;
drop package obpackagetest;

create table a(a1 decimal(6,2));
insert into a values(1000.23);
insert into a values(1001.23);
create table b(b1 decimal(6,2));
create package obpackagetest as
declare type tab_type is table of decimal(6,2);
declare v_tab tab_type;
end;//
do
begin
declare c cursor for select a1 from a;
open c;
fetch c bulk collect into obpackagetest.v_tab limit 1000;
insert into b values(obpackagetest.v_tab(1));
insert into b values(obpackagetest.v_tab(2));
close c;
end//
select * from b;
+---------+
| b1      |
+---------+
| 1000.23 |
| 1001.23 |
+---------+
drop table a;
drop table b;
drop package obpackagetest;

create table obtabletest (a decimal(6,2), b varchar(10));
insert into obtabletest values(1000.23, 'test1'), (1001.23, 'test2');
create package obpackagetest as
declare type typ_rec is record (x decimal(6,2), y varchar(10));
declare type tab_type is table of typ_rec;
declare v_tab tab_type;
end;//
do
begin
declare c cursor for select a, b from obtabletest;
open c;
fetch c bulk collect into obpackagetest.v_tab limit 1000;
insert into obtabletest values(obpackagetest.v_tab(1).x, obpackagetest.v_tab(1).y);
insert into obtabletest values(obpackagetest.v_tab(2).x, obpackagetest.v_tab(2).y);
close c;
end;//
select * from obtabletest;
+---------+-------+
| a       | b     |
+---------+-------+
| 1000.23 | test1 |
| 1001.23 | test2 |
| 1000.23 | test1 |
| 1001.23 | test2 |
+---------+-------+
drop table obtabletest;
drop package obpackagetest;

create table obtabletest (a varchar(10), b int);
create package obpackagetest as
declare type typ_rec is record (x varchar(10), y int);
end;//
do
begin
declare res obpackagetest.typ_rec;
set res.x = 'test1';
set res.y = 1;
insert into obtabletest values(res.x, res.y);
end;//
select * from obtabletest;
+-------+------+
| a     | b    |
+-------+------+
| test1 |    1 |
+-------+------+
drop table obtabletest;
drop package obpackagetest;

create table obtabletest (a varchar(10), b varchar(10));
create package obpackagetest as
declare type tab_type is table of varchar(10);
end;//
do
begin
declare v_tab obpackagetest.tab_type;
do v_tab.extend;
set v_tab(1) = 'test1';
do v_tab.extend;
set v_tab(2) = 'test2';
insert into obtabletest values(v_tab(1), v_tab(2));
end;//
select * from obtabletest;
+-------+-------+
| a     | b     |
+-------+-------+
| test1 | test2 |
+-------+-------+
drop table obtabletest;
drop package obpackagetest;

create table obtabletest (a varchar(10));
create package obpackagetest as
declare x varchar(10);
end;//
create package body obpackagetest as
begin
set x = 'test';
end;//
do
begin
insert into obtabletest values(obpackagetest.x);
end;//
select * from obtabletest;
+------+
| a    |
+------+
| test |
+------+
drop table obtabletest;
drop package obpackagetest;

drop tenant if exists tt1 force;
drop resource pool if exists test_resource_pool1;
