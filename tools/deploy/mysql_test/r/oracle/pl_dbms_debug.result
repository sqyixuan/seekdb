use test;

set @@ob_query_timeout=1000000000;


DROP PACKAGE DBMS_DEBUG ;//
ERROR 42000: PACKAGE 'test.DBMS_DEBUG' does not exist
CREATE PACKAGE DBMS_DEBUG AS

    DECLARE retry_on_timeout INTEGER DEFAULT 0;
    DECLARE continue_on_timeout INTEGER DEFAULT 1;
    DECLARE nodebug_on_timeout INTEGER DEFAULT 2;
    DECLARE abort_on_timeout INTEGER DEFAULT 3;

    DECLARE default_timeout INTEGER DEFAULT 3600;

    PROCEDURE probe_version(OUT major INTEGER,
                            OUT minor INTEGER);

    PROCEDURE set_timeout(INOUT timeout INTEGER);

    PROCEDURE initialize(INOUT debug_session_id VARCHAR(1024),
                         IN diagnostices INTEGER,
                         IN debug_role VARCHAR(1024),
                         IN debug_role_pwd VARCHAR(1024));

    PROCEDURE debug_on(IN no_client_side_plsql_engine BOOLEAN,
                       IN immediate_ BOOLEAN);

    PROCEDURE debug_off();

    PROCEDURE set_timeout_behaviour(IN behaviour_ INTEGER);

    PROCEDURE get_timeout_behaviour(OUT behaviour_ INTEGER);

    PROCEDURE attach_session(IN debug_session_id VARCHAR(1024),
                             IN diagnostices INTEGER);

    PROCEDURE print_backtrace(INOUT listing VARCHAR(1024));

    PROCEDURE continue_target(IN breakflags INTEGER,
                              IN info_requested INTEGER,
                              OUT status INTEGER);

    PROCEDURE set_breakpoint(IN func_name VARCHAR(1024),
                             IN line_ INTEGER,
                             OUT breakpoint INTEGER,
                             IN fuzzy INTEGER,
                             IN iterations INTEGER,
                             OUT status INTEGER);

    PROCEDURE delete_breakpoint(IN breakpoint INTEGER,
                                OUT status INTEGER);

    PROCEDURE disable_breakpoint(IN breakpoint INTEGER,
                                 OUT status INTEGER);

    PROCEDURE enable_breakpoint(IN breakpoint INT,
                                OUT status INTEGER);

    PROCEDURE show_breakpoints(INOUT listing VARCHAR(1024));

    PROCEDURE get_value(IN variable_name VARCHAR(1024),
                        IN frame_ INT,
                        OUT scalar_value VARCHAR(1024),
                        IN format_ VARCHAR(1024));

    PROCEDURE detach_session();
END ;//

CREATE PACKAGE BODY DBMS_DEBUG IS

    DECLARE VERSION_MAJOR INTEGER DEFAULT 1;
    DECLARE VERSION_MINOR INTEGER DEFAULT 0;

    DECLARE timeout_behaviour INTEGER DEFAULT 0;

    PROCEDURE probe_version(OUT major INTEGER,
                            OUT minor INTEGER)
    IS
    BEGIN
        SET major = VERSION_MAJOR;
        SET minor = VERSION_MINOR;
    END;

    PROCEDURE set_timeout(INOUT timeout INTEGER)
    IS
    BEGIN
        DECLARE ret INTEGER DEFAULT 0;
        IF (TIMEOUT = 0) THEN
            SET default_timeout = 3600;
        ELSE
            SET default_timeout = timeout;
        END IF;
        SET ret = pdb_set_timeout(default_timeout);
    END;

    PROCEDURE initialize(INOUT debug_session_id VARCHAR(1024),
                         IN diagnostices INTEGER,
                         IN debug_role VARCHAR(1024),
                         IN debug_role_pwd VARCHAR(1024))
    IS
    BEGIN
        DECLARE id BIGINT;
        SET id = pdb_initialize();
        SET debug_session_id = id;
    END;

    PROCEDURE debug_on(IN no_client_side_plsql_engine BOOLEAN,
                       IN immediate_ BOOLEAN)
    IS
    BEGIN
        DECLARE ret INTEGER;
        SET ret = pdb_debug_on();
    END;

    PROCEDURE debug_off()
    IS
    BEGIN
        DECLARE ret INTEGER;
        SET ret = pdb_debug_off();
    END;

    PROCEDURE set_timeout_behaviour(IN behaviour_ INTEGER)
    IS
    BEGIN
        DECLARE unimplemented CONDITION FOR SQLSTATE '1112';
        DECLARE ret INTEGER;
        IF (behaviour_ < retry_on_timeout) OR (behaviour_ > abort_on_timeout) THEN
            SIGNAL unimplemented;
        END IF;
        SET timeout_behaviour = behaviour_;
        SET ret = pdb_set_timeout_behaviour(timeout_behaviour);
    END;

    PROCEDURE get_timeout_behaviour(OUT behaviour_ INTEGER)
    IS
    BEGIN
        SET behaviour_ = timeout_behaviour;
    END;

    PROCEDURE attach_session(IN debug_session_id VARCHAR(1024),
                             IN diagnostices INTEGER)
    IS
    BEGIN
        DECLARE ret INTEGER;
        DECLARE debug_id INTEGER;
        SET debug_id = debug_session_id;
        SET ret = pdb_attach_session(debug_id);
    END;

    PROCEDURE print_backtrace(INOUT listing VARCHAR(1024))
    IS
    BEGIN
        SET listing = pdb_print_backtrace();
    END;

    PROCEDURE continue_target(IN breakflags INTEGER,
                       IN info_requested INTEGER,
                       OUT status INTEGER)
    IS
    BEGIN
        DECLARE ret INTEGER;
        SET status = 0;
        SET ret = pdb_continue(breakflags);
    END;

    PROCEDURE set_breakpoint(IN func_name VARCHAR(1024),
                             IN line_ INTEGER,
                             OUT breakpoint INTEGER,
                             IN fuzzy INTEGER,
                             IN iterations INTEGER,
                             OUT status INTEGER)
    IS
    BEGIN
        SET status = 0;
        SET breakpoint = pdb_set_breakpoint(func_name, line_);
    END;

    PROCEDURE delete_breakpoint(IN breakpoint INTEGER,
                                OUT status INTEGER)
    IS
    BEGIN
        SET status = pdb_delete_breakpoint(breakpoint);
    END;

    PROCEDURE disable_breakpoint(IN breakpoint INTEGER,
                                 OUT status INTEGER)
    IS
    BEGIN
        SET status = pdb_disable_breakpoint(breakpoint);
    END;

    PROCEDURE enable_breakpoint(IN breakpoint INT,
                                OUT status INTEGER)
    IS
    BEGIN
        SET status = pdb_enable_breakpoint(breakpoint);
    END;

    PROCEDURE show_breakpoints(INOUT listing VARCHAR(1024))
    IS
    BEGIN
        SET listing = pdb_show_breakpoints();
    END;

    PROCEDURE get_value(IN variable_name VARCHAR(1024),
                        IN frame_ INT,
                        OUT scalar_value VARCHAR(1024),
                        IN format_ VARCHAR(1024))
    IS
    BEGIN
        SET scalar_value = pdb_get_value(variable_name, frame_);
    END;

    PROCEDURE detach_session()
    IS
    BEGIN
        DECLARE ret INTEGER;
        SET ret = pdb_detach_session();
    END;
END DBMS_DEBUG ;//


DROP PACKAGE DBMS_DEBUG;

