    WHEN 3 THEN SET str="3";
    WHEN 4 THEN SET str="4";
    WHEN 5 THEN SET str="5";
    WHEN 6 THEN SET str="6";
    WHEN 7 THEN SET str="7";
    WHEN 8 THEN SET str="8";
    WHEN 9 THEN SET str="9";
    WHEN 10 THEN SET str="10";
    ELSE SET str="unknown";
  END CASE;
  SELECT str;
END
