create procedure p1()
begin
  drop table if exists t1;
  create table t1 (id integer not null primary key,
                   name varchar(20) not null);
  insert into t1 (id, name) values (1, 'aaa'), (2, 'bbb'), (3, 'ccc');
  prepare stmt_sel_1 from "select name from t1";
  execute stmt_sel_1;
  select name from t1;
  execute stmt_sel_1;
  prepare stmt_sel_2 from
    "select name from t1 where name=(select name from t1 where id=2)";
  execute stmt_sel_2;
  select name from t1 where name=(select name from t1 where id=2);
  execute stmt_sel_2;
  deallocate prepare stmt_sel_1;
  deallocate prepare stmt_sel_2;
end|
