test update whether support use alias table
update t1 tt set tt.b=1 where tt.a=1;
select * from t1;
a	b
1	1
2	0
update t1 as tt set tt.b=2 where tt.a=1;
select * from t1;
a	b
1	2
2	0
update t1 tt set b=3 where a=1;
select * from t1;
a	b
1	3
2	0
update t1 tt set b=4 where a=1;
select * from t1;
a	b
