create table t1(pk int primary key, a int, b int, c varchar(1024));
create index i1 on t1(b) storing(c);
alter system major freeze tenant = sys;
alter system major freeze tenant = all_user;
alter system major freeze tenant = all_meta;
set autocommit=0;
select * from t1 where pk=10 for update;
pk	a	b	c
set autocommit=0;
select * from t1 where pk=10 for update;
pk	a	b	c
commit;
commit;
