CREATE PROCEDURE p(a bigint, sum bigint)
BEGIN
label1: LOOP
begin
declare b bigint;
set b=a+1;
IF a+b > sum THEN
LEAVE label1;
else
set a=b;
END IF;
end;
END LOOP label1;
END//
call p(1,1000000);
drop procedure p;

CREATE PROCEDURE p(a bigint)
BEGIN
label1: Repeat
begin
declare b bigint;
SET b = a + 1;
end;
UNTIL a<10
END repeat label1;
END//
