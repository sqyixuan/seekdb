show parameters where svr_ip = (select svr_ip from oceanbase.__all_virtual_processlist limit 1) and name = 'default_compress_func';
zone	svr_type	svr_ip	svr_port	name	data_type	value	value_strict	info	need_reboot	section	visible_level
zone1	observer	server_ip	server_port	default_compress_func	NULL	lz4_1.0	NULL	default compress function name for create new table	0	observer	
CREATE TABLE compress_table (c1 int primary key, c2 varchar(500), c3 float, index i1 (c1), index i2 (c2), unique index i2_u (c2));
show create table compress_table;
Table	Create Table
compress_table	CREATE TABLE `compress_table` (
  `c1` int(11) NOT NULL,
  `c2` varchar(500) DEFAULT NULL,
  `c3` float DEFAULT NULL,
  PRIMARY KEY (`c1`),
  UNIQUE KEY `i2_u` (`c2`) BLOCK_SIZE 16384,
  KEY `i1` (`c1`) BLOCK_SIZE 16384,
  KEY `i2` (`c2`) BLOCK_SIZE 16384
) DEFAULT CHARSET = utf8mb4 COMPRESSION = 'lz4_1.0' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 10
