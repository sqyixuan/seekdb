drop database if exists hualong;
create database hualong;
use hualong;
create table t_abc (a int primary key, b int, c int, index idx_b(b), unique idx_c(c));
insert into t_abc values (1, 1, 10), (11, 1, 100), (111, 1, 1000), (2, 2, 20), (22, 2, 200), (222, 2, 2000), (3, NULL, NULL), (33, NULL, NULL), (333, NULL, NULL);
create table t_xyz (x int primary key, y int, z int, index idx_y(y), unique idx_z(z));
insert into t_xyz values (1, 1, 10), (11, 1, 100), (111, 1, 1000), (2, 2, 20), (22, 2, 200), (222, 2, 2000), (3, NULL, NULL), (33, NULL, NULL), (333, NULL, NULL);
create table t_ccc (c1 int primary key, c2 int, c3 int, index idx_c2(c2), unique idx_c3(c3));
explain select * from t_abc where a in (select x + 1 from t_xyz where a = 100);
Query Plan
=========================================
|ID|OPERATOR       |NAME |EST. ROWS|COST|
-----------------------------------------
|0 |MERGE SEMI JOIN|     |1        |91  |
|1 | TABLE GET     |t_abc|1        |53  |
|2 | TABLE SCAN    |t_xyz|1        |38  |
=========================================

Outputs & filters: 
-------------------------------------
  0 - output([t_abc.a], [t_abc.b], [t_abc.c]), filter(nil), 
      equal_conds([t_abc.a = t_xyz.x + 1]), other_conds(nil)
  1 - output([t_abc.a], [t_abc.b], [t_abc.c]), filter(nil), 
      access([t_abc.a], [t_abc.b], [t_abc.c]), partitions(p0)
  2 - output([t_xyz.x + 1]), filter([t_xyz.x + 1 = 100]), 
      access([t_xyz.x]), partitions(p0)

