drop table if exists mytest;
create table mytest(id int primary key, name varchar(2048));
create index idx_mytest on mytest(name);
insert into mytest values(1, "overhang");
alter system major freeze tenant = sys;
alter system major freeze tenant = all_user;
alter system major freeze tenant = all_meta;
update mytest set name='overhang ' where id=1;
select * from mytest;
id	name
1	overhang 
select length(name) from mytest;
length(name)
9
select /*+ index(mytest idx_mytest) */ length(name) from mytest;
length(name)
9
