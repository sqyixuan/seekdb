update ob_all_proxy_kv_table set value='upgrade_off' where name='{0}';
update ob_all_proxy set hot_upgrade_cmd = 'commit' where proxy_port=0 and proxy_ip=1;
update ob_all_proxy_kv_table set value=value+1 where name='ob_proxy_vip_tenant_version';
update ob_all_proxy set hot_upgrade_cmd = 'exit' where  proxy_port=0 and proxy_ip = 1;
alter system set cluster_id=1;
create resource unit if not exists  obschema min_memory = '1024M',max_memory = '1025M', max_cpu  1,  MAX_DISK_SIZE='5G', MAX_IOPS=10000, MAX_SESSION_NUM=92233;
create resource unit if not exists  obschema2 min_memory = '1024M',max_memory = '1025M', max_cpu  1,  MAX_DISK_SIZE='5G', MAX_IOPS=10000, MAX_SESSION_NUM=92233;
create resource pool if not exists pool_1 unit ='obschema' ,unit_num = 1;
create tenant if not exists ten_1 RESOURCE_POOL_LIST= ('pool_1') set ob_tcp_invited_nodes='%';
alter resource pool pool_1  unit='obschema2';
alter resource pool pool_1 unit_num=2;
alter system set cluster_id=1;
alter user 'root' identified by 'abcd';
alter user 'root' identified by '';
alter tenant ten_1 lock;
alter tenant ten_1 unlock;
alter system upgrade virtual schema;
