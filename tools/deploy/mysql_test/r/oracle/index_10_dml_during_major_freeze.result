create table t1(c1 int primary key, c2 varchar(1024), c3 int, c4  timestamp(6) default "2012-01-01 12:00:00");
create index i1 on t1(c3) storing(c2);
alter system major freeze tenant = sys;
alter system major freeze tenant = all_user;
alter system major freeze tenant = all_meta;
select /*+ index(t1 i1) */ * from t1 where c3>=2 limit 5;
c1	c2	c3	c4
1	b	2	2013-12-10 00:00:00.000000
2	b	3	2013-12-10 00:00:00.000000
3	b	4	2013-12-10 00:00:00.000000
4	b	5	2013-12-10 00:00:00.000000
5	b	6	2013-12-10 00:00:00.000000
select /*+ index(t1 primary) */ * from t1 where c3>=2 limit 5;
c1	c2	c3	c4
1	b	2	2013-12-10 00:00:00.000000
2	b	3	2013-12-10 00:00:00.000000
3	b	4	2013-12-10 00:00:00.000000
4	b	5	2013-12-10 00:00:00.000000
5	b	6	2013-12-10 00:00:00.000000
create index i2 on t1(c3) storing(c4);
alter system major freeze tenant = sys;
alter system major freeze tenant = all_user;
alter system major freeze tenant = all_meta;
select /*+ index(t1 i2) */ c1,c3,c4 from t1 where c3 > 1000 limit 5;
