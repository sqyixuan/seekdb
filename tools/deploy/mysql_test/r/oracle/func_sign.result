insert into t1(a1 , a2) values('CC2' , sign(-0.1) ) when row_count( insert into t1(a1, a2) values('CCC' , sign(0.1) ) ) = 1;
insert into t1(a1 , a2) values('CC4', sign(null) ) when row_count( replace into t1(a1, a2) values('CC3' , sign(-0.1) ) ) = 1;
replace into t1(a1 , a2) values('CC5', sign('-1.1') ) when row_count( update t1 set a2 = 20 + sign(a2) where a1 = 'CCC' ) = 1;
update t1 set a2 = 30 * sign(a2) where a1 = 'CC2' when row_count( replace into t1(a1, a2) values('CC6' , sign(-0.1) ) ) = 1;
update t1 set a2 = 50 / sign(a2) where a1 = 'CC2' when row_count( update t1 set a2 = sign(a2) % 98 where a1 = 'CC3' ) = 1;
