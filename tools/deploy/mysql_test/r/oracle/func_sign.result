drop table if exists t1,t2;
alter system set merge_delay_interval='1s' server_type=chunkserver;
alter system set merge_delay_for_lsync='1s' server_type=chunkserver;
alter system set min_major_freeze_interval='1s' server_type=updateserver;
alter system set check_async_task_interval='5s' server_type=rootserver;
alter system set check_tablet_available_interval='2s' server_type=chunkserver;
alter system set write_delay_after_drop_index = '1s' server_type=rootserver;
alter system set read_delay_after_drop_index = '1s' server_type=rootserver;
alter system set build_global_index_time='60s' server_type=rootserver;
alter system set build_sample_time='60s' server_type=rootserver;
alter system set write_delay_after_create_index = '1s' server_type=rootserver;
create table t1(
a1 char(3) primary key,
a2 int,
a3 char(3),
a4 float,
a5 datetime
);
