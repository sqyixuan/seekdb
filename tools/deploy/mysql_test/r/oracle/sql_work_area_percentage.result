create resource unit test_unit max_cpu 4, max_memory '1G', max_iops=100000, max_disk_size=536870912, MAX_SESSION_NUM=64;
create tenant test_tenant resource_pool_list=('test_pool') set ob_tcp_invited_nodes='%';
