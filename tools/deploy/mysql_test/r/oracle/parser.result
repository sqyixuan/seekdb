set @bar="bar";
set @foobar="foobar";
select instr("foobar", "bar");
+------------------------+
| instr("foobar", "bar") |
+------------------------+
|                      4 |
+------------------------+
select instr("foobar" "p1", "bar");
+-----------------------------+
| instr("foobar" "p1", "bar") |
+-----------------------------+
|                           4 |
+-----------------------------+
select instr("foobar", "bar" "p2");
+-----------------------------+
| instr("foobar", "bar" "p2") |
+-----------------------------+
|                           0 |
+-----------------------------+
