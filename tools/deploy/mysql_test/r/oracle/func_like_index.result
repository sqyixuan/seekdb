drop table if exists t1;
create table t1 (a varchar(50) primary key,b int default 0,index idx(a))  ;
insert into t1(a) values('abcdef');
insert into t1(a) values('_bcdef');
insert into t1(a) values('a_cdef');
insert into t1(a) values('ab_def');
insert into t1(a) values('abc_ef');
insert into t1(a) values('abcd_f');
insert into t1(a) values('abcde_');
select a as c1u from t1 where a like 'ab\_def';
c1u
ab_def
select a as c2h from t1 where a like 'ab#_def' escape '#';
c2h
ab_def
