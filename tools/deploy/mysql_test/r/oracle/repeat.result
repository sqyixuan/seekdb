drop table if exists t2;
CREATE TABLE t2 (a int  primary key not null, b varchar(256)) ;
iNSERT INTO t2 VALUES (0,REPEAT('a', 1024));
ERROR 22001: Data too long for column 'b' at row 1
iNSERT INTO t2 VALUES (2,REPEAT('a', 256));
select length(b),a from t2;
length(b)	a
256	2
insert into t2 values (1, concat(repeat('1', 200), '2'));
select length(b),a from t2;
length(b)	a
201	1
256	2
select length(repeat(b,a)) as abc from t2;
abc
201
512
select length(repeat(b,a)) as abc from t2 order by abc;
abc
201
512
