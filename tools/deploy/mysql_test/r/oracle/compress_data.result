drop database if exists db_create;
create database db_create;
use db_create;
CREATE TABLE compress_table (c1 int primary key, c2 varchar(500), c3 float, index i1 (c1), index i2 (c2), unique index i2_u (c2)) COMPRESSION = 'NONE';
SHOW CREATE TABLE compress_table;
Table	Create Table
compress_table	CREATE TABLE `compress_table` (
  `c1` int(11) NOT NULL,
  `c2` varchar(500) DEFAULT NULL,
  `c3` float DEFAULT NULL,
  PRIMARY KEY (`c1`),
  UNIQUE KEY `i2_u` (`c2`) BLOCK_SIZE 16384,
  KEY `i1` (`c1`) BLOCK_SIZE 16384,
  KEY `i2` (`c2`) BLOCK_SIZE 16384
) DEFAULT CHARSET = utf8mb4 REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 10
