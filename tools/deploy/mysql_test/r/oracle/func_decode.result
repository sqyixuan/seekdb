select decode();
ERROR 42000: You have an error in your SQL syntax; check the manual that corresponds to your OceanBase version for the right syntax to use near ')' at line 1
select decode(1);
ERROR 42000: DECODE() function need more one argument
select decode(1, 1);
ERROR 42000: DECODE() function has 2 arguments, but need 3 to 255
basic testing
select decode(1, 1, 1);
decode(1, 1, 1)
1
select decode(1, 1, 1, 2);
decode(1, 1, 1, 2)
1
select decode(8, 1, 1, 2);
decode(8, 1, 1, 2)
2
select decode(8, 1, 1);
decode(8, 1, 1)
NULL
select decode(8, 1, 1, 2, 2, 8, 8, 100);
decode(8, 1, 1, 2, 2, 8, 8, 100)
8
select decode(8, 1, 1, 2, 2, 3, 3, 100);
decode(8, 1, 1, 2, 2, 3, 3, 100)
100
null testing
select decode(null, 1, 1, null, 2, 100);
decode(null, 1, 1, null, 2, 100)
2
select decode(null, 1, 1, null, 2);
decode(null, 1, 1, null, 2)
2
select decode(null, 1, 1, 2, 2);
decode(null, 1, 1, 2, 2)
NULL
result type testing
select decode('1.1', 1.1, 'found', 'notfound');
decode('1.1', 1.1, 'found', 'notfound')
found
select decode('1.1', 1.1, true, 'notfound');
decode('1.1', 1.1, true, 'notfound')
true
select decode(1, 1, 100, 100.1);
decode(1, 1, 100, 100.1)
100
select decode(1, 2, 100, 100.1);
decode(1, 2, 100, 100.1)
100.1
used in table testing
drop table if exists t1;
create table t1 (pk int primary key, v1 varchar(16), n1 numeric, t1  timestamp(6) default "2012-01-01 12:00:00");
insert into t1 values (1, 'a', 1.1, timestamp'2014-10-17 14:02:00'), (2, 'b', 2.2, timestamp'2014-10-17 15:02:00');
select decode(pk, 1, pk, 2, v1) from t1;
decode(pk, 1, pk, 2, v1)
1
b
select decode(pk, 1, pk, 2, n1) from t1;
decode(pk, 1, pk, 2, n1)
1
2.2
select decode(pk, 1, pk, 2, t1) from t1;
decode(pk, 1, pk, 2, t1)
1
2014-10-17 15:02:00.000000
select decode(pk, 1, v1, 2, n1) from t1;
decode(pk, 1, v1, 2, n1)
a
2.2
select decode(pk, 1, v1, 2, t1) from t1;
decode(pk, 1, v1, 2, t1)
a
2014-10-17 15:02:00.000000
select decode(pk, 1, n1, 2, t1) from t1;
decode(pk, 1, n1, 2, t1)
1.1
2014-10-17 15:02:00.000000
drop table t1;
