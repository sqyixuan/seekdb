#################### create use kill_user  #####################
drop user kill_user;
create user 'kill_user' identified by 'kill_user';
GRANT ALL ON *.* TO 'kill_user';
#################### kill session in transaction #####################
### create a new connection named by conn1 ###
### create a new connection named by conn2 ###
## expect 2 session ##
select count(*) from oceanbase.__all_virtual_processlist where user = 'kill_user';
count(*)
2
drop table if exists t1;
create table t1(c1 int);
insert into t1 values(1);
set session ob_trx_timeout=1000000000000;
set session ob_query_timeout=1000000000000;
begin;
update t1 set c1 = 1;
### conn1 connection ###
set session ob_trx_timeout=1000000000000;
set session ob_query_timeout=1000000000000;
begin;
update t1 set c1 = 1;
### conn2 connection, kill conn1 ###
select count(*) from oceanbase.__all_virtual_processlist where user = 'kill_user';
count(*)
2
### conn1 connection, session has been killed ###
Got one of the listed errors
### conn2 connection, expect 1 session ###
select count(*) from oceanbase.__all_virtual_processlist where user = 'kill_user';
count(*)
1
#################### kill query in transaction #####################
### create a new connection named by conn3 ###
set session ob_trx_timeout=1000000000000;
set session ob_query_timeout=1000000000000;
begin;
update t1 set c1 = 1;
### conn2 connection, kill conn3 query , expect 2 connection###
select count(*) from oceanbase.__all_virtual_processlist where user = 'kill_user';
count(*)
2
select count(*) from oceanbase.__all_virtual_processlist where user = 'kill_user';
count(*)
2
### conn3 connection, query has been killed ###
ERROR 70100: Query execution was interrupted
commit;
begin;
select * from t1 where c1 = 1 for update;
c1
1
set session ob_trx_timeout=1000000000000;
set session ob_query_timeout=1000000000000;
begin;
select * from t1 where c1 = 1 for update;
Got one of the listed errors
select count(*) from oceanbase.__all_virtual_processlist where user = 'kill_user';
count(*)
2
select connection_id();
set session ob_trx_timeout=1000000000000;
set session ob_query_timeout=1000000000000;
select count(*) from oceanbase.__all_virtual_processlist where user = 'kill_user';
count(*)
3
begin;
select * from t1 where c1 = 1 for update;
select connection_id();
ERROR 70100: Query execution was interrupted
select count(*) from oceanbase.__all_virtual_processlist where user = 'kill_user';
