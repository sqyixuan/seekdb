drop database if exists tt;
create database tt;
use tt;
CREATE TABLE t1 (a varchar(32) BINARY) CHARACTER SET utf8mb4;
show create table t1;
Table	Create Table
t1	CREATE TABLE `t1` (
  `a` varchar(32) CHARACTER SET utf8mb4 COLLATE utf8mb4_bin DEFAULT NULL
) DEFAULT CHARSET = utf8mb4 COMPRESSION = 'lz4_1.0' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 10
drop table t1;
create table test(c1 char(3) charset binary);
show create table test;
Table	Create Table
test	CREATE TABLE `test` (
  `c1` binary(3) DEFAULT NULL
) DEFAULT CHARSET = utf8mb4 COMPRESSION = 'lz4_1.0' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 10
drop table test;
create table test(c1 varchar(3) charset binary);
show create table test;
Table	Create Table
test	CREATE TABLE `test` (
  `c1` varbinary(3) DEFAULT NULL
) DEFAULT CHARSET = utf8mb4 COMPRESSION = 'lz4_1.0' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 10
