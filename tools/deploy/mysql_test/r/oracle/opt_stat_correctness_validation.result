result_format: 4
drop table if exists t1, t2;
create table opt_stat_valid_t1 (c1 int, c2 int, index idx(c1));
create table opt_stat_valid_t2 (d1 int, d2 int, index idx(d1));
# insert into T1, T2. 1000 rows each table
# 初始时统计信息应为空
select column_id, num_distinct, num_null, des_hex_str(min_value), des_hex_str(max_value) from oceanbase.__all_virtual_column_statistic as s, oceanbase.__all_virtual_table as t where t.table_name = "opt_stat_valid_t1" and t.table_id = s.table_id;
+-----------+--------------+----------+------------------------+------------------------+
| column_id | num_distinct | num_null | des_hex_str(min_value) | des_hex_str(max_value) |
+-----------+--------------+----------+------------------------+------------------------+
+-----------+--------------+----------+------------------------+------------------------+
select column_id, num_distinct, num_null, des_hex_str(min_value), des_hex_str(max_value) from oceanbase.__all_virtual_column_statistic as s, oceanbase.__all_virtual_table as t where t.table_name = "opt_stat_valid_t2" and t.table_id = s.table_id;
+-----------+--------------+----------+------------------------+------------------------+
| column_id | num_distinct | num_null | des_hex_str(min_value) | des_hex_str(max_value) |
+-----------+--------------+----------+------------------------+------------------------+
+-----------+--------------+----------+------------------------+------------------------+

# 做两次合并验证每次合并是否存在统计信息缺失的情况
alter system major freeze tenant = sys;
alter system major freeze tenant = all_user;
alter system major freeze tenant = all_meta;
