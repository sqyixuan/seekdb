alter table t16 set EXPIRE_INFO (c0<1 or c1 < date_add(merging_frozen_time(),interval -1 HOUR));
show create table t16;
table_name	table_definition
t16	CREATE TABLE t16 (
  c0 INT,
  c1 TIMESTAMP,
  PRIMARY KEY(c0)
) TABLET_MAX_SIZE = 268435456, TABLET_BLOCK_SIZE = 16384, EXPIRE_INFO =( c0<1 or c1 < date_add(merging_frozen_time(),interval -1 HOUR), REPLICA_NUM = 1, DEFAULT CHARSET = 'utf8'
alter table t16 set EXPIRE_INFO (0<1);
