create table t1 (c1 int primary key, c2 int, z1 datetime default now(), z2 datetime default now());
create index i1 on t1 (z1);
create index i2 on t1 (z2);
create index i3 on t1 (c2) storing (z1);
create index i4 on t1 (c2) storing (z2);
drop table t1;
