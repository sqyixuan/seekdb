use oceanbase;
alter system add zone 'test_zone_admin_zone1';
select zone, name, value, info from __all_zone where zone='test_zone_admin_zone1' and name = 'region';
zone	name	value	info
test_zone_admin_zone1	region	0	default_region
alter system add zone 'test_zone_admin_zone2' region 'test_zone_admin_region';
select zone, name, value, info from __all_zone where zone='test_zone_admin_zone2' and name = 'region';
zone	name	value	info
test_zone_admin_zone2	region	0	test_zone_admin_region
alter system modify zone 'test_zone_admin_zone1' set region 'region2';
select zone, name, value, info from __all_zone where zone='test_zone_admin_zone1' and name = 'region';
zone	name	value	info
test_zone_admin_zone1	region	0	region2
alter system delete zone 'test_zone_admin_zone1';
select zone, name, value, info from __all_zone where zone='test_zone_admin_zone1' and name = 'region';
zone	name	value	info
alter system delete zone 'test_zone_admin_zone2';
