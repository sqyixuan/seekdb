set ob_enable_index_direct_select=1;
create table t1(pk1 int, pk2 int, a int, b int, c int, primary key(pk1, pk2));
create table t2(pk1 int, nonpk int, a int, b int, c int, primary key(pk1));
create index i1 on t1(a) storing(c);
create index i2 on t1(b);
create index i3 on t1(c);
create index i4 on t1(a,b);
create index i1 on t2(a) storing(c);
create index i2 on t2(b);
create index i3 on t2(c);
create index i4 on t2(a,b);
alter system major freeze tenant = sys;
alter system major freeze tenant = all_user;
alter system major freeze tenant = all_meta;
insert into t1 values(1,1,1,1,1),(1,2,1,1,1);
insert into t1 values(1,3,2,1,1),(1,4,2,1,1);
insert into t1 values(2,5,3,1,1),(2,6,3,1,1);
insert into t1 values(2,7,4,1,1),(2,8,4,1,1);
