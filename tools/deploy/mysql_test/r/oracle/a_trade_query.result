GMT_OCCUR     TIMESTAMP(6) default "2012-01-01 12:00:00" NULL,
PRIMARY KEY (JOB_ID)
) DEFAULT CHARSET = 'utf8';
CREATE INDEX BYD_TIMEOUT_LONG_ENDTIME_IND ON TIMEOUT_LONG_000 (END_TIME);
