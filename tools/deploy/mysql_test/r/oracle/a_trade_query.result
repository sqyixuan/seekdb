SELECT a.seller_account, a.seller_fullname, a.seller_nick, a.buyer_account,a.buyer_fullname, a.buyer_nick, b.ID, a.trade_no, b.MESSAGE, b.poster,b.poster_role, b.operator_ip, b.msg_type, b.gmt_create, a.gmt_create trade_create_time, b.is_read  FROM trade_base_000 a, trade_message_board_000 b WHERE a.trade_no = b.trade_no and a.trade_no ='2012091400001000440001838128' order by b.id desc;
