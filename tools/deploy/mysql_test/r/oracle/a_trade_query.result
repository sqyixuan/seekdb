SELECT a.seller_account, a.seller_fullname, a.seller_nick, a.buyer_account, a.buyer_fullname, a.buyer_nick, b.ID, a.trade_no, b.MESSAGE, b.poster,b.poster_role, b.operator_ip, b.msg_type, b.gmt_create, a.gmt_create trade_create_time, b.is_read FROM trade_base_000 a, trade_message_board_000 b WHERE a.trade_no = b.trade_no and (buyer_account = '20881026748129240156' or seller_account = '20880022709924030156') and a.trade_no = '2012091400001000440001838128' and a.gmt_create < date_add(str_to_date(substr('2012091500001000440001838128',1,8),'%Y%m%d'),interval 2 day) and a.gmt_create > date_sub(str_to_date(substr('2012091400001000440001838128',1,8),'%Y%m%d'),interval 1 day) and (poster_role = 1 or is_read = '1') and msg_type = 2 order by b.id desc;
