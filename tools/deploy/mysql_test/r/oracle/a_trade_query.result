CREATE INDEX TIMEOUT_LONG_TNO_IND ON TIMEOUT_LONG_000 (TRADE_NO);
CREATE TABLE if not exists TIMEOUT_REMIND_000 
(
JOB_ID        varchar(32)   NOT NULL,
