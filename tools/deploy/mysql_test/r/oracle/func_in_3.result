drop table if exists t1;
create table t1(
col_int bigint, 
col_num decimal(10, 5),
col_date date,
col_str1 varchar(100) collate utf8mb4_bin,
col_str2 varchar(100) collate utf8mb4_general_ci
);
insert into 
t1(col_int, col_num, col_date, col_str1, col_str2) 
values
(0, 0.0, '0000-00-00', '', ''),
(1, 1.1, '2016-1-1', 'a', 'a'),
(2, 2.2, '2016-2-1', 'A', 'A'),
(3, 3.3, '2016-3-1', 'b', 'b'),
(4, 4.4, '2016-4-1', 'B', 'B'),
(5, 5.5, '2016-5-1', 'c', 'c'),
(6, 6.6, '2016-6-1', 'C', 'C'),
(7, 7.7, '2016-7-1', 'd', 'd'),
(null, null, null, null, null);
select * from t1
where
col_int  in (1, 2, 3, 4) and
col_num  in (1.1, 2.2, 3.3, 4.4) and
col_date in ('2016-1-1', '2016-2-1', '2016-3-1', '2016-4-1') and
col_str1 in ('a' collate utf8mb4_bin, 'b' collate utf8mb4_bin) and
col_str2 in ('a' collate utf8mb4_general_ci, 'b' collate utf8mb4_general_ci)
order by
col_int;
col_int	col_num	col_date	col_str1	col_str2
1	1.10000	2016-01-01	a	a
3	3.30000	2016-03-01	b	b
select * from t1
where
col_int  not in (1, 2, 3, 4) and
col_num  not in (1.1, 2.2, 3.3, 4.4) and
col_date not in ('2016-1-1', '2016-2-1', '2016-3-1', '2016-4-1') and
col_str1 not in ('a' collate utf8mb4_bin, 'b' collate utf8mb4_bin) and
col_str2 not in ('a' collate utf8mb4_general_ci, 'b' collate utf8mb4_general_ci)
order by
col_int;
