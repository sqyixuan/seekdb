drop tenant if exists ora_tt force;
drop resource pool if exists pool1;
drop resource unit if exists box1;
create resource unit box1 max_cpu 1, max_memory 1073741824, max_iops 100000, max_disk_size 536870912, max_session_num 64, MIN_CPU=1, MIN_MEMORY=1073741824, MIN_IOPS=128;
## 功能: 获取指定租户的ip&port
## 用法:
## 模板:


use test;

set @@ob_query_timeout=1000000000;

create package dbms_output as
  procedure enable(buffer_size integer);
  procedure disable();
  procedure put(a varchar(32767));
  procedure put_line(a varchar(32767));
  procedure new_line();
  procedure get_line(out line varchar(32767), out status integer);
end;//
create package body dbms_output as
  declare enabled         boolean default false;
  declare get_in_progress boolean default true;
  declare type char_arr   is table of varchar(32767);
  declare buf             char_arr;
  declare buf_size        integer default 20000;
  declare bufleft         integer default -1;
  declare linebuflen      integer default 0;
  declare putidx          integer default 1;
  declare getidx          integer default 1;
  
  procedure enable(buffer_size integer) is
  begin
    set enabled = true;
    if buffer_size < 2000 then
      set buf_size = 2000;
    else if buffer_size > 1000000 then
      set buf_size = 1000000;
    else if buffer_size is null then
      set buf_size = -1; 
    else
      set buf_size = buffer_size;
    end if;
    set bufleft = buf_size;
  end;
  
  procedure disable() is
  begin
    set enabled = false; 
    set putidx = 1; 
    set get_in_progress = true;  
  end;
  
  procedure put_init() is
  begin
    set putidx = 1;
    do buf.extend;
    set buf(putidx) = '';
    set linebuflen = 0;
    set bufleft = buf_size;
    set get_in_progress = false;
  end;
  
  procedure put(a varchar(32767)) is
  begin
    declare strlen integer;
 
    if enabled then
      if get_in_progress then
        call put_init();
      end if;

      set strlen = nvl(length(a), 0);
      if ((strlen + linebuflen) > 32767) then
        set linebuflen = 0;
      end if;

      if (buf_size <> -1) then   
        set bufleft = bufleft - strlen;
      end if;
	 
      set buf(putidx) = concat(buf(putidx), a);
      set linebuflen = linebuflen + strlen;
    end if;
  end;
  
  procedure put_line(a varchar(32767)) is
  begin
    if enabled then
      call put(a);
      call new_line();
    end if;
  end;
  
  procedure new_line() is
  begin
    if enabled then
      if get_in_progress then
        call put_init();
      end if;
      set linebuflen = 0;
      set putidx = putidx + 1;
      do buf.extend;
      set buf(putidx) = '';
    end if;
  end;
  
  procedure get_line(out line varchar(32767), out status integer) is
  begin
    if not enabled then
      set status = 1;
    else 
    begin
     if not get_in_progress then
	   set get_in_progress = true;
	   if (linebuflen > 0) and (putidx = 1) then
	     set status = 1;
	   end if;
	   set getidx = 1;
     end if;
	 if getidx <= putidx then
	   set line = buf(getidx);
	   set getidx = getidx + 1;
	   set status = 0;
	 else 
	   set status = 1;
	 end if;
    end;
	end if;  
  end;
end;//
call dbms_output.enable(1000);
call dbms_output.put_line('test');
call dbms_output.get_line('', 0);
+------+--------+
| line | status |
+------+--------+
| test |      0 |
+------+--------+
call dbms_output.get_line('', 0);
+------+--------+
| line | status |
+------+--------+
|      |      0 |
+------+--------+
call dbms_output.get_line('', 0);
+------+--------+
| line | status |
+------+--------+
|      |      1 |
+------+--------+
drop package dbms_output;

