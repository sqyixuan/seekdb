drop table if exists t1,t2,t3;
CREATE TABLE t1 (
id int,
val char(10),
PRIMARY KEY  (id)
) ;
INSERT INTO t1 VALUES
(1,'one'),(2,'two'),(3,'three'),(4,'one'),(5,'two');
select val, count(*) from t1 group by val order by val;
val	count(*)
one	2
three	1
two	2
drop table t1;
create table t1(a int primary key, b datetime default now());
insert into t1(a) values (1), (2);
select MAX(b) from t1 group by a;
MAX(b)
max
max
drop table t1;
CREATE TABLE t1(
id int PRIMARY KEY,
a  int,
b  int
);
INSERT INTO t1 VALUES 
(1,1,4), (2,2,1), (3,1,3), (4,2,1), (5,1,1);
SELECT MAX(id) FROM t1 WHERE id < 3 AND a=2 AND b=6;
MAX(id)
NULL
DROP TABLE t1;
CREATE TABLE t1(
id int PRIMARY KEY,
a  int,
b  int
);
create index  i_id on  t1(a,id);
create index  i_b_id on  t1(a,b,id);
alter system major freeze tenant = sys;
alter system major freeze tenant = all_user;
alter system major freeze tenant = all_meta;
INSERT INTO t1 VALUES  (1,1,4), (2,2,1), (3,1,3), (4,2,1), (5,1,1);
SELECT MAX(id) FROM t1 WHERE id < 3 AND a=2 AND b=6;
MAX(id)
NULL
SELECT MAX(id) FROM t1 WHERE id < 3 AND a=2 ;
MAX(id)
2
DROP TABLE t1;
CREATE TABLE t1 (id int PRIMARY KEY, b char(3));
INSERT INTO t1 VALUES (1,'xx'), (2,'aa');
SELECT * FROM t1;
id	b
1	xx
2	aa
SELECT MAX(b) FROM t1 WHERE b < 'ppppp';
MAX(b)
aa
SELECT MAX(b) FROM t1 WHERE b < 'pp';
MAX(b)
aa
DROP TABLE t1;
CREATE TABLE t1 (id int PRIMARY KEY, b char(16));
INSERT INTO t1 VALUES (1, 'xxxxbbbb'), (2, 'xxxxaaaa');
SELECT MAX(b) FROM t1;
MAX(b)
xxxxbbbb
DROP TABLE t1;
create table t2 (ff double, i int primary key);
insert into t2 values (2.2,0);
select cast(sum(distinct ff) as decimal(5,2)) from t2;
cast(sum(distinct ff) as decimal(5,2))
2.20
select cast(min(ff) as decimal(5,2)) from t2;
cast(min(ff) as decimal(5,2))
2.20
create table t1 (df double , i int primary key);
insert into t1 values(1.1,0);
insert into t1 values(2.2,1);
select 1e8 * sum(distinct df) from t1;
1e8 * sum(distinct df)
330000000
select 1e8 * min(df) from t1;
1e8 * min(df)
110000000.00000001
select 100000000 * sum(distinct df) from t1;
100000000 * sum(distinct df)
330000000
select 100000000 * min(df) from t1;
100000000 * min(df)
110000000.00000001
create table t3 (ifl int primary key, i int);
insert into t3 values(1,0), (2,0);
select cast(min(ifl) as decimal(5,2)) from t3;
cast(min(ifl) as decimal(5,2))
1.00
drop table t1, t2, t3;
