SELECT REGEXP_SUBSTR('500 Oracle Parkway, Redwood Shores, CA', ',[^,]+,') "REGEXPR_SUBSTR" FROM DUAL;
REGEXPR_SUBSTR
, Redwood Shores,
SELECT REGEXP_SUBSTR('http://www.example.com/products', 'http://([[:alnum:]]+\\.?){3,4}/?') "REGEXP_SUBSTR" FROM DUAL;
REGEXP_SUBSTR
http://www.example.com/
SELECT REGEXP_SUBSTR('1234567890', '(123)(4(56)(78))', 1, 1, 'i', 1) "REGEXP_SUBSTR" FROM DUAL;
REGEXP_SUBSTR
123
SELECT REGEXP_SUBSTR('1234567890', '(123)(4(56)(78))', 1, 1, 'i', 4) "REGEXP_SUBSTR" FROM DUAL;
REGEXP_SUBSTR
78
DROP TABLE IF EXISTS regexp_temp;
CREATE TABLE regexp_temp(empName varchar(20), emailID varchar(20));
INSERT INTO regexp_temp (empName, emailID) VALUES ('John Doe', 'johndoe@example.com');
INSERT INTO regexp_temp (empName, emailID) VALUES ('Jane Doe', 'janedoe');
SELECT empName, REGEXP_SUBSTR(emailID, '[[:alnum:]]+\@[[:alnum:]]+\.[[:alnum:]]+') "Valid Email" FROM regexp_temp;
empName	Valid Email
John Doe	johndoe@example.com
Jane Doe	NULL
DROP TABLE regexp_temp;
select regexp_substr(str, '[0-9]') First_Occurrence_of_Number,
regexp_substr(str, '[0-9].*') Num_Followed_by_String,   
regexp_substr(str, '[A-Z][0-9]') Letter_Followed_by_String   
from (   
select 'ABC123' str from dual union all   
select 'A1B2C3' str from dual union all   
select '123ABC' str from dual union all   
select '1A2B3C' str from dual   
) strings;
First_Occurrence_of_Number	Num_Followed_by_String	Letter_Followed_by_String
1	123	C1
1	1B2C3	A1
1	123ABC	NULL
1	1A2B3C	A2
SELECT regexp_substr(str, '[A-Z]{6}') String_of_6_characters,   
regexp_substr(str, '[0-9]+') First_Matching_Numbers,   
regexp_substr(str, '[A-Z].*$') Letter_by_other_characters,     
regexp_substr(str, '/[A-Z].*$') Slash_letter_and_characters     
FROM (    
select 'LHRJFK/010315/JOHNDOE' str from dual union all    
select 'CDGLAX/050515/JANEDOE' str from dual union all    
select 'LAXCDG/220515/JOHNDOE' str from dual union all    
select 'SFOJFK/010615/JANEDOE' str from dual    
) strings;
String_of_6_characters	First_Matching_Numbers	Letter_by_other_characters	Slash_letter_and_characters
LHRJFK	010315	LHRJFK/010315/JOHNDOE	/JOHNDOE
CDGLAX	050515	CDGLAX/050515/JANEDOE	/JANEDOE
LAXCDG	220515	LAXCDG/220515/JOHNDOE	/JOHNDOE
SFOJFK	010615	SFOJFK/010615/JANEDOE	/JANEDOE
select regexp_substr ("I love aliyun very much", "a[[:alpha:]]{5}") from dual;
regexp_substr ("I love aliyun very much", "a[[:alpha:]]{5}")
aliyun
select regexp_substr('I have 2 apples and 100 bucks!', '[[:blank:]][[:alnum:]]*', 1, 1) from dual;
regexp_substr('I have 2 apples and 100 bucks!', '[[:blank:]][[:alnum:]]*', 1, 1)
 have
select regexp_substr('I have 2 apples and 100 bucks!', '[[:blank:]][[:alnum:]]*', 1, 2) from dual;
regexp_substr('I have 2 apples and 100 bucks!', '[[:blank:]][[:alnum:]]*', 1, 2)
 2
select regexp_substr('8d99d8', '8d([[:alnum:]]+)d8', 1, 1, 'i', 1) from dual;
regexp_substr('8d99d8', '8d([[:alnum:]]+)d8', 1, 1, 'i', 1)
99
select regexp_substr('foothebar', 'foo(.*)(bar)', 1, 1, 'i', 1) from dual;
regexp_substr('foothebar', 'foo(.*)(bar)', 1, 1, 'i', 1)
the
select regexp_substr('foothebar', 'foo(.*)(bar)', 1, 1, 'i', 2) from dual;
regexp_substr('foothebar', 'foo(.*)(bar)', 1, 1, 'i', 2)
bar
select regexp_substr('foothebar', 'foo(.*)(bar)', 1, 1, 'i', 0) from dual;
regexp_substr('foothebar', 'foo(.*)(bar)', 1, 1, 'i', 0)
foothebar
drop table if exists regexp_substr_t;
create table regexp_substr_t(col varchar(50));
insert into regexp_substr_t values('foothebar');
insert into regexp_substr_t values('8d99d8');
insert into regexp_substr_t values('i love www.taobao.com');
insert into regexp_substr_t values('123.456.7890');
insert into regexp_substr_t values('oceanbase::common::sql');
SELECT col,
regexp_substr(col, 'o[[:alpha:]]{3}'),
regexp_substr(col, 'o[[:alpha:]]{1}', 10),
regexp_substr(col, 'o[[:alpha:]]{1}', 1, 2)
FROM regexp_substr_t;
col	regexp_substr(col, 'o[[:alpha:]]{3}')	regexp_substr(col, 'o[[:alpha:]]{1}', 10)	regexp_substr(col, 'o[[:alpha:]]{1}', 1, 2)
foothebar	ooth	NULL	NULL
8d99d8	NULL	NULL	NULL
i love www.taobao.com	obao	ob	ob
123.456.7890	NULL	NULL	NULL
oceanbase::common::sql	ocea	om	om
SELECT col,
regexp_substr(col, '[[:digit:]](.{4})([[:digit:]])', 1, 1, 'i', 2) as col1,
regexp_substr(col, '(.{2})(.{3})[[:digit:]]$', 1, 1, 'i', 1) as col2,
regexp_substr(col, '(.{2})(.{3})[[:digit:]]$', 1, 1, 'i', 0) as col3,
regexp_substr(col, "(foo|apsara|i)([a-z: ]{3})", 1, 1, 'i', 2) as col4,
regexp_substr(col, "(.)[do](.)", 1, 1, 'i', 1) as col5
FROM regexp_substr_t;
col	col1	col2	col3	col4	col5
foothebar	NULL	NULL	NULL	the	f
8d99d8	8	8d	8d99d8	NULL	8
i love www.taobao.com	NULL	NULL	NULL	 lo	l
123.456.7890	5	6.	6.7890	NULL	NULL
oceanbase::common::sql	NULL	NULL	NULL	NULL	c
