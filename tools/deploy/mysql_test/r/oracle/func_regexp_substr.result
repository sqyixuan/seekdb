regexp_substr('1234567890', '(123)(4(56)(78))', col1, col1, 'i', col1)
123
select regexp_substr('1234567890', '(123)(4(56)(78))', 1, 1, col2, 0) from match_param_t;
ERROR HY000: Invalid argument
drop table match_param_t;
