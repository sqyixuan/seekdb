drop table if exists order_history;
CREATE TABLE ORDER_HISTORY(
ORDER_ID bigint, 
SELLER_ID bigint, 
BUYER_ID bigint, 
GMT_CREATE DATETIME, 
PARENT_ORDER_ID bigint, 
AUCTION_TITLE VARCHAR(100), 
PRIMARY KEY (ORDER_ID));
