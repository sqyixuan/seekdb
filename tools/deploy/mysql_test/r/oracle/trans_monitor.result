set autocommit=1;
drop table if exists t1;
create table t1 (c1 int primary key, c2 int);
set autocommit = 0;
insert into t1 values (1, 2);
insert into t1 values (2, 3);
set autocommit = 1;
insert into t1 values (3, 4);
set autocommit = 0;
insert into t1 values (5, 2);
insert into t1 values (6, 3);
rollback;
set autocommit = 0;
insert into t1 values (5, 2);
insert into t1 values (6, 3);
commit;
drop table t1;
