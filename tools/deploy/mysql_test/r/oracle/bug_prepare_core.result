drop table if exists writer_test43;
create table writer_test43(i1 int, i2 int, i3 int, v1 varchar(1024), v2 varchar(1024), d1 double, d2 double, f1 float, f2 float, b1 boolean, t1  timestamp(6) default "2012-01-01 12:00:00", primary key(i1));
prepare batch from replace into writer_test43 (i1,i2,i3,v1,v2,d1,d2,f1,f2,b1,t1) values (?,?,?,?,?,?,?,?,?,?,?);
set autocommit = 0;
prepare batch2 from replace into writer_test43 (i1,i2,i3,v1,v2,d1,d2,f1,f2,b1,t1) values (?,?,?,?,?,?,?,?,?,?,?);
select * from writer_test43;
i1	i2	i3	v1	v2	d1	d2	f1	f2	b1	t1
drop table writer_test43;
