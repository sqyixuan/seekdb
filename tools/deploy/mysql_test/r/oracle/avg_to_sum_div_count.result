drop table if exists t1,t2,t3, t_empty, t_distinct, LINEITEM;
create table t1 (c1 int, c2 bigint, c3 float);
insert into t1 values(1, 2, 3.5), (-3, 2, 4.5), (7, 5, 2.0), (9, 4, -0.5);
select avg(c1) from t1;
avg(c1)
3.5000
explain select avg(c1) from t1;
Query Plan
========================================
|ID|OPERATOR       |NAME|EST. ROWS|COST|
----------------------------------------
|0 |SCALAR GROUP BY|    |1        |38  |
|1 | TABLE SCAN    |t1  |4        |37  |
========================================

Outputs & filters: 
-------------------------------------
  0 - output([T_FUN_SUM(t1.c1) / T_FUN_COUNT(t1.c1)]), filter(nil), 
      group(nil), agg_func([T_FUN_SUM(t1.c1)], [T_FUN_COUNT(t1.c1)])
  1 - output([t1.c1]), filter(nil), 
      access([t1.c1]), partitions(p0)

