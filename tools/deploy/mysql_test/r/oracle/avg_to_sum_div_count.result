create table t_distinct (c1 int, c2 bigint, c3 float);
insert into t_distinct values(1, 2, 3.5), (-3, 2, 4.5), (1, 5, -0.5), (9, 4, -0.5);
select avg(c1), avg(distinct c1) from t_distinct;
avg(c1)	avg(distinct c1)
2.0000	2.3333
explain select avg(distinct c1) from t_distinct;
