drop table if exists t1,t2;
create table t1(
a1 char(3) primary key,
a2 int,
a3 char(3),
a4 float,
a5 datetime
);
create table t2(
a1 char(3) primary key,
a2 char(17),
a3 char(2),
a4 char(3)
);
