result_format: 4
drop table if exists t1,t2;
create table t1 (c1 varchar(20) collate utf8mb4_general_ci primary key, c2 varchar(20) collate utf8mb4_general_ci) partition by key(c1) partitions 8;
create table t2 (c1 varchar(20) collate utf8mb4_bin primary key, c2 varchar(20) collate utf8mb4_bin) partition by key(c1) partitions 8;

insert into t1 values ('a', 'a'), ('B', 'B'), ('c', 'c');
insert into t2 values ('a', 'a'), ('B', 'B'), ('c', 'c');

explain select * from t1, t2 where t1.c1 = t2.c2;
Query Plan
========================================================
|ID|OPERATOR                |NAME    |EST. ROWS|COST   |
--------------------------------------------------------
|0 |HASH JOIN               |        |792000   |4503413|
|1 | PX COORDINATOR         |        |800000   |684125 |
|2 |  EXCHANGE OUT DISTR    |:EX10000|800000   |494805 |
|3 |   PX PARTITION ITERATOR|        |800000   |494805 |
|4 |    TABLE SCAN          |t1      |800000   |494805 |
|5 | PX COORDINATOR         |        |800000   |684125 |
|6 |  EXCHANGE OUT DISTR    |:EX20000|800000   |494805 |
|7 |   PX PARTITION ITERATOR|        |800000   |494805 |
|8 |    TABLE SCAN          |t2      |800000   |494805 |
========================================================

Outputs & filters: 
-------------------------------------
  0 - output([t1.c1], [t1.c2], [t2.c1], [t2.c2]), filter(nil), 
      equal_conds([t1.c1 = t2.c2]), other_conds(nil)
  1 - output([t1.c1], [t1.c2]), filter(nil)
  2 - output([t1.c1], [t1.c2]), filter(nil), dop=1
  3 - output([t1.c1], [t1.c2]), filter(nil)
  4 - output([t1.c1], [t1.c2]), filter(nil), 
      access([t1.c1], [t1.c2]), partitions(p[0-7])
  5 - output([t2.c1], [t2.c2]), filter(nil)
  6 - output([t2.c1], [t2.c2]), filter(nil), dop=1
  7 - output([t2.c1], [t2.c2]), filter(nil)
  8 - output([t2.c1], [t2.c2]), filter(nil), 
      access([t2.c1], [t2.c2]), partitions(p[0-7])

select * from t1, t2 where t1.c1 = t2.c2;
