drop table if exists t1;
set ob_enable_index_direct_select=1;
alter system set merger_check_interval = '10s' tenant sys;
alter system set merger_check_interval = '10s' tenant all_user;
alter system set merger_check_interval = '10s' tenant all_meta;
create table t1(pk1 int, pk2 int, key1 int, key2 int, key3 int, key4 int, key5 int, key6 int, key7 int, key8 int, key9 int,primary key(pk1, pk2));
create index i1 on t1(key1,key2) storing(key9);
create index i2 on t1(key3,key4,key5) storing(key9);
create index i4 on t1(key6);
create index i5 on t1(key7,key8) storing(key9);
create index i6 on t1(key1,pk2) storing(key9);
