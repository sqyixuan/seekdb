create table t1(pk int primary key, a int, b int, c int, d int);
create index i1 on t1(b) storing(c,d);
insert into t1 values(1,1,1,1,1),(2,1,1,1,1);
set autocommit=0;
select pk, b, c, d from t1 where b>=1 and b<=1;
pk	b	c	d
1	1	1	1
2	1	1	1
select * from t1 where pk>0 and pk<10 and b=1;
pk	a	b	c	d
1	1	1	1	1
2	1	1	1	1
select * from t1 where b=1;
pk	a	b	c	d
1	1	1	1	1
2	1	1	1	1
set autocommit=0;
update t1 set a=10, b=10, c=10, d=10 where pk=1;
delete from t1 where pk=2;
commit;
insert into t1(pk,a ,b, c, d) values(3,1,1,1,1);
select pk, b, c, d from t1 where b>0 and b<100;
pk	b	c	d
