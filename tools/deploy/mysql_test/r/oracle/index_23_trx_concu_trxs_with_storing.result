pk	a	b	c	d
1	10	10	10	10
3	1	1	1	1
select * from t1 where b>0 and b<100;
pk	a	b	c	d
1	10	10	10	10
3	1	1	1	1
set autocommit=0;
update t1 set a=30, b=30, c=30, d=30 where pk=3;
