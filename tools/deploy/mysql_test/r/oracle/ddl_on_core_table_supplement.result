show create table __all_column;
Table	Create Table
__all_column	CREATE TABLE `__all_column` (
  `gmt_create` timestamp(6) NULL DEFAULT CURRENT_TIMESTAMP(6),
  `gmt_modified` timestamp(6) NULL DEFAULT CURRENT_TIMESTAMP(6) ON UPDATE CURRENT_TIMESTAMP(6),
  `tenant_id` bigint(20) NOT NULL,
  `table_id` bigint(20) NOT NULL,
  `column_id` bigint(20) NOT NULL,
  `column_name` varchar(128) NOT NULL DEFAULT '',
  `rowkey_position` bigint(20) NOT NULL DEFAULT '0',
  `index_position` bigint(20) NOT NULL,
  `order_in_rowkey` bigint(20) NOT NULL,
  `partition_key_position` bigint(20) NOT NULL,
  `data_type` bigint(20) NOT NULL,
  `data_length` bigint(20) NOT NULL,
  `data_precision` bigint(20) DEFAULT NULL,
  `data_scale` bigint(20) DEFAULT NULL,
  `zero_fill` bigint(20) NOT NULL,
  `nullable` bigint(20) NOT NULL,
  `on_update_current_timestamp` bigint(20) NOT NULL,
  `autoincrement` bigint(20) NOT NULL,
  `is_hidden` bigint(20) NOT NULL DEFAULT '0',
  `collation_type` bigint(20) NOT NULL,
  `orig_default_value` varchar(262144) DEFAULT NULL,
  `cur_default_value` varchar(262144) DEFAULT NULL,
  `comment` varchar(2048) DEFAULT NULL,
  `schema_version` bigint(20) NOT NULL,
  `column_flags` bigint(20) NOT NULL DEFAULT '0',
  `prev_column_id` bigint(20) NOT NULL DEFAULT '-1',
  `extended_type_info` varbinary(65536) DEFAULT NULL,
  PRIMARY KEY (`tenant_id`, `table_id`, `column_id`)
) DEFAULT CHARSET = utf8mb4 REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 10 TABLEGROUP = 'oceanbase'
 partition by key (tenant_id) partitions 16

