case 1 : varchar
drop table if exists t1;
create table t1(c0 int primary key,c1 varchar(1024)) EXPIRE_INFO ( c1 = 'd');
insert into t1 values(1,'i'),(2,'s'),(3,'D');
select c0,c1 from t1;
c0	c1
1	i
2	s
3	D
update t1 set c1='d' where c0=1;
update t1 set c1='d' where c0=2;
select c0,c1 from t1;
c0	c1
1	d
2	d
3	D
merge happens
alter system major freeze tenant = sys;
alter system major freeze tenant = all_user;
alter system major freeze tenant = all_meta;
select c0,c1 from t1;
c0	c1
3	D
drop table t1;
case 2 : expire row
drop table if exists t1;
create table t1(c0 int primary key,c1 int) EXPIRE_INFO =( c1 < 0);
insert into t1 values(1,1),(2,1),(3,1);
select c0,c1 from t1;
c0	c1
1	1
2	1
3	1
update t1 set c1=-1 where c0=1;
select c0,c1 from t1;
c0	c1
1	-1
2	1
3	1
merge happens
alter system major freeze tenant = sys;
alter system major freeze tenant = all_user;
alter system major freeze tenant = all_meta;
select c0,c1 from t1;
c0	c1
2	1
3	1
drop table t1;
case 3 : int + rows
drop table if exists t1;
create table t1(c0 int primary key,c1 int) EXPIRE_INFO ( c1 < 0);
insert into t1 values(1,1),(2,1),(3,1);
select c0,c1 from t1;
c0	c1
1	1
2	1
3	1
update t1 set c1=-1 where c0=1;
update t1 set c1=-1 where c0=2;
update t1 set c1=-1 where c0=3;
select c0,c1 from t1;
c0	c1
1	-1
2	-1
3	-1
merge happens
alter system major freeze tenant = sys;
alter system major freeze tenant = all_user;
alter system major freeze tenant = all_meta;
select c0,c1 from t1;
c0	c1
drop table t1;
case 4 : all expire
drop table if exists t1;
create table t1(c0 int primary key,c1 modifytime) EXPIRE_INFO (cast(c1 as int) > 0);
ERROR 22000: Cast don't support the transition from 'modifytime' to 'int'
create table t1(c0 int primary key,c1 modifytime) EXPIRE_INFO (TIME_TO_USEC(c1) > 0);
insert into t1(c0) values(1),(2),(3);
select c0,c1 from t1;
c0	c1
1	time
2	time
3	time
merge happens
alter system major freeze tenant = sys;
alter system major freeze tenant = all_user;
alter system major freeze tenant = all_meta;
select c0,c1 from t1;
c0	c1
drop table t1;
case 5: no expire
drop table if exists t1;
create table t1(c0 int primary key,c1 modifytime) EXPIRE_INFO (cast(c1 as int) < 0);
ERROR 22000: Cast don't support the transition from 'modifytime' to 'int'
create table t1(c0 int primary key,c1 modifytime) EXPIRE_INFO (TIME_TO_USEC(c1) < 0);
insert into t1(c0) values(1),(2),(3);
select c0,c1 from t1;
c0	c1
1	time
2	time
3	time
merge happens
alter system major freeze tenant = sys;
alter system major freeze tenant = all_user;
alter system major freeze tenant = all_meta;
select c0,c1 from t1;
c0	c1
1	time
2	time
3	time
drop table t1;
case 6: expression test
drop table if exists t1,t2,t3,t4,t5,t6,t7,t8,t9,t10,t11,t12,t13,t14,t15;
create table t1(c0 int primary key,c1 int) EXPIRE_INFO (c0 > c1);
insert into t1 values(1,1),(100,0),(0,1);
create table t2(c0 int primary key,c1 int) EXPIRE_INFO (c0 = c1);
insert into t2 values(1,1),(100,0),(0,1);
create table t3(c0 int primary key,c1 int) EXPIRE_INFO (c0 != c1);
insert into t3 values(1,1),(100,0),(0,1);
create table t4(c0 int primary key,c1 int) EXPIRE_INFO (c0 < c1);
insert into t4 values(1,1),(100,0),(0,1);
create table t5(c0 int primary key,c1 int) EXPIRE_INFO (c0 >= c1);
insert into t5 values(1,1),(100,0),(0,1);
create table t6(c0 int primary key,c1 int) EXPIRE_INFO (c0 <= c1);
insert into t6 values(1,1),(100,0),(0,1);
create table t7(c0 int primary key,c1 int) EXPIRE_INFO (c0 + c1 > 100);
insert into t7 values(100,1),(1,100),(0,1);
create table t8(c0 int primary key,c1 int) EXPIRE_INFO (c0 - c1 > 0);
insert into t8 values(100,1),(1,100),(0,1);
create table t9(c0 int primary key,c1 int) EXPIRE_INFO (c0 + c1 = 100);
insert into t9 values(100,0),(0,100),(10,1);
create table t10(c0 int primary key,c1 int, c2 int) EXPIRE_INFO (c0 + c1 + c2 = 100);
insert into t10 values(100,0,0),(10,100,0),(0,1,101);
alter table t10 drop c2;
ERROR 42S21: Column 'c2' in Expire Info can not be dropped
create table t11(c0 int primary key,c1 int, c2 int) EXPIRE_INFO (c0 + c1  > c2);
insert into t11 values(100,0,0),(10,100,100),(0,1,100);
alter table t11 drop c2;
ERROR 42S21: Column 'c2' in Expire Info can not be dropped
alter table t11 drop c0;
ERROR 23000: Primary key column can not be dropped in table or index, column name = 'c0'
create table t12(c0 int primary key,c1 double) EXPIRE_INFO (c1 > 1.5);
insert into t12 values(1,1),(2,2),(3,2.6);
create table t13(c0 int primary key,c1 timestamp) EXPIRE_INFO (c1 > '2012-10-01 23:00:00');
insert into t13 values(1,'2012-10-01 23:00:00'),(2,'2012-10-01 23:00:01'),(3,'2012-11-01 23:00:00');
alter table t13 alter c1  set default '2050-01-01 00:00:00';
create table t14(c0 int primary key,c1 createtime) EXPIRE_INFO (c1 > '2014-01-01 00:00:00' and TIME_TO_USEC(c1) != 0);
insert into t14(c0) values(1),(2),(3);
create table t15(c0 int primary key,c1 modifytime) EXPIRE_INFO (c1 < '2050-01-01 00:00:00');
insert into t15(c0) values(1),(2);
alter table t15 alter c1 drop not null;
ERROR 42000: OB-4007: Operation not allowed now
alter table t15 alter c1  set default '2050-01-01 00:00:00';
ERROR 42000: OB-4007: Operation not allowed now
merge happens
alter system major freeze tenant = sys;
alter system major freeze tenant = all_user;
alter system major freeze tenant = all_meta;
select c0,c1 from t12;
c0	c1
1	1
select c0,c1 from t11;
c0	c1
0	1
select c0,c1 from t10;
c0	c1
0	1
10	100
select c0,c1 from t9;
c0	c1
10	1
select c0,c1 from t8;
c0	c1
0	1
1	100
select c0,c1 from t7;
c0	c1
0	1
select c0,c1 from t6;
c0	c1
100	0
select c0,c1 from t5;
c0	c1
0	1
select c0,c1 from t4;
c0	c1
1	1
100	0
select c0,c1 from t3;
c0	c1
1	1
select c0,c1 from t2;
c0	c1
0	1
100	0
select c0,c1 from t1;
c0	c1
0	1
1	1
select c0,c1 from t13;
c0	c1
1	2012-10-01 23:00:00
select c0,c1 from t14;
c0	c1
select c0,c1 from t15;
c0	c1
case 7: function MERGING_FROZEN_TIME() system function test
drop table if exists t1;
create table t1(c1 int primary key, c2 timestamp) EXPIRE_INFO (c2<merging_frozen_time());
insert into t1 values(1, now());
insert into t1 values(2, now());
insert into t1 values(3, now());
insert into t1 values(4, date_add(now(), INTERVAL 5 DAY));
insert into t1 values(5, date_add(now(), INTERVAL 6 DAY));
select c1, c2 from t1;
c1	c2
1	time
2	time
3	time
4	time
5	time
merge happens
alter system major freeze tenant = sys;
alter system major freeze tenant = all_user;
alter system major freeze tenant = all_meta;
select c1, c2 from t1;
c1	c2
4	time
5	time
drop table t1,t2,t3,t4,t5;
drop table t6,t7,t8,t9,t10;
drop table t11,t12,t13,t14,t15;
case 8:some expr with merging_frozen_time
drop table if exists t16;
create table t16(c0 int primary key,c1 timestamp) EXPIRE_INFO (c1 < date_add(merging_frozen_time(),interval 30 second));
select merging_frozen_time();
