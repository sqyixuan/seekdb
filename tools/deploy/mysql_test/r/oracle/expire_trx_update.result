drop table if exists t1, t2;
create table t1(pk int primary key, c1 int, c2 int default 0) EXPIRE_INFO ( pk < 100,enable_transaction_expire=true);
create table t2(pk int primary key, c1 int, c2 timestamp default now()) EXPIRE_INFO ( pk < 100,enable_transaction_expire=true);
alter system set merge_delay_interval='20s' server_type=chunkserver;
alter system set merge_delay_for_lsync='20s' server_type=chunkserver;
insert 1000 rows to ups
alter system major freeze tenant = sys;
alter system major freeze tenant = all_user;
alter system major freeze tenant = all_meta;
select pk, c1, c2 from t1 where pk<=100 limit 10;
pk	c1	c2
select pk, c1, c2 from t2 where pk<=100 limit 10;
pk	c1	c2
select pk, c1, c2 from t1 where pk<=100 limit 10;
pk	c1	c2
select pk, c1, c2 from t2 where pk<=100 limit 10;
pk	c1	c2
select count(*) from t1;
count(*)
1000
