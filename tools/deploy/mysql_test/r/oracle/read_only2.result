#
# WL#5968 Implement START TRANSACTION READ (WRITE|ONLY);
#
#
# Test interaction with read_only system variable.
DROP TABLE IF EXISTS t1;
CREATE TABLE t1(a INT);
INSERT INTO t1 VALUES (1), (2);
SET GLOBAL read_only = on;
show global variables like 'read_only';
Variable_name	Value
read_only	ON
show variables like 'read_only';
Variable_name	Value
read_only	ON
show tenant status;
Tenant	Status
sys	read only
select @@global.read_only;
@@global.read_only
1
# All allowed with super privilege
START TRANSACTION;
COMMIT;
START TRANSACTION READ ONLY;
COMMIT;
START TRANSACTION READ WRITE;
COMMIT;
# We allow implicit RW transaction without super privilege
# for compatibility reasons
show global variables like 'read_only';
Variable_name	Value
read_only	ON
show variables like 'read_only';
Variable_name	Value
read_only	ON
show tenant status;
Tenant	Status
sys	read only
select @@global.read_only;
@@global.read_only
1
START TRANSACTION;
# Check that table updates are still disallowed.
INSERT INTO t1 VALUES (3);
ERROR HY000: The MySQL server is running with the --read-only option so it cannot execute this statement
UPDATE t1 SET a= 1;
ERROR HY000: The MySQL server is running with the --read-only option so it cannot execute this statement
DELETE FROM t1;
ERROR HY000: The MySQL server is running with the --read-only option so it cannot execute this statement
COMMIT;
START TRANSACTION READ ONLY;
COMMIT;
# Explicit RW trans is not allowed without super privilege
START TRANSACTION READ WRITE;
ERROR HY000: The MySQL server is running with the --read-only option so it cannot execute this statement
COMMIT;
set global read_only = off;
