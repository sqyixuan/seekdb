create table t1(pk int primary key, a int);
create table t2(pk int primary key, a int);
insert into t1 values(1,1),(2,1),(3,2),(4,2);
insert into t2 values(1,1),(2,2),(3,3),(4,4);
prepare stmt from select * from t1, t2 where t1.pk = t2.a and t1.pk > 1 and t1.pk < 4;
execute stmt;
pk	a	pk	a
2	1	2	2
3	2	3	3
execute stmt;
pk	a	pk	a
2	1	2	2
3	2	3	3
create index iloveidx on t2(a);
alter system major freeze tenant = sys;
alter system major freeze tenant = all_user;
alter system major freeze tenant = all_meta;
execute stmt;
pk	a	pk	a
2	1	2	2
3	2	3	3
execute stmt;
pk	a	pk	a
2	1	2	2
3	2	3	3
execute stmt;
pk	a	pk	a
2	1	2	2
3	2	3	3
drop table t1, t2;
