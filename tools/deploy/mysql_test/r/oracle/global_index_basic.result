## build global index table with subpartition
create table t1(c1 int, c2 int, c3 int, c4 int, primary key(c1, c2)) partition by hash(c1)  subpartition by range columns(c2)  subpartition template ( subpartition p0 values less than (5),   subpartition p1 values less than (100)) partitions 2;
affected rows: 0
create index i1 on t1(c3) global partition by hash(c3) partitions 2;
affected rows: 0
drop table t1;
affected rows: 0

