result_format: 3
DROP DATABASE IF EXISTS HJ_LEFT_EMPTY;
CREATE DATABASE HJ_LEFT_EMPTY;
USE HJ_LEFT_EMPTY;
create table T1 (c1 int, c2 int);
create table T2 (d1 int, d2 int);
explain select /*+ use_hash(T1 T2) leading(T1 T2) */ * from T1, T2 where T1.c1 = T2.d1;
Query Plan
======================================
|ID|OPERATOR   |NAME|EST. ROWS|COST  |
--------------------------------------
|0 |HASH JOIN  |    |196020   |197532|
|1 | TABLE SCAN|t1  |1000     |499   |
|2 | TABLE SCAN|t2  |100000   |46673 |
======================================

Outputs & filters: 
-------------------------------------
  0 - output([t1.c1], [t1.c2], [t2.d1], [t2.d2]), filter(nil), 
      equal_conds([t1.c1 = t2.d1]), other_conds(nil)
  1 - output([t1.c1], [t1.c2]), filter(nil), 
      access([t1.c1], [t1.c2]), partitions(p0)
  2 - output([t2.d1], [t2.d2]), filter(nil), 
      access([t2.d1], [t2.d2]), partitions(p0)

# 插入100000条数据之后。这个时候如果扫描右表将花费较多的时间，100ms应超时，但由于加了
# 特殊处理，这里理论上不会超时
set @@ob_query_timeout = 100000;
select /*+ use_hash(T1 T2) leading(T1 T2) */ * from T1, T2 where T1.c1 = T2.d1;
+------+------+------+------+
| c1   | c2   | d1   | d2   |
+------+------+------+------+
+------+------+------+------+
set @@ob_query_timeout = 10000000;
insert into T1 values (12345678, 12345678);
# 插入100000条数据之后。这个时候如果扫描右表将花费较多的时间，100ms应超时，且左表此时
# 有数据，不能特殊处理
set @@ob_query_timeout = 100000;
select /*+ use_hash(T1 T2) leading(T1 T2) */ * from T1, T2 where T1.c1 = T2.d1;
ERROR HY000: Timeout
set @@ob_query_timeout=10000000;
USE HJ_LEFT_EMPTY;
DROP DATABASE IF EXISTS HJ_LEFT_EMPTY;
