-------------------------------------
  0 - output(nil), filter(nil), params([{t1: (t1.i1, t1.pk2, t1.pk1, t1.v1)}])
  1 - output([t1.i1], [t1.pk2], [t1.pk1], [t1.v1]), filter([t1.pk1 < 15]), 
      access([t1.i1], [t1.pk2], [t1.pk1], [t1.v1]), partitions(p0)

