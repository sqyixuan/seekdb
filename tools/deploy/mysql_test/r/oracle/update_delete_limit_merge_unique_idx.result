drop table if exists t1;
create table t1 (pk1 int,pk2 int, i1 int, v1 varchar(20),primary key(i1,pk2));
create unique index idx1 on t1(pk1,i1,pk2);
alter system major freeze tenant = sys;
alter system major freeze tenant = all_user;
alter system major freeze tenant = all_meta;
alter system major freeze tenant = sys;
alter system major freeze tenant = all_user;
alter system major freeze tenant = all_meta;
insert into t1 values(1,1,1,'a'),(2,2,2,'b'),(3,3,3,'c'),(4,4,4,'d'),(5,5,5,'e');
update t1 set pk1=4 where pk1=1;
update t1 set pk1=6,v1='d' where pk1=3;
select * from t1;
pk1	pk2	i1	v1
4	1	1	a
2	2	2	b
6	3	3	d
4	4	4	d
5	5	5	e
update t1 set pk1=4 where pk1<15 limit 2;
select * from t1;
pk1	pk2	i1	v1
4	1	1	a
4	2	2	b
6	3	3	d
4	4	4	d
5	5	5	e
update t1 set pk1=8 where pk1<15 order by pk2 asc  limit 2;
select * from t1;
pk1	pk2	i1	v1
8	1	1	a
8	2	2	b
6	3	3	d
4	4	4	d
5	5	5	e
update t1 set pk1=7 where pk1<15 order by pk2 limit 2,1;
select * from t1;
pk1	pk2	i1	v1
8	1	1	a
8	2	2	b
7	3	3	d
4	4	4	d
5	5	5	e
update t1 set pk1=6,v1='d' where pk1=3 limit 0;
select * from t1;
pk1	pk2	i1	v1
8	1	1	a
8	2	2	b
7	3	3	d
4	4	4	d
5	5	5	e
update t1 set v1=4 where pk1<15 limit 2;
select * from t1;
pk1	pk2	i1	v1
8	1	1	4
8	2	2	4
7	3	3	d
4	4	4	d
5	5	5	e
update t1 set v1=8 where pk1<15 order by pk2 asc  limit 2;
select * from t1;
pk1	pk2	i1	v1
8	1	1	8
8	2	2	8
7	3	3	d
4	4	4	d
5	5	5	e
update t1 set v1=7 where pk1<15 order by pk2 limit 2,1;
select * from t1;
pk1	pk2	i1	v1
8	1	1	8
8	2	2	8
7	3	3	7
4	4	4	d
5	5	5	e
update t1 set pk1=6,v1='d' where pk1=3 limit 0;
select * from t1;
pk1	pk2	i1	v1
8	1	1	8
8	2	2	8
7	3	3	7
4	4	4	d
5	5	5	e
explain delete from t1 where pk1<15;
