## test for NULL value any/all
drop table if exists null_t1,null_t2,null_t3;
create table null_t1 (c1 int primary key);
create table null_t2 (c2 int ,index(c2));
create table null_t3 (c3 int ,index(c3));
insert into null_t1 values(1),(10);
insert into null_t2 values(5),(NULL),(NULL);
insert into null_t3 values(NULL),(NULL),(NULL);
select * from null_t1 where c1 > any (select c2 from null_t2);
c1
10
select * from null_t1 where c1 < any (select c2 from null_t2);
c1
1
select * from null_t1 where c1 > any (select c3 from null_t3);
c1
select * from null_t1 where c1 < any (select c3 from null_t3);
c1
drop table if exists null_t1, null_t2, null_t3;
select max(1) from agg_table order by 1;
