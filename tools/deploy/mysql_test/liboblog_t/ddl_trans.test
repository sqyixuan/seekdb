#owner: wanhong.wwh
#owner group: liboblog
#description: 测试包含DDL表的事务，要求liboblog正确过滤__all_ddl_operation表数据
#tags: cost

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
connect (obsys1,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
--echo $OBMYSQL_MS0;
connection obsys1;
use oceanbase;
set @@ob_query_timeout = 10000000000;
set @@ob_log_level = 'WARN';

use oceanbase;

drop table if exists ddl_test;
create table ddl_test (pk int primary key);

# 包含读__all_ddl_operation表的事务
begin;
replace into ddl_test values (1);
select * from __all_ddl_operation;
commit;


# 事务排序后, 可能导致安全位点无法推进
# 比如该场景：两个参与者, DDL分区+DML分区
# 在定序后-Committer, 当作DDL处理还是DML处理呢？
# 包含写__all_ddl_operation的事务
#begin;
#let $now  = query_get_value(select time_to_usec(now()), now, 1);
#eval replace into __all_ddl_operation (schema_version, tenant_id, user_id, database_id, database_name, tablegroup_id, table_id, table_name, operation_type, ddl_stmt_str) values ($now, 1, 0, 0, '', 0, 0, '', 4, '');
#eval delete from __all_ddl_operation where schema_version = $now;
#replace into ddl_test values (1);
#commit;
