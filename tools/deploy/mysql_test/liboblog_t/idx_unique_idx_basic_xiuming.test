#owner: wanhong.wwh
#owner group: liboblog
#description: Test unique index basic information in liboblog
#tags: cost

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

# 不包含唯一索引
--disable_warnings
drop table if exists t_no_uk;
--enable_warnings
create table t_no_uk(pk int primary key, c1 int, c2 int);
replace into t_no_uk values (1, 1, 1);

# 包含单个唯一索引
--disable_warnings
drop table if exists t_single_uk;
--enable_warnings
create table t_single_uk(pk int primary key, c1 int, c2 int, unique key (c1));
replace into t_single_uk values (1, 1, 1);

# 包含组合唯一索引
--disable_warnings
drop table if exists t_comp_uk;
--enable_warnings
create table t_comp_uk(pk int primary key, c1 int, c2 int, unique key (c1, c2));
replace into t_comp_uk values (1, 1, 1);

# 包含多个唯一索引
--disable_warnings
drop table if exists t_multiple_uk;
--enable_warnings
create table t_multiple_uk(pk int primary key, c1 int, c2 int, unique key UK1 (c1, c2), unique key UK2 (c1), unique key UK3 (c2), unique key UK4 (pk, c1, c2), unique key UK5 (pk, c1));
replace into t_multiple_uk values (1, 1, 1);

# 表列很多
--disable_warnings
drop table if exists t_many_column_with_uk;
--enable_warnings
--let $const=511
--let $create_sql=create table t_many_column_with_uk(pk int primary key
--let $field=1
--let $counter=$const
while($counter)
{
   --let $create_sql=$create_sql , f$field int
   inc $field;
   dec $counter;
}

--let $create_sql=$create_sql , unique key UK1 (f1), unique key uk2 (f511, f510), unique key uk3 (f356, f342, f100, f1, f234), unique key uk4 (pk

--let $field=1
--let $counter=63
while($counter)
{
   --let $create_sql=$create_sql , f$field
   inc $field;
   dec $counter;
}
--let $create_sql=$create_sql ))
eval $create_sql;

replace into t_many_column_with_uk (pk, f1) values (1, 1);
