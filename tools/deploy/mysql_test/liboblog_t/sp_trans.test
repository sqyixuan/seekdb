--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

# owner: 修铭
# owner group: liboblog
# description: 验证単分区事务，包括autocommit=0和1，以及大事务

--disable_warnings
drop table if exists sp_simple;
drop table if exists sp_big;
--enable_warnings

create table sp_simple(pk int primary key, v1 varchar(10), v2 datetime);
create table sp_big(pk int primary key, v1 varchar(65536), v2 varchar(65536), v3 varchar(65536));

#--disable_query_log
#--disable_result_log

set ob_org_cluster_id=1234;

# 验证autocommit=1
set autocommit=1;
replace into sp_simple values (1, 1, '2017-1-19 20:00:00');

# 验证autocommit=0
set autocommit=0;
replace into sp_simple values (1, 1, '2017-1-19 20:00:00');
commit;

# 验证大事务
begin;
let $i=0;
while($i < 10)
{
    eval insert into sp_big values($i, repeat('1',65536), repeat('2',65536), repeat('3',65536));
    inc $i;
}
commit;

begin;
let $i=0;
while($i < 10)
{
    eval update sp_big set v1=repeat('a',65536), v2=repeat('b',65536), v3=repeat('c',65536) where pk=$i;
    inc $i;
}
commit;

begin;
let $i=0;
while($i < 10)
{
    eval delete from sp_big where pk=$i;
    inc $i;
}
commit;
