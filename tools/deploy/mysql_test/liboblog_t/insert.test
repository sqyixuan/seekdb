--disable_warnings
drop table if exists t1,t2,t3,t4,t5,t6,t7;
--enable_warnings
#--disable_abort_on_error
##
# bug:
# 非strict模式下， not null 将插入列的隐式默认值；
##

CREATE TABLE t1 (a INT PRIMARY KEY, b INT NOT NULL);

--error 1364
INSERT INTO t1 (a) VALUES (1);

--error 1364
INSERT INTO t1 (a) VALUES (1) ON DUPLICATE KEY UPDATE a = b;

###
# Bug http://bugfree.corp.taobao.com/bug/214981
##
create table t2(pk1 int, pk2 int, pk3 int default 0, primary key(pk1,pk2), extra int);
insert /*agadgafdgafdghfdhggh*/ into t2(pk1,pk2) values(0,1),(-1,0);
insert into t2(pk1,pk2) values(1,2),(2,3);
insert into t2(pk2,pk1) values(4,3),(5,4);
select * from t2;
select pk2,pk1 from t2;


create table t3(pk1 int primary key, a int);
insert into t3 values(0,1),(-1,0);
insert into t3(pk1,a) values(1,2),(2,3);
insert into t3(a,pk1) values(4,3),(5,4);
select * from t3;
select a,pk1 from t3;

create table t4(pk1 int, pk2 int, primary key(pk1,pk2), extra int);
insert into t4(pk1,pk2) values(0,1),(-1,0),(3,1),(4,0),(5,1),(6,0);
insert into t4(pk1,pk2) values(1,2),(2,3),(7,1),(8,0),(9,1),(10,0);
create table t5(pk1 int, pk2 int, primary key(pk1,pk2), extra int);
insert into t5 select * from t4;
select * from (select * from t4) as tmp1 where pk1>0;
select * from t4;
select * from t4 where pk1>0 limit 1,10;
select * from t4 where pk1>0 limit 3,10;
select * from (select * from t4) tt4;
delete from t4 where pk2=3 and pk1=2;

#test insert hex data,in 10 decimal
CREATE TABLE t6(a BIGINT primary key);
INSERT INTO t6 VALUES (0xFFFFFFFFFFFFF);
INSERT INTO t6 VALUES (0xF);
select * from t6;
SELECT * FROM t6 WHERE a=-1 OR a=-2 OR a=16;
SELECT * FROM t6 WHERE a in (-1,-2,16);
CREATE TABLE t7(a int primary key);
INSERT INTO t7 VALUES (0xF1); 
INSERT INTO t7 VALUES (0x01); 
select * from t7;
select * from t7 where a=1;
select * from t7 where a in (1);


