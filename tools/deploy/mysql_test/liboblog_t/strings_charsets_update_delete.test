#check table t7;
INSERT INTO t7 VALUES('uU');
#check table t7;
INSERT INTO t7 VALUES('uu');
#check table t7;
INSERT INTO t7 VALUES('uuABC');
#check table t7;
INSERT INTO t7 VALUES('UuABC');
#check table t7;
INSERT INTO t7 VALUES('uuABC');
#check table t7;
alter table t7 add b int;
