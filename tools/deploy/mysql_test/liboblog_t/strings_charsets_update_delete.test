#Tests for utf8 character set 
CREATE TABLE t8 (a char(10) character set utf8 not null);
INSERT INTO t8 VALUES ('a'),('a\0'),('a\t'),('a ');
# SELECT hex(a),STRCMP(a,'a'), STRCMP(a,'a ') FROM t8;
SELECT hex(a),a='a', a='a ' FROM t8;

CREATE TABLE t7(a VARCHAR(255), KEY(a)) DEFAULT CHARSET=utf8;
eval INSERT INTO t7 VALUES('uUABCDEFGHIGKLMNOPRSTUVWXYZbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb');
