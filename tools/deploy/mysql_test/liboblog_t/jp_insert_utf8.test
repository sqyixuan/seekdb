#
# Test INSERT() function with Japanese characters in utf8 encoding
#

SET NAMES utf8;
SET character_set_database = utf8;

CREATE TABLE `пјҙпј‘` (`пјЈпј‘` char(5)) DEFAULT CHARSET = utf8;
CREATE TABLE `пјҙпј’` (`пјЈпј‘` char(5)) DEFAULT CHARSET = utf8;
CREATE TABLE `пјҙпј“` (`пјЈпј‘` char(5)) DEFAULT CHARSET = utf8;
CREATE TABLE `пјҙпј”` (`пјЈпј‘` char(5)) DEFAULT CHARSET = utf8;
CREATE TABLE `пјҙпј•` (`пјЈпј‘` char(5)) DEFAULT CHARSET = utf8;
CREATE TABLE `пјҙпј–` (`пјЈпј‘` char(5)) DEFAULT CHARSET = utf8;
CREATE TABLE `пјҙпј—` (`пјЈпј‘` char(5)) DEFAULT CHARSET = utf8;
CREATE TABLE `пјҙпјҳ` (`пјЈпј‘` char(5)) DEFAULT CHARSET = utf8;
CREATE TABLE `пјҙпјҷ` (`пјЈпј‘` char(5)) DEFAULT CHARSET = utf8;

INSERT INTO `пјҙпј‘` VALUES ('пҪұпҪІпҪіпҪҙпҪө');
INSERT INTO `пјҙпј’` VALUES ('гҒӮгҒ„гҒҶгҒҲгҒҠ');
INSERT INTO `пјҙпј“` VALUES ('йҫ”йҫ–йҫ—йҫһйҫЎ');
