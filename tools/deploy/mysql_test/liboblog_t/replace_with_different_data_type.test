--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: zhiyong.jzy
# owner group: SQL3
# description: foobar
# owner: zhiyong.jzy
# owner group: SQL3
# description: foobar

#--disable_abort_on_error

drop database  if exists oblog_db;
create database oblog_db;
use oblog_db;

--enable_info
## 三、带timestamp列，bigint(100)
create table  t_1(c1 bigint primary key, c2 int auto_increment unique, c3 timestamp, c4 decimal(5,3), c5 varchar(20), c6 int, unique index(c3) , unique index(c4), index (c5));
insert into t_1 (c1, c2, c3, c4, c5, c6) values(1, 1, '2015-11-12 00:00:00', 1.33, 'aaaa', 1),(2, 2, '2015-11-14 00:00:00', 2.33, 'aaab', 2),(3, 3, '2015-11-13 00:00:00', 3.33, 'aaac', 3);

## 1.插入一新行 affected rows = 1
replace into t_1 (c1, c3, c4,c5) values(4, '2015-11-15 00:00:00', 4.33, 'aad');
select * from t_1;

## 2. 插入行在多个唯一索引列有冲突，affected rows =>冲突行数+插入行数

## c1,c3列有冲突 => 4
replace into t_1 values(1, 5, '2015-11-14 00:00:00', 3.331, 'aaac', 5);
select * from t_1;

## 在所有索引列有冲突
replace into t_1 values(6, 5, '2015-11-13 00:00:00', 4.330, 'aaac', 5);
select * from t_1;

## 在所有列有冲突，但值完全一样 =>1
replace into t_1 values(6, 5, '2015-11-13 00:00:00', 4.330, 'aaac', 5);
select * from t_1;

