--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner : zhenjiang.xzj, madoll.tw
#owner group: liboblog
#description: basic alter table partition by
#

create database offline_ddl_alter_part;

--disable_warnings
drop table if exists t5;
--enable_warnings

--echo #测试非分区表转换成一级分区表
create table t5(c1 int, c2 datetime, primary key(c1, c2));
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t5;
insert into t5 values(1,'2016-12-12');
alter table t5 partition by hash(c1) partitions 4;
insert into t5 values(2,'2018-12-12');
insert into t5 values(3,'2018-12-12');
insert into t5 values(4,'2018-12-12');
insert into t5 values(5,'2018-12-12');
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t5;
drop table t5;

--echo #测试非分区表转换成模板二级分区表
create table t5(c1 int, c2 datetime, primary key(c1, c2));
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t5;
insert into t5 values(1,'2016-12-12');
alter table t5 partition by hash(c1)
                subpartition by range columns(c2)
                subpartition template(
                subpartition p1 values less than ('2016-10-10'),
                subpartition p2 values less than ('2116-3-30'))
                partitions 2;
insert into t5 values(2,'2016-09-16');
insert into t5 values(3,'2016-10-10');
insert into t5 values(4,'2018-10-10');
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t5;
drop table t5;

--echo #测试非分区表转换成非模板二级分区表
create table t5(c1 int, c2 datetime, primary key(c1, c2));
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t5;
insert into t5 values(1,'2016-12-12');
alter table t5 partition by range(c1) subpartition by key(c2) subpartitions 5 (partition p0 values less than(0), partition p1 values less than(100));
insert into t5 values(2,'2018-12-12');
insert into t5 values(3,'2018-12-12');
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t5;
drop table t5;

--echo #测试一级分区表转换成一级分区表
create table t5(c1 int, c2 datetime, primary key(c1, c2)) partition by hash(c1) partitions 4;
insert into t5 values(1,'2016-12-12');
alter table t5 partition by key(c1) partitions 10;
insert into t5 values(3,'2018-12-12');
insert into t5 values(5,'2018-12-12');
insert into t5 values(7,'2018-12-12');
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t5;
drop table t5;

--echo #测试一级分区表转换成模板二级分区表
create table t5(c1 int, c2 datetime, primary key(c1, c2)) partition by hash(c1) partitions 4;
insert into t5 values(1,'2016-12-12');
alter table t5 partition by hash(c1)
                subpartition by range columns(c2)
                subpartition template(
                subpartition p1 values less than ('2016-10-10'),
                subpartition p2 values less than ('2116-3-30'))
                partitions 2;
insert into t5 values(2,'2016-09-16');
insert into t5 values(3,'2016-10-10');
insert into t5 values(4,'2018-10-10');
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t5;
drop table t5;

--echo #测试一级分区表转换成非模板二级分区表
create table t5(c1 int, c2 datetime, primary key(c1, c2)) partition by hash(c1) partitions 4;
insert into t5 values(1,'2016-12-12');
alter table t5 partition by range(c1) subpartition by key(c2) subpartitions 5 (partition p0 values less than(0), partition p1 values less than(100));
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t5;
drop table t5;

--echo #测试模板二级分区表转换成一级分区表
create table t5(c1 int, c2 datetime, primary key(c1, c2)) partition by hash(c1)
                subpartition by range columns(c2)
                subpartition template(
                subpartition p1 values less than ('2016-10-10'),
                subpartition p2 values less than ('2116-3-30'))
                partitions 2;
insert into t5 values(1,'2016-12-12');
alter table t5 partition by hash(c1) partitions 4;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t5;
drop table t5;

--echo #测试模板二级分区表转换成模板二级分区表
create table t5(c1 int, c2 datetime, primary key(c1, c2)) partition by hash(c1)
                subpartition by range columns(c2)
                subpartition template(
                subpartition p1 values less than ('2016-10-10'),
                subpartition p2 values less than ('2116-3-30'))
                partitions 2;
insert into t5 values(1,'2016-12-12');
alter table t5 partition by key(c1)
                subpartition by range columns(c2)
                subpartition template(
                subpartition p1 values less than ('2016-10-10'),
                subpartition p2 values less than ('2116-3-30'),
                subpartition p3 values less than ('2136-4-30'))
                partitions 10;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t5;
drop table t5;

--echo #测试模板二级分区表转换成非模板二级分区表
create table t5(c1 int, c2 datetime, primary key(c1, c2)) partition by hash(c1)
                subpartition by range columns(c2)
                subpartition template(
                subpartition p1 values less than ('2016-10-10'),
                subpartition p2 values less than ('2116-3-30'))
                partitions 2;
insert into t5 values(1,'2016-12-12');
alter table t5 partition by range(c1) subpartition by key(c2) subpartitions 5 (partition p0 values less than(0), partition p1 values less than(100));
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t5;
drop table t5;

--echo #测试非模板二级分区表转换成一级分区表
create table t5(c1 int, c2 datetime, primary key(c1, c2)) partition by range(c1)
                subpartition by key(c2)
                subpartitions 5 (
                partition p0 values less than(0),
                partition p1 values less than(100));
insert into t5 values(1,'2016-12-12');
alter table t5 partition by hash(c1) partitions 4;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t5;
drop table t5;

--echo #测试非模板二级分区表转换成一级分区表
create table t5(c1 int, c2 datetime, primary key(c1, c2)) partition by range(c1)
                subpartition by key(c2)
                subpartitions 5 (
                partition p0 values less than(0),
                partition p1 values less than(100));
insert into t5 values(1,'2016-12-12');
alter table t5 partition by hash(c1) partitions 4;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t5;
drop table t5;

--echo #测试非模板二级分区表转换成模板二级分区表
create table t5(c1 int, c2 datetime, primary key(c1, c2)) partition by range(c1)
                subpartition by key(c2)
                subpartitions 5 (
                partition p0 values less than(0),
                partition p1 values less than(100));
insert into t5 values(1,'2016-12-12');
alter table t5 partition by hash(c1)
                subpartition by range columns(c2)
                subpartition template(
                subpartition p1 values less than ('2016-10-10'),
                subpartition p2 values less than ('2116-3-30'))
                partitions 2;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t5;
drop table t5;

--echo #测试非模板二级分区表转换成非模板二级分区表
create table t5(c1 int, c2 datetime, primary key(c1, c2)) partition by range(c1)
                subpartition by key(c2)
                subpartitions 5 (
                partition p0 values less than(0),
                partition p1 values less than(100));
insert into t5 values(1,'2016-12-12');
alter table t5 partition by range(c1)
                subpartition by key(c2)
                subpartitions 5 (
                partition p0 values less than(0),
                partition p1 values less than(100),
                partition p2 values less than(200),
                partition p3 values less than(300),
                partition p4 values less than(400));
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t5;
drop table t5;

--echo #测试tablegroup内的表不支持转换
--echo #测试tablegroup非分区表转换成一级分区表
drop tablegroup if exists t_luofan;
create tablegroup t_luofan;
create table t5(c1 int, c2 datetime, primary key(c1, c2)) tablegroup=t_luofan;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t5;
insert into t5 values(1,'2016-12-12');
--error 4179
alter table t5 partition by hash(c1) partitions 4;
drop table t5;

--echo #测试tablegroup非分区表转换成模板二级分区表
drop tablegroup if exists t_luofan;
create tablegroup t_luofan;
create table t5(c1 int, c2 datetime, primary key(c1, c2)) tablegroup=t_luofan;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t5;
insert into t5 values(1,'2016-12-12');
--error 4179
alter table t5 partition by hash(c1)
                subpartition by range columns(c2)
                subpartition template(
                subpartition p1 values less than ('2016-10-10'),
                subpartition p2 values less than ('2116-3-30'))
                partitions 2;
drop table t5;

--echo #测试tablegroup非分区表转换成非模板二级分区表
drop tablegroup if exists t_luofan;
create tablegroup t_luofan;
create table t5(c1 int, c2 datetime, primary key(c1, c2)) tablegroup=t_luofan;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t5;
insert into t5 values(1,'2016-12-12');
--error 4179
alter table t5 partition by range(c1) subpartition by key(c2) subpartitions 5 (partition p0 values less than(0), partition p1 values less than(100));
drop table t5;

--echo #测试tablegroup一级分区表转换成模板二级分区表
drop tablegroup if exists t_luofan;
create tablegroup t_luofan;
create table t5(c1 int, c2 datetime, primary key(c1, c2)) tablegroup=t_luofan partition by hash(c1) partitions 4;
insert into t5 values(1,'2016-12-12');
--error 4179
alter table t5 partition by hash(c1)
                subpartition by range columns(c2)
                subpartition template(
                subpartition p1 values less than ('2016-10-10'),
                subpartition p2 values less than ('2116-3-30'))
                partitions 2;
insert into t5 values(2,'2016-09-16');
insert into t5 values(3,'2016-10-10');
insert into t5 values(4,'2018-10-10');
drop table t5;

--echo #测试tablegroup一级分区表转换成非模板二级分区表
drop tablegroup if exists t_luofan;
create tablegroup t_luofan;
create table t5(c1 int, c2 datetime, primary key(c1, c2)) tablegroup=t_luofan partition by hash(c1) partitions 4;
insert into t5 values(1,'2016-12-12');
--error 4179
alter table t5 partition by range(c1) subpartition by key(c2) subpartitions 5 (partition p0 values less than(0), partition p1 values less than(100));
drop table t5;

--echo #测试非模板二级分区表转换成一级分区表
drop tablegroup if exists t_luofan;
create tablegroup t_luofan;
create table t5(c1 int primary key, c2 int) tablegroup = "t_luofan" partition by range(c1) subpartition by hash(c1)
subpartitions 2 (
partition p0 values less than (100),
partition p1 values less than (maxvalue));
insert into t5 values(20, 20);
--error 4179
alter table t5 partition by hash(c1) partitions 4;
drop table t5;

drop database offline_ddl_alter_part;
