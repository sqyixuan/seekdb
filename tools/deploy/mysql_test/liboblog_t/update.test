--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: guangang.gg
# owner group: SQL4
# description: foobar
#
# test of updating of keys
#
--disable_abort_on_error
--disable_warnings
drop table if exists t1,t2,t3,t4;
--enable_warnings

create table t1 (a int auto_increment,b int ,key (a));
insert into t1(b) values(NULL),(NULL);
insert into t1 values(NULL,1),(NULL,2);
update /*adgagafgafg*/ t1 set b=3 where a = NULL;
update t1 set b=2 where b =1;
select * from t1;


create table t2(a int primary key, b int);
insert into t2 values(1,1),(2,2);
update t2 set b=0 where a=1;
select * from t2;
update t2 set b=0 where a=2 and b=1;
select * from t2;
update t2 set b=0 where a=2 and b=2;
select * from t2;

create table t3(a varchar(124) primary key, b varchar(1024));
insert into t3 values(1,1),(2,2);
update t3 set b=0 where a=1;
select * from t3;
update t3 set b=0 where a=2 and b=1;
select * from t3;
update t3 set b=0 where a=2 and b=2;
select * from t3;
--echo test update whether support use alias table
update t3 tt set tt.b=1 where tt.a=1;
select * from t3;
update t3 as tt set tt.b=2 where tt.a=1;
select * from t3;
update t3 tt set b=3 where a=1;
select * from t3;
update t3 tt set b=4 where a=1;
select * from t3;
update t3 tt set b=5 where tt.a=1;
select * from t3;
update t3 set t3.b=6 where t3.a=1;
select * from t3;
--error 1288 
update (select * from t3) as tt set tt.b=6 where tt.a=1;
--echo update rowkey use alias table
update t3 as tt set tt.a=3 where tt.a=1;
select * from t3;



create table t4 (pk int primary key, a int, b int);

insert into t4 values(1,1,1),(2,1,1),(3,NULL,NULL),(4,1,1);

update t4 set a=0 where pk=1;
update t4 set a=2 where pk=1 and a=0;
update t4 set a=3 where pk=1 and a=0;

update t4 set a=0 where pk=2 or a=1;
update t4 set a=0 where pk=2 and a=1;


update t4 set a=0 where pk=3 and a=NULL;
update t4 set a=0 where pk=3 and a is NULL;
update t4 set a=NULL where pk=3 and a=0;

update t4 set a=0 where pk=4 and (a=2 or a=3);
update t4 set a=0 where pk=4 and (a=2 or a=1);
update t4 set a=10 where pk=4 and (a=2 or a=0);

select * from t4;

--enable_abort_on_error
