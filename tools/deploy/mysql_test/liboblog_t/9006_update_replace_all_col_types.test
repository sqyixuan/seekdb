--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
##
#
# 测试功能点：update/replace all types
#
##

--disable_warnings
drop table if exists t1,t2,t3,t4;
--enable_warnings

create table t1(c1 bigint, c2 varchar(1638), primary key(c1,c2), c3 numeric, c4 datetime, c5 int);
sleep 2;

##----------------------------------- replace with all cloumns specified --------------------------------
# boundary for bigint/int
replace into t1 values(1,'aaa',1.5,'2000-01-01',0);

 replace into t1 values(-92233720,'aaa',1.5,'2000-01-01',-92233720); 

replace into t1 values(9223372,'aaa',1.5,'2000-01-01',9223372);


# boundary for datetime
replace into t1 values(10,'aaa',1.5,'1970-01-01',0);

replace into t1 values(12,'aaa',1.5,'2101-12-31',0);

replace into t1 values(13,'aaa',1.5,'9999-01-01',0);

#--error 1292
replace into t1 values(16,'aaa',1.5,'0001-00-00',0);

replace into t1 values(17,'aaa',1.5,'0001-01-01',0);

replace into t1 values(18,'aaa',1.5,'9999-12-31',0);

--error 1292
replace into t1 values(19,'aaa',1.5,'9999-12-32',0);

##----------------------------------- replace with only part of cloumns specified --------------------------------
# boundary for bigint/int
replace into t1 values(1,'aaa',1.5,'2000-01-01',0);

replace into t1 values(-92233720,'aaa',1.5,'2000-01-01',-92233720);

replace into t1 values(9223372,'aaa',1.5,'2000-01-01',9223372);


# boundary for datetime
replace into t1(c1,c2,c4,c5) values(10,'bbb','1970-01-01',0);

replace into t1(c1,c2,c4,c5) values(12,'bbb','2101-12-31',0);

replace into t1(c1,c2,c4,c5) values(13,'bbb','9999-01-01',0);

#--error 1292
replace into t1(c1,c2,c4,c5) values(16,'bbb','0001-00-00',0);
replace into t1(c1,c2,c4,c5) values(17,'bbb','0001-01-01',0);

replace into t1(c1,c2,c4,c5) values(18,'bbb','9999-12-31',0);

--error 1292
replace into t1(c1,c2,c4,c5) values(19,'bbb','9999-12-32',0);

##----------------------------------- update with only part of cloumns specified --------------------------------
# boundary for bigint/int
update t1 set c1=-922,c2='bbb-update' where c1=-92233720 and c2='aaa';

update t1 set c1=-92209,c2='bbb-update2' where c1=-92233720 and c3=1.5;
update t1 set c1=922000,c5=922300 where c1=9223372 and c2='aaa';


# boundary for datetime
update t1 set c4='0001-01-01',c2='aaa-update' where c1=1 and c2='aaa';

update t1 set c4='9999-12-31',c2='aaa-update2' where c1=1 and c2='aaa-update';

--error 1292
update t1 set c4='9999-13-31',c2='bbb' where c1=1;


