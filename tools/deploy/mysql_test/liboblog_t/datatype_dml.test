--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: zuojiao.hzj
# owner group: SQL3
# Test of datatype dml functions

--disable_warnings
drop table if exists t;
--enable_warnings
create table t(
  id            int primary key auto_increment,
  col_int8      tinyint default 1,
  col_int16     smallint,
  col_int24     mediumint default 2,
  col_int32     int,
  col_int64     bigint,
  col_uint8     tinyint unsigned,
  col_uint16    smallint unsigned,
  col_uint24    mediumint unsigned default 10000,
  col_uint32    int unsigned,
  col_uint64    bigint unsigned,
  col_float     float,
  col_double    double,
  col_ufloat    float unsigned,
  col_udouble   double unsigned,
  col_decimal   decimal(20, 2) default 11.11,
  col_udecimal  decimal(20, 4) unsigned,
  col_datetime  datetime(2),
  col_timestamp timestamp(3) default '2020-01-01 00:00:00',
  col_date      date,
  col_time      time(4),
  col_year      year(4),
  col_varchar   varchar(6) default 'helo$',
  col_char      char(5),
  col_varbinary varbinary(5) default 'word#',
  col_binary    binary(4)
);
--disable_result_log
--disable_abort_on_error
set sql_mode='strict_all_tables';
insert into t(col_varchar) values ('bb        ');
insert into t(col_varchar) values (0x6565202020202020202020);
insert into t(col_varchar) values ('支付宝          ');
insert into t(col_char) values ('cc       !');
insert into t(col_char) values (0x6565202020202020202020);
insert into t(col_char) values ('支付宝          ');
insert into t(col_varbinary) values (0x6565202020202020202020);
insert into t(col_binary) values ('cc       !');
insert into t(col_binary) values (0x6868000000000000000021);
set sql_mode='';
delete from t;

set sql_mode='strict_all_tables';
--disable_abort_on_error
# test string_int,string_uint
insert into t(col_int64) values ('11a');
insert into t(col_int64) values ('55 5');
insert into t(col_int64) values ('66 a');
insert into t(col_int64) values ('88.a');
insert into t(col_uint64) values ("184467440737095516150");
insert into t(col_uint64) values ('99.9a');
insert into t(col_int64) values('123E2');

