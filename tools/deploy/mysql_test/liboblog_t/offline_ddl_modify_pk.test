--disable_result_log
drop table if exists t1;
--enable_result_log

# Heap-organized table with partition key can have rowkey with some null values.
create table t1(c1 int, c2 int) partition by hash(c2);
insert into t1(c1, c2) values(1, null);
alter table t1 modify column c1 char(10);
insert into t1(c1, c2) values ('a', 1);
drop table t1;


# test add/alter pk to generated column related.
--disable_result_log
DROP TABLE IF EXISTS Z0CASE;
--enable_result_log
CREATE TABLE Z0CASE(C1 CHAR(10), C2 INT, C3 INT GENERATED ALWAYS AS (C2+1) VIRTUAL);
INSERT INTO Z0CASE(c1, c2) values ('1', 1);
ALTER TABLE Z0CASE ADD PRIMARY KEY(C2);
INSERT INTO Z0CASE(c1, c2) values ('2', 2);
DROP TABLE Z0CASE;
CREATE TABLE Z0CASE(C1 CHAR(10), C2 INT, C3 INT GENERATED ALWAYS AS (C2+1) VIRTUAL, PRIMARY KEY(C2));
INSERT INTO Z0CASE(c1, c2) values ('1', 1);
ALTER TABLE Z0CASE DROP PRIMARY KEY, ADD PRIMARY KEY(C2, C1);
INSERT INTO Z0CASE(c1, c2) values ('2', 2);
DROP TABLE Z0CASE;

--disable_warnings
--disable_result_log
drop table if exists t3, t2, t1, t0;
--enable_result_log
--enable_warnings

create table t0(c1 int, c2 int);
insert into t0 values (1, 1);
alter table t0 add primary key(c1);
insert into t0 values (2, 2);
drop table t0;

create table t1(c1 int, c2 char(20), constraint pk1 primary key(c1));
create table t2(c1 int, c2 int, c3 int, constraint pk2 primary key(c1, c2), constraint fk2 foreign key (c1) references t1(c1));
create table t3(c1 int, c2 int, c3 int, constraint pk3 primary key(c2), constraint fk3 foreign key (c1) references t1(c1));
create index idx1 on t3 (c2);
create index idx2 on t3 (c1) storing(c3);
create unique index idx3 on t3(c3) storing (c2);

--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t3;
insert into t1 values (9999, 'OceanBase');
alter table t3 drop primary key;
insert into t3 values (9999, 9999, 9999);
delete from t3 where c1=9999;

--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t3;
select count(*) from t3;
drop table t3, t2, t1;

--echo 2. to test partition table.
create table t1(c1 int, c2 char(20), c3 int, constraint pk1 primary key(c1, c2)) partition by hash(c1) partitions 3;
create index idx1 on t1(c1, c3);
create index idx2 on t1(c1) storing (c2, c3);
create index idx3 on t1(c2) storing (c3);
create unique index idx4 on t1(c1, c3) storing (c2);

--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t1;
insert into t1 values (1, 'a', 1);
alter table t1 drop primary key;
insert into t1 values (2, 'b', 2);
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t1;

alter table t1 add constraint pk1 primary key(c1, c3);
select count(*) from t1;
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t1;
drop table t1;

#
# test of basic insert with text/blob after daily merge
#
--disable_warnings
drop table if exists t1;
--enable_warnings
#
# mix test of some dml with text/blob after daily merge
#
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1 (nr int, a tinyblob, b text, c mediumblob, d longtext);

insert into t1 values(1, 'a', 'b', repeat('c', 100), repeat('d', 100));
insert into t1 values(2, 'aa', 'bb', repeat('c', 200), repeat('d', 200));
insert into t1 values(3, 'aaa', 'bbb', repeat('c', 300), repeat('d', 300));
insert into t1 values(10, 'aaa', 'bbb', repeat('c', 300), repeat('d', 500));
insert into t1 values(4, null, null, null, null);
insert into t1 values(5, '', '', '', '');
select nr, a, b, length(c), length(d) from t1 order by nr asc;
delete from t1 where a is null;
update t1 set c = 'updatemedium', d = 'updatelong' where b = 'bbb';
select nr, a, b, length(c), length(d) from t1 order by nr asc;
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
connection default;
insert into t1 values(6, 'aaa', 'bbb', repeat('c', 300), repeat('d', 600));
insert into t1 values(7, 'aaa', 'bbb', repeat('c', 300), repeat('d', 900));
select crc32(nr), crc32(a), crc32(b), crc32(c), crc32(d) from t1 order by nr;
alter table t1 add primary key(nr);
insert into t1 values(8, 'aaa', 'bbb', repeat('c', 300), repeat('d', 900));
select crc32(nr), crc32(a), crc32(b), crc32(c), crc32(d) from t1 order by nr;
drop table t1;
