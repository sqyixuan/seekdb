#owner: wanhong.wwh
#owner group: liboblog
#description: 校验唯一索引修改

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

# 包含单个唯一索引
--disable_warnings
drop table if exists t_single_uk;
--enable_warnings
create table t_single_uk(pk int primary key, c1 int, unique key (c1));

--let $const=10
--let $counter=$const

while($counter)
{
  replace into t_single_uk values (1, 1);
  replace into t_single_uk values (1, 2);
  replace into t_single_uk values (2, 1);
  replace into t_single_uk values (2, 3);
  replace into t_single_uk values (3, 1);
  replace into t_single_uk values (3, 4);
  replace into t_single_uk values (4, 1);
  replace into t_single_uk values (4, 5);
  replace into t_single_uk values (5, 1);
  replace into t_single_uk values (5, 6);
  replace into t_single_uk values (6, 1);
  replace into t_single_uk values (6, 7);
  replace into t_single_uk values (7, 1);
  replace into t_single_uk values (7, 8);
  replace into t_single_uk values (8, 1);
  replace into t_single_uk values (8, 9);

  replace into t_single_uk values (11, 1);
  replace into t_single_uk values (11, 12);
  replace into t_single_uk values (12, 1);
  replace into t_single_uk values (12, 13);
  replace into t_single_uk values (13, 1);
  replace into t_single_uk values (13, 14);
  replace into t_single_uk values (14, 1);
  replace into t_single_uk values (14, 15);
  replace into t_single_uk values (15, 1);
  replace into t_single_uk values (15, 16);
  replace into t_single_uk values (16, 1);
  replace into t_single_uk values (16, 17);
  replace into t_single_uk values (17, 1);
  replace into t_single_uk values (17, 18);
  replace into t_single_uk values (18, 1);
  replace into t_single_uk values (18, 19);

  replace into t_single_uk values (101, 1);
  replace into t_single_uk values (101, 22);
  replace into t_single_uk values (102, 1);
  replace into t_single_uk values (102, 23);
  replace into t_single_uk values (103, 1);
  replace into t_single_uk values (103, 24);
  replace into t_single_uk values (104, 1);
  replace into t_single_uk values (104, 25);
  replace into t_single_uk values (105, 1);
  replace into t_single_uk values (105, 26);
  replace into t_single_uk values (106, 1);
  replace into t_single_uk values (106, 27);
  replace into t_single_uk values (107, 1);
  replace into t_single_uk values (107, 28);
  replace into t_single_uk values (108, 1);
  replace into t_single_uk values (108, 29);

  replace into t_single_uk values (1001, 1);
  replace into t_single_uk values (1001, 32);
  replace into t_single_uk values (1002, 1);
  replace into t_single_uk values (1002, 33);
  replace into t_single_uk values (1003, 1);
  replace into t_single_uk values (1003, 34);
  replace into t_single_uk values (1004, 1);
  replace into t_single_uk values (1004, 35);
  replace into t_single_uk values (1005, 1);
  replace into t_single_uk values (1005, 36);
  replace into t_single_uk values (1006, 1);
  replace into t_single_uk values (1006, 37);
  replace into t_single_uk values (1007, 1);
  replace into t_single_uk values (1007, 38);
  replace into t_single_uk values (1008, 1);
  replace into t_single_uk values (1008, 39);

  dec $counter;
}
