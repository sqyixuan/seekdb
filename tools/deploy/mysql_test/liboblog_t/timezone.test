--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# This script tests our own time zone support functions
--disable_warnings
drop table if exists t1, t2,t3,t4,t5,t6,t7,t8,t9;
--enable_warnings

create table t1 (ts timestamp);
set time_zone='+00:00';
select unix_timestamp(utc_timestamp())-unix_timestamp(current_timestamp());
insert into t1 (ts) values ('2003-03-30 02:30:00');
set time_zone='+10:30';
select unix_timestamp(utc_timestamp())-unix_timestamp(current_timestamp());
insert into t1 (ts) values ('2003-03-30 02:30:00');
set time_zone='-10:00';
select unix_timestamp(utc_timestamp())-unix_timestamp(current_timestamp());
insert into t1 (ts) values ('2003-03-30 02:30:00');
select * from t1;


# 
# Let us try DB specified time zones
#

create table t2 (i int, ts timestamp);
set time_zone='+10:00';
insert into t2 (i, ts) values
  (unix_timestamp('2003-03-30 01:59:59'),'2003-03-30 01:59:59'),
  (unix_timestamp('2003-03-30 02:30:00'),'2003-03-30 02:30:00'),
  (unix_timestamp('2003-03-30 03:00:00'),'2003-03-30 03:00:00');
set time_zone='-7:00';
select * from t2;

create table t3 (i int, ts timestamp);
# Simple check for time zone just for showing that it works
set time_zone='-9:00';
insert into t3 (i, ts) values
  (unix_timestamp('2004-01-01 00:00:00'),'2004-01-01 00:00:00'),
  (unix_timestamp('2004-03-28 02:30:00'),'2004-03-28 02:30:00'),
  (unix_timestamp('2004-08-01 00:00:00'),'2003-08-01 00:00:00'),
  (unix_timestamp('2004-10-31 02:30:00'),'2004-10-31 02:30:00');
select * from t3;

create table t4 (i int, ts timestamp);
set time_zone='+1:00';
insert into t4 (i, ts) values
  (unix_timestamp('2004-01-01 00:00:00'),'2004-01-01 00:00:00'),
  (unix_timestamp('2004-03-28 02:30:00'),'2004-03-28 02:30:00'),
  (unix_timestamp('2004-08-01 00:00:00'),'2003-08-01 00:00:00'),
  (unix_timestamp('2004-10-31 02:30:00'),'2004-10-31 02:30:00');
select * from t4;

create table t5 (i int, ts timestamp);
insert into t5 (i, ts) values
  (unix_timestamp('1981-07-01 03:59:59'),'1981-07-01 03:59:59'),
  (unix_timestamp('1981-07-01 04:00:00'),'1981-07-01 04:00:00');
select * from t5;


# 
# Let us test range for TIMESTAMP
#
create table t6 (ts timestamp);
set time_zone='+6:00';
insert into t6 values ('1969-12-31 23:59:59'),
                      ('1970-01-01 00:00:00'),('1970-01-01 00:00:01'),
                      ('2038-01-19 03:14:07'),('2038-01-19 03:14:08');
select * from t6;

 create table t8 (ts timestamp);
set time_zone='+5:00';
insert into t8 values ('1970-01-01 00:30:00'),
                      ('1970-01-01 01:00:00'),('1970-01-01 01:00:01'),
                      ('2038-01-19 04:14:07'),('2038-01-19 04:14:08');
select * from t8;

 create table t9 (ts timestamp);
set time_zone='+01:30';
insert into t9 values ('1970-01-01 01:00:00'),
                      ('1970-01-01 01:30:00'),('1970-01-01 01:30:01'),
                      ('2038-01-19 04:44:07'),('2038-01-19 04:44:08');
select * from t9;

SET time_zone='-01:30';
CREATE TABLE t7 (a TIMESTAMP, b VARCHAR(30));
INSERT INTO t7 VALUES
('2003-03-30 01:59:59', 'Before the gap'),
('2003-03-30 02:30:00', 'Inside the gap'),
('2003-03-30 03:00:00',  'After the gap');
SELECT a, UNIX_TIMESTAMP(a), b FROM t7;

