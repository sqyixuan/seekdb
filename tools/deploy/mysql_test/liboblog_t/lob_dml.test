--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: chaser.ch
# owner group: SQL1
# description: basic dml test for blob and text column
# tags: text,blob

#
# basic insert test for text/blob
#
set ob_default_lob_inrow_threshold=4100;
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(a int primary key, b tinyblob, c text, d mediumblob, e longtext);
insert into t1 values(1, 'b', 'c', 'd', 'e');
insert into t1 values(2, 'bb', 'cc', 'dd', 'ee');
insert into t1 values(3, '', '', '', '');
insert into t1 values(4, null, null, null, null);
select * from t1 order by a;
insert into t1 values(5, repeat('~', 255), repeat('~', 65535), repeat('~', 262144), repeat('~', 524288));
select a, length(b), length(c), length(d), length(e) from t1  order by a;
--error 1406
insert into t1 values(6, repeat('~', 256), repeat('~', 65535), repeat('~', 262144), repeat('~', 524288));
--error 1406
insert into t1 values(6, repeat('~', 255), repeat('~', 65536), repeat('~', 262144), repeat('~', 524288));
insert into t1 values(6, repeat('~', 255), repeat('~', 65535), repeat('~', 262145), repeat('~', 524288));
insert into t1 values(7, repeat('~', 255), repeat('~', 65535), repeat('~', 262144), repeat('~', 524289));
# drop table t1; # for liboblog
delete from t1; # for liboblog

#
# basic incremental update test for text/blob
#
--disable_warnings
# drop table if exists t1; # for liboblog
--enable_warnings
# create table t1(a int primary key, b tinyblob, c text, d mediumblob, e longtext);
insert into t1 values(1, 'b', 'c', 'd', 'e');
insert into t1 values(2, 'bb', 'cc', 'dd', 'ee');

#length($a) == 400
--let $a=''
--let $loop=40
while ($loop)
{
	--disable_query_log
	eval update t1 set c=concat(c, $a) where a = 2;
	eval update t1 set d=concat(d, $a) where a = 1;
	eval update t1 set e=concat(e, $a) where a = 2;
	--enable_query_log
	select a, length(b), length(c), length(d), length(e) from t1 order by a;
	dec $loop;
}
# drop table t1; # for liboblog
delete from t1; # for liboblog

#
# basic decremental update test for text
#
--disable_warnings
# drop table if exists t1; # for liboblog
--enable_warnings
# create table t1(a int primary key, b tinyblob, c text, d mediumblob, e longtext);
insert into t1 values(1, repeat('~', 255), repeat('~', 65535), repeat('~', 262144), repeat('~', 524288));
insert into t1 values(2, repeat('~', 255), repeat('~', 65535), repeat('~', 262144), repeat('~', 524288));
insert into t1 values(3, repeat('~', 255), repeat('~', 65535), repeat('~', 262144), repeat('~', 524288));
insert into t1 values(4, repeat('~', 255), repeat('~', 65535), repeat('~', 262144), repeat('~', 524288));
select a, length(b), length(c), length(d), length(e) from t1 order by a;
--let $loop=18
while ($loop)
{
	update t1 set b = substr(b, 1, length(b) / 2) where a = 1;
	update t1 set c = substr(c, 1, length(c) / 2) where a = 2;
	update t1 set d = substr(d, 1, length(d) / 2) where a = 3;
	update t1 set e = substr(e, 1, length(e) / 2) where a = 4;
	select a, length(b), length(c), length(d), length(e) from t1 order by a;
	dec $loop;
}
#drop table t1; # for liboblog
delete from t1; # for liboblog

#
# basic delete test for text/blob
#
--disable_warnings
# drop table if exists t1; # for liboblog
--enable_warnings
# create table t1(a int primary key, b tinyblob, c text, d mediumblob, e longtext);
insert into t1 values(1, 'b', 'c', 'd', 'e');
insert into t1 values(2, 'bb', 'cc', 'dd', 'ee');
insert into t1 values(3, '', '', '', '');
insert into t1 values(4, null, null, null, null);
insert into t1 values(5, repeat('~', 10), repeat('~', 10), repeat('~', 10), repeat('~', 10));
select * from t1 order by a;
delete from t1 where b is null;
select * from t1 order by a;
delete from t1 where c like '%cc%';
select * from t1 order by a;
delete from t1 where length(d) = 0;
select * from t1 order by a;
delete from t1 where e < 'z';
select * from t1 order by a;
# drop table t1; # for liboblog
delete from t1; # for liboblog

#
# large value insert test for text
#
--disable_warnings
drop table if exists ta,tb,tc,td;
--enable_warnings
create table ta(a int primary key, b tinytext, c text, d mediumtext, e longtext);
create table tb(a int primary key, b tinyblob, c blob, d mediumblob, e longblob);
#length($b) == 255
--let $b=abcdefghijk123456789abcdefghijk123456789abcdefghijk123456789abcdefghijk123456789abcdefghijk123456789abcdefghijk123456789abcdefghijk123456789abcdefghijk123456789abcdefghijk123456789abcdefghijk123456789abcdefghijk123456789abcdefghijk123456789abcdefghijk1234
--disable_query_log
eval replace into ta values(1, '$b', '$b', '$b', '$b');
eval replace into tb values(1, '$b', '$b', '$b', '$b');
--enable_query_log
select a, length(b), length(c), length(d), length(e) from ta order by a;
select a, length(b), length(c), length(d), length(e) from tb order by a;
--let $c=$b
--let $loop=8
while ($loop)
{
	--let $c=$c$c
	dec $loop;
}
--disable_query_log
eval replace into ta values(2, '$b', '$c', '$c', '$c');
eval replace into tb values(2, '$b', '$c', '$c', '$c');
--enable_query_log
select a, length(b), length(c), length(d), length(e) from ta order by a;
select a, length(b), length(c), length(d), length(e) from tb order by a;
--let $d=$c
--let $loop=2
while ($loop)
{
	--let $d=$d$d
	dec $loop;
}
--disable_query_log
eval replace into ta values(3, '$b', '$c', '$d', '$d');
eval replace into tb values(3, '$b', '$c', '$d', '$d');
--enable_query_log
select a, length(b), length(c), length(d), length(e) from ta order by a;
select a, length(b), length(c), length(d), length(e) from tb order by a;
--let $e=$d$d
--disable_query_log
eval replace into ta values(4, '$b', '$c', '$d', '$e');
eval replace into tb values(4, '$b', '$c', '$d', '$e');
--enable_query_log
select a, length(b), length(c), length(d), length(e) from ta order by a;
select a, length(b), length(c), length(d), length(e) from tb order by a;

