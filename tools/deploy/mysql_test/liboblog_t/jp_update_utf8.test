--disable_warnings
drop table if exists `пјҙпј‘`;
--disable_warnings
drop table if exists `пјҙпј’`;
--enable_warnings
--disable_warnings
drop table if exists `пјҙпј“`;

#
# Test Updating with Japanese characters in utf8 encoding
#

SET NAMES utf8;
SET character_set_database ='utf8';

CREATE TABLE `пјҙпј‘` (`пјЈпј‘` char(5) primary key, INDEX(`пјЈпј‘`)) DEFAULT CHARSET = utf8;
CREATE TABLE `пјҙпј’` (`пјЈпј‘` char(5) primary key, INDEX(`пјЈпј‘`)) DEFAULT CHARSET = utf8;
CREATE TABLE `пјҙпј“` (`пјЈпј‘` char(5) primary key, INDEX(`пјЈпј‘`)) DEFAULT CHARSET = utf8;

INSERT INTO `пјҙпј‘` VALUES ('пҪұпҪІпҪіпҪҙпҪө');
INSERT INTO `пјҙпј’` VALUES ('гҒӮгҒ„гҒҶгҒҲгҒҠ');
INSERT INTO `пјҙпј“` VALUES ('йҫ”йҫ–йҫ—йҫһйҫЎ');

UPDATE `пјҙпј‘` SET `пјЈпј‘` = ('пҪ¶пҪ·пҪёпҪ№пҪә');
UPDATE `пјҙпј’` SET `пјЈпј‘` = ('гҒӢгҒҚгҒҸгҒ‘гҒ“');
UPDATE `пјҙпј“` SET `пјЈпј‘` = ('йҪ—йҪҳйҪҡйҪқйҪһ');

