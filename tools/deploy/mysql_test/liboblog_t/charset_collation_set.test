--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: zhiyong.jzy
# owner group: SQL3
# description: foobar
# set charset and collation on different stage

#database
#use illegal charset and collation
drop database if exists db1;

#--error 1115
#此处bug修好后回来验证，应该返回1115
#create database db1 charset qa;
--error 1273
create database db1 charset utf8 collate qa_bin;
--error 1115
create database db1 charset qa_utf8 collate utf8_bin;
#--error 1273
#此处bug修好好回来验证，应该是返回1273错误码
#create database db1 charset utf8,collate utf8mb4_general_ci;

create database db1 DEFAULT CHARACTER SET utf8  COLLATE utf8_bin;

drop database if exists db1;

create database db1 charset utf8mb4 collate utf8mb4_general_ci;
use db1;
#table
#use illegal charset and collation

--disable_warnings
drop table if exists t1;
--enable_warnings
--error 1115
create table t1(c1 int primary key,c2 varchar(10)) charset qa;
#--error 1273
#create table t1(c1 int primary key,c2 varchar(10)) charset utf8,collate qa_bin;
--error 1115
create table t1(c1 int primary key,c2 varchar(10)) charset qa_utf8 collate utf8_bin;
#--error 1273
#create table t1(c1 int primary key,c2 varchar(10)) charset utf8,collate utf8mb4_general_ci;

create table t1(c1 int primary key,c2 varchar(10)) default character set utf8 collate utf8_bin;

#column
#use illegal charset and collation
#--error 1115
#未进行语法校验，修好后再测
#create table t2(c1 int primary key,c2 varchar(10) charset qa);
#--error 1273
#create table t2(c1 int primary key,c2 varchar(10)  charset utf8,collate qa_bin);
--error 1064
create table t2(c1 int primary key,c2 varchar(10) charset qa_utf8,collate utf8_bin);
#--error 1273
#create table t2(c1 int primary key,c2 varchar(10) charset utf8,collate utf8mb4_general_ci);
#不支持如下对列这种写法
#create table t2(c1 int primary key,c2 varchar(10) default charset set utf8,collate utf8mb4_general_ci);
