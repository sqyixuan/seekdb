--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: zhiyong.jzy
# owner group: SQL3
# description: foobar
####TITLE:单行事务和多行事务同时更新走索引的查询列,查询索引表、数据表，回表
####

--disable_query_log
--source mysql_test/include/index_quick_major.inc
--real_sleep 1
--disable_warnings
connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn2,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn3,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
drop table if exists t1,t2,t3,t4;
--enable_warnings
--enable_query_log

connection conn2;
create table t1(pk int primary key, a int, b int);
create index i1 on t1(b);

connect (conn_sys,$OBMYSQL_MS0,admin,admin,test,$OBMYSQL_PORT);
alter system major freeze tenant = sys;
alter system major freeze tenant = all_user;
alter system major freeze tenant = all_meta;
--disable_query_log
let $index_name = __idx_3003_i1;
--enable_query_log
--source mysql_test/include/check_all_idx_ok.inc

####CASE:单行事务和多行事务同时更新，事务均提交,事务1读
connection conn2;
insert into t1(pk, a, b) values(1,1,1),(2,1,1);
select * from t1;

connection conn2;
set autocommit=0;
update t1 set a=10, b=10 where pk=1;
delete from t1 where pk=2;
commit;

connection conn3;
insert into t1(pk,a ,b) values(3,1,1);


####CASE:多行事务提交,单行事务回滚,查询数据表、索引表、回表
connection conn2;
set autocommit=0;
select * from t1 where pk=3;
update t1 set a=30, b=30 where pk=3;
insert into t1 values(4,1,1);
select * from t1;
commit;
select * from t1;

create table t2(c1 timestamp(6) primary key);
insert into t2 values('2018-06-15 01:00:00.000003');
--error 1062
insert into t2 values('2018-06-15 01:00:00.000003');
insert into t2 values('2018-06-16 01:00:00.000003');
--error 1062
update t2 set c1 = '2018-06-15 01:00:00.000003';

CREATE TABLE t3 (a TIME(6));
--error 1292
INSERT INTO t3 VALUES (8385959.1e0);
INSERT INTO t3 VALUES (83859.1);

use test;
create table t4(a int);
select * from t4 for update wait 0.000001;
--error 1210
select * from t4 for update wait 0.0000001;

