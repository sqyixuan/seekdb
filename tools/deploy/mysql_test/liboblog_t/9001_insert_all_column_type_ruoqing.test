--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
##
#
# 测试功能点：单partition insert all column types
#
##
--disable_warnings
drop table if exists t1,t2,t3,t4;
--enable_warnings

create table t1(c1 bigint, c2 varchar(90), primary key(c1,c2), c3 numeric, c4 datetime, c5 int);

##----------------------------------- insert with all cloumns specified --------------------------------
# boundary for bigint/int
insert into t1 values(1,'aaa',1.5,'2000-01-01',0);

insert into t1 values(-922,'aaa',1.5,'2000-01-01 00:00:00',-922);



# boundary for numeric
insert into t1 values(3,'aaa',9999,'2000-01-01',0);

insert into t1 values(8,'aaa',-7935,'2000-01-01',0);

# boundary for datetime
insert into t1 values(10,'aaa',1.5,'1970-01-01',0);

#--error 1292
insert into t1 values(11,'aaa',1.5,'1970-01-00',0);

insert into t1 values(12,'aaa',1.5,'2101-12-31',0);

insert into t1 values(13,'aaa',1.5,'9999-01-01',0);


#--error 1292
insert into t1 values(16,'aaa',1.5,'0001-00-00',0);

insert into t1 values(17,'aaa',1.5,'0001-01-01',0);

insert into t1 values(18,'aaa',1.5,'9999-12-31',0);

--error 1292 
insert into t1 values(19,'aaa',1.5,'9999-12-32',0);
--error 1292 
insert into t1 values(20,'aaa',1.5,'9999-13-31',0);
--error 1292 
insert into t1 values(21,'aaa',1.5,'10000-13-31',0);

##----------------------------------- insert with only part of cloumns specified --------------------------------
# boundary for bigint/int
insert into t1(c1,c2,c5) values(-9223,'bbb',-922);

insert into t1(c1,c2,c3) values(3,'bbb',999);

insert into t1(c1,c2,c4,c5) values(10,'bbb','1970-01-01',0);

