--disable_result_log
drop table if exists t1;
--enable_result_log

create table t1(c1 int primary key, c2 int, c3 int) partition by hash(c1) partitions 10;
insert into t1 values (1, 1, 1);
alter table t1 drop primary key, add primary key(c2, c1);
insert into t1 values (2, 2, 2);
alter table t1 partition by hash(c2) partitions 10;
insert into t1 values (3, 3, 3);
alter table t1 drop primary key, add primary key(c2);
insert into t1 values (4, 4, 4);
alter table t1 drop primary key;
alter table t1 partition by hash(c1+c2) partitions 4;
insert into t1 values (5, 5, 5);
alter table t1 partition by hash(c2+c1) partitions 3;
insert into t1 values (6, 6, 6);
alter table t1 partition by hash(c3) partitions 5;
insert into t1 values (7, 7, 7);
alter table t1 add primary key(c3);
insert into t1 values (8, 8, 8);
drop table t1;

create table t1(c1 timestamp);
set time_zone = "+8:00";
insert into t1(c1) values('2011-11-11 11:11:11');
alter table t1 modify column c1 datetime;
insert into t1(c1) values('2022-02-22 22:22:22');
drop table t1;

create table t1(c1 int, c2 int, c3 int) partition by range(c1+c3) subpartition by hash(c2) subpartitions 3 (
  partition p0 values less than (10),
  partition p1 values less than (20),
  partition p2 values less than MAXVALUE
);
insert into t1 values (1, 1, 1);
alter table t1 partition by range(c3+c2) subpartition by hash(c2) subpartitions 5 (
  partition p0 values less than (100),
  partition p1 values less than (200),
  partition p2 values less than MAXVALUE
);
insert into t1 values (2, 199, -1);
alter table t1 add column c4 int;
insert into t1 values (3, 3, 3, 3);
alter table t1 partition by hash(c4+c1) partitions 10;
insert into t1 values (4, 4, 4, 4);
drop table t1;

create table t1(c1 int);
insert into t1 values (0);
alter table t1 add column c2 int, add unique index i2(c2);
insert into t1 values (1, 1);
insert into t1 values (2, 2);
drop table t1;

create table t1 (Z0_TEST0 int, Z0_TEST1 varchar(100)) partition by key (Z0_TEST0) (partition p1, partition p2, partition p3);

INSERT INTO t1 (Z0_TEST0,Z0_TEST1) values(-1,'111');
INSERT INTO t1 (Z0_TEST0,Z0_TEST1) values(0,'111');
INSERT INTO t1 (Z0_TEST0,Z0_TEST1) values('111','111');

alter table t1 partition by key(Z0_TEST0) subpartition by key(Z0_TEST1, Z0_TEST0) (partition part_1, partition part_2);
INSERT INTO t1 (Z0_TEST0,Z0_TEST1) values(222,'222');

drop table t1;

create table t1 (c1 int primary key, c2 int, c3 int, c4 int);
insert into t1 values (1, 1, 1, 1);
alter table t1 modify c2 int first, modify c3 int after c2, modify c4 int after c3, modify c1 int after c4;
insert into t1 values (2, 2, 2, 2);
drop table t1;