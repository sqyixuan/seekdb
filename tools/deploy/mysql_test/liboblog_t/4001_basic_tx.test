# owner: bohou.ws
# owner group: LOG
# description: liboblog basic trans support

--disable_warnings;
drop database if exist obcdc_db;
--enable_warnings;

create database obcdc_db;
use obcdc_db;

# t1, 1k for each row
create table t1(a int primary key, b varchar(1024)) partition by hash(a) partitions 10;

# 1M tx;
begin;
--let $loop=1024
while ($loop)
{
  eval insert into t1 values($loop, repeat('~', 1024));
  dec $loop;
}
commit;

# 1G tx;
begin;
--let $loop=1024*1024
while ($loop)
{
  eval insert into t1 values($loop, repeat('~', 1024));
  dec $loop;
}
commit;
