--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
##
#
# 测试功能点：primary key test(single/multi)
#
##

--disable_warnings
drop table if exists t1,t2,t3,t4;
--enable_warnings

create table t1(pk1 int, pk2 int, pk3 int default 0, primary key(pk1,pk2), extra int);
sleep 2;

insert /*agadgafdgafdghfdhggh*/ into t1(pk1,pk2) values(0,1),(-1,0);

insert into t1(pk1,pk2) values(1,2),(2,3);

insert into t1(pk2,pk1) values(4,3),(5,4);

select * from t1;
select pk2,pk1 from t1;


create table t2(pk1 int primary key, a int);
sleep 2;

insert into t2 values(0,1),(-1,0);

insert into t2(pk1,a) values(1,2),(2,3);

insert into t2(a,pk1) values(4,3),(5,4);

select * from t2;
select a,pk1 from t2;

create table t3(pk1 int, pk2 int, primary key(pk1,pk2), extra int);
insert into t3(pk1,pk2) values(0,1),(-1,0),(3,1),(4,0),(5,1),(6,0);

insert into t3(pk1,pk2) values(1,2),(2,3),(7,1),(8,0),(9,1),(10,0);

select * from (select * from t3) as tmp1 where pk1>0;
select * from t3;
select * from t3 where pk1>0 limit 1,10;
select * from t3 where pk1>0 limit 3,10;
select * from (select * from t3) tt3;
delete from t3 where pk2=3 and pk1=2;

#test insert hex data,in 10 decimal

CREATE TABLE t4(a BIGINT primary key);
INSERT INTO t4 VALUES (0xFFFFFFFFFFFFF);

INSERT INTO t4 VALUES (0xF);

SELECT * FROM t4 WHERE a=-1 OR a=-2 OR a=16;
SELECT * FROM t4 WHERE a in (-1,-2,16);




