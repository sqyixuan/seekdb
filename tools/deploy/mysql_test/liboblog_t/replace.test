--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: zhiyong.jzy
# owner group: SQL3
# description: foobar
#
# Test of REPLACE with MyISAM and HEAP
#
#--disable_abort_on_error

--disable_warnings
drop table if exists t1,t2,t3;
--enable_warnings

CREATE TABLE t1 (
  gesuchnr int(11) DEFAULT '0' NOT NULL,
  benutzer_id int(11) DEFAULT '0' NOT NULL,
  PRIMARY KEY (gesuchnr,benutzer_id)
);

replace into t1 (gesuchnr,benutzer_id) values (2,1);
replace into t1 (gesuchnr,benutzer_id) values (1,1);
replace into t1 (gesuchnr,benutzer_id) values (1,1);
#alter table t1 engine=heap;
replace into t1 (gesuchnr,benutzer_id) values (1,1);

#
# Test when using replace on a key that has used up it's whole range
#

create table t2 (a tinyint not null auto_increment primary key, b char(20) default "default_value");
insert into t2 values (126,"first"),(63, "middle"),(0,"last");
--error 1062
insert into t2 values (0,"error");
#--error 1062
#there is a bug
########
## MYSQL的自增列这块处理比较特殊，如果自增列到最大值以后，replace中如果自增列的值为0，该replace操作就会失败。
## OB暂时不处理这种情况。会认为replace成功。
########
replace into t2 values (0,"error");
replace into t2 values (127,"error");
replace into t2 values (126,"first updated");
replace into t2 values (63,default);
select * from t2;

# End of 4.1 tests

#
# Bug#19789: REPLACE was allowed for a VIEW with CHECK OPTION enabled.
#
drop view if exists v1;
--enable_warnings
CREATE TABLE t3 (f1 INT primary key);
#CREATE VIEW v1 AS SELECT f1 FROM t3 WHERE f1 = 0 WITH CHECK OPTION;
CREATE VIEW v1 AS SELECT f1 FROM t3 WHERE f1 = 0;
#--error 1369
REPLACE INTO t3 (f1) VALUES (1);
select * from v1;
