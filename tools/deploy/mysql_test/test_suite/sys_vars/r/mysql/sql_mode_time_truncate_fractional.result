drop table if exists t1, t2, t3, t4, t5, t6;
SELECT @@sql_mode;
@@sql_mode
STRICT_ALL_TABLES,NO_ZERO_IN_DATE,NO_AUTO_CREATE_USER
set sql_mode = 'TIME_TRUNCATE_FRACTIONAL';
SELECT @@sql_mode;
@@sql_mode
TIME_TRUNCATE_FRACTIONAL
CREATE TABLE t1 (id INT, tval TIME(1));
SET sql_mode='';
INSERT INTO t1 (id, tval) VALUES(1, 1.55);
SET sql_mode='TIME_TRUNCATE_FRACTIONAL';
INSERT INTO t1 (id, tval) VALUES(2, 1.55);
SELECT id, tval FROM t1 ORDER BY id;
id	tval
1	00:00:01.6
2	00:00:01.5
update t1 set tval =1.55 where id = 1;
SELECT id, tval FROM t1 ORDER BY id;
id	tval
1	00:00:01.5
2	00:00:01.5
SET sql_mode='';
update t1 set tval =1.55 where id = 1;
SELECT id, tval FROM t1 ORDER BY id;
id	tval
1	00:00:01.6
2	00:00:01.5
