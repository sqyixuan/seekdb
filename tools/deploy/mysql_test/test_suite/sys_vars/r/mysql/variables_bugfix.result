LENGTH(@@ob_tcp_invited_nodes)
65536
SELECT LENGTH(@@ob_tcp_invited_nodes);
LENGTH(@@ob_tcp_invited_nodes)
65536
set @@global.ob_tcp_invited_nodes='%';
