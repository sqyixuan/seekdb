#
# req/31526234 - add transaction_read_only for mysql_mode
#
drop table t0;
drop table t1;
drop table t2;
create table t0 (id int);
show variables like "%tx_read_only%";
Variable_name	Value
tx_read_only	OFF
show variables like "%transaction_read_only%";
Variable_name	Value
transaction_read_only	OFF
set transaction_read_only = 1;
show variables like "%tx_read_only%";
Variable_name	Value
tx_read_only	ON
show variables like "%transaction_read_only%";
Variable_name	Value
transaction_read_only	ON
insert into t0 values(1);
ERROR 25006: Cannot execute statement in a READ ONLY transaction.
create table t1 (id int);
ERROR 25006: Cannot execute statement in a READ ONLY transaction.
set tx_read_only = 0;
show variables like "%tx_read_only%";
Variable_name	Value
tx_read_only	OFF
show variables like "%transaction_read_only%";
Variable_name	Value
transaction_read_only	OFF
set tx_read_only = 1;
show variables like "%tx_read_only%";
Variable_name	Value
tx_read_only	ON
show variables like "%transaction_read_only%";
Variable_name	Value
transaction_read_only	ON
create table t1 (id int);
ERROR 25006: Cannot execute statement in a READ ONLY transaction.
set transaction_read_only = 0;
show variables like "%tx_read_only%";
Variable_name	Value
tx_read_only	OFF
show variables like "%transaction_read_only%";
Variable_name	Value
transaction_read_only	OFF
create table t2 (id int);
insert into t2 values(1);
# connection conn2
show variables like "%tx_read_only%";
Variable_name	Value
tx_read_only	OFF
show variables like "%transaction_read_only%";
Variable_name	Value
transaction_read_only	OFF
create table t1 (id int);
insert into t1 values(1);
set global transaction_read_only = 1;
# connection conn3
show variables like "%tx_read_only%";
Variable_name	Value
tx_read_only	ON
show variables like "%transaction_read_only%";
Variable_name	Value
transaction_read_only	ON
insert into t1 values(2);
ERROR 25006: Cannot execute statement in a READ ONLY transaction.
set global tx_read_only = 0;
# connection conn4
show variables like "%tx_read_only%";
Variable_name	Value
tx_read_only	OFF
show variables like "%transaction_read_only%";
Variable_name	Value
transaction_read_only	OFF
drop table t0;
drop table t1;
drop table t2;
