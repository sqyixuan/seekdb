#owner: yibo.tyf
#owner group: sql1
#description: 测试init_connect系统变量的表现，对拥有super权限的用户不生效。
--source mysql_test/include/index_quick_major.inc
--disable_warnings
drop table if exists t1;
--enable_warnings
use test;
#创建用户登记表
create  table t1 ( cur_user varchar(100));
#设置init_connect的值
set global init_connect = "insert into test.t1 values(current_user())";
#创建普通用户
set sql_mode='STRICT_ALL_TABLES,NO_ZERO_IN_DATE';
grant USAGE on *.* to 'yeti1';
grant USAGE on *.* to 'yeti2';
drop user yeti1;
drop user yeti2;

create user 'yeti1' identified by 'test';
create user 'yeti2' identified by 'test';
grant create,  select, update, insert on *.* to 'yeti1';
grant create, select, update, insert on *.* to 'yeti2';
--source mysql_test/include/check_schema_sync.inc
connect (conn1,$OBMYSQL_MS0,yeti1,test,test,$OBMYSQL_PORT);

#case1:测试通过init_connect设置的sql对不拥有super权限的用户生效，在创建连接之后执行。
connection conn1;
select * from test.t1;
connect (conn2,$OBMYSQL_MS0,yeti2,test,test,$OBMYSQL_PORT);
connection conn2;
select * from test.t1;
connect (conn3,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn3;
select * from test.t1;

#case2:测试init_connect中含有多条sql语句的执行。
connection conn3;
set global init_connect = "insert into test.t1 values(current_user());insert into test.t1 values(current_user())";
connect (conn12,$OBMYSQL_MS0,yeti1,test,test,$OBMYSQL_PORT);
connection conn12;
select * from test.t1;
connect (conn22,$OBMYSQL_MS0,yeti2,test,test,$OBMYSQL_PORT);
connection conn22;
select * from test.t1;

#case3:测试当执行init_connect中的内容出错时，不拥有super权限的用户断连接。
#connection conn3;
#set global init_connect="selwrwrwr";
##这个地方需要后续修改，建立连接的时候不应该报错
#--error 1064
#connect (conn13,$OBMYSQL_MS0,yeti1,test,test,$OBMYSQL_PORT);
#--error 1064
#connect (conn23,$OBMYSQL_MS0,yeti2,test,test,$OBMYSQL_PORT);
#connection conn13;
#--error 2013
#select 1;
#connection conn23;
#--error 2013
#select 1;
#connection conn3;
#set global init_connect = "";

#case4:测试init_connec中的sql执行是在选择数据库之前做的。
connection conn3;
set global init_connect = "use test";
connect (conn14,$OBMYSQL_MS0,yeti1,test,test,$OBMYSQL_PORT);
connect (conn24,$OBMYSQL_MS0,yeti2,test,test,$OBMYSQL_PORT);
connection conn14;
select database();
connection conn24;
select database();
connection conn3;
set global init_connect = "";

#case5:测试init_connect中的语句走同步执行
connection conn3;
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(a int);
insert into t1 values(1);
set global init_connect = "update test.t1 set a = 2";
connect (conn15,$OBMYSQL_MS0,yeti1,test,test,$OBMYSQL_PORT);
connection conn15;
select * from test.t1;
connection conn3;
set global init_connect = "";

#case6: 测试init_connect中的语句为set语句
connection conn3;
set global init_connect = "set @@sql_select_limit=10";
connect (conn16,$OBMYSQL_MS0,yeti1,test,test,$OBMYSQL_PORT);
connection conn16;
select @@sql_select_limit;
set @@sql_select_limit = default;
connection conn3;
set global init_connect = "";

#case7: 测试通过init_connect create db/table
connection conn3;
set global init_connect = "create database sys_vars_yeti_db_test1;use test;create table sys_vars_yeti_conn17_test(a int)";
grant create,drop on *.* to yeti1;
--source mysql_test/include/check_schema_sync.inc
connect (conn17,$OBMYSQL_MS0,yeti1,test,test,$OBMYSQL_PORT);
connection conn17;
--real_sleep 1
show tables like 'sys_vars_yeti%';
show databases like 'sys_vars_yeti%';
--disable_warnings
drop table if exists sys_vars_yeti_conn17_test;
drop database if exists sys_vars_yeti_db_test1;
--enable_warnings
connection conn3;
set global init_connect = "";

#case8: 测试init_connect中语句为权限相关
connection conn3;
set global init_connect = "grant create, insert, select, update on *.* to yeti2";
revoke all on *.* from yeti2;
grant grant option on *.* to yeti1;
--source mysql_test/include/check_schema_sync.inc
connect (conn18,$OBMYSQL_MS0,yeti1,test,test,$OBMYSQL_PORT);
--source mysql_test/include/check_schema_sync.inc
connection conn3;
set global init_connect = "";
connect (conn28,$OBMYSQL_MS0,yeti2,test,test,$OBMYSQL_PORT);
show grants;
connection conn3;
set global init_connect = "";

#case9: 测试init_connect中的内容为select语句，不返回任何结果
connection conn3;
set global init_connect = "select 1+1";
connect (conn29,$OBMYSQL_MS0,yeti2,test,test,$OBMYSQL_PORT);
connection conn29;
#连接后不返回结果，可以正常使用
select 1+1;
connection conn3;
set global init_connect = "";

drop user yeti1;
drop user yeti2;
--disable_warnings
drop table if exists t1;
--enable_warnings
