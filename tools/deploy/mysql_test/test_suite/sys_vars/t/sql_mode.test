--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: yibo.tyf
# owner group: SQL3
# Test of sql mode functions

set @save_sqlmode= @@global.sql_mode;
set @@session.sql_mode = "";
select @@session.sql_mode;
--error 1231
set @@session.sql_mode = "pad_char_to_full_length, ONLY_FULL_GROUP_BY";
set @@session.sql_mode = "pad_char_to_full_length,ONLY_FULL_GROUP_BY";
select @@session.sql_mode;
set @@session.sql_mode = 2147483648;
select @@session.sql_mode;
set @@session.sql_mode = 2147483680;
select @@session.sql_mode;
--error 1232
set @@session.sql_mode = 111111111111111111111;
--error 1231
set @@session.sql_mode = 'abc';
--error 1231
set @@session.sql_mode = '12abc';

set sql_mode = 'ANSI';
select @@session.sql_mode;

set sql_mode = 'TRADITIONAL';
select @@session.sql_mode;

#
set @@session.sql_mode = 4194304;
select @@session.sql_mode;
set @@sql_mode=default;
select @@session.sql_mode;

# 
set @@session.sql_mode = 2;
set @@global.sql_mode = 2;
set @@session.sql_mode = 3;
set @@global.sql_mode = 3;
let $ENGINE=InnoDB;
set @@global.sql_mode= @save_sqlmode;

set @@sql_mode = concat(@save_sqlmode, ',NO_AUTO_CREATE_USER');
--error 1045
grant select on *.* to newuser1;
set @@sql_mode = @save_sqlmode;

set @@sql_mode = concat(@save_sqlmode, ',NO_DIR_IN_CREATE');
select @@session.sql_mode;
set @@sql_mode = @save_sqlmode;

set @@sql_mode = concat(@save_sqlmode, ',REAL_AS_FLOAT');
select @@session.sql_mode;
create table t_real(c1 int, c2 real);
desc t_real;
drop table t_real;
set @@sql_mode = @save_sqlmode;

set @@sql_mode = concat(@save_sqlmode, ',IGNORE_SPACE');
select @@session.sql_mode;
set @@sql_mode = @save_sqlmode;

set @@sql_mode = 'ANSI';
select @@session.sql_mode;
set @@sql_mode = @save_sqlmode;

set @@sql_mode = 'DB2';
select @@session.sql_mode;
set @@sql_mode = @save_sqlmode;

set @@sql_mode = 'MAXDB';
select @@session.sql_mode;
set @@sql_mode = @save_sqlmode;

set @@sql_mode = 'MSSQL';
select @@session.sql_mode;
set @@sql_mode = @save_sqlmode;

set @@sql_mode = 'MYSQL323';
select @@session.sql_mode;
set @@sql_mode = @save_sqlmode;

set @@sql_mode = 'MYSQL40';
select @@session.sql_mode;
set @@sql_mode = @save_sqlmode;

set @@sql_mode = 'ORACLE';
select @@session.sql_mode;
set @@sql_mode = @save_sqlmode;

set @@sql_mode = 'POSTGRESQL';
select @@session.sql_mode;
set @@sql_mode = @save_sqlmode;

set @@sql_mode = 'TRADITIONAL';
select @@session.sql_mode;
set @@sql_mode = @save_sqlmode;

#bug48749892
--error 0,942,1051
drop table table10_bigint;
CREATE TABLE table10_bigint (
col_bigint_signed bigint signed,
pk bigint,
col_bigint_unsigned bigint unsigned,
col_bigint bigint,
col_char_20 char(20),
col_decimal_20_0 decimal(20,0),
col_timestamp_6 timestamp(6) NULL DEFAULT NULL,
col_decimal_20_0_signed decimal(20,0) signed,
col_decimal_20_0_unsigned decimal(20,0) unsigned,
/*Indices*/
primary key (pk) ) charset latin1;

set sql_mode = STRICT_ALL_TABLES;
