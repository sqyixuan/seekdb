connect (sys_conn,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection sys_conn;
alter system set _enable_reserved_user_dcl_restriction = true;
connection default;
set sql_mode = 'STRICT_ALL_TABLES,NO_ZERO_IN_DATE,NO_AUTO_CREATE_USER';
--error 0,1396
drop user ruinao;
--error 0,1396
drop user ruinao_1;
--error 1045
grant select on *.* to ruinao;
grant select on *.* to ruinao identified by '123456';

drop user ruinao;
set sql_mode = 'STRICT_ALL_TABLES,NO_ZERO_IN_DATE';
grant select on *.* to ruinao;
grant select on *.* to ruinao_1 identified by '123456';
drop user ruinao;
drop user ruinao_1;
set sql_mode = 'STRICT_ALL_TABLES,NO_ZERO_IN_DATE,NO_AUTO_CREATE_USER';
connection sys_conn;
alter system set _enable_reserved_user_dcl_restriction = false;
