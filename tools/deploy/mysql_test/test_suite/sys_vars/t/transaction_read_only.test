# owner: laibingzheng.lbz
# owner group: SQL2
# tags: transaction_read_only
--echo #
--echo # req/31526234 - add transaction_read_only for mysql_mode
--echo #

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_abort_on_error

connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);

--error 0,1051
drop table t0;
--error 0,1051
drop table t1;
--error 0,1051
drop table t2;

create table t0 (id int);

connection conn1;
show variables like "%tx_read_only%";
show variables like "%transaction_read_only%";

set transaction_read_only = 1;
show variables like "%tx_read_only%";
show variables like "%transaction_read_only%";

# fail to into table
insert into t0 values(1);
# fail to create table
create table t1 (id int);

set tx_read_only = 0;
show variables like "%tx_read_only%";
show variables like "%transaction_read_only%";

set tx_read_only = 1;
show variables like "%tx_read_only%";
show variables like "%transaction_read_only%";

# fail to create table
create table t1 (id int);

set transaction_read_only = 0;
show variables like "%tx_read_only%";
show variables like "%transaction_read_only%";

create table t2 (id int);
insert into t2 values(1);

--sleep 2
--echo # connection conn2
connect (conn2,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn2;
show variables like "%tx_read_only%";
show variables like "%transaction_read_only%";

create table t1 (id int);
insert into t1 values(1);

set global transaction_read_only = 1;
 
--sleep 2
--echo # connection conn3
connect (conn3,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn3;
show variables like "%tx_read_only%";
show variables like "%transaction_read_only%";
insert into t1 values(2);
set global tx_read_only = 0;

--sleep 2
--echo # connection conn4
connect (conn4,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn4;
show variables like "%tx_read_only%";
show variables like "%transaction_read_only%";

drop table t0;
drop table t1;
drop table t2;
