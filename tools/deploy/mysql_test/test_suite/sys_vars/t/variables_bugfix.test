--error 4019
set @@global.ob_tcp_invited_nodes=CONCAT('%', REPEAT(',127.0.0.1', 6553), '123456'); # len = 1 + 10 * 6553 + 6 = 65537

set global ob_tcp_invited_nodes=CONCAT('%', REPEAT(',127.0.0.1', 6553), '12345'); # len = 1 + 10 * 6553 + 5 = 65536
SELECT LENGTH(@@ob_tcp_invited_nodes);
sleep 10;

disconnect default;

connect (default, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection default;
SELECT LENGTH(@@ob_tcp_invited_nodes);

disconnect default;
connect (default, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection default;
SELECT LENGTH(@@ob_tcp_invited_nodes);
set @@global.ob_tcp_invited_nodes='%';

connect (obsys,$OBMYSQL_MS0,root,,test,$OBMYSQL_PORT);
connection obsys;
--error 4019
eval alter tenant sys set variables ob_tcp_invited_nodes=CONCAT('%', REPEAT(',127.0.0.1', 6553), '123456'); # len = 1 + 10 * 6553 + 6 = 65537
eval alter tenant sys set variables ob_tcp_invited_nodes=CONCAT('%', REPEAT(',127.0.0.1', 6553), '12345'); # len = 1 + 10 * 6553 + 5 = 65536
sleep 10;
disconnect obsys;

disconnect default;
connect (default, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection default;
SELECT LENGTH(@@ob_tcp_invited_nodes);
set @@global.ob_tcp_invited_nodes='%';

disconnect default;
connect (default, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);


