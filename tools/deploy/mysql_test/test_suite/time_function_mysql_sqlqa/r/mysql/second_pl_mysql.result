drop   procedure if   exists   pro1;
create procedure pro1(aa int,bb int)
begin
if aa = bb then
update t1 set c2 = second('2008-08-08 10:15:15') where c1 = 2 ;
elseif aa > bb then
update t1 set c2 = second('1998-08-08 12:12:12') where c1 = 1 ;
else
update t1 set c2 = second('14:14:14') where c1 = 3 ;
end if;
end
//
