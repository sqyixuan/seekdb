drop   procedure if   exists   pro1;
create procedure pro1()
begin
declare i int default 1;
while i <= 10 do
if mod(i,10) = 0 then
insert into t1 values(6,second('1981-01-01 08:08:08'),second(010101));
elseif mod(i,8)=0 then
insert into t1 values(7,second('1987-07-07 09:09:09'),second(020202));
elseif mod(i,7)=0 then
insert into t1 values(8,second('1988-08-08 10:10:10'),second(030303));
elseif mod(i,5)=0 then
insert into t1 values(9,second('1909-09-09 11:11:11'),second(040404));
elseif mod(i,3)=0 then
insert into t1 values(10,second('2010-10-10 12:12:12'),second(050505));
else
insert into t1 values(11,second('2011-11-11 13:13:13'),second(060606));
end if;
set i = i+1;
end while;
end
