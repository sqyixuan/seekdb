##数据类型验证
##TINYINT,SMALLINT,MEDIUMINT,int,BIGINT,FLOAT,DOUBLE,DECIMAL
create table t1(c1 TINYINT,c2 SMALLINT,c3 MEDIUMINT,c4 int,c5 BIGINT,c6 FLOAT,c7 DOUBLE,c8 DECIMAL(5,2));
insert into t1 values(22,621,0721,0621,1221,0621.221,0621.01,0621.02);
insert into t1 values(23,622,0722,0622,1222,0622.221,0622.01,0622.02);
insert into t1 values(24,null,null,null,null,null,null,null);
select * from t1 ORDER by c1 asc;
c1	c2	c3	c4	c5	c6	c7	c8
22	621	721	621	1221	621.221	621.01	621.02
23	622	722	622	1222	622.221	622.01	622.02
24	NULL	NULL	NULL	NULL	NULL	NULL	NULL
select * from t1 ORDER by dayofyear(c1) asc;
