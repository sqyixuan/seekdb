update t1 set c1= dayofyear(20220811) where c2 in ('test01','test02');
update t1 set c1= dayofyear(20220811),c3=dayofyear(20220811) where c2 in ('test01','test02');
update t1 set c1= dayofyear(20220811),c3=dayofyear(20220811)+0 where c2 in ('test01','test02');
update t1 set c1= dayofyear(20220811) where c3>dayofyear(20220811);
update t1 set c1= dayofyear(20220811)+0  where c3>dayofyear(20220811)+0;
update t1 set c1= dayofyear(20220811) where c3>dayofyear(20220811);
update t1 set c1= dayofyear(20220811)+0  where c3<dayofyear(20220811)+0;
update t1 set c1= dayofyear(20220811) where c3=dayofyear(20220811);
update t1 set c1= dayofyear(20220811) where c3<=dayofyear(20220811);
update t1 set c1= dayofyear(20220811) where c3 between dayofyear() and dayofyear(20220811)+3 ;
