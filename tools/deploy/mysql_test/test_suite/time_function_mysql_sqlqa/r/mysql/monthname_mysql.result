DROP PROCEDURE pro3;
CREATE PROCEDURE pro3(in a varchar(20))
begin
declare i int;
set i=20220910;
while i <=20220914  DO
if i > a then
select monthname(i);
end if;
insert into t1 values(i,monthname(i));
set i = i + 1;
end WHILE;
end;
//
CALL pro3(20220920);
