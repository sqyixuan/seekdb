DROP PROCEDURE pro4;
CREATE PROCEDURE pro4(in a int)
begin
declare i int;
declare b int;
set i=20220910;
while i <=20220914  DO
if a =20220920 then
select monthname(a);
end if;
insert into t1 values(a ,monthname(a));
set i = i + 1;
end WHILE;
select a into b;
end;
//
CALL pro4(20220920);
monthname(a)
monthname(a)
monthname(a)
monthname(a)
monthname(a)
September
September
September
September
September
select * from t1;
c1	c2
20220920	September
20220920	September
20220920	September
20220920	September
20220920	September
