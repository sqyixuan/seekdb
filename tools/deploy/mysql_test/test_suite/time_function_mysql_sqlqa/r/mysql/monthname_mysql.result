##insert型触发器
drop table t1;
drop table t2;
drop trigger t1_trigger;
create table t1 (c1 int ,c2 varchar(20),c3 date);
insert into t1 values(1,'test01','20220907');
insert into t1 values(2,'test02','20220909');
insert into t1 values(3,'test03','2022-08-20');
insert into t1 values(4,'test04','2022-09-15');
insert into t1 values(5,'test05','2022-09-16');
select * from t1;
c1	c2	c3
1	test01	2022-09-07
2	test02	2022-09-09
3	test03	2022-08-20
4	test04	2022-09-15
5	test05	2022-09-16
create table t2 (a1 int ,a2 varchar(20));
insert into t2 values(1,'test08');
insert into t2 values(2,'test09');
select * from t2;
a1	a2
1	test08
2	test09
create trigger t1_trigger after insert on  t2
for each row
begin 
update t1 set c2=monthname('2022-09-16') where c3="2022-09-16";
end //
insert into t2 values(3,'test03');
