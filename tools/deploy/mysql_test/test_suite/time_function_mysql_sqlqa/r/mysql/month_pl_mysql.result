drop database if exists db1;
create database db1;
use db1;
#PL
#procedure
drop table if exists t1;
Warnings:
Note	1051	Unknown table 'db1.t1'
create table t1(c1 int,c2 int,c3 char(100));
drop procedure if exists pro1;
CREATE  PROCEDURE pro1()
begin
declare j int;
declare i int;
set j = 5;
set i = 1;
while i <= j DO
insert into t1 values(i,month(20201212+1),month('2022-02-02'));
set i = i + 1;
end WHILE;
end
//
call pro1();
select * from t1;
c1	c2	c3
1	12	2
2	12	2
3	12	2
4	12	2
5	12	2
drop   procedure if   exists   pro1;
create procedure pro1(aa int,bb int)
begin
if aa = bb then
update t1 set c2 = month('2008-08-08') where c1 = 2 ;
elseif aa > bb then
update t1 set c2 = month('1998-08-08') where c1 = 1 ;
else
update t1 set c2 = month('1978-08-08') where c1 = 3 ;
end if;
end
//
call pro1(1,1);
call pro1(2,1);
call pro1(0,1);
select * from t1;
c1	c2	c3
1	8	2
2	8	2
3	8	2
4	12	2
5	12	2
drop   procedure if   exists   pro1;
create procedure pro1()
begin
declare i int default 1;
while i <= 10 do
if mod(i,10) = 0 then
insert into t1 values(6,month('1981-01-01'),month(19810101));
elseif mod(i,8)=0 then
insert into t1 values(7,month('1987-07-07'),month(19870707));
elseif mod(i,7)=0 then
insert into t1 values(8,month('1988-08-08'),month(19880808));
elseif mod(i,5)=0 then
insert into t1 values(9,month('1909-09-09'),month(19990909));
elseif mod(i,3)=0 then
insert into t1 values(10,month('2010-10-10'),month(20101010));
else
insert into t1 values(11,month('2011-11-11'),month(20111101));
end if;
set i = i+1;
end while;
end
//
call pro1();
select * from t1;
