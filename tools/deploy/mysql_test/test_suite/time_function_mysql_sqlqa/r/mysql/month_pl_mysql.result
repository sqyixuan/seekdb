create procedure pro1(aa int,bb int)
begin
if aa = bb then
delete from t1 where c1 > 1 and c2 = month('1988-10-02');
elseif aa > bb then
delete from t1 where c2 > month('2011-02-02') and c3 = month('2011-02-02');
else
delete from t1 where c3 = month('1998-02-02');
end if;
end
