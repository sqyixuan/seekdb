#trigger
drop   table     if   exists   t1;
drop   table     if   exists   t2;
Warnings:
Note	1051	Unknown table 'db1.t2'
create table t1(c1 int,c2 int);
insert into t1 values(1,10);
insert into t1 values(2,11);
create table t2(a1 int,a2 varchar(20));
insert into t2 values(2,'AA');
insert into t2 values(3,'cc');
drop trigger if exists tg1;
Warnings:
Note	1360	Trigger does not exist
create trigger tg1
AFTER
insert on t2
for each ROW
BEGIN
insert t1 values(month('2001-03-05'),month('2000/04/06'));
END
//
insert into t2 values(1,1);
select * from t1;
c1	c2
1	10
2	11
3	4
drop trigger if exists tg1;
create trigger tg1
AFTER
update on t2
for each ROW
BEGIN
update t1 set c1 = month('20100909') where c2 = month('2010-10-10');
END
//
update t2 set a1 = 4 where a2 = 'AA';
select * from t1;
c1	c2
9	10
2	11
3	4
drop trigger if exists tg1;
create trigger tg1
AFTER
delete on t2
for each ROW
BEGIN
delete from t1 where c1 = month('2010^09^09');
END
