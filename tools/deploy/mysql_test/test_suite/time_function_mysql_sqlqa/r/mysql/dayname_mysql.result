drop database  IF EXISTS  db1;
create database db1;
use db1;
SET wait_timeout=30000000;
SET ob_trx_timeout = 30000000;
SET ob_query_timeout = 30000000;
##设置相同sql_mode;
SET @@sql_mode='STRICT_TRANS_TABLES,NO_ENGINE_SUBSTITUTION,no_zero_date,no_zero_in_date,PIPES_AS_CONCAT';
##参数验证
select dayname();
ERROR 42000: Incorrect parameter count in the call to native function 'dayname'
select dayname(" ");
dayname(" ")
NULL
Warnings:
Warning	5086	Not timestamp Can not cast varchar value to timestamp type
select dayname("null");
dayname("null")
NULL
Warnings:
Warning	5086	Not timestamp Can not cast varchar value to timestamp type
select dayname(0);
dayname(0)
NULL
Warnings:
Warning	5086	Not timestamp Can not cast varchar value to timestamp type
##结果不一致,ob输出工作日名称,mysql结果为null--已修复
select dayname("0000-00-00");
dayname("0000-00-00")
NULL
Warnings:
Warning	5086	Not timestamp Can not cast varchar value to timestamp type
##ob和MySQL5.7结果不一致,mysql会自动跳到下一天;
select dayname('1969-12-31 23:59:59.9999999');
dayname('1969-12-31 23:59:59.9999999')
Thursday
##ob和MySQL5.7结果不一致;OB默认00年2月有29天,mysql默认28天
select dayname('0000-02-29');
dayname('0000-02-29')
NULL
