2	test02	2022-09-09	9
4	test04	2022-09-15	15
select t1_view.*, dayofmonth(c3) from t1_view where dayofmonth(c3)=15;
c1	c2	c3	dayofmonth(c3)
4	test04	2022-09-15	15
select t1_view.*, dayofmonth(c3) from t1_view where dayofmonth(c3)<15;
c1	c2	c3	dayofmonth(c3)
1	test01	2022-09-07	7
2	test02	2022-09-09	9
select t1_view.*, dayofmonth(c3) from t1_view where dayofmonth(c3)>15;
