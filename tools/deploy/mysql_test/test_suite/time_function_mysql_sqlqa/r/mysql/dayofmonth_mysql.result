create table t1 (c1 int primary key, c2 varchar(30)) partition by range(c1) (
PARTITION p0 VALUES LESS THAN (2),
PARTITION p1 VALUES LESS THAN (4),
PARTITION p2 VALUES LESS THAN (6)
);
