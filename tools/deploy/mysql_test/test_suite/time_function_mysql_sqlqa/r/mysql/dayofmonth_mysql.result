##PL块
drop table t1;
drop table t2;
DROP PROCEDURE pro1;
CREATE  PROCEDURE pro1( out a varchar(30))
begin
select dayofmonth('2022-09-14') into a;
end;
//
CALL pro1(@aa);
select @aa;
@aa
14
DROP PROCEDURE pro1;
DROP PROCEDURE pro2;
CREATE  PROCEDURE pro2( out b int)
begin
select dayofmonth('2022-09-14') into b;
end;
//
CALL pro2(@bb);
select @bb;
@bb
14
DROP PROCEDURE pro2;
drop table t1;
create table t1(c1 int,c2 varchar(30));
DROP PROCEDURE pro3;
CREATE PROCEDURE pro3(in a varchar(20))
begin
declare i int;
set i=20220910;
while i <=20220914  DO
if i > a then
select dayofmonth(i);
end if;
insert into t1 values(i,dayofmonth(i));
set i = i + 1;
end WHILE;
end;
//
CALL pro3(20220920);
DROP PROCEDURE pro3;
drop table t1;
create table t1(c1 int,c2 varchar(30));
DROP PROCEDURE pro4;
CREATE PROCEDURE pro4(in a int)
begin
declare i int;
declare b int;
set i=20220910;
while i <=20220914  DO
if a =20220920 then
select dayofmonth(a);
end if;
insert into t1 values(a ,dayofmonth(a));
set i = i + 1;
end WHILE;
select a into b;
end;
//
CALL pro4(20220920);
dayofmonth(a)
dayofmonth(a)
dayofmonth(a)
dayofmonth(a)
dayofmonth(a)
20
20
20
20
20
select * from t1;
c1	c2
20220920	20
20220920	20
20220920	20
20220920	20
20220920	20
DROP PROCEDURE pro4;
drop table t1;
create table t1(c1 int,c2 varchar(30));
drop function  f1;
create function f1(aa  int) returns varchar(30)
begin
return dayofmonth(aa);
end;
//
select f1(20220914);
f1(20220914)
14
drop table t1;
drop function  f1;
