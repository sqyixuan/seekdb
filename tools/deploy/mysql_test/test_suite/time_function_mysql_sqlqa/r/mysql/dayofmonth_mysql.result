目前 OB 不支持这样改变列类型。小类型可以改大，大的不能改小。也不能跨大类型改。
alter  table t1 modify  column c1 varchar(30)  GENERATED ALWAYS AS (dayofmonth('2022-09-13')) STORED NOT NULL COMMENT '日期';
ERROR HY000: 'Changing the STORED status' is not supported for generated columns.
drop table t1;
create table t1 (c1 int primary key, c2 varchar(30)) partition by hash(dayofmonth(c1)) partitions 3;
