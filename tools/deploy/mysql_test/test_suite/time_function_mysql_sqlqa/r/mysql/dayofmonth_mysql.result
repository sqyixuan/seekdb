drop database  IF EXISTS  db1;
create database db1;
use db1;
SET wait_timeout=30000000;
SET ob_trx_timeout = 30000000;
SET ob_query_timeout = 30000000;
##设置相同sql_mode;
SET @@sql_mode='STRICT_TRANS_TABLES,NO_ENGINE_SUBSTITUTION,no_zero_date,no_zero_in_date,PIPES_AS_CONCAT';
##参数验证
select dayofmonth();
ERROR 42000: Incorrect parameter count in the call to native function 'dayofmonth'
select dayofmonth(" ");
dayofmonth(" ")
NULL
Warnings:
Warning	5086	Not timestamp Can not cast varchar value to timestamp type
select dayofmonth("null");
dayofmonth("null")
NULL
Warnings:
Warning	5086	Not timestamp Can not cast varchar value to timestamp type
select dayofmonth(0);
dayofmonth(0)
0
select dayofmonth(1);
dayofmonth(1)
NULL
Warnings:
Warning	5086	Not timestamp Can not cast varchar value to timestamp type
