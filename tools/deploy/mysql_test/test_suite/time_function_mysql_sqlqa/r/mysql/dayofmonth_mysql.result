##约束
drop table t1;
create table t1(c1 varchar(20) primary key,c2 varchar(20) default '10');
drop table t2;
create table t2(a1 varchar(20) unique key ,a2 varchar(20),a3 varchar(20),CONSTRAINT for_key FOREIGN KEY (a3) REFERENCES  t1 (c1));
drop table t3;
create table t3(b1 varchar(20) not null ,b2 varchar(20));
insert into t1 values(dayofmonth('2022-09-14'),dayofmonth('2022-09-15'));
insert into t1(c1) values(dayofmonth('2022-09-16'));
update t1 set c1=dayofmonth('2022-09-17'),c2=dayofmonth('2022-09-18') where c2='10';
select * from t1;
c1	c2
14	15
17	18
insert into t2 values(dayofmonth('2022-09-14'),'test',dayofmonth('2022-09-15'));
