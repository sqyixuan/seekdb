drop database if exists db1;
create database db1;
use db1;
#PL
#procedure
drop table if exists t1;
Warnings:
Note	1051	Unknown table 'db1.t1'
create table t1(c1 int,c2 year,c3 char(100));
drop procedure if exists pro1;
CREATE  PROCEDURE pro1()
begin
declare j int;
declare i int;
set j = 5;
set i = 1;
while i <= j DO
insert into t1 values(i,year(20201212+1),year('2022-02-02'));
set i = i + 1;
end WHILE;
end
//
call pro1();
select * from t1;
c1	c2	c3
1	2020	2022
2	2020	2022
3	2020	2022
4	2020	2022
5	2020	2022
drop   procedure if   exists   pro1;
create procedure pro1(aa int,bb int)
begin
if aa = bb then
update t1 set c2 = year('2008-08-08') where c1 = 2 and c3 = year('2022-06-06');
elseif aa > bb then
update t1 set c2 = year('1998-08-08') where c1 = 1 and c3 = year('2022-08-08');
else
update t1 set c2 = year('1978-08-08') where c1 = 3 and c3 = year('2022-10-10');
end if;
end
//
call pro1(1,1);
call pro1(2,1);
call pro1(0,1);
select * from t1;
c1	c2	c3
1	1998	2022
2	2008	2022
3	1978	2022
4	2020	2022
5	2020	2022
drop   procedure if   exists   pro1;
create procedure pro1()
begin
declare i int default 1;
while i <= 10 do
if mod(i,10) = 0 then
insert into t1 values(6,year('1981-01-01'),year(19810101));
elseif mod(i,8)=0 then
insert into t1 values(7,year('1987-07-07'),year(19870707));
elseif mod(i,7)=0 then
insert into t1 values(8,year('1988-08-08'),year(19880808));
elseif mod(i,5)=0 then
insert into t1 values(9,year('1909-09-09'),year(19990909));
elseif mod(i,3)=0 then
insert into t1 values(10,year('2010-10-10'),year(20101010));
else
insert into t1 values(11,year('2011-11-11'),year(20111101));
end if;
set i = i+1;
end while;
end
//
call pro1();
select * from t1;
