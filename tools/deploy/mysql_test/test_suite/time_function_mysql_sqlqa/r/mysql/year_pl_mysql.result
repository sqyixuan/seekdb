drop   procedure if   exists   pro1;
create procedure pro1(aa int,bb int)
begin
if aa = bb then
delete from t1 where c1 = 1 and c2 = year('1988-02-02');
elseif aa > bb then
delete from t1 where c2 = year('2011-02-02') and c3 = year('2011-02-02');
else
delete from t1 where c3 = year('1998-02-02');
end if;
end
//
call pro1(1,1);
call pro1(2,1);
call pro1(0,1);
select * from t1;
