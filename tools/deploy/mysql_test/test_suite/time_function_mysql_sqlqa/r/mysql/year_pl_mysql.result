#function
drop table if exists t1;
create table t1(c1 int,c2 year,c3 char(100));
drop function if exists func1;
CREATE  function func1() returns year
begin
declare j int;
declare i int;
set j = 5;
set i = 1;
while i <= j DO
insert into t1 values(i,year(20201212+1),year('2022-02-02'));
set i = i + 1;
end WHILE;
return year('2022-09-15');
end
//
select func1();
func1()
2022
select * from t1;
c1	c2	c3
1	2020	2022
2	2020	2022
3	2020	2022
4	2020	2022
5	2020	2022
drop function if exists func1;
create function func1(aa int,bb int) returns year
begin
if aa = bb then
update t1 set c2 = year('2008-08-08') where c1 = 2 and c3 = year('2022-06-06');
elseif aa > bb then
update t1 set c2 = year('1998-08-08') where c1 = 1 and c3 = year('2022-08-08');
else
update t1 set c2 = year('1978-08-08') where c1 = 3 and c3 = year('2022-10-10');
end if;
return year('0001-01-01');
end
