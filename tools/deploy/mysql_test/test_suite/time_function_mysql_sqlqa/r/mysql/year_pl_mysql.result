drop   procedure if   exists   pro1;
create procedure pro1(aa int,bb int)
begin
if aa = bb then
select year('2020-10-10'),year(20201010),year('2004-02-30');
elseif aa > bb then
select year('0001-10-10'),year(99991231),year('0002-02-30');
else
select year('5000-10-10'),year(50001010),year('2999-02-30');
end if;
end
//
call pro1(1,1);
year('2020-10-10')	year(20201010)	year('2004-02-30')
