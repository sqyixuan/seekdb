create function func1(aa int,bb int) returns int
begin
if aa = bb then
delete from t1 where c1 > 1 and c2 = hour('1988-10-02 10:10:10');
elseif aa > bb then
delete from t1 where c2 > hour('2011-02-02 10:10:10') and c3 = hour('2011-02-02 05:05:05');
else
delete from t1 where c3 = hour('1998-02-02 06:06:06');
end if;
return hour('05:05:05');
end
