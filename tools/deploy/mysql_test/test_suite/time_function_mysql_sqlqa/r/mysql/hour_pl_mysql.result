drop table if exists t1;
Warnings:
Note	1051	Unknown table 'db1.t1'
create table t1(c1 int,c2 int,c3 char(100));
drop procedure if exists pro1;
CREATE  PROCEDURE pro1()
begin
declare j int;
declare i int;
set j = 5;
set i = 1;
while i <= j DO
insert into t1 values(i,hour(20201212155050),hour('2022-02-02 18:06:06'));
set i = i + 1;
end WHILE;
end
//
call pro1();
