drop   procedure if   exists   pro1;
create procedure pro1()
begin
declare i int default 1;
while i <= 10 do
if mod(i,10) = 0 then
insert into t1 values(6,hour('1981-01-01 08:08:08'),hour(010101));
elseif mod(i,8)=0 then
insert into t1 values(7,hour('1987-07-07 09:09:09'),hour(020202));
elseif mod(i,7)=0 then
insert into t1 values(8,hour('1988-08-08 10:10:10'),hour(030303));
elseif mod(i,5)=0 then
insert into t1 values(9,hour('1909-09-09 11:11:11'),hour(040404));
elseif mod(i,3)=0 then
insert into t1 values(10,hour('2010-10-10 12:12:12'),hour(050505));
else
insert into t1 values(11,hour('2011-11-11 13:13:13'),hour(060606));
end if;
set i = i+1;
end while;
end
