begin
declare j int;
declare i int;
set j = 5;
set i = 1;
while i <= j DO
insert into t1 values(i,hour(20201212155050),hour('2022-02-02 18:06:06'));
set i = i + 1;
end WHILE;
return hour('08:08:08');
end
