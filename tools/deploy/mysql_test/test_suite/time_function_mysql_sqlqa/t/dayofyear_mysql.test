select (dayofyear('2022-09-15')+1)/-50.55;

select dayofyear('2022-09-15')%0;
select dayofyear('2022-09-15')%10;
select dayofyear('2022-09-15')%'a';
select dayofyear('2022-09-15')%'2020-06-17';
