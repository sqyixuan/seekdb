--disable_warnings
drop database  IF EXISTS  db1;
--enable_warnings
create database db1;
use db1;

SET wait_timeout=30000000;
SET ob_trx_timeout = 30000000;
SET ob_query_timeout = 30000000;

--echo ##设置相同sql_mode;
SET @@sql_mode='STRICT_TRANS_TABLES,NO_ENGINE_SUBSTITUTION,no_zero_date,no_zero_in_date,PIPES_AS_CONCAT';

--echo ##参数验证

--error 1582
select dayofyear();
select dayofyear(" ");
select dayofyear("null");
select dayofyear(0);
select dayofyear(1);
select dayofyear("0000-00-00");
select dayofyear('2022年9月19日');
select dayofyear('二零二二年九月十九日');

select dayofyear('1969-12-31 23:59:59.9999999');
--echo ##ob和MySQL5.7结果不一致;
select dayofyear('0000-02-29');

--error 1582
select dayofyear(current_time(),current_timestamp());

select dayofyear('monday'), dayofyear('Tuesday'), dayofyear('Wednesday'),dayofyear('Sunday'),dayofyear('Thursday'),dayofyear('Friday'),dayofyear('Saturday');
select dayofyear('0.01.01');
select dayofyear('9999.12.31');
select dayofyear(+"2022-09-05");
select dayofyear(-"2022-09-05");
select dayofyear('a');
select dayofyear('@@@');
select dayofyear('#');
select dayofyear('""');
select dayofyear('_');
select dayofyear('false');
select dayofyear('true');
select dayofyear('2022-09-05')+4;
select dayofyear('2022-09-05')+false;
select dayofyear('2022-09-05')+true;
select dayofyear('星期一');
select dayofyear('星期一1999-12-31');
select dayofyear('星期一@#');
select dayofyear('1999-12-31星期一');
select dayofyear(1.175494351E-38) From dual;
select dayofyear('-1970-12-31');
select dayofyear('にににににににに');
select dayofyear('천구백구십칠년 일월 오일');
select dayofyear('一九九九零二二六');
select dayofyear('壹玖玖捌零伍贰贰');
select dayofyear('2022-09-07')<'monday';
select dayofyear('2022-09-07')>'monday';
select dayofyear('2022-09-07') != 'Wednesday';
select dayofyear('2022-09-07') >= 'Wednesday';
select dayofyear('2022-09-07') <= 'Wednesday';
select dayofyear('2022-09-07') = 'Wednesday';
select dayofyear(date '2022-09-15');
--echo ##MYSQL5.7报错1525,OB显示为null
--error 1525
select dayofyear(date '0000-00-00');
select dayofyear(date '9999-12-31');
#select dayofyear(time '17:01:00');

--echo OB会显示系统时间,MySQL5.7直接报错;
#select dayofyear(time '17:01:-1');

--error 1525
select dayofyear(time '17:01:60');
#select dayofyear(time '00:00:00');
#select dayofyear(time '23:59:59');
#select dayofyear(time '23:59:59');

select dayofyear('2022-09-15 23:59:59');
select dayofyear('2022-09-15 00:00:00');
select dayofyear('2022-09-15 00:59:59');



--echo ##ob和MySQL5.7结果不一致;
select dayofyear('1999-12-31星期1999-12-30');

select dayofyear('1995.02.28')+2000000000000000;
select dayofyear('9999-12-31 23:59:59.999999')+0;
select dayofyear('9999-12-31 23:59:59.999999')-0;
select dayofyear('9999-12-31 23:59:59.999999')*1;
select dayofyear('9999-12-31 23:59:59.999999')/1;

--echo 表字符集测试

set names binary;
select dayofyear('');
select dayofyear('0');
select dayofyear(0);
select dayofyear('+1');
select dayofyear('-1');
select dayofyear('-false');
select dayofyear('-true');
select dayofyear('null');
select dayofyear('1970-01-01');
select dayofyear('9999-12-31');
select dayofyear('1000-01-01');

