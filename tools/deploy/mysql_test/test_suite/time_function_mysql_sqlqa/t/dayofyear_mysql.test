#select dayofyear('2022-09-15') DIV DATE_ADD(NOW(), INTERVAL 5 DAY);
#select (dayofyear('2022-09-15')+0) DIV DATE_ADD(NOW(), INTERVAL 5 DAY);
select (dayofyear('2022-09-15')+0) DIV -8;

select dayofyear('2022-09-15') MOD 0;
select dayofyear('2022-09-15') MOD 10;
select dayofyear('2022-09-15') MOD 'a';
select dayofyear('2022-09-15') MOD '2020-06-17';
#select dayofyear('2022-09-15') MOD CURRENT_DATE();
#select dayofyear('2022-09-15') MOD CURDATE();
#select dayofyear('2022-09-15') MOD CURRENT_TIMESTAMP(6);
#select dayofyear('2022-09-15') MOD DATE_ADD(NOW(), INTERVAL 5 DAY);
#select (dayofyear('2022-09-15')+0) MOD CURRENT_TIMESTAMP(6);

select dayofyear('2022-09-15') || dayofyear('2022-09-15')+0;
select dayofyear('2022-09-15')+0+1000;
