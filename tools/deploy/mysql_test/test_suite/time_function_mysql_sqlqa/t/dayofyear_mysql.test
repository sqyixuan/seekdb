--error 0,1305
DROP PROCEDURE pro4;
DELIMITER //;
CREATE PROCEDURE pro4(in a int)
begin
declare i int;
declare b int;
set i=20220910;
while i <=20220914  DO
if a =20220920 then
select dayofyear(a);
end if;
insert into t1 values(a ,dayofyear(a));
set i = i + 1;
end WHILE;
select a into b;
end;
//
DELIMITER ;//
CALL pro4(20220920);
select * from t1;
DROP PROCEDURE pro4;

