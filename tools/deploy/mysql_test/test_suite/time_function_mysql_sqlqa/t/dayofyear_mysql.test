select * from t1 ORDER by c1 asc;
select * from t1 ORDER by dayofyear(c1) asc;
select dayofyear(c2+1) from t1;
select dayofyear(c2-1) from t1;
select dayofyear(c2*1) from t1;
select dayofyear(c2/1) from t1;
select c1,dayofyear(c1) from t1;
select c2,dayofyear(c2) from t1;
select c3,dayofyear(c3) from t1;
select c4,dayofyear(c4) from t1;
select c5,dayofyear(c5) from t1;
select c6,dayofyear(c6) from t1;
select c7,dayofyear(c7) from t1;
select c8,dayofyear(c8) from t1;
SELECT * FROM t1 WHERE dayofyear(c2) ORDER by c1 asc;
drop table t1;

