#select dayofyear('2022-09-15')%CURDATE();
#select dayofyear('2022-09-15')%CURRENT_TIMESTAMP(6);
#select dayofyear('2022-09-15')%DATE_ADD(NOW(), INTERVAL 5 DAY);
select (dayofyear('2022-09-15')+0)%0;
