update t1 set c1= abs(dayofmonth(20220811));
update t1 set c1= abs(dayofmonth(20220811)+1);
--error 1292
update t1 set c1= TO_DAYS(dayofmonth(20220811));
update t1 set c1= LOCATE(dayofmonth(20220811)-1,dayofmonth(20220811));
--error 1582
update t1 set c1= DATE_ADD(dayofmonth()+0,INTERVAL 5 DAY);
