#description: obmysql模式,dayofmonth()函数测试
#tags:
#author: wb-ljh01399065
--disable_warnings
drop database  IF EXISTS  db1;
--enable_warnings
create database db1;
use db1;

SET wait_timeout=30000000;
SET ob_trx_timeout = 30000000;
SET ob_query_timeout = 30000000;

--echo ##设置相同sql_mode;
SET @@sql_mode='STRICT_TRANS_TABLES,NO_ENGINE_SUBSTITUTION,no_zero_date,no_zero_in_date,PIPES_AS_CONCAT';

--echo ##参数验证

--error 1582
select dayofmonth();
select dayofmonth(" ");
select dayofmonth("null");
select dayofmonth(0);
select dayofmonth(1);

--echo ##结果不一致,ob输出工作日名称,mysql结果为null
select dayofmonth("0000-00-00");
select dayofmonth('1969-12-31 23:59:59.9999999');
--echo ##ob和MySQL5.7结果不一致;
select dayofmonth('0000-02-29');

--error 1582
select dayofmonth(current_time(),current_timestamp());

select dayofmonth('monday'), dayofmonth('Tuesday'), dayofmonth('Wednesday'),dayofmonth('Sunday'),dayofmonth('Thursday'),dayofmonth('Friday'),dayofmonth('Saturday');
select dayofmonth('0.01.01');
select dayofmonth('9999.12.31');
select dayofmonth(+"2022-09-05");
select dayofmonth(-"2022-09-05");
select dayofmonth('a');
select dayofmonth('@@@');
select dayofmonth('#');
select dayofmonth('""');
select dayofmonth('_');
select dayofmonth('false');
select dayofmonth('true');
select dayofmonth('2022-09-05')+4;
select dayofmonth('2022-09-05')+false;
select dayofmonth('2022-09-05')+true;
select dayofmonth('星期一');
select dayofmonth('星期一1999-12-31');
select dayofmonth('星期一@#');
select dayofmonth('1999-12-31星期一');
select dayofmonth(1.175494351E-38) From dual;
select dayofmonth('-1970-12-31');
select dayofmonth('にににににににに');
select dayofmonth('천구백구십칠년 일월 오일');
select dayofmonth('一九九九零二二六');
select dayofmonth('壹玖玖捌零伍贰贰');
select dayofmonth('2022-09-07')<'monday';
select dayofmonth('2022-09-07')>'monday';
select dayofmonth('2022-09-07') != 'Wednesday';
select dayofmonth('2022-09-07') >= 'Wednesday';
select dayofmonth('2022-09-07') <= 'Wednesday';
select dayofmonth('2022-09-07') = 'Wednesday';
select dayofmonth(date '2022-09-15');
--error 1525
select dayofmonth(date '0000-00-00');
select dayofmonth(date '9999-12-31');
#select dayofmonth(time '17:01:00');

--echo OB会显示系统时间,MySQL5.7直接报错;
#select dayofmonth(time '17:01:-1');

--error 1525
select dayofmonth(time '17:01:60');
#select dayofmonth(time '00:00:00');
#select dayofmonth(time '23:59:59');
#select dayofmonth(time '23:59:59');

select dayofmonth('2022-09-15 23:59:59');
select dayofmonth('2022-09-15 00:00:00');
select dayofmonth('2022-09-15 00:59:59');



--echo ##ob和MySQL5.7结果不一致;
select dayofmonth('1999-12-31星期1999-12-30');

select dayofmonth('1995.02.28')+2000000000000000;
select dayofmonth('9999-12-31 23:59:59.999999')+0;
select dayofmonth('9999-12-31 23:59:59.999999')-0;
select dayofmonth('9999-12-31 23:59:59.999999')*1;
select dayofmonth('9999-12-31 23:59:59.999999')/1;

--echo 表字符集测试

set names binary;
select dayofmonth('');
select dayofmonth('0');
select dayofmonth(0);
select dayofmonth('+1');
select dayofmonth('-1');
select dayofmonth('-false');
select dayofmonth('-true');
select dayofmonth('null');
select dayofmonth('1970-01-01');
select dayofmonth('9999-12-31');
select dayofmonth('1000-01-01');

