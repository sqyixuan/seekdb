--echo	#select
drop table if exists t1;
create table t1(c1 int ,c2 varchar(60) not null,c3 datetime default '1999-09-09 18:16:30');
insert into t1 values(161050,'18:20:30','2001-02-02 03:30:03');
insert into t1(c1,c2) values(051501,'04:25:50');
insert into t1 values(071313,'082308','1880-05-05 05:33:05');
insert into t1 values(101010,'11:11:11','0001-01-01 01:01:01');
insert into t1(c1,c2) values(121212,'15:20:20');
insert into t1 values(164050,'20220926055005','0001-01-01 01:01:01');
insert into t1 values(101010,'2020.02.02','0001-01-01 01:01:01');

select minute(c1),minute(c2),minute(c3) from t1 order by minute(c1);

--echo	#where
select minute(c1) from t1 where minute(c1) > 20 and minute(c2) <=50;
select minute(c3) from t1 where minute(c2) < 30 and minute(c3) >10;

select minute(c2) from t1 where minute(c1)<30 order by minute(c2);

select c1,case minute(c1) when minute(c1)> 5 then minute('202020') else minute('101010') end as a from t1;

select c1, case c2 when '11111111' then minute('1111') else minute('080808') end as a from t1;

select distinct minute(c1),c2,c3 from t1 order by minute(c1);
select distinct minute(c3) ,c1,c3 from t1 order by minute(c3);

select minute(c1) from t1 group by c1 having minute(c1) >=10;
drop table t1;



