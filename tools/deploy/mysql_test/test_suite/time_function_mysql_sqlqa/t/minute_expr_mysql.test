--echo	#聚合函数
drop table if exists test1;
create table test1(a1 int,a2 int,c1 datetime,c2 datetime);
insert into test1 values(1,080606,'1998-12-12 12:12:12','2038-01-19 03:14:14');
insert into test1 values(2,090909,'2002-02-02 10:00:00','2034-02-22 00:50:50');
insert into test1 values(3,101010,'2006-04-15 06:06:20','2026-05-08 05:16:16');
insert into test1 values(4,111111,'2012-12-12 12:12:12','2030-08-16 14:05:05');
select * from test1;


--echo	#count
select count(minute(c1)) from test1;
select minute(count(c1)) from test1;
select count(minute(c2)) from test1;
select minute(count(c2)) from test1;

--echo	#max
select max(minute(c1)) from test1;
select minute(max(c1)) from test1;
select max(minute(c2)) from test1;
select minute(max(c2)) from test1;

--echo	#min
select min(minute(c1)) from test1;
select minute(min(c1)) from test1;
select max(minute(c2)) from test1;
select minute(max(c2)) from test1;

--echo	#avg
select avg(minute(c1)) from test1;
select minute(avg(c1)) from test1;
select max(minute(c2)) from test1;
select minute(max(c2)) from test1;

--echo	#sum
select sum(minute(c1)) from test1;
select minute(sum(c1)) from test1;
select max(minute(c2)) from test1;
select minute(max(c2)) from test1;



