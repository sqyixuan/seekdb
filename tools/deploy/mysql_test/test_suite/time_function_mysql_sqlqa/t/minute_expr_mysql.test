select minute(sec_to_time(321513)+0);
select minute(sec_to_time(0));
select minute(sec_to_time(9999999999999999));

--echo	#date_add/sub
select minute(DATE_ADD('2018-05-01 12:12:12',INTERVAL 1 DAY));
select minute(DATE_SUB('2018-05-01 16:12:12',INTERVAL 1 minute));
select minute(DATE_ADD('2020-12-31 23:59:58',INTERVAL 1 SECOND));
select minute(DATE_ADD('2018-12-31 23:59:59',INTERVAL 1 DAY));
select minute(DATE_ADD('2100-12-31 22:59:57',INTERVAL '1:1' MINUTE_SECOND));
select minute(DATE_SUB('2025-01-01 00:00:00',INTERVAL '1 1:1:1' DAY_SECOND));
select minute(DATE_ADD('1900-01-01 00:00:00',INTERVAL '-1 10' DAY_HOUR));
select minute(DATE_SUB('1998-01-02', INTERVAL 31 DAY));
select minute(DATE_ADD('1992-12-31 23:59:59.000002',INTERVAL '1.999999' SECOND_MICROSECOND));

--echo	#date_format
select minute(DATE_FORMAT('2009-10-04 22:23:00', '%W %M %Y'));
select minute(DATE_FORMAT('2007-10-04 22:23:00', '%H:%i:%s'));

--echo #OB与MYSQL结果不一致。
select minute(DATE_FORMAT('1900-10-04 22:23:00','%D %y %a %d %m %b %j'));

select minute(DATE_FORMAT('1997-10-04 22:23:00','%H %k %I %r %T %S %w'));
select minute(DATE_FORMAT('1999-01-01 06:06:06', '%X %V'));
select minute(DATE_FORMAT('2006-06-00 12:12:12', '%d'));

--echo	#form_days
select minute(from_days(730669));
select minute(from_days(999999));

select minute(from_days(110000));

--echo	#from_unixtime
select minute(FROM_UNIXTIME(1447430881));
select minute(FROM_UNIXTIME(1447430881) + 0);
select minute(FROM_UNIXTIME(1447430881,'%Y %D %M %h:%i:%s %x'));


select minute(DATE_FORMAT('2003-10-03',GET_FORMAT(DATE,'EUR')));
select minute(STR_TO_DATE('10.31.2003',GET_FORMAT(DATE,'USA')));

