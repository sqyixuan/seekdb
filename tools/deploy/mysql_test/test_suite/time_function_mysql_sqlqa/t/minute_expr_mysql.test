--echo  #生成列
drop table if exists t1;
CREATE TABLE t1(c1 int,c2 int GENERATED ALWAYS AS (minute('060606')) VIRTUAL);
insert into t1(c1) values(1);
insert into t1(c1) values(2);
select * from t1;
drop table t1;



--echo  #算数运算符
--echo  #'+'
select minute('AAA'+060606);
select minute('77'+12121);
select minute('张三'+'050505');
select minute(060606+'AAA');
select minute(12121+'77');
select minute('050505'+'张三');

select minute('010101'+'20:50:60');
select minute('020202'+'');
select minute('03:03:03'+' ');
select minute('040404'+0001);
select minute('1010-01-01 05:05:05'+2001);
select minute('10101')+minute('123232');
select minute('202020' )+minute('2003-02-29');
select minute('211818')+minute('aaa');


--echo	#'-'
select minute('202020'-'212121');
select minute('232323'-080808);
select minute('235959'-606060);
select minute('906060'-606060);
select minute('1005050'-'AA');
select minute('885050'-'张三/');
select minute('ABC'-'060606');
select minute('周五周五'-'2010-10-10 10:10:10');

--echo  #'*'
select minute(2020*121);
select minute('1'*'2020-03-03 14:20:20');
select minute('14:20:20'+501010);
select minute('020202'*'张三');
select minute('AAA'*060606);
select minute('77'*12121);
select minute('张三'*'050505');

--echo  #'/'
select minute(21212121/333);
select minute('18:18:18'/66);
select minute(33333333/'33');
select minute('3333a333'/6);
select minute(2222222/2);
select minute('11110101'/2);

select minute(121212*3/2+121-61321);
select minute(300000/2*4+615-3.666666);


--echo  #逻辑运算符
select minute('030303') and minute(0305011);
select minute('1921-10-10 06:06:07') and minute('06:09:09');

select not minute('1111-01-01 15:24:25') ;
select not minute('111101') ;


select minute('202101') or minute('222222');
select minute('192110') or minute('198808');
select minute('180110') or minute('180010');
select minute('212112') or ('2');
select minute('212112') or 'aa';

--echo  #比较运算符
select minute('200101') > minute('20:21:02');
select minute('380101') > minute('200102');
select minute('AASA22CCC') > minute('0000-01-01');
select minute('202020') > 'AA';
select minute('00010101') >1;

select minute('2020-01-01 16:13:21') < minute('2020-01-02 19:16:18');
select minute('22:34:56') < minute('230516');
select minute('2221212') < minute('9991231');
select minute('1500-01-01 15:13:12') < 'Abc';
select minute('2000-01-01 14:18:19') < 14;


select minute('2020-01-01 11:12:11') >= minute('2020-01-02 08:09:10');
select minute('3800-01-01 10:11:11') >= minute('2050-01-01 08:08:08');
select minute('0001-01-01 22:30:50') >= minute('0000-01-01 23:23:23');
select minute('14:13:15') >= 'AA';
select minute('16:18:18') >=1;

select minute('20201111') <= minute('2020-011-11 22:22:22');
select minute(12341122) <= minute(05711212);
select minute('1500101') < 'CCC';
select minute('241231') < 25;


