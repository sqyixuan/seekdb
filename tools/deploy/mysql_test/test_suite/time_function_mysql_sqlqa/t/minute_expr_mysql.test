--echo  #update、delete
drop table if exists test1;
create table test1(a1 int,a2 char(20),c1 datetime,c2 datetime);
insert into test1 values(1,'1998-12-12 02:02:02','1998-12-12 03:12:12','2038-01-19 11:20:07');
insert into test1 values(2,'2002-02-02 04:04:04','2002-02-02 05:14:00','2034-02-22 12:22:20');
insert into test1 values(3,'2006-04-15 06:06:06','2006-04-15 07:16:20','2026-05-08 13:24:50');
insert into test1 values(4,'2012-12-12 08:08:08','2012-12-12 09:18:12','2030-08-16 14:26:50');
select * from test1;
create table test2(a1 int,a2 int);
insert into test2 values(1,2),(2,4),(3,6),(4,8),(5,10),(6,12),(7,14),(8,16),(9,18),(10,20),(11,22),(12,24),(13,26),(14,28);

update test1 set a1 = minute('11:11:11') where minute(a2) = (select a2 from test2 where a1 = 2);
update test1 set a1 = minute('12:12:12') where minute(c1) = 3 or minute(c2) = (select a2 from test2 where a1 = 11);

delete from test1 where minute(c1)> minute('2006-04-15 07:06:20') and minute(c2) > minute('2038-01-19 01:14:07');
delete from test1 where minute(c2) =(select a2 from test2 where a1 = 13);

drop table test1;



--echo  #复制表
drop table if exists t1;
create table t1(c1 int ,c2 varchar(60) not null,c3 datetime default '1999-09-09 18:16:30');
insert into t1 values(161050,'18:20:30','2001-02-02 03:30:03');
insert into t1(c1,c2) values(051501,'04:25:50');
insert into t1 values(071313,'082308','1880-05-05 05:33:05');
insert into t1 values(101010,'11:11:11','0001-01-01 01:01:01');
insert into t1(c1,c2) values(121212,'15:20:20');
insert into t1 values(164050,'20220926055005','0001-01-01 01:01:01');
insert into t1 values(101010,'200202','0001-01-01 01:01:01');
create table tt1 as select * from t1;
select minute(c1),minute(c2),minute(c3) from tt1 order by minute(c1);

--echo	#select
select minute(c1) from tt1 where minute(c1) > 20 and minute(c2) <=50;
select minute(c3) from tt1 where minute(c2) < 30 and minute(c3) >10;

select minute(c2) from tt1 where minute(c1)<30 order by minute(c2);

select c1,case minute(c1) when minute(c1)> 5 then minute('202020') else minute('101010') end as a from tt1;

select c1, case c2 when '11111111' then minute('1111') else minute('080808') end as a from tt1;

select distinct minute(c1),c2,c3 from tt1 order by minute(c1);
select distinct minute(c3) ,c1,c3 from tt1 order by minute(c3);

select minute(c1) from tt1 group by c1 having minute(c1) >=10 order by c1;


--echo #update
update tt1 set c1 = minute('080808') where minute(c2) > minute('011010') and minute(c2)<minute('011515');
update tt1 set c2 = minute('010101') where minute(c1) = minute('011313') or minute(c3) = minute('16:30:31');
update tt1 set c1 = minute('12:30:30') where minute(c3) in (select a2 from test2);

--echo  #delete
delete from tt1 where minute(c1) >minute('12:10:30') and minute(c1) < minute('161531');
delete from tt1 where minute(c2) not in (select a2 from test2);
delete from tt1 where minute(c3) != 0;

drop table t1;
drop table tt1;



--echo	#分区
--echo	#hash
drop table if exists t1;
create table t1(c1 int,c2 datetime) partition by hash(c1)
(
partition p1,
partition p2
);

insert into t1 values(114040,'1991-01-01 02:08:08');
insert into t1 values(123020,'2001-03-01 04:08:08');
insert into t1 values(131516,'2011-05-01 06:08:08');
insert into t1 values(141516,'2021-07-01 08:08:08');
insert into t1 values(141617,'2021-07-01 10:08:08');
select * from t1;

select c1 from t1 where minute(c2) > 1 group by minute(c1) having max(minute(c2))<10;
update t1 set c1 = minute('060606') where minute(c2) > 5;
delete from t1 where minute(c2) > 5 and minute(c1) = 6;
select * from t1;
drop table t1;



--echo	#range
drop table if exists t1;
create table t1(c1 int ,c2 datetime) partition by range(c1)
(
partition p1 values less than(400000),
partition p2 values less than(maxvalue)
);


insert into t1 values(200102,'1991-02-01 4:02:08');
insert into t1 values(300304,'2001-04-01 8:04:08');
insert into t1 values(400506,'2011-06-01 12:06:08');
insert into t1 values(500607,'2021-08-01 16:08:08');
insert into t1 values(600708,'2021-08-01 20:10:08');
select * from t1;

select c1 from t1 where minute(c2) > 1 group by c1 having max(minute(c2))<6;
update t1 set c1 = minute('020202') where minute(c2) > 5 and minute(c2) < 8;
select * from t1;
delete from t1 where minute(c2) > 2;
select * from t1;
drop table t1;




--echo	#list
drop table if exists t1;
create table t1(c1 int,c2 int) partition by list(c1)
(
partition p1 values in(080808,070707,060606,050505),
partition p2 values in(101010,111111,121212,131313)
);
insert into t1 values(080808,1),(070707,2),(060606,3),(050505,4);
insert into t1 values(101010,5),(111111,6),(121212,7),(131313,8);
select * from t1 order by c1;

select * from t1 partition(p1) where minute(c1) >5 and minute(c2)<5 order by minute(c1);

update t1 partition(p2) set c2 = minute('060606') where minute(c1) = minute('131010');

delete from t1 where minute(c1) > 6 and c2 < minute('12:59:59');

select * from t1;

drop table t1;



--echo	#key
drop table if exists t1;
create table t1(c1 int primary key , c2 datetime)
partition by key(c1)
partitions 2;

insert into t1 values(114040,'1991-01-01 02:02:08');
insert into t1 values(123020,'2001-03-01 04:04:08');
insert into t1 values(131516,'2011-05-01 06:06:08');
insert into t1 values(141516,'2021-07-01 08:08:08');
insert into t1 values(141617,'2021-07-01 10:10:08');
select * from t1;

select c1 from t1 where minute(c2) > 1 group by minute(c1) having max(minute(c2))<10;
update t1 set c1 = minute('060606') where minute(c2) > 9;
delete from t1 where minute(c2) > 5 and minute(c1) = 6;
select * from t1 order by c1;
drop table t1;



--echo	#range columns
drop table if exists t1;
CREATE TABLE t1 (
    c1 int,
    c2 datetime
)
PARTITION BY RANGE COLUMNS(c1) (
partition p1 values less than(400000),
partition p2 values less than(maxvalue)
);

insert into t1 values(200102,'1991-02-01 4:04:08');
insert into t1 values(300304,'2001-04-01 8:08:08');
insert into t1 values(400506,'2011-06-01 12:12:08');
insert into t1 values(500607,'2021-08-01 16:16:08');
insert into t1 values(600708,'2021-08-01 20:20:08');
select * from t1;

select c1 from t1 where minute(c2) > 1 group by c1 having max(minute(c2))<6;
update t1 set c1 = minute('020202') where minute(c2) > 5;
select * from t1;
delete from t1 where minute(c2) > 2;
select * from t1;
drop table t1;


--echo	#columns list
drop table if exists t1;
create table t1(c1 int,c2 int) partition by list columns(c1)
(
partition p1 values in(080808,070707,060606,050505),
partition p2 values in(101010,111111,121212,131313)
);
insert into t1 values(080808,1),(070707,2),(060606,3),(050505,4);
insert into t1 values(101010,5),(111111,6),(121212,7),(131313,8);
select * from t1 order by c1;

select * from t1 partition(p1) where minute(c1) >5 and minute(c2)<5 order by minute(c1);

update t1 partition(p2) set c2 = minute('060606') where minute(c1) = minute('131010');

delete from t1 where minute(c1) > 6 and c2 < minute('12:59:59');

select * from t1;

drop table t1;


--echo  #view
drop table if exists t1;
drop view if exists v_t1;
create table t1(c1 int ,c2 varchar(60) not null,c3 datetime default '1999-09-09 18:16:30');
insert into t1 values(161050,'18:20:30','2001-02-02 03:30:03');
insert into t1(c1,c2) values(051501,'04:25:50');
insert into t1 values(071313,'082308','1880-05-05 05:33:05');
insert into t1 values(101010,'11:11:11','0001-01-01 01:01:01');
insert into t1(c1,c2) values(121212,'15:20:20');
insert into t1 values(164050,'20220926055005','0001-01-01 01:01:01');
insert into t1 values(101010,'200202','0001-01-01 01:01:01');
create view v_t1 as select * from t1;
select minute(c1),minute(c2),minute(c3) from v_t1 order by minute(c1);

--echo	#select
select minute(c1) from v_t1 where minute(c1) > 20 and minute(c2) <=50;
select minute(c3) from v_t1 where minute(c2) < 30 and minute(c3) >10;

select minute(c2) from v_t1 where minute(c1)<30 order by minute(c2);

select c1,case minute(c1) when minute(c1)> 5 then minute('202020') else minute('101010') end as a from v_t1;

select c1, case c2 when '11111111' then minute('1111') else minute('080808') end as a from v_t1;

select distinct minute(c1),c2,c3 from v_t1 order by minute(c1);
select distinct minute(c3) ,c1,c3 from v_t1 order by minute(c3);

select minute(c1) from v_t1 group by c1 having minute(c1) >=10 order by c1;


--echo #update
update v_t1 set c1 = minute('080808') where minute(c2) > minute('011010') and minute(c2)<minute('011515');
update v_t1 set c2 = minute('010101') where minute(c1) = minute('011313') or minute(c3) = minute('16:30:31');
update v_t1 set c1 = minute('12:30:30') where minute(c3) in (select a2 from test2);

--echo  #delete
delete from v_t1 where minute(c1) >minute('12:10:30') and minute(c1) < minute('161531');
delete from v_t1 where minute(c2) not in (select a2 from test2);
delete from v_t1 where minute(c3) != 0;

drop table test2;
drop table t1;
