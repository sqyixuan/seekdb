--echo ##日期时间函数校验
--error 1064
select CURRENT_TIME(dayname('2022-09-07'));
--error 1064
select CURRENT_TIME(dayname('2022-09-07')-dayname('2022-09-07'));
--error 1064
select CURRENT_TIMESTAMP(dayname('2022-09-07')-dayname('2022-09-07'));
