--echo ##运算符验证
--echo ##算数运算符
--echo ##当前使用表达式进行运算时,结果与MySQL5.7不一致，MySQL会以工作日索引进行计算（周一到周日对应0-6）,mysql有时候会根据外层表达式,改变内层表达式的返回值,ob无论如何都为0；
select +dayname('2022-09-07');
select dayname('2022-09-07')-dayname('2022-09-07');

--echo ##比较运算符
--echo ##当前使用表达式进行运算时,结果与MySQL5.7不一致，MySQL会以工作日索引进行计算（周一到周日对应0-6）,mysql有时候会根据外层表达式,改变内层表达式的返回值,ob无论如何都为0；
select dayname('2022-09-07') = dayname('2022-09-07');
select dayname('2022-09-07') <> dayname('2022-09-07');
select dayname('2022-09-07') < dayname('2022-09-07');
select dayname('2022-09-07') != dayname('2022-09-07');
select dayname('2022-09-07') > dayname('2022-09-07');
select dayname('2022-09-07') >= dayname('2022-09-07');
select dayname('2022-09-07') <= dayname('2022-09-07');
select dayname('2022-09-07') <=> dayname('2022-09-07');


#select dayname('2022-09-07') = 1;
#select dayname('2022-09-07') < 1;
#select dayname('2022-09-07') <> 1;
#select dayname('2022-09-07') != 1;
#select dayname('2022-09-07') > 1;
#select dayname('2022-09-07') >= 1;
#select dayname('2022-09-07') <= 1;
#select dayname('2022-09-07') <=> 1;

select dayname('2022-09-07') in ('monday','Tuesday','Wednesday','Thursday','Friday','Saturday','Sunday');
select dayname('null') in ('monday','Tuesday','Wednesday','Thursday','Friday','Saturday','Sunday');
select dayname('null')  not in ('monday','Tuesday','Wednesday','Thursday','Friday','Saturday','Sunday');
select dayname('2022-09-07')  not in ('monday','Tuesday','Wednesday','Thursday','Friday','Saturday','Sunday');
select dayname('2022-09-07') between dayname('2022-09-07') and dayname('2022-09-08');
select dayname('2022-09-07') not between dayname('2022-09-07') and dayname('2022-09-07');
select dayname('2022-09-07') is null;
select dayname('2022-09-07') is not null;
select dayname('0') is null;
select dayname('null') is null;
select dayname('null') is true;
select dayname('null') is false;


