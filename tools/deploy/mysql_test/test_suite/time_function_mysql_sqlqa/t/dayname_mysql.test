#owner:dachuan.sdc
#owner group: SQL2组
#description: obmysql模式,dayname()函数测试
#tags:
#author: wb-ljh01399065
--disable_warnings
drop database  IF EXISTS  db1;
--enable_warnings
create database db1;
use db1;

SET wait_timeout=30000000;
SET ob_trx_timeout = 30000000;
SET ob_query_timeout = 30000000;

--echo ##设置相同sql_mode;
SET @@sql_mode='STRICT_TRANS_TABLES,NO_ENGINE_SUBSTITUTION,no_zero_date,no_zero_in_date,PIPES_AS_CONCAT';

--echo ##参数验证

--error 1582
select dayname();
select dayname(" ");
select dayname("null");
select dayname(0);

--echo ##结果不一致,ob输出工作日名称,mysql结果为null--已修复
select dayname("0000-00-00");
--echo ##ob和MySQL5.7结果不一致,mysql会自动跳到下一天;
select dayname('1969-12-31 23:59:59.9999999');
--echo ##ob和MySQL5.7结果不一致;OB默认00年2月有29天,mysql默认28天
select dayname('0000-02-29');

--error 1582
select dayname(current_time(),current_timestamp());

select dayname('monday'), dayname('Tuesday'), dayname('Wednesday'),dayname('Sunday'),dayname('Thursday'),dayname('Friday'),dayname('Saturday');
select dayname('0.01.01');
select dayname('9999.12.31');
select dayname(+"2022-09-05");
select dayname(-"2022-09-05");
select dayname('a');
select dayname('@@@');
select dayname('#');
select dayname('""');
select dayname('_');
select dayname('false');
select dayname('true');
select dayname('2022-09-05')+4;
select dayname('2022-09-05')+false;
select dayname('2022-09-05')+true;
select dayname('星期一');
select dayname('星期一1999-12-31');
select dayname('星期一@#');
select dayname('1999-12-31星期一');
select dayname(1.175494351E-38) From dual;
select dayname('-1970-12-31');
select dayname('にににににににに');
select dayname('천구백구십칠년 일월 오일');
select dayname('一九九九零二二六');
select dayname('壹玖玖捌零伍贰贰');
select dayname('2022-09-07')<'monday';
select dayname('2022-09-07')>'monday';
select dayname('2022-09-07') != 'Wednesday';
select dayname('2022-09-07') >= 'Wednesday';
select dayname('2022-09-07') <= 'Wednesday';
select dayname('2022-09-07') = 'Wednesday';


--echo ##ob和MySQL5.7结果不一致;
select dayname('1999-12-31星期1999-12-30');

--echo ##ob与mysql表现形式不一致
select dayname('1995.02.28')+2000000000000000;

--echo ##经过和山庭老师确认,此处是by design的，mysql有时候会根据外层表达式，改变内层表达式的返回值，比如这里dayname外面是加一个int，那dayname会返回是一周的第几天，而不是一个字符串
select dayname('9999-12-31 23:59:59.999999')+0;
select dayname('9999-12-31 23:59:59.999999')-0;
select dayname('9999-12-31 23:59:59.999999')*1;
select dayname('9999-12-31 23:59:59.999999')/1;


--echo 表字符集测试
set names binary;
select dayname('');
select dayname('0');
select dayname(0);
select dayname('+1');
select dayname('-1');
select dayname('-false');
select dayname('-true');
select dayname('null');
select dayname('1970-01-01');
select dayname('9999-12-31');
select dayname('1000-01-01');

drop table  IF EXISTS  t1;
CREATE TABLE t1(c1 TIME ,
                c2 date ,
                c3 DATETIME ,
                c4 TIMESTAMP DEFAULT '2000-01-01 00:00:00',
                c5 YEAR ) default charset=binary;
