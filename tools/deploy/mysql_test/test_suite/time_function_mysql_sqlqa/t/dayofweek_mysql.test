select * from t1 ORDER by dayofweek(c1) asc;
select dayofweek(c2+1) from t1;
select dayofweek(c2-1) from t1;
select dayofweek(c2*1) from t1;
select dayofweek(c2/1) from t1;
select c1,dayofweek(c1) from t1;
