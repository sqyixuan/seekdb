# Mysql8.0 rewrites Q1 to Q2.Then it calculates the result type in stage of execution and cast dayofmonth(20220812) to date.
# If the rewrite does not happen, Mysql will convert C3 to double.For example, Mysql 8.0 returns success when excuting Q3.
# OB calculates the result type in stage of resolver.So it will cast c3 to double.
# Q1:update t1 set c1= dayofmonth(20220812) where c3>any(select dayofmonth(20220811));
# Q2:update t1 set c1 = dayofmonth(20220812) where c3 > dayofmonth(20220811)
# Q3:update t1 set c1 = dayofmonth(20220812) where c3 > any(select dayofmonth(20220811) from t1);
