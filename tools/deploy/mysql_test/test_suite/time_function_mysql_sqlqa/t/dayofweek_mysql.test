--disable_warnings
drop database if exists  db1;
--enable_warnings
create database db1;
use db1;

SET wait_timeout=30000000;
SET ob_trx_timeout = 30000000;
SET ob_query_timeout = 30000000;

--echo ##设置相同sql_mode;
SET @@sql_mode='STRICT_TRANS_TABLES,NO_ENGINE_SUBSTITUTION,no_zero_date,no_zero_in_date,PIPES_AS_CONCAT';

--echo ##参数验证

--error 1582
select dayofweek();
select dayofweek(" ");
select dayofweek("null");
select dayofweek(0);
select dayofweek(1);
select dayofweek("0000-00-00");
select dayofweek('2022年9月19日');
select dayofweek('二零二二年九月十九日');

select dayofweek('1969-12-31 23:59:59.9999999');
--echo ##ob和MySQL5.7结果不一致;
select dayofweek('0000-02-29');

--error 1582
select dayofweek(current_time(),current_timestamp());

select dayofweek('monday'), dayofweek('Tuesday'), dayofweek('Wednesday'),dayofweek('Sunday'),dayofweek('Thursday'),dayofweek('Friday'),dayofweek('Saturday');
select dayofweek('0.01.01');
select dayofweek('9999.12.31');
select dayofweek(+"2022-09-05");
select dayofweek(-"2022-09-05");
select dayofweek('a');
select dayofweek('@@@');
select dayofweek('#');
select dayofweek('""');
select dayofweek('_');
select dayofweek('false');
select dayofweek('true');
select dayofweek('2022-09-05')+4;
select dayofweek('2022-09-05')+false;
select dayofweek('2022-09-05')+true;
select dayofweek('星期一');
select dayofweek('星期一1999-12-31');
select dayofweek('星期一@#');
select dayofweek('1999-12-31星期一');
select dayofweek(1.175494351E-38) From dual;
select dayofweek('-1970-12-31');
select dayofweek('にににににににに');
select dayofweek('천구백구십칠년 일월 오일');
select dayofweek('一九九九零二二六');
select dayofweek('壹玖玖捌零伍贰贰');
select dayofweek('2022-09-07')<'monday';
select dayofweek('2022-09-07')>'monday';
select dayofweek('2022-09-07') != 'Wednesday';
select dayofweek('2022-09-07') >= 'Wednesday';
select dayofweek('2022-09-07') <= 'Wednesday';
select dayofweek('2022-09-07') = 'Wednesday';
select dayofweek(date '2022-09-15');
--error 1525
select dayofweek(date '0000-00-00');
select dayofweek(date '9999-12-31');
#select dayofweek(time '17:01:00');

--echo OB会显示系统时间,MySQL5.7直接报错;
#select dayofweek(time '17:01:-1');

--error 1525
select dayofweek(time '17:01:60');
#select dayofweek(time '00:00:00');
#select dayofweek(time '23:59:59');
#select dayofweek(time '23:59:59');

select dayofweek('2022-09-15 23:59:59');
select dayofweek('2022-09-15 00:00:00');
select dayofweek('2022-09-15 00:59:59');



--echo ##ob和MySQL5.7结果不一致;
select dayofweek('1999-12-31星期1999-12-30');

select dayofweek('1995.02.28')+2000000000000000;
select dayofweek('9999-12-31 23:59:59.999999')+0;
select dayofweek('9999-12-31 23:59:59.999999')-0;
select dayofweek('9999-12-31 23:59:59.999999')*1;
select dayofweek('9999-12-31 23:59:59.999999')/1;

--echo 表字符集测试

set names binary;
select dayofweek('');
select dayofweek('0');
select dayofweek(0);
select dayofweek('+1');
select dayofweek('-1');
select dayofweek('-false');
select dayofweek('-true');
select dayofweek('null');
select dayofweek('1970-01-01');
select dayofweek('9999-12-31');
select dayofweek('1000-01-01');

