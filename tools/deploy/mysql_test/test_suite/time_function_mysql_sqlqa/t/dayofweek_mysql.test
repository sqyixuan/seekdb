#select dayofweek('2022-09-15') DIV DATE_ADD(NOW(), INTERVAL 5 DAY);
#select (dayofweek('2022-09-15')+0) DIV DATE_ADD(NOW(), INTERVAL 5 DAY);
select (dayofweek('2022-09-15')+0) DIV -8;

select dayofweek('2022-09-15') MOD 0;
select dayofweek('2022-09-15') MOD 10;
select dayofweek('2022-09-15') MOD 'a';
select dayofweek('2022-09-15') MOD '2020-06-17';
#select dayofweek('2022-09-15') MOD CURRENT_DATE();
#select dayofweek('2022-09-15') MOD CURDATE();
#select dayofweek('2022-09-15') MOD CURRENT_TIMESTAMP(6);
#select dayofweek('2022-09-15') MOD DATE_ADD(NOW(), INTERVAL 5 DAY);
#select (dayofweek('2022-09-15')+0) MOD CURRENT_TIMESTAMP(6);

select dayofweek('2022-09-15') || dayofweek('2022-09-15')+0;
select dayofweek('2022-09-15')+0+1000;
select dayofweek('2022-09-15')-1-1000;
select (dayofweek('2022-09-15')-1)*1000;
