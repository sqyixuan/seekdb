--echo ##ob和MySQL5.7结果不一致;
select monthname('1999-12-31星期1999-12-30');

--echo ##ob与mysql表现形式不一致
select monthname('1995.02.28')+2000000000000000;


select monthname('9999-12-31 23:59:59.999999')+0;
select monthname('9999-12-31 23:59:59.999999')-0;
select monthname('9999-12-31 23:59:59.999999')*1;
