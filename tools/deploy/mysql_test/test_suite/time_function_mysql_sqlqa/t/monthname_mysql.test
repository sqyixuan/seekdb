--disable_warnings
drop database  IF EXISTS  db1;
--enable_warnings
create database db1;
use db1;

SET wait_timeout=30000000;
SET ob_trx_timeout = 30000000;
SET ob_query_timeout = 30000000;

--echo ##参数验证

--error 1582
select monthname();
select monthname(" ");
select monthname("null");
select monthname(0);
select monthname("0000-00-00");
--echo ##ob和MySQL5.7结果不一致;
select monthname('1969-12-31 23:59:59.9999999');
--echo ##ob和MySQL5.7结果不一致;
select monthname('0000-02-29');

--error 1582
select monthname(current_time(),current_timestamp());
select monthname('monday'), monthname('Tuesday'), monthname('Wednesday'),monthname('Sunday'),monthname('Thursday'),monthname('Friday'),monthname('Saturday');
select monthname('0.01.01');
select monthname('9999.12.31');
select monthname(+"2022-09-05");
select monthname(-"2022-09-05");
