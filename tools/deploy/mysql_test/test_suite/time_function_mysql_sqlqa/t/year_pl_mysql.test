--disable_warnings
drop database if exists db1;
--enable_warnings

create database db1;
use db1;



--echo	#PL
--echo	#procedure
drop table if exists t1;
create table t1(c1 int,c2 year,c3 char(100));
drop procedure if exists pro1;
DELIMITER //;
CREATE  PROCEDURE pro1()
begin
	declare j int;
	declare i int;
	set j = 5;
	set i = 1;
    while i <= j DO
        insert into t1 values(i,year(20201212+1),year('2022-02-02'));
        set i = i + 1;
    end WHILE;
end
//
DELIMITER ;//

call pro1();
select * from t1;



drop   procedure if   exists   pro1;
delimiter //;
create procedure pro1(aa int,bb int)
begin
    if aa = bb then
         update t1 set c2 = year('2008-08-08') where c1 = 2 and c3 = year('2022-06-06');
    elseif aa > bb then
         update t1 set c2 = year('1998-08-08') where c1 = 1 and c3 = year('2022-08-08');
    else
        update t1 set c2 = year('1978-08-08') where c1 = 3 and c3 = year('2022-10-10');
    end if;
end
//
delimiter ;//
call pro1(1,1);
call pro1(2,1);
call pro1(0,1);

select * from t1;


drop   procedure if   exists   pro1;
delimiter //;
create procedure pro1()
begin
    declare i int default 1;
    while i <= 10 do
        if mod(i,10) = 0 then
        		insert into t1 values(6,year('1981-01-01'),year(19810101));
        elseif mod(i,8)=0 then
                insert into t1 values(7,year('1987-07-07'),year(19870707));
        elseif mod(i,7)=0 then
        		insert into t1 values(8,year('1988-08-08'),year(19880808));
        elseif mod(i,5)=0 then
        		insert into t1 values(9,year('1909-09-09'),year(19990909));
        elseif mod(i,3)=0 then
                insert into t1 values(10,year('2010-10-10'),year(20101010));
        else
                insert into t1 values(11,year('2011-11-11'),year(20111101));
        end if;
        set i = i+1;
    end while;
end
//
delimiter ;//
call pro1();
select * from t1;


drop   procedure if   exists   pro1;
delimiter //;
create procedure pro1(aa int,bb int)
begin
    if aa = bb then
         delete from t1 where c1 = 1 and c2 = year('1988-02-02');
    elseif aa > bb then
         delete from t1 where c2 = year('2011-02-02') and c3 = year('2011-02-02');
    else
        delete from t1 where c3 = year('1998-02-02');
    end if;
end
//
delimiter ;//
call pro1(1,1);
call pro1(2,1);
call pro1(0,1);

select * from t1;


drop   procedure if   exists   pro1;
delimiter //;
create procedure pro1(aa int,bb int)
begin
    if aa = bb then
         select year('2020-10-10'),year(20201010),year('2004-02-30');
    elseif aa > bb then
         select year('0001-10-10'),year(99991231),year('0002-02-30');
    else
        select year('5000-10-10'),year(50001010),year('2999-02-30');
    end if;
end
//
delimiter ;//
call pro1(1,1);
call pro1(2,1);
call pro1(0,1);


--echo	#function
drop table if exists t1;
create table t1(c1 int,c2 year,c3 char(100));
drop function if exists func1;
DELIMITER //;
CREATE  function func1() returns year
begin
	declare j int;
	declare i int;
	set j = 5;
	set i = 1;
    while i <= j DO
        insert into t1 values(i,year(20201212+1),year('2022-02-02'));
        set i = i + 1;
    end WHILE;
   	return year('2022-09-15');
end
//
DELIMITER ;//

select func1();
select * from t1;


drop function if exists func1;
delimiter //;
create function func1(aa int,bb int) returns year
begin
    if aa = bb then
         update t1 set c2 = year('2008-08-08') where c1 = 2 and c3 = year('2022-06-06');
    elseif aa > bb then
         update t1 set c2 = year('1998-08-08') where c1 = 1 and c3 = year('2022-08-08');
    else
        update t1 set c2 = year('1978-08-08') where c1 = 3 and c3 = year('2022-10-10');
    end if;
    return year('0001-01-01');
end
//
delimiter ;//
select func1(1,1);
select func1(2,1);
select func1(0,1);

select * from t1;


drop function if exists func1;
delimiter //;
create function func1() returns year
begin
    declare i int default 1;
    while i <= 10 do
        if mod(i,10) = 0 then
        		insert into t1 values(6,year('1981-01-01'),year(19810101));
        elseif mod(i,8)=0 then
                insert into t1 values(7,year('1987-07-07'),year(19870707));
        elseif mod(i,7)=0 then
        		insert into t1 values(8,year('1988-08-08'),year(19880808));
        elseif mod(i,5)=0 then
        		insert into t1 values(9,year('1909-09-09'),year(19990909));
        elseif mod(i,3)=0 then
                insert into t1 values(10,year('2010-10-10'),year(20101010));
        else
                insert into t1 values(11,year('2011-11-11'),year(20111101));
        end if;
        set i = i+1;
    end while;
    return year('2008-08-08');
end
//
delimiter ;//
select func1();
select * from t1;

drop function if exists func1;
delimiter //;
create function func1(aa int,bb int) returns year
begin
    if aa = bb then
         delete from t1 where c1 = 1 and c2 = year('1988-02-02');
    elseif aa > bb then
         delete from t1 where c2 = year('2011-02-02') and c3 = year('2011-02-02');
    else
        delete from t1 where c3 = year('1998-02-02');
    end if;
    return year(19980909);
end
//
delimiter ;//
select func1(1,1);
select func1(2,1);
select func1(0,1);
select * from t1;


--echo	#trigger
drop   table     if   exists   t1;
drop   table     if   exists   t2;
create table t1(c1 int,c2 year);
insert into t1 values(1,2001);
insert into t1 values(2,2002);
create table t2(a1 int,a2 varchar(20));
insert into t2 values(2,'AA');
insert into t2 values(3,'cc');

drop trigger if exists tg1;
delimiter //;
create trigger tg1
AFTER
insert on t2
for each ROW
BEGIN
  insert t1 values(year('2022-09-09'),year('2020-09-09'));
END
//
delimiter ;//
insert into t2 values(1,1);
select * from t1;



drop trigger if exists tg1;
delimiter //;
create trigger tg1
AFTER
update on t2
for each ROW
BEGIN
		update t1 set c1 = year('19980808') where c2 = year('2001/01/01');
END
//
delimiter ;//
update t2 set a1 = 4 where a2 = 'AA';
select * from t1;



drop trigger if exists tg1;
delimiter //;
create trigger tg1
AFTER
delete on t2
for each ROW
BEGIN
     delete from t1 where c1 = year('19980808');
END
//
delimiter ;//
delete from t2 where a1 = 3;
select * from t1;


drop database db1;

