--echo	#convert_tz
select year(CONVERT_TZ('2004-01-01 12:00:00','+00:00','+10:00'));
select year(CONVERT_TZ('2004-01-01 12:00:00','+00:00','+20:00'));

--echo #其他函数
--echo	#concat
