--echo  #select
drop table if exists t1;
create table t1(c1 int ,c2 varchar(60) not null,c3 datetime default '2020-08-08');
insert into t1 values(19990909,'2000-01-01','2001-02-02 03:03:03');
insert into t1(c1,c2) values(10000101,'33330303');
insert into t1 values(99991231,'00010101','1880-05-05 05:05:05');
insert into t1 values(66660606,'99990909090909','0001-01-01 01:01:01');
insert into t1(c1,c2) values(20000808,'11111111');
insert into t1 values(66660606,'99990909090909','0001-01-01 01:01:01');
select year(c1),year(c2),year(c3) from t1;

--echo  #where
select year(c1) from t1 where year(c1) > 5000 and year(c2) < 7000;
select year(c3) from t1 where year(c2) < 2000 and year(c3) >2000;

select * from t1 where year(c1)>year(c2) order by year(c1);

select c1,case year(c1) when year(c1)> 5000 then year('0101-01-01') else year('2000-10-10') end as a from t1;

select c1, case c2 when '11111111' then year('1111') else year('2020-02-02') end as a from t1;

select distinct year(c1),c2,c3 from t1;
select distinct year(c3) ,c1,c3 from t1;



