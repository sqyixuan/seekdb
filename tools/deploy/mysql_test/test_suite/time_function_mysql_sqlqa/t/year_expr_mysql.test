select year(concat('2021','1111'));
select year(concat('19980715','aa'));

--echo	#ceil
select year(ceil(2.0111111));
select year(ceil(20121212.123456789));
select year(ceil(-20121212.123456789));

--echo	#cast
--error 1064
select year(cast('2021-10-08 12:12:00' as int));
select year(cast('2021-10-08 12:12:00' as double));

--echo	#MYSQL报错，OB执行成功
select year(cast('2021-10-08 14:14:00' as float));
select year(cast('2021-10-08 14:14:00' as char(100)));

--error 1064
select year(cast('2021-10-08 14:14:00' as varchar(100)));

select year(cast('2021-10-08 14:14:00' as date));
select year(cast('2021-10-08 14:14:00' as time));
select year(cast('2021-10-08 14:14:00' as datetime));

--error 1064
select year(cast('2021-10-08 14:14:00' as timestamp));
select year(cast('2021-10-08 14:14:00' as decimal(15,5)));

--echo	#length
select year(length(11111111));


--echo	#substr
select year(substr('00000002121-01-01',5));
select year(substr('012300021212' from 8));
select year(substr('012300021212' from 7));
select year(substr('1111121211121212121212121',5,13));
select year(substr('212312313-030303',2));

--echo	#reverse
select year(reverse('20120229'));
select year(reverse('92202102'));
select year(reverse(cast('2021-10-08 14:14:00' as datetime)));


--echo	#聚合函数
drop table if exists test1;
create table test1(a1 int,a2 year,c1 datetime,c2 datetime);
insert into test1 values(1,'1998','1998-12-12 12:12:12','2038-01-19 03:14:07');
insert into test1 values(2,'2002','2002-02-02 10:00:00','2034-02-22 00:50:20');
insert into test1 values(3,'2006','2006-04-15 06:06:20','2026-05-08 05:16:50');
insert into test1 values(4,'2012','2012-12-12 12:12:12','2030-08-16 14:05:50');
select * from test1;

--echo	#count
select count(year(c1)) from test1;
select year(count(c1)) from test1;
select count(year(c2)) from test1;
select year(count(c2)) from test1;

--echo	#max
select max(year(c1)) from test1;
select year(max(c1)) from test1;
select max(year(c2)) from test1;
select year(max(c2)) from test1;

--echo	#min
select min(year(c1)) from test1;
select year(min(c1)) from test1;
select max(year(c2)) from test1;
select year(max(c2)) from test1;

--echo	#avg
select avg(year(c1)) from test1;
select year(avg(c1)) from test1;
select max(year(c2)) from test1;
select year(max(c2)) from test1;

--echo	#sum
select sum(year(c1)) from test1;
select year(sum(c1)) from test1;
select max(year(c2)) from test1;
select year(max(c2)) from test1;

drop table test1;
