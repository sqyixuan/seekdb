--disable_warnings
drop database if exists db1;
--enable_warnings

create database db1;
use db1;
set timestamp = 1600000000;

--echo	#参数YYYY-MM-DD HH:MM:SS
select year('0001-01-01');
select year('0000-01-01');
select year('-2001-01-01');
select year('2001-1-01');
select year('1999-1-1');
select year('1888-111-1');
select year('0001-02-31');
