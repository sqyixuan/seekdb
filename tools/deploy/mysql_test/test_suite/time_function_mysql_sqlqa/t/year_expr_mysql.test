--echo	#date
select year(date('2003-12-31 01:02:03'));


--echo	#date_add/sub
select year(DATE_ADD('2018-05-01',INTERVAL 1 DAY));
select year(DATE_SUB('2018-05-01',INTERVAL 1 YEAR));
select year(DATE_ADD('2020-12-31 23:59:59',INTERVAL 1 SECOND));
select year(DATE_ADD('2018-12-31 23:59:59',INTERVAL 1 DAY));
select year(DATE_ADD('2100-12-31 23:59:59',INTERVAL '1:1' MINUTE_SECOND));
select year(DATE_SUB('2025-01-01 00:00:00',INTERVAL '1 1:1:1' DAY_SECOND));
select year(DATE_ADD('1900-01-01 00:00:00',INTERVAL '-1 10' DAY_HOUR));
select year(DATE_SUB('1998-01-02', INTERVAL 31 DAY));
select year(DATE_ADD('1992-12-31 23:59:59.000002',INTERVAL '1.999999' SECOND_MICROSECOND));

--echo	#date_format
select year(DATE_FORMAT('2009-10-04 22:23:00', '%W %M %Y'));
select year(DATE_FORMAT('2007-10-04 22:23:00', '%H:%i:%s'));
select year(DATE_FORMAT('1900-10-04 22:23:00','%D %y %a %d %m %b %j'));
select year(DATE_FORMAT('1997-10-04 22:23:00','%H %k %I %r %T %S %w'));
select year(DATE_FORMAT('1999-01-01', '%X %V'));
select year(DATE_FORMAT('2006-06-00', '%d'));

--echo	#form_days
select year(from_days(730669));
select year(from_days(999999));

select year(from_days(110000));

--echo	#from_unixtime
select year(FROM_UNIXTIME(1447430881));
select year(FROM_UNIXTIME(1447430881) + 0);
select year(FROM_UNIXTIME(1447430881,'%Y %D %M %h:%i:%s %x'));


select year(DATE_FORMAT('2003-10-03',GET_FORMAT(DATE,'EUR')));
select year(STR_TO_DATE('10.31.2003',GET_FORMAT(DATE,'USA')));

--echo	#last_day
select year(LAST_DAY('2003-02-05'));
select year(LAST_DAY('2004-02-05'));
select year(LAST_DAY('2004-01-01 01:01:01'));
select year(LAST_DAY('2003-03-32'));

--echo	#makedate
select year(MAKEDATE(2011,31));
select year(MAKEDATE(2011,32));
select year(MAKEDATE(2011,365));
select year(MAKEDATE(2014,365));
select year(MAKEDATE(2011,0));

select year(PERIOD_ADD(200801,2));

--echo	#str_to_date
select year(STR_TO_DATE('01,5,2013','%d,%m,%Y'));
select year(STR_TO_DATE('May 1, 2013','%M %d,%Y'));
select year(STR_TO_DATE('abc','abc'));
select year(STR_TO_DATE('9','%m'));
select year(STR_TO_DATE('00/00/0000', '%m/%d/%Y'));
select year(STR_TO_DATE('04/31/2004', '%m/%d/%Y'));
select year(STR_TO_DATE('200442 Monday', '%X%V %W'));

--echo	#subdate/time
select year(DATE_SUB('2008-01-02', INTERVAL 31 DAY));
select year(SUBDATE('2008-01-02', INTERVAL 31 DAY));
select year(SUBDATE('2008-01-02 12:00:00', 31));
select year(SUBTIME('2007-12-31 23:59:59.999999','1 1:1:1.000002'));


--echo	#timestamp
select year(TIMESTAMP('2003-12-31'));
select year(TIMESTAMP('2003-12-31 12:00:00','12:00:00'));
select year(TIMESTAMPADD(MINUTE,1,'2003-01-02'));
select year(TIMESTAMPADD(WEEK,1,'2003-01-02'));

