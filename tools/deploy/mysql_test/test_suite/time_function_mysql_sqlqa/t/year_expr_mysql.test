drop table if exists test1;
create table test1(a1 int,a2 year,c1 datetime,c2 datetime);
insert into test1 values(1,year('1998-12-12 12:12:12'),convert_tz('1998-12-12 12:12:12','+00:00','+00:00'),convert_tz('2038-01-19 03:14:07','+00:00','+00:00'));
insert into test1 values(2,year('2002-02-02 10:00:00'),convert_tz('2002-02-02 10:00:00','+00:00','+00:00'),convert_tz('2034-02-22 00:50:20','+00:00','+00:00'));
insert into test1 values(3,year('2006-04-15 06:06:20'),convert_tz('2006-04-15 06:06:20','+00:00','+00:00'),convert_tz('2026-05-08 05:16:50','+00:00','+00:00'));
insert into test1 values(4,year('2012-12-12 12:12:12'),convert_tz('2012-12-12 12:12:12','+00:00','+00:00'),convert_tz('2030-08-16 14:05:50','+00:00','+00:00'));
select * from test1;

update test1 set a1 = year('2008-08-08') where year(c1)>'2010';
update test1 set a2 = year('2019-10-01') where year(c1) = (select max(year(c1)) from test1);
select * from test1;

delete from test1 where a2 = (select min(year(c1)) from test1);
delete from test1 where year(c2) < '2050';
select * from test1;

drop table test1;


--echo	#复制表
create table test1(a1 int,a2 year,c1 datetime,c2 datetime);
insert into test1 values(1,year('1998-12-12 12:12:12'),convert_tz('1998-12-12 12:12:12','+00:00','+00:00'),convert_tz('2038-01-19 03:14:07','+00:00','+00:00'));
insert into test1 values(2,year('2002-02-02 10:00:00'),convert_tz('2002-02-02 10:00:00','+00:00','+00:00'),convert_tz('2034-02-22 00:50:20','+00:00','+00:00'));
insert into test1 values(3,year('2006-04-15 06:06:20'),convert_tz('2006-04-15 06:06:20','+00:00','+00:00'),convert_tz('2026-05-08 05:16:50','+00:00','+00:00'));
insert into test1 values(4,year('2012-12-12 12:12:12'),convert_tz('2012-12-12 12:12:12','+00:00','+00:00'),convert_tz('2030-08-16 14:05:50','+00:00','+00:00'));
insert into test1 values(4,year('2012-12-12 12:12:12'),convert_tz('2012-12-12 12:12:12','+00:00','+00:00'),convert_tz('2030-08-16 14:05:50','+00:00','+00:00'));
create table tt1 as select * from test1;
select * from tt1;

select * from tt1 where year(c1) >='2006';
select * from tt1 where a2 = year(c1) and a2 >2000 order by year(c2);
select * from tt1 where a2 = year(c1) and  year(c1)>'1900' group by a2;
select * from tt1 where a2 = year(c1) and  year(c1)>'1900' group by a2 having max(year(c2)>'2030');
select c1,case year(c1) when year(c1)> 2005 then year('0101-01-01') else year('2000-10-10') end as a from tt1;
select c1, case c2 when '11111111' then year('1111') else year('2020-02-02') end as a from tt1;
select distinct year(c1),c2 from tt1;

update tt1 set a1 = year(c1) where year(c1)>'2010';

delete from tt1 where year(c2) > '1900';

drop table tt1,test1;


--echo	#分区
--echo	#hash
drop table if exists t1;
create table t1(c1 year,c2 datetime) partition by hash(c1)
(
partition p1,
partition p2
);

insert into t1 values(year('1991-01-01'),'1991-01-01 08:08:08');
insert into t1 values(year('2001-01-01'),'2001-01-01 08:08:08');
insert into t1 values(year('2011-01-01'),'2011-01-01 08:08:08');
insert into t1 values(year('2021-01-01'),'2021-01-01 08:08:08');
insert into t1 values(year('2021-01-01'),'2021-01-01 08:08:08');
select * from t1;

select * from t1 where year(c2) > '1990' group by c1 having max(year(c2))<'2015';

update t1 set c1 = year('2009-09-09') where year(c2) > '2020';
select * from t1;

delete from t1 where year(c2) > '1999';
select * from t1;

drop table t1;



--echo	#range
drop table if exists t1;
create table t1(c1 year ,c2 datetime) partition by range(c1)
(
partition p1 values less than(year('1980-01-01')),
partition p2 values less than(maxvalue)
);

insert into t1 values(year('1970-01-01'),'1970-01-01 08:08:08');
insert into t1 values(year('1971-01-01'),'1971-01-01 08:08:08');
insert into t1 values(year('1971-01-01'),'1971-01-01 08:08:08');
insert into t1 values(year('2021-01-01'),'2021-01-01 08:08:08');
insert into t1 values(year('2021-01-01'),'2021-01-01 08:08:08');
select * from t1;

select * from t1 partition(p1) where year(c2)>'1969' group by c1 having max(year(c2)>'1970');

update t1 partition(p2) set c1 = year('2010-10-10') where year(c2)> '1999';
select * from t1;

delete from t1 partition(p2) where year(c2)>'2000';
select * from t1;

drop table t1;



--echo	#list
drop table if exists t1;
--echo	#OB报错，mysql执行成功
--error 1495
create table t1(c1 year,c2 year) partition by list(c1)
(
partition p0 values in(year('1900-01-01'),year('1950-01-01'),year('2020-01-01'),year('2070-01-01')),
partition p1 values in(year('3030-12-31'),year('4030-12-31'),year('5030-12-31'),year('6030-12-31'))
);

--echo	#key
drop table if exists t1;
create table t1(c1 year primary key , c2 datetime)
partition by key(c1)
partitions 2;

insert into t1 values(year('1970-01-01'),'1970-01-01 08:08:08');
insert into t1 values(year('1981-01-01'),'1971-01-01 08:08:08');
insert into t1 values(year('1991-01-01'),'1971-01-01 08:08:08');
insert into t1 values(year('2021-01-01'),'2021-01-01 08:08:08');
insert into t1 values(year('2031-01-01'),'2021-01-01 08:08:08');
select * from t1;

select * from t1 partition(p0) where year(c2)>'1969' group by c1 having max(year(c2)>'1970');

--echo	#OB报错，mysql执行成功
--error 1748
update t1 partition(p1) set c1 = year('2010-10-10') where year(c2)> '1999';

delete from t1 partition(p1) where year(c2)>'2000';
select * from t1;

drop table t1;


--echo	#range columns
drop table if exists t1;
CREATE TABLE t1 (
    c1 year,
    c2 datetime
)
PARTITION BY RANGE COLUMNS(c1) (
partition p1 values less than(year('1980-01-01')),
partition p2 values less than(maxvalue)
);



--echo	#columns list
drop table if exists t1;
--error 1495
create table t1(c1 year,c2 datetime)
partition by list columns(c1)
(
partition p0 values in(year('1900-01-01'),year('1950-01-01'),year('2020-01-01'),year('2070-01-01')),
partition p1 values in(year('3030-12-31'),year('4030-12-31'),year('5030-12-31'),year('6030-12-31'))
);




--echo	#view
drop table if exists test1;
create table test1(a1 int,a2 year,c1 datetime,c2 datetime);
insert into test1 values(1,year('1998-12-12 12:12:12'),convert_tz('1998-12-12 12:12:12','+00:00','+00:00'),convert_tz('2038-01-19 03:14:07','+00:00','+00:00'));
insert into test1 values(2,year('2002-02-02 10:00:00'),convert_tz('2002-02-02 10:00:00','+00:00','+00:00'),convert_tz('2034-02-22 00:50:20','+00:00','+00:00'));
insert into test1 values(3,year('2006-04-15 06:06:20'),convert_tz('2006-04-15 06:06:20','+00:00','+00:00'),convert_tz('2026-05-08 05:16:50','+00:00','+00:00'));
insert into test1 values(4,year('2012-12-12 12:12:12'),convert_tz('2012-12-12 12:12:12','+00:00','+00:00'),convert_tz('2030-08-16 14:05:50','+00:00','+00:00'));
insert into test1 values(4,year('2012-12-12 12:12:12'),convert_tz('2012-12-12 12:12:12','+00:00','+00:00'),convert_tz('2030-08-16 14:05:50','+00:00','+00:00'));
create view v_t1 as select * from test1;
select * from v_t1;


select * from v_t1 where year(c1) >='2006';

select * from v_t1 where a2 = year(c1) and a2 >2000 order by year(c2);

select * from v_t1 where a2 = year(c1) and  year(c1)>'1900' group by a2;

select * from v_t1 where a2 = year(c1) and  year(c1)>'1900' group by a2 having max(year(c2)>'2030');

select c1,case year(c1) when year(c1)> 2005 then year('0101-01-01') else year('2000-10-10') end as a from v_t1;

select c1, case c2 when '11111111' then year('1111') else year('2020-02-02') end as a from v_t1;

select distinct year(c1),c2 from v_t1;

update v_t1 set a1 = year(c1) where year(c1)>'2010';

delete from v_t1 where year(c2) > '1900';

drop table test1;
drop view v_t1;

--echo	#生成列
drop table if exists t1;
CREATE TABLE t1(c1 int,c2 int GENERATED ALWAYS AS (year('2020-02-02')) VIRTUAL);
insert into t1(c1) values(year('0001-01-01'));
insert into t1(c1) values(year('9999-12-31'));
select * from t1;
drop table t1;



--echo	#算术运算符
--echo	#'+'
select year('1010-01-01'+'1019-09-09');
select year('1010-01-01'+'');
select year('1010-01-01'+' ');
select year('1010-01-01'+0001);
select year('1010-01-01'+2001);
select year('0001-01-01')+year('9999-12-31');
select year('2020-02-02')+year('2003-02-29');
select year('2020-02-02')+year('aaa');


--echo	#'-'
select year('1010-01-01'-'1019-09-09');
select year('1010-01-01'-'');
select year('1010-01-01'-' ');
select year('1010-01-01'-0001);
select year('1010-01-01'-2001);
select year('0001-01-01')-year('9999-12-31');
select year('2020-02-02')-year('2003-02-29');
select year('2020-02-02')-year('aaa');

--echo	#'*'
select year('2020'*'2021');
select year(2020*2021);
select year(1234011*10);

--echo	#'/'
select year(202001010/10);
select year(2222222/2);
select year('11110101'/2);

--echo	#逻辑运算符
select year('2021-01-01') and year('22222222222');
select year('1921-10-10') and year('1988-08-08');

select not year('1111-01-01') ;
select not year(' ') ;
select not year('1111-01-0111') ;

select year('2021-01-01') or year('22222222222');
select year('1921-10-10') or year('1988-08-08');
select year('1800-10-10') or year('1800-10-10');
select year('2121-12-12') or ('2');
select year('2121-12-12') or 'aa';

--echo	#比较运算符
select year('2020-01-01') > year('2020-01-02');
select year('3800-01-01') > year('2050-01-02');
select year('0001-01-01') > year('0000-01-01');
select year('0001-01-01') > 'AA';
select year('0001-01-01') >1;

select year('2020-01-01') < year('2020-01-02');
select year('3800-01-01') < year('2050-01-02');
select year('2020-01-01') < year('0000-01-01');
select year('1500-01-01') < 'Abc';
select year('2000-01-01') < 1998;

select year('2020-01-01') >= year('2020-01-02');
select year('3800-01-01 10:11:11') >= year('2050-01-01 08:08:08');
select year('0001-01-01') >= year('0000-01-01');
select year('0001-01-01') >= 'AA';
select year('0001-01-01') >=1;

select year('20201111') <= year('2020-011-11');
select year(12341122) <= year(05711212);
select year('1500-01-01') < 'CCC';
select year('2499-12-31') < 2500;


