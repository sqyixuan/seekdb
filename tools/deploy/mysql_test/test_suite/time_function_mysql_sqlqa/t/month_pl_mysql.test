--disable_warnings
drop database if exists db1;
--enable_warnings

create database db1;
use db1;



--echo	#PL
--echo	#procedure
drop table if exists t1;
create table t1(c1 int,c2 int,c3 char(100));
drop procedure if exists pro1;
DELIMITER //;
CREATE  PROCEDURE pro1()
begin
	declare j int;
	declare i int;
	set j = 5;
	set i = 1;
    while i <= j DO
        insert into t1 values(i,month(20201212+1),month('2022-02-02'));
        set i = i + 1;
    end WHILE;
end
//
DELIMITER ;//

call pro1();
select * from t1;


drop   procedure if   exists   pro1;
delimiter //;
create procedure pro1(aa int,bb int)
begin
    if aa = bb then
         update t1 set c2 = month('2008-08-08') where c1 = 2 ;
    elseif aa > bb then
         update t1 set c2 = month('1998-08-08') where c1 = 1 ;
    else
        update t1 set c2 = month('1978-08-08') where c1 = 3 ;
    end if;
end
//
delimiter ;//
call pro1(1,1);
call pro1(2,1);
call pro1(0,1);

select * from t1;


drop   procedure if   exists   pro1;
delimiter //;
create procedure pro1()
begin
    declare i int default 1;
    while i <= 10 do
        if mod(i,10) = 0 then
        		insert into t1 values(6,month('1981-01-01'),month(19810101));
        elseif mod(i,8)=0 then
                insert into t1 values(7,month('1987-07-07'),month(19870707));
        elseif mod(i,7)=0 then
        		insert into t1 values(8,month('1988-08-08'),month(19880808));
        elseif mod(i,5)=0 then
        		insert into t1 values(9,month('1909-09-09'),month(19990909));
        elseif mod(i,3)=0 then
                insert into t1 values(10,month('2010-10-10'),month(20101010));
        else
                insert into t1 values(11,month('2011-11-11'),month(20111101));
        end if;
        set i = i+1;
    end while;
end
//
delimiter ;//
call pro1();
select * from t1;


drop   procedure if   exists   pro1;
delimiter //;
create procedure pro1(aa int,bb int)
begin
    if aa = bb then
         delete from t1 where c1 > 1 and c2 = month('1988-10-02');
    elseif aa > bb then
         delete from t1 where c2 > month('2011-02-02') and c3 = month('2011-02-02');
    else
        delete from t1 where c3 = month('1998-02-02');
    end if;
end
//
delimiter ;//
call pro1(1,1);
call pro1(2,1);
call pro1(0,1);

select * from t1;


drop   procedure if   exists   pro1;
delimiter //;
create procedure pro1(aa int,bb int)
begin
    if aa = bb then
         select month('2020-10-10'),month(20201010),month('2004-02-30');
    elseif aa > bb then
         select month('0001-10-10'),month(99991231),month('0002-02-30');
    else
        select month('5000-10-10'),month(50001010),month('2999-02-30');
    end if;
end
//
delimiter ;//
call pro1(1,1);
call pro1(2,1);
call pro1(0,1);



--echo	#function
drop table if exists t1;
create table t1(c1 int,c2 int,c3 char(100));
drop function if exists func1;
DELIMITER //;
CREATE  function func1() returns int
begin
	declare j int;
	declare i int;
	set j = 5;
	set i = 1;
    while i <= j DO
        insert into t1 values(i,month(20201212+1),month('2022-02-02'));
        set i = i + 1;
    end WHILE;
   	return month('2022-09-15');
end
//
DELIMITER ;//

select func1();
select * from t1;


drop function if exists func1;
delimiter //;
create function func1(aa int,bb int) returns int
begin
    if aa = bb then
         update t1 set c2 = month('2008-08-08') where c1 = 2 ;
    elseif aa > bb then
         update t1 set c2 = month('1998-08-08') where c1 = 1 ;
    else
        update t1 set c2 = month('1978-08-08') where c1 = 3 ;
    end if;
    return month('0001-01-01');
end
//
delimiter ;//
select func1(1,1);
select func1(2,1);
select func1(0,1);
select * from t1;


drop function if exists func1;
delimiter //;
create function func1() returns int
begin
    declare i int default 1;
    while i <= 10 do
        if mod(i,10) = 0 then
        		insert into t1 values(6,month('1981-01-01'),month(19810101));
        elseif mod(i,8)=0 then
                insert into t1 values(7,month('1987-07-07'),month(19870707));
        elseif mod(i,7)=0 then
        		insert into t1 values(8,month('1988-08-08'),month(19880808));
        elseif mod(i,5)=0 then
        		insert into t1 values(9,month('1909-09-09'),month(19990909));
        elseif mod(i,3)=0 then
                insert into t1 values(10,month('2010-10-10'),month(20101010));
        else
                insert into t1 values(11,month('2011-11-11'),month(20111101));
        end if;
        set i = i+1;
    end while;
    return month('2008-08-08');
end
//
delimiter ;//
select func1();
select * from t1;


drop function if exists func1;
delimiter //;
create function func1(aa int,bb int) returns int
begin
    if aa = bb then
         delete from t1 where c1 > 1 and c2 = month('1988-02-02');
    elseif aa > bb then
         delete from t1 where c2 > month('2011-02-02') and c3 = month('2011-02-02');
    else
        delete from t1 where c3 = month('1998-02-02');
    end if;
    return month(19980909);
end
//
delimiter ;//
select func1(1,1);
select func1(2,1);
select func1(0,1);
select * from t1;


--echo #trigger
drop   table     if   exists   t1;
drop   table     if   exists   t2;
create table t1(c1 int,c2 int);
insert into t1 values(1,10);
insert into t1 values(2,11);
create table t2(a1 int,a2 varchar(20));
insert into t2 values(2,'AA');
insert into t2 values(3,'cc');

drop trigger if exists tg1;
delimiter //;
create trigger tg1
AFTER
insert on t2
for each ROW
BEGIN
  insert t1 values(month('2001-03-05'),month('2000/04/06'));
END
//
delimiter ;//
insert into t2 values(1,1);
select * from t1;


drop trigger if exists tg1;
delimiter //;
create trigger tg1
AFTER
update on t2
for each ROW
BEGIN
		update t1 set c1 = month('20100909') where c2 = month('2010-10-10');
END
//
delimiter ;//
update t2 set a1 = 4 where a2 = 'AA';
select * from t1;



drop trigger if exists tg1;
delimiter //;
create trigger tg1
AFTER
delete on t2
for each ROW
BEGIN
     delete from t1 where c1 = month('2010^09^09');
END
//
delimiter ;//
delete from t2 where a1 = 3;
select * from t1;

drop database db1;


