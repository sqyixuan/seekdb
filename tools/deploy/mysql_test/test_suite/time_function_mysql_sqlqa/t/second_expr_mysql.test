--echo	#select
drop table if exists t1;
create table t1(c1 int ,c2 varchar(60) not null,c3 datetime default '1999-09-09 18:16:16');
insert into t1 values(161050,'18:20:30','2001-02-02 03:30:03');
insert into t1(c1,c2) values(051501,'04:25:50');
insert into t1 values(071313,'082308','1880-05-05 05:33:05');
insert into t1 values(101010,'11:11:11','0001-01-01 01:01:01');
insert into t1(c1,c2) values(121212,'15:20:20');
insert into t1 values(164050,'20220926055005','0001-01-01 01:01:01');
insert into t1 values(101010,'2020.02.02','0001-01-01 01:01:01');

select second(c1),second(c2),second(c3) from t1 order by second(c1);

--echo	#where
select second(c1) from t1 where second(c1) > 20 and second(c2) <=50;
select second(c3) from t1 where second(c2) < 30 and second(c3) >10;

select second(c2) from t1 where second(c1)<30 order by second(c2);

select c1,case second(c1) when second(c1)> 5 then second('202020') else second('101010') end as a from t1;

select c1, case c2 when '11111111' then second('1111') else second('080808') end as a from t1;

select distinct second(c1),c2,c3 from t1 order by second(c1);
select distinct second(c3) ,c1,c3 from t1 order by second(c3);

select second(c1) from t1 group by c1 having second(c1) >=10;
drop table t1;


