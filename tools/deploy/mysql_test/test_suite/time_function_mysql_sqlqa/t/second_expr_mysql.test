select second(DATE_ADD('2100-12-31 22:59:57',INTERVAL '1:1' MINUTE_SECOND));
select second(DATE_SUB('2025-01-01 00:00:00',INTERVAL '1 1:1:1' DAY_SECOND));
select second(DATE_ADD('1900-01-01 00:00:00',INTERVAL '-1 10' DAY_HOUR));
select second(DATE_SUB('1998-01-02', INTERVAL 31 DAY));
select second(DATE_ADD('1992-12-31 23:59:59.000002',INTERVAL '1.999999' SECOND_MICROSECOND));

--echo	#date_format
