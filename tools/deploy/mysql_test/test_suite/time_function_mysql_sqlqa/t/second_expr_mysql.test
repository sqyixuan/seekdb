--echo  #update、delete
drop table if exists test1;
create table test1(a1 int,a2 char(20),c1 datetime,c2 datetime);
insert into test1 values(1,'1998-12-12 02:02:02','1998-12-12 03:12:12','2038-01-19 11:20:20');
insert into test1 values(2,'2002-02-02 04:04:04','2002-02-02 05:14:14','2034-02-22 12:22:22');
insert into test1 values(3,'2006-04-15 06:06:06','2006-04-15 07:16:16','2026-05-08 13:24:24');
insert into test1 values(4,'2012-12-12 08:08:08','2012-12-12 09:18:18','2030-08-16 14:26:26');
select * from test1;
create table test2(a1 int,a2 int);
insert into test2 values(1,2),(2,4),(3,6),(4,8),(5,10),(6,12),(7,14),(8,16),(9,18),(10,20),(11,22),(12,24),(13,26),(14,28);

update test1 set a1 = second('11:11:11') where second(a2) = (select a2 from test2 where a1 = 2);
update test1 set a1 = second('12:12:12') where second(c1) = 3 or second(c2) = (select a2 from test2 where a1 = 11);
select * from test1;

delete from test1 where second(c1)> second('2006-04-15 07:06:06') and second(c2) > second('2038-01-19 01:14:14');
delete from test1 where second(c2) =(select a2 from test2 where a1 = 13);
select * from test1;

drop table test1;


--echo  #复制表
drop table if exists t1;
create table t1(c1 int ,c2 varchar(60) not null,c3 datetime default '1999-09-09 18:16:30');
insert into t1 values(161010,'18:20:20','2001-02-02 03:30:30');
insert into t1(c1,c2) values(051515,'04:25:25');
insert into t1 values(071313,'082323','1880-05-05 05:33:33');
insert into t1 values(101010,'11:11:11','0001-01-01 01:01:01');
insert into t1(c1,c2) values(121212,'15:20:20');
insert into t1 values(164040,'20220926055050','0001-01-01 01:01:01');
insert into t1 values(101010,'200202','0001-01-01 01:01:01');
create table tt1 as select * from t1;
select second(c1),second(c2),second(c3) from tt1 order by second(c1);

--echo	#select
select second(c1) from tt1 where second(c1) > 20 and second(c2) <=50;
select second(c3) from tt1 where second(c2) < 30 and second(c3) >10;

select second(c2) from tt1 where second(c1)<30 order by second(c2);

select c1,case second(c1) when second(c1)> 5 then second('202020') else second('101010') end as a from tt1;

select c1, case c2 when '11111111' then second('1111') else second('080808') end as a from tt1;

select distinct second(c1),c2,c3 from tt1 order by second(c1);
select distinct second(c3) ,c1,c3 from tt1 order by second(c3);

select second(c1) from tt1 group by c1 having second(c1) >=10 order by c1;


--echo #update
update tt1 set c1 = second('080808') where second(c2) > second('011010') and second(c2)<second('011515');
update tt1 set c2 = second('010101') where second(c1) = second('011313') or second(c3) = second('16:30:31');
update tt1 set c1 = second('12:30:30') where second(c3) in (select a2 from test2);
select * from tt1;

--echo  #delete
delete from tt1 where second(c1) >second('12:10:30') and second(c1) < second('161531');
delete from tt1 where second(c2) not in (select a2 from test2);
delete from tt1 where second(c3) != 0;

drop table t1;
drop table tt1;



--echo	#分区
--echo	#hash
drop table if exists t1;
create table t1(c1 int,c2 datetime) partition by hash(c1)
(
partition p1,
partition p2
);

insert into t1 values(114040,'1991-01-01 02:02:02');
insert into t1 values(123030,'2001-03-01 04:04:04');
insert into t1 values(131515,'2011-05-01 06:06:06');
insert into t1 values(141515,'2021-07-01 08:08:08');
insert into t1 values(141616,'2021-07-01 10:10:10');
select * from t1;

select c1 from t1 where second(c2) > 1 group by second(c1) having max(second(c2))<10;
update t1 set c1 = second('060606') where second(c2) > 5;
delete from t1 where second(c2) > 5 and second(c1) = 6;
select * from t1;
drop table t1;


--echo	#range
drop table if exists t1;
create table t1(c1 int ,c2 datetime) partition by range(c1)
(
partition p1 values less than(400000),
partition p2 values less than(maxvalue)
);

insert into t1 values(200101,'1991-02-01 4:02:02');
insert into t1 values(300303,'2001-04-01 8:04:04');
insert into t1 values(400505,'2011-06-01 12:06:06');
insert into t1 values(500606,'2021-08-01 16:08:08');
insert into t1 values(600707,'2021-08-01 20:10:10');
select * from t1;

select c1 from t1 where second(c2) > 1 group by c1 having max(second(c2))<6;
update t1 set c1 = second('020202') where second(c2) > 5 and second(c2) < 8;
select * from t1;
delete from t1 where second(c2) > 2;
select * from t1;
drop table t1;


--echo	#list
drop table if exists t1;
create table t1(c1 int,c2 int) partition by list(c1)
(
partition p1 values in(080808,070707,060606,050505),
partition p2 values in(101010,111111,121212,131313)
);
insert into t1 values(080808,1),(070707,2),(060606,3),(050505,4);
insert into t1 values(101010,5),(111111,6),(121212,7),(131313,8);
select * from t1 order by c1;

select * from t1 partition(p1) where second(c1) >5 and second(c2)<5 order by second(c1);

update t1 partition(p2) set c2 = second('060606') where second(c1) = second('131010');

delete from t1 where second(c1) > 6 and c2 < second('12:59:59');

select * from t1;

drop table t1;


--echo	#key
drop table if exists t1;
create table t1(c1 int primary key , c2 datetime)
partition by key(c1)
partitions 2;

insert into t1 values(114040,'1991-01-01 02:02:02');
insert into t1 values(123030,'2001-03-01 04:04:04');
insert into t1 values(131515,'2011-05-01 06:06:06');
insert into t1 values(141515,'2021-07-01 08:08:08');
insert into t1 values(141616,'2021-07-01 10:10:10');
select * from t1;

select c1 from t1 where second(c2) > 1 group by second(c1) having max(second(c2))<10;
update t1 set c1 = second('060606') where second(c2) > 9;
delete from t1 where second(c2) > 5 and second(c1) = 6;
select * from t1 order by c1;
drop table t1;


--echo	#range columns
drop table if exists t1;
CREATE TABLE t1 (
    c1 int,
    c2 datetime
)
PARTITION BY RANGE COLUMNS(c1) (
partition p1 values less than(400000),
partition p2 values less than(maxvalue)
);

insert into t1 values(200101,'1991-02-01 4:04:04');
insert into t1 values(300303,'2001-04-01 8:08:08');
insert into t1 values(400505,'2011-06-01 12:12:12');
insert into t1 values(500606,'2021-08-01 16:16:16');
insert into t1 values(600707,'2021-08-01 20:20:20');
select * from t1;

select c1 from t1 where second(c2) > 1 group by c1 having max(second(c2))<6;
update t1 set c1 = second('020202') where second(c2) > 5;
select * from t1;
delete from t1 where second(c2) > 2;
select * from t1;
drop table t1;


--echo	#columns list
drop table if exists t1;
create table t1(c1 int,c2 int) partition by list columns(c1)
(
partition p1 values in(080808,070707,060606,050505),
partition p2 values in(101010,111111,121212,131313)
);
insert into t1 values(080808,1),(070707,2),(060606,3),(050505,4);
insert into t1 values(101010,5),(111111,6),(121212,7),(131313,8);
select * from t1 order by c1;

select * from t1 partition(p1) where second(c1) >5 and second(c2)<5 order by second(c1);

update t1 partition(p2) set c2 = second('060606') where second(c1) = second('131010');

delete from t1 where second(c1) > 6 and c2 < second('12:59:59');

select * from t1;

drop table t1;


--echo  #view
drop table if exists t1;
drop view if exists v_t1;
create table t1(c1 int ,c2 varchar(60) not null,c3 datetime default '1999-09-09 18:16:16');
insert into t1 values(161010,'18:20:20','2001-02-02 03:30:30');
insert into t1(c1,c2) values(051515,'04:25:25');
insert into t1 values(071313,'082323','1880-05-05 05:33:33');
insert into t1 values(101010,'11:11:11','0001-01-01 01:01:01');
insert into t1(c1,c2) values(121212,'15:20:20');
insert into t1 values(164040,'20220926055050','0001-01-01 01:01:01');
insert into t1 values(101010,'200202','0001-01-01 01:01:01');
create view v_t1 as select * from t1;
select second(c1),second(c2),second(c3) from v_t1 order by second(c1);

--echo	#select
select second(c1) from v_t1 where second(c1) > 20 and second(c2) <=50;
select second(c3) from v_t1 where second(c2) < 30 and second(c3) >10;

select second(c2) from v_t1 where second(c1)<30 order by second(c2);

select c1,case second(c1) when second(c1)> 5 then second('202020') else second('101010') end as a from v_t1;

select c1, case c2 when '11111111' then second('1111') else second('080808') end as a from v_t1;

select distinct second(c1),c2,c3 from v_t1 order by second(c1);
select distinct second(c3) ,c1,c3 from v_t1 order by second(c3);

select second(c1) from v_t1 group by c1 having second(c1) >=10 order by c1;


--echo #update
update v_t1 set c1 = second('080808') where second(c2) > second('011010') and second(c2)<second('011515');
update v_t1 set c2 = second('010101') where second(c1) = second('011313') or second(c3) = second('16:30:31');
update v_t1 set c1 = second('12:30:30') where second(c3) in (select a2 from test2);
select * from v_T1;

--echo  #delete
delete from v_t1 where second(c1) >second('12:10:30') and second(c1) < second('161531');
delete from v_t1 where second(c2) not in (select a2 from test2);
delete from v_t1 where second(c3) != 0;
select * from v_T1;

drop table test2;
drop table t1;
drop view v_t1;


--echo  #生成列
drop table if exists t1;
CREATE TABLE t1(c1 int,c2 int GENERATED ALWAYS AS (second('060606')) VIRTUAL);
