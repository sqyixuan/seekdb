--disable_warnings
drop database if exists db1;
--enable_warnings

create database db1;
use db1;

--echo #参数
--echo  #最大返回值 838
select hour('838:00:00');
select hour('839:00:00');
select hour('0:59:59');
select hour('-12:05:05');
select hour('-838:05:05');
select hour('-839:05:05');
select hour('22:12:-10');
select hour('22:-12:-10');
select hour('-24:-22:-22');

select hour('00:00:00');
select hour('00:00:71');
select hour('00:60:00');
select hour('60:00:00');
select hour('0:0:0');
select hour('000018:0001:01');
select hour('1:0000000101:1');

select hour('20');
select hour('88:08');
select hour('66:6:66');
select hour('22:05:-05');
--echo  #mysql返回3，OB返回2(精度超过6位后 MYSQL视为下一小时，OB不变)
select hour('2:59:59.9999999');
select hour('2022-09-20 23:59:59.9999999');

select hour('0.555:55:55');
select hour('0.5:55:60');
select hour('0.99:71:88');
select hour('66:0.5:0.6');
select hour('1:59.9999999:60.00');
select hour('20:60:05');
select hour('20:59.9:61.00');
select hour('5.9:20:02');
select hour('20.0001:20:02');


--echo  #日期格式
