--echo	#聚合函数
drop table if exists test1;
create table test1(a1 int,a2 int,c1 datetime,c2 datetime);
insert into test1 values(1,080606,'1998-12-12 12:12:12','2038-01-19 03:14:07');
insert into test1 values(2,090909,'2002-02-02 10:00:00','2034-02-22 00:50:20');
insert into test1 values(3,101010,'2006-04-15 06:06:20','2026-05-08 05:16:50');
insert into test1 values(4,111111,'2012-12-12 12:12:12','2030-08-16 14:05:50');
select * from test1;

