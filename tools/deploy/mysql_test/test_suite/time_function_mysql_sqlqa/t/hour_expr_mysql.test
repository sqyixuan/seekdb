--echo	#select
drop table if exists t1;
create table t1(c1 int ,c2 varchar(60) not null,c3 datetime default '1999-09-09 18:16:30');
insert into t1 values(165050,'18:30:30','2001-02-02 03:03:03');
insert into t1(c1,c2) values(050101,'04:50:50');
insert into t1 values(071313,'080808','1880-05-05 05:05:05');
insert into t1 values(101010,'11:11:11','0001-01-01 01:01:01');
insert into t1(c1,c2) values(121212,'15:20:20');
insert into t1 values(165050,'99990909090909','0001-01-01 01:01:01');
insert into t1 values(101010,'2020.02.02','0001-01-01 01:01:01');

select hour(c1),hour(c2),hour(c3) from t1 order by hour(c1);

--echo	#where
select hour(c1) from t1 where hour(c1) > 5 and hour(c2) <10;
select hour(c3) from t1 where hour(c2) < 3 and hour(c3) >0;

select hour(c2) from t1 where hour(c1)>3 order by hour(c2);

select c1,case hour(c1) when hour(c1)> 5 then hour('202020') else hour('101010') end as a from t1;

select c1, case c2 when '11111111' then hour('1111') else hour('080808') end as a from t1;

select distinct hour(c1),c2,c3 from t1 order by hour(c1);
select distinct hour(c3) ,c1,c3 from t1 order by hour(c3);

select hour(c1) from t1 group by c1 having hour(c1) >3;

