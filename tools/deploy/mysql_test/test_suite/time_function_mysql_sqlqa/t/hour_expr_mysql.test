--echo	#date_add/sub
select hour(DATE_ADD('2018-05-01 12:12:12',INTERVAL 1 DAY));
select hour(DATE_SUB('2018-05-01 16:12:12',INTERVAL 1 hour));
select hour(DATE_ADD('2020-12-31 23:59:58',INTERVAL 1 SECOND));
select hour(DATE_ADD('2018-12-31 23:59:59',INTERVAL 1 DAY));
select hour(DATE_ADD('2100-12-31 22:59:57',INTERVAL '1:1' MINUTE_SECOND));
select hour(DATE_SUB('2025-01-01 00:00:00',INTERVAL '1 1:1:1' DAY_SECOND));
select hour(DATE_ADD('1900-01-01 00:00:00',INTERVAL '-1 10' DAY_HOUR));
select hour(DATE_SUB('1998-01-02', INTERVAL 31 DAY));
select hour(DATE_ADD('1992-12-31 23:59:59.000002',INTERVAL '1.999999' SECOND_MICROSECOND));

