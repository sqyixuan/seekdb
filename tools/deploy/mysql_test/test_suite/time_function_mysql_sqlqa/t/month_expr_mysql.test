--echo	#select
drop table if exists t1;
create table t1(c1 int ,c2 varchar(60) not null,c3 datetime default '1999-09-09');
insert into t1 values(19990909,'2000-01-01','2001-02-02 03:03:03');
insert into t1(c1,c2) values(10000101,'33330303');
insert into t1 values(99991231,'00010101','1880-05-05 05:05:05');
insert into t1 values(66660606,'99990909090909','0001-01-01 01:01:01');
insert into t1(c1,c2) values(20000808,'11111111');
insert into t1 values(66660606,'99990909090909','0001-01-01 01:01:01');
insert into t1 values(66660606,'2020.02.02','0001-01-01 01:01:01');

select month(c1),month(c2),month(c3) from t1 order by month(c1);

--echo	#where
select month(c1) from t1 where month(c1) > 5 and month(c2) <10;
select month(c3) from t1 where month(c2) < 3 and month(c3) >0;

select month(c2) from t1 where month(c1)>3 order by month(c2);

select c1,case month(c1) when month(c1)> 5 then month('0101-01-01') else month('2000-10-10') end as a from t1;

select c1, case c2 when '11111111' then month('1111') else month('2020-02-02') end as a from t1;

select distinct month(c1),c2,c3 from t1 order by month(c1);
select distinct month(c3) ,c1,c3 from t1 order by month(c3);

select month(c1) from t1 group by c1 having month(c1) >3;


