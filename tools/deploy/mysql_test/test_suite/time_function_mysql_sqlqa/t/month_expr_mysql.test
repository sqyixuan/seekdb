--echo	#date_add/sub
select month(DATE_ADD('2018-05-01',INTERVAL 1 DAY));
select month(DATE_SUB('2018-05-01',INTERVAL 1 month));
select month(DATE_ADD('2020-12-31 23:59:59',INTERVAL 1 SECOND));
select month(DATE_ADD('2018-12-31 23:59:59',INTERVAL 1 DAY));
select month(DATE_ADD('2100-12-31 23:59:59',INTERVAL '1:1' MINUTE_SECOND));
select month(DATE_SUB('2025-01-01 00:00:00',INTERVAL '1 1:1:1' DAY_SECOND));
select month(DATE_ADD('1900-01-01 00:00:00',INTERVAL '-1 10' DAY_HOUR));
select month(DATE_SUB('1998-01-02', INTERVAL 31 DAY));
select month(DATE_ADD('1992-12-31 23:59:59.000002',INTERVAL '1.999999' SECOND_MICROSECOND));

