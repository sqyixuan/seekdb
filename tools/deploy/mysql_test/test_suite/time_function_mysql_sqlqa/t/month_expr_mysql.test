--echo	#update、delete
drop table if exists test1;
create table test1(a1 int,a2 int,c1 datetime,c2 datetime);
insert into test1 values(1,month('1998-12-12 12:12:12'),convert_tz('1998-12-12 12:12:12','+00:00','+00:00'),convert_tz('2038-01-19 03:14:07','+00:00','+00:00'));
insert into test1 values(2,month('2002-02-02 10:00:00'),convert_tz('2002-02-02 10:00:00','+00:00','+00:00'),convert_tz('2034-02-22 00:50:20','+00:00','+00:00'));
insert into test1 values(3,month('2006-04-15 06:06:20'),convert_tz('2006-04-15 06:06:20','+00:00','+00:00'),convert_tz('2026-05-08 05:16:50','+00:00','+00:00'));
insert into test1 values(4,month('2012-12-12 12:12:12'),convert_tz('2012-12-12 12:12:12','+00:00','+00:00'),convert_tz('2030-08-16 14:05:50','+00:00','+00:00'));
select * from test1;

update test1 set a1 = month('2008-08-08') where month(c1)=2;
update test1 set a2 = month('2019-10-01') where month(c1) = (select max(month(c1)) from test1);
select * from test1;

delete from test1 where month(c1) > 10 and month(c2)<5;
delete from test1 where month(c1) != 2;

drop table test1;


--echo	#复制表
drop table if exists t1;
create table t1(c1 int ,c2 varchar(60) not null,c3 datetime default '1999-09-09');
insert into t1 values(19990909,'2000-01-01','2001-02-02 03:03:03');
insert into t1(c1,c2) values(10000101,'33330303');
insert into t1 values(99991231,'00010101','1880-05-05 05:05:05');
insert into t1 values(66660606,'99990909090909','0001-01-01 01:01:01');
insert into t1(c1,c2) values(20000808,'11111111');
insert into t1 values(66660606,'99990909090909','0001-01-01 01:01:01');
insert into t1 values(66660606,'2020.02.02','0001-01-01 01:01:01');
create table tt1 as select * from t1;

select month(c1),month(c2),month(c3) from tt1 order by month(c1);

--echo	#where
select month(c1) from tt1 where month(c1) > 5 and month(c2) <10;
select month(c3) from tt1 where month(c2) < 3 and month(c3) >0;

select month(c2) from tt1 where month(c1)>3 order by month(c2);

select c1,case month(c1) when month(c1)> 5 then month('0101-01-01') else month('2000-10-10') end as a from tt1;

select c1, case c2 when '11111111' then month('1111') else month('2020-02-02') end as a from tt1;

select distinct month(c1),c2,c3 from tt1 order by month(c1);
select distinct month(c3) ,c1,c3 from tt1 order by month(c3);

select month(c1) from tt1 group by c1 having month(c1) >3;

--echo	#update,delete
update tt1 set c1 = month('2012.12.12') where month(c2) = 3;
update tt1 set c2 = month('99990909') where month(c3)=2;

--error 0,1292
delete from tt1 where month(c3) = 5 and month(c1) = 12;
select * from tt1;

drop table tt1;
drop table t1;



--echo	#分区
--echo	#hash
drop table if exists t1;
create table t1(c1 int,c2 datetime) partition by hash(c1)
(
partition p1,
partition p2
);

insert into t1 values(month('1991-01-01'),'1991-01-01 08:08:08');
insert into t1 values(month('2001-03-01'),'2001-03-01 08:08:08');
insert into t1 values(month('2011-05-01'),'2011-05-01 08:08:08');
insert into t1 values(month('2021-07-01'),'2021-07-01 08:08:08');
insert into t1 values(month('2021-07-01'),'2021-07-01 08:08:08');
select * from t1;

select * from t1 where month(c2) > 1 group by c1 having max(month(c2))<10;

update t1 set c1 = month('2009-09-09') where month(c2) > 5;
select * from t1;

delete from t1 where month(c2) > 2;
select * from t1;

drop table t1;


--echo	#range
drop table if exists t1;
create table t1(c1 int ,c2 datetime) partition by range(c1)
(
partition p1 values less than(month('1980-5-01')),
partition p2 values less than(maxvalue)
);


insert into t1 values(month('1991-02-01'),'1991-02-01 08:08:08');
insert into t1 values(month('2001-04-01'),'2001-04-01 08:08:08');
insert into t1 values(month('2011-06-01'),'2011-06-01 08:08:08');
insert into t1 values(month('2021-08-01'),'2021-08-01 08:08:08');
insert into t1 values(month('2021-08-01'),'2021-08-01 08:08:08');
select * from t1;

select * from t1 where month(c2) > 1 group by c1 having max(month(c2))<6;

update t1 set c1 = month('2009-09-09') where month(c2) > 5;
select * from t1;

delete from t1 where month(c2) > 2;
select * from t1;

drop table t1;




--echo	#list
drop table if exists t1;
--error 1495
create table t1(c1 int,c2 int) partition by list(c1)
(
partition p0 values in(month('1900-01-01'),month('1950-01-01'),month('2020-01-01'),month('2070-01-01')),
partition p1 values in(month('3030-12-31'),month('4030-12-31'),month('5030-12-31'),month('6030-12-31'))
);


--echo	#key
drop table if exists t1;
create table t1(c1 int primary key , c2 datetime)
partition by key(c1)
partitions 2;

insert into t1 values(month('1970-01-01'),'1970-01-01 08:08:08');
insert into t1 values(month('1981-03-01'),'1971-05-01 08:08:08');
insert into t1 values(month('1991-05-01'),'1971-08-01 08:08:08');
insert into t1 values(month('2021-07-01'),'2021-11-01 08:08:08');
insert into t1 values(month('2031-09-01'),'2021-12-01 08:08:08');
select * from t1;

select * from t1 partition(p0) where month(c2)>2 group by c1 having max(month(c2)>3);

update t1 partition(p1) set c1 = month('2010-10-10') where month(c2)> 2;

delete from t1 partition(p1) where month(c2)>2;
select * from t1;

drop table t1;



--echo	#range columns
drop table if exists t1;
CREATE TABLE t1 (
    c1 int,
    c2 datetime
)
PARTITION BY RANGE COLUMNS(c1) (
partition p1 values less than(month('1980-05-01')),
partition p2 values less than(maxvalue)
);

insert into t1 values(month('1991-02-01'),'1991-02-01 08:08:08');
insert into t1 values(month('2001-04-01'),'2001-04-01 08:08:08');
insert into t1 values(month('2011-06-01'),'2011-06-01 08:08:08');
insert into t1 values(month('2021-08-01'),'2021-08-01 08:08:08');
insert into t1 values(month('2021-08-01'),'2021-08-01 08:08:08');
select * from t1;

select * from t1 where month(c2) > 1 group by c1 having max(month(c2))<6;

update t1 set c1 = month('2009-09-09') where month(c2) > 5;
select * from t1;

delete from t1 where month(c2) > 2;
select * from t1;

drop table t1;

--echo	#columns list
drop table if exists t1;
--error 1495
create table t1(c1 int,c2 datetime)
partition by list columns(c1)
(
partition p0 values in(month('1900-01-01'),month('1950-01-01'),month('2020-01-01'),month('2070-01-01')),
partition p1 values in(month('3030-12-31'),month('4030-12-31'),month('5030-12-31'),month('6030-12-31'))
);


--echo	#view
drop table if exists test1;
create table test1(a1 int,a2 int,c1 datetime,c2 datetime);
insert into test1 values(1,month('1998-12-12 12:12:12'),convert_tz('1998-12-12 12:12:12','+00:00','+00:00'),convert_tz('2038-01-19 03:14:07','+00:00','+00:00'));
insert into test1 values(2,month('2002-02-02 10:00:00'),convert_tz('2002-02-02 10:00:00','+00:00','+00:00'),convert_tz('2034-02-22 00:50:20','+00:00','+00:00'));
insert into test1 values(3,month('2006-04-15 06:06:20'),convert_tz('2006-04-15 06:06:20','+00:00','+00:00'),convert_tz('2026-05-08 05:16:50','+00:00','+00:00'));
insert into test1 values(4,month('2012-12-12 12:12:12'),convert_tz('2012-12-12 12:12:12','+00:00','+00:00'),convert_tz('2030-08-16 14:05:50','+00:00','+00:00'));
insert into test1 values(4,month('2012-12-12 12:12:12'),convert_tz('2012-12-12 12:12:12','+00:00','+00:00'),convert_tz('2030-08-16 14:05:50','+00:00','+00:00'));
create view v_t1 as select * from test1;
select * from v_t1;

select * from v_t1 where month(c1) >=5;

select * from v_t1 where a2 = month(c1) and a2 >2 order by month(c2);

select * from v_t1 where a2 = month(c1) and  month(c1)>3 group by a2;

select * from v_t1 where a2 = month(c1) and  month(c1)>5 group by a2 having max(month(c2)>2);

select c1,case month(c1) when month(c1)> 3 then month('0101-01-01') else month('2000-10-10') end as a from v_t1;

select c1, case c2 when '11111111' then month('1111') else month('2020-02-02') end as a from v_t1;

select distinct month(c1),c2 from v_t1;

update v_t1 set a1 = month(c1) where month(c1)>2;

delete from v_t1 where month(c2) > 1;

drop table test1;
drop view v_t1;

--echo	#生成列
drop table if exists t1;
CREATE TABLE t1(c1 int,c2 int GENERATED ALWAYS AS (month('2020-02-02')) VIRTUAL);
insert into t1(c1) values(1);
insert into t1(c1) values(2);
select * from t1;
drop table t1;

--echo	#算术运算符
--echo	#'+'
select month('1010-01-01'+'1019-09-09');
select month('1010-01-01'+'');
