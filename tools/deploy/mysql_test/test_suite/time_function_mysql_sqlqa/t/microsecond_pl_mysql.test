--disable_warnings
drop database if exists db1;
--enable_warnings

create database db1;
use db1;


--echo	#PL
--echo	#procedure
drop table if exists t1;
create table t1(c1 int,c2 char(60),c3 char(100));
drop procedure if exists pro1;
DELIMITER //;
CREATE  PROCEDURE pro1()
begin
	declare j int;
	declare i int;
	set j = 5;
	set i = 1;
    while i <= j DO
        insert into t1 values(i,microsecond(20201212155050.0005),microsecond('2022-02-02 18:06:06.0006'));
        set i = i + 1;
    end WHILE;
end
//
DELIMITER ;//
call pro1();
select * from t1;


drop   procedure if   exists   pro1;
delimiter //;
create procedure pro1(aa int,bb int)
begin
    if aa = bb then
         update t1 set c2 = microsecond('2008-08-08 10:15:15.000015') where c1 = 2 ;
    elseif aa > bb then
         update t1 set c2 = microsecond('1998-08-08 12:12:12.000012') where c1 = 1 ;
    else
        update t1 set c2 = microsecond('14:14:14.000014') where c1 = 3 ;
    end if;
end
//
delimiter ;//
call pro1(1,1);
call pro1(2,1);
call pro1(0,1);

select * from t1;


drop   procedure if   exists   pro1;
delimiter //;
create procedure pro1()
begin
    declare i int default 1;
    while i <= 10 do
        if mod(i,10) = 0 then
        		insert into t1 values(6,microsecond('1981-01-01 08:08:08.000008'),microsecond(010101.000001));
        elseif mod(i,8)=0 then
                insert into t1 values(7,microsecond('1987-07-07 09:09:09.000009'),microsecond(020202.000002));
        elseif mod(i,7)=0 then
        		insert into t1 values(8,microsecond('1988-08-08 10:10:10.000010'),microsecond(030303.000003));
        elseif mod(i,5)=0 then
        		insert into t1 values(9,microsecond('1909-09-09 11:11:11.000011'),microsecond(040404.000004));
        elseif mod(i,3)=0 then
                insert into t1 values(10,microsecond('2010-10-10 12:12:12.000012'),microsecond(050505.000005));
        else
                insert into t1 values(11,microsecond('2011-11-11 13:13:13.000013'),microsecond(060606.000006));
        end if;
        set i = i+1;
    end while;
end
//
delimiter ;//
call pro1();
select * from t1;


drop   procedure if   exists   pro1;
delimiter //;
create procedure pro1(aa int,bb int)
begin
    if aa = bb then
         delete from t1 where c1 > 1 and c2 = microsecond('1988-10-02 10:10:10.000010');
    elseif aa > bb then
         delete from t1 where c2 > microsecond('2011-02-02 10:10:10.000010') and c3 = microsecond('2011-02-02 05:05:05.000005');
    else
        delete from t1 where c3 = microsecond('1998-02-02 06:06:06.000006');
    end if;
end
//
delimiter ;//
call pro1(1,1);
call pro1(2,1);
call pro1(0,1);

select * from t1;


drop   procedure if   exists   pro1;
delimiter //;
create procedure pro1(aa int,bb int)
begin
    if aa = bb then
         select microsecond('2020-10-10 07:07:07.000007'),microsecond(201010.000010),microsecond('20220927141516.000016');
    elseif aa > bb then
         select microsecond('0001-10-10 08:08:08.000008'),microsecond(991231.000031),microsecond('20001010050505.000005');
    else
        select microsecond('5000-10-10 09:09:09.000009'),microsecond(501010.000010),microsecond('19990909090909.000009');
    end if;
end
//
delimiter ;//
call pro1(1,1);
call pro1(2,1);
call pro1(0,1);


--echo	#function
drop table if exists t1;
create table t1(c1 int,c2 char(60),c3 char(100));
drop function if exists func1;
DELIMITER //;
CREATE  function func1() returns int
begin
	declare j int;
	declare i int;
	set j = 5;
	set i = 1;
    while i <= j DO
        insert into t1 values(i,microsecond(20201212155050.0005),microsecond('2022-02-02 18:06:06.000006'));
        set i = i + 1;
    end WHILE;
   	return microsecond('08:08:08.000008');
end
//
DELIMITER ;//
select func1();
select * from t1;


drop function if exists func1;
delimiter //;
CREATE  function func1(aa int,bb int) returns int
begin
    if aa = bb then
         update t1 set c2 = microsecond('2008-08-08 10:15:15.000015') where c1 = 2 ;
    elseif aa > bb then
         update t1 set c2 = microsecond('1998-08-08 12:12:12.000012') where c1 = 1 ;
    else
        update t1 set c2 = microsecond('14:14:14.000014') where c1 = 3 ;
    end if;
    return microsecond('08:08:08.00006');
end
//
delimiter ;//
select func1(1,1);
select func1(2,1);
select func1(0,1);

select * from t1;


drop function if exists func1;
delimiter //;
CREATE  function func1() returns int
begin
    declare i int default 1;
    while i <= 10 do
        if mod(i,10) = 0 then
        		insert into t1 values(6,microsecond('1981-01-01 08:08:08.000008'),microsecond(010101.000001));
        elseif mod(i,8)=0 then
                insert into t1 values(7,microsecond('1987-07-07 09:09:09.000009'),microsecond(020202.000002));
        elseif mod(i,7)=0 then
        		insert into t1 values(8,microsecond('1988-08-08 10:10:10.000010'),microsecond(030303.000003));
        elseif mod(i,5)=0 then
        		insert into t1 values(9,microsecond('1909-09-09 11:11:11.000011'),microsecond(040404.000004));
        elseif mod(i,3)=0 then
                insert into t1 values(10,microsecond('2010-10-10 12:12:12.000012'),microsecond(050505.000005));
        else
                insert into t1 values(11,microsecond('2011-11-11 13:13:13.000013'),microsecond(060606.000006));
        end if;
        set i = i+1;
    end while;
   	return microsecond('06:06:06.00006');
end
//
delimiter ;//
select func1();
select * from t1;


drop function if exists func1;
delimiter //;
create function func1(aa int,bb int) returns int
begin
    if aa = bb then
         delete from t1 where c1 > 1 and c2 = microsecond('1988-10-02 10:10:10.000010');
    elseif aa > bb then
         delete from t1 where c2 > microsecond('2011-02-02 10:10:10.000010') and c3 = microsecond('2011-02-02 05:05:05.000005');
    else
        delete from t1 where c3 = microsecond('1998-02-02 06:06:06.000006');
    end if;
   	return microsecond('05:05:05.05');
end
//
delimiter ;//
select func1(1,1);
select func1(2,1);
select func1(0,1);

select * from t1;


--echo	#trigger
drop   table     if   exists   t1;
drop   table     if   exists   t2;
create table t1(c1 int,c2 int);
insert into t1 values(1,21);
insert into t1 values(2,20);
create table t2(a1 int,a2 varchar(20));
insert into t2 values(2,'AA');
insert into t2 values(3,'cc');

drop trigger if exists tg1;
delimiter //;
create trigger tg1
AFTER
insert on t2
for each ROW
BEGIN
  insert t1 values(microsecond('1999/09/09 02:20:20.000020'),microsecond('2000-08-08 05:06:14.000014'));
END
//
delimiter ;//
insert into t2 values(1,1);
select * from t1;


drop trigger if exists tg1;
delimiter //;
create trigger tg1
AFTER
update on t2
for each ROW
BEGIN
		update t1 set c1 = microsecond('01:01:01.000001') where c2 = microsecond('2001/01/01 20:20:20.000020');
END
//
delimiter ;//
update t2 set a1 = 4 where a2 = 'AA';
select * from t1;



drop trigger if exists tg1;
delimiter //;
create trigger tg1
AFTER
delete on t2
for each ROW
BEGIN
     delete from t1 where c1 = microsecond('19990909152020.000020');
END
//
delimiter ;//
delete from t2 where a1 = 3;
select * from t1;


drop database db1;
