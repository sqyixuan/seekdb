--disable_warnings
drop database if exists db1;
--enable_warnings

create database db1;
use db1;

--echo  #参数
select microsecond('01:01:01.000001');
select microsecond('01:01:01.0000001');
select microsecond('01:01:01.1');
select microsecond('01:01:01.000001.123');
SELECT MICROSECOND('2019-12-31 23:59:59.000010');
SELECT MICROSECOND('12:00:00.123456');
select microsecond('1900-08-08 23:59:59.999999');
select microsecond('05:05:05.09999999');

--echo  #YYYYY^MM^DD HH+MM+SS
select microsecond('2020^01^02 16+01+30.123456');
select microsecond('2020^07^02 24+26.5+00.00500');
select microsecond('2020^09^02 22+30+20.678910');
select microsecond('2020^12^02 23+30+33.22222');
select microsecond('2020^03^29 23+6+11.010203');
select microsecond('2020^13^29 23+8+22.123');


--echo  #YY^MM^DD HH+MM+SS
--echo  #OB与MYSQL不一致。OB返回NULL
select microsecond('88^00^02 16+20+11.1');
select microsecond('77^01^02 24+26.5+05.00001');
select microsecond('66^03^02 22+05+17.20050');
select microsecond('55^5^02 15+07+29.34564');
select microsecond('44^7^29 12+59+03.456782');
select microsecond('33^13^29 20+59+59.531237');


--echo  #YYYY@MM@DD HH^MM^SS
select microsecond('2020@09@02 22^15^66.1234');
select microsecond('2020@12@02 23^45^50.6457');
select microsecond('2020@03@29 23^30^30.01010');
select microsecond('2020@13@29 23^59^59.999999');

--echo  #YY@MM@DD HH^MM^SS
select microsecond('01@09@02 22^15^66.000001');
select microsecond('80@12@02 23^45^50.000000001');
select microsecond('10@13@29 23^59^59.4536434');

--echo  #OB与MYSQL不一致。
select microsecond('50@03@29 23^30^30.9999999');


--echo  #参数为字符串
select microsecond('15595966996');
select microsecond('0050.123456');
select microsecond('080000.123456');
select microsecond('125960.334123');
select microsecond('9991111.11231');
select microsecond('20220926151050.11111');
select microsecond('20220926155000.2222');
select microsecond('202209261500AA50');


--echo  #多个参数
--error 1064
select microsecond('10:10:10','11:11:11');

--echo  #为空
select microsecond('');
select microsecond('0');

--echo  #参数位数值类型
select microsecond(15595966996);
select microsecond(0050.123456);
select microsecond(080000.123456);
select microsecond(125960.334123);

select microsecond(9991111.11231);

select microsecond(20220926151050.11111);
select microsecond(20220926155000.2222);

--echo  #中文
select microsecond('12时22分2.123456秒');
select microsecond('2022年9月21日 12时22分2.11222333秒');
select microsecond('咚咚咚');

--echo  #特殊字符
select microsecond('@##%');
select microsecond('@222#1#%$%3');
select microsecond('@#%#%^#%');
select microsecond('/*-+*-*-');
select microsecond('{:}}{":"');


