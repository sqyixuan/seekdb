--echo	#select
drop table if exists t1;
create table t1(c1 char(30) ,c2 varchar(60) not null,c3 char(30) default '1999-09-09 18:16:16.00016');
insert into t1 values(161050.01,'18:20:30.011','2001-02-02 03:30:03.00017');
insert into t1(c1,c2) values(051501.02,'04:25:50.022');
insert into t1 values(071313.03,'082308.033','1880-05-05 05:33:05.00018');
insert into t1 values(101010.04,'11:11:11.044','0001-01-01 01:01:01.00019');
insert into t1(c1,c2) values(121212.05,'15:20:20.055.00020');
insert into t1 values(164050.06,'20220926055005.066','0001-01-01 01:01:01.00021');
insert into t1 values(101010.07,'2020.02.02.077','0001-01-01 01:01:01.00022');

select microsecond(c1),microsecond(c2),microsecond(c3) from t1 order by microsecond(c1);

--echo	#where
select microsecond(c1) from t1 where microsecond(c1) > 20000 and microsecond(c2) <=50000;
select microsecond(c3) from t1 where microsecond(c2) < 30000 and microsecond(c3) >100;

select microsecond(c2) from t1 where microsecond(c1)<30000 order by microsecond(c2);

select c1,case microsecond(c1) when microsecond(c1)> 5000 then microsecond('202020.11') else microsecond('101010.22') end as a from t1;

select c1, case c2 when '111111.0001' then microsecond('111111.002') else microsecond('080808.003') end as a from t1;

select distinct microsecond(c1),c2,c3 from t1 order by microsecond(c1);
select distinct microsecond(c3) ,c1,c3 from t1 order by microsecond(c3);

select microsecond(c1) from t1 group by c1 having microsecond(c1) >=10000;
drop table t1;


