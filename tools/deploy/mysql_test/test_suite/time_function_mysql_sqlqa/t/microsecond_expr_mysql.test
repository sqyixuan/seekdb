insert into test1 values(2,090909.000009,'2002-02-02 10:00:00.000','2034-02-22 00:50:50.000050');
insert into test1 values(3,101010.000010,'2006-04-15 06:06:20.000020','2026-05-08 05:16:16.000016');
insert into test1 values(4,111111.000011,'2012-12-12 12:12:12.000012','2030-08-16 14:05:05.000005');
select * from test1;

