--echo  #update、delete
drop table if exists test1;
create table test1(a1 int,a2 char(30),c1 varchar(60),c2 varchar(60));
insert into test1 values(1,'1998-12-12 02:02:02.000002','1998-12-12 03:12:12.000012','2038-01-19 11:20:20.000020');
insert into test1 values(2,'2002-02-02 04:04:04.000004','2002-02-02 05:14:14.000014','2034-02-22 12:22:22.000022');
insert into test1 values(3,'2006-04-15 06:06:06.000006','2006-04-15 07:16:16.000016','2026-05-08 13:24:24.000024');
insert into test1 values(4,'2012-12-12 08:08:08.000008','2012-12-12 09:18:18.000018','2030-08-16 14:26:26.000026');
select * from test1;
create table test2(a1 int,a2 int);
insert into test2 values(1,2),(2,4),(3,6),(4,8),(5,10),(6,12),(7,14),(8,16),(9,18),(10,20),(11,22),(12,24),(13,26),(14,28);

update test1 set a1 = microsecond('11:11:11.000011') where microsecond(a2) = (select a2 from test2 where a1 = 2);
update test1 set a1 = microsecond('12:12:12.000012') where microsecond(c1) = 3 or microsecond(c2) = (select a2 from test2 where a1 = 11);
select * from test1;

delete from test1 where microsecond(c1)> microsecond('2006-04-15 07:06:06.000006') and microsecond(c2) > microsecond('2038-01-19 01:14:14.000014');
delete from test1 where microsecond(c2) =(select a2 from test2 where a1 = 13);
select * from test1;

drop table test1;


--echo  #复制表
drop table if exists t1;
create table t1(c1 char(60) ,c2 varchar(60) not null,c3 char(30) default '1999-09-09 18:16:30.000030');
insert into t1 values('161010.000010','18:20:20.000020','2001-02-02 03:30:30.000030');
insert into t1(c1,c2) values('051515.000015.000015','04:25:25.000025');
insert into t1 values('071313.000013','082323.000023','1880-05-05 05:33:33.000033');
insert into t1 values('101010.000010','11:11:11.000011','0001-01-01 01:01:01.000001');
insert into t1(c1,c2) values('121212.000012.000012','15:20:20.000020');
insert into t1 values('164040.000040','20220926055050.000050','0001-01-01 01:01:01.000001');
insert into t1 values('101010.000010','200202.000002','0001-01-01 01:01:01.000001');
create table tt1 as select * from t1;
select microsecond(c1),microsecond(c2),microsecond(c3) from tt1 order by microsecond(c1);

--echo	#select
select microsecond(c1) from tt1 where microsecond(c1) > 20 and microsecond(c2) <=50;
select microsecond(c3) from tt1 where microsecond(c2) < 30 and microsecond(c3) >10;

select microsecond(c2) from tt1 where microsecond(c1)<30 order by microsecond(c2);

select c1,case microsecond(c1) when microsecond(c1)> 5 then microsecond('202020.000020') else microsecond('101010.000010') end as a from tt1;

select c1, case c2 when '11111111' then microsecond('111111.000011') else microsecond('080808.000008') end as a from tt1;

select distinct microsecond(c1),c2,c3 from tt1 order by microsecond(c1);
select distinct microsecond(c3) ,c1,c3 from tt1 order by microsecond(c3);

select microsecond(c1) from tt1 group by c1 having microsecond(c1) >=10 order by c1;

--echo #update
update tt1 set c1 = microsecond('080808.000008') where microsecond(c2) > microsecond('011010.000010') and microsecond(c2)<microsecond('011515.000015');
update tt1 set c2 = microsecond('010101.000001') where microsecond(c1) = microsecond('011313.000013') or microsecond(c3) = microsecond('16:30:31.000031');
update tt1 set c1 = microsecond('12:30:30.000030') where microsecond(c3) in (select a2 from test2);
select * from tt1;

--echo  #delete
delete from tt1 where microsecond(c1) >microsecond('12:10:30') and microsecond(c1) < microsecond('161531');
delete from tt1 where microsecond(c2) not in (select a2 from test2);
delete from tt1 where microsecond(c3) != 0;

drop table t1;
drop table tt1;


--echo	#分区
--echo	#hash
drop table if exists t1;
create table t1(c1 int,c2 char(30)) partition by hash(c1)
(
partition p1,
partition p2
);

insert into t1 values(114040,'1991-01-01 02:08:02.000002');
insert into t1 values(123030,'2001-03-01 04:08:04.000004');
insert into t1 values(131515,'2011-05-01 06:08:06.000006');
insert into t1 values(141515,'2021-07-01 08:08:08.000008');
insert into t1 values(141616,'2021-07-01 10:08:10.000010');
select * from t1;

select c1 from t1 where microsecond(c2) > 1 and microsecond(c2)< 7 order by microsecond(c2);
update t1 set c1 = microsecond('060606') where microsecond(c2) > 5;
delete from t1 where microsecond(c2) > 5 or microsecond(c1) = 6;
select * from t1;
drop table t1;


--echo	#range
drop table if exists t1;
create table t1(c1 int ,c2 varchar(30)) partition by range(c1)
(
partition p1 values less than(400000),
partition p2 values less than(maxvalue)
);


insert into t1 values(200101,'1991-02-01 4:02:02.000002');
insert into t1 values(300303,'2001-04-01 8:04:04.000004');
insert into t1 values(400505,'2011-06-01 12:06:06.000006');
insert into t1 values(500606,'2021-08-01 16:08:08.000008');
insert into t1 values(600707,'2021-08-01 20:10:10.000010');
select * from t1;

select c1 from t1 where microsecond(c2) > 1 and microsecond(c2)< 7 order by microsecond(c2);
update t1 set c1 = microsecond('020202') where microsecond(c2) > 5 and microsecond(c2) < 8;
select * from t1;
delete from t1 where microsecond(c2) > 2;
select * from t1;
drop table t1;


--echo	#list
drop table if exists t1;
create table t1(c1 int,c2 varchar(60)) partition by list(c1)
(
partition p1 values in(1,2,3,4),
partition p2 values in(5,6,7,8)
);
insert into t1 values(1,'1991-01-01 02:08:02.000002');
insert into t1 values(2,'2001-03-01 04:08:04.000004');
insert into t1 values(5,'2011-05-01 06:08:06.000006');
insert into t1 values(7,'2021-07-01 08:08:08.000008');
insert into t1 values(8,'2021-07-01 10:08:10.000010');
select * from t1;

select c1 from t1 where microsecond(c2) > 1 and microsecond(c2)< 7 order by microsecond(c2);
update t1 set c1 = microsecond('060606.000006') where microsecond(c2) > 5;
delete from t1 where microsecond(c2) > 5 or microsecond(c1) = 6;
select * from t1;
drop table t1;


--echo	#key
drop table if exists t1;
create table t1(c1 int primary key , c2 varchar(60))
partition by key(c1)
partitions 2;

insert into t1 values(114040,'1991-01-01 02:02:02.000002');
insert into t1 values(123030,'2001-03-01 04:04:04.000004');
insert into t1 values(131515,'2011-05-01 06:06:06.000006');
insert into t1 values(141515,'2021-07-01 08:08:08.000008');
insert into t1 values(141616,'2021-07-01 10:10:10.000010');
select * from t1;

select c1 from t1 where microsecond(c2) > 1 group by second(c1) having max(microsecond(c2))<10;
update t1 set c1 = microsecond('060606.000006') where microsecond(c2) > 9;
delete from t1 where microsecond(c2) > 5 and second(c1) = 6;
select * from t1 order by c1;
drop table t1;



--echo	#range columns
drop table if exists t1;
CREATE TABLE t1 (
    c1 int,
    c2 varchar(60)
)
PARTITION BY RANGE COLUMNS(c1) (
partition p1 values less than(400000),
partition p2 values less than(maxvalue)
);

insert into t1 values(200101,'1991-02-01 4:04:04.000004');
insert into t1 values(300303,'2001-04-01 8:08:08.000008');
insert into t1 values(400505,'2011-06-01 12:12:12.000012');
insert into t1 values(500606,'2021-08-01 16:16:16.000016');
insert into t1 values(600707,'2021-08-01 20:20:20.000020');
select * from t1;

select c1 from t1 where microsecond(c2) > 1 group by c1 having max(microsecond(c2))<6;
update t1 set c1 = microsecond('020202') where microsecond(c2) > 5;
select * from t1;
delete from t1 where microsecond(c2) > 2;
select * from t1;
drop table t1;


--echo	#list columns
drop table if exists t1;
create table t1(c1 int,c2 varchar(60)) partition by list columns(c1)
(
partition p1 values in(1,2,3,4),
partition p2 values in(5,6,7,8)
);
insert into t1 values(1,'1991-01-01 02:08:02.000002');
insert into t1 values(2,'2001-03-01 04:08:04.000004');
insert into t1 values(5,'2011-05-01 06:08:06.000006');
insert into t1 values(7,'2021-07-01 08:08:08.000008');
insert into t1 values(8,'2021-07-01 10:08:10.000010');
select * from t1;

select c1 from t1 where microsecond(c2) > 1 and microsecond(c2)< 7 order by microsecond(c2);
update t1 set c1 = microsecond('060606.000006') where microsecond(c2) > 5;
delete from t1 where microsecond(c2) > 5 or microsecond(c1) = 6;
select * from t1;
drop table t1;


--echo  #view
drop table if exists t1;
create table t1(c1 char(60) ,c2 varchar(60) not null,c3 char(30) default '1999-09-09 18:16:30.000030');
insert into t1 values('161010.000010','18:20:20.000020','2001-02-02 03:30:30.000030');
insert into t1(c1,c2) values('051515.000015.000015','04:25:25.000025');
insert into t1 values('071313.000013','082323.000023','1880-05-05 05:33:33.000033');
insert into t1 values('101010.000010','11:11:11.000011','0001-01-01 01:01:01.000001');
insert into t1(c1,c2) values('121212.000012.000012','15:20:20.000020');
insert into t1 values('164040.000040','20220926055050.000050','0001-01-01 01:01:01.000001');
insert into t1 values('101010.000010','200202.000002','0001-01-01 01:01:01.000001');
create view v_t1 as select * from t1;
select microsecond(c1),microsecond(c2),microsecond(c3) from v_t1 order by microsecond(c1);

--echo	#select
select microsecond(c1) from v_t1 where microsecond(c1) > 20 and microsecond(c2) <=50;
select microsecond(c3) from v_t1 where microsecond(c2) < 30 and microsecond(c3) >10;

select microsecond(c2) from v_t1 where microsecond(c1)<30 order by microsecond(c2);

select c1,case microsecond(c1) when microsecond(c1)> 5 then microsecond('202020.000020') else microsecond('101010.000010') end as a from v_t1;

select c1, case c2 when '11111111' then microsecond('111111.000011') else microsecond('080808.000008') end as a from v_t1;

select distinct microsecond(c1),c2,c3 from v_t1 order by microsecond(c1);
select distinct microsecond(c3) ,c1,c3 from v_t1 order by microsecond(c3);

select microsecond(c1) from v_t1 group by c1 having microsecond(c1) >=10 order by c1;


--echo #update
update v_t1 set c1 = microsecond('080808.000008') where microsecond(c2) > microsecond('011010.000010') and microsecond(c2)<microsecond('011515.000015');
update v_t1 set c2 = microsecond('010101.000001') where microsecond(c1) = microsecond('011313.000013') or microsecond(c3) = microsecond('16:30:31.000031');
update v_t1 set c1 = microsecond('12:30:30.000030') where microsecond(c3) in (select a2 from test2);
select * from v_t1;

--echo  #delete
delete from v_t1 where microsecond(c1) >microsecond('12:10:30') and microsecond(c1) < microsecond('161531');
delete from v_t1 where microsecond(c2) not in (select a2 from test2);
delete from v_t1 where microsecond(c3) != 0;

drop table t1;
drop view v_t1;
drop table test2;


--echo  #生成列
drop table if exists t1;
CREATE TABLE t1(c1 int,c2 int GENERATED ALWAYS AS (microsecond('060606.000006')) VIRTUAL);
insert into t1(c1) values(1);
insert into t1(c1) values(2);
select * from t1;
drop table t1;


--echo  #算数运算符
select microsecond('200505.001'+'050505.005');
select microsecond('200505.001'-'050505.0005');
select microsecond('200505.001'*'050505.0005');
select microsecond('200505.001'/'050505.0005');


--echo  #逻辑运算符
select microsecond('030303.000003') and microsecond(0305011.000011);
select microsecond('1921-10-10 06:06:07.000007') and microsecond('06:09:09.000009');

select not microsecond('1111-01-01 15:24:25.000025') ;
select not microsecond('111101.000001') ;


select microsecond('202101.1') or microsecond('222222.22');
select microsecond('192110.00') or microsecond('198808.08');
select microsecond('180110.010') or microsecond('180010.10');
select microsecond('212112.12') or ('2');
select microsecond('212112.12') or 'aa';

--echo  #比较运算符
select microsecond('200101.1') > microsecond('20:21:02.02');
select microsecond('380101.1') > microsecond('200102.2');
select microsecond('AASA22CCC') > microsecond('0000-01-01.000001');
select microsecond('202020.000020') > 'AA';
select microsecond('00010101.0001') >1;

select microsecond('2020-01-01 16:13:21.000021') < microsecond('2020-01-02 19:16:18.000018');
select microsecond('22:34:56.00056') < microsecond('230516.00016');
select microsecond('2221212.00012') < microsecond('9991231.00031');
select microsecond('1500-01-01 15:13:12.00012') < 'Abc';
select microsecond('2000-01-01 14:18:19.000019') < 14;


select microsecond('2020-01-01 11:12:11.00011') >= microsecond('2020-01-02 08:09:10.00010');
select microsecond('3800-01-01 10:11:11.11') >= microsecond('2050-01-01 08:08:08.000008');
select microsecond('0001-01-01 22:30:50.50') >= microsecond('0000-01-01 23:23:23.000023');
select microsecond('14:13:15.15') >= 'AA';
select microsecond('16:18:18.18') >=1;

select microsecond('20201111.000011') <= microsecond('2020-011-11 22:22:22.00022');
select microsecond('1500101.0010') < 'CCC';
select microsecond('241231.1') < 25;


--echo	#时间函数嵌套
--echo  #addtime
select microsecond(ADDTIME('2007-12-31 23:59:59.999999', '11:1:1.000002'));
select microsecond(ADDTIME('01:00:00.999999', '02:00:00.999998'));
select microsecond(ADDTIME('2007-12-31 23:59:59.999999', '1 1:1:1.000002'));


--echo	#date_add/sub
select microsecond(DATE_ADD('2018-05-01 12:12:12.0001',INTERVAL 1 DAY));
select microsecond(DATE_SUB('2018-05-01 16:12:12.0002',INTERVAL 1 microsecond));
select microsecond(DATE_ADD('2020-12-31 23:59:58.0003',INTERVAL 1 microsecond));
select microsecond(DATE_ADD('2018-12-31 23:59:59.0004',INTERVAL 1 DAY));
select microsecond(DATE_ADD('2100-12-31 22:59:57.0005',INTERVAL '1:1' MINUTE_SECOND));
select microsecond(DATE_SUB('2025-01-01 00:00:00.0006',INTERVAL '1 1:1:1' DAY_SECOND));
select microsecond(DATE_ADD('1900-01-01 00:00:00.0007',INTERVAL '-1 10' DAY_HOUR));
select microsecond(DATE_SUB('1998-01-02 15:15:15.000015', INTERVAL 31 DAY));
select microsecond(DATE_ADD('1992-12-31 23:59:59.000002',INTERVAL '1.999999' SECOND_MICROSECOND));

select microsecond(DATE_FORMAT('2003-10-03',GET_FORMAT(DATE,'EUR')));
select microsecond(STR_TO_DATE('10.31.2003',GET_FORMAT(DATE,'USA')));

--echo	#subdate/time
select microsecond(DATE_SUB('2008-01-02 08:08:08.001', INTERVAL 31 DAY));
select microsecond(SUBDATE('2008-01-02 13:13:13.003', INTERVAL 31 DAY));
select microsecond(SUBDATE('2008-01-02 12:00:00.123', 31));
select microsecond(SUBTIME('2007-12-31 23:59:59.999999','1 1:1:1.000002'));


--echo	#timestamp
select microsecond(TIMESTAMP('2003-12-31 08:08:08.005'));
select microsecond(TIMESTAMP('2003-12-31 12:00:00','12:00:00.007'));
select microsecond(TIMESTAMPADD(microsecond,1,'2003-01-02 15:16:17.00003'));
select microsecond(TIMESTAMPADD(WEEK,1,'2003-01-02 18:18:18.2020'));

--echo	#convert_tz
select microsecond(CONVERT_TZ('2004-01-01 12:05:20.00789','+00:00','+10:00'));
select microsecond(CONVERT_TZ('2004-01-01 12:05:50.180','+00:00','+20:00'));

