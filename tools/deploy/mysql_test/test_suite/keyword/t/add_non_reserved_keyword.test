# description: 测试mysql模式新增的非保留关键字

##请按照如下模版添加case

--disable_warnings
drop table if exists ACCESS;
--enable_warnings
create table ACCESS(a int);
alter table ACCESS add (ACCESS int);
drop table ACCESS;

--disable_warnings
drop table if exists ACCOUNT;
--enable_warnings
create table ACCOUNT(a int);
alter table ACCOUNT add (ACCOUNT int);
drop table ACCOUNT;

--disable_warnings
drop table if exists ARBITRATION;
--enable_warnings
create table ARBITRATION(a int);
alter table ARBITRATION add (ARBITRATION int);
drop table ARBITRATION;

--disable_warnings
drop table if exists SERVICE;
--enable_warnings
create table SERVICE(a int);
alter table SERVICE add (SERVICE int);
drop table SERVICE;

--disable_warnings
drop table if exists ENABLE_ARBITRATION_SERVICE;
--enable_warnings
create table ENABLE_ARBITRATION_SERVICE(a int);
alter table ENABLE_ARBITRATION_SERVICE add (ENABLE_ARBITRATION_SERVICE int);
drop table ENABLE_ARBITRATION_SERVICE;

--disable_warnings
drop table if exists ENCRYPTED;
--enable_warnings
create table ENCRYPTED(a int);
alter table ENCRYPTED add (ENCRYPTED int);
drop table ENCRYPTED;
