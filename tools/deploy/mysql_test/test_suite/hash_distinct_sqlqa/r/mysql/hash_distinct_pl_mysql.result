drop   procedure if   exists   pro1;
create procedure pro1()
begin
declare i int default 1;
while i <= 10 do
if mod(i,10) = 0 then
select /*+parallel(10)*/ max(distinct c1),min(distinct c3),count(distinct c2) from t1 where c1 > 19992 group by c1 order by c1;
elseif mod(i,8)=0 then
select /*+parallel(10) */ case when c1/2 =0 then 1 else 0 end c1,sum(c3) from (select distinct c3,c2,c1 from t1) as a group by c2 order by c2 asc limit 10;
elseif mod(i,7)=0 then
select /*+parallel(10 )*/ case when c1 >10000 then 777 else 888 end c1,count(c2),max(c3) from (select distinct c1,c2,c3 from t1) as a group by c1 desc limit 1;
elseif mod(i,5)=0 then
with tl1 as (select /*+parallel(10)*/ max(distinct c1) c1,min(distinct c3) c3,count(distinct c2) c2 from t1  group by c1 having max(c1) > 19992) select max(c1) from (select distinct c1 from t1) order by c1;
elseif mod(i,3)=0 then
select /*+parallel(10)*/ count(c1) from (select distinct c1 from t1) as a where c1 in (select max(c1) from t1);
else
select /*+parallel(10)*/ max(c1) from (select distinct c1 from t1) as a where c1 < any (select avg(c1) from t1);
end if;
set i = i+1;
end while;
end
