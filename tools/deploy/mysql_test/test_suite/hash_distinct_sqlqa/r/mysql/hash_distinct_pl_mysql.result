call pro1(1,1);
call pro1(2,1);
call pro1(0,1);
drop   procedure if   exists   pro1;
create procedure pro1()
begin
Declare i int default 1;
label:loop
if mod(i,10) = 0 then
delete from t1 where c1 = (select /*+parallel(10)*/ count(c1) from (select distinct c1 from t1) as a where c1 <> (select min(c1) from t1));
elseif mod(i,8)=0 then
delete from t1 where c3 = (select /*+parallel(10)*/ sum(c3) from (select distinct c3 from t1) as a where c3 >= all(select avg(c3) from t1));
elseif mod(i,5)=0 then
delete from t1 where c1 = (select /*+parallel(10)*/ count(c1) from (select distinct c1 from t1) as a where c1 like (select max(c1) from t1));
elseif mod(i,3)=0 then
delete from t1 where c3 = (select /*+parallel(10)*/ min(c3) from (select distinct c3 from t1) as a where c3 <= (select avg(c3) from t1));
else
delete from t1 where c1 = (select /*+parallel(10)*/ avg(c1) from (select distinct c1 from t1) as a where c1 != (select max(c1) from t1));
end if;
set i = i + 1;
if i>=10 then leave label;
end if;
end loop label;
end
//
call pro1();
drop   procedure if   exists   pro1;
create procedure pro1(aa int,bb int)
begin
Declare i int default 1;
repeat
if aa = bb then
insert into t1 select /*+parallel(10)*/ count(c1),max(c2),min(c3) from (select distinct c1,c2,c3 from t1) as a;
insert into t1 select /*+parallel(10)*/ c1,c2,min(c3) from (select distinct c3,c1,c2 from t1) as a where c3 <= (select avg(c3) from t1);
elseif aa > bb then
insert into t1 select /*+parallel(10)*/ count(c1),c2,c3 from (select distinct c1,c2,c3 from t1) as a where c1 <> (select min(c1) from t1);
else
insert into t1 select /*+parallel(10)*/ c1,c2,sum(c3) from (select distinct c3,c1,c2 from t1) as a where c3 >= all(select avg(c3) from t1);
end if;
set i = i+1;
until i>=2
end repeat;
end
