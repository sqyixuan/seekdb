drop   procedure if   exists   pro1;
create procedure pro1(aa int,bb int)
begin
if aa = bb then
update t1 set c3 = 1.11111 where c3 = (select /*+parallel(10)*/ min(c3) from (select distinct c3 from t1) as a where c3 <= (select avg(c3) from t1));
elseif aa > bb then
update t1 set c1 = 101 where c1 = (select /*+parallel(10)*/ max(c1) from (select distinct c1 from t1) as a where c1 < (select avg(c1) from t1));
else
update t1 set c1 = 102 where c1 = (select /*+parallel(10)*/ count(c1) from (select distinct c1 from t1) as a where c1 in (select max(c1) from t1));
end if;
end
