drop table if exists test4;
create table test4 (a1 decimal(10,2),a2 char(60));
drop procedure if exists pro4;
CREATE  PROCEDURE pro4(in i int,j int)
begin
while i <= j DO
insert into test4 values(i*0.1,concat('刘',i));
set i = i + 1;
end WHILE;
end
