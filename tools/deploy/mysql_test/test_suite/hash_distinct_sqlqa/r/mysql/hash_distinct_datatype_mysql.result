drop table test3;
drop table test4;
drop procedure pro3;
drop procedure pro4;
drop table if exists test5;
create table test5 (c1 datetime not null,c2 year ,c3 timestamp not null,primary key(c1,c2));
drop procedure if exists pro5;
CREATE  PROCEDURE pro5(in i int,j int)
begin
while i <= j DO
insert into test5 values(makedate(2000,i),year(makedate(2000,i)),makedate(1980,i));
set i = i + 1;
end WHILE;
end
