drop table if exists test2;
create table test2(a1 int,a2 varchar(60));
drop procedure if exists pro2;
CREATE  PROCEDURE pro2(in i int,j int)
begin
while i <= j DO
insert into test2 values(i,concat("万",i));
set i = i + 1;
end WHILE;
end
//
call pro2(1,20050);
