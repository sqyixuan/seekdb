#key分区
drop table if exists t4;
create table t4(c1 year not null primary key , c2 datetime not null,index index_c1(c1))
partition by key(c1)
partitions 3;
drop procedure if exists pro4;
CREATE  PROCEDURE pro4(in i int,j int)
begin
while i <= j DO
insert into t4 values(1969+i,makedate(1980,i));
set i = i + 1;
end WHILE;
end
