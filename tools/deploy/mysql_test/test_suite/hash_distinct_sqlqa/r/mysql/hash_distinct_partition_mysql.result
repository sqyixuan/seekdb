#hash 分区
drop table  if exists t2;
create table t2(c1 int primary key auto_increment,c2 datetime not null,c3 timestamp not null default '2022-01-01',key index_c1_c2(c1,c2)) partition by hash(c1)
(partition p1,
partition p2,
partition p3
);
drop procedure if exists pro2;
CREATE  PROCEDURE pro2(in i int,j int)
begin
while i <= j DO
insert into t2 values
(i,makedate(2000,i),makedate(1980,i)),
(i+1,makedate(2000,i+1),makedate(1980,i+1)),
(i+2,makedate(2000,i+2),makedate(1980,i+2)),
(i+3,makedate(2000,i+3),makedate(1980,i+3)),
(i+4,makedate(2000,i+4),makedate(1980,i+4)),
(i+5,makedate(2000,i+5),makedate(1980,i+5)),
(i+6,makedate(2000,i+6),makedate(1980,i+6)),
(i+7,makedate(2000,i+7),makedate(1980,i+7)),
(i+8,makedate(2000,i+8),makedate(1980,i+8)),
(i+9,makedate(2000,i+9),makedate(1980,i+9)),
(i+10,makedate(2000,i+10),makedate(1980,i+10));
set i = i + 11;
end WHILE;
end
//
call pro2(1,20000);
