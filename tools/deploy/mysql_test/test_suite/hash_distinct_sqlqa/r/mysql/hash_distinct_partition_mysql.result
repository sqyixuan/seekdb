drop table if exists t3;
create table t3(c1 int not null,c2 double not null)
partition by list (c1)
(
partition p0 values in(1,2,3,4,5),
partition p1 values in(6,7,8,9,10),
partition p2 values in(11,12,13,14,15),
partition p3 values in(16,17,18,19,20)
);
drop procedure if exists pro3;
CREATE  PROCEDURE pro3(in i int,j int)
begin
while i <= j DO
insert into t3 values(i,i*0.1);
set i = i + 1;
end WHILE;
end
//
call pro3(1,20);
