select /*+parallel(10)*/ sum(c3),max(c3),min(c3),count(c3),avg(c3) from (select distinct c3 from test7) as a;
select /*+parallel(10)*/ sum(c3),max(c2),min(c2),bin(min(c1)),bin(avg(c1)) from (select distinct c1,c2,c3 from test7) as a;
select /*+parallel(10)*/ count(c1),sum(c2),avg(c3),bin(max(c1)),min(c2) from (select distinct c1,c2,c3 from test7) as a group by c1 limit 1;
