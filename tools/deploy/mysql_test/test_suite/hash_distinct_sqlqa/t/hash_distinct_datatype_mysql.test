--disable_warnings
drop database if exists db1;
create database db1;
use db1;



SET wait_timeout=30000000;
SET ob_trx_timeout = 200000000;
SET ob_query_timeout = 200000000;




drop table if exists test3;
create table test3 (c1 float primary key,c2 double not null,c3 decimal(12,5),key index_c1_c2(c1,c2));
create index index_c3 on test3(c3);

drop procedure if exists pro3;
DELIMITER //;
CREATE  PROCEDURE pro3(in i int,j int)
begin
    while i <= j DO
        insert into test3 values(i*0.1,i*0.02,i*0.00003);
        set i = i + 1;
    end WHILE;
end
//
DELIMITER ;//
call pro3(1,20000);

--disable_result_log
--echo  #float
select /*+parallel(10)*/ count(c1) from (select distinct c1 from test3) as a;
select /*+parallel(10)*/ max(c1) from (select distinct c1 from test3) as a;
select /*+parallel(10)*/ min(c1) from (select distinct c1 from test3) as a;
select /*+parallel(10)*/ avg(c1) from (select distinct c1 from test3) as a;
select /*+parallel(10)*/ sum(c1) from (select distinct c1 from test3) as a;
select /*+parallel(10)*/ sum(c1),count(c1),max(c1),min(c1),avg(c1) from (select distinct c1 from test3) as a;
select /*+parallel(10)*/ sum(c1),count(c1),max(c1),min(c1),avg(c1) from (select distinct c1 from test3) as a group by c1 order by c1 desc limit 1;
select /*+parallel(10)*/ case when c1 then 1.111 else 2.222 end c1,sum(c1),count(c1),max(c1),min(c1),avg(c1) from (select distinct c1 from test3) as a;
select /*+parallel(10)*/ case when c1 > 20 then count(c1) else max(c1) end c1,sum(c1),count(c1),max(c1),min(c1),avg(c1) from (select distinct c1 from test3) as a;


--echo  #double
select /*+parallel(10)*/ count(c2) from (select distinct c2 from test3) as a;
select /*+parallel(10)*/ max(c2) from (select distinct c2 from test3) as a;
select /*+parallel(10)*/ min(c2) from (select distinct c2 from test3) as a;
select /*+parallel(10)*/ avg(c2) from (select distinct c2 from test3) as a;
select /*+parallel(10)*/ sum(c2) from (select distinct c2 from test3) as a;

select /*+parallel(10)*/ sum(c2),count(c2),max(c2),min(c2),avg(c2) from (select distinct c2 from test3) as a;
select /*+parallel(10)*/ sum(c2),count(c2),max(c2),min(c2),avg(c2) from (select distinct c2 from test3) as a group by c2 order by c2 asc limit 1;
select /*+parallel(10)*/ case when c2 then 3.333 else 4.444 end c2,sum(c2),count(c2),max(c2),min(c2),avg(c2) from (select distinct c2 from test3) as a;
select /*+parallel(10)*/ case when c2 >100 then sum(c2) else min(c2) end c2,sum(c2),count(c2),max(c2),min(c2),avg(c2) from (select distinct c2 from test3) as a group by c2 order by c2 asc limit 1;
--enable_result_log

--echo  #decimal
select /*+parallel(10)*/ count(c3) from (select distinct c3 from test3) as a;
select /*+parallel(10)*/ max(c3) from (select distinct c3 from test3) as a;
select /*+parallel(10)*/ min(c3) from (select distinct c3 from test3) as a;
select /*+parallel(10)*/ avg(c3) from (select distinct c3 from test3) as a;
select /*+parallel(10)*/ sum(c3) from (select distinct c3 from test3) as a;
select /*+parallel(10)*/ sum(c3),count(c3),max(c3),min(c3),avg(c3) from (select distinct c3 from test3) as a;
select /*+parallel(10)*/ sum(c3),count(c3),max(c3),min(c3),avg(c3) from (select distinct c3 from test3) as a group by c3 order by c3 limit 1;
select /*+parallel(10)*/ case when c3 then 1.111 else 2.222 end c3,sum(c3),count(c3),max(c3),min(c3),avg(c3) from (select distinct c3 from test3) as a;
select /*+parallel(10)*/ case when c3 >100 then sum(c3) else max(c3) end c3,sum(c3),count(c3),max(c3),min(c3),avg(c3) from (select distinct c3 from test3) as a group by c3 order by c3 limit 1;


--disable_result_log
select /*+parallel(10)*/ count(c1),sum(c2),avg(c3),max(c1),min(c2) from (select distinct c1,c2,c3 from test3) as a;
select /*+parallel(10)*/ count(c1),sum(distinct c2),avg(c3),max(distinct c1),min(c2) from (select distinct c1,c2,c3 from test3) as a;
select /*+parallel(10)*/ count(c1),sum(distinct c2),avg(c3),max(distinct c1),min(c2) from (select distinct c1,c2,c3 from test3) as a group by c1 limit 1;
with tt1 as (select /*+parallel(10)*/ max(distinct c1) c1,min(distinct c3) c3,count(distinct c2) c2 from test3  group by c1 having max(c1) > 100) select max(c1) from (select distinct c1 from tt1);
--enable_result_log


--disable_result_log
--echo  #子查询
select /*+parallel(10)*/ count(distinct c1) from test3 where c1 > (select avg(c1) from test3);
select /*+parallel(10)*/ count(c1) from (select distinct c1 from test3) as a where c1 > (select avg(c1) from test3);

select /*+parallel(10)*/ max(distinct c1) from test3 where c1 < (select avg(c1) from test3);
select /*+parallel(10)*/ max(c1) from (select distinct c1 from test3) as a where c1 < (select avg(c1) from test3);
--enable_result_log


select /*+parallel(10)*/ sum(distinct c3) from test3 where c3 >= (select avg(c3) from test3);
select /*+parallel(10)*/ sum(c3) from (select distinct c3 from test3) as a where c3 >= (select avg(c3) from test3);

select /*+parallel(10)*/ min(distinct c3) from test3 where c3 <= (select avg(c3) from test3);
select /*+parallel(10)*/ min(c3) from (select distinct c3 from test3) as a where c3 <= (select avg(c3) from test3);

--disable_result_log
select /*+parallel(10)*/ avg(distinct c1) from test3 where c1 != (select max(c1) from test3);
select /*+parallel(10)*/ avg(c1) from (select distinct c1 from test3) as a where c1 != (select max(c1) from test3);

select /*+parallel(10)*/ count(distinct c1) from test3 where c1 <> (select min(c1) from test3);
select /*+parallel(10)*/ count(c1) from (select distinct c1 from test3) as a where c1 <> (select min(c1) from test3);


select /*+parallel(10)*/ count(distinct c1) from test3 where c1 in (select max(c1) from test3);
select /*+parallel(10)*/ count(c1) from (select distinct c1 from test3) as a where c1 in (select max(c1) from test3);


select /*+parallel(10)*/ count(distinct c1) from test3 where c1 not in (select min(c1) from test3);
select /*+parallel(10)*/ count(c1) from (select distinct c1 from test3) as a where c1 not in (select min(c1) from test3);


select /*+parallel(10)*/ max(distinct c1) from test3 where c1 < any (select avg(c1) from test3);
select /*+parallel(10)*/ max(c1) from (select distinct c1 from test3) as a where c1 < any (select avg(c1) from test3);
--enable_result_log


select /*+parallel(10)*/ sum(distinct c3) from test3 where c3 >= all (select avg(c3) from test3);
select /*+parallel(10)*/ sum(c3) from (select distinct c3 from test3) as a where c3 >= all(select avg(c3) from test3);


select /*+parallel(10)*/ min(distinct c3) from test3 where exists (select avg(c3) from test3);
select /*+parallel(10)*/ min(c3) from (select distinct c3 from test3) as a where exists (select avg(c3) from test3);


select /*+parallel(10)*/ min(distinct c3) from test3 where not exists (select avg(c3) from test3);
select /*+parallel(10)*/ min(c3) from (select distinct c3 from test3) as a where not exists (select avg(c3) from test3);

--disable_result_log
select /*+parallel(10)*/ avg(distinct c1) from test3 where c1 != some (select max(c1) from test3);
select /*+parallel(10)*/ avg(c1) from (select distinct c1 from test3) as a where c1 != some (select max(c1) from test3);


select /*+parallel(10)*/ count(distinct c1) from test3 where c1 like (select max(c1) from test3);
select /*+parallel(10)*/ count(c1) from (select distinct c1 from test3) as a where c1 like (select max(c1) from test3);
--enable_result_log


drop table if exists test4;
create table test4 (a1 decimal(10,2),a2 char(60));

drop procedure if exists pro4;
DELIMITER //;
CREATE  PROCEDURE pro4(in i int,j int)
begin
    while i <= j DO
        insert into test4 values(i*0.1,concat('刘',i));
        set i = i + 1;
    end WHILE;
end
//
DELIMITER ;//
call pro4(1,20050);


--echo  #多表
--disable_parsing
select /*parallel(10)*/ count(c1) from (select distinct c1 from test3,test4)as a;
