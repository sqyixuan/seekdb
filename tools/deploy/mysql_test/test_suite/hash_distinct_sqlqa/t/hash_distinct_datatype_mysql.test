drop table if exists test6;
create table test6 (a1 datetime not null,a2 year ,a3 timestamp not null,primary key(a1,a2));
drop procedure if exists pro6;
DELIMITER //;
CREATE  PROCEDURE pro6(in i int,j int)
begin
    while i <= j DO
        insert into test6 values(makedate(2000,i),year(makedate(2000,i)),makedate(1980,i));
        set i = i + 1;
    end WHILE;
end
//
DELIMITER ;//
call pro6(1,2050);


