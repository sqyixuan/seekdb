drop table test3;
drop table test4;
drop procedure pro3;
drop procedure pro4;


drop table if exists test5;
create table test5 (c1 datetime not null,c2 year ,c3 timestamp not null,primary key(c1,c2));
drop procedure if exists pro5;
DELIMITER //;
CREATE  PROCEDURE pro5(in i int,j int)
begin
    while i <= j DO
        insert into test5 values(makedate(2000,i),year(makedate(2000,i)),makedate(1980,i));
        set i = i + 1;
    end WHILE;
end
//
DELIMITER ;//
call pro5(1,2000);

--echo  #datetime
select /*+parallel(10)*/ count(c1) from (select distinct c1 from test5) as a;
select /*+parallel(10)*/ max(c1) from (select distinct c1 from test5) as a;
select /*+parallel(10)*/ min(c1) from (select distinct c1 from test5) as a;
select /*+parallel(10)*/ avg(c1) from (select distinct c1 from test5) as a;
select /*+parallel(10)*/ sum(c1) from (select distinct c1 from test5) as a;
select /*+parallel(10)*/ sum(c1),max(c1),min(c1),count(c1),avg(c1) from (select distinct c1 from test5) as a;
select /*+parallel(10)*/ sum(c1),max(c1),min(c1),count(c1),avg(c1) from (select distinct c1 from test5) as a group by c1 having max(c1) > '2004-12-12' order by c1 desc limit 5;
select /*+parallel(10)*/ case when c1 then '2008-08-08' else '2020-02-02' end c1,sum(c1),count(c1),max(c1),min(c1),avg(c1) from (select distinct c1 from test5) as a;
select /*+parallel(10)*/ case when c1 > '2004-08-08'  then sum(c1) else max(c1) end c1,sum(c1),count(c1),max(c1),min(c1),avg(c1) from (select distinct c1 from test5) as a group by c1 order by c1 limit 1;


