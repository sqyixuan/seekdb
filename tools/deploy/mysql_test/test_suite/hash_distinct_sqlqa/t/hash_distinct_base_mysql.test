#description : 普通表中测试
#author : wb-zwc01059807
--disable_warnings
drop database if exists db1;

create database db1;
use db1;

SET wait_timeout=30000000;
SET ob_trx_timeout = 200000000;
SET ob_query_timeout = 200000000;


drop table if exists test1;
create table test1(c1 int,c2 varchar(60),c3 decimal(10,2));
drop procedure if exists pro1;
DELIMITER //;
CREATE  PROCEDURE pro1(in i int,j int)
begin
    while i <= j DO
        insert into test1 values(i,concat("李",i),i*0.1);
        set i = i + 1;
    end WHILE;
end
//
DELIMITER ;//
call pro1(1,20000);
call pro1(50,1000);


--echo  #单列多列,聚合
select /*+parallel(10)*/ count(distinct c1) from test1;
select /*+parallel(10)*/ count(distinct c1,c2) from test1;
select /*+parallel(10)*/ count(distinct c1,c2,c3) from test1;

select /*+parallel(10)*/ count(c1) from (select distinct c1 from test1) as a;
select /*+parallel(10)*/ count(c1) from (select distinct c1,c2 from test1) as a;
select /*+parallel(10)*/ count(c1) from (select distinct c1,c2,c3 from test1) as a;

select /*+parallel(10)*/ max(distinct c1) from test1;
select /*+parallel(10)*/ max(distinct c2) from test1;
select /*+parallel(10)*/ max(distinct c3) from test1;

select /*+parallel(10)*/ max(c1) from (select distinct c1 from test1) as a;
select /*+parallel(10)*/ max(c3) from (select distinct c3 from test1) as a;

select /*+parallel(10)*/ min(distinct c1) from test1;
select /*+parallel(10)*/ min(distinct c2) from test1;
select /*+parallel(10)*/ min(distinct c3) from test1;

select /*+parallel(10)*/ min(c1) from (select distinct c1 from test1) as a;
select /*+parallel(10)*/ min(c3) from (select distinct c3 from test1) as a;

select /*+parallel(10)*/ avg(distinct c1) from test1;
#select /*+parallel(10)*/ avg(distinct c2) from test1;
select /*+parallel(10)*/ avg(distinct c3) from test1;

select /*+parallel(10)*/ avg(c1) from (select distinct c1 from test1) as a;
#select /*+parallel(10)*/ avg(c2) from (select distinct c2 from test1) as a;
select /*+parallel(10)*/ avg(c3) from (select distinct c3 from test1) as a;

select /*+parallel(10)*/ sum(distinct c1) from test1;
select /*+parallel(10)*/ sum(distinct c2) from test1;
select /*+parallel(10)*/ sum(distinct c3) from test1;

select /*+parallel(10)*/ sum(c1) from (select distinct c1 from test1) as a;
select /*+parallel(10)*/ sum(c2) from (select distinct c2 from test1) as a;
select /*+parallel(10)*/ sum(c3) from (select distinct c3 from test1) as a;


--echo  #多个聚合
select /*+parallel(10)*/ count(distinct c1),max(distinct c1),min(distinct c1),sum(distinct c1),avg(distinct c1) from test1;
select /*+parallel(10)*/ count(c1),max(c1),min(c1),sum(c1),avg(c1) from (select distinct c1 from test1) as a;

#select /*+parallel(10)*/ count(distinct c2),max(distinct c2),min(distinct c2),sum(distinct c2),avg(distinct c2) from test1;
#select /*+parallel(10)*/ count(c2),max(c2),min(c2),sum(c2),avg(c2) from (select distinct c2 from test1) as a;

select /*+parallel(10)*/ count(distinct c3),max(distinct c3),min(distinct c3),sum(distinct c3),avg(distinct c3) from test1;
select /*+parallel(10)*/ count(c3),max(c3),min(c3),sum(c3),avg(c3) from (select distinct c3 from test1) as a;

select /*+parallel(10)*/ count(c3),count(distinct c2),max(c3) from test1;
select /*+parallel(10)*/ count(c3),count(distinct c2),max(c3) from (select distinct c3,c2 from test1)as a;

#select /*+parallel(10)*/ max(c1),min(distinct c2),sum(c3),avg(c1),avg(c2) from test1;
#select /*+parallel(10)*/ max(c1),min(distinct c2),sum(c3),avg(c1),avg(c2) from (select distinct c1,c2,c3 from test1) as a;

select /*+parallel(10)*/ max(c3),min(c1),sum(c2),avg(c3),avg(c2) from test1;
select /*+parallel(10)*/ max(c3),min(c1),sum(c2),avg(c3),avg(c2) from (select distinct c1,c2,c3 from test1) as a;



--echo  #distinct内进行计算
select /*+parallel(10)*/ max(distinct c1+c1) from test1;
select /*+parallel(10)*/ max(distinct c2+c3) from test1;
select /*+parallel(10)*/ max(distinct c3+c1+c2) from test1;

select /*+parallel(10)*/ max(c1) from (select distinct c1+c3,c1 from test1) as a;
select /*+parallel(10)*/ max(c2) from (select distinct c2+c1,c2 from test1) as a;
select /*+parallel(10)*/ max(c3) from (select distinct c3+c1+c1,c3 from test1) as a;

select /*+parallel(10)*/ max(distinct c1*c1) from test1;
select /*+parallel(10)*/ max(distinct c2*c3) from test1;
select /*+parallel(10)*/ max(distinct c3*c1*c2) from test1;

select /*+parallel(10)*/ max(c1) from (select distinct c1*c1*c3,c1 from test1) as a;
select /*+parallel(10)*/ max(c2) from (select distinct c2+c1*c2,c2 from test1) as a;
select /*+parallel(10)*/ max(c3) from (select distinct c3+c1*c1,c3 from test1) as a;

select /*+parallel(10)*/ max(distinct c1/c1*c3) from test1;
select /*+parallel(10)*/ max(distinct c2/c3) from test1;
select /*+parallel(10)*/ max(distinct c3*c1*c2/0) from test1;

select /*+parallel(10)*/ max(c1) from (select distinct c1/c1-c3,c1 from test1) as a;
select /*+parallel(10)*/ max(c2) from (select distinct c2*c1+c2,c2 from test1) as a;
select /*+parallel(10)*/ max(c3) from (select distinct c3-c1*c1,c3 from test1) as a;

select /*+parallel(10)*/ min(distinct c1*c3/c3+c1*c3-c2) from test1;
select /*+parallel(10)*/ min(distinct c3-c1*c3/c1) from test1;

select /*+parallel(10)*/ min(c1) from (select distinct c1*c3/c3+c1*c3-c2,c1 from test1) as a;
select /*+parallel(10)*/ min(c2) from (select distinct c3-c1*c3/c1,c2 from test1) as a;


select /*+parallel(10)*/ avg(c1) from (select distinct c1+c3+c1*c3*c1/c3-c2,c1 from test1) as a;
select /*+parallel(10)*/ avg(c3) from (select distinct c1+c3*c3/c1*c3+c2,c3 from test1) as a;

select /*+parallel(10)*/ sum(distinct c1%c3*c3-c2+c1/c3) from test1;

select /*+parallel(10)*/ sum(c1) from (select distinct c1%c3*c3-c2+c1/c3,c1 from test1) as a;
select /*+parallel(10)*/ sum(c3) from (select distinct c1*c3/c3+c1*c3-c2%c3,c3 from test1) as a;



--echo  #case when
select /*+parallel(10) */ case when c1/2 =0 then 1 else 0 end c1,count(c3),sum(distinct c2),min(c2) from test1 group by c2 order by c2 asc limit 5;
select /*+parallel(10) */ case when c1/2 =0 then 1 else 0 end c1,sum(c3) from (select distinct c3,c2,c1 from test1) as a group by c2 order by c2 asc limit 10;
select /*+parallel(10) */ case when c1/2 =0 then 1 else 0 end c1,sum(distinct c2)from test1;

select /*+parallel(10) */ case when c2 then 'AAAA' else 'BBBB' end c2,avg(distinct c1),max(distinct c3),min(distinct c2) from test1 order by c1 asc;
select /*+parallel(10) */ case when c2 then 'AAAA' else 'BBBB' end c2,avg(distinct c1),max(distinct c3),min(distinct c2) from (select * from test1) as a order by c1 asc;

select /*+parallel(10 )*/ case when c1 >10000 then 777 else 888 end c1,count(c2),max(c3) from (select distinct c1,c2,c3 from test1) as a group by c1 desc limit 1;
select /*+parallel(10 )*/ case when c1 <(select /*+parallel(10)*/ avg(c1) from (select distinct c1 from test1) as c) then 1 else 0 end c1,max(c2),count(c3) from (select distinct c1,c2,c3 from test1) as a order by c1 desc ;

--echo  #with as
with tt1 as (select /*+parallel(10)*/ max(distinct c1) c1,min(distinct c3) c3,count(distinct c2) c2 from test1  group by c1 having max(c1) > 19992) select max(c1) from (select distinct c1 from tt1);
with tt1 as (select /*+parallel(10) */ case when c1/2 =0 then 1 else 0 end c1,sum(c3) c3,c2 from (select distinct c3,c2,c1 from test1) as a group by c2 order by c2 asc limit 10) select distinct c1,max(c3) from (select distinct c3,c1,c2 from tt1);


--echo  #嵌套子查询
select /*+parallel(10)*/ count(distinct c1) from test1 where c1 > (select avg(c1) from test1);
select /*+parallel(10)*/ count(c1) from (select distinct c1 from test1) as a where c1 > (select avg(c1) from test1);

select /*+parallel(10)*/ max(distinct c1) from test1 where c1 < (select avg(c1) from test1);
select /*+parallel(10)*/ max(c1) from (select distinct c1 from test1) as a where c1 < (select avg(c1) from test1);

select /*+parallel(10)*/ sum(distinct c3) from test1 where c3 >= (select avg(c3) from test1);
select /*+parallel(10)*/ sum(c3) from (select distinct c3 from test1) as a where c3 >= (select avg(c3) from test1);

select /*+parallel(10)*/ min(distinct c3) from test1 where c3 <= (select avg(c3) from test1);
select /*+parallel(10)*/ min(c3) from (select distinct c3 from test1) as a where c3 <= (select avg(c3) from test1);

select /*+parallel(10)*/ avg(distinct c1) from test1 where c1 != (select max(c1) from test1);
select /*+parallel(10)*/ avg(c1) from (select distinct c1 from test1) as a where c1 != (select max(c1) from test1);

select /*+parallel(10)*/ count(distinct c1) from test1 where c1 <> (select min(c1) from test1);
select /*+parallel(10)*/ count(c1) from (select distinct c1 from test1) as a where c1 <> (select min(c1) from test1);

select /*+parallel(10)*/ count(distinct c1) from test1 where c1 in (select max(c1) from test1);
select /*+parallel(10)*/ count(c1) from (select distinct c1 from test1) as a where c1 in (select max(c1) from test1);

select /*+parallel(10)*/ count(distinct c1) from test1 where c1 not in (select min(c1) from test1);
select /*+parallel(10)*/ count(c1) from (select distinct c1 from test1) as a where c1 not in (select min(c1) from test1);

select /*+parallel(10)*/ max(distinct c1) from test1 where c1 < any (select avg(c1) from test1);
select /*+parallel(10)*/ max(c1) from (select distinct c1 from test1) as a where c1 < any (select avg(c1) from test1);

select /*+parallel(10)*/ sum(distinct c3) from test1 where c3 >= all (select avg(c3) from test1);
select /*+parallel(10)*/ sum(c3) from (select distinct c3 from test1) as a where c3 >= all(select avg(c3) from test1);

select /*+parallel(10)*/ min(distinct c3) from test1 where exists (select avg(c3) from test1);
select /*+parallel(10)*/ min(c3) from (select distinct c3 from test1) as a where exists (select avg(c3) from test1);

select /*+parallel(10)*/ min(distinct c3) from test1 where not exists (select avg(c3) from test1);
select /*+parallel(10)*/ min(c3) from (select distinct c3 from test1) as a where not exists (select avg(c3) from test1);

select /*+parallel(10)*/ avg(distinct c1) from test1 where c1 != some (select max(c1) from test1);
select /*+parallel(10)*/ avg(c1) from (select distinct c1 from test1) as a where c1 != some (select max(c1) from test1);

select /*+parallel(10)*/ count(distinct c1) from test1 where c1 like (select max(c1) from test1);
select /*+parallel(10)*/ count(c1) from (select distinct c1 from test1) as a where c1 like (select max(c1) from test1);



drop table if exists test2;
create table test2(a1 int,a2 varchar(60));
drop procedure if exists pro2;
DELIMITER //;
CREATE  PROCEDURE pro2(in i int,j int)
begin
    while i <= j DO
        insert into test2 values(i,concat("万",i));
        set i = i + 1;
    end WHILE;
end
//
DELIMITER ;//
call pro2(1,20050);


--echo  #无条件连接
select /*+parallel(10)*/ max(a1) from (select distinct a1 from test1,test2) as a;

--echo	#执行时间过长(可以跑通)
#select /*+parallel(10)*/ min(a1) from (select distinct a1 from test1,test2) as a;
#select /*+parallel(10)*/ count(a1) from (select distinct a1 from test1,test2) as a;
#select /*+parallel(10)*/ sum(a1) from (select distinct a1 from test1,test2) as a;
#select /*+parallel(10)*/ avg(a1) from (select distinct a1 from test1,test2) as a;

