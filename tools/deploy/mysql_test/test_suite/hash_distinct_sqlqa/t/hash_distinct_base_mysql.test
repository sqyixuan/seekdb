--echo  #natural join
#select /*+parallel(10)*/ max(a1) from (select distinct a1 from test1 natural join test2) as a;
#select /*+parallel(10)*/ min(a1) from (select distinct a1 from test1 natural join test2) as a;
#select /*+parallel(10)*/ count(a1) from (select distinct a1 from test1 natural join test2) as a;
#select /*+parallel(10)*/ sum(a1) from (select distinct a1 from test1 natural join test2) as a;
#select /*+parallel(10)*/ avg(a1) from (select distinct a1 from test1 natural join test2) as a;

--echo  #基本连接
select /*+parallel(10)*/ max(a1) from (select distinct a1 from test1,test2 where test1.c1 = test2.a1) as a;
select /*+parallel(10)*/ min(a1) from (select distinct a1 from test1,test2 where test1.c1 = test2.a1) as a;
select /*+parallel(10)*/ count(a1) from (select distinct a1 from test1,test2 where test1.c1 = test2.a1) as a;
select /*+parallel(10)*/ sum(a1) from (select distinct a1 from test1,test2 where test1.c1 = test2.a1) as a;
select /*+parallel(10)*/ avg(a1) from (select distinct a1 from test1,test2 where test1.c1 = test2.a1) as a;
select /*+parallel(10)*/ min(a1),max(c1),count(a2),count(c2),sum(c1) from (select distinct a1,a2,c1,c2 from test1,test2 where test1.c1 = test2.a1) as a;


--echo  #inner join
select /*+parallel(10)*/ avg(c1) from (select distinct c1 from test1 inner join test2 on test1.c1 = test2.a1) as a;
select /*+parallel(10)*/ sum(c1) from (select distinct c1 from test1 inner join test2 on test1.c1 = test2.a1) as a;
select /*+parallel(10)*/ min(c1) from (select distinct c1 from test1 inner join test2 on test1.c1 = test2.a1) as a;
select /*+parallel(10)*/ max(c1) from (select distinct c1 from test1 inner join test2 on test1.c1 = test2.a1) as a;
select /*+parallel(10)*/ min(a1),max(c1),count(a2),count(c2),sum(c1) from (select distinct a1,a2,c1,c2 from test1 inner join test2 on test1.c1 = test2.a1) as a;

--echo  #left join
select /*+parallel(10)*/ sum(c1) from (select distinct c1 from test1 left join test2 on test1.c1 = test2.a1) as a;
select /*+parallel(10)*/ avg(c1) from (select distinct c1 from test1 left join test2 on test1.c1 = test2.a1) as a;
select /*+parallel(10)*/ max(c1) from (select distinct c1 from test1 left join test2 on test1.c1 = test2.a1) as a;
select /*+parallel(10)*/ min(c1) from (select distinct c1 from test1 left join test2 on test1.c1 = test2.a1) as a;
select /*+parallel(10)*/ sum(a1),max(c1),count(a2),avg(c1),min(a1) from (select distinct a1,a2,c1,c2 from test1 left join test2 on test1.c1 = test2.a1) as a;

--echo  #rifht join
select /*+parallel(10)*/ sum(c1) from (select distinct c1 from test1 right join test2 on test1.c1 = test2.a1) as a;
select /*+parallel(10)*/ avg(c1) from (select distinct c1 from test1 right join test2 on test1.c1 = test2.a1) as a;
select /*+parallel(10)*/ max(c1) from (select distinct c1 from test1 right join test2 on test1.c1 = test2.a1) as a;
select /*+parallel(10)*/ min(c1) from (select distinct c1 from test1 right join test2 on test1.c1 = test2.a1) as a;
select /*+parallel(10)*/ sum(a1),max(c1),count(a2),avg(c1),min(a1) from (select distinct a1,a2,c1,c2 from test1 right join test2 on test1.c1 = test2.a1) as a;

drop table test1;
drop table test2;
drop procedure pro1;
drop procedure pro2;

--enable_warnings

drop database db1;
