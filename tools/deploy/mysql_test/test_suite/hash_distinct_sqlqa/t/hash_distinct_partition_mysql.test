--disable_warnings
drop database if exists db1;
create database db1;
use db1;


SET wait_timeout=30000000;
SET ob_trx_timeout = 200000000;
SET ob_query_timeout = 200000000;



--echo  #分区表
--echo  #range分区
drop table if exists t1;
create table t1(c1 int not null,c2 int default '6') partition by range(c1)
(
partition p1 values less than(5000),
partition p2 values less than(10000),
partition p3 values less than(maxvalue)
);
drop procedure if exists pro1;
DELIMITER //;
CREATE  PROCEDURE pro1(in i int,j int)
begin
    while i <= j DO
    insert into t1 values(i,i),(i+1,i+1),(i+2,i+2),(i+3,i+3),(i+4,i+4),(i+5,i+5),(i+6,i+6),(i+7,i+7),(i+8,i+8),(i+9,i+9),(i+10,i+10);
  set i = i + 10;
    end WHILE;
end
//
DELIMITER ;//
call pro1(1,20000);


select /*+parallel(10)*/ count(c1) from (select distinct c1 from t1) as a;
explain basic select /*+parallel(10)*/ count(c1) from (select distinct c1 from t1) as a;
select /*+parallel(10)*/ count(c1),max(c1),min(c1),sum(c1),avg(c1) from (select distinct c1 from t1) as a;

select /*+parallel(10)*/ count(c1) from (select distinct c1 from t1 partition (p1)) as a;
select /*+parallel(10)*/ max(c1) from (select distinct c1 from t1 partition (p1)) as a;
select /*+parallel(10)*/ avg(c1) from (select distinct c1 from t1 partition (p1)) as a;
select /*+parallel(10)*/ sum(c1) from (select distinct c1 from t1 partition (p1)) as a;
select /*+parallel(10)*/ min(c1) from (select distinct c1 from t1 partition (p1)) as a;

select /*+parallel(10)*/ sum(c1),min(c1),avg(c1),max(c1),count(c1) from (select distinct c1 from t1 partition (p1)) as a group by c1 having max(c1)>3000 order by c1 limit 5;

select /*+parallel(10)*/ sum(c1),min(c1),avg(c1),max(c1),count(c1) from (select distinct c1 from t1 partition (p1)) as a where a.c1 > (select max(c1) from t1 partition(p1) where c1 < 4000);

select /*+parallel(10)*/ sum(c1),min(c1),avg(c1),max(c1),count(c1) from (select distinct c1 from t1 partition (p1)) as a where a.c1 in (select max(c1) from t1 partition(p1) where c1 < 4000);

select /*+parallel(10)*/ sum(c1),min(c1),avg(c1),max(c1),count(c1) from (select distinct c1 from t1 partition (p1)) as a where a.c1 not in (select avg(c1) from t1 partition(p1) where c1 < 4000);

select /*+parallel(10)*/ sum(c1),min(c1),avg(c1),max(c1),count(c1) from (select distinct c1 from t1 partition (p1)) as a where a.c1 = any (select count(c1) from t1 partition(p1) where c1 < 4000);

select /*+parallel(10)*/ sum(c1),min(c1),avg(c1),max(c1),count(c1) from (select distinct c1 from t1 partition (p1)) as a where a.c1 < all (select avg(c1) from t1 partition(p1) where c1 < 4000);

select /*+parallel(10)*/ sum(c1),min(c1),avg(c1),max(c1),count(c1) from (select distinct c1 from t1 partition (p1)) as a where a.c1 != some (select min(c1) from t1 partition(p1) where c1 < 4000);

select /*+parallel(10)*/ sum(c1),min(c1),avg(c1),max(c1),count(c1) from (select distinct c1 from t1 partition (p1)) as a where exists (select min(c1) from t1 partition(p1) where c1 < 4000);

select /*+parallel(10)*/ sum(c1),min(c1),avg(c1),max(c1),count(c1) from (select distinct c1 from t1 partition (p1)) as a where not exists (select count(c1) from t1 partition(p1) where c1 < 4000);

select /*+parallel(10)*/ sum(c1),min(c1),avg(c1),max(c1),count(c1) from (select distinct c1 from t1 partition (p1)) as a where a.c1 like (select max(c1) from t1 partition(p1) where c1 < 4000);


--echo  #hash 分区
drop table  if exists t2;
create table t2(c1 int primary key auto_increment,c2 datetime not null,c3 timestamp not null default '2022-01-01',key index_c1_c2(c1,c2)) partition by hash(c1)
(partition p1,
partition p2,
partition p3
);

drop procedure if exists pro2;
DELIMITER //;
CREATE  PROCEDURE pro2(in i int,j int)
begin
    while i <= j DO
        insert into t2 values
        (i,makedate(2000,i),makedate(1980,i)),
        (i+1,makedate(2000,i+1),makedate(1980,i+1)),
        (i+2,makedate(2000,i+2),makedate(1980,i+2)),
        (i+3,makedate(2000,i+3),makedate(1980,i+3)),
        (i+4,makedate(2000,i+4),makedate(1980,i+4)),
        (i+5,makedate(2000,i+5),makedate(1980,i+5)),
        (i+6,makedate(2000,i+6),makedate(1980,i+6)),
        (i+7,makedate(2000,i+7),makedate(1980,i+7)),
        (i+8,makedate(2000,i+8),makedate(1980,i+8)),
        (i+9,makedate(2000,i+9),makedate(1980,i+9)),
        (i+10,makedate(2000,i+10),makedate(1980,i+10));
        set i = i + 11;
    end WHILE;
end
//
DELIMITER ;//
call pro2(1,20000);

select /*+parallel(10)*/ count(c1) from (select distinct c1 from t2) as a;
select /*+parallel(10)*/ count(c1) from (select distinct c1 from t2 partition (p1)) as a;
select /*+parallel(10)*/ max(c1) from (select distinct c1 from t2 partition (p1)) as a;
select /*+parallel(10)*/ avg(c1) from (select distinct c1 from t2 partition (p1)) as a;
select /*+parallel(10)*/ sum(c1) from (select distinct c1 from t2 partition (p1)) as a;
select /*+parallel(10)*/ min(c1) from (select distinct c1 from t2 partition (p1)) as a;
select /*+parallel(10)*/ sum(c1),min(c1),avg(c1),max(c1),count(c1) from (select distinct c1 from t2 partition (p1)) as a group by c1 having max(c1)>3000 order by c1 limit 5;

select /*+parallel(10)*/ count(c1) from (select distinct t2.c1 from t1 partition(p1),t2 partition(p1)) as a;
select /*+parallel(10)*/ max(c1) from (select distinct t2.c1 from t1 partition(p1),t2 partition(p1)) as a;
select /*+parallel(10)*/ min(c1) from (select distinct t2.c1 from t1 partition(p1),t2 partition(p1)) as a;
select /*+parallel(10)*/ sum(c1) from (select distinct t2.c1 from t1 partition(p1),t2 partition(p1)) as a;
select /*+parallel(10)*/ avg(c1) from (select distinct t2.c1 from t1 partition(p1),t2 partition(p1)) as a;
select /*+parallel(10)*/ sum(c1),min(c1),avg(c1),max(c1),count(c1) from (select distinct t2.c1 from t1 partition(p1),t2 partition(p1)) as a;

select /*+parallel(10)*/ count(c1) from (select distinct t2.c1 from t1 partition(p1) cross join t2 partition(p1)) as a;
select /*+parallel(10)*/ max(c1) from (select distinct t2.c1 from t1 partition(p1) cross join t2 partition(p1)) as a;
select /*+parallel(10)*/ min(c1) from (select distinct t2.c1 from t1 partition(p1) cross join t2 partition(p1)) as a;
select /*+parallel(10)*/ sum(c1) from (select distinct t2.c1 from t1 partition(p1) cross join t2 partition(p1)) as a;
select /*+parallel(10)*/ avg(c1) from (select distinct t2.c1 from t1 partition(p1) cross join t2 partition(p1)) as a;
select /*+parallel(10)*/ sum(c1),min(c1),avg(c1),max(c1),count(c1) from (select distinct t2.c1 from t1 partition(p1) cross join t2 partition(p1)) as a;

--echo  #结果为NULL
select /*+parallel(10)*/ count(c1) from (select distinct t2.c1 from t1 partition(p1) natural join t2 partition(p1)) as a;
select /*+parallel(10)*/ max(c1) from (select distinct t2.c1 from t1 partition(p1) natural join t2 partition(p1)) as a;
select /*+parallel(10)*/ min(c1) from (select distinct t2.c1 from t1 partition(p1) natural join t2 partition(p1)) as a;
select /*+parallel(10)*/ sum(c1) from (select distinct t2.c1 from t1 partition(p1) natural join t2 partition(p1)) as a;
select /*+parallel(10)*/ avg(c1) from (select distinct t2.c1 from t1 partition(p1) natural join t2 partition(p1)) as a;
select /*+parallel(10)*/ sum(c1),min(c1),avg(c1),max(c1),count(c1) from (select distinct t2.c1 from t1 partition(p1) natural join t2 partition(p1)) as a;



drop table if exists t3;
create table t3(c1 int not null,c2 double not null)
partition by list (c1)
(
partition p0 values in(1,2,3,4,5),
partition p1 values in(6,7,8,9,10),
partition p2 values in(11,12,13,14,15),
partition p3 values in(16,17,18,19,20)
);

drop procedure if exists pro3;
DELIMITER //;
CREATE  PROCEDURE pro3(in i int,j int)
begin
    while i <= j DO
    insert into t3 values(i,i*0.1);
  set i = i + 1;
    end WHILE;
end
//
DELIMITER ;//
call pro3(1,20);

select /*+parallel(10)*/ count(c1) from (select distinct c1 from t3) as a;
select /*+parallel(10)*/ count(c1) from (select distinct c1 from t3 partition (p1)) as a;
select /*+parallel(10)*/ max(c1) from (select distinct c1 from t3 partition (p1)) as a;
select /*+parallel(10)*/ avg(c1) from (select distinct c1 from t3 partition (p1)) as a;
select /*+parallel(10)*/ sum(c1) from (select distinct c1 from t3 partition (p1)) as a;
select /*+parallel(10)*/ min(c1) from (select distinct c1 from t3 partition (p1)) as a;
select /*+parallel(10)*/ sum(c1),min(c1),avg(c1),max(c1),count(c1) from (select distinct c1 from t3 partition (p1)) as a group by c1 having max(c1)>3000 order by c1 limit 5;


select /*+parallel(10)*/ count(c1) from (select distinct t3.c1 from t1 partition(p1),t3 partition(p1)) as a;
select /*+parallel(10)*/ max(c1) from (select distinct t3.c1 from t1 partition(p1),t3 partition(p1)) as a;
select /*+parallel(10)*/ min(c1) from (select distinct t3.c1 from t1 partition(p1),t3 partition(p1)) as a;
select /*+parallel(10)*/ sum(c1) from (select distinct t3.c1 from t1 partition(p1),t3 partition(p1)) as a;
select /*+parallel(10)*/ avg(c1) from (select distinct t3.c1 from t1 partition(p1),t3 partition(p1)) as a;
select /*+parallel(10)*/ sum(c1),min(c1),avg(c1),max(c1),count(c1) from (select distinct t3.c1 from t1 partition(p1),t3 partition(p1)) as a;


select /*+parallel(10)*/ count(c1) from (select distinct t3.c1 from t1 partition(p1) cross join t3 partition(p1)) as a;
select /*+parallel(10)*/ max(c1) from (select distinct t3.c1 from t1 partition(p1) cross join t3 partition(p1)) as a;
select /*+parallel(10)*/ min(c1) from (select distinct t3.c1 from t1 partition(p1) cross join t3 partition(p1)) as a;
select /*+parallel(10)*/ sum(c1) from (select distinct t3.c1 from t1 partition(p1) cross join t3 partition(p1)) as a;
select /*+parallel(10)*/ avg(c1) from (select distinct t3.c1 from t1 partition(p1) cross join t3 partition(p1)) as a;
select /*+parallel(10)*/ sum(c1),min(c1),avg(c1),max(c1),count(c1) from (select distinct t3.c1 from t1 partition(p1) cross join t3 partition(p1)) as a;


--echo  #key分区
drop table if exists t4;
create table t4(c1 year not null primary key , c2 datetime not null,index index_c1(c1))
partition by key(c1)
partitions 3;


drop procedure if exists pro4;
DELIMITER //;
CREATE  PROCEDURE pro4(in i int,j int)
begin
    while i <= j DO
        insert into t4 values(1969+i,makedate(1980,i));
        set i = i + 1;
    end WHILE;
end
//
DELIMITER ;//
call pro4(1,100);

select /*+parallel(10)*/ count(c1) from (select distinct c1 from t4) as a;
select /*+parallel(10)*/ count(c1) from (select distinct c1 from t4 partition (p1)) as a;
select /*+parallel(10)*/ max(c1) from (select distinct c1 from t4 partition (p1)) as a;
select /*+parallel(10)*/ avg(c1) from (select distinct c1 from t4 partition (p1)) as a;
select /*+parallel(10)*/ sum(c1) from (select distinct c1 from t4 partition (p1)) as a;
select /*+parallel(10)*/ min(c1) from (select distinct c1 from t4 partition (p1)) as a;
select /*+parallel(10)*/ sum(c1),min(c1),avg(c1),max(c1),count(c1) from (select distinct c1 from t4 partition (p1)) as a group by c1 having max(c1)>3000 order by c1 limit 5;


select /*+parallel(10)*/ count(c1) from (select distinct t4.c1 from t1 partition(p1),t4 partition(p1)) as a;
select /*+parallel(10)*/ max(c1) from (select distinct t4.c1 from t1 partition(p1),t4 partition(p1)) as a;
select /*+parallel(10)*/ min(c1) from (select distinct t4.c1 from t1 partition(p1),t4 partition(p1)) as a;
select /*+parallel(10)*/ sum(c1) from (select distinct t4.c1 from t1 partition(p1),t4 partition(p1)) as a;
select /*+parallel(10)*/ avg(c1) from (select distinct t4.c1 from t1 partition(p1),t4 partition(p1)) as a;
select /*+parallel(10)*/ sum(c1),min(c1),avg(c1),max(c1),count(c1) from (select distinct t4.c1 from t1 partition(p1),t4 partition(p1)) as a;


select /*+parallel(10)*/ count(c1) from (select distinct t4.c1 from t1 partition(p1) cross join t4 partition(p1)) as a;
select /*+parallel(10)*/ max(c1) from (select distinct t4.c1 from t1 partition(p1) cross join t4 partition(p1)) as a;
select /*+parallel(10)*/ min(c1) from (select distinct t4.c1 from t1 partition(p1) cross join t4 partition(p1)) as a;
select /*+parallel(10)*/ sum(c1) from (select distinct t4.c1 from t1 partition(p1) cross join t4 partition(p1)) as a;
select /*+parallel(10)*/ avg(c1) from (select distinct t4.c1 from t1 partition(p1) cross join t4 partition(p1)) as a;
select /*+parallel(10)*/ sum(c1),min(c1),avg(c1),max(c1),count(c1) from (select distinct t4.c1 from t1 partition(p1) cross join t4 partition(p1)) as a;

--enable_warnings

drop database db1;
