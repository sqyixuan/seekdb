--disable_warnings
drop database if exists db1;
create database db1;
use db1;


SET wait_timeout=30000000;
SET ob_trx_timeout = 200000000;
SET ob_query_timeout = 200000000;


drop table if exists t1;
create table t1(c1 int,c2 varchar(60),c3 decimal(10,2));
drop procedure if exists pro1;
DELIMITER //;
CREATE  PROCEDURE pro1(in i int,j int)
begin
    while i <= j DO
        insert into t1 values(i,concat("李",i),i*0.1);
        set i = i + 1;
    end WHILE;
end
//
DELIMITER ;//
call pro1(1,20000);
call pro1(50,1000);


drop   procedure if   exists   pro1;
delimiter //;
create procedure pro1(aa int,bb int)
begin
    if aa = bb then
         select /*+parallel(10)*/ count(distinct c1),max(distinct c1),min(distinct c1),sum(distinct c1),avg(distinct c1) from t1;
         select /*+parallel(10)*/ count(c1),max(c1),min(c1),sum(c1),avg(c1) from (select distinct c1 from t1) as a;
    elseif aa > bb then
         select /*+parallel(10)*/ count(distinct c3),max(distinct c3),min(distinct c3),sum(distinct c3),avg(distinct c3) from t1;
         select /*+parallel(10)*/ count(c3),max(c3),min(c3),sum(c3),avg(c3) from (select distinct c3 from t1) as a;
    else
         select /*+parallel(10)*/ max(c1),min(distinct c2),sum(c3),avg(c1),avg(c2) from t1;
         select /*+parallel(10)*/ max(c1),min(distinct c2),sum(c3),avg(c1),avg(c2) from (select distinct c1,c2,c3 from t1) as a;
    end if;
end
//
delimiter ;//
call pro1(1,1);
call pro1(2,1);
call pro1(0,1);




drop   procedure if   exists   pro1;
delimiter //;
create procedure pro1()
begin
    declare i int default 1;
    while i <= 10 do
        if mod(i,10) = 0 then
                select /*+parallel(10)*/ max(distinct c1),min(distinct c3),count(distinct c2) from t1 where c1 > 19992 group by c1 order by c1;
        elseif mod(i,8)=0 then

                select /*+parallel(10) */ case when c1/2 =0 then 1 else 0 end c1,sum(c3) from (select distinct c3,c2,c1 from t1) as a group by c2 order by c2 asc limit 10;
        elseif mod(i,7)=0 then
                select /*+parallel(10 )*/ case when c1 >10000 then 777 else 888 end c1,count(c2),max(c3) from (select distinct c1,c2,c3 from t1) as a group by c1 desc limit 1;
        elseif mod(i,5)=0 then
                with tl1 as (select /*+parallel(10)*/ max(distinct c1) c1,min(distinct c3) c3,count(distinct c2) c2 from t1  group by c1 having max(c1) > 19992) select max(c1) from (select distinct c1 from t1) order by c1;
        elseif mod(i,3)=0 then
                select /*+parallel(10)*/ count(c1) from (select distinct c1 from t1) as a where c1 in (select max(c1) from t1);
        else
                select /*+parallel(10)*/ max(c1) from (select distinct c1 from t1) as a where c1 < any (select avg(c1) from t1);
        end if;
        set i = i+1;
    end while;
end
//
delimiter ;//
call pro1();





drop   procedure if   exists   pro1;
delimiter //;
create procedure pro1()
begin
	Declare i int default 1;
	label:loop
         if mod(i,10) = 0 then
                select /*+parallel(10)*/ sum(distinct c3) from t1 where c3 >= all (select avg(c3) from t1);
                select /*+parallel(10)*/ sum(c3) from (select distinct c3 from t1) as a where c3 >= all(select avg(c3) from t1);
        elseif mod(i,8)=0 then
                select /*+parallel(10)*/ min(distinct c3) from t1 where exists (select avg(c3) from t1);
                select /*+parallel(10)*/ min(c3) from (select distinct c3 from t1) as a where exists (select avg(c3) from t1);
        elseif mod(i,7)=0 then
                select /*+parallel(10)*/ min(distinct c3) from t1 where not exists (select avg(c3) from t1);
                select /*+parallel(10)*/ min(c3) from (select distinct c3 from t1) as a where not exists (select avg(c3) from t1);
        elseif mod(i,5)=0 then
                select /*+parallel(10)*/ avg(distinct c1) from t1 where c1 != some (select max(c1) from t1);
                select /*+parallel(10)*/ avg(c1) from (select distinct c1 from t1) as a where c1 != some (select max(c1) from t1);
        elseif mod(i,3)=0 then
                select /*+parallel(10)*/ count(distinct c1) from t1 where c1 like (select max(c1) from t1);
                select /*+parallel(10)*/ count(c1) from (select distinct c1 from t1) as a where c1 like (select max(c1) from t1);
        else
                select /*+parallel(10) */ case when c1/2 =0 then 1 else 0 end c1,sum(c3) from (select distinct c3,c2,c1 from t1) as a group by c2 order by c2 asc limit 3;
        end if;
	set i = i + 1;
	if i>=10 then leave label;
	end if;
	end loop label;
end
//
delimiter ;//
call pro1();



drop   procedure if   exists   pro1;
delimiter //;
create procedure pro1(aa int,bb int)
begin
    if aa = bb then
            update t1 set c3 = 1.11111 where c3 = (select /*+parallel(10)*/ min(c3) from (select distinct c3 from t1) as a where c3 <= (select avg(c3) from t1));
    elseif aa > bb then
            update t1 set c1 = 101 where c1 = (select /*+parallel(10)*/ max(c1) from (select distinct c1 from t1) as a where c1 < (select avg(c1) from t1));
    else
            update t1 set c1 = 102 where c1 = (select /*+parallel(10)*/ count(c1) from (select distinct c1 from t1) as a where c1 in (select max(c1) from t1));
    end if;
end
//
delimiter ;//
call pro1(1,1);
call pro1(2,1);
call pro1(0,1);




drop   procedure if   exists   pro1;
delimiter //;
create procedure pro1()
begin
	Declare i int default 1;
	label:loop
         if mod(i,10) = 0 then
                delete from t1 where c1 = (select /*+parallel(10)*/ count(c1) from (select distinct c1 from t1) as a where c1 <> (select min(c1) from t1));
        elseif mod(i,8)=0 then
                delete from t1 where c3 = (select /*+parallel(10)*/ sum(c3) from (select distinct c3 from t1) as a where c3 >= all(select avg(c3) from t1));
        elseif mod(i,5)=0 then
                delete from t1 where c1 = (select /*+parallel(10)*/ count(c1) from (select distinct c1 from t1) as a where c1 like (select max(c1) from t1));
        elseif mod(i,3)=0 then
                delete from t1 where c3 = (select /*+parallel(10)*/ min(c3) from (select distinct c3 from t1) as a where c3 <= (select avg(c3) from t1));
        else
                delete from t1 where c1 = (select /*+parallel(10)*/ avg(c1) from (select distinct c1 from t1) as a where c1 != (select max(c1) from t1));
        end if;
	set i = i + 1;
	if i>=10 then leave label;
	end if;
	end loop label;
end
//
delimiter ;//
call pro1();





drop   procedure if   exists   pro1;
delimiter //;
create procedure pro1(aa int,bb int)
begin
Declare i int default 1;
repeat
    if aa = bb then
            insert into t1 select /*+parallel(10)*/ count(c1),max(c2),min(c3) from (select distinct c1,c2,c3 from t1) as a;
            insert into t1 select /*+parallel(10)*/ c1,c2,min(c3) from (select distinct c3,c1,c2 from t1) as a where c3 <= (select avg(c3) from t1);
    elseif aa > bb then
            insert into t1 select /*+parallel(10)*/ count(c1),c2,c3 from (select distinct c1,c2,c3 from t1) as a where c1 <> (select min(c1) from t1);
    else
            insert into t1 select /*+parallel(10)*/ c1,c2,sum(c3) from (select distinct c3,c1,c2 from t1) as a where c3 >= all(select avg(c3) from t1);
    end if;
set i = i+1;
until i>=2
end repeat;
end
//
delimiter ;//
call pro1(1,1);
call pro1(1,0);
call pro1(0,1);


--echo  #function

drop function if exists func1;
delimiter //;
create function func1() returns int
begin
declare i int default 1;
    while i <= 10 do
        if mod(i,10) = 0 then
            insert into t1 select /*+parallel(10)*/ count(c1),max(c2),min(c3) from (select distinct c1,c2,c3 from t1) as a;
        elseif mod(i,8)=0 then
            insert into t1 select /*+parallel(10)*/ c1,c2,min(c3) from (select distinct c3,c1,c2 from t1) as a where c3 <= (select avg(c3) from t1);
        elseif mod(i,7)=0 then
            insert into t1 select /*+parallel(10)*/ count(c1),c2,c3 from (select distinct c1,c2,c3 from t1) as a where c1 <> (select min(c1) from t1);
        elseif mod(i,5)=0 then
            insert into t1 select /*+parallel(10)*/ c1,c2,sum(c3) from (select distinct c3,c1,c2 from t1) as a where c3 >= all(select avg(c3) from t1);
        elseif mod(i,3)=0 then
            insert into t1 select /*+parallel(10)*/ count(c1),max(c2),c3 from (select distinct * from t1) as a where a.c1 > 19992 group by a.c1 limit 1;
        else
            insert into t1 select /*+parallel(10)*/ sum(c1),min(c2),avg(c3) from (select distinct * from t1)as a;
        end if;
        set i = i+1;
    end while;
    return 1;
end
//
delimiter ;//
select func1();


drop function if exists func1;
delimiter //;
create function func1() returns int
begin
declare i int default 1;
    while i <= 10 do
        if mod(i,10) = 0 then
              delete from t1 where c1 = (select /*+parallel(10)*/ count(c1) from (select distinct c1 from t1) as a where c1 <> (select min(c1) from t1));
        elseif mod(i,8)=0 then
              delete from t1 where c3 = (select /*+parallel(10)*/ sum(c3) from (select distinct c3 from t1) as a where c3 >= all(select avg(c3) from t1));
        elseif mod(i,5)=0 then
              delete from t1 where c1 = (select /*+parallel(10)*/ count(c1) from (select distinct c1 from t1) as a where c1 like (select max(c1) from t1));
        elseif mod(i,3)=0 then
              delete from t1 where c3 = (select /*+parallel(10)*/ min(c3) from (select distinct c3 from t1) as a where c3 <= (select avg(c3) from t1));
        else
              delete from t1 where c1 = (select /*+parallel(10)*/ avg(c1) from (select distinct c1 from t1) as a where c1 != (select max(c1) from t1));
        end if;
        set i = i+1;
    end while;
    return 1;
end
//
delimiter ;//
select func1();


drop function if exists func1;
delimiter //;
create function func1() returns int
begin
declare i int default 1;
    while i <= 10 do
        if mod(i,10) = 0 then
            update t1 set c3 = 1.11111 where c3 = (select /*+parallel(10)*/ min(c3) from (select distinct c3 from t1) as a where c3 <= (select avg(c3) from t1));
        elseif mod(i,8)=0 then
            update t1 set c1 = 101 where c1 = (select /*+parallel(10)*/ max(c1) from (select distinct c1 from t1) as a where c1 < (select avg(c1) from t1));
        elseif mod(i,5)=0 then
            update t1 set c1 = 102 where c1 = (select /*+parallel(10)*/ count(c1) from (select distinct c1 from t1) as a where c1 in (select max(c1) from t1));
        else
              delete from t1 where c1 = (select /*+parallel(10)*/ avg(c1) from (select distinct c1 from t1) as a where c1 != (select max(c1) from t1));
        end if;
        set i = i+1;
    end while;
    return 1;
end
//
delimiter ;//
select func1();

--enable_warnings

drop database db1;
