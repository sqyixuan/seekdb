drop table ex_t2;
create external table ex_t2(
a1 VARCHAR(50) as (metadata$filecol9)
)
format (type = 'csv') location 'mysqltest_data_for_external_table3/data/external_data2_orc/'
PATTERN = "000000_0$";
SELECT * from ex_t2;
+------+
| a1   |
+------+
| NULL |
| NULL |
| NULL |
| NULL |
| NULL |
| NULL |
| NULL |
+------+
drop table ex_t2;
create external table ex_t2(
a1 VARCHAR(50) as (metadata$filecol9)
)
format (
    type = 'csv'
    FIELD_DELIMITER = ','
	FIELD_OPTIONALLY_ENCLOSED_BY = char(34)
	ENCODING = 'UTF8MB4'
	SKIP_HEADER = 0
	EMPTY_FIELD_AS_NULL = true) location 'mysqltest_data_for_external_table3/data/external_data2_orc/'
PATTERN = "000000_0$";
SELECT * from ex_t2;
+------+
| a1   |
+------+
| NULL |
| NULL |
| NULL |
| NULL |
| NULL |
| NULL |
| NULL |
+------+
drop table ex_t2;
create external table ex_t2(
a1 VARCHAR(50) as (get_path(external$filerow, 'c9'))
)
format (
    type = 'orc'
    FIELD_DELIMITER = ','
	FIELD_OPTIONALLY_ENCLOSED_BY = char(34)
	ENCODING = 'BINARY'
	SKIP_HEADER = 0
	EMPTY_FIELD_AS_NULL = true) location 'mysqltest_data_for_external_table3/data/external_data3_orc/'
PATTERN = "^(?!.*\.crc$).*$";
SELECT * from ex_t2;
+------------------+
| a1               |
+------------------+
|                  |
| 1234567891       |
| 12345678912      |
| ~!@#$%^&*)       |
| _+{|:"<?,.       |
| 中すāд￥壹       |
| NULL             |
+------------------+
####location
##null
drop table ex_t2;
create external table ex_t2(
a1 TINYINT as (get_path(external$filerow, 'c1'))
)
format (type = 'orc') location ''
PATTERN = "000000_0$";
ERROR HY000: Directory not exist
drop table ex_t2;
create external table ex_t2(
a1 TINYINT as (get_path(external$filerow, 'c1'))
)
format (type = 'orc') location 'NULL'
PATTERN = "000000_0$";
SELECT * from ex_t2;
+------+
| a1   |
+------+
+------+
