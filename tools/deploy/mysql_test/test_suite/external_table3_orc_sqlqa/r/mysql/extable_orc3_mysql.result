result_format: 4
####测试create external TABLE 其他的表属性(orc)####
create external table ex_t1(
a1 TINYINT as (get_path(external$filerow, 'c1')),
b2 SMALLINT as (get_path(external$filerow, 'c2')),
c3 INT as (get_path(external$filerow, 'c3')),
d4 BIGINT as (get_path(external$filerow, 'c4')),
e5 FLOAT as (get_path(external$filerow, 'c5')),
f6 DOUBLE as (get_path(external$filerow, 'c6')),
g7 DECIMAL(10,2) as (get_path(external$filerow, 'c7')),
h8 BOOLEAN as (get_path(external$filerow, 'c8')),
i9 VARCHAR(50) as (get_path(external$filerow, 'c9')),
j10 VARCHAR(50) as (get_path(external$filerow, 'c10')),
k11 CHAR(100) as (get_path(external$filerow, 'c11')),
l12 VARBINARY(50) as (get_path(external$filerow, 'c12')),
m13 TIMESTAMP as (get_path(external$filerow, 'c13')),
n14 DATE as (get_path(external$filerow, 'c14'))
)
format (type = 'orc') location 'mysqltest_data_for_external_table3/data/external_data2_orc/'
PATTERN = "000000_0$";
SELECT * from ex_t1;
+------+------+-------+--------+-------+-------+---------+------+---------+----------+-------+---------+---------------------+------------+
| a1   | b2   | c3    | d4     | e5    | f6    | g7      | h8   | i9      | j10      | k11   | l12     | m13                 | n14        |
+------+------+-------+--------+-------+-------+---------+------+---------+----------+-------+---------+---------------------+------------+
|    1 |  101 |  1001 |  10001 |  10.1 |  20.2 |  123.46 |    1 | string1 | varchar1 | char1 | binary1 | 2021-01-01 00:00:01 | 2021-01-01 |
|   -2 | -102 | -1002 | -10002 | -10.2 | -20.3 | -456.79 |    0 | string2 | varchar2 | char2 | binary2 | 2021-01-02 00:00:02 | 2021-01-02 |
|    3 |  103 |  1003 |  10003 |  10.3 |  20.4 |  789.01 |    1 | string3 | varchar3 | char3 | binary3 | 2021-01-03 00:00:03 | 2021-01-03 |
|   -4 | -104 | -1004 | -10004 | -10.4 | -20.5 |  -12.35 |    0 | string4 | varchar4 | char4 | binary4 | 2021-01-04 00:00:04 | 2021-01-04 |
|    5 |  105 |  1005 |  10005 |  10.5 |  20.6 |  345.68 |    1 | string5 | varchar5 | char5 | binary5 | 2021-01-05 00:00:05 | 2021-01-05 |
| NULL | NULL |  NULL |   NULL |  NULL |  NULL |    NULL | NULL | NULL    | NULL     | NULL  | NULL    | NULL                | NULL       |
