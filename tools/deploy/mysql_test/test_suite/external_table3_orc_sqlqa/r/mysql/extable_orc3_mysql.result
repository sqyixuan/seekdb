####函数嵌套外表的伪列
####not support
create external table ex_t2(
a1 TINYINT as (LOWER(get_path(external$filerow, 'c1')))
)
format (type = 'orc') location 'mysqltest_data_for_external_table3/data/external_data2_orc/'
PATTERN = "000000_0$";
SELECT * from ex_t2;
ERROR HY000: not supported for generated columns
drop table ex_t2;
create external table ex_t2(
a1 TINYINT as (ABS(get_path(external$filerow, 'c1')))
)
format (type = 'orc') location 'mysqltest_data_for_external_table3/data/external_data2_orc/'
PATTERN = "000000_0$";
SELECT * from ex_t2;
ERROR HY000: not supported for generated columns
####colname
drop table ex_t2;
create external table ex_t2(
a1 TINYINT as (get_path(external$filerow, NULL))
)
format (type = 'orc') location 'mysqltest_data_for_external_table3/data/external_data2_orc/'
PATTERN = "000000_0$";
SELECT * from ex_t2;
ERROR 0A000: Not supported feature or function
drop table ex_t2;
create external table ex_t2(
a1 TINYINT as (get_path(external$filerow, ''))
)
format (type = 'orc') location 'mysqltest_data_for_external_table3/data/external_data2_orc/'
PATTERN = "000000_0$";
SELECT * from ex_t2;
ERROR HY000: missing access path for external table
drop table ex_t2;
create external table ex_t2(
a1 TINYINT as (get_path(external$filerow, 'cc1'))
)
format (type = 'orc') location 'mysqltest_data_for_external_table3/data/external_data2_orc/'
PATTERN = "000000_0$";
SELECT * from ex_t2;
ERROR HY000: fair to read orc file, message: Invalid column selected cc1. Valid names are c1, c10, c11, c12, c13, c14, c2, c3, c4, c5, c6, c7, c8, c9
####format
##csv外表读orc文件报1210
drop table ex_t2;
create external table ex_t2(
a1 VARCHAR(50) as (get_path(external$filerow, 'c9'))
)
format (type = 'csv') location 'mysqltest_data_for_external_table3/data/external_data2_orc/'
PATTERN = "000000_0$";
SELECT * from ex_t2;
ERROR HY000: Invalid argument
drop table ex_t2;
create external table ex_t2(
a1 VARCHAR(50) as (metadata$filecol1)
)
format (type = 'csv') location 'mysqltest_data_for_external_table3/data/external_data2_orc/'
PATTERN = "000000_0$";
SELECT * from ex_t2;
