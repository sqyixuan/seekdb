# owner: mingye.swj
# owner group: 技术部-SQL-优化器
# tags: external_table
# description: test create external table

--result_format 4
--source mysql_test/test_suite/external_table3_orc_sqlqa/include/copy_data_for_external_table.inc

connection default;
--disable_query_log
--error 0,1051
drop table ex_t1;
--error 0,1051
drop table ex_t2;
--enable_query_log

####不同hive表属性场景
####create as SELECT
create external table ex_t1(
a1 TINYINT as (get_path(external$filerow, 'c1')),
b2 SMALLINT as (get_path(external$filerow, 'c2')),
c3 INT as (get_path(external$filerow, 'c3')),
d4 BIGINT as (get_path(external$filerow, 'c4')),
e5 FLOAT as (get_path(external$filerow, 'c5')),
f6 DOUBLE as (get_path(external$filerow, 'c6')),
g7 DECIMAL(10,2) as (get_path(external$filerow, 'c7')),
h8 BOOLEAN as (get_path(external$filerow, 'c8')),
i9 VARCHAR(50) as (get_path(external$filerow, 'c9')),
j10 VARCHAR(50) as (get_path(external$filerow, 'c10')),
k11 CHAR(100) as (get_path(external$filerow, 'c11')),
l12 VARBINARY(50) as (get_path(external$filerow, 'c12')),
m13 TIMESTAMP as (get_path(external$filerow, 'c13')),
n14 DATE as (get_path(external$filerow, 'c14'))
)
format (type = 'orc') location 'mysqltest_data_for_external_table3/data/external_data4_orc/'
PATTERN = "000000_0$";

SELECT * from ex_t1;


####PARTITIONED BY
create external table ex_t2(
b VARCHAR(50) as (get_path(external$filerow, 'c2')),
c DATE as (get_path(external$filerow, 'c3'))
)
format (type = 'orc') location 'mysqltest_data_for_external_table3/data/external_data5_orc/'
PATTERN = "000000_0$";

SELECT * from ex_t2;


