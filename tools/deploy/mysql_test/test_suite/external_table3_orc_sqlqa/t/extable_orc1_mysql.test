# description: test create external table

--result_format 4
--source mysql_test/test_suite/external_table3_orc_sqlqa/include/copy_data_for_external_table.inc

connection default;
--disable_query_log
--error 0,1051
drop table ex_t1;
--error 0,1051
drop table ex_t2;
--enable_query_log

##手动测试后修改文件路径


####basic test####
create external table ex_t1(
c1 bigint  as (get_path(external$filerow, 'c1')),
c2 bigint  as (get_path(external$filerow, 'c2')),
c3 varchar(50) as (get_path(external$filerow, 'c3')),
c4 DATE as (get_path(external$filerow, 'c4'))
)
format (type = 'orc') location 'mysqltest_data_for_external_table3/data/external_data1_orc/'
PATTERN = "000000_0$";

SELECT * from ex_t1;

####parquet外表读orc文件报11018
--error 0,1051
drop table ex_t1;
create external table ex_t1(
c1 bigint  as (get_path(external$filerow, 'c1')),
c2 bigint  as (get_path(external$filerow, 'c2')),
c3 varchar(50) as (get_path(external$filerow, 'c3')),
c4 DATE as (get_path(external$filerow, 'c4'))
)
format (type = 'PARQUET') location 'mysqltest_data_for_external_table3/data/external_data1_orc/'
PATTERN = "000000_0$";
--error 11018
SELECT * from ex_t1;

####datatype####
##UNSIGNED属性预期报错
##INT32(INTEGER(8,true)
--error 0,1051
drop table ex_t1;

create external table ex_t1(
c1 TINYINT UNSIGNED as (get_path(external$filerow, 'c1')),
c2 TINYINT as (get_path(external$filerow, 'c1'))
)
format (type = 'orc') location 'mysqltest_data_for_external_table3/data/external_data2_orc/'
PATTERN = "000000_0$";
--error 5083
SELECT * from ex_t1;


