--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: xiaoyi.xy
#owner group : sql2

#update、insert时当列不存在报错信息不正确。
--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1(c1 int, c2 int);
--error 1054
update t1 set t.i=i+(SELECT MAX(i) FROM (SELECT 1) t);

--error 1054
update t1 set i = 1;

--error 1054
insert into t1 (t1.c) values(1);

--error 1054
insert into t1 (c) values(1);
drop table t1;

create table t1(c1 varchar(100) collate gbk_bin);
--error 1366
insert into t1 values('𐐀');
insert ignore t1 values('𐐀');
insert ignore t1 values('𐐀中𐐀国£');
select * from t1;

drop table t1;
