--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: yuchen.wyc
#owner group: sql2
#description:本case是为了测试指定索引更新主键列
connect (my_obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection default;
set ob_enable_index_direct_select=1;
use test;
--disable_warnings
drop table if exists t1;
--enable_warnings
--source mysql_test/include/index_quick_major.inc

create table t1 (pk int primary key, key1 int, key2 int, v1 varchar(20));
create index i1 on t1(key1) storing(v1);
create index i2 on t1(key2) storing(pk);
connection my_obsys;
let $database_id = query_get_value(select database_id from oceanbase.__all_virtual_database where tenant_id = (select tenant_id from oceanbase.__all_tenant where tenant_name = 'sys') and database_name = 'test', database_id, 1);
let $t1_id = query_get_value(select table_id from oceanbase.__all_virtual_table where tenant_id = (select tenant_id from oceanbase.__all_tenant where tenant_name = 'sys') and table_name = 't1' and database_id = $database_id, table_id, 1);
let $idx1 = query_get_value(select table_name from oceanbase.__all_virtual_table where tenant_id = (select tenant_id from oceanbase.__all_tenant where tenant_name = 'sys') and data_table_id = $t1_id, table_name, 1);
let $idx2 = query_get_value(select table_name from oceanbase.__all_virtual_table where tenant_id = (select tenant_id from oceanbase.__all_tenant where tenant_name = 'sys') and data_table_id = $t1_id, table_name, 2);
connection default;

--source mysql_test/include/check_all_idx_ok.inc

insert into t1 values(1,1,1,'a'),(2,1,1,'b'),(3,2,2,'c'),(4,3,3,'d');

##指定索引列更新主键列
#单行更新
--error 1062
update t1 set pk=5 where key1=1;
update t1 set pk=6 where key1=2;
--error 1062
update t1 set pk=7 where key2=1;
--disable_query_log
eval update /*index($idx1)*/ t1 set pk=8 where key2=2;
--enable_query_log
update t1 set pk=9,v1='e' where key1=3;
--disable_query_log
eval select * from $idx1;
eval select * from $idx2;
--enable_query_log

select * from t1 where pk<10;

#范围更新
replace into t1 values(11,11,11,'a'),(12,11,11,'b'),(13,12,12,'c'),(14,13,13,'d');
update t1 set pk=15 where key1>11 and key1<13;
--error 1062
update t1 set pk=16 where key1>=11 and key1<13;
update t1 set pk=17 where key2>11 and key2<13;
--error 1062
update t1 set pk=18 where key2>=11 and key2<13;
update t1 set pk=19,v1='e' where key1>11 and key1<13;
--disable_query_log
eval select * from $idx1;
eval select * from $idx2;
--enable_query_log
select * from t1 where pk>10;

##指定索引列更新索引列
#单行更新
replace into t1 values(21,21,21,'a'),(22,21,21,'b'),(23,22,22,'c'),(24,23,23,'d');
update t1 set key1=25 where key1=21;
update t1 set key1=26 where key1=22;
update t1 set key1=26,v1='e' where key1=23;
update t1 set key1=25 where key1=26;
--disable_query_log
eval select * from $idx1;
eval select * from $idx2;
--enable_query_log
select * from t1 where pk>20;

#范围更新
replace into t1 values(31,31,31,'a'),(32,31,31,'b'),(33,32,32,'c'),(34,33,33,'d');
update t1 set key1=35 where key1>31 and key1<33;
update t1 set key1=36 where key1>=31 and key1<33;
update t1 set key1=36,v1='e' where key1>=33 and key1<35;
update t1 set key1=35 where key1>35 and key1<37;
--disable_query_log
eval select * from $idx1;
eval select * from $idx2;
--enable_query_log
select * from t1 where pk>30;

##指定索引列更新主键列和索引列
#单行更新
replace into t1 values(41,41,41,'a'),(42,41,41,'b'),(43,42,42,'c'),(44,43,43,'d');
--error 1062
update t1 set pk=45,key1=45 where key1=41;
update t1 set pk=46,key1=46 where key1=42;
--error 1062
update t1 set pk=47,key2=45 where key2=41;
update t1 set pk=48,key2=46 where key2=42;
--disable_query_log
eval select * from $idx1;
eval select * from $idx2;
--enable_query_log
select * from t1 where pk>40;

#范围更新
replace into t1 values(51,51,51,'a'),(52,51,51,'b'),(53,52,52,'c'),(54,53,53,'d');
--error 1062
update t1 set pk=55,key1=55 where key1>=51 and key1<52;
--error 1062
update t1 set pk=56,key1=56 where key1>=51 and key1<53;
update t1 set pk=56,key1=56,v1='e' where key1>=53 and key1<55;
update t1 set pk=56,key1=55 where key1>55 and key1<57;
--disable_query_log
eval select * from $idx1;
eval select * from $idx2;
--enable_query_log
select * from t1 where pk>50;

##指定主键列更新索引列
#单行更新
replace into t1 values(61,61,61,'a'),(62,61,61,'b'),(63,62,62,'c'),(64,63,63,'d');
update t1 set key1=62 where pk=62;
update t1 set key1=61 where pk=62;
update t1 set key2=62,v1='b' where pk=61;
--disable_query_log
eval select * from $idx1;
eval select * from $idx2;
--enable_query_log
select * from t1 where pk>60;

#范围更新
replace into t1 values(71,71,71,'a'),(72,71,71,'b'),(73,72,72,'c'),(74,73,73,'d');
update t1 set key1=62 where pk>=61 and pk<63;
update t1 set key1=63 where pk>62 and pk<64;
update t1 set key1=65 where pk>=64 and pk<66;
update t1 set key1=66,v1='e' where pk>=64 and pk<66;
--disable_query_log
eval select * from $idx1;
eval select * from $idx2;
--enable_query_log
select * from t1 where pk>70;

##指定主键列更新索引列和主键列
#单行更新
replace into t1 values(81,81,81,'a'),(82,81,81,'b'),(83,82,82,'c'),(84,83,83,'d');
update t1 set pk=85,key1=82 where pk=82;
update t1 set pk=82,key1=81 where pk=85;
update t1 set pk=85,key2=83 where pk=84;
--disable_query_log
eval select * from $idx1;
eval select * from $idx2;
--enable_query_log
select * from t1 where pk>80;

#范围更新
replace into t1 values(91,91,91,'a'),(92,91,91,'b'),(93,92,92,'c'),(94,93,93,'d');
update t1 set pk=95,key1=94 where pk>=94 and pk<96;
--error 1062
update t1 set pk=96,key1=91 where pk>91 and pk<94;
--error 1062
update t1 set pk=97,key1=97 where pk>=91 and pk<93;
--disable_query_log
eval select * from $idx1;
eval select * from $idx2;
--enable_query_log
select * from t1 where pk>90;

#trx1
delete from t1 where pk<100;
insert into t1 values(1,1,1,'a'),(2,1,1,'b'),(3,2,2,'c'),(4,3,3,'d');
connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn2,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn1;
set autocommit=0;
update t1 set pk=5,key1=5 where pk=1;
select * from t1;
update t1 set v1='aa' where pk=5;
commit;
select * from t1;
--disable_query_log
set ob_enable_index_direct_select = 1;
eval select * from $idx1;
eval select * from $idx2;
--enable_query_log


#trx2
delete from t1 where pk<100;
insert into t1 values(1,1,1,'a'),(2,1,1,'b'),(3,2,2,'c'),(4,3,3,'d');
connection conn1;
set autocommit=0;
update t1 set pk=5,key1=5 where pk=1;
select * from t1;
update t1 set v1='aa' where pk=5;
rollback;
select * from t1;
--disable_query_log
eval select * from $idx1;
eval select * from $idx2;
--enable_query_log


#trx3
delete from t1 where pk<100;
insert into t1 values(1,1,1,'a'),(2,1,1,'b'),(3,2,2,'c'),(4,3,3,'d');
connection conn1;
set autocommit=0;
send update t1 set pk=5,key1=5 where pk=1;

connection conn2;
set autocommit=0;
send update t1 set v1='aaa' where pk=1;

connection conn1;
reap;
commit;

connection conn2;
reap;
update t1 set v1='aaa' where pk=5;
commit;

select * from t1; 
--disable_query_log
set ob_enable_index_direct_select = 1;
eval select * from $idx1;
eval select * from $idx2;
--enable_query_log

#trx4
delete from t1 where pk<100;
insert into t1 values(1,1,1,'a'),(2,1,1,'b'),(3,2,2,'c'),(4,3,3,'d');
commit;

connection conn1;
set autocommit=0;
send update t1 set pk=5,key1=5 where pk=1;

connection conn2;
set autocommit=0;
sleep 1;
send update t1 set v1='aaa' where pk=1;

connection conn1;
reap;
rollback;

connection conn2;
reap;
update t1 set v1='aaa' where pk=1;
commit;

select * from t1;
--disable_query_log
eval select * from $idx1;
eval select * from $idx2;
--enable_query_log
set ob_enable_index_direct_select=0;
