--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: yibo.tyf
#owner group: sql1
# tags: dml,optimizer

--disable_warnings
drop table if EXISTS test1,test2;
--enable_warnings

create table test1(h1 int PRIMARY key AUTO_INCREMENT,h2 varchar(20) not null,h3 FLOAT not null,h4 date not null,h5 char(20) not null);
create table test2(h1 int PRIMARY key AUTO_INCREMENT,h2 varchar(20) not null,h3 FLOAT not null,h4 date not null,h5 char(20) not null);
insert into test1(h2,h3,h4,h5) values('xiaowang',60.5,'2022-05-01','一组');
insert into test1(h2,h3,h4,h5) values('xiaolizi',65.420,'2022-06-16','二组');
insert into test2(h2,h3,h4,h5) values('zhaoyun',107,'2023-10-01','一组');
insert into test2(h2,h3,h4,h5) values('akeyashi',65.420,'2022-01-01','二组');
select * from test1 full join test2 on test1.h1=test2.h1;

--explain_protocol 2
UPDATE test1 full join  test2 ON test1.h3=null set test1.h2='null' where test2.h2=( select * from (select DISTINCT(test2.h2) from test2 order by test2.h3 asc LIMIT 1 ) as test2);
UPDATE test1 full join  test2 ON test1.h3=null set test1.h2='null' where test2.h2='akeyashi';

drop table test1,test2;