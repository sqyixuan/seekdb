--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: laibingzheng.lbz
# owner group: IMF
# description: foobar
# tags: dml
#
# test of heap_table update part_key
#

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
alter system set _enable_defensive_check = 2;
sleep 2;
connection default;

--disable_warnings
drop table if exists t1;
--enable_warnings
--result_format 4

set @@binlog_row_image = 'MINIMAL';
# 基本测试, 更新主键，记录完整列
CREATE TABLE t1(c1 INTEGER UNSIGNED NOT NULL AUTO_INCREMENT PRIMARY KEY, c2 INTEGER NULL, c3 TINYINT, c4 SMALLINT);
create unique index i12 on t1(c3) storing(c2, c4);
insert into t1 (c1, c2) values (7, 100);
update t1 set c1 = c1 * 10;
CREATE INDEX test_index on t1 (c2, c3);
update t1 set c3 = 3; 

drop table if exists t1;
set @@binlog_row_image = 'FULL';

connection obsys;
alter system set _enable_defensive_check = 0;
connection default;
