drop table if exists t1,t2;
result_format: 4
create table t1(c1 int, c2 int, c3 int);
insert into t1 values(1,1,1),(2,2,2),(3,3,3),(5,5,5);
create table t2(c1 int, c2 int, c3 int) partition by hash(c2) partitions 3;
insert into t2 values(2,2,2),(3,3,3),(4,4,4);
update t1 left join t2 on t1.c1=t2.c1 set t2.c2=t2.c2+1;
select * from t2 order by c1;
+------+------+------+
| c1   | c2   | c3   |
+------+------+------+
|    2 |    3 |    2 |
|    3 |    4 |    3 |
|    4 |    4 |    4 |
+------+------+------+
drop table t2;
drop table t1;
