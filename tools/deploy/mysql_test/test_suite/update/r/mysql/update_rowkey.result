drop table if exists t1;
create table t1 (c1 int, c2 int, c3 int, primary key(c1, c2)) partition by hash(c1) partitions 4;
create index t1_idx_01 on t1(c3) global;
insert into t1 values(1,1,1),(2,2,2),(3,3,3),(4,4,4),(5,5,5);
alter system minor freeze;
update t1 set c2 = c2+1, c3 = c3 + 1;
alter system minor freeze;
update t1 set c1 = c1 + 1;
alter system minor freeze;
update t1 set c2 = c2 + 1;
alter system minor freeze;
update t1 set c3 = c3 + 1;
select /*+index(t1 primary)*/ c1 from t1 order by c1;
