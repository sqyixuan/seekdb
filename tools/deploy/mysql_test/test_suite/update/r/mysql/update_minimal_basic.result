create table t7(c1 int, c2 datetime, c3 timestamp(6) not null default '2012-10-12', c4 timestamp DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP, c5 int, primary key(c1));
