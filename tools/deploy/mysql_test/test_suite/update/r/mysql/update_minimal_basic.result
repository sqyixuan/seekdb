create table t13(c1 int, c2 int, c3 int, c4 int , primary key(c1, c2)) partition by hash(c1) partitions 4;
create unique index t13_idx_01 on t13(c3) global;
insert into t13(c1, c2,c3,c4) values(1,1,null,1),(2,2,2,2),(3,3,3,3);
update t13 set c1 = 11  where c2 = 1;

drop table if exists t1,t2,t3,t4,t5,t6,t7,t8,t9, t10, t11, t12, t13;
