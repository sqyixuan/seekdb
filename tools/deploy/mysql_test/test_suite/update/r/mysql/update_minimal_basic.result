create table t9(c1 int, c2 int, c3 int, c4 int not null, c5 int as (c1 + c2) not null, c6 int) partition by hash(c5) partitions 4;
create unique index t9_idx_01 on t9(c4, c5) global;
insert into t9(c1,c2,c3,c4, c6) values(1,2,3,4, 44),(5,6,7,8,88),(9,10,11,12,122),(13,14,15,16,166),(17,18,19,20,200);
update t9 set c3 = c3 + 100 where c2 < 10;
select * from t9 order by c1;
