drop table if exists t1;
drop table if exists t2;
create TABLE t1(c1 int, c2 int, c3 int as (c1+c2)) partition by hash(c3) partitions 2;
alter table t1 add constraint check_cst12 check(c1 > c2);
create index t1_idx3 on t1 (c3) partition by hash(c3) partitions 2;
INSERT INTO t1 (c2) VALUES (25), (26);
insert into t1(c1) values(65535.4);
select * from t1;
c1	c2	c3
NULL	25	NULL
NULL	26	NULL
65535	NULL	NULL
update t1 set c1 = 5 where c1 in (select max(c1) FROM t1 );
select * from t1;
c1	c2	c3
NULL	25	NULL
NULL	26	NULL
5	NULL	NULL
drop table t1;
