#
# BUG#57373: Multi update+InnoDB reports ER_KEY_NOT_FOUND if a
#            table is updated twice
#
drop table if exists t1;
CREATE TABLE t1(
pk INT,
a INT,
b INT,
PRIMARY KEY (pk)
);
INSERT INTO t1 VALUES (0,0,0);
SELECT * FROM t1;
pk	a	b
0	0	0
drop table if exists v1;
drop view if exists v1;
CREATE VIEW v1 AS SELECT * FROM t1;
SELECT * FROM t1;
pk	a	b
0	0	0
# Should be (0,1,2)
SELECT * FROM t1;
pk	a	b
0	0	0
DROP VIEW v1;
DROP TABLE t1;
#
# BUG#11882110: UPDATE REPORTS ER_KEY_NOT_FOUND IF TABLE IS 
#               UPDATED TWICE
#
drop table if exists t1, t2;
CREATE TABLE t1 ( 
col_int_key int, 
pk int, 
col_int int, 
key(col_int_key), 
primary key (pk)
);
INSERT INTO t1 VALUES (1,2,3);

CREATE TABLE t2 ( 
col_int_key int, 
pk_1 int, 
pk_2 int, 
col_int int, 
key(col_int_key), 
primary key (pk_1,pk_2)
);
INSERT INTO t2 VALUES (1,2,3,4);

UPDATE t1 AS A JOIN t1 B SET A.pk=5,B.pk=7;
ERROR 0A000: multiple aliases to same table not supported

SELECT * FROM t1;
col_int_key	pk	col_int
1	2	3

UPDATE t2 AS A JOIN t2 B SET A.pk_1=5,B.pk_1=7;
ERROR 0A000: multiple aliases to same table not supported

UPDATE t2 AS A JOIN t2 B SET A.pk_2=10,B.pk_2=11;
ERROR 0A000: multiple aliases to same table not supported

SELECT * FROM t2;
col_int_key	pk_1	pk_2	col_int
1	2	3	4
DROP TABLE t1,t2;
