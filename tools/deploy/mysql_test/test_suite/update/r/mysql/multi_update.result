#
# Bug#49534: multitable IGNORE update with sql_safe_updates error
# causes debug assertion
#
CREATE TABLE t1( a INT, KEY( a ) );
INSERT INTO t1 VALUES (1), (2), (3);
# Must not cause failed assertion
UPDATE IGNORE t1, t1 t1a SET t1.a = 1 WHERE t1a.a = 1;
DROP TABLE t1;

#
# Bug#54543: update ignore with incorrect subquery leads to assertion
# failure: inited==INDEX
#
CREATE TABLE t1 ( a INT );
INSERT INTO t1 VALUES (1), (2);

CREATE TABLE t2 ( a INT );
INSERT INTO t2 VALUES (1), (2);

CREATE TABLE t3 ( a INT );
INSERT INTO t3 VALUES (1), (2);

DROP TABLE t1, t2, t3;
#
# Bug#52157 various crashes and assertions with multi-table update, stored function
#
#
# BUG#57373: Multi update+InnoDB reports ER_KEY_NOT_FOUND if a
#            table is updated twice
#
CREATE TABLE t1(
  pk INT,
  a INT,
  PRIMARY KEY (pk)
);

INSERT INTO t1 VALUES (0,0);
UPDATE t1 AS A, t1 AS B SET A.pk = 1, B.a = 2;
ERROR 0A000: multiple aliases to same table not supported

# Should be (1,2)
SELECT * FROM t1;
+----+------+
| pk | a    |
+----+------+
|  0 |    0 |
+----+------+
DROP TABLE t1;

#
# BUG#11882110: UPDATE REPORTS ER_KEY_NOT_FOUND IF TABLE IS 
#               UPDATED TWICE
#
CREATE TABLE t1 ( 
  col_int_key int, 
  pk int, 
  col_int int, 
  key(col_int_key), 
  primary key (pk)
);
INSERT INTO t1 VALUES (1,2,3);


CREATE TABLE t2 ( 
  col_int_key int, 
  pk_1 int, 
  pk_2 int, 
  col_int int, 
  key(col_int_key), 
  primary key (pk_1,pk_2)
);
INSERT INTO t2 VALUES (1,2,3,4);

UPDATE t1 AS A NATURAL JOIN t1 B SET A.pk=5,B.pk=7;
ERROR 0A000: multiple aliases to same table not supported
UPDATE t1 AS A NATURAL JOIN t1 B SET A.col_int_key=5,B.col_int_key=7;
ERROR 0A000: multiple aliases to same table not supported


SELECT * FROM t1;
+-------------+----+---------+
| col_int_key | pk | col_int |
+-------------+----+---------+
|           1 |  2 |       3 |
+-------------+----+---------+


UPDATE t2 AS A NATURAL JOIN t2 B SET A.pk_1=5,B.pk_1=7;
ERROR 0A000: multiple aliases to same table not supported
UPDATE t2 AS A NATURAL JOIN t2 B SET A.col_int_key=5,B.col_int_key=7;
ERROR 0A000: multiple aliases to same table not supported

UPDATE t2 AS A NATURAL JOIN t2 B SET A.pk_2=10,B.pk_2=11;
ERROR 0A000: multiple aliases to same table not supported
UPDATE t2 AS A NATURAL JOIN t2 B SET A.col_int_key=10,B.col_int_key=11;
ERROR 0A000: multiple aliases to same table not supported


SELECT * FROM t2;
+-------------+------+------+---------+
| col_int_key | pk_1 | pk_2 | col_int |
+-------------+------+------+---------+
|           1 |    2 |    3 |       4 |
+-------------+------+------+---------+

DROP TABLE t1,t2;

