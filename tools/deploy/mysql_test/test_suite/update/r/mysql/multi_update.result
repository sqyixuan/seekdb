insert into t1 values ('A'),('B'),('C'),('D'),('E'),('F');

alter table t1 add b char(8) not null;
alter table t1 add a char(8) not null;
update t1 set a=c, b=c;

create table t2 like t1;
drop table t1,t2;

create table t1 ( c char(8) not null ) engine=innodb;
