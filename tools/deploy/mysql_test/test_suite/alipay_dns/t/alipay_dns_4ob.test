# owner: luofan.zp
# owner group: SQL1
# description:
#
/******************************************/
/*   数据库全名 = alipay_dns   */
/*   表名称 = antvip_api_auth   */
/******************************************/
CREATE TABLE `antvip_api_auth` (
  `id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
  `invoke_app` varchar(50) NOT NULL COMMENT '调用方名字',
  `target_app` varchar(1000) NOT NULL COMMENT '目标APP名字',
  `secret` varchar(50) NOT NULL COMMENT '密钥',
  `not_in_zappinfo` tinyint(4) NOT NULL COMMENT '调用方信息是否在appinfo中存在',
  `gmt_expired` datetime DEFAULT NULL COMMENT '过期时间',
  `gmt_modify` datetime DEFAULT NULL COMMENT '修改时间',
  `operator` varchar(50) NOT NULL COMMENT '修改人',
  PRIMARY KEY (`id`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8 COMMENT='antvip rest权限信息'
;

/******************************************/
/*   数据库全名 = alipay_dns   */
/*   表名称 = antvip_real_node   */
/******************************************/
CREATE TABLE `antvip_real_node` (
  `id` int(11) NOT NULL AUTO_INCREMENT COMMENT '主键',
  `domain_name` varchar(255) DEFAULT NULL COMMENT '域名，最长255字节',
  `ip` varchar(16) NOT NULL COMMENT 'ip',
  `fqdn` varchar(255) NOT NULL COMMENT '机器名',
  `env` varchar(16) NOT NULL DEFAULT 'PROD' COMMENT 'env，如pre/prod',
  `zone` varchar(32) NOT NULL COMMENT '所属LDC名称',
  `weight` int(11) NOT NULL DEFAULT '5' COMMENT '权重，范围是[1,10]',
  `health_check_port` int(11) NOT NULL DEFAULT '80' COMMENT '默认健康检测，在ip未设置检测端口的情况下使用默认端口',
  `enable` tinyint(4) NOT NULL DEFAULT '0' COMMENT '是否启用，可用于临时下线',
  `gmt_create` datetime NOT NULL COMMENT '添加时间',
  `gmt_modified` datetime DEFAULT NULL COMMENT '更新时间',
  `domain_id` int(11) DEFAULT NULL COMMENT 'domain_id',
  PRIMARY KEY (`id`),
  KEY `idx_ip` (`ip`),
  KEY `domain_id` (`domain_id`),
  KEY `domain_ip` (`ip`,`domain_id`)
) ENGINE=InnoDB AUTO_INCREMENT=160468 DEFAULT CHARSET=utf8 COMMENT='realserver表'
;

/******************************************/
/*   数据库全名 = alipay_dns   */
/*   表名称 = antvip_rname   */
/******************************************/
CREATE TABLE `antvip_rname` (
  `id` int(11) NOT NULL AUTO_INCREMENT COMMENT 'id',
  `rname` varchar(255) NOT NULL COMMENT 'gbobal name',
  `domain_name` varchar(255) NOT NULL COMMENT '被映射的域名:inner domain or normal domain',
  `domain_type` varchar(50) NOT NULL COMMENT '被映射的域名的类型:inner or normal',
  `env` varchar(16) NOT NULL COMMENT '被映射的域名的env',
  `enable` tinyint(4) NOT NULL COMMENT '被映射的域名的enable状态',
  `weight` int(11) NOT NULL DEFAULT '1' COMMENT '权重',
  `gmt_create` datetime NOT NULL COMMENT '创建时间',
  `gmt_modified` datetime NOT NULL COMMENT '修改时间',
  `rname_id` int(11) DEFAULT NULL COMMENT 'rname_id: global domain id',
  `domain_id` int(11) DEFAULT NULL COMMENT 'domain_id',
  `status` varchar(15) DEFAULT NULL COMMENT '挂载状态',
  PRIMARY KEY (`id`),
  KEY `rname` (`rname_id`),
  KEY `rname_domain` (`domain_id`,`rname_id`),
  KEY `rname_enable` (`enable`,`rname_id`),
  KEY `domain` (`domain_id`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8 COMMENT='rname'
;

/******************************************/
/*   数据库全名 = alipay_dns   */
/*   表名称 = antvip_vip_domain   */
/******************************************/
CREATE TABLE `antvip_vip_domain` (
  `id` int(11) NOT NULL AUTO_INCREMENT COMMENT '主键',
  `name` varchar(255) NOT NULL COMMENT '域名，最长255字节',
  `app` varchar(128) DEFAULT NULL COMMENT '域名所属应用名，最长255字节',
  `env` varchar(16) NOT NULL DEFAULT 'PROD' COMMENT 'env，如pre/prod',
  `station` varchar(50) NOT NULL COMMENT '站点信息',
  `zone` varchar(32) DEFAULT NULL COMMENT '所属LDC名称',
  `protect_threshold` int(11) NOT NULL COMMENT '保护阈值，百分比',
  `enable` tinyint(4) NOT NULL DEFAULT '0' COMMENT '是否启用，可用于临时下线',
  `health_check_type` varchar(16) NOT NULL DEFAULT 'TCP' COMMENT '健康检测方式，枚举类型：TCP|HTTP',
  `health_check_default_port` int(11) NOT NULL DEFAULT '12200' COMMENT '默认健康检测，在ip未设置检测端口的情况下使用默认端口',
  `health_check_timeout` int(11) NOT NULL DEFAULT '500' COMMENT '健康检测的超时时间，单位是毫秒',
  `health_check_interval` int(11) NOT NULL DEFAULT '5' COMMENT '健康检测的间隔时间，单位是秒',
  `health_check_raise` int(11) NOT NULL DEFAULT '1' COMMENT 'RealServer从不可用到可用，需要多少次心跳成功',
  `health_check_fall` int(11) NOT NULL DEFAULT '2' COMMENT 'RealServer从可用到不可用，需要多少次心跳失败',
  `health_check_payload` varchar(1024) NOT NULL DEFAULT '' COMMENT '健康检测的附加数据，json格式，TCP不需要，Http需要访问指定path，验证是否返回2xx或2xx/3xx，可验证返回内容是否含有指定文本',
  `version` bigint(20) NOT NULL DEFAULT '1' COMMENT '版本号，从1开始',
  `gmt_ceate` datetime NOT NULL COMMENT '添加时间',
  `gmt_modified` datetime DEFAULT NULL COMMENT '更新时间',
  `owner` varchar(255) DEFAULT NULL COMMENT 'owner',
  `health_check_enable` tinyint(4) NOT NULL DEFAULT '1' COMMENT '是否允许健康检测',
  `domain_type` varchar(50) NOT NULL DEFAULT 'INNER' COMMENT '域名类型',
  `idc_disaster_protect` int(11) DEFAULT NULL COMMENT 'IDC容灾保护阈值',
  PRIMARY KEY (`id`),
  UNIQUE KEY `domain_env` (`name`,`env`),
  KEY `domain_enable` (`name`,`enable`),
  KEY `app_zone` (`app`,`zone`),
  KEY `idx_env_station` (`env`,`station`),
  KEY `idx_en_en_st` (`enable`,`env`,`station`,`domain_type`)
) ENGINE=InnoDB AUTO_INCREMENT=1890 DEFAULT CHARSET=utf8 COMMENT='域名表'
;

/******************************************/
/*   数据库全名 = alipay_dns   */
/*   表名称 = antvip_vip_server   */
/******************************************/
CREATE TABLE `antvip_vip_server` (
  `id` int(11) NOT NULL AUTO_INCREMENT COMMENT '主键',
  `host` varchar(255) NOT NULL COMMENT 'antvip server ip:port',
  `weight` int(11) NOT NULL DEFAULT '5' COMMENT '权重，范围是[1,10]',
  `last_heartbeat` datetime DEFAULT NULL COMMENT '最后的心跳时间',
  `env` varchar(16) NOT NULL DEFAULT 'PROD' COMMENT 'pre/prod',
  `zone` varchar(32) NOT NULL COMMENT 'idc名称',
  `gmt_create` datetime NOT NULL COMMENT '添加时间',
  `gmt_modified` datetime DEFAULT NULL COMMENT '更新时间',
  `hostname` varchar(50) NOT NULL COMMENT '主机名',
  `domain_count` int(11) DEFAULT NULL COMMENT '负责域名数量',
  PRIMARY KEY (`id`)
) ENGINE=InnoDB AUTO_INCREMENT=14 DEFAULT CHARSET=utf8 COMMENT='server的心跳表，实时记录idc下的server列表'
;

/******************************************/
/*   数据库全名 = alipay_dns   */
/*   表名称 = antvip_zone_info   */
/******************************************/
CREATE TABLE `antvip_zone_info` (
  `id` int(11) NOT NULL AUTO_INCREMENT COMMENT 'key',
  `zone` varchar(50) NOT NULL COMMENT '所属LDC名称',
  `station` varchar(50) NOT NULL COMMENT '站点信息',
  `gmt_create` datetime DEFAULT NULL COMMENT '添加时间',
  `gmt_modified` datetime DEFAULT NULL COMMENT '修改时间',
  `idc` varchar(50) NOT NULL COMMENT 'idc',
  `city` varchar(50) NOT NULL COMMENT 'city',
  PRIMARY KEY (`id`),
  KEY `ind_zone_station` (`zone`,`station`)
) ENGINE=InnoDB AUTO_INCREMENT=231 DEFAULT CHARSET=utf8 COMMENT='zone info'
;

/******************************************/
/*   数据库全名 = alipay_dns   */
/*   表名称 = cloudinc_dispatch_cmd   */
/******************************************/
CREATE TABLE `cloudinc_dispatch_cmd` (
  `id` int(11) NOT NULL AUTO_INCREMENT COMMENT '主键',
  `dispatch_log_id` int(11) DEFAULT NULL COMMENT 'dispatch id',
  `type` varchar(20) DEFAULT NULL COMMENT '类型',
  `extra_info` varchar(1024) DEFAULT NULL COMMENT '额外信息',
  `gmt_create` datetime DEFAULT NULL COMMENT '创建时间',
  `gmt_modified` datetime DEFAULT NULL COMMENT '修改时间',
  PRIMARY KEY (`id`),
  KEY `dispatch_log_id` (`dispatch_log_id`)
) ENGINE=InnoDB AUTO_INCREMENT=52418 DEFAULT CHARSET=utf8 COMMENT='dns 下发命令表'
;

/******************************************/
/*   数据库全名 = alipay_dns   */
/*   表名称 = cloudinc_dispatch_conf   */
/******************************************/
CREATE TABLE `cloudinc_dispatch_conf` (
  `id` int(11) NOT NULL AUTO_INCREMENT COMMENT '主键',
  `name` varchar(50) DEFAULT NULL COMMENT '名称',
  `value` varchar(3000) COMMENT '内容',
  `status` varchar(11) DEFAULT NULL COMMENT '状态',
  `md5` varchar(128) DEFAULT NULL COMMENT 'MD5',
  `type` varchar(25) DEFAULT NULL COMMENT '类型',
  `path` varchar(255) DEFAULT NULL COMMENT '路径',
  `cluster_name` varchar(50) DEFAULT NULL COMMENT '集群名',
  `dispatch_log_id` int(11) DEFAULT NULL COMMENT 'dispatch_id',
  `gmt_create` datetime DEFAULT NULL COMMENT '创建时间',
  `gmt_modified` datetime DEFAULT NULL COMMENT '修改时间',
  `exec_compress` varchar(10) DEFAULT 'false' COMMENT '是否压缩',
  PRIMARY KEY (`id`),
  KEY `dispatch_log_id` (`dispatch_log_id`),
  KEY `cluster_name` (`cluster_name`),
  KEY `name` (`name`,`cluster_name`)
) ENGINE=InnoDB AUTO_INCREMENT=49572 DEFAULT CHARSET=utf8 COMMENT='dns 下发文件信息'
;

/******************************************/
/*   数据库全名 = alipay_dns   */
/*   表名称 = cloudinc_dispatch_group   */
/******************************************/
CREATE TABLE `cloudinc_dispatch_group` (
  `id` int(11) NOT NULL AUTO_INCREMENT COMMENT '主键',
  `dispatch_log_id` int(11) NOT NULL COMMENT 'dispatch_id',
  `status` varchar(20) DEFAULT NULL COMMENT '状态',
  `gmt_occur` datetime DEFAULT NULL COMMENT '发生时间',
  `gmt_start` datetime DEFAULT NULL COMMENT '开始时间',
  `gmt_end` datetime DEFAULT NULL COMMENT '结束时间',
  `gmt_create` datetime DEFAULT NULL COMMENT '创建时间',
  `gmt_modified` datetime DEFAULT NULL COMMENT '修改时间',
  PRIMARY KEY (`id`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8 COMMENT='dns 下发组'
;

/******************************************/
/*   数据库全名 = alipay_dns   */
/*   表名称 = cloudinc_dispatch_log   */
/******************************************/
CREATE TABLE `cloudinc_dispatch_log` (
  `id` int(11) NOT NULL AUTO_INCREMENT COMMENT '主键',
  `title` varchar(100) DEFAULT NULL COMMENT '标题',
  `params`varchar(3000)COMMENT '参数',
  `progress` varchar(100) DEFAULT NULL COMMENT '进度',
  `status` varchar(15) DEFAULT NULL COMMENT '状态',
  `strategy` varchar(50) DEFAULT NULL COMMENT '策略',
  `ops_type` varchar(15) DEFAULT NULL COMMENT '类型',
  `operator` varchar(50) DEFAULT NULL COMMENT '操作人',
  `gmt_occur` datetime DEFAULT NULL COMMENT '下发时间',
  `gmt_end` datetime DEFAULT NULL COMMENT '结束时间',
  `acceptor` varchar(50) DEFAULT NULL COMMENT '接受端',
  `invoker` varchar(50) DEFAULT NULL COMMENT '调用端',
  `gmt_create` datetime DEFAULT NULL COMMENT '创建时间',
  `gmt_modified` datetime DEFAULT NULL COMMENT '修改时间',
  PRIMARY KEY (`id`)
) ENGINE=InnoDB AUTO_INCREMENT=1483 DEFAULT CHARSET=utf8 COMMENT='dns 下发记录'
;

/******************************************/
/*   数据库全名 = alipay_dns   */
/*   表名称 = cloudinc_dispatch_target   */
/******************************************/
CREATE TABLE `cloudinc_dispatch_target` (
  `id` int(11) NOT NULL AUTO_INCREMENT COMMENT '主键',
  `hostname` varchar(50) DEFAULT NULL COMMENT '主机名',
  `ip` varchar(20) DEFAULT NULL COMMENT 'ip地址',
  `status` varchar(20) DEFAULT NULL COMMENT '状态',
  `cluster_name` varchar(50) DEFAULT NULL COMMENT '集群名',
  `dispatch_group_id` int(11) DEFAULT NULL COMMENT 'dispatch_group_id',
  `dispatch_log_id` int(11) DEFAULT NULL COMMENT 'dispatch_id',
  `remark`varchar(3000)COMMENT '备注',
  `gmt_create` datetime DEFAULT NULL COMMENT '创建时间',
  `gmt_modified` datetime DEFAULT NULL COMMENT '修改时间',
  PRIMARY KEY (`id`),
  KEY `dispatch_log_id` (`dispatch_log_id`),
  KEY `ip` (`ip`),
  KEY `hostname` (`hostname`)
) ENGINE=InnoDB AUTO_INCREMENT=1666 DEFAULT CHARSET=utf8 COMMENT='dns 下发机器信息'
;

/******************************************/
/*   数据库全名 = alipay_dns   */
/*   表名称 = cloudinc_system_config   */
/******************************************/
CREATE TABLE `cloudinc_system_config` (
  `id` int(11) NOT NULL AUTO_INCREMENT COMMENT 'pkey',
  `config_key` varchar(100) NOT NULL COMMENT 'key',
  `config_value` varchar(8096) DEFAULT NULL COMMENT 'value',
  `description` varchar(100) DEFAULT NULL COMMENT 'desciption',
  `gmt_create` datetime DEFAULT NULL COMMENT 'create time',
  `gmt_modified` datetime DEFAULT NULL COMMENT 'modified time',
  PRIMARY KEY (`id`)
) ENGINE=InnoDB AUTO_INCREMENT=36 DEFAULT CHARSET=utf8 COMMENT='system config'
;

/******************************************/
/*   数据库全名 = alipay_dns   */
/*   表名称 = dns_acl_build_rule_info   */
/******************************************/
CREATE TABLE `dns_acl_build_rule_info` (
  `id` bigint(20) NOT NULL AUTO_INCREMENT COMMENT '主键',
  `builder_name` varchar(20) NOT NULL DEFAULT '' COMMENT '更新器名称',
  `acl_key` varchar(64) NOT NULL DEFAULT '' COMMENT '生成 KEY',
  `continent` varchar(100) DEFAULT '*' COMMENT '洲',
  `nation` varchar(100) DEFAULT '*' COMMENT '国家',
  `area` varchar(100) DEFAULT '*' COMMENT '地区',
  `province` varchar(100) DEFAULT '*' COMMENT '省份',
  `city` varchar(100) DEFAULT '*' COMMENT '城市',
  `district` varchar(100) DEFAULT '*' COMMENT '区县',
  `isp` varchar(255) DEFAULT '*' COMMENT '运营商',
  `start_ip` varchar(20) NOT NULL DEFAULT '' COMMENT '开始IP',
  `end_ip` varchar(20) NOT NULL DEFAULT '' COMMENT '结束 IP',
  `ord` int(11) DEFAULT '0' COMMENT '顺序  用于优化执行效率',
  `flow_weight` int(11) DEFAULT NULL COMMENT '流量权重',
  `gmt_create` datetime DEFAULT NULL COMMENT '创建时间',
  `gmt_modified` datetime DEFAULT NULL COMMENT '修改时间',
  `acl_desc` varchar(50) DEFAULT NULL COMMENT 'acl描述',
  PRIMARY KEY (`id`),
  KEY `name` (`builder_name`)
) ENGINE=InnoDB AUTO_INCREMENT=61 DEFAULT CHARSET=utf8 COMMENT='Dns 解析规则'
;

/******************************************/
/*   数据库全名 = alipay_dns   */
/*   表名称 = dns_acl_meta_info   */
/******************************************/
CREATE TABLE `dns_acl_meta_info` (
  `id` int(11) NOT NULL AUTO_INCREMENT COMMENT '主键',
  `continent` varchar(10) DEFAULT NULL COMMENT '洲',
  `nation` varchar(100) DEFAULT NULL COMMENT '国家',
  `area` varchar(20) DEFAULT NULL COMMENT '地区',
  `province` varchar(60) DEFAULT NULL COMMENT '省份',
  `city` varchar(60) DEFAULT NULL COMMENT '城市',
  `district` varchar(60) DEFAULT NULL COMMENT '区县',
  `isp` varchar(100) DEFAULT NULL COMMENT '运营商',
  `gmt_create` datetime NOT NULL COMMENT '创建时间',
  `gmt_modified` datetime NOT NULL COMMENT '修改时间',
  PRIMARY KEY (`id`),
  KEY `nation` (`nation`),
  KEY `province` (`province`)
) ENGINE=InnoDB AUTO_INCREMENT=19459 DEFAULT CHARSET=utf8 COMMENT='DNS acl元数据'
;

/******************************************/
/*   数据库全名 = alipay_dns   */
/*   表名称 = dns_api_auth_conf_info   */
/******************************************/
CREATE TABLE `dns_api_auth_conf_info` (
  `id` bigint(20) NOT NULL AUTO_INCREMENT COMMENT '主键',
  `invoke_mode` varchar(10) NOT NULL DEFAULT '' COMMENT '调用方式',
  `invoker_info` varchar(60) NOT NULL DEFAULT '' COMMENT '调用方信息',
  `invoker_data` varchar(60) DEFAULT NULL COMMENT '调用方数据',
  `cluster_name` varchar(128) DEFAULT NULL COMMENT '集群列表',
  `add_record` char(1) DEFAULT 'N' COMMENT '添加RR',
  `upd_record` char(1) DEFAULT 'N' COMMENT '更新RR',
  `del_record` char(1) DEFAULT 'N' COMMENT '删除RR',
  `add_zone` char(1) DEFAULT 'N' COMMENT '添加ZONE',
  `upd_zone` char(1) DEFAULT 'N' COMMENT '更新ZONE',
  `del_zone` char(1) DEFAULT 'N' COMMENT '删除ZONE',
  `dr_switch` char(1) DEFAULT 'N' COMMENT '容灾切换',
  `query_data` char(1) DEFAULT 'N' COMMENT '查询数据',
  `data` varchar(3000) COMMENT '指定zone和domain',
  `expried_time` datetime DEFAULT NULL COMMENT '过期时间',
  `gmt_create` datetime DEFAULT NULL COMMENT '创建时间',
  `gmt_modified` datetime DEFAULT NULL COMMENT '修改时间',
  `auth_desc` varchar(200) DEFAULT NULL COMMENT '描述信息',
  `contacter` varchar(60) DEFAULT NULL COMMENT '联系人信息',
  `transfer_zone` varchar(1) DEFAULT 'N' COMMENT 'zone transfer',
  PRIMARY KEY (`id`),
  KEY `invoker_info` (`invoker_info`)
) ENGINE=InnoDB AUTO_INCREMENT=5 DEFAULT CHARSET=utf8 COMMENT='dns 外部调用权限配置'
;

/******************************************/
/*   数据库全名 = alipay_dns   */
/*   表名称 = dns_bind_server_info   */
/******************************************/
CREATE TABLE `dns_bind_server_info` (
  `id` bigint(20) NOT NULL AUTO_INCREMENT COMMENT '主键',
  `cluster_name` varchar(20) NOT NULL DEFAULT '' COMMENT '集群名',
  `address` varchar(15) NOT NULL DEFAULT '' COMMENT '机器 IP地址',
  `host_name` varchar(255) NOT NULL DEFAULT '' COMMENT '机器名',
  `host_desc` varchar(256) NOT NULL DEFAULT '' COMMENT '机器描述信息',
  `agent_port` int(11) NOT NULL COMMENT 'agent端口',
  `server_type` varchar(10) DEFAULT NULL COMMENT '机器类型：master/slave',
  `idc_id` varchar(10) DEFAULT NULL COMMENT '机器所在机房信息',
  `status` varchar(10) DEFAULT 'ONLINE' COMMENT '机器状态：在线，下线等',
  `gmt_create` datetime NOT NULL COMMENT '创建时间',
  `gmt_modified` datetime DEFAULT NULL COMMENT '修改时间',
  `seq_num` int(11) DEFAULT '0' COMMENT '序号',
  PRIMARY KEY (`id`),
  UNIQUE KEY `address` (`address`),
  KEY `cluster` (`cluster_name`)
) ENGINE=InnoDB AUTO_INCREMENT=191 DEFAULT CHARSET=utf8 COMMENT='dns bind解析服务器'
;

/******************************************/
/*   数据库全名 = alipay_dns   */
/*   表名称 = dns_biz_info   */
/******************************************/
CREATE TABLE `dns_biz_info` (
  `id` bigint(20) NOT NULL AUTO_INCREMENT COMMENT '主键',
  `biz_name` varchar(64) NOT NULL COMMENT '业务名称',
  `biz_desc` varchar(100) DEFAULT NULL COMMENT '业务描述',
  `gmt_create` datetime DEFAULT NULL COMMENT '创建时间',
  `gmt_modified` datetime DEFAULT NULL COMMENT '修改时间',
  `parent` varchar(64) NOT NULL DEFAULT 'default' COMMENT '父租户ID',
  PRIMARY KEY (`id`),
  UNIQUE KEY `biz_name` (`biz_name`)
) ENGINE=InnoDB AUTO_INCREMENT=6 DEFAULT CHARSET=utf8 COMMENT='业务表，划分流量策略'
;

/******************************************/
/*   数据库全名 = alipay_dns   */
/*   表名称 = dns_cluster_idc_status_info   */
/******************************************/
CREATE TABLE `dns_cluster_idc_status_info` (
  `id` bigint(20) NOT NULL AUTO_INCREMENT COMMENT '主键',
  `idc_id` varchar(20) NOT NULL DEFAULT '' COMMENT 'IDC',
  `cluster_name` varchar(20) NOT NULL DEFAULT '' COMMENT 'CLUSTER',
  `status` varchar(10) NOT NULL DEFAULT 'ONLINE' COMMENT '状态',
  `gmt_create` datetime NOT NULL COMMENT '创建时间',
  `gmt_modified` datetime NOT NULL COMMENT '修改时间',
  PRIMARY KEY (`id`),
  UNIQUE KEY `idc_id` (`idc_id`,`cluster_name`)
) ENGINE=InnoDB AUTO_INCREMENT=14 DEFAULT CHARSET=utf8 COMMENT='dns 集群包含的机房信息'
;

/******************************************/
/*   数据库全名 = alipay_dns   */
/*   表名称 = dns_cluster_info   */
/******************************************/
CREATE TABLE `dns_cluster_info` (
  `id` bigint(20) NOT NULL AUTO_INCREMENT COMMENT '主键',
  `cluster_name` varchar(20) NOT NULL COMMENT 'DNS集群名',
  `cluster_desc` varchar(100) NOT NULL COMMENT '集群描述',
  `builder_name` varchar(20) DEFAULT NULL COMMENT 'ACL/VIEW生成器名',
  `deploy_mode` varchar(10) DEFAULT NULL COMMENT '部署结构 经典(m-s) all_master',
  `operator` varchar(60) DEFAULT NULL COMMENT '集群信息是否可更改',
  `gmt_create` datetime NOT NULL COMMENT '创建时间',
  `gmt_modified` datetime DEFAULT NULL COMMENT '修改时间',
  `effect_mode` varchar(20) DEFAULT NULL COMMENT '生效方式:(下发配置、动态更新)',
  `exec_compress` varchar(10) DEFAULT 'false' COMMENT '是否开启压缩',
  PRIMARY KEY (`id`),
  UNIQUE KEY `name` (`cluster_name`)
) ENGINE=InnoDB AUTO_INCREMENT=4 DEFAULT CHARSET=utf8 COMMENT='dns 集群信息'
;

/******************************************/
/*   数据库全名 = alipay_dns   */
/*   表名称 = dns_conf_file_dispatch_ref   */
/******************************************/
CREATE TABLE `dns_conf_file_dispatch_ref` (
  `id` bigint(20) NOT NULL AUTO_INCREMENT COMMENT '主键',
  `cluster_name` varchar(20) NOT NULL COMMENT '集群名',
  `conf_file_id` bigint(20) NOT NULL COMMENT '配置文件id',
  `dispatch_log_id` bigint(20) NOT NULL COMMENT '下发单id',
  `file_name` varchar(60) NOT NULL COMMENT '文件名',
  `file_type` varchar(10) NOT NULL COMMENT '文件类型',
  `file_version` bigint(20) NOT NULL COMMENT '版本号',
  `gmt_create` datetime NOT NULL COMMENT '创建时间',
  `gmt_modified` datetime DEFAULT NULL COMMENT '修改时间',
  PRIMARY KEY (`id`),
  KEY `cluster_name` (`cluster_name`)
) ENGINE=InnoDB AUTO_INCREMENT=49572 DEFAULT CHARSET=utf8 COMMENT='dns 下发文件记录表'
;

/******************************************/
/*   数据库全名 = alipay_dns   */
/*   表名称 = dns_conf_file_info   */
/******************************************/
CREATE TABLE `dns_conf_file_info` (
  `id` bigint(20) NOT NULL AUTO_INCREMENT COMMENT '主键',
  `cluster_name` varchar(20) NOT NULL DEFAULT '' COMMENT '集群名',
  `view_name` varchar(64) NOT NULL COMMENT 'view名',
  `file_name` varchar(60) NOT NULL DEFAULT '' COMMENT '配置文件名',
  `file_path` varchar(256) NOT NULL DEFAULT '' COMMENT '配置文件路径',
  `file_version` bigint(20) NOT NULL COMMENT '配置文件版本信息',
  `file_content` varchar(3000) NOT NULL COMMENT '文件内容',
  `md5` varchar(64) DEFAULT NULL COMMENT '内容摘要',
  `file_type` varchar(10) NOT NULL DEFAULT '' COMMENT '文件类型源自模板类型 如ACL/NAMED/ZONEFILE',
  `file_status` varchar(10) DEFAULT NULL COMMENT '文件状态',
  `tpl_name` varchar(60) NOT NULL DEFAULT '' COMMENT '模板名',
  `server_type` varchar(10) DEFAULT NULL COMMENT '下发的服务器类型',
  `gmt_create` datetime NOT NULL COMMENT '创建时间',
  `gmt_modified` datetime DEFAULT NULL COMMENT '修改时间',
  `exec_compress` varchar(10) DEFAULT 'false' COMMENT '是否压缩',
  `zone_name` varchar(255) DEFAULT NULL COMMENT 'zone名,允许为空',
  PRIMARY KEY (`id`),
  KEY `cluster_type` (`cluster_name`,`file_type`,`server_type`)
) ENGINE=InnoDB AUTO_INCREMENT=55848 DEFAULT CHARSET=utf8 COMMENT='dns 配置文件表'
;

/******************************************/
/*   数据库全名 = alipay_dns   */
/*   表名称 = dns_conf_file_server_ref   */
/******************************************/
CREATE TABLE `dns_conf_file_server_ref` (
  `id` bigint(20) NOT NULL AUTO_INCREMENT COMMENT '主键',
  `cluster_name` varchar(20) NOT NULL COMMENT '集群名',
  `conf_file_id`varchar(3000)NOT NULL COMMENT '文件id',
  `dispatch_log_id` bigint(20) NOT NULL COMMENT '下发id',
  `host_name` varchar(255) NOT NULL COMMENT '主机名',
  `file_name` varchar(60) NOT NULL COMMENT '文件名',
  `status` varchar(20) DEFAULT NULL COMMENT '状态(生效、无效)',
  `gmt_create` datetime NOT NULL COMMENT '创建时间',
  `gmt_modified` datetime DEFAULT NULL COMMENT '修改时间',
  `file_type` varchar(10) NOT NULL COMMENT '文件类型',
  PRIMARY KEY (`id`),
  KEY `host_name` (`host_name`),
  KEY `cluster_name_host_name_file_name_dispatchlog` (`dispatch_log_id`,`host_name`,`file_name`,`cluster_name`),
  KEY `cluster_name_host_name_file_name_status` (`host_name`,`file_name`,`cluster_name`,`status`),
  KEY `dispatchlog` (`dispatch_log_id`)
) ENGINE=InnoDB AUTO_INCREMENT=2699 DEFAULT CHARSET=utf8 COMMENT='dns 下发机器上的配置文件'
;

/******************************************/
/*   数据库全名 = alipay_dns   */
/*   表名称 = dns_conf_tpl_info   */
/******************************************/
CREATE TABLE `dns_conf_tpl_info` (
  `id` bigint(20) NOT NULL AUTO_INCREMENT COMMENT '主键',
  `tpl_name` varchar(60) NOT NULL DEFAULT '' COMMENT '模板名',
  `cluster_name` varchar(20) NOT NULL DEFAULT '' COMMENT '集群名',
  `server_type` varchar(10) NOT NULL DEFAULT '' COMMENT '集群机器类型',
  `tpl_type` varchar(10) NOT NULL DEFAULT '' COMMENT '模板类型',
  `tpl_lang` varchar(20) DEFAULT NULL COMMENT '模板语言',
  `dest_file_name` varchar(60) DEFAULT NULL COMMENT '生成的目标文件名',
  `dest_file_path` varchar(100) DEFAULT NULL COMMENT '目标文件目录',
  `content` varchar(3000) NOT NULL COMMENT '内容',
  `gmt_create` datetime NOT NULL COMMENT '创建时间',
  `gmt_modified` datetime NOT NULL COMMENT '修改时间',
  PRIMARY KEY (`id`),
  KEY `cluster` (`cluster_name`)
) ENGINE=InnoDB AUTO_INCREMENT=10 DEFAULT CHARSET=utf8 COMMENT='dns 配置文件模板'
;

/******************************************/
/*   数据库全名 = alipay_dns   */
/*   表名称 = dns_dispatch_task_info   */
/******************************************/
CREATE TABLE `dns_dispatch_task_info` (
  `id` bigint(20) NOT NULL AUTO_INCREMENT COMMENT 'id',
  `batch_no` varchar(64) NOT NULL COMMENT '批次号',
  `type` varchar(30) NOT NULL COMMENT '类型',
  `operator` varchar(100) NOT NULL COMMENT '操作人',
  `cluster_name` varchar(20) NOT NULL COMMENT '集群名称',
  `zone_name` varchar(255) NOT NULL COMMENT 'zone名称',
  `data` varchar(255) DEFAULT NULL COMMENT '数据',
  `status` varchar(30) NOT NULL DEFAULT 'PENDING' COMMENT '状态',
  `gmt_create` datetime NOT NULL COMMENT '创建时间',
  `gmt_modified` datetime NOT NULL COMMENT '修改时间',
  `domain_name` varchar(4096) DEFAULT NULL COMMENT '域名列表, 多个以逗号分隔',
  PRIMARY KEY (`id`),
  KEY `batch_no` (`batch_no`),
  KEY `status` (`status`)
) ENGINE=InnoDB AUTO_INCREMENT=5 DEFAULT CHARSET=utf8 COMMENT='下发异步任务'
;

/******************************************/
/*   数据库全名 = alipay_dns   */
/*   表名称 = dns_domain_group_info   */
/******************************************/
CREATE TABLE `dns_domain_group_info` (
  `id` bigint(20) NOT NULL AUTO_INCREMENT COMMENT '主键',
  `group_name` varchar(60) NOT NULL DEFAULT '' COMMENT '域名组名',
  `cluster_name` varchar(20) NOT NULL COMMENT '集群',
  `group_desc` varchar(200) NOT NULL DEFAULT '' COMMENT '组描述',
  `idc_list` varchar(100) NOT NULL DEFAULT '' COMMENT '本组下挂域名的域名列表',
  `exclude_view_list` varchar(300) NOT NULL DEFAULT '' COMMENT 'exclude_view_list',
  `group_type` varchar(20) NOT NULL DEFAULT '' COMMENT '域名组类型：集群自定义智能解析/轮询/自定义',
  `gmt_create` datetime NOT NULL COMMENT '创建时间',
  `gmt_modified` datetime NOT NULL COMMENT '修改时间',
  `dr_group_name` varchar(60) DEFAULT NULL COMMENT '容灾组',
  `biz_name` varchar(64) NOT NULL DEFAULT 'default' COMMENT '业务分组标识',
  `unique_key` varchar(256) DEFAULT NULL COMMENT '唯一标识',
  PRIMARY KEY (`id`),
  UNIQUE KEY `name_unique` (`group_name`),
  UNIQUE KEY `unqi_key` (`unique_key`),
  KEY `cluster` (`cluster_name`),
  KEY `name_type_idc_view` (`idc_list`,`exclude_view_list`,`cluster_name`,`group_type`)
) ENGINE=InnoDB AUTO_INCREMENT=710 DEFAULT CHARSET=utf8 COMMENT='dns 域名组'
;

/******************************************/
/*   数据库全名 = alipay_dns   */
/*   表名称 = dns_domain_info   */
/******************************************/
CREATE TABLE `dns_domain_info` (
  `id` bigint(20) NOT NULL AUTO_INCREMENT COMMENT '主键',
  `domain_name` varchar(255) NOT NULL COMMENT '域名',
  `zone_name` varchar(255) NOT NULL DEFAULT '' COMMENT 'zone name',
  `cluster_name` varchar(20) NOT NULL COMMENT '所属集群名',
  `group_name` varchar(60) DEFAULT NULL COMMENT '所属组名',
  `resolve_mode` varchar(64) DEFAULT '' COMMENT '解析类型',
  `app_name` varchar(60) DEFAULT NULL COMMENT '所属应用名',
  `level` int(11) DEFAULT NULL COMMENT '级别',
  `domain_type` varchar(10) DEFAULT NULL COMMENT '域名类型',
  `gmt_create` datetime NOT NULL COMMENT '创建时间',
  `gmt_modified` datetime NOT NULL COMMENT '修改时间',
  PRIMARY KEY (`id`),
  UNIQUE KEY `domain` (`cluster_name`,`zone_name`,`domain_name`)
) ENGINE=InnoDB AUTO_INCREMENT=698 DEFAULT CHARSET=utf8 COMMENT='dns 域名信息'
;

/******************************************/
/*   数据库全名 = alipay_dns   */
/*   表名称 = dns_dr_info   */
/******************************************/
CREATE TABLE `dns_dr_info` (
  `id` bigint(20) NOT NULL AUTO_INCREMENT COMMENT '主键',
  `idc_id` varchar(10) NOT NULL DEFAULT '' COMMENT 'idc',
  `cluster_name` varchar(20) NOT NULL DEFAULT '' COMMENT '集群名',
  `biz_name` varchar(20) NOT NULL DEFAULT '' COMMENT '业务域名',
  `data` varchar(512) NOT NULL DEFAULT '-' COMMENT '恢复业务域，仅用于集群容灾，业务域恢复，多个以-分隔',
  `gmt_create` datetime NOT NULL COMMENT '创建时间',
  `gmt_modified` datetime NOT NULL COMMENT '修改时间',
  PRIMARY KEY (`id`),
  UNIQUE KEY `biz_index` (`idc_id`,`cluster_name`,`biz_name`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8 COMMENT='DNS容灾信息'
;

/******************************************/
/*   数据库全名 = alipay_dns   */
/*   表名称 = dns_dr_switch_history   */
/******************************************/
CREATE TABLE `dns_dr_switch_history` (
  `id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
  `gmt_create` datetime NOT NULL COMMENT '创建时间',
  `gmt_modified` datetime NOT NULL COMMENT '修改时间',
  `cluster_name` varchar(20) NOT NULL COMMENT '集群名',
  `tenant_id` varchar(64) NOT NULL COMMENT '租户ID',
  `machine` varchar(255) NOT NULL COMMENT '机器',
  `operator` varchar(60) NOT NULL COMMENT '操作人',
  `operator_nick` varchar(60) NOT NULL COMMENT '操作人描述',
  `switch_mode` varchar(20) NOT NULL COMMENT '切换方式：IDC/CITY',
  `disaster_item` varchar(64) NOT NULL COMMENT '灾难对象',
  `backup` varchar(64) DEFAULT NULL COMMENT '灾备',
  `ops_type` varchar(20) NOT NULL COMMENT '操作类型：容灾切换/容灾恢复等',
  `result_status` varchar(20) NOT NULL COMMENT '操作状态：成功/失败/执行中...',
  `request_id` varchar(64) NOT NULL COMMENT '请求ID',
  `dispatch_id` bigint(20) unsigned NOT NULL COMMENT '下发ID',
  `result_message`varchar(3000)COMMENT '切换结果',
  PRIMARY KEY (`id`),
  KEY `idx_request` (`request_id`)
) ENGINE=InnoDB AUTO_INCREMENT=2 DEFAULT CHARSET=utf8 COMMENT='DNS容灾切换历史记录'
;

/******************************************/
/*   数据库全名 = alipay_dns   */
/*   表名称 = dns_event_info   */
/******************************************/
CREATE TABLE `dns_event_info` (
  `id` bigint(20) NOT NULL AUTO_INCREMENT COMMENT '主键',
  `event_id` varchar(64) NOT NULL DEFAULT '' COMMENT '事件唯一ID',
  `request_id` varchar(64) DEFAULT NULL COMMENT '源事件',
  `action_type` varchar(20) NOT NULL DEFAULT '' COMMENT '操作类型',
  `data_type` varchar(20) NOT NULL DEFAULT '' COMMENT '数据类型',
  `cluster_name` varchar(20) NOT NULL DEFAULT '' COMMENT '所属集群名',
  `source` varchar(256) DEFAULT NULL COMMENT '事件源',
  `operator` varchar(60) DEFAULT NULL COMMENT '操作员',
  `target` varchar(256) DEFAULT NULL COMMENT '事件对象',
  `machine` varchar(255) DEFAULT NULL COMMENT '事件所在机器信息',
  `data` varchar(3000) COMMENT '事件数据',
  `gmt_create` datetime DEFAULT NULL COMMENT '开始时间',
  `gmt_modified` datetime DEFAULT NULL COMMENT '结束时间',
  PRIMARY KEY (`id`),
  UNIQUE KEY `eventid` (`event_id`),
  KEY `idx_datatype-create` (`gmt_create`,`data_type`),
  KEY `idx_datatype` (`data_type`)
) ENGINE=InnoDB AUTO_INCREMENT=64743 DEFAULT CHARSET=utf8 COMMENT='dns 事件记录表'
;

/******************************************/
/*   数据库全名 = alipay_dns   */
/*   表名称 = dns_flow_default_info   */
/******************************************/
CREATE TABLE `dns_flow_default_info` (
  `id` bigint(20) NOT NULL AUTO_INCREMENT COMMENT '主键',
  `cluster_name` varchar(20) NOT NULL DEFAULT '' COMMENT '集群',
  `domain_group_name` varchar(64) NOT NULL DEFAULT '' COMMENT '域名组',
  `batch_no` varchar(64) NOT NULL COMMENT '批次',
  `view_group_name` varchar(64) NOT NULL DEFAULT '' COMMENT 'view组',
  `flow_type` varchar(20) NOT NULL DEFAULT '' COMMENT '类型',
  `idc_id` varchar(20) DEFAULT NULL COMMENT '机房',
  `view_name` varchar(20) NOT NULL DEFAULT '' COMMENT '线路名',
  `gmt_create` datetime DEFAULT NULL COMMENT '创建时间',
  `gmt_modified` datetime DEFAULT NULL COMMENT '修改时间',
  PRIMARY KEY (`id`),
  KEY `cluster` (`cluster_name`),
  KEY `dg` (`domain_group_name`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8 COMMENT='流量基线'
;

/******************************************/
/*   数据库全名 = alipay_dns   */
/*   表名称 = dns_flow_eavl_info   */
/******************************************/
CREATE TABLE `dns_flow_eavl_info` (
  `id` bigint(20) NOT NULL AUTO_INCREMENT COMMENT '主键',
  `cluster_name` varchar(20) NOT NULL DEFAULT '' COMMENT '集群',
  `domain_group_name` varchar(64) NOT NULL DEFAULT '' COMMENT '域名组',
  `view_group_name` varchar(64) NOT NULL DEFAULT '' COMMENT 'view组',
  `flow_type` varchar(20) NOT NULL DEFAULT '' COMMENT '类型',
  `idc_id` varchar(20) DEFAULT NULL COMMENT '机房',
  `view_name` varchar(20) NOT NULL DEFAULT '' COMMENT '线路名',
  `gmt_create` datetime DEFAULT NULL COMMENT '创建时间',
  `gmt_modified` datetime DEFAULT NULL COMMENT '修改时间',
  PRIMARY KEY (`id`),
  KEY `vg_cluster_type` (`view_group_name`,`cluster_name`,`flow_type`),
  KEY `dg_cluster_type` (`domain_group_name`,`cluster_name`,`flow_type`),
  KEY `cluster` (`cluster_name`),
  KEY `idc_cluster` (`idc_id`,`cluster_name`),
  KEY `dg` (`domain_group_name`),
  KEY `vg` (`view_group_name`)
) ENGINE=InnoDB AUTO_INCREMENT=3123 DEFAULT CHARSET=utf8 COMMENT='dns 流量信息'
;

/******************************************/
/*   数据库全名 = alipay_dns   */
/*   表名称 = dns_hc_result   */
/******************************************/
CREATE TABLE `dns_hc_result` (
  `id` bigint(20) NOT NULL AUTO_INCREMENT COMMENT '主键',
  `bat_no` bigint(20) NOT NULL COMMENT '批次信息',
  `cluster_name` varchar(20) NOT NULL DEFAULT '' COMMENT '集群',
  `channel` varchar(20) NOT NULL DEFAULT '' COMMENT '检测渠道',
  `result` varchar(10) NOT NULL DEFAULT '' COMMENT '检测结果',
  `detail` varchar(3000) COMMENT '检测详情',
  `gmt_create` datetime NOT NULL COMMENT '创建时间',
  `gmt_modified` datetime NOT NULL COMMENT '修改时间',
  PRIMARY KEY (`id`),
  KEY `batno` (`bat_no`),
  KEY `cluster` (`cluster_name`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8 COMMENT='dns 健康检查结果'
;

/******************************************/
/*   数据库全名 = alipay_dns   */
/*   表名称 = dns_hc_tpl_group_info   */
/******************************************/
CREATE TABLE `dns_hc_tpl_group_info` (
  `id` bigint(20) NOT NULL AUTO_INCREMENT COMMENT '主键',
  `group_name` varchar(20) NOT NULL DEFAULT '' COMMENT '健康检测模板组名',
  `group_desc` varchar(200) NOT NULL DEFAULT '' COMMENT '组描述信息',
  `gmt_create` datetime NOT NULL COMMENT '创建时间',
  `gmt_modified` datetime NOT NULL COMMENT '修改时间',
  PRIMARY KEY (`id`),
  UNIQUE KEY `name` (`group_name`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8 COMMENT='dns 健康检查模板组'
;

/******************************************/
/*   数据库全名 = alipay_dns   */
/*   表名称 = dns_hc_tpl_group_ref   */
/******************************************/
CREATE TABLE `dns_hc_tpl_group_ref` (
  `id` bigint(20) NOT NULL AUTO_INCREMENT COMMENT '主键',
  `group_id` bigint(20) NOT NULL COMMENT '组ID',
  `hc_tpl_id` bigint(20) NOT NULL COMMENT '模板ID',
  `hc_tpl_name` varchar(20) NOT NULL DEFAULT '' COMMENT '模板名',
  `gmt_create` datetime NOT NULL COMMENT '创建时间',
  `gmt_modified` datetime NOT NULL COMMENT '修改时间',
  PRIMARY KEY (`id`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8 COMMENT='dns 健康检查模板与模板组映射关系'
;

/******************************************/
/*   数据库全名 = alipay_dns   */
/*   表名称 = dns_hc_tpl_info   */
/******************************************/
CREATE TABLE `dns_hc_tpl_info` (
  `id` bigint(20) NOT NULL AUTO_INCREMENT COMMENT '主键',
  `hc_tpl_name` varchar(20) NOT NULL DEFAULT '' COMMENT '模板名',
  `hc_tpl_desc` varchar(200) NOT NULL DEFAULT '' COMMENT '模板描述',
  `hc_tpl_type` varchar(10) NOT NULL DEFAULT '' COMMENT '检测类型',
  `hc_channel` varchar(20) NOT NULL DEFAULT '' COMMENT '检测渠道',
  `hc_tpl_content` varchar(3000) NOT NULL COMMENT '模板内容',
  `gmt_create` datetime NOT NULL COMMENT '创建时间',
  `gmt_modified` datetime NOT NULL COMMENT '修改时间',
  PRIMARY KEY (`id`),
  UNIQUE KEY `name` (`hc_tpl_name`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8 COMMENT='dns 健康检查模板'
;

/******************************************/
/*   数据库全名 = alipay_dns   */
/*   表名称 = dns_idc_info   */
/******************************************/
CREATE TABLE `dns_idc_info` (
  `id` bigint(20) NOT NULL AUTO_INCREMENT COMMENT '主键',
  `idc_id` varchar(10) NOT NULL DEFAULT '' COMMENT 'IDC ID',
  `idc_name` varchar(10) NOT NULL DEFAULT '' COMMENT 'IDC NAME',
  `city_name` varchar(10) NOT NULL DEFAULT '' COMMENT '城市名',
  `idc_desc` varchar(140) NOT NULL DEFAULT '' COMMENT 'IDC 备注',
  `status` varchar(10) DEFAULT NULL COMMENT '机房状态',
  `gmt_create` datetime NOT NULL COMMENT '创建时间',
  `gmt_modified` datetime DEFAULT NULL COMMENT '修改时间',
  `is_proxy` varchar(1) DEFAULT 'N' COMMENT '是否是海外代理理点机房',
  PRIMARY KEY (`id`),
  UNIQUE KEY `idc_idc` (`idc_id`)
) ENGINE=InnoDB AUTO_INCREMENT=9 DEFAULT CHARSET=utf8 COMMENT='dns 机房信息'
;

/******************************************/
/*   数据库全名 = alipay_dns   */
/*   表名称 = dns_inner_cluster_hc_info   */
/******************************************/
CREATE TABLE `dns_inner_cluster_hc_info` (
  `id` bigint(20) unsigned NOT NULL AUTO_INCREMENT COMMENT '主键',
  `gmt_create` datetime NOT NULL COMMENT '创建时间',
  `gmt_modified` datetime NOT NULL COMMENT '修改时间',
  `cluster` varchar(20) NOT NULL COMMENT '集群名',
  `zone_name` varchar(255) NOT NULL COMMENT 'zone',
  `serial` bigint(20) unsigned NOT NULL COMMENT '序号',
  `result_status` varchar(20) NOT NULL COMMENT '校验状态',
  PRIMARY KEY (`id`),
  UNIQUE KEY `uk_zone-cluster` (`zone_name`,`cluster`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8 COMMENT='内网集群健康检测信息'
;

/******************************************/
/*   数据库全名 = alipay_dns   */
/*   表名称 = dns_inner_domain_info   */
/******************************************/
CREATE TABLE `dns_inner_domain_info` (
  `id` bigint(20) NOT NULL AUTO_INCREMENT COMMENT '主键',
  `domain_name` varchar(255) NOT NULL COMMENT '域名',
  `zone_name` varchar(255) NOT NULL DEFAULT '' COMMENT 'zone name',
  `cluster_name` varchar(20) NOT NULL COMMENT '所属集群名',
  `group_name` varchar(60) DEFAULT NULL COMMENT '所属组名',
  `resolve_mode` varchar(64) DEFAULT '' COMMENT '解析类型',
  `app_name` varchar(60) DEFAULT NULL COMMENT '所属应用名',
  `level` int(11) DEFAULT NULL COMMENT '级别',
  `domain_type` varchar(10) DEFAULT NULL COMMENT '域名类型',
  `gmt_create` datetime NOT NULL COMMENT '创建时间',
  `gmt_modified` datetime NOT NULL COMMENT '修改时间',
  PRIMARY KEY (`id`),
  UNIQUE KEY `domain` (`cluster_name`,`zone_name`,`domain_name`)
) ENGINE=InnoDB AUTO_INCREMENT=922653 DEFAULT CHARSET=utf8 COMMENT='dns 内网集群域名信息'
;

/******************************************/
/*   数据库全名 = alipay_dns   */
/*   表名称 = dns_inner_resource_record_info   */
/******************************************/
CREATE TABLE `dns_inner_resource_record_info` (
  `id` bigint(20) NOT NULL AUTO_INCREMENT COMMENT '主键',
  `owner` varchar(256) NOT NULL COMMENT '资源',
  `cluster_name` varchar(20) NOT NULL COMMENT '所属集群 冗余字段',
  `zone_name` varchar(255) NOT NULL DEFAULT '' COMMENT 'ZONE NAME',
  `view_group_name` varchar(60) DEFAULT '' COMMENT 'VIEW GRP name',
  `domain_group_name` varchar(60) DEFAULT NULL COMMENT '域名组',
  `idc_id` varchar(20) DEFAULT NULL COMMENT 'IDC ID',
  `rr_type` varchar(10) NOT NULL COMMENT '资源类型',
  `ttl` varchar(20) NOT NULL DEFAULT '' COMMENT 'TTL',
  `rr_class` varchar(12) NOT NULL DEFAULT '' COMMENT 'RECODR 类型',
  `data` varchar(500) NOT NULL COMMENT '数据',
  `status` varchar(10) DEFAULT NULL COMMENT '状态',
  `gmt_create` datetime NOT NULL COMMENT '创建时间',
  `gmt_modified` datetime DEFAULT NULL COMMENT '修改时间',
  PRIMARY KEY (`id`),
  KEY `rrdata` (`data`(383)),
  KEY `rrtype` (`rr_type`),
  KEY `owner` (`owner`),
  KEY `cluster` (`cluster_name`),
  KEY `zonename` (`zone_name`),
  KEY `viewgroupname` (`view_group_name`),
  KEY `domain_group_name` (`domain_group_name`),
  KEY `idc_id` (`idc_id`)
) ENGINE=InnoDB AUTO_INCREMENT=1365592 DEFAULT CHARSET=utf8 COMMENT='dns 内网集群资源记录表'
;

/******************************************/
/*   数据库全名 = alipay_dns   */
/*   表名称 = dns_jnl_lock_info   */
/******************************************/
CREATE TABLE `dns_jnl_lock_info` (
  `id` bigint(20) NOT NULL AUTO_INCREMENT COMMENT '主键',
  `cluster_name` varchar(20) NOT NULL COMMENT '所属集群',
  `lock_key` varchar(300) NOT NULL COMMENT '锁的key',
  `gmt_create` datetime NOT NULL COMMENT '创建时间',
  `gmt_modified` datetime NOT NULL COMMENT '修改时间',
  PRIMARY KEY (`id`),
  UNIQUE KEY `uk_lock_key` (`lock_key`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8 COMMENT='用于锁定jnl处理'
;

/******************************************/
/*   数据库全名 = alipay_dns   */
/*   表名称 = dns_key_info   */
/******************************************/
CREATE TABLE `dns_key_info` (
  `id` bigint(20) NOT NULL AUTO_INCREMENT COMMENT '主键',
  `key_name` varchar(128) NOT NULL DEFAULT 'key name' COMMENT '名称',
  `key_algorithm` varchar(32) NOT NULL DEFAULT 'hmac-md5' COMMENT '算法',
  `key_secret` varchar(512) NOT NULL COMMENT '密钥',
  `cluster_name` varchar(20) NOT NULL DEFAULT '' COMMENT '集群名',
  `gmt_create` datetime NOT NULL COMMENT '创建时间',
  `gmt_modified` datetime DEFAULT NULL COMMENT '修改时间',
  PRIMARY KEY (`id`),
  UNIQUE KEY `name` (`key_name`,`cluster_name`)
) ENGINE=InnoDB AUTO_INCREMENT=107 DEFAULT CHARSET=utf8 COMMENT='dns 密钥信息'
;

/******************************************/
/*   数据库全名 = alipay_dns   */
/*   表名称 = dns_lock_info   */
/******************************************/
CREATE TABLE `dns_lock_info` (
  `id` bigint(20) NOT NULL AUTO_INCREMENT COMMENT 'id',
  `cluster_name` varchar(20) NOT NULL DEFAULT '' COMMENT '集群名',
  `lock_key` varchar(300) NOT NULL DEFAULT '' COMMENT '锁key',
  `lock_type` varchar(20) NOT NULL DEFAULT '' COMMENT '锁类型',
  `operator` varchar(100) NOT NULL DEFAULT '' COMMENT '操作人',
  `gmt_create` datetime NOT NULL COMMENT '创建时间',
  `gmt_modified` datetime NOT NULL COMMENT '修改时间',
  PRIMARY KEY (`id`),
  UNIQUE KEY `lock_key` (`lock_key`)
) ENGINE=InnoDB AUTO_INCREMENT=1042 DEFAULT CHARSET=utf8 COMMENT='操作加锁'
;

/******************************************/
/*   数据库全名 = alipay_dns   */
/*   表名称 = dns_log_journal   */
/******************************************/
CREATE TABLE `dns_log_journal` (
  `id` bigint(20) NOT NULL AUTO_INCREMENT COMMENT '主键',
  `owner` varchar(256) NOT NULL COMMENT '数据的owner',
  `request_id` varchar(255) NOT NULL COMMENT '请求ID',
  `data`varchar(3000)NOT NULL COMMENT '数据',
  `old_data`varchar(3000)COMMENT '原数据',
  `action_type` varchar(20) NOT NULL COMMENT '操作类型:add、update、delete',
  `ops_host` varchar(255) DEFAULT NULL COMMENT '操作所在的管控机器',
  `master_host` varchar(255) DEFAULT NULL COMMENT '主master',
  `status` varchar(20) DEFAULT NULL COMMENT '状态:NEW、FINISH',
  `create_time` bigint(20) NOT NULL COMMENT '数据生成的时间戳',
  `gmt_create` datetime DEFAULT NULL COMMENT '创建时间',
  `gmt_modified` datetime DEFAULT NULL COMMENT '修改时间',
  `cluster_name` varchar(20) DEFAULT NULL COMMENT '集群',
  `zone_name` varchar(255) DEFAULT NULL COMMENT 'zone',
  `dispatch_log_id` bigint(20) DEFAULT NULL COMMENT '下发id',
  `complex_data`varchar(3000)COMMENT '复合数据',
  `merge_count` int(11) DEFAULT '0' COMMENT '合并次数',
  PRIMARY KEY (`id`),
  UNIQUE KEY `uk_requestid` (`request_id`),
  UNIQUE KEY `requestid` (`request_id`),
  KEY `idx_ops_host` (`ops_host`),
  KEY `ops_host` (`ops_host`),
  KEY `idx_zone_name` (`zone_name`),
  KEY `idx_owner` (`owner`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8 COMMENT='DNS 内网集群Log数据临时表'
;

/******************************************/
/*   数据库全名 = alipay_dns   */
/*   表名称 = dns_log_journal_copy   */
/******************************************/
CREATE TABLE `dns_log_journal_copy` (
  `id` bigint(20) NOT NULL AUTO_INCREMENT COMMENT '主键',
  `owner` varchar(256) NOT NULL COMMENT '数据的owner',
  `cluster_name` varchar(20) NOT NULL COMMENT '所属集群',
  `zone_name` varchar(255) DEFAULT NULL COMMENT '所属zone',
  `data`varchar(3000)COMMENT '数据',
  `old_data`varchar(3000)COMMENT '原数据',
  `complex_data`varchar(3000)COMMENT '复合数据',
  `action_type` varchar(20) NOT NULL COMMENT '操作类型:add、update、delete',
  `batch_no` varchar(64) DEFAULT NULL COMMENT '合并批次号',
  `gmt_create` datetime NOT NULL COMMENT '创建时间',
  `gmt_modified` datetime NOT NULL COMMENT '修改时间',
  `request_id` varchar(255) DEFAULT NULL COMMENT '请求ID',
  PRIMARY KEY (`id`),
  KEY `idx_owner` (`owner`),
  KEY `idx_batch_no` (`batch_no`),
  KEY `idx_requestId` (`request_id`)
) ENGINE=InnoDB AUTO_INCREMENT=419 DEFAULT CHARSET=utf8 COMMENT='LogJnl处理完的备份数据'
;

/******************************************/
/*   数据库全名 = alipay_dns   */
/*   表名称 = dns_operation_journal   */
/******************************************/
CREATE TABLE `dns_operation_journal` (
  `id` bigint(20) NOT NULL AUTO_INCREMENT COMMENT 'id',
  `batch_no` varchar(64) NOT NULL DEFAULT '' COMMENT '批次号',
  `cluster_name` varchar(20) NOT NULL COMMENT '集群名称',
  `base_key` varchar(255) DEFAULT '' COMMENT '基准数据key',
  `operator` varchar(100) NOT NULL DEFAULT '' COMMENT '操作人',
  `action_type` varchar(20) NOT NULL DEFAULT '' COMMENT '操作类型',
  `data_type` varchar(20) NOT NULL DEFAULT '' COMMENT '数据类型',
  `data` varchar(3000) COMMENT '数据',
  `status` varchar(20) DEFAULT 'INITIAL' COMMENT '状态，INITIAL：初始，SUBMITTED：已提交',
  `gmt_create` datetime NOT NULL COMMENT '创建时间',
  `gmt_modified` datetime DEFAULT NULL COMMENT '修改时间',
  `order_id` varchar(64) DEFAULT NULL COMMENT '工单号',
  `old_data` varchar(3000) COMMENT '原数据',
  PRIMARY KEY (`id`),
  KEY `operator` (`operator`)
) ENGINE=InnoDB AUTO_INCREMENT=199 DEFAULT CHARSET=utf8 COMMENT='元数据缓存'
;

/******************************************/
/*   数据库全名 = alipay_dns   */
/*   表名称 = dns_order_info   */
/******************************************/
CREATE TABLE `dns_order_info` (
  `id` int(11) NOT NULL AUTO_INCREMENT COMMENT 'id',
  `order_id` varchar(64) NOT NULL DEFAULT '' COMMENT '工单id',
  `order_type` varchar(20) NOT NULL DEFAULT 'DISPATCH' COMMENT '工单类型',
  `order_title` varchar(100) DEFAULT NULL COMMENT '工单标题',
  `order_data` varchar(3000) COMMENT '工单数据',
  `cluster_name` varchar(20) NOT NULL DEFAULT '' COMMENT '集群名称',
  `operator` varchar(100) NOT NULL DEFAULT '' COMMENT '操作人',
  `status` varchar(20) DEFAULT 'NEW' COMMENT '工单状态',
  `gmt_create` datetime NOT NULL COMMENT '创建时间',
  `gmt_modified` datetime DEFAULT NULL COMMENT '修改时间',
  PRIMARY KEY (`id`),
  KEY `order_id` (`order_id`)
) ENGINE=InnoDB AUTO_INCREMENT=188 DEFAULT CHARSET=utf8 COMMENT='工单数据'
;

/******************************************/
/*   数据库全名 = alipay_dns   */
/*   表名称 = dns_resource_record_info   */
/******************************************/
CREATE TABLE `dns_resource_record_info` (
  `id` bigint(20) NOT NULL AUTO_INCREMENT COMMENT '主键',
  `owner` varchar(256) NOT NULL COMMENT '资源',
  `cluster_name` varchar(20) NOT NULL COMMENT '所属集群 冗余字段',
  `zone_name` varchar(255) NOT NULL DEFAULT '' COMMENT 'ZONE NAME',
  `view_group_name` varchar(60) DEFAULT '' COMMENT 'VIEW GRP name',
  `domain_group_name` varchar(60) DEFAULT NULL COMMENT '域名组',
  `idc_id` varchar(20) DEFAULT NULL COMMENT 'IDC ID',
  `rr_type` varchar(10) NOT NULL COMMENT '资源类型',
  `ttl` varchar(20) NOT NULL DEFAULT '' COMMENT 'TTL',
  `rr_class` varchar(12) NOT NULL DEFAULT '' COMMENT 'RECODR 类型',
  `data` varchar(500) NOT NULL COMMENT '数据',
  `status` varchar(10) DEFAULT NULL COMMENT '状态',
  `gmt_create` datetime NOT NULL COMMENT '创建时间',
  `gmt_modified` datetime DEFAULT NULL COMMENT '修改时间',
  PRIMARY KEY (`id`),
  KEY `rrdata` (`data`(383)),
  KEY `rrtype` (`rr_type`),
  KEY `owner` (`owner`),
  KEY `cluster` (`cluster_name`),
  KEY `zonename` (`zone_name`),
  KEY `viewgroupname` (`view_group_name`),
  KEY `domain_group_name` (`domain_group_name`),
  KEY `idc_id` (`idc_id`)
) ENGINE=InnoDB AUTO_INCREMENT=3048 DEFAULT CHARSET=utf8 COMMENT='dns 资源记录表'
;

/******************************************/
/*   数据库全名 = alipay_dns   */
/*   表名称 = dns_sequence_info   */
/******************************************/
CREATE TABLE `dns_sequence_info` (
  `id` bigint(20) NOT NULL AUTO_INCREMENT COMMENT '主键',
  `name` varchar(300) NOT NULL DEFAULT '' COMMENT '名称',
  `value` bigint(20) NOT NULL DEFAULT '0' COMMENT '值',
  `gmt_create` datetime DEFAULT NULL COMMENT '创建时间',
  `gmt_modified` datetime DEFAULT NULL COMMENT '修改时间',
  PRIMARY KEY (`id`),
  UNIQUE KEY `name` (`name`)
) ENGINE=InnoDB AUTO_INCREMENT=7 DEFAULT CHARSET=utf8 COMMENT='dns 配置文件版本号'
;

/******************************************/
/*   数据库全名 = alipay_dns   */
/*   表名称 = dns_server_dispatch_jnl_ref   */
/******************************************/
CREATE TABLE `dns_server_dispatch_jnl_ref` (
  `id` bigint(20) NOT NULL AUTO_INCREMENT COMMENT '主键',
  `server_ip` varchar(255) NOT NULL COMMENT 'master的ip',
  `cluster_name` varchar(20) NOT NULL COMMENT '所属集群',
  `zone_name` varchar(255) NOT NULL COMMENT '所属的zone',
  `dispatch_log_id` bigint(20) DEFAULT '0' COMMENT '所对应的下发单id',
  `log_jnl_id` bigint(20) DEFAULT '0' COMMENT '本次下发中,该zone最大的logJnl已处理状态的ID',
  `gmt_create` datetime NOT NULL COMMENT '创建时间',
  `gmt_modified` datetime NOT NULL COMMENT '修改时间',
  PRIMARY KEY (`id`),
  KEY `idx_server_ip` (`server_ip`),
  KEY `idx_zone_name` (`zone_name`)
) ENGINE=InnoDB AUTO_INCREMENT=517 DEFAULT CHARSET=utf8 COMMENT='用于标识下发机器当前最大的LogJnlId'
;

/******************************************/
/*   数据库全名 = alipay_dns   */
/*   表名称 = dns_step_builder_info   */
/******************************************/
CREATE TABLE `dns_step_builder_info` (
  `id` bigint(20) NOT NULL AUTO_INCREMENT COMMENT 'id',
  `type` varchar(10) NOT NULL DEFAULT '' COMMENT '类型',
  `ord` int(11) NOT NULL COMMENT '顺序',
  `name` varchar(20) DEFAULT NULL COMMENT '名称',
  `description` varchar(200) DEFAULT NULL COMMENT '描述',
  `processor_name` varchar(60) DEFAULT NULL COMMENT '处理器名称',
  `allow_skip` char(1) NOT NULL DEFAULT 'N' COMMENT '是否允许跳过',
  `auto_pause` int(11) NOT NULL DEFAULT '0' COMMENT '是否自动暂停',
  `gmt_create` datetime NOT NULL COMMENT '创建时间',
  `gmt_modified` datetime DEFAULT NULL COMMENT '修改时间',
  `order_type` varchar(100) DEFAULT 'dispatch' COMMENT '所属工单类型',
  PRIMARY KEY (`id`),
  KEY `type` (`type`)) ENGINE=InnoDB AUTO_INCREMENT=120 DEFAULT CHARSET=utf8 COMMENT='下发步骤构建';
/******************************************/
/*   数据库全名 = alipay_dns   */
/*   表名称 = dns_step_info   */
/******************************************/
CREATE TABLE `dns_step_info` (
  `id` bigint(20) NOT NULL AUTO_INCREMENT COMMENT 'id',
  `ord` int(11) NOT NULL COMMENT '顺序',
  `order_id` varchar(64) NOT NULL DEFAULT '' COMMENT '工单id',
  `task_id` bigint(20) NOT NULL COMMENT '关联的任务id',
  `step_set` bigint(20) NOT NULL DEFAULT '1' COMMENT '父步骤id',
  `name` varchar(20) DEFAULT NULL COMMENT '步骤名称',
  `description` varchar(3000) COMMENT '步骤描述',
  `required` char(1) NOT NULL DEFAULT 'N' COMMENT '是否需要执行',
  `selected` char(1) NOT NULL DEFAULT 'N' COMMENT '是否选择',
  `allow_skip` char(1) NOT NULL DEFAULT 'N' COMMENT '是否允许跳过',
  `processor_name` varchar(60) DEFAULT NULL COMMENT '处理器名称',
  `data` varchar(3000) COMMENT '数据',
  `result`varchar(3000)COMMENT '处理结果',
  `status` varchar(20) NOT NULL DEFAULT 'INITIAL' COMMENT 'INITIAL,RUNNING,SUCCESS,FAILED,CLOSED',
  `gmt_create` datetime NOT NULL COMMENT '创建时间',
  `gmt_modified` datetime DEFAULT NULL COMMENT '修改时间',
  `auto_pause` int(11) DEFAULT '0' COMMENT '自动暂停，-1：此步之前暂停，0：不暂停，1：此步之后暂停',
  PRIMARY KEY (`id`),
  KEY `task_id` (`task_id`),
  KEY `order_id` (`order_id`)
) ENGINE=InnoDB AUTO_INCREMENT=1011 DEFAULT CHARSET=utf8 COMMENT='执行步骤数据';

/******************************************/
/*   数据库全名 = alipay_dns   */
/*   表名称 = dns_sync_info   */
/******************************************/
CREATE TABLE `dns_sync_info` (
  `id` bigint(20) NOT NULL AUTO_INCREMENT COMMENT '主键',
  `data_key` varchar(100) NOT NULL COMMENT '数据键值',
  `data_value` varchar(3000) COMMENT '数据值',
  `gmt_create` datetime DEFAULT NULL COMMENT '创建时间',
  `gmt_modified` datetime DEFAULT NULL COMMENT '修改时间',
  PRIMARY KEY (`id`),
  UNIQUE KEY `data_key` (`data_key`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8 COMMENT='dns 同步数据'
;

/******************************************/
/*   数据库全名 = alipay_dns   */
/*   表名称 = dns_task_info   */
/******************************************/
CREATE TABLE `dns_task_info` (
  `id` bigint(20) NOT NULL AUTO_INCREMENT COMMENT '主键',
  `event_id` varchar(64) NOT NULL DEFAULT '' COMMENT '时间ID',
  `cluster_name` varchar(20) NOT NULL COMMENT '集群名',
  `task_type` varchar(20) NOT NULL DEFAULT '' COMMENT '任务类型',
  `task_smr` varchar(256) NOT NULL DEFAULT '' COMMENT '任务摘要',
  `task_content` varchar(3000) COMMENT '任务内容',
  `task_status` varchar(10) NOT NULL DEFAULT '' COMMENT '任务状态',
  `gmt_create` datetime NOT NULL COMMENT '创建时间',
  `gmt_modified` datetime NOT NULL COMMENT '修改时间',
  PRIMARY KEY (`id`),
  KEY `eventid` (`event_id`)
) ENGINE=InnoDB AUTO_INCREMENT=655 DEFAULT CHARSET=utf8 COMMENT='dns 任务列表'
;

/******************************************/
/*   数据库全名 = alipay_dns   */
/*   表名称 = dns_view_acl_ref   */
/******************************************/
CREATE TABLE `dns_view_acl_ref` (
  `id` int(11) NOT NULL AUTO_INCREMENT COMMENT 'id',
  `cluster_name` varchar(20) NOT NULL COMMENT '集群名称',
  `view_name` varchar(64) NOT NULL COMMENT 'view名称',
  `acl_key` varchar(64) NOT NULL COMMENT 'acl key',
  `flow_weight` int(11) NOT NULL COMMENT '权重',
  `gmt_create` datetime DEFAULT NULL COMMENT '创建时间',
  `gmt_modified` datetime DEFAULT NULL COMMENT '修改时间',
  PRIMARY KEY (`id`),
  UNIQUE KEY `acl` (`cluster_name`,`view_name`,`acl_key`)
) ENGINE=InnoDB AUTO_INCREMENT=73 DEFAULT CHARSET=utf8 COMMENT='view acl映射'
;

/******************************************/
/*   数据库全名 = alipay_dns   */
/*   表名称 = dns_view_info   */
/******************************************/
CREATE TABLE `dns_view_info` (
  `id` bigint(20) NOT NULL AUTO_INCREMENT COMMENT '主键',
  `view_name` varchar(64) NOT NULL DEFAULT '' COMMENT '线路名',
  `key_name` varchar(64) DEFAULT NULL COMMENT 'KEY NAME',
  `view_class` varchar(20) DEFAULT NULL COMMENT '类型',
  `view_desc` varchar(512) NOT NULL COMMENT 'VIEW 描述',
  `cluster_name` varchar(20) NOT NULL DEFAULT '' COMMENT '集群名',
  `match_clients_text` varchar(512) DEFAULT NULL COMMENT 'match-clients  文本形式',
  `match_destinations_text` varchar(512) DEFAULT NULL COMMENT 'match-destinations 文本形式',
  `allow_transfer_text` varchar(512) DEFAULT NULL COMMENT 'allow_transfer_text 文本形式',
  `match_recursive_only` varchar(10) DEFAULT NULL COMMENT 'match-recursive-only yes or no',
  `gmt_create` datetime NOT NULL COMMENT 'gmt_create 创建时间',
  `gmt_modified` datetime DEFAULT NULL COMMENT 'gmt_modified',
  `flow_weight` int(11) DEFAULT '0' COMMENT '权重',
  PRIMARY KEY (`id`),
  UNIQUE KEY `viewname` (`view_name`,`cluster_name`)
) ENGINE=InnoDB AUTO_INCREMENT=107 DEFAULT CHARSET=utf8 COMMENT='dns 线路信息'
;

/******************************************/
/*   数据库全名 = alipay_dns   */
/*   表名称 = dns_vip_info   */
/******************************************/
CREATE TABLE `dns_vip_info` (
  `id` bigint(20) NOT NULL AUTO_INCREMENT COMMENT '主键',
  `address` varchar(64) NOT NULL DEFAULT '' COMMENT 'IP地址',
  `cluster_name` varchar(20) NOT NULL DEFAULT '' COMMENT '集群名',
  `idc_id` varchar(10) DEFAULT '' COMMENT '所属IDC',
  `addr_type` varchar(10) NOT NULL DEFAULT 'V4' COMMENT '地址类型：V4/V6',
  `hc_tpl_group_id` bigint(20) DEFAULT NULL COMMENT '健康检测模板组',
  `status` varchar(10) DEFAULT '' COMMENT '状态',
  `gmt_create` datetime DEFAULT NULL COMMENT '创建时间',
  `gmt_modified` datetime DEFAULT NULL COMMENT '修改时间',
  PRIMARY KEY (`id`),
  UNIQUE KEY `cluster_address` (`address`,`cluster_name`),
  KEY `idcid` (`idc_id`),
  KEY `address` (`address`),
  KEY `cluster` (`cluster_name`)
) ENGINE=InnoDB AUTO_INCREMENT=593052 DEFAULT CHARSET=utf8 COMMENT='dns vip元数据信息'
;

/******************************************/
/*   数据库全名 = alipay_dns   */
/*   表名称 = dns_zone_info   */
/******************************************/
CREATE TABLE `dns_zone_info` (
  `id` bigint(20) NOT NULL AUTO_INCREMENT COMMENT 'id',
  `cluster_name` varchar(20) NOT NULL COMMENT '集群名字',
  `zone_name` varchar(255) NOT NULL DEFAULT '' COMMENT 'ZONE NAME',
  `soa_save_mode` varchar(10) NOT NULL COMMENT 'SOA 保存方式',
  `operator` varchar(60) DEFAULT NULL COMMENT 'zone信息是否可更改',
  `gmt_create` datetime NOT NULL COMMENT '创建时间',
  `gmt_modified` datetime DEFAULT NULL COMMENT '修改时间',
  `rest_ops` varchar(10) DEFAULT 'Y' COMMENT '是否支持rest操作',
  `rely_db` varchar(10) DEFAULT 'Y' COMMENT '是否强依赖DB',
  `inverse` varchar(10) DEFAULT 'N' COMMENT '是否支持反解',
  PRIMARY KEY (`id`),
  UNIQUE KEY `zonename` (`cluster_name`,`zone_name`)
) ENGINE=InnoDB AUTO_INCREMENT=340 DEFAULT CHARSET=utf8 COMMENT='dns zone信息'
;

/******************************************/
/*   数据库全名 = alipay_dns   */
/*   表名称 = dns_zone_soa_info   */
/******************************************/
CREATE TABLE `dns_zone_soa_info` (
  `id` bigint(20) NOT NULL AUTO_INCREMENT COMMENT 'id',
  `cluster_name` varchar(20) NOT NULL COMMENT '集群名字',
  `view_name` varchar(64) NOT NULL COMMENT '线路',
  `zone_name` varchar(255) NOT NULL DEFAULT '' COMMENT 'ZONE NAME',
  `serial` bigint(20) NOT NULL COMMENT 'serial',
  `refresh` varchar(20) NOT NULL DEFAULT '' COMMENT 'refresh',
  `ttl` varchar(20) NOT NULL DEFAULT '' COMMENT 'ttl',
  `email` varchar(128) NOT NULL DEFAULT '' COMMENT 'email',
  `retry` bigint(20) NOT NULL COMMENT 'retry',
  `expire` varchar(20) NOT NULL DEFAULT '' COMMENT 'expire',
  `ns_json` varchar(3000) COMMENT 'zone ns list json 格式 标准dns record 结构',
  `minimum` bigint(20) NOT NULL COMMENT 'minimum',
  `gmt_create` datetime NOT NULL COMMENT '创建时间',
  `gmt_modified` datetime DEFAULT NULL COMMENT '修改时间',
  PRIMARY KEY (`id`),
  UNIQUE KEY `zonename` (`cluster_name`,`view_name`,`zone_name`)
) ENGINE=InnoDB AUTO_INCREMENT=339 DEFAULT CHARSET=utf8 COMMENT='dns soa信息'
;
