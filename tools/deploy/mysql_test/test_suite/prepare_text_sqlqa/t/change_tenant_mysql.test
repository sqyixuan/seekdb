--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: luofan.zp
#owner group: sql2
connect (my_obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);

--echo #测试session上没有打开过prepared stmt可以正常切租户
connection my_obsys;
alter system change tenant sys;
alter system change tenant sys;

--echo #测试session上打开过prepared stmt禁止切租户
prepare stmt from 'select 1 from dual';
#--error 4179
alter system change tenant sys;
deallocate prepare stmt;
alter system change tenant sys;
alter system change tenant sys;

--echo #测试通过ps执行切租户
prepare stmt from 'alter system change tenant sys';
#--error 4179
execute stmt;

disconnect my_obsys;
