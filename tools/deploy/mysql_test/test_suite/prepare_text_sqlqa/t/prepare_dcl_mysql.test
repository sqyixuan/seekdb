purge recyclebin;
let $char_charset = 'utf8';
--disable_warnings
drop database IF EXISTS oblrp;
--enable_warnings
create database oblrp;
use oblrp;
set timestamp = 1600000000;
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;
--result_format 4
--error 0,1051
drop table tt1;
create table tt1(id int,a varchar(20),d date);
insert into tt1 values(1,'test01','2022-3-2');
insert into tt1 values(2,'test02','2022-3-3');
insert into tt1 values(3,'test03','2022-3-3');
--error 0,1051
drop table tt2;
create table tt2(id int,a varchar(20),d date);
insert into tt2 values(3,'test03','2022-3-2');
--error 0,1051
drop table tt3;
create table tt3(id int,a varchar(20),d date);
--error 0,1396
drop USER obsqluser01;
CREATE USER 'obsqluser01' IDENTIFIED BY '123456';
--echo ob_mysql_prepare_text_2_3

prepare st1 from 'GRANT ALL PRIVILEGES ON *.* TO obsqluser01 WITH GRANT OPTION';
execute st1;
deallocate prepare st1;
--error 0,1396
drop USER sqluser01;
CREATE USER 'sqluser01' IDENTIFIED BY '123456';
prepare st1 from 'GRANT ALL PRIVILEGES ON *.* TO obsqluser01 WITH GRANT OPTION';
execute st1;
deallocate prepare st1;
--error 1064
prepare st1 from "grant select on test.* to sqluser01@?";

prepare st1 from "set @a=1,@b='test'";
select @a,@b;
execute st1;
select @a,@b;
drop prepare st1;
--error 1243
deallocate prepare st1;

prepare st1 from "set @a=?,@b=?,@c=?";
set @a=1,@b='test',@c='2010-10-10';
execute st1 using @a,@b,@c;
select @a,@b,@c;
deallocate prepare st1;

set @e='set @a=?,@b=?,@c=?';
prepare st1 from @e;
set @a=1,@b='test',@c='2010-10-10';
execute st1 using @a,@b,@c;
select @a,@b,@c;
deallocate prepare st1;

set @e='set @a="test",@b="2011-12-12",@c=3';
prepare st1 from @e;
execute st1 ;
select @a,@b,@c;
deallocate prepare st1;

--error 1243
drop prepare st1;

prepare st1 from "SET @proxy_route_policy = ?";
set @a='follower_first';
execute st1 using @a;
deallocate prepare st1;

--error 1064
prepare st1 from "SET charset ?";
prepare st1 from "SET charset 'gbk'";
execute st1;
deallocate prepare st1;
set @e='set @a="test",@b="2011-12-12",@c=3';
prepare st1 from @e;
execute st1 ;
select @a,@b,@c;
deallocate prepare st1;
prepare st1 from "SET charset 'utf8'";
execute st1;
deallocate prepare st1;

prepare st1 from "SET names 'gbk'";
execute st1;
deallocate prepare st1;
prepare st1 from "SET names 'gb18030'";
execute st1;
deallocate prepare st1;
prepare st1 from "SET names 'utf8'";
execute st1;
deallocate prepare st1;
prepare st1 from "SET names 'utf8mb4'";
execute st1;
deallocate prepare st1;
--error 0,1396
drop USER sqluser02;
CREATE USER 'sqluser02' IDENTIFIED BY '8888888';
set @a="SET PASSWORD FOR sqluser02 = PASSWORD('123456')";
prepare st1 from @a;
execute st1;
deallocate prepare st1;
set @a="SET PASSWORD FOR sqluser02 = PASSWORD('?')";
prepare st1 from @a;
set @b=666666;
--error 1210
execute st1 using @b;
deallocate prepare st1;



prepare st1 from 'SET TRANSACTION ISOLATION LEVEL READ COMMITTED';
execute st1;
deallocate prepare st1;

#prepare st1 from 'SHOW DATABASES';
#execute st1;
#deallocate prepare st1;

prepare st1 from 'SHOW tables';
execute st1;
deallocate prepare st1;

prepare st1 from 'SHOW CHARSET';
execute st1;
deallocate prepare st1;

prepare st1 from 'SHOW SESSION STATUS';
#execute st1;
deallocate prepare st1;

#prepare st1 from 'SHOW PRIVILEGES';
#execute st1;
#deallocate prepare st1;

prepare st1 from 'SHOW RECYCLEBIN';
#execute st1;
#deallocate prepare st1;

prepare st1 from 'commit';
execute st1;
deallocate prepare st1;
--error 0,1396
drop USER u1;
CREATE USER 'u1' IDENTIFIED BY '8888888';
GRANT ALL PRIVILEGES ON *.* TO u1;
prepare st1 from 'REVOKE SELECT ON *.* FROM u1';
execute st1;
deallocate prepare st1;


--disable_warnings
drop database  IF EXISTS  oblrp1;
--enable_warnings
