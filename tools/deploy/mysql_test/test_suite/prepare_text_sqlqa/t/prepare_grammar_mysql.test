purge recyclebin;
let $char_charset = 'utf8';
--disable_warnings
drop database IF EXISTS oblrp;
--enable_warnings
create database oblrp;
use oblrp;
set timestamp = 1600000000;
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;
--result_format 4

--error 0,1051
drop table tt1;
create table tt1(id int,a varchar(20),d date);
insert into tt1 values(1,'test01','2022-3-2');
insert into tt1 values(2,'test02','2022-3-3');
insert into tt1 values(3,'test03','2022-3-3');
--error 0,1051
drop table tt2;
create table tt2(id int,a varchar(20),d date);
insert into tt2 values(3,'test03','2022-3-2');
--error 0,1051
drop table tt3;
create table tt3(id int,a varchar(20),d date);
insert into tt3 values(3,'test03','2022-3-2');

--echo ob_mysql_prepare_text_1
prepare st1 from 'select 1';
execute st1;
execute st1;
prepare st1 from 'select * from tt1';
execute st1;
prepare st2 from 'select * from tt1';
execute st2;
execute st2;
execute st2;
execute st2;
execute st2;
DEALLOCATE PREPARE st1;
--error 1243
execute st1;
execute st2;
--error 1243
DEALLOCATE PREPARE st1;
DEALLOCATE PREPARE st2;
--error 1064
prepare st1 from select 1 from dual;
--error 1064
prepare 'st1' from 'select 1';
--error 1064
prepare 8985934 from 'select 1';
--error 1064
prepare (_) from 'select 1';
prepare a_4 from 'select 2';
execute a_4;
DEALLOCATE PREPARE a_4;
prepare st19888jkjdkfjdfjjdfjjdfjdkjfdkjdfkjdsdsf from 'select 1';
execute st19888jkjdkfjdfjjdfjjdfjdkjfdkjdfkjdsdsf;
DEALLOCATE PREPARE st19888jkjdkfjdfjjdfjjdfjdkjfdkjdfkjdsdsf;
set @a='select id,a,d from tt3';
prepare st1 from @a;
execute st1;
--error 1243
execute st3;
deallocate prepare st1;
set @a='select * from tt1 where id=?';
prepare st1 from @a;
set @b=1;
execute st1 using @b;
--error 1064
execute st1 using 1;
DEALLOCATE PREPARE st1;
PREPARE st1 FROM 'SELECT SQRT(POW(?,2) + POW(?,2)) AS hypotenuse';
set @a=(select 3),@b=(select 4);
execute st1 using @a,@b;
DEALLOCATE PREPARE st1;

PREPARE st1 FROM 'SELECT ? from tt1';
set @a='id';
execute st1 using @a;
set @b=4;
execute st1 using @b;
DEALLOCATE PREPARE st1;

PREPARE st1 FROM 'SELECT * from tt1';
set @b=4;
--error 1210
execute st1 using @b;
execute st1;
DEALLOCATE PREPARE st1;
--error 1064
PREPARE st1 FROM 'SELECT % from tt1';

PREPARE st1 FROM "insert into tt1 values(1,'test01','2022-3-29')";
execute st1;
select * from tt1 order by 1;
DEALLOCATE PREPARE st1;

PREPARE st1 FROM "insert into tt1 values(1,'test01','2022-3-29')";
execute st1;
select * from tt1 order by 1;
drop PREPARE st1;
--error 1243
execute st1;
--error 1243
drop PREPARE st1;

set @c='update tt1 set id=?,a=?,d=?';
PREPARE st1 FROM @c;
set @id=5;
set @a=(select 'xiaolai');
set @d=(select '2019-12-12');
--error 1210
execute st1;
--error 1366
execute st1 using @a,@b,@id;
execute st1 using @id,@a,@d;
select * from tt1 order by 1;
DEALLOCATE PREPARE st1;
--error 1064
PREPARE st1 FROM 'delete from tt1 where id=!';
PREPARE st1 FROM 'delete from tt1 where id=?';
set @id=5;
execute  st1 using @id;
select * from tt1 order by 1;

PREPARE st1 FROM 'create table tt4(id int)';
execute st1;
select * from tt4;
DEALLOCATE PREPARE st1;

set @a='ALTER TABLE tt1 ADD id02 INTEGER ';
PREPARE st1 FROM @a;
execute st1;
desc tt1;
DEALLOCATE PREPARE st1;

PREPARE st1 FROM 'drop table tt4';
execute st1;
--error 1146
desc tt4;
DEALLOCATE PREPARE st1;

PREPARE st1 FROM 'set @b=1';
execute st1;
select @b;
DEALLOCATE PREPARE st1;
set @c='set @b=5';
PREPARE st1 FROM @c;
execute st1;
select @b;
DEALLOCATE PREPARE st1;

PREPARE st1 FROM 'commit';
execute st1;
DEALLOCATE PREPARE st1;

PREPARE st1 FROM 'show tables';
execute st1;
DEALLOCATE PREPARE st1;

set @t='tt2';
SET @s = CONCAT('SELECT * FROM ', @t);
PREPARE st1 FROM @s;
execute st1;
