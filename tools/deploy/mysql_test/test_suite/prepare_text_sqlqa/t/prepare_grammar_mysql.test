prepare st1 from @A;
execute st1;

prepare st1 from 'select ?';
set @a=11;
execute st1 using @a;
set @a=now();
execute st1 using @a;
set @a=abs(10);
execute st1 using @a;
drop prepare st1;
--error 1243
deallocate prepare st1;

prepare st1 from 'select 10';
deallocate prepare st1;
--error 1243
execute st1;

prepare st1 from 'select ?';
drop prepare st1;
set @a='test';
--error 1243
execute st1 using @a;

