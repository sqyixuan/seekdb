deallocate prepare st1;
#select * from tt1 order by id,a,d;
prepare st1 from "replace into tt1 values('1',?,'2010-10-1')";
set @a='测试';
execute st1 using @a;
deallocate prepare st1;
#select * from tt1 order by id,a,d;
prepare st1 from "update tt1 set a ='测试' where id =1";
execute st1;
#select * from tt1 order by id,a,d;
deallocate prepare st1;
prepare st1 from "update tt1 set a =? where id =1";
set @a='数据';
execute st1 using @a;
deallocate prepare st1;
#select * from tt1 order by id,a,d;

prepare st1 from "delete from tt1 where a='数据' limit 2";
execute st1;
deallocate prepare st1;
#select * from tt1 order by id,a,d;

prepare st1 from "delete from tt1 where a=? limit ?";
set @a='数据';
set @b =1;
execute st1 using @a,@b;
deallocate prepare st1;
