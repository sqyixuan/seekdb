--error 0,1305
drop PROCEDURE p_test01;
delimiter //;
CREATE  PROCEDURE p_test01(in a int,out b varchar(20))
begin
if a>1 then
 prepare st1 from 'select 10';
 execute st1;
 deallocate prepare st1;
 prepare st1 from 'select ?';
 set @a=8;
 execute st1 using @a;
 deallocate prepare st1;
 elseif a=1 then
 prepare st1 from "insert into tt1 values(1,'test02','2020-10-10')";
 execute st1;
 deallocate prepare st1;
 prepare st1 from "insert into tt1 values(?,?,'2020-10-10')";
 set @e='10',@t='test';
 execute st1 using @e,@t;
 deallocate prepare st1;
 else
 prepare st1 from 'create table tt4(id int, a varchar(20), d date)';
 execute st1;
 deallocate prepare st1;
 prepare st1 from "insert into tt4 values(1,'test','2020-10-10')";
 execute st1;
 deallocate prepare st1;
 set @q='delete from tt4 where a=? and d=?';
 prepare st1 from @q;
 set @a='test';
 set @d='2010-10-10';
 execute st1 using @a,@d ;
 deallocate prepare st1;
 prepare st1 from "drop table tt4";
 execute st1;
 deallocate prepare st1;
 end if;
 select 'select ?' into b;
 end;
//
delimiter ;//
call p_test01(2,@b);
call p_test01(1,@b);
call p_test01(0,@b);
prepare st1 from @b;
set @a=2;
execute st1 using @a;
deallocate prepare st1;

