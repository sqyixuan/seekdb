CREATE  PROCEDURE p_test01(in s varchar(50))
begin
 declare i int;
  set i=0;
  loop_label:loop
  set i=i+1;
  if i>=5 then 
       leave loop_label;
	   end if;
  prepare st1 from 'create table tt4(id int, a varchar(20), d date)';
 execute st1;
 deallocate prepare st1;
 prepare st1 from "insert into tt4 values(1,'test','2020-10-10')";
 execute st1;
 deallocate prepare st1;
 set @q='delete from tt4 where a=? and d=?';
 prepare st1 from @q;
 set @a='test';
 set @d='2010-10-10';
 execute st1 using @a,@d ;
 deallocate prepare st1;
 prepare st1 from "drop table tt4";
 execute st1;
 deallocate prepare st1;
 set @s=s;
 prepare st1 from @s;
execute st1;
deallocate prepare st1;
  end loop;
 end;
