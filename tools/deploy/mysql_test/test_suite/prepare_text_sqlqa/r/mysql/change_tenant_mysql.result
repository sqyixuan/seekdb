#测试session上没有打开过prepared stmt可以正常切租户
alter system change tenant sys;
alter system change tenant sys;
#测试session上打开过prepared stmt禁止切租户
prepare stmt from 'select 1 from dual';
alter system change tenant sys;
deallocate prepare stmt;
alter system change tenant sys;
alter system change tenant sys;
#测试通过ps执行切租户
prepare stmt from 'alter system change tenant sys';
execute stmt;
