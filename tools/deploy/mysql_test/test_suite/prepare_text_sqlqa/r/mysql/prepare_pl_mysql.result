deallocate prepare st2;
DROP PROCEDURE p_test01;
CREATE  PROCEDURE p_test01()
begin
prepare st1 from 'select 10';
prepare st1 from 'select abs(?)';
set @b=12;
execute st1 using @b;
drop prepare st1;
end;
//
call p_test01();
