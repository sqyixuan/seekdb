CREATE  PROCEDURE p_test01(in a int)
begin
 while @i<=2 do
 prepare st1 from 'select 10';
 execute st1;
 deallocate prepare st1;
 prepare st1 from 'select ?';
 set @a=8;
 execute st1 using @a;
 deallocate prepare st1;
 set @i=@i+1;
 end while;
 end;
