drop table t2 ;
create table t2 (s2 double,s3 double);
insert into t2 values (1.1,1.4);
insert into t2 values (2,2.5);
insert into t2 values (3,null);
select random_bytes(t1.s3) from t1 join t2 on t1.s2=t2.s2;
select * from t1 join t2 on t1.s2=t2.s2 where random_bytes(t1.s3)>0;
select random_bytes(t1.s3) from t1 join t2 on random_bytes(t1.s2)=t2.s2;
select random_bytes(t1.s3) from t1 right join t2 on t1.s2=t2.s2;
select random_bytes(t1.s3) from t1 left join t2 on t1.s2=t2.s2;
select random_bytes(t1.s3) from t1 cross join t2 on t1.s2=t2.s2;
