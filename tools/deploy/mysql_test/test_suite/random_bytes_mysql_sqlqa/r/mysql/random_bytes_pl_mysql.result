#update
drop table t1 ;
create table t1 (s2 char(20),s3 int);
insert into t1 values (1,2);
insert into t1 values (2,3);
drop trigger tr;
create trigger tr before update on t1 for each row
begin
if new.s2 is null then
set new.s2 =  random_bytes(old.s2) ;
elseif new.s2 < 0 then
set new.s2 = abs(new.s2);
end if;
end/
update t1 set s2=random_bytes(null) where s2=1;
select * from t1;
#delete
drop table t1 ;
create table t1 (s2 char(20),s3 int);
insert into t1 values (1,2);
insert into t1 values (2,3);
drop trigger tr;
create trigger tr before delete on t1 for each row
begin
set @aa= random_bytes(old.s2) ;

end/
delete from  t1  where s2=1;
select * from t1;
select @aa;
游标
drop table t1 ;
create table t1 (
 s1 int,
 s2 char(20),
 s3 time,
 s4 binary(20),
 s5 set('1','5','4')
 );
insert into t1 values (1,'1','0102',1,1);
insert into t1 values (2.6,'2.6','0102',2.6,3);
insert into t1 values (null,null,null,null,null);
drop procedure processorders;
create procedure processorders()
begin
declare aa binary(20);
declare rc int;
declare i int default 1;
declare cur cursor for select random_bytes(s4) from t1 ;
select count(*)  into rc from t1;
open cur;
 while i < rc do
fetch cur into aa;
set i = i + 1;
select aa;
end while;
close cur;

end/
call processorders();
动态sql
drop table t1 ;
create table t1 (
 s1 int,
 s2 char(20),
 s3 time,
 s4 binary(20),
 s5 set('1','5','4')
 );
insert into t1 values (1,'1','0102',1,1);
insert into t1 values (2.6,'2.6','0102',2.6,3);
insert into t1 values (null,null,null,null,null);
drop procedure agm;
create procedure agm(in func char(50),in order_param varchar(10),in anchor int,in size int)
begin
	set @s = concat("select " ,func, "from t1 order by ",order_param," limit ",anchor,",",size);
	prepare stmt from @s;
	execute stmt;
	deallocate prepare stmt;
end/
call agm('random_bytes(s1)','s1',1,5);
call agm('random_bytes(s2)','s1',1,5);
call agm('random_bytes(s3)','s1',1,5);
call agm('random_bytes(s4)','s1',1,5);
call agm('random_bytes(s5)','s1',1,5);
call agm('length(random_bytes(s1))','s1',1,5);
#44958137 动态sql小数进位方式
call agm('length(random_bytes(s2))','s1',1,5);
call agm('length(random_bytes(s3))','s1',1,5);
call agm('length(random_bytes(s4))','s1',1,5);
call agm('length(random_bytes(s5))','s1',1,5);
