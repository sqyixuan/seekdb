set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;
drop database IF EXISTS nxa;
create database nxa  character set utf8;
use nxa;
set ob_enable_plan_cache=0;
set@@sql_mode='STRICT_ALL_TABLES,NO_ZERO_DATE,NO_ZERO_IN_DATE,ERROR_FOR_DIVISION_BY_ZERO ';
result_format: 4
数据类型传参
set names 'utf8mb4';
drop table t1;
create table t1 
(tt tinyint,
 ft float,
 dle double,
 dl decimal(10,7),
 bi bit(5),

 te time,
 cr char(30),
 txt text,
 em enum('春','2'),
 se set('1','2','3'),
 bry binary(10),
 bb blob)
 default charset=utf8mb4 collate=utf8mb4_general_ci;
insert into t1 values
(5,7.345,1.54526,3.2984,b'11',
001024,
'4','4',
'2','4',2,1);
drop procedure p1;
create procedure p1()
BEGIN
select tt  into @a from t1;
select ft  into @b from t1;
select dle into @c from t1;
select dl  into @d from t1;
select bi  into @e from t1;
select te  into @f from t1;
select cr  into @g from t1;
select txt into @h from t1;

select em  into @aa from t1;
select se  into @bb from t1;
select bry into @cc from t1;
select bb  into @dd from t1;

end;
/
call p1();
select length(random_bytes(@a ));
select length(random_bytes(@b ));
#44958137 小数进位方式类型结果不一致
select length(random_bytes(@c ));
select length(random_bytes(@d ));
select length(random_bytes(@e ));
select length(random_bytes(@f ));
select length(random_bytes(@g ));
select length(random_bytes(@h ));
select length(random_bytes(@aa));
select length(random_bytes(@bb));
#44953004 二进制类型结果不一致
select length(random_bytes(@cc));
select length(random_bytes(@dd));
无参
drop table t1 ;
create table t1 (s2 double,s3 double);
insert into t1 values (1.1,1.4);
insert into t1 values (2,2.5);
insert into t1 values (3,null);
insert into t1 values (1.45,6);
set @dd=1;
drop function n_1;
create function n_1() returns char(50) 
begin
  declare a char(20);
  set a=random_bytes(@dd);
  select random_bytes(s2) into @a from t1 limit 1;

  return 1;
end/
select n_1();
select @a;
#44953004通过pl将random_bytes随机返回的非数字结果传入外部random_bytes()参数中，ob没有按预期报错
select random_bytes(@a);
有参
drop table t1 ;
create table t1 (s2 double,s3 double);
insert into t1 values (1.1,1.4);
insert into t1 values (2,2.5);
drop function n_1;
create function n_1(a char(30)) returns char(30)
begin
  select s3 into @a from t1 order by s2 limit 1;
  return a;
end/
select random_bytes(n_1(1)),length(random_bytes(@a));
#case when
drop table t1 ;
create table t1 (s2 int,s3 int);
insert into t1 values (1,2);
insert into t1 values (2,3);
drop function n_1;
create function n_1(a int) 
returns char(20)
begin
declare week char(20);
case a
when 2 then set week=random_bytes(a);

else set week=random_bytes(1);
end case;
return week;
end/
select n_1(s2) from t1;
drop table t1 ;
create table t1 (s2 int,s3 int);
insert into t1 values (1,2);
insert into t1 values (2,3);
drop function n_1;
create function n_1(a int) 
returns char(20)
begin
declare week char(20);
case random_bytes(a)
when 2 then set week=a;

else set week=random_bytes(a);
end case;
return week;
end/
select n_1(s2) from t1;
# if
drop table t1 ;
create table t1 (s2 int,s3 int);
insert into t1 values (1,1);
insert into t1 values (2,3);
drop table t2 ;
create table t2 (s2 int,s3 int);
drop function n_1;
create function n_1(a int,b int)
returns int
begin
if a!=random_bytes(b) then 
insert into t2 values(3,0);
else 
insert into t2 values(5,1);
end if;
return 6;
end/
select n_1(s2,s3) from t1  ;
select * from t2;
#procedure
#in
drop procedure prre;
create procedure prre(in a char(20),in b char(20))
begin
declare aa char(20);
  set @aa=9;
  set aa=9;
    if a >= b then
      set @aa =  random_bytes(2);
      set aa=  random_bytes(1);
    else
      set @aa = 0;
    end if;
select aa;
end/
call prre(random_bytes(1),random_bytes(2));
#out
drop procedure p1;
create procedure p1(out ia char(20)) 
BEGIN
	select random_bytes(1) into ia ;
END/
call p1(@bb);
select @bb;
#inout
drop procedure if exists p1;
create procedure p1(inout ia char(20),inout ib char(20)) 
BEGIN
	select random_bytes(1) into ia ;
	select ib;
END/
set @hh = random_bytes(1);
call p1(@qq,@hh);
select @qq;
#trigger
#insert
drop table t1 ;
create table t1 (s2 char(20),s3 int);
insert into t1 values (1,2);
insert into t1 values (2,3);
drop trigger tr;
create trigger tr before insert on t1 for each row
begin
if new.s2 is null then
set new.s2 = (select max(s2) from t1);
elseif new.s2 < 0 then
set new.s2 = abs(new.s2);
end if;
end/
insert into t1(s2) values(random_bytes(1));
select * from t1;
drop table t2 ;
create table t2 (s2 char(20),s3 int);
insert into t2 values (1,2);
insert into t2 values (2,3);
drop table t1 ;
create table t1 (s2 char(20),s3 int);
insert into t1 values (1,2);
insert into t1 values (2,3);
drop trigger tr;
create trigger tr before insert on t1 for each row
begin
if new.s2 is null then
set new.s2 = (select random_bytes(s2) from t2 limit 1);
elseif new.s2 < 0 then
set new.s2 = abs(new.s2);
end if;
end/
insert into t1(s2) values(random_bytes(null));
