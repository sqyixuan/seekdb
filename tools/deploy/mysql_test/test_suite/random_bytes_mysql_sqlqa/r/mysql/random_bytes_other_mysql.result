set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;
drop database IF EXISTS nxa;
create database nxa  character set utf8;
use nxa;
set ob_enable_plan_cache=0;
set@@sql_mode='STRICT_ALL_TABLES,NO_ZERO_DATE,NO_ZERO_IN_DATE,ERROR_FOR_DIVISION_BY_ZERO ';
result_format: 4
#索引
drop procedure initData;
create procedure initData()
begin
declare count int default 1;
while count <= 20 DO
 insert into t1 (id,s1,s2) values (count,count,count); 
 set count = count +1;
end while;
end;
/
#普通索引
drop table t1;
create table t1(id binary(20),s1 char(20), s2 blob);
call initData();
create index t1_id on t1(id);
create index t1_s1 on t1(s1);
select random_bytes(id) from t1 where random_bytes(s1)=15;
#unique
drop table t1;
create table t1(id binary(20),s1 char(20), s2 blob);
call initData();
create unique index t1_id on t1(id);
create unique index t1_s1 on t1(s1);
select random_bytes(id) from t1 where random_bytes(s1)=15;
#组合索引
drop table t1;
create table t1(id binary(20),s1 char(20), s2 binary(33),s3 blob);
call initData();
create  index t1_id on t1(id,s1,s2);
select random_bytes(id) from t1 where random_bytes(s1)=15;
#约束
#虚拟列
drop table t1;
create table t1(id binary(20),s1 char(20), bao binary(100) GENERATED ALWAYS AS (id) VIRTUAL);
insert into t1(id,s1) values (1,1),(5,1);
select random_bytes(bao),length(random_bytes(bao)) from t1;
#44924589 函数在VIRTUAL生成列中时，ob报4016 (HY000): Internal error
drop table t1;
create table t1(id binary(20),s1 char(20), bao binary(10) GENERATED ALWAYS AS (random_bytes(1)) VIRTUAL);
#存储列
create table t1(id binary(20),s1 char(20), bao char(20) GENERATED ALWAYS AS (id) STORED);
insert into t1(id,s1) values (1,1),(5,1);
select random_bytes(bao),length(random_bytes(bao)) from t1;
#44924589 函数在VIRTUAL生成列中时，ob报4016 (HY000): Internal error
drop table t1;
create table t1(id binary(20),s1 char(20), bao binary(10) GENERATED ALWAYS AS (random_bytes(1)) STORED);
#unsigned zerofill
create table t1 (s1 int unsigned zerofill) ;
insert into t1 values (1);
insert into t1 values (10);
select * from t1;
select length(random_bytes(s1)),random_bytes(s1) from t1;
drop table t1;
create table t1 (s1 int unsigned zerofill) ;
insert into t1 values (random_bytes(1));
select * from t1;
#unique
drop table t1;
create table t1 (s1 char(20) unique,s2 int) ;
insert into t1 values (1,2);
insert into t1 values (10,4);
select length(random_bytes(s1)),random_bytes(s1) from t1;
insert into t1(s1) values (random_bytes(1));
select * from t1;
#not null
drop table t1;
create table t1 (s1 binary(20) not null,s2 int);
insert into t1 values (1,2);
insert into t1 values (10,4);
select length(random_bytes(s1)),random_bytes(s1) from t1;
insert into t1(s1) values (random_bytes(2));
insert into t1(s1) values (random_bytes (null));
#check
drop table t1;
create table t1 (s1 char(20)  check(random_bytes(s1) >1) ,s2 int);
insert into t1 values (2,2);
insert into t1(s1) values (random_bytes(s1));
select * from t1;
drop table t1;
create table t1 (s1 binary(20)  check(s1 >0) ,s2 int);
insert into t1(s1) values (random_bytes(1));
select * from t1;
#44923288 二进制,字符串,枚举字段和random_bytes()函数值对比报内部错误
drop table t1;
create table t1 (s1 int  check(s1 <random_bytes(1)) ,s2 int);
insert into t1(s1) values (0);
select * from t1;
drop table t1;
create table t1 (s1 year  check(s1 <random_bytes(1)) ,s2 int);
insert into t1(s1) values (0);
select * from t1;
drop table t1;
create table t1 (s1 date  check(s1 <random_bytes(1)) ,s2 int);
insert into t1(s1) values (0);
select * from t1;
drop table t1;
create table t1 (s1 set('1','6')  check(s1 <random_bytes(1)) ,s2 int);
drop table t1;
create table t1 (s1 binary(20)  check(s1 <random_bytes(1)) ,s2 int);
drop table t1;
create table t1 (s1 char(20)  check(s1 <random_bytes(1)) ,s2 int);
#default
drop table t1;
create table t1 (s1 int default 10 ,s2 binary(20) default 10 );
insert into t1(s1) values(1);
insert into t1(s2) values(1);
select length(random_bytes(s1)),random_bytes(s1) from t1;
select length(random_bytes(s2)),random_bytes(s2) from t1;
drop table t1;
create table t1 (s1 int default 10 ,s2 binary(20) default 10 );
insert into t1(s2) values (random_bytes (1));
select * from t1;
insert into t1(s1) values (random_bytes (null));
select * from t1;
select random_bytes(s1) from t1;
#外键
drop table t3;
drop table t1;
create table t1(id binary(20) primary key, s1 int, s2 int);
insert into t1 values(1,1,3),(5,1,0),(3,1,0),(9,1,0),(2,7,0);
create table t3(bid binary(20) ,s1 int, s2 int,foreign key (bid) references t1(id));
INSERT INTO t3 VALUES(3,1,3),(1,6,0),(1,6,0),(2,7,0);
select length(random_bytes(bid)),random_bytes(bid) from t3;
select length(random_bytes(id)),random_bytes(id) from t1;
insert into t1(id) values (random_bytes(1));
select * from t1;
insert into t3(bid) values (random_bytes(1));
insert into t3(bid) values (random_bytes(bid));
select * from t3;
drop table t3 ;
#视图
drop table t1 ;
create table t1 (
 s1 int,
 s2 char(20),
 s3 time,
 s4 binary(20),
 s5 set('1','5','4')
 );
insert into t1 values (1,'1','0102',2,1);
insert into t1 values (2.6,'2.6','0102',2.6,3);
insert into t1 values (null,null,null,null,null);
drop view v1;
create view v1 as select *,s1 dd  from t1;
#44958137 从视图中传入小数，结果也有进位问题
select length(random_bytes(s1)) from v1;
select length(random_bytes(s2)) from v1;
select length(random_bytes(s3)) from v1;
select length(random_bytes(s4)) from v1;
select length(random_bytes(s5)) from v1;
select length(random_bytes(dd)) from v1;
#insert
drop view v1;
create view v1 as select *  from t1;
insert into v1 values (5,'5','0102',5,5);
select * from v1;
select length(random_bytes(s1)) from v1 order by s1 desc limit 1;
select length(random_bytes(s2)) from v1 order by s1 desc limit 1;
select length(random_bytes(s3)) from v1 order by s1 desc limit 1;
select length(random_bytes(s4)) from v1 order by s1 desc limit 1;
select length(random_bytes(s5)) from v1 order by s1 desc limit 1;
drop view v1;
create view v1 as select * from t1;
select * from v1;
insert into v1 values (6,'6','0102',random_bytes(s1),6);
select * from v1;
select * from t1;
insert into v1 values (6,'6','0102',random_bytes(1),6);
select * from v1;
select * from t1;
#delete
drop table t1 ;
create table t1 (
 s1 int,
 s2 char(20),
 s3 time,
 s4 binary(20),
 s5 set('1','5','4')
 );
insert into t1 values (1,'1','0102',1,1);
insert into t1 values (2.6,'2.6','0102',2.6,3);
insert into t1 values (null,null,null,null,null);
drop view v1;
create view v1 as select *  from t1;
select * from v1;
delete from v1 where random_bytes(s1)=2;
delete from v1 where random_bytes(s2)=2;
delete from v1 where random_bytes(s3)=2;
delete from v1 where random_bytes(s4)=2;
delete from v1 where random_bytes(s5)=2;
select * from v1;
select * from t1;
#update
drop table t1 ;
create table t1 (
 s1 int,
 s2 char(20),
 s3 time,
 s4 binary(20),
 s5 set('1','5','4')
 );
insert into t1 values (1,'1','0102',1,1);
insert into t1 values (2.6,'2.6','0102',2.6,3);
insert into t1 values (null,null,null,null,null);
#44923288  set binary列和random_bytes赋值报错4016
drop view v1;
create view v1 as select * from t1;
select * from v1;
update t1 set s4= random_bytes(s1);
select * from v1;
select * from t1;
update v1 set s4= random_bytes(1);
select * from v1;
select * from t1;
#分区表
#range
drop table t1 ;
create table t1 (
 s1 int,
 s2 char(20),
 s3 time,
 s4 binary(20),
 s5 set('1','5','4')
 )
  partition by range(s1)(
  partition p1 values less than(2) ,
  partition p2 values less than(10) ,
  partition p3 values less than(maxvalue)
);
insert into t1 values (1,'1','0102',1,1);
insert into t1 values (2.6,'2.6','0102',2.6,3);
insert into t1 values (null,null,null,null,null);
select * from t1;
select length(random_bytes(s1)) from t1;
#list
drop table t1 ;
create table t1 (
 s1 int,
 s2 char(20),
 s3 time,
 s4 binary(20),
 s5 set('1','5','4')
 )
  partition by list(s1)(
  partition p1 values in (1,2),
  partition p2 values in (4,11),
  partition p3 values in (3000)
);
insert into t1 values (1,'1','0102',1,1);
insert into t1 values (4,'2.6','0102',2.6,3);
insert into t1 values (11,null,null,null,null);
select * from t1;
insert into t1(s1) values(random_bytes(1));
select * from t1;
select length(random_bytes(s1)) from t1;
#hash
drop table t1 ;
create table t1 (
 s1 int,
 s2 char(20),
 s3 time,
 s4 binary(20),
 s5 set('1','5','4')
 )
partition by hash(s1)
partitions 4;
insert into t1 values (1,'1','0102',1,1);
insert into t1 values (4,'2.6','0102',2.6,3);
insert into t1 values (11,null,null,null,null);
select * from t1;
insert into t1(s1) values(random_bytes(1));
select * from t1;
select length(random_bytes(s1)) from t1;
drop table t1 ;
create table t1 (
 s1 int,
 s2 char(20),
 s3 time,
 s4 binary(20),
 s5 set('1','random_bytes(1)','4')
 );
insert into t1(s5) values (3);
#AES_ENCRYPT()、AES_DECRYPT()
SET block_encryption_mode = 'aes-256-cbc';
SET @key_str = SHA2('My secret passphrase',512);
SET @init_vector = RANDOM_BYTES(16);
SET @crypt_str = AES_ENCRYPT('ni',@key_str,@init_vector);
SELECT AES_DECRYPT(@crypt_str,@key_str,@init_vector);
SET block_encryption_mode = 'aes-256-cbc';
SET @key_str = SHA2('My secret passphrase',512);
SET @init_vector = RANDOM_BYTES(20);
SET @crypt_str = AES_ENCRYPT('ni',@key_str,@init_vector);
SELECT AES_DECRYPT(@crypt_str,@key_str,@init_vector);
SET block_encryption_mode = 'aes-256-cbc';
SET @key_str = SHA2('My secret passphrase',512);
SET @init_vector = RANDOM_BYTES(1);
SET @crypt_str = AES_ENCRYPT('ni',@key_str,@init_vector);
SELECT AES_DECRYPT(@crypt_str,@key_str,@init_vector);
SET block_encryption_mode = 'aes-256-cbc';
SET @key_str = SHA2('My secret passphrase',512);
SET @crypt_str = AES_ENCRYPT('ni',@key_str,RANDOM_BYTES(16));
SELECT AES_DECRYPT(@crypt_str,@key_str,RANDOM_BYTES(16));
SET @key_str = SM3('My secret passphrase');
SET @init_vector = RANDOM_BYTES(16);
SET block_encryption_mode = 'sm4-cbc';
SET @crypt_str = SM4_ENCRYPT('ni', @key_str, @init_vector);
SELECT SM4_DECRYPT(@crypt_str, @key_str, @init_vector);
SET @key_str = SM3('My secret passphrase');
SET @init_vector = RANDOM_BYTES(20);
SET @crypt_str = SM4_ENCRYPT('ni',@key_str,@init_vector);
SELECT SM4_DECRYPT(@crypt_str,@key_str,@init_vector);
SET @key_str = SM3('My secret passphrase');
SET @init_vector = RANDOM_BYTES(1);
SET @crypt_str = SM4_ENCRYPT('ni', @key_str, @init_vector);
SELECT SM4_DECRYPT(@crypt_str, @key_str, @init_vector);
SET @key_str = SM3('My secret passphrase');
SET @crypt_str = SM4_ENCRYPT('ni', @key_str, RANDOM_BYTES(16));
SELECT SM4_DECRYPT(@crypt_str, @key_str, RANDOM_BYTES(16));
###清理环境
drop user yyl;
purge recyclebin;
