--disable_query_log
--error 0,1396
drop user nxa;
create user 'nxa' identified by '123';
GRANT all privileges ON *.* TO 'nxa'@'%' WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
--enable_query_log

###切换测试用户
connect(conn,$OBMYSQL_MS0,nxa,123,test,$OBMYSQL_PORT);
connection conn;

###设置超时时间
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;

--disable_warnings
drop database IF EXISTS nxa;
--enable_warnings
###创建DB，切换DB测试
create database nxa  character set utf8;
use nxa;
set ob_enable_plan_cache=0;
set@@sql_mode='STRICT_ALL_TABLES,NO_ZERO_DATE,NO_ZERO_IN_DATE,ERROR_FOR_DIVISION_BY_ZERO ';
--result_format 4
--disable_result_log

--echo  合法数据
set @s =  3;
select hex(random_bytes(@s)),random_bytes(@s);

set @s =  2.56;
select hex(random_bytes(@s)),random_bytes(@s);
--echo  边界
set @s = 0;
--error 5674
select hex(random_bytes(@s)),random_bytes(@s);

set @s = 1;
select hex(random_bytes(@s)),random_bytes(@s);

set @s = 1;
select hex(random_bytes(@s)),random_bytes(@s);

set @s = 1024;
select hex(random_bytes(@s)),random_bytes(@s);

set @s = 1025;
--error 5674
select hex(random_bytes(@s)),random_bytes(@s);

--echo  特殊

set @s = '';
--error 5674
select hex(random_bytes(@s)),random_bytes(@s);
set @s =' ';
--error 5674
select hex(random_bytes(@s)),random_bytes(@s);
set @s = null;
select hex(random_bytes(@s)),random_bytes(@s);
set @s = '#';
--error 5674
select hex(random_bytes(@s)),random_bytes(@s);
set @s = '中';
--error 5674
select hex(random_bytes(@s)),random_bytes(@s);
set @s = -3;
--error 5674
select hex(random_bytes(@s)),random_bytes(@s);

--echo  参数个数

set @s = null,@a=3;
--error 1582
select hex(random_bytes(@s,@a)),random_bytes(@s,@a);


--echo  字符集
set @s = _utf8mb4 '3';
select hex(random_bytes(@s)),random_bytes(@s);

set @s =  cast('3' as binary);
select hex(random_bytes(@s)),random_bytes(@s);

set @s = _gbk '3';
select  hex(random_bytes(@s)),random_bytes(@s);

select hex(random_bytes(0x5)),random_bytes(0x5);

set @s = _gb18030 '3';
select  hex(random_bytes(@s)),random_bytes(@s);

--echo  二进制
select length(random_bytes(binary 12));
--echo  十六进制
select length(random_bytes(0x12));
--echo  json
--error 5674
select length(random_bytes( (SELECT JSON_ARRAY(1))));

--echo  数据类型
set names 'utf8mb4';
--error 1051
drop table t1;
create table t1 
(tt tinyint,
 ft float,
 dle double,
 dl decimal(10,7),
 bi bit(5),

 te time,
 de date,
 dae datetime,
 tp timestamp,
 cr char(30),
 txt text,
 em enum('春','2'),
 se set('1','2','3'),
 bry binary(10),
 bb blob)
 default charset=utf8mb4 collate=utf8mb4_general_ci;

insert into t1 values
(5,7.345,1.54526,3.2984,b'11',
001024,0101,00000000000101,00000000000101,
'4','4',
'2','4',2,1);


select hex(random_bytes(tt )),random_bytes(tt ) from t1;
select hex(random_bytes(ft )),random_bytes(ft ) from t1;
select hex(random_bytes(dle)),random_bytes(dle) from t1;
select hex(random_bytes(dl )),random_bytes(dl ) from t1;
select hex(random_bytes(bi )),random_bytes(bi ) from t1;

select hex(random_bytes(te )),random_bytes(te ) from t1;
--error 5674
select hex(random_bytes(de )),random_bytes(de ) from t1;
--error 5674
select hex(random_bytes(dae)),random_bytes(dae) from t1;
--error 5674
select hex(random_bytes(tp )),random_bytes(tp ) from t1;

select hex(random_bytes(cr )),random_bytes(cr ) from t1;
select hex(random_bytes(txt )),random_bytes(txt ) from t1;

select hex(random_bytes(em )),random_bytes(em ) from t1;
select hex(random_bytes(se )),random_bytes(se ) from t1;
select hex(random_bytes(bry)),random_bytes(bry) from t1;
select hex(random_bytes(bb )),random_bytes(bb ) from t1;

--echo  子查询


select hex(random_bytes((select tt  from t1))),random_bytes((select tt  from t1)) from t1;
select hex(random_bytes((select ft  from t1))),random_bytes((select ft  from t1)) from t1;
select hex(random_bytes((select dle from t1))),random_bytes((select dle from t1)) from t1;
select hex(random_bytes((select dl  from t1))),random_bytes((select dl  from t1)) from t1;
select hex(random_bytes((select bi  from t1))),random_bytes((select bi  from t1)) from t1;


select hex(random_bytes((select te  from t1))),random_bytes((select te  from t1)) from t1;
--error 5674
select hex(random_bytes((select de  from t1))),random_bytes((select de  from t1)) from t1;
--error 5674
select hex(random_bytes((select dae from t1))),random_bytes((select dae from t1)) from t1;
--error 5674
select hex(random_bytes((select tp  from t1))),random_bytes((select tp  from t1)) from t1;

select hex(random_bytes((select cr  from t1))),random_bytes((select cr  from t1)) from t1;
select hex(random_bytes((select txt from t1))),random_bytes((select txt from t1)) from t1;

select hex(random_bytes((select em  from t1))),random_bytes((select em  from t1)) from t1;
--echo  #44928411  random_bytes()参数传入嵌套set类型字段，ob和MySQL结果不一致
select hex(random_bytes((select se  from t1))),random_bytes((select se  from t1)) from t1;
select hex(random_bytes((select bry from t1))),random_bytes((select bry from t1)) from t1;
select hex(random_bytes((select bb  from t1))),random_bytes((select bb  from t1)) from t1;


--echo  运算

select random_bytes(1024)+random_bytes(1024);
select hex(random_bytes(1+2)),random_bytes(1+2);
select hex(random_bytes(1/2)),random_bytes(1/2);
select hex(random_bytes(3-2)),random_bytes(3-2);
select hex(random_bytes(1*2)),random_bytes(1*2);

drop table t1 ;
create table t1 (s2 double,s3 double);
insert into t1 values (1.1,1.4);
insert into t1 values (2,2.5);
insert into t1 values (3,null);
insert into t1 values (1.45,6);

select length(random_bytes(s2)) from t1;
select length(random_bytes(s2+s3)) from t1;
select length(random_bytes(s2)+random_bytes(s3)) from t1;
select length(random_bytes(s2)+random_bytes(1+2))from t1;

--echo  distinct
select distinct(random_bytes(s2)) from t1 ;

--echo  concat
--echo  #44924589 表达式在concat()中，ob 报4016Internal error
select concat (random_bytes(s2),random_bytes(s3)) from t1;

select random_bytes(s2)||random_bytes(s3) from t1;

--echo  函数嵌套
--error 5674
select random_bytes(now() + 2048) ;
--error 5674
select random_bytes(curdate() + 2048);
--error 5674
select random_bytes(curtime() + 2048);

select random_bytes(ascii(s2)) from t1 ;
select random_bytes(instr(442,2)) from t1 ;
select random_bytes(length(s2)) from t1 ;

select random_bytes(abs(s2)) from t1 ;
select random_bytes(ceil(s2))from t1 ;
select random_bytes(floor(s2)) from t1 ;
--echo  #44925021 ob对于常量form多行表时，返回均为第一次随机值，mysql每次生成随机值

select hex(random_bytes(sin(1))),random_bytes(sin(1)) from t1 ;
select hex(random_bytes(cos(0.5)))from t1 ;
select random_bytes(sign(s2)) from t1 ;

select random_bytes(power(s2,3)) from t1 ;
select random_bytes(mod(27.8,3)) from t1 ;
select random_bytes(round(s2)) from t1 ;

select random_bytes(sqrt(s2)) from t1 ;
select random_bytes(sum(s2)) from t1  ;
select random_bytes(count(s2)) from t1  ;

select random_bytes(max(s2)) from t1  ;
select random_bytes(min(s2)) from t1  ;
select random_bytes(avg(s2)) from t1  ;

select random_bytes(rand()+1.2) from t1  ;
--echo  convert
select convert(random_bytes(1),signed) ;
select convert(random_bytes(1),unsigned)  ;
select convert(random_bytes(1),date) ;
select convert(random_bytes(1),char) ;
select convert(random_bytes(1),binary)  ;
--echo  cast
select cast(weight_string(1) as char)  ;
select cast(weight_string(1) as date) ;
select cast(weight_string(1) as decimal(2,1)) ;
select cast(weight_string(1) as signed);


--echo  where
drop table t1;
create table t1 
(tt tinyint,
 ft float,
 dle double,
 dl decimal(10,7),
 bi bit(5),

 te time,
 de date,
 dae datetime,
 tp timestamp,
 cr char(30),
 txt text,
 em enum('春','2'),
 se set('1','2','3'),
 bry binary(10),
 bb blob)
 default charset=utf8mb4 collate=utf8mb4_general_ci;

insert into t1 values
(5,7.345,1.54526,3.2984,b'11',
001024,0101,00000000000101,00000000000101,
'4','4',
'2','4',2,1);

select * from t1 where tt =random_bytes(1);
select * from t1 where ft =random_bytes(1);
select * from t1 where dle=random_bytes(1);
select * from t1 where dl =random_bytes(1);
select * from t1 where bi =random_bytes(1);
select * from t1 where te =random_bytes(1);
select * from t1 where de =random_bytes(1);
select * from t1 where dae=random_bytes(1);
select * from t1 where tp =random_bytes(1);
--echo #44923288 二进制,字符串,枚举字段和random_bytes()函数值对比报内部错误
select * from t1 where cr =random_bytes(1);
select * from t1 where txt=random_bytes(1);
select * from t1 where em =random_bytes(1);
select * from t1 where se =random_bytes(1);
select * from t1 where bry=random_bytes(1);
select * from t1 where bb =random_bytes(1);


drop table t1 ;
create table t1 (s2 double,s3 double);
insert into t1 values (1.1,1.4);
insert into t1 values (2,2.5);
insert into t1 values (3,null);
insert into t1 values (1.45,6);
--echo  比较
select * from t1 where random_bytes(s2)=3;
select * from t1 where random_bytes(s2)!=3;
select * from t1 where random_bytes(s2)<=3;
select * from t1 where random_bytes(s2)>=3;
select * from t1 where random_bytes(s2)<3;
select * from t1 where random_bytes(s2)>3;
--echo   #44923288 以函数值作比较，ob报4016Internal error，mysql正常
select * from t1 where random_bytes(s2) = random_bytes(s2) ;
select * from t1 where random_bytes(s2) = length(s2) ;
select * from t1 where  s2= random_bytes(s2) ;

select * from t1 where length(random_bytes(s2))=3;

--echo  between and

select length(random_bytes(s2)) from t1 where s2 between 1 and 2;
select * from t1 where s2 between random_bytes(s2) and random_bytes(s3);
select * from t1 where random_bytes(s2) between 0 and 100;
select * from t1 where s2 between length(random_bytes(s2)) and length(random_bytes(s3));
--echo  in
select length(random_bytes(s2)) from t1 where s2 in(1,3);
select * from t1 where s2 in (random_bytes(s2) , random_bytes(s3));
select * from t1 where s2 not in (random_bytes(s2) , random_bytes(s3));

select * from t1 where random_bytes(s3) in (1,2,29,343);
select * from t1 where random_bytes(s3) not in (1,2,29,343);
--echo   #44923288 当以函数值作in筛选，ob报4016Internal error，mysql正常
select * from t1 where random_bytes(s3) in (random_bytes(1),random_bytes(2));


--echo  and
select random_bytes(s2) from t1 where s2 =2 and s3= 2.5;
select * from t1 where s2 =random_bytes(s2) and s2= random_bytes(s3);
select * from t1 where length(random_bytes(s2)) = 2 and 1;

--echo  or
select random_bytes(s2) from t1 where s2 =2 or s3= 6;
select * from t1 where s2 =random_bytes(s2) or s2= random_bytes(s3);
select * from t1 where length(random_bytes(s2)) = 2 or 1;

--echo  is
select random_bytes(s2) from t1 where  s3 is null;
select * from t1 where  random_bytes(s3) is null;
select * from t1 where length(random_bytes(s3)) is null;
--echo  运算
select * from t1 where  random_bytes(s3) +random_bytes(s3) ;
select * from t1 where  random_bytes(s3) -random_bytes(s3) ;
select * from t1 where  random_bytes(s3) *random_bytes(s3) ;
select * from t1 where  random_bytes(s3) /random_bytes(s3) ;

--echo  like
--echo  #44923556 ob函数不能进行like筛选，报4016Internal error
select * from t1 where  random_bytes(1024) like '%3%' ;

--echo  exists
drop table t1 ;
create table t1 (s2 double,s3 double);
insert into t1 values (1.1,1.4);
insert into t1 values (2,2.5);
insert into t1 values (3,null);
insert into t1 values (1.45,6);
select * from t1 where exists (select random_bytes(s2) from t1 );

select * from t1 where exists (select random_bytes(s2)>99989 from t1 );

select random_bytes(s2) from t1 where exists (select random_bytes(s2) from t1 );
--echo  ob和mysql返回行数结果不一样
select * from t1 where exists (select s2 from t1 where random_bytes(s2)>1 );


--echo  any
drop table t1 ;
create table t1 (s2 double,s3 double);
insert into t1 values (1.1,1.4);
insert into t1 values (2,2.5);
insert into t1 values (3,null);
insert into t1 values (1.45,6);

select * from t1 where s2<any(select random_bytes(s2) from t1 );
--echo  #44923288  当以函数值同any、all语句内部函数值作比较，ob报4016Internal error，mysql正常
select * from t1 where random_bytes(s2)<any(select random_bytes(s2) from t1 );



--echo  all
drop table t1 ;
create table t1 (s2 double,s3 double);
insert into t1 values (1.1,1.4);
insert into t1 values (2,2.5);
insert into t1 values (3,null);
insert into t1 values (1.45,6);

select * from t1 where s2<all(select random_bytes(s2) from t1 );
--echo   #44923288 当以函数值同any、all语句内部函数值作比较，ob报4016Internal error，mysql正常
select * from t1 where random_bytes(s2)<all(select random_bytes(s2) from t1 );

--echo  limit
drop table t1 ;
create table t1 (s2 double,s3 double);
insert into t1 values (1.1,1.4);
insert into t1 values (2,2.5);
insert into t1 values (3,null);
insert into t1 values (1.45,6);

select random_bytes(s2) from t1 limit 0;
select random_bytes(s2) from t1 limit 1,4;
select distinct(random_bytes(s2)) from t1  limit 1,4;

select random_bytes(s2) from t1 where random_bytes(s2)>0 limit 1,4;

select random_bytes(s2) from t1 group by random_bytes(s2) limit 1,4;

select random_bytes(s2) from t1 order by random_bytes(s2) limit 1,4;


--echo  order by
select random_bytes(s2) from t1 order by s2 ;
select random_bytes(s2) from t1 order by random_bytes(s2) ;
select s3 from t1 order by random_bytes(s2) ;

--echo  group by
select random_bytes(s2) from t1 group by s2 ;
select random_bytes(s2) from t1 group by random_bytes(s2) ;
select s3 from t1 group by random_bytes(s2) ;

select random_bytes(s2) from t1 group by s2 having max(random_bytes(1))>0;
select random_bytes(s2) from t1 group by random_bytes(s2) having max(random_bytes(s2))>2 ;



--echo  case when
--echo #44923978 case when返回函数值报ob报4016Internal error
select case when s3=6 then random_bytes(s3) else random_bytes(s3) end from t1 order by s2;

select case when random_bytes(s3)=1 then 9.99 else 3 end from t1 order by s3;
--echo #44923978 case when函数做case ob报4016Internal error
select (case random_bytes(s3) when 6 then 0.29 when 1 then 9 else 0 end) from t1;

select case when random_bytes(s3)=1 then 9.99 else 3 end from t1 
group by (case when random_bytes(s3)=1 then 9.99 else 3 end) order by s3 ;

--echo  多表联查

drop table t1 ;
create table t1 (s2 double,s3 double);
insert into t1 values (1.1,1.4);
insert into t1 values (2,2.5);
insert into t1 values (3,null);
insert into t1 values (1.45,6);
--error 1051
drop table t2 ;
create table t2 (s2 double,s3 double);
insert into t2 values (1.1,1.4);
insert into t2 values (2,2.5);
insert into t2 values (3,null);


select random_bytes(t1.s3) from t1 join t2 on t1.s2=t2.s2;

select * from t1 join t2 on t1.s2=t2.s2 where random_bytes(t1.s3)>0;
select random_bytes(t1.s3) from t1 join t2 on random_bytes(t1.s2)=t2.s2;

select random_bytes(t1.s3) from t1 right join t2 on t1.s2=t2.s2;

select random_bytes(t1.s3) from t1 left join t2 on t1.s2=t2.s2;

select random_bytes(t1.s3) from t1 cross join t2 on t1.s2=t2.s2;

