# --error 1292
delete from t2 where s2=random_bytes(s2);


--echo  update
drop table t1 ;
create table t1 (s2 char(10),s3 char(10));
insert into t1 values (1,1);
insert into t1 values (2,3);
--disable_abort_on_error 
update  t1 set s2=random_bytes(s3);
update  t1 set s2=random_bytes(2);
--enable_abort_on_error
--echo  ##44825821 random_bytes作为where修改条件报错5114
--disable_abort_on_error
#--error 5114
update  t1 set s2=999 where random_bytes(1)>0;
