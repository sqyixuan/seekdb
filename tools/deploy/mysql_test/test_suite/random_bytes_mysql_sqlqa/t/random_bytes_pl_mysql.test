#owner:qiaolinjun.qlj 
#owner group: 创新研发
#description: obmysql模式, random_bytes表达式测试
#tags:dml
#author: wb-nxa01399802
--disable_query_log
--error 0,1396
drop user nxa;
create user 'nxa' identified by '123';
GRANT all privileges ON *.* TO 'nxa'@'%' WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
--enable_query_log

###切换测试用户
connect(conn,$OBMYSQL_MS0,nxa,123,test,$OBMYSQL_PORT);
connection conn;

###设置超时时间
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;

--disable_warnings
drop database IF EXISTS nxa;
--enable_warnings
###创建DB，切换DB测试
create database nxa  character set utf8;
use nxa;
set ob_enable_plan_cache=0;
set@@sql_mode='STRICT_ALL_TABLES,NO_ZERO_DATE,NO_ZERO_IN_DATE,ERROR_FOR_DIVISION_BY_ZERO ';
--result_format 4
--disable_result_log

--echo  数据类型传参
set names 'utf8mb4';
--error 1051
drop table t1;
create table t1 
(tt tinyint,
 ft float,
 dle double,
 dl decimal(10,7),
 bi bit(5),

 te time,
 cr char(30),
 txt text,
 em enum('春','2'),
 se set('1','2','3'),
 bry binary(10),
 bb blob)
 default charset=utf8mb4 collate=utf8mb4_general_ci;

insert into t1 values
(5,7.345,1.54526,3.2984,b'11',
001024,
'4','4',
'2','4',2,1);


--error 1305
drop procedure p1;
delimiter /;
create procedure p1()
BEGIN
select tt  into @a from t1;
select ft  into @b from t1;
select dle into @c from t1;
select dl  into @d from t1;
select bi  into @e from t1;
select te  into @f from t1;
select cr  into @g from t1;
select txt into @h from t1;

select em  into @aa from t1;
select se  into @bb from t1;
select bry into @cc from t1;
select bb  into @dd from t1;

end;
/
delimiter ;/
 
call p1();
select length(random_bytes(@a ));
select length(random_bytes(@b ));
--echo #44958137 小数进位方式类型结果不一致
select length(random_bytes(@c ));
select length(random_bytes(@d ));
select length(random_bytes(@e ));
--error 5674
select length(random_bytes(@f ));

select length(random_bytes(@g ));
select length(random_bytes(@h ));

select length(random_bytes(@aa));
select length(random_bytes(@bb));
--echo #44953004 二进制类型结果不一致
--disable_abort_on_error 
select length(random_bytes(@cc));
select length(random_bytes(@dd));
--enable_abort_on_error


--echo  无参
drop table t1 ;
create table t1 (s2 double,s3 double);
insert into t1 values (1.1,1.4);
insert into t1 values (2,2.5);
insert into t1 values (3,null);
insert into t1 values (1.45,6);

set @dd=1;
--error 1305
drop function n_1;
delimiter /;
create function n_1() returns char(50) 
begin
  declare a char(20);
  set a=random_bytes(@dd);
  select random_bytes(s2) into @a from t1 limit 1;

  return 1;
end/
delimiter ;/
--disable_abort_on_error 
select n_1();
select @a;
--echo #44953004通过pl将random_bytes随机返回的非数字结果传入外部random_bytes()参数中，ob没有按预期报错
select random_bytes(@a);
--enable_abort_on_error
--echo 有参

drop table t1 ;
create table t1 (s2 double,s3 double);
insert into t1 values (1.1,1.4);
insert into t1 values (2,2.5);
drop function n_1;
delimiter /;
create function n_1(a char(30)) returns char(30)
begin
  select s3 into @a from t1 order by s2 limit 1;
  return a;
end/
delimiter ;/
--disable_abort_on_error 
select random_bytes(n_1(1)),length(random_bytes(@a));
--enable_abort_on_error

--echo #case when

drop table t1 ;
create table t1 (s2 int,s3 int);
insert into t1 values (1,2);
insert into t1 values (2,3);

drop function n_1;
delimiter /;
create function n_1(a int) 
returns char(20)
begin
declare week char(20);
case a
when 2 then set week=random_bytes(a);

else set week=random_bytes(1);
end case;
return week;
end/
delimiter ;/
--disable_abort_on_error 
select n_1(s2) from t1;
--enable_abort_on_error



drop table t1 ;
create table t1 (s2 int,s3 int);
insert into t1 values (1,2);
insert into t1 values (2,3);

drop function n_1;
delimiter /;
create function n_1(a int) 
returns char(20)
begin
declare week char(20);
case random_bytes(a)
when 2 then set week=a;

else set week=random_bytes(a);
end case;
return week;
end/
delimiter ;/
--disable_abort_on_error 
select n_1(s2) from t1;
--enable_abort_on_error


--echo # if
drop table t1 ;
create table t1 (s2 int,s3 int);
insert into t1 values (1,1);
insert into t1 values (2,3);
--error 1051
drop table t2 ;
create table t2 (s2 int,s3 int);
drop function n_1;
delimiter /;
create function n_1(a int,b int)
returns int
begin
if a!=random_bytes(b) then 
insert into t2 values(3,0);
else 
insert into t2 values(5,1);
end if;
return 6;
end/
delimiter ;/
--disable_abort_on_error
select n_1(s2,s3) from t1  ;
select * from t2;
--enable_abort_on_error
--echo  #procedure
--echo  #in
--error 1305
drop procedure prre;
delimiter /;
create procedure prre(in a char(20),in b char(20))
begin
declare aa char(20);
  set @aa=9;
  set aa=9;
    if a >= b then
      set @aa =  random_bytes(2);
      set aa=  random_bytes(1);
    else
      set @aa = 0;
    end if;
select aa;
end/
delimiter ;/
--disable_abort_on_error
call prre(random_bytes(1),random_bytes(2));
--enable_abort_on_error
--echo  #out
drop procedure p1;
delimiter /;
create procedure p1(out ia char(20)) 
BEGIN
	select random_bytes(1) into ia ;
END/
delimiter ;/
--disable_abort_on_error
call p1(@bb);
select @bb;
--enable_abort_on_error

--echo #inout
drop procedure if exists p1;
delimiter /;
create procedure p1(inout ia char(20),inout ib char(20)) 
BEGIN
	select random_bytes(1) into ia ;
	select ib;
END/
delimiter ;/
set @hh = random_bytes(1);
--disable_abort_on_error
call p1(@qq,@hh);
select @qq;
--enable_abort_on_error

--echo  #trigger
--echo  #insert
drop table t1 ;
create table t1 (s2 char(20),s3 int);
insert into t1 values (1,2);
insert into t1 values (2,3);
--error 1360
drop trigger tr;
delimiter /;
create trigger tr before insert on t1 for each row
begin
if new.s2 is null then
set new.s2 = (select max(s2) from t1);
elseif new.s2 < 0 then
set new.s2 = abs(new.s2);
end if;
end/
delimiter ;/
--disable_abort_on_error
insert into t1(s2) values(random_bytes(1));
select * from t1;
--enable_abort_on_error

drop table t2 ;
create table t2 (s2 char(20),s3 int);
insert into t2 values (1,2);
insert into t2 values (2,3);

drop table t1 ;
create table t1 (s2 char(20),s3 int);
insert into t1 values (1,2);
insert into t1 values (2,3);
--error 1360
drop trigger tr;
delimiter /;
create trigger tr before insert on t1 for each row
begin
if new.s2 is null then
set new.s2 = (select random_bytes(s2) from t2 limit 1);
elseif new.s2 < 0 then
set new.s2 = abs(new.s2);
end if;
end/
delimiter ;/
--disable_abort_on_error
insert into t1(s2) values(random_bytes(null));
select * from t1;
--enable_abort_on_error

drop table t1 ;
create table t1 (s2 char(20),s3 int);
insert into t1 values (1,2);
insert into t1 values (2,3);
--error 1360
drop trigger tr;
delimiter /;
create trigger tr before insert on t1 for each row
begin
if new.s2 is null then
set new.s2 =  random_bytes(1) ;
elseif new.s2 < 0 then
set new.s2 = abs(new.s2);
end if;
end/
delimiter ;/
--disable_abort_on_error
insert into t1(s2) values(random_bytes(null));
select * from t1;
--enable_abort_on_error

--echo  #update
drop table t1 ;
create table t1 (s2 char(20),s3 int);
insert into t1 values (1,2);
insert into t1 values (2,3);
--error 1360
drop trigger tr;
delimiter /;
create trigger tr before update on t1 for each row
begin
if new.s2 is null then
set new.s2 =  random_bytes(old.s2) ;
elseif new.s2 < 0 then
set new.s2 = abs(new.s2);
end if;
end/
delimiter ;/
--disable_abort_on_error
update t1 set s2=random_bytes(null) where s2=1;
select * from t1;
--enable_abort_on_error

--echo #delete
drop table t1 ;
create table t1 (s2 char(20),s3 int);
insert into t1 values (1,2);
insert into t1 values (2,3);
--error 1360
drop trigger tr;
delimiter /;
create trigger tr before delete on t1 for each row
begin
set @aa= random_bytes(old.s2) ;

end/
delimiter ;/
--disable_abort_on_error
delete from  t1  where s2=1;
select * from t1;
select @aa;
--enable_abort_on_error




--echo  游标
drop table t1 ;
create table t1 (
 s1 int,
 s2 char(20),
 s3 time,
 s4 binary(20),
 s5 set('1','5','4')
 );
insert into t1 values (1,'1','0102',1,1);
insert into t1 values (2.6,'2.6','0102',2.6,3);
insert into t1 values (null,null,null,null,null);
--error 1305
drop procedure processorders;
delimiter /;
create procedure processorders()
begin
declare aa binary(20);
declare rc int;
declare i int default 1;
declare cur cursor for select random_bytes(s4) from t1 ;
select count(*)  into rc from t1;
open cur;
 while i < rc do
fetch cur into aa;
set i = i + 1;
select aa;
end while;
close cur;

end/
delimiter ;/

call processorders();



--echo  动态sql

drop table t1 ;
create table t1 (
 s1 int,
 s2 char(20),
 s3 time,
 s4 binary(20),
 s5 set('1','5','4')
 );
insert into t1 values (1,'1','0102',1,1);
insert into t1 values (2.6,'2.6','0102',2.6,3);
insert into t1 values (null,null,null,null,null);
--error 1305
drop procedure agm;
delimiter /;
create procedure agm(in func char(50),in order_param varchar(10),in anchor int,in size int)
begin
	set @s = concat("select " ,func, "from t1 order by ",order_param," limit ",anchor,",",size);
	prepare stmt from @s;
	execute stmt;
	deallocate prepare stmt;
end/
delimiter ;/
call agm('random_bytes(s1)','s1',1,5);
call agm('random_bytes(s2)','s1',1,5);
call agm('random_bytes(s3)','s1',1,5);
call agm('random_bytes(s4)','s1',1,5);
call agm('random_bytes(s5)','s1',1,5);


call agm('length(random_bytes(s1))','s1',1,5);
--echo #44958137 动态sql小数进位方式
call agm('length(random_bytes(s2))','s1',1,5);
call agm('length(random_bytes(s3))','s1',1,5);
call agm('length(random_bytes(s4))','s1',1,5);
call agm('length(random_bytes(s5))','s1',1,5);



--enable_result_log

