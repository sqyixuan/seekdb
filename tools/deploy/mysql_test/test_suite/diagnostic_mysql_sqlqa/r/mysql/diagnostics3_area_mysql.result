### GET STACKED DIAGNOSTICS 语句，在当前上下文不是条件处理程序时使用
# bug15:在没有条件件处理程序的存储过程中， 用于GET STACKED DIAGNOSTICS 语句，mysql与ob结果不一致。 
SET @p21=NULL, @p22=NULL, @p23=NULL, @p24=NULL, @p25=NULL,@p26=NULL, @p27=NULL;//
DROP PROCEDURE IF EXISTS pro1;//
CREATE PROCEDURE pro1 () 
BEGIN
  DROP TABLE IF EXISTS no_such_table14;
  SHOW warnings;
  GET STACKED DIAGNOSTICS @p21 = NUMBER, @p22 = ROW_COUNT;
  GET STACKED DIAGNOSTICS CONDITION 1 @p23 = CLASS_ORIGIN, @p24 = SUBCLASS_ORIGIN, @p25 = RETURNED_SQLSTATE, @p26 = MESSAGE_TEXT, @p27 = MYSQL_ERRNO;
  SELECT 'STACKED DIAGNOSTICS',@p21 'NUMBER', @p22 'ROW_COUNT', @p23 'CLASS_ORIGIN', @p24 'SUBCLASS_ORIGIN', @p25 'RETURNED_SQLSTATE', @p26 'MESSAGE_TEXT', @p27 'MYSQL_ERRNO';
END;
//
CALL pro1()//
+-------+------+--------------------------------------+
| Level | Code | Message                              |
+-------+------+--------------------------------------+
| Note  | 1051 | Unknown table 'test.no_such_table14' |
+-------+------+--------------------------------------+
ERROR 0Z002: GET STACKED DIAGNOSTICS when handler not active
-----------------------------------------------------------------------------------------------------------------
------------------------- GET DIAGNOSTICS  诊断语句 -------------------------------------------------------------
###### 标签:diagnostics-5 补充场景
-----------------------------------------------------------------------------------------------------------------
#### 用DECLARE声明的变量接收语句信息/条件信息的值，然后用IF语句判断变量的值
# bug23:GET [CURRENT | STACKED] DIAGNOSTICS语句, 用DECLARE声明的变量接收语句信息/条件信息,IF语句判断变量的值时，mysql成功，ob失败。
DROP PROCEDURE IF EXISTS pro1;//
CREATE PROCEDURE pro1()
BEGIN
   DECLARE numbers1,numbers2 INT;
   DECLARE rowcount1,rowcount2 INT;  
   DECLARE CONTINUE HANDLER FOR SQLEXCEPTION
   BEGIN
    GET CURRENT DIAGNOSTICS numbers1 = NUMBER,rowcount1 = ROW_COUNT;
	GET STACKED DIAGNOSTICS numbers2 = NUMBER,rowcount2 = ROW_COUNT;
	SELECT numbers1,rowcount1,numbers2,rowcount2;
	
    IF numbers1  = 0 THEN
      SELECT 'IF 分支';
    ELSE
      SELECT 'ELSE 分支';
    END IF ;
  END;
  SELECT * FROM tt1;
END;//
CALL pro1()//
+----------+-----------+----------+-----------+
| numbers1 | rowcount1 | numbers2 | rowcount2 |
+----------+-----------+----------+-----------+
+-------------+
| ELSE 分支   |
+-------------+
|        1 |        -1 |        1 |        -1 |
| ELSE 分支   |
+----------+-----------+----------+-----------+
+-------------+
DROP TABLE t1;//
CREATE TABLE t1(int_col int NOT NULL);//
DROP PROCEDURE IF EXISTS pro1;//
CREATE PROCEDURE pro1(value INT)
BEGIN
  DECLARE code1,code2 CHAR(5) DEFAULT '00000';
  DECLARE msg1,msg2 TEXT;
  DECLARE nrows,errno1,errno2 INT;
  DECLARE result TEXT;
  
  DECLARE CONTINUE HANDLER FOR SQLEXCEPTION
   BEGIN
    GET CURRENT DIAGNOSTICS CONDITION 1 code1 = RETURNED_SQLSTATE, msg1 = MESSAGE_TEXT, errno1 = MYSQL_ERRNO;
	GET STACKED DIAGNOSTICS CONDITION 1 code2 = RETURNED_SQLSTATE, msg2 = MESSAGE_TEXT, errno2 = MYSQL_ERRNO;	
  END; 
  INSERT INTO t1 (int_col) VALUES(value);  
  select 'IF语句前 code1 = ',code1;  
  IF code1 = '00000' THEN
    SELECT 'IF 分支';
	GET DIAGNOSTICS nrows = ROW_COUNT;
    SELECT 'insert succeeded, ',nrows;
  ELSE
    SELECT 'ELSE 分支';
    SELECT 'insert failed, ',code1,msg1,errno1;
  END IF;
END;//
CALL pro1(NULL)//
+----------------------+-------+
| IF语句前 code1 =     | code1 |
+----------------------+-------+
+-------------+
| ELSE 分支   |
+-------------+
+-----------------+-------+---------------------------------+--------+
| insert failed,  | code1 | msg1                            | errno1 |
+-----------------+-------+---------------------------------+--------+
| IF语句前 code1 =     | 23000 |
| ELSE 分支   |
| insert failed,  | 23000 | Column 'int_col' cannot be null |   1048 |
+----------------------+-------+
+-------------+
+-----------------+-------+---------------------------------+--------+
#### 用户自定义变量接收NUMBER值，用DECLARE声明的变量接收ROW_COUNT的值
# bug24:GET [CURRENT | STACKED] DIAGNOSTICS语句, NUMBER用户自定义变量接收，ROW_COUNT用DECLARE声明的变量接收,mysql与ob结果不一致。
SET @p1=NULL, @p2=NULL;//
DROP PROCEDURE IF EXISTS pro1;//
CREATE PROCEDURE pro1()
BEGIN
   DECLARE rowcount1,rowcount2 INT;  
   DECLARE CONTINUE HANDLER FOR SQLEXCEPTION
   BEGIN
    GET CURRENT DIAGNOSTICS @p1 = NUMBER,rowcount1 = ROW_COUNT;
	GET STACKED DIAGNOSTICS @p2 = NUMBER,rowcount2 = ROW_COUNT;
	SELECT @p1,rowcount1,@p2,rowcount2;
  END;
  SELECT * FROM tt1;
END;//
CALL pro1()//
+------+-----------+------+-----------+
| @p1  | rowcount1 | @p2  | rowcount2 |
+------+-----------+------+-----------+
|    1 |        -1 |    1 |        -1 |
+------+-----------+------+-----------+
#### 先检索条件计数，然后使用它来指定要检查的条件编号
# bug26:GET [CURRENT | STACKED] DIAGNOSTICS语句, 先检索条件计数（用户自定义变量接收），然后使用它来指定要检查的条件编号,mysql与ob结果不一致。
SET @p1=NULL, @p2=NULL, @p3=NULL, @p4=NULL;//
DROP TABLE test.no_such_table;//
ERROR 42S02: Unknown table 'test.no_such_table'
GET DIAGNOSTICS @p1 = NUMBER, @p2 = ROW_COUNT;//
GET CURRENT DIAGNOSTICS CONDITION @p1 @p3 = RETURNED_SQLSTATE, @p4 = MESSAGE_TEXT;//
SELECT @p1 'NUMBER', @p2 'ROW_COUNT', @p3 'RETURNED_SQLSTATE', @p4 'MESSAGE_TEXT';//
+--------+-----------+-------------------+------------------------------------+
| NUMBER | ROW_COUNT | RETURNED_SQLSTATE | MESSAGE_TEXT                       |
+--------+-----------+-------------------+------------------------------------+
|      1 |        -1 | 42S02             | Unknown table 'test.no_such_table' |
+--------+-----------+-------------------+------------------------------------+
SET @num1=NULL, @p13=NULL, @p14=NULL, @p15=NULL,@p16=NULL, @p17=NULL;//
SET @num2=NULL, @p23=NULL, @p24=NULL, @p25=NULL,@p26=NULL, @p27=NULL;//
DROP PROCEDURE IF EXISTS pro1;//
CREATE PROCEDURE pro1 () 
BEGIN
  DECLARE CONTINUE HANDLER FOR SQLEXCEPTION
   BEGIN
      GET DIAGNOSTICS @num1 = NUMBER;
      GET DIAGNOSTICS CONDITION @num1 @p13 = CLASS_ORIGIN, @p14 = SUBCLASS_ORIGIN, @p15 = RETURNED_SQLSTATE, @p16 = MESSAGE_TEXT, @p17 = MYSQL_ERRNO;
	  
	  GET STACKED DIAGNOSTICS @num2 = NUMBER;
      GET STACKED DIAGNOSTICS CONDITION @num2 @p23 = CLASS_ORIGIN, @p24 = SUBCLASS_ORIGIN, @p25 = RETURNED_SQLSTATE, @p26 = MESSAGE_TEXT, @p27 = MYSQL_ERRNO;
      
	  SELECT '【CURRENT DIAGNOSTICS】',@num1 'NUMBER', @p13 'CLASS_ORIGIN', @p14 'SUBCLASS_ORIGIN', @p15 'RETURNED_SQLSTATE', @p16 'MESSAGE_TEXT', @p17 'MYSQL_ERRNO';
      SELECT '【STACKED DIAGNOSTICS】',@num2 'NUMBER', @p23 'CLASS_ORIGIN', @p24 'SUBCLASS_ORIGIN', @p25 'RETURNED_SQLSTATE', @p26 'MESSAGE_TEXT', @p27 'MYSQL_ERRNO';
  END;
  DROP USER nouser;
END;
//
CALL pro1()//
+---------------------------+--------+--------------+-----------------+-------------------+---------------------------------------------+-------------+
| 【CURRENT DIAGNOSTICS】   | NUMBER | CLASS_ORIGIN | SUBCLASS_ORIGIN | RETURNED_SQLSTATE | MESSAGE_TEXT                                | MYSQL_ERRNO |
+---------------------------+--------+--------------+-----------------+-------------------+---------------------------------------------+-------------+
+---------------------------+--------+--------------+-----------------+-------------------+---------------------------------------------+-------------+
| 【STACKED DIAGNOSTICS】   | NUMBER | CLASS_ORIGIN | SUBCLASS_ORIGIN | RETURNED_SQLSTATE | MESSAGE_TEXT                                | MYSQL_ERRNO |
+---------------------------+--------+--------------+-----------------+-------------------+---------------------------------------------+-------------+
| 【CURRENT DIAGNOSTICS】   |      1 | ISO 9075     | ISO 9075        | HY000             | Operation DROP USER failed for 'nouser'@'%' | 1396        |
| 【STACKED DIAGNOSTICS】   |      1 | ISO 9075     | ISO 9075        | HY000             | Operation DROP USER failed for 'nouser'@'%' | 1396        |
+---------------------------+--------+--------------+-----------------+-------------------+---------------------------------------------+-------------+
+---------------------------+--------+--------------+-----------------+-------------------+---------------------------------------------+-------------+
SET @num1=NULL, @p13=NULL, @p14=NULL, @p15=NULL,@p16=NULL, @p17=NULL;//
SET @num2=NULL, @p23=NULL, @p24=NULL, @p25=NULL,@p26=NULL, @p27=NULL;//
DROP PROCEDURE IF EXISTS pro1;//
CREATE PROCEDURE pro1 () 
BEGIN
  DECLARE num1,num2 INT;
  DECLARE CONTINUE HANDLER FOR SQLEXCEPTION
   BEGIN
      GET DIAGNOSTICS num1 = NUMBER;
      GET DIAGNOSTICS CONDITION num1 @p13 = CLASS_ORIGIN, @p14 = SUBCLASS_ORIGIN, @p15 = RETURNED_SQLSTATE, @p16 = MESSAGE_TEXT, @p17 = MYSQL_ERRNO;
	  SELECT num1;
	  GET STACKED DIAGNOSTICS num2 = NUMBER;
      GET STACKED DIAGNOSTICS CONDITION num2 @p23 = CLASS_ORIGIN, @p24 = SUBCLASS_ORIGIN, @p25 = RETURNED_SQLSTATE, @p26 = MESSAGE_TEXT, @p27 = MYSQL_ERRNO;
      
	  SELECT '【CURRENT DIAGNOSTICS】',num1 'NUMBER', @p13 'CLASS_ORIGIN', @p14 'SUBCLASS_ORIGIN', @p15 'RETURNED_SQLSTATE', @p16 'MESSAGE_TEXT', @p17 'MYSQL_ERRNO';
      SELECT '【STACKED DIAGNOSTICS】',num2 'NUMBER', @p23 'CLASS_ORIGIN', @p24 'SUBCLASS_ORIGIN', @p25 'RETURNED_SQLSTATE', @p26 'MESSAGE_TEXT', @p27 'MYSQL_ERRNO';
  END;
  DROP USER nouser;
END;
//
CALL pro1()//
