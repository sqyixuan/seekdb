      GET CURRENT DIAGNOSTICS CONDITION 1 @p13 = CLASS_ORIGIN, @p14 = SUBCLASS_ORIGIN, @p15 = RETURNED_SQLSTATE, @p16 = MESSAGE_TEXT, @p17 = MYSQL_ERRNO;
