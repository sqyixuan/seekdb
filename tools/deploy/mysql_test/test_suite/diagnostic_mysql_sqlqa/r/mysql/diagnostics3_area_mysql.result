  DECLARE CONTINUE HANDLER FOR SQLEXCEPTION
   BEGIN
    GET STACKED DIAGNOSTICS CONDITION 1 @p23 = CLASS_ORIGIN . @p24 = SUBCLASS_ORIGIN . @p25 = RETURNED_SQLSTATE;
