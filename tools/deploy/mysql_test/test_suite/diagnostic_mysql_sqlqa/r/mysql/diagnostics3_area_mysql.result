#### 先执行一条错误的非诊断语句,再执行一条SIGNAL 语句
# bug28:GET [CURRENT | STACKED] DIAGNOSTICS语句,先执行一条错误的非诊断语句,再执行一条SIGNAL 语句,mysql与ob结果不一致。
SET @p11=NULL, @p12=NULL, @p13=NULL, @p14=NULL, @p15=NULL,@p16=NULL, @p17=NULL;//
SET @p21=NULL, @p22=NULL, @p23=NULL, @p24=NULL, @p25=NULL,@p26=NULL, @p27=NULL;//
SET @p31=NULL, @p32=NULL, @p33=NULL, @p34=NULL, @p35=NULL,@p36=NULL, @p47=NULL;//
SET @p41=NULL, @p42=NULL, @p43=NULL, @p44=NULL, @p45=NULL,@p46=NULL, @p47=NULL;//
DROP PROCEDURE IF EXISTS pro1;//
CREATE PROCEDURE pro1 () 
BEGIN
  DECLARE CONTINUE HANDLER FOR SQLEXCEPTION
   BEGIN
      DECLARE CONTINUE HANDLER FOR SQLEXCEPTION
      BEGIN
        GET DIAGNOSTICS @p11 = NUMBER, @p12 = ROW_COUNT;
        GET DIAGNOSTICS CONDITION 1 @p13 = CLASS_ORIGIN, @p14 = SUBCLASS_ORIGIN, @p15 = RETURNED_SQLSTATE, @p16 = MESSAGE_TEXT, @p17 = MYSQL_ERRNO;
	    GET STACKED DIAGNOSTICS @p21 = NUMBER, @p22 = ROW_COUNT;
        GET STACKED DIAGNOSTICS CONDITION 1 @p23 = CLASS_ORIGIN, @p24 = SUBCLASS_ORIGIN, @p25 = RETURNED_SQLSTATE, @p26 = MESSAGE_TEXT, @p27 = MYSQL_ERRNO; 
      END;
	  
	  SIGNAL SQLSTATE '45000' SET MESSAGE_TEXT = 'SIGNAL语句执行：An error occurred', MYSQL_ERRNO = 1000;

      GET DIAGNOSTICS @p31 = NUMBER, @p32 = ROW_COUNT;
      GET DIAGNOSTICS CONDITION 1 @p33 = CLASS_ORIGIN, @p34 = SUBCLASS_ORIGIN, @p35 = RETURNED_SQLSTATE, @p36 = MESSAGE_TEXT, @p37 = MYSQL_ERRNO;
	  GET STACKED DIAGNOSTICS @p41 = NUMBER, @p42 = ROW_COUNT;
      GET STACKED DIAGNOSTICS CONDITION 1 @p43 = CLASS_ORIGIN, @p44 = SUBCLASS_ORIGIN, @p45 = RETURNED_SQLSTATE, @p46 = MESSAGE_TEXT, @p47 = MYSQL_ERRNO;
  END;
  SELECT * FROM no_such_table15;
END;
//
CALL pro1()//
Warnings:
Warning	1758	Invalid condition number
