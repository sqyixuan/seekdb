purge recyclebin;
result_format: 4
drop user whh@'%';
create user whh identified by 'whh';
grant all on *.* to whh WITH GRANT OPTION;


#### 测试前表准备
DROP TABLE dia_table1;//
CREATE TABLE dia_table1( 
  c1 int, 
  c2 VARCHAR(200),
  c3 VARCHAR(200)
);//
INSERT INTO dia_table1 VALUES(1,'mysql','8.0');//
INSERT INTO dia_table1 VALUES(2,'oracle','11g');//
INSERT INTO dia_table1 VALUES(3,'ob','8.0');//
DROP TABLE dia_table2;//
CREATE TABLE dia_table2( 
  id int primary key auto_increment,
  numbers  varchar(200),
  row_count varchar(200),
  cla_ori varchar(200),
  sub_ori varchar(200),
  ret_sqlstate varchar(200),
  mes_text varchar(200),
  mysql_err varchar(200)
);//
-----------------------------------------------------------------------------------------------------------------
------------------------- GET DIAGNOSTICS  诊断语句 -------------------------------------------------------------
###### 标签:diagnostics-3 诊断区域 
-----------------------------------------------------------------------------------------------------------------
######################### 标签：diagnostics-3-3 诊断区域数据比较 #########################
#### 1、执行一条成功的非诊断语句
# bug18:GET [CURRENT] DIAGNOSTICS语句, 当一条sql成功执行时,mysql与ob结果不一致。 
SET @p11=NULL, @p12=NULL, @p13=NULL, @p14=NULL, @p15=NULL,@p16=NULL, @p17=NULL;//
SET @p21=NULL, @p22=NULL, @p23=NULL, @p24=NULL, @p25=NULL,@p26=NULL, @p27=NULL;//
DROP PROCEDURE IF EXISTS pro1;//
CREATE PROCEDURE pro1 () 
BEGIN
  DECLARE CONTINUE HANDLER FOR SQLEXCEPTION
   BEGIN
      SELECT '执行一条成功的非诊断语句';
      GET DIAGNOSTICS @p11 = NUMBER, @p12 = ROW_COUNT;
      GET DIAGNOSTICS CONDITION 1 @p13 = CLASS_ORIGIN, @p14 = SUBCLASS_ORIGIN, @p15 = RETURNED_SQLSTATE, @p16 = MESSAGE_TEXT, @p17 = MYSQL_ERRNO;
	  GET STACKED DIAGNOSTICS @p21 = NUMBER, @p22 = ROW_COUNT;
      GET STACKED DIAGNOSTICS CONDITION 1 @p23 = CLASS_ORIGIN, @p24 = SUBCLASS_ORIGIN, @p25 = RETURNED_SQLSTATE, @p26 = MESSAGE_TEXT, @p27 = MYSQL_ERRNO;
      SELECT '【CURRENT DIAGNOSTICS】',@p11 'NUMBER', @p12 'ROW_COUNT', @p13 'CLASS_ORIGIN', @p14 'SUBCLASS_ORIGIN', @p15 'RETURNED_SQLSTATE', @p16 'MESSAGE_TEXT', @p17 'MYSQL_ERRNO';
      SELECT '【STACKED DIAGNOSTICS】',@p21 'NUMBER', @p22 'ROW_COUNT', @p23 'CLASS_ORIGIN', @p24 'SUBCLASS_ORIGIN', @p25 'RETURNED_SQLSTATE', @p26 'MESSAGE_TEXT', @p27 'MYSQL_ERRNO';
  END;
  SELECT * FROM no_such_table41;
END;
//
CALL pro1()//
+--------------------------------------+
| 执行一条成功的非诊断语句             |
+--------------------------------------+
+---------------------------+--------+-----------+--------------+-----------------+-------------------+--------------+-------------+
| 【CURRENT DIAGNOSTICS】   | NUMBER | ROW_COUNT | CLASS_ORIGIN | SUBCLASS_ORIGIN | RETURNED_SQLSTATE | MESSAGE_TEXT | MYSQL_ERRNO |
+---------------------------+--------+-----------+--------------+-----------------+-------------------+--------------+-------------+
+---------------------------+--------+-----------+--------------+-----------------+-------------------+--------------------------------------------+-------------+
| 【STACKED DIAGNOSTICS】   | NUMBER | ROW_COUNT | CLASS_ORIGIN | SUBCLASS_ORIGIN | RETURNED_SQLSTATE | MESSAGE_TEXT                               | MYSQL_ERRNO |
+---------------------------+--------+-----------+--------------+-----------------+-------------------+--------------------------------------------+-------------+
| 执行一条成功的非诊断语句             |
| 【CURRENT DIAGNOSTICS】   |      0 |        -1 | NULL         | NULL            | NULL              | NULL         | NULL        |
| 【STACKED DIAGNOSTICS】   |      1 |        -1 | ISO 9075     | ISO 9075        | 42S02             | Table 'test.no_such_table41' doesn't exist | 1146        |
+--------------------------------------+
+---------------------------+--------+-----------+--------------+-----------------+-------------------+--------------+-------------+
+---------------------------+--------+-----------+--------------+-----------------+-------------------+--------------------------------------------+-------------+
#### 2、执行一条警告的非诊断语句
# bug19:GET [CURRENT | STACKED] DIAGNOSTICS语句, 当执行一条sqlc产生警告时,mysql与ob结果不一致。
SET @p11=NULL, @p12=NULL, @p13=NULL, @p14=NULL, @p15=NULL,@p16=NULL, @p17=NULL;//
SET @p21=NULL, @p22=NULL, @p23=NULL, @p24=NULL, @p25=NULL,@p26=NULL, @p27=NULL;//
DROP PROCEDURE IF EXISTS pro1;//
CREATE PROCEDURE pro1 () 
BEGIN
  DECLARE CONTINUE HANDLER FOR SQLEXCEPTION
   BEGIN
      DROP TABLE IF EXISTS no_such_table42;
      GET DIAGNOSTICS @p11 = NUMBER, @p12 = ROW_COUNT;
      GET DIAGNOSTICS CONDITION 1 @p13 = CLASS_ORIGIN, @p14 = SUBCLASS_ORIGIN, @p15 = RETURNED_SQLSTATE, @p16 = MESSAGE_TEXT, @p17 = MYSQL_ERRNO;
	  GET STACKED DIAGNOSTICS @p21 = NUMBER, @p22 = ROW_COUNT;
      GET STACKED DIAGNOSTICS CONDITION 1 @p23 = CLASS_ORIGIN, @p24 = SUBCLASS_ORIGIN, @p25 = RETURNED_SQLSTATE, @p26 = MESSAGE_TEXT, @p27 = MYSQL_ERRNO;
      SELECT '【CURRENT DIAGNOSTICS】',@p11 'NUMBER', @p12 'ROW_COUNT', @p13 'CLASS_ORIGIN', @p14 'SUBCLASS_ORIGIN', @p15 'RETURNED_SQLSTATE', @p16 'MESSAGE_TEXT', @p17 'MYSQL_ERRNO';
      SELECT '【STACKED DIAGNOSTICS】',@p21 'NUMBER', @p22 'ROW_COUNT', @p23 'CLASS_ORIGIN', @p24 'SUBCLASS_ORIGIN', @p25 'RETURNED_SQLSTATE', @p26 'MESSAGE_TEXT', @p27 'MYSQL_ERRNO';
  END;
  DROP USER nouser;
END;
//
CALL pro1()//
+---------------------------+--------+-----------+--------------+-----------------+-------------------+--------------------------------------+-------------+
| 【CURRENT DIAGNOSTICS】   | NUMBER | ROW_COUNT | CLASS_ORIGIN | SUBCLASS_ORIGIN | RETURNED_SQLSTATE | MESSAGE_TEXT                         | MYSQL_ERRNO |
+---------------------------+--------+-----------+--------------+-----------------+-------------------+--------------------------------------+-------------+
+---------------------------+--------+-----------+--------------+-----------------+-------------------+---------------------------------------------+-------------+
| 【STACKED DIAGNOSTICS】   | NUMBER | ROW_COUNT | CLASS_ORIGIN | SUBCLASS_ORIGIN | RETURNED_SQLSTATE | MESSAGE_TEXT                                | MYSQL_ERRNO |
+---------------------------+--------+-----------+--------------+-----------------+-------------------+---------------------------------------------+-------------+
| 【CURRENT DIAGNOSTICS】   |      1 |        -1 | ISO 9075     | ISO 9075        | 42S02             | Unknown table 'test.no_such_table42' | 1051        |
| 【STACKED DIAGNOSTICS】   |      1 |        -1 | ISO 9075     | ISO 9075        | HY000             | Operation DROP USER failed for 'nouser'@'%' | 1396        |
+---------------------------+--------+-----------+--------------+-----------------+-------------------+--------------------------------------+-------------+
+---------------------------+--------+-----------+--------------+-----------------+-------------------+---------------------------------------------+-------------+
#### 3、执行一条错误的非诊断语句
# bug16:条件处理程序嵌套场合，使用 GET [CURRENT|STACKED] DIAGNOSTICS 语句，mysql与ob结果不一致。 
SET @num1=NULL,@row1=NULL,@sta1=NULL, @msg1=NULL,@num2=NULL,@row2=NULL,@sta2=NULL, @msg2=NULL;//
SET @num3=NULL,@row3=NULL,@sta3=NULL, @msg3=NULL,@num4=NULL,@row4=NULL,@sta4=NULL, @msg4=NULL;//
DROP PROCEDURE IF EXISTS pro1;//
CREATE PROCEDURE pro1()
BEGIN
  DECLARE CONTINUE HANDLER FOR SQLEXCEPTION
  BEGIN
    DECLARE CONTINUE HANDLER FOR SQLEXCEPTION
    BEGIN
	  GET CURRENT DIAGNOSTICS @num1 = NUMBER, @row1 = ROW_COUNT;
      GET CURRENT DIAGNOSTICS CONDITION 1 @sta1 = RETURNED_SQLSTATE,@msg1 = MESSAGE_TEXT;
	  GET STACKED DIAGNOSTICS @num2 = NUMBER, @row2 = ROW_COUNT;
      GET STACKED DIAGNOSTICS CONDITION 1 @sta2 = RETURNED_SQLSTATE,@msg2 = MESSAGE_TEXT;
    END;
	
    SELECT * FROM no_such_table43;
	
	GET CURRENT DIAGNOSTICS @num3 = NUMBER, @row3 = ROW_COUNT;
    GET CURRENT DIAGNOSTICS CONDITION 1 @sta3 = RETURNED_SQLSTATE,@msg3 = MESSAGE_TEXT;
	GET STACKED DIAGNOSTICS @num4 = NUMBER, @row4 = ROW_COUNT;
    GET STACKED DIAGNOSTICS CONDITION 1 @sta4 = RETURNED_SQLSTATE,@msg4 = MESSAGE_TEXT;
  END;
  
  DROP USER nouser;
END;
//
CALL pro1()//
Warnings:
Warning	1758	Invalid condition number
SELECT '【内层 CURRENT DIAGNOSTICS】',@num1 'NUMBER', @row1 'ROW_COUNT',@sta1 'RETURNED_SQLSTATE', @msg1 'MESSAGE_TEXT';//
