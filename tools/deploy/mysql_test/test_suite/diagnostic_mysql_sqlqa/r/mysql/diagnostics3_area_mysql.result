### 检索列表指定一个或多个 target = item_name 分配，用除逗号以外符号分隔
DROP PROCEDURE IF EXISTS pro1;//
CREATE PROCEDURE pro1 () 
BEGIN
  DECLARE CONTINUE HANDLER FOR SQLEXCEPTION
   BEGIN
    GET CURRENT DIAGNOSTICS CONDITION 1 @p13 = CLASS_ORIGIN | @p14 = SUBCLASS_ORIGIN; 
  END;
  DROP USER nouser;
END;
