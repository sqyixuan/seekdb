# 条件处理程序嵌套场景
# 2层嵌套场景
# bug16:条件处理程序嵌套场合，使用 GET [CURRENT|STACKED] DIAGNOSTICS 语句，mysql与ob结果不一致。 
SET @num1=NULL,@row1=NULL,@sta1=NULL, @msg1=NULL;//
SET @num11=NULL,@row11=NULL,@sta11=NULL, @msg11=NULL;//
DROP PROCEDURE IF EXISTS pro1;//
CREATE PROCEDURE pro1()
BEGIN
  DECLARE CONTINUE HANDLER FOR SQLEXCEPTION
  BEGIN
    DECLARE CONTINUE HANDLER FOR SQLEXCEPTION
    BEGIN
	  GET CURRENT DIAGNOSTICS @num1 = NUMBER, @row1 = ROW_COUNT;
	  GET CURRENT DIAGNOSTICS CONDITION 1 @sta1 = RETURNED_SQLSTATE,@msg1 = MESSAGE_TEXT;
    END;
	
    SELECT * FROM bbb;
	
	GET CURRENT DIAGNOSTICS @num11 = NUMBER, @row11 = ROW_COUNT;
	GET CURRENT DIAGNOSTICS CONDITION 1 @sta11 = RETURNED_SQLSTATE,@msg11 = MESSAGE_TEXT;
  END;
  
  DROP USER aaa;
END;
//
CALL pro1()//
