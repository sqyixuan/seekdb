### 指示符对象- DECLARE声明的局部变量
DROP PROCEDURE IF EXISTS pro1;//
CREATE PROCEDURE pro1 () DETERMINISTIC
BEGIN
  DECLARE cla_ori varchar(200);
  DECLARE sub_ori varchar(200);
  DECLARE ret_sqlstate varchar(200);
  DECLARE mes_text varchar(200);
  DECLARE mysql_err varchar(200);
  UPDATE dia_table1 SET c2='oracle-update' WHERE c1 = 2;
  GET DIAGNOSTICS CONDITION 1 cla_ori = CLASS_ORIGIN, sub_ori = SUBCLASS_ORIGIN, ret_sqlstate = RETURNED_SQLSTATE, mes_text = MESSAGE_TEXT, mysql_err = MYSQL_ERRNO;
  INSERT INTO dia_table2 VALUES(null,'-','-',cla_ori,sub_ori,ret_sqlstate,mes_text,mysql_err);
END;
//
CALL pro1()//
SELECT * FROM dia_table2 ORDER BY id;//
+----+---------+-----------+---------+---------+--------------+----------+-----------+
| id | numbers | row_count | cla_ori | sub_ori | ret_sqlstate | mes_text | mysql_err |
+----+---------+-----------+---------+---------+--------------+----------+-----------+
|  1 | -       | -         | NULL    | NULL    | NULL         | NULL     | NULL      |
+----+---------+-----------+---------+---------+--------------+----------+-----------+
DROP PROCEDURE IF EXISTS pro1;//
CREATE PROCEDURE pro1 () DETERMINISTIC
BEGIN
  DECLARE cla_ori,cla_ori2 varchar(200);
