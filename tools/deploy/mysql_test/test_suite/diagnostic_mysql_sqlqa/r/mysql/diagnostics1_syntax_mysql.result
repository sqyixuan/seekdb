  BEGIN
	GET CURRENT DIAGNOSTICS CONDITION 100 @p15 = RETURNED_SQLSTATE, @p16 = MESSAGE_TEXT;
	GET STACKED DIAGNOSTICS CONDITION 100 @p25 = RETURNED_SQLSTATE, @p26 = MESSAGE_TEXT;
   	show warnings;
	GET CURRENT DIAGNOSTICS @cur_number = NUMBER;
	GET STACKED DIAGNOSTICS @sta_number = NUMBER;
  END;  
  SELECT * FROM no_such_table18;
END;
