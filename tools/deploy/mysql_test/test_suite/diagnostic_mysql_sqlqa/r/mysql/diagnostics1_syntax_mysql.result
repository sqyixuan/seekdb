# bug9:GET DIAGNOSTICS 诊断语句,条件编号指示符的值单引号数字/双引号数字时，mysql成功，ob失败。
SET @p11=NULL, @p12=NULL,@p13=NULL, @p14=NULL,@p21=NULL, @p22=NULL,@p23=NULL, @p24=NULL;//
DROP PROCEDURE IF EXISTS pro1;//
CREATE PROCEDURE pro1 () DETERMINISTIC 
BEGIN
  DECLARE CONTINUE HANDLER FOR SQLEXCEPTION
  BEGIN
	GET CURRENT DIAGNOSTICS CONDITION '1' @p11 = RETURNED_SQLSTATE, @p12 = MESSAGE_TEXT;
	GET CURRENT DIAGNOSTICS CONDITION "1" @p13 = RETURNED_SQLSTATE, @p14 = MESSAGE_TEXT;
	GET STACKED DIAGNOSTICS CONDITION '1' @p21 = RETURNED_SQLSTATE, @p22 = MESSAGE_TEXT;
	GET STACKED DIAGNOSTICS CONDITION "1" @p23 = RETURNED_SQLSTATE, @p24 = MESSAGE_TEXT;
   	show warnings;
	GET CURRENT DIAGNOSTICS @cur_number = NUMBER;
	GET STACKED DIAGNOSTICS @sta_number = NUMBER;
  END;  
  SELECT * FROM no_such_table19;
END;
//
