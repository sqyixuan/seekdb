  UPDATE dia_table1 SET c2='oracle-update' WHERE c1 = 2;
  GET CURRENT DIAGNOSTICS CONDITION 1 cla_ori = CLASS_ORIGIN, sub_ori = SUBCLASS_ORIGIN, ret_sqlstate = RETURNED_SQLSTATE, mes_text = MESSAGE_TEXT, mysql_err = MYSQL_ERRNO;
END;
