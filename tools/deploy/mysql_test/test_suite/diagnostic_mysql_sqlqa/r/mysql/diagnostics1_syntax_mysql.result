purge recyclebin;
result_format: 4
drop user whh@'%';
create user whh identified by 'whh';
grant all on *.* to whh WITH GRANT OPTION;


-----------------------------------------------------------------------------------------------------------------
------------------------- GET DIAGNOSTICS  诊断语句 -------------------------------------------------------------
###### 标签：diagnostics-1 基本语法 
-----------------------------------------------------------------------------------------------------------------
######################### 标签：diagnostics-1-1 基本语法 - 关键字参数  #########################
SET @p2=NULL, @p20=NULL, @p21=NULL, @p22=NULL, @p23=NULL, @p24=NULL, @p25=NULL;//
SET @p3=NULL, @p30=NULL, @p31=NULL, @p32=NULL, @p33=NULL, @p34=NULL, @p35=NULL;//
DROP PROCEDURE IF EXISTS pro1;//
CREATE PROCEDURE pro1 () 
BEGIN
  DECLARE CONTINUE HANDLER FOR SQLEXCEPTION
   BEGIN
      GET CURRENT DIAGNOSTICS @p2 = NUMBER, @p20 = ROW_COUNT;
      GET CURRENT DIAGNOSTICS CONDITION 1 @p21 = CLASS_ORIGIN, @p22 = SUBCLASS_ORIGIN, @p23 = RETURNED_SQLSTATE, @p24 = MESSAGE_TEXT, @p25 = MYSQL_ERRNO;
      GET STACKED DIAGNOSTICS @p3 = NUMBER, @p30 = ROW_COUNT;
	  GET STACKED DIAGNOSTICS CONDITION 1 @p31 = CLASS_ORIGIN, @p32 = SUBCLASS_ORIGIN, @p33 = RETURNED_SQLSTATE, @p34 = MESSAGE_TEXT, @p35 = MYSQL_ERRNO;
      SELECT 'CURRENT DIAGNOSTICS',@p2 'NUMBER', @p20 'ROW_COUNT',@p21 'CLASS_ORIGIN', @p22 'SUBCLASS_ORIGIN', @p23 'RETURNED_SQLSTATE', @p24 'MESSAGE_TEXT', @p25 'MYSQL_ERRNO';
	  SELECT 'STACKED DIAGNOSTICS',@p3 'NUMBER', @p30 'ROW_COUNT',@p31 'CLASS_ORIGIN', @p32 'SUBCLASS_ORIGIN', @p33 'RETURNED_SQLSTATE', @p34 'MESSAGE_TEXT', @p35 'MYSQL_ERRNO';
  END;
  DROP TABLE no_such_table0;
END;
//
CALL pro1()//
+---------------------+--------+-----------+--------------+-----------------+-------------------+-------------------------------------+-------------+
| CURRENT DIAGNOSTICS | NUMBER | ROW_COUNT | CLASS_ORIGIN | SUBCLASS_ORIGIN | RETURNED_SQLSTATE | MESSAGE_TEXT                        | MYSQL_ERRNO |
+---------------------+--------+-----------+--------------+-----------------+-------------------+-------------------------------------+-------------+
+---------------------+--------+-----------+--------------+-----------------+-------------------+-------------------------------------+-------------+
| STACKED DIAGNOSTICS | NUMBER | ROW_COUNT | CLASS_ORIGIN | SUBCLASS_ORIGIN | RETURNED_SQLSTATE | MESSAGE_TEXT                        | MYSQL_ERRNO |
+---------------------+--------+-----------+--------------+-----------------+-------------------+-------------------------------------+-------------+
| CURRENT DIAGNOSTICS |      1 |        -1 | ISO 9075     | ISO 9075        | 42S02             | Unknown table 'test.no_such_table0' | 1051        |
| STACKED DIAGNOSTICS |      1 |        -1 | ISO 9075     | ISO 9075        | 42S02             | Unknown table 'test.no_such_table0' | 1051        |
+---------------------+--------+-----------+--------------+-----------------+-------------------+-------------------------------------+-------------+
+---------------------+--------+-----------+--------------+-----------------+-------------------+-------------------------------------+-------------+
######################### 标签：diagnostics-1-2 基本语法 - 检索列表参数 #########################
#### 测试前表准备
DROP TABLE dia_table1;
CREATE TABLE dia_table1( 
  c1 int, 
  c2 VARCHAR(200),
  c3 VARCHAR(200)
);
insert into dia_table1 values(1,'mysql','8.0');
insert into dia_table1 values(2,'oracle','-');
insert into dia_table1 values(3,'ob','8.0');
DROP TABLE dia_table2;
CREATE TABLE dia_table2( 
  id int primary key auto_increment,
  numbers  varchar(200),
  row_count varchar(200),
  cla_ori varchar(200),
  sub_ori varchar(200),
  ret_sqlstate varchar(200),
  mes_text varchar(200),
  mysql_err varchar(200)
);
#### 标签：diagnostics-1-2-1 语句信息
# bug1:GET DIAGNOSTICS 诊断语句获取ROW_COUNT （SQL语句改变的行数），mysql与ob结果不一致。
SET @p1=NULL, @p2=NULL;
DELETE FROM dia_table1 WHERE c1 <= 2;
GET CURRENT DIAGNOSTICS @p1 = NUMBER, @p2 = ROW_COUNT;
SELECT  @p1 'NUMBER', @p2 'ROW_COUNT';
+--------+-----------+
| NUMBER | ROW_COUNT |
+--------+-----------+
|      0 |        -1 |
+--------+-----------+
SET @p1=NULL, @p2=NULL;
INSERT INTO dia_table1 VALUES(2,'oracle','-');
GET DIAGNOSTICS @p1 = NUMBER, @p2 = ROW_COUNT;
SELECT  @p1 'NUMBER', @p2 'ROW_COUNT';
+--------+-----------+
| NUMBER | ROW_COUNT |
+--------+-----------+
|      0 |        -1 |
+--------+-----------+
SET @p1=NULL, @p2=NULL;
UPDATE dia_table1 SET c2='oracle-update' WHERE c1 = 2;
GET CURRENT DIAGNOSTICS @p1 = NUMBER, @p2 = ROW_COUNT;
SELECT  @p1 'NUMBER', @p2 'ROW_COUNT';
+--------+-----------+
| NUMBER | ROW_COUNT |
+--------+-----------+
|      0 |        -1 |
+--------+-----------+
SET @p1=NULL, @p2=NULL;
SELECT * FROM dia_table1 ORDER BY c1;
+------+---------------+------+
| c1   | c2            | c3   |
+------+---------------+------+
|    2 | oracle-update | -    |
|    3 | ob            | 8.0  |
+------+---------------+------+
GET DIAGNOSTICS @p1 = NUMBER, @p2 = ROW_COUNT;
SELECT  @p1 'NUMBER', @p2 'ROW_COUNT';
+--------+-----------+
| NUMBER | ROW_COUNT |
+--------+-----------+
|      0 |        -1 |
+--------+-----------+
SET @p1=NULL, @p2=NULL;
DROP TABLE no_such_table1;
ERROR 42S02: Unknown table 'test.no_such_table1'
GET CURRENT DIAGNOSTICS @p1 = NUMBER, @p2 = ROW_COUNT;
SELECT  @p1 'NUMBER', @p2 'ROW_COUNT';
+--------+-----------+
| NUMBER | ROW_COUNT |
+--------+-----------+
|      1 |        -1 |
+--------+-----------+
