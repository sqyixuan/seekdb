## ''/' '/null/false
# bug4:GET DIAGNOSTICS 诊断语句,条件编号指示符值是''/' '/null/false时，mysql警告，ob报错。 
SET @p11=NULL, @p12=NULL, @p21=NULL, @p22=NULL, @p31=NULL,@p32=NULL, @p41=NULL, @p42=NULL, @p51=NULL, @p52=NULL, @p61=NULL, @p62=NULL;//
DROP PROCEDURE IF EXISTS pro1;//
CREATE PROCEDURE pro1 () DETERMINISTIC 
BEGIN
  DECLARE CONTINUE HANDLER FOR SQLEXCEPTION
  BEGIN
    GET CURRENT DIAGNOSTICS CONDITION '' @p11 = RETURNED_SQLSTATE, @p12 = MESSAGE_TEXT;
    GET CURRENT DIAGNOSTICS CONDITION ' ' @p21 = RETURNED_SQLSTATE, @p22 = MESSAGE_TEXT;
    GET CURRENT DIAGNOSTICS CONDITION null @p31 = RETURNED_SQLSTATE, @p32 = MESSAGE_TEXT;
	GET CURRENT DIAGNOSTICS CONDITION false @p31 = RETURNED_SQLSTATE, @p32 = MESSAGE_TEXT;
    GET STACKED DIAGNOSTICS CONDITION '' @p41 = RETURNED_SQLSTATE, @p42 = MESSAGE_TEXT;
    GET STACKED DIAGNOSTICS CONDITION ' ' @p51 = RETURNED_SQLSTATE, @p52 = MESSAGE_TEXT;
    GET STACKED DIAGNOSTICS CONDITION null @p61 = RETURNED_SQLSTATE, @p62 = MESSAGE_TEXT;
	GET STACKED DIAGNOSTICS CONDITION false @p61 = RETURNED_SQLSTATE, @p62 = MESSAGE_TEXT;
    show warnings;
  END;  
  SELECT * FROM no_such_table13;
END;
