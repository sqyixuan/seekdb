DROP FUNCTION IF EXISTS fun1;//
CREATE FUNCTION fun1 (num int) RETURNS varchar(200) DETERMINISTIC 
BEGIN
  GET DIAGNOSTICS CONDITION num @p21 = CLASS_ORIGIN, @p22 = SUBCLASS_ORIGIN, @p23 = RETURNED_SQLSTATE, @p24 = MESSAGE_TEXT, @p25 = MYSQL_ERRNO;
  RETURN 'ok';
END;
