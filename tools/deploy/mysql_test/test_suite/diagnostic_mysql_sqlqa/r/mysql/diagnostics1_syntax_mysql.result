#### 标签：diagnostics-1-2-3 存储信息指示符 
#### 标签：diagnostics-1-2-3-1 指示符对象-语句信息指示符对象
# issue: 41307421 Closed bug2:GET DIAGNOSTICS 诊断语句,target用于存储项目信息的有效指示符是存储过程参数，DECLARE声明的存储程序局部变量或用户定义的变量，获取ROW_COUNT （SQL语句改变的行数）时，mysql与ob结果不一致。
### 指示符对象-存储过程参数
SET @p11=NULL, @p12=NULL,@p21=NULL, @p22=NULL;//
DROP PROCEDURE IF EXISTS pro1;//
CREATE PROCEDURE pro1 (out num1 varchar(200),out row_cou1 varchar(200),out num2 varchar(200),out row_cou2 varchar(200)) 
BEGIN
  DECLARE CONTINUE HANDLER FOR SQLEXCEPTION
   BEGIN
      GET CURRENT DIAGNOSTICS num1 = NUMBER, row_cou1 = ROW_COUNT;
	  GET STACKED DIAGNOSTICS num2 = NUMBER, row_cou2 = ROW_COUNT;
  END;
  DROP TABLE no_such_table3;
END;
//
CALL pro1(@p11, @p12,@p21, @p22)//
SELECT 'CURRENT DIAGNOSTICS',@p11 'NUMBER', @p12 'ROW_COUNT';//
+---------------------+--------+-----------+
| CURRENT DIAGNOSTICS | NUMBER | ROW_COUNT |
+---------------------+--------+-----------+
| CURRENT DIAGNOSTICS | 1      | -1        |
+---------------------+--------+-----------+
SELECT 'STACKED DIAGNOSTICS',@p21 'NUMBER', @p22 'ROW_COUNT';//
+---------------------+--------+-----------+
| STACKED DIAGNOSTICS | NUMBER | ROW_COUNT |
+---------------------+--------+-----------+
| STACKED DIAGNOSTICS | 1      | -1        |
+---------------------+--------+-----------+
SET @p11=NULL, @p12=NULL,@p21=NULL, @p22=NULL;//
DROP PROCEDURE IF EXISTS pro1;//
CREATE PROCEDURE pro1 (inout num1 varchar(200),inout row_cou1 varchar(200),inout num2 varchar(200),inout row_cou2 varchar(200)) 
BEGIN
  DECLARE CONTINUE HANDLER FOR SQLEXCEPTION
   BEGIN
      GET CURRENT DIAGNOSTICS num1 = NUMBER, row_cou1 = ROW_COUNT;
	  GET STACKED DIAGNOSTICS num2 = NUMBER, row_cou2 = ROW_COUNT;
  END;
  DROP TABLE no_such_table3;
END;
//
CALL pro1(@p11, @p12,@p21, @p22)//
SELECT 'CURRENT DIAGNOSTICS',@p11 'NUMBER', @p12 'ROW_COUNT';//
+---------------------+--------+-----------+
| CURRENT DIAGNOSTICS | NUMBER | ROW_COUNT |
+---------------------+--------+-----------+
| CURRENT DIAGNOSTICS | 1      | -1        |
+---------------------+--------+-----------+
SELECT 'STACKED DIAGNOSTICS',@p21 'NUMBER', @p22 'ROW_COUNT';//
+---------------------+--------+-----------+
| STACKED DIAGNOSTICS | NUMBER | ROW_COUNT |
+---------------------+--------+-----------+
| STACKED DIAGNOSTICS | 1      | -1        |
+---------------------+--------+-----------+
### 指示符对象-用户定义的变量
SET @p1=NULL, @p2=NULL,@p3=NULL, @p4=NULL;//
DROP PROCEDURE IF EXISTS pro1;//
CREATE PROCEDURE pro1 () 
BEGIN
  DECLARE CONTINUE HANDLER FOR SQLEXCEPTION
   BEGIN
      GET DIAGNOSTICS @p1 = NUMBER, @p2 = ROW_COUNT;
	  GET STACKED DIAGNOSTICS @p3 = NUMBER, @p4 = ROW_COUNT;
      SELECT 'CURRENT DIAGNOSTICS',@p1 'NUMBER', @p2 'ROW_COUNT';
	  SELECT 'STACKED DIAGNOSTICS',@p3 'NUMBER', @p4 'ROW_COUNT';
  END;
  DROP TABLE no_such_table4;
END;
//
CALL pro1()//
+---------------------+--------+-----------+
| CURRENT DIAGNOSTICS | NUMBER | ROW_COUNT |
+---------------------+--------+-----------+
+---------------------+--------+-----------+
| STACKED DIAGNOSTICS | NUMBER | ROW_COUNT |
+---------------------+--------+-----------+
| CURRENT DIAGNOSTICS |      1 |        -1 |
| STACKED DIAGNOSTICS |      1 |        -1 |
+---------------------+--------+-----------+
+---------------------+--------+-----------+
### 指示符对象- DECLARE声明的局部变量
DROP PROCEDURE IF EXISTS pro1;//
CREATE PROCEDURE pro1()
BEGIN
   DECLARE num1,cou1 INT;
   DECLARE num2,cou2 INT;
   DECLARE CONTINUE HANDLER FOR SQLEXCEPTION
   BEGIN
    GET DIAGNOSTICS num1 = NUMBER, cou1 = ROW_COUNT;
	GET STACKED DIAGNOSTICS num2 = NUMBER, cou2 = ROW_COUNT;
    SELECT 'CURRENT DIAGNOSTICS',num1 'NUMBER', cou1 'ROW_COUNT';
	SELECT 'STACKED DIAGNOSTICS',num2 'NUMBER', cou2 'ROW_COUNT';
  END;
  SELECT * FROM tt1;
END;//
CALL pro1()//
+---------------------+--------+-----------+
| CURRENT DIAGNOSTICS | NUMBER | ROW_COUNT |
+---------------------+--------+-----------+
+---------------------+--------+-----------+
| STACKED DIAGNOSTICS | NUMBER | ROW_COUNT |
+---------------------+--------+-----------+
| CURRENT DIAGNOSTICS |      1 |        -1 |
| STACKED DIAGNOSTICS |      1 |        -1 |
+---------------------+--------+-----------+
+---------------------+--------+-----------+
