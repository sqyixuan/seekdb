DROP PROCEDURE IF EXISTS pro1;//
CREATE PROCEDURE pro1()
BEGIN
  DECLARE CONTINUE HANDLER FOR SQLEXCEPTION
  BEGIN
    DECLARE CONTINUE HANDLER FOR SQLEXCEPTION
    BEGIN
	  GET STACKED DIAGNOSTICS @num2 = NUMBER, @row2 = ROW_COUNT;
      GET STACKED DIAGNOSTICS CONDITION 1 @sta2 = RETURNED_SQLSTATE,@msg2 = MESSAGE_TEXT;
    END;
	
    REVOKE SELECT ON test.t1 FROM jerry@localhost;
	
	GET STACKED DIAGNOSTICS @num12 = NUMBER, @row12 = ROW_COUNT;
    GET STACKED DIAGNOSTICS CONDITION 1 @sta12 = RETURNED_SQLSTATE,@msg12 = MESSAGE_TEXT;
  END;
  
  GRANT SELECT ON db1.t1 TO user1;
END;
//

CALL pro1()//
SELECT '内层 STACKED DIAGNOSTICS',@num2 'NUMBER', @row2 'ROW_COUNT',@sta2 'RETURNED_SQLSTATE', @msg2 'MESSAGE_TEXT';//
SELECT '外层 STACKED DIAGNOSTICS',@num12 'NUMBER', @row12 'ROW_COUNT',@sta12 'RETURNED_SQLSTATE', @msg12 'MESSAGE_TEXT';//


