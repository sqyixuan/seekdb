CREATE PROCEDURE pro1 () 
BEGIN
  DECLARE CONTINUE HANDLER FOR SQLEXCEPTION
   BEGIN
      SHOW WARNINGS;
      GET STACKED DIAGNOSTICS @p11 = NUMBER, @p12 = ROW_COUNT;
      GET STACKED DIAGNOSTICS CONDITION 1 @p13 = CLASS_ORIGIN, @p14 = SUBCLASS_ORIGIN, @p15 = RETURNED_SQLSTATE, @p16 = MESSAGE_TEXT, @p17 = MYSQL_ERRNO;
      SELECT '诊断语句执行成功时：',@p11 'NUMBER', @p12 'ROW_COUNT', @p13 'CLASS_ORIGIN', @p14 'SUBCLASS_ORIGIN', @p15 'RETURNED_SQLSTATE', @p16 'MESSAGE_TEXT', @p17 'MYSQL_ERRNO';
   END;
  SELECT * FROM no_such_table39;
END;
//

CALL pro1()//


