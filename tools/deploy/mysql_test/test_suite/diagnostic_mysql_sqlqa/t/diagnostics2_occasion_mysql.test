SET @num2=NULL,@row2=NULL,@sta2=NULL, @msg2=NULL;//
SET @num12=NULL,@row12=NULL,@sta12=NULL, @msg12=NULL;//
DROP PROCEDURE IF EXISTS pro1;//
CREATE PROCEDURE pro1 () 
BEGIN
  DECLARE CONTINUE HANDLER FOR SQLEXCEPTION
   BEGIN
      DECLARE id INT DEFAULT 'DECLEAR 语句';
	  DECLARE CONTINUE HANDLER FOR SQLEXCEPTION
      BEGIN
	    GET STACKED DIAGNOSTICS @num2 = NUMBER, @row2 = ROW_COUNT;
        GET STACKED DIAGNOSTICS CONDITION 1 @sta2 = RETURNED_SQLSTATE,@msg2 = MESSAGE_TEXT;
      END;

	  GET STACKED DIAGNOSTICS @num12 = NUMBER, @row12 = ROW_COUNT;
      GET STACKED DIAGNOSTICS CONDITION 1 @sta12 = RETURNED_SQLSTATE,@msg12 = MESSAGE_TEXT;
     
   END;
  SELECT * FROM no_such_table37;
END;
//

--error 1366
CALL pro1()//
SELECT '内层 STACKED DIAGNOSTICS',@num2 'NUMBER', @row2 'ROW_COUNT',@sta2 'RETURNED_SQLSTATE', @msg2 'MESSAGE_TEXT';//
SELECT '外层 STACKED DIAGNOSTICS',@num12 'NUMBER', @row12 'ROW_COUNT',@sta12 'RETURNED_SQLSTATE', @msg12 'MESSAGE_TEXT';//


SET @p11=NULL,@p12=NULL,@p13=NULL, @p14=NULL;//
DROP PROCEDURE IF EXISTS pro1;//
CREATE PROCEDURE pro1 () 
BEGIN
  DECLARE CONTINUE HANDLER FOR SQLEXCEPTION
   BEGIN
      DECLARE id VARCHAR(200) DEFAULT 'DECLEAR 语句';
      GET STACKED DIAGNOSTICS @p11 = NUMBER, @p12 = ROW_COUNT;
      GET STACKED DIAGNOSTICS CONDITION 1 @p13 = RETURNED_SQLSTATE, @p14 = MESSAGE_TEXT;
      SELECT 'STACKED DIAGNOSTICS',@p11 'NUMBER', @p12 'ROW_COUNT', @p13 'RETURNED_SQLSTATE', @p14 'MESSAGE_TEXT';
   END;
  SELECT * FROM no_such_table37;
END;
//

CALL pro1()//



--echo #### 标签：diagnostics-3-2-2 诊断语句
--echo ## GET DIAGNOSTICS 语句
SET @p11=NULL, @p12=NULL, @p13=NULL, @p14=NULL, @p15=NULL,@p16=NULL, @p17=NULL;//
DROP PROCEDURE IF EXISTS pro1;//
CREATE PROCEDURE pro1 () 
BEGIN
  DECLARE CONTINUE HANDLER FOR SQLEXCEPTION
   BEGIN
      GET STACKED DIAGNOSTICS @p11 = NUMBER, @p12 = ROW_COUNT;
      GET STACKED DIAGNOSTICS CONDITION 1 @p13 = CLASS_ORIGIN, @p14 = SUBCLASS_ORIGIN, @p15 = RETURNED_SQLSTATE, @p16 = MESSAGE_TEXT, @p17 = MYSQL_ERRNO;
      SELECT '诊断语句执行成功时：',@p11 'NUMBER', @p12 'ROW_COUNT', @p13 'CLASS_ORIGIN', @p14 'SUBCLASS_ORIGIN', @p15 'RETURNED_SQLSTATE', @p16 'MESSAGE_TEXT', @p17 'MYSQL_ERRNO';
   END;
  SELECT * FROM no_such_table38;
END;
//

CALL pro1()//


SET @p11=NULL, @p12=NULL, @p13=NULL, @p14=NULL, @p15=NULL,@p16=NULL, @p17=NULL;//
DROP PROCEDURE IF EXISTS pro1;//
CREATE PROCEDURE pro1 () 
BEGIN
  DECLARE CONTINUE HANDLER FOR SQLEXCEPTION
   BEGIN
      GET STACKED DIAGNOSTICS CONDITION 2 @p0 = MESSAGE_TEXT;
      GET STACKED DIAGNOSTICS @p11 = NUMBER, @p12 = ROW_COUNT;
      GET STACKED DIAGNOSTICS CONDITION 1 @p13 = CLASS_ORIGIN, @p14 = SUBCLASS_ORIGIN, @p15 = RETURNED_SQLSTATE, @p16 = MESSAGE_TEXT, @p17 = MYSQL_ERRNO;
      SELECT '诊断语句产生警告时：',@p11 'NUMBER', @p12 'ROW_COUNT', @p13 'CLASS_ORIGIN', @p14 'SUBCLASS_ORIGIN', @p15 'RETURNED_SQLSTATE', @p16 'MESSAGE_TEXT', @p17 'MYSQL_ERRNO';
   END;
  SELECT * FROM no_such_table38;
END;
//

CALL pro1()//


--echo ## SHOW WARNINGS 语句
