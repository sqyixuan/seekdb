--echo ######################### 标签:diagnostics-2-5 使用场景 - 存储过程  #########################
--echo #### 有条件处理程序
--echo # 一个条件处理程序
DROP PROCEDURE IF EXISTS pro1;//
CREATE PROCEDURE pro1 () 
BEGIN
  DECLARE CONTINUE HANDLER FOR SQLEXCEPTION
   BEGIN
      GET CURRENT DIAGNOSTICS @p11 = NUMBER, @p12 = ROW_COUNT;
      GET CURRENT DIAGNOSTICS CONDITION 1 @p13 = CLASS_ORIGIN, @p14 = SUBCLASS_ORIGIN, @p15 = RETURNED_SQLSTATE, @p16 = MESSAGE_TEXT, @p17 = MYSQL_ERRNO;
      GET STACKED DIAGNOSTICS @p21 = NUMBER, @p22 = ROW_COUNT;
      GET STACKED DIAGNOSTICS CONDITION 1 @p23 = CLASS_ORIGIN, @p24 = SUBCLASS_ORIGIN, @p25 = RETURNED_SQLSTATE, @p26 = MESSAGE_TEXT, @p27 = MYSQL_ERRNO;
      SELECT 'CURRENT DIAGNOSTICS',@p11 'NUMBER', @p12 'ROW_COUNT', @p13 'CLASS_ORIGIN', @p14 'SUBCLASS_ORIGIN', @p15 'RETURNED_SQLSTATE', @p16 'MESSAGE_TEXT', @p17 'MYSQL_ERRNO';
	  SELECT 'STACKED DIAGNOSTICS',@p21 'NUMBER', @p22 'ROW_COUNT', @p23 'CLASS_ORIGIN', @p24 'SUBCLASS_ORIGIN', @p25 'RETURNED_SQLSTATE', @p26 'MESSAGE_TEXT', @p27 'MYSQL_ERRNO';
  END;
  DROP TABLE no_such_table11;
END;
//

CALL pro1()//


--echo # 条件处理程序嵌套场景
--echo # 2层嵌套场景
--echo # bug16:条件处理程序嵌套场合，使用 GET [CURRENT|STACKED] DIAGNOSTICS 语句，mysql与ob结果不一致。 
SET @num1=NULL,@row1=NULL,@sta1=NULL, @msg1=NULL;//
SET @num11=NULL,@row11=NULL,@sta11=NULL, @msg11=NULL;//
DROP PROCEDURE IF EXISTS pro1;//
CREATE PROCEDURE pro1()
BEGIN
  DECLARE CONTINUE HANDLER FOR SQLEXCEPTION
  BEGIN
    DECLARE CONTINUE HANDLER FOR SQLEXCEPTION
    BEGIN
	  GET CURRENT DIAGNOSTICS @num1 = NUMBER, @row1 = ROW_COUNT;
	  GET CURRENT DIAGNOSTICS CONDITION 1 @sta1 = RETURNED_SQLSTATE,@msg1 = MESSAGE_TEXT;
    END;
	
    SELECT * FROM bbb;
	
	GET CURRENT DIAGNOSTICS @num11 = NUMBER, @row11 = ROW_COUNT;
	GET CURRENT DIAGNOSTICS CONDITION 1 @sta11 = RETURNED_SQLSTATE,@msg11 = MESSAGE_TEXT;
  END;
  
  DROP USER aaa;
END;
//

CALL pro1()//
SELECT '内层 CURRENT DIAGNOSTICS',@num1 'NUMBER', @row1 'ROW_COUNT',@sta1 'RETURNED_SQLSTATE', @msg1 'MESSAGE_TEXT';//
SELECT '外层 CURRENT DIAGNOSTICS',@num11 'NUMBER', @row11 'ROW_COUNT',@sta11 'RETURNED_SQLSTATE', @msg11 'MESSAGE_TEXT';//


SET @num2=NULL,@row2=NULL,@sta2=NULL, @msg2=NULL;//
SET @num12=NULL,@row12=NULL,@sta12=NULL, @msg12=NULL;//
DROP PROCEDURE IF EXISTS pro1;//
CREATE PROCEDURE pro1()
BEGIN
  DECLARE CONTINUE HANDLER FOR SQLEXCEPTION
  BEGIN
    DECLARE CONTINUE HANDLER FOR SQLEXCEPTION
    BEGIN
	  GET STACKED DIAGNOSTICS @num2 = NUMBER, @row2 = ROW_COUNT;
      GET STACKED DIAGNOSTICS CONDITION 1 @sta2 = RETURNED_SQLSTATE,@msg2 = MESSAGE_TEXT;
    END;
	
    SELECT * FROM bbb;
	
	GET STACKED DIAGNOSTICS @num12 = NUMBER, @row12 = ROW_COUNT;
    GET STACKED DIAGNOSTICS CONDITION 1 @sta12 = RETURNED_SQLSTATE,@msg12 = MESSAGE_TEXT;
  END;
  
  DROP USER aaa;
END;
//

CALL pro1()//
SELECT '内层 STACKED DIAGNOSTICS',@num2 'NUMBER', @row2 'ROW_COUNT',@sta2 'RETURNED_SQLSTATE', @msg2 'MESSAGE_TEXT';//
SELECT '外层 STACKED DIAGNOSTICS',@num12 'NUMBER', @row12 'ROW_COUNT',@sta12 'RETURNED_SQLSTATE', @msg12 'MESSAGE_TEXT';//


--echo # 3层嵌套场景
SET @num11=NULL,@row11=NULL,@sta11=NULL, @msg11=NULL;//
SET @num22=NULL,@row22=NULL,@sta22=NULL, @msg22=NULL;//
SET @num33=NULL,@row33=NULL,@sta33=NULL, @msg33=NULL;//
DROP PROCEDURE IF EXISTS pro1;//
CREATE PROCEDURE pro1()
BEGIN
  DECLARE CONTINUE HANDLER FOR SQLEXCEPTION
  BEGIN
    DECLARE CONTINUE HANDLER FOR SQLEXCEPTION
    BEGIN
      DECLARE CONTINUE HANDLER FOR SQLEXCEPTION
      BEGIN
        GET CURRENT DIAGNOSTICS @num33 = NUMBER, @row33 = ROW_COUNT;
        GET CURRENT DIAGNOSTICS CONDITION 1 @sta33 = RETURNED_SQLSTATE,@msg33 = MESSAGE_TEXT;
      END;
      SELECT * FROM ccc;
      GET CURRENT DIAGNOSTICS @num22= NUMBER, @row22 = ROW_COUNT;
      GET CURRENT DIAGNOSTICS CONDITION 1 @sta22 = RETURNED_SQLSTATE,@msg22 = MESSAGE_TEXT;
    END;
	
    SELECT * FROM bbb;
	
	GET CURRENT DIAGNOSTICS @num11 = NUMBER, @row11 = ROW_COUNT;
	GET CURRENT DIAGNOSTICS CONDITION 1 @sta11 = RETURNED_SQLSTATE,@msg11 = MESSAGE_TEXT;
  END;
  DROP USER aaa;
END;
//

CALL pro1()//
SELECT '1层 CURRENT DIAGNOSTICS',@num11 'NUMBER', @row11 'ROW_COUNT',@sta11 'RETURNED_SQLSTATE', @msg11 'MESSAGE_TEXT';//
SELECT '2层 CURRENT DIAGNOSTICS',@num22 'NUMBER', @row22 'ROW_COUNT',@sta22 'RETURNED_SQLSTATE', @msg22 'MESSAGE_TEXT';//
SELECT '3层 CURRENT DIAGNOSTICS',@num33 'NUMBER', @row33 'ROW_COUNT',@sta33 'RETURNED_SQLSTATE', @msg33 'MESSAGE_TEXT';//


SET @num11=NULL,@row11=NULL,@sta11=NULL, @msg11=NULL;//
SET @num22=NULL,@row22=NULL,@sta22=NULL, @msg22=NULL;//
SET @num33=NULL,@row33=NULL,@sta33=NULL, @msg33=NULL;//
DROP PROCEDURE IF EXISTS pro1;//
CREATE PROCEDURE pro1()
BEGIN
  DECLARE CONTINUE HANDLER FOR SQLEXCEPTION
  BEGIN
    DECLARE CONTINUE HANDLER FOR SQLEXCEPTION
    BEGIN
      DECLARE CONTINUE HANDLER FOR SQLEXCEPTION
      BEGIN
        GET STACKED DIAGNOSTICS @num33 = NUMBER, @row33 = ROW_COUNT;
        GET STACKED DIAGNOSTICS CONDITION 1 @sta33 = RETURNED_SQLSTATE,@msg33 = MESSAGE_TEXT;
      END;
      DROP USER ccc;
      GET STACKED DIAGNOSTICS @num22= NUMBER, @row22 = ROW_COUNT;
      GET STACKED DIAGNOSTICS CONDITION 1 @sta22 = RETURNED_SQLSTATE,@msg22 = MESSAGE_TEXT;
    END;
	
    SELECT * FROM bbb;
	
	GET STACKED DIAGNOSTICS @num11 = NUMBER, @row11 = ROW_COUNT;
	GET STACKED DIAGNOSTICS CONDITION 1 @sta11 = RETURNED_SQLSTATE,@msg11 = MESSAGE_TEXT;
  END;
  DROP USER aaa;
END;
//

CALL pro1()//
SELECT '1层 STACKED DIAGNOSTICS',@num11 'NUMBER', @row11 'ROW_COUNT',@sta11 'RETURNED_SQLSTATE', @msg11 'MESSAGE_TEXT';//
SELECT '2层 STACKED DIAGNOSTICS',@num22 'NUMBER', @row22 'ROW_COUNT',@sta22 'RETURNED_SQLSTATE', @msg22 'MESSAGE_TEXT';//
SELECT '3层 STACKED DIAGNOSTICS',@num33 'NUMBER', @row33 'ROW_COUNT',@sta33 'RETURNED_SQLSTATE', @msg33 'MESSAGE_TEXT';//


--echo #### 没有条件件处理程序
--echo # bug13:创建获取诊断信息（GET [CURRENT ] DIAGNOSTICS）的存储过程，执行sql语句后，调用该存储过程，mysql与ob结果不一致。 
SET @p11=NULL, @p12=NULL, @p13=NULL, @p14=NULL, @p15=NULL,@p16=NULL, @p17=NULL;//
DROP PROCEDURE IF EXISTS pro1;//
CREATE PROCEDURE pro1 () 
BEGIN
  SHOW warnings;
  GET CURRENT DIAGNOSTICS @p11 = NUMBER, @p12 = ROW_COUNT;
  GET CURRENT DIAGNOSTICS CONDITION 1 @p13 = CLASS_ORIGIN, @p14 = SUBCLASS_ORIGIN, @p15 = RETURNED_SQLSTATE, @p16 = MESSAGE_TEXT, @p17 = MYSQL_ERRNO;
  SELECT 'CURRENT DIAGNOSTICS',@p11 'NUMBER', @p12 'ROW_COUNT', @p13 'CLASS_ORIGIN', @p14 'SUBCLASS_ORIGIN', @p15 'RETURNED_SQLSTATE', @p16 'MESSAGE_TEXT', @p17 'MYSQL_ERRNO';
END;
//

--error 1051
DROP TABLE no_such_table13;//
CALL pro1()//


--echo # bug14:在存储过程中，使用 GET DIAGNOSTICS 语句获取诊断信息，执行存储过程时，mysql与ob结果不一致。 
SET @p11=NULL, @p12=NULL, @p13=NULL, @p14=NULL, @p15=NULL,@p16=NULL, @p17=NULL;//
DROP PROCEDURE IF EXISTS pro1;//
CREATE PROCEDURE pro1 () 
BEGIN
  DROP TABLE IF EXISTS no_such_table13;
  SHOW warnings;
  GET CURRENT DIAGNOSTICS @p11 = NUMBER, @p12 = ROW_COUNT;
  GET CURRENT DIAGNOSTICS CONDITION 1 @p13 = CLASS_ORIGIN, @p14 = SUBCLASS_ORIGIN, @p15 = RETURNED_SQLSTATE, @p16 = MESSAGE_TEXT, @p17 = MYSQL_ERRNO;
  SELECT 'CURRENT DIAGNOSTICS',@p11 'NUMBER', @p12 'ROW_COUNT', @p13 'CLASS_ORIGIN', @p14 'SUBCLASS_ORIGIN', @p15 'RETURNED_SQLSTATE', @p16 'MESSAGE_TEXT', @p17 'MYSQL_ERRNO';
END;
//

CALL pro1()//
SHOW warnings;//


--echo # bug15:在没有条件件处理程序的存储过程中， 用于GET STACKED DIAGNOSTICS 语句，mysql与ob结果不一致。 
SET @p21=NULL, @p22=NULL, @p23=NULL, @p24=NULL, @p25=NULL,@p26=NULL, @p27=NULL;//
DROP PROCEDURE IF EXISTS pro1;//
CREATE PROCEDURE pro1 () 
BEGIN
  DROP TABLE IF EXISTS no_such_table14;
  SHOW warnings;
  GET STACKED DIAGNOSTICS @p21 = NUMBER, @p22 = ROW_COUNT;
  GET STACKED DIAGNOSTICS CONDITION 1 @p23 = CLASS_ORIGIN, @p24 = SUBCLASS_ORIGIN, @p25 = RETURNED_SQLSTATE, @p26 = MESSAGE_TEXT, @p27 = MYSQL_ERRNO;
