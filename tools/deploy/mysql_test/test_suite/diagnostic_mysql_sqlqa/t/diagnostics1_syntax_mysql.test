BEGIN
  UPDATE dia_table1 SET c2='oracle-update' WHERE c1 = 2;
  GET DIAGNOSTICS CONDITION 1 @p21 = CLASS_ORIGIN, @p22 = SUBCLASS_ORIGIN, @p23 = RETURNED_SQLSTATE, @p24 = MESSAGE_TEXT, @p25 = MYSQL_ERRNO;
  SELECT @p21 'CLASS_ORIGIN', @p22 'SUBCLASS_ORIGIN', @p23 'RETURNED_SQLSTATE', @p24 'MESSAGE_TEXT', @p25 'MYSQL_ERRNO';
END;
