--echo ##日期时间类型
DROP PROCEDURE IF EXISTS pro1;//
CREATE PROCEDURE pro1 () DETERMINISTIC
BEGIN
  DECLARE num,num2 date;
  DECLARE row_count,row_count2 VARCHAR(200);
  DECLARE cla_ori,cla_ori2 time;
  DECLARE sub_ori,sub_ori2 year;
  DECLARE ret_sqlstate,ret_sqlstate2 datetime;
  DECLARE mes_text,mes_text2 timestamp;
  DECLARE mysql_err,mysql_err2 json;
  
  DECLARE CONTINUE HANDLER FOR SQLEXCEPTION
   BEGIN
      GET CURRENT DIAGNOSTICS num = NUMBER, row_count = ROW_COUNT;
	  GET STACKED DIAGNOSTICS num2 = NUMBER, row_count2 = ROW_COUNT;
      GET CURRENT DIAGNOSTICS CONDITION 1 cla_ori = CLASS_ORIGIN, sub_ori = SUBCLASS_ORIGIN, ret_sqlstate = RETURNED_SQLSTATE, mes_text = MESSAGE_TEXT, mysql_err = MYSQL_ERRNO;
	  GET STACKED DIAGNOSTICS CONDITION 1 cla_ori2 = CLASS_ORIGIN, sub_ori2 = SUBCLASS_ORIGIN, ret_sqlstate2 = RETURNED_SQLSTATE, mes_text2 = MESSAGE_TEXT, mysql_err2 = MYSQL_ERRNO;
      SELECT 'CURRENT DIAGNOSTICS',num 'NUMBER',row_count 'ROW_COUNT';
	  SELECT 'STACKED DIAGNOSTICS',num2 'NUMBER',row_count2 'ROW_COUNT';
	  SELECT 'CURRENT DIAGNOSTICS',cla_ori 'CLASS_ORIGIN', sub_ori 'SUBCLASS_ORIGIN', ret_sqlstate 'RETURNED_SQLSTATE', mes_text 'MESSAGE_TEXT', mysql_err 'MYSQL_ERRNO';
	  SELECT 'STACKED DIAGNOSTICS',cla_ori2 'CLASS_ORIGIN', sub_ori2 'SUBCLASS_ORIGIN', ret_sqlstate2 'RETURNED_SQLSTATE', mes_text2 'MESSAGE_TEXT', mysql_err2 'MYSQL_ERRNO';
  END;
  SELECT * FROM no_such_table8;
END;
//

#--error 1235
CALL pro1()//


