--echo ### 指示符对象- DECLARE声明的局部变量
DROP PROCEDURE IF EXISTS pro1;//
CREATE PROCEDURE pro1 () DETERMINISTIC
BEGIN
  DECLARE cla_ori varchar(200);
  DECLARE sub_ori varchar(200);
  DECLARE ret_sqlstate varchar(200);
  DECLARE mes_text varchar(200);
  DECLARE mysql_err varchar(200);
  UPDATE dia_table1 SET c2='oracle-update' WHERE c1 = 2;
  GET DIAGNOSTICS CONDITION 1 cla_ori = CLASS_ORIGIN, sub_ori = SUBCLASS_ORIGIN, ret_sqlstate = RETURNED_SQLSTATE, mes_text = MESSAGE_TEXT, mysql_err = MYSQL_ERRNO;
  INSERT INTO dia_table2 VALUES(null,'-','-',cla_ori,sub_ori,ret_sqlstate,mes_text,mysql_err);
END;
//

CALL pro1()//
SELECT * FROM dia_table2 ORDER BY id;//


DROP PROCEDURE IF EXISTS pro1;//
CREATE PROCEDURE pro1 () DETERMINISTIC
BEGIN
  DECLARE cla_ori,cla_ori2 varchar(200);
  DECLARE sub_ori,sub_ori2 varchar(200);
  DECLARE ret_sqlstate,ret_sqlstate2 varchar(200);
  DECLARE mes_text,mes_text2 varchar(200);
  DECLARE mysql_err,mysql_err2 varchar(200);
  
  DECLARE CONTINUE HANDLER FOR SQLEXCEPTION
   BEGIN
      GET DIAGNOSTICS CONDITION 1 cla_ori = CLASS_ORIGIN, sub_ori = SUBCLASS_ORIGIN, ret_sqlstate = RETURNED_SQLSTATE, mes_text = MESSAGE_TEXT, mysql_err = MYSQL_ERRNO;
      GET STACKED DIAGNOSTICS CONDITION 1 cla_ori2 = CLASS_ORIGIN, sub_ori2 = SUBCLASS_ORIGIN, ret_sqlstate2 = RETURNED_SQLSTATE, mes_text2 = MESSAGE_TEXT, mysql_err2 = MYSQL_ERRNO;
      INSERT INTO dia_table2 VALUES(null,'-','-',cla_ori,sub_ori,ret_sqlstate,mes_text,mysql_err);
	  INSERT INTO dia_table2 VALUES(null,'-','-',cla_ori2,sub_ori2,ret_sqlstate2,mes_text2,mysql_err2);
  END;
  SELECT * FROM no_such_table5;
END;
//

CALL pro1()//
SELECT * FROM dia_table2 ORDER BY id;//


--echo #### 标签：diagnostics-1-2-3-2 指示符对象-指示符数据类型
--echo # bug3:GET DIAGNOSTICS 诊断语句,target(用于存储项目信息的有效指示符)用数值，字符，日期数据类型存储时，mysql与ob结果不一致。
--echo ##数值类型
DROP PROCEDURE IF EXISTS pro1;//
CREATE PROCEDURE pro1 () DETERMINISTIC
BEGIN
  DECLARE num,num2 tinyint;
  DECLARE row_count,row_count2 smallint;
  DECLARE cla_ori,cla_ori2 mediumint;
  DECLARE sub_ori,sub_ori2 int;
  DECLARE ret_sqlstate,ret_sqlstate2 bigint;
  DECLARE mes_text,mes_text2 float;
  DECLARE mysql_err,mysql_err2 double;
  
  DECLARE CONTINUE HANDLER FOR SQLEXCEPTION
   BEGIN
      GET CURRENT DIAGNOSTICS num = NUMBER, row_count = ROW_COUNT;
	  GET STACKED DIAGNOSTICS num2 = NUMBER, row_count2 = ROW_COUNT;
      GET CURRENT DIAGNOSTICS CONDITION 1 cla_ori = CLASS_ORIGIN, sub_ori = SUBCLASS_ORIGIN, ret_sqlstate = RETURNED_SQLSTATE, mes_text = MESSAGE_TEXT, mysql_err = MYSQL_ERRNO;
	  GET STACKED DIAGNOSTICS CONDITION 1 cla_ori2 = CLASS_ORIGIN, sub_ori2 = SUBCLASS_ORIGIN, ret_sqlstate2 = RETURNED_SQLSTATE, mes_text2 = MESSAGE_TEXT, mysql_err2 = MYSQL_ERRNO;
      SELECT 'CURRENT DIAGNOSTICS',num 'NUMBER',row_count 'ROW_COUNT';
	  SELECT 'STACKED DIAGNOSTICS',num2 'NUMBER',row_count2 'ROW_COUNT';
	  SELECT 'CURRENT DIAGNOSTICS',cla_ori 'CLASS_ORIGIN', sub_ori 'SUBCLASS_ORIGIN', ret_sqlstate 'RETURNED_SQLSTATE', mes_text 'MESSAGE_TEXT', mysql_err 'MYSQL_ERRNO';
	  SELECT 'STACKED DIAGNOSTICS',cla_ori2 'CLASS_ORIGIN', sub_ori2 'SUBCLASS_ORIGIN', ret_sqlstate2 'RETURNED_SQLSTATE', mes_text2 'MESSAGE_TEXT', mysql_err2 'MYSQL_ERRNO';
  END;
  SELECT * FROM no_such_table6;
END;
//

CALL pro1()//


DROP PROCEDURE IF EXISTS pro1;//
CREATE PROCEDURE pro1 () DETERMINISTIC
BEGIN
  DECLARE num,num2 decimal;
  DECLARE row_count,row_count2 bit;
  DECLARE cla_ori,cla_ori2 float;
  DECLARE sub_ori,sub_ori2 double;
  DECLARE ret_sqlstate,ret_sqlstate2 decimal;
  DECLARE mes_text,mes_text2 tinyint;
  DECLARE mysql_err,mysql_err2 bigint;
  
  DECLARE CONTINUE HANDLER FOR SQLEXCEPTION
   BEGIN
      GET CURRENT DIAGNOSTICS num = NUMBER, row_count = ROW_COUNT;
	  GET STACKED DIAGNOSTICS num2 = NUMBER, row_count2 = ROW_COUNT;
      GET CURRENT DIAGNOSTICS CONDITION 1 cla_ori = CLASS_ORIGIN, sub_ori = SUBCLASS_ORIGIN, ret_sqlstate = RETURNED_SQLSTATE, mes_text = MESSAGE_TEXT, mysql_err = MYSQL_ERRNO;
	  GET STACKED DIAGNOSTICS CONDITION 1 cla_ori2 = CLASS_ORIGIN, sub_ori2 = SUBCLASS_ORIGIN, ret_sqlstate2 = RETURNED_SQLSTATE, mes_text2 = MESSAGE_TEXT, mysql_err2 = MYSQL_ERRNO;
      SELECT 'CURRENT DIAGNOSTICS',num 'NUMBER',row_count 'ROW_COUNT';
	  SELECT 'STACKED DIAGNOSTICS',num2 'NUMBER',row_count2 'ROW_COUNT';
	  SELECT 'CURRENT DIAGNOSTICS',cla_ori 'CLASS_ORIGIN', sub_ori 'SUBCLASS_ORIGIN', ret_sqlstate 'RETURNED_SQLSTATE', mes_text 'MESSAGE_TEXT', mysql_err 'MYSQL_ERRNO';
	  SELECT 'STACKED DIAGNOSTICS',cla_ori2 'CLASS_ORIGIN', sub_ori2 'SUBCLASS_ORIGIN', ret_sqlstate2 'RETURNED_SQLSTATE', mes_text2 'MESSAGE_TEXT', mysql_err2 'MYSQL_ERRNO';
  END;
  SELECT * FROM no_such_table7;
END;
//

--error 1235
CALL pro1()//


--echo ##字符串类型
DROP PROCEDURE IF EXISTS pro1;//
CREATE PROCEDURE pro1 () DETERMINISTIC
BEGIN
  DECLARE num,num2 CHAR(200);
  DECLARE row_count,row_count2 BINARY;
  DECLARE cla_ori,cla_ori2 BLOB;
  DECLARE sub_ori,sub_ori2 BLOB;
  DECLARE ret_sqlstate,ret_sqlstate2 TEXT;
  DECLARE mes_text,mes_text2 BINARY;
  DECLARE mysql_err,mysql_err2 VARBINARY(200);
  DECLARE CONTINUE HANDLER FOR SQLEXCEPTION
   BEGIN
      GET CURRENT DIAGNOSTICS num = NUMBER, row_count = ROW_COUNT;
	  GET STACKED DIAGNOSTICS num2 = NUMBER, row_count2 = ROW_COUNT;
      GET CURRENT DIAGNOSTICS CONDITION 1 cla_ori = CLASS_ORIGIN, sub_ori = SUBCLASS_ORIGIN, ret_sqlstate = RETURNED_SQLSTATE, mes_text = MESSAGE_TEXT, mysql_err = MYSQL_ERRNO;
	  GET STACKED DIAGNOSTICS CONDITION 1 cla_ori2 = CLASS_ORIGIN, sub_ori2 = SUBCLASS_ORIGIN, ret_sqlstate2 = RETURNED_SQLSTATE, mes_text2 = MESSAGE_TEXT, mysql_err2 = MYSQL_ERRNO;
      SELECT 'CURRENT DIAGNOSTICS',num 'NUMBER',row_count 'ROW_COUNT';
	  SELECT 'STACKED DIAGNOSTICS',num2 'NUMBER',row_count2 'ROW_COUNT';
	  SELECT 'CURRENT DIAGNOSTICS',cla_ori 'CLASS_ORIGIN', sub_ori 'SUBCLASS_ORIGIN', ret_sqlstate 'RETURNED_SQLSTATE', mes_text 'MESSAGE_TEXT', mysql_err 'MYSQL_ERRNO';
	  SELECT 'STACKED DIAGNOSTICS',cla_ori2 'CLASS_ORIGIN', sub_ori2 'SUBCLASS_ORIGIN', ret_sqlstate2 'RETURNED_SQLSTATE', mes_text2 'MESSAGE_TEXT', mysql_err2 'MYSQL_ERRNO';
  END;
  SELECT * FROM no_such_table8;
END;
//

CALL pro1()//


DROP PROCEDURE IF EXISTS pro1;//
CREATE PROCEDURE pro1 () DETERMINISTIC
BEGIN
  DECLARE num,num2 BINARY;
  DECLARE row_count,row_count2 SET('1');
  DECLARE cla_ori,cla_ori2 ENUM ('1');
  DECLARE sub_ori,sub_ori2 SET('1');
  DECLARE ret_sqlstate,ret_sqlstate2 ENUM ('1');
  DECLARE mes_text,mes_text2 SET('1');
  DECLARE mysql_err,mysql_err2 ENUM ('1');
  DECLARE CONTINUE HANDLER FOR SQLEXCEPTION
   BEGIN
