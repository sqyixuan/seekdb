SET @p21=NULL, @p22=NULL, @p23=NULL, @p24=NULL, @p25=NULL,@p31=NULL, @p32=NULL, @p33=NULL, @p34=NULL, @p35=NULL;//
DROP PROCEDURE IF EXISTS pro1;//
CREATE PROCEDURE pro1 () 
BEGIN
  DECLARE CONTINUE HANDLER FOR SQLEXCEPTION
   BEGIN
      GET CURRENT DIAGNOSTICS CONDITION 1 @p21 = CLASS_ORIGIN, @p22 = SUBCLASS_ORIGIN, @p23 = RETURNED_SQLSTATE, @p24 = MESSAGE_TEXT, @p25 = MYSQL_ERRNO;
      GET STACKED DIAGNOSTICS CONDITION 1 @p31 = CLASS_ORIGIN, @p32 = SUBCLASS_ORIGIN, @p33 = RETURNED_SQLSTATE, @p34 = MESSAGE_TEXT, @p35 = MYSQL_ERRNO;
      SELECT 'CURRENT DIAGNOSTICS',@p21 'CLASS_ORIGIN', @p22 'SUBCLASS_ORIGIN', @p23 'RETURNED_SQLSTATE', @p24 'MESSAGE_TEXT', @p25 'MYSQL_ERRNO';
	  SELECT 'STACKED DIAGNOSTICS',@p31 'CLASS_ORIGIN', @p32 'SUBCLASS_ORIGIN', @p33 'RETURNED_SQLSTATE', @p34 'MESSAGE_TEXT', @p35 'MYSQL_ERRNO';
  END;
