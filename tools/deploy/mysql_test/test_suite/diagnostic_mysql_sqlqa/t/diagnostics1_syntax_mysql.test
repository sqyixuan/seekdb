BEGIN
  DECLARE CONTINUE HANDLER FOR SQLEXCEPTION
  BEGIN
    GET DIAGNOSTICS CONDITION num @p21 = CLASS_ORIGIN, @p22 = SUBCLASS_ORIGIN, @p23 = RETURNED_SQLSTATE, @p24 = MESSAGE_TEXT, @p25 = MYSQL_ERRNO;
	GET STACKED DIAGNOSTICS CONDITION num @p31 = CLASS_ORIGIN, @p32 = SUBCLASS_ORIGIN, @p33 = RETURNED_SQLSTATE, @p34 = MESSAGE_TEXT, @p35 = MYSQL_ERRNO;
  END;  
  SELECT id into @p FROM no_such_table9;
  RETURN 'ok';
END;
