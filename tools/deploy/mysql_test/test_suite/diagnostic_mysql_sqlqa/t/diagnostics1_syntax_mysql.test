# owner: hr351303
# owner group: sql4
# description: GET DIAGNOSTICS 诊断语句 - 基本语法
# tags: pl,dml,auto_increment
# author: whh01047778


purge recyclebin;
--result_format 4
--error 0,1396
drop user whh@'%';
--enable_warnings
create user whh identified by 'whh';
grant all on *.* to whh WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,whh,whh,test,$OBMYSQL_PORT);

delimiter //;

--echo -----------------------------------------------------------------------------------------------------------------
--echo ------------------------- GET DIAGNOSTICS  诊断语句 -------------------------------------------------------------
--echo ###### 标签：diagnostics-1 基本语法 
--echo -----------------------------------------------------------------------------------------------------------------

--echo ######################### 标签：diagnostics-1-1 基本语法 - 关键字参数  #########################
SET @p2=NULL, @p20=NULL, @p21=NULL, @p22=NULL, @p23=NULL, @p24=NULL, @p25=NULL;//
SET @p3=NULL, @p30=NULL, @p31=NULL, @p32=NULL, @p33=NULL, @p34=NULL, @p35=NULL;//
DROP PROCEDURE IF EXISTS pro1;//
CREATE PROCEDURE pro1 () 
BEGIN
  DECLARE CONTINUE HANDLER FOR SQLEXCEPTION
   BEGIN
      GET CURRENT DIAGNOSTICS @p2 = NUMBER, @p20 = ROW_COUNT;
      GET CURRENT DIAGNOSTICS CONDITION 1 @p21 = CLASS_ORIGIN, @p22 = SUBCLASS_ORIGIN, @p23 = RETURNED_SQLSTATE, @p24 = MESSAGE_TEXT, @p25 = MYSQL_ERRNO;
      GET STACKED DIAGNOSTICS @p3 = NUMBER, @p30 = ROW_COUNT;
	  GET STACKED DIAGNOSTICS CONDITION 1 @p31 = CLASS_ORIGIN, @p32 = SUBCLASS_ORIGIN, @p33 = RETURNED_SQLSTATE, @p34 = MESSAGE_TEXT, @p35 = MYSQL_ERRNO;
      SELECT 'CURRENT DIAGNOSTICS',@p2 'NUMBER', @p20 'ROW_COUNT',@p21 'CLASS_ORIGIN', @p22 'SUBCLASS_ORIGIN', @p23 'RETURNED_SQLSTATE', @p24 'MESSAGE_TEXT', @p25 'MYSQL_ERRNO';
	  SELECT 'STACKED DIAGNOSTICS',@p3 'NUMBER', @p30 'ROW_COUNT',@p31 'CLASS_ORIGIN', @p32 'SUBCLASS_ORIGIN', @p33 'RETURNED_SQLSTATE', @p34 'MESSAGE_TEXT', @p35 'MYSQL_ERRNO';
  END;
  DROP TABLE no_such_table0;
END;
//

CALL pro1()//

delimiter ;//


--echo ######################### 标签：diagnostics-1-2 基本语法 - 检索列表参数 #########################
--echo #### 测试前表准备
--error 0,1051
DROP TABLE dia_table1;
CREATE TABLE dia_table1( 
  c1 int, 
  c2 VARCHAR(200),
  c3 VARCHAR(200)
);

insert into dia_table1 values(1,'mysql','8.0');
insert into dia_table1 values(2,'oracle','-');
insert into dia_table1 values(3,'ob','8.0');

--error 0,1051
DROP TABLE dia_table2;
CREATE TABLE dia_table2( 
  id int primary key auto_increment,
  numbers  varchar(200),
  row_count varchar(200),
  cla_ori varchar(200),
  sub_ori varchar(200),
  ret_sqlstate varchar(200),
  mes_text varchar(200),
  mysql_err varchar(200)
);


--echo #### 标签：diagnostics-1-2-1 语句信息
--echo # bug1:GET DIAGNOSTICS 诊断语句获取ROW_COUNT （SQL语句改变的行数），mysql与ob结果不一致。
SET @p1=NULL, @p2=NULL;
DELETE FROM dia_table1 WHERE c1 <= 2;
GET CURRENT DIAGNOSTICS @p1 = NUMBER, @p2 = ROW_COUNT;
SELECT  @p1 'NUMBER', @p2 'ROW_COUNT';

SET @p1=NULL, @p2=NULL;
INSERT INTO dia_table1 VALUES(2,'oracle','-');
GET DIAGNOSTICS @p1 = NUMBER, @p2 = ROW_COUNT;
SELECT  @p1 'NUMBER', @p2 'ROW_COUNT';

SET @p1=NULL, @p2=NULL;
UPDATE dia_table1 SET c2='oracle-update' WHERE c1 = 2;
GET CURRENT DIAGNOSTICS @p1 = NUMBER, @p2 = ROW_COUNT;
SELECT  @p1 'NUMBER', @p2 'ROW_COUNT';

SET @p1=NULL, @p2=NULL;
SELECT * FROM dia_table1 ORDER BY c1;
GET DIAGNOSTICS @p1 = NUMBER, @p2 = ROW_COUNT;
SELECT  @p1 'NUMBER', @p2 'ROW_COUNT';

SET @p1=NULL, @p2=NULL;
--error 1051
DROP TABLE no_such_table1;
GET CURRENT DIAGNOSTICS @p1 = NUMBER, @p2 = ROW_COUNT;
SELECT  @p1 'NUMBER', @p2 'ROW_COUNT';


--echo #### 标签：diagnostics-1-2-2 条件信息
SET @p10=NULL, @p20=NULL, @p30=NULL, @p40=NULL, @p50=NULL;
SET @p11=NULL, @p12=NULL, @p13=NULL, @p1=NULL, @p15=NULL, @p16=NULL, @p17=NULL;
insert into dia_table1 values(1,'mysql','8.0');
GET CURRENT DIAGNOSTICS CONDITION 1 @p10 = CLASS_ORIGIN, @p20 = SUBCLASS_ORIGIN, @p30 = RETURNED_SQLSTATE, @p40 = MESSAGE_TEXT, @p50 = MYSQL_ERRNO;
GET CURRENT DIAGNOSTICS CONDITION 1 @p11 = CONSTRAINT_CATALOG, @p12 = CONSTRAINT_SCHEMA, @p13 = CONSTRAINT_NAME, @p14 = CATALOG_NAME, @p15 = SCHEMA_NAME, @p16 = TABLE_NAME, @p17 = COLUMN_NAME, @p18 = CURSOR_NAME;
SELECT @p10, @p20, @p30, @p40, @p50;
SELECT @p11, @p12, @p13, @p14, @p15, @p16, @p17;


SET @p1=NULL, @p2=NULL, @p3=NULL, @p4=NULL, @p5=NULL;
SET @p11=NULL, @p12=NULL, @p13=NULL, @p1=NULL, @p15=NULL, @p16=NULL, @p17=NULL;
--error 1051
DROP TABLE no_such_table2;
GET DIAGNOSTICS CONDITION 1 @p1 = CLASS_ORIGIN, @p2 = SUBCLASS_ORIGIN, @p3 = RETURNED_SQLSTATE, @p4 = MESSAGE_TEXT, @p5 = MYSQL_ERRNO;
GET DIAGNOSTICS CONDITION 1 @p11 = CONSTRAINT_CATALOG, @p12 = CONSTRAINT_SCHEMA, @p13 = CONSTRAINT_NAME, @p14 = CATALOG_NAME, @p15 = SCHEMA_NAME, @p16 = TABLE_NAME, @p17 = COLUMN_NAME, @p18 = CURSOR_NAME;
SELECT @p1, @p2, @p3, @p4, @p5;
SELECT @p11, @p12, @p13, @p14, @p15, @p16, @p17;

delimiter //;

--echo #### 标签：diagnostics-1-2-3 存储信息指示符 
--echo #### 标签：diagnostics-1-2-3-1 指示符对象-语句信息指示符对象
--echo # issue: 41307421 Closed bug2:GET DIAGNOSTICS 诊断语句,target用于存储项目信息的有效指示符是存储过程参数，DECLARE声明的存储程序局部变量或用户定义的变量，获取ROW_COUNT （SQL语句改变的行数）时，mysql与ob结果不一致。
--echo ### 指示符对象-存储过程参数
SET @p11=NULL, @p12=NULL,@p21=NULL, @p22=NULL;//
DROP PROCEDURE IF EXISTS pro1;//
CREATE PROCEDURE pro1 (out num1 varchar(200),out row_cou1 varchar(200),out num2 varchar(200),out row_cou2 varchar(200)) 
BEGIN
  DECLARE CONTINUE HANDLER FOR SQLEXCEPTION
   BEGIN
      GET CURRENT DIAGNOSTICS num1 = NUMBER, row_cou1 = ROW_COUNT;
	  GET STACKED DIAGNOSTICS num2 = NUMBER, row_cou2 = ROW_COUNT;
  END;
  DROP TABLE no_such_table3;
END;
//

CALL pro1(@p11, @p12,@p21, @p22)//
SELECT 'CURRENT DIAGNOSTICS',@p11 'NUMBER', @p12 'ROW_COUNT';//
SELECT 'STACKED DIAGNOSTICS',@p21 'NUMBER', @p22 'ROW_COUNT';//


SET @p11=NULL, @p12=NULL,@p21=NULL, @p22=NULL;//
DROP PROCEDURE IF EXISTS pro1;//
CREATE PROCEDURE pro1 (inout num1 varchar(200),inout row_cou1 varchar(200),inout num2 varchar(200),inout row_cou2 varchar(200)) 
BEGIN
  DECLARE CONTINUE HANDLER FOR SQLEXCEPTION
   BEGIN
      GET CURRENT DIAGNOSTICS num1 = NUMBER, row_cou1 = ROW_COUNT;
	  GET STACKED DIAGNOSTICS num2 = NUMBER, row_cou2 = ROW_COUNT;
  END;
  DROP TABLE no_such_table3;
END;
//

CALL pro1(@p11, @p12,@p21, @p22)//
SELECT 'CURRENT DIAGNOSTICS',@p11 'NUMBER', @p12 'ROW_COUNT';//
SELECT 'STACKED DIAGNOSTICS',@p21 'NUMBER', @p22 'ROW_COUNT';//


--echo ### 指示符对象-用户定义的变量
SET @p1=NULL, @p2=NULL,@p3=NULL, @p4=NULL;//

DROP PROCEDURE IF EXISTS pro1;//
CREATE PROCEDURE pro1 () 
BEGIN
  DECLARE CONTINUE HANDLER FOR SQLEXCEPTION
   BEGIN
      GET DIAGNOSTICS @p1 = NUMBER, @p2 = ROW_COUNT;
	  GET STACKED DIAGNOSTICS @p3 = NUMBER, @p4 = ROW_COUNT;
      SELECT 'CURRENT DIAGNOSTICS',@p1 'NUMBER', @p2 'ROW_COUNT';
	  SELECT 'STACKED DIAGNOSTICS',@p3 'NUMBER', @p4 'ROW_COUNT';
  END;
  DROP TABLE no_such_table4;
END;
//

CALL pro1()//


--echo ### 指示符对象- DECLARE声明的局部变量
DROP PROCEDURE IF EXISTS pro1;//
CREATE PROCEDURE pro1()
BEGIN
   DECLARE num1,cou1 INT;
   DECLARE num2,cou2 INT;
   DECLARE CONTINUE HANDLER FOR SQLEXCEPTION
   BEGIN
    GET DIAGNOSTICS num1 = NUMBER, cou1 = ROW_COUNT;
	GET STACKED DIAGNOSTICS num2 = NUMBER, cou2 = ROW_COUNT;
    SELECT 'CURRENT DIAGNOSTICS',num1 'NUMBER', cou1 'ROW_COUNT';
	SELECT 'STACKED DIAGNOSTICS',num2 'NUMBER', cou2 'ROW_COUNT';
  END;
  SELECT * FROM tt1;
END;//

CALL pro1()//


--echo #### 标签：diagnostics-1-2-3-2 指示符对象-条件信息指示符对象
--echo ### 指示符对象-存储过程参数
SET @p21=NULL, @p22=NULL, @p23=NULL, @p24=NULL, @p25=NULL;//
DROP PROCEDURE IF EXISTS pro1;//
CREATE PROCEDURE pro1 (out cla_ori varchar(200),out sub_ori varchar(200),out ret_sqlstate varchar(200),out mes_text varchar(200),out mysql_err varchar(200)) 
BEGIN
  UPDATE dia_table1 SET c2='oracle-update' WHERE c1 = 2;
  GET CURRENT DIAGNOSTICS CONDITION 1 cla_ori = CLASS_ORIGIN, sub_ori = SUBCLASS_ORIGIN, ret_sqlstate = RETURNED_SQLSTATE, mes_text = MESSAGE_TEXT, mysql_err = MYSQL_ERRNO;
END;
//

CALL pro1(@p21, @p22, @p23, @p24, @p25)//
SELECT  @p21 'CLASS_ORIGIN', @p22 'SUBCLASS_ORIGIN', @p23 'RETURNED_SQLSTATE', @p24 'MESSAGE_TEXT', @p25 'MYSQL_ERRNO';//


SET @p21=NULL, @p22=NULL, @p23=NULL, @p24=NULL, @p25=NULL,@p31=NULL, @p32=NULL, @p33=NULL, @p34=NULL, @p35=NULL;//
DROP PROCEDURE IF EXISTS pro1;//
CREATE PROCEDURE pro1 (out cla_ori varchar(200),out sub_ori varchar(200),out ret_sqlstate varchar(200),out mes_text varchar(200),out mysql_err varchar(200),out cla_ori2 varchar(200),out sub_ori2 varchar(200),out ret_sqlstate2 varchar(200),out mes_text2 varchar(200),out mysql_err2 varchar(200)) 
BEGIN
  DECLARE CONTINUE HANDLER FOR SQLEXCEPTION
   BEGIN
      GET DIAGNOSTICS CONDITION 1 cla_ori = CLASS_ORIGIN, sub_ori = SUBCLASS_ORIGIN, ret_sqlstate = RETURNED_SQLSTATE, mes_text = MESSAGE_TEXT, mysql_err = MYSQL_ERRNO;
      GET STACKED DIAGNOSTICS CONDITION 1 cla_ori2 = CLASS_ORIGIN, sub_ori2 = SUBCLASS_ORIGIN, ret_sqlstate2 = RETURNED_SQLSTATE, mes_text2 = MESSAGE_TEXT, mysql_err2 = MYSQL_ERRNO;
  END;
  DROP TABLE no_such_table3;
END;
//

CALL pro1(@p21, @p22, @p23, @p24, @p25,@p31, @p32, @p33, @p34, @p35)//
SELECT 'CURRENT DIAGNOSTICS',@p21 'CLASS_ORIGIN', @p22 'SUBCLASS_ORIGIN', @p23 'RETURNED_SQLSTATE', @p24 'MESSAGE_TEXT', @p25 'MYSQL_ERRNO';//
SELECT 'STACKED DIAGNOSTICS',@p31 'CLASS_ORIGIN', @p32 'SUBCLASS_ORIGIN', @p33 'RETURNED_SQLSTATE', @p34 'MESSAGE_TEXT', @p35 'MYSQL_ERRNO';//


SET @p21=NULL, @p22=NULL, @p23=NULL, @p24=NULL, @p25=NULL,@p31=NULL, @p32=NULL, @p33=NULL, @p34=NULL, @p35=NULL;//
DROP PROCEDURE IF EXISTS pro1;//
CREATE PROCEDURE pro1 (inout cla_ori varchar(200),inout sub_ori varchar(200),inout ret_sqlstate varchar(200),inout mes_text varchar(200),inout mysql_err varchar(200),inout cla_ori2 varchar(200),inout sub_ori2 varchar(200),inout ret_sqlstate2 varchar(200),inout mes_text2 varchar(200),inout mysql_err2 varchar(200)) 
BEGIN
  DECLARE CONTINUE HANDLER FOR SQLEXCEPTION
   BEGIN
      GET DIAGNOSTICS CONDITION 1 cla_ori = CLASS_ORIGIN, sub_ori = SUBCLASS_ORIGIN, ret_sqlstate = RETURNED_SQLSTATE, mes_text = MESSAGE_TEXT, mysql_err = MYSQL_ERRNO;
      GET STACKED DIAGNOSTICS CONDITION 1 cla_ori2 = CLASS_ORIGIN, sub_ori2 = SUBCLASS_ORIGIN, ret_sqlstate2 = RETURNED_SQLSTATE, mes_text2 = MESSAGE_TEXT, mysql_err2 = MYSQL_ERRNO;
  END;
  DROP TABLE no_such_table3;
END;
//

CALL pro1(@p21, @p22, @p23, @p24, @p25,@p31, @p32, @p33, @p34, @p35)//
SELECT 'CURRENT DIAGNOSTICS',@p21 'CLASS_ORIGIN', @p22 'SUBCLASS_ORIGIN', @p23 'RETURNED_SQLSTATE', @p24 'MESSAGE_TEXT', @p25 'MYSQL_ERRNO';//
SELECT 'STACKED DIAGNOSTICS',@p31 'CLASS_ORIGIN', @p32 'SUBCLASS_ORIGIN', @p33 'RETURNED_SQLSTATE', @p34 'MESSAGE_TEXT', @p35 'MYSQL_ERRNO';//


--echo ### 指示符对象-用户定义的变量
SET @p21=NULL, @p22=NULL, @p23=NULL, @p24=NULL, @p25=NULL;//
DROP PROCEDURE IF EXISTS pro1;//
