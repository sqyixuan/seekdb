	  SELECT '【CURRENT DIAGNOSTICS】',@num1 'NUMBER', @p13 'CLASS_ORIGIN', @p14 'SUBCLASS_ORIGIN', @p15 'RETURNED_SQLSTATE', @p16 'MESSAGE_TEXT', @p17 'MYSQL_ERRNO';
      SELECT '【STACKED DIAGNOSTICS】',@num2 'NUMBER', @p23 'CLASS_ORIGIN', @p24 'SUBCLASS_ORIGIN', @p25 'RETURNED_SQLSTATE', @p26 'MESSAGE_TEXT', @p27 'MYSQL_ERRNO';
  END;
