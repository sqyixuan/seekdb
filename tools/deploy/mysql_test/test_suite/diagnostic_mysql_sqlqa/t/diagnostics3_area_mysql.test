SELECT '【STACKED DIAGNOSTICS】', @p21 'NUMBER', @p22 'ROW_COUNT',@p23 'CLASS_ORIGIN', @p24 'SUBCLASS_ORIGIN', @p25 'RETURNED_SQLSTATE', @p26 'MESSAGE_TEXT', @p27 'MYSQL_ERRNO';//


