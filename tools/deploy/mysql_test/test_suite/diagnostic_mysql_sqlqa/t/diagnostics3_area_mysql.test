  DECLARE CONTINUE HANDLER FOR SQLEXCEPTION
   BEGIN
    GET CURRENT DIAGNOSTICS @p11 = NUMBER, @p12 = ROW_COUNT,@p13 = CLASS_ORIGIN, @p14 = SUBCLASS_ORIGIN, @p15 = RETURNED_SQLSTATE, @p16 = MESSAGE_TEXT, @p17 = MYSQL_ERRNO;
  END;
  DROP USER nouser;
END;
//


