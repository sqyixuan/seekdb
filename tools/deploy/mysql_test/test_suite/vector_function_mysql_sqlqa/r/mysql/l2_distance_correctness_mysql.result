CREATE TABLE t2 (a1 int , a2 vector(3),a3 vector(3) ,a4 vector(3),
VECTOR INDEX vector_idx(a3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
insert into t2 select c1,c2,c3,c4 from t1;
SELECT sum(c2+c3), CASE WHEN (SELECT sum(c2+c3) FROM t1 where c3 is not null order by l2_distance(c3, [1,1,-1]) approximate limit 1) = [2,0,6] THEN 'High' ELSE 'Low' END AS A FROM T1 order by l2_distance(c3, [1,1,-1]) approximate limit 1;
sum(c2+c3)	A
[-4,7,17]	Low
SELECT sum(c2+c3), CASE WHEN (SELECT sum(c2+c3) FROM t1 order by l2_distance(c3, [1,1,-1]) approximate limit 1) is  null THEN (select l2_distance(c3, [1,1,-1]) from t1 order by l2_distance(c3, [1,1,-1]) approximate limit 1) ELSE (select l2_distance(c2, [1,1,-1]) from t1 order by l2_distance(c3, [1,1,-1]) approximate limit 1) END AS A FROM T1 order by l2_distance(c3, [1,1,-1]) approximate limit 1;
sum(c2+c3)	A
[-4,7,17]	4.123105625617661
SELECT sum(c2+c3), CASE WHEN (SELECT sum(c2+c3) FROM t1 order by l2_distance(c3, [1,1,-1])  limit 1) is  null THEN (select l2_distance(c3, [1,1,-1]) from t1 order by l2_distance(c3, [1,1,-1])  limit 1) ELSE (select l2_distance(c2, [1,1,-1]) from t1 order by l2_distance(c3, [1,1,-1])  limit 1) END AS A FROM T1 order by l2_distance(c3, [1,1,-1])  limit 1;
sum(c2+c3)	A
