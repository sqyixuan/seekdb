2	[1,0,3]	[1,0,3]	[2,3,2]
select * from t1 order by l2_distance(c3, [1,2,3]) approximate limit 1,1;
c1	c2	c3	c4
2	[1,0,3]	[1,0,3]	[2,3,2]
drop table if exists t1;
