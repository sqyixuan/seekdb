1	[1,1,2]	[2,1,3]	{"page": "null"}
select * from t1 where c4->'$.page' >= '3' order by l2_distance(c3, [1,2,3]) approximate limit 10;
c1	c2	c3	c4
1	[1,1,2]	[2,1,3]	{"page": "null"}
select * from t1 where c4->'$.page' <= '3' order by l2_distance(c3, [1,2,3]) approximate limit 10;
c1	c2	c3	c4
2	[1,2,2]	[2,2,3]	{"page": "1"}
select * from t1 where c4->'$.page' between '1' and '2' order by l2_distance(c3, [1,2,3]) approximate limit 10;
c1	c2	c3	c4
2	[1,2,2]	[2,2,3]	{"page": "1"}
select * from t1 where c4->'$.page' <> '3' order by l2_distance(c3, [1,2,3]) approximate limit 10;
c1	c2	c3	c4
1	[1,1,2]	[2,1,3]	{"page": "null"}
2	[1,2,2]	[2,2,3]	{"page": "1"}
select * from t1 where c4->'$.page' <=> '3' order by l2_distance(c3, [1,2,3]) approximate limit 10;
c1	c2	c3	c4
