##where子句
drop table if exists t1;
CREATE TABLE t1 (c1 int primary key, c2 vector(3),c3 vector(3) ,c4 vector(3),
VECTOR INDEX vector_idx(c2) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
insert into t1 values(1,'[1,1,2]','[2,2,3]','[1,3,2]');
insert into t1 values(2,'[1,0,3]','[1,0,3]','[2,3,2]');
insert into t1 values(3,'[-1,2,2]','[-3,2,3]','[4,3,3]');
insert into t1 values(4,'[-1,-2,-2]','[-4,2,3]',null);
insert into t1 values(5,'[-1,-3,-2]',null,'[2,3,1]');
update t1 set c2 ='[1,2,3]' where c1 >l2_distance('[1,1,2]','[1,2,2]');
update t1 set c2 =[1,2,3] where c1 >l2_distance('[1,1,2]','[1,2,2]');
update t1 set c2 =[2,2,3] where c1 <l2_distance('[1,1,2]','[1,2,2]');
update t1 set c2 =[1,2,3] where c1 >=l2_distance('[1,1,2]','[1,2,2]');
update t1 set c2 =[2,2,3] where c1 <=l2_distance('[1,1,2]','[1,2,2]');
update t1 set c2 =[1,2,3] where c1 =l2_distance('[1,1,2]','[1,2,2]');
update t1 set c2 =[2,2,3] where c1 <>l2_distance('[1,1,2]','[1,2,2]');
select * from t1 order by c1;
c1	c2	c3	c4
1	[1,2,3]	[2,2,3]	[1,3,2]
2	[2,2,3]	[1,0,3]	[2,3,2]
3	[2,2,3]	[-3,2,3]	[4,3,3]
4	[2,2,3]	[-4,2,3]	NULL
5	[2,2,3]	NULL	[2,3,1]
update t1 set c2 =[1,2,3] where c1 > l2_distance('[1,3,2]','[1,2,2]') and c1 > l2_distance('[1,3,2]','[1,2,2]');
update t1 set c2 =[2,2,3] where c1 < l2_distance('[1,1,2]','[1,2,2]') or c1 > l2_distance('[1,3,2]','[1,2,2]') ;
update t1 set c2 =[1,2,3] where c1 BETWEEN l2_distance(c3,c4)  and l2_distance(c3,'[1,2,3]') >1;
update t1 set c2 =[2,2,3] where c3 like '%-4%' ;
ERROR 22000: Invalid data type for the operation
update t1 set c2 =[l2_distance('[1,3,2]','[1,1,2]'),l2_distance('[1,2,2]','[1,1,11]'),l2_distance('[1,1,2]','[1,1,2]')] where c1 like '%5%' ;
update t1 set c2 =[l2_distance('[1,3,2]','[1,1,2]'),l2_distance('[1,2,2]','[1,1,11]'),l2_distance('[1,1,2]','[1,1,2]')] where c1 not like '%5%' ;
update t1 set c2 =[2,2,3] where l2_distance(c3,c3) = any (SELECT l2_distance(c3,c4) FROM t1) order by c1;
update t1 set c2 =[2,2,3] where l2_distance(c3,c3) = all (SELECT l2_distance(c3,c4) FROM t1) order by c1;
update t1 set c2 =[2,2,3] where  exists (SELECT l2_distance(c3,c4) FROM t1) order by c1;
update t1 set c2 =[2,2,3] where l2_distance(c3,c3) in  (SELECT l2_distance(c3,c4) FROM t1) order by c1;
update t1 set c2 =[2,2,3] where l2_distance(c3,c3) not in  (SELECT l2_distance(c3,c4) FROM t1) order by c1;
select * from t1 order by c1;
c1	c2	c3	c4
1	[2,2,3]	[2,2,3]	[1,3,2]
2	[2,2,3]	[1,0,3]	[2,3,2]
3	[2,2,3]	[-3,2,3]	[4,3,3]
4	[2,2,3]	[-4,2,3]	NULL
5	[2,2,3]	NULL	[2,3,1]
call dbms_vector.refresh_index('vector_idx','t1','c2',1,'FAST');
call dbms_vector.rebuild_index('vector_idx','t1');
## update join(子查询/多表更新)
drop table if exists t1;
CREATE TABLE t1 (c1 int primary key, c2 vector(3),c3 vector(3) ,c4 vector(3));
insert into t1 values(1,'[1,1,2]','[2,2,3]','[1,3,2]');
insert into t1 values(2,'[1,0,3]','[1,0,3]','[2,3,2]');
insert into t1 values(3,'[-1,2,2]','[-3,2,3]','[4,3,3]');
insert into t1 values(4,'[-1,-2,-2]','[-4,2,3]',null);
insert into t1 values(5,'[-1,-3,-2]',null,'[2,3,1]');
drop table if exists t2;
CREATE TABLE t2 (a1 int , a2 vector(3),a3 vector(3) ,a4 vector(3));
insert into t2 select c1,c2,c3,c4 from t1;
select * from t1 union  select * from t2;
c1	c2	c3	c4
1	[1,1,2]	[2,2,3]	[1,3,2]
2	[1,0,3]	[1,0,3]	[2,3,2]
3	[-1,2,2]	[-3,2,3]	[4,3,3]
4	[-1,-2,-2]	[-4,2,3]	NULL
5	[-1,-3,-2]	NULL	[2,3,1]
update t1 set c2 =[1,2,4] where c1 in (select l2_distance(c3,c3) from t1 inner join t2 on c2=a2);
update t1 join t2 on c2 =a2 set c2 =[1,2,4] where a3 is null;
update t1 set c1 = l2_distance([1,2,4],[1,3,5]) where c1 in (select l2_distance(c3,c3) from t1 inner join t2 on c2=a2);
update t1 join t2 on c2 =a2 set c1 = l2_distance([1,2,4],[1,3,5]) where a3 is null;
