SELECT t1.C1, 
CASE 
WHEN l2_distance(t1.C2, t2.A2) > 10 THEN 'Far'
           WHEN l2_distance(t1.C3, t2.A3) BETWEEN 5 AND 10 THEN 'Medium'
           WHEN avg(t1.C3+t2.A3) <> [1,2,3] THEN 'true'
           ELSE 'Close'
       END AS distance_category,
avg(t1.C2) OVER (PARTITION BY t1.C1) AS avg_vector
FROM T1 t1
JOIN T2 t2 ON t1.C1 = t2.A1
WHERE l2_distance(t1.C2, t2.A2) < 0.5;
C1	distance_category	avg_vector
1	true	[1,1,2]
