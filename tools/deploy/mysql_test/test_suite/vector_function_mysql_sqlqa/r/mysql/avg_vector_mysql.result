explain select avg(c3),avg(c4) from t1 a join t2 b on c2=a2 order by l2_distance(c3, [1,2,3]) approximate limit 10;
Query Plan
=====================================================
|ID|OPERATOR             |NAME|EST.ROWS|EST.TIME(us)|
-----------------------------------------------------
|0 |LIMIT                |    |1       |57          |
|1 |└─SCALAR GROUP BY    |    |1       |57          |
|2 |  └─HASH JOIN        |    |5       |57          |
|3 |    ├─TABLE FULL SCAN|b   |5       |3           |
|4 |    └─TABLE FULL SCAN|a   |5       |3           |
=====================================================
Outputs & filters:
-------------------------------------
  0 - output([cast(T_FUN_SUM(a.c3) / cast(T_FUN_COUNT(a.c3), FLOAT(-1, -1)), ARRAY(18, 0))], [cast(T_FUN_SUM(a.c4) / cast(T_FUN_COUNT(a.c4), FLOAT(-1, -1)),
       ARRAY(18, 0))]), filter(nil), rowset=16
      limit(10), offset(nil)
  1 - output([T_FUN_SUM(a.c3)], [T_FUN_COUNT(a.c3)], [T_FUN_SUM(a.c4)], [T_FUN_COUNT(a.c4)]), filter(nil), rowset=16
      group(nil), agg_func([T_FUN_SUM(a.c3)], [T_FUN_COUNT(a.c3)], [T_FUN_SUM(a.c4)], [T_FUN_COUNT(a.c4)])
  2 - output([a.c3], [a.c4]), filter(nil), rowset=16
      equal_conds([a.c2 = b.a2]), other_conds(nil)
  3 - output([b.a2]), filter(nil), rowset=16
      access([b.a2]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([b.__pk_increment]), range(MIN ; MAX)always true
  4 - output([a.c3], [a.c2], [a.c4]), filter(nil), rowset=16
      access([a.c3], [a.c2], [a.c4]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([a.c1]), range(MIN ; MAX)always true
