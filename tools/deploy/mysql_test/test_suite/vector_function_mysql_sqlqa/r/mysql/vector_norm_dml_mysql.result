##and/or
drop table if exists t1;
CREATE TABLE t1 (c1 int primary key, c2 VARCHAR(30),c3 vector(3) ,c4 vector(3),
VECTOR INDEX vector_idx(c3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
insert into t1 values(1,'[1,1,2]','[2,2,3]','[1,-1.5,3]');
insert into t1 values(2,'[1,2,3]','[1,2,3]','[2,1.5,3]');
insert into t1 values(3,'[-1,2,2]','[-3,2,3]','[4,-1,3]');
insert into t1 values(4,'[-1,-2,-2]','[-4,2,3]',null);
insert into t1 values(5,'[-1,-2,-2]',null,'[2,-2,3]');
select vector_norm(c3) ld_c3,vector_norm(c4) ld_c4 from t1 where vector_norm(c3) =0 and vector_norm(c4) is null order by c1;
ld_c3	ld_c4
select vector_norm(c3) ld_c3,vector_norm(c4) ld_c4 from t1 where vector_norm(c3) <=2 and vector_norm(c2) >1 ;
ld_c3	ld_c4
select vector_norm(c3) ld_c3,vector_norm(c4) ld_c4 from t1 where vector_norm('[1,2,3]') > 0 or vector_norm(c3) is null order by c1;
ld_c3	ld_c4
4.123105625617661	3.5
3.7416573867739413	3.905124837953327
4.69041575982343	5.0990195135927845
5.385164807134504	NULL
NULL	4.123105625617661
select vector_norm(c3) ld_c3,vector_norm(c4) ld_c4 from t1 where vector_norm('[1,2,3]') > 0 or vector_norm(c3) is null  and c1 >3 order by c1;
ld_c3	ld_c4
4.123105625617661	3.5
3.7416573867739413	3.905124837953327
4.69041575982343	5.0990195135927845
5.385164807134504	NULL
NULL	4.123105625617661
##between and
select  * from t1 where 1 BETWEEN vector_norm(c3)  and vector_norm('[1,2,3]') order by vector_norm(c3)  limit 10;
c1	c2	c3	c4
select  * from t1 where 1 BETWEEN vector_norm(c3)  and vector_norm('[1,2,3]') order by l2_distance(c3, [1,2,3]) approximate limit 10;
c1	c2	c3	c4
select  vector_norm(c3) BETWEEN vector_norm(c3)  and vector_norm(c3) from t1 order by vector_norm(c3)  limit 10;
vector_norm(c3) BETWEEN vector_norm(c3)  and vector_norm(c3)
NULL
1
1
1
1
select  vector_norm(c3) BETWEEN vector_norm(c3)  and vector_norm(c3) from t1 order by l2_distance(c3, [1,2,3]) approximate limit 10;
vector_norm(c3) BETWEEN vector_norm(c3)  and vector_norm(c3)
1
1
1
1
select  vector_norm(c3) BETWEEN vector_norm(c3)  and vector_norm(c3) from t1 where vector_norm(c3) BETWEEN vector_norm(c3)  and vector_norm(c3) >1;
vector_norm(c3) BETWEEN vector_norm(c3)  and vector_norm(c3)
##like/not like
drop table if exists t1;
CREATE TABLE t1 (c1 int primary key, c2 VARCHAR(30),c3 vector(3) ,c4 vector(2),
VECTOR INDEX vector_idx(c3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
insert into t1 values(1,'[1,1,2]','[2,2,3]','[1,3]');
insert into t1 values(2,'[1,0,3]','[1,0,3]','[2,3]');
insert into t1 values(3,'[-1,2,2]','[-3,2,3]','[4,3]');
insert into t1 values(4,'[-1,-2,-2]','[-4,2,3]',null);
insert into t1 values(5,'[-1,-3,-2]',null,'[2,3]');
select  * from t1 where vector_norm(c3) like '%0%' order by vector_norm( [1,2,3])  limit 10;
c1	c2	c3	c4
1	[1,1,2]	[2,2,3]	[1,3]
2	[1,0,3]	[1,0,3]	[2,3]
3	[-1,2,2]	[-3,2,3]	[4,3]
4	[-1,-2,-2]	[-4,2,3]	NULL
select  * from t1 where vector_norm(c3) like vector_norm(c3) order by l2_distance(c3, [1,2,3]) approximate limit 10;
c1	c2	c3	c4
1	[1,1,2]	[2,2,3]	[1,3]
2	[1,0,3]	[1,0,3]	[2,3]
3	[-1,2,2]	[-3,2,3]	[4,3]
4	[-1,-2,-2]	[-4,2,3]	NULL
select  * from t1 where vector_norm(c3) not like '%1%' order by c1;
c1	c2	c3	c4
select  * from t1 where vector_norm(c3) not like vector_norm(c2) order by c1;
c1	c2	c3	c4
1	[1,1,2]	[2,2,3]	[1,3]
3	[-1,2,2]	[-3,2,3]	[4,3]
4	[-1,-2,-2]	[-4,2,3]	NULL
##exists,any,all,in(无关键字)
