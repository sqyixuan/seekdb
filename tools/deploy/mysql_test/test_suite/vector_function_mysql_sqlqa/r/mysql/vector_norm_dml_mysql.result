insert into t1(c1) values(vector_norm([1,2,5]));
insert into t1(c1) values(vector_norm([1,2,6]));
insert into t1(c1) values(vector_norm([1,2,7]));
insert into t1(c1) values(vector_norm([1,2,10]));
insert into t1(c1,c2,c3) values(vector_norm([1,2,8]),[1,1,2],[2,3,4]);
insert into t1(c1,c2,c3) values(vector_norm([1,2,9]),[2,3,4],null);
replace into t1(c1,c2,c3) values(vector_norm([1,2,100]),[2,3,1],[2,3,1]);
replace into t1(c1,c2,c3) values(vector_norm([1,2,100]),null,[2,3,1]);
replace into t1(c1,c2,c3) values(-1,[-1,-3,-2],[2,3,1]);
