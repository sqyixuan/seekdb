## update
drop table if exists t1;
CREATE TABLE t1 (c1 int primary key, c2 vector(3),c3 vector(3) ,c4 vector(3),
VECTOR INDEX vector_idx(c2) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
insert into t1 values(1,'[1,1,2]','[2,2,3]','[1,3,2]');
insert into t1 values(2,'[1,0,3]','[1,0,3]','[2,3,2]');
insert into t1 values(3,'[-1,2,2]','[-3,2,3]','[4,3,3]');
insert into t1 values(4,'[-1,-2,-2]','[-4,2,3]',null);
insert into t1 values(5,'[-1,-3,-2]',null,'[2,3,1]');
update t1 set c1 = 10 where c1 =5;
update t1 set c2 = '[1,23,null]' where c1 =5;
update t1 set c2 = '[1,23,abs(null)]' where c1 =5;
update t1 set c2 =[vector_norm('[1,3,2]'),vector_norm('[1,2,2]'),vector_norm('[1,1,2]')] where c3 is null;
update t1 set c1 = vector_norm('[1,8,2]') where c3 = '[2,2,3]';
select * from t1 order by c1;
c1	c2	c3	c4
2	[1,0,3]	[1,0,3]	[2,3,2]
3	[-1,2,2]	[-3,2,3]	[4,3,3]
4	[-1,-2,-2]	[-4,2,3]	NULL
8	[1,1,2]	[2,2,3]	[1,3,2]
10	[3.74166,3,2.44949]	NULL	[2,3,1]
show create table t1;
Table	Create Table
t1	CREATE TABLE `t1` (
  `c1` int(11) NOT NULL,
  `c2` VECTOR(3) DEFAULT NULL,
  `c3` VECTOR(3) DEFAULT NULL,
  `c4` VECTOR(3) DEFAULT NULL,
  PRIMARY KEY (`c1`),
  VECTOR KEY `vector_idx` (`c2`) WITH (DISTANCE=L2, LIB=VSAG, TYPE=HNSW, M=10, EF_CONSTRUCTION=100, EF_SEARCH=40) BLOCK_SIZE 16384
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0 LOB_INROW_THRESHOLD=0
truncate table t1;
CREATE VECTOR INDEX vector_idx_c4  ON t1 (c4)  WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40);
insert into t1 values(1,'[1,1,2]','[2,2,3]','[1,3,2]');
insert into t1 values(2,'[1,0,3]','[1,0,3]','[2,3,2]');
insert into t1 values(3,'[-1,2,2]','[-3,2,3]','[4,3,3]');
insert into t1 values(4,'[-1,-2,-2]','[-4,2,3]',null);
insert into t1 values(5,'[-1,-3,-2]',null,'[2,3,1]');
call dbms_vector.rebuild_index('vector_idx','t1');
call dbms_vector.rebuild_index('vector_idx_c4','t1');
##where子句
drop table if exists t1;
CREATE TABLE t1 (c1 int primary key, c2 vector(3),c3 vector(3) ,c4 vector(3),
VECTOR INDEX vector_idx(c2) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
insert into t1 values(1,'[1,1,2]','[2,2,3]','[1,3,2]');
insert into t1 values(2,'[1,0,3]','[1,0,3]','[2,3,2]');
insert into t1 values(3,'[-1,2,2]','[-3,2,3]','[4,3,3]');
insert into t1 values(4,'[-1,-2,-2]','[-4,2,3]',null);
insert into t1 values(5,'[-1,-3,-2]',null,'[2,3,1]');
update t1 set c2 ='[1,2,3]' where c1 >vector_norm('[1,1,2]');
update t1 set c2 =[1,2,3] where c1 >vector_norm('[1,1,2]');
update t1 set c2 =[2,2,3] where c1 <vector_norm('[1,1,2]');
update t1 set c2 =[1,2,3] where c1 >=vector_norm('[1,1,2]');
update t1 set c2 =[2,2,3] where c1 <=vector_norm('[1,1,2]');
update t1 set c2 =[1,2,3] where c1 =vector_norm('[1,1,2]');
update t1 set c2 =[2,2,3] where c1 <>vector_norm('[1,1,2]');
select * from t1 order by c1;
c1	c2	c3	c4
1	[2,2,3]	[2,2,3]	[1,3,2]
2	[2,2,3]	[1,0,3]	[2,3,2]
3	[2,2,3]	[-3,2,3]	[4,3,3]
4	[2,2,3]	[-4,2,3]	NULL
5	[2,2,3]	NULL	[2,3,1]
update t1 set c2 =[1,2,3] where c1 > vector_norm('[1,3,2]') and c1 > vector_norm('[1,2,2]');
update t1 set c2 =[2,2,3] where c1 < vector_norm('[1,1,2]') or c1 > vector_norm('[1,2,2]') ;
update t1 set c2 =[1,2,3] where c1 BETWEEN vector_norm(c3)  and vector_norm(c3) >1;
update t1 set c2 =[vector_norm('[1,1,2]'),vector_norm('[1,1,11]'),vector_norm('[1,1,2]')] where c1 like '%5%' ;
update t1 set c2 =[vector_norm('[1,1,2]'),vector_norm('[1,2,2]'),vector_norm('[1,1,2]')] where c1 not like '%5%' ;
update t1 set c2 =[2,2,3] where vector_norm(c3) = any (SELECT vector_norm(c3) FROM t1) order by c1;
update t1 set c2 =[2,2,3] where vector_norm(c3) = all (SELECT vector_norm(c3) FROM t1) order by c1;
update t1 set c2 =[2,2,3] where  exists (SELECT vector_norm(c3) FROM t1) order by c1;
update t1 set c2 =[2,2,3] where vector_norm(c3) in  (SELECT vector_norm(c3) FROM t1) order by c1;
update t1 set c2 =[2,2,3] where vector_norm(c3) not in  (SELECT vector_norm(c3) FROM t1) order by c1;
select * from t1 order by c1;
c1	c2	c3	c4
1	[2,2,3]	[2,2,3]	[1,3,2]
2	[2,2,3]	[1,0,3]	[2,3,2]
3	[2,2,3]	[-3,2,3]	[4,3,3]
4	[2,2,3]	[-4,2,3]	NULL
5	[2,2,3]	NULL	[2,3,1]
call dbms_vector.refresh_index('vector_idx','t1','c2',1,'FAST');
call dbms_vector.rebuild_index('vector_idx','t1');
## update join(子查询/多表更新)
drop table if exists t1;
CREATE TABLE t1 (c1 int primary key, c2 vector(3),c3 vector(3) ,c4 vector(3));
insert into t1 values(1,'[1,1,2]','[2,2,3]','[1,3,2]');
insert into t1 values(2,'[1,0,3]','[1,0,3]','[2,3,2]');
insert into t1 values(3,'[-1,2,2]','[-3,2,3]','[4,3,3]');
insert into t1 values(4,'[-1,-2,-2]','[-4,2,3]',null);
insert into t1 values(5,'[-1,-3,-2]',null,'[2,3,1]');
drop table if exists t2;
CREATE TABLE t2 (a1 int , a2 vector(3),a3 vector(3) ,a4 vector(3));
insert into t2 select c1,c2,c3,c4 from t1;
select vector_norm(c2) from t1 union  select vector_norm(a3) from t2;
vector_norm(c2)
2.449489742783178
3.1622776601683795
3
3.7416573867739413
4.123105625617661
4.69041575982343
5.385164807134504
NULL
update t1 set c2 =[1,2,4] where c1 not  in (select vector_norm(c3) from t1 inner join t2 on c2=a2);
update t1 join t2 on c2 =a2 set c2 =[1,2,4] where a3 is null;
update t1 set c1 = vector_norm([1,2,4]) where c1 in (select vector_norm(c3) from t1 inner join t2 on c2=a2);
update t1 join t2 on c2 =a2 set c1 = vector_norm([1,3,5]) where a3 is null;
