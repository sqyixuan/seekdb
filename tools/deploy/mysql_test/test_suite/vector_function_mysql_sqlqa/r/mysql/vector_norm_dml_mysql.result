insert into t2 select c1,c2,c3,c4 from t1;
SELECT count(c1), CASE WHEN vector_norm(C2) > vector_norm([1,1,1]) THEN 'High' ELSE 'Low' END AS A FROM T1,t2 ;
count(c1)	A
25	High
SELECT count(*) FROM t1,t2 where vector_norm(t1.C2+t2.A2) > 0.5;
count(*)
25
SELECT t1.C1, 
CASE 
WHEN vector_norm(t1.C2+t2.A2) > 10 THEN 'Far'
           WHEN vector_norm(t1.C3+t2.A3) BETWEEN 5 AND 10 THEN 'Medium'
           ELSE 'Close'
       END AS distance_category,
avg(t1.C2) OVER (PARTITION BY t1.C1) AS avg_vector
FROM T1 t1
JOIN T2 t2 ON t1.C1 = t2.A1
WHERE vector_norm(t1.C2+t2.A2) <> 0.5;
C1	distance_category	avg_vector
1	Medium	[1,1,2]
2	Medium	[1,0,3]
3	Medium	[-1,2,2]
4	Close	[-1,-2,-2]
5	Close	[-1,-3,-2]
