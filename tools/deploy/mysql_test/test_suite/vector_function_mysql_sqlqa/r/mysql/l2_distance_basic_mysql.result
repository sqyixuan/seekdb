##流程控制函数
SELECT CASE l2_distance([1,1],[1,1.1])>1  WHEN l2_distance([1,1],[1,1.1]) THEN 'TRUE' ELSE 'FALSE' END;
CASE l2_distance([1,1],[1,1.1])>1  WHEN l2_distance([1,1],[1,1.1]) THEN 'TRUE' ELSE 'FALSE' END
FALSE
SELECT l2_distance( [CASE 'B' WHEN 'A' THEN 2 WHEN 'B' THEN 3 END,CASE 'B' WHEN 'A' THEN 1 WHEN 'B' THEN 2 END],[CASE 'B' WHEN 'A' THEN 1 WHEN 'B' THEN 2 END,CASE 'B' WHEN 'A' THEN 1 WHEN 'B' THEN 2 END]) from dual;
l2_distance( [CASE 'B' WHEN 'A' THEN 2 WHEN 'B' THEN 3 END,CASE 'B' WHEN 'A' THEN 1 WHEN 'B' THEN 2 END],[CASE 'B' WHEN 'A' THEN 1 WHEN 'B' THEN 2 END,CASE 'B' WHEN 'A' THEN 1 WHEN 'B' THEN 2 END])
1
##比较函数
SELECT ISNULL(l2_distance([1,1],null)) from dual;
ISNULL(l2_distance([1,1],null))
1
##json函数
SELECT l2_distance(JSON_ARRAY(1,23,4),JSON_ARRAY(1,23,3));
ERROR HY000: Invalid argument
##插入json数组报错4016
drop table if exists t1;
CREATE TABLE t1 (c1 int PRIMARY KEY, c2 vector(3),c3 vector(3));
insert into t1 values(1,JSON_ARRAY(1,23,4),JSON_ARRAY(1,23,3));
ERROR 0A000: type casting not supported
insert into t1 values(2,[1,23,4],[1,23,3]);
select l2_distance(c2,c3) from t1;
l2_distance(c2,c3)
1
