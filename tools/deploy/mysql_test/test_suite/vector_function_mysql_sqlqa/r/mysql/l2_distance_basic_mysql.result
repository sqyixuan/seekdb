0.11000001430511475	1	1.1	1.11
##bit类型
drop table if exists t1;
CREATE TABLE t1 (c1 int PRIMARY KEY, c2 bit(10));
INSERT INTO t1 (c1, c2) VALUES (1, b'1');
INSERT INTO t1 (c1, c2) VALUES (2, b'0');
INSERT INTO t1 (c1, c2) VALUES (3, b'10');
INSERT INTO t1 (c1, c2) VALUES (4, 1);
INSERT INTO t1 (c1, c2) VALUES (5, null);
INSERT INTO t1 (c1, c2) VALUES (6, b'0111');
select l2_distance(c2,c2),c2,* from t1 where c2 is not null order by c1;
ERROR HY000: Invalid argument
select l2_distance([c2],[c2]),* from t1 where c2 is not null  order by c1;
ERROR 0A000: array element type not supported
select l2_distance([c2],[1]),* from t1 where c2 is not null  order by c1;
ERROR 0A000: array element type not supported
##bool
drop table if exists t1;
CREATE TABLE t1 (c1 int PRIMARY KEY, c2 bool);
INSERT INTO t1 (c1, c2) VALUES (1, 1);
INSERT INTO t1 (c1, c2) VALUES (2, 0);
INSERT INTO t1 (c1, c2) VALUES (3,false);
INSERT INTO t1 (c1, c2) VALUES (4, 100);
INSERT INTO t1 (c1, c2) VALUES (5, null);
INSERT INTO t1 (c1, c2) VALUES (6, true);
select l2_distance(c2,c2),c2,* from t1 where c2 is not null order by c1;
ERROR HY000: Invalid argument
