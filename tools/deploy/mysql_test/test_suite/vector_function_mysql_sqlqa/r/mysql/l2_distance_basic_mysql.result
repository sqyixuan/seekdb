INSERT INTO t1 (c1, c2, c3) VALUES (2, 2.2, NULL);
INSERT INTO t1 (c1, c2, c3) VALUES (3, NULL, 3.33);
INSERT INTO t1 (c1, c2, c3) VALUES (4, NULL, NULL);
INSERT INTO t1 (c1, c2, c3) VALUES (5, 5.5, NULL);
select l2_distance(c2,c2),c2,* from t1 where c2 is not null order by c1;
ERROR HY000: Invalid argument
