##枚举类型
drop table if exists t1;
CREATE TABLE t1 (c1 int PRIMARY KEY, c2 ENUM('A','1','W','12','999','NULL'),c3 vector(1));
INSERT INTO t1 (c1, c2, c3) VALUES (1, '999', '[1]');
INSERT INTO t1 (c1, c2, c3) VALUES (2, '12', '[4]');
INSERT INTO t1 (c1, c2, c3) VALUES (3, 'W', NULL);
INSERT INTO t1 (c1, c2, c3) VALUES (4, NULL, NULL);
INSERT INTO t1 (c1, c2, c3) VALUES (5, '12', '[9]');
select l2_distance([c2],c3) from t1 where c1 = 1;
ERROR 0A000: array element type not supported
select l2_distance(c2,c3) from t1 where c2 is null;
ERROR HY000: Invalid argument
select l2_distance(null,null) from dual ;
l2_distance(null,null)
NULL
