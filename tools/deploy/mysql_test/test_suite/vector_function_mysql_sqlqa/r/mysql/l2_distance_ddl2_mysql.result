update v1 set c1 = 10 where c1 =5;
update v1 set c2 = '[1,23,null]' where c1 =5;
update v1 set c2 = '[1,23,abs(null)]' where c1 =5;
update v1 set c2 =[l2_distance('[1,3,2]','[1,1,2]'),l2_distance('[1,2,2]','[1,1,11]'),l2_distance('[1,1,2]','[1,1,2]')] where c3 is null;
update v1 set c1 = l2_distance('[1,8,2]','[1,1,2]') where c3 = '[2,2,3]';
update v1 set c1 = l2_distance('[1,10,2]','[1,1,2]'),c2 = '[1,1,1]',c3 = '[0,1,0]',c4 = '[0.1,1.2,100]' where c4 = '[2,3,2]';
update v1 set c2 ='[1,2,3]' where c1 >l2_distance('[1,1,2]','[1,2,2]');
update v1 set c2 =[1,2,3] where c1 >l2_distance('[1,1,2]','[1,2,2]');
update v1 set c2 =[2,2,3] where c1 <l2_distance('[1,1,2]','[1,2,2]');
update v1 set c2 =[1,2,3] where c1 >=l2_distance('[1,1,2]','[1,2,2]');
update v1 set c2 =[2,2,3] where c1 <=l2_distance('[1,1,2]','[1,2,2]');
update v1 set c2 =[1,2,3] where c1 =l2_distance('[1,1,2]','[1,2,2]');
update v1 set c2 =[2,2,3] where c1 <>l2_distance('[1,1,2]','[1,2,2]');
update v1 set c2 =[1,2,3] where c1 > l2_distance('[1,3,2]','[1,2,2]') and c1 > l2_distance('[1,3,2]','[1,2,2]');
update v1 set c2 =[2,2,3] where c1 < l2_distance('[1,1,2]','[1,2,2]') or c1 > l2_distance('[1,3,2]','[1,2,2]') ;
##分区表后创建向量索引  导致hang
drop table if exists t1;
CREATE TABLE t1 (c1 int primary key, c2 VARCHAR(30),c3 vector(3) ,c4 vector(3),
VECTOR INDEX vector_idx_c3(c3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40))
PARTITION BY RANGE(c1) (
PARTITION p0 VALUES less than(5),
PARTITION p1 VALUES less than(6),
PARTITION p2 VALUES less than(9),
PARTITION p5 VALUES less than (MAXVALUE));
insert into t1(c1,c2,c3,c4) values(1,'[1,1,2]','[2,2,3]','[1,3,2]');
