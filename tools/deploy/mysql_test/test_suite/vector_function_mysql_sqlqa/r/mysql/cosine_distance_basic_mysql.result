##浮点类型(float,double)
drop table if exists t1;
CREATE TABLE t1 (c1 int PRIMARY KEY, c2 float,c3 double);
INSERT INTO t1 (c1, c2, c3) VALUES (1, 1.1, 1.11);
INSERT INTO t1 (c1, c2, c3) VALUES (2, 2.2, NULL);
INSERT INTO t1 (c1, c2, c3) VALUES (3, NULL, 3.33);
INSERT INTO t1 (c1, c2, c3) VALUES (4, NULL, NULL);
INSERT INTO t1 (c1, c2, c3) VALUES (5, 5.5, NULL);
select cosine_distance(c2,c2),c2,* from t1 where c2 is not null order by c1;
ERROR HY000: Invalid argument
select cosine_distance(c3,c3),c3,* from t1 where c3 is not null order by c1;
ERROR HY000: Invalid argument
select cosine_distance([c2],[c3]),* from t1 where c2 is not null and c3 is not null order by c1;
cosine_distance([c2],[c3])	c1	c2	c3
0	1	1.1	1.11
select cosine_distance([c2],[1]),* from t1 where c2 is not null and c3 is not null order by c1;
cosine_distance([c2],[1])	c1	c2	c3
0	1	1.1	1.11
select cosine_distance([c3],[1]),* from t1 where c2 is not null and c3 is not null order by c1;
cosine_distance([c3],[1])	c1	c2	c3
0	1	1.1	1.11
##bit类型
drop table if exists t1;
CREATE TABLE t1 (c1 int PRIMARY KEY, c2 bit(10));
INSERT INTO t1 (c1, c2) VALUES (1, b'1');
INSERT INTO t1 (c1, c2) VALUES (2, b'0');
INSERT INTO t1 (c1, c2) VALUES (3, b'10');
INSERT INTO t1 (c1, c2) VALUES (4, 1);
INSERT INTO t1 (c1, c2) VALUES (5, null);
INSERT INTO t1 (c1, c2) VALUES (6, b'0111');
select cosine_distance(c2,c2),c2,* from t1 where c2 is not null order by c1;
ERROR HY000: Invalid argument
select cosine_distance([c2],[c2]),* from t1 where c2 is not null  order by c1;
ERROR 0A000: array element type not supported
select cosine_distance([c2],[1]),* from t1 where c2 is not null  order by c1;
ERROR 0A000: array element type not supported
##bool
drop table if exists t1;
CREATE TABLE t1 (c1 int PRIMARY KEY, c2 bool);
INSERT INTO t1 (c1, c2) VALUES (1, 1);
INSERT INTO t1 (c1, c2) VALUES (2, 0);
INSERT INTO t1 (c1, c2) VALUES (3,false);
INSERT INTO t1 (c1, c2) VALUES (4, 100);
INSERT INTO t1 (c1, c2) VALUES (5, null);
INSERT INTO t1 (c1, c2) VALUES (6, true);
select cosine_distance(c2,c2),c2,* from t1 where c2 is not null order by c1;
ERROR HY000: Invalid argument
select cosine_distance([c2],[c2]),* from t1 where c2 is not null  order by c1;
