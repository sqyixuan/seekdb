##流程控制函数
SELECT CASE cosine_distance([1,1],[1,1.1])>1  WHEN cosine_distance([1,1],[1,1.1]) THEN 'TRUE' ELSE 'FALSE' END;
CASE cosine_distance([1,1],[1,1.1])>1  WHEN cosine_distance([1,1],[1,1.1]) THEN 'TRUE' ELSE 'FALSE' END
FALSE
SELECT cosine_distance( [CASE 'B' WHEN 'A' THEN 2 WHEN 'B' THEN 3 END,CASE 'B' WHEN 'A' THEN 1 WHEN 'B' THEN 2 END],[CASE 'B' WHEN 'A' THEN 1 WHEN 'B' THEN 2 END,CASE 'B' WHEN 'A' THEN 1 WHEN 'B' THEN 2 END]) from dual;
cosine_distance( [CASE 'B' WHEN 'A' THEN 2 WHEN 'B' THEN 3 END,CASE 'B' WHEN 'A' THEN 1 WHEN 'B' THEN 2 END],[CASE 'B' WHEN 'A' THEN 1 WHEN 'B' THEN 2 END,CASE 'B' WHEN 'A' THEN 1 WHEN 'B' THEN 2 END])
0.019419324309079777
##比较函数
SELECT ISNULL(cosine_distance([1,1],null)) from dual;
ISNULL(cosine_distance([1,1],null))
1
##json函数
SELECT JSON_ARRAY(1, cosine_distance([1,2],[1,1]), NULL, TRUE, CURTIME(),'[a,b,c]','{"d":100}');
JSON_ARRAY(1, cosine_distance([1,2],[1,1]), NULL, TRUE, CURTIME(),'[a,b,c]','{"d":100}')
[1, 0.05131670194948623, null, true, "20:26:40.000000", "[a,b,c]", "{\"d\":100}"]
SELECT cosine_distance(JSON_ARRAY(1,23,4),JSON_ARRAY(1,23,3));
ERROR HY000: Invalid argument
##插入json数组报错4016
drop table if exists t1;
CREATE TABLE t1 (c1 int PRIMARY KEY, c2 vector(3),c3 vector(3));
insert into t1 values(1,JSON_ARRAY(1,23,4),JSON_ARRAY(1,23,3));
ERROR 0A000: type casting not supported
insert into t1 values(2,[1,23,4],[1,23,3]);
select cosine_distance(c2,c3) from t1;
cosine_distance(c2,c3)
0.0009008658637857936
