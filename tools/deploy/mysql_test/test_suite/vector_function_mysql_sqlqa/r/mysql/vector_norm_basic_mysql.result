##流程控制函数
SELECT CASE vector_norm([1,1])>1  WHEN vector_norm([1,1]) THEN 'TRUE' ELSE 'FALSE' END;
CASE vector_norm([1,1])>1  WHEN vector_norm([1,1]) THEN 'TRUE' ELSE 'FALSE' END
FALSE
