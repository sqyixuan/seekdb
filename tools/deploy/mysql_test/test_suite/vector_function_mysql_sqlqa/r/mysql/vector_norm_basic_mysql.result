purge recyclebin;
drop database IF EXISTS obljh;
create database obljh ;
use obljh;
set timestamp = 1600000000;
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;
set ob_default_lob_inrow_threshold = 0;
alter system set ob_vector_memory_limit_percentage =44;
##参数个数验证
##单个参数
select vector_norm(null) from dual;
vector_norm(null)
NULL
select vector_norm() from dual;
ERROR 42000: Incorrect parameter count in the call to native function 'vector_norm'
select vector_norm('') from dual;
ERROR 42000: Null value
select vector_norm("_") from dual;
ERROR 22032: Invalid JSON text.
select vector_norm(               ) from dual;
ERROR 42000: Incorrect parameter count in the call to native function 'vector_norm'
select vector_norm(999999999999999999999999999) from dual;
ERROR HY000: Invalid argument
select vector_norm(中文) from dual;
ERROR 42S22: Unknown column '中文' in 'field list'
select vector_norm(true) from dual;
ERROR HY000: Invalid argument
select vector_norm(false) from dual;
ERROR HY000: Invalid argument
select vector_norm('1111') from dual;
ERROR HY000: Invalid argument
select vector_norm(+10) from dual;
ERROR HY000: Invalid argument
select vector_norm(-10) from dual;
ERROR HY000: Invalid argument
select vector_norm(1.111) from dual;
ERROR HY000: Invalid argument
select vector_norm([1]) from dual;
vector_norm([1])
1
select vector_norm([null]) from dual;
ERROR 42000: Null value
