CREATE TABLE t1 (c1 int primary key, c2 varchar(30),c3 vector(3) ,c4 vector(3),c5 vector(3) AS ((c3*c2)) ,c6 vector(3) AS ((c3*c4)) ,c7 vector(3) AS ((c3-c4)) ,c8 vector(3) AS ((c3+c4+c2)) ,
VECTOR INDEX vector_idx(c3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40))PARTITION BY KEY(c1) PARTITIONS 4;
