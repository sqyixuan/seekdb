create table ttt1 as select a.c1 c1,b.c1 cc1,avg(a.c3) avg_c3,sum(b.c3) sum_c3,a.c5 from t1 a ,t1 b where a.c5=b.c5 order by vector_norm(b.c3)  limit 100;
