##结合聚合函数使用关键字
drop table if exists t1;
CREATE TABLE t1 (c1 int primary key, c2 vector(3),c3 vector(3) ,c4 vector(3),
VECTOR INDEX vector_idx(c3) 
WITH (distance=inner_product, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
insert into t1 values(1,'[1,1,2]','[2,2,3]','[1,3,2]');
insert into t1 values(2,'[1,0,3]','[1,0,3]','[2,3,2]');
insert into t1 values(3,'[-1,2,2]','[-3,2,3]','[4,3,3]');
insert into t1 values(4,'[-1,-2,-2]','[-4,2,3]',null);
insert into t1 values(5,'[-1,-3,-2]',null,'[2,3,1]');
select c1,c2,inner_product(c3,c2),count(c2) from t1 order by inner_product(c3, [1,2,3]) APPROX limit 10;
c1	c2	inner_product(c3,c2)	count(c2)
1	[1,1,2]	10	5
select c1,c2,inner_product(c3,c2),avg(c2) from t1 order by inner_product(c3, [1,2,3]) APPROX limit 10;
c1	c2	inner_product(c3,c2)	avg(c2)
1	[1,1,2]	10	[-0.2,-0.4,0.6]
select c1,c2,inner_product(c3,c2),sum(c2) from t1 order by inner_product(c3, [1,2,3]) APPROX limit 10;
c1	c2	inner_product(c3,c2)	sum(c2)
1	[1,1,2]	10	[-1,-2,3]
select  inner_product(c2, c3) from t1 order by inner_product(c3, [1,2,3]) APPROX limit 10;
inner_product(c2, c3)
