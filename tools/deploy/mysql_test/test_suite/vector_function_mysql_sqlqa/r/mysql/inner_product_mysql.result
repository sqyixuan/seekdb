SELECT t1.C1, 
CASE 
WHEN inner_product(t1.C2, t2.A2) > 10 THEN 'Far'
           WHEN inner_product(t1.C3, t2.A3) BETWEEN 5 AND 10 THEN 'Medium'
           ELSE 'Close'
       END AS distance_category,
avg(t1.C2) OVER (PARTITION BY t1.C1) AS avg_vector
FROM T1 t1
JOIN T2 t2 ON t1.C1 = t2.A1
WHERE inner_product(t1.C2, t2.A2) > 0.5;
C1	distance_category	avg_vector
1	Close	[1,1,2]
2	Medium	[1,0,3]
3	Close	[-1,2,2]
4	Close	[-1,-2,-2]
5	Far	[-1,-3,-2]
