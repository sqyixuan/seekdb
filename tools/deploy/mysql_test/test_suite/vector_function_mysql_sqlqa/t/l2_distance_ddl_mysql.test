CREATE TABLE t1 (c1 INT PRIMARY KEY,c2 vector(3),c3 vector(3), c4 vector(3),c5 vector(2000) AS ([c3*c4]) STORED,
VECTOR INDEX vector_idx(c4) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
call dbms_vector.rebuild_index('vector_idx','t1');



