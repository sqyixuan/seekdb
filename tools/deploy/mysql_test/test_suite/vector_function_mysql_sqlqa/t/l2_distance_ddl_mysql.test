##旁路导入后建向量索引
--disable_warnings
drop table if exists t1;
drop materialized view if exists mv1;
--enable_warnings
CREATE TABLE t1 (c1 int, c2 vector(3),c3 vector(3) ,c4 vector(3));
insert into t1 values(1,'[1,1,2]','[2,2,3]',null);
create materialized view mv1  refresh complete on demand  as select c1,c2,c3,c4 from t1 ;
insert /*+ direct(true,100,full) enable_parallel_dml parallel(100) */ into t1 select * from t1;
insert /*+ direct(true,100,full) enable_parallel_dml parallel(100) */ into t1 select * from t1;
insert /*+ direct(true,100,full) enable_parallel_dml parallel(100) */ into t1 select * from t1;
insert /*+ direct(true,100,full) enable_parallel_dml parallel(100) */ into t1 select * from t1;

create VECTOR index vector_idx1 on t1(c3) with (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40);
create VECTOR index vector_idx2 on t1(c4) with (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40);
show index from t1;
select * from t1 order by l2_distance(c4, [1,2,3]) approximate limit 1,1;
truncate table t1;


###二级分区表
--disable_warnings
drop table if exists t1;
drop table if exists tt1;
drop view if exists v1;
--enable_warnings
CREATE TABLE t1 (c1 INT PRIMARY KEY ,c2 vector(3),c3 vector(3), c4 vector(3),c5 vector(3) AS (c4*c3) STORED,
VECTOR INDEX vector_idx(c3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40))PARTITION BY RANGE (c1)
SUBPARTITION BY HASH(c1)
SUBPARTITIONS 100 (
    PARTITION p1 VALUES LESS THAN (30) (
        SUBPARTITION s1,
        SUBPARTITION s2
    ),
    PARTITION p2 VALUES LESS THAN (40) (
        SUBPARTITION s3,
        SUBPARTITION s4
    ),
    PARTITION p3 VALUES LESS THAN MAXVALUE (
        SUBPARTITION s5,
        SUBPARTITION s6
    )
);
insert into t1(c1,c2,c3,c4) values(10,'[1,1,2]','[2,2,3]','[1,3,2]');
insert into t1(c1,c2,c3,c4) values(20,'[1,0,3]','[1,0,3]','[2,3,2]');
insert into t1(c1,c2,c3,c4) values(30,'[-1,2,2]','[-3,2,3]','[4,3,3]');
insert into t1(c1,c2,c3,c4) values(40,'[-1,-2,-2]','[-4,2,3]',null);
insert into t1(c1,c2,c3,c4) values(50,'[-1,-3,-2]',null,'[2,3,1]');
ALTER TABLE t1 MODIFY c1 INT AUTO_INCREMENT;
--error 1063
ALTER TABLE t1 MODIFY c3 vector(3) AUTO_INCREMENT;
insert /*+ direct(true,100,full) enable_parallel_dml parallel(100) */ into t1(c2,c3,c4) select c2,c3,c4 from t1;
insert /*+ direct(true,100,full) enable_parallel_dml parallel(100) */ into t1(c2,c3,c4) select c2,c3,c4 from t1;
insert /*+ direct(true,100,full) enable_parallel_dml parallel(100) */ into t1(c2,c3,c4) select c2,c3,c4 from t1;
insert /*+ direct(true,100,full) enable_parallel_dml parallel(100) */ into t1(c2,c3,c4) select c2,c3,c4 from t1;
insert /*+ direct(true,100,full) enable_parallel_dml parallel(100) */ into t1(c2,c3,c4) select c2,c3,c4 from t1;
##函数索引
