create index idx2 on t1 (c1);
--error 3754
create index idx3 on t1 ((l2_distance(c3, [1,c1,3])));
create index idx5 on t1 ((l2_distance(c3, [1,1,3])));
##show index from t1;

--error 1235
CREATE VECTOR INDEX vector_idx_c5  ON t1 (c5)  WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40);
CREATE VECTOR INDEX vector_idx_c4  ON t1 (c4)  WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40);

create table tt1 like t1;
replace into tt1(c1,c2,c3,c4) values(10,'[1,1,2]','[2,2,3]','[1,3,2]');
replace into tt1(c1,c2,c3,c4) values(20,'[1,0,3]','[1,0,3]','[2,3,2]');
replace into tt1(c1,c2,c3,c4) values(30,'[-1,2,2]','[-3,2,3]','[4,3,3]');
replace into tt1(c1,c2,c3,c4) values(40,'[-1,-2,-2]','[-4,2,3]',null);
replace into tt1(c1,c2,c3,c4) values(50,'[-1,-3,-2]',null,'[2,3,1]');
select count(*) from tt1,t1;
select count(*) from tt1,t1 where tt1.c5=t1.c5 order by l2_distance(t1.c5, [1,2,3]) approximate limit 10;
select count(*) from tt1,t1 where tt1.c1=t1.c1 order by l2_distance(t1.c5, [1,2,3])  limit 10;
select count(*) from t1 PARTITION(p3) order by l2_distance(c5, [1,2,3]) approximate limit 10;

