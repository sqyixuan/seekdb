purge recyclebin;

--disable_warnings
drop database IF EXISTS obljh;
--enable_warnings

create database obljh ;
use obljh;
set timestamp = 1600000000;
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;
set ob_default_lob_inrow_threshold = 0;

alter system set ob_vector_memory_limit_percentage =44;
set ob_query_timeout  = 3216672000000000;

--echo ##create table as select 
--disable_warnings
drop table if exists t1;
--enable_warnings

--error 4152
create table t1 as select l2_distance('','') from dual;
create table t1 as select l2_distance(null,null) from dual;
--error 7602
create table t1 as select l2_distance([null,[null]],[null,[null]]) from dual;

--error 1210
create table t1 as select l2_distance(1,1) from dual;

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1 as select [1,1,2] a from dual;
create table t2 as select [1,1,2] a,[1,1,2] b from dual;
create table t3 as select l2_distance([1,1,2],[1,12,2]) a,l2_distance([1,1,2],[1,11,2]) b from dual;
select * from t1;select * from t2;select * from t3;

--disable_warnings
drop table if exists t1;
drop table if exists t2;
drop table if exists t3;
--enable_warnings

create table t1 as select l2_distance([1,1,2],null) a,l2_distance([1,1,2],[1,11,2]) b,l2_distance([1,1,2],[1,1,211]) c,l2_distance([1,1,2],[1,1,211]) d,l2_distance([1,1,2],[1,1,211]) e,l2_distance([1,1,2],[1,1,211]) f from dual;
select * from t1;

--disable_warnings
drop table if exists t1;
--enable_warnings

--error 4152
create table t1 as select l2_distance([1,0.01,2],null) a,l2_distance([1,1.01,2],[1,11,2]) b,l2_distance([1,1,2],[1,1,211]) c,l2_distance([1,1,2],[1,2,1/0]) d,l2_distance([1,1,2],[1,1,211]) e,l2_distance([1,1,2],[1,1,211]) f from dual;

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1 as select l2_distance([true],[false]) a,l2_distance([true],[false]) b,l2_distance([true],[false]) c,l2_distance([true],[true+false]) d from dual;
select * from t1;

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1 as select l2_distance([9999999999],[9999999999999999]),l2_distance([-100],[+10000]) b,l2_distance(null,[false]) c,l2_distance([0.2],[8+8]) d  from dual;
select * from t1;

--disable_warnings
drop table if exists t1;
--enable_warnings

--error 3140
create table t1 as select l2_distance('[?,?,?,?,?????????????]','[?,?,?,?,?]') from dual;
--error 1210
create table t1 as select l2_distance('101','101')a,l2_distance('101','101')b,l2_distance('101','101')c from dual;
--error 1059
create table t1 as select l2_distance('-147777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777770','-147777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777770'),l2_distance('-147777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777770','-147777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777770') from dual;
--error 1210
create table t1 as select l2_distance('1','0x48656C6C6F20576F726C64')a,l2_distance('1','0x48656C6C6F20576F726C64')b,l2_distance('1','0x48656C6C6F20576F726C64')c from dual;

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1 as select l2_distance([true],[false]) a,l2_distance([true],[false]) b,l2_distance([true],[false]) c,l2_distance([true],[true+false]) d from dual union select l2_distance([true],[false]) e,l2_distance([true],[false]) f,l2_distance([true],[false]) g,l2_distance([true],[true+false]) h from dual;


--disable_warnings
drop table if exists t1;
drop table if exists tt1;
drop table if exists tt2;
--enable_warnings

CREATE TABLE t1 (c1 int primary key, c2 vector(3),c3 vector(3) ,c4 vector(3),
VECTOR INDEX vector_idx(c3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
insert into t1(c1,c2,c3,c4) values(1,'[1,1,2]','[2,2,3]','[1,3,2]');
insert into t1(c1,c2,c3,c4) values(2,'[1,0,3]','[1,0,3]','[2,3,2]');
insert into t1(c1,c2,c3,c4) values(3,'[-1,2,2]','[-3,2,3]','[4,3,3]');
insert into t1(c1,c2,c3,c4) values(4,'[-1,-2,-2]','[-4,2,3]',null);
insert into t1(c1,c2,c3,c4) values(5,'[-1,-3,-2]',null,'[2,3,1]');
create  table tt1  as select count(*) cnt, count(c3) cnt_c3, sum(c3) sum_c3 from t1 ;
create  table tt2  as select count(*) cnt, count(c3) cnt_c3, avg(c3) avg_c3 from t1 ;
select * from tt1 order by cnt;
select * from tt2 order by cnt;

##多表连接
--disable_warnings
drop table if exists t1;
--enable_warnings

CREATE TABLE t1 (c1 int primary key, c2 vector(3),c3 vector(3) ,c4 vector(3),
VECTOR INDEX vector_idx(c3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
insert into t1(c1,c2,c3,c4) values(1,'[1,1,2]','[2,2,3]','[1,3,2]');
insert into t1(c1,c2,c3,c4) values(2,'[1,0,3]','[1,0,3]','[2,3,2]');
insert into t1(c1,c2,c3,c4) values(3,'[-1,2,2]','[-3,2,3]','[4,3,3]');
insert into t1(c1,c2,c3,c4) values(4,'[-1,-2,-2]','[-4,2,3]',null);
insert into t1(c1,c2,c3,c4) values(5,'[-1,-3,-2]',null,'[2,3,1]');
--disable_warnings
drop table if exists t2;
--enable_warnings
CREATE TABLE t2 (a1 int primary key , a2 vector(3),a3 vector(3) ,a4 vector(3),
VECTOR INDEX vector_idx(a3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
show index from t2;
show index from t1;
insert into t2 select c1,c2,c3,c4 from t1 where c3 is not null and c4 is not null;

--disable_warnings
drop table if exists tt0;
drop table if exists tt1;
drop table if exists tt2;
--enable_warnings
create table tt0 as select c2+c3 from t1 ;
create table tt1 as select l2_distance(c2,a3) a,l2_distance(c4,a2) b,c1,a1,a3,c2 from t1 join t2 on c1=a1 ;
create table tt2 as select c2+c3+c4,a2+c3+c2 from t1 join t2 on c1=a1 ;
select l2_distance(c2,a3) from tt1 ;
select count(*) from t1,t2,tt1;


##物化视图结合关键字使用  --不支持创建向量索引
--disable_warnings
drop view if exists v1;
drop table if exists t1;
drop materialized view if exists mv1;
--enable_warnings

CREATE TABLE t1 (c1 int primary key, c2 vector(3),c3 vector(3) ,c4 vector(3),
VECTOR INDEX vector_idx(c3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
insert into t1(c1,c2,c3,c4) values(1,'[1,1,2]','[2,2,3]','[1,3,2]');
insert into t1(c1,c2,c3,c4) values(2,'[1,0,3]','[1,0,3]','[2,3,2]');
insert into t1(c1,c2,c3,c4) values(3,'[-1,2,2]','[-3,2,3]','[4,3,3]');
insert into t1(c1,c2,c3,c4) values(4,'[-1,-2,-2]','[-4,2,3]',null);
insert into t1(c1,c2,c3,c4) values(5,'[-1,-3,-2]',null,'[2,3,1]');
create materialized view mv1  parallel 2 refresh complete on demand  as select * from t1 ;
##导致hang住 已修复
--error 1235  
CREATE VECTOR INDEX vector_idx  ON mv1 (c2)  WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=10, ef_search=40);



##普通视图结合关键字使用
--disable_warnings
drop view if exists v1;
drop table if exists t1;
drop materialized view mv1;
--enable_warnings

CREATE TABLE t1 (c1 int primary key, c2 vector(3),c3 vector(3) ,c4 vector(3),
VECTOR INDEX vector_idx(c3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
insert into t1(c1,c2,c3,c4) values(1,'[1,1,2]','[2,2,3]','[1,3,2]');
insert into t1(c1,c2,c3,c4) values(2,'[1,0,3]','[1,0,3]','[2,3,2]');
insert into t1(c1,c2,c3,c4) values(3,'[-1,2,2]','[-3,2,3]','[4,3,3]');
insert into t1(c1,c2,c3,c4) values(4,'[-1,-2,-2]','[-4,2,3]',null);
insert into t1(c1,c2,c3,c4) values(5,'[-1,-3,-2]',null,'[2,3,1]');
create  view v1 as select * from t1 ; 
select l2_distance(c3,c2) from v1  group by l2_distance(c3,[1,2,3]) order by l2_distance(c3, [1,2,3]) APPROX limit 10;
select l2_distance(c3,c2) from v1  group by l2_distance(c3,[1,2,3]) order by l2_distance(c3, [1,2,3]) APPROX limit 100000000;

select  c4+c3+c2 from v1 order by l2_distance(c3, [1,2,3])  limit 100000000;
select  c4+c3+c2 from v1 order by l2_distance(c3, [1,2,3])  limit 10;


##创建多表join的物化视图
--disable_warnings
drop table if exists t1;
drop view if exists v1;
drop table if exists t2;
drop materialized view if exists mv1;
--enable_warnings

CREATE TABLE t1 (c1 int primary key, c2 varchar(30),c3 vector(3) ,c4 vector(3),
VECTOR INDEX vector_idx(c3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40))PARTITION BY KEY(c1) PARTITIONS 4;
insert into t1(c1,c2,c3,c4) values(1,'[1,1,2]','[2,2,3]','[1,3,2]');
insert into t1(c1,c2,c3,c4) values(2,'[1,0,3]','[1,0,3]','[2,3,2]');
insert into t1(c1,c2,c3,c4) values(3,'[-1,2,2]','[-3,2,3]','[4,3,3]');

CREATE TABLE t2 (a1 int , a2 vector(3),a3 vector(3) ,a4 vector(3),
VECTOR INDEX vector_idx(a3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
insert into t2 select c1,c2,c3,c4 from t1;

select * from t1,t2 where c3=a3 order by l2_distance(c3, [1,2,3]) APPROX limit 10;
create materialized view mv1   refresh complete on demand  as select * from t1,t2 where c2=a2 order by l2_distance(c3, [1,2,3]) APPROX limit 10;

##创建stmt相关的表不包含关键字
--disable_warnings
drop table if exists t1;
drop table if exists tt1;
drop view if exists v1;
drop materialized view if exists mv1;
--enable_warnings

CREATE TABLE t1 (c1 int primary key, c2 varchar(30),c3 vector(3) ,c4 vector(3),
VECTOR INDEX vector_idx(c3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
insert into t1(c1,c2,c3,c4) values(1,'[1,1,2]','[2,2,3]','[1,3,2]');
insert into t1(c1,c2,c3,c4) values(2,'[1,0,3]','[1,0,3]','[2,3,2]');
insert into t1(c1,c2,c3,c4) values(3,'[-1,2,2]','[-3,2,3]','[4,3,3]');
insert into t1(c1,c2,c3,c4) values(4,'[-1,-2,-2]','[-4,2,3]',null);
insert into t1(c1,c2,c3,c4) values(5,'[-1,-3,-2]',null,'[2,3,1]');
select * from t1 order by l2_distance(c3, [1,2,3]) APPROX limit 10;
create view v1 as select * from t1 order by l2_distance(c3, [1,2,3]) APPROX limit 10;
show create table v1;

create table tt1 as select * from t1 order by l2_distance(c3, [1,2,3]) APPROX limit 10;
select * from tt1 order by l2_distance(c3, [1,2,3]) APPROX limit 10;
select * from tt1 order by l2_distance(c3, [1,2,3]) APPROX limit 0;
create materialized view mv1   refresh complete on demand  as select * from t1 order by l2_distance(c3, [1,2,3]) APPROX limit 1000;
select * from mv1 order by l2_distance(c3, [1,2,3]) APPROX limit 10;
select * from mv1 order by l2_distance(c3, [1,2,3]) APPROX limit 0;

##全量物化视图和普通视图连接(物化视图作为基表创建普通视图后再连接物化视图)
--disable_warnings
drop view if exists v1;
drop table if exists t1;
drop table if exists t2;
drop materialized view if exists mv1;
--enable_warnings 

CREATE TABLE t1 (c1 int primary key, c2 vector(3),c3 vector(3) ,c4 vector(3),
VECTOR INDEX vector_idx(c3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
create materialized view mv1  parallel 2 refresh complete on demand  as select * from t1 ;
insert into t1(c1,c2,c3,c4) values(1,'[1,1,2]','[2,2,3]','[1,3,2]');
insert into t1(c1,c2,c3,c4) values(2,'[1,0,3]','[1,0,3]','[2,3,2]');
insert into t1(c1,c2,c3,c4) values(3,'[-1,2,2]','[-3,2,3]','[4,3,3]');
insert into t1(c1,c2,c3,c4) values(4,'[-1,-2,-2]','[-4,2,3]',null);
insert into t1(c1,c2,c3,c4) values(5,'[-1,-3,-2]',null,'[2,3,1]');
CALL DBMS_MVIEW.REFRESH('mv1','c');
select * from mv1 order by c1;

create  view v1 as select * from mv1 ; 
select count(*) from v1,mv1;
select count(*) from v1,t1,mv1;
select count(*) from v1,t1;
select count(*) from v1,mv1;
select count(*) from v1,mv1 where v1.c1=mv1.c1;

select c1,c2,sum(c3),avg(c4),l2_distance(c3,c2) from t1 a order by l2_distance(a.c3, [1,2,3]) APPROX limit 1;

CREATE TABLE t2 (a1 int , a2 vector(3),a3 vector(3) ,a4 vector(3),
VECTOR INDEX vector_idx(a3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
insert into t2 select c1,c2,c3,c4 from t1;

##select a.c1,b.c2,sum(a.c3),avg(b.c4),l2_distance(a.c3,b.c2) from t1 a join mv1 b on a.c2=b.c2  order by l2_distance(a.c3,b.c2);
##select a.c1,a.c2,sum(a.c3),avg(a.c4),l2_distance(a.c3,a.c2) from t1 a order by l2_distance(a.c3, [1,2,3]) APPROX limit 1000;
select c1,c2,c3,c4,l2_distance(a3,c2) from t1 a inner join t2 b on l2_distance(c2,c3)=l2_distance(a3,a4)  order by l2_distance(a3,c2);
select c1,c2,c3,c4,l2_distance(a3,c2) from t1 a right join t2 b on l2_distance(c2,c3)=l2_distance(a3,a4)  order by l2_distance(a3,c2);
select c1,c2,c3,c4,l2_distance(a3,c2) from t1 a left join t2 b on l2_distance(c2,c3)=l2_distance(a3,a4)  order by l2_distance(a3,c2);
select c1,c2,c3,c4,l2_distance(a3,c2) from t1 a cross  join t2 b on l2_distance(c2,c3)=l2_distance(a3,a4)  order by l2_distance(a3,c2);

select c1,c2,c3,c4,l2_distance(a3,c2) from t1 a join t2 b on l2_distance(a4,c3)=l2_distance(a3,c2)  order by l2_distance(a3,c2);
select c1,c2,c3,c4,l2_distance(a3,c2) from t1 a inner join t2 b on l2_distance(a4,c3)=l2_distance(a3,c2)  order by l2_distance(a3,c2);
select c1,c2,c3,c4,l2_distance(a3,c2) from t1 a right join t2 b on l2_distance(a4,c3)=l2_distance(a3,c2)  order by l2_distance(a3,c2);
select c1,c2,c3,c4,l2_distance(a3,c2) from t1 a left join t2 b on l2_distance(a4,c3)=l2_distance(a3,c2)  order by l2_distance(a3,c2);
select c1,c2,c3,c4,l2_distance(a3,c2) from t1 a cross  join t2 b on l2_distance(a4,c3)=l2_distance(a3,c2)  order by l2_distance(a3,c2);



##聚合函数作为列的物化视图
--disable_warnings
drop table if exists t1;
drop view if exists v1;
drop view if exists v1;
drop view if exists v2;
drop materialized view if exists mv1;
drop materialized view if exists mv2;
--enable_warnings 

CREATE TABLE t1 (c1 int primary key, c2 vector(3),c3 vector(3) ,c4 vector(3),
VECTOR INDEX vector_idx(c3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
insert into t1(c1,c2,c3,c4) values(1,'[1,1,2]','[2,2,3]','[1,3,2]');
insert into t1(c1,c2,c3,c4) values(2,'[1,0,3]','[1,0,3]','[2,3,2]');
insert into t1(c1,c2,c3,c4) values(3,'[-1,2,2]','[-3,2,3]','[4,3,3]');
insert into t1(c1,c2,c3,c4) values(4,'[-1,-2,-2]','[-4,2,3]',null);
insert into t1(c1,c2,c3,c4) values(5,'[-1,-3,-2]',null,'[2,3,1]');
create materialized view mv1 refresh complete on demand  as select count(*) cnt, count(c3) cnt_c3, sum(c3) sum_c3 from t1 ;
##--error 4016  已修复
create materialized view mv2 refresh complete on demand  as select * from t1 order by l2_distance(c3, [1,2,3]) APPROX limit 1000;
create  view v1  as select * from t1 ;
create  view v2  as select count(*) cnt, count(c3) cnt_c3, sum(c3) sum_c3 from t1 order by l2_distance(c3, [1,2,3]) APPROX limit 1000;
select * from mv1 order by cnt;
select * from v1  order by l2_distance(c3, [1,2,3]) APPROX limit 1000;
select * from v2 order by cnt;
drop materialized view if exists mv1;
create materialized view mv1  parallel 2 refresh complete on demand  as select * from t1 ;
select * from v1,mv1 where v1.c2=mv1.c3;


###创建物化视图
--disable_warnings
drop table if exists t1;
drop table if exists tt1;
drop materialized view if exists mv1;
drop materialized view if exists mv2;
--enable_warnings

CREATE TABLE t1 (c1 int primary key, c2 vector(3),c3 vector(3) ,c4 vector(3),
VECTOR INDEX vector_idx(c3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
insert into t1(c1,c2,c3,c4) values(1,'[1,1,2]','[2,2,3]','[1,3,2]');
insert into t1(c1,c2,c3,c4) values(2,'[1,0,3]','[1,0,3]','[2,3,2]');
insert into t1(c1,c2,c3,c4) values(3,'[-1,2,2]','[-3,2,3]','[4,3,3]');
insert into t1(c1,c2,c3,c4) values(4,'[-1,-2,-2]','[-4,2,3]',null);
insert into t1(c1,c2,c3,c4) values(5,'[-1,-3,-2]',null,'[2,3,1]');
create materialized view mv1  parallel 2 refresh complete on demand  as select c1,c2 a2 from t1 order by c1;
create materialized view mv2  parallel 2 refresh complete on demand  as select c1,c2 c2 from t1 order by c1 limit 1;
CALL DBMS_MVIEW.REFRESH('mv1','c');
CALL DBMS_MVIEW.REFRESH('mv2','c');
create table tt1 select l2_distance(c2,a2) a from mv1,mv2 order by mv2.c1;
select * from tt1 order by a;

##物化视图创建向量列为主键  --预期应报错
--disable_warnings
drop table if exists t1;
drop materialized view if exists mv1;
--enable_warnings

CREATE TABLE t1 (c1 int primary key, c2 vector(3),c3 vector(3) ,c4 vector(3),
VECTOR INDEX vector_idx(c3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
insert into t1(c1,c2,c3,c4) values(1,'[1,1,2]','[2,2,3]','[1,3,2]');
insert into t1(c1,c2,c3,c4) values(2,'[1,0,3]','[1,0,3]','[2,3,2]');
insert into t1(c1,c2,c3,c4) values(3,'[-1,2,2]','[-3,2,3]','[4,3,3]');
insert into t1(c1,c2,c3,c4) values(4,'[-1,-2,-2]','[-4,2,3]',null);
insert into t1(c1,c2,c3,c4) values(5,'[-1,-3,-2]',null,'[2,3,1]');
--error 1167
create materialized view mv1(primary key(c2))  refresh complete on demand  as select c1,c2 from t1 ;
create materialized view mv1(primary key(c1))  refresh complete on demand  as select c1,c2 from t1 ;
desc mv1;
--error 1235
alter table mv1 drop primary key;

##创建多个主键
--error 1167
create materialized view mv2(primary key(c1,c2))  refresh complete on demand  as select c1,c2,c3 from t1 ;
--error 1167
create materialized view mv2(primary key(a))  refresh complete on demand  as select c1,c2,c3,c4 a from t1 ;



##物化视图创建普通视图
--disable_warnings
drop table if exists t1;
drop view if exists v1;
drop materialized view if exists mv1;
--enable_warnings

CREATE TABLE t1 (c1 int primary key, c2 vector(3),c3 vector(3) ,c4 vector(3),
VECTOR INDEX vector_idx(c3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
create materialized view mv1  refresh complete on demand  as select c1,c2,c3,c4 from t1 ;
create  view v1 as select c1,c2,c3,c4 from mv1 order by l2_distance(c3, [1,2,3]) approximate limit 10;
insert into t1(c1,c2,c3,c4) values(1,'[1,1,2]','[2,2,3]','[1,3,2]');
insert into t1(c1,c2,c3,c4) values(2,'[1,0,3]','[1,0,3]','[2,3,2]');
insert into t1(c1,c2,c3,c4) values(3,'[-1,2,2]','[-3,2,3]','[4,3,3]');
insert into t1(c1,c2,c3,c4) values(4,'[-1,-2,-2]','[-4,2,3]',null);
insert into t1(c1,c2,c3,c4) values(5,'[-1,-3,-2]',null,'[2,3,1]');
CALL DBMS_MVIEW.REFRESH('mv1','c');
select * from mv1 order by l2_distance(c3, [1,2,3])  limit 1;
select * from mv1 order by l2_distance(c3, [1,2,3])  limit 1,1;

select * from v1 order by l2_distance(c3, [1,2,3]) approximate limit 1;
select * from v1 order by l2_distance(c3, [1,2,3]) approximate limit 1,1;
select * from v1 order by l2_distance(c3, [1,2,3])  limit 1;
select * from v1 order by l2_distance(c3, [1,2,3])  limit 1,1;


select * from t1 order by l2_distance(c3, [1,2,3]) approximate limit 1;
select * from t1 order by l2_distance(c3, [1,2,3]) approximate limit 1,1;

select * from t1 order by l2_distance(c3, [1,2,3])  limit 1;



