select count(*) from t1 a,tt2 b where l2_distance(a.c2,b.c3)=l2_distance(a.c3,b.c4) order by l2_distance(a.c3, [1,2,3]) approximate limit 10;
select count(*) from tt1 a,tt2 b where l2_distance(a.c2,b.c3)=l2_distance(a.c3,b.c4) order by l2_distance(a.c3, [1,2,3]) approximate limit 10;
