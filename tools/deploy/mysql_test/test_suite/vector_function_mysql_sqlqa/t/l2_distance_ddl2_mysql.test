##show create table t1;
TRUNCATE TABLE t1;

##--已知问题 入参都是向量列
select * from t1 PARTITION (p2) order by l2_distance(c3, [1,2,3]) approximate limit 10 ;
select * from t1 PARTITION (p5) order by l2_distance(c3, [1,2,3]) approximate limit 10 ;
select * from t1 PARTITION (p2) order by l2_distance(c3, [1,2,3]) approximate limit 10 ;
select l2_distance(c3, c2) from t1 PARTITION (p2) union all select l2_distance(c3, [1,2,3]) from t1 PARTITION (p5) ;
CREATE VECTOR INDEX vector_idx_c4  ON t1 (c4)  WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40);
drop index vector_idx_c4 on t1;


