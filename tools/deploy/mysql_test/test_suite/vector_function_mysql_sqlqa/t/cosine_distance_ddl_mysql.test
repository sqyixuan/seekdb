purge recyclebin;
--disable_warnings
drop database IF EXISTS obljh;
--enable_warnings
create database obljh ;
use obljh;
set timestamp = 1600000000;
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;
set ob_default_lob_inrow_threshold = 0;

alter system set ob_vector_memory_limit_percentage =44;

--echo ##create table as select 
--disable_warnings
drop table if exists t1;
--enable_warnings
--error 4152
create table t1 as select cosine_distance('','') from dual;
create table t1 as select cosine_distance(null,null) from dual;
--error 7602
create table t1 as select cosine_distance([null,[null]],[null,[null]]) from dual;

--error 1210
create table t1 as select cosine_distance(1,1) from dual;

--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1 as select [1,1,2] a from dual;

--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1 as select [1,1,2] a,[1,1,2] b from dual;

--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1 as select cosine_distance([1,1,2],[1,12,2]) a,cosine_distance([1,1,2],[1,11,2]) b from dual;
select * from t1;

--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1 as select cosine_distance([1,1,2],null) a,cosine_distance([1,1,2],[1,11,2]) b,cosine_distance([1,1,2],[1,1,211]) c,cosine_distance([1,1,2],[1,1,211]) d,cosine_distance([1,1,2],[1,1,211]) e,cosine_distance([1,1,2],[1,1,211]) f from dual;
select * from t1;

--disable_warnings
drop table if exists t1;
--enable_warnings
--error 4152
create table t1 as select cosine_distance([1,0.01,2],null) a,cosine_distance([1,1.01,2],[1,11,2]) b,cosine_distance([1,1,2],[1,1,211]) c,cosine_distance([1,1,2],[1,2,1/0]) d,cosine_distance([1,1,2],[1,1,211]) e,cosine_distance([1,1,2],[1,1,211]) f from dual;

--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1 as select cosine_distance([true],[false]) a,cosine_distance([true],[false]) b,cosine_distance([true],[false]) c,cosine_distance([true],[true+false]) d from dual;
select * from t1;


--disable_warnings
drop table if exists t1;
--enable_warnings
--error 1264
create table t1 as select l2_distance([9999999999999999],[999999999999999999999]),cosine_distance([-100],[+10000]) b,cosine_distance(null,[false]) c,cosine_distance([0.2],[8+8]) d  from dual;

--disable_warnings
drop table if exists t1;
--enable_warnings
--error 3140
create table t1 as select cosine_distance('[?,?,?,?,?????????????]','[?,?,?,?,?]') from dual;
--error 1210
create table t1 as select cosine_distance('101','101')a,cosine_distance('101','101')b,cosine_distance('101','101')c from dual;
--error 1059
create table t1 as select cosine_distance('-147777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777770','-147777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777770'),cosine_distance('-147777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777770','-147777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777770') from dual;
--error 1210
create table t1 as select cosine_distance('1','0x48656C6C6F20576F726C64')a,cosine_distance('1','0x48656C6C6F20576F726C64')b,cosine_distance('1','0x48656C6C6F20576F726C64')c from dual;

--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1 as select cosine_distance([true],[false]) a,cosine_distance([true],[false]) b,cosine_distance([true],[false]) c,cosine_distance([true],[true+false]) d from dual union select cosine_distance([true],[false]) e,cosine_distance([true],[false]) f,cosine_distance([true],[false]) g,cosine_distance([true],[true+false]) h from dual;




##多表连接
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int primary key, c2 vector(3),c3 vector(3) ,c4 vector(3),
VECTOR INDEX vector_idx(c3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
insert into t1(c1,c2,c3,c4) values(1,'[1,1,2]','[2,2,3]','[1,3,2]');
insert into t1(c1,c2,c3,c4) values(2,'[1,0,3]','[1,0,3]','[2,3,2]');
insert into t1(c1,c2,c3,c4) values(3,'[-1,2,2]','[-3,2,3]','[4,3,3]');
insert into t1(c1,c2,c3,c4) values(4,'[-1,-2,-2]','[-4,2,3]',null);
insert into t1(c1,c2,c3,c4) values(5,'[-1,-3,-2]',null,'[2,3,1]');

--disable_warnings
drop table if exists t2;
--enable_warnings
CREATE TABLE t2 (a1 int primary key , a2 vector(3),a3 vector(3) ,a4 vector(3),
VECTOR INDEX vector_idx(a3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
##show index from t2;
##show index from t1;
insert into t2 select c1,c2,c3,c4 from t1 where c3 is not null and c4 is not null;

--disable_warnings
drop table if exists tt0;
drop table if exists tt1;
drop table if exists tt2;
--enable_warnings
create table tt0 as select c2+c3 from t1 ;
create table tt1 as select cosine_distance(c2,a3) a,cosine_distance(c4,a2) b,c1,a1,a3,c2 from t1 join t2 on c1=a1 ;
create table tt2 as select c2+c3+c4,a2+c3+c2 from t1 join t2 on c1=a1 ;

select cosine_distance(c2,a3) from tt1 ;
select count(*) from t1,t2,tt1;

select cosine_distance(c2,a3),cosine_distance(c2,a3),cosine_distance(c2,a3),cosine_distance(c2,a3),cosine_distance(c2,a3),cosine_distance(c2,a3),(select cosine_distance(a4,a3) from t2 order by cosine_distance(a3, a3)  limit 1) from tt1 ;


##物化视图结合关键字使用  --不支持创建向量索引
--disable_warnings
drop view if exists v1;
drop table if exists t1;
drop materialized view if exists mv1;
--enable_warnings
CREATE TABLE t1 (c1 int primary key, c2 vector(3),c3 vector(3) ,c4 vector(3),
VECTOR INDEX vector_idx(c3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
insert into t1(c1,c2,c3,c4) values(1,'[1,1,2]','[2,2,3]','[1,3,2]');
insert into t1(c1,c2,c3,c4) values(2,'[1,0,3]','[1,0,3]','[2,3,2]');
insert into t1(c1,c2,c3,c4) values(3,'[-1,2,2]','[-3,2,3]','[4,3,3]');
insert into t1(c1,c2,c3,c4) values(4,'[-1,-2,-2]','[-4,2,3]',null);
insert into t1(c1,c2,c3,c4) values(5,'[-1,-3,-2]',null,'[2,3,1]');
create materialized view mv1  parallel 2 refresh complete on demand  as select * from t1 ;
##导致hang住 已修复
--error 1235  
CREATE VECTOR INDEX vector_idx  ON mv1 (c2)  WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40);



##普通视图结合关键字使用
--disable_warnings
drop view if exists v1;
drop table if exists t1;
drop materialized view if exists mv1;
--enable_warnings
CREATE TABLE t1 (c1 int primary key, c2 vector(3),c3 vector(3) ,c4 vector(3),
VECTOR INDEX vector_idx(c3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
insert into t1(c1,c2,c3,c4) values(1,'[1,1,2]','[2,2,3]','[1,3,2]');
insert into t1(c1,c2,c3,c4) values(2,'[1,0,3]','[1,0,3]','[2,3,2]');
insert into t1(c1,c2,c3,c4) values(3,'[-1,2,2]','[-3,2,3]','[4,3,3]');
insert into t1(c1,c2,c3,c4) values(4,'[-1,-2,-2]','[-4,2,3]',null);
insert into t1(c1,c2,c3,c4) values(5,'[-1,-3,-2]',null,'[2,3,1]');
create  view v1 as select * from t1 ; 
select cosine_distance(c3,c2) from v1  group by cosine_distance(c3,[1,2,3]) order by l2_distance(c3, [1,2,3]) APPROX limit 10;
select cosine_distance(c3,c2) from v1  group by cosine_distance(c3,[1,2,3]) order by l2_distance(c3, [1,2,3]) APPROX limit 100000000;

select  c4+c3+c2 from v1 order by cosine_distance(c3, [1,2,3])  limit 100000000;
select  c4+c3+c2 from v1 order by cosine_distance(c3, [1,2,3])  limit 10;


##创建多表join的物化视图
--disable_warnings
drop table if exists t1;
drop table if exists t2;
drop materialized view if exists mv1;
--enable_warnings
CREATE TABLE t1 (c1 int primary key, c2 varchar(30),c3 vector(3) ,c4 vector(3),
VECTOR INDEX vector_idx(c3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40))PARTITION BY KEY(c1) PARTITIONS 4;
insert into t1(c1,c2,c3,c4) values(1,'[1,1,2]','[2,2,3]','[1,3,2]');
insert into t1(c1,c2,c3,c4) values(2,'[1,0,3]','[1,0,3]','[2,3,2]');
insert into t1(c1,c2,c3,c4) values(3,'[-1,2,2]','[-3,2,3]','[4,3,3]');

CREATE TABLE t2 (a1 int , a2 vector(3),a3 vector(3) ,a4 vector(3),
VECTOR INDEX vector_idx(a3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
insert into t2 select c1,c2,c3,c4 from t1;
select * from t1,t2 where c3=a3 order by l2_distance(c3, [1,2,3]) APPROX limit 10;
create materialized view mv1   refresh complete on demand  as select * from t1,t2 where c3=a3 order by l2_distance(c3, [1,2,3]) APPROX limit 10;





##全量物化视图和普通视图连接(物化视图作为基表创建普通视图后再连接物化视图)
--disable_warnings
drop view if exists v1;
drop table if exists t1;
drop materialized view if exists mv1;
--enable_warnings
CREATE TABLE t1 (c1 int primary key, c2 vector(3),c3 vector(3) ,c4 vector(3),
VECTOR INDEX vector_idx(c3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
create materialized view mv1  parallel 2 refresh complete on demand  as select * from t1 ;
insert into t1(c1,c2,c3,c4) values(1,'[1,1,2]','[2,2,3]','[1,3,2]');
insert into t1(c1,c2,c3,c4) values(2,'[1,0,3]','[1,0,3]','[2,3,2]');
insert into t1(c1,c2,c3,c4) values(3,'[-1,2,2]','[-3,2,3]','[4,3,3]');
insert into t1(c1,c2,c3,c4) values(4,'[-1,-2,-2]','[-4,2,3]',null);
insert into t1(c1,c2,c3,c4) values(5,'[-1,-3,-2]',null,'[2,3,1]');
CALL DBMS_MVIEW.REFRESH('mv1','c');
select * from mv1 order by c1;

create  view v1 as select * from mv1 ; 
select count(*) from v1,mv1 ;
select count(*) from v1,t1,mv1;
select count(*) from v1,t1;
select count(*) from v1,mv1;
select count(*) from v1,mv1 where v1.c1=mv1.c1;

select c1,c2,sum(c3),avg(c4),cosine_distance(c3,c2) from t1 a order by l2_distance(a.c3, [1,2,3]) APPROX limit 1;
select a.c1,a.c2,sum(a.c3),avg(a.c4),cosine_distance(a.c3,a.c2) from t1 a order by l2_distance(a.c3, [1,2,3]) APPROX limit 1000;
select c1,c2,c3,c4,cosine_distance(a3,c2) from t1 a inner join t2 b on cosine_distance(c2,c3)=cosine_distance(a3,a4)  order by cosine_distance(a3,c2);
select c1,c2,c3,c4,cosine_distance(a3,c2) from t1 a right join t2 b on cosine_distance(c2,c3)=cosine_distance(a3,a4)  order by cosine_distance(a3,c2);
select c1,c2,c3,c4,cosine_distance(a3,c2) from t1 a left join t2 b on cosine_distance(c2,c3)=cosine_distance(a3,a4)  order by cosine_distance(a3,c2);
select c1,c2,c3,c4,cosine_distance(a3,c2) from t1 a cross  join t2 b on cosine_distance(c2,c3)=cosine_distance(a3,a4)  order by cosine_distance(a3,c2);

select c1,c2,c3,c4,cosine_distance(a3,c2) from t1 a join t2 b on cosine_distance(a4,c3)=cosine_distance(a3,c2)  order by cosine_distance(a3,c2);
select c1,c2,c3,c4,cosine_distance(a3,c2) from t1 a inner join t2 b on cosine_distance(a4,c3)=cosine_distance(a3,c2)  order by cosine_distance(a3,c2);
select c1,c2,c3,c4,cosine_distance(a3,c2) from t1 a right join t2 b on cosine_distance(a4,c3)=cosine_distance(a3,c2)  order by cosine_distance(a3,c2);
select c1,c2,c3,c4,cosine_distance(a3,c2) from t1 a left join t2 b on cosine_distance(a4,c3)=cosine_distance(a3,c2)  order by cosine_distance(a3,c2);
select c1,c2,c3,c4,cosine_distance(a3,c2) from t1 a cross  join t2 b on cosine_distance(a4,c3)=cosine_distance(a3,c2)  order by cosine_distance(a3,c2);


###创建物化视图
--disable_warnings
drop table if exists t1;
drop table if exists tt1;
drop materialized view if exists mv1;
drop materialized view if exists mv2;
drop materialized view if exists mv3;
--enable_warnings
CREATE TABLE t1 (c1 int primary key, c2 vector(3),c3 vector(3) ,c4 vector(3),
VECTOR INDEX vector_idx(c3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
insert into t1(c1,c2,c3,c4) values(1,'[1,1,2]','[2,2,3]','[1,3,2]');
insert into t1(c1,c2,c3,c4) values(2,'[1,0,3]','[1,0,3]','[2,3,2]');
insert into t1(c1,c2,c3,c4) values(3,'[-1,2,2]','[-3,2,3]','[4,3,3]');
insert into t1(c1,c2,c3,c4) values(4,'[-1,-2,-2]','[-4,2,3]',null);
insert into t1(c1,c2,c3,c4) values(5,'[-1,-3,-2]',null,'[2,3,1]');
create materialized view mv1  parallel 2 refresh complete on demand  as select c1,cosine_distance(c4,c3) from t1 order by c1;
create materialized view mv2  parallel 2 refresh complete on demand  as select c1,cosine_distance(c4,c3) from t1 limit 1;
create materialized view mv3  parallel 2 refresh complete on demand  as select c1,c2,c3,c4 from t1 limit 1;
CALL DBMS_MVIEW.REFRESH('mv1','c');
create table tt1 select cosine_distance(c2,c3) from mv3 order by c1;




##物化视图创建普通视图
--disable_warnings
drop table if exists t1;
drop view if exists v1;
drop materialized view if exists mv1;
--enable_warnings
CREATE TABLE t1 (c1 int primary key, c2 vector(3),c3 vector(3) ,c4 vector(3),
VECTOR INDEX vector_idx(c3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
create materialized view mv1  refresh complete on demand  as select c1,c2,c3,c4 from t1 ;
create  view v1 as select c1,c2,c3,c4 from mv1 order by cosine_distance(c3, [1,2,3]) approximate limit 10;
insert into t1(c1,c2,c3,c4) values(1,'[1,1,2]','[2,2,3]','[1,3,2]');
insert into t1(c1,c2,c3,c4) values(2,'[1,0,3]','[1,0,3]','[2,3,2]');
insert into t1(c1,c2,c3,c4) values(3,'[-1,2,2]','[-3,2,3]','[4,3,3]');
insert into t1(c1,c2,c3,c4) values(4,'[-1,-2,-2]','[-4,2,3]',null);
insert into t1(c1,c2,c3,c4) values(5,'[-1,-3,-2]',null,'[2,3,1]');
CALL DBMS_MVIEW.REFRESH('mv1','c');
select * from mv1 order by cosine_distance(c3, [1,2,3])  limit 1;
select * from mv1 order by cosine_distance(c3, [1,2,3])  limit 1,1;

##select * from v1 order by cosine_distance(c3, [1,2,3]) approximate limit 1;
##select * from v1 order by cosine_distance(c3, [1,2,3]) approximate limit 1,1;
##select * from v1 order by cosine_distance(c3, [1,2,3])  limit 1;
##select * from v1 order by cosine_distance(c3, [1,2,3])  limit 1,1;
select * from t1 order by cosine_distance(c3, [1,2,3]) approximate limit 1;
select * from t1 order by cosine_distance(c3, [1,2,3]) approximate limit 1,1;

select * from t1 order by cosine_distance(c3, [1,2,3])  limit 1;


##走向量索引和不走向量索引结果不一致 
--disable_warnings
drop table if exists t1;
drop view if exists v1;
drop materialized view if exists mv1;
--enable_warnings
CREATE TABLE t1 (c1 int primary key, c2 vector(3),c3 vector(3) ,c4 vector(3),
VECTOR INDEX vector_idx(c3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
insert into t1(c1,c2,c3,c4) values(1,'[1,1,2]','[2,2,3]','[1,3,2]');
insert into t1(c1,c2,c3,c4) values(2,'[1,0,3]','[1,0,3]','[2,3,2]');
insert into t1(c1,c2,c3,c4) values(3,'[-1,2,2]','[-3,2,3]','[4,3,3]');
insert into t1(c1,c2,c3,c4) values(4,'[-1,-2,-2]','[-4,2,3]',null);
insert into t1(c1,c2,c3,c4) values(5,'[-1,-3,-2]',null,'[2,3,1]');
select * from t1 order by cosine_distance(c3, [1,2,3]);
select * from t1 order by cosine_distance(c3, [1,2,3])  limit 1,1;


##分区表的向量索引列存在null值，走索引查询导致core
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(c1 int primary key, c2 vector(3),c3 vector(3) , c4 vector(3),
VECTOR INDEX vector_idx(c4) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40)) partition by hash(c1) partitions 4;
replace into t1(c1, c2, c3) values(1,'[1,1,2]','[2,2,3]');
replace into t1(c1, c2, c3) values(2,'[1,-1,3]','[1,0,3]');
select * from t1 order by cosine_distance(c4, [1,2,3]);
select * from t1 order by cosine_distance(c4, [1,2,3])  limit 1;


--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(c1 int primary key, c2 vector(3),c3 vector(3) , c4 vector(3),
VECTOR INDEX vector_idx(c4) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40)) partition by hash(c1) partitions 4;
replace into t1(c1, c2, c3) values(1,'[1,1,2]','[2,2,3]');
replace into t1(c1, c2, c3) values(2,'[1,-1,3]','[1,0,3]');
select * from t1 order by cosine_distance(c4, [1,2,3]);
select * from t1 order by cosine_distance(c4, [1,2,3])  limit 1,1;

--disable_warnings
drop view if exists v1;
--enable_warnings
create view v1 as select * from t1;
select * from v1;

##旁路导入后建向量索引
--disable_warnings
drop table if exists t1;
drop materialized view if exists mv1;
--enable_warnings
CREATE TABLE t1 (c1 int, c2 vector(3),c3 vector(3) ,c4 vector(3));
insert into t1 values(1,'[1,1,2]','[2,2,3]','[1,3,2]');
insert /*+ direct(true,100) enable_parallel_dml parallel(2) */ into t1 select * from t1;
create VECTOR index vector_idx1 on t1(c3) with (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40);
create materialized view mv1  refresh complete on demand  as select c1,c2,c3,c4 from t1 ;
##函数索引
--error 1235
create index idx1 on mv1 ((c2+c3));
create index idx1 on mv1 (c1);
##show index from mv1;

##物化视图后建向量索引hang住
--disable_warnings
drop table if exists t1;
drop materialized view if exists mv1;
--enable_warnings
CREATE TABLE t1 (c1 int primary key, c2 vector(3),c3 vector(3) ,c4 vector(3),
VECTOR INDEX vector_idx(c3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
insert into t1(c1,c2,c3,c4) values(1,'[1,1,2]','[2,2,3]','[1,3,2]');
insert into t1(c1,c2,c3,c4) values(2,'[1,0,3]','[1,0,3]','[2,3,2]');
insert into t1(c1,c2,c3,c4) values(3,'[-1,2,2]','[-3,2,3]','[4,3,3]');
insert into t1(c1,c2,c3,c4) values(4,'[-1,-2,-2]','[-4,2,3]',null);
insert into t1(c1,c2,c3,c4) values(5,'[-1,-3,-2]',null,'[2,3,1]');
select cosine_distance(c4,c3),c1,* from t1 order by cosine_distance(c3, [1,2,3]) approximate limit 10;
drop index vector_idx on t1;
