--echo ##create view
--disable_warnings
drop table if exists t1;
drop view if exists v1;
drop table if exists t2;
drop view if exists v2;
--enable_warnings
CREATE TABLE t1 (c1 int primary key, c2 vector(3),c3 vector(3) ,c4 vector(3),
VECTOR INDEX vector_idx(c3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
create view v1 as select * from t1;
CREATE TABLE t2 (a1 int , a2 vector(3),a3 vector(3) ,a4 vector(3),
VECTOR INDEX vector_idx(a3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
create view v2 as select * from t2;
insert into v1(c1,c2,c3,c4) values(1,'[1,1,2]','[2,2,3]','[1,3,2]');
insert into v1(c1,c2,c3,c4) values(2,'[1,0,3]','[1,0,3]','[2,3,2]');
insert into v1(c1,c2,c3,c4) values(3,'[-1,2,2]','[-3,2,3]','[4,3,3]');
insert into v1(c1,c2,c3,c4) values(4,'[-1,-2,-2]','[-4,2,3]',null);
insert into v1(c1,c2,c3,c4) values(5,'[-1,-3,-2]',null,'[2,3,1]');
insert into t2 select c1,c2,c3,c4 from t1; 

select c1,c2,c3,c4,cosine_distance(a3,c2) from v1 a join v2 b on c2=a2  order by l2_distance(c3, [1,2,3]) approximate limit 10;
select c1,c2,c3,c4,cosine_distance(a3,c2) from v1 a join v2 b on cosine_distance(c2,c3)=cosine_distance(a3,a4)  order by l2_distance(c3, [1,2,3]) approximate limit 10;
select c1,c2,c3,c4,cosine_distance(a3,c2) from v1 a inner join v2 b on cosine_distance(c2,c3)=cosine_distance(a3,a4)  order by l2_distance(c3, [1,2,3]) approximate limit 10;
select c1,c2,c3,c4,cosine_distance(a3,c2) from v1 a right join t2 b on cosine_distance(c2,c3)=cosine_distance(a3,a4) order by l2_distance(c3, [1,2,3]) approximate limit 10;
select c1,c2,c3,c4,cosine_distance(a3,c2) from v1 a left join t2 b on cosine_distance(c2,c3)=cosine_distance(a3,a4)  order by l2_distance(c3, [1,2,3]) approximate limit 10;
select c1,c2,c3,c4,cosine_distance(a3,c2) from v1 a cross  join t2 b on cosine_distance(c2,c3)=cosine_distance(a3,a4)  order by l2_distance(c3, [1,2,3]) approximate limit 10;

select c1,c2,c3,c4,cosine_distance(a3,c2) from v1 a join v2 b on cosine_distance(a4,c3)=cosine_distance(a3,c2)  order by cosine_distance(a3,c2);
select c1,c2,c3,c4,cosine_distance(a3,c2) from v1 a inner join v2 b on cosine_distance(a4,c3)=cosine_distance(a3,c2)  order by cosine_distance(a3,c2);
select c1,c2,c3,c4,cosine_distance(a3,c2) from v1 a right join t2 b on cosine_distance(a4,c3)=cosine_distance(a3,c2)  order by cosine_distance(a3,c2);
select c1,c2,c3,c4,cosine_distance(a3,c2) from v1 a left join t2 b on cosine_distance(a4,c3)=cosine_distance(a3,c2)  order by cosine_distance(a3,c2);
select c1,c2,c3,c4,cosine_distance(a3,c2) from v1 a cross  join v2 b on cosine_distance(a4,c3)=cosine_distance(a3,c2)  order by cosine_distance(a3,c2);

##普通表存在已知问题
select * from v1 a join v1 b  where a.c2=b.c2 order by l2_distance(a.c3, [1,2,3])  approximate limit 10;
select * from (select * from v1 order by c1) a join (select c1,c2,c3 from v1 order by c1) b  where cosine_distance(a.c3,b.c2)=cosine_distance(b.c3,a.c2) order by l2_distance(a.c3, [1,2,3]) approximate limit 1,1;
##存在关键字
select * from t1 order by l2_distance(c3, [1,2,3]) approximate limit 10;


