##分区表视图update操作
--disable_warnings
drop table if exists t1;
drop table if exists tt1;
drop view if exists v1;
--enable_warnings
CREATE TABLE t1 (c1 int primary key, c2 vector(3),c3 vector(3) ,c4 vector(3),
VECTOR INDEX vector_idx(c3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40))PARTITION BY KEY(c1) PARTITIONS 4;
insert into t1(c1,c2,c3,c4) values(1,'[1,1,2]','[2,2,3]','[1,3,2]');
insert into t1(c1,c2,c3,c4) values(2,'[1,0,3]','[1,0,3]','[2,3,2]');
insert into t1(c1,c2,c3,c4) values(3,'[-1,2,2]','[-3,2,3]','[4,3,3]');
insert into t1(c1,c2,c3,c4) values(4,'[-1,-2,-2]','[-4,2,3]',null);
insert into t1(c1,c2,c3,c4) values(5,'[-1,-3,-2]',null,'[2,3,1]');
create view v1 as  select * from t1;

update v1 set c1 = 10 where c1 =5;
update v1 set c2 = '[1,23,null]' where c1 =5;
update v1 set c2 = '[1,23,abs(null)]' where c1 =5;
update v1 set c2 =[cosine_distance('[1,3,2]','[1,1,2]'),cosine_distance('[1,2,2]','[1,1,11]'),cosine_distance('[1,1,2]','[1,1,2]')] where c3 is null;
update v1 set c1 = cosine_distance('[1,8,2]','[1,1,2]') where c3 = '[2,2,3]';
--error 1062
update v1 set c1 = cosine_distance('[1,10,2]','[1,1,2]'),c2 = '[1,1,1]',c3 = '[0,1,0]',c4 = '[0.1,1.2,100]' where c4 = '[2,3,2]';
update v1 set c2 ='[1,2,3]' where c1 >cosine_distance('[1,1,2]','[1,2,2]');

update v1 set c2 =[1,2,3] where c1 >cosine_distance('[1,1,2]','[1,2,2]');
update v1 set c2 =[2,2,3] where c1 <cosine_distance('[1,1,2]','[1,2,2]');
update v1 set c2 =[1,2,3] where c1 >=cosine_distance('[1,1,2]','[1,2,2]');
update v1 set c2 =[2,2,3] where c1 <=cosine_distance('[1,1,2]','[1,2,2]');
update v1 set c2 =[1,2,3] where c1 =cosine_distance('[1,1,2]','[1,2,2]');
update v1 set c2 =[2,2,3] where c1 <>cosine_distance('[1,1,2]','[1,2,2]');
update v1 set c2 =[1,2,3] where c1 > cosine_distance('[1,3,2]','[1,2,2]') and c1 > cosine_distance('[1,3,2]','[1,2,2]');
update v1 set c2 =[2,2,3] where c1 < cosine_distance('[1,1,2]','[1,2,2]') or c1 > cosine_distance('[1,3,2]','[1,2,2]') ;



