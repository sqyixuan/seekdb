insert into t1 values(5,'[-1,-3,-2]',null,'[2,3,1]');
SELECT avg(c3),avg(c4) from t1 where  EXISTS (SELECT l2_distance(c3,[1,1,1]) FROM t1 order by l2_distance(c3, [1,2,3])  limit 10 ) order by c1;

SELECT avg(c3),avg(c4) from t1 where  EXISTS (SELECT l2_distance(c3,[1,1,1]) FROM t1 order by l2_distance(c3, [1,2,3]) approximate limit 10 ) order by c1;

