##数组中包含聚合函数
select l2_distance([max(100),1,3],'[1,1,2]') from dual;
select l2_distance([count(100),1,3],'[1,1,2]') from dual;
select l2_distance([min(100),1,3],'[1,1,2]') from dual;
select l2_distance([sum(100),1,3],'[1,1,2]') from dual;
select l2_distance([avg(100),1,3],'[1,1,2]') from dual;

create table table_max as select l2_distance([max(100),1,3],'[1,1,2]') from dual;
create table table_count as select l2_distance([count(100),1,3],'[1,1,2]') from dual;
create table table_min as select l2_distance([min(100),1,3],'[1,1,2]') from dual;
create table table_sum as select l2_distance([sum(100),1,3],'[1,1,2]') from dual;
create table table_avg as select l2_distance([avg(100),1,3],'[1,1,2]') from dual;



##dml操作

--echo ##where子句
--disable_warnings
drop table if exists t1;drop table if exists tt1;drop table if exists tt2;
--enable_warnings
CREATE TABLE t1 (c1 int AUTO_INCREMENT primary key , c2 vector(3),c3 vector(3) ,c4 BLOB,
VECTOR INDEX vector_idx(c3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
--error 1111
select * from t1 where avg(c2);


--echo ##=,<,<=,>=,<>
--disable_warnings
drop table if exists t1;drop table if exists tt1;drop table if exists tt2;
--enable_warnings
CREATE TABLE t1 (c1 int primary key, c2 VARCHAR(30),c3 vector(3) ,c4 vector(2));
insert into t1 values(1,'[1,1,2]','[2,2,3]','[1,3]');
insert into t1 values(2,'[1,2,3]','[1,2,3]','[2,3]');
insert into t1 values(3,'[-1,2,2]','[-3,2,3]','[4,3]');
insert into t1 values(4,'[-1,-2,-2]','[-4,2,3]',null);
insert into t1 values(5,'[-1,-2,-2]',null,'[2,3]');
--error 5083
select avg(c3) = avg(c2) from t1  order by c1;

select avg(c3) = avg(c3) from t1  order by c1;
--error 5083
select avg(c3) < avg(c3) from t1  order by c1;
--error 5083
select avg(c3) > avg(c3) from t1  order by c1;
--error 5083
select avg(c3) >= avg(c3) from t1  order by c1;
--error 5083
select avg(c3) <= avg(c3) from t1  order by c1;

select avg(c3) <> avg(c3) from t1  order by c1;


--echo ##and/or
--disable_warnings
drop table if exists t1;drop table if exists tt1;drop table if exists tt2;
--enable_warnings
CREATE TABLE t1 (c1 int primary key, c2 VARCHAR(30),c3 vector(3) ,c4 vector(3),
VECTOR INDEX vector_idx(c3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40),
VECTOR INDEX vector_idx1(c4) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
insert into t1 values(1,'[1,1,2]','[2,2,3]','[1,-1.5,3]');
insert into t1 values(2,'[1,2,3]','[1,2,3]','[2,1.5,3]');
insert into t1 values(3,'[-1,2,2]','[-3,2,3]','[4,-1,3]');
insert into t1 values(4,'[-1,-2,-2]','[-4,2,3]',null);
insert into t1 values(5,'[-1,-2,-2]',null,'[2,-2,3]');

select avg(c3),avg(c4) from t1 where l2_distance(c3,c3) =0 and l2_distance(c3,c4) is  null order by c1;

select avg(c3)+avg(c4) from t1 where l2_distance(c3,c3) <=2 or l2_distance(c3,c2) >1 ;


--echo ##between and
--disable_warnings
drop table if exists t1;drop table if exists tt1;drop table if exists tt2;
--enable_warnings
CREATE TABLE t1 (c1 int primary key, c2 VARCHAR(30),c3 vector(3) ,c4 vector(2),
VECTOR INDEX vector_idx(c3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
insert into t1 values(1,'[1,1,2]','[2,2,3]','[1,3]');
insert into t1 values(2,'[1,2,3]','[1,2,3]','[2,3]');
insert into t1 values(3,'[-1,2,2]','[-3,2,3]','[4,3]');
insert into t1 values(4,'[-1,-2,-2]','[-4,2,3]',null);
insert into t1 values(5,'[-1,-2,-2]',null,'[2,3]');

select  avg(c3),avg(c4) from t1 where 1 BETWEEN l2_distance(c3,c3)  and l2_distance(c3,'[1,2,3]') order by l2_distance(c3, [1,2,3])  limit 10;
select  avg(c3),avg(c4) from t1 where 1 BETWEEN l2_distance(c3,c3)  and l2_distance(c3,'[1,2,3]') order by l2_distance(c3, [1,2,3]) approximate limit 10;

select  l2_distance(avg(c3),'[1,2.2,3]') BETWEEN l2_distance(avg(c3),c3)  and l2_distance(avg(c3),'[1,2,3]') from t1 order by l2_distance(c3, [1,2,3])  limit 10;
select  l2_distance(avg(c4),'[1,3]') BETWEEN l2_distance(avg(c3),c3)  and l2_distance(avg(c3),'[1,2,3]') from t1 order by l2_distance(c3, [1,2,3]) approximate limit 10;

--echo ##like/not like
--disable_warnings
drop table if exists t1;drop table if exists tt1;drop table if exists tt2;
--enable_warnings
CREATE TABLE t1 (c1 int primary key, c2 VARCHAR(30),c3 vector(3) ,c4 vector(2),
VECTOR INDEX vector_idx(c3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
insert into t1 values(1,'[1,1,2]','[2,2,3]','[1,3]');
insert into t1 values(2,'[1,0,3]','[1,0,3]','[2,3]');
insert into t1 values(3,'[-1,2,2]','[-3,2,3]','[4,3]');
insert into t1 values(4,'[-1,-2,-2]','[-4,2,3]',null);
insert into t1 values(5,'[-1,-3,-2]',null,'[2,3]');

select  avg(c3),avg(c4) from t1 where l2_distance(c3,c3) like '%0%' order by l2_distance(c3, [1,2,3])  limit 10;
select  avg(c3),avg(c4) from t1 where l2_distance(c3,c3) like l2_distance(c3,c2) order by l2_distance(c3, [1,2,3]) approximate limit 10;

select  * from t1 where l2_distance(c3,c3) not like '%1%' order by c1;
select  * from t1 where l2_distance(c3,c3) not like l2_distance(c3,c2) order by c1;


--echo ##exists,any,all,in(无关键字)
--disable_warnings
drop table if exists t1;drop table if exists tt1;drop table if exists tt2;
--enable_warnings
CREATE TABLE t1 (c1 int primary key, c2 VARCHAR(30),c3 vector(3) ,c4 vector(3),
VECTOR INDEX vector_idx(c3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
insert into t1 values(1,'[1,1,2]','[2,2,3]','[1,3,2]');
insert into t1 values(2,'[1,0,3]','[1,0,3]','[2,3,2]');
insert into t1 values(3,'[-1,2,2]','[-3,2,3]','[4,3,3]');
insert into t1 values(4,'[-1,-2,-2]','[-4,2,3]',null);
insert into t1 values(5,'[-1,-3,-2]',null,'[2,3,1]');

SELECT avg(c3),avg(c4) from t1 where  EXISTS (SELECT l2_distance(c3,[1,null,1]) FROM t1) order by c1;
SELECT avg(c3),avg(c4) from t1 where  EXISTS (SELECT c3 FROM t1) order by c1;
SELECT avg(c3),avg(c4) from t1 where l2_distance(c3,c3) = any (SELECT l2_distance(c3,[1,-1,1]) FROM t1) order by c1;
SELECT avg(c3),avg(c4) from t1 where l2_distance(c3,c3) >= any (SELECT l2_distance(c3,[1,-1,1]) FROM t1) order by c1;
SELECT avg(c3),avg(c4) from t1 where l2_distance(c3,c3) <= any (SELECT l2_distance(c3,[1,-1,1]) FROM t1) order by c1;
SELECT avg(c3),avg(c4) from t1 where l2_distance(c3,c3) <> any (SELECT l2_distance(c3,[1,-1,1]) FROM t1) order by c1;
SELECT avg(c3),avg(c4) from t1 where l2_distance(c3,c3) != any (SELECT l2_distance(c3,[1,-1,1]) FROM t1) order by c1;
SELECT avg(c3),avg(c4) from t1 where l2_distance(c3,c3) > any (SELECT l2_distance(c3,[1,-1,1]) FROM t1) order by c1;
SELECT avg(c3),avg(c4) from t1 where l2_distance(c3,c3) < any (SELECT l2_distance(c3,[1,-1,1]) FROM t1) order by c1;



SELECT avg(c3),avg(c4) from t1 where l2_distance(c3,c3) in (l2_distance(c3,c3),l2_distance(c3,c4)) order by c1;
SELECT avg(c3),avg(c4) from t1 where l2_distance(c3,c3) not in (l2_distance(c3,'[1,2,3]'),l2_distance(c4,'[1,2,3]')) order by c1;
SELECT avg(c3),avg(c4) from t1 where l2_distance(c3,c3) not in (SELECT l2_distance(c3,'[1,2,3]')FROM t1) order by c1;

