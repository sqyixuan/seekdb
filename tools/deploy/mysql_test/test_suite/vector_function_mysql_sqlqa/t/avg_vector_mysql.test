##字符数据类型入参

--echo ##CHAR
--disable_warnings
drop table if exists t1;drop table if exists tt1;drop table if exists tt2;
--enable_warnings

CREATE TABLE t1 (c1 int PRIMARY KEY, c2 char(30),c3 vector(3));
insert into t1 values(1,'[1,1,2]','[2,2,3]');
insert into t1 values(2,'[2,2,3]','[3,2,3]');
insert into t1 values(3,'[29,2,2]','[3,2,3]');
insert into t1 values(4,'[-1,-2,-2]','[3,2,3]');
select avg(c2) a from t1;
select avg(c3) a from t1;
create table tt1 as select avg(c3) a from t1;
--error 1292
create table tt2 as select avg(c2) from t1;


