--echo ##distinct
--error 5083
select distinct c2 from t1 order By c1;
select distinct l2_distance(c2,c3) from t1 order By c1;
SELECT avg(DISTINCT l2_distance(c2,c3)) FROM t1 order By c1;
SELECT avg(DISTINCT l2_distance(c2,[1,1,2])) FROM t1 order By c1;

--echo ##with as
--disable_warnings
drop table if exists t1;drop table if exists t2;
--enable_warnings
CREATE TABLE t1 (c1 int primary key, c2 vector(3),c3 vector(3) ,c4 vector(3),
VECTOR INDEX vector_idx(c3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
insert into t1 values(1,'[1,1,2]','[2,2,3]','[1,3,2]');
insert into t1 values(2,'[1,0,3]','[1,0,3]','[2,3,2]');
insert into t1 values(3,'[-1,2,2]','[-3,2,3]','[4,3,3]');
insert into t1 values(4,'[-1,-2,-2]','[-4,2,3]',null);
insert into t1 values(5,'[-1,-3,-2]',null,'[2,3,1]');
CREATE TABLE t2 (a1 int , a2 vector(3),a3 vector(3) ,a4 vector(3));
insert into t2 select c1,c2,c3,c4 from t1; 

with ct1 AS(
select avg(c2) from t1 order by c1)
select avg(c2) from t1 where c1 >2 order by c1 ;

with ct1 as(
select avg(c2) from t1 order by c1)
select avg(c2) from t1 where c3 is not null order by c1 ;

##导致core -已修复
with ct1 as(
select l2_distance(c2,c3),avg(c2) from t1 order by c1)
select l2_distance(c2,c3),avg(c2) from t1 join t2 on l2_distance(c2,c3)=l2_distance(a3,a4) order by c1;


##CASE WHEN
alter system set ob_vector_memory_limit_percentage =44;
--disable_warnings
drop table if exists t1;drop table if exists t2;
--enable_warnings
CREATE TABLE t1 (c1 int primary key, c2 vector(3),c3 vector(3) ,c4 vector(3),
VECTOR INDEX vector_idx(c3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
insert into t1 values(1,'[1,1,2]','[2,2,3]','[1,3,2]');
insert into t1 values(2,'[1,0,3]','[1,0,3]','[2,3,2]');
insert into t1 values(3,'[-1,2,2]','[-3,2,3]','[4,3,3]');
insert into t1 values(4,'[-1,-2,-2]','[-4,2,3]',null);
insert into t1 values(5,'[-1,-3,-2]',null,'[2,3,1]');
SELECT count(c1), CASE WHEN l2_distance(C2,[1,2,3]) > 1 THEN avg(c2) ELSE avg(c3) END AS A FROM T1 ;

SELECT count(c1), CASE WHEN l2_distance(C2,[1,2,3]) > 1 THEN sum(c2) ELSE sum(c3) END AS A FROM T1 ;

--disable_warnings
drop table if exists t2;
--enable_warnings
CREATE TABLE t2 (a1 int , a2 vector(3),a3 vector(3) ,a4 vector(3));
insert into t2 select c1,c2,c3,c4 from t1; 

SELECT count(c1), CASE WHEN l2_distance(C2,[1,2,3]) > l2_distance([1,1,1],a3) THEN avg(c2) ELSE avg(c3) END AS A FROM T1,t2 ;


##导致core  --已修复
SELECT count(*) FROM t1,t2 where l2_distance(t1.C2, t2.A2) < 0.5;
##导致core --已修复
#SELECT count(c1), CASE WHEN l2_distance(C2,[1,2,3]) > l2_distance([1,1,1],a3) THEN 'High' ELSE 'Low' END AS A FROM T1,t2 ;

SELECT C1, CASE WHEN l2_distance(C2,[1,2,3]) > 5 THEN 'High' ELSE 'Low' END AS A FROM T1,t2 ;

##--error 4016  已修复
SELECT t1.C1, 
       CASE 
           WHEN l2_distance(t1.C2, t2.A2) > 10 THEN 'Far'
           WHEN l2_distance(t1.C3, t2.A3) BETWEEN 5 AND 10 THEN 'Medium'
           WHEN avg(t1.C3+t2.A3) <> [1,2,3] THEN 'true'
           ELSE 'Close'
       END AS distance_category,
       avg(t1.C2) OVER (PARTITION BY t1.C1) AS avg_vector
FROM T1 t1
JOIN T2 t2 ON t1.C1 = t2.A1
WHERE l2_distance(t1.C2, t2.A2) < 0.5;


