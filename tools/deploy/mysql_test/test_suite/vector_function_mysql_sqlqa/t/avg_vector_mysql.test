--error 1064
select avg([ ]) ;
drop table if exists t1;
create table t1(c1 vector(1));
insert into t1 values([2]);
insert into t1 values([4]);
insert into t1 values([0]);
insert into t1 values([-100]);
select avg(c1) from t1;

