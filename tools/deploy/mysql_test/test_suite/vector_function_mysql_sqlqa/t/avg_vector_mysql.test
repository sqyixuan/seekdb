--echo ##where子句
--disable_warnings
drop table if exists t1;drop table if exists t2;
--enable_warnings
CREATE TABLE t1 (c1 int primary key, c2 vector(3),c3 vector(3) ,c4 vector(3),
VECTOR INDEX vector_idx(c2) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
insert into t1 values(1,'[1,1,2]','[2,2,3]','[1,3,2]');
insert into t1 values(2,'[1,0,3]','[1,0,3]','[2,3,2]');
insert into t1 values(3,'[-1,2,2]','[-3,2,3]','[4,3,3]');
insert into t1 values(4,'[-1,-2,-2]','[-4,2,3]',null);
insert into t1 values(5,'[-1,-3,-2]',null,'[2,3,1]');
--error 1111
update t1 set c2 ='[1,2,3]' where c1 >l2_distance(avg(c2),'[1,2,2]');

select * from t1 order by c1;
update t1 set c2 =[2,2,3] where l2_distance(c3,c3) = any (SELECT l2_distance(avg(c3),c4) FROM t1) order by c1;
update t1 set c2 =[2,2,3] where l2_distance(c3,c3) = all (SELECT l2_distance(avg(c3),c4) FROM t1) order by c1;
update t1 set c2 =[2,2,3] where  exists (SELECT l2_distance(avg(c3),c4) FROM t1) order by c1;
update t1 set c2 =[2,2,3] where l2_distance(c3,c3) in  (SELECT l2_distance(avg(c3),c4) FROM t1) order by c1;
update t1 set c2 =[2,2,3] where l2_distance(c3,c3) not in  (SELECT l2_distance(avg(c3),c4) FROM t1) order by c1;
select * from t1 order by c1;

call dbms_vector.refresh_index('vector_idx','t1','c2',1,'FAST');
call dbms_vector.rebuild_index('vector_idx','t1');

--echo ## update join(子查询/多表更新)
--disable_warnings
drop table if exists t1;drop table if exists t2;
--enable_warnings
CREATE TABLE t1 (c1 int primary key, c2 vector(3),c3 vector(3) ,c4 vector(3));
insert into t1 values(1,'[1,1,2]','[2,2,3]','[1,3,2]');
insert into t1 values(2,'[1,0,3]','[1,0,3]','[2,3,2]');
insert into t1 values(3,'[-1,2,2]','[-3,2,3]','[4,3,3]');
insert into t1 values(4,'[-1,-2,-2]','[-4,2,3]',null);
insert into t1 values(5,'[-1,-3,-2]',null,'[2,3,1]');

--disable_warnings
drop table if exists t2;
--enable_warnings
CREATE TABLE t2 (a1 int , a2 vector(3),a3 vector(3) ,a4 vector(3));
insert into t2 select c1,c2,c3,c4 from t1; 

select avg(c2) from t1 union  select avg(a3) from t2;

select l2_distance(c2,c3) from t1 union  select l2_distance(a2,a3) from t2;
CREATE VECTOR INDEX vector_idx_c2  ON t1 (c2)  WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40);
update t1 set c2 =[1,2,4] where c1 in (select l2_distance(avg(a3),avg(c3)) from t1 inner join t2 on c2=a2);

update t1 join t2 on c2 =a2 set c2 =[1,2,4] where a3 is null;

update t1 set c1 = l2_distance([1,2,4],[1,3,5]) where c1 in (select l2_distance(avg(a3),avg(c3)) from t1 inner join t2 on c2=a2);

update t1 join t2 on c2 =a2 set c1 = l2_distance([1,2,4],[1,3,5]) where a3 is null;

call dbms_vector.refresh_index('vector_idx_c2','t1','c2',1,'FAST');
call dbms_vector.rebuild_index('vector_idx_c2','t1');



--echo ##insert/replace
--disable_warnings
drop table if exists t1;drop table if exists t2;
--enable_warnings
CREATE TABLE t1 (c1 int primary key, c2 vector(3),c3 vector(3) ,c4 vector(3),
VECTOR INDEX vector_idx(c3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
insert into t1(c1) values(l2_distance([1,2,3],[1,2,4]));
insert into t1(c1) values(l2_distance([1,2,3],[1,2,5]));
insert into t1(c1) values(l2_distance([1,2,3],[1,2,6]));
insert into t1(c1) values(l2_distance([1,2,3],[1,2,7]));
insert into t1(c1) values(l2_distance([1,2,3],[1,2,3]));
insert into t1(c1,c2,c3,c4) values(l2_distance([1,2,3],[1,2,8]),[1,1,2],[2,3,4],[2,3,4]);
insert into t1(c1,c2,c3,c4) values(l2_distance([1,2,3],[1,2,9]),[1,1,2],[2,3,4],null);

replace into t1(c1,c2,c3,c4) values(l2_distance([1,2,3],[1,2,100]),[-1,-3,-2],[2,3,1],[2,3,1]);
replace into t1(c1,c2,c3,c4) values(l2_distance([1,2,3],[1,2,100]),[-1,-3,-2],null,[2,3,1]);
replace into t1(c1,c2,c3,c4) values(-1,[-1,-3,-2],null,[2,3,1]);
replace into t1(c1,c2,c3,c4) values(l2_distance([1,2,3],[1,2,100]),[-1,-3,-2],null,[2,3,1]);
create table t2 like t1;
replace into t2 select c1,sum(c2) a,avg(c3) b,c4 from t1;

select avg(c2) from t2  order by c1 ;



##运算符
--disable_warnings
drop table if exists t1;drop table if exists t2;
--enable_warnings
CREATE TABLE t1 (c1 int AUTO_INCREMENT primary key , c2 vector(3),c3 vector(3) ,c4 BLOB,
VECTOR INDEX vector_idx(c3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
insert into t1(c1) values(l2_distance([1.5+1,2.5-1,-1.5*2],[-1.5 % 1,1.5+0,1%1]));
insert into t1(c1) values(l2_distance([2.5+1,2.5-1,-1.5*2],[-1000.5 % 1,1.5+1,1%1]));
insert into t1(c1) values(l2_distance([1.5+1,2.5-1,-1.5*2],[-1.5 % 1,1.5+1,1%1])+l2_distance([1.5+1,2.5-1,-1.5*2],[-1.5 % 1,1.5+0,1%1]));
insert into t1(c1) values(l2_distance([1.5+1,2.5-1,-1.5*2],[-1.5 % 1,1.5+1,1%1])+l2_distance([1.5+1,2.5-1,-1.5*2],[-1.5 % 1,1.5+0,1%1])+l2_distance([1.5+1,2.5-1,-1.5*2],[-1.5 % 1,1.5+0,1%1])+l2_distance([1.5+1,2.5-1,-1.5*2],[-1.5 % 1,1.5+0,1%1])+l2_distance([1.5+1,2.5-1,-1.5*2],[-1.5 % 1,1.5+0,1%1])+l2_distance([1.5+1,2.5-1,-1.5*2],[-1.5 % 1,1.5+0,1%1])+l2_distance([1.5+1,2.5-1,-1.5*2],[-1.5 % 1,1.5+0,1%1]));
insert into t1(c1) values(l2_distance([1.5+1,2.5-1,-1.5*2],[-1.5 % 1,1.5+1,1%1])-l2_distance([1.5+1,2.5-1,-1.5*2],[-1.5 % 1,1.5+0,1%1])+l2_distance([1.5+1,2.5-1,-1.5*2],[-1.5 % 1,1.5+0,1%1])*l2_distance([1.5+1,2.5-1,-1.5*2],[-1.5 % 1,1.5+0,1%1])+l2_distance([1.5+1,2.5-1,-1.5*2],[-1.5 % 1,1.5+0,1%1])+l2_distance([1.5+1,2.5-1,-1.5*2],[-1.5 % 1,1.5+0,1%1])+l2_distance([1.5+1,2.5-1,-1.5*2],[-1.5 % 1,1.5+0,1%1]));
insert into t1(c2) select [2,3,4] from dual; 
insert into t1(c3) select [3,3,4] from dual; 
insert into t1(c3) select [l2_distance([1.5+1,2.5-1,-1.5*2],[-1.5 % 1,1.5+1,1%1]),l2_distance([1.5+1,2.5-1,-1.5*2],[-1.5 % 1,1.5+1,1%1]),l2_distance([1.5+1,2.5-1,-1.5*2],[-1.5 % 1,1.5+1,1%1])] from dual; 
insert into t1(c4) select l2_distance([1.5+1,2.5-1,-1.5*2],[-1.5 % 1,1.5+1,1%1]) from dual; 

select l2_distance(c3,[2,3,5]) from t1 order by c1 limit 6,2;
select l2_distance(c3,[-2,3,-5]) from t1 order by c1 limit 6,2;

##插入多个字段值
--disable_warnings
drop table if exists t1;drop table if exists t2;drop table if exists tt1;
--enable_warnings
CREATE TABLE t1 (c1 int AUTO_INCREMENT primary key , c2 vector(3),c3 vector(3) ,c4 BLOB,
VECTOR INDEX vector_idx(c3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
drop table if exists t2;
CREATE TABLE t2 (a1 int AUTO_INCREMENT primary key , a2 vector(3),a3 vector(3) ,a4 BLOB,
VECTOR INDEX vector_idx(a3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
insert into t1(c1,c2) values(l2_distance([1.5+1,2.5-1,-1.5*2],[-1.5 % 1,1.5+0,1%1]),[l2_distance([-1.5+1,2.5-1,-1.5*2],[-1.5 % 1,1.5+1.5,1%1]),l2_distance([1.5+1,2.5-1,-1.5*2],[-1.5 % 1,1.5+1,1%1]),l2_distance([1.5+1,2.5-1,-1.5*2],[-1.5 % 1,1.5+1,1%1])]);
insert into t2(a1,a2) values(l2_distance([1.5+1,2.5-1,-1.5*2],[-1.5 % 1,1.5+0,1%1]),[l2_distance([-1.5+1,2.5-1,-1.5*2],[-1.5 % 1,1.5+1,1%1.5]),l2_distance([1.5+1,2.5-1,-1.5*2],[-1.5 % 1,1.5+1,1%1]),l2_distance([1.5+1,2.5-1,-1.5*2],[-1.5 % 1,1.5+1,1%1])]);
