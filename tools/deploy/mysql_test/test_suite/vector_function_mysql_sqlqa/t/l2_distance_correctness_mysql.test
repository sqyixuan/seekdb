select * from t1 order by l2_distance(sum(c3), [1,2,3]) approximate limit 1;
select * from t1 order by l2_distance(avg(c3), [1,2,3])  limit 1;
select * from t1 order by l2_distance(sum(c3), [1,2,3])  limit 1;


