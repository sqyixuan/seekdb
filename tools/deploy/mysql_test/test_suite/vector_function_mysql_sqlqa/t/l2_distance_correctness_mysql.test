#description: correctness
#tags:vector
#author: wb-ljh01399065
purge recyclebin;
--disable_warnings
drop database IF EXISTS obljh;
--enable_warnings
create database obljh ;
use obljh;
set timestamp = 1600000000;
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;
set ob_default_lob_inrow_threshold = 0;

alter system set ob_vector_memory_limit_percentage =44;

##普通表创建索引后进行验证
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int primary key, c2 VARCHAR(30),c3 vector(3) ,c4 vector(2));
insert into t1 values(1,'[1,1,2]','[2,2,3]','[1,3]');
insert into t1 values(2,'[1,2,3]','[1,2,3]','[2,3]');
insert into t1 values(3,'[-1,2,2]','[-3,2,3]','[4,3]');
insert into t1 values(4,'[-1,-2,-2]','[-4,2,3]',null);
insert into t1 values(5,'[1,1,2]','[2,2,3]','[1,3]');
insert into t1 values(6,'[1,2,3]','[1,2,3]','[2,3]');
insert into t1 values(7,'[-1,2,2]','[-3,2,3]','[4,3]');
insert into t1 values(8,'[-1,-2,-2]','[-4,2,3]',null);
CREATE VECTOR INDEX vector_idx ON t1 (c3)  WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=200, ef_search=40);

select l2_distance(c3,'[1,2.2,3]') ld_c3,l2_distance(c4,'[1,1.3]') ld_c4 from t1 where l2_distance(c3,c3) =0  order by l2_distance(c3, [1,2,3]) approximate limit 10;
select l2_distance(c3,'[1,2.2,3]') ld_c3,l2_distance(c4,'[1,1.3]') ld_c4 from t1 where l2_distance(c3,[1,2,3]) =0  order by l2_distance(c3, [1,2,3]) approximate limit 10;
select l2_distance(c3,'[1,2.2,3]') ld_c3,l2_distance(c4,'[1,1.3]') ld_c4 from t1 where l2_distance(c3,c2) > 1  order by l2_distance(c3, [1,2,3]) approximate limit 10;
select l2_distance(c3,'[1,2.2,3]') ld_c3,l2_distance(c4,'[1,1.3]') ld_c4 from t1 where l2_distance(c3,[1,2,3]) > 1  order by l2_distance(c3, [1,2,3]) approximate limit 10;
select l2_distance(c3,'[1,2.2,3]') ld_c3,l2_distance(c4,'[1,1.3]') ld_c4 from t1 where l2_distance(c3,c2) < 1  order by l2_distance(c3, [1,2,3]) approximate limit 10;
select l2_distance(c3,'[1,2.2,3]') ld_c3,l2_distance(c4,'[1,1.3]') ld_c4 from t1 where l2_distance(c3,[1,2,3]) < 1  order by l2_distance(c3, [1,2,3]) approximate limit 10;


select l2_distance(c3,'[1,2.2,3]') ld_c3,l2_distance(c4,'[1,1.3]') ld_c4 from t1 where l2_distance(c3,c3) =0  order by l2_distance(c3, [1,2,3])  limit 10;
select l2_distance(c3,'[1,2.2,3]') ld_c3,l2_distance(c4,'[1,1.3]') ld_c4 from t1 where l2_distance(c3,[1,2,3]) =0  order by l2_distance(c3, [1,2,3])  limit 10;
select l2_distance(c3,'[1,2.2,3]') ld_c3,l2_distance(c4,'[1,1.3]') ld_c4 from t1 where l2_distance(c3,c2) > 1  order by l2_distance(c3, [1,2,3])  limit 10;
select l2_distance(c3,'[1,2.2,3]') ld_c3,l2_distance(c4,'[1,1.3]') ld_c4 from t1 where l2_distance(c3,[1,2,3]) > 1  order by l2_distance(c3, [1,2,3])  limit 10;
select l2_distance(c3,'[1,2.2,3]') ld_c3,l2_distance(c4,'[1,1.3]') ld_c4 from t1 where l2_distance(c3,c2) < 1  order by l2_distance(c3, [1,2,3])  limit 10;
select l2_distance(c3,'[1,2.2,3]') ld_c3,l2_distance(c4,'[1,1.3]') ld_c4 from t1 where l2_distance(c3,[1,2,3]) < 1  order by l2_distance(c3, [1,2,3])  limit 10;


##limit后多个参数
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int primary key, c2 vector(3),c3 vector(3) ,c4 vector(3),
VECTOR INDEX vector_idx(c3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
insert into t1(c1,c2,c3,c4) values(1,'[1,1,2]','[2,2,3]','[1,3,2]');
insert into t1(c1,c2,c3,c4) values(2,'[1,0,3]','[1,0,3]','[2,3,2]');
insert into t1(c1,c2,c3,c4) values(3,'[-1,2,2]','[-3,2,3]','[4,3,3]');
select * from t1 order by l2_distance(c3, [1,2,3]);
select * from t1 order by l2_distance(c3, [1,2,3])  limit 1,1;
select * from t1 order by l2_distance(c3, [1,2,3]) approximate limit 1,1;


##order by中使用聚合函数
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int primary key, c2 varchar(30),c3 vector(3) ,c4 vector(3),
VECTOR INDEX vector_idx(c3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40))PARTITION BY KEY(c1) PARTITIONS 4;
insert into t1(c1,c2,c3,c4) values(1,'[1,1,2]','[2,2,3]','[1,3,2]');
insert into t1(c1,c2,c3,c4) values(2,'[1,0,3]','[1,0,3]','[2,3,2]');
insert into t1(c1,c2,c3,c4) values(3,'[-1,2,2]','[-3,2,3]','[4,3,3]');
insert into t1(c1,c2,c3,c4) values(4,'[-1,-2,-2]','[-4,2,3]',null);
insert into t1(c1,c2,c3,c4) values(5,'[-1,-2,-2]',null,'[2,3,1]');
--error 1235
select * from t1 order by l2_distance(avg(c3), [1,2,3]) approximate limit 1;
--error 1235
select * from t1 order by l2_distance(sum(c3), [1,2,3]) approximate limit 1;
select * from t1 order by l2_distance(avg(c3), [1,2,3])  limit 1;
select * from t1 order by l2_distance(sum(c3), [1,2,3])  limit 1;

####查询聚合函数列
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int primary key, c2 vector(3),c3 vector(3) ,c4 vector(3),
VECTOR INDEX vector_idx(c3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
insert into t1 values(1,'[1,1,2]','[2,2,3]','[1,3,2]');
insert into t1 values(2,'[1,0,3]','[1,0,3]','[2,3,2]');
insert into t1 values(3,'[-1,2,2]','[-3,2,3]','[4,3,3]');

SELECT avg(c2) FROM T1 order by l2_distance(c3, [1,1,-1]);
SELECT avg(c2) FROM T1 order by l2_distance(c3, [1,1,-1])  limit 1;
SELECT avg(c2) FROM T1 order by l2_distance(c3, [1,1,-1]) approximate limit 1;
##explain SELECT avg(c2) FROM T1 order by l2_distance(c3, [1,1,-1]) approximate limit 1;

SELECT sum(c2) FROM T1 order by l2_distance(c3, [1,1,-1]);
SELECT sum(c2) FROM T1 order by l2_distance(c3, [1,1,-1])  limit 1;
SELECT sum(c2) FROM T1 order by l2_distance(c3, [1,1,-1]) approximate limit 1;

SELECT c2 FROM T1 order by l2_distance(c3, [1,1,-1]);
SELECT c2 FROM T1 order by l2_distance(c3, [1,1,-1])  limit 1;
SELECT c2 FROM T1 order by l2_distance(c3, [1,1,-1]) approximate limit 1;

##case when
--disable_warnings
drop table if exists t1;
drop table if exists t2;
drop table if exists tt1;
--enable_warnings

CREATE TABLE t1 (c1 int primary key, c2 varchar(30),c3 vector(3) ,c4 vector(3),
VECTOR INDEX vector_idx(c3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40))PARTITION BY KEY(c1) PARTITIONS 4;
insert into t1(c1,c2,c3,c4) values(1,'[1,1,2]','[2,2,3]','[1,3,2]');
insert into t1(c1,c2,c3,c4) values(2,'[1,0,3]','[1,0,3]','[2,3,2]');
insert into t1(c1,c2,c3,c4) values(3,'[-1,2,2]','[-3,2,3]','[4,3,3]');
insert into t1(c1,c2,c3,c4) values(4,'[-1,-2,-2]','[-4,2,3]',null);
insert into t1(c1,c2,c3,c4) values(5,'[-1,-2,-2]',null,'[2,3,-1]');
drop table if exists t2;
CREATE TABLE t2 (a1 int , a2 vector(3),a3 vector(3) ,a4 vector(3),
VECTOR INDEX vector_idx(a3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
insert into t2 select c1,c2,c3,c4 from t1; 

SELECT sum(c2+c3), CASE WHEN (SELECT sum(c2+c3) FROM t1 where c3 is not null order by l2_distance(c3, [1,1,-1]) approximate limit 1) = [2,0,6] THEN 'High' ELSE 'Low' END AS A FROM T1 order by l2_distance(c3, [1,1,-1]) approximate limit 1;


SELECT sum(c2+c3), CASE WHEN (SELECT sum(c2+c3) FROM t1 order by l2_distance(c3, [1,1,-1]) approximate limit 1) is  null THEN (select l2_distance(c3, [1,1,-1]) from t1 order by l2_distance(c3, [1,1,-1]) approximate limit 1) ELSE (select l2_distance(c2, [1,1,-1]) from t1 order by l2_distance(c3, [1,1,-1]) approximate limit 1) END AS A FROM T1 order by l2_distance(c3, [1,1,-1]) approximate limit 1;


SELECT sum(c2+c3), CASE WHEN (SELECT sum(c2+c3) FROM t1 order by l2_distance(c3, [1,1,-1])  limit 1) is  null THEN (select l2_distance(c3, [1,1,-1]) from t1 order by l2_distance(c3, [1,1,-1])  limit 1) ELSE (select l2_distance(c2, [1,1,-1]) from t1 order by l2_distance(c3, [1,1,-1])  limit 1) END AS A FROM T1 order by l2_distance(c3, [1,1,-1])  limit 1;

##hint使用
--disable_warnings
drop table if exists t1;
drop table if exists t2;
--enable_warnings


CREATE TABLE t1 (c1 int primary key, c2 vector(3),c3 vector(3) ,c4 vector(3),
VECTOR INDEX vector_idx(c3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40))PARTITION BY KEY(c1) PARTITIONS 4;
insert into t1(c1,c2,c3,c4) values(1,'[1,1,2]','[2,2,3]','[1,3,2]');
insert into t1(c1,c2,c3,c4) values(2,'[1,0,3]','[1,0,3]','[2,3,2]');
insert into t1(c1,c2,c3,c4) values(3,'[-1,2,2]','[-3,2,3]','[4,3,3]');
insert into t1(c1,c2,c3,c4) values(4,'[-1,-2,-2]','[-4,2,3]',null);
insert into t1(c1,c2,c3,c4) values(5,'[-1,-2,-2]',null,'[2,3,-1]');
drop table if exists t2;
CREATE TABLE t2 (a1 int , a2 vector(3),a3 vector(3) ,a4 vector(3),
VECTOR INDEX vector_idx(a3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
insert into t2 select c1,c2,c3,c4 from t1;
select l2_distance(c3,'[1,2.2,3]') ld_c3,* from t1,t2 where l2_distance(c3,[1,3,1]) = 1  order by l2_distance(c3, [1,1,-1]) approximate limit 1;
select /*+PARALLEL(8)*/l2_distance(c3,'[1,2.2,3]') ld_c3 from t1,t2   order by l2_distance(c3, [1,1,-1]) approximate limit 1;
select l2_distance(c3,'[1,2.2,3]') ld_c3 from t1,t2   order by l2_distance(c3, [1,1,-1]) approximate limit 1;
select /*+PARALLEL(8)*/l2_distance(c3,'[1,2.2,3]') ld_c3,* from t1,t2 where l2_distance(c3,[1,3,1]) = 1  order by l2_distance(c3, [1,1,-1]) approximate limit 1;
select l2_distance(c3,'[1,2.2,3]') ld_c3,* from t1,t2 where l2_distance(c3,[1,3,1]) = 1  order by l2_distance(c3, [1,1,-1]) approximate limit 1;
select /*+index(t1 vector_idx)*/l2_distance(c3,'[1,2.2,3]') ld_c3,l2_distance(c4,'[1,1.456,2]') ld_c4 from t1,t2 where l2_distance(c3,[1,3,1]) != 1  order by l2_distance(c3, [1,1,-1]) approximate limit 1;
select /*+PARALLEL(100)*/l2_distance(c4,'[1,1.456,2]')  from t1,t2 where c3 is not null and a3 is not null  order by l2_distance(c3, [1,1,-1]) approximate limit 1;
select /*+index(t1 vector_idx)*/l2_distance(c3,'[1,2.2,3]') ld_c3,l2_distance(c4,'[1,1.456,2]') ld_c4 from t1 where l2_distance(c3,[1,3,1]) != 1;
select /*+index(t1 vector_idx)*/l2_distance(c3,'[1,2.2,3]') ld_c3,l2_distance(c4,'[1,1.456,2]') ld_c4 from t1 where l2_distance(c3,[1,3,1]) != 1  order by l2_distance(c3, [1,1,-1]) approximate limit 1;


select /*+PARALLEL(100)*/l2_distance(c3,'[1,2.2,3]') ld_c3,l2_distance(c4,'[1,1.456,2]') ld_c4 from t1 where l2_distance(c3,[1,3,1]) != 1  order by l2_distance(c3, [1,1,-1]) approximate limit 1;
select l2_distance(c3,'[1,2.2,3]') ld_c3,l2_distance(c4,'[1,1.456,2]') ld_c4 from t1 where l2_distance(c3,[1,3,1]) != 1  order by l2_distance(c3, [1,1,-1]) approximate limit 1;


##物化视图连接普通表
--disable_warnings
drop table if exists t1;
drop table if exists t2;
drop materialized view if exists mv1;
--enable_warnings

CREATE TABLE t1 (c1 int primary key, c2 vector(3),c3 vector(3) ,c4 vector(3),
VECTOR INDEX vector_idx(c3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40))PARTITION BY KEY(c1) PARTITIONS 4;
call dbms_vector.refresh_index('vector_idx', 't1', 'c3', 1, 'FAST');
insert into t1(c1,c2,c3,c4) values(1,'[1,1,2]','[2,2,3]','[1,3,2]');
insert into t1(c1,c2,c3,c4) values(2,'[1,0,3]','[1,0,3]','[2,3,2]');
insert into t1(c1,c2,c3,c4) values(3,'[-1,2,2]','[-3,2,3]','[4,3,3]');
insert into t1(c1,c2,c3,c4) values(4,'[-1,-2,-2]','[-4,2,3]',null);
insert into t1(c1,c2,c3,c4) values(5,'[-1,-2,-2]',null,'[2,3,-1]');
create materialized view mv1(a1,a2,a3,a4,primary key (a1))  parallel 2 refresh complete on demand  as select * from t1;
select l2_distance(c3,'[1,2.2,3]') ld_c3,* from t1,mv1 where l2_distance(c3,[1,3,1]) != 1  order by l2_distance(c3, [1,1,-1]) approximate limit 1;
select l2_distance(c3,'[1,2.2,3]') ld_c3,* from t1,mv1 where l2_distance(c3,[1,3,1]) != 1  order by l2_distance(c3, [1,1,-1])  limit 1;


##多表join
--disable_warnings
drop table if exists t1;
drop table if exists t2;
drop materialized view if exists mv1;
--enable_warnings
CREATE TABLE t1 (c1 int primary key, c2 varchar(30),c3 vector(3) ,c4 vector(3),
VECTOR INDEX vector_idx(c3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
insert into t1(c1,c2,c3,c4) values(1,'[1,1,2]','[2,2,3]','[1,3,2]');
insert into t1(c1,c2,c3,c4) values(2,'[1,0,3]','[1,0,3]','[2,3,2]');
insert into t1(c1,c2,c3,c4) values(3,'[-1,2,2]','[-3,2,3]','[4,3,3]');
--disable_warnings
drop table if exists t2;
--enable_warnings
CREATE TABLE t2 (a1 int , a2 vector(3),a3 vector(3) ,a4 vector(3),
VECTOR INDEX vector_idx(a3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
insert into t2 select c1,c2,c3,c4 from t1;

select * from t1,t2 where c3=a3 order by l2_distance(c3, [1,2,3]) APPROX limit 10;
select * from t1 a join t2 b on c3=a3 order by l2_distance(c3, [1,2,3]) APPROX limit 10;
select * from t1 a join t2 b on c2=a2 order by l2_distance(c3, [1,2,3]) APPROX limit 10;
##explain select * from t1 a join t2 b on c2=a2 order by l2_distance(c3, [1,2,3]) APPROX limit 10;

select * from t1,t2 where c3=a3 order by l2_distance(c3, [1,2,3])  limit 10;
select * from t1 a join t2 b on c3=a3 order by l2_distance(c3, [1,2,3])  limit 10;
select * from t1 a join t2 b on c2=a2 order by l2_distance(c3, [1,2,3])  limit 10;
##explain select * from t1 a join t2 b on c2=a2 order by l2_distance(c3, [1,2,3])  limit 10;

select * from t1 join t2 on l2_distance(c2,c3)=l2_distance(a3,a2) order by l2_distance(c3, [1,2,3]) APPROX limit 10;
select * from t1 join t2 on l2_distance(c2,c3)=l2_distance(a3,a2) order by l2_distance(c3, [1,2,3])  limit 10;



##查询非索引列
--disable_warnings
drop table if exists t1;
drop table if exists t2;
--enable_warnings
CREATE TABLE t1 (c1 int primary key, c2 vector(3),c3 vector(3) ,c4 vector(3),
VECTOR INDEX vector_idx(c3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40))PARTITION BY KEY(c1) PARTITIONS 4;
insert into t1(c1,c2,c3,c4) values(1,'[1,1,2]','[2,2,3]','[1,3,2]');
insert into t1(c1,c2,c3,c4) values(2,'[1,0,3]','[1,0,3]','[2,3,2]');
insert into t1(c1,c2,c3,c4) values(3,'[-1,2,2]','[-3,2,3]','[4,3,3]');
insert into t1(c1,c2,c3,c4) values(4,'[-1,-2,-2]','[-4,2,3]',null);
insert into t1(c1,c2,c3,c4) values(5,'[-1,-2,-2]',null,'[2,3,-1]');
drop table if exists t2;
CREATE TABLE t2 (a1 int , a2 vector(3),a3 vector(3) ,a4 vector(3),
VECTOR INDEX vector_idx(a3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
insert into t2 select c1,c2,c3,c4 from t1;

select l2_distance(c4,'[1,1.456,2]')  from t1,t2 where c3 is not null and a3 is not null  order by l2_distance(c3, [1,1,-1]) approximate limit 1;

select l2_distance(c3,'[1,1.456,2]')  from t1,t2 where c4 is not null and a4 is not null order by l2_distance(c3, [1,1,-1])  limit 1;
select l2_distance(c4,'[1,1.456,2]')  from t1,t2 where c4 is not null and a4 is not null order by l2_distance(c3, [1,1,-1])  limit 1;

select l2_distance(c3,'[1,1.456,2]')  from t1,t2 where c4 is not null and a4 is not null order by l2_distance(c3, [1,1,-1]) APPROX limit 1;
select l2_distance(c4,'[1,1.456,2]')  from t1,t2 where c4 is not null and a4 is not null order by l2_distance(c3, [1,1,-1]) APPROX limit 1;

