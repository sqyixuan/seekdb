--disable_warnings
drop table if exists t2;
--enable_warnings
CREATE TABLE t2 (a1 int , a2 vector(3),a3 vector(3) ,a4 vector(3));
insert into t2 select c1,c2,c3,c4 from t1; 
select * from t1 join t2 on c3=a3 order by l2_distance(c3, [1,2,3]) APPROX limit 10;
create VECTOR INDEX vector_idx on t2(a3)  WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40);
select * from t1 join t2 on c3=a3 order by l2_distance(c3, [1,2,3]) APPROX limit 10;
select * from t1 join t2 on c3=a2 order by l2_distance(c3, [1,2,3]) APPROX limit 10;

select * from t1 join t2 on c3=a3 order by l2_distance(c3, [1,2,3])  limit 10;
select * from t1 join t2 on c3=a2 order by l2_distance(c3, [1,2,3])  limit 10;

##WITH AS
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int primary key, c2 vector(3),c3 vector(3) ,c4 vector(3),
VECTOR INDEX vector_idx(c3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
insert into t1 values(1,'[1,1,2]','[2,2,3]','[1,3,2]');
insert into t1 values(2,'[1,0,3]','[1,0,3]','[2,3,2]');
insert into t1 values(3,'[-1,2,2]','[-3,2,3]','[4,3,3]');


--disable_warnings
drop table if exists t2;
--enable_warnings
CREATE TABLE t2 (a1 int , a2 vector(3),a3 vector(3) ,a4 vector(3),
VECTOR INDEX vector_idx(a3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
insert into t2 select c1,c2,c3,c4 from t1; 

with ct1 AS(select c2 from t1 order by c1) select c2 from t1 where c1 >2 order by l2_distance(c3, [1,2,3]) APPROX limit 10;
with ct1 as(select l2_distance(c2,c3) from t1 order by c1)select l2_distance(c2,c3) from t1 where c3 is not null order by l2_distance(c3, [1,2,3]) APPROX limit 10;
with ct1 as(select l2_distance(c2,c3) from t1 order by c1)select l2_distance(c2,c3) from t1 join t2 on l2_distance(c2,c3)=l2_distance(a3,a4) order by l2_distance(c3, [1,2,3]) APPROX limit 10;
with ct1 as(select l2_distance(c2,[1,2,3]) from t1 order by c1)select l2_distance(c2,c3) from t1 join t2 on l2_distance(c2,c3)=l2_distance(a3,a4) order by l2_distance(c3, [1,2,3]) APPROX limit 10;
with CTE1 as(select l2_distance(c2,c3) a from t1 order by l2_distance(C3, [1,2,3]) APPROX limit 10),CTE2 AS (SELECT l2_distance(a2,a3) b from t2 order by l2_distance(A3, [1,2,3]) APPROX limit 10)select * from CTE1,CTE2  where a =0 ;

with ct1 AS(select c2 from t1 order by c1) select c2 from t1 where c1 >2 order by l2_distance(c3, [1,2,3])  limit 10;
with ct1 as(select l2_distance(c2,c3) from t1 order by c1)select l2_distance(c2,c3) from t1 where c3 is not null order by l2_distance(c3, [1,2,3])  limit 10;
with ct1 as(select l2_distance(c2,c3) from t1 order by c1)select l2_distance(c2,c3) from t1 join t2 on l2_distance(c2,c3)=l2_distance(a3,a4) order by l2_distance(c3, [1,2,3])  limit 10;
with ct1 as(select l2_distance(c2,[1,2,3]) from t1 order by c1)select l2_distance(c2,c3) from t1 join t2 on l2_distance(c2,c3)=l2_distance(a3,a4) order by l2_distance(c3, [1,2,3])  limit 10;
with CTE1 as(select l2_distance(c2,c3) a from t1 order by l2_distance(C3, [1,2,3])  limit 10),CTE2 AS (SELECT l2_distance(a2,a3) b from t2 order by l2_distance(A3, [1,2,3])  limit 10)select * from CTE1,CTE2  where a =0 ;




##窗口函数使用
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int primary key, c2 vector(3),c3 vector(3) ,c4 vector(3),
VECTOR INDEX vector_idx(c3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
insert into t1 values(1,'[1,1,2]','[2,2,3]','[1,3,2]');
insert into t1 values(2,'[1,0,3]','[1,0,3]','[2,3,2]');
insert into t1 values(3,'[-1,2,2]','[-3,2,3]','[4,3,3]');
--error 1054
SELECT * FROM t1 JOIN t2 USING(c1) order by l2_distance(T1.c3, [1,2,3]) APPROX limit 10;
SELECT avg(C2) OVER (PARTITION BY c1 ORDER BY c2) FROM T1  order by l2_distance(c3, [1,2,3]) APPROX limit 10;
SELECT sum(C2) OVER (PARTITION BY c1 ORDER BY c2) FROM T1  order by l2_distance(c3, [1,2,3]) APPROX limit 10;
SELECT count(C2) OVER (PARTITION BY c1 ORDER BY c2) FROM T1  order by l2_distance(c3, [1,2,3]) APPROX limit 10;
--error 1054
SELECT * FROM t1 JOIN t2 USING(c1) order by l2_distance(T1.c3, [1,2,3])  limit 10;
SELECT avg(C2) OVER (PARTITION BY c1 ORDER BY c2) FROM T1  order by l2_distance(c3, [1,2,3])  limit 10;
SELECT sum(C2) OVER (PARTITION BY c1 ORDER BY c2) FROM T1  order by l2_distance(c3, [1,2,3])  limit 10;
SELECT count(C2) OVER (PARTITION BY c1 ORDER BY c2) FROM T1  order by l2_distance(c3, [1,2,3])  limit 10;


SELECT avg(C2+[1,2,3]) OVER (PARTITION BY c1 ORDER BY sum(c2)) FROM T1  order by l2_distance(c3, [1,2,3]) APPROX limit 10;
SELECT sum(C2+c3) OVER (PARTITION BY c1 ORDER BY sum(c2)) FROM T1  order by l2_distance(c3, [1,2,3]) APPROX limit 10;
SELECT count(C2+c2) OVER (PARTITION BY c1 ORDER BY sum(c2)) FROM T1  order by l2_distance(c3, [1,2,3]) APPROX limit 10;

SELECT avg(C2+[1,2,3]) OVER (PARTITION BY c1 ORDER BY sum(c2)) FROM T1  order by l2_distance(c3, [1,2,3])  limit 10;
SELECT sum(C2+c3) OVER (PARTITION BY c1 ORDER BY sum(c2)) FROM T1  order by l2_distance(c3, [1,2,3])  limit 10;
SELECT count(C2+c2) OVER (PARTITION BY c1 ORDER BY sum(c2)) FROM T1  order by l2_distance(c3, [1,2,3])  limit 10;

SELECT c1, c3, avg_c3, avg_c2 FROM( SELECT c1, c3, avg_c2, avg(c3) OVER (PARTITION BY c1) AS avg_c3 FROM (SELECT c1, c3, avg(c2) as avg_c2 FROM (SELECT c1, c2, c3 FROM t1 order by l2_distance(c3, [1,2,3]) APPROX limit 1) v GROUP BY c1, c3) v2) v3 order by l2_distance(c3, [1,2,3]) APPROX limit 1;





###dml操作结合关键字
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int , c2 vector(3),c3 vector(3) ,c4 vector(3),
VECTOR INDEX vector_idx(c3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
insert into t1(c1,c2,c3,c4) values(l2_distance([1,2,3],[1,2,100]),[-1,-3,-2],[2,3,1],[2,3,1]);
insert into t1(c1,c2,c3,c4) values(l2_distance([1,2,3],[1,2,102]),[-1,-3,-2],null,[2,3,1]);
insert into t1(c1,c2,c3,c4) select 100,c2,c3,c4 from t1 where c3 is not null order by l2_distance(c3, [1,2,3]) APPROX limit 1;
insert into t1(c1,c2,c3,c4) select c1,c2,c3,c4 from t1 where c3 is not null order by l2_distance(c3, [1,2,3]) APPROX limit 1;
replace into t1(c1,c2,c3,c4) select c1,c2,c3,c4 from t1 where c3 is not null order by l2_distance(c3, [1,2,3]) APPROX limit 1;
select * from t1 order by c1;
--error 1064
update t1 set c1 =101 where c3 is not null order by l2_distance(c3, [1,2,3]) APPROX limit 1;
--error 1064
delete from t1 where c3 is not null order by l2_distance(c3, [1,2,3]) APPROX limit 1;
select * from t1 order by c1;

SELECT c2+c3 FROM T1 order by l2_distance(c3, [1,1,-1]);
SELECT c2+c3 FROM T1 order by l2_distance(c3, [1,1,-1])  limit 1;
SELECT c2+c3 FROM T1 order by l2_distance(c3, [1,1,-1]) approximate limit 1;
select c1,c2,l2_distance(c3,c2),count(c2) from t1 where c3 is not null order by l2_distance(c3, [1,2,3]) APPROX limit 10;
select c1,c2,l2_distance(c3,c2),avg(c2) from t1 where c3 is not null order by l2_distance(c3, [1,2,3]) APPROX limit 10;
select c1,c2,l2_distance(c3,c2),sum(c2) from t1 where c3 is not null order by l2_distance(c3, [1,2,3]) APPROX limit 10;
select  l2_distance(c2, c3) from t1 where c3 is not null order by l2_distance(c3, [1,2,3]) APPROX limit 10;
select c1,c2,l2_distance(c3,c2) from t1 where c3 is not null order by l2_distance(c3, [1,2,3]) APPROX limit 10;

select c1,c2,l2_distance(c3,c2),count(c2) from t1 where c3 is not null order by l2_distance(c3, [1,2,3])  limit 10;
select c1,c2,l2_distance(c3,c2),avg(c2) from t1 where c3 is not null order by l2_distance(c3, [1,2,3])  limit 10;
select c1,c2,l2_distance(c3,c2),sum(c2) from t1 where c3 is not null order by l2_distance(c3, [1,2,3])  limit 10;
select  l2_distance(c2, c3) from t1 where c3 is not null order by l2_distance(c3, [1,2,3])  limit 10;
select c1,c2,l2_distance(c3,c2) from t1 where c3 is not null order by l2_distance(c3, [1,2,3])  limit 10;
