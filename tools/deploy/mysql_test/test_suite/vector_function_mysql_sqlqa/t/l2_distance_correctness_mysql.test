##创建多个索引名
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int primary key, c2 VARCHAR(30),c3 vector(3) ,c4 vector(2),
VECTOR INDEX vector_idx1(c3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40),
VECTOR INDEX vector_idx2(c4) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40)
);
insert into t1 values(1,'[1,1,2]','[2,2,3]','[1,3]');
insert into t1 values(2,'[1,2,3]','[1,2,3]','[2,3]');
insert into t1 values(3,'[-1,2,2]','[-3,2,3]','[2,3]');
insert into t1 values(4,'[-1,-2,-2]','[-4,2,3]','[2,3]');
insert into t1 values(5,'[-1,-2,-2]','[-4,2,3]','[2,3]');
insert into t1 values(6,'[1,1,2]','[2,2,3]','[1,3]');
insert into t1 values(7,'[1,2,3]','[1,2,3]','[2,3]');
insert into t1 values(8,'[-1,2,2]','[-3,2,3]','[4,3]');
insert into t1 values(9,'[-1,-2,-2]','[-4,2,3]','[2,3]');
insert into t1 values(10,'[-1,-2,-2]','[-4,2,3]','[2,3]');

SELECT * FROM t1 ORDER BY l2_distance(c3, [1,1, 1]) APPROXIMATE LIMIT 10;
SELECT * FROM t1 ORDER BY l2_distance(c3, [1,1, 1])  LIMIT 10;

SELECT CASE  WHEN 8 !=(SELECT COUNT(*) FROM ( SELECT * FROM t1 ORDER BY l2_distance(c3, [1,8, 30]) APPROXIMATE LIMIT 8) AS tmp1 JOIN(SELECT * FROM t1  ORDER BY l2_distance(c3, [1,8, 30]) LIMIT 8) AS tmp2  ON tmp1.c3 = tmp2.c3) THEN '有问题' ELSE '没问题'END AS result;



