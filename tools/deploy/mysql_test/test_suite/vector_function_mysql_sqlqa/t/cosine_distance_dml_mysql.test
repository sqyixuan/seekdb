select c1 a,cosine_distance(c3,'[1,3,-5]') a  from t1 order by c1;
select c1 a,cosine_distance(c3,'[1,3,-5]') a,cosine_distance(c3,'[1,3,-5]') a  from t1 order by c1;
select cosine_distance('[-1.5,3.5,-2]',c2)  a  from t1 order by c1;
select cosine_distance('[-1.5,3.5,0]',c2)  a ,* from t1 order by c1;
select cosine_distance(c3,[-1.5,3.5,0])  中文 ,* from t1 order by c1;
select cosine_distance(c3,'[-1.5,3.5,0]') + cosine_distance(c3,c2) - cosine_distance('[-1.5,3.5,0]',c2)  中文 ,cosine_distance(c3,c2) + cosine_distance(c3,'[-1.5,3.5,0]') - cosine_distance(c3,'[-1.5,3.5,0]') 中文 from t1 order by c1;
select cosine_distance('[-1.5,3.5,0]',c2) + cosine_distance('[-1.5,3.5,0]',c2) - cosine_distance(c3,'[-1.5,3.5,0]')  a ,cosine_distance(c3,c2) + cosine_distance(c3,c2) - cosine_distance('[-1.5,3.5,0]',c2) b from t1 order by c1;


