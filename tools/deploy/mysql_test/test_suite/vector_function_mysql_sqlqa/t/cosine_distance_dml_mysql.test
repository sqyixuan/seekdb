cosine_distance(c3,c3) is null or cosine_distance(c3,c3) is null or cosine_distance(c3,c3) is null or cosine_distance(c3,c3) is null or cosine_distance(c3,c3) is null or cosine_distance(c3,c3) is null or cosine_distance(c3,c3) is null or cosine_distance(c3,c3) is null or cosine_distance(c3,c3) is null or cosine_distance(c3,c3)
 is null order by c1;
select cosine_distance(c3,'[1,2.2,3]') ld_c3,cosine_distance(c4,'[1,1.3,-1]') ld_c4 from t1 where cosine_distance(c3,'[1,2,3]') > 0 or cosine_distance(c3,c3) is null  and c1 >3 order by c1;



--echo ##between and
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int primary key, c2 VARCHAR(30),c3 vector(3) ,c4 vector(2),
VECTOR INDEX vector_idx(c3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
insert into t1 values(1,'[1,1,2]','[2,2,3]','[1,3]');
insert into t1 values(2,'[1,2,3]','[1,2,3]','[2,3]');
insert into t1 values(3,'[-1,2,2]','[-3,2,3]','[4,3]');
insert into t1 values(4,'[-1,-2,-2]','[-4,2,3]',null);
insert into t1 values(5,'[-1,-2,-2]',null,'[2,3]');

select  * from t1 where 1 BETWEEN cosine_distance(c3,c3)  and cosine_distance(c3,'[1,2,3]') order by cosine_distance(c3, [1,2,3])  limit 10;
select  * from t1 where 1 BETWEEN cosine_distance(c3,c3)  and cosine_distance(c3,'[1,2,3]') order by l2_distance(c3, [1,2,3]) approximate limit 10;

select  cosine_distance(c3,'[1,2.2,3]') BETWEEN cosine_distance(c3,c3)  and cosine_distance(c3,'[1,2,3]') from t1 order by cosine_distance(c3, [1,2,3])  limit 10;
select  cosine_distance(c3,'[1,2.2,3]') BETWEEN cosine_distance(c3,c3)  and cosine_distance(c3,'[1,2,3]') from t1 order by l2_distance(c3, [1,2,3]) approximate limit 10;

select  cosine_distance(c3,'[1,2.2,3]') BETWEEN cosine_distance(c3,c3)  and cosine_distance(c3,'[1,2,3]') from t1 where cosine_distance(c3,'[1,2.2,3]') BETWEEN cosine_distance(c3,c3)  and cosine_distance(c3,'[1,2,3]') >1;




--echo ##like/not like
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int primary key, c2 VARCHAR(30),c3 vector(3) ,c4 vector(2),
VECTOR INDEX vector_idx(c3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
insert into t1 values(1,'[1,1,2]','[2,2,3]','[1,3]');
insert into t1 values(2,'[1,0,3]','[1,0,3]','[2,3]');
insert into t1 values(3,'[-1,2,2]','[-3,2,3]','[4,3]');
insert into t1 values(4,'[-1,-2,-2]','[-4,2,3]',null);
insert into t1 values(5,'[-1,-3,-2]',null,'[2,3]');

select  * from t1 where cosine_distance(c3,c3) like '%0%' order by cosine_distance(c3, [1,2,3])  limit 10;
select  * from t1 where cosine_distance(c3,c3) like cosine_distance(c3,c2) order by l2_distance(c3, [1,2,3]) approximate limit 10;

select  * from t1 where cosine_distance(c3,c3) not like '%1%' order by c1;
select  * from t1 where cosine_distance(c3,c3) not like cosine_distance(c3,c2) order by c1;


--echo ##exists,any,all,in(无关键字)
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int primary key, c2 VARCHAR(30),c3 vector(3) ,c4 vector(3),
VECTOR INDEX vector_idx(c3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
insert into t1 values(1,'[1,1,2]','[2,2,3]','[1,3,2]');
insert into t1 values(2,'[1,0,3]','[1,0,3]','[2,3,2]');
insert into t1 values(3,'[-1,2,2]','[-3,2,3]','[4,3,3]');
insert into t1 values(4,'[-1,-2,-2]','[-4,2,3]',null);
insert into t1 values(5,'[-1,-3,-2]',null,'[2,3,1]');

SELECT cosine_distance(c3,c4) from t1 where  EXISTS (SELECT cosine_distance(c3,[1,null,1]) FROM t1) order by c1;
SELECT c3 from t1 where  EXISTS (SELECT c3 FROM t1) order by c1;
SELECT cosine_distance(c3,c4) from t1 where cosine_distance(c3,c3) = any (SELECT cosine_distance(c3,[1,-1,1]) FROM t1) order by c1;
SELECT cosine_distance(c3,c4) from t1 where cosine_distance(c3,c3) >= any (SELECT cosine_distance(c3,[1,-1,1]) FROM t1) order by c1;
SELECT cosine_distance(c3,c4) from t1 where cosine_distance(c3,c3) <= any (SELECT cosine_distance(c3,[1,-1,1]) FROM t1) order by c1;
SELECT cosine_distance(c3,c4) from t1 where cosine_distance(c3,c3) <> any (SELECT cosine_distance(c3,[1,-1,1]) FROM t1) order by c1;
SELECT cosine_distance(c3,c4) from t1 where cosine_distance(c3,c3) != any (SELECT cosine_distance(c3,[1,-1,1]) FROM t1) order by c1;
SELECT cosine_distance(c3,c4) from t1 where cosine_distance(c3,c3) > any (SELECT cosine_distance(c3,[1,-1,1]) FROM t1) order by c1;
SELECT cosine_distance(c3,c4) from t1 where cosine_distance(c3,c3) < any (SELECT cosine_distance(c3,[1,-1,1]) FROM t1) order by c1;


SELECT cosine_distance(c3,c4) from t1 where  EXISTS (SELECT cosine_distance(c3,c3) FROM t1) order by c1;
SELECT c3 from t1 where  EXISTS (SELECT c3 FROM t1) order by c1;
SELECT cosine_distance(c3,c4) from t1 where cosine_distance(c3,c3) = any (SELECT cosine_distance(c3,c4) FROM t1) order by c1;
SELECT cosine_distance(c3,c4) from t1 where cosine_distance(c3,c3) >= any (SELECT cosine_distance(c3,c4) FROM t1) order by c1;
SELECT cosine_distance(c3,c4) from t1 where cosine_distance(c3,c3) <= any (SELECT cosine_distance(c3,c4) FROM t1) order by c1;
SELECT cosine_distance(c3,c4) from t1 where cosine_distance(c3,c3) <> any (SELECT cosine_distance(c3,c4) FROM t1) order by c1;
SELECT cosine_distance(c3,c4) from t1 where cosine_distance(c3,c3) != any (SELECT cosine_distance(c3,c4) FROM t1) order by c1;
SELECT cosine_distance(c3,c4) from t1 where cosine_distance(c3,c3) > any (SELECT cosine_distance(c3,c4) FROM t1) order by c1;
SELECT cosine_distance(c3,c4) from t1 where cosine_distance(c3,c3) < any (SELECT cosine_distance(c3,c4) FROM t1) order by c1;

SELECT cosine_distance(c3,c4) from t1 where cosine_distance(c3,c4) = all (SELECT cosine_distance(c3,c3) FROM t1) order by c1;
SELECT cosine_distance(c3,c4) from t1 where cosine_distance(c3,c4) >= all (SELECT cosine_distance(c3,c3) FROM t1) order by c1;
SELECT cosine_distance(c3,c4) from t1 where cosine_distance(c3,c4) <= all (SELECT cosine_distance(c3,c3) FROM t1) order by c1;
SELECT cosine_distance(c3,c4) from t1 where cosine_distance(c3,c4) <> all (SELECT cosine_distance(c3,c3) FROM t1) order by c1;
SELECT cosine_distance(c3,c4) from t1 where cosine_distance(c3,c4) != all (SELECT cosine_distance(c3,c3) FROM t1) order by c1;
SELECT cosine_distance(c3,c4) from t1 where cosine_distance(c3,c4) > all (SELECT cosine_distance(c3,c3) FROM t1) order by c1;
SELECT cosine_distance(c3,c4) from t1 where cosine_distance(c3,c4) < all (SELECT cosine_distance(c3,c3) FROM t1) order by c1;

SELECT cosine_distance(c3,c4) from t1 where cosine_distance(c3,c3) in (cosine_distance(c3,c3),cosine_distance(c3,c4)) order by c1;
SELECT cosine_distance(c3,'[1,2,3]') from t1 where cosine_distance(c3,c3) not in (cosine_distance(c3,'[1,2,3]'),cosine_distance(c4,'[1,2,3]')) order by c1;
SELECT cosine_distance(c3,'[1,2,3]') from t1 where cosine_distance(c3,c3) not in (SELECT cosine_distance(c3,'[1,2,3]')FROM t1) order by c1;

--echo ##exists,any,all,in(存在关键字APPROXIMATE|APPROX)
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int primary key, c2 VARCHAR(30),c3 vector(3) ,c4 vector(3),
VECTOR INDEX vector_idx(c3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
insert into t1 values(1,'[1,1,2]','[2,2,3]','[1,3,2]');
insert into t1 values(2,'[1,0,3]','[1,0,3]','[2,3,2]');
insert into t1 values(3,'[-1,2,2]','[-3,2,3]','[4,3,3]');
insert into t1 values(4,'[-1,-2,-2]','[-4,2,3]',null);
insert into t1 values(5,'[-1,-3,-2]',null,'[2,3,1]');
SELECT cosine_distance(c3,c4) from t1 where  EXISTS (SELECT cosine_distance(c3,[1,1,1]) FROM t1 order by cosine_distance(c3, [1,2,3])  limit 10 ) order by c1;

SELECT cosine_distance(c3,c4) from t1 where  EXISTS (SELECT cosine_distance(c3,[1,1,1]) FROM t1 order by l2_distance(c3, [1,2,3]) approximate limit 10 ) order by c1;

##explain SELECT cosine_distance(c3,c4) from t1 where  EXISTS (SELECT cosine_distance(c3,[1,1,1]) FROM t1 order by l2_distance(c3, [1,2,3]) approximate limit 10 ) order by c1;

SELECT c3 from t1 where  EXISTS (SELECT c3 FROM t1 order by l2_distance(c3, [1,2,3]) approximate limit 10 ) order by c1;

SELECT cosine_distance(c3,c4) from t1 where cosine_distance(c3,c3) = any (SELECT cosine_distance(c3,[1,-1,1]) FROM t1 order by l2_distance(c3, [1,2,3]) approximate limit 10) order by c1;
SELECT cosine_distance(c3,c4) from t1 where cosine_distance(c3,c3) >= any (SELECT cosine_distance(c3,[1,-1,1]) FROM t1 order by l2_distance(c3, [1,2,3]) approximate limit 10 ) order by c1;
SELECT cosine_distance(c3,c4) from t1 where cosine_distance(c3,c3) <= any (SELECT cosine_distance(c3,[1,-1,1]) FROM t1 order by l2_distance(c3, [1,2,3]) approximate limit 10 ) order by c1;
SELECT cosine_distance(c3,c4) from t1 where cosine_distance(c3,c3) <> any (SELECT cosine_distance(c3,[1,-1,1]) FROM t1 order by l2_distance(c3, [1,2,3]) approximate limit 10 ) order by c1;
SELECT cosine_distance(c3,c4) from t1 where cosine_distance(c3,c3) != any (SELECT cosine_distance(c3,[1,-1,1]) FROM t1 order by l2_distance(c3, [1,2,3]) approximate limit 10 ) order by c1;
SELECT cosine_distance(c3,c4) from t1 where cosine_distance(c3,c3) > any (SELECT cosine_distance(c3,[1,-1,1]) FROM t1 order by l2_distance(c3, [1,2,3]) approximate limit 10 ) order by c1;
SELECT cosine_distance(c3,c4) from t1 where cosine_distance(c3,c3) < any (SELECT cosine_distance(c3,[1,-1,1]) FROM t1 order by l2_distance(c3, [1,2,3]) approximate limit 10 ) order by c1;


SELECT cosine_distance(c3,c4) from t1 where cosine_distance(c3,c3) in (cosine_distance(c3,c3),cosine_distance(c3,c4)) order by l2_distance(c3, [1,2,3]) approximate limit 10;
SELECT cosine_distance(c3,'[1,2,3]') from t1 where cosine_distance(c3,c3) not in (cosine_distance(c3,'[1,2,3]'),cosine_distance(c4,'[1,2,3]')) order by l2_distance(c3, [1,2,3]) approximate limit 10;
SELECT cosine_distance(c3,'[1,2,3]') from t1 where cosine_distance(c3,c3) not in (SELECT cosine_distance(c3,'[1,2,3]')FROM t1 order by l2_distance(c3, [1,2,3]) approximate limit 10 ) order by c1;

SELECT cosine_distance(c3,'[1,2,3]') from t1 where cosine_distance(c3,c3) not in (cosine_distance(c3,'[1,2,3]'),cosine_distance(c4,'[1,2,3]')) order by l2_distance(c3, [1,2,3])  limit 10;
SELECT cosine_distance(c3,'[1,2,3]') from t1 where cosine_distance(c3,c3) not in (SELECT cosine_distance(c3,'[1,2,3]')FROM t1 where c3 is not null order by l2_distance(c3, [1,2,3])  limit 10 ) order by c1;
SELECT cosine_distance(c3,'[1,2,3]') from t1 where cosine_distance(c3,c3) not in (SELECT cosine_distance(c3,'[1,2,3]')FROM t1 where c3 is not null order by l2_distance(c3, [1,2,3]) approximate limit 10 ) order by c1;


