##INSERT IGNORE
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int AUTO_INCREMENT primary key , c2 vector(3),c3 vector(3) ,c4 BLOB,
VECTOR INDEX vector_idx(c3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
INSERT IGNORE t1(c1) values (cosine_distance([1,2],[2,-1]));
INSERT IGNORE t1(c1) values (cosine_distance([1,2],[2,-1]));
INSERT IGNORE t1(c2) values ([cosine_distance([1,2],[2,-1]),cosine_distance([-1,2],[2,-1]),cosine_distance([-1,2],[-2,-1])]);
INSERT IGNORE t1 values (10,[1,2,3],[2,-1,-1.5],cosine_distance([-1,2],[2,-1]));

select c1,c2,cosine_distance(c2,[2,3,-1.5]),cosine_distance(c2,c3) from t1 order by c1;
