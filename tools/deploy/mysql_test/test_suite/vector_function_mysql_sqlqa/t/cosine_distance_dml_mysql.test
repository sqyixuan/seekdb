#owner: gehao.wh
#owner group: 多模
#description: vector_dml
#tags:vector_dml
#author: wb-ljh01399065
purge recyclebin;
--disable_warnings
drop database IF EXISTS obljh;
--enable_warnings
create database obljh ;
use obljh;
set timestamp = 1600000000;
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;
set ob_default_lob_inrow_threshold = 0;

alter system set ob_vector_memory_limit_percentage =44;
--echo ##where子句
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int AUTO_INCREMENT primary key , c2 vector(3),c3 vector(3) ,c4 BLOB,
VECTOR INDEX vector_idx(c3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
select * from t1 where cosine_distance(null,null);

select * from t1 where cosine_distance([1,1],[1,1]);
select * from t1 where cosine_distance(null,[1]);

--echo ##=,<,<=,>=,<>
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int primary key, c2 VARCHAR(30),c3 vector(3) ,c4 vector(2),
VECTOR INDEX vector_idx(c3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
insert into t1 values(1,'[1,1,2]','[2,2,3]','[1,3]');
insert into t1 values(2,'[1,2,3]','[1,2,3]','[2,3]');
insert into t1 values(3,'[-1,2,2]','[-3,2,3]','[4,3]');
insert into t1 values(4,'[-1,-2,-2]','[-4,2,3]',null);
insert into t1 values(5,'[-1,-2,-2]',null,'[2,3]');
select cosine_distance(c3,'[1,2.2,3]') ld_c3,cosine_distance(c4,'[1,1.3]') ld_c4 from t1 where cosine_distance(c3,c3) =0  order by c1;
select cosine_distance(c3,'[1,2.2,3]') ld_c3,cosine_distance(c4,'[1,1.3]') ld_c4 from t1 where cosine_distance(c3,[1,2,3]) =0  order by c1;
select cosine_distance(c3,'[1,2.2,3]') ld_c3,cosine_distance(c4,'[1,1.3]') ld_c4 from t1 where cosine_distance(c3,c2) > 1  order by c1;
select cosine_distance(c3,'[1,2.2,3]') ld_c3,cosine_distance(c4,'[1,1.3]') ld_c4 from t1 where cosine_distance(c3,[1,2,3]) > 1  order by c1;
select cosine_distance(c3,'[1,2.2,3]') ld_c3,cosine_distance(c4,'[1,1.3]') ld_c4 from t1 where cosine_distance(c3,c2) < 1  order by c1;
select cosine_distance(c3,'[1,2.2,3]') ld_c3,cosine_distance(c4,'[1,1.3]') ld_c4 from t1 where cosine_distance(c3,[1,2,3]) < 1  order by c1;
select cosine_distance(c3,'[1,2.2,3]') ld_c3,cosine_distance(c4,'[1,1.3]') ld_c4 from t1 where cosine_distance(c3,c2) <= 0  order by c1;
select cosine_distance(c3,'[1,2.2,3]') ld_c3,cosine_distance(c4,'[1,1.3]') ld_c4 from t1 where cosine_distance(c3,[1,2,3]) <= 0  order by c1;
select cosine_distance(c3,'[1,2.2,3]') ld_c3,cosine_distance(c4,'[1,1.3]') ld_c4 from t1 where cosine_distance(c3,c2) >=1  order by c1;
select cosine_distance(c3,'[1,2.2,3]') ld_c3,cosine_distance(c4,'[1,1.3]') ld_c4 from t1 where cosine_distance(c3,[1,2,3]) >=1  order by c1;
select cosine_distance(c3,'[1,2.2,3]') ld_c3,cosine_distance(c4,'[1,1.3]') ld_c4 from t1 where cosine_distance(c3,c2) <>1  order by c1;
select cosine_distance(c3,'[1,2.2,3]') ld_c3,cosine_distance(c4,'[1,1.3]') ld_c4 from t1 where cosine_distance(c3,[1,2,3])<>1  order by c1;
select cosine_distance(c3,'[1,2.2,3]') ld_c3,cosine_distance(c4,'[1,1.3]') ld_c4 from t1 where cosine_distance(c3,c2) <>false  order by c1;
select cosine_distance(c3,'[1,2.2,3]') ld_c3,cosine_distance(c4,'[1,1.3]') ld_c4 from t1 where cosine_distance(c3,[1,2,3])<>false  order by c1;
select cosine_distance(c3,'[1,2.2,3]') ld_c3,cosine_distance(c4,'[1,1.3]') ld_c4 from t1 where cosine_distance(c3,c2) <>true  order by c1;
select cosine_distance(c3,'[1,2.2,3]') ld_c3,cosine_distance(c4,'[1,1.3]') ld_c4 from t1 where cosine_distance(c3,[1,2,3]) <>true  order by c1;

select cosine_distance(c3,'[1,2.2,3]') ld_c3,cosine_distance(c4,'[1,1.3]') ld_c4 from t1 where cosine_distance(c3,c3) =0  order by l2_distance(c3, [1,2,3]) approximate limit 10;
select cosine_distance(c3,'[1,2.2,3]') ld_c3,cosine_distance(c4,'[1,1.3]') ld_c4 from t1 where cosine_distance(c3,[1,2,3]) =0  order by l2_distance(c3, [1,2,3]) approximate limit 10;
select cosine_distance(c3,'[1,2.2,3]') ld_c3,cosine_distance(c4,'[1,1.3]') ld_c4 from t1 where cosine_distance(c3,c2) > 1  order by l2_distance(c3, [1,2,3]) approximate limit 10;
select cosine_distance(c3,'[1,2.2,3]') ld_c3,cosine_distance(c4,'[1,1.3]') ld_c4 from t1 where cosine_distance(c3,[1,2,3]) > 1  order by l2_distance(c3, [1,2,3]) approximate limit 10;
select cosine_distance(c3,'[1,2.2,3]') ld_c3,cosine_distance(c4,'[1,1.3]') ld_c4 from t1 where cosine_distance(c3,c2) < 1  order by l2_distance(c3, [1,2,3]) approximate limit 10;
select cosine_distance(c3,'[1,2.2,3]') ld_c3,cosine_distance(c4,'[1,1.3]') ld_c4 from t1 where cosine_distance(c3,[1,2,3]) < 1  order by l2_distance(c3, [1,2,3]) approximate limit 10;
select cosine_distance(c3,'[1,2.2,3]') ld_c3,cosine_distance(c4,'[1,1.3]') ld_c4 from t1 where cosine_distance(c3,c2) <= 0  order by l2_distance(c3, [1,2,3]) approximate limit 10;
select cosine_distance(c3,'[1,2.2,3]') ld_c3,cosine_distance(c4,'[1,1.3]') ld_c4 from t1 where cosine_distance(c3,[1,2,3]) <= 0  order by l2_distance(c3, [1,2,3]) approximate limit 10;
select cosine_distance(c3,'[1,2.2,3]') ld_c3,cosine_distance(c4,'[1,1.3]') ld_c4 from t1 where cosine_distance(c3,c2) >=1  order by l2_distance(c3, [1,2,3]) approximate limit 10;
select cosine_distance(c3,'[1,2.2,3]') ld_c3,cosine_distance(c4,'[1,1.3]') ld_c4 from t1 where cosine_distance(c3,[1,2,3]) >=1  order by l2_distance(c3, [1,2,3]) approximate limit 10;
select cosine_distance(c3,'[1,2.2,3]') ld_c3,cosine_distance(c4,'[1,1.3]') ld_c4 from t1 where cosine_distance(c3,c2) <>1  order by l2_distance(c3, [1,2,3]) approximate limit 10;
select cosine_distance(c3,'[1,2.2,3]') ld_c3,cosine_distance(c4,'[1,1.3]') ld_c4 from t1 where cosine_distance(c3,[1,2,3])<>1  order by l2_distance(c3, [1,2,3]) approximate limit 10;
select cosine_distance(c3,'[1,2.2,3]') ld_c3,cosine_distance(c4,'[1,1.3]') ld_c4 from t1 where cosine_distance(c3,c2) <>false  order by l2_distance(c3, [1,2,3]) approximate limit 10;
select cosine_distance(c3,'[1,2.2,3]') ld_c3,cosine_distance(c4,'[1,1.3]') ld_c4 from t1 where cosine_distance(c3,[1,2,3])<>false  order by l2_distance(c3, [1,2,3]) approximate limit 10;
select cosine_distance(c3,'[1,2.2,3]') ld_c3,cosine_distance(c4,'[1,1.3]') ld_c4 from t1 where cosine_distance(c3,c2) <>true  order by l2_distance(c3, [1,2,3]) approximate limit 10;
select cosine_distance(c3,'[1,2.2,3]') ld_c3,cosine_distance(c4,'[1,1.3]') ld_c4 from t1 where cosine_distance(c3,[1,2,3]) <>true  order by l2_distance(c3, [1,2,3]) approximate limit 10;


--echo ##and/or
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int primary key, c2 VARCHAR(30),c3 vector(3) ,c4 vector(3),
VECTOR INDEX vector_idx(c3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
insert into t1 values(1,'[1,1,2]','[2,2,3]','[1,-1.5,3]');
insert into t1 values(2,'[1,2,3]','[1,2,3]','[2,1.5,3]');
insert into t1 values(3,'[-1,2,2]','[-3,2,3]','[4,-1,3]');
insert into t1 values(4,'[-1,-2,-2]','[-4,2,3]',null);
insert into t1 values(5,'[-1,-2,-2]',null,'[2,-2,3]');

select cosine_distance(c3,'[1,2.2,3]') ld_c3,cosine_distance(c4,'[1,1.3,-1]') ld_c4 from t1 where cosine_distance(c3,c3) =0 and cosine_distance(c3,c4) is null order by c1;
select cosine_distance(c3,'[1,2.2,3]') ld_c3,cosine_distance(c4,'[1,1.3,1]') ld_c4 from t1 where cosine_distance(c3,c3) <=2 and cosine_distance(c3,c2) >1 ;
select cosine_distance(c3,'[1,2.2,3]') ld_c3,cosine_distance(c4,'[1,1.3,-1]') ld_c4 from t1 where cosine_distance(c3,c3) =0 and cosine_distance(c3,c2) >0  and cosine_distance(c3,c2) >0 and cosine_distance(c3,c2) >0 and cosine_distance(c3,c2) >0 and cosine_distance(c3,c2) >0 and cosine_distance(c3,c2) >0 and cosine_distance(c3,c2) >0 
and cosine_distance(c3,c2) >0 and cosine_distance(c3,c2) >0 and cosine_distance(c3,c2) >0 and cosine_distance(c3,c2) >0 and cosine_distance(c3,c2) >0 and cosine_distance(c3,c2) >0 and cosine_distance(c3,c2) >0 and cosine_distance(c3,c2) >0 and cosine_distance(c3,c2) >0 and cosine_distance(c3,c2) >0 and cosine_distance(c3,c2) >0 and 
cosine_distance(c3,c2) >0 and cosine_distance(c3,c2) >0 and cosine_distance(c3,c2) >0 and cosine_distance(c3,c2) >0 and cosine_distance(c3,c2) >0 and cosine_distance(c3,c2) >0 and cosine_distance(c3,c2) >0 and cosine_distance(c3,c2) >0 and cosine_distance(c3,c2) >0 and cosine_distance(c3,c2) >0 and cosine_distance(c3,c2) >0 and 
cosine_distance(c3,c2) >0 and cosine_distance(c3,c2) >0 and cosine_distance(c3,c2) >0 and cosine_distance(c3,c2) >0 and cosine_distance(c3,c2) >0 and cosine_distance(c3,c2) >0 and cosine_distance(c3,c2) >0 and cosine_distance(c3,c2) >0 and cosine_distance(c3,c2) >0 and cosine_distance(c3,c2) >0 and cosine_distance(c3,c2) >0 and 
cosine_distance(c3,c2) >0 and cosine_distance(c3,c2) >0 and cosine_distance(c3,c2) >0 and cosine_distance(c3,c2) >0 and cosine_distance(c3,c2) >0 and cosine_distance(c3,c2) >0 and cosine_distance(c3,c2) >0 and cosine_distance(c3,c2) >0 and cosine_distance(c3,c2) >0 and cosine_distance(c3,c2) >0 and cosine_distance(c3,c2) >0 and 
cosine_distance(c3,c2) >0 and cosine_distance(c3,c2) >0 and cosine_distance(c3,c2) >0 and cosine_distance(c3,c2) >0 and cosine_distance(c3,c2) >0 and cosine_distance(c3,c2) >0 and cosine_distance(c3,c2) >0 and cosine_distance(c3,c2) >0 and cosine_distance(c3,c2) >0 and cosine_distance(c3,c2) >0 and cosine_distance(c3,c2) >0 and 
cosine_distance(c3,c2) >0 and cosine_distance(c3,c2) >0 order by c1;


select cosine_distance(c3,'[1,2.2,3]') ld_c3,cosine_distance(c4,'[1,1.3,1]') ld_c4 from t1 where cosine_distance(c3,'[1,2,3]') > 0 or cosine_distance(c3,c3) is null order by c1;

select cosine_distance(c3,'[1,2.2,3]') ld_c3,cosine_distance(c4,'[1,1.3,1]') ld_c4 from t1 where cosine_distance(c3,'[1,2,3]') > 0 or cosine_distance(c3,c3) is null or cosine_distance(c3,c3) is null or cosine_distance(c3,c3) is null or cosine_distance(c3,c3) is null or cosine_distance(c3,c3) is null or cosine_distance(c3,c3) 
is null or cosine_distance(c3,c3) is null or cosine_distance(c3,c3) is null or cosine_distance(c3,c3) is null or cosine_distance(c3,c3) is null or cosine_distance(c3,c3) is null or cosine_distance(c3,c3) is null or cosine_distance(c3,c3) is null or cosine_distance(c3,c3) is null or cosine_distance(c3,c3) is null or 
