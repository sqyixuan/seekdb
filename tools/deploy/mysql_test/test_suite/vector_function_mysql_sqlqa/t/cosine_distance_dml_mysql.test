##运算符
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int AUTO_INCREMENT primary key , c2 vector(3),c3 vector(3) ,c4 BLOB,
VECTOR INDEX vector_idx(c3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
insert into t1(c1) values(cosine_distance([1.5+1,2.5-1,-1.5*2],[-1.5 % 1,1.5+0,1%1]));
insert into t1(c2) select [2,3,4] from dual; 
insert into t1(c3) select [3,3,4] from dual; 
insert into t1(c3) select [cosine_distance([1.5+1,2.5-1,-1.5*2],[-1.5 % 1,1.5+1,1%1]),cosine_distance([1.5+1,2.5-1,-1.5*2],[-1.5 % 1,1.5+1,1%1]),cosine_distance([1.5+1,2.5-1,-1.5*2],[-1.5 % 1,1.5+1,1%1])] from dual; 
insert into t1(c4) select cosine_distance([1.5+1,2.5-1,-1.5*2],[-1.5 % 1,1.5+1,1%1]) from dual; 

select cosine_distance(c3,[2,3,5]) from t1 order by c1 limit 2,2;
select cosine_distance(c3,[-2,3,-5]) from t1 order by c1 limit 2,2;

