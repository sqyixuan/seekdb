##like /not like
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int primary key,c2 json,c4 json)partition by hash(c1) partitions 8;
insert into t1 values(1,'[1,1,2]','{"page":"null"}');
insert into t1 values(2,'[1,2,2]','{"page":"1"}');
insert into t1 values(3,'[1,3,2]','[1,{"page":"1"},1]');
insert into t1 values(4,'[1,4,2]','[1,{"中文":"语 种"},1]');
insert into t1 values(5,'[1,5,2]','[1,null,1]');
insert into t1 values(6,'[1,6,2]',null);
insert into t1 values(7,'[1,7,3]','{"name": "刘德华","age": 60,"email": "john.doe@example.com"}');
select * from t1 where c4->'$.page'  like '%n%' order by c1;
select * from t1 where c4->'$[1].中文'  like '%语%' order by c1;
select * from t1 where c4->'$.age'  like '%6%' order by c1;
select * from t1 where c4->'$.email'  like '%@%' order by c1;

select * from t1 where c4->'$.page'  not like '%n%' order by c1;
select * from t1 where c4->'$[1].中文'   not like '%语%' order by c1;
select * from t1 where c4->'$.age'  not like '%6%' order by c1;
select * from t1 where c4->'$.email'  not like '%@%' order by c1;

##is /not is
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int primary key,c2 json,c4 json)partition by hash(c1) partitions 8;
insert into t1 values(1,'[1,1,2]','{"page":"null"}');
insert into t1 values(2,'[1,2,2]','{"page":"1"}');
insert into t1 values(3,'[1,3,2]','[1,{"page":"1"},1]');
insert into t1 values(4,'[1,4,2]','[1,{"中文":"语 种"},1]');
insert into t1 values(5,'[1,5,2]','[1,null,1]');
insert into t1 values(6,'[1,6,2]',null);
insert into t1 values(7,'[1,7,3]','{"name": "刘德华","age": 60,"email": "john.doe@example.com"}');
select * from t1 where c4->'$.page'  is null order by c1;
select * from t1 where c4->'$[1].中文'  is null order by c1;
select * from t1 where c4->'$.age'  is null order by c1;
select * from t1 where c4->'$.email'  is null order by c1;

select * from t1 where c4->'$.page'  is not null order by c1;
select * from t1 where c4->'$[1].中文'  is not null order by c1;
select * from t1 where c4->'$.age'  is not null order by c1;
select * from t1 where c4->'$.email'  is not null order by c1;


##regexp /not regexp
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int primary key,c2 json,c4 json)partition by hash(c1) partitions 8;
insert into t1 values(1,'[1,1,2]','{"page":"null"}');
insert into t1 values(2,'[1,2,2]','{"page":"1"}');
insert into t1 values(3,'[1,3,2]','[1,{"page":"1"},1]');
insert into t1 values(4,'[1,4,2]','[1,{"中文":"语 种"},1]');
insert into t1 values(5,'[1,5,2]','[1,null,1]');
insert into t1 values(6,'[1,6,2]',null);
insert into t1 values(7,'[1,7,3]','{"name": "刘德华","age": 60,"email": "john.doe@example.com"}');
select * from t1 where c4->'$.page'  regexp '1' order by c1;
select * from t1 where c4->'$.name'  regexp '刘德华' order by c1;
select * from t1 where c4->'$[1].中文'  regexp '语 种' order by c1;
select * from t1 where c4->'$.email'  regexp 'j' order by c1;

select * from t1 where c4->'$.page' not regexp '1' order by c1;
select * from t1 where c4->'$.name' not regexp '刘德华' order by c1;
select * from t1 where c4->'$[1].中文' not regexp '语 种' order by c1;
select * from t1 where c4->'$.email' not regexp 'j' order by c1;



##多列
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int primary key, c2 vector(3),c3 vector(3) ,c4 json,
VECTOR INDEX vector_idx(c3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40))partition by hash(c1) partitions 8;
insert into t1 values(1,'[1,1,2]','[2,1,3]','{"page":"null"}');
insert into t1 values(2,'[1,2,2]','[2,2,3]','{"page":"1"}');
insert into t1 values(3,'[1,3,2]','[2,3,3]','[1,{"page":"1"},1]');
insert into t1 values(4,'[1,4,2]','[2,4,3]','[1,{"中文":"语 种"},1]');
insert into t1 values(5,'[1,5,2]','[2,5,3]','[1,null,1]');
insert into t1 values(6,'[1,6,2]',null,null);
insert into t1 values(7,'[1,7,3]','[1,6,3]','{"name": "刘德华","age": 60,"email": "john.doe@example.com"}');

select * from t1 where (c2,c4->'$.page') in (([1,2,2], '1')) order by c1;
--error 5083
select * from t1 where (c2,c4->'$.page') in (([1,2,2], '1'),([1,1,2],'null')) order by c1;
select * from t1 where (c3,c4->'$.page') in (([2,2,3], '1')) order by c1;
select * from t1 where (c1,c2,c3,c4->'$.page') in ((2,[1,2,2],[2,2,3], '1')) order by c1;
select * from t1 where (c1,c2,c3,c4->'$[1].page') in ((3,[1,3,2],[2,3,3], '1')) order by c1;
select * from t1 where (c1,c2,c3,c4->'$[1].page') in ((3,[1,3,2],[2,3,3], '0')) order by c1;
select * from t1 where (c1,c2,c3,c4->' ') in ((6,[1,6,2],null,null)) order by c1;

select * from t1 where (c2,c4->'$.page') not in (([1,2,2], '1')) order by c1;
--error 5083
select * from t1 where (c2,c4->'$.page') not in (([1,2,2], '1'),([1,1,2],'null')) order by c1;
select * from t1 where (c3,c4->'$.page') not in (([2,2,3], '1')) order by c1;
select * from t1 where (c1,c2,c3,c4->'$.page') not in ((2,[1,2,2],[2,2,3], '1')) order by c1;
select * from t1 where (c1,c2,c3,c4->'$[1].page') not in ((3,[1,3,2],[2,3,3], '1')) order by c1;
select * from t1 where (c1,c2,c3,c4->'$[1].page') not in ((3,[1,3,2],[2,3,3], '0')) order by c1;
select * from t1 where (c1,c2,c3,c4->' ') not in ((6,[1,6,2],null,null)) order by c1;


select * from t1 where (c2,c4->'$.page') in (('[1,2,2]', '1'));
select * from t1 where (c2,c4->'$.page') in (('[1,1,2]', 'null'));
--error 5083
select * from t1 where (c2,c4->'$.page') in (('[1,1,2]', 'null'),('[1,2,2]', '1'));
--error 3146
select * from t1 where (c2->'$[0]',c4->'$.email')  in ((1,'john.doe@example.com'));

select * from t1 where c4 = '{"page":"null"}';
select * from t1 where c4 <> '{"page":"null"}';
select * from t1 where c4 = '{"name": "刘德华","age": 60,"email": "john.doe@example.com"}';
select * from t1 where c4 <> '{"name": "刘德华","age": 60,"email": "john.doe@example.com"}';
select * from t1 where c4 in ('{"name": "刘德华","age": 60,"email": "john.doe@example.com"}');
select * from t1 where c4 not in ('{"name": "刘德华","age": 60,"email": "john.doe@example.com"}');
select * from t1 where  c4->'$[1]' = '1' order by c1;
select * from t1 where  c4->'$[1]' <> '1' order by c1;

##多表连接
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int primary key,c2 vector(3),c4 json)partition by hash(c1) partitions 8;
insert into t1 values(1,'[1,1,2]','{"page":"null"}');
insert into t1 values(2,'[1,2,2]','{"page":"1"}');
insert into t1 values(3,'[1,3,2]','[1,{"page":"1"},1]');
insert into t1 values(4,'[1,4,2]','[1,{"中文":"语 种"},1]');
insert into t1 values(5,'[1,5,2]','[1,null,1]');
insert into t1 values(6,'[1,6,2]',null);
insert into t1 values(7,'[1,7,3]','{"name": "刘德华","age": 60,"email": "john.doe@example.com"}');

select * from t1 a,t1 b where a.c1=b.c1 and b.c4->'$[1]' = 'null' order by a.c1;
create table tt1 like t1;
replace into tt1 select * from t1;
select * from t1,tt1 where t1.c1=tt1.c1 and tt1.c4->'$[1]' = 'null' order by t1.c1;
select * from t1,tt1 where t1.c1=tt1.c1 and tt1.c4->'$[1]' is null order by t1.c1;


##结合向量索引
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int primary key, c2 vector(3),c3 vector(3) ,c4 json,
VECTOR INDEX vector_idx(c3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40))partition by hash(c1) partitions 8;
insert into t1 values(1,'[1,1,2]','[2,1,3]','{"page":"null"}');
insert into t1 values(2,'[1,2,2]','[2,2,3]','{"page":"1"}');
insert into t1 values(3,'[1,3,2]','[2,3,3]','[1,{"page":"蘩媞字"},1]');
insert into t1 values(4,'[1,4,2]','[2,4,3]','[1,{"中文":"？？？"},1]');
insert into t1 values(5,'[1,5,2]','[2,5,3]','[1,null,1]');
insert into t1 values(6,'[1,6,2]',null,null);
insert into t1 values(7,'[1,7,3]','[1,6,3]','{"name": "刘德华","age": 60,"email": "john.doe@example.com"}');

select * from t1 where c4->'$[1].中文' = '？？？' order by l2_distance(c3, [1,2,3]) approximate limit 10;
select * from t1 where c4->'$[1].page' = '蘩媞字' order by l2_distance(c3, [1,2,3]) approximate limit 10;
select * from t1 where (c3,c4->'$[1].中文') in (([2,4,3],'？？？'))  order by l2_distance(c3, [1,2,3]) approximate limit 10;

select * from t1 where c4->'$.page' = '1' order by l2_distance(c3, [1,2,3]) approximate limit 10;
select * from t1 where c4->'$.page' > '2' order by l2_distance(c3, [1,2,3]) approximate limit 10;
select * from t1 where c4->'$.page' >= '3' order by l2_distance(c3, [1,2,3]) approximate limit 10;
select * from t1 where c4->'$.page' <= '3' order by l2_distance(c3, [1,2,3]) approximate limit 10;
select * from t1 where c4->'$.page' between '1' and '2' order by l2_distance(c3, [1,2,3]) approximate limit 10;
select * from t1 where c4->'$.page' <> '3' order by l2_distance(c3, [1,2,3]) approximate limit 10;
select * from t1 where c4->'$.page' <=> '3' order by l2_distance(c3, [1,2,3]) approximate limit 10;




