#description: vector_dml
#tags:vector_dml
#author: wb-ljh01399065
purge recyclebin;
--disable_warnings
drop database IF EXISTS obljh;
--enable_warnings
create database obljh ;
use obljh;
set timestamp = 1600000000;
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;
set ob_default_lob_inrow_threshold = 0;

alter system set ob_vector_memory_limit_percentage =44;
--enable_sorted_result

##主要针对基础比较操作，涉及到子查询的比较，需要考虑非关联子查询和关联子查询，根据后面关键字找一下对应的操作符或者表达式，多列的场景；
##加强测试
##比较运算符验证（路径过滤）
--disable_warnings
drop table if exists t1;
--enable_warnings

CREATE TABLE t1 (c1 int primary key, c2 vector(3),c3 vector(3) ,c4 json,
VECTOR INDEX vector_idx(c3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40))partition by hash(c1) partitions 8;
insert into t1 values(1,'[1,1,2]','[2,1,3]','{"page":"null"}');
insert into t1 values(2,'[1,2,2]','[2,2,3]','{"page":"1"}');
insert into t1 values(3,'[1,3,2]','[2,3,3]','[1,{"page":"1"},1]');
insert into t1 values(4,'[1,4,2]','[2,4,3]','[1,{"中文":"语 种"},1]');
insert into t1 values(5,'[1,5,2]','[2,5,3]','[1,null,1]');
insert into t1 values(6,'[1,6,2]',null,null);
insert into t1 values(7,'[1,7,3]','[1,6,3]','{"name": "刘德华","age": 60,"email": "john.doe@example.com"}');
select * from t1 where  c4->'$[1]' = '1' order by c1;
select * from t1 where  c4->'$[1]' <> '1' order by c1;
select * from t1 where c4->'$.page' = '1' order by c1;
select * from t1 where c4->'$.page' > '2' order by c1;
select * from t1 where c4->'$.page' >= '3' order by c1;
select * from t1 where c4->'$.page' <= '3' order by c1;
select * from t1 where c4->'$.page' between '1' and '2' order by c1;
select * from t1 where c4->'$.page' <> '3' order by c1;
select * from t1 where c4->'$.page' <=> '3' order by c1;
##多个条件(and/or)
select * from t1 where c4->'$.page' = '1' or c4->'$.page' <> '1' order by c1;
select * from t1 where c4->'$.page' > '2' or c4->'$.page' <= '2' order by c1;
select * from t1 where c4->'$.page' >= '3' and c4->'$.page' <> '1' order by c1;
select * from t1 where c4->'$.page' <= '3' and c4->'$.page' <=> '1' order by c1;
select * from t1 where c4->'$.page' between '1' and '2' and '3' order by c1;
select * from t1 where c4->'$.page' <> '3' and c4->'$.page' <> '3' order by c1;
select * from t1 where c4->'$.page' <> '3' or c2 is null order by c1;
select * from t1 where c4->'$.page' <> '3' and c2 is null or c4 is not null order by c1;


####json列比较运算符操作
select * from t1 where c4 = '{"name": "刘德华","age": 60,"email": "john.doe@example.com"}' order by c1;
select * from t1 where c4 <> '{"name": "刘德华","age": 60,"email": "john.doe@example.com"}' order by c1;
select * from t1 where c4 > '{"name": "刘德华","age": 60,"email": "john.doe@example.com"}' order by c1;
select * from t1 where c4 < '{"name": "刘德华","age": 60,"email": "john.doe@example.com"}' order by c1;
select * from t1 where c4 >= '{"name": "刘德华","age": 60,"email": "john.doe@example.com"}' order by c1;
select * from t1 where c4 <= '{"name": "刘德华","age": 60,"email": "john.doe@example.com"}' order by c1;
select * from t1 where c4 <=> '{"name": "刘德华","age": 60,"email": "john.doe@example.com"}' order by c1;



##子查询
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int primary key, c2 vector(3),c3 vector(3) ,c4 json,
VECTOR INDEX vector_idx(c3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40))partition by hash(c1) partitions 8;
insert into t1 values(1,'[1,1,2]','[2,1,3]','{"page":"null"}');
insert into t1 values(2,'[1,2,2]','[2,2,3]','{"page":"1"}');
insert into t1 values(3,'[1,3,2]','[2,3,3]','[1,{"page":"1"},1]');
insert into t1 values(4,'[1,4,2]','[2,4,3]','[1,{"中文":"语 种"},1]');
insert into t1 values(5,'[1,5,2]','[2,5,3]','[1,null,1]');
insert into t1 values(6,'[1,6,2]',null,null);
insert into t1 values(7,'[1,7,3]','[1,6,3]','{"name": "刘德华","age": 60,"email": "john.doe@example.com"}');

select * from t1 where c4->'$.page' = (select c4 from t1 limit 1);
select * from t1 where c4->'$.page' >= (select c4 from t1 limit 1);
select * from t1 where c4->'$.page' <> (select c4 from t1 limit 1);
select * from t1 where c4->'$.page' <= (select c4 from t1 limit 1);
select * from t1 where c4->'$.page' > (select c4 from t1 limit 1);
select * from t1 where c4->'$.page' < (select c4 from t1 limit 1);

select * from t1 where c4->'$.page' = (select c4 from t1 where c4->'$[1].中文' = '语 种'order by l2_distance(c3, [1,2,3]) approximate limit 10);
select * from t1 where c4->'$.page' >= (select c4 from t1 where c4->'$[1].中文' > '语 种' order by l2_distance(c3, [1,2,3]) approximate limit 10);
select * from t1 where c4->'$.page' <> (select c4 from t1 where c4->'$[1].中文' < '语 种' order by l2_distance(c3, [1,2,3]) approximate limit 10);
select * from t1 where c4->'$.page' <= (select c4 from t1 where c4->'$[1].中文' >= '语 种' order by l2_distance(c3, [1,2,3]) approximate limit 10);
select * from t1 where c4->'$.page' > (select c4 from t1 where c4->'$[1].中文' <= '语 种' order by l2_distance(c3, [1,2,3]) approximate limit 10);
select * from t1 where c4->'$.page' < (select c4 from t1 where c4->'$[1].中文' <> '语 种' order by l2_distance(c3, [1,2,3]) approximate limit 10);
select * from t1 where c4->'$.page' <=> (select c4 from t1 where c4->'$[1].中文' <=> '语 种' order by l2_distance(c3, [1,2,3]) approximate limit 10);

select * from t1 where c4->'$.page' in (select c4 from t1 where c4->'$[1].中文' = '语 种' order by l2_distance(c3, [1,2,3]) approximate limit 10);
select * from t1 where c4->'$.page' in (select c4 from t1 where c4->'$[1].中文' > '语 种' order by l2_distance(c3, [1,2,3]) approximate limit 10);
select * from t1 where c4->'$.page' in (select c4 from t1 where c4->'$[1].中文' < '语 种' order by l2_distance(c3, [1,2,3]) approximate limit 10);
select * from t1 where c4->'$.page' in (select c4 from t1 where c4->'$[1].中文' >= '语 种' order by l2_distance(c3, [1,2,3]) approximate limit 10);
select * from t1 where c4->'$.page' in (select c4 from t1 where c4->'$[1].中文' <= '语 种' order by l2_distance(c3, [1,2,3]) approximate limit 10);
select * from t1 where c4->'$.page' in (select c4 from t1 where c4->'$[1].中文' <> '语 种' order by l2_distance(c3, [1,2,3]) approximate limit 10);
select * from t1 where c4->'$.page' in (select c4 from t1 where c4->'$[1].中文' <=> '语 种' order by l2_distance(c3, [1,2,3]) approximate limit 10);

select * from t1 where c4->'$.page' not in (select c4 from t1 where c4->'$[1].中文' = '语 种' order by l2_distance(c3, [1,2,3]) approximate limit 10);
select * from t1 where c4->'$.page' not in (select c4 from t1 where c4->'$[1].中文' > '语 种' order by l2_distance(c3, [1,2,3]) approximate limit 10);
select * from t1 where c4->'$.page' not in (select c4 from t1 where c4->'$[1].中文' < '语 种' order by l2_distance(c3, [1,2,3]) approximate limit 10);
select * from t1 where c4->'$.page' not in (select c4 from t1 where c4->'$[1].中文' >= '语 种' order by l2_distance(c3, [1,2,3]) approximate limit 10);
select * from t1 where c4->'$.page' not in (select c4 from t1 where c4->'$[1].中文' <= '语 种' order by l2_distance(c3, [1,2,3]) approximate limit 10);
select * from t1 where c4->'$.page' not in (select c4 from t1 where c4->'$[1].中文' <> '语 种' order by l2_distance(c3, [1,2,3]) approximate limit 10);
select * from t1 where c4->'$.page' not in (select c4 from t1 where c4->'$[1].中文' <=> '语 种' order by l2_distance(c3, [1,2,3]) approximate limit 10);

select * from t1 where c4->'$.page' in (select c4 from t1 where c4->'$.page' is null and  c4->'$.page' is not null order by l2_distance(c3, [1,2,3]) approximate limit 10);
select * from t1 where c4->'$.page' not in (select c4 from t1 where c4->'$.page' is null and  c4->'$.page' is not null order by l2_distance(c3, [1,2,3]) approximate limit 10);
select * from t1 where c4->'$.page' in (select c4 from t1 where c4->'$.page' is null or  c4->'$.page' is not null order by l2_distance(c3, [1,2,3]) approximate limit 10);
select * from t1 where c4->'$.page' not in (select c4 from t1 where c4->'$.page' is null or  c4->'$.page' is not null order by l2_distance(c3, [1,2,3]) approximate limit 10);



select * from t1 where c4->'$.page' >= (select c4 from t1 where c4->'$[1].中文' > '语 种' order by l2_distance(c3, [1,2,3]) approximate limit 10);
select * from t1 where c4->'$.page' <> (select c4 from t1 where c4->'$[1].中文' < '语 种' order by l2_distance(c3, [1,2,3]) approximate limit 10);
select * from t1 where c4->'$.page' <= (select c4 from t1 where c4->'$[1].中文' >= '语 种' order by l2_distance(c3, [1,2,3]) approximate limit 10);
select * from t1 where c4->'$.page' > (select c4 from t1 where c4->'$[1].中文' <= '语 种' order by l2_distance(c3, [1,2,3]) approximate limit 10);
select * from t1 where c4->'$.page' < (select c4 from t1 where c4->'$[1].中文' <> '语 种' order by l2_distance(c3, [1,2,3]) approximate limit 10);
select * from t1 where c4->'$.page' <=> (select c4 from t1 where c4->'$[1].中文' <=> '语 种' order by l2_distance(c3, [1,2,3]) approximate limit 10);

select * from t1 where c4->'$.page' in (select c4 from t1 where c4->'$[1].中文' = '语 种' order by l2_distance(c3, [1,2,3]) approximate limit 10);
select * from t1 where c4->'$.page' in (select c4 from t1 where c4->'$[1].中文' > '语 种' order by l2_distance(c3, [1,2,3]) approximate limit 10);
select * from t1 where c4->'$.page' in (select c4 from t1 where c4->'$[1].中文' < '语 种' order by l2_distance(c3, [1,2,3]) approximate limit 10);
select * from t1 where c4->'$.page' in (select c4 from t1 where c4->'$[1].中文' >= '语 种' order by l2_distance(c3, [1,2,3]) approximate limit 10);
select * from t1 where c4->'$.page' in (select c4 from t1 where c4->'$[1].中文' <= '语 种' order by l2_distance(c3, [1,2,3]) approximate limit 10);
select * from t1 where c4->'$.page' in (select c4 from t1 where c4->'$[1].中文' <> '语 种' order by l2_distance(c3, [1,2,3]) approximate limit 10);
select * from t1 where c4->'$.page' in (select c4 from t1 where c4->'$[1].中文' <=> '语 种' order by l2_distance(c3, [1,2,3]) approximate limit 10);

select * from t1 where c4->'$.page' not in (select c4 from t1 where c4->'$[1].中文' = '语 种' order by l2_distance(c3, [1,2,3]) approximate limit 10);
select * from t1 where c4->'$.page' not in (select c4 from t1 where c4->'$[1].中文' > '语 种' order by l2_distance(c3, [1,2,3]) approximate limit 10);
select * from t1 where c4->'$.page' not in (select c4 from t1 where c4->'$[1].中文' < '语 种' order by l2_distance(c3, [1,2,3]) approximate limit 10);
select * from t1 where c4->'$.page' not in (select c4 from t1 where c4->'$[1].中文' >= '语 种' order by l2_distance(c3, [1,2,3]) approximate limit 10);
select * from t1 where c4->'$.page' not in (select c4 from t1 where c4->'$[1].中文' <= '语 种' order by l2_distance(c3, [1,2,3]) approximate limit 10);
select * from t1 where c4->'$.page' not in (select c4 from t1 where c4->'$[1].中文' <> '语 种' order by l2_distance(c3, [1,2,3]) approximate limit 10);
