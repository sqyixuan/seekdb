WITH (distance=inner_product, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
insert into t1(c1) values(negative_inner_product([1,2,3],[1,2,4]));
replace into t1(c1,c2,c3,c4) values(negative_inner_product([1,2,3],[1,2,100]),[-1,-3,-2],[2,3,1],[2,3,1]);
replace into t1(c1,c2,c3,c4) values(negative_inner_product([1,2,3],[1,2,100]),[-1,-3,-2],null,[2,3,1]);
replace into t1(c1,c2,c3,c4) values(-1,[-1,-3,-2],null,[2,3,1]);
replace into t1(c1,c2,c3,c4) values(negative_inner_product([1,2,3,1,1,1,1,1,1,1,2,3,1,1,1,1,1,1,1,2,3,1,1,1,1,1,1,1,2,3,1,1,1,1,1,1,1,2,3,1,1,1,1,1,1,1,2,3,1,1,1,1,1,1,1,2,3,1,1,1,1,1,1,1,2,3,1,1,1,1,1,1,1,2,3,1,1,1,1,1,1,1,2,3,1,1,1,1,1,1,1,2,3,1,1,1,1,1,1,1,2,3,1,1,1,1,1,1],[1,2,3,1,1,1,1,1,1,1,2,3,1,1,1,1,1,1,1,2,3,1,1,1,1,1,1,1,2,3,1,1,1,1,1,1,1,2,3,1,1,1,1,1,1,1,2,3,1,1,1,1,1,1,1,2,3,1,1,1,1,1,1,1,2,3,1,1,1,1,1,1,1,2,3,1,1,1,1,1,1,1,2,3,1,1,1,1,1,1,1,2,3,1,1,1,1,1,1,1,2,3,10.20,1,1,1,1,1]),[1,2,3],null,[2,3,1]);
