--echo ##where子句
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int primary key, c2 vector(3),c3 vector(3) ,c4 vector(3),
VECTOR INDEX vector_idx(c2) 
WITH (distance=inner_product, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
insert into t1 values(1,'[1,1,2]','[2,2,3]','[1,3,2]');
insert into t1 values(2,'[1,0,3]','[1,0,3]','[2,3,2]');
insert into t1 values(3,'[-1,2,2]','[-3,2,3]','[4,3,3]');
insert into t1 values(4,'[-1,-2,-2]','[-4,2,3]',null);
insert into t1 values(5,'[-1,-3,-2]',null,'[2,3,1]');

update t1 set c2 ='[1,2,3]' where c1 >negative_inner_product('[1,1,2]','[1,2,2]');

update t1 set c2 =[1,2,3] where c1 >negative_inner_product('[1,1,2]','[1,2,2]');
update t1 set c2 =[2,2,3] where c1 <negative_inner_product('[1,1,2]','[1,2,2]');
update t1 set c2 =[1,2,3] where c1 >=inner_product('[1,1,2]','[1,2,2]');
update t1 set c2 =[2,2,3] where c1 <=inner_product('[1,1,2]','[1,2,2]');
update t1 set c2 =[1,2,3] where c1 =inner_product('[1,1,2]','[1,2,2]');
update t1 set c2 =[2,2,3] where c1 <>negative_inner_product('[1,1,2]','[1,2,2]');
select * from t1 order by c1;

update t1 set c2 =[1,2,3] where c1 > negative_inner_product('[1,3,2]','[1,2,2]') and c1 > negative_inner_product('[1,3,2]','[1,2,2]');
update t1 set c2 =[2,2,3] where c1 < negative_inner_product('[1,1,2]','[1,2,2]') or c1 > negative_inner_product('[1,3,2]','[1,2,2]') ;

update t1 set c2 =[1,2,3] where c1 BETWEEN negative_inner_product(c3,c4)  and negative_inner_product(c3,'[1,2,3]') >1;
--error 5083
update t1 set c2 =[2,2,3] where c3 like '%-4%' ;
update t1 set c2 =[negative_inner_product('[1,3,2]','[1,1,2]'),negative_inner_product('[1,2,2]','[1,1,11]'),negative_inner_product('[1,1,2]','[1,1,2]')] where c1 like '%5%' ;
update t1 set c2 =[negative_inner_product('[1,3,2]','[1,1,2]'),negative_inner_product('[1,2,2]','[1,1,11]'),negative_inner_product('[1,1,2]','[1,1,2]')] where c1 not like '%5%' ;

update t1 set c2 =[2,2,3] where negative_inner_product(c3,c3) = any (SELECT negative_inner_product(c3,c4) FROM t1) order by c1;
update t1 set c2 =[2,2,3] where negative_inner_product(c3,c3) = all (SELECT negative_inner_product(c3,c4) FROM t1) order by c1;
update t1 set c2 =[2,2,3] where  exists (SELECT negative_inner_product(c3,c4) FROM t1) order by c1;
update t1 set c2 =[2,2,3] where negative_inner_product(c3,c3) in  (SELECT negative_inner_product(c3,c4) FROM t1) order by c1;
update t1 set c2 =[2,2,3] where negative_inner_product(c3,c3) not in  (SELECT negative_inner_product(c3,c4) FROM t1) order by c1;
select * from t1 order by c1;

call dbms_vector.refresh_index('vector_idx','t1','c2',1,'FAST');
call dbms_vector.rebuild_index('vector_idx','t1');

