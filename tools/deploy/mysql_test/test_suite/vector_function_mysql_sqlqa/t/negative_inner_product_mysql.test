#owner: gehao.wh
#owner group: 多模
#description: vector_dml
#tags:vector_dml
#author: wb-ljh01399065
purge recyclebin;
--disable_warnings
drop database IF EXISTS obljh;
--enable_warnings
create database obljh ;
use obljh;
set timestamp = 1600000000;
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;
set ob_default_lob_inrow_threshold = 0;

alter system set ob_vector_memory_limit_percentage =44;
--echo ##where子句
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int AUTO_INCREMENT primary key , c2 vector(3),c3 vector(3) ,c4 BLOB,
VECTOR INDEX vector_idx(c3) 
WITH (distance=inner_product, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
select * from t1 where negative_inner_product(null,null);
##只使用where，无条件时会导致core
select * from t1 where negative_inner_product([1,1],[1,1]);
select * from t1 where negative_inner_product(null,[1]);

--echo ##=,<,<=,>=,<>
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int primary key, c2 VARCHAR(30),c3 vector(3) ,c4 vector(2),
VECTOR INDEX vector_idx(c3) 
WITH (distance=inner_product, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
insert into t1 values(1,'[1,1,2]','[2,2,3]','[1,3]');
insert into t1 values(2,'[1,2,3]','[1,2,3]','[2,3]');
insert into t1 values(3,'[-1,2,2]','[-3,2,3]','[4,3]');
insert into t1 values(4,'[-1,-2,-2]','[-4,2,3]',null);
insert into t1 values(5,'[-1,-2,-2]',null,'[2,3]');
select negative_inner_product(c3,'[1,2.2,3]') ld_c3,negative_inner_product(c4,'[1,1.3]') ld_c4 from t1 where negative_inner_product(c3,c3) =0  order by c1;
select negative_inner_product(c3,'[1,2.2,3]') ld_c3,negative_inner_product(c4,'[1,1.3]') ld_c4 from t1 where negative_inner_product(c3,[1,2,3]) =0  order by c1;
select negative_inner_product(c3,'[1,2.2,3]') ld_c3,negative_inner_product(c4,'[1,1.3]') ld_c4 from t1 where negative_inner_product(c3,c2) > 1  order by c1;
select negative_inner_product(c3,'[1,2.2,3]') ld_c3,negative_inner_product(c4,'[1,1.3]') ld_c4 from t1 where negative_inner_product(c3,[1,2,3]) > 1  order by c1;
select negative_inner_product(c3,'[1,2.2,3]') ld_c3,negative_inner_product(c4,'[1,1.3]') ld_c4 from t1 where negative_inner_product(c3,c2) < 1  order by c1;
select negative_inner_product(c3,'[1,2.2,3]') ld_c3,negative_inner_product(c4,'[1,1.3]') ld_c4 from t1 where negative_inner_product(c3,[1,2,3]) < 1  order by c1;
select negative_inner_product(c3,'[1,2.2,3]') ld_c3,negative_inner_product(c4,'[1,1.3]') ld_c4 from t1 where negative_inner_product(c3,c2) <= 0  order by c1;
select negative_inner_product(c3,'[1,2.2,3]') ld_c3,negative_inner_product(c4,'[1,1.3]') ld_c4 from t1 where negative_inner_product(c3,[1,2,3]) <= 0  order by c1;
select negative_inner_product(c3,'[1,2.2,3]') ld_c3,negative_inner_product(c4,'[1,1.3]') ld_c4 from t1 where negative_inner_product(c3,c2) >=1  order by c1;
select negative_inner_product(c3,'[1,2.2,3]') ld_c3,negative_inner_product(c4,'[1,1.3]') ld_c4 from t1 where negative_inner_product(c3,[1,2,3]) >=1  order by c1;
select negative_inner_product(c3,'[1,2.2,3]') ld_c3,negative_inner_product(c4,'[1,1.3]') ld_c4 from t1 where negative_inner_product(c3,c2) <>1  order by c1;
select negative_inner_product(c3,'[1,2.2,3]') ld_c3,negative_inner_product(c4,'[1,1.3]') ld_c4 from t1 where negative_inner_product(c3,[1,2,3])<>1  order by c1;
select negative_inner_product(c3,'[1,2.2,3]') ld_c3,negative_inner_product(c4,'[1,1.3]') ld_c4 from t1 where negative_inner_product(c3,c2) <>false  order by c1;
select negative_inner_product(c3,'[1,2.2,3]') ld_c3,negative_inner_product(c4,'[1,1.3]') ld_c4 from t1 where negative_inner_product(c3,[1,2,3])<>false  order by c1;
select negative_inner_product(c3,'[1,2.2,3]') ld_c3,negative_inner_product(c4,'[1,1.3]') ld_c4 from t1 where negative_inner_product(c3,c2) <>true  order by c1;
select negative_inner_product(c3,'[1,2.2,3]') ld_c3,negative_inner_product(c4,'[1,1.3]') ld_c4 from t1 where negative_inner_product(c3,[1,2,3]) <>true  order by c1;



select negative_inner_product(c3,'[1,2.2,3]') ld_c3,negative_inner_product(c4,'[1,1.3]') ld_c4 from t1 where negative_inner_product(c3,c3) =0  order by negative_inner_product(c3, [1,2,3]) approximate limit 10;
select negative_inner_product(c3,'[1,2.2,3]') ld_c3,negative_inner_product(c4,'[1,1.3]') ld_c4 from t1 where negative_inner_product(c3,[1,2,3]) =0  order by negative_inner_product(c3, [1,2,3]) approximate limit 10;
select negative_inner_product(c3,'[1,2.2,3]') ld_c3,negative_inner_product(c4,'[1,1.3]') ld_c4 from t1 where negative_inner_product(c3,c2) > 1  order by negative_inner_product(c3, [1,2,3]) approximate limit 10;
select negative_inner_product(c3,'[1,2.2,3]') ld_c3,negative_inner_product(c4,'[1,1.3]') ld_c4 from t1 where negative_inner_product(c3,[1,2,3]) > 1  order by negative_inner_product(c3, [1,2,3]) approximate limit 10;
select negative_inner_product(c3,'[1,2.2,3]') ld_c3,negative_inner_product(c4,'[1,1.3]') ld_c4 from t1 where negative_inner_product(c3,c2) < 1  order by negative_inner_product(c3, [1,2,3]) approximate limit 10;
select negative_inner_product(c3,'[1,2.2,3]') ld_c3,negative_inner_product(c4,'[1,1.3]') ld_c4 from t1 where negative_inner_product(c3,[1,2,3]) < 1  order by negative_inner_product(c3, [1,2,3]) approximate limit 10;
select negative_inner_product(c3,'[1,2.2,3]') ld_c3,negative_inner_product(c4,'[1,1.3]') ld_c4 from t1 where negative_inner_product(c3,c2) <= 0  order by negative_inner_product(c3, [1,2,3]) approximate limit 10;
select negative_inner_product(c3,'[1,2.2,3]') ld_c3,negative_inner_product(c4,'[1,1.3]') ld_c4 from t1 where negative_inner_product(c3,[1,2,3]) <= 0  order by negative_inner_product(c3, [1,2,3]) approximate limit 10;
select negative_inner_product(c3,'[1,2.2,3]') ld_c3,negative_inner_product(c4,'[1,1.3]') ld_c4 from t1 where negative_inner_product(c3,c2) >=1  order by negative_inner_product(c3, [1,2,3]) approximate limit 10;
select negative_inner_product(c3,'[1,2.2,3]') ld_c3,negative_inner_product(c4,'[1,1.3]') ld_c4 from t1 where negative_inner_product(c3,[1,2,3]) >=1  order by negative_inner_product(c3, [1,2,3]) approximate limit 10;
select negative_inner_product(c3,'[1,2.2,3]') ld_c3,negative_inner_product(c4,'[1,1.3]') ld_c4 from t1 where negative_inner_product(c3,c2) <>1  order by negative_inner_product(c3, [1,2,3]) approximate limit 10;
select negative_inner_product(c3,'[1,2.2,3]') ld_c3,negative_inner_product(c4,'[1,1.3]') ld_c4 from t1 where negative_inner_product(c3,[1,2,3])<>1  order by negative_inner_product(c3, [1,2,3]) approximate limit 10;
select negative_inner_product(c3,'[1,2.2,3]') ld_c3,negative_inner_product(c4,'[1,1.3]') ld_c4 from t1 where negative_inner_product(c3,c2) <>false  order by negative_inner_product(c3, [1,2,3]) approximate limit 10;
select negative_inner_product(c3,'[1,2.2,3]') ld_c3,negative_inner_product(c4,'[1,1.3]') ld_c4 from t1 where negative_inner_product(c3,[1,2,3])<>false  order by negative_inner_product(c3, [1,2,3]) approximate limit 10;
select negative_inner_product(c3,'[1,2.2,3]') ld_c3,negative_inner_product(c4,'[1,1.3]') ld_c4 from t1 where negative_inner_product(c3,c2) <>true  order by negative_inner_product(c3, [1,2,3]) approximate limit 10;
select negative_inner_product(c3,'[1,2.2,3]') ld_c3,negative_inner_product(c4,'[1,1.3]') ld_c4 from t1 where negative_inner_product(c3,[1,2,3]) <>true  order by negative_inner_product(c3, [1,2,3]) approximate limit 10;

--echo ##and/or
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int primary key, c2 VARCHAR(30),c3 vector(3) ,c4 vector(3),
VECTOR INDEX vector_idx(c3) 
WITH (distance=inner_product, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
insert into t1 values(1,'[1,1,2]','[2,2,3]','[1,-1.5,3]');
insert into t1 values(2,'[1,2,3]','[1,2,3]','[2,1.5,3]');
insert into t1 values(3,'[-1,2,2]','[-3,2,3]','[4,-1,3]');
insert into t1 values(4,'[-1,-2,-2]','[-4,2,3]',null);
insert into t1 values(5,'[-1,-2,-2]',null,'[2,-2,3]');

select negative_inner_product(c3,'[1,2.2,3]') ld_c3,negative_inner_product(c4,'[1,1.3,-1]') ld_c4 from t1 where negative_inner_product(c3,c3) =0 and negative_inner_product(c3,c4) is null order by c1;
select negative_inner_product(c3,'[1,2.2,3]') ld_c3,negative_inner_product(c4,'[1,1.3,1]') ld_c4 from t1 where negative_inner_product(c3,c3) <=2 and negative_inner_product(c3,c2) >1 ;
select negative_inner_product(c3,'[1,2.2,3]') ld_c3,negative_inner_product(c4,'[1,1.3,-1]') ld_c4 from t1 where negative_inner_product(c3,c3) =0 and negative_inner_product(c3,c2) >0  and negative_inner_product(c3,c2) >0 and negative_inner_product(c3,c2) >0 and negative_inner_product(c3,c2) >0 and negative_inner_product(c3,c2) >0 and negative_inner_product(c3,c2) >0 and negative_inner_product(c3,c2) >0 
and negative_inner_product(c3,c2) >0 and negative_inner_product(c3,c2) >0 and negative_inner_product(c3,c2) >0 and negative_inner_product(c3,c2) >0 and negative_inner_product(c3,c2) >0 and negative_inner_product(c3,c2) >0 and negative_inner_product(c3,c2) >0 and negative_inner_product(c3,c2) >0 and negative_inner_product(c3,c2) >0 and negative_inner_product(c3,c2) >0 and negative_inner_product(c3,c2) >0 and 
negative_inner_product(c3,c2) >0 and negative_inner_product(c3,c2) >0 and negative_inner_product(c3,c2) >0 and negative_inner_product(c3,c2) >0 and negative_inner_product(c3,c2) >0 and negative_inner_product(c3,c2) >0 and negative_inner_product(c3,c2) >0 and negative_inner_product(c3,c2) >0 and negative_inner_product(c3,c2) >0 and negative_inner_product(c3,c2) >0 and negative_inner_product(c3,c2) >0 and 
negative_inner_product(c3,c2) >0 and negative_inner_product(c3,c2) >0 and negative_inner_product(c3,c2) >0 and negative_inner_product(c3,c2) >0 and negative_inner_product(c3,c2) >0 and negative_inner_product(c3,c2) >0 and negative_inner_product(c3,c2) >0 and negative_inner_product(c3,c2) >0 and negative_inner_product(c3,c2) >0 and negative_inner_product(c3,c2) >0 and negative_inner_product(c3,c2) >0 and 
negative_inner_product(c3,c2) >0 and negative_inner_product(c3,c2) >0 and negative_inner_product(c3,c2) >0 and negative_inner_product(c3,c2) >0 and negative_inner_product(c3,c2) >0 and negative_inner_product(c3,c2) >0 and negative_inner_product(c3,c2) >0 and negative_inner_product(c3,c2) >0 and negative_inner_product(c3,c2) >0 and negative_inner_product(c3,c2) >0 and negative_inner_product(c3,c2) >0 and 
negative_inner_product(c3,c2) >0 and negative_inner_product(c3,c2) >0 and negative_inner_product(c3,c2) >0 and negative_inner_product(c3,c2) >0 and negative_inner_product(c3,c2) >0 and negative_inner_product(c3,c2) >0 and negative_inner_product(c3,c2) >0 and negative_inner_product(c3,c2) >0 and negative_inner_product(c3,c2) >0 and negative_inner_product(c3,c2) >0 and negative_inner_product(c3,c2) >0 and 
negative_inner_product(c3,c2) >0 and negative_inner_product(c3,c2) >0 order by c1;


select negative_inner_product(c3,'[1,2.2,3]') ld_c3,negative_inner_product(c4,'[1,1.3,1]') ld_c4 from t1 where negative_inner_product(c3,'[1,2,3]') > 0 or negative_inner_product(c3,c3) is null order by c1;

select negative_inner_product(c3,'[1,2.2,3]') ld_c3,negative_inner_product(c4,'[1,1.3,1]') ld_c4 from t1 where negative_inner_product(c3,'[1,2,3]') > 0 or negative_inner_product(c3,c3) is null or negative_inner_product(c3,c3) is null or negative_inner_product(c3,c3) is null or negative_inner_product(c3,c3) is null or negative_inner_product(c3,c3) is null or negative_inner_product(c3,c3) 
is null or negative_inner_product(c3,c3) is null or negative_inner_product(c3,c3) is null or negative_inner_product(c3,c3) is null or negative_inner_product(c3,c3) is null or negative_inner_product(c3,c3) is null or negative_inner_product(c3,c3) is null or negative_inner_product(c3,c3) is null or negative_inner_product(c3,c3) is null or negative_inner_product(c3,c3) is null or 
negative_inner_product(c3,c3) is null or negative_inner_product(c3,c3) is null or negative_inner_product(c3,c3) is null or negative_inner_product(c3,c3) is null or negative_inner_product(c3,c3) is null or negative_inner_product(c3,c3) is null or negative_inner_product(c3,c3) is null or negative_inner_product(c3,c3) is null or negative_inner_product(c3,c3) is null or negative_inner_product(c3,c3) 
is null or negative_inner_product(c3,c3) is null or negative_inner_product(c3,c3) is null or negative_inner_product(c3,c3) is null or negative_inner_product(c3,c3) is null or negative_inner_product(c3,c3) is null or negative_inner_product(c3,c3) is null or negative_inner_product(c3,c3) is null or negative_inner_product(c3,c3) is null or negative_inner_product(c3,c3) is null or 
negative_inner_product(c3,c3) is null or negative_inner_product(c3,c3) is null or negative_inner_product(c3,c3) is null or negative_inner_product(c3,c3) is null or negative_inner_product(c3,c3) is null or negative_inner_product(c3,c3) is null or negative_inner_product(c3,c3) is null or negative_inner_product(c3,c3) is null or negative_inner_product(c3,c3) is null or negative_inner_product(c3,c3)
 is null order by c1;
select negative_inner_product(c3,'[1,2.2,3]') ld_c3,negative_inner_product(c4,'[1,1.3,-1]') ld_c4 from t1 where negative_inner_product(c3,'[1,2,3]') > 0 or negative_inner_product(c3,c3) is null  and c1 >3 order by c1;



--echo ##between and
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int primary key, c2 VARCHAR(30),c3 vector(3) ,c4 vector(2),
VECTOR INDEX vector_idx(c3) 
WITH (distance=inner_product, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
insert into t1 values(1,'[1,1,2]','[2,2,3]','[1,3]');
insert into t1 values(2,'[1,2,3]','[1,2,3]','[2,3]');
insert into t1 values(3,'[-1,2,2]','[-3,2,3]','[4,3]');
insert into t1 values(4,'[-1,-2,-2]','[-4,2,3]',null);
insert into t1 values(5,'[-1,-2,-2]',null,'[2,3]');

select  * from t1 where 1 BETWEEN negative_inner_product(c3,c3)  and negative_inner_product(c3,'[1,2,3]') order by negative_inner_product(c3, [1,2,3])  limit 10;
select  * from t1 where 1 BETWEEN negative_inner_product(c3,c3)  and negative_inner_product(c3,'[1,2,3]') order by negative_inner_product(c3, [1,2,3]) approximate limit 10;

select  negative_inner_product(c3,'[1,2.2,3]') BETWEEN negative_inner_product(c3,c3)  and negative_inner_product(c3,'[1,2,3]') from t1 order by negative_inner_product(c3, [1,2,3])  limit 10;
select  negative_inner_product(c3,'[1,2.2,3]') BETWEEN negative_inner_product(c3,c3)  and negative_inner_product(c3,'[1,2,3]') from t1 order by negative_inner_product(c3, [1,2,3]) approximate limit 10;

select  negative_inner_product(c3,'[1,2.2,3]') BETWEEN negative_inner_product(c3,c3)  and negative_inner_product(c3,'[1,2,3]') from t1 where negative_inner_product(c3,'[1,2.2,3]') BETWEEN negative_inner_product(c3,c3)  and negative_inner_product(c3,'[1,2,3]') >1;




--echo ##like/not like
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int primary key, c2 VARCHAR(30),c3 vector(3) ,c4 vector(2),
VECTOR INDEX vector_idx(c3) 
WITH (distance=inner_product, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
insert into t1 values(1,'[1,1,2]','[2,2,3]','[1,3]');
insert into t1 values(2,'[1,0,3]','[1,0,3]','[2,3]');
insert into t1 values(3,'[-1,2,2]','[-3,2,3]','[4,3]');
insert into t1 values(4,'[-1,-2,-2]','[-4,2,3]',null);
insert into t1 values(5,'[-1,-3,-2]',null,'[2,3]');

select  * from t1 where negative_inner_product(c3,c3) like '%0%' order by negative_inner_product(c3, [1,2,3])  limit 10;
select  * from t1 where negative_inner_product(c3,c3) like negative_inner_product(c3,c2) order by negative_inner_product(c3, [1,2,3]) approximate limit 10;

select  * from t1 where negative_inner_product(c3,c3) not like '%1%' order by c1;
select  * from t1 where negative_inner_product(c3,c3) not like negative_inner_product(c3,c2) order by c1;


--echo ##exists,any,all,in(无关键字)
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int primary key, c2 VARCHAR(30),c3 vector(3) ,c4 vector(3),
VECTOR INDEX vector_idx(c3) 
WITH (distance=inner_product, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
insert into t1 values(1,'[1,1,2]','[2,2,3]','[1,3,2]');
insert into t1 values(2,'[1,0,3]','[1,0,3]','[2,3,2]');
insert into t1 values(3,'[-1,2,2]','[-3,2,3]','[4,3,3]');
insert into t1 values(4,'[-1,-2,-2]','[-4,2,3]',null);
insert into t1 values(5,'[-1,-3,-2]',null,'[2,3,1]');

SELECT negative_inner_product(c3,c4) from t1 where  EXISTS (SELECT negative_inner_product(c3,[1,null,1]) FROM t1) order by c1;
SELECT c3 from t1 where  EXISTS (SELECT c3 FROM t1) order by c1;
SELECT negative_inner_product(c3,c4) from t1 where negative_inner_product(c3,c3) = any (SELECT negative_inner_product(c3,[1,-1,1]) FROM t1) order by c1;
SELECT negative_inner_product(c3,c4) from t1 where negative_inner_product(c3,c3) >= any (SELECT negative_inner_product(c3,[1,-1,1]) FROM t1) order by c1;
SELECT negative_inner_product(c3,c4) from t1 where negative_inner_product(c3,c3) <= any (SELECT negative_inner_product(c3,[1,-1,1]) FROM t1) order by c1;
SELECT negative_inner_product(c3,c4) from t1 where negative_inner_product(c3,c3) <> any (SELECT negative_inner_product(c3,[1,-1,1]) FROM t1) order by c1;
SELECT negative_inner_product(c3,c4) from t1 where negative_inner_product(c3,c3) != any (SELECT negative_inner_product(c3,[1,-1,1]) FROM t1) order by c1;
SELECT negative_inner_product(c3,c4) from t1 where negative_inner_product(c3,c3) > any (SELECT negative_inner_product(c3,[1,-1,1]) FROM t1) order by c1;
SELECT negative_inner_product(c3,c4) from t1 where negative_inner_product(c3,c3) < any (SELECT negative_inner_product(c3,[1,-1,1]) FROM t1) order by c1;


SELECT negative_inner_product(c3,c4) from t1 where  EXISTS (SELECT negative_inner_product(c3,c3) FROM t1) order by c1;
SELECT c3 from t1 where  EXISTS (SELECT c3 FROM t1) order by c1;
SELECT negative_inner_product(c3,c4) from t1 where negative_inner_product(c3,c3) = any (SELECT negative_inner_product(c3,c4) FROM t1) order by c1;
SELECT negative_inner_product(c3,c4) from t1 where negative_inner_product(c3,c3) >= any (SELECT negative_inner_product(c3,c4) FROM t1) order by c1;
SELECT negative_inner_product(c3,c4) from t1 where negative_inner_product(c3,c3) <= any (SELECT negative_inner_product(c3,c4) FROM t1) order by c1;
SELECT negative_inner_product(c3,c4) from t1 where negative_inner_product(c3,c3) <> any (SELECT negative_inner_product(c3,c4) FROM t1) order by c1;
SELECT negative_inner_product(c3,c4) from t1 where negative_inner_product(c3,c3) != any (SELECT negative_inner_product(c3,c4) FROM t1) order by c1;
SELECT negative_inner_product(c3,c4) from t1 where negative_inner_product(c3,c3) > any (SELECT negative_inner_product(c3,c4) FROM t1) order by c1;
SELECT negative_inner_product(c3,c4) from t1 where negative_inner_product(c3,c3) < any (SELECT negative_inner_product(c3,c4) FROM t1) order by c1;


SELECT negative_inner_product(c3,c4) from t1 where negative_inner_product(c3,c3) in (negative_inner_product(c3,c3),negative_inner_product(c3,c4)) order by c1;
