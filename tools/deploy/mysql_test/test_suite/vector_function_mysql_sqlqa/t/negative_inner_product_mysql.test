--echo ##旁路导入
##普通表旁路导入
--disable_warnings
drop table if exists t1;
drop view if exists v1;
--enable_warnings

CREATE TABLE t1 (c1 int , c2 VARCHAR(30),c3 vector(3) ,c4 vector(3));
insert into t1(c1,c2,c3,c4) values(1,'[1,1,2]','[2,2,3]','[1,3,2]');
insert into t1(c1,c2,c3,c4) values(2,'[1,0,3]','[1,0,3]','[2,3,2]');
insert into t1(c1,c2,c3,c4) values(3,'[-1,2,2]','[-3,2,3]','[4,3,3]');
insert into t1(c1,c2,c3,c4) values(4,'[-1,-2,-2]','[-4,2,3]',null);
insert into t1(c1,c2,c3,c4) values(5,'[-1,-3,-2]',null,'[2,3,1]');
create view v1 as select * from t1;
insert /*+ direct(true,100) enable_parallel_dml parallel(2)*/ into v1(c1) select negative_inner_product(c2,c3) from t1;
insert  into t1 select c1,c2,c3,c4 from t1;
insert /*+ direct(true,100) enable_parallel_dml parallel(2) append*/ into t1(c1) select negative_inner_product(c2,c3) from t1;
insert /*+ direct(true,100) enable_parallel_dml parallel(2) append*/ into t1 select c1,c2,c3,c4 from t1;
insert /*+ enable_parallel_dml parallel(2) */ into t1(c1) select negative_inner_product(c2,c3) from t1;

##分区表旁路导入--导致core
--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1(c1 int, c2 vector(3)) partition by hash(c1);
insert into t1 values(1,'[1,1,3]');
insert into t1 values(2,'[1,2,4]');
insert into t1 values(3,'[2,4,1]');
insert /*+ direct(true,100) enable_parallel_dml parallel(2) append*/ into t1(c2) select sum(c2) from t1;
insert /*+ direct(true,100) enable_parallel_dml parallel(2) append*/ into t1(c2) select sum(c2) from t1;
insert /*+ direct(true,100) enable_parallel_dml parallel(2) append*/ into t1(c2) select sum(c2)+avg(c2) from t1;
insert /*+ direct(true,100) enable_parallel_dml parallel(2) append*/ into t1(c2) select sum(c2)+avg(c2) from t1;
select count(negative_inner_product(c2,[1,2,3])) from t1 order by c1;
select sum(negative_inner_product(c2,[1,2,3])) from t1 order by c1;
select avg(negative_inner_product(c2,[1,2,3])) from t1 order by c1;
select min(negative_inner_product(c2,[1,2,3])) from t1 order by c1;
select max(negative_inner_product(c2,[1,2,3])) from t1 order by c1;
select distinct negative_inner_product(c2,[1,2,3]) from t1 order by c1;


