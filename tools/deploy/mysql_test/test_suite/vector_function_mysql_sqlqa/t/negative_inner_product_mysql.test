SELECT count(c1), CASE WHEN negative_inner_product(C2,[1,2,3]) > negative_inner_product([1,1,1],a3) THEN 'High' ELSE 'Low' END AS A FROM T1,t2 ;
##导致core  --已修复
SELECT count(*) FROM t1,t2 where negative_inner_product(t1.C2, t2.A2) < 0.5;
##导致core --已修复
SELECT count(c1), CASE WHEN negative_inner_product(C2,[1,2,3]) > negative_inner_product([1,1,1],a3) THEN 'High' ELSE 'Low' END AS A FROM T1,t2 ;

SELECT C1, CASE WHEN negative_inner_product(C2,[1,2,3]) > 5 THEN 'High' ELSE 'Low' END AS A FROM T1,t2 limit 1;

##--error 4016  已修复
SELECT t1.C1, 
       CASE 
           WHEN negative_inner_product(t1.C2, t2.A2) > 10 THEN 'Far'
           WHEN negative_inner_product(t1.C3, t2.A3) BETWEEN 5 AND 10 THEN 'Medium'
           ELSE 'Close'
       END AS distance_category,
       avg(t1.C2) OVER (PARTITION BY t1.C1) AS avg_vector
FROM T1 t1
JOIN T2 t2 ON t1.C1 = t2.A1
WHERE negative_inner_product(t1.C2, t2.A2) < 0.5;


