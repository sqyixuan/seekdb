--echo ##binary
--disable_warnings
drop table if exists t1;
--enable_warnings

CREATE TABLE t1 (c1 int PRIMARY KEY, c2 binary(12),c3 vector(3),
VECTOR INDEX vector_idx(c3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
insert into t1 values(1,0x0000803F0000803F00000040,'[2,2,3]');
insert into t1 values(2,0x000000400000004000004040,'[3,2,3]');
insert into t1 values(3,0x0000E8410000004000000040,'[3,2,3]');
insert into t1 values(4,0x000080BF000000C0000000C0,'[3,2,3]');
select vector_norm(c2) from t1 order by c1;
select vector_norm(c3) from t1 order by c1;

