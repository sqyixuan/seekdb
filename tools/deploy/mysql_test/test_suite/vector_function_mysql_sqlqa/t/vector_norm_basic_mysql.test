#owner: gehao.wh
#owner group: 多模
#description: vector_basic
#tags:vector_basic
#author: wb-ljh01399065
purge recyclebin;
--disable_warnings
drop database IF EXISTS obljh;
--enable_warnings
create database obljh ;
use obljh;
set timestamp = 1600000000;
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;
set ob_default_lob_inrow_threshold = 0;

alter system set ob_vector_memory_limit_percentage =44;

--echo ##参数个数验证
--echo ##单个参数
select vector_norm(null) from dual;

--error 1582
select vector_norm() from dual;
--error 4152
select vector_norm('') from dual;
--error 3140
select vector_norm("_") from dual;
--error 1582
select vector_norm(               ) from dual;
--error 1210
select vector_norm(999999999999999999999999999) from dual;
--error 1054
select vector_norm(中文) from dual;
--error 1210
select vector_norm(true) from dual;
--error 1210
select vector_norm(false) from dual;
--error 1210
select vector_norm('1111') from dual;
--error 1210
select vector_norm(+10) from dual;
--error 1210
select vector_norm(-10) from dual;
--error 1210
select vector_norm(1.111) from dual;

select vector_norm([1]) from dual;
--error 4152
select vector_norm([null]) from dual;

--echo ##多维度值为入参

select vector_norm([1,2]) from dual;
select vector_norm([2,1]) from dual;
select vector_norm([1,2,3]) from dual;
select vector_norm([2,1,3,4]) from dual;
--error 4152
select vector_norm([2,1,null,4]) from dual;

select vector_norm([2,1,false,4]) from dual;
--error 4152
select vector_norm([2,1,abs(null),4]) from dual;

select vector_norm([2,1,abs(''),4]) from dual;

select vector_norm([2,1,abs('-100'),4]) from dual;
--error 4152
select vector_norm([2,1,1/0,4]) from dual;
--error 4152
select vector_norm([2,1,null,4]) from dual;

select vector_norm([0.1]) from dual;
select vector_norm([0.001]) from dual;

--echo ##v1,v2都是一维数组
select vector_norm([-1,1]) from dual;
select vector_norm(['1000000.1']) from dual;
select vector_norm([1]) from dual;
select vector_norm([ 1                                        ]) from dual;
select vector_norm([-1.1]) from dual;
select vector_norm([0]) from dual;
select vector_norm(['']) from dual;




--error 1064
select vector_norm(?) from dual;
--error 3140
select vector_norm('[?,?,?,?,?????????????]') from dual;
--error 1064
select vector_norm([???????????????????????????????????????????????????????????????????????????????????????????????????]) from dual;
--error 3140
select vector_norm('[#$%%%%%%%]') from dual;
--error 3140
select vector_norm('0x5461626c65') from dual;
--error 3140
select vector_norm(CHARSET(0x5461626c65)) from dual;
--error 1235
select vector_norm(X'01AF') from dual;
--error 1210
select vector_norm('10101') from dual;
--error 3140
select vector_norm('0x48656C6C6F20576F726C64') from dual;
--error 1235
select vector_norm(b'11') from dual;
--error 1064
select vector_norm(0B11) from dual;
--error 3140
select vector_norm('[0B11]') from dual;
--error 3140
select vector_norm('abscaa') from dual;
--error 3140
select vector_norm('中文') from dual;
--error 3140
select vector_norm('中文ing23') from dual;
--error 1210
select vector_norm(10) from dual;
--error 1210
select vector_norm('-147777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777770') from dual;
--error 1210
select vector_norm(''+'') from dual;
--error 1210
select vector_norm(''+null) from dual;
--error 1210
select vector_norm(null+null) from dual;


--error 1582
select vector_norm(true,true) from dual;
--error 1582
select vector_norm(' ',' ') from dual;
--error 1210
select vector_norm(1.11) from dual;
--error 1292
select vector_norm(['中问ings']) from dual;
--error 1292
select vector_norm(['中问ings']) from dual;
select vector_norm(['-10001']) from dual;
select vector_norm([1/1]) from dual;

set @a=999;
select vector_norm([@a]) from dual;
select vector_norm([@a+@a]) from dual;

set @a='[999,99,21]';
set @b='[999,9,21]';
select vector_norm(@a) from dual;
select vector_norm(@b) from dual;


select vector_norm([-147777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777770,100]) as a from dual;


--echo ##三维数组
select vector_norm([1,1,3]) from dual;
--error 3140
select vector_norm('[1000000.1,'','']') from dual;
--error 3140
select vector_norm('[1,100,'']') from dual;
select vector_norm([ 1                               ,1         ,   1]) from dual;
select vector_norm([+1,-1,1.021]) from dual;
select vector_norm([-1.1,-1,-100]) from dual;
select vector_norm([0,0,0]) from dual;
select vector_norm([0,1,1]) from dual;
select vector_norm([0,false,false]) from dual;
select vector_norm(['','','']) from dual;
--error 1241
select vector_norm(('','','')) from dual;

--error 4152
select vector_norm(['',null,'']) from dual;
--error 4152
select vector_norm([null,1,1]) from dual;
--error 4152
select vector_norm([1,null,null]) from dual;
--error 1235
select vector_norm([null,[1],[1]]) from dual;

--error 1064
select vector_norm({false,false,false}) from dual;

select vector_norm([false,false,false]) from dual;

select vector_norm([1,1/1,1*1]) from dual;

--echo ##超过三维
select vector_norm('[1.11,2,2,1000]') from dual;
select vector_norm('[1.11,2,2,1000,100]') from dual;
select vector_norm('[1.11,2,2,1000,100,1,100,1]') from dual;
select vector_norm('[1.11,2,2,1000,100,1,3,100,100,1]') from dual;
select vector_norm('[1.11,2,2,1000,100,1,1,1,3,100,100,1]') from dual;
select vector_norm('[1,1,3,100,100,1,1,1,3,100,100,1,10000]') from dual;
select vector_norm('[1,1,2,100,100,1,10000,1.11,2,2,1000,100,1,1,1,3,100,100,1,10000,1.11,2,2,1000,100,1,1,1,3,100,100,1,10000]') from dual;


--echo ##运算符
select vector_norm('[1,1,1]') || vector_norm('[1,1,1]');
select vector_norm([1.11,2,2,1000]) * vector_norm([1,1,3,100]);

--echo ##数据类型验证
--echo ##数值类型(INTEGER、SMALLINT、DECIMAL 和 NUMERIC)
--disable_warnings
drop table if exists t1;
--enable_warnings

CREATE TABLE t1 (c1 int PRIMARY KEY,c2 INTEGER,c3 SMALLINT,c4 DECIMAL(10,2),c5 NUMERIC(10,2));
INSERT INTO t1 (c1, c2, c3, c4, c5) VALUES (1, 100, 20, 3.14, NULL);
INSERT INTO t1 (c1, c2, c3, c4, c5) VALUES (2, 200, 40, NULL, NULL);
INSERT INTO t1 (c1, c2, c3, c4, c5) VALUES (3, 300, 60, 6.28, 7.89);
INSERT INTO t1 (c1, c2, c3, c4, c5) VALUES (4, 400, NULL, 8.56, 9.12);
INSERT INTO t1 (c1, c2, c3, c4, c5) VALUES (5, NULL, 100, NULL, 11.22);

--error 1210
select vector_norm(c2),c2,* from t1 where c2 is not null order by c1;
select vector_norm([c2]),c2,* from t1 where c2 is not null order by c1;

--error 1210
select vector_norm(c3),c3,* from t1 where c3 is not null order by c1;
select vector_norm([c3]),c3,* from t1 where c3 is not null order by c1;


--error 1210
select vector_norm(c4),c2,* from t1 where c4 is not null order by c1;
select vector_norm([c4]),c4,* from t1 where c4 is not null order by c1;

--error 1210
select vector_norm(c5),c5,* from t1 where c5 is not null order by c1;
select vector_norm([c5]),c5,* from t1 where c5 is not null order by c1;



--echo ##浮点类型(float,double)
--disable_warnings
drop table if exists t1;
--enable_warnings

CREATE TABLE t1 (c1 int PRIMARY KEY, c2 float,c3 double);
INSERT INTO t1 (c1, c2, c3) VALUES (1, 1.1, 1.11);
INSERT INTO t1 (c1, c2, c3) VALUES (2, 2.2, NULL);
INSERT INTO t1 (c1, c2, c3) VALUES (3, NULL, 3.33);
INSERT INTO t1 (c1, c2, c3) VALUES (4, NULL, NULL);
INSERT INTO t1 (c1, c2, c3) VALUES (5, 5.5, NULL);
select vector_norm([c2]),c2,* from t1 where c2 is not null order by c1;
select vector_norm([c3]),c3,* from t1 where c3 is not null order by c1;


--echo ##bit类型
--disable_warnings
drop table if exists t1;
--enable_warnings

CREATE TABLE t1 (c1 int PRIMARY KEY, c2 bit(10));
INSERT INTO t1 (c1, c2) VALUES (1, b'1');
INSERT INTO t1 (c1, c2) VALUES (2, b'0');
INSERT INTO t1 (c1, c2) VALUES (3, b'10');
INSERT INTO t1 (c1, c2) VALUES (4, 1);
INSERT INTO t1 (c1, c2) VALUES (5, null);
INSERT INTO t1 (c1, c2) VALUES (6, b'0111');
--error 1210
select vector_norm(c2),c2,* from t1 where c2 is not null order by c1;
--error 1235
select vector_norm([c2]),* from t1 where c2 is not null  order by c1;


--echo ##bool
--disable_warnings
drop table if exists t1;
--enable_warnings

CREATE TABLE t1 (c1 int PRIMARY KEY, c2 bool);
INSERT INTO t1 (c1, c2) VALUES (1, 1);
INSERT INTO t1 (c1, c2) VALUES (2, 0);
INSERT INTO t1 (c1, c2) VALUES (3,false);
INSERT INTO t1 (c1, c2) VALUES (4, 100);
INSERT INTO t1 (c1, c2) VALUES (5, null);
INSERT INTO t1 (c1, c2) VALUES (6, true);

--error 1210
select vector_norm(c2),c2,* from t1 where c2 is not null order by c1;
select vector_norm([c2]),* from t1 where c2 is not null  order by c1;




--echo ##扩展类型(TINYINT、MEDIUMINT 和 BIGINT)
--disable_warnings
drop table if exists t1;
--enable_warnings

CREATE TABLE t1 (c1 int PRIMARY KEY, c2 TINYINT,c3 MEDIUMINT,c4 BIGINT);
INSERT INTO t1 (c1, c2, c3, c4) VALUES (1, 10, 100, 1000);
INSERT INTO t1 (c1, c2, c3, c4) VALUES (2, 20, 200, NULL);
INSERT INTO t1 (c1, c2, c3, c4) VALUES (3, 30, NULL, NULL);
INSERT INTO t1 (c1, c2, c3, c4) VALUES (4, 40, NULL, NULL);
INSERT INTO t1 (c1, c2, c3, c4) VALUES (5, 127, 8388607, 9223372036854775807);

--error 1210
select vector_norm(c2),c2,* from t1 where c2 is not null order by c1;
select vector_norm([c2]),c2,* from t1 where c2 is not null order by c1;

--error 1210
select vector_norm(c3),c3,* from t1 where c3 is not null order by c1;
--error 1235
select vector_norm([c3]),c3,* from t1 where c3 is not null order by c1;

--error 1210
select vector_norm(c4),c2,* from t1 where c4 is not null order by c1;
select vector_norm([c4]),c4,* from t1 where c4 is not null order by c1;


--echo ##日期时间类型(DATE、TIME、DATETIME、TIMESTAMP 、YEAR) --预期不支持
--disable_warnings
drop table if exists t1;
--enable_warnings

CREATE TABLE t1 (c1 int PRIMARY KEY, c2 DATE,c3 TIME,c4 DATETIME(6),c5 TIMESTAMP,c6 YEAR);
INSERT INTO t1 (c1, c2, c3, c4, c5, c6) VALUES (1, '2023-04-01', '12:34:56', '2023-04-01 12:34:56', '2023-04-01 12:34:56', 2023);
INSERT INTO t1 (c1, c2, c3, c4, c5, c6) VALUES (2, '2023-04-02', '13:45:00', NULL, '2023-04-02 13:45:00', 2023);
INSERT INTO t1 (c1, c2, c3, c4, c5, c6) VALUES (3, NULL, NULL, '2023-04-03 01:23:45', '2023-04-03 01:23:45', 2023);
INSERT INTO t1 (c1, c2, c3, c4, c5, c6) VALUES (4, NULL, NULL, NULL, '2023-04-04 00:00:00', NULL);
INSERT INTO t1 (c1, c2, c3, c4, c5, c6) VALUES (5, '2023-04-05', '02:30:00', '2023-04-05 02:30:00', '2023-04-05 02:30:00', NULL);

--error 1210
select vector_norm(c2),c2,* from t1 where c2 is not null order by c1;
--error 1235
select vector_norm([c2]),c2,* from t1 where c2 is not null order by c1;


--error 1210
select vector_norm(c3),c3,* from t1 where c3 is not null order by c1;
--error 1235
select vector_norm([c3]),c3,* from t1 where c3 is not null order by c1;


--error 1210
select vector_norm(c4),c2,* from t1 where c4 is not null order by c1;
--error 1235
select vector_norm([c4]),c4,* from t1 where c4 is not null order by c1;


--error 1210
select vector_norm(c5),c5,* from t1 where c5 is not null order by c1;
--error 1235
select vector_norm([c5]),c5,* from t1 where c5 is not null order by c1;


--error 1210
select vector_norm(c6),c6,* from t1 where c6 is not null order by c1;
--error 1235
select vector_norm([c6]),c6,* from t1 where c6 is not null order by c1;


--echo ##CHAR
--disable_warnings
drop table if exists t1;
--enable_warnings

CREATE TABLE t1 (c1 int PRIMARY KEY, c2 char(30),c3 vector(3),
VECTOR INDEX vector_idx(c3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
insert into t1 values(1,'[1,1,2]','[2,2,3]');
insert into t1 values(2,'[2,2,3]','[3,2,3]');
insert into t1 values(3,'[29,2,2]','[3,2,3]');
insert into t1 values(4,'[-1,-2,-2]','[3,2,3]');
select vector_norm(c2) from t1 order by c1;
select vector_norm(c3) from t1 order by c1;


--echo ##VARCAHR
--disable_warnings
drop table if exists t1;
--enable_warnings

CREATE TABLE t1 (c1 int PRIMARY KEY, c2 VARCHAR(30),c3 vector(3),
VECTOR INDEX vector_idx(c3) 
