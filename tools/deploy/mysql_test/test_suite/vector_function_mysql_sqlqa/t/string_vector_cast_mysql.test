#owner group: 多模
#description: string_vector
#tags:vector
#author: wb-ljh01399065

purge recyclebin;

--disable_warnings
drop database IF EXISTS obljh;
--enable_warnings

create database obljh ;
use obljh;
set timestamp = 1600000000;
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;
set ob_default_lob_inrow_threshold = 0;

alter system set ob_vector_memory_limit_percentage =44;
set ob_query_timeout  = 3216672000000000;

--echo ##CHAR
drop table if exists t1;
CREATE TABLE t1 (c1 int PRIMARY KEY, c2 char(30),c3 vector(3),
VECTOR INDEX vector_idx(c3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=64, ef_construction=100, ef_search=40));
insert into t1 values(1,'[1,1,2]','[2,2,3]');
insert into t1 values(2,'[2,2,3]','[3,2,3]');
insert into t1 values(3,'[29,2,2]','[3,2,3]');
insert into t1 values(4,'[-1,-2,-2]','[3,2,3]');
select l2_distance([1.1001,1.2001,3.1001],c2) from t1 order by c1;
select l2_distance(c3,c2) from t1 order by c1;
select l1_distance([1.1001,1.2001,3.1001],c2) from t1 order by c1;
select l1_distance(c3,c2) from t1 order by c1;

select l2_distance('[11,11,3]',c2) from t1  order by c1;
select l1_distance('[11,11,3]',c2) from t1  order by c1;
select l1_distance('[1.1,1.1,3]',c2) from t1  order by c1;
select l1_distance(c3,c2) from t1  order by c1;
select cosine_distance('[1.1001,1.2001,3.1001]',c2) from t1  order by c1;
select inner_product('[1.1001,1.2001,3.1001]',c2) from t1  order by c1;
select vector_distance('[1.1001,1.2001,3.1001]',c2) from t1  order by c1;
select vector_norm(c2) from t1  order by c1;
select vector_dims(c2) from t1  order by c1;


