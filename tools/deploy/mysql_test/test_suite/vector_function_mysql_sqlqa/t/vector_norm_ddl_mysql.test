purge recyclebin;
--disable_warnings
drop database IF EXISTS obljh;
--enable_warnings
create database obljh ;
use obljh;
set timestamp = 1600000000;
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;
set ob_default_lob_inrow_threshold = 0;

alter system set ob_vector_memory_limit_percentage =44;


--echo ##create table as select 
--disable_warnings
drop table if exists t1;
--enable_warnings

--error 4152
create table t1 as select vector_norm('') from dual;
create table t1 as select vector_norm(null) from dual;
--error 1235
create table t1 as select vector_norm([null,[null]]) from dual;

--error 1210
create table t1 as select vector_norm(1) from dual;

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1 as select vector_norm([1,1,2]) a from dual;
select * from t1;
--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1 as select vector_norm([1,1,2]) a,vector_norm([1,1,2]) b from dual;
select * from t1;
--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1 as select vector_norm([1,12,2]) a,vector_norm([1,1,2]) b from dual;
select * from t1;

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1 as select vector_norm(null) a,vector_norm([1,11,2]) b,vector_norm([1,1,211]) c,vector_norm([1,1,211]) d,vector_norm([1,1,2]) e,vector_norm([1,1,211]) f from dual;
select * from t1;

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1 as select vector_norm([1,0.01,2]) a,vector_norm([1,11,2]) b,vector_norm([1,1,2]) c,vector_norm([1,1,2]) d,vector_norm([1,1,2]) e,vector_norm([1,1,2]) f from dual;

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1 as select vector_norm([false]) a,vector_norm([true]) b,vector_norm([true]) c,vector_norm([true+false]) d from dual;
select * from t1;

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1 as select vector_norm([99999999]),vector_norm([-100]) b,vector_norm([false]) c,vector_norm([8+8]) d  from dual;
select * from t1;

--disable_warnings
drop table if exists t1;
--enable_warnings

--error 3140
create table t1 as select vector_norm('[?,?,?,?,?????????????]') from dual;
--error 1210
create table t1 as select vector_norm('101')a,vector_norm('101')b,vector_norm('101')c from dual;
--error 1059
create table t1 as select vector_norm('-147777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777770'),vector_norm('-147777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777777770') from dual;
--error 3140
create table t1 as select vector_norm('0x48656C6C6F20576F726C64')a,vector_norm('0x48656C6C6F20576F726C64')b,vector_norm('0x48656C6C6F20576F726C64')c from dual;

--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1 as select vector_norm([true]) a,vector_norm([false]) b,vector_norm([false]) c,vector_norm([true+false]) d from dual union select vector_norm([false]) e,vector_norm([true]) f,vector_norm([true]) g,vector_norm([true+false]) h from dual;

--disable_warnings
drop table if exists t1;
drop table if exists tt1;
drop table if exists tt2;
--enable_warnings
CREATE TABLE t1 (c1 int primary key, c2 vector(3),c3 vector(3) ,c4 vector(3),
VECTOR INDEX vector_idx(c3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
insert into t1(c1,c2,c3,c4) values(1,'[1,1,2]','[2,2,3]','[1,3,2]');
insert into t1(c1,c2,c3,c4) values(2,'[1,0,3]','[1,0,3]','[2,3,2]');
insert into t1(c1,c2,c3,c4) values(3,'[-1,2,2]','[-3,2,3]','[4,3,3]');
insert into t1(c1,c2,c3,c4) values(4,'[-1,-2,-2]','[-4,2,3]',null);
insert into t1(c1,c2,c3,c4) values(5,'[-1,-3,-2]',null,'[2,3,1]');
create  table tt1  as select count(*) cnt, count(c3) cnt_c3, sum(c3) sum_c3 from t1 ;
create  table tt2  as select count(*) cnt, count(c3) cnt_c3, avg(c3) avg_c3 from t1 ;
select * from tt1 order by cnt;
select * from tt2 order by cnt;

##多表连接
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int primary key, c2 vector(3),c3 vector(3) ,c4 vector(3),
VECTOR INDEX vector_idx(c3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
insert into t1(c1,c2,c3,c4) values(1,'[1,1,2]','[2,2,3]','[1,3,2]');
insert into t1(c1,c2,c3,c4) values(2,'[1,0,3]','[1,0,3]','[2,3,2]');
insert into t1(c1,c2,c3,c4) values(3,'[-1,2,2]','[-3,2,3]','[4,3,3]');
insert into t1(c1,c2,c3,c4) values(4,'[-1,-2,-2]','[-4,2,3]',null);
insert into t1(c1,c2,c3,c4) values(5,'[-1,-3,-2]',null,'[2,3,1]');

--disable_warnings
drop table if exists t2;
--enable_warnings
CREATE TABLE t2 (a1 int primary key , a2 vector(3),a3 vector(3) ,a4 vector(3),
VECTOR INDEX vector_idx(a3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
show index from t2;
show index from t1;
insert into t2 select c1,c2,c3,c4 from t1 where c3 is not null and c4 is not null;


--disable_warnings
drop table if exists tt0;
drop table if exists tt1;
drop table if exists tt2;
--enable_warnings

create table tt0 as select c2+c3 from t1 ;
create table tt1 as select vector_norm(a3) a,vector_norm(c4) b,c1,a1,a3,c2 from t1 join t2 on c1=a1 ;
create table tt2 as select c2+c3+c4,a2+c3+c2 from t1 join t2 on c1=a1 ;

select vector_norm(c2) from tt1 ;
select count(*) from t1,t2,tt1;

--error 1235
select vector_norm(c2),vector_norm(a3),vector_norm(c2),vector_norm(c2),vector_norm(a3),vector_norm(a3),(select vector_norm(a3) from t2 order by vector_norm(a3) APPROX limit 1) from tt1 ;


##物化视图结合关键字使用  --不支持创建向量索引
--disable_warnings
drop view if exists v1;
drop table if exists t1;
drop materialized view if exists mv1;
--enable_warnings

CREATE TABLE t1 (c1 int primary key, c2 vector(3),c3 vector(3) ,c4 vector(3),
VECTOR INDEX vector_idx(c3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
insert into t1(c1,c2,c3,c4) values(1,'[1,1,2]','[2,2,3]','[1,3,2]');
insert into t1(c1,c2,c3,c4) values(2,'[1,0,3]','[1,0,3]','[2,3,2]');
insert into t1(c1,c2,c3,c4) values(3,'[-1,2,2]','[-3,2,3]','[4,3,3]');
insert into t1(c1,c2,c3,c4) values(4,'[-1,-2,-2]','[-4,2,3]',null);
insert into t1(c1,c2,c3,c4) values(5,'[-1,-3,-2]',null,'[2,3,1]');
create materialized view mv1  parallel 2 refresh complete on demand  as select * from t1 ;
##导致hang住 已修复
--error 1235  
CREATE VECTOR INDEX vector_idx  ON mv1 (c2)  WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=10, ef_search=40);



##普通视图结合关键字使用
--disable_warnings
drop view if exists v1;
drop table if exists t1;
drop materialized view if exists mv1;
--enable_warnings
CREATE TABLE t1 (c1 int primary key, c2 vector(3),c3 vector(3) ,c4 vector(3),
VECTOR INDEX vector_idx(c3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
insert into t1(c1,c2,c3,c4) values(1,'[1,1,2]','[2,2,3]','[1,3,2]');
insert into t1(c1,c2,c3,c4) values(2,'[1,0,3]','[1,0,3]','[2,3,2]');
insert into t1(c1,c2,c3,c4) values(3,'[-1,2,2]','[-3,2,3]','[4,3,3]');
insert into t1(c1,c2,c3,c4) values(4,'[-1,-2,-2]','[-4,2,3]',null);
insert into t1(c1,c2,c3,c4) values(5,'[-1,-3,-2]',null,'[2,3,1]');
create  view v1 as select * from t1 ; 
--error 1235
select vector_norm(c3) from v1  group by vector_norm(c3) order by vector_norm(c3) APPROX limit 10;
--error 1235
select vector_norm(c2) from v1  group by vector_norm(c3) order by vector_norm(c3) APPROX limit 100000000;

select  c4+c3+c2 from v1 order by vector_norm(c3)  limit 100000000;
select  c4+c3+c2 from v1 order by vector_norm(c3)  limit 10;


##创建多表join的物化视图
--disable_warnings
drop table if exists t1;
drop view if exists v1;
drop table if exists t2;
drop materialized view if exists mv1;
--enable_warnings

CREATE TABLE t1 (c1 int primary key, c2 varchar(30),c3 vector(3) ,c4 vector(3),
VECTOR INDEX vector_idx(c3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40))PARTITION BY KEY(c1) PARTITIONS 4;
insert into t1(c1,c2,c3,c4) values(1,'[1,1,2]','[2,2,3]','[1,3,2]');
insert into t1(c1,c2,c3,c4) values(2,'[1,0,3]','[1,0,3]','[2,3,2]');
insert into t1(c1,c2,c3,c4) values(3,'[-1,2,2]','[-3,2,3]','[4,3,3]');

drop table if exists t2;
CREATE TABLE t2 (a1 int , a2 vector(3),a3 vector(3) ,a4 vector(3),
VECTOR INDEX vector_idx(a3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
insert into t2 select c1,c2,c3,c4 from t1;
--error 1235
select * from t1,t2 where c3=a3 order by vector_norm(c3) APPROX limit 10;
--error 1235
create materialized view mv1   refresh complete on demand  as select * from t1,t2 where c2=a2 order by vector_norm(c3) APPROX limit 10;





##聚合函数作为列的物化视图
--disable_warnings
drop table if exists t1;
drop view if exists v1;
drop view if exists v2;
drop materialized view if exists mv1;
drop materialized view if exists mv2;
--enable_warnings

CREATE TABLE t1 (c1 int primary key, c2 vector(3),c3 vector(3) ,c4 vector(3),
VECTOR INDEX vector_idx(c3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
insert into t1(c1,c2,c3,c4) values(1,'[1,1,2]','[2,2,3]','[1,3,2]');
insert into t1(c1,c2,c3,c4) values(2,'[1,0,3]','[1,0,3]','[2,3,2]');
insert into t1(c1,c2,c3,c4) values(3,'[-1,2,2]','[-3,2,3]','[4,3,3]');
insert into t1(c1,c2,c3,c4) values(4,'[-1,-2,-2]','[-4,2,3]',null);
insert into t1(c1,c2,c3,c4) values(5,'[-1,-3,-2]',null,'[2,3,1]');
create materialized view mv1 refresh complete on demand  as select count(*) cnt, count(c3) cnt_c3, sum(c3) sum_c3 from t1 ;
create materialized view mv2 refresh complete on demand  as select * from t1 order by vector_norm(c3)  limit 1000;
create  view v1  as select * from t1 ;
create  view v2  as select count(*) cnt, count(c3) cnt_c3, sum(c3) sum_c3 from t1 order by vector_norm(c3)  limit 1000;
select vector_norm(sum_c3) from mv1 order by cnt;
--error 1235
select vector_norm(c3) from v1  order by vector_norm(c3) APPROX limit 1000;
--error 1054
select vector_norm(c3) from v2 order by cnt;



###创建物化视图
--disable_warnings
drop table if exists t1;
drop table if exists tt1;
drop table if exists tt2;
drop materialized view if exists mv1;
drop materialized view if exists mv2;
--enable_warnings

CREATE TABLE t1 (c1 int primary key, c2 vector(3),c3 vector(3) ,c4 vector(3),
VECTOR INDEX vector_idx(c3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
create materialized view mv1  parallel 2 refresh complete on demand  as select c1,c2,vector_norm(c4) from t1 order by c1;
create materialized view mv2  parallel 2 refresh complete on demand  as select c1,c2,vector_norm(c3) from t1 limit 1;
insert into t1(c1,c2,c3,c4) values(1,'[1,1,2]','[2,2,3]','[1,3,2]');
insert into t1(c1,c2,c3,c4) values(2,'[1,0,3]','[1,0,3]','[2,3,2]');
insert into t1(c1,c2,c3,c4) values(3,'[-1,2,2]','[-3,2,3]','[4,3,3]');
insert into t1(c1,c2,c3,c4) values(4,'[-1,-2,-2]','[-4,2,3]',null);
insert into t1(c1,c2,c3,c4) values(5,'[-1,-3,-2]',null,'[2,3,1]');
CALL DBMS_MVIEW.REFRESH('mv1','c');
CALL DBMS_MVIEW.REFRESH('mv2','c');
create table tt1 select vector_norm(c2) from mv1 order by c1;
create table tt2 select vector_norm(c2) from mv2 order by c1;



##mv join mv
--disable_warnings
drop table if exists t1;
drop materialized view if exists mv1;
drop materialized view if exists mv2;
--enable_warnings

CREATE TABLE t1 (c1 int primary key, c2 vector(3),c3 vector(3) ,c4 vector(3),
VECTOR INDEX vector_idx(c3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
insert into t1(c1,c2,c3,c4) values(1,'[1,1,2]','[2,2,3]','[1,3,2]');
insert into t1(c1,c2,c3,c4) values(2,'[1,0,3]','[1,0,3]','[2,3,2]');
insert into t1(c1,c2,c3,c4) values(3,'[-1,2,2]','[-3,2,3]','[4,3,3]');
insert into t1(c1,c2,c3,c4) values(4,'[-1,-20,-2]','[-4,2,3]',null);
insert into t1(c1,c2,c3,c4) values(5,'[-1,-30,-2]',null,'[2,3,1]');
create materialized view mv1  refresh complete on demand  as select c1,c2,c3 from t1 ;
create materialized view mv2  refresh complete on demand  as select c1,c2,c3 from t1 ;
select * from mv1 a,mv2 b where vector_norm(a.c2)=vector_norm(b.c2) order by a.c1;




##分区表的向量索引列
--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1(c1 int primary key, c2 vector(3),c3 vector(3) , c4 vector(3),
VECTOR INDEX vector_idx(c4) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40)) partition by hash(c1) partitions 4;
replace into t1(c1, c2, c3) values(1,'[1,1,2]','[2,2,3]');
replace into t1(c1, c2, c3) values(2,'[1,-1,3]','[1,0,3]');
select * from t1 order by vector_norm(c4),c1;


###二级分区表
--disable_warnings
drop table if exists t1;
drop table if exists tt1;
drop view if exists v1;
--enable_warnings

CREATE TABLE t1 (c1 INT PRIMARY KEY,c2 vector(3),c3 vector(3), c4 vector(3),c5 vector(3) AS (c4*c3) STORED,
VECTOR INDEX vector_idx(c3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40))PARTITION BY RANGE (c1)
SUBPARTITION BY HASH(c1)
SUBPARTITIONS 100 (
    PARTITION p1 VALUES LESS THAN (30) (
        SUBPARTITION s1,
        SUBPARTITION s2
    ),
    PARTITION p2 VALUES LESS THAN (40) (
        SUBPARTITION s3,
        SUBPARTITION s4
    ),
    PARTITION p3 VALUES LESS THAN MAXVALUE (
        SUBPARTITION s5,
        SUBPARTITION s6
    )
);
insert into t1(c1,c2,c3,c4) values(10,'[1,1,2]','[2,2,3]','[1,3,2]');
insert into t1(c1,c2,c3,c4) values(20,'[1,0,3]','[1,0,3]','[2,3,2]');
insert into t1(c1,c2,c3,c4) values(30,'[-1,2,2]','[-3,2,3]','[4,3,3]');
insert into t1(c1,c2,c3,c4) values(40,'[-1,-2,-2]','[-4,2,3]',null);
insert into t1(c1,c2,c3,c4) values(50,'[-1,-3,-2]',null,'[2,3,1]');
--error 1235
CREATE VECTOR INDEX vector_idx_c5  ON t1 (c5)  WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40);

create table tt1 like t1;
replace into tt1(c1,c2,c3,c4) values(10,'[1,1,2]','[2,2,3]','[1,3,2]');
replace into tt1(c1,c2,c3,c4) values(20,'[1,0,3]','[1,0,3]','[2,3,2]');
replace into tt1(c1,c2,c3,c4) values(30,'[-1,2,2]','[-3,2,3]','[4,3,3]');
replace into tt1(c1,c2,c3,c4) values(40,'[-1,-2,-2]','[-4,2,3]',null);
replace into tt1(c1,c2,c3,c4) values(50,'[-1,-3,-2]',null,'[2,3,1]');
select count(*) from tt1,t1;
select * from tt1,t1 where tt1.c5=t1.c5 order by vector_norm(t1.c5) limit 10;
select vector_norm(c4),c1,* from t1 PARTITION(p3) order by vector_norm(c5)  limit 10;



##函数索引
--disable_warnings
drop table if exists t1;
drop materialized view if exists mv1;
--enable_warnings
CREATE TABLE t1 (c1 int primary key, c2 vector(3),c3 vector(3) ,c4 vector(3),
VECTOR INDEX vector_idx(c3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
create index idx1 on t1 ((vector_norm(c2)));

##物化视图创建hash分区  
--disable_warnings
drop table if exists t1;
drop materialized view if exists mv1;
--enable_warnings
CREATE TABLE t1 (c1 int primary key, c2 vector(3),c3 vector(3) ,c4 vector(3),
VECTOR INDEX vector_idx(c3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
insert into t1(c1,c2,c3,c4) values(1,'[1,1,2]','[2,2,3]','[1,3,2]');
insert into t1(c1,c2,c3,c4) values(2,'[1,0,3]','[1,0,3]','[2,3,2]');
insert into t1(c1,c2,c3,c4) values(3,'[-1,2,2]','[-3,2,3]','[4,3,3]');
insert into t1(c1,c2,c3,c4) values(4,'[-1,-2,-2]','[-4,2,3]',null);
insert into t1(c1,c2,c3,c4) values(5,'[-1,-3,-2]',null,'[2,3,1]');
create materialized view mv1 partition by hash(c1) partitions 10  refresh complete on demand  as select c1,c2,c3+c4 a from t1;
desc mv1;
select vector_norm(c2),c1,* from mv1 order by c1;
insert into t1 values(6,'[-1,-3,-2]',null,'[2,3,1]');
CALL DBMS_MVIEW.REFRESH('mv1','c');



