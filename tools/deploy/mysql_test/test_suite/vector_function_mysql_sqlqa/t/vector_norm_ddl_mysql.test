##分区表创建临时表
--disable_warnings
drop table if exists t1;
drop table if exists tt1;
drop table if exists tt2;
--enable_warnings

CREATE TABLE t1 (c1 int primary key, c2 varchar(30),c3 vector(3) ,c4 vector(3),
VECTOR INDEX vector_idx(c3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40))PARTITION BY KEY(c1) PARTITIONS 4;
CREATE TABLE tt1 like t1;
insert into t1(c1,c2,c3,c4) values(1,'[1,1,2]','[2,2,3]','[1,3,2]');
insert into t1(c1,c2,c3,c4) values(2,'[1,0,3]','[1,0,3]','[2,3,2]');
insert into t1(c1,c2,c3,c4) values(3,'[-1,2,2]','[-3,2,3]','[4,3,3]');
insert into t1(c1,c2,c3,c4) values(4,'[-1,-2,-2]','[-4,2,3]',null);
insert into t1(c1,c2,c3,c4) values(5,'[-1,-3,-2]',null,'[2,3,1]');
insert into tt1(c1,c2,c3,c4) values(1,'[1,1,2]','[2,2,3]','[1,3,2]');
insert into tt1(c1,c2,c3,c4) values(2,'[1,0,3]','[1,0,3]','[2,3,2]');
insert into tt1(c1,c2,c3,c4) values(3,'[-1,2,2]','[-3,2,3]','[4,3,3]');
insert into tt1(c1,c2,c3,c4) values(4,'[-1,-2,-2]','[-4,2,3]',null);
insert into tt1(c1,c2,c3,c4) values(5,'[-1,-3,-2]',null,'[2,3,1]');
CREATE TABLE tt2 as select * from t1;
select count(*) from t1 a,tt1 b order by vector_norm(a.c3)  limit 10;
select count(*) from t1 a,tt2 b order by vector_norm(a.c3)  limit 10;
select count(*) from tt1 a,tt2 b order by vector_norm(a.c3)  limit 10;
select count(*) from tt1 a ,tt2 b ,t1 c order by vector_norm(a.c3)  limit 10;
select count(*) from t1 a,tt1 b where vector_norm(b.c3)=vector_norm(a.c3) order by vector_norm(a.c3)  limit 10;
select count(*) from t1 a,tt2 b where vector_norm(b.c3)=vector_norm(a.c3) order by vector_norm(a.c3)  limit 10;
select count(*) from tt1 a,tt2 b where vector_norm(b.c3)=vector_norm(a.c3) order by vector_norm(a.c3)  limit 10;
select count(*) from tt1 a,tt2 b where vector_norm([0.123,0.523,0.852])=vector_norm([0.123,0.523,0.852]) order by vector_norm(a.c3)  limit 10;


