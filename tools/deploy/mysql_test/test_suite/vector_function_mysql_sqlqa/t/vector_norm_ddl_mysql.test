VECTOR INDEX vector_idx(c3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40))PARTITION BY KEY(c1) PARTITIONS 4;
--error 1235
ALTER TABLE t1  DROP PARTITION p1;

##增加约束
ALTER TABLE t1 ADD CONSTRAINT chk_c3_range CHECK (vector_norm(c3) is not null);
insert into t1(c1,c2,c3,c4) values(1,'[1,1,2]','[2,2,3]','[1,3,2]');
insert into t1(c1,c2,c3,c4) values(2,'[1,0,3]','[1,0,3]','[2,3,2]');
insert into t1(c1,c2,c3,c4) values(3,'[-1,2,2]','[-3,2,3]','[4,3,3]');
insert into t1(c1,c2,c3,c4) values(4,'[-1,-2,-2]','[-4,2,3]',null);
--error 3819
insert into t1(c1,c2,c3,c4) values(5,'[-1,-3,-2]',null,'[2,3,1]');

##删除约束
ALTER TABLE t1 drop CONSTRAINT chk_c3_range ;


##向量列作为分区键
--disable_warnings
drop table if exists t1;
--enable_warnings
--error 1659
CREATE TABLE t1 (c1 int , c2 varchar(30),c3 vector(3) ,c4 vector(3),c5  vector(3))PARTITION BY KEY(c4) PARTITIONS 4;

##向量虚拟列作为分区键
--disable_warnings
drop table if exists t1;
drop table if exists tt1;
drop table if exists tt2;
drop view if exists v1;
drop materialized view if exists mv1;
--enable_warnings
--error 1659
CREATE TABLE t1 (c1 int primary key, c2 varchar(30),c3 vector(3) ,c4 vector(3),c5  vector(3) AS ([1,2,3]) )PARTITION BY KEY(c5) PARTITIONS 4;

##结合表达式使用向量虚拟列作为分区键
--disable_warnings
drop table if exists t1;
drop table if exists tt1;
drop table if exists tt2;
drop view if exists v1;
drop materialized view if exists mv1;
--enable_warnings

CREATE TABLE t1 (c1 int primary key, c2 varchar(30),c3 vector(3) ,c4 vector(3),c5  double AS (vector_norm([1,2,3])))PARTITION BY KEY(c5) PARTITIONS 4;
insert into t1(c1,c2,c3,c4) values(1,'[1,1,2]','[2,2,3]','[1,3,2]');
insert into t1(c1,c2,c3,c4) values(2,'[1,0,3]','[1,0,3]','[2,3,2]');
insert into t1(c1,c2,c3,c4) values(3,'[-1,2,2]','[-3,2,3]','[4,3,3]');
insert into t1(c1,c2,c3,c4) values(4,'[-1,-2,-2]','[-4,2,3]',null);
insert into t1(c1,c2,c3,c4) values(5,'[-1,-3,-2]',null,'[2,3,1]');
replace into t1(c1,c2,c3,c4) values(1,'[1,1,2]','[2,2,3]','[1,3,2]');
replace into t1(c1,c2,c3,c4) values(2,'[1,0,3]','[1,0,3]','[2,3,2]');
replace into t1(c1,c2,c3,c4) values(3,'[-1,2,2]','[-3,2,3]','[4,3,3]');
replace into t1(c1,c2,c3,c4) values(4,'[-1,-2,-2]','[-4,2,3]',null);
replace into t1(c1,c2,c3,c4) values(5,'[-1,-3,-2]',null,'[2,3,1]');

create view v1 as select * from t1;
replace into v1(c1,c2,c3,c4) select c1,c2,c3,c4 from t1;
create table tt1 as select * from t1;
replace into tt1 select * from v1;
create table tt2 like t1;
replace into tt2(c1,c2,c3,c4) select c1,c2,c3,c4 from t1;
--error 1062
create materialized view mv1(primary key(c5))  parallel 2 refresh complete on demand  as select * from t1;


#基表为物化视图
--disable_warnings
drop table if exists t1;
drop materialized view if exists mv1;
--enable_warnings

CREATE TABLE t1 (c1 int primary key, c2 varchar(30),c3 vector(3) ,c4 vector(3),c5  double AS (vector_norm(c2+c3+c4)),
VECTOR INDEX vector_idx(c3)
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40))PARTITION BY KEY(c1) PARTITIONS 4;
insert into t1(c1,c2,c3,c4) values(1,'[1,1,2]','[2,2,3]','[1,3,2]');
create materialized view mv1  parallel 2 refresh complete on demand  as select * from t1;
replace into t1(c1,c2,c3,c4) select c1,c2,c3,c4 from mv1;

create index vector_idx1 on t1(c5);
create index vector_idx2 on mv1(c5);

--disable_warnings
drop table if exists t1;
drop materialized view if exists mv1;
--enable_warnings

CREATE TABLE t1 (c1 int primary key, c2 vector(3),c3 vector(3) ,c4 vector(3));
insert into t1 values(1,'[1,1,2]','[2,2,3]','[1,3,2]');
create materialized view mv1  parallel 2 refresh complete on demand  as select * from t1 order by vector_norm(c3)  limit 10;
replace into t1 select * from mv1;
select * from mv1;


--disable_warnings
drop table if exists t1;
drop materialized view if exists mv1;
--enable_warnings
CREATE TABLE t1 (c1 int primary key, c2 vector(3),c3 vector(3) ,c4 vector(3),
VECTOR INDEX vector_idx(c3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
insert into t1(c1,c2,c3,c4) values(1,'[1,1,2]','[2,2,3]','[1,3,2]');
insert into t1(c1,c2,c3,c4) values(2,'[1,0,3]','[1,0,3]','[2,3,2]');
insert into t1(c1,c2,c3,c4) values(3,'[-1,2,2]','[-3,2,3]','[4,3,3]');
insert into t1(c1,c2,c3,c4) values(4,'[-1,-2,-2]','[-4,2,3]',null);
insert into t1(c1,c2,c3,c4) values(5,'[-1,-3,-2]',null,'[2,3,1]');
create materialized view mv1  parallel 2 refresh complete on demand  as select * from t1 order by c1;

