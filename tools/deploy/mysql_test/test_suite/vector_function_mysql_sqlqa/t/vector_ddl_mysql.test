#owner: yangjiali.yjl
#owner group: 多模
#description: vector_ddl
#tags:vector_ddl
#author: wb-ljh01399065
purge recyclebin;
--disable_warnings
drop database IF EXISTS obljh;
--enable_warnings
create database obljh ;
use obljh;
set timestamp = 1600000000;
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;
set ob_default_lob_inrow_threshold = 0;

alter system set ob_vector_memory_limit_percentage =44;

##建表不含向量索引
##中间加列  --后建向量索引
--disable_warnings
drop table if exists t1;
--enable_warnings

CREATE TABLE t1 (c1 int AUTO_INCREMENT primary key , c2 vector(3),c3 vector(3) ,c4 json);
insert into t1 values(1,'[1,1,2]','[2,2,3]','{"page":"null"}');
insert into t1 values(2,'[1,2,3]','[1,2,3]','{"page":"0"}');
ALTER TABLE t1 ADD cc1 vector(16000) AFTER  c4;
ALTER TABLE t1 ADD cc2 vector(1) before  cc1;
ALTER TABLE t1 ADD cc3 vector(2000) first;
ALTER TABLE t1 ADD cc4 json AFTER  cc2;
create VECTOR index vector_idx on t1(cc2) with (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40);
create VECTOR index vector_idx2 on t1(c3) with (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40);
#--error 1235
#ALTER TABLE t1 ADD cc5 vector(16000) AFTER  c4;
select * from t1 where l2_distance(c3,c2) <>1  order by l2_distance(c3, [1,2,3]) approximate limit 10;


##重排列 --后建向量索引
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int AUTO_INCREMENT primary key , c2 vector(3),c3 vector(3) ,c4 json);
insert into t1 values(1,'[1,1,2]','[2,2,3]','{"page":"null"}');
insert into t1 values(2,'[1,2,3]','[1,2,3]','{"page":"0"}');
ALTER TABLE t1 MODIFY COLUMN c3 vector(3) FIRST;
ALTER TABLE t1 MODIFY COLUMN c4 json FIRST;
create VECTOR index vector_idx2 on t1(c3) with (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40);
#--error 1235
#ALTER TABLE t1 MODIFY COLUMN c4 json AFTER c2;
select * from t1 where l2_distance(c3,c2) <>1  order by l2_distance(c3, [1,2,3]) approximate limit 10;

