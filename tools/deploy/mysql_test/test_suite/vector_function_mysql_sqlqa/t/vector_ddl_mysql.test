##添加/删除 stored 生成列 --后建向量索引
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int primary key, c2 vector(3),c3 vector(3) ,c4 json,c5 vector(3) as (c3-c2*c2+c3) STORED);
ALTER TABLE t1 ADD COLUMN c6 vector(3) AS (c3*c2) STORED;
insert into t1(c1,c2,c3,c4) values(2,'[1,2,3]','[1,2,3]','{"page":"0"}');
create VECTOR index vector_idx2 on t1(c2) with (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40);
#--error 1235
#ALTER TABLE t1 DROP COLUMN c5;
#--error 1235
#ALTER TABLE t1 DROP COLUMN c6;

##删除列 --后建向量索引
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int primary key, c2 vector(3),c3 vector(3) ,c4 json);
create VECTOR index vector_idx2 on t1(c2) with (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40);
--error 1235
ALTER TABLE t1 DROP COLUMN c1;
--error 1235,3108
ALTER TABLE t1 DROP COLUMN c2;


##混合列操作 --后建向量索引
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int primary key, c2 vector(3),c3 vector(3) ,c4 json);
ALTER TABLE t1  MODIFY COLUMN c2 vector(10), ADD c5 vector(3), DROP COLUMN c2;
insert into t1(c1,c5,c3,c4) values(2,'[1,2,3]','[1,2,3]','{"page":"0"}');
create VECTOR index vector_idx2 on t1(c5) with (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40);
#--error 1235
ALTER TABLE t1  MODIFY COLUMN c5 vector(3), drop COLUMN c3 ;

##加/删主键 --后建向量索引
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int , c2 vector(3),c3 vector(3) ,c4 json);
insert into t1(c1,c2,c3,c4) values(2,'[1,2,3]','[1,2,3]','{"page":"0"}');
#--error 5083
#ALTER TABLE t1 ADD PRIMARY KEY (c2);
create VECTOR index vector_idx2 on t1(c2) with (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40);
#--error 1235
ALTER TABLE t1 ADD PRIMARY KEY (c1);
#--error 1091
ALTER TABLE t1 DROP PRIMARY KEY;


##truncate表 --后建向量索引
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int primary key, c2 vector(3),c3 vector(3) ,c4 json);
insert into t1 values(1,'[1,1,2]','[2,2,3]','{"page":"null"}');
insert into t1 values(2,'[1,2,3]','[1,2,3]','{"page":"0"}');
truncate table t1;
create VECTOR index vector_idx2 on t1(c2) with (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40);
insert into t1 values(1,'[1,1,2]','[2,2,3]','{"page":"null"}');
insert into t1 values(2,'[1,2,3]','[1,2,3]','{"page":"0"}');
truncate table t1;

##转换字符集 --后建向量索引
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int primary key, c2 vector(3),c3 vector(3) ,c4 json);
insert into t1 values(1,'[1,1,2]','[2,2,3]','{"page":"null"}');
insert into t1 values(2,'[1,2,3]','[1,2,3]','{"page":"0"}');
ALTER TABLE t1 CONVERT TO CHARACTER SET gbk;
create VECTOR index vector_idx2 on t1(c2) with (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40);
#--error 1235
ALTER TABLE t1 CONVERT TO CHARACTER SET utf8mb4;

##删表 --后建向量索引
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int primary key, c2 vector(3),c3 vector(3) ,c4 json);
insert into t1 values(1,'[1,1,2]','[2,2,3]','{"page":"null"}');
insert into t1 values(2,'[1,2,3]','[1,2,3]','{"page":"0"}');
create VECTOR index vector_idx2 on t1(c2) with (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40);
drop table t1;

##修改分区规则/删除分区/truncate分区 --后建向量索引
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int primary key, c2 vector(3),c3 vector(3) ,c4 json)partition by hash(c1) partitions 5;
insert into t1 values(1,'[1,1,2]','[2,2,3]','{"page":"null"}');
insert into t1 values(2,'[1,2,3]','[1,2,3]','{"page":"0"}');
ALTER TABLE t1 PARTITION BY HASH(c1) PARTITIONS 4;
create VECTOR index vector_idx2 on t1(c2) with (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40);
--error 1235
ALTER TABLE t1 DROP PARTITION p3;
--error 1235
ALTER TABLE t1 TRUNCATE PARTITION p2;
#--error 1235
ALTER TABLE t1 PARTITION BY HASH(c1) PARTITIONS 10;


--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int primary key, c2 vector(3),c3 vector(3) ,c4 json)PARTITION BY LIST (c1) (
    PARTITION p1 VALUES IN (1,2),
    PARTITION p2 VALUES IN (3,4),
    PARTITION p3 VALUES IN (5,6)
);
insert into t1 values(1,'[1,1,2]','[2,1,3]','{"page":"null"}');
insert into t1 values(2,'[1,2,2]','[2,2,3]','{"page":"1"}');
insert into t1 values(3,'[1,3,2]','[2,3,3]','{"page":"2"}');
insert into t1 values(4,'[1,4,2]','[2,4,3]','{"page":"100"}');
insert into t1 values(5,'[1,5,2]','[2,5,3]','{"page":"4"}');
insert into t1 values(6,'[1,6,3]','[1,6,3]','{"page":"0"}');
ALTER TABLE t1 DROP PARTITION p3;
ALTER TABLE t1 TRUNCATE PARTITION p2;
ALTER TABLE t1 PARTITION BY HASH(c1) PARTITIONS 4;
create VECTOR index vector_idx2 on t1(c2) with (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40);
##修改分区键类型
--error 4006,1659
ALTER TABLE t1 MODIFY c1 vector(3);


