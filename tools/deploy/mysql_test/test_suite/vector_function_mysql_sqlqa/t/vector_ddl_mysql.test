ALTER TABLE t1 MODIFY c2 DECIMAL(15, 2);
--error 5083
ALTER TABLE t1 MODIFY c2 json;
--error 5083
ALTER TABLE t1 MODIFY c2 date;
create VECTOR index vector_idx2 on t1(c2) with (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40);
