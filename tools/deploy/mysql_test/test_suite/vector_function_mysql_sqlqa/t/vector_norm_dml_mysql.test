#owner: gehao.wh
#owner group: 多模
#description: vector_dml
#tags:vector_dml
#author: wb-ljh01399065
purge recyclebin;
--disable_warnings
drop database IF EXISTS obljh;
--enable_warnings
create database obljh ;
use obljh;
set timestamp = 1600000000;
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;
set ob_default_lob_inrow_threshold = 0;

alter system set ob_vector_memory_limit_percentage =44;
--echo ##where子句
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int AUTO_INCREMENT primary key , c2 vector(3),c3 vector(3) ,c4 BLOB,
VECTOR INDEX vector_idx(c3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
select * from t1 where vector_norm(null);
##只使用where，无条件时会导致core
select * from t1 where vector_norm([1,1]);
select * from t1 where vector_norm([1]);

--echo ##=,<,<=,>=,<>
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int primary key, c2 VARCHAR(30),c3 vector(3) ,c4 vector(2),
VECTOR INDEX vector_idx(c3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
insert into t1 values(1,'[1,1,2]','[2,2,3]','[1,3]');
insert into t1 values(2,'[1,2,3]','[1,2,3]','[2,3]');
insert into t1 values(3,'[-1,2,2]','[-3,2,3]','[4,3]');
insert into t1 values(4,'[-1,-2,-2]','[-4,2,3]',null);
insert into t1 values(5,'[-1,-2,-2]',null,'[2,3]');
select vector_norm(c3) ld_c3,vector_norm(c4) ld_c4 from t1 where vector_norm(c3) =0  order by c1;
select vector_norm(c3) ld_c3,vector_norm(c4) ld_c4 from t1 where vector_norm(c3) =0  order by c1;
select vector_norm(c3) ld_c3,vector_norm(c4) ld_c4 from t1 where vector_norm(c2) > 1  order by c1;
select vector_norm(c3) ld_c3,vector_norm(c4) ld_c4 from t1 where vector_norm([1,2,3]) > 1  order by c1;
select vector_norm(c3) ld_c3,vector_norm(c4) ld_c4 from t1 where vector_norm(c2) < 1  order by c1;
select vector_norm(c3) ld_c3,vector_norm(c4) ld_c4 from t1 where vector_norm([1,2,3]) < 1  order by c1;
select vector_norm(c3) ld_c3,vector_norm(c4) ld_c4 from t1 where vector_norm(c2) <= 0  order by c1;
select vector_norm(c3) ld_c3,vector_norm(c4) ld_c4 from t1 where vector_norm([1,2,3]) <= 0  order by c1;
select vector_norm(c3) ld_c3,vector_norm(c4) ld_c4 from t1 where vector_norm(c2) >=1  order by c1;
select vector_norm(c3) ld_c3,vector_norm(c4) ld_c4 from t1 where vector_norm([1,2,3]) >=1  order by c1;
select vector_norm(c3) ld_c3,vector_norm(c4) ld_c4 from t1 where vector_norm(c2) <>1  order by c1;
select vector_norm(c3) ld_c3,vector_norm(c4) ld_c4 from t1 where vector_norm([1,2,3])<>1  order by c1;
select vector_norm(c3) ld_c3,vector_norm(c4) ld_c4 from t1 where vector_norm(c2) <>false  order by c1;
select vector_norm(c3) ld_c3,vector_norm(c4) ld_c4 from t1 where vector_norm([1,2,3])<>false  order by c1;
select vector_norm(c3) ld_c3,vector_norm(c4) ld_c4 from t1 where vector_norm(c2) <>true  order by c1;
select vector_norm(c3) ld_c3,vector_norm(c4) ld_c4 from t1 where vector_norm([1,2,3]) <>true  order by c1;

select vector_norm(c3) ld_c3,vector_norm(c4) ld_c4 from t1 where vector_norm(c3) =0  order by l2_distance(c3, [1,2,3]) approximate limit 10;
select vector_norm(c3) ld_c3,vector_norm(c4) ld_c4 from t1 where vector_norm(c3) =0  order by l2_distance(c3, [1,2,3]) approximate limit 10;
select vector_norm(c3) ld_c3,vector_norm(c4) ld_c4 from t1 where vector_norm(c2) > 1  order by l2_distance(c3, [1,2,3]) approximate limit 10;
select vector_norm(c3) ld_c3,vector_norm(c4) ld_c4 from t1 where vector_norm([1,2,3]) > 1  order by l2_distance(c3, [1,2,3]) approximate limit 10;
select vector_norm(c3) ld_c3,vector_norm(c4) ld_c4 from t1 where vector_norm(c2) < 1  order by l2_distance(c3, [1,2,3]) approximate limit 10;
select vector_norm(c3) ld_c3,vector_norm(c4) ld_c4 from t1 where vector_norm([1,2,3]) < 1  order by l2_distance(c3, [1,2,3]) approximate limit 10;
select vector_norm(c3) ld_c3,vector_norm(c4) ld_c4 from t1 where vector_norm(c2) <= 0  order by l2_distance(c3, [1,2,3]) approximate limit 10;
select vector_norm(c3) ld_c3,vector_norm(c4) ld_c4 from t1 where vector_norm([1,2,3]) <= 0  order by l2_distance(c3, [1,2,3]) approximate limit 10;
select vector_norm(c3) ld_c3,vector_norm(c4) ld_c4 from t1 where vector_norm(c2) >=1  order by l2_distance(c3, [1,2,3]) approximate limit 10;
select vector_norm(c3) ld_c3,vector_norm(c4) ld_c4 from t1 where vector_norm([1,2,3]) >=1  order by l2_distance(c3, [1,2,3]) approximate limit 10;
select vector_norm(c3) ld_c3,vector_norm(c4) ld_c4 from t1 where vector_norm(c2) <>1  order by l2_distance(c3, [1,2,3]) approximate limit 10;
select vector_norm(c3) ld_c3,vector_norm(c4) ld_c4 from t1 where vector_norm([1,2,3])<>1  order by l2_distance(c3, [1,2,3]) approximate limit 10;
select vector_norm(c3) ld_c3,vector_norm(c4) ld_c4 from t1 where vector_norm(c2) <>false  order by l2_distance(c3, [1,2,3]) approximate limit 10;
select vector_norm(c3) ld_c3,vector_norm(c4) ld_c4 from t1 where vector_norm([1,2,3])<>false  order by l2_distance(c3, [1,2,3]) approximate limit 10;
select vector_norm(c3) ld_c3,vector_norm(c4) ld_c4 from t1 where vector_norm(c2) <>true  order by l2_distance(c3, [1,2,3]) approximate limit 10;
select vector_norm(c3) ld_c3,vector_norm(c4) ld_c4 from t1 where vector_norm([1,2,3]) <>true  order by l2_distance(c3, [1,2,3]) approximate limit 10;


--echo ##and/or
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int primary key, c2 VARCHAR(30),c3 vector(3) ,c4 vector(3),
VECTOR INDEX vector_idx(c3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
insert into t1 values(1,'[1,1,2]','[2,2,3]','[1,-1.5,3]');
insert into t1 values(2,'[1,2,3]','[1,2,3]','[2,1.5,3]');
insert into t1 values(3,'[-1,2,2]','[-3,2,3]','[4,-1,3]');
insert into t1 values(4,'[-1,-2,-2]','[-4,2,3]',null);
insert into t1 values(5,'[-1,-2,-2]',null,'[2,-2,3]');

select vector_norm(c3) ld_c3,vector_norm(c4) ld_c4 from t1 where vector_norm(c3) =0 and vector_norm(c4) is null order by c1;
select vector_norm(c3) ld_c3,vector_norm(c4) ld_c4 from t1 where vector_norm(c3) <=2 and vector_norm(c2) >1 ;


select vector_norm(c3) ld_c3,vector_norm(c4) ld_c4 from t1 where vector_norm('[1,2,3]') > 0 or vector_norm(c3) is null order by c1;
select vector_norm(c3) ld_c3,vector_norm(c4) ld_c4 from t1 where vector_norm('[1,2,3]') > 0 or vector_norm(c3) is null  and c1 >3 order by c1;


--echo ##between and

select  * from t1 where 1 BETWEEN vector_norm(c3)  and vector_norm('[1,2,3]') order by vector_norm(c3)  limit 10;
select  * from t1 where 1 BETWEEN vector_norm(c3)  and vector_norm('[1,2,3]') order by l2_distance(c3, [1,2,3]) approximate limit 10;
select  vector_norm(c3) BETWEEN vector_norm(c3)  and vector_norm(c3) from t1 order by vector_norm(c3)  limit 10;
select  vector_norm(c3) BETWEEN vector_norm(c3)  and vector_norm(c3) from t1 order by l2_distance(c3, [1,2,3]) approximate limit 10;
select  vector_norm(c3) BETWEEN vector_norm(c3)  and vector_norm(c3) from t1 where vector_norm(c3) BETWEEN vector_norm(c3)  and vector_norm(c3) >1;




--echo ##like/not like
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int primary key, c2 VARCHAR(30),c3 vector(3) ,c4 vector(2),
VECTOR INDEX vector_idx(c3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
insert into t1 values(1,'[1,1,2]','[2,2,3]','[1,3]');
insert into t1 values(2,'[1,0,3]','[1,0,3]','[2,3]');
insert into t1 values(3,'[-1,2,2]','[-3,2,3]','[4,3]');
insert into t1 values(4,'[-1,-2,-2]','[-4,2,3]',null);
insert into t1 values(5,'[-1,-3,-2]',null,'[2,3]');

select  * from t1 where vector_norm(c3) like '%0%' order by vector_norm( [1,2,3])  limit 10;
select  * from t1 where vector_norm(c3) like vector_norm(c3) order by l2_distance(c3, [1,2,3]) approximate limit 10;

select  * from t1 where vector_norm(c3) not like '%1%' order by c1;
select  * from t1 where vector_norm(c3) not like vector_norm(c2) order by c1;


--echo ##exists,any,all,in(无关键字)
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int primary key, c2 VARCHAR(30),c3 vector(3) ,c4 vector(3),
VECTOR INDEX vector_idx(c3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
insert into t1 values(1,'[1,1,2]','[2,2,3]','[1,3,2]');
insert into t1 values(2,'[1,0,3]','[1,0,3]','[2,3,2]');
insert into t1 values(3,'[-1,2,2]','[-3,2,3]','[4,3,3]');
insert into t1 values(4,'[-1,-2,-2]','[-4,2,3]',null);
insert into t1 values(5,'[-1,-3,-2]',null,'[2,3,1]');

SELECT vector_norm(c3) from t1 where  EXISTS (SELECT vector_norm([1,null,1]) FROM t1) order by c1;
SELECT c3 from t1 where  EXISTS (SELECT c3 FROM t1) order by c1;
SELECT vector_norm(c3) from t1 where vector_norm(c3) = any (SELECT vector_norm(c3) FROM t1) order by c1;
SELECT vector_norm(c3) from t1 where vector_norm(c3) >= any (SELECT vector_norm(c3) FROM t1) order by c1;
SELECT vector_norm(c3) from t1 where vector_norm(c3) <= any (SELECT vector_norm(c3) FROM t1) order by c1;
SELECT vector_norm(c3) from t1 where vector_norm(c3) <> any (SELECT vector_norm(c3) FROM t1) order by c1;
SELECT vector_norm(c3) from t1 where vector_norm(c3) != any (SELECT vector_norm(c3) FROM t1) order by c1;
SELECT vector_norm(c3) from t1 where vector_norm(c3) > any (SELECT vector_norm(c3) FROM t1) order by c1;
SELECT vector_norm(c3) from t1 where vector_norm(c3) < any (SELECT vector_norm(c3) FROM t1) order by c1;


SELECT vector_norm(c3) from t1 where  EXISTS (SELECT vector_norm(c3) FROM t1) order by c1;
SELECT c3 from t1 where  EXISTS (SELECT c3 FROM t1) order by c1;
SELECT vector_norm(c3) from t1 where vector_norm(c3) = any (SELECT vector_norm(c3) FROM t1) order by c1;
SELECT vector_norm(c3) from t1 where vector_norm(c3) >= any (SELECT vector_norm(c3) FROM t1) order by c1;
SELECT vector_norm(c3) from t1 where vector_norm(c3) <= any (SELECT vector_norm(c3) FROM t1) order by c1;
SELECT vector_norm(c3) from t1 where vector_norm(c3) <> any (SELECT vector_norm(c3) FROM t1) order by c1;
SELECT vector_norm(c3) from t1 where vector_norm(c3) != any (SELECT vector_norm(c3) FROM t1) order by c1;
SELECT vector_norm(c3) from t1 where vector_norm(c3) > any (SELECT vector_norm(c3) FROM t1) order by c1;
SELECT vector_norm(c3) from t1 where vector_norm(c3) < any (SELECT vector_norm(c3) FROM t1) order by c1;

SELECT vector_norm(c3) from t1 where vector_norm(c3) = all (SELECT vector_norm(c3) FROM t1) order by c1;
SELECT vector_norm(c3) from t1 where vector_norm(c3) >= all (SELECT vector_norm(c3) FROM t1) order by c1;
SELECT vector_norm(c3) from t1 where vector_norm(c3) <= all (SELECT vector_norm(c3) FROM t1) order by c1;
SELECT vector_norm(c3) from t1 where vector_norm(c3) <> all (SELECT vector_norm(c3) FROM t1) order by c1;
SELECT vector_norm(c3) from t1 where vector_norm(c3) != all (SELECT vector_norm(c3) FROM t1) order by c1;
SELECT vector_norm(c3) from t1 where vector_norm(c3) > all (SELECT vector_norm(c3) FROM t1) order by c1;
SELECT vector_norm(c3) from t1 where vector_norm(c3) < all (SELECT vector_norm(c3) FROM t1) order by c1;

SELECT vector_norm(c3) from t1 where vector_norm(c3) in (vector_norm(c3),vector_norm(c3)) order by c1;
SELECT vector_norm(c3) from t1 where vector_norm(c3) not in (vector_norm(c3),vector_norm(c4)) order by c1;
SELECT vector_norm(c3) from t1 where vector_norm(c3) not in (SELECT vector_norm(c3)FROM t1) order by c1;

--echo ##exists,any,all,in(存在关键字APPROXIMATE|APPROX)
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int primary key, c2 VARCHAR(30),c3 vector(3) ,c4 vector(3),
VECTOR INDEX vector_idx(c3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
insert into t1 values(1,'[1,1,2]','[2,2,3]','[1,3,2]');
insert into t1 values(2,'[1,0,3]','[1,0,3]','[2,3,2]');
insert into t1 values(3,'[-1,2,2]','[-3,2,3]','[4,3,3]');
insert into t1 values(4,'[-1,-2,-2]','[-4,2,3]',null);
insert into t1 values(5,'[-1,-3,-2]',null,'[2,3,1]');
SELECT vector_norm(c3) from t1 where  EXISTS (SELECT vector_norm([1,1,1]) FROM t1 order by vector_norm([1,2,3])  limit 10 ) order by c1;
SELECT vector_norm(c3) from t1 where  EXISTS (SELECT vector_norm([1,1,1]) FROM t1 order by l2_distance(c3,[1,2,3]) approximate limit 10 ) order by c1;
###explain SELECT vector_norm(c3) from t1 where  EXISTS (SELECT vector_norm(c3,[1,1,1]) FROM t1 order by vector_norm(c3, [1,2,3]) approximate limit 10 ) order by c1;
--error 1582
SELECT c3 from t1 where  EXISTS (SELECT c3 FROM t1 order by vector_norm(c3, [1,2,3]) approximate limit 10 ) order by c1;

SELECT vector_norm(c3) from t1 where vector_norm(c3) = any (SELECT vector_norm(c3) FROM t1 order by l2_distance(c3, [1,2,3]) approximate limit 10) order by c1;
SELECT vector_norm(c3) from t1 where vector_norm(c3) >= any (SELECT vector_norm(c3) FROM t1 order by l2_distance(c3, [1,2,3]) approximate limit 10 ) order by c1;
SELECT vector_norm(c3) from t1 where vector_norm(c3) <= any (SELECT vector_norm(c3) FROM t1 order by l2_distance(c3, [1,2,3]) approximate limit 10 ) order by c1;
SELECT vector_norm(c3) from t1 where vector_norm(c3) <> any (SELECT vector_norm(c3) FROM t1 order by l2_distance(c3, [1,2,3]) approximate limit 10 ) order by c1;
SELECT vector_norm(c3) from t1 where vector_norm(c3) != any (SELECT vector_norm(c3) FROM t1 order by l2_distance(c3, [1,2,3]) approximate limit 10 ) order by c1;
SELECT vector_norm(c3) from t1 where vector_norm(c3) > any (SELECT vector_norm(c3) FROM t1 order by l2_distance(c3, [1,2,3]) approximate limit 10 ) order by c1;
SELECT vector_norm(c3) from t1 where vector_norm(c3) < any (SELECT vector_norm(c3) FROM t1 order by l2_distance(c3, [1,2,3]) approximate limit 10 ) order by c1;

--error 1582
SELECT vector_norm(c3) from t1 where vector_norm(c3) in (vector_norm(c3),vector_norm(c3)) order by vector_norm(c3, [1,2,3]) approximate limit 10;
--error 1582
SELECT vector_norm(c3) from t1 where vector_norm(c3) not in (vector_norm(c3,'[1,2,3]'),vector_norm(c4,'[1,2,3]')) order by vector_norm(c3, [1,2,3]) approximate limit 10;
--error 1582
SELECT vector_norm(c3) from t1 where vector_norm(c3) not in (SELECT vector_norm(c3,'[1,2,3]')FROM t1 order by vector_norm(c3, [1,2,3]) approximate limit 10 ) order by c1;

SELECT vector_norm(c3) from t1 where vector_norm(c3) not in (vector_norm([1,2,3]),vector_norm([1,2,3])) order by vector_norm(c3)  limit 10;
SELECT vector_norm(c3) from t1 where vector_norm(c3) not in (SELECT vector_norm([1,2,3])FROM t1 where c3 is not null order by vector_norm(c3)  limit 10 ) order by c1;
SELECT vector_norm(c3) from t1 where vector_norm(c3) not in (SELECT vector_norm([1,2,3])FROM t1 where c3 is not null order by l2_distance(c3, [1,2,3]) approximate limit 10 ) order by c1;


--echo ##多表join
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int primary key, c2 vector(3),c3 vector(3) ,c4 vector(3));
insert into t1 values(1,'[1,1,2]','[2,2,3]','[1,3,2]');
insert into t1 values(2,'[1,0,3]','[1,0,3]','[2,3,2]');
insert into t1 values(3,'[-1,2,2]','[-3,2,3]','[4,3,3]');
insert into t1 values(4,'[-1,-2,-2]','[-4,2,3]',null);
insert into t1 values(5,'[-1,-3,-2]',null,'[2,3,1]');

--disable_warnings
drop table if exists t2;
--enable_warnings
CREATE TABLE t2 (a1 int , a2 vector(3),a3 vector(3) ,a4 vector(3));
insert into t2 select c1,c2,c3,c4 from t1; 
select vector_norm([1,2,3]) from t1 union  select vector_norm([1,2,3]) from t2;


