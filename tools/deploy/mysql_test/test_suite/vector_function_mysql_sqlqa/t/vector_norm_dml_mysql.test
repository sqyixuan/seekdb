CREATE TABLE t2 (a1 int , a2 vector(3),a3 vector(3) ,a4 vector(3),
VECTOR INDEX vector_idx(a3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
insert into t2 select c1,c2,c3,c4 from t1; 
select * from t1 a  order by vector_norm(a.c3)  limit 10;


select c1,c2,c3,vector_norm(a3) from t1 a join t2 b on c2=a2  order by vector_norm(a3);
select c1,c2,c3,vector_norm(a3) from t1 a join t2 b on vector_norm(c3)=vector_norm(a3)  order by vector_norm(a3);
select c1,c2,c3,vector_norm(a3) from t1 a inner join t2 b on vector_norm(c3)=vector_norm(a3)  order by vector_norm(a3);
select c1,c2,c3,vector_norm(a3) from t1 a right join t2 b on vector_norm(c3)=vector_norm(a3)  order by vector_norm(a3);
select c1,c2,c3,vector_norm(a3) from t1 a left join t2 b on vector_norm(c3)=vector_norm(a3)  order by vector_norm(a3);
select c1,c2,c3,vector_norm(a3) from t1 a cross  join t2 b on vector_norm(c3)=vector_norm(a3)  order by vector_norm(a3);
select c1,c2,c3,vector_norm(a3) from t1 a join t2 b on vector_norm(a4)=vector_norm(a3)  order by vector_norm(a3);
select c1,c2,c3,vector_norm(a3) from t1 a inner join t2 b on vector_norm(a4)=vector_norm(a3)  order by vector_norm(a3);
select c1,c2,c3,vector_norm(a3) from t1 a right join t2 b on vector_norm(a4)=vector_norm(a3)  order by vector_norm(a3);
select c1,c2,c3,vector_norm(a3) from t1 a left join t2 b on vector_norm(a4)=vector_norm(a3)  order by vector_norm(a3);
select c1,c2,c3,vector_norm(a3) from t1 a cross  join t2 b on vector_norm(a4)=vector_norm(a3)  order by vector_norm(a3);

select vector_norm(c3) from t1  union all select vector_norm(a2) from t2 ;
select vector_norm(c3) from t1  union  select vector_norm(a3) from t2 ;

