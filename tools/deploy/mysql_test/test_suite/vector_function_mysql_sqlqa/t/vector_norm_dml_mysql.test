##存在关键字APPROXIMATE|APPROX
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int primary key, c2 vector(3),c3 vector(3) ,c4 vector(3),
VECTOR INDEX vector_idx(c3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
insert into t1 values(1,'[1,1,2]','[2,2,3]','[1,3,2]');
insert into t1 values(2,'[1,0,3]','[1,0,3]','[2,3,2]');
insert into t1 values(3,'[-1,2,2]','[-3,2,3]','[4,3,3]');
insert into t1 values(4,'[-1,-2,-2]','[-4,2,3]',null);
insert into t1 values(5,'[-1,-3,-2]',null,'[2,3,1]');

--disable_warnings
drop table if exists t2;
--enable_warnings
CREATE TABLE t2 (a1 int , a2 vector(3),a3 vector(3) ,a4 vector(3),
VECTOR INDEX vector_idx(a3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
insert into t2 select c1,c2,c3,c4 from t1; 

select * from t1 a join t2 b on vector_norm(c3+a2)=vector_norm(a3+c2) order by l2_distance(c3, [1,2,3]) approximate limit 10;

select * from t1 a join t2 b on vector_norm(c3+[1,10,-1000])=vector_norm(a3+[1,10,-1000]) order by l2_distance(c3, [1,100,-10000]) approximate limit 2;
select * from t1 a join t2 b on vector_norm(c3+[1,10,-1000])=vector_norm(a3+[1,10,-1000]) order by l2_distance(c3, [1,100,-10000])  limit 2;
##explain select * from t1 a join t2 b on vector_norm(c3+[1,10,-1000])=vector_norm(a3+[1,10,-1000]) order by l2_distance(c3, [1,2,3]) approximate limit 2;
select * from t1 a join t2 b on vector_norm(c3+a2)=vector_norm([1,1,1]) order by c1;



