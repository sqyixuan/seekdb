#owner: gehao.wh
#owner group: 多模
#description: vector_refresh
#tags:vector
#author: wb-ljh01399065

purge recyclebin;

--disable_warnings
drop database IF EXISTS obljh;
--enable_warnings

create database obljh ;
use obljh;
set timestamp = 1600000000;
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;
set ob_default_lob_inrow_threshold = 0;

alter system set ob_vector_memory_limit_percentage =44;
set ob_query_timeout  = 3216672000000000;

##空表验证
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int primary key, c2 vector(3),c3 vector(3) ,c4 vector(3),
VECTOR INDEX vector_idx(c2) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
call dbms_vector.rebuild_index('vector_idx','t1');
call dbms_vector.rebuild_index('vector_idx','t1');
call dbms_vector.rebuild_index('vector_idx','t1');
call dbms_vector.rebuild_index('vector_idx','t1');
call dbms_vector.refresh_index('vector_idx','t1','c2',1,'FAST');

##不存在的索引名
--error 1210
call dbms_vector.rebuild_index('vector_idx1','t1');
--error 1210
call dbms_vector.rebuild_index('vector_idx','tt1');
--error 1210
call dbms_vector.refresh_index('vector_idx1','t1','c2',1,'FAST');


##普通表刷新

--disable_warnings
drop table if exists t1;
drop table if exists tt1;
--enable_warnings

CREATE TABLE t1 (c1 int primary key, c2 vector(3),c3 vector(3) ,c4 vector(3),
VECTOR INDEX vector_idx(c3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
insert into t1 values(1,'[1,1,2]','[2,2,3]','[1,3,2]');
insert into t1 values(2,'[1,0,3]','[1,0,3]','[2,3,2]');
insert into t1 values(3,'[-1,2,2]','[-3,2,3]','[4,3,3]');
insert into t1 values(4,'[-1,-2,-2]','[-4,2,3]',null);
insert into t1 values(5,'[-1,-3,-2]',null,'[2,3,1]');
create table tt1 like t1;
insert /*+PARALLEL(8)*/into tt1 select * from t1;

call dbms_vector.refresh_index('vector_idx','tt1','c3',1,'FAST');
call dbms_vector.refresh_index('vector_idx','t1','c3',1,'FAST');
call dbms_vector.rebuild_index('vector_idx','tt1','c3');
call dbms_vector.rebuild_index('vector_idx','t1','c3');

##分区表刷新
--disable_warnings
drop table if exists t1;
drop table if exists tt1;
--enable_warnings

CREATE TABLE t1 (c1 int primary key, c2 vector(3),c3 vector(3) ,c4 vector(3),
VECTOR INDEX vector_idx(c3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40))PARTITION BY KEY(c1) PARTITIONS 4;
insert into t1 values(1,'[1,1,2]','[2,2,3]','[1,3,2]');
insert into t1 values(2,'[1,0,3]','[1,0,3]','[2,3,2]');
insert into t1 values(3,'[-1,2,2]','[-3,2,3]','[4,3,3]');
insert into t1 values(4,'[-1,-2,-2]','[-4,2,3]',null);
insert into t1 values(5,'[-1,-3,-2]',null,'[2,3,1]');
create table tt1 like t1;
insert /*+PARALLEL(8)*/into tt1 select * from t1;

call dbms_vector.refresh_index('vector_idx','tt1','c3',1,'FAST');
call dbms_vector.refresh_index('vector_idx','t1','c3',1,'FAST');
call dbms_vector.rebuild_index('vector_idx','tt1','c3');
call dbms_vector.rebuild_index('vector_idx','t1','c3');

##视图验证
--disable_warnings
drop table if exists t1;
drop view if exists v1;
--enable_warnings

CREATE TABLE t1 (c1 int primary key, c2 VARCHAR(30),c3 vector(3) ,c4 vector(3),
VECTOR INDEX vector_idx(c3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40)) partition by list columns (c1)(
  PARTITION p0 VALUES in(10),
  PARTITION p1 VALUES in(50)
);

create view v1 as select * from t1;
replace into v1 values(50,'[1,1,2]','[2,2,3]','[1,3,2]');
replace into t1 values(50 ,'[1,1,2]','[2,2,3]','[1,3,2]');
replace into v1 values(10,'[1,1,2]','[2,2,3]','[1,3,2]');
replace into v1 values(10,'[1,1,2]','[2,2,3]','[1,3,2]');
--error 1210
call dbms_vector.refresh_index('vector_idx','v1','c3',1,'FAST');
--error 1210
call dbms_vector.rebuild_index('vector_idx','v1','c3');

##复制表验证
--disable_warnings
drop table if exists t1;
drop table if exists t2;
--enable_warnings

CREATE TABLE t1 (c1 int primary key, c2 VARCHAR(30),c3 vector(3) ,c4 vector(3)) partition by list columns (c1)(
  PARTITION p0 VALUES in(10),
  PARTITION p1 VALUES in(50)
);
replace into t1 values(50,'[1,1,2]','[2,2,3]','[1,3,2]');
replace into t1 values(50 ,'[1,1,2]','[2,2,3]','[1,3,2]');
replace into t1 values(10,'[1,1,2]','[2,2,3]','[1,3,2]');
replace into t1 values(10,'[1,1,2]','[2,2,3]','[1,3,2]');
create table t2 as select * from t1;
CREATE VECTOR INDEX vector_idx_c4  ON t1 (c4)  WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40);
CREATE VECTOR INDEX vector_idx_c4  ON t2 (c4)  WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40);


call dbms_vector.refresh_index('vector_idx_c4','t1','c4',1,'FAST');
call dbms_vector.rebuild_index('vector_idx_c4','t1','c4');
call dbms_vector.refresh_index('vector_idx_c4','t2','c4',1,'FAST');
call dbms_vector.rebuild_index('vector_idx_c4','t2','c4');

##update操作
--disable_warnings
drop table if exists t1;
--enable_warnings

CREATE TABLE t1 (c1 int primary key, c2 vector(3),c3 vector(3) ,c4 vector(3),
VECTOR INDEX vector_idx(c2) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
insert into t1 values(1,'[1,1,2]','[2,2,3]','[1,3,2]');
insert into t1 values(2,'[1,0,3]','[1,0,3]','[2,3,2]');
insert into t1 values(3,'[-1,2,2]','[-3,2,3]','[4,3,3]');
insert into t1 values(4,'[-1,-2,-2]','[-4,2,3]',null);
insert into t1 values(5,'[-1,-3,-2]',null,'[2,3,1]');

update t1 set c1 = 10 where c1 =5;
update t1 set c2 = '[1,23,null]' where c1 =5;
update t1 set c2 = '[1,23,abs(null)]' where c1 =5;
update t1 set c2 =[l2_distance('[1,3,2]','[1,1,2]'),l2_distance('[1,2,2]','[1,1,11]'),l2_distance('[1,1,2]','[1,1,2]')] where c3 is null;
update t1 set c1 = l2_distance('[1,8,2]','[1,1,2]') where c3 = '[2,2,3]';
update t1 set c1 = l2_distance('[1,10,2]','[1,1,2]'),c2 = '[1,1,1]',c3 = '[0,1,0]',c4 = '[0.1,1.2,100]' where c4 = '[2,3,2]';

call dbms_vector.refresh_index('vector_idx','t1','c2',1,'FAST');
call dbms_vector.rebuild_index('vector_idx','t1');

##delete
--disable_warnings
drop table if exists t1;
--enable_warnings

CREATE TABLE t1 (c1 int primary key, c2 vector(3),c3 vector(3) ,c4 vector(3));
insert into t1(c1,c2,c3,c4) values(1,'[1,1,2]','[2,2,3]','[1,3,2]');
insert into t1(c1,c2,c3,c4) values(2,'[1,0,3]','[1,0,3]','[2,3,2]');
insert into t1(c1,c2,c3,c4) values(3,'[-1,2,2]','[-3,2,3]','[4,3,3]');
insert into t1(c1,c2,c3,c4) values(4,'[-1,-2,-2]','[-4,2,3]',null);
insert into t1(c1,c2,c3,c4) values(5,'[-1,-3,-2]',null,'[2,3,1]');

drop table if exists t2;
CREATE TABLE t2 (a1 int primary key , a2 vector(3),a3 vector(3) ,a4 vector(3),
VECTOR INDEX vector_idx(a2) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
insert into t2 select c1,c2,c3,c4 from t1;

select * from t1 inner join t2 on c2+c3+c4=a2+a3+a4 order by c1,c2,c3;
DELETE t1 FROM t1 INNER JOIN  t2 ON c3=c2 where a1 =3 or c4 is null;
DELETE t1 FROM t1 INNER JOIN  t2 ON l2_distance(c2,c3)=l2_distance(a3,a4) where a1 =3 or c4 is null;

call dbms_vector.refresh_index('vector_idx','t2','a2',1,'FAST');
call dbms_vector.rebuild_index('vector_idx','t2');

##replace into 后刷新
--disable_warnings
drop table if exists t1;
--enable_warnings

CREATE TABLE t1 (c1 int primary key, c2 vector(3),c3 vector(3) ,c4 vector(3),
VECTOR INDEX vector_idx(c3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
insert into t1(c1) values(l2_distance([1,2,3],[1,2,4]));
replace into t1(c1,c2,c3,c4) values(l2_distance([1,2,3],[1,2,100]),[-1,-3,-2],[2,3,1],[2,3,1]);
replace into t1(c1,c2,c3,c4) values(l2_distance([1,2,3],[1,2,100]),[-1,-3,-2],null,[2,3,1]);
replace into t1(c1,c2,c3,c4) values(-1,[-1,-3,-2],null,[2,3,1]);
replace into t1(c1,c2,c3,c4) values(l2_distance([1,2,3,1,1,1,1,1,1,1,2,3,1,1,1,1,1,1,1,2,3,1,1,1,1,1,1,1,2,3,1,1,1,1,1,1,1,2,3,1,1,1,1,1,1,1,2,3,1,1,1,1,1,1,1,2,3,1,1,1,1,1,1,1,2,3,1,1,1,1,1,1,1,2,3,1,1,1,1,1,1,1,2,3,1,1,1,1,1,1,1,2,3,1,1,1,1,1,1,1,2,3,1,1,1,1,1,1],[1,2,3,1,1,1,1,1,1,1,2,3,1,1,1,1,1,1,1,2,3,1,1,1,1,1,1,1,2,3,1,1,1,1,1,1,1,2,3,1,1,1,1,1,1,1,2,3,1,1,1,1,1,1,1,2,3,1,1,1,1,1,1,1,2,3,1,1,1,1,1,1,1,2,3,1,1,1,1,1,1,1,2,3,1,1,1,1,1,1,1,2,3,1,1,1,1,1,1,1,2,3,10.20,1,1,1,1,1]),[1,2,3],null,[2,3,1]);
replace into t1(c1,c2,c3,c4) values(l2_distance([1,2,3],[1,2,100]),[-1,-3,-2],null,[2,3,1]);
call dbms_vector.refresh_index('vector_idx','t1','c3',1,'FAST');
call dbms_vector.rebuild_index('vector_idx','t1');


####INSERT ... ON DUPLICATE KEY UPDATE
--disable_warnings
drop table if exists t1;
--enable_warnings

CREATE TABLE t1 (c1 int AUTO_INCREMENT primary key , c2 vector(3),c3 vector(3) ,c4 BLOB,
VECTOR INDEX vector_idx(c3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));

insert into t1(c1) values(l2_distance([1],[3]))ON DUPLICATE KEY UPDATE c1='[1,1,3]';
insert into t1(c2,c3,c4) values([l2_distance([1.5+1,2.5-1,-1.5*2],[-1.5 % 1,1.5+1,1%1]),l2_distance([-1.5+1,2.5-1,-1.5*2],[-1.5 % 1,1.5+1.5,1%1]),l2_distance([1.5+1,2.5-1,-1.5*2],[-1.5 % 1,1.5+1,1%1])],'[1,0,3]','[2,3,2]') ON DUPLICATE KEY UPDATE c2='[1,1,3]';
insert into t1(c2,c3,c4) values('[1,2,3]','[1,3,3]','[2,1,2]') ON DUPLICATE KEY UPDATE c2='[1,null,3]';
insert into t1(c2,c3,c4) values('[1,6,3]','[1,4,3]','[2,3,2]') ON DUPLICATE KEY UPDATE c2='[1,1,3]';
insert into t1(c2,c3,c4) values('[1,6,3]','[1,4,3]','[2,3,2]') ON DUPLICATE KEY UPDATE c2='[1,1,3]';
insert into t1(c2,c3,c4) values('[1,6,3]','[1,4,3]','[2,3,2]') ON DUPLICATE KEY UPDATE c2='[1,1,3]';
select * from t1 order by c1;

call dbms_vector.refresh_index('vector_idx','t1','c3',1,'FAST');
call dbms_vector.rebuild_index('vector_idx','t1');


##INSERT ALL
--disable_warnings
drop table if exists t1;
--enable_warnings

CREATE TABLE t1 (c1 int AUTO_INCREMENT primary key , c2 vector(3),c3 vector(3) ,c4 BLOB,
VECTOR INDEX vector_idx(c3) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
INSERT INTO T1 (C1,C2)VALUES (l2_distance([1],[2]), [1,2,3]), (l2_distance([2],[4]), [1,2,3]), (l2_distance([3],[46]), [1,2,3]);
INSERT INTO T1 (C3,C4)VALUES ([1,2,3], l2_distance([1],[2])),([2,3,-1],l2_distance([2],[2])),([2.23,4.23,1.323],l2_distance([3],[46]));
SELECT * FROM T1 order by c1,c4;
call dbms_vector.refresh_index('vector_idx','t1','c3',1,'FAST');
call dbms_vector.rebuild_index('vector_idx','t1');

##外键
--disable_warnings
drop table if exists t2;
drop table if exists t1;
--enable_warnings
drop table if exists t2;
drop table if exists t1;
CREATE TABLE t1 (c1 int primary key, c2 vector(3),c3 vector(3) ,c4 vector(3),
VECTOR INDEX vector_idx(c2) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
insert into t1(c1,c2,c3,c4) values(1,'[1,1,2]','[2,2,3]','[1,3,2]');
insert into t1(c1,c2,c3,c4) values(2,'[1,0,3]','[1,0,3]','[2,3,2]');
insert into t1(c1,c2,c3,c4) values(3,'[-1,2,2]','[-3,2,3]','[4,3,3]');
insert into t1(c1,c2,c3,c4) values(4,'[-1,-2,-2]','[-4,2,3]',null);
insert into t1(c1,c2,c3,c4) values(5,'[-1,-3,-2]',null,'[2,3,1]');

CREATE TABLE t2 (a1 int primary key , a2 vector(3),a3 vector(3) ,a4 vector(3),
VECTOR INDEX vector_idx(a2) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40));
insert into t2 select c1,c2,c3,c4 from t1 ;
ALTER TABLE t2 ADD CONSTRAINT fk_a1 FOREIGN KEY (a1) REFERENCES t1(c1) ON DELETE CASCADE ON UPDATE CASCADE;
CREATE VECTOR INDEX vector_idx_c3  ON t1 (c3)  WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40);

delete from t1 where c2 =[1,1,2];
delete from t1 where c1 =l2_distance([1],[3]);
insert into t1(c1,c2,c3,c4) values(6,'[1,1,2]','[2,2,3]','[1,3,2]');
insert into t1(c1,c2,c3,c4) values(100,'[1,1,2]','[2,2,3]','[1,3,2]');
##--error 1210
##update t1 set c1=10 where c4 is null;
TRUNCATE TABLE t2;

call dbms_vector.refresh_index('vector_idx','t1','c2',1,'FAST');
call dbms_vector.rebuild_index('vector_idx','t1');

call dbms_vector.refresh_index('vector_idx','t2','a2',1,'FAST');
call dbms_vector.rebuild_index('vector_idx','t2');

drop table if exists t2;
drop table if exists t1;



--echo  ########清空回收站，删除测试数据库，表等 ##########
--disable_warnings
drop database  IF EXISTS  obljh;
--enable_warnings
purge recyclebin;

