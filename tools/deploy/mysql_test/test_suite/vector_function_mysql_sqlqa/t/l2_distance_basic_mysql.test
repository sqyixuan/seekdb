select l2_distance([c2],[c3]),* from t1 where c2 is not null and c3 is not null order by c1;
select l2_distance([c3],[c4]),* from t1 where c3 is not null and c4 is not null order by c1;
select l2_distance([c4],[c5]),* from t1 where c4 is not null and c5 is not null order by c1;
select l2_distance([c5],[c2]),* from t1 where c5 is not null and c2 is not null order by c1;
select l2_distance([c5],[c3]),* from t1 where c5 is not null and c3 is not null order by c1;
select l2_distance([c2],[c4]),* from t1 where c2 is not null and c4 is not null order by c1;



--echo ##浮点类型(float,double)
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int PRIMARY KEY, c2 float,c3 double);
INSERT INTO t1 (c1, c2, c3) VALUES (1, 1.1, 1.11);
INSERT INTO t1 (c1, c2, c3) VALUES (2, 2.2, NULL);
INSERT INTO t1 (c1, c2, c3) VALUES (3, NULL, 3.33);
INSERT INTO t1 (c1, c2, c3) VALUES (4, NULL, NULL);
INSERT INTO t1 (c1, c2, c3) VALUES (5, 5.5, NULL);


--error 1210
select l2_distance(c2,c2),c2,* from t1 where c2 is not null order by c1;
--error 1210
select l2_distance(c3,c3),c3,* from t1 where c3 is not null order by c1;
select l2_distance([c2],[c3]),* from t1 where c2 is not null and c3 is not null order by c1;
select l2_distance([c2],[1]),* from t1 where c2 is not null and c3 is not null order by c1;
select l2_distance([c3],[1]),* from t1 where c2 is not null and c3 is not null order by c1;


--echo ##bit类型
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int PRIMARY KEY, c2 bit(10));
INSERT INTO t1 (c1, c2) VALUES (1, b'1');
INSERT INTO t1 (c1, c2) VALUES (2, b'0');
INSERT INTO t1 (c1, c2) VALUES (3, b'10');
INSERT INTO t1 (c1, c2) VALUES (4, 1);
INSERT INTO t1 (c1, c2) VALUES (5, null);
INSERT INTO t1 (c1, c2) VALUES (6, b'0111');

--error 1210
select l2_distance(c2,c2),c2,* from t1 where c2 is not null order by c1;
--error 1235
select l2_distance([c2],[c2]),* from t1 where c2 is not null  order by c1;
--error 1235 
select l2_distance([c2],[1]),* from t1 where c2 is not null  order by c1;

--echo ##bool
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int PRIMARY KEY, c2 bool);
INSERT INTO t1 (c1, c2) VALUES (1, 1);
INSERT INTO t1 (c1, c2) VALUES (2, 0);
INSERT INTO t1 (c1, c2) VALUES (3,false);
INSERT INTO t1 (c1, c2) VALUES (4, 100);
INSERT INTO t1 (c1, c2) VALUES (5, null);
INSERT INTO t1 (c1, c2) VALUES (6, true);

--error 1210
select l2_distance(c2,c2),c2,* from t1 where c2 is not null order by c1;
select l2_distance([c2],[c2]),* from t1 where c2 is not null  order by c1; 
select l2_distance([c2],[1]),* from t1 where c2 is not null  order by c1;



--echo ##扩展类型(TINYINT、MEDIUMINT 和 BIGINT)
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int PRIMARY KEY, c2 TINYINT,c3 MEDIUMINT,c4 BIGINT);
INSERT INTO t1 (c1, c2, c3, c4) VALUES (1, 10, 100, 1000);
INSERT INTO t1 (c1, c2, c3, c4) VALUES (2, 20, 200, NULL);
INSERT INTO t1 (c1, c2, c3, c4) VALUES (3, 30, NULL, NULL);
INSERT INTO t1 (c1, c2, c3, c4) VALUES (4, 40, NULL, NULL);
