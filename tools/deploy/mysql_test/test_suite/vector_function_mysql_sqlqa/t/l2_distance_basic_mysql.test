--echo ##数据类型验证
--echo ##数值类型(INTEGER、SMALLINT、DECIMAL 和 NUMERIC)
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 int PRIMARY KEY,c2 INTEGER,c3 SMALLINT,c4 DECIMAL(10,2),c5 NUMERIC(10,2));
INSERT INTO t1 (c1, c2, c3, c4, c5) VALUES (1, 100, 20, 3.14, NULL);
INSERT INTO t1 (c1, c2, c3, c4, c5) VALUES (2, 200, 40, NULL, NULL);
INSERT INTO t1 (c1, c2, c3, c4, c5) VALUES (3, 300, 60, 6.28, 7.89);
INSERT INTO t1 (c1, c2, c3, c4, c5) VALUES (4, 400, NULL, 8.56, 9.12);
INSERT INTO t1 (c1, c2, c3, c4, c5) VALUES (5, NULL, 100, NULL, 11.22);

--error 1210
select l2_distance(c2,c2),c2,* from t1 where c2 is not null order by c1;
select l2_distance([c2],[1]),c2,* from t1 where c2 is not null order by c1;
--error 4152
select l2_distance([c2],[null]),c2,* from t1 where c2 is not null order by c1;
select l2_distance([c2],null),c2,* from t1 where c2 is not null order by c1 ;
select l2_distance([1],[c2]),c2,* from t1 where c2 is not null order by c1;
--error 4152
select l2_distance([null],[c2]),c2,* from t1 where c2 is not null order by c1;
select l2_distance(null,[c2]),c2,* from t1 where c2 is not null order by c1 ;

--error 1210
select l2_distance(c3,c3),c3,* from t1 where c3 is not null order by c1;
select l2_distance([c3],[1]),c3,* from t1 where c3 is not null order by c1;
--error 4152
select l2_distance([c3],[null]),c3,* from t1 where c3 is not null order by c1;
select l2_distance([c3],null),c3,* from t1 where c3 is not null order by c1 ;
select l2_distance([1],[c3]),c3,* from t1 where c3 is not null order by c1;
--error 4152
select l2_distance([null],[c3]),c3,* from t1 where c3 is not null order by c1;
select l2_distance(null,[c3]),c3,* from t1 where c3 is not null order by c1 ;

--error 1210
select l2_distance(c4,c4),c2,* from t1 where c4 is not null order by c1;
select l2_distance([c4],[1]),c4,* from t1 where c4 is not null order by c1;
--error 4152
select l2_distance([c4],[null]),c4,* from t1 where c4 is not null order by c1;
select l2_distance([c4],null),c4,* from t1 where c4 is not null order by c1 ;
select l2_distance([1],[c4]),c4,* from t1 where c4 is not null order by c1;
--error 4152
select l2_distance([null],[c4]),c4,* from t1 where c4 is not null order by c1;
select l2_distance(null,[c4]),c4,* from t1 where c4 is not null order by c1 ;

--error 1210
select l2_distance(c5,c5),c5,* from t1 where c5 is not null order by c1;
select l2_distance([c5],[1]),c5,* from t1 where c5 is not null order by c1;
--error 4152
select l2_distance([c5],[null]),c5,* from t1 where c5 is not null order by c1;
select l2_distance([c5],null),c5,* from t1 where c5 is not null order by c1 ;
select l2_distance([1],[c5]),c5,* from t1 where c5 is not null order by c1;
--error 4152
select l2_distance([null],[c5]),c5,* from t1 where c5 is not null order by c1;
