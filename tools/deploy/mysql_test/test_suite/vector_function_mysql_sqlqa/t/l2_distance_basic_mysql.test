##json类型
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (c1 INT PRIMARY KEY, c2 json);
INSERT INTO t1 (c1, c2) VALUES (1, '{"name": "Alice", "age": 30}');
INSERT INTO t1 (c1, c2) VALUES (2, '[{"item": "apple"}, {"item": "banana"}]');
INSERT INTO t1 (c1, c2) VALUES (3, '{"person": {"name": "Bob", "details": {"age": 25, "city": "New York"}}}');
INSERT INTO t1 (c1, c2) VALUES (4, NULL);
INSERT INTO t1 (c1, c2) VALUES (5, '{}');
--error 1235
select l2_distance([c2],[1]) from t1 where c2 is null;
--error 1210
select l2_distance(c2,[1]) from t1 where c2 is null;
--error 1235
select l2_distance([c2],[1]) from t1 ;


--echo ##函数嵌套
--echo ##字符函数嵌套
select ASCII(l2_distance([1,1],[1.11,2])) from dual;
select l2_distance( [ASCII('oceanbase')],[ASCII('Oceanbase')]) from dual;

select BIN(l2_distance([1,1],[1.11,2])) from dual;
select l2_distance( [BIN(12)],[BIN(23)]) from dual;

select BIT_LENGTH(l2_distance([1,1],[1.11,2])) from dual;
select l2_distance( [BIT_LENGTH('oceanbase')],[BIT_LENGTH('mysql')]) from dual;

select CHAR(l2_distance([1,1],[1.11,2])) from dual;
--error 1235
select l2_distance([CHAR(100)],[CHAR(99)]) from dual;

select CHAR_LENGTH(l2_distance([1,1],[1.11,2])) from dual;
select l2_distance( [CHAR_LENGTH('中国'),CHAR_LENGTH('俄罗斯')],[CHAR_LENGTH('中国'),CHAR_LENGTH('哥伦比亚')]) from dual;

select CONCAT(l2_distance([1,1],[1.11,2]),l2_distance([1,1],[1.11,2]),l2_distance([1,1],[1.11,2]),l2_distance([1,1],[1.11,2]),l2_distance([1,1],[1.11,2])) from dual;
select l2_distance( [CONCAT(1,2,3,5)],[CONCAT(1,2,3)]) from dual;

select FIND_IN_SET(l2_distance([1,1],[1.11,2]),l2_distance([1,1],[1,2])) from dual;
select l2_distance( [FIND_IN_SET('a','null,b,c,d')],[FIND_IN_SET('d','a,b,c,d')]) from dual;

select LENGTH(l2_distance([1,1],[1.11,2])) from dual;
select l2_distance( [LENGTH('a,b,c,d')],[LENGTH('a,b,c,d,e')]) from dual;

--echo ##数学函数嵌套
select ABS(-l2_distance([1,1],[1.11,2])) from dual;
--error 4152
select l2_distance([ABS(-1001),abs(null)],[ABS(-0.12),22]) from dual;
select l2_distance([ABS(-1001),abs(-1)],[ABS(-0.12),22]) from dual;


select ACOS(-l2_distance([1,1],[1.11,2])) from dual;
--error 4152
select l2_distance([ACOS(-1001),ACOS(null)],[ACOS(-0.12),22]) from dual;
--error 4152
select l2_distance([ACOS(-1001),ACOS(-1)],[ACOS(-0.12),22]) from dual;


select ATAN(-l2_distance([1,1],[1.11,2])) from dual;
--error 4152
select l2_distance([ATAN(-1001),ATAN(null)],[ATAN(-0.12),22]) from dual;
select l2_distance([ATAN(-1001),ATAN(-1)],[ATAN(-0.12),22]) from dual;


--error 1582
select PI(l2_distance([1,1],[1.11,2])) from dual;
select l2_distance([PI(),PI()],[PI(),22]) from dual;
select l2_distance([PI(),PI()],[PI(),PI()*2]) from dual;


select FLOOR(-l2_distance([1,1],[1.11,2])) from dual;
--error 4152
select l2_distance([FLOOR(-1001),FLOOR(null)],[FLOOR(-0.12),22]) from dual;
select l2_distance([FLOOR(-1001),FLOOR(-1)],[FLOOR(-0.12),22]) from dual;


--echo ##时间函数嵌套
select DATE(l2_distance([2023,1],[1,1])) from dual;
--error 1235
select l2_distance([DATE(-1001),DATE(null)],[DATE(-0.12),22]) from dual;
--error 1235
select l2_distance([DATE(-1001),DATE(-1)],[DATE(-0.12),22]) from dual;


select TO_DAYS(l2_distance([2023,1],[1,1])) from dual;
select l2_distance([TO_DAYS('20151104'),TO_DAYS('20151104')],[TO_DAYS('20151104'),22]) from dual;
select l2_distance([TO_DAYS('20151103'),TO_DAYS('20151104')],[TO_DAYS('20151104'),22]) from dual;


select YEAR(l2_distance([20231123,1],[1,1])) from dual;

select l2_distance([YEAR('20151104'),YEAR('20151104')],[YEAR('20151104'),22]) from dual;

select l2_distance([YEAR('20151103'),YEAR('20151104')],[YEAR('20151104'),22]) from dual;


--echo ##流程控制函数
SELECT CASE l2_distance([1,1],[1,1.1])>1  WHEN l2_distance([1,1],[1,1.1]) THEN 'TRUE' ELSE 'FALSE' END;
SELECT l2_distance( [CASE 'B' WHEN 'A' THEN 2 WHEN 'B' THEN 3 END,CASE 'B' WHEN 'A' THEN 1 WHEN 'B' THEN 2 END],[CASE 'B' WHEN 'A' THEN 1 WHEN 'B' THEN 2 END,CASE 'B' WHEN 'A' THEN 1 WHEN 'B' THEN 2 END]) from dual;

--echo ##比较函数
SELECT ISNULL(l2_distance([1,1],null)) from dual;

