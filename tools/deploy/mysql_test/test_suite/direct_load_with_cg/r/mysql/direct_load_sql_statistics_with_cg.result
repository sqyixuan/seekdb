带主键的二级分区表
drop table if exists lineitem;
create table lineitem(
l_orderkey           bigint NOT NULL ,
l_partkey            bigint NOT NULL ,
l_suppkey            bigint NOT NULL ,
l_linenumber         bigint NOT NULL ,
l_quantity           bigint NOT NULL ,
l_extendedprice      decimal(10,2) NOT NULL ,
l_discount           decimal(10,2) NOT NULL ,
l_tax                decimal(10,2) NOT NULL ,
l_returnflag         char(1) ,
l_linestatus         char(1) ,
l_shipdate           date ,
l_commitdate         date ,
l_receiptdate        date ,
l_shipinstruct       char(25) ,
l_shipmode           char(10) ,
l_comment            varchar(44),
primary key(L_ORDERKEY, L_LINENUMBER)
) partition by hash(L_ORDERKEY)
subpartition by range(l_linenumber) subpartition template
(subpartition p0 values less than (10),
subpartition p1 values less than (1000),
subpartition p2 values less than (10000),
subpartition p3 values less than maxvalue)  partitions 10 with column group(all columns, each column);
select count(*) from lineitem;
count(*)
100000
explain select * from lineitem;
Query Plan
================================================================
|ID|OPERATOR                    |NAME    |EST.ROWS|EST.TIME(us)|
----------------------------------------------------------------
|0 |PX COORDINATOR              |        |160516  |1556032     |
|1 |└─EXCHANGE OUT DISTR        |:EX10000|160516  |1082145     |
|2 |  └─PX PARTITION ITERATOR   |        |160516  |15674       |
|3 |    └─COLUMN TABLE FULL SCAN|lineitem|160516  |15674       |
================================================================
Outputs & filters:
-------------------------------------
  0 - output([INTERNAL_FUNCTION(lineitem.l_orderkey, lineitem.l_partkey, lineitem.l_suppkey, lineitem.l_linenumber, lineitem.l_quantity, lineitem.l_extendedprice,
       lineitem.l_discount, lineitem.l_tax, lineitem.l_returnflag, lineitem.l_linestatus, lineitem.l_shipdate, lineitem.l_commitdate, lineitem.l_receiptdate, 
      lineitem.l_shipinstruct, lineitem.l_shipmode, lineitem.l_comment)]), filter(nil), rowset=256
  1 - output([INTERNAL_FUNCTION(lineitem.l_orderkey, lineitem.l_partkey, lineitem.l_suppkey, lineitem.l_linenumber, lineitem.l_quantity, lineitem.l_extendedprice,
       lineitem.l_discount, lineitem.l_tax, lineitem.l_returnflag, lineitem.l_linestatus, lineitem.l_shipdate, lineitem.l_commitdate, lineitem.l_receiptdate, 
      lineitem.l_shipinstruct, lineitem.l_shipmode, lineitem.l_comment)]), filter(nil), rowset=256
      dop=1
  2 - output([lineitem.l_orderkey], [lineitem.l_linenumber], [lineitem.l_partkey], [lineitem.l_suppkey], [lineitem.l_quantity], [lineitem.l_extendedprice],
       [lineitem.l_discount], [lineitem.l_tax], [lineitem.l_returnflag], [lineitem.l_linestatus], [lineitem.l_shipdate], [lineitem.l_commitdate], [lineitem.l_receiptdate],
       [lineitem.l_shipinstruct], [lineitem.l_shipmode], [lineitem.l_comment]), filter(nil), rowset=256
      force partition granule
  3 - output([lineitem.l_orderkey], [lineitem.l_linenumber], [lineitem.l_partkey], [lineitem.l_suppkey], [lineitem.l_quantity], [lineitem.l_extendedprice],
       [lineitem.l_discount], [lineitem.l_tax], [lineitem.l_returnflag], [lineitem.l_linestatus], [lineitem.l_shipdate], [lineitem.l_commitdate], [lineitem.l_receiptdate],
       [lineitem.l_shipinstruct], [lineitem.l_shipmode], [lineitem.l_comment]), filter(nil), rowset=256
      access([lineitem.l_orderkey], [lineitem.l_linenumber], [lineitem.l_partkey], [lineitem.l_suppkey], [lineitem.l_quantity], [lineitem.l_extendedprice],
