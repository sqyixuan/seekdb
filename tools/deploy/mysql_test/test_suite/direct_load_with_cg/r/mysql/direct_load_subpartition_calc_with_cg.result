use test;
alter system set direct_load_allow_fallback=False;
# TEST 1 PARTITION BY LIST COLUMNS(c8) SUBPARTITION BY HASH(c2)
# Create table
drop table if exists lineitem;
create table lineitem(
`c1` varchar(10) NOT NULL,
`c2` bigint(20) NOT NULL,
`c3` char(10) NOT NULL,
`c4` date NOT NULL,
`c5` datetime NOT NULL,
`c6` decimal(5,2) NOT NULL,
`c7` double NOT NULL,
`c8` int(11) NOT NULL,
`c9` smallint(6) NOT NULL,
`c10` time NOT NULL,
`c11` tinyint(4) NOT NULL,
`c13` json DEFAULT NULL,
`c14` mediumint(9) DEFAULT NULL,
`c15` mediumtext DEFAULT NULL,
`c16` float DEFAULT NULL,
`c17` enum('M','F') not NULL,
`md5` varchar(128) not NULL,
PRIMARY KEY (c1,c5,c2,c8))PARTITION BY LIST COLUMNS(c8) SUBPARTITION BY HASH(c2) SUBPARTITIONS 3 (PARTITION p0 VALUES IN (1,2,3,4,5,6,7),
PARTITION p1 VALUES IN (8,9,10,11,12,13,14,15),
PARTITION p2 VALUES IN (default)
) with column group(all columns, each column);
set @@ob_query_timeout = 1000000*60*60*10, @@ob_trx_timeout=1000000*60*60*10;
# Start load data
# Query table
select count(*) from lineitem;
count(*)
3
# TEST 2 partition by key(c1) SUBPARTITION BY RANGE(c2)
# Create table
drop table if exists lineitem;
create table lineitem(
`c1` varchar(10) NOT NULL,
`c2` bigint(20) NOT NULL,
`c3` char(10) NOT NULL,
`c4` date NOT NULL,
`c5` datetime NOT NULL,
`c6` decimal(5,2) NOT NULL,
`c7` double NOT NULL,
`c8` int(11) NOT NULL,
`c9` smallint(6) NOT NULL,
`c10` time NOT NULL,
`c11` tinyint(4) NOT NULL,
`c13` json DEFAULT NULL,
`c14` mediumint(9) DEFAULT NULL,
`c15` mediumtext DEFAULT NULL,
`c16` float DEFAULT NULL,
`c17` enum('M','F') DEFAULT NULL,
`md5` varchar(128) DEFAULT NULL,
PRIMARY KEY (c1,c2))partition by key(c1) SUBPARTITION BY RANGE(c2) SUBPARTITION TEMPLATE (SUBPARTITION p0 VALUES LESS than(1000),
SUBPARTITION p1 VALUES LESS THAN (2000),
SUBPARTITION p2 VALUES LESS THAN (3000),
SUBPARTITION p3 VALUES LESS THAN (MAXVALUE)
)PARTITIONS 10 with column group(all columns, each column);
set @@ob_query_timeout = 1000000*60*60*10, @@ob_trx_timeout=1000000*60*60*10;
# Start load data
# Query table
select count(*) from lineitem;
count(*)
3
