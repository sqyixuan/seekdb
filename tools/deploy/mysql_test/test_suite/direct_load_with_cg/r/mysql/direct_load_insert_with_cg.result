use test;
alter system set direct_load_allow_fallback=False;
drop table if exists lineitem;
create table lineitem(
l_orderkey           bigint NOT NULL ,
l_partkey            bigint NOT NULL ,
l_suppkey            bigint NOT NULL ,
l_linenumber         bigint NOT NULL ,
l_quantity           bigint NOT NULL ,
l_extendedprice      decimal(10,2) NOT NULL ,
l_discount           decimal(10,2) NOT NULL ,
l_tax                decimal(10,2) NOT NULL ,
l_returnflag         char(1) ,
l_linestatus         char(1) ,
l_shipdate           date ,
l_commitdate         date ,
l_receiptdate        date ,
l_shipinstruct       char(25) ,
l_shipmode           char(10) ,
l_comment            varchar(44),
primary key(L_ORDERKEY, L_LINENUMBER)
) partition by hash(L_ORDERKEY) partitions 10 with column group(all columns, each column);
set @@ob_query_timeout = 1000000*60*60*10, @@ob_trx_timeout=1000000*60*60*10;
select count(*) from lineitem;
count(*)
100000
ERROR 23000: Duplicated primary key
select count(*) from lineitem;
count(*)
100000
ERROR 42000: Result consisted of more than one row
select count(*) from lineitem;
count(*)
100100
truncate lineitem;
select count(*) from lineitem;
count(*)
100000
select count(*) from lineitem;
count(*)
100100
truncate lineitem;
select count(*) from lineitem;
count(*)
100000
ERROR 23000: Duplicated primary key
select count(*) from lineitem;
count(*)
100000
truncate lineitem;
select count(*) from lineitem;
count(*)
100000
ERROR 42000: Result consisted of more than one row
select count(*) from lineitem;
count(*)
100000
truncate lineitem;
ERROR 23000: Duplicated primary key
select count(*) from lineitem;
count(*)
0
truncate lineitem;
select count(*) from lineitem;
count(*)
200
drop table lineitem;
alter system set direct_load_allow_fallback=True;
