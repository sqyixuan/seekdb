--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: jianyun.sjy
# owner group: ddl
# description: direct load empty table

--source mysql_test/test_suite/direct_load_data/include/copy_data_for_direct_load.inc
connect (conn_query,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,oceanbase,$OBMYSQL_PORT);
--disable_warnings
connection default;
--enable_query_log
use test;

--source mysql_test/test_suite/direct_load_data/include/set_direct_load_allow_fallback_false.inc

--echo # TEST 1 PARTITION BY LIST COLUMNS(c8) SUBPARTITION BY HASH(c2)
--echo # Create table
--disable_warnings
drop table if exists lineitem;
--enable_warnings
create table lineitem(
    `c1` varchar(10) NOT NULL,
    `c2` bigint(20) NOT NULL,
    `c3` char(10) NOT NULL,
    `c4` date NOT NULL,
    `c5` datetime NOT NULL,
    `c6` decimal(5,2) NOT NULL,
    `c7` double NOT NULL,
    `c8` int(11) NOT NULL,
    `c9` smallint(6) NOT NULL,
    `c10` time NOT NULL,
    `c11` tinyint(4) NOT NULL,
    `c13` json DEFAULT NULL,
    `c14` mediumint(9) DEFAULT NULL,
    `c15` mediumtext DEFAULT NULL,
    `c16` float DEFAULT NULL,
    `c17` enum('M','F') not NULL,
    `md5` varchar(128) not NULL,
    PRIMARY KEY (c1,c5,c2,c8))PARTITION BY LIST COLUMNS(c8) SUBPARTITION BY HASH(c2) SUBPARTITIONS 3 (PARTITION p0 VALUES IN (1,2,3,4,5,6,7),
    PARTITION p1 VALUES IN (8,9,10,11,12,13,14,15),
    PARTITION p2 VALUES IN (default)
) with column group(all columns, each column);
set @@ob_query_timeout = 1000000*60*60*10, @@ob_trx_timeout=1000000*60*60*10;
--echo # Start load data
--disable_query_log
eval load data /*+ direct(true,0) parallel(1) */ infile "$OBSERVER_DIR/$DATA_FOLDER_NAME/misc/subpartition-table.csv" into table lineitem fields terminated by '|' enclosed by '''' lines starting by '' terminated by '\n';
--enable_query_log
--echo # Query table
select count(*) from lineitem;

--echo # TEST 2 partition by key(c1) SUBPARTITION BY RANGE(c2)
--echo # Create table
--disable_warnings
drop table if exists lineitem;
--enable_warnings
create table lineitem(
    `c1` varchar(10) NOT NULL,
    `c2` bigint(20) NOT NULL,
    `c3` char(10) NOT NULL,
    `c4` date NOT NULL,
    `c5` datetime NOT NULL,
    `c6` decimal(5,2) NOT NULL,
    `c7` double NOT NULL,
    `c8` int(11) NOT NULL,
    `c9` smallint(6) NOT NULL,
    `c10` time NOT NULL,
    `c11` tinyint(4) NOT NULL,
    `c13` json DEFAULT NULL,
    `c14` mediumint(9) DEFAULT NULL,
    `c15` mediumtext DEFAULT NULL,
    `c16` float DEFAULT NULL,
    `c17` enum('M','F') DEFAULT NULL,
    `md5` varchar(128) DEFAULT NULL,
    PRIMARY KEY (c1,c2))partition by key(c1) SUBPARTITION BY RANGE(c2) SUBPARTITION TEMPLATE (SUBPARTITION p0 VALUES LESS than(1000),
    SUBPARTITION p1 VALUES LESS THAN (2000),
    SUBPARTITION p2 VALUES LESS THAN (3000),
    SUBPARTITION p3 VALUES LESS THAN (MAXVALUE)
)PARTITIONS 10 with column group(all columns, each column);
set @@ob_query_timeout = 1000000*60*60*10, @@ob_trx_timeout=1000000*60*60*10;
--echo # Start load data
--disable_query_log
eval load data /*+ direct(true,0) parallel(1) */ infile "$OBSERVER_DIR/$DATA_FOLDER_NAME/misc/subpartition-table.csv" into table lineitem fields terminated by '|' enclosed by '''' lines starting by '' terminated by '\n';
--enable_query_log
--echo # Query table
select count(*) from lineitem;

--echo # TEST 3 ERROR HY000: Table has no partition for value
--echo # Create table
--disable_warnings
drop table if exists lineitem;
--enable_warnings
create table lineitem(
    `c1` varchar(10) NOT NULL,
    `c2` bigint(20) NOT NULL,
    `c3` char(10) NOT NULL,
    `c4` date NOT NULL,
    `c5` datetime NOT NULL,
    `c6` decimal(5,2) NOT NULL,
    `c7` double NOT NULL,
    `c8` int(11) NOT NULL,
    `c9` smallint(6) NOT NULL,
    `c10` time NOT NULL,
    `c11` tinyint(4) NOT NULL,
    `c13` json DEFAULT NULL,
    `c14` mediumint(9) DEFAULT NULL,
    `c15` mediumtext DEFAULT NULL,
    `c16` float DEFAULT NULL,
    `c17` enum('M','F') DEFAULT NULL,
    `md5` varchar(128) DEFAULT NULL,
    PRIMARY KEY (c1,c5))partition by key(c1) SUBPARTITION BY RANGE COLUMNS(c5)SUBPARTITION TEMPLATE (SUBPARTITION p0 VALUES LESS THAN ('2014-11-11'),
    SUBPARTITION p1 VALUES LESS THAN ('2015-11-11'),
    SUBPARTITION p2 VALUES LESS THAN ('2016-11-11')
)PARTITIONS 10 with column group(all columns, each column);
set @@ob_query_timeout = 1000000*60*60*10, @@ob_trx_timeout=1000000*60*60*10;
--echo # Start load data
--disable_query_log
--error 1526
eval load data /*+ direct(true,0) parallel(1) */ infile "$OBSERVER_DIR/$DATA_FOLDER_NAME/misc/subpartition-table.csv" into table lineitem fields terminated by '|' enclosed by '''' lines starting by '' terminated by '\n';
--enable_query_log

--echo # TEST 4 partition by hash(c02)
--echo # Create table
--disable_warnings
drop table if exists lineitem;
--enable_warnings
create table lineitem(
    c01 int(255) NOT NULL,
    c02 int,
    c03 bit(64),
    c04 char(4),
    c05 binary(255),
    c06 varbinary(255),
    c07 datetime(6),
    c08 timestamp(6) NULL DEFAULT NULL,
    tchar char(64) not null,
    ttinyint tinyint,
    tsmallint smallint,
    tmediumint mediumint,
    tinteger integer,
    tbigint bigint,
    tfloat float,
    tdouble double,
    tdecimal decimal(10,5),
    tdate date,
    ttime time,
    tyear year,
    tdatetime datetime,
    ttimestamp timestamp NULL DEFAULT NULL,
    tvarchar varchar(128),
    ttinyint1 tinyint(1),
    ttinyint4 tinyint(4),
    tblob blob,
    tjson json,
    primary key(c01,c02)
) partition by hash(c02) partitions 10 with column group(all columns, each column);
set @@ob_query_timeout = 1000000*60*60*10, @@ob_trx_timeout=1000000*60*60*10;
--echo # Start load data
--disable_query_log
eval load data /*+ direct(true,0) parallel(1) */ infile "$OBSERVER_DIR/$DATA_FOLDER_NAME/lineitem/lineitem-empty-table.tbl" into table lineitem fields terminated by '|' enclosed by '' lines starting by '' terminated by '\n';
--enable_query_log
--echo # Query table
select count(*) from lineitem;

