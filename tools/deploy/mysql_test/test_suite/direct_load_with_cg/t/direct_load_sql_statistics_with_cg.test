--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: jianyun.sjy
# owner group: ddl
# tags: direct, load_data, partition_table, opt_stats, optimizer
--source mysql_test/test_suite/direct_load_data/include/copy_data_for_direct_load.inc

connect (conn_query,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,oceanbase,$OBMYSQL_PORT);

--disable_warnings

connection default;
--enable_query_log
use test;

--source mysql_test/test_suite/direct_load_data/include/set_direct_load_allow_fallback_false.inc

#Create View
--disable_warnings
drop view if exists tab_stat_view;
drop view if exists col_stat_view;
drop view if exists col_part_stat_view;
drop view if exists col_subpart_stat_view;
drop view if exists modified_data_view;
--enable_warnings
create view tab_stat_view as select OWNER, TABLE_NAME, PARTITION_NAME, SUBPARTITION_NAME, NUM_ROWS, OBJECT_TYPE from oceanbase.DBA_TAB_STATISTICS where owner = 'test' order by PARTITION_NAME, SUBPARTITION_NAME;
create view col_stat_view as select OWNER, TABLE_NAME, COLUMN_NAME, LOW_VALUE, HIGH_VALUE, NUM_NULLS from oceanbase.DBA_TAB_COL_STATISTICS where owner = 'test' ORDER BY COLUMN_NAME;
create view col_part_stat_view as select OWNER, TABLE_NAME, COLUMN_NAME, PARTITION_NAME, LOW_VALUE, HIGH_VALUE, NUM_NULLS from oceanbase.DBA_PART_COL_STATISTICS where owner = 'test' ORDER BY COLUMN_NAME, PARTITION_NAME;
create view col_subpart_stat_view as select OWNER, TABLE_NAME, COLUMN_NAME, SUBPARTITION_NAME, LOW_VALUE, HIGH_VALUE, NUM_NULLS from oceanbase.DBA_SUBPART_COL_STATISTICS where owner = 'test' ORDER BY COLUMN_NAME, SUBPARTITION_NAME;
create view modified_data_view as select TABLE_OWNER, TABLE_NAME, PARTITION_NAME, SUBPARTITION_NAME, INSERTS, UPDATES, DELETES from oceanbase.DBA_TAB_MODIFICATIONS order by PARTITION_NAME, SUBPARTITION_NAME;

call dbms_stats.set_global_prefs('online_estimate_percent', '100');
--echo
--echo
--echo 带主键的非分区表
# Create table
--disable_warnings
drop table if exists lineitem;
--enable_warnings
create table lineitem(
    l_orderkey           bigint NOT NULL ,
    l_partkey            bigint NOT NULL ,
    l_suppkey            bigint NOT NULL ,
    l_linenumber         bigint NOT NULL ,
    l_quantity           bigint NOT NULL ,
    l_extendedprice      decimal(10,2) NOT NULL ,
    l_discount           decimal(10,2) NOT NULL ,
    l_tax                decimal(10,2) NOT NULL ,
    l_returnflag         char(1) ,
    l_linestatus         char(1) ,
    l_shipdate           date ,
    l_commitdate         date ,
    l_receiptdate        date ,
    l_shipinstruct       char(25) ,
    l_shipmode           char(10) ,
    l_comment            varchar(44),
    primary key(L_ORDERKEY, L_LINENUMBER)
) with column group(all columns, each column);

set @@ob_query_timeout = 1000000*60*60*10, @@ob_trx_timeout=1000000*60*60*10;
set _OPTIMIZER_GATHER_STATS_ON_LOAD = 'ON';
# Start load data

--disable_query_log
eval load data /*+ direct(true,0) gather_optimizer_statistics parallel(2) load_batch_size(100) */ infile "$OBSERVER_DIR/$DATA_FOLDER_NAME/lineitem/lineitem-100k-head100.tbl" into table lineitem fields terminated by '|' enclosed by '' lines starting by '' terminated by '\n';
--enable_query_log

# Query table
select count(*) from lineitem;
select * from tab_stat_view where table_name='lineitem';
select * from col_stat_view where table_name='lineitem';
select * from modified_data_view where table_name='lineitem';


--echo
--echo
--echo 带主键的一级分区表
# Create table
--disable_warnings
drop table if exists lineitem;
--enable_warnings
create table lineitem(
    l_orderkey           bigint NOT NULL ,
    l_partkey            bigint NOT NULL ,
    l_suppkey            bigint NOT NULL ,
    l_linenumber         bigint NOT NULL ,
    l_quantity           bigint NOT NULL ,
    l_extendedprice      decimal(10,2) NOT NULL ,
    l_discount           decimal(10,2) NOT NULL ,
    l_tax                decimal(10,2) NOT NULL ,
    l_returnflag         char(1) ,
    l_linestatus         char(1) ,
    l_shipdate           date ,
    l_commitdate         date ,
    l_receiptdate        date ,
    l_shipinstruct       char(25) ,
    l_shipmode           char(10) ,
    l_comment            varchar(44),
    primary key(L_ORDERKEY, L_LINENUMBER)
) partition by hash(L_ORDERKEY) partitions 10 with column group(all columns, each column);

# Start load data

--disable_query_log
eval load data /*+ direct(true,0) gather_optimizer_statistics parallel(2) load_batch_size(100) */ infile "$OBSERVER_DIR/$DATA_FOLDER_NAME/lineitem/lineitem-100k-head100.tbl" into table lineitem fields terminated by '|' enclosed by '' lines starting by '' terminated by '\n';
--enable_query_log

# Query table
select count(*) from lineitem;
explain select * from lineitem;
select * from tab_stat_view where table_name='lineitem';
select * from col_stat_view where table_name='lineitem';
select * from col_part_stat_view where table_name='lineitem';
select * from modified_data_view where table_name='lineitem';

--echo
--echo
--echo 带主键的二级分区表
# Create table
--disable_warnings
drop table if exists lineitem;
--enable_warnings
create table lineitem(
    l_orderkey           bigint NOT NULL ,
    l_partkey            bigint NOT NULL ,
    l_suppkey            bigint NOT NULL ,
    l_linenumber         bigint NOT NULL ,
    l_quantity           bigint NOT NULL ,
    l_extendedprice      decimal(10,2) NOT NULL ,
    l_discount           decimal(10,2) NOT NULL ,
    l_tax                decimal(10,2) NOT NULL ,
    l_returnflag         char(1) ,
    l_linestatus         char(1) ,
    l_shipdate           date ,
    l_commitdate         date ,
    l_receiptdate        date ,
    l_shipinstruct       char(25) ,
    l_shipmode           char(10) ,
    l_comment            varchar(44),
    primary key(L_ORDERKEY, L_LINENUMBER)
) partition by hash(L_ORDERKEY)
subpartition by range(l_linenumber) subpartition template
(subpartition p0 values less than (10),
subpartition p1 values less than (1000),
subpartition p2 values less than (10000),
subpartition p3 values less than maxvalue)  partitions 10 with column group(all columns, each column);

# Start load data

--disable_query_log
eval load data /*+ direct(true,0) gather_optimizer_statistics parallel(2) load_batch_size(100) */ infile "$OBSERVER_DIR/$DATA_FOLDER_NAME/lineitem/lineitem-100k.tbl" into table lineitem fields terminated by '|' enclosed by '' lines starting by '' terminated by '\n';
--enable_query_log

# Query table
select count(*) from lineitem;
explain select * from lineitem;
select * from tab_stat_view where table_name='lineitem';
select * from col_stat_view where table_name='lineitem';
select * from col_part_stat_view where table_name='lineitem';
select * from col_subpart_stat_view where table_name ='lineitem';
select * from modified_data_view where table_name='lineitem';

