# Create target table
--disable_warnings
drop table if exists lineitem1;
--enable_warnings
create table lineitem1(
    l_orderkey           bigint NOT NULL ,
    l_partkey            bigint NOT NULL ,
    l_suppkey            bigint NOT NULL ,
    l_linenumber         bigint NOT NULL ,
    l_quantity           bigint NOT NULL ,
    l_extendedprice      decimal(10,2) NOT NULL ,
    l_discount           decimal(10,2) NOT NULL ,
    l_tax                decimal(10,2) NOT NULL ,
    l_returnflag         char(1) ,
    l_linestatus         char(1) ,
    l_shipdate           date ,
    l_commitdate         date ,
    l_receiptdate        date ,
    l_shipinstruct       char(25) ,
    l_shipmode           char(10) ,
    l_comment            varchar(44),
    primary key(L_ORDERKEY, L_LINENUMBER)
) with column group(all columns, each column);
# Start insert into select
insert /*+ append enable_parallel_dml parallel(2) */ into lineitem1 select * from lineitem;
--source mysql_test/include/minorfreeze.inc
--source mysql_test/include/wait_minor_merge.inc

# Query table
select count(*) from lineitem1;
select * from tab_stat_view where table_name='lineitem1';
select * from col_stat_view where table_name='lineitem1';
select * from col_part_stat_view where table_name='lineitem1';
select * from modified_data_view where table_name='lineitem1';

# bugfix: 
# shouldn't sync stats if the ddl task is from load data's direct_load
--disable_warnings
drop table if exists lineitem;
--enable_warnings
create table lineitem(
    l_orderkey           bigint NOT NULL ,
    l_partkey            bigint NOT NULL ,
    l_suppkey            bigint NOT NULL ,
    l_linenumber         bigint NOT NULL ,
    l_quantity           bigint NOT NULL ,
    l_extendedprice      decimal(10,2) NOT NULL ,
    l_discount           decimal(10,2) NOT NULL ,
    l_tax                decimal(10,2) NOT NULL ,
    l_returnflag         char(1) ,
    l_linestatus         char(1) ,
    l_shipdate           date ,
    l_commitdate         date ,
    l_receiptdate        date ,
    l_shipinstruct       char(25) ,
    l_shipmode           char(10) ,
    l_comment            varchar(44)
) with column group(all columns, each column);

call dbms_stats.gather_table_stats(null, 'LINEITEM');
# Start load data
--disable_query_log
eval load data /*+ direct(true,1) gather_optimizer_statistics parallel(2) load_batch_size(100) */ infile "$OBSERVER_DIR/$DATA_FOLDER_NAME/lineitem/lineitem-100k-head100.tbl" into table lineitem fields terminated by '|' enclosed by '' lines starting by '' terminated by '\n';
--enable_query_log
