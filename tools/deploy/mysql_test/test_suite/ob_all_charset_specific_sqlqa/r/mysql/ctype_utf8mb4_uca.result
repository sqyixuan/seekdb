DROP TABLE t1;
#
# Start of 5.5 tests
#
SET collation_connection=utf8mb4_czech_ci;
SELECT @@collation_connection;
@@collation_connection
utf8mb4_czech_ci
#
# Bug#57737 Character sets: search fails with like, contraction, index
#
CREATE TABLE t1 AS SELECT REPEAT(' ', 10) AS s1 LIMIT 0;
INSERT INTO t1 VALUES ('c'),('ce'),('cé'),('ch');
SELECT * FROM t1 WHERE s1 LIKE 'c%';
s1
c
ce
ch
cé
ALTER TABLE t1 ADD KEY s1 (s1);
SELECT * FROM t1 WHERE s1 LIKE 'c%';
s1
c
ce
cé
alter system set _enable_drop_and_add_index = true;
ALTER TABLE t1 DROP KEY s1, ADD KEY(s1(1));
alter system set _enable_drop_and_add_index = false;
SELECT * FROM t1 WHERE s1 LIKE 'ch';
s1
ch
DROP TABLE t1;
SELECT @@collation_connection;
@@collation_connection
utf8mb4_czech_ci
#
# Bug#57737 Character sets: search fails with like, contraction, index
# Part#2 - ignorable characters
#
CREATE TABLE t1 AS SELECT REPEAT(' ', 10) AS s1 LIMIT 0;
INSERT INTO t1 VALUES ('a\0\0\0\0\0\t'),('a'),('b'),('c'),('d'),('e');
SELECT HEX(s1) FROM t1 WHERE s1 LIKE 'a%';
HEX(s1)
61
61000000000009
ALTER TABLE t1 ADD KEY s1 (s1);
SELECT HEX(s1) FROM t1 WHERE s1 LIKE 'a%';
HEX(s1)
61
61000000000009
DROP TABLE t1;
#
# End of 5.5 tests
#
#
# Bug#23752284: STRCMP NOT CONSISTENT WITH ORDER BY FOR
#               UTF8MB4_UNICODE_CI
#
DROP TABLE T1;
SET @A = CONVERT('A' USING utf8mb4);
SET @B = CONVERT('B' USING utf8mb4);
CREATE TABLE t1 (chr CHAR(4)) CHARSET = utf8mb4 COLLATE = utf8mb4_unicode_ci;
INSERT INTO t1 VALUES(@A),(@B);
SELECT HEX(chr), HEX(WEIGHT_STRING(chr)) FROM t1 ORDER BY chr;
HEX(chr)	HEX(WEIGHT_STRING(chr))
41	0E33
42	0E4A
SELECT STRCMP(@B, @A COLLATE utf8mb4_unicode_ci);
STRCMP(@B, @A COLLATE utf8mb4_unicode_ci)
1
DELETE FROM t1;
SET @A = CONVERT(CHAR(X'33fc' USING utf32) USING utf8mb4);
ERROR 42000: Unknown character set: 'utf32'
SET @B = CONVERT(CHAR(X'32' USING utf32) USING utf8mb4);
ERROR 42000: Unknown character set: 'utf32'
INSERT INTO t1 VALUES('s'), (_utf16 0x00DF), (_utf16 0x33FC), (_utf16 0x0032);
INSERT INTO t1 VALUES('sa'), (_utf16 0x00DF0061), (_utf16 0x33FC0061), (_utf16 0x00320061);
SELECT HEX(chr), HEX(WEIGHT_STRING(chr AS CHAR(1))) FROM t1;
HEX(chr)	HEX(WEIGHT_STRING(chr AS CHAR(1)))
32	0E2B
3261	0E2B
73	0FEA
7361	0FEA
C39F	0FEA0FEA
C39F61	0FEA0FEA
E38FBC	0E2B0E32FB40E5E5
E38FBC61	0E2B0E32FB40E5E5
SELECT HEX(chr), HEX(WEIGHT_STRING(chr AS CHAR(2))) FROM t1;
HEX(chr)	HEX(WEIGHT_STRING(chr AS CHAR(2)))
32	0E2B0209
