drop table t1;
set names utf8;
create table t1 (
name varchar(10),
level smallint unsigned);
show create table t1;
Table	Create Table
  `level` smallint(5) unsigned DEFAULT NULL
  `name` varchar(10) COLLATE utf16_swedish_ci DEFAULT NULL,
) ORGANIZATION INDEX DEFAULT CHARSET = utf16 COLLATE = utf16_swedish_ci ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
t1	CREATE TABLE `t1` (
insert into t1 values ('string',1);
select concat(name,space(level)), concat(name, repeat(' ',level)) from t1;
concat(name,space(level))	concat(name, repeat(' ',level))
string 	string 
