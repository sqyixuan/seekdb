purge recyclebin;
DROP TABLE IF EXISTS t1;
set names utf8;
set collation_connection=utf8_unicode_ci;
select 'a' = 'a', 'a' = 'a ', 'a ' = 'a';
'a' = 'a'	'a' = 'a '	'a ' = 'a'
1	1	1
select 'a\t' = 'a' , 'a\t' < 'a' , 'a\t' > 'a';
'a\t' = 'a'	'a\t' < 'a'	'a\t' > 'a'
0	1	0
select 'a\t' = 'a ', 'a\t' < 'a ', 'a\t' > 'a ';
'a\t' = 'a '	'a\t' < 'a '	'a\t' > 'a '
0	1	0
select 'a' = 'a\t', 'a' < 'a\t', 'a' > 'a\t';
'a' = 'a\t'	'a' < 'a\t'	'a' > 'a\t'
0	0	1
select 'a ' = 'a\t', 'a ' < 'a\t', 'a ' > 'a\t';
'a ' = 'a\t'	'a ' < 'a\t'	'a ' > 'a\t'
0	0	1
select 'a  a' > 'a', 'a  \t' < 'a';
'a  a' > 'a'	'a  \t' < 'a'
1	1
select 'c' like '\_' as want0;
want0
0
