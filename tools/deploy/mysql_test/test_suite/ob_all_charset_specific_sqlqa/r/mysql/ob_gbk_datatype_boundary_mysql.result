DROP DATABASE db1;
CREATE DATABASE db1 CHARACTER SET gbk;
use db1;

drop table test_gbk;
CREATE TABLE test_gbk (id int AUTO_INCREMENT PRIMARY KEY, a char(10) CHARACTER SET gbk) DEFAULT CHARSET=gbk;

DROP PROCEDURE create_gbk;
CREATE PROCEDURE create_gbk()
BEGIN
DECLARE i int DEFAULT 0;
  WHILE i < 256 DO
    INSERT INTO test_gbk (a) VALUES (char(i));
    set i = i + 1;
  END WHILE;
END;
//
call create_gbk();
