--echo ########## 发散case ###
--ERROR 0,1051
DROP TABLE charset_gbk_03;

CREATE TABLE charset_gbk_03 (
    c1 VARCHAR(100),
    c2 VARCHAR(100) CHARACTER SET gbk COLLATE gbk_bin GENERATED ALWAYS AS (SUBSTR(c1, 1, 100))
) PARTITION BY KEY(c2) PARTITIONS 3;

INSERT INTO charset_gbk_03(c1) VALUES 
('???????'),
('¤№?????'),
('???????????????'),
('??????????????'),
('???????????'),
('@ABCDEFGHIJKLMNO'),
('abcdefghijklmno'),
('????????????????????'),
('êě?ē???????íì??ǐ?ī??'),
('?????ńň??óò??ǒ?ō????'),
('丂丄丅丌丒丟丣两丨丫丮丯丰丵乀乁乄乇乑'),
('許體_TRIG_體');

SELECT * FROM charset_gbk_03 WHERE c1='???????';

--ERROR 0,1051
DROP TABLE IF EXISTS charset_gbk_03;
CREATE TABLE charset_gbk_03 (
    id INT NOT NULL,
    c1 VARCHAR(100) CHARACTER SET gbk COLLATE gbk_bin,
    c2 VARCHAR(100) CHARACTER SET gbk COLLATE gbk_bin GENERATED ALWAYS AS (CONCAT(c1, ' - Generated')) VIRTUAL ,
    created_at DATE
) PARTITION BY RANGE (YEAR(created_at)) (
    PARTITION p0 VALUES LESS THAN (2020),
    PARTITION p1 VALUES LESS THAN (2021),
    PARTITION p2 VALUES LESS THAN (2022),
    PARTITION p3 VALUES LESS THAN (2023),
    PARTITION p4 VALUES LESS THAN (MAXVALUE)
);

INSERT INTO charset_gbk_03 (id,c1,created_at) VALUES 
(1,'???????','20200101'),
(1,'???????????????','20220101'),
(1,'??????????????','20230101'),
(1,'@ABCDEFGHIJKLMNO','20210101');

INSERT INTO charset_gbk_03 (id,c1,created_at) VALUES 
(1,'許體_TRIG_體','20200101');
SELECT * FROM charset_gbk_03 WHERE c1='???????';

--ERROR 0,1051
DROP TABLE charset_gbk_example;
CREATE TABLE charset_gbk_example (
    a VARCHAR(100) CHARACTER SET gbk COLLATE gbk_bin,
    b VARCHAR(100) CHARACTER SET gbk COLLATE gbk_bin,
    c VARCHAR(100) CHARACTER SET gbk COLLATE gbk_bin,
    d VARCHAR(300) GENERATED ALWAYS AS (CONCAT(a, b, c)) 
);

