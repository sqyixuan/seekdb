    pk INT PRIMARY KEY COMMENT '主键，包含字符：???????¤№?????????????????????????????????????????????',
    col1 VARCHAR(255) COMMENT '?@ABCDEFGHIJKLMNO',
    col2 VARCHAR(255) COMMENT '?abcdefghijklmno',
    col3 VARCHAR(255) COMMENT '?????????????????????',
    col4 VARCHAR(255) COMMENT '?êě?ē???????íì??ǐ?ī??',
    col5 VARCHAR(255) COMMENT '??????ńň??óò??ǒ?ō????',
    col6 VARCHAR(255) COMMENT '?丂丄丅丌丒丟丣两丨丫丮丯丰丵乀乁乄乇乑',
    col7 VARCHAR(255) COMMENT '?許體_TRIG_體'
);

SHOW FULL COLUMNS FROM tbl_max_count;

SELECT *
/*
    这是一个多行注释示例。
    包含字符：¤№????????????????????
    以及其他多种字符。
*/
FROM tbl_max_length;

SELECT * FROM tbl_max_count;
INSERT INTO tbl_max_length (pk) VALUES (1);
INSERT INTO tbl_max_count (pk, col1, col2, col3, col4, col5, col6, col7)
VALUES (1, '数据1', '数据2', '数据3', '数据4', '数据5', '数据6', '数据7');
