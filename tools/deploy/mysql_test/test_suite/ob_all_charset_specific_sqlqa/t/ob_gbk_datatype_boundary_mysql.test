CREATE TABLE blob_table (
    id INT AUTO_INCREMENT PRIMARY KEY,
    tiny_blob1 TINYBLOB,
    blob1 BLOB,
    medium_blob1 MEDIUMBLOB,
    long_blob1 LONGBLOB
) CHARSET=gbk;

### OB ERROR 1301 (HY000): Result of repeat() was larger than max_allowed_packet (16777216) - truncated
