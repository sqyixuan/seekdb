purge recyclebin;
--result_format 4
--echo #Environmental cleaning

--echo ###锟斤拷锟矫筹拷时时锟斤拷
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;

--echo ##锟斤拷锟矫诧拷锟介看锟斤拷前锟街凤拷锟斤拷锟斤拷锟斤拷
set names 'gbk' COLLATE gbk_chinese_ci;
set character_set_database = 'gbk';
set character_set_server = 'gbk';
set character_set_results = 'utf8mb4';
show character set where Charset = 'gbk';
show variables like '%character%';
show variables like'%collation%';
--enable_sorted_result

--echo ############################# 锟街凤拷锟斤拷锟斤拷 #############################
--error 0,1008
DROP DATABASE db1;
CREATE DATABASE db1 CHARACTER SET gbk;
use db1;

--error 0,1051
drop table test_gbk;
CREATE TABLE test_gbk (id int AUTO_INCREMENT PRIMARY KEY, a char(10) CHARACTER SET gbk) DEFAULT CHARSET=gbk;

--error 0,1305
DROP PROCEDURE create_gbk;
delimiter //;
CREATE PROCEDURE create_gbk()
BEGIN
DECLARE i int DEFAULT 0;
  WHILE i < 256 DO
    INSERT INTO test_gbk (a) VALUES (char(i));
    set i = i + 1;
  END WHILE;
END;
//
delimiter ;//
--error 1366
call create_gbk();

SELECT (CONVERT(_TIS620 0x00C8 USING GBK));
SELECT (CONVERT(_TIS620 0x00C8 USING UTF8));

### GBK锟斤拷127锟斤拷锟较碉拷ASCII锟斤拷展锟街凤拷锟斤拷锟斤拷锟斤拷锟斤拷识锟斤拷
--ERROR 1300
SELECT (CONVERT(_UTF8 0xC8 USING GBK));
--ERROR 1300
SELECT _GBK 0x00C8;
--ERROR 1300
SELECT _GBK 0xC8;
--ERROR 1300
SELECT _GBK 0x80;

--disable_result_log
SELECT _GBK 0x1A;
SELECT _GBK 0x7F;
SELECT _GBK 0x7A;
--enable_result_log

SELECT CHAR(0x1A);
SELECT CHAR(0x7F);
SELECT CHAR(0x7A);
SELECT CHAR(0x80);
SELECT CHAR(0xC8);

--error 0,1051
drop table char_table;
CREATE TABLE IF NOT EXISTS char_table (
    id INT AUTO_INCREMENT PRIMARY KEY,
    char_value CHAR(1) CHARACTER SET gbk
);

delimiter /;
CREATE PROCEDURE create_gbk2()
BEGIN
DECLARE i int DEFAULT 128;
  WHILE i < 256 DO
    INSERT INTO char_table (char_value) VALUES (char(i USING gbk));
    set i = i + 1;
  END WHILE;
END;
/
delimiter ;/
call create_gbk2();
SELECT id, CHAR_LENGTH(char_value) AS length, char_value FROM char_table;
SELECT (char(200 USING gbk));

SET sql_mode = '';
--ERROR 0,1051
DROP TABLE sample_table;

### OB锟斤拷MYSQL锟斤拷锟斤拷锟捷★拷
CREATE TABLE sample_table (
    char_0 CHAR(0) CHARACTER SET gbk,
    char_1 CHAR(1) CHARACTER SET gbk,
    char_255 CHAR(255) CHARACTER SET gbk,
    char_256 CHAR(256) CHARACTER SET gbk
) DEFAULT CHARSET=gbk;

INSERT INTO sample_table (char_0, char_1, char_255, char_256) VALUES 
('', 'A', LPAD('', 255, 'A'), LPAD('', 256, 'B'));
SELECT * FROM sample_table;

--ERROR 0,1051
DROP TABLE sample_table2;
--error 1074
