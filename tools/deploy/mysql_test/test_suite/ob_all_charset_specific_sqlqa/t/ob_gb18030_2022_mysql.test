DROP TABLE my_partitioned_table;
CREATE TABLE my_partitioned_table (
    id INT AUTO_INCREMENT PRIMARY KEY,
    content VARCHAR(255) NOT NULL
) 
CHARACTER SET gb18030
COLLATE gb18030_chinese_ci
PARTITION BY HASH(id)
PARTITIONS 4; 
INSERT INTO my_partitioned_table (content) VALUES
('ºª©®™'),
('ΆΈΉΊΪ・Ό・ΎΫ・Ώ'),
('άέήίϊΐόςύϋΰώ'),
('ЂЃЄЅІЇ'),
('ЈЉЊЋЌЎЏ'),
('@ABCDEFGHIJKLMNO'),
('・ÁÀÄÂĂǍĀĄÅÃĆĈČÇĊĎÉÈË'),
('乚乜乣乨乩乴乵乹乿亍亖亗亝亯亹仃仐仚仛仠'),
('伙伮伱你伳伵伷伹伻伾佀佂佈佉佋佌佒佔佖佘'),
('佟佣佪佬佮佱佷佸佹佺佽佾侁侂侄'),
('許體_TRIG_體');
SELECT * FROM my_partitioned_table;
SELECT content, COUNT(*) FROM my_partitioned_table GROUP BY content;
SELECT LOCATE('©', content) FROM my_partitioned_table;
SELECT * FROM my_partitioned_table WHERE content LIKE '乚%';
--disable_result_log
EXPLAIN SELECT * FROM my_partitioned_table WHERE content LIKE '乚%';
--enable_result_log
SELECT content, HEX(content), HEX(WEIGHT_STRING(content)) AS hex_weight,CONV(HEX(WEIGHT_STRING(content)), 16, 10) FROM my_partitioned_table;

SELECT LENGTH(content) FROM my_partitioned_table;
SELECT CHAR_LENGTH(content) FROM my_partitioned_table;
SELECT LEFT(content, 2) FROM my_partitioned_table;
SELECT RIGHT(content, 2) FROM my_partitioned_table;
SELECT SUBSTRING(content, 2, 2) FROM my_partitioned_table;
SELECT SUBSTR(content, 2, 2) FROM my_partitioned_table;
SELECT CONVERT(content USING utf8mb4) FROM my_partitioned_table;

SELECT HEX(content),
       HEX(@u := CONVERT(content USING utf8mb4)),
       HEX(@l := CONVERT(@u USING latin1)),
       content, 
       @u, 
       @l, 
       content = @l 
FROM my_partitioned_table;
SELECT UPPER(content) FROM my_partitioned_table;
SELECT LOWER(content) FROM my_partitioned_table;


