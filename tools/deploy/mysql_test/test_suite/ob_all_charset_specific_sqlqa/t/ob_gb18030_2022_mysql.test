purge recyclebin;
--result_format 4
--echo #Environmental cleaning

--echo ###设置超时时间
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;

--echo ##设置并查看当前字符集设置
set names 'gb18030' COLLATE gb18030_chinese_ci;
set character_set_database = 'gb18030';
set character_set_server = 'gb18030';
set character_set_results = 'utf8mb4';
show character set where Charset = 'gb18030';
show variables like '%character%';
show variables like'%collation%';

--enable_sorted_result
--echo ############################# 指定字符集级别 #############################
--error 0,1008
DROP DATABASE db1;
CREATE DATABASE db1 CHARACTER SET gb18030;
use db1;

--echo #### charset_name: gbk

