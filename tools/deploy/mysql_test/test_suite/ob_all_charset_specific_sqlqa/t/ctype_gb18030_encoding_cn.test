purge recyclebin;
### --character_set gb18030
--enable_sorted_result
# Use the following chars to get single bytes
# 亗儎厗噲墛悜挀敃牎ⅲぅ焙患骄 櫄枟
# And construct these gb18030 chars maped from SIP
# 𠀀𠀂𫭃𤈼𠻜𠻝𠻞𠻟𠻠

### --CHARACTER_SET gb18030
set names 'gb18030' collate 'gb18030_chinese_ci';
set character_set_database = 'gb18030';
set character_set_server = 'gb18030';
set character_set_results = 'utf8mb4';
show character set where Charset = 'gb18030';
show variables like 'character_set%';

--ERROR 0,1008
DROP DATABASE `中文`;
CREATE DATABASE `中文`;

--ERROR 0,1008
DROP DATABASE `数据库`;
### --error 5018
CREATE DATABASE `数据库`;

--disable_result_log
SELECT schema_name, HEX(schema_name)
  FROM information_schema.schemata
  WHERE schema_name NOT IN ('mtr', 'sys')
  ORDER BY schema_name;
--enable_result_log

### USE `数据库`;
USE `中文`;

