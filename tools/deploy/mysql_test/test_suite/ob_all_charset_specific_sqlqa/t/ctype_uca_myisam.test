purge recyclebin;
--enable_sorted_result
### --source mysql_test/test_suite/ob_all_charset_specific_sqlqa/include/force_myisam_default.inc
### --source mysql_test/test_suite/ob_all_charset_specific_sqlqa/include/have_myisam.inc
### --source mysql_test/test_suite/ob_all_charset_specific_sqlqa/include/no_valgrind_without_big.inc

#
# Bug #5679 utf8_unicode_ci LIKE--trailing % doesn't equal zero characters
#
--error 0,1051
DROP TABLE t;
CREATE TABLE t (
  c char(20) NOT NULL
) ENGINE=MyISAM DEFAULT CHARSET=utf8 COLLATE=utf8_unicode_ci;
INSERT INTO t VALUES ('a'),('ab'),('aba');
ALTER TABLE t ADD INDEX (c);
SELECT c FROM t WHERE c LIKE 'a%';
#should find 3 rows but only found 2
DROP TABLE t;

#
# Bug #27079 Crash while grouping empty ucs2 strings
#
--ERROR 1115
CREATE TABLE t1 (
 c1 text character set ucs2 collate ucs2_polish_ci NOT NULL
) ENGINE=MyISAM;
### insert into t1 values (''),('a');
### SELECT COUNT(*), c1 FROM t1 GROUP BY c1;
### DROP TABLE IF EXISTS t1;
--error 0,1051
DROP TABLE t;