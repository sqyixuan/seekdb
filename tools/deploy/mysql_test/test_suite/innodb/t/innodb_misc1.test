#
# Test that we can create a large (>1K) key
# Moved to innodb_16k, innodb_8k, and innodb_4k
# since each page size has its own maximum key length.
#

# test the padding of BINARY types and collations (Bug #14189)

create table t1 (s1 varbinary(2),primary key (s1)) ;
create table t2 (s1 binary(2),primary key (s1)) ;
create table t3 (s1 varchar(2) binary,primary key (s1)) ;
create table t4 (s1 char(2) binary,primary key (s1)) ;

insert into t1 values (0x41),(0x4120),(0x4100);
-- error ER_DUP_ENTRY
insert into t2 values (0x41),(0x4120),(0x4100);
insert into t2 values (0x41),(0x4120);
-- error ER_DUP_ENTRY
insert into t3 values (0x41),(0x4120),(0x4100);
insert into t3 values (0x41),(0x4100);
-- error ER_DUP_ENTRY
insert into t4 values (0x41),(0x4120),(0x4100);
insert into t4 values (0x41),(0x4100);
select hex(s1) from t1;
select hex(s1) from t2;
select hex(s1) from t3;
select hex(s1) from t4;
drop table t1,t2,t3,t4;

