#
# Test that checksum table uses a consistent read Bug #12669
#
connect (a,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (b,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection a;
set ob_trx_timeout=100000000;
set ob_trx_idle_timeout=120000000;

--disable_warnings
drop table if exists t1,t2,t3,t4,t5, t6,t7,t8;
--enable_warnings

create table t1(a int not null);
insert into t1 values (1),(2);
set autocommit=0;
##checksum table t1;
connection b;
set ob_trx_timeout=100000000;
set ob_trx_idle_timeout=120000000;
insert into t1 values(3);
drop table t1;
connection a;
#
# Here checksum should not see insert
#
#TODO CHECKOUT table is not supported so far
##checksum table t1;
##connection a;
##commit;
##checksum table t1;
##commit;
##drop table t1;
#
# autocommit = 1
#
connection a;
create table t1(a int not null);
insert into t1 values (1),(2);
set autocommit=1;
##checksum table t1;
connection b;
set autocommit=1;
insert into t1 values(3);
connection a;
#
# Here checksum sees insert
#
##checksum table t1;
drop table t1;

connection default;
disconnect a;
disconnect b;

