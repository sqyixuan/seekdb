#
# Bug #25927: Prevent ALTER TABLE ... MODIFY ... NOT NULL on columns
# for which there is a foreign key constraint ON ... SET NULL.
#

CREATE TABLE t1 (a INT, INDEX(a));
CREATE TABLE t2 (a INT, INDEX(a));
INSERT INTO t1 VALUES (1);
INSERT INTO t2 VALUES (1);
# NULL -> NOT NULL only allowed INPLACE if strict sql_mode is on.
SET @old_sql_mode = @@sql_mode;
SET @@sql_mode = 'STRICT_TRANS_TABLES';
ALTER TABLE t2 MODIFY a INT NULL;
SET @@sql_mode = @old_sql_mode;
DELETE FROM t1;
DROP TABLE t2,t1;

#
# Bug #26835: table corruption after delete+insert
#

CREATE TABLE t1 (a VARCHAR(5) PRIMARY KEY);
INSERT INTO t1 VALUES (0xEFBCA4EFBCA4EFBCA4);
DELETE FROM t1;
INSERT INTO t1 VALUES ('DDD');
SELECT * FROM t1;
DROP TABLE t1;

