--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
set @@session.ob_trx_timeout=100000000;
set @@session.ob_trx_idle_timeout=120000000;
--enable_query_log
#owner: link.zt
#owner group: SQL4
# tags: optimizer
#description: case transferred from mysql

