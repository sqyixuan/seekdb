-------------------------------------
  0 - output([t1.v2]), filter(nil), rowset=16
      access([t1.__pk_increment], [t1.v2]), partitions(p0)
      is_index_back=true, is_global_index=false, 
      range_key([t1.v1], [t1.i], [t1.__pk_increment]), range(f,2,MIN ; f,2,MAX), (d,2,MIN ; d,2,MAX), (h,2,MIN ; h,2,MAX), (u,2,MIN ; u,2,MAX), 
      range_cond([t1.v1 IN ('f', 'd', 'h', 'u')], [t1.i = 2])
DROP TABLE t1;
#
# Bug#54606 innodb fast alter table + pack_keys=0 
#           prevents adding new indexes
#
DROP TABLE IF EXISTS t1;
CREATE TABLE t1 (a INT, b CHAR(9), c INT, key(b));
CREATE INDEX a ON t1 (a);
CREATE INDEX c on t1 (c);
DROP TABLE t1;
#
# Bug#11762345 54927: DROPPING AND ADDING AN INDEX IN ONE
#              COMMAND CAN FAIL IN INNODB PLUGIN 1.0
#
DROP TABLE IF EXISTS t1;
CREATE TABLE t1 (id int, a  int, b  int, PRIMARY KEY (id),
INDEX a (a));
ALTER TABLE t1 DROP INDEX a;
alter table t1 ADD INDEX a (b, a);
ALTER TABLE t1 DROP INDEX a;
alter table t1 ADD INDEX (a, b);
DROP TABLE t1;
End of 6.0 tests
