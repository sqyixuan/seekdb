# Bug#50843: Filesort used instead of clustered index led to
#            performance degradation.
#
create table t1(f1 int not null primary key, f2 int) ;
create table t2(f1 int not null, key (f1)) ;
insert into t1 values (1,1),(2,2),(3,3);
insert into t2 values (1),(2),(3);
explain  select t1.* from t1 left join t2 using(f1) group by t1.f1;
Query Plan
===============================================
|ID|OPERATOR       |NAME|EST.ROWS|EST.TIME(us)|
-----------------------------------------------
|0 |TABLE FULL SCAN|t1  |3       |3           |
===============================================
Outputs & filters:
-------------------------------------
  0 - output([t1.f1], [t1.f2]), filter(nil), rowset=16
      access([t1.f1], [t1.f2]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t1.f1]), range(MIN ; MAX)always true
drop table t1,t2;
