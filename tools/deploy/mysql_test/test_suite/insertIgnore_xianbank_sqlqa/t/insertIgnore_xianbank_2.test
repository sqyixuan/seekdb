--disable_warnings
DROP TABLE IF EXISTS cool_deal_record;
--enable_warnings
CREATE TABLE `cool_deal_record` (
  `deal_record_id` int(11) unsigned NOT NULL AUTO_INCREMENT,
  `business_id` varchar(11) DEFAULT NULL,
  `door_id` varchar(11) DEFAULT NULL,
  `out_trade_id` varchar(50) DEFAULT NULL,
  `pay_type` varchar(10) DEFAULT NULL,
  `pay_pass` varchar(10) NOT NULL DEFAULT '010',
  `money` varchar(100) DEFAULT NULL,
  `regtime` varchar(20) DEFAULT NULL,
  `from_business_trade_id` varchar(128) DEFAULT NULL,
  `openpl_secret_id` varchar(100) DEFAULT NULL,
  `order_type` smallint(2) DEFAULT NULL COMMENT '订单类型',
  `status` tinyint(2) DEFAULT '0' COMMENT '订单状态(0.正在支付，1.支付成功，2.支付失败，6.订单关闭，7.未支付)',
  `device_id` int(11) DEFAULT NULL COMMENT '扫码设备ID',
  `attach` varchar(255) DEFAULT NULL COMMENT '附加数据',
  `pay_log_id` varchar(40) DEFAULT NULL COMMENT '西银在线流水号',
  `remark_one_value` varchar(255) DEFAULT NULL COMMENT '备注一',
  `remark_two_value` varchar(255) DEFAULT NULL COMMENT '备注二',
  `remark_three_value` varchar(255) DEFAULT NULL COMMENT '备注三',
  `user_id` varchar(11) DEFAULT NULL COMMENT '用户标识',
  `trade_body` varchar(255) DEFAULT NULL COMMENT '商品信息',
  `longitude` decimal(15,10) DEFAULT '0.0000000000' COMMENT '经度',
  `latitude` decimal(15,10) DEFAULT '0.0000000000' COMMENT '纬度',
  `ip` varchar(30) DEFAULT '' COMMENT 'ip地址',
  `order_source` varchar(3) DEFAULT '001' COMMENT '订单来源，默认001 西银惠付',
  PRIMARY KEY (`deal_record_id`),
  UNIQUE KEY `uiq_out_trade_id` (`out_trade_id`),
  UNIQUE KEY `business_trade_id` (`business_id`, `from_business_trade_id`),
  KEY `origin_trade_no` (`from_business_trade_id`),
  KEY `pay_log_id` (`pay_log_id`),
  KEY `regtime_idx` (`regtime`),
  KEY `business_id_idx` (`business_id`),
  KEY `pay_pass_idx` (`pay_pass`),
  KEY `pay_type_idx` (`pay_type`)
) AUTO_INCREMENT = 47325689 DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMMENT = '支付流水表';
--echo 自定义开放平台
--disable_warnings
