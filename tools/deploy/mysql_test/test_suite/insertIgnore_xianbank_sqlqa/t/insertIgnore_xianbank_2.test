select business_id,door_id,out_trade_id,pay_type,pay_pass,money,regtime,from_business_trade_id,openpl_secret_id,order_type,status,device_id,attach,pay_log_id,remark_one_value,remark_two_value,remark_three_value,user_id,trade_body,longitude,latitude,ip,order_source from cool_deal_record order by deal_record_id;

