drop user cwx;
drop database if exists cwx;
--enable_warnings
create database cwx;
use cwx;
create user 'cwx'@'%' identified by 'cwx';
grant all privileges on *.* to 'cwx'@'%';
--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,cwx,'cwx',cwx,$OBMYSQL_PORT);
connection conn;

