DROP TABLE IF EXISTS cool_bill_card_data;
--enable_warnings

select @@sql_mode;
set sql_mode=null;
CREATE TABLE `cool_bill_card_data` (
  `clear_sft_id` int(11) unsigned NOT NULL AUTO_INCREMENT,
  `door_id` int(11) DEFAULT NULL,
  `total_fee` decimal(10,2) DEFAULT '0.00' COMMENT '对账单获取的账单总金额',
  `clear_fee` decimal(10,2) DEFAULT '0.00' COMMENT '对账单获取的账单结算金额',
  `fee` decimal(10,2) DEFAULT '0.00' COMMENT '对账单表获取的手续费',
  `clear_date` int(11) DEFAULT NULL COMMENT '交易时间',
  `business_id` int(11) DEFAULT NULL,
  PRIMARY KEY (`clear_sft_id`)
) AUTO_INCREMENT = 4000103 DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMMENT = '盛付通刷卡数据统计（以对账单表为依据）';
