  KEY `origin_trade_no` (`from_business_trade_id`) BLOCK_SIZE 16384,
  KEY `b_d_u_r_idx` (`business_id`, `door_id`, `user_id`, `regtime`) BLOCK_SIZE 16384,
  KEY `b_o_o_idx` (`business_id`, `order_regtime`, `order_type`) BLOCK_SIZE 16384
) AUTO_INCREMENT = 8178461 DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.0' REPLICA_NUM = 3 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 10;
