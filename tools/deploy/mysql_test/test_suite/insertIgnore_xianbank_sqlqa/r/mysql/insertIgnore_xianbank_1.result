DROP TABLE IF EXISTS cool_bill_card;
CREATE TABLE `cool_bill_card` (
`bill_id` int(11) unsigned NOT NULL AUTO_INCREMENT,
`mch_no_sft` varchar(15) NOT NULL DEFAULT '' COMMENT '盛付通商户号（pos机商户号）',
`terminal_id` varchar(8) DEFAULT '' COMMENT '终端号',
`batch_no` varchar(6) DEFAULT '' COMMENT '终端批次号',
`trace_no` varchar(6) DEFAULT '0' COMMENT '终端流水号',
`order_no` varchar(32) DEFAULT '' COMMENT '商户订单号',
`trade_type` varchar(20) DEFAULT '' COMMENT '交易类型 0 支付 1 退款',
`trade_time` int(11) DEFAULT '0' COMMENT '交易时间',
`short_account` varchar(12) DEFAULT '' COMMENT '缩略主账号',
`card_type` varchar(10) DEFAULT '' COMMENT '卡类型',
`trade_money` decimal(10,2) DEFAULT '0.00' COMMENT '交易金额',
`fee` decimal(10,2) DEFAULT '0.00' COMMENT '收单手续费',
`cash_money` decimal(10,2) DEFAULT '0.00' COMMENT '实际结算金额',
`door_id` int(11) DEFAULT NULL,
`business_id` int(11) DEFAULT NULL,
`agent_id` int(11) DEFAULT NULL,
`created_at` int(11) DEFAULT NULL COMMENT '操作入库时间',
PRIMARY KEY (`bill_id`)
) AUTO_INCREMENT = 4000012 DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC;
