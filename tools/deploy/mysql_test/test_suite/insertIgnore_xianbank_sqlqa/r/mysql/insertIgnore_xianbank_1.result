DROP TABLE IF EXISTS cool_refund_card;
CREATE TABLE `cool_refund_card` (
`refund_card_id` int(11) NOT NULL AUTO_INCREMENT COMMENT '退款ID',
`status` varchar(10) DEFAULT '' COMMENT '退款类型( RFD 退款 ，VID 撤销 )',
`refund_money` decimal(14,2) DEFAULT '0.00' COMMENT '退款金额',
`out_trade_id` varchar(35) DEFAULT NULL COMMENT '西银惠付订单号',
`mch_no_sft` varchar(15) DEFAULT '' COMMENT '盛付通商户号',
`terminal_id` varchar(8) DEFAULT '' COMMENT '终端号',
`trace_no` varchar(6) DEFAULT '' COMMENT '终端流水号(凭证号)',
`order_id_sft` varchar(12) DEFAULT '' COMMENT '盛付通订单号',
`regtime` int(10) DEFAULT '0' COMMENT '退款时间',
`trade_ref` varchar(20) DEFAULT '' COMMENT '交易参考号',
`trade_result` varchar(2) DEFAULT '0' COMMENT '交易应答码,00交易成功;其他失败',
`orig_trade_ref` varchar(50) DEFAULT '' COMMENT '原交易参考号',
PRIMARY KEY (`refund_card_id`)
) AUTO_INCREMENT = 8000034 DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC;
盛付通相关
