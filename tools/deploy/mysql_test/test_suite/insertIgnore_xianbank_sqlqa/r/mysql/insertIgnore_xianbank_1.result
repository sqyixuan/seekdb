drop user cwx;
drop database if exists cwx;
create database cwx;
use cwx;
create user 'cwx'@'%' identified by 'cwx';
grant all privileges on *.* to 'cwx'@'%';
DROP TABLE IF EXISTS cool_deal;
select @@sql_mode;
@@sql_mode
STRICT_ALL_TABLES,NO_ZERO_IN_DATE,NO_AUTO_CREATE_USER
CREATE TABLE `cool_deal` (
`deal_id` int(11) NOT NULL AUTO_INCREMENT COMMENT '交易流水ID',
`agent_id` varchar(11) DEFAULT NULL,
`business_id` varchar(11) DEFAULT NULL,
`door_id` varchar(11) DEFAULT NULL,
`out_trade_id` varchar(40) DEFAULT NULL,
`status` int(1) NOT NULL DEFAULT '0' COMMENT '状态（1,已支付，2，未支付，3已退款，4部分退款,5订单撤销，支付宝和微信主动退款）',
`transation_id` varchar(32) DEFAULT NULL COMMENT '微信订单号',
`total_fee` decimal(10,2) DEFAULT NULL COMMENT '总金额',
`bonus_fee` decimal(10,2) DEFAULT '0.00' COMMENT '微信补贴',
`cash_fee` decimal(10,2) NOT NULL COMMENT '实际支付',
`pay_type` varchar(20) DEFAULT NULL COMMENT '支付方式',
`pay_pass` varchar(20) NOT NULL DEFAULT '010',
`admin_id` varchar(11) DEFAULT NULL,
`regtime` varchar(11) DEFAULT NULL,
`remark_one_value` varchar(255) DEFAULT NULL COMMENT '备注一',
`remark_two_value` varchar(255) DEFAULT NULL COMMENT '备注二',
`remark_three_value` varchar(255) DEFAULT NULL COMMENT '备注三',
`from_business_trade_id` varchar(128) DEFAULT NULL,
`is_read` int(1) NOT NULL DEFAULT '0',
`app_id` varchar(200) DEFAULT NULL,
`open_id` varchar(255) DEFAULT '0' COMMENT '支付人微信OPENID',
`order_type` int(11) DEFAULT NULL,
`order_regtime` int(11) DEFAULT NULL,
`discount_amt` decimal(10,2) DEFAULT NULL,
`offer_type` varchar(20) DEFAULT NULL,
`device_id` int(11) DEFAULT NULL COMMENT '扫码设备编号,设备表bind_flag_no',
`attach` varchar(255) DEFAULT NULL COMMENT '附加数据',
`bank_type` varchar(30) DEFAULT NULL COMMENT '付款银行',
`pay_log_id` varchar(40) DEFAULT NULL COMMENT '西银在线流水号',
`activity_type` varchar(30) DEFAULT NULL COMMENT '三方平台活动类型',
`user_id` varchar(11) DEFAULT NULL COMMENT '用户标识',
`trade_body` varchar(255) DEFAULT NULL COMMENT '商品信息',
`longitude` decimal(15,10) DEFAULT '0.0000000000' COMMENT '经度',
`latitude` decimal(15,10) DEFAULT '0.0000000000' COMMENT '纬度',
`ip` varchar(30) DEFAULT '' COMMENT 'ip地址',
`pay_card_type` varchar(2) DEFAULT '' COMMENT '支付卡类型：01-借记卡，02-信用卡，03-余额，04-其他',
`order_source` varchar(3) DEFAULT '001' COMMENT '订单来源，默认001 西银惠付',
PRIMARY KEY (`deal_id`),
UNIQUE KEY `out_trade_id` (`out_trade_id`),
KEY `business_id` (`business_id`),
KEY `door_id` (`door_id`),
KEY `regtime_bdoor_idx` (`regtime`, `business_id`, `door_id`),
KEY `regtime_idx` (`regtime`),
KEY `pay_log_id` (`pay_log_id`),
KEY `origin_trade_no` (`from_business_trade_id`),
KEY `b_d_u_r_idx` (`business_id`, `door_id`, `user_id`, `regtime`),
KEY `b_o_o_idx` (`business_id`, `order_regtime`, `order_type`)
) AUTO_INCREMENT = 8178461 DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC;
