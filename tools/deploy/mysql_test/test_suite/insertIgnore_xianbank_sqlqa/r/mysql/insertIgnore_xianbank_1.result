DROP TABLE IF EXISTS cool_deal_card;
CREATE TABLE `cool_deal_card` (
`deal_id` int(11) unsigned NOT NULL AUTO_INCREMENT,
`agent_id` int(11) DEFAULT NULL,
`business_id` int(11) DEFAULT '0',
`door_id` int(11) DEFAULT NULL,
`status` varchar(20) DEFAULT '' COMMENT '交易类型(PUR 支付 RFD 退款 VID 撤销)',
`out_trade_id` varchar(32) DEFAULT '' COMMENT '商户订单号(西银惠付)',
`cur` varchar(20) DEFAULT 'CNY' COMMENT '交易币别',
`total_fee` decimal(14,2) DEFAULT '0.00' COMMENT '交易金额',
`cash_fee` decimal(10,2) DEFAULT '0.00' COMMENT '实付金额',
`mch_no_sft` varchar(15) DEFAULT '' COMMENT '盛付通商户号',
`terminal_id` varchar(8) DEFAULT '' COMMENT '终端号',
`trace_no` varchar(6) DEFAULT '' COMMENT '终端流水号(凭证号)',
`batch_no` varchar(6) DEFAULT '' COMMENT '终端批次号',
`order_id_sft` varchar(12) DEFAULT '' COMMENT '盛付通订单号',
`regtime` int(11) DEFAULT '0' COMMENT '交易时间',
`trade_ref` varchar(20) DEFAULT '' COMMENT '交易参考号',
`trade_result` varchar(2) DEFAULT '0' COMMENT '交易应答码,00交易成功;其他失败',
`short_pan` varchar(10) DEFAULT '' COMMENT '卡号末4位',
`ext_data` varchar(255) DEFAULT '' COMMENT '附加信息，内含发卡机构和微信userId',
`orig_trade_ref` varchar(50) DEFAULT '' COMMENT '原交易参考号',
PRIMARY KEY (`deal_id`)
) AUTO_INCREMENT = 4000067 DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC;
INSERT ignore INTO cool_deal_card (`agent_id`,`business_id`,`door_id`,`status`,`out_trade_id`,`cur`,`total_fee`,`cash_fee`,`mch_no_sft`,`terminal_id`,`trace_no`,`batch_no`,`order_id_sft`,`regtime`,`trade_ref`,`trade_result`,`short_pan`,`ext_data`,`orig_trade_ref`) VALUES('','','','','','','','','','','','','','','','','','','');
delete from cool_deal_card;
select agent_id,business_id,door_id,status,out_trade_id,cur,total_fee,cash_fee,mch_no_sft,terminal_id,trace_no,batch_no,order_id_sft,regtime,trade_ref,trade_result,short_pan,ext_data,orig_trade_ref from cool_deal_card order by deal_id;
agent_id	business_id	door_id	status	out_trade_id	cur	total_fee	cash_fee	mch_no_sft	terminal_id	trace_no	batch_no	order_id_sft	regtime	trade_ref	trade_result	short_pan	ext_data	orig_trade_ref
