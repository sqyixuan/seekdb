DROP TABLE IF EXISTS cool_bill;
CREATE TABLE `cool_bill` (
`bill_id` int(11) unsigned NOT NULL AUTO_INCREMENT,
`trade_time` varchar(30) DEFAULT NULL COMMENT '交易时间',
`app_id` varchar(20) DEFAULT NULL COMMENT '公众账号ID',
`mch_id` varchar(30) DEFAULT NULL COMMENT '商户号',
`sub_mch` varchar(30) DEFAULT NULL COMMENT '子商户号',
`device_id` varchar(50) DEFAULT NULL COMMENT '设备号',
`wx_order` varchar(50) DEFAULT NULL COMMENT '微信订单号',
`order_no` varchar(50) DEFAULT NULL COMMENT '商户订单号',
`openid` varchar(50) DEFAULT NULL COMMENT 'openid',
`trade_type` varchar(50) DEFAULT NULL COMMENT '交易类型 0 支付, 1 退款',
`trade_status` varchar(50) DEFAULT NULL COMMENT '交易状态',
`bank` varchar(100) DEFAULT NULL COMMENT '付款银行',
`cny` varchar(20) DEFAULT NULL COMMENT '货币种类',
`total_money` varchar(20) DEFAULT NULL COMMENT '总金额',
`redpacket_money` varchar(20) DEFAULT NULL COMMENT '代金券或立减优惠金额',
`aprefund_time` varchar(30) DEFAULT NULL COMMENT '退款申请时间',
`surefund_time` varchar(30) DEFAULT NULL COMMENT '退款成功时间',
`wxrefund_no` varchar(50) DEFAULT NULL COMMENT '微信退款单号',
`mcrefund_no` varchar(50) DEFAULT NULL COMMENT '商户退款单号',
`refund_money` varchar(20) DEFAULT NULL COMMENT '退款金额',
`redpacket_refund_money` varchar(20) DEFAULT NULL COMMENT '代金券或立减优惠退款金额',
`refund_type` varchar(20) DEFAULT NULL COMMENT '退款类型，1全部退款，2部分退款',
`refund_status` varchar(20) DEFAULT NULL COMMENT '退款状态',
`product_target_name` varchar(100) DEFAULT NULL COMMENT '商品名称',
`data_packet` varchar(255) DEFAULT NULL COMMENT '商户数据包',
`fee` varchar(20) DEFAULT NULL COMMENT '手续费',
`rate` varchar(20) DEFAULT NULL COMMENT '费率',
`business_id` varchar(11) DEFAULT NULL,
`door_id` varchar(11) DEFAULT NULL,
`pay_type` varchar(100) DEFAULT NULL COMMENT '支付方式',
`pay_pass` varchar(100) DEFAULT NULL,
`agent_id` varchar(11) DEFAULT NULL COMMENT '代理商编号',
`agent_fr_fee` varchar(100) DEFAULT NULL COMMENT '代理商分润金额',
`qd_fr_fee` varchar(100) DEFAULT NULL COMMENT '渠道商分润金额',
`td_cost_fee` varchar(100) DEFAULT NULL COMMENT '第三方成本',
`from_business_trade_id` varchar(128) DEFAULT NULL,
`bill_time` varchar(30) DEFAULT NULL,
`channel_id` int(11) DEFAULT NULL COMMENT '渠道号',
`activity_type` varchar(30) DEFAULT NULL COMMENT '三方平台活动类型',
`pay_log_id` varchar(40) DEFAULT NULL COMMENT '西银在线流水号',
`user_id` varchar(11) DEFAULT NULL COMMENT '用户标识',
`order_source` varchar(3) DEFAULT '001' COMMENT '订单来源，默认001 西银惠付',
PRIMARY KEY (`bill_id`),
UNIQUE KEY `uiq_order_type_refund` (`order_no`, `trade_type`, `wxrefund_no`),
KEY `mch_id_idx` (`mch_id`),
KEY `agent_id_idx` (`agent_id`),
KEY `bill_time_idx` (`bill_time`),
KEY `trade_time_idx` (`trade_time`),
KEY `business_id_idx` (`business_id`),
KEY `agent_id_idx1` (`agent_id`),
KEY `door_id_idx` (`door_id`),
KEY `bus_id_b_t_time_idx` (`business_id`, `bill_time`, `trade_time`)
) AUTO_INCREMENT = 10055453 DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC;
