DROP TABLE IF EXISTS cool_fenrun;
CREATE TABLE `cool_fenrun` (
`fenrun_id` int(11) NOT NULL AUTO_INCREMENT,
`mch_no` varchar(255) DEFAULT NULL COMMENT '商户号',
`tran_type` tinyint(1) DEFAULT NULL COMMENT '交易类型   0 支付  1  退款',
`trade_money` varchar(255) DEFAULT NULL COMMENT '交易金额',
`channel_id` varchar(11) DEFAULT NULL COMMENT '所属渠道商Id',
`qd_fr_total` varchar(100) DEFAULT NULL COMMENT '渠道商分润金额',
`agent_one_id` varchar(100) DEFAULT NULL COMMENT '一级代理商ID',
`agent_one_fr_total` varchar(100) DEFAULT NULL COMMENT '一级代理商分润金额',
`agent_two_id` varchar(100) DEFAULT NULL COMMENT '二级代理商ID',
`agent_two_fr_total` varchar(100) DEFAULT NULL COMMENT '二级代理商分润金额',
`pay_pass` varchar(20) DEFAULT NULL COMMENT '支付渠道',
`regtime` varchar(50) DEFAULT NULL COMMENT '分润时间',
`order_no` varchar(100) DEFAULT NULL COMMENT '订单编号',
`is_true` tinyint(1) DEFAULT '0' COMMENT '分润数据是否错误标志 0 正确 1 失败',
`created_at` int(10) DEFAULT NULL COMMENT '操作入库时间',
PRIMARY KEY (`fenrun_id`),
KEY `index_m` (`mch_no`),
KEY `index_r` (`regtime`),
KEY `index_p` (`pay_pass`),
KEY `created_at_two_id_idx` (`created_at`, `agent_two_id`),
KEY `agent_one_id_r_indx` (`agent_one_id`, `regtime`),
KEY `agent_two_id_r_indx` (`agent_two_id`, `regtime`),
KEY `mch_no_r_indx` (`mch_no`, `regtime`)
) AUTO_INCREMENT = 1001136810 DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC;
