DROP TABLE IF EXISTS cool_deal_record1;
CREATE TABLE `cool_deal_record1` (
`deal_record_id` int(11) unsigned NOT NULL AUTO_INCREMENT,
`business_id` varchar(11) DEFAULT NULL,
`door_id` varchar(11) DEFAULT NULL,
`out_trade_id` varchar(50) DEFAULT NULL,
`money` varchar(100) DEFAULT NULL,
`from_business_trade_id` varchar(128) DEFAULT NULL,
`order_type` smallint(2) DEFAULT NULL COMMENT '订单类型',
`status` tinyint(2) DEFAULT '0' COMMENT '订单状态(0.正在支付，1.支付成功，2.支付失败，6.订单关闭，7.未支付)',
`device_id` int(11) DEFAULT NULL COMMENT '扫码设备ID',
`latitude` decimal(15,10) DEFAULT '0.0000000000' COMMENT '纬度',
PRIMARY KEY (`deal_record_id`),
UNIQUE KEY `uiq_out_trade_id` (`out_trade_id`),
UNIQUE KEY `business_trade_id` (`business_id`, `from_business_trade_id`,`device_id`),
KEY `origin_trade_no` (`from_business_trade_id`),
KEY `business_id_idx` (`business_id`)
) AUTO_INCREMENT = 47325689 DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMMENT = '西安银行简化改进版case，集中测试';
