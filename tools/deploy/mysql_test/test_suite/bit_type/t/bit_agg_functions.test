--echo decimal type
create table t1 (a decimal(5, 2));
select bit_and(a), bit_or(a), bit_xor(a) from t1;
insert into t1 values (null);
select bit_and(a), bit_or(a), bit_xor(a) from t1;
insert into t1 values (2.8);
select bit_and(a), bit_or(a), bit_xor(a) from t1;
