insert into t1 values ('one');
select bit_and(a), bit_or(a), bit_xor(a) from t1;
insert into t1 values ('two');
select bit_and(a), bit_or(a), bit_xor(a) from t1;
insert into t1 values ('three');
select bit_and(a), bit_or(a), bit_xor(a) from t1;
drop table t1;

--echo set type
create table t1 (a set('one','two','three'));
select bit_and(a), bit_or(a), bit_xor(a) from t1;
insert into t1 values (null);
select bit_and(a), bit_or(a), bit_xor(a) from t1;
insert into t1 values ('one');
select bit_and(a), bit_or(a), bit_xor(a) from t1;
insert into t1 values ('two');
select bit_and(a), bit_or(a), bit_xor(a) from t1;
insert into t1 values ('three');
select bit_and(a), bit_or(a), bit_xor(a) from t1;
drop table t1;

--echo bit type
create table t1 (a bit(10));
select bit_and(a), bit_or(a), bit_xor(a) from t1;
insert into t1 values (null);
select bit_and(a), bit_or(a), bit_xor(a) from t1;
insert into t1 values (b'01');
select bit_and(a), bit_or(a), bit_xor(a) from t1;
insert into t1 values (b'11');
select bit_and(a), bit_or(a), bit_xor(a) from t1;
insert into t1 values (b'10');
select bit_and(a), bit_or(a), bit_xor(a) from t1;
drop table t1;

--echo binary type
create table t1 (a binary(100));
select bit_and(a), bit_or(a), bit_xor(a) from t1;
insert into t1 values (null);
select bit_and(a), bit_or(a), bit_xor(a) from t1;
insert into t1 values ('abc');
select bit_and(a), bit_or(a), bit_xor(a) from t1;
insert into t1 values ('a123');
select bit_and(a), bit_or(a), bit_xor(a) from t1;
insert into t1 values ('123a');
select bit_and(a), bit_or(a), bit_xor(a) from t1;
insert into t1 values ('124');
select bit_and(a), bit_or(a), bit_xor(a) from t1;
drop table t1;

--echo create view as select
create table t1 (a int);
insert into t1 values (null);
create view v1 as select bit_and(a), bit_or(a), bit_xor(a) from t1;
select * from v1;
insert into t1 values (3);
create view v2 as select bit_and(a), bit_or(a), bit_xor(a) from t1;
select * from v2;
drop view v1, v2;
drop table t1;

--echo bit functions should not push groupby
create TABLE t1 (a int, b int, c int, d int) partition by list(a) subpartition by hash(b) subpartitions 4 ( partition p0 values in (1), partition p1 values in (2), partition p2 values in (3), partition p3 values in (4));
select a,count(b), sum(b), avg(b), std(b), min(b), max(b), bit_and(b), bit_or(b), bit_xor(b) FROM t1  group by a;
drop table t1;

--echo bug:

CREATE TABLE `t1` (
  `col_13` smallint(5) unsigned DEFAULT NULL,
  `col_14` float DEFAULT '6113.12',
  `col_15` year(4) DEFAULT '1987',
  `col_16` char(99) COLLATE utf8mb4_unicode_ci DEFAULT NULL,
  `col_17` time DEFAULT NULL,
  `col_18` binary(137) NOT NULL,
  `col_19` tinyblob DEFAULT NULL,
  `col_20` datetime DEFAULT NULL,
  `col_21` date NOT NULL DEFAULT '1980-10-05',
  `col_22` char(41) COLLATE utf8mb4_unicode_ci DEFAULT 'cDI5azBi^',
  `col_26` json DEFAULT NULL
) DEFAULT CHARSET = utf8mb4 COLLATE = utf8mb4_unicode_ci ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 3 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
 partition by hash(col_13)
(partition p0,
partition p1,
partition p2,
partition p3,
partition p4,
partition p5) ;

explain select ascii( t1.col_19 ) as r0 , count( distinct  t1.col_13 ) as r1 , bit_and( t1.col_13 ) as r2 , bit_or( t1.col_13 ) as r3, bit_xor( t1.col_13 ) as r4, t1.col_22 as r5 , length( t1.col_22 ) as r6 from t1    order by r0,r1,r2,r3,r4 ;
select ascii( t1.col_19 ) as r0 , count( distinct  t1.col_13 ) as r1 , bit_and( t1.col_13 ) as r2 , bit_or( t1.col_13 ) as r3, bit_xor( t1.col_13 ) as r4, t1.col_22 as r5 , length( t1.col_22 ) as r6 from t1    order by r0,r1,r2,r3,r4;
drop table t1;

--echo bug:
create table t1(c1 int,c2 int);
insert into t1 values (-105119744,1);
insert into t1 values (-1860239360,2);

SELECT BIT_OR(c1) OVER (PARTITION BY c2 ORDER BY C2) FROM t1;
SELECT BIT_AND(c1) OVER (PARTITION BY c2 ORDER BY C2) FROM t1;
SELECT BIT_XOR(c1) OVER (PARTITION BY c2 ORDER BY C2) FROM t1;
drop table t1;

explain SELECT  BIT_AND(-1.25);
SELECT  BIT_AND(-1.25);

create table t1 (c1 bigint, c2 bigint unsigned, c3 bit(64), c4 double, c5 double unsigned, c6 decimal(10, 2), c7 decimal(10, 2) unsigned);
insert into t1 values (-1.25, 1, 0xffffffffffffffff, -1.25, 1.25, -1.25, 1.25);
select * from t1;
explain select bit_and(c1), bit_and(c2), bit_and(c3), bit_and(c4), bit_and(c5), bit_and(c6), bit_and(c7) from t1;
select bit_and(c1), bit_and(c2), bit_and(c3), bit_and(c4), bit_and(c5), bit_and(c6), bit_and(c7) from t1;
drop table t1;

drop database bitdb;
