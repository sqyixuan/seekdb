#owner: zuojiao.hzj
#owner group: SQL2
#description: bit_and/bit_or/bit_xor aggregate function test
##tags: aggregation

--disable_warnings
drop database if exists bitdb;
--enable_warnings
create database bitdb;
use bitdb;

--echo literal
select bit_and(null), bit_or(null), bit_xor(null);
select bit_and(b'10'), bit_or(b'10'), bit_xor(b'10');
select bit_and(0b11), bit_or(0b11), bit_xor(0b11);
select bit_and(0x23), bit_or(0x23), bit_xor(0x23);
select bit_and(45), bit_or(45), bit_xor(45);
select bit_and('67'), bit_or('67'), bit_xor('67');

--echo null values
create table t1 (a int);
select bit_and(a), bit_or(a), bit_xor(a) from t1;
insert into t1 values (null);
select bit_and(a), bit_or(a), bit_xor(a) from t1;
insert into t1 values (null);
select bit_and(a), bit_or(a), bit_xor(a) from t1;
insert into t1 values (1);
select bit_and(a), bit_or(a), bit_xor(a) from t1;
insert into t1 values (null);
select bit_and(a), bit_or(a), bit_xor(a) from t1;
drop table t1;

--echo int type
create table t1 (a int);
select bit_and(a), bit_or(a), bit_xor(a) from t1;
insert into t1 values (null);
select bit_and(a), bit_or(a), bit_xor(a) from t1;
insert into t1 values (3);
select bit_and(a), bit_or(a), bit_xor(a) from t1;
insert into t1 values (1);
select bit_and(a), bit_or(a), bit_xor(a) from t1;
insert into t1 values (2);
select bit_and(a), bit_or(a), bit_xor(a) from t1;
drop table t1;

--echo float type
create table t1 (a float(5, 2));
select bit_and(a), bit_or(a), bit_xor(a) from t1;
insert into t1 values (null);
select bit_and(a), bit_or(a), bit_xor(a) from t1;
insert into t1 values (2.8);
select bit_and(a), bit_or(a), bit_xor(a) from t1;
insert into t1 values (1.3);
select bit_and(a), bit_or(a), bit_xor(a) from t1;
insert into t1 values (2.0);
select bit_and(a), bit_or(a), bit_xor(a) from t1;
drop table t1;

--echo double type
