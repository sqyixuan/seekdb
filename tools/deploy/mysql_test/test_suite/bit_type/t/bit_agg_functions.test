--echo datetime type
create table t1 (a datetime);
select bit_and(a), bit_or(a), bit_xor(a) from t1;
insert into t1 values (null);
select bit_and(a), bit_or(a), bit_xor(a) from t1;
insert into t1 values ('20000101101010');
select bit_and(a), bit_or(a), bit_xor(a) from t1;
insert into t1 values ('20000101101011');
select bit_and(a), bit_or(a), bit_xor(a) from t1;
insert into t1 values ('20000101101012');
select bit_and(a), bit_or(a), bit_xor(a) from t1;
drop table t1;

--echo timestamp type
create table t1 (a timestamp);
select bit_and(a), bit_or(a), bit_xor(a) from t1;
insert into t1 values ('20000101101010');
select bit_and(a), bit_or(a), bit_xor(a) from t1;
insert into t1 values ('20000101101011');
select bit_and(a), bit_or(a), bit_xor(a) from t1;
insert into t1 values ('20000101101012');
select bit_and(a), bit_or(a), bit_xor(a) from t1;
drop table t1;

--echo string type
create table t1 (a char(100));
select bit_and(a), bit_or(a), bit_xor(a) from t1;
insert into t1 values (null);
select bit_and(a), bit_or(a), bit_xor(a) from t1;
insert into t1 values ('abc');
select bit_and(a), bit_or(a), bit_xor(a) from t1;
insert into t1 values ('a123');
select bit_and(a), bit_or(a), bit_xor(a) from t1;
insert into t1 values ('123a');
select bit_and(a), bit_or(a), bit_xor(a) from t1;
insert into t1 values ('124');
select bit_and(a), bit_or(a), bit_xor(a) from t1;
drop table t1;

--echo enum type
create table t1 (a enum('one','two','three'));
select bit_and(a), bit_or(a), bit_xor(a) from t1;
insert into t1 values (null);
