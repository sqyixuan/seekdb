#owner: zuojiao.hzj
#owner group: SQL4
#description: 验证创建bit column的正确性
##tags: datatype

--disable_warnings
drop database if exists bitdb;
create database bitdb;
use bitdb;
--enable_warnings

--echo ##### case 1: test for different length #####
--error 1064
create table tbl1_1 (c1 bit(-1));
create table tbl1_2 (c1 bit(0));
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table tbl1_2;
create table tbl1_3 (c1 bit(3));
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table tbl1_3;
create table tbl1_4 (c1 bit(64));
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table tbl1_4;
set @@sql_mode = "";
--error 1439
create table tbl1_5 (c1 bit(65));
show warnings;
set @@sql_mode = "STRICT_ALL_TABLES";
--error 1439
create table tbl1_5 (c1 bit(65));

drop database bitdb;
