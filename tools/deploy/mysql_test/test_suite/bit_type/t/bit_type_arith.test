--echo
--echo ### bit arith ObDatetimeTC ###
create table t1(c1 bit(24), c2 datetime, c3 datetime);
insert into t1 values(0x1, "20090909", "1998-08-21 14:00:00");
--enable_metadata
select c1 + c2, c1 * c2, c2 - c1 from t1;
select c1 + c3, c1 * c3, c3 - c1 from t1;
--disable_metadata
drop table t1;

create table t1(c1 bit(24), c2 timestamp, c3 timestamp);
insert into t1 values(0x1, "20090909", "1998-08-21 14:00:00");
--enable_metadata
select c1 + c2, c1 * c2, c2 - c1 from t1;
select c1 + c3, c1 * c3, c3 - c1 from t1;
--disable_metadata
drop table t1;

--echo
--echo ### bit arith ObDatetimeTC ###
create table t1(c1 bit(24), c2 date, c3 date);
insert into t1 values(0xFFFFFF, "20090909", "1998-08-21");
--enable_metadata
select c1 + c2, c1 * c2, c2 - c1 from t1;
select c1 + c3, c1 * c3, c3 - c1 from t1;
--disable_metadata
drop table t1;

--echo
--echo ### bit arith ObTimeTC ###
create table t1(c1 bit(24), c2 date, c3 date);
insert into t1 values(0x1123, "121212", "00:08:21");
--enable_metadata
select c1 + c2, c1 * c2, c2 - c1 from t1;
select c1 + c3, c1 * c3, c3 - c1 from t1;
--disable_metadata
drop table t1;

--echo
--echo ### bit arith ObYearTC ###
create table t1(c1 bit(24), c2 year, c3 year);
insert into t1 values(0x1, "1998", "2005");
--enable_metadata
select c1 + c2, c1 * c2, c2 - c1 from t1;
select c1 + c3, c1 * c3, c3 - c1 from t1;
--disable_metadata
drop table t1;

--echo
--echo ### bit arith ObYearTC ###
create table t1(c1 bit(36), c2 varchar(20), c3 char(20));
insert into t1 values(0xFFFFFF, "1aa1aaaaaa", "b2bbbbbb3");
--enable_metadata
##下面两个语句应该有warning，但是因为#15138120,暂时忽略warning
select c1 + c2, c1 * c2, c2 - c1 from t1;
select c1 + c3, c1 * c3, c3 - c1 from t1;
--disable_metadata
drop table t1;

--echo
--echo ### bit arith bit ###
create table t1(c1 bit(36), c2 bit(16), c3 bit(64));
insert into t1 values(0xFFFFFFFF, 0xFFFF, 0xFFFFFFFF);
--enable_metadata
select c1 + c2, c1 * c2, c3 - c2 from t1;
select c1 + c3, c1 * c3, c3 - c1 from t1;
--disable_metadata
drop table t1;



drop database bitdb;