#owner: zuojiao.hzj
#owner group: SQL4
#description: 验证bit type与其他数据类型之间进行arith 计算的结果(add, minus, mul)
##tags: datatype

##测试思路：
## 1. 测试的校验 1）通过column meta来确定result type; 2) result value
## 2. 测试xxx为column和const的情况
## 3. bt在运算符的左侧或右侧
## 4. 测试计算结果溢出的情况: 1)warn; 2)error的情况

--disable_warnings
drop database if exists bitdb;
--enable_warnings
create database bitdb;
use bitdb;

--echo
--echo ### bit arith ObNULLTC ###

create table t1(c1 bit(64));
insert into t1 values(20080909);
--enable_metadata
select c1 + NULL, c1 - NULL , NULL * c1 from t1;
--disable_metadata
drop table t1;

--echo
--echo ### bit arith ObIntTC/ObUIntTC ###
create table t1(c1 bit(32), c2 int, c3 int unsigned);
insert into t1 value(65535, 1, 2);
--enable_metadata
select c1 + c2, c1 * c2, c1 - c2 from t1;
select c1 + c3, c1 * c3, c1 - c3 from t1;
select c2 * c3 from t1;
--disable_metadata
drop table t1;

--echo
--echo ### bit arith ObFloatTC/ObDoubleTC ###
create table t1(c1 bit(32), c2 float, c3 double);
insert into t1 values(33333, 12.000, 67.11111);
--enable_metadata
select c1 + c2, c1 * c2, c1 - c2 from t1;
select c1 + c3, c1 * c3, c1 - c3 from t1;
--disable_metadata
drop table t1;

