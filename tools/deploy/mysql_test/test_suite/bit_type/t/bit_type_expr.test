#owner: zuojiao.hzj
#owner group: SQL4
#description: 验证bit类型参与各种表达式计算的结果
##tags: datatype
--disable_warnings
drop database if exists bitdb;
--enable_warnings
create database bitdb;
use bitdb;

create table t1(c1 bit(32) default 97);
insert into t1 values(98),(97),(96);
select cast(least(c1,c1) as datetime) from t1;
select cast(greatest(c1,c1) as datetime) from t1;
## select least(c1,c1) from t1;
##select concat(least(c1,c1), "***") from t1;
select cast(default(c1) as datetime) from t1;
select hex(default(c1)) from t1;
select hex(concat(default(c1), '***')) from t1;
#bug #14409387
select * from t1 where c1 like 'a';

drop database bitdb;