#owner: zuojiao.hzj
#owner group: SQL4
#description: 验证bit column进行dml操作的正确性
##tags: datatype

set @ori_mode = @@sql_mode;
--disable_warnings
drop database if exists bitdb;
--enable_warnings
create database bitdb;
use bitdb;

create table t1(c1 bit);
create table t2(c1 bit(8));
create table t3(c1 bit(64));
--echo
--echo
--echo ##### case 1: test for insert different length value to bit column #####
set @@sql_mode = "";
insert into t1 values(0b1);
insert into t1 values(0b11);
insert into t2 values(0b0);
insert into t2 values(0b11111111);
insert into t2 values(0b111111111);
insert into t3 values(0x0);
insert into t3 values(0x1);
insert into t3 values(0xFF);
insert into t3 values(0xFFFFFFFFFFFFFFFF);
insert into t3 values(0xFFFFFFFFFFFFFFFFF);
--echo
select hex(c1) from t1;
select hex(c1) from t2;
select hex(c1) from t3;
--echo
set @@sql_mode = "STRICT_ALL_TABLES";
insert into t1 values(0b1);
--error 1406
insert into t1 values(0b11);
insert into t2 values(0b0);
insert into t2 values(0b11111111);
--error 1406
insert into t2 values(0b111111111);
insert into t3 values(0x0);
insert into t3 values(0x1);
insert into t3 values(0xFF);
insert into t3 values(0xFFFFFFFFFFFFFFFF);
--error 1406,1264
insert into t3 values(0xFFFFFFFFFFFFFFFFF);
--echo
select hex(c1) from t1;
select hex(c1) from t2;
select hex(c1) from t3;

--echo
--echo
--echo ##### case 2: test for assign bit column value to user variable #####
create table t2_1(c1 bit(64));
insert into t2_1 values(0b110001);
select @v1:=c1 from t2_1;
select @v2:=(select * from t2_1);
select @v1, @v2;
create table t2_2(c1 bit(64));
insert into t2_2 values("A");
select @v1:=c1 from t2_2;
select @v2:=(select * from t2_2);
select @v1, @v2;

--echo
--echo
--echo ##### case 3: test for bit column default value #####
## case 3.1 : 测试default value的指定和创建
create table t3_1 (c1 bit(64) default 0b1000001, c2 int);
insert into t3_1 (c2) values(2),(3);
select hex(c1), c2 from t3_1;

## case 3.2 : 测试pre zero是会给忽略
create table t3_2 (c1 bit(64) default 0b0001000001, c2 int);
insert into t3_2 (c2) values(2),(3);
select hex(c1), c2 from t3_2;

## case 3.3 : 测试default值为0的情况
create table t3_3 (c1 bit(64) default 0b0, c2 int);
insert into t3_3(c2) values(2),(3);
select hex(c1), c2 from t3_3;

## case 3.4 : 测试default值len > column_length
--error 1067
create table t3_4 (c1 bit(8) default 111111111111111111111, c2 int);
--error 1067
create table t3_4 (c1 bit(8) default 0b111111111, c2 int);

## case 3.5 : 测试default值为numeric时
create table t3_5 (c1 bit(8) default 65, c2 int);
insert into t3_5 (c2) values(2),(3);
select hex(c1), c2 from t3_5;

create table t3_6 (c1 bit(8) default NULL, c2 int);
insert into t3_6 (c2) values(2),(3);
select hex(c1), c2 from t3_6;

--echo
--echo
--echo ##### case 4: test for bit column not null attribute #####
set @@sql_mode="";
create table t4_1(c1 bit(8) not null, c2 bit(7) not null, c3 bit(16) not null, c4 bit(64) not null, c5 int);
insert /*+USE_PLAN_CACHE(NONE)*/ into t4_1 (c5) values(1),(2),(0xFFFFFF),(0xFFFFFFFFFFF);
select hex(c1), hex(c2), hex(c3), hex(c4), c5 from t4_1;
set @@sql_mode=STRICT_ALL_TABLES;
--error 1364
insert into t4_1 (c5) values(1),(2),(0xFFFFFF),(0xFFFFFFFFFFF);

--echo
--echo
--echo ##### case 5: test for empty hexstring for bit column #####
set @@sql_mode=STRICT_ALL_TABLES;
--error 1067
create table t5_1(c1 bit(64) default b'');
--error 1067
create table t5_1(c1 bit(64) default X'');
create table t5_1(c1 bit(64) default '');
--error 1366
insert into t5_1 values(b'');
insert into t5_1 values('');
select hex(c1) from t5_1;

set @@sql_mode="";
insert into t5_1 values(b'');
insert into t5_1 values('');
select hex(c1) from t5_1;
drop database bitdb;
set @@sql_mode = @ori_mode;
