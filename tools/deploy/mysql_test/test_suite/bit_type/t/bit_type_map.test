#owner: zuojiao.hzj
#owner group: SQL4
#description: 验证bit type在abs, div, int div, round, sum, neg, mode,nvl
##tags: datatype

##测试思路：
## 1. 测试的校验 1）通过column meta来确定result type; 2) result value
## 2. 测试xxx为column和const的情况
## 3. bt在运算符的左侧或右侧
## 4. 测试计算结果溢出的情况: 1)warn; 2)error的情况

--disable_warnings
drop database if exists bitdb;
--enable_warnings
create database bitdb;
use bitdb;

--echo
--echo ### bit op ObNULLTC ###
create table t1(c1 bit(64));
insert into t1 values(20080909);
--enable_metadata
select c1 % NULL, c1 / NULL , NULL div c1 from t1;
--disable_metadata
drop table t1;


########################### test mod, div, int div ########################
--echo
--echo ### bit op ObIntTC/ObUIntTC ###
create table t1(c1 bit(32), c2 int, c3 int unsigned);
insert into t1 value(65535, 1, 2);
--enable_metadata
select c1 % c3, c1 / c3, c1 div c3 from t1;
--disable_metadata
drop table t1;

--echo
--echo ### bit op ObFloatTC/ObDoubleTC ###
create table t1(c1 bit(32), c2 float, c3 double);
insert into t1 values(33333, 12.000, 67.11111);
--enable_metadata
select c1 % c2, c1 / c2, c1 div c2 from t1;
select c1 % c3, c1 / c3, c1 div c3 from t1;
--disable_metadata
drop table t1;

--echo
--echo ### bit op ObNumberTC ###
create table t1(c1 bit(64), c2 decimal(30, 5), c3 decimal(30, 5));
insert into t1 values(0xFFFFFFFFFFFFFFFF, -123.0000000, 456.000001);
--enable_metadata
## bug #14727572
## select c1 % c2, c1 / c2, c1 div -c2 from t1;
## select c1 % c3, c1 / c3, c1 div c3 from t1;
--disable_metadata
drop table t1;

--echo
--echo ### bit op ObDatetimeTC ###
create table t1(c1 bit(24), c2 datetime, c3 datetime);
insert into t1 values(0x1, "20090909", "1998-08-21 14:00:00");
--enable_metadata
select c1 % c2, c1 / c2, c2 div c1 from t1;
select c1 % c3, c1 / c3, c3 div c1 from t1;
--disable_metadata
drop table t1;

create table t1(c1 bit(24), c2 timestamp, c3 timestamp);
insert into t1 values(0x1, "20090909", "1998-08-21 14:00:00");
--enable_metadata
select c1 % c2, c1 / c2, c2 div c1 from t1;
select c1 % c3, c1 / c3, c3 div c1 from t1;
--disable_metadata
drop table t1;

--echo
--echo ### bit op ObDateTC ###
create table t1(c1 bit(24), c2 date, c3 date);
insert into t1 values(0xFFFFFF, "20090909", "1998-08-21");
--enable_metadata
select c1 % c2, c1 / c2, c2 div c1 from t1;
select c1 % c3, c1 / c3, c3 div c1 from t1;
--disable_metadata
drop table t1;

--echo
--echo ### bit op ObTimeTC ###
create table t1(c1 bit(24), c2 date, c3 date);
insert into t1 values(0x1123, "121212", "00:08:21");
--enable_metadata
select c1 % c2, c1 / c2, c2 div c1 from t1;
select c1 % c3, c1 / c3, c3 div c1 from t1;
--disable_metadata
drop table t1;

--echo
--echo ### bit op ObYearTC ###
create table t1(c1 bit(24), c2 year, c3 year);
insert into t1 values(0x1, "1998", "2005");
--enable_metadata
select c1 % c2, c1 / c2, c2 div c1 from t1;
select c1 % c3, c1 / c3, c3 div c1 from t1;
--disable_metadata
drop table t1;

--echo
--echo ### bit op ObYearTC ###
create table t1(c1 bit(36), c2 varchar(20), c3 char(20));
insert into t1 values(0xFFFFFF, "1aa1aaaaaa", "b2bbbbbb3");
--enable_metadata
select c1 % c2, c1 / c2, c2 div c1 from t1;
select c1 % c3, c1 / c3, c3 div c1 from t1;
--disable_metadata
drop table t1;

--echo
--echo ### bit op bit ###
create table t1(c1 bit(36), c2 bit(16), c3 bit(64));
insert into t1 values(0xFFFFFFFF, 0xFFFF, 0xFFFFFFFF);
--enable_metadata
select c1 % c2, c1 / c2, c3 div c2 from t1;
select c1 % c3, c1 / c3, c3 div c1 from t1;
--disable_metadata
drop table t1;

######################### test abs, round, sum  ########################
--echo
--echo ### bit op ObIntTC/ObUIntTC ###
create table t1(c1 bit(32), c2 int, c3 int unsigned);
insert into t1 value(65535, 1, 2);
--enable_metadata
select abs(c1), round(c1, c3), sum(c1) from t1;
--disable_metadata
drop table t1;

--echo
--echo ### bit op ObFloatTC/ObDoubleTC ###
create table t1(c1 bit(32), c2 float, c3 double);
insert into t1 values(33333, 12.000, 67.11111);
--enable_metadata
select abs(c1), round(c1, c2), sum(c1) from t1;
select abs(c1), round(c1, c3), sum(c1) from t1;
--disable_metadata
drop table t1;

--echo
--echo ### bit op ObNumberTC ###
create table t1(c1 bit(64), c2 decimal(30, 5), c3 decimal(30, 5));
insert into t1 values(0xFFFFFFFFFFFFFFFF, -123.0000000, 456.000001);
--enable_metadata
## bug #14727572
##select abs(c1), round(c1, c2), sum(c1) from t1;
##select abs(c1), round(c1, c3), sum(c1) from t1;
--disable_metadata
drop table t1;

--echo
--echo ### bit op ObDatetimeTC ###
create table t1(c1 bit(24), c2 datetime, c3 datetime);
insert into t1 values(0x1, "20090909", "1998-08-21 14:00:00");
--enable_metadata
select abs(c1), round(c1, c2), sum(c1) from t1;
select abs(c1), round(c1, c3), sum(c1) from t1;
--disable_metadata
drop table t1;

create table t1(c1 bit(24), c2 timestamp, c3 timestamp);
insert into t1 values(0x1, "20090909", "1998-08-21 14:00:00");
--enable_metadata
select abs(c1), round(c1, c2), sum(c1) from t1;
select abs(c1), round(c1, c3), sum(c1) from t1;
--disable_metadata
drop table t1;

--echo
--echo ### bit op ObDateTC ###
create table t1(c1 bit(24), c2 date, c3 date);
insert into t1 values(0xFFFFFF, "20090909", "1998-08-21");
--enable_metadata
select abs(c1), round(c1, c2), sum(c1) from t1;
select abs(c1), round(c1, c3), sum(c1) from t1;
--disable_metadata
drop table t1;

--echo
--echo ### bit op ObTimeTC ###
create table t1(c1 bit(24), c2 date, c3 date);
insert into t1 values(0x1123, "121212", "00:08:21");
--enable_metadata
select abs(c1), round(c1, c2), sum(c1) from t1;
select abs(c1), round(c1, c3), sum(c1) from t1;
--disable_metadata
drop table t1;

--echo
--echo ### bit op ObYearTC ###
create table t1(c1 bit(24), c2 year, c3 year);
insert into t1 values(0x1, "1998", "2005");
--enable_metadata
select abs(c1), round(c1, c2), sum(c1) from t1;
select abs(c1), round(c1, c3), sum(c1) from t1;
--disable_metadata
drop table t1;

--echo
--echo ### bit op ObYearTC ###
create table t1(c1 bit(36), c2 varchar(20), c3 char(20));
insert into t1 values(0xFFFFFF, "1aa1aaaaaa", "b2bbbbbb3");
select abs(c1), round(c1, c2), sum(c1) from t1;
select abs(c1), round(c1, c3), sum(c1) from t1;
--disable_metadata
drop table t1;

--echo
--echo ### bit op bit ###
create table t1(c1 bit(36), c2 bit(16), c3 bit(64));
insert into t1 values(0xFFFFFFFF, 0xFFFF, 0xFFFFFFFF);
select abs(c1), round(c1, c2), sum(c2) from t1;
select abs(c1), round(c1, c3), sum(c1) from t1;
--disable_metadata
drop table t1;

--echo
--echo ######################### test neg  ########################
create table t1(c1 bit(64), c2 bigint unsigned);
insert into t1 values
(1,1),
(0xFF, 0xFF),
(0x1000,1000),
(0x8000,0x8000),
(0xFFFFFFFF,0xFFFFFFFF),
(0x80000000,0x80000000),
(0x70000000,0x70000000),
(0x7000000000000000,0x7000000000000000);
select neg(c1), neg(c2) from t1;
drop table t1;

--echo
######################### test nvl  ########################
--echo
--echo ### bit nvl ObIntTC/ObUIntTC ###
create table t1(c1 bit(32), c2 bigint unsigned, c3 int unsigned);
insert into t1 value(NULL, NULL, 2);
--enable_metadata
select nvl(c1, c3), nvl(c2, c3) from t1;
--disable_metadata
drop table t1;

--echo
--echo ### bit nvl ObFloatTC/ObDoubleTC ###
create table t1(c1 bit(32), c2 bigint unsigned, c3 double);
insert into t1 values(NULL, NULL, 67.11111);
--enable_metadata
select nvl(c1, c3), nvl(c2, c3) from t1;
--disable_metadata
drop table t1;

--echo
--echo ### bit nvl ObNumberTC ###
create table t1(c1 bit(64), c2 bigint unsigned, c3 decimal(30, 5));
insert into t1 values(NULL, NULL, 456.000001);
--enable_metadata
select nvl(c1, c3), nvl(c2, c3) from t1;
select nvl(c1, c3), nvl(c2, c3) from t1;
--disable_metadata
drop table t1;

--echo
--echo ### bit nvl ObDatetimeTC ###
create table t1(c1 bit(24), c2 bigint unsigned, c3 datetime, c4 timestamp);
insert into t1 values(NULL, NULL, "1998-08-21 14:00:00", "1998-08-21 14:00:00");
--enable_metadata
select nvl(c1, c3), nvl(c2, c3), nvl(c1, c4) , nvl(c2, c4) from t1;
--disable_metadata
drop table t1;

--echo
--echo ### bit nvl ObDateTC ###
create table t1(c1 bit(24), c2 bigint unsigned, c3 date);
insert into t1 values(NULL, NULL, "1998-08-21");
--enable_metadata
select nvl(c1, c3), nvl(c2, c3) from t1;
--disable_metadata
drop table t1;

--echo
--echo ### bit nvl ObTimeTC ###
create table t1(c1 bit(24), c2 bigint unsigned, c3 date);
insert into t1 values(NULL, NULL, "00:08:21");
--enable_metadata
select nvl(c1, c3), nvl(c2, c3) from t1;
--disable_metadata
drop table t1;

--echo
--echo ### bit nvl ObYearTC ###
create table t1(c1 bit(24), c2 bigint unsigned, c3 year);
insert into t1 values(0x1, 0x1, "2005");
--enable_metadata
select nvl(c1, c3), nvl(c2, c3) from t1;
--disable_metadata
drop table t1;

--echo
--echo ### bit nvl ObYearTC ###
create table t1(c1 bit(36), c2 bigint unsigned, c3 char(20));
insert into t1 values(NULL, NULL, "b2bbbbbb3");
--enable_metadata
select nvl(c1, c3), nvl(c2, c3) from t1;
--disable_metadata
drop table t1;

--echo
--echo ### bit nvl bit ###
create table t1(c1 bit(36), c2 bigint unsigned, c3 bit(64));
insert into t1 values(NULL, NULL, 0xFFFFFFFF);
--enable_metadata
select hex(nvl(c1, c3)), hex(nvl(c2, c3)) from t1;
--disable_metadata
drop table t1;

drop database bitdb;