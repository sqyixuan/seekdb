#owner: zuojiao.hzj
#owner group: SQL4
#description: 验证BIT与其他类型之间的cast，结果文件为mysql5.7产生
##tags: datatype

--disable_warnings
drop database if exists bitdb;
--enable_warnings
create database bitdb;
use bitdb;

--echo ##### case 1 : xxx -> bit #####
--echo
--echo ### int -> bit ###
create table t1(c1 bit(16));
insert into t1 values(1), (0xff), (49), (3185);
select hex(c1) from t1;
select hex(concat("*", c1)) from t1;
set @@sql_mode = "";
insert into t1 values(65536),(-1),(-49),(-3185);
select hex(c1) from t1;
set @@sql_mode = "STRICT_ALL_TABLES";
--error 1406
insert into t1 values(65536),(-1),(-49),(-3185);
drop table t1;

--echo
--echo ### float/double -> bit ###
create table t1(c1 bit(16), c2 bit(16));
create table t2(c1 float, c2 double);
insert into t2 values(1,0xFFFF),(1.1, 1111.1111),(3185.99, 3185.99999);
insert into t2 values(-1,0xFFFF),(-1.1, -1111.1111),(-3185.99, -3185.99999);
set @@sql_mode = "";
insert into t1 select c1, c2 from t2;
set @@sql_mode = "STRICT_ALL_TABLES";
--error 1406
insert into t1 select c1, c2 from t2;
select hex(c1), hex(c2) from t1;
create table t3(c1 float, c2 double);
set @@sql_mode = "";
insert into t3 values(65555.5555, 65555.5555), (-65555.5555, -65555.5555);
insert into t1 select c1, c2 from t3;
select hex(c1), hex(c2) from t1;
set @@sql_mode = "STRICT_ALL_TABLES";
--error 1406
insert into t1 select c1, c2 from t3;
drop table t1,t2,t3;

--echo
--echo ### number -> bit ###
create table t1(c1 bit(16));
create table t2(c1 decimal(15,5));
insert into t2 values(0xFFFF),(1111.1111),(3185.99999);
insert into t2 values(-1.00001),(-1111.1111),(-3185.99999);
set @@sql_mode = "";
insert into t1 select c1 from t2;
set @@sql_mode = "STRICT_ALL_TABLES";
--error 1264
insert into t1 select c1 from t2;
select hex(c1) from t1;
create table t3(c1 decimal(15,5));
insert into t3 values(165555.55551), (-165555.55551);
set @@sql_mode = "";
insert into t1 select c1 from t3;
set @@sql_mode = "STRICT_ALL_TABLES";
--error 1406
insert into t1 select c1 from t3;
select hex(c1) from t1;
drop table t1,t2,t3;

--echo
--echo ### datetime -> bit ###
set @@sql_mode = "";
create table t1(c1 bit(64));
insert into t1 values(cast(20080909 as date)), (cast(10000101 as date)), (cast(99991231 as date));
select hex(c1) from t1;
drop table t1;

--echo
--echo ### date -> bit ###
create table t1(c1 bit(64));
set @@sql_mode = "";
#insert into t1 values(cast(20080909 as date)), (cast(10000101 as date)), (cast(99991231 as date));
insert into t1 values(cast(20080909 as date));
insert into t1 values(20080909);
insert into t1 values("2008-09-09");
select hex(c1) from t1;
drop table t1;

--echo
--echo ### year -> bit ###
create table t1(c1 bit(64));
create table t2(c1 year);
insert into t2 values("2008"),("1990"),("1901"),("2155");
insert into t1 select * from t2;
select hex(c1) from t1;
drop table t1,t2;

### 时间相关类型到bit的转换mysql的表现并不一致，已经提交bug
--echo
--echo ### time -> bit ###
create table t1(c1 bit(6));
set @@sql_mode = "";
insert into t1 values(cast("010101" as time)), (cast("242321" as time)), (cast("1" as time));
select hex(c1) from t1;
create table t2(c1 time);
insert into t2 values("010101"),("242321"),("1");
insert into t1 select * from t2;
select hex(c1) from t1;
drop table t1,t2;

--echo
--echo ### bit -> bit ###
set @@sql_mode = "";
create table t1(c1 bit(32));
create table t2(c1 bit(64));
create table t3(c1 bit(16));
insert into t2 values(0x1122),(0x1122334455667788);
insert into t3 values(0x11),(0x1122);
insert into t1 select * from t2;
select hex(c1) from t1;
insert into t1 select * from t3;
select hex(c1) from t1;
drop table t1,t2,t3;

--echo  # bit -> year/date/time/datetime/string. BUG, 
set @@sql_mode = "STRICT_ALL_TABLES";
CREATE TABLE t1(
int_      int,
float_     float(5,2),
double_    double(5,2),
decimal_    decimal(5,2),
year_     year,
date_     date,
time_     time,
datetime_   datetime,
timestamp_   timestamp,
char_     char(20),
varchar_    varchar(20),
text_     text,
enum_     enum('one','two','three'),
set_      set('one','two','three'),
bit_      bit(6),
binary_    BINARY(20),
varbinary_   varbinary(20),
blob_     blob(5)) PARTITION BY hash(int_) PARTITIONS 3;
CREATE TABLE t2(
int_      int,
float_     float(5,2),
double_    double(5,2),
decimal_    decimal(5,2),
year_     year,
date_     date,
time_     time,
datetime_   datetime,
timestamp_   timestamp,
char_     char(20),
varchar_    varchar(20),
text_     text,
enum_     enum('one','two','three'),
set_      set('one','two','three'),
bit_      bit(6),
binary_    BINARY(20),
varbinary_   varbinary(20),
blob_     blob(5)) PARTITION BY hash(int_) PARTITIONS 3;
INSERT INTO t1 VALUES(10,100.11,10.1,20.1,'2000','20000101','101010','20000101101010','20000101101010','abc','111','1abc','one','one',20,'t1','test_1','admin1');
INSERT INTO t1 VALUES(11,110.11,11.1,21.1,'2001','20010101','101011','20010101101011','20010101101011','bcd','112','2abc','two','two',21,'test2','test_2','admin2');
INSERT INTO t1 VALUES(12,120.11,12.1,22.1,'2002','20020101','101012','20020101101012','20020101101012','cde','113','3abc','three','three',22,'test3','test_3','admin3');
INSERT INTO t1 VALUES(13,130.11,13.1,23.1,'2003','20030101','101013','20030101101013','20030101101013','def','114','4abc','one','one',23,'test4','test_4','admin4');
# bit to year
INSERT INTO t2(year_) VALUES((SELECT bit_ FROM t1 WHERE int_ IS NOT NULL AND int_ BETWEEN 12 AND 12.5));
SELECT year_ FROM t2 WHERE year_ IS NOT NULL;
# bit to date
--error 1292
INSERT INTO t2(date_) VALUES((SELECT bit_ FROM t1 WHERE int_!=ALL(SELECT 10 FROM DUAL UNION SELECT 12 FROM DUAL UNION SELECT 13 FROM DUAL)));
# bit to time
INSERT INTO t2(time_) VALUES((SELECT bit_ FROM t1 WHERE int_>12));
SELECT time_ FROM t2 WHERE time_ IS NOT NULL;
# bit to datetime
--error 1292
INSERT INTO t2(datetime_) VALUES((SELECT bit_ FROM t1 WHERE int_<11));
# bit to timestamp
--error 1292
INSERT INTO t2(timestamp_) VALUES((SELECT bit_ FROM t1 WHERE int_=11));
# bit to char_
INSERT INTO t2(char_) VALUES((SELECT bit_ FROM t1 WHERE int_ NOT IN (10,12,13)));
SELECT char_ FROM t2 WHERE char_ IS NOT NULL;
# bit to varchar
INSERT INTO t2(varchar_) VALUES((SELECT bit_ FROM t1 WHERE int_>=13));
SELECT varchar_ FROM t2 WHERE varchar_ IS NOT NULL;
# bit to text
INSERT INTO t2(text_) VALUES((SELECT bit_ FROM t1 WHERE int_<=10));
SELECT text_ FROM t2 WHERE text_ IS NOT NULL;
# bit to binary
INSERT INTO t2(binary_) VALUES((SELECT bit_ FROM t1 WHERE int_<11));
SELECT HEX(binary_) FROM t2 WHERE binary_ IS NOT NULL;
# bit to varbinary
INSERT INTO t2(varbinary_) VALUES((SELECT bit_ FROM t1 WHERE int_=12));
SELECT varbinary_ FROM t2 WHERE varbinary_ IS NOT NULL;
# bit to blob_
INSERT INTO t2(blob_) VALUES((SELECT bit_ FROM t1 WHERE int_=13));
SELECT blob_ FROM t2 WHERE blob_ IS NOT NULL;
drop table t1, t2;

--echo cast by alter cmd
CREATE TABLE Z0CASE(Z0_TEST0 BIT(25));
INSERT INTO Z0CASE VALUES(b'1001101000011111010010001');
ALTER TABLE Z0CASE MODIFY column z0_test0 DATE;
SELECT * FROM Z0CASE;
DROP TABLE Z0CASE;

--echo bit -> year
create table t1 (bit_ BIT(64));
create table t2 (year_ YEAR);

insert into t1 values(2020);
select bin(bit_) from t1;
insert into t2 select bit_ from t1;
select year_ from t2;

truncate table t1;
insert into t1 values('2020');
select bin(bit_) from t1;
--error 1264
insert into t2 select bit_ from t1;
drop table t1, t2;

--echo bit -> time
create table t1 (bit_ BIT(64));
create table t2 (time_ TIME);

insert into t1 values(123456);
select bin(bit_) from t1;
insert into t2 select bit_ from t1;
select time_ from t2;

truncate table t1;
insert into t1 values('12:34:56');
select bin(bit_) from t1;
--error 1292
insert into t2 select bit_ from t1;

select cast(bit_ as time) from t1;
drop table t1, t2;

--echo bit -> date
create table t1 (bit_ BIT(64));
create table t2 (date_ DATE);

insert into t1 values(19700101);
select bin(bit_) from t1;
insert into t2 select bit_ from t1;
select date_ from t2;

truncate table t1;
insert into t1 values('19700101');
select bin(bit_) from t1;
--error 1292
insert into t2 select bit_ from t1;

select cast(bit_ as date) from t1;
drop table t1, t2;

--echo bit -> datetime
create table t1 (bit_ BIT(64));
create table t2 (datetime_ DATETIME);

insert into t1 values(19700101000001);
select bin(bit_) from t1;
insert into t2 select bit_ from t1;
select datetime_ from t2;

truncate table t1;
--error 1406
insert into t1 values('19700101000001');
insert into t1 values('19700101');
select bin(bit_) from t1;
--error 1292
insert into t2 select bit_ from t1;

select cast(bit_ as datetime) from t1;
drop table t1, t2;

--echo bit -> string
create table t1(bit_ BIT(64));
create table t2(c CHAR(10));
insert into t1 values (1);
insert into t1 values ('1');
select bin(bit_) from t1;
insert into t2 select bit_ from t1;
select c from t2;
select hex(cast(bit_ as char(10))) from t1;
drop table t1, t2;

--echo bit -> datetime by expr
create table t1(bit_ BIT(64));
insert into t1 values (19700101);
insert into t1 values ('19700101');
select timestamp(bit_) from t1;
drop table t1;

--echo issue#45256466
create table t1(c1 bit(16), c2 bit(24));
insert into t1 values(61, 61), (180, 180), (1800, 1800);
select hex(convert(c1 using utf16)) from t1;
select hex(convert(c2 using utf16)) from t1;
drop table t1;

create table t8(
  c1 bit(64),
  c2 int,
  c3 int unsigned,
  c4 float,
  c5 double,
  c6 float unsigned,
  c7 double unsigned,
  c8 decimal,
  c9 decimal unsigned,
  c10 year,
  c11 char
);
create table h1 as select case c1 when 10 then c2 else c1 end from t8;
desc h1;
drop table h1;
create table h1 as select case c1 when 10 then c3 else c1 end from t8;
desc h1;
drop table h1;
create table h1 as select case c1 when 10 then c4 else c1 end from t8;
desc h1;
drop table h1;
create table h1 as select case c1 when 10 then c5 else c1 end from t8;
desc h1;
drop table h1;
create table h1 as select case c1 when 10 then c6 else c1 end from t8;
desc h1;
drop table h1;
create table h1 as select case c1 when 10 then c7 else c1 end from t8;
desc h1;
drop table h1;
create table h1 as select case c1 when 10 then c8 else c1 end from t8;
desc h1;
drop table h1;
create table h1 as select case c1 when 10 then c9 else c1 end from t8;
desc h1;
drop table h1;
create table h1 as select case c1 when 10 then c10 else c1 end from t8;
desc h1;
drop table h1;
create table h1 as select case c1 when 10 then c11 else c1 end from t8;
desc h1;
drop table h1;
drop table t8;

create TABLE t1(a bit(64));
insert into t1 values(1);
DELIMITER //;
create procedure p1()
begin
  declare a varchar(20);
  select t1.a into a from t1;
end;
//
DELIMITER ;//
call p1();

drop procedure p1;
drop table t1;

create table t1 (a bit(64));
insert into t1 values(null),(0),(1),(X'FFFFFFFFFFFFFF'),(X'AFFFFFFFFFFFFFFF'),(X'FFFFFFFFFFFFFFFF');
select cast(a as decimal(64, 0)) from t1;
drop table t1;

set sql_mode = '';
create sequence s1 cache 1000;
create table t1(c1 bit(9) PRIMARY key) DEFAULT CHARSET = utf16 ;
insert into t1 select s1.nextval from table(generator(511));
alter table t1 modify column c1 varchar ( 357 ) ;
select sum(hex(c1)) from t1;
drop table t1;
drop sequence s1;

create table jim_t1(c1 bit);
create table jim_t2(c1 tinytext charset utf16);
insert into jim_t1 values(0x01);
select hex(c1) from jim_t1;
explain insert into jim_t2 select * from jim_t1;
insert into jim_t2 select * from jim_t1;
select hex(c1) from jim_t2;
select * from jim_t2 where c1 = '1';
drop table jim_t1, jim_t2;

drop database bitdb;
