#owner: zuojiao.hzj
#owner group: SQL4
#description: 验证BIT与其他类型之间的cmp，结果文件为mysql5.7产生
##tags: datatype

##测试思路：
## 1. bit cmp xxx  , xxx cmp bit
## 2. cmp: >, >=, =, !=, <=, < ; least, greatest
## 3. xxx 分别来自column和const
## 4. xxx的value分别满足上述cmp值

--disable_warnings
drop database if exists bitdb;
--enable_warnings
create database bitdb;
use bitdb;

############################### test for >, >=, =, !=, <=, < ############################
create table t1(c1 bit(64));

--echo
--echo ### bit cmp ObIntTC ###
truncate t1;
insert into t1 values("9");
select hex(c1) from t1;
select c1 > NULL, c1 = NULL, c1 < NULL from t1;
create table t2(c1 int);
insert into t2 values(NULL);
select c1 > (select c1 from t2), c1 = (select c1 from t2), c1 < (select c1 from t2) from t1;
drop table t2;

--echo
--echo ### bit cmp ObIntTC ###
truncate t1;
insert into t1 values("9");
select hex(c1) from t1;
select c1 > 9, c1 = 9, c1 < 9 from t1;
select c1 > 57, c1 = 57, c1 < 57 from t1;

--echo ### bit cmp ObUIntTC ###
truncate t1;
insert into t1 values("9");
select hex(c1) from t1;
select c1 > cast(9 as unsigned), c1 = cast(9 as unsigned), c1 < cast(9 as unsigned) from t1;
select c1 > cast(57 as unsigned), c1 = cast(57 as unsigned), c1 < cast(57 as unsigned) from t1;

--echo
--echo ### bit cmp ObFloatTC ###
create table t2 (c1 bit(64), c2 float, c3 float);
insert into t2 values("9", 57.000, 57.001);
select hex(c1), c1 > c2, c1 = c2, c1 < c2 from t2;
select hex(c1), c1 > c3, c1 = c3, c1 < c3 from t2;
drop table t2;

--echo
--echo ### bit cmp ObDoubleTC ###
create table t2 (c1 bit(64), c2 double, c3 double);
insert into t2 values("9", 57.000, 57.001);
select hex(c1), c1 > c2, c1 = c2, c1 < c2 from t2;
select hex(c1), c1 > c3, c1 = c3, c1 < c3 from t2;
drop table t2;

--echo
--echo ### bit cmp ObNumberTC ###
create table t2 (c1 bit(64), c2 decimal(10, 5), c3 decimal(10, 5));
insert into t2 values("9", 57.000, 57.001);
select hex(c1), c1 > c2, c1 = c2, c1 < c2 from t2;
select hex(c1), c1 > c3, c1 = c3, c1 < c3 from t2;
drop table t2;

--echo
--echo ### bit cmp ObDateTimeTC ###
truncate t1;
insert into t1 values("20080909");
insert into t1 values(20080909000000);
create table t2(c1 datetime);
insert into t2 values("20080909");
select hex(c1), c1 > cast("20080909" as datetime),c1 = cast("20080909" as datetime),c1 < cast("20080909" as datetime) from t1;
select hex(c1), c1 > cast("2008-09-09 00:00:00.1" as datetime),c1 = cast("20080909" as datetime),c1 < cast("20080909" as datetime) from t1;
select hex(c1), cast("20080909" as datetime) < c1 , cast("20080909" as datetime) = c1, cast("20080909" as datetime) > c1 from t1;
select hex(c1), c1 > (select c1 from t2), c1 = (select c1 from t2), c1 < (select c1 from t2) from t1;
drop table t2;

create table t2(c1 timestamp);
insert into t2 values("20080909");
select hex(c1), c1 > cast("20080909" as datetime),c1 = cast("20080909" as datetime),c1 < cast("20080909" as datetime) from t1;
select hex(c1), c1 > cast("2008-09-09 00:00:00.1" as datetime),c1 = cast("20080909" as datetime),c1 < cast("20080909" as datetime) from t1;
select hex(c1), cast("20080909" as datetime) < c1 , cast("20080909" as datetime) = c1, cast("20080909" as datetime) > c1 from t1;
select hex(c1), c1 > (select c1 from t2), c1 = (select c1 from t2), c1 < (select c1 from t2) from t1;
drop table t2;

--echo
--echo ### bit cmp ObDateTC ###
truncate t1;
insert into t1 values("20080909");
insert into t1 values(20080909);
create table t2(c1 date);
insert into t2 values("20080909");
select hex(c1), c1 > (select c1 from t2), c1 = (select c1 from t2), c1 < (select c1 from t2) from t1;
drop table t2;

--echo
--echo ### bit cmp ObTimeTC ###
truncate t1;
insert into t1 values("121212");
insert into t1 values(121212);
create table t2(c1 time);
insert into t2 values("121212");
select hex(c1), c1 > (select c1 from t2), c1 = (select c1 from t2), c1 < (select c1 from t2) from t1;
drop table t2;

--echo
--echo ### bit cmp ObYearTC ###
truncate t1;
insert into t1 values("1998");
insert into t1 values(1998);
create table t2(c1 year);
insert into t2 values("1998");
select hex(c1), c1 > (select c1 from t2), c1 = (select c1 from t2), c1 < (select c1 from t2) from t1;
drop table t2;

--echo
--echo ### bit cmp ObStringTC ###
truncate t1;
insert into t1 values("9");
select c1 > "9", c1 = "9", c1 < "9" from t1;
select c1 > "57", c1 = "57", c1 < "57" from t1;

--echo
--echo ### bit cmp ObBitTC ###
create table t2(c1 bit(32), c2 bit(48), c3 bit(52), c4 bit(64));
insert into t2 values(57, 57, 58, 59);
select c1 > c2, c1 = c2, c1 < c2 from t2;
select c1 > c3, c1 = c3, c1 < c3 from t2;
select c1 > c4, c1 = c4, c1 < c4 from t2;
drop table t1, t2;

############################### test for least and greatest ############################
--echo
--echo ### bit op ObNULLTC ###
create table t1(c1 bit(64));
insert into t1 values(20080909);
--enable_metadata
select least(c1, NULL), greatest(c1, NULL) from t1;
--disable_metadata
drop table t1;

--echo
--echo ### bit op ObIntTC/ObUIntTC ###
create table t1(c1 bit(32), c2 int, c3 int unsigned);
insert into t1 value(57, 56, 57);
--enable_metadata
select least(c1, c2), greatest(c1, c3), least(c2, c1), greatest(c3, c1) from t1;
--disable_metadata
drop table t1;

--echo
--echo ### bit op ObFloatTC/ObDoubleTC ###
create table t1(c1 bit(32), c2 float, c3 double);
insert into t1 values(256, 255.999, 256.001);
--enable_metadata
select least(c1, c2), greatest(c1, c3), least(c2, c1), greatest(c3, c1) from t1;
--disable_metadata
drop table t1;

--echo
--echo ### bit op ObNumberTC ###
create table t1(c1 bit(64), c2 decimal(30, 5), c3 decimal(30, 5));
insert into t1 values(65535, 65534.99999, 65535.00001);
--enable_metadata
select least(c1, c2), greatest(c1, c2), least(c2, c1), greatest(c3, c1) from t1;
--disable_metadata
drop table t1;

--echo
--echo ### bit op ObDatetimeTC ###
create table t1(c1 bit(24), c2 datetime, c3 datetime);
insert into t1 values(0x1, "20090909", "1998-08-21 14:00:00");
--enable_metadata
select least(c1, c2), greatest(c1, c2), least(c2, c1), greatest(c3, c1) from t1;
--disable_metadata
drop table t1;

create table t1(c1 bit(24), c2 timestamp, c3 timestamp);
insert into t1 values(0x1, "20090909", "1998-08-21 14:00:00");
--enable_metadata
select least(c1, c2), greatest(c1, c2), least(c2, c1), greatest(c3, c1) from t1;
--disable_metadata
drop table t1;

--echo
--echo ### bit op ObDateTC ###
create table t1(c1 bit(64), c2 date, c3 date);
insert into t1 values(20090910, "20090909", "2009-09-10");
--enable_metadata
select least(c1, c2), greatest(c1, c2), least(c2, c1), greatest(c3, c1) from t1;
--disable_metadata
drop table t1;

--echo
--echo ### bit op ObTimeTC ###
create table t1(c1 bit(24), c2 date, c3 date);
insert into t1 values(121212, "121211", "12:12:13");
--enable_metadata
select least(c1, c2), greatest(c1, c2), least(c2, c1), greatest(c3, c1) from t1;
--disable_metadata
drop table t1;

--echo
--echo ### bit op ObYearTC ###
create table t1(c1 bit(24), c2 year, c3 year);
insert into t1 values(1999, "1998", "2000");
--enable_metadata
select least(c1, c2), greatest(c1, c2), least(c2, c1), greatest(c3, c1) from t1;
--disable_metadata
drop table t1;

--echo
--echo ### bit op ObStringTC ###
create table t1(c1 bit(36), c2 varchar(20), c3 char(20));
insert into t1 values(57, "8", "10");
--enable_metadata
select least(c1, c2), greatest(c1, c2), least(c2, c1), greatest(c3, c1) from t1;
--disable_metadata
drop table t1;

--echo
--echo ### bit op bit ###
create table t1(c1 bit(36), c2 bit(48), c3 bit(64));
insert into t1 values(0xFFFFFFFE, 0xFFFFFFFF, 0xFFFFFFFD);
--enable_metadata
select hex(least(c1, c2)), hex(greatest(c1, c3)), hex(least(c2, c1)), hex(greatest(c3, c1)) from t1;
--disable_metadata
drop table t1;

drop database bitdb;