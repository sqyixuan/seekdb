drop database if exists bitdb;
create database bitdb;
use bitdb;

### bit arith ObNULLTC ###
create table t1(c1 bit(64));
insert into t1 values(20080909);
select c1 + NULL, c1 - NULL , NULL * c1 from t1;
Catalog	Database	Table	Table_alias	Column	Column_alias	Type	Length	Max length	Is_null	Flags	Decimals	Charsetnr
def					c1 + NULL	5	23	0	Y	32896	31	63
def					c1 - NULL	5	23	0	Y	32896	31	63
def					NULL * c1	5	23	0	Y	32896	31	63
c1 + NULL	c1 - NULL	NULL * c1
NULL	NULL	NULL
drop table t1;

