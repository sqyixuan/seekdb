drop database if exists bitdb;
create database bitdb;
use bitdb;
##### case 1 : xxx -> bit #####

### int -> bit ###
create table t1(c1 bit(16));
insert into t1 values(1), (0xff), (49), (3185);
select hex(c1) from t1;
hex(c1)
1
FF
31
C71
select hex(concat("*", c1)) from t1;
hex(concat("*", c1))
2A0001
2A00FF
2A0031
2A0C71
set @@sql_mode = "";
insert into t1 values(65536),(-1),(-49),(-3185);
select hex(c1) from t1;
hex(c1)
1
FF
31
C71
FFFF
FFFF
FFFF
FFFF
set @@sql_mode = "STRICT_ALL_TABLES";
insert into t1 values(65536),(-1),(-49),(-3185);
ERROR 22001: Data too long for column 'c1' at row 1
drop table t1;

### float/double -> bit ###
create table t1(c1 bit(16), c2 bit(16));
create table t2(c1 float, c2 double);
insert into t2 values(1,0xFFFF),(1.1, 1111.1111),(3185.99, 3185.99999);
insert into t2 values(-1,0xFFFF),(-1.1, -1111.1111),(-3185.99, -3185.99999);
set @@sql_mode = "";
insert into t1 select c1, c2 from t2;
set @@sql_mode = "STRICT_ALL_TABLES";
insert into t1 select c1, c2 from t2;
ERROR 22001: Data too long for column 'c1' at row 4
select hex(c1), hex(c2) from t1;
hex(c1)	hex(c2)
1	FFFF
1	457
C71	C71
FFFF	FFFF
FFFF	FFFF
FFFF	FFFF
create table t3(c1 float, c2 double);
set @@sql_mode = "";
insert into t3 values(65555.5555, 65555.5555), (-65555.5555, -65555.5555);
insert into t1 select c1, c2 from t3;
select hex(c1), hex(c2) from t1;
hex(c1)	hex(c2)
1	FFFF
1	457
C71	C71
FFFF	FFFF
FFFF	FFFF
FFFF	FFFF
FFFF	FFFF
FFFF	FFFF
set @@sql_mode = "STRICT_ALL_TABLES";
insert into t1 select c1, c2 from t3;
ERROR 22001: Data too long for column 'c1' at row 1
drop table t1,t2,t3;

### number -> bit ###
create table t1(c1 bit(16));
create table t2(c1 decimal(15,5));
insert into t2 values(0xFFFF),(1111.1111),(3185.99999);
insert into t2 values(-1.00001),(-1111.1111),(-3185.99999);
set @@sql_mode = "";
insert into t1 select c1 from t2;
set @@sql_mode = "STRICT_ALL_TABLES";
insert into t1 select c1 from t2;
ERROR 22003: Out of range value for column 'c1' at row 4
select hex(c1) from t1;
hex(c1)
FFFF
457
C72
0
0
0
create table t3(c1 decimal(15,5));
insert into t3 values(165555.55551), (-165555.55551);
set @@sql_mode = "";
insert into t1 select c1 from t3;
set @@sql_mode = "STRICT_ALL_TABLES";
insert into t1 select c1 from t3;
ERROR 22001: Data too long for column 'c1' at row 1
select hex(c1) from t1;
hex(c1)
FFFF
457
C72
0
0
0
FFFF
0
drop table t1,t2,t3;

### datetime -> bit ###
set @@sql_mode = "";
create table t1(c1 bit(64));
insert into t1 values(cast(20080909 as date)), (cast(10000101 as date)), (cast(99991231 as date));
select hex(c1) from t1;
hex(c1)
FFFFFFFFFFFFFFFF
FFFFFFFFFFFFFFFF
FFFFFFFFFFFFFFFF
drop table t1;

### date -> bit ###
create table t1(c1 bit(64));
set @@sql_mode = "";
insert into t1 values(cast(20080909 as date));
insert into t1 values(20080909);
insert into t1 values("2008-09-09");
select hex(c1) from t1;
hex(c1)
FFFFFFFFFFFFFFFF
132690D
FFFFFFFFFFFFFFFF
drop table t1;

### year -> bit ###
create table t1(c1 bit(64));
create table t2(c1 year);
insert into t2 values("2008"),("1990"),("1901"),("2155");
insert into t1 select * from t2;
select hex(c1) from t1;
hex(c1)
32303038
31393930
31393031
32313535
drop table t1,t2;

### time -> bit ###
create table t1(c1 bit(6));
set @@sql_mode = "";
insert into t1 values(cast("010101" as time)), (cast("242321" as time)), (cast("1" as time));
select hex(c1) from t1;
hex(c1)
3F
3F
3F
create table t2(c1 time);
insert into t2 values("010101"),("242321"),("1");
insert into t1 select * from t2;
select hex(c1) from t1;
hex(c1)
3F
3F
3F
3F
3F
3F
drop table t1,t2;

### bit -> bit ###
set @@sql_mode = "";
create table t1(c1 bit(32));
create table t2(c1 bit(64));
create table t3(c1 bit(16));
insert into t2 values(0x1122),(0x1122334455667788);
insert into t3 values(0x11),(0x1122);
insert into t1 select * from t2;
select hex(c1) from t1;
hex(c1)
1122
FFFFFFFF
insert into t1 select * from t3;
select hex(c1) from t1;
hex(c1)
1122
FFFFFFFF
11
1122
drop table t1,t2,t3;
drop database bitdb;
