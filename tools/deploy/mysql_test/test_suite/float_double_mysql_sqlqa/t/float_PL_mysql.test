--disable_warnings
drop database  IF EXISTS  db1;
--enable_warnings
create database db1;
use db1;

SET wait_timeout=30000000;
SET ob_trx_timeout = 30000000;
SET ob_query_timeout = 30000000;

--echo ##设置相同sql_mode;
SET @@sql_mode='STRICT_TRANS_TABLES,NO_ENGINE_SUBSTITUTION,no_zero_date,no_zero_in_date,PIPES_AS_CONCAT';

--echo ##PL块
--echo ##存储过程
--echo ##作为in参数
drop table if exists  t1;
drop table if exists  t2;
drop procedure if exists  p1;
create table t1 (c1 int primary key,c2 char(20) not null,c3 float(10,5) default 0,c4 float(255,30));
DELIMITER //;
CREATE  PROCEDURE p1(in a float(255,30),in b float(10,3))
begin
	if (a is not null) then
	set a = a + 0.495;
	set b = a + b;
end if;
insert into t1 values(a,b,23.215611,-1023.625);
select * from t1 where c4=-1023.625;
desc t1;
end//
DELIMITER ;//
call p1(36.5,52555.9999);

drop table if exists  t1;
drop table if exists  t2;
drop procedure if exists  p1;
create table t1 (c1 float(8,3) primary key,c2 float(7,2) not null,c3 float(10,5) default 0,c4 float(25,10));
DELIMITER //;
CREATE  PROCEDURE p1(in a char(20))
begin
	if (a is not null) then
	set a = a + 0.495;
end if;
insert into t1 values(a,11.591,23.215611,-1023.625);
select * from t1 where c4=-1023.625;
create table t2 as select * from t1 where c4=-1023.625;
desc t1;
desc t2;
end//
DELIMITER ;//
call p1(36.5-(-1.236));

drop table if exists  t1;
drop table if exists  t2;
drop procedure if exists  p1;
create table t1 (c1 float(8,3) primary key,c2 float(7,2) not null,c3 float(10,5) default 0,c4 float(25,10));
DELIMITER //;
CREATE  PROCEDURE p1(in a int)
begin
	if (a is not null) then
	set a = a + 0.495;
end if;
insert into t1 values(a,11.591,23.215611,-1023.625);
select * from t1 where c4=-1023.625;
create table t2 as select * from t1 where c4=-1023.625;
desc t1;
desc t2;
end//
DELIMITER ;//
call p1(36.5-(-1.236));

--echo ##包含out的存储过程
drop table if exists  t1;
drop table if exists  t2;
drop procedure if exists  p1;
create table t1 (c1 float(8,3) primary key,c2 float(7,2) not null,c3 float(10,5) default 0,c4 float(25,10));
DELIMITER //;
CREATE  PROCEDURE p1(out a char(20))
begin
	if (a is null) then
	set a ='99.954';
	set a = a + 0.495;
end if;
insert into t1 values(a,11.591,23.215611,-1023.625);
select * from t1 where c4=-1023.625;
desc t1;
end//
DELIMITER ;//
call p1(@a);
select @a;

drop table if exists  t1;
drop table if exists  t2;
drop procedure if exists  p1;
create table t1 (c1 float(8,3) primary key,c2 float(7,2) not null,c3 float(10,5) default 0,c4 float(25,10));
DELIMITER //;
CREATE  PROCEDURE p1(out a int)
begin
	if (a is null) then
	set a ='99.954';
	set a = a + 0.495;
end if;
insert into t1 values(a,11.591,23.215611,-1023.625);
select * from t1 where c4=-1023.625;
desc t1;
end//
DELIMITER ;//
call p1(@a);
select @a;

drop table if exists  t1;
drop table if exists  t2;
drop procedure if exists  p1;
create table t1 (c1 char(20) primary key,c2 float(7,2) not null,c3 float(10,5) default 0,c4 float(25,10));
DELIMITER //;
CREATE  PROCEDURE p1(out a float(20,5))
begin
	if (a is null) then
	set a ='99.954';
	set a = a + 0.495;
end if;
insert into t1 values(a,11.591,23.215611,-1023.625);
select * from t1 where c4=-1023.625;
desc t1;
end//
DELIMITER ;//
call p1(@a);
select @a;

--echo ##包含in out参数
drop table if exists  t1;
drop table if exists  t2;
drop procedure if exists  p1;
create table t1 (c1 char(20),c2 float(7,2),c3 float(10,5) default 0,c4 float(25,10));
DELIMITER //;
CREATE PROCEDURE p1(OUT a float(10,2),inout b float(30,5) ,in c  float(8,3))
begin
	declare i int;
	SELECT  sum(c1)  FROM t1 into a ;
    set i := 1;
	WHILE i <= 10 do
	insert into t1 values(1.23601,b,23.2122,-1023.662);
	insert into t1 values(1.301,c,23.2222,-1023.62);
	set i := i + 1;
	END while;
END;
//
delimiter ;//
call p1(@a,@b,20.36);
select @a,@b;
SELECT COUNT(*) FROM t1;

--echo ##无参定义存储过程
drop table if exists  t1;
drop procedure if exists  p1;
create table t1 (c1 float(20,6) primary key,c2 float(7,2) not null,c3 float(10,5) default 0,c4 float(25,10));
delimiter //;
create procedure p1()
begin
    insert into t1 values(1.23601,9.996,23.21222,-1023.662);
end
//
delimiter ;//
select count(*) from t1;

call p1();
select * from t1;

--echo ##存储过程用循环
drop table if exists  t1;
drop procedure if exists  p1;
create table t1 (c1 float(20,6),c2 float(7,2) not null,c3 float(10,5) default 0,c4 float(25,10));
delimiter //;
create  PROCEDURE p1(in a float(10,3))
begin
	declare i int;
  	set i := 1;
	WHILE i <= 10 do
	insert into t1 values(1.23601,9.96,23.2122,-1023.662);
	set i := i+1;
	END while;
END;
//
delimiter ;//
CALL p1(10.111);
SELECT COUNT(*)  FROM  t1;


--echo ##定义一个无参的函数
drop table if exists  t1;
drop procedure if exists  p1;
drop function if exists  f1;
create table t1 (c1 float(20,6) primary key,c2 float(7,2) not null,c3 float(10,5) default 0,c4 float(25,10));
insert into t1 values(1.23601,9.96,23.2122,-1023.662);
insert into t1 values(1.301,9.96,23.2222,-1023.62);
insert into t1 values(1.231,9.996,23.21222,-023.662);
delimiter //;
CREATE  FUNCTION f1()
returns float(255,30)
begin
	declare a float(255,30);
	SELECT  sum(c1)  FROM t1 into a ;
	return a;
END
//
delimiter ;//
select f1();

--echo ##定义一个有参的函数	
drop table if exists  t1;
drop procedure if exists  p1;
drop function if exists  f1;
create table t1 (c1 float(20,6) primary key,c2 float(7,2) not null,c3 float(10,5) default 0,c4 float(25,10));
insert into t1 values(1.23601,9.96,23.2122,-1023.662);
insert into t1 values(1.301,9.96,23.2222,-1023.62);
insert into t1 values(1.231,9.996,23.21222,-023.662);
delimiter //;
CREATE  FUNCTION f1(a float(255,10))
returns float(255,30)
begin
	declare a float(255,30);
	SELECT  sum(c1)  FROM t1 into a ;
	return a;
END
//
delimiter ;//
select f1(1.2);


--echo ##定义函数while循环
drop table if exists  t1;
drop function if exists  f1;
create table t1 (c1 float(20,6),c2 float(7,2) not null,c3 float(10,5) default 0,c4 float(25,10));
delimiter //;
CREATE  FUNCTION f1(a  float(20,2),b float(5,2))
returns  float(10,3)
begin
	declare a float(20,2);
	declare b float(5,2);
	declare i int default 0;
	SELECT  sum(c1) FROM t1 into a ;
	SELECT  sum(c2) FROM t1 into b ;
	WHILE i <= 10 do
	insert into t1 values(2.23601,9.96,23.2122,-1023.662);
	set i := i + 1;
	END while;
	return a;
END 
//
delimiter ;//
--error 1264
SELECT  f1(2000,5000);
select count(*) from t1;

--echo ##定义函数repeat循环
drop table if exists  t1;
drop function if exists  f1;
create table t1 (c1 float(20,6),c2 float(7,2) not null,c3 float(10,5) default 0,c4 float(25,10));
delimiter //;
CREATE  FUNCTION f1(a  float(20,2),b float(5,2))
returns  float(10,3)
begin
	declare a float(20,2);
	declare b float(5,2);
	declare i int default 0;
	SELECT  sum(c1) FROM t1 into a ;
	SELECT  sum(c2) FROM t1 into b ;
	repeat 	
	insert into t1 values(1.23601,9.96,23.2122,-1023.662);
	insert into t1 values(1.301,9.96,23.2222,-1023.62);
	set i := i + 1;
	until i >= 10	
	end	 repeat;
	return a;
END
//
delimiter ;//
SELECT  f1(20.1,220.1)  FROM  dual;
SELECT COUNT(*) FROM t1; 

--echo ##定义函数loop循环
drop table if exists  t1;
drop function if exists  f1;
create table t1 (c1 float(20,6),c2 float(7,2) not null,c3 float(10,5) default 0,c4 float(25,10));
delimiter //;
CREATE  FUNCTION f1(samplename varchar(200),samplename1 varchar(200))
returns  varchar(200)
BEGIN
	declare a float(20,2);
	declare b float(5,2);
	declare i int default 0;
	SELECT  sum(c1) FROM t1 into a ;
	SELECT  sum(c2) FROM t1 into b ;
	
	c : loop
	set i := i + 1;
	insert into t1 values(1.23601,9.96,23.2122,-1023.662);
	insert into t1 values(1.301,9.96,23.2222,-1023.62);
	if i > 10 then
	leave c;
	end if;
	end loop;
	return b;
END
//
delimiter ;//
SELECT  f1(5000,9111)  FROM  dual;
SELECT COUNT(*) FROM t1;


--echo ##insert触发器
drop table if exists t1;
drop table if exists t2;
drop trigger if exists tr1;
drop function if exists  f1;
create table t1 (c1 float(7,2) primary key, c2 float(8,3)) default charset='utf8';
insert into t1 values(999.9,12.123);
create table t2 (a1 float(7,2) primary key, a2 float(8,3)) default charset='utf8';
insert into t2 values(999.9,12.123);
DELIMITER //;
create trigger tr1
before insert on t1
for each row 
begin
	declare a float(20,2);
	SELECT  sum(a1) FROM t2 into a ;
	set @a=a;
end
//
DELIMITER ;//
insert into t1 values(99.9,12.123);
select @a;

--echo ##update触发器
drop table if exists t1;
drop table if exists t2;
drop trigger if exists tr1;
drop function if exists  f1;
create table t1 (c1 float(7,2) primary key, c2 float(8,3)) default charset='utf8';
insert into t1 values(999.9,12.123);
create table t2 (a1 float(7,2) primary key, a2 float(8,3)) default charset='utf8';
insert into t2 values(999.9,12.123);
DELIMITER //;
create trigger tr1
before update on t1
for each row 
begin
	declare a float(20,2);
	SELECT  sum(a1) FROM t2 into a ;
	set @a=a;
end
//
DELIMITER ;//
update t1 set c1=99.9 where c2=12.123;
select @a;

--echo ##delete触发器
drop table if exists t1;
drop table if exists t2;
drop trigger if exists tr1;
drop function if exists  f1;
create table t1 (c1 float(7,2) primary key, c2 float(8,3)) default charset='utf8';
insert into t1 values(999.9,12.123);
create table t2 (a1 float(7,2) primary key, a2 float(8,3)) default charset='utf8';
insert into t2 values(999.9,12.123);
DELIMITER //;
create trigger tr1
before delete on t1
for each row 
begin
	declare a float(20,2);
	set a = '999';
	update t2 set a1=a where a2=12.123;
end
//
DELIMITER ;//
delete from t1;
select @a;

--echo ##赋值为布尔值
drop table if exists  t1;
drop table if exists  t2;
drop procedure if exists  p1;
create table t1 (c1 float(7,2) primary key,c2 float(255,30));
DELIMITER //;
CREATE  PROCEDURE p1()
begin
	DECLARE a float(54,25);
	DECLARE b float(54,25);
	set a = true;
	set b = false;
	insert into t1 VALUES(a,b);
end//
DELIMITER ;//
call p1();
select * from t1;

--echo ##赋值为字符类型
drop table if exists  t1;
drop table if exists  t2;
drop procedure if exists  p1;
create table t1 (c1 float(7,2) primary key,c2 float(255,30));
DELIMITER //;
CREATE  PROCEDURE p1()
begin
	DECLARE a char(10);
	DECLARE b varchar(50);
	set a = '8.295002';
	set b = '9.555512002';
	insert into t1 VALUES(a,b);
end//
DELIMITER ;//
call p1();
select sum(c1) from t1;

--echo ##赋值为数值类型
drop table if exists  t1;
drop table if exists  t2;
drop procedure if exists  p1;
create table t1 (c1 float(7,2) primary key,c2 float(255,30));
DELIMITER //;
CREATE  PROCEDURE p1()
begin
	DECLARE a int;
	DECLARE b float(10,3);
	set a = 99999;
	set b = 9.555512002;
	insert into t1 VALUES(a,b);
end//
DELIMITER ;//
call p1();
select * from t1;

--echo ##赋值为日期类型
drop table if exists  t1;
drop table if exists  t2;
drop procedure if exists  p1;
create table t1 (c1 float(20,2) primary key,c2 float(255,30));
DELIMITER //;
CREATE  PROCEDURE p1()
begin
	DECLARE a date;
	DECLARE b datetime;
	set a = '2022-12-12';
	set b = '2022-12-12 09:12:59';
	insert into t1 VALUES(a,b);
end//
DELIMITER ;//
call p1();
select * from t1;

--echo ##赋值为大对象类型
drop table if exists  t1;
drop table if exists  t2;
drop procedure if exists  p1;
create table t1 (c1 float(20,2) primary key,c2 float(255,30));
DELIMITER //;
CREATE  PROCEDURE p1()
begin
	DECLARE a blob;
	DECLARE b text;
	set a = '99.529';
	set b = '9.9';
	insert into t1 VALUES(a,b);
end//
DELIMITER ;//
call p1();
select * from t1;


--echo  ########清空回收站，删除测试数据库，表等 ##########
--disable_warnings
drop database  IF EXISTS db1;