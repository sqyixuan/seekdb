--disable_warnings
drop database  IF EXISTS  db1;
--enable_warnings
create database db1;
use db1;

SET wait_timeout=30000000;
SET ob_trx_timeout = 30000000;
SET ob_query_timeout = 30000000;

--echo ##设置相同sql_mode;
SET @@sql_mode='STRICT_TRANS_TABLES,NO_ENGINE_SUBSTITUTION,no_zero_date,no_zero_in_date,PIPES_AS_CONCAT';

--echo ##DML操作
--echo ##select
--echo ##create as select 
drop table if exists  t1;
drop table if exists  t2;
create table t1 (c1 float(7,2),c2 float(8,2),c3 float(10,5),c4 float(255,30));
insert into t1 values(-1023.909,11.591,2.222,-12.123),(123.5,11.5995,556.02,22.45),(-123.5,11.5995,556.1102,22.999909),(null,0,1.234567894562,10.0000000000002);
create table t2 as select distinct c2 from t1 where c2>=11.60;
select * from t2;
desc t2;

--echo ##聚合函数
drop table if exists  t1;
drop table if exists  t2;
create table t1 (c1 float(7,2),c2 float(8,2),c3 float(10,5),c4 float(255,30));
insert into t1 values(-1023.909,11.591,2.222,-12.123),(123.5,11.5995,556.02,22.45),(-123.5,11.5995,556.1102,22.999909),(null,0,1.234567894562,10.0000000000002);
create table t2 as select min(c1) a from t1;
desc t2;
create table t3 as select max(c1) a from t1;
desc t3;
create table t4 as select avg(c1) a from t1;
desc t4;
create table t5 as select sum(c1) a from t1;
desc t5;
create table t6 as select count(c1) a from t1;
desc t6; 
drop table if exists  t1;
drop table if exists  t2;
drop table if exists  t3;
drop table if exists  t4;
drop table if exists  t5;
drop table if exists  t6;

--echo ##where子句
--echo ##=,<,<=,>=,<>
drop table if exists  t1;
drop table if exists  t2;
create table t1 (c1 float(7,2),c2 float(8,2),c3 float(10,5),c4 float(255,30));
insert into t1 values(-1023.909,11.591,2.222,-12.123),(123.5,11.5995,556.02,22.45),(-123.5,11.5995,556.1102,22.999909),(null,0,1.234567894562,10.0000000000002);
--sorted_result 
select c1 from t1 where c1='-1023.91';
--sorted_result 
select c1 from t1 where c1>123.5;
--sorted_result 
select c1 from t1 where c1<-123.5;
--sorted_result 
select c1 from t1 where c1<=-123.5;
--sorted_result 
select c1 from t1 where c1>=-123.5;
create table t2 as select c1 from t1 where c1<>-123.5;
desc t2;

--echo ##and or
drop table if exists  t1;
drop table if exists  t2;
create table t1 (c1 float(7,2),c2 float(8,2),c3 float(10,5),c4 float(255,30));
insert into t1 values(-1023.909,11.591,2.222,-12.123),(123.5,11.5995,556.02,22.45),(-123.5,11.5995,556.1102,22.999909),(null,0,1.234567894562,10.0000000000002);
--sorted_result 
select min(c1) from t1 where c2=11.6 and c1 is not null and c3 !=556.11023 ;
--sorted_result 
select min(c1) from t1 where c2=11.6 or c1 is not null or c3 !=556.11023 ;
--sorted_result 
select min(c1) from t1 where c2=11.6 and c1 is not null or c3 !=556.11023 ;
create table t2 as select min(c1) from t1 where c2=11.6 or c1 is null and c3 !=556.11023;
desc t2 ;

--echo ##between and 
drop table if exists  t1;
drop table if exists  t2;
create table t1 (c1 float(7,2),c2 float(8,2),c3 float(10,5),c4 float(255,30));
insert into t1 values(-1023.909,11.591,2.222,-12.123),(123.5,11.5995,556.02,22.45),(-123.5,11.5995,556.1102,22.999909),(null,0,1.234567894562,10.0000000000002);
--sorted_result 
select c1 from t1 where c1 between  -1023.91 and 123.5;
--sorted_result 
select c1 from t1 where c2 between 11.59 and 11.60;
create table t2 as select c1 from t1 where c1 between  -1023.91 and 123.5;
desc t2 ;

--echo ##like,not like
drop table if exists  t1;
drop table if exists  t2;
create table t1 (c1 float(7,2),c2 float(8,2),c3 float(10,5),c4 float(255,30));
insert into t1 values(-1023.909,11.591,2.222,-12.123),(123.5,11.5995,556.02,22.45),(-123.5,11.5995,556.1102,22.999909),(null,0,1.234567894562,10.0000000000002);
select min(c1) from t1 where c2 like '%1%' and c1 like '%5%';
select min(c1) from t1 where c2 like '%1%' and c1 not like '%5%';
create table t2 as select min(c1) a from t1 where c2 like '%1%' and c1 not like '%5%';
desc t2 ;

--echo ##exists,any,all,in
drop table if exists  t1;
drop table if exists  t2;
create table t1 (c1 float(7,3),c2 float(8,2),c3 float(10,5),c4 float(255,30));
insert into t1 values(-1023.909,11.591,2.222,-12.123),(123.5,11.5995,556.02,22.45),(-123.5,11.5995,556.1102,22.999909),(null,0,1.234567894562,10.0000000000002);
create table t2 (a1 float(7,3),a2 float(8,2));
insert into t2 values(-1023.908,11.591),(123.5,11.5995),(-123.5,11.5995);
select avg(c1) from t1 where exists(select a2 from t2) limit 1;
select avg(c1) from t1 where -1023.909 < any (select a1 from t2) limit 1;
select avg(c1) from t1 where -1023.909 < all(select a1 from t2) limit 1;
select avg(c1) from t1 where -1023.908 in (select a1 from t2) ;

--echo ##多表join
--echo ##inner join (float+int)
drop table if exists  t1;
drop table if exists  t2;
drop table if exists  t3;
create table t1 (c1 float(7,3),c2 float(8,2),c3 float(10,5),c4 float(255,30));
insert into t1 values(-1023.909,11.591,2.222,-12.123),(123.5,11.5995,556.02,22.45),(-123.5,11.5995,556.1102,22.999909),(null,0,1.234567894562,10.0000000000002);
create table t2 (a1 int,a2 int,a3 int,a4 int);
insert into t2 values(-1023.909,11.59,2.222,-12.123),(123.5,11.60,556.02,22.45),(-123.5,11.5995,556.1102,22.999909),(null,0,1.234567894562,10.0000000000002);
--echo ##此处BUG,不显示结果--已修复
--sorted_result 
select * from t1 inner join t2 on t1.c4=t2.a4;
create table t3 as select * from t1 inner join t2 on t1.c4=t2.a4;
desc t3;

--echo ##inner join (float+float)
drop table if exists  t1;
drop table if exists  t2;
drop table if exists  t3;
create table t1 (c1 float(7,3),c2 float(8,2),c3 float(10,5),c4 float(255,30));
insert into t1 values(-1023.909,11.591,2.222,-12.123),(123.5,11.5995,556.02,22.45),(-123.5,11.5995,556.1102,22.999909),(null,0,1.234567894562,10.0000000000002);
create table t2 (a1 float(7,3),a2 float(8,2),a3 float(10,5),a4 float(255,30));
insert into t2 values(-1023.909,11.59,2.222,-12.123),(123.5,11.60,556.02,22.45),(-123.5,11.5995,556.1102,22.999909),(null,0,1.234567894562,10.0000000000002);
--sorted_result 
select * from t1 inner join t2 on t1.c4=t2.a4;
create table t3 as select * from t1 inner join t2 on t1.c4=t2.a4 ;
desc t3;

--echo ##left join (float+int)
drop table if exists  t1;
drop table if exists  t2;
drop table if exists  t3;
create table t1 (c1 float(7,3),c2 float(8,2),c3 float(10,5),c4 float(255,30));
insert into t1 values(-1023.909,11.591,2.222,-12.123),(123.5,11.5995,556.02,22.45),(-123.5,11.5995,556.1102,22.999909),(null,0,1.234567894562,10.0000000000002);
create table t2 (a1 int,a2 int,a3 int,a4 int);
insert into t2 values(-1023.909,11.59,2.222,-12.123),(123.5,11.60,556.02,22.45),(-123.5,11.5995,556.1102,22.999909),(null,0,1.234567894562,10.0000000000002);
--sorted_result 
select /*+use_nl(t1 t2)*/a2,a3,a4 from t1 left join t2 on t1.c4=t2.a4 order by  c1;
--sorted_result 
select a2,a3,a4 from t1 left join t2 on t1.c4=t2.a4 order by  c1;
create table t3 as select a2,a3,a4 from t1 left join t2 on t1.c4=t2.a4 order by t1.c3;
desc t3;

--echo ##left join (float+float)
drop table if exists  t1;
drop table if exists  t2;
drop table if exists  t3;
create table t1 (c1 float(7,3),c2 float(8,2),c3 float(10,5),c4 float(255,30));
insert into t1 values(-1023.909,11.591,2.222,-12.123),(123.5,11.5995,556.02,22.45),(-123.5,11.5995,556.1102,22.999909),(null,0,1.234567894562,10.0000000000002);
create table t2 (a1 float(7,3),a2 float(8,2),a3 float(10,5),a4 float(255,30));
insert into t2 values(-1023.909,11.59,2.222,-12.123),(123.5,11.60,556.02,22.45),(-123.5,11.5995,556.1102,22.999909),(null,0,1.234567894562,10.0000000000002);
--sorted_result 
select a2,a3,a4 from t1 left join t2 on t1.c4=t2.a4 order by  c1;
