--echo #组合索引
drop table if exists  t1;
drop table if exists  t2;
create table t1 (c1 float(7,2),c2 float(8,3),c3 float(10,5),c4 float(255,30));
create index index_c1 on t1(c1,c2);
desc t1;
create table t2 as select max(c1) a from t1;
desc t2;


