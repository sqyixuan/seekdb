--disable_warnings
drop database  IF EXISTS  db1;
--enable_warnings
create database db1;
use db1;

SET wait_timeout=30000000;
SET ob_trx_timeout = 30000000;
SET ob_query_timeout = 30000000;

--echo ##设置相同sql_mode;
SET @@sql_mode='STRICT_TRANS_TABLES,NO_ENGINE_SUBSTITUTION,no_zero_date,no_zero_in_date,PIPES_AS_CONCAT';

--echo ##常量值（M，D）设置
drop table if exists  t1;
create table t1 (c1 double(10,2));
desc t1;
insert into t1 values(10.199);
select * from t1;


drop table if exists  t1;
create table t1 (c1 double(255,30));
insert into t1 values(123456789123456789123456789123456789123);
insert into t1 values(1234567891234567891234567891234567891234);
desc t1;
select * from t1;

drop table if exists  t1;
create table t1 (c1 double(100,15));
insert into t1 values(123456789123456789123456789123456789123);
insert into t1 values(1234567891234567891234567891234567891234);
desc t1;
select * from t1;

--echo 此处bug,MySQL5.7报错 bug地址:
drop table if exists  t1;
--error 1439
create table t1 (c1 double(0,0));

drop table if exists  t1;
create table t1 (c1 double(255,0));
desc t1;
insert into t1 values(10),(10.01);
select * from t1;

drop table if exists  t1;
--error 1427
create table t1 (c1 double(0,30));
--error 1064
