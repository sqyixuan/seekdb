SELECT IFNULL(min(c2),max(c1)) a ,IFNULL(min(c1),max(c2)) b from t1;
create table t2 select IFNULL(min(c2),max(c1)) a ,IFNULL(min(c1),max(c2)) b  from t1;
desc t2;

