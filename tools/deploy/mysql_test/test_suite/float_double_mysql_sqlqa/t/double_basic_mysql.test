insert into t1 values(-1023.909,11.591,2.222,-12.123),(-123.5,11.5995,556.02,22.45),(null,0,1.234567894562,10.0000000000002);
create table t2 select FLOOR(min(c1)) a from t1 ;
select * from t2 where a=-1024.0;
desc t2;
create table t3 select FLOOR(min(c2)) b from t1 ;
select * from t3 where b =0;
desc t3;
create table t4 select FLOOR(min(c3)) c from t1 ;
select * from t4 where c =1.0;
desc t4;
create table t5 select FLOOR(min(c4)) d from t1 ;
select * from t5 where d =-13.0;
desc t5;

