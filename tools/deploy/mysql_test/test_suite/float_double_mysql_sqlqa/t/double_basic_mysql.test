--echo ##字符集测试
--echo ##设置binary
drop table if exists  t1;
create table t1 (c1 double(7,2),c2 double(8,2),c3 double(255,30),c4 double(2,0))default character set binary;
insert into t1 values(1023.909,11.591,2.222,-12.123),(123.5,11.5995,556.02,22.45);
--echo ##此处更新与8.0结果不一致，5.7与OB结果一致;
update t1 set c1=222.021 where c3=2.222;
delete from t1 where c2=11.59 ;
select sum(c1+c2+c3+c4) from t1 ;
desc t1 ;

--echo ##设置utf8mb4
drop table if exists  t1;
create table t1 (c1 double(7,2),c2 double(8,2),c3 double(255,30),c4 double(2,0))default character set utf8mb4;
insert into t1 values(1023.909,11.591,2.222,-12.123),(123.5,11.5995,556.02,22.45);
update t1 set c1=222.021 where c3=2.222;
delete from t1 where c2=11.59 limit 1;
select sum(c1+c2+c3+c4) from t1 ;
desc t1 ;

--echo ##设置gbk
drop table if exists  t1;
create table t1 (c1 double(7,2),c2 double(8,2),c3 double(255,30),c4 double(2,0))default character set gbk;
insert into t1 values(1023.909,11.591,2.222,-12.123),(123.5,11.5995,556.02,22.45);
update t1 set c1=222.021 where c3=2.222;
delete from t1 where c2=11.59 limit 1;
select sum(c1+c2+c3+c4) from t1 ;
desc t1 ;

--echo ##设置gb18030
drop table if exists  t1;
create table t1 (c1 double(7,2),c2 double(8,2),c3 double(255,30),c4 double(2,0))default character set gb18030;
insert into t1 values(1023.909,11.591,2.222,-12.123),(123.5,11.5995,556.02,22.45);
update t1 set c1=222.021 where c3=2.222;
delete from t1 where c2=11.59 limit 1;
select sum(c1+c2+c3+c4) from t1 ;
desc t1 ;


