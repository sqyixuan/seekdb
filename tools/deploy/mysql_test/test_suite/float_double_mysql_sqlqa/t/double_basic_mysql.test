--echo ##日期时间函数
drop table if exists  t1;
drop table if exists  t2;
create table t1 (c1 float(7,2),c2 float(8,2),c3 float(10,5),c4 float);
insert into t1 values(1023.909,11.591,2.222,-12.123),(123.5,11.5995,556.02,22.45);
#select CURRENT_TIME()+c1 from t1;
#select CURRENT_TIMESTAMP()+c1 from t1;
--sorted_result 
SELECT DATE_ADD('2022-10-31 23:59:59',INTERVAL c1 SECOND)  from t1;
--sorted_result 
SELECT DATE_FORMAT('2017-11-15 21:45:00','%y')+c1  from t1;
--sorted_result 
SELECT DATE_SUB('2018-01-02',INTERVAL c1 DAY) from t1;
--sorted_result 
SELECT DATEDIFF('2017-11-30','2017-11-29')+c4  from t1;
--sorted_result 
SELECT EXTRACT(SECOND from c1)  from t1;
--sorted_result 
SELECT from_days(c1)  from t1;
--sorted_result 
SELECT FROM_UNIXTIME(c1)  from t1;
--sorted_result 
SELECT month(c1)  from t1;
#SELECT now()+c1  from t1;
--sorted_result 
SELECT PERIOD_DIFF(c1,c2)  from t1;
--sorted_result 
SELECT STR_TO_DATE('25,5,2022','%d,%m,%Y')+c1 from t1;
--sorted_result 
SELECT time(c1) from t1;
--error 5110
SELECT TIME_TO_USEC(c1) from t1;
--error 1582
SELECT TIMEDIFF(c1) from t1;
--sorted_result 
SELECT to_days(c1) from t1;
--sorted_result 
SELECT year(c1) from t1;
--error 1582
SELECT UNIX_TIMESTAMP(c1,c2) from t1;

--echo ##字符串函数
drop table if exists  t1;
drop table if exists  t2;
create table t1 (c1 double(7,2),c2 double(8,2),c3 double(10,5),c4 double);
insert into t1 values(1023.909,11.591,2.222,-12.123),(123.5,11.5995,556.02,22.45),(null,0,1.234567894562,10.0000000000002);
select CONCAT(max(c1),max(c2),max(c3)) from t1;
select CONCAT_WS(c1,c2,c3,c4) from t1;
select format(max(c1),15),format(min(c3),15) from t1;
select format(max(c1),0),format(min(c3),0) from t1;
select SUBSTR(max(c1) from 1 for 2) from t1;
select SUBSTR(min(c1),1) from t1;
select SUBSTR(c1,max(c1)-1022.91,22) from t1;
select SUBSTRING(max(c1) from 1 for 2) from t1;
select SUBSTRING(min(c1),1) from t1;
select SUBSTRING(c1,max(c1)-1022.91,22) from t1;
SELECT TRIM(LEADING '1' FROM max(c1)) from t1;
SELECT TRIM(BOTH '12' FROM min(c1)) from t1;
SELECT TRIM(TRAILING '.91' FROM max(c1)) from t1;
SELECT concat(LTRIM(' c 1 '),max(c1)) from t1;
SELECT concat(RTRIM(' c 1 '),max(c1)) from t1;
SELECT ascii(min(c2)) from t1;
SELECT ord(min(c2)) from t1;
SELECT length(concat(min(c2),c1,c3,c4))from t1;
SELECT CHAR_length(concat(min(c2),c1,c3,c4))from t1;
SELECT UPPER(concat(min(c2),c1,c3,c4))from t1;
SELECT lower(concat(min(c2),c1,c3,c4))from t1;
SELECT HEX(concat(min(c2),c1,c3,c4))from t1;
SELECT UNHEX(concat(min(c2),c1,c3,c4))from t1;
SELECT MD5(concat(min(c2),c1,c3,c4))from t1;
#SELECT INT2IP(concat(min(c2),c1,c3,c4))from t1;
SELECT min(c2) FROM t1 where c1 LIKE '%1%';
SELECT min(c2) FROM t1 where c1 REGEXP '1';
SELECT REPEAT(c1,min(c2)) from t1;
SELECT space(min(c2)) from t1;
SELECT SUBSTRING_INDEX(max(c2),'.',2) from t1;
SELECT LOCATE(max(c2),0) from t1;
SELECT POSITION('.' in max(c1)) from t1;
SELECT instr('%1%',max(c1)) FROM t1;
SELECT REPLACE(max(c1),1023,'咻咻') FROM t1;
SELECT FIELD(max(c1),c2,c3) FROM t1;
SELECT ELT(1,MIN(c1),c2,c3) FROM t1;
SELECT INSERT(MAX(c1),2,3,'咻咻') FROM t1;
SELECT LPAD(MAX(c1),10-1,'咻咻') FROM t1;
SELECT RPAD(MAX(c1),10-1,'咻咻') FROM t1;
SELECT RPAD(MAX(c1),10-1,'咻咻') FROM t1;
SELECT length(uuid()) FROM t1;
SELECT bin(MAX(c1))+c1 FROM t1;
SELECT quote(MAX(c1)) FROM t1;
SELECT REGEXP_SUBSTR(MAX(c1),c1) FROM t1;

