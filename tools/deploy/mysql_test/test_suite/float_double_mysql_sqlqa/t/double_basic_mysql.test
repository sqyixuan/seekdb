--echo ##数学函数
--echo ##ROUND函数
drop table if exists  t1;
drop table if exists  t2;
drop table if exists  t3;
drop table if exists  t4;
drop table if exists  t5;
create table t1 (c1 double(7,2),c2 double(8,2),c3 double(10,5),c4 double(255,30));
insert into t1 values(1023.909,11.591,2.222,-12.123),(123.5,11.5995,556.02,22.45),(null,0,1.234567894562,10.0000000000002);
create table t2 select ROUND(min(c1),2) a from t1 ;
select * from t2 where a =123.5;
desc t2;
create table t3 select ROUND(min(c2),3) b from t1 ;
select * from t3 where b =0;
desc t3;
create table t4 select ROUND(min(c3),10) c from t1 ;
select * from t4 where c =1.234570064;
desc t4;
create table t5 select ROUND(min(c4),6) d from t1 ;
select * from t5 where d =-12.123;
desc t5;


--echo ##CEIL函数
drop table if exists  t1;
drop table if exists  t2;
drop table if exists  t3;
drop table if exists  t4;
drop table if exists  t5;
create table t1 (c1 double(7,2),c2 double(8,2),c3 double(10,5),c4 double(255,30));
insert into t1 values(-1023.909,11.591,2.222,-12.123),(-123.5,11.5995,556.02,22.45),(null,0,1.234567894562,10.0000000000002);
create table t2 select CEIL(min(c1)) a from t1 ;
select * from t2 where a=-1023.0;
desc t2;
create table t3 select CEIL(min(c2)) b from t1 ;
select * from t3 where b =0;
desc t3;
create table t4 select CEIL(min(c3)) c from t1 ;
select * from t4 where c =2.0;
desc t4;
create table t5 select CEIL(min(c4)) d from t1 ;
select * from t5 where d =-12.0;
desc t5;

--echo ##FLOOR函数
