##运算符测试
#算数运算符
drop table t1;
create table t1 (c1 double(7,2),c2 double(8,2),c3 double(10,5),c4 double);
insert into t1 values(1023.909,11.591,2.222,-12.123),(123.5,11.5995,556.02,22.45),(null,0,1.234567894562,10.0000000000002);
create table t2 as select c1+c2 a,c1-c2 b,c1*c2 c,c1/c2 d from t1;
desc t2;
select a+0.02,b+1.09,c+2.36,d+3.00 from t2;
create table t3 as select c2+c3 a,c2-c3 b,c2*c3 c,c2/c3 d from t1;
desc t3;
select a-0.02,b-1.09,c-2.36,d-3.00 from t3;
create table t4 as select c3+c4 a,c3-c4 b,c3*c4 c,c3/c4 d from t1;
desc t4;
select a*0.02,b*1.09,c*2.36,d*3.00 from t4;
create table t5 as select c4+c2 a,c4-c3 b,c4*c2 c,c4/c3 d from t1;
desc t5;
select a/0.02,b/1.09,c/2.36,d/3.00 from t5;
create table t6 as select c1+c2 a,c1-c2 b,c1*c2 c,c1/c2 d from t1;
desc t6;
select a div 0.02,b div 1.09,c div 2.36,d div 3.00 from t6;
create table t7 as select c2+c3 a,c2-c3 b,c2*c3 c,c2/c3 d from t1;
desc t7;
select a mod 0.02,b mod 1.09,c mod 2.36,d mod 3.00 from t7;
create table t8 as select c3+c4 a,c3-c4 b,c3*c4 c,c3/c4 d from t1;
desc t8;
select a % 0.02,b % 1.09,c % 2.36,d % 3.00 from t8;
drop table if exists  t3;
drop table if exists  t4;
drop table if exists  t5;
drop table if exists  t6;
drop table if exists  t7;
drop table if exists  t8;
