##char类型
drop table if exists  t1;
create table t1 (c1 double(7,2),c2 double(8,2),c3 double(10,5),c4 double(255,30));
insert into t1 values(1023.909,11.591,2.222,-12.123),(123.5,11.5995,556.02,22.45),(null,0,1.234567894562,10.0000000000002);
create table t2 select cast(min(c1) as char(255)) from t1 ;
create table t3 select cast(min(c2) as char(255)) from t1 ;
create table t4 select cast(min(c3) as char(255)) from t1 ;
create table t5 select cast(min(c4) as char(255)) from t1 ;
