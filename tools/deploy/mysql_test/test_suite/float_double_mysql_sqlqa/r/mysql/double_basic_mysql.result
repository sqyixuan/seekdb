##case和if函数会导致scale丢失;
##流程控制函数
##case
drop table if exists  t1;
drop table if exists  t2;
drop table if exists  t3;
drop table if exists  t4;
drop table if exists  t5;
create table t1 (c1 double(7,2),c2 double(8,2),c3 double(10,5),c4 double(20,10));
insert into t1 values(1023.909,11.591,2.222,-12.123),(-123.5,11.5995,556.02,22.45),(null,0,1.234567894562,10.0000000000002);
select (case when c1 < 400 or c1 is null then max(c1) when c2 =0 then false else max(c4) end ) a from t1;
a
22.4500000000
create table t2 select (case when c1 < 400 or c1 is null then max(c1) when c2 =0 then false else max(c4) end ) a from t1;
desc t2;
Field	Type	Null	Key	Default	Extra
a	double(27,10)	YES		NULL	
##IF函数
drop table if exists  t1;
drop table if exists  t2;
create table t1 (c1 double(7,2),c2 double(8,2),c3 double(10,5),c4 double(20,10));
insert into t1 values(1023.909,11.591,2.222,-12.123),(-123.5,11.5995,556.02,22.45),(null,0,1.234567894562,10.0000000000002);
SELECT IF(min(c1)<max(c2),min(c3),max(c4)) a  from t1;
a
1.2345700000
create table t2 select IF(min(c1)<max(c2),min(c3),max(c4)) a  from t1;
desc t2;
Field	Type	Null	Key	Default	Extra
a	double(27,10)	YES		NULL	
