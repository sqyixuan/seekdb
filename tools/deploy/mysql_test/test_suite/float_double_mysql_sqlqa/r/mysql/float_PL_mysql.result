##包含in out参数
drop table if exists  t1;
drop table if exists  t2;
Warnings:
Note	1051	Unknown table 'db1.t2'
drop procedure if exists  p1;
create table t1 (c1 char(20),c2 float(7,2),c3 float(10,5) default 0,c4 float(25,10));
CREATE PROCEDURE p1(OUT a float(10,2),inout b float(30,5) ,in c  float(8,3))
begin
declare i int;
SELECT  sum(c1)  FROM t1 into a ;
set i := 1;
WHILE i <= 10 do
insert into t1 values(1.23601,b,23.2122,-1023.662);
insert into t1 values(1.301,c,23.2222,-1023.62);
set i := i + 1;
END while;
END;
//
call p1(@a,@b,20.36);
select @a,@b;
@a	@b
NULL	NULL
SELECT COUNT(*) FROM t1;
COUNT(*)
20
