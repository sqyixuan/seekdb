##存储过程用循环
drop table if exists  t1;
drop procedure if exists  p1;
create table t1 (c1 float(20,6),c2 float(7,2) not null,c3 float(10,5) default 0,c4 float(25,10));
create  PROCEDURE p1(in a float(10,3))
begin
declare i int;
set i := 1;
WHILE i <= 10 do
insert into t1 values(1.23601,9.96,23.2122,-1023.662);
set i := i+1;
END while;
END;
//
CALL p1(10.111);
SELECT COUNT(*)  FROM  t1;
COUNT(*)
10
##定义一个无参的函数
drop table if exists  t1;
drop procedure if exists  p1;
drop function if exists  f1;
create table t1 (c1 float(20,6) primary key,c2 float(7,2) not null,c3 float(10,5) default 0,c4 float(25,10));
insert into t1 values(1.23601,9.96,23.2122,-1023.662);
insert into t1 values(1.301,9.96,23.2222,-1023.62);
insert into t1 values(1.231,9.996,23.21222,-023.662);
CREATE  FUNCTION f1()
returns float(255,30)
begin
declare a float(255,30);
SELECT  sum(c1)  FROM t1 into a ;
return a;
END
//
select f1();
f1()
3.768009901046753000000000000000
##定义一个有参的函数	
drop table if exists  t1;
drop procedure if exists  p1;
drop function if exists  f1;
create table t1 (c1 float(20,6) primary key,c2 float(7,2) not null,c3 float(10,5) default 0,c4 float(25,10));
insert into t1 values(1.23601,9.96,23.2122,-1023.662);
insert into t1 values(1.301,9.96,23.2222,-1023.62);
insert into t1 values(1.231,9.996,23.21222,-023.662);
CREATE  FUNCTION f1(a float(255,10))
returns float(255,30)
begin
declare a float(255,30);
SELECT  sum(c1)  FROM t1 into a ;
return a;
END
//
select f1(1.2);
f1(1.2)
3.768009901046753000000000000000
##定义函数while循环
drop table if exists  t1;
drop function if exists  f1;
create table t1 (c1 float(20,6),c2 float(7,2) not null,c3 float(10,5) default 0,c4 float(25,10));
CREATE  FUNCTION f1(a  float(20,2),b float(5,2))
returns  float(10,3)
begin
declare a float(20,2);
declare b float(5,2);
declare i int default 0;
SELECT  sum(c1) FROM t1 into a ;
SELECT  sum(c2) FROM t1 into b ;
WHILE i <= 10 do
insert into t1 values(2.23601,9.96,23.2122,-1023.662);
set i := i + 1;
END while;
return a;
END 
//
SELECT  f1(2000,5000);
ERROR 22003: Out of range value for column
select count(*) from t1;
count(*)
0
##定义函数repeat循环
drop table if exists  t1;
drop function if exists  f1;
create table t1 (c1 float(20,6),c2 float(7,2) not null,c3 float(10,5) default 0,c4 float(25,10));
CREATE  FUNCTION f1(a  float(20,2),b float(5,2))
returns  float(10,3)
begin
declare a float(20,2);
declare b float(5,2);
declare i int default 0;
SELECT  sum(c1) FROM t1 into a ;
SELECT  sum(c2) FROM t1 into b ;
repeat 	
insert into t1 values(1.23601,9.96,23.2122,-1023.662);
insert into t1 values(1.301,9.96,23.2222,-1023.62);
set i := i + 1;
until i >= 10	
end	 repeat;
return a;
END
//
SELECT  f1(20.1,220.1)  FROM  dual;
f1(20.1,220.1)
NULL
SELECT COUNT(*) FROM t1;
COUNT(*)
20
##定义函数loop循环
drop table if exists  t1;
drop function if exists  f1;
create table t1 (c1 float(20,6),c2 float(7,2) not null,c3 float(10,5) default 0,c4 float(25,10));
CREATE  FUNCTION f1(samplename varchar(200),samplename1 varchar(200))
returns  varchar(200)
BEGIN
declare a float(20,2);
declare b float(5,2);
declare i int default 0;
SELECT  sum(c1) FROM t1 into a ;
SELECT  sum(c2) FROM t1 into b ;
c : loop
set i := i + 1;
insert into t1 values(1.23601,9.96,23.2122,-1023.662);
insert into t1 values(1.301,9.96,23.2222,-1023.62);
if i > 10 then
leave c;
end if;
end loop;
return b;
END
//
SELECT  f1(5000,9111)  FROM  dual;
f1(5000,9111)
NULL
SELECT COUNT(*) FROM t1;
COUNT(*)
22
##insert触发器
drop table if exists t1;
drop table if exists t2;
Warnings:
Note	1051	Unknown table 'db1.t2'
drop trigger if exists tr1;
Warnings:
Note	1360	Trigger does not exist
drop function if exists  f1;
create table t1 (c1 float(7,2) primary key, c2 float(8,3)) default charset='utf8';
insert into t1 values(999.9,12.123);
create table t2 (a1 float(7,2) primary key, a2 float(8,3)) default charset='utf8';
insert into t2 values(999.9,12.123);
create trigger tr1
before insert on t1
for each row 
begin
declare a float(20,2);
SELECT  sum(a1) FROM t2 into a ;
set @a=a;
end
//
insert into t1 values(99.9,12.123);
select @a;
@a
999.9
##update触发器
drop table if exists t1;
drop table if exists t2;
drop trigger if exists tr1;
Warnings:
Note	1360	Trigger does not exist
drop function if exists  f1;
create table t1 (c1 float(7,2) primary key, c2 float(8,3)) default charset='utf8';
insert into t1 values(999.9,12.123);
create table t2 (a1 float(7,2) primary key, a2 float(8,3)) default charset='utf8';
insert into t2 values(999.9,12.123);
create trigger tr1
before update on t1
for each row 
begin
declare a float(20,2);
SELECT  sum(a1) FROM t2 into a ;
set @a=a;
end
//
update t1 set c1=99.9 where c2=12.123;
select @a;
@a
999.9
##delete触发器
drop table if exists t1;
drop table if exists t2;
drop trigger if exists tr1;
Warnings:
Note	1360	Trigger does not exist
drop function if exists  f1;
create table t1 (c1 float(7,2) primary key, c2 float(8,3)) default charset='utf8';
insert into t1 values(999.9,12.123);
create table t2 (a1 float(7,2) primary key, a2 float(8,3)) default charset='utf8';
insert into t2 values(999.9,12.123);
create trigger tr1
before delete on t1
for each row 
begin
declare a float(20,2);
set a = '999';
update t2 set a1=a where a2=12.123;
end
//
delete from t1;
select @a;
@a
999.9
