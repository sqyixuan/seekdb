--echo obmysql-greatest-6
--echo obmysql-greatest-6-1

SELECT GREATEST(GREATEST(consumer,price),datetime1) FROM t1;
SELECT GREATEST(GREATEST(GREATEST(consumer,price),datetime1),datetime2) FROM t1;

SELECT SUM(GREATEST(price,sal)) FROM t1 ORDER BY id;
SELECT GREATEST(sal,SUM(price)) FROM t1 ORDER BY id;
SELECT GREATEST(SUM(sal),SUM(price)) FROM t1 ORDER BY id;


SELECT COUNT(GREATEST(price,sal)) FROM t1 ORDER BY id;
SELECT GREATEST(COUNT(sal),COUNT(price)) FROM t1 ORDER BY id;

SELECT MAX(GREATEST(price,sal)) FROM t1 ORDER BY id;
SELECT GREATEST(MAX(sal),MAX(price)) FROM t1 ORDER BY id;

SELECT MIN(GREATEST(price,sal)) FROM t1 ORDER BY id;
SELECT GREATEST(MIN(sal),MIN(price)) FROM t1 ORDER BY id;

SELECT AVG(GREATEST(price,sal)) FROM t1 ORDER BY id;
SELECT GREATEST(AVG(sal),AVG(price)) FROM t1 ORDER BY id;

SELECT ABS(GREATEST(price,sal)) FROM t1 ORDER BY id;
SELECT GREATEST(ABS(sal),ABS(price)) FROM t1 ORDER BY id;

SELECT CEIL(GREATEST(price,sal)) FROM t1 ORDER BY id;
SELECT GREATEST(CEIL(sal),CEIL(price)) FROM t1 ORDER BY id;

SELECT FLOOR(GREATEST(price,sal)) FROM t1 ORDER BY id;
SELECT GREATEST(FLOOR(sal),FLOOR(price)) FROM t1 ORDER BY id;

SELECT MOD(GREATEST(price,sal),33) FROM t1 ORDER BY id;
SELECT GREATEST(MOD(sal,3),MOD(price,7)) FROM t1 ORDER BY id;


SELECT LENGTH(GREATEST(consumer,datetime1)) FROM t1;
SELECT GREATEST(LENGTH(consumer),LENGTH(datetime1)) FROM t1;


SELECT INSTR(GREATEST(consumer,datetime1),'书') FROM t1;
SELECT GREATEST(INSTR(consumer,'书'),INSTR(datetime1,'2')) FROM t1;


SELECT GREATEST(consumer,CAST(datetime1 AS CHAR(200))) FROM t1;
SELECT CAST(GREATEST(consumer,datetime1) AS CHAR(200)) FROM t1;


