--error 0,1051
DROP TABLE t1;
--error 0,1051
DROP TABLE t2;
--error 0,1051
DROP TABLE t3;
CREATE TABLE t1(id int,consumer char(20), brand varchar(20),sal int);
INSERT INTO t1 VALUES(1,'书局','apple',5000);
INSERT INTO t1 VALUES(2,'微山','xiaomi',4000);
INSERT INTO t1 VALUES(3,'深咖','oppo',3000);
INSERT INTO t1 VALUES(4,'流苏','huawei',6000);

CREATE TABLE t2(id int,model varchar(200),Price int);
INSERT INTO t2 VALUES(1,'apple 12',7000);
INSERT INTO t2 VALUES(2,'xiaomi 9',5000);
INSERT INTO t2 VALUES(3,'oppo findx',6000);
INSERT INTO t2 VALUES(4,'huawei mata30',8000);



--echo obmysql-greatest-3
--echo obmysql-greatest-3-1
#SELECT
SELECT GREATEST(e.id,e.consumer,e.brand,e.sal) FROM t1 e;
SELECT GREATEST(e.consumer,e.id,e.brand,e.sal) FROM t1 e;
SELECT GREATEST(e.sal,p.price) money,GREATEST(e.brand,p.model) model FROM t1 e LEFT JOIN t2 p ON e.id = p.id ORDER BY e.id DESC;
SELECT GREATEST(e.sal,p.price) money,GREATEST(e.brand,p.model) model FROM t1 e RIGHT JOIN t2 p ON e.id = p.id ORDER BY e.id DESC;
SELECT GREATEST(e.sal,p.price) money,GREATEST(e.brand,p.model) model FROM t1 e INNER JOIN t2 p ON e.id = p.id ORDER BY e.id DESC;
SELECT * FROM (SELECT e.id,GREATEST(e.sal,p.price) price,GREATEST(e.brand,p.model)model FROM t1 e LEFT JOIN t2 p ON e.id = p.id ) e ORDER BY e.id;

#ANY
SELECT *  FROM t1 e WHERE GREATEST(e.id,e.sal) = ANY (SELECT GREATEST(p.id,p.price) FROM t2 p ) ORDER BY e.id;
SELECT *  FROM t1 e WHERE GREATEST(e.id,e.sal) < ANY (SELECT GREATEST(p.id,p.price) FROM t2 p) ORDER BY e.id;
SELECT *  FROM t1 e WHERE GREATEST(e.consumer,e.brand,e.sal) > ANY (SELECT GREATEST(p.model,p.price) FROM t2 p) ORDER BY e.id;

#ALL 
SELECT *  FROM t1 e WHERE GREATEST(e.id,e.sal) < ALL (SELECT GREATEST(p.id,p.price) FROM t2 p) ORDER BY e.id;
SELECT *  FROM t1 e WHERE GREATEST(e.consumer,e.brand,e.sal) > ALL (SELECT GREATEST(p.model,p.price) FROM t2 p) ORDER BY e.id;
SELECT *  FROM t1 e WHERE GREATEST(e.id,e.sal) = ALL (SELECT GREATEST(p.id,p.price) FROM t2 p WHERE p.model = 'oppo findx') ORDER BY e.id;

#EXISTS AND NOT EXISTS
SELECT *  FROM t1 e WHERE EXISTS (SELECT GREATEST(p.id,p.price) FROM t2 p ) ORDER BY e.id;
SELECT *  FROM t1 e WHERE EXISTS (SELECT GREATEST(p.model,p.price) FROM t2 p) ORDER BY e.id;
SELECT *  FROM t1 e WHERE EXISTS (SELECT GREATEST(p.model,p.id,p.price) FROM t2 p) ORDER BY e.id;

SELECT GREATEST(e.consumer,e.brand,e.sal)  FROM t1 e WHERE NOT EXISTS (SELECT p.id,p.price FROM t2 p WHERE GREATEST(p.id,p.price) = 7500 ) ORDER BY e.id;
SELECT GREATEST(e.consumer,e.brand,e.sal)  FROM t1 e WHERE NOT EXISTS (SELECT p.id,p.price FROM t2 p WHERE GREATEST(p.model,p.price) = 'apple 12' ) ORDER BY e.id;
SELECT GREATEST(e.consumer,e.brand,e.sal)  FROM t1 e WHERE NOT EXISTS (SELECT p.id,p.price FROM t2 p WHERE GREATEST(p.model,p.price) = 'apple 12 ' ) ORDER BY e.id;


#CREATE AS 
CREATE TABLE t3 AS SELECT GREATEST(e.consumer,e.brand)  FROM t1 e WHERE GREATEST(e.id,e.sal) = 6000;
select * from t3;
drop table t3;
CREATE TABLE t3 AS SELECT GREATEST(e.consumer,e.brand)name  FROM t1 e WHERE GREATEST(e.id,e.sal) = 6000;
SELECT *  FROM t3;


#WITH AS SELECT
#-- WITH 
#-- a AS (SELECT e.id,GREATEST(e.id,e.sal) FROM t1 e WHERE GREATEST(e.id,e.sal) > 4000),
#-- b AS (SELECT p.id,GREATEST(p.id,p.price) FROM t2 p WHERE GREATEST(p.id,p.price) >5000)
#-- SELECT *  FROM a,b WHERE a.id = b.id;
#-- 
#-- 
#-- WITH 
#-- a AS (SELECT * FROM t1 e WHERE GREATEST(e.id,e.sal) > 4000),
#-- b AS (SELECT * FROM t2 p WHERE GREATEST(p.id,p.price) >5000)
#-- SELECT *  FROM a,b WHERE a.id = b.id;


#LIKE 
SELECT GREATEST(e.brand,e.consumer) FROM t1 e WHERE GREATEST(e.brand,e.consumer) LIKE '%山%';
SELECT GREATEST(e.sal,p.price) FROM t1 e LEFT JOIN t2 p ON e.id = p.id WHERE GREATEST(e.sal,p.price) LIKE '%00%';

#WHERE
SELECT * FROM t1 e WHERE GREATEST(e.consumer,e.brand) = '书局';
SELECT * FROM t1 e WHERE GREATEST(e.consumer,e.brand) = '书局                ';
SELECT * FROM t1 e WHERE GREATEST(e.id,e.sal) > 4000 ORDER BY e.id;
SELECT * FROM t1 e WHERE GREATEST(e.id,e.sal) < 5000 ORDER BY e.id;
SELECT * FROM t1 e WHERE GREATEST(e.id,e.sal) = 3000 ORDER BY e.id;


#ORDER BY 
SELECT e.id,GREATEST(e.brand,e.consumer) FROM t1 e WHERE GREATEST(e.id,e.sal) > 4000 ORDER BY GREATEST(e.id,e.sal);
SELECT e.id,GREATEST(e.brand,e.consumer) FROM t1 e WHERE GREATEST(e.id,e.sal) > 4000 ORDER BY GREATEST(e.id,e.sal) DESC;
SELECT e.id,GREATEST(e.brand,e.consumer) FROM t1 e WHERE GREATEST(e.id,e.sal) > 4000 ORDER BY GREATEST(e.brand,e.consumer);
SELECT e.id,GREATEST(e.brand,e.consumer) FROM t1 e WHERE GREATEST(e.id,e.sal) > 4000 ORDER BY GREATEST(e.brand,e.consumer) DESC;




#GROUP BY HAVING
SELECT SUM(GREATEST(e.sal,p.price)) FROM t1 e LEFT JOIN t2 p ON e.id = p.id GROUP BY GREATEST(e.sal,p.price),e.id ORDER BY e.id ;
SELECT SUM(GREATEST(e.sal,p.price)) FROM t1 e LEFT JOIN t2 p ON e.id = p.id GROUP BY GREATEST(e.sal,p.price),e.id HAVING SUM(GREATEST(e.sal,p.price)) > 6000 ORDER BY e.id;



#CASE WHEN
SELECT id,GREATEST(consumer,brand,CASE WHEN sal < 4000 THEN NULL ELSE sal END) name FROM t1 ORDER BY id;
SELECT id,CASE GREATEST(id,sal) WHEN 3000 THEN '低' WHEN 4000 THEN '一般' ELSE '高' END FROM t1 ORDER BY id; 
SELECT (CASE GREATEST(id,sal) WHEN 3000 THEN '低' WHEN 4000 THEN '一般' ELSE '高' END) FROM t1 GROUP BY (CASE GREATEST(id,sal) WHEN 3000 THEN '低' WHEN 4000 THEN '一般' ELSE '高' END),id ORDER BY id ; 


