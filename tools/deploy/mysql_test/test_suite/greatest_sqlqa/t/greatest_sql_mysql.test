--echo obmysql-greatest-7-1
SELECT GREATEST(price * 10,sal / 21) FROM t1;
SELECT GREATEST(price + 1500,sal - 1000) FROM t1;
SELECT GREATEST(price + 1500 * 10,sal - 1000 *20) FROM t1;
SELECT GREATEST(price * 10 - 10000,sal / 21 + 1000) FROM t1;
SELECT GREATEST(consumer||price, datetime1 || datetime2) FROM t1;

--echo obmysql-greatest-7-2
SELECT GREATEST(price,sal) FROM t1;
SELECT GREATEST(consumer,datetime1) FROM t1;

SELECT id,sal,datetime1 FROM t1 WHERE GREATEST(price,sal) = 7000;
SELECT id,sal,datetime1 FROM t1 WHERE GREATEST(price,sal) < 7000;
SELECT id,sal,datetime1 FROM t1 WHERE GREATEST(price,sal) > 7000;
SELECT id,sal,datetime1 FROM t1 WHERE GREATEST(price,sal) >= 7000;
SELECT id,sal,datetime1 FROM t1 WHERE GREATEST(price,sal) <= 7000;
SELECT id,sal,datetime1 FROM t1 WHERE GREATEST(price,sal) != 7000;
SELECT id,sal,datetime1 FROM t1 WHERE GREATEST(price,sal) <> 7000;

--echo obmysql-greatest-7-3
SELECT id,sal,datetime1 FROM t1 WHERE GREATEST(price,sal) = 7000 OR  GREATEST(consumer,datetime1) = '深咖                ';
SELECT id,sal,datetime1 FROM t1 WHERE GREATEST(price,sal) = 7000 AND GREATEST(consumer,datetime1) = '书局                ';
SELECT id,sal,datetime1 FROM t1 WHERE GREATEST(price,sal) = 7000  OR  GREATEST(consumer,datetime1) = '深咖                ' AND GREATEST(consumer,datetime1) = '书局                ';




--error 0,1051
drop table t1;



