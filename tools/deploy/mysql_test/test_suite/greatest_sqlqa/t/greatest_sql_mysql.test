CREATE TABLE t1(id int,consumer char(20), brand varchar(20),sal int);
INSERT INTO t1 VALUES(1,'书局','apple',5000);
INSERT INTO t1 VALUES(2,'微山','xiaomi',4000);
INSERT INTO t1 VALUES(3,'深咖','oppo',3000);
INSERT INTO t1 VALUES(4,'流苏','huawei',6000);

CREATE TABLE t2(id int,model varchar(200),Price int);
INSERT INTO t2 VALUES(1,'apple 12',7000);
INSERT INTO t2 VALUES(2,'xiaomi 9',5000);
INSERT INTO t2 VALUES(3,'oppo findx',6000);
INSERT INTO t2 VALUES(4,'huawei mata30',8000);

CREATE VIEW t1_view AS SELECT *  FROM t1;
CREATE VIEW t2_view AS SELECT *  FROM t2;

#SELECT
SELECT GREATEST(e.id,e.consumer,e.brand,e.sal) FROM t1_view e;
SELECT GREATEST(e.consumer,e.id,e.brand,e.sal) FROM t1_view e;
SELECT GREATEST(e.sal,p.price) money,GREATEST(e.brand,p.model) model FROM t1_view e LEFT JOIN t2_view p ON e.id = p.id ORDER BY e.id DESC;
SELECT GREATEST(e.sal,p.price) money,GREATEST(e.brand,p.model) model FROM t1_view e RIGHT JOIN t2_view p ON e.id = p.id ORDER BY e.id DESC;
SELECT GREATEST(e.sal,p.price) money,GREATEST(e.brand,p.model) model FROM t1_view e INNER JOIN t2_view p ON e.id = p.id ORDER BY e.id DESC;
SELECT * FROM (SELECT e.id,GREATEST(e.sal,p.price) price,GREATEST(e.brand,p.model)model FROM t1_view e LEFT JOIN t2_view p ON e.id = p.id ) e ORDER BY e.id;

#ANY
SELECT *  FROM t1_view e WHERE GREATEST(e.id,e.sal) < ANY (SELECT GREATEST(p.id,p.price) FROM t2_view p) ORDER BY e.id;
SELECT *  FROM t1_view e WHERE GREATEST(e.id,e.sal) = ANY (SELECT GREATEST(p.id,p.price) FROM t2_view p ) ORDER BY e.id;
SELECT *  FROM t1_view e WHERE GREATEST(e.consumer,e.brand,e.sal) > ANY (SELECT GREATEST(p.model,p.price) FROM t2_view p) ORDER BY e.id;

#ALL 
SELECT *  FROM t1_view e WHERE GREATEST(e.id,e.sal) < ALL (SELECT GREATEST(p.id,p.price) FROM t2_view p) ORDER BY e.id;
SELECT *  FROM t1_view e WHERE GREATEST(e.consumer,e.brand,e.sal) > ALL (SELECT GREATEST(p.model,p.price) FROM t2_view p) ORDER BY e.id;
SELECT *  FROM t1_view e WHERE GREATEST(e.id,e.sal) = ALL (SELECT GREATEST(p.id,p.price) FROM t2_view p WHERE p.model = 'oppo findx') ORDER BY e.id;


#EXISTS AND NOT EXISTS
SELECT *  FROM t1_view e WHERE EXISTS (SELECT GREATEST(p.id,p.price) FROM t2_view p ) ORDER BY e.id;
SELECT *  FROM t1_view e WHERE EXISTS (SELECT GREATEST(p.model,p.price) FROM t2_view p) ORDER BY e.id;
SELECT *  FROM t1_view e WHERE EXISTS (SELECT GREATEST(p.model,p.id,p.price) FROM t2_view p) ORDER BY e.id;
SELECT GREATEST(e.consumer,e.brand,e.sal)  FROM t1_view e WHERE NOT EXISTS (SELECT p.id,p.price FROM t2_view p WHERE GREATEST(p.id,p.price) = 7500 ) ORDER BY e.id;
SELECT GREATEST(e.consumer,e.brand,e.sal)  FROM t1_view e WHERE NOT EXISTS (SELECT p.id,p.price FROM t2_view p WHERE GREATEST(p.model,p.price) = 'apple 12' ) ORDER BY e.id;
SELECT GREATEST(e.consumer,e.brand,e.sal)  FROM t1_view e WHERE NOT EXISTS (SELECT p.id,p.price FROM t2_view p WHERE GREATEST(p.model,p.price) = 'apple 12 ' ) ORDER BY e.id;


