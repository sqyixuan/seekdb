CREATE TABLE t1(id int,consumer char(20), price varchar(20),sal int,datetime1 datetime,datetime2 bigint);
INSERT INTO t1 VALUES(1,'书局','7000',5000,'2020-09-22 12:11:59',20200923121200);
INSERT INTO t1 VALUES(2,'微山','3000',4000,'2020-09-21 10:11:59',20200921101159);
INSERT INTO t1 VALUES(3,'深咖','5000',3000,'2020-08-21 10:11:59',20190821101159);
INSERT INTO t1 VALUES(4,'流苏','9111',10000,'2020-02-29 10:11:59',20200228101159);

--echo obmysql-greatest-4
--echo obmysql-greatest-4-1
DELIMITER //;





#定义一个无参的函数
--error 0,1305
drop function f_test;//
CREATE  FUNCTION f_test()
returns varchar(200)
begin
	declare a varchar(200);
	SELECT  GREATEST(consumer,datetime1)  FROM t1 e WHERE GREATEST(e.price,e.sal)  = 7000 INTO a;
	return a;
END;
//
#30728768- [greatest函数]ob mysql 模式自定义函数返回类型与mysql不一致
SELECT  f_test();//


#定义一个有参的函数
--error 0,1305
drop function f_test;//
CREATE  FUNCTION f_test(samplename varchar(200))
returns  varchar(200)
begin
	declare a varchar(200);
	SELECT  GREATEST(e.price,e.sal) FROM t1 e WHERE  GREATEST(consumer,datetime1) = samplename into a ;
	return a;
END ;
//

SELECT  f_test('2020-09-22 12:11:59')//


--echo obmysql-greatest-4-1-2
#定义函数用while循环
--error 0,1305
drop function f_test;//
CREATE  FUNCTION f_test(samplename  varchar(200),samplename1 varchar(200))
returns  varchar(200)
begin
	declare a varchar(200);
	declare b varchar(200);
	declare i int default 0;
	SELECT  GREATEST(e.price,e.sal) FROM t1 e WHERE  GREATEST(consumer,datetime1) = samplename into a ;
	SELECT  GREATEST(e.price,e.sal) FROM t1 e WHERE  GREATEST(consumer,datetime1) = samplename1 into b ;
	WHILE i <= 10 do
	INSERT INTO t1 VALUES(5,a,'600',7000,'2020-08-21 10:11:59',20190821101159);
	INSERT INTO t1 VALUES(6,b,'19111',90000,'2020-02-29 10:11:59',20200228101159);
	set i := i + 1;
	END while;
	return a;
END ;
//

SELECT  f_test('2020-09-22 12:11:59','2020-09-21 10:11:59')  FROM  dual;//
select count(*) from t1;//


#定义函数用repeat循环
--error 0,1305
drop function f_test;//
CREATE  FUNCTION f_test(samplename varchar(200),samplename1 varchar(200))
returns  varchar(200)
begin
	declare a varchar(200);
	declare b varchar(200);
	declare i int default 0;
	SELECT  GREATEST(e.price,e.sal) FROM t1 e WHERE  GREATEST(consumer,datetime1) = samplename into a ;
	SELECT  GREATEST(e.price,e.sal) FROM t1 e WHERE  GREATEST(consumer,datetime1) = samplename1 into b ;

	repeat 	
	INSERT INTO t1 VALUES(5,a,'600',7000,'2020-08-21 10:11:59',20190821101159);
	INSERT INTO t1 VALUES(6,b,'19111',90000,'2020-02-29 10:11:59',20200228101159);
	set i := i + 1;
	until i >= 10	
	end	 repeat;
	return a;
END;
//
SELECT  f_test('2020-09-22 12:11:59','2020-09-21 10:11:59')  FROM  dual;//
SELECT COUNT(*) FROM t1; //


#定义函数用loop循环
--error 0,1305
drop function f_test;//
CREATE  FUNCTION f_test(samplename varchar(200),samplename1 varchar(200))
returns  varchar(200)
BEGIN
	declare a varchar(200);
	declare b varchar(200);
	declare i int default 0;
	SELECT  GREATEST(e.price,e.sal) FROM t1 e WHERE  GREATEST(consumer,datetime1) = samplename into a ;
	SELECT  GREATEST(e.price,e.sal) FROM t1 e WHERE  GREATEST(consumer,datetime1) = samplename1 into b ;
	
	lp1 : loop
	set i := i + 1;
	INSERT INTO t1 VALUES(5,a,'600',7000,'2020-08-21 10:11:59',20190821101159);
	INSERT INTO t1 VALUES(6,b,'19111',90000,'2020-02-29 10:11:59',20200228101159);
	if i > 10 then
	leave lp1;
	end if;
	end loop;
	return b;
END;
//

SELECT  f_test('2020-09-22 12:11:59','2020-09-21 10:11:59')  FROM  dual;//
SELECT COUNT(*) FROM t1;//





--echo obmysql-greatest-4-2
--echo obmysql-greatest-4-2-1
#无参的存储过程
--error 0,1305
drop procedure p_test;//
CREATE  PROCEDURE p_test()
begin
	declare a varchar(200);
	declare b varchar(200);
	declare i int default 0;
	SELECT  GREATEST(e.price,e.sal) FROM t1 e WHERE  GREATEST(consumer,datetime1) = '2020-09-22 12:11:59' into a ;
	SELECT  GREATEST(e.price,e.sal) FROM t1 e WHERE  GREATEST(consumer,datetime1) = '2020-09-21 10:11:59' into b ;
	WHILE i <= 10 do
	INSERT INTO t1 VALUES(5,a,'600',7000,'2020-08-21 10:11:59',20190821101159);
	INSERT INTO t1 VALUES(6,b,'19111',90000,'2020-02-29 10:11:59',20200228101159);
	set i := i + 1;
	END while;
END ;
//

SELECT COUNT(*) FROM t1;//
CALL p_test();//
SELECT COUNT(*) FROM t1;//



#只有一个in参数的存储过程
--echo obmysql-greatest-4-2-2
--error 0,1305
drop procedure p_test;//
CREATE PROCEDURE p_test(in samplename  varchar(200))
begin
	declare i int;
	declare a varchar(200);
	declare b varchar(200);
	SELECT  GREATEST(e.price,e.sal) FROM t1 e WHERE  GREATEST(consumer,datetime1) = samplename into a ;
	SELECT  GREATEST(e.price,e.sal) FROM t1 e WHERE  GREATEST(consumer,datetime1) = samplename into b ;
    set i := 1;
   	repeat
	INSERT INTO t1 VALUES(5,a,'600',7000,'2020-08-21 10:11:59',20190821101159);
	INSERT INTO t1 VALUES(6,b,'19111',90000,'2020-02-29 10:11:59',20200228101159);
	set i := i+1;
	until i >= 10	
	end	 repeat;
END ;
//

SELECT COUNT(*) FROM t1; //
CALL p_test('2020-09-22 12:11:59'); //
SELECT COUNT(*) FROM t1;//




#包含out参数的存储过程
--echo obmysql-greatest-4-2-3
--error 0,1305
drop procedure p_test;//
CREATE  PROCEDURE p_test(out wb  varchar(200),OUT wb1  varchar(200))
begin
	declare i int;
	SELECT  GREATEST(e.price,e.sal) FROM t1 e WHERE  GREATEST(consumer,datetime1) = '2020-09-22 12:11:59' into wb;
	SELECT  GREATEST(e.price,e.sal)	FROM t1 e WHERE  GREATEST(consumer,datetime1) = '2020-09-21 10:11:59' into wb1 ;
   	set i :=  1; 
	while i <= 10 do
	INSERT INTO t1 VALUES(5,'哈哈哈','600',7000,'2020-08-21 10:11:59',20190821101159);
	set i := i + 1;
	end while;
END;
//

SELECT COUNT(*) FROM t1;//
call p_test(@wb,@wb1);//
SELECT COUNT(*) FROM t1;//



#包含in out参数的存储过程
--echo obmysql-greatest-4-2-4
--error 0,1305
drop procedure p_test;//
CREATE  PROCEDURE p_test( out wb varchar(200),inout  wb1 varchar(200))
begin
	declare i int;
	SELECT  GREATEST(e.price,e.sal) FROM t1 e WHERE  GREATEST(consumer,datetime1) = '2020-09-22 12:11:59' into wb;
	SELECT  GREATEST(e.price,e.sal)	FROM t1 e WHERE  GREATEST(consumer,datetime1) = '2020-09-21 10:11:59' into wb1;
    set i := 1;
	WHILE i <= 10 do
	INSERT INTO t1 VALUES(5,'哈哈哈','600',7000,'2020-08-21 10:11:59',20190821101159);
	set i := i+1;
	END while;
END;
//


call p_test(@wb,@wb1);//
SELECT COUNT(*) FROM t1;//




#in out参数作
--echo obmysql-greatest-4-2-5
--error 0,1305
drop procedure p_test;//
CREATE PROCEDURE p_test(OUT wb varchar(200),inout wb1 int ,in wb2  int)
begin
	declare i int;
	SELECT  GREATEST(e.price,e.sal) FROM t1 e WHERE  GREATEST(consumer,datetime1) = '2020-09-22 12:11:59' into wb;
    set i := 1;
	WHILE i <= 10 do
    INSERT INTO t1 VALUES(5,'哈哈哈','600',wb1,'2020-08-21 10:11:59',20190821101159);
	INSERT INTO t1 VALUES(6,'哦哦哦','19111',wb2,'2020-02-29 10:11:59',20200228101159);
	set i := i + 1;
	END while;
END;
//
SELECT COUNT(*) FROM t1;//
call p_test(@wb,@wb1,80000);//
SELECT COUNT(*) FROM t1;//




#存储过程用循环
--echo obmysql-greatest-4-2-5
--error 0,1305
drop procedure p_test;//
create  PROCEDURE p_test(in wb int)
begin
	declare i int;
  	set i := 1;
	WHILE i <= 10 do
    INSERT INTO t1 VALUES(5,'哈哈哈','600',wb+100,'2020-08-21 10:11:59',20190821101159);
	INSERT INTO t1 VALUES(6,'哦哦哦','19111',wb+2000,'2020-02-29 10:11:59',20200228101159);
	set i := i+1;
	END while;
END;
//

CALL p_test(GREATEST(20,3003,523,5959,2314));//
SELECT COUNT(*)  FROM  t1;//



#存储过程和函数的结果作为参数传递
--echo obmysql-greatest-4-2-6
--error 0,1305
drop function f_test;//
CREATE FUNCTION f_test()
returns int
begin
	declare a int;
	SELECT  GREATEST(e.price,e.sal) FROM t1 e WHERE  GREATEST(consumer,datetime1) = '2020-09-22 12:11:59' into a ;
	RETURN a;
END;
//
SELECT f_test()  FROM  dual;//


--error 0,1305
drop procedure p_test;//
create  PROCEDURE p_test(in wb int)
begin
	declare i int;
  	set i := 1;
	WHILE i <= 10 do
    INSERT INTO t1 VALUES(5,'哈哈哈','600',wb+100,'2020-08-21 10:11:59',20190821101159);
	INSERT INTO t1 VALUES(6,'哦哦哦','19111',wb+2000,'2020-02-29 10:11:59',20200228101159);
	set i := i+1;
	END while;
END;
//
#30728768- [greatest函数]ob mysql 模式自定义函数返回类型与mysql不一致
CALL p_test(f_test());//
SELECT COUNT(*)  FROM t1;//


