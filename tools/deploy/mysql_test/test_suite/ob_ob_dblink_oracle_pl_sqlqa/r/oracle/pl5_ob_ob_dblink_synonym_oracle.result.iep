##############################
## 本地/远程端 pl 对象间嵌套，有多个事务操作，部分成功/失败，验证事务回滚情况
## 连接远程ob端 dblink_tenant1
set autocommit = off;

drop table tnt1_tab1;
create table tnt1_tab1 (id int not null unique, c1 number,c2 varchar2(400) default '备注');

# 函数
create or replace function tnt1_fun1(p1 number, p2 number) return number is
  new_c1 number;
begin
  select c1 into new_c1 from tnt1_tab1 where id = p1 for update;
  new_c1 := new_c1 + p2;
  update tnt1_tab1 set c1 = new_c1,c2 = '远程 tnt1_fun1 update'where id = p1;
  return new_c1;
end;
$
create or replace function tnt1_fun2(p1 number, p2 number) return number is
begin
  update tnt1_tab1 set c1 = p1+p2,c2 = '远程 tnt1_fun2 update' where id = p1;
  return p1;
  exception
    when no_data_found then
        return 0;
    when others then
        raise;
end;
$
create or replace function tnt1_fun3(p1 number, p2 number) return number is
begin
  update tnt1_tab1 set c1 = p1 - (p2 / 0),c2 = '远程 tnt1_fun3 update' where id = p1;
  return p1;
  exception
    when no_data_found then
        return 0;
    when others then
        raise;
end;
$
# 存储过程
create or replace procedure tnt1_pro1(p1 number,p2 number) is
begin
  insert into tnt1_tab1 values (p1, p1/p2,'远程 tnt1_pro1');
end;
$
create or replace procedure tnt1_pro2(p1 number,p2 number) is
begin
  insert into tnt1_tab1 values (p1+1, p1+p2,'远程 tnt1_pro2');
  insert into tnt1_tab1 values (p1+2, p1+p2+100,'远程 tnt1_pro2');
end;
$
create or replace procedure tnt1_pro3(p1 number,p2 number) is
begin
  insert into tnt1_tab1 values (p1+3, p1/p2/0,'远程 tnt1_pro3');
end;
$

# set autocommit = off;
#### 调用方式
## 连接本地ob端  dblink_tenant2
set autocommit = off;

# 存储过程
create or replace procedure tnt2_pro1(p1 number,p2 number) is
begin
  insert into tnt2_tab1 values (p1, p1/p2,'本地 tnt2_pro1');
  insert into tnt1_tab1@my_link1 values (p1, p1/p2,'本地 tnt2_pro1');
end;
$
create or replace procedure tnt2_pro2(p1 number,p2 number) is
begin
  insert into tnt2_tab1 values (p1+1, p1/p2/0,'本地 tnt2_pro2');
  insert into tnt1_tab1@my_link1 values (p1+1, p1/p2/0,'本地 tnt2_pro2');
end;
$

insert into tnt1_tab1@my_link1 values (1, 1000,'初始 tnt1_tab1');
insert into tnt1_tab1@my_link1 values (2, 1000,'初始 tnt1_tab1');
commit;
select * from tnt1_tab1@my_link1 order by 1,2,3;
+------+------+------------------+
| ID   | C1   | C2               |
+------+------+------------------+
|    1 | 1000 | 初始 tnt1_tab1   |
|    2 | 1000 | 初始 tnt1_tab1   |
+------+------+------------------+

create or replace function tnt2_fun1(p1 number, p2 number) return number is
  id number;
begin
  id := tnt1_fun2@my_link1(p1, p2);
  id := tnt1_fun3@my_link1(p1, p2);
  return id;
end;
/
declare
  result varchar2(100);
begin
  result := tnt2_fun1(1,200);
end;
/
ERROR HY000: divisor is equal to zero
at function WHH_DBLINK.TNT2_FUN1 , line : 5, col : 3
at anonymous block , line : 4, col : 11

rollback;
select * from tnt1_tab1@my_link1 order by 1,2,3;
+------+------+------------------+
| ID   | C1   | C2               |
+------+------+------------------+
|    1 | 1000 | 初始 tnt1_tab1   |
|    2 | 1000 | 初始 tnt1_tab1   |
+------+------+------------------+

create or replace procedure my_pro1(p1 in number,p2 number) is
  v1 number;
begin
  v1 := tnt1_fun2@my_link1(p1, p2);
  v1 := tnt1_fun3@my_link1(p1, p2);
end;
/

call my_pro1(2,200);
