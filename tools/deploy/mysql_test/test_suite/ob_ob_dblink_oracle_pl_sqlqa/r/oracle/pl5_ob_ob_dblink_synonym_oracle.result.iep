drop user whhtest1 cascade;
create user whhtest1 IDENTIFIED BY 123;
grant all on *.* to whhtest1 WITH GRANT OPTION;
grant dba to whhtest1;















#-----------------------------------------------------------------------------
# 测试需求：  OB-oracle到OB-oracle PL dblink 测试
# 测试场景：  5、同义词
#-----------------------------------------------------------------------------
##############################
######## 基础触发器
## 连接远程ob端 dblink_tenant1
set autocommit= on;
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;

#-----------------------------------------------------------------------------
# 远程OB端 dblink_tenant1租户下测试环境准备
#-----------------------------------------------------------------------------
# 表
drop table ori_tab1;
CREATE TABLE ori_tab1 (id int, c1 char(2000) DEFAULT 'ori_tab1',c2 varchar2(4000) DEFAULT '备注');
INSERT INTO ori_tab1 VALUES(1,DEFAULT,DEFAULT);
drop table ori_tab2;
CREATE TABLE ori_tab2 (id int, c1 char (2000) DEFAULT 'ori_tab2',c2 varchar2(4000) DEFAULT '备注');
INSERT INTO ori_tab2 VALUES(1,DEFAULT,DEFAULT);
# 存储过程
create or replace procedure ori_pro1(p1 in varchar default 'ori_pro1',p2 out number,p3 out varchar2,p4 out timestamp) is
begin
  p2 := 2024;
  p3 := p1;
  p4 := to_timestamp('04-06-2024 12:01:33.3333','dd-mm-yyyy hh24:mi:ss.ff');
end;
/
# 函数
create or replace function ori_fun1(p1 number) return number is 
begin
  return p1*2;
end;
/
create or replace function ori_fun2(p1 varchar2) return varchar2 is 
begin
  return upper(p1);
end;
/
create or replace function ori_fun3(p1 timestamp) return timestamp is 
begin
  return next_day(p1,'monday');
end;
/
# 包
create or replace package ori_pck1 is
  a NUMBER;
  b varchar2(200) default 'ori_pck1';
  c timestamp default NULL;
  procedure pack_pro(p1 in out number);
  function pack_func(p1 in number) return number;
end;
/
create or replace package body ori_pck1 is
  procedure pack_pro(p1 in out number) is
  begin
    p1 := p1 *2;
  end;
  function pack_func(p1 in number) return number is
  begin
    a := p1;
    return p1;
  end;
end;
/
# 序列
drop sequence ori_seq1;
ERROR HY000: sequence does not exist
create sequence ori_seq1 start with 500 increment by 1 maxvalue 1000 cycle nocache;
# 同义词
create or replace synonym syn_ori_pro1 for ori_pro1;
create or replace synonym syn_ori_fun1 for ori_fun1;
create or replace synonym syn_ori_fun2 for ori_fun2;
create or replace synonym syn_ori_fun3 for ori_fun3;
create or replace synonym syn_ori_pck1 for ori_pck1;
create or replace synonym syn_ori_seq1 for ori_seq1;
declare
  v1 varchar2(200) default '远程OB端';
  v2 number;
  v3 varchar2(200);
  v4 timestamp;
begin
  ori_pro1(v1,v2,p3=>v3,p4=>v4);
  DBMS_OUTPUT.PUT_LINE('存储过程结果：' || v2 || ',' || v3 || ',' || v4);
  v2 := ori_fun1(1);
  v3 := ori_fun2('function');
  v4 := ori_fun3(to_timestamp('04-06-2024 12:01:33.3333','dd-mm-yyyy hh24:mi:ss.ff'));
  DBMS_OUTPUT.PUT_LINE('函数结果：' || v2 || ',' || v3 || ',' || v4);
  ori_pck1.pack_pro(v2);
  DBMS_OUTPUT.PUT_LINE('包结果：' || v2);
  v2 := ori_pck1.pack_func(v2);
  DBMS_OUTPUT.PUT_LINE('包结果：' || v2);
  v2 := ori_seq1.nextval;
  DBMS_OUTPUT.PUT_LINE('序列结果：' || v2);
end;
/
select println() from dual;/
+------------------------------------------------------------------------------------------------------------------------------------------------------------------------------+
| PRINTLN()                                                                                                                                                                    |
+------------------------------------------------------------------------------------------------------------------------------------------------------------------------------+
| 存储过程结果：2024,远程OB端,2024-06-04 12:01:33.333300
  函数结果：2,FUNCTION,2024-06-10 12:01:33.000000
  包结果：4
  包结果：4
  序列结果：500                             |
+------------------------------------------------------------------------------------------------------------------------------------------------------------------------------+
declare
  v1 varchar2(200) default '远程OB端';
  v2 number;
  v3 varchar2(200);
  v4 timestamp;
begin
  v2 := syn_ori_syn1.nextval;
  DBMS_OUTPUT.PUT_LINE('序列结果：' || v2);
end;
/
ERROR 42S22: invalid identifier
at  line : 7, col : 8

drop user tnt1_other_schema cascade;
create user tnt1_other_schema identified by 123;
grant all on *.* to tnt1_other_schema with grant option;
grant dba to tnt1_other_schema;

drop table other_tab1;
create table other_tab1(id number,c1 varchar2(500),c2 number,c3 date);
insert into other_tab1 values(1,'[tnt1_other_schema] other_tab1',2024,to_date('2023-06-14','yyyy-mm-dd'));

create or replace procedure other_pro1(p1 out varchar2,p2 in out number,p3 in date default NULL) is
begin
  p2 := p2 * 2;
  p1 := concat('[远程ob端 tnt1_other_schema] other_pro1', p2 ||','|| p3);
end;
/
create or replace function other_fun1(p1 out varchar2,p2 in out number,p3 in date default to_date('2023-06-14','yyyy-mm-dd')) return varchar2 is 
begin
  p2 := p2 * 3;
  p1 := concat('[远程ob端 tnt1_other_schema] other_fun1', p2 ||','|| p3);
  return p1;
end;
/
create or replace package other_pack1 is
  a1 varchar2(500) default 'other_pack1';
  b1 NUMBER default 2023;
  c1 date default to_date('2023-01-01','yyyy-mm-dd');
  procedure pack_pro (p1 out varchar2,p2 in out number,p3 in date default NULL);
  function pack_func (p1 out varchar2,p2 in out number,p3 in date default to_date('2023-06-22','yyyy-mm-dd')) return varchar2;
end;
/
create or replace package body other_pack1 is
  procedure pack_pro (p1 out varchar2,p2 in out number,p3 in date default null) is
  begin
    p2 := p2 * 4;
    p1 := '[远端OB tnt1_other_schema] pack_pro ' ||','|| p2 ||','|| p3;
  end; 
  function pack_func (p1 out varchar2,p2 in out number,p3 in date default to_date('2023-06-22','yyyy-mm-dd')) return varchar2 is
  begin
    p2 := p2 * 5;
	p1 := '[远端OB tnt1_other_schema] pack_func ' ||','|| p2 ||','|| p3;
	return p1;
  end;
end;
/


create or replace synonym syn_tnt1_other_tab1 for tnt1_other_schema.other_tab1;
create or replace synonym syn_tnt1_other_pro1 for tnt1_other_schema.other_pro1;
create or replace public synonym syn_tnt1_other_fun1 for tnt1_other_schema.other_fun1;
create or replace public synonym syn_tnt1_other_pack1 for tnt1_other_schema.other_pack1;

create or replace synonym syn2_tnt1_other_tab1 for syn_tnt1_other_tab1;
create or replace public synonym syn2_tnt1_other_pro1 for syn_tnt1_other_pro1;
create or replace public synonym syn2_tnt1_other_fun1 for syn_tnt1_other_fun1;
create or replace public synonym syn2_tnt1_other_pack1 for syn_tnt1_other_pack1;

create or replace public synonym syn3_tnt1_other_pro1 for syn2_tnt1_other_pro1;
create or replace public synonym syn3_tnt1_other_fun1 for syn2_tnt1_other_fun1;

create or replace public synonym syn4_tnt1_other_pro1 for syn3_tnt1_other_pro1;
create or replace public synonym syn4_tnt1_other_fun1 for syn3_tnt1_other_fun1;

create or replace public synonym syn5_tnt1_other_pro1 for syn4_tnt1_other_pro1;
create or replace public synonym syn5_tnt1_other_fun1 for syn4_tnt1_other_fun1;

create or replace public synonym syn6_tnt1_other_pro1 for syn5_tnt1_other_pro1;
create or replace public synonym syn6_tnt1_other_fun1 for syn5_tnt1_other_fun1;

#### 调用方式
## 连接本地ob端  dblink_tenant2
set autocommit= on;
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;

#-----------------------------------------------------------------------------
# 本地OB端 dblink_tenant2租户下测试环境准备
#-----------------------------------------------------------------------------
# 表
drop table loc_tab1;
CREATE TABLE loc_tab1 (id int, c1 char(500) DEFAULT 'loc_tab1',c2 varchar2(300) DEFAULT '备注');
INSERT INTO loc_tab1 VALUES(1,DEFAULT,DEFAULT);
drop table loc_tab2;
CREATE TABLE loc_tab2 (id int, c1 char(500) DEFAULT 'loc_tab2',c2 varchar2(300) DEFAULT '备注');
INSERT INTO loc_tab2 VALUES(1,DEFAULT,DEFAULT);
# 存储过程
create or replace procedure loc_pro1(p1 in varchar default 'loc_pro1',p2 out number,p3 out varchar2,p4 out timestamp) is
begin
  p2 := 2024;
  p3 := p1;
  p4 := to_timestamp('04-06-2024 12:01:33.3333','dd-mm-yyyy hh24:mi:ss.ff');
end;
/
# 函数
create or replace function loc_fun1(p1 number) return number is 
begin
  return p1*2;
end;
/
create or replace function loc_fun2(p1 varchar2) return varchar2 is 
begin
  return upper(p1);
end;
/
create or replace function loc_fun3(p1 timestamp) return timestamp is 
begin
  return next_day(p1,'monday');
end;
/
# 包
create or replace package loc_pck1 is
  a NUMBER;
  b varchar2(200) default 'loc_pck1';
  c timestamp default NULL;
  procedure pack_pro(p1 in out number);
  function pack_func(p1 in number) return number;
end;
/
create or replace package body loc_pck1 is
  procedure pack_pro(p1 in out number) is
  begin
    p1 := p1 *2;
  end;
  function pack_func(p1 in number) return number is
  begin
    a := p1;
    return p1;
  end;
end;
/
# 序列
drop sequence loc_seq1;
ERROR HY000: sequence does not exist
create sequence loc_seq1 start with 100 increment by 1 maxvalue 500 cycle nocache;
# 同义词
create or replace synonym syn_loc_pro1 for loc_pro1;
create or replace synonym syn_loc_fun1 for loc_fun1;
create or replace synonym syn_loc_fun2 for loc_fun2;
create or replace synonym syn_loc_fun3 for loc_fun3;
create or replace synonym syn_loc_pck1 for loc_pck1;
create or replace synonym syn_loc_seq1 for loc_seq1;
declare
  v1 varchar2(200) default '本地OB端';
  v2 number;
  v3 varchar2(200);
  v4 timestamp;
begin
  DBMS_OUTPUT.PUT_LINE('====== 本地OB端 ======');
  loc_pro1(v1,v2,p3=>v3,p4=>v4);
  DBMS_OUTPUT.PUT_LINE('存储过程结果：' || v2 || ',' || v3 || ',' || v4);
  v2 := loc_fun1(1);
  v3 := loc_fun2('function');
  v4 := loc_fun3(to_timestamp('04-06-2024 12:01:33.3333','dd-mm-yyyy hh24:mi:ss.ff'));
  DBMS_OUTPUT.PUT_LINE('函数结果：' || v2 || ',' || v3 || ',' || v4);
  loc_pck1.pack_pro(v2);
  DBMS_OUTPUT.PUT_LINE('包结果：' || v2);
  v2 := loc_pck1.pack_func(v2);
  DBMS_OUTPUT.PUT_LINE('包结果：' || v2);
  v2 := loc_seq1.nextval;
  DBMS_OUTPUT.PUT_LINE('序列结果：' || v2);
end;
/
