  存储过程结果：2024,本地OB端,2024-06-04 12:01:33.333300
  函数结果：2,FUNCTION,2024-06-10 12:01:33.000000
  包结果：4
  包结果：4
  序列结果：100                                |
+----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------+

create or replace synonym syn_tnt2_tab1 for syn_tnt1_other_tab1@my_link1;
