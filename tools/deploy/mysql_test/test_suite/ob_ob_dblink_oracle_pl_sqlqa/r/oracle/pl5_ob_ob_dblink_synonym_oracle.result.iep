+-------------------------------------------------------------------------------------------------+

declare
  v1 varchar2(500) default 'v1';
  v2 NUMBER default 1;
  v3 date default NULL;
  res varchar2(500);
begin
  res := whh_dblink.syn_tnt2_pack1.pack_func(v1,p2=>v2,p3=>NULL);
  DBMS_OUTPUT.PUT_LINE('结果3：' || v1 || ',' || v2 || ',' || v3);
  whh_dblink.syn_tnt2_pack1.pack_pro(v1,p2=>v2,p3=>NULL);
  DBMS_OUTPUT.PUT_LINE('结果3：' || v1 || ',' || v2 || ',' || v3);
  end;
/
select println() from dual;/
+--------------------------------------------------------------------------------------------------------------------+
| PRINTLN()                                                                                                          |
+--------------------------------------------------------------------------------------------------------------------+
| 结果3：[远端OB tnt1_other_schema] pack_func ,5,,5,
  结果3：[远端OB tnt1_other_schema] pack_pro ,20,,20,           |
+--------------------------------------------------------------------------------------------------------------------+

declare
  v1 varchar2(500) default 'v1';
  v2 NUMBER default 1;
  v3 date default NULL;
  res varchar2(500);
begin
  v2 := NULL;
  v3 := NULL;
  res := syn2_tnt2_pack1.pack_func(p2=>v2,p1=>v1,p3=>v3);
  DBMS_OUTPUT.PUT_LINE('结果4：' || v1 || ',' || v2 || ',' || v3);
  syn2_tnt2_pack1.pack_pro(p2=>v2,p1=>v1,p3=>v3);
  DBMS_OUTPUT.PUT_LINE('结果4：' || v1 || ',' || v2 || ',' || v3);
  
  v2 := 4;
  v3 := to_date('2024-06-14','yyyy-mm-dd');
  res := syn3_tnt2_pack1.pack_func(p1=>v1,p2=>v2,p3=>v3);
  DBMS_OUTPUT.PUT_LINE('结果5：' || v1 || ',' || v2 || ',' || v3);
  syn3_tnt2_pack1.pack_pro(p1=>v1,p2=>v2,p3=>v3);
  DBMS_OUTPUT.PUT_LINE('结果5：' || v1 || ',' || v2 || ',' || v3);
end;
/
