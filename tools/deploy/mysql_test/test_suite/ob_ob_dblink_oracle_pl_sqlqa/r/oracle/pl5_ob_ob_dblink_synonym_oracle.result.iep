create or replace public synonym syn2_tnt2_tab1 for syn2_tnt1_other_tab1@my_link1;
create or replace public synonym syn2_tnt2_pro1 for syn2_tnt1_other_pro1@my_link1;
create or replace public synonym syn2_tnt2_fun1 for syn2_tnt1_other_fun1@my_link1;
create or replace public synonym syn2_tnt2_pack1 for syn2_tnt1_other_pack1@my_link1;

create or replace public synonym syn3_tnt2_tab1 for syn2_tnt2_tab1;
