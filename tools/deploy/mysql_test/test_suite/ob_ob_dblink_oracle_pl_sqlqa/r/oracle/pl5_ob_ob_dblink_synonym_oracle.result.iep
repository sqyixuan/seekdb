|    2 | 1000 | 初始 tnt1_tab1   |
+------+------+------------------+

create or replace procedure my_pro1(p1 in number,p2 number) is
begin
  tnt1_pro2@my_link1(p1, p2);
  tnt1_pro3@my_link1(p1, p2);
end;
