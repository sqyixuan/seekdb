create or replace public synonym syn6_tnt2_pro1 for syn5_tnt2_pro1;
create or replace public synonym syn6_tnt2_fun1 for syn5_tnt2_fun1;

# 本地PL对象中使用同义词
declare
  v1 varchar2(500) default 'v1';
  v2 NUMBER default 1;
  v3 date default NULL;
begin
  syn_tnt1_other_pro1@my_link1(p1=>v1,p2=>v2);
  DBMS_OUTPUT.PUT_LINE('结果1：' || v1 || ',' || v2 || ',' || v3);
  
  select c1,c2,c3 into v1,v2,v3 from syn_tnt1_other_tab1@my_link1 where id =1;
  syn2_tnt1_other_pro1@my_link1(v1,v2,v3);
  DBMS_OUTPUT.PUT_LINE('结果2：' || v1 || ',' || v2 || ',' || v3);
  
  syn_tnt2_pro1(v1,p2=>v2,p3=>NULL);
  DBMS_OUTPUT.PUT_LINE('结果3：' || v1 || ',' || v2 || ',' || v3);
  
  v2 := NULL;
  v3 := NULL;
  syn2_tnt2_pro1(p2=>v2,p1=>v1,p3=>v3);
  DBMS_OUTPUT.PUT_LINE('结果4：' || v1 || ',' || v2 || ',' || v3);
  
  v2 := ori_fun1@my_link1(2);
  v3 := to_date('2024-06-14','yyyy-mm-dd');
  syn3_tnt2_pro1(p1=>v1,p2=>v2,p3=>v3);
  DBMS_OUTPUT.PUT_LINE('结果5：' || v1 || ',' || v2 || ',' || v3);
end;
/
declare
  v1 varchar2(500) default 'v1';
  v2 NUMBER default 1;
  v3 date default NULL;
begin
  v3 := to_date('2024-06-14','yyyy-mm-dd');
  syn6_tnt1_other_pro1@my_link1(p1=>v1,p2=>v2,p3=>v3);
  DBMS_OUTPUT.PUT_LINE('结果：' || v1 || ',' || v2 || ',' || v3);
  v2 := NULL;
  v3 := NULL;
  syn2_tnt2_pro1(p2=>v2,p1=>v1,p3=>v3);
  DBMS_OUTPUT.PUT_LINE('结果：' || v1 || ',' || v2 || ',' || v3);
end;
/

declare
  v1 varchar2(500) default 'v1';
  v2 NUMBER default 1;
  v3 date default NULL;
  res varchar2(500);
begin
  res := syn_tnt1_other_fun1@my_link1(p1=>v1,p2=>v2);
  DBMS_OUTPUT.PUT_LINE('结果1：' || v1 || ',' || v2 || ',' || v3);
  
  select c1,c2,c3 into v1,v2,v3 from syn_tnt1_other_tab1@my_link1 where id =1;
  res := syn2_tnt1_other_fun1@my_link1(v1,v2,v3);
  DBMS_OUTPUT.PUT_LINE('结果2：' || v1 || ',' || v2 || ',' || v3);
  
  res := syn_tnt2_fun1(v1,p2=>v2,p3=>NULL);
  DBMS_OUTPUT.PUT_LINE('结果3：' || v1 || ',' || v2 || ',' || v3);
  
  v2 := NULL;
  v3 := NULL;
  res := syn2_tnt2_fun1(p2=>v2,p1=>v1,p3=>v3);
  DBMS_OUTPUT.PUT_LINE('结果4：' || v1 || ',' || v2 || ',' || v3);
  
  v2 := ori_fun1@my_link1(2);
  v3 := to_date('2024-06-14','yyyy-mm-dd');
  res := syn3_tnt2_fun1(p1=>v1,p2=>v2,p3=>v3);
  DBMS_OUTPUT.PUT_LINE('结果5：' || v1 || ',' || v2 || ',' || v3);
end;
/
