| 结果3：[远程ob端 tnt1_other_schema] other_fun16072,,6072,2023-06-14 00:00:00
  结果4：[远程ob端 tnt1_other_schema] other_fun1,,,
  结果5：[远程ob端 tnt1_other_schema] other_fun19,2024-06-14 00:00:00,9,2024-06-14 00:00:00                   |
+------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------+

declare
  v1 varchar2(500) default 'v1';
  v2 NUMBER default 1;
  v3 date default NULL;
  res varchar2(500);
begin
  v3 := to_date('2024-06-14','yyyy-mm-dd');
  res := syn6_tnt2_fun1(p1=>v1,p2=>v2,p3=>v3);
  DBMS_OUTPUT.PUT_LINE('结果5：' || v1 || ',' || v2 || ',' || v3);
end;
/
select println() from dual;/
+-------------------------------------------------------------------------------------------------+
| PRINTLN()                                                                                       |
+-------------------------------------------------------------------------------------------------+
