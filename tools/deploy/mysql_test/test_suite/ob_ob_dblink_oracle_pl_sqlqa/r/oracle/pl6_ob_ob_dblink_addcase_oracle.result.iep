#-----------------------------------------------------------------------------
# 测试需求：  OB-oracle到OB-oracle PL dblink 测试
# 测试场景：  6、补充其他场景
#-----------------------------------------------------------------------------
############################################################
######## udf、procedure嵌套使用
## 连接远程ob端 dblink_tenant1
set autocommit= on;
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;

#-----------------------------------------------------------------------------
# 远程OB端 dblink_tenant1租户下测试环境准备
#-----------------------------------------------------------------------------
# 表
drop table ori_tab1;
CREATE TABLE ori_tab1 (id int, c1 char(2000) DEFAULT 'ori_tab1',c2 varchar2(4000) DEFAULT '备注');
INSERT INTO ori_tab1 VALUES(1,DEFAULT,DEFAULT);
drop table ori_tab2;
CREATE TABLE ori_tab2 (id int, c1 char (2000) DEFAULT 'ori_tab2',c2 varchar2(4000) DEFAULT '备注');
INSERT INTO ori_tab2 VALUES(1,DEFAULT,DEFAULT);
# 存储过程
create or replace procedure ori_pro1(p1 in varchar default 'ori_pro1',p2 out number,p3 out varchar2,p4 out timestamp) is
begin
  p2 := 2024;
  p3 := p1;
  p4 := to_timestamp('04-06-2024 12:01:33.3333','dd-mm-yyyy hh24:mi:ss.ff');
end;
/
# 函数
create or replace function ori_fun1(p1 number) return number is 
begin
  return p1*2;
end;
/
create or replace function ori_fun2(p1 varchar2) return varchar2 is 
begin
  return upper(p1);
end;
/
create or replace function ori_fun3(p1 timestamp) return timestamp is 
begin
  return next_day(p1,'monday');
end;
/
# 包
create or replace package ori_pck1 is
  a NUMBER;
  b varchar2(200) default 'ori_pck1';
  c timestamp default NULL;
  procedure pack_pro(p1 in out number);
  function pack_func(p1 in number) return number;
end;
/
create or replace package body ori_pck1 is
  procedure pack_pro(p1 in out number) is
  begin
    p1 := p1 *2;
  end;
  function pack_func(p1 in number) return number is
  begin
    a := p1;
    return p1;
  end;
end;
/
# 序列
drop sequence ori_seq1;
ERROR HY000: sequence does not exist
create sequence ori_seq1 start with 500 increment by 1 maxvalue 1000 cycle nocache;
# 同义词
create or replace synonym syn_ori_pro1 for ori_pro1;
create or replace synonym syn_ori_fun1 for ori_fun1;
create or replace synonym syn_ori_fun2 for ori_fun2;
create or replace synonym syn_ori_fun3 for ori_fun3;
create or replace synonym syn_ori_pck1 for ori_pck1;
create or replace synonym syn_ori_seq1 for ori_seq1;
declare
  v1 varchar2(200) default '远程OB端';
  v2 number;
  v3 varchar2(200);
  v4 timestamp;
begin
  ori_pro1(v1,v2,p3=>v3,p4=>v4);
  DBMS_OUTPUT.PUT_LINE('存储过程结果：' || v2 || ',' || v3 || ',' || v4);
  v2 := ori_fun1(1);
  v3 := ori_fun2('function');
  v4 := ori_fun3(to_timestamp('04-06-2024 12:01:33.3333','dd-mm-yyyy hh24:mi:ss.ff'));
  DBMS_OUTPUT.PUT_LINE('函数结果：' || v2 || ',' || v3 || ',' || v4);
  ori_pck1.pack_pro(v2);
  DBMS_OUTPUT.PUT_LINE('包结果：' || v2);
  v2 := ori_pck1.pack_func(v2);
  DBMS_OUTPUT.PUT_LINE('包结果：' || v2);
  v2 := ori_seq1.nextval;
  DBMS_OUTPUT.PUT_LINE('序列结果：' || v2);
end;
/
select println() from dual;/
+------------------------------------------------------------------------------------------------------------------------------------------------------------------------------+
| PRINTLN()                                                                                                                                                                    |
+------------------------------------------------------------------------------------------------------------------------------------------------------------------------------+
| 存储过程结果：2024,远程OB端,2024-06-04 12:01:33.333300
  函数结果：2,FUNCTION,2024-06-10 12:01:33.000000
  包结果：4
  包结果：4
  序列结果：500                             |
+------------------------------------------------------------------------------------------------------------------------------------------------------------------------------+
declare
  v1 varchar2(200) default '远程OB端';
  v2 number;
  v3 varchar2(200);
  v4 timestamp;
begin
  v2 := syn_ori_syn1.nextval;
  DBMS_OUTPUT.PUT_LINE('序列结果：' || v2);
end;
/
ERROR 42S22: invalid identifier
at  line : 7, col : 8

create or replace function tnt1_fun11(p1 in varchar2 DEFAULT null) return varchar2 is 
begin
  return concat('tnt1_fun11,',p1);
end;
/
create or replace function tnt1_fun12 return varchar2 IS
  v1 varchar2(500) DEFAULT 'tnt1_fun2';
begin
  return tnt1_fun11(p1=>v1);
end;
/
create or replace procedure tnt1_pro13(p1 in varchar2  DEFAULT tnt1_fun11,p2 in varchar2 DEFAULT tnt1_fun12,p3 OUT varchar2) is
begin
  p3 := tnt1_fun11(p1 =>concat(p1,p2));
end;
/

create or replace synonym syn_tnt1_pro13 for tnt1_pro13;

CREATE OR REPLACE PROCEDURE tnt1_pro14(p1 IN boolean,p2 IN OUT number) IS
BEGIN
  IF p1 THEN
    p2:= power(p2,2);
  END IF;
END;
/

create or replace function tnt1_fun21(p1 in number DEFAULT 1) return number is 
begin
  return p1+2;
end;
/
create or replace procedure tnt1_pro22(p1 in number DEFAULT 1,p2 in OUT number) is
begin
  p2 := p1 * tnt1_fun21(p1=>p2);
end;
/
create or replace function tnt1_fun23(p1 in number DEFAULT 1,p2 in OUT number) return number IS
  procedure sub_pro1(p1 in number DEFAULT 1,p2 in OUT number) is
  BEGIN
    p2 := p2-1;
    tnt1_pro22(p1=>p1,p2=>p2);
  end;
BEGIN
  sub_pro1(p1=>p1,p2=>p2);
  return p2;
end;
/
create or replace function tnt1_fun24(p1 in number DEFAULT 1,p2 OUT varchar2) return number is 
BEGIN
  p2 := 'function tnt1_fun24';
  return p1*2;
end;
/

create or replace synonym syn_tnt1_fun23 for tnt1_fun23;
create or replace synonym syn_tnt1_fun24 for tnt1_fun24;

create or replace function tnt1_fun31(p1 in number,p2 in number) return number is 
begin
  return p1 / p2;
end;
$
create or replace function tnt1_fun32(p1 in number DEFAULT 2,p2 in number DEFAULT 1) return number IS
BEGIN
  return tnt1_fun31(p1=>p1,p2=>p2);
  EXCEPTION
    WHEN OTHERS THEN
     return 0;
end;
$

create or replace synonym syn_tnt1_fun32 for tnt1_fun32;

create or replace procedure tnt1_pro33 (n number,res out varchar2) authid definer is
  c varchar2(20) := 'exception';
  i integer;
  i_not_num exception;
begin
  i := n;
  loop
    if i > 0 then
      null;
    else
      c := i + c;
    end if;
    i := i - 1;
  end loop;
exception
  when i_not_num then
    res := 'i_not_num ' || sqlcode || sqlerrm;
  when invalid_number then
    res := 'invalid_number ' || sqlcode || sqlerrm;
end;
$
create or replace synonym syn_tnt1_pro33 for tnt1_pro33;

create or replace procedure tnt1_pro(a varchar,b varchar default null,res OUT varchar) is
 procedure c_pro(c varchar,d varchar) is
 begin
  execute immediate c||d INTO res;
 end;
begin
  c_pro(a,b);
end;
/
create or replace function tnt1_func(a varchar,b varchar default null,res OUT varchar) return number is
 function c_func(c varchar,d varchar) return number is
 begin
  execute immediate c||d INTO res;
 return 1;
 end;
begin
return c_func(a,b);
end;
/
create or replace package tnt1_pack is
procedure pack_pro(a varchar,b varchar default null,res OUT varchar);
function pack_func(a varchar,b varchar default null,res OUT varchar) return number;
end;
/
create or replace package body tnt1_pack is
procedure pack_pro(a varchar,b varchar default null,res OUT varchar) is
begin
tnt1_pro(a,b,res);
end;
function pack_func(a varchar,b varchar default null,res OUT varchar) return number is
begin
return tnt1_func(a,b,res);
end;
end;
/

create or replace synonym syn_tnt1_pack for tnt1_pack;

create or replace function tnt1_fun51(p1 in number DEFAULT 1,p2 IN OUT number) return number is 
BEGIN
  p2 := power(p1,2);
  return p2;
end;
/
create or replace synonym syn_tnt1_fun51 for tnt1_fun51;/

create or replace procedure tnt1_pro52(p1 in number DEFAULT 2,p2 in OUT number) is
begin
  p2 := syn_tnt1_fun51(p1=>p1,p2=>p2);
end;
/

create or replace synonym syn_pri_tnt1_pro52 for tnt1_pro52;
create or replace public synonym syn_pub_tnt1_pro52 for tnt1_pro52;
create or replace public synonym syn2_pub_tnt1_pro52 for syn_pri_tnt1_pro52;
create or replace synonym syn2_pri_tnt1_pro52 for syn_pub_tnt1_pro52;

CREATE OR REPLACE PROCEDURE tnt1_pro61(p1 IN varchar2,p2 OUT number) IS
  myref1 sys_refcursor;
BEGIN
  OPEN myref1 FOR SELECT id FROM ori_tab1 WHERE c1 like p1;
  FETCH myref1 INTO p2;
  CLOSE myref1;
END;
/

create or replace synonym syn_tnt1_pro61 for tnt1_pro61;

