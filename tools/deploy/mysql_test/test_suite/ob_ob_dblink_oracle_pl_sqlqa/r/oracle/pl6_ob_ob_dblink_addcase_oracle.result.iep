create or replace synonym syn_tnt2_pro52 for tnt1_pro52@my_link1;
create or replace synonym syn_tnt2_syn_pri_tnt1_pro52 for syn_pri_tnt1_pro52@my_link1;
create or replace public synonym syn_tnt2_pub_tnt1_pro52 for syn_pub_tnt1_pro52@my_link1;
create or replace public synonym syn_tnt2_syn2_pub_tnt1_pro52 for syn2_pub_tnt1_pro52@my_link1;
create or replace synonym syn_tnt2_syn2_pri_tnt1_pro52 for syn2_pri_tnt1_pro52@my_link1;

declare
  v1 number;
  v2 number;
begin
  tnt1_pro52@my_link1(p2=>v2);
  DBMS_OUTPUT.PUT_LINE('结果1：' || v2);
  syn_pri_tnt1_pro52@my_link1(p1=>v1,p2=>v2);
  DBMS_OUTPUT.PUT_LINE('结果2：' || v2);
  syn_pub_tnt1_pro52@my_link1(p1=>power(2,2),p2=>v2);
  DBMS_OUTPUT.PUT_LINE('结果3：' || v2);
  syn2_pub_tnt1_pro52@my_link1(p1=>0,p2=>v2);
  DBMS_OUTPUT.PUT_LINE('结果4：' || v2);
  syn2_pri_tnt1_pro52@my_link1(p1=>null,p2=>v2);
  DBMS_OUTPUT.PUT_LINE('结果5：' || v2);
end;
/
select println() from dual;/
+--------------------------------------------------------------------+
| PRINTLN()                                                          |
+--------------------------------------------------------------------+
| 结果1：4
  结果2：
  结果3：16
  结果4：0
  结果5：                |
+--------------------------------------------------------------------+
declare
  v1 number;
  v2 number;
begin
  syn_tnt2_pro52(p2=>v2);
  DBMS_OUTPUT.PUT_LINE('结果1：' || v2);
  syn_tnt2_syn_pri_tnt1_pro52(p1=>v1,p2=>v2);
  DBMS_OUTPUT.PUT_LINE('结果2：' || v2);
  syn_tnt2_pub_tnt1_pro52(p1=>power(syn_tnt1_fun51@my_link1(p1=>tnt1_fun51@my_link1(p1=>power(2,2),p2=>v2),p2=>v2),tnt1_fun51@my_link1(p2=>v2)),p2=>v2);
  DBMS_OUTPUT.PUT_LINE('结果3：' || v2);
  syn_tnt2_syn2_pub_tnt1_pro52(p1=>4-1*2+5,p2=>v2);
  DBMS_OUTPUT.PUT_LINE('结果4：' || v2);
  syn_tnt2_syn2_pri_tnt1_pro52(p1=>null,p2=>v2);
  DBMS_OUTPUT.PUT_LINE('结果5：' || v2);
end;
