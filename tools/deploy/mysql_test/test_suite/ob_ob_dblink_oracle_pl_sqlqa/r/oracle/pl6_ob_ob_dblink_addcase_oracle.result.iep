create or replace type tnt1_type as object(
a varchar(2000),
b varchar(2000),
static procedure type_pro(a varchar,b varchar,res OUT VARCHAR),
member function type_func(res OUT VARCHAR) return number
);
/
create or replace type body tnt1_type is
static procedure type_pro(a varchar,b varchar,res OUT VARCHAR) is
begin
tnt1_pack.pack_pro@my_link1(a,b,res);
end;
member function type_func(res OUT VARCHAR) return number is
begin
return tnt1_pack.pack_func@my_link1(a,b,res);
end;
end;
/
declare
  v1 tnt1_type := tnt1_type('select ori_pck1.pack_func(p1=>2*3)',' from dual');
  v2 varchar2(500) := 'select power(2,3) from dual'; 
  v3 varchar2(500); 
  res number;
begin
  tnt1_type.type_pro(a=>v2,b=>NULL,res=>v3);
  DBMS_OUTPUT.PUT_LINE('结果1：' || res || ',' || v3);
  res := v1.type_func(res=>v3);
  DBMS_OUTPUT.PUT_LINE('结果1：' || res || ',' || v3);
end;
/
