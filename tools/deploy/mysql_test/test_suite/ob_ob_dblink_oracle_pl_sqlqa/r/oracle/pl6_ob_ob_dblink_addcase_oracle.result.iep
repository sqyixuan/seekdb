DECLARE
  v1 number := 1;
  v2 varchar2(500);
  res number;
begin
  res := tnt1_fun24@my_link1(p1=>v1,p2=>v2);
  dbms_output.put_line('结果1：' || v2 ||','|| res );
  res := syn_tnt1_fun24@my_link1(p1=>v1,p2=>v2);
  dbms_output.put_line('结果2：' || v2 ||','|| res );
  res := syn_tnt2_syn_fun24(p1=>v1,p2=>v2);
  dbms_output.put_line('结果3：' || v2 ||','|| res );
end;
/
