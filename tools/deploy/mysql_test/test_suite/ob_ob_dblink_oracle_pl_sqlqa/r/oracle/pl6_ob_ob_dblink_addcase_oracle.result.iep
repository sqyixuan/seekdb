create or replace synonym syn_tnt2_fun32 for tnt1_fun32@my_link1;
create or replace synonym syn_tnt2_syn_fun32 for syn_tnt1_fun32@my_link1;

declare
  v1 number DEFAULT 11;
  v2 number DEFAULT 12;
  v3 number DEFAULT 13;
begin
  v3 := tnt1_fun32@my_link1();
  DBMS_OUTPUT.PUT_LINE('结果1：' || v3);
  v3 := syn_tnt1_fun32@my_link1(p1=>ori_fun1@my_link1(v1),p2=>loc_fun1(v2));
  DBMS_OUTPUT.PUT_LINE('结果2：' || v3);
  v3 := syn_tnt2_fun32(p1=>v1,p2=>null);
  DBMS_OUTPUT.PUT_LINE('结果3：' || v3);
  v3 := syn_tnt2_syn_fun32(p1=>v1,p2=>0);
  DBMS_OUTPUT.PUT_LINE('结果4：' || v3);
end;
