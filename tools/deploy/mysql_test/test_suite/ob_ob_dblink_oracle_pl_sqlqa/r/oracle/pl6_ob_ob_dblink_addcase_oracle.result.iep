+----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------+

create or replace synonym syn_tnt2_pro13 for tnt1_pro13@my_link1;
create or replace synonym syn_tnt2_syn_pro13 for syn_tnt1_pro13@my_link1;
declare
  v1 varchar2(500) DEFAULT '-v1-';
  v2 varchar2(500) DEFAULT '-v2-';
  v3 varchar2(500) DEFAULT '-v3-';
begin
  tnt1_pro13@my_link1(p3=>v3);
  DBMS_OUTPUT.PUT_LINE('结果1：' || v3);
  syn_tnt1_pro13@my_link1(p1=>tnt1_fun11@my_link1(p1=>v1),p3=>v3);
  DBMS_OUTPUT.PUT_LINE('结果2：' || v3);
  syn_tnt2_pro13(p2=>tnt1_fun12@my_link1(),p3=>v3);
  DBMS_OUTPUT.PUT_LINE('结果3：' || v3);
  syn_tnt2_syn_pro13(p1=>tnt1_fun11@my_link1(p1=>tnt1_fun11@my_link1(p1=>tnt1_fun12@my_link1())),p3=>v3);
  DBMS_OUTPUT.PUT_LINE('结果4：' || v3);
end;
/
select println() from dual;/
+--------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------+
| PRINTLN()                                                                                                                                                                                                                                                    |
+--------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------+
| 结果1：tnt1_fun11,tnt1_fun11,tnt1_fun11,tnt1_fun2
  结果2：tnt1_fun11,tnt1_fun11,-v1-tnt1_fun11,tnt1_fun2
  结果3：tnt1_fun11,tnt1_fun11,tnt1_fun11,tnt1_fun2
  结果4：tnt1_fun11,tnt1_fun11,tnt1_fun11,tnt1_fun11,tnt1_fun2tnt1_fun11,tnt1_fun2             |
+--------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------+
declare
  v1 number DEFAULT 2;
BEGIN
  INSERT INTO ori_tab1@my_link1 VALUES(10,DEFAULT,DEFAULT);
  --tnt1_pro14@my_link1(p1=>sql%FOUND OR sql%found,p2=>v1);
  tnt1_pro14@my_link1(p1=>sql%FOUND,p2=>v1);
  DBMS_OUTPUT.PUT_LINE('结果1：' || v1);
end;
/
select * from ori_tab1@my_link1 WHERE id = 10;
select println() from dual;/
+------+-------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------begin
  v3 := tnt1_fun23@my_link1(p2=>v2);
  DBMS_OUTPUT.PUT_LINE('结果1：' || v2 || ',' || v3);
  v3 := syn_tnt1_fun23@my_link1(p1=>tnt1_fun21@my_link1(p1=>v1),p2=>v2);
  DBMS_OUTPUT.PUT_LINE('结果2：' || v2 || ',' || v3);
  v3 := syn_tnt2_fun23(p1=>v1,p2=>v2);
  DBMS_OUTPUT.PUT_LINE('结果3：' || v2 || ',' || v3);
  v3 := syn_tnt2_syn_fun23(p1=>tnt1_fun21@my_link1(p1=>tnt1_fun21@my_link1(p1=>v1)),p2=>v2);
  DBMS_OUTPUT.PUT_LINE('结果4：' || v2 || ',' || v3);
end;
/
select println() from dual;/
+-----------------------------------------------------------------------------------+
| PRINTLN()                                                                         |
+-----------------------------------------------------------------------------------+
| 结果1：13,13
  结果2：182,182
  结果3：2013,2013
  结果4：30210,30210             |
+-----------------------------------------------------------------------------------+
declare
  v1 number DEFAULT 1000;
  v2 number DEFAULT 1;
  v3 number DEFAULT 13;
BEGIN
  WHILE v1 > 0 loop
    v3 := tnt1_fun21@my_link1(p1=>v1);
    v1 := v1 -1;
  END LOOP;
  DBMS_OUTPUT.PUT_LINE('结果1：' || v2 || ',' || v3);
end;
/
select println() from dual;/
+---------------+
| PRINTLN()     |
+---------------+
| 结果1：1,3    |
+---------------+
DECLARE
  v1 number := 1;
  v2 number := 1;
begin 
  for rec in (select tnt1_fun21@my_link1(p1=>v1) AS res from (SELECT tnt1_fun21@my_link1(p1=>v1) FROM dual) t) loop 
    DBMS_OUTPUT.PUT_LINE('rec.res=' || rec.res);
  end loop; 
end;
/
select println() from dual;/
+-----------+
| PRINTLN() |
+-----------+
| rec.res=3 |
+-----------+
declare
  v1 number DEFAULT 10;
  v2 number DEFAULT 0;
BEGIN
  if tnt1_fun21@my_link1(p1=>v1) >0 OR tnt1_fun23@my_link1(p1=>v1,p2=>v2) >0 then
    DBMS_OUTPUT.PUT_LINE('结果1：' || v2 );
  end if;
  if tnt1_fun21@my_link1(p1=>v1) >0 and tnt1_fun23@my_link1(p1=>v1,p2=>v2) >0 then
    DBMS_OUTPUT.PUT_LINE('结果2：' || v2 );
  end if;
end;
/
select println() from dual;/
+----------------------------+
| PRINTLN()                  |
+----------------------------+
| 结果1：0
  结果2：10       |
+----------------------------+
declare
  cursor test_cursor is select tnt1_fun21@my_link1(p1=>20) as c from dual;
  res number;
begin
  open test_cursor;
  fetch test_cursor into res;
  dbms_output.put_line('结果1：' || res );
  res := tnt1_fun21@my_link1(p1=>sql%rowcount);
  dbms_output.put_line('结果2：' || res );
  close test_cursor;
end;
/
select println() from dual;/
+---------------------------+
| PRINTLN()                 |
+---------------------------+
| 结果1：22
  结果2：       |
+---------------------------+

DECLARE
  v1 number := 1;
  v2 varchar2(500);
  res number;
begin
  res := tnt1_fun24@my_link1(p1=>v1,p2=>v2);
  dbms_output.put_line('结果1：' || v2 ||','|| res );
  res := syn_tnt1_fun24@my_link1(p1=>v1,p2=>v2);
  dbms_output.put_line('结果2：' || v2 ||','|| res );
  res := syn_tnt2_syn_fun24(p1=>v1,p2=>v2);
  dbms_output.put_line('结果3：' || v2 ||','|| res );
end;
/
