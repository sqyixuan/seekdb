+--------------------------------------------------------------------------------------------------------------------------------------------------------------------------+


create or replace function tnt1_fun24(p1 in number DEFAULT 1,p2 IN OUT varchar2,p3 IN varchar2 DEFAULT 'p3') return number is 
BEGIN
  p2 := p2 || '远程函数修改后2 function tnt1_fun24' || p3;
  return p1*3;
end;
/

