create or replace synonym syn_tnt2_pack for tnt1_pack@my_link1;
create or replace synonym syn_tnt2_syn_pack for syn_tnt1_pack@my_link1;

declare
  v1 varchar2(500) DEFAULT 'select c1 from ori_tab1 where id = 1';
  v2 varchar2(500) := 'select 2*3 from dual';
  v3 varchar2(2000);
  res number;
begin
  tnt1_pack.pack_pro@my_link1(a=>v1,res=>v3);
  DBMS_OUTPUT.PUT_LINE('结果1：' || v3);
  res := syn_tnt1_pack.pack_func@my_link1(a=>null,b=>v2,res=>v3);
  DBMS_OUTPUT.PUT_LINE('结果2：' || v3);
  res := syn_tnt2_pack.pack_func(a=>'select c2 ',b=>'from ori_tab1 where id = 1',res=>v3);
  DBMS_OUTPUT.PUT_LINE('结果2：' || v3);
  syn_tnt2_syn_pack.pack_pro(a=>'select power(2,2) from dual',b=>null,res=>v3);
  DBMS_OUTPUT.PUT_LINE('结果2：' || v3);
end;
