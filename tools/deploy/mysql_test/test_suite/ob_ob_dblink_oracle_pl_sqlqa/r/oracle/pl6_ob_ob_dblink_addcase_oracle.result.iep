declare
  v1 varchar2(500) := 'select ori_fun1(p1=>2*3) from dual';
  v2 varchar2(500) := 'select ori_fun1(p1=>ori_fun1(p1=>ori_fun1(p1=>2*3))) from dual';
  v3 varchar2(500); 
  res number;
begin
  res := tnt1_pack.pack_func@my_link1(a=>v1,res=>v3);
  DBMS_OUTPUT.PUT_LINE('结果1：' || res || ',' || v3);
  syn_tnt1_pack.pack_pro@my_link1(a=>NULL,b=>v2,res=>v3);
  DBMS_OUTPUT.PUT_LINE('结果1：' || res || ',' || v3);
end;
