declare
  v1 varchar2(500);
  v2 number default null;
  v3 date default null;
  res varchar2(500);
begin
  syn_tnt2_pack1.pack_in_pro2(p1=>v1);
  res := tnt1_pack1.pack_get_constant@my_link1();
  DBMS_OUTPUT.PUT_LINE('结果：' || res);
  syn_tnt2_pack1.pack_in_pro2(p2=>v2);
  res := tnt1_pack1.pack_get_constant@my_link1();
  DBMS_OUTPUT.PUT_LINE('结果：' || res);
  syn_tnt2_pack1.pack_in_pro2(p3=>v3);
  res := tnt1_pack1.pack_get_constant@my_link1();
  DBMS_OUTPUT.PUT_LINE('结果：' || res);
  syn_tnt2_pack1.pack_in_pro2(p2=>22,p3=>to_date('2024-06-22','yyyy-mm-dd'));
  res := tnt1_pack1.pack_get_constant@my_link1();
  DBMS_OUTPUT.PUT_LINE('结果：' || res);
  syn_tnt2_syn_pack1.pack_in_pro2(p1=>'pack_in_pro2',p2=>22);
  res := tnt1_pack1.pack_get_constant@my_link1();
  DBMS_OUTPUT.PUT_LINE('结果：' || res);
  syn_tnt2_syn_pack1.pack_in_pro2(p1=>'pack_in_pro2',p3=>to_date('2024-06-22','yyyy-mm-dd'));
  res := tnt1_pack1.pack_get_constant@my_link1();
  DBMS_OUTPUT.PUT_LINE('结果：' || res);
end;
/
select println() from dual;/
+-----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------+-----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------begin
  select syn_tnt2_pack1.pack_in_func2() into res from dual;
  DBMS_OUTPUT.PUT_LINE('结果：' || res);
  select syn_tnt2_syn_pack1.pack_in_func2(p1=>'pack_in_func2') into res from dual;
  DBMS_OUTPUT.PUT_LINE('结果：' || res);
  select syn_tnt2_pack1.pack_in_func2(p2=>22) into res from dual;
  DBMS_OUTPUT.PUT_LINE('结果：' || res);
  select syn_tnt2_syn_pack1.pack_in_func2(p3=>to_date('2024-06-22','yyyy-mm-dd')) into res from dual;
  DBMS_OUTPUT.PUT_LINE('结果：' || res);
end;
/
