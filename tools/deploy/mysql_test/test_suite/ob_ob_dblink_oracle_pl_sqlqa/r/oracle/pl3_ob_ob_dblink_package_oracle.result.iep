select println() from dual;/
+--------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------+--------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------end my_pkg;
/

create or replace package body my_pkg is
  procedure sub_pkg_pro1(p1 in number) is
  begin
	a := 'print_employee_salary';
	b := p1;
  end sub_pkg_pro1;

  procedure pkg_pro1(p1 in number) is
  begin
    sub_pkg_pro1(p1=>p1);
	dbms_output.put_line('结果：' || a || b);
  end pkg_pro1;
  
  function pack_get_constant return varchar2 is
  begin
    return '【a='|| a ||',b='|| b ||'】';
  end;
end my_pkg;
/

create or replace synonym syn_tnt1_my_pkg for my_pkg;

#### 调用方式
## 连接本地ob端  dblink_tenant2
set autocommit= on;

create or replace synonym syn_tnt2_pack1 for my_pkg@my_link1;
create or replace synonym syn_tnt2_syn_pack1 for syn_tnt1_my_pkg@my_link1;
create or replace synonym syn2_tnt2_syn_pack1 for syn_tnt2_syn_pack1;

declare
  res varchar2(500);
BEGIN
  res := syn_tnt1_my_pkg.pack_get_constant@my_link1;
  DBMS_OUTPUT.PUT_LINE('调用前：' || res);
  
  my_pkg.pkg_pro1@my_link1(p1 => NULL);
  res := syn_tnt2_pack1.pack_get_constant();
  DBMS_OUTPUT.PUT_LINE('调用后：' || res);
  
  syn2_tnt2_syn_pack1.pkg_pro1(p1 => 100);
  res := syn_tnt2_syn_pack1.pack_get_constant();
  DBMS_OUTPUT.PUT_LINE('调用后：' || res);
END;
/
select println() from dual;/
+-----------------------------------------------------------------------------------------------------------------------------+
| PRINTLN()                                                                                                                   |
+-----------------------------------------------------------------------------------------------------------------------------+
| 调用前：【a=a ,b=1】
  调用后：【a=print_employee_salary,b=】
  调用后：【a=print_employee_salary,b=100】                   |
+-----------------------------------------------------------------------------------------------------------------------------+

declare
  res varchar2(500);
BEGIN
  my_pkg.sub_pkg_pro1@my_link1(p1 => 100);
END;
