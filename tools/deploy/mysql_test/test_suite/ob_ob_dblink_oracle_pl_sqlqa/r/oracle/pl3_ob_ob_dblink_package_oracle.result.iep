######## 包中方法间相互嵌套调用
## 连接远程ob端 dblink_tenant1
set autocommit= on;

create or replace package tnt1_pack1 is
  a1 varchar2(5000) default '0';
  b1 NUMBER default 0;
  c1 date default to_date('2024-01-01','yyyy-mm-dd');
  procedure pack_pro1 (p1 in varchar2,p2 in number);
  procedure pack_pro2 (p1 in varchar2,p3 in date);
  procedure pack_pro3 (p2 in number,p3 in date);
  procedure pack_pro4 (p1 out varchar2,p2 in out number,p3 in date default null);
  
  function pack_func1 (p1 in varchar2) return varchar2;
  function pack_func2 (p2 in number) return varchar2;
  function pack_func3 (p3 in date) return varchar2;
  function pack_func4 (p1 out varchar2,p2 in out number,p3 in date default null) return varchar2;
  function pack_get_constant return varchar2;
end;
/
create or replace package body tnt1_pack1 is
  procedure pack_pro1(p1 in varchar2,p2 in number) is
  begin
    a1 := a1 || '1'|| p1;
	b1 := b1 + p2;
	c1 := to_date('2024-01-01','yyyy-mm-dd');
  end;
  procedure pack_pro2(p1 in varchar2,p3 in date) is
  begin
    a1 := a1 || '2'|| p1;
	b1 := b1 + 2;
	c1 := p3;
	pack_pro1(p1=>a1,p2=>b1);
  end;
  procedure pack_pro3(p2 in number,p3 in date) is
  begin
    a1 := a1 || '3';
	b1 := b1 + p2;
    c1 := p3;
	pack_pro2(p1=>a1,p3=>p3);
  end;
  procedure pack_pro4(p1 out varchar2,p2 in out number,p3 in date default null) is
  begin
    a1 := a1 || '4';
	b1 := b1 + p2;
    c1 := p3;
	p2 := p2 + b1;
    p1 := p2 || p3;
	pack_pro3(p2=>p2,p3=>p3);
  end;
  
  function pack_func1(p1 in varchar2)  return varchar2 is
  begin
    a1 := a1 || '1' || p1;
	b1 := b1 * 2;
    c1 := to_date('2024-02-01','yyyy-mm-dd');
	return a1;
  end;
  function pack_func2(p2 in number) return varchar2 is
  begin
    a1 := a1 || '2';
    b1 := b1 + p2;
	c1 := to_date('2024-02-02','yyyy-mm-dd');
	return pack_func1(p1=>a1);
  end;
  function pack_func3(p3 in date) return varchar2 is
  begin
    a1 := a1 || '3';
    b1 := b1 + 3;
    c1 := p3;
	return pack_func2(p2=>b1);
  end;
  function pack_func4(p1 out varchar2,p2 in out number,p3 in date default null) return varchar2 is
  begin
    a1 := a1 || '4';
    b1 := b1 + p2;
    c1 := p3;
	p1 := pack_func3(p3=>p3);
	return a1;
  end;
  
  function pack_get_constant return varchar2 is
  begin
    return '【a1='|| a1 ||'】,【b1='|| b1 ||'】,【c1='|| c1||'】';
  end;
end;
/

create or replace synonym syn_tnt1_pack1 for tnt1_pack1;

#### 调用方式
