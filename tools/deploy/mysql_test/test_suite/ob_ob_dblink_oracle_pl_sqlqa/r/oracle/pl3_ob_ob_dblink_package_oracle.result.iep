  res := tnt1_pack1.pack_get_constant@my_link1();
  DBMS_OUTPUT.PUT_LINE(res);
  tnt1_pack1.pack_pro1@my_link1(v2);
  res := tnt1_pack1.pack_get_constant@my_link1();
  DBMS_OUTPUT.PUT_LINE(res);
  tnt1_pack1.pack_pro1@my_link1(v3);
  res := tnt1_pack1.pack_get_constant@my_link1();
  DBMS_OUTPUT.PUT_LINE(res);
  tnt1_pack1.pack_pro1@my_link1(v1,v2);
  res := tnt1_pack1.pack_get_constant@my_link1();
  DBMS_OUTPUT.PUT_LINE(res);
  tnt1_pack1.pack_pro1@my_link1(v1,v3);
  res := tnt1_pack1.pack_get_constant@my_link1();
  DBMS_OUTPUT.PUT_LINE(res);
  tnt1_pack1.pack_pro1@my_link1(v2,v3);
  res := tnt1_pack1.pack_get_constant@my_link1();
  DBMS_OUTPUT.PUT_LINE(res);
  tnt1_pack1.pack_pro1@my_link1(v1,p2=>v2,p3=>v3);
  res := tnt1_pack1.pack_get_constant@my_link1();
  DBMS_OUTPUT.PUT_LINE(res);
end;
/
