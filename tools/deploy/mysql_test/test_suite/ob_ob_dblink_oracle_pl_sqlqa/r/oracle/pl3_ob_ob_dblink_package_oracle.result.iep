create or replace synonym syn_tnt2_pack1 for tnt1_pack1@my_link1;
create or replace synonym syn_tnt2_syn_pack1 for syn_tnt1_pack1@my_link1;

# 无参
call tnt1_pack1.pack_pro1@my_link1();
select syn_tnt1_pack1.pack_get_constant@my_link1() from dual;
+----------------------------------------------------------------------------+
| SYN_TNT1_PACK1.PACK_GET_CONSTANT@MY_LINK1()                                |
+----------------------------------------------------------------------------+
| [包中无参存储过程 pack_pro1,,],[tnt1_pack1,11,2024-06-11 00:00:00]         |
+----------------------------------------------------------------------------+
call syn_tnt1_pack1.pack_pro1@my_link1();
select syn_tnt1_pack1.pack_get_constant@my_link1() from dual;
+----------------------------------------------------------------------------+
| SYN_TNT1_PACK1.PACK_GET_CONSTANT@MY_LINK1()                                |
+----------------------------------------------------------------------------+
| [包中无参存储过程 pack_pro1,,],[tnt1_pack1,11,2024-06-11 00:00:00]         |
+----------------------------------------------------------------------------+

select tnt1_pack1.pack_func1@my_link1() from dual;
+----------------------------------+
| TNT1_PACK1.PACK_FUNC1@MY_LINK1() |
+----------------------------------+
| 包中无参函数 pack_func1          |
+----------------------------------+
select syn_tnt1_pack1.pack_func1@my_link1() from dual;
+--------------------------------------+
| SYN_TNT1_PACK1.PACK_FUNC1@MY_LINK1() |
+--------------------------------------+
| 包中无参函数 pack_func1              |
+--------------------------------------+

declare
  res varchar2(500);
begin
  syn_tnt2_pack1.pack_pro1();
  res := tnt1_pack1.pack_get_constant@my_link1();
  DBMS_OUTPUT.PUT_LINE('结果：' || res);
  syn_tnt2_syn_pack1.pack_pro1();
  res := tnt1_pack1.pack_get_constant@my_link1();
  DBMS_OUTPUT.PUT_LINE('结果：' || res);
  
  select syn_tnt2_pack1.pack_func1() into res from dual;
  DBMS_OUTPUT.PUT_LINE('结果：' || res);
  select syn_tnt2_syn_pack1.pack_func1() into res from dual;
  DBMS_OUTPUT.PUT_LINE('结果：' || res);
end;
/
select println() from dual;/
+-------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------+
| PRINTLN()                                                                                                                                                                                                                                                   |
