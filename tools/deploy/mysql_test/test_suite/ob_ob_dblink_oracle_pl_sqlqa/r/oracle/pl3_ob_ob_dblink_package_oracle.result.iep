[100.88.109.130:51005] [2024-07-04 11:01:50.987200] [YC73D64586D82-00061C62D06A5CD5-0-0]
at  line : 7, col : 8

create or replace package tnt1_pack1 is
  a1 varchar2(500);
  b1 NUMBER;
  c1 date;
  a2 varchar2(500) default 'tnt1_pack1';
  b2 NUMBER default 11;
  c2 date default to_date('2024-06-11','yyyy-mm-dd');
  procedure pack_pro1;
  function pack_func1 return varchar2;
  procedure pack_in_pro2 (p1 in varchar2 default '',p2 in number default NULL,p3 in date default NULL);
  function pack_in_func2 (p1 in varchar2 default 'default',p2 in number default 11,p3 in date default to_date('2024-06-11','yyyy-mm-dd'))return varchar2;
  procedure pack_inout_pro3 (p1 in out varchar2,p2 in out number,p3 in out date);
  function pack_inout_func3 (p1 in out varchar2,p2 in out number,p3 in out date) return varchar2;
  procedure pack_out_pro4 (p1 out varchar2,p2 out number,p3 out date);
  function pack_out_func4 (p1 out varchar2,p2 out number,p3 out date) return varchar2;
  procedure pack_outin_pro5 (p1 out varchar2,p2 in out number,p3 in date default NULL);
  function pack_outin_func5 (p1 out varchar2,p2 in out number,p3 in date default to_date('2024-06-22','yyyy-mm-dd')) return varchar2;
  function pack_set_constant (p1 in varchar2 default '',p2 in number default NULL,p3 in date default NULL)return varchar2;
  function pack_get_constant return varchar2;
end;
/
create or replace package body tnt1_pack1 is
  procedure pack_pro1 is
  begin
    a1 := '包中无参存储过程 pack_pro1';
  end;
  function pack_func1 return varchar2 is
  begin
    return '包中无参函数 pack_func1';
  end;
  
  procedure pack_in_pro2 (p1 in varchar2 default '',p2 in number default NULL,p3 in date default NULL) is
  begin
    a1 := '包中in存储过程 pack_in_pro2 ' || p1 ||','|| p2 ||','|| p3;
  end;
  function pack_in_func2 (p1 in varchar2 default 'default',p2 in number default 11,p3 in date default to_date('2024-06-11','yyyy-mm-dd')) return varchar2 is
  begin
    return '包中in函数 pack_in_func2 ' || p1 ||','|| p2 ||','|| p3;
  end;
  
  procedure pack_inout_pro3 (p1 in out varchar2,p2 in out number,p3 in out date) is
  begin
    p1 := concat('[远端OB pack_inout_pro3]',p1);
	p2 := p2 * 2;
	p3 := last_day(p3);
    a1 := '包中inout存储过程 pack_inout_pro3' || p1 ||','|| p2 ||','|| p3;
  end;
  function pack_inout_func3 (p1 in out varchar2,p2 in out number,p3 in out date) return varchar2 is
  begin
    p1 := concat('[远端OB pack_inout_func3]',p1);
	p2 := p2 * 2;
	p3 := last_day(p3);
	return '包中out函数 pack_inout_func3 ' || p1 ||','|| p2 ||','|| p3;
  end;
  
  procedure pack_out_pro4 (p1 out varchar2,p2 out number,p3 out date) is
  begin
    p1 := '[远端OB pack_out_pro4]';
    p2 := 2024;
	p3 := to_date('2024-06-12','yyyy-mm-dd');
  end;
  function pack_out_func4 (p1 out varchar2,p2 out number,p3 out date) return varchar2 is
  begin
    p1 := '[远端OB pack_out_func4]';
	p2 := 2025;
	p3 := to_date('2025-01-01','yyyy-mm-dd');
	return p1 ||','|| p2 ||','|| p3;
  end;
  
  procedure pack_outin_pro5 (p1 out varchar2,p2 in out number,p3 in date default null) is
  begin
    p2 := p2 * 2;
    p1 := '[远端OB pack_outin_pro5] ' ||','|| p2 ||','|| p3;
  end; 
  function pack_outin_func5 (p1 out varchar2,p2 in out number,p3 in date default to_date('2024-06-22','yyyy-mm-dd')) return varchar2 is
  begin
    p2 := p2 * 2;
	p1 := '[远端OB pack_outin_func5] ' ||','|| p2 ||','|| p3;
	return '包中in,in out,out函数 pack_outin_func5' || p1;
  end;
  
  function pack_set_constant (p1 in varchar2 default '',p2 in number default NULL,p3 in date default NULL)return varchar2 is
  begin
    a1 := p1;
	b1 := p2;
	c1 := p3;
    return 'pack_set_constant';
  end;
  function pack_get_constant return varchar2 is
  begin
    return '[' ||a1 ||','|| b1 ||','|| c1 ||'],['|| a2 ||','|| b2 ||','|| c2 || ']';
  end;
end;
/

create or replace synonym syn_tnt1_pack1 for tnt1_pack1;

#### 调用方式
## 连接本地ob端  dblink_tenant2
set autocommit= on;
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;

#-----------------------------------------------------------------------------
# 本地OB端 dblink_tenant2租户下测试环境准备
#-----------------------------------------------------------------------------
# 表
drop table loc_tab1;
CREATE TABLE loc_tab1 (id int, c1 char(500) DEFAULT 'loc_tab1',c2 varchar2(300) DEFAULT '备注');
INSERT INTO loc_tab1 VALUES(1,DEFAULT,DEFAULT);
drop table loc_tab2;
CREATE TABLE loc_tab2 (id int, c1 char(500) DEFAULT 'loc_tab2',c2 varchar2(300) DEFAULT '备注');
INSERT INTO loc_tab2 VALUES(1,DEFAULT,DEFAULT);
# 存储过程
create or replace procedure loc_pro1(p1 in varchar default 'loc_pro1',p2 out number,p3 out varchar2,p4 out timestamp) is
begin
  p2 := 2024;
  p3 := p1;
  p4 := to_timestamp('04-06-2024 12:01:33.3333','dd-mm-yyyy hh24:mi:ss.ff');
end;
/
# 函数
create or replace function loc_fun1(p1 number) return number is 
begin
  return p1*2;
end;
/
create or replace function loc_fun2(p1 varchar2) return varchar2 is 
begin
  return upper(p1);
end;
/
create or replace function loc_fun3(p1 timestamp) return timestamp is 
begin
  return next_day(p1,'monday');
end;
/
# 包
create or replace package loc_pck1 is
  a NUMBER;
  b varchar2(200) default 'loc_pck1';
  c timestamp default NULL;
  procedure pack_pro(p1 in out number);
  function pack_func(p1 in number) return number;
end;
/
create or replace package body loc_pck1 is
  procedure pack_pro(p1 in out number) is
  begin
    p1 := p1 *2;
  end;
  function pack_func(p1 in number) return number is
  begin
    a := p1;
    return p1;
  end;
end;
/
# 序列
drop sequence loc_seq1;
ERROR HY000: sequence does not exist
[100.88.109.130:51005] [2024-07-04 11:01:52.873036] [YC73D64586D82-00061C62D53A5CD0-0-0]
create sequence loc_seq1 start with 100 increment by 1 maxvalue 500 cycle nocache;
# 同义词
create or replace synonym syn_loc_pro1 for loc_pro1;
create or replace synonym syn_loc_fun1 for loc_fun1;
create or replace synonym syn_loc_fun2 for loc_fun2;
create or replace synonym syn_loc_fun3 for loc_fun3;
create or replace synonym syn_loc_pck1 for loc_pck1;
create or replace synonym syn_loc_seq1 for loc_seq1;
declare
  v1 varchar2(200) default '本地OB端';
  v2 number;
  v3 varchar2(200);
  v4 timestamp;
begin
  DBMS_OUTPUT.PUT_LINE('====== 本地OB端 ======');
  loc_pro1(v1,v2,p3=>v3,p4=>v4);
  DBMS_OUTPUT.PUT_LINE('存储过程结果：' || v2 || ',' || v3 || ',' || v4);
  v2 := loc_fun1(1);
  v3 := loc_fun2('function');
  v4 := loc_fun3(to_timestamp('04-06-2024 12:01:33.3333','dd-mm-yyyy hh24:mi:ss.ff'));
  DBMS_OUTPUT.PUT_LINE('函数结果：' || v2 || ',' || v3 || ',' || v4);
  loc_pck1.pack_pro(v2);
  DBMS_OUTPUT.PUT_LINE('包结果：' || v2);
  v2 := loc_pck1.pack_func(v2);
  DBMS_OUTPUT.PUT_LINE('包结果：' || v2);
  v2 := loc_seq1.nextval;
  DBMS_OUTPUT.PUT_LINE('序列结果：' || v2);
end;
/
