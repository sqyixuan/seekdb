  v1 varchar2(5000) := 'v1';
  v2 number := 2;
  v3 date := to_date('2024-06-12','yyyy-mm-dd');
  res varchar2(5000);
begin
  tnt1_pack1.pack_pro4@my_link1(p1=>v1,p2=>v2);
  res := tnt1_pack1.pack_get_constant@my_link1();
  DBMS_OUTPUT.PUT_LINE(res);
end;
