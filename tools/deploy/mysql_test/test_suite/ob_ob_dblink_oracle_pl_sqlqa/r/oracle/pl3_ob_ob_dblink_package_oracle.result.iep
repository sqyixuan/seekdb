  res := tnt1_pack1.pack_get_constant@my_link1();
  DBMS_OUTPUT.PUT_LINE(res);
  res := syn_tnt1_pack1.pack_func1@my_link1(v1,v3);
  res := tnt1_pack1.pack_get_constant@my_link1();
  DBMS_OUTPUT.PUT_LINE(res);
  res := syn_tnt1_pack1.pack_func1@my_link1(v2,v3);
  res := tnt1_pack1.pack_get_constant@my_link1();
