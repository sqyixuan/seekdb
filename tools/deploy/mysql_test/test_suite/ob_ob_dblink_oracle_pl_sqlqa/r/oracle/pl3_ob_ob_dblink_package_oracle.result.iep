##############################
######## 包中方法重载
## 连接远程ob端 dblink_tenant1
set autocommit= on;

create or replace package tnt1_pack1 is
  a1 varchar2(500) default 'tnt1_pack1 default';
  b1 NUMBER default 1001;
  c1 date default to_date('2024-01-01','yyyy-mm-dd');
  procedure pack_pro1;
  procedure pack_pro1 (p1 in varchar2);
  procedure pack_pro1 (p2 in number);
  procedure pack_pro1 (p3 in date);
  procedure pack_pro1 (p1 in varchar2,p2 in number);
  procedure pack_pro1 (p1 in varchar2,p3 in date);
  procedure pack_pro1 (p2 in number,p3 in date);
  procedure pack_pro1 (p1 in varchar2,p2 in number,p3 in date);
  
  function pack_func1 return varchar2;
  function pack_func1 (p1 in varchar2) return varchar2;
  function pack_func1 (p2 in number) return varchar2;
  function pack_func1 (p3 in date) return varchar2;
  function pack_func1 (p1 in varchar2,p2 in number) return varchar2;
  function pack_func1 (p1 in varchar2,p3 in date) return varchar2;
  function pack_func1 (p2 in number,p3 in date) return varchar2;
  function pack_func1 (p1 in varchar2,p2 in number,p3 in date) return varchar2;
  function pack_get_constant return varchar2;
end;
/
create or replace package body tnt1_pack1 is
  procedure pack_pro1 is
  begin
    a1 := '1 pack_pro1()';
  end;
  procedure pack_pro1(p1 in varchar2) is
  begin
    a1 := '2 pack_pro1(varchar2) '|| p1;
  end;
  procedure pack_pro1(p2 in number) is
  begin
    a1 := '3 pack_pro1(number) ';
    b1 := p2;
  end;
  procedure pack_pro1(p3 in date) is
  begin
    a1 := '4 pack_pro1(date) ';
    c1 := p3;
  end;
  procedure pack_pro1(p1 in varchar2,p2 in number) is
  begin
    a1 := '5 pack_pro1(varchar2,number) '|| p1;
	b1 := p2;
  end;
  procedure pack_pro1(p1 in varchar2,p3 in date) is
  begin
    a1 := '6 pack_pro1(varchar2,date) '|| p1;
	c1 := p3;
  end;
  procedure pack_pro1(p2 in number,p3 in date) is
  begin
    a1 := '7 pack_pro1(number,date) ';
	b1 := p2;
    c1 := p3;
  end;
  procedure pack_pro1(p1 in varchar2,p2 in number,p3 in date) is
  begin
    a1 := '8 pack_pro1(varchar2,number,date) '|| p1;
    b1 := p2;
    c1 := p3;
  end;
  
  function pack_func1 return varchar2 is
  begin
    a1 := '1 pack_func1()';
    return 'pack_func1()';
  end;
  function pack_func1(p1 in varchar2)  return varchar2 is
  begin
    a1 := '2 pack_func1(varchar2)' || p1;
	return 'pack_func1(varchar2)';
  end;
  function pack_func1(p2 in number) return varchar2 is
  begin
    a1 := '3 pack_pro1(number) ';
    b1 := p2;
	return 'pack_func1(number)';
  end;
  function pack_func1(p3 in date) return varchar2 is
  begin
    a1 := '4 pack_pro1(date) ';
    c1 := p3;
	return 'pack_func1(date)';
  end;
  function pack_func1(p1 in varchar2,p2 in number) return varchar2 is
  begin
    a1 := '5 pack_pro1(varchar2,number) ' || p1;
    b1 := p2;
	return 'pack_func1(varchar2,number)';
  end;
  function pack_func1(p1 in varchar2,p3 in date) return varchar2 is
  begin
    a1 := '6 pack_pro1(varchar2,date) ' || p1;
    c1 := p3;
	return 'pack_func1(varchar2,date)';
  end;
  function pack_func1(p2 in number,p3 in date) return varchar2 is
  begin
    a1 := '7 pack_pro1(number,date) ';
    b1 := p2;
    c1 := p3;
	return 'pack_func1(number,date)';
  end;
  function pack_func1(p1 in varchar2,p2 in number,p3 in date) return varchar2 is
  begin
    a1 := '8 pack_pro1(varchar2,number,date) ' || p1;
    b1 := p2;
    c1 := p3;
	return 'pack_func1(varchar2,number,date)';
  end;
  
  function pack_get_constant return varchar2 is
  begin
    return '[' ||a1 ||','|| b1 ||','|| c1 ||']';
  end;
end;
/

create or replace synonym syn_tnt1_pack1 for tnt1_pack1;

#### 调用方式
