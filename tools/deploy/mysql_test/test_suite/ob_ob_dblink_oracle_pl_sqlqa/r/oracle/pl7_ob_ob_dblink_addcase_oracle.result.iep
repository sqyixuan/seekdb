declare
  v1 varchar2(500);
  v2 char(500);
  v3 int;
  v4 number;
  v5 long;
  v6 float;
  v7 binary_float;
  v8 binary_double;
  v9 date;
  v10 timestamp;
  v11 timestamp with time zone;
  v12 timestamp with local time zone;
BEGIN
  V1 := 'local varchar2';
  V2 := 'local char';
  V3 := 20;
  V4 := 21;
  V5 := 'local long';
  V6 := 22.123;
  V7 := 23.456;
  V8 := 24.789;
  V9 := TO_DATE('2024-02-01', 'YYYY-MM-DD');
  V10 := TO_TIMESTAMP('2024-02-01 00:00:00', 'YYYY-MM-DD HH24:MI:SS');
  V11 := TO_TIMESTAMP('2024-02-01 00:00:00', 'YYYY-MM-DD HH24:MI:SS');
  V12 := TO_TIMESTAMP('2024-02-01 00:00:00', 'YYYY-MM-DD HH24:MI:SS');
  ori_pro2@my_link1(V1,V2,V3,V4,V5,V6,V7,V8,V9,V10,V11,V12);
  DBMS_OUTPUT.PUT_LINE('字符类型参数：' || V1||V2||V5);
  DBMS_OUTPUT.PUT_LINE('数字类型参数：' || V3||V4||V6||V7||V8);
  DBMS_OUTPUT.PUT_LINE('日期类型参数：' || V9||V10||V11||V12);
end;
/
