| c1     |
+--------+
|   1.23 |
| 999.99 |
|   1.23 |
|   1.23 |
|   1.23 |
+--------+
drop table t1, t2;

set sql_mode = 'STRICT_ALL_TABLES';

create table t1 (c1 decimal(5,2));
insert into t1 values (1.234);
Warnings:
Warning	1265	Data truncated for column 'c1' at row 1
insert into t1 values (1234.4321);
ERROR 22003: Out of range value for column 'c1' at row 1
insert into t1 values ('1.234');
Warnings:
Warning	1265	Data truncated for column 'c1' at row 1

create table t2 (c1 decimal(5, 3), c2 double(5,3));
insert into t2 values (1.234, 1.2345);
insert into t1 select c1 from t2;
Warnings:
Warning	1265	Data truncated for column 'c1' at row 1
insert into t1 select c2 from t2;
Warnings:
Warning	1265	Data truncated for column 'c1' at row 1

select * from t1;
+------+
| c1   |
+------+
| 1.23 |
| 1.23 |
| 1.23 |
| 1.23 |
+------+
drop table t1, t2;

set sql_mode = '';
