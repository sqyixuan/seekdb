result_format: 4
drop table molly_nn;
#const numbers
create table molly_nn as select 1.00 as b, 0.035 as c, 0.8376439437 as d, 3.8237438E10 as e, 3472891678543.89302418 as f from dual;
desc molly_nn;
+-------+----------------+------+-----+--------------+-------+
| Field | Type           | Null | Key | Default      | Extra |
+-------+----------------+------+-----+--------------+-------+
| b     | decimal(3,2)   | NO   |     | 0.00         |       |
| c     | decimal(4,3)   | NO   |     | 0.000        |       |
| d     | decimal(11,10) | NO   |     | 0.0000000000 |       |
| e     | double         | NO   |     | 0            |       |
| f     | decimal(21,8)  | NO   |     | 0.00000000   |       |
+-------+----------------+------+-----+--------------+-------+
#double 3.8237438E10 is not correct for now bug#18360384
select * from molly_nn;
+------+-------+--------------+-------------+------------------------+
| b    | c     | d            | e           | f                      |
+------+-------+--------------+-------------+------------------------+
| 1.00 | 0.035 | 0.8376439437 | 38237438000 | 3472891678543.89302418 |
+------+-------+--------------+-------------+------------------------+
drop table molly_nn;

