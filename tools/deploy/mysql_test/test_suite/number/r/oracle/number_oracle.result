show create table t_number;
TABLE	CREATE TABLE
T_NUMBER	CREATE TABLE "T_NUMBER" (
  "ID" NUMBER(*,0),
  "C1" NUMBER(*,0),
  "C2" NUMBER(*,3),
  "C3" NUMBER(*,-5)
) REPLICA_NUM = NUM BLOCK_SIZE = SIZE USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = SIZE PCTFREE = 10
