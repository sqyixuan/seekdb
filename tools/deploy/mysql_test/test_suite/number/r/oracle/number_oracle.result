insert into t_number values(5, rpad('-9.', 42, '9'), rpad('-9.', 42, '9'), rpad('-9.', 42, '9'));
insert into t_number values(6, rpad('0.01', 43, '9'), rpad('0.01', 43, '9'), rpad('0.01', 43, '9'));
