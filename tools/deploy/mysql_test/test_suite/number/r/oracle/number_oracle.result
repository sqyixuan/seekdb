|    1 |   9999999999999999999999999999999999999999 |   9999999999999999999999999999999999999999 |  10000000000000000000000000000000000000000 |
|    2 |   9999999999999999999999999999999999999999 |   9999999999999999999999999999999999999999 |  10000000000000000000000000000000000000000 |
|    3 | 100000000000000000000000000000000000000000 | 100000000000000000000000000000000000000000 | 100000000000000000000000000000000000000000 |
|    4 |             999999999999999999999999999999 |         999999999999999999999999999999.346 |            1000000000000000000000000000000 |
|    5 |                                        -10 |                                        -10 |                                          0 |
|    6 |                                          0 |                                        .02 |                                          0 |
+------+--------------------------------------------+--------------------------------------------+--------------------------------------------+
drop table t_number;
select cast(rpad('9', 30, '9')||'.345643232' as number(*, 5)), cast(rpad('9', 30, '9')||'.3456324' as number(*, -1)) from dual;
+---------------------------------------------------+--------------------------------------------------+
| CAST(RPAD('9',30,'9')||'.345643232'ASNUMBER(*,5)) | CAST(RPAD('9',30,'9')||'.3456324'ASNUMBER(*,-1)) |
+---------------------------------------------------+--------------------------------------------------+
|              999999999999999999999999999999.34564 |                  1000000000000000000000000000000 |
+---------------------------------------------------+--------------------------------------------------+
create view v_number as select cast(rpad('9', 30, '9')||'.345643232' as number(*, 5)) as c1, cast(rpad('9', 30, '9')||'.3456324' as number(*, -1)) as c2 from dual;
desc v_number;
+-------+--------------+------+-----+---------+-------+
| FIELD | TYPE         | NULL | KEY | DEFAULT | EXTRA |
+-------+--------------+------+-----+---------+-------+
| C1    | NUMBER(*,5)  | NO   | NULL | NULL    | NULL  |
| C2    | NUMBER(*,-1) | NO   | NULL | NULL    | NULL  |
+-------+--------------+------+-----+---------+-------+
show create view v_number;
VIEW	CREATE VIEW	CHARACTER_SET_CLIENT	COLLATION_CONNECTION
V_NUMBER	CREATE VIEW "V_NUMBER" ("C1", "C2")  AS select cast(rpad('9', 30, '9')||'.345643232' as number(*, 5)) as c1, cast(rpad('9', 30, '9')||'.3456324' as number(*, -1)) as c2 from dual	utf8mb4	utf8mb4_bin
select * from v_number;
+--------------------------------------+---------------------------------+
| C1                                   | C2                              |
+--------------------------------------+---------------------------------+
| 999999999999999999999999999999.34564 | 1000000000000000000000000000000 |
+--------------------------------------+---------------------------------+
drop view v_number;

create table t_number(id int, c1 number, c2 number(*));
