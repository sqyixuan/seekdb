insert into t_number values(2, rpad('9', 40, '9'), rpad('9', 40, '9'), rpad('9', 40, '9'));
insert into t_number values(3, rpad('9', 41, '9'), rpad('9', 41, '9'), rpad('9', 41, '9'));
