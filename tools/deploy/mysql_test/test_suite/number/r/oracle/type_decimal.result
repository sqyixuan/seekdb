2.000	4	2
3.000	3	3
4.000	2	4
5.000	1	5
SELECT a, b, ROUND( a, b ) AS c FROM t1 ORDER BY c DESC;
a	b	c
5.000	1	5
4.000	2	4
3.000	3	3
2.000	4	2
1.000	5	1
