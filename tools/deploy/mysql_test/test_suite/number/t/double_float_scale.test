--disable_warnings
drop table if exists t_integer;
drop table if exists t_decimal;
drop table if exists t_exp;
drop table if exists t_spec;
drop table if exists double_float2;
--enable_warnings


let $integer_cnt=6;
create table t_integer(id int, c1 varchar(20));
insert into t_integer values (1,'0');
insert into t_integer values (2,'-1');
insert into t_integer values (3,'1');
insert into t_integer values (4,'1234567890');
insert into t_integer values (5,'-1234567890');
insert into t_integer values (6,'');

let $decimal_cnt=2;
create table t_decimal(id int, c1 varchar(60));
insert into t_decimal values (1,'0');
insert into t_decimal values (2,'12345678901234567890123456789012345678901234567890');

let $exp_cnt=41;
create table t_exp(id int, c1 varchar(20));
let $cnt=1;
while ($cnt <= 20)
{
  eval insert into t_exp values ($cnt,'e$cnt');
  inc $cnt;
}
let $cnt=1;
while ($cnt <= 20)
{
  eval insert into t_exp values (20 + $cnt,'e-$cnt');
  inc $cnt;
}
insert into t_exp values (41,'e0');

