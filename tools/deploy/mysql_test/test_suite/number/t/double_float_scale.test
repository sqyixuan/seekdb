--disable_warnings
drop table if exists double_float;
--enable_warnings
create table double_float(a double(5,3),b float(5,3));
insert into double_float value(0,0);
insert into double_float value(0.1,0.1);
insert into double_float value(0.22,0.22);
insert into double_float value(0.333,0.333);
insert into double_float value(0.4444,0.4444);
insert into double_float value(0.999999,0.999999);
insert into double_float value(0.8999,0.8999);
insert into double_float value(5,5);
insert into double_float value(66,66);
--error 1264
insert into double_float value(777,777);
select * from double_float;
select cast(a as char(10)), cast(b as char(10)) from double_float;
select cast(a as char(2)), cast(b as char(2)) from double_float;
select convert(a, char(10)), convert(b, char(10)) from double_float;
select convert(a, char(2)), convert(b, char(2)) from double_float;

