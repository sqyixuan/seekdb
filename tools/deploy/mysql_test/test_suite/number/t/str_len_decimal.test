#description: 测试当字符串长度类型为decimal时的表现
# owner: zuojiao.hzj
# owner group: SQL2
# tags: datatype

select hex(cast('a' as binary(1)));
select hex(cast('a' as binary(1.2)));
select hex(cast('a' as binary(3.2)));
select hex(cast('a' as binary(3.7)));
--error ER_PARSE_ERROR
select convert('a' , binary(-1));
select convert('a' , binary(0));
--error 1439
select convert('a' , binary(10000000000000000000000));
--error 1439
select convert('a' , binary(4294967296));
--error 1439
select convert('a' , binary(4294967296.0));

select convert('a' , binary(4294967295));
select convert('a' , binary(4294967295.0));
select convert('a' , binary(4294967294));
select convert('a' , binary(4294967294.0));
