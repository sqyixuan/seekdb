# owner: zuojiao.hzj
# owner group: SQL2
# tags: datatype
# Test of cast to int with ending '.' or space
--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--enable_abort_on_error
connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn1;

--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(a int, b float);
--error 1265
insert into t1 values('1.1.', '9.9');
--error 1265
insert into t1 values(' 1.1.', '9.9');
--error 1265
insert into t1 values('1.1. ', '9.9');
--error 1265
insert into t1 values(' 1.1. ', '9.9');
insert into t1 values(' 9', ' 9.9');
insert into t1 values('9 ', '9.9 ');
insert into t1 values(' 9 ', ' 9.9 ');
insert into t1 values(' 9.9', ' 9.9');
insert into t1 values('9.9 ', '9.9 ');
insert into t1 values(' 9.9 ', ' 9.9 ');
select * from t1;

--disable_warnings
drop table if exists t1;
--enable_warnings
