--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# Test of uint functions
# owner: zuojiao.hzj
# owner group: SQL2
# tags: datatype, optimizer


# test of unsigned int
#

--disable_warnings
drop table if exists t1;
--enable_warnings
#SET SQL_WARNINGS=1;
set sql_mode='';
create table t1 (this int unsigned primary key);
insert into t1 values (1);
insert into t1 values (-1);
insert into t1 values ('5000000000');
select * from t1;
drop table t1;
set sql_mode='STRICT_TRANS_TABLES';

# End of 4.1 tests
