#Precision and scale check
drop table t1;
create table t1 (c1 decimal(5,3), c2 int, primary key(c2));
desc t1;
insert into t1 values (12.3456, 1);
insert into t1 values (12.3454, 2);
--error 1264
insert into t1 values (123.456, 3);
select * from t1;
select * from t1 where c1=12.346;
select * from t1 where c1=12.345;

drop table t1;
create table t1 (c1 decimal(5,3), c2 int, primary key(c2));
