set div_precision_increment = 0;
create table stu(s1 decimal(2), s2 decimal(20) generated always as(s1/5));
insert into stu(s1) values (99);
select * from stu;
select 99/5 from dual;
set div_precision_increment = 1;
insert into stu(s1) values (99);
select * from stu;
select 99/5 from dual;
set div_precision_increment = 4;
insert into stu(s1) values (99);
select * from stu;
select 99/5 from dual;
drop table stu;

set sql_mode = '';
create table t1 (c1 decimal(5,2));
insert into t1 values (1.234);
insert into t1 values (1234.4321);
insert into t1 values ('1.234');

create table t2 (c1 decimal(5, 3), c2 double(5,3));
insert into t2 values (1.234, 1.2345);
insert into t1 select c1 from t2;
insert into t1 select c2 from t2;

select * from t1;
drop table t1, t2;

set sql_mode = 'STRICT_ALL_TABLES';

create table t1 (c1 decimal(5,2));
insert into t1 values (1.234);
--error 1264
insert into t1 values (1234.4321);
insert into t1 values ('1.234');

create table t2 (c1 decimal(5, 3), c2 double(5,3));
insert into t2 values (1.234, 1.2345);
insert into t1 select c1 from t2;
insert into t1 select c2 from t2;

select * from t1;
drop table t1, t2;

set sql_mode = '';
create table t1 (c1 decimal(10, 2) unsigned);
insert into t1 values (1);
update t1 set c1 = -1.66e0;
select * from t1;
drop table t1;

set sql_mode = 'STRICT_ALL_TABLES';
CREATE TABLE t1(c1 TIME NULL, c2 CHAR(25) NOT NULL, c3 INTEGER(4) NULL, c4 CHAR(15) NOT NULL PRIMARY KEY, c5 TIME NOT NULL UNIQUE KEY,c6 DEC(10,8) NOT NULL DEFAULT 3.141592); 
insert INTO t1  values (-10,2,3,4,5,6); 
--error 1264
ALTER TABLE t1 CHANGE c1 c1 DECIMAL(23,11) UNSIGNED, CHANGE c2 c2 DECIMAL(23,11) ;
--error 1264
ALTER TABLE t1 MODIFY c1 DOUBLE UNSIGNED ZEROFILL NULL; 
set sql_mode = '';
ALTER TABLE t1 CHANGE c1 c1 DECIMAL(23,11) UNSIGNED, CHANGE c2 c2 DECIMAL(23,11) ;
select * from t1;
ALTER TABLE t1 MODIFY c1 DOUBLE UNSIGNED ZEROFILL NULL; 
select * from t1;
drop table t1;

select cast( '303030303030303030303030303030303030303030303030303030303030303030303030303030303030303030303030303030303030303030303030303030303639320444' as decimal(10, 0)) ;
select '303030303030303030303030303030303030303030303030303030303030303030303030303030303030303030303030303030303030303030303030303030303639320444' is true;
select cast('303030303030303030303030303030303030303030303030303030303030303030303030303030303030303030303030303030303030303030303030303030303639320444' as decimal(10, 0)) is true;

CREATE TABLE t1 (
    c0 INT(100) ZEROFILL UNIQUE
) PARTITION BY HASH (c0) partitions 1 WITH COLUMN GROUP (all columns, each column);

INSERT INTO t1 (c0) VALUES (64804693);

SELECT true FROM t1 WHERE HEX(concat(t1.c0, ''));
SELECT true FROM t1 WHERE HEX(concat(t1.c0, '')) IS TRUE;

drop table t1;
CREATE TABLE t1 (c1 varchar(10), pk int(11), PRIMARY KEY (pk)) ;
UPDATE t1 SET c1 = 1 WHERE pk IN (REPEAT( 0x3835 , 156 ) );
drop table t1;