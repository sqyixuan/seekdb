--result_format 4
--disable_warnings
--error 0, 1051
drop table molly_nn;
--enable_warnings

--echo #const numbers
create table molly_nn as select 1.00 as b, 0.035 as c, 0.8376439437 as d, 3.8237438E10 as e, 3472891678543.89302418 as f from dual;
desc molly_nn;
--echo #double 3.8237438E10 is not correct for now bug#18360384
select * from molly_nn;
drop table molly_nn;


