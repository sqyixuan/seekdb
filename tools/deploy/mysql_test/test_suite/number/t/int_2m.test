--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: zuojiao.hzj
# owner group: SQL2
# tags: datatype

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1(pk int primary key, c1 int,c2 int ,c3 int , c4 int, c5 int,c6 int,c7 int);

--disable_query_log
let $cnt=100000;
while($cnt)
{
  eval insert into t1 values($cnt,$cnt,$cnt,$cnt,$cnt,$cnt,$cnt,$cnt);
  dec $cnt;
}
--enable_query_log

select pk,c1,c2,c3,c4,c5,c6,c7 from t1;


