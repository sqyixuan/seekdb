create table t1(pk int primary key, n1 numeric(8,5));
insert into t1 values(1,0.123456),(2,1.234567),(3,12.345678),(4,'123.456789'),(5,1),(6,1.23),(7,0.23),(8,-0.123456),(9,-1.234567),(10,-12.345678),(11,'-123.456789'),(12,-1),(13,-1.46),(14,123.123456789),(15,-1.23456789123456789),(16,0),(17,120.55);
select * from t1;
select n1,round(n1) from t1;
select n1,round(n1,1) from t1;
select n1,round(n1,-1) from t1;

select pk,n1,round(n1,n1) from t1 where pk<>11;

select max(n1)-min(n1),round(max(n1)-min(n1)),round(max(n1)-min(n1),4),round(max(n1)-min(n1),-2),min(n1)-max(n1),round(min(n1)-max(n1)),round(min(n1)-max(n1),4),round(min(n1)-max(n1),-2) from t1;
select min(n1) from t1;
select min(n1)+1 from t1;
select 1+min(n1) from t1;

--sorted_result
select n1,round(n1,2),max(round(n1)),round(n1,2)-max(round(n1)),round(round(n1,2)-max(round(n1)),1) from t1 group by n1;

select sum(n1) from t1;

select sum(n1),round(sum(n1),-1),round(sum(n1),1),round(sum(n1))from t1;

select avg(n1) from t1;

select avg(n1),round(avg(n1),-1),round(avg(n1),1),round(avg(n1))from t1;

