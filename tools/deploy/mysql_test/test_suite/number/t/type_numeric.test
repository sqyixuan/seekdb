##
create table t1 (pk int primary key, n1 numeric(3,2));
insert into t1 values(1,1.01),(2,1.99),(3,0.01),(4,0.99),(5,1.01),(6,1.990),(7,1.0123),(8,0.999),(9,1),(10,-1.99),(11,-1);
select * from t1 where n1=1.01;
select * from t1 where n1=1.99;
select * from t1 where n1=0.999;
select * from t1 where n1=1;
select * from t1 where n1='0.999';
select * from t1 where n1='1.01';
select * from t1 where n1>=0.999;
select * from t1 where n1<=1;
select * from t1 where n1>1.5;
select * from t1 where n1<0.8;
select * from t1 where n1 between 1.0111 and 1.895;
select * from t1 where n1 in (1.01,1.993);
select count(*) from t1 where n1=1.01;
select max(n1) from t1;
select min(n1) from t1;
select avg(n1) from t1;
select sum(n1) from t1;
drop table t1;


##
create table t1(pk1 int, pk2 numeric, n1 int, primary key(n1));
insert into t1(pk1,pk2,n1) values(1, 28.50,1), (1, 121.85,2), (1, 157.23,3), (1, 1351.00,4), (1, -1965.35,5), (1, 81.75,6), (1, 217.08,7), (1, 7.94,8), (4, 96.07,9), (4, 6404.65,10), (4, -6500.72,11), (2, 100.00,12),(5, 5.00,13), (5, -2104.80,14), (5, 2033.80,15), (5, 0.07,16), (5, 65.93,17),(3, -4986.24,18), (3, 5.00,19), (3, 4857.34,20), (3, 123.74,21), (3,  0.16,22),(6, -1695.31,23), (6, 1003.77,24), (6, 499.72,25), (6, 191.82,26);
--sorted_result
select sum(pk2) s from t1 group by pk1;
--sorted_result
select sum(pk2) s from t1 group by pk1 having s<>0;
--sorted_result
select sum(pk2) s from t1 group by pk1 having s=0;
select sum(pk2) s from t1 group by pk1 having s=0 order by s;
--sorted_result
select avg(pk2) a from t1 group by pk1;
drop table t1;
