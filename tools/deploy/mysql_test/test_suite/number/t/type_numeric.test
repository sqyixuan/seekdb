##
create table t1(pk int primary key, n1 numeric, n2 numeric);
insert into t1 values(0,2,0),(1,2,2),(2,0,1),(3,-1,1.01),(4,-1.02,3);
select sum(n1+n2) from t1;
select (n1/n2) from t1;
select sum(n1/n2) from t1;
select sum(n1-n2) from t1;
select sum(n1*n2) from t1;
select (n1+n2),(n1-n2+2) from t1;
select sum((n1+n2)/(n1-n2+2)) from t1;

select sum(n1*0.01) from t1;
select sum(n1*0) from t1;
select sum(n1-1) from t1;
select sum(n1-0) from t1;
select sum(0-n1) from t1;
select sum(-n1) from t1;
select sum(n1/1.0) from t1;
select sum(n1*1.0) from t1;

select avg(n1+n2) from t1;
select avg((n1+n2)/(n1-n2+2)) from t1;
select avg(n1-n2) from t1;
select avg(n1*n2) from t1;

select avg(n1*0.01) from t1;
select avg(n1*0) from t1;
select avg(n1-1) from t1;
select avg(n1-0) from t1;
select avg(0-n1) from t1;
select avg(-n1) from t1;
select avg(n1/1.0) from t1;
select avg(n1*1.0) from t1;

select max(n1+n2) from t1;
select max((n1+n2)/(n1-n2+2)) from t1;
select max(n1-n2) from t1;
select max(n1*n2) from t1;

select max(n1*0.01) from t1;
select max(n1*0) from t1;
select max(n1-1) from t1;
select max(n1-0) from t1;
select max(0-n1) from t1;
select max(-n1) from t1;
select max(n1/1.0) from t1;
select max(n1*1.0) from t1;

select min(n1+n2) from t1;
select min((n1+n2)/(n1-n2+2)) from t1;
select min(n1-n2) from t1;
select min(n1*n2) from t1;

select min(n1*0.01) from t1;
select min(n1*0) from t1;
select min(n1-1) from t1;
select min(n1-0) from t1;
select min(0-n1) from t1;
select min(-n1) from t1;
select min(n1/1.0) from t1;
select min(n1*1.0) from t1;

drop table t1;

