--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t_number;
insert into t_number values(1, rpad('9', 40, '9')||'.3456', rpad('9', 40, '9')||'.3456', rpad('9', 40, '9')||'.3456');
insert into t_number values(2, rpad('9', 40, '9'), rpad('9', 40, '9'), rpad('9', 40, '9'));
insert into t_number values(3, rpad('9', 41, '9'), rpad('9', 41, '9'), rpad('9', 41, '9'));
insert into t_number values(4, rpad('9', 30, '9')||'.3456', rpad('9', 30, '9')||'.3456', rpad('9', 30, '9')||'.3456');
insert into t_number values(5, rpad('-9.', 42, '9'), rpad('-9.', 42, '9'), rpad('-9.', 42, '9'));
insert into t_number values(6, rpad('0.01', 43, '9'), rpad('0.01', 43, '9'), rpad('0.01', 43, '9'));
select * from t_number;
drop table t_number;
select cast(rpad('9', 30, '9')||'.345643232' as number(*, 5)), cast(rpad('9', 30, '9')||'.3456324' as number(*, -1)) from dual;
create view v_number as select cast(rpad('9', 30, '9')||'.345643232' as number(*, 5)) as c1, cast(rpad('9', 30, '9')||'.3456324' as number(*, -1)) as c2 from dual;
desc v_number;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create view v_number;
select * from v_number;
drop view v_number;


create table t_number(id int, c1 number, c2 number(*));
desc t_number;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t_number;
insert into t_number values(1, rpad('9', 40, '9')||'.3456', rpad('9', 40, '9')||'.3456');
insert into t_number values(2, rpad('9', 40, '9'), rpad('9', 40, '9'));
insert into t_number values(3, rpad('9', 41, '9'), rpad('9', 41, '9'));
insert into t_number values(4, rpad('9', 30, '9')||'.3456', rpad('9', 30, '9')||'.3456');
insert into t_number values(5, rpad('-9.', 42, '9'), rpad('-9.', 42, '9'));
insert into t_number values(6, rpad('0.01', 43, '9'), rpad('0.01', 43, '9'));
select * from t_number;
drop table t_number;
select cast(rpad('9', 30, '9')||'.345643232' as number), cast(rpad('9', 30, '9')||'.3456324' as number(*)) from dual;
create view v_number as select cast(rpad('9', 30, '9')||'.345643232' as number) as c1, cast(rpad('9', 30, '9')||'.3456324' as number(*)) as c2 from dual;
desc v_number;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create view v_number;
select * from v_number;
drop view v_number;


