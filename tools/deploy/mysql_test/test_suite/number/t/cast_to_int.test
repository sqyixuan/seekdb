--disable_warnings
drop table if exists t1;
--enable_warnings
select cast(sum(0) as datetime);
create table t1(a decimal(30,6), b datetime(4));
insert into t1(a) values(20150407120309.23456789);
insert into t1(a) values(20150407120309.23);
insert into t1(a) values(20150407120309);
update t1 set b = a;
select * from t1;

--disable_warnings
drop table if exists t1;
--enable_warnings
select cast(sum(0) as datetime);
create table t1(a decimal(30,3), b datetime(6));
insert into t1(a) values(20150407120309.23456789);
insert into t1(a) values(20150407120309.23);
insert into t1(a) values(20150407120309);
update t1 set b = a;
select * from t1;

--disable_warnings
drop table if exists t1;
--enable_warnings
select cast(sum(0) as datetime);
create table t1(a decimal(30,3), b datetime(3));
insert into t1(a) values(20150407120309.23456789);
insert into t1(a) values(20150407120309.23);
insert into t1(a) values(20150407120309);
insert into t1(a) values(0.23);
insert into t1(a) values(0.2388888);
update t1 set b = a;
select * from t1;
insert into t1(a) values(10.23);
insert into t1(a) values(23);
select cast(a as datetime) from t1;
