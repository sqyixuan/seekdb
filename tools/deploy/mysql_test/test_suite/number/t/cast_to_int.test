# Test of cast to int functions

--enable_abort_on_error
connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn1;
##
#round
select cast('9.5' as signed int);
select cast('-9.5' as signed int);
select cast('9.4' as signed int);
select cast('-9.4' as signed int);

select cast(9.5 as signed int);
select cast(-9.5 as signed int);
select cast(9.4 as signed int);
select cast(-9.4 as signed int);

####################################################################################################

#positive max
select cast('9223372036854775807' as signed int);
select cast('9223372036854775807.4' as signed int);
select cast('9223372036854775807.5' as signed int);
select cast('9223372036854775808' as signed int);

select cast(9223372036854775807 as signed int);
select cast(9223372036854775807.4 as signed int);
select cast(9223372036854775807.5 as signed int);
select cast(9223372036854775808 as signed int);

####################################################################################################

#negative max
select cast('-9223372036854775808' as signed int);
select cast('-9223372036854775808.4' as signed int);
select cast('-9223372036854775808.5' as signed int);
select cast('-9223372036854775809' as signed int);

select cast(-9223372036854775808 as signed int);
select cast(-9223372036854775808.4 as signed int);
select cast(-9223372036854775808.5 as signed int);
select cast(-9223372036854775809 as signed int);

####################################################################################################

#invalid char
select cast(' 9' as signed int);
select cast('9 ' as signed int);
select cast(' 9 ' as signed int);
select cast(' 9.9' as signed int);
select cast('9.9 ' as signed int);
select cast(' 9.9 ' as signed int);

select cast(9 as signed int);
select cast(9.9 as signed int);

