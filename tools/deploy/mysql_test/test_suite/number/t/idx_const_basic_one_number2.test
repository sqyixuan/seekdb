--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: zuojiao.hzj
# owner group: SQL2
# Test of numeric idx functions
# tags: datatype
#
--source mysql_test/include/index_quick_major.inc
#case:int as idx
--disable_warnings
drop table if exists tbl1;
--enable_warnings
create table tbl1 (pk int,i1 int, v2 varchar(80), i3 char(20),i4 NUMERIC, d4 datetime(6),i5 double,i6 bool, primary key(pk));
insert into tbl1 values(1,1,'abc12','1agc',1.25,'2014-01-01 12:00:00',23.23,1),
                       (2,10,'23abc12','4agc1',-0.25,'2015-11-01 12:00:00',-23.230,0),
                       (3,201,'xx23abc12','cagc1',-2.25,'2015-11-21 11:20:10',3.231,1),
                       (4,80,'zx23abc12','zcagc1',2.25,'2013-01-21 11:20:10',-3.231,1),
                       (5,53,'cx23abc12','rcagc1',109.25,'2016-01-22 11:20:10',-13.131,0),
                       (6,78,'tx23abc12','icagc1',-109.25,'2014-09-16 16:24:00',-13.131,1),
                       (7,400,'yx23abc12','ocagc1',85.85,'2014-09-17 16:20:21',-93.131,0),
                       (8,50,'vx23abc12','wcagc1',-85.85,'2014-09-15 16:20:21',93.131,1),
                       (9,610,'ukx23abc12','pecagc1',-1.85,'2014-09-19 16:20:21',99.131,0),
                       (10,42,'kx23abc12','ecagc1',-85.85,'2014-09-18 16:20:21',-99.131,1),
                       (11,null,null,null,null,null,null,null);
create index idx_1 on tbl1(v2);
--source mysql_test/include/check_all_idx_ok.inc
select * from tbl1 where i4>-150.123 and i4<=1000.1234;
select * from tbl1 where i4>-150.455434+2.36 and i4<1000.1234; 
select * from tbl1 where i4>-150.123 and i4<1000.1234-10; 
select * from tbl1 where i4>-150.455434+2.36 and i4<1000.1234-10; 
select * from tbl1 where i4>1*-150.455434+2.36 and i4<1000.1234; 
select * from tbl1 where i4>-150.123 and i4<=1000.1234*2; 
select * from tbl1 where i4>-110*2+3 and i4<=1000.1234*2; 
select * from tbl1 where i4>-10*50/5+1 and i4<=1000.1234*2/2+1; 
select * from tbl1 where i4>-500.1 and i4<=1000.1234*2/2+1; 
select * from tbl1 where i4>-50*5+3 and i4<=1000.1234; 
select * from tbl1 where i4>(19 mod 10)-100.1 and i4<=1000.1234; 
select * from tbl1 where i4>(19 mod 10)-100.5 and i4<=(1000.1234 mod 1001) +10; 
select * from tbl1 where i4>-150.123 and i4<=(1000.1234 mod 1001) +10; 
select * from tbl1 where i4>-110.123+0 and i4<=(1000.1234*1001) +10; 
select * from tbl1 where i4>=-110+null and i4<=(1000.1234*1001) +10; 
select * from tbl1 where i4>=-150.455434+2.36 and i4<=(1000.1234*2) +null; 
select * from tbl1 where i4>=-150.455434+2.36 and i4<=(1000.1234*2) or i4 is null; 
select * from tbl1 where i4>=-150.455434+2.36 and i4<=(1000.1234*2) and i4 is null; 
select * from tbl1 where i4>=-150.455434+2.36 and i4<=(1000.1234*2) and i4 is not  null; 
select * from tbl1 where i4>=-150.455434+2.36 and i4<=(100*2) or i1 = 610; 
select * from tbl1 where i4>=-150.455434+2.36 and i4<=(100*2) or i3 = 'cx23abc12'; 
select * from tbl1 where i4>=-150.455434+2.36 and i4<=(100*2) and i5  between 0 and 1000.1234; 
select * from tbl1 where i4>=-150.455434+2.36 and i4<=(100*10) and i5  between -100 and 1000.1234;
select * from tbl1 where i4<=round(1000.1234) and i4>=round(-200.5);
#case:more than noe cloumn idx
drop index idx_1 on tbl1;
create index idx_2 on tbl1(v2,i3);
--source mysql_test/include/check_all_idx_ok.inc
