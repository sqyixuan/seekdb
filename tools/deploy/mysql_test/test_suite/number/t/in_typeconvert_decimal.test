#####bug:
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(a int primary key,b int);
insert into t1 values(1,1),(2,2),(3,3),(4,4),(0,0),(-1,-1);
select * from t1;
select * from t1 where a in (0,abs(-1.0));
select * from t1 where a in (5,0,abs(-1.0));
select * from t1 where a in (5,0,4/2);
select * from t1 where a in (5,2/1,4/2);
select * from t1 where a in (5,2/1,sign(b*1.0));
