--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: zuojiao.hzj
# owner group: SQL2
# tags: datatype

#
--enable_abort_on_error
--disable_warnings
drop table if exists t5;
--enable_warnings
create table t5  (c1 decimal(5,3) default 12.3456, c2 int, primary key(c2));
desc t5;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t5;
alter table t5 alter column c1 set default 12.3454;
sleep 1;
desc t5;
--error 1067 
alter table t5 alter column c1 set default 123.4;
sleep 1;
desc t5;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t5;
--disable_warnings
drop table if exists t6;
--enable_warnings
create table t6  (c1 decimal(5,3) default 12.3456, c2 int, primary key(c2));
desc t5;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t6;
alter table t6 alter column c1 set default 12.3454;
sleep 1;
desc t6;
--error 1067
alter table t6 alter column c1 set default 123.4;
sleep 1;
desc t6;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t6;
