--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: zuojiao.hzj
# owner group: SQL2
# tags: datatype

--disable_query_log
--disable_result_log
--source mysql_test/include/index_quick_major.inc
--enable_query_log
--enable_result_log

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1(pk int primary key , c1 decimal(27),c2 decimal(27) ,c3 decimal(27) , c4 decimal(27), c5 decimal(27),c6 decimal(27),c7 decimal(27),c8 decimal(27), c9 decimal(27),c10 decimal(27),c11 decimal(27),c12 decimal(27),c13 decimal(27),c14 decimal(27),c15 decimal(27),c16 decimal(27), c17 decimal(27),c18 decimal(27) ,c19 decimal(27) , c20 decimal(27), c21 decimal(27),c22 decimal(27),c23 decimal(27),c24 decimal(27), c25 decimal(27),c26 decimal(27),c27 decimal(27),c28 decimal(27),c29 decimal(27),c30 decimal(27),c31 decimal(27),c32 decimal(27));


--disable_query_log

## 32 cols * 16 bytes each number * 10000 > 2 * 1024 *1024
## should be more than 2M

let $cnt=5000;
while($cnt)
{
  eval insert into t1 values($cnt,999999999999999999999999999,999999999999999999999999999, 999999999999999999999999999, 999999999999999999999999999,999999999999999999999999999,999999999999999999999999999,999999999999999999999999999, 999999999999999999999999999,999999999999999999999999999,999999999999999999999999999, 999999999999999999999999999, 999999999999999999999999999,999999999999999999999999999,999999999999999999999999999,999999999999999999999999999, 999999999999999999999999999,999999999999999999999999999,999999999999999999999999999, 999999999999999999999999999, 999999999999999999999999999,999999999999999999999999999,999999999999999999999999999,999999999999999999999999999, 999999999999999999999999999,999999999999999999999999999,999999999999999999999999999, 999999999999999999999999999, 999999999999999999999999999,999999999999999999999999999,999999999999999999999999999,999999999999999999999999999, 999999999999999999999999999);
  dec $cnt;
}
--enable_query_log

select * from t1;

####����������ڵı��������ݽ϶࣬�ںϲ��Ĺ����У�ɾ����
sleep 1;
alter table t1 set expire_info (pk<=100000);
sleep 1;
--source mysql_test/include/majorfreeze.inc
sleep 2;
drop table t1;
--source mysql_test/include/wait_daily_merge.inc



