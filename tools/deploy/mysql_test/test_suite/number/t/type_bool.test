--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# Test of bool functions
# owner: zuojiao.hzj
# owner group: SQL2
# tags: datatype

--disable_warnings
drop table if exists t1;
#signed test bool <> tinyint
create table t1(pk int primary key,c1 bool, c2 tinyint);
insert into t1 values (1,1,1);
insert into t1 values (2,True,True);
insert into t1 values (3,0,0);
insert into t1 values (4,False,False);
insert into t1 values (5,127,127);
insert into t1 values (6,-128,-128);
insert into t1 values (7, '4' ,'4');
insert into t1 values (8, '-4','-4');
--error 1264
insert into t1 values (9, 128,128);
#--error SHY000
#insert into t1 values (10, '128','128');
--error 1264
insert into t1 values (11, -129, -129);
#--error SHY000
#insert into t1 values (12, '-129', '-129');
--error SHY000
insert into t1 values (13,'a','a');
select * from t1;

#unsigned test
drop table t1;
--error 1064
create table t1 (pk int primary key, c1 bool unsigned, c2 tinyint unsigned);

--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1 (pk int primary key, c1 bool, c2 tinyint unsigned);
insert into t1 values (1,1,1);
insert into t1 values (2,True,True);
insert into t1 values (3,0,0);
insert into t1 values (4,False,False);
insert into t1 values (5,127,255);
insert into t1 values (6,-128,'255');
--error 1264
insert into t1 values (7, 5, 256);
--error 1264
insert into t1 values (8, -1, -1);
select * from t1;
drop table t1;



