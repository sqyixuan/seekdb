set sql_mode='';
drop table if exists t;
create table t(
id            int auto_increment primary key, 
col_int       bigint,
col_uint      bigint unsigned,
col_float     float,
col_double    double,
col_decimal   decimal(30, 6),
col_datetime  datetime(3),
col_timestamp timestamp(4) null default null,
col_date      date,
col_time      time(5),
col_year      year(4),
col_varchar   varchar(100)
);
