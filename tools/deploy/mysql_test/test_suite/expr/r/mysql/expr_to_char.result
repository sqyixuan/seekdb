drop table if exists time_test;
create table time_test(
c1 timestamp,
c2 datetime,
c3 date,
c4 time,
c5 year
);
insert into time_test values(
'2018-12-25 20:10:59',
'2018-12-25 20:10:59',
'2018-12-25',
'20:10:59',
2018
);
select c1, to_char(c1), c2, to_char(c2), c3, to_char(c3), c4, to_char(c4), c5, to_char(c5) from time_test;
