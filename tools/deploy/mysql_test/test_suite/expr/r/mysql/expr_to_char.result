drop table if exists t1;
create table t1(
c0 int primary key,
c1 bigint,
c2 bool,
c3 float,
c4 double,
c5 decimal(18,2),
c6 date,
c7 DATETIME,
c8 TIMESTAMP,
c9 char(20),
c10 varchar(20)
);
