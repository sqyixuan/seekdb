select maketime();
ERROR 42000: Incorrect parameter count in the call to native function 'maketime'
select maketime(1);
ERROR 42000: Incorrect parameter count in the call to native function 'maketime'
select maketime(1,2);
ERROR 42000: Incorrect parameter count in the call to native function 'maketime'
select maketime(1,2,3);
maketime(1,2,3)
01:02:03.000000
select maketime(-1, 1, 1);
maketime(-1, 1, 1)
-01:01:01.000000
##
## implicit type conversion
##
select maketime('1','2','3');
maketime('1','2','3')
01:02:03.000000
select maketime('-1','2','3');
maketime('-1','2','3')
-01:02:03.000000
##
## empty string conversion
##
select maketime(1, 2, '');
maketime(1, 2, '')
01:02:00.000000
select maketime(1, '', '');
maketime(1, '', '')
01:00:00.000000
select maketime('', '', '');
maketime('', '', '')
00:00:00.000000
