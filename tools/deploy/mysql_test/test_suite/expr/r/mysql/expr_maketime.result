##
## abnormal input testing, return null under below cases
##
select maketime(null, null, null);
maketime(null, null, null)
NULL
select maketime(1, null, null);
maketime(1, null, null)
NULL
select maketime(1, 1, null);
maketime(1, 1, null)
NULL
select maketime(1, 1, -1);
maketime(1, 1, -1)
NULL
select maketime(1, -1, 1);
maketime(1, -1, 1)
NULL
select maketime(1, 1, 60);
maketime(1, 1, 60)
NULL
select maketime(1, 60, 1);
maketime(1, 60, 1)
NULL
##
## get 00:00:00.000000 under chinese character
##
select maketime('中文', '中文', '中文');
maketime('中文', '中文', '中文')
00:00:00.000000
