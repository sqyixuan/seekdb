drop table if exists t2;
drop table if exists t1;
create database lf_db;
use lf_db;
set ob_query_timeout=10000000000;
set ob_trx_timeout=100000000000;
#测试数据类型
select format(10, 0) from dual;
format(10, 0)
10
select format(10.12, 2) from dual;
format(10.12, 2)
10.12
select format(10.146, 2) from dual;
format(10.146, 2)
10.15
select format(10.146, 3) from dual;
format(10.146, 3)
10.146
select format('10', 0) from dual;
format('10', 0)
10
select format('10.12', 0) from dual;
format('10.12', 0)
10
select format('10.12', 1) from dual;
format('10.12', 1)
10.1
select format(-10, 0) from dual;
format(-10, 0)
-10
select format(-10.12, 2) from dual;
format(-10.12, 2)
