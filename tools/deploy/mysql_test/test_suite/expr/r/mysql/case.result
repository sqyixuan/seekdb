// case when expr to type use conn collation, should use collation of result_type_
DROP TABLE if exists `cu_configfile`;
CREATE TABLE `cu_configfile` (
`cpid` varchar(20) COLLATE utf8mb4_bin NOT NULL,
`cuid` varchar(30) COLLATE utf8mb4_bin NOT NULL,
`configfilename` varchar(50) COLLATE utf8mb4_bin NOT NULL,
`comments` varchar(100) COLLATE utf8mb4_bin DEFAULT NULL,
`format` varchar(1) COLLATE utf8mb4_bin DEFAULT NULL,
`configtype` varchar(1) COLLATE utf8mb4_bin DEFAULT NULL,
PRIMARY KEY (`cpid`, `cuid`, `configfilename`)
);
select( case when a.cpid = '' then null else a.cpid end ) cpid from cu_configfile a 
union select( case when a.cpid = '' then null else a.cpid end ) cpid from cu_configfile a;
cpid
