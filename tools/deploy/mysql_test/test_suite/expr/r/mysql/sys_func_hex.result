drop table if exists test;
create table test(c1 int primary key, c2 float, c3 char(5), c4 varchar(5), c6 binary(5), c7
varbinary(8), c9 timestamp, c10 time, c11 date, c12 year, c13 datetime);
insert into test values(1, 1.2, 'ab', 'cd', 'ea', '13', '2012-12-12 12:12:12', '12:12:12',
'2012-12-12', '2012', '2012-12-12 12:12:12');
select
hex(c1),hex(c2),hex(c3),hex(c4) from test;
hex(c1)	hex(c2)	hex(c3)	hex(c4)
1	1	6162	6364
select hex(c6),hex(c7),hex(c9),hex(c10) from test;
hex(c6)	hex(c7)	hex(c9)	hex(c10)
6561000000	3133	323031322D31322D31322031323A31323A3132	31323A31323A3132
select hex(c11),hex(c12),hex(c13) from test;
hex(c11)	hex(c12)	hex(c13)
323031322D31322D3132	7DC	323031322D31322D31322031323A31323A3132
