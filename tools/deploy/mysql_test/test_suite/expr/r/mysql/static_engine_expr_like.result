result_format: 4

alter system set enable_async_syslog = false;

set @@ob_enable_plan_cache = 0;

drop table if exists t;
create table t(text varchar(20), pat varchar(20), id int);
insert into t values(null, null, 1);
insert into t values('', '', 2);
insert into t values('abc', 'abc', 3);
insert into t values('abc', '%', 4);
insert into t values('abc', 'ab%', 5);
insert into t values('abc', '%abc', 6);
insert into t values('ab_', '%b%', 6);
insert into t values('bc', '%b_', 7);
insert into t values('bc', '%b_c', 8);
insert into t values('%bc', '%%b_', 9);


