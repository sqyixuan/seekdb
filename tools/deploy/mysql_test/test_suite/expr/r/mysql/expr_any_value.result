result_format: 4

drop table if exists t;
drop table if exists t1;
drop table if exists t2;
create table t1(c1 int, c2 int, c3 int);
insert into t1 values(1, 2, 3);
insert into t1 values(1, 20, 30);
insert into t1 values(1, 200, 300);
insert into t1 values(2, 4, 5);
insert into t1 values(2, 40, 50);
insert into t1 values(2, 400, 500);
insert into t1 values(3, 7, 8);
insert into t1 values(3, 70, 80);
insert into t1 values(3, 700, 800);
create table t2(c1 int, c2 int);
insert into t2 values(1, 2);
insert into t2 values(3, 4);
insert into t2 values(1, 20);
insert into t2 values(3, 40);

