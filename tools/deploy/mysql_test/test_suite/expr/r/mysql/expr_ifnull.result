c
1.0000000
drop table tbl;
create table tbl (
c1 tinyint, c2 smallint, c3 mediumint, c4 int, c5 bigint,
c6 tinyint unsigned, c7 smallint unsigned, c8 mediumint unsigned, c9 int unsigned, c10 bigint unsigned);
"same type"
create table sb as select ifnull(c1, c1), ifnull(c5, c5), ifnull(c6, c6), ifnull(c10, c10) from tbl;
desc sb;
Field	Type	Null	Key	Default	Extra
ifnull(c1, c1)	tinyint(4)	YES		NULL	
ifnull(c5, c5)	bigint(20)	YES		NULL	
ifnull(c6, c6)	tinyint(3) unsigned	YES		NULL	
ifnull(c10, c10)	bigint(20) unsigned	YES		NULL	
drop table sb;
"same type class"
create table sb as select ifnull(c1, c2), ifnull(c4, c5), ifnull(c6, c7), ifnull(c9, c10) from tbl;
desc sb;
Field	Type	Null	Key	Default	Extra
ifnull(c1, c2)	smallint(6)	YES		NULL	
ifnull(c4, c5)	bigint(20)	YES		NULL	
ifnull(c6, c7)	smallint(5) unsigned	YES		NULL	
ifnull(c9, c10)	bigint(20) unsigned	YES		NULL	
drop table sb;
"diff type1"
create table sb as select ifnull(c1, c6), ifnull(c2, c7), ifnull(c3, c8), ifnull(c4, c9), ifnull(c5, c10) from tbl;
desc sb;
Field	Type	Null	Key	Default	Extra
ifnull(c1, c6)	smallint(3)	YES		NULL	
ifnull(c2, c7)	mediumint(5)	YES		NULL	
ifnull(c3, c8)	int(8)	YES		NULL	
ifnull(c4, c9)	bigint(10)	YES		NULL	
ifnull(c5, c10)	decimal(20,0)	YES		NULL	
drop table sb;
"diff type2"
create table sb as select ifnull(c1, c10), ifnull(c2, c9), ifnull(c3, c8), ifnull(c4, c7), ifnull(c5, c6) from tbl;
desc sb;
Field	Type	Null	Key	Default	Extra
ifnull(c1, c10)	decimal(20,0)	YES		NULL	
ifnull(c2, c9)	bigint(10)	YES		NULL	
ifnull(c3, c8)	int(8)	YES		NULL	
ifnull(c4, c7)	int(5)	YES		NULL	
ifnull(c5, c6)	bigint(20)	YES		NULL	
drop table sb;
drop table tbl;
#array type
create table tbl (c1 array(int), c2 array(double));
insert into tbl values (array(1,2,3), array(1.1));
insert into tbl values (NULL, array(2.2));
select ifnull(c1, c2) from tbl;
ifnull(c1, c2)
[1,2,3]
[2.2]
create table sb as select ifnull(c1, c2) from tbl;
desc sb;
Field	Type	Null	Key	Default	Extra
ifnull(c1, c2)	ARRAY(DOUBLE)	YES		NULL	
drop table sb;
drop table tbl;
