result_format: 4
// test zero datetime(bug:30105612) 
drop table if exists tt;
create table tt(c1 datetime);
insert into tt values('0000-00-00 00:00:00.000000');
select subtime(c1, '10:00:00.000001') from tt;
+--------------------------------+
| subtime(c1, '10:00:00.000001') |
+--------------------------------+
| NULL                           |
+--------------------------------+

select subtime('2020-01-01 00:00:00', c1) from tt;
+------------------------------------+
| subtime('2020-01-01 00:00:00', c1) |
+------------------------------------+
| 2020-01-01 00:00:00                |
+------------------------------------+
