drop table if exists t1;
drop /**/ function if exists lookup;
CREATE FUNCTION lookup RETURNS STRING SONAME "udf_example.so";
create table t1 (c1 int primary key , c2 varchar(100)) partition by hash(c1) partitions 4;
insert into t1 (c1, c2) values (1, 'localhost');
insert into t1 (c1, c2) values (2, 'localhost');
insert into t1 (c1, c2) values (3, 'localhost');
insert into t1 (c1, c2) values (4, 'localhost');
select lookup(c2) from t1;
lookup(c2)
127.0.0.1
127.0.0.1
127.0.0.1
127.0.0.1
drop table t1;
drop /**/ function if exists lookup;
