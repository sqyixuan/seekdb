drop table if exists double_fixed_double_cmp_t;
create table double_fixed_double_cmp_t(empno bigint, ename VARCHAR(100), job VARCHAR(100), mgr int, hiredate DATE, sal float(7,2), comm float(9,2), deptno int);
SELECT * FROM double_fixed_double_cmp_t e where e.sal BETWEEN (SELECT sum(sal-2000) FROM double_fixed_double_cmp_t e where e.SAL like '%3%') AND (SELECT sum(sal-1000)  FROM double_fixed_double_cmp_t e where e.SAL like '%3%') order by empno;
