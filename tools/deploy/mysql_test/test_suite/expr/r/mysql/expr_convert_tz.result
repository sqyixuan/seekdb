CREATE TABLE tbl_convert (
col_88 VARCHAR(39) DEFAULT (LCASE('#WW5$#hT$L#@OjLR' - 'yrWz#swlExx@!')),
col_89 SMALLINT DEFAULT -24110,
col_90 BIT(56),
col_91 INT NOT NULL,
col_92 ENUM('Alice', 'Bob', 'Charlie', 'David') DEFAULT 'Charlie',
col_93 JSON,
col_94 SET('Alice', 'Bob', 'Charlie', 'David') NOT NULL DEFAULT 'Charlie',
col_95 ENUM('Alice', 'Bob', 'Charlie', 'David') NOT NULL,
col_96 JSON NOT NULL,
col_97 JSON NOT NULL,
col_98 BIT(28),
col_99 CHAR(152),
col_100 BOOLEAN NOT NULL DEFAULT (DAYNAME(1)),
col_101 TEXT(467) NOT NULL,
col_102 DECIMAL(56, 27),
col_103 DATETIME NOT NULL,
col_104 TIMESTAMP,
col_105 BLOB(292) NOT NULL,
col_106 TINYINT UNSIGNED,
col_107 TIME NOT NULL DEFAULT (CONVERT_TZ('13:09:01.00', 'GMT', 'MET')),
col_108 TINYINT UNSIGNED NOT NULL,
col_109 JSON NOT NULL,
col_110 CHAR(177) NOT NULL,
KEY idx_13 (col_89) GLOBAL,
UNIQUE KEY idx_14 (col_108, col_91, col_92, col_89, col_99) GLOBAL,
UNIQUE KEY idx_15 (col_108, col_107, col_88, col_90, col_98) GLOBAL,
KEY idx_16 (col_99(3)) LOCAL
) DEFAULT CHARSET=gbk
ROW_FORMAT=DYNAMIC
COMPRESSION='lz4_1.0'
  PARTITION BY HASH(col_108) PARTITIONS 264;
INSERT INTO tbl_convert (col_91, col_94, col_95, col_96, col_97, col_100, col_101, col_103, col_105, col_108, col_109, col_110) 
