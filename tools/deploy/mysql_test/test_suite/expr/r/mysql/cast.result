|        0 |    0 | NULL | NULL | NULL | NULL |                    0 |
|      0.5 |    0 | NULL | NULL | NULL | NULL |                    0 |
|      1.5 |    2 | NULL | NULL | NULL | NULL |                    2 |
|      2.5 |    2 | NULL | NULL | NULL | NULL |                    2 |
