bugfix: 
## test cast float to int
drop table t1;
create table t1(c1 float, c2 tinyint, c3 smallint, c4 mediumint, c5 int, c6 bigint);
insert into t1(c1) values(0.5);
insert into t1(c1) values(1.5);
insert into t1(c1) values(2.5);
insert into t1(c1) values(3.5);
insert into t1(c1) values(99.5);
insert into t1(c1) values(100.5);
insert into t1(c1) values(127);
insert into t1 select -c1, c2, c3, c4, c5, c6 from t1;
insert into t1(c1) values(127.4);
insert into t1(c1) values(-128.4);
insert into t1(c1) values(-128.5);
### 127.4和-128.5可以cast到tinyint范围内, 即[-128, 127]
update t1 set c2 = c1;
### 127.5和-128.50001 cast到tinyint以后超出范围
insert into t1(c1) values(127.5);
update t1 set c2 = c1;
ERROR 22003: Out of range value for column 'c2' at row 18
insert into t1(c1) values(-128.50001);
update t1 set c2 = c1 where c1 < 0;
ERROR 22003: Out of range value for column 'c2' at row 10

insert into t1(c1) values(32765.5);
insert into t1(c1) values(32766.5);
insert into t1(c1) values(32767);
insert into t1(c1) values(32767.4);
insert into t1 select -c1, c2, c3, c4, c5, c6 from t1 where c1 > 129;
insert into t1 (c1) values(-32768);
insert into t1 (c1) values(-32768.4);
insert into t1 (c1) values(-32768.5);
insert into t1(c1) values(-32768.501);
### 32767.4和-32768.501可以cast到smallint范围内, 即[-32768, 32767]
update t1 set c3 = c1;
### 32767.5和-32768.51 cast到smallint以后超出范围
insert into t1(c1) values(32767.5);
update t1 set c3 = c1;
ERROR 22003: Out of range value for column 'c3' at row 32
insert into t1(c1) values(-32768.51);
update t1 set c3 = c1 where c1 < 0;
ERROR 22003: Out of range value for column 'c3' at row 19

insert into t1(c1) values(8388605.5);
insert into t1(c1) values(8388606.5);
insert into t1(c1) values(8388607);
insert into t1(c1) values(8388607.2);
insert into t1 select -c1, c2, c3, c4, c5, c6 from t1 where c1 > 32770;
insert into t1 (c1) values(-8388608);
insert into t1 (c1) values(-8388608.4);
insert into t1 (c1) values(-8388608.5);
### 8388607.2和-8388608.5可以cast到mediumint范围内, 即[-8388608, 8388607]
update t1 set c4 = c1;
### 8388607.3和-8388608.50001 cast到mediumint以后超出范围
insert into t1(c1) values(8388607.3);
update t1 set c4 = c1;
ERROR 22003: Out of range value for column 'c4' at row 45
insert into t1(c1) values(-8388608.50001);
update t1 set c4 = c1 where c1 < 0;
ERROR 22003: Out of range value for column 'c4' at row 27

insert into t1(c1) values(2147483581.5);
insert into t1(c1) values(2147483582.5);
insert into t1(c1) values(2147483583.5);
insert into t1(c1) values(-2147483773.5);
insert into t1(c1) values(-2147483774.5);
insert into t1(c1) values(-2147483775.5);
insert into t1(c1) values(-2147483776);
### 2147483583和-2147483776可以cast到int范围内, 即[-2147483648, 2147483647]
update t1 set c5 = c1;
### 2147483584和-2147483777 cast到int以后超出范围
