// old engine, expect max/min value(99999 or -99999 9的个数取决与prec/scale)
bug:31068411
select cast('1e500' as decimal);
+--------------------------+
| cast('1e500' as decimal) |
+--------------------------+
|               9999999999 |
+--------------------------+
select cast('1e500' as decimal(5, 1));
+--------------------------------+
| cast('1e500' as decimal(5, 1)) |
+--------------------------------+
|                         9999.9 |
+--------------------------------+
select cast('-1e500' as decimal);
+---------------------------+
| cast('-1e500' as decimal) |
+---------------------------+
|               -9999999999 |
+---------------------------+
select cast('-1e500' as decimal(5, 1));
+---------------------------------+
| cast('-1e500' as decimal(5, 1)) |
+---------------------------------+
|                         -9999.9 |
+---------------------------------+
select cast('--1e500' as decimal);
+----------------------------+
| cast('--1e500' as decimal) |
+----------------------------+
|                          0 |
+----------------------------+
Warnings:
Warning	1292	Truncated incorrect DECIMAL value: '--1e500'
select cast('--1e500' as decimal(5, 1));
+----------------------------------+
| cast('--1e500' as decimal(5, 1)) |
+----------------------------------+
|                              0.0 |
+----------------------------------+
Warnings:
Warning	1292	Truncated incorrect DECIMAL value: '--1e500'
select cast('+1e500' as decimal);
+---------------------------+
| cast('+1e500' as decimal) |
+---------------------------+
|                9999999999 |
+---------------------------+
select cast('+1e500' as decimal(5, 1));
+---------------------------------+
| cast('+1e500' as decimal(5, 1)) |
+---------------------------------+
|                          9999.9 |
+---------------------------------+

bugfix: 
create table t0(c1 varchar(100), c2 decimal(10,0), c3 decimal);
insert into t0 values('5e45', 0, 0);
insert into t0 values('5e451', 0, 0);
insert into t0 values('5e451nA*7zV2]9u', 0, 0);
SELECT '5e451nA*7zV2]9u' IS TRUE from t0;
+---------------------------+
| '5e451nA*7zV2]9u' IS TRUE |
+---------------------------+
|                         1 |
|                         1 |
|                         1 |
+---------------------------+
select * FROM t0 WHERE '5e451nA*7zV2]9u';
+-----------------+------+------+
| c1              | c2   | c3   |
+-----------------+------+------+
| 5e45            |    0 |    0 |
| 5e451           |    0 |    0 |
| 5e451nA*7zV2]9u |    0 |    0 |
+-----------------+------+------+
select c1, c1 is true  from t0;
+-----------------+------------+
| c1              | c1 is true |
+-----------------+------------+
| 5e45            |          1 |
| 5e451           |          1 |
| 5e451nA*7zV2]9u |          1 |
+-----------------+------------+
select * from t0 where c1;
+-----------------+------+------+
| c1              | c2   | c3   |
+-----------------+------+------+
| 5e45            |    0 |    0 |
| 5e451           |    0 |    0 |
| 5e451nA*7zV2]9u |    0 |    0 |
+-----------------+------+------+
select * from t0 where c1 is true;
+-----------------+------+------+
| c1              | c2   | c3   |
+-----------------+------+------+
| 5e45            |    0 |    0 |
| 5e451           |    0 |    0 |
| 5e451nA*7zV2]9u |    0 |    0 |
+-----------------+------+------+
insert into t0 values('', '5e45', 0);
ERROR 22003: Out of range value for column 'c2' at row 1
insert into t0 values('', '5e451', 0);
ERROR 22003: Result value was out of range when casting varchar to number
insert into t0 values('', 0, '5e45');
ERROR 22003: Out of range value for column 'c3' at row 1
insert into t0 values('', 0, '5e451');
ERROR 22003: Result value was out of range when casting varchar to number
set @@sql_mode = '';
insert into t0 values('', '5e45', '5e45');
insert into t0 values('', '5e451', '5e451');
select * from t0;
+-----------------+------------+------------+
| c1              | c2         | c3         |
+-----------------+------------+------------+
| 5e45            |          0 |          0 |
| 5e451           |          0 |          0 |
| 5e451nA*7zV2]9u |          0 |          0 |
|                 | 9999999999 | 9999999999 |
|                 | 9999999999 | 9999999999 |
+-----------------+------------+------------+
set @@sql_mode = 'STRICT_ALL_TABLES,NO_ZERO_IN_DATE,NO_AUTO_CREATE_USER';
drop table t0;


