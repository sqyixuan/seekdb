drop table if exists t1;
SELECT BIT_LENGTH('text');
BIT_LENGTH('text')
32
SELECT BIT_LENGTH('我们') from dual;
BIT_LENGTH('我们')
48
SELECT BIT_LENGTH('奥新贝斯oceanbase');
BIT_LENGTH('奥新贝斯oceanbase')
168
SELECT BIT_LENGTH(1234566);
BIT_LENGTH(1234566)
56
SELECT BIT_LENGTH(null);
BIT_LENGTH(null)
NULL
SELECT BIT_LENGTH(date'2020-01-01');
BIT_LENGTH(date'2020-01-01')
80
create table t1 (c1 int, c2 int unsigned,
c3 tinyint, c4 tinyint unsigned,
c5 bigint, c6 bigint unsigned,
c7 float, c8 float unsigned,
c9 double, c10 double unsigned,
c11 decimal, c12 decimal unsigned,
c13 date, c14 datetime, c15 timestamp,
c16 varchar(30), c17 char(30));
select * from t1;
c1	c2	c3	c4	c5	c6	c7	c8	c9	c10	c11	c12	c13	c14	c15	c16	c17
insert into t1 values(null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null, null);
