## 2.test remove repeated soundex code.
select soundex('soundex') from dual;
soundex('soundex')
S532
select soundex('ssoundex') from dual;
soundex('ssoundex')
S532
select soundex('sxoundex') from dual;
soundex('sxoundex')
S532
select soundex('sounmdex') from dual;
soundex('sounmdex')
S532
select soundex('sounamdex') from dual;
soundex('sounamdex')
S532
select soundex('abafapcagajdatlalmanrar') from dual;
soundex('abafapcagajdatlalmanrar')
A123456
select soundex('ababcac') from dual;
soundex('ababcac')
A120
## 3.test utf16
drop table t1;
drop table t2;
create table t1(c1 varchar(100) collate utf16_bin);
insert into t1 values('ab');
insert into t1 values('abfpcgjdtllmnrr');
insert into t1 values('ababcac');
create table t2 as select soundex(c1) c1 from t1;
select c1, length(c1), collation(c1) from t2;
c1	length(c1)	collation(c1)
A100	8	utf16_bin
A123456	14	utf16_bin
A120	8	utf16_bin
## 4.test nonalphabetic character
select soundex('!ag') from dual;
soundex('!ag')
A200
select soundex(';ag') from dual;
soundex(';ag')
A200
select soundex('二ag') from dual;
soundex('二ag')
A200
select soundex('??ag') from dual;
soundex('??ag')
A200
select soundex('a!g') from dual;
soundex('a!g')
A200
select soundex('a;g') from dual;
soundex('a;g')
A200
select soundex('a二g') from dual;
soundex('a二g')
A200
select soundex('a??g') from dual;
soundex('a??g')
A200
select soundex(''), length(soundex('')), soundex('') is null from dual;
soundex('')	length(soundex(''))	soundex('') is null
	0	0
select soundex('!!'), length(soundex('!!')), soundex('!!') is null from dual;
soundex('!!')	length(soundex('!!'))	soundex('!!') is null
	0	0
select soundex('ab!f!p') from dual;
soundex('ab!f!p')
A100
select soundex('ab!af!p') from dual;
soundex('ab!af!p')
A100
drop table t1, t2;
