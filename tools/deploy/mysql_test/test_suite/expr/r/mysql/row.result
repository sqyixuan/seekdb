drop table if exists  table100_int;
CREATE TABLE table100_int (
pk INT
, col_int INT
, col_char_12 VARCHAR(12)
, col_char_12_key VARCHAR(12)
, col_int_key INT
, PRIMARY KEY(pk)
) DEFAULT CHARSET = 'utf8' ;
CREATE INDEX idx_table100_int_col_char_12_key ON table100_int(col_char_12_key);
CREATE INDEX idx_table100_int_col_int_key ON table100_int(col_int_key);
SELECT * FROM table100_int WHERE NOT ( ( col_int_key , col_char_12 ) = ( col_char_12_key , pk ) ) AND  ( ( SUBSTR( CAST( ( ( -10 * -1.99999 ) ) AS CHAR(100) ) , 1 , 12 ) , SUBSTR( CAST( ( -10 ) AS CHAR(100) ) , 1 , 12 ) ) <=  ( pk , col_int_key ) ) AND  (  ( col_char_12_key , pk ) < ( SUBSTR( CAST( ( ( -100.1234500 - 0 ) ) AS CHAR(100) ) , 1 , 12 ) , SUBSTR( CAST( ( ABS ( -100.1234500 ) ) AS CHAR(100) ) , 1 , 12 ) ) ) AND  ( ( col_char_12_key , col_char_12_key ) =  ( SUBSTR( CAST( ( 4 ) AS CHAR(100) ) , 1 , 12 ) , SUBSTR( CAST( ( ( ( ABS ( ( 2 * ( -100.1234500 + CEIL ( ( 10 * -10 ) ) ) ) ) / -100.1234500 ) / 10 ) ) AS CHAR(100) ) , 1 , 12 ) ) ) AND  ( ( col_char_12,col_char_12_key,col_int,col_int_key,pk ) >=  ( col_char_12,col_char_12_key,col_int,col_int_key,pk ) ) OR NOT (  ( col_char_12,col_char_12_key,col_int,col_int_key,pk ) <  ( col_char_12,col_char_12_key,col_int,col_int_key,pk ) );
