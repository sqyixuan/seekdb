### 2.2 v
## week and weekday will not overwrite month and monthday if it's not complete.
select str_to_date('2020 10 10 2022 1','%Y %m %d %X %V');
str_to_date('2020 10 10 2022 1','%Y %m %d %X %V')
2020-10-10
select str_to_date('2020 10 10 1','%Y %m %d %U');
str_to_date('2020 10 10 1','%Y %m %d %U')
2020-10-10
