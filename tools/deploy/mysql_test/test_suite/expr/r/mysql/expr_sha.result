drop table if exists t1;
drop table if exists t_sha;
drop table if exists t_sha1;
drop table if exists t_sha2;
create table t1 (c1 varchar(100), c2 int);
create table t_sha as select sha(c1) c1 from t1;
create table t_sha1 as select sha1(c1) c1 from t1;
create table t_sha2 as select sha2(c1, c2) c1 from t1;
desc t_sha;
+-------+-------------+------+-----+---------+-------+
| Field | Type        | Null | Key | Default | Extra |
+-------+-------------+------+-----+---------+-------+
| c1    | varchar(40) | YES  |     | NULL    |       |
+-------+-------------+------+-----+---------+-------+
desc t_sha1;
+-------+-------------+------+-----+---------+-------+
| Field | Type        | Null | Key | Default | Extra |
+-------+-------------+------+-----+---------+-------+
| c1    | varchar(40) | YES  |     | NULL    |       |
+-------+-------------+------+-----+---------+-------+
desc t_sha2;
+-------+--------------+------+-----+---------+-------+
| Field | Type         | Null | Key | Default | Extra |
+-------+--------------+------+-----+---------+-------+
| c1    | varchar(128) | YES  |     | NULL    |       |
+-------+--------------+------+-----+---------+-------+
drop table t1;
drop table t_sha;
drop table t_sha1;
drop table t_sha2;
