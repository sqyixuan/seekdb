result_format: 4
drop table if exists t_div_zero_select, t_div_zero_insert, t_div_zero_update, t_div_zero_replace;
drop procedure if exists p_div_zero;
drop table if exists t_div_zero_partition;

############################# sql_mode with ERROR_FOR_DIVISION_BY_ZERO ############################
set sql_mode = 'STRICT_ALL_TABLES,ERROR_FOR_DIVISION_BY_ZERO';

############## test select ############
create table t_div_zero_select(c int);
insert into t_div_zero_select values(1);
insert into t_div_zero_select values(null);
select * from t_div_zero_select;
+------+
| c    |
+------+
|    1 |
| NULL |
+------+

select c/0 from t_div_zero_select;
+------+
| c/0  |
+------+
| NULL |
| NULL |
+------+
select c/-0 from t_div_zero_select;
+------+
| c/-0 |
+------+
| NULL |
| NULL |
+------+
select c/0.0 from t_div_zero_select;
+-------+
| c/0.0 |
+-------+
|  NULL |
|  NULL |
+-------+
select c/'0' from t_div_zero_select;
+-------+
| c/'0' |
+-------+
|  NULL |
|  NULL |
+-------+
select c/(1-1) from t_div_zero_select;
+---------+
| c/(1-1) |
+---------+
|    NULL |
|    NULL |
+---------+
select * from t_div_zero_select where c > 1/0;
+------+
| c    |
+------+
+------+
select * from t_div_zero_select where c > 1/-0;
+------+
| c    |
+------+
+------+
select * from t_div_zero_select where c > 1/0.0;
+------+
| c    |
+------+
+------+
select * from t_div_zero_select where c > 1/'0';
+------+
| c    |
+------+
+------+
select * from t_div_zero_select where c > 1/(1-1);
+------+
| c    |
+------+
+------+
select * from t_div_zero_select;
+------+
| c    |
+------+
|    1 |
| NULL |
+------+


############## test insert ############
create table t_div_zero_insert(c int);

insert into t_div_zero_insert values(1/0);
ERROR 22012: Divided by zero
insert into t_div_zero_insert values(1/-0);
ERROR 22012: Divided by zero
insert into t_div_zero_insert values(1/0.0);
ERROR 22012: Divided by zero
insert into t_div_zero_insert values(1/'0');
ERROR 22012: Divided by zero
insert into t_div_zero_insert values(1/(1-1));
ERROR 22012: Divided by zero
select * from t_div_zero_insert;
+------+
| c    |
+------+
+------+

insert ignore into t_div_zero_insert values(1/0);
insert ignore into t_div_zero_insert values(1/-0);
insert ignore into t_div_zero_insert values(1/0.0);
insert ignore into t_div_zero_insert values(1/'0');
insert ignore into t_div_zero_insert values(1/(1-1));
select * from t_div_zero_insert;
+------+
| c    |
+------+
| NULL |
| NULL |
| NULL |
| NULL |
| NULL |
+------+


############## test update ############
create table t_div_zero_update(c int);
insert into t_div_zero_update values(1);

update t_div_zero_update set c = 1/0;
ERROR 22012: Divided by zero
update t_div_zero_update set c = 1/-0;
ERROR 22012: Divided by zero
update t_div_zero_update set c = 1/0.0;
ERROR 22012: Divided by zero
update t_div_zero_update set c = 1/'0';
ERROR 22012: Divided by zero
update t_div_zero_update set c = 1/(1-1);
ERROR 22012: Divided by zero
select * from t_div_zero_update;
+------+
| c    |
+------+
|    1 |
+------+

update ignore t_div_zero_update set c = 1/0;
update ignore t_div_zero_update set c = 1/-0;
update ignore t_div_zero_update set c = 1/0.0;
update ignore t_div_zero_update set c = 1/'0';
update ignore t_div_zero_update set c = 1/(1-1);
select * from t_div_zero_update;
+------+
| c    |
+------+
| NULL |
+------+


############## test replace ###########
create table t_div_zero_replace(c int);

replace into t_div_zero_replace values(1/0);
ERROR 22012: Divided by zero
replace into t_div_zero_replace values(1/-0);
ERROR 22012: Divided by zero
replace into t_div_zero_replace values(1/0.0);
ERROR 22012: Divided by zero
replace into t_div_zero_replace values(1/'0');
ERROR 22012: Divided by zero
replace into t_div_zero_replace values(1/(1-1));
ERROR 22012: Divided by zero
select * from t_div_zero_replace;
+------+
| c    |
+------+
+------+


############## test procedure #########
create procedure p_div_zero()
begin
drop table if exists p_t;
create table p_t(c int);
insert into p_t values(1);
select c/0 from p_t;
insert into p_t values(1/0);
end |

call p_div_zero();
+------+
| c/0  |
+------+
| NULL |
+------+
ERROR 22012: Divided by zero


############## test partition table ###
create table t_div_zero_partition (c1 int)
   partition by list(1 div c1) (
   partition p0 values in (null),
   partition p1 values in (1)
);

insert into t_div_zero_partition values (null), (0), (1);
ERROR 22012: Divided by zero
select * from t_div_zero_partition;
+------+
| c1   |
+------+
+------+


############## drop table #############
drop table if exists t_div_zero_select, t_div_zero_insert, t_div_zero_update, t_div_zero_replace;
drop procedure if exists p_div_zero;
drop table if exists t_div_zero_partition;


