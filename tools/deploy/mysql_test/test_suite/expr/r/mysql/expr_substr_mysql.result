drop table if exists table1_float;
CREATE TABLE table1_float (
  col_char_20_gbk_unique_key char(20) CHARACTER SET gbk DEFAULT NULL
);
SELECT * 
FROM   table1_float 
WHERE  Nullif(
            col_char_20_gbk_unique_key, 
            Substr(REPEAT('aa', 0+1), 1, 20)
           );
+----------------------------+
| col_char_20_gbk_unique_key |
+----------------------------+
+----------------------------+
drop table table1_float;
