ERROR 42000: Query was empty
select statement_digest_text('abcd');
ERROR 42000: You have an error in your SQL syntax; check the manual that corresponds to your OceanBase version for the right syntax to use near 'abcd' at line 1
select statement_digest_text('select * from');
ERROR 42000: You have an error in your SQL syntax; check the manual that corresponds to your OceanBase version for the right syntax to use near 'from' at line 1
select statement_digest_text(123);
ERROR 42000: You have an error in your SQL syntax; check the manual that corresponds to your OceanBase version for the right syntax to use near '123' at line 1
create table t_statement_digest as select statement_digest(c1) c1 from t1;
create table t_statement_digest_text as select statement_digest_text(c1) c1 from t1;
desc t_statement_digest;
+-------+-------------+------+-----+---------+-------+
| Field | Type        | Null | Key | Default | Extra |
+-------+-------------+------+-----+---------+-------+
| c1    | varchar(32) | YES  |     | NULL    |       |
+-------+-------------+------+-----+---------+-------+
desc t_statement_digest_text;
+-------+----------+------+-----+---------+-------+
| Field | Type     | Null | Key | Default | Extra |
+-------+----------+------+-----+---------+-------+
| c1    | longtext | YES  |     | NULL    |       |
+-------+----------+------+-----+---------+-------+
drop table t1;
drop table t2;
drop table t_statement_digest;
drop table t_statement_digest_text;
