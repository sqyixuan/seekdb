set @sqlstr1='CREATE VIEW v2 AS SELECT * FROM t2 WHERE id > 1';
set @sqlstr2='ALTER VIEW v1 AS SELECT c1,c2 FROM t1 WHERE c1 = "view"';
set @sqlstr31='CREATE TRIGGER tri3 AFTER INSERT ON t2 FOR EACH ROW INSERT INTO t3 VALUES (1,2,3,4)';
set @sqlstr32='CREATE TRIGGER tri4 AFTER INSERT ON t2 FOR EACH ROW UPDATE t3 SET c1 = 2;';
set @sqlstr33='CREATE TRIGGER tri5 AFTER INSERT ON t2 FOR EACH ROW DELETE FROM t3 WHERE c1 = 1';
set @sqlstr4='ALTER TABLE t1 ROW_FORMAT = COMPRESSED';
set @sqlstr5='GRANT SELECT ON world.* TO role3';
set @sqlstr6='CREATE USER "whh"@"localhost" IDENTIFIED BY "password"';
