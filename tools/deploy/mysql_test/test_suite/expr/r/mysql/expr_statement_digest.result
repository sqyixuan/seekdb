drop table if exists t1;
drop table if exists t1_gbk;
drop table if exists t2;
drop table if exists t_statement_digest;
drop table if exists t_statement_digest_text;
result_format: 3
create table t1(c1 varchar(100));
create table t1_gbk(c1 varchar(100) charset gbk);
create table t2(c1 int, c2 int);
insert into t1 values('select 1');
insert into t1 values('select 1 from dual');
insert into t1 values('select 1 from t2 where c1 = 1 order by 1');
insert into t1 values('insert into t2 values(1,2), (3,4)');
insert into t1 values('select "中文", 列名 from 表名');
insert into t1_gbk select * from t1;
select 1 from t2 where c1 = 1 order by 1;
+---+
| 1 |
+---+
+---+
insert into t2 values(1,2), (3,4);
select c1, statement_digest_text(c1), collation(statement_digest_text(c1)), statement_digest(c1), collation(statement_digest(c1)) from t1;
+------------------------------------------+----------------------------------------------+--------------------------------------+----------------------------------+---------------------------------+
| c1                                       | statement_digest_text(c1)                    | collation(statement_digest_text(c1)) | statement_digest(c1)             | collation(statement_digest(c1)) |
+------------------------------------------+----------------------------------------------+--------------------------------------+----------------------------------+---------------------------------+
| select 1                                 | SELECT ?                                     | utf8mb4_general_ci                   | ADF99D2BF60A4EC4A05EADBB6D68161B | utf8mb4_general_ci              |
| select 1 from dual                       | SELECT ? FROM DUAL                           | utf8mb4_general_ci                   | BFF90B6A4F55F07EF9B8E82843D758D2 | utf8mb4_general_ci              |
| select 1 from t2 where c1 = 1 order by 1 | SELECT ? FROM T2 WHERE C1 = ? ORDER BY 1     | utf8mb4_general_ci                   | E8E6A4F8E21DF4961FE471FBC9C182A3 | utf8mb4_general_ci              |
| insert into t2 values(1,2), (3,4)        | INSERT INTO T2 VALUES ( ? , ? ) , ( ? , ? )  | utf8mb4_general_ci                   | E766F55D1FE5268C6F469F9B61B52AE5 | utf8mb4_general_ci              |
| select "中文", 列名 from 表名            | SELECT ? , 列名 FROM 表名                    | utf8mb4_general_ci                   | 92F6EB166FD2AEB9781CCF2657144211 | utf8mb4_general_ci              |
+------------------------------------------+----------------------------------------------+--------------------------------------+----------------------------------+---------------------------------+
select c1, statement_digest_text(c1), collation(statement_digest_text(c1)), statement_digest(c1), collation(statement_digest(c1)) from t1_gbk;
+------------------------------------------+----------------------------------------------+--------------------------------------+----------------------------------+---------------------------------+
| c1                                       | statement_digest_text(c1)                    | collation(statement_digest_text(c1)) | statement_digest(c1)             | collation(statement_digest(c1)) |
+------------------------------------------+----------------------------------------------+--------------------------------------+----------------------------------+---------------------------------+
| select 1                                 | SELECT ?                                     | gbk_chinese_ci                       | ADF99D2BF60A4EC4A05EADBB6D68161B | utf8mb4_general_ci              |
| select 1 from dual                       | SELECT ? FROM DUAL                           | gbk_chinese_ci                       | BFF90B6A4F55F07EF9B8E82843D758D2 | utf8mb4_general_ci              |
| select 1 from t2 where c1 = 1 order by 1 | SELECT ? FROM T2 WHERE C1 = ? ORDER BY 1     | gbk_chinese_ci                       | E8E6A4F8E21DF4961FE471FBC9C182A3 | utf8mb4_general_ci              |
| insert into t2 values(1,2), (3,4)        | INSERT INTO T2 VALUES ( ? , ? ) , ( ? , ? )  | gbk_chinese_ci                       | E766F55D1FE5268C6F469F9B61B52AE5 | utf8mb4_general_ci              |
| select "中文", 列名 from 表名            | SELECT ? , 列名 FROM 表名                    | gbk_chinese_ci                       | B1D0F0139D8C2504486BDAD32E77FD7F | utf8mb4_general_ci              |
+------------------------------------------+----------------------------------------------+--------------------------------------+----------------------------------+---------------------------------+
select format_sql_id, query_sql from oceanbase.V$OB_SQL_AUDIT where format_sql_id = statement_digest('select 1 from t2 where c1 = 1 order by 1') limit 1;
+----------------------------------+------------------------------------------+
| format_sql_id                    | query_sql                                |
+----------------------------------+------------------------------------------+
| E8E6A4F8E21DF4961FE471FBC9C182A3 | select 1 from t2 where c1 = 1 order by 1 |
+----------------------------------+------------------------------------------+
