# End of 5.0 tests
#
# Bug #44743: Join in combination with concat does not always work
#
CREATE TABLE t1 (
a VARCHAR(100) NOT NULL DEFAULT '0',
b VARCHAR(2) NOT NULL DEFAULT '',
c VARCHAR(2) NOT NULL DEFAULT '',
d VARCHAR(10000) NOT NULL,
PRIMARY KEY (a, b, c),
KEY (a)
) DEFAULT CHARSET=utf8;
INSERT INTO t1 VALUES ('gui_A', 'a', 'b', 'str1'),
('gui_AB', 'a', 'b', 'str2'), ('gui_ABC', 'a', 'b', 'str3');
CREATE TABLE t2 (
a VARCHAR(100) NOT NULL DEFAULT '',
PRIMARY KEY (a)
) DEFAULT CHARSET=utf8mb4;
INSERT INTO t2 VALUES ('A'), ('AB'), ('ABC');
SELECT CONCAT('gui_', t2.a), t1.d FROM t2 LEFT JOIN t1 ON t1.a = CONCAT('gui_', t2.a) AND t1.b = 'a' AND t1.c = 'b';
CONCAT('gui_', t2.a)	d
gui_A	str1
gui_AB	str2
gui_ABC	str3
DROP TABLE t1, t2;
drop view v1,v2;
drop table t;
create table t(a1 varchar(1), b1 varchar(10));
create view v1 as select a1 || b1 as x from t;
create view v2 as select concat(a1, b1) as x from t;
show create view v1;
View	Create View	character_set_client	collation_connection
v1	CREATE VIEW `v1` AS select (`test`.`t`.`a1` or `test`.`t`.`b1`) AS `x` from `test`.`t`	utf8mb4	utf8mb4_general_ci
show create view v2;
View	Create View	character_set_client	collation_connection
v2	CREATE VIEW `v2` AS select concat(`test`.`t`.`a1`,`test`.`t`.`b1`) AS `x` from `test`.`t`	utf8mb4	utf8mb4_general_ci
desc v1;
Field	Type	Null	Key	Default	Extra
x	int(1)	YES		NULL	
desc v2;
Field	Type	Null	Key	Default	Extra
x	varchar(11)	YES		NULL	
DROP TABLE t1;
drop view v1,v2;
