###bug18851852, clob类型,使用concat表达式查询建表时报-4002
drop table t2a;
drop table t2b;
create table t1(v1 text);
insert into t1 values('ssss');
create table t2A as select concat(v1,v1) v1 from t1;
create table t2B as select concat(concat(v1,v1),v1) v1 from t1;
desc t2a;
Field	Type	Null	Key	Default	Extra
v1	longtext	YES		NULL	
desc t2b;
Field	Type	Null	Key	Default	Extra
v1	longtext	YES		NULL	
select length(v1) from t2a union all select length(v1) from t2b order by 1;
length(v1)
8
12
drop table t2c;
drop table t2d;
drop table t2e;
create table t2c(c1 varchar(262143), c2 varchar(1));
create table t2d as select concat(concat(c1,c2),c2) v1 from t2c;
ERROR 42000: Column length too big for column 'v1' (max = 262144)
create table t2e as select concat(c1,c2) v1 from t2c;
desc t2e;
Field	Type	Null	Key	Default	Extra
v1	varchar(262144)	YES		NULL	
