result_format: 4
# IN/NOT IN的测试, 针对ObExprIn
select 1 from dual where 1  in (2.0, 1 / 0.1 / 10);
+---+
| 1 |
+---+
| 1 |
+---+
select 2 from dual where (1,2, null)  in ((1,2,null), (1,2,5));
+---+
| 2 |
+---+
+---+
select 3 from dual where (1,2, null) not  in ((1,2,null), (1,2,5));
+---+
| 3 |
+---+
+---+
select 4 from dual where (1,2) not  in ((1,3), (1,2-5), (1+null, 5.05+'1'));
+---+
| 4 |
+---+
| 4 |
+---+
select 5 from dual where (1,2) not  in ((1,3), (1,2-5), (1+null, null-5.05+'1'));
+---+
| 5 |
+---+
+---+
select 6 from dual where '1' in (2.0, 1.0, 5,'null');
+---+
| 6 |
+---+
| 6 |
+---+
select 7 from dual where 4/2.0 in (2, 1, 0,'x');
+---+
| 7 |
+---+
| 7 |
+---+
Warnings:
Warning	1292	Truncated incorrect DECIMAL value: 'x'
