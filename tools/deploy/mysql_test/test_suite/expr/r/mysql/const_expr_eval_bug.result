result_format: 4
prepare stmt from 'set ob_query_timeout = ?';

set @test_timeout=1234567890;

execute stmt using @test_timeout;

select @@ob_query_timeout;
+--------------------+
| @@ob_query_timeout |
+--------------------+
|         1234567890 |
+--------------------+

set @test_timeout=10000000;

execute stmt using @test_timeout;

select @@ob_query_timeout;
+--------------------+
| @@ob_query_timeout |
+--------------------+
|           10000000 |
+--------------------+
