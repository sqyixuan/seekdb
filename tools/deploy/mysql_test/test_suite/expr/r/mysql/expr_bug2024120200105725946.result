drop table if exists t1;
drop table if exists t2, t3, t4;
create table t1 (c1 int zerofill, c2 double zerofill, c3 decimal(10,2) zerofill);
INSERT INTO t1 (c1, c2, c3) VALUES (1, 1.1, 123.45);
INSERT INTO t1 (c1, c2, c3) VALUES (2, 2.2, 234.56);
INSERT INTO t1 (c1, c2, c3) VALUES (3, 3.3, 345.67);
INSERT INTO t1 (c1, c2, c3) VALUES (4, 4.4, 456.78);
INSERT INTO t1 (c1, c2, c3) VALUES (5, 5.5, 567.89);
result_format: 4
select sum(c1), sum(c2), sum(c3), c1, c2, c3, c1+1, c2+1, c3+1 from t1;
+---------+---------+---------+------------+-------------------------+-------------+------+------+--------+
| sum(c1) | sum(c2) | sum(c3) | c1         | c2                      | c3          | c1+1 | c2+1 | c3+1   |
+---------+---------+---------+------------+-------------------------+-------------+------+------+--------+
|      15 |    16.5 | 1728.35 | 0000000001 | 000000000000000000001.1 | 00000123.45 |    2 |  2.1 | 124.45 |
+---------+---------+---------+------------+-------------------------+-------------+------+------+--------+
select min(c1), min(c2), min(c3), c1, c2, c3, c1+1, c2+1, c3+1 from t1;
+---------+---------+---------+------------+-------------------------+-------------+------+------+--------+
| min(c1) | min(c2) | min(c3) | c1         | c2                      | c3          | c1+1 | c2+1 | c3+1   |
+---------+---------+---------+------------+-------------------------+-------------+------+------+--------+
|       1 |     1.1 |  123.45 | 0000000001 | 000000000000000000001.1 | 00000123.45 |    2 |  2.1 | 124.45 |
+---------+---------+---------+------------+-------------------------+-------------+------+------+--------+
select avg(c1), avg(c2), avg(c3), c1, c2, c3, c1+1, c2+1, c3+1 from t1;
+---------+---------+------------+------------+-------------------------+-------------+------+------+--------+
| avg(c1) | avg(c2) | avg(c3)    | c1         | c2                      | c3          | c1+1 | c2+1 | c3+1   |
+---------+---------+------------+------------+-------------------------+-------------+------+------+--------+
|  3.0000 |     3.3 | 345.670000 | 0000000001 | 000000000000000000001.1 | 00000123.45 |    2 |  2.1 | 124.45 |
+---------+---------+------------+------------+-------------------------+-------------+------+------+--------+

create table t2 as select sum(c1), sum(c2), sum(c3), c1, c2, c3 from t1;
create table t3 as select min(c1), min(c2), min(c3), c1, c2, c3 from t1;
create table t4 as select avg(c1), avg(c2), avg(c3), c1, c2, c3 from t1;

select * from t2;
+---------+---------+---------+------------+-------------------------+-------------+
| sum(c1) | sum(c2) | sum(c3) | c1         | c2                      | c3          |
+---------+---------+---------+------------+-------------------------+-------------+
|      15 |    16.5 | 1728.35 | 0000000001 | 000000000000000000001.1 | 00000123.45 |
+---------+---------+---------+------------+-------------------------+-------------+
select * from t3;
+---------+---------+---------+------------+-------------------------+-------------+
| min(c1) | min(c2) | min(c3) | c1         | c2                      | c3          |
+---------+---------+---------+------------+-------------------------+-------------+
|       1 |     1.1 |  123.45 | 0000000001 | 000000000000000000001.1 | 00000123.45 |
+---------+---------+---------+------------+-------------------------+-------------+
select * from t4;
+---------+---------+------------+------------+-------------------------+-------------+
| avg(c1) | avg(c2) | avg(c3)    | c1         | c2                      | c3          |
+---------+---------+------------+------------+-------------------------+-------------+
|  3.0000 |     3.3 | 345.670000 | 0000000001 | 000000000000000000001.1 | 00000123.45 |
+---------+---------+------------+------------+-------------------------+-------------+

drop table t1,t2,t3,t4;
