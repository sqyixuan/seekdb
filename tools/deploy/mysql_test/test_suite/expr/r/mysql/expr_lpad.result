drop table if exists AllTypes;
CREATE TABLE AllTypes (
    c_bool BOOLEAN,
    c_int INT,
    c_decimal DECIMAL(13 , 0 ),
    c_double DOUBLE,
    c_bit BIT,

    c_datetime DATETIME,
    c_data DATE,
    c_time TIME,

    c_char CHAR(10),
    c_varchar VARCHAR(10),
    c_binary BINARY(10),
    c_varbinary VARBINARY(10)
);

insert AllTypes values(
    true,
    1,
    1,
    1.5,
    1,

    '2011-11-11 11:11:11',
    '2011-11-11',
    '11:11:11',

    'a',
    'a',
    'a',
    'a'
);

