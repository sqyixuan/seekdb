result_format: 4
drop table if exists t3;
select collation(random_bytes(4));
+----------------------------+
| collation(random_bytes(4)) |
+----------------------------+
| binary                     |
+----------------------------+
select charset(random_bytes(4));
+--------------------------+
| charset(random_bytes(4)) |
+--------------------------+
| binary                   |
+--------------------------+
select length(random_bytes(4));
+-------------------------+
| length(random_bytes(4)) |
+-------------------------+
|                       4 |
+-------------------------+
select random_bytes(NULL);
+--------------------+
| random_bytes(NULL) |
+--------------------+
| NULL               |
+--------------------+
select length(random_bytes(NULL));
+----------------------------+
| length(random_bytes(NULL)) |
+----------------------------+
|                       NULL |
+----------------------------+
set block_encryption_mode = 0;
select hex(aes_encrypt('a', 'a', random_bytes(16)));
+----------------------------------------------+
| hex(aes_encrypt('a', 'a', random_bytes(16))) |
+----------------------------------------------+
| 7B20575DA106759DBDB1A32EE2D9A774             |
+----------------------------------------------+
Warnings:
Warning	9721	input value for iv is not valid
set block_encryption_mode = 18;
select hex(sm4_encrypt('a', 'a', random_bytes(16)));
+----------------------------------------------+
| hex(sm4_encrypt('a', 'a', random_bytes(16))) |
+----------------------------------------------+
| 4F0330BF3E33689F5CE6F969EAAB719D             |
+----------------------------------------------+
Warnings:
Warning	9721	input value for iv is not valid
set block_encryption_mode = 0;
