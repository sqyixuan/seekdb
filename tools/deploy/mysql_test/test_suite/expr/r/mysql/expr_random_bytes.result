select length(random_bytes(cast('87-01-01 01:01:59' as datetime)));
ERROR HY000: argument is out of range
create table t3(c1 int, c2 float, c3 varbinary(100));
insert into t3 values(10, 9.8, random_bytes(12));
insert into t3 values(9, 5.6, random_bytes(7));
insert into t3 values(0, 5.6, random_bytes(7.6));

select length(random_bytes(c1)) from t3 where c1 = 9;
+--------------------------+
| length(random_bytes(c1)) |
+--------------------------+
|                        9 |
+--------------------------+
drop table t3;
