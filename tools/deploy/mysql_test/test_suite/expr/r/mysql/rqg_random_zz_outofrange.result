col_varchar_16_index varchar(16),
col_char_20_index char(20),
/*Indices*/
key idx10(col_char_20_key ),
key idx16(col_timestamp_6_key ),
key idx4(col_char_5_key ),
index idx5(col_char_5_index ),
key idx1(col_bigint_key ),
