result_format: 4


drop table if exists t1, t2, t3;
SET sql_mode='';
select CAST(0 AS UNSIGNED) -1;
ERROR 22003: BIGINT UNSIGNED value is out of range in ''(0 + -1)''
CREATE TABLE t1(a INT UNSIGNED, b DECIMAL(10,2) UNSIGNED);
INSERT INTO t1 VALUES (2015, 123456.78);

CREATE TABLE t2(a INT UNSIGNED, b INT UNSIGNED);
INSERT INTO t2 VALUES (2015, 123456);

CREATE TABLE t3(a DECIMAL(10,2) UNSIGNED, b DECIMAL(10,2) UNSIGNED);
INSERT INTO t3 VALUES (2015, 123456);

SELECT a - b FROM t1;
+------------+
| a - b      |
+------------+
| -121441.78 |
+------------+
SELECT a - b FROM t2;
ERROR 22003: BIGINT UNSIGNED value is out of range in ''(2015 - 123456)''
SELECT a - b FROM t3;
+------------+
| a - b      |
+------------+
| -121441.00 |
+------------+

SET sql_mode=NO_UNSIGNED_SUBTRACTION;
select CAST(0 AS UNSIGNED) -1;
ERROR 22003: BIGINT UNSIGNED value is out of range in ''(0 + -1)''
SELECT a - b FROM t1;
+------------+
| a - b      |
+------------+
| -121441.78 |
+------------+
SELECT a - b FROM t2;
+---------+
| a - b   |
+---------+
| -121441 |
+---------+
SELECT a - b FROM t3;
+------------+
| a - b      |
+------------+
| -121441.00 |
+------------+

DROP TABLE t1, t2, t3;
SET sql_mode='';
