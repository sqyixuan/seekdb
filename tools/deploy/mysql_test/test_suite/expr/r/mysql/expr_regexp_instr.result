drop table if exists t1;
create table t1(c1 int, c2 int);
insert into t1 values(regexp_instr('阿里2巴3巴','\d{1,}'), regexp_instr('阿里123巴巴','阿|巴', 1, 1, 1));
select * from t1 where c1 = 0;
+------+------+
| c1   | c2   |
+------+------+
|    0 |    2 |
+------+------+
select * from t1 where c2 = (regexp_instr('1a232','1', 1, 1, 1));
+------+------+
| c1   | c2   |
+------+------+
|    0 |    2 |
+------+------+
drop table t1;

create table t1 (c1 varchar(10), c2 varchar(10) collate utf8mb4_bin);
insert into t1 values('a', 'b'),('a', 'B'),('A', 'b');

select regexp_instr(c1, 'a', 1) from t1;
+--------------------------+
| regexp_instr(c1, 'a', 1) |
+--------------------------+
|                        1 |
|                        1 |
|                        1 |
+--------------------------+
select regexp_instr(c2, 'b', 1) from t1;
+--------------------------+
| regexp_instr(c2, 'b', 1) |
+--------------------------+
|                        1 |
|                        0 |
|                        1 |
+--------------------------+
drop table t1;

drop table if exists v1;
create view v1 as select regexp_instr('abcabd', '\Aa') as c1 from dual;
desc v1;
+-------+------------+------+-----+---------+-------+
| Field | Type       | Null | Key | Default | Extra |
+-------+------------+------+-----+---------+-------+
| c1    | bigint(20) | NO   |     |         |       |
+-------+------------+------+-----+---------+-------+
drop view v1;
