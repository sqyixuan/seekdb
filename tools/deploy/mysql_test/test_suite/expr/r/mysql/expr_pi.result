result_format: 4
SELECT PI();
+----------+
| PI()     |
+----------+
| 3.141593 |
+----------+

SELECT format(PI(), 10);
+------------------+
| format(PI(), 10) |
+------------------+
| 3.1415926536     |
+------------------+

SELECT PI()+ 0.0000000000;
+--------------------+
| PI()+ 0.0000000000 |
+--------------------+
|       3.1415926536 |
+--------------------+

SELECT PI() + 0.000000000000000000;
+-----------------------------+
| PI() + 0.000000000000000000 |
+-----------------------------+
|        3.141592653589793000 |
+-----------------------------+

SELECT PI() + 0.000000000000000000000000000000;
+-----------------------------------------+
| PI() + 0.000000000000000000000000000000 |
+-----------------------------------------+
|        3.141592653589793000000000000000 |
+-----------------------------------------+
