drop table if exists test;
create table test as select char(13) c1, char(13, 13) c2, char(13, 13, 13 using utf8mb4) c3;
desc test;
Field	Type	Null	Key	Default	Extra
c1	varbinary(4)	YES		NULL	
c2	varbinary(8)	YES		NULL	
c3	varchar(12)	YES		NULL	
select * from test;
c1	c2	c3
		
select hex(c1), hex(c2), hex(c3) from test;
hex(c1)	hex(c2)	hex(c3)
0D	0D0D	0D0D0D
drop table test;
