result_format: 4
drop table if exists t1, t2;
drop view if exists v1, v2;
create table t1(c1 longtext, c2 longtext);
insert into t1 values('abcdef', substr(c1, 2, 3));
create view v1 as select substr(c1, 2, 3)  from t1;
desc v1;
+------------------+------------+------+-----+---------+-------+
| Field            | Type       | Null | Key | Default | Extra |
+------------------+------------+------+-----+---------+-------+
| substr(c1, 2, 3) | varchar(3) | YES  |     | NULL    |       |
+------------------+------------+------+-----+---------+-------+

create table t2(c1 blob, c2 blob);
insert into t2 values('abcdef', substr(c1, 2, 3));
create view v2 as select substr(c1, 2, 3)  from t2;
desc v1;
+------------------+------------+------+-----+---------+-------+
| Field            | Type       | Null | Key | Default | Extra |
+------------------+------------+------+-----+---------+-------+
| substr(c1, 2, 3) | varchar(3) | YES  |     | NULL    |       |
+------------------+------------+------+-----+---------+-------+

drop table t1, t2;
drop view v1, v2;

