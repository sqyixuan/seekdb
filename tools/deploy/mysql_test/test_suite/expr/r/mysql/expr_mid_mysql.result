SELECT mid( '' , 1) RLIKE 'a' ;
+------------------------+
| mid( '' , 1) RLIKE 'a' |
+------------------------+
|                      0 |
+------------------------+
SELECT mid( 'abc' , 1) RLIKE 'a' ;
+---------------------------+
| mid( 'abc' , 1) RLIKE 'a' |
+---------------------------+
|                         1 |
+---------------------------+

