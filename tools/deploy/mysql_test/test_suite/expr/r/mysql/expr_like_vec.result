drop table t1;
drop table if exists t2;
create table t2 (a varchar(500)) COLLATE=utf8mb4_bin with column group (each column);
insert into t2 values('abcdefghijklmnopqrstuvwxyz');
insert into t2 values('01234567890');
insert into t2 values('你好');
insert into t2 values('baidugoogle?abcdefghijklmnopqrst');
insert into t2 values('google?baidu.com?abcdefghijklmnopqrst');
insert into t2 values('google');
insert into t2 values('baidu.com?abcdefghijklmnopqrst@google');
insert into t2 values(NULL);
insert into t2 values('');
select * from t2 where a like '%google%';
a
