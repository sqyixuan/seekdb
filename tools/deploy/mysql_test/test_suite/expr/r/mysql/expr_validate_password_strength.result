# prepare variables
set global validate_password_mixed_case_count = 1;
set global validate_password_number_count = 1;
set global validate_password_special_char_count = 1;
set global validate_password_length = 8;
show variables like 'validate_pass%';
Variable_name	Value
validate_password_check_user_name	on
validate_password_dictionary_file	
validate_password_length	8
validate_password_mixed_case_count	1
validate_password_number_count	1
validate_password_policy	low
validate_password_special_char_count	1
# error params
select validate_password_strength();
ERROR 42000: Incorrect parameter count in the call to native function 'validate_password_strength'
select validate_password_strength('1','');
ERROR 42000: Incorrect parameter count in the call to native function 'validate_password_strength'
# basic test
# WEAK: Length < 4 or password matches the user name
select validate_password_strength('ab');
validate_password_strength('ab')
0
select validate_password_strength('123');
validate_password_strength('123')
0
select validate_password_strength('admin');
validate_password_strength('admin')
0
select validate_password_strength('三个字');
validate_password_strength('三个字')
0
# LESS_WEAK: Length >= 4 and < validate_password_length
select validate_password_strength('abcde');
validate_password_strength('abcde')
25
select validate_password_strength('123abc');
validate_password_strength('123abc')
25
select validate_password_strength('四个字符');
validate_password_strength('四个字符')
25
# LOW: Length >= validate_password_length
select validate_password_strength('12345678');
validate_password_strength('12345678')
50
select validate_password_strength('abcd1234');
validate_password_strength('abcd1234')
50
# MEDIUM: mix_case/number/special chars count all match rules
# STRONG: not match words in the dictionary file(always passed)
select validate_password_strength('abc123A$');
validate_password_strength('abc123A$')
100
select validate_password_strength('123--ABc');
validate_password_strength('123--ABc')
100
# null params
select validate_password_strength(null);
validate_password_strength(null)
NULL
select validate_password_strength('');
validate_password_strength('')
0
# non-ascii characters, treated as special char (not compatible with mysql)
select validate_password_strength('ab123A中文');
validate_password_strength('ab123A中文')
100
# non-string params
select validate_password_strength(1234567);
validate_password_strength(1234567)
25
select validate_password_strength(3.141592);
validate_password_strength(3.141592)
50
# cleanup
set global validate_password_mixed_case_count = 0;
set global validate_password_number_count = 0;
set global validate_password_special_char_count = 0;
set global validate_password_length = 0;
select validate_password_strength('test');
validate_password_strength('test')
100
drop table if exists t1;
create table t1 as select validate_password_strength('test') c1 from dual;
desc t1;
Field	Type	Null	Key	Default	Extra
c1	int(10)	YES		NULL	
drop table t1;
