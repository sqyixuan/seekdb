drop table if exists t1;
create table t1(c1 decimal unsigned, c2 char(10), c3 longtext);
insert into t1 values(0, '-1', '-1');
explain_protocol: 1
result_format: 4
EXPLAIN BASIC select * from t1 where c1 = c2;
