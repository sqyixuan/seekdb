SET sql_mode = 'NO_BACKSLASH_ESCAPES';
SELECT _latin1'a\bc' LIKE _latin1'a\%' AS col1, _utf8mb4'a\bc' LIKE _utf8mb4'a\%' AS col2;
col1	col2
1	1
SELECT 'abc''' like 'a%';
'abc''' like 'a%'
1
SELECT 'abc''' like 'ab''c%';
'abc''' like 'ab''c%'
0
SELECT 'abc' like 'ab''%';
'abc' like 'ab''%'
0
SELECT 'abc%' LIKE 'abc#%' ESCAPE '#';
'abc%' LIKE 'abc#%' ESCAPE '#'
1
drop table if exists t1, t2;
create table t1(c1 int primary key, c2 varchar(50));
insert into t1 values(0, 'a');
insert into t1 values(1, 'ab');
insert into t1 values(2, 'abc');
insert into t1 values(3, 'aa');
insert into t1 values(4, 'a\');
insert into t1 values(5, 'ab''c');
insert into t1 values(6, 'abc%');
select * from t1;
c1	c2
0	a
1	ab
2	abc
3	aa
4	a\
5	ab'c
6	abc%
CREATE TABLE `t2` (
`a` int(11) NOT NULL AUTO_INCREMENT
) CHARSET = utf8mb4;
insert into t2 values(1);
insert into t2 values(6);
select * from t2 where a not like _gb18030'a\\\\b';
a
1
6
