result_format: 4
drop database if exists dml_cast_mode;
create database dml_cast_mode;
use dml_cast_mode;

set sql_mode = 'strict_all_tables';

"basic"
create table t1 (c1 int ,c2 varchar(20), c3 date);
insert into t1 values(1,'test01','20220811');
select * from t1 where c2 > 1;
+------+------+------+
| c1   | c2   | c3   |
+------+------+------+
+------+------+------+
Warnings:
Warning	1292	Truncated incorrect DECIMAL value: 'test01'
delete from t1 where c2 > 1;
ERROR 22007: Truncated incorrect DECIMAL value: 'test01'
delete from t1 where substr(c2, 1, 100) > 1;
Warnings:
Warning	1292	Truncated incorrect DECIMAL value: 'test01'
drop table t1;

"column convert"
create table t1 (c1 int, c2 varchar(10));
insert into t1 values (1, 'a');

insert into t1(c1) values ('a');
ERROR HY000: Incorrect integer value for column 'c1' at row 1
insert into t1(c1) select 'a';
ERROR HY000: Incorrect integer value for column 'c1' at row 1
insert into t1(c1) select c2 from t1;
ERROR HY000: Incorrect integer value for column 'c1' at row 1
update t1 set c1 = 'a';
ERROR HY000: Incorrect integer value for column 'c1' at row 1
update t1 set c1 = c2;
ERROR HY000: Incorrect integer value for column 'c1' at row 1

insert into t1(c1) values (substr('a', 1, 100));
ERROR HY000: Incorrect integer value for column 'c1' at row 1
insert into t1(c1) select substr('a', 1, 100);
ERROR HY000: Incorrect integer value for column 'c1' at row 1
insert into t1(c1) select substr(c2, 1, 100) from t1;
ERROR HY000: Incorrect integer value for column 'c1' at row 1
update t1 set c1 = substr('a', 1, 100);
ERROR HY000: Incorrect integer value for column 'c1' at row 1
update t1 set c1 = substr(c2, 1, 100);
ERROR HY000: Incorrect integer value for column 'c1' at row 1

insert into t1(c1) values ('a' + 1);
ERROR 01000: Data truncated for column 'c1' at row 1
insert into t1(c1) select 'a' + 1;
ERROR 01000: Truncated incorrect DOUBLE value
insert into t1(c1) select c2 + 1 from t1;
ERROR 01000: Truncated incorrect DOUBLE value
update t1 set c1 = 'a' + 1;
ERROR 01000: Data truncated for column 'c1' at row 1
update t1 set c1 = c2 + 1;
ERROR 01000: Data truncated for column 'c1' at row 1

drop table t1;

"dml cast"
"implicit cast"
create table t1 (c1 int ,c2 varchar(20), c3 date);
insert into t1 values(1,'test01','20220811');

delete from t1 where c2 > 1;
ERROR 22007: Truncated incorrect DECIMAL value: 'test01'
delete from t1 where c2 + 1 > 1;
ERROR 01000: Truncated incorrect DOUBLE value

delete from t1 where substr(c2, 1, 100) > 1;
Warnings:
Warning	1292	Truncated incorrect DECIMAL value: 'test01'
delete from t1 where ifnull(c2,c2) > 1;
Warnings:
Warning	1292	Truncated incorrect DECIMAL value: 'test01'

delete from t1 where c1 > 'code';
ERROR 22007: Truncated incorrect DECIMAL value: 'code'
delete from t1 where c1 < substr('code', 1,100);
Warnings:
Warning	1292	Truncated incorrect DECIMAL value: 'code'
Warning	1292	Truncated incorrect DECIMAL value: 'code'
Warning	1292	Truncated incorrect DECIMAL value: 'code'
Warning	1292	Truncated incorrect DECIMAL value: 'code'
Warning	1292	Truncated incorrect DECIMAL value: 'code'
Warning	1292	Truncated incorrect DECIMAL value: 'code'

"explicit cast"
delete from t1 where cast(c2 as double)  > 1;
ERROR 01000: Truncated incorrect DOUBLE value
delete from t1 where cast(c2 as double) + 1  > 1;
ERROR 01000: Truncated incorrect DOUBLE value

delete from t1 where cast(substr(c2, 1, 100) as double) > 1;
Warnings:
Warning	1292	Truncated incorrect DOUBLE value: 'test01'
delete from t1 where cast(ifnull(c2,c2) as double) > 1;
Warnings:
Warning	1292	Truncated incorrect DOUBLE value: 'test01'

delete from t1 where c1 > cast('code' as double);
ERROR 01000: Truncated incorrect DOUBLE value
delete from t1 where c1 < cast(substr('code', 1,100) as double);
Warnings:
Warning	1292	Truncated incorrect DOUBLE value: 'code'
Warning	1292	Truncated incorrect DOUBLE value: 'code'

"multi stmt"
create table t2 as select * from t1;
delete from t1 where c1 > (select 1 from t2 where c2 > 1);
ERROR 22007: Truncated incorrect DECIMAL value: 'test01'
delete from t1 where c1 > (select 1 from t2 where c2 + 1> 1);
ERROR 01000: Truncated incorrect DOUBLE value
delete from t1 where c1 > (select 1 from t2 where substr(c2, 1, 100) > 1);
Warnings:
Warning	1292	Truncated incorrect DECIMAL value: 'test01'

"view"
create view v1 as select c2 as c1, substr(c2, 1, 100) c2 from t2;
delete from t1 where c1 > (select 1 from v1 where c1 > 1);
ERROR 22007: Truncated incorrect DECIMAL value: 'test01'
delete from t1 where c1 > (select 1 from v1 where c2 > 1);
ERROR 22007: Truncated incorrect DECIMAL value: 'test01'

drop table t1, t2;
drop view v1;

"temporal type cast"
create table t1 (c1 date, c2 datetime, c3 timestamp, c4 year, c5 time);
insert into t1 values ('20200101', '20200101', '20200101', '2020', '11:00:00');
delete from t1 where c1 > 11;
ERROR 22007: Incorrect value
delete from t1 where c1 > cast(11 as date);
ERROR 22007: Incorrect value
delete from t1 where c1 > day(20220811);
ERROR 22007: Incorrect value
delete from t1 where c1 > cast(day(20220811) as date);
ERROR 22007: Incorrect value
delete from t1 where c1 > ifnull(12, 13);
ERROR 22007: Incorrect value
delete from t1 where c1 > cast(ifnull(12, 13) as date);
ERROR 22007: Incorrect value
delete from t1 where c2 > 11;
ERROR 22007: Incorrect value
delete from t1 where c3 > 11;
ERROR 22007: Incorrect value

drop database dml_cast_mode;
