result_format: 3
drop table if exists t1;
create table t1 (c1 timestamp);
set ob_log_level='sql.*:debug';
insert into t1 values(NULL);
select * from t1;
+------+
| c1   |
+------+
| NULL |
+------+
select timestamp_nvl(c1, '2019-01-01 00:00:00') from t1;
+------------------------------------------+
| timestamp_nvl(c1, '2019-01-01 00:00:00') |
+------------------------------------------+
| 2019-01-01 00:00:00                      |
+------------------------------------------+
select timestamp_nvl(c1, timestamp'2019-01-01 00:00:00') from t1;
+---------------------------------------------------+
| timestamp_nvl(c1, timestamp'2019-01-01 00:00:00') |
+---------------------------------------------------+
| 2019-01-01 00:00:00                               |
+---------------------------------------------------+
select timestamp_nvl(c1, 123) from t1;
+------------------------+
| timestamp_nvl(c1, 123) |
+------------------------+
| 2000-01-23 00:00:00    |
+------------------------+
select timestamp_nvl(c1, '123') from t1;
+--------------------------+
| timestamp_nvl(c1, '123') |
+--------------------------+
| 0000-00-00 00:00:00      |
+--------------------------+
select timestamp_nvl(c1, '123123123123123') from t1;
+--------------------------------------+
| timestamp_nvl(c1, '123123123123123') |
+--------------------------------------+
| 0000-00-00 00:00:00                  |
+--------------------------------------+
select timestamp_nvl(c1, 'invalid string') from t1;
+-------------------------------------+
| timestamp_nvl(c1, 'invalid string') |
+-------------------------------------+
| 0000-00-00 00:00:00                 |
+-------------------------------------+
drop table t1;
create table t1 (c1 timestamp);
insert into t1 values (123);
insert into t1 values ('123');
ERROR 22007: Incorrect datetime value for column 'c1' at row 1
insert into t1 values ('123123123123123');
ERROR 22007: Incorrect datetime value for column 'c1' at row 1
insert into t1 values ('invalid string');
ERROR 22007: Incorrect datetime value for column 'c1' at row 1
select * from t1;
+---------------------+
| c1                  |
+---------------------+
| 2000-01-23 00:00:00 |
+---------------------+
drop table t1;
