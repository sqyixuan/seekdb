FIND_IN_SET(binary 'B','a,B,c,d')
2
drop table if exists t1;
select find_in_set(convert('C' using utf16), convert('B,A,b,c,a,D,d,C' using utf16));
find_in_set(convert('C' using utf16), convert('B,A,b,c,a,D,d,C' using utf16))
4
select find_in_set(convert('b' using gb18030), convert('B,A,b,c,a,D,d,C' using gb18030));
find_in_set(convert('b' using gb18030), convert('B,A,b,c,a,D,d,C' using gb18030))
1
create table t1(pk int primary key, c1 varchar(100) collate utf8mb4_bin, c2 varchar(100) collate utf8mb4_general_ci, c3 varchar(100) collate utf16_bin, c4 varchar(100) collate utf16_general_ci);
insert into t1 values(1, 'a', 'B,A,b,c,a,D,d,C', 'C', 'D');
select find_in_set(c1,c2), find_in_set(c3,c2), find_in_set(c4,c2) from t1;
find_in_set(c1,c2)	find_in_set(c3,c2)	find_in_set(c4,c2)
5	4	6
delete from t1;
insert into t1 values(1, 'B,A,b,c,a,D,d,C', 'a', 'C', 'D');
select find_in_set(c2,c1), find_in_set(c3,c1), find_in_set(c4,c1) from t1;
find_in_set(c2,c1)	find_in_set(c3,c1)	find_in_set(c4,c1)
5	8	6
delete from t1;
insert into t1 values(1, 'a', 'C', 'B,A,b,c,a,D,d,C', 'D');
select find_in_set(c1,c3), find_in_set(c2,c3), find_in_set(c4,c3) from t1;
find_in_set(c1,c3)	find_in_set(c2,c3)	find_in_set(c4,c3)
5	4	6
delete from t1;
insert into t1 values(1, 'a', 'C', 'D', 'B,A,b,c,a,D,d,C');
select find_in_set(c1,c4), find_in_set(c2,c4), find_in_set(c3,c4) from t1;
find_in_set(c1,c4)	find_in_set(c2,c4)	find_in_set(c3,c4)
5	4	6
delete from t1;
drop table t1;
select FIND_IN_SET(_latin1'B', _latin1'a,b,c,d') from dual;
FIND_IN_SET(_latin1'B', _latin1'a,b,c,d')
2
select FIND_IN_SET(_gbk '繁體ing',_gbk '繁體ing') as gbk_res from dual;
gbk_res
1
drop table if exists test_aaa;
drop table if exists test_bbb;
drop table if exists test_find_in_set;
CREATE TABLE `test_aaa` (
`uuid` bigint(20) NOT NULL AUTO_INCREMENT COMMENT 'auto increment id',
`create_time` datetime NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT 'record create time',
`update_time` datetime DEFAULT NULL ON UPDATE CURRENT_TIMESTAMP COMMENT 'record update time',
`id` int(11) DEFAULT NULL,
`namels` varchar(256) COLLATE utf8mb4_bin DEFAULT NULL,
`uid` varchar(256) COLLATE utf8mb4_bin DEFAULT NULL,
PRIMARY KEY (`uuid`)
) DEFAULT CHARSET = utf8mb4 COLLATE = utf8mb4_bin  WITH COLUMN GROUP(each column);
CREATE TABLE `test_bbb` (
`uuid` bigint(20) NOT NULL AUTO_INCREMENT COMMENT 'auto increment id',
`create_time` datetime NOT NULL DEFAULT CURRENT_TIMESTAMP COMMENT 'record create time',
`update_time` datetime DEFAULT NULL ON UPDATE CURRENT_TIMESTAMP COMMENT 'record update time',
`name` varchar(256) COLLATE utf8mb4_bin DEFAULT NULL,
`uid` varchar(256) COLLATE utf8mb4_bin DEFAULT NULL,
PRIMARY KEY (`uuid`)
) DEFAULT CHARSET = utf8mb4 COLLATE = utf8mb4_bin WITH COLUMN GROUP(each column);
INSERT into test_aaa(id,namels,uid) 
select 1 as id,'aa,bb,cc' as namels,'1' as uid union all
select 1 as id,'aa,bb,cc' as namels,'2' as uid union all
select 1 as id,'aa,bb,cc' as namels,'3' as uid union all
select 2 as id,'aa,cc'    as namels,'4' as uid union all
select 2 as id,'aa,cc'    as namels,'5' as uid union all
select 3 as id,'aa'       as namels,'6' as uid 
;
INSERT into test.test_bbb(name,uid) 
select 'aa' as name,'1'  as uid union all
select 'bb' as name,'1'  as uid union all
select 'cc' as name,'1'  as uid union all
select 'dd' as name,'1'  as uid union all
select 'ff' as name,'1'  as uid union all
select 'aa' as name,'2'  as uid union all
select 'bb' as name,'2'  as uid union all
select 'cc' as name,'2'  as uid union all
select 'aa' as name,'3'  as uid union all
select 'bb' as name,'3'  as uid union all
select 'cc' as name,'3'  as uid union all
select 'ff' as name,'3'  as uid union all
select 'aa' as name,'4'  as uid union all
select 'bb' as name,'4'  as uid union all
select 'cc' as name,'4'  as uid union all
select 'aa' as name,'5'  as uid union all
select 'cc' as name,'5'  as uid union all
select 'aa' as name,'6'  as uid union all
select 'bb' as name,'6'  as uid         
;
create table test_find_in_set as select bbb.name, aaa.namels  from test.test_aaa aaa join test.test_bbb bbb on bbb.uid=aaa.uid;
select name, namels, find_in_set(name, namels) from test_find_in_set;
name	namels	find_in_set(name, namels)
aa	aa,bb,cc	1
bb	aa,bb,cc	2
cc	aa,bb,cc	3
dd	aa,bb,cc	0
