create table t2 as select regexp_substr(c1,c2) c1_2, regexp_substr(c1,c3) c1_3, regexp_substr(c1,c1) c1_1 from t1;
show create table t2;
Table	Create Table
t2	CREATE TABLE `t2` (
  `c1_2` varchar(20) CHARACTER SET utf8mb4 COLLATE utf8mb4_bin DEFAULT NULL,
  `c1_3` varbinary(20) DEFAULT NULL,
  `c1_1` varchar(20) DEFAULT NULL
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
drop table t2;

create table t2 as select regexp_substr(c3,c1) c3_1, regexp_substr(c3,c2) c3_3, regexp_substr(c3,c3) c3_2 from t1;
show create table t2;
Table	Create Table
t2	CREATE TABLE `t2` (
  `c3_1` longblob DEFAULT NULL,
  `c3_3` longblob DEFAULT NULL,
  `c3_2` longblob DEFAULT NULL
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
drop table t2;

drop table t1;



