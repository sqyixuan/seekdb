+---------------------------------+

create table t2 as select regexp_replace(c1,c2,'a') c1_2, regexp_replace(c1,c3,'a') c1_3, regexp_replace(c1,c1,'a') c1_1 from t1;
show create table t2;
Table	Create Table
t2	CREATE TABLE `t2` (
  `c1_2` longtext CHARACTER SET utf8mb4 COLLATE utf8mb4_bin DEFAULT NULL,
  `c1_3` longblob DEFAULT NULL,
  `c1_1` longtext DEFAULT NULL
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
drop table t2;
create table t2 as select regexp_replace(c1,'a',c2) c1_2, regexp_replace(c1,'a',c3) c1_3, regexp_replace(c1,'a',c1) c1_1 from t1;
show create table t2;
Table	Create Table
t2	CREATE TABLE `t2` (
  `c1_2` longtext DEFAULT NULL,
  `c1_3` longtext DEFAULT NULL,
  `c1_1` longtext DEFAULT NULL
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
drop table t2;

