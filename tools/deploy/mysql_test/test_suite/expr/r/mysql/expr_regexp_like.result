drop table if exists t1;
create table t1 (c1 varchar(10), c2 varchar(10) collate utf8mb4_bin);
insert into t1 values('a', 'b'),('a', 'B'),('A', 'b');

select * from t1 where regexp_like(c1,'a');
+------+------+
| c1   | c2   |
+------+------+
| a    | b    |
| a    | B    |
| A    | b    |
+------+------+
select * from t1 where regexp_like(c2,'b');
+------+------+
| c1   | c2   |
+------+------+
| a    | b    |
| A    | b    |
+------+------+

drop table t1;

select 1 from dual where regexp_like ('Aa', 'Aa','p');
ERROR HY000: Incorrect arguments to use match param in regexp expression
select 1 from dual where regexp_like ('22', '22', 'q');
ERROR HY000: Incorrect arguments to use match param in regexp expression
select 1 from dual where regexp_like(NULL, '(');
ERROR HY000: unmatched parentheses in regular expression
select 1 from dual where regexp_like(NULL, '\d[');
ERROR HY000: unmatched bracket in regular expression
select 1 from dual where regexp_like(NULL, '\d{3');
ERROR 42000: Got error 'U_REGEX_BAD_INTERVAL' from regexp
select 1 from dual where regexp_like('abc', '');
ERROR 42000: Got error from regexp
select 1 from dual where regexp_like('abcABC', 'a b c a b c', 'x');
ERROR HY000: Incorrect arguments to use match param in regexp expression

drop table if exists t1;
create table t1(a int, b varchar(50));

insert into t1 values(1,'qqqqqqqdqqqqq');
insert into t1 values(2,'(020)12345678');
insert into t1 values(3,'192.168.0.1');
insert into t1 values(4,'123a34cc');
insert into t1 values(5,'A7007');
insert into t1 values(6,'001517729C28');
insert into t1 values(7,'人民日报');
insert into t1 values(8,'DNF*cf（QQ华夏');
insert into t1 values(9,'12345678cc');
insert into t1 values(10,'14844887@sina.com');
insert into t1 values(11,'http');
insert into t1 values(12,'ftp');
insert into t1 values(13,'https');
insert into t1 values(14,'ftps');

select * from t1 where regexp_like(b,'^[[:lower:],[:digit:]]','i');
+------+-------------------+
| a    | b                 |
+------+-------------------+
|    1 | qqqqqqqdqqqqq     |
|    3 | 192.168.0.1       |
|    4 | 123a34cc          |
|    5 | A7007             |
|    6 | 001517729C28      |
|    8 | DNF*cf（QQ华夏    |
|    9 | 12345678cc        |
|   10 | 14844887@sina.com |
|   11 | http              |
|   12 | ftp               |
|   13 | https             |
|   14 | ftps              |
+------+-------------------+

drop table t1;

create table t1(c1 blob);
insert into t1 values('UNPRESS123');
insert into t1 values('UNPRESS456');
select * from t1 where c1 regexp '^U';
+------------+
| c1         |
+------------+
| UNPRESS123 |
| UNPRESS456 |
+------------+

drop table if exists t1,t2;
CREATE TABLE t1 (
  id varchar(64) NOT NULL,
  delete_time bigint(20) NOT NULL DEFAULT '0',
  create_time bigint(20) NOT NULL,
  doc_data json NOT NULL,
  PRIMARY KEY (delete_time,id),
  KEY idx_deletetime (id,delete_time)
);
insert into t1 set id='1', create_time = 1, doc_data='{"num": 0, "queryDocumentTest_key": "queryDocumentTest_value"}';
SELECT * FROM t1 WHERE JSON_VALUE(doc_data, '$.\"queryDocumentTest_key\"') REGEXP BINARY 'queryDocumentTest_value';
ERROR HY000: Character set 'utf8mb4_general_ci' cannot be used in conjunction with 'binary' in regexp function call.

drop table t1;
create table t1(c1 varchar(20), c2 varchar(20) collate utf8mb4_bin , c3 blob);
##regexp
SELECT '' REGEXP BINARY NULL;
ERROR HY000: Character set 'utf8mb4_general_ci' cannot be used in conjunction with 'binary' in regexp function call.
SELECT NULL REGEXP BINARY NULL;
+-------------------------+
| NULL REGEXP BINARY NULL |
+-------------------------+
|                    NULL |
+-------------------------+
SELECT 'A' REGEXP BINARY NULL;
ERROR HY000: Character set 'utf8mb4_general_ci' cannot be used in conjunction with 'binary' in regexp function call.
SELECT 'AAA' REGEXP BINARY NULL;
ERROR HY000: Character set 'utf8mb4_general_ci' cannot be used in conjunction with 'binary' in regexp function call.
SELECT 'aaa' REGEXP x'01';
ERROR HY000: Character set 'utf8mb4_general_ci' cannot be used in conjunction with 'binary' in regexp function call.
SELECT x'01' REGEXP 'aaa';
ERROR HY000: Character set 'binary' cannot be used in conjunction with 'utf8mb4_general_ci' in regexp function call.
SELECT x'01' REGEXP BINARY '01';
+--------------------------+
| x'01' REGEXP BINARY '01' |
+--------------------------+
|                        0 |
+--------------------------+
SELECT '1' REGEXP 1;
+--------------+
| '1' REGEXP 1 |
+--------------+
|            1 |
+--------------+
SELECT 1 REGEXP 1;
+------------+
| 1 REGEXP 1 |
+------------+
|          1 |
+------------+

