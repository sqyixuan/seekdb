#### owner: xiaoyi.xy
#### owner group: sql2

--result_format 4

--disable_warnings
drop table if exists t1, t2;
--enable_warnings

create table t1(c1 int primary key, c2 int default '1', gen_sc int generated always as (c2));
insert into t1(c1, c2) values (1, 2);
select * from t1;
select default(gen_sc) from t1;
SELECT * FROM (SELECT default(gen_sc) FROM t1 GROUP BY gen_sc) d;

# 
create table t2 (c1 int default 1, c2 varchar(100));
insert into t2 (c2) values ('v1');
insert into t2 (c2) values ('v2');

select * from t2 where c1 = (select default(c1) from dual);
select * from t2 where c1 = (select default(c1));

select default(c1) from t2;
select default(c2) from t2;
select * from t2 where c1 = (select default(c2) from dual);

select * from t2 where c1 in (select v.a from (select c1 as a from dual)v);
select * from t2 where c1 in (select v.a from (select default(c1) as a from dual)v);

drop table t1, t2;
