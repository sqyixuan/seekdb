# owner: bin.lb
#tags: optimizer
# owner group: sql2
# fix bug of neg expr:

--disable_warnings
drop table if exists t1;
--enable_warnings

select -false;
select -true;
select --'a';

--disable_abort_on_error

# INT64 bound
select -(-(9223372036854775808));
create table t1 (c1 bigint, c2 bigint unsigned);
insert into t1 (c1, c2) values (-9223372036854775808, 9223372036854775808);
insert into t1 (c1, c2) values (0, 9223372036854775809);

select c1, -c1 from t1 where c1 != 0;
select c2, -c2 from t1 where c1 != 0;
select c2, --c2 from t1 where c1 != 0;
select c2, ---c2 from t1 where c1 != 0;

select c2, -c2 from t1 where c1 = 0;

explain basic select c1, -c1, --c1, ---c1, ----c1, -----c1, ------c1 from t1;


# tinyint
drop table t1;
create table t1 (c1 tinyint);
insert into t1 (c1) values (-2), (-1), (0), (1), (2);
select c1, -c1 from t1;


# time type
drop table t1;
create table t1 (c1 date, c2 datetime, c3 timestamp, c4 time, c5 year);
insert into t1 (c1, c2, c3, c4, c5) values ('2020-12-01', '2020-12-01', '2020-12-01', '12:00', '2020');
select c1, -c1, --c1, c2, -c2, --c2, c3, -c3, --c3, c4, -c4, --c4, c5, -c5, --c5 from t1;


drop table t1;

# security fuzzy testing
( SELECT ( + ( - - 13 - - - 59 + - 86 ) * - - - false / - - 2 ) FROM ( SELECT ( - + - - 93 - + ( - - date'1965-10-20' IN ( 'Australia/Broken_Hill' ) ) - 99 + - - - - - - -2147483648 - - 3 ) ) v0 ) ;
( SELECT + - - ( 'PVARGAS' < - - 'x2' ) - - - - + - - - - - - - -2147483648 - - - - - 63 FROM ( SELECT ( NULL ) = + - - - - - - -1 + - - - - - - 0 - - - - - -1 < '1111' ) v0 ) ;
( SELECT - - REVERSE ( 'debug' ) FROM ( SELECT 'WGST' < COLLATION ( '24-DEC-1997' ) ) v0 ) ;
( SELECT - FALSE ) ;
( SELECT - - 'Ande' = 'DLEE' FROM ( SELECT ( + - - ( '1111111111' < - - 'MMARVINS' ) - + - - - - - - 37 - - - - - 38 + - - - - - -128 ) ) v0 WHERE - 'QMT' = 'DLEE' OR - 84 = + - + - - -1 ) ;
