#Bugfix:
--disable_warnings
drop table if exists t1,t2;
--enable_warnings

select from_base64('    ');
select from_base64(' ');
select from_base64('\n');
select from_base64('\n\n');
select from_base64('\r');
select from_base64('\r\r');
select from_base64('\t');
select from_base64('\t\t');
select from_base64(' \t  \n   \r  ');

create table t1 (c1 int);
--error 1366
insert into t1 select from_base64('    ');
--error 1366
insert into t1 select from_base64(' ');
--error 1366
insert into t1 select from_base64('\n');
--error 1366
insert into t1 select from_base64('\n\n');
--error 1366
insert into t1 select from_base64('\r');
--error 1366
insert into t1 select from_base64('\r\r');
--error 1366
insert into t1 select from_base64('\t');
--error 1366
insert into t1 select from_base64('\t\t');
insert into t1 select from_base64(' \t  \n   \r . ');

create table t2(c1 varbinary(20));
insert into t2 values('    '),(' '),('\n'),('\n\n'),('\r'),('\r\r'),('\t'),('\t\t'),(' \t  \n   \r  '),(' \t  \n  . \r  ');
insert into t2 select to_base64(10);
select from_base64(c1) from t2;
--error 1366
insert into t1 select from_base64(c1) from t2;
drop table t1,t2;

