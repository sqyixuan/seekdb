# owner: yuchen.wyc
# owner group: SQL2
# Test of functions FROM_BASE64

#null
SELECT FROM_BASE64(NULL);
SELECT FROM_BASE64('Y===');
SELECT FROM_BASE64('====');

#empty
SELECT FROM_BASE64('');

#single char
SELECT FROM_BASE64('a');
SELECT FROM_BASE64('a\n');
SELECT FROM_BASE64('\ta\n');
SELECT FROM_BASE64('\ta\n\r\t');

#multiple chars
SELECT FROM_BASE64('abc ');
SELECT FROM_BASE64('ab c');
SELECT FROM_BASE64('abc \n');
SELECT FROM_BASE64('ab\n c\t');
SELECT HEX(FROM_BASE64('abcd'));

#test with TO_BASE64
SELECT FROM_BASE64(TO_BASE64('阿里巴巴'));
SELECT FROM_BASE64(TO_BASE64(REPEAT('a', 75)));
SELECT FROM_BASE64(TO_BASE64(REPEAT('a', 57)));
SELECT FROM_BASE64(TO_BASE64(REPEAT('a', 57 * 2)));
SELECT FROM_BASE64(TO_BASE64(REPEAT('a', 57 * 2 + 1)));

#Boundary test
SELECT FROM_BASE64('YWFh');
SELECT FROM_BASE64('YWFh=');
SELECT FROM_BASE64('YWFh==');
SELECT FROM_BASE64('Y\nW\nF\nh\n\t\r');
SELECT FROM_BASE64('YWFh=');
SELECT FROM_BASE64('YW==');
SELECT FROM_BASE64('YQ==');
SELECT FROM_BASE64('YQ==\n\t\r');
SELECT FROM_BASE64('YQ==YQ==');
SELECT FROM_BASE64('YQ==YQ==\n\t\r');
SELECT HEX(FROM_BASE64(CONVERT('avcd' USING UTF16)));
SELECT FROM_BASE64(123);
SELECT HEX(FROM_BASE64(1234));
SELECT HEX(FROM_BASE64(TO_BASE64(CONVERT('你好' USING UTF16))));
SELECT CONVERT(FROM_BASE64(TO_BASE64(CONVERT('你好' USING UTF16))) USING UTF16);
SELECT HEX(FROM_BASE64(TO_BASE64(CONVERT('AET' USING UTF16))));
SELECT CONVERT(FROM_BASE64(TO_BASE64(CONVERT('AET' USING UTF16))) USING UTF16);
SELECT FROM_BASE64(CONVERT(TO_BASE64('你好') USING UTF16));
--disable_warnings
DROP TABLE IF EXISTS t;
--enable_warnings
CREATE TABLE t AS SELECT FROM_BASE64(TO_BASE64(REPEAT('A',65))) AS C1;
SELECT COLUMN_TYPE='varbinary(8304)' FROM  INFORMATION_SCHEMA.COLUMNS WHERE TABLE_SCHEMA='test' AND TABLE_NAME='t';
SELECT LENGTH(C1) FROM t;
DROP TABLE t;
--disable_warnings
DROP TABLE IF EXISTS t1;
--enable_warnings
CREATE TABLE t1 AS SELECT FROM_BASE64(TO_BASE64(REPEAT('A',655536))) AS C1;
SELECT COLUMN_TYPE='longblob' FROM  INFORMATION_SCHEMA.COLUMNS WHERE TABLE_SCHEMA='test' AND TABLE_NAME='t1';
SELECT LENGTH(C1) FROM t1;
--disable_warnings
DROP TABLE IF EXISTS t1;
CREATE TABLE t1 (a varchar(20));
INSERT INTO t1 VALUES('MQ==');
SELECT FROM_BASE64(a), HEX(a) FROM t1;
DROP TABLE t1;

#multiple rows
--disable_warnings
DROP TABLE IF EXISTS t1;
--enable_warnings
CREATE TABLE t1(c1 varchar(20));
INSERT INTO t1 VALUES ('MQ=='), ('Mg==');
SELECT FROM_BASE64(c1) FROM t1;
DROP TABLE t1;

connect (syscon, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection syscon;
alter system set _rowsets_enabled=true tenant=sys;
alter system set _rowsets_enabled=true tenant=all_user;
alter system set _rowsets_enabled=true tenant=all_meta;
