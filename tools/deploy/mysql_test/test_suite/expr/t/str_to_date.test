#owner: dachuan.sdc
#owner group: sql2
#test Mysql function str_to_date

--echo ############ test %u %x %v %w ##################
--echo # format only includes these elements.
--disable_warnings
drop table if exists t1, t2, t3, t4;

create table t1(year varchar(100));
create table t2(weekday varchar(100), weekdayname varchar(100), weekdayattr varchar(100));
create table t3(fmt1 varchar(100) collate utf8_bin, fmt2 varchar(100), fmt3 varchar(100));
## year start with different weekday.
insert into t1 values('2018'), ('2019'), ('2020'), ('2015'), ('2021'), ('2022'), ('2023');
insert into t2 values(' 0 0', ' 0 Sunday', ' 0 Sun'),
		(' 0 1', ' 0 Monday', ' 0 Mon'), (' 1 0', ' 1 sunday', ' 1 sun'),
    (' 1 1', ' 1 monday', ' 1 mon'), (' 10 0', ' 10 sunday', ' 10 sun'),
		(' 10 1', ' 10 monday', ' 10 mon'), (' 53 0', ' 53 sunday', ' 53 sun'),
		(' 53 1', ' 53 monday', ' 53 mon');
insert into t3 values ('%X %V %w', '%X %V %W', '%X %V %a'), ('%x %v %w', '%x %v %W', '%x %v %a');

select concat("str_to_date(", year,  weekday, ", ", fmt1, ")") date_str, str_to_date(concat(year, weekday), fmt1) from t1, t2, t3 order by year, weekday, fmt1;
select t1.*, t2.*, t3.* from t1, t2, t3 where str_to_date(concat(year, weekday), fmt1) != str_to_date(concat(year, weekdayname), fmt2);
select t1.*, t2.*, t3.* from t1, t2, t3 where str_to_date(concat(year, weekday), fmt1) != str_to_date(concat(year, weekdayattr), fmt3);

## only record last value of %x/%X, %v/%V, %w/%W, %U/%u, previous invalid value will not be ignored.
select str_to_date('2015 1 1', '%X %V %w');
select str_to_date('2015 1 1', '%x %v %w');
select str_to_date('2015 1 2015 1 1', '%X %V %x %v %w');
select str_to_date('2015 1 2015 1 1', '%x %v %X %V %w');
select str_to_date('2015 1 2015 1 1', '%X %v %x %V %w');
select str_to_date('2015 1 2015 1 1', '%x %V %X %v %w');
select str_to_date('1 1 2015 2015 1', '%v %V %x %X %w');
select str_to_date('1 1 2015 2015 1', '%v %V %X %x %w');

select str_to_date('2015 1 1', '%X %V %w');
select str_to_date('2015 1 1 2', '%X %V %w %w');
select str_to_date('2015 1 1 Wednesday', '%X %V %w %W');
select str_to_date('2015 1 1 Sunday 4', '%X %V %w %W %w');
select str_to_date('2015 1 1 Sunday Friday', '%X %V %w %W %W');
select str_to_date('2015 1 1 Sunday Monday 6', '%X %V %w %W %W %w');

select str_to_date('2015 52 52 1', '%Y %U %u %w');
select str_to_date('2015 52 52 51 1', '%Y %U %u %U %w');
select str_to_date('2015 52 52 40 1', '%Y %U %u %U %w');

select str_to_date('2015 54 2015 1 1', '%X %V %x %v %w');
select str_to_date('2015 1 9 Sunday Monday 6', '%X %V %w %W %W %w');
select str_to_date('2015 1 9 aaa Monday 6', '%X %V %w %W %W %w');

## %u will overwrite %v, which makes single %x invalid.
select str_to_date('2015 10 1', '%x %v %w');
select str_to_date('2015 10 10 1', '%x %v %u %w');
select str_to_date('10 2015 10 1', '%u %x %v %w');
select str_to_date('2015 10 10 1', '%x %v %U %w');
select str_to_date('10 2015 10 1', '%U %x %v %w');

--echo ## unexpect parameters
--echo ### out of range
select str_to_date('54 0', '%V %w');
select str_to_date('2015 54 0', '%X %V %w');
select str_to_date('2015 1 9', '%X %V %w');
select str_to_date('2015 1 10', '%X %V %w');
--error 1411
create table t4 as select str_to_date('2015 54 0', '%X %V %w');
--error 1411
create table t4 as select str_to_date('2015 1 9', '%X %V %w');

--echo ### %X/x must be used with %V/v
select str_to_date('2020 1 1', '%X %U %w');
select str_to_date('2020 1 1', '%X %u %w');
select str_to_date('2020 1 1', '%x %U %w');
select str_to_date('2020 1 1', '%X %u %w');
select str_to_date('2020 1 1', '%X %U %w');
select str_to_date('2020 1 1 1', '%X %w %V %x');

--echo ### %V/v must with %X/x
select str_to_date('2020 0 1', '%Y %V %w');
select str_to_date('2020 0 1', '%Y %v %w');
select str_to_date('2020 1 1', '%Y %V %w');
select str_to_date('2020 1 1', '%Y %v %w');
select str_to_date('2020 10 1', '%Y %V %w');
select str_to_date('2020 10 1', '%Y %v %w');
select str_to_date('2020 10 1 10', '%x %v %w %V');


--echo ### information is not complete
select str_to_date('10 10','%U %w');

--echo ## 2. 包含新旧元素
--echo ### 2.1 新旧元素信息都充足
select str_to_date('2020 1 2020 1 1', '%X %U %Y %V %w');
select str_to_date('2020 1 2020 1 1', '%Y %U %X %V %w');
select str_to_date('2020 1 2020 1 1', '%X %V %Y %U %w');
select str_to_date('2020 1 2020 1 1', '%Y %V %X %U %w');

--echo ## complete week and weekday will overwrite month and monthday
select str_to_date('2020 1 1', '%X %V %w');
select str_to_date('2020 1 1 2020 1 6', '%X %V %w %Y %m %d');
select str_to_date('2020 1 1 2020 1 10', '%X %V %w %Y %m %d');
select str_to_date('2020 1 10 2020 1 1', '%Y %m %d %X %V %w');

select str_to_date('2020 1 1 1 6', '%Y %U %w %m %d');
select str_to_date('2020 1 1 1 10', '%Y %U %w %m %d');

--echo ### 2.2 v
--echo ## week and weekday will not overwrite month and monthday if it's not complete.
select str_to_date('2020 10 10 2022 1','%Y %m %d %X %V');
select str_to_date('2020 10 10 1','%Y %m %d %U');

--echo ### 2.3 只有新元素信息充足
select str_to_date('2010 2015 10 2', '%Y %X %V %w');
select str_to_date('2010 2015 10 2', '%X %Y %V %w');


--echo ## week + weekday is different with month + month day when year not exist·
select str_to_date('1 1', '%m %d');
select str_to_date('1 1', '%U %w');
select str_to_date('0 1 1', '%Y %U %w');
select str_to_date('0000 1 1', '%Y %U %w');
select str_to_date('0000 2 1', '%Y %U %w');
select str_to_date('0000 10 1', '%Y %U %w');
select str_to_date('0001 10 1', '%Y %U %w');


--echo ### 2.4 信息都不全
select str_to_date('10 1 1', '%m %d %u');
select str_to_date('10 1 1 1', '%m %d %u %w');
select str_to_date('10 1 1', '%m %d %w');

select str_to_date('202101', '%Y%m');
select str_to_date('20210100', '%Y%m%d');
select str_to_date('202102', '%Y%m');
select str_to_date('20210200', '%Y%m%d');
select str_to_date('202103', '%Y%m');
select str_to_date('20210300', '%Y%m%d');
select str_to_date('202003', '%Y%m');
select str_to_date('20200300', '%Y%m%d');

select str_to_date('202102', '%Y%d');
select str_to_date('20210002', '%Y%m%d');
select str_to_date('202101', '%Y%d');
select str_to_date('20210001', '%Y%m%d');

select str_to_date('2021', '%Y');
select str_to_date('20210000', '%Y%m%d');

set sql_mode = '';
select str_to_date('202101', '%Y%m');
select str_to_date('20210100', '%Y%m%d');
select str_to_date('202102', '%Y%m');
select str_to_date('20210200', '%Y%m%d');
select str_to_date('202103', '%Y%m');
select str_to_date('20210300', '%Y%m%d');
select str_to_date('202003', '%Y%m');
select str_to_date('20200300', '%Y%m%d');

select str_to_date('202102', '%Y%d');
select str_to_date('20210002', '%Y%m%d');
select str_to_date('202101', '%Y%d');
select str_to_date('20210001', '%Y%m%d');

select str_to_date('2021', '%Y');
select str_to_date('20210000', '%Y%m%d');