--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: luofan.zp
# owner group: SQL3
# description: 严格模式和非严格模式下：本case是为了测试values函数的结果要作类型转换

--disable_warnings
drop table if exists test;
--enable_warnings


create table test(c1 int primary key, c2 tinyint);
insert into test values(1,2);
--error 1264
insert into test values(1, 99999) on duplicate key update c2 = values(c2);
set sql_mode='';
insert into test values(1, 99999) on duplicate key update c2 = values(c2);
select * from test;

set sql_mode='STRICT_ALL_TABLES';
--disable_warnings
drop table if exists test;
--enable_warnings
create table test(c1 int primary key, c2 timestamp);
insert into test values(1, now());
--error 1292
insert into test values(1, 2013) on duplicate key update c2 = values(c2);
set sql_mode='';
insert into test values(1, 2013) on duplicate key update c2 = values(c2);
select * from test;

set sql_mode='STRICT_ALL_TABLES';
--disable_warnings
drop table if exists test;
--enable_warnings
create table test(c1 int primary key, c2 char(5));
insert into test values(1, 'abc');
--error 1406
insert into test values(1, 255342) on duplicate key update c2 = values(c2);
select * from test;
--error 1406
insert into test values(1, 'adegsf') on duplicate key update c2 = values(c2);
select * from test;
set sql_mode='';
insert into test values(1, 255342) on duplicate key update c2 = values(c2);
select * from test;
insert into test values(1, 'adegsf') on duplicate key update c2 = values(c2);
select * from test;


set sql_mode='STRICT_ALL_TABLES';
--disable_warnings
drop table if exists test;
--enable_warnings
create table test(c1 int primary key, c2 int unsigned);
insert into test values(1, 99);
--error 1264
insert into test values(1, -23) on duplicate key update c2 = values(c2);
select * from test;
set sql_mode='';
insert into test values(1, -23) on duplicate key update c2 = values(c2);
select * from test;

drop table test;



