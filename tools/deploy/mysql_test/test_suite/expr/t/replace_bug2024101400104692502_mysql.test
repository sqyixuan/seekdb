# owner: zhuangyifeng.zyf
# owner group: sql1
# tags: expr, cross_validation
# description: 测试 replace 函数对 varchar/longtext 类型的行为一致性

--explain_protocol 1
--result_format 4

# compat control 设置为 MYSQL5.7 时, 下列所有语句都应该输出 'aaaaa'
show variables like "%compat_control%";

alter system flush plan cache global;
select REPLACE(SUBSTRING(REPEAT('a', 900), 1, LEAST(63, 5)), '', null);
select REPLACE(SUBSTRING(REPEAT('a', 900), 1, LEAST(63, 5)), '', null);
select REPLACE(SUBSTRING(REPEAT('a', 9  ), 1, LEAST(63, 5)), '', null);
select REPLACE(SUBSTRING(REPEAT('a', 900), 1, LEAST(63, 5)), '', null);
select REPLACE(SUBSTRING(REPEAT('a', 9  ), 1, LEAST(63, 5)), '', null);

alter system flush plan cache global;
select REPLACE(SUBSTRING(REPEAT('a' ,9  ), 1, LEAST(63, 5)), '', null);
select REPLACE(SUBSTRING(REPEAT('a' ,9  ), 1, LEAST(63, 5)), '', null);
select REPLACE(SUBSTRING(REPEAT('a' ,900), 1, LEAST(63, 5)), '', null);
select REPLACE(SUBSTRING(REPEAT('a' ,9  ), 1, LEAST(63, 5)), '', null);
select REPLACE(SUBSTRING(REPEAT('a' ,900), 1, LEAST(63, 5)), '', null);

alter system flush plan cache global;
select SUBSTRING(REPLACE(REPEAT('a', 512), '', null), 1, 5);
alter system flush plan cache global;
select SUBSTRING(REPLACE(REPEAT('a', 513), '', null), 1, 5);