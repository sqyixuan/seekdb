# owner: dachuan.sdc
# owner group: SQL2
# tag: expr

set timestamp = 1600000000;
select last_day('2020-01-01 00:00:00');
select last_day('2020-01-15 00:00:00');
select last_day('2020-01-31 23:00:00');
select last_day('2020-02-01 00:00:00');
select last_day('2020-02-20 00:00:00');
select last_day('2020-02-29 23:00:00');
select last_day('2020-02-31 23:00:00');
select last_day('0000-00-00 00:00:00');

select last_day('2020-02-20');
select last_day('2020-02-29');
select last_day('2020-02-31');
select last_day('0000-00-00');

--disable_warnings
drop table if exists t1;
drop table if exists t2;
--enable_warnings
create table t1(c1 varchar(100), c2 date, c3 datetime, c4 timestamp, c5 time);
insert into t1 values('2020-01-01 00:00:00', '2020-01-01', '2020-01-01 00:00:00', '2020-01-01 00:00:00', '00:00:00');
insert into t1 values('2020-01-15 00:00:00', '2020-01-15', '2020-01-15 00:00:00', '2020-01-15 00:00:00', '10:00:00');
insert into t1 values('2020-01-31 23:00:00', '2020-01-31', '2020-01-31 23:00:00', '2020-01-31 23:00:00', '20:00:00');
insert into t1 values('2020-02-01 00:00:00', '2020-02-01', '2020-02-01 00:00:00', '2020-02-01 00:00:00', '23:59:59');
insert into t1 values('2020-02-20 00:00:00', '2020-02-20', '2020-02-20 00:00:00', '2020-02-20 00:00:00', '00:00:00');
insert into t1 values('2020-02-29 23:00:00', '2020-02-29', '2020-02-29 23:00:00', '2020-02-29 23:00:00', '00:00:00');
insert into t1 values('2020-02-20', '2020-02-20', '2020-02-20', '2020-02-20', '00:00:00');
insert into t1 values('2020-02-29', '2020-02-29', '2020-02-29', '2020-02-29', '00:00:00');


select c1, last_day(c1) from t1;
select c2, last_day(c2) from t1;
select c3, last_day(c3) from t1;
select c4, last_day(c4) from t1;
select c5, last_day(c5) from t1;

create table t2 as select last_day(c1) c1, last_day(c2) c2, last_day(c3) c3, last_day(c4) c4, last_day(c5) c5 from t1;
desc t2;
select * from t2;
drop table t2;

--error 1292
create table t2 as select last_day('2020-02-30') c1 from dual;
--error 1292
create table t2 as select last_day('0000-00-00') c1 from dual;

set sql_mode = '';
create table t2 as select last_day('2020-02-30') c1 from dual;
desc t2;
select * from t2;
drop table t1,t2;
set sql_mode = default;