--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: yibo.tyf
# owner group: SQL3
# Test of round functions

select round(10);
select round(10.1);
select round(10.5);
select round(10, 0);
select round(10,10);
select round(10,30);
select round(10, 100);
select round(10, -10);
select round(123.34, 0);
select round(123.34, 10);
select round(123.56, 10);
select round(123.56, 128);
select round(123.56, -1);
select round(123.56, -10);
select round(123.153,10);
select round(123.153,128);
select round(12, 100); 
select ROUND( 1.10 , 6 );
select round(121213123123123123123.23, -12);
select round(121213123123123123123.23, -121);
select round(-1212, 0);
select round(-12323, 10);
select round(-121231, 100);
select round(-213.34, 0);
select round(-121.56, 1);
select round(-1212.12, 10);
select round(-121312.23, 100);
select round(-22323.123, -2);
select round(-1212777313.46, -10);
select round(-232423423423423.56, -100);
select round(1,null);
select round(null,1);
select round(null,null);

--echo #切换到老引擎测试ROUND(25E-1)与mysql不兼容
connect (conn_admin, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn_admin;
--sleep 5
connection default;
select round(25E-1);
select round(25E-1, 0);
select round(25E-1, 1);
select round(2.5);
select round(2.5, 0);
select round(2.5, 1);
select round(35E-1);
select round(35E-1, 0);
select round(35E-1, 1);
select round(3.5);
select round(3.5, 0);
select round(3.5, 1);
select round(-25E-1);
select round(-25E-1, 0);
select round(-25E-1, 1);
select round(-2.5);
select round(-2.5, 0);
select round(-2.5, 1);
select round(-35E-1);
select round(-35E-1, 0);
select round(-35E-1, 1);
select round(-3.5);
select round(-3.5, 0);
select round(-3.5, 1);
connection conn_admin;


##bugfix: 
--disable_warnings
DROP TABLE IF EXISTS t2;
--enable_warnings
CREATE TABLE t2(a number,b number);
INSERT INTO t2 VALUES(-10,25);
SELECT ROUND(b,a) FROM t2 WHERE ROUND(b,a) =0;
drop table t2;