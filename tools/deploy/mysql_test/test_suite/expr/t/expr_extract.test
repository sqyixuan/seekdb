sleep 2;
connection default;
set timestamp = 1600000000;
select date_format(utc_time(),get_format(DATE,'JIS'));
select date_format(utc_time(),get_format(DATETIME,'internal'));
select to_seconds(utc_time());
select extract(year from utc_time());
select extract(quarter from utc_time());
select extract(month from utc_time());
select extract(day from utc_time());
select from_unixtime(utc_time());
select round(utc_time());
select year(utc_time());
select quarter(utc_time());
select weekofyear(utc_time());
select weekday(utc_time());
select yearweek(utc_time());
select week(utc_time());
