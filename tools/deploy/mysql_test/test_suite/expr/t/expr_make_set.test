select make_set(16, '蚂蚁1','金服2','3','天天向上4');

select make_set(9223372036854775807, 'ab','cd','ac','bd');
select make_set(-9223372036854775808,'ab','cd','ac','bd');
select make_set(1844674407370955161, 'ab','cd','ac','bd');
select make_set(15, 'ab','cd','ac','bd');
select make_set(15, null,'cd','ac','bd');
select make_set(15, 'ab',null,'ac','bd');
select make_set(15, 'ab','cd',null,'bd');
select make_set(15, 'ab','cd','ac',null);
select make_set(15, null,null,null,'bd');
select make_set(1 | 2, 'ab','cd','ac','bd');
select make_set(1 & 2, 'ab','cd','ac','bd');
select make_set(2 + 1, 'ab','cd','ac','bd');
select make_set(2 - 1, 'ab','cd','ac','bd');
select make_set(12345.768, 'ab','cd','ac','bd');
select make_set(-1234.657, 'ab','cd','ac','bd');
select make_set('78349', 'ab','cd','ac','bd');
select make_set('-12349', 'ab','cd','ac','bd');
select make_set('abc', 'ab','cd','ac','bd');
select make_set('蚂蚁', 'ab','cd','ac','bd');
select make_set('2013-12-20', 'ab','cd','ac','bd');
select make_set('2012-11-21 17:20:30', 'ab','cd','ac','bd');

--disable_warnings
drop table if exists t_make_set_1;
--enable_warnings

#bug fix: 
create table t_make_set_1(i int);
insert into t_make_set_1 values(1);
insert into t_make_set_1 values(-1);
select group_concat(i), make_set(i, 'a', 'b') field FROM t_make_set_1 group by field;

drop table t_make_set_1;
