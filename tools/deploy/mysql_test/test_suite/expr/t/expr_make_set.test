select make_set(1, '蚂蚁1','金服2','3','天天向上4');
select make_set(2, '蚂蚁1','金服2','3','天天向上4');
select make_set(3, '蚂蚁1','金服2','3','天天向上4');
select make_set(4, '蚂蚁1','金服2','3','天天向上4');
select make_set(5, '蚂蚁1','金服2','3','天天向上4');
select make_set(6, '蚂蚁1','金服2','3','天天向上4');
select make_set(7, '蚂蚁1','金服2','3','天天向上4');
select make_set(8, '蚂蚁1','金服2','3','天天向上4');
select make_set(9, '蚂蚁1','金服2','3','天天向上4');
select make_set(10, '蚂蚁1','金服2','3','天天向上4');
select make_set(11, '蚂蚁1','金服2','3','天天向上4');
select make_set(12, '蚂蚁1','金服2','3','天天向上4');
select make_set(13, '蚂蚁1','金服2','3','天天向上4');
select make_set(14, '蚂蚁1','金服2','3','天天向上4');
