select convert(123.23456789 , decimal(38,2));
select convert('abc', char);
select convert('abc', binary);
select convert('asas' using utf8);
select convert('1234' using utf8);
select convert(binary '1234' using utf8);

#bugfix:
set names gb18030;
set sql_mode = 'STRICT_TRANS_TABLES';
select convert('『』' using gb18030) c1 from dual;
select length(convert('『』111' using gb18030)) c1 from dual;
select length(convert('『』111222' using gb18030)) c1 from dual;
set sql_mode = '';
select convert('『』' using gb18030) c1 from dual;
select length(convert('『』111' using gb18030)) c1 from dual;
select length(convert('『』111222' using gb18030)) c1 from dual;

set names default;
