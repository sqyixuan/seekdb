# owner: zuojiao.hzj
# owner group: SQL2
# tags: mod
## test ERROR_FOR_DIVISION_BY_ZERO sql_mode.
--result_format 4

--disable_warnings
drop table if exists t_div_zero_select, t_div_zero_insert, t_div_zero_update, t_div_zero_replace;
drop table if exists t_div_zero_partition;
drop procedure if exists p_div_zero;
--enable_warnings



############################# sql_mode with ERROR_FOR_DIVISION_BY_ZERO ############################

set sql_mode = 'STRICT_ALL_TABLES,ERROR_FOR_DIVISION_BY_ZERO';


############## test select ############

create table t_div_zero_select(c int);
insert into t_div_zero_select values(1);
insert into t_div_zero_select values(null);
select * from t_div_zero_select;

select mod(c,0) from t_div_zero_select;
select mod(c,-0) from t_div_zero_select;
select mod(c,0.0) from t_div_zero_select;
select mod(c,'0') from t_div_zero_select;
select mod(c,1-1) from t_div_zero_select;
select * from t_div_zero_select where c > mod(1,0);
select * from t_div_zero_select where c > mod(1,-0);
select * from t_div_zero_select where c > mod(1,0.0);
select * from t_div_zero_select where c > mod(1,'0');
select * from t_div_zero_select where c > mod(1,1-1);
select * from t_div_zero_select;



############## test insert ############

create table t_div_zero_insert(c int);

--error 1365
insert into t_div_zero_insert values(mod(1,0));
--error 1365
insert into t_div_zero_insert values(mod(1,-0));
--error 1365
insert into t_div_zero_insert values(mod(1,0.0));
--error 1365
insert into t_div_zero_insert values(mod(1,'0'));
--error 1365
insert into t_div_zero_insert values(mod(1,1-1));
select * from t_div_zero_insert;

insert ignore into t_div_zero_insert values(mod(1,0));
insert ignore into t_div_zero_insert values(mod(1,-0));
insert ignore into t_div_zero_insert values(mod(1,0.0));
insert ignore into t_div_zero_insert values(mod(1,'0'));
insert ignore into t_div_zero_insert values(mod(1,1-1));
select * from t_div_zero_insert;



############## test update ############

create table t_div_zero_update(c int);
insert into t_div_zero_update values(1);

--error 1365
update t_div_zero_update set c = mod(1,0);
--error 1365
update t_div_zero_update set c = mod(1,-0);
--error 1365
update t_div_zero_update set c = mod(1,0.0);
--error 1365
update t_div_zero_update set c = mod(1,'0');
--error 1365
update t_div_zero_update set c = mod(1,1-1);
select * from t_div_zero_update;

update ignore t_div_zero_update set c = mod(1,0);
update ignore t_div_zero_update set c = mod(1,-0);
update ignore t_div_zero_update set c = mod(1,0.0);
update ignore t_div_zero_update set c = mod(1,'0');
update ignore t_div_zero_update set c = mod(1,1-1);
select * from t_div_zero_update;



############## test replace ###########

create table t_div_zero_replace(c int);

--error 1365
replace into t_div_zero_replace values(mod(1,0));
--error 1365
replace into t_div_zero_replace values(mod(1,-0));
--error 1365
replace into t_div_zero_replace values(mod(1,0.0));
--error 1365
replace into t_div_zero_replace values(mod(1,'0'));
--error 1365
replace into t_div_zero_replace values(mod(1,1-1));
select * from t_div_zero_replace;



############## test partition table ###

create table t_div_zero_partition(c int)
partition by list (mod(1,c)) (
  partition p0 values in (null),
  partition p1 values in (1)
);
--error 1365
insert into t_div_zero_partition values(0);



############## test procedure #########

delimiter |;
create procedure p_div_zero()
begin
drop table if exists p_t;
create table p_t(c int);
insert into p_t values(1);
select mod(c,0) from p_t;
insert into p_t values(mod(1,0));
end |
delimiter ;|

--error 1365
call p_div_zero();



############## drop table #############

--disable_warnings
drop table if exists t_div_zero_select, t_div_zero_insert, t_div_zero_update, t_div_zero_replace;
drop table if exists t_div_zero_partition;
drop procedure if exists p_div_zero;
--enable_warnings





