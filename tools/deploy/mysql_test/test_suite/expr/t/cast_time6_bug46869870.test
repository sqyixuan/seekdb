#### owner: dachuan.sdc
#### owner group: sql2
#### description: cast time(6)

--result_format 4

--echo bugfix: 
connect (conn_admin, $OBMYSQL_MS0, admin, $OBMYSQL_PWD, test, $OBMYSQL_PORT);
connection conn_admin;

--disable_warnings
DROP TABLE IF EXISTS t1;
--enable_warnings

alter system set _enable_defensive_check=2;
SET @@session.sql_mode = NO_ZERO_DATE;
CREATE TABLE t1 (a TIME(6)) PARTITION BY KEY(a) PARTITIONS 4; 

#alter system set _enable_static_typing_engine = 1;
INSERT INTO t1  VALUES ('838:59:59.0000008');

#alter system set _enable_static_typing_engine = 0;
INSERT INTO t1  VALUES ('838:59:59.0000008');

## cast to time
#alter system set _enable_static_typing_engine = 1;

select cast('838:59:59.0000008' as time(6)) from dual;
select cast('838:59:59.0000004' as time(6)) from dual;
select cast('838:59:59.0000008' as time) from dual;
select cast('838:59:59.0000002' as time) from dual;
select cast('838:59:59.0008' as time(3)) from dual;
select cast('838:59:59.0003' as time(3)) from dual;

#alter system set _enable_static_typing_engine = 0;
select cast('838:59:59.0000008' as time(6)) from dual;
select cast('838:59:59.0000004' as time(6)) from dual;
select cast('838:59:59.0000008' as time) from dual;
select cast('838:59:59.0000002' as time) from dual;
select cast('838:59:59.0008' as time(3)) from dual;
select cast('838:59:59.0003' as time(3)) from dual;

select * from t1;
drop table t1;