--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: dingjincheng.djc
#owner group: sql1


--disable_warnings
drop table if exists yeti_dt;
--enable_warnings
create table yeti_dt(dt date not null);
insert into yeti_dt values('2015-01-01'),('0000-00-00');
select * from yeti_dt where dt is null;
--disable_warnings
drop table if exists yeti_dttime;
--enable_warnings
create table yeti_dttime(dtme datetime not null);
insert into yeti_dttime values('2015-01-01 01:01:01'),('0000-00-00 00:00:00');
select * from yeti_dttime where dtme is null;
--disable_warnings
drop table if exists yeti_dt;
--enable_warnings
create table yeti_dt(dt date);
insert into yeti_dt values('2015-01-01'),('0000-00-00');
select * from yeti_dt where dt is null;
--disable_warnings
drop table if exists yeti_dttime;
--enable_warnings
create table yeti_dttime(dtme datetime);
insert into yeti_dttime values('2015-01-01 01:01:01'),('0000-00-00 00:00:00');
select * from yeti_dttime where dtme is null;
--disable_warnings
drop table if exists yeti;
--enable_warnings
create table yeti(c1 int not null, c2 double not null, c3 timestamp not null);
insert into yeti values(0,0,'0000-00-00 00:00:00');
select * from yeti where c1 is null;
select * from yeti where c2 is null;
select * from yeti where c3 is null;

