# Test of functions ascii

--error 1064
select ascii();
--error 1064
select ascii('1','');

select ascii(null);

select ascii('');

select ascii('0');
select ascii(0);

select ascii('-');
select ascii('-12');
select ascii(-12);
select ascii('-10000000000000000000000000');
select ascii(-10000000000000000000000000);

select ascii('1');
select ascii(1);
select ascii(100000000000000000000000);

select ascii('中文');
select ascii(X'4142');
select ascii(X'41');
select ascii(now());
select ascii(' a');
select ascii(01);
select ascii(02);

#fix bug: review: #11142388
select crc32(ascii('张三')/3) from dual;
select ascii('张三')/3 from dual;
select concat('a', ascii('张三')/3) from dual;
create table tt1 as select ascii('张三')/3 from dual;
drop table tt1;
