# Test of functions password

select password(null);
select password("");
select password('123');
select password('开心');
select password(convert('开心' using gbk));
create table charsetFun ( id INT, date DATE, name1 VARCHAR(50) CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci, name2 VARCHAR(50) CHARACTER SET gbk COLLATE gbk_chinese_ci, name3 VARCHAR(50) CHARACTER SET utf16 COLLATE utf16_general_ci);
insert into charsetFun value(0, STR_TO_DATE('2024:01:01', '%Y:%m:%d'), '开心', convert('开心' using gbk), convert('开心' using utf16));
select password(id), password(date),password(name1),password(name2),password(name3) from charsetFun;
drop table charsetFun;
set names gbk;
select collation(password('123'));
