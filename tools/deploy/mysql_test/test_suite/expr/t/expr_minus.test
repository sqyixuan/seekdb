# owner: peihan.dph
# owner group: sql2

--disable_abort_on_error
--result_format 4

connect (syscon, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection syscon;

--sleep 1
connection default;

--disable_warnings
drop table if exists t1, t2, t3;
--enable_warnings
SET sql_mode='';
--sleep 2
--error 1690
select CAST(0 AS UNSIGNED) -1;
CREATE TABLE t1(a INT UNSIGNED, b DECIMAL(10,2) UNSIGNED);
INSERT INTO t1 VALUES (2015, 123456.78);

CREATE TABLE t2(a INT UNSIGNED, b INT UNSIGNED);
INSERT INTO t2 VALUES (2015, 123456);

CREATE TABLE t3(a DECIMAL(10,2) UNSIGNED, b DECIMAL(10,2) UNSIGNED);
INSERT INTO t3 VALUES (2015, 123456);

SELECT a - b FROM t1;
--error 1690
SELECT a - b FROM t2;
SELECT a - b FROM t3;

SET sql_mode=NO_UNSIGNED_SUBTRACTION;
--sleep 2
select CAST(0 AS UNSIGNED) -1;
SELECT a - b FROM t1;
SELECT a - b FROM t2;
SELECT a - b FROM t3;

DROP TABLE t1, t2, t3;
SET sql_mode='';
--sleep 2
