--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#### owner: jingfeng.jf
#### owner group: sql 2
#### description: for encode_sortkey_opt

--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1 (c1 varchar(10));
insert into t1 values ("abcd");
insert into t1 values ("cdef");
insert into t1 values ("efgh");
insert into t1 values ("ghij");
insert into t1 select * from t1;
insert into t1 select * from t1;
select /*+ opt_param('enable_newsort', 'true') */* from t1 order by c1;