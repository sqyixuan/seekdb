create table t(a tinyint, b smallint, c mediumint, d int, e bigint, f float, g double, h decimal(10, 5), i tinyint unsigned, j smallint unsigned, k mediumint unsigned, l int unsigned, m bigint unsigned, n char(100), o varchar(100), p datetime(5), q date, r time, s year);
