# owner group: SQL2
# Test of functions maketime

--error 1582
select maketime();
--error 1582
select maketime(1);
--error 1582
select maketime(1,2);

select maketime(1,2,3);
select maketime(-1, 1, 1);

--echo ##
--echo ## implicit type conversion
--echo ##
select maketime('1','2','3');
select maketime('-1','2','3');

--echo ##
--echo ## empty string conversion
--echo ##
select maketime(1, 2, '');
select maketime(1, '', '');
select maketime('', '', '');

--echo ##
--echo ## time value range check: [-838:59:59.000000, 838:59:59.000000]
--echo ##
select maketime(-1000, 2, 3);
select maketime(1000, 2, 3);
select maketime(838, 59, 59.999999);
select maketime(-838, 59, 59.999999);
select maketime(-2147483648, 2, 3);
select maketime(2147483648, 2, 3);

--echo ##
--echo ## second fragment test with rounding
--echo ##
select maketime(10, 20, 3.1);
select maketime(10, 20, 3.123);
select maketime(10, 20, 3.123456);
select maketime(10, 20, 3.1234564);
select maketime(10, 20, 3.1234565);
select maketime(10, 20, 3.1234569);
select maketime(838, 59, 59.999999);
select maketime(-838, 59, 59.999999);

--echo ##
--echo ## abnormal input testing, return null under below cases
--echo ##
select maketime(null, null, null);
select maketime(1, null, null);
select maketime(1, 1, null);
select maketime(1, 1, -1);
select maketime(1, -1, 1);
select maketime(1, 1, 60);
select maketime(1, 60, 1);

--echo ##
--echo ## get 00:00:00.000000 under chinese character
--echo ##
select maketime('中文', '中文', '中文');
