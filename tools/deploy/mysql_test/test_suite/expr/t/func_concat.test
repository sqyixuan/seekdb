--echo ###bug18851852, clob类型,使用concat表达式查询建表时报-4002
###
--error 0,1051
drop table t2a;
--error 0,1051
drop table t2b;
create table t1(v1 text);
insert into t1 values('ssss');
create table t2A as select concat(v1,v1) v1 from t1;
create table t2B as select concat(concat(v1,v1),v1) v1 from t1;

desc t2a;
desc t2b;

select length(v1) from t2a union all select length(v1) from t2b order by 1;
--error 0,1051
drop table t2c;
