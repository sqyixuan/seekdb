select '2018-12-28' not between 1 and 2;
create table sb(a bigint);
insert into sb values(1234556789);
insert into sb values(-9030561677807976448);
SELECT a FROM sb WHERE !(a BETWEEN NULL AND "你好 世界！");
SELECT a FROM sb WHERE ("hello world!" BETWEEN (((a <= a) IN (a, 'acqjd')) IS NULL) and (!(-146929937842962432 and (99.99999999 BETWEEN a and 'c')) IS NULL));
drop table sb;

