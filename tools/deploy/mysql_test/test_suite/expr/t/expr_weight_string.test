--result_format 4
--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

# owner: jiajingzhe.jjz
# owner group: IMF
# 测试mysql模式下的WEIGHT_STRING()表达式

--disable_warnings
drop table if exists t1;
drop table if exists t2;
drop table if exists tbl_512;
--enable_warnings

set names utf8mb4;
# collation 为 utf8mb4_general_ci

# 如果输入为 NULL、数字时，输出值为NULL
select hex(weight_string(NULL));
select hex(weight_string(123));
select hex(weight_string(3.123));

# 输入为日期或者时间类型
set timestamp = 133.345;
select hex(weight_string(year(current_timestamp())));
select hex(weight_string(current_date()));
select hex(weight_string(current_time()));
select hex(weight_string(current_timestamp()));

# 输入为枚举、lob、bit set类型
create table t1(
c1 blob,
c2 text ,
c3 longblob,
c4 longtext,
c5 ENUM ('value1','value2','value3','值4','值5'),
c6 SET('a1', 'b2', 'c3', 'd4'));
insert into t1(c1,c2,c3,c4,c5,c6) values('blob1一','text1','longblob1一','longtext1','value1','a1');
insert into t1(c1,c2,c3,c4,c5,c6) values('blob2二','text2','longblob2二','longtext2','value2','b2,c3');
insert into t1(c1,c2,c3,c4,c5,c6) values('blob3三','text3','longblob3三','longtext3','值5','a1,b2,c3,d4');
select hex(weight_string(c1)) from t1;
select hex(weight_string(c2)) from t1;
select hex(weight_string(c3)) from t1;
select hex(weight_string(c4)) from t1;
select hex(weight_string(c5)) from t1;
select hex(weight_string(c6)) from t1;
drop table t1;
# 如果输入字符串是 BLOB BINARY VARBINARY,输出值等于输入值
select hex(weight_string(0x010203));

# 如果输入字符串时 CHAR VARCHAR等类型，输出为该字符串的比较权重
select hex(weight_string('ab'));
select hex(weight_string('宇宙无敌'));

# "AS BINARY( INTNUM )" ,在右侧进行字符的填充
# BINARY类型的填充为 0x00 
select hex(weight_string('aa' as binary(3)));
select hex(weight_string(cast('aa' as binary(3))));

# INTNUM 小于字符长度时， 截断字符串
select hex(weight_string('ab' as binary(1)));

# "AS CHAR( INTNUM ) ",在右侧进行字符的填充
# CHAR类型的填充为空格，即0x0020
select hex(weight_string('aa' as char(5)));
select hex(weight_string('abcdefghijk' as char(5)));

# 仅有 "LEVEL numeric-list"子句后面可以跟[ASC|DESC][REVERSE]
# "LEVEL range"子句不可以
--error 1064
select hex(weight_string('ab' level 1-1 ASC));
--error 1064
select hex(weight_string('ab' level 1-1 DESC));
--error 1064
select hex(weight_string('ab' level 1-1 DESC REVERSE));

# "LEVEL numeric-list"子句后面可以跟[ASC|DESC][REVERSE]"
select hex(weight_string(0x007fff LEVEL 1));
select hex(weight_string(0x007fff LEVEL 1 DESC));
select hex(weight_string(0x007fff LEVEL 1 REVERSE));
select hex(weight_string(0x007fff LEVEL 1 DESC REVERSE));
select hex(weight_string('ab' level 1 ASC));
select hex(weight_string('ab' level 1 DESC));
select hex(weight_string('ab' level 1 REVERSE));
select hex(weight_string('ab' level 1 DESC REVERSE));

# LEVEL range测试
select hex(weight_string(0x007fff LEVEL 2));
select hex(weight_string(0x007fff LEVEL 1-3));
select hex(weight_string(0x007fff LEVEL 4-2));
select hex(weight_string(0x007fff LEVEL 5-5));
select hex(weight_string(0x007fff LEVEL 0-8));

# WEIGHT_STRING and REVERSE 不是一个保留词.
select 1 as weight_string, 2 as reverse;

# 检查weight_string结果的collation_level
select coercibility(weight_string('test'));
select coercibility(weight_string(user()));
select coercibility(weight_string('test' as binary(2)));
select coercibility(weight_string(cast('test' as binary)));

# 测试从表中读取数据
create table t1 (s1 varchar(5));
insert into t1 values ('a'),(null);
select hex(weight_string(s1)) from t1 order by s1;
drop table t1;

# 测试输入字符串是其他复杂表达式计算结果的情况
select hex(weight_string(concat('中国','abc')));
select hex(weight_string(substring_index('www.oceanbase.com', '.', 2)));
select hex(weight_string(date_add('2008-01-02', INTERVAL 31 DAY)));
set timestamp = 133.345;
select hex(weight_string(date_add(NOW(), INTERVAL 99 DAY)));

# 测试utf8mb4的特殊字符
set names utf8mb4;
select hex(weight_string("🐙"));
select hex(weight_string("宇宙无敌，客户第一" AS CHAR(4)));
select "aaaa3" < "bbbb2", weight_string("aaaa3") < weight_string("bbb2");
select "壹" < "贰" , weight_string("壹") < weight_string("贰");
set @s1 = _utf8mb4 "ABCD" COLLATE utf8mb4_general_ci;
set @s2 = _utf8mb4 "abcd" COLLATE utf8mb4_general_ci;
select @s1 = @s1;
select weight_string(@s1) = weight_string(@s2);

# 测试gb18030字符集
set names gb18030;
select hex(weight_string("�^&" AS CHAR(10)));
select "aaaa3" < "bbbb2", weight_string("aaaa3") < weight_string("bbb2");
select "bbb2" < "^^^", weight_string("bbb2") < weight_string("^^^");
set @s1 = _gb18030 "ABCD" COLLATE gb18030_chinese_ci;
set @s2 = _gb18030 "abcd" COLLATE gb18030_chinese_ci;
select @s1 = @s1;
select weight_string(@s1) = weight_string(@s2);

# 测试gbk字符集
set names gbk;
select hex(weight_string("�^&" AS CHAR(10)));
select "aaaa3" < "bbbb2", weight_string("aaaa3") < weight_string("bbb2");
select "bbb2" < "^^^", weight_string("bbb2") < weight_string("^^^");
set @s1 = _gbk "ABCD" COLLATE gbk_chinese_ci;
set @s2 = _gbk "abcd" COLLATE gbk_chinese_ci;
select @s1 = @s1;
select weight_string(@s1) = weight_string(@s2);

# 测试binary字符集
set names binary;
select hex(weight_string("�^&" AS CHAR(10)));
select hex(weight_string("宇宙无敌，客户第一" AS CHAR(4)));
select "aaaa3" < "bbbb2", weight_string("aaaa3") < weight_string("bbb2");
select "bbb2" < "^^^", weight_string("bbb2") < weight_string("^^^");



# 测试WEIGHT_STRING()函数在VIEW中结果正确性
SET NAMES utf8mb4;
CREATE TABLE t1 (a VARCHAR(10) CHARACTER SET gbk COLLATE gbk_chinese_ci);
INSERT INTO t1 VALUES ('abcd');
INSERT INTO t1 VALUES ('dcba');
CREATE VIEW v1 AS SELECT WEIGHT_STRING('ab') AS b;
CREATE VIEW v2 AS SELECT WEIGHT_STRING(a LEVEL 1) AS b FROM t1;
CREATE VIEW v3 AS SELECT WEIGHT_STRING(a AS CHAR(2) LEVEL 1) AS b FROM t1;
CREATE VIEW v4 AS SELECT WEIGHT_STRING(a AS CHAR(6) LEVEL 2) AS b FROM t1;
CREATE VIEW v5 AS SELECT WEIGHT_STRING(a AS BINARY(2)) AS b FROM t1;
CREATE VIEW v6 AS SELECT WEIGHT_STRING(a AS BINARY(6)) AS b FROM t1;
CREATE VIEW v7 AS SELECT WEIGHT_STRING(a AS CHAR(2) LEVEL 1 ASC) AS b FROM t1;
CREATE VIEW v8 AS SELECT WEIGHT_STRING(a AS CHAR(2) LEVEL 1 DESC) AS b FROM t1;
CREATE VIEW v9 AS SELECT WEIGHT_STRING(a AS CHAR(2) LEVEL 1,3 REVERSE) AS b FROM t1;
SHOW CREATE VIEW v1;
SHOW CREATE VIEW v2;
SHOW CREATE VIEW v3;
SHOW CREATE VIEW v4;
SHOW CREATE VIEW v5;
SHOW CREATE VIEW v6;
SHOW CREATE VIEW v7;
SHOW CREATE VIEW v8;
SHOW CREATE VIEW v9;
DROP VIEW v1;
DROP VIEW v2;
DROP VIEW v3;
DROP VIEW v4;
DROP VIEW v5;
DROP VIEW v6;
DROP VIEW v7;
DROP VIEW v8;
DROP VIEW v9;
DROP TABLE t1;
CREATE TABLE t1 (a VARCHAR(10));
INSERT INTO t1 VALUES ('abcd');
INSERT INTO t1 VALUES ('dcba');
CREATE VIEW v1 AS SELECT WEIGHT_STRING('ab') AS b;
CREATE VIEW v2 AS SELECT WEIGHT_STRING(a) AS b FROM t1;
CREATE VIEW v3 AS SELECT WEIGHT_STRING(a AS CHAR(2)) AS b FROM t1;
CREATE VIEW v4 AS SELECT WEIGHT_STRING(a AS CHAR(6)) AS b FROM t1;
CREATE VIEW v5 AS SELECT WEIGHT_STRING(a AS BINARY(2)) AS b FROM t1;
CREATE VIEW v6 AS SELECT WEIGHT_STRING(a AS BINARY(6)) AS b FROM t1;
CREATE VIEW v7 AS SELECT WEIGHT_STRING(a AS CHAR(2) LEVEL 1 ASC) AS b FROM t1;
CREATE VIEW v8 AS SELECT WEIGHT_STRING(a AS CHAR(2) LEVEL 1 DESC) AS b FROM t1;
CREATE VIEW v9 AS SELECT WEIGHT_STRING(a AS CHAR(2) LEVEL 1 REVERSE) AS b FROM t1;
SHOW CREATE VIEW v1;
SHOW CREATE VIEW v2;
SHOW CREATE VIEW v3;
SHOW CREATE VIEW v4;
SHOW CREATE VIEW v5;
SHOW CREATE VIEW v6;
SHOW CREATE VIEW v7;
SHOW CREATE VIEW v8;
SHOW CREATE VIEW v9;
SELECT HEX(b) FROM v1;
SELECT HEX(WEIGHT_STRING('ab'));
SELECT HEX(b) FROM v2;
SELECT HEX(WEIGHT_STRING(a LEVEL 1)) FROM t1;
SELECT HEX(b) FROM v3;
SELECT HEX(WEIGHT_STRING(a AS CHAR(2) LEVEL 1)) FROM t1;
SELECT HEX(b) FROM v4;
SELECT HEX(WEIGHT_STRING(a AS CHAR(6) LEVEL 2)) FROM t1;
SELECT HEX(b) FROM v5;
SELECT HEX(WEIGHT_STRING(a AS BINARY(2))) FROM t1;
SELECT HEX(b) FROM v6;
SELECT HEX(WEIGHT_STRING(a AS BINARY(6))) FROM t1;
SELECT HEX(b) FROM v7;
SELECT HEX(WEIGHT_STRING(a AS CHAR(2) LEVEL 1 ASC)) FROM t1;
SELECT HEX(b) FROM v8;
SELECT HEX(WEIGHT_STRING(a AS CHAR(2) LEVEL 1 DESC)) FROM t1;
SELECT HEX(b) FROM v9;
SELECT HEX(WEIGHT_STRING(a AS CHAR(2) LEVEL 1 REVERSE)) FROM t1;
DROP VIEW v1;
DROP VIEW v2;
DROP VIEW v3;
DROP VIEW v4;
DROP VIEW v5;
DROP VIEW v6;
DROP VIEW v7;
DROP VIEW v8;
DROP VIEW v9;
DROP TABLE t1;
# 测试 weight_string作为结果的复杂查询,测试多行处理过程中内存的复用
create table t1 (c1 VARCHAR(100) CHARACTER SET utf8mb4 COLLATE utf8mb4_general_ci);
insert into t1 values("a");
insert into t1 values("aaaa");
insert into t1 values("aaa");
insert into t1 values("bbb");
insert into t1 values("a");
insert into t1 values("aaaa");
insert into t1 values("bbbbb");
insert into t1 values("aaa");
insert into t1 values("bbb");
insert into t1 values("a");
insert into t1 values("aaa");
insert into t1 values("bbbbb");
insert into t1 values("AAA");
insert into t1 values("BBB");
insert into t1 values("A");
insert into t1 values("AAA");
insert into t1 values("AAA");
insert into t1 values("BBB");
insert into t1 values("A");
insert into t1 values("aaa");
select hex(weight_string(c1)) ,count(*) from t1 group by weight_string(c1) order by weight_string(c1) desc;
drop table t1;
# Max_length case
create view v1 as select weight_string("abcdef");
desc v1;
drop view v1;
select length(weight_string("abcdef"));
--enable_metadata
# metadata checked by eyes
## gbk
set names gbk;
select weight_string("abcdef");
select length(weight_string("abcdef"));
## binary
set names binary;
select weight_string("abcdef");
select length(weight_string("abcdef"));
# time\date\datetime
set timestamp = 133.345;
select weight_string(current_date());
select length(weight_string(current_date()));
select weight_string(current_time());
select length(weight_string(current_time()));
select weight_string(current_timestamp());
select length(weight_string(current_timestamp()));
# hex
select weight_string(0x4242);
select length(weight_string(0x4242));
# as_binary
select weight_string("abcdef" as binary(3));
select length(weight_string("abcdef" as binary(3)));
# as char
select weight_string("abcdef" as char(3));
select length(weight_string("abcdef" as char(3)));
--disable_metadata

set collation_connection = 'utf8mb4_unicode_ci';
select hex(weight_string('ab' as char(1)));

