#fix bug:
# 《【weight_string】as char(N)或binary(N)，N超长，ob报错,mysql结果为null》
set names 'utf8mb4';
select count(weight_string('ab'));
select count(weight_string('ab' as char(2097151)));
select count(weight_string('ab' as char(2097152)));
select count(weight_string('ab' as char(2097153)));
select count(weight_string('ab' as binary(4194303)));
select count(weight_string('ab' as binary(4194304)));
select count(weight_string('ab' as binary(4194305)));
set names 'utf8mb4';
select hex(weight_string('ab' as char(111111111111111111))),weight_string('ab' as char(111111111111111111));
create table t2 (tt tinyint, st smallint,mt mediumint,it integer,bt bigint,ft float,dle double,dl decimal(10,7),bi bit(5), cy year, cd date, cdt datetime)default charset=gbk collate=gbk_chinese_ci;
insert into t2 values(127,32767,1677215,2147483647,1,9.345,12.34526,35.2984,b'1111',2022, "2022-01-19","2022-01-19 11:12:11");
select weight_string (tt as binary(5)),hex(weight_string (tt as binary(5))) from t2;
select weight_string (st as binary(5)),hex(weight_string (st as binary(5))) from t2;
select weight_string (mt as binary(5)),hex(weight_string (mt as binary(5))) from t2;
select weight_string (it as binary(5)),hex(weight_string (it as binary(5))) from t2;
select weight_string (bt as binary(5)),hex(weight_string (bt as binary(5))) from t2;
select weight_string (ft as binary(5)),hex(weight_string (ft as binary(5))) from t2;
select weight_string (dle as binary(5)),hex(weight_string (dle as binary(5))) from t2;
select weight_string (dl as binary(5)),hex(weight_string (dl as binary(5))) from t2;
select weight_string (bi as binary(5)),hex(weight_string (bi as binary(5))) from t2;
select weight_string (cy as binary(5)),hex(weight_string (cy as binary(5))) from t2;
select weight_string (cd as binary(5)),hex(weight_string (cd as binary(5))) from t2;
select weight_string (cdt as binary(5)),hex(weight_string (cdt as binary(5))) from t2;
select weight_string (tt as char(5)),hex(weight_string (tt as char(5))) from t2;
select weight_string (st as char(5)),hex(weight_string (st as char(5))) from t2;
select weight_string (mt as char(5)),hex(weight_string (mt as char(5))) from t2;
select weight_string (it as char(5)),hex(weight_string (it as char(5))) from t2;
select weight_string (bt as char(5)),hex(weight_string (bt as char(5))) from t2;
select weight_string (ft as char(5)),hex(weight_string (ft as char(5))) from t2;
select weight_string (dle as char(5)),hex(weight_string (dle as char(5))) from t2;
select weight_string (dl as char(5)),hex(weight_string (dl as char(5))) from t2;
select weight_string (bi as char(5)),hex(weight_string (bi as char(5))) from t2;
drop table t2;
# fix bug:
# 《【weight_string】对于字符集为gb18030的变量，weight_string设置desc和 reverse，ob实现结果和mysql不一致》
set @s = _gb18030 '12345' collate  gb18030_chinese_ci ;
select hex(weight_string(@s as char(5) level 1 reverse)) hex;
set @s = _gb18030 '12345' collate  gb18030_chinese_ci ;
select hex(weight_string(@s as char(5) level 1 desc )) hex;
#fix bug:
# 《【weight_string 】可选参数 as char（N）或binary（N），对''进行补充空格或0时，ob和mysql结果不一致》
set names 'gbk';
select hex(weight_string('' as char(3))),weight_string('' as char(3));
select hex(weight_string('' as binary(3))),weight_string('' as binary(3));
set @s = _utf16 '' collate  utf16_general_ci;
select hex(weight_string(@s as char(3))),weight_string(@s as char(3));
select hex(weight_string(@s as binary(3))),weight_string(@s as binary(3));
set names 'gb18030';
select hex(weight_string('' as char(3))),weight_string('' as char(3));
select hex(weight_string('' as binary(3))),weight_string('' as binary(3));
set names 'binary';
select hex(weight_string('' as char(3))),weight_string('' as char(3));
select hex(weight_string('' as binary(3))),weight_string('' as binary(3));

# fix bug: 
# 《【fast parser/normal parser校验】level的语法时候参数化常量不一致》
select weight_string("aaa" as char(2) level 3,4,5);
select weight_string("aaa" as char(2) level 1-3);

# fix bug: 
# 《CORE DUMP at ObExprWeightString::calc_result_typeN》
--error 3037
select weight_string(st_srid(333));
select weight_string(st_srid(NULL));