--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#### owner: zongmei.zzm
#### owner group: sql1
#### description: 测试regexp_instr函数
# tags: expr, datatype

--result_format 4

--echo ================ expression regexp_instr ================
#normal test(optional params is default value(position = 1, nth_appearance = 1,return_option = 0 , match_parameter = 'c')
select regexp_instr('abcabc', 'a') from dual;
select regexp_instr('阿里巴巴', '巴') from dual;
select regexp_instr(123123, 123) from dual;
select regexp_instr('123123', '123') from dual;
select regexp_instr(123.400000, 3.4) from dual;
--error 1139
select regexp_instr('abc', '') from dual;
select regexp_instr(null, 'b') from dual;
select regexp_instr(null,null) from dual;

select regexp_instr('abcabc', '.*') from dual;
select regexp_instr('abcabc', '.?') from dual;
select regexp_instr('abcabc', 'a*') from dual;
select regexp_instr('阿里巴巴', '阿|里|巴|巴') from dual;
select regexp_instr('abcdef', '[a-z]') from dual;
select regexp_instr('11223311112', '1{2,4}') from dual;
select regexp_instr('122absdsadas123', '[[:digit:]]{3}') from dual;
select regexp_instr('12312alipay.com123sadqwe', '[[:alpha:]]{6}\.[[:alpha:]]{3}') from dual;


# with optional params(position, nth_appearance, return_option, match_parameter)
select regexp_instr('abaaba', 'a', 3) from dual;
select regexp_instr('abcabc', 'abc', 1, 2) from dual;
select regexp_instr('abcabc', 'abc', 1, 2, 1) from dual;
select regexp_instr('abcabc', '(a)(b)(c)', 1, 1, 0, 'c') from dual;
select regexp_instr('abcabcABC', 'abc', 1, 3, 1, 'i') from dual;
select regexp_instr('abcabcABC', 'a', 3, 2, 0) from dual;
select regexp_instr('abcabcABC', '(a)(b)(c)', 1, 3, 1, 'i') from dual;
select regexp_instr('阿里巴巴', '巴', 1, 2, 1) from dual;
select regexp_instr('123123', '123',3,1) from dual;
select regexp_instr('123123', '123', NULL, 1, 1, 'c') from dual;
select regexp_instr('123123', '123', 1, NULL, 1, 'c') from dual;
select regexp_instr('123123', '123', 1, 1, NULL, 'c') from dual;
select regexp_instr('123123', '123', 1, 1, 1, NULL) from dual;
select regexp_instr('123123', '123', 1, 1, 1, 'c') from dual;
select regexp_instr('a123b123', '([[:alpha:]])(\d{3})', 1, 2, 0, NULL) from dual;
select regexp_instr('蚂123蚁123', '([[:alpha:]])(\d{3})', 1, 2, 0, NULL) from dual;
--error 1139
select regexp_instr('abcabc', '', 1, 1, 0, 'c') from dual;
--error 1139
select regexp_instr('abcabc', '', 1, 1, NULL, 'c') from dual;

select regexp_instr('abaaba', 'a*', 3) from dual;
select regexp_instr('abcabc', 'a..', 1, 2, 1) from dual;
select regexp_instr('abcabcABC', '[a-z]{3}', 1, 3, 0, 'i') from dual;
--error 1210
select regexp_instr('abcabcABC', '[a-z]   {3}', 1, 3, 0, 'xi') from dual;
select regexp_instr('阿里巴巴', '(阿)(里)(巴)(巴)', 1, 1, 1, 'c') from dual;
select regexp_instr('123.400000', '[1-9]{2}\.[1-9]', 1, 1, 0) from dual;
--error 1210
select regexp_instr('abcabcABC', '[a-z]   {3}', 1, 3, 0, 'xi') from dual;

# 测试中英文混合
select regexp_instr('123阿里123巴巴123', '123', 1, 2) from dual;
select regexp_instr('abc阿里123巴巴abc', 'abc', 1, 2, 1) from dual;
select regexp_instr('123阿里abc巴巴123', '巴', 1, 2, 0) from dual;
select regexp_instr('abc阿里123巴巴ABC', 'abc', 1, 2, 1, 'i') from dual;

select regexp_instr('123阿里123巴巴123', '[1-9]{3}', 5, 2, 1) from dual;
select regexp_instr('abc阿里abc巴巴abc', '巴*', 1) from dual;
select regexp_instr('abc阿里123巴巴abc', '[[:alpha:]]{3}', 1, 2) from dual;
select regexp_instr('123阿里abc巴巴123', '^123.',  1) from dual;
select regexp_instr('abc阿里123巴巴abc', '[a-z]$', 1)  from dual;
select regexp_instr('abc阿里123巴巴abc', '阿|里|巴|巴', 1, 4, 1, 'c') from dual;
select regexp_instr('abc阿里123巴巴ABC', '[a-z]|[1-9]', 1, 7, 0, 'c') from dual;
select regexp_instr('abc阿里123巴巴ABC', '[a-z]|[1-9]', 1, 7, 0, 'i') from dual;

# 测试非整的可选参数(position and nth_appearance)
select regexp_instr('abcabc', 'abc', 1.9) from dual;
select regexp_instr(123123, 123, 1.01, 2.999999) from dual;
select regexp_instr(123123, 123, 1.01, 2.999999, 1.49999999) from dual;
select regexp_instr('abc阿里123巴巴ABC', 'abc', 1.99999999999999, 3.5, 1.4, 'i') from dual;

select regexp_instr('abcabd', 'ab.', 1.99999) from dual;
select regexp_instr(123123, '^123', 1.0000001, 1.999999, 1.080808080808) from dual;
select regexp_instr('abc阿里123巴巴ABC', '[a-z]{3}', 1.99999999999999, 2, 1,'i') from dual;
select regexp_instr('abc阿里巴巴abc', '(阿)(里)(巴)(巴)', 1.00001, 1.0009, 1.4999988882, 'c') from dual;

#参数边界测试
--error 1139
select regexp_instr('abcabc', 'a', 1844674407370955161518446744073709551615) from dual;
select regexp_instr('abcabc', 'a', 1,23123123123123121312131231231312) from dual;
--error 1139
select regexp_instr('abc阿里123巴巴abc', '巴', 12312312312313123.9999999) from dual;
select regexp_instr('abc阿里123巴巴abc', '巴', 1, 12312312312313123.9999999) from dual;
select regexp_instr('abc阿里巴巴abc', '(阿)(里)(巴)(巴)', 1, 1, 1, 'c') from dual;
--error 1139
select regexp_instr(123123, '[[:digit:]]{3}', 1844674407370955161518446744073709551615) from dual;
select regexp_instr('abc阿里123巴巴abc', '阿|巴',1, 12312312312313123.9999999) from dual;

#结合其他表达式测试
select regexp_instr(lower('ABCdefg') ,substr('abcdd', 1,2)) from dual;
select regexp_instr(concat('xy','xy'), 'x', abs(-1)) from dual;
select regexp_instr(concat('xy','xy'), 'x*', abs(-1)) from dual;
select regexp_instr('abc阿123里123巴abc巴abc','阿|里|巴|巴',regexp_instr('abcabc', 'a.*')) from dual;

#特殊匹配测试
select regexp_instr ('2, 5, and 10 are numbers in this example', '\d', 1, 3, 1) from dual;
select regexp_instr(123123,'\d+', 1, 1, 1) from dual;
select regexp_instr(123123,'\d+?', 2, 2, 1) from dual;
select regexp_instr(123123, '[0-9]{2,4}') from dual;
select regexp_instr(123123, '[0-9]{2,4}?') from dual;
select regexp_instr(123123, '\d{2,4}?') from dual;
select regexp_instr('abc阿里123阿里巴巴&!@','\W') from dual;
select regexp_instr('TechOnTheNet is a great resource', '^(\S*)') from dual;
select regexp_instr('abcabd', '\Aab') from dual;
select regexp_instr('abcabd', '^ab') from dual;
select regexp_instr('abcabe', '.*be\Z') from dual;
select regexp_instr('abcabe', '.*be$') from dual;

#无效参数测试
--error 1210
select regexp_instr('abcabc', 'abc', -1) from dual;
--error 1210
select regexp_instr('abcabc', 'abc', 1, -1) from dual;
--error 1210
select regexp_instr('abcabc', 'abc', 1, 1, 2) from dual;
--error 1210
select regexp_instr('abcabc', 'abc', 1, 1, 0, -1) from dual;
--error 1210
select regexp_instr('abcabc', 'abc', 1, 1, 0, 'e') from dual;
--error 5813
select regexp_instr(NULL, '(', 1) from dual;
--error 5812
select regexp_instr(NULL, '\d[', 1) from dual;
--error 1139
select regexp_instr(NULL, '\d{3', 1) from dual;

--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(c1 int, c2 int);
insert into t1 values(regexp_instr('阿里2巴3巴','\d{1,}'), regexp_instr('阿里123巴巴','阿|巴', 1, 1, 1));
select * from t1 where c1 = 0;
select * from t1 where c2 = (regexp_instr('1a232','1', 1, 1, 1));
drop table t1;

create table t1 (c1 varchar(10), c2 varchar(10) collate utf8mb4_bin);
insert into t1 values('a', 'b'),('a', 'B'),('A', 'b');

select regexp_instr(c1, 'a', 1) from t1;
select regexp_instr(c2, 'b', 1) from t1;
drop table t1;

--disable_warnings
drop table if exists v1;
--enable_warnings
create view v1 as select regexp_instr('abcabd', '\Aa') as c1 from dual; 
desc v1; 
drop view v1;