#### description: addtime
# tags: addtime

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
DROP TABLE IF EXISTS t1;
--enable_warnings

### the result is same as mysql

## params format cases

# when the params format is right
# params : datetime + time
SELECT ADDTIME('2007-12-31 23:59:59.999999', '1 1:1:1.000002');
# params : time + time
SELECT ADDTIME('01:00:00.999999', '02:00:00.999998');

# when the param1 is null 
SELECT ADDTIME('', '02:00:00.999998');
# when the param2 is null 
SELECT ADDTIME('01:00:00.999999', '');
# when the param1 and the param2 are null 
SELECT ADDTIME('', '');
# when the param1 format is different
SELECT ADDTIME('01-0:00.999999', '02:00:00.999998');
# when the param2 format is different
SELECT ADDTIME('01:00.999999', '02-00:00.999998');
# when the params format are different
SELECT ADDTIME('01-0:00.999999', '02-00:00.999998');

# params are intergers
SELECT ADDTIME(13243223, 78324234);
SELECT ADDTIME(132, 244);

# params are float
SELECT ADDTIME(132.889923, 244.328823);
SELECT ADDTIME(132.8899243, 244.3528823);

## params are datas from table
CREATE TABLE t1(c1 DATETIME, c2 TIME);

INSERT INTO t1 (c1, c2) values('2007-12-31 23:59:59', '123:59:59');
INSERT INTO t1 (c1, c2) values('2007-12-31 23:59:59.999999', '123:59:59.999999');

SELECT ADDTIME(c1, c2) from t1;

DROP TABLE t1;

## need to improve
# mysql return null, ob return ''
SELECT ADDTIME(13243223.0003213, 78324234.23989823);
# mysql return 838:59:59, ob return 916:40:00
SELECT ADDTIME('500:00:00', '416:40:00');
# mysql return 838:59:59, ob return ''
SELECT ADDTIME('916:40:00', '416:40:00');
# mysql return -838:59:59, ob return -916:40:00
SELECT ADDTIME('-500:00:00', '-416:40:00');
# mysql return -838:59:59, ob return ''
SELECT ADDTIME('-916:40:00', '-416:40:00');