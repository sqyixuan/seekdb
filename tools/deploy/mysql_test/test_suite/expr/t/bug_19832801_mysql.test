# owner: dachuan.sdc
# owner group: sql2
# description: 测试cast表达式第一个参数是clob类型，第二个参数是varchar（且长度小于clob长度）时的行为
# tags: expr

--result_format 3
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1 (c1 longtext);
insert into t1 values ('12345');
insert into t1 values ('abcdef');

# MySQL不允许cast到varchar类型，但是ob支持
# select cast(c1 as varchar(1)) from t1;

# 下面的语句，MySQL会给warning
select cast(c1 as char(1)) from t1;
select cast(lower(c1) as char(1)) from t1;
select cast(upper(c1) as char(1)) from t1;
