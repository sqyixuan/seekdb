--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: sean.yyj
# owner group: sql3

--disable_abort_on_error
--result_format 3

select sha('abc');
select sha1('abc');
select sha2('abc', 224);
select sha2('abc', 256);
select sha2('abc', 384);
select sha2('abc', 512);
select sha(repeat('a', 1000));
select sha1(repeat('a', 1000));
select sha2(repeat('a', 1000), 224);
select sha2(repeat('a', 1000), 256);
select sha2(repeat('a', 1000), 384);
select sha2(repeat('a', 1000), 512);
select sha(123);
select sha1(123);
select sha2(123, 224);
select sha2(123, 256);
select sha2(123, 384);
select sha2(123, 512);

select sha('');
select sha(null);
select sha2(null, null);
select sha2(null, 224);
select sha2('abc', null);
select sha2('abc', 128);
select sha2('abc', 0);

--disable_warnings
drop table if exists t1;
drop table if exists t_sha;
drop table if exists t_sha1;
drop table if exists t_sha2;
--enable_warnings

create table t1 (c1 varchar(100), c2 int);
create table t_sha as select sha(c1) c1 from t1;
create table t_sha1 as select sha1(c1) c1 from t1;
create table t_sha2 as select sha2(c1, c2) c1 from t1;

desc t_sha;
desc t_sha1;
desc t_sha2;
drop table t1;
drop table t_sha;
drop table t_sha1;
drop table t_sha2;
