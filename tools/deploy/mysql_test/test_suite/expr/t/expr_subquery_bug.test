--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1 (c1 int);
insert into t1 (c1) values (100);
SELECT * FROM t1 WHERE (NOT (exists (select 1) IN (100, t1.c1 < t1.c1)));

--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1 (num int);
select 1 from (select @a:=1);
select @a;
--disable_warnings
drop table if exists t;
--enable_warnings
create table t (c1 int);
select 1 from (select @b:=1 from t);
select @b;
insert into t values(1);
select 1 from (select @b:=1 from t);
select @b;

