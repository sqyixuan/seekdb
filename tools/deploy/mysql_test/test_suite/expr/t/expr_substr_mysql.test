select substr('abcd',18446744073709551615);
select substr('abcd',18446744073709551615);
select substr('abcd',-18446744073709551615);
select substr('abcd',18446744073709551615,18446744073709551615);
select substr('abcd',-18446744073709551615,-18446744073709551615);
SELECT SUBSTR( '' , 1) RLIKE 'a' ;
SELECT SUBSTR( 'abc' , 1) RLIKE 'a' ;

--echo

select substr('abcd', '1.1', '1.1');
select substr('abcd', '1.9', '1.1');
select substr('abcd', '1.1', '1.9');
select substr('abcd', '1.9', '1.9');
select substr('abcd', 1.1, 1.1);
select substr('abcd', 1.9, 1.1);
select substr('abcd', 1.1, 1.9);
select substr('abcd', 1.9, 1.9);

--echo

select substr('abcd', '-1.9', '1.9');
select substr('abcd', -1.1, 1.1);
select substr('abcd', '-1.9', '-1.9');
select substr('abcd', -1.1, -1.1);

--echo

select substr('', '1.1', '1.1');
select substr('', '1.9', '1.1');
select substr('', '1.1', '1.9');
select substr('', '1.9', '1.9');
select substr('', 1.1, 1.1);
select substr('', 1.9, 1.1);
select substr('', 1.1, 1.9);
select substr('', 1.9, 1.9);

--echo

select substr('abcd', 1234567890098765432100000, 100);
select substr('abcd', 1234567890098765432100000, 1234567890098765432100000);

# 下面这行MySQL和OB结果不一致
# select substr('abcd','18446744073709551615');

--echo

select substr('abcdef', '1.1', '1.9'),'a' from dual;
select substr('abcdef', '1.1', '1.9'),'a' from dual;
select substr('abcdef', '1.1', '1.9'),'a' from dual;
select substr('abcdef', '1.9',2.9),'abc' from dual;
select substr('abcdef', '1.9',2.9),'abc' from dual;
select substr('abcdef', '1.9',2.9),'abc' from dual;
select substr('abcdef', 1.9, '2.2'),'bc' from dual;
select substr('abcdef', 1.9, '2.2'),'bc' from dual;
select substr('abcdef', 1.9, '2.2'),'bc' from dual;
select substr('abcdef', 1.9) from dual;
select substr('abcdef', 1.9) from dual;
select substr('abcdef', 1.9) from dual;


##bugfix: 
--disable_warnings
drop table if exists table1_float;
--enable_warnings
CREATE TABLE table1_float (
  col_char_20_gbk_unique_key char(20) CHARACTER SET gbk DEFAULT NULL
);

SELECT * 
FROM   table1_float 
WHERE  Nullif(
            col_char_20_gbk_unique_key, 
            Substr(REPEAT('aa', 0+1), 1, 20)
           );
drop table table1_float;
