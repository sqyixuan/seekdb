select mid('abcd',18446744073709551615);
select mid('abcd',18446744073709551615);
select mid('abcd',-18446744073709551615);
select mid('abcd',18446744073709551615,18446744073709551615);
select mid('abcd',-18446744073709551615,-18446744073709551615);
SELECT mid( '' , 1) RLIKE 'a' ;
SELECT mid( 'abc' , 1) RLIKE 'a' ;

--echo

select mid('abcd', '1.1', '1.1');
select mid('abcd', '1.9', '1.1');
select mid('abcd', '1.1', '1.9');
select mid('abcd', '1.9', '1.9');
select mid('abcd', 1.1, 1.1);
select mid('abcd', 1.9, 1.1);
select mid('abcd', 1.1, 1.9);
select mid('abcd', 1.9, 1.9);

--echo

select mid('abcd', '-1.9', '1.9');
select mid('abcd', -1.1, 1.1);
select mid('abcd', '-1.9', '-1.9');
select mid('abcd', -1.1, -1.1);

--echo

select mid('', '1.1', '1.1');
select mid('', '1.9', '1.1');
select mid('', '1.1', '1.9');
select mid('', '1.9', '1.9');
select mid('', 1.1, 1.1);
select mid('', 1.9, 1.1);
select mid('', 1.1, 1.9);
select mid('', 1.9, 1.9);

--echo

select mid('abcd', 1234567890098765432100000, 100);
select mid('abcd', 1234567890098765432100000, 1234567890098765432100000);

# 下面这行MySQL和OB结果不一致
# select mid('abcd','18446744073709551615');

--echo

select mid('abcdef', '1.1', '1.9'),'a' from dual;
select mid('abcdef', '1.1', '1.9'),'a' from dual;
select mid('abcdef', '1.1', '1.9'),'a' from dual;
select mid('abcdef', '1.9',2.9),'abc' from dual;
select mid('abcdef', '1.9',2.9),'abc' from dual;
select mid('abcdef', '1.9',2.9),'abc' from dual;
select mid('abcdef', 1.9, '2.2'),'bc' from dual;
select mid('abcdef', 1.9, '2.2'),'bc' from dual;
select mid('abcdef', 1.9, '2.2'),'bc' from dual;
select mid('abcdef', 1.9) from dual;
select mid('abcdef', 1.9) from dual;
select mid('abcdef', 1.9) from dual;
