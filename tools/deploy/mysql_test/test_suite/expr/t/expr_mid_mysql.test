# Test of functions

--result_format 3
# 测试mid在create table时表现是否正确
--error 0, 1051
drop table t1;
create table t1(c1 varchar(64), c2 varchar(2) GENERATED ALWAYS AS (mid(c1,2,2)) VIRTUAL);
insert into t1(c1) values('1234567');
select * from t1;

--echo

drop table t1;
create table t1(c1 varchar(64), c2 varchar(2) GENERATED ALWAYS AS (mid(c1,-2,2)) VIRTUAL);
insert into t1(c1) values('1234567');
select * from t1;

--echo

