--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: xiaoyi.xy 
# owner group: SQL2
# Test of functions insert 
# tags: expr, datatype
--disable_warnings
--error 0,1008
drop database variablesandconstants;
create database variablesandconstants character set utf16;
use variablesandconstants;
DROP TABLE IF EXISTS table001;
CREATE TABLE table001( c1 INT UNSIGNED AUTO_INCREMENT, c2 VARCHAR(101) CHARACTER SET gbk NOT NULL, c3 VARCHAR(204) CHARACTER SET utf16 NOT NULL, c4 CHAR(200) CHARACTER SET gbk, c5 CHAR(200) CHARACTER SET utf16,PRIMARY KEY(c1))CHARSET=gbk; 

insert into table001(c1,c2,c3,c4,c5)values(null,'中国','中国・米国・英国・フランス','China, the United Kingdom, France','Chine États-Unis Royaume-Uni France');

select insert(c2, 0, 4, c3) from  table001;
select charset(insert(c2, 0, 4, c3)) from  table001;

select insert(c2, 1, 4, c3) from  table001;
select charset(insert(c2, 1, 4, c3)) from  table001;

select insert(c2, 2, 4, c3) from  table001;
select charset(insert(c2, 2, 4, c3)) from  table001;

select insert(c2, 3, 4, c3) from  table001;
select charset(insert(c2, 3, 4, c3)) from  table001;
