--result_format 3

# owner: dachuan.sdc
# owner group: sql2
# desc: 测试timestamp_nvl
# 

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1 (c1 timestamp);
set ob_log_level='sql.*:debug';
insert into t1 values(NULL);
select * from t1;
select timestamp_nvl(c1, '2019-01-01 00:00:00') from t1;
select timestamp_nvl(c1, timestamp'2019-01-01 00:00:00') from t1;

# 修改之前结果为输入,修改后结果为0000-00-00 00:00:00
select timestamp_nvl(c1, 123) from t1;
select timestamp_nvl(c1, '123') from t1;
select timestamp_nvl(c1, '123123123123123') from t1;
select timestamp_nvl(c1, 'invalid string') from t1;

drop table t1;
create table t1 (c1 timestamp);
insert into t1 values (123);
--error 1292
insert into t1 values ('123');
--error 1292
insert into t1 values ('123123123123123');
--error 1292
insert into t1 values ('invalid string');
select * from t1;

drop table t1;
