#BugFix:
--disable_warnings
drop table if exists t1,t2,t3,t4;
--enable_warnings
create table t1 (c1 int auto_increment primary key, c2 int);
create table t3 (c1 int);
create table t4 (c1 int);
create index idx1 on t1(c2);
select last_insert_id(0) from dual;
insert into t1 (c2) values (3);
insert into t1 (c2) values (2);
insert into t3 values(1);
insert into t4 values(1);
select * from t1;
select last_insert_id(0) from dual;
##test index
explain select * from t1 where c2 = last_insert_id();
select * from t1 where c2 = last_insert_id();
##test constraints
alter system flush plan cache global;
explain select * from t1 where 1 = last_insert_id();
explain select * from t1 where 2 = last_insert_id();
select * from t1 where 1 = last_insert_id();
select * from t1 where 2 = last_insert_id();
insert into t1 (c2) values (1);
select * from t1 where 2 = last_insert_id();
