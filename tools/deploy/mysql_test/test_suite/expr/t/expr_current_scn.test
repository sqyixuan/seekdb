#### description: test expr current_scn

select length(current_scn()) from dual;
select substr(current_scn(), 1, 10) = substr(timestamp_to_scn(now(6)), 1, 10);
--disable_warnings
drop table if exists t1;
drop view if exists v1;
--enable_warnings
create table t1 as select current_scn() c1 from dual;
create view v1 as select current_scn() c1 from dual;
desc t1;
desc v1;
drop table t1;
drop view v1;