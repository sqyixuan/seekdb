#Case for other param is col refrence
--disable_warnings
drop table if exists regexp_substr_col_ref;
--enable_warnings

create table regexp_substr_col_ref(text varchar(20), pattern varchar(20), position int, occur int, match_param varchar(10), subexpr int);
insert into regexp_substr_col_ref values('1234567890', '(123)(456)(7890)', 1, 1, NULL, 1);
insert into regexp_substr_col_ref values(NULL, '(123)(456)(7890)', 1, 1, NULL, 1);
insert into regexp_substr_col_ref values('1234567890', NULL, 1, 1, NULL, 1);
insert into regexp_substr_col_ref values('1234567890', '(123)(456)(7890)', NULL, 1, NULL, 1);
insert into regexp_substr_col_ref values('1234567890', '(123)(456)(7890)', 1, NULL, NULL, 1);
insert into regexp_substr_col_ref values('1234567890', '(123)(456)(7890)', 1, 1, NULL, NULL);

select text, pattern, position, occur, match_param, subexpr, regexp_substr(text, pattern, position, occur, match_param, subexpr) from regexp_substr_col_ref;
select text, pattern, position, occur, match_param, subexpr, regexp_substr(text, pattern, position, occur, 'i', subexpr) from regexp_substr_col_ref;

drop table regexp_substr_col_ref;

#Case for match_param 'i' and 'c'
select regexp_substr('AbCdEfg', 'ABCDEFG', 1, 1, 'i', 0) from dual;
select regexp_substr('AbCdEfg', 'ABCDEFG', 1, 1, 'c', 0) from dual;

#Case from regexp / not regexp
create table regexp_substr_t (col varchar(10) primary key, b int default 0);
insert into regexp_substr_t (col) values ('a'),('abc'),('abcd'),('hello'),('test');

