--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#### owner: dingjincheng.djc
#### owner group: hangzhou sql group
# tags: optimizer
#### description: test rand function plan

--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1 (a int, b int);
insert into t1 values (1, 1),(2, 2),(3, 3);
explain basic select rand(), rand(1), rand(a) from t1;
explain basic select * from t1 where rand() < 0.5 and rand(a) < 0.5;
explain basic select rand(1), sum(b) from t1 group by rand(1);
explain basic select rand(a), sum(b) from t1 group by rand(a);
explain basic select * from t1 order by rand(1);
explain basic select * from t1 order by rand(a);
explain basic select rand(a), sum(b) from t1 group by rand(a) order by rand(a+b);

explain basic select rand(), rand(1), rand(A.a) from t1 as A, t1 as B;
explain basic select * from t1 as A, t1 as B where rand() < 0.5 and rand(A.a) < 0.5;
explain basic select rand(1), sum(A.b) from t1 as A, t1 as B group by rand(1);
explain basic select rand(A.a), sum(A.b) from t1 as A, t1 as B group by rand(A.a);
explain basic select * from t1 as A, t1 as B order by rand(A.a);