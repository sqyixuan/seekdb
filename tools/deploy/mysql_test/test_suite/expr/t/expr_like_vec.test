#owner: dachuan.sdc
#owner group: SQL2
#description: test vectorized like expression
#tags: expr

connect (syscon, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection syscon;
alter system set _rowsets_enabled = true;

--sleep 1
connection default;

--disable_warnings
drop table if exists part;
--enable_warnings

create table part(p_name varchar(55));
insert into part values(''), ('a'), ('b'), ('c'), ('d'), ('-'), ('一'), ('  '), ('aa'), ('ab'), ('xy'), ('--'), ('??'), ('一二'), ('abc'), ('aaa'), ('xyz'), ('???'), ('一二三'), ('abcd'), ('aaaa'), ('xyzz'), ('1.,?'), ('一二三四'), ('abcde'), ('12345'), ('xxxxx'),
  ('abcdef'), ('123456'), ('xxxxxx'), ('abcdefg'), ('1234567'), ('xxxxxxx'), ('abcdefgh'), ('12345678'), ('xxxxxxxx'), ('abcdefghi'), ('123456789'), ('xxxxxxxxx');

insert into part select * from part;
insert into part select * from part;
insert into part select * from part;
insert into part select * from part;
insert into part select * from part;
insert into part select * from part;



select p_name like '' from part;
select p_name like null from part;
select p_name like 'abc%' from part;
select p_name like '%def' from part;
select p_name like '%ab%de%' from part;
select sum((p_name like 'abc%') + (p_name like 'abc%')) from part;
select sum((p_name like 'abc%')  + (p_name like 'abc%')  +(p_name like 'abc%')  +(p_name like 'abc%')  +(p_name like 'abc%')  +(p_name like 'abc%')  +(p_name like 'abc%')  +(p_name like 'abc%')  +(p_name like 'abc%')  +(p_name like 'abc%')  +(p_name like 'abc%')  +(p_name like 'abc%')  +(p_name like 'abc%')  +(p_name like 'abc%')  +(p_name like 'abc%')  +(p_name like 'abc%')  +(p_name like 'abc%')  +(p_name like 'abc%')  +(p_name like 'abc%')  +(p_name like 'abc%')  +(p_name like 'abc%')  +(p_name like 'abc%')  +(p_name like 'abc%')) x  from part;
select sum((p_name like '%Customer%Complaints%')  + (p_name like '%Customer%Complaints%')  +(p_name like '%Customer%Complaints%')  +(p_name like '%Customer%Complaints%')  +(p_name like '%Customer%Complaints%')  +(p_name like '%Customer%Complaints%')  +(p_name like '%Customer%Complaints%')  +(p_name like '%Customer%Complaints%')  +(p_name like '%Customer%Complaints%')  +(p_name like '%Customer%Complaints%')  +(p_name like '%Customer%Complaints%')  +(p_name like '%Customer%Complaints%')  +(p_name like '%Customer%Complaints%')  +(p_name like '%Customer%Complaints%')  +(p_name like '%Customer%Complaints%')  +(p_name like '%Customer%Complaints%')  +(p_name like '%Customer%Complaints%')  +(p_name like '%Customer%Complaints%')  +(p_name like '%Customer%Complaints%')  +(p_name like '%Customer%Complaints%')  +(p_name like '%Customer%Complaints%')  +(p_name like '%Customer%Complaints%')  +(p_name like '%Customer%Complaints%')) x  from part;


update part set p_name = null where p_name = 'b';
select p_name like '' from part;
select p_name like null from part;
select p_name like 'abc%' from part;
select p_name like '%def' from part;
select p_name like '%ab%de%' from part;
select sum((p_name like 'abc%') + (p_name like 'abc%')) from part;
select sum((p_name like 'abc%')  + (p_name like 'abc%')  +(p_name like 'abc%')  +(p_name like 'abc%')  +(p_name like 'abc%')  +(p_name like 'abc%')  +(p_name like 'abc%')  +(p_name like 'abc%')  +(p_name like 'abc%')  +(p_name like 'abc%')  +(p_name like 'abc%')  +(p_name like 'abc%')  +(p_name like 'abc%')  +(p_name like 'abc%')  +(p_name like 'abc%')  +(p_name like 'abc%')  +(p_name like 'abc%')  +(p_name like 'abc%')  +(p_name like 'abc%')  +(p_name like 'abc%')  +(p_name like 'abc%')  +(p_name like 'abc%')  +(p_name like 'abc%')) x  from part;
select sum((p_name like '%Customer%Complaints%')  + (p_name like '%Customer%Complaints%')  +(p_name like '%Customer%Complaints%')  +(p_name like '%Customer%Complaints%')  +(p_name like '%Customer%Complaints%')  +(p_name like '%Customer%Complaints%')  +(p_name like '%Customer%Complaints%')  +(p_name like '%Customer%Complaints%')  +(p_name like '%Customer%Complaints%')  +(p_name like '%Customer%Complaints%')  +(p_name like '%Customer%Complaints%')  +(p_name like '%Customer%Complaints%')  +(p_name like '%Customer%Complaints%')  +(p_name like '%Customer%Complaints%')  +(p_name like '%Customer%Complaints%')  +(p_name like '%Customer%Complaints%')  +(p_name like '%Customer%Complaints%')  +(p_name like '%Customer%Complaints%')  +(p_name like '%Customer%Complaints%')  +(p_name like '%Customer%Complaints%')  +(p_name like '%Customer%Complaints%')  +(p_name like '%Customer%Complaints%')  +(p_name like '%Customer%Complaints%')) x  from part;
select sum((p_name like 'abc%')  + (p_name like 'abc%')  +(p_name like 'abc%')  +(p_name like 'abc%')  +(p_name like 'abc%')  +(p_name like 'abc%')  +(p_name like 'abc%')  +(p_name like 'abc%')  +(p_name like 'abc%')  +(p_name like 'abc%')  +(p_name like 'abc%')  +(p_name like 'abc%')  +(p_name like 'abc%')  +(p_name like 'abc%')  +(p_name like 'abc%')  +(p_name like 'abc%')  +(p_name like 'abc%')  +(p_name like 'abc%')  +(p_name like 'abc%')  +(p_name like 'abc%')  +(p_name like 'abc%')  +(p_name like 'abc%')  +(p_name like 'abc%')) x  from part where (p_name like 'abc%') is not null;
select sum((p_name like '%Customer%Complaints%')  + (p_name like '%Customer%Complaints%')  +(p_name like '%Customer%Complaints%')  +(p_name like '%Customer%Complaints%')  +(p_name like '%Customer%Complaints%')  +(p_name like '%Customer%Complaints%')  +(p_name like '%Customer%Complaints%')  +(p_name like '%Customer%Complaints%')  +(p_name like '%Customer%Complaints%')  +(p_name like '%Customer%Complaints%')  +(p_name like '%Customer%Complaints%')  +(p_name like '%Customer%Complaints%')  +(p_name like '%Customer%Complaints%')  +(p_name like '%Customer%Complaints%')  +(p_name like '%Customer%Complaints%')  +(p_name like '%Customer%Complaints%')  +(p_name like '%Customer%Complaints%')  +(p_name like '%Customer%Complaints%')  +(p_name like '%Customer%Complaints%')  +(p_name like '%Customer%Complaints%')  +(p_name like '%Customer%Complaints%')  +(p_name like '%Customer%Complaints%')  +(p_name like '%Customer%Complaints%')) x  from part where (p_name like '%Customer%Complaints%') is not null;

drop table part;

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1 (c1  char(20));
insert into t1 values('naxpnxpnxpnxpnsx'), ('06'), (''), ('70647567776F6A'), (''), (''), (NULL), (NULL), ('E7A7776656E766F656E7'), (NULL), (NULL), (NULL);
SELECT/*+monitor*/ c1 AS al FROM t1  WHERE    c1 LIKE REPEAT( REPEAT( '' , 1 ) , 2);
drop table t1;

# test for special pattern, such as "%xx%" which will be opt with SIMD.
--disable_warnings
drop table if exists t2;
--enable_warnings

create table t2 (a varchar(500)) COLLATE=utf8mb4_bin with column group (each column);
insert into t2 values('abcdefghijklmnopqrstuvwxyz');
insert into t2 values('01234567890');
insert into t2 values('你好');
insert into t2 values('baidugoogle?abcdefghijklmnopqrst');
insert into t2 values('google?baidu.com?abcdefghijklmnopqrst');
insert into t2 values('google');
insert into t2 values('baidu.com?abcdefghijklmnopqrst@google');
insert into t2 values(NULL);
insert into t2 values('');
select * from t2 where a like '%google%';
select * from t2 where a like '%0%';
select * from t2 where a like '%google';
select * from t2 where a like 'google%';
select * from t2 where a like 'google';
drop table t2;
