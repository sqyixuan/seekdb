## normal cases ##
set sql_mode='';
--disable_warnings
drop table if exists t;
--enable_warnings
create table t(
  id            int auto_increment primary key, 
  col_int       bigint,
  col_uint      bigint unsigned,
  col_float     float,
  col_double    double,
  col_decimal   decimal(30, 6),
  col_datetime  datetime(3),
  col_timestamp timestamp(4) null default null,
  col_date      date,
  col_time      time(5),
  col_year      year(4),
  col_varchar   varchar(100)
);
insert into t(col_int) values (0), (-123456), (456789), (789123);
insert into t(col_uint) values (0), (987654), (654321), (321987);
insert into t(col_decimal) values (0), (-142857.12), (-285714.34), (428571.56), (571428.78);
insert into t(col_datetime) values (0), ('1000-1-1 21:35:52.232118'), ('1970-1-1 0:0:0'), ('3089-10-29 20:2:45.142051');
insert into t(col_timestamp) values (0), ('1999-12-31 12:34:56.456789'), ('2015-10-16 11:07:31.610211'), ('2037-01-01 00:00:00.123456');
insert into t(col_date) values (0), ('1534-7-4'), ('2689-1-23'), ('5921-3-4');
insert into t(col_time) values (0), ('-838:59:59'), ('-92:13:55.819532'), ('00:00:34.901835'), ('201:51:16.792539'), ('838:59:59');
insert into t(col_year) values (0), ('1901'), ('1997'), ('2155');
insert into t(col_varchar) values (0), ('-998877.654'), ('-665544.321'), ('125213.07241'), ('321987.844918');

