##test for @@div_precision_increment
set @origin_div_precision_increment = @@div_precision_increment;
drop table t;
create table t(a int);
insert into t values(1);
insert into t values(0);
insert into t values(0);
set @@div_precision_increment = 0;
select 1/7;
select 1.023/7.2;
select avg(a) from t;
set @@div_precision_increment = 12;
select 1/7;
select 1.023/7.2;
select avg(a) from t;
set @@div_precision_increment = 30;
select 1/7;
select 1.023/7.2;
select avg(a) from t;
## restore 
set @@div_precision_increment = @origin_div_precision_increment;


# clear tables
drop table t;
