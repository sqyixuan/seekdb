select c1, c2, c1 + c2 from (select t1.col_int as c1, t2.col_uint as c2 from t t1, t t2) as tmp where c1 is not null and c2 is not null and (c1 + 0.0) + (c2 + 0.0) >= 0 order by c1, c2;                            
