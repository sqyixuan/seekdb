select '2000-01-01' >= from_days(700000) or '2000-01-01' <= from_days(800000);
select 730500 >= to_days('2000-01-01') or 730500 <= to_days('2001-01-01');

select '2013-01-05' >= '2013-01-01' or '2013-01-05' <= makedate(2013,10);
select '2013-01-05' >= makedate(2013,1) or '2013-01-05' <= '2013-01-10';
