# owner: peihan.dph
# owner group: sql2

--disable_abort_on_error
--result_format 4

connect (con, $OBMYSQL_MS0, admin, $OBMYSQL_PWD, test, $OBMYSQL_PORT);
connection con;
alter system flush sql audit global;

--sleep 1
connection default;
set ob_enable_plan_cache = off;
--disable_warnings


################################   true      true      ->     true    #############################

select 3 >= 0 or 3 <= 5;
select 3.14 >= 2.00 or 3.14 <= 4.00;
select 'hij' >= 'abc' or 'hij' <= 'opq';

select 2008 >= year('1949-10-01') or 2008 <= year('2021-07-01');
select 7 >= month('2013-03-01') or 7 <= month('2013-10-01');
select 10 >= week('2013-01-12') or 10 <= week('2013-04-25');
select 21 >= dayofyear('2013-01-01') or 21 <= dayofyear('2013-01-31');
select 21 >= dayofmonth('2013-01-01') or 21 <= dayofmonth('2013-01-31');
