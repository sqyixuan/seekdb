--echo ## test subquery
select * from t1 where id not in (select id from t2 group by id);

select * from t1 where id not in (select max(id) from t2 group by value);

select * from t1 where id not in (select max(id) from t2 where 1 = 0);

select * from (select id from t2 group by id) v where v.id is not null;

select * from (select max(id) m from t2 group by value) v where v.m is not null;

select * from (select count(id) m from t2 group by value) v where v.m is not null;

--echo ## test set op
select * from t1 where id not in (select 1 from t2 union select 1 from t2);

select * from t1 where id not in (select 1 from t2 union select null from t2);

select * from t1 where id not in (select 1 from t2 intersect select null from t2);

select * from t1 where id not in (select null from t2 intersect select null from t2);

select * from t1 where id not in (select 1 from t2 except select null from t2);

select * from t1 where id not in (select null from t2 except select null from t2);

select * from t1 where id not in (select null from t2 except select 1 from t2);

select * from t1 where id not in (select null from dual except select null from t2);

--echo ## tpch cases
CREATE TABLE partsupp (
	ps_partkey int NOT NULL,
	ps_suppkey decimal(10, 0) NOT NULL,
	ps_availqty decimal(10, 0) DEFAULT NULL,
	ps_supplycost decimal(10, 0) DEFAULT NULL,
	ps_comment varchar(199) DEFAULT NULL,
	PRIMARY KEY (ps_partkey, ps_suppkey)
);

CREATE TABLE supplier (
	s_suppkey int NOT NULL,
	s_name char(25) DEFAULT NULL,
	s_address varchar(40) DEFAULT NULL,
	s_nationkey decimal(10, 0) DEFAULT NULL,
	s_phone char(15) DEFAULT NULL,
	s_acctbal decimal(10, 0) DEFAULT NULL,
	s_comment varchar(101) DEFAULT NULL,
	PRIMARY KEY (s_suppkey)
);

CREATE TABLE part (
	p_partkey int NOT NULL,
	p_name varchar(55) DEFAULT NULL,
	p_mfgr char(25) DEFAULT NULL,
	p_brand char(10) DEFAULT NULL,
	p_type varchar(25) DEFAULT NULL,
	p_size decimal(10, 0) DEFAULT NULL,
	p_container char(10) DEFAULT NULL,
	p_retailprice decimal(10, 0) DEFAULT NULL,
	p_comment varchar(23) DEFAULT NULL,
	PRIMARY KEY (p_partkey)
);

SELECT P_BRAND, P_TYPE, P_SIZE, COUNT(DISTINCT PS_SUPPKEY) AS SUPPLIER_CNT
FROM PARTSUPP, PART
WHERE P_PARTKEY = PS_PARTKEY
	AND P_BRAND <> 'Brand#45'
	AND P_TYPE NOT LIKE 'MEDIUM PLLISHED%'
	AND P_SIZE IN (49, 14, 23, 45, 19, 3, 36, 9)
	AND PS_SUPPKEY NOT IN (
		SELECT S_SUPPKEY
		FROM SUPPLIER
		WHERE S_COMMENT LIKE '%Customer%Complaints%'
	)
GROUP BY P_BRAND, P_TYPE, P_SIZE
ORDER BY SUPPLIER_CNT DESC, P_BRAND, P_TYPE, P_SIZE;


