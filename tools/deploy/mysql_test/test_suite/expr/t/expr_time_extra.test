#### owner: dachuan.sdc
#### owner group: sql2
#### description: date_type

--result_format 4

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
drop table if exists t0, t1, t2, t3, t4, t5;
--enable_warnings





--echo bugfix: 

select hour(' ');
select minute(' ');
select second(' ');
select microsecond(' ');

create table t0(c1 varchar(30));
insert into t0 values(' ');
select hour(c1) from t0;
select minute(c1) from t0;
select second(c1) from t0;
select microsecond(c1) from t0;


--echo bugfix: 

select year('0.05.0013');
select year('0.05.013');
select year('0.05.13');

create table t1(c1 varchar(30));
insert into t1 values('0.05.0013');
insert into t1 values('0.05.013');
insert into t1 values('0.05.13');

select year(c1) from t1;
select year(c1) from t1;
select year(c1) from t1;


--echo bugfix: 

select hour('0000-00-00 01:00:00.1');
select year('0000-00-00 01:00:00.1');
select minute('0000-00-00 01:00:00.1');
select second('0000-00-00 01:00:00.1');
select microsecond('0000-00-00 01:00:00.1');
select month('0000-00-00 01:00:00.1');
select day('0000-00-00 01:00:00.1');

create table t2(c1 varchar(30));
insert into t2 values('0000-00-00 01:00:00.1');
select hour(c1) from t2;
select year(c1) from t2;
select minute(c1) from t2;
select second(c1) from t2;
select microsecond(c1) from t2;
select month(c1) from t2;
select day(c1) from t2;


--echo bugfix: 

select microsecond('01:01:01.9999999');
select microsecond('01:01:01.8999999');

create table t3(c1 varchar(30));
insert into t3 values('01:01:01.9999999');
insert into t3 values('01:01:01.8999999');
select microsecond(c1) from t3;

set @@sql_mode = 'STRICT_ALL_TABLES,NO_ZERO_IN_DATE,NO_ZERO_DATE';
select year(00000000);
select year(00000001);
select year('00000101');
select year(0000);
select year(0);
select year('0000');
select year('0');

create table t4(c1 date);
# need comp with mysql in future, error
insert into t4 values(00000000);
--error 1292
insert into t4 values(00000001);
# need comp with mysql in future, error
insert into t4 values(0000);
# need comp with mysql in future, error
insert into t4 values(0);
--error 1292
insert into t4 values('0000');
--error 1292
insert into t4 values('0');
select * from t4;

select @@sql_mode;
set @@sql_mode = '';
select year(00000000);
select year(00000001);
select year('00000101');
select year(0000);
select year(0);
select year('0000');
select year('0');

insert into t4 values(00000000);
insert into t4 values(00000001);
insert into t4 values(0000);
insert into t4 values(0);
insert into t4 values('0000');
insert into t4 values('0');
select * from t4;

--echo bugfix: 
set @@sql_mode = 'STRICT_ALL_TABLES,NO_ZERO_IN_DATE,NO_ZERO_DATE';
create table t5(c datetime);
insert into t5 values('0000-02-28');
--error 1292
insert into t5 values('0000-02-29');

select dayname('0000-02-28');
select dayname('0000-02-29');
select dayname('0000-03-01');
SELECT TO_DAYS('0000-11-04');

drop table t0, t1, t2, t3, t4, t5;


