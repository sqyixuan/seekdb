--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

#owner: linlin.xll
#owner group: SQL1
#description: 本case是为了测试一些操作符, 应该和func_test区分开来，一个用于测试操作符，一个专门用于测试函数。
#tags: pl, optimizer, funcs

# Description
# -----------
# Simple operands and arithmetic grouping

select 1+1,1-1,1+1*2,8/5,8%5,mod(8,5),mod(8,5)|0,-(1+1)*-2;
explain select 1+1,1-1,1+1*2,8/5,8%5,mod(8,5),mod(8,5)|0,-(1+1)*-2;
select 1 | (1+1),5 & 3;
#select bit_count(7);
explain select 1 | (1+1),5 & 3;
#explain select bit_count(7);
select 1 << 32,1 << 63, 1 << 64, 4 >> 2, 4 >> 63, 1<< 63 >> 60;
#
# bug #1993: bit functions must be unsigned
#
select -1 | 0, -1 ^ 0, -1 & 0;
select -1 | 1, -1 ^ 1, -1 & 1;
select  1 | -1,  1 ^ -1,  1 & -1;
select  0 | -1,  0 ^ -1,  0 & -1;
select  null | 1, 1 | null, null | null; 
select  null & 1, 1 & null, null & null; 
select  null ^ 1, 1 ^ null, null ^ null; 

select -1 >> 0, -1 << 0;
select -1 >> 1, -1 << 1;
select 1 >> -1, -1 << -1;
select ~0, ~1, ~-1, ~null;
select null >> 1, 1 >> null, null >> null; 
select null << 1, 1 << null, null << null; 
select 18446744073709551610 | 2, 18446744073709551610 & 2;
select pow(2,3),power(2,3);

#function bit_count() is not supported so far
# Bug 13044: wrong bit_count() results
#
## not supported so far :bit_count()
