# End of 4.1 tests

--disable_warnings
drop table if exists sb;
--enable_warnings
create table sb(a bigint);
insert into sb values(null and "2.3");
insert into sb values(null or "2.3");
insert into sb values(pow(2,1.2));
--echo // we add CM_WARN_ON_FAIL in pow expr, so '2.a' will is casted as 0. compatiable with mysql
--disable_warnings
insert into sb values(pow(2,"2.a"));
--enable_warnings
select hex(char(NULL,121,83,81,125,128,255,256,1,2,3,11,99,'76'));
select char_length(null);
select concat(null, null, null, null, null);
select conv(123,-5,10);
select from_days(null);
SELECT FROM_UNIXTIME(-1234567);
select hex(-5.4);
select insert('Quadratic',6,-1,'');
select insert('',6,-1,'helloworld');
select insert('Quadratic',6,-1,null);
select insert('',6,-1,'');
select insert(null,6,-1,'helloworld');
select int2ip(-123456);
select int2ip(111111111123456);
drop table sb;
create table sb(a int, b int unsigned);
insert into sb values(1,0);
insert into sb values(0,0);
insert into sb values(0,2);
select a div b from sb;
select b div a from sb;
select ip2int(null);
select ip2int("xxxxxxxxxxxxxxxxxxxxxxxxx");
drop table sb;
select unix_timestamp(20100101123456);
select unhex("ABXDE");
SELECT TRIM(LEADING null FROM null);
select to_days(null);
select to_days("helloworld");
select timestampdiff(MICROSECOND, null, null);
select timestampdiff(MICROSECOND, "0000-00-00 00:00:00", "0000-00-00 00:00:00");
select timestampdiff(MICROSECOND, "2012-01-01 12:22:22", "2012-01-01 12:22:22");
select timestampdiff(MICROSECOND, "2010-02-19 12:10", "2010-02-19 12:08");
select timestampdiff(MICROSECOND, "2010-02-19 12:15:18", "2010-02-19 12:15:16");
select timestampdiff(MICROSECOND, "2010-02-19 12:15:18", "2010-02-19 12:15:19");
create table sb(a decimal(18,10), b decimal(20,12));
insert into sb values(123456,123455);
select timediff(a, b) from sb;
drop table sb;
select rpad("",1,"");
select rpad("",-1,"");
select rpad("",1,"xxx");
select rpad("xxx",1,"");
select rpad("",-1,"xxx");
select rpad("xxx",-1,"");
select rpad("",-1,null);
select rpad("xxx",-1,null);
select rpad("",1,null);
select rpad("xxx",1,null);
select replace("", "", "");
select replace("hello", "", "");
select replace("", "hello", "");
select replace("", "", "hello");
select pow(null, null);
select pad(null, null, null);
select ora_decode("1", "1", "1", "1", "1", "1");
create table sb(a int, b int, c int unsigned);
insert into sb values(0,0,0);
insert into sb values(1,-1,1);
select * from sb where b between a and c;
select * from sb where -99999 between c and -11;
drop table sb;
select nvl(null, null);
select nvl(null, "helloworld");
select nvl("helloworld", null);
select nullif(null, null);
select nullif(null, "helloworld");
select nullif("helloworld", null);
select ifnull(null, null);
select ifnull(null, "helloworld");
select ifnull("helloworld", null);
select lower("");
select upper("");
select "a" like "a%%";
select "a" like "%a%";
select "a" like "%%";
#bug 14727453
--disable_warnings
drop table if exists nvl_test;
--enable_warnings
create table nvl_test(a int);
insert into nvl_test values(1);
select case a when 1 then nvl(a,1)/1 end as a from nvl_test;


##bugfix: 
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1(c0 INT);
INSERT INTO t1(c0) VALUES (1),(1);
SELECT t1.c0 rc1 FROM t1 WHERE t1.c0 & 0.5;
select t1.c0, t1.c0 ^ 0.5 from t1;
drop table t1;

##bugfix: 
CREATE TABLE t1(c1 VARCHAR(10) );
INSERT INTO t1(c1) VALUES ('a'), ('a');
SELECT t1.c1 rc1 FROM t1 WHERE (0.7) ^ (t1.c1) ORDER BY t1.c1 DESC; 
drop table t1;