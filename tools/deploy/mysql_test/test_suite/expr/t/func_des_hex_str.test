#description: test hex_to_cstr

--disable_warnings
--disable_query_log

drop table if exists yuanfeng_test;
create table yuanfeng_test (c1 int, c2 float, c3 double, c4 varchar(100), c5 date, c6 datetime, c7 timestamp, c8 time, c9 year, primary key(c1));
insert into yuanfeng_test values
(1, 1.1, 1.111, 'abc', '2000-01-01', '2000-01-01 00:00:00', '2000-01-01 00:00:00', '00:00:00', '2000'),
(2, 2.2, 2.222, 'bcd', '2001-01-01', '2001-01-01 01:01:01', '2001-01-01 01:01:01', '01:01:01', '2001'),
(3, 3.3, 3.333, 'cde', '2002-02-02', '2002-02-02 02:02:02', '2002-02-02 02:02:02', '02:02:02', '2002'),
(4, 4.4, 4.444, 'def', '2003-03-03', '2003-03-03 03:03:03', '2003-03-03 03:03:03', '03:03:03', '2003'),
(5, 5.5, 5.555, 'efg', '2004-04-04', '2004-04-04 04:04:04', '2004-04-04 04:04:04', '04:04:04', '2004');

call dbms_stats.gather_table_stats('TEST', 'yuanfeng_test');
