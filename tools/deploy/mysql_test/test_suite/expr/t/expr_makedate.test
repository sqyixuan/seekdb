# owner: dachuan.sdc
# owner group: SQL2
# Test of functions makedate

--error 1054
select makedate;
--error 1582
select makedate();
--error 1582
select makedate(1);
--error 1582
select makedate(1, 2, 3);


--disable_warnings
drop table if exists t1, t2, t3;
drop view if exists v1;
--enable_warnings

create table t1(c1 int);
create table t2(d1 int);
insert into t1 values(-1), (0), (10), (69), (70), (99), (100), (1000), (2000), (9999);
insert into t2 values(-1), (0), (10), (365), (366), (1000), (10000), (999999);
select c1, d1, makedate(c1, d1) from t1, t2 order by c1, d1;
create table t3 as select c1, d1, makedate(c1, d1) from t1, t2 order by c1, d1;
create view v1 as select c1, d1, makedate(c1, d1) from t1, t2 order by c1, d1;
desc t3;
desc v1;
select * from t3;
show create view v1;

select makedate(1.5, 1.5);
select makedate('1', '1');
select makedate('1.5', '1.5');
drop table t1, t2, t3;
drop view v1;
