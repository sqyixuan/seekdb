# owner: qiaolinjun.qlj
# owner group: IMF

--disable_abort_on_error
--result_format 4

--disable_warnings
drop table if exists t3;
--enable_warnings

#测试random_bytes函数
select collation(random_bytes(4));
select charset(random_bytes(4));
select length(random_bytes(4));
select random_bytes(NULL);
select length(random_bytes(NULL));
set block_encryption_mode = 0;
select hex(aes_encrypt('a', 'a', random_bytes(16)));
set block_encryption_mode = 18;
select hex(sm4_encrypt('a', 'a', random_bytes(16)));
set block_encryption_mode = 0;
#select (random_bytes(4) = random_bytes(4));

select char_length(random_bytes(4.5));
select random_bytes(1025);
select random_bytes(-10);
select random_bytes('a');
select length(random_bytes('10'));
select length(random_bytes('1025'));
select length(random_bytes(b'00000101'));
select random_bytes(0);
select random_bytes(4,2);
select random_bytes(a);
select random_bytes(a,b);

#测试时间类型的转换
select length(random_bytes('21-11-11'));
select length(random_bytes(cast('21-11-11' as date)));
select length(random_bytes(cast('00:00:00' as time)));
select length(random_bytes('10:00:1025'));
select length(random_bytes(cast('10:00:1025' as time)));
select length(random_bytes(cast('10:00:59' as time)));
select length(random_bytes('87-01-01 01:01:59'));
select length(random_bytes(cast('87-01-01 01:01:59' as datetime)));
#测试从数据表中读取数据作为random_bytes的参数

create table t3(c1 int, c2 float, c3 varbinary(100));
insert into t3 values(10, 9.8, random_bytes(12));
insert into t3 values(9, 5.6, random_bytes(7));
insert into t3 values(0, 5.6, random_bytes(7.6));

--sleep 1
select length(random_bytes(c1)) from t3 where c1 = 9;
drop table t3;
