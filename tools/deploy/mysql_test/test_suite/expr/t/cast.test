--disable_warnings
drop table if exists t0;
--enable_warnings
CREATE TABLE t0(c0 FLOAT ZEROFILL PRIMARY KEY);
REPLACE INTO t0(c0) VALUES(0.0);
SELECT /*+ NO_MERGE (t0) */ ALL t0.c0 AS ref0 FROM t0 WHERE (NOT (BIT_COUNT(LEAST( EXISTS (SELECT 1 from dual wHERE FALSE), -705681661,  EXISTS (SELECT 1 from dual wHERE FALSE), t0.c0))));

