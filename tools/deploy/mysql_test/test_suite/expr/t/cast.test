## float转int时，如果超过LLONG_MAX应该trunc成LLONG_MIN，而double转int时超过LLONG_MAX应该trunc成LLONG_MAX
--disable_warnings
drop table if exists t0;
--enable_warnings
create table t0(c1 float, c2 double, c3 bigint unsigned, c4 bigint unsigned);
insert into t0(c1,c2) values(8223372036854775809,8223372036854775809);
insert into t0(c1,c2) values(9223372036854775807,9223372036854775807);
insert into t0(c1,c2) values(9223372036854775808,9223372036854775808);
insert into t0(c1,c2) values(9223372036854775809,9223372036854775809);
insert into t0(c1,c2) values(11223372036854775809,11223372036854775809);
insert into t0(c1,c2) values(17446744073709551615,17446744073709551615);
update t0 set c3 = c1, c4 = c2;
select c1, c2, c3, c4 from t0;

insert into t0(c1,c2) values(18446744073709551614,18446744073709551614);
insert into t0(c1,c2) values(18446744073709551615,18446744073709551615);
insert into t0(c1,c2) values(18446744073709551616,18446744073709551616);
insert into t0(c1,c2) values(19446744073709551615,19446744073709551615);

insert into t0(c1,c2) values(-10,-10);
insert into t0(c1,c2) values(-123.5, -123.5);
insert into t0(c1,c2) values(-123456.5, -123456.5);
insert into t0(c1,c2) values(-8223372036854775809,-8223372036854775809);
insert into t0(c1,c2) values(-9223372036854775807,-9223372036854775807);
insert into t0(c1,c2) values(-9223372036854775808,-9223372036854775808);
insert into t0(c1,c2) values(-9223372036854775809,-9223372036854775809);
insert into t0(c1,c2) values(-11223372036854775809,-11223372036854775809);
insert into t0(c1,c2) values(-17446744073709551615,-17446744073709551615);
insert into t0(c1,c2) values(-17446744073709551615,-17446744073709551615);
insert into t0(c1,c2) values(-19446744073709551615,-19446744073709551615);

select c1, cast(c1 as signed), c2, cast(c2 as signed) from t0;
