--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#### owner: luofan.zp
#### owner group: sql2
#### description: Test of cast function


--disable_query_log
SET GLOBAL max_allowed_packet = 4194304;
disconnect default;
connect (default, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
--enable_query_log


select CAST(1-2 AS UNSIGNED);
select CAST(CAST(1-2 AS UNSIGNED) AS SIGNED INTEGER);
select CAST('10 ' as unsigned integer);
select cast(-5 as unsigned) | 1, cast(-5 as unsigned) & -1;
select cast(-5 as unsigned) -1, cast(-5 as unsigned) + 1;
select ~5, cast(~5 as signed);
select cast(5 as unsigned) -6.0;
select cast(NULL as signed), cast(1/0 as signed);
#
select cast(NULL as unsigned), cast(1/0 as unsigned); 
select cast("A" as binary) = "a", cast(BINARY "a" as CHAR) = "A";
select cast("2001-1-1" as DATE), cast("2001-1-1" as DATETIME);
select cast("1:2:3" as TIME);
select CONVERT("2004-01-22 21:45:33",DATE);
select 10+'10';
select 10.0+'10';
select 10E+0+'10';

SELECT CONVERT(TIMESTAMP "2004-01-22 21:45:33", CHAR);
SELECT CONVERT(TIMESTAMP "2004-01-22 21:45:33", CHAR(4));
SELECT CONVERT(TIMESTAMP "2004-01-22 21:45:33", BINARY(4));
select CAST(TIMESTAMP "2004-01-22 21:45:33" AS BINARY(4));

select CAST(0xb3 as signed);
select CAST(0x8fffffffffffffff as signed);
select CAST(0xffffffffffffffff as unsigned);
select CAST(0xfffffffffffffffe as signed);
select cast('-10a' as signed integer);
select cast('a10' as unsigned integer);
select 10+'a';
select 10.0+cast('a' as decimal);
select 10E+0+'a';

# out-of-range cases
select cast('18446744073709551616' as unsigned);
####select cast('18446744073709551616' as signed);
select cast('9223372036854775809' as signed);
select cast('abc' as signed);
select cast('1a' as signed);
select cast('' as signed);

#
select cast(1000 as CHAR(3));

select cast("2001-1-1" as date) = "2001-01-01";
select cast("2001-1-1" as datetime) = "2001-01-01 00:00:00";
select cast("1:2:3" as TIME) = "1:02:03";
select cast(NULL as DATE);
select cast(NULL as BINARY);

#
select date_add(cast('2004-12-30 12:00:00' as date), interval 0 hour);
select timediff(cast('2004-12-30 12:00:00' as time), '12:00:00');

select timediff(cast('1 12:00:00' as time), '12:00:00');

#
select cast(18446744073709551615 as unsigned);
select cast('18446744073709551615' as unsigned);
select cast('9223372036854775807' as signed);

select cast(concat('184467440','73709551615') as unsigned);

select cast(repeat('1',20) as unsigned);

#
select cast(1.0e+300 as signed int);

#
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (f1 double);
INSERT INTO t1 SET f1 = -1.0e+30 ;
INSERT INTO t1 SET f1 = +1.0e+30 ;
SELECT f1 AS double_val, CAST(f1 AS SIGNED INT) AS cast_val FROM t1;
DROP TABLE t1;
					   
#

select isnull(date(NULL)), isnull(cast(NULL as DATE));

#
SELECT CAST(cast('01-01-01' as date) AS UNSIGNED);
SELECT CAST(cast('01-01-01' as date) AS SIGNED);

select cast('1.2' as decimal(3,2));
select 1e18 * cast('1.2' as decimal(3,2));
select cast(cast('1.2' as decimal(3,2)) as signed);
set @v1=1e18;
select cast(@v1 as decimal(22, 2));
select cast(-1e18 as decimal(22,2));

create table t1(s1 time);
insert into t1 values ('11:11:11');
select cast(s1 as decimal(7,2)) from t1;
drop table t1;

#
select cast(NULL as decimal(6)) as t1;

#
select hex(cast('a' as char(2) binary));

#
CREATE TABLE t1 (d1 datetime);
INSERT INTO t1(d1) VALUES ('2007-07-19 08:30:00'), (NULL),
  ('2007-07-19 08:34:00'), (NULL), ('2007-07-19 08:36:00');
SELECT cast(date(d1) as signed) FROM t1;
drop table t1;

#

CREATE TABLE t1 (f1 DATE);
INSERT INTO t1 VALUES ('2007-07-19'), (NULL);
SELECT month(f1) FROM t1;
SELECT month(CAST('2007-07-19' AS DATE));
SELECT month(CAST(NULL AS DATE));
SELECT month(NULL);
DROP TABLE t1;
SELECT HEX(CONVERT('a', BINARY(2049)));  
SELECT CONVERT('a', CHAR(2049));

--error 1427
select cast(1 as decimal(3,100000));
--error 1427
select convert(1, decimal(3,100000));
--error 1426
select cast(1 as decimal(100000, 3));
--error 1426
select convert(1, decimal(100000, 3));
--error 1426
select convert(1, decimal(100000,100000));
--error 1426
select cast(1 as decimal(100000, 100000));

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1(c1 timestamp);
insert into t1 values('2016-01-01 01:01:01');
select case c1 when 0.00000 then '' end from t1;

select collation(cast('a' as binary(10)));
select collation(cast('a' as char(10)));
select length(cast('a' as binary(10)));
select length(cast('a' as char(10)));

--disable_warnings
drop table if exists t1;
--enable_warnings

--disable_warnings
drop table if exists t2;
--enable_warnings

CREATE TABLE t1 (c1 int(80) DEFAULT NULL) ;
CREATE TABLE t2 (c2 varbinary(60) NOT NULL) ;
insert into t2 values ('hello'),('oceanbase');
select c1, length(c1) from ((select c1 from t1 ) union (select c2 from t2)) a;

--disable_warnings
drop table if exists t1;
--enable_warnings

--disable_warnings
drop table if exists t2;
--enable_warnings

CREATE TABLE t1 (c1 varchar(10), c2 char(10) DEFAULT NULL) ;
--error 1292
insert into t1 (c1) values(cast('abced' as binary(2)));
--error 1292
insert into t1 (c1) values(cast('abced' as char(2)));
insert into t1 (c1) values(cast('abced' as binary(5)));
--error 1292
insert into t1 values(cast('abced' as binary(5)), cast('a' as binary(0)));
--error 1292
insert into t1 values(cast('abced' as binary(5)), cast('a' as char(0)));
select * from t1;

--disable_warnings
drop table if exists t1;
--enable_warnings

--error 1426
SELECT CAST(1 AS TIME(100));
--error 1426
SELECT CAST(1 AS DATETIME(100));
SELECT CAST(1 AS TIME(0));
SELECT CAST(1 AS DATETIME(0));
SELECT CAST(1 AS TIME(6));
SELECT CAST(1 AS DATETIME(6));
select cast(1 as decimal(0));
select cast(123 as decimal(0));
select cast(1234567891 as decimal(0));
select cast(12345678910 as decimal(0));
select cast('9999-12-31 23:59:59.998' as datetime);
select cast('9999-12-31 23:59:59.998' as datetime(6));

--disable_warnings
DROP TABLE if exists t1;
--enable_warnings
CREATE TABLE t1 (a VARCHAR(32));
INSERT INTO t1 VALUES('9999-12-31 23:59:59.0000009'), ('9999-12-31 23:59:59.9'),('2001-01-01 10:10:10.9999994'), ('2001-01-01 10:10:10.9999995');
SELECT a, CAST(a AS DATETIME) FROM t1;
--disable_warnings
DROP TABLE if exists t1;
--enable_warnings

--result_format 4
# boundary test
--error 1064
select length(cast('a' as binary(-1))) as a from dual;
select length(cast('a' as binary(0))) as a from dual;
select length(cast('a' as binary(4194304))) as a from dual;
select length(cast('a' as binary(4194305))) as a from dual;
select length(cast('a' as binary(2147483647))) as a from dual;
select length(cast('a' as binary(2147483648))) as a from dual;
select length(cast('a' as binary(4294967295))) as a from dual;
--error 1439
select length(cast('a' as binary(4294967296))) as a from dual;

# test multi-bytes character
select length(cast('阿' as binary(1))) as a from dual;
select length(cast('阿' as binary(2))) as a from dual;
select length(cast('阿' as binary(3))) as a from dual;
select length(cast('阿' as binary(4))) as a from dual;
select length(cast('阿' as binary(5))) as a from dual;

select length(cast('阿斯蒂芬' as binary(1))) as a from dual;
select length(cast('阿斯蒂芬' as binary(2))) as a from dual;
select length(cast('阿斯蒂芬' as binary(3))) as a from dual;
select length(cast('阿斯蒂芬' as binary(4))) as a from dual;
select length(cast('阿斯蒂芬' as binary(5))) as a from dual;

--disable_warnings
drop table if exists t2;
--enable_warnings
create table t2(c1 decimal(65, 30));
insert into t2 values
(0.92345678901234567890123), (0.92), (0.12), (0.1234567890123456789012),
(10.92345678901234567890123), (10.92), (10.12), (10.1234567890123456789012),
(-0.92345678901234567890123), (-0.92), (-0.12), (-0.1234567890123456789012),
(-10.92345678901234567890123), (-10.92), (-10.12), (-10.1234567890123456789012);
select c1, cast(c1 as signed) from t2;
select c1, cast(c1 as unsigned) from t2;

--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1 (pk int , c1 bigint);
insert into t1 values(1, 140);
select c1, cast(c1/COALESCE(142,2377,99) as signed)from t1 where c1=140;
select 140, cast(140/COALESCE( 142 , 23773 , 99 ) as signed);
select c1, cast(c1/COALESCE(142,2377,99) as unsigned)from t1 where c1=140;
select 140, cast(140/COALESCE( 142 , 23773 , 99 ) as unsigned);

drop table t1;
create table t1(c1 decimal(65, 1));
insert into t1 values(11111111111111111111111111111111);
insert into t1 values(-11111111111111111111111111111111);
select cast(c1 as signed) from t1;
select cast(c1 as unsigned) from t1;



--echo bugfix: 
--echo ## test cast float to int
drop table t1;
create table t1(c1 float, c2 tinyint, c3 smallint, c4 mediumint, c5 int, c6 bigint);
insert into t1(c1) values(0.5);
insert into t1(c1) values(1.5);
insert into t1(c1) values(2.5);
insert into t1(c1) values(3.5);
insert into t1(c1) values(99.5);
insert into t1(c1) values(100.5);
insert into t1(c1) values(127);
insert into t1 select -c1, c2, c3, c4, c5, c6 from t1;
insert into t1(c1) values(127.4);
insert into t1(c1) values(-128.4);
insert into t1(c1) values(-128.5);
### 127.4和-128.5可以cast到tinyint范围内, 即[-128, 127]
update t1 set c2 = c1;
### 127.5和-128.50001 cast到tinyint以后超出范围
insert into t1(c1) values(127.5);
--error 1264
update t1 set c2 = c1;
insert into t1(c1) values(-128.50001);
--error 1264
update t1 set c2 = c1 where c1 < 0;


insert into t1(c1) values(32765.5);
insert into t1(c1) values(32766.5);
insert into t1(c1) values(32767);
insert into t1(c1) values(32767.4);
insert into t1 select -c1, c2, c3, c4, c5, c6 from t1 where c1 > 129;
insert into t1 (c1) values(-32768);
insert into t1 (c1) values(-32768.4);
insert into t1 (c1) values(-32768.5);
insert into t1(c1) values(-32768.501);
### 32767.4和-32768.501可以cast到smallint范围内, 即[-32768, 32767]
update t1 set c3 = c1;
### 32767.5和-32768.51 cast到smallint以后超出范围
insert into t1(c1) values(32767.5);
--error 1264
update t1 set c3 = c1;
insert into t1(c1) values(-32768.51);
--error 1264
update t1 set c3 = c1 where c1 < 0;


insert into t1(c1) values(8388605.5);
insert into t1(c1) values(8388606.5);
insert into t1(c1) values(8388607);
insert into t1(c1) values(8388607.2);
insert into t1 select -c1, c2, c3, c4, c5, c6 from t1 where c1 > 32770;
insert into t1 (c1) values(-8388608);
insert into t1 (c1) values(-8388608.4);
insert into t1 (c1) values(-8388608.5);
### 8388607.2和-8388608.5可以cast到mediumint范围内, 即[-8388608, 8388607]
update t1 set c4 = c1;
### 8388607.3和-8388608.50001 cast到mediumint以后超出范围
insert into t1(c1) values(8388607.3);
--error 1264
update t1 set c4 = c1;
insert into t1(c1) values(-8388608.50001);
--error 1264
update t1 set c4 = c1 where c1 < 0;


insert into t1(c1) values(2147483581.5);
insert into t1(c1) values(2147483582.5);
insert into t1(c1) values(2147483583.5);
insert into t1(c1) values(-2147483773.5);
insert into t1(c1) values(-2147483774.5);
insert into t1(c1) values(-2147483775.5);
insert into t1(c1) values(-2147483776);
### 2147483583和-2147483776可以cast到int范围内, 即[-2147483648, 2147483647]
update t1 set c5 = c1;
### 2147483584和-2147483777 cast到int以后超出范围
insert into t1(c1) values(2147483584);
--error 1264
update t1 set c5 = c1;
insert into t1(c1) values(-2147483777);
--error 1264
update t1 set c5 = c1 where c1 < 0;


insert into t1(c1) values(9223372586610590719.5);
insert into t1(c1) values(-9223372586610590719.5);
### 9223372586610590719.5和-9223372586610590719.5可以cast到bigint范围内, 即[-9223372036854775808, 9223372036854775807]
update t1 set c6 = c1;
### 9223372586610590720.5和-9223372586610590720.5 cast到bigint以后超出范围
insert into t1(c1) values(9223372586610590720.5);
--error 1264
update t1 set c6 = c1;
insert into t1(c1) values(-9223372586610590720.5);
--error 1264
update t1 set c6 = c1 where c1 < 0;

insert into t1(c1) values(10223372586610590720.5);
insert into t1(c1) values(-10223372586610590720.5);
select c1, c2, c3, c4, c5, c6, cast(c1 as signed) from t1;




--echo ## test cast float to unsigned int
drop table t1;
create table t1(c1 float, c2 tinyint unsigned, c3 smallint unsigned, c4 mediumint unsigned, c5 int unsigned, c6 bigint unsigned);
insert into t1(c1) values(-0.5);
insert into t1(c1) values(0);
insert into t1(c1) values(0.5);
insert into t1(c1) values(1.5);
insert into t1(c1) values(2.5);
insert into t1(c1) values(3.5);
insert into t1(c1) values(99.5);
insert into t1(c1) values(100.5);
insert into t1(c1) values(255);
insert into t1(c1) values(255.4);
### -0.5和255.4可以cast到tinyint unsigned范围内, 即[0, 255]
update t1 set c2 = c1;
### -0.50001和255.5 cast到tinyint以后超出范围
insert into t1(c1) values(-0.50001);
--error 1264
update t1 set c2 = c1;
select c1, c2, c3, c4, c5, c6, cast(c1 as unsigned) from t1;
delete from t1;
insert into t1(c1) values(255.5);
--error 1264
update t1 set c2 = c1;


delete from t1;
insert into t1(c1) values(-0.5);
insert into t1(c1) values(0);
insert into t1(c1) values(0.5);
insert into t1(c1) values(1.5);
insert into t1(c1) values(2.5);
insert into t1(c1) values(3.5);
insert into t1(c1) values(99.5);
insert into t1(c1) values(100.5);
insert into t1(c1) values(65535);
insert into t1(c1) values(65535.4);
### -0.5和65535.4可以cast到smallint unsigned范围内, 即[0, 65535]
update t1 set c3 = c1;
### -0.50001和65535.5 cast到smallint unsigned以后超出范围
insert into t1(c1) values(-0.50001);
--error 1264
update t1 set c3 = c1;
select c1, c2, c3, c4, c5, c6, cast(c1 as unsigned) from t1;
delete from t1;
insert into t1(c1) values(65535.5);
--error 1264
update t1 set c3 = c1;


delete from t1;
insert into t1(c1) values(-0.5);
insert into t1(c1) values(0);
insert into t1(c1) values(0.5);
insert into t1(c1) values(1.5);
insert into t1(c1) values(2.5);
insert into t1(c1) values(3.5);
insert into t1(c1) values(99.5);
insert into t1(c1) values(100.5);
insert into t1(c1) values(16777215);
insert into t1(c1) values(16777215.4);
### -0.5和16777215.4可以cast到mediumint unsigned范围内, 即[0, 16777215]
update t1 set c4 = c1;
### -0.50001和16777215.5 cast到mediumint unsigned以后超出范围
insert into t1(c1) values(-0.50001);
--error 1264
update t1 set c4 = c1;
select c1, c2, c3, c4, c5, c6, cast(c1 as unsigned) from t1;
delete from t1;
insert into t1(c1) values(16777215.5);
--error 1264
update t1 set c4 = c1;



delete from t1;
insert into t1(c1) values(-0.5);
insert into t1(c1) values(0);
insert into t1(c1) values(0.5);
insert into t1(c1) values(1.5);
insert into t1(c1) values(2.5);
insert into t1(c1) values(3.5);
insert into t1(c1) values(99.5);
insert into t1(c1) values(100.5);
insert into t1(c1) values(4294967167);
### -0.4294967167可以cast到int unsigned范围内, 即[0, 4294967295]
update t1 set c5 = c1;
### -0.50001和4294967168 cast到int unsigned以后超出范围
insert into t1(c1) values(-0.50001);
--error 1264
update t1 set c5 = c1;
select c1, c2, c3, c4, c5, c6, cast(c1 as unsigned) from t1;
delete from t1;
insert into t1(c1) values(4294967168);
--error 1264
update t1 set c5 = c1;

delete from t1;
insert into t1(c1) values(-0.5);
insert into t1(c1) values(0);
insert into t1(c1) values(0.5);
insert into t1(c1) values(1.5);
insert into t1(c1) values(2.5);
insert into t1(c1) values(3.5);
insert into t1(c1) values(99.5);
insert into t1(c1) values(100.5);
insert into t1(c1) values(18446743523953736703);
### -0.5和18446743523953736703可以cast到bigint unsigned范围内, 即[0, 18446744073709551615]
update t1 set c6 = c1;
### -0.50001和18446743523953736704 cast到bigint unsigned以后超出范围
insert into t1(c1) values(-0.50001);
--error 1264
