CREATE TABLE `sb` (
  `col_bigint_signed` bigint(20) DEFAULT NULL,
  `col_date` date DEFAULT NULL,
  `col_timestamp` timestamp NULL DEFAULT NULL
);
insert into sb values(1, '2000-01-01', '2000-05-04 17:37:59');
SELECT col_date, col_timestamp, BINARY IFNULL( STR_TO_DATE( DATE_FORMAT( col_timestamp , '%Y-%m-%d %H:%i:%s.%f' ) , '%Y-%m-%d %H:%i:%s.%f' ), col_date ) from sb;

drop table sb;

--echo #
select IFNULL(-1.7976931348623157E200, 0.5252138124537323) from dual;

--echo #bug:
--disable_warnings
drop table if exists tbl;
--enable_warnings
create table tbl (c1 json, c2 varchar(10));
INSERT INTO tbl VALUES (json_object( '"a"', 1 ), "abcdefgh");
INSERT INTO tbl VALUES ('{ "firstName" : "Fred", "lastName" : "Flintstone" }', "abcdefg");
select cast(ifnull(c1, 1) as CHAR) from tbl;
select ifnull(cast(c1 as CHAR), 0) from tbl;
drop table tbl;

--echo #bug:
create table tbl as select ifnull(cast(1 as decimal(10, 7)), cast(2 as decimal(12, 5))) as c from dual;
desc tbl;
select * from tbl;
drop table tbl;

create table tbl (
  c1 tinyint, c2 smallint, c3 mediumint, c4 int, c5 bigint,
  c6 tinyint unsigned, c7 smallint unsigned, c8 mediumint unsigned, c9 int unsigned, c10 bigint unsigned);

--echo "same type"
create table sb as select ifnull(c1, c1), ifnull(c5, c5), ifnull(c6, c6), ifnull(c10, c10) from tbl;
desc sb;
drop table sb;

--echo "same type class"
create table sb as select ifnull(c1, c2), ifnull(c4, c5), ifnull(c6, c7), ifnull(c9, c10) from tbl;
desc sb;
drop table sb;

--echo "diff type1"
create table sb as select ifnull(c1, c6), ifnull(c2, c7), ifnull(c3, c8), ifnull(c4, c9), ifnull(c5, c10) from tbl;
desc sb;
drop table sb;

--echo "diff type2"
create table sb as select ifnull(c1, c10), ifnull(c2, c9), ifnull(c3, c8), ifnull(c4, c7), ifnull(c5, c6) from tbl;
desc sb;
drop table sb;

drop table tbl;

--echo #array type
create table tbl (c1 array(int), c2 array(double));
insert into tbl values (array(1,2,3), array(1.1));
insert into tbl values (NULL, array(2.2));
select ifnull(c1, c2) from tbl;
create table sb as select ifnull(c1, c2) from tbl;
desc sb;
drop table sb;
drop table tbl;
