# owner: yuchen.wyc
# owner group: SQL2
# Test of functions TO_BASE64

#null
SELECT TO_BASE64(NULL);

#empty
SELECT TO_BASE64('');

#single char with case sensitive
SELECT TO_BASE64('a');
SELECT TO_BASE64('A');
SELECT TO_BASE64('0');
SELECT TO_BASE64('1');
SELECT TO_BASE64('@');
SELECT TO_BASE64('#');
SELECT TO_BASE64(' ');

#normal english word
SELECT TO_BASE64('abcdefg');
SELECT TO_BASE64('abcdefg ');
SELECT TO_BASE64('Good morning');
SELECT TO_BASE64('Good evening');

#ip like
SELECT TO_BASE64('255.255.255.255');
SELECT TO_BASE64('192.168.1.100');
SELECT TO_BASE64('30.32.204.180');

#email like
SELECT TO_BASE64('emily@163.com');
SELECT TO_BASE64('mike@sohu.com');
SELECT TO_BASE64('joey@sina.com');

#chinese word
SELECT TO_BASE64('阿里巴巴');
SELECT TO_BASE64('阿里巴巴 ');
SELECT TO_BASE64('淘宝');
SELECT TO_BASE64('淘宝 ');

#type cast
SELECT TO_BASE64(0);
SELECT TO_BASE64(100);
SELECT TO_BASE64(3.1415);
SELECT TO_BASE64(TRUE);
SELECT TO_BASE64(cast("2010-10-01 12:34:56" as datetime));

#diff with MySQL
#
SELECT TO_BASE64(REPEAT('a', 75));
SELECT length(TO_BASE64(REPEAT('a', 75)));

SELECT TO_BASE64(REPEAT('a', 57));
SELECT TO_BASE64(REPEAT('a', 57 * 2));
SELECT TO_BASE64(REPEAT('a', 57 * 2 + 1));

#test with other collation
SELECT TO_BASE64(CONVERT('你好' USING UTF16)) FROM DUAL;
SELECT TO_BASE64(123);
SELECT TO_BASE64(2021-01-01);
SELECT TO_BASE64(TO_BASE64(CONVERT('你好' USING UTF16)));
SELECT TO_BASE64(TO_BASE64('你好'));
SELECT TO_BASE64(TO_BASE64(CONVERT('adcd' USING UTF16)));
SELECT TO_BASE64(TO_BASE64('adcd'));

SELECT TO_BASE64(CONVERT('ABC' USING UTF16));
SELECT TO_BASE64(TO_BASE64(CONVERT('ABC' USING UTF16)));
SELECT TO_BASE64(CONVERT(TO_BASE64(CONVERT('ABC' USING UTF16)) USING UTF8));
SELECT TO_BASE64(CONVERT(TO_BASE64(CONVERT('ABC' USING UTF16)) USING UTF16));
--disable_warnings
DROP TABLE IF EXISTS t;
--enable_warnings
CREATE TABLE t AS SELECT TO_BASE64(REPEAT('A',65)) AS C1;
SELECT COLUMN_TYPE='varchar(2768)' FROM  INFORMATION_SCHEMA.COLUMNS WHERE TABLE_SCHEMA='test' AND TABLE_NAME='t';
SELECT LENGTH(C1) FROM t;
DROP TABLE t;
--disable_warnings
DROP TABLE IF EXISTS t1;
--enable_warnings
CREATE TABLE t1 AS SELECT TO_BASE64(REPEAT('A',655536)) AS C1;
SELECT COLUMN_TYPE='longtext' FROM  INFORMATION_SCHEMA.COLUMNS WHERE TABLE_SCHEMA='test' AND TABLE_NAME='t1';
SELECT LENGTH(C1) FROM t1;
--disable_warnings
DROP TABLE IF EXISTS t1;
CREATE TABLE t1 (a varchar(20));
INSERT INTO t1 VALUES('MQ==');
SELECT TO_BASE64(a), HEX(a) FROM t1;
DROP TABLE t1;

connect (syscon, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection syscon;
alter system set _rowsets_enabled=true tenant=sys;
alter system set _rowsets_enabled=true tenant=all_user;
alter system set _rowsets_enabled=true tenant=all_meta;

