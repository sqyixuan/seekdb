# 测试 mysql 模式下的 day 表达式
--disable_warnings
SELECT DAY('2021-08-09');
SELECT DAY('2021-11-31');
SELECT DAY('2021-02-28');
SELECT DAY('2021-02-28');

SELECT DAY('2000-02-29');
SELECT DAY('1900-02-29');

SELECT DAY('2012-02-29');
SELECT DAY('2013-02-29');

select DAY(20130229);
select DAY(20130228);

select DAY(NULL);
select TIMESTAMP(b'0011001000110000001100100011000100110000001100010011000000110010');
select DAY(b'0011001000110000001100100011000100110000001100010011000000110010');

--enable_warnings

--disable_warnings
drop table if exists integer_signed_type_table;
--enable_warnings
create table integer_signed_type_table (c1 TINYINT,c2 SMALLINT,c3 MEDIUMINT ,c4 INT,c5 BIGINT);
insert into integer_signed_type_table values(-128,-32768,-8388608,-2147483648,-9223372036854775808);
insert into integer_signed_type_table values(127,32767,8388607,2147483647,	9223372036854775807);
insert into integer_signed_type_table values(123,1231,210102,20210102,20210102);
insert into integer_signed_type_table values(123,1231,210229,20210229,20210229);
insert into integer_signed_type_table values(123,1231,210228,20210228,20210228);
insert into integer_signed_type_table values(NULL,NULL,NULL,NULL,NULL);

select day(c1),day(c2),day(c3),day(c4),day(c5) from integer_signed_type_table;

--disable_warnings
drop table if exists integer_unsigned_type_table;
--enable_warnings
create table integer_unsigned_type_table (c1 TINYINT unsigned,c2 SMALLINT unsigned,c3 MEDIUMINT unsigned,c4 INT unsigned,c5 BIGINT unsigned);
insert into integer_unsigned_type_table values(0,0,0,0,0);
insert into integer_unsigned_type_table values(255,65535,16777215,4294967295,18446744073709551615);
insert into integer_unsigned_type_table values(123,1231,210102,20210102,20210102);
insert into integer_unsigned_type_table values(123,1231,210229,20210229,20210229);
insert into integer_unsigned_type_table values(123,1231,210228,20210228,20210228);
insert into integer_unsigned_type_table values(NULL,NULL,NULL,NULL,NULL);

select day(c1),day(c2),day(c3),day(c4),day(c5) from integer_unsigned_type_table;

--disable_warnings
drop table if exists decimal_and_float_type_table;
--enable_warnings
create table decimal_and_float_type_table (c1 decimal(20,6),c2 FLOAT,c3 DOUBLE);
insert into decimal_and_float_type_table values(0.0,0.0,0.0);
insert into decimal_and_float_type_table values(123.123,123.123,123.123);
insert into decimal_and_float_type_table values(210809010203.123456,210809010203.123456,210809010203.123456);
insert into decimal_and_float_type_table values(20210809010203.123456,20210809010203.123456,20210809010203.123456);
insert into decimal_and_float_type_table values(20210809010203,20210809010203,20210809010203);
insert into decimal_and_float_type_table values(NULL,NULL,NULL);

select day(c1),day(c2),day(c3) from decimal_and_float_type_table;

--disable_warnings
drop table if exists date_type_table;
--enable_warnings
create table date_type_table (c1 DATE,c2 TIMESTAMP,c3 DATETIME);
insert into date_type_table values('2012-02-03','2012-02-03 01:01:01.123456','2012-02-03 01:01:01.123456');
insert into date_type_table values('2012-02-04','2012-02-04','2012-02-04');
insert into date_type_table values(120205,120205,120205);
insert into date_type_table values('0000-00-00','0000-00-00','0000-00-00');
select day(c1),day(c2),day(c3) from date_type_table;

--disable_warnings
drop table if exists string_type_table_one;
--enable_warnings
create table string_type_table_one (c1 CHAR(30) CHARACTER SET utf8mb4,c2 VARCHAR(30) CHARACTER SET utf8mb4,c3 BINARY(30),c4 VARBINARY(30));
insert into string_type_table_one values('210102','210102','210102','210102');
insert into string_type_table_one values('20210102','20210102','20210102','20210102');
insert into string_type_table_one values('2021-01-02','2021-01-02','2021-01-02','2021-01-02');
insert into string_type_table_one values('20210102000000.1','20210102000000.1','20210102000000.1','20210102000000.1');
insert into string_type_table_one values('2021-01-02T01:02:03.123','2021-01-02T01:02:03.123','2021-01-02T01:02:03.123','2021-01-02T01:02:03.123');

select HEX(c1),HEX(c2),HEX(c3),HEX(c4) from string_type_table_one;
select day(c1),day(c2),day(c3),day(c4) from string_type_table_one;

--disable_warnings
drop table if exists string_type_table_one;
--enable_warnings
create table string_type_table_one (c1 CHAR(30) CHARACTER SET gbk,c2 VARCHAR(30) CHARACTER SET gbk,c3 BINARY(30),c4 VARBINARY(30));
insert into string_type_table_one values('210102','210102','210102','210102');
insert into string_type_table_one values('20210102','20210102','20210102','20210102');
insert into string_type_table_one values('2021-01-02','2021-01-02','2021-01-02','2021-01-02');
insert into string_type_table_one values('20210102000000.1','20210102000000.1','20210102000000.1','20210102000000.1');
insert into string_type_table_one values('2021-01-02T01:02:03.123','2021-01-02T01:02:03.123','2021-01-02T01:02:03.123','2021-01-02T01:02:03.123');

select HEX(c1),HEX(c2),HEX(c3),HEX(c4) from string_type_table_one;
select day(c1),day(c2),day(c3),day(c4) from string_type_table_one;

--disable_warnings
drop table if exists string_type_table_one;
--enable_warnings
create table string_type_table_one (c1 CHAR(30) CHARACTER SET utf16,c2 VARCHAR(30) CHARACTER SET utf16,c3 BINARY(30),c4 VARBINARY(30));
insert into string_type_table_one values('210102','210102','210102','210102');
insert into string_type_table_one values('20210102','20210102','20210102','20210102');
insert into string_type_table_one values('2021-01-02','2021-01-02','2021-01-02','2021-01-02');
insert into string_type_table_one values('20210102000000.1','20210102000000.1','20210102000000.1','20210102000000.1');
insert into string_type_table_one values('2021-01-02T01:02:03.123','2021-01-02T01:02:03.123','2021-01-02T01:02:03.123','2021-01-02T01:02:03.123');

select HEX(c1),HEX(c2),HEX(c3),HEX(c4) from string_type_table_one;
select day(c1),day(c2),day(c3),day(c4) from string_type_table_one;

--disable_warnings
drop table if exists string_type_table_one;
--enable_warnings
create table string_type_table_one (c1 CHAR(30) CHARACTER SET gb18030,c2 VARCHAR(30) CHARACTER SET gb18030,c3 BINARY(30),c4 VARBINARY(30));
insert into string_type_table_one values('210102','210102','210102','210102');
insert into string_type_table_one values('20210102','20210102','20210102','20210102');
insert into string_type_table_one values('2021-01-02','2021-01-02','2021-01-02','2021-01-02');
insert into string_type_table_one values('20210102000000.1','20210102000000.1','20210102000000.1','20210102000000.1');
insert into string_type_table_one values('2021-01-02T01:02:03.123','2021-01-02T01:02:03.123','2021-01-02T01:02:03.123','2021-01-02T01:02:03.123');

select HEX(c1),HEX(c2),HEX(c3),HEX(c4) from string_type_table_one;
select day(c1),day(c2),day(c3),day(c4) from string_type_table_one;

--disable_warnings
drop table if exists string_type_table_two;
--enable_warnings
create table string_type_table_two (c1 TINYBLOB,c2 TINYTEXT,c3 BLOB,c4 TEXT,c5 MEDIUMBLOB,c6 MEDIUMTEXT,c7 LONGBLOB,c8 LONGTEXT);
insert into string_type_table_two values('210102','210102','210102','210102','210102','210102','210102','210102');
insert into string_type_table_two values('20210102','20210102','20210102','20210102','20210102','20210102','20210102','20210102');
insert into string_type_table_two values('2021-01-02','2021-01-02','2021-01-02','2021-01-02','2021-01-02','2021-01-02','2021-01-02','2021-01-02');
insert into string_type_table_two values('2021-01-02T01:02:03.123','2021-01-02T01:02:03.123','2021-01-02T01:02:03.123','2021-01-02T01:02:03.123','2021-01-02T01:02:03.123','2021-01-02T01:02:03.123','2021-01-02T01:02:03.123','2021-01-02T01:02:03.123');

select hex(c1),hex(c2),hex(c3),hex(c4),hex(c5),hex(c6),hex(c7),hex(c8) from string_type_table_two;
select day(c1),day(c2),day(c3),day(c4),day(c5),day(c6),day(c7),day(c8) from string_type_table_two;

--disable_warnings
drop table if exists enum_type_table;
--enable_warnings
create table enum_type_table (c1 ENUM('210102', '20210102', '2021-01-02','20210102000000.1','2021-01-02T01:02:03.123'));
insert into enum_type_table values('210102');
insert into enum_type_table values('20210102');
insert into enum_type_table values('2021-01-02');
insert into enum_type_table values('20210102000000.1');
insert into enum_type_table values('2021-01-02T01:02:03.123');
select day(c1) from enum_type_table;

--disable_warnings
drop table if exists set_type_table;
--enable_warnings

CREATE TABLE set_type_table (c1 SET('210102', '20210102', '2021-01-02','20210102000000.1','2021-01-02T01:02:03.123'));
insert into set_type_table values('210102');
insert into set_type_table values('20210102');
insert into set_type_table values('2021-01-02');
insert into set_type_table values('20210102000000.1');
insert into set_type_table values('2021-01-02T01:02:03.123');
insert into set_type_table values('210102,20210102,2021-01-02T01:02:03.123');
select day(c1) from set_type_table;
