--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: xiaoyi.xy
# owner group: SQL3
# description: OUR GOAL: Make all this simple and effective!
--disable_warnings
drop table if exists t1;
--enable_warnings
# set-up
create table t1 (id int primary key, v varchar(256));
insert into t1 values (0, 'abc'), (1, null), (2, 'def'), (3, null), (4, 'xyz');
select * from t1;

# normal compare
select * from t1 where (id) in ((1), (2));
select * from t1 where (id, v) in ((1, null), (2, 'def'));
# not row
select * from t1 where (id) = (1) or (id) = (2); 
select * from t1 where (id) = (1) or (id) = (2);

select * from t1 where (id, v) = (1, null) or (id, v) = (2, 'def');
select * from t1 where (id, v) = (2, '');
select * from t1 where (id, v) = (2, 'def');
select * from t1 where (id, v) > (2, 'def');
select * from t1 where (id, v) >= (2, 'def');
select * from t1 where (id, v) < (2, 'def');
select * from t1 where (id, v) <= (2, 'def');
select * from t1 where (id, v) != (2, 'def');

# compare with null values
select * from t1 where (1, null) in ((id, v));
select * from t1 where (1, null) = (id, v);
# not row
select * from t1 where (null) = (v); 
select * from t1 where (null) = (v);

select (id, v) = (2, null) from t1;
select * from t1 where (id, v) = (3, null);
select * from t1 where (id, v) > (3, null);
select * from t1 where (id, v) >= (3, null);
select * from t1 where (id, v) < (3, null);
select * from t1 where (id, v) <= (3, null);
select * from t1 where (id, v) != (3, null);

# exception
--error 1241 
select * from t1 where (id, v) in ((1), (2));
--error 1241
select * from t1 where (id, v) in ((1, null), (2));
--error 1241
select * from t1 where (id, v) = (1);

# tear-down
drop table t1;

