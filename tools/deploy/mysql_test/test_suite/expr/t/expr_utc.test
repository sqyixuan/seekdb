# Test of functions

set timestamp = 1600000000;
select utc_time;
select utc_time();
--error 1064
select utc_time('1');
--error 1064
select utc_time(-1);
select utc_time(0);
select utc_time(1);
select utc_time(2);
select utc_time(3);
select utc_time(4);
select utc_time(5);
select utc_time(6);
--error 1426
select utc_time(7);
--error 1426
select utc_time(10);
--disable_warnings
drop table if exists t;
drop view if exists v;
--enable_warnings
create table t as select utc_time c1, utc_time(0) c2, utc_time(6) c3;
create view v as select utc_time c1, utc_time(0) c2, utc_time(6) c3;
desc t;
desc v;
show create view v;
select * from t;
select * from v;
drop table t;
drop view v;
## generate column not allowed
--error 3102
create table t(c1 int, c2 time generated always as (utc_time()));

select utc_date;
select utc_date();
--error 1064
select utc_date('1');
--error 1064
select utc_date(-1);
--error 1064
select utc_date(0);
--error 1064
select utc_date(1);
create table t as select utc_date c1, utc_date() c2;
create view v as select utc_date c1, utc_date() c2;
desc t;
desc v;
show create view v;
select * from t;
select * from v;
drop table t;
drop view v;
## generate column not allowed
--error 3102
create table t(c1 int, c2 time generated always as (utc_date()));
