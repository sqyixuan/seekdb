--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: sean.yyj
# owner group: sql3

--disable_abort_on_error
--result_format 3

select compress(repeat('a', 1000));
select hex(compress(repeat('a', 1000)));
select uncompressed_length(compress(repeat('a', 1000)));
select uncompress(compress(repeat('a', 1000)));

select compress(123);
select hex(compress(123));
select uncompressed_length(compress(123));
select uncompress(compress(123));

select compress('');
select uncompressed_length(compress(''));
select uncompress(compress(''));

select compress(null);
select uncompressed_length(null);
select uncompress(null);

select compress('');
select uncompressed_length('');
select uncompress('');

--echo # illegal compress header
select uncompressed_length('a');
select uncompress('a');

--echo # too large data
select uncompressed_length(0xffffffff0000);
select uncompress(0xffffffff0000);

--echo # corrucpted data
select uncompressed_length(0x01000000123);
select uncompress(0x01000000123);

--disable_warnings
drop table if exists t1;
drop table if exists t_compress;
drop table if exists t_uncompressed_length;
drop table if exists t_uncompress;
--enable_warnings

create table t1 (c1 varchar(100));
create table t_compress as select compress(c1) c1 from t1;
create table t_uncompressed_length as select uncompressed_length(c1) c1 from t1;
create table t_uncompress as select uncompress(c1) c1 from t1;

desc t_compress;
desc t_uncompressed_length;
desc t_uncompress;
drop table t1;
drop table t_compress;
drop table t_uncompressed_length;
drop table t_uncompress;
