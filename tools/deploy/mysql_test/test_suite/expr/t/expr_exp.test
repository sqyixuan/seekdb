--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: dingjincheng.djc
# owner group: SQL1
# Test of functions
--result_format 4

#仅仅有select list的情况
select exp(1);
select exp(0);
select exp(-1);
select exp(100);
select exp("1");
select exp('a');
use test;
drop table if exists test.na_test_table;
#从表中查询列，其中的列是各种类型的参数的情况
create table na_test_table(a bit(8), b char(2), c int unsigned, d int, e float, f double, g decimal(5,2), h int, i char);
insert into na_test_table values(2, "ac", 2, -1, 1.0, 1.234, 1.234, null, 'a');
select exp(a), exp(b), exp(c), exp(d), exp(e), exp(f), exp(h), exp(i) from na_test_table;
truncate table test.na_test_table;
#decimal和double区分一下
insert into na_test_table values(12, "12", 1, 2, -0.1, 2.32, 2.324, null, 'b');
select exp(a), exp(b), exp(c), exp(d), exp(e), exp(f), exp(h), exp(i) from na_test_table;
#exp中含有算数表达式
select exp(a+c+f) from na_test_table;
#exp中的参数是null不确定的情况
select exp(a+c+h) from na_test_table;
drop table if exists test.na_test_table;
