#owner: fy373789
#owner group: SQL2
#description: Verify the correctness of LIKE when SQL mode is set to NO_BACKSLASH_ESCAPES.
# tags: NO_BACKSLASH_ESCAPES_LIKE

# 测试组
SET sql_mode = 'NO_BACKSLASH_ESCAPES';

# 测试\转义是否失效
SELECT _latin1'a\bc' LIKE _latin1'a\%' AS col1, _utf8mb4'a\bc' LIKE _utf8mb4'a\%' AS col2;

# 测试双写转义是否仍有效
SELECT 'abc''' like 'a%';
SELECT 'abc''' like 'ab''c%';
SELECT 'abc' like 'ab''%';

# 测试escape语法优先级是否更高
SELECT 'abc%' LIKE 'abc#%' ESCAPE '#';

--disable_warnings
drop table if exists t1, t2;
--enable_warnings
create table t1(c1 int primary key, c2 varchar(50));
insert into t1 values(0, 'a');
insert into t1 values(1, 'ab');
insert into t1 values(2, 'abc');
insert into t1 values(3, 'aa');
insert into t1 values(4, 'a\');
insert into t1 values(5, 'ab''c');
insert into t1 values(6, 'abc%');
select * from t1;

# 
CREATE TABLE `t2` (
  `a` int(11) NOT NULL AUTO_INCREMENT
) CHARSET = utf8mb4;
insert into t2 values(1);
insert into t2 values(6);
select * from t2 where a not like _gb18030'a\\\\b';

set _enable_rich_vector_format = false;
SELECT t1.c2 LIKE _latin1'a\%' AS col1, t1.c2 LIKE _utf8mb4'a\%' AS col2 from t1;
SELECT t1.c2 like 'ab''c%' from t1;
SELECT t1.c2 LIKE 'abc#%' ESCAPE '#' from t1;

set _enable_rich_vector_format = true;
SELECT t1.c2 LIKE _latin1'a\%' AS col1, t1.c2 LIKE _utf8mb4'a\%' AS col2 from t1;
SELECT t1.c2 like 'ab''c%' from t1;
SELECT t1.c2 LIKE 'abc#%' ESCAPE '#' from t1;

# 设回默认，以免影响其他case
SET sql_mode = 'STRICT_ALL_TABLES,NO_ZERO_IN_DATE,NO_AUTO_CREATE_USER';