--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: xiaoyi.xy
# owner group: SQL1

# 不要从farm删掉这个case!
# 这些函数都是在ob 1.x版本中为了支持少量oracle功能引入的，同时为了和mysql函数相区分，特意加了ora_前缀。
# 这些函数都有真实内部业务需求，同时也包含在我们已经对外部业务发布的版本中，所以这些函数都是完全不能动的，否则升级兼容性无法保证。

--enable_sorted_result
--result_format 4

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1(a decimal(5,2), b int);
insert into t1 values (1.23, 1), (2.34, 2);
select a, ora_trunc(a) from t1;
select b, ora_decode(b, 1, 'one', 2, 'two') from t1;

--disable_warnings
drop table if exists t1;
--enable_warnings

