## charset and collation
--disable_warnings
drop table if exists test;
drop table if exists test1;
--enable_warnings

create table test (pk bigint(20) not null, col_varchar_16_utf16 varchar(16) null);
create table test1 (pk bigint(20) not null, col_varchar_16_utf16 varchar(16) charset utf16 null);
insert into test values(8, 'i');
insert into test1 values(8, 'i');

select pk ,col_varchar_16_utf16  from test  WHERE  col_varchar_16_utf16 LIKE 'i';
select pk ,col_varchar_16_utf16  from test1  WHERE  col_varchar_16_utf16 LIKE 'i';

--disable_warnings
drop table if exists test;
drop table if exists test1;
--enable_warnings

##bug:

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1(c1 varchar(20), c2 int);

insert into t1 values('a3c', 123), ('d3f', 456), ('abd', 135), ('acc', 222), ('dce', 234), ('abe', 235), ('%3%',245);

select * from t1 where c1 like ""''"";

select * from t1 where c1 like ''""''''"" ;

select * from t1 where c1 like ""''"" ESCAPE ""''"";

select * from t1 where c2 like "1" "3" '5';

select * from t1 where c2 like "2" "4" '5';

select * from t1 where c2 like "1" "2" '3';

select * from t1 where c1 like "%"''"%";

select * from t1 where c1 like "%"''"%" ESCAPE ''"?"'';

select * from t1 where c1 like ''"%"'3'"%"'';

select * from t1 where c1 like ''"?%"'3'"?%"'' ESCAPE ''""''"?"''"";

select * from t1 where c1 like ''""''''"" ;

select * from t1 where c1 like "%"''""''""''""''""''""''""''""''""''""''""''"%" ESCAPE ""''""''""''""''""''""''""''""''""''""''""''"" ;

select * from t1 where c1 not like ""''"";

select * from t1 where c1 not like ''""''''"" ;

select * from t1 where c2 not like "1" "3" '5';

select * from t1 where c2 not like "2" "4" '5';

select * from t1 where c2 not like "1" "2" '3';

select * from t1 where c1 not like ""''"" ESCAPE ""''"";

select * from t1 where c1 not like "%"''"%";

select * from t1 where c1 not like "%"''"%" ESCAPE ''"?"'';

select * from t1 where c1 not like ''"%"'3'"%"'';

select * from t1 where c1 not like ''"?%"'3'"?%"'' ESCAPE ''""''"?"''"";

select * from t1 where c1 not like "%"''""''""''""''""''""''""''""''""''""''""''"%" ESCAPE ""''""''""''""''""''""''""''""''""''""''""''"" ;

--error 1210
select * from t1 where c1 like "%"''"%" ESCAPE '?'""'?';

--error 1210
select * from t1 where c1 not like "%"''"%" ESCAPE '?'""'?';

--error 1210
select * from t1 where c1 like "%"''"%" ESCAPE ''"%"''""''""'%';

--error 1210
select * from t1 where c1 not like "%"''"%" ESCAPE ''"%"''""''""'%';

drop table t1;

##bugfix: 
create table t1(c1 varchar(100) collate utf8mb4_bin);
insert into t1 values('abcd');
insert into t1 values('aad');
select c1, c1 like 'abcd%abcd' collate utf8mb4_bin from t1;
select c1, c1 like 'abc%bcd' collate utf8mb4_bin from t1;
select c1, c1 like 'ab%cd' collate utf8mb4_bin from t1;
select c1, c1 like 'a%d' collate utf8mb4_bin from t1;
select c1, c1 like 'a%d%d' collate utf8mb4_bin from t1;
drop table t1;

