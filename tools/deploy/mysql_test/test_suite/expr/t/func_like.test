--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: yibo.tyf
#owner group: sql1
# tags: optimizer
#description: test like func
#create table txxxxxxx (a int)
--disable_warnings
drop table if exists t1;
drop table if exists t0;
--enable_warnings
##
#--real_sleep 1
create table t1 (a varchar(10) primary key, b int default 0);
#--real_sleep 1
insert into t1 (a) values ('a'),('abc'),('abcd'),('hello'),('test');
--replace_regex /Plan signature: [0-9]*/Plan signature/
--disable_result_log
explain  select * from t1 where a like 'abc%';
--enable_result_log
--replace_regex /Plan signature: [0-9]*/Plan signature/
--disable_result_log
explain  select * from t1 where a like concat('abc','%');
--enable_result_log
select * from t1 where a like 'abc%';
select * from t1 where a not like  'abc%';
select * from t1 where a like concat('abc','%');
select * from t1 where a like 'ABC%';
select * from t1 where a not like 'ABC%';
select * from t1 where a like 'test%';
select * from t1 where a like 'te_t';
#
##
## The following will test the Turbo Boyer-Moore code
##
select * from t1 where a like '%a%';
select * from t1 where a like '%abcd%';
select * from t1 where a like '%abc\d%';
#
## bug 5846697
#
select * from t1 where a like '%b%c%';
select * from t1 where a like '%c%b%';
select * from t1 where a like '_b%c_';
select * from t1 where a like '_c%b_';

drop table t1;

#--real_sleep 1
create table t1 (a varchar(10) primary key, b int default 0);
#--real_sleep 1
#
##
## Bug #2231
##
insert into t1 (a) values ('a'), ('a\\b');
select * from t1 where a like 'a\\%';
select * from t1 where a like 'a\\%' escape '#';
select * from t1 where a not like 'a\\%' escape '#';
select * from t1 where a like 'a\\%' escape '#' and a like 'a\\\\b';
select * from t1 where a like 'a\\%' escape '#' and a not like 'a\\\\b';
select * from t1 where a like 'a\\%' escape '#' or a not like 'a\\\\b';
#
