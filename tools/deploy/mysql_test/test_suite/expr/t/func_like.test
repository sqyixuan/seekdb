#--error 1235
INSERT v0 ( ) VALUES ( v2 > ( ( v2 , v2 ) IN ( SELECT DISTINCT v1 , ( SELECT v2 FROM v0 GROUP BY v1 ) AS v2 FROM v0 HAVING v2 IN ( ( SELECT v1 FROM v0 WHERE v1 = FALSE HAVING CASE WHEN v2 NOT LIKE 'x' THEN v1 ELSE v1 END ) , v2 ) ) AND v1 > - - - 7 ) , _GBK 'x' ) ;
select * from v0;
drop table v0;

