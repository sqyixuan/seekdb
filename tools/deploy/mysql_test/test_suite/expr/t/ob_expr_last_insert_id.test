# fix last_insert_id(null) bug.


--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1 (c1 int primary key auto_increment);
insert into t1 (c1) values (null);
insert into t1 (c1) values (null);

select last_insert_id() from dual;
select last_insert_id(null) from dual;
select last_insert_id() from dual;
select last_insert_id(10) from dual;
select last_insert_id('abc') from dual;
select last_insert_id() from dual;

drop table t1;
