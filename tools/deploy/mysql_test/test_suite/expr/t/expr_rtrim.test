## --enable_metadata
# metadata checked by eyes
select rtrim(null);

select rtrim('');
select length(rtrim(''));

select rtrim('  ');
select length(rtrim('  '));

select rtrim('a');
select length(rtrim('a'));
select rtrim('  a');
select length(rtrim('  a'));
select rtrim('a  ');
select length(rtrim('a  '));
select rtrim('  a  ');
select length(rtrim('  a  '));

select rtrim('中文');
select length(rtrim('中文'));
select rtrim('  中文');
select length(rtrim('  中文'));
select rtrim('中文  ');
select length(rtrim('中文  '));
select rtrim('  中文  ');
select length(rtrim('  中文  '));

--disable_warnings
create database if not exists test;
use test;

drop table if exists AllTypes;
--enable_warnings

CREATE TABLE AllTypes(
c_bool      BOOLEAN,
c_int       INTEGER,
c_char      CHAR(10),
c_varchar   VARCHAR(10),
c_binary    BINARY(10),
c_varbinary VARBINARY(10));

insert AllTypes values(true, 01, 'a', 'a', hex('a'), hex('a'));
insert AllTypes values(false, 2, '  a', '  a', hex('  a'), hex('  a'));
insert AllTypes values(false, 3, 'a  ', 'a  ', hex('a  '), hex('a  '));
insert AllTypes values(false, 3, '  a  ', '  a  ', hex('  a  '), hex('  a  '));

select rtrim(c_bool), rtrim(c_int), rtrim(c_char), rtrim(c_varchar), rtrim(c_binary), rtrim(c_varbinary) from AllTypes;
## --disable_metadata
