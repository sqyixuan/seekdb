--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#### owner: dingjincheng.djc
#### owner group: hangzhou sql group
#### description: test rand function

--disable_warnings
drop table if exists test;
--enable_warnings
create table test (i int);
insert into test values (1),(2),(3);
select rand(1) from test;
select rand(1) from test;
select rand(2) from test;
select rand(i) from test;

select * from test where rand(1) > 0.5;
select * from test where rand(1) > 0.5;
select * from test where rand(i) > 0.5;

select * from test order by rand(1);
select * from test order by rand(1);
select * from test order by rand(2);
select * from test order by rand(i);