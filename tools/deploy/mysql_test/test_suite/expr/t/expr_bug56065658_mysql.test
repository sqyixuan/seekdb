--disable_warnings
drop table if exists t0;
--enable_warnings

## 
create table t0(c1 int, c2 varchar(20));
insert into t0 values (1, 'ABCD');

--error 1411
SELECT BIN_TO_UUID(REPEAT('NULL', 60000), TRUE);
--error 1411
select * from t0 where bin_to_uuid(repeat(c2, 60000), true) = '7f9d04ae-61b3-4468-ac79-8ffcc984ab68';

drop table t0;