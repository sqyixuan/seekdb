# owner: linyi.cl
# owner group: sql3
# description: test fix bug 50526902
# 



--disable_warnings
drop table if exists t1,t2;
--enable_warnings

create table t1(c1 int);
insert into t1 values(1),(2),(3),(4);

create table t2(c1 DECIMAL(0));
insert into t2 values(0.123),(1e-30),(01),(-1),(-0.1),(01010);


--result_format 4
--explain_protocol 2
select * from t1 group by c1 having avg(c1) between 1 and 2.2;
select * from t1 group by c1 having avg(c1) + avg(c1) between 1 and 3.2;
select * from t1 group by c1 having avg(c1) + 1 between 1 and 3.2;
select * from t1 group by c1 having avg(c1) + sum(c1) between 1 and 3.2;

select c1 from t2 group by c1 having avg(c1) between 01010 mod -1.2 and 01010/0.8;


drop table t1,t2;
