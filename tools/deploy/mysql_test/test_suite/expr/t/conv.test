insert into t1 values(23, '100');
insert into t1 values(10, '-9223372036854775807');
insert into t1 values(-10, '9223372036854775807');

select conv(a, 10, 2) from t1;
select conv(b, 36, 2) from t1 where length(b) < 10;
select conv(b, 36, a) from t1 where length(b) < 10 and abs(a) <= 36 and abs(a)>=2;

drop table t1;
