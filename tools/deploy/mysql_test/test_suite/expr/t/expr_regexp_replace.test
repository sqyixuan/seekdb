--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#### owner: zongmei.zzm
#### owner group: sql1
#### description: 测试regexp_replace函数
# tags: expr, datatype

--result_format 4

--echo ================ expression regexp_replace ================
#normal test(optional params is default value(position = 1, nth_appearance = 0, match_parameter = 'c')
select regexp_replace('abcabc', 'a','d') from dual;
select regexp_replace('abcabc','abc','e') from dual;
select regexp_replace('阿里巴巴', '巴', '阿里') from dual;
select regexp_replace(123123, 123, 1) from dual;
select regexp_replace('123123', '123','1') from dual;
select regexp_replace(123.400000, 3.4, 1) from dual;
select regexp_replace('abcabc','abc',null) from dual;
select regexp_replace('阿里巴巴', '巴', null) from dual;
select regexp_replace(123123, 123, null) from dual;
--error 1139
select regexp_replace('abc', '','b') from dual;
select regexp_replace('abc', null, null) from dual;
select regexp_replace(null,'b', 'c') from dual;
select regexp_replace('', null,'') from dual;

select regexp_replace('abcabc', '.*','d') from dual;
select regexp_replace('abcabc', '.?','d') from dual;
select regexp_replace('abcabc', 'a*','d') from dual;
select regexp_replace('abcabe','ab.','ef') from dual;
select regexp_replace('阿里巴巴', '阿|里|巴|巴', '123') from dual;
select regexp_replace('abcdef', '[a-z]', '123') from dual;
select regexp_replace('11223311112', '1{2,4}', 'abc') from dual;
select regexp_replace('122absdsadas123', '[[:digit:]]{3}', null) from dual;
select regexp_replace('12312alipay.com123sadqwe', '[[:alpha:]]{6}\.[[:alpha:]]{3}', '支付宝') from dual;


# with optional params(position, nth_appearance, match_parameter)
select regexp_replace('abcabc', 'abc','e', 3, 2) from dual;
select regexp_replace('abcabc', 'abc','e', 1, 0) from dual;
select regexp_replace('abcabcABC', 'a','d', 1, 1, 'i') from dual;
select regexp_replace('abcabcABC', 'a','d', 1, 0, 'c') from dual;
select regexp_replace('阿里巴巴', '巴', '阿里', 1, 2) from dual;
select regexp_replace('阿里巴巴', '巴', '阿里', 4, 0) from dual;
select regexp_replace(123123, 123, 1, 1, 2) from dual;
select regexp_replace('123123', '123', 1, 3, 0) from dual;
select regexp_replace(123.400000, 3.4, 1, 1, 1) from dual;
select regexp_replace('abcabc','abc', null, 2, 1) from dual;
select regexp_replace('阿里巴巴', '巴', null, 4, 1) from dual;
select regexp_replace(123123, 123, null, 3, 0) from dual;
select regexp_replace('123.400000', 23.4, null, 1, 1, 'c') from dual;
select regexp_replace('123.400000', 23.4, 1, null, 1, 'c') from dual;
select regexp_replace('123.400000', 23.4, 1, 1, null, 'c') from dual;
select regexp_replace('123.400000', 23.4, 1, 1, 1, NULL)from dual;

select regexp_replace('abcabc', 'ab*','e', 3, 2) from dual;
select regexp_replace('abcabc', 'a..','d', 1, 0) from dual;
select regexp_replace('abcabc', '^abc','e', 1, 0) from dual;
select regexp_replace('abcabcABC', '[a-z]{3}','d', 1, 0, 'i') from dual;
--error 1210
select regexp_replace('abcabcABC', '[a-z]  {3}','d', 1, 0, 'ix') from dual;
select regexp_replace('abc\nabc', 'abc.\w{3}','d', 1, 1) from dual;
select regexp_replace('阿里巴巴', '巴*', '阿里', 1, 2) from dual;
select regexp_replace('阿里巴巴', '巴.', '阿里', 2, 0) from dual;
select regexp_replace('123.400000', '[1-9]{2}\.[1-9]', null, 1, 1) from dual;

# 测试中英文混合
select regexp_replace('123阿里123巴巴123', '123', '巴巴') from dual;
select regexp_replace('abc阿里abc巴巴abc', '巴', '阿里') from dual;
select regexp_replace('abc阿里123巴巴abc', 'abc', null) from dual;
select regexp_replace('123阿里abc巴巴123', '巴', '123', 1, 2) from dual;
select regexp_replace('abc阿里123巴巴abc', '巴', 'abc', 1, 0) from dual;
select regexp_replace('abc阿里123巴巴abc', 'abc', '阿里巴巴', 3) from dual;
select regexp_replace('abc阿里123巴巴ABC', 'abc', '阿里巴巴', 1, 0, 'c') from dual;
select regexp_replace('abc阿里123巴巴ABC', 'abc', '阿里巴巴', 1, 0, 'i') from dual;

select regexp_replace('123阿里123巴巴123', '[1-9]{3}', '#') from dual;
select regexp_replace('abc阿里abc巴巴abc', '巴*', '阿里') from dual;
select regexp_replace('abc阿里123巴巴abc', '[[:alpha:]]{3}', null) from dual;
select regexp_replace('123阿里abc巴巴123', '^123.', '#', 1, 2) from dual;
select regexp_replace('abc阿里123巴巴abc', '[a-z]$', '*', 1, 0) from dual;
select regexp_replace('abc阿里123巴巴abc', '阿|里|巴|巴', '@', 3) from dual;
select regexp_replace('abc阿里123巴巴ABC', '[a-z]|[1-9]', '阿里巴巴', 1, 0, 'c') from dual;
select regexp_replace('abc阿里123巴巴ABC', '[a-z]|[1-9]', '阿里巴巴', 1, 0, 'i') from dual;

# 测试非整的可选参数(position and nth_appearance)
select regexp_replace('abcabc', 'abc', 'd', 1.9, 1) from dual;
select regexp_replace('abcabc', 'abc', 'd', 1.9, 2.2) from dual;
select regexp_replace(123123, 123, null, 3.5, 0) from dual;
select regexp_replace('阿里巴巴', '巴', null, 3.8, 1.9) from dual;
select regexp_replace('abc阿里123巴巴ABC', 'abc', '阿里巴巴', 1, 0.99999999999999, 'i') from dual;

select regexp_replace('abcabd', 'ab.', 'd', 1.9, 1) from dual;
select regexp_replace('abcabe', 'ab.', 'd', 1.9, 2.2) from dual;
select regexp_replace(123123, '^123', null, 1.5, 1) from dual;
select regexp_replace('阿里巴巴', '巴*', null, 3.8, 1.9) from dual;
select regexp_replace('abc阿里123巴巴ABC', '[a-z]{3}', '阿里巴巴', 1, 0.99999999999999, 'i') from dual;

#参数边界测试
--error 1139
select regexp_replace('abcabc', 'a','d', 1844674407370955161518446744073709551615, 1) from dual;
select regexp_replace(123123, 123, 1, 1, 1844674407370955161518446744073709551615) from dual;
--error 1139
select regexp_replace('阿里巴巴', '巴', '阿里', 1844674407370955161518446744073709551615, 1844674407370955161518446744073709551615) from dual;
--error 1139
select regexp_replace('abc阿里123巴巴abc', '巴', 'abc', 1844674407370955161518446744073709551615, 12312312312313123.9999999) from dual;
--error 1139
select regexp_replace('abcabc', 'a*','d', 1844674407370955161518446744073709551615, 1) from dual;
select regexp_replace(123123, '[[:digit:]]{3}', 1, 1, 1844674407370955161518446744073709551615) from dual;
--error 1139
select regexp_replace('阿里巴巴', '.*巴$', '阿里', 1844674407370955161518446744073709551615, 1844674407370955161518446744073709551615) from dual;
--error 1139
select regexp_replace('abc阿里123巴巴abc', '巴.', 'abc', 1844674407370955161518446744073709551615, 12312312312313123.9999999) from dual;

#结合其他表达式测试
select regexp_replace(lower('ABCdefg') ,substr('abcdde', 1,2), '阿里巴巴', 1 ,1) from dual;
select regexp_replace(concat('xy','xy'), 'x', abs(-1)) from dual;
select regexp_replace(concat('xy','xy'), 'x*', abs(-1)) from dual;
select regexp_replace((select regexp_replace('abc阿123里123巴abc巴abc', 'abc', '阿里巴巴') from dual), '阿|里|巴|巴','123') from dual;

#特殊匹配测试
select regexp_replace('aaaaa', 'a*', '1') from dual;
select regexp_replace ('2, 5, and 10 are numbers in this example', '\d', '#') from dual;
select regexp_replace(123123,'\d+','a') from dual;
select regexp_replace(123123,'\d+?','a') from dual;
select regexp_replace(123123, '[0-9]{2,4}','#') from dual;
select regexp_replace(123123, '\d{2,4}?','#') from dual;
select regexp_replace('abc阿里123阿里巴巴&!@','\W','#') from dual;
select regexp_replace ('TechOnTheNet is a great resource', '^(\S*)', 'CheckYourMath') from dual;
select regexp_replace('abcabd', '\Aab', '1') from dual;
select regexp_replace('abcabd', '^ab', '1') from dual;
select regexp_replace('abcabe', '.*be\Z', '1') from dual;
select regexp_replace('abcabe', '.*be$', '1') from dual;
select regexp_replace('', 'b', 'c') from dual;

#无效参数测试
--error 1210
select regexp_replace('abcabd', 'ab', '1', -1) from dual;
--error 1210
select regexp_replace('abcabd', 'aab', '1', 1, -1) from dual;
--error 1210
select regexp_replace('abcabd', '\Aab', '1', 1, 0, 'p') from dual;
--error 5813
select regexp_replace(NULL, '(', 100, 1, 10) from dual;
--error 5812
select regexp_replace(NULL, '\d[', 100, 1, 10) from dual;
--error 1139
select regexp_replace(NULL, '\d{3', 100, 1, 10) from dual;

#位于建表查询语句中测试及类型推导
--disable_warnings
drop table if exists t1, v1;
--enable_warnings
create table t1(c1 varchar(64), c2 varchar(64));
insert into t1 values(regexp_replace('阿123巴巴','\d{1,}','里'), regexp_replace('阿123巴巴','阿|巴','123'));
select * from t1;
select regexp_replace(c2, '123', 'abc') from t1;
drop table t1;

create view v1 as select regexp_replace('abcabd', '\Aab', '1') as c1 from dual;
desc v1;
drop view v1;

##bug:

##测试匹配分组替换
##basic test
select regexp_replace('2019-08-07', '(2019)-(08)-(07)', '\1/\2/\3') from dual;
select regexp_replace('abc阿里abc巴巴abc', '(阿)(里)', '\1-\2') from dual;
select regexp_replace('baseocean', '(base)(ocean)', '\2\1\3\4') from dual;
select regexp_replace('aaa', 'aaa', '\\\\\\\\\1') from dual;
select regexp_replace('aaaa', '(a)(a)(a)(a)','\1-\2-$3-$4') from dual;

##multi params test
select regexp_replace('a123b123', '([[:alpha:]])(\d{3})','\1', 1, 2) from dual;
select regexp_replace('蚂123蚁123', '([[:alpha:]])(\d{3})','\1', 1, 2) from dual;

##test other situation
--disable_warnings
drop table if exists t1, t2;
--enable_warnings
create table t1 (c1 varchar(20), c2 varchar(20));
create table t2 (c1 varchar(20), c2 varchar(20));
insert into t1 values('阿里巴巴123','蚂蚁金服456');
insert into t2 values('蚂蚁金服abc','阿里巴巴DEF');

select regexp_replace(c1, '(\w{4})(\d{3})', '\2\1') from t1;
select regexp_replace('蚂蚁金服abc', '(\w{4})([[:alpha:]]{3})', '\2\1', 1) from t2;
select regexp_replace(concat(c1, c2), '(\w{4})(\d{3})', '\2\1\3\4') from t1;
select regexp_replace(c1, '(\w{4})([[:alpha:]]{3})', '\2\1\\', 1, 1, 'i') from t2;

drop table t1;
drop table t2;

create table t1 (c1 varchar(10), c2 varchar(10) collate utf8mb4_bin);
insert into t1 values('a', 'b'),('a', 'B'),('A', 'b');

select regexp_replace(c1, 'a', '#') from t1;
select regexp_replace(c2, 'b', '#') from t1;
drop table t1;