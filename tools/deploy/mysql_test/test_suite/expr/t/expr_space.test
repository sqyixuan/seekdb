--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: yibo.tyf
# owner group: SQL1
# Test of functions space

--error 1582
select space();
--error 1582
select space(1,1);

select space(5);
select length(space(5));
select space(0);
select length(space(0));
select space(-1);
select length(space(-1));
# FIXME: lack warning(mysql_code 1301) during ObExprRepeat::calc;
# select length(space(X'400000' + 1));
# FIXME: lack warning(mysq_code 1292) during ObExprOperator::cast_operand_type;
# select length(space('钡'));

--disable_warnings
create database if not exists test;
use test;
drop table if exists AllTypes;
--enable_warnings

CREATE TABLE AllTypes (
    c_bool BOOLEAN,
    c_int INT,
    c_decimal DECIMAL(13 , 0 ),
    c_double DOUBLE,
    c_bit BIT,
    
    c_datetime DATETIME,
    c_data DATE,
    c_time TIME,
    
    c_char CHAR(10),
    c_varchar VARCHAR(10),
    c_binary BINARY(10),
    c_varbinary VARBINARY(10)
);

# insert
insert AllTypes values(
    true,
    1,
    1,
    1.5,
    1,
    
    '2011-11-11 11:11:11',
    '2011-11-11',
    '11:11:11',
    
    'a',
    'a',
    'a',
    'a'
);

# FIXME: lack warning(mysq_code 1292) during ObExprOperator::cast_operand_type;
# FIXME: lack warning(mysql_code 1301) during ObExprRepeat::calc;
--disable_warnings
# select
SELECT 
    length(space(c_bool)),
    length(space(c_int)),
    length(space(c_decimal)),
    length(space(c_double)),
    length(space(c_bit)),

    length(space(c_datetime)),
    length(space(c_data)),
    length(space(c_time)),

    length(space(c_char)),
    length(space(c_varchar)),
    length(space(c_binary)),
    length(space(c_varbinary))
FROM
    AllTypes;
--enable_warnings
