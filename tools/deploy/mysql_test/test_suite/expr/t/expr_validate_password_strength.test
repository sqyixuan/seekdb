# owner: sean.yyj
# owner group: SQL3
# Test of functions validate_password_strength

--echo # prepare variables
set global validate_password_mixed_case_count = 1;
set global validate_password_number_count = 1;
set global validate_password_special_char_count = 1;
set global validate_password_length = 8;
--source mysql_test/include/check_schema_sync.inc
connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn1;
show variables like 'validate_pass%';

--echo # error params
--error 1582
select validate_password_strength();
--error 1582
select validate_password_strength('1','');

--echo # basic test
--echo # WEAK: Length < 4 or password matches the user name
select validate_password_strength('ab');
select validate_password_strength('123');
select validate_password_strength('admin');
select validate_password_strength('三个字');
--echo # LESS_WEAK: Length >= 4 and < validate_password_length
select validate_password_strength('abcde');
select validate_password_strength('123abc');
select validate_password_strength('四个字符');
--echo # LOW: Length >= validate_password_length
select validate_password_strength('12345678');
select validate_password_strength('abcd1234');
--echo # MEDIUM: mix_case/number/special chars count all match rules
--echo # STRONG: not match words in the dictionary file(always passed)
select validate_password_strength('abc123A$');
select validate_password_strength('123--ABc');

--echo # null params
select validate_password_strength(null);
select validate_password_strength('');

--echo # non-ascii characters, treated as special char (not compatible with mysql)
select validate_password_strength('ab123A中文');

--echo # non-string params
select validate_password_strength(1234567);
select validate_password_strength(3.141592);

--echo # cleanup
set global validate_password_mixed_case_count = 0;
set global validate_password_number_count = 0;
set global validate_password_special_char_count = 0;
set global validate_password_length = 0;
disconnect conn1;
--source mysql_test/include/check_schema_sync.inc
connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn1;
select validate_password_strength('test');

--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1 as select validate_password_strength('test') c1 from dual;
desc t1;
drop table t1;
