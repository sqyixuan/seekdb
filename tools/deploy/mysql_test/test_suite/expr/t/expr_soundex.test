# owner group: SQL2
# Test function soundex and sounds like

--disable_warnings
drop table if exists t1, t2;
--enable_warnings


create table t1(c1 varchar(1), c2 varchar(10000), c3 char(255), c4 tinytext,
  c5 text, c6 mediumtext, c7 longtext);
insert into t1 values('s', 'smith', 'smith', 'smith', 'smith', 'smith', 'smith');
create table t2 as select soundex(c1) c1, soundex(c2) c2, soundex(c3) c3, soundex(c4) c4,
  soundex(c5) c5, soundex(c6) c6, soundex(c7) c7 from t1;
desc t2;
select * from t2;


drop table t1;
drop table t2;
create table t1(c1 decimal(10,3), c2 float, c3 double, c4 date, c5 time, c6 datetime);
insert into t1 values(123, 123, 123, '2020-01-01', '12:12:12', '2020-01-01 12:34:56');
create table t2 as select soundex(c1) c1, soundex(c2) c2, soundex(c3) c3, soundex(c4) c4,
  soundex(c5) c5, soundex(c6) c6 from t1;
desc t2;
select * from t2;

--echo ## 1.test basic letter conversion.
select soundex('ab') from dual;
select soundex('af') from dual;
select soundex('ap') from dual;
select soundex('av') from dual;
select soundex('ac') from dual;
select soundex('ag') from dual;
select soundex('aj') from dual;
select soundex('ak') from dual;
select soundex('aq') from dual;
select soundex('as') from dual;
select soundex('ax') from dual;
select soundex('az') from dual;
select soundex('ad') from dual;
select soundex('at') from dual;
select soundex('al') from dual;
select soundex('am') from dual;
select soundex('an') from dual;
select soundex('ar') from dual;

select soundex('aa') from dual;
select soundex('ae') from dual;
select soundex('ai') from dual;
select soundex('ao') from dual;
select soundex('au') from dual;
select soundex('ah') from dual;
select soundex('aw') from dual;
select soundex('ay') from dual;


--echo ## 2.test remove repeated soundex code.
select soundex('soundex') from dual;
select soundex('ssoundex') from dual;
select soundex('sxoundex') from dual;
select soundex('sounmdex') from dual;
select soundex('sounamdex') from dual;
select soundex('abafapcagajdatlalmanrar') from dual;
select soundex('ababcac') from dual;



--echo ## 3.test utf16
drop table t1;
drop table t2;
create table t1(c1 varchar(100) collate utf16_bin);
insert into t1 values('ab');
insert into t1 values('abfpcgjdtllmnrr');
insert into t1 values('ababcac');
create table t2 as select soundex(c1) c1 from t1;
select c1, length(c1), collation(c1) from t2;


--echo ## 4.test nonalphabetic character
## 4.1 at start
select soundex('!ag') from dual;
select soundex(';ag') from dual;
select soundex('二ag') from dual;
select soundex('??ag') from dual;

## 4.2 in the middle
select soundex('a!g') from dual;
select soundex('a;g') from dual;
select soundex('a二g') from dual;
select soundex('a??g') from dual;

## 4.3 all nonalphabetic character, result is empty string
select soundex(''), length(soundex('')), soundex('') is null from dual;
select soundex('!!'), length(soundex('!!')), soundex('!!') is null from dual;

## 4.4 not effect remove repeated soundex code.
select soundex('ab!f!p') from dual;
select soundex('ab!af!p') from dual;
drop table t1, t2;


--echo ## 5.test sounds like
select 'smith' sounds like 'smyth';
select 'smithsmith' sounds like 'smythsmyth';
select 'abjm' sounds like 'afkm';
select 'abjmn' sounds like 'afkm';
select 'abjmu' sounds like 'afkmi';

select 'abjm' sounds like 'afku';
select 'abjmk' sounds like 'afkm';
select 'abjm' sounds like 'afkmk';

select 'smith' sounds like 'smy' 'th';
select 'smithsmith' sounds like 'smy' 'ths' 'myth';
select 'abjm' sounds like 'a' 'fkm';
select 'abjmn' sounds like 'a' 'fkm';
select 'abjmu' sounds like 'afkm' 'i';

select 'abjm' sounds like 'af' 'ku';
select 'abjmk' sounds like 'afk' 'm';
select 'abjm' sounds like 'a' 'fkmk';

## bugfix: 
create table t1(c1 set('a','b','c','d','e') COLLATE gbk_bin DEFAULT NULL,
                c2 set('a','b','c','d','e') COLLATE utf16_bin DEFAULT NULL,
                c3 varchar(100) collate utf16_bin);
insert into t1 values('a', 'a', 'a');
insert into t1 values('b', 'b', 'b');
create index idx_t1_1 on t1((soundex(c1)));
create index idx_t1_2 on t1((soundex(c2)));
create index idx_t1_3 on t1((soundex(c3)));
create table t2 as select soundex(c1) c1, soundex(c2) c2, soundex(c3) c3 from t1;
select c1, soundex(c1), collation(soundex(c1)), length(soundex(c1)) from t1;
select c2, soundex(c2), collation(soundex(c2)), length(soundex(c2)) from t1;
select c3, soundex(c3), collation(soundex(c3)), length(soundex(c3)) from t1;
drop table t1, t2;


CREATE TABLE t1 (c1 INTEGER);
set collation_connection = latin1_swedish_ci;
create index i1 on t1((SOUNDEX(c1)));
set collation_connection = default;
drop table t1;
