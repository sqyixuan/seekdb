#owner: huangweixiang.hwx

--disable_abort_on_error
--result_format 4

connect (conn_admin, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,oceanbase,$OBMYSQL_PORT);
connection conn_admin;
--sleep 2

#old engine

#valid
--disable_result_log
select uuid_short();

select uuid_short();

select uuid_short();

select uuid_short();

select uuid_short() + 12345;

select uuid_short() + 12345.345;

select uuid_short() + "12345.345";

select uuid_short() * uuid_short() + uuid_short() - uuid_short();

select uuid_short() from dual;
--enable_result_log
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(c1 bigint);
insert into t1 values(1);
insert into t1 values(uuid_short());
insert into t1 values(any_value(uuid_short()));
select count(*) from t1;
--disable_result_log
select * from t1;
select uuid_short() from t1;
--enable_result_log

#invalid
insert into t1 values(uuid_short);
select uuid_short(0);
select uuid_short('abcd');
select uuid_short;
uuid_short;
uuid_short();

#new engine

#valid
--disable_result_log
select uuid_short();

select uuid_short();

select uuid_short();

select uuid_short();

select uuid_short() + 12345;

select uuid_short() + 12345.345;

select uuid_short() + "12345.345";

select uuid_short() * uuid_short() + uuid_short() - uuid_short();

select uuid_short() from dual;
--enable_result_log
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(c1 bigint);
insert into t1 values(1);
insert into t1 values(uuid_short());
insert into t1 values(any_value(uuid_short()));
select count(*) from t1;
--disable_result_log
select * from t1;
select uuid_short() from t1;
--enable_result_log

#invalid
insert into t1 values(uuid_short);
select uuid_short(0);
select uuid_short('abcd');
select uuid_short;
uuid_short;
uuid_short();

#Restore the environment
drop table t1;