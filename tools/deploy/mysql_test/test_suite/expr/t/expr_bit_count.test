select bit_count(NULL);
select bit_count(0);
select bit_count(1);
select bit_count(9);
select bit_count(20);
select bit_count(-1);
select bit_count(-9);
select bit_count(-20);
select bit_count(9223372036854775807);
select bit_count(-9223372036854775808);
select bit_count(1844674407370955161);

select bit_count(0.2);
select bit_count(0.9);
select bit_count(-0.2);
select bit_count(-0.9);
select bit_count(-8.1);
select bit_count(-8.9);

select bit_count('0.2');
select bit_count('0.8');
select bit_count('-0.2');
select bit_count('-0.8');
select bit_count('1234.56');
select bit_count('123456789.12');
select bit_count('abc');
select bit_count('a56c');
select bit_count('蚂蚁金服天天向上');
select bit_count('2014-12-12');
select bit_count('2015-11-30 15:30:20');
select bit_count(x'01');
select bit_count(x'0a');
select bit_count(b'1101');
select bit_count(b'0000');
select bit_count(b'1111');

select bit_count('-1') from dual;
select 0.45 xor 1 from dual;
select '-5.227061434592839E-4' XOR 1;