## BUG#19618: Crash in range optimizer for 
##   'unsigned_keypart NOT IN(negative_number,...)' 
##   (introduced in fix BUG#15872) 
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1 (
  some_id int,
  b       int default 0,
  primary key (some_id)
);
insert into t1(some_id) values (1),(2);
select some_id from t1 where some_id not in(2,-1);
select some_id from t1 where some_id not in(-4,-1,-4);
select some_id from t1 where some_id not in(-4,-1,3423534,2342342);
#
##
## BUG#24261: crash when WHERE contains NOT IN ('<negative value>') for unsigned column type
##
#
select some_id from t1 where some_id not in('-1', '0');
#
drop table t1;
#
##
## BUG#20420: optimizer reports wrong keys on left join with IN
##
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (a int, b int, PRIMARY KEY (a));
INSERT INTO t1 VALUES (1,1),(2,1),(3,1),(4,1),(5,1),(6,1);
#
--disable_warnings
drop table if exists t2,t3,t4;
--enable_warnings
CREATE TABLE t2 (a int, b int, PRIMARY KEY (a));
INSERT INTO t2 VALUES (1,2),(2,3),(3,2),(4,2),(100,100),(101,201),(102,102);
#
CREATE TABLE t3 (a int PRIMARY KEY);
INSERT INTO t3 VALUES (1),(2),(3),(4);
#
CREATE TABLE t4 (a int PRIMARY KEY,b int);
INSERT INTO t4 VALUES (1,1),(2,2),(3,3),(4,4),(1000,1000),(1001,1001),(1002,1002),
       (1003,1003),(1004,1004);

--replace_regex /Plan signature: [0-9]*/Plan signature/
--disable_result_log
EXPLAIN SELECT  * FROM t3 
  JOIN t1 ON t3.a=t1.a 
  JOIN t2 ON t3.a=t2.a
  JOIN t4 on t4.a=t3.a  WHERE t4.a IN (t1.b, t2.b);
--enable_result_log

SELECT  * FROM t3 
  JOIN t1 ON t3.a=t1.a 
  JOIN t2 ON t3.a=t2.a
  JOIN t4 on t4.a=t3.a WHERE t4.a  IN (t1.b, t2.b);
#
--disable_result_log
#EXPLAIN SELECT  
--enable_result_log
#   (SELECT SUM(t4.a) FROM t4 WHERE t4.a IN (t1.b, t2.b)) 
 # FROM t3, t1, t2
  #WHERE t3.a=t1.a AND t3.a=t2.a;
#
#SELECT  
  # (SELECT SUM(t4.a) FROM t4 WHERE t4.a IN (t1.b, t2.b)) 
  #FROM t3, t1, t2
  #WHERE t3.a=t1.a AND t3.a=t2.a;
#
DROP TABLE t1,t2,t3,t4;  
#
