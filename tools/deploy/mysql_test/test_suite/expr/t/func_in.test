--disable_query_log
--disable_result_log
DROP DATABASE IF EXISTS database2;
CREATE DATABASE database2;
USE database2;
CREATE TABLE IF NOT EXISTS t0(c0 VARCHAR(500)  COMMENT 'asdf'  ) ;
CREATE INDEX i260 ON t0(c0(4));
CREATE INDEX i530 USING BTREE ON t0(c0(4));
select TABLE_NAME, 'InnoDB' from information_schema.TABLES where table_schema = 'database2';
select TABLE_NAME, 'InnoDB' from information_schema.TABLES where table_schema = 'database2';
ALTER TABLE t0 ;
DELETE FROM t0;
DROP INDEX i530 ON t0;
INSERT  INTO t0(c0) VALUES('d^mz%48M}|Rp*^fQ~G0'), ("d^mz%48M}|Rp*^fQ~G0");
select TABLE_NAME, 'InnoDB' from information_schema.TABLES where table_schema = 'database2';
DELETE FROM t0;
ALTER TABLE t0 ;
INSERT  INTO t0(c0) VALUES("");
INSERT  INTO t0(c0) VALUES('');
TRUNCATE TABLE t0;
DELETE FROM t0;
INSERT INTO t0(c0) VALUES(''), ('v'), (""), ('C#!v[W>]n ,phSm)B0c<');
select TABLE_NAME, 'InnoDB' from information_schema.TABLES where table_schema = 'database2';
INSERT  INTO t0(c0) VALUES('');
--enable_result_log
--enable_query_log
SELECT /*+ USE_HASH (t0) */ ALL t0.c0 AS ref0 FROM t0 WHERE (( EXISTS (SELECT 1)) IN (t0.c0, t0.c0)) NOT IN (( EXISTS (SELECT 1)) NOT IN (t0.c0), (t0.c0) && (t0.c0));
SELECT 1 FROM t0 WHERE (1 IN (t0.c0)) NOT IN (t0.c0, 1);
drop database database2;
