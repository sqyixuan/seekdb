create table t1 (id int, b int default 0, primary key(id));
insert into t1(id) values (1),(2),(3);
select count(*) from t1 where id in (1,1,2,2,3);
select count(*) from t1 where id in (1,2,1);
select count(*) from t1 where id not in(1,1,2);
select count(*) from t1 where id not in(1,2,1,3);
drop table t1;

#add by bug5103217,in have case when will core
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (id int not null primary key);
INSERT INTO t1 VALUES (1),(2),(3),(4),(5),(6),(7),(8);
SELECT id FROM t1 WHERE id IN(4564,case when 1>0 then 1 else 0 END );
#add case when and in 
--error 1064
select case id when id in(1,2,3,4,5) then "little" when id in (6,7,8) then "large" from t1;
select case  when id in(1,2,3,4) then 'little' when id in (6,7,8) then 'large' else 'not exists' end as daxiao  from t1;
select case  when id in(1,2,3,4) then 'little' when id in (6,7,8) then 'large' else 'not exists' end as daxiao  from t1 a where id>=1;
select case  when id in(1,2,3,4) then 'little' when id in (6,7,8) then 'large' else 'not exists' end as daxiao  from t1 a where id>3;
select case  when a.id in(1,2,3,4) then 'little' when a.id in (6,7,8) then 'large' else 'not exists' end as daxiao  from t1 a where a.id>3;

