##bug:
select 1 from dual where (select 1, 2 from dual) in ((3,4), (5,6));
select 1 from dual where (select '3', '4' from dual) in (('3','4'), ('5','6'));
select 1 from dual where (select '3', '4' from dual) in (('3','4'), (5,6));
select 1 from dual where (select 3, 4 from dual) in (('3','4'), ('5','6'));
