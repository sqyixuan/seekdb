##
## Bug#18360: Type aggregation for IN and CASE may lead to a wrong result 
##
--disable_warnings
drop table if exists t1,t2;
--enable_warnings
create table t1(f1 char(1),b int primary key);
insert into t1 values ('a',1),('b',2),('1',3);
select f1 from t1 where f1 in ('a','1');
select f1, case f1 when 'a' then '+' when '1' then '-' end from t1;
select f1, case f1 when 'a' then '+' when '1' then '-' else '*' end from t1;
create index t1f1_idx on t1(f1);
--source mysql_test/include/check_all_idx_ok.inc
select f1 from t1 where f1 in ('a','1');
--replace_regex /Plan signature: [0-9]*/Plan signature/
--disable_result_log
explain select f1 from t1 where f1 in ('a','1');
--enable_result_log
select f1 from t1 where f1 in ('a','b');
--replace_regex /Plan signature: [0-9]*/Plan signature/
--disable_result_log
explain select f1 from t1 where f1 in ('a','b');
--enable_result_log
select f1 from t1 where f1 in (2,1);
--replace_regex /Plan signature: [0-9]*/Plan signature/
--disable_result_log
explain select f1 from t1 where f1 in ('2','1');
--enable_result_log
create table t2(f2 int, primary key (f2));
insert into t2 values(0),(1),(2);
select f2 from t2 where f2 in ('a',2);
--replace_regex /Plan signature: [0-9]*/Plan signature/
--disable_result_log
explain select f2 from t2 where f2 in ('a',2);
--enable_result_log
select f2 from t2 where f2 in ('a','b');
--replace_regex /Plan signature: [0-9]*/Plan signature/
--disable_result_log
explain select f2 from t2 where f2 in ('a','b');
--enable_result_log
select f2 from t2 where f2 in (1,'b');
--error 5085
--replace_regex /Plan signature: [0-9]*/Plan signature/
--disable_result_log
explain select f2 from t2 where f2 in (1,'b');
--enable_result_log
drop table t1, t2;
