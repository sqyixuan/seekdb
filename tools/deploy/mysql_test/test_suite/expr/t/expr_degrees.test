# owner group: SQL1
# Test of functions degrees

--error 1582
select degrees();
--error 1582
select degrees('1','');

select degrees(null);

select degrees('');

select degrees(PI());
select degrees(PI()/2);
select degrees("3.14");
select degrees(3.14);

select degrees('-');
select degrees('-3.14');
select degrees(3.14);
select degrees(-PI());

select degrees('1');
select degrees(1);
select degrees(100000000000000000000000);
select degrees(0.0000000000000000000001);

select degrees('中文');
select degrees(X'4142');
select degrees(X'41');
select degrees(01);
select degrees(02);

select degrees(CAST(0xb3 as unsigned));
select degrees(CAST('3.1415926' as unsigned));
select degrees(CAST('900000000' as unsigned));
select degrees(CAST(3.1415926 as unsigned));

