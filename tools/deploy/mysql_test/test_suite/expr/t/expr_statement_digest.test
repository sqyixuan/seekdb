--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: sean.yyj
# owner group: sql3

--disable_warnings
drop table if exists t1;
drop table if exists t1_gbk;
drop table if exists t2;
drop table if exists t_statement_digest;
drop table if exists t_statement_digest_text;
--enable_warnings
--result_format 3

create table t1(c1 varchar(100));
create table t1_gbk(c1 varchar(100) charset gbk);
create table t2(c1 int, c2 int);
insert into t1 values('select 1');
insert into t1 values('select 1 from dual');
insert into t1 values('select 1 from t2 where c1 = 1 order by 1');
insert into t1 values('insert into t2 values(1,2), (3,4)');
insert into t1 values('select "中文", 列名 from 表名');
insert into t1_gbk select * from t1;

select 1 from t2 where c1 = 1 order by 1;
insert into t2 values(1,2), (3,4);

select c1, statement_digest_text(c1), collation(statement_digest_text(c1)), statement_digest(c1), collation(statement_digest(c1)) from t1;
select c1, statement_digest_text(c1), collation(statement_digest_text(c1)), statement_digest(c1), collation(statement_digest(c1)) from t1_gbk;

select format_sql_id, query_sql from oceanbase.V$OB_SQL_AUDIT where format_sql_id = statement_digest('select 1 from t2 where c1 = 1 order by 1') limit 1;

select statement_digest_text(null);
--error 1065
select statement_digest_text('');
--error 1064
select statement_digest_text('abcd');
--error 1064
select statement_digest_text('select * from');
--error 1064
select statement_digest_text(123);

create table t_statement_digest as select statement_digest(c1) c1 from t1;
create table t_statement_digest_text as select statement_digest_text(c1) c1 from t1;
desc t_statement_digest;
desc t_statement_digest_text;
drop table t1;
drop table t2;
drop table t_statement_digest;
drop table t_statement_digest_text;

--echo issue: 
set @sqlstr1='CREATE VIEW v2 AS SELECT * FROM t2 WHERE id > 1';
set @sqlstr2='ALTER VIEW v1 AS SELECT c1,c2 FROM t1 WHERE c1 = "view"';
set @sqlstr31='CREATE TRIGGER tri3 AFTER INSERT ON t2 FOR EACH ROW INSERT INTO t3 VALUES (1,2,3,4)';
set @sqlstr32='CREATE TRIGGER tri4 AFTER INSERT ON t2 FOR EACH ROW UPDATE t3 SET c1 = 2;';
set @sqlstr33='CREATE TRIGGER tri5 AFTER INSERT ON t2 FOR EACH ROW DELETE FROM t3 WHERE c1 = 1';
set @sqlstr4='ALTER TABLE t1 ROW_FORMAT = COMPRESSED';
set @sqlstr5='GRANT SELECT ON world.* TO role3';
set @sqlstr6='CREATE USER "whh"@"localhost" IDENTIFIED BY "password"';
set @sqlstr7='SET PASSWORD FOR "whh"@"localhost" = "whh"';
set @sqlstr8='SET SESSION TRANSACTION ISOLATION LEVEL REPEATABLE READ';
set @sqlstr9='EXPLAIN t1';
set @sqlstr10='DESCRIBE t1';
set @sqlstr11='CREATE TABLE t1 (id INT(21),c1 VARCHAR(25),c2 DATE,c3 BLOB,INDEX(c3(10)))';
set @sqlstr12='ALTER TABLE t1 ADD COLUMN c2 INT GENERATED ALWAYS AS (c1 + 1) STORED';
set @ps = "prepare stmt from 'select * from t1 where c1 = ?'";
set @show = "show create table t1";

select statement_digest(@sqlstr1)  digest,statement_digest_text(@sqlstr1) digest_text from dual;
select statement_digest(@sqlstr2)  digest,statement_digest_text(@sqlstr2) digest_text from dual;
select statement_digest(@sqlstr31)  digest,statement_digest_text(@sqlstr31) digest_text from dual;
select statement_digest(@sqlstr32)  digest,statement_digest_text(@sqlstr32) digest_text from dual;
select statement_digest(@sqlstr33)  digest,statement_digest_text(@sqlstr33) digest_text from dual;
select statement_digest(@sqlstr4)  digest,statement_digest_text(@sqlstr4) digest_text from dual;
select statement_digest(@sqlstr5)  digest,statement_digest_text(@sqlstr5) digest_text from dual;
select statement_digest(@sqlstr6)  digest,statement_digest_text(@sqlstr6) digest_text from dual;
select statement_digest(@sqlstr7)  digest,statement_digest_text(@sqlstr7) digest_text from dual;
select statement_digest(@sqlstr8)  digest,statement_digest_text(@sqlstr8) digest_text from dual;
select statement_digest(@sqlstr9)  digest,statement_digest_text(@sqlstr9) digest_text from dual;
select statement_digest(@sqlstr10) digest,statement_digest_text(@sqlstr10) digest_text from dual;
select statement_digest(@sqlstr11) digest,statement_digest_text(@sqlstr11) digest_text from dual;
select statement_digest(@sqlstr12) digest,statement_digest_text(@sqlstr12) digest_text from dual;
select statement_digest(@ps) digest,statement_digest_text(@ps) digest_text from dual;
select statement_digest(@show) digest,statement_digest_text(@show) digest_text from dual;

--error 1065
select statement_digest_text(' ');
--error 1210
select statement_digest_text(' ;');
select statement_digest_text('select 1; ');
select statement_digest_text('select 1;;;');
select statement_digest_text('select 1; #a');
--error 1210
select statement_digest_text('select 1; select 2');
--error 1064
select statement_digest_text('select 1; abc');
--error 1210
select statement_digest_text('select ?');
select statement_digest_text('select "?"');
