--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#### owner: luofan.zp
#### owner group: sql3
#### description: 测试比较函数（大于、等于,etc）
set sql_mode='';
--disable_warnings
drop table if exists t;
--enable_warnings
create table t(
  id            int auto_increment primary key, 
  col_int       bigint,
  col_uint      bigint unsigned,
  col_float     float,
  col_double    double,
  col_decimal   decimal(30, 6),
  col_datetime  datetime(3),
  col_timestamp timestamp(4) null default null,
  col_date      date,
  col_time      time(5),
  col_year      year(4),
  col_varchar   varchar(100)
);
insert into t(col_int) values (-9223372036854775808), (-9223372036854775807), (9223372036854775806), (9223372036854775807);
insert into t(col_uint) values (0), (1), (18446744073709551614), (18446744073709551615);
insert into t(col_varchar) values ('-9223372036854775809'), ('-9223372036854775808'), ('-9223372036854775807'), 
                                  ('-1'), ('0'), ('1'),
                                  ('9223372036854775806'), ('9223372036854775807'), ('9223372036854775808'),
                                  ('18446744073709551614'), ('18446744073709551615'), ('18446744073709551616');
select c1, c2, c1 < c2, c1 = c2, c1 > c2 from (select t1.col_int as c1, t2.col_uint      as c2 from t t1, t t2) as tmp where c1 is not null and c2 is not null order by cast(c1 as decimal(30, 6)), cast(c2 as decimal(30, 6));
select c1, c2, c1 < c2, c1 = c2, c1 > c2 from (select t1.col_int as c1, t2.col_varchar   as c2 from t t1, t t2) as tmp where c1 is not null and c2 is not null order by cast(c1 as decimal(30, 6)), cast(c2 as decimal(30, 6));
select c1, c2, c1 < c2, c1 = c2, c1 > c2 from (select t1.col_uint as c1, t2.col_int       as c2 from t t1, t t2) as tmp where c1 is not null and c2 is not null order by cast(c1 as decimal(30, 6)), cast(c2 as decimal(30, 6));
select c1, c2, c1 < c2, c1 = c2, c1 > c2 from (select t1.col_uint as c1, t2.col_varchar   as c2 from t t1, t t2) as tmp where c1 is not null and c2 is not null order by cast(c1 as decimal(30, 6)), cast(c2 as decimal(30, 6));
#test string_double
select "123a" < 123;
select cast("49.6" as signed) = cast("50" as signed);
select cast("49.2" as signed) = cast("50" as signed);
select "a123.3" < 123;
# clear.
drop table t;
set ob_enable_transformation=ON;
create table t(pk1 varchar(10), pk2 int, c1 int , c2 varchar(64), primary key(pk1, pk2));
insert into t(pk1,pk2,c1,c2) values(0,'0',0,'0');
insert into t(pk1,pk2,c1,c2) values(1,'1',1,'1');
insert into t(pk1,pk2,c1,c2) values(1,2,1,'1');
select pk2='2' from t;
set ob_enable_transformation=OFF;
select pk2='2' from t;
drop table t;
