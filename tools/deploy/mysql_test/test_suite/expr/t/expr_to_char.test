# owner: chenxiansen.cxs
# owner group: sql2

--disable_abort_on_error

connect (syscon, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
--sleep 2
connection default;


--disable_warnings
drop table if exists t1;

create table t1(
c0 int primary key,
c1 bigint,
c2 bool,
c3 float,
c4 double,
c5 decimal(18,2),
c6 date,
c7 DATETIME,
c8 TIMESTAMP,
c9 char(20),
c10 varchar(20)
);

INSERT INTO t1 VALUES (
    1017731666,
    8658427321709128105,
    false,
    3.8683e+37,
    -1.2829e+09,
    -36050.76,
    '2010-03-24',
    '1999-06-26 20:56:23',
    '1979-12-18 16:32:48',
    'YLYEQXAQEHRUAYGUHCGQ',
    'c46cx1me78DL77Kwledu'
);

INSERT INTO t1 VALUES (
    1017111116,
    8658427321790338105,
    true,
    -3.8683e+37,
    1.2829e+09,
    36050.76,
    '2024-03-24',
    '1998-06-26 20:56:23',
    '1979-12-18 16:32:48',
    'YLYEQXAQEHRUAYGUHCGQ',
    'c46cx1me78DL77Kwledu'
);

select c1, to_char(c1), c2, to_char(c2), c3, to_char(c3), c4, to_char(c4), c5, to_char(c5), c6, to_char(c6), c7, to_char(c7), c8, to_char(c8), c9, to_char(c9), c10, to_char(c10) from t1;

--enable_warnings

connection syscon;

sleep 2;

connection default;
set @@ob_enable_plan_cache = 0;

select to_char(NULL, '999') from dual;
select to_char('345', '9999') from dual;
select to_char('345', NULL) from dual;

select to_char(01234567) as  c from dual;
select to_char(1234567) as  c from dual;
select to_char(123.4567) as c from dual;
select to_char(12.34567) as c from dual;
select to_char(1.234567) as c from dual;
select to_char(1234567, '9999') as c from dual;
select to_char(1234,    '9999') as c from dual;
select to_char(12,      '9999') as c from dual;
select to_char(1.2,     '9999') as c from dual;
select to_char(0.4999,  '9999') as c from dual;
select to_char(0.5,     '9999') as c from dual;
select to_char(9999.5,  '9999') as c from dual;
select to_char(1.1,  '0.9') as c from dual;
select to_char(0.93, '0.9') as c from dual;
select to_char(0.45, '0.9') as c from dual;

select to_char(timestamp'2018-12-25 20:10:59', 'AD') as R from dual;
select to_char(timestamp'2018-12-25 20:10:59', 'A.D.') as R from dual;
select to_char(timestamp'2018-12-25 11:59:59', 'AM') as R from dual;
select to_char(timestamp'2018-12-25 00:00:00', 'aM') as R from dual;
select to_char(timestamp'2018-12-25 23:59:59', 'Am') as R from dual;
select to_char(timestamp'2018-12-25 12:00:00', 'am') as R from dual;

SELECT TO_CHAR(-10000, 'L99G999D99MI') "Amount" FROM DUAL;


--sleep 2
--disable_warnings
drop table if exists time_test;
create table time_test(
c1 timestamp,
c2 datetime,
c3 date,
c4 time,
c5 year
);

insert into time_test values(
'2018-12-25 20:10:59',
'2018-12-25 20:10:59',
'2018-12-25',
'20:10:59',
2018
);

select c1, to_char(c1), c2, to_char(c2), c3, to_char(c3), c4, to_char(c4), c5, to_char(c5) from time_test;

select c1, to_char(c1, 'yyyy=mm') from time_test;

select c2, to_char(c2, 'mon dd mi ss') from time_test;

select c3, to_char(c3, 'dd') from time_test;

select c4, to_char(c4, 'hh:mi:ss') from time_test;

select c5, to_char(c5, '=yyyy') from time_test;
select c1, to_char(c1, 'FF4'), to_char(c1, 'FF5'), to_char(c1, 'FF6') from time_test;
select c1, to_char(c1, 'FF7') from time_test;
select c1, to_char(c1, 'FF8') from time_test;
select c1, to_char(c1, 'FF9') from time_test;

select to_char(timestamp'2018-12-25 20:10:59.123456789', 'FF') as R1, 
       to_char(timestamp'2018-12-25 20:10:59.123456789', 'FF2') as R2,
       to_char(timestamp'2018-12-25 20:10:59.123456789', 'FF6') as R3
        from dual;

SELECT TO_CHAR(TIMESTAMP '2023-07-15 14:30:45.2', 'FF') FROM DUAL;
SELECT TO_CHAR(TIMESTAMP '2023-07-15 14:30:45.22', 'FF') FROM DUAL;

# format_string tmx
select to_char(0.1,'tm')  from dual;
select to_char(-0.1,'tm')  from dual;
select to_char(0.1111111111111111111111111122222222222222222222222222222222222222222222222222,'tm')  from dual;
select to_char(0.1,'tme')  from dual;
select to_char(-0.1,'tme')  from dual;
select to_char(10.1,'tme')  from dual;
select to_char(-10.1,'tme')  from dual;

# format_string ivvv-iw, iso week
select to_char(date '2012-12-31','iyyy-iw') R from dual;
select to_char(date '2012-12-30','iyyy-iw') R from dual;

connection syscon;
