k)  and (((27 is not NULL)  or (ref_0.pk & (select pk from obcachetable2queuing limit 1 offset 5) ))  or (ref_0.pk < ref_0.pk)))  and (ref_0.pk / ref_0.pk))))  and (ref_0.pk is NULL))  or (((1)  and (ref_0.pk << ref_0.pk))  or (((select sum(amount) from pay_comm)  is not NULL)  or (ref_0.gmt_create is not NULL))))) as subq_0 where (subq_0.c3 OR subq_0.c2)  and (subq_0.c2 = case when (subq_0.c3 | 22)  or (subq_0.c3 >> case when subq_0.c3 AND (select pk1 from obcachetable1 limit 1 offset 4)  then subq_0.c2 else subq_0.c2 end ) then subq_0.c2 else 21 end ) limit 118  for update;

