##bugfix: 
select nullif( 1,  VAR_SAMP(1) over (partition by 1)) from dual;

create database nullif_test;
use nullif_test;

create table t1(c1 char(10), c2 char(10), c3 longtext);
select 1 from t1 where c1 BETWEEN c2 and nullif('a', c3);
select 1 from t1 where c1 BETWEEN c2 and nullif(c3, 'a');

insert into t1 values('123', 'abc', '123');
insert into t1 values('123', 'abc', 'abc');
select nullif(c1, c3), nullif(c2, c3), nullif(c3, c1), nullif(c3, c2) from t1;
create table t2 as select nullif(c1, c3) c1, nullif(c2, c3) c2, nullif(c3, c1) c3, nullif(c3, c2) c4 from t1;
desc t2;
select * from t2;

create table t3(c1 char(10) collate utf8mb4_general_ci, c2 char(10) collate gbk_bin);
insert into t3 values('123', 'abc');
insert into t3 values('ä¸€äşŚä¸‰', 'ĺ››äş”ĺ…­');
insert into t3 values('ĺ››äş”ĺ…­', 'ä¸€äşŚä¸‰');
select c1, hex(c1), collation(c1), nullif(c1, c2), hex(nullif(c1, c2)), collation(nullif(c1, c2)) from t3;
select c2, hex(c2), collation(c2), nullif(c2, c1), hex(nullif(c2, c1)), collation(nullif(c2, c1)) from t3;

