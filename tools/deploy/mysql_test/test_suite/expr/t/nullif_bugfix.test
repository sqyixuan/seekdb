select   subq_0.c4 as c0,  cast(ifnull(if(  avg( cast((select max(trans_sequence) from upp_online_checktrans_92 order by 1)  as DECIMAL)) over (partition by subq_0.c5 order by subq_0.c5) < subq_0.c3 , subq_0.c0 , cast(nullif(subq_0.c1, subq_0.c1) as DATETIME) ) , if( EXISTS ( select   ref_4.c3 as c0,  subq_0.c4 as c1,  subq_0.c2 as c2,  subq_0.c4 as c3 from  obcachetable1queuing as ref_4 where EXISTS ( select   ref_4.gmt_create as c0 from  obright as ref_5 where ref_5.v3 like "ref_5.v1%" limit 63)) , cast(coalesce(subq_0.c1, subq_0.c1) as DATETIME) , cast(nullif(subq_0.c0, subq_0.c1) as DATETIME) ) ) as DATETIME) as c1,  cast(coalesce(subq_0.c0, subq_0.c1) as DATETIME) as c2 from  (select distinct  ref_0.gm_modified as c0,  case when (select payment_id from partkeyupdate order by 1 desc  limit 1 offset 5)  in (  group_concat( cast((select payment_id from pay_comm order by 1 limit 1 offset 6)  as CHAR)) over (partition by ref_0.grp_num,ref_0.gm_create order by ref_0.grp_num,ref_0.grp_num),  (select c1 from bigpartition order by 1 limit 1 offset 2) ,  (select v1 from updaterowkey order by 1 desc  limit 1 offset 6) ,  (select group_concat(trans_seqno) from upp_online_checktrans_92 order by 1) ,  (select c3 from obcachetable0 order by 1 limit 1 offset 3) ,  (select v1 from obcachetable2 order by 1 desc  limit 1 offset 5) ,   max( cast((select a from multiupdatet2 order by 1 desc  limit 1 offset 6)  as CHAR)) over (partition by ref_0.grp_num order by ref_0.version),  (select a from insertintot2 order by 1 limit 1 offset 2) ,   min( cast((select c1 from bigpartition order by 1 desc  limit 1 offset 5)  as CHAR)) over (partition by ref_0.gm_modified,ref_0.gm_create order by ref_0.version,ref_0.gm_create)) then ref_0.gm_create else ref_0.gm_modified end  as c1,   group_concat( cast((select payment_id from nopk_global_index order by 1 limit 1 offset 49)  as CHAR)) over (partition by ref_0.gm_modified,ref_0.gm_create,ref_0.row_num order by ref_0.gm_modified) as c2,  ref_0.version as c3,   avg( cast(ref_0.version as DECIMAL)) over (partition by ref_0.version order by ref_0.gm_modified,ref_0.version,ref_0.gm_modified) as c4,  ref_0.grp_num as c5 from  ob_causal_ordering2 as ref_0 where EXISTS ( select   ref_1.v1 as c0,  (select avg(dec1) from obright order by 1)  as c1,  ref_1.md5 as c2,  ref_0.gm_modified as c3,  (select c3 from obcachetable1queuing order by 1 desc  limit 1 offset 6)  as c4,  ref_1.a as c5,  ref_1.a as c6,  ref_1.v1 as c7,  ref_0.row_num as c8,  (select v1 from part_global_index order by 1 limit 1 offset 6)  as c9 from  multiupdatet2 as ref_1 where EXISTS ( select   ref_1.a as c0,  ref_2.c as c1 from  t_update as ref_2 where EXISTS ( select   ref_3.pid2 as c0 from  obson as ref_3 where ref_2.d in ( ref_1.md5,  ref_3.id_check,  ref_2.d,  ref_2.d,  ref_1.md5,  ref_0.version,  ref_3.id_check,  ref_0.grp_num,  ref_0.grp_num,  (select pk from obfloat order by 1 desc  limit 1 offset 3) ,  ref_0.grp_num,  ref_0.row_num,  ref_1.md5,  ref_2.d))) limit 66) limit 73) as subq_0 where EXISTS ( select   subq_0.c5 as c0,  (select min(a) from multiupdatet1 order by 1)  as c1 from  (insertintot1 as ref_6 full join obweak as ref_7 on (ref_6.c OR ref_7.row_num)) where subq_0.c5 not  in ( cast(coalesce(subq_0.c5, subq_0.c4) as DECIMAL),  ref_7.grp_num,  ref_7.row_num,  ref_6.c,  ref_6.c,  cast(nullif(ref_7.grp_num, ref_6.c) as DECIMAL),  (select pk from bigpartition order by 1 desc  limit 1 offset 23) ,  ref_6.c,  cast(ifnull(subq_0.c4, subq_0.c5) as DECIMAL),  (select max(trans_sequence) from upp_online_checktrans_92 order by 1) ,  subq_0.c4,  subq_0.c5,  subq_0.c5,  ref_7.row_num,  cast(nullif(subq_0.c3, subq_0.c5) as DECIMAL),  subq_0.c4) limit 168) limit 132;
