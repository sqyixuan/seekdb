#### owner: dachuan.sdc
#### owner group: sql2
#### description: test function time_format

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

set character_set_connection = 'utf8';
--disable_warnings
drop table if exists t1, t2, t3;
drop view if exists v1;
--enable_warnings
select time_format(time '-1:34:56.789', '%f %H %h %I %i %k %l %p %r %S %s %T %c %e %d %m %y %Y');
select time_format(time '-2:34:56.789', '%f %H %h %I %i %k %l %p %r %S %s %T %c %e %d %m %y %Y');
select time_format(time '-10:34:56.789', '%f %H %h %I %i %k %l %p %r %S %s %T %c %e %d %m %y %Y');
select time_format(time '-100:34:56.789', '%f %H %h %I %i %k %l %p %r %S %s %T %c %e %d %m %y %Y');
select time_format(time '00:34:56.789', '%f %H %h %I %i %k %l %p %r %S %s %T %c %e %d %m %y %Y');
select time_format(time '11:34:56.789', '%f %H %h %I %i %k %l %p %r %S %s %T %c %e %d %m %y %Y');
select time_format(time '12:34:56.789', '%f %H %h %I %i %k %l %p %r %S %s %T %c %e %d %m %y %Y');
select time_format(time '13:34:56.789', '%f %H %h %I %i %k %l %p %r %S %s %T %c %e %d %m %y %Y');
select time_format(time '23:34:56.789', '%f %H %h %I %i %k %l %p %r %S %s %T %c %e %d %m %y %Y');
select time_format(time '24:34:56.789', '%f %H %h %I %i %k %l %p %r %S %s %T %c %e %d %m %y %Y');
select time_format(time '25:34:56.789', '%f %H %h %I %i %k %l %p %r %S %s %T %c %e %d %m %y %Y');
select time_format(time '800:34:56.789', '%f %H %h %I %i %k %l %p %r %S %s %T %c %e %d %m %y %Y');
select collation(time_format(time '800:34:56.789', '%f %H %h %I %i %k %l %p %r %S %s %T %c %e %d %m %y %Y')),
  length(time_format(time '800:34:56.789', '%f %H %h %I %i %k %l %p %r %S %s %T %c %e %d %m %y %Y'));
--error 1525
select time_format(time '900:34:56.789', '%f %H %h %I %i %k %l %p %r %S %s %T %c %e %d %m %y %Y');
create table t2 as select time_format(time '800:34:56.789', '%f %H %h %I %i %k %l %p %r %S %s %T %c %e %d %m %y %Y') c1;
create view v1 as select time_format(time '800:34:56.789', '%f %H %h %I %i %k %l %p %r %S %s %T %c %e %d %m %y %Y') c2;
select * from t2;
select * from v1;
show create view v1;
drop table t2;
drop view v1;

select time_format(time '12:34:56.789', '%f %a');
select time_format(time '12:34:56.789', '%f %b');
select time_format(time '12:34:56.789', '%f %D');
select time_format(time '12:34:56.789', '%f %j');
select time_format(time '12:34:56.789', '%f %M');
select time_format(time '12:34:56.789', '%f %U');
select time_format(time '12:34:56.789', '%f %u');
select time_format(time '12:34:56.789', '%f %V');
select time_format(time '12:34:56.789', '%f %v');
select time_format(time '12:34:56.789', '%f %W');
select time_format(time '12:34:56.789', '%f %w');
select time_format(time '12:34:56.789', '%f %X');
select time_format(time '12:34:56.789', '%f %x');
select time_format(time '12:34:56.789', '%% %z'), length(time_format(time '12:34:56.789', '%% %z'));
create table t1(c1 time);
create table t2(d1 varchar(100) collate utf8_bin, d2 varchar(100) collate utf16_bin, d3 varchar(100) collate gbk_bin);
insert into t1 values (time '-1:34:56.789'), (time '-2:34:56.789'), (time '-10:34:56.789'), (time '-100:34:56.789'), 
  (time '00:34:56.789'), (time '11:34:56.789'), (time '12:34:56.789'), (time '13:34:56.789'),
  (time '23:34:56.789'), (time '24:34:56.789'), (time '25:34:56.789'), (time '800:34:56.789');
insert into t2 values('%f %H %h %I %i %k %l %p %r %S %s %T %c %e %d %m %y %Y',
  '%f %H %h %I %i %k %l %p %r %S %s %T %c %e %d %m %y %Y',
  '%f %H %h %I %i %k %l %p %r %S %s %T %c %e %d %m %y %Y'),
  ('%% %z', '%% %z', '%% %z');
select c1, d1, time_format(c1, d1), length(time_format(c1, d1)), collation(time_format(c1, d1)) from t1, t2 order by c1, d1;
select c1, d2, time_format(c1, d2), length(time_format(c1, d2)), collation(time_format(c1, d2)) from t1, t2 order by c1, d1;
select c1, d3, time_format(c1, d3), length(time_format(c1, d3)), collation(time_format(c1, d3)) from t1, t2 order by c1, d1;
create table t3 as select c1, d1 c2, time_format(c1, d1) r1, time_format(c1, d2) r2, time_format(c1, d3) r3 from t1, t2 order by c1, d1;
desc t3;
select t3.*, collation(r1), length(r1), length(r2), length(r3) from t3;




