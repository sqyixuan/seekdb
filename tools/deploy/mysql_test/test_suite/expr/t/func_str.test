CREATE TABLE t1 (a binary(64));
INSERT INTO t1 VALUES (0x00), (0x0000), (0x000000), (0x00000000);
INSERT INTO t1 VALUES (0x00010203040506070809);
SELECT hex(a) FROM t1 ORDER BY a;
DROP TABLE t1;

--echo #
--echo # Bug#42404: SUBSTRING_INDEX() RESULTS ARE INCONSISTENT
--echo #

CREATE TABLE t (i INT NOT NULL, c CHAR(255) NOT NULL);
INSERT INTO t VALUES (0,'.www.mysql.com'),(1,'.wwwmysqlcom');
SELECT i, SUBSTRING_INDEX(c, '.', -2) FROM t WHERE i = 1;
SELECT i, SUBSTRING_INDEX(c, '.', -2) FROM t;
DROP TABLE t;

--echo # End of test  BUG#42404
--echo #
--echo # Bug#13812875 ILLEGAL MIX OF COLLATIONS WITH FUNCTIONS THAT USED TO WORK
--echo #
CREATE TABLE t1 (a varchar(1));
SELECT * FROM t1 WHERE a=md5('a');
SELECT * FROM t1 WHERE a=hex('a');
DROP TABLE t1;
create table t1(a varchar(10) collate utf8mb4_general_ci, b binary(10), c varchar(10) collate utf8mb4_bin, d int);
insert into t1 values("hello","world","bar",12345);
--enable_metadata
select right(a, 2) from t1;
select right(b, 2) from t1;
select right(c, 2) from t1;
select right(d, 2) from t1;
select reverse(a) from t1;
select reverse(b) from t1;
select reverse(c) from t1;
select reverse(d) from t1;
--disable_metadata
drop table t1;

create table t1(a varchar(100));
create view v as select substr(a, 1, 10) from t1;
desc v;
drop view v;
create view v as select substr(a, 1, 100) from t1;
desc v;
drop view v;
create view v as select substr(a, 98, 2) from t1;
desc v;
drop view v;
create view v as select substr(a, 98, 3) from t1;
desc v;
drop view v;
create view v as select substr(a, 1, 200) from t1;
desc v;
drop view v;
create view v as select substr(a, 1) from t1;
desc v;
drop view v;
create view v as select substr(a, 98) from t1;
desc v;
drop view v;
create view v as select substr(a, 101) from t1;
desc v;
drop view v;
create view v as select substr(a, 110) from t1;
desc v;
drop view v;
create view v as select substr(a, 100) from t1;
desc v;
drop view v;
drop table t1;
