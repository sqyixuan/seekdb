#set @@session.explicit_defaults_for_timestamp=off;
# owner:peihan.dph
# owner group:sql2
# tags:funcs, expr, datatype
# descriotion: 
# 验证mysql模式下的
#ObExprIn
#ObExprNotIn

--disable_sorted_result
--disable_abort_on_error

--result_format 4

--echo # IN/NOT IN的测试, 针对ObExprIn
select 1 from dual where 1  in (2.0, 1 / 0.1 / 10);
select 2 from dual where (1,2, null)  in ((1,2,null), (1,2,5));
select 3 from dual where (1,2, null) not  in ((1,2,null), (1,2,5));
select 4 from dual where (1,2) not  in ((1,3), (1,2-5), (1+null, 5.05+'1'));
select 5 from dual where (1,2) not  in ((1,3), (1,2-5), (1+null, null-5.05+'1'));
select 6 from dual where '1' in (2.0, 1.0, 5,'null');
select 7 from dual where 4/2.0 in (2, 1, 0,'x');
select 8 from dual where 4.0/'2.0' in (2, 1, 0,'');
select 9 from dual where 4.0/'2.0' in (2, 1, 0,'');
select 10 from dual where (1,1) in ((1,0),(0,1),(0,0));
select 11 from dual where (1.5,1.7) in ((1.5,0),(0,1.7),(0,0));
select 12 from dual where (cast(1.5 as decimal),1.7) in ((1.5,0),(1.5,'1.7'),(0,0));

# oracle模式做cast报错，MySQL模式不报错
select 13 from dual where ('x', -5555) in ((1,0),(0,1),('a', 555), ('x', -5555));
# oracle模式做cast报错，MySQL模式不报错
select 13 from dual where ('x' ) in (1,'a','x');
select 13 from dual where '1' in( 1.0,'x');
select 13 from dual where '1.0000' in( 1.0,'x');

# oracle模式做cast报错，MySQL模式不报错
select 14 from dual where ('x', -5555, 5.04) in ((1,0,5),(0,4,1),('a', 1, 555), ('x', 0, -5555),
                                                (1,0,5),(0,4,1),('x', -5555, 5.04));
# oracle模式做cast报错，MySQL模式不报错
select 15 from dual where ('x', -5555, 5.04) in ((1,0,5),(0,4,1),('a', 1, 555), ('x', 0, -5555),
                                                (1,0,5),(0,4,1),('x', -5555, 5.04));

