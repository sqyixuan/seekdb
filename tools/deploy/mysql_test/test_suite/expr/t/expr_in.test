select 1 from dual where 10  in (10,null);

select 1 from dual where 1 not in (2.0, 1 / 0);
select 2 from dual where 1 not in (10,null);
select 3 from dual where '1' not in (2.0, 1.0, 5,'null');

select 4 from dual where 4/2.0 not in (2, 1, 0,'x');
select 5 from dual where 4.0/'2.0' not in (2, 1, 0,'');
select 6 from dual where 4.0/'2.0' not in (2, 1, 0,'');
select 7 from dual where (1,1) not in ((1,0),(0,1),(0,0));
select 8 from dual where (1,1) not in (((select '1' from dual), (select min(0) from dual)),(0,1),(0,0));
select 12 from dual where cast(1.2 as decimal(15,6)) in (cast(1.20 as decimal(3,0)));
select 13 from dual where cast(1.24456 as decimal(15,2)) in (cast(1.23888888 as decimal(13,2)));
select 14 from dual where cast(1.2 as decimal(15,6)) not in (cast(1.20 as decimal(3,0)));

select 1 from dual where  'x' in ('a', 5);
select 1 from dual where 1 NOT in(1.0);
select 2 from dual where 1 IN('01');
select 2.5 from dual where 1.00100 IN(1.001);

select 3 as x from dual where 1 NOT in(1.0,2.0) union all
select 4 from dual where 1 IN('01','002') union all
select 33 from dual where 1.0 NOT in(1,2) union all
select 44 from dual where 1.000 IN('01','002');
select 1 from dual where cast(1.2 as decimal(15,6)) < cast(1.20 as decimal(3,0));
select 11 from dual where 1 < '02';
select 12 from dual where 1 <> '02';
select 13 from dual where 1 > '02';

--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(c1 varchar(10),c2 char(10), c3 varchar(100), c4 int, c5 decimal(10,2));
insert into t1 values('1','1','1',1,1);
insert into t1 values('1 ','1  ','1  ',1 ,1.0 );
insert into t1 values('',' ','  ',2 ,1.0 );
insert into t1 values(null,null,null,null,null);
insert into t1 values(2,null,null,null,null);
insert into t1 values(2,2,4,5,6);
insert into t1 values(3,2,4,5,6);

select count(*),count(x.c1),sum(y.c1) from t1 x, t1 y where x.c1 in (x.c1,x.c2,x.c3,x.c4,x.c5);
--enable_sorted_result
select * from t1 x join t1 y on y.c1 not in (x.c1,x.c2,y.c3,x.c4,y.c5) where x.c1 in (x.c1,x.c2,x.c3,x.c4,x.c5);
select count(*),count(x.c1),sum(y.c1) from t1 x, t1 y where (x.c1, x.c2) in ((x.c1, x.c2), (x.c2, x.c2), (x.c3, x.c2), (x.c4, x.c2), (x.c5, x.c2));
select count(*),count(x.c1),sum(y.c1) from t1 x, t1 y where (x.c2, x.c2) in ((x.c2, x.c2), (x.c2, x.c2), (x.c2, x.c2), (x.c2, x.c2), (x.c2, x.c2));
select count(*),count(x.c1),sum(y.c1) from t1 x, t1 y where (x.c3, x.c2) in ((x.c3, x.c2), (x.c3, x.c2), (x.c3, x.c2), (x.c3, x.c2), (x.c3, x.c2));
drop table t1;
