drop table if exists store_car_bd_0;
--enable_warnings

CREATE TABLE `store_car_bd_0` (
`useyears` decimal(19,0),
`d4_amount` decimal(16,2)
);

insert into store_car_bd_0 (useyears, d4_amount) values (0, 12.0), (1, 13.12), (0, 14.0), (1, 15.0);

select 1 union all 
select floor(case when ta.useyears=0 then ta.d4_amount else 0 end) as xin_car_cnt from store_car_bd_0 ta;

select 1 union all 
select floor(sum(case when ta.useyears=0 then ta.d4_amount else 0 end)) as xin_car_cnt from store_car_bd_0 ta;

alter system set _enable_decimal_int_type = false;
sleep 5;
drop table if exists store_car_bd_0;
CREATE TABLE `store_car_bd_0` (
`useyears` decimal(19,0),
`d4_amount` decimal(16,2)
);

insert into store_car_bd_0 (useyears, d4_amount) values (0, 12.0), (1, 13.12), (0, 14.0), (1, 15.0);

select 1 union all 
select floor(case when ta.useyears=0 then ta.d4_amount else 0 end) as xin_car_cnt from store_car_bd_0 ta;

select 1 union all 
select floor(sum(case when ta.useyears=0 then ta.d4_amount else 0 end)) as xin_car_cnt from store_car_bd_0 ta;

alter system set _enable_decimal_int_type = true; 