##
SELECT 'case+union+test' UNION SELECT CASE LOWER('1') WHEN LOWER('2') THEN 'BUG' ELSE 'nobug' END;
SELECT CASE LOWER('1') WHEN LOWER('2') THEN 'BUG' ELSE 'nobug' END;
SELECT 'case+union+test' UNION SELECT CASE '1' WHEN '2' THEN 'BUG' ELSE 'nobug' END;

##
--disable_warnings
drop table if exists t1,t2;
--enable_warnings
create table t1(a float, b int default 3);
insert into t1 (a) values (2), (11), (8);
select min(a), min(case when 1=1 then a else NULL end),min(case when 1!=1 then NULL else a end) from t1 where b=3 group by b;
drop table t1;

##
--disable_warnings
drop table if exists t1,t2;
--enable_warnings
CREATE TABLE t1 (EMPNUM INT);
INSERT INTO t1 VALUES (0), (2);
CREATE TABLE t2 (EMPNUM DECIMAL (4, 2));
INSERT INTO t2 VALUES (0.0), (9.0);
SELECT COALESCE(t2.EMPNUM,t1.EMPNUM) AS CEMPNUM,
                t1.EMPNUM AS EMPMUM1, t2.EMPNUM AS EMPNUM2
       FROM t1 LEFT JOIN t2 ON t1.EMPNUM=t2.EMPNUM;

SELECT IFNULL(t2.EMPNUM,t1.EMPNUM) AS CEMPNUM,
              t1.EMPNUM AS EMPMUM1, t2.EMPNUM AS EMPNUM2
       FROM t1 LEFT JOIN t2 ON t1.EMPNUM=t2.EMPNUM;

DROP TABLE t1,t2;
##
create table t1 (a int, b bigint unsigned);
create table t2 (c int);
insert into t1 (a, b) values (1,4572794622775114594), (2,18196094287899841997), (3,11120436154190595086);
insert into t2 (c) values (1), (2), (3);
select t1.a, (case t1.a when 0 then 0 else t1.b end) d from t1 join t2 on t1.a = t2.c order by d;
select t1.a, (case t1.a when 0 then 0 else t1.b end) d from t1 join t2 on t1.a = t2.c where b = 11120436154190595086 order by d;
drop table t1, t2;
##
CREATE TABLE t1(a int);
insert into t1 values(1);
SELECT 1 FROM t1 WHERE a=1 AND CASE 1 WHEN a THEN 1 ELSE 1 END;
DROP TABLE t1;

SELECT CASE timestamp '2015-01-01 01:01:01' WHEN ROUND( -1 ) THEN 1 END ;
SELECT CASE timestamp '2015-01-01 01:01:01' WHEN -1  THEN 1 END ;

create table t1(a varchar(10) collate utf8mb4_general_ci, 
cond1 varchar(10) collate utf8mb4_bin, 
cond2 varchar(10) collate utf8mb4_general_ci, 
val1 varchar(10) collate utf8mb4_bin,
val2 varchar(10) collate utf8mb4_bin);
insert into t1 values ('cond', 'COND', 'cond', 'hello', 'world');
insert into t1 values ('cond', 'cond', 'COND', 'hello', 'world');
insert into t1 values ('cond', 'COND', 'COND', 'hello', 'world');
insert into t1 values ('cond', 'cond', 'cond', 'hello', 'world');
insert into t1 values ('cond', 'bar', 'foo', 'hello', 'world');
select a, collation(a) from (select (case a when cond1 then val1 when cond2 then val2 else 'default_val' collate utf8mb4_bin end) as a from t1) tmp;
select a, collation(a) from (select (case a when cond1 then val1 when cond2 then val2 end) as a from t1) tmp;
drop table t1;
create table t1(a varchar(10) collate utf8mb4_general_ci, cond varchar(10) collate utf8mb4_general_ci, val varchar(10) collate utf8mb4_bin);
insert into t1 values ('cond', 'COND', 'val');
select a, collation(a) from (select (case a when cond then val else 'def_val' collate utf8mb4_bin end) as a from t1) tmp;
drop table t1;
create table t1(a varchar(10) collate utf8mb4_general_ci, 
cond1 varchar(10) collate utf8mb4_bin, 
cond2 varchar(10) collate utf8mb4_general_ci, 
val1 varchar(10) collate utf8mb4_general_ci,
val2 varchar(10) collate utf8mb4_bin);
insert into t1 values ('cond', 'cond', 'COND', 'hello', 'world');
insert into t1 values ('cond', 'COND', 'cond', 'hello', 'world');
insert into t1 values ('cond', 'COND', 'COND', 'hello', 'world');
insert into t1 values ('cond', 'cond', 'cond', 'hello', 'world');
insert into t1 values ('cond', 'bar', 'foo', 'hello', 'world');
select a, collation(a) from (select (case a when cond1 then val1 when cond2 then val2 else 'default_val' collate utf8mb4_bin end) as a from t1) tmp;
select a, collation(a) from (select (case a when cond1 then val1 when cond2 then val2 end) as a from t1) tmp;
drop table t1;

--echo
--echo // case when expr to type use conn collation, should use collation of result_type_
--disable_warnings
DROP TABLE if exists `cu_configfile`;
--enable_warnings
CREATE TABLE `cu_configfile` (
    `cpid` varchar(20) COLLATE utf8mb4_bin NOT NULL,
    `cuid` varchar(30) COLLATE utf8mb4_bin NOT NULL,
    `configfilename` varchar(50) COLLATE utf8mb4_bin NOT NULL,
    `comments` varchar(100) COLLATE utf8mb4_bin DEFAULT NULL,
    `format` varchar(1) COLLATE utf8mb4_bin DEFAULT NULL,
    `configtype` varchar(1) COLLATE utf8mb4_bin DEFAULT NULL,
    PRIMARY KEY (`cpid`, `cuid`, `configfilename`)
    );
select( case when a.cpid = '' then null else a.cpid end ) cpid from cu_configfile a 
union select( case when a.cpid = '' then null else a.cpid end ) cpid from cu_configfile a;


--echo case when with BIT type.
--disable_warnings
DROP TABLE if exists t, t1;
--enable_warnings
create table t(c1 bit(50));
insert into t values('123');
select * from t;
select cast(if( 0 , ref_0.c1 , ref_0.c1 ) as char) from t as ref_0;
select length(case when 1 = 1 then c1 else c1 end) from t;
select length(coalesce(c1, c1)) from t;
create table t1 as select case when 1 = 1 then c1 else c1 end c1 from t;
desc t1;
drop table t;

