#### owner group: sql2
#### description: 测试时间相关的函数

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--echo test time exprs such as hour, microsecond, year, week, and so on.
--echo test decimal parameter
--disable_warnings
drop table if exists test_time;
--enable_warnings
create table test_time(c1 decimal(30, 10));
insert into test_time values(1234);
insert into test_time values(2010.102);
insert into test_time values(2010.1020);
insert into test_time values(132515);
insert into test_time values(132515.123);
insert into test_time values(20210101112233);
insert into test_time values(20210101112233.123);
select c1, year(c1), quarter(c1), month(c1), monthname(c1), week(c1), weekofyear(c1), weekday(c1),
  yearweek(c1), hour(c1), minute(c1), second(c1), to_seconds(c1), microsecond(c1) from test_time;

drop table test_time;

--echo bugfix: 
--disable_warnings
drop table if exists t2;
--enable_warnings
create table t2(col_decimal decimal);
insert into t2 values(132515);
SELECT MICROSECOND(col_decimal) FROM t2;


