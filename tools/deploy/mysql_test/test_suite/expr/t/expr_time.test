--echo ##bugfix: 
connect (conn_admin, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn_admin;
sleep 2;
connection default;

select subtime(120000,'10000');
select subtime('2020-01-02 12:00:00',10000.5);
select subtime('121123', '12');

connection conn_admin;
sleep 2;
connection default;

--echo ##bugfix: 
drop table t2;
create table t2(col_tinyint tinyint);
insert into t2 values(23);

alter table t2 add column col_column time generated always as(SUBTIME(col_tinyint,31));
create index t2_index on t2(col_column);
drop table t2;


