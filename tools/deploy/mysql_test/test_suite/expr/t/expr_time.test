--echo bugfix: 
drop table t2;
create table t2(col_double double);
insert into t2 values(2010.102);
insert into t2 values(20101010.102);
insert into t2 values(201010101010.102);
SELECT MONTHNAME(col_double) FROM t2;


--echo bugfix: 
drop table t2;
create table t2(col_double double);
insert into t2 values(2010.102);
SELECT date_format(col_double,'%Y-%m-%d') FROM t2;
SELECT date_format(20200519172958.123456499,'%Y-%m-%d %T:%f') ;
SELECT date_format(20200519172958.123456500,'%Y-%m-%d %T:%f') ;

--echo bugfix: 
