#owner: zongmei.zzm

--disable_abort_on_error
--result_format 4

connect (conn_admin, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,oceanbase,$OBMYSQL_PORT);
connection conn_admin;
--sleep 2

connection default;

--disable_warnings
drop table if exists t;
drop table if exists t1;
drop table if exists t2;
--enable_warnings

create table t1(c1 int, c2 int, c3 int);
insert into t1 values(1, 2, 3);
insert into t1 values(1, 20, 30);
insert into t1 values(1, 200, 300);
insert into t1 values(2, 4, 5);
insert into t1 values(2, 40, 50);
insert into t1 values(2, 400, 500);
insert into t1 values(3, 7, 8);
insert into t1 values(3, 70, 80);
insert into t1 values(3, 700, 800);
create table t2(c1 int, c2 int);
insert into t2 values(1, 2);
insert into t2 values(3, 4);
insert into t2 values(1, 20);
insert into t2 values(3, 40);

SET sql_mode = 'ONLY_FULL_GROUP_BY';

select c2 from t1;
select any_value(c2) from t1;

select c2 from t1 group by c1;
select any_value(c2) from t1 group by c1;

select c2 + any_value(c3) from t1 group by c1;
select any_value(c2) + c3 from t1 group by c1;
select c1 + any_value(c2) + c3 from t1 group by c1;
select c1 + any_value(any_value(c2) + c3) from t1 group by c1;
select c1 + any_value(any_value(c3) + c3) + c3, c3 from t1 group by c1;

select c1 + any_value(c2) + sum(c3) from t1;
select c1 + any_value(c2) + sum(c3) from t1 group by c1;
select c1 + any_value(c2) + sum(c3) + c2 from t1 group by c1;
select c1 + sum(c2) + any_value(c3) from t1 group by c1;
select c1 + sum(c2) + any_value(c3) + c2 from t1 group by c1;
select any_value(c2 + sum(c2) + c3) from t1;
select any_value(c2 + sum(c2) + c3) from t1 group by c1;
select sum(any_value(c2) + c3) from t1 group by c1;
select any_value(c2 + sum(c3 + c2 + any_value(c2))) from t1 group by c1;
select any_value(c2 + sum(c3 + c2 + any_value(c2))), any_value(c2), c3 from t1 group by c1;

select c1, c2 from t1 where c1 > 1 group by c1;
select c1, any_value(c2) from t1 where c1 > 1 group by c1;
select c1, any_value(c2) + c3 from t1 where c1 > 1 group by c1;
select c1, any_value(c2), c3 from t1 where c1 > 1 group by c1;
select c1, any_value(c2) from t1 where any_value(c1)> 1 group by c1;
select c1, any_value(c2) from t1 where any_value(c2)> 1 group by c1;
select c1, any_value(c2) from t1 where any_value(c1) + c2 > 1 group by c1;
select c1, any_value(c2) from t1 where any_value(c2) + c2 > 1 group by c1;
select c1, any_value(c2) from t1 where any_value(c2 + c3) > 1 group by c1;
select c1, any_value(c2) from t1 where any_value(sum(c2) + c3) > 1 group by c1;
select c1, any_value(c2) from t1 where any_value(sum(c2 + c3) + c3) > 1 group by c1;

select any_value(c2 + c3) from t1 where EXISTS(select any_value(t1.c3) from t2) group by c1;
select any_value(c2 + c3) from t1 where EXISTS(select t1.c3 from t2) group by c1;
select any_value(c2 + c3) from t1 where EXISTS(select t1.c3 + any_value(t1.c2) from t2) group by c1;
select any_value(c2), c3 from t1 where EXISTS(select any_value(t1.c3) + any_value(t1.c2) from t2) group by c1;
select any_value(c2 + c3) from t1 where EXISTS(select sum(t1.c3) + sum(any_value(t1.c2)) from t2) group by c1;

select c2 from t1 group by c1 having sum(c2) > 10;
select any_value(c2) from t1 group by c1 having sum(c2) > 10;
select c2 from t1 group by c1 having any_value(c2) > 10;
select any_value(c2) from t1 group by c1 having any_value(c2) > 10;
select c2 from t1 group by c1 having any_value(c2) + c3 > 10;
select any_value(c2) from t1 group by c1 having any_value(c2) + c3 > 10;
select c2 from t1 group by c1 having sum(any_value(c2)) + any_value(c3) > 10;
select any_value(c2) from t1 group by c1 having any_value(sum(c2)) + c3 > 10;
select c2 from t1 group by c1 having any_value(c2) + sum(c3) + any_value(c3) + c3 > 10;
select any_value(c2) from t1 group by c1 having any_value(c2) + c3 + sum(c3) > 10;
select any_value(c2)+c3 from t1 group by c1 having any_value(c2) > 10;
select any_value(c2)+c3 from t1 group by c1 having sum(c2) > 10;
select any_value(c2), c3 from t1 group by c1 having any_value(c2) > 10;
select any_value(c2), c3 from t1 group by c1 having sum(c2) > 10;
                                              
select c1, any_value(c2) from t1 group by c1 order by c2;
select c1, any_value(c2) from t1 group by c1 order by any_value(c2);
select c1, any_value(c2) from t1 group by c1 order by any_value(c2) + c1;
select c1, any_value(c2) from t1 group by c1 order by any_value(c2) + c1, c3;
select c1, any_value(c2) from t1 group by c1 order by any_value(any_value(c2) + c1 + c3);
select c1, any_value(c2) from t1 group by c1 order by sum(any_value(c2) + c1 + c3);
select c1, any_value(c2) from t1 group by c1 order by any_value(sum(c2) + c1 + c3);     
                                              
select c1, any_value(c2), (select t1.c3 from t2) from t1 group by c1;
select c1, any_value(c2), any_value(select t1.c3 from t2) from t1;
select c1, any_value(c2), any_value(select t1.c3 from t2) from t1 group by c1;
select c2 from t1 where c2 < (select max(any_value(t1.c3)) from t2);
select c2 from t1 where c2 < (select max(any_value(t1.c3)) from t2) group by c1;
select c2 from t1 where c2 < (select any_value(max(t1.c3)) from t2);
select c2 from t1 where c2 < (select any_value(max(t1.c3)) from t2) group by c1;                                              
select any_value(c2) from t1 where c2 < (select max(any_value(t1.c3)) from t2) group by c1;
select any_value(c2) from t1 where c2 < (select max(t1.c3) from t2) group by c1;
                                              
select c1, sum(c2) from t1 group by c1 having sum(c2) = (select t1.c3 from t2);
select c1, sum(c2) from t1 group by c1 having sum(c2) = (select sum(t1.c3) from t2);
select c1, sum(c2) from t1 group by c1 having sum(c2) = (select any_value(t1.c3) from t2);
select c1, sum(c2) from t1 group by c1 having sum(c2) = (select any_value(sum(t1.c3) + c3 from t2);
select c1, sum(c2) from t1 group by c1 having sum(c2) = (select sum(any_value(t1.c3) + c3 from t1);
select c1, sum(c2) from t1 group by c1 having sum(c2) = (select any_value(t1.c3 + sum(t1.c2)) from t1);
                                                         
                                                         
