--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: luofan.zp
# # owner group: SQL2
# # description: 本case是为了测试format函数

--disable_warnings
drop database if exists lf_db;
drop table if exists t2;
drop table if exists t1;
--enable_warnings
create database lf_db;
use lf_db;

--disable_abort_on_error
set ob_query_timeout=10000000000;
set ob_trx_timeout=100000000000;

--echo #测试数据类型
select format(10, 0) from dual;
select format(10.12, 2) from dual;
select format(10.146, 2) from dual;
select format(10.146, 3) from dual;
select format('10', 0) from dual;
select format('10.12', 0) from dual;
select format('10.12', 1) from dual;

select format(-10, 0) from dual;
select format(-10.12, 2) from dual;
select format(-10.146, 2) from dual;
select format(-10.146, 3) from dual;
select format('-10', 0) from dual;
select format('-10.12', 0) from dual;
select format('-10.12', 1) from dual;

select format(' ', 4) from dual;
select format('  ', 4) from dual;

select format(null, 3) from dual;
select format(3, null) from dual;
select format(null, null) from dual;

--disable_warnings
select format('fasdfasdf', 4) from dual;
select format('567fasdfasdf', 4) from dual;

select format(date'2020-11-11 12:23:45', 0) from dual;
select format(date'2020-11-11 12:23:45', 1) from dual;
select format(3241234123412341234123.23412341234123, 20) from dual;
select format('', 0) from dual;
select format('', 20) from dual;

--echo #测试参数个数
--error 1582
select format(10) from dual;
--error 1582
select format(10, 0, 3, 5) from dual;

--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1 (c1 int, c2 int unsigned,
    c3 tinyint, c4 tinyint unsigned,
    c5 smallint, c6 smallint unsigned,
    c7 mediumint, c8 mediumint unsigned,
    c9 integer, c10 integer unsigned,
    c11 bigint, c12 bigint unsigned,
    c13 float, c14 float unsigned,
    c15 double, c16 double unsigned,
    c17 decimal(30, 20), c18 decimal(30, 20) unsigned,
    c19 datetime, c20 timestamp,
    c21 year, c22 date, c23 time,
    c24 varchar(30), c25 char(30),
    c26 varbinary(30),
    c27 enum("","0","1","2","3","5","6","7","8","9"),
    c28 set("","0","1","2","3","5","6","7","8","9"),
    c29 bit
    );

select * from t1;

insert into t1 values(1, 2,
    1, 2,
    1, 2,
    1, 2,
    1, 2,
    1, 2,
    3.1, 4.1,
    5.1, 6.1,
    7.1, 8.1,
    '2019-12-01 12:00:00', '2019-12-13 06:00:00',
    2020,'2020-01-01','12:34:56',
    '9.1', '10.1',
    '9.1',
    '0', '0',
    0);
insert into t1 values(-1, 2,
    -1, 2,
    -1, 2,
    -1, 2,
    -1, 2,
    -1, 2,
    -3.6, 4.6,
    -5.6, 6.6,
    -7.6, 8.6,
    '2019-12-11 12:00:00', '2019-12-03 06:00:00',
    2021,'2020-01-11','12:35:56',
    '-9.6', '10.6',
    '-9.6',
    '3', '3',
    1);

let $cnt=29;
let $left=1;
--disable_warnings
drop table if exists t2;
while ($left <= $cnt)
{
  let $dec=0;
  while ($dec <= 30)
  {
    eval select c$left, format(c$left, $dec) from t1;
    eval create table t2 as select format(c$left, $dec) as c$left from t1;
    eval desc t2;
    eval drop table if exists t2;

    inc $dec;
  }
  inc $left;
}

--echo #BUGFIX 
drop table if exists t2;
drop table if exists t1;
create table t1(c1 varbinary(500));
create table t2(c1 tinyint(4));
insert into t1 values('~_)88zF$');
insert into t2 values(99);
(select format(c1, 3) from t1) union (select c1 from t2);

drop table if exists t2;
drop table if exists t1;
drop database lf_db;


