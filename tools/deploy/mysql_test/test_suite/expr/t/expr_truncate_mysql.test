--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#### owner: peihan.dph
#### owner group: SQL1
#### Test TRUNCATE function

--error 1582
select truncate();
--error 1582
select truncate(1);
--error 1582
select truncate(1, 2, 3);

--enable_metadata

select truncate(1.234, 1);
select truncate(1.234, 5);
select truncate(123.34, -1);
select truncate(123.34, -3);
select truncate(123.34, -2);

select truncate(123.345, 1.6);
select truncate(123.345, 1.2);
select truncate(123.345, -1.6);
select truncate(123.345, -1.2);
select truncate(123.345, 1.5);
select truncate(123.345, -1.5);

select truncate(null, 1);
select truncate(1, null);
select truncate(null, null);

select truncate(123456789012345678901234567890123456789, 10);
select truncate(1.2345678901234567890123456789012345679, 10);

select truncate('h', 2);
select truncate(2.23, 'h');
select truncate('2018-07-09', 2);

use test;
--disable_warnings
drop table if exists trunctypes;
--enable_warnings

create table trunctypes (
    c_bit BIT,
    c_tiny TINYINT,
    c_bool BOOL,
    c_small SMALLINT,
    c_medium MEDIUMINT,
    c_int INT,
    c_big BIGINT,
    c_dec DEC(65, 0),
    c_float FLOAT,
    c_double DOUBLE,
    c_datetime DATETIME,
    c_date DATE,
    c_time TIME,
    c_timestamp TIMESTAMP,
    c_year YEAR,
    c_char char(10),
    c_varchar VARCHAR(55),
    c_binary BINARY(10),
    c_varbinary VARBINARY(10),
    c_unsigned_tiny tinyint unsigned,
    c_unsigned_small smallint unsigned,
    c_unsigned_medium mediumint unsigned,
    c_unsigned_int int unsigned,
    c_unsigned_big bigint unsigned,
    c_unsigned_dec decimal(65, 0) unsigned,
    c_unsigned_float float unsigned,
    c_unsigned_double double unsigned
);

insert into trunctypes values (
    1,
    2,
    true,
    3,
    4,
    5,
    6,
    7,
    7.1,
    7.2,
    "2018-07-09 10:00:01",
    "2018-07-09",
    "10:00:01",
    "2018-07-09 10:00:11",
    "2018",
    "hello",
    "hi there",
    "10",
    "10",
    2,
    4,
    5,
    6,
    7,
    7.1,
    7.2,
    7.3
);

select truncate(c_bit, -1),
       truncate(c_tiny, -1),
       truncate(c_tiny, -1),
       truncate(c_small, -1),
       truncate(c_medium, -1),
       truncate(c_int, -1),
       truncate(c_big, -1),
       truncate(c_dec, -1),
       truncate(c_float, -1),
       truncate(c_double, -1),
       truncate(c_datetime, -1),
       truncate(c_date, -1),
       truncate(c_time, -1),
       truncate(c_timestamp, -1),
       truncate(c_year, -1),
       truncate(c_char, -1),
       truncate(c_varchar, -1),
       truncate(c_binary, -1),
       truncate(c_varbinary, -1),
       truncate(c_unsigned_tiny, -1),
       truncate(c_unsigned_small, -1),
       truncate(c_unsigned_medium, -1),
       truncate(c_unsigned_int, -1),
       truncate(c_unsigned_big, -1),
       truncate(c_unsigned_dec, -1),
       truncate(c_unsigned_float, -1),
       truncate(c_unsigned_double, -1)
       from trunctypes;

select truncate(c_bit, 5),
       truncate(c_tiny, 5),
       truncate(c_tiny, 5),
       truncate(c_small, 5),
       truncate(c_medium, 5),
       truncate(c_int, 5),
       truncate(c_big, 5),
       truncate(c_dec, 5),
       truncate(c_float, 5),
       truncate(c_double, 5),
       truncate(c_datetime, 5),
       truncate(c_date, 5),
       truncate(c_time, 5),
       truncate(c_timestamp, 5),
       truncate(c_year, 5),
       truncate(c_char, 5),
       truncate(c_varchar, 5),
       truncate(c_binary, 5),
       truncate(c_varbinary, 5),
       truncate(c_unsigned_tiny, 5),
       truncate(c_unsigned_small, 5),
       truncate(c_unsigned_medium, 5),
       truncate(c_unsigned_int, 5),
       truncate(c_unsigned_big, 5),
       truncate(c_unsigned_dec, 5),
       truncate(c_unsigned_float, 5),
       truncate(c_unsigned_double, 5)
       from trunctypes;

select truncate(12345.12345, c_bit),
       truncate(12345.12345, c_tiny),
       truncate(12345.12345, c_bool),
       truncate(12345.12345, c_small),
       truncate(12345.12345, c_medium),
       truncate(12345.12345, c_int),
       truncate(12345.12345, c_big),
       truncate(12345.12345, c_dec),
       truncate(12345.12345, c_float),
       truncate(12345.12345, c_double),
       truncate(12345.12345, c_datetime),
       truncate(12345.12345, c_date),
       truncate(12345.12345, c_time),
       truncate(12345.12345, c_timestamp),
       truncate(12345.12345, c_year),
       truncate(12345.12345, c_char),
       truncate(12345.12345, c_varchar),
       truncate(12345.12345, c_binary),
       truncate(12345.12345, c_varbinary),
       truncate(12345.12345, c_unsigned_tiny),
       truncate(12345.12345, c_unsigned_small),
       truncate(12345.12345, c_unsigned_medium),
       truncate(12345.12345, c_unsigned_int),
       truncate(12345.12345, c_unsigned_big),
       truncate(12345.12345, c_unsigned_dec),
       truncate(12345.12345, c_unsigned_float),
       truncate(12345.12345, c_unsigned_double)
       from trunctypes;


select truncate(c_bit, c_tiny),
       truncate(c_tiny, c_small),
       truncate(c_small, c_medium),
       truncate(c_medium, c_big),
       truncate(c_big, c_dec),
       truncate(c_dec, c_float),
       truncate(c_float, c_double),
       truncate(c_double, c_datetime),
       truncate(c_datetime, c_date),
       truncate(c_date, c_time),
       truncate(c_time, c_timestamp),
       truncate(c_year, c_char),
       truncate(c_char, c_varchar),
       truncate(c_varchar, c_binary),
       truncate(c_binary, c_varbinary),
       truncate(c_varbinary, c_binary),
       truncate(c_binary, c_varbinary),
       truncate(c_varbinary, c_unsigned_tiny),
       truncate(c_unsigned_tiny, c_unsigned_small),
       truncate(c_unsigned_small, c_unsigned_medium),
       truncate(c_unsigned_medium, c_unsigned_int),
       truncate(c_unsigned_int, c_unsigned_big),
       truncate(c_unsigned_big, c_unsigned_dec),
       truncate(c_unsigned_dec, c_unsigned_float),
       truncate(c_unsigned_float, c_unsigned_double)
       from trunctypes;
--echo #
select truncate((( row_number() over() -1)/5),0) from dual;


