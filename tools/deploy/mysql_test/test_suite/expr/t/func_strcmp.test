--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: yibo.tyf
#owner group: sql1
#description: test math function

select strcmp(1,2);
select strcmp(2,2);
select strcmp(3,2);
select strcmp(18446744073709551615, 18446744073709551616);
select strcmp(18446744073709551616, 18446744073709551616);
select strcmp("18446744073709551616", 18446744073709551616);
select strcmp(18446744073709551616.0, "18446744073709551616");
select strcmp("asadasd", 123);
select strcmp("oceanbase", "oceanbase");
select strcmp("oceanbasd", "oceanbase");
select strcmp("oceanbasf", "oceanbase");
select strcmp("a12", 123);
select strcmp(12, 123);
select strcmp(12.1, 13);
select strcmp("12.1", 13);
select strcmp(null, 1212);
select strcmp("asas", null);
select strcmp(null, null);
--disable_warnings
drop table if exists sb;
select strcmp(1E108,1e108);
create table sb(a bigint(12) zerofill, b int(12) zerofill);
insert into sb values(1,1);
insert into sb values(1,0);
insert into sb values(0,0);
insert into sb values(0,1);
select strcmp(a, b) from sb;
drop table sb;
create table sb(a bigint(12), b int(12));
insert into sb values(1,1);
insert into sb values(1,0);
insert into sb values(0,0);
insert into sb values(0,1);
select strcmp(a, b) from sb;
drop table sb;
create table sb(a varchar(10) collate utf8mb4_general_ci, b binary(123), c varchar(10) collate utf8mb4_bin);
insert into sb values("hello","Hello","Hello");
insert into sb values("Hello","Hello","hello");
insert into sb values("Hello","hello","Hello");
select strcmp(a, b) from sb;
select strcmp(a, c) from sb;
select strcmp(b, c) from sb;
select strcmp(a, "hello") from sb;
select strcmp(b, "hello") from sb;
select strcmp(c, "hello") from sb;
select strcmp(a, "Hello") from sb;
select strcmp(b, "Hello") from sb;
select strcmp(c, "Hello") from sb;
drop table sb;
