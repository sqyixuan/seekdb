--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: zhenling.zzg
# owner group: SQL3
# Test of functions monthname
# tags: expr, time

--echo ## test invalid paramter number
--error 1582
select monthname();
--error 1582
select monthname('1','1');
--error 1582
select monthname(1,1);
--error 1582
select monthname('2019-06-10 12:11:12', '2019-06-10 12:11:12');

--echo ## test invalid paramter
select monthname('中文');
select monthname(null);
select monthname(1);

--echo ## test incompelete time format
select monthname('2019-06-10');
select monthname('2019-06');
select monthname('12:11:12');

--echo ## test w/o '' & w/ ""
--error 1064
select monthname(2019-06-10 12:11:12);
select monthname("2019-06-10 12:11:12");

--echo ## test normal cases
select monthname('2019-01-10 12:11:12');
select monthname('2019-02-10 12:11:12');
select monthname('2019-03-10 12:11:12');
select monthname('2019-04-10 12:11:12');
select monthname('2019-05-10 12:11:12');
select monthname('2019-06-10 12:11:12');
select monthname('2019-07-10 12:11:12');
select monthname('2019-08-10 12:11:12');
select monthname('2019-09-10 12:11:12');
select monthname('2019-10-10 12:11:12');
select monthname('2019-11-10 12:11:12');
select monthname('2019-12-10 12:11:12');

--echo ## test invalid month value
select monthname('2019-00-10 12:11:12');
select monthname('2019-13-10 12:11:12');

--echo ## test invalid day value
select monthname('2019-10-00');
select monthname('2019-00-00');

--echo ## test February corner cases
select monthname('2012-02-00');
select monthname('2012-02-29');
select monthname('2010-02-29');
select monthname('2010-02-30');
select monthname('2012-02-30');

--echo ## test collation level: 
select monthname(str_to_date(null, '%m')), monthname(str_to_date(null, '%m')), monthname(str_to_date(1, '%m')), monthname(str_to_date(0, '%m'));

# for solving core bug bucause of the monthname function exsiting in where-subquery
--disable_warnings
drop table if exists t1, t2;
--enable_warnings
create table t1 (c1 TINYINT,c2 SMALLINT,c3 MEDIUMINT);
insert into  t1 values(22,621,0721);
insert into  t1 values(22,821,0921);
SELECT * FROM t1 WHERE monthname(c2);
SELECT * FROM t1 WHERE monthname(c2) = 'June';

create table t2 (c1 int ,c2 varchar(20),c3 date);
insert into t2 values(1,'test01','20220907');
insert into t2 values(2,'test02','20220909');
insert into t2 values(3,'test03','2022-08-20');
insert into t2 values(4,'test04','2022-09-15');
insert into t2 values(5,'test05','2022-09-16');
select t2.*, monthname(c3) from t2 where monthname(c3)='Friday';
SELECT * FROM t2 WHERE monthname(c3) = 'September';

drop table t1, t2;