##操作数都是字面常量
select 1+3;
select 1+3.4444;
select 3.4444+1;
select 1.111+3.3333;
select 3.33+1.111111;
select 1+"2.333";
select "2.333"+1;
select 1+"-3.3";
select "2.22"+"33.33456";
select 4294967295 + 1.0;
select 1.0+4294967295;
select 4294967294 + 1.222;
select 1.222+4294967294;
select 4294967295 + "1.0";
select "1.0"+4294967295;
select 4294967294 + "1.222";
select "1.222"+4294967295;
select 4294967295 + "-1.0";
select "-1.0"+4294967295;
select 4294967294 + "-1.222";
select "-1.222"+4294967295;
select -9223372036854775807 + 1.22;
select 1.22+-9223372036854775807;
select -9223372036854775807 + "1.22";
select "1.22"+-9223372036854775807;
select -9223372036854775807 + "-1.22";
select 9223372036854775807 + 1.22;
select 9223372036854775807 + 3.333333;
select 9223372036854775807 + "-1.22";
select 9223372036854775807 + "3.333333";
select 18446744073709551615 + "1.0";
select 18446744073709551615 + "1.222";
select 18446744073709551615 + "-1.0";
select 18446744073709551615 + "-1.222";
select 18446744073709551616 + "1.0";
select 18446744073709551616 + "1.222";
select 18446744073709551616 + "-1.0";
select 18446744073709551616 + "-1.222";
select "1.22"+"18446744073709551616";
select "18446744073709551616"+"18446744073709551616";
##操作数都来源于列
create table sb(a int, b bigint, c bigint unsigned, d decimal, e decimal(5,3), f decimal(7,6));
insert into sb values(1,2,3,4.1,5.22,6.333);
insert into sb values(2,-1234,1234,4.122,5.22222,6.3);
insert into sb values(-3,2,3,4.1,5.22,-6.333);
insert into sb values(4,-1234,1234,4.122,-5.22222,6.3);
insert into sb values(5,2,3,4.1,-5.01,6.333);
insert into sb values(6,-1234,1234,4.0000000,5.22222,6.3);
select a+b,a+c,a+d,a+e,a+f from sb;
select b+a,b+c,b+d,b+e,b+f from sb;
select c+a,c+b,c+d,c+e,c+f from sb;
select d+a,d+b,d+c,d+e,d+f from sb;
select e+a,e+b,e+c,e+d,e+f from sb;
select f+a,f+b,f+c,f+d,f+e from sb;
##select a+b+c,a+b+d,a+b+e,a+b+f from sb;
##select b+a+c,b+a+d,b+a+e,b+a+f from sb;
select e+a+b,e+a+c,e+a+d,e+a+f from sb;
select f+e+a,f+e+b,f+e+c,f+e+d from sb;
select a+c+b,a+c+d,a+c+e,a+c+f from sb;
##部分操作数来源于列
select 1.00+a,1.00+b,1.00+c,1.00+d,1.00+e,1.00+f from sb;
select a+1.00,b+1.00,c+1.00,d+1.00,e+1.00,f+1.00 from sb;
select "1.00"+a,"1.00"+b,"1.00"+c,"1.00"+d,"1.00"+e,"1.00"+f from sb;
select a+"1.00",b+"1.00",c+"1.00",d+"1.00",e+"1.00",f+"1.00" from sb;
select 1234+a,1234+b,1234+c,1234+d,1234+e,1234+f from sb;
select a+1234,b+1234,c+1234,d+1234,e+1234,f+1234 from sb;
select -1234+d,-1234+e,-1234+f from sb;
drop table sb;
