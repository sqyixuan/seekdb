##操作数都来源于列
create table sb(a int, b bigint, c bigint unsigned, d decimal, e decimal(5,3), f decimal(7,6));
insert into sb values(1,2,3,4.1,5.22,6.333);
insert into sb values(2,-1234,1234,4.122,5.22222,6.3);
insert into sb values(-3,2,3,4.1,5.22,-6.333);
insert into sb values(4,-1234,1234,4.122,-5.22222,6.3);
insert into sb values(5,2,3,4.1,-5.01,6.333);
insert into sb values(6,-1234,1234,4.0000000,5.22222,6.3);
select a-b,a-d,a-e,a-f from sb;
select b-a,b-d,b-e,b-f from sb;
select c-d,c-e,c-f from sb;
select d-a,d-b,d-c,d-e,d-f from sb;
select e-a,e-b,e-c,e-d,e-f from sb;
select f-a,f-b,f-c,f-d,f-e from sb;
select e-a-b,e-a-c,e-a-d,e-a-f from sb;
select f-e-a,f-e-b,f-e-c,f-e-d from sb;
##部分操作数来源于列
select 1.00-a,1.00-b,1.00-c,1.00-d,1.00-e,1.00-f from sb;
select a-1.00,b-1.00,c-1.00,d-1.00,e-1.00,f-1.00 from sb;
select "1.00"-a,"1.00"-b,"1.00"-c,"1.00"-d,"1.00"-e,"1.00"-f from sb;
select a-"1.00",b-"1.00",c-"1.00",d-"1.00",e-"1.00",f-"1.00" from sb;
select 1234-a,1234-b,1234-c,1234-d,1234-e,1234-f from sb;
select a-1234,b-1234,d-1234,e-1234,f-1234 from sb;
select -1234-d,-1234-e,-1234-f from sb;
drop table sb;
