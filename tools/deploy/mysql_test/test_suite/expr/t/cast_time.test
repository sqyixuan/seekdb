#### owner: dachuan.sdc
#### owner group: sql2
#### description: test cast between time/date/datetime/year type

set timestamp = 1600000000;
--echo bugfix: 
--echo cast time to date
--disable_warnings
drop table if exists t0;
--enable_warnings


--echo bugfix: 
CREATE TABLE t0(z0_test0 DATE);
select cast(111.11111 as date);
--error 1292
INSERT INTO t0 (z0_test0)values(111.11111);
drop table t0;


CREATE TABLE t0(z0_test0 TIME, z0_test1 char(50), z0_test2 date);
INSERT INTO t0 (z0_test0,z0_test1)values(NULL,NULL);
INSERT INTO t0 (z0_test0,z0_test1)values(111,222);
INSERT INTO t0 (z0_test0,z0_test1)values(111.1111,222);

select cast(z0_test0 as date) from t0;
update t0 set z0_test2 = z0_test0;
select * from t0;
drop table t0;


--echo cast year to date
create table t0(c1 year, c2 date);
insert into t0(c1) values(0);
select cast(c1 as date) from t0;
update t0 set c2 = c1;
select * from t0;

delete from t0;
insert into t0(c1) values(1);
select cast(c1 as date) from t0;
--error 1292
update t0 set c2 = c1;

delete from t0;
--error 1264
insert into t0(c1) values(100);
insert into t0(c1) values(2000);
select cast(c1 as date) from t0;
--error 1292
update t0 set c2 = c1;

drop table t0;
