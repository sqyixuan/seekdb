--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#### owner: dingjincheng.djc
#### owner group: sql1
# tags: optimizer
#### description: 测试包含向量IN谓词的语句估计行数，由于目前在估行之前有一部分逻辑会估出更小的行，所以目前估出的行数不会发生变化，这部分case之后预期要发生变化，和普通列的IN行为保持一致。


--disable_warnings
drop table if exists t1,t2,t3;
--enable_warnings

# 发现BUG的case
create table t1(a bigint, b bigint, c bigint, primary key(a,b,c));
explain extended_noaddr select * from t1 where (a,b,c) in ((1,1,2), (2,3,4));

create table t2(a bigint, b bigint, c bigint, d bigint, e bigint, f bigint, primary key(a,b,c), key(d,e));
create table t3(a bigint, b bigint, c bigint, d bigint, e bigint, f bigint, primary key(a,b,c), key(d,e,f));

# estimated number of rows should be 2
explain select/*+index(t1 d)*/ * from t2 where (d,e) in ((1,2),(2,3));

# estimated number of rows should be 3
explain select * from t2 where (d,e) in ((1,2),(2,3),(3,4));

# this case is not supposed to be changed since not all vectors are of same expr_type
explain select * from t2 where (d,e) in ((1,2),(e,3),(3,4));

# estimated number of rows should be 2
explain select * from t3 where (d,e,f) in ((1,2,3),(2,3,9));

# estimated number of rows should be 3
explain select * from t3 where (d,e,f) in ((1,2,3),(2,3,9),(6,7,8));

# this case is not supposed to be changed since not all vectors are of same expr_type
explain select * from t3 where (d,e,f) in ((7,1,2),(e,3,2),(2,3,4));

# this case is not supposed to be changed since not all vectors are of same expr_type
explain select * from t3 where (d,e,f) in ((7,1,2),(d+e+f,3,2),(2,3,4));

drop table t1,t2,t3;
