# owner:wuyuming.wym
# owner group:sql1
# tags:funcs, expr, datatype
# description: icu_version()

select icu_version() from dual;
--error 1582
select icu_version(1) from dual;
select icu_version() from dual where 1=0;
select name_const(icu_version(), 1) from dual;
select name_const(1, icu_version()) from dual;

select icu_version()>="60";
select icu_version()>=_utf8"60";
select charset(icu_version());
select length(icu_version());
select coercibility(icu_version());

--disable_warnings
drop table if exists t;
--enable_warnings
create table t(a int, b varchar(20), c char(1));

insert into t values (1, icu_version(), '2');
--error 1406
insert into t values (2, icu_version(), icu_version());
insert into t values (3, null, '');

select * from t where b = icu_version();
select count(*) from t group by icu_version();
select * from t having lnnvl(b <> icu_version());
select icu_version() from t;
select concat(c, icu_version()) from t;

drop table t;