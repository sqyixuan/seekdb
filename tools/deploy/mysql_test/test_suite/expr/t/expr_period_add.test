# owner group: SQL2
# Test of function period_add

--error 1054
select period_add;
--error 1582
select period_add();
--error 1582
select period_add(1);
--error 1582
select period_add(1, 2, 3);


--disable_warnings
drop table if exists t1, t2, t3;
drop view if exists v1;
--enable_warnings

create table t1(c1 int);
create table t2(d1 int);
insert into t1 values(-1), (0), (1), (2), (10), (100), (1010), (2010),(11111), (12345), (111111), (200011), (999912);
insert into t2 values(-1000), (-1), (0), (1), (2), (10), (20), (100), (999), (10000), (10000000);
select c1, d1, period_add(c1, d1) from t1, t2 order by c1, d1;
create table t3 as select c1, d1, period_add(c1, d1) from t1, t2 order by c1, d1;
create view v1 as select c1, d1, period_add(c1, d1) from t1, t2 order by c1, d1;
desc t3;
desc v1;
select * from t3;
show create view v1;

select period_add(100101, -1);
select period_add(100101, -2);
select period_add(100101, -10812);
select period_add(100101, -11172);
select period_add(100101, -11173);
select period_add(100101, -12000);
select period_add(100101, -12011);
select period_add(100101, -12012);
select period_add(100101, -12013);
select period_add(100101, -12014);
select period_add(100101, -12023);
select period_add(100101, -12024);
select period_add(100101, -12025);
select period_add(100101, -12026);


select period_add('000101', 3);
select period_add(1010.5, 1.5);
select period_add('1010.5', '1.5');
drop table t1, t2, t3;
drop view v1;