## --enable_metadata
# metadata checked by eyes
select ltrim(null);

select ltrim('');
select length(ltrim(''));

select ltrim('  ');
select length(ltrim('  '));

select ltrim('a');
select length(ltrim('a'));
select ltrim('  a');
select length(ltrim('  a'));
select ltrim('a  ');
select length(ltrim('a  '));
select ltrim('  a  ');
select length(ltrim('  a  '));

select ltrim('中文');
select length(ltrim('中文'));
select ltrim('  中文');
select length(ltrim('  中文'));
select ltrim('中文  ');
select length(ltrim('中文  '));
select ltrim('  中文  ');
select length(ltrim('  中文  '));

--disable_warnings
create database if not exists test;
use test;

drop table if exists AllTypes;
--enable_warnings

CREATE TABLE AllTypes(
c_bool      BOOLEAN,
c_int       INTEGER,
c_char      CHAR(10),
c_varchar   VARCHAR(10),
c_binary    BINARY(10),
c_varbinary VARBINARY(10));

insert AllTypes values(true, 01, 'a', 'a', hex('a'), hex('a'));
insert AllTypes values(false, 2, '  a', '  a', hex('  a'), hex('  a'));
insert AllTypes values(false, 3, 'a  ', 'a  ', hex('a  '), hex('a  '));
insert AllTypes values(false, 3, '  a  ', '  a  ', hex('  a  '), hex('  a  '));

select ltrim(c_bool), ltrim(c_int), ltrim(c_char), ltrim(c_varchar), ltrim(c_binary), ltrim(c_varbinary) from AllTypes;
## --disable_metadata
