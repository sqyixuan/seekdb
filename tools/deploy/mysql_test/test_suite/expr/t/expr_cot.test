--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: laibingzheng.lbz
# owner group: SQL2
# 测试mysql模式下的cot表达式

--disable_warnings
drop table if exists t1;
--enable_warnings

# 正常功能测试
select cot(1);
select cot(-1);
select cot(0.1);
select cot(-0.1);
select cot(1000);
select cot(-1000);
select cot(null);

# 测试不同周期的
select cot(0.7 +   3.141592653589793238462643383);
select cot(1.7 +   3.141592653589793238462643383);
select cot(0.7 +   2*3.141592653589793238462643383);
select cot(1.7 +   2*3.141592653589793238462643383);
select cot(-(0.7 + 3.141592653589793238462643383));
select cot(-(1.7 + 3.141592653589793238462643383));
select cot(-(0.7 + 2*3.141592653589793238462643383));
select cot(-(1.7 + 2*3.141592653589793238462643383));

#  测试不同周期，而且比较大的数(10000倍)
select cot(0.7 +   100000 * 3.141592653589793238462643383);
select cot(1.7 +   100000 * 3.141592653589793238462643383);
select cot(0.7 +   100000 * 2*3.141592653589793238462643383);
select cot(1.7 +   100000 * 2*3.141592653589793238462643383);
select cot(-(0.7 + 100000 * 3.141592653589793238462643383));
select cot(-(1.7 + 100000 * 3.141592653589793238462643383));
select cot(-(0.7 + 100000 * 2*3.141592653589793238462643383));
select cot(-(1.7 + 100000 * 2*3.141592653589793238462643383));
 
# 非法参数测试
--error 1582
select cot();
--error 1582
select cot(1, 0, 2, 1);
--error 1264
select cot('abcdef');

# 这个结果和mysql略微有出入，是在小数点后十八位出现不同(显示结果的最后一位)
#     2^64 - 1
select cot(18446744073709551615);
#     -2^63 + 1 
select cot(-9223372036854775807);
select cot(1e20);
select cot(1e20 + 5);

# 下面这些很大的数字结果都不准确，但是相对Oracle来说精度要更高
#  这个和mysql结算结果一致
select cot(123456789012345678901234567890123456789);
#  这个和mysql结算结果一致
select sin(1234567890123456789012345678901234567890) from dual;
# 结算结果和mysql一致
select sin(12345678901234567890123456789012345678901) from dual;
#   参数很小
#     小数点后有40位数字，和mysql一致
select cot(.0000000000000000000000000000000000000001);
select cot(-0.0000000000000000000000000000000000000001);
select cot(.000000000000000000000000000000000000000000000000001);
select cot(-0.000000000000000000000000000000000000000000000000001);

#   π，精确到小数点后150位, 和mysql一致
select cot(3.141592653589793238462643383279502884197169399375105820974944592307816406286208998628034825342117067982148086513282306647093844609550582231725359408128);
select cot(-3.141592653589793238462643383279502884197169399375105820974944592307816406286208998628034825342117067982148086513282306647093844609550582231725359408128);
select cot('3.141592653589793238462643383279502884197169399375105820974944592307816406286208998628034825342117067982148086513282306647093844609550582231725359408128');
select cot('-3.141592653589793238462643383279502884197169399375105820974944592307816406286208998628034825342117067982148086513282306647093844609550582231725359408128');

#   π/2，精确到小数点后150位
select cot(1.570796326794896619231321691639751442098584699687552910487472296153908203143104499314017412671058533991074043256641153323546922304775291115862679704064);
select cot(-1.570796326794896619231321691639751442098584699687552910487472296153908203143104499314017412671058533991074043256641153323546922304775291115862679704064);
select cot('1.570796326794896619231321691639751442098584699687552910487472296153908203143104499314017412671058533991074043256641153323546922304775291115862679704064');
select cot('-1.570796326794896619231321691639751442098584699687552910487472296153908203143104499314017412671058533991074043256641153323546922304775291115862679704064');

create table t1 (c1 int,
 c2 TINYINT, 
 c3 double, 
 c4 float, 
 c5 DATE, 
 c6 TIMESTAMP, 
 c7 CHAR,
 c8 blob);

insert into t1 values (1, 2, 2.222, -1.333, date '2019-04-17', timestamp '2019-04-17 10:10:10.000000', 'e', 'aasdasd');

select cot(c1) from t1;
select cot(c2) from t1;
select cot(c3) from t1;
select cot(c4) from t1;
select cot(c5) from t1;
select cot(c6) from t1;
--error 1264
select cot(c7) from t1;
--error 1264
select cot(c8) from t1;
drop table t1;
