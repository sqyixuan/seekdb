# Test of functions convert_tz


--echo ================ expression convert_tz ================
--source mysql_test/test_suite/otimestamp/t/otimestamp_import_time_zone_mysql.inc
# 直接时刻类型
SELECT CONVERT_TZ('2021-01-01 12:00:00','+00:00','+08:00');
SELECT CONVERT_TZ('2021-01-01 12:00:00','+01:00','+08:00');
SELECT CONVERT_TZ('2021-01-01 12:00:00','+01:00','+06:30');
SELECT CONVERT_TZ('2021-01-01 12:00:00','+01:00','+10:10');
SELECT CONVERT_TZ('2021-01-01 12:00:00','+01:30','+13:00');
SELECT CONVERT_TZ('2021-01-01 12:00:00','-11:30','+13:00');
SELECT CONVERT_TZ('2021-01-01 12:00:00','-12:00','+13:00');
SELECT CONVERT_TZ('2021-01-01 00:00:00','-12:00','+13:00');
SELECT CONVERT_TZ('2021-01-01 23:59:59','-12:00','+13:00');
SELECT CONVERT_TZ('2021-01-01 13:19:38','-10:38','+10:12');
SELECT CONVERT_TZ('2021-01-01 12:23:35','-09:23','-11:11');
SELECT CONVERT_TZ('2021-01-01 00:01:00','+10:00','-11:00');
SELECT CONVERT_TZ('2021-01-01 00:11:00','+00:00','-11:00');
SELECT CONVERT_TZ('2021-03-01 00:11:00','+00:00','-11:00');
SELECT CONVERT_TZ('2021-06-01 00:11:00','+00:00','-11:00');
SELECT CONVERT_TZ('2020-03-01 00:11:00','+00:00','-11:00');
SELECT CONVERT_TZ('2020-02-28 23:11:00','-00:00','+11:00');
SELECT CONVERT_TZ('2020-12-31 23:11:00','-05:00','+11:00');

#直接时刻类型异常
SELECT CONVERT_TZ('2020-12-31 23:11:00',null,'+11:00');
SELECT CONVERT_TZ('2020-12-31 23:11:00','+11:00', null);
SELECT CONVERT_TZ(null,'-13:00','+11:00');
SELECT CONVERT_TZ(null, null,'+11:00');
SELECT CONVERT_TZ(null, null, null);

#时区类型
SELECT CONVERT_TZ('2020-12-31 23:11:00','America/Merida','Asia/Tokyo');
SELECT CONVERT_TZ('2021-01-01 00:11:00','America/Merida','Australia/Darwin');
SELECT CONVERT_TZ('2021-01-01 00:11:00','America/Merida','Europe/Amsterdam');
SELECT CONVERT_TZ('2021-01-01 07:11:00','Europe/Amsterdam','America/Merida');
SELECT CONVERT_TZ('2021-01-01 07:11:00','MET','Libya');
SELECT CONVERT_TZ('2021-01-01 07:11:00','MET','MST');
SELECT CONVERT_TZ('2021-01-01 07:11:00','PRC','MST');
SELECT CONVERT_TZ('2021-01-01 07:11:00','PRC','ROC');
SELECT CONVERT_TZ('2021-01-01 07:11:00','UCT','ROC');
SELECT CONVERT_TZ('2021-01-01 07:11:00','Universal','ROC');
SELECT CONVERT_TZ('2021-01-01 07:11:00','Pacific/Marquesas','ROC');
SELECT CONVERT_TZ('2021-02-28 17:11:00','GMT+0','ROC');
SELECT CONVERT_TZ('2021-02-28 17:11:00','GMT+0','Singapore');
SELECT CONVERT_TZ('2021-02-28 17:11:00','US/Michigan','ROC');

#时区类型异常
SELECT CONVERT_TZ('2021-02-28 17:11:00', null,'ROC');
SELECT CONVERT_TZ('2021-02-28 17:11:00','US/Michigan', null);
SELECT CONVERT_TZ('2021-02-28 17:11:00', null, null);

#混合类型
SELECT CONVERT_TZ('2021-02-28 17:11:00', '+00:00','ROC');
SELECT CONVERT_TZ('2021-02-28 17:11:00', '+00:00','US/Michigan');
SELECT CONVERT_TZ('2021-02-28 17:11:00', 'ROC','+00:00');
SELECT CONVERT_TZ('2021-02-28 17:11:00', 'US/Michigan', '+00:00');
SELECT CONVERT_TZ('2021-02-28 17:11:00', 'ROC','+12:58');
SELECT CONVERT_TZ('2021-01-01 07:11:00', 'UCT','-12:58');
SELECT CONVERT_TZ('2021-01-01 07:11:00', '-12:58','UCT');
SELECT CONVERT_TZ('2021-01-01 07:11:00', '-12:58','US/Michigan');
SELECT CONVERT_TZ('2021-01-01 07:11:00', '+05:12','MET');
SELECT CONVERT_TZ('2021-01-01 07:11:00', '+03:32','PRC');
SELECT CONVERT_TZ('2021-01-01 07:11:00', '+11:32','PRC');

##bugfix: 
SELECT CONVERT_TZ('2004-01-01 12:00:00','-13:00','+10:00');
SELECT CONVERT_TZ('2004-01-01 12:00:00','-12:00','+14:00');
SELECT CONVERT_TZ('2004-01-01 12:00:00','-13:00','ABC');
SELECT CONVERT_TZ('2004-01-01 12:00:00','-12:00','OK');
--disable_warnings
drop table if exists t;
--enable_warnings
create table t(c1 timestamp);
insert into t values(CONVERT_TZ('2004-01-01 12:00:00','-13:00','+10:00'));
insert into t values(CONVERT_TZ('2004-01-01 12:00:00','-12:00','+14:00'));
insert into t values(CONVERT_TZ('2004-01-01 12:00:00','-13:00','ABC'));
insert into t values(CONVERT_TZ('2004-01-01 12:00:00','-12:00','OK'));
select * from t;
delete from t;

## test result out of range
select convert_tz('9999-12-31 20:00:00', '+02:00', '+06:00');
select convert_tz('0000-01-01 01:00:00', '+00:00', '-02:00');
insert into t values(convert_tz('9999-12-31 20:00:00', '+02:00', '+06:00'));
insert into t values(convert_tz('0000-01-01 01:00:00', '+00:00', '-02:00'));
select * from t;


##bugfix: 
SELECT CONVERT_TZ(123456,'-12:00','+10:00');
SELECT CONVERT_TZ('','-12:00','+10:00');
SELECT CONVERT_TZ('aa','-12:00','+10:00');
SELECT CONVERT_TZ('张三','-12:00','+10:00');
SELECT CONVERT_TZ('1asd561ad','-12:00','+10:00');
SELECT CONVERT_TZ('￥￥%……&*￥','-12:00','+10:00');


##bugfix: 
drop table t;
create table t(c1 year);
insert into t values('1901'),('2155'), ('0000'), ('0001');
SELECT c1, CONVERT_TZ(c1,'+00:00','+00:00') from t;


##bugfix: 
drop table t;
create table t(a1 int,a2 year,c1 timestamp,c2 timestamp);
insert into t values(1,'1998','1998-12-12 12:12:12','2038-01-19 03:14:07');
insert into t values(2,'2002','2002-02-02 10:00:00','2034-02-22 00:50:20');
insert into t values(3,'2006','2006-04-15 06:06:20','2038-01-19 03:14:07');
insert into t values(4,'2012','2012-12-12 12:12:12','2030-08-16 14:05:50');
select c1,c2 ,case c1 when convert_tz(c1,'+06:00','+00:00')<'2006-04-15 06:06:20' then convert_tz('2020-02-02 02:02:02','+00:00','+00:00') else convert_tz('1999-09-09 09:09:09','+00:00','+00:00') end as c1 from t;
drop table t;

create table t(c1 timestamp(0), c2 timestamp(3), c3 decimal(20,4));
insert into t values('2020-01-01 12:00:00.123456', '2020-01-01 12:00:00.123456', '20200101120000.123456');
select c1, convert_tz(c1, '+00:00', '+08:00') from t;
select c2, convert_tz(c2, '+00:00', '+08:00') from t;
select c3, convert_tz(c3, '+00:00', '+08:00') from t;
drop table t;


##bugfix: 
SELECT CONVERT_TZ('2007-03-11 2:00:00','US/Eastern','US/Central') AS time1,
		CONVERT_TZ('2007-03-11 2:00:01','US/Eastern','US/Central') AS time2,
		CONVERT_TZ('2007-03-11 3:00:00','US/Eastern','US/Central') AS time3,
		CONVERT_TZ('2007-03-11 3:00:01','US/Eastern','US/Central') AS time4;

SELECT CONVERT_TZ('2007-03-11 2:00:00','US/Eastern','+00:00') AS time1,
		CONVERT_TZ('2007-03-11 3:00:00','US/Eastern','+00:00') AS time2,
		CONVERT_TZ('2007-03-11 3:00:01','US/Eastern','+00:00') AS time3;

SELECT CONVERT_TZ('2007-11-04 01:00:00','US/Eastern','+00:00') AS time1,
		CONVERT_TZ('2007-11-04 01:00:01','US/Eastern','+00:00') AS time2,
		CONVERT_TZ('2007-11-04 02:00:00','US/Eastern','+00:00') AS time3,
		CONVERT_TZ('2007-11-04 02:00:01','US/Eastern','+00:00') AS time4;

create table t(c1 datetime);
insert into t values('2007-03-11 2:00:00'), ('2007-03-11 2:00:01'), ('2007-03-11 3:00:00'), ('2007-03-11 3:00:01');
insert into t values('2007-11-04 1:00:00'), ('2007-11-04 1:00:01'), ('2007-11-04 2:00:00'), ('2007-11-04 2:00:01');
select convert_tz(c1, 'US/Eastern', '+00:00') from t;
drop table t;

create table t(c1 timestamp);
insert into t values('2007-03-11 1:59:59'), ('2007-03-11 3:00:00'), ('2007-03-11 3:00:01');
insert into t values('2007-11-04 1:00:00'), ('2007-11-04 1:00:01'), ('2007-11-04 2:00:00'), ('2007-11-04 2:00:01');
select convert_tz(c1, 'US/Eastern', '+00:00') from t;
drop table t;

## time zone are not const
CREATE TABLE timezone_conversion_test (
    original_time DATETIME,
    from_timezone VARCHAR(100),
    to_timezone VARCHAR(100)
);
INSERT INTO timezone_conversion_test (original_time, from_timezone, to_timezone) VALUES
('2021-01-01 12:00:00', '+00:00', '+08:00'),
('2021-01-01 12:00:00', '+01:00', '+08:00'),
('2021-01-01 12:00:00', '+01:00', '+06:30'),
('2021-01-01 12:00:00', '+01:00', '+10:10'),
('2021-01-01 12:00:00', '+01:30', '+13:00'),
('2021-01-01 12:00:00', '-11:30', '+13:00'),
('2021-01-01 12:00:00', '-12:00', '+13:00'),
('2021-01-01 00:00:00', '-12:00', '+13:00'),
('2021-01-01 23:59:59', '-12:00', '+13:00'),
('2021-01-01 13:19:38', '-10:38', '+10:12'),
('2021-01-01 12:23:35', '-09:23', '-11:11'),
('2021-01-01 00:01:00', '+10:00', '-11:00'),
('2021-01-01 00:11:00', '+00:00', '-11:00'),
('2021-03-01 00:11:00', '+00:00', '-11:00'),
('2021-06-01 00:11:00', '+00:00', '-11:00'),
('2020-03-01 00:11:00', '+00:00', '-11:00'),
('2020-02-28 23:11:00', '-00:00', '+11:00'),
('2020-02-28 23:11:00', null, null),
('2020-12-31 23:11:00', '-05:00', '+11:00'),
(null, '-05:00', '+11:00');
SELECT 
    original_time,
    from_timezone,
    to_timezone,
    CONVERT_TZ(original_time, from_timezone, to_timezone) AS converted_time
FROM 
    timezone_conversion_test;
DROP TABLE timezone_conversion_test;

# COMMON TIMEZONE NAMES TEST
CREATE TABLE IF NOT EXISTS common_timezone_test (
    original_time DATETIME COMMENT 'Original datetime',
    from_timezone VARCHAR(100) COMMENT 'Source timezone (name)',
    to_timezone VARCHAR(100) COMMENT 'Target timezone (name)'
);
INSERT INTO common_timezone_test (original_time, from_timezone, to_timezone) VALUES
('2023-01-01 12:00:00', 'UTC', 'Asia/Shanghai'),
('2023-01-01 12:00:00', 'GMT', 'America/New_York'),
('2023-01-01 12:00:00', 'Europe/London', 'Asia/Tokyo'),
('2023-01-01 12:00:00', 'America/Los_Angeles', 'Australia/Sydney');
SELECT 
    original_time,
    from_timezone,
    to_timezone,
    CONVERT_TZ(original_time, from_timezone, to_timezone) AS converted_time
FROM 
    common_timezone_test;
DROP TABLE IF EXISTS common_timezone_test;


#MIXED TIMEZONE FORMAT TEST
CREATE TABLE IF NOT EXISTS mixed_timezone_test (
    original_time DATETIME COMMENT 'Original datetime',
    from_timezone VARCHAR(100) COMMENT 'Source timezone (mixed formats)',
    to_timezone VARCHAR(100) COMMENT 'Target timezone (mixed formats)'
);
INSERT INTO mixed_timezone_test (original_time, from_timezone, to_timezone) VALUES
('2023-06-01 12:00:00', '+08:00', 'Asia/Singapore'),
('2023-06-01 12:00:00', 'Europe/Paris', '+05:30'),
('2023-06-01 12:00:00', 'CET', 'EET');
SELECT 
    original_time,
    from_timezone,
    to_timezone,
    CONVERT_TZ(original_time, from_timezone, to_timezone) AS converted_time
FROM 
    mixed_timezone_test;
DROP TABLE IF EXISTS mixed_timezone_test;


#SPECIAL TIMEZONE NAMES TEST 
CREATE TABLE IF NOT EXISTS special_timezone_test (
    original_time DATETIME COMMENT 'Original datetime',
    from_timezone VARCHAR(100) COMMENT 'Special source timezone',
    to_timezone VARCHAR(100) COMMENT 'Special target timezone'
);
INSERT INTO special_timezone_test (original_time, from_timezone, to_timezone) VALUES
('2023-12-01 12:00:00', 'US/Eastern', 'US/Pacific'),
('2023-12-01 12:00:00', 'Canada/Eastern', 'Brazil/East'),
('2023-12-01 12:00:00', 'Egypt', 'Turkey');
SELECT 
    original_time,
    from_timezone,
    to_timezone,
    CONVERT_TZ(original_time, from_timezone, to_timezone) AS converted_time
FROM 
    special_timezone_test;
DROP TABLE IF EXISTS special_timezone_test;


# DAYLIGHT SAVING TIME TEST 
CREATE TABLE IF NOT EXISTS dst_timezone_test (
    original_time DATETIME COMMENT 'Original datetime',
    from_timezone VARCHAR(100) COMMENT 'Source timezone with DST',
    to_timezone VARCHAR(100) COMMENT 'Target timezone with DST'
);
INSERT INTO dst_timezone_test (original_time, from_timezone, to_timezone) VALUES
('2023-03-12 01:30:00', 'America/Chicago', 'America/Denver'),
('2023-11-05 01:30:00', 'America/New_York', 'America/Chicago');
SELECT 
    original_time,
    from_timezone,
    to_timezone,
    CONVERT_TZ(original_time, from_timezone, to_timezone) AS converted_time
FROM 
    dst_timezone_test;
DROP TABLE IF EXISTS dst_timezone_test;


#INTERNATIONAL DATE LINE TEST  
CREATE TABLE IF NOT EXISTS date_line_test (
    original_time DATETIME COMMENT 'Original datetime',
    from_timezone VARCHAR(100) COMMENT 'Source timezone crossing date line',
    to_timezone VARCHAR(100) COMMENT 'Target timezone crossing date line'
);
INSERT INTO date_line_test (original_time, from_timezone, to_timezone) VALUES
('2023-01-01 23:59:59', 'Pacific/Auckland', 'Pacific/Honolulu');
SELECT 
    original_time,
    from_timezone,
    to_timezone,
    CONVERT_TZ(original_time, from_timezone, to_timezone) AS converted_time
FROM 
    date_line_test;
DROP TABLE IF EXISTS date_line_test;


# INVALID TIMEZONE TEST 
CREATE TABLE IF NOT EXISTS invalid_timezone_test (
    original_time DATETIME COMMENT 'Original datetime',
    from_timezone VARCHAR(100) COMMENT 'Invalid source timezone',
    to_timezone VARCHAR(100) COMMENT 'Invalid target timezone'
);
INSERT INTO invalid_timezone_test (original_time, from_timezone, to_timezone) VALUES
('2023-01-01 12:00:00', 'Invalid/Timezone', 'UTC'),
('2023-01-01 12:00:00', 'UTC', 'Not_A_Timezone');
#expecting errors or NULLs
SELECT 
    original_time,
    from_timezone,
    to_timezone,
    CONVERT_TZ(original_time, from_timezone, to_timezone) AS converted_time
FROM 
    invalid_timezone_test;
DROP TABLE IF EXISTS invalid_timezone_test;


# ABBREVIATED TIMEZONE TEST

CREATE TABLE IF NOT EXISTS abbreviated_timezone_test (
    original_time DATETIME COMMENT 'Original datetime',
    from_timezone VARCHAR(100) COMMENT 'Abbreviated source timezone',
    to_timezone VARCHAR(100) COMMENT 'Abbreviated target timezone'
);
INSERT INTO abbreviated_timezone_test (original_time, from_timezone, to_timezone) VALUES
('2023-01-01 12:00:00', 'PST', 'EST'),
('2023-01-01 12:00:00', 'CST', 'MST');
SELECT 
    original_time,
    from_timezone,
    to_timezone,
    CONVERT_TZ(original_time, from_timezone, to_timezone) AS converted_time
FROM 
    abbreviated_timezone_test;
DROP TABLE IF EXISTS abbreviated_timezone_test;

# convert_tz in DDL
set sql_mode='PIPES_AS_CONCAT,ERROR_FOR_DIVISION_BY_ZERO';
--disable_warnings
CREATE TABLE tbl_convert (
    col_88 VARCHAR(39) DEFAULT (LCASE('#WW5$#hT$L#@OjLR' - 'yrWz#swlExx@!')),
    col_89 SMALLINT DEFAULT -24110,
    col_90 BIT(56),
    col_91 INT NOT NULL,
    col_92 ENUM('Alice', 'Bob', 'Charlie', 'David') DEFAULT 'Charlie',
    col_93 JSON,
    col_94 SET('Alice', 'Bob', 'Charlie', 'David') NOT NULL DEFAULT 'Charlie',
    col_95 ENUM('Alice', 'Bob', 'Charlie', 'David') NOT NULL,
    col_96 JSON NOT NULL,
    col_97 JSON NOT NULL,
    col_98 BIT(28),
    col_99 CHAR(152),
    col_100 BOOLEAN NOT NULL DEFAULT (DAYNAME(1)),
    col_101 TEXT(467) NOT NULL,
    col_102 DECIMAL(56, 27),
    col_103 DATETIME NOT NULL,
    col_104 TIMESTAMP,
    col_105 BLOB(292) NOT NULL,
    col_106 TINYINT UNSIGNED,
    col_107 TIME NOT NULL DEFAULT (CONVERT_TZ('13:09:01.00', 'GMT', 'MET')),
    col_108 TINYINT UNSIGNED NOT NULL,
    col_109 JSON NOT NULL,
    col_110 CHAR(177) NOT NULL,
    KEY idx_13 (col_89) GLOBAL,
    UNIQUE KEY idx_14 (col_108, col_91, col_92, col_89, col_99) GLOBAL,
    UNIQUE KEY idx_15 (col_108, col_107, col_88, col_90, col_98) GLOBAL,
    KEY idx_16 (col_99(3)) LOCAL
) DEFAULT CHARSET=gbk
  ROW_FORMAT=DYNAMIC
  COMPRESSION='lz4_1.0'
  PARTITION BY HASH(col_108) PARTITIONS 264;
INSERT INTO tbl_convert (col_91, col_94, col_95, col_96, col_97, col_100, col_101, col_103, col_105, col_108, col_109, col_110) 
VALUES (1, 'Alice', 'Bob', '{}', '{}', 1, 'test', NOW(), '', 100, '{}', 'test');
select col_107 from tbl_convert;
DROP TABLE tbl_convert;
--enable_warnings
set sql_mode='';
