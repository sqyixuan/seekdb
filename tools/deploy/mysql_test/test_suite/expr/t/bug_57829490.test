--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1(c1 decimal unsigned, c2 char(10), c3 longtext);
insert into t1 values(0, '-1', '-1');

--explain_protocol 1
--result_format 4

select * from t1 where c1 = c2;
select * from t1 where c2 = c1;
select * from t1 where c1 = c3;
select * from t1 where c3 = c1;

drop table t1;
