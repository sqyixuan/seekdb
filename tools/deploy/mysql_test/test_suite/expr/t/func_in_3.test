# owner: yibo.tyf
# owner group: SQL3
# Test of expr in.

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1(
  col_int bigint, 
  col_num decimal(10, 5),
  col_date date,
  col_str1 varchar(100) collate utf8mb4_bin,
  col_str2 varchar(100) collate utf8mb4_general_ci
);

insert into 
  t1(col_int, col_num, col_date, col_str1, col_str2) 
values
  (0, 0.0, '0000-00-00', '', ''),
  (1, 1.1, '2016-1-1', 'a', 'a'),
  (2, 2.2, '2016-2-1', 'A', 'A'),
  (3, 3.3, '2016-3-1', 'b', 'b'),
  (4, 4.4, '2016-4-1', 'B', 'B'),
  (5, 5.5, '2016-5-1', 'c', 'c'),
  (6, 6.6, '2016-6-1', 'C', 'C'),
  (7, 7.7, '2016-7-1', 'd', 'd'),
  (null, null, null, null, null);

select * from t1
where
  col_int  in (1, 2, 3, 4) and
  col_num  in (1.1, 2.2, 3.3, 4.4) and
  col_date in ('2016-1-1', '2016-2-1', '2016-3-1', '2016-4-1') and
  col_str1 in ('a' collate utf8mb4_bin, 'b' collate utf8mb4_bin) and
  col_str2 in ('a' collate utf8mb4_general_ci, 'b' collate utf8mb4_general_ci)
order by
  col_int;

select * from t1
where
  col_int  not in (1, 2, 3, 4) and
  col_num  not in (1.1, 2.2, 3.3, 4.4) and
  col_date not in ('2016-1-1', '2016-2-1', '2016-3-1', '2016-4-1') and
  col_str1 not in ('a' collate utf8mb4_bin, 'b' collate utf8mb4_bin) and
  col_str2 not in ('a' collate utf8mb4_general_ci, 'b' collate utf8mb4_general_ci)
order by
  col_int;

select * from t1
where
  col_int  in (5, 6, 7, 8) and
  col_num  in (5.5, 6.6, 7.7, 8.8) and
  col_date in ('2016-5-1', '2016-6-1', '2016-7-1', '2016-8-1') and
  col_str1 in ('c' collate utf8mb4_general_ci, 'd' collate utf8mb4_general_ci) and
  col_str2 in ('c' collate utf8mb4_bin, 'd' collate utf8mb4_bin)
order by
  col_int;

select * from t1
where
  col_int  not in (5, 6, 7, 8) and
  col_num  not in (5.5, 6.6, 7.7, 8.8) and
  col_date not in ('2016-5-1', '2016-6-1', '2016-7-1', '2016-8-1') and
  col_str1 not in ('c' collate utf8mb4_general_ci, 'd' collate utf8mb4_general_ci) and
  col_str2 not in ('c' collate utf8mb4_bin, 'd' collate utf8mb4_bin)
order by
  col_int;

select
  col_int,
  col_int in (1, 2, 3, null),
  col_int in (1.0, 2.0, 3.0, 1 / 0),
  col_int in (null, null, '1', '2', '3'),
  col_int in ('a', 1.0, '2', null),
  col_int not in (1, 2, 3, null),
  col_int not in (1.0, 2.0, 3.0, null),
  col_int not in (null, null, '1', '2', '3'),
  col_int not in ('a', 1.0, '2', null)
from t1 order by col_int;

select
  col_num,
  col_num in (1, 2, 3, null),
  col_num in (1.1, 2.2, 3.3, 1 / 0),
  col_num in (null, null, '1.1', '2.2', '3.3'),
  col_num in ('a', 1.1, '2.2', null),
  col_num not in (1, 2, 3, null),
  col_num not in (1.1, 2.2, 3.3, null),
  col_num not in (null, null, '1.1', '2.2', '3.3'),
  col_num not in ('a', 1.1, '2.2', null)
from t1 order by col_num;

select
  col_date,
  col_date in ('a', '2016-5-1', '2016-6-1', '2016-7-1'),
  col_date in (0, 20160501, 20160601, null),
  col_date not in ('a', '2016-5-1', '2016-6-1', '2016-7-1'),
  col_date not in (0, 20160501, 20160601, null)
from t1 order by col_date;

select
  col_str1,
  col_str1 in ('a' collate utf8mb4_bin, 'b' collate utf8mb4_bin, null),
  col_str1 in ('a' collate utf8mb4_general_ci, 'b' collate utf8mb4_general_ci, null),
  col_str1 in ('a' collate utf8mb4_bin, 'b' collate utf8mb4_general_ci, null),
  col_str1 not in ('a' collate utf8mb4_bin, 'b' collate utf8mb4_bin, null),
  col_str1 not in ('a' collate utf8mb4_general_ci, 'b' collate utf8mb4_general_ci, null),
  col_str1 not in ('a' collate utf8mb4_bin, 'b' collate utf8mb4_general_ci, null)
from t1 order by col_str1;

select
  col_str2,
  col_str2 in ('a' collate utf8mb4_bin, 'b' collate utf8mb4_bin, null),
  col_str2 in ('a' collate utf8mb4_general_ci, 'b' collate utf8mb4_general_ci, null),
  col_str2 in ('a' collate utf8mb4_bin, 'b' collate utf8mb4_general_ci, null),
  col_str2 not in ('a' collate utf8mb4_bin, 'b' collate utf8mb4_bin, null),
  col_str2 not in ('a' collate utf8mb4_general_ci, 'b' collate utf8mb4_general_ci, null),
  col_str2 not in ('a' collate utf8mb4_bin, 'b' collate utf8mb4_general_ci, null)
from t1 order by col_str2;

drop table t1;

