--disable_warnings
drop table if exists obstress;
--enable_warnings
create table obstress(pid int, tid int, trx_grp_num int, primary key(pid,tid));
insert into obstress values(0,0,332953),(0,1,334071);
insert into obstress values(2,30,332953),(2,31,334071);
select * from obstress where (trx_grp_num, pid,tid) in((332953,0,0),(334071,0,1),(332953,2,30),(334071,2,31));
select * from obstress where (trx_grp_num, pid,tid) in((332953,0,0),(334071,0,1));
select * from obstress where (trx_grp_num, pid,tid) in((332953,2,30),(334071,2,31));
