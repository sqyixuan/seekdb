#add bug 5098084
--disable_warnings
drop table if exists test_1;
--enable_warnings
create table test_1 (id int primary key, name varchar(1024), addr varchar(1024), birthday  timestamp(6) default "2012-01-01 12:00:00", money int, score float);
replace into test_1 values(1,1,1,'2010-09-01',103,1.1);
replace into test_1 values(2,2,2,'2010-09-01',103,1.2);
Set @@session.ob_query_timeout = 5000000;
select * from test_1 where (id,name) in ((1,'1'),(2,'2'));
select * from test_1 where (name,id) in (('1',1),('2',2));
#add bug 5098141
--disable_warnings
drop table if exists test_2;
--enable_warnings
create table test_2 (id int , name varchar(1024), addr varchar(1024), birthday  timestamp(6) default "2012-01-01 12:00:00", money int, score float,primary key(id,name));
--disable_query_log

let $i = 3;
while($i < 10000)
{
   eval  replace into test_1 values($i,$i,$i,'2010-09-01',101,$i.$i);
   inc $i;
}

let $i = 10000;
while($i < 20000)
{
   eval  replace into test_1 values($i,$i,$i,'2010-09-01',103,$i.$i);
   inc $i;
}
--enable_query_log
select * from test_1 where id between 100 and 110;
select * from test_1 where (id,name) in ((1,'1'),(2,'2'));
select * from test_1 where (name,id) in (('1',1),('2',2));
Set @@session.ob_query_timeout = 5000000;
select * from test_1 where score between 10 and 20;
