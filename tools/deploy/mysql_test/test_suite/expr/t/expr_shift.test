#### description: test left shift and right shift
# tags: expr


--echo ##bugfix: 
create or replace view v as select 1 << 5 from dual;
desc v;
show create view v;

create or replace view v as select 1 >> 5 from dual;
desc v;
show create view v;

create or replace view v as select 1 << 5 << 6 from dual;
desc v;
show create view v;

create or replace view v as select (1 + 2) >> 5 >> 6 from dual;
desc v;
show create view v;

create or replace view v as select (1 + 2) >> 5 << 6 from dual;
desc v;
show create view v;