--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(a int, b int as (a+1));

select regexp_replace(b,'[1-9]',1,2) from t1;

--disable_warnings
drop table if exists t1;
--enable_warnings
create TABLE t1 (c1 int primary key, c2 int, c3 int);
create index i1 on t1((COERCIBILITY(c2)));
insert into t1 (c1, c2) values (1,1);
select /*+index(t1 i1)*/ SYS_NC19$ from t1;
select /*+full(t1)*/ SYS_NC19$ from t1;

drop table t1;
