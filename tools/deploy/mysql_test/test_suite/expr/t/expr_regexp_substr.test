--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#### owner: zongmei.zzm
#### owner group: sql1
#### description: 测试regexp_substr函数
# tags: expr, datatype

--result_format 4

--echo ================ expression regexp_substr ================
#normal test(optional params is default value(position = 1, nth_appearance = 1,	 match_parameter = 'c')
select regexp_substr('abcabc', 'a') from dual;
select regexp_substr('abcabc', 'abc') from dual;
select regexp_substr('阿里巴巴', '阿里') from dual;
select regexp_substr(123123, 123, 1) from dual;
select regexp_substr('123123', '123') from dual;
select regexp_substr(123.400000, 3.4) from dual;
--error 1139
select regexp_substr('abc', '') from dual;
select regexp_substr(null, 'b') from dual;
select regexp_substr(null, null) from dual;

select regexp_substr('abcabc', '.*') from dual;
select regexp_substr('abcabc', '.?') from dual;
select regexp_substr('abcabc', 'a*') from dual;
select regexp_substr('abcabe','ab.') from dual;
select regexp_substr('阿里巴巴', '阿|里|巴') from dual;
select regexp_substr('abcdef', '[a-z]') from dual;
select regexp_substr('11223311112', '1{2,4}') from dual;
select regexp_substr('122absdsadas123', '[[:digit:]]{3}') from dual;
select regexp_substr('12312alipay.com123sadqwe', '[[:alpha:]]{6}\.[[:alpha:]]{3}') from dual;


# with optional params(position, nth_appearance, match_parameter)
select regexp_substr('abcabc', 'abc', 4) from dual;
select regexp_substr('abcabc', 'abc', 1, 2) from dual;
select regexp_substr('ABC', 'abc', 1, 1, 'i') from dual;
select regexp_substr('ABC', 'abc', 1, 1, 'c') from dual;
select regexp_substr('阿里巴巴', '巴', 4) from dual;
select regexp_substr('阿里巴巴','巴', 1, 2) from dual;
select regexp_substr(123123, 123, 2) from dual;
select regexp_substr('123123', '123', 1, 2) from dual;
select regexp_substr(123.400000, 3.4, 1, 1) from dual;
select regexp_substr('abcABC','(abc)(abc)',1, 1, 'i') from dual;
select regexp_substr('阿里巴巴', '(阿)(里)(巴巴)', 1, 1, 'c') from dual;
select regexp_substr('阿里巴巴', '(阿)(里)(巴巴)', NULL, 1, 'c') from dual;
select regexp_substr('阿里巴巴', '(阿)(里)(巴巴)', 1, NULL, 'c') from dual;
select regexp_substr('阿里巴巴', '(阿)(里)(巴巴)', 1, 1, NULL) from dual;
select regexp_substr('阿里巴巴', '(阿)(里)(巴巴)', 1, 1, 'c') from dual;
select regexp_substr('a123b123', '([[:alpha:]])(\d{3})', 1, 2, NULL) from dual;
select regexp_substr('蚂123蚁123', '([[:alpha:]])(\d{3})', 1, 2, NULL) from dual;

select regexp_substr('abcabc', 'ab*', 3) from dual;
select regexp_substr('abcabc', 'a..', 1, 2) from dual;
select regexp_substr('abcABC', '[a-z]{3}',1, 2, 'c') from dual;
select regexp_substr('abcabcABC', '[a-z]{3}', 1, 1, 'i') from dual;
--error 1210
select regexp_substr('abcabcABC', '[a-z]  {3}', 1, 1, 'x') from dual;
--error 1210
select regexp_substr('abcabcABC', '[a-z]  {3}', 1, 3, 'ix') from dual;
select regexp_substr('阿里巴巴', '巴*', 1, 1) from dual;
select regexp_substr('阿里巴巴', '(里)(.)', 1, 1, 'c') from dual;
select regexp_substr('123.400000', '[1-9]{2}\.[1-9]', 1, 1) from dual;

# 测试中英文混合
select regexp_substr('123阿里123巴巴123', '123') from dual;
select regexp_substr('abc阿里abc巴巴abc', '阿里') from dual;
select regexp_substr('abc阿里123巴巴abc', 'abc') from dual;
select regexp_substr('123阿里abc巴巴123',  '123', 1, 2) from dual;
select regexp_substr('abc阿里123巴巴abc', 'abc', 1, 2) from dual;
select regexp_substr('abc阿里123巴巴abc', '巴', 1, 2) from dual;
select regexp_substr('abc阿里123巴巴ABC', 'abc', 1, 2, 'c') from dual;
select regexp_substr('abc阿里123巴巴ABC', 'abc', 1, 2, 'i') from dual;
select regexp_substr('abc阿里123巴巴abc', '(abc)(阿里)', 1, 1, 'c') from dual;

select regexp_substr('123阿里123巴巴123', '[1-9]{3}') from dual;
select regexp_substr('abc阿里abc巴巴abc', '巴*') from dual;
select regexp_substr('abc阿里123巴巴abc', '[[:alpha:]]{3}') from dual;
select regexp_substr('123阿里abc巴巴123', '12[1-9]', 1, 2) from dual;
select regexp_substr('abc阿里123巴巴abc', '[a-z]', 1, 5) from dual;
select regexp_substr('abc阿里123巴巴abc', '(阿)', 1, 1, 'c') from dual;
--error 1210
select regexp_substr('abc阿里123巴巴ABC', '[a-z]{3} | [1-9]{3}', 1, 2, 'cx') from dual;
--error 1210
select regexp_substr('abc阿里123巴巴ABC', '[a-z]{3} | [1-9]{3}', 1, 3, 'ix') from dual;

# 测试非整的可选参数(position and nth_appearance)
select regexp_substr('abcabc', 'abc', 1.9) from dual;
select regexp_substr('abcabc', 'abc', 1.9, 2.2) from dual;
select regexp_substr(123123, 123, 4.9999) from dual;
select regexp_substr('阿里巴巴', '巴', 3.8, 1.9) from dual;
select regexp_substr('abc阿里123巴巴ABC', 'abc', 1, 1.99999999999999, 'i') from dual;

select regexp_substr('abcabd', 'ab.', 1.9, 1) from dual;
select regexp_substr('abcabe', 'ab.', 1.9, 2.99999) from dual;
select regexp_substr(123123, '^123', 1.1, 1.5) from dual;
select regexp_substr('阿里巴巴', '巴*', 3.8, 1.9) from dual;
--error 1210
select regexp_substr('abc阿里123巴巴ABC', '[a-z]   {3}', 1, 2.99999999999999, 'ix') from dual;

#参数边界测试
--error 1139
select regexp_substr('abcabc', 'abc', 1844674407370955161518446744073709551615, 1) from dual;

select regexp_substr(123123, 123, 1, 1844674407370955161518446744073709551615) from dual;
--error 1139
select regexp_substr('阿里巴巴', '巴', 1844674407370955161518446744073709551615, 1844674407370955161518446744073709551615) from dual;
--error 1139
select regexp_substr('abc阿里123巴巴abc', 'abc', 1844674407370955161518446744073709551615, 12312312312313123.9999999) from dual;
--error 1139
select regexp_substr('abcabc', 'a*', 1844674407370955161518446744073709551615, 1) from dual;
select regexp_substr(123123, '[[:digit:]]{3}', 1, 1844674407370955161518446744073709551615) from dual;
--error 1139
select regexp_substr('阿里巴巴', '.*巴$', 1844674407370955161518446744073709551615, 1844674407370955161518446744073709551615) from dual;
--error 1139
select regexp_substr('abc阿里123巴巴abc', '巴.', 1844674407370955161518446744073709551615, 12312312312313123.9999999) from dual;

#结合其他表达式测试
select regexp_substr(lower('ABCdefg') ,substr('abcdde', 1,2), 1 ,1) from dual;
select regexp_substr(concat('xy','xy'), 'xy', abs(-1), abs(-2)) from dual;
select regexp_substr(concat('xy','xy'), 'x*', abs(-1)) from dual;
select regexp_substr(regexp_substr('abc阿123里123巴abc巴abc', '123'), '12') from dual;

#特殊匹配测试
select regexp_substr('2, 5, and 10 are numbers in this example', '\d') from dual;
select regexp_substr(123123,'\d+') from dual;
select regexp_substr(123123,'\d+?') from dual;
select regexp_substr(123123, '[0-9]{2,4}') from dual;
select regexp_substr(123123, '\d{2,4}?') from dual;
select regexp_substr('abc阿里123阿里巴巴&!@','\W') from dual;
select regexp_substr('TechOnTheNet is a great resource', '^(\S*)') from dual;
select regexp_substr('abcabd', '\Aab') from dual;
select regexp_substr('abcabd', '^ab') from dual;
select regexp_substr('abcabe', '.*be\Z') from dual;
select regexp_substr('abcabe', '.*be$') from dual;

#无效参数测试
--error 1210
select regexp_substr('abcabd', 'ab', -1) from dual;
--error 1210
select regexp_substr('abcabd', 'aab', 1, -1) from dual;
--error 1210
select regexp_substr('abcabd', '\Aab',  1, 1, 'p') from dual;
--error 5813
select regexp_substr(NULL, '(', 1) from dual;
--error 5812
select regexp_substr(NULL, '\d[', 1) from dual;
--error 1139
select regexp_substr(NULL, '\d{3', 1) from dual;

#位于建表查询语句中测试及类型推导
--disable_warnings
drop table if exists t1, v1;
--disable_warnings

create table t1(c1 varchar(64), c2 varchar(64));
insert into t1 values(regexp_substr('阿123巴巴','\d{1,}'), regexp_substr('阿123巴巴','12'));
select * from t1;
select regexp_substr(c1, '12') from t1;
drop table t1;

create view v1 as select regexp_substr('abcabd', '\Aab') as c1 from dual;
desc v1;
drop view v1;

create table t1 (c1 varchar(10), c2 varchar(10) collate utf8mb4_bin);
insert into t1 values('a', 'b'),('a', 'B'),('A', 'b');

select regexp_substr(c1, 'a', 1) from t1;
select regexp_substr(c2, 'b', 1) from t1;
drop table t1;