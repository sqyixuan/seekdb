--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: luofan.zp
# owner group: SQL2
# Test of cast functions

select cast(0 as datetime), cast(1 as datetime);
select cast(0 as time), cast(1 as time);
select cast(0 as date), cast(1 as date);
select cast(0 as decimal), cast(1 as decimal);
select cast(0 as decimal(9)), cast(1 as decimal(9));
select cast(0 as decimal(9,2)), cast(1 as decimal(9,2));


select CAST(  'abc' AS datetime );
select cast('abc' as decimal(9,2));
select cast('abc' as decimal(9));
select cast('abc' as binary);
select cast('abc' as char);
select cast('abc' as date);
select cast('abc' as char(2));
select cast('abc' as binary(2));
select cast('abc' as signed integer);
select cast('abc' as unsigned);
select cast('abc' as time);
select cast('abc' as signed);

select CAST('123.4' AS datetime );
select cast('123.4' as decimal(9,2));
select cast('123.4' as decimal(9));
select cast('123.4' as binary);
select cast('123.4' as char);
select cast('123.4' as date);
select cast('123.4' as char(2));
select hex(cast('123.4' as binary(2)));
select cast('123.4' as signed integer);
select cast('123.4' as unsigned);
select cast('123.4' as time);
select cast('123.4' as signed);

select CAST('#' AS datetime );
select cast('#' as decimal(9,2));
select cast('#' as decimal(9));
select cast('#' as binary);
select cast('#' as char);
select cast('#' as date);
select cast('#' as char(2));
select hex(cast('#' as binary(2)));
select cast('#' as signed integer);
select cast('#' as unsigned);
select cast('#' as time);
select cast('#' as signed);
select cast('#' as signed);

select CAST('-1' AS datetime );
select cast('-1' as decimal(9,2));
select cast('-1' as decimal(9));
select cast('-1' as binary);
select cast('-1' as char);
select cast('-1' as date);
select cast('-1' as char(2));
select hex(cast('-1' as binary(2)));
select cast('-1' as signed integer);
select cast('-1' as unsigned);
select cast('-1' as time);
select cast('-1' as signed);
select cast('-1' as signed);
select cast('-1' as signed);

select cast('#' as unsigned integer);
select cast('-1' as unsigned integer);
