#### owner: dachuan.sdc
#### owner group: sql2
#### description: test expr CHAR

--disable_warnings
drop table if exists test;
--enable_warnings

create table test as select char(13) c1, char(13, 13) c2, char(13, 13, 13 using utf8mb4) c3;
desc test;
select * from test;
select hex(c1), hex(c2), hex(c3) from test;
drop table test;