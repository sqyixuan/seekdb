--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: peihan.dph
# owner group: SQL1
# Test of functions elt

--enable_result_log
--enable_query_log

connect (conn1,$OBMYSQL_MS0,root,,test,$OBMYSQL_PORT);
set global ob_sql_work_area_percentage=90;

--error 1582
select elt();
--error 1582
select elt(0);
--error 1582
select elt(null);
--error 1054
select elt('null', 9a, 8, 7, 6, 5);

select elt(1,NULL);
select elt(1,12,NULL);
select elt(2,12,NULL);
select elt('null',12,NULL);
select elt(null,12,NULL);


select elt(-10000000000000000000000000, 'abc1', 'abc2', 'abc3', 'abc4', 'abc5');
select elt(-1, 'abc1', 'abc2', 'abc3', 'abc4', 'abc5');
select elt(0, 'abc1', 'abc2', 'abc3', 'abc4', 'abc5');
select elt(1, 'abc1', 'abc2', 'abc3', 'abc4', 'abc5');
select elt(2, 'abc1', 'abc2', 'abc3', 'abc4', 'abc5');
select elt(3, 'abc1', 'abc2', 'abc3', 'abc4', 'abc5');
select elt(4, 'abc1', 'abc2', 'abc3', 'abc4', 'abc5');
select elt(5, 'abc1', 'abc2', 'abc3', 'abc4', 'abc5');
select elt(6, 'abc1', 'abc2', 'abc3', 'abc4', 'abc5');
select elt(7, 'abc1', 'abc2', 'abc3', 'abc4', 'abc5');
select elt(100000000000000000000000, 'abc1', 'abc2', 'abc3', 'abc4', 'abc5');

select elt(-10000000000000000000000000, 'abc1', 'abc2', 'abc3');
select elt(-1, 'abc1');
select elt(0, 'abc1', 'abc2');
select elt(1, 'abc1', 'abc2', 'abc3');
select elt(2, 'abc1', 'abc2', 'abc3', 'abc4');
select elt(3, 'abc1', 'abc2', 'abc3', 'abc4', 'abc5');
select elt(4, 'abc1', 'abc2', 'abc3', 'abc4');
select elt(5, 'abc1', 'abc2', 'abc3', 'abc4', 'abc5');
select elt(6, 'abc1', 'abc2', 'abc3', 'abc4');
select elt(7, 'abc1', 'abc2', 'abc3', 'abc4', 'abc5');
select elt(100000000000000000000000, 'abc1', 'abc2', 'abc3', 'abc4', 'abc5');

select elt('-1', 9, 8, 7, 6, 5);
select elt('0', 9, 8, 7, 6, 5);
select elt('1', 9, 8, 7, 6, 5);
select elt('2', 9, 8, 7, 6, 5);
select elt('3', 9, 8, 7, 6, 5);
select elt('4', 9, 8, 7, 6, 5);
select elt('5', 9, 8, 7, 6, 5);
select elt('6', 9, 8, 7, 6, 5);
--disable_query_log
set global ob_sql_work_area_percentage = 90;
--enable_query_log
--sleep 2
