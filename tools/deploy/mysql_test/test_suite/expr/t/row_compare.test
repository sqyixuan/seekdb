select ('1') = (1);
select ('01') = (1);
select (1) = ('01');

select (1,'2') > (1, '03');
select (1,2) > (1, '03');

select (1, '2') < (1, '03');
select (1, '2') < (1, '02');
select (1, 2) < (1, '03');

select (1,1) >= (1,'00001');
select (1,'1') >= (1,'00001');
select (1,'a') >= (1,'A');
select (1,'A') >= (1,'a');
select (1,1) >= (1,1.0000001);
select (1,1) >= (1,1.0000000000000001);


