--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner      : xiaoyi.xy
#owner group: SQL1
#description: test for func: host_ip(),rpc_port(),mysql_port();
#tags       : parameter

## Initialise
## test host_ip(),rpc_port(),mysql_port()
--disable_result_log
select host_ip(),rpc_port(),mysql_port();
--enable_result_log

# test
select length(host_ip())>7, rpc_port()>1024, mysql_port()>1024, int2ip(ip2int(host_ip())) = host_ip();
select host_ip() is not null, rpc_port() is not null, mysql_port() is not null;
select count(host_ip()), count(rpc_port()), count(mysql_port());

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
select count(1) from oceanbase.__all_server where svr_ip=host_ip() and svr_port=rpc_port() and inner_port=mysql_port();
select status from oceanbase.__all_server where svr_ip=host_ip() and svr_port=rpc_port() and inner_port=mysql_port();
select name from oceanbase.__all_virtual_sys_parameter_stat where svr_ip=host_ip() and svr_port=rpc_port() and name like '%zone_merge%' order by name;
disconnect obsys;

