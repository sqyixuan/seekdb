# owner: peihan.dph
# owner group: sql2

--disable_abort_on_error
--result_format 4

connect (con, $OBMYSQL_MS0, admin, $OBMYSQL_PWD, test, $OBMYSQL_PORT);
connection con;
alter system flush sql audit global;

--sleep 1
connection default;
set ob_enable_plan_cache = off;
--disable_warnings


################################   true      true      ->     true    #############################

select 3 between 0 and 5;
select 3.14 between 2.00 and 4.00;
select 'hij' between 'abc' and 'opq';

select 2008 between year('1949-10-01') and year('2021-07-01');
select 7 between month('2013-03-01') and month('2013-10-01');
select 10 between week('2013-01-12') and week('2013-04-25');
select 21 between dayofyear('2013-01-01') and dayofyear('2013-01-31');
select 21 between dayofmonth('2013-01-01') and dayofmonth('2013-01-31');
select 50 between hour('10:05:03') and hour('85:45:09');

select '2000-01-01' between from_days(700000) and from_days(800000);
select 730500 between to_days('2000-01-01') and to_days('2001-01-01');

select '2013-01-05' between '2013-01-01' and makedate(2013,10);
select '2013-01-05' between makedate(2013,1) and '2013-01-10';
select '2013-01-05' between makedate(2013,1) and makedate(2013,10);

select '2013-01-05' between '2013-01-01' and makedate(2013,500);
select '2013-01-05' between makedate(2013,1) and makedate(2013,500);

select makedate(2013,10) between makedate(2013,1) and makedate(2013,500);
select makedate(2013,500) between makedate(2013,1) and makedate(2013,500);




################################   true      false     ->     false   #############################

