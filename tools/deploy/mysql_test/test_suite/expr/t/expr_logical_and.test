select 21 between dayofyear('2013-01-01') and dayofyear('2013-01-11');
select 21 between dayofmonth('2013-01-01') and dayofmonth('2013-01-11');
select 50 between hour('10:05:03') and hour('25:45:09');

select '2000-01-01' between from_days(700000) and from_days(700100);
select 730500 between to_days('2000-01-01') and to_days('1999-01-01');

select '2013-01-05' between '2013-01-01' and makedate(2013,4);
select '2013-01-05' between makedate(2013,1) and '2013-01-04';
select '2013-01-05' between makedate(2013,1) and makedate(2013,4);

select makedate(2013,5) between makedate(2013,1) and makedate(2013,4);
select makedate(2013,500) between makedate(2013,1) and makedate(2013,4);





