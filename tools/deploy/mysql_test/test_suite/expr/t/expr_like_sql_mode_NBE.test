#owner: dachuan.sdc
#owner group: sql1
# tags: resolver
#description: test like clause in NO_BACKSLASH_ESCAPES sql_mode.
--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
set sql_mode = 'NO_BACKSLASH_ESCAPES';
--enable_query_log

--disable_warnings
drop table if exists t1;
--enable_warnings
# cases from func_expr.test
# we only need to test cases with backslash('\')
create table t1 (a varchar(10) primary key, b int default 0);
insert into t1 (a) values ('a'), ('a\\b');
select * from t1 where a like 'a\\%';
select * from t1 where a like 'a\\%' escape '#';
select * from t1 where a not like 'a\\%' escape '#';
select * from t1 where a like 'a\\%' escape '#' and a like 'a\\\\b';
select * from t1 where a like 'a\\%' escape '#' and a not like 'a\\\\b';
select * from t1 where a like 'a\\%' escape '#' or a not like 'a\\\\b';

# NO_BACKSLASH_ESCAPES only affect LIKE clause without ESCAPE
# in mysql: the ESCAPE clause have same result in both NO_BACKSLSAH_ESCAPES mode and 
# normal mode. So we do not need to test the ESCAPES clause.
# e.g., "select 'aaa#a' like 'aaa##a" escape '#';" --ignore
select '\t' like '\t';
select '\t' like '\\t';
select '\t' like '\\\t';
select '\\t' like '\\t';
select '\\t' like '\\\\t';
select '\\t' like '\\\\\t';
select '\\t' like '\\\\\\t';

select '\t' rlike '\t';
select '\t' rlike '\\t';
select '\t' rlike '\\\t';
select '\\t' rlike '\\t';
select '\\t' rlike '\\\\t';
select '\\t' rlike '\\\\\t';
select '\\t' rlike '\\\\\\t';

select '\t' like binary '\t';
select '\t' like binary '\\t';
select '\t' like binary '\\\t';
select '\\t' like binary '\\t';
select '\\t' like binary '\\\\t';
select '\\t' like binary '\\\\\t';
select '\\t' like binary '\\\\\\t';

select 'ab\_s' like 'ab\_s'; 
select 'ab\_s' like 'ab\\\_s'; 
select 'ab_s' like 'ab\_s'; 
select 'ab_s' like 'ab\\_s'; 
select '\\' like '\\\\';
select 'a\\' like '%\\\\';

# without sql_mode 'NO_BACKSLASH_ESCAPES'
set sql_mode = 'STRICT_ALL_TABLES,NO_ZERO_IN_DATE';

--disable_warnings
drop table if exists t1;
--enable_warnings
# cases from func_expr.test
# we only need to test cases with backslash('\')
create table t1 (a varchar(10) primary key, b int default 0);
insert into t1 (a) values ('a'), ('a\\b');
select * from t1 where a like 'a\\%';
select * from t1 where a like 'a\\%' escape '#';
select * from t1 where a not like 'a\\%' escape '#';
select * from t1 where a like 'a\\%' escape '#' and a like 'a\\\\b';
select * from t1 where a like 'a\\%' escape '#' and a not like 'a\\\\b';
select * from t1 where a like 'a\\%' escape '#' or a not like 'a\\\\b';

# NO_BACKSLASH_ESCAPES only affect LIKE clause without ESCAPE
# in mysql: the ESCAPE clause have same result in both NO_BACKSLSAH_ESCAPES mode and 
# normal mode. So we do not need to test the ESCAPES clause.
# e.g., "select 'aaa#a' like 'aaa##a" escape '#';" --ignore
select '\t' like '\t';
select '\t' like '\\t';
select '\t' like '\\\t';
select '\\t' like '\\t';
select '\\t' like '\\\\t';
select '\\t' like '\\\\\t';
select '\\t' like '\\\\\\t';

select 'ab\_s' like 'ab\_s'; 
select 'ab\_s' like 'ab\\\_s'; 
select 'ab_s' like 'ab\_s'; 
select 'ab_s' like 'ab\\_s'; 
select '\\' like '\\\\';
select 'a\\' like '%\\\\';
