#owner: dachuan.sdc
#owner group: sql2

--disable_abort_on_error
--result_format 4
--disable_warnings

connect (conn_admin, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);

connection conn_admin;
alter system set enable_async_syslog = false;

connection default;
set @@ob_enable_plan_cache = 0;

drop table if exists t;
create table t(text varchar(20), pat varchar(20), id int);
insert into t values(null, null, 1);
insert into t values('', '', 2);
insert into t values('abc', 'abc', 3);
insert into t values('abc', '%', 4);
insert into t values('abc', 'ab%', 5);
insert into t values('abc', '%abc', 6);
insert into t values('ab_', '%b%', 6);
insert into t values('bc', '%b_', 7);
insert into t values('bc', '%b_c', 8);
insert into t values('%bc', '%%b_', 9);

connection conn_admin;
connection default;

select id, text like pat from t limit 10;
select id, text like pat escape null from t limit 10;
select id, text like pat escape '_' from t limit 10;
select id, text like pat escape '%' from t limit 10;
select id, text like pat escape '/' from t limit 10;

select id, null like pat from t limit 10;
select id, '' like pat from t limit 10;
select id, 'abc' like pat from t limit 10;
select id, 'ab' like pat from t limit 10;
select id, 'bc' like pat from t limit 10;

select id, null like pat escape '%' from t limit 10;
select id, '' like pat escape '%' from t limit 10;
select id, 'abc' like pat escape '%' from t limit 10;
select id, 'ab' like pat escape '%' from t limit 10;
select id, 'bc' like pat escape '%' from t limit 10;

select id, null like pat escape '_' from t limit 10;
select id, '' like pat escape '_' from t limit 10;
select id, 'abc' like pat escape '_' from t limit 10;
select id, 'ab' like pat escape '_' from t limit 10;
select id, 'bc' like pat escape '_' from t limit 10;

select id, null like pat escape '/' from t limit 10;
select id, '' like pat escape '/' from t limit 10;
select id, 'abc' like pat escape '/' from t limit 10;
select id, 'ab' like pat escape '/' from t limit 10;
select id, 'bc' like pat escape '/' from t limit 10;

select id, text like null from t limit 10;
select id, text like '' from t limit 10;
select id, text like '%' from t limit 10;
select id, text like 'ab%' from t limit 10;
select id, text like '%abc' from t limit 10;
select id, text like '%b%' from t limit 10;

select id, text like null escape '' from t limit 10;
select id, text like '' escape '' from t limit 10;
select id, text like '%' escape '' from t limit 10;
select id, text like 'ab%' escape '' from t limit 10;
select id, text like '%abc' escape '' from t limit 10;
select id, text like '%b%' escape '' from t limit 10;

select id, text like '' escape '%' from t limit 10;
select id, text like '%' escape '%' from t limit 10;
select id, text like 'ab%' escape '%' from t limit 10;
select id, text like '%abc' escape '%' from t limit 10;
select id, text like '%b%' escape '%' from t limit 10;

select id, text like '' escape '_' from t limit 10;
select id, text like '%' escape '_' from t limit 10;
select id, text like 'ab%' escape '_' from t limit 10;
select id, text like '%abc' escape '_' from t limit 10;
select id, text like '%b%' escape '_' from t limit 10;

select id, text like pat escape null from t limit 10;
select id, text like pat escape '' from t limit 10;
select id, text like pat escape '-' from t limit 10;
select id, text like pat escape '%' from t limit 10;


select id, null like null escape null from t limit 1;
select id, '' like '' escape '' from t limit 1;
select id, 'abc' like 'abc' escape '/' from t limit 1;
select id, 'abc' like 'abc' escape 'a' from t limit 1;
select id, 'abc' like 'abc' escape 'c' from t limit 1;
select id, '%abc' like '%abc' escape '/' from t limit 1;
select id, '%abc' like '%abc' escape '%' from t limit 1;
select id, 'abdc' like 'ab_c' escape '/' from t limit 1;
select id, 'abdc' like 'ab_c' escape '_' from t limit 1;
select id, 'abc' like 'ab_c' escape '_' from t limit 1;
select id, 'abdc%' like 'ab_c%' escape '_' from t limit 1;
select id, 'abdc%' like 'ab_c%' escape '%' from t limit 1;
select id, 'abdc' like 'ab%c' escape '%' from t limit 1;
select id, 'abc' like 'ab%c' escape '%' from t limit 1;
select id, 'abdc%' like 'ab_c%' escape '/' from t limit 1;
select id, 'abdc%' like 'abc%' escape '_' from t limit 1;
select id, 'abdc%' like 'abc%' escape '%' from t limit 1;
select id, 'abdc%' like 'abc%' escape '/' from t limit 1;

--echo nested loop left outer join 
--disable_query_log
--disable_result_log
drop table if exists t1;
CREATE TABLE `t1` (
`group_id` varchar(100) COLLATE utf8mb4_bin NOT NULL,
`sub_group_id` int(11) NOT NULL,
`execute_seq` int(11) NOT NULL,
`jobname` varchar(100) COLLATE utf8mb4_bin DEFAULT NULL,
`disabled` char(1) COLLATE utf8mb4_bin DEFAULT NULL,
`interrupt_flag` char(1) COLLATE utf8mb4_bin DEFAULT NULL,
`cc` varchar(100) COLLATE utf8mb4_bin DEFAULT NULL,
PRIMARY KEY (`group_id`, `sub_group_id`, `execute_seq`)
);
insert into t1 values('A', 1, 10, 'batch_corebatch_start_job', '0', '0', 'A-1-10-20190626-10001%');
insert into t1 values('A', 99, 10, 'batch_before_cutoff_end_job', '0', '0', 'A-99-10-20190626-10001%');

drop table if exists t2;
CREATE TABLE `t2` (
`execute_batch_seq` varchar(100) COLLATE utf8mb4_bin NOT NULL,
`execute_start_date` date NOT NULL,
`jobname` varchar(100) COLLATE utf8mb4_bin NOT NULL,
PRIMARY KEY (`execute_batch_seq`, `execute_start_date`, `jobname`)
);
insert into t2 values('A-1-10-20190626-10001', '2019-06-26', 'batch_corebatch_start_job');
insert into t2 values('A-99-10-20190626-10001', '2019-06-26', 'batch_before_cutoff_end_job');
--enable_query_log
--enable_result_log
select/*+use_hash(jgc gs)*/ jgc.group_id, jgc.sub_group_id, jgc.execute_seq , jgc.jobname, gs.execute_start_date From t1 jgc left join t2 gs on gs.execute_batch_seq like jgc.cc AND gs.jobname = jgc.jobname;
--disable_query_log
drop table t1;
drop table t2;
--enable_query_log
