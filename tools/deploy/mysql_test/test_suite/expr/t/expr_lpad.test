CREATE TABLE AllTypes (
    c_bool BOOLEAN,
    c_int INT,
    c_decimal DECIMAL(13 , 0 ),
    c_double DOUBLE,
    c_bit BIT,

    c_datetime DATETIME,
    c_data DATE,
    c_time TIME,

    c_char CHAR(10),
    c_varchar VARCHAR(10),
    c_binary BINARY(10),
    c_varbinary VARBINARY(10)
);

# insert
insert AllTypes values(
    true,
    1,
    1,
    1.5,
    1,

    '2011-11-11 11:11:11',
    '2011-11-11',
    '11:11:11',

    'a',
    'a',
    'a',
    'a'
);

--result_format 1
--vertical_results

# FIXME: lack warning(mysq_code 1292) during ObExprOperator::cast_operand_type;
# FIXME: lack warning(mysql_code 1301) during ObExprRepeat::calc;
# --disable_warnings
# select
SELECT
    lpad(c_bool,20,'a'),
    lpad(c_int,20,'a'),
    lpad(c_decimal,20,'a'),
    lpad(c_double,20,'a'),
    lpad(c_bit,20,'a'),

    lpad(c_datetime,20,'a'),
    lpad(c_data,20,'a'),
    lpad(c_time,20,'a'),

    lpad(c_char,20,'a'),
    lpad(c_varchar,20,'a'),
    lpad(c_binary,20,'a'),
    lpad(c_varbinary,20,'a')
FROM
    AllTypes;

SELECT
    lpad('a', c_bool, 'b'),
    lpad('a', c_int, 'b'),
    lpad('a', c_decimal, 'b'),
    lpad('a', c_double, 'b'),
    lpad('a', c_bit, 'b'),

    lpad('a', c_datetime, 'b'),
    lpad('a', c_data, 'b'),
    lpad('a', c_time, 'b'),

    lpad('a', c_char, 'b'),
    lpad('a', c_varchar, 'b'),
    lpad('a', c_binary, 'b'),
    lpad('a', c_varbinary, 'b')
FROM
    AllTypes;

SELECT
    lpad('a', 20, c_bool),
    lpad('a', 20, c_int),
    lpad('a', 20, c_decimal),
    lpad('a', 20, c_double),
    lpad('a', 20, c_bit),

    lpad('a', 20, c_datetime),
    lpad('a', 20, c_data),
    lpad('a', 20, c_time),

    lpad('a', 20, c_char),
    lpad('a', 20, c_varchar),
    lpad('a', 20, c_binary),
    lpad('a', 20, c_varbinary)
FROM
    AllTypes;


drop table AllTypes;
# --enable_warnings

--disable_warnings
drop table if exists t2,t3;
--enable_warnings
create table t2 as select rpad('a', 512, 'a'),rpad('a', 513, 'a'),rpad('a', 32767, 'a'),rpad('a', 65536, 'a') from dual;
create table t3 as select lpad('a', 512, 'a'),lpad('a', 513, 'a'),lpad('a', 32767, 'a'),lpad('a', 65536, 'a') from dual;
desc t2;
desc t3;
drop table t2,t3;
