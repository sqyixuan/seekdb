--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#### owner: zongmei.zzm
#### owner group: sql1
#### description: 测试regexp_like函数
# tags: expr, datatype

--result_format 4

--echo ================ expression regexp_like ================
#normal test(optional params is default value(match_parameter = 'c')
select 1 from dual where regexp_like('abcabc', 'abcabc');
select 1 from dual where regexp_like('abcabc', 'abcabd');
select 1 from dual where regexp_like('阿里巴巴', '阿里巴巴');
select 1 from dual where regexp_like('阿里巴巴', '阿里巴阿');
select 1 from dual where regexp_like(123123, 123123);
select 1 from dual where regexp_like('123123', '123124');
select 1 from dual where regexp_like(123.400000, 123.400000);
select 1 from dual where regexp_like(123.400000, 123.40000);
select 1 from dual where regexp_like(null, 'b');
select 1 from dual where regexp_like(null,null);
select 1 from dual where regexp_like('abc', '', NULL);

select 1 from dual where regexp_like('abcabc', '.*');
select 1 from dual where regexp_like('abcabc', '.?');
select 1 from dual where regexp_like('abcabc', '.+');
select 1 from dual where regexp_like('阿里巴巴', '(阿|啊)里巴巴');
select 1 from dual where regexp_like('abcdef', '[a-z]{5}');
select 1 from dual where regexp_like('1111', '1{2,4}');
select 1 from dual where regexp_like('123', '[[:digit:]]{3}', null);


# with optional params(match_parameter)
select 1 from dual where regexp_like('abcABC', 'abcabc');
select 1 from dual where regexp_like('abcABC', 'abcabc', 'c');
select 1 from dual where regexp_like('abcABC', 'abcabc', 'i');
select 1 from dual where regexp_like('abcABC', 'a b c a b c', 'u');
select 1 from dual where regexp_like('abc', 'abc', NULL);

select 1 from dual where regexp_like('AAaa', 'a*');
select 1 from dual where regexp_like('AAaa', 'a*', 'c');
select 1 from dual where regexp_like('AAaa', 'a*', 'i');
select 1 from dual where regexp_like('AAaa', 'a  *', 'u');

# 测试中英文混合
select 1 from dual where regexp_like('123阿里', '123阿里');
select 1 from dual where regexp_like('阿里abc', '阿里abc');
select 1 from dual where regexp_like('阿里abc', '阿里ABC', 'i');

select 1 from dual where regexp_like('123阿里', '[1-9]{3}阿.');
select 1 from dual where regexp_like('巴巴abc', '巴*[[:alpha:]]{3}');
select 1 from dual where regexp_like('巴巴ABC', '巴*[[:alpha:]]{3}','i');
select 1 from dual where regexp_like('123阿', '^123.');
select 1 from dual where regexp_like('123abc', '[0-9]{3}[a-z]{3}$') ;

#结合其他表达式测试
select 1 from dual where regexp_like(lower('ABC') ,substr('abcdd', 1, 3), 'i');
select 1 from dual where regexp_like(concat('xy','xy'), 'xyxy');
select 1 from dual where regexp_like(concat('x','x'), 'x*');
select 1 from dual where regexp_like('heart', regexp_replace('a','.','HEART'), 'i');

#特殊匹配测试
select 1 from dual where regexp_like ('2', '\d');
select 1 from dual where regexp_like(123123,'\d+');
select 1 from dual where regexp_like(123123,'\d+?');
select 1 from dual where regexp_like(123123, '[0-9]{2,6}');
select 1 from dual where regexp_like(123123, '\d{2,6}?');
select 1 from dual where regexp_like('abc123','\w*');
select 1 from dual where regexp_like('TechOnTheNet', '^(\S*)');
select 1 from dual where regexp_like('ABC', '\Aabc' ,'i');
select 1 from dual where regexp_like('abc', '^abc');
select 1 from dual where regexp_like('12阿里巴巴312ABC', '.*bc\Z', 'i');
select 1 from dual where regexp_like('12阿里巴巴312abc', '.*bc$');

select regexp_like('a', 'a') from dual;

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1 (c1 varchar(10), c2 varchar(10) collate utf8mb4_bin);
insert into t1 values('a', 'b'),('a', 'B'),('A', 'b');

select * from t1 where regexp_like(c1,'a');
select * from t1 where regexp_like(c2,'b');

drop table t1;

#无效参数测试
--error 1210
select 1 from dual where regexp_like ('Aa', 'Aa','p');
--error 1210
select 1 from dual where regexp_like ('22', '22', 'q');
--error 5813
select 1 from dual where regexp_like(NULL, '(');
--error 5812
select 1 from dual where regexp_like(NULL, '\d[');
--error 1139
select 1 from dual where regexp_like(NULL, '\d{3');
--error 1139
select 1 from dual where regexp_like('abc', '');
--error 1210
select 1 from dual where regexp_like('abcABC', 'a b c a b c', 'x');

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1(a int, b varchar(50));

insert into t1 values(1,'qqqqqqqdqqqqq');
insert into t1 values(2,'(020)12345678');
insert into t1 values(3,'192.168.0.1');
insert into t1 values(4,'123a34cc');
insert into t1 values(5,'A7007');
insert into t1 values(6,'001517729C28');
insert into t1 values(7,'人民日报');
insert into t1 values(8,'DNF*cf（QQ华夏');
insert into t1 values(9,'12345678cc');
insert into t1 values(10,'14844887@sina.com');
insert into t1 values(11,'http');
insert into t1 values(12,'ftp');
insert into t1 values(13,'https');
insert into t1 values(14,'ftps');

select * from t1 where regexp_like(b,'^[[:lower:],[:digit:]]','i');

drop table t1;

create table t1(c1 blob);
insert into t1 values('UNPRESS123');
insert into t1 values('UNPRESS456');
select * from t1 where c1 regexp '^U';

