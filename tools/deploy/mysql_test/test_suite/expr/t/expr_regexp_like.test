--error 3995
SELECT regexp_replace(x'01', '1', '1');
--error 3995
SELECT regexp_replace(x'01', x'01', '1');
--error 3995
SELECT regexp_replace('1', '1', x'01');
SELECT hex(regexp_replace(x'01', x'01', x'02'));
SELECT regexp_replace('01', '1', '02');

create table t2 as select regexp_replace(c1,c2,'a') c1_2, regexp_replace(c1,c3,'a') c1_3, regexp_replace(c1,c1,'a') c1_1 from t1;
show create table t2;
drop table t2;
create table t2 as select regexp_replace(c1,'a',c2) c1_2, regexp_replace(c1,'a',c3) c1_3, regexp_replace(c1,'a',c1) c1_1 from t1;
show create table t2;
drop table t2;

##regexp_substr
--error 3995
SELECT regexp_substr('1', x'01');
--error 3995
SELECT regexp_substr(x'01', '1');
SELECT regexp_substr(x'01', x'01');

create table t2 as select regexp_substr(c1,c2) c1_2, regexp_substr(c1,c3) c1_3, regexp_substr(c1,c1) c1_1 from t1;
show create table t2;
drop table t2;

create table t2 as select regexp_substr(c3,c1) c3_1, regexp_substr(c3,c2) c3_3, regexp_substr(c3,c3) c3_2 from t1;
show create table t2;
drop table t2;

drop table t1;





