--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#### owner: peihan.dph
#### owner group: sql3
#### description: test for sleep func
set @tmp_ob_query_time_out = @@ob_query_timeout;
set @@ob_query_timeout = 3000000;
select sleep(-1);
select sleep(-111111111111111111111111111111111111);
select sleep(0);
select sleep(1);
select sleep(1.5);
select sleep(1.55555555555555555555555);
select sleep(18446744074);
--error 4012
select sleep(4);
--error 4012
select sleep(5);
select sleep(1111111111111111111111111111111111111);
select sleep(18446744073709551615);
select sleep(18446744073709551616);
--error 4012
select sleep(18446744072);
--error 4012
select sleep(18446744073);
--error 4012
select sleep(18446744073.6);
--error 4012
select sleep(18446744073.7);
--disable_warnings
drop table if exists sb;
--enable_warnings
create table sb(a int);
insert into sb values(1);
insert into sb values(2);
insert into sb values(3);
select sleep(2) from sb where a = 0;
select sleep(2) from sb where a = 1;
--error 4012
select sleep(2) from sb where a <= 3;


# 
--error 1210
select sleep(null);
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(c1 int);
insert into t1 values(0),(0);
select sleep(c1) from t1;
insert into t1 values(null);
--error 1210
select sleep(c1) from t1;

# 
--error 1210
SELECT SLEEP(@step);

drop table sb, t1;
set @@ob_query_timeout = @tmp_ob_query_time_out;
