result_format: 4


DROP TABLE test.`a'b`;
DROP TABLE test.t01;
DROP TABLE test.t02;
DROP TABLE test.t03;

CREATE TABLE test.`a'b`(col1 INT,col2 INT);
CREATE TABLE test.t01(id int);
CREATE TABLE test.t02(id int);
CREATE TABLE test.t03(col1 INT,col2 INT) 
       PARTITION BY LIST COLUMNS(col1)
       SUBPARTITION BY HASH(col2) SUBPARTITIONS 5
        (PARTITION p0 VALUES IN(100),
         PARTITION p1 VALUES IN(200),
         PARTITION p2 VALUES IN(300)
        );

DROP TABLE t01_sys;
CREATE TABLE t01_sys(id int);

select tenant_name, database_name, table_name, part_num, table_type, dup_replica_type from __all_virtual_proxy_schema where tenant_name='sys' and database_name='test' and table_name="a'b" order by role asc limit 1;
