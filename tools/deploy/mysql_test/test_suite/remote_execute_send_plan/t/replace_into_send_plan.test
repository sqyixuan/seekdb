--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: laibingzheng.lbz
# owner group: SQL2
# description: remote execute with send plan
# tags:dml, replace into

--disable_abort_on_error

--disable_warnings
drop table if exists t1, t2;
--enable_warnings

--echo # 必须远程执行发SQL，永远报错-4653, 然后重试发plan，测试发plan的路径
connect (conn_admin, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn_admin;
alter system set_tp tp_no = 256, error_code = 4653, frequency = 1;
sleep 1;

connection default;

CREATE TABLE t1 (
  gesuchnr int(11) DEFAULT '0' NOT NULL,
  benutzer_id int(11) DEFAULT '0' NOT NULL,
  PRIMARY KEY (gesuchnr,benutzer_id)
);

replace into t1 (gesuchnr,benutzer_id) values (2,1);
replace into t1 (gesuchnr,benutzer_id) values (1,1);
replace into t1 (gesuchnr,benutzer_id) values (1,1);
replace into t1 (gesuchnr,benutzer_id) values (1,1);
drop table t1;

create table t1(c1 int primary key, c2 int, c3 int);
replace into t1 set c1 = 3, c2=c1+2, c3=c2+11;
--error 1048
replace into t1 set c3 = 1, c1=c2+3;
replace into t1 set c3 = 1, c1=c3+3;
select * from t1;
create table t2(c1 int primary key, c2 int, c3 int);
replace into t2 select * from t1;
select * from t2;
replace into t2 select * from t1;
select * from t2;
delete from t2;
replace into t2 (c2,c1) select c1, c1+2 from t1;
select * from t2;
drop table t1,t2;


connection conn_admin;
alter system set_tp tp_no = 256, error_code = 0, frequency = 1;
