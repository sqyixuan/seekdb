# owner: zhanghuidong.zhd
# owner group: storage
# description: create table with delete insert merge engine, test the basic grammar

--disable_query_log
connect (conn_mysql,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
# connect (conn_oracle,$OBMYSQL_MS0,admin@oracle,admin,test,$OBMYSQL_PORT);
connect (conn_sys, $OBMYSQL_MS0,root@sys,,oceanbase,$OBMYSQL_PORT);
--enable_query_log

connection conn_mysql;
alter system set _enable_delete_insert_scan = true;
--disable_warnings
drop table if exists t1;
drop table if exists t2;
drop table if exists t3;
drop table if exists t4;
drop table if exists t5;
drop table if exists t6;
drop table if exists t9;
--enable_warnings
alter system set _enable_parallel_table_creation = true;
sleep 3;
create table t1(c1 int primary key, c2 int, c3 int) merge_engine = delete_insert;
create table t3(c1 int primary key, c2 int, c3 int);
alter system set _enable_parallel_table_creation = false;
sleep 3;
create table t2(c1 int primary key, c2 int, c3 int) merge_engine = delete_insert with column group (each column);
create table t4(c1 int primary key, c2 int, c3 int) merge_engine = partial_update with column group (each column);

insert into t1 values (1,2,3), (2,3,4), (3,4,5), (4,5,6), (5,6,7), (6,7,8);
insert into t2 values (1,2,3), (2,3,4), (3,4,5), (4,5,6), (5,6,7), (6,7,8);
insert into t3 values (1,2,3), (2,3,4), (3,4,5), (4,5,6), (5,6,7), (6,7,8);
insert into t4 values (1,2,3), (2,3,4), (3,4,5), (4,5,6), (5,6,7), (6,7,8);

alter system major freeze;
--source mysql_test/include/wait_daily_merge.inc

connection conn_mysql;
update t1 set c2 = c2 * 10 where c1 = 3 or c1 = 4;
update t2 set c2 = c2 * 10 where c1 = 3 or c1 = 4;
update t3 set c2 = c2 * 10 where c1 = 3 or c1 = 4;
update t4 set c2 = c2 * 10 where c1 = 3 or c1 = 4;

alter system minor freeze;
--source mysql_test/include/wait_minor_merge.inc

connection conn_mysql;
insert into t1 values (7,8,9), (8,9,10);
insert into t2 values (7,8,9), (8,9,10);
insert into t3 values (7,8,9), (8,9,10);
insert into t4 values (7,8,9), (8,9,10);

alter system minor freeze;
--source mysql_test/include/wait_minor_merge.inc

connection conn_mysql;
explain select * from t1 order by c2;
explain select * from t2 order by c3;
explain select * from t3 order by c3;
explain select * from t4 order by c2;
select * from t1 order by c2;
select * from t2 order by c3;
select * from t3 order by c3;
select * from t4 order by c2;

# check sys table
select merge_engine_type from oceanbase.__all_table where table_name = "t1";
select merge_engine_type from oceanbase.__all_table where table_name = "t2";
select merge_engine_type from oceanbase.__all_table where table_name = "t3";
select merge_engine_type from oceanbase.__all_table where table_name = "t4";

# check with global config
alter system set default_table_merge_engine = 'delete_insert';
sleep 3;
create table t5(c1 int primary key, c2 int, c3 int);
create table t6(c1 int primary key, c2 int, c3 int) merge_engine = partial_update;
select merge_engine_type from oceanbase.__all_table where table_name = "t5";
select merge_engine_type from oceanbase.__all_table where table_name = "t6";
alter system set default_table_merge_engine = 'partial_update';
alter system set _enable_delete_insert_scan = false;
sleep 3;
explain select * from t1 order by c2;
explain select * from t2 order by c3;

# check oracle mode grammar
# connection conn_oracle;
# create table t7(c1 int primary key, c2 int, c3 int) merge_engine = delete_insert with column group (each column);
# create table t8(c1 int primary key, c2 int, c3 int) merge_engine = partial_update with column group (all columns);
# connection conn_sys;
# select merge_engine_type from __all_virtual_table where table_name = "t7";
# select merge_engine_type from __all_virtual_table where table_name = "t8";

# check show create table
connection conn_mysql;
show create table t1;
show create table t3;
show create table t4;
set _show_ddl_in_compat_mode = 1;
show create table t1;
show create table t3;
show create table t4;

# check alter table option
--error 1235
alter table t1 set merge_engine = partial_update;

# check truncate parition
create table t9 (id1 int, id2 int, c1 int, c2 varchar(100), c3 VARCHAR(100), primary key(id1, id2), index(c1)) merge_engine=delete_insert partition by range(id1) (partition p0 values less than(0) , partition p1 values less than(65535) , partition p2 values less than(maxvalue));
alter table t9 truncate partition p0;
alter table t9 truncate partition p1;
alter table t9 truncate partition p2;
insert into t9 values (1, 1, 1, 'a', 'a'), (2, 2, 2, 'b', 'b'), (3, 3, 3, 'c', 'c');
update t9 set c1 = 100 where id1 < 10;

--disable_query_log
connection conn_mysql;
alter system set _enable_delete_insert_scan = true;
--enable_query_log

drop table t1;
drop table t2;
drop table t3;
drop table t4;
drop table t5;
drop table t6;
drop table t9;
# connection conn_oracle;
# drop table t7;
# drop table t8;
