# owner: zhanghuidong.zhd
# owner group: storage
# description: reproduce 4016 bug under concurrent txn

connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn2,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn1;

--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(c1 int primary key, c2 int) merge_engine = delete_insert;
insert into t1 values (3,300), (4,200), (5,5), (7,7), (8,65), (100,100), (2000,200),(10320, 320302), (43294,20302);
alter system major freeze;
--source mysql_test/include/wait_daily_merge.inc

connection conn1;
begin;
update t1 set c2 = 300 where c1 = 4;

connection conn2;
begin;
update t1 set c2 = 300 where c1 = 3;
select * from t1;

connection conn1;
commit;

connection conn2;
commit;

drop table t1;
