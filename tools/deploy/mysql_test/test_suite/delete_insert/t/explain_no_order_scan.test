# owner: zhanghuidong.zhd
# owner group: storage
# description: test explain no order scan mode for delete insert

connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn1;
--disable_warnings
drop table if exists t1;
drop table if exists t2;
--enable_warnings
create table t1(c1 int primary key, c2 int, c3 int, c4 int, index(c4) local) merge_engine = delete_insert;
create table t2(c1 int primary key, c2 int, c3 int, c4 int) merge_engine = delete_insert;

--disable_query_log
let $cnt = 1;
while($cnt <= 100)
{
    eval insert into t1 values ($cnt, $cnt+1, $cnt+2, $cnt+10);
    inc $cnt;
}
--enable_query_log

explain select * from t1;
explain select count(*) from t1;
explain select sum(c1 + c2) from t1;
explain select c2 + c3 from t1 order by c4;
explain select c2 + c3 from t1 order by c4 desc;
explain select * from t1 limit 20 offset 40;
explain insert into t2 select * from t1 limit 20 offset 40;
explain select * from t1 order by c1;
explain select * from t1 order by c1 desc;
explain select sum(t1.c1 + t1.c2) from t1, t2 where t1.c3 = 2 * t2.c3 group by t1.c4 order by t1.c4;

drop table t1;
drop table t2;
