# owner: zhanghuidong.zhd
# owner group: storage
# description: test delete insert table with index

connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn1;
--disable_warnings
drop table if exists t1;
drop table if exists t2;
drop table if exists t3;
drop view if exists t4;
drop materialized view if exists t5;
--enable_warnings
# bug: index table use delete_insert flag in mvcc ctx write flag
create table t1(c1 int primary key, c2 int, c3 int, index(c3)) merge_engine = delete_insert;

insert into t1 values (1, 2, 3), (2, 3, 3), (3, 4, 5);
update t1 set c3 = 100 where c3 = 3;
select * from t1;
drop table t1;

# set default merge_engine to partial_update
alter system set default_table_merge_engine = 'partial_update';
# test with index
create table t2 (c1 int primary key, c2 int, c3 int, c4 int, c5 int, index(c2), unique index(c3), index(c4) global) merge_engine = delete_insert;
--error 1064
create index i5 on t2(c5) merge_engine = delete_insert;
let $table_id2 = query_get_value(select table_id from oceanbase.__all_table where table_name = 't2', table_id, 1);
--disable_query_log
eval select unique(merge_engine_type) from oceanbase.__all_table where data_table_id = $table_id2;
--enable_query_log

# test with lob/gis
create table t3 (c1 int primary key, c2 BLOB, c3 GEOMETRY NOT NULL SRID 0) merge_engine = delete_insert;
alter table t3 add c4 blob;
create spatial index t3_i1 on t3(c3);
let $table_id3 = query_get_value(select table_id from oceanbase.__all_table where table_name = 't3', table_id, 1);
--disable_query_log
eval select unique(merge_engine_type) from oceanbase.__all_table where data_table_id = $table_id3;
--enable_query_log

# test with view
create view t4 as select * from t2;
select unique(merge_engine_type) from oceanbase.__all_table where table_name = 't4';

# test with materialized view
create materialized view t5 refresh complete as select * from t3;
select unique(merge_engine_type) from oceanbase.__all_table where table_name = 't5';

drop table t2;
drop table t3;
drop view t4;
drop materialized view t5;

# set default merge_engine to delete insert
alter system set default_table_merge_engine = 'delete_insert';
# test with index
create table t2 (c1 int primary key, c2 int, c3 int, c4 int, c5 int, index(c2), unique index(c3), index(c4) global);
create index i5 on t2(c5);
let $table_id2 = query_get_value(select table_id from oceanbase.__all_table where table_name = 't2', table_id, 1);
--disable_query_log
eval select unique(merge_engine_type) from oceanbase.__all_table where data_table_id = $table_id2;
--enable_query_log

# test with lob
create table t3 (c1 int primary key, c2 BLOB);
alter table t3 add c3 blob;
let $table_id3 = query_get_value(select table_id from oceanbase.__all_table where table_name = 't3', table_id, 1);
--disable_query_log
eval select unique(merge_engine_type) from oceanbase.__all_table where data_table_id = $table_id3;
--enable_query_log

# test with view
create view t4 as select * from t2;
select unique(merge_engine_type) from oceanbase.__all_table where table_name = 't4';

# test with materialized view
create materialized view t5 refresh complete as select * from t3;
select unique(merge_engine_type) from oceanbase.__all_table where table_name = 't5';

drop table t2;
drop table t3;
drop view t4;
drop materialized view t5;
alter system set default_table_merge_engine = 'partial_update';