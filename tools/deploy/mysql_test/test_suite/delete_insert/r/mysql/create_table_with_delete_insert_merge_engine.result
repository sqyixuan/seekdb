alter system set _enable_delete_insert_scan = true;
drop table if exists t1;
drop table if exists t2;
drop table if exists t3;
drop table if exists t4;
drop table if exists t5;
drop table if exists t6;
drop table if exists t9;
alter system set _enable_parallel_table_creation = true;
create table t1(c1 int primary key, c2 int, c3 int) merge_engine = delete_insert;
create table t3(c1 int primary key, c2 int, c3 int);
alter system set _enable_parallel_table_creation = false;
create table t2(c1 int primary key, c2 int, c3 int) merge_engine = delete_insert with column group (each column);
create table t4(c1 int primary key, c2 int, c3 int) merge_engine = partial_update with column group (each column);
insert into t1 values (1,2,3), (2,3,4), (3,4,5), (4,5,6), (5,6,7), (6,7,8);
insert into t2 values (1,2,3), (2,3,4), (3,4,5), (4,5,6), (5,6,7), (6,7,8);
insert into t3 values (1,2,3), (2,3,4), (3,4,5), (4,5,6), (5,6,7), (6,7,8);
insert into t4 values (1,2,3), (2,3,4), (3,4,5), (4,5,6), (5,6,7), (6,7,8);
alter system major freeze;
update t1 set c2 = c2 * 10 where c1 = 3 or c1 = 4;
update t2 set c2 = c2 * 10 where c1 = 3 or c1 = 4;
update t3 set c2 = c2 * 10 where c1 = 3 or c1 = 4;
update t4 set c2 = c2 * 10 where c1 = 3 or c1 = 4;
alter system minor freeze;
insert into t1 values (7,8,9), (8,9,10);
insert into t2 values (7,8,9), (8,9,10);
insert into t3 values (7,8,9), (8,9,10);
insert into t4 values (7,8,9), (8,9,10);
alter system minor freeze;
explain select * from t1 order by c2;
