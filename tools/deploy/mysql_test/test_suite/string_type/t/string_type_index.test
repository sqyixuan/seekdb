# owner: houhaojun.hhj
# tags: storage
# description: test the functions of string type

--disable_query_log
set global max_allowed_packet=60000000;
set global ob_sql_work_area_percentage=80;
sleep 1;
set @@recyclebin = off;
set ob_query_timeout=1000000000;
set ob_trx_timeout=1000000000;

--disable_warnings
drop table if exists t_s1, t_s2, t_part1, t_part2, t_u1, t_u2, t_ft1, t_ft2, t_ft3, t_ch;
--enable_warnings
--enable_query_log

--result_format 4

####################### storing column #######################
create table t_s1 (c1 string, c2 string, index idx_c1(c1) storing(c2)) lob_inrow_threshold = 4;
insert into t_s1 values ("a", "b");
insert into t_s1 values ("abcd", "hijk");
--error 1235
insert into t_s1 values ("abcde", "hijkl");
select * from t_s1;

create table t_s2 (c1 string, c2 string) lob_inrow_threshold = 4;
insert into t_s2 values ("a", "b");
insert into t_s2 values ("abcd", "hijk");
insert into t_s2 values ("abcde", "hijkl");
--error 1071
create index idx_c1 on t_s2(c1) storing(c2);
select * from t_s2;

####################### partition key and index #######################
create table t_part1(c1 string, c2 string, index(c1) global) lob_inrow_threshold = 2 partition by key(c1) partitions 4;
insert into t_part1 values ("aa", "11");
insert into t_part1 values ("bb", "22");
insert into t_part1 values ("cc", "33");
insert into t_part1 values ("dd", "44");

select * from t_part1;
select * from t_part1 partition(p0);
select * from t_part1 partition(p1);
select * from t_part1 partition(p2);
select * from t_part1 partition(p3);

create table t_part2(c1 string, c2 string, index(c2) global) lob_inrow_threshold = 2 partition by key(c1) partitions 4;
insert into t_part2 values ("aa", "11");
--error 1235
insert into t_part2 values ("bbb", "22");
insert into t_part2 values ("bb", "22");
insert into t_part2 values ("cc", "33");
--error 1235
insert into t_part2 values ("dd", "444");
insert into t_part2 values ("dd", "44");

select * from t_part2;
select * from t_part2 partition(p0);
select * from t_part2 partition(p1);
select * from t_part2 partition(p2);
select * from t_part2 partition(p3);

####################### unique index #######################
create table t_u1 (c1 string unique) lob_inrow_threshold = 2;
insert into t_u1 values("aa");
--error 1235
insert into t_u1 values("aaa");
select * from t_u1;

create table t_u2 (c1 string) lob_inrow_threshold = 2;
insert into t_u2 values("aa");
insert into t_u2 values("aaa");
--error 1071
create unique index idx_c1 on t_u2(c1);
select * from t_u2; 

####################### fulltext index #######################
create table t_ft1(id int, c1 tinytext, c2 text, c3 mediumtext, primary key(id), fulltext index ft_idx1(c1), fulltext index ft_idx2(c2), fulltext index ft_idx3(c3));
alter table t_ft1 modify column c1 string;
alter table t_ft1 modify column c2 string;
alter table t_ft1 modify column c3 string;

create table t_ft2(id int, c1 string, c2 string, c3 varchar(10), fulltext index ft_idx1(c1));
insert into t_ft2 values (1, "c1: fulltext search index support string type", "c2: fulltext search index support string type", "hello");
insert into t_ft2 values (2, "c1: this is a test sql to test string fulltext, fulltext", "c2: this is a test sql to test string fulltext", "world");
insert into t_ft2 values (3, "c1: oceanbase is a database", "c2: oceanbase is a database", "string");
insert into t_ft2 values (4, "c1: fulltext search is supported in oceanbase", "c2: fulltext search is supported in oceanbase", "oceanbase");
insert into t_ft2 values (5, "c1: fulltext search index support string type", "c2: fulltext search index support string type", "fulltext");

create fulltext index ft_idx2 on t_ft2(c2);
create fulltext index ft_idx3 on t_ft2(c1, c2, c3);

select id, c1 from t_ft2 where match(c1) against ('+fulltext' IN BOOLEAN MODE);
select id, match(c2) against ('fulltext') as score from t_ft2 where match(c2) against ('+fulltext' IN BOOLEAN MODE);
select * from t_ft2 where match(c1,c2,c3) against ('+string' IN BOOLEAN MODE);
select id, match(c1, c2, c3) against ('string') as score from t_ft2 where match(c1, c2, c3) against ('+string' IN BOOLEAN MODE);

create table t_ft3(c1 string, c2 string, c3 string, primary key(c1, c2), fulltext index ft_idx(c2));
insert into t_ft3 values("test1 begin", "this is a test for string primary key with fulltext index", "test1 finish");
insert into t_ft3 values("test2 begin", "fulltext index can be built on string primary key", "test2 finish");

select * from t_ft3 where match(c2) against('+string' IN BOOLEAN MODE);
select * from t_ft3 where match(c2) against('+built' IN BOOLEAN MODE);
select match(c2) against ('string') as score from t_ft3 where match(c2) against ('+string' IN BOOLEAN MODE);

####################### column character #######################
create table t_ch (c1 varchar(10), c2 mediumtext, c3 string);
--source mysql_test/include/show_create_table_old_version.inc
show create table t_ch;
insert into t_ch values("varchar", "mediumtext", "this is a string column value");
insert into t_ch values("varchar", "this is a mediumtext column", "this is a string column value, too");

alter table t_ch convert to character set binary;
--source mysql_test/include/show_create_table_old_version.inc
show create table t_ch;
--error 1283
create fulltext index ft_idx1 on t_ch(c1);
--error 1283
create fulltext index ft_idx2 on t_ch(c2);
--error 1283
create fulltext index ft_idx3 on t_ch(c3);

alter table t_ch convert to character set utf8;
--source mysql_test/include/show_create_table_old_version.inc
show create table t_ch;
--error 1283
create fulltext index ft_idx1 on t_ch(c1);
--error 1283
create fulltext index ft_idx2 on t_ch(c2);
create fulltext index ft_idx3 on t_ch(c3);

create index idx_c3 on t_ch(c3);

select * from t_ch;
select match(c3) against ('string') as score from t_ch where match(c3) against ('+string' IN BOOLEAN MODE);
select /*+index(idx_c3)*/ c3 from t_ch;

# to verify the checksum
alter system major freeze;
--source mysql_test/include/wait_daily_merge.inc

select * from t_s1;
select * from t_s2;

select * from t_part1;
select * from t_part1 partition(p0);
select * from t_part1 partition(p1);
select * from t_part1 partition(p2);
select * from t_part1 partition(p3);
select * from t_part2;
select * from t_part2 partition(p0);
select * from t_part2 partition(p1);
select * from t_part2 partition(p2);
select * from t_part2 partition(p3);

select * from t_u1;
select * from t_u2;

alter table t_ft2 modify column c3 string;

select id, c1 from t_ft2 where match(c1) against ('+fulltext' IN BOOLEAN MODE);
select id, match(c2) against ('fulltext') as score from t_ft2 where match(c2) against ('+fulltext' IN BOOLEAN MODE);
select * from t_ft2 where match(c1,c2,c3) against ('+string' IN BOOLEAN MODE);
select id, match(c1, c2, c3) against ('string') as score from t_ft2 where match(c1, c2, c3) against ('+string' IN BOOLEAN MODE);

select * from t_ft3 where match(c2) against('+string' IN BOOLEAN MODE);
select * from t_ft3 where match(c2) against('+built' IN BOOLEAN MODE);
select match(c2) against ('string') as score from t_ft3 where match(c2) against ('+string' IN BOOLEAN MODE);

select * from t_ch;
select match(c3) against ('string') as score from t_ch where match(c3) against ('+string' IN BOOLEAN MODE);
select /*+index(idx_c3)*/ c3 from t_ch;

drop table t_s1, t_s2, t_part1, t_part2, t_u1, t_u2, t_ft1, t_ft2, t_ft3, t_ch;

--disable_query_log
set global ob_sql_work_area_percentage=5;
set @@recyclebin = on;
--enable_query_log
