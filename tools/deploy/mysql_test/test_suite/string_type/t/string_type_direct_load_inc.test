# owner: houhaojun.hhj
# tags: storage
# description: test the inc direct load of string type

--disable_query_log
set global max_allowed_packet=60000000;
set global ob_sql_work_area_percentage=80;
sleep 1;
set @@recyclebin = off;
set ob_query_timeout=1000000000;
set ob_trx_timeout=1000000000;

--disable_query_log
--disable_warnings
drop table if exists t_src, t_dst_inc, t_dst_heap, t_ld_inc, t_ld_heap;
drop table if exists t1, t2;

--enable_warnings
--enable_query_log

create table t_src (c1 string, c2 string) lob_inrow_threshold = 8192;
create table t_dst_inc (c1 string primary key, c2 string, index idx_c2(c2) local);
create table t_dst_heap (c1 string, c2 string) lob_inrow_threshold = 8192;

insert into t_src values("aaa", "bbb");
insert into t_src values(repeat("c", 8193), "ddd");
insert into t_src values(repeat("e", 16381), "fff");
insert into t_src values("ggg", repeat("h", 8193));
insert into t_src values("hhhh", repeat("i", 16368));
insert into t_src values("iiii", repeat("j", 16376));
insert into t_src values("kkkk", repeat("l", 16377));

########## insert into select ##########
create table t1 (c1 string, c2 int auto_increment, unique key pk (c1) storing (c2));
create table t2 (c1 string, c2 int);
insert into t2 values ("string", 1);
insert /*+parallel(2) direct(true, 0, 'inc') enable_parallel_dml*/ into t1 select * from t2;
select * from t2;

insert /*+direct(true, 0, 'inc') enable_parallel_dml parallel(4)*/ into t_dst_inc select c1, c2 from t_src where c1 = "aaa";
--error 1062
insert /*+direct(true, 0, 'inc') enable_parallel_dml parallel(4)*/ into t_dst_inc select c1, c2 from t_src where c1 = "aaa";
--error 1071
insert /*+direct(true, 0, 'inc') enable_parallel_dml parallel(4)*/ into t_dst_inc select c1, c2 from t_src where c2 = "ddd";
--error 1071
insert /*+direct(true, 0, 'inc') enable_parallel_dml parallel(4)*/ into t_dst_inc select c1, c2 from t_src where c2 = "fff";
--error 1071
insert /*+direct(true, 0, 'inc') enable_parallel_dml parallel(4)*/ into t_dst_inc select c1, c2 from t_src where c1 = "ggg";

insert /*+direct(true, 0, 'inc') enable_parallel_dml parallel(4)*/ into t_dst_heap select c1, c2 from t_src;

########## load data ##########
--source mysql_test/test_suite/string_type/include/prepare_data.inc

create table t_ld_inc (c1 string primary key, c2 int, c3 string, index idx_c3(c3) local);
create table t_ld_heap (c1 string, c2 string, c3 string);

--disable_query_log
eval load data /*+direct(true, 0, 'inc') parallel(4)*/ infile "$OBSERVER_DIR/$DATA_FOLDER_NAME/string_test/data_pk_100.csv" into table t_ld_inc fields terminated by ',';
eval load data /*+direct(true, 0, 'inc') parallel(4)*/ infile "$OBSERVER_DIR/$DATA_FOLDER_NAME/string_test/data_pk_8193.csv" into table t_ld_inc fields terminated by ',';
--error 1071
eval load data /*+direct(true, 0, 'inc') parallel(4)*/ infile "$OBSERVER_DIR/$DATA_FOLDER_NAME/string_test/data_pk_16373.csv" into table t_ld_inc fields terminated by ',';
--error 1071
eval load data /*+direct(true, 0, 'inc') parallel(4)*/ infile "$OBSERVER_DIR/$DATA_FOLDER_NAME/string_test/data_idx_8193.csv" into table t_ld_inc fields terminated by ',';

eval load data /*+direct(true, 0, 'inc') parallel(4)*/ infile "$OBSERVER_DIR/$DATA_FOLDER_NAME/string_test/data_pk_100.csv" into table t_ld_heap fields terminated by ',';
eval load data /*+direct(true, 0, 'inc') parallel(4)*/ infile "$OBSERVER_DIR/$DATA_FOLDER_NAME/string_test/data_pk_8193.csv" into table t_ld_heap fields terminated by ',';
eval load data /*+direct(true, 0, 'inc') parallel(4)*/ infile "$OBSERVER_DIR/$DATA_FOLDER_NAME/string_test/data_pk_16373.csv" into table t_ld_heap fields terminated by ',';
eval load data /*+direct(true, 0, 'inc') parallel(4)*/ infile "$OBSERVER_DIR/$DATA_FOLDER_NAME/string_test/data_idx_8193.csv" into table t_ld_heap fields terminated by ',';
--enable_query_log

select count(*) from t_src;
select char_length(c1), char_length(c2) from t_src;
select count(*) from t_dst_inc;
select char_length(c1), char_length(c2) from t_dst_inc;
select count(*) from t_dst_heap;
select char_length(c1), char_length(c2) from t_dst_heap order by 1,2;
select count(*) from t_ld_inc;
select char_length(c1), c2, char_length(c3) from t_ld_inc;
select count(*) from t_ld_heap;
select char_length(c1), c2, char_length(c3) from t_ld_heap order by 1,2,3;

# to verify the checksum
alter system major freeze;
--source mysql_test/include/wait_daily_merge.inc

select count(*) from t_src;
select char_length(c1), char_length(c2) from t_src;
select count(*) from t_dst_inc;
select char_length(c1), char_length(c2) from t_dst_inc;
select count(*) from t_dst_heap;
select char_length(c1), char_length(c2) from t_dst_heap order by 1,2;
select count(*) from t_ld_inc;
select char_length(c1), c2, char_length(c3) from t_ld_inc;
select count(*) from t_ld_heap;
select char_length(c1), c2, char_length(c3) from t_ld_heap order by 1,2,3;

drop table t_src, t_dst_inc, t_dst_heap, t_ld_inc, t_ld_heap;
drop table t1, t2;

--disable_query_log
set global ob_sql_work_area_percentage=5;
set @@recyclebin = on;
--enable_query_log
