# owner: houhaojun.hhj
# tags: storage
# description: test the alter column functions of string type

--disable_query_log
set global max_allowed_packet=60000000;
set global ob_sql_work_area_percentage=80;
sleep 1;
set @@recyclebin = off;
set ob_query_timeout=1000000000;
set ob_trx_timeout=1000000000;

########## check alter column ##########

--disable_query_log
--disable_warnings
drop table if exists t_add_pk1, t_add_pk2, t_add_pk3, t_alt_pk1, t_alt_pk2, t_alt_pk3, t_alt_pk4, t_alt_pk5;
drop table if exists t_add_col1, t_add_col2, t_mod_col1, t_mod_col2;
--enable_warnings
--enable_query_log

## modify column
create table t_mod_col1(c1 string, c2 string, c3 string, c4 string, c5 string, c6 string, c7 string, c8 string);
--disable_query_log
--let $count = 0
while($count < 100)
{
  eval insert into t_mod_col1 values($count, concat("bb", $count), concat("ccc", $count), concat("dddd", $count), concat("e", $count), concat("ff", $count), concat("ggg", $count), concat("hhhh", $count));
  --inc $count
}
insert into t_mod_col1 values(NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL);
--enable_query_log

create table t_mod_col2(c1 int, c2 char(20), c3 varchar(30), c4 binary(10), c5 mediumtext, c6 longtext, c7 text, c8 blob, c9 set('a','b','c'));
--disable_query_log
--let $count = 0
while($count < 10)
{
  eval insert into t_mod_col2 values($count, concat("bb", $count), concat("ccc", $count), concat("dddd", $count), concat("e", $count), concat("ff", $count), concat("ggg", $count), concat("hhhh", $count), 'a');
  --inc $count
}
while($count < 20)
{
  eval insert into t_mod_col2 values($count, concat("bb", $count), concat("ccc", $count), concat("dddd", $count), concat("e", $count), concat("ff", $count), concat("ggg", $count), concat("hhhh", $count), 'b');
  --inc $count
}
while($count < 30)
{
  eval insert into t_mod_col2 values($count, concat("bb", $count), concat("ccc", $count), concat("dddd", $count), concat("e", $count), concat("ff", $count), concat("ggg", $count), concat("hhhh", $count), 'c');
  --inc $count
}
--enable_query_log

## add column
create table t_add_col1(c1 int);
insert into t_add_col1 values(1), (2), (3), (4);
alter table t_add_col1 add c2 string;
alter table t_add_col1 add c3 string not null;

create index idx_c2 on t_add_col1(c2);
create index idx_c3 on t_add_col1(c3);
create index idx_c1_c2 on t_add_col1(c1, c2);

create table t_add_col2(c1 int);
insert into t_add_col2 values(1), (2), (3), (4);
alter table t_add_col2 add c2 string;
alter table t_add_col2 add c3 string not null;

alter system minor freeze;
--source mysql_test/include/wait_minor_merge.inc

create index idx_c2 on t_add_col2(c2);
create index idx_c3 on t_add_col2(c3);
create index idx_c1_c2 on t_add_col2(c1, c2);

# add string primary key, primary key length is '16K'
create table t_add_pk1 (c1 string, c2 varchar(262144), c3 varchar(126977));
create table t_add_pk2 (c1 string, c2 double, c3 string, c4 varchar(262144), c5 varchar(126976));

## check rowkey length is less than '16K'
create table t_add_pk3 (c1 varchar(3969), c2 string);

# alter column with string primary key
## change non-string rowkey column to string.
create table t_alt_pk1 (c1 varchar(4096), c2 varchar(262144), c3 varchar(126976), primary key(c1));
create table t_alt_pk2 (c1 varchar(4095), c2 varchar(262144), c3 varchar(126977), primary key(c1));


## change string rowkey column to non-string column
### rowkey has only one string column
create table t_alt_pk3 (c1 varchar(262144), c2 varchar(126976), c3 string, primary key(c3));

### rowkey has more than one string column
create table t_alt_pk4 (c1 varchar(262144), c2 string, c3 varchar(126976), c4 string,  primary key(c2, c4));

## check rowkey length is less than '16K'
create table t_alt_pk5 (c1 varchar(3969), c2 varchar(127), c3 varchar(3), primary key(c1, c2));

--disable_query_log
--let $count = 0
while($count < 100)
{
  eval insert into t_add_pk1 values(concat("oceanbase", $count), "hello world", "tpcc");
  eval insert into t_add_pk2 values(concat("oceanbase", $count), 7.7, "hello", "world", "tpcc");
  eval insert into t_add_pk3 values(concat("oceanbase", $count), "hello world");
  eval insert into t_alt_pk1 values(concat("oceanbase", $count), "hello world", "tpcc");
  eval insert into t_alt_pk2 values(concat("oceanbase", $count), "hello world", "tpch");
  eval insert into t_alt_pk3 values("oceanbase", "hello", concat("world", $count));
  eval insert into t_alt_pk4 values("oceanbase", concat("tpcc", $count), "tpch", "hello world");
  eval insert into t_alt_pk5 values(concat("oceanbase", $count), "hello world", "aa");
  --inc $count
}
# insert outrow string
eval insert into t_add_pk1 values(repeat("x", 8193), "hello world", "tpcc");
eval insert into t_add_pk2 values("oceanbase", 7.7, repeat("x", 8193), "world", "tpcc");
eval insert into t_add_pk3 values("oceanbase", repeat("x", 8193));
eval insert into t_alt_pk1 values("oceanbase", "hello world", "tpcc");
eval insert into t_alt_pk2 values("oceanbase", "hello world", "tpch");
eval insert into t_alt_pk3 values("oceanbase", "hello", "world");
eval insert into t_alt_pk4 values("oceanbase", "tpcc", "tpch", "hello world");
eval insert into t_alt_pk5 values("oceanbase", "hello world", "aa");
--enable_query_log

alter system major freeze;
--source mysql_test/include/wait_daily_merge.inc

# modify column
## string to other data types
alter table t_mod_col1 modify column c1 int;
alter table t_mod_col1 modify column c2 char(10);
alter table t_mod_col1 modify column c3 varchar(10);
alter table t_mod_col1 modify column c4 binary(10);
alter table t_mod_col1 modify column c5 mediumtext;
alter table t_mod_col1 modify column c6 longtext;
alter table t_mod_col1 modify column c7 text;
alter table t_mod_col1 modify column c8 blob;

alter table t_mod_col1 rename column c2 to a1;
alter table t_mod_col1 rename column c1 to a1, rename column a1 to a2;

--source mysql_test/include/show_create_table_old_version.inc
show create table t_mod_col1;
select min(a1), max(a1), min(a2), max(a2), min(c3), max(c3), min(HEX(c4)), max(HEX(c4)), min(c5), max(c5), min(c6), max(c6), min(c7), max(c7), min(c8), max(c8) from t_mod_col1;

--error 1138
alter table t_mod_col1 modify column c5 string not null;
update t_mod_col1 set c5 = "not null" where c5 is null;
alter table t_mod_col1 modify column c5 string not null;
--error 1048
insert into t_mod_col1 values (NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL);

--source mysql_test/include/show_create_table_old_version.inc
show create table t_mod_col1;
select min(a1), max(a1), min(a2), max(a2), min(c3), max(c3), min(HEX(c4)), max(HEX(c4)), min(c5), max(c5), min(c6), max(c6), min(c7), max(c7), min(c8), max(c8) from t_mod_col1;

## other data types to string
alter table t_mod_col2 modify column c1 string;
alter table t_mod_col2 modify column c2 string;
alter table t_mod_col2 modify column c3 string;
alter table t_mod_col2 modify column c4 string;
alter table t_mod_col2 modify column c5 string;
alter table t_mod_col2 modify column c6 string;
alter table t_mod_col2 modify column c7 string;
alter table t_mod_col2 modify column c8 string;
alter table t_mod_col2 modify column c9 string;

--source mysql_test/include/show_create_table_old_version.inc
show create table t_mod_col2;

select min(c1), max(c1), min(c2), max(c2), min(c3), max(c3), min(HEX(c4)), max(HEX(c4)), min(c5), max(c5), min(c6), max(c6), min(c7), max(c7), min(c8), max(c8), min(c9), max(c9) from t_mod_col2;

# add string primary key, primary key length is '16K'
--error 1118
alter table t_add_pk1 add primary key(c1);

--error 1118
alter table t_add_pk2 add primary key(c1);
alter table t_add_pk2 add primary key(c1, c2, c3);

## check rowkey length is less than '16K'
#### need report error after fix bug in master
#### --error 1071
#### alter table t_add_pk3 add primary key (c1, c2);
alter table t_add_pk3 modify c1 varchar(3968);
alter table t_add_pk3 add primary key (c1, c2);

# alter column with string primary key
## change non-string rowkey column to string.
alter table t_alt_pk1 modify c1 string;
--error 1118
alter table t_alt_pk2 modify c1 string;

## change string rowkey column to non-string column
### rowkey has only one string column
alter table t_alt_pk3 modify c3 varchar(2048);
alter table t_alt_pk3 add column c4 varchar(2048);

### rowkey has more than one string column
alter table t_alt_pk4 modify c2 varchar(2048);
--error 1118
alter table t_alt_pk4 add column c5 varchar(2048);

## check rowkey length is less than '16K'
alter table t_alt_pk5 modify c2 string;
alter table t_alt_pk5 modify c1 varchar(3968);
alter table t_alt_pk5 modify c2 string;

drop table t_add_pk1, t_add_pk2, t_add_pk3, t_alt_pk1, t_alt_pk2, t_alt_pk3, t_alt_pk4, t_alt_pk5;
drop table t_add_col1, t_add_col2, t_mod_col1, t_mod_col2;

--disable_query_log
set global ob_sql_work_area_percentage=5;
set @@recyclebin = on;
--enable_query_log
