# owner: houhaojun.hhj
# tags: storage
# description: test the compatibility of string type

--disable_query_log
set global max_allowed_packet=60000000;
set global ob_sql_work_area_percentage=80;
sleep 1;
set @@recyclebin = off;
set ob_query_timeout=1000000000;
set ob_trx_timeout=1000000000;

--disable_warnings
drop table if exists t1, t2, t3, t4, t5, t6, t_cs1, t_cs2;
drop table if exists t_outrow;
--enable_warnings
--enable_query_log

--result_format 4

create table t_cs1 (c1 string CHARACTER set gbk);
create table t_cs2 (c1 string CHARACTER set utf8mb4 COLLATE utf8mb4_bin);
--source mysql_test/include/show_create_table_old_version.inc
show create table t_cs1;
--source mysql_test/include/show_create_table_old_version.inc
show create table t_cs2;
drop table t_cs1, t_cs2;

create table t_cs1 (c1 string);
create table t_cs2 (c1 string);
--source mysql_test/include/show_create_table_old_version.inc
show create table t_cs1;
--source mysql_test/include/show_create_table_old_version.inc
show create table t_cs2;

alter table t_cs1 modify c1 string CHARACTER set gbk;
alter table t_cs2 modify c1 string CHARACTER set utf8mb4 COLLATE utf8mb4_bin;
--source mysql_test/include/show_create_table_old_version.inc
show create table t_cs1;
--source mysql_test/include/show_create_table_old_version.inc
show create table t_cs2;

drop table t_cs1, t_cs2;

create table t1 (c1 string, c2 int, c3 string, c4 varchar(10), c5 mediumtext, primary key(c1));
create index idx_c3 on t1(c3);

--source mysql_test/include/show_create_table_old_version.inc
show create table t1;
desc t1;
show index from t1;
show columns from t1;
select * from information_schema.COLUMNS where table_name='t1';

--disable_warnings
drop table if exists t1;
--enable_warnings

CREATE TABLE `t1` (
  `c1` string NOT NULL,
  `c2` int(11) DEFAULT NULL,
  `c3` string DEFAULT NULL,
  `c4` varchar(10) DEFAULT NULL,
  `c5` mediumtext DEFAULT NULL,
  PRIMARY KEY (`c1`),
  KEY `idx_c3` (`c3`) BLOCK_SIZE 16384 LOCAL
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0;

--disable_query_log
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,oceanbase,$OBMYSQL_PORT);
connection obsys;
--enable_query_log
select OWNER, TABLE_NAME, COLUMN_NAME, DATA_TYPE, DATA_LENGTH, DATA_PRECISION, DATA_SCALE, NULLABLE, COLUMN_ID, CHARACTER_SET_NAME, CHAR_LENGTH, CHAR_USED, QUALIFIED_COL_NAME from CDB_TAB_COLS where table_name = 't1' order by column_id;
select OWNER, TABLE_NAME, COLUMN_NAME, DATA_TYPE, DATA_LENGTH, DATA_PRECISION, DATA_SCALE, NULLABLE, COLUMN_ID, CHARACTER_SET_NAME, CHAR_LENGTH, CHAR_USED, QUALIFIED_COL_NAME from CDB_TAB_COLS_V$ where table_name = 't1' order by column_id;
select INDEX_OWNER, INDEX_NAME, TABLE_OWNER, TABLE_NAME, COLUMN_NAME, COLUMN_POSITION, COLUMN_LENGTH, CHAR_LENGTH, DESCEND, COLLATED_COLUMN_ID from CDB_IND_COLUMNS where table_name = 't1' and index_name = 'idx_c3' order by column_name;

--disable_query_log
connection default;
--enable_query_log

insert into t1 values ("a", 1, "b", "c", "d");
--error 1235
insert into t1 values (repeat("a", 10000), 2, repeat("b", 10000), repeat("c", 10), repeat("d", 10000));
--error 1235
insert into t1 values (repeat("a", 1000), 2, repeat("b", 10000), repeat("c", 10), repeat("d", 10000));
drop index idx_c3 on t1;
insert into t1 values (repeat("a", 10000), 2, repeat("b", 10000), repeat("c", 10), repeat("d", 10000));

select count(*) from t1;
select char_length(c1), c2, char_length(c3), c4, char_length(c5) from t1;

create table t2 (c1 string primary key, c2 string, c3 string, c4 string);

--error 1167
create table t3 (c1 mediumtext primary key, c2 mediumtext, c3 mediumtext, c4 mediumtext);
create table t3 (c1 mediumtext, c2 mediumtext, c3 mediumtext, c4 mediumtext);

create index idx_c2 on t2(c2);
create index idx_c3 on t2(c3) global;
create unique index idx_c4 on t2(c4);
create index idx_c2_c3 on t2(c2) storing (c3, c4);


--error 1167
create index idx_c2 on t3(c2);
--error 1167
create index idx_c3 on t3(c3) global;
--error 1167
create unique index idx_c4 on t3(c4);
--error 1167
create index idx_c2_c3 on t3(c2) storing (c3, c4);

insert into t3 values ("a", "b", "c", "d");
insert into t3 values ("abc", "bcd", "cdef", "dhij");
insert into t3 values (repeat("a", 100), repeat("b", 100), repeat("c", 100), repeat("d", 100));
insert into t3 values (repeat("a", 500), repeat("b", 500), repeat("c", 500), NULL);
insert into t3 values (repeat("a", 1000), NULL, repeat("c", 100), repeat("d", 1000));
insert into t3 values (repeat("a", 1000), repeat("b", 7000), repeat("c", 7000), repeat("d", 7000));
--error 1062
insert into t2 select * from t3;
update t3 set c1 = repeat("a", 999) where c4 = repeat("d", 1000);
insert into t2 select * from t3;

select count(*) from t2;
select char_length(c1), char_length(c2), char_length(c3), char_length(c4) from t2;
select count(*) from t3;
select char_length(c1), char_length(c2), char_length(c3), char_length(c4) from t3;

--error 1659
create table t4 (c1 int, c2 string, c3 varchar(10), c4 mediumtext) partition by hash(c2) partitions 4;
--error 1659
create table t4 (c1 int, c2 string, c3 varchar(10), c4 mediumtext) partition by hash(c3) partitions 4;
--error 1659
create table t4 (c1 int, c2 string, c3 varchar(10), c4 mediumtext) partition by hash(c4) partitions 4;

--error 1659
create table t4 (c1 int, c2 string, c3 varchar(10), c4 mediumtext) partition by key(c4) partitions 4;
create table t4 (c1 int, c2 string, c3 varchar(10), c4 mediumtext) partition by key(c3) partitions 4;
drop table if exists t4;
create table t4 (c1 int, c2 string, c3 varchar(10), c4 mediumtext) partition by key(c2) partitions 4;

insert into t4 values (1, "a", "b", "c");
insert into t4 values (2, "aaaa", "bbbb", "cccc");
insert into t4 values (3, repeat("a", 100), "bbbbb", NULL);
insert into t4 values (4, NULL, "bbbbbbb", repeat("c", 1000));
insert into t4 values (5, repeat("a", 10000), repeat("b", 10), repeat("c", 10000));
select count(*) from t4;
select c1, char_length(c2), char_length(c3) from t4;

create table t_outrow (c1 int, c2 string, c3 varchar(10)) lob_inrow_threshold = 0;
insert into t_outrow values (7, "outrow", "outrow");

--error 1659
create table t5 (c1 int, c2 string, c3 varchar(10)) lob_inrow_threshold = 4 partition by range(c2) (partition p0 values less than("a"), partition p1 values less than("b"), partition p2 values less than("c"), partition p3 values less than(maxvalue));
create table t5 (c1 int, c2 string, c3 varchar(10)) lob_inrow_threshold = 4 partition by range columns(c2) (partition p0 values less than("a"), partition p1 values less than("b"), partition p2 values less than("c"), partition p3 values less than(maxvalue));
insert into t5 values (1, "a", "a");
insert into t5 values (2, "bb", "bb");
insert into t5 values (3, "ccc", "ccc");
insert into t5 values (4, "dddd", "dddd");
insert into t5 values (5, "eeeee", "eeeee");
insert into t5 values (NULL, NULL, NULL);
--error 1235
insert into t5 select * from t_outrow;
select * from t5;
select * from t5 partition(p0);
select * from t5 partition(p1);
select * from t5 partition(p2);
select * from t5 partition(p3);

--error 1659
create table t6 (c1 int, c2 string, c3 varchar(10)) lob_inrow_threshold = 4 partition by list(c2) (partition p0 values in("a"), partition p1 values in("bb"), partition p2 values in("ccc"), partition p3 values in(default));
create table t6 (c1 int, c2 string, c3 varchar(10)) lob_inrow_threshold = 4 partition by list columns(c2) (partition p0 values in("a"), partition p1 values in("bb"), partition p2 values in("ccc"), partition p3 values in(default));
insert into t6 select * from t5 where c1 <> 5;
--error 1235
insert into t6 select * from t5 where c1 = 5;
insert into t6 values (NULL, NULL, NULL);
select * from t6;
select * from t6 partition(p0);
select * from t6 partition(p1);
select * from t6 partition(p2);
select * from t6 partition(p3);

alter system major freeze;
--source mysql_test/include/wait_daily_merge.inc

select count(*) from t1;
select char_length(c1), c2, char_length(c3), c4 from t1;
select count(*) from t2;
select char_length(c1), char_length(c2), char_length(c3), char_length(c4) from t2;
select count(*) from t3;
select char_length(c1), char_length(c2), char_length(c3), char_length(c4) from t3;
select count(*) from t4;
select c1, char_length(c2), char_length(c3) from t4;

select * from t5;
select * from t5 partition(p0);
select * from t5 partition(p1);
select * from t5 partition(p2);
select * from t5 partition(p3);

select * from t6;
select * from t6 partition(p0);
select * from t6 partition(p1);
select * from t6 partition(p2);
select * from t6 partition(p3);

drop table t1, t2, t3, t4, t5, t6;
drop table t_outrow;

--disable_query_log
set global ob_sql_work_area_percentage=5;
set @@recyclebin = on;
--enable_query_log
