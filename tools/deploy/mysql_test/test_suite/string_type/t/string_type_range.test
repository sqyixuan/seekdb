# owner: houhaojun.hhj
# tags: storage
# description: test the functions of string type

--disable_query_log
set global max_allowed_packet=60000000;
set global ob_sql_work_area_percentage=80;
sleep 1;
set @@recyclebin = off;
set ob_query_timeout=1000000000;
set ob_trx_timeout=1000000000;

--disable_warnings
drop table if exists t1, t2_fk, t2;
drop sequence if exists s1;
--enable_warnings
--enable_query_log

--result_format 4

create sequence s1 cache 100000 order;

create table t1 (c1 string, c2 int, c3 string, c4 string, c5 string, primary key(c1, c2)) row_format = redundant;
insert into t1(c1,c2,c3,c4,c5) select randstr(10, random(0)) c1, s1.nextval c2, randstr(10, random(1)) c3, randstr(10, random(2)) c4, randstr(50, random(3)) c5 from table(generator(100000));

create table t2 (c1 string primary key);
create table t2_fk (c1 string, constraint t1 foreign key (c1) references t2(c1) on update cascade on delete cascade);
insert into t2 values ("key1");
insert into t2_fk values ("key1");
insert into t2 values ("key2");
--error 1452
insert into t2_fk values ("key3");

select * from t2;
select * from t2_fk;

alter system major freeze;
--source mysql_test/include/wait_daily_merge.inc

select /*+parallel(2)*/ * from t1 where c2 > 2000 and c2 < 2020 order by c2;
delete from t1 where c2 in (2011, 2012);
select /*+parallel(2)*/ * from t1 where c2 > 2000 and c2 < 2020 order by c2;

insert into t2_fk values ("key1");
insert into t2_fk values ("key2");
--error 1452
insert into t2_fk values ("key3");

select * from t2;
select * from t2_fk;

drop table t1, t2_fk, t2;
drop sequence s1;

--disable_query_log
set global ob_sql_work_area_percentage=5;
set @@recyclebin = on;
--enable_query_log
