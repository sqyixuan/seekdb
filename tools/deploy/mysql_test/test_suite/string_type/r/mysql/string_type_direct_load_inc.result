insert /*+direct(true, 0, 'inc') enable_parallel_dml parallel(4)*/ into t_dst_inc select c1, c2 from t_src where c1 = "ggg";
ERROR 42000: Specified key was too long
insert /*+direct(true, 0, 'inc') enable_parallel_dml parallel(4)*/ into t_dst_heap select c1, c2 from t_src;
create table t_ld_inc (c1 string primary key, c2 int, c3 string, index idx_c3(c3) local);
create table t_ld_heap (c1 string, c2 string, c3 string);
