create table t5 (c1 int, c2 string, c3 varchar(10)) lob_inrow_threshold = 4 partition by range(c2) (partition p0 values less than("a"), partition p1 values less than("b"), partition p2 values less than("c"), partition p3 values less than(maxvalue));
