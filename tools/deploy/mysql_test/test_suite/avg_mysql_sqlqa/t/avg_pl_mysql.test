--echo   #avg-6   pl语句


--echo   #avg-6-1-1   存储过程
--echo   #存储过程=====>while循环
--error 0,1051
drop table hj_test;
CREATE TABLE hj_test(c1 int,c2 int);
--error 0,1305
drop procedure procedure_1;
DELIMITER /;
CREATE PROCEDURE procedure_1()
BEGIN
DECLARE i INT DEFAULT 1;
WHILE i < (SELECT AVG(300) FROM DUAL LIMIT 1)
DO
INSERT INTO hj_test VALUES (i, (select avg(i+200) from dual));
SET i = i + 1;
END WHILE;
COMMIT;
END;
/
DELIMITER ;/
--error 0,4013
call procedure_1();
#SELECT c1,c2 FROM hj_test ORDER BY c1 ASC;




--echo   #存储过程=====>REPEAT循环
drop procedure procedure_1;
DROP TABLE hj_test;
CREATE TABLE hj_test(c1 int,c2 int);

DELIMITER /;
CREATE PROCEDURE PROCEDURE_1()
BEGIN
DECLARE i INT DEFAULT 1;
REPEAT
INSERT INTO hj_test VALUES (i, (SELECT AVG(i+200) FROM dual));
SET i = i + 1;
UNTIL i > 20 END REPEAT;
END;
/
DELIMITER ;/
call procedure_1();
SELECT * FROM hj_test ORDER BY c1 ASC;



--echo   #存储过程=====>loop循环
DROP TABLE hj_test;
CREATE TABLE hj_test(c1 int,c2 int);
drop procedure procedure_1;

DELIMITER /;
create procedure procedure_1()
begin
    declare i int;
    set i = 1;
    lp : loop
        insert into hj_test values (i,(SELECT AVG(i+200) FROM dual));
        set i = i + 1;
        if i > 201 then
            leave lp;
        end if;
    end loop;
end;
/
DELIMITER ;/
CALL procedure_1();
#SELECT * FROM hj_test ORDER BY c1 ASC;
drop procedure procedure_1;
DROP TABLE hj_test;




--echo   #avg-5-2-2    触发器
--error 0,1051
DROP TABLE hj_test1;
CREATE TABLE hj_test1(c1 int,c2 int);
--error 0,1051
DROP TABLE hj_test2;
CREATE TABLE hj_test2(c1 int,c2 int);
INSERT INTO hj_test1 values((select avg(40000) from dual),(select avg(250000) from dual));

INSERT INTO hj_test1 values((select avg(20000) from dual),(select avg(90000) from dual));
INSERT INTO hj_test1 values((select avg(160000) from dual),(select avg(360000) from dual));
INSERT INTO hj_test1 values((select avg(490000) from dual),(select avg(640000) from dual));
SELECT * FROM hj_test1 ORDER BY c1 ASC;

INSERT INTO hj_test2 values((select avg(5123) from dual),(select avg(25161) from dual));
INSERT INTO hj_test2 values((select avg(5212) from dual),(select avg(546414) from dual));
INSERT INTO hj_test2 values((select avg(154641) from dual),(select avg(121) from dual));
INSERT INTO hj_test2 values((select avg(2313) from dual),(select avg(21314) from dual));
SELECT * FROM hj_test2 ORDER BY c1 ASC;
--error 0,1360
DROP TRIGGER TRIGGER_1;
DELIMITER /;
CREATE TRIGGER TRIGGER_1 AFTER DELETE ON hj_test2
FOR EACH ROW
BEGIN
    DELETE FROM hj_test1 WHERE c1=(select round(avg(160000)) from dual) OR c2=(select round(avg(640000)) from dual);
END
/
DELIMITER ;/
SELECT * FROM hj_test2 ORDER BY c1 ASC;
SELECT * FROM hj_test1 ORDER BY c1 ASC;
DELETE FROM hj_test2 WHERE c2=(select round(avg(25161)) from dual);
SELECT * FROM hj_test2 ORDER BY c1 ASC;
SELECT * FROM hj_test1 ORDER BY c1 ASC;
DROP TRIGGER TRIGGER_1;
DELIMITER /;
CREATE TRIGGER TRIGGER_1 AFTER DELETE ON hj_test2
FOR EACH ROW
BEGIN
    INSERT INTO hj_test1 values((select round(avg(5000)) from dual),(select round(avg(6666)) from dual));
END
/
DELIMITER ;/
SELECT * FROM hj_test2 ORDER BY c1 ASC;
SELECT * FROM hj_test1 ORDER BY c1 ASC;
DELETE FROM hj_test2 WHERE c1=(select round(avg(5212)) from dual);
SELECT * FROM hj_test2 ORDER BY c1 ASC;
SELECT * FROM hj_test1 ORDER BY c1 ASC;
DROP TRIGGER TRIGGER_1;
DELIMITER /;
CREATE TRIGGER TRIGGER_1 AFTER delete ON hj_test2
FOR EACH ROW
BEGIN
    UPDATE hj_test1 SET c1=((select round(avg(3000))+round(avg(2000)) from dual));
END
/
DELIMITER ;/
SELECT * FROM hj_test2 ORDER BY c1 ASC;
SELECT * FROM hj_test1 ORDER BY c1 ASC;
DELETE FROM hj_test2 WHERE c1=(select round(avg(2313)) from dual);
SELECT * FROM hj_test2 ORDER BY c1 ASC;
SELECT * FROM hj_test1 ORDER BY c1 ASC;
DROP TRIGGER TRIGGER_1;
DROP TABLE hj_test1;
DROP TABLE hj_test2;



--echo   #avg-5-2-3    自定义函数
