--echo   #avg-5-1-2    select
--error 0,1051
DROP TABLE hj_test;
--error 0,1051
DROP view view_1;
CREATE TABLE hj_test(c1 int,c2 int,c3 int,c4 int);
CREATE view view_1 as SELECT * from hj_test;
--error 0,1305
drop procedure procedure_1;
delimiter /;
CREATE PROCEDURE procedure_1()
BEGIN
DECLARE i INT DEFAULT 1;
WHILE i < 6000 DO
INSERT INTO view_1 VALUES (AVG(315) + i, AVG(0) + i, AVG(NULL) + i, AVG(120) + AVG(0.120) + i);
SET i = i + 1;
END WHILE;
COMMIT;
END/
delimiter ;/
--error 0,1111
call procedure_1();
drop procedure procedure_1;
delimiter /;
CREATE PROCEDURE procedure_1()
BEGIN
DECLARE i INT DEFAULT 1;
WHILE i < avg(6001) DO
INSERT INTO view_1 values((select avg(315)+i from dual),(select avg(0) from dual)+i,(select avg(null) from dual)+i,(select avg(120)+avg(0.120) from dual)+i);
SET i = i + 1;
END WHILE;
COMMIT;
END /
delimiter ;/
--error 0,1235
call procedure_1();
drop procedure procedure_1;
delimiter /;
CREATE PROCEDURE procedure_1()
BEGIN
DECLARE i INT DEFAULT 1;
WHILE i < 6001 DO
INSERT INTO view_1 values((select avg(315)+i from dual),(select avg(0) from dual)+i,(select avg(null) from dual)+i,(select avg(120)+avg(0.120) from dual)+i);
SET i = i + 1;
END WHILE;
COMMIT;
END/
delimiter ;/
call procedure_1();
