SELECT avg(520,0.0000000000001) FROM DUAL;
--error 0,1064
SELECT avg(0,0) FROM DUAL;
--error 0,1064
SELECT avg(0,0,1,2) FROM DUAL;
--error 0,1064
SELECT avg() FROM DUAL;





