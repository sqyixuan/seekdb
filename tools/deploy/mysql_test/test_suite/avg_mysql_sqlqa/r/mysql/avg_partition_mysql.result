#avg-8-5   组合分区表
DROP TABLE hj_test;
CREATE TABLE hj_test (
c1 NUMBER
)
PARTITION BY RANGE (c1)
(
PARTITION p1 VALUES LESS THAN (100)
SUBPARTITION BY LIST (c1)
(
SUBPARTITION sp1 VALUES ((select avg(200) from dual)),
SUBPARTITION sp2 VALUES ((select avg(400) from dual))
),
PARTITION p2 VALUES LESS THAN (200)
SUBPARTITION BY LIST (c1)
(
SUBPARTITION sp3 VALUES (select avg(900) from dual),
SUBPARTITION sp4 VALUES (select avg(1600) from dual)
));
create table hj_test(id int,h1 bigint) partition by range(id) subpartition by hash(avg(h1))
(
partition p1 values less than(200)(subpartition p11),
partition p2 values less than(400)(subpartition p22),
partition p3 values less than(MAXVALUE)(subpartition p33)
);
drop table test1;
create table test1(c1 bigint);
insert into test1 values(66);
create table hj_test(id int,h1 bigint) partition by range(id) subpartition by hash((select avg(c1) from test1))
(
partition p1 values less than(200)(subpartition p11),
partition p2 values less than(400)(subpartition p22),
partition p3 values less than(MAXVALUE)(subpartition p33)
);
drop table test1;
create table hj_test(id int,h1 bigint) partition by range(id) subpartition by hash(h1)
(
partition p1 values less than(200)(subpartition p11),
partition p2 values less than(400)(subpartition p22),
partition p3 values less than(MAXVALUE)(subpartition p33)
);
