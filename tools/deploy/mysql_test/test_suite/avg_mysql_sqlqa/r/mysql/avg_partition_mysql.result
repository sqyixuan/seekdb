#avg-8-4   range分区表
DROP TABLE hj_test;
CREATE TABLE hj_test(c1 int,c2 int,c3 char(80))
partition BY range((select avg(c1) from dual))(
PARTITION p1 VALUES less than((select avg(400) from dual)),
PARTITION p2 VALUES less than((select avg(1600) from dual)),
PARTITION p3 VALUES less than((select avg(3200) from dual)),
PARTITION p4 VALUES less than((select avg(6400) from dual)));
CREATE TABLE hj_test(c1 int,c2 int,c3 char(80))
partition BY range((select avg(c3) from dual))(
PARTITION p1 VALUES less than((select avg(400) from dual)),
PARTITION p2 VALUES less than((select avg(1600) from dual)),
PARTITION p3 VALUES less than((select avg(3200) from dual)),
PARTITION p4 VALUES less than((select avg(6400) from dual)));
CREATE TABLE hj_test(c1 int,c2 int,c3 char(80))
partition BY range(c1)(
PARTITION p1 VALUES less than((select avg(400) from dual)),
PARTITION p2 VALUES less than((select avg(1600) from dual)),
PARTITION p3 VALUES less than((select avg(3200) from dual)),
PARTITION p4 VALUES less than((select avg(6400) from dual)));
CREATE TABLE hj_test(c1 int,c2 int,c3 char(80))
partition BY range(c3)(
PARTITION p1 VALUES less than((select avg(400) from dual)),
PARTITION p2 VALUES less than((select avg(1600) from dual)),
PARTITION p3 VALUES less than((select avg(3200) from dual)),
PARTITION p4 VALUES less than((select avg(6400) from dual)));
CREATE TABLE hj_test(c1 int,c2 int,c3 char(80))
partition BY range(c1)(
PARTITION p1 VALUES less than(400),
PARTITION p2 VALUES less than(1600),
PARTITION p3 VALUES less than(3200),
PARTITION p4 VALUES less than(6400));
