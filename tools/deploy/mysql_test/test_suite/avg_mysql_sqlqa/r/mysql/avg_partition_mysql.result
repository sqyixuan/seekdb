#avg-8-3   list分区表
DROP TABLE hj_test;
CREATE TABLE hj_test(c1 int,c2 int,c3 char(80))
partition BY list(avg(c1))(
PARTITION p1 values((select avg(400) from dual)),
PARTITION p2 values((select avg(1600) from dual)),
PARTITION p3 values((select avg(3200) from dual)),
PARTITION p4 values((select avg(6400) from dual)));
CREATE TABLE hj_test(c1 int,c2 int,c3 char(80))
partition BY list(avg(c3))(
PARTITION p1 values((select avg(400) from dual)),
PARTITION p2 values((select avg(1600) from dual)),
PARTITION p3 values((select avg(3200) from dual)),
PARTITION p4 values((select avg(6400) from dual)));
CREATE TABLE hj_test(c1 int,c2 int,c3 char(80))
partition BY list(c1)(
PARTITION p1 values((select avg(400) from dual)),
PARTITION p2 values((select avg(1600) from dual)),
PARTITION p3 values((select avg(3200) from dual)),
PARTITION p4 values((select avg(6400) from dual)));
CREATE TABLE hj_test(c1 int,c2 int,c3 char(80))
partition BY list(c1)(
PARTITION p1 values((select avg(400) from dual)),
PARTITION p2 values((select avg(1600) from dual)),
PARTITION p3 values((select avg(3200) from dual)),
PARTITION p4 values((select avg(6400) from dual)));
CREATE TABLE hj_test(c1 int,c2 int,c3 char(80))
partition BY list(c1)(
PARTITION p1 values in(400),
PARTITION p2 values in(1600),
PARTITION p3 values in(3200),
PARTITION p4 values in(6400));
