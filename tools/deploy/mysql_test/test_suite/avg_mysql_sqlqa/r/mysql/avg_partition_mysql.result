#Environmental cleaning
drop user hjw@'%';
create user hjw identified by 'hjw';
grant all on *.* to hjw WITH GRANT OPTION;
#avg-8   分区表
#avg-8-1   hash分区表
DROP TABLE hj_test;
CREATE TABLE hj_test(c1 int,c2 int,c3 char(80))
partition BY hash((select avg(c1) from dual))(
PARTITION p1,
PARTITION p2,
PARTITION p3,
PARTITION p4);
CREATE TABLE hj_test(c1 int,c2 int,c3 char(80))
partition BY hash(avg(c1))(
PARTITION p1,
PARTITION p2,
PARTITION p3,
PARTITION p4);
CREATE TABLE hj_test(c1 int,c2 int,c3 char(80))
partition BY hash(avg(c3))(
PARTITION p1,
PARTITION p2,
PARTITION p3,
PARTITION p4);
CREATE TABLE hj_test(c1 int,c2 int,c3 char(80))
partition BY hash(c1)(
PARTITION p1,
PARTITION p2,
PARTITION p3,
PARTITION p4);
INSERT INTO hj_test VALUES (1,231,'foo');
INSERT INTO hj_test VALUES (4,453,'bar');
INSERT INTO hj_test VALUES (9,54613,'baz');
SELECT * FROM hj_test ORDER BY c1 ASC;
c1	c2	c3
1	231	foo
4	453	bar
9	54613	baz
SELECT * FROM hj_test WHERE avg(c1) = 2;
SELECT * FROM hj_test WHERE c1 = avg(4);
SELECT * FROM hj_test WHERE c1 =(select avg(4) from dual);
c1	c2	c3
4	453	bar
INSERT INTO hj_test VALUES ((select avg(545643) from dual),(select avg(23115513) from dual),'foo');
INSERT INTO hj_test PARTITION(p1) VALUES ((select avg(545643) from dual),(select avg(23115513) from dual),'foo');
INSERT INTO hj_test PARTITION(p2) VALUES ((select avg(545643) from dual),(select avg(23115513) from dual),'foo');
INSERT INTO hj_test PARTITION(p3) VALUES ((select avg(545643) from dual),(select avg(23115513) from dual),'foo');
SELECT * FROM hj_test ORDER BY c1 ASC;
c1	c2	c3
1	231	foo
4	453	bar
9	54613	baz
545643	23115513	foo
