SELECT CAST(avg(0.546) AS TIME) FROM DUAL;
SELECT CAST(avg(2023-01-12) AS TIME) FROM DUAL;
SELECT CAST(avg(0) AS TIME) FROM DUAL;
SELECT CAST(avg(null) AS TIME) FROM DUAL;
