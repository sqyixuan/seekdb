#avg-4-4   json类型
DROP TABLE hj_test;
CREATE TABLE hj_test(c1 bigint,c2 json,c3 json);
INSERT INTO hj_test values(
avg(2332),avg(99.9),
avg(0.5231));
SELECT * FROM hj_test;
INSERT INTO hj_test values(
(SELECT avg(0) FROM DUAL),
(SELECT avg('{"key1": "value1", "key2": "value2"}') FROM DUAL),
(SELECT avg('[1, 2,') FROM DUAL));
INSERT INTO hj_test values(
(SELECT avg(0) FROM DUAL),
(SELECT avg(JSON_OBJECT('key1', 1, 'key2', 'abc')) FROM DUAL),
(SELECT avg(JSON_MERGE('["a", 1]', '{"key": "value"}')) FROM DUAL));
SELECT avg('{"key1": "value1", "key2": "value2"}') FROM DUAL;
