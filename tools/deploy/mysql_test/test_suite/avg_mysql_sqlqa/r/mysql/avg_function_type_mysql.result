#avg-3-3   字符函数
SELECT avg(ASCII('国粹精华')) FROM DUAL;
SELECT avg(LENGTH('国粹精华')) FROM DUAL;
SELECT avg(LOWER('国粹精华')) FROM DUAL;
SELECT avg(UPPER('国粹精华')) FROM DUAL;
SELECT avg(CHAR_LENGTH("国粹精华")) FROM DUAL;
SELECT avg(CHARACTER_LENGTH("国粹精华")) FROM DUAL;
SELECT avg(CONCAT("国粹精华","天之骄子")) FROM DUAL;
SELECT avg(FORMAT("国粹精华",2)) FROM DUAL;
SELECT avg(LOCATE("国粹精华",'谁威威韩国的苏菲我')) FROM DUAL;
SELECT avg(LCASE("国粹精华")) FROM DUAL;
SELECT avg(LEFT('谁威威韩国的苏菲我',4)) FROM DUAL;
SELECT avg(REVERSE('谁威威韩国的苏菲我')) FROM DUAL;
#avg-3-4   时间函数
SELECT avg(ADDDATE('2023-02-09',-1)) FROM DUAL;
SELECT avg(ADDTIME('2030-02-01')) FROM DUAL;
SELECT avg(ADDTIME('2030-11-11 11:11:11', 5)) FROM DUAL;
SELECT avg(CURDATE()) FROM DUAL;
SELECT avg(DATE(2023)) FROM DUAL;
SELECT avg(DATE('2023-02-09')) FROM DUAL;
SELECT avg(DATEDIFF('2001-01-01','2001-02-02')) FROM DUAL;
#avg-3-5   转换函数=====>字符串
SELECT CAST(avg(5454113) AS char(20)) FROM DUAL;
SELECT CAST(avg(0.546) AS char(20)) FROM DUAL;
SELECT CAST(avg(0) AS char(20)) FROM DUAL;
SELECT CAST(avg(null) AS char(20)) FROM DUAL;
