SELECT CAST(avg(0.546) AS SIGNED int) FROM DUAL;
SELECT CAST(avg(2023-01-12) AS SIGNED int) FROM DUAL;
SELECT CAST(avg(12s432) AS SIGNED int) FROM DUAL;
SELECT CAST(avg(0) AS SIGNED int) FROM DUAL;
SELECT CAST(avg(null) AS SIGNED int) FROM DUAL;
#avg-3-5   转换函数=====>时间日期
SELECT CAST(avg(5454113) AS DATE) FROM DUAL;
SELECT CAST(avg(0.546) AS DATE) FROM DUAL;
SELECT CAST(avg(2023-01-12) AS DATE) FROM DUAL;
