#avg-5-2-3    自定义函数
DROP FUNCTION abc;
CREATE FUNCTION abc()
RETURNS FLOAT
BEGIN
RETURN (SELECT AVG(300) FROM DUAL);
END;
/
select abc() from dual;
abc()
300
