#Environmental cleaning
drop user hjw@'%';
create user hjw identified by 'hjw';
grant all on *.* to hjw WITH GRANT OPTION;
#avg-6   pl语句
#avg-6-1-1   存储过程
#存储过程=====>while循环
drop table hj_test;
CREATE TABLE hj_test(c1 int,c2 int);
drop procedure procedure_1;
CREATE PROCEDURE procedure_1()
BEGIN
DECLARE i INT DEFAULT 1;
WHILE i < (SELECT AVG(300) FROM DUAL LIMIT 1)
DO
INSERT INTO hj_test VALUES (i, (select avg(i+200) from dual));
SET i = i + 1;
END WHILE;
COMMIT;
END;
/
call procedure_1();
#存储过程=====>REPEAT循环
drop procedure procedure_1;
DROP TABLE hj_test;
CREATE TABLE hj_test(c1 int,c2 int);
CREATE PROCEDURE PROCEDURE_1()
BEGIN
DECLARE i INT DEFAULT 1;
REPEAT
INSERT INTO hj_test VALUES (i, (SELECT AVG(i+200) FROM dual));
SET i = i + 1;
UNTIL i > 20 END REPEAT;
END;
/
call procedure_1();
SELECT * FROM hj_test ORDER BY c1 ASC;
c1	c2
1	201
2	202
3	203
4	204
5	205
6	206
7	207
8	208
9	209
10	210
11	211
12	212
13	213
14	214
15	215
16	216
17	217
18	218
19	219
20	220
#存储过程=====>loop循环
DROP TABLE hj_test;
CREATE TABLE hj_test(c1 int,c2 int);
drop procedure procedure_1;
create procedure procedure_1()
begin
declare i int;
set i = 1;
lp : loop
insert into hj_test values (i,(SELECT AVG(i+200) FROM dual));
set i = i + 1;
if i > 201 then
leave lp;
end if;
end loop;
end;
/
CALL procedure_1();
drop procedure procedure_1;
DROP TABLE hj_test;
