#avg-5-1-2    select
DROP TABLE hj_test;
CREATE TABLE hj_test(c1 int,c2 int,c3 int,c4 int);
drop procedure procedure_1;
CREATE PROCEDURE procedure_1()
BEGIN
DECLARE i INT DEFAULT 1;
WHILE i < 6000 DO
INSERT INTO hj_test VALUES (AVG(315) + i, AVG(0) + i, AVG(NULL) + i, AVG(120) + AVG(0.120) + i);
SET i = i + 1;
END WHILE;
COMMIT;
END/
call procedure_1();
drop procedure procedure_1;
CREATE PROCEDURE procedure_1()
BEGIN
DECLARE i INT DEFAULT 1;
WHILE i < avg(6001) DO
INSERT INTO hj_test values((select avg(315)+i from dual),(select avg(0) from dual)+i,(select avg(null) from dual)+i,(select avg(120)+avg(0.120) from dual)+i);
SET i = i + 1;
END WHILE;
COMMIT;
END/
Warnings:
Warning	5002	Resolve error
call procedure_1();
drop PROCEDURE procedure_1;
CREATE PROCEDURE procedure_1()
BEGIN
DECLARE i INT DEFAULT 1;
WHILE i < 6001 DO
INSERT INTO hj_test values((select avg(315)+i from dual),(select avg(0) from dual)+i,(select avg(null) from dual)+i,(select avg(120)+avg(0.120) from dual)+i);
SET i = i + 1;
END WHILE;
COMMIT;
END/
call procedure_1();
