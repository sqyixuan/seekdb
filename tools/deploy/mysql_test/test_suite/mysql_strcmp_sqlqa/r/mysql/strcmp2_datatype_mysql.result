######################## 标签：strcmp-2 字符集部分  ########################
######## strcmp-2-2  测试场景
#### 函数参数是相同字符集/排序规则
select strcmp(_gbk 'mysql' COLLATE gbk_chinese_ci,_gbk 'oceanbase' COLLATE gbk_chinese_ci) as gbk_res from dual;
+---------+
| gbk_res |
+---------+
|      -1 |
+---------+
select strcmp(_binary 'a',_binary 'b') as binary_res from dual;
+------------+
| binary_res |
+------------+
|         -1 |
+------------+
select strcmp(_latin1 'A' COLLATE latin1_swedish_ci,_latin1 'a' COLLATE latin1_swedish_ci) as latin1_res from dual;
+------------+
| latin1_res |
+------------+
|          0 |
+------------+
select strcmp(_utf16 'ab' COLLATE utf16_general_ci,_utf16 'cd' COLLATE utf16_general_ci) as utf16_res from dual;
+-----------+
| utf16_res |
+-----------+
|        -1 |
+-----------+
select strcmp(_utf8mb4 'q1' COLLATE utf8mb4_general_ci,_utf8mb4 'q2' COLLATE utf8mb4_general_ci) as utf8mb4_res from dual;
+-------------+
| utf8mb4_res |
+-------------+
|          -1 |
+-------------+
select strcmp(_gb18030 'ok' COLLATE gb18030_chinese_ci,_gb18030 'ok a' COLLATE gb18030_chinese_ci) as gb18030_res from dual;
+-------------+
| gb18030_res |
+-------------+
|          -1 |
+-------------+
#### 函数参数是不同字符集/排序规则
select strcmp(_gbk 'mysql' COLLATE gbk_chinese_ci,_binary 'a') as gbk_res from dual;
+---------+
| gbk_res |
+---------+
|       1 |
+---------+
select strcmp(_gbk 'mysql' COLLATE gbk_chinese_ci,_utf16 'ab' COLLATE utf16_general_ci) as gbk_res from dual;
+---------+
| gbk_res |
+---------+
|      -1 |
+---------+
select strcmp(_gbk 'mysql' COLLATE gbk_chinese_ci,_utf8mb4 'q1' COLLATE utf8mb4_general_ci) as gbk_res from dual;
+---------+
| gbk_res |
+---------+
|      -1 |
+---------+
select strcmp(_gbk 'mysql' COLLATE gbk_chinese_ci,_gb18030 'ok' COLLATE gb18030_chinese_ci) as gbk_res from dual;
ERROR HY000: Illegal mix of collations (gbk_chinese_ci,EXPLICIT), (gb18030_chinese_ci,EXPLICIT)
select strcmp(_gbk 'mysql' COLLATE gbk_chinese_ci,_latin1 'A' COLLATE latin1_swedish_ci) as gbk_res from dual;
+---------+
| gbk_res |
+---------+
|       1 |
+---------+
#### 函数参数是相同字符集，不同排序规则
select strcmp(_gbk 'mysql' COLLATE gbk_chinese_ci,_gbk 'mysql' COLLATE gbk_bin) as gbk_res from dual;
ERROR HY000: Illegal mix of collations (gbk_chinese_ci,EXPLICIT), (gbk_bin,EXPLICIT)
select strcmp(_latin1 'A' COLLATE latin1_swedish_ci,_latin1 'A' COLLATE latin1_bin) as gbk_res from dual;
ERROR HY000: Illegal mix of collations (latin1_swedish_ci,EXPLICIT), (latin1_bin,EXPLICIT)
select strcmp(_utf16 'ab' COLLATE utf16_general_ci,_utf16 'ab' COLLATE utf16_bin) as gbk_res from dual;
ERROR HY000: Illegal mix of collations (utf16_general_ci,EXPLICIT), (utf16_bin,EXPLICIT)
select strcmp(_utf16 'ab' COLLATE utf16_general_ci,_utf16 'ab' COLLATE utf16_unicode_ci) as gbk_res from dual;
ERROR HY000: Illegal mix of collations (utf16_general_ci,EXPLICIT), (utf16_unicode_ci,EXPLICIT)
select strcmp(_utf16 'ab' COLLATE utf16_general_ci,_utf16 'ab' COLLATE utf16_unicode_ci) as gbk_res from dual;
ERROR HY000: Illegal mix of collations (utf16_general_ci,EXPLICIT), (utf16_unicode_ci,EXPLICIT)
select strcmp( _utf8mb4 'x' COLLATE utf8mb4_unicode_ci,_utf8mb4 'x' COLLATE utf8mb4_general_ci) as gbk_res from dual;
ERROR HY000: Illegal mix of collations (utf8mb4_unicode_ci,EXPLICIT), (utf8mb4_general_ci,EXPLICIT)
select strcmp( _utf8mb4 'x' COLLATE utf8mb4_unicode_ci,_utf8mb4 'x' COLLATE utf8mb4_bin) as gbk_res from dual;
ERROR HY000: Illegal mix of collations (utf8mb4_unicode_ci,EXPLICIT), (utf8mb4_bin,EXPLICIT)
select strcmp(_gb18030 'ok' COLLATE gb18030_chinese_ci,_gb18030 'ok' COLLATE gb18030_bin) as gbk_res from dual;
ERROR HY000: Illegal mix of collations (gb18030_chinese_ci,EXPLICIT), (gb18030_bin,EXPLICIT)
set _enable_old_charset_aggregation = false;
# Clean up users
drop user whh@'%';
