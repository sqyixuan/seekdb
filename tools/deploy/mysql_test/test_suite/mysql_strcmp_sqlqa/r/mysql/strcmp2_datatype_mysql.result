###### 字符串类型
DROP TABLE str_table1;
CREATE TABLE str_table1( 
  c1 CHAR(10), 
  c2 VARCHAR(100), 
  c3 BINARY(100),
  c4 VARBINARY(100), 
  c5 ENUM('星期一', '星期二', '星期三', '星期四', '星期五', '星期六'), 
  c6 SET('a', 'b', 'c', 'd', 'e')
)default character set = 'utf8mb4';
insert into str_table1 values(NULL,NULL,NULL,NULL,NULL,NULL);
insert into str_table1 values('char-类型','VARCHAR-类型','BINARY-类型','VARBINARY-类型','星期一','a,b,c');
