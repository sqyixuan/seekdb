### 标签：strcmp-3-2 insert
INSERT INTO strcmp_table3 VALUES(4,strcmp('wang','Wan'),strcmp(2022,2023),strcmp(NULL,0));
INSERT INTO strcmp_table3 SELECT id,name,age,strcmp(sal,6000) FROM strcmp_table1 WHERE strcmp(name,'一诺')=0 ORDER BY 1;
SELECT * FROM  strcmp_table3 ORDER BY 1;
+------+--------+------+------+
| id   | c1     | c2   | c3   |
+------+--------+------+------+
|    1 | 张     | 1    | NULL |
|    1 | 程程   | 1    | 1    |
|    2 | 陈     | 陈   | NULL |
|    3 | 王     | 望   | NULL |
|    4 | 1      | -1   | NULL |
|    4 | 一诺   | 31   | -1   |
+------+--------+------+------+
### 标签：strcmp-3-3 update
UPDATE strcmp_table3 SET c2 = strcmp(c2,'a'),c3 = strcmp(c1,c2)  where strcmp(concat(c1,c2),'陈陈') = 0;
SELECT * FROM strcmp_table3 ORDER BY 1;
+------+--------+------+------+
| id   | c1     | c2   | c3   |
+------+--------+------+------+
|    1 | 张     | 1    | NULL |
|    1 | 程程   | 1    | 1    |
|    2 | 陈     | 1    | 1    |
|    3 | 王     | 望   | NULL |
|    4 | 1      | -1   | NULL |
|    4 | 一诺   | 31   | -1   |
+------+--------+------+------+
### 标签：strcmp-3-4 delete
DELETE FROM strcmp_table3 WHERE c3 = strcmp(1,2);
SELECT * FROM  strcmp_table3 ORDER BY 1;
+------+--------+------+------+
| id   | c1     | c2   | c3   |
+------+--------+------+------+
|    1 | 张     | 1    | NULL |
|    1 | 程程   | 1    | 1    |
|    2 | 陈     | 1    | 1    |
|    3 | 王     | 望   | NULL |
|    4 | 1      | -1   | NULL |
+------+--------+------+------+
### 标签：strcmp-3-5 replace   
replace into strcmp_table1 values(5,'replace',28,'杭州',103,9000);
