purge recyclebin;
result_format: 4
drop user whh@'%';
create user whh identified by 'whh';
grant all on *.* to whh WITH GRANT OPTION;


SET character_set_client = 'utf8mb4';
SET character_set_connection = 'utf8mb4';
SET character_set_results = 'utf8mb4';
--------------------------------------------------------------------------
######################## 标签：strcmp-2 SQL操作  ########################
######## strcmp-3-1  select
DROP TABLE strcmp_table1;
CREATE TABLE strcmp_table1(
  id int, 
  name varchar(100), 
  age int,
  city varchar(100),
  depno int not null,
  sal int, 
  PRIMARY KEY (id,age))
PARTITION BY RANGE (age) ( 
  PARTITION p0 VALUES LESS THAN (20), 
  PARTITION p1 VALUES LESS THAN (30),  
  PARTITION p2 VALUES LESS THAN MAXVALUE);
INSERT INTO strcmp_table1 VALUES(1,'程程',20,'杭州',101,8000);
INSERT INTO strcmp_table1 VALUES(2,'依依',25,'广州',101,7000);
INSERT INTO strcmp_table1 VALUES(3,'阿布',30,'苏州',102,6000);
INSERT INTO strcmp_table1 VALUES(4,'一诺',31,'苏州',103,5000);
DROP TABLE strcmp_table2;
CREATE TABLE strcmp_table2(
  id int,
  depno int,
  depname varchar(200),
  INDEX index_name (depno))
PARTITION BY LIST(depno)( 
  PARTITION p0 VALUES IN (101,102),
  PARTITION p1 VALUES IN (103,104),
  PARTITION p2 VALUES IN (105,106));
INSERT INTO strcmp_table2 VALUES(1,101,'蚂蚁');
INSERT INTO strcmp_table2 VALUES(2,102,'淘宝');
INSERT INTO strcmp_table2 VALUES(3,103,'支付');
DROP TABLE strcmp_table3;
CREATE TABLE strcmp_table3(
  id int,
  c1 varchar(200),
  c2 varchar(200),
  c3 varchar(200))
PARTITION BY HASH(id) PARTITIONS 3;
INSERT INTO strcmp_table3 VALUES(1,'张','章',NULL);
INSERT INTO strcmp_table3 VALUES(2,'陈','陈',NULL);
INSERT INTO strcmp_table3 VALUES(3,'王','望',NULL);
DROP VIEW strcmp_view;
CREATE VIEW strcmp_view as SELECT id,name,age FROM strcmp_table1;
###### select 普通查询
SELECT strcmp(name,'依依') FROM strcmp_table1 ORDER BY 1;
+-----------------------+
| strcmp(name,'依依')   |
+-----------------------+
|                    -1 |
|                     0 |
|                     1 |
|                     1 |
+-----------------------+
SELECT strcmp(depno,102) FROM strcmp_table2 ORDER BY 1;
+-------------------+
| strcmp(depno,102) |
+-------------------+
|                -1 |
|                 0 |
|                 1 |
+-------------------+
SELECT strcmp(c1,c2) FROM strcmp_table3 ORDER BY 1;
+---------------+
| strcmp(c1,c2) |
+---------------+
|            -1 |
|             0 |
|             1 |
+---------------+
SELECT strcmp(age,20+3) FROM strcmp_view ORDER BY 1;
+------------------+
| strcmp(age,20+3) |
+------------------+
|               -1 |
|                1 |
|                1 |
|                1 |
+------------------+
###### where 子句
SELECT * FROM strcmp_table1 WHERE strcmp(name,'依依') = 0 ORDER BY 1;
+----+--------+-----+--------+-------+------+
| id | name   | age | city   | depno | sal  |
+----+--------+-----+--------+-------+------+
|  2 | 依依   |  25 | 广州   |   101 | 7000 |
+----+--------+-----+--------+-------+------+
SELECT * FROM strcmp_table2 WHERE strcmp(depno,102) < 0 ORDER BY 1;
+------+-------+---------+
| id   | depno | depname |
+------+-------+---------+
|    1 |   101 | 蚂蚁    |
+------+-------+---------+
SELECT * FROM strcmp_table3 WHERE strcmp(c1,c2) > 0 ORDER BY 1;
+------+------+------+------+
| id   | c1   | c2   | c3   |
+------+------+------+------+
|    3 | 王   | 望   | NULL |
+------+------+------+------+
SELECT * FROM strcmp_view WHERE strcmp(age,20+3) <= strcmp(age,age-3) ORDER BY 1;
+----+--------+-----+
| id | name   | age |
+----+--------+-----+
|  1 | 程程   |  20 |
|  2 | 依依   |  25 |
|  3 | 阿布   |  30 |
|  4 | 一诺   |  31 |
+----+--------+-----+
##order by 子句
SELECT * FROM strcmp_table1 WHERE strcmp(name,'依依') = 0 ORDER BY strcmp(name,name);
+----+--------+-----+--------+-------+------+
| id | name   | age | city   | depno | sal  |
+----+--------+-----+--------+-------+------+
|  2 | 依依   |  25 | 广州   |   101 | 7000 |
+----+--------+-----+--------+-------+------+
SELECT * FROM strcmp_table2 WHERE strcmp(depno,102) < 0 ORDER BY strcmp(depno,102);
+------+-------+---------+
| id   | depno | depname |
+------+-------+---------+
|    1 |   101 | 蚂蚁    |
+------+-------+---------+
SELECT * FROM strcmp_table3 WHERE strcmp(c1,c2) > 0 ORDER BY strcmp(c1,c2);
+------+------+------+------+
| id   | c1   | c2   | c3   |
+------+------+------+------+
|    3 | 王   | 望   | NULL |
+------+------+------+------+
SELECT * FROM strcmp_view WHERE strcmp(age,20+5) = 0 ORDER BY strcmp(age,25);
+----+--------+-----+
| id | name   | age |
+----+--------+-----+
|  2 | 依依   |  25 |
+----+--------+-----+
SELECT * FROM strcmp_view ORDER BY strcmp(age,NULL);
+----+--------+-----+
| id | name   | age |
+----+--------+-----+
|  1 | 程程   |  20 |
|  2 | 依依   |  25 |
|  3 | 阿布   |  30 |
|  4 | 一诺   |  31 |
+----+--------+-----+
SELECT * FROM strcmp_view ORDER BY strcmp(NULL,NULL);
+----+--------+-----+
| id | name   | age |
+----+--------+-----+
|  1 | 程程   |  20 |
|  2 | 依依   |  25 |
|  3 | 阿布   |  30 |
|  4 | 一诺   |  31 |
+----+--------+-----+
##group by having 子句
SELECT * FROM strcmp_table1 WHERE strcmp(name,'依依') = 0 GROUP BY strcmp(name,'') ORDER BY 1;
+----+--------+-----+--------+-------+------+
| id | name   | age | city   | depno | sal  |
+----+--------+-----+--------+-------+------+
|  2 | 依依   |  25 | 广州   |   101 | 7000 |
+----+--------+-----+--------+-------+------+
SELECT * FROM strcmp_table2 WHERE strcmp(depno,102) < 0 GROUP BY strcmp(depname,'') HAVING strcmp(depno,102) < 0 ORDER BY 1;
+------+-------+---------+
| id   | depno | depname |
+------+-------+---------+
|    1 |   101 | 蚂蚁    |
+------+-------+---------+
SELECT * FROM strcmp_table3 WHERE strcmp(c1,c2) > 0 GROUP BY strcmp(c1,'') ORDER BY 1;
+------+------+------+------+
| id   | c1   | c2   | c3   |
+------+------+------+------+
|    3 | 王   | 望   | NULL |
+------+------+------+------+
SELECT * FROM strcmp_view WHERE strcmp(age,20+3) <= strcmp(age,name) GROUP BY strcmp(age,20) ORDER BY 1;
+----+--------+-----+
| id | name   | age |
+----+--------+-----+
|  1 | 程程   |  20 |
+----+--------+-----+
#DISTINCT
SELECT DISTINCT strcmp(city,'苏州') FROM strcmp_table1 WHERE strcmp(name,'依依') = 0 ORDER BY 1;
+-----------------------+
| strcmp(city,'苏州')   |
+-----------------------+
|                    -1 |
+-----------------------+
SELECT DISTINCT strcmp(depno,103) FROM strcmp_table2 WHERE strcmp(depno,102) < 0 ORDER BY 1;
+-------------------+
| strcmp(depno,103) |
+-------------------+
|                -1 |
+-------------------+
SELECT DISTINCT strcmp(c1,c2) FROM strcmp_table3 WHERE strcmp(c1,c2) > 0 ORDER BY 1;
+---------------+
| strcmp(c1,c2) |
+---------------+
|             1 |
+---------------+
SELECT DISTINCT strcmp(age,25) FROM strcmp_view ORDER BY 1;
+----------------+
| strcmp(age,25) |
+----------------+
|             -1 |
|              0 |
|              1 |
+----------------+
#CASE WHEN
SELECT id,name,sal,strcmp(CASE WHEN sal < 6000 THEN NULL ELSE sal END,sal) strcmp_sal FROM strcmp_table1 ORDER BY 1;
+----+--------+------+------------+
| id | name   | sal  | strcmp_sal |
+----+--------+------+------------+
|  1 | 程程   | 8000 |          0 |
|  2 | 依依   | 7000 |          0 |
|  3 | 阿布   | 6000 |          0 |
|  4 | 一诺   | 5000 |       NULL |
+----+--------+------+------------+
SELECT id,depno,depname,CASE strcmp(depno,102) WHEN 1 THEN 'depno>102' WHEN 0 THEN 'depno=102' ELSE 'depno<102' END strcmp_depo FROM strcmp_table2 ORDER BY 1;
+------+-------+---------+-------------+
| id   | depno | depname | strcmp_depo |
+------+-------+---------+-------------+
|    1 |   101 | 蚂蚁    | depno<102   |
|    2 |   102 | 淘宝    | depno=102   |
|    3 |   103 | 支付    | depno>102   |
+------+-------+---------+-------------+
SELECT id,c1,c2,CASE WHEN strcmp(c1,c2)=0 THEN 'c1=c2' WHEN strcmp(c1,c2)>0 THEN 'c1>c2' ELSE 'c1<c2' END FROM strcmp_table3 ORDER BY 1 ;
+------+------+------+-------------------------------------------------------------------------------------------+
| id   | c1   | c2   | CASE WHEN strcmp(c1,c2)=0 THEN 'c1=c2' WHEN strcmp(c1,c2)>0 THEN 'c1>c2' ELSE 'c1<c2' END |
+------+------+------+-------------------------------------------------------------------------------------------+
|    1 | 张   | 章   | c1<c2                                                                                     |
|    2 | 陈   | 陈   | c1=c2                                                                                     |
|    3 | 王   | 望   | c1>c2                                                                                     |
+------+------+------+-------------------------------------------------------------------------------------------+
##连接查询
SELECT e.*,p.*,strcmp(e.depno,p.depno) FROM strcmp_table1 e, strcmp_table2 p WHERE strcmp(e.depno,p.depno) = 0 ORDER BY 1;
+----+--------+-----+--------+-------+------+------+-------+---------+-------------------------+
| id | name   | age | city   | depno | sal  | id   | depno | depname | strcmp(e.depno,p.depno) |
+----+--------+-----+--------+-------+------+------+-------+---------+-------------------------+
|  1 | 程程   |  20 | 杭州   |   101 | 8000 |    1 |   101 | 蚂蚁    |                       0 |
|  2 | 依依   |  25 | 广州   |   101 | 7000 |    1 |   101 | 蚂蚁    |                       0 |
|  3 | 阿布   |  30 | 苏州   |   102 | 6000 |    2 |   102 | 淘宝    |                       0 |
|  4 | 一诺   |  31 | 苏州   |   103 | 5000 |    3 |   103 | 支付    |                       0 |
+----+--------+-----+--------+-------+------+------+-------+---------+-------------------------+
SELECT e.*,p.*,strcmp(e.id,p.depno)  FROM strcmp_table1 e LEFT JOIN strcmp_table2 p ON strcmp(e.depno,p.depno) = 0 ORDER BY 1;
+----+--------+-----+--------+-------+------+------+-------+---------+----------------------+
| id | name   | age | city   | depno | sal  | id   | depno | depname | strcmp(e.id,p.depno) |
+----+--------+-----+--------+-------+------+------+-------+---------+----------------------+
|  1 | 程程   |  20 | 杭州   |   101 | 8000 |    1 |   101 | 蚂蚁    |                   -1 |
|  2 | 依依   |  25 | 广州   |   101 | 7000 |    1 |   101 | 蚂蚁    |                    1 |
|  3 | 阿布   |  30 | 苏州   |   102 | 6000 |    2 |   102 | 淘宝    |                    1 |
|  4 | 一诺   |  31 | 苏州   |   103 | 5000 |    3 |   103 | 支付    |                    1 |
+----+--------+-----+--------+-------+------+------+-------+---------+----------------------+
SELECT e.*,p.*,strcmp(e.name,p.depname)  FROM strcmp_table1 e RIGHT JOIN strcmp_table2 p ON strcmp(e.depno,p.depno) = 0 ORDER BY 1;
+----+--------+-----+--------+-------+------+------+-------+---------+--------------------------+
| id | name   | age | city   | depno | sal  | id   | depno | depname | strcmp(e.name,p.depname) |
+----+--------+-----+--------+-------+------+------+-------+---------+--------------------------+
|  1 | 程程   |  20 | 杭州   |   101 | 8000 |    1 |   101 | 蚂蚁    |                       -1 |
|  2 | 依依   |  25 | 广州   |   101 | 7000 |    1 |   101 | 蚂蚁    |                       -1 |
|  3 | 阿布   |  30 | 苏州   |   102 | 6000 |    2 |   102 | 淘宝    |                        1 |
|  4 | 一诺   |  31 | 苏州   |   103 | 5000 |    3 |   103 | 支付    |                       -1 |
+----+--------+-----+--------+-------+------+------+-------+---------+--------------------------+
SELECT e.*,p.*,strcmp(e.depno,NULL)  FROM strcmp_table1 e INNER JOIN strcmp_table2 p ON strcmp(e.depno,p.depno) = 0 ORDER BY 1;
+----+--------+-----+--------+-------+------+------+-------+---------+----------------------+
| id | name   | age | city   | depno | sal  | id   | depno | depname | strcmp(e.depno,NULL) |
+----+--------+-----+--------+-------+------+------+-------+---------+----------------------+
|  1 | 程程   |  20 | 杭州   |   101 | 8000 |    1 |   101 | 蚂蚁    |                 NULL |
|  2 | 依依   |  25 | 广州   |   101 | 7000 |    1 |   101 | 蚂蚁    |                 NULL |
|  3 | 阿布   |  30 | 苏州   |   102 | 6000 |    2 |   102 | 淘宝    |                 NULL |
|  4 | 一诺   |  31 | 苏州   |   103 | 5000 |    3 |   103 | 支付    |                 NULL |
+----+--------+-----+--------+-------+------+------+-------+---------+----------------------+
##select嵌套
#SELECT
SELECT id,name,age,strcmp(sal,5000) FROM (SELECT * FROM strcmp_table1 WHERE strcmp(age,30) = -1 ORDER BY 1) t1 ORDER BY 1;
+----+--------+-----+------------------+
| id | name   | age | strcmp(sal,5000) |
+----+--------+-----+------------------+
|  1 | 程程   |  20 |                1 |
|  2 | 依依   |  25 |                1 |
+----+--------+-----+------------------+
SELECT id,depno,depname,strcmp(depno,102) FROM strcmp_table2 where depno = (SELECT depno FROM strcmp_table1 WHERE strcmp(depno,102) <= 0 limit 1) ORDER BY 1;
+------+-------+---------+-------------------+
| id   | depno | depname | strcmp(depno,102) |
+------+-------+---------+-------------------+
|    1 |   101 | 蚂蚁    |                -1 |
+------+-------+---------+-------------------+
#EXISTS AND NOT EXISTS
SELECT id,name,age,strcmp(sal,5000) FROM strcmp_table1 WHERE EXISTS (SELECT * FROM strcmp_table2 where strcmp(depno,102)) ORDER BY 1;
+----+--------+-----+------------------+
| id | name   | age | strcmp(sal,5000) |
+----+--------+-----+------------------+
|  1 | 程程   |  20 |                1 |
|  2 | 依依   |  25 |                1 |
|  3 | 阿布   |  30 |                1 |
|  4 | 一诺   |  31 |                0 |
+----+--------+-----+------------------+
SELECT id,depno,depname,strcmp(depno,102) FROM strcmp_table2 WHERE NOT EXISTS (SELECT * FROM strcmp_table3 WHERE strcmp(c1,'wang') = 0) ORDER BY 1;
+------+-------+---------+-------------------+
| id   | depno | depname | strcmp(depno,102) |
+------+-------+---------+-------------------+
|    1 |   101 | 蚂蚁    |                -1 |
|    2 |   102 | 淘宝    |                 0 |
|    3 |   103 | 支付    |                 1 |
+------+-------+---------+-------------------+
#ANY
SELECT id,name,age,strcmp(sal,5000) FROM strcmp_table1 WHERE strcmp(sal,5000) = ANY (SELECT strcmp(age,25) FROM strcmp_table1) ORDER BY 1;
+----+--------+-----+------------------+
| id | name   | age | strcmp(sal,5000) |
+----+--------+-----+------------------+
|  1 | 程程   |  20 |                1 |
|  2 | 依依   |  25 |                1 |
|  3 | 阿布   |  30 |                1 |
|  4 | 一诺   |  31 |                0 |
+----+--------+-----+------------------+
SELECT id,depno,depname,strcmp(depno,102) FROM strcmp_table2 WHERE strcmp(depno,102) <= ANY (SELECT strcmp(depno,25) FROM strcmp_table1) ORDER BY 1;
+------+-------+---------+-------------------+
| id   | depno | depname | strcmp(depno,102) |
+------+-------+---------+-------------------+
|    1 |   101 | 蚂蚁    |                -1 |
+------+-------+---------+-------------------+
SELECT id,c1,c2,strcmp(c1,c2) FROM strcmp_table3 WHERE strcmp(c1,c2) >= ANY (SELECT strcmp(c1,'a') FROM strcmp_table3) ORDER BY 1;
+------+------+------+---------------+
| id   | c1   | c2   | strcmp(c1,c2) |
+------+------+------+---------------+
|    3 | 王   | 望   |             1 |
+------+------+------+---------------+
#ALL 
SELECT id,name,age,strcmp(sal,5000) FROM strcmp_table1 WHERE strcmp(sal,5000) = ALL (SELECT strcmp(age,25) FROM strcmp_table1) ORDER BY 1;
+----+------+-----+------------------+
| id | name | age | strcmp(sal,5000) |
+----+------+-----+------------------+
+----+------+-----+------------------+
SELECT id,depno,depname,strcmp(depno,102) FROM strcmp_table2 WHERE strcmp(depno,102) <= ALL (SELECT strcmp(depno,25) FROM strcmp_table1) ORDER BY 1;
+------+-------+---------+-------------------+
| id   | depno | depname | strcmp(depno,102) |
+------+-------+---------+-------------------+
|    1 |   101 | 蚂蚁    |                -1 |
+------+-------+---------+-------------------+
SELECT id,c1,c2,strcmp(c1,c2) FROM strcmp_table3 WHERE strcmp(c1,c2) >= ALL (SELECT strcmp(c1,'a') FROM strcmp_table3) ORDER BY 1;
+------+------+------+---------------+
| id   | c1   | c2   | strcmp(c1,c2) |
+------+------+------+---------------+
|    3 | 王   | 望   |             1 |
+------+------+------+---------------+
#CREATE AS
DROP TABLE strcmp_table4;
CREATE TABLE strcmp_table4 AS SELECT id,name,age,strcmp(sal,6000) FROM strcmp_table1;
SELECT * FROM strcmp_table4;
+----+--------+-----+------------------+
| id | name   | age | strcmp(sal,6000) |
+----+--------+-----+------------------+
|  1 | 程程   |  20 |                1 |
|  2 | 依依   |  25 |                1 |
|  3 | 阿布   |  30 |                0 |
|  4 | 一诺   |  31 |               -1 |
+----+--------+-----+------------------+
#INSERT INTO AS
INSERT INTO strcmp_table3 SELECT id,name,strcmp(age,20),strcmp(sal,6000) FROM strcmp_table1 WHERE strcmp(name,'程程') = 0;
SELECT * FROM strcmp_table3 ORDER BY 1;
+------+--------+------+------+
| id   | c1     | c2   | c3   |
+------+--------+------+------+
|    1 | 张     | 章   | NULL |
|    1 | 程程   | 0    | 1    |
|    2 | 陈     | 陈   | NULL |
|    3 | 王     | 望   | NULL |
+------+--------+------+------+
#UPDATE SET
UPDATE strcmp_table3 e INNER JOIN  strcmp_table1 p ON e.id = p.id SET e.c2 = strcmp(p.sal,6000) where strcmp(p.name,'程程') = 0;
SELECT * FROM strcmp_table3 ORDER BY 1;
+------+--------+------+------+
| id   | c1     | c2   | c3   |
+------+--------+------+------+
|    1 | 张     | 1    | NULL |
|    1 | 程程   | 1    | 1    |
|    2 | 陈     | 陈   | NULL |
|    3 | 王     | 望   | NULL |
+------+--------+------+------+
#WITH AS的SELECT
WITH a AS (SELECT id,name,city,strcmp(name,'a'),strcmp(city,'a') name2 FROM strcmp_table1) SELECT * FROM a ORDER BY 1;
+----+--------+--------+------------------+-------+
| id | name   | city   | strcmp(name,'a') | name2 |
+----+--------+--------+------------------+-------+
|  1 | 程程   | 杭州   |                1 |     1 |
|  2 | 依依   | 广州   |                1 |     1 |
|  3 | 阿布   | 苏州   |                1 |     1 |
|  4 | 一诺   | 苏州   |                1 |     1 |
+----+--------+--------+------------------+-------+
WITH a AS (SELECT id,depno,depname,strcmp(depno,102),strcmp(depname,'a') FROM strcmp_table2 where strcmp(depno,102) = 0) SELECT * FROM a ORDER BY 1;
+------+-------+---------+-------------------+---------------------+
| id   | depno | depname | strcmp(depno,102) | strcmp(depname,'a') |
+------+-------+---------+-------------------+---------------------+
|    2 |   102 | 淘宝    |                 0 |                   1 |
+------+-------+---------+-------------------+---------------------+
