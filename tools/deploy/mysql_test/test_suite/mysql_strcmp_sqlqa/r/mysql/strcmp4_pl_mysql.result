#定义一个有参的函数
DROP FUNCTION f_strcmp;//
CREATE FUNCTION f_strcmp(invalue varchar(200)) returns  varchar(200) READS SQL DATA 
begin
  declare a varchar(200);
    SELECT strcmp(1,invalue) into a FROM dual;
  return a;
END ;
