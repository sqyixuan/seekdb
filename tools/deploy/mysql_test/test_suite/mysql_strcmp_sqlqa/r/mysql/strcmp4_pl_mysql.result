##游标
DROP PROCEDURE pro_strcmp;//
CREATE PROCEDURE pro_strcmp()
BEGIN
  DECLARE a varchar(200);
  DECLARE b varchar(200);
  DECLARE done INT DEFAULT 0;
  DECLARE strcmp_cursor CURSOR FOR SELECT id,strcmp(c1,c2) FROM strcmp_table;
  DECLARE CONTINUE HANDLER FOR SQLSTATE '02000' SET done=1;
  OPEN strcmp_cursor;
  FETCH strcmp_cursor INTO a,b;
  WHILE done<>1 DO
    INSERT INTO strcmp_table VALUES(a,'id','strcmp(c1,c2)=',b);
    FETCH strcmp_cursor INTO a,b;
  END WHILE;
  CLOSE strcmp_cursor;
END;
//
CALL pro_strcmp();
SELECT * FROM strcmp_table ORDER BY 1;
