#### str1,str2 两个参数是表列数据
DROP TABLE num_table1;
CREATE TABLE num_table1( 
  c1 tinyint, 
  c2 smallint,
  c3 mediumint, 
  c4 int, 
  c5 bigint, 
  c6 float, 
  c7 double, 
  c8 DECIMAL(5,2), 
  c9 bit(10)
);
insert into num_table1 values(127,32767,8388607,2147483647,12345678912345678,1.1111,123.1231123,1.1,b'1000001');
select strcmp(c1,10) from num_table1;
+---------------+
| strcmp(c1,10) |
+---------------+
|             1 |
+---------------+
select strcmp(20,c2) from num_table1;
+---------------+
| strcmp(20,c2) |
+---------------+
|            -1 |
+---------------+
select strcmp(c3,c4) from num_table1;
+---------------+
| strcmp(c3,c4) |
+---------------+
|             1 |
+---------------+
#### str1,str2 两个参数是全局变量
DROP TABLE res_table;
CREATE TABLE res_table(
  id int,
  c1 varchar(200), 
  c2 varchar(200));
DROP PROCEDURE p_sha;//
CREATE PROCEDURE p_sha(IN ina varchar(200),IN inb varchar(200))
begin
  declare a varchar(200) default 'mysql1';
  declare b varchar(200) default 'mysql2';
  INSERT INTO res_table VALUES(1,'变量',strcmp(a,b));
  INSERT INTO res_table VALUES(2,'in参数',strcmp(ina,inb));
  INSERT INTO res_table VALUES(3,'变量、参数',strcmp(a,ina));
END;
//
CALL p_sha('mysql','oceanbase');
SELECT * FROM res_table ORDER BY id;
+------+-----------------+------+
| id   | c1              | c2   |
+------+-----------------+------+
|    1 | 变量            | -1   |
|    2 | in参数          | -1   |
|    3 | 变量、参数      | 1    |
+------+-----------------+------+
#### str1,str2 两个参数是用户自定义变量
SET @s1 = 'mysql';
SET @s2 = 'mysql strcmp';
SET @s3 = 'MYSQL STRCMP';
select strcmp(@s1,@s2) from dual;
+-----------------+
| strcmp(@s1,@s2) |
+-----------------+
|              -1 |
+-----------------+
select strcmp(@s1,@s3) from dual;
+-----------------+
| strcmp(@s1,@s3) |
+-----------------+
|              -1 |
+-----------------+
select strcmp(@s2,@s3) from dual;
+-----------------+
| strcmp(@s2,@s3) |
+-----------------+
|               0 |
+-----------------+
#### str1,str2 两个参数是自定义函数的返回值
DROP FUNCTION func1;//
CREATE FUNCTION func1(flg int,invalue varchar(200)) RETURNS varchar(200) READS SQL DATA 
BEGIN
  declare a varchar(200) default 'hello';
  IF flg = 1 THEN 
	RETURN a;
  ELSE 
	RETURN invalue;
  END IF;
END;
//
select strcmp(func1(1,''),func1(2,'hello2')) from dual;
+---------------------------------------+
| strcmp(func1(1,''),func1(2,'hello2')) |
+---------------------------------------+
|                                    -1 |
+---------------------------------------+
