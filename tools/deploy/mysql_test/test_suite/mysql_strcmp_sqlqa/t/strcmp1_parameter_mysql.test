purge recyclebin;
--result_format 4
--error 0,1396
drop user whh@'%';
--enable_warnings
create user whh identified by 'whh';
grant all on *.* to whh WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,whh,whh,test,$OBMYSQL_PORT);

SET character_set_client = 'utf8mb4';
SET character_set_connection = 'utf8mb4';
SET character_set_results = 'utf8mb4';

--echo --------------------------------------------------------------------------
--echo ######################## 标签：strcmp-1 参数部分  ########################
--echo ######## strcmp-1-1  参数个数
--echo ###### 0个
--error 1582
select strcmp() from dual;


--echo ###### 1个
--error 1582
select strcmp(1) from dual;
--error 1582
select strcmp('') from dual;
--error 1582
select strcmp('china') from dual;
--error 1582
select strcmp('2023-02-10 12:00:00') from dual;
--error 1582
select strcmp(NULL) from dual;


--echo ###### 2个
--echo #### str1,str2 两个参数是字面量值
--echo ## str1-参数值
select strcmp(NULL,'str2') from dual;

select strcmp('','str2') from dual;

select strcmp(' ','str2') from dual;

select strcmp('!@#$%^&*','str2') from dual;

select strcmp(TRUE,'str2') from dual;

select strcmp(FALSE,'str2') from dual;

select strcmp('\n','str2') from dual;

select strcmp('\r','str2') from dual;

select strcmp('\t','str2') from dual;

select strcmp('str2
              ','str2') from dual;

select strcmp('STR','str') from dual;

select strcmp('str','str') from dual;

select strcmp('str123','str123') from dual;

select strcmp('str１２３','str123') from dual;

select strcmp(1,'str2') from dual;

select strcmp(1.2345,'str2') from dual;

select strcmp(-1,'str2') from dual;

select strcmp('123','str2') from dual;

select strcmp("456",'str2') from dual;

select strcmp(1.0E+10,'str2') from dual;

--error 1054
select strcmp(10abc,'str2') from dual;

select strcmp(1+2*3/4,'str2') from dual;

select strcmp('20230213','str2') from dual;

select strcmp('12:32:22','str2') from dual;

select strcmp('2023-02-13 12:32:22','str2') from dual;

select strcmp('中国','str2') from dual;

select strcmp('中國','str2') from dual;

select strcmp('中國','中国') from dual;

select strcmp('oceanbase','oceanbase2') from dual;

select strcmp('?????','中国') from dual;

select strcmp('?????','oceanbase2') from dual;

select strcmp('?????','こんにちは') from dual;

select strcmp('こんにちは','こんにちは') from dual;

select strcmp('コンニチハ','コンニチハ') from dual;

select strcmp('こんにちは','コンニチハ') from dual;

select strcmp('こんにちは','中国') from dual;

select strcmp('こんにちは','oceanbase2') from dual;

select strcmp(rpad('w',4194304,'h'),'str2') from dual;

