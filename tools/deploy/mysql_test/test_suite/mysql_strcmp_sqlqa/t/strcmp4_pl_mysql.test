purge recyclebin;
--result_format 4
--error 0,1396
drop user whh@'%';
--enable_warnings
create user whh identified by 'whh';
grant all on *.* to whh WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,whh,whh,test,$OBMYSQL_PORT);

SET character_set_client = 'utf8mb4';
SET character_set_connection = 'utf8mb4';
SET character_set_results = 'utf8mb4';

--echo --------------------------------------------------------------------------
--echo ######################## 标签：strcmp-4 PL/SQL场景  ########################
--error 0,1051
DROP TABLE strcmp_table;
CREATE TABLE strcmp_table(
  id int,
  c1 varchar(200),
  c2 varchar(200),
  c3 varchar(200))
PARTITION BY RANGE COLUMNS(id) (   
  PARTITION p0 VALUES LESS THAN (5),    
  PARTITION p1 VALUES LESS THAN (10),     
  PARTITION p2 VALUES LESS THAN MAXVALUE );

INSERT INTO strcmp_table VALUES(1,'MYSQL','mysql',NULL);
INSERT INTO strcmp_table VALUES(2,'oceanbase','oceanbase mysql',NULL);


--echo ######## strcmp-4-1  存储过程
--echo ###### 参数
--echo ### 无参数的存储过程
DELIMITER //;
--error 0,1305
DROP PROCEDURE pro_strcmp;//
CREATE PROCEDURE pro_strcmp()
begin
	declare var varchar(200);
	declare i int default 3;
	SELECT strcmp(c1,c2) into var FROM strcmp_table WHERE strcmp(c1,c2) is not null and id = 1;
    UPDATE strcmp_table SET c3 = var WHERE id = 1;
	WHILE i <= 4 do
	  INSERT INTO strcmp_table VALUES(i,'i=',i,strcmp(i,10));
	  SET i := i + 1;
	END while;
END;
//
DELIMITER ;//

CALL pro_strcmp();
SELECT * FROM strcmp_table ORDER BY 1;


--echo ##只有一个in参数的存储过程
DELIMITER //;
--error 0,1305
DROP PROCEDURE pro_strcmp;//
CREATE PROCEDURE pro_strcmp(in invalue varchar(200))
begin
	declare var varchar(200);
	declare i int default 5;
	SELECT strcmp(c1,c2) into var FROM strcmp_table WHERE strcmp(c1,c2) is not null and id = 2;
    UPDATE strcmp_table SET c3 = var WHERE id = 2;
	WHILE i <= 6 do
	  INSERT INTO strcmp_table VALUES(i,'invalue=',invalue,strcmp(invalue,10));
	  SET i := i + 1;
	END while;
END;
//
DELIMITER ;//

CALL pro_strcmp(10);
SELECT * FROM strcmp_table ORDER BY 1;
CALL pro_strcmp(strcmp('mysql','oracle'));
SELECT * FROM strcmp_table ORDER BY 1;


--echo ##包含out参数的存储过程
DELIMITER //;
--error 0,1305
DROP PROCEDURE pro_strcmp;//
CREATE  PROCEDURE pro_strcmp(out outa varchar(200))
begin
    declare i int default 7;
	SELECT strcmp(c1,c2) into outa FROM strcmp_table WHERE strcmp(c1,'oceanbase') like '%0%';
	WHILE i <= 8 do
	   INSERT INTO strcmp_table VALUES(i,'i=',i,strcmp(i,10));
	SET i := i + 1;
	END WHILE;
END;
//
DELIMITER ;//

CALL pro_strcmp(@outa);
SELECT * FROM strcmp_table ORDER BY 1;
SELECT @outa;


--echo ##包含inout参数的存储过程
DELIMITER //;
--error 0,1305
DROP PROCEDURE pro_strcmp;//
CREATE  PROCEDURE pro_strcmp(INOUT inouta varchar(200))
begin
    declare invalue varchar(200);
    declare i int default 9;
	set invalue := inouta;
	SELECT strcmp(c1,c2) into inouta FROM strcmp_table WHERE strcmp(c1,c2) = invalue limit 1;
	WHILE i <= 10 do
	  INSERT INTO strcmp_table VALUES(i,'i=',i,strcmp(i,10));
	  set i := i+1;
	END WHILE;
END;
//
DELIMITER ;//

SET @inouta=strcmp('strcmp','strcmp()');
CALL pro_strcmp(@inouta);
SELECT * FROM strcmp_table ORDER BY 1;
SELECT @inouta;


--echo ###### dml语句
--echo ## 条件语句
DELIMITER //;
--error 0,1305
DROP PROCEDURE pro_strcmp;//
CREATE PROCEDURE pro_strcmp(IN invalue varchar(200),IN ina varchar(200),IN inb varchar(200))
begin
    IF invalue = strcmp('B','b') THEN 
	   INSERT INTO strcmp_table VALUES(11,'PROCEDURE-If条件','dml语句',strcmp(ina,inb));
    ELSE 
	   INSERT INTO strcmp_table VALUES(12,ina,inb,strcmp(ina,inb));
    END IF;
END;
//
DELIMITER ;//

SET @invalue := strcmp('A','a');
SET @ina := '1';
SET @inb := '2';
CALL pro_strcmp(@invalue,@ina,@inb);
SELECT * FROM strcmp_table ORDER BY 1;


SET @invalue := 1;
SET @ina := '1';
SET @inb := '2';
CALL pro_strcmp(@invalue,@ina,@inb);
SELECT * FROM strcmp_table ORDER BY 1;


--echo #循环语句
DELIMITER //;
--error 0,1305
DROP PROCEDURE pro_strcmp;//
CREATE PROCEDURE pro_strcmp()
begin
    declare i int default 13;
    WHILE i <= 15 do
      INSERT INTO strcmp_table VALUES(i,'PROCEDURE-While循环','strcmp(i,15)',strcmp(i,15));
      set i := i+1;
    END WHILE;

    loop_name:LOOP
      INSERT INTO strcmp_table VALUES(i,'PROCEDURE-Loop循环','strcmp(i,17)',strcmp(i,17));
      SET i := i+1;
      IF i > 17 THEN 
	    LEAVE loop_name;
      END IF;
    END LOOP loop_name;

    REPEAT
      INSERT INTO strcmp_table VALUES(i,'PROCEDURE-Repeat循环','strcmp(i,19)',strcmp(i,19));
      SET i := i+1;
      until i > 19	
    END REPEAT;
END;
//
DELIMITER ;//

CALL pro_strcmp();
SELECT * FROM strcmp_table ORDER BY 1;


--echo ##游标
DELIMITER //;
--error 0,1305
DROP PROCEDURE pro_strcmp;//
CREATE PROCEDURE pro_strcmp()
BEGIN
  DECLARE a varchar(200);
  DECLARE b varchar(200);
  DECLARE done INT DEFAULT 0;
  DECLARE strcmp_cursor CURSOR FOR SELECT id,strcmp(c1,c2) FROM strcmp_table;
  DECLARE CONTINUE HANDLER FOR SQLSTATE '02000' SET done=1;
  OPEN strcmp_cursor;
  FETCH strcmp_cursor INTO a,b;
  WHILE done<>1 DO
    INSERT INTO strcmp_table VALUES(a,'id','strcmp(c1,c2)=',b);
    FETCH strcmp_cursor INTO a,b;
  END WHILE;
  CLOSE strcmp_cursor;
END;
//
DELIMITER ;//

CALL pro_strcmp();
SELECT * FROM strcmp_table ORDER BY 1;


--echo ##动态sql
DELIMITER //;
--error 0,1305
DROP PROCEDURE pro_strcmp;//
CREATE PROCEDURE pro_strcmp()
BEGIN
  SET @s = 'INSERT INTO strcmp_table VALUES(?,"动态sql插入的数据","abc123 abc1234",?);';
  PREPARE stmstrcmp_table FROM @s;
  SET @a = 20;
  SET @b = strcmp('abc123','abc1234');
  EXECUTE stmstrcmp_table USING @a,@b;

  SET @s = 'SELECT * FROM strcmp_table WHERE id = 20';
  PREPARE stmt2 FROM @s;
  EXECUTE stmt2; 
END;
//
DELIMITER ;//

CALL pro_strcmp();


DELIMITER //;
--error 0,1305
DROP PROCEDURE pro_strcmp;//
CREATE PROCEDURE pro_strcmp()
BEGIN
  SET @s = 'update strcmp_table set c1 = ?,c2 = ?,c3 = ? WHERE id = 20;';
  PREPARE stmstrcmp_table FROM @s;
  SET @a = '动态sql更新的数据';
  SET @b = 'mysql Mysql';
  SET @c = strcmp('mysql','Mysql');
  EXECUTE stmstrcmp_table USING @a,@b,@c;

  SET @s = 'SELECT * FROM strcmp_table WHERE id = 20';
  PREPARE stmt2 FROM @s;
  EXECUTE stmt2; 
  
  SET @s = 'delete FROM strcmp_table WHERE c2 = ?;';
  PREPARE stmstrcmp_table FROM @s;
  SET @a = 'mysql Mysql';
  EXECUTE stmstrcmp_table USING @a;

  SET @s = 'SELECT * FROM strcmp_table WHERE id = 20';
  PREPARE stmt2 FROM @s;
  EXECUTE stmt2; 
END;
//
DELIMITER ;//

CALL pro_strcmp();


--echo ##函数返回值作为存储过程的参数传递
DELIMITER //;
--error 0,1305
DROP FUNCTION f_strcmp;//
CREATE FUNCTION f_strcmp() RETURNS varchar(200) READS SQL DATA 
BEGIN
  declare a varchar(200);
  SELECT strcmp('function','procedure') into a FROM dual;
  RETURN a;
END;
//

--error 0,1305
DROP PROCEDURE pro_strcmp;//
CREATE PROCEDURE pro_strcmp(in infun varchar(200))
begin
	declare a varchar(200);
	declare b varchar(200);
	declare i int;
	set a := '变量1';
	set b := '变量2';
  	INSERT INTO strcmp_table VALUES(21,infun,concat(a,b),strcmp(a,b));
END;
//
DELIMITER ;//


CALL pro_strcmp(f_strcmp());
SELECT * FROM strcmp_table ORDER BY 1;


-- echo #自定义变量，全局变量，in 参数作为strcmp函数的参数
DELIMITER //;
--error 0,1305
DROP PROCEDURE pro_strcmp;//
CREATE PROCEDURE pro_strcmp(IN ina varchar(200),IN inb varchar(200))
begin
  declare a varchar(200) default 'var1';
  declare b varchar(200) default 'var2';

  INSERT INTO strcmp_table VALUES(22,'自定义变量','var1 var2',strcmp(a,b));
  INSERT INTO strcmp_table VALUES(23,'全局变量','user var USER VAR',strcmp(@mya,@myb));
  INSERT INTO strcmp_table VALUES(24,'参数变量','wang huan huan chen zhi heng',strcmp(ina,inb));
END;
//
DELIMITER ;//

SET @mya := 'user var';
SET @myb := 'USER VAR';
CALL pro_strcmp('wang huan huan','chen zhi heng');
SELECT * FROM strcmp_table ORDER BY 1;


--echo ### 标签：strcmp-3-2 函数      
--echo #定义一个无参的函数
DELIMITER //;
--error 0,1305
DROP FUNCTION f_strcmp;//
CREATE FUNCTION f_strcmp() returns varchar(200) READS SQL DATA 
begin
  declare a varchar(200);
  SELECT strcmp('function','function compare') into a FROM dual;
  return a;
END;
//
DELIMITER ;//

SELECT  f_strcmp();


--echo #定义一个有参的函数
DELIMITER //;
--error 0,1305
DROP FUNCTION f_strcmp;//
CREATE FUNCTION f_strcmp(invalue varchar(200)) returns  varchar(200) READS SQL DATA 
begin
  declare a varchar(200);
    SELECT strcmp(1,invalue) into a FROM dual;
  return a;
END ;
//
DELIMITER ;//

SELECT f_strcmp(strcmp('function','in'));


--echo ##dml语句
--echo #条件语句
DELIMITER //;
--error 0,1305
DROP FUNCTION f_strcmp;//
CREATE FUNCTION f_strcmp(invalue varchar(200),ina varchar(200),inb varchar(200))returns varchar(200) DETERMINISTIC
begin
  IF invalue = 0 THEN 
     INSERT INTO strcmp_table VALUES(25,'FUNCTION-If条件','invalue=0',strcmp(invalue,inb));
  ELSE 
     INSERT INTO strcmp_table VALUES(26,'FUNCTION-If条件','invalue!=0',strcmp(invalue,ina));
  END IF;
  return strcmp(ina,inb);
END;
//
DELIMITER ;//

SET @invalue := strcmp('in','inout');
SET @ina := 'ina';
SET @inb := 'inb';
SELECT f_strcmp(@invalue,@ina,@inb);
SELECT * FROM strcmp_table ORDER BY 1;

SET @invalue := strcmp('strcmp_table','STRCMP_TABLE');
SET @ina := 'str1';
SET @inb := 'str2';
SELECT f_strcmp(@invalue,@ina,@inb);
SELECT * FROM strcmp_table ORDER BY 1;


--echo #循环语句
DELIMITER //;
--error 0,1305
DROP FUNCTION f_strcmp;//
CREATE FUNCTION f_strcmp(invalue varchar(200)) returns varchar(200) DETERMINISTIC
begin
  declare a varchar(200);
  declare i int default 27;
  SELECT strcmp(invalue,invalue) into a FROM dual;
  
  WHILE i <= 28 do
    INSERT INTO strcmp_table VALUES(i,'FUNCTION-While循环','字符比较',strcmp('abc','efg'));
    set i := i+1;
  END WHILE;
  
  loop_name:LOOP
    INSERT INTO strcmp_table VALUES(i,'FUNCTION-Loop循环','数字比较',strcmp(i+1,i));
    SET i := i+1;
    IF i > 30 THEN 
      LEAVE loop_name;
    END IF;
  END LOOP loop_name;
  
  REPEAT
    INSERT INTO strcmp_table VALUES(i,'FUNCTION-Repeat循环','特殊符号比较',strcmp('$%^','*&%'));
    SET i := i+1;
    until i > 32	
  END REPEAT;
  return a;
END;
//
DELIMITER ;//

SELECT f_strcmp(strcmp('strcmp','substring'));
SELECT * FROM strcmp_table ORDER BY 1;


--echo ### 标签：strcmp-3-3 触发器
--error 0,1051
DROP TABLE t1;
CREATE TABLE t1(id int,c1 varchar(200));

DELIMITER //;
--error 0,1360
DROP TRIGGER base_pl;//
CREATE TRIGGER base_pl BEFORE INSERT ON t1 FOR EACH ROW
BEGIN
  DECLARE a int;
  DECLARE b VARCHAR(20);
  set a = 33;
  set b = '36';
  loop1: LOOP
    if a < 38 then
      INSERT INTO strcmp_table VALUES(a,'触发器-插入数据','a b',strcmp(a,b));
    elseif a = 39 then
      update strcmp_table set c1 = '触发器-更新数据',c2='b a',c3=strcmp(b,a)  WHERE id >= 34;
      LEAVE loop1;
    else
      delete FROM strcmp_table WHERE id = 35;	
    end if;
    set a = a + 1;
  end LOOP loop1;
END;
//
DELIMITER ;//

INSERT INTO t1 VALUES(1,'t1 触发触发器');
SELECT * FROM strcmp_table ORDER BY 1;


