# owner: xiaoyi.xy
# owner group: sql-执行组
# description: mysql STRCMP(str1,str2) - 运算符，函数间嵌套
# tags: DDL,DML
# author: whh01047778


purge recyclebin;
--result_format 4
--error 0,1396
drop user whh@'%';
--enable_warnings
create user whh identified by 'whh';
grant all on *.* to whh WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,whh,whh,test,$OBMYSQL_PORT);

SET character_set_client = 'utf8mb4';
SET character_set_connection = 'utf8mb4';
SET character_set_results = 'utf8mb4';

--echo --------------------------------------------------------------------------
--echo ######################## 标签：strcmp-5 运算符    ########################
--echo ### 标签：strcmp-5-1 算术运算符
select strcmp(6+2-3,3*2/3),strcmp(5 DIV 2,5 MOD 3) from dual;
select strcmp(1,2) + strcmp('a','b') * 2 /3 from dual;


--echo ### 标签：strcmp-5-2 比较运算符
select strcmp(not 1,3 and 1),strcmp(5 or 2,5 xor 3) from dual;
select strcmp(1,2) and strcmp('a','b') or not strcmp('a','b') xor strcmp('a','b') from dual;


--echo ### 标签：strcmp-5-3 位运算符
select strcmp(6&3,3|3),strcmp(5 ^ 2,5 MOD !3),strcmp(5<<2,5>>3) from dual;
select strcmp(1,2) & strcmp('a','b'),strcmp(1,2) | strcmp('a','b') from dual;
select strcmp(1,2) ^ strcmp('a','b'),strcmp(1,2) | ! strcmp('a','b') from dual;
select strcmp(1,2) >> strcmp('a','b'),strcmp(1,2) << strcmp('a','b') from dual;


--echo ### 标签：strcmp-5-4 比较运算符
select strcmp(6!=3,3=3),strcmp(5 > 2,5 < 3),strcmp(5<>2,5>=3) from dual;
select strcmp(6,3 in (1,2,3)),strcmp(5,5 between 1 and 2),strcmp(2,5 is null) from dual;
select strcmp(1 <=> null,5 is null),strcmp(null <=> null,5 is not null) from dual;
select strcmp('a' like '%a%','abc' rlike '%a%'),strcmp('a' regexp 'a',5) from dual;
select strcmp(1,2) >= strcmp('a','b'),strcmp(1,2) <= strcmp('a','b') from dual;
select strcmp(1,2) = strcmp('a','b'),strcmp(1,2) <> strcmp('a','b') from dual;
select strcmp(1,2) != strcmp('a','b'),strcmp(1,2) < strcmp('a','b') from dual;
select strcmp(1,2) in (strcmp(1,1),strcmp(1,2),strcmp(2,1)) from dual;
select strcmp('str','string') is null from dual;
select strcmp('a','b') between 0 and 1 from dual;
select strcmp('a','b') <=> strcmp(2,5 MOD 3) from dual;
select strcmp('a','b') from dual where strcmp('a','b') LIKE strcmp('b','a');
select strcmp('a','b') from dual where strcmp('a','b') RLIKE '-1';
select strcmp('a','b') from dual where strcmp('a','b') REGEXP '%0%';


--echo ---------------------------------------------------------------------------
--echo ######################## 标签：strcmp-6 函数间嵌套 ########################
--echo ### 标签：strcmp-6-1，strcmp-6-2 嵌套其他函数，被其他函数嵌套
--echo ## 数字函数
SELECT strcmp('a','b'),ABS(strcmp('a','b')) FROM dual;
SELECT ABS(-1),strcmp(ABS(-1),1) FROM dual;

SELECT strcmp('a','b'),AVG(strcmp('a','b')) FROM dual;
SELECT AVG(-1),strcmp(AVG(-1),1) FROM dual;

SELECT strcmp('a','b'),ceil(strcmp('a','b')) FROM dual;
SELECT ceil(3.1415),strcmp(ceil(3.1415),3) FROM dual;

SELECT strcmp('a','b'),sin(strcmp('a','b')) FROM dual;
SELECT sin(3.1415),strcmp(sin(3.1415),3) FROM dual;

SELECT strcmp('a','b'),cos(strcmp('a','b')) FROM dual;
SELECT cos(3.1415),strcmp(cos(3.1415),3) FROM dual;

SELECT strcmp('a','b'),sign(strcmp('a','b')) FROM dual;
SELECT sign(3.1415),strcmp(sign(3.1415),3) FROM dual;

SELECT strcmp('a','b'),floor(strcmp('a','b')) FROM dual;
SELECT floor(3.1415),strcmp(floor(3.1415),3) FROM dual;

SELECT strcmp('a','b'),power(strcmp('a','b'),2) FROM dual;
SELECT power(3,2),strcmp(power(3,2),3) FROM dual;

SELECT strcmp('a','b'),max(strcmp('a','b')) FROM dual;
SELECT max(3.1415),strcmp(max(3.1415),3) FROM dual;

SELECT strcmp('a','b'),min(strcmp('a','b')) FROM dual;
SELECT min(3.1415),strcmp(min(3.1415),3.1415) FROM dual;

SELECT strcmp('a','b'),mod(strcmp('a','b'),2) FROM dual;
SELECT mod(3,2),strcmp(mod(3,2),3) FROM dual;

SELECT strcmp('a','ab'),round(strcmp('a','ab')) FROM dual;
SELECT round(3.1415),strcmp(round(3.1415),3) FROM dual;

SELECT strcmp('a','b'),truncate(strcmp('a','b'),2) FROM dual;
SELECT truncate(3.1415926,2),strcmp(truncate(3.1415926,2),3) FROM dual;

SELECT strcmp('a','b'),sqrt(strcmp('a','b')) FROM dual;
SELECT sqrt(3.1415),strcmp(sqrt(3.1415),3.1415) FROM dual;

SELECT strcmp('a','b'),sum(strcmp('a','b')) FROM dual;
SELECT sum(3.1415),strcmp(sum(3.1415),3.1415) FROM dual;

--echo ## 字符函数
SELECT strcmp('mysql','oracle'),upper(strcmp('mysql','oracle')) FROM dual;
SELECT upper('oceanbase'),strcmp(upper('oceanbase'),'OCEANBASE') FROM dual;

SELECT strcmp('mysql','oracle'),lower(strcmp('mysql','oracle')) FROM dual;
SELECT lower('oceanbase'),strcmp(lower('oceanbase'),'OCEANBASE') FROM dual;

SELECT strcmp('mysql','oracle'),instr(strcmp('mysql','oracle'),'1') FROM dual;
SELECT instr('oceanbase','b'),strcmp(instr('oceanbase','b'),'OCEANBASE') FROM dual;

SELECT strcmp('mysql','oracle'),length(strcmp('mysql','oracle')) FROM dual;
SELECT length('oceanbase'),strcmp(length('oceanbase'),8) FROM dual;

SELECT strcmp('mysql','oracle'),replace(strcmp('mysql','oracle'),'1','&') FROM dual;
SELECT replace('oceanbase','e','@'),strcmp(replace('oceanbase','e','@'),'OCEANBASE') FROM dual;

SELECT strcmp('mysql','oracle'),substr(strcmp('mysql','oracle'),0,2) FROM dual;
SELECT substr('oceanbase',1,5),strcmp(substr('oceanbase',1,5),'OCEANBASE') FROM dual;

SELECT strcmp('mysql','oracle'),concat(strcmp('mysql','oracle'),'--') FROM dual;
SELECT concat('oceanbase',' mysql'),strcmp(concat('oceanbase',' mysql'),'oceanbase mysql') FROM dual;


--echo ## 日期函数
SELECT strcmp(SYSDATE(),'2023-03-06') FROM dual;

SELECT strcmp('mysql','oracle'),FROM_DAYS(strcmp('mysql','oracle')) FROM dual;
SELECT FROM_DAYS('oceanbase'),strcmp(FROM_DAYS('oceanbase'),'OCEANBASE') FROM dual;


--echo ##通用函数
SELECT strcmp('mysql','oracle'),ifnull(null,strcmp('mysql','oracle')) FROM dual;
SELECT ifnull('oceanbase',null),strcmp(ifnull('oceanbase',null),'OCEANBASE') FROM dual;

SELECT strcmp('mysql','oracle'),coalesce(null,strcmp('mysql','oracle')) FROM dual;
SELECT coalesce('oceanbase',null),strcmp(coalesce('oceanbase',null),'OCEANBASE') FROM dual;


--echo ### 标签：strcmp-6-3 多级函数嵌套  
SELECT strcmp(strcmp(strcmp(strcmp(strcmp(strcmp('china','world'),'1'),'0'),'1'),'-1'),'1') FROM dual;
SELECT strcmp('-1',strcmp('china',strcmp('china',strcmp('china',strcmp('china',strcmp('china','world'))))))  FROM dual;
SELECT strcmp(strcmp(strcmp('a','ab'),'1'),strcmp(strcmp(strcmp('a','ab'),'0'),'0')) FROM dual;

SELECT strcmp(upper('oceanbase'),strcmp(lower('oceanbase'),length('oceanbase'))) FROM dual;
SELECT ABS(strcmp(floor(floor(floor(3.1415))),lower(upper('oceanbase')))) FROM dual;


--echo # Clean up users
connection default;
--disable_warnings
--error 0,1396
drop user whh@'%';
--enable_warnings
