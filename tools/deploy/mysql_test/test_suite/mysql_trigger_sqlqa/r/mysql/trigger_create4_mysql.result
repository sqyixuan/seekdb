result_format: 4
# 创建用户
drop database cwx_db;
drop database cwx_db1;
drop user cwx@'%';
drop user cwx1@'%';

# 创建测试用户
create database cwx_db;
use cwx_db;
create user cwx identified by 'cwx';
grant all privileges on *.* to cwx;

create database cwx_db1;
use cwx_db1;
create user 'cwx1' identified by 'cwx1';
grant all privileges on *.* to 'cwx1';
# 建立链接
##trigger-1-1-3
##创建（权限）
##触发器创建
##权限
##old+new
##无select权限,使用old+new
set session autocommit=1;
commit;
revoke select on *.* from 'cwx';
set session autocommit=1;
create table c1(t1 int);$
create table c2(t1 int);$
##正常使用
##36077820,去除user的select权限,delete table时ob报错，mysql成功;预期结果：ob删除失败
create trigger cai_trig before insert on c1
for each row
begin
insert into c2 values(1);
end;
$
insert into c1 values(1);$
select * from cwx.c2 order by t1;$
ERROR 42S02: Table 'cwx.c2' doesn't exist
set session autocommit=1;
use cwx_db;
commit;
select * from c2 order by t1;
+------+
| t1   |
+------+
|    1 |
+------+
##使用old + new(after+ insert)
set session autocommit=1;
commit;
##使用大写
##同 36077820
##目前执行为obclient端报错，mysqltest端执行成功
delete from c1;
drop trigger cai_trig;$
##36078552，去除user的select权限,ob可成功触发触发器，mysql创建失败；预期结果：ob创建失败
create trigger cai_trig1 after insert on c1
for each row
begin
insert into c2 values(OLD.t1);
end;
$
ERROR HY000: There is no OLD row in on INSERT trigger
insert into c1 values(1);$
create trigger cai_trig1 after update on c1
for each row
begin
insert into c2 values(OLD.t1);
end;
$
##目前执行为obclient端报错，mysqltest端执行成功
update c1 set t1=4;$
drop trigger cai_trig1;$
create trigger cai_trig1 after delete on c1
for each row
begin
insert into c2 values(OLD.t1);
end;
$
##目前执行为obclient端报错，mysqltest端执行成功
delete from c1;$
drop trigger cai_trig1;$
create trigger cai_trig1 before insert on c1
for each row
begin
insert into c2 values(NEW.t1);
end;
$
