ERROR HY000: There is no NEW row in on DELETE trigger
##无update权限，在before触发器中使用SET NEW.col_name = value
set session autocommit=1;
commit;
grant all privileges on *.* to 'cwx';
revoke update on *.* from 'cwx';
set session autocommit=1;
commit;
insert into c1 values(2);$
create trigger cai_trig1 before update on c1
for each row
SET NEW.t1 = 7;
$
##目前执行为obclient端报错，mysqltest端执行成功
update c1 set t1=3;$
drop trigger cai_trig1;$
create trigger cai_trig1 after update on c1
for each row
SET NEW.t1 = 7;
$
ERROR HY000: Updating of NEW row is not allowed in after trigger
drop trigger cai_trig1;$
ERROR HY000: Trigger does not exist
##user不存在super权限，设置definer
set session autocommit=1;
commit;
grant all privileges on *.* to 'cwx';
delete from c1;
delete from c2;
revoke super on *.* from 'cwx';
set session autocommit=1;
commit;
create definer='cwx' trigger cai_trig1 before insert on c1
for each row
insert into c2 values(3);
$
insert into c1 values(1);$
##proxy模式执行失败，obs0，obs1及obclient均成功
drop trigger cai_trig1;$
##同 36078552
create definer='cwx1' trigger cai_trig1 before insert on c1
for each row
insert into c2 values(3);
$
insert into c1 values(1);$
##proxy0报错，其余模式成功
drop trigger cai_trig1;$
create definer='notexist' trigger cai_trig1 before insert on c1
for each row
insert into c2 values(3);
$
