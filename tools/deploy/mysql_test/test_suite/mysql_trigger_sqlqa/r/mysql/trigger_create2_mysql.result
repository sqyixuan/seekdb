##procedure 中存在 in参数+ dml + 其他语句
delete from c4;$
delete from c5;$
drop procedure if exists cai_pro;$
create procedure cai_pro(in a int)
begin
set @b=a+6;
insert into c5 values(a,a,a);
insert into c5 values(@b,@b,@b);
end;
$
create trigger cai_trig before insert on c4
for each row
begin
call cai_pro(2);
end;
$
