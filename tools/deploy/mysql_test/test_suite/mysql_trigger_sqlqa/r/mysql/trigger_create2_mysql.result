# 创建用户
drop database cwx_db;
drop database cwx_db1;
drop user cwx@'%';
drop user cwx1@'%';

# 创建测试用户
create database cwx_db;
use cwx_db;
create user cwx identified by 'cwx';
grant all privileges on *.* to cwx;

create database cwx_db1;
use cwx_db1;
create user 'cwx1' identified by 'cwx1';
grant all privileges on *.* to 'cwx1';
# 建立链接
##trigger-1-1-3，trigger-1-2，trigger-4，trigger-5,trigger-3
##创建（权限+注意点），删除触发器，显示触发器,使用触发器
set session autocommit=1;
##触发器创建
create table c1(t1 int);$
create table c2(t1 int);$
##使用 lock tables 
lock tables c1 read;$
##36093068，使用lock table，ob触发成功，mysql创建失败；预期结果：ob创建失败
create trigger cai_trig1 before insert on c1
for each row
insert into c2 values(3);
$
insert into c1 values(1);$
drop trigger cai_trig1;$
##同 36093068
create trigger cai_trig1 before update on c1
for each row
insert into c2 values(3);
$
update c1 set t1=2;$
drop trigger cai_trig1;$
##同 36093068
create trigger cai_trig1 before delete on c1
for each row
insert into c2 values(3);
$
delete from c1;$
drop trigger cai_trig1;$
