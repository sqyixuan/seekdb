--echo ##不同 数据类型 + 表

create table c1(t1 integer,t2 smallint,t3 decimal,t4 numeric,t5 float,t6 real,t7 double precision,t8 int);
create table c2(t1 date,t2 time,t3 datetime,t4 timestamp,t5 year);
create table c3(t1 char(20),t2 varchar(20),t3 binary(10),t4 varbinary(10),t5 blob,t6 text,t7 enum('1','2'),t8 set('1','2'));
create table c20(t1 boolean,t2 int default 3);
create table c5(t1 geometry,t2 point,t3 linestring,t4 polygon);
drop table c5;
create table c21(t1 long);
create table c4(t1 varchar(200));

--echo ##definer 验证
