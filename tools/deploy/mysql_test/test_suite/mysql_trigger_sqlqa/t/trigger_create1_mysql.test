delimiter /;
create definer='cwx' trigger cai_trig before insert on c1
for each row
begin
insert into c4 values(1);
end;
/
insert into c1 values(1,1,1,1,1,1,1,1);/
select * from c4 order by t1;/

drop trigger cai_trig;
delete from c1;/
delete from c4;/
