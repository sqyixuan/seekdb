--echo ##procedure中存在out$inout 参数，触发器逻辑为call pro
delete from c4;$
delete from c5;$
drop procedure if exists cai_pro;$
drop procedure if exists cai_pro1;$
create procedure cai_pro(in a int,inout b int)
begin
insert into c5 values(a,b,7);
end;
$
create procedure cai_pro1(in a int,out b int)
begin
set b =a+2;
insert into c5 values(a,b,7);
end;
$
create trigger cai_trig before insert on c4
for each row
begin
call cai_pro(1,2);
end;
$
