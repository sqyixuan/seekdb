--echo ##function 中存在 in参数+ dml + 其他语句
delete from c4;$
delete from c5;$
create table c6(t1 int,t2 int,t3 int);$
drop function if exists cai_func;$
create function cai_func(a int) returns int
begin
set @b=a+6;
insert into c5 values(a,a,a);
insert into c5 values(@b,@b,@b);
return 1;
end;
$
create trigger cai_trig before insert on c4
for each row
begin
insert into c6 select cai_func(2),cai_func(4),cai_func(6) from dual;
end;
$
