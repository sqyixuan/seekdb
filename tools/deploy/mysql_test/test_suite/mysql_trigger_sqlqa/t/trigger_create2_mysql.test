--echo ##触发器不能使用显式或隐式开始或结束事务的语句，例如 START TRANSACTION、COMMIT 或 ROLLBACK。 （回滚到 SAVEPOINT 是允许的，因为它不会结束事务。）。
--echo ##触发器存在 START TRANSACTION、COMMIT 、 ROLLBACK、SAVEPOINT 
delete from c4;$
delete from c5;$
###mysql: ERROR 1422 (HY000): Explicit or implicit commit is not allowed in stored function or trigger.
--error 1422
create trigger cai_trig before insert on c4
for each row
begin
start transaction;
insert into c5 values (1,1,1);
end;
$
--echo ##36128024，触发器中存在事务相关语句，ob创建成功，mysql失败；预期结果：ob创建失败
insert into c4 values(1);$
select * from c4 order by t1;$
select * from c5 order by t1;$

delete from c4;$
delete from c5;$
--error 1422
create trigger cai_trig before insert on c4
for each row
begin
insert into c5 values (1,1,1);
commit;
end;
$

insert into c4 values(1);$

--error 1422
create trigger cai_trig before insert on c4
for each row
begin
insert into c5 values (1,1,1);
rollback;
end;
$

insert into c4 values(1);$

delete from c4;$
delete from c5;$
--echo ##同 36128024
create trigger cai_trig before insert on c4
for each row
begin
insert into c5 values (2,2,2);
savepoint p1;
insert into c5 values (1,1,1);
rollback to p1;
end;
$

insert into c4 values(1);$
select * from c4 order by t1;$
select * from c5 order by t1;$
--error 0,1360
drop trigger cai_trig;$

--echo ##仅当任何 BEFORE 触发器和行操作成功执行时，才会执行 AFTER 触发器。
--echo ##before触发器成功，after触发器失败
delete from c4;$
delete from c5;$
create trigger cai_trig before insert on c4
for each row
begin
insert into c5 values (2,2,2);
end;
$
create trigger cai_trig1 after insert on c4
for each row
begin
insert into c5 values ('a','b');
end;
$
--echo ##36128626，before 触发器可触发成功，after可触发失败；ob及mysql表内结果不一致；预期结果：ob结果同mysql
--error 1136
insert into c4 values(1);$
select * from c4 order by t1;$
select * from c5 order by t1;$
drop trigger cai_trig;$
drop trigger cai_trig1;$


--echo ##BEFORE 或 AFTER 触发器期间的错误会导致导致触发器调用的整个语句失败。
--echo ##before 、after 触发器中存在多条语句（多正一错）
delete from c4;$
delete from c5;$
create trigger cai_trig before insert on c4
for each row
begin
insert into c5 values (2,2,2);
insert into c5 values (2,2,2);
insert into c5 values (2,2,'a');
end;
$
--echo ##mysql行为：c5内有正确的数据；ob执行：c5内无数据，同手册描述；已和开发确认，此场景未符合预期
--error 1366
insert into c4 values(1);$
select * from c4 order by t1;$
select * from c5 order by t1;$
drop trigger cai_trig;$

delete from c4;$
delete from c5;$
create trigger cai_trig after insert on c4
for each row
begin
insert into c5 values (2,2,2);
insert into c5 values (2,2,2);
insert into c5 values ('a','b');
end;
$
--echo ##同 before 行为，符合预期
--error 1136
insert into c4 values(1);$
select * from c4 order by t1;$
select * from c5 order by t1;$
drop trigger cai_trig;$


--echo ##对于事务表，语句失败应导致该语句执行的所有更改回滚。 触发器失败会导致语句失败，因此触发器失败也会导致回滚。 对于非事务性表，无法进行这种回滚，因此尽管语句失败，但在错误点之前执行的任何更改仍然有效。
create table c7(t1 int,t2 int);$
set session autocommit=0;$
start transaction;$
delete from c4;$
delete from c7;$
create trigger cai_trig before insert on c4
for each row
begin
insert into c7 values(1,1);
insert into c7 values(2,2);
insert into c7 values(3,3);
insert into c7 values(4,4);
end;
$
--error 1366
insert into c4 values('a');$
insert into c4 values(1);$
rollback;$
select * from c4 order by t1;$
select * from c7 order by t1;$
drop trigger cai_trig;$

set session autocommit=1;$
start transaction;$
delete from c4;$
delete from c7;$
create trigger cai_trig before insert on c4
for each row
begin
insert into c7 values(1,1);
insert into c7 values(2,2);
end;
$
--error 1366
insert into c4 values('a');$
insert into c4 values(1);$
rollback;$
