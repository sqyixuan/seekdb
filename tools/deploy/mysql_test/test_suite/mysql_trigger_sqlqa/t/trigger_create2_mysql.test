--echo ##多个trigger_time $trigger_event 相同的触发器 + 触发时间及行为均相同的触发器
create table c3(t1 int);$
create table c4(t1 int);$

create trigger cai_trig before insert on c3
for each row
insert into c4 values(2);
$
create trigger cai_trig1 before update on c3
for each row
insert into c4 values(2);
$
create trigger cai_trig2 before delete on c3
for each row
insert into c4 values(2);
$
create trigger cai_trig3 after insert on c3
for each row
insert into c4 values(1);
$
create trigger cai_trig4 after update on c3
for each row
insert into c4 values(1);
$
create trigger cai_trig5 after delete on c3
for each row
insert into c4 values(1);
$
insert into c3 values(1);$
update c3 set t1=4;$
delete from c3;$
select * from c3 order by t1;$
select * from c4 order by t1;$

--echo ##触发时间+动作均相同的触发器
create trigger cai_trig6 before insert on c3
for each row
insert into c4 values(2);
$
drop trigger cai_trig;$
drop trigger cai_trig1;$
drop trigger cai_trig2;$
drop trigger cai_trig3;$
drop trigger cai_trig4;$
drop trigger cai_trig5;$


--echo ##不能使用 CALL 语句调用将数据返回给客户端或使用动态 SQL 的存储过程。 （允许存储过程通过 OUT 或 INOUT 参数将数据返回给触发器。）
--echo ##触发器中存在call调用
--echo ##存储过程中存在dml，ddl，动态sql
--echo ##36123693，存储过程中存在动态sql，触发器逻辑为call调用时，mysql触发失败，ob成功；预期结果：ob触发失败
create table c5(t1 int,t2 int,t3 int);$

delete from c4;$
delete from c5;$
drop procedure if exists cai_pro;$
create procedure cai_pro()
begin
set @sql='insert into c5 values (1,1,1)';
prepare stmt from @sql;
execute stmt;
deallocate prepare stmt;
end;
$
create trigger cai_trig before insert on c4
for each row
call cai_pro;
$
--echo ##目前执行为obclient端报错，mysqltest端执行成功
