--echo # 创建用户
--source mysql_test/test_suite/mysql_trigger_sqlqa/t/create.inc


--echo # 建立链接
connect (conn1,$OBMYSQL_MS0,cwx,cwx,cwx_db,$OBMYSQL_PORT);
connect (conn2,$OBMYSQL_MS0,cwx1,cwx1,cwx_db1,$OBMYSQL_PORT);
connection conn1;


--echo ##trigger-2-2，trigger-2-3，trigger-2-4，trigger-2-5
--echo ##sql部分+pl部分+触发方式+触发器特有场景

delimiter /;
create table c1(t1 int,t2 int);/
create table c2(t1 int,t2 int);/
--echo ##sql部分 （存在运算（+-/and not/>= 等），连接符，null值，函数嵌套（to_date等）等）
delete from c1;/
delete from c2;/
create trigger cai_trig before insert on c1
for each row
begin
insert into c2 values(3+4-5*0.3,5||4);
insert into c2 values(null,length(1122));
insert into c2 values(1 and 2,3<4);
end;
/
insert into c1 values(3+4-5*0.3,5||4);/
insert into c1 values(null,length(1122));/
insert into c1 values(1 and 2,3<4);/
select * from c1 order by t1;/
select * from c2 order by t1;/
drop trigger cai_trig;/

delete from c2;/
create trigger cai_trig after delete on c1
for each row
begin
insert into c2 values(3+4-5*0.3,5||4);
insert into c2 values(null,length(1122));
insert into c2 values(1 and 2,3<4);
end;
/
delete from c1 where t1=3+4-5*0.3 and t2=5||4;/
delete from c1 where t1 is null;/
delete from c1 where t1 not in (2) or t1 in (1);/
select * from c1 order by t1;/
select * from c2 order by t1;/
drop trigger cai_trig;/

delete from c2;/
insert into c1 values(3+4-5*0.3,5||4);/
insert into c1 values(null,length(1122));/
insert into c1 values(1 and 2,3<4);/
create trigger cai_trig after update on c1
for each row
begin
insert into c2 values(3+4-5*0.3,5||4);
insert into c2 values(null,length(1122));
insert into c2 values(1 and 2,3<4);
end;
/
update c1 set t1=77 where t1=3+4-5*0.3 and t2=5||4;/
update c1 set t1=77 where t1 is null;/
update c1 set t1=77 where t1 not in (2) or t1 in (1);/
select * from c1 order by t1;/
select * from c2 order by t1;/
drop trigger cai_trig;/

--echo ##pl部分
--echo ##存在循环
delete from c1;/
delete from c2;/
create trigger cai_trig before insert on c1
for each row
begin
declare sum int default 0;
declare i int default 1;
declare a int default 3;
while i<=a do
 set sum=sum+i;
 set i=i+1;
end while;

set i=i+0;
loop1:loop
if i>a then
leave loop1;
end if;
set sum=sum+sum;
end loop;

repeat
set i=i+1;
set sum=sum+sum;
until i>a end repeat;

insert into c2 values(sum,sum);
end;
/
insert into c1 values(1,1);/
select * from c1 order by t1;/
select * from c2 order by t1;/
drop trigger cai_trig;/

--echo ##存在判断（case when/if/elt/ifnull 等等） + 存在游标
delete from c1;/
delete from c2;/
insert into c1 values(1,2),(3,4),(5,6),(7,8);/
create trigger cai_trig before insert on c1
for each row
begin
declare t1 int;
declare t2 int;
declare done int default 0;
declare c_cursor cursor for select * from c1;
declare continue handler for not found set done=1;
open c_cursor;
while done!=1 do
 fetch c_cursor into t1,t2;
 if done!=1 then
 insert into c2 values(t1,t2);
 end if;
end while;
close c_cursor;
end;
/
--echo ##36252076，触发器中存在游标的open+close；ob触发失败，mysql成功；预期结果：ob触发成功
insert into c1 values(8,9);/
select * from c1 order by t1;/
select * from c2 order by t1;/
drop trigger cai_trig;/

delete from c1;/
delete from c2;/
create trigger cai_trig before insert on c1
for each row
begin
declare t1 int;
declare t2 int;
if t1 is null then
 case when t2 is null then set t2=1;
 end case;
 case t2 when 1 then set t1=1;
 end case;
 if elt(t2,0,1)=0 then
 insert into c2 values(t1,t2);
 end if;
else
insert into c2 values(3,3);
end if;
end;
/
insert into c1 values(8,9);/
select * from c1 order by t1;/
select * from c2 order by t1;/
drop trigger cai_trig;/

--echo ##存在异常(自定义 +异常定义+异常捕获)
delete from c1;/
delete from c2;/
create trigger cai_trig before insert on c1
for each row
begin
declare t1 int;
declare c_error condition for 1235;
declare continue handler for c_error set t1='a';
insert into c2 values(1,2);
insert into c2 values(2,3);

begin
declare exit handler for sqlstate '42000' set t1='a';
insert into c2 values(4,5);
end;
end;
/
insert into c1 values(1,1);/
select * from c1 order by t1;/
select * from c2 order by t1;/
drop trigger cai_trig;/

--echo ##execute immediate（pl语句 +sql语句） 
delete from c1;/
delete from c2;/
--echo ##36265412,触发器中存在动态执行语句，ob成功，mysql失败;预期结果：ob创建失败
--error 1336
create trigger cai_trig before insert on c1
for each row
begin
declare c_sql varchar(200);
set c_sql="insert into c2 values(?,?)";
set @c_sql=c_sql;
set @t1=3;
prepare stmt from @c_sql;
execute stmt using @t1,@t1;
deallocate prepare stmt;
end;
/
insert into c1 values(1,1);/
select * from c1 order by t1;/
select * from c2 order by t1;/

delete from c1;/
delete from c2;/
--echo ##同 36265412
--error 1336
create trigger cai_trig before insert on c1
for each row
begin
declare c_sql varchar(200);
set c_sql="create procedure cai_pro() begin set @qq=1; end;";
set @c_sql=c_sql;
prepare stmt from @c_sql;
execute stmt;
deallocate prepare stmt;
end;
/

insert into c1 values(1,1);/
select * from c1 order by t1;/
select * from c2 order by t1;/


--echo ##存在 iterate，exit
delete from c1;/
delete from c2;/
create trigger cai_trig before insert on c1
for each row
begin
declare sum int default 0;
declare i int default 1;
declare a int default 2;
loop1:loop
 set sum=sum+i;
 set i=i+1;
 if sum<2 then 
 insert into c2 values(1,1);
 iterate loop1;
 elseif sum>2 then
 insert into c2 values(2,2);
 leave loop1;
 end if;
end loop;
end;
/
insert into c1 values(1,1);/
select * from c1 order by t1;/
select * from c2 order by t1;/
drop trigger cai_trig;/


--echo ##存在嵌套子程序（存储过程，函数）
delete from c1;/
delete from c2;/
--error 1064
create trigger cai_trig before insert on c1
for each row
begin
procedure c_pro()
begin
insert into c1 values(1,1);
end;
insert into c1 values(2,2);
end;
/
--error 1064
create trigger cai_trig before insert on c1
for each row
begin
function c_pro() return int
begin
insert into c1 values(1,1);
return 1;
end;
insert into c1 values(2,2);
end;
/

--echo ## 存在其他子程序的调用
--echo ##子程序中存在游标等
delete from c1;/
delete from c2;/
insert into c1 values(9,9);/
create procedure cai_pro()
begin
declare sum int default 0;
declare i int default 1;
declare a int default 3;
repeat
set i=i+1;
set sum=sum+sum;
until i>a end repeat;
insert into c2 values(sum,sum);

begin
declare t1_1 int;
declare c_error condition for 1235;
declare continue handler for c_error set t1_1='a';
insert into c2 values(1,2);
end;

insert into c2 values(3+4-5*0.3,5||4);
insert into c2 values(null,length(1122));
insert into c2 values(1 and 2,3<4);
end;
/
create function cai_func() returns int
begin
call cai_pro();
begin
declare a_return int default 1;
insert into c2 values(2,2);
return a_return;
end;
end;
/
--error 1363
create trigger cai_trig before insert on c1
for each row
begin
declare a_return int;
set a_return=cai_func();
insert into c2 values(OLD.t1,NEW.t1);
end;
/
insert into c1 values(3,4);/
select * from c1 order by t1;/
select * from c2 order by t1;/

delete from c1;/
delete from c2;/
insert into c1 values(9,9);/
create trigger cai_trig before insert on c1
for each row
begin
call cai_pro();
end;
/
insert into c1 values(1,1);/
select * from c1 order by t1;/
select * from c2 order by t1;/
drop trigger cai_trig;/


--echo ##存在其他触发器的触发语句
--echo ##两个触发器逻辑互相为触发语句
create table c3(t1 int);/
create table c4(t1 int);/
create trigger cai_trig1 before insert on c3
for each row
insert into c4 values(3);
/
create trigger cai_trig2 before insert on c4
for each row
insert into c3 values(3);
/
--error 1442
insert into c3 values(1);/
select * from c3 order by t1;/
select * from c4 order by t1;/
drop trigger cai_trig1;/
drop trigger cai_trig2;/

--echo ##不互相为对方的触发语句
delete from c1;/
delete from c2;/
create trigger cai_trig1 before insert on c1
for each row
insert into c3 values(3);
/
create trigger cai_trig2 before insert on c3
for each row
insert into c4 values(3);
/
create trigger cai_trig3 before insert on c4
for each row
insert into c2 values(3,1);
/
insert into c1 values(1,2);/
select * from c1 order by t1;/
select * from c2 order by t1;/
select * from c3 order by t1;/
select * from c4 order by t1;/
drop trigger cai_trig1;/
drop trigger cai_trig2;/
drop trigger cai_trig3;/

--echo ##不同触发动作，同一基表
delete from c1;/
delete from c2;/
delete from c3;/
delete from c4;/
create trigger cai_trig1 before insert on c1
for each row
insert into c3 values(3);
/
create trigger cai_trig2 after insert on c1
for each row
insert into c4 values(3);
/
insert into c1 values(1,2);/
select * from c1 order by t1;/
select * from c2 order by t1;/
select * from c3 order by t1;/
select * from c4 order by t1;/
drop trigger cai_trig1;/
drop trigger cai_trig2;/

--echo ##触发方式(子程序中,私有嵌套子程序中,sql语句（dml+merge into）,execute immediate中)
drop procedure cai_pro;/
delete from c1;/
delete from c2;/
create trigger cai_trig before insert on c1
for each row
insert into c2 values(1,1);
/
create procedure cai_pro()
begin
insert into c1 values(7,7);
begin
declare t1 int;
declare t2 int;
declare done int default 0;
declare c_cursor cursor for select * from c1;
declare continue handler for not found set done=1;
open c_cursor;
while done!=1 do
 fetch c_cursor into t1,t2;
 if done!=1 then
 insert into c1 values(t1,t2);
 end if;
end while;
close c_cursor;
end;

begin
declare t1 int;
declare c_error condition for 1235;
declare continue handler for c_error set t1='a';
insert into c1 values(1,2);
insert into c1 values(2,3);
end;

begin
declare c_sql varchar(200);
set c_sql="insert into c1 values(?,?)";
set @c_sql=c_sql;
set @t1=3;
prepare stmt from @c_sql;
execute stmt using @t1,@t1;
deallocate prepare stmt;
end;
end;
/
call cai_pro();/
select * from c1 order by t1;/
select * from c2 order by t1;/
drop trigger cai_trig;/


--echo ##触发器特有场景
--echo ##对基表进行数据操作 
delete from c1;/
delete from c2;/
insert into c1 values(1,1);/
create trigger cai_trig before insert on c1
for each row
update c1 set t1=5;
/
--echo ##36285412,触发器逻辑为对基表操作，ob触发成功，mysql失败;
--error 1442
insert into c1 values(1,1);/
select * from c1 order by t1;/
select * from c2 order by t1;/
drop trigger cai_trig;/

--echo ##基表删除后重新触发触发器
delete from c1;/
delete from c2;/
create trigger cai_trig before insert on c1
for each row
insert into c2 values(1,1);
/
insert into c1 values(1,1);/
select * from c1 order by t1;/
select * from c2 order by t1;/
drop table c1;/
create table c1(t1 int,t2 int);/
insert into c1 values(1,1);/
select * from c1 order by t1;/
select * from c2 order by t1;/
--error 1360
drop trigger cai_trig;/

--echo ##基表存在主键，存在触发主键逻辑
create table c5(t1 int,primary key (t1));/
create table c6(t1 int);/
delete from c5;/
delete from c6;/
create trigger cai_trig before insert on c5
for each row
insert into c6 values(1);
/
insert into c5 values(1);/
--error 1062
insert into c5 values(1);/
select * from c5 order by t1;/
select * from c6 order by t1;/
drop trigger cai_trig;/

--echo ##基表创建触发器后，使用alter更改基表信息(修改/新增列。修改表名)
drop table c5;/
drop table c6;/
create table c5(t1 int,primary key (t1));/
create table c6(t1 int);/
delete from c5;/
delete from c6;/
create trigger cai_trig before insert on c5
for each row
insert into c6 values(1);
/
insert into c5 values(1);/
select * from c5 order by t1;/
select * from c6 order by t1;/
alter table c5 change t1 newt1 int;/
alter table c5 add t2 int;/
rename table c5 to newc5;/
insert into newc5 values(2,2);/
select * from newc5 order by newt1;/
select * from c6 order by t1;/
drop trigger cai_trig;/


