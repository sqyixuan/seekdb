--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

#owner: peihan.dph
##owner group: sql3

#
# Test PARTITION BY KEY(col_list)
#
#--disable_abort_on_error
# a) col_list is empty 
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (col1 INT, col2 DATE, col3 VARCHAR(20), col4 BIGINT, PRIMARY KEY (col1, col2, col3), UNIQUE KEY (col1, col2, col3) LOCAL)PARTITION BY KEY() PARTITIONS 4;

# b) col_list use all data types, with single column pk
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (col1 TINYINT, col2 DATE, col3 VARCHAR(20), col4 BIGINT, PRIMARY KEY (col1, col2, col3), UNIQUE KEY (col1, col2, col3) LOCAL)PARTITION BY KEY(col1) PARTITIONS 4;

