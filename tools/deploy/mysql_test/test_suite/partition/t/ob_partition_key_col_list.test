# c) partitioning key is part of multi-column primary key
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (col1 INT, col2 DATE, col3 VARCHAR(20), col4 BIGINT, PRIMARY KEY (col1, col2, col3), UNIQUE KEY (col1, col2, col3) LOCAL)PARTITION BY KEY(col1,col2,col3) PARTITIONS 4;

--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (col1 INT, col2 DATE, col3 VARCHAR(20), col4 BIGINT, PRIMARY KEY (col1, col2, col3), UNIQUE KEY (col1, col2, col3) LOCAL)PARTITION BY KEY(col1, col2) PARTITIONS 4;

--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (col1 INT, col2 DATE, col3 VARCHAR(20), col4 BIGINT, PRIMARY KEY (col1, col2, col3), UNIQUE KEY (col1, col2, col3) LOCAL)PARTITION BY KEY(col1, col3) PARTITIONS 4;

--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (col1 INT, col2 DATE, col3 VARCHAR(20), col4 BIGINT, PRIMARY KEY (col1, col2, col3), UNIQUE KEY (col1, col2, col3) LOCAL)PARTITION BY KEY(col2, col3) PARTITIONS 4;

--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (col1 INT, col2 DATE, col3 VARCHAR(20), col4 BIGINT, PRIMARY KEY (col1, col2, col3), UNIQUE KEY (col1, col2, col3) LOCAL)PARTITION BY KEY(col2) PARTITIONS 4;

--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (col1 INT, col2 DATE, col3 VARCHAR(20), col4 BIGINT, PRIMARY KEY (col1, col2, col3), UNIQUE KEY (col1, col2, col3) LOCAL)PARTITION BY KEY(col3) PARTITIONS 4;

--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (col1 INT, col2 DATE, col3 VARCHAR(20), col4 BIGINT, PRIMARY KEY (col1, col2, col3), UNIQUE KEY (col1, col2, col3) LOCAL)PARTITION BY KEY(col3,col2,col1) PARTITIONS 4;

--disable_warnings
drop table if exists t1;
--enable_warnings
--error 1652
CREATE TABLE t1 (col1 INT, col2 DATE, col3 VARCHAR(20), col4 BIGINT, PRIMARY KEY (col1, col2, col3), UNIQUE KEY (col1, col2, col3) LOCAL)PARTITION BY KEY(col3,col2,col2,col2) PARTITIONS 4;

# d) invalid input in key()
--disable_warnings
drop table if exists t1;
--enable_warnings
--error 1064
CREATE TABLE t1 (col1 INT, col2 DATE, col3 VARCHAR(20), col4 BIGINT, PRIMARY KEY (col1, col2, col3), UNIQUE KEY (col1, col2, col3) LOCAL)PARTITION BY KEY(1) PARTITIONS 4;

--error 1064
CREATE TABLE t1 (col1 INT, col2 DATE, col3 VARCHAR(20), col4 BIGINT, PRIMARY KEY (col1, col2, col3), UNIQUE KEY (col1, col2, col3) LOCAL)PARTITION BY KEY(1+1) PARTITIONS 4;

--error 1064
CREATE TABLE t1 (col1 INT, col2 DATE, col3 VARCHAR(20), col4 BIGINT, PRIMARY KEY (col1, col2, col3), UNIQUE KEY (col1, col2, col3) LOCAL)PARTITION BY KEY('abc') PARTITIONS 4;

--error 1064
CREATE TABLE t1 (col1 INT, col2 DATE, col3 VARCHAR(20), col4 BIGINT, PRIMARY KEY (col1, col2, col3), UNIQUE KEY (col1, col2, col3) LOCAL)PARTITION BY KEY(length('abc')) PARTITIONS 4;

--error 1064
CREATE TABLE t1 (col1 INT, col2 DATE, col3 VARCHAR(20), col4 BIGINT, PRIMARY KEY (col1, col2, col3), UNIQUE KEY (col1, col2, col3) LOCAL)PARTITION BY KEY('-') PARTITIONS 4;

--error 1064
CREATE TABLE t1 (col1 INT, col2 DATE, col3 VARCHAR(20), col4 BIGINT, PRIMARY KEY (col1, col2, col3), UNIQUE KEY (col1, col2, col3) LOCAL)PARTITION BY KEY('123') PARTITIONS 4;

--error 1064
CREATE TABLE t1 (col1 INT, col2 DATE, col3 VARCHAR(20), col4 BIGINT, PRIMARY KEY (col1, col2, col3), UNIQUE KEY (col1, col2, col3) LOCAL)PARTITION BY KEY(col1+col2) PARTITIONS 4;

--error 1064
CREATE TABLE t1 (col1 INT, col2 DATE, col3 VARCHAR(20), col4 BIGINT, PRIMARY KEY (col1, col2, col3), UNIQUE KEY (col1, col2, col3) LOCAL)PARTITION BY KEY(col1 + 1) PARTITIONS 4;

--disable_warnings
drop table if exists t1;
--enable_warnings
--error 1652
CREATE TABLE t1 (col1 INT, col2 DATE, col3 VARCHAR(20), col4 BIGINT, PRIMARY KEY (col1, col2, col3), UNIQUE KEY (col1, col2, col3) LOCAL)PARTITION BY KEY(col1,col1) PARTITIONS 4;

--disable_warnings
drop table if exists t1;
--enable_warnings
--error 1652
CREATE TABLE t1 (col1 INT, col2 DATE, col3 VARCHAR(20), col4 BIGINT, PRIMARY KEY (col1, col2, col3), UNIQUE KEY (col1, col2, col3) LOCAL)PARTITION BY KEY(col2,col1,col2) PARTITIONS 4;

--disable_warnings
drop table if exists t1;
--enable_warnings
--error 1652
CREATE TABLE t1 (col1 INT, col2 DATE, col3 VARCHAR(20), col4 BIGINT, PRIMARY KEY (col1, col2, col3), UNIQUE KEY (col1, col2, col3) LOCAL)PARTITION BY KEY(col3,col3,col3,col3) PARTITIONS 4;


