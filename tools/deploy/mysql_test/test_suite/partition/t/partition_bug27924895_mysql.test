# owner: yibo.tyf
#tags: optimizer
# owner group: SQL1
# tags: partition

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
drop table if exists t1,t2;
--enable_warnings

create TABLE t1(c1 int(11) not null, c3 varchar(32) not null) partition by key(c1,c3) partitions 4;

create TABLE t2(c1 int(11) not null, c2 int(11) not null, c3 varchar(32) not null, c4 int)
partition by range columns(c2, c4) 
subpartition by key(c1,c3) subpartitions 4 
(partition p0 values less than (3,43), partition p1 values less than (MAXVALUE, MAXVALUE));

--result_format 4
--explain_protocol 2
insert into t1 values (2, '4.0');
insert into t1 values (2, 4.0);
select * from t1 partition (p0);
select * from t1 partition (p2);

insert into t2 values (2, 0, '4.0', 2);
insert into t2 values (2, 0, 4.0, 2);
select * from t2 partition (p0sp0);
select * from t2 partition (p0sp2);

drop table t1,t2;