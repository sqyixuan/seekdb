#owner: peihan.dph
##owner group: sql3
# tags: optimizer

--source mysql_test/include/index_quick_major.inc
use test;

--disable_warnings
drop table if exists t1;
drop table if exists t2;
drop table if exists t3;
drop table if exists t4;
drop table if exists b1;
--enable_warnings

# 创建普通的range hash分区表，是否能正常创建, show create table是否正确
# 查询range hash分区表，是否能走到指定的分区, 插入是否正常
# range hash分区创建索引，是否能正常创建，并且能正常使用, 使用唯一索引的情况。索引直接写在create table里面的情况
# 各种特殊写法的range hash分区表。例如不给定subpartitions的数目。给定range partition的数目是否能正常使用
# range columns分区是否支持 
# 不同分区键的类型是否支持
# 分区表的各种内部表是否正常


create table t1 (c1 int, c2 int, c3 int) partition by range(c1) subpartition by hash(c2) subpartitions 5 (partition p0 values less than(10), partition p1 values less than(100), partition p2 values less than(1000));

--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;

insert into t1 values(1, 0, 100);

select * from t1 partition(p0sp0);

explain select * from t1 where c1 = 1 and c2 = 0;
explain select * from t1 where c2 = 0;
explain select * from t1 where c2 = 0 or c2 = 1;
explain select * from t1 where c2 in (0, 1);
explain select * from t1 where c1 > 1 and c1 < 10 and c2 = 0;

select * from t1 where c1 = 1 and c2 = 0;
select * from t1 where c2 = 0;
select * from t1 where c2 = 0 or c2 = 1;
select * from t1 where c2 in (0, 1);
select * from t1 where c1 > 1 and c1 < 10 and c2 = 0;



create index i1 on t1 (c3) local;

call dbms_stats.gather_table_stats('TEST', 't1');
let $index_name=i1;
--source mysql_test/include/index_status_check.inc


create table t2 (c1 int, c2 int, c3 int, primary key(c1,c2), index i2(c3) local) partition by range(c1) subpartition by hash(c2) subpartitions 5 (partition p0 values less than(10), partition p1 values less than(100), partition p2 values less than(1000));
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t2;

# 全局索引打开以后，默认unique是全局索引，所以这个case能过 peihan.dph
create table t3 (c1 int, c2 int, c3 int, primary key(c1,c2), unique (c3) global) partition by range(c1) subpartition by hash(c2) subpartitions 5 (partition p0 values less than(10), partition p1 values less than(100), partition p2 values less than(1000));

# 这种写法暂时是有问题的，mysql不允许这种写法
create table t4 (c1 int, c2 int, c3 int) partition by range(c1) subpartition by hash(c2) partitions 3 (partition p0 values less than(10), partition p1 values less than(100), partition p2 values less than(MAXVALUE));

create table b1 (c1 int, c2 int, c3 int) partition by range columns(c1,c2) subpartition by hash(c2) subpartitions 5 (partition p0 values less than(10, 10), partition p1 values less than(100, 10), partition p2 values less than(1000, 10));
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table b1;

--error 1493
create table t1(c1 int, c2 int) partition by range(c1)
  subpartition by hash(c2)
  subpartitions 4
(partition TAB_PARTOTION_01 values less than (950000),
 partition TAB_PARTOTION_02 values less than (900000),
 partition TAB_PARTOTION_03 values less than (1350000),
 partition TAB_PARTOTION_OTHER values less THAN (MAXVALUE));
