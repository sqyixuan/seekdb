# a-2, valid test, test operators in hash expr
--disable_warnings
drop table if exists t1;
--enable_warnings
let $expr = col1 + 1;
eval CREATE TABLE t1 (col1 INT, col2 DATE, col3 VARCHAR(20), col4 BIGINT, PRIMARY KEY (col1, col2, col3), UNIQUE KEY (col1, col2, col3) LOCAL)PARTITION BY HASH( $expr ) PARTITIONS 4;
insert into t1 values(1,'2016-01-01', 'a', 1);
insert into t1 values(2,'2016-01-02', 'b', 1);
--replace_regex /.*, (partitions)/             \1/
explain basic select * from t1 where col1 + 1  = 100;
--replace_regex /.*, (partitions)/             \1/
explain basic select * from t1 where col1 + 1 =1;

--disable_warnings
drop table if exists t1;
--enable_warnings
let $expr = 2 - col2;
eval CREATE TABLE t1 (col1 INT, col2 DATE, col3 VARCHAR(20), col4 BIGINT, PRIMARY KEY (col1, col2, col3), UNIQUE KEY (col1, col2, col3) LOCAL)PARTITION BY HASH( $expr ) PARTITIONS 4;
insert into t1 values(1,'2016-01-01', 'a', 1);
insert into t1 values(2,'2016-01-02', 'b', 1);
--replace_regex /.*, (partitions)/             \1/
explain basic select * from t1 where 2 - col2  = 100;
--replace_regex /.*, (partitions)/             \1/
explain basic select * from t1 where 2 - col2 =1;

--disable_warnings
drop table if exists t1;
--enable_warnings
let $expr = col1 * 3;
eval CREATE TABLE t1 (col1 INT, col2 DATE, col3 VARCHAR(20), col4 BIGINT, PRIMARY KEY (col1, col2, col3), UNIQUE KEY (col1, col2, col3) LOCAL)PARTITION BY HASH( $expr ) PARTITIONS 4;
insert into t1 values(1,'2016-01-01', 'a', 1);
insert into t1 values(2,'2016-01-02', 'b', 1);
--replace_regex /.*, (partitions)/             \1/
explain basic select * from t1 where col1 * 3  = 100;
--replace_regex /.*, (partitions)/             \1/
explain basic select * from t1 where col1 * 3 =1;

--disable_warnings
drop table if exists t1;
--enable_warnings
let $expr = col1 / 4;
--error ER_PARTITION_FUNCTION_IS_NOT_ALLOWED
eval CREATE TABLE t1 (col1 INT, col2 DATE, col3 VARCHAR(20), col4 BIGINT, PRIMARY KEY (col1, col2, col3), UNIQUE KEY (col1, col2, col3) LOCAL)PARTITION BY HASH( $expr ) PARTITIONS 4;


# a-3, valid test, test combination of functions and operators
--disable_warnings
drop table if exists t1;
--enable_warnings
let $expr = abs(col1) + floor(col1) ;
eval CREATE TABLE t1 (col1 INT, col2 DATE, col3 VARCHAR(20), col4 INT, PRIMARY KEY (col1, col2, col3), UNIQUE KEY (col1, col2, col3) LOCAL)PARTITION BY HASH( $expr ) PARTITIONS 4;
insert into t1 values(1,'2016-01-01', 'a', 1);
insert into t1 values(2,'2016-01-02', 'b', 1);
--replace_regex /.*, (partitions)/             \1/
explain basic select * from t1 where abs(col1) + floor(col1)  = 100;
--replace_regex /.*, (partitions)/             \1/
explain basic select * from t1 where abs(col1) + floor(col1) =1;

--disable_warnings
drop table if exists t1;
--enable_warnings
let $expr = (col1 % 4) - extract(year from col2);
eval CREATE TABLE t1 (col1 INT, col2 DATE, col3 VARCHAR(20), col4 BIGINT, PRIMARY KEY (col1, col2, col3), UNIQUE KEY (col1, col2, col3) LOCAL)PARTITION BY HASH( $expr ) PARTITIONS 4;
insert into t1 values(1,'2016-01-01', 'a', 1);
insert into t1 values(2,'2016-01-02', 'b', 1);
--replace_regex /.*, (partitions)/             \1/
explain basic select * from t1 where (col1 % 4) - extract(year from col2)  = 100;
--replace_regex /.*, (partitions)/             \1/
explain basic select * from t1 where (col1 % 4) - extract(year from col2) =1;

