# b-1, invalid test, test return non-int return code of expr
--disable_warnings
drop table if exists t1;
--enable_warnings
let $expr = col1 + 1.5;
--error 1697
eval CREATE TABLE t1 (col1 INT, col2 DATE, col3 VARCHAR(20), col4 BIGINT, PRIMARY KEY (col1, col2, col3), UNIQUE KEY (col1, col2, col3) LOCAL)PARTITION BY HASH( $expr ) PARTITIONS 4;

--disable_warnings
drop table if exists t1;
--enable_warnings
let $expr = col2;
--error 1659
eval CREATE TABLE t1 (col1 INT, col2 DATE, col3 VARCHAR(20), col4 BIGINT, PRIMARY KEY (col1, col2, col3), UNIQUE KEY (col1, col2, col3) LOCAL)PARTITION BY HASH( $expr ) PARTITIONS 4;

--disable_warnings
drop table if exists t1;
--enable_warnings
let $expr = col3;
--error 1659
eval CREATE TABLE t1 (col1 INT, col2 DATE, col3 VARCHAR(20), col4 BIGINT, PRIMARY KEY (col1, col2, col3), UNIQUE KEY (col1, col2, col3) LOCAL)PARTITION BY HASH( $expr ) PARTITIONS 4;

# b-2. invalid test, test now-allowed hash expression
--disable_warnings
drop table if exists t1;
--enable_warnings
let $expr=unix_timestamp( '2015-01-01' );
--error 1486
eval CREATE TABLE t1 (col1 INT, col2 DATE, col3 VARCHAR(20), col4 BIGINT, PRIMARY KEY (col1, col2, col3), UNIQUE KEY (col1, col2, col3) LOCAL)PARTITION BY HASH( $expr ) PARTITIONS 4;

--disable_warnings
drop table if exists t1;
--enable_warnings
let $expr=1;
--error 1486
eval CREATE TABLE t1 (col1 INT, col2 DATE, col3 VARCHAR(20), col4 BIGINT, PRIMARY KEY (col1, col2, col3), UNIQUE KEY (col1, col2, col3) LOCAL)PARTITION BY HASH( $expr ) PARTITIONS 4;

--disable_warnings
drop table if exists t1;
--enable_warnings
let $expr = 1 or 0;
--error 1486
eval CREATE TABLE t1 (col1 INT, col2 DATE, col3 VARCHAR(20), col4 BIGINT, PRIMARY KEY (col1, col2, col3), UNIQUE KEY (col1, col2, col3) LOCAL)PARTITION BY HASH( $expr ) PARTITIONS 4;


# c-1, valid test, test complex expr
--disable_warnings
drop table if exists t1;
--enable_warnings
let $expr = abs(col1) + (col1 % 4) - floor(col1 + 1) * 123;
eval CREATE TABLE t1 (col1 INT, col2 DATE, col3 VARCHAR(20), col4 BIGINT, PRIMARY KEY (col1, col2, col3), UNIQUE KEY (col1, col2, col3) LOCAL)PARTITION BY HASH( $expr ) PARTITIONS 4;
insert into t1 values(1,'2016-01-01', 'a', 1);
insert into t1 values(2,'2016-01-02', 'b', 1);
--replace_regex /.*, (partitions)/             \1/
explain basic select * from t1 where abs(col1) + (col1 % 4) - floor(col1 + 1) * 123  = 100;
--replace_regex /.*, (partitions)/             \1/
explain basic select * from t1 where abs(col1) + (col1 % 4) - floor(col1 + 1) * 123 =1;


# d-1, valid test, test expr with multiple columns in hash expr
--disable_warnings
drop table if exists t1;
--enable_warnings
let $expr = col1 + col2 + col3;
eval CREATE TABLE t1 (col1 INT, col2 TINYINT, col3 SMALLINT, col4 BIGINT, PRIMARY KEY (col1, col2, col3), UNIQUE KEY (col1, col2, col3) LOCAL)PARTITION BY HASH( $expr ) PARTITIONS 4;
insert into t1 values(1, 1, 1, 1);
insert into t1 values(2, 2, 2, 1);
--replace_regex /.*, (partitions)/             \1/
explain basic select * from t1 where col1 + col2 + col3  = 100;
--replace_regex /.*, (partitions)/             \1/
explain basic select * from t1 where col1 + col2 + col3 =1;


