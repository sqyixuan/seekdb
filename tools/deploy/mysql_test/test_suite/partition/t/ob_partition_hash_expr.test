--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

#owner : peihan.dph
#owner group : sql3
# tags: optimizer

#--disable_abort_on_error
#
# Test PARTITION BY HASH(expr)
#
#--disable_abort_on_error
# a-1, valid test, test functions in hash expr
--disable_warnings
drop table if exists t1;
--enable_warnings
let $expr = abs(col1);
eval CREATE TABLE t1 (col1 INT, col2 DATE, col3 VARCHAR(20), col4 BIGINT, PRIMARY KEY (col1, col2, col3), UNIQUE KEY (col1, col2, col3) LOCAL)PARTITION BY HASH( $expr ) PARTITIONS 4;
insert into t1 values(1,'2016-01-01', 'a', 1);
insert into t1 values(2,'2016-01-02', 'b', 1);
--replace_regex /.*, (partitions)/             \1/
explain basic select * from t1 where abs(col1)  = 100;
--replace_regex /.*, (partitions)/             \1/
explain basic select * from t1 where abs(col1) =1;

--disable_warnings
drop table if exists t1;
--enable_warnings
let $expr=floor(col1);
eval CREATE TABLE t1 (col1 INT, col2 DATE, col3 VARCHAR(20), col4 BIGINT, PRIMARY KEY (col1, col2, col3), UNIQUE KEY (col1, col2, col3) LOCAL)PARTITION BY HASH( $expr ) PARTITIONS 4;
insert into t1 values(1,'2016-01-01', 'a', 1);
insert into t1 values(2,'2016-01-02', 'b', 1);
--replace_regex /.*, (partitions)/             \1/
explain basic select * from t1 where floor(col1)  = 100;
--replace_regex /.*, (partitions)/             \1/
explain basic select * from t1 where floor(col1) =1;

--disable_warnings
drop table if exists t1;
--enable_warnings
let $expr=ceil(col1);
eval CREATE TABLE t1 (col1 INT, col2 DATE, col3 VARCHAR(20), col4 BIGINT, PRIMARY KEY (col1, col2, col3), UNIQUE KEY (col1, col2, col3) LOCAL)PARTITION BY HASH( $expr ) PARTITIONS 4;
insert into t1 values(1,'2016-01-01', 'a', 1);
insert into t1 values(2,'2016-01-02', 'b', 1);
--replace_regex /.*, (partitions)/             \1/
explain basic select * from t1 where ceil(col1)  = 100;
--replace_regex /.*, (partitions)/             \1/
explain basic select * from t1 where ceil(col1) =1;

--disable_warnings
drop table if exists t1;
--enable_warnings
let $expr=col1 % 4;
eval CREATE TABLE t1 (col1 INT, col2 DATE, col3 VARCHAR(20), col4 BIGINT, PRIMARY KEY (col1, col2, col3), UNIQUE KEY (col1, col2, col3) LOCAL)PARTITION BY HASH( $expr ) PARTITIONS 4;
insert into t1 values(1,'2016-01-01', 'a', 1);
insert into t1 values(2,'2016-01-02', 'b', 1);
--replace_regex /.*, (partitions)/             \1/
explain basic select * from t1 where col1 % 4  = 100;
--replace_regex /.*, (partitions)/             \1/
explain basic select * from t1 where col1 % 4 =1;

--disable_warnings
drop table if exists t1;
--enable_warnings
let $expr=extract( year from col2);
eval CREATE TABLE t1 (col1 INT, col2 DATE, col3 VARCHAR(20), col4 BIGINT, PRIMARY KEY (col1, col2, col3), UNIQUE KEY (col1, col2, col3) LOCAL)PARTITION BY HASH( $expr ) PARTITIONS 4;
insert into t1 values(1,'2016-01-01', 'a', 1);
insert into t1 values(2,'2016-01-02', 'b', 1);
--replace_regex /.*, (partitions)/             \1/
explain basic select * from t1 where extract( year from col2)  = 100;
--replace_regex /.*, (partitions)/             \1/
explain basic select * from t1 where extract( year from col2) =1;

--disable_warnings
drop table if exists t1;
--enable_warnings
let $expr=extract( week from col2);
--error ER_WRONG_EXPR_IN_PARTITION_FUNC_ERROR
eval CREATE TABLE t1 (col1 INT, col2 DATE, col3 VARCHAR(20), col4 BIGINT, PRIMARY KEY (col1, col2, col3), UNIQUE KEY (col1, col2, col3) LOCAL)PARTITION BY HASH( $expr ) PARTITIONS 4;
