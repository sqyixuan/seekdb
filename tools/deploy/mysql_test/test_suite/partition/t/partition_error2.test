#owner: peihan.dph
##owner group: sql3

# description:
#
# test of range partition 

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
drop database if exists hualong;
--enable_warnings
create database hualong;
use hualong;

--error ER_VALUES_IS_NOT_INT_TYPE_ERROR
create table range_table(c1 int) partition by range(c1) (partition p0 values less than('1'));

--error ER_WRONG_TYPE_COLUMN_VALUE_ERROR
create table range_table(c1 datetime) partition by range columns(c1) (partition p0 values less than (11));

--error ER_FIELD_TYPE_NOT_ALLOWED_AS_PARTITION_FIELD
create table range_table(c1 date) partition by range(c1) (partition p0 values less than (123456));

##const expr
--error ER_WRONG_EXPR_IN_PARTITION_FUNC_ERROR
create table range_table(c1 int) partition by range(123) (partition p0 values less than (123456));

## value cross
--error ER_PARTITION_CONST_DOMAIN_ERROR
CREATE TABLE tu (c1 BIGINT UNSIGNED)
PARTITION BY RANGE(c1) (
PARTITION p0 VALUES LESS THAN (-2),
PARTITION p1 VALUES LESS THAN (3),
PARTITION p2 VALUES LESS THAN (5),
PARTITION p3 VALUES LESS THAN (10 - 4),
PARTITION p4 VALUES LESS THAN (MAXVALUE)
);

--error ER_PARTITION_CONST_DOMAIN_ERROR
create table t1 (a bigint unsigned) partition by range (a) (partition p0 values less than (-1));

##### value contain invalid function
#bit operator
--error ER_PARTITION_FUNCTION_IS_NOT_ALLOWED
create table t1 (a int) partition by range (a) (partition p0 values less than (1 & 1));
--error ER_PARTITION_FUNCTION_IS_NOT_ALLOWED
create table t1 (a int) partition by range (a) (partition p0 values less than (1 | 1));
--error ER_PARTITION_FUNCTION_IS_NOT_ALLOWED
create table t1 (a int) partition by range (a) (partition p0 values less than (1 ^ 1));
--error ER_PARTITION_FUNCTION_IS_NOT_ALLOWED
create table t1 (a int) partition by range (a) (partition p0 values less than (1 << 1));
--error ER_PARTITION_FUNCTION_IS_NOT_ALLOWED
create table t1 (a int) partition by range (a) (partition p0 values less than (1 >> 1));
--error ER_PARTITION_FUNCTION_IS_NOT_ALLOWED
create table t1 (a int) partition by range (a) (partition p0 values less than (~1));
#bool operator
--error ER_PARTITION_FUNCTION_IS_NOT_ALLOWED
create table t1 (a int) partition by range (a) (partition p0 values less than ((1 = 1)));
--error ER_PARTITION_FUNCTION_IS_NOT_ALLOWED
create table t1 (a int) partition by range (a) (partition p0 values less than ((1 != 1)));
--error ER_PARTITION_FUNCTION_IS_NOT_ALLOWED
create table t1 (a int) partition by range (a) (partition p0 values less than ((1 <= 1)));
--error ER_PARTITION_FUNCTION_IS_NOT_ALLOWED
create table t1 (a int) partition by range (a) (partition p0 values less than ((1 >= 1)));
--error ER_PARTITION_FUNCTION_IS_NOT_ALLOWED
create table t1 (a int) partition by range (a) (partition p0 values less than ((1 < 1)));
--error ER_PARTITION_FUNCTION_IS_NOT_ALLOWED
create table t1 (a int) partition by range (a) (partition p0 values less than ((1 > 1)));


##function return null
--error ER_NULL_IN_VALUES_LESS_THAN
CREATE TABLE t1 (a date) PARTITION BY RANGE (TO_DAYS(a)) (PARTITION p311 VALUES LESS THAN (TO_DAYS('abc')));

CREATE TABLE tn (c1 INT) PARTITION BY RANGE(1 DIV c1) (PARTITION p0 VALUES LESS THAN (100),PARTITION p1 VALUES LESS THAN(200));
INSERT INTO tn VALUES (0);
INSERT INTO tn VALUES (1);
INSERT INTO tn VALUES (NULL);
SELECT * FROM tn partition(p0);
SELECT * FROM tn partition(p1);

#SET sql_mode='STRICT_ALL_TABLES,ERROR_FOR_DIVISION_BY_ZERO';
#--error ER_DIVISION_BY_ZERO
#INSERT INTO tn VALUES (NULL), (0), (1);

#SET sql_mode='NO_UNSIGNED_SUBTRACTION'
#should not fail
#CREATE TABLE tu (c1 BIGINT UNSIGNED) PARTITION BY RANGE(c1 - 10) ( PARTITION p0 VALUES LESS THAN (-5), PARTITION p1 VALUES LESS THAN (0),PARTITION p2 VALUES LESS THAN (5),PARTITION p3 VALUES LESS THAN (10 - 4),PARTITION p4 VALUES LESS THAN (MAXVALUE));

CREATE TABLE tu2 (c1 BIGINT UNSIGNED) PARTITION BY RANGE(c1 - 10) ( PARTITION p0 VALUES LESS THAN (2), PARTITION p1 VALUES LESS THAN (3),PARTITION p2 VALUES LESS THAN (5),PARTITION p3 VALUES LESS THAN (10 - 4),PARTITION p4 VALUES LESS THAN (MAXVALUE));
--error ER_DATA_OUT_OF_RANGE
insert into tu2 values(9);






drop database hualong;
