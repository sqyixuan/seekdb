--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: yuchen.wyc
#owner group: sql4
#description: Test character set related things with partition

#
# Test for character set related things in combination
# with the partition storage engine
# 
#-- source include/have_partition.inc

--disable_warnings
drop table if exists t1;
--enable_warnings

set names utf8mb4;
create table t1 (s1 int)
  partition by hash (s1);
#    (partition c values in (1),
#     partition Ç values in (3));
insert into t1 values (1),(3);
select * from t1;
#flush tables;
set names utf8;
select * from t1;
drop table t1;

--error ER_PARTITION_FUNCTION_IS_NOT_ALLOWED
create table t1 (a varchar(1), primary key (a))
partition by hash (cast(hex(a) as unsigned));
#(partition p1 values in (65));
#insert into t1 values ('A');
#replace into t1 values ('A');
#drop table t1;

## Test partition values in gbk
CREATE TABLE t1 (
city varchar(10) NOT NULL,
id int
) DEFAULT CHARSET = gbk
partition by list columns(city,id)
(partition p0 values in (('北京',1),('上海',2)),
partition p1 values in (('成都',4),('天津',3)));
alter table t1 add partition (partition p3 values in (('湖',4)));
drop table t1;

## Test partition values in gbk
CREATE TABLE t1 (
city varchar(10) NOT NULL,
id int
) DEFAULT CHARSET = gbk
partition by range columns(id, city)
(partition p0 values less than (1, '北京'),
partition p1 values less than (2, '上海'),
partition p2 values less than (3, '成都'),
partition p3 values less than (4, '天津'));
alter table t1 add partition (partition p4 values less than (5, '湖'));
drop table t1;

