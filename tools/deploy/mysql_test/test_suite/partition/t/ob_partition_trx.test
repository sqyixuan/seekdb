
#owner: yibo.tyf
#owner group: SQL1
## -- Test transactions with partition

--disable_warnings
drop table if exists t1,t2,t3;
--enable_warnings

connect(conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect(conn2,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);

## - Test partition by hash
create table t1(c1 int primary key, c2 int) partition by hash(c1 % 4) partitions 4;
insert into t1 values(0,0),(4,4);
insert into t1 values(1,1),(5,5);
insert into t1 values(2,2),(6,6);
insert into t1 values(3,3),(7,7);

# Operate same single partition, same row
#connection conn1;
#set autocommit = 0;
#update t1 set c2 = c2 + 10 where c1 = 1;
#connection conn2;
#set autocommit = 0;
#update t1 set c2 = c2 + 20 where c1 = 1;
#connection conn1;
#commit;
#connection conn2;
#commit;
#connection default;
#select * from t1;

# Operate same single partition, different row
connection conn1;
update t1 set c2 = c2 + 10 where c1 = 1;
connection conn2;
update t1 set c2 = c2 + 20 where c1 = 5;
connection conn1;
commit;
connection conn2;
commit;
connection default;
select * from t1;

# Operate diferent single partition
connection conn1;
update t1 set c2 = c2 + 10 where c1 = 1;
connection conn2;
update t1 set c2 = c2 + 20 where c1 = 2;
connection conn1;
commit;
connection conn2;
commit;
connection default;
select * from t1;

# Operate same multiple partitions, same records
#connection conn1;
#update t1 set c2 = c2 + 10 where c1 = 1;
#update t1 set c2 = c2 + 10 where c1 = 2;
#connection conn2;
#update t1 set c2 = c2 + 20 where c1 = 1;
#update t1 set c2 = c2 + 20 where c1 = 2;
#connection conn1;
#commit;
#connection conn2;
#commit;
#connection default;
#select * from t1;

# Operate same multiple partitions, different records
connection conn1;
update t1 set c2 = c2 + 10 where c1 = 1;
update t1 set c2 = c2 + 10 where c1 = 2;
connection conn2;
update t1 set c2 = c2 + 20 where c1 = 5;
update t1 set c2 = c2 + 20 where c1 = 6;
connection conn1;
commit;
connection conn2;
commit;
connection default;
select * from t1;

# Operate different multiple partitions
connection conn1;
update t1 set c2 = c2 + 10 where c1 = 1;
update t1 set c2 = c2 + 10 where c1 = 2;
connection conn2;
update t1 set c2 = c2 + 20 where c1 = 3;
update t1 set c2 = c2 + 20 where c1 = 4;
connection conn1;
commit;
connection conn2;
commit;
connection default;
select * from t1;

# Operate different multiple partitions
connection conn1;
update t1 set c2 = c2 + 10 where c1 = 1;
update t1 set c2 = c2 + 10 where c1 = 2;
connection conn2;
update t1 set c2 = c2 + 20 where c1 = 6;
update t1 set c2 = c2 + 20 where c1 = 7;
connection conn1;
commit;
connection conn2;
commit;
connection default;
select * from t1;

drop table t1;

## - Test partition by range
create table t1(c1 int primary key, c2 int) partition by range(c1) (partition p0 values less than 10, partition p1 values less then MAXVALUE);
insert into t1 values(1,1),(2,2),(3,3),(4,4);
insert into t1 values(10,10),(11,11),(12,12),(13,13);

# Operate same single partition, same row
#connection conn1;
#set autocommit = 0;
#update t1 set c2 = c2 + 10 where c1 = 1;
#connection conn2;
#set autocommit = 0;
#update t1 set c2 = c2 + 20 where c1 = 1;
#connection conn1;
#commit;
#connection conn2;
#commit;
#connection default;
#select * from t1;

# Operate same single partition, different row
connection conn1;
update t1 set c2 = c2 + 10 where c1 = 1;
connection conn2;
update t1 set c2 = c2 + 20 where c1 = 5;
connection conn1;
commit;
connection conn2;
commit;
connection default;
select * from t1;

# Operate diferent single partition
connection conn1;
update t1 set c2 = c2 + 10 where c1 = 1;
connection conn2;
update t1 set c2 = c2 + 20 where c1 = 2;
connection conn1;
commit;
connection conn2;
commit;
connection default;
select * from t1;

# Operate same multiple partitions, same records
#connection conn1;
#update t1 set c2 = c2 + 10 where c1 = 1;
#update t1 set c2 = c2 + 10 where c1 = 2;
#connection conn2;
#update t1 set c2 = c2 + 20 where c1 = 1;
#update t1 set c2 = c2 + 20 where c1 = 2;
#connection conn1;
#commit;
#connection conn2;
#commit;
#connection default;
#select * from t1;

# Operate same multiple partitions, different records
connection conn1;
update t1 set c2 = c2 + 10 where c1 = 1;
update t1 set c2 = c2 + 10 where c1 = 2;
connection conn2;
update t1 set c2 = c2 + 20 where c1 = 5;
update t1 set c2 = c2 + 20 where c1 = 6;
connection conn1;
commit;
connection conn2;
commit;
connection default;
select * from t1;

# Operate different multiple partitions
connection conn1;
update t1 set c2 = c2 + 10 where c1 = 1;
update t1 set c2 = c2 + 10 where c1 = 2;
connection conn2;
update t1 set c2 = c2 + 20 where c1 = 3;
update t1 set c2 = c2 + 20 where c1 = 4;
connection conn1;
commit;
connection conn2;
commit;
connection default;
select * from t1;

# Operate different multiple partitions
connection conn1;
update t1 set c2 = c2 + 10 where c1 = 1;
update t1 set c2 = c2 + 10 where c1 = 2;
connection conn2;
update t1 set c2 = c2 + 20 where c1 = 6;
update t1 set c2 = c2 + 20 where c1 = 7;
connection conn1;
commit;
connection conn2;
commit;
connection default;
select * from t1;

drop table t1;

