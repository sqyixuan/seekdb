#owner: xiaoyi.xy
#owner group: sql1

## Test consistency among equivalent partition definitions

--disable_warnings
drop table if exists t1,t2,t3;
--enable_warnings

## partition by hash subpartition by range( 2 subs) partitions 1 <=> partition by range(2 subs)
create table t1(c1 int primary key, c2 int) partition by hash subpartition by range(c1) (subpartition p0 values less then 10, subpartition p1 values less then maxvalue) partitions 1;
create table t2(c1 int primary key, c2 int) partition by range(c1) (partition p0 values less then 10, partition p1 values less then maxvalue);
insert into t1 values(1,1),(2,2),(3,3),(4,4);
insert into t1 values(11,11),(22,22),(33,33),(44,44);
insert into t2 values(1,1),(2,2),(3,3),(4,4);
insert into t2 values(11,11),(22,22),(33,33),(44,44);
select * from t1 partition(p0);
select * from t2 partition(p0);
select * from t1 partition(p1);
select * from t2 partition(p1);
drop table t1,t2;

## partition by hash subpartition by range( 1 sub) partitions 4 <=> partition by range(1 sub) partitions 4
create table t1(c1 int primary key, c2 int) partition by hash subpartition by range(c1) (subpartition p1 values less then maxvalue) partitions 4;
create table t2(c1 int primary key, c2 int) partition by hash(c1) partitions 4;
insert into t1 values(1,1);
insert into t1 values(2,2);
insert into t1 values(3,3);
insert into t1 values(4,4);
insert into t1 values(11,11);
insert into t1 values(22,22);
insert into t1 values(33,33);
insert into t1 values(44,44);
insert into t2 values(1,1);
insert into t2 values(2,2);
insert into t2 values(3,3);
insert into t2 values(4,4);
insert into t2 values(11,11);
insert into t2 values(22,22);
insert into t2 values(33,33);
insert into t2 values(44,44);
select * from t1 partition(p0);
select * from t2 partition(p0);
select * from t1 partition(p1);
select * from t2 partition(p1);
select * from t1 partition(p2);
select * from t2 partition(p2);
select * from t1 partition(p3);
select * from t2 partition(p3);
drop table t1,t2;

## test single value range partitions
create table t1(c1 int primary key, c2 int) partition by range(c1) (partition p0 values less then 10, partition p0 values less then 11, partition p0 values less then 12, partition p1 values less then maxvalue);
insert into t1 values(1,1),(2,2),(3,3),(4,4);
insert into t1 values(10,10);
insert into t1 values(11,11);
insert into t1 values(12,12);
insert into t1 values(11,11),(22,22),(33,33),(44,44);
select * from t1 partition(p0);
select * from t1 partition(p1);
select * from t1 partition(p2);
select * from t1 partition(p3);


