#owner: yibo.tyf
#owner group:sql1

--disable_warnings
drop table if exists t1, t2;
--enable_warnings

create table t1(c1 date, c2 int) partition by range(year(c1)) (partition p0 values less than (1988), partition p1 values less than (2188));

insert into t1 values('1978-12-12', 1);
insert into t1 values('1988-12-12', 2);
insert into t1 values('2018-12-12', 3);

select * from t1 partition(p0);
#As current,partition name is pNum
--error 1735
select * from t1 partition(p00);
select * from t1 partition(p1);
--error 1735
select * from t1 partition(p01);

--error 1735
select * from t1 partition(p4);
--error 1735
select * from t1 partition(p8192);
--error 1735
select * from t1 partition(p1024);


create table t2(c1 int, c2 datetime)
partition by hash(c1)
subpartition by range columns(c2)
subpartition template
(subpartition p0 values less than ('2000-01-01 00:00:00'),
 subpartition p1 values less than ('2010-01-01 00:00:00'),
 subpartition p2 values less than ('2020-01-02 00:00:00'),
 subpartition p3 values less than (MAXVALUE))
partitions 4;

insert into t2 values(1, '1988-12-12');
insert into t2 values(1, '2008-12-12');
insert into t2 values(1, '2018-12-12');
insert into t2 values(2, '2008-12-12');
insert into t2 values(2, '2018-12-12');
insert into t2 values(3, '2010-12-12');

select * from t2 partition(p0);

select * from t2 partition(p0sp0);

select * from t2 partition(p1sp2);
select * from t2 partition(p1sp1);
select * from t2 partition(p2sp1);

--error 1735
select * from t2 partition(p4sp2);
--error 1735
select * from t2 partition(p1sp4);

drop table t1, t2;

