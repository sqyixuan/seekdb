--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

#owner: sean.yyj
#owner group: SQL1
# tags: partition

--disable_warnings
drop database if exists part_func;
--enable_warnings

create database part_func;
use part_func;

--error 1486
create table t_hash_part (c1 date) partition by hash(hour(c1)) partitions 2;

create table t_hash_part (c1 time) partition by hash(hour(c1)) partitions 2;
insert into t_hash_part values("01:23:45");
select * from t_hash_part;
drop table t_hash_part;

create table t_hash_part (c1 datetime) partition by hash(hour(c1)) partitions 2;
insert into t_hash_part values("2001-02-03");
select * from t_hash_part;
drop table t_hash_part;

create table t_hash_part (c1 date) partition by hash(day(c1)) partitions 2;
insert into t_hash_part values("2001-02-03");
select * from t_hash_part;
drop table t_hash_part;

--error 1486
create table t_hash_part (c1 time) partition by hash(day(c1)) partitions 2;

create table t_hash_part (c1 datetime) partition by hash(day(c1)) partitions 2;
insert into t_hash_part values("2001-02-03");
select * from t_hash_part;
drop table t_hash_part;

create table t_hash_part (c1 date) partition by hash(quarter(c1)) partitions 2;
insert into t_hash_part values("2001-02-03");
select * from t_hash_part;
drop table t_hash_part;

--error 1486
create table t_hash_part (c1 time) partition by hash(quarter(c1)) partitions 2;

create table t_hash_part (c1 datetime) partition by hash(quarter(c1)) partitions 2;
insert into t_hash_part values("2001-02-03");
select * from t_hash_part;
drop table t_hash_part;

create table t_range_columns (c1 time) partition by range columns(c1)
(partition p0 values less than ('08:00:00'),
 partition p1 values less than ('16:00:00'),
 partition p2 values less than (MAXVALUE));
insert into t_range_columns values("01:23:45");
select * from t_range_columns;
drop table t_range_columns;

drop database part_func;
