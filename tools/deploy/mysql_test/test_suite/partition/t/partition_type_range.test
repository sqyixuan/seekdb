create table t_smalluint(c1 smallint(1) unsigned) partition by range(c1)
(partition p1 values less than (0),
 partition p2 values less than (65535),
 partition p3 values less than (65536),
 partition p4 values less than (1000000),
 partition p5 values less than (MAXVALUE));
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
--disable_query_log
--echo part value for t_smalluint
let $t_smalluint_id= query_get_value(select table_id from oceanbase.__all_virtual_table where tenant_id = $mysql_tenant_id and table_name = 't_smalluint' and database_id = $database_id, table_id, 1);
