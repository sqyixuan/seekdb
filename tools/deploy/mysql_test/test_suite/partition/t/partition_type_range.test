--enable_query_log
disconnect obsys;
connection default;

--error ER_VALUES_IS_NOT_INT_TYPE_ERROR
create table t1 (c1 bigint) partition by range(c1) (partition p0 values less than (-9223372036854775809));
create table t1 (c1 bigint) partition by range(c1) (partition p0 values less than (9223372036854775808));
--error ER_VALUES_IS_NOT_INT_TYPE_ERROR 
create table t1 (c1 bigint unsigned) partition by range(c1) (partition p0 values less than (18446744073709551616));

