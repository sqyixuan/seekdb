create table t_int(c1 int(1)) partition by range(c1)
(partition p0 values less than (-3000000000),
 partition p1 values less than (-2147483649),
 partition p2 values less than (-2147483648),
 partition p3 values less than (0),
 partition p4 values less than (2147483647),
 partition p5 values less than (2147483648),
 partition p6 values less than (3000000000),
 partition p7 values less than (MAXVALUE));

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
--disable_query_log
--echo part value for t_int
let $t_int_id = query_get_value(select table_id from oceanbase.__all_virtual_table where tenant_id = $mysql_tenant_id and table_name = 't_int' and database_id = $database_id, table_id, 1);
