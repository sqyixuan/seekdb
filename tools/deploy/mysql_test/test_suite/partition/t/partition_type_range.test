#owner: peihan.dph
##owner group: sql3

# description:
#
# test of range partition 

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
drop database if exists db1;
--enable_warnings
create database db1;
use db1;

let $mysql_tenant_id = 1;

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
let $database_id = query_get_value(select database_id from oceanbase.__all_virtual_database where tenant_id = $mysql_tenant_id and database_name = 'db1', database_id, 1);
disconnect obsys;
connection default;
##
create table t_tinyint(c1 tinyint(1)) partition by range(c1)
(partition p0 values less than (-2500),
 partition p1 values less than (-129),
 partition p2 values less than (-128),
 partition p3 values less than (0),
 partition p4 values less than (127),
 partition p5 values less than (128),
 partition p6 values less than (2500),
 partition p7 values less than (MAXVALUE));


connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
let $t_tinyint_id= query_get_value(select table_id from oceanbase.__all_virtual_table where tenant_id = $mysql_tenant_id and table_name = 't_tinyint' and database_id = $database_id, table_id, 1);
--disable_query_log
--echo part value for t_tinyint
eval select part_name, high_bound_val from oceanbase.__all_virtual_part where tenant_id = $mysql_tenant_id and table_id = $t_tinyint_id;
--enable_query_log
disconnect obsys;
connection default;

create table t_tinyuint(c1 tinyint(1) unsigned) partition by range(c1)
(partition p1 values less than (0),
 partition p2 values less than (255),
 partition p3 values less than (256),
 partition p4 values less than (2500),
 partition p5 values less than (MAXVALUE));

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
--disable_query_log
--echo part value for t_tinyuint
let $t_tinyuint_id= query_get_value(select table_id from oceanbase.__all_virtual_table where tenant_id = $mysql_tenant_id and table_name = 't_tinyuint' and database_id = $database_id, table_id, 1);
eval select part_name, high_bound_val from oceanbase.__all_virtual_part where tenant_id = $mysql_tenant_id and table_id = $t_tinyuint_id;
--enable_query_log
disconnect obsys;
connection default;

create table t_smallint(c1 smallint(1)) partition by range(c1)
