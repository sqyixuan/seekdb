#owner: yibo.tyf
#owner group: sql1
connect (my_obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection default;

--disable_warnings
drop table if exists ts, ts1, tr, tr1, tk, tk1, th, th1, th2;
--enable_warnings

create table ts(c1 int, c2 datetime, primary key(c1, c2)) partition by hash(c1) subpartition by range columns(c1,c2) subpartition template (subpartition p0 values less than (10, '2013-10-10'), subpartition p1 values less than (100, '2016-3-30')) partitions 2;

create table ts1(c1 int, c2 datetime, primary key(c1, c2)) partition by hash(c1) subpartition by range columns(c2) subpartition template (subpartition p0 values less than ('2013-10-10'), subpartition p1 values less than ('2016-3-30')) partitions 2;

create table tr(c1 int, c2 int) partition by range(c1) (partition p0 values less than (100));

create table tr1(c1 int, c2 int) partition by range(c1 + c2) (partition p0 values less than (100));

create table tk(c1 int, c2 int) partition by key(c2) partitions 2;

create table tk1(c1 int, c2 int) partition by key(c1, c2) partitions 2;

create table th(c1 int, c2 int) partition by hash(c2) partitions 2;

create table th1(c1 int, c2 int) partition by hash(c2 * c1) partitions 2;

create table th2(c1 int, c2 int) partition by hash(c1 * c1) partitions 2;

connection my_obsys;
eval
SELECT
  tb.table_name,
    tc.column_name,
      tc.column_id,
        hex (tc.partition_key_position)
      FROM
      oceanbase.__all_virtual_table tb,
      oceanbase.__all_virtual_column tc
    WHERE
    tb.tenant_id = (select tenant_id from oceanbase.__all_tenant where tenant_name = '$TENANT')
  AND tc.tenant_id = tb.tenant_id
  AND tb.table_id = tc.table_id
  AND tc.partition_key_position > 0
  AND (
    tb.table_name = 'ts'
OR tb.table_name = 'ts1'
OR tb.table_name = 'tr'
OR tb.table_name = 'tr1'
OR tb.table_name = 'tk'
OR tb.table_name = 'tk1'
OR tb.table_name = 'th'
OR tb.table_name = 'th1'
OR tb.table_name = 'th2')
  ORDER BY tb.table_name, tc.column_name;

connection default;


drop table ts, ts1, tr, tr1, tk, tk1, th,th1, th2;
