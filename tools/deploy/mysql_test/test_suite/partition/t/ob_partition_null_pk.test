# Test KEY()
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (
	col1 INT, 
	col2 VARCHAR(20), 
	col3 BIGINT PRIMARY KEY)
PARTITION BY KEY(col3)
PARTITIONS 4;

# Insert data
let $cnt = 1000;
--disable_query_log
while ($cnt)
{
	eval INSERT INTO t1 VALUES($cnt, 'C$cnt', $cnt * $cnt);
#	eval INSERT INTO t1 VALUES(NULL, 'C$cnt', $cnt * $cnt + 1);
	dec $cnt;
}
#eval INSERT INTO t1 VALUES(NULL, 'C$cnt', $cnt * $cnt + 1);
--enable_query_log

# Show rows layout in all partitions
select partition_name from information_schema.partitions where table_name='t1' and table_schema='test';
#select count(*) from t1 partition(p0);
#select count(*) from t1 partition(p1);
#select count(*) from t1 partition(p2);
#select count(*) from t1 partition(p3);


