--disable_query_log
--disable_result_log
connect (conn_admin,$OBMYSQL_MS0,admin@sys,admin,*NO-ONE*,$OBMYSQL_PORT);
#drop tenant tenant force;
#drop resource pool new_pool1;
#drop resource unit new_box1;
--enable_result_log
--enable_query_log
