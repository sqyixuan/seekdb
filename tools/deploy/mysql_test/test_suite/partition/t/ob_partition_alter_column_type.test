#owner: yibo.tyf
#owner group: sql1
## Test modify partition column type
--disable_query_log
--disable_result_log
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
#eval create resource unit new_box1 max_cpu 1, memory_size '2G';
#let $zone_name=query_get_value(select zone from oceanbase.__all_zone where zone != '' limit 1, zone, 1);
#let $obs_num = query_get_value(select count(1) as cnt from oceanbase.__all_server group by zone limit 1,cnt, 1);
#eval create resource pool new_pool1 unit = 'new_box1', unit_num = $obs_num;
#eval create tenant tenant primary_zone='$zone_name', resource_pool_list('new_pool1') set ob_tcp_invited_nodes='%';
#--source mysql_test/include/check_tenant_sync.inc
disconnect obsys;
connect (conn1,$OBMYSQL_MS0,root,,test,$OBMYSQL_PORT);
set global ob_sql_work_area_percentage=90;
--enable_query_log
--enable_result_log

--disable_warnings
drop table if exists t1;
--enable_warnings

# from\to   tinyint smallint  mediumint int     bigint
#   tinyint succ    succ      succ      succ    succ
#  smallint fail    succ      succ      succ    succ
# mediumint fail    fail      succ      succ    succ
#       int fail    fail      fail      succ    succ
#    bigint fail    fail      fail      fail    succ

# tinyint to tinyint
create table t1(c1 tinyint primary key) partition by hash(c1) partitions 10;
replace into t1 values(0);
select * from t1;
alter table t1 modify column c1 tinyint;
replace into t1 values(0);
select * from t1;

# tinyint to smallint

drop table if exists t1;
create table t1(c1 tinyint primary key) partition by hash(c1) partitions 10;
replace into t1 values(0);
select * from t1;
alter table t1 modify column c1 smallint;
replace into t1 values(0);
select * from t1;

