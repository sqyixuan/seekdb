--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: link.zt
# tags: optimizer

#--disable_abort_on_error
#

--disable_warnings
drop table if exists ts;
--enable_warnings

create table ts(c1 varchar(20), c2 datetime, primary key(c1, c2),c3 varchar(8) generated always as (substring(c1, 10)) virtual ) partition by key(c3) subpartition by range columns(c2) subpartition template (subpartition p0 values less than ('2013-10-10'),  subpartition p1 values less than ('2016-3-30')) partitions 16;
--disable_result_log
--disable_query_log
select count(*) from ts;
--enable_query_log
--enable_result_log

