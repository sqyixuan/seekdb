--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: yibo.tyf 
#owner group: sql4
#description: Test auto-recover of partitioned tables

#--source include/have_innodb.inc
#--source include/have_partition.inc
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (a INT)  PARTITION BY HASH(a);
INSERT INTO t1 VALUES (0), (1), (2);
START TRANSACTION;
UPDATE t1 SET a = 5 WHERE a = 1;
connect (con1, $OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
--echo # Connection con1
--echo # InnoDB lock timeout and monitor thread runs every 15 seconds
#SET innodb_lock_wait_timeout = 20;
SET ob_trx_timeout=1;
--error 0,4012,6002
START TRANSACTION;
#--error ER_LOCK_WAIT_TIMEOUT
--error 1210,4012,6002
UPDATE t1 SET a = 3 WHERE a = 1;
--error 0,6002
COMMIT;
disconnect con1;
connection default;
--echo # Connection default
COMMIT;
DROP TABLE t1;
