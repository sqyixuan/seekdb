
#owner: peihan.dph
##owner group: sql3

# description:
#
# test of charset and collation


--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
set @@recyclebin = off;
drop database if exists hualong;
--enable_warnings
create database hualong;
use hualong;

create TABLE t_varchar (a varchar(5)) partition by range columns(a) ( partition p0 values less than ('m'), partition p1 values less than ('za'));
INSERT INTO t_varchar  VALUES('a');
select * from t_varchar;
drop table t_varchar;

create TABLE t_binary (a binary(5)) partition by range columns(a) ( partition p0 values less than ('m'), partition p1 values less than ('za'));
INSERT INTO t_binary VALUES('a');
select * from t_binary;
drop table t_binary;

create TABLE t_char(a char(5)) partition by range columns(a) ( partition p0 values less than ('m'), partition p1 values less than ('za'));
INSERT INTO t_char VALUES('a');
select * from t_char;
drop table t_char;

create TABLE t_varbinary(a varbinary(5)) partition by range columns(a) ( partition p0 values less than ('m'), partition p1 values less than ('za'));
INSERT INTO t_varbinary VALUES('a');
select * from t_varbinary;
drop table t_varbinary;

--error ER_PARTITION_FUNCTION_IS_NOT_ALLOWED
create TABLE t3 (a varchar(5)) partition by range columns(a) ( partition p0 values less than ('m' collate 'utf8mb4_bin'), partition p1 values less than ('za' collate 'utf8mb4_bin'));

--error ER_PARTITION_FUNCTION_IS_NOT_ALLOWED
create TABLE t3 (a varchar(5)) partition by range columns(a) ( partition p0 values less than ('m' collate 'utf8mb4_general_ci'), partition p1 values less than ('za' collate 'utf8mb4_general_ci'));

--error ER_COLLATION_CHARSET_MISMATCH
create TABLE t3 (a varchar(5)) partition by range columns(a) ( partition p0 values less than ('m' collate 'binary'), partition p1 values less than ('za' collate 'binary'));


drop database hualong;
