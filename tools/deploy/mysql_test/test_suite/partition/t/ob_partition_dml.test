--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: yibo.tyf
#owner group: sql1
# tags: cost, optimizer

--disable_abort_on_error
#
# Test dml for partitioned tables;
#

# Test HASH()
let $part_type = HASH;
--source mysql_test/include/partition_dml.inc

# Test LINEAR HASH() -- not supported yet
#let $part_type = LINEAR HASH;
#--source mysql_test/include/partition_dml.inc

# Test KEY()
let $part_type = KEY;
--source mysql_test/include/partition_dml.inc

# Test LINEAR KEY() -- not supported yet
#let $part_type = LINEAR KEY;
#--source mysql_test/include/partition_dml.inc


# Test multiple column partitioning key with KEY()
let $part_type = KEY;
--source mysql_test/include/partition_dml_mul.inc

# Test multiple column partitioning key with LINEAR KEY() -- not supported yet
#let $part_type = LINEAR KEY;
#--source mysql_test/include/partition_dml_mul.inc

# Test RANGE()
#let $part_type = RANGE; not supported
#--source mysql_test/include/partition_dml.inc

