--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

#owner: peihan.dph
##owner group: sql3

#
# Test PARTITION BY HASH/KEY () PARTITIONS num
#
set ob_query_timeout=600000000;
set ob_trx_timeout=600000000;

# a) no PARTITIONS num (default 1)
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (col1 INT, col2 DATE, col3 VARCHAR(20), col4 BIGINT, PRIMARY KEY (col1, col2, col3), UNIQUE KEY (col1, col2, col3) LOCAL)PARTITION BY KEY();

--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (col1 INT, col2 DATE, col3 VARCHAR(20), col4 BIGINT, PRIMARY KEY (col1, col2, col3), UNIQUE KEY (col1, col2, col3) LOCAL)PARTITION BY HASH(col1);

# b) all kinds of valid num test
--disable_warnings
drop table if exists t1;
--enable_warnings
--error 1504
CREATE TABLE t1 (col1 INT, col2 DATE, col3 VARCHAR(20), col4 BIGINT, PRIMARY KEY (col1, col2, col3), UNIQUE KEY (col1, col2, col3) LOCAL)PARTITION BY HASH(col1) PARTITIONS 0;

