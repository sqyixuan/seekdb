#owner: xiaoyi.xy
#owner group: sql1

## Test partition related ddls

--disable_warnings
drop table if exists t1,t2,t3;
--enable_warnings

## --- delete column in partition key

## partition by hash
# primary key(1 column), hash(1 column)
create table t1(c1 int, c2 int, c3 varchar(20), primary key(c1)) partition by hash(c1) partitions 4;
alter table t1 drop column c1;
drop table t1;

# primary key(2 columns), hash(1 column)
create table t1(c1 int, c2 int, c3 varchar(20), primary key(c1,c2)) partition by hash(c1) partitions 4;
alter table t1 drop column c1;
drop table t1;

# primary key(2 columns), hash(2 columns)
create table t1(c1 int, c2 int, c3 varchar(20), primary key(c1,c2)) partition by hash((c1 + c2)%4) partitions 4;
alter table t1 drop column c1;
drop table t1;

# primary key(1 column), hash(2 columns) - failure expected
create table t1(c1 int, c2 int, c3 varchar(20), primary key(c1)) partition by hash(c1%4) partitions 4;

# partition by range
# primary key(1 column), hash(1 column)
create table t1(c1 int, c2 int, c3 varchar(20), primary key(c1)) partition by range(c1) (partition p0 values less than 10, partition p1 values less than MAXVALUE);
alter table t1 drop column c1;
drop table t1;

# primary key(2 columns), hash(1 column)
create table t1(c1 int, c2 int, c3 varchar(20), primary key(c1,c2)) partition by range(c1) (partition p0 values less than 10, partition p1 values less than MAXVALUE);
alter table t1 drop column c1;
drop table t1;

# primary key(2 columns), hash(2 columns)
create table t1(c1 int, c2 int, c3 varchar(20), primary key(c1,c2)) partition by range((c1 + c2) % 4) (partition p0 values less than 10, partition p1 values less than MAXVALUE);
alter table t1 drop column c1;
drop table t1;

# primary key(1 column), hash(2 columns) - failure expected
create table t1(c1 int, c2 int, c3 varchar(20), primary key(c1)) partition by partition by range(c1) (partition p0 values less than 10, partition p1 values less than MAXVALUE);



## --- test inner table update before and after drop table with partitions
create table t1(c1 int, c2 int, c3 varchar(20), primary key(c1,c2)) partition by hash(c1) partitions 4;
let $table_name='t1';
let $table_schema='test';
source mysql_test/include/partition_inner_table_check.inc
drop table t1;
let $table_name='t1';
let $table_schema='test';
source mysql_test/include/partition_inner_table_check.inc

create table t1(c1 int, c2 int, c3 varchar(20), primary key(c1,c2)) partition by range((c1 + c2) % 4) (partition p0 values less than 10, partition p1 values less than MAXVALUE);
let $table_name='t1';
let $table_schema='test';
source mysql_test/include/partition_inner_table_check.inc
drop table t1;
let $table_name='t1';
let $table_schema='test';
source mysql_test/include/partition_inner_table_check.inc

## Test partition definition is not related to `local unique index`
create table t1(c1 int, c2 int, c3 varchar(20), primary key(c1,c2), local unique ui1(c3)) partition by hash(c1) partitions 4;
drop table t1;

create table t1(c1 int, c2 int, c3 varchar(20), primary key(c1,c2), local unique ui1(c3)) partition by range((c1 + c2) % 4) (partition p0 values less than 10, partition p1 values less than MAXVALUE);
drop table t1;


