--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

#owner: peihan.dph
##owner group: sql3
# tags: optimizer
# description: Test local index for partitioned tables

--disable_warnings
drop table if exists t1;
--enable_warnings

# partition by hash
create table t1(c1 int primary key, c2 int, c3 char(20), c4 int, index i1(c2) local, index i2(c3,c4) local) partition by hash(c1) partitions 4;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;
insert into t1 values(1,3,'d',1);
insert into t1 values(5,2,'c',2);
insert into t1 values(9,4,'b',3);
insert into t1 values(13,1,'a',4);
select * from t1;
select * from t1 partition(p0);
select * from t1 partition(p1);
select * from t1 partition(p2);
select * from t1 partition(p3);
explain basic select * from t1 where c2 >= 0;
select * from t1 where c2 >= 0;
explain basic select * from t1 where c3 >= 'a';
select * from t1 where c3 >= 'a';
drop table t1;

# partition by key
create table t1(c1 int primary key, c2 int, c3 char(20), c4 int, index i1(c2) local, index i2(c3,c4) local) partition by key(c1) partitions 4;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;
insert into t1 values(1,3,'d',1);
insert into t1 values(5,2,'c',2);
insert into t1 values(9,4,'b',3);
insert into t1 values(13,1,'a',4);
select * from t1;
select * from t1 partition(p0);
select * from t1 partition(p1);
select * from t1 partition(p2);
select * from t1 partition(p3);
explain basic select * from t1 where c2 >= 0;
select * from t1 where c2 >= 0;
explain basic select * from t1 where c3 >= 'a';
select * from t1 where c3 >= 'a';


