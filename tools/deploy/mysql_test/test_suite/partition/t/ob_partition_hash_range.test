#owner: xiaoyi.xy
#owner group: sql1
# tags: optimizer

--source mysql_test/include/index_quick_major.inc
--disable_warnings
drop table if exists t1;
--enable_warnings

let $init_rows=10000;

create table t1(c1 int, c2 datetime, primary key(c1,c2), c3 varchar(200), index i1(c3) local, unique index ui1(c1,c2,c3) local)
partition by hash(c1)
subpartition by range columns(c2)
subpartition template
(subpartition a values less than ('2000-01-01 00:00:00'),
 subpartition b values less than ('2010-01-01 00:00:00'),
 subpartition c values less than ('2020-01-02 00:00:00'),
 subpartition d values less than (MAXVALUE))
partitions 4;


# -------------------------- Test insert ----------------------------------------------------------
let $cnt=$init_rows;
dec $cnt;
--disable_query_log
while($cnt>0)
{
  eval INSERT INTO t1 values($cnt, DATE_ADD('1990-01-01 00:00:01', interval $cnt DAY), 'CHAR$cnt');
  dec $cnt;
}
--enable_query_log

echo ----Verify partition allocation start
--disable_query_log
let $cnt=$init_rows;
while($cnt>0)
{
--echo c1 = $cnt
--replace_regex /.*, (partitions)/             \1/
  eval explain basic select * from t1 where c1=$cnt and c2=DATE_ADD('1990-01-01 00:00:01', interval $cnt DAY);
  dec $cnt;
  dec $cnt;
  dec $cnt;
  dec $cnt;
}
let $cnt=$init_rows;
dec $cnt;
while($cnt>0)
{
--echo c1 = $cnt
--replace_regex /.*, (partitions)/             \1/
  eval explain basic select * from t1 where c1=$cnt and c2=DATE_ADD('1990-01-01 00:00:01', interval $cnt DAY);
  dec $cnt;
  dec $cnt;
  dec $cnt;
  dec $cnt;
}
let $cnt=$init_rows;
dec $cnt;
dec $cnt;
while($cnt>0)
{
--echo c1 = $cnt
--replace_regex /.*, (partitions)/             \1/
  eval explain basic select * from t1 where c1=$cnt and c2=DATE_ADD('1990-01-01 00:00:01', interval $cnt DAY);
  dec $cnt;
  dec $cnt;
  dec $cnt;
  dec $cnt;
}
let $cnt=$init_rows;
dec $cnt;
dec $cnt;
dec $cnt;
while($cnt>0)
{
--echo c1 = $cnt
--replace_regex /.*, (partitions)/             \1/
  eval explain basic select * from t1 where c1=$cnt and c2=DATE_ADD('1990-01-01 00:00:01', interval $cnt DAY);
  dec $cnt;
  dec $cnt;
  dec $cnt;
  dec $cnt;
}
--enable_query_log
echo ----Verify partition allocation end

explain basic select * from t1;
#select count(*) from t1 partition(p0sp0);
select count(*) from t1 group by c1 % 4, case when c2 < '2000-01-01 00:00:00' then 'sp0' when c2 < '2010-01-01 00:00:00' then 'sp1' when c2 < '2020-01-01 00:00:00' then 'sp2' else 'sp3' end;


