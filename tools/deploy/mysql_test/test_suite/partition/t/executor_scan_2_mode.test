--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: luofan.zp
#owner group: sql3

--disable_warnings
drop table if exists large_t1;
--enable_warnings


# 下面三个参数是建表必须的参数，分别为：列宽度，多少列，行数，表名 
--let $COLUMN_WIDTH = 1024
--let $LARGE_COLUMN_COUNT = 300
#--let $ROW_COUNT = 200000
--let $ROW_COUNT = 200
--let $TABLE_NAME = large_t1

--source mysql_test/include/create_large_partition_table.inc

select c1,c2,c3 from large_t1 limit 1;
set ob_query_timeout = 1000000000000;
--disable_result_log
select * from large_t1;
select * from large_t1 where pk1=1;
select * from large_t1 where pk1=2;
--enable_result_log

#drop table large_t1;
