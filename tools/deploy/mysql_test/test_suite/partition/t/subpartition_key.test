#owner: peihan.dph
##owner group: sql3
# tags: optimizer

# key分区作为二级分区

use test;
--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1 (c1 int, c2 int, c3 int) partition by range(c1) subpartition by key(c2) subpartitions 5 (partition p0 values less than(0), partition p1 values less than(100));
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;

insert into t1 values(-1, 0, 3);
insert into t1 values(-1, 1, 3);
insert into t1 values(10, 1000, 3);
select * from t1;
select * from t1 where c1 = -1 and c2 = 0;
explain select * from t1 where c1 = -1 and c2 = 0;
explain select * from t1 where c1 = -1 and c2 = 1;
explain select * from t1 where c1 = 10 and c2 = 1000;
explain select * from t1;
drop table t1;


--error 1064
create table t1 (c1 int, c2 int, c3 int, primary key(c1,c2)) partition by range(c1) subpartition by key() subpartitions 5 (partition p0 values less than(0), partition p1 values less than(100));

create table t1 (c1 int, c2 int, c3 int) partition by range(c1) subpartition by key(c2, c3) subpartitions 5 (partition p0 values less than(0), partition p1 values less than(100));
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;
insert into t1 values(-1, 0, 3);
insert into t1 values(-1, 1, 3);
insert into t1 values(10, 1, 3);

select * from t1;
explain select * from t1;
select * from t1 where c1 = -1 and c2 = 0;
explain select * from t1 where c1 = -1 and c2 = 0 and c3 = 3;
explain select * from t1 where c1 = -1 and c2 = 1 and c3 = 3;
explain select * from t1 where c1 = 10 and c2 = 1 and c3 = 3;
drop table t1;


create table t1 (c1 int, c2 varchar(500), c3 int) partition by range(c1) subpartition by key(c2) subpartitions 5 (partition p0 values less than(0), partition p1 values less than(100));
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;

insert into t1 values(-1, 'a', 3);
insert into t1 values(-1, 'd', 3);
insert into t1 values(10, 'd', 3);
select * from t1;
explain select * from t1;
select * from t1 where c1 = -1 and c2 = 'a';
explain select * from t1 where c1 = -1 and c2 = 'd';
explain select * from t1 where c1 = -1 and c2 = 'd';
explain select * from t1 where c1 = 10 and c2 = 'd';
drop table t1;


create table t1 (c1 int, c2 varchar(500), c3 int) partition by range columns(c1) subpartition by key(c2) subpartitions 5 (partition p0 values less than(0), partition p1 values less than(100));
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;

insert into t1 values(-1, 'a', 3);
insert into t1 values(-1, 'd', 3);
insert into t1 values(10, 'd', 3);
select * from t1;
explain select * from t1;
select * from t1 where c1 = -1 and c2 = 'a';
explain select * from t1 where c1 = -1 and c2 = 'd';
explain select * from t1 where c1 = -1 and c2 = 'd';
explain select * from t1 where c1 = 10 and c2 = 'd';
drop table t1;

