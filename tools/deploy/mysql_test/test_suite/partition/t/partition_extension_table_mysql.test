# owner: yibo.tyf
# owner group: SQL1
# tags: partition, optimizer
# description: test table with partition extension in stmt

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
drop table if exists t1,t2,t3,tmp_t;
--enable_warnings

create table t1 (c1 int primary key, c2 int, c3 int);
create table t2 (c1 int primary key, c2 int, c3 int) partition by range (c1)
(
  partition p0 values less than (100),
  partition p1 values less than (200),
  partition p2 values less than (300),
  partition p3 values less than (400)
);
create table t3 (c1 int, c2 int, c3 int, primary key (c1,c2)) partition by range (c1)
subpartition by hash(c2) subpartitions 16
(
  partition p0 values less than (100),
  partition p1 values less than (200),
  partition p2 values less than (300),
  partition p3 values less than (400)
);
create table tmp_t (c1 int, c2 int, c3 int);

--explain_protocol 2
--result_format 4

## use partition on non partitioned table

select * from t1 partition(p0);
delete from t1 partition(p0);
update t1 partition(p0) set c1 = c1 + 1;
insert into tmp_t select * from t1 partition(p0);
replace into t1 partition(p0) values (1, 0, 0);

--error 1735
select * from t1 partition(p0sp0);

## use patition on level one partitioned table

# specific existed partition 
select * from t2 partition(p0);
delete from t2 partition(p0);
update t2 partition(p0) set c1 = c1 + 1;
insert into tmp_t select * from t2 partition(p0);
replace into t2 partition(p0) values (1, 0, 0);

# specific not existed partition
--error 1735 
select * from t2 partition(p5);
--error 1735
delete from t2 partition(p5);
--error 1735
update t2 partition(p5) set c1 = c1 + 1;
--error 1735
insert into tmp_t select * from t2 partition(p5);
--error 1735
replace into t2 partition(p5) set c2 = 123;


# specific not existed subpartition 
--error 1735
select * from t2 partition(p0sp0);

# specific existed partitions
select * from t2 partition(p1, p2);
delete from t2 partition(p1, p2);
update t2 partition(p1, p2) set c1 = c1 + 1;
insert into tmp_t select * from t2 partition(p1, p2);
replace into t2 partition(p1, p2) values (101, 0, 0);

# specific not existed partitions
--error 1735
select * from t2 partition(p1, p5);

# specific not existed subpartition
--error 1735
select * from t2 partition(p0sp0);


## use patition on level two partitioned table

# specific existed partition 
select * from t3 partition(p0);
delete from t3 partition(p0);
update t3 partition(p0) set c1 = c1 + 1;
insert into tmp_t select * from t3 partition(p0);
replace into t3 partition(p0) values (1, 0, 0);

# specific not existed partition 
--error 1735
select * from t3 partition(p5);
--error 1735
delete from t3 partition(p5);
--error 1735
update t3 partition(p5) set c1 = c1 + 1;
--error 1735
insert into tmp_t select * from t3 partition(p5);
--error 1735
replace into t3 partition(p5) values (1, 0, 0);

# specific existed subpartition 
select * from t3 partition(p0sp0);

# specific existed partitions
select * from t3 partition(p1, p2);
delete from t3 partition(p1, p2);
update t3 partition(p1, p2) set c1 = c1 + 1;
insert into tmp_t select * from t3 partition(p1, p2);
replace into t3 partition(p1, p2) values (101, 0, 0);

# specific not existed partitions
--error 1735
select * from t3 partition(p1, p5);

# specific existed subpartition
select * from t3 partition(p0sp0);
delete from t3 partition(p0sp0);
update t3 partition(p0sp0) set c1 = c1 + 1;
insert into tmp_t select * from t3 partition(p0sp0);
replace into t3 partition(p0sp0) values (1, 0, 0);

# specific not existed partition
--error 1735
select * from t3 partition(p0sp20);
--error 1735
delete from t3 partition(p0sp20);
--error 1735
update t3 partition(p0sp20) set c1 = c1 + 1;
--error 1735
insert into tmp_t select * from t3 partition(p0sp20);
--error 1735
replace into t3 partition(p0sp20) values (1, 0, 0);

# specific existed subpartitions
select * from t3 partition(p1sp1, p2sp2);
delete from t3 partition(p1sp1, p2sp2);
update t3 partition(p1sp1, p2sp2) set c1 = c1 + 1;
insert into tmp_t select * from t3 partition(p1sp1, p2sp2);
replace into t3 partition(p1sp1, p2sp2) values (101, 1, 0);

# specific not existed subpartitions
--error 1735
select * from t3 partition(p1sp1, p0sp20);

set autocommit=1;

drop table t1, t2, t3, tmp_t;