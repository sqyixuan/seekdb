# ===二级分区的情况
create table t1 (c1 int, c2 int, c3 int) partition by hash(c1) subpartition by list(c2) subpartition template(subpartition p0 values in (1,2,3), subpartition p1 values in (default)) partitions 3;

insert into t1 values(0,1,3);

select * from t1 where c1 = 0 and c2 = 1;
explain select * from t1 where c1 = 0 and c2 = 1;

insert into t1 values(0,5,3);

select * from t1 where c1 = 0 and c2 = 5;
explain select * from t1 where c1 = 0 and c2 = 5;

drop table t1;

create table t1 (c1 int, c2 int, c3 int) partition by list(c1) subpartition by hash(c2) subpartitions 3 (partition p0 values in (1,2,3), partition p1 values in (default));

insert into t1 values(1,0,3);
select * from t1 where c1 = 1 and c2 = 0;
explain select * from t1 where c1 = 1 and c2 = 0;

insert into t1 values(5,0,3);
select * from t1 where c1 = 5 and c2 = 0;
explain select * from t1 where c1 = 5 and c2 = 0;

drop table t1;

create table t1 (c1 int, c2 int, c3 int) partition by range(c1) subpartition by list(c2) subpartition template (subpartition p0 values in (1,2,3), subpartition p1 values in (default)) (partition p0 values less than (5), partition p1 values less than(10));

insert into t1 values(0,1,3);
select * from t1 where c1 = 0 and c2 = 1;
explain select * from t1 where c1 = 0 and c2 = 1;

insert into t1 values(6,5,3);
select * from t1 where c1 = 6 and c2 = 5;
explain select * from t1 where c1 = 6 and c2 = 5;

drop table t1;


create table t1 (c1 int, c2 int, c3 int) partition by list(c1) subpartition by range(c2) subpartition template (subpartition p0 values less than (5), subpartition p1 values less than (maxvalue)) (partition p0 values in (1,2,3), partition p1 values in (default));

insert into t1 values(0,1,3);
select * from t1 where c1 = 0 and c2 = 1;
explain select * from t1 where c1 = 0 and c2 = 1;

insert into t1 values(6,5,3);
select * from t1 where c1 = 6 and c2 = 5;
explain select * from t1 where c1 = 6 and c2 = 5;

drop table t1;


create table t1 (c1 int, c2 int, c3 int) partition by range(c1) subpartition by list(c2) subpartition template (subpartition p0 values in (1,2,3), subpartition p1 values in (default)) (partition p0 values less than (5), partition p1 values less than(10));

insert into t1 values(6,1,2);

alter table t1 drop partition (p1);

select * from t1;

--error 1526
insert into t1 values(6,1,0);


alter table t1 add partition (partition p1 values less than(maxvalue));

insert into t1 values(6,1,0);
drop table t1;


