insert into tx4xb values('default');
select * from tx4xb partition(p1);
select * from tx4xb partition(p2);

drop table tx4xb;

create table tx4xb(c int)
partition by list columns (c)
(partition p1 values in(null), partition p2 values in (5));

insert into tx4xb values(null);
insert into tx4xb values(5);
select * from tx4xb partition(p1);
select * from tx4xb partition(p2);


