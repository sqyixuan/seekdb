CREATE TABLE `test` (
    `partner_id` varchar(400) COLLATE utf8mb4_bin NOT NULL,
    `out_trade_no` varchar(64) COLLATE utf8mb4_bin NOT NULL,
    `trade_from` varchar(200) COLLATE utf8mb4_bin NOT NULL,
    `trade_no_prefix` varchar(1) COLLATE utf8mb4_bin DEFAULT NULL,
    `trade_no` varchar(64) COLLATE utf8mb4_bin NOT NULL,
    `gmt_create` datetime(6) NOT NULL,
    `partition_id` varchar(2),
    PRIMARY KEY (`out_trade_no`, `partner_id`, `trade_from`,`partition_id`)
    ) partition by list columns(partition_id)
  (partition p00 values in (('00')),
   partition p01 values in (('01')),
   partition p02 values in (('02')),
   partition p03 values in (('03')));
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table test;
drop table test;

create table t1 (c1 int, c2 int) partition by list (c1) (partition p0 values in (1), partition p1 values in (default));
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;
drop table t1;

create table t1 (c1 int, c2 int) partition by list columns(c1, c2) (partition p0 values in (1,2), partition p1 values in (default));
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;
drop table t1;

