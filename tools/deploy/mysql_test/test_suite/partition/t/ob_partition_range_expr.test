#owner: yibo.tyf
#owner group: sql1

## Test partition by range related expr

--disable_warnings
drop table if exists t1,t2,t3;
--enable_warnings

# range not in sequence
--error 1064
create table t1(c1 int primary key, c2 int, c3 varchar(20)) partition by range(c1) partitions 3 (partition p0 values less than 500, partition p1 values less than 200, partition p2 values less than maxvalue);

# maxvalue in or not in ()
create table t1(c1 int primary key, c2 int, c3 varchar(20)) partition by range(c1) partitions 3 (partition p0 values less than 100, partition p1 values less than 200, partition p2 values less than maxvalue);
drop table t1;

create table t1(c1 int primary key, c2 int, c3 varchar(20)) partition by range(c1) partitions 3 (partition p0 values less than 100, partition p1 values less than 200, partition p2 values less than (maxvalue));
drop table t1;

# partitions != defined partitions
--error 1064
create table t1(c1 int primary key, c2 int, c3 varchar(20)) partition by range(c1) partitions 2 (partition p0 values less than 100, partition p1 values less than 200, partition p2 values less than maxvalue);

# No maxvalue, and inserted value out of range of last range broundary
create table t1(c1 int primary key, c2 int, c3 varchar(20)) partition by range(c1) partitions 3 (partition p0 values less than 100, partition p1 values less than 200, partition p2 values less than 300);
insert into t1 values(500);
drop table t1;

# max value insert, should go to maxvalue partition
create table t1(c1 int primary key, c2 int, c3 varchar(20)) partition by range(c1) partitions 3 (partition p0 values less than 100, partition p1 values less than 200, partition p2 values less than maxvalue);
insert into t1 values(2147483647);
insert into t1 values(2147483648);
select * from t1 partition(p2);
drop table t1;

# test expr in values expr
create table t1(c1 int primary key, c2 int, c3 varchar(20)) partition by range(c1) partitions 3 (partition p0 values less than 100+10, partition p1 values less than 200 % 500, partition p2 values less than maxvalue - 1);
drop table t1;

create table t1(c1 int primary key, c2 int, c3 varchar(20)) partition by range(c1) partitions 3 (partition p0 values less than abs(-100), partition p1 values less than round(200.5), partition p2 values less than maxvalue);
drop table t1;

create table t1(c1 int primary key, c2 int, c3 varchar(20)) partition by range(c1) partitions 3 (partition p0 values less than 100.2, partition p1 values less than 200 + ceil(3.5), partition p2 values less than maxvalue);
drop table t1;

create table t1(c1 int primary key, c2 int, c3 varchar(20)) partition by range(c1) partitions 3 (partition p0 values less than '123', partition p1 values less than '200', partition p2 values less than maxvalue);
drop table t1;

create table t1(c1 int, c2 date, c3 varchar(20), primary key(c1,c2)) partition by range(c1) partitions 3 (partition p0 values less than YEAR(c2), partition p1 values less than 200, partition p2 values less than maxvalue);

create table t1(c1 int primary key, c2 int, c3 varchar(20)) partition by range(c1) partitions 3 (partition p0 values less than DAY('2016-10-30'), partition p1 values less than YEAR('2016-10-30'), partition p2 values less than maxvalue);

# Test invalid partition num
create table t1(c1 int primary key, c2 int, c3 varchar(20)) partition by range(c1) partitions 1+2 (partition p0 values less than 100, partition p1 values less than 200, partition p2 values less than maxvalue);
create table t1(c1 int primary key, c2 int, c3 varchar(20)) partition by range(c1) partitions 'a' (partition p0 values less than 100, partition p1 values less than 200, partition p2 values less than maxvalue);
create table t1(c1 int primary key, c2 int, c3 varchar(20)) partition by range(c1) partitions '3' (partition p0 values less than 100, partition p1 values less than 200, partition p2 values less than maxvalue);
create table t1(c1 int primary key, c2 int, c3 varchar(20)) partition by range(c1) partitions 3.1 (partition p0 values less than 100, partition p1 values less than 200, partition p2 values less than maxvalue);
create table t1(c1 int primary key, c2 int, c3 varchar(20)) partition by range(c1) partitions ceil(2.8) (partition p0 values less than 100, partition p1 values less than 200, partition p2 values less than maxvalue);
create table t1(c1 int primary key, c2 int, c3 varchar(20)) partition by range(c1) partitions -3 (partition p0 values less than 100, partition p1 values less than 200, partition p2 values less than maxvalue);

# Test partition key which is not int or date related column
create table t1(c1 float primary key, c2 int, c3 varchar(20)) partition by range(c1) partitions 3 (partition p0 values less than 100, partition p1 values less than 200, partition p2 values less than maxvalue);
create table t1(c1 double primary key, c2 int, c3 varchar(20)) partition by range(c1) partitions 3 (partition p0 values less than 100, partition p1 values less than 200, partition p2 values less than maxvalue);
create table t1(c1 decimal(20,0) primary key, c2 int, c3 varchar(20)) partition by range(c1) partitions 3 (partition p0 values less than 100, partition p1 values less than 200, partition p2 values less than maxvalue);
create table t1(c1 decimal(20,5) primary key, c2 int, c3 varchar(20)) partition by range(c1) partitions 3 (partition p0 values less than 100, partition p1 values less than 200, partition p2 values less than maxvalue);
create table t1(c1 char(20) primary key, c2 int, c3 varchar(20)) partition by range(c1) partitions 3 (partition p0 values less than 100, partition p1 values less than 200, partition p2 values less than maxvalue);
create table t1(c1 varchar(200) primary key, c2 int, c3 varchar(20)) partition by range(c1) partitions 3 (partition p0 values less than 100, partition p1 values less than 200, partition p2 values less than maxvalue);
create table t1(c1 binary(200) primary key, c2 int, c3 varchar(20)) partition by range(c1) partitions 3 (partition p0 values less than 100, partition p1 values less than 200, partition p2 values less than maxvalue);
create table t1(c1 varbinary(200) primary key, c2 int, c3 varchar(20)) partition by range(c1) partitions 3 (partition p0 values less than 100, partition p1 values less than 200, partition p2 values less than maxvalue);
create table t1(c1 datetime primary key, c2 int, c3 varchar(20)) partition by range(c1) partitions 3 (partition p0 values less than 100, partition p1 values less than 200, partition p2 values less than maxvalue);
create table t1(c1 time primary key, c2 int, c3 varchar(20)) partition by range(c1) partitions 3 (partition p0 values less than 100, partition p1 values less than 200, partition p2 values less than maxvalue);
create table t1(c1 timestamp(4) primary key, c2 int, c3 varchar(20)) partition by range(c1) partitions 3 (partition p0 values less than 100, partition p1 values less than 200, partition p2 values less than maxvalue);
create table t1(c1 tinyint primary key, c2 int, c3 varchar(20)) partition by range(c1) partitions 3 (partition p0 values less than 100, partition p1 values less than 200, partition p2 values less than maxvalue);

# test single column restriction
create table t1(c1 int, c2 int, c3 varchar(20)) partition by range(c1,c2) partitions 3 (partition p0 values less than 100, partition p1 values less than 200, partition p2 values less than maxvalue);
create table t1(c1 int primary key, c2 int, c3 varchar(20)) partition by range(c5) partitions 3 (partition p0 values less than 100, partition p1 values less than 200, partition p2 values less than maxvalue);
create table t1(c1 int primary key, c2 int, c3 varchar(20)) partition by range() partitions 3 (partition p0 values less than 100, partition p1 values less than 200, partition p2 values less than maxvalue);
create table t1(c1 int primary key, c2 int, c3 varchar(20)) partition by range(c1) partitions 3;


