#owner: yibo.tyf
#owner group: sql1
# tags: optimizer

--disable_warnings
drop table if exists ts, tb, tc, trs, trb, trc;
--enable_warnings

#values of insert, update for table location is final value.

create table ts (c1 datetime not null, c2 int, primary key (c1)) partition by key(c1) partitions 11;

create table trs (c1 datetime not null, c2 int, primary key (c1)) partition by range columns(c1)
  (partition p0 values less than ('2016-1-1 1:1:1.002222'), partition p1 values less than ('2017-7-8'));


create table tb(c1 binary(5) default 'a', primary key(c1)) partition by key(c1) partitions 7;

create table trb(c1 binary(5) default 'a', primary key(c1)) partition by range columns(c1)
  (partition p0 values less than ('a'), partition p1 values less than ('c'));


#for char(5) as compare and hash ignore space, so even not final value can also correct

create table tc(c1 char(5), primary key(c1)) partition by key(c1) partitions 7;
create table trc(c1 char(5), primary key(c1)) partition by range columns(c1)
  (partition p0 values less than ('a'), partition p1 values less than ('c'));

let $ts = ts;
let $tb = tb;
let $tc = tc;
--source mysql_test/include/ob_partition_location.inc

let $ts = trs;
let $tb = trb;
let $tc = trc;
--source mysql_test/include/ob_partition_location.inc
explain select * from trs where c1 < '2016-1-1 1:1:1.112222';
explain select * from trs where c1 < '2016-1-1 1:1:1';
select * from trs where c1 < '2016-1-1 1:1:1.112222';

drop table if exists ts, tb, tc, trs, trb, trc;
