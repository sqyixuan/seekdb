# 测试range类型为无符号类型
# 1. Initialise

use test;
--disable_warnings
drop table if exists t_uint;
--enable_warnings

# 2. Test tinyint unsinged 

#    2.1 value in range[0, 255]
create table t_uint (c1 tinyint unsigned, c2 int, c3 int) 
partition by range columns(c1) (partition p0 values less than(0), partition p1 values less than(255),
                                partition p2 values less than(maxvalue));
--error 1264
insert into t_uint(c1) values(-1);

insert into t_uint(c1) values(0);
insert into t_uint(c1) values(1);
insert into t_uint(c1) values(255);

--error 1264
insert into t_uint(c1) values(256);

select c1 from t_uint partition(p1) order by c1;

drop table t_uint;

#    2.2 value out of range
--error 1654
create table t_uint (c1 tinyint unsigned, c2 int, c3 int) 
partition by range columns(c1) (partition p0 values less than(-1), partition p1 values less than(100));

--error 1654
create table t_uint (c1 tinyint unsigned, c2 int, c3 int) 
partition by range columns(c1) (partition p0 values less than(0), partition p1 values less than(256));

# 3. Test smallint unsigned

#    3.1 value in range[0, 65535]
create table t_uint (c1 smallint unsigned, c2 int, c3 int) 
partition by range columns(c1) (partition p0 values less than(0), partition p1 values less than(65535),
                                partition p2 values less than(maxvalue));
--error 1264
insert into t_uint(c1) values(-1);

insert into t_uint(c1) values(0);
insert into t_uint(c1) values(1);
insert into t_uint(c1) values(65535);

--error 1264
insert into t_uint(c1) values(65536);

select c1 from t_uint partition(p1) order by c1;

drop table t_uint;

#    3.2 value out of range
--error 1654
create table t_uint (c1 smallint unsigned, c2 int, c3 int) 
partition by range columns(c1) (partition p0 values less than(-1), partition p1 values less than(100));

--error 1654
create table t_uint (c1 smallint unsigned, c2 int, c3 int) 
partition by range columns(c1) (partition p0 values less than(0), partition p1 values less than(65536));

# 4. Test int unsigned

#    4.1 value in range[0, 4294967295]
create table t_uint (c1 int unsigned, c2 int, c3 int) 
partition by range columns(c1) (partition p0 values less than(0), partition p1 values less than(4294967295),
                                partition p2 values less than(maxvalue));
--error 1264
insert into t_uint(c1) values(-1);

insert into t_uint(c1) values(0);
insert into t_uint(c1) values(1);
insert into t_uint(c1) values(4294967295);

--error 1264
insert into t_uint(c1) values(4294967296);

select c1 from t_uint partition(p1) order by c1;

drop table t_uint;

#    4.2 value out of range
--error 1654
create table t_uint (c1 int unsigned, c2 int, c3 int) 
partition by range columns(c1) (partition p0 values less than(-1), partition p1 values less than(100));

--error 1654
create table t_uint (c1 int unsigned, c2 int, c3 int) 
partition by range columns(c1) (partition p0 values less than(0), partition p1 values less than(4294967296));

# 5. Test big int unsigned

#    5.1 value in range[0, 18446744073709551615]
create table t_uint (c1 bigint unsigned, c2 int, c3 int) 
partition by range columns(c1) (partition p0 values less than(0), partition p1 values less than(18446744073709551615), partition p2 values less than(maxvalue));
--error 1264
insert into t_uint(c1) values(-1);

insert into t_uint(c1) values(0);
insert into t_uint(c1) values(1);
insert into t_uint(c1) values(18446744073709551615);

--error 1264
insert into t_uint(c1) values(18446744073709551616);

select c1 from t_uint partition(p1) order by c1;

drop table t_uint;

#    5.2 value out of range
--error 1654
create table t_uint (c1 bigint unsigned, c2 int, c3 int) 
partition by range columns(c1) (partition p0 values less than(-1), partition p1 values less than(100));

--error 1654
create table t_uint (c1 bigint unsigned, c2 int, c3 int) 
partition by range columns(c1) (partition p0 values less than(18446744073709551616), partition p1 values less than(maxvalue));

# 6. test multi columns
#    6.1 valide range 255, 65535, 4294967295, 18446744073709551615 
create table t_uint (
    c1 tinyint  unsigned, 
    c2 smallint unsigned, 
    c3 int      unsigned, 
    c4 bigint   unsigned
) 
partition by range columns(c1,c2,c3,c4) (
    partition p0 values less than(0,0,0,0),
    partition p1 values less than(255,65535,4294967295,18446744073709551615),
    partition p2 values less than(maxvalue, maxvalue, maxvalue, maxvalue)
);

--error 1264
insert into t_uint values(-1,0,0,0);
--error 1264
insert into t_uint values(0,-1,0,0);
--error 1264
insert into t_uint values(0,0,-1,0);
--error 1264
insert into t_uint values(0,0,0,-1);
--error 1264
insert into t_uint values(-1,-1,0,0);
--error 1264
insert into t_uint values(0,-1,-1,0);
--error 1264
insert into t_uint values(0,0,-1,-1);
--error 1264
insert into t_uint values(0,-1,0,-1);

insert into t_uint values(0,0,0,0);
insert into t_uint values(1,1,1,1);
insert into t_uint values(255, 65535, 4294967295, 18446744073709551615);

--error 1264
insert into t_uint values(256,0,0,0);
--error 1264
insert into t_uint values(0,65536,0,0);
--error 1264
insert into t_uint values(0,0,4294967296,0);
--error 1264
insert into t_uint values(0,0,0,18446744073709551616);


select c1 from t_uint partition(p1) order by c1;
drop table t_uint;

#    6.2 invalide range 256, 65536, 4294967296, 18446744073709551616 
--error 1654
create table t_uint (
    c1 tinyint  unsigned, 
    c2 smallint unsigned, 
    c3 int      unsigned, 
    c4 bigint   unsigned
) 
partition by range columns(c1,c2,c3,c4) (
    partition p0 values less than(0, 0, 0, 0),
    partition p1 values less than(256, 65535, 4294967295, 18446744073709551615),
    partition p2 values less than(maxvalue, maxvalue, maxvalue, maxvalue)
);

--error 1654
create table t_uint (
    c1 tinyint  unsigned, 
    c2 smallint unsigned, 
    c3 int      unsigned, 
    c4 bigint   unsigned
) 
partition by range columns(c1,c2,c3,c4) (
    partition p0 values less than(0, 0, 0, 0),
    partition p1 values less than(255, 65536, 4294967295, 18446744073709551615),
    partition p2 values less than(maxvalue, maxvalue, maxvalue, maxvalue)
);

--error 1654
create table t_uint (
    c1 tinyint  unsigned, 
    c2 smallint unsigned, 
    c3 int      unsigned, 
    c4 bigint   unsigned
) 
partition by range columns(c1,c2,c3,c4) (
    partition p0 values less than(0,0,0,0),
    partition p1 values less than(255, 65535, 4294967296, 18446744073709551615),
    partition p2 values less than(maxvalue, maxvalue, maxvalue, maxvalue)
);

--error 1654
create table t_uint (
    c1 tinyint  unsigned, 
    c2 smallint unsigned, 
    c3 int      unsigned, 
    c4 bigint   unsigned
) 
partition by range columns(c1,c2,c3,c4)(
    partition p0 values less than(0, 0, 0, 0),
    partition p1 values less than(255, 65535, 4294967295, 18446744073709551616),
    partition p2 values less than(maxvalue, maxvalue, maxvalue, maxvalue)
);

# 7. subpartition test
#     7.1 valide range in subpartition
create table t_uint (
    c1 tinyint  unsigned, 
    c2 smallint unsigned, 
    c3 int      unsigned, 
    c4 bigint   unsigned, 
    c5 int
) 
partition by hash(c5)
    subpartition by range columns(c1, c2, c3, c4) 
    subpartition template(  
        subpartition p1 values less than (0, 0, 0, 0), 
        subpartition p2 values less than (255, 65535, 4294967295, 18446744073709551615), 
        subpartition p_max_value values less than (MAXVALUE, maxvalue, maxvalue, maxvalue)
        )
partitions 2;

drop table t_uint;

#    7.2 invalide range in supartition
--error 1654
