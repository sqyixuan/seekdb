--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: yuchen.wyc
# owner group: SQL1
# description: mysql的partition datetime innodb测试

################################################################################
# t/partition_datetime_innodb.test                                             #
#                                                                              #
# Purpose:                                                                     #
#  Tests around integer type                                                   #
#        INNODB branch                                                         #
#                                                                              #
#------------------------------------------------------------------------------#
# Original Author: HH                                                          #
# Original Date: 2006-08-01                                                    #
# Change Author:                                                               #
# Change Date:                                                                 #
# Change:                                                                      #
################################################################################

#
# NOTE: PLEASE DO NOT ADD NOT INNODB SPECIFIC TESTCASES HERE !
#       TESTCASES WHICH MUST BE APPLIED TO ALL STORAGE ENGINES MUST BE ADDED IN
#       THE SOURCED FILES ONLY.
#
# Please read the README at the end of inc/partition.pre before changing
# any of the variables.
#

#------------------------------------------------------------------------------#
# General not engine specific settings and requirements

##### Options, for debugging support #####
let $debug= 0;

# The server must support partitioning.
#--source include/have_partition.inc

#------------------------------------------------------------------------------#
# Engine specific settings and requirements

##### Storage engine to be tested
#--source include/have_innodb.inc
let $engine= 'InnoDB';

##### max rows to be inserted
let $maxrows=1024;

#------------------------------------------------------------------------------#
# Execute the tests to be applied to all storage engines
--source mysql_test/include/partition_timestamp.inc
--source mysql_test/include/partition_date.inc
--source mysql_test/include/partition_time.inc
--source mysql_test/include/partition_datetime.inc
--source mysql_test/include/partition_year.inc
