--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

#owner: peihan.dph
#owner group: sql3

#
#
# Test maximum number of partitions
#

set @@recyclebin = off;
set ob_query_timeout=600000000;

# Test 8192 partitions
let $index_cnt = 0 ;
let $unique_cnt = 0 ;
let $part_type = HASH;
--source mysql_test/include/partition_num_limit_pk.inc

# Test 8192 partitions with 60 indexes
# mysql 5.6 will hung in this test!! How about ob?
let $index_cnt = 60 ;
let $unique_cnt = 0 ;
let $part_type = HASH;
--source mysql_test/include/partition_num_limit_pk.inc

# Test 8192 partitions with 60 unique indexes
# mysql 5.6 will hung in this test!! How about ob?
let $index_cnt = 0 ;
let $unique_cnt = 60 ;
let $part_type = HASH;
--source mysql_test/include/partition_num_limit_pk.inc

# Test 8192 partitions with 30 indexes and 30 unique indexes
# mysql 5.6 will hung in this test!! How about ob?
let $index_cnt = 0 ;
let $unique_cnt = 60 ;
let $part_type = HASH;
--source mysql_test/include/partition_num_limit_pk.inc

# Test large number of columns in partitioning key
--disable_warnings
drop table if exists t1;
--enable_warnings
let $create_stmt = CREATE TABLE t1 (c0 INT ;
let $cnt = 15;
let $part_key = c0 ;
while ($cnt)
{
	let $create_stmt = $create_stmt , c$cnt CHAR(8);
	let $part_key = $part_key , c$cnt;
	dec $cnt;
}
let $create_stmt = $create_stmt ) PARTITION BY KEY( $part_key ) PARTITIONS 8;
eval $create_stmt;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;
drop table t1;


