--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: sean.yyj
# tags: optimizer

#--disable_abort_on_error
#

--disable_warnings
drop database if exists db_partition;
--enable_warnings

create database db_partition;
use db_partition;

create table t_part_range(c1 int, c2 int) partition by range(mod(c1,30))
(partition p0 values less than(10),
 partition p1 values less than(20),
 partition p2 values less than(MAXVALUE));
explain select * from t_part_range where c1 > 27 and c1 < 33;
explain select * from t_part_range where c1 > 27 and c1 < 57;
drop table t_part_range;

create table t_part_range(c1 int, c2 int) partition by range(c1 + 10)
(partition p0 values less than(10),
 partition p1 values less than(20),
 partition p2 values less than(MAXVALUE));
explain select * from t_part_range where c1 > 1 and c1 < 3;
drop table t_part_range;

create table t_part_range(c1 int, c2 int) partition by range(c1*10)
(partition p0 values less than(11),
 partition p1 values less than(16),
 partition p2 values less than(MAXVALUE));
explain select * from t_part_range where c1 > 0 and c1 < 5;
drop table t_part_range;

create table t_part_range(c1 int, c2 int) partition by range(abs(c1))
(partition p0 values less than(-50),
 partition p1 values less than(100),
 partition p2 values less than(MAXVALUE));
explain select * from t_part_range where c1 >= -90 and c1 < -70;
explain select * from t_part_range where c1 >= -10 and c1 < 0 or c1 >= -40 and c1 < -30 or c1 >= 10 and c1 < 20 or c1 >= 60 and c1 < 70;
explain select * from t_part_range where c1 >= -10.1 and c1 < -0.2 or c1 >= -40 and c1 < -29.5;
drop table t_part_range;

create table t_part_hash(c1 int, c2 int) partition by hash(c1) partitions 100;
explain select * from t_part_hash where c1 > 1 and c1 < 10;
drop table t_part_hash;

create table t_part_hash (c1 date, c2 time, c3 year, c4 datetime, c5 timestamp) partition by hash (year(c1)) partitions 4;
explain select c1,c2 from t_part_hash where c1 < '2000-02-10';
explain select c1,c2 from t_part_hash where c1 between '2021-02-01' and '2021-02-11';
explain select * from t_part_hash where c1 >= '2021-02-01' and c1 <= '2022-02-11';
drop table t_part_hash;

drop database db_partition;
