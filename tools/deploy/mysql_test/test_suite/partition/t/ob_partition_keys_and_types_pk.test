--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

#owner: peihan.dph
##owner group: sql3

#
##
## Test relation between partitioning keys and prinary keys, unique keys
## Test all supported partition types in oceanbase 1.0: hash , key , linear hash , linear key
##

let $partition_type = HASH;
-- source mysql_test/include/partition_keys_hash_pk.inc

#let $partition_type = LINEAR HASH;
#-- source mysql_test/include/partition_keys_hash.inc

let $partition_type = KEY;
-- source mysql_test/include/partition_keys_key_pk.inc

#let $partition_type = LINEAR KEY;
#-- source mysql_test/include/partition_keys_key.inc

# Test subpartition is not supported
--disable_warnings
drop table if exists t1;
--enable_warnings
--error 1659
CREATE TABLE t1 (id INT, purchased DATE)
    PARTITION BY KEY( purchased )
    SUBPARTITION BY HASH( purchased)
    SUBPARTITIONS 2;

