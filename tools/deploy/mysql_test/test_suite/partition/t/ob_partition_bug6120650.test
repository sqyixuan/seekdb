--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: yuchen.wyc
# owner group: SQL1
# description: 修复bug6120650

--disable_warnings
drop table if exists t2;
--enable_warnings
create table t2(c1 int, c2 int ,primary key(c1,c2)) partition by hash(c2) partitions 5;
insert into  t2 values(2, 1324), (3, 1324), (4, 1324), (5, 1324);
delete from t2 where c2 =1324;
select * from t2 where c2 =1324;
drop table t2;
