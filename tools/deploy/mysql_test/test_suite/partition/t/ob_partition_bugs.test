--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: yuchen.wyc
#owner group: sql4
#description: For partition related bugs recreate

## bug: 
--echo bug: 
--disable_warnings
drop table if exists t1;
create table t1(a int primary key, b char(20)) partition by hash(a) partitions 4;
--enable_warnings
insert into t1 values(1,'a'),(5,'b');
update t1 set b=concat(b,'_up') where a=1 or a=2;
update t1 set b=concat(b,'_up') where a=1 or a=5;
update t1 set b=concat(b,'_up') where a=1 or a=2;
select * from t1 where a>=0;

## bug: 
--echo bug: 
--disable_warnings
drop table if exists dist_t;
--enable_warnings
create table dist_t(c1 int primary key, c2 int) partition by hash (c1) partitions 5;
insert into dist_t values(0, 0);
insert into dist_t values(1, 1);
insert into dist_t values(2, 1);
insert into dist_t values(3, 2);
insert into dist_t values(4, 2);
insert into dist_t values(5, 3);
insert into dist_t values(6, 3);
insert into dist_t values(7, 4);
insert into dist_t values(8, 4);
insert into dist_t values(9, 5);
select sum(c1)+sum(c2), sum(c1) from dist_t group by c2 having sum(c1) > 5 order by c2;
select sum(c1)+sum(c2), sum(c1), sum(c2) from dist_t group by c2 having sum(c1) > 5 order by c2;
select sum(c1)+sum(c2), sum(c1), sum(c2) from dist_t group by c2 order by c2;
select sum(c1)+sum(c2), sum(c1) sum1, sum(c2) from dist_t group by c2 having sum1 > 5 order by c2;
select sum(c1)+sum(c2), sum(c1), sum(c2) from dist_t group by c2 order by c2 limit 3;

##bug: 
--echo bug: 
--disable_warnings
drop table if exists t1;
--enable_warnings

CREATE TABLE t1 (c1 INT NOT NULL, c2 INT)
    PARTITION BY RANGE (c1) PARTITIONS 3 SUBPARTITION BY KEY (c2) (
        PARTITION p1 VALUES LESS THAN (200) (
            SUBPARTITION p11,
            SUBPARTITION p12,
            SUBPARTITION p13),
        PARTITION p2 VALUES LESS THAN (600) (
            SUBPARTITION p21,
            SUBPARTITION p22,
            SUBPARTITION p23),
        PARTITION p3 VALUES LESS THAN (1800) (
            SUBPARTITION p31,
            SUBPARTITION p32,
            SUBPARTITION p33));
show create table t1;
drop table t1;
--error 1064
CREATE TABLE t1 (c1 INT NOT NULL, c2 INT)
    PARTITION BY RANGE (c1) PARTITIONS 4 SUBPARTITION BY KEY (c2) (
        PARTITION p1 VALUES LESS THAN (200) (
            SUBPARTITION p11,
            SUBPARTITION p12,
            SUBPARTITION p13),
        PARTITION p2 VALUES LESS THAN (600) (
            SUBPARTITION p21,
            SUBPARTITION p22,
            SUBPARTITION p23),
        PARTITION p3 VALUES LESS THAN (1800) (
            SUBPARTITION p31,
            SUBPARTITION p32,
            SUBPARTITION p33));