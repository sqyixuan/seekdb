## partition by year/bit type
--disable_warnings
drop table if exists t;
--enable_warnings
create table t(c1 bit(8), c2 int) partition by hash(c1) partitions 5;
insert into t values(0, 0);
insert into t values(1, 1);
insert into t values(2, 2);
insert into t values(3, 3);
insert into t values(4, 4);
insert into t values(5, 5);
insert into t values(6, 6);
insert into t values(254, 254);
insert into t values(255, 255);
select c1, partition_hash(c1), partition_hash(c1) from t;
select c2 from t partition(p0);
select c2 from t partition(p1);
select c2 from t partition(p2);
select c2 from t partition(p3);
select c2 from t partition(p4);


drop table if exists t;
create table t(c1 year, c2 int) partition by hash(c1) partitions 5;
insert into t values(0, 0);
insert into t values(1, 1);
insert into t values(2, 2);
insert into t values(3, 3);
insert into t values(4, 4);
insert into t values(5, 5);
insert into t values(6, 6);
insert into t values(98, 98);
insert into t values(99, 99);
select c1, partition_hash(c1), partition_hash(c1) from t;
select c2 from t partition(p0);
select c2 from t partition(p1);
select c2 from t partition(p2);
select c2 from t partition(p3);
select c2 from t partition(p4);