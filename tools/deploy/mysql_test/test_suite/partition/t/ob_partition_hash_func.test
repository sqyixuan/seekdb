--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

#owner: peihan.dph
#owner group: sql3
# tags: optimizer
#
#
# Test hashing functions
#
#--disable_abort_on_error

# Test hashing in HASH()
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (
	col1 INT, 
	col2 VARCHAR(20), 
	col3 BIGINT, 
PRIMARY KEY (col1, col2), 
UNIQUE KEY (col1, col2) LOCAL)
PARTITION BY HASH(col1)
PARTITIONS 4;

# Insert data
let $cnt = 1000;
--disable_query_log
while ($cnt)
{
	eval INSERT INTO t1 VALUES($cnt, 'C$cnt', $cnt * $cnt);
	dec $cnt;
}
--enable_query_log

# Show rows layout in all partitions
select partition_name , table_rows from information_schema.partitions where table_name='t1' and table_schema='test';

select 
case 
	when	(col1)%(4)=0 then 'p0' 
	when	(col1)%(4)=1 then 'p1' 
	when	(col1)%(4)=2 then 'p2' 
	when	(col1)%(4)=3 then 'p3' 
end as partition_name , count(*) as table_rows 
from t1 group by partition_name;

SELECT col1%4 , count(*) FROM t1 PARTITION(p0) GROUP BY col1%4;
SELECT col1%4 , count(*) FROM t1 PARTITION(p1) GROUP BY col1%4;
SELECT col1%4 , count(*) FROM t1 PARTITION(p2) GROUP BY col1%4;
SELECT col1%4 , count(*) FROM t1 PARTITION(p3) GROUP BY col1%4;

# Show partition info
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;
--disable_result_log
explain partitions select * from t1 where col1=123;
--enable_result_log


