# owner: yibo.tyf
#tags: optimizer
# owner group: SQL1
# tags: partition

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
drop table if exists t1,t2,t3,t4,t5;
--enable_warnings

create table t1 (c1 int, c2 int, c3 int);
create index gidx_t1_c1 on t1 (c1) global;
create index gidx_t1_c2 on t1 (c2) global partition by hash(c2) partitions 2;
insert into t1 values (1,1,1),(2,2,2),(3,3,3),(4,4,4),(5,5,5),(10,10,10),(11,11,11);

create table t2 (c1 int, c2 int, c3 int) partition by hash (c3) partitions 3;
create index gidx_t2_c1 on t2 (c1) global;
create index gidx_t2_c2 on t2 (c2) global partition by hash(c2) partitions 2;
insert into t2 values (1,1,1),(2,2,2),(3,3,3),(4,4,4),(5,5,5),(10,10,10),(11,11,11);

create table t3 (c1 int, c2 int, c3 int) partition by range (c3)
( partition p0 values less than (5),
  partition p1 values less than (10),
  partition p2 values less than (15));
create index gidx_t3_c1 on t3 (c1) global;
create index gidx_t3_c2 on t3 (c2) global partition by hash(c2) partitions 2;
insert into t3 values (1,1,1),(2,2,2),(3,3,3),(4,4,4),(5,5,5),(10,10,10),(11,11,11);

create table t4 (c1 int, c2 int, c3 int) partition by list (c3)
( partition p0 values in (1,4,7,10),
  partition p1 values in (2,5,8,11),
  partition p2 values in (3,6,9,12));
create index gidx_t4_c1 on t4 (c1) global;
create index gidx_t4_c2 on t4 (c2) global partition by hash(c2) partitions 2;
insert into t4 values (1,1,1),(2,2,2),(3,3,3),(4,4,4),(5,5,5),(10,10,10),(11,11,11);

create table t5 (c1 int, c2 int, c3 int) partition by range (c2) subpartition by list (c3)
subpartition template
( subpartition sp0 values in (1,4,7,10),
  subpartition sp1 values in (2,5,8,11),
  subpartition sp2 values in (3,6,9,12))
( partition p0 values less than (5),
  partition p1 values less than (10),
  partition p2 values less than (15));
create index gidx_t5_c1 on t5 (c1) global;
create index gidx_t5_c2 on t5 (c2) global partition by hash(c2) partitions 2;
insert into t5 values (1,1,1),(2,2,2),(3,3,3),(4,4,4),(5,5,5),(10,10,10),(11,11,11);

--result_format 4
--explain_protocol 2
select /*+index(t1 gidx_t1_c1)*/ * from t1;
select /*+index(t1 gidx_t1_c2)*/ * from t1;
select /*+index(t2 gidx_t2_c1)*/ * from t2;
select /*+index(t2 gidx_t2_c2)*/ * from t2;
select /*+index(t3 gidx_t3_c1)*/ * from t3;
select /*+index(t3 gidx_t3_c2)*/ * from t3;
select /*+index(t4 gidx_t4_c1)*/ * from t4;
select /*+index(t4 gidx_t4_c2)*/ * from t4;
select /*+index(t5 gidx_t5_c1)*/ * from t5;
select /*+index(t5 gidx_t5_c2)*/ * from t5;

drop table t1,t2,t3,t4,t5;