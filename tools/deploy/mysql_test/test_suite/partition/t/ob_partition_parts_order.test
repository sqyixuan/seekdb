
#owner: yibo.tyf
#owner group: sql1
# tags: optimizer

--disable_warnings
drop table if exists trs, tr, ts, ts1, t1;
--enable_warnings

create table trs (c1 datetime not null, c2 int, primary key (c1))
  partition by range columns(c1)
  (partition p0 values less than ('2016-1-1 1:1:1.002222'),
   partition p1 values less than ('2017-7-8'));

insert into trs values('2015-1-1 1:1:1.002222', 2);
insert into trs values('2015-10-1 1:1:1.002222', 2);
insert into trs values('2016-10-1 1:1:1.002222', 2);
insert into trs values('2016-11-1 1:1:1.002222', 2);
insert into trs values('2015-11-1 1:1:1.002222', 2);
insert into trs values('2017-1-1 1:1:1.002222', 2);

explain basic select * from trs order by c1;

explain basic select * from trs where c1 > '2015-1-1 1:1:1.002222' order by c1;

explain basic select * from trs where c2 = 2 order by c1;

explain basic select * from trs order by c1 limit 10;

select * from trs order by c1;

select * from trs where c1 > '2015-1-1 1:1:1.002222' order by c1;

select * from trs where c2 = 2 order by c1;

select * from trs order by c1 limit 10;


create table tr(c1 int, c2 int primary key) partition by range(c2)
  (partition p0 values less than (10),
   partition p1 values less than (100),
   partition p2 values less than(1000));

insert into tr values(1, 2);
insert into tr values(2, 3);
insert into tr values(3, 4);
insert into tr values(4, 5);
insert into tr values(5, 6);

explain basic select * from tr where c1 > 1 order by c2;

explain basic select * from tr where c2 > 1 order by c2;

explain basic select * from tr where c2 > 1 and c1 = 1 order by c2 limit 1;

select * from tr where c1 > 1 order by c2;

select * from tr where c2 > 1 order by c2;

select * from tr where c2 > 1 and c1 = 1 order by c2 limit 1;

create table ts(c1 int, c2 datetime, primary key(c1, c2))
  partition by hash(c1)
  subpartition by range columns(c2) subpartition template
  (subpartition p0 values less than ('2013-10-10'),
   subpartition p1 values less than ('2016-3-30')) partitions 2;

insert into ts values(1, '2012-2-2 12:23:1.002222');
insert into ts values(1, '2012-3-2 12:23:1.002222');
insert into ts values(1, '2016-3-2 12:23:1.002222');
insert into ts values(1, '2014-3-2 12:23:1.002222');
insert into ts values(1, '2013-3-2 12:23:1.002222');
insert into ts values(1, '2015-3-2 12:23:1.002222');

explain basic select * from ts where c1 = 1 order by c2 limit 1;

explain basic select * from ts where c1 >= 1 order by c2 limit 1;

select * from ts where c1 = 1 order by c2 limit 1;

select * from ts where c1 >= 1 order by c2 limit 1;


create table ts1(c1 int, c2 datetime, primary key(c1, c2))
  partition by hash(mod(c1, 3))
  subpartition by range columns(c2) subpartition template
  (subpartition p0 values less than ('2013-10-10'),
   subpartition p1 values less than ('2016-3-30')) partitions 2;

insert into ts1 values(1, '2012-2-2 10:12:12.002222');
insert into ts1 values(1, '2013-2-2 10:12:12.002222');
insert into ts1 values(1, '2015-2-2 10:12:12.002222');
insert into ts1 values(1, '2016-2-2 10:12:12.002222');
insert into ts1 values(1, '2014-2-2 10:12:12.002222');

insert into ts1 values(2, '2012-2-2 10:12:12.002222');
insert into ts1 values(2, '2013-2-2 10:12:12.002222');
insert into ts1 values(2, '2015-2-2 10:12:12.002222');
insert into ts1 values(2, '2016-2-2 10:12:12.002222');
insert into ts1 values(2, '2014-2-2 10:12:12.002222');

explain basic select * from ts1 where c1 = 1 order by c2;

#not param
explain basic select * from ts1 where c1 = 1 or c1 = 1 order by c2, c1;

explain basic select * from ts1 where c1 = 1 or c1 = 2 order by c2, c1 desc;

explain basic select * from ts1 where c1 > 1 order by c2, c1;

select * from ts1 where c1 = 1 order by c2, c1;

select * from ts1 where c1 = 1 or c1 = 1 order by c2, c1;

select * from ts1 where c1 = 1 or c1 = 2 order by c2, c1 desc;

select * from ts1 where c1 > 1 order by c2;

create table t1(c1 int, c2 int);

insert into t1 values(1, 2);
insert into t1 values(2, 3);
insert into t1 values(3, 4);

explain basic select/*+leading(trs, t1) use_nl(trs, t1)*/ * from trs, t1 where trs.c2 = t1.c1 order by trs.c1;

explain basic select/*+leading(trs, t1) use_nl(trs, t1)*/ * from trs, t1 where trs.c2 = t1.c1 order by trs.c1 limit 1;

select * from trs, t1 where trs.c2 = t1.c1 order by trs.c1;

drop table trs, tr, ts, ts1, t1;
