      access([t1.c], [t1.b], [t1.a]), partitions(p[0-2])

# Adding more fillers to get index_merge_union
INSERT INTO t1 VALUES (1,1,1+30), (1,1,1+33), (1,1,1+36), (1,1,1+39),
(1,1,1+42), (1,1,1+45), (1,1,1+48), (1,1,1+51), (1,1,1+54), (1,1,1+57),
(1,1,1+60), (1,1,1+63), (1,1,1+66), (1,1,1+69), (1,1,1+72), (1,1,1+75),
(1,1,1+78);
EXPLAIN BASIC SELECT a,b,c FROM t1 WHERE (b = 2 OR a = 2) AND  c > 0 AND c < 100;
Query Plan
==============================
|ID|OPERATOR           |NAME |
------------------------------
|0 |EXCHANGE IN DISTR  |     |
|1 | EXCHANGE OUT DISTR|     |
|2 |  UNION ALL        |     |
|3 |   TABLE SCAN      |t1(b)|
|4 |   TABLE SCAN      |t1(a)|
==============================

Outputs & filters: 
-------------------------------------
  0 - output([UNION(t1.a, t1.a)], [UNION(t1.b, t1.b)], [UNION(t1.c, t1.c)]), filter(nil)
  1 - output([UNION(t1.a, t1.a)], [UNION(t1.b, t1.b)], [UNION(t1.c, t1.c)]), filter(nil)
  2 - output([UNION(t1.a, t1.a)], [UNION(t1.b, t1.b)], [UNION(t1.c, t1.c)]), filter(nil)
  3 - output([t1.a], [t1.b], [t1.c]), filter([t1.c > 0], [t1.c < 100]), 
      access([t1.c], [t1.b], [t1.a]), partitions(p[0-2])
  4 - output([t1.a], [t1.b], [t1.c]), filter([t1.c > 0], [t1.c < 100], [lnnvl(t1.b = 2)]), 
      access([t1.c], [t1.b], [t1.a]), partitions(p[0-2])

SELECT a,b,c FROM t1 WHERE (b = 2 OR a = 2) AND  c > 0 AND c < 100;
