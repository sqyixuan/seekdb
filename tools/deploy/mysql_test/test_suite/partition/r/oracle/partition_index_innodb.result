#
# Bug#18167648: WRONG RESULTS WITH PARTITIONING, INDEX_MERGE AND NO PK
#
drop table if exists t1;
CREATE TABLE t1
(a smallint,
b smallint,
c smallint,
KEY  a (a) LOCAL,
KEY  b (b) LOCAL
)
PARTITION BY HASH(c) PARTITIONS 3;
# c will simulate DB_ROW_ID + force to chosen partition.
# c is unique so we can identify rows in the test.
# Fillers to make the optimizer choose index_merge_intersect/union:
INSERT INTO t1 VALUES (1,1,1), (1,1,1+3), (1,1,1+6), (1,1,1+9);
# row N..N+3
INSERT INTO t1 VALUES (1,2,2+12), (2,2,2+15), (2,2,2+18), (1,2,2+21);
# More index matching rows for index_merge_intersect: N+4, N+5
INSERT INTO t1 VALUES (2,2,1+24);
INSERT INTO t1 VALUES (2,1,1+27);
EXPLAIN BASIC SELECT a,b,c FROM t1 WHERE b = 2 AND a = 2 AND  c > 0 AND c < 100;
Query Plan
==============================
|ID|OPERATOR           |NAME |
------------------------------
|0 |EXCHANGE IN DISTR  |     |
|1 | EXCHANGE OUT DISTR|     |
|2 |  TABLE SCAN       |t1(a)|
==============================

Outputs & filters: 
-------------------------------------
  0 - output([t1.a], [t1.b], [t1.c]), filter(nil)
  1 - output([t1.c], [t1.b], [t1.a]), filter(nil)
  2 - output([t1.c], [t1.b], [t1.a]), filter([t1.b = 2], [t1.c > 0], [t1.c < 100]), 
      access([t1.c], [t1.b], [t1.a]), partitions(p[0-2])

SELECT a,b,c FROM t1 WHERE b = 2 AND a = 2 AND  c > 0 AND c < 100;
a	b	c
2	2	25
2	2	17
2	2	20
EXPLAIN BASIC SELECT a,b,c FROM t1 WHERE a = 2 AND b = 2 AND c IN (13,25,28);
SELECT a,b,c FROM t1 WHERE a = 2 AND b = 2 AND c IN (13,25,28);
a	b	c
2	2	25
SELECT a,b,c FROM t1 WHERE b = 2 AND a = 2 AND  c > 0 AND c < 100;
a	b	c
2	2	25
2	2	17
