set ob_query_timeout=600000000;
set ob_trx_timeout=600000000;
drop table if exists t2;
create table t2 (a int not null, primary key(a)) 
partition by hash (a) partitions 192;
show create table t2;
Table	Create Table
t2	CREATE TABLE `t2` (
  `a` int(11) NOT NULL,
  PRIMARY KEY (`a`)
) DEFAULT CHARSET = utf8mb4 COMPRESSION = 'lz4_1.0' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 10
