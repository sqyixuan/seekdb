c2 INT)  PARTITION BY HASH(c2) PARTITIONS 2;
INSERT INTO t VALUES (-2,-20);
INSERT INTO t(c2) VALUES (30);
SELECT * FROM t ORDER BY c1 ASC;
c1	c2
-2	-20
1	30
DROP TABLE t;
