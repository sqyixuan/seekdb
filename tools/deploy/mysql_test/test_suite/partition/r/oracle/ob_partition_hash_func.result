select 
case 
when	(col1)%(4)=0 then 'p0' 
when	(col1)%(4)=1 then 'p1' 
when	(col1)%(4)=2 then 'p2' 
when	(col1)%(4)=3 then 'p3' 
end as partition_name , count(*) as table_rows 
from t1 group by partition_name;
