drop table if exists t1;
CREATE TABLE t1 (
col1 INT, 
col2 VARCHAR(20), 
col3 BIGINT, 
PRIMARY KEY (col1, col2), 
UNIQUE KEY (col1, col2) LOCAL)
PARTITION BY HASH(col1)
PARTITIONS 4;
