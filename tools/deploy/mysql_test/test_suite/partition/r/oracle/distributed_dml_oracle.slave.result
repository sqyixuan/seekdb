create table t1(a int, b date, c varchar(20), primary key(b, c))
partition by range (b, c) (
partition p0 values less than (to_date('2015-01-01 00:00:00','YYYY-MM-DD HH24:MI:SS'), 'abc'),
partition p1 values less than (to_date('2016-01-01 00:00:00','YYYY-MM-DD HH24:MI:SS'), 'bcd'),
partition p2 values less than (to_date('2017-01-01 00:00:00','YYYY-MM-DD HH24:MI:SS'), 'cde'),
partition p3 values less than (MAXVALUE, MAXVALUE)
);
