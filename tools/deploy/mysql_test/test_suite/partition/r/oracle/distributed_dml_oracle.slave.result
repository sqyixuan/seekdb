CREATE TABLE info_t(id INT, gmt_create DATE, info VARCHAR(20), PRIMARY KEY (gmt_create))
PARTITION BY RANGE (gmt_create)
(PARTITION p0 VALUES LESS THAN (to_date('2015-01-01 00:00:00','YYYY-MM-DD HH24:MI:SS')),
PARTITION p1 VALUES LESS THAN (to_date('2016-01-01 00:00:00','YYYY-MM-DD HH24:MI:SS')),
PARTITION p2 VALUES LESS THAN (to_date('2017-01-01 00:00:00','YYYY-MM-DD HH24:MI:SS')),
PARTITION p3 VALUES LESS THAN (MAXVALUE));
