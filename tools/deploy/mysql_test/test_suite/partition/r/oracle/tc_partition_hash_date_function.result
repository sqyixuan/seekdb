DROP TABLE IF EXISTS t2;
CREATE TABLE t2 (c1 TINYINT NULL, c2 CHAR(5),c3 DATETIME) PARTITION BY HASH(MONTH(c3));
SHOW CREATE TABLE t2;
Table	Create Table
t2	CREATE TABLE `t2` (
  `c1` tinyint(4) DEFAULT NULL,
  `c2` char(5) DEFAULT NULL,
  `c3` datetime DEFAULT NULL
) DEFAULT CHARSET = utf8mb4 COMPRESSION = 'lz4_1.0' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 10
 partition by hash(month(c3)) partitions 1

