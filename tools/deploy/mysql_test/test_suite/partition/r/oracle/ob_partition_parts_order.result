drop table if exists trs, tr, ts, ts1, t1;
create table trs (c1 datetime not null, c2 int, primary key (c1))
partition by range columns(c1)
(partition p0 values less than ('2016-1-1 1:1:1.002222'),
partition p1 values less than ('2017-7-8'));
insert into trs values('2015-1-1 1:1:1.002222', 2);
insert into trs values('2015-10-1 1:1:1.002222', 2);
insert into trs values('2016-10-1 1:1:1.002222', 2);
insert into trs values('2016-11-1 1:1:1.002222', 2);
insert into trs values('2015-11-1 1:1:1.002222', 2);
insert into trs values('2017-1-1 1:1:1.002222', 2);
explain basic select * from trs order by c1;
Query Plan
======================================
|ID|OPERATOR                    |NAME|
--------------------------------------
|0 |EXCHANGE IN TASK ORDER DISTR|    |
|1 | EXCHANGE OUT DISTR         |    |
|2 |  TABLE SCAN                |trs |
======================================

Outputs & filters: 
-------------------------------------
  0 - output([trs.c1], [trs.c2]), filter(nil), task_order
  1 - output([trs.c1], [trs.c2]), filter(nil)
  2 - output([trs.c1], [trs.c2]), filter(nil), 
      access([trs.c1], [trs.c2]), partitions(p[0-1])

