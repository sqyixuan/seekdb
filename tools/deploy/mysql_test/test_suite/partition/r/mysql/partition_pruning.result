set @@recyclebin = off;
drop table if exists t1,t2,t3,t4,t5,t6,t7,t8,t9;
create table t1 ( a int not null) partition by hash(a) partitions 2;
insert into t1 values (1);
insert into t1 values (2);
insert into t1 values (3);
drop table t1;
create table t1 (
a int(11) not null
) partition by hash (a) partitions 2;
insert into t1 values (1);
insert into t1 values (2);
insert into t1 values (3);
create table t2 (
a int not null,
b int not null
) partition by key(a,b) partitions 2;
insert into t2 values (1,1);
insert into t2 values (2,2);
insert into t2 values (3,3);
drop table t1;
create table t1 (a int) partition by hash(a) partitions 2;
insert into t1 values (1);
insert into t1 values (2);
drop table t1;
create table t1 (a int not null, b int not null, key(a) LOCAL, key(b) LOCAL)
partition by hash(a) partitions 4;
insert into t1 values (1,1);
insert into t1 values (2,2);
insert into t1 values (3,3);
insert into t1 values (4,4);
select * from t1 X, t1 Y 
where X.b = Y.b and (X.a=1 or X.a=2) and (Y.a=2 or Y.a=3);
a	b	a	b
2	2	2	2
set _nlj_batching_enabled=false;
select * from t1 X, t1 Y where X.a = Y.a and (X.a=1 or X.a=2);
a	b	a	b
1	1	1	1
2	2	2	2
drop table t1;
create table t1 (a int) partition by hash(a) partitions 20;
insert into t1 values (1);
insert into t1 values (2);
insert into t1 values (3);
drop table t1;
create table t1 (a char(32) primary key)
partition by key()
partitions 100;
insert into t1 values ('na');
select * from t1;
a
na
select * from t1 where a like 'n%';
a
na
drop table t1;
create table t1 (s1 varchar(15)) partition by key (s1);
select * from t1 where s1 = 0 or s1 is null;
s1
insert into t1 values ('aa'),('bb'),('0');
drop table t1;
drop table if exists t1,t2,t3,t4,t5,t6,t7,t8,t9;
