SET @max_row = 20;

#------------------------------------------------------------------------
#  0. Setting of auxiliary variables + Creation of an auxiliary tables
#     needed in many testcases
#------------------------------------------------------------------------
DROP TABLE IF EXISTS t0_template;
CREATE TABLE t0_template (
f_int1 INTEGER,
f_int2 INTEGER,
f_char1 CHAR(20),
f_char2 CHAR(20),
f_charbig VARCHAR(1000) ,
PRIMARY KEY(f_int1));
DROP TABLE IF EXISTS t0_definition;
CREATE TABLE t0_definition (
state CHAR(3),
create_command VARBINARY(5000),
file_list      VARBINARY(10000),
PRIMARY KEY (state));
DROP TABLE IF EXISTS t0_aux;
CREATE TABLE t0_aux ( f_int1 INTEGER,
f_int2 INTEGER,
f_char1 CHAR(20),
f_char2 CHAR(20),
f_charbig VARCHAR(1000) );
SET AUTOCOMMIT= 1;
SET @@session.sql_mode= '';
# End of basic preparations needed for all tests
#-----------------------------------------------

#========================================================================
#  Check partitioning methods on just created tables
#  The tables should be defined without/with PRIMARY KEY and
#  UNIQUE INDEXes.
#  Every test round has to check
#        PARTITION BY HASH/KEY/LIST/RANGE
#        PARTITION BY RANGE/LIST ... SUBPARTITION BY HASH/KEY ...
#========================================================================
#------------------------------------------------------------------------
#  1   Tables without PRIMARY KEY or UNIQUE INDEXes
#------------------------------------------------------------------------
#  1.1 The partitioning function contains one column.
DROP TABLE IF EXISTS t1;
CREATE TABLE t1 (
f_int1 INTEGER,
f_int2 INTEGER,
f_char1 CHAR(20),
f_char2 CHAR(20),
f_charbig VARCHAR(1000)

)
PARTITION BY HASH(f_int1) PARTITIONS 2;
DROP TABLE t1;
CREATE TABLE t1 (
f_int1 INTEGER,
f_int2 INTEGER,
f_char1 CHAR(20),
f_char2 CHAR(20),
f_charbig VARCHAR(1000)

)
PARTITION BY KEY(f_int1) PARTITIONS 5;
DROP TABLE t1;
#  1.2 The partitioning function contains two columns.
DROP TABLE IF EXISTS t1;
CREATE TABLE t1 (
f_int1 INTEGER,
f_int2 INTEGER,
f_char1 CHAR(20),
f_char2 CHAR(20),
f_charbig VARCHAR(1000)

)
PARTITION BY HASH(f_int1 + f_int2) PARTITIONS 2;
DROP TABLE t1;
CREATE TABLE t1 (
f_int1 INTEGER,
f_int2 INTEGER,
f_char1 CHAR(20),
f_char2 CHAR(20),
f_charbig VARCHAR(1000)

)
PARTITION BY KEY(f_int1,f_int2) PARTITIONS 5;
DROP TABLE t1;
#------------------------------------------------------------------------
#  2   Tables with PRIMARY KEY and/or UNIQUE INDEXes
#        The partitioning function contains one column.
#------------------------------------------------------------------------
#  2.5 PRIMARY KEY + UNIQUE INDEX consisting of two columns
DROP TABLE IF EXISTS t1;
CREATE TABLE t1 (
f_int1 INTEGER,
f_int2 INTEGER,
f_char1 CHAR(20),
f_char2 CHAR(20),
f_charbig VARCHAR(1000)
, UNIQUE INDEX uidx1 (f_int1,f_int2) LOCAL, PRIMARY KEY(f_int2,f_int1)
)
PARTITION BY HASH(f_int1) PARTITIONS 2;
DROP TABLE t1;
CREATE TABLE t1 (
f_int1 INTEGER,
f_int2 INTEGER,
f_char1 CHAR(20),
f_char2 CHAR(20),
f_charbig VARCHAR(1000)
, UNIQUE INDEX uidx1 (f_int1,f_int2) LOCAL, PRIMARY KEY(f_int2,f_int1)
)
PARTITION BY KEY(f_int1) PARTITIONS 5;
DROP TABLE t1;
DROP TABLE IF EXISTS t1;
CREATE TABLE t1 (
f_int1 INTEGER,
f_int2 INTEGER,
f_char1 CHAR(20),
f_char2 CHAR(20),
f_charbig VARCHAR(1000)
, UNIQUE INDEX uidx1 (f_int2,f_int1) LOCAL, PRIMARY KEY(f_int1,f_int2)
)
PARTITION BY HASH(f_int1) PARTITIONS 2;
DROP TABLE t1;
CREATE TABLE t1 (
f_int1 INTEGER,
f_int2 INTEGER,
f_char1 CHAR(20),
f_char2 CHAR(20),
f_charbig VARCHAR(1000)
, UNIQUE INDEX uidx1 (f_int2,f_int1) LOCAL, PRIMARY KEY(f_int1,f_int2)
)
PARTITION BY KEY(f_int1) PARTITIONS 5;
DROP TABLE t1;
DROP TABLE IF EXISTS t1;
CREATE TABLE t1 (
f_int1 INTEGER,
f_int2 INTEGER,
f_char1 CHAR(20),
f_char2 CHAR(20),
f_charbig VARCHAR(1000)
, UNIQUE INDEX uidx1 (f_int1,f_int2) LOCAL, UNIQUE INDEX uidx2 (f_int2,f_int1) LOCAL
)
PARTITION BY HASH(f_int1) PARTITIONS 2;
DROP TABLE t1;
CREATE TABLE t1 (
f_int1 INTEGER,
f_int2 INTEGER,
f_char1 CHAR(20),
f_char2 CHAR(20),
f_charbig VARCHAR(1000)
, UNIQUE INDEX uidx1 (f_int1,f_int2) LOCAL, UNIQUE INDEX uidx2 (f_int2,f_int1) LOCAL
)
PARTITION BY KEY(f_int1) PARTITIONS 5;
DROP TABLE t1;
#------------------------------------------------------------------------
#  3   Tables with PRIMARY KEY and/or UNIQUE INDEXes
#        The partitioning function contains two columns.
#------------------------------------------------------------------------
#  3.3 PRIMARY KEY and UNIQUE INDEX consisting of two columns
DROP TABLE IF EXISTS t1;
CREATE TABLE t1 (
f_int1 INTEGER,
f_int2 INTEGER,
f_char1 CHAR(20),
f_char2 CHAR(20),
f_charbig VARCHAR(1000)
, UNIQUE INDEX uidx1 (f_int1,f_int2) LOCAL, PRIMARY KEY(f_int2,f_int1)
)
PARTITION BY HASH(f_int1 + f_int2) PARTITIONS 2;
DROP TABLE t1;
CREATE TABLE t1 (
f_int1 INTEGER,
f_int2 INTEGER,
f_char1 CHAR(20),
f_char2 CHAR(20),
f_charbig VARCHAR(1000)
, UNIQUE INDEX uidx1 (f_int1,f_int2) LOCAL, PRIMARY KEY(f_int2,f_int1)
)
PARTITION BY KEY(f_int1,f_int2) PARTITIONS 5;
DROP TABLE t1;
DROP TABLE IF EXISTS t1;
CREATE TABLE t1 (
f_int1 INTEGER,
f_int2 INTEGER,
f_char1 CHAR(20),
f_char2 CHAR(20),
f_charbig VARCHAR(1000)
, UNIQUE INDEX uidx1 (f_int2,f_int1) LOCAL, PRIMARY KEY(f_int1,f_int2)
)
PARTITION BY HASH(f_int1 + f_int2) PARTITIONS 2;
DROP TABLE t1;
CREATE TABLE t1 (
f_int1 INTEGER,
f_int2 INTEGER,
f_char1 CHAR(20),
f_char2 CHAR(20),
f_charbig VARCHAR(1000)
, UNIQUE INDEX uidx1 (f_int2,f_int1) LOCAL, PRIMARY KEY(f_int1,f_int2)
)
PARTITION BY KEY(f_int1,f_int2) PARTITIONS 5;
DROP TABLE t1;
DROP TABLE IF EXISTS t1;
CREATE TABLE t1 (
f_int1 INTEGER,
f_int2 INTEGER,
f_char1 CHAR(20),
f_char2 CHAR(20),
f_charbig VARCHAR(1000)
, UNIQUE INDEX uidx1 (f_int1,f_int2) LOCAL, UNIQUE INDEX uidx2 (f_int2,f_int1) LOCAL
)
PARTITION BY HASH(f_int1 + f_int2) PARTITIONS 2;
DROP TABLE t1;
CREATE TABLE t1 (
f_int1 INTEGER,
f_int2 INTEGER,
f_char1 CHAR(20),
f_char2 CHAR(20),
f_charbig VARCHAR(1000)
, UNIQUE INDEX uidx1 (f_int1,f_int2) LOCAL, UNIQUE INDEX uidx2 (f_int2,f_int1) LOCAL
)
PARTITION BY KEY(f_int1,f_int2) PARTITIONS 5;
DROP TABLE t1;
DROP VIEW  IF EXISTS v1;
DROP TABLE IF EXISTS t1;
DROP TABLE IF EXISTS t0_aux;
DROP TABLE IF EXISTS t0_definition;
DROP TABLE IF EXISTS t0_template;
