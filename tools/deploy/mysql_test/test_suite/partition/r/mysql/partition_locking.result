#
# Test of BEFORE UPDATE triggers and multi UPDATE
#
CREATE TABLE t1 (a int, b varchar(128), KEY (b) LOCAL)
PARTITION BY HASH (a) PARTITIONS 13;
CREATE TABLE t2 (a int PRIMARY KEY, b varchar(128))
PARTITION BY HASH (a) PARTITIONS 13;
INSERT INTO t1 VALUES (1, "MultiUpdate1");
INSERT INTO t1 VALUES (2, "MultiUpdate2");
INSERT INTO t2 VALUES (1, "MultiUpdate1");
INSERT INTO t2 VALUES (2, "MultiUpdate2");
EXPLAIN BASIC UPDATE t1, t2
SET t1.b = CONCAT(t1.b, ",(1) t2.b:", t2.b),
t2.b = CONCAT(t2.b, ",(1) t1.b:", t1.b)
WHERE t2.b = t1.b and t1.a = 1;
Query Plan
===========================================
|ID|OPERATOR                     |NAME    |
-------------------------------------------
|0 |DISTRIBUTED UPDATE           |        |
|1 |â””â”€HASH JOIN                  |        |
|2 |  â”śâ”€TABLE FULL SCAN          |t1      |
|3 |  â””â”€PX COORDINATOR           |        |
|4 |    â””â”€EXCHANGE OUT DISTR     |:EX10000|
|5 |      â””â”€PX PARTITION ITERATOR|        |
|6 |        â””â”€TABLE FULL SCAN    |t2      |
===========================================
Outputs & filters:
-------------------------------------
  0 - output(nil), filter(nil)
      table_columns([{t1: ({t1: (t1.__pk_increment, t1.a, t1.b)}), hash_distinct}], [{t2: ({t2: (t2.a, t2.b)}), hash_distinct}]),
      update([t1.b=column_conv(VARCHAR,utf8mb4_general_ci,length:128,NULL,CONCAT(t1.b, ',(1) t2.b:', t2.b))], [t2.b=column_conv(VARCHAR,utf8mb4_general_ci,
      length:128,NULL,CONCAT(t2.b, ',(1) t1.b:', t1.b))])
  1 - output([t1.__pk_increment], [t1.a], [t1.b], [t2.a], [t2.b]), filter(nil), rowset=16
      equal_conds([t2.b = t1.b]), other_conds(nil)
  2 - output([t1.__pk_increment], [t1.a], [t1.b]), filter([t1.a = 1]), rowset=16
      access([t1.__pk_increment], [t1.a], [t1.b]), partitions(p1)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([t1.__pk_increment]), range(MIN ; MAX)always true
  3 - output([t2.a], [t2.b]), filter(nil), rowset=16
  4 - output([t2.a], [t2.b]), filter(nil), rowset=16
      dop=1
  5 - output([t2.a], [t2.b]), filter(nil), rowset=16
      force partition granule
  6 - output([t2.a], [t2.b]), filter(nil), rowset=16
      access([t2.a], [t2.b]), partitions(p[0-12])
      is_index_back=false, is_global_index=false, 
      range_key([t2.a]), range(MIN ; MAX)always true
