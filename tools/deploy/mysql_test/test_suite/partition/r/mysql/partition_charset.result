ERROR HY000: This partition function is not allowed
CREATE TABLE t1 (
city varchar(10) NOT NULL,
id int
) DEFAULT CHARSET = gbk
partition by list columns(city,id)
(partition p0 values in (('北京',1),('上海',2)),
partition p1 values in (('成都',4),('天津',3)));
alter table t1 add partition (partition p3 values in (('湖',4)));
drop table t1;
CREATE TABLE t1 (
city varchar(10) NOT NULL,
id int
) DEFAULT CHARSET = gbk
partition by range columns(id, city)
(partition p0 values less than (1, '北京'),
partition p1 values less than (2, '上海'),
partition p2 values less than (3, '成都'),
partition p3 values less than (4, '天津'));
alter table t1 add partition (partition p4 values less than (5, '湖'));
drop table t1;
