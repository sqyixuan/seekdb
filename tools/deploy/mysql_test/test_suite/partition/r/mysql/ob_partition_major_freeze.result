drop table if exists part_major_freeze_t, index_major_freeze_t;
create table part_major_freeze_t(c1 int, c2 datetime, c3 int, c4 int) partition by hash(c1) subpartition by range columns(c2) subpartition template(subpartition p0 values less than('2016-01-01'), subpartition p1 values less than('2016-02-01'), subpartition p2 values less than('2016-03-01'), subpartition p3 values less than('2016-04-01')) partitions 5;
insert into part_major_freeze_t values(1, '2012-01-02', 1, 1);
insert into part_major_freeze_t values(2, '2016-01-02', 1, 1);
create table index_major_freeze_t(c1 int, c2 datetime, c3 int, c4 int, key t_c2(c2) LOCAL) partition by hash(c1) subpartition by range columns(c2) subpartition template(subpartition p0 values less than('2016-01-01'), subpartition p1 values less than('2016-02-01'), subpartition p2 values less than('2016-03-01'), subpartition p3 values less than('2016-04-01')) partitions 5;
insert into index_major_freeze_t values(1, '2012-01-02', 1, 1);
insert into index_major_freeze_t values(2, '2016-01-02', 1, 1);
alter system major freeze tenant = sys;
alter system major freeze tenant = all_user;
alter system major freeze tenant = all_meta;
select * from part_major_freeze_t order by c1;
c1	c2	c3	c4
1	2012-01-02 00:00:00	1	1
2	2016-01-02 00:00:00	1	1
drop table part_major_freeze_t, index_major_freeze_t;
