drop table if exists t1,t2,t3,tmp_t;
create table t1 (c1 int primary key, c2 int, c3 int);
create table t2 (c1 int primary key, c2 int, c3 int) partition by range (c1)
(
partition p0 values less than (100),
partition p1 values less than (200),
partition p2 values less than (300),
partition p3 values less than (400)
);
create table t3 (c1 int, c2 int, c3 int, primary key (c1,c2)) partition by range (c1)
subpartition by hash(c2) subpartitions 16
(
partition p0 values less than (100),
partition p1 values less than (200),
partition p2 values less than (300),
partition p3 values less than (400)
);
create table tmp_t (c1 int, c2 int, c3 int);
explain_protocol: 2
result_format: 4
## use partition on non partitioned table
EXPLAIN select * from t1 partition(p0);
