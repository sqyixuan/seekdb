drop table if exists ts;
create table ts(c1 varchar(20), c2 datetime, primary key(c1, c2),c3 varchar(8) generated always as (substring(c1, 10)) virtual ) partition by key(c3) subpartition by range columns(c2) subpartition template (subpartition p0 values less than ('2013-10-10'),  subpartition p1 values less than ('2016-3-30')) partitions 16;
explain insert into ts(c1,c2) values("buyerxxx-nijia.nj", "2013-09-10");
Query Plan
==================================================
|ID|OPERATOR          |NAME|EST.ROWS|EST.TIME(us)|
--------------------------------------------------
|0 |DISTRIBUTED INSERT|    |1       |13          |
|1 |└─EXPRESSION      |    |1       |1           |
==================================================
Outputs & filters:
-------------------------------------
  0 - output(nil), filter(nil)
      columns([{ts: ({ts: (ts.c1, ts.c2, ts.c3)})}]), 
      column_values([column_conv(VARCHAR,utf8mb4_general_ci,length:20,NOT NULL,__values.c1)], [column_conv(MYSQL_DATETIME,PS:(19,0),NOT NULL,__values.c2)],
       [column_conv(VARCHAR,utf8mb4_general_ci,length:8,NULL,column_conv(VARCHAR,utf8mb4_general_ci,length:8,NULL,substr(column_conv(VARCHAR,utf8mb4_general_ci,
      length:20,NOT NULL,__values.c1), 10)))])
  1 - output([__values.c1], [__values.c2]), filter(nil)
      values({'buyerxxx-nijia.nj', '2013-09-10'})
