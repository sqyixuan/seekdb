------------------------- test each expr and data_type -------------------------
# to_days(datetime)
create table t_part_range (c1 int, c2 int, c3 datetime) partition by range (to_days(c3))
(partition p0 values less than (to_days('2000-01-01')),
partition p1 values less than (to_days('2010-01-01')),
partition p2 values less than (to_days('2020-01-01'))
);
explain select * from t_part_range where c3 >= '2004-04-04 04:04:04' and c3 <= '2008-08-08 08:08:08';
Query Plan
=======================================================
|ID|OPERATOR       |NAME        |EST.ROWS|EST.TIME(us)|
-------------------------------------------------------
|0 |TABLE FULL SCAN|t_part_range|1       |3           |
=======================================================
Outputs & filters:
-------------------------------------
  0 - output([t_part_range.c1], [t_part_range.c2], [t_part_range.c3]), filter([t_part_range.c3 >= cast('2004-04-04 04:04:04', MYSQL_DATETIME(-1, -1))], 
      [t_part_range.c3 <= cast('2008-08-08 08:08:08', MYSQL_DATETIME(-1, -1))]), rowset=16
      access([t_part_range.c3], [t_part_range.c1], [t_part_range.c2]), partitions(p1)
      is_index_back=false, is_global_index=false, filter_before_indexback[false,false], 
      range_key([t_part_range.__pk_increment]), range(MIN ; MAX)always true
drop table t_part_range;
