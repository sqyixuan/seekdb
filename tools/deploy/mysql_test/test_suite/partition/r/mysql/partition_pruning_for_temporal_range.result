# test range-range partition
CREATE TABLE t_range_range (c1 int, c2 datetime, c3 datetime)
partition by range (year(c2)) subpartition by range(year(c3))
subpartition template
(subpartition p0_0 values less than (2000),
subpartition p0_1 values less than (2010),
subpartition p0_2 values less than (2020)
)
(partition p0 values less than (2000),
partition p1 values less than (2010),
partition p2 values less than (2020)
);
