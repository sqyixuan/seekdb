# hash(year(datetime)) with multi range
create table t_part_hash (c1 int, c2 int, c3 datetime) partition by hash (year(c3)) partitions 3;
explain select * from t_part_hash where (c3 >= '2004-04-04 04:04:04' and c3 <= '2004-08-08 08:08:08') or (c3 >= '2000-04-04 04:04:04' and c3 <= '2000-08-08 08:08:08');
