| c1                  |
+---------------------+
| 2024-01-01 12:00:00 |
| 2024-02-01 12:00:00 |
| 2024-03-01 12:00:00 |
+---------------------+
select * from t_timestamp_range2 partition(p1);
+---------------------+
| c1                  |
+---------------------+
| 2024-04-01 12:00:00 |
| 2024-05-01 12:00:00 |
| 2024-06-01 12:00:00 |
| 2024-07-01 12:00:00 |
+---------------------+
select * from t_timestamp_range2 partition(p2);
+---------------------+
| c1                  |
+---------------------+
| 2024-08-01 12:00:00 |
| 2024-09-01 12:00:00 |
| 2024-10-01 12:00:00 |
+---------------------+

create table t_timestamp_range3(c1 timestamp) partition by range columns(c1)
(
  partition p0 values less than (date '2024-04-01'),
  partition p1 values less than (date '2024-08-01'),
  partition p2 values less than (date '2024-12-01')
);
insert into t_timestamp_range3 values (timestamp '2024-01-01 12:00:00'), (timestamp '2024-02-01 12:00:00'), (timestamp '2024-03-01 12:00:00'),
                                    (timestamp '2024-04-01 12:00:00'), (timestamp '2024-05-01 12:00:00'), (timestamp '2024-06-01 12:00:00'),
                                    (timestamp '2024-07-01 12:00:00'), (timestamp '2024-08-01 12:00:00'), (timestamp '2024-09-01 12:00:00'),
                                    (timestamp '2024-10-01 12:00:00');
select * from t_timestamp_range3 partition(p0);
+---------------------+
| c1                  |
+---------------------+
| 2024-01-01 12:00:00 |
| 2024-02-01 12:00:00 |
| 2024-03-01 12:00:00 |
+---------------------+
select * from t_timestamp_range3 partition(p1);
+---------------------+
| c1                  |
+---------------------+
| 2024-04-01 12:00:00 |
| 2024-05-01 12:00:00 |
| 2024-06-01 12:00:00 |
| 2024-07-01 12:00:00 |
+---------------------+
select * from t_timestamp_range3 partition(p2);
+---------------------+
| c1                  |
+---------------------+
| 2024-08-01 12:00:00 |
| 2024-09-01 12:00:00 |
| 2024-10-01 12:00:00 |
+---------------------+

create table t_timestamp_range4(c1 timestamp) partition by range columns(c1)
(
  partition p0 values less than (time '08:00:00'),
  partition p1 values less than (time '16:00:00'),
  partition p2 values less than (time '24:00:00')
);
insert into t_timestamp_range4 values ('1970-01-01 01:00:00'), ('1970-01-01 02:00:00'), ('1970-01-01 03:00:00'),
                                      ('1970-01-01 04:00:00'), ('1970-01-01 05:00:00'), ('1970-01-01 06:00:00'),
                                      ('1970-01-01 07:00:00'), ('1970-01-01 08:00:00'), ('1970-01-01 09:00:00'),
                                      ('1970-01-01 10:00:00');
select * from t_timestamp_range4 partition(p0);
+---------------------+
| c1                  |
+---------------------+
| 1970-01-01 01:00:00 |
| 1970-01-01 02:00:00 |
| 1970-01-01 03:00:00 |
| 1970-01-01 04:00:00 |
| 1970-01-01 05:00:00 |
| 1970-01-01 06:00:00 |
| 1970-01-01 07:00:00 |
+---------------------+
select * from t_timestamp_range4 partition(p1);
+---------------------+
| c1                  |
+---------------------+
| 1970-01-01 08:00:00 |
| 1970-01-01 09:00:00 |
| 1970-01-01 10:00:00 |
+---------------------+
select * from t_timestamp_range4 partition(p2);
+----+
| c1 |
+----+
+----+

drop table if exists t_decimal_range, t_udecimal_range, t_float_range, t_ufloat_range,
                     t_double_range, t_udouble_range, t_timestamp_range1, t_timestamp_range2,
                     t_timestamp_range3, t_timestamp_range4;
