partition by range columns(b, c) (
partition p0 values less than ('2015-01-01', 'abc'),
partition p1 values less than ('2016-01-01', 'bcd'),
partition p2 values less than ('2017-01-01', 'cde'),
partition p3 values less than (MAXVALUE, MAXVALUE)
);
