drop table if exists t1;
CREATE TABLE t1 (
col1 INT, 
col2 VARCHAR(20), 
col3 BIGINT PRIMARY KEY)
PARTITION BY HASH(col3)
PARTITIONS 4;
INSERT INTO t1 VALUES(4, 'C4', 4 * 4);
INSERT INTO t1 VALUES(3, 'C3', 3 * 3);
INSERT INTO t1 VALUES(2, 'C2', 2 * 2);
INSERT INTO t1 VALUES(1, 'C1', 1 * 1);
