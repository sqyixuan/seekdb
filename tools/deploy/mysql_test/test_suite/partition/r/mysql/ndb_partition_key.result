select * from nott1 where a=0 order by c;
a	b	c
0	0	0
0	1	1
0	2	2
0	3	3
Single partition scan
select * from nott1 where a=4 order by c;
a	b	c
MRR scan on one partition
select * from nott1 where a=0 and (( b > 0 and b < 3) or 
( b > 5 and b < 10) or 
( b > 22 and b < 50)) order by c;
a	b	c
0	1	1
0	2	2
