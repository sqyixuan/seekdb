DROP TABLE IF EXISTS t1;
#
# Bug#12696518/Bug#11766879/60106:DIFF BETWEEN # OF INDEXES IN MYSQL
# VS INNODB, PARTITONING, ON INDEX CREATE
#
CREATE TABLE t1 (a INT PRIMARY KEY, b VARCHAR(64))PARTITION BY HASH (a) PARTITIONS 3;
INSERT INTO t1 VALUES (0, 'first row');
INSERT INTO t1 VALUES (1, 'second row');
INSERT INTO t1 VALUES (2, 'Third row');
INSERT INTO t1 VALUES (3, 'row id 3');
INSERT INTO t1 VALUES (4, '4 row');
INSERT INTO t1 VALUES (5, 'row5');
INSERT INTO t1 VALUES (6, 'X 6 row');
INSERT INTO t1 VALUES (7, 'Seventh row');
INSERT INTO t1 VALUES (8, 'Last row');
ALTER TABLE t1 ADD INDEX new_b_index (b) LOCAL;
ALTER TABLE t1 DROP INDEX new_b_index;
ALTER TABLE t1 ADD INDEX (b) LOCAL;
