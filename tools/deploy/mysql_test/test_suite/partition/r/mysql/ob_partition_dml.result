drop table if exists t1,t2;
CREATE TABLE t1 (c1 INT,	c2 VARCHAR(100), c3 BIGINT,	PRIMARY KEY(c1,c2),	KEY(c1) LOCAL) PARTITION BY HASH (c1) PARTITIONS 4;
CREATE TABLE t2 (c1 INT,	c2 VARCHAR(100), c3 BIGINT,	PRIMARY KEY(c1,c2),	KEY(c1) LOCAL) PARTITION BY HASH (c1) PARTITIONS 4;
