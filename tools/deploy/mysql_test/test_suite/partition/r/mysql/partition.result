|2 |  └─MERGE DISTINCT                |        |
|3 |    └─EXCHANGE IN MERGE SORT DISTR|        |
|4 |      └─EXCHANGE OUT DISTR (HASH) |:EX10000|
|5 |        └─PX PARTITION ITERATOR   |        |
|6 |          └─MERGE DISTINCT        |        |
|7 |            └─TABLE RANGE SCAN    |t1(bc)  |
================================================
Outputs & filters:
-------------------------------------
  0 - output([INTERNAL_FUNCTION(t1.b, t1.c)]), filter(nil), rowset=256
  1 - output([INTERNAL_FUNCTION(t1.b, t1.c)]), filter(nil), rowset=256
      dop=1
  2 - output([t1.c], [t1.b]), filter(nil), rowset=256
      distinct([t1.c])
  3 - output([t1.c], [t1.b]), filter(nil), rowset=256
      sort_keys([t1.c, ASC]), Local Order
  4 - output([t1.c], [t1.b]), filter(nil), rowset=256
      (#keys=1, [t1.c]), dop=1
  5 - output([t1.c], [t1.b]), filter(nil), rowset=256
      force partition granule
  6 - output([t1.c], [t1.b]), filter(nil), rowset=256
      distinct([t1.c])
  7 - output([t1.b], [t1.c]), filter(nil), rowset=256
      access([t1.b], [t1.c]), partitions(p[0-2])
      is_index_back=false, is_global_index=false, 
      range_key([t1.b], [t1.c], [t1.__pk_increment]), range(1,MIN,MIN ; 1,MAX,MAX), 
      range_cond([t1.b = 1])

DROP TABLE t1;

