create table t1
 (s1 timestamp on update current_timestamp, s2 int)
 partition by key(s1) partitions 3;

insert into t1 values (null,null);
drop table t1;

create table t1 (
  c0 int,
  c1 bigint,
  c2 char(20),
  key (c2,c1,c0) LOCAL,
  key(c0) LOCAL
) partition by hash (c0) partitions 5;

insert into t1 set c0 = -6502262, c1 = 3992917, c2 = 35019;
insert into t1 set c0 = 241221, c1 = -6862346, c2 = 56644;
select c1 from t1 group by (select c0 from t1 limit 1);
+----------+
| c1       |
+----------+
| -6862346 |
+----------+
drop table t1;

