drop table if exists t1;
create table t1(c1 int primary key, c2 int, c3 char(20), c4 int, index i1(c2) local, index i2(c3,c4) local) partition by hash(c1) partitions 4;
show create table t1;
Table	Create Table
t1	CREATE TABLE `t1` (
  `c1` int(11) NOT NULL,
  `c2` int(11) DEFAULT NULL,
  `c3` char(20) DEFAULT NULL,
  `c4` int(11) DEFAULT NULL,
  PRIMARY KEY (`c1`),
  KEY `i1` (`c2`) BLOCK_SIZE 16384 LOCAL,
  KEY `i2` (`c3`, `c4`) BLOCK_SIZE 16384 LOCAL
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 COMPRESSION = 'lz4_1.0' REPLICA_NUM = NUM BLOCK_SIZE = SIZE USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = SIZE PCTFREE = 10
 partition by hash(c1)
(partition `p0`,
partition `p1`,
partition `p2`,
partition `p3`)
insert into t1 values(1,3,'d',1);
insert into t1 values(5,2,'c',2);
insert into t1 values(9,4,'b',3);
insert into t1 values(13,1,'a',4);
select * from t1;
c1	c2	c3	c4
1	3	d	1
5	2	c	2
9	4	b	3
13	1	a	4
select * from t1 partition(p0);
c1	c2	c3	c4
select * from t1 partition(p1);
c1	c2	c3	c4
1	3	d	1
5	2	c	2
9	4	b	3
13	1	a	4
select * from t1 partition(p2);
c1	c2	c3	c4
select * from t1 partition(p3);
c1	c2	c3	c4
explain basic select * from t1 where c2 >= 0;
Query Plan
=======================================
|ID|OPERATOR                 |NAME    |
---------------------------------------
|0 |PX COORDINATOR           |        |
|1 |└─EXCHANGE OUT DISTR     |:EX10000|
|2 |  └─PX PARTITION ITERATOR|        |
|3 |    └─TABLE RANGE SCAN   |t1(i1)  |
=======================================
Outputs & filters:
-------------------------------------
  0 - output([INTERNAL_FUNCTION(t1.c1, t1.c2, t1.c3, t1.c4)]), filter(nil), rowset=16
  1 - output([INTERNAL_FUNCTION(t1.c1, t1.c2, t1.c3, t1.c4)]), filter(nil), rowset=16
      dop=1
  2 - output([t1.c1], [t1.c2], [t1.c3], [t1.c4]), filter(nil), rowset=16
      force partition granule
  3 - output([t1.c1], [t1.c2], [t1.c3], [t1.c4]), filter(nil), rowset=16
      access([t1.c1], [t1.c2], [t1.c3], [t1.c4]), partitions(p[0-3])
      is_index_back=true, is_global_index=false, 
      range_key([t1.c2], [t1.c1]), range(0,MIN ; MAX,MAX), 
      range_cond([t1.c2 >= 0])
select * from t1 where c2 >= 0;
