drop database if exists db_partition;
create database db_partition;
use db_partition;
create table t_part_range(c1 int, c2 int) partition by range(mod(c1,30))
(partition p0 values less than(10),
partition p1 values less than(20),
partition p2 values less than(MAXVALUE));
explain select * from t_part_range where c1 > 27 and c1 < 33;
Query Plan
=================================================================
|ID|OPERATOR                 |NAME        |EST.ROWS|EST.TIME(us)|
-----------------------------------------------------------------
|0 |PX COORDINATOR           |            |1       |5           |
|1 |└─EXCHANGE OUT DISTR     |:EX10000    |1       |5           |
|2 |  └─PX PARTITION ITERATOR|            |1       |5           |
|3 |    └─TABLE FULL SCAN    |t_part_range|1       |5           |
=================================================================
Outputs & filters:
-------------------------------------
  0 - output([INTERNAL_FUNCTION(t_part_range.c1, t_part_range.c2)]), filter(nil), rowset=16
  1 - output([INTERNAL_FUNCTION(t_part_range.c1, t_part_range.c2)]), filter(nil), rowset=16
      dop=1
  2 - output([t_part_range.c1], [t_part_range.c2]), filter(nil), rowset=16
      force partition granule
  3 - output([t_part_range.c1], [t_part_range.c2]), filter([t_part_range.c1 > 27], [t_part_range.c1 < 33]), rowset=16
      access([t_part_range.c1], [t_part_range.c2]), partitions(p0, p2)
      is_index_back=false, is_global_index=false, filter_before_indexback[false,false], 
      range_key([t_part_range.__pk_increment]), range(MIN ; MAX)always true
