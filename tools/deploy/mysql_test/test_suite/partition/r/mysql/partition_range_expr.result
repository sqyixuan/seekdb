drop table if exists employees;
CREATE TABLE employees ( id INT NOT NULL, fname VARCHAR(30), lname VARCHAR(30), hired DATE NOT NULL DEFAULT '1970-01-01', separated DATE NOT NULL DEFAULT '9999-12-31', job_code INT, store_id INT ) PARTITION BY RANGE ( YEAR(separated) ) ( PARTITION p0 VALUES LESS THAN (1991), PARTITION p1 VALUES LESS THAN (1996), PARTITION p2 VALUES LESS THAN (2001), PARTITION p3 VALUES LESS THAN MAXVALUE );
explain partitions select * from employees where separated = '1990-1-1';
Query Plan
====================================================
|ID|OPERATOR       |NAME     |EST.ROWS|EST.TIME(us)|
----------------------------------------------------
|0 |TABLE FULL SCAN|employees|1       |3           |
====================================================
Outputs & filters:
-------------------------------------
  0 - output([employees.id], [employees.fname], [employees.lname], [employees.hired], [employees.separated], [employees.job_code], [employees.store_id]), filter([employees.separated 
      = demote_cast('1990-1-1', MYSQL_DATE(10, 0))]), rowset=16
      access([employees.separated], [employees.id], [employees.fname], [employees.lname], [employees.hired], [employees.job_code], [employees.store_id]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([employees.__pk_increment]), range(MIN ; MAX)always true
select * from employees where separated = '1990-1-1';
