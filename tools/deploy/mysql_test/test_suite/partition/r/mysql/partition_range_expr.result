drop table if exists t6;
create table t6(c1 int , c2 int,primary key(c1,c2)) partition by range(c1+c2) ( PARTITION p0 VALUES LESS THAN (2),PARTITION P1 VALUES LESS THAN (100));
insert into t6 values(1,2);
select * from t6 where c1=1;
c1	c2
1	2
select * from t6;
c1	c2
1	2
explain basic  select * from t6 where c1=1;
