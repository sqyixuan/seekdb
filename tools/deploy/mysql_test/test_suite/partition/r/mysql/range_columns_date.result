drop table if exists rcd_t;
########### 1.  test date datatype in create table  #####################################
create table rcd_t(
c1 date,
c2 int) 
partition by range columns(c1) 
(partition p0 values less than (date'2020-10-10'));
insert into rcd_t values(date'2010-10-10', 1);
select * from rcd_t partition (p0);
c1	c2
2010-10-10	1
########### 2.  test datetime datatype, date in values in create table  #####################################
drop table if exists rcd_t;
create table rcd_t(
c1 datetime,
c2 int) 
partition by range columns(c1) 
(partition p0 values less than (date'2020-10-10'));
insert into rcd_t values(date'2020-10-09', 1);
select * from rcd_t partition (p0);
c1	c2
2020-10-09 00:00:00	1
########### 3.  test datetime datatype, time in values in create table  #####################################
drop table if exists rcd_t;
create table rcd_t(
c1 datetime,
c2 int) 
partition by range columns(c1) 
(partition p0 values less than (time '10:10:00'),
partition p1 values less than (maxvalue));
insert into rcd_t values(time'10:01:00', 1);
select count(*) from rcd_t partition (p1);
count(*)
1
########### 4.  test datetime datatype, timestamp in values in create table  #####################################
drop table if exists rcd_t;
create table rcd_t(
c1 datetime,
c2 int) 
partition by range columns(c1) 
(partition p0 values less than (timestamp '2020-10-10 10:00:00'));
insert into rcd_t values(date'2020-10-10', 1);
select * from rcd_t partition (p0);
c1	c2
2020-10-10 00:00:00	1
drop table if exists rcd_t;
