drop table if exists t1,t2;
create TABLE t1(c1 int(11) not null, c3 varchar(32) not null) partition by key(c1,c3) partitions 4;
create TABLE t2(c1 int(11) not null, c2 int(11) not null, c3 varchar(32) not null, c4 int)
partition by range columns(c2, c4) 
subpartition by key(c1,c3) subpartitions 4 
(partition p0 values less than (3,43), partition p1 values less than (MAXVALUE, MAXVALUE));
result_format: 4
explain_protocol: 2
EXPLAIN insert into t1 values (2, '4.0');
Query Plan
==================================================
|ID|OPERATOR          |NAME|EST.ROWS|EST.TIME(us)|
--------------------------------------------------
|0 |DISTRIBUTED INSERT|    |1       |13          |
|1 |└─EXPRESSION      |    |1       |1           |
==================================================
Outputs & filters:
-------------------------------------
  0 - output(nil), filter(nil)
      columns([{t1: ({t1: (t1.__pk_increment, t1.c1, t1.c3)})}]), 
      column_values([T_HIDDEN_PK], [column_conv(INT,PS:(11,0),NOT NULL,__values.c1)], [column_conv(VARCHAR,utf8mb4_general_ci,length:32,NOT NULL,__values.c3)])
  1 - output([__values.c1], [__values.c3]), filter(nil)
      values({2, '4.0'})
insert into t1 values (2, '4.0');
