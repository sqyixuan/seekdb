create table pr1(a int, b int) partition by range(a) (
partition p0 values less than (100),
partition p1 values less than (200));
show create table pr1;
Table	Create Table
pr1	CREATE TABLE `pr1` (
  `a` int(11) DEFAULT NULL,
  `b` int(11) DEFAULT NULL
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 COMPRESSION = 'lz4_1.0' REPLICA_NUM = NUM BLOCK_SIZE = SIZE USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = SIZE PCTFREE = 10
 partition by range(a)
(partition `p0` values less than (100),
partition `p1` values less than (200))
create table prc1(a datetime, b int) partition by range columns(a) (
partition p0 values less than ('2011-01-01'),
partition p1 values less than ('2116-01-01'));
show create table prc1;
Table	Create Table
prc1	CREATE TABLE `prc1` (
  `a` datetime DEFAULT NULL,
  `b` int(11) DEFAULT NULL
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 COMPRESSION = 'lz4_1.0' REPLICA_NUM = NUM BLOCK_SIZE = SIZE USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = SIZE PCTFREE = 10
 partition by range columns(a)
(partition `p0` values less than ('2011-01-01 00:00:00'),
partition `p1` values less than ('2116-01-01 00:00:00'))
create table prc2(a int, b int, primary key(a,b)) partition by range columns(a, b) (
partition p0 values less than (1, 1),
partition p1 values less than (5, 5)
);
show create table prc2;
Table	Create Table
prc2	CREATE TABLE `prc2` (
  `a` int(11) NOT NULL,
  `b` int(11) NOT NULL,
  PRIMARY KEY (`a`, `b`)
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 COMPRESSION = 'lz4_1.0' REPLICA_NUM = NUM BLOCK_SIZE = SIZE USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = SIZE PCTFREE = 10
 partition by range columns(a, b)
(partition `p0` values less than (1,1),
partition `p1` values less than (5,5))
create table prc3(a int, b datetime, c int, d int, e int, f int, g int, primary key(a,b,c,d,e,f,g)) partition by range columns(a,b,c,d,e,f,g) (
partition p0 values less than(1, '2011-01-01', 1, 1, 1, 1, 1),
partition p1 values less than(10, '2016-01-01', 10, 10, 10, 10, 10)
);
show create table prc3;
Table	Create Table
prc3	CREATE TABLE `prc3` (
  `a` int(11) NOT NULL,
  `b` datetime NOT NULL,
  `c` int(11) NOT NULL,
  `d` int(11) NOT NULL,
  `e` int(11) NOT NULL,
  `f` int(11) NOT NULL,
  `g` int(11) NOT NULL,
  PRIMARY KEY (`a`, `b`, `c`, `d`, `e`, `f`, `g`)
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 COMPRESSION = 'lz4_1.0' REPLICA_NUM = NUM BLOCK_SIZE = SIZE USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = SIZE PCTFREE = 10
 partition by range columns(a,b,c,d,e,f,g)
(partition `p0` values less than (1,'2011-01-01 00:00:00',1,1,1,1,1),
partition `p1` values less than (10,'2016-01-01 00:00:00',10,10,10,10,10))
create table sp1(a int, b datetime, primary key(a, b)) partition by hash(a)
subpartition by range columns(b)
subpartition template (
subpartition p0 values less than ('2016-10-10'),
subpartition p1 values less than ('2116-3-30')) partitions 2;
show create table sp1;
Table	Create Table
sp1	CREATE TABLE `sp1` (
  `a` int(11) NOT NULL,
  `b` datetime NOT NULL,
  PRIMARY KEY (`a`, `b`)
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 COMPRESSION = 'lz4_1.0' REPLICA_NUM = NUM BLOCK_SIZE = SIZE USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = SIZE PCTFREE = 10
 partition by hash(a) subpartition by range columns(b) subpartition template (
subpartition `p0` values less than ('2016-10-10 00:00:00'),
subpartition `p1` values less than ('2116-03-30 00:00:00'))
(partition `p0`,
partition `p1`)
create TABLE taa (a varchar(5) collate 'binary') 
partition by range columns(a) 
( partition p0 values less than ('m'), 
partition p1 values less than ('za'));
show create table taa;
Table	Create Table
taa	CREATE TABLE `taa` (
  `a` varbinary(5) DEFAULT NULL
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 3 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
 partition by range columns(a)
(partition `p0` values less than ('m'),
partition `p1` values less than ('za'))
create TABLE tab (a binary(10) NULL default 'x') partition by range columns(a) ( 
partition p0 values less than ('6\0\0'), 
partition p1 values less than ('z\0\0'));
show create table tab;
Table	Create Table
tab	CREATE TABLE `tab` (
  `a` binary(10) DEFAULT 'x'
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 3 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
 partition by range columns(a)
(partition `p0` values less than ('6'),
partition `p1` values less than ('z'))
