DROP TABLE IF EXISTS t1, t2;
#
# Bug#11763825/56590: PARTITIONS: FULLTEXT SEARCHES FAIL
# (bad/confusing error message)
CREATE TABLE t1
(a INT UNSIGNED  NOT NULL PRIMARY KEY,
b VARCHAR(100),
c varchar(100))
PARTITION BY HASH(a) PARTITIONS 1;
CREATE  INDEX msg ON t1 (b, c);
DROP TABLE t1;
CREATE TABLE t1
(a INT UNSIGNED  NOT NULL PRIMARY KEY,
b VARCHAR(100),
c varchar(100),
INDEX (b, c))
PARTITION BY HASH(a) PARTITIONS 1;
drop table t1;
#
# Bug#31931: Mix of handlers error message
#
CREATE TABLE t1 (a INT)
PARTITION BY HASH (a)
PARTITIONS 2;
drop table t1;
#
# Bug#49161: Out of memory; restart server and try again (needed 2 bytes)
#
CREATE TABLE t1 (a INT)
PARTITION BY HASH (a);
SELECT * FROM t1;
a
DROP TABLE t1;
#
# Bug#50392: insert_id is not reset for partitioned tables
#            auto_increment on duplicate entry
CREATE TABLE t1 (a INT AUTO_INCREMENT PRIMARY KEY)
;
INSERT INTO t1 VALUES (NULL);
# For transactional engines, 12 will not be inserted, since the failing
# statement is rolled back.
INSERT INTO t1 VALUES (NULL), (NULL), (NULL);
SHOW CREATE TABLE t1;
