--error 1210
select zipf(null, 100, random(3)) a from dual;
--error 1210
select zipf(100, null, random(3)) a from dual;
--error 1210
select zipf('x1', 'x100', random(3)) a from dual;
select zipf(1, 100, null) a from dual;
select zipf(1, 100, random(3)) a from dual;
--error 1210
select normal(null, 100, random(3)) a from dual;
--error 1210
select normal(100, null, random(3)) a from dual;
select normal('x1', 'x100', random(3)) a from dual;
select normal(1, 100, null) a from dual;
select normal(1, 100, random(3)) a from dual;
select normal(1.0, 100, random(3)) a from dual;
--error 1210
select uniform(null, 100, random(3)) a from dual;
--error 1210
select uniform(100, null, random(3)) a from dual;
select uniform('x1', 'x3', random(3)) a from dual;
select uniform(1, 100, null) a from dual;
select uniform(1, 100, random(3)) a from dual;
select uniform(1.0, 100, random(3)) a from dual;

select randstr(null, null) a from dual;
select randstr(3, null) a from dual;
select randstr(null, random(3)) a from dual;
select randstr(3, random(3)) a from dual;
select randstr('x1', random(3)) a from dual;

select  count(*), zipf(1, 10, random(3)) v from table(generator(10000)) group by v order by 1;
select  normal(1, 10, random(3)) from table(generator(10));
select  count(*), uniform(5, 10, random(3)) v from table(generator(10000)) group by v order by 1;
