#owner: dachuan.sdc
#owner group: SQL2
#tags: retry 

--disable_warnings

drop table if exists t1;
drop table if exists t2;

create table t1 (c1 int);
create table t2 (c1 int primary key) partition by hash(c1) partitions 3;

insert into t1 values (1), (2), (NULL);
insert into t2 values (1), (2), (3), (4);

explain basic select * from table(generator(NULL));
--error 1210
select * from table(generator(NULL));
--error 1210
select /*+ parallel(2) */ * from t2 where t2.c1 in (select * from table(generator(NULL)));
--error 1210
select * from t2, table(generator(t2.c1));

explain basic select * from table(generator(3));
explain basic select * from t2, table(generator(3));
--sorted_result
select * from t1, table(generator(3));
--sorted_result
select * from t2, table(generator(3));

explain basic select /*+ parallel(2) */ * from t2 where t2.c1 in (select * from table(generator(3)));
--sorted_result
select /*+ parallel(2) */ * from t2 where t2.c1 in (select * from table(generator(3)));

