DROP TABLE t_char;
drop table if exists t1;

--enable_warnings
create table t1(c1 int);
insert into t1 values(1),(2),(3),(4);
--echo This execution plan cannot be changed, otherwise it may not be compatible with MySQL.
explain select a from (select @a := c1 as a FROM t1 order by c1) v where a > @a / 2;
select a from (select @a := c1 as a FROM t1 order by c1) v where a > @a / 2;
insert into t1 select * from t1;
--echo This execution plan cannot be changed, otherwise it may not be compatible with MySQL.
explain select distinct c1, @rownum:=@rownum+1 as rownum from t1, (select @rownum:=0) t;
select distinct c1, @rownum:=@rownum+1 as rownum from t1, (select @rownum:=0) t;
select @rownum from dual;
--echo This execution plan cannot be changed, otherwise it may not be unexpected
explain select c1, @rownum:=@rownum+1 as rownum from t1, (select @rownum:=0) t order by @rownum;
select c1, @rownum:=@rownum+1 as rownum from t1, (select @rownum:=0) t order by @rownum;
select @rownum from dual;
drop table t1;

--disable_warnings
drop table if exists case_fk_subpartition_child3;
drop table if exists case_fk_subpartition_parent;
--enable_warnings
CREATE TABLE case_fk_subpartition_parent (pk INT, a INT, b INT, UNIQUE(a) , UNIQUE(b));
CREATE TABLE case_fk_subpartition_child3 (fk1 INT, c2 INT PRIMARY KEY, FOREIGN KEY (fk1) REFERENCES case_fk_subpartition_parent (b));
set @def_value=171;
INSERT /*+ use_xinglu_das(case_fk_subpartition_parent) */ INTO case_fk_subpartition_parent values (@def_value, @def_value+1, @def_value-1);
INSERT /*+ use_xinglu_das(case_fk_subpartition_child3) */ INTO case_fk_subpartition_child3 values (@def_value:=@def_value-1, @def_value:=@def_value+1);
explain SELECT /*+ use_xinglu_das(case_fk_subpartition_child3) */ count(*) from case_fk_subpartition_child3 where c2=@def_value and fk1=(@def_value:=@def_value-1);
SELECT /*+ use_xinglu_das(case_fk_subpartition_child3) */ count(*) from case_fk_subpartition_child3 where c2=@def_value and fk1=(@def_value:=@def_value-1);
DROP TABLE case_fk_subpartition_child3;
DROP TABLE case_fk_subpartition_parent;

--disable_warnings
drop table if exists test, t1;
--enable_warnings
create table test(id int primary key, value int, group_id int);
create table t1(a int);
insert into test select @id:=@id+1, @id+1000, FLOOR(@id/10) from table(generator(50)) t, (select @id:=0) init;
--echo 使用用户变量计算每行的累计和
SELECT id, value, @sum := @sum + value AS cumulative_sum FROM test, (SELECT @sum := 0) AS init ORDER BY id;
--echo 使用用户变量计算每个组的累计和
SELECT id, value, group_id, 
       @sum := IF(group_id = @prev_group, @sum + value, value) AS cumulative_sum,
              @prev_group := group_id
              FROM test, (SELECT @sum := 0, @prev_group := NULL) AS init
              ORDER BY group_id, id;
--echo 计算每组的平均值，并将其与每行的值进行比较
SELECT id, value, group_id, 
       @avg := AVG(value) OVER (PARTITION BY group_id) AS avg_value,
              IF(value > @avg, 'Above average', 'Below average') AS comparison
              FROM test;
--echo 使用用户变量计算滚动平均值
SELECT id, value,
       @avg := (@avg * @count + value) / (@count + 1) AS rolling_avg,
              @count := @count + 1
              FROM test, (SELECT @avg := 0, @count := 0) AS init;
--echo 初始化用户变量
set @sum=NULL;
select /*+use_nl(t1 init)*/ * from t1, (SELECT @sum := (SELECT SUM(value) FROM test) AS total_sum FROM DUAL) init;
select @sum;
select /*+use_nl(t1 init) leading(t1 init)*/ * from t1, (SELECT @sum := (SELECT SUM(value) OVER () FROM test ) AS total_sum FROM DUAL) init;
select @sum;
select /*+use_nl(t1 init)*/ * from t1, (SELECT @num := (SELECT 10) AS num_value FROM DUAL) init;
select @num;
select /*+use_nl(t1 init)*/ * from t1, (SELECT @message := (SELECT 'Hello, World!') AS message_value FROM DUAL) init;
select @message;
select /*+use_nl(t1 init)*/ * from t1, (SELECT @date1 := (SELECT STR_TO_DATE('2023-10-07 15:00:00', '%Y-%m-%d %H:%i:%s') AS converted_time)) init;
select @date1;
select /*+use_nl(t1 init)*/ * from t1, (select @sum1:=(select id from test limit 1)) init;
select @sum1;
select /*+use_nl(t1 init) leading(t1 init)*/ * from t1, (select @sum2:=(select id from test), @sum3:=0) init;
select @sum2, @sum3;
select /*+use_nl(t1 init)*/ * from t1, (select @aa:=(select 1)+(select 2), @bb:=(select id from test limit 1), @cc:=1) init; 
select @aa, @bb, @cc;
select /*+use_nl(t1 init) leading(t1 init)*/ * from t1, (select @sum1:=(select id from test)) init;
drop table test, t1;

