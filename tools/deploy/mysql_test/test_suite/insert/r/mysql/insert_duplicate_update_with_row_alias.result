result_format: 4
drop table t1;
drop table t2;
create table t1(a int primary key,b int,c int);
insert into t1 values (4,5,6);
create table t2(a int primary key,b int,c int,m int,n int, p int);
insert into t2 values (4,5,7,4,5,7);

================================test basic usage================================
---expect c=10
INSERT INTO t1 VALUES (4,5,7) AS NEW(m,n,p)
            ON DUPLICATE KEY UPDATE c = values(a)+values(b)+1;
select * from t1;
+---+------+------+
| a | b    | c    |
+---+------+------+
| 4 |    5 |   10 |
+---+------+------+
INSERT INTO t1 select * from (VALUES ROW(4,5,7)) AS NEW(m,n,p)
            ON DUPLICATE KEY UPDATE c = values(a)+values(b)+1;
select * from t1;
+---+------+------+
| a | b    | c    |
+---+------+------+
| 4 |    5 |   10 |
+---+------+------+
---expect c=9
INSERT INTO t1 VALUES (4,5,7) AS NEW(m,n,p)
            ON DUPLICATE KEY UPDATE c = NEW.m+values(b);
select * from t1;
+---+------+------+
| a | b    | c    |
+---+------+------+
| 4 |    5 |    9 |
+---+------+------+
INSERT INTO t1 select * from (VALUES ROW(4,5,7)) AS NEW(m,n,p)
            ON DUPLICATE KEY UPDATE c = NEW.m+values(b);
select * from t1;
