================================test 特殊语法测试================================
#As关键词必须出现
INSERT INTO t1 (a,b,c) VALUES (4,5,6) new
            ON DUPLICATE KEY UPDATE c = new.a+new.b;
ERROR 42000: You have an error in your SQL syntax; check the manual that corresponds to your OceanBase version for the right syntax to use near 'new
            ON DUPLICATE KEY UPDATE c = new.a+new.b' at line 1

#As多个别名
INSERT INTO t1 (a,b,c) VALUES (4,5,6) AS new new1
            ON DUPLICATE KEY UPDATE c = new.a+new1.b;
ERROR 42000: You have an error in your SQL syntax; check the manual that corresponds to your OceanBase version for the right syntax to use near 'new1
            ON DUPLICATE KEY UPDATE c = new.a+new1.b' at line 1

#Row语法不允许有别名
INSERT INTO t1 (a,b,c) VALUES row(4,5,6),(7,8,9) as new
            ON DUPLICATE KEY UPDATE c = a+new.c;
ERROR 42000: You have an error in your SQL syntax; check the manual that corresponds to your OceanBase version for the right syntax to use near '(7,8,9) as new
            ON DUPLICATE KEY UPDATE c = a+new.c' at line 1

#生成列
drop table t_gen;
create table t_gen(a int primary key,b int,c int as (a+b));
insert into t_gen (a,b) values (4,5);
select * from t_gen;
+---+------+------+
| a | b    | c    |
+---+------+------+
| 4 |    5 |    9 |
+---+------+------+
INSERT INTO t_gen (a,b) VALUES (4,5)
            ON DUPLICATE KEY UPDATE c = values(a)+values(b)+1;
ERROR HY000: The value specified for generated column 'c' in table 't_gen' is not allowed
INSERT INTO t_gen (a,b) VALUES (4,5) AS NEW
            ON DUPLICATE KEY UPDATE c = NEW.a+NEW.b+1;
ERROR HY000: The value specified for generated column 'c' in table 't_gen' is not allowed
INSERT INTO t_gen (a,b) VALUES (4,5) AS NEW(m,n)
            ON DUPLICATE KEY UPDATE c = m+n+1;
ERROR HY000: The value specified for generated column 'c' in table 't_gen' is not allowed
INSERT INTO t_gen set a=4,b=5 AS NEW(m,n)
            ON DUPLICATE KEY UPDATE c = m+n+1;
ERROR HY000: The value specified for generated column 'c' in table 't_gen' is not allowed
---expect b=10,c=14
INSERT INTO t_gen (a,b) VALUES (4,5)
            ON DUPLICATE KEY UPDATE b = values(a)+values(b)+1;
select * from t_gen;
+---+------+------+
| a | b    | c    |
+---+------+------+
| 4 |   10 |   14 |
+---+------+------+
---expect b=8,c=12
INSERT INTO t_gen (a,b) VALUES (4,5) AS NEW
            ON DUPLICATE KEY UPDATE b = NEW.a+NEW.b-1;
select * from t_gen;
+---+------+------+
| a | b    | c    |
+---+------+------+
| 4 |    8 |   12 |
+---+------+------+
---expect b=11,c=15
INSERT INTO t_gen (a,b) VALUES (4,5) AS NEW(m,n)
            ON DUPLICATE KEY UPDATE b = m+n+2;
select * from t_gen;
+---+------+------+
| a | b    | c    |
+---+------+------+
| 4 |   11 |   15 |
+---+------+------+
---expect b=10,c=14
INSERT INTO t_gen set a=4,b=5 AS NEW(m,n)
            ON DUPLICATE KEY UPDATE b = m+n+1;
select * from t_gen;
+---+------+------+
| a | b    | c    |
+---+------+------+
| 4 |   10 |   14 |
+---+------+------+

#其他
INSERT INTO t1 (a,b) (SELECT m, p FROM t2) as NEW
            ON DUPLICATE KEY UPDATE c = VALUES(b)+NEW.p;
ERROR 42000: You have an error in your SQL syntax; check the manual that corresponds to your OceanBase version for the right syntax to use near 'as NEW
            ON DUPLICATE KEY UPDATE c = VALUES(b)+NEW.p' at line 1

INSERT INTO t1 (a,b) select * from (SELECT t2.m, t2.p FROM t2 union select a,b from t1) as NEW
            ON DUPLICATE KEY UPDATE c = VALUES(b)+NEW.p;
INSERT INTO t1 (a,b) select * from (SELECT t2.m, t2.p FROM t2 union select a,b from t1) as NEW
            ON DUPLICATE KEY UPDATE c = VALUES(b)+NEW.p;
INSERT INTO t1 (a,b) select * from (SELECT m, p FROM t2) as NEW(k,j)
            ON DUPLICATE KEY UPDATE c = VALUES(b)+NEW.p;
ERROR 42S22: Unknown column 'new.p' in 'field list'
INSERT INTO t1 (a,b) select * from (SELECT m, p FROM t2) as NEW
            ON DUPLICATE KEY UPDATE c = VALUES(b)+NEW.b;
ERROR 42S22: Unknown column 'new.b' in 'field list'
INSERT INTO t1 set a=4,b=5 AS NEW(m,n)
            ON DUPLICATE KEY UPDATE c = d-1;
ERROR 42S22: Unknown column 'd' in 'field list'
INSERT INTO t1 set a=4,b=5 AS NEW(m,n)
            ON DUPLICATE KEY UPDATE c = NEW.d-1;
ERROR 42S22: Unknown column 'new.d' in 'field list'
================================test 别名数量================================
#数量不对应
INSERT INTO t1 (a,b) VALUES (5,6) AS NEW(m,n,p)
            ON DUPLICATE KEY UPDATE c = m+values(b);
ERROR HY000: View's SELECT and view's field list have different column counts
INSERT INTO t1 (a,b,c) VALUES (5,6,7) AS NEW(m,n)
            ON DUPLICATE KEY UPDATE c = m+values(b);
ERROR HY000: View's SELECT and view's field list have different column counts
INSERT INTO t1 set a=1,b=4 AS new(a,b,c)
            ON DUPLICATE KEY UPDATE c = values(a)+new.b;
ERROR HY000: View's SELECT and view's field list have different column counts
INSERT INTO t1 set a=1,b=2,c=3 AS new(m,n)
            ON DUPLICATE KEY UPDATE c = new.m+new.n;
ERROR HY000: View's SELECT and view's field list have different column counts
#重复列名
INSERT INTO t1 VALUES (4,5,6) AS new(m,m,c)
            ON DUPLICATE KEY UPDATE c = values(a)+new.a;
ERROR 42S21: Duplicate column name 'm'
INSERT INTO t1 (a,a,b) VALUES (4,5,6) AS new(m,m,c)
            ON DUPLICATE KEY UPDATE c = values(a)+new.a;
ERROR 42000: Column 'a' specified twice
INSERT INTO t1 (a,a,b) VALUES (4,5,6) AS new
            ON DUPLICATE KEY UPDATE c = values(a)+new.a;
ERROR 42000: Column 'a' specified twice
INSERT INTO t1 VALUES (4,5,6) AS new(M,m,c)
            ON DUPLICATE KEY UPDATE c = values(a)+new.a;
ERROR 42S21: Duplicate column name 'm'
INSERT INTO t1 set a=1,b=4 AS new(c,c)
            ON DUPLICATE KEY UPDATE c = values(a)+new.c;
ERROR 42S21: Duplicate column name 'c'

