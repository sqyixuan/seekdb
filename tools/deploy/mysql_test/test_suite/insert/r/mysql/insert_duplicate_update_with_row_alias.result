================================test 别名歧义测试================================
INSERT INTO t1 (a,b,c) VALUES (4,7,6) AS new(m,n,p)
            ON DUPLICATE KEY UPDATE c = NEW.m+b;
INSERT INTO t1 VALUES (4,5,6) AS NEW 
