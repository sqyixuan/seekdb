'no conflict, only insert rows'
insert /*+query_timeout(4000000)*/ into biz_time_series_quota select * from biz_time_series_quota_ym t2 on duplicate key update quota_value=t2.quota_value;
'all conflict, update rows in memtable'
insert /*+query_timeout(10000000)*/ into biz_time_series_quota select * from biz_time_series_quota_ym t2 on duplicate key update quota_value=t2.quota_value;
'all conflict, update rows in sstable'
alter system major freeze;
insert /*+query_timeout(10000000)*/ into biz_time_series_quota select * from biz_time_series_quota_ym t2 on duplicate key update quota_value=t2.quota_value;
drop table biz_time_series_quota, biz_time_series_quota_ym;
