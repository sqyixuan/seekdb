drop table if exists test;
drop table if exists tt;
create table test(c1 int primary key, c2 int);
create table tt(c1 int primary key, c2 int);
insert into tt values(1,2),(2,3),(3,4);
insert ignore into test select * from tt;
select * from test;
c1	c2
1	2
2	3
3	4
insert into test select * from tt on duplicate key update test.c1 =1;
ERROR 23000: Duplicate entry '1' for key 'PRIMARY'
insert into test select * from tt;
ERROR 23000: Duplicate entry '1' for key 'PRIMARY'
insert ignore into test select * from tt;
select * from test;
c1	c2
1	2
2	3
3	4
insert into test select * from tt on duplicate key update test.c1 = test.c1 - 1;
select * from test;
c1	c2
0	2
1	3
2	4
insert ignore into test select * from tt on duplicate key update test.c1 = 1;
select * from test;
c1	c2
0	2
1	3
2	4
3	4
drop table test;
drop table tt;
