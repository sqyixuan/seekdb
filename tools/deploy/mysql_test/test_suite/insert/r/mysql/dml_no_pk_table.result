drop table if exists t1, t2, t3, t4;
result_format: 4
##
CREATE TABLE t1 (a INT, b INT NOT NULL);

INSERT INTO t1 (a) VALUES (1);
ERROR HY000: Field 'b' doesn't have a default value
drop table t1;

drop table if exists t1, t2;
CREATE TABLE t1(a number(21));
INSERT INTO t1 VALUES (4503599627370495);
INSERT INTO t1 VALUES (15);
select * from t1;
+------------------+
| a                |
+------------------+
| 4503599627370495 |
|               15 |
+------------------+
SELECT * FROM t1 WHERE a=-1 OR a=-2 OR a=16;
+------+
| a    |
+------+
+------+
SELECT * FROM t1 WHERE a in (-1,-2,16);
+------+
| a    |
+------+
+------+
CREATE TABLE t2(a int primary key);
INSERT INTO t2 VALUES (241);
INSERT INTO t2 VALUES (1);
select * from t2;
+-----+
| a   |
+-----+
|   1 |
| 241 |
+-----+
select * from t2 where a=1;
+---+
| a |
+---+
| 1 |
+---+
select * from t2 where a in (1);
+---+
| a |
+---+
| 1 |
+---+

##支持insert values之间的引用关系
drop table if exists test, tt;
create table test (c1 int ,c2 int, c3 int);
insert into test values(1, 1, 2);
insert into test values(2, 1, 2);
insert into test values(4, 1, 2);
select * from test;
+------+------+------+
| c1   | c2   | c3   |
+------+------+------+
|    1 |    1 |    2 |
|    2 |    1 |    2 |
|    4 |    1 |    2 |
+------+------+------+

##value之间存在引用关系时，要做类型转换
drop table if exists test, tt;
create table test (c1 int ,c2 int, c3 varchar(4));
insert into test values(1,2,3);
insert into test (c3,c1,c2) values('1', c3+1,c2+c3);
select * from test;
+------+------+------+
| c1   | c2   | c3   |
+------+------+------+
|    1 |    2 | 3    |
|    2 | NULL | 1    |
+------+------+------+
drop table test;
