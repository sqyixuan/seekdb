drop table if exists biz_time_series_quota, biz_time_series_quota_ym;
CREATE TABLE `biz_time_series_quota_ym` (
`stat_time` datetime NOT NULL COMMENT '数据时间',
`cube_hash` varchar(256) NOT NULL COMMENT '维度hash，确保唯一',
`time_range_type` int(11) NOT NULL COMMENT '统计周期 1 2分钟 2 10 分钟 3 小时 4 天级',
`type` int(11) NOT NULL COMMENT '指标类型',
`quota_name` varchar(128) NOT NULL COMMENT '指标名称',
`quota_value` decimal(12,2) DEFAULT NULL COMMENT '指标值',
`yesterday_quota_value` decimal(12,2) DEFAULT NULL COMMENT '昨天的值',
`pre_week_quota_value` decimal(12,2) DEFAULT NULL COMMENT '上周的值',
PRIMARY KEY (`stat_time`, `cube_hash`, `time_range_type`, `type`, `quota_name`)
);
CREATE TABLE `biz_time_series_quota` (
`stat_time` datetime NOT NULL COMMENT '数据时间',
`cube_hash` varchar(256) NOT NULL COMMENT '维度hash，确保唯一',
`time_range_type` int(11) NOT NULL COMMENT '统计周期 1 2分钟 2 10 分钟 3 小时 4 天级',
`type` int(11) NOT NULL COMMENT '指标类型',
`quota_name` varchar(128) NOT NULL COMMENT '指标名称',
`quota_value` decimal(12,2) DEFAULT NULL COMMENT '指标值',
`yesterday_quota_value` decimal(12,2) DEFAULT NULL COMMENT '昨天的值',
`pre_week_quota_value` decimal(12,2) DEFAULT NULL COMMENT '上周的值',
PRIMARY KEY (`stat_time`, `cube_hash`, `time_range_type`, `type`, `quota_name`)
)
