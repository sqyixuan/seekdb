drop table if exists test;
create table test(c1 int primary key, c2 char(100) default 'fffyyy', c3 int);
insert into test values(1, substr(c1,1,3), c3);
insert into test values(100, substr(c1,1,3), c3);
insert into test values(101, substr(c3,1,3), c3);
insert into test (c2,c1,c3) values(substr(c1,1,3), 102, 3);
insert into test (c2,c1,c3) values(substr(c3,1,3), 103, 3);
insert into test (c1,c2,c3) values(104, substr(c3,1,3), c3);
insert into test (c1 ,c2) values(105, substr(c3,1,3));
select * from test;
