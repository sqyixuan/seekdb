drop table if exists test;
create table test (c1 int primary key, c2 int unique key, c3 int, c4 char(3));
insert into test values(1,2,2,2),(1,4,4,4),(4,5,5,5);
ERROR 23000: Duplicate entry '1' for key 'PRIMARY'
select * from test;
c1	c2	c3	c4
insert ignore into test values(1,2,2,2),(1,4,4,4),(4,5,5,5);
select * from test;
c1	c2	c3	c4
delete from test;
insert into test values(1,2,2,2),(3,4,4,4),(4,5,5,'5eeeeee');
ERROR 22001: Data too long for column 'c4' at row 3
select * from test;
c1	c2	c3	c4
insert ignore into test values(1,2,2,2),(3,4,4,4),(4,5,5,'eeeeeeee');
select * from test;
c1	c2	c3	c4
1	2	2	2
3	4	4	4
4	5	5	eee
delete from test;
insert into test values(1,2,2,2),(2,4,4,4),(4,5,5,5);
insert into test values(1,2,2,2),(2,4,4,4),(4,5,5,5) on duplicate key update c1 = 2;
ERROR 23000: Duplicate entry '2' for key 'PRIMARY'
select * from test;
c1	c2	c3	c4
1	2	2	2
2	4	4	4
4	5	5	5
insert ignore into test values(1,2,2,2),(2,4,4,4),(4,5,5,5) on duplicate key update c1 = c1+1, c2 = c2 +1;
select * from test;
c1	c2	c3	c4
1	2	2	2
2	4	4	4
4	5	5	5
delete from test;
insert into test values(1,2,2,2),(2,4,4,4),(4,5,5,5);
insert into test values(1,2,2,2),(2,4,4,4),(4,5,5,5) on duplicate key update c4 = 'sefesfse';
ERROR 22001: Data too long for column
select * from test;
c1	c2	c3	c4
1	2	2	2
2	4	4	4
4	5	5	5
insert ignore into test values(1,2,2,2),(2,4,4,4),(4,5,5,5) on duplicate key update c4 = 'dddddddd';
select * from test;
c1	c2	c3	c4
1	2	2	ddd
2	4	4	ddd
4	5	5	ddd
delete from test;
start transaction;
insert ignore into test values(1,2,2,2),(2,4,4,4),(4,5,5,5);
update ignore test set c1 = c1+1,c2=c2+1;
select * from test;
c1	c2	c3	c4
1	2	2	2
2	4	4	4
4	5	5	5
commit;
select * from test;
c1	c2	c3	c4
1	2	2	2
2	4	4	4
4	5	5	5
start transaction;
update ignore test set c1=c1+1,c2=c2+1;
select * from test;
c1	c2	c3	c4
1	2	2	2
2	4	4	4
4	5	5	5
rollback;
select * from test;
c1	c2	c3	c4
1	2	2	2
2	4	4	4
4	5	5	5
