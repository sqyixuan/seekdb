--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: xiaoyi.xy
# owner group: SQL3
# description: 本case是为了测试dml语句的affected_rows count
# 本case在java下结果验证会失败

--enable_info
--disable_warnings
drop table if exists test, test_index, test_unique_index, test_multi_unique_index;
--enable_warnings

create table test (c1 int primary key, c2 char(10));
create table test_index (c1 int primary key, c2 char(10), index(c2));
create table test_unique_index (c1 int primary key, c2 char(10), unique key(c2));
create table test_multi_unique_index(c1 int primary key, c2 int, c3 int, unique key(c2), unique key(c3));

#单行插入
insert into test values(1, 'a');
insert into test_index values(1, 'a');
insert into test_unique_index values(1, 'a');
insert into test_multi_unique_index values(1, 2, 3);

#多行插入
insert into test values(2, 'b'), (3, 'c'), (4, 'c');
insert into test_index values(2, 'b'), (3, 'c'), (4, 'd');
insert into test_unique_index values (2, 'b'), (3, 'c'), (4, 'd');
insert into test_multi_unique_index values(2,3,4),(3,4,5),(4,5,6);

#单行更新
update test set c2 = 'bb' where c1 = 2;
update test_index set c2 = 'bb' where c1 = 2;
update test_unique_index set c2 = 'bb' where c1 = 2;
update test_multi_unique_index set c2 = 13 where c1 = 2;

#单行更新前后一致
update test set c2 = 'bb' where c1 = 2;
update test_index set c2 = 'bb' where c1 = 2;
update test_unique_index set c2 = 'bb' where c1 = 2;
update test_multi_unique_index set c2 = 13 where c1 = 2;

#多行更新
update test set c2 = concat(c2, 'bb') where c1 > 2;
update test_index set c2 = concat(c2, 'bb') where c1 > 2;
update test_unique_index set c2 = concat(c2, 'bb') where c1 > 2;
update test_multi_unique_index set c2 = c2 + 13 where c1 > 2;

#多行更新前后一致
update test set c2 = c2 where c1 > 2;
update test_index set c2 = c2 where c1 > 2;
update test_unique_index set c2 = c2 where c1 > 2;
update test_multi_unique_index set c2 = c2 where c1 > 2;

#replace插入单行
replace into test values(11, 'hi');
replace into test_index values(11, 'hi');
replace into test_unique_index values(11, 'hi');
replace into test_multi_unique_index values(11, 12, 13);

#replace插入多行
replace into test values(12, 'zi'), (13, 'dw'), (14, 'se');
replace into test_index values(12, 'zi'), (13, 'dw'), (14, 'se');
replace into test_unique_index values(12, 'zi'), (13, 'dw'), (14, 'se');
replace into test_multi_unique_index values(12, 13, 14), (23,24,25), (24,25,26);

#replace单行前后一致
replace into test values(11, 'hi');
replace into test_index values(11, 'hi');
replace into test_unique_index values(11, 'hi');
replace into test_multi_unique_index values(11, 12, 13);

#replace单行前后不一致
replace into test values(11, 'hii');
replace into test_index values(11, 'hii');
replace into test_unique_index values(11, 'hii');
replace into test_multi_unique_index values(11, 14, 16);

#replace多行前后一致
replace into test values(12, 'zi'), (13, 'dw'), (14, 'se');
replace into test_index values(12, 'zi'), (13, 'dw'), (14, 'se');
replace into test_unique_index values(12, 'zi'), (13, 'dw'), (14, 'se');
replace into test_multi_unique_index values(12, 13, 14), (23,24,25), (24,25,26);

#replace多行前后不一致
replace into test values(12, 'ziu'), (13, 'dws'), (14, 'dse');
replace into test_index values(12, 'zis'), (13, 'dws'), (14, 'sde');
replace into test_unique_index values(12, 'zsi'), (13, 'dfw'), (14, 'see');
replace into test_multi_unique_index values(12, 113, 114), (23,224,225), (24,235,236);

#replace冲突多行
replace into test_unique_index values(12, 'dfw'), (14, 'dfw');
replace into test_multi_unique_index values(12,224,236), (23,24,25), (33,34,35), (23, 224, 35);

#insert on duplicate插入单行
insert into test values(101, 'dea') on duplicate key update c2 = 'efs';
insert into test_index values(101, 'dea') on duplicate key update c2 = 'efs';
insert into test_unique_index values(101, 'dea') on duplicate key update c2 = 'efs';
insert into test_multi_unique_index values(101, 102, 103) on duplicate key update c2 = 104;

#insert on duplicate插入多行
insert into test values(102, 'dea'), (103, 'afe'), (104, 'sae') on duplicate key update c2 = 'efs';
insert into test_index values(102, 'dea'), (103, 'afe'), (104, 'sae') on duplicate key update c2 = 'efs';
insert into test_unique_index values(102, 'dea'), (103, 'afe'), (104, 'sae') on duplicate key update c2 = 'efs';
insert into test_multi_unique_index values(102,103,104),(112,113,114), (123,124,125) on duplicate key update c2 = c2 + 1;

#insert on duplicate单行更新，前后一致
insert into test values(101, 'dea') on duplicate key update c2 = 'dea';
insert into test_index values(101, 'dea') on duplicate key update c2 = 'dea';
insert into test_unique_index values(101, 'dea') on duplicate key update c2 = 'dea';
insert into test_multi_unique_index values(101, 102, 103) on duplicate key update c2 = 102;

#insert on duplicate单行更新，前后不一致
insert into test values(101, 'dea') on duplicate key update c2 = 'efs';
insert into test_index values(101, 'dea') on duplicate key update c2 = 'efs';
insert into test_unique_index values(101, 'dea') on duplicate key update c2 = 'efs';
insert into test_multi_unique_index values(101, 102, 103) on duplicate key update c2 = 104;

#insert on duplicate多行更新，前后一致
insert into test values(102, 'dea'), (103, 'afe'), (104, 'sae') on duplicate key update c2 = c2;
insert into test_index values(102, 'dea'), (103, 'afe'), (104, 'sae') on duplicate key update c2 = c2;
insert into test_unique_index values(102, 'dea'), (103, 'afe'), (104, 'sae') on duplicate key update c2 = c2;
insert into test_multi_unique_index values(102,103,104),(112,113,114), (123,124,125) on duplicate key update c2 = c2;

#insert on duplicate多行更新，前后不一致
insert into test values(102, 'dea'), (103, 'afe'), (104, 'sae') on duplicate key update c2 = 'efs';
insert into test_index values(102, 'dea'), (103, 'afe'), (104, 'sae') on duplicate key update c2 = 'efs';
insert into test_unique_index values(102, 'dea'), (103, 'afe'), (104, 'sae') on duplicate key update c2 = concat(c2, 'efs');
insert into test_multi_unique_index values(102,103,104),(112,113,114), (123,124,125) on duplicate key update c2 = c2 + 1000;

#insert on duplicate冲突多行
insert into test_unique_index values(102, 'afeefs'), (104, 'saesfs') on duplicate key update c2 = concat(c1, c2);
insert into test_multi_unique_index values(102, 1113, 125), (112, 1124,115),(134, 113, 115) on  duplicate key update c2 = c1+c2;

#delete 单行
delete from test where c1 = 102;
delete from test_index where c1 = 102;
delete from test_unique_index where c1 = 102;
delete from test_multi_unique_index where c1 = 134;
insert into test_unique_index values(300,'se'),(301, 'dfe');
insert into test_multi_unique_index values(300, 321,324), (400,402,402);
#delete 多行
delete from test;
delete from test_index;
delete from test_unique_index;
delete from test_multi_unique_index;

drop table test;
drop table test_index;
drop table test_unique_index;
drop table test_multi_unique_index;
