--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: xiaoyi.xy
# owner group: SQL3
# description: foobar
#
# duplicate insert the same primary key is allowd for ob
#

--disable_warnings
drop table if exists t1;
--enable_warnings


#
# int 
#
create table t1(pk int primary key,a int);
insert into t1(pk) values(1);
select * from t1;
--error 1062
insert into t1(pk) values(1);
select * from t1;
drop table t1;

#
# char
#
create table t1(pk varchar(128) primary key,a int);
insert into t1(pk) values('c1');
select * from t1;
--error 1062
insert into t1(pk) values('c1');
select * from t1;
drop table t1;

#
# datetime
#
create table t1(pk datetime primary key,a datetime(6));
insert into t1(pk) values('2012-02-02 12:00:00');
select * from t1;
#result目前不一致因obbug:6497561
--error 1062
insert into t1(pk) values('2012-02-02 12:00:00');
select * from t1;
drop table t1;

#
# TIMESTAMP, DATETIME DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP做主键
#
CREATE TABLE t1 (
  ts TIMESTAMP(6) DEFAULT CURRENT_TIMESTAMP(6) ON UPDATE CURRENT_TIMESTAMP(6),
  dt DATETIME(6) DEFAULT CURRENT_TIMESTAMP(6) ON UPDATE CURRENT_TIMESTAMP(6),
  c1 int,
  primary key(ts, dt)
);
insert into t1 values('2012-02-02 12:00:00.000001','2012-02-02 12:00:00.000001', 0);
insert into t1(c1) values(0);
insert into t1(c1) values(0);
--error 1062
insert into t1 values('2012-02-02 12:00:00.000001','2012-02-02 12:00:00.000001', 0);
--replace_column 1 TIMESTAMP 2 DATETIME
select * from t1;
drop table t1;

create table t1 (id int primary key);
insert into t1 values(1);
--source mysql_test/include/majorfreeze.inc
--error 1062
insert into t1 values(1),(2);
drop table t1;
--source mysql_test/include/wait_daily_merge.inc
