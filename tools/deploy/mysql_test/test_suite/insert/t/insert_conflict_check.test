# owner: chaser.ch
# owner group: storage
# description: for conflict check when insert row

#--disable_abort_on_error
--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;

# set GLOBAL ob_trx_timeout = 1000000;
# set GLOBAL ob_query_timeout = 1000000000000;
# set GLOBAL ob_trx_idle_timeout = 10000000000;

connect (conn3,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn2,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn0,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,oceanbase,$OBMYSQL_PORT);

connection conn0;
alter system set minor_compact_trigger = 10;

--let $value=1
--let $bytes=1500
--let $byte=1
while($bytes)
{
    --let $value=$value$byte
    dec $bytes;
}

connection conn1;
--disable_warnings
drop table if exists test_insert_conflict_check;
--enable_warnings
set session ob_trx_timeout=100000000000;
create table test_insert_conflict_check(c1 varchar(2048) primary key, c2 int) BLOCK_SIZE = 4096 COMPRESSION = 'none';

connection conn3;
eval insert into test_insert_conflict_check values ('a$value',0);
set session transaction isolation level repeatable read;
begin;
select * from test_insert_conflict_check; 

connection conn1;
eval update test_insert_conflict_check set c2=1 where c1='a$value';
eval insert into test_insert_conflict_check values ('c$value',0);
eval insert into test_insert_conflict_check values ('d$value',0);
eval insert into test_insert_conflict_check values ('e$value',0);
eval insert into test_insert_conflict_check values ('f$value',0);
eval insert into test_insert_conflict_check values ('g$value',0);
eval insert into test_insert_conflict_check values ('h$value',0);
eval insert into test_insert_conflict_check values ('i$value',0);
eval insert into test_insert_conflict_check values ('k$value',0);
eval insert into test_insert_conflict_check values ('l$value',0);
eval insert into test_insert_conflict_check values ('m$value',0);

connection conn2;
set session transaction isolation level repeatable read;
begin;
eval select * from test_insert_conflict_check where c1='m$value'; 

connection conn1;
eval update test_insert_conflict_check set c2=1 where c1='m$value';
eval update test_insert_conflict_check set c2=2 where c1='m$value';
eval update test_insert_conflict_check set c2=3 where c1='m$value';
eval update test_insert_conflict_check set c2=4 where c1='m$value';
eval update test_insert_conflict_check set c2=5 where c1='m$value'; 

connection conn2;
commit;

connection conn1;
begin;
eval update test_insert_conflict_check set c2=6 where c1='m$value';
eval insert into test_insert_conflict_check values ('y$value',0);
eval insert into test_insert_conflict_check values ('z$value',0);

connection conn0;
alter system minor freeze;
--source mysql_test/include/wait_minor_merge.inc

connection conn2;
--error 1205
eval insert into test_insert_conflict_check values ('m$value',0);
--error 1062
eval insert into test_insert_conflict_check values ('c$value',0);
--error 1062
eval insert into test_insert_conflict_check values ('d$value',0);
--error 1062
eval insert into test_insert_conflict_check values ('e$value',0);
--error 1062
eval insert into test_insert_conflict_check values ('f$value',0);
--error 1062
eval insert into test_insert_conflict_check values ('g$value',0);
--error 1062
eval insert into test_insert_conflict_check values ('h$value',0);
--error 1062
eval insert into test_insert_conflict_check values ('i$value',0);
--error 1062
eval insert into test_insert_conflict_check values ('k$value',0);
--error 1062
eval insert into test_insert_conflict_check values ('l$value',0);

set session ob_trx_timeout=1000000;

--error 1205
eval insert into test_insert_conflict_check values ('y$value',0);
--error 1205
eval insert into test_insert_conflict_check values ('z$value',0);
--error 1205 
eval update test_insert_conflict_check set c2=7 where c1='m$value';

begin;
eval update test_insert_conflict_check set c2=2 where c1='a$value';
rollback;

connection conn3;
--error 6235
eval update test_insert_conflict_check set c2=3 where c1='a$value';
commit;

connection conn2;
eval insert into test_insert_conflict_check values ('b$value',0);
eval insert into test_insert_conflict_check values ('j$value',0);
eval insert into test_insert_conflict_check values ('n$value',0);
eval insert into test_insert_conflict_check values ('o$value',0);

connection conn1;
commit;

connection conn0;
alter system minor freeze;
--source mysql_test/include/wait_minor_merge.inc

connection conn2;
--error 1062
eval insert into test_insert_conflict_check values ('c$value',0);
--error 1062
eval insert into test_insert_conflict_check values ('d$value',0);
--error 1062
eval insert into test_insert_conflict_check values ('e$value',0);
--error 1062
eval insert into test_insert_conflict_check values ('f$value',0);
--error 1062
eval insert into test_insert_conflict_check values ('g$value',0);
--error 1062
eval insert into test_insert_conflict_check values ('h$value',0);
--error 1062
eval insert into test_insert_conflict_check values ('i$value',0);
--error 1062
eval insert into test_insert_conflict_check values ('k$value',0);
--error 1062
eval insert into test_insert_conflict_check values ('l$value',0);
--error 1062
eval insert into test_insert_conflict_check values ('m$value',0);

--error 1062
eval insert into test_insert_conflict_check values ('y$value',0);
--error 1062
eval insert into test_insert_conflict_check values ('z$value',0);
--error 1062
eval insert into test_insert_conflict_check values ('a$value',0);
--error 1062
eval insert into test_insert_conflict_check values ('b$value',0);
--error 1062
eval insert into test_insert_conflict_check values ('j$value',0);
--error 1062
eval insert into test_insert_conflict_check values ('n$value',0);
--error 1062
eval insert into test_insert_conflict_check values ('o$value',0);

eval insert into test_insert_conflict_check values ('s$value',0);
eval insert into test_insert_conflict_check values ('t$value',0);
eval insert into test_insert_conflict_check values ('r$value',0);
eval update test_insert_conflict_check set c2=7 where c1='m$value';

drop table test_insert_conflict_check;
