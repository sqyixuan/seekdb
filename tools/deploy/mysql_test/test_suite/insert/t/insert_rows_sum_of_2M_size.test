--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: link.zt
#owner: jingyan.kfy
#owner group: sql1
#description: 用于测试将近2M的insert sql语句的执行

--disable_abort_on_error
--disable_warnings
drop table if exists t1;
--enable_warnings

--let $value=1
--let $kb=62
--let $
while($kb)
{
    --let $value=$value$byte
    dec $kb;
}


# insert one each time
create table t1(pk int primary key, f1 varchar(65535));

--let $row=50

--disable_query_log
while($row)
{
   eval insert into t1 values($row, '$value');
   dec $row;
}
--enable_query_log

select * from t1;
drop table t1;

###
### insert nearly overflow max_allowed size
create table t1(pk int primary key, f1 varchar(65535));

--let $insert_sql_low=insert into t1 values(-1,'1')
--let $row=16

--disable_query_log
while($row)
{
   --let $insert_sql_low=$insert_sql_low,($row, '$value')
   dec $row;
}
eval $insert_sql_low;
--enable_query_log
select * from t1;
drop table t1;
###

# insert all
create table t1(pk int primary key, f1 varchar(65535));

--let $insert_sql=insert into t1 values(-1,'1')
--let $row=100

--disable_query_log
while($row)
{
   --let $insert_sql=$insert_sql,($row, '$value')
   dec $row;
}
eval $insert_sql;
--enable_query_log

sleep 1;
drop table t1;
