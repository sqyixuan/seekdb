# owner: chaser.ch
# owner group: storage
# description: for conflict check when batch insert rows

#--disable_abort_on_error
--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;

connect (conn2,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn0,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,oceanbase,$OBMYSQL_PORT);

connection conn0;
alter system set minor_compact_trigger = 10;

connection conn1;
--disable_warnings
drop table if exists test_batch_insert_conflict_check;
--enable_warnings
set session ob_trx_timeout=20000000;
create table test_batch_insert_conflict_check(c1 int primary key, c2 int);

connection conn1;
insert into test_batch_insert_conflict_check values(10,0),(11,0),(12,0),(13,0),(100,0);
begin;
insert into test_batch_insert_conflict_check values(9,0);

connection conn0;
alter system minor freeze;
--source mysql_test/include/wait_minor_merge.inc

connection conn2;
--error 1205 
insert into test_batch_insert_conflict_check values(8,0),(9,0);

connection conn1;
commit;

connection conn2;
--error 1062 
insert into test_batch_insert_conflict_check values(8,0),(9,0);

connection conn0;
alter system major freeze;
--source mysql_test/include/wait_daily_merge.inc

connection conn1;
insert into test_batch_insert_conflict_check values(20,0),(21,0),(22,0),(33,0),(34,0);

connection conn0;
alter system minor freeze;
--source mysql_test/include/wait_minor_merge.inc

connection conn1;
insert into test_batch_insert_conflict_check values(18,0),(19,0),(35,0);
begin;
delete from test_batch_insert_conflict_check where c1 = 12;

connection conn2;
--error 1062 
insert into test_batch_insert_conflict_check values(1,0),(3,0),(5,0),(13,0);

insert into test_batch_insert_conflict_check values(1,0),(3,0),(5,0),(7,0);

--error 1205 
insert into test_batch_insert_conflict_check values(4,0),(12,0);

connection conn1;
commit;

connection conn2;
insert into test_batch_insert_conflict_check values(4,0),(12,0);
select * from test_batch_insert_conflict_check; 

--disable_warnings
drop table if exists test_batch_insert_conflict_check;
--enable_warnings

connection conn1;
--let $value=1
--let $bytes=1500
--let $byte=1
while($bytes)
{
    --let $value=$value$byte
    dec $bytes;
}

connection conn2;
--disable_warnings
drop table if exists test_batch_insert_duplication_check;
--enable_warnings
create table test_batch_insert_duplication_check(c1 int primary key, c2 varchar(2048)) BLOCK_SIZE = 4096 COMPRESSION = 'none';

connection conn2;
eval insert into test_batch_insert_duplication_check values (1, 'a$value');

connection conn1;
alter system major freeze;
--source mysql_test/include/wait_daily_merge.inc

connection conn2;
delete from test_batch_insert_duplication_check where c1 = 1; 
begin;
eval insert into test_batch_insert_duplication_check values (1, 'a$value');
delete from test_batch_insert_duplication_check where c1 = 1;
eval insert into test_batch_insert_duplication_check values (1, 'b$value');
delete from test_batch_insert_duplication_check where c1 = 1;
eval insert into test_batch_insert_duplication_check values (1, 'c$value');
delete from test_batch_insert_duplication_check where c1 = 1;
eval insert into test_batch_insert_duplication_check values (1, 'd$value');
delete from test_batch_insert_duplication_check where c1 = 1;
eval insert into test_batch_insert_duplication_check values (1, 'e$value');
delete from test_batch_insert_duplication_check where c1 = 1;
eval insert into test_batch_insert_duplication_check values (1, 'f$value');
delete from test_batch_insert_duplication_check where c1 = 1;
eval insert into test_batch_insert_duplication_check values (1, 'g$value');
delete from test_batch_insert_duplication_check where c1 = 1;
eval insert into test_batch_insert_duplication_check values (1, 'h$value');
delete from test_batch_insert_duplication_check where c1 = 1;
eval insert into test_batch_insert_duplication_check values (1, 'i$value');
delete from test_batch_insert_duplication_check where c1 = 1;
eval insert into test_batch_insert_duplication_check values (1, 'j$value');
delete from test_batch_insert_duplication_check where c1 = 1;
eval insert into test_batch_insert_duplication_check values (1, 'k$value');
delete from test_batch_insert_duplication_check where c1 = 1;
eval insert into test_batch_insert_duplication_check values (1, 'l$value');
delete from test_batch_insert_duplication_check where c1 = 1;
eval insert into test_batch_insert_duplication_check values (1, 'm$value');
delete from test_batch_insert_duplication_check where c1 = 1;
eval insert into test_batch_insert_duplication_check values (1, 'n$value');
delete from test_batch_insert_duplication_check where c1 = 1;

connection conn1;
alter system minor freeze;
--source mysql_test/include/wait_minor_merge.inc

connection conn2;
rollback;
insert into test_batch_insert_duplication_check values (1, ''),(2, '');
select * from test_batch_insert_duplication_check; 
drop table test_batch_insert_duplication_check;

connection conn2;
--disable_warnings
drop table if exists test_batch_insert_duplication_check2;
--enable_warnings
create table test_batch_insert_duplication_check2(c1 int primary key); 
begin;
insert into test_batch_insert_duplication_check2 values(2);
savepoint s1;
insert into test_batch_insert_duplication_check2 values(1);

connection conn1;
alter system minor freeze;
--source mysql_test/include/wait_minor_merge.inc

connection conn2;
rollback to s1;
select * from test_batch_insert_duplication_check2;
insert into test_batch_insert_duplication_check2 values(1),(100);
select * from test_batch_insert_duplication_check2; 
commit;
drop table test_batch_insert_duplication_check2;
