  KEY `idx1` (`pk`, `col_bigint_index`),
  KEY `idx3` (`pk`, `col_char_20_index`) ,
  KEY `idx5` (`pk`, `col_timestamp_6_index`)
) DEFAULT CHARSET = utf8mb4  partition by key(pk) partitions 1;
