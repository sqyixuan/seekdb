--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: yuchen.wyc
#tags: optimizer
# owner group: SQL1
# description: 本case是为了测试insert 多行加values（）函数的情况；
# tags: dml
--disable_warnings
drop table if exists test;
--enable_warnings
--result_format 4

create table test(c1 int, c2 int, c3 int);
insert into test values(1,1,1),(2,2,2),(3,3,3);
select * from test;

drop table test;
create table test(c1 int primary key, c2 int, c3 int);
insert into test values(1,1,1),(2,2,2),(3,3,3);
select * from test;
insert into test values(1,1,1),(2,2,2),(3,3,3) on duplicate key update c2 = values(c1)+ values(c3),
      c3 = values(c1) + values(c3) + values(c2);
select * from test;

insert into test values(4, c1+1, c1+2), (5, c1 + c2, c2+c1+c3), (6,c1+c2, c2+c1+c3);
select * from test;
insert into test values(4, c1+1, c1+2), (5, c1 + c2, c2+c1+c3), (6,c1+c2, c2+c1+c3) on duplicate key
update c2 = values(c1)+ values(c3), c3 = values(c1) + values(c3) + values(c2);
select * from test;

insert into test set c1 = 7, c2=c1+5, c3=c1+c2;
insert into test set c1 = 8, c2=c1+5, c3=c1+c2 + c3;
select * from test;
insert into test set c1 = 7, c2=c1+5, c3=c1+c2 on duplicate key update c2 = values(c1)+ values(c3),
       c3 = values(c1) + values(c3) + values(c2);
insert into test set c1 = 8, c2=c1+5, c3=c1+c2 + c3 on duplicate key update c2 = values(c1)+ values(c3), c3 = values(c1) + values(c3) + values(c2);
select * from test;

########
# 主键为自增列
########
drop table test;
create table test(c1 int primary key auto_increment, c2 int, c3 int);
insert into test values(1,1,1),(2,2,2),(3,3,3);
select * from test;
insert into test values(1,1,1),(2,2,2),(3,3,3) on duplicate key update c2 = values(c1)+ values(c3),
      c3 = values(c1) + values(c3) + values(c2);
select * from test;

insert into test values(4, c1+1, c1+2), (5, c1 + c2, c2+c1+c3), (6,c1+c2, c2+c1+c3);
select * from test;
insert into test values(4, c1+1, c1+2), (5, c1 + c2, c2+c1+c3), (6,c1+c2, c2+c1+c3) on duplicate key
update c2 = values(c1)+ values(c3), c3 = values(c1) + values(c3) + values(c2);
select * from test;

insert into test set c1 = 7, c2=c1+5, c3=c1+c2;
insert into test set c1 = 8, c2=c1+5, c3=c1+c2 + c3;
select * from test;
insert into test set c1 = 7, c2=c1+5, c3=c1+c2 on duplicate key update c2 = values(c1)+ values(c3),
       c3 = values(c1) + values(c3) + values(c2);
insert into test set c1 = 8, c2=c1+5, c3=c1+c2 + c3 on duplicate key update c2 = values(c1)+ values(c3), c3 = values(c1) + values(c3) + values(c2);
select * from test;

delete from test;
insert into test(c2,c3) values(c1+1, c1+2), (c1 + c2, c2+c1+c3), (c1+c2, c2+c1+c3);
select * from test;
insert into test (c2,c3)values(c1+1, c1+2), (c1 + c2, c2+c1+c3), (c1+c2, c2+c1+c3) on duplicate key
update c2 = values(c1)+ values(c3), c3 = values(c1) + values(c3) + values(c2);
select * from test;

insert into test set c2=c1+5, c3=c1+c2;
insert into test set c2=c1+5, c3=c1+c2 + c3;
select * from test;
insert into test set c1 = 2, c2=c1+5, c3=c1+c2 on duplicate key update c2 = values(c1)+ values(c3),
       c3 = values(c1) + values(c3) + values(c2);
insert into test set c1 = 3, c2=c1+5, c3=c1+c2 + c3 on duplicate key update c2 = values(c1)+ values(c3), c3 = values(c1) + values(c3) + values(c2);
select * from test;

#########
# 带char列
#########
drop table test;
create table test(c1 int primary key, c2 char(5), c3 char(8));
insert into test values(1, 'sbc    ', concat(c2, 'd'));
select * from test;
set @@sql_mode='';
insert into test values(1, 'deeeeee', concat(c2, 'de')), (2, 'eeee22aa', 'eeff')on duplicate key update c3 = values(c2);
select * from test;
insert into test values(1, 'deeeeee', concat(c2, 'de')), (2, 'eeee22aa', 'eeff')on duplicate key update c3 = values(c2);
select * from test;
set @@sql_mode ='pad_char_to_full_length';
insert into test values(1, 'dee', concat(c2, 'de')), (2, 'eeee22aa', 'eeff')on duplicate key update c3 = values(c2);
select * from test;
insert into test values(1, 'dee', concat(c2, 'de')), (2, 'eeee22aa', 'eeff')on duplicate key update c3 = values(c2);
select * from test;

#######
# values()函数用在insert  values里面
#######
drop table test;
create table test(c1 int default 3, c2 int);
insert into test values(1, values(c2));
insert into test values(2, values(c1));
insert into test values(values(c1), 3);
insert into test values(values(c2), 4);
insert into test values(values(c2), values(c1));
select * from test;
drop table test;

###binary类型的列
create table test(c1 binary(4), c2 binary(5));
insert into test values(4, c1 + 1);
insert into test values(4, concat(c1,1));
select hex(c1),hex(c2) from test;
drop table test;

create table test(id int primary key, name varchar(10), telephone varchar(10)) partition by range(id) (partition p0 values less than(10), partition p1 values less than(20), partition pmax values less than(MAXVALUE));
create index idx on test(telephone) partition by key(telephone) partitions 2;
--error 1748
insert into test partition(p0) values(200, 'abc', '123456');
drop table test;

--disable_warnings
DROP TABLE IF EXISTS t_high_avaiable_test;
--enable_warnings
CREATE TABLE t_high_avaiable_test (
    id int(11) NOT NULL,
    name varchar(20) DEFAULT NULL,
    code int(11) NOT NULL,
    insert_time datetime default current_timestamp,
    constraint pk_t_high_avaiable_test PRIMARY KEY (id, code)
    )
  partition by list (code)
  (
   partition p1 values in (1),
   partition p2 values in (2),
   partition p3 values in (3)
  );


--explain_protocol 1
insert into t_high_avaiable_test(id, name, code) value(1,'aa',floor(rand()*3)+1);
insert into t_high_avaiable_test(id, name, code) value(2,'aa',floor(rand()*3)+1);
insert into t_high_avaiable_test(id, name, code) value(3,'aa',floor(rand()*3)+1);

select count(1) from t_high_avaiable_test;
drop table t_high_avaiable_test;

--explain_protocol 0
#test multi partition insert index with LTS
--disable_result_log
--disable_query_log
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
let $old_primary_zone=query_get_value(select primary_zone from oceanbase.__all_tenant where tenant_name='mysql',primary_zone,1);
alter tenant sys set primary_zone='RANDOM';
connection default;
sleep 3;
--enable_result_log
--enable_query_log
create table test(a int primary key, b int) partition by hash(a) partitions 3;
insert into test values(1, 1), (2, 2), (3, 3);
insert into test select 4, 4 union select 5, 5 union select 6, 6;
##test rely consistent snapshot sql
--source mysql_test/include/replace_object_name_created_by_sys.inc
--error 1062
insert into test select * from test t;
--error 0,1235
update test set b=1 where a>=3;
--error 0,1235
select * from test order by a;
--disable_result_log
--disable_query_log
connection obsys;
eval alter tenant sys set primary_zone='zone1';
connection default;
--enable_result_log
--enable_query_log

## oracle 模式下，普通SQL不支持 insert + ref 
drop table test;
create table test(a int, b int);
--error 1064,4007
insert into test values rec1;
drop table test;

