# aone issue: 
 
--disable_warnings
drop table if exists t1;
--enable_warnings
 
create table t1(c1 int primary key auto_increment, c2 date, c3 datetime, c4 float, c5 double, c6 decimal, c7 year);

# INCORRECT INT
--error 1366
insert into t1(c1) values (1), ('a'), (3);
--error 1366
insert into t1(c1) select 1 from dual union all select 2 from dual union select 'a' from dual;
--error 1366
replace into t1(c1) values (1), ('a'), (3);
--error 1366
replace into t1(c1) select 1 from dual union all select 2 from dual union select 'a' from dual;
 
# INCORRECT DATE
--error 1292
insert into t1(c2) values (date'20220324'), (3), (date'20230324');
--error 1292
insert into t1(c2) select date'20220324' from dual union all select 3 from dual union select date'20230324' from dual;
--error 1292
replace into t1(c2) values (date'20220324'), (3), (date'20230324');
--error 1292
replace into t1(c2) select date'20220324' from dual union all select 3 from dual union select date'20230324' from dual;

# INCORRECT DATETIME;
--error 1292
insert into t1(c3) values ('2022-03-24 10:00:00'), (3);
--error 1292
insert into t1(c3) select 3 from dual union all select '2022-03-24 10:00:00' from dual;
--error 1292
replace into t1(c3) values ('2022-03-24 10:00:00'), (3);
--error 1292
insert into t1(c3) select 3 from dual union all select '2022-03-24 10:00:00' from dual;

# INCORRECT FLOAT/DOUBLE
--error 1265
insert into t1(c4) values (1.1), ('a');
--error 1265
insert into t1(c4) select 'a' from dual union all select 1.1 from dual;
--error 1265
replace into t1(c4) values (1.1), ('a');
--error 1265
replace into t1(c4) select 'a' from dual union all select 1.1 from dual;
--error 1265
insert into t1(c5) values (1.1), ('a');
--error 1265
insert into t1(c5) select 'a' from dual union all select 1.1 from dual;
--error 1265
replace into t1(c5) values (1.1), ('a');
--error 1265
replace into t1(c5) select 'a' from dual union all select 1.1 from dual;

# INCORRECT DECIMAL
--error 1366
insert into t1(c6) values (1.1), ('a');
--error 1366
insert into t1(c6) select 'a' from dual union all select 1.1 from dual;
--error 1366
replace into t1(c6) values (1.1), ('a');
--error 1366
replace into t1(c6) select 'a' from dual union all select 1.1 from dual;

# INCORRECT YEAR 
--error 1366
insert into t1(c7) values (2022), ('a');
--error 1366
insert into t1(c7) select 'a' from dual union all select 2022 from dual;
--error 1366
replace into t1(c7) values (2022), ('a');
--error 1366
replace into t1(c7) select 'a' from dual union all select 2022 from dual;

# INSERT/REPLACE ON DUPLICATE KEY UPDATE
--error 1292
insert into t1(c1, c2) values (1, 2) on duplicate key update c2 = date'20220324';
--error 1292
insert into t1(c1, c2) select 2, date"20230324" from dual union all select 1, 3 from dual on duplicate key update c2 = date'20220324';
--error 1292
insert into t1(c1, c2) values (1, 2) on duplicate key update c2 = date'20220324';
--error 1292
insert into t1(c1, c2) select 2, date"20230324" from dual union all select 1, 3 from dual on duplicate key update c2 = date'20220324';

--disable_warnings
drop table if exists t1;