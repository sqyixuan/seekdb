--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: laibingzheng.lbz
# owner group: DML
# description: 本case是为了测试insert ignore的情况；
# tags: dml
--disable_warnings
drop table if exists t1;
--enable_warnings
--result_format 4

create table t1(c1 varchar(10) not null unique, c2 int not null);
insert ignore t1 values(null,null);
select * from t1;
drop table t1;
