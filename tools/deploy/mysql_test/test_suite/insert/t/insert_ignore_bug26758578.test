# owner: yuchen.wyc
# owner group: SQL1
# description: multi part insert with ignore 
# tags: dml,dml_ignore

--disable_warnings
drop table if exists keystore_datatype2,t1,t2;
--enable_warnings


create table keystore_datatype2(c1 integer, primary key (c1)
) DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC partition by range(c1)(partition p0 values less than (0),partition p1 values less than (3000),partition p2 values less than maxvalue);
create table t1 (c1 int primary key, c2 int) partition by hash(c1) partitions 3;
create index idx1 on t1 (c2) global;
create table t2 (c1 int primary key, c2 int) partition by hash(c1) partitions 3;
create index idx2 on t2 (c2) global partition by range (c2)
(
  partition p0 values less than (100),
  partition p1 values less than (200)
);

insert ignore into keystore_datatype2 values (''), (0.0);
insert ignore into keystore_datatype2 values (''), (-129), (0.0);
select * from keystore_datatype2;
--error 1235
insert ignore into t1 values (1, 1), (2, 2);
--error 1235
update ignore t1 set c1 = 20;

drop table keystore_datatype2, t1, t2;
