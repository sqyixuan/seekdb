--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: yuchen.wyc
# owner group: SQL1
# description: 本case是为了测试DML操作时，啥时候用显式default值，什么时候用隐式default值
# tags: dml,default_value

--disable_warnings
drop table if exists test;
--enable_warnings

echo 'insert + strict mode + not null';
create table test (c1 int auto_increment primary key, c2 int not null, c3 int not null default 3,
    c4 char(10) not null, c5 char(10) not null default 'hello',
    c6 timestamp not null, c7 timestamp not null default '1998-09-23 12:34:12',
    c8 time not null, c9 time not null default '12:23:23',
    c10 datetime not null, c11 datetime not null default '1998-09-23 12:34:12');


#set c1 = c1
insert into test set c1 = 1,c2=c2,c3=c3,c4=c4,c5=c5,c6=c6,c7=c7,c8=c8,c9=c9,c10=c10,c11=c11;
select * from test;


#set c1 = default;
echo 'strict + not null + default';
delete from test;
--error 1364
insert into test set c1= default,
       c2=default,c3=default,c4=default,c5=default,c6=default,c7=default,c8=default,c9=default,c10=default,c11=default;
--error 1364
insert into test set c1= default,
       c2=1,c3=default,c4=default,c5=default,c6=default,c7=default,c8=default,c9=default,c10=default,c11=default;
--error 1364
insert into test set c1= default,
       c2=1,c3=default,c4='ese',c5=default,c6=default,c7=default,c8=default,c9=default,c10=default,c11=default;
--error 1364
insert into test set c1= default,
       c2=1,c3=default,c4='ese',c5=default,c6=default,c7=default,c8='12:23:12',c9=default,c10=default,c11=default;
insert into test set c1= default,
       c2=1,c3=default,c4='ese',c5=default,c6=default,c7=default,c8='12:23:12',c9=default,c10='1998-09-23 12:34:12',c11=default;
select c1,c2,c3,c4,c5,c7,c8,c9,c10,c11 from test;

echo 'strict + not null + default(c1)';


delete from test;
--error 1364
insert into test set c1 = default(c1), c2 = default(c2),c3=default(c3),c4=default(c4),
       c5=default(c5),c6=default(c6),c7=default(c7),c8=default(c8),c9=default(c9),c10=default(c10),c11=default(c11);
--error 1364
insert into test set c1 = default(c1), c2 = 100,c3=default(c3),c4=default(c4),
       c5=default(c5),c6=default(c6),c7=default(c7),c8=default(c8),c9=default(c9),c10=default(c10),c11=default(c11);
--error 1364
insert into test set c1 = default(c1), c2 = 100,c3=default(c3),c4='yes3',
       c5=default(c5),c6=default(c6),c7=default(c7),c8=default(c8),c9=default(c9),c10=default(c10),c11=default(c11);
--error 1364
insert into test set c1 = default(c1), c2 = 100,c3=default(c3),c4='yes3',
       c5=default(c5),c6=default(c6),c7=default(c7),c8='12:23:12',c9=default(c9),c10=default(c10),c11=default(c11);
insert into test set c1 = default(c1), c2 = 100,c3=default(c3),c4='yes3',
       c5=default(c5),c6=default(c6),c7=default(c7),c8='12:23:12',c9=default(c9),c10='2013-02-12 23:22:22',c11=default(c11);

echo 'strict + not null + 不带';
delete from test;
--error 1364,1048
insert into test set c1 = 5;
--error 1364,1048
insert into test set c1 = 5, c2 = 100;
--error 1364,1048
insert into test set c1 = 5, c2 = 100, c4='no';
--error 1364,1048
insert into test set c1 = 5, c2 = 100, c4='no',c8='12:23:12';
insert into test set c1 = 5, c2 = 100, c4='no',c8='12:23:12', c10='2013-02-12 23:22:22';

####
set @@sql_mode='';
echo 'not strict + not null';
delete from test;
#set c1 = c1
insert into test set c1 = 1,c2=c2,c3=c3,c4=c4,c5=c5,c6=c6,c7=c7,c8=c8,c9=c9,c10=c10,c11=c11;
select c1,c2,c3,c4,c5,c7,c8,c9,c10,c11 from test;

#set c1 = default;
echo 'not strict + not null + default';
delete from test;
insert into test set c1= default,
       c2=default,c3=default,c4=default,c5=default,c6=default,c7=default,c8=default,c9=default,c10=default,c11=default;
select c1,c2,c3,c4,c5,c7,c8,c9,c10,c11 from test;
echo 'strict + not null + default(c1)';


delete from test;
--error 1364
insert into test set c1 = default(c1), c2 = default(c2),c3=default(c3),c4=default(c4),
       c5=default(c5),c6=default(c6),c7=default(c7),c8=default(c8),c9=default(c9),c10=default(c10),c11=default(c11);
--error 1364
insert into test set c1 = default(c1), c2 = 100,c3=default(c3),c4=default(c4),
       c5=default(c5),c6=default(c6),c7=default(c7),c8=default(c8),c9=default(c9),c10=default(c10),c11=default(c11);
--error 1364
insert into test set c1 = default(c1), c2 = 100,c3=default(c3),c4='yes3',
       c5=default(c5),c6=default(c6),c7=default(c7),c8=default(c8),c9=default(c9),c10=default(c10),c11=default(c11);
--error 1364
insert into test set c1 = default(c1), c2 = 100,c3=default(c3),c4='yes3',
       c5=default(c5),c6=default(c6),c7=default(c7),c8='12:23:12',c9=default(c9),c10=default(c10),c11=default(c11);
insert into test set c1 = default(c1), c2 = 100,c3=default(c3),c4='yes3',
       c5=default(c5),c6=default(c6),c7=default(c7),c8='12:23:12',c9=default(c9),c10='2013-02-12 23:22:22',c11=default(c11);

echo 'strict + not null + 不带';
delete from test;
insert /*+USE_PLAN_CACHE(NONE)*/ into test set c1 = 5;
select c1,c2,c3,c4,c5,c7,c8,c9,c10,c11 from test;
######################
########### start to proess  null column
drop table test;
echo 'insert + strict mode +  ';
create table test (c1 int auto_increment primary key, c2 int  , c3 int   default 3,
    c4 char(10)  , c5 char(10)   default 'hello',
    c6 timestamp  , c7 timestamp   default '1998-09-23 12:34:12',
    c8 time  , c9 time   default '12:23:23',
    c10 datetime  , c11 datetime   default '1998-09-23 12:34:12');


#set c1 = c1
insert into test set c1 = 1,c2=c2,c3=c3,c4=c4,c5=c5,c6=c6,c7=c7,c8=c8,c9=c9,c10=c10,c11=c11;
select * from test;


#set c1 = default;
echo 'strict +   + default';
delete from test;
insert into test set c1= default,
       c2=default,c3=default,c4=default,c5=default,c6=default,c7=default,c8=default,c9=default,c10=default,c11=default;

select c1,c2,c3,c4,c5,c7,c8,c9,c10,c11 from test;
echo 'strict +   + default(c1)';


delete from test;
insert into test set c1 = default(c1), c2 = default(c2),c3=default(c3),c4=default(c4),
       c5=default(c5),c6=default(c6),c7=default(c7),c8=default(c8),c9=default(c9),c10=default(c10),c11=default(c11);
select * from test;

echo 'strict +   + 不带';
delete from test;
insert into test set c1 = 5;

select c1,c2,c3,c4,c5,c7,c8,c9,c10,c11 from test;
####
set @@sql_mode='';
echo 'not strict +  ';
#set c1 = c1
insert into test set c1 = 1,c2=c2,c3=c3,c4=c4,c5=c5,c6=c6,c7=c7,c8=c8,c9=c9,c10=c10,c11=c11;

select c1,c2,c3,c4,c5,c7,c8,c9,c10,c11 from test;

#set c1 = default;
echo 'not strict +   + default';
delete from test;
insert into test set c1= default,
       c2=default,c3=default,c4=default,c5=default,c6=default,c7=default,c8=default,c9=default,c10=default,c11=default;

select c1,c2,c3,c4,c5,c7,c8,c9,c10,c11 from test;
echo 'strict +   + default(c1)';


delete from test;
insert into test set c1 = default(c1), c2 = default(c2),c3=default(c3),c4=default(c4),
       c5=default(c5),c6=default(c6),c7=default(c7),c8=default(c8),c9=default(c9),c10=default(c10),c11=default(c11);
select * from test;



echo 'strict +   + 不带';
delete from test;
insert into test set c1 = 5;
select c1,c2,c3,c4,c5,c7,c8,c9,c10,c11 from test;

drop table test;
create table test (c1 decimal, c2 decimal(65, 30));
explain insert into test set c1 = 1 * c2;
insert into test set c1 = 1 * c2;
explain insert into test set c1 = 1.1 * c2;
insert into test set c1 = 1.1 * c2;
explain insert into test set c1 = '1.1' * c2;
insert into test set c1 = '1.1' * c2;
select * from test;
drop table test;