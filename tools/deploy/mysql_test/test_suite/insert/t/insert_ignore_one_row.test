# owner: xiaoyi.xy
# owner group: SQL3
# description: 本case是为了测试单语句情况下insert ignore的问题； insert ignore on
# update,包括主键错误，数据类型错误，事务相关
# tags: dml,dml_ignore
--disable_warnings
drop table if exists test;
--enable_warnings
create table test (c1 int primary key, c2 int unique key, c3 int, c4 char(3));
#插入主键冲突
insert into test values(1,2,3,4);
--error 1062
insert into test values(1,1,1,1);
insert ignore into test values(1,1,1,1);
#唯一索引冲突；
--error 1062
insert  into test values(2,2,3,4);
insert ignore into test values(2,2,3,4);
#index冲突；
insert into test values(3,3,3,3);
insert ignore into test values(4,3,3,3);
#insert update相关：
delete from test;
insert into test values(1,2,3,4);
insert into test values(3,3,3,3);
#同行内冲突；
insert ignore into test values(1,1,1,1) on duplicate key update c1 = 1;
select * from test;
insert ignore into test values(1,1,1,1) on duplicate key update c2 = 2;
select * from test;
insert ignore into test values(1,1,1,1) on duplicate key update c2 = 4;
select * from test;
#跟其他行冲突
insert ignore into test values(1,1,1,1) on duplicate key update c2 = 3;
select * from test;
#insert 发生update，update要进行类型转换；
delete from test;
insert into test values(1,2,3,4);
insert into test values(3,3,3,3);
--error 1406
insert into test values(1,1,1,1) on duplicate key update c4 = 'hello';
insert ignore into test values(1,1,1,1) on duplicate key update c4 = 'hello';
#show warnings;
drop table test;

#数据类型转
create table test (c1 int primary key, c2 time, c3 char(3));
--error 1406
insert into test values(1, 0, 'nihoaaw');
insert ignore test values(1, 0, 'nihoaaw');
select * from test;
set sql_mode='';
insert ignore test values(2, 0, 'nihoaaw');
select * from test;
set sql_mode='strict_all_tables';
drop table test;

#开启事务
create table test (c1 int primary key, c2 time, c3 char(3));
start transaction;
insert into test values(1, 0, 'ni');
--error 1406
insert into test values(2, 0, 'nihoaaw');
select * from test;
insert ignore into test values(3, 0, 'nihoaaw');
select * from test;
--error 1406
update test set c2 = '12:12:12', c3 = 'hoense';
select * from test;
update ignore test set c2 = '12:12:12', c3 = 'hoense';
select * from test;
commit;
select * from test;
drop table test;

