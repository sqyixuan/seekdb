--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: xiaoyi.xy 
#tags: optimizer
# owner group: sql3
# description: 测试insert into t1 select * from t1这种情况
# tags: dml
--disable_warnings
drop table if exists t1,t2,t3,t4,test;
--enable_warnings
--result_format 4

create table t1(c1 int primary key, c2 int);
create table t2(c1 int, c2 int);
create table t3(c1 int primary key, c2 int, c3 int);
create table t4(c1 int primary key, c2 int) partition by hash(c1) partitions 3;
create table test(c1 int primary key auto_increment, c2 int);
#prepare data
insert into t1 values(1, 1), (2, 2);
insert into t2 values(3, 3), (4, 4);
#test insert into...select...
insert into t1 select * from t2;
select * from t1;
insert into t2 select * from t1;
select * from t2;
insert into t2(c2) select c2 from t2;
select * from t2;
#Duplicate entry '1' for key 'PRIMARY'
--error 1062
insert into t1 select * from t1;
insert into t2 select * from t2; 
select * from t2;
insert into t2 select c1, c2 from t3;
select * from t2;
insert into t3 select distinct c1, c2, c1 from t2 where c1 is not null;
select * from t3;
insert into t1 select * from t4;
insert into t1 select t3.c1, t3.c2 from t3 join t4 using(c1);
--error 1062
insert into t1 select * from (select c1, c2 from t3 union select c1, c2 from t4) tt;

delete from t2;
insert into t2 (c1) select c1 from t1;
select * from t2;
insert into test(c2) select c1 from t1;
select * from test;
insert into test(c2) select c1 from t1;
select * from test;

drop table t1, t2, t3, t4;
####insert select update
create table t1(c1 int primary key, c2 int, d int default 5);
create table t2(c3 int primary key, c4 int, d int);
insert into t2 values(1,2,3),(3,3,4);
insert into t1 select * from t2 on duplicate key update t1.c1 = t1.c1 + 1;
insert into t1 select * from t2 on duplicate key update t1.c1 = t1.c1 + 1;
select * from t1;
insert into t1 select * from t2 on duplicate key update t1.c1 = t1.c1 + 1 + values(c1), c2 = c1 + 3;
delete from t1;
#不带默认值
insert into t1(c1) select c3 from t2 on duplicate key update t1.c1 = t1.c1 + 1;
insert into t1(c1) select c3 from t2 on duplicate key update t1.c1 = t1.c1 + 1;
insert into t1(c1) select c3 from t2 on duplicate key update c1 = t1.c1 + 1 + values(c1), c2 = c1 + 3;
select * from t1;
drop table t1,t2;
####insert select update 带自增列
create table t1(c1 int primary key auto_increment, c2 int, c3 int);
create table t2(c4 int primary key, c5 int, c6 int);
insert into t2 values(1,2,3), (3,3,4);
insert into t1(c2,c3) select c4,c5 from t2;
insert into t1(c2,c3) select c4,c5 from t2 on duplicate key update t1.c2 = values(t1.c2) + values(t1.c3);
select * from t1;
drop table t1;
drop table t2;
create table t2(c1 enum('a','b','c'), c2 enum('a','b','c'));
--disable_query_log
insert into t2 values (1,1);
--enable_query_log
insert into t2 select c1 ,c1 from t2;
insert into t2 select c1 ,c1 from t2;
select * from t2;
drop table t2;
create table t1 (c1 int, c2 int, primary key(c1));
create table t2 (k1 int, k2 int);
insert into t2 values(1, 1);
explain insert into t1(c1, c2) select k1, k2 from t2 on duplicate key update c1 = c1 - k1;
insert into t1(c1, c2) select k1, k2 from t2 on duplicate key update c1 = c1 - k1;
select * from t1;
insert into t1(c1, c2) select k1, k2 from t2 on duplicate key update c1 = c1 - k1;
select * from t1;
insert into t1(c1, c2) select k1, k2 from t2 on duplicate key update c1 = c1 - k1;
select * from t1;
--error 1062
insert into t1(c1, c2) select k1, k2 from t2 on duplicate key update c1 = c1 - k1;
delete from t1;
explain insert into t1(c1, c2) select 1, k2 from t2 on duplicate key update c1 = c1 - k1;
insert into t1(c1, c2) select 1, k2 from t2 on duplicate key update c1 = c1 - k1;
select * from t1;
insert into t1(c1, c2) select 1, k2 from t2 on duplicate key update c1 = c1 - k1;
select * from t1;
insert into t1(c1, c2) select 1, k2 from t2 on duplicate key update c1 = c1 - k1;
select * from t1;
--error 1062
insert into t1(c1, c2) select 1, k2 from t2 on duplicate key update c1 = c1 - k1;
drop table t1;
drop table t2;
create table t1 (c1 int, c2 int, primary key(c1));
create index idx on t1(c2) partition by hash(c2) partitions 2;
--source mysql_test/include/check_all_idx_ok.inc
create table t2 (k1 int, k2 int);
insert into t2 values(1, 2);
explain insert into t1(c1, c2) select k1, k2 from t2 on duplicate key update c1 = c1 - k1;
insert into t1(c1, c2) select k1, k2 from t2 on duplicate key update c1 = c1 - k1;
select * from t1;
insert into t1(c1, c2) select k1, k2 from t2 on duplicate key update c1 = c1 - k1;
select * from t1;
insert into t1(c1, c2) select k1, k2 from t2 on duplicate key update c1 = c1 - k1;
select * from t1;
--error 1062
insert into t1(c1, c2) select k1, k2 from t2 on duplicate key update c1 = c1 - k1;
delete from t1;
explain insert into t1(c1, c2) select 1, k2 from t2 on duplicate key update c1 = c1 - k1;
insert into t1(c1, c2) select 1, k2 from t2 on duplicate key update c1 = c1 - k1;
select * from t1;
insert into t1(c1, c2) select 1, k2 from t2 on duplicate key update c1 = c1 - k1;
select * from t1;
insert into t1(c1, c2) select 1, k2 from t2 on duplicate key update c1 = c1 - k1;
select * from t1;
--error 1062
insert into t1(c1, c2) select 1, k2 from t2 on duplicate key update c1 = c1 - k1;
drop table t1;
drop table t2;

CREATE TABLE `t1` (
  `aid` char(2) NOT NULL,
  `avalue` decimal(12,0) NOT NULL,
  PRIMARY KEY (`aid`)
) partition by key(aid) partitions 2;
CREATE TABLE `t2` (
  `id` bigint(20) NOT NULL AUTO_INCREMENT,
  `aid` char(2) NOT NULL,
  `bvalue` decimal(12,0) DEFAULT NULL
) partition by key(aid) partitions 2;
 
insert into t2 (aid,bvalue) values('1',1000),('1',-100),('1',-100),('1',-100),('1',-100),('1',-100);
insert into t1(aid,avalue) select t2.aid, t2.bvalue from t2 on duplicate key update avalue=avalue+bvalue;
select * from t1;
select * from t2;
drop table t1, t2;

create table t1(a int primary key, b int) partition by hash(a) partitions 2;
create table t2(a int primary key, b int) partition by hash(a) partitions 2;
insert into t1 values(1, 1), (2, 2);
--error 1748
insert into t2 partition(p0) select * from t1 partition(p1) on duplicate key update a=0;
insert into t2 partition(p0) select * from t1 partition(p0) on duplicate key update a=1;
select * from t2;
--error 1748
insert into t2 partition(p0) select * from t1 partition(p0) on duplicate key update a=1;
replace into t2 partition(p0) select * from t1 partition(p0);
select * from t2;
--error 1748
replace into t2 partition(p0) select * from t1 partition(p1);
delete from t2;
insert into t2 partition(p0) select * from t1 partition(p0);
select * from t2;
--error 1748
insert into t2 partition(p1) select * from t1 partition(p0);
delete from t2;
insert into t2 select * from t1 partition(p0);
select * from t2;
--error 1748
insert into t2 partition(p0) select * from t1 where a=1;
select * from t2;
--error 1748
insert into t2 partition(p1) select * from t1 where a=2;
--error 1062
insert into t2 partition(p0) select * from t1 where a=2;
select * from t2;
drop table t1, t2;

create table t1 (c1 varchar(10)) partition by key (c1) partitions 3;
create table t2 (c1 varchar(10)) partition by key (c1) partitions 3;
insert into t1 values ('001'), ('002'), ('003'), ('004');
insert into t2 partition (p0) select * from t1 partition (p0);
insert into t2 partition (p1) select * from t1 partition (p1);
insert into t2 partition (p2) select * from t1 partition (p2);
select * from t2 order by c1;
delete from t2;
insert into t2 partition (p0) select * from t1 where c1 = '001';
insert into t2 partition (p1) select * from t1 where c1 = '004';
insert into t2 partition (p2) select * from t1 where c1 in ('002', '003');
select * from t2 order by c1;
drop table t1, t2;

##insert null value to not null column in px insert
create table t1(a int primary key, b int not null, c int) partition by hash(a) partitions 2;
create table t2(a int primary key, b int, c int) partition by hash(a) partitions 2;
insert into t2 values(1, null, 1), (2, null, 2), (3, null, 3);
select * from t2;
explain basic insert /*+parallel(2)*/ into t1 select * from t2;
##expected not null error
--error 1048
insert /*+parallel(2)*/ into t1 select * from t2;
update t2 set b=2;
insert /*+parallel(2)*/ into t1 select * from t2;
select * from t1;
drop table t1, t2;
