--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: link.zt
#owner group: sql1

--disable_abort_on_error
--disable_warnings
drop table if exists t1;
--enable_warnings

--let $const=50

--let $create_sql=create table t1(pk int primary key
--let $field=$const
while($field)
{
   --let $create_sql=$create_sql , f$field varchar(7865)
   dec $field;
}
--let $create_sql=$create_sql )
--error 1118 
eval $create_sql;



--let $const=50
--let $create_sql_ok=create table t1(pk int primary key
--let $field=$const
while($field)
{
   --let $create_sql_ok=$create_sql_ok , f$field varchar(7864)
   dec $field;
}
--let $create_sql_ok=$create_sql_ok )
eval $create_sql_ok;



#1050 perline
#1050*7
--let $insert_sql=replace into t1 values(1
--let $value=1
--let $kb=7
--let $
while($kb)
{
    --let $value=$value$byte
    dec $kb;
}

--let $field=$const
while($field)
{
    --let $insert_sql=$insert_sql , '$value'
    dec $field;
}
--let $insert_sql=$insert_sql )
--disable_query_log
eval $insert_sql;



--let $insert_sql=replace into t1 values(2
--let $value=1
--let $kb=8
--let $
while($kb)
{
    --let $value=$value$byte
    dec $kb;
}

--let $field=$const
while($field)
{
    --let $insert_sql=$insert_sql , '$value'
    dec $field;
}
--let $insert_sql=$insert_sql )
--disable_query_log
--error 1406
eval $insert_sql;

drop table t1;
