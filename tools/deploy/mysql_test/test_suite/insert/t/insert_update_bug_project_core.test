# owner: xiaoyi.xy
# owner group: SQL3
# description: 本case是为了验证core的修复；insert on duplicate 在minimal模式下，core掉的问题；
# tags: dml
#
#
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);

connection default;

--disable_warnings
drop table if exists test;
--enable_warnings

set binlog_row_image='minimal';
create table test(c1 int primary key ,c2 int, c3 int);
insert into test values(1,2,3) on duplicate key update c2=c2 +1;
insert into test values(1,2,3) on duplicate key update c2=c2 +1;

connection obsys;
alter system flush plan cache;
connection default;

insert into test values(1,2,3) on duplicate key update c2=c2 +1;
insert into test values(1,2,3) on duplicate key update c2=c2 +1;
set ob_enable_plan_cache = false;

insert into test values(1,2,3) on duplicate key update c2=c2 +1;
insert into test values(1,2,3) on duplicate key update c2=c2 +1;
set binlog_row_image='full';
drop table test;

