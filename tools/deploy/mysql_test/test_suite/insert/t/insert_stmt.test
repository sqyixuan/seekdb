--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: xiaoyi.xy
# owner group: SQL3
# description: 本case是为了测试insert 语法正确性
# tags:dml

--disable_warnings
drop table if exists test;
--enable_warnings

create table test(c1 int primary key, c2 char(100) default 'fffyyy', c3 int);
insert into test values(1, substr(c1,1,3), c3);
insert into test values(100, substr(c1,1,3), c3);
insert into test values(101, substr(c3,1,3), c3);
insert into test (c2,c1,c3) values(substr(c1,1,3), 102, 3);
insert into test (c2,c1,c3) values(substr(c3,1,3), 103, 3);
insert into test (c1,c2,c3) values(104, substr(c3,1,3), c3);
insert into test (c1 ,c2) values(105, substr(c3,1,3));
select * from test;
insert into test set c1 = 2, c2 = 'hhee', c3 = 24;
select * from test;
--error 1048
insert into test set c1 = c3+1, c2=concat(c1, 'yy');
select * from test;
insert into test values(1, substr(c1,1,3), c3) on duplicate key update c3=c3+1;
select * from test;
insert into test set c1 = 2, c2 = 'hhee', c3 = 24 on duplicate key update c3=c3+1;
select * from test;
--error 1048
insert into test set c1 = c3+1, c2=concat(c1, 'yy') on duplicate key update c3=c3+1;
select * from test;


replace into test values(1, substr(c1,1,3), 3);
select * from test;
replace into test values(2, concat(c1, 'he'), 4);
select * from test;
replace into test set c1 = c1+1, c2='concat';
select * from test;
--error 1048
replace into test set c1 = c3+1, c2=concat(c1, 'yy');
select * from test;
delete from test;
replace into test values(100, substr(c1,1,3), c3);
replace into test values(101, substr(c3,1,3), c3);
replace into test (c2,c1,c3) values(substr(c1,1,3), 102, 3);
replace into test (c2,c1,c3) values(substr(c3,1,3), 103, 3);
replace into test (c1,c2,c3) values(104, substr(c3,1,3), c3);
replace into test (c1 ,c2) values(105, substr(c3,1,3));
select * from test;

