--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: sean.yyj
# owner group: SQL3

--disable_warnings
drop table if exists t1;
--enable_warnings
--result_format 4

create table t1 (c1 int, c2 int);
insert into t1 values(1, 1 > (select min(c1) from t1));
insert into t1 values(1, c1 > (select min(c1) from t1));
insert into t1 values(1, c1 > exists(select min(c1) from t1));
insert into t1 values(1, c1 <> c1 + exists(select min(c1) from t1));
insert into t1 values(1, c1 = !exists(select min(c1) from t1));
insert into t1 values(1, 1 in (select min(c1) from t1));
--error 1235
insert into t1 values(1, c1 in (select min(c1) from t1));

insert into t1 values(1, 1) on duplicate key update c1 = 1 > (select min(c1) from t1);
insert into t1 values(1, 1) on duplicate key update c1 = c1 > (select min(c1) from t1);
insert into t1 values(1, 1) on duplicate key update c1 = c1 > exists(select min(c1) from t1);
insert into t1 values(1, 1) on duplicate key update c1 = c1 < 1 + exists(select min(c1) from t1);
insert into t1 values(1, 1) on duplicate key update c1 = 1 in (select min(c1) from t1);
--error 1235
insert into t1 values(1, 1) on duplicate key update c1 = c1 in (select min(c1) from t1);

drop table t1;

--disable_warnings
drop table if exists v0;
--enable_warnings
CREATE TABLE v0 ( v2 INTEGER , v1 INTEGER , STATUS INTEGER ) ;
INSERT INTO v0 SELECT * FROM v0 WHERE v2 = v0 . v1 AND v2 = v0 . v2 AND v1 <= v0 . v1 ;
--error 1235
INSERT INTO v0 VALUES ( 81 , 68 , 16 + ( v1 NOT IN ( SELECT ( NULL + 99 ) FROM v0 WHERE v1 > -1 ) ) ) ;

drop table v0;
CREATE TABLE v0 ( v2 INTEGER DEFAULT 10 , v1 INTEGER ) ;
--error 1235
INSERT INTO v0 VALUES ( 17 , 56 ) ON DUPLICATE KEY UPDATE v1 = v1 > ( ( v2 , 'x' ) IN ( SELECT * FROM v0 WHERE CASE -1 WHEN FALSE THEN FALSE WHEN 73 THEN 'x' ELSE -1 END ^ v1 ) AND NOT ( FALSE OR TRUE ) ) ;

