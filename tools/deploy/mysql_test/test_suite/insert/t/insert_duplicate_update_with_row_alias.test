select * from t_gen;
--error 3105
INSERT INTO t_gen (a,b) VALUES (4,5)
            ON DUPLICATE KEY UPDATE c = values(a)+values(b)+1;
--error 3105
INSERT INTO t_gen (a,b) VALUES (4,5) AS NEW
            ON DUPLICATE KEY UPDATE c = NEW.a+NEW.b+1;
--error 3105
INSERT INTO t_gen (a,b) VALUES (4,5) AS NEW(m,n)
            ON DUPLICATE KEY UPDATE c = m+n+1;
--error 3105
INSERT INTO t_gen set a=4,b=5 AS NEW(m,n)
            ON DUPLICATE KEY UPDATE c = m+n+1;
--echo ---expect b=10,c=14
INSERT INTO t_gen (a,b) VALUES (4,5)
            ON DUPLICATE KEY UPDATE b = values(a)+values(b)+1;
select * from t_gen;
--echo ---expect b=8,c=12
INSERT INTO t_gen (a,b) VALUES (4,5) AS NEW
            ON DUPLICATE KEY UPDATE b = NEW.a+NEW.b-1;
