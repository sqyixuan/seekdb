DROP TABLE table30_hash_pk_parts_4_int_unsigned; 
CREATE TABLE table30_hash_pk_parts_4_int_unsigned (
col_integer_unsigned_key integer unsigned,
col_tinyint_unsigned_key tinyint unsigned,
col_char_20_key char(20),
col_varchar_10 varchar(10),
col_date date,
col_decimal_30_5_unsigned decimal(30,5) unsigned,
col_mediumint_unsigned_key mediumint unsigned,
col_datetime_key datetime,
col_smallint_unsigned smallint unsigned,
col_decimal_20_0_unsigned decimal(20,0) unsigned,
col_integer_unsigned integer unsigned,
col_decimal_20_0_unsigned_key decimal(20,0) unsigned,
col_tinyint_unsigned tinyint unsigned,
col_char_30 char(30),
col_timestamp_key timestamp NULL DEFAULT NULL,
col_int_unsigned int unsigned,
col_varchar_10_key varchar(10),
col_char_30_key char(30),
col_decimal_30_5_unsigned_key decimal(30,5) unsigned,
col_mediumint_unsigned mediumint unsigned,
col_timestamp timestamp NULL DEFAULT NULL,
col_int_unsigned_key int unsigned,
col_bigint_unsigned_key bigint unsigned,
col_char_20 char(20),
pk int unsigned,
col_datetime datetime,
col_date_key date,
col_bigint_unsigned bigint unsigned,
col_smallint_unsigned_key smallint unsigned,
/*Indices*/
key idx9(pk, col_integer_unsigned_key ),
key idx1(pk, col_tinyint_unsigned_key ),
key idx17(pk, col_char_20_key ),
key idx5(pk, col_mediumint_unsigned_key ),
key idx25(pk, col_datetime_key ),
key idx13(pk, col_decimal_20_0_unsigned_key ),
key idx27(pk, col_timestamp_key ),
key idx21(pk, col_varchar_10_key ),
key idx19(pk, col_char_30_key ),
key idx15(pk, col_decimal_30_5_unsigned_key ),
key idx7(pk, col_int_unsigned_key ),
key idx11(pk, col_bigint_unsigned_key ),
primary key (pk) ,
key idx23(pk, col_date_key ),
key idx3(pk, col_smallint_unsigned_key ))    PARTITION BY hash(pk) partitions 4 ; 
