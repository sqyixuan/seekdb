--echo ================================test 特殊语法测试================================
--echo #As关键词必须出现
--error 1064
INSERT INTO t1 (a,b,c) VALUES (4,5,6) new
            ON DUPLICATE KEY UPDATE c = new.a+new.b;

--echo #As多个别名
--error 1064
INSERT INTO t1 (a,b,c) VALUES (4,5,6) AS new new1
            ON DUPLICATE KEY UPDATE c = new.a+new1.b;

--echo #Row语法不允许有别名
--error 1064
INSERT INTO t1 (a,b,c) VALUES row(4,5,6),(7,8,9) as new
            ON DUPLICATE KEY UPDATE c = a+new.c;

--echo #生成列
--error 0,942,1051
drop table t_gen;
create table t_gen(a int primary key,b int,c int as (a+b));
