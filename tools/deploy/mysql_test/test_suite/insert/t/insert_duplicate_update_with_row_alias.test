drop table t1;
create table t1(a int primary key,b int,c int,d int,e int);
insert into t1(a) values(0);
insert into t1(a,c,d) values(1,15,5);
SELECT * FROM t1;
explain extended_noaddr insert into t1(b,c,d) SELECT 1,2,3 ON DUPLICATE KEY UPDATE e = VALUES(a);
insert into t1(b,c,d) SELECT 1,2,3 ON DUPLICATE KEY UPDATE e = VALUES(a);
SELECT * FROM t1; 

SET sql_mode = '';
drop table t2;
create table t2(a int primary key,b set('中文字符','123456','ABCabc','!@#$%^&*','2020-10-10') DEFAULT '',
                c set('中文字符','123456','ABCabc','!@#$%^&*','2020-10-10') DEFAULT '!@#$%^&*');
