--echo bug54413048
--error 0,942,1051
DROP TABLE test_table;
CREATE TABLE test_table (
    id INT PRIMARY KEY,
    col1 INT DEFAULT 0,
    col2 VARCHAR(45) DEFAULT 'Default Text',
    col3 FLOAT DEFAULT 0.0,
    col4 DATE DEFAULT '2022-01-01',
    col5 VARCHAR(100) DEFAULT 'Default Text'
);

INSERT INTO test_table VALUES 
(1, DEFAULT, DEFAULT, DEFAULT, DEFAULT, DEFAULT) AS n(id, col1, col2, col3, col4, col5)
ON DUPLICATE KEY UPDATE 
    col1 = n.col1 + test_table.col1,
    col2 = CONCAT(n.col2, ' appended'),
    col3 = n.col3 * test_table.col3,
    col4 = n.col4,
    col5 = CONCAT(test_table.col5, ' ', n.col5);
select * from test_table;

