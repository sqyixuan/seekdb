INSERT INTO student001  VALUES('Dengchao','7000',22,1500,100);
INSERT INTO student001  VALUES('Huge','8000',20,2800,100);
INSERT INTO student001  VALUES('Pengyuyan','9000',24,4500,100);
INSERT INTO student001  VALUES('Baoluo','6000',25,8500,100);
