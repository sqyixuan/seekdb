delimiter //;
drop procedure if exists studentwbmcl;//
create procedure studentwbmcl()
begin
declare tablename001 varchar(100);
declare dropname002 varchar(100);
set  @dropname002= 'DROP  TABLE if exists  student;';
set  @tablename001= 'create table student as select * from  student001  where  1=1;';
prepare step001 from @dropname002;
execute step001;
prepare step002 from @tablename001;
execute step002;
end;
//

call studentwbmcl();//
SELECT  *  FROM  student;//

-- echo  pow-6-1-1  

drop procedure if exists pl_test;//
create  procedure pl_test()  
begin
declare  i  BIGINT;              
declare  a BIGINT;
declare  b BIGINT;
declare  c BIGINT;
SELECT   pow(e.age,1)  into  a FROM student e WHERE  e.NAME='Kebi';
SELECT   POW(e.SALARY/1000,1)   into  b FROM   student  e WHERE  e.NAME='Kebi';
SELECT   POW(e.mon/10000,1)  into  c FROM   student  e WHERE  e.NAME='Kebi';
set i=0;
loop_label:loop
INSERT INTO student  VALUES('Kebi',a,20,3000,100);
INSERT INTO student  VALUES('James','2000',21,b,100);
INSERT INTO student  VALUES('Denglun','3000',22,c,100);
set i=i+1;
if  i>=100 then
         leave loop_label;
end if;
end loop;
end;
// 
select  count(*)  from student;//
call  pl_test();//
select  count(*)  from student;//
SELECT   DISTINCT(POW(e.age,1))  FROM student e WHERE  e.NAME='Kebi';//


-- echo POWER-6-1-2  只有一个 in 参数的存储过程  :  ---begin 里面使用的变量必须在begin上面定义过。
call studentwbmcl();//
drop procedure if exists pl_test;//
create  procedure pl_test (in numb int)
begin
declare  i BIGINT;
declare  a BIGINT;
declare  b BIGINT;
declare  c BIGINT;
SELECT   POWER(e.age,1)  INTO a FROM student e WHERE  e.NAME='Kebi';
SELECT   POWER(e.SALARY/1000,1)    INTO b FROM   student  e WHERE  e.NAME='Kebi';
SELECT   POWER(e.mon/900,1)    INTO c FROM   student  e WHERE  e.NAME='Kebi';
set i:=1;
REPEAT
INSERT INTO student  VALUES('Kebi',a,20,3000,100);
INSERT INTO student  VALUES('James','2000',21,b,100);
INSERT INTO student  VALUES('Denglun','3000',22,c,100);
set i := i + 1;
until  i >= 100 END REPEAT;
end;
//
call   pl_test(100);//
SELECT   DISTINCT(POWER(e.age,1))  FROM student e WHERE  e.NAME='Kebi';//


--echo POWER-6-1-3   包含 out 
CALL studentwbmcl();//
drop procedure if exists pl_test;//
CREATE   PROCEDURE pl_test( OUT p1  int,OUT p2  int, OUT p3  int)
BEGIN
declare  i BIGINT;
SELECT   POWER(e.age,1)  INTO p1 FROM student e WHERE  e.NAME='Kebi';
SELECT   POWER(e.SALARY/1000,1)    INTO p2 FROM   student  e WHERE  e.NAME='Kebi';
SELECT   POWER(e.mon/50,1)    INTO p3 FROM   student  e WHERE  e.NAME='Kebi';
set i:=1;
WHILE i <= 5 DO
INSERT INTO student  VALUES('Kebi',p1*i,20,3000,100);
INSERT INTO student  VALUES('James','2000',p2+i,5000,100);
INSERT INTO student  VALUES('Denglun','3000',22,p3+i,100);
set i := i + 1;
END WHILE;
END;
//

call pl_test(@p1,@p2,@p3);//

SELECT count(*) FROM   student;//
SELECT   DISTINCT(POWER(e.age,1))  FROM student e WHERE  e.NAME='Kebi';//


--echo POWER-6-1-4 包含 inout 参数的存储过程,in需要穿参数   out的传变量，in  out 的作in使用就按照in处理 作out使用就按照out处理   
###in out作out使用
CALL studentwbmcl();//
drop procedure if exists pl_test;//
CREATE  PROCEDURE pl_test(OUT p1   int ,in  p2   int, inout p3 int)
BEGIN	
declare  i BIGINT;
SELECT   POWER(e.age,1)  INTO p1 FROM student e WHERE  e.NAME='Kebi';
SELECT   POWER(e.mon/100,1)    INTO p3 FROM   student  e WHERE  e.NAME='Kebi';
set i:=1;
WHILE i <= 10 DO
INSERT INTO student  VALUES('Kebi',p1*i,20,3000,100);
INSERT INTO student  VALUES('James','2000',p2,5000,100);
INSERT INTO student  VALUES('Denglun','3000',22,p3+i,100);
set i := i + 1;
END WHILE;
END;
//
call pl_test(@p1,100,@p3);//

SELECT count(*) FROM   student;//
SELECT   DISTINCT(POWER(e.age,1))  FROM student e WHERE  e.NAME='Kebi';//

--echo  POWER-6-1-5    存储过程用循环      
CALL studentwbmcl();//
drop procedure if exists pl_test;//
CREATE PROCEDURE pl_test(in p1 int)
BEGIN	
declare  i BIGINT;
set i:=1;
while i <= 100 do
INSERT INTO student  VALUES('Kebi',p1*i,20,3000,100);
INSERT INTO student  VALUES('James','2000',p1,5000,100);
INSERT INTO student  VALUES('Denglun','3000',22,p1+i,100);
set i := i + 1;
END WHILE;
END;
//
CALL  pl_test(POWER(10,1));//
SELECT count(*) FROM   student;//
SELECT   DISTINCT(POWER(e.age/10,1))  FROM student e WHERE  e.NAME='Kebi';//
SELECT   DISTINCT(POWER(e.age/-1000,1))  FROM student e WHERE  e.NAME='Kebi';//

--echo  POWER-6-1-6   存储过程和函数的结果作为参数传递
CALL studentwbmcl();//
drop function  IF EXISTS fun_test;//
create  function fun_test()  returns BIGINT   
begin
DECLARE ag BIGINT DEFAULT 0;
select POWER(sum(salary)/10000,1) into ag from student;   
return ag;  
end//
select  fun_test()  from  dual//


drop procedure if exists pl_test;//
CREATE  PROCEDURE pl_test( in p1 int)
BEGIN	
declare  i BIGINT DEFAULT 0;
while i <= 10 do
INSERT INTO student  VALUES('Kebi',p1*i,20,3000,100);
INSERT INTO student  VALUES('James','2000',p1,5000,100);
INSERT INTO student  VALUES('Denglun','3000',22,p1+i,100);
set i := i + 1;
END WHILE;
end
//
CALL  pl_test(fun_test());//
SELECT count(*) FROM   student;//
SELECT   DISTINCT(POWER(e.age/1000,1))  FROM student e WHERE  e.NAME='Kebi';//


--echo     函数function                  
--echo   POWER-6-2-1  无参数的自定义函数
CALL studentwbmcl();//
drop function  IF EXISTS fun_test;//
create  function fun_test() returns int
begin
declare  i BIGINT DEFAULT 0;
select POWER(salary/1000,1) into i from student e WHERE  e.NAME='Kebi'; 
return i;
end;
//
select  fun_test()  from  dual;//


--echo   POWER-6-2-2   自定义函数  有参数
drop function  IF EXISTS fun_test;//
create  function fun_test(empname1  varchar(20),empname2  varchar(20)) returns BIGINT
begin   
	declare  a BIGINT DEFAULT 0;
    declare  b  BIGINT DEFAULT 0;
select POWER(salary/1000,1) into a from student e WHERE  e.NAME=empname1; 
select POWER(salary/POWER(10,1),1) into b from student e WHERE  e.NAME=empname2; 
return(a*b);   
end;
//
select  fun_test('Kebi','Denglun')  from dual;//


--echo  POWER-6-2-3 自定义函数使用循环   
drop function  IF EXISTS fun_test;//
create   function fun_test(empname  varchar(20))returns int
BEGIN
	declare  a BIGINT DEFAULT 0;
    declare  b  BIGINT DEFAULT 0;
    declare  i  BIGINT DEFAULT 0;
   
SELECT  POWER(salary/1000,1) into a  from student  where  name =empname;
SELECT   POWER(age/10.00,1) into b   from student where  name =empname;

while i <= 100 do
INSERT INTO student  VALUES('Kebi',200,a,3000,100);
INSERT INTO student  VALUES('James','2000',b,5000,100);
INSERT INTO student  VALUES('Denglun','3000',22,a,b);
set i := i + 1;
END WHILE;
return(a*b);   
end;
//
select  fun_test('Kebi')  from dual;//


--echo  POWER-6-3     游标   在begin 后 添加一行 代码：            
drop table  IF EXISTS  store;//
CREATE TABLE IF NOT EXISTS store(
id    int(11) NOT NULL AUTO_INCREMENT,
name  varchar(20) NOT NULL,
count int(11) NOT NULL DEFAULT '1',PRIMARY KEY (id)
)DEFAULT CHARSET=gbk AUTO_INCREMENT=9;//
 
INSERT INTO store(id, name, count) VALUES(1, 'android', 15),(2, 'iphone', 14),(3, 'iphone', 20),(4, 'android', 5),(5, 'android', 13),(6, 'iphone', 13),(7, 'iphonee', 15),(8, 'iphone9', 19);//
select   *  from  store;//

drop procedure if exists fun_test//
CREATE PROCEDURE fun_test()
begin	
	# 创建接收游标数据的变量
	declare c int;         #获取单条纪录的数量
	declare n varchar(20); #获取名称
	# 创建总数变量
	declare total BIGINT default 0;
	# 创建结束标志变量
	declare done int default false;
	# 创建游标 获取name和count的集合
	declare cur cursor for select name,POWER(count,1) from store where name = 'iphone';
	# 指定游标循环结束时的返回值
	declare continue HANDLER for not found set done = true;

	# set赋值全局变量时 写在declare的下面。
	set @total002 := 100;
	# 设置初始值：set后的变量要么是前面已经定义过的局部变量，要么set后的变量前面加@定义成系统变量
	set total = 0;#这里是否设置初始值都可以，上面定义变量时已经设置了默认值
	# 打开游标
	open cur;
	# 开始循环游标里的数据
	read_loop:loop
	# 根据游标当前指向的一条数据 插入到上面申明的局部变量中
	fetch cur into n,c;#右边循环结束时会给done赋值
	# 判断游标的循环是否结束
	if done then
		leave read_loop;	# 跳出游标循环
	end if;
	# 获取一条数据时，将count值进行累加操作，这里可以做任意你想做的操作，
	set @totaldone := total + POWER(c/100000000,1);# 每次循环都设置一个新变量@totaldone，
	set total := total + c;     #total为历次循环的综合
	# 有loop 就一定要有end loop
	end loop;
	# 关闭游标
	close cur; 
	# 输出结果
	select total;
END//
call fun_test();//
select @totaldone;//
