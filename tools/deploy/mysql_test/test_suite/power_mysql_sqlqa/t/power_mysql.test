delimiter //;
drop procedure if exists mayitest;//
create procedure mayitest()
begin
declare tablename001 varchar(100);
declare dropname002 varchar(100);
declare tablename003 varchar(100);
declare dropname004 varchar(100);
set  @dropname002= 'DROP  TABLE if exists  EMP001;';
set  @tablename001= 'create table EMP001 as select * from EMP where 1=1;';
set  @dropname004= 'DROP  TABLE if exists  invbasdoc001;';
set  @tablename003= 'create table invbasdoc001 as select * from invbasdoc where 1=1;';
prepare step001 from @dropname002;
execute step001;
prepare step002 from @tablename001;
execute step002;
prepare step003 from @dropname004;
execute step003;
prepare step004 from @tablename003;
execute step004;
end
//
DELIMITER  ;//
call mayitest();

-- echo     pow-2-1-1  select
SELECT  pow(e.monkey00/pow(10,1),10)   FROM   invbasdoc001 e;
SELECT  pow(e.DEPTNO,2)   FROM   emp001  e;

SELECT  pow(e.sal/10000,2)+pow(e.comm/999,2)   FROM   emp001  e;
SELECT pow(e.sal/10000,2)+null FROM emp001 e;

-- echo     pow-2-1-2  select                    
SELECT  pow(pow(e.DEPTNO/99,2),pow(pow(pow(e.DEPTNO/99,2),2),2))  FROM   emp001  e;


-- echo     pow-2-1-3   select                  
SELECT  pow(pow(e.DEPTNO/99,2),1)   hello   FROM   emp001  e;


-- echo     pow-2-1-4   where 
SELECT  pow(e.DEPTNO,2)   FROM   emp001  e  WHERE  e.SAL<1000;

-- echo     pow-2-1-5   order by 
SELECT  pow(e.DEPTNO,2)   FROM   emp001  e ORDER BY e.sal;
SELECT  pow(e.DEPTNO,2)   FROM   emp001  e GROUP BY DEPTNO   ORDER BY e.DEPTNO;

-- echo     pow-2-1-6   having
SELECT  pow(e.DEPTNO,2)   FROM   emp001  e GROUP BY DEPTNO HAVING e.DEPTNO>20   ORDER BY e.DEPTNO ;

-- echo     pow-2-1-7   insert into     
INSERT INTO EMP001 VALUES(pow(3,2),'MILLER','CLERK',pow(3,3),'1982-03-24 13:24:01',pow(3,5),NULL,pow(3,6));
SELECT  *    FROM   emp001  e   WHERE e.EMPNO=pow(3,2);

-- echo     pow-2-1-8   update               
UPDATE   EMP001  SET   sal = pow(3,6);  
SELECT  sal   FROM   emp001  e;

-- echo     pow-2-1-9                           
SELECT max(pow((e.mgr/88),2))    FROM   emp001  e;
SELECT min(pow((e.mgr/88),2))  FROM   emp001  e;
SELECT avg(pow(e.mgr/88,2)) FROM emp001 e;

-- echo   pow-2-2-1   select
-- error 0,1426               
SELECT pow(r.DEPTNO/100005,1),pow(r.COMM/5000,1)   FROM   emp001  r   WHERE   sal > (SELECT  pow(sal/1000,2)    FROM   emp001   e   WHERE    e.EMPNO=7369) ;
CALL mayitest();

-- echo   pow-2-2-2   exists,any,all
select    *   from   emp001 e  WHERE   exists(select  pow(sal/100,2)   from emp001 r where  pow(r.sal/100,2)>pow(e.COMM/100,2)) ;

SELECT *  FROM emp001 e  WHERE  pow(e.DEPTNO,1)  > any(select pow(r.COMM/5,1) from emp001 r where r.DEPTNO>10);

SELECT *  FROM emp001 e  WHERE  pow(e.DEPTNO,1)  > some(select pow(r.COMM/5,1) from emp001 r where r.DEPTNO>10);


