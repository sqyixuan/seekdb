#tags: mysql xa
#no: mysql01
#description: test basic cases for mysql xa

--result_format 4

connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,TEST,$OBMYSQL_PORT);
connection conn1;

--error 0,1051
drop table mysqlxa_tt01;
create table mysqlxa_tt01 (c1 int, c2 int);

## currently, if execute xa stmt, not support is returned
--error 1235
xa start 'mysql-0101';

--error 1235
xa start 'mysql-0101', 'branchid-001', 123;

--error 1235
xa start X'6D7973716C2D30373034', X'6272616E636869642D303031', X'7B';

--error 1235
xa start 0x6D7973716C2D30373035, 0x6272616E636869642D303031, 0x7B;

--error 1235
xa end 'mysql-0101';

--error 1235
xa end 'mysql-0101', 'branchid-001', 123;

--error 1235
xa end X'6D7973716C2D30373034', X'6272616E636869642D303031', X'7B';

--error 1235
xa end 0x6D7973716C2D30373035, 0x6272616E636869642D303031, 0x7B;

--error 1235
xa prepare 'mysql-0101';

--error 1235
xa prepare 'mysql-0101', 'branchid-001', 123;

--error 1235
xa prepare X'6D7973716C2D30373034', X'6272616E636869642D303031', X'7B';

--error 1235
xa prepare 0x6D7973716C2D30373035, 0x6272616E636869642D303031, 0x7B;

--error 1235
xa commit 'mysql-0101';

--error 1235
xa commit 'mysql-0101', 'branchid-001', 123;

--error 1235
xa commit X'6D7973716C2D30373034', X'6272616E636869642D303031', X'7B';

--error 1235
xa commit 0x6D7973716C2D30373035, 0x6272616E636869642D303031, 0x7B;

--error 1235
xa commit 'mysql-0101' one phase;

--error 1235
xa commit 'mysql-0101', 'branchid-001', 123 one phase;

--error 1235
xa commit X'6D7973716C2D30373034', X'6272616E636869642D303031', X'7B' one phase;

--error 1235
xa commit 0x6D7973716C2D30373035, 0x6272616E636869642D303031, 0x7B one phase;

--error 1235
xa rollback 'mysql-0101';

--error 1235
xa rollback 'mysql-0101', 'branchid-001', 123;

--error 1235
xa rollback X'6D7973716C2D30373034', X'6272616E636869642D303031', X'7B';

--error 1235
xa rollback 0x6D7973716C2D30373035, 0x6272616E636869642D303031, 0x7B;

## reset
drop table mysqlxa_tt01;
