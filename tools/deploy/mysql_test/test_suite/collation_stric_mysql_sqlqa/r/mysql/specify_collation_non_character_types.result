select 1 collate utf8mb4_general_ci;
1 collate utf8mb4_general_ci
1
SELECT 123 collate utf8mb4_general_ci AS int_value;
int_value
123
SELECT CAST(123.45 AS FLOAT) collate utf8mb4_general_ci AS float_value;
float_value
123.45
SELECT CAST(123.456789 AS DOUBLE) collate utf8mb4_general_ci AS double_value;
double_value
123.456789
SELECT CAST(123.45 AS DECIMAL(10, 2)) collate utf8mb4_general_ci AS decimal_value;
decimal_value
123.45
SELECT date'2024-01-01' collate utf8mb4_general_ci AS date_value;
date_value
2024-01-01
SELECT time'12:34:56' collate utf8mb4_general_ci AS time_value;
time_value
12:34:56
SELECT IF(TRUE, 1, 0) collate utf8mb4_general_ci AS boolean_value;
boolean_value
1
