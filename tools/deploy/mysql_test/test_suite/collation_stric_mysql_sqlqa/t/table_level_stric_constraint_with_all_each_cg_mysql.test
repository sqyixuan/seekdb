#owner:lihongqin.lhq
#owner group: 技术部-存储
#description: 表级修改--创建表时含有约束和索引，然后修改普通表的charset和collation
#author: wb-zc01081081

#设置SQL为严格模式
SET sql_mode='STRICT_TRANS_TABLES,STRICT_ALL_TABLES';
#查询sql模式
SELECT @@sql_mode;

--echo
--disable_warnings
DROP TABLE IF EXISTS Z0CASE;
DROP TABLE IF EXISTS Z1CASE;
--enable_warnings

--echo Indexes and Constraint

--echo char

CREATE TABLE Z0CASE(T1 CHAR(20) PRIMARY KEY) DEFAULT charset= utf8mb4 DEFAULT collate = utf8mb4_general_ci with column group (all columns, each column);
INSERT INTO Z0CASE VALUES(123);
INSERT INTO Z0CASE VALUES('%^&*[];//\\');
INSERT INTO Z0CASE VALUES('abc');
INSERT INTO Z0CASE VALUES('中文');
SELECT T1,HEX(T1) FROM Z0CASE ORDER BY T1*1;
SELECT table_name,column_type,COLLATION_NAME,CHARACTER_SET_NAME FROM information_schema.columns WHERE table_name='Z0CASE';
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
SHOW CREATE TABLE Z0CASE;

ALTER TABLE Z0CASE CONVERT TO CHARACTER SET 'binary' COLLATE 'binary';
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
SHOW CREATE TABLE Z0CASE;
SHOW INDEX FROM Z0CASE;
SELECT T1,HEX(T1) FROM Z0CASE ORDER BY T1*1;
SELECT INSTR(T1,'a') FROM Z0CASE ORDER BY T1*1;

--echo insert
--error 01062
INSERT INTO Z0CASE VALUES(123);
--error 01062
INSERT INTO Z0CASE VALUES(123);
--error 01048
INSERT INTO Z0CASE VALUES(null);
INSERT INTO Z0CASE VALUES(UPPER('abc'));
REPLACE INTO Z0CASE VALUES(123);
SELECT T1,HEX(T1) FROM Z0CASE ORDER BY T1*1;

--echo update
--error 01048
UPDATE Z0CASE SET T1=REPLACE(T1,'abc',NULL);
UPDATE Z0CASE SET T1=NULL WHERE T1='abc';
UPDATE Z0CASE SET T1='中文' WHERE T1='123';
UPDATE Z0CASE SET T1=UPPER('abc') WHERE T1='中文';
SELECT * FROM Z0CASE WHERE T1 IN('中文');

UPDATE Z0CASE SET T1=b'0101101' WHERE T1='abc';
SELECT T1,HEX(T1) FROM Z0CASE ORDER BY T1*1;

DROP TABLE Z0CASE;
CREATE TABLE Z0CASE(T1 CHAR(20) UNIQUE) DEFAULT charset='binary' DEFAULT collate='binary' with column group (all columns, each column);
INSERT INTO Z0CASE VALUES(123);
INSERT INTO Z0CASE VALUES('%^&*[];//\\');
INSERT INTO Z0CASE VALUES(NULL);
INSERT INTO Z0CASE VALUES('abc');
INSERT INTO Z0CASE VALUES('中文');
SELECT T1,HEX(T1) FROM Z0CASE ORDER BY T1*1;
SELECT table_name,column_type,COLLATION_NAME,CHARACTER_SET_NAME FROM information_schema.columns WHERE table_name='Z0CASE';
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
SHOW CREATE TABLE Z0CASE;

ALTER TABLE Z0CASE CONVERT TO CHARACTER SET 'gbk' COLLATE 'gbk_bin';
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
SHOW CREATE TABLE Z0CASE;
SHOW INDEX FROM Z0CASE;
SELECT T1,HEX(T1) FROM Z0CASE ORDER BY T1*1;

--error 01062
INSERT INTO Z0CASE VALUES(123);
SELECT * FROM Z0CASE WHERE T1 IN('123');
UPDATE Z0CASE SET T1='abc' WHERE T1='123';
SELECT * FROM Z0CASE WHERE T1 IN('abc');

DROP TABLE Z0CASE;
CREATE TABLE Z0CASE(T1 CHAR(20),T2 VARCHAR(20)) DEFAULT charset= 'binary' DEFAULT collate = 'binary' with column group (all columns, each column);
INSERT INTO Z0CASE VALUES(123,'122');
INSERT INTO Z0CASE VALUES('%^&*[];//\\','20:22:32');
INSERT INTO Z0CASE VALUES(NULL,NULL);
INSERT INTO Z0CASE VALUES('abc','ABC');
INSERT INTO Z0CASE VALUES('中文',b'1100101');
SELECT T1,HEX(T1) FROM Z0CASE ORDER BY T1*1;
SELECT table_name,column_type,COLLATION_NAME,CHARACTER_SET_NAME FROM information_schema.columns WHERE table_name='Z0CASE';
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
SHOW CREATE TABLE Z0CASE;
CREATE INDEX ind ON Z0CASE(T1,T2);
SHOW INDEX FROM Z0CASE;

ALTER TABLE Z0CASE CONVERT TO CHARACTER SET 'gbk' COLLATE 'gbk_bin';
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
SHOW CREATE TABLE Z0CASE;
SHOW INDEX FROM Z0CASE;
SELECT T1,HEX(T1) FROM Z0CASE ORDER BY T1*1;

INSERT INTO Z0CASE VALUES(123,'122');
INSERT INTO Z0CASE VALUES(123,'122');
SELECT T1,HEX(T1) FROM Z0CASE ORDER BY T1*1;
SELECT * FROM Z0CASE WHERE T1 ='123';
UPDATE Z0CASE SET T1='abc' WHERE T2='20:22:32';
UPDATE Z0CASE SET T1='abc' WHERE T2='ABC';
SELECT * FROM Z0CASE WHERE T1 ='abc';

DROP TABLE Z0CASE;
CREATE TABLE Z1CASE(T2 CHAR(20) PRIMARY KEY) DEFAULT charset= 'binary' DEFAULT collate = 'binary' with column group (all columns, each column);
CREATE TABLE Z0CASE(T1 CHAR(20),CONSTRAINT fk_t1_t2 FOREIGN KEY(T1) REFERENCES Z1CASE(T2)) DEFAULT charset= 'binary' DEFAULT collate = 'binary' with column group (all columns, each column);

ALTER TABLE Z0CASE CONVERT TO CHARACTER SET 'gbk' COLLATE 'gbk_bin';
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
SHOW CREATE TABLE Z0CASE;
SELECT TABLE_NAME,CONSTRAINT_TYPE,CONSTRAINT_NAME FROM INFORMATION_SCHEMA.TABLE_CONSTRAINTS WHERE table_name='Z0CASE';

DROP TABLE Z0CASE;
