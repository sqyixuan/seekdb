#owner:lihongqin.lhq
#owner group: 技术部-存储
#description: 表级修改--创建表时未指定字符集和字符序，然后修改普通表的charset和collation
#author: wb-zc01081081

#设置SQL为严格模式
SET sql_mode='STRICT_TRANS_TABLES,STRICT_ALL_TABLES';
#查询sql模式
SELECT @@sql_mode;

--echo
--disable_warnings
DROP TABLE IF EXISTS Z0CASE;
--enable_warnings

--echo general_list_update  utf8mb4/utf8mb4_general_ci --> utf16/utf16_unicode_ci

--echo char
CREATE TABLE Z0CASE(T1 CHAR(50)) DEFAULT charset= utf8mb4 DEFAULT collate = utf8mb4_general_ci;
INSERT INTO Z0CASE VALUES(123);
INSERT INTO Z0CASE VALUES('%^&*[];//\\');
INSERT INTO Z0CASE VALUES(NULL);
INSERT INTO Z0CASE VALUES('abc');
INSERT INTO Z0CASE VALUES('中文');
SELECT * FROM Z0CASE;
SELECT table_name,column_type,COLLATION_NAME,CHARACTER_SET_NAME FROM information_schema.columns WHERE table_name='Z0CASE';
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
SHOW CREATE TABLE Z0CASE;

ALTER TABLE Z0CASE CONVERT TO CHARACTER SET 'utf16' COLLATE 'utf16_unicode_ci';
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
SHOW CREATE TABLE Z0CASE;
SELECT * FROM Z0CASE;

--echo insert
INSERT INTO Z0CASE VALUES(111);
INSERT INTO Z0CASE VALUES('2001');
INSERT INTO Z0CASE VALUES('!*?< >aB12 中文');
INSERT INTO Z0CASE VALUES(b'0101101');
INSERT INTO Z0CASE VALUES('2021-10-01 12:23:35.54');
INSERT INTO Z0CASE VALUES('2011-11-01');
INSERT INTO Z0CASE VALUES('22:22:35');
INSERT INTO Z0CASE VALUES(12.345);
INSERT INTO Z0CASE VALUES(null);

SELECT table_name,column_type,COLLATION_NAME,CHARACTER_SET_NAME FROM information_schema.columns WHERE table_name='Z0CASE';
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
SHOW CREATE TABLE Z0CASE;
SELECT * FROM Z0CASE;

--echo update
UPDATE Z0CASE SET T1=NULL WHERE T1='111';
--error 01292
UPDATE Z0CASE SET T1='12:31:56' WHERE T1=2001;
UPDATE Z0CASE SET T1=1221.34 WHERE T1='2011-11-01';
UPDATE Z0CASE SET T1='Aa1$< >中文' WHERE T1='12.345';
UPDATE Z0CASE SET T1=b'0101101' WHERE T1='abc';

SELECT table_name,column_type,COLLATION_NAME,CHARACTER_SET_NAME FROM information_schema.columns WHERE table_name='Z0CASE';
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
SHOW CREATE TABLE Z0CASE;
SELECT * FROM Z0CASE;

--echo delete
--error 01292
DELETE FROM Z0CASE WHERE T1=1221.34;
DELETE FROM Z0CASE WHERE T1='2021-10-01 12:23:35.54';
DELETE FROM Z0CASE WHERE T1 IS NULL;
DELETE FROM Z0CASE WHERE T1=b'0101101';
SELECT * FROM Z0CASE;

