--echo trigger

DROP VIEW V1;
DROP TABLE Z0CASE;
CREATE TABLE Z1CASE(C1 INT,C2 CHAR(20)) DEFAULT charset= utf8mb4 DEFAULT collate = utf8mb4_general_ci;
CREATE TABLE Z0CASE(T1 INT,T2 VARCHAR(20)) DEFAULT charset= 'binary' DEFAULT collate = 'binary';
INSERT INTO Z0CASE VALUES(1,123);
INSERT INTO Z0CASE VALUES(2,'aa');
INSERT INTO Z1CASE VALUES(1,'%^&*[];//\\');
INSERT INTO Z1CASE VALUES(2,'abc');
INSERT INTO Z1CASE VALUES(3,'中文');
SELECT C1,C2 FROM Z1CASE ORDER BY C1;
SELECT T1,T2 FROM Z0CASE ORDER BY T1;
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
SHOW CREATE TABLE Z0CASE;
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
SHOW CREATE TABLE Z1CASE;

DELIMITER //;
CREATE TRIGGER tg_t1 AFTER INSERT ON Z1CASE FOR EACH ROW
BEGIN
    UPDATE Z0CASE SET T2=T2-1 WHERE T1=1;
END;
//
DELIMITER ;//

--replace_column 6 "2022-11-16 11:16:22"
SHOW TRIGGERS;
INSERT INTO Z1CASE VALUES(4,'111');
SELECT T1,T2,HEX(T2) FROM Z0CASE ORDER BY T1;

ALTER TABLE Z0CASE CONVERT TO CHARACTER SET 'utf8mb4' COLLATE 'utf8mb4_bin';
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
SHOW CREATE TABLE Z0CASE;

INSERT INTO Z1CASE VALUES(5,'C');
SELECT T1,T2,HEX(T2) FROM Z0CASE ORDER BY T1;
UPDATE Z1CASE SET C2='国家' WHERE C1='4';
SELECT C1,C2 FROM Z1CASE ORDER BY C1;
SELECT T1,T2,HEX(T2) FROM Z0CASE ORDER BY T1;
DROP TRIGGER tg_t1;

