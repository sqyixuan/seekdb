SHOW CREATE TABLE Z1CASE;

DELIMITER //;
CREATE TRIGGER tg_t1 AFTER DELETE ON Z1CASE FOR EACH ROW
BEGIN
    IF OLD.C1=3 THEN
    INSERT INTO Z0CASE VALUES(OLD.C1,'LAL 来 2%…=…￥');
    END IF;
END;
//
DELIMITER ;//

--replace_column 6 "2022-11-16 11:16:22"
SHOW TRIGGERS;
DELETE FROM Z1CASE WHERE C1=2;
SELECT C1,C2 FROM Z1CASE ORDER BY C1;
SELECT T1,T2,HEX(T2) FROM Z0CASE ORDER BY T1;
DELETE FROM Z1CASE WHERE C1=3;
SELECT C1,C2 FROM Z1CASE ORDER BY C1;
SELECT T1,T2,HEX(T2) FROM Z0CASE ORDER BY T1;

ALTER TABLE Z0CASE CONVERT TO CHARACTER SET 'gb18030' COLLATE 'gb18030_chinese_ci';
