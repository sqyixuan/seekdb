DELIMITER //;
CREATE TRIGGER tg_t1 AFTER UPDATE ON Z1CASE FOR EACH ROW
BEGIN
    IF NEW.C2 IS NULL THEN
    INSERT INTO Z0CASE VALUES(3,'LAL 来 2%…=…￥');
    END IF;
END;
//
DELIMITER ;//

