DELETE FROM Z1CASE WHERE C1=3;
SELECT C1,C2 FROM Z1CASE ORDER BY C1;
SELECT T1,T2,HEX(T2) FROM Z0CASE ORDER BY T1;
DROP TRIGGER tg_t1;

DROP TABLE Z1CASE;
DROP TABLE Z0CASE;
CREATE TABLE Z0CASE(T1 INT,T2 VARCHAR(20)) DEFAULT charset= utf8mb4 DEFAULT collate = utf8mb4_general_ci;
INSERT INTO Z0CASE VALUES(1,123);
INSERT INTO Z0CASE VALUES(2,'AA');
SELECT T1,T2 FROM Z0CASE ORDER BY T1;
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
SHOW CREATE TABLE Z0CASE;

DELIMITER //;
CREATE TRIGGER tg_t1 AFTER INSERT ON Z0CASE FOR EACH ROW
BEGIN
    UPDATE Z0CASE SET T2='美 over' WHERE T1=1;
END;
//
DELIMITER ;//

ALTER TABLE Z0CASE CONVERT TO CHARACTER SET 'utf16' COLLATE 'utf16_unicode_ci';

DROP TRIGGER tg_t1;

ALTER TABLE Z0CASE CONVERT TO CHARACTER SET 'utf16' COLLATE 'utf16_unicode_ci';
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
SHOW CREATE TABLE Z0CASE;

DELIMITER //;
CREATE TRIGGER tg_t1 BEFORE INSERT ON Z0CASE FOR EACH ROW
BEGIN
    IF NEW.T1 IS NULL THEN
    SET NEW.T1='0';
    END IF;
    IF NEW.T2 IS NULL THEN
    SET NEW.T2='123 美 over';
    END IF;
END;
//
DELIMITER ;//

INSERT INTO Z0CASE VALUES(NULL,NULL);
INSERT INTO Z0CASE VALUES(NULL,'hahaha');
SELECT T1,T2 FROM Z0CASE ORDER BY T1;

DROP TABLE Z0CASE;
