--echo VIEW
--echo Create a view, modify the base tables charset and collation, and finally perform DML operations on the view.
--echo Modifying charset and collation of views is not supported.

--echo char

DROP TABLE Z0CASE;
CREATE TABLE Z0CASE(T1 CHAR(20) PRIMARY KEY) DEFAULT charset= utf8mb4 DEFAULT collate = utf8mb4_general_ci;
INSERT INTO Z0CASE VALUES(123);
INSERT INTO Z0CASE VALUES('%^&*[];//\\');
INSERT INTO Z0CASE VALUES('abc');
INSERT INTO Z0CASE VALUES('中文');
SELECT T1,HEX(T1) FROM Z0CASE ORDER BY T1*1;
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
SHOW CREATE TABLE Z0CASE;

CREATE VIEW V1 AS SELECT * FROM Z0CASE;
SELECT * FROM V1 ORDER BY T1*1;

ALTER TABLE Z0CASE CONVERT TO CHARACTER SET 'binary' COLLATE 'binary';
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
SHOW CREATE TABLE Z0CASE;

--error 01062
INSERT INTO V1 VALUES('123');
--error 01048
INSERT INTO V1 VALUES(NULL);
INSERT INTO V1 VALUES('');
SELECT * FROM V1 ORDER BY T1*1;
SELECT * FROM Z0CASE ORDER BY T1*1;

UPDATE V1 SET T1=NULL WHERE T1='abc';
SELECT * FROM V1 ORDER BY T1*1;
SELECT * FROM Z0CASE ORDER BY T1*1;
--error 01048
UPDATE V1 SET T1=NULL;
--error 01062
UPDATE V1 SET T1='abc';

