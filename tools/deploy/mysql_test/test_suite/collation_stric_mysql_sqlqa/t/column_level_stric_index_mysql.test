--echo Creates a column with a regular index and a composite index without the specified charset and collation.

DROP TABLE Z0CASE;
CREATE TABLE Z0CASE(T1 CHAR(20) ,T2 VARCHAR(20),T3 CHAR(20));
INSERT INTO Z0CASE VALUES(123,123,123);
INSERT INTO Z0CASE VALUES('%^&*[];//\\','%^&*[];//\\','%^&*[];//\\');
INSERT INTO Z0CASE VALUES('abc','abc','abc');
INSERT INTO Z0CASE VALUES('中文','中文','中文');
SELECT * FROM Z0CASE ORDER BY T2*1;
CREATE INDEX ind ON Z0CASE(T1,T2);
ALTER TABLE Z0CASE ADD INDEX Z0_T3(T3);
SHOW INDEX FROM Z0CASE;
SELECT table_name,column_type,COLLATION_NAME,CHARACTER_SET_NAME FROM information_schema.columns WHERE table_name='Z0CASE';


