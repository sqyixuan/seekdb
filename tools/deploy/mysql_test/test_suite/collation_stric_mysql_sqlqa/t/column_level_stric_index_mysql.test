#owner group: 技术部-存储
#description: 列级修改--创建普通表，带有索引，然后修改表的charset和collation
#author: wb-zc01081081

#设置SQL为严格模式
SET sql_mode='STRICT_TRANS_TABLES,STRICT_ALL_TABLES';
#查询sql模式
SELECT @@sql_mode;

--echo
--disable_warnings
DROP TABLE IF EXISTS Z0CASE;
DROP TABLE IF EXISTS Z1CASE;
--enable_warnings

--echo The column has a primary key index and a unique index, and charset and collation are not specified

CREATE TABLE Z0CASE(T1 CHAR(20) PRIMARY KEY,T2 VARCHAR(20) UNIQUE);
INSERT INTO Z0CASE VALUES(123,123);
INSERT INTO Z0CASE VALUES('%^&*[];//\\','%^&*[];//\\');
INSERT INTO Z0CASE VALUES('abc','abc');
INSERT INTO Z0CASE VALUES('中文','中文');
SELECT * FROM Z0CASE ORDER BY T2*1;
--source mysql_test/include/show_create_table_old_version.inc
SHOW INDEX FROM Z0CASE;
SELECT table_name,column_type,COLLATION_NAME,CHARACTER_SET_NAME FROM information_schema.columns WHERE table_name='Z0CASE';


ALTER TABLE Z0CASE MODIFY T1 CHAR(20) CHARACTER SET 'utf16';
SHOW INDEX FROM Z0CASE;
--source mysql_test/include/show_create_table_old_version.inc
SHOW CREATE TABLE Z0CASE;
SELECT table_name,column_type,COLLATION_NAME,CHARACTER_SET_NAME FROM information_schema.columns WHERE table_name='Z0CASE';

SELECT * FROM Z0CASE ORDER BY T2*1;

--error 01062
INSERT INTO Z0CASE VALUES(123,0);
--error 01062
INSERT INTO Z0CASE VALUES('%^&*[];//\\','&*');
--error 01062
INSERT INTO Z0CASE VALUES('abc','c');
--error 01062
INSERT INTO Z0CASE VALUES('中文','文');

INSERT INTO Z0CASE VALUES(1223,1223);
INSERT INTO Z0CASE VALUES('%%^&*[];//\\','%%^&*[];//\\');
INSERT INTO Z0CASE VALUES('ac','ac');
INSERT INTO Z0CASE VALUES('中','中');
SELECT * FROM Z0CASE ORDER BY T2*1;

ALTER TABLE Z0CASE MODIFY T2 VARCHAR(20) CHARACTER SET 'gbk' COLLATE 'gbk_bin';
SHOW INDEX FROM Z0CASE;
--source mysql_test/include/show_create_table_old_version.inc
SHOW CREATE TABLE Z0CASE;
SELECT table_name,column_type,COLLATION_NAME,CHARACTER_SET_NAME FROM information_schema.columns WHERE table_name='Z0CASE';

SELECT * FROM Z0CASE ORDER BY T2*1;

--error 01062
