SELECT table_name,column_type,COLLATION_NAME,CHARACTER_SET_NAME FROM information_schema.columns WHERE table_name='Z0CASE';

SELECT T1,HEX(T1),T2,HEX(T2) FROM Z0CASE ORDER BY T2*1;

INSERT INTO Z0CASE(T1) VALUES('TEST');
SELECT T1,HEX(T1),T2,HEX(T2) FROM Z0CASE ORDER BY T2*1;

DROP TABLE Z0CASE;
CREATE TABLE Z0CASE(T1 CHAR(20) NOT NULL,T2 VARCHAR(20) DEFAULT 'NON')
DEFAULT charset= 'utf16' DEFAULT collate = 'utf16_unicode_ci' with column group (all columns, each column);
INSERT INTO Z0CASE VALUES(123,123);
INSERT INTO Z0CASE VALUES('%^&*[];//\\','%^&*[];//\\');
INSERT INTO Z0CASE VALUES('abc','abc');
INSERT INTO Z0CASE VALUES('中文','中文');
INSERT INTO Z0CASE VALUES('',NULL);
INSERT INTO Z0CASE(T1) VALUES('');
SELECT * FROM Z0CASE ORDER BY T2*1;
