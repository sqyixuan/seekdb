#设置SQL为严格模式
SET sql_mode='STRICT_TRANS_TABLES,STRICT_ALL_TABLES';
#查询sql模式
SELECT @@sql_mode;

--echo
--disable_warnings
DROP TABLE IF EXISTS Z0CASE;
DROP TABLE IF EXISTS Z1CASE;
DROP TABLE IF EXISTS Z2CASE;
--enable_warnings

--echo String type

CREATE TABLE Z0CASE (T1 CHAR(10) PRIMARY KEY,T2 VARCHAR(10)) with column group (all columns, each column);
INSERT INTO  Z0CASE VALUES(11,11);
INSERT INTO  Z0CASE VALUES('abc','abc');
INSERT INTO  Z0CASE VALUES('$%^&*()//','$%^&*()//');
INSERT INTO  Z0CASE VALUES('','');
SELECT * FROM Z0CASE ORDER BY T2*1;
SELECT table_name,column_type,COLLATION_NAME,CHARACTER_SET_NAME FROM information_schema.columns WHERE table_name='Z0CASE';

CREATE TABLE Z1CASE LIKE Z0CASE;
INSERT INTO Z1CASE SELECT * FROM Z0CASE;
--source mysql_test/include/show_create_table_old_version.inc
SHOW CREATE TABLE Z1CASE;
SELECT * FROM Z1CASE ORDER BY T2*1;

SELECT table_name,column_type,COLLATION_NAME,CHARACTER_SET_NAME FROM information_schema.columns WHERE table_name='Z1CASE';

