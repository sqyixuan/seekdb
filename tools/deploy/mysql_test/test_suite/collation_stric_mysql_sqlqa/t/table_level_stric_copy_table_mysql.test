DROP TABLE Z0CASE;
CREATE TABLE Z0CASE (T1 INT PRIMARY KEY,T2 INT) DEFAULT charset= 'utf8mb4' DEFAULT collate = 'utf8mb4_general_ci'
PARTITION BY RANGE(T1)
 ( PARTITION part_1 VALUES LESS THAN ( 50),
   PARTITION part_2 VALUES LESS THAN ( 100 ));
INSERT INTO  Z0CASE VALUES(11,1);
INSERT INTO  Z0CASE VALUES('22',2);
INSERT INTO  Z0CASE VALUES('33','3');
INSERT INTO  Z0CASE VALUES('44','4');
INSERT INTO  Z0CASE VALUES('55','5');
SELECT * FROM Z0CASE ORDER BY T2;

CREATE TABLE Z1CASE LIKE Z0CASE;
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
SHOW CREATE TABLE Z1CASE;
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
SHOW CREATE TABLE Z1CASE;
SELECT table_name,column_type,COLLATION_NAME,CHARACTER_SET_NAME FROM information_schema.columns WHERE table_name='Z1CASE' ORDER BY 1,2,3,4;
SELECT PARTITION_NAME,TABLE_ROWS,PARTITION_DESCRIPTION FROM INFORMATION_SCHEMA.PARTITIONS WHERE TABLE_SCHEMA=SCHEMA() AND TABLE_NAME = 'Z1CASE' ORDER BY 1;

ALTER TABLE Z0CASE CONVERT TO CHARACTER SET 'gb18030' COLLATE 'gb18030_chinese_ci';

INSERT INTO Z1CASE SELECT * FROM Z0CASE;
SELECT * FROM Z1CASE ORDER BY T2;
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
SHOW CREATE TABLE Z1CASE;

