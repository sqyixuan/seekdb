#description: 列级修改--创建普通表，带有分区，然后修改表的charset和collation
#author: wb-zc01081081

#设置SQL为严格模式
SET sql_mode='STRICT_TRANS_TABLES,STRICT_ALL_TABLES';
#查询sql模式
SELECT @@sql_mode;

--echo
--disable_warnings
DROP TABLE IF EXISTS Z0CASE;
DROP TABLE IF EXISTS Z1CASE;
--enable_warnings

--echo First create the partition table, and then modify the column level charset and collation.

--echo key partition

CREATE TABLE Z0CASE (T1 CHAR(10) PRIMARY KEY,T2 VARCHAR(10))
PARTITION BY KEY(T1) PARTITIONS 3  with column group (all columns, each column);
INSERT INTO  Z0CASE VALUES(11,11);
INSERT INTO  Z0CASE VALUES('abc','abc');
INSERT INTO  Z0CASE VALUES('$%^&*()//','$%^&*()//');
INSERT INTO  Z0CASE VALUES('','');
SELECT * FROM Z0CASE ORDER BY T2;
SELECT PARTITION_NAME,TABLE_ROWS,PARTITION_DESCRIPTION FROM INFORMATION_SCHEMA.PARTITIONS WHERE TABLE_SCHEMA=SCHEMA() AND TABLE_NAME = 'Z0CASE' ORDER BY 1;

ALTER TABLE Z0CASE MODIFY T1 CHAR(20) CHARACTER SET 'gbk' COLLATE 'gbk_bin';
SELECT PARTITION_NAME,TABLE_ROWS,PARTITION_DESCRIPTION FROM INFORMATION_SCHEMA.PARTITIONS WHERE TABLE_SCHEMA=SCHEMA() AND TABLE_NAME = 'Z0CASE' ORDER BY 1;
SELECT * FROM Z0CASE ORDER BY T2;

INSERT INTO  Z0CASE VALUES('AbC','ABc');
SELECT * FROM Z0CASE WHERE T1='AbC';
SELECT HEX(T1),HEX(T2) FROM Z0CASE ORDER BY T1;

--error 01048
UPDATE Z0CASE SET T1=NULL WHERE T2='11';
--error 01062
UPDATE Z0CASE SET T1='AbC' WHERE T2='11';
UPDATE Z0CASE SET T1='abC' WHERE T2='11';
SELECT * FROM Z0CASE ORDER BY T1;
SELECT HEX(T1),HEX(T2) FROM Z0CASE ORDER BY T1;

ALTER TABLE Z0CASE MODIFY T1 CHAR(20) CHARACTER SET 'utf8mb4' COLLATE 'utf8mb4_bin';

SELECT * FROM Z0CASE ORDER BY T1;

