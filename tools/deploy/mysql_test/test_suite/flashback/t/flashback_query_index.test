#owner: cxf262476
#owner group: transaction

--disable_warnings
--error 0, 942
DROP TABLE IF EXISTS t;
--error 0, 942
DROP TABLE IF EXISTS pt;
--enable_warnings

connect (my_obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);

connection default;
let $tenant_id = `select effective_tenant_id()`;
connection my_obsys;
let $point1 = query_get_value("select ts_value from oceanbase.__all_virtual_timestamp_service where tenant_id = $tenant_id and role = 'LEADER';", ts_value, 1);
connection default;
# 1. 分区表 + 分区全局索引
# 2. 分区表 + 非分区全局索引
# 3. 非分区表 + 分区全局索引
# 4. 非分区表 + 非分区全局索引
CREATE TABLE t (id int primary key, k int, i int);
CREATE INDEX t_idx ON t(i);
CREATE INDEX t_pidx ON t(i) PARTITION BY HASH(i) PARTITIONS 2;
INSERT INTO t VALUES(1,1,1);

CREATE TABLE pt (id int primary key, k int, i int) PARTITION BY HASH(id) PARTITIONS 2;
CREATE INDEX pt_idx ON pt(i);
CREATE INDEX pt_pidx ON pt(i) PARTITION BY HASH(i) PARTITIONS 2;
INSERT INTO pt VALUES(1,1,1);

connection my_obsys;
let $point2 = query_get_value("select ts_value from oceanbase.__all_virtual_timestamp_service where tenant_id = $tenant_id and role = 'LEADER';", ts_value, 1);

connection default;
UPDATE t SET k=2 WHERE id=1;
UPDATE pt SET k=2 WHERE id=1;

connection my_obsys;
let $point3 = query_get_value("select ts_value from oceanbase.__all_virtual_timestamp_service where tenant_id = $tenant_id and role = 'LEADER';", ts_value, 1);

connection default;
DELETE FROM t WHERE id = 1;
DELETE FROM pt WHERE id = 1;

connection my_obsys;
let $point4 = query_get_value("select ts_value from oceanbase.__all_virtual_timestamp_service where tenant_id = $tenant_id and role = 'LEADER';", ts_value, 1);

connection default;
--disable_query_log
--echo "current data"
SELECT * FROM t;
SELECT * FROM pt;

--echo "before create table"
--error 1412
eval SELECT * FROM t AS OF SNAPSHOT $point1;
--error 1412
eval SELECT /*+index(t t_idx)*/* FROM t AS OF SNAPSHOT $point1;
--error 1412
eval SELECT /*+index(t t_pidx)*/* FROM t AS OF SNAPSHOT $point1;

--error 1412
eval SELECT * FROM pt AS OF SNAPSHOT $point1;
--error 1412
eval SELECT /*+index(pt pt_idx)*/* FROM pt AS OF SNAPSHOT $point1;
--error 1412
eval SELECT /*+index(pt pt_pidx)*/* FROM pt AS OF SNAPSHOT $point1;

--echo "after insert"
eval SELECT * FROM t AS OF SNAPSHOT $point2;
eval SELECT /*+index(t t_idx)*/* FROM t AS OF SNAPSHOT $point2;
eval SELECT /*+index(t t_pidx)*/* FROM t AS OF SNAPSHOT $point2;

eval SELECT * FROM pt AS OF SNAPSHOT $point2;
eval SELECT /*+index(pt pt_idx)*/* FROM pt AS OF SNAPSHOT $point2;
eval SELECT /*+index(pt pt_pidx)*/* FROM pt AS OF SNAPSHOT $point2;

--echo "after update"
eval SELECT * FROM t AS OF SNAPSHOT $point3;
eval SELECT /*+index(t t_idx)*/* FROM t AS OF SNAPSHOT $point3;
eval SELECT /*+index(t t_pidx)*/* FROM t AS OF SNAPSHOT $point3;

eval SELECT * FROM pt AS OF SNAPSHOT $point3;
eval SELECT /*+index(pt pt_idx)*/* FROM pt AS OF SNAPSHOT $point3;
eval SELECT /*+index(pt pt_pidx)*/* FROM pt AS OF SNAPSHOT $point3;

--echo "after delete"
eval SELECT * FROM t AS OF SNAPSHOT $point4;
eval SELECT /*+index(t t_idx)*/* FROM t AS OF SNAPSHOT $point4;
eval SELECT /*+index(t t_pidx)*/* FROM t AS OF SNAPSHOT $point4;

eval SELECT * FROM pt AS OF SNAPSHOT $point4;
eval SELECT /*+index(pt pt_idx)*/* FROM pt AS OF SNAPSHOT $point4;
eval SELECT /*+index(pt pt_pidx)*/* FROM pt AS OF SNAPSHOT $point4;
--enable_query_log

DROP TABLE t;
DROP TABLE pt;
