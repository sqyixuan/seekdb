#owner: yanyuan.cxf
#owner group: transaction

--disable_warnings
--error 0, 942
drop table if exists t;
--enable_warnings

let $default_id = query_get_value(select effective_tenant_id() as id, id, 1);

connect (my_obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);

connection my_obsys;
let $point1 = query_get_value("select last_id from oceanbase.__all_virtual_id_service where tenant_id = $default_id and id_service_type = 0 and is_master = true;", last_id, 1);
connection default;
create table t (id int primary key, k int);
insert into t values(1,1);

--sleep 2
connection my_obsys;
let $point2 = query_get_value("select last_id from oceanbase.__all_virtual_id_service where tenant_id = $default_id and id_service_type = 0 and is_master = true;", last_id, 1);
connection default;

update t set k=2 where id=1;

--sleep 2
connection my_obsys;
let $point3 = query_get_value("select last_id from oceanbase.__all_virtual_id_service where tenant_id = $default_id and id_service_type = 0 and is_master = true;", last_id, 1);
connection default;

delete from t where id = 1;

--sleep 2
connection my_obsys;
let $point4 = query_get_value("select last_id from oceanbase.__all_virtual_id_service where tenant_id = $default_id and id_service_type = 0 and is_master = true;", last_id, 1);
connection default;

--disable_query_log
--error 1412
eval select * from t as of snapshot $point1;

eval select * from t as of snapshot $point2;

eval select * from t as of snapshot $point3;

eval select * from t as of snapshot $point4;
--enable_query_log

drop table t;

--sleep 2
connection my_obsys;
let $point5 = query_get_value("select last_id from oceanbase.__all_virtual_id_service where tenant_id = $default_id and id_service_type = 0 and is_master = true;", last_id, 1);
connection default;

--disable_query_log
--error 1146
eval select * from t as of snapshot $point5;
--enable_query_log
