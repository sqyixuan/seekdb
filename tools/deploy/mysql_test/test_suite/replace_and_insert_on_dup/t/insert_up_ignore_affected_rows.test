--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: laibingzheng.lbz
# owner group: SQL2
# description: insert_up, dml
--disable_warnings

--disable_warnings
drop table if exists t1, t2;
--enable_warnings

--enable_info

create table t1(c1 int primary key, c2 varchar(3));
insert ignore into t1 values(9,'111222222221') on duplicate key update c1 = 6;
select * from t1;
insert ignore into t1 values(9,'111222222221') on duplicate key update c1 = 6;
select * from t1;
insert ignore into t1 values(9,'111222222221') on duplicate key update c1 = 6;
select * from t1;
