# owner: laibingzheng.lbz
# owner group: SQL2
# description: bug: dist_insert with conflict
# tags: dml, insert_up

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
drop table if exists t1;
--enable_warnings

CREATE TABLE t1(c1 INT PRIMARY KEY, c2 int, c3 int) PARTITION BY HASH(c1) partitions 6;
create unique index idx_c2 on t1(c2) global;
create index t1_idx_01 on t1(c3) partition by hash(c3) partitions 4;
insert into t1 values(1,1,1),(2,2,2),(3,3,3),(4,4,4),(5,5,5),(6,6,6),(7,7,7),(8,8,8),(12,12,12),(13,13,13),(14,14,14),(15,15,15);
insert into t1 values(18,18,18),(19,19,19),(25,25,25),(28,28,28),(30,30,30),(38,38,38),(40,40,40),(41,41,41),(42,42,42),(43,43,43),(44,44,44),(45,45,45),(50,50,50),(51,51,51),(52,52,52),(53,53,53);
insert into t1 values(55,55,55),(56,56,56),(58,58,58),(60,60,60),(65,65,65),(69,69,69),(72,72,72),(73,73,73),(75,75,75),(76,76,76),(78,78,78),(88,88,88);
insert into t1 values(89,89,89),(95,95,95),(101,101,101);

connect (conn_admin, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn_admin;
alter system set enable_auto_leader_switch=false;
let $data_table_tid = query_get_value(select table_id from oceanbase.__all_virtual_table where table_name = 't1', table_id, 1);
let $data_table_follower_ip = query_get_value(select svr_ip from oceanbase.__all_virtual_meta_table where table_id = $data_table_tid and role = 2 and partition_id = 0, svr_ip, 1);
let $data_table_follower_port = query_get_value(select svr_port from oceanbase.__all_virtual_meta_table where table_id = $data_table_tid and role = 2 and partition_id = 0, svr_port, 1);
--disable_query_log
eval alter system switch replica leader partition_id='0%1@$data_table_tid' server='$data_table_follower_ip:$data_table_follower_port';
--sleep 2
eval alter system switch replica leader partition_id='2%1@$data_table_tid' server='$data_table_follower_ip:$data_table_follower_port';
--sleep 2
eval alter system switch replica leader partition_id='4%1@$data_table_tid' server='$data_table_follower_ip:$data_table_follower_port';
--enable_query_log
--sleep 15

let $database_id = query_get_value(select database_id from oceanbase.__all_virtual_database where tenant_id = (select tenant_id from oceanbase.__all_tenant where tenant_name = '$TENANT') and database_name = 'test', database_id, 1);
let $t1_id = query_get_value(select table_id from oceanbase.__all_virtual_table where tenant_id = (select tenant_id from oceanbase.__all_tenant where tenant_name = '$TENANT') and table_name = 't1' and database_id = $database_id, table_id, 1);
let $idx1 = query_get_value(select table_name from oceanbase.__all_virtual_table where tenant_id = (select tenant_id from oceanbase.__all_tenant where tenant_name = '$TENANT') and data_table_id = $t1_id, table_name, 1);
let $idx2 = query_get_value(select table_name from oceanbase.__all_virtual_table where tenant_id = (select tenant_id from oceanbase.__all_tenant where tenant_name = '$TENANT') and data_table_id = $t1_id, table_name, 2);

connection default;
set ob_enable_index_direct_select =1;
--disable_query_log
eval select * from $idx2 order by c1;
--enable_query_log



connection default;
