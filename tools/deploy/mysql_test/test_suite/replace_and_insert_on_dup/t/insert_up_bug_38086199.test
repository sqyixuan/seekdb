# owner: laibingzheng.lbz
# owner group: SQL2
# description: bug: dist_insert with conflict
# tags: dml, replace into

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
drop table if exists t1;
drop table if exists t2;
--enable_warnings

create table t1(c1 int primary key, c2 int auto_increment) partition by key(c1) partitions 2;
create table t2(c1 int, c2 int) partition by key(c1) partitions 3;
insert into t2 values('1',1000),('1',-100), (1, -300),('1',-200);
insert into t1 select t2.c1, t2.c2 from t2 on duplicate key update t1.c2 = t1.c2+ t2.c2;
select * from t1;
drop table t1;
drop table t2;

create table t1(c1 int primary key, c2 int);
create table t2(c1 int, c2 int) partition by key(c1);
insert into t2 values('1',1000),('1',-100),('1',-200);
insert into t1 select t2.c1, t2.c2 from t2 on duplicate key update t1.c2 = t1.c2+ t2.c1, t1.c1 = t1.c1 + t2.c2;
select * from t1;
drop table t1;
drop table t2;


