INSERT INTO t1 values(61, 72, 71), (62,73, 72), (63,74,73),(64,75,74), (65,76,75), (66,77,76), (67, 78, 77), (68, 79, 78), (69, 80, 79);

connect (conn_admin, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn_admin;
alter system set enable_auto_leader_switch=false;
let $data_table_tid = query_get_value(select table_id from oceanbase.__all_virtual_table where table_name = 't1', table_id, 1);
let $data_table_follower_ip = query_get_value(select svr_ip from oceanbase.__all_virtual_meta_table where table_id = $data_table_tid and role = 2 and partition_id = 0, svr_ip, 1);
let $data_table_follower_port = query_get_value(select svr_port from oceanbase.__all_virtual_meta_table where table_id = $data_table_tid and role = 2 and partition_id = 0, svr_port, 1);
--disable_query_log
eval alter system switch replica leader partition_id='0%1@$data_table_tid' server='$data_table_follower_ip:$data_table_follower_port';
--sleep 2
eval alter system switch replica leader partition_id='2%1@$data_table_tid' server='$data_table_follower_ip:$data_table_follower_port';
--sleep 2
eval alter system switch replica leader partition_id='4%1@$data_table_tid' server='$data_table_follower_ip:$data_table_follower_port';
--enable_query_log
--sleep 15

