# owner: laibingzheng.lbz
# owner group: SQL2
# description: bug: dist_insert with conflict
# tags: dml, replace into

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

# error will not exit
--disable_abort_on_error

--disable_warnings
drop table if exists t0;
drop table if exists t1;
drop table if exists t2;
--enable_warnings


CREATE TABLE t1(c1 INT PRIMARY KEY, c2 int, c3 int) PARTITION BY HASH(c1) partitions 6;
create index t1_idx_01 on t1(c3) global;
INSERT INTO t1 values(1, 2, 1), (2,3, 2), (3,4,3),(4,5,4), (5,6,5), (6,7,6), (7, 8, 7), (8, 9, 8), (9, 10, 9), (10, 11, 10), (11, 12, 11), (12, 13, 12), (13, 14, 13),(14, 15, 14), (15, 16, 15);
INSERT INTO t1 values(16, 17, 16), (17,18, 17), (18,19, 18),(19,20,19), (20,21,20);
INSERT INTO t1 values(21, 22, 21), (22,23, 22), (23,24,23),(24,25,34), (25,26,35), (26,27,36), (27, 28, 27), (28, 29, 38), (29, 30, 29);
INSERT INTO t1 values(31, 32, 41), (32,33, 42), (33,34,43),(34,35,44), (35,36,45), (36,37,46), (37, 38, 47), (38, 39, 48), (39, 40, 39);
INSERT INTO t1 values(41, 42, 51), (42,43, 52), (43,44,53),(44,45,54), (45,46,55), (46,47,56), (47, 48, 57), (48, 49, 58), (49, 50, 59);
