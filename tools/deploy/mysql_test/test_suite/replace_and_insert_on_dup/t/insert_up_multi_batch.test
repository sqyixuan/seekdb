# owner: laibingzheng.lbz
# owner group: SQL2
# description: bug: unique global index, insert_up, multi batch insert_up
# tags: dml, insert_up

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

# error will not exit
--disable_abort_on_error

--disable_warnings
drop table if exists t0;
drop table if exists t1;
drop table if exists t2;
--enable_warnings

# conn with oceanbase tenant
connect (conn_admin, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn_admin;
alter system set_tp tp_no = 402, error_code = 3, frequency = 1;
sleep 2;

connection default;
create table t1 (c1 int primary key, c2 int unique, c3 int);
insert into t1 values(1,1,1);
insert into t1 values(1,1,1),(2,2,2) on duplicate key update c1 = 2, c2 = 2, c3 = 2;
insert into t1 values(3,3,3),(4,4,4),(5,5,5),(6,6,6),(7,7,7),(8,8,8),(9,9,9),(10,10,10),(11,11,11),(12,12,12);
insert into t1 values(3,3,3),(4,4,4),(5,5,5),(6,6,6),(7,7,7),(8,8,8),(9,9,9),(10,10,10),(11,11,11),(12,12,12) on duplicate key update c1 = c1 + 100, c2 = c2 + 100;
select * from t1 order by c1;
drop table t1;

create table t1 (c1 int primary key, c2 int, c3 int) partition by hash(c1) partitions 4;
create unique index idx_c2 on t1(c2) global;
insert into t1 values(1,1,1),(2,2,2),(3,3,3),(4,4,4),(5,5,5),(6,6,6),(7,7,7),(8,8,8),(9,9,9),(10,10,10),(11,11,11),(12,12,12);
insert into t1 values(3,3,3),(4,4,4),(5,5,5),(6,6,6),(7,7,7),(8,8,8),(9,9,9),(10,10,10),(11,11,11),(12,12,12) on duplicate key update c1 = c1 + 100, c2 = c2 + 100;
select * from t1 order by c1;
drop table t1;

connection conn_admin;
alter system set_tp tp_no = 402, error_code = 0, frequency = 1;
