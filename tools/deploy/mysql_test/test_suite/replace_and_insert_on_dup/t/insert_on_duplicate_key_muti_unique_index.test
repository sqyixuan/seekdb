--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: yuchen.wyc
# owner group: SQL3
# description: foobar
--disable_abort_on_error
--disable_warnings
drop database  if exists db_1;
--enable_warnings
create database db_1;
use db_1;

### 二、有多个索引列，带不同列类型(timestamp,smallint,decimal,varchar,bigint)
create table t_0(c1 bigint primary key, c2 varchar(20) unique, c3 decimal(5,3) default 0.33, c4 timestamp default '2015-11-12 11:00:00', c5 smallint, unique index (c3), c6 int, unique index(c4,c5), index (c6) );
insert into t_0 (c1,c2,c3,c4,c5,c6) values(1,'a',1.33,'2015-11-12 11:00:01',1, 1),(2,'aa',2.33,'2015-11-12 11:00:02',1, 1),(3,'b',3.33,'2015-11-12 11:00:02',2, 3);
insert into t_0 (c1, c2, c3, c4, c5, c6) values(31,'31',31.1,'2016-11-12 11:00:00',31, 31),(32,'32',32.1,'2017-11-12 11:00:00',32, 32),(33,'33',33.1,'2017-11-12 11:00:00',33, 33),(34,'34',34.1,'2018-11-12 11:00:00',34, 34);

--enable_info

## 1.插入一新行，affected rows=1
insert into t_0 values(4,'bc',4.33,'2015-11-12 11:00:03',3, 3) on duplicate key update c2='b';
insert into t_0 (c1,c2,c3,c4,c5,c6) values(5,'bd',5.33,'2015-11-12 11:00:04',4, 4) on duplicate key update c1=6;
select * from t_0;

## 2.插入行只在一个索引列有冲突,但旧行有更新，affected rows=2
# c1列有冲突
insert into t_0 values(1,'cc',6.33,'2015-11-12 11:00:09',6, 6) on duplicate key update c4='2015-11-12 11:00:20';
select * from t_0;

# c2列有冲突
insert into t_0 values(6,'aa',7.33,'2015-11-12 11:00:10',7, 7) on duplicate key update c3=values(c6);
select * from t_0;

# c2,c3,c4 c5列有冲突
insert into t_0 values(7,'a',8.33,'2015-11-12 11:00:11',8, 9),(8,'dd',3.33,'2015-11-12 11:00:12',8, 9),(9,'ee',9.33,'2015-11-12 11:00:02',1, 10) on duplicate key update c1 = values(c6)+values(c1)+ 9,c3=values(c3) + 20;
select * from t_0;

## 3. 插入行只在一个索引列有冲突，但旧行无列新，affected rows=0
# c1列冲突
insert into t_0 values(5,'cc',21.33,'2015-11-12 12:00:09',10, 10) on duplicate key update c4='2015-11-12 11:00:04';
select * from t_0;

# c3列有冲突 
insert into t_0 values(4,'11',10.33,'2015-11-12 12:00:01',11, 11) on duplicate key update c3=4.33;
select * from t_0;

# c4 c5列有冲突
insert into t_0 values(12,'12',21.33,'2015-11-12 11:00:20', 1, 9),(9,'9',3.33, '2015-11-12 11:00:03', 3, 9) on duplicate key update c5=values(c5), c4=values(c4);
select * from t_0;

insert into t_0 values(12,'12',21.33,'2015-11-12 12:00:01',11, 9),(9,'9',4.33,'2015-11-12 12:01:12',8, 9) on duplicate key update c5=values(c5) - 10, c3=values(c3);
select * from t_0;

## 4. 插入多行，在索引列有冲突 =>affected rows=冲突行数+insert行数
#--error 1062
insert into t_0 values(31,'32',33.1,'2017-11-12 11:00:00',35,35) on duplicate key update c1=values(c6) + 1;

insert into t_0 values(31,'32',33.1,'2017-11-12 11:00:00',35,35) on duplicate key update c1=values(c6) + 10;
select * from t_0;

insert into t_0 values(31,'32',33.1,'2017-11-12 11:00:00',36,36) on duplicate key update c1=values(c6), c2=values(c2), c3= values(c3) + 0.01;
select * from t_0;

insert into t_0 values(36,'36',32.11,'2018-11-12 11:00:00',34, 32),(37,'37',37.1,'2018-11-12 11:00:00',37, 32) on duplicate key update c1 = values(c6), c2=values(c2), c3=values(c3) + values(c1), c4='2018-11-12 11:00:00';
select * from t_0;

create table tab(s1 number primary key, s2 varchar(6));
create table tab1(s1 number primary key, s2 number default 1, s3 int, constraint tab1_fk foreign key(s2) references tab(s1));
insert into tab values(1,66);
insert into tab values(10,88);
insert into tab1 values (66, 1, 0), (88, 10, 0), (11, 11, 0);
insert into tab1 values (66, 1, 0), (88, 10, 0), (11, 11, 0) on duplicate key update s3 = 1000;
select * from tab1;

drop database db_1;
