--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: yuchen.wyc
# owner group: SQL3
# description: foobar
#--disable_abort_on_error
--disable_warnings
drop database  if exists db_1;
--enable_warnings
create database db_1;
use db_1;

### 一、只有一个索引列
create table t_0(c1 int primary key, c2 varchar(20), c3 int);
insert into t_0 values(1,2,3),(4,5,6);

--enable_info

## 1.插入一新行，affected rows=1
insert into t_0 values(7,8,9) on duplicate key update c3=c3+1;

## 2.插入行在索引列有冲突，并且旧行有更新 => affected rows = 2
insert into t_0 values(1,1,1) on duplicate key update c3=1;
insert into t_0 values(4,9,9) on duplicate key update c3=values(c3);

select * from t_0;

## 3.插入行在索引列有冲突，但旧行被更新与其相同的值 =>affected rows = 0
insert into t_0 values(4,5,6) on duplicate key update c2 = values(c2);
select * from t_0;

insert into t_0 (c1, c2) values(7,7) on duplicate key update c3 = t_0.c3;
select * from t_0;

## 4. 插入多行，在索引列有冲突 =>affected rows=冲突行数+insert行数
insert into t_0 (c1, c2,c3) values(1,9,9),(4,5,6),(7,8,10),(3,3,3),(5,4,3) on duplicate key update c3 = values(c3);
select * from t_0;
insert into t_0 (c1,c2,c3) values(1,1,1),(2,2,2),(3,3,3),(4,4,4),(5,5,5) on duplicate key update c3= values(c1) + values(c1), c1=values(c1);
select * from t_0;

insert into t_0(c1, c2,c3) values (7,7,7) on duplicate key update c2=values(c3), c1=values(c2),c3=values(c1);
insert into t_0(c1, c2,c3) values (3,9,9),(2,8,8) on duplicate key update c2=values(c3), c1=values(c2) + 10,c3=values(c1);
select * from t_0;
