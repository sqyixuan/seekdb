select * from t1 order by c1;

connect (my_admin,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection my_admin;

let $TENANT = sys;
let $database_id = query_get_value(select database_id from oceanbase.__all_virtual_database where database_name = 'test', database_id, 1);
let $t1_id = query_get_value(select table_id from oceanbase.__all_virtual_table where table_name = 't1' and database_id = $database_id, table_id, 1);
let $idx1 = query_get_value(select table_name from oceanbase.__all_virtual_table where data_table_id = $t1_id, table_name, 1);
let $idx2 = query_get_value(select table_name from oceanbase.__all_virtual_table where data_table_id = $t1_id, table_name, 2);
let $idx3 = query_get_value(select table_name from oceanbase.__all_virtual_table where data_table_id = $t1_id, table_name, 3);

connection default;
set ob_enable_index_direct_select =1;
--disable_query_log
eval select * from $idx1 order by c1;
eval select * from $idx2 order by c1;
eval select * from $idx3 order by c1;
--enable_query_log

delete from t1;
insert into t1 values(1, 'aaa', '2020-01-01', 'aa', 1), (2, 'bbb', '2020-2-2', 'bb', 2), (4, 'ddd', '2020-4-4', 'dd',4),(6,'fff', '2020-6-6', 'ff',6),(8,'hhh','2020-8-8', 'hh',8);
insert into t1 values(1, 'aaa', '2020-01-01', 'aa', 1), (2, 'bbb', '2020-2-2', 'bb', 2), (4, 'ddd', '2020-4-4', 'dd',4),(6,'fff', '2020-6-6', 'ff',6),(8,'hhh','2020-8-8', 'hh',8) ON DUPLICATE KEY UPDATE c2 = concat(c2, '--3'), c5 = c5 + 10000;
select * from t1 order by c1;
set ob_enable_index_direct_select =1;
--disable_query_log
eval select * from $idx1 order by c1;
eval select * from $idx2 order by c1;
eval select * from $idx3 order by c1;
--enable_query_log


delete from t1;
insert into t1 values(1, 'aaa', '2020-01-01', 'aa', 1), (2, 'bbb', '2020-2-2', 'bb', 2), (4, 'ddd', '2020-4-4', 'dd',4),(6,'fff', '2020-6-6', 'ff',6),(8,'hhh','2020-8-8', 'hh',8);
--error 1062
insert into t1 values(4, 'ddd-new', '2020-4-4', 'dd-new', 4) ON DUPLICATE KEY UPDATE c2 = concat(c2, '--3'),  c4 = 'ff';
insert into t1 values(4, 'ddd-new', '2020-4-4', 'dd-new', 4) ON DUPLICATE KEY UPDATE c2 = concat(c2, '--3'),  c4 = concat(values(c4), '--new--dkz');
select * from t1;
set ob_enable_index_direct_select =1;
--disable_query_log
eval select * from $idx1 order by c1;
eval select * from $idx2 order by c1;
eval select * from $idx3 order by c1;
--enable_query_log

drop table t1;


create table t1(c1 varchar(200), c2 date, c3 int, c4 int, c5 varchar(200), c6 int, primary key(c1, c2, c3)) partition by key(c2) partitions 4;
create unique index idx_c4 on t1(c4) global;
create index t1_c5_01 on t1(c5) partition by key(c5) partitions 4;
create index t1_c6_01 on t1(c6) partition by hash(c6) partitions 4;
