--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
--disable_warnings
drop table if exists t1;
drop table if exists t2;
--enable_warnings

create table t1 (c1 int, c2 varchar(20), c3 date, c4 varchar(200), c5 int, primary key(c1,c2)) partition by key(c2) partitions 4;
create unique index idx_c3 on t1(c3) global;
create unique index idx_c4 on t1(c4) global;
create index c5_idx_01 on t1(c5) partition by hash(c5) partitions 3;
insert into t1 values(1, 'aaa', '2020-01-01', 'aa', 1), (2, 'bbb', '2020-2-2', 'bb', 2), (4, 'ddd', '2020-4-4', 'dd',4),(6,'fff', '2020-6-6', 'ff',6),(8,'hhh','2020-8-8', 'hh',8);
