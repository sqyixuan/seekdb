# owner: qiaolinjun.qlj
# owner group: IMF
# description: for replace into op, test insert on local index
# tags: dml, replace into

--disable_warnings
drop table if exists t2;
--enable_warnings

## 无主键分区表，局部非唯一索引
create table t2 (c1 int, c2 int, c3 int, key idx_1(c1) local) partition by hash(c2) partitions 10;
insert into t2 values(1,1,1),(2,2,2),(3,3,3);
replace into t2 values (1,1,3);
select * from t2;

## 无主键分区表，局部唯一索引
drop table t2;
create table t2 (c1 int, c2 int, c3 int) partition by hash(c2) partitions 10;
CREATE UNIQUE INDEX ind_1 ON t2 (c1, c2) local;
insert into t2 values(1,1,1),(2,2,2),(3,3,3);
replace into t2 values (1,1,3);
select * from t2;

## 无主键非分区表，非唯一索引
drop table t2;
create table t2 (c1 int, c2 int, c3 int, key idx_1(c1));
insert into t2 values(1,1,1),(2,2,2),(3,3,3);
replace into t2 values (1,1,3);
select * from t2;

## 无主键分区表，唯一索引
drop table t2;
create table t2 (c1 int, c2 int, c3 int);
CREATE UNIQUE INDEX ind_1 ON t2 (c1, c2);
insert into t2 values(1,1,1),(2,2,2),(3,3,3);
replace into t2 values (1,1,3);
select * from t2;

## 有主键分区表，非唯一索引
drop table t2;
create table t2 (c1 int primary key, c2 int, c3 int, key idx_1(c2) local) partition by hash(c1) partitions 10;
insert into t2 values(1,1,1),(2,2,2),(3,3,3);
replace into t2 values (1,1,3);
select * from t2;

## 有主键分区表，唯一索引
drop table t2;
create table t2 (c1 int primary key, c2 int, c3 int) partition by hash(c1) partitions 10;
CREATE UNIQUE INDEX ind_1 ON t2 (c1, c2) local;
insert into t2 values(1,1,1),(2,2,2),(3,3,3);
replace into t2 values (1,1,3);
select * from t2;

## clear schema
drop table t2;