--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: yuchen.wyc
# owner group: SQL3
# description: foobar
#--disable_abort_on_error
--disable_warnings
drop database  if exists db_1;
--enable_warnings
create database db_1;
use db_1;

--enable_info
## 三、带自增列的情况
## 自动列是主键列
create table  t_1(c1 int primary key auto_increment, c2 int ,c3 int,c4 int, unique index(c2) , index (c3));
insert into t_1 (c2, c3,c4) values(0,0,0), (1,1,1),(3,3,3),(4,4,4), (5,5,5);

## 1.插入一新行，affected rows = 1
replace into t_1 (c2, c3, c4 ) values (20,20,20);
replace into t_1 (c1,c2,c3,c4) values(7,21,21,21);
select * from t_1;

## 2. 插入行同时在两个唯一索引列有冲突，并且新行的值与旧行不完全相同，先删除行，插入 affected rows = 冲突行数 + 插入行数

## =>3
replace into t_1 values(5,3,4,5);
select * from t_1;

## =>5
replace into t_1 values(1,1,6,6),(4,4,7,7);
select * from t_1;

## =>5
replace into t_1 values(5,4,8,8),(0,0,0,0),(9,9,1,9);
select * from t_1;

## 3. 只在索引列，非唯一索引列有冲突 =>1
replace into t_1 values(10,10,1,9);

## 4. 在普通索引列和主键列有冲突 =>2
replace into t_1 values(10,7,1,7);

## 自增列是唯一索引列
create table  t_2(c1 int primary key, c2 int unique auto_increment, c3 int,c4 int, index (c3));
insert into t_2 (c1, c3,c4) values(0,0,0), (1,1,1),(3,3,3),(4,4,4), (5,5,5);

# 1.插入一新行，affected rows = 1
replace into t_2  (c1, c3, c4 ) values (20,20,20);
replace into t_2 (c1,c2,c3,c4) values(21,7,21,21);
select * from t_2;

## 2. 插入行同时在两个唯一索引列有冲突，并且新行的值与旧行不完全相同，先删除行，插入 affected rows = 冲突行数 + 插入行数

## =>3
replace into t_2 values(5,1,4,5);
select * from t_2;

## =>3
replace into t_2 (c1, c3,c4) values(0,6,6), (0,7,7);
select * from t_2;

## =>7
replace into t_2 values(0,7,8,8),(0,0,0,0),(9,4,1,9);
select * from t_2;

## 3. 只在索引列，非唯一索引列有冲突 =>1
replace into t_2 values(11,11,1,9);

## 自增列是一个普通列
create table  t_3(c1 int primary key, c2 int, c3 int, c4 int auto_increment, unique index(c2) , index (c3));
insert into t_3 (c1, c3, c2) values (1,1,1),(3,3,3),(4,4,4), (5,5,5);
insert into t_3 values(6,6,6,6);

## 1. 插入一新行，affected rows = 1
replace into t_3 (c1, c2, c3 ) values (7,7,7);
select * from t_3;

## 2. 插入行同时在两个唯一索引列有冲突，并且新行的值与旧行不完全相同，先删除行，插入 affected rows = 冲突行数 + 插入行数

## =>3
replace into t_3 (c1, c2, c3) values(5,3,5);
select * from t_3;

## =>5
replace into t_3 (c1, c2, c3) values(1,7,7), (1,8,8);
select * from t_3;

## =>4
replace into t_3 (c1, c2, c3)values(8,7,8),(1,1,1),(9,9,1);
select * from t_3;

## 3. 只在索引列，非唯一索引列有冲突 =>1
replace into t_3 (c1,c2,c3) values(10,10,1);
select * from t_3;

## 4. 在普通索引列和主键列有冲突 =>3
replace into t_3 (c1,c2,c3) values(9,7,1);
select * from t_3;

## 5. 插入行只在自增列有冲突
replace into t_3 values(11,11,11,8);
select * from t_3;

