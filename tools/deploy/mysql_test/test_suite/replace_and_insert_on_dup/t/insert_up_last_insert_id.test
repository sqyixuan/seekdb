# owner: laibingzheng.lbz
# owner group: SQL2
# description: bug: dist_insert with conflict
# tags: dml, replace into

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
connect (conn_admin, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn_admin;
sleep 2;

connection default;
set global ob_plan_cache_percentage=20;

--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE `t1` (`c1` bigint unsigned NOT NULL AUTO_INCREMENT, `c2` int, c3 int, PRIMARY KEY (`c1`, c2), UNIQUE KEY `c3` (`c3`));
insert into t1(c2,c3) values(1,1),(2,2),(3,3) on duplicate key update c2 = c2 + 100;
select last_insert_id();
select * from t1 order by c1;
insert into t1(c1,c2,c3) values(default,21,21),(default,21,21),(default,23,23) on duplicate key update c2 = c2 + 100;
select last_insert_id();
select * from t1 order by c1;
insert into t1(c2,c3) values(1,1),(2,2),(3,3),(8,8),(9,9) on duplicate key update c2 = c2 + 100;
select last_insert_id();
select * from t1 order by c1;

## Incompatible with mysql, will return the value of the specified auto-increment column
insert into t1(c1,c2,c3) values(default,30,30),(2,2,2),(3,3,3) on duplicate key update c2 = c2 + 100;
select last_insert_id();
insert into t1(c1,c2,c3) values(70,70,70) on duplicate key update c2 = c2 + 100;
select last_insert_id();
insert into t1(c1,c2,c3) values(71,71,71) on duplicate key update c2 = c2 + 100;
select last_insert_id();
insert into t1(c1,c2,c3) values(72,72,72) on duplicate key update c2 = c2 + 100;
select last_insert_id();
select * from t1 order by c1;

insert into t1(c1,c2,c3) values(default,2,2),(default,3,3),(default,50,50),(default,51,51),(default,52,52) on duplicate key update c2 = c2 + 100;
select last_insert_id();
select * from t1 order by c1;

insert into t1(c2,c3) values(61,61) on duplicate key update c2 = c2 + 100;
select last_insert_id();
select * from t1 order by c1;
insert into t1(c2,c3) values(62,62) on duplicate key update c2 = c2 + 100;
select last_insert_id();
insert into t1(c2,c3) values(63,63) on duplicate key update c2 = c2 + 100;
select last_insert_id();
insert into t1(c2,c3) values(64,64) on duplicate key update c2 = c2 + 100;
select last_insert_id();
insert into t1(c2,c3) values(65,65) on duplicate key update c2 = c2 + 100;

# duplicate
insert into t1(c2,c3) values(62,62) on duplicate key update c2 = c2 + 100;
select last_insert_id();
insert into t1(c2,c3) values(63,63) on duplicate key update c2 = c2 + 100;
select last_insert_id();
insert into t1(c2,c3) values(64,64) on duplicate key update c2 = c2 + 100;
select last_insert_id();
insert into t1 values(default,64,64) on duplicate key update c2 = c2 + 100;
select last_insert_id();
insert into t1 values(default,65,65) on duplicate key update c2 = c2 + 100;
select last_insert_id();

