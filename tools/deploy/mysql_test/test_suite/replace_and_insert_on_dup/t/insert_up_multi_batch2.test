# owner: laibingzheng.lbz
# owner group: SQL2
# description: bug: unique global index, insert_up, multi batch insert_up
# tags: dml, insert_up

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

# error will not exit
--disable_abort_on_error

--disable_warnings
drop table if exists t0;
drop table if exists t1;
drop table if exists t2;
--enable_warnings

# conn with oceanbase tenant
connect (conn_admin, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn_admin;
alter system set_tp tp_no = 402, error_code = 2, frequency = 1;
sleep 2;

connection default;

create table t1(c1 varchar(400), c2 varchar(200), c3 varchar(200), c4 varchar(200), c5 varchar(50), primary key(c1, c2)) partition by key(c1) partitions 6;
create unique index idx_c3 on t1(c3) global;
create unique index idx_c4 on t1(c4) global;

insert into t1 values(repeat('a', 100), repeat('a',50), repeat('a', 25), repeat('a', 20), repeat('a', 20));
insert into t1 values(repeat('b', 100), repeat('b',50), repeat('b', 25), repeat('b', 20), repeat('b', 20));
insert into t1 values(repeat('c', 100), repeat('c',50), repeat('c', 25), repeat('c', 20), repeat('c', 20));
insert into t1 values(repeat('d', 100), repeat('d',50), repeat('d', 25), repeat('d', 20), repeat('d', 20));
insert into t1 values(repeat('e', 100), repeat('e',50), repeat('e', 25), repeat('e', 20), repeat('e', 20));
insert into t1 values(repeat('f', 100), repeat('f',50), repeat('f', 25), repeat('f', 20), repeat('f', 20));
insert into t1 values(repeat('g', 100), repeat('g',50), repeat('g', 25), repeat('g', 20), repeat('g', 20));
insert into t1 values(repeat('h', 100), repeat('h',50), repeat('h', 25), repeat('h', 20), repeat('h', 20));
insert into t1 values(repeat('i', 100), repeat('i',50), repeat('i', 25), repeat('i', 20), repeat('i', 20));
insert into t1 values(repeat('j', 100), repeat('j',50), repeat('j', 25), repeat('j', 20), repeat('j', 20));

create table t2(c1 varchar(400), c2 varchar(200), c3 varchar(200), c4 varchar(200), c5 varchar(50));
# 冲突 (repeat('a', 100), repeat('a',50), repeat('a', 25), repeat('a', 20), repeat('a', 20))
insert into t2 values(repeat('a', 100), repeat('a',50), repeat('ag', 10), repeat('ag', 20), repeat('ab', 10));
# # 冲突(repeat('c', 100), repeat('c',50), repeat('c', 25), repeat('c', 20), repeat('c', 20))
insert into t2 values(repeat('b', 100), repeat('a',20), repeat('c', 25), repeat('c', 20), repeat('ad', 10));
# # 冲突(repeat('c', 100), repeat('c',50), repeat('c', 25), repeat('c', 20), repeat('c', 20)) 和 (repeat('d', 100), repeat('d',50), repeat('d', 25), repeat('d', 20), repeat('d', 20))
insert into t2 values(repeat('c', 100), repeat('a',50), repeat('c', 25), repeat('d', 20), repeat('af', 10));
# # 冲突 (repeat('d', 100), repeat('d',50), repeat('d', 25), repeat('d', 20), repeat('d', 20))
insert into t2 values(repeat('d', 100), repeat('d',60), repeat('d', 25), repeat('d', 20), repeat('ag', 20));
# # 冲突 (repeat('f', 100), repeat('f',50), repeat('f', 25), repeat('f', 20), repeat('f', 20))
insert into t2 values(repeat('f', 100), repeat('f',50), repeat('f', 25), repeat('f', 30), repeat('af', 20));
insert into t2 values(repeat('g', 100), repeat('g',50), repeat('g', 25), repeat('g', 30), repeat('g', 20));
insert into t2 values(repeat('h', 100), repeat('h',30), repeat('h', 25), repeat('h', 30), repeat('h', 6));
insert into t2 values(repeat('i', 100), repeat('i',50), repeat('j', 25), repeat('i', 30), repeat('k', 6));
insert into t2 values(repeat('x', 100), repeat('x',50), repeat('x', 25), repeat('x', 30), repeat('x', 6));
insert into t2 values(repeat('y', 100), repeat('y',50), repeat('y', 25), repeat('y', 30), repeat('y', 6));

insert into t1 select * from t2 on duplicate key update c5 = repeat('upd', 5), c4 = concat('update_', concat(t1.c4, '_a'));
select * from t1 order by c1;
drop table t1;
drop table t2;
connection conn_admin;
alter system set_tp tp_no = 402, error_code = 0, frequency = 1;
