--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: yuchen.wyc
# owner group: SQL3
# description: 本case是为了测试replace、insert up 能读到最新的数据；
# tags: dml, replace

--disable_warnings
drop table if exists test, t1;
--enable_warnings

--enable_info
#只含主键
create table test(c1 int primary key, c2 int, c3 int);
replace into test values(1,2,3), (2,3,4), (1,2,5), (2,4,6);
select * from test;
replace into test values(3,4,5),(4,5,6),(3,6,2),(3,5,2),(3,4,1);
select * from test;
insert into test values(1,2,3),(1,4,2),(1,3,2) on duplicate key update c3 = c3 + 1;
select * from test;

#含主键和唯一索引列
drop table test;
create table test(c1 int primary key, c2 int unique key, c3 int);
replace into test values(1,2,3), (2,3,4), (1,2,5), (2,4,6), (2,4,7);
select * from test;
replace into test values(3,4,5),(4,5,6),(3,6,2),(3,5,2),(3,4,1);
select * from test;
insert into test values(1,2,3),(1,4,2),(1,3,2) on duplicate key update c3 = c3 + 1;
select * from test;

##其他语句

drop table test;
create table test(c1 int primary key, c2 int);
insert into test values(1,2), (2,3),(4,2);
update test set c1 = c1 + 1 where c1 in (1,2,3,4) limit 2;
select 8 from test;
drop table test;

create table t1 (c1 int primary key);
insert into t1 values(-100),(6),(10);
select * from t1 where c1 in (-100,5,6,10) limit 2;
--error 1062
update t1 set c1 = 5 where c1 in (-100,5,6,10) limit 2;
drop table t1;
