# owner: jingfeng.jf
# owner group: SQL2
# description: bug: 
# tags: dml, replace into

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
drop table if exists genco1;
--enable_warnings


create table genco1(
  c1 VARCHAR(20),
  c2 VARCHAR(20) GENERATED ALWAYS AS (substr(c1, 2)) VIRTUAL,
  c3 VARCHAR(20)
) partition by key(c2, c3) partitions 3;

replace into genco1(c1, c3) values('123456', '123456');
drop table genco1;

--disable_warnings
drop table if exists t5;
--enable_warnings

create table t5(c1 varchar(10), c2 varchar(8) generated always as (substring(c1, 2)) virtual, c3 int) partition by key(c2) partitions 5;
replace into t5 (c1, c3) values ('abcdefg', 100);
drop table t5;