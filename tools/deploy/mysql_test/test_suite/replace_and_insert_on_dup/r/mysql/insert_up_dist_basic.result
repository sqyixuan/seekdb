drop table if exists t1;
CREATE TABLE t1(c1 INT PRIMARY KEY, c2 int, c3 int) PARTITION BY HASH(c1) partitions 6;
create unique index idx_c2 on t1(c2) global;
create index t1_idx_01 on t1(c3) partition by hash(c3) partitions 4;
insert into t1 values(1,1,1),(2,2,2),(3,3,3),(4,4,4),(5,5,5),(6,6,6),(7,7,7),(8,8,8),(12,12,12),(13,13,13),(14,14,14),(15,15,15);
