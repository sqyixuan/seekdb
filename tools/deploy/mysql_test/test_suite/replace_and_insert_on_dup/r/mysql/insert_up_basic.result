drop table if exists t1;
drop table if exists t2;
# 测试单分区表基本的insert_up功能
create table t1(c1 int primary key , c2 int);
insert into t1 values(1,1),(2,2),(3,3),(4,4);
insert into t1 values(1,2) ON DUPLICATE KEY UPDATE c1 = c1 + 1;
ERROR 23000: Duplicate entry '2' for key 'PRIMARY'
insert into t1 values(1,1), (2,2), (3,3), (4,5) ON DUPLICATE KEY UPDATE c1 = c1 + 100, c2 = c2 + 1;
select * from t1;
c1	c2
101	2
102	3
103	4
104	5
delete from t1;
insert into t1 values(1,1), (3,3), (5,5), (10, 10), (20, 20), (25, 25), (30, 30), (40, 40), (50, 50);
