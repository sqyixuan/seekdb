drop table if exists t_eleme_order_all_partitionly;
CREATE TABLE `t_eleme_order_all_partitionly` (
`dim_date_id` int(10) NOT NULL,
`pt` char(8) COLLATE utf8mb4_bin NOT NULL,
`date` char(10) COLLATE utf8mb4_bin NOT NULL,
`dim_pshop_id` bigint(20) NOT NULL,
`platform_shop_id` bigint(20) NOT NULL,
`platform` varchar(50) COLLATE utf8mb4_bin NOT NULL,
`platform_id` int(11) NOT NULL,
`order_id` bigint(20) NOT NULL,
`user_id` bigint(20) NOT NULL,
`address` varchar(500) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '配送地址',
`delivery_geo` varchar(100) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '配送坐标',
`delivery_poi_address` varchar(500) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '门店地址',
`original_price` decimal(10,2) DEFAULT NULL COMMENT '包含菜品+包装+配送',
`total_price` decimal(10,2) NOT NULL COMMENT '包含菜品+包装+配送-补贴,用户实付',
`activity_total` decimal(10,2) DEFAULT NULL COMMENT '活动补贴',
`shop_part` decimal(10,2) DEFAULT NULL COMMENT '商家部分',
`eleme_part` decimal(10,2) DEFAULT NULL COMMENT '平台部分',
`income` decimal(10,2) DEFAULT NULL COMMENT '实收',
`service_rate` decimal(10,2) DEFAULT NULL COMMENT '费率',
`service_fee` decimal(10,2) DEFAULT NULL COMMENT '服务费',
`cold_box_fee` decimal(10,2) DEFAULT NULL,
`package_fee` decimal(10,2) DEFAULT NULL,
`deliver_fee` decimal(10,2) DEFAULT NULL COMMENT '配送费',
`status` varchar(50) COLLATE utf8mb4_bin DEFAULT NULL,
`refund_status` varchar(50) COLLATE utf8mb4_bin DEFAULT NULL,
`sku_count` int(11) DEFAULT NULL COMMENT '根据sku_id去重后的菜品数量',
`item_count` int(11) DEFAULT NULL COMMENT '订单的菜品个数（一个菜品点多次算一个）',
`item_quantity` int(11) DEFAULT NULL COMMENT '订单的菜品总数（一个菜品点多次算多个）',
`order_7d` int(11) DEFAULT NULL,
`order_15d` int(11) DEFAULT NULL,
`order_30d` int(11) DEFAULT NULL,
`order_60d` int(11) DEFAULT NULL,
`order_90d` int(11) DEFAULT NULL,
`distance` decimal(10,2) DEFAULT NULL,
`merchant_delivery_subsidy` decimal(10,2) DEFAULT NULL COMMENT '商户配送补贴',
`delivery_type` int(11) DEFAULT NULL COMMENT '配送方式',
`created_at` varchar(50) COLLATE utf8mb4_bin DEFAULT NULL,
`baidu_waimai` tinyint(1) DEFAULT NULL COMMENT '百度外卖',
`updateTime` timestamp NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
`addTime` timestamp NOT NULL DEFAULT CURRENT_TIMESTAMP,
`turnover_amount` decimal(20,2) DEFAULT NULL,
`downgraded` tinyint(1) DEFAULT NULL,
`tag` int(11) NOT NULL DEFAULT '1',
`rider_finished_time` varchar(50) COLLATE utf8mb4_bin DEFAULT NULL COMMENT '骑手送达时间',
`original_deliver_fee` decimal(10,2) DEFAULT NULL COMMENT '饿了么原始配送费包含配送补贴',
`deliver_time` varchar(50) COLLATE utf8mb4_bin DEFAULT NULL,
`daysn` int(10) DEFAULT NULL COMMENT '流水号',
UNIQUE KEY `orderid_idx` (`order_id`, `dim_pshop_id`, `dim_date_id`) BLOCK_SIZE 16384 LOCAL,
KEY `data_check` (`platform`, `date`) BLOCK_SIZE 16384 LOCAL,
KEY `index_dim_pshop_id_updateTime` (`dim_pshop_id`, `updateTime`) BLOCK_SIZE 16384 LOCAL,
KEY `shopid_date_status_idx` (`dim_pshop_id`, `date`, `status`) BLOCK_SIZE 16384 LOCAL
) DEFAULT CHARSET = utf8mb4 COLLATE = utf8mb4_bin ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 3 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
partition by range(`dim_date_id`)
subpartition by HASH(dim_pshop_id) SUBPARTITIONS 4
