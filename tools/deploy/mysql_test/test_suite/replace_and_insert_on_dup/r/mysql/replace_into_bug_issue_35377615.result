drop table if exists t0;
CREATE TABLE t0(c0 INT PRIMARY KEY, c1  VARCHAR(500)) PARTITION BY HASH(c0) partitions 13;
INSERT INTO t0(c0, c1) values(1, 'a');
REPLACE INTO t0(c0, c1) VALUES(-2, "dkz");
CREATE INDEX i670 ON t0(c1(2), c0) ;
REPLACE INTO t0(c0, c1) VALUES(1, "b"), (-2, "c");
select * from t0;
c0	c1
1	b
-2	c
select /*+index(t0 i670)*/ c1 from t0;
c1
b
c
drop table t0;
