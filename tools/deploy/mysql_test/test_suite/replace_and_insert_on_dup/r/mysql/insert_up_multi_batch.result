drop table if exists t0;
drop table if exists t1;
drop table if exists t2;
alter system set_tp tp_no = 402, error_code = 3, frequency = 1;
create table t1 (c1 int primary key, c2 int unique, c3 int);
insert into t1 values(1,1,1);
insert into t1 values(1,1,1),(2,2,2) on duplicate key update c1 = 2, c2 = 2, c3 = 2;
insert into t1 values(3,3,3),(4,4,4),(5,5,5),(6,6,6),(7,7,7),(8,8,8),(9,9,9),(10,10,10),(11,11,11),(12,12,12);
