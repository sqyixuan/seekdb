CREATE TABLE `t3` ( `gmt_create` timestamp(6) NULL DEFAULT CURRENT_TIMESTAMP(6), `tenant_id` bigint(20) NOT NULL, PRIMARY KEY (`tenant_id`) );
insert into t3(`tenant_id`) values(1),(2),(3),(4),(5),(6),(7),(8),(9) on duplicate key update`tenant_id` = values(`tenant_id`);
replace into t3(`tenant_id`) values(1),(2),(3),(4),(5),(6),(7),(8),(9);
select count(*) from t3;
count(*)
