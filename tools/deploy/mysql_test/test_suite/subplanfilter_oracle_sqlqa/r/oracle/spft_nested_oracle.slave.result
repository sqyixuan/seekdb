insert into t1
with
tmp1 as(select case when
c1 > (select /*+no_rewrite*/ max(c1) from t1 where c1 > all (select min(a1) from t2))
then '1'
when c1 < (select /*+no_rewrite*/ avg(c1) from t1 where c1 >  some (select avg(a1) from t2))
then '2'
when c1 = (select /*+no_rewrite*/ min(c1) from t1 where exists (select a1 from t2))
then '3'
when c1 != (select /*+no_rewrite*/ count(c1) from t1 where c1 like (select min(a1) from t2))
then '4'
else 'null'
end from t1),
tmp2 as (select case when
a1 = (select /*+no_rewrite*/ max(t1.c1) from t1 inner join t2 on t1.c1 = t2.a1 where exists  (select max(a1) from t2 where t1.c1 = t2.a1))
then 'DDD'
when a1 > (select /*+no_rewrite*/ min(t1.c1) from t1 left join t2 on t1.c1 = t2.a1 where not exists (select min(a1) from t2 where t1.c1 = t2.a1))
then 'CCC'
when a1 < (select /*+no_rewrite*/ avg(t1.c1) from t1 right join t2 on t1.c1 = t2.a1 where t1.c1 =  (select min(a1) from t2 where t1.c1 = t2.a1))
then 'BBB'
when a1 != (select /*+no_rewrite*/ max(t2.a1) from t1 cross join t2 where c1 = all  (select max(a1) from t2 where t1.c1 = t2.a1))
then 'AAA'
else 'SSS'
end from t2)
select * from tmp1,tmp2;
insert into t1
with
tmp1 as (select * from (select /*+no_rewrite*/  * from t2 where a1 > any (select b1 from t3))  tt1),
tmp2 as (select * from (select /*+no_rewrite*/  * from t3 where b1 = (select a1 from t2 where t2.a1 = t3.b1))  tt2)
select tmp1.a1,tmp2.b1 from tmp1,tmp2 where tmp1.a1 = tmp2.b1;
drop table t1;
drop table t2;
drop table t3;
# Clean up users
drop user zwc cascade;
