select case when
c1 > (select /*+no_rewrite*/ max(c1) from t1 where c1 > all (select min(a1) from t2))
then '1'
when c1 < (select /*+no_rewrite*/ avg(c1) from t1 where c1 >  some (select avg(a1) from t2))
then '2'
when c1 = (select /*+no_rewrite*/ min(c1) from t1 where c1 like (select max(a1) from t2))
then '3'
when c1 != (select /*+no_rewrite*/ count(c1) from t1 where c1 like (select min(a1) from t2))
then '4'
else 'null'
end from t1;
