drop user zwc cascade;
create user zwc identified by zwc;
grant all on *.* to zwc with grant option;
grant dba to zwc;
#设置超时等待时间
SET wait_timeout=30000000;
SET ob_trx_timeout = 100000000;
SET ob_query_timeout = 100000000;
#case when
create table t1(c1 int,c2 varchar(20));
create table t2(a1 int,a2 varchar2(20));
create table t3(b1 int,b2 binary_double);
insert into t1 values(1,'ab');
insert into t1 values(2,'cd');
insert into t1 values(3,'ka');
insert into t1 values(4,null);
insert into t1 values(5,'五六');
insert into t2 values(0,'2019-03-22');
