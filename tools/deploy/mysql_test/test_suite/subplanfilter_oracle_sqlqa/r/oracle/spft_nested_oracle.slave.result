insert into t1
with
tmp1 as (select /*+no_rewrite*/ *  from t1 where c1 > (select min(a1) from t2)),
tmp2 as (select /*+no_rewrite*/ * from t2 where a1  = (select b1 from t3 where t3.b1 = t2.a1))
