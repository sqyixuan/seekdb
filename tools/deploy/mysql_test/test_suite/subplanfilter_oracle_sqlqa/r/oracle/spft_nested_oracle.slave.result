insert into t2 values(2,'2021-03-22');
insert into t2 values(4,'2022-03-22');
insert into t2 values(6,'2023-03-22');
insert into t3 values(1,0.1);
insert into t3 values(2,0.2);
insert into t3 values(3,0.3);
insert into t3 values(4,0.4);
insert into t3 values(5,0.5);
insert into t3 values(6,0.6);
insert into t3 values(7,0.7);
