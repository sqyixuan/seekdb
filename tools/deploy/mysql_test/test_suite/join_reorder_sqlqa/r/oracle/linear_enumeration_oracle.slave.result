FROM (a1 LEFT JOIN c1 ON a1.id=c1.id FULL JOIN d1 ON c1.id=d1.id CROSS JOIN b1 INNER JOIN a3 ON b1.id=a3.id INNER JOIN d3 ON a3.id=d3.id) INNER JOIN 
(b2 INNER JOIN c2 ON b2.id!=c2.id FULL JOIN d2 ON c2.id=d2.id LEFT JOIN a2 ON a2.id<3 FULL JOIN b3 ON a2.id=b3.id RIGHT JOIN c3 ON c3.id=b2.id+c2.id) ON 1=1
