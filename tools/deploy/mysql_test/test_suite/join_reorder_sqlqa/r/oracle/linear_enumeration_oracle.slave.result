FROM a2 LEFT JOIN (c5 LEFT JOIN b1 ON c5.id=b1.id RIGHT JOIN a5 ON a5.id=c5.id+b1.id INNER JOIN a3 ON a3.id!=b1.id FULL JOIN c2 ON a3.id=a5.id+1) ON a2.id=b1.id+1
