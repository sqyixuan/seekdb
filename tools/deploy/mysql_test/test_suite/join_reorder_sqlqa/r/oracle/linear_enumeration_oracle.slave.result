FROM c1 INNER JOIN d2 ON c1.id<3 AND d2.id>3 INNER JOIN c5 ON c5.id=5 CROSS JOIN (d3 FULL JOIN d4 ON d3.id<4 FULL JOIN a1 ON d4.id>6 LEFT JOIN c2 ON c2.id=4 LEFT JOIN c3 ON c3.id>2)
RIGHT JOIN b1 ON a1.id=3 AND b1.id=1 RIGHT JOIN c4 ON c1.id=2 AND c4.id<3 INNER JOIN (d5 NATURAL JOIN d1) ON d2.id<5 AND d1.p_id_d1=1
