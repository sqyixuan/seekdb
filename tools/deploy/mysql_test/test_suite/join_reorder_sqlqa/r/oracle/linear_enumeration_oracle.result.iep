INNER JOIN c2 ON b2.id=c2.id FULL JOIN d2 ON c2.id=d2.id FULL JOIN a1 ON d2.id=a1.id FULL JOIN b1 ON a1.id=b1.id FULL JOIN c1 ON b1.id=c1.id FULL JOIN d1 ON c1.id=d1.id
