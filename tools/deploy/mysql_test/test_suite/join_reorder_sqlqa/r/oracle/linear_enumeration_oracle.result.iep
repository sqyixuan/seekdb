RIGHT JOIN b1 ON b1.id=3 INNER JOIN c1 ON c1.id=d2.id INNER JOIN d1 ON d1.id=d2.id LEFT JOIN a2 ON a2.id=4 LEFT JOIN a3 ON a3.id=2 INNER JOIN b3 ON b3.id<a3.id+a2.id
START WITH b3.id=1 CONNECT BY NOCYCLE PRIOR a1.id!=b2.id
