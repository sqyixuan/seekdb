FROM a4 FULL JOIN (a2 NATURAL JOIN b3) ON 1=1 FULL JOIN b1 ON 1=1 INNER JOIN c1 ON 1=1 RIGHT JOIN (a1 LEFT JOIN a3 ON 1=1) ON 1=1
CROSS JOIN d1 FULL JOIN a5 ON 1=1 INNER JOIN b4 ON 1=1 INNER JOIN b2 ON 1=1 RIGHT JOIN b5 ON 1=1
