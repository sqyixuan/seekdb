FULL JOIN c1 ON b1.id=c1.id INNER JOIN d1 ON c1.id!=d1.id RIGHT JOIN a3 ON d1.id=a3.id INNER JOIN b3 ON a3.id=b3.id RIGHT JOIN c3 ON b3.id=c3.id LEFT JOIN d3 ON c3.id=a2.id
