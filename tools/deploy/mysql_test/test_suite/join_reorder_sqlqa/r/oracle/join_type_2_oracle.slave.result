SELECT /*+ leading(c5 c2 c1) */ c1.id,c2.id,c3.id,c4.id,c5.id FROM c3 FULL OUTER JOIN c2 ON c3.id=c2.id FULL OUTER JOIN c4 ON c4.id=c3.id FULL OUTER JOIN c5 ON c5.id=c4.id FULL OUTER JOIN c1 ON c3.id=c5.id WHERE c1.id!=c2.id AND c2.id<3 ORDER BY 1,2,3,4,5;
