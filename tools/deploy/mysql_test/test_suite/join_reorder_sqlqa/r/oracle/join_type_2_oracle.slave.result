SELECT d1.id,d2.id,d3.id,d4.id,d5.id FROM (d2 FULL OUTER JOIN d4 ON d2.id=d4.id FULL OUTER JOIN d3 ON d2.id=d4.id) FULL OUTER JOIN d1 ON d1.id=1 AND d1.id+d2.id=d3.id+d4.id FULL OUTER JOIN d5 ON d3.id=d5.id WHERE d2.id<2 OR d2.id IS NULL ORDER BY 1,2,3,4,5;
