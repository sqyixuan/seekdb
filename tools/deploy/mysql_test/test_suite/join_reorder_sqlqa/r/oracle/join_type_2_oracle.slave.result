EXPLAIN SELECT /*+ leading(a3 a4 a1) */ a1.id,a2.id,a3.id,a4.id,a5.id FROM a1 FULL OUTER JOIN a2 ON a1.id>0 FULL OUTER JOIN (a3 FULL OUTER JOIN a4 ON a3.id<a4.id) ON 1=1 FULL OUTER JOIN a5 ON a5.id=a1.id+a4.id WHERE a1.id=a2.id+a3.id AND a2.id=a3.id ORDER BY 1,2,3,4,5;
