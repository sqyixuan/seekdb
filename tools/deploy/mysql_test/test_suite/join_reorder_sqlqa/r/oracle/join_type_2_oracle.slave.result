FROM (a2 FULL OUTER JOIN b2 ON 1=1 FULL OUTER JOIN c2 ON a2.id=b2.id) FULL OUTER JOIN d2 ON c2.id=d2.id FULL OUTER JOIN c3 ON c3.id=c2.id FULL OUTER JOIN 
