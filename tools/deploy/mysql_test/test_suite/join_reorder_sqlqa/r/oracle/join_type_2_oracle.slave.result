SELECT /*+ ordered */ d1.id,d2.id,d3.id FROM d3 FULL OUTER JOIN d2 ON d3.id=1 FULL OUTER JOIN d1 ON d2.id=1 WHERE 1=1 ORDER BY 1,2,3;
ID	ID	ID
