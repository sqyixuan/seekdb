SELECT /*+ leading(b1 c1 d1) */ a1.id,b1.id,c1.id,d1.id,d2.id,a2.id FROM (a1 FULL OUTER JOIN b1 ON a1.id=1) FULL OUTER JOIN (c1 FULL OUTER JOIN d1 ON d1.id=1) ON c1.id=1 FULL OUTER JOIN d2 ON d2.id=1 FULL OUTER JOIN a2 ON a2.id=1 WHERE d2.id=2 OR d2.id IS NULL ORDER BY 1,2,3,4,5,6;
ID	ID	ID	ID	ID	ID
NULL	NULL	NULL	NULL	2	1
NULL	NULL	NULL	NULL	NULL	1
NULL	NULL	NULL	NULL	NULL	2
NULL	NULL	NULL	NULL	NULL	3
NULL	NULL	NULL	NULL	NULL	4
NULL	NULL	NULL	NULL	NULL	5
NULL	NULL	NULL	NULL	NULL	NULL
EXPLAIN SELECT /*+ leading(a3 a5) */ a1.id,a2.id,a3.id,a4.id,a5.id FROM a3 FULL OUTER JOIN a2 ON a3.id=a2.id FULL OUTER JOIN a1 ON a2.id+a1.id>a3.id FULL OUTER JOIN a4 ON a4.id=a2.id FULL OUTER JOIN a5 ON a5.id=a2.id AND a5.id<a1.id WHERE lnnvl(a4.id>=2) ORDER BY 1,2,3,4,5;
