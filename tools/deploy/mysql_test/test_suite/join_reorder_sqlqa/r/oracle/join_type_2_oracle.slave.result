SELECT c1.id,c2.id,c3.id,c4.id,c5.id FROM c5 FULL OUTER JOIN (c2 FULL OUTER JOIN c4 ON c2.id=c4.id FULL OUTER JOIN c3 ON c2.id=c4.id) ON c3.id=c5.id FULL OUTER JOIN c1 ON c1.id=1 AND c1.id+c2.id=c3.id+c4.id WHERE lnnvl(c5.id>=2) ORDER BY 1,2,3,4,5;
