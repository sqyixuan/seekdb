drop database if exists wf;
create database wf;
use wf;
create table t1(c1 varchar(100), c2 int);
insert into t1 values('a', 1), ('aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa', 2);
select sum(c2) over (partition by c1) from t1;
sum(c2) over (partition by c1)
1
2
drop table if exists t1;
create table t1(a int, b int, c decimal(10,2) DEFAULT NULL);
insert into t1 values (1, 1, 1.11),(2,2,2.22);
select * from (select min(c) over() as min, c from t1) as V where V.c  = V.min;
min	c
1.11	1.11
create table t(a int, b int);
SELECT a, b, SUM(1+SUM(a+b) OVER()) OVER () AS sum FROM t;
ERROR HY000: Invalid use of window function
drop database if exists wf;
