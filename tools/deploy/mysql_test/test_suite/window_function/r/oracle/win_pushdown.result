      win_expr(T_FUN_COUNT(1)), partition_by([t2.a], [t2.b]), order_by(nil), window_type(RANGE), upper(UNBOUNDED PRECEDING), lower(UNBOUNDED FOLLOWING)
  3 - output([t2.a], [t2.b], [t2.c]), filter(nil), 
