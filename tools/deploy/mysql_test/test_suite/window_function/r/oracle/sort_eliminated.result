  2 - output([t1.c1], [t1.c2], [t1.c3]), filter(nil), 
      access([t1.c1], [t1.c2], [t1.c3]), partitions(p0)

create table table_history(tenant_id int, table_id int, schema_version int, table_name varchar(50), primary key(tenant_id, table_id, schema_version)) partition by hash(tenant_id) partitions 8;
explain select *, row_number() over w as rn from
(select * from table_history where tenant_id = 1 and table_id < 1099511627777 order by table_id desc, schema_version desc limit 100)
window w as (partition by table_id order by schema_version desc);
Query Plan
==========================================================
|ID|OPERATOR       |NAME                  |EST. ROWS|COST|
----------------------------------------------------------
|0 |WINDOW FUNCTION|                      |1        |36  |
|1 | SUBPLAN SCAN  |                      |1        |36  |
|2 |  TABLE SCAN   |table_history(Reverse)|1        |36  |
==========================================================

Outputs & filters: 
-------------------------------------
  0 - output([.tenant_id], [.table_id], [.schema_version], [.table_name], [T_WIN_FUN_ROW_NUMBER()]), filter(nil), 
      win_expr(T_WIN_FUN_ROW_NUMBER()), partition_by([.table_id]), order_by([.schema_version, DESC]), window_type(RANGE), upper(UNBOUNDED PRECEDING), lower(UNBOUNDED FOLLOWING)
  1 - output([.table_id], [.schema_version], [.tenant_id], [.table_name]), filter([.tenant_id = 1]), 
      access([.table_id], [.schema_version], [.tenant_id], [.table_name])
  2 - output([table_history.tenant_id], [table_history.table_id], [table_history.schema_version], [table_history.table_name]), filter(nil), 
      access([table_history.tenant_id], [table_history.table_id], [table_history.schema_version], [table_history.table_name]), partitions(p1), 
      limit(100), offset(nil)

