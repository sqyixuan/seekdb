set @@recyclebin = off;
drop database if exists nijia;
create database nijia;
use nijia;
create table t1(c1 int, c2 int, c3 int, primary key(c1, c2));
insert into t1 values (1,1,1);
insert into t1 values (1,2,2);
insert into t1 values (2,1,1);
insert into t1 values (1,3,2);
insert into t1 values (3,1,5);
explain select sum(c1) over (order by c1,c2) from t1;
Query Plan
========================================
|ID|OPERATOR       |NAME|EST. ROWS|COST|
----------------------------------------
|0 |WINDOW FUNCTION|    |5        |38  |
|1 | TABLE SCAN    |t1  |5        |37  |
========================================

Outputs & filters: 
-------------------------------------
  0 - output([T_FUN_SUM(t1.c1)]), filter(nil), 
      win_expr(T_FUN_SUM(t1.c1)), partition_by(nil), order_by([t1.c1, ASC], [t1.c2, ASC]), window_type(RANGE), upper(UNBOUNDED PRECEDING), lower(CURRENT ROW)
  1 - output([t1.c1], [t1.c2]), filter(nil), 
      access([t1.c1], [t1.c2]), partitions(p0)

