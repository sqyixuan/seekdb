drop table if exists test;
create table test(a int, b int, c decimal(10,2) DEFAULT NULL);
insert into test values (1, 1, 1.11),(2,2,2.22);
select * from (select count(c) over() as v, c from test) as V where V.c  = V.v;
v	c
select * from (select sum(c) over() as v, c from test) as V where V.c  = V.v;
v	c
select * from (select avg(c) over() as v, c from test) as V where V.c  = V.v;
v	c
select * from (select min(c) over() as v, c from test) as V where V.c  = V.v;
v	c
1.11	1.11
select * from (select max(c) over() as v, c from test) as V where V.c  = V.v;
v	c
2.22	2.22
select * from (select group_concat(c) over() as v, c from test) as V where V.c  = V.v;
v	c
1.11,2.22	1.11
