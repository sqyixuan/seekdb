drop database if exists wf;
create database wf;
use wf;
create table t1(a int primary key, b int, c varchar(20), d int);
select sum(1) over() from t1;
sum(1) over()
select count(1) over() from t1;
count(1) over()
select min(1) over() from t1;
min(1) over()
select max(1) over() from t1;
max(1) over()
select avg(1) over() from t1;
avg(1) over()
select group_concat(1) over() from t1;
group_concat(1) over()
select listagg(1) over() from t1;
listagg(1) over()
select first_value(1) over() from t1;
first_value(1) over()
select last_value(1) over() from t1;
last_value(1) over()
select nth_value(a, 1) over() from t1;
nth_value(a, 1) over()
drop database if exists wf;
