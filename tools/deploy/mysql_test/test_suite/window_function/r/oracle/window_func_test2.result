| colq5 | total_row_cnt |
+-------+---------------+
+-------+---------------+

#tkoqpdml.sql
create table talx1(a number, c number) ;
create table talx2(a number, d number, e number, f number);
create index ialx2 on talx2(d, a, e) ;
create table talx3(f number);
create table talx4(a number, b number);

insert /*+ parallel(8) */ into talx4
select x.a, y.a from
(select a
   from (select distinct a , sum(c) over (partition by a) from talx1)) x
left join
(select /*+ use_hash(p) */ o.a
   from talx1 o, talx2 p, talx3 q
  where p.a = o.a and p.d < 10 and q.f = p.f) y
on x.a = y.a;

#tkoqpjp2.sql
SELECT last_name
FROM departments d,
     (SELECT ROW_NUMBER() over (partition by department_id
                                order by employee_id) as R,
             department_id, last_name FROM employees) v
WHERE R BETWEEN 1 and 5
  AND d.department_id = v.department_id
  AND department_name in ('Sales');
