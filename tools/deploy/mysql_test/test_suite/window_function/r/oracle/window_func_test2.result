#tkoqdism.sql
CREATE TABLE TEST_SOURCE
(CONT_EVENT_INST_ITEM_ID NUMBER(38, 0) NOT NULL  ,
 CONTRACT_EVENT_INSTANCE_ID NUMBER(38, 0) NOT NULL  ,
 CONT_EVNT_INST_ITM_REF_ID VARCHAR(65) NOT NULL  ,
 CONT_EVNT_INST_ITM_REF_TYPE_ID NUMBER(4, 0) NOT NULL  ,
 GL_PRODUCT_GROUP NUMBER(4, 0),
 QUANTITY NUMBER(10, 0),
 CREATED_BY VARCHAR(8) NOT NULL  ,
 CREATION_DATE DATE NOT NULL  ,
 LAST_UPDATED_BY VARCHAR(8) NOT NULL,
 LAST_UPDATED_DATE DATE NOT NULL  ,
 LAST_UPDATED DATE NOT NULL  ,
 DW_LAST_UPDATED DATE NOT NULL  ,
 DW_CREATION_DATE DATE NOT NULL  );

SELECT CONT_EVENT_INST_ITEM_ID,
CONTRACT_EVENT_INSTANCE_ID,
LAST_UPDATED_DATE,
CREATION_DATE,
CONT_EVNT_INST_ITM_REF_TYPE_ID,
CREATED_BY,
GL_PRODUCT_GROUP,
LAST_UPDATED_BY,
DW_CREATION_DATE,
LAST_UPDATED,
CONT_EVNT_INST_ITM_REF_ID,
QUANTITY,
DW_LAST_UPDATED,
row_number () over (partition by CONT_EVENT_INST_ITEM_ID
order by DW_DEDUP_LAST_UPDATED desc) as DW_DEDUP_COL
FROM (SELECT
CONT_EVENT_INST_ITEM_ID AS CONT_EVENT_INST_ITEM_ID,
CONTRACT_EVENT_INSTANCE_ID AS CONTRACT_EVENT_INSTANCE_ID,
LAST_UPDATED_DATE AS LAST_UPDATED_DATE,
CREATION_DATE AS CREATION_DATE,
CONT_EVNT_INST_ITM_REF_TYPE_ID AS CONT_EVNT_INST_ITM_REF_TYPE_ID,
SUBSTR(CREATED_BY, 1, 8) AS CREATED_BY,
GL_PRODUCT_GROUP AS GL_PRODUCT_GROUP,
SUBSTR(LAST_UPDATED_BY, 1, 8) AS LAST_UPDATED_BY,
1 AS DW_CREATION_DATE,
LAST_UPDATED AS LAST_UPDATED,
SUBSTR(CONT_EVNT_INST_ITM_REF_ID, 1, 65) AS CONT_EVNT_INST_ITM_REF_ID,
QUANTITY AS QUANTITY,
11 AS DW_LAST_UPDATED,
LAST_UPDATED AS DW_DEDUP_LAST_UPDATED
FROM TEST_SOURCE) foo2 ;
