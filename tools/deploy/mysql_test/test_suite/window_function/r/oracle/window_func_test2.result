create table pat1 (dim_1 number, dim_2 number, dim_3 number, val number);
create table pat2 (dim_1 number, dim_2 number, dim_3 number, val number);

insert into pat1 values(1, 1, 2, 10);
insert into pat1 values(1, 5, 3, 50);
insert into pat2 values(1, 1, 2, 10);
insert into pat2 values(1, 5, 3, 50);
insert into pat1 values(2, 2, 4, 10);
insert into pat1 values(2, 7, 3, 50);
insert into pat2 values(2, 2, 4, 10);
insert into pat2 values(2, 7, 3, 50);
commit;

create view pat_v1
as
select dim_1, dim_2, dim_3,
       sum(val) over(partition by dim_1
                     order by dim_2
                     rows between 1 preceding and 1 preceding) pred_val
from pat1
union all
select dim_1, dim_2, dim_3,
       sum(val) over(partition by dim_2
                     order by dim_1
                     rows between 1 preceding and 1 preceding) pred_val
from pat2;
