#tkoqcard.sql
create table fact(id int, mo int);
create table dim(id int);


create procedure insert_p3()
begin
declare i int;
set i = 1;
while i <= 1001 do
insert into fact values (i, mod(i, 100));
insert into dim values (i);
set i = i + 1;
end while;
end
//

call insert_p3();

select id
from
 (
 select id, row_number() over (order by id) as rn
 from dim d
 )
 join
 fact using (id)
 where rn < 10;
