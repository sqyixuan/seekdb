#tkoqcgbpg.sql
create  table t19452473(
tracking_number varchar(20),
charge_category_code varchar(20),
billed_weight float);

select /*+no_merge(ups2) */
ups2.billed_weight as billed_weight
from
    (select distinct tracking_number
                    ,case
                       when
                           first_value(charge_category_code)
                           over (partition by tracking_number
                                 order by charge_category_code
                                ) = 'ADJ'
                       then max(billed_weight)
                            over (partition by tracking_number)
                       else max(billed_weight)
                            over (partition by tracking_number)
                       end as billed_weight
     from t19452473
    ) ups2
;
+---------------+
| billed_weight |
+---------------+
+---------------+

drop table t19452473;
tkoqcqtb.sql
select 1
from (select 'a' text
      union all
      select 'a' text ) x,
     (select 1 text
      union all
      select text
      from (select 'a' text, 0
            union all
            select 'a' text, row_number() over (order by 0)
            )) y
where y.text=x.text;
+---+
| 1 |
+---+
| 1 |
| 1 |
| 1 |
| 1 |
+---+

create table EMP (
  EMPno  number,
  ENAME varchar(30),
  JOB varchar(30),
  MGR number(4),
  HIREDATE date,
  SAL number(7,2),
  COMM number(7,2),
  DEPTNO number(2)
) ;

