#tkoqfidx.sql
create table pat (a number not null, b number, c number, d date not null);


create procedure insert_p12()
begin
  declare i int;
  declare j int;
    set i = 1;
    set j = 1;
while i <= 10 do
while j <= 3 do
insert into pat values (j,i,j,'2010-1-12');
insert into pat values (j,i,j,'2010-2-12');
insert into pat values (j,i,j,'2010-3-12');
set j = j + 1;
end while;
set i = i + 1;
end while;
end
//

call insert_p12();

