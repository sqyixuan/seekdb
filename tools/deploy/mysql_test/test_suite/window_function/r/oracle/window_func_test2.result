CREATE TABLE COMPL
(
  FIN         NUMBER(22,6)            NOT NULL
);

CREATE TABLE BRIS
(
  NUM_PARTN           NUMBER(1)                 NOT NULL,
  VAL                 NUMBER(6)                 NOT NULL
);

CREATE TABLE ACTLS
(
  IDE         NUMBER(22,6)            NOT NULL,
  DAT_EFFCT   DATE                    NOT NULL
);

INSERT INTO compl (fin)
 (SELECT g_i.ide
  FROM (SELECT g_d.ide
        FROM (SELECT date'2018-10-10' dat,
                     CASE WHEN s.val > 1 THEN (0) ELSE (0) END fin
              FROM (SELECT ROW_NUMBER() OVER (ORDER BY 'N') no_line,
                     bris.val val
                    FROM bris) s
              WHERE ( s.no_line = 1 ) ) g,
            (SELECT act.ide, act.dat_effct
             FROM actls act)  g_d
        WHERE ( g.dat >= g_d.dat_effct (+) ) ) g_i ) ;
drop table compl;
drop table bris;
drop table actls;

create or replace view valx as
select  1 rn,  4 i  from dual union all
select  2 rn,  5 i  from dual;

create table talx(rn int, i int);
insert into talx values(1,4);
insert into talx values(2,5);
commit;


drop table talx;
drop view valx;

drop table talx1,talx2;
create table talx1 (a number, b number, c number, val number);
create table talx2 (a number, b number, c number, val number);

insert into talx1 values(1, 2, 2, 1);
insert into talx1 values(1, 2, 3, 4);
insert into talx1 values(1, 2, 2, 7);
insert into talx1 values(1, 2, 3, 5);
insert into talx2 values(1, 2, 2, 1);
insert into talx2 values(1, 2, 3, 2);
insert into talx2 values(1, 2, 2, 3);
insert into talx2 values(1, 2, 3, 4);

select * from (
select a, b, c,
       sum(val) over(partition by a, c) sum
from talx1
union all
select a, b, c,
       sum(val) over(partition by a, b) sum
from talx2)
where a = 1 and b = 2 order by a, b, sum, c;
