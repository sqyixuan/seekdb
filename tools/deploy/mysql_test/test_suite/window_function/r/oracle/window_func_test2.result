select  channel_id,
        lag(channel_id) over (partition by channel_id order by channel_id)
as lag_sales,
        lead(channel_id) over (partition by channel_id order by channel_id)
as lead_sales,
        first_value(channel_id) over (partition by channel_id order by
channel_id)  as fv_sales,
        last_value(channel_id) over (partition by channel_id order by
channel_id)  as lv_sales
from sales
group by channel_id
order by channel_id;
