| last_name |
+-----------+
| Russell   |
| Partners  |
| Errazuriz |
| Cambrault |
| Zlotkey   |
+-----------+

create table sales(channel_id int, CUST_ID int);


create procedure insert_ptop3()
begin
  declare i int;
    set i = 0;
    while i < 999 do
    insert into sales values (mod(i, 70), mod(i, 140));
    set i = i + 1;
    end while;
end
//
call insert_ptop3;

#tkoqsrbg3.sql
create table o(o1 number not null, o2 varchar(5), o3 varchar(5));
insert into o values(1, 'x', 'y');
create table b(b1 number not null);
insert into b values(2);
create unique index bpk on b(b1);
create table l(l1 number not null, l2 varchar(5), l3 varchar(5));
insert into l values(3, 'z', 'w');
create table c(c1 number, c2 number, c3 number);
insert into c values(2, 3, 1);
create index ci1 on c(c1);
create index ci2 on c(c2);
create table d(d1 number, d2 number, d3 number);
insert into d values(2, 1, 3);

select /*+ STAR_TRANSFORMATION(c SUBQUERIES(TEMP_TABLE(d l o) (l))) */
       l2, row_number() over (partition by min(l2) order by min(l2))
  from o, b, l, c, d
 where c1 = d1 and o1 = c3 and o1 = d2 and c1 = b1 and c2 = l1
   and b1 = d1 and d3 = l1 and o2 = 'x' and o3 = 'y' and l3 = 'w'
 group by l2;
+------+-----------------------------------------------------------+
| l2   | row_number() over (partition by min(l2) order by min(l2)) |
+------+-----------------------------------------------------------+
| z    |                                                         1 |
+------+-----------------------------------------------------------+

select /*+ STAR_TRANSFORMATION(c SUBQUERIES(TEMP_TABLE(d l o) (l))) */
       l2, row_number() over (partition by min(l2||'x') order by min(l2||'x'))
  from o, b, l, c, d
 where c1 = d1 and o1 = c3 and o1 = d2 and c1 = b1 and c2 = l1
   and b1 = d1 and d3 = l1 and o2 = 'x' and o3 = 'y' and l3 = 'w'
 group by l2;
+------+---------------------------------------------------------------------+
| l2   | row_number() over (partition by min(l2||'x') order by min(l2||'x')) |
+------+---------------------------------------------------------------------+
| z    |                                                                   1 |
+------+---------------------------------------------------------------------+

drop table o;
drop table b;
drop table l;
drop table c;
drop table d;

#tkoqsrbg4.sql
create table t10066495(idh number not null);
create or replace view v10066495 as
select idh from t10066495;

create table dim2_10066495
(idh number not null,
 id number not null,
 d_eff_to date not null,
 d_eff_from date not null,
 rfr_id number);

select idh as idh,
       rfr_id as rfr_id,
       case
           when max (d_eff_to) over (partition by id) < date'2018-10-10'
           then 'y'
           when date'2018-10-10' between d_eff_from and d_eff_to
           then 'y'
           else 'n'
       end as actual_record
from dim2_10066495;
