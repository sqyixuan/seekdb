#tkoqjois.sql
select /*+ NO_PARALLEL */ B.DEPTNO, B.SAL, SUM(0) OVER(partition by B.SAL)
       Total_Sal
from ( select A.DEPTNO, A.SAL, row_number() over (partition by A.SAL
              order by A.DEPTNO) row_num
       from ( select DEPT_TEMP.DEPTNO, EMP.SAL
              from (select DEPTNO
                    from DEPT) DEPT_TEMP
              left outer join EMP
              on (DEPT_TEMP.DEPTNO*10=EMP.DEPTNO)
              where EMP.MGR > 1
                and EMP.HIREDATE > DATE('0080-12-13')
            ) A
      ) B
where B.SAL > 400
order by B.DEPTNO, B.SAL;
