#tkoqatopa.sql
select deptno, job, job_cnt, sal_sum
   from
   ( select deptno, job, count(job) job_cnt, sum(sal) sal_sum,
     rank() over (partition by deptno order by count(job) desc) cnt_rank,
     rank() over (partition by deptno order by sum(sal) desc) sum_rank
     from emp
     group by deptno,job
   )
   where cnt_rank <=10 and sum_rank <= 500;
+--------+-----------+---------+---------+
| deptno | job       | job_cnt | sal_sum |
+--------+-----------+---------+---------+
|     10 | PRESIDENT |       1 | 5000.00 |
|     10 | MANAGER   |       1 | 2450.00 |
|     10 | CLERK     |       1 | 1300.00 |
|     20 | ANALYST   |       2 | 6000.00 |
|     20 | MANAGER   |       1 | 2975.00 |
|     20 | CLERK     |       2 | 1900.00 |
|     30 | SALESMAN  |       4 | 5600.00 |
|     30 | MANAGER   |       1 | 2850.00 |
|     30 | CLEARK    |       1 |  950.00 |
+--------+-----------+---------+---------+

#tkoqview.sql part2
create table TCol (TName varchar(5), CName varchar(5),
  constraint TPK primary key (TName, CName));
insert into tcol values ('T1', 'C1');
insert into tcol values ('T1', 'C2');
insert into tcol values ('T1', 'C3');
insert into tcol values ('T2', 'C1');
insert into tcol values ('T2', 'C2');
insert into tcol values ('T2', 'C3');

Select *
From (
  Select TName, Min (CName) Over (Partition By TName) Min_Col From TCol
  Union All
  Select TName, Min (CName) Over (Partition By TName) Min_Col From TCol )
Where TName='T2';
+-------+---------+
| TName | Min_Col |
+-------+---------+
| T2    | C1      |
| T2    | C1      |
| T2    | C1      |
| T2    | C1      |
| T2    | C1      |
| T2    | C1      |
+-------+---------+

drop table TCol;

create table t_6020789_1
(
  sgb_sgbc varchar(7) not null,
  sgb_tkymd date not null,
  sgb_tsymd date not null,
  sgb_btbkb varchar(1),
  primary key (sgb_sgbc, sgb_tkymd, sgb_tsymd)
);
create table t_6020789_2
(
  krn_corp_cd varchar(6) not null,
  jgyin_bg varchar(3) not null,
  primary key (krn_corp_cd, jgyin_bg)
);
create table t_6020789_3
(
  thsk_id varchar(9) not null,
  cnvs_cd varchar(5) not null,
  cnvs_nen varchar(4) not null,
  hnbi_rcd_bg varchar(2) not null,
  dtrk_ryu_sts varchar(2),
  kn_hnbi_gtgki number(14,0),
  kn_hnbi_sgki number(14,0),
  primary key (thsk_id, cnvs_cd, cnvs_nen, hnbi_rcd_bg)
);
create table t_6020789_4
(
  thsk_id varchar(9) not null,
  cnvs_cd varchar(5) not null,
  cnvs_nen varchar(4) not null,
  sy_cnvs_jsnen varchar(4) not null,
  kk_tubn varchar(3) not null,
  hnbi_rcd_bg varchar(2),
  udac_kk_sbt varchar(8),
  udac_prmtn varchar(2),
  udac_prmtn_hnk_ncj varchar(16),
  jhnbi_gtgk number(20,0),
  kknryk_sts_cd varchar(4),
  dtrk_ryu_sts varchar(2),
  kks_dwchhn_cd varchar(6),
  dwch_hko_ym varchar(6),
  kks_skg_bnri_cd varchar(7),
  cst_shkchsn_cd varchar(3),
  primary key (thsk_id, cnvs_cd, cnvs_nen, sy_cnvs_jsnen, kk_tubn)
);
create table t_6020789_5
(
  thsk_id varchar(9) not null,
  thsk_syskg_bnri_cd varchar(7),
  primary key (thsk_id)
);
create index i_6020789_1 on t_6020789_4
(cnvs_cd, cnvs_nen, thsk_id, kknryk_sts_cd, dtrk_ryu_sts);
create index i_6020789_2 on t_6020789_4 (udac_kk_sbt);
create index i_6020789_3 on t_6020789_4
(dwch_hko_ym, kks_dwchhn_cd, dtrk_ryu_sts, jhnbi_gtgk);
create index i_6020789_4 on t_6020789_4 (kks_skg_bnri_cd);
create index i_6020789_5 ON t_6020789_4 (kks_dwchhn_cd, dwch_hko_ym);
select min(t1.udac_kk_sbt) over (partition by t1.cnvs_cd,
 t1.cnvs_nen, t1.thsk_id, t1.udac_kk_sbt, t1.udac_prmtn, t1.kks_dwchhn_cd,
 t1.dwch_hko_ym, t1.kks_skg_bnri_cd, t2.sgb_btbkb) c16
 from ((( select  tbl5.thsk_id thsk_id,
 tbl5.thsk_syskg_bnri_cd thsk_syskg_bnri_cd,
 date'2018-10-10' system_jikoku from t_6020789_5 tbl5
 where substr(tbl5.thsk_id,1 ,1) in ('G') or tbl5.thsk_id=tbl5.thsk_id)
 tbl5 left outer join ( select /*+ no_merge */ tbl3.thsk_id thsk_id,
 tbl3.cnvs_cd cnvs_cd, tbl3.cnvs_nen cnvs_nen, tbl3.hnbi_rcd_bg hnbi_rcd_bg,
 tbl3.kn_hnbi_gtgki kn_hnbi_gtgki, tbl3.kn_hnbi_sgki kn_hnbi_sgki from
 t_6020789_3 tbl3 where substr(tbl3.thsk_id,1 ,1) in ('G')
 or tbl3.thsk_id=tbl3.thsk_id) tbl3 on tbl5.thsk_id=tbl3.thsk_id)
 left outer join ( select  /*+ no_merge push_pred */ t1.thsk_id thsk_id,
 t1.cnvs_cd cnvs_cd, t1.cnvs_nen cnvs_nen, t1.hnbi_rcd_bg hnbi_rcd_bg,
 t1.udac_kk_sbt udac_kk_sbt, t1.udac_prmtn udac_prmtn,
 t1.kknryk_sts_cd kknryk_sts_cd, t1.dtrk_ryu_sts dtrk_ryu_sts,
 t1.kks_dwchhn_cd kks_dwchhn_cd, t1.dwch_hko_ym dwch_hko_ym,
 t1.kks_skg_bnri_cd kks_skg_bnri_cd from t_6020789_4 t1 where
 substr(t1.thsk_id,1 ,1) in ('G') or t1.thsk_id=t1.thsk_id) t1
 on tbl3.thsk_id=t1.thsk_id and tbl3.cnvs_cd=t1.cnvs_cd and
 tbl3.cnvs_nen=t1.cnvs_nen and tbl3.hnbi_rcd_bg=t1.hnbi_rcd_bg)
 left outer join t_6020789_1 T2 on tbl5.thsk_syskg_bnri_cd=t2.sgb_sgbc
 and  tbl5.system_jikoku >=
  t2.sgb_tkymd
 and  tbl5.system_jikoku <=
  T2.SGB_TSYMD
 where substr(t1.kknryk_sts_cd, 2, 1) in ('2', '4')
 and t1.dtrk_ryu_sts='  ' and t1.cnvs_cd in ('C3301') and t1.cnvs_nen in ('2007')
;
+------+
| c16  |
+------+
+------+
