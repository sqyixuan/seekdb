create table DEPT(
  DEPTNO integer,
  DNAME char(45),
  loc varchar(10)
) ;
insert into DEPT values (0, 'A', 'xx');
insert into DEPT values (1, 'B', 'yy');
insert into DEPT values (2, 'C', 'zz');
insert into DEPT values (3, 'D', 'mm');
insert into DEPT values (4, 'E', 'nn');
insert into DEPT values (5, 'F', 'oo');

select /*+ PUSH_PRED (v) */ d.*, v.*
from dept d,
     (select e.deptno,
             SUM(e.sal) OVER (PARTITION BY e.deptno) AS MAX_DEPT_SALES
      from emp e
      ) v
where d.dname = 'C'
and d.deptno * 10 = v.deptno;
+--------+-------+------+--------+----------------+
| DEPTNO | DNAME | loc  | deptno | MAX_DEPT_SALES |
+--------+-------+------+--------+----------------+
