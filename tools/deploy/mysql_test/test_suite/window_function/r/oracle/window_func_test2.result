#tkoqatop1.sql
#tkoqatop3.sql
select  channel_id,
        lag(channel_id) over (partition by channel_id order by channel_id)  as lag_sales,
        lead(channel_id) over (partition by channel_id order by channel_id)  as lead_sales,
        first_value(channel_id) over (partition by channel_id order by channel_id)  as fv_sales,
        last_value(channel_id) over (partition by channel_id order by channel_id)  as lv_sales,
        count(CUST_ID),
        sum(CUST_ID)
from sales
group by channel_id
having count(CUST_ID) < 15 and
       sum(CUST_ID) >1400 ;
+------------+-----------+------------+----------+----------+----------------+--------------+
| channel_id | lag_sales | lead_sales | fv_sales | lv_sales | count(CUST_ID) | sum(CUST_ID) |
