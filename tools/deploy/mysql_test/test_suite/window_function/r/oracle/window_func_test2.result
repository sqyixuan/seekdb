create table stock_overview_daily
 (  time_sid number,
    material_id varchar(25),
	map_flag varchar(15)
 );

create table active_items
 (    sku_no number,
      itemsource varchar(10),
      date_time date
 );

select *
from (select material_id,
max(case when map_flag = 'n' and pre_map_flag = 'y'
then str_to_date(time_sid,'yyyy-mm-dd') end) max_added_date
from (select material_id, map_flag, time_sid,
lag(map_flag,1) over(order by material_id,time_sid)
pre_map_flag
from (select  /*+ full(sod)*/ distinct material_id,
case when map_flag*1 > 0
then 'y' else 'n' end map_flag, time_sid
from stock_overview_daily sod
)
)
group by material_id
)
where exists (select 1 from active_items  web
                       where web. sku_no||'' = material_id);
+-------------+----------------+
| material_id | max_added_date |
+-------------+----------------+
+-------------+----------------+

