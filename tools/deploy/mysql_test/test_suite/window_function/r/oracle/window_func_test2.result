create table t1alx(a number, b number, c number);
create table t2alx(a number);
create table t3alx(a number, b number, c number);

insert into t1alx values(1,9,1);
insert into t1alx values(2,9,1);

insert into t2alx values(1);
insert into t2alx values(2);
insert into t2alx values(2);

insert into t3alx values(1,9,14);

select t1.a, t3.b, t3.c, max(t3.c) over (partition by t3.a) max
  from t1alx t1, t3alx t3,
       (select distinct t1.c from t1alx t1, t2alx t2 where t1.a = t2.a) iv
 where t1.a = iv.c and t1.a = t3.a and t1.b = t3.b;
+------+------+------+------+
| a    | b    | c    | max  |
+------+------+------+------+
|    1 |    9 |   14 |   14 |
+------+------+------+------+

select t1.a, t3.b, t3.c, max(t3.c) over (partition by t3.a) max
  from t1alx t1, t3alx t3,
       (select distinct t1.c from t1alx t1, t2alx t2 where t1.a = t2.a) iv
 where t1.a = iv.c and t1.a = t3.a and t1.b = t3.b;
+------+------+------+------+
| a    | b    | c    | max  |
+------+------+------+------+
|    1 |    9 |   14 |   14 |
+------+------+------+------+

