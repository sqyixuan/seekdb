vtmp.*, max(rownum) over() total_row_cnt
from (select  ord.colq5
      from t2_11905801 t,
           t2_11905801 tst,
           t1_11905801 ord,
           t1_11905801 pat
      where
          ord.colq0 = t.colq1
          and ord.colq2 = t.colq2
          and tst.col34 = t.col34
          and ord.colq3 = pat.colq3
          and not exists
        (select 1 from t2_11905801 otest,
                       t2_11905801 test
                where otest.colq4 = test.colq4
                      and otest.colq1 = t.colq1
        )
          and ord.colq2 >= 110000001
          and ord.colq2 <= 110002108
                  ) vtmp
;
