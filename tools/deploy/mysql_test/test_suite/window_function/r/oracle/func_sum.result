select sum(1) over (order by c2 rows between 1 preceding and 2 preceding) from t1 where c1 = 1;
+--------------------------------------------------------------------+
| sum(1) over (order by c2 rows between 1 preceding and 2 preceding) |
+--------------------------------------------------------------------+
|                                                               NULL |
+--------------------------------------------------------------------+
select sum(c2) over (), sum(distinct c2) over () from t1 where c1 in (4,5,6) order by c1;
+-----------------+--------------------------+
| sum(c2) over () | sum(distinct c2) over () |
+-----------------+--------------------------+
|               6 |                        3 |
|               6 |                        3 |
|               6 |                        3 |
+-----------------+--------------------------+
select sum(c4) over () from t1 where c1 = 1;
+-----------------+
| sum(c4) over () |
+-----------------+
|               0 |
