result_format: 3
set @@recyclebin = off;
drop table if exists t1;
create table t1 (c1 int primary key, c2 int, c3 int, c4 varchar(100));
insert into t1 values (1,1,3, 'fdsf');
insert into t1 values (2,2,2, '1fdfdsf');
insert into t1 values (3,2,1, 'kkkkk');
insert into t1 values (4,3,2, '8y77');
insert into t1 values (5,3,6, 'fdfd');
insert into t1 values (6,NULL,6, 'mnn');
insert into t1 values (7,4,2, '6fe');
insert into t1 values (8,4,1, 'kk');
insert into t1 values (9,4,1, 'kk');
insert into t1 values (10,4,3, 'kk');
select *, sum(c1) over (), sum(c1) over (partition by c1), sum(c1) over (partition by c2), sum(c1) over (partition by c4) from t1 order by c1;
+----+------+------+---------+-----------------+--------------------------------+--------------------------------+--------------------------------+
| c1 | c2   | c3   | c4      | sum(c1) over () | sum(c1) over (partition by c1) | sum(c1) over (partition by c2) | sum(c1) over (partition by c4) |
+----+------+------+---------+-----------------+--------------------------------+--------------------------------+--------------------------------+
|  1 |    1 |    3 | fdsf    |              55 |                              1 |                              1 |                              1 |
|  2 |    2 |    2 | 1fdfdsf |              55 |                              2 |                              5 |                              2 |
|  3 |    2 |    1 | kkkkk   |              55 |                              3 |                              5 |                              3 |
|  4 |    3 |    2 | 8y77    |              55 |                              4 |                              9 |                              4 |
|  5 |    3 |    6 | fdfd    |              55 |                              5 |                              9 |                              5 |
|  6 | NULL |    6 | mnn     |              55 |                              6 |                              6 |                              6 |
|  7 |    4 |    2 | 6fe     |              55 |                              7 |                             34 |                              7 |
|  8 |    4 |    1 | kk      |              55 |                              8 |                             34 |                             27 |
|  9 |    4 |    1 | kk      |              55 |                              9 |                             34 |                             27 |
| 10 |    4 |    3 | kk      |              55 |                             10 |                             34 |                             27 |
