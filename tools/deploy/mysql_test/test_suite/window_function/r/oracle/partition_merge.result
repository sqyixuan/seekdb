set @@recyclebin = off;
drop table if exists test,t1,empsalary;
create table test (c1 int primary key, c2 int, c3 int, c4 int, c5 int);
explain select *, sum(c1) over(partition by c2 order by c3), max(c1) over(partition by c2) from test;
Query Plan
========================================
|ID|OPERATOR       |NAME|EST. ROWS|COST|
----------------------------------------
|0 |WINDOW FUNCTION|    |1000     |2823|
|1 | SORT          |    |1000     |2632|
|2 |  TABLE SCAN   |test|1000     |499 |
========================================

Outputs & filters: 
-------------------------------------
  0 - output([test.c1], [test.c2], [test.c3], [test.c4], [test.c5], [T_FUN_SUM(test.c1)], [T_FUN_MAX(test.c1)]), filter(nil), 
      win_expr(T_FUN_SUM(test.c1)), partition_by([test.c2]), order_by([test.c3, ASC]), window_type(RANGE), upper(UNBOUNDED PRECEDING), lower(CURRENT ROW)
      win_expr(T_FUN_MAX(test.c1)), partition_by([test.c2]), order_by(nil), window_type(RANGE), upper(UNBOUNDED PRECEDING), lower(UNBOUNDED FOLLOWING)
  1 - output([test.c1], [test.c2], [test.c3], [test.c4], [test.c5]), filter(nil), sort_keys([test.c2, ASC], [test.c3, ASC])
  2 - output([test.c1], [test.c2], [test.c3], [test.c4], [test.c5]), filter(nil), 
      access([test.c1], [test.c2], [test.c3], [test.c4], [test.c5]), partitions(p0)

