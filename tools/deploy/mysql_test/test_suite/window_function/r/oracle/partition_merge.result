create table t1(c1 int, c2 int,c3 int);
insert into t1 values(1,1,1),(1,1,2),(1,2,3),(1,2,4);
select sum(1) over (partition by c1,c2,c3), sum(1) over(partition by c1,c2),  sum(1) over(partition by c1) from t1;
sum(1) over (partition by c1,c2,c3)	sum(1) over(partition by c1,c2)	sum(1) over(partition by c1)
1	2	4
1	2	4
1	2	4
1	2	4
CREATE TABLE empsalary (depname varchar(50), empno bigint, salary int, enroll_date date);
explain sELECT sum(salary), row_number() OVER (ORDER BY depname), sum(sum(salary)) OVER (ORDER BY depname DESC) FROM empsalary GROUP BY depname;
Query Plan
===============================================
|ID|OPERATOR         |NAME     |EST. ROWS|COST|
-----------------------------------------------
|0 |WINDOW FUNCTION  |         |500      |6658|
|1 | SORT            |         |500      |6563|
|2 |  WINDOW FUNCTION|         |500      |4300|
|3 |   SORT          |         |500      |4205|
|4 |    HASH GROUP BY|         |500      |1238|
|5 |     TABLE SCAN  |empsalary|1000     |499 |
===============================================

Outputs & filters: 
-------------------------------------
  0 - output([T_FUN_SUM(empsalary.salary)], [T_WIN_FUN_ROW_NUMBER()], [T_FUN_SUM(T_FUN_SUM(empsalary.salary))]), filter(nil), 
      win_expr(T_FUN_SUM(T_FUN_SUM(empsalary.salary))), partition_by(nil), order_by([empsalary.depname, DESC]), window_type(RANGE), upper(UNBOUNDED PRECEDING), lower(CURRENT ROW)
  1 - output([T_FUN_SUM(empsalary.salary)], [empsalary.depname], [T_WIN_FUN_ROW_NUMBER()]), filter(nil), sort_keys([empsalary.depname, DESC])
  2 - output([T_FUN_SUM(empsalary.salary)], [empsalary.depname], [T_WIN_FUN_ROW_NUMBER()]), filter(nil), 
      win_expr(T_WIN_FUN_ROW_NUMBER()), partition_by(nil), order_by([empsalary.depname, ASC]), window_type(RANGE), upper(UNBOUNDED PRECEDING), lower(UNBOUNDED FOLLOWING)
  3 - output([T_FUN_SUM(empsalary.salary)], [empsalary.depname]), filter(nil), sort_keys([empsalary.depname, ASC])
  4 - output([T_FUN_SUM(empsalary.salary)], [empsalary.depname]), filter(nil), 
      group([empsalary.depname]), agg_func([T_FUN_SUM(empsalary.salary)])
  5 - output([empsalary.salary], [empsalary.depname]), filter(nil), 
      access([empsalary.salary], [empsalary.depname]), partitions(p0)

