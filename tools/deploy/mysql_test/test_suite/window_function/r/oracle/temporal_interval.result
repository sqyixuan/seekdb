drop database if exists temporal;
create database temporal;
use temporal;
result_format: 3
create table t1(a int auto_increment primary key, b date);
insert into t1(b) values('2018-05-27' - interval 2 day);
insert into t1(b) values('2018-05-27');
insert into t1(b) values('2018-05-27');
insert into t1(b) values('2018-05-27' + interval 2 day);
select *, listagg(a) over (order by b range between interval 0 day preceding and interval 0 day following) from t1;
+---+------------+--------------------------------------------------------------------------------------------------+
| a | b          | listagg(a) over (order by b range between interval 0 day preceding and interval 0 day following) |
+---+------------+--------------------------------------------------------------------------------------------------+
| 1 | 2018-05-25 | 1                                                                                                |
| 2 | 2018-05-27 | 2,3                                                                                              |
| 3 | 2018-05-27 | 2,3                                                                                              |
| 4 | 2018-05-29 | 4                                                                                                |
+---+------------+--------------------------------------------------------------------------------------------------+
select *, listagg(a) over (order by b range between interval 1 day preceding and interval 2 day following) from t1;
+---+------------+--------------------------------------------------------------------------------------------------+
| a | b          | listagg(a) over (order by b range between interval 1 day preceding and interval 2 day following) |
+---+------------+--------------------------------------------------------------------------------------------------+
| 1 | 2018-05-25 | 1,2,3                                                                                            |
| 2 | 2018-05-27 | 2,3,4                                                                                            |
| 3 | 2018-05-27 | 2,3,4                                                                                            |
| 4 | 2018-05-29 | 4                                                                                                |
+---+------------+--------------------------------------------------------------------------------------------------+
select *, listagg(a) over (order by b range between interval 1 day preceding and interval 2 * 23 hour following) from t1;
+---+------------+--------------------------------------------------------------------------------------------------------+
| a | b          | listagg(a) over (order by b range between interval 1 day preceding and interval 2 * 23 hour following) |
+---+------------+--------------------------------------------------------------------------------------------------------+
| 1 | 2018-05-25 | 1                                                                                                      |
| 2 | 2018-05-27 | 2,3                                                                                                    |
| 3 | 2018-05-27 | 2,3                                                                                                    |
| 4 | 2018-05-29 | 4                                                                                                      |
+---+------------+--------------------------------------------------------------------------------------------------------+
select *, listagg(a) over (order by b range between interval 1 day preceding and interval 2 * 24 hour following) from t1;
+---+------------+--------------------------------------------------------------------------------------------------------+
| a | b          | listagg(a) over (order by b range between interval 1 day preceding and interval 2 * 24 hour following) |
+---+------------+--------------------------------------------------------------------------------------------------------+
| 1 | 2018-05-25 | 1,2,3                                                                                                  |
| 2 | 2018-05-27 | 2,3,4                                                                                                  |
| 3 | 2018-05-27 | 2,3,4                                                                                                  |
| 4 | 2018-05-29 | 4                                                                                                      |
+---+------------+--------------------------------------------------------------------------------------------------------+
select *, listagg(a) over (order by b range between interval 1 day preceding and interval 2 * 25 hour following) from t1;
+---+------------+--------------------------------------------------------------------------------------------------------+
| a | b          | listagg(a) over (order by b range between interval 1 day preceding and interval 2 * 25 hour following) |
+---+------------+--------------------------------------------------------------------------------------------------------+
| 1 | 2018-05-25 | 1,2,3                                                                                                  |
| 2 | 2018-05-27 | 2,3,4                                                                                                  |
| 3 | 2018-05-27 | 2,3,4                                                                                                  |
| 4 | 2018-05-29 | 4                                                                                                      |
+---+------------+--------------------------------------------------------------------------------------------------------+
drop table t1;
create table t1(a int auto_increment primary key, b datetime);
insert into t1(b) values('2018-05-27 10:10:10' - interval '2:2' MINUTE_SECOND);
insert into t1(b) values('2018-05-27 10:10:10' - interval '2:2' MINUTE_SECOND);
insert into t1(b) values('2018-05-27 10:10:10' - interval '2:1' MINUTE_SECOND);
insert into t1(b) values('2018-05-27 10:10:10' - interval '2:1' MINUTE_SECOND);
insert into t1(b) values('2018-05-27 10:10:10');
insert into t1(b) values('2018-05-27 10:10:10');
insert into t1(b) values('2018-05-27 10:10:10' + interval '2:1' MINUTE_SECOND);
insert into t1(b) values('2018-05-27 10:10:10' + interval '2:1' MINUTE_SECOND);
insert into t1(b) values('2018-05-27 10:10:10' + interval '2:2' MINUTE_SECOND);
insert into t1(b) values('2018-05-27 10:10:10' + interval '2:2' MINUTE_SECOND);
select *,
            listagg(a) over w1,
            listagg(a) over w2,
            listagg(a) over w3,
            listagg(a) over w4
     from t1
     window w as (order by b),
            w1 as (w range between interval '2:2' MINUTE_SECOND preceding and interval '2:2' MINUTE_SECOND following),
            w2 as (w range between interval '2:1' MINUTE_SECOND preceding and interval '2:1' MINUTE_SECOND following),
            w3 as (w range between interval '2:2' MINUTE_SECOND preceding and interval '2:1' MINUTE_SECOND following),
            w4 as (w range between interval '2:1' MINUTE_SECOND preceding and interval '2:2' MINUTE_SECOND following)
     ;
+----+---------------------+----------------------+--------------------+--------------------+--------------------+
| a  | b                   | listagg(a) over w1   | listagg(a) over w2 | listagg(a) over w3 | listagg(a) over w4 |
+----+---------------------+----------------------+--------------------+--------------------+--------------------+
