result_format: 3
set @@recyclebin = off;
drop table if exists t1;
create table t1 (c1 int primary key, c2 int, c3 int, c4 varchar(100));
insert into t1 values (1,1,3, 'fdsf');
insert into t1 values (2,2,2, '1fdfdsf');
insert into t1 values (3,2,1, 'kkkkk');
insert into t1 values (4,3,2, '8y77');
insert into t1 values (5,3,6, 'fdfd');
insert into t1 values (6,3,6, 'mnn');
insert into t1 values (7,4,2, '6fe');
insert into t1 values (8,4,NULL, 'kk');
insert into t1 values (9,4,1, 'kk');
insert into t1 values (10,4,3, 'kk');
select *, min(c1) over (), min(c1) over (partition by c1), min(c1) over (partition by c2), min(c1) over (partition by c4) from t1 order by c1;
+----+------+------+---------+-----------------+--------------------------------+--------------------------------+--------------------------------+
| c1 | c2   | c3   | c4      | min(c1) over () | min(c1) over (partition by c1) | min(c1) over (partition by c2) | min(c1) over (partition by c4) |
+----+------+------+---------+-----------------+--------------------------------+--------------------------------+--------------------------------+
|  1 |    1 |    3 | fdsf    |               1 |                              1 |                              1 |                              1 |
|  2 |    2 |    2 | 1fdfdsf |               1 |                              2 |                              2 |                              2 |
|  3 |    2 |    1 | kkkkk   |               1 |                              3 |                              2 |                              3 |
|  4 |    3 |    2 | 8y77    |               1 |                              4 |                              4 |                              4 |
|  5 |    3 |    6 | fdfd    |               1 |                              5 |                              4 |                              5 |
|  6 |    3 |    6 | mnn     |               1 |                              6 |                              4 |                              6 |
|  7 |    4 |    2 | 6fe     |               1 |                              7 |                              7 |                              7 |
|  8 |    4 | NULL | kk      |               1 |                              8 |                              7 |                              8 |
|  9 |    4 |    1 | kk      |               1 |                              9 |                              7 |                              8 |
| 10 |    4 |    3 | kk      |               1 |                             10 |                              7 |                              8 |
+----+------+------+---------+-----------------+--------------------------------+--------------------------------+--------------------------------+
select min(c1) over(order by c2 rows between 1 preceding and 2 preceding) from t1 where c1 = 1;
+--------------------------------------------------------------------+
| min(c1) over(order by c2 rows between 1 preceding and 2 preceding) |
+--------------------------------------------------------------------+
|                                                               NULL |
+--------------------------------------------------------------------+
select min(distinct c2) over(order by c2) from t1 where c1 in (4,5,6) order by c1;
+------------------------------------+
| min(distinct c2) over(order by c2) |
+------------------------------------+
|                                  3 |
|                                  3 |
|                                  3 |
+------------------------------------+
select min(c1) over () from t1 where c1 in (7,8);
+-----------------+
| min(c1) over () |
+-----------------+
|               7 |
|               7 |
+-----------------+
set @@recyclebin = off;
drop table t1;
