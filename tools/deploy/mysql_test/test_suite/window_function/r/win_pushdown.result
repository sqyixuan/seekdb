  2 - output([t1.a], [t1.b], [T_FUN_COUNT(1)], [T_FUN_COUNT(1)]), filter(nil)
  3 - output([t1.a], [t1.b], [T_FUN_COUNT(1)], [T_FUN_COUNT(1)]), filter(nil), 
      win_expr(T_FUN_COUNT(1)), partition_by([t1.a], [t1.b]), order_by(nil), window_type(RANGE), upper(UNBOUNDED PRECEDING), lower(UNBOUNDED FOLLOWING)
      win_expr(T_FUN_COUNT(1)), partition_by([t1.a]), order_by(nil), window_type(RANGE), upper(UNBOUNDED PRECEDING), lower(UNBOUNDED FOLLOWING)
