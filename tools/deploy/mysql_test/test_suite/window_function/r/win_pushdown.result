drop database if exists wf;
create database wf;
use wf;
create table t1(a int primary key, b int, c varchar(20), d int) partition by hash(a) partitions 4;
insert into t1 values(1, 1, "121", 4);
insert into t1 values(2, -1, "3f1", 400);
insert into t1 values(3, 4, "hh1", 19);
insert into t1 values(4, 6, "c1", 4);
insert into t1 values(5, 2, "c1", 23);
insert into t1 values(6, -3, "a1", 4);
insert into t1 values(7, 3, "21", 41);
insert into t1 values(8, 8, "b1", 32);
insert into t1 values(9, 3, "ha", 1);
insert into t1 values(10, 19, "he", 3);
create table t2(a int, b int, c varchar(20), d int, primary key(a,b)) partition by range columns(a, b) (partition p0 values less than(10, 20), partition p1 values less than(20, 30));
explain select a, b, count(1) over(partition by a) from t1;
Query Plan
=======================================================
|ID|OPERATOR                  |NAME    |EST. ROWS|COST|
-------------------------------------------------------
|0 |EXCHANGE IN DISTR         |        |8        |38  |
|1 | EXCHANGE OUT DISTR       |:EX10000|8        |38  |
|2 |  PX PART GRANULE ITERATOR|        |8        |38  |
|3 |   WINDOW FUNCTION        |        |8        |38  |
|4 |    TABLE SCAN            |t1      |8        |37  |
=======================================================

Outputs & filters: 
-------------------------------------
  0 - output([t1.a], [t1.b], [T_FUN_COUNT(1)]), filter(nil)
  1 - output([t1.a], [t1.b], [T_FUN_COUNT(1)]), filter(nil), dop=1
  2 - output([t1.a], [t1.b], [T_FUN_COUNT(1)]), filter(nil)
  3 - output([t1.a], [t1.b], [T_FUN_COUNT(1)]), filter(nil), 
      win_expr(T_FUN_COUNT(1)), partition_by([t1.a]), order_by(nil), window_type(RANGE), upper(UNBOUNDED PRECEDING), lower(UNBOUNDED FOLLOWING)
  4 - output([t1.a], [t1.b]), filter(nil), 
      access([t1.a], [t1.b]), partitions(p[0-3])

explain select a, b, count(1) over(partition by a), count(1) over(partition by a, b) from t1;
