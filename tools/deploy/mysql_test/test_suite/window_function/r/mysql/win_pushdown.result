Query Plan
======================================================================
|ID|OPERATOR                          |NAME    |EST.ROWS|EST.TIME(us)|
----------------------------------------------------------------------
|0 |PX COORDINATOR                    |        |1       |8           |
|1 |└─EXCHANGE OUT DISTR              |:EX10001|1       |7           |
|2 |  └─WINDOW FUNCTION               |        |1       |6           |
|3 |    └─EXCHANGE IN MERGE SORT DISTR|        |1       |6           |
|4 |      └─EXCHANGE OUT DISTR (HASH) |:EX10000|1       |5           |
|5 |        └─PX PARTITION ITERATOR   |        |1       |5           |
|6 |          └─TABLE FULL SCAN       |t2      |1       |5           |
======================================================================
Outputs & filters:
-------------------------------------
  0 - output([INTERNAL_FUNCTION(t2.a, t2.b, T_FUN_COUNT(1))]), filter(nil), rowset=16
  1 - output([INTERNAL_FUNCTION(t2.a, t2.b, T_FUN_COUNT(1))]), filter(nil), rowset=16
      dop=1
  2 - output([t2.a], [T_FUN_COUNT(1)], [t2.b]), filter(nil), rowset=16
      win_expr(T_FUN_COUNT(1)), partition_by([t2.a]), order_by(nil), window_type(RANGE), upper(UNBOUNDED PRECEDING), lower(UNBOUNDED FOLLOWING)
  3 - output([t2.a], [t2.b]), filter(nil), rowset=16
      sort_keys([t2.a, ASC])
  4 - output([t2.a], [t2.b]), filter(nil), rowset=16
      (#keys=1, [t2.a]), dop=1
  5 - output([t2.a], [t2.b]), filter(nil), rowset=16
      force partition granule, asc
  6 - output([t2.a], [t2.b]), filter(nil), rowset=16
      access([t2.a], [t2.b]), partitions(p[0-1])
      is_index_back=false, is_global_index=false, 
      range_key([t2.a], [t2.b]), range(MIN,MIN ; MAX,MAX)always true
drop database if exists wf;
