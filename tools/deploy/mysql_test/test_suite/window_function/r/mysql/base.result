drop table if exists t1;
drop table if exists t2;
create table t1 (a int, b int);
create table t2 (a int, b int);
insert into t1 values (1, 1);
insert into t2 values (2, 2);
explain
select /*+no_rewrite*/
if(
EXISTS (
select
11 as c0,
71 as c1,
14 as c2
from
t1 as ref_1
where
41 <=> 14
),
std(cast(cast(null as CHAR) as CHAR)) over (
partition by ref_0.a,
ref_0.a
order by
ref_0.a
),
LAG(cast("test" as CHAR)) over (
partition by ref_0.a,
ref_0.a
order by
ref_0.a
)
) as c0,
(
select
b
from
t2
order by
1 desc
limit
1 offset 2
) as c1,
LEAD(cast(60 as DECIMAL)) over (
partition by ref_0.a
order by
ref_0.a
) as c2
from
t1 as ref_0
where
ref_0.a MOD ref_0.a
limit
145;
