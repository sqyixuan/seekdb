drop table if exists `table5000_range_pk_part_p0__1000_part_p1__maxvalue_int`;
CREATE TABLE `table5000_range_pk_part_p0__1000_part_p1__maxvalue_int` (
  `pk` int(11) NOT NULL,
  `col_varchar_512` varchar(512) DEFAULT NULL,
  `col_decimal_20_0` decimal(20,0) DEFAULT NULL,
  `col_bigint` bigint(20) DEFAULT NULL,
  `col_int` int(11) DEFAULT NULL,
  `col_varchar_200` varchar(200) DEFAULT NULL,
  PRIMARY KEY (`pk`)
) 
 partition by range(pk)
(partition `p0` values less than (1000),
partition `p1` values less than (MAXVALUE)) WITH COLUMN GROUP(each column);

explain extended_noaddr
SELECT
    /*+parallel(2) pq_distribute_window((0,1) list (2) hash partition_sort pushdown) */
    MAX(DISTINCT TABLE1.col_decimal_20_0) over (partition by TABLE1.col_bigint),
    MAX(TABLE1.pk) over (
        partition by TABLE1.col_bigint
        ORDER BY TABLE1.pk,
            TABLE1.col_varchar_200 desc
    ),
    MAX(TABLE1.col_varchar_512) over (
        partition by TABLE1.col_varchar_512
        ORDER BY TABLE1.pk,
            TABLE1.pk,
            TABLE1.col_varchar_200,
            TABLE1.col_bigint,
            TABLE1.col_varchar_200,
            TABLE1.col_varchar_200,
            TABLE1.col_decimal_20_0,
            TABLE1.col_int ROWS BETWEEN 7 PRECEDING AND CURRENT ROW
    )
from table5000_range_pk_part_p0__1000_part_p1__maxvalue_int TABLE1
ORDER BY TABLE1.pk
limit 10;
