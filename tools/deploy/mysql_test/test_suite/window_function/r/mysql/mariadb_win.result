(127 , 6, 1, NULL);
select sum(b) over (partition by a order by b,pk
rows between unbounded preceding  and current row) as c1,
avg(b) over (partition by a order by b,pk rows between 1 preceding and 1 following) as c2,
sum(c) over (partition by b order by c,pk rows between 1 preceding and 1 following) as c5,  
avg(b) over (partition by a order by b,pk rows between 5 preceding and 5 following) as c3,
sum(b) over (partition by a order by b,pk rows between 1 preceding and 1 following) as c4
from t1;
