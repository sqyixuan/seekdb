2	1	4
3	1	4
4	1	3
5	2	3
6	2	4
7	2	5
8	2	5
9	2	4
10	2	3
select 
pk, c, 
count(*) over (partition by c order by pk rows between 2 preceding and 2 following) as CNT
from t1;
pk	c	CNT
