drop database if exists removal;
create database removal;
use removal;
result_format: 4

create table removal_basic
(
c1             integer              ,
c2             integer              ,
c3             integer              ,
c4             integer              ,
c5             double               ,
c6             float                ,
c7             integer unsigned     ,
c8             integer              ,
c9             integer
);
insert into removal_basic values(1, 1, 1, 4305, 1.1, 1.2, 1, 3, 4);
