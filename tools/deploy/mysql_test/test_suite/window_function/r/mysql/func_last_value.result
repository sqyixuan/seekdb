result_format: 3
set @@recyclebin = off;
drop table if exists t1;
create table t1 (c1 int primary key, c2 int, c3 int, c4 varchar(100));
insert into t1 values (1,1,3, 'fdsf');
insert into t1 values (2,2,2, '1fdfdsf');
insert into t1 values (3,2,1, NULL);
insert into t1 values (4,3,2, '8y77');
insert into t1 values (5,3,6, 'fdfd');
insert into t1 values (6,3,6, 'mnn');
insert into t1 values (7,4,2, '6fe');
insert into t1 values (8,4,1, 'kk');
insert into t1 values (9,4,1, 'kk');
insert into t1 values (10,4,3, 'kk');
select *, last_value(c4) over (order by c1), last_value(c4) over (partition by c1 order by c1), last_value(c4) over (partition by c2 order by c1) from t1 order by c1;
+----+------+------+---------+-----------------------------------+---------------------------------------------------+---------------------------------------------------+
| c1 | c2   | c3   | c4      | last_value(c4) over (order by c1) | last_value(c4) over (partition by c1 order by c1) | last_value(c4) over (partition by c2 order by c1) |
+----+------+------+---------+-----------------------------------+---------------------------------------------------+---------------------------------------------------+
|  1 |    1 |    3 | fdsf    | fdsf                              | fdsf                                              | fdsf                                              |
|  2 |    2 |    2 | 1fdfdsf | 1fdfdsf                           | 1fdfdsf                                           | 1fdfdsf                                           |
|  3 |    2 |    1 | NULL    | NULL                              | NULL                                              | NULL                                              |
|  4 |    3 |    2 | 8y77    | 8y77                              | 8y77                                              | 8y77                                              |
|  5 |    3 |    6 | fdfd    | fdfd                              | fdfd                                              | fdfd                                              |
|  6 |    3 |    6 | mnn     | mnn                               | mnn                                               | mnn                                               |
|  7 |    4 |    2 | 6fe     | 6fe                               | 6fe                                               | 6fe                                               |
|  8 |    4 |    1 | kk      | kk                                | kk                                                | kk                                                |
|  9 |    4 |    1 | kk      | kk                                | kk                                                | kk                                                |
| 10 |    4 |    3 | kk      | kk                                | kk                                                | kk                                                |
+----+------+------+---------+-----------------------------------+---------------------------------------------------+---------------------------------------------------+
select *, last_value(c4) over (order by c1 desc), last_value(c4 respect NULLS) over (order by c1 desc), last_value(c4 ignore NULLs) over (order by c1 desc) from t1 where c1 in (2,3) order by c1;
+----+------+------+---------+----------------------------------------+------------------------------------------------------+-----------------------------------------------------+
| c1 | c2   | c3   | c4      | last_value(c4) over (order by c1 desc) | last_value(c4 respect NULLS) over (order by c1 desc) | last_value(c4 ignore NULLs) over (order by c1 desc) |
+----+------+------+---------+----------------------------------------+------------------------------------------------------+-----------------------------------------------------+
|  2 |    2 |    2 | 1fdfdsf | 1fdfdsf                                | 1fdfdsf                                              | 1fdfdsf                                             |
|  3 |    2 |    1 | NULL    | NULL                                   | NULL                                                 | NULL                                                |
+----+------+------+---------+----------------------------------------+------------------------------------------------------+-----------------------------------------------------+
set @@recyclebin = off;
drop table t1;
