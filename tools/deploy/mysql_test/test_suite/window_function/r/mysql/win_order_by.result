drop table if exists t1;
create table t1 (c1 int primary key, c2 int, c3 int, c4 int,
index idx_c2_c4    (c2, c4),
index idx_c2_c3_c4 (c2, c3, c4));
alter system minor freeze;
call dbms_stats.gather_table_stats('TEST', 'T1', method_opt=>'for all columns size 10');
explain_protocol: 2
result_format: 4
## windown function 索引访问方向的选择
EXPLAIN select c1, avg(c1) over () v2 from t1 order by c2 desc;
Query Plan
==================================================================
|ID|OPERATOR         |NAME                 |EST.ROWS|EST.TIME(us)|
------------------------------------------------------------------
|0 |WINDOW FUNCTION  |                     |6       |11          |
|1 |└─TABLE FULL SCAN|t1(idx_c2_c4,Reverse)|6       |3           |
==================================================================
Outputs & filters:
-------------------------------------
  0 - output([t1.c1], [cast(cast(T_FUN_SUM(t1.c1), DECIMAL_INT(65, 32)) / cast(T_FUN_COUNT(t1.c1), DECIMAL_INT(20, 0)), DECIMAL(15, 4))]), filter(nil), rowset=16
      win_expr(T_FUN_SUM(t1.c1)), partition_by(nil), order_by(nil), window_type(RANGE), upper(UNBOUNDED PRECEDING), lower(UNBOUNDED FOLLOWING)
      win_expr(T_FUN_COUNT(t1.c1)), partition_by(nil), order_by(nil), window_type(RANGE), upper(UNBOUNDED PRECEDING), lower(UNBOUNDED FOLLOWING)
  1 - output([t1.c1]), filter(nil), rowset=16
      access([t1.c1]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t1.c2], [t1.c4], [t1.c1]), range(MIN,MIN,MIN ; MAX,MAX,MAX)always true
select c1, avg(c1) over () v2 from t1 order by c2 desc;
+----+--------+
| c1 | v2     |
+----+--------+
|  2 | 3.5000 |
|  4 | 3.5000 |
|  6 | 3.5000 |
|  1 | 3.5000 |
|  3 | 3.5000 |
|  5 | 3.5000 |
+----+--------+
