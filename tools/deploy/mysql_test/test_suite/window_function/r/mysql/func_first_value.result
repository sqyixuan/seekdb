result_format: 3
set @@recyclebin = off;
drop table if exists t1;
create table t1 (c1 int primary key, c2 int, c3 int, c4 varchar(100));
insert into t1 values (1,1,3, 'fdsf');
insert into t1 values (2,2,2, NULL);
insert into t1 values (3,2,1, 'kkkkk');
insert into t1 values (4,3,2, '8y77');
insert into t1 values (5,3,6, 'fdfd');
insert into t1 values (6,3,6, 'mnn');
insert into t1 values (7,4,2, '6fe');
insert into t1 values (8,4,1, 'kk');
insert into t1 values (9,4,1, 'kk');
insert into t1 values (10,4,3, 'kk');
select *, first_value(c4) over (order by c1), first_value(c4) over (partition by c1 order by c1), first_value(c4) over (partition by c2 order by c1) from t1 order by c1;
+----+------+------+-------+------------------------------------+----------------------------------------------------+----------------------------------------------------+
| c1 | c2   | c3   | c4    | first_value(c4) over (order by c1) | first_value(c4) over (partition by c1 order by c1) | first_value(c4) over (partition by c2 order by c1) |
+----+------+------+-------+------------------------------------+----------------------------------------------------+----------------------------------------------------+
|  1 |    1 |    3 | fdsf  | fdsf                               | fdsf                                               | fdsf                                               |
|  2 |    2 |    2 | NULL  | fdsf                               | NULL                                               | NULL                                               |
|  3 |    2 |    1 | kkkkk | fdsf                               | kkkkk                                              | NULL                                               |
|  4 |    3 |    2 | 8y77  | fdsf                               | 8y77                                               | 8y77                                               |
|  5 |    3 |    6 | fdfd  | fdsf                               | fdfd                                               | 8y77                                               |
|  6 |    3 |    6 | mnn   | fdsf                               | mnn                                                | 8y77                                               |
|  7 |    4 |    2 | 6fe   | fdsf                               | 6fe                                                | 6fe                                                |
|  8 |    4 |    1 | kk    | fdsf                               | kk                                                 | 6fe                                                |
|  9 |    4 |    1 | kk    | fdsf                               | kk                                                 | 6fe                                                |
| 10 |    4 |    3 | kk    | fdsf                               | kk                                                 | 6fe                                                |
+----+------+------+-------+------------------------------------+----------------------------------------------------+----------------------------------------------------+
select *, first_value(c4) over (order by c1), first_value(c4 respect NULLS) over (order by c1), first_value(c4 ignore NULLs) over (order by c1) from t1 where c1 in (2,3) order by c1;
+----+------+------+-------+------------------------------------+--------------------------------------------------+-------------------------------------------------+
| c1 | c2   | c3   | c4    | first_value(c4) over (order by c1) | first_value(c4 respect NULLS) over (order by c1) | first_value(c4 ignore NULLs) over (order by c1) |
+----+------+------+-------+------------------------------------+--------------------------------------------------+-------------------------------------------------+
|  2 |    2 |    2 | NULL  | NULL                               | NULL                                             | NULL                                            |
|  3 |    2 |    1 | kkkkk | NULL                               | NULL                                             | kkkkk                                           |
+----+------+------+-------+------------------------------------+--------------------------------------------------+-------------------------------------------------+
set @@recyclebin = off;
drop table t1;
