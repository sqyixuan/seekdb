set @@recyclebin = off;
drop table t1;
drop table if exists t1;
create table t1 (c1 datetime);
insert into t1 value ('2020-01-01 12:24:47');
insert into t1 value ('2020-01-01 12:24:50');
select avg(c1) from t1;
+---------------------+
| avg(c1)             |
+---------------------+
| 20200101122448.5000 |
+---------------------+
select avg(c1) x from t1 having x > '';
+---------------------+
| x                   |
+---------------------+
| 20200101122448.5000 |
+---------------------+
select cast(avg(c1) as char), avg(c1) from t1 having avg(c1) > '';
+-----------------------+---------------------+
| cast(avg(c1) as char) | avg(c1)             |
+-----------------------+---------------------+
| 20200101122448.5000   | 20200101122448.5000 |
+-----------------------+---------------------+
