|  7 |    4 |    2 | 6fe     |          5.5000 |                         7.0000 |                         8.5000 |                         7.0000 |
|  8 |    4 | NULL | kk      |          5.5000 |                         8.0000 |                         8.5000 |                         9.0000 |
|  9 |    4 |    1 | kk      |          5.5000 |                         9.0000 |                         8.5000 |                         9.0000 |
| 10 |    4 |    3 | kk      |          5.5000 |                        10.0000 |                         8.5000 |                         9.0000 |
