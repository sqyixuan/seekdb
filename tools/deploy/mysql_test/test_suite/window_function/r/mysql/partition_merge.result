      win_expr(T_FUN_MAX(test.c1)), partition_by([test.c2], [test.c3]), order_by(nil), window_type(RANGE), upper(UNBOUNDED PRECEDING), lower(UNBOUNDED FOLLOWING)
      win_expr(T_FUN_SUM(test.c1)), partition_by([test.c2], [test.c3]), order_by([test.c4, ASC]), window_type(RANGE), upper(UNBOUNDED PRECEDING), lower(CURRENT 
      ROW)
      win_expr(T_FUN_SUM(test.c1)), partition_by([test.c3], [test.c2]), order_by([test.c4, ASC]), window_type(RANGE), upper(UNBOUNDED PRECEDING), lower(CURRENT 
