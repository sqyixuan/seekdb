      win_expr(T_FUN_SUM(test.c1)), partition_by([test.c2]), order_by([test.c3, ASC]), window_type(RANGE), upper(UNBOUNDED PRECEDING), lower(CURRENT ROW)
  1 - output([test.c1], [test.c2], [test.c3], [test.c4], [test.c5]), filter(nil), rowset=16
      sort_keys([test.c2, ASC], [test.c3, ASC], [test.c4, ASC])
  2 - output([test.c1], [test.c2], [test.c3], [test.c4], [test.c5]), filter(nil), rowset=16
      access([test.c1], [test.c2], [test.c3], [test.c4], [test.c5]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([test.c1]), range(MIN ; MAX)always true
