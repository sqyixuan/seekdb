ERROR HY000: Incorrect arguments to ntile
drop procedure if exists test_p;
drop procedure if exists test_p2;
create procedure test_p()
begin
declare b double;
select 1.0 from dual into b;
select ntile(b) over() from ntile_test;
end;
//
create procedure test_p2()
begin
declare b int;
select 1 from dual into b;
select ntile(b) over() from ntile_test;
end;
//
call test_p();
