create table table_history(tenant_id int, table_id int, schema_version int, table_name varchar(50), primary key(tenant_id, table_id, schema_version)) partition by hash(tenant_id) partitions 8;
explain select *, row_number() over w as rn from
(select * from table_history where tenant_id = 1 and table_id < 1099511627777 order by table_id desc, schema_version desc limit 100)
window w as (partition by table_id order by schema_version desc);
Query Plan
======================================================================
|ID|OPERATOR            |NAME                  |EST.ROWS|EST.TIME(us)|
----------------------------------------------------------------------
|0 |WINDOW FUNCTION     |                      |1       |4           |
|1 |└─SUBPLAN SCAN      |ANONYMOUS_VIEW1       |1       |3           |
|2 |  └─TABLE RANGE SCAN|table_history(Reverse)|1       |3           |
======================================================================
Outputs & filters:
-------------------------------------
  0 - output([ANONYMOUS_VIEW1.tenant_id], [ANONYMOUS_VIEW1.table_id], [ANONYMOUS_VIEW1.schema_version], [ANONYMOUS_VIEW1.table_name], [T_WIN_FUN_ROW_NUMBER()]), filter(nil), rowset=16
      win_expr(T_WIN_FUN_ROW_NUMBER()), partition_by([ANONYMOUS_VIEW1.table_id]), order_by([ANONYMOUS_VIEW1.schema_version, DESC]), window_type(RANGE), 
      upper(UNBOUNDED PRECEDING), lower(UNBOUNDED FOLLOWING)
  1 - output([ANONYMOUS_VIEW1.table_id], [ANONYMOUS_VIEW1.schema_version], [ANONYMOUS_VIEW1.tenant_id], [ANONYMOUS_VIEW1.table_name]), filter(nil), rowset=16
      access([ANONYMOUS_VIEW1.table_id], [ANONYMOUS_VIEW1.schema_version], [ANONYMOUS_VIEW1.tenant_id], [ANONYMOUS_VIEW1.table_name])
  2 - output([table_history.tenant_id], [table_history.table_id], [table_history.schema_version], [table_history.table_name]), filter(nil), rowset=16
      access([table_history.tenant_id], [table_history.table_id], [table_history.schema_version], [table_history.table_name]), partitions(p1)
      limit(100), offset(nil), is_index_back=false, is_global_index=false, 
      range_key([table_history.tenant_id], [table_history.table_id], [table_history.schema_version]), range(1,NULL,MAX ; 1,2147483647,MAX), 
      range_cond([table_history.tenant_id = 1], [table_history.table_id < 1099511627777])
