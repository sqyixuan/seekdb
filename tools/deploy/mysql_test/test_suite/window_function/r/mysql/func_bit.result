|  4 |    3 |    2 | 8y77    |                 15 |                                 4 |                                 7 |                                 4 |
|  5 |    3 |    6 | fdfd    |                 15 |                                 5 |                                 7 |                                 5 |
|  6 |    3 |    6 | mnn     |                 15 |                                 6 |                                 7 |                                 6 |
|  7 |    4 |    2 | 6fe     |                 15 |                                 7 |                                15 |                                 7 |
|  8 |    4 | NULL | kk      |                 15 |                                 8 |                                15 |                                11 |
|  9 |    4 |    1 | kk      |                 15 |                                 9 |                                15 |                                11 |
| 10 |    4 |    3 | kk      |                 15 |                                10 |                                15 |                                11 |
+----+------+------+---------+--------------------+-----------------------------------+-----------------------------------+-----------------------------------+
