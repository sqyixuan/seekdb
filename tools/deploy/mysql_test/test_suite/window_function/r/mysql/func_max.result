insert into t1 values (6,3,6, 'mnn');
insert into t1 values (7,4,2, '6fe');
insert into t1 values (8,4,1, 'kk');
insert into t1 values (9,4,1, 'kk');
insert into t1 values (10,4,3, 'kk');
select *, max(c1) over (), max(c1) over (partition by c1), max(c1) over (partition by c2), max(c1) over (partition by c4) from t1 order by c1;
