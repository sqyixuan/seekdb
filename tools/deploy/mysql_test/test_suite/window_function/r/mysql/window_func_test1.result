#tkoqpuv.sql with modify
SELECT
  SUBSTR(LINE, 1, 80) PART1,
  SUBSTR(LINE, 81, 80) PART2,
  SUBSTR(LINE, 161, 80) PART3
FROM
( (SELECT LINE
   FROM
    (SELECT
         SUM(NUM) OVER ()   LINE
     FROM (SELECT COUNT(*) NUM FROM DUAL)
    )
  )
) ;
