select /*+ parallel(t1, 3) parallel(t2, 3) ordered use_merge(t2) */
       t1.a, t2.b, t2.c, t1.d, t1.e,
       rank() over (partition by t1.a order by t2.b) as w1,
       rank() over (partition by t2.b order by t1.a) as w2,
       rank() over (partition by t2.b order by t1.a desc) as w3,
       rank() over (partition by t2.b, t1.a order by t2.c) as w4,
       rank() over (partition by t1.a, t2.b order by t2.c desc) as w5,
       rank() over (partition by t2.c, t1.a, t2.b order by t1.d) as w6,
       rank() over (partition by t1.a, t2.b, t2.c order by t1.d, t1.e desc) as w7
from testwn1cp t1, testwn1cp t2 where t1.f = 1 and t1.f = t2.f and t1.b = t2.b
and t1.c = t2.c and t1.a = t2.a group by t1.f, t2.b, t1.a, t2.c order by t2.c, t2.b;
