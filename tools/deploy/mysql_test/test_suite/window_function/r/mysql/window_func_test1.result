select count(*)
      from t_5k, t_4k
      where t_5k.ten = mod(t_4k.thousand,11)
      and  (mod(t_5k.thousand, 10), mod(t_5k.ten,5)) <>ANY
      (select mod(suM(t1_100.hundred),10),mod(rank()
      over (order by (sum(t1_100.hundred))), 5) as rank1
         from t1_100
              where t1_100.char_unique < t_5k.char_hund
              group by t1_100.ten, t1_100.thousand);
