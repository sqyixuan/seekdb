#tkoqfrow.sql
select  sum(rnum) from
  (select  /*+ FIRST_ROWS */ row_number()
  over (order by t_10k.char_hund) as rnum
  from t_10k, t_4k, t_5k
  where  t_10k.unique1 = t_4k.unique1 and
         t_10k.char_hund = t_5k.char_hund);
