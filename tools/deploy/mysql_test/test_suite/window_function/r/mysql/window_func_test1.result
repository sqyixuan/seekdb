#tkoqapcdtonum.sql
select t_5k.unique1
      from t_5k, t_4k
      where t_5k.ten = mod(t_4k.thousand,7)
      and  (t_5k.thousand, t_5k.hundred) =ANY
      (select sum(t1_100.hundred), rank()
      over (order by (max(t1_100.char_unique))) as rank1
         from t1_100
              where t1_100.char_unique < t_5k.char_hund
              ) and t_5k.unique1 >1 order by 1;
+---------+
| unique1 |
+---------+
+---------+

select nvl(min(t1_100.hundred),(sum(t1_100.hundred))),'OK','WRONG', rank()
      over (order by (max(t1_100.char_unique))) as rank1
         from t1_100, t_5k
              where t1_100.char_unique < t_5k.char_hund;
+------------------------------------------------+----+-------+-------+
| nvl(min(t1_100.hundred),(sum(t1_100.hundred))) | OK | WRONG | rank1 |
+------------------------------------------------+----+-------+-------+
|                                              0 | OK | WRONG |     1 |
+------------------------------------------------+----+-------+-------+
select * from
(select t_5k.unique1
from t_5k, t_4k
where t_5k.ten = mod(t_4k.thousand,10)
and  (t_5k.thousand, t_5k.hundred) =ANY
(select max(t1_100.hundred), rank()
over (order by (max(t1_100.char_unique))) as rank1
from t1_100
	where t1_100.char_unique < t_5k.char_hund)
	and t_5k.unique1 >3)
MINUS
(select t_5k.unique1
from t_5k, t_4k
where t_5k.ten = mod(t_4k.thousand, 10)
and  (t_5k.thousand, t_5k.hundred) =ANY
      (select min((t1_100.hundred)), rank()
       over (order by (max(t1_100.char_unique))) as rank1
       from t1_100
       where t1_100.char_unique < t_5k.char_hund )
and t_5k.unique1 >1);
