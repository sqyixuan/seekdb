select t_5k.unique1, ntile(3) over (order by (t_5k.unique1)) as ntile_5k,
t_4k.unique1
from t_5k, t_4k
where mod(t_5k.ten,10) = mod(t_4k.thousand,17)
and t_5k.unique1 >= 3500
and EXISTS (select (z_4k.unique2)
        from z_4k, g_4k
        where z_4k.ten = g_4k.thousand
        and z_4k.ten = 1
        and g_4k.thousand = t_5k.hundred)
order by t_5k.unique1, t_4k.unique1;
