select /*+ parallel(t1, 2) parallel(t2, 2) ordered use_merge(t2) */
       t1.a, t2.b, rank() over (partition by t1.a order by t2.b desc) as w1,
       rank() over (partition by t2.b order by t1.a, t2.c) as w2
from testwn1 t1, testwn1 t2 where t1.f = 1 and t1.f = t2.f and t1.b = t2.b
and t1.c = t2.c and t1.a = t2.a group by t1.f, t2.b, t1.a, t2.c order by t2.c, t2.b;
