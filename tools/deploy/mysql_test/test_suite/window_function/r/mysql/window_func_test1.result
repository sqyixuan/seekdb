|      3 | D     | mm   |     30 |        9400.00 |
|      3 | D     | mm   |     30 |        9400.00 |
+--------+-------+------+--------+----------------+

select/*+push_pred(uv)*/ *
from
    (select /*+push_pred(wn) */dname
     from dept d1,
               (select deptno,
                       row_number() over (partition by deptno
                                          order by deptno),
                       ename
                from emp
               ) wn
     where (dname ='A' or dname='D')
     union all
     select dname from dept d2 where deptno=99
    ) uv, dept d
where d.loc='mm' and d.dname=uv.dname;
