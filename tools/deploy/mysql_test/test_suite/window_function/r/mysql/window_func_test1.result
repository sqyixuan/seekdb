create table x_8520169(id int primary key);
insert into x_8520169 values(87);
insert into x_8520169 values(395);

create table t_8520169(pid int, cid int, outdate date);
insert into t_8520169 values (87, 302151, '2009-5-31');
insert into t_8520169 values (395, 3872455, '2009-5-31');

create table s_8520169(pid int, submissions int, callday date);

insert into s_8520169 values (87, 1, '2009-5-31');
insert into s_8520169 values (395, 1, '2009-5-31');

create index t_8520169_practice on t_8520169(pid);
create index s_8520169_callday on s_8520169(callday);
create index s_8520169_pid on s_8520169(pid);

select /*+ push_pred(s_8520169) */  * from
   ( select  outdate as datesplit,
              100 * count(*) / sum(count(*)) over ()  as percent,
             pid
    from t_8520169, x_8520169
    where id = pid
    group by  outdate , pid
   order by datesplit) t_8520169,
  (select sum(submissions) as submissions,
               callday  as datesplit,
              pid
   from s_8520169
   group by  callday , pid) s_8520169
where t_8520169.pid = s_8520169.pid
    and t_8520169.datesplit = s_8520169.datesplit
order by t_8520169.pid;
