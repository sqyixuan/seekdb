#tkoqrrgb.sql
select suM(t2.hundred),rank()
         over (order by (sum(t2.hundred))) as rank1
from t2_100 t2
where t2.char_unique < t2.char_hund
and t2.unique1 is not null
group by t2.unique1;
+-----------------+-------+
| suM(t2.hundred) | rank1 |
+-----------------+-------+
+-----------------+-------+

#tkoqscsu.sql
SELECT DISTINCT(t_4k.ten),
     (SELECT AVG(t10.thousand)
      FROM t_10k t10
      WHERE t10.ten=t_4k.ten
      AND  (t10.thousand, t10.ten) =ANY
           (SELECT suM(t1_100.hundred),RANK()
             OVER (order by (sum(t1_100.hundred))) as rank1
            FROM t1_100
            WHERE t1_100.char_unique < t10.char_hund
            GROUP BY t1_100.ten, t1_100.thousand))sc
FROM t_4k WHERE t_4k.unique3 is null
order by 1;
+------+------+
| ten  | sc   |
+------+------+
|    1 | NULL |
|    3 | NULL |
|    5 | NULL |
|    7 | NULL |
|    9 | NULL |
+------+------+

select t1.unique1, (select rank() over (order by (MAX(t_5k.unique1)))
                     from t_5k
                    where t_5k.thousand = t1.thousand)sc
from t_4k t1;
