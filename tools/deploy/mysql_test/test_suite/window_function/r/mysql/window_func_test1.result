select /*+ parallel(testwn1, 2) */
       a, b, c, rank() over (partition by a order by b) as w1,
             rank() over (partition by b order by a) as w2,
             rank() over (partition by b order by a desc) as w3,
             rank() over (partition by b, a order by c) as w4,
