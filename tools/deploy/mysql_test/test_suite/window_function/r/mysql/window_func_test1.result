#tkoqsrb1.sql 内存耗尽, bug 17160365;
create table vfdlbst1_ogz_daily(
    pkg_alt_ref_nr varchar(10),
    org_ntm_ttd_qy varchar(10),
    ntm_fna_dtn_ttd_qy varchar(10),
    der_xcp_qy int,
    xcp_rpy_ogz_dri_nr varchar(10),
    ld_dtn_ogz_dri_nr varchar(10),
    dtn_ogz_dri_nr varchar(10),
    xcp_rpy_srt_dri_nr varchar(10),
    ld_dtn_srt_dri_nr varchar(10),
    ulo_svc_dri_nr varchar(10),
    pkg_svc_dri_nr varchar(10),
    DT_DRI_NR varchar(10),
    lbt_cgy_dri_nr varchar(10),
    org_fna_dtn_ttd_qy varchar(10));

create table vdogzbs0_base(
    fac_loc_nr varchar(10),
    ogz_dri_nr varchar(10),
    cny_cd varchar(10),
    reg_nr varchar(10),
    ogz_nr varchar(10));
create table vdsrtbs0_base(
    srt_typ_mnm_te varchar(10),
    srt_dri_nr varchar(10)
);
create table vdservc0_base(
    pdc_typ_cd varchar(10),
    svc_dri_nr varchar(10)
);
create table vddate0_base(
    DT_DRI_NR varchar(10),
    dy_dt date
);
create table vdcatgy0_base(
    lbt_cgy_dri_nr varchar(10),
    lbt_cgy_cd varchar(10)
);

set @@ob_query_timeout = 999999999;
set @@ob_trx_timeout =   999999999;

Select * from (
SELECT MAX(vlb.pkg_alt_ref_nr || ',' || vbase3.ogz_nr || ',' ||
           vlb.org_ntm_ttd_qy || ',' || vlb.ntm_fna_dtn_ttd_qy ||
           ',' || vlb.org_fna_dtn_ttd_qy) AS arrSample,
       SUM(vlb.der_xcp_qy) AS misloads,
 row_number () over (order by SUM(vlb.der_xcp_qy) desc ) as row_number,
    vbase1.fac_loc_nr AS pkg_xcp_rpy_ogz_nr,
    vsort1.srt_typ_mnm_te AS pkg_xcp_rpy_srt_cd,
    vbase2.ogz_nr AS ld_dtn_ogz_nr,
    vsort2.srt_typ_mnm_te AS ld_dtn_srt_typ_cd
FROM vfdlbst1_ogz_daily vlb, vdogzbs0_base vbase1,
    vdogzbs0_base vbase2, vdogzbs0_base vbase3,
    vdsrtbs0_base vsort1, vdsrtbs0_base vsort2,
    vdservc0_base vservice1, vdservc0_base vservice2,
    vddate0_base vdate, vdcatgy0_base vcat
WHERE vlb.xcp_rpy_ogz_dri_nr = vbase1.ogz_dri_nr AND
    vlb.ld_dtn_ogz_dri_nr = vbase2.ogz_dri_nr AND
    vlb.dtn_ogz_dri_nr = vbase3.ogz_dri_nr AND
    vlb.xcp_rpy_srt_dri_nr = vsort1.srt_dri_nr AND
    vlb.ld_dtn_srt_dri_nr = vsort2.srt_dri_nr AND
    vlb.ulo_svc_dri_nr = vservice1.svc_dri_nr AND
    vlb.pkg_svc_dri_nr = vservice2.svc_dri_nr AND
    vlb.DT_DRI_NR = vdate.DT_DRI_NR AND
    vlb.lbt_cgy_dri_nr = vcat.lbt_cgy_dri_nr AND
    vdate.dy_dt BETWEEN date('2003-1-26')  AND
    date('2003-4-1') AND
    vbase1.cny_cd = 'US' AND vbase1.reg_nr LIKE '%' AND
    vcat.lbt_cgy_cd = '01'
GROUP BY vbase1.fac_loc_nr, vsort1.srt_typ_mnm_te,
    vbase2.ogz_nr, vsort2.srt_typ_mnm_te
ORDER BY 2 DESC)
limit 4;
+-----------+----------+------------+--------------------+--------------------+---------------+-------------------+
| arrSample | misloads | row_number | pkg_xcp_rpy_ogz_nr | pkg_xcp_rpy_srt_cd | ld_dtn_ogz_nr | ld_dtn_srt_typ_cd |
+-----------+----------+------------+--------------------+--------------------+---------------+-------------------+
+-----------+----------+------------+--------------------+--------------------+---------------+-------------------+

#tkoqvma.sql
create table pers_app (aid_beg_date DATE NOT NULL  ,
pgm_pers_id NUMBER NOT NULL  ,
created_by VARCHAR (30) NOT NULL  ,
updated_by VARCHAR (30) NOT NULL  ,
created_on TIMESTAMP (6) NOT NULL  ,
updated_on TIMESTAMP (6) NOT NULL  ,
id NUMBER,
app_date DATE NOT NULL  ,
mc_decl_elig_ind VARCHAR (1),
cash_mc_aid_beg_date DATE NOT NULL  ,
actn_date DATE NOT NULL  ,
restore_ind VARCHAR (1),
change_ind VARCHAR (1))  ;

create unique index pers_app_pk on pers_app (id );
create index pers_app00_idx on pers_app (pgm_pers_id );
create index pers_app_0s_idx on pers_app (app_date );

select  pa1.aid_beg_date,
       pa1.pgm_pers_id,
       pa1.updated_on,
       pa1.id,
       pa1.app_date,
       pa1.mc_decl_elig_ind,
       pa1.cash_mc_aid_beg_date,
       pa1.restore_ind,
       pa1.actn_date,
       (row_number() over ( partition by pa1.pgm_pers_id
        order by case pa1.actn_date
        when date('9999-12-1') then date('1000-1-1')
        else pa1.actn_date end DESC,
      	pa1.updated_on DESC)) part_rownum
       from pers_app pa1
       where pa1.pgm_pers_id = 203
         and pa1.app_date <= date('2004-01-01')
         and pa1.app_date = (select max(pa2.app_date)
                             from pers_app pa2
                             where pa2.pgm_pers_id = pa1.pgm_pers_id);
+--------------+-------------+------------+------+----------+------------------+----------------------+-------------+-----------+-------------+
| aid_beg_date | pgm_pers_id | updated_on | id   | app_date | mc_decl_elig_ind | cash_mc_aid_beg_date | restore_ind | actn_date | part_rownum |
+--------------+-------------+------------+------+----------+------------------+----------------------+-------------+-----------+-------------+
+--------------+-------------+------------+------+----------+------------------+----------------------+-------------+-----------+-------------+
drop table pers_app;

create table t17080195
(col1 varchar(1) not null,col2 varchar(1) not null,
 col3  varchar(1) not null, val number not null);

select d1.c0,
       sum(d1.c1) over (partition by d1.c0)
from
    (select /*+ merge */ sum(val) as c1,
                         case ''
                                when col3
                                then col2
                                else col1
                         end  as c0
     from
         t17080195
     group by  col1,
               col2,
               case ''
                      when col3
                      then col2
                      else col1
               end
    ) d1;
+----+--------------------------------------+
| c0 | sum(d1.c1) over (partition by d1.c0) |
+----+--------------------------------------+
+----+--------------------------------------+

drop table t17080195;

