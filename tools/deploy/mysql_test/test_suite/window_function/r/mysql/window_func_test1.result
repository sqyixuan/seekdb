select t_5k.unique1
from t_5k, t_4k
where t_5k.ten = t_4k.thousand
and  (t_5k.thousand, t_5k.hundred) =ANY
      (select approx_count_distinct(t1_100.hundred), rank()
       over (order by (max(t1_100.char_unique))) as rank1
       from t1_100
       where t1_100.char_unique < t_5k.char_hund )
and t_5k.unique1 >3000 order by 1;
+---------+
| unique1 |
+---------+
+---------+

select * from
(select t_5k.unique1
from t_5k, t_4k
where t_5k.ten = t_4k.thousand
and  (t_5k.thousand, t_5k.hundred) =ANY
     (select count(distinct t1_100.hundred), rank()
      over (order by (max(t1_100.char_unique))) as rank1
      from t1_100
           where t1_100.char_unique < t_5k.char_hund
               ) and t_5k.unique1 >3000 order by 1)
MINUS
select * from
(select t_5k.unique1
from t_5k, t_4k
where t_5k.ten = t_4k.thousand
and  (t_5k.thousand, t_5k.hundred) =ANY
      (select approx_count_distinct(t1_100.hundred), rank()
       over (order by (max(t1_100.char_unique))) as rank1
       from t1_100
       where t1_100.char_unique < t_5k.char_hund )
and t_5k.unique1 >3000 order by 1);
+---------+
| unique1 |
+---------+
+---------+

#tkoqapcdagg.sql
select max(splcol) from
(select sum(t_5k.unique1) splcol from
t_5k, t_4k
where t_5k.ten = t_4k.thousand
and  (t_5k.thousand, t_5k.hundred) =ANY
(select count(distinct t1_100.hundred), rank()
over (order by (max(t1_100.char_unique))) as rank1
from t1_100
	where t1_100.char_unique < t_5k.char_hund
	group by t1_100.hundred)
and t_5k.unique1 >3000
group by t_5k.unique1);
+-------------+
| max(splcol) |
+-------------+
|        NULL |
+-------------+

select *
from   (select (count(splcol)) c1
from 	(select count(t_5k.unique1) splcol
from t_5k, t_4k
where t_5k.ten = t_4k.thousand
and  (t_5k.thousand, t_5k.hundred) =ANY
(select count(distinct t1_100.hundred), rank()
over (order by (max(t1_100.char_unique))) as rank1
from t1_100
where t1_100.char_unique < t_5k.char_hund
group by t1_100.hundred)
and t_5k.unique1 >3000
group by t_5k.unique1)) andv,
(select sum(t_5k.unique1) c1
from t_5k, t_4k
where t_5k.ten = t_4k.thousand
and  (t_5k.thousand, t_5k.hundred) =ANY
(select count(distinct t1_100.hundred), rank()
over (order by (max(t1_100.char_unique))) as rank1
from t1_100
where t1_100.char_unique < t_5k.char_hund
group by t1_100.hundred)
and t_5k.unique1 >3000) dist;
+------+----+
| c1   | c1 |
+------+----+
|    0 | NULL |
+------+----+

create table empagg(deptno int, splcol int);
insert into empagg
select deptno, sum(empno) splcol from emp group by deptno;

select sum(splcol) over (partition by deptno) from empagg;
+----------------------------------------+
| sum(splcol) over (partition by deptno) |
+----------------------------------------+
|                                  23555 |
|                                  38501 |
|                                  46116 |
+----------------------------------------+

drop table empagg;

select (sum(splcol)) from
(select (t_5k.unique1) splcol from t_5k, t_4k
  where t_5k.ten = t_4k.thousand
      and  (t_5k.thousand, t_5k.hundred) =ANY
      (select count(distinct t1_100.hundred), rank()
      over (order by (max(t1_100.char_unique))) as rankap
         from t1_100
              where t1_100.char_unique < t_5k.char_hund
group by t1_100.ten, t1_100.thousand) group by t_5k.ten);
+---------------+
| (sum(splcol)) |
+---------------+
|          NULL |
+---------------+

select /*+query_timeout(60000000)*/ *
from   (select sum(splcol) c1
from	(select count(t_5k.unique1) splcol from t_5k, t_4k
where t_5k.ten = mod(t_4k.thousand,10)
and  (t_5k.thousand, t_5k.hundred) =ANY
(select count(distinct t1_100.hundred), rank()
over (order by (max(t1_100.char_unique))) as rankap
from t1_100
where t1_100.char_unique < t_5k.char_hund
group by t1_100.ten, t1_100.thousand) group by t_5k.ten)) andv,
(select count(t_5k.unique1) c1
from t_5k, t_4k
where t_5k.ten = mod(t_4k.thousand,10)
and  (t_5k.thousand, t_5k.hundred) =ANY
(select count(distinct t1_100.hundred), rank()
over (order by (max(t1_100.char_unique))) as rankap
from t1_100
where t1_100.char_unique < t_5k.char_hund
group by t1_100.ten, t1_100.thousand)) dist;
+------+------+
| c1   | c1   |
+------+------+
| NULL |    0 |
+------+------+

