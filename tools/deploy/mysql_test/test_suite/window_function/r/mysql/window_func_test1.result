#tkoqview.sql
select * from
(
  select
    ten,
    4,
    rank() over (partition by ten order by 1) as rank_numeric,
    case when ten = 2 then 1 else 1/0 end as pushchecker
  from
    t1_100
)
where ten = 2
order by ten, rank_numeric;
ERROR HY000: Window '<unnamed window>': ORDER BY or PARTITION BY uses legacy position indication which is not supported use expression.

select * from
(
  select
    ten,
    4,
    rank() over (partition by ten order by 1) as rank_numeric,
    case when ten = 2 or ten = 1 then 1 else 1/0 end as pushchecker
  from
    t1_100
)
where ten = 2 or ten = 1
order by ten, rank_numeric;
ERROR HY000: Window '<unnamed window>': ORDER BY or PARTITION BY uses legacy position indication which is not supported use expression.

select * from
(
  select
    ten,
    4,
    rank() over (partition by ten order by 1) as rank_numeric,
    case when ten in (1,2,3) then 1 else 1/0 end as pushchecker
  from
    t1_100
  order by
    ten, rank_numeric
)
where ten in (1,2,3)
order by ten, rank_numeric;
ERROR HY000: Window '<unnamed window>': ORDER BY or PARTITION BY uses legacy position indication which is not supported use expression.

select * from
(
  select
    ten,
    4,
    rank() over (partition by ora_decode(ten, 2, 100, 0)
                 order by 1) as rank_numeric,
    case when ora_decode(ten, 2, 100, 0) = 100 then 1
         else 1/0
    end as pushchecker
  from
    t1_100
)
where ora_decode(ten, 2, 100, 0) = 100
order by ten, rank_numeric;
ERROR HY000: Window '<unnamed window>': ORDER BY or PARTITION BY uses legacy position indication which is not supported use expression.

