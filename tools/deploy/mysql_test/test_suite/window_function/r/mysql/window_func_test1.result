| PART1 | PART2 | PART3 |
+-------+-------+-------+
| 1     |       |       |
+-------+-------+-------+

CREATE TABLE AVG_CEL_VOICETRAFFIC(
    START_TIME TIME(6) NOT NULL ,
	NETWORK_ELEMENT_CO_GID  NUMBER NOT NULL ,
	WAP_PAGE_CO_GID NUMBER NOT NULL ,
	DURATION  NUMBER,
	WEIGHT  NUMBER,
	AVG_INCOMINGVOICE  NUMBER,
	AVG_OUTGOINGVOICE NUMBER,
	SIMPLE_VOICE_COUNTER  NUMBER,
	SIMPLE_VC_SUM_NONE NUMBER,
	SIMPLE_VC_NONE_SUM  NUMBER,
	SIMPLE_VC_SUM_SUM NUMBER,
	 CONSTRAINT  PK_AVG_CEL_VOICETRAFFIC
         PRIMARY KEY (START_TIME, NETWORK_ELEMENT_CO_GID,
                      WAP_PAGE_CO_GID));

CREATE TABLE MOF_COMMON_OBJECTS
   (	CO_GID NUMBER NOT NULL ,
	CO_MOF_OC_ID NUMBER,
	CO_OCV_SYS_VERSION VARCHAR(20),
	CO_DI_TOKEN NUMBER DEFAULT 0 NOT NULL ,
	CO_DB_TIME_STAMP TIME(6) NOT NULL ,
	CO_CREATE_TIME_STAMP DATE  NOT NULL ,
	CO_LAST_MODIFIER VARCHAR(30) NOT NULL ,
	CO_STATE NUMBER NOT NULL ,
	CO_OBJECT_INSTANCE VARCHAR(80),
	CO_PARENT_GID NUMBER,
	CO_DN VARCHAR(400),
	CO_NAME VARCHAR(80),
	CO_MAINTENANCE_MODE NUMBER,
	CO_ADMIN_STATE NUMBER,
	CO_FOREIGN_OBJECT NUMBER DEFAULT 0,
	CO_NOTES_INDICATOR NUMBER DEFAULT 0,
	CO_MF_GID NUMBER,
	CO_MR_GID NUMBER,
	CO_SO_GID NUMBER,
	CO_MAIN_HOST VARCHAR(256),
	CO_LAST_UPLOADED DATE,
	CO_RESYNC_REQUIRED NUMBER,
	CO_EXTERNAL_KEY VARCHAR(400),
	CO_VENDOR VARCHAR(256),
	CO_SNMP_PORT NUMBER,
	CO_FTP_USERNAME VARCHAR(30),
	CO_FTP_PASSWORD VARCHAR(70),
	CO_SNMP_GET_NAME VARCHAR(70),
	CO_SNMP_SET_NAME VARCHAR(70),
	CO_INT_ID NUMBER,
	CO_OC_ID NUMBER,
	CO_PARENT_INT_ID NUMBER,
	CO_NE_VERSION VARCHAR(20),
	LA_SA_INT_ID NUMBER,
	LA_FREQUENCY_BAND_IN_USE NUMBER,
	LA_BCF_TYPE NUMBER,
	 CONSTRAINT MOF_PK_COMMON_OBJECTS PRIMARY KEY (CO_GID));

CREATE TABLE REQUESTS
   (START_TIME TIMESTAMP (6) NOT NULL ,
	NETWORK_ELEMENT_CO_GID NUMBER NOT NULL ,
	WAP_PAGE_CO_GID NUMBER NOT NULL ,
	DURATION NUMBER,
	WEIGHT NUMBER,
	NBR_REQUESTS NUMBER,
	SUCC_REQUESTS NUMBER,
	AVE_RESP_TIME NUMBER,
	 CONSTRAINT PK_REQUESTS PRIMARY KEY (
                                     START_TIME,
                                     NETWORK_ELEMENT_CO_GID,
                                     WAP_PAGE_CO_GID));

SELECT /* bug-10288630 */
  COALESCE(q1.a10, q0.a4) AS a10,
  COALESCE(q1.a6, q0.a0) AS a6,
  q0.i1,
  q1.i3
FROM (SELECT AVG(f.i0) AS i1, f.a0, d1.CO_GID AS a4, d4.CO_GID AS a5
      FROM (SELECT q1.a0 AS a0, q1.f0 AS a1, q1.f0 AS a2,
                   SUM(q1.i1) AS i0
            FROM (SELECT  (q0.i0+200) AS i1,   q0.f0,   q0.a0
                  FROM (SELECT   f.ave_resp_time AS i0,
                                 f.START_TIME AS a0,
                                 f.network_element_CO_GID AS f0
                        FROM REQUESTS f
                        WHERE  (f.START_TIME >= TIMESTAMP '2007-04-13 00:00:00'
                             AND f.START_TIME < TIMESTAMP '2007-07-20 00:00:00')
                       ) q0
                  WHERE  q0.i0>0
                 ) q1
            GROUP BY   q1.a0,  q1.f0,  q1.f0
           ) f
           INNER JOIN
           (Select MOF_COMMON_OBJECTS.*, mof_common_objects.co_parent_gid source,
                   mof_common_objects.co_gid target
            from mof_common_objects
            where mof_common_objects.co_parent_gid is not null
              and mof_common_objects.co_mof_oc_id = 11540
           ) d0 ON (f.a2=d0.TARGET)
           INNER JOIN
           (Select MOF_COMMON_OBJECTS.*
            from MOF_COMMON_OBJECTS
            where MOF_COMMON_OBJECTS.CO_MOF_OC_ID=11539
           ) d1 ON (d0.SOURCE=d1.CO_GID)
           INNER JOIN
           (Select MOF_COMMON_OBJECTS.*, mof_common_objects.co_parent_gid source,
                   mof_common_objects.co_gid target
            from mof_common_objects
            where mof_common_objects.co_parent_gid is not null
              and mof_common_objects.co_mof_oc_id = 11540
           ) d2 ON (f.a2=d2.TARGET)
           INNER JOIN
           (Select MOF_COMMON_OBJECTS.*, mof_common_objects.co_parent_gid source,
                   mof_common_objects.co_gid target
            from mof_common_objects
            where mof_common_objects.co_parent_gid is not null
              and mof_common_objects.co_mof_oc_id = 11539
           ) d3 ON (d2.SOURCE=d3.TARGET)
           INNER JOIN
           (Select MOF_COMMON_OBJECTS.*
            from MOF_COMMON_OBJECTS
            where MOF_COMMON_OBJECTS.CO_MOF_OC_ID=11538
           )d4 ON (d3.SOURCE=d4.CO_GID)
     GROUP BY f.a0,   d1.CO_GID,   d4.CO_GID
    ) q0
 FULL OUTER JOIN
    (SELECT   AVG(f.i2) AS i3, f.a6,   d6.CO_GID AS a10,   d9.CO_GID AS a11
     FROM ( SELECT   q2.a1 AS a6,   q2.f2 AS a7,
                     q2.f2 AS a8,   SUM(q2.i3) AS i2
            FROM (SELECT   ((q0.i0)/q1.i2) AS i3,   COALESCE(q1.f2, q0.f0) AS f2,
                           COALESCE(q1.a1, q0.a0) AS a1, COALESCE(q1.f3, q0.f1) AS f3
                  FROM ( SELECT   f.avg_incomingvoice AS i0,   f.weight AS i1,
                                  f.START_TIME AS a0,
                                  f.network_element_CO_GID AS f0,
                                  f.wap_page_CO_GID AS f1
                         FROM AVG_CEL_VOICETRAFFIC f
                         WHERE  (f.START_TIME >= TIMESTAMP '2007-04-13 00:00:00'
                             AND f.START_TIME < TIMESTAMP '2007-07-20 00:00:00' )
                       ) q0
                       FULL OUTER JOIN
                       ( SELECT   f.ave_resp_time AS i2,
                                  f.START_TIME AS a1,
                                  f.network_element_CO_GID AS f2,
                                  f.wap_page_CO_GID AS f3
                         FROM REQUESTS f
                         WHERE  (f.START_TIME >= TIMESTAMP '2007-04-13 00:00:00'
                             AND f.START_TIME < TIMESTAMP '2007-07-20 00:00:00' )
                       ) q1 ON  (q0.f1=q1.f3 AND q0.f0=q1.f2 AND q0.a0=q1.a1)
                  WHERE  q1.i2<>0
                 )q2
            GROUP BY   q2.a1,   q2.f2,   q2.f2
          ) f
          INNER JOIN
          ( Select MOF_COMMON_OBJECTS.*, mof_common_objects.co_parent_gid source,
                   mof_common_objects.co_gid target
            from mof_common_objects
            where mof_common_objects.co_parent_gid is not null
              and mof_common_objects.co_mof_oc_id = 11540
          ) d5 ON (f.a8=d5.TARGET)
          INNER JOIN
          ( Select MOF_COMMON_OBJECTS.*
            from MOF_COMMON_OBJECTS
            where MOF_COMMON_OBJECTS.CO_MOF_OC_ID=11539
          ) d6 ON (d5.SOURCE=d6.CO_GID)
          INNER JOIN
          ( Select MOF_COMMON_OBJECTS.*, mof_common_objects.co_parent_gid source,
                   mof_common_objects.co_gid target
            from mof_common_objects
            where mof_common_objects.co_parent_gid is not null
              and mof_common_objects.co_mof_oc_id = 11540
          ) d7 ON (f.a8=d7.TARGET)
          INNER JOIN
          ( Select MOF_COMMON_OBJECTS.*, mof_common_objects.co_parent_gid source,
                   mof_common_objects.co_gid target
            from mof_common_objects
            where mof_common_objects.co_parent_gid is not null
              and mof_common_objects.co_mof_oc_id = 11539
          ) d8 ON (d7.SOURCE=d8.TARGET)
          INNER JOIN
          ( Select MOF_COMMON_OBJECTS.*
            from MOF_COMMON_OBJECTS
            where MOF_COMMON_OBJECTS.CO_MOF_OC_ID=11538
          ) d9 ON (d8.SOURCE=d9.CO_GID)
     GROUP BY f.a6,   d6.CO_GID,   d9.CO_GID
   ) q1 ON  (q0.a4=q1.a10 AND q0.a0=q1.a6 AND q0.a5=q1.a11)
WHERE  a10 in (SELECT rnk.a16
               FROM (SELECT   AVG(f.i4) AS i5, f.a12,   d12.CO_GID AS a16,
                              d15.CO_GID AS a17   ,
                              rank() over (partition by f.a12, d15.CO_GID
                              order by AVG(f.i4) desc) AS rank
                     FROM (SELECT  q2.a1 AS a12,   q2.f2 AS a13,
                                   q2.f2 AS a14,   SUM(q2.i3) AS i4
                           FROM (SELECT   ((q0.i0)/q1.i2) AS i3,
                                          COALESCE(q1.f2, q0.f0) AS f2,
                                          COALESCE(q1.a1, q0.a0) AS a1,
                                          COALESCE(q1.f3, q0.f1) AS f3
                                 FROM ( SELECT f.avg_incomingvoice AS i0,
                                               f.weight AS i1,
                                               f.START_TIME AS a0,
                                               f.network_element_CO_GID AS f0,
                                               f.wap_page_CO_GID AS f1
                                        FROM AVG_CEL_VOICETRAFFIC f
                                        WHERE (f.START_TIME >=
                                               TIMESTAMP '2007-04-13 00:00:00'
                                           AND f.START_TIME <
                                               TIMESTAMP '2007-07-20 00:00:00' )
                                      ) q0
                                      FULL OUTER JOIN
                                      ( SELECT f.ave_resp_time AS i2,
                                               f.START_TIME AS a1,
                                               f.network_element_CO_GID AS f2,
                                               f.wap_page_CO_GID AS f3
                                        FROM REQUESTS f
                                        WHERE  (f.START_TIME >=
                                                TIMESTAMP '2007-04-13 00:00:00'
                                            AND f.START_TIME <
                                                TIMESTAMP '2007-07-20 00:00:00' )
                                      ) q1 ON  (q0.f1=q1.f3 AND q0.f0=q1.f2
                                                AND q0.a0=q1.a1)
                                 WHERE  q1.i2<>0
                                ) q2
                           GROUP BY   q2.a1,   q2.f2,   q2.f2
                          ) f
                          INNER JOIN
                          (Select MOF_COMMON_OBJECTS.*,
                                  mof_common_objects.co_parent_gid source,
                                  mof_common_objects.co_gid target
                           from mof_common_objects
                           where mof_common_objects.co_parent_gid is not null
                             and mof_common_objects.co_mof_oc_id = 11540
                          ) d11 ON (f.a14=d11.TARGET)
                          INNER JOIN
                          (Select MOF_COMMON_OBJECTS.*
                           from MOF_COMMON_OBJECTS
                           where MOF_COMMON_OBJECTS.CO_MOF_OC_ID=11539
                          ) d12 ON (d11.SOURCE=d12.CO_GID)
                          INNER JOIN
                          (Select MOF_COMMON_OBJECTS.*,
                                  mof_common_objects.co_parent_gid source,
                                  mof_common_objects.co_gid target
                           from mof_common_objects
                           where mof_common_objects.co_parent_gid is not null
                             and mof_common_objects.co_mof_oc_id = 11540
                          ) d13 ON (f.a14=d13.TARGET)
                          INNER JOIN
                          (Select MOF_COMMON_OBJECTS.*,
                                  mof_common_objects.co_parent_gid source,
                                  mof_common_objects.co_gid target
                           from mof_common_objects
                           where mof_common_objects.co_parent_gid is not null
                             and mof_common_objects.co_mof_oc_id = 11539
                          ) d14 ON (d13.SOURCE=d14.TARGET)
                          INNER JOIN
                          (Select MOF_COMMON_OBJECTS.*
                           from MOF_COMMON_OBJECTS
                           where MOF_COMMON_OBJECTS.CO_MOF_OC_ID=11538
                          ) d15 ON (d14.SOURCE=d15.CO_GID)
                   GROUP BY f.a12,   d12.CO_GID,   d15.CO_GID
                  ) rnk
             WHERE (a5=rnk.a17) and (a0=rnk.a12) and (rank<=1)
            );
+-----+----+------+------+
| a10 | a6 | i1   | i3   |
+-----+----+------+------+
+-----+----+------+------+


#tkoqqkk.sql with modify
create table testwn1 (a number, b number, c number, d number, e number, f number);

create table testwn1cp (a int, b number, c int, d number, e number, f number)
partition by range (a) subpartition by hash (c) subpartitions 2
(partition p1 values less than (3),
 partition p2 values less than (6),
 partition p3 values less than (maxvalue));

create index testwn1_abcde on testwn1 (a, b, c, d, e);


create procedure insert_p1()
begin
  declare i int;
    set i = 0;
    while i < 999 do
    insert into testwn1 values (mod(i, 10), mod(i, 100), mod(i, 1000),
                                mod(i, 1000), mod(i, 100), mod(i, 10));
    insert into testwn1cp values (mod(i, 10), mod(i, 100), mod(i, 1000),
                                  mod(i, 1000), mod(i, 100), mod(i, 10));
      set i = i + 1;
    end while;
end
//
call insert_p1();

select a, b, c, rank() over (partition by a order by b) as w1,
             rank() over (partition by b order by a) as w2,
             rank() over (partition by b order by a desc) as w3,
             rank() over (partition by b, a order by c) as w4,
             rank() over (partition by a, b order by c desc) as w5,
             rank() over (partition by c, a, b order by d) as w6,
             rank() over (partition by a, b, c order by d, e desc) as w7
from testwn1 group by b, a, c, d, e order by b, a desc;
