#tkoqgbp.sql
SELECT NVL(SUM(1),0)
FROM (SELECT S.unique3, AVG(F.ten) AVG_ten,
             ROW_NUMBER() OVER (ORDER BY S.unique3 DESC ) SRNUM
      FROM G_4K S, T_10K F
      WHERE S.hundred = F.hundred
      GROUP BY S.unique3) VW;
+---------------+
| NVL(SUM(1),0) |
+---------------+
|            96 |
+---------------+

SELECT NVL(SUM(1),0)
FROM (SELECT S.unique3, AVG(F.ten) AVG_ten,
             ROW_NUMBER() OVER (ORDER BY S.unique3 DESC  ) SRNUM
      FROM G_4K S, T_10K F
      WHERE S.hundred = F.hundred
      GROUP BY S.unique3) VW;
+---------------+
| NVL(SUM(1),0) |
+---------------+
|            96 |
+---------------+

SELECT dcnt
FROM (SELECT COUNT(*) as dcnt,
             RANK() OVER (order by count(*) desc, 1) as drnk
      FROM DUAL);
