      over (order by (max(t1_100.char_unique))) as rank1
      from t1_100
           where t1_100.char_unique < t_5k.char_hund
               ) and t_5k.unique1 >3000)
UNION ALL
(select t_5k.unique1
from t_5k, t_4k
where t_5k.ten = t_4k.thousand
and  (t_5k.thousand, t_5k.hundred) =ANY
      (select ((t1_100.hundred)), rank()
       over (order by (max(t1_100.char_unique))) as rank1
       from t1_100
       where t1_100.char_unique < t_5k.char_hund )
and t_5k.unique1 >3000);
+---------+
| unique1 |
+---------+
+---------+

#tkoqapcd.sql
select t_5k.unique1
      from t_5k, t_4k
      where t_5k.ten = mod(t_4k.thousand,10)
      and  (t_5k.thousand, t_5k.hundred) =ANY
      (select count(distinct t1_100.hundred), rank()
      over (order by (max(t1_100.char_unique))) as rank1
         from t1_100
              where t1_100.char_unique < t_5k.char_hund
              ) and t_5k.unique1 >3000 order by 1;
+---------+
| unique1 |
+---------+
+---------+

select t_5k.unique1
      from t_5k, t_4k
      where t_5k.ten = mod(t_4k.thousand,10)
      and  (mod(t_5k.thousand,10), mod(t_5k.hundred,11)) <>ANY
      (select mod(approx_count_distinct(t1_100.hundred),8),
	  mod(rank()
      over (order by (max(t1_100.char_unique))),10) as rank1
         from t1_100
              where t1_100.char_unique < t_5k.char_hund
              ) and t_5k.unique1 >3000 order by 1;
