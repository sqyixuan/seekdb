#tkoqsqbg.sql
select count(*)
from sales s
where quantity_sold > 2 and
  exists (select rank() over (order by prod_category) as rnk
          from products p
          where p.prod_id = s.prod_id);
+----------+
| count(*) |
+----------+
|        2 |
+----------+

select distinct count(*) over (partition by empno) cnt
from emp e1
where deptno in (select /*+ unnest */ deptno
                from emp e2
                where deptno>10  and deptno in (select deptno
                                               from emp
                                               where deptno <40
                                       ));
+------+
| cnt  |
+------+
|    1 |
+------+

CREATE TABLE t24576570_1( ELCAP_DCMNT_NO VARCHAR(32 ) NOT NULL);

CREATE TABLE t24576570_2(
  EMPLMN_REQST_NO              VARCHAR(24 ) NOT NULL,
  SKLSTF_NO                    VARCHAR(15 ) NOT NULL,
  EMPLMN_CODE                  VARCHAR(14 ),
  ELCAP_DCMNT_NO               VARCHAR(32 )
 );

CREATE TABLE t24576570_3(
  RSRCH_PROFSR_REQST_NO   VARCHAR(24 )     NOT NULL,
  SKLSTF_NO               VARCHAR(15 )     NOT NULL,
  ELCAP_DCMNT_NO          VARCHAR(32 )
 );

CREATE TABLE t24576570_4(
  SKLSTF_NO                   VARCHAR(15 ) NOT NULL,
  EMPLMN_CODE                 VARCHAR(14 )
);

SELECT
       (SELECT EMPLMN_CODE
         FROM   (SELECT B.EMPLMN_CODE
               FROM   t24576570_2 B
               UNION
                SELECT B.EMPLMN_CODE
               FROM   t24576570_2 B
               WHERE  B.SKLSTF_NO= A.SKLSTF_NO
               AND    EXISTS(
                         SELECT 'X'
                         FROM   t24576570_1
                         WHERE  ELCAP_DCMNT_NO=B.ELCAP_DCMNT_NO
                       )
               )
       ) STATS_HFFC_SE_CODE
    , (SELECT RN
       FROM   (SELECT ROW_NUMBER() OVER(PARTITION BY RSRCH_PROFSR_REQST_NO
                      ORDER BY RSRCH_PROFSR_REQST_NO DESC ) RN
               FROM   t24576570_3 B
              ) Z
       ) SBBYR_SE_CODE
FROM   t24576570_4 A;
+--------------------+---------------+
| STATS_HFFC_SE_CODE | SBBYR_SE_CODE |
+--------------------+---------------+
+--------------------+---------------+
#tkoqsqex.sql
select t_5k.unique1, rank() over (order by (t_5k.unique1)),t_4k.unique1
from t_5k, t_4k
where t_5k.thousand = t_4k.thousand
and t_5k.thousand = 599
and t_5k.ten is not null
and t_5k.ten != ALL (select /*+ unnest */ z_4k.ten from z_4k
        where z_4k.char_hund >= t_5k.char_unique)
order by t_5k.unique1, t_4k.unique1;
+---------+---------------------------------------+---------+
| unique1 | rank() over (order by (t_5k.unique1)) | unique1 |
+---------+---------------------------------------+---------+
|    1599 |                                     1 |    1599 |
|    1599 |                                     1 |    3599 |
|    3599 |                                     3 |    1599 |
|    3599 |                                     3 |    3599 |
+---------+---------------------------------------+---------+

select t_5k.unique1, rank() over (order by (t_5k.unique1)),t_4k.unique1
from t_5k, t_4k
where t_5k.thousand = t_4k.thousand
and t_5k.thousand = 767
and t_5k.ten is not null
and t_5k.ten != ALL (select /*+ unnest */ z_4k.ten from z_4k
        where z_4k.char_hund like 'AAA%' and z_4k.ten <> 7 )
order by t_5k.unique1, t_4k.unique1;
+---------+---------------------------------------+---------+
| unique1 | rank() over (order by (t_5k.unique1)) | unique1 |
+---------+---------------------------------------+---------+
|    2767 |                                     1 |    2767 |
|    2767 |                                     1 |    3767 |
|    3767 |                                     3 |    2767 |
|    3767 |                                     3 |    3767 |
+---------+---------------------------------------+---------+

select t_5k.unique1, ntile(3) over (order by (t_5k.unique1)) as ntile_5k,
t_4k.unique1
from t_5k, t_4k
where t_5k.ten = mod(t_4k.thousand, 12)
and t_5k.unique1 >= 3500
and EXISTS (select (z_4k.unique2)
        from z_4k, g_4k
        where z_4k.ten = g_4k.thousand
        and z_4k.ten = 1
        and g_4k.thousand = t_5k.hundred)
order by t_5k.unique1, t_4k.unique1;
