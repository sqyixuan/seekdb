#tkoqorei.sql
select col
from
  (select d1.ten dten, e1.hundred edno,
   rank() over (partition by e1.ten order by e1.hundred) as col
         from
         t_4k e1, t_5k d1
         where d1.unique3 = e1.hundred
         OR d1.unique1<e1.ten
         OR e1.unique2=9)v
where dten = 8 OR edno<=20;
