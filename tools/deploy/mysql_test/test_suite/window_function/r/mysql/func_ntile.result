result_format: 3
set @@recyclebin = off;
drop table if exists t1;
create table t1 (c1 int primary key, c2 int, c3 int, c4 varchar(100));
insert into t1 values (1,1,3, 'fdsf');
insert into t1 values (2,2,2, '1fdfdsf');
insert into t1 values (3,2,1, 'kkkkk');
insert into t1 values (4,3,2, '8y77');
insert into t1 values (5,3,6, 'fdfd');
insert into t1 values (6,3,6, 'mnn');
insert into t1 values (7,4,2, '6fe');
insert into t1 values (8,4,1, 'kk');
insert into t1 values (9,4,1, 'kk');
insert into t1 values (10,4,3, 'kk');
select *, ntile(3) over (order by c1), ntile(3) over (partition by c1 order by c1), ntile(3) over (partition by c2 order by c1) from t1;
+----+------+------+---------+-----------------------------+---------------------------------------------+---------------------------------------------+
| c1 | c2   | c3   | c4      | ntile(3) over (order by c1) | ntile(3) over (partition by c1 order by c1) | ntile(3) over (partition by c2 order by c1) |
+----+------+------+---------+-----------------------------+---------------------------------------------+---------------------------------------------+
|  1 |    1 |    3 | fdsf    |                           1 |                                           1 |                                           1 |
|  2 |    2 |    2 | 1fdfdsf |                           1 |                                           1 |                                           1 |
|  3 |    2 |    1 | kkkkk   |                           1 |                                           1 |                                           2 |
|  4 |    3 |    2 | 8y77    |                           1 |                                           1 |                                           1 |
|  5 |    3 |    6 | fdfd    |                           2 |                                           1 |                                           2 |
|  6 |    3 |    6 | mnn     |                           2 |                                           1 |                                           3 |
|  7 |    4 |    2 | 6fe     |                           2 |                                           1 |                                           1 |
|  8 |    4 |    1 | kk      |                           3 |                                           1 |                                           1 |
|  9 |    4 |    1 | kk      |                           3 |                                           1 |                                           2 |
| 10 |    4 |    3 | kk      |                           3 |                                           1 |                                           3 |
+----+------+------+---------+-----------------------------+---------------------------------------------+---------------------------------------------+
select ntile(-1) over (order by c1) from t1 where c1 = 1;
ERROR HY000: Invalid argument
select ntile(0) over (order by c1) from t1 where c1 = 1;
ERROR HY000: Invalid argument
select ntile(9223372036854775808) over (order by c1) from t1 where c1 = 1;
ERROR HY000: Invalid argument
select ntile(9223372036854775808 - 1) over (order by c1) from t1 where c1 = 1;
+---------------------------------------------------+
| ntile(9223372036854775808 - 1) over (order by c1) |
+---------------------------------------------------+
|                                                 1 |
+---------------------------------------------------+
select ntile(1 << 63) over (order by c1) from t1 where c1 = 1;
ERROR HY000: Invalid argument
select ntile(1 << 63 - 1) over (order by c1) from t1 where c1 = 1;
+---------------------------------------+
| ntile(1 << 63 - 1) over (order by c1) |
+---------------------------------------+
|                                     1 |
+---------------------------------------+
select ntile(1.2) over (order by c1) from t1 where c1 = 1;
ERROR HY000: Incorrect arguments to ntile
select ntile(100) over (order by c1) from t1 where c1 in (4,5,6) order by c1;
+-------------------------------+
| ntile(100) over (order by c1) |
+-------------------------------+
|                             1 |
|                             2 |
|                             3 |
+-------------------------------+
set @@recyclebin = off;
drop table t1;
