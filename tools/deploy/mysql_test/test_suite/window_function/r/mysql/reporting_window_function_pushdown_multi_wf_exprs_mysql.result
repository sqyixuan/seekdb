result_format: 4
## NON-VECTORIZED
## 使用错误注入 EN_ENFORCE_PUSH_DOWN_WF，无视 ndv 和 dop 的关系，强行让可以走两阶段下压的 window function 走两阶段下压
alter system set_tp tp_no = 247, error_code = 4000, frequency = 1;
alter system set _rowsets_enabled = false;

## 准备数据
drop table if exists t1;
CREATE TABLE t1
WITH RECURSIVE my_cte(c1, c2, c3, c4) AS
(
  SELECT 0, 0, 1, 1
  UNION ALL
  SELECT round((c4 + 1) / 5, 0), round((c4 + 1) / 3, 0), round((c4 + 1) / 2, 0), c4 + 1  FROM my_cte WHERE c4 < 15
)
SELECT * FROM my_cte;
call dbms_stats.gather_table_stats('TEST', 'T1', method_opt=>'for all columns size auto', estimate_percent=>100);
select * from t1;
+------+------+------+------+
| c1   | c2   | c3   | c4   |
+------+------+------+------+
|    0 |    0 |    1 |    1 |
|    0 |    1 |    1 |    2 |
|    1 |    1 |    2 |    3 |
|    1 |    1 |    2 |    4 |
|    1 |    2 |    3 |    5 |
|    1 |    2 |    3 |    6 |
|    1 |    2 |    4 |    7 |
|    2 |    3 |    4 |    8 |
|    2 |    3 |    5 |    9 |
|    2 |    3 |    5 |   10 |
|    2 |    4 |    6 |   11 |
|    2 |    4 |    6 |   12 |
|    3 |    4 |    7 |   13 |
|    3 |    5 |    7 |   14 |
|    3 |    5 |    8 |   15 |
+------+------+------+------+

## 默认开启 reporting wf 两阶段下压
set _windowfunc_optimization_settings = 0;
explain_protocol: 1
EXPLAIN BASIC select /*+parallel(3) */c1, c2, c3, c4, max(c1) over (partition by c1), min(c2) over (partition by c1), sum(c3) over (partition by c1), count(c4) over (partition by c1) from t1 order by c1, c2, c3, c4;
Query Plan
==========================================================
|ID|OPERATOR                                    |NAME    |
----------------------------------------------------------
|0 |PX COORDINATOR MERGE SORT                   |        |
|1 |└─EXCHANGE OUT DISTR                        |:EX10001|
|2 |  └─MATERIAL                                |        |
|3 |    └─SORT                                  |        |
|4 |      └─WINDOW FUNCTION CONSOLIDATOR        |        |
|5 |        └─EXCHANGE IN MERGE SORT DISTR      |        |
|6 |          └─EXCHANGE OUT DISTR (HASH HYBRID)|:EX10000|
|7 |            └─WINDOW FUNCTION               |        |
|8 |              └─SORT                        |        |
|9 |                └─PX BLOCK ITERATOR         |        |
|10|                  └─TABLE FULL SCAN         |t1      |
==========================================================
Outputs & filters:
-------------------------------------
  0 - output([INTERNAL_FUNCTION(t1.c1, t1.c2, t1.c3, t1.c4, T_FUN_MAX(T_FUN_MAX(t1.c1)), T_FUN_MIN(T_FUN_MIN(t1.c2)), T_FUN_SUM(T_FUN_SUM(t1.c3)), T_FUN_COUNT_SUM(T_FUN_COUNT(t1.c4)))]), filter(nil)
      sort_keys([t1.c1, ASC], [t1.c2, ASC], [t1.c3, ASC], [t1.c4, ASC])
  1 - output([t1.c1], [t1.c2], [t1.c3], [t1.c4], [INTERNAL_FUNCTION(t1.c1, t1.c2, t1.c3, t1.c4, T_FUN_MAX(T_FUN_MAX(t1.c1)), T_FUN_MIN(T_FUN_MIN(t1.c2)),
       T_FUN_SUM(T_FUN_SUM(t1.c3)), T_FUN_COUNT_SUM(T_FUN_COUNT(t1.c4)))]), filter(nil)
      dop=3
  2 - output([t1.c1], [t1.c2], [t1.c3], [t1.c4], [T_FUN_MAX(T_FUN_MAX(t1.c1))], [T_FUN_MIN(T_FUN_MIN(t1.c2))], [T_FUN_SUM(T_FUN_SUM(t1.c3))], [T_FUN_COUNT_SUM(T_FUN_COUNT(t1.c4))]), filter(nil)
  3 - output([t1.c1], [t1.c2], [t1.c3], [t1.c4], [T_FUN_MAX(T_FUN_MAX(t1.c1))], [T_FUN_MIN(T_FUN_MIN(t1.c2))], [T_FUN_SUM(T_FUN_SUM(t1.c3))], [T_FUN_COUNT_SUM(T_FUN_COUNT(t1.c4))]), filter(nil)
      sort_keys([t1.c1, ASC], [t1.c2, ASC], [t1.c3, ASC], [t1.c4, ASC]), prefix_pos(1)
  4 - output([t1.c1], [t1.c2], [t1.c3], [t1.c4], [T_FUN_MAX(T_FUN_MAX(t1.c1))], [T_FUN_MIN(T_FUN_MIN(t1.c2))], [T_FUN_SUM(T_FUN_SUM(t1.c3))], [T_FUN_COUNT_SUM(T_FUN_COUNT(t1.c4))]), filter(nil)
      win_expr(T_FUN_MAX(T_FUN_MAX(t1.c1))), partition_by([t1.c1]), order_by(nil), window_type(RANGE), upper(UNBOUNDED PRECEDING), lower(UNBOUNDED FOLLOWING)
      win_expr(T_FUN_MIN(T_FUN_MIN(t1.c2))), partition_by([t1.c1]), order_by(nil), window_type(RANGE), upper(UNBOUNDED PRECEDING), lower(UNBOUNDED FOLLOWING)
      win_expr(T_FUN_SUM(T_FUN_SUM(t1.c3))), partition_by([t1.c1]), order_by(nil), window_type(RANGE), upper(UNBOUNDED PRECEDING), lower(UNBOUNDED FOLLOWING)
      win_expr(T_FUN_COUNT_SUM(T_FUN_COUNT(t1.c4))), partition_by([t1.c1]), order_by(nil), window_type(RANGE), upper(UNBOUNDED PRECEDING), lower(UNBOUNDED 
      FOLLOWING)
  5 - output([t1.c1], [t1.c2], [t1.c3], [t1.c4], [AGGR_STATUS], [T_FUN_MAX(t1.c1)], [T_FUN_MIN(t1.c2)], [T_FUN_SUM(t1.c3)], [T_FUN_COUNT(t1.c4)]), filter(nil)
      sort_keys([t1.c1, ASC], [AGGR_STATUS, DESC])
  6 - output([t1.c1], [t1.c2], [t1.c3], [t1.c4], [AGGR_STATUS], [T_FUN_MAX(t1.c1)], [T_FUN_MIN(t1.c2)], [T_FUN_SUM(t1.c3)], [T_FUN_COUNT(t1.c4)]), filter(nil)
      (#keys=1, [t1.c1]), dop=3
  7 - output([t1.c1], [t1.c2], [t1.c3], [t1.c4], [AGGR_STATUS], [T_FUN_MAX(t1.c1)], [T_FUN_MIN(t1.c2)], [T_FUN_SUM(t1.c3)], [T_FUN_COUNT(t1.c4)]), filter(nil)
      win_expr(T_FUN_MAX(t1.c1)), partition_by([t1.c1]), order_by(nil), window_type(RANGE), upper(UNBOUNDED PRECEDING), lower(UNBOUNDED FOLLOWING)
      win_expr(T_FUN_MIN(t1.c2)), partition_by([t1.c1]), order_by(nil), window_type(RANGE), upper(UNBOUNDED PRECEDING), lower(UNBOUNDED FOLLOWING)
      win_expr(T_FUN_SUM(t1.c3)), partition_by([t1.c1]), order_by(nil), window_type(RANGE), upper(UNBOUNDED PRECEDING), lower(UNBOUNDED FOLLOWING)
      win_expr(T_FUN_COUNT(t1.c4)), partition_by([t1.c1]), order_by(nil), window_type(RANGE), upper(UNBOUNDED PRECEDING), lower(UNBOUNDED FOLLOWING)
  8 - output([t1.c1], [t1.c2], [t1.c3], [t1.c4]), filter(nil)
      sort_keys([t1.c1, ASC])
  9 - output([t1.c1], [t1.c2], [t1.c3], [t1.c4]), filter(nil)
 10 - output([t1.c1], [t1.c2], [t1.c3], [t1.c4]), filter(nil)
      access([t1.c1], [t1.c2], [t1.c3], [t1.c4]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t1.__pk_increment]), range(MIN ; MAX)always true
