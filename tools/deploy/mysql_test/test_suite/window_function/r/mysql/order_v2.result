drop database if exists wf;
create database wf;
use wf;
create table t1(a int primary key, b int, c varchar(20), d int);
insert into t1 values(1, 1, "121", 4);
insert into t1 values(2, -1, "3f1", 400);
insert into t1 values(3, 4, "hh1", 19);
insert into t1 values(4, 6, "c1", 4);
insert into t1 values(5, 2, "c1", 23);
insert into t1 values(6, -3, "a1", 4);
insert into t1 values(7, 3, "21", 41);
insert into t1 values(8, 8, "b1", 32);
insert into t1 values(9, 3, "ha", 1);
insert into t1 values(10, 19, "he", 3);
select a, b, first_value(a) over(order by 2) from t1;
ERROR HY000: Window '<unnamed window>': ORDER BY or PARTITION BY uses legacy position indication which is not supported use expression.
select a, b, first_value(a) over(order by b, a + b) from t1;
a	b	first_value(a) over(order by b, a + b)
6	-3	6
2	-1	6
1	1	6
5	2	6
7	3	6
9	3	6
3	4	6
4	6	6
8	8	6
10	19	6
select a, b, first_value(a) over(order by b,c range 1 preceding) from t1;
ERROR HY000: Invalid use of window function
select a, b, first_value(a) over(order by b range 1 preceding) from t1 where a = 1;
a	b	first_value(a) over(order by b range 1 preceding)
1	1	1
select a as aa, count(1) over(order by aa) from t1;
ERROR 42S22: Unknown column 'aa' in 'field list'
select count(1) over(order by count(1)) from t1;
count(1) over(order by count(1))
1
select count(1) over(order by count(1) over()) from t1;
ERROR HY000: Invalid use of window function
select count(1) over(order siblings by a) from t1;
ERROR 42000: You have an error in your SQL syntax; check the manual that corresponds to your OceanBase version for the right syntax to use near 'siblings by a) from t1' at line 1
select count(1) over(order by a NULLS first) from t1;
ERROR 42000: You have an error in your SQL syntax; check the manual that corresponds to your OceanBase version for the right syntax to use near 'NULLS first) from t1' at line 1
select count(1) over(order by a NULLS last) from t1;
ERROR 42000: You have an error in your SQL syntax; check the manual that corresponds to your OceanBase version for the right syntax to use near 'NULLS last) from t1' at line 1
drop database if exists wf;
