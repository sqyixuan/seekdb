result_format: 3
set @@recyclebin = off;
drop table if exists t1;
create table t1 (c1 int primary key, c2 int, c3 int, c4 varchar(100));
insert into t1 values (1,1,3, 'fdsf');
insert into t1 values (2,2,2, '1fdfdsf');
insert into t1 values (3,2,1, 'kkkkk');
insert into t1 values (4,3,2, NULL);
insert into t1 values (5,3,6, NULL);
insert into t1 values (6,3,6, 'mnn');
insert into t1 values (7,4,2, '6fe');
insert into t1 values (8,4,1, 'kk');
insert into t1 values (9,4,1, 'kk');
insert into t1 values (10,4,3, 'kk');
select *, count(1) over (), count(1) over (partition by c1), count(1) over (partition by c2), count(1) over (partition by c4) from t1 order by c1;
+----+------+------+---------+------------------+---------------------------------+---------------------------------+---------------------------------+
| c1 | c2   | c3   | c4      | count(1) over () | count(1) over (partition by c1) | count(1) over (partition by c2) | count(1) over (partition by c4) |
+----+------+------+---------+------------------+---------------------------------+---------------------------------+---------------------------------+
|  1 |    1 |    3 | fdsf    |               10 |                               1 |                               1 |                               1 |
|  2 |    2 |    2 | 1fdfdsf |               10 |                               1 |                               2 |                               1 |
|  3 |    2 |    1 | kkkkk   |               10 |                               1 |                               2 |                               1 |
|  4 |    3 |    2 | NULL    |               10 |                               1 |                               3 |                               2 |
|  5 |    3 |    6 | NULL    |               10 |                               1 |                               3 |                               2 |
|  6 |    3 |    6 | mnn     |               10 |                               1 |                               3 |                               1 |
|  7 |    4 |    2 | 6fe     |               10 |                               1 |                               4 |                               1 |
|  8 |    4 |    1 | kk      |               10 |                               1 |                               4 |                               3 |
|  9 |    4 |    1 | kk      |               10 |                               1 |                               4 |                               3 |
| 10 |    4 |    3 | kk      |               10 |                               1 |                               4 |                               3 |
+----+------+------+---------+------------------+---------------------------------+---------------------------------+---------------------------------+
select count(1) over (order by c1 rows between 1 preceding and 2 preceding) from t1 where c1 = 1;
+----------------------------------------------------------------------+
| count(1) over (order by c1 rows between 1 preceding and 2 preceding) |
+----------------------------------------------------------------------+
|                                                                    0 |
+----------------------------------------------------------------------+
select count(c2) over (), count(distinct c2) over () from t1 where c1 in (4,5,6) order by c1;
+-------------------+----------------------------+
| count(c2) over () | count(distinct c2) over () |
+-------------------+----------------------------+
|                 3 |                          1 |
|                 3 |                          1 |
|                 3 |                          1 |
+-------------------+----------------------------+
set @@recyclebin = off;
drop table t1;
