explain_protocol: 2
###### 1. one rank winfunc ###################
EXPLAIN select /*+PQ_DISTRIBUTE_WINDOW(@"SEL$2" (0) NONE PARTITION_SORT WF_TOPN)*/ count(*) from (select c1,c2,c0,rank() over (partition by c1,c2 order by c0) rk from wf_hash) where rk = 1;
Query Plan
=====================================================================
|ID|OPERATOR                  |NAME           |EST.ROWS|EST.TIME(us)|
---------------------------------------------------------------------
|0 |SCALAR GROUP BY           |               |1       |799         |
|1 |└─SUBPLAN SCAN            |ANONYMOUS_VIEW1|16      |799         |
|2 |  └─WINDOW FUNCTION       |               |16      |799         |
|3 |    └─PARTITION TOP-N SORT|               |16      |786         |
|4 |      └─TABLE FULL SCAN   |wf_hash        |5144    |373         |
=====================================================================
Outputs & filters:
-------------------------------------
  0 - output([T_FUN_COUNT(*)]), filter(nil), rowset=256
      group(nil), agg_func([T_FUN_COUNT(*)])
  1 - output(nil), filter(nil), rowset=256
      access(nil)
  2 - output([1]), filter([T_WIN_FUN_RANK() = 1]), rowset=256
      win_expr(T_WIN_FUN_RANK()), partition_by([wf_hash.c1], [wf_hash.c2]), order_by([wf_hash.c0, ASC]), window_type(RANGE), upper(UNBOUNDED PRECEDING),
       lower(UNBOUNDED FOLLOWING)
  3 - output([wf_hash.c1], [wf_hash.c2], [wf_hash.c0]), filter(nil), rowset=256
      sort_keys([HASH(wf_hash.c1, wf_hash.c2), ASC], [wf_hash.c1, ASC], [wf_hash.c2, ASC], [wf_hash.c0, ASC]), topn(1), with_ties(true)
  4 - output([wf_hash.c1], [wf_hash.c2], [wf_hash.c0]), filter([TOPN_FILTER(wf_hash.c1, wf_hash.c2, wf_hash.c0)]), rowset=256
      access([wf_hash.c1], [wf_hash.c2], [wf_hash.c0]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([wf_hash.__pk_increment]), range(MIN ; MAX)always true
