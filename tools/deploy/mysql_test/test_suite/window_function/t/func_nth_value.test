# owner group: sql1
# description:
#
# test of rank

--result_format 3
--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
set @@recyclebin = off;
drop table if exists t1;
--enable_warnings

create table t1 (c1 int primary key, c2 int, c3 int, c4 varchar(100));
insert into t1 values (1,1,3, 'fdsf');
insert into t1 values (2,2,2, NULL);
insert into t1 values (3,2,1, 'fdsf');
insert into t1 values (4,3,2, '8y77');
insert into t1 values (5,3,6, NULL);
insert into t1 values (6,3,6, 'mnn');
insert into t1 values (7,4,2, '6fe');
insert into t1 values (8,4,1, 'kk');
insert into t1 values (9,4,1, 'kk');
insert into t1 values (10,4,3, 'kk');

select *, nth_value(c4, 1) over (order by c1), nth_value(c4, 1) over (partition by c1 order by c1), nth_value(c4, 1) over (partition by c2 order by c1) from t1;

# ignore nulls
select *, nth_value(c4, 1) over (order by c1), nth_value(c4 , 1) respect NULLS over (order by c1), nth_value(c4,1) ignore NULLs over (order by c1) from t1 where c1 in (2,3) order by c1;


--error 1064
select nth_value(c4) over (order by c1) from t1;

select *, nth_value(c4,1) over (order by c1), nth_value(c4, 1) from first respect NULLS over (order by c1), nth_value(c4, 1) ignore NULLS over (order by c1) from t1 where c1 in (2,3) order by c1; 
select *, nth_value(c4,2) over (order by c1), nth_value(c4, 1) from last respect NULLS over (order by c1), nth_value(c4, 1) from last ignore NULLS over (order by c1) from t1 where c1 in (4,5) order by c1; 

set @@recyclebin = off;
drop table t1;















