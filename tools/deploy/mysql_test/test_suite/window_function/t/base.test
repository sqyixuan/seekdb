#owner: zongmei.zzm
#owner group: sql1
# tags: optimizer
#description:

--disable_warnings
drop database if exists wf;
create database wf;
use wf;
--disable_warnings

create table t1(a int primary key, b int, c varchar(20), d int);

insert into t1 values(1, 1, "121", 4);
insert into t1 values(2, -1, "3f1", 400);
insert into t1 values(3, 4, "hh1", 19);
insert into t1 values(4, 6, "c1", 4);
insert into t1 values(5, 2, "c1", 23);
insert into t1 values(6, -3, "a1", 4);
insert into t1 values(7, 3, "21", 41);
insert into t1 values(8, 8, "b1", 32);
insert into t1 values(9, 3, "ha", 1);
insert into t1 values(10, 19, "he", 3);

select * from t1;

#explain select a, row_number() over(partition by b order by c desc) as rn, max(b) over(partition by a) as mb from t1;

select t1.*, row_number() over(order by b) as rn from t1;
select t1.*, row_number() over(partition by b order by c desc) as rn from t1;
select t1.*, max(d) over(partition by b) as mb from t1;

#new
create table score_tbl(school int, class int, student int, primary key(school, class, student), score int);
insert into score_tbl values(1, 1, 1, 90);
insert into score_tbl values(1, 1, 2, 70);
insert into score_tbl values(1, 1, 3, 80);
insert into score_tbl values(1, 1, 4, 65);
insert into score_tbl values(1, 2, 5, 98);
insert into score_tbl values(1, 2, 6, 40);
insert into score_tbl values(1, 2, 7, 86);
insert into score_tbl values(1, 2, 8, 77);
insert into score_tbl values(1, 2, 9, 81);
insert into score_tbl values(2, 1, 1, 63);
insert into score_tbl values(2, 1, 2, 73);
insert into score_tbl values(2, 1, 3, 92);
insert into score_tbl values(2, 1, 4, 56);
insert into score_tbl values(2, 2, 5, 74);
insert into score_tbl values(2, 2, 6, 99);
insert into score_tbl values(2, 2, 7, 80);
insert into score_tbl values(2, 2, 8, 55);
insert into score_tbl values(2, 2, 9, 32);

select score_tbl.*, max(score) over(partition by school, class order by score rows between 1 preceding and 2 following) as m from score_tbl;
select score_tbl.*, max(score) over(partition by school, class order by score rows between 2 preceding and 1 preceding) as m from score_tbl;
select score_tbl.*, max(score) over(partition by school, class order by score rows between 1 following and 2 following) as m from score_tbl;
select score_tbl.*, max(score) over(partition by school, class order by score rows 1 preceding) as m from score_tbl;
select score_tbl.*, max(score) over(partition by school, class order by score rows current row) as m from score_tbl;
select score_tbl.*, max(score) over(partition by school, class order by score rows unbounded preceding) as m from score_tbl;

# 兼容oracle的几个特殊case
# 对于rows窗口, 浮点数会被取整后计算
--error 3586
(select score_tbl.*, max(score) over(partition by school, class order by score rows between 1.2 preceding and 2.7 following) as m from score_tbl) except (select score_tbl.*, max(score) over(partition by school, class order by score rows between 1 preceding and 2 following) as m from score_tbl);
--error 3586
(select score_tbl.*, max(score) over(partition by school, class order by score rows between 1.0 preceding and 2.0 following) as m from score_tbl) except (select score_tbl.*, max(score) over(partition by school, class order by score rows between 1 preceding and 2 following) as m from score_tbl);
# 上界大于下界的无效窗口, 总是返回空值
select score_tbl.*, max(score) over(partition by school, class order by score rows between 1 preceding and 2 preceding) as m from score_tbl;
select score_tbl.*, max(score) over(partition by school, class order by score rows between 2 following and 1 following) as m from score_tbl;

select score_tbl.*, max(score) over(partition by school, class order by score rows between unbounded preceding and unbounded following) as m from score_tbl;
select score_tbl.*, max(score) over(partition by school, class order by score rows between unbounded preceding and current row) as m from score_tbl;
select score_tbl.*, max(score) over(partition by school, class order by score rows between unbounded preceding and 2 following) as m from score_tbl;
select score_tbl.*, max(score) over(partition by school, class order by score rows between current row and unbounded following) as m from score_tbl;
select score_tbl.*, max(score) over(partition by school, class order by score rows between current row and current row) as m from score_tbl;
select score_tbl.*, max(score) over(partition by school, class order by score rows between current row and 2 following) as m from score_tbl;
select score_tbl.*, max(score) over(partition by school, class order by score rows between 2 preceding and unbounded following) as m from score_tbl;
select score_tbl.*, max(score) over(partition by school, class order by score rows between 2 preceding and current row) as m from score_tbl;
select score_tbl.*, max(score) over(partition by school, class order by score rows between 2 preceding and 2 following) as m from score_tbl;

--disable_warnings
drop table if exists t1;
drop table if exists t2;
--enable_warnings

create table t1 (a int, b int);
create table t2 (a int, b int);
insert into t1 values (1, 1);
insert into t2 values (2, 2);

explain
select /*+no_rewrite*/
  if(
    EXISTS (
      select
        11 as c0,
        71 as c1,
        14 as c2
      from
        t1 as ref_1
      where
        41 <=> 14
    ),
    std(cast(cast(null as CHAR) as CHAR)) over (
      partition by ref_0.a,
      ref_0.a
      order by
        ref_0.a
    ),
    LAG(cast("test" as CHAR)) over (
      partition by ref_0.a,
      ref_0.a
      order by
        ref_0.a
    )
  ) as c0,
  (
    select
      b
    from
      t2
    order by
      1 desc
    limit
      1 offset 2
  ) as c1,
  LEAD(cast(60 as DECIMAL)) over (
    partition by ref_0.a
    order by
      ref_0.a
  ) as c2
from
  t1 as ref_0
where
  ref_0.a MOD ref_0.a
limit
  145;

select /*+no_rewrite*/
  if(
    EXISTS (
      select
        11 as c0,
        71 as c1,
        14 as c2
      from
        t1 as ref_1
      where
        41 <=> 14
    ),
    std(cast(cast(null as CHAR) as CHAR)) over (
      partition by ref_0.a,
      ref_0.a
      order by
        ref_0.a
    ),
    LAG(cast("test" as CHAR)) over (
      partition by ref_0.a,
      ref_0.a
      order by
        ref_0.a
    )
  ) as c0,
  (
    select
      b
    from
      t2
    order by
      1 desc
    limit
      1 offset 2
  ) as c1,
  LEAD(cast(60 as DECIMAL)) over (
    partition by ref_0.a
    order by
      ref_0.a
  ) as c2
from
  t1 as ref_0
where
  ref_0.a MOD ref_0.a
limit
  145;

--disable_warnings
drop database if exists wf;
--disable_warnings
