--disable_warnings
drop table if exists t0,t1;
--enable_warnings
--explain_protocol 0
CREATE TABLE IF NOT EXISTS t0(c0 DATETIME  NULL COMMENT 'asdf' , c1 MEDIUMTEXT )  PARTITION BY KEY (c0) partitions 13;
CREATE TABLE t1 LIKE t0;
CREATE INDEX i750 USING BTREE ON t1(c0, c1(1)) ;
--explain_protocol 2
(SELECT * FROM (SELECT ALL t1.c0 AS C0, t1.c1 AS C1, DENSE_RANK() over(partition by t1.c1, t1.c0 order by t1.c1, t1.c0 asc) AS WF0, DENSE_RANK() over( order by t1.c0, t1.c1 desc) AS WF1 FROM t1) L0 WHERE ((-1,"1543498115") NOT IN ((WF1,C1))) || ((WF0) NOT IN ((FALSE))) ORDER BY C0 DESC) UNION ALL (SELECT ALL * FROM (SELECT /*+ index(t1 i750) */ ALL t1.c0 AS C0, t1.c1 AS C1, DENSE_RANK() over(partition by t1.c1, t1.c0 order by t1.c1, t1.c0 asc) AS WF0, DENSE_RANK() over( order by t1.c0, t1.c1 desc) AS WF1 FROM t1) L0 WHERE (NOT (((-1,"1543498115") NOT IN ((WF1,C1))) || ((WF0) NOT IN ((FALSE))))) ORDER BY C0 DESC);

