--disable_warnings
drop table if exists t0;
--enable_warnings
--explain_protocol 0
CREATE TABLE IF NOT EXISTS t0(c0 FLOAT(30, 24) , c1 VARCHAR(500) , c2 TINYTEXT  COMMENT 'asdf' )  PARTITION BY KEY (c1) partitions 9;
INSERT /*+NO_GATHER_OPTIMIZER_STATISTICS GATHER_OPTIMIZER_STATISTICS parallel(8) enable_parallel_dml */ INTO t0(c2) VALUES('O''*Y5Nw3~e|us><ZN('), (''), ('EtY*^6BhRdUrt>7|^dFg\\2v_D+I');
INSERT /*+NO_GATHER_OPTIMIZER_STATISTICS GATHER_OPTIMIZER_STATISTICS */ INTO t0(c2) VALUES ROW("") ON DUPLICATE KEY UPDATE c1='f1>9JZhoznSQ4VVdm1sz_P7Eby>/';
INSERT /*+parallel(4) enable_parallel_dml */ INTO t0(c2, c1, c0) VALUES('S ?uyKd', '(Pod', -92.40563077335922), ("'*v]l4t4z1bI%4IIA[u-r-a19&", '', 3.823226395071904), ("mNr?qD6?&zBH_kV41PZRIue|bvt]", "[", 34.83963961010326), ('(XYryqH*SPl&b!-t9K}*', "34548320", 121.8799083925519) ON DUPLICATE KEY UPDATE c2="-1631443671";
REPLACE INTO t0(c0) select c0 from t0;

--explain_protocol 2
SELECT /*+ ORDERED  */ ALL concat(t0.c0,'') AS C0, t0.c1 AS C1, t0.c2 AS C2, ROW_NUMBER() over(partition by t0.c2, t0.c1, t0.c0 order by t0.c0, t0.c2, t0.c1 desc) AS WF0 FROM t0;
SELECT ALL count(*) FROM (SELECT /*+ ORDERED  */ ALL concat(t0.c0,'') AS C0, t0.c1 AS C1, t0.c2 AS C2, ROW_NUMBER() over(partition by t0.c2, t0.c1, t0.c0 order by t0.c0, t0.c2, t0.c1 desc) AS WF0 FROM t0) L0 WHERE (("") <= ("e^dJ")) IN (WF0, NULL);
SELECT ALL count(*) FROM (SELECT /*+ ORDERED  */ ALL concat(t0.c0,'') AS C0, t0.c1 AS C1, t0.c2 AS C2, ROW_NUMBER() over(partition by t0.c2, t0.c1, t0.c0 order by t0.c0, t0.c2, t0.c1 desc) AS WF0 FROM t0) L0 WHERE (NOT ((("") <= ("e^dJ")) IN (WF0, NULL)));
SELECT ALL count(*) FROM (SELECT /*+ ORDERED  */ ALL concat(t0.c0,'') AS C0, t0.c1 AS C1, t0.c2 AS C2, ROW_NUMBER() over(partition by t0.c2, t0.c1, t0.c0 order by t0.c0, t0.c2, t0.c1 desc) AS WF0 FROM t0) L0 WHERE ((("") <= ("e^dJ")) IN (WF0, NULL)) IS UNKNOWN;

