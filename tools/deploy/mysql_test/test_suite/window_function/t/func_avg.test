# test of rank

--result_format 3
--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
set @@recyclebin = off;
drop table if exists t1;
--enable_warnings

create table t1 (c1 int primary key, c2 int, c3 int, c4 varchar(100));
insert into t1 values (1,1,3, 'fdsf');
insert into t1 values (2,2,2, '1fdfdsf');
insert into t1 values (3,2,1, 'kkkkk');
insert into t1 values (4,3,2, '8y77');
insert into t1 values (5,3,6, 'fdfd');
insert into t1 values (6,3,6, 'mnn');
insert into t1 values (7,4,2, '6fe');
insert into t1 values (8,4,NULL, 'kk');
insert into t1 values (9,4,1, 'kk');
insert into t1 values (10,4,3, 'kk');

select *, avg(c1) over (), avg(c1) over (partition by c1), avg(c1) over (partition by c2), avg(c1) over (partition by c4) from t1 order by c1;

# return null when invalid window(runtime)
select avg(c1) over (order by c2 rows between 1 preceding and 2 preceding) from t1 where c1 = 1;

# distinct
select avg(c2) over (), avg(distinct c2) over () from t1 where c1 in (4,5,6,7) order by c1;

select avg(c3) over () from t1 where c1 = 8 ;

set @@recyclebin = off;
drop table t1;

#verify bugfix of 
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1 (c1 datetime);
insert into t1 value ('2020-01-01 12:24:47');
insert into t1 value ('2020-01-01 12:24:50');
select avg(c1) from t1;
select avg(c1) x from t1 having x > '';
select cast(avg(c1) as char), avg(c1) from t1 having avg(c1) > '';
drop table t1;

create table t1(col_int int,col_int_key int,col_char_20 char(20),col_char_20_key char(20));
INSERT into t1(col_int,col_int_key,col_char_20,col_char_20_key) values(4,2,4,0);
INSERT into t1(col_int,col_int_key,col_char_20,col_char_20_key) values(8,3,6,7);
INSERT into t1(col_int,col_int_key,col_char_20,col_char_20_key) values(6,1,3,9);
INSERT into t1(col_int,col_int_key,col_char_20,col_char_20_key) values(9,4,6,7);
INSERT into t1(col_int,col_int_key,col_char_20,col_char_20_key) values(3,3,3,3);
INSERT into t1(col_int,col_int_key,col_char_20,col_char_20_key) values(5,2,8,6);
INSERT into t1(col_int,col_int_key,col_char_20,col_char_20_key) values(0,3,5,2);
INSERT into t1(col_int,col_int_key,col_char_20,col_char_20_key) values(7,6,8,3);
INSERT into t1(col_int,col_int_key,col_char_20,col_char_20_key) values(3,0,8,4);
INSERT into t1(col_int,col_int_key,col_char_20,col_char_20_key) values(6,9,5,6);
select * from t1;



SELECT avg(distinct col_int)*1.5 from t1 group by col_int_key order by col_int asc;

drop table t1;
