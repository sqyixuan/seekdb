# owner group: sql1
# description:
#
# test of rank

--result_format 3
--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
set @@recyclebin = off;
drop table if exists t1;
--enable_warnings

create table t1 (c1 int primary key, c2 int, c3 int, c4 varchar(100));
insert into t1 values (1,1,3, 'fdsf');
insert into t1 values (2,2,2, '1fdfdsf');
insert into t1 values (3,2,1, 'kkkkk');
insert into t1 values (4,3,2, '8y77');
insert into t1 values (5,3,6, 'fdfd');
insert into t1 values (6,3,6, 'mnn');
insert into t1 values (7,4,2, '6fe');
insert into t1 values (8,4,1, 'kk');
insert into t1 values (9,4,1, 'kk');
insert into t1 values (10,4,3, 'kk');

select *, max(c1) over (), max(c1) over (partition by c1), max(c1) over (partition by c2), max(c1) over (partition by c4) from t1 order by c1;

# return NULL when invalid window (runtime)
select max(c1) over(order by c2 rows between 1 preceding and 2 preceding) from t1 where c1 = 1;

# distinct 
select max(distinct c1) over() from t1 where c1 in (4,5,6) order by c1;

set @@recyclebin = off;
drop table t1;















