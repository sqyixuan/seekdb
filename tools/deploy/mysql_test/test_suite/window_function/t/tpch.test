select c_name, c_custkey, o_orderkey, o_orderdate, o_totalprice, sum(l_quantity), sum(l_quantity) over (partition by l_orderkey) from customer, orders, lineitem where o_orderkey in (     select     l_orderkey     from     lineitem     group by     l_orderkey having     sum(l_quantity) > 314     ) and c_custkey = o_custkey and o_orderkey = l_orderkey group by c_name, c_custkey, o_orderkey, o_orderdate, o_totalprice order by o_totalprice desc, o_orderdate limit 100; 

select c_name,c_custkey,o_orderkey,o_orderdate,o_totalprice,sum(v.lq) from customer, orders, (select l_orderkey lo, l_quantity lq, sum(l_quantity) over (partition by l_orderkey) ss from lineitem) v where c_custkey = o_custkey and o_orderkey = v.lo and v.ss > 314
group by c_name,c_custkey,o_orderkey,o_orderdate, o_totalprice order by o_totalprice desc, o_orderdate limit 100;

if ($TENANT =='oracle') {
select * from (select c_name,c_custkey,o_orderkey,o_orderdate,o_totalprice,sum(v.lq) from customer,orders,(select l_orderkey lo, l_quantity lq, sum(l_quantity) over (partition by l_orderkey) ss from lineitem) v where c_custkey = o_custkey and o_orderkey = v.lo and v.ss > 314 group by c_name,c_custkey,o_orderkey,o_orderdate,o_totalprice order by o_totalprice desc, o_orderdate) where rownum < 101;
}
if ($TENANT =='mysql') {
select * from (select c_name,c_custkey,o_orderkey,o_orderdate,o_totalprice,sum(v.lq) from customer,orders,(select l_orderkey lo, l_quantity lq, sum(l_quantity) over (partition by l_orderkey) ss from lineitem) v where c_custkey = o_custkey and o_orderkey = v.lo and v.ss > 314 group by c_name,c_custkey,o_orderkey,o_orderdate,o_totalprice order by o_totalprice desc, o_orderdate) limit 100;
}
select case when c_acctbal > avg(c_acctbal) over () then 1 else null end gt from customer where c_acctbal > 0.00 and substring(c_phone from 1 for 2) in ('20', '40', '22', '30', '39', '42', '21');
