#description:

--disable_warnings
drop database if exists wf;
create database wf;
use wf;
--disable_warnings

create table t1(a int primary key, b int, c varchar(20), d int);

insert into t1 values(1, 1, "121", 4);
insert into t1 values(2, -1, "3f1", 400);
insert into t1 values(3, 4, "hh1", 19);
insert into t1 values(4, 6, "c1", 4);
insert into t1 values(5, 2, "c1", 23);
insert into t1 values(6, -3, "a1", 4);
insert into t1 values(7, 3, "21", 41);
insert into t1 values(8, 8, "b1", 32);
insert into t1 values(9, 3, "ha", 1);
insert into t1 values(10, 19, "he", 3);

select * from t1 order by row_number() over(order by b,a) desc;
select *, row_number() over(order by b,a) as rn from t1 order by rn desc;

select * from t1 order by rank() over(order by b), a;
select *, rank() over(order by b) as rk from t1 order by rk, a;

--error 1054 
select *, row_number() over(order by a) as rn from t1 where rn = 1;
--error 5338 
select * from t1 where row_number() over(order by a) = 1;
--error 5561 
select *, row_number() over(order by a) as rn from t1 having rn = 1;
--error 5338 
select * from t1 having row_number() over(order by a) = 1;
--error 5561
select *, row_number() over(order by a) as rn from t1 group by rn;
--error 5338 
select * from t1 group by row_number() over(order by a);



--disable_warnings
drop database if exists wf;
--disable_warnings

