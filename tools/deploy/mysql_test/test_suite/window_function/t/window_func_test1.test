from   (select sum(splcol) c1
from	(select count(t_5k.unique1) splcol from t_5k, t_4k
where t_5k.ten = mod(t_4k.thousand,10)
and  (t_5k.thousand, t_5k.hundred) =ANY
(select count(distinct t1_100.hundred), rank()
over (order by (max(t1_100.char_unique))) as rankap
from t1_100
where t1_100.char_unique < t_5k.char_hund
group by t1_100.ten, t1_100.thousand) group by t_5k.ten)) andv,
(select count(t_5k.unique1) c1
from t_5k, t_4k
where t_5k.ten = mod(t_4k.thousand,10)
and  (t_5k.thousand, t_5k.hundred) =ANY
(select count(distinct t1_100.hundred), rank()
over (order by (max(t1_100.char_unique))) as rankap
from t1_100
where t1_100.char_unique < t_5k.char_hund
group by t1_100.ten, t1_100.thousand)) dist;

--echo #tkoqadopc7q.sql
#-------------------
#-- Windows function
#-------------------
select hundred,char_unique, thousand,
 RANK() over (partition by  hundred order by thousand) rank
from t_5k where thousand = 750
order by rank, char_unique;

--echo #tkoqview.sql

#Rem ##################################################################
#Rem Test pushing predicates through a view with window functions
#Rem ##################################################################

#Rem simple push through window, this should return divide by 0 error
if ($ORACLE_MODE){
select * from
(
  select
    ten,
    4,
    rank() over (partition by ten order by 1) as rank_numeric,
    case when ten = 2 then 1 else 1/0 end as pushchecker
    rownum as rnum
  from
    t1_100
)
where ten = 2
order by rank_numeric;
}
#Rem simple push through window, this should return without divide by 0 error
--error 3592
select * from
(
  select
    ten,
    4,
    rank() over (partition by ten order by 1) as rank_numeric,
    case when ten = 2 then 1 else 1/0 end as pushchecker
  from
    t1_100
)
where ten = 2
order by ten, rank_numeric;


#Rem push through window with OR, this should return without divide by 0 error
#was common error bug 17169649
--error 3592
select * from
(
  select
    ten,
    4,
    rank() over (partition by ten order by 1) as rank_numeric,
    case when ten = 2 or ten = 1 then 1 else 1/0 end as pushchecker
  from
    t1_100
)
where ten = 2 or ten = 1
order by ten, rank_numeric;


#Rem push through window with IN, this should return without divide by 0 error
#was common error , bug 17169649
--error 3592
select * from
(
  select
    ten,
    4,
    rank() over (partition by ten order by 1) as rank_numeric,
    case when ten in (1,2,3) then 1 else 1/0 end as pushchecker
  from
    t1_100
  order by
    ten, rank_numeric
)
where ten in (1,2,3)
order by ten, rank_numeric;

#Rem push through window with func, this should return divide by 0 error
#--error 1305
--error 3592
select * from
(
  select
    ten,
    4,
    rank() over (partition by ora_decode(ten, 2, 100, 0)
                 order by 1) as rank_numeric,
    case when ora_decode(ten, 2, 100, 0) = 100 then 1
         else 1/0
    end as pushchecker
  from
    t1_100
)
where ora_decode(ten, 2, 100, 0) = 100
order by ten, rank_numeric;

--echo #tkoquind.sql
#-- 9.11 Window function
#-- Index range scan is used to access t_5k where all access paths are available
#-- But Full table scan is used otherwise when index usage is restricted
select max(unique1) over(partition by mod(thousand,2))
from t_5k
where unique1 > 4800 ;

--echo #tkoqts.sql
#Rem ***********************************************************************
#Rem Test window
select hundred, unique1,
         rank() over (partition by hundred order by unique1) as w1
from t_10k;

#Rem two windows
select hundred, unique1, thousand, unique2,
         rank() over (partition by hundred order by unique1) as w1,
         rank() over (partition by thousand order by unique2) as w1
from t_10k;

#Rem window nosort (group by)
select hundred, unique1,
         rank() over (partition by hundred order by unique1) as w1
  from t_10k group by hundred, unique1;

