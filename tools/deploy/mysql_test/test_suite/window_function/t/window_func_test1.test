--echo #tkoqpjp.sql with modify
create table dept(
  DEPTNO integer,
  DNAME char(45),
  loc varchar(10)
) ;
#data
insert into dept values (0, 'A', 'xx');
insert into dept values (1, 'B', 'yy');
insert into dept values (2, 'C', 'zz');
insert into dept values (3, 'D', 'mm');
insert into dept values (4, 'E', 'nn');
insert into dept values (5, 'F', 'oo');
select /*+ PUSH_PRED (v) */ d.*, v.*
from dept d,
     (select e.deptno,
             SUM(e.sal) OVER (PARTITION BY e.deptno) AS MAX_DEPT_SALES
      from emp e
      union all
      select e.deptno,
             SUM(e.sal) OVER (PARTITION BY e.deptno) AS MAX_DEPT_SALES
      from emp e
      ) v
where d.dname = 'D'
and d.deptno * 10 = v.deptno;

# report bug#17169649
select/*+push_pred(uv)*/ *
from
    (select /*+push_pred(wn) */dname
     from dept d1,
               (select deptno,
                       row_number() over (partition by deptno
                                          order by deptno),
                       ename
                from emp
               ) wn
     where (dname ='A' or dname='D')
     union all
     select dname from dept d2 where deptno=99
    ) uv, dept d
where d.loc='mm' and d.dname=uv.dname;

#最简重现
select * from (
select row_number() over (partition by deptno) as x
from emp )
where (x = 1 or x = 2);

