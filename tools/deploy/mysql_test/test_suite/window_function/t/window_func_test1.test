create index s_8520169_callday on s_8520169(callday);
create index s_8520169_pid on s_8520169(pid);

select /*+ push_pred(s_8520169) */  * from
   ( select  outdate as datesplit,
              100 * count(*) / sum(count(*)) over ()  as percent,
             pid
    from t_8520169, x_8520169
    where id = pid
    group by  outdate , pid
   order by datesplit) t_8520169,
  (select sum(submissions) as submissions,
               callday  as datesplit,
