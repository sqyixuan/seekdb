--echo #tkoqgbaev.sql
#-----------------------------------------------------------------
# 13.Test CASE: Query using Windowing Function
#-#Window functions are not allowed in either the view or the OQB
#-----------------------------------------------------------------
#--13.1: Query with OQB using windowing function: GBAE possible
SELECT VW.hundred, SUM(VW.sm),
             sum(sum(VW.sm)) over (order by hundred rows between unbounded
                                     preceding and current row) just_above
      FROM (SELECT hundred, char_hund, SUM(ten) AS sm
               FROM T_10K WHERE hundred<30
               GROUP BY hundred, char_hund) VW
      GROUP BY VW.hundred;
#--13.2: Query with View Part using windowing function: NO GBAE

SELECT VW.hundred, SUM(VW.sm), SUM(VW.just_above)
      FROM (SELECT hundred, char_hund, SUM(ten) AS sm,
               sum(sum(ten)) over (order by hundred rows between unbounded
                                     preceding and current row) just_above
               FROM T_10K WHERE hundred>60
               GROUP BY hundred, char_hund) VW
      GROUP BY VW.hundred ;
#-------------------------------------------------
#Rem 14.Test CASE: Query using Partition_By clause
#-------------------------------------------------
#--14: Query with PARTITION-BY clause: GBAE possible
SELECT o.hundred, max(o.mx) OVER (PARTITION BY o.hundred) from
        (SELECT VW.hundred, MAX(VW.mx) as mx
           FROM (SELECT hundred, char_hund, MAX(ten) AS mx
               FROM T_10K WHERE hundred>60
               GROUP BY hundred, char_hund) VW
        GROUP BY VW.hundred) O;

