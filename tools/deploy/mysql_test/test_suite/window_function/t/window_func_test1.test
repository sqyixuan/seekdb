#---------------------------------------------------------
# #14292075: Push a filter predicate inside view with WiF
# based on equijoin predicate inside the view.
# --------------------------------------------------------
select col
from
  (select d1.deptno ddno, e1.deptno edno,
   rank() over (partition by e1.deptno order by e1.deptno) as col
         from
         emp e1, dept d1
         where d1.deptno = e1.deptno)V
where ddno = 20;

