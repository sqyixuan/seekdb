# ---------------------------------------------------------------------.
# 9024933: poor perfromacne with OJPPD and window function in nested qb
# ---------------------------------------------------------------------.
create index I1_9024933 on emp(deptno);

#disable cost based JPPD
#JPPD should not happen
select * from emp e left join
  (select e1.deptno
   from emp e1,
        (select MAX (sal) OVER (PARTITION BY deptno) max_sal
	 from emp)
   where e1.sal = max_sal) d
on e.deptno = d.deptno;

# honour old JPPD hint
select * from emp e left join
  (select /*+ OLD_PUSH_PRED */ e1.deptno
   from emp e1,
        (select MAX (sal) OVER (PARTITION BY deptno) max_sal
         from emp)
   where e1.sal = max_sal) d
on e.deptno = d.deptno;

drop index I1_9024933 on emp;

#---------------------------
#-- Test case for #9573347
#---------------------------
create table sr_3_1640661001_employees (empno number(10, 0));
insert into sr_3_1640661001_employees values (120);
select * from sr_3_1640661001_employees;

create table sr_3_1640661001_year(
  year  number   primary key);

insert into sr_3_1640661001_year values (2008);
insert into sr_3_1640661001_year values (2009);
insert into sr_3_1640661001_year values (2010);
select * from sr_3_1640661001_year;

create or replace view vw_sr_3_1640661001 as
  select empno, year
  from   sr_3_1640661001_employees,
         sr_3_1640661001_year;

# the value for first_year should be 2008
select v1.*
from (select empno, year,
             first_value(year)
	       over (partition by empno order by year)  first_year
      from vw_sr_3_1640661001
      union all
      select empno, year, null
      from   vw_sr_3_1640661001
      where  1 = 2) v1,
     vw_sr_3_1640661001 v2
where
  v1.year = v2.year and v1.empno = v2.empno and
  v1.empno = 120 and v1.year = 2010;

drop table sr_3_1640661001_employees;
drop table sr_3_1640661001_year;
drop view vw_sr_3_1640661001;

# ---------------------------------------------------------------------.
# 12410972: push predicate in window function when NLS_SORT is set
# ---------------------------------------------------------------------.

# create

create table talx(a varchar(1) primary key, b varchar(1));
create table ualx(c varchar(1) primary key, d varchar(1));

# execute
# the join predicate is pushed into the window function
# when NLS_SORT is not set
select (select c
          from (select y.c, d, rank() over (partition by c order by d) r
                  from ualx y) x
         where r = 1 and x.c = o.b) y
  from talx o
 where o.a = 1;

drop table talx;
drop table ualx;

# ----------------------------------------------------------------------.
# 13981873: kkqwmrm_noref WiF cleanup select list on eliminating qbcWN
# ----------------------------------------------------------------------.
# create
create table talx(a number not null, b number primary key);
insert into talx values(1,1);
create index ialx on talx(a);

# execute
# this should not result in OBE-937

# 1 row should be selected

select /*+ push_pred(p) */ 1
  from (select x, first_value(s) over (partition by x) c
          from (select a x, sum(1) s from talx group by a) u) p,
       (select a y, sum(1) s from talx group by a) q
 where x = y;

# set query block case should also have no error

# 2 rows should be selected

select /*+ push_pred(p) */ 1
  from (select x, first_value(s) over (partition by x) c
          from (select a x, sum(1) s from talx group by a) u) p,
       (select a y, sum(1) s from talx group by a) q
 where x = y
union all
select /*+ push_pred(p) */ x
  from (select x, first_value(s) over (partition by x) c
          from (select a x, sum(1) s from talx group by a) u) p,
       (select a y, sum(1) s from talx group by a) q
 where x = y;

# cleanup

drop table talx;

# ----------------------------------------------------------------------.
# 15951740: columns in predicate and PARTITION BY must not be
#           from different instances of the same view
# ----------------------------------------------------------------------.

# create

CREATE TABLE CATEGORIES (
CATEGORYID INT,
CATEGORYNAME VARCHAR(15) NOT NULL ,
DESCRIPTION VARCHAR(100),
 PRIMARY KEY(CATEGORYID),
 UNIQUE(CATEGORYNAME));

CREATE TABLE SUPPLIERS_RAGGED (
SUPPLIERID INT,
SUPPLIERLEVELID INT,
COMPANYNAME CHAR(42) NOT NULL ,
SUPPLIERCOMPANY CHAR(42),
CONTACTNAME CHAR(30),
CONTACTTITLE VARCHAR(30),
ADDRESS VARCHAR(60),
CITY CHAR(16),
REGION CHAR(16),
POSTALCODE CHAR(10),
COUNTRY CHAR(15),
PHONE CHAR(24),
FAX CHAR(24),
 PRIMARY KEY(SUPPLIERID));

CREATE TABLE PRODUCTS_RAGGED (
PRODUCTID INT,
PRODUCTLEVELID INT,
PRODUCTNAME CHAR(42) NOT NULL ,
PRODUCTLEVELNAME CHAR(42),
SUPPLIERID INT,
CATEGORYID INT,
QUANTITYPERUNIT CHAR(20),
UNITPRICE NUMBER(9,2) DEFAULT 0.0,
UNITSINSTOCK INT DEFAULT 0,
UNITSONORDER INT DEFAULT 0,
REORDERLEVEL INT DEFAULT 0,
DISCONTINUED INT DEFAULT 0,
 PRIMARY KEY(PRODUCTID));

CREATE TABLE ORDERS (
ORDERID INT,
CUSTOMERID CHAR(5),
SITEID INT,
EMPLOYEEID INT,
ORDERDATE DATE,
REQUIREDDATE DATE,
SHIPPEDDATE DATE,
SHIPVIA INT,
FREIGHT NUMBER(9,2) DEFAULT 0.0,
SHIPNAME VARCHAR(40),
SHIPADDRESS VARCHAR(60),
SHIPCITY CHAR(15),
SHIPREGION CHAR(15),
SHIPPOSTALCODE CHAR(10),
SHIPCOUNTRY CHAR(15),
 PRIMARY KEY(ORDERID));

CREATE TABLE ORDERDETAILS (
ORDERID INT,
PRODUCTID INT,
UNITPRICE NUMBER(9,2) DEFAULT 0.0 NOT NULL ,
QUANTITY INT DEFAULT 1 NOT NULL ,
DISCOUNT INT DEFAULT 0 NOT NULL ,
 CONSTRAINT PK PRIMARY KEY(ORDERID, PRODUCTID) );

# execute
# the query below used to dump with [kkqjpdpvpd: no join pred found]
if ($ORACLE_MODE) {
WITH SAWITH0 AS (select
D1.c1 as c1, D1.c2 as c2, D1.c3 as c3, D1.c4 as c4, D1.c5 as c5, D1.c6 as c6
from (select
 avg(T11466.UnitPrice * T11466.Quantity) as c1,
 sum(T11466.UnitPrice * T11466.Quantity) as c2,
 T11477.Country as c3,
 T11477.City as c4,
 T11477.CompanyName as c5,
 T11477.SupplierID as c6,
 ROW_NUMBER() OVER (PARTITION BY T11477.SupplierID, T11477.City, T11477.Country
 ORDER BY T11477.SupplierID ASC, T11477.City ASC, T11477.Country ASC) as c7
from Suppliers_Ragged T11477, Products_Ragged T11468,
     OrderDetails T11466, Orders T11467
where T11466.OrderID = T11467.OrderID and T11466.ProductID = T11468.ProductID
  and T11468.SupplierID = T11477.SupplierID
group by T11477.SupplierID, T11477.CompanyName, T11477.City, T11477.Country) D1
where D1.c7 = 1),
SAWITH1 AS (select
T11477.City as c4, T11477.Country as c6, T11477.SupplierID as c7,
T11477.CompanyName as c8, T11477.Country as c9
from Suppliers_Ragged T11477, Products_Ragged T11468
where T11468.SupplierID = T11477.SupplierID),
SAWITH2 AS (select
D1.c1 as c1, D1.c2 as c2, D1.c3 as c3, D1.c4 as c4, D1.c5 as c5, D1.c6 as c6
from (select
 count(D0.c9) as c1, count(D0.c8) as c2,
 D0.c6 as c3, D0.c4 as c4, D0.c8 as c5, D0.c7 as c6,
 ROW_NUMBER() OVER (PARTITION BY D0.c4, D0.c6, D0.c7
 ORDER BY D0.c4 ASC, D0.c6 ASC, D0.c7 ASC) as c7
from SAWITH1 D0
group by D0.c4, D0.c6, D0.c7, D0.c8) D1
where D1.c7 = 1),
SACOMMON2871293 AS (select
 avg(T11466.UnitPrice * T11466.Quantity) as c1,
 sum(T11466.UnitPrice * T11466.Quantity) as c2,
 T11477.City as c3, T11477.CompanyName as c4, T11477.SupplierID as c5
from Categories T11463, Suppliers_Ragged T11477, Products_Ragged T11468,
     OrderDetails T11466, Orders T11467
where T11468.SupplierID = T11477.SupplierID
  and T11466.ProductID = T11468.ProductID and T11466.OrderID = T11467.OrderID
  and T11463.CategoryID = T11468.CategoryID and T11463.CategoryName = 'Seafood'
group by T11477.SupplierID, T11477.CompanyName, T11477.City),
SAWITH3 AS (select
 D1.c1 as c1, D1.c2 as c2, D1.c3 as c3, D1.c4 as c4, D1.c5 as c5
from (select
 D1.c1 as c1, D1.c2 as c2, D1.c3 as c3, D1.c4 as c4, D1.c5 as c5,
 ROW_NUMBER() OVER (PARTITION BY D1.c3, D1.c5
 ORDER BY D1.c3 ASC, D1.c5 ASC) as c6
from SACOMMON2871293 D1) D1
where D1.c6 = 1),
SACOMMON2871599 AS (select
 T11477.City as c1, T11477.SupplierID as c4, T11477.CompanyName as c5,
 T11477.Country as c6
from Categories T11463, Suppliers_Ragged T11477, Products_Ragged T11468
where T11463.CategoryID = T11468.CategoryID and T11463.CategoryName = 'Seafood'
  and T11468.SupplierID = T11477.SupplierID),
SAWITH4 AS (select
 D1.c1 as c1, D1.c2 as c2, D1.c3 as c3, D1.c4 as c4, D1.c5 as c5
from (select
 count(D0.c6) as c1, count(D0.c5) as c2, D0.c1 as c3, D0.c5 as c4, D0.c4 as c5,
 ROW_NUMBER() OVER (PARTITION BY D0.c1, D0.c4
 ORDER BY D0.c1 ASC, D0.c4 ASC) as c6
from SACOMMON2871599 D0
group by D0.c1, D0.c4, D0.c5) D1
where D1.c6 = 1),
SAWITH5 AS (select
 D1.c1 as c1, D1.c2 as c2, D1.c3 as c3, D1.c4 as c4, D1.c5 as c5
from (select
 D1.c1 as c1, D1.c2 as c2, D1.c3 as c3, D1.c4 as c4, D1.c5 as c5,
 ROW_NUMBER() OVER (PARTITION BY D1.c3, D1.c5
 ORDER BY D1.c3 ASC, D1.c5 ASC) as c6
from SACOMMON2871293 D1) D1
where D1.c6 = 1),
SAWITH6 AS (select
 D1.c1 as c1, D1.c2 as c2, D1.c3 as c3, D1.c4 as c4, D1.c5 as c5
from (select
 count(D0.c6) as c1, count(D0.c5) as c2, D0.c1 as c3, D0.c5 as c4, D0.c4 as c5,
 ROW_NUMBER() OVER (PARTITION BY D0.c1, D0.c4
 ORDER BY D0.c1 ASC, D0.c4 ASC) as c6
from SACOMMON2871599 D0
group by D0.c1, D0.c4, D0.c5) D1
where D1.c6 = 1),
SAWITH7 AS ((select
 D1.c1 as c1, D1.c2 as c2, D1.c3 as c3, D1.c4 as c4,
 D1.c5 as c5, D1.c6 as c6, D1.c7 as c7
from (select case
 when D1.c3 is not null then D1.c3 when D2.c3 is not null then D2.c3 end as c1,
 D2.c1 as c2, case
 when D1.c4 is not null then D1.c4 when D2.c4 is not null then D2.c4 end as c3,
 case
 when D1.c5 is not null then D1.c5 when D2.c5 is not null then D2.c5 end as c4,
 D2.c2 as c5, D1.c2 as c6, D1.c1 as c7,
 ROW_NUMBER() OVER (PARTITION BY case
 when D1.c3 is not null then D1.c3 when D2.c3 is not null then D2.c3 end, case
 when D1.c4 is not null then D1.c4 when D2.c4 is not null then D2.c4 end, case
 when D1.c5 is not null then D1.c5 when D2.c5 is not null then D2.c5 end
 ORDER BY case
 when D1.c3 is not null then D1.c3 when D2.c3 is not null then D2.c3 end ASC,
 case
 when D1.c4 is not null then D1.c4 when D2.c4 is not null then D2.c4 end ASC,
 case
 when D1.c5 is not null then D1.c5 when D2.c5 is not null then D2.c5 end ASC)
as c8
from SAWITH0 D1 left outer join SAWITH2 D2
On D1.c6 = D2.c6 and nvl(D1.c3 , '1') = nvl(D2.c3 , '1')
and nvl(D1.c3 , '2') = nvl(D2.c3 , '2') and nvl(D1.c4 , '1') = nvl(D2.c4 , '1')
and nvl(D1.c4 , '2') = nvl(D2.c4 , '2')) D1
where D1.c8 = 1
union all
select
 D1.c1 as c1, D1.c2 as c2, D1.c3 as c3, D1.c4 as c4, D1.c5 as c5,
 D1.c6 as c6, D1.c7 as c7
from (select
 'Seafood Products' as c1, D2.c1 as c2, case
  when D1.c3 is not null then D1.c3 when D2.c3 is not null then D2.c3 end as c3,
  case
  when D1.c4 is not null then D1.c4 when D2.c4 is not null then D2.c4 end as c4,
  D2.c2 as c5, D1.c2 as c6, D1.c1 as c7,
  ROW_NUMBER() OVER (PARTITION BY case
  when D1.c3 is not null then D1.c3 when D2.c3 is not null then D2.c3 end, case
  when D1.c4 is not null then D1.c4 when D2.c4 is not null then D2.c4 end
  ORDER BY case
  when D1.c3 is not null then D1.c3 when D2.c3 is not null then D2.c3 end ASC,
  case
  when D1.c4 is not null then D1.c4 when D2.c4 is not null then D2.c4 end ASC)
as c8
from SAWITH3 D1 left outer join SAWITH4 D2
On D1.c5 = D2.c5 and nvl(D1.c3 , '1') = nvl(D2.c3 , '1')
and nvl(D1.c3 , '2') = nvl(D2.c3 , '2')) D1
where D1.c8 = 1
union all
select D1.c1 as c1, D1.c2 as c2, D1.c3 as c3, D1.c4 as c4,
       D1.c5 as c5, D1.c6 as c6, D1.c7 as c7
from (select case
 when D1.c3 is not null then D1.c3 when D2.c3 is not null then D2.c3 end as c1,
 D2.c1 as c2, case
 when D1.c3 is not null then D1.c3 when D2.c3 is not null then D2.c3 end as c3,
 case
 when D1.c4 is not null then D1.c4 when D2.c4 is not null then D2.c4 end as c4,
 D2.c2 as c5, D1.c2 as c6, D1.c1 as c7,
 ROW_NUMBER() OVER (PARTITION BY case
 when D1.c3 is not null then D1.c3 when D2.c3 is not null then D2.c3 end, case
 when D1.c4 is not null then D1.c4 when D2.c4 is not null then D2.c4 end
ORDER BY case
 when D1.c3 is not null then D1.c3 when D2.c3 is not null then D2.c3 end ASC,
 case
 when D1.c4 is not null then D1.c4 when D2.c4 is not null then D2.c4 end ASC)
as c8
from SAWITH5 D1 left outer join SAWITH6 D2
On D1.c5 = D2.c5 and nvl(D1.c3 , '1') = nvl(D2.c3 , '1')
and nvl(D1.c3 , '2') = nvl(D2.c3 , '2')) D1
where D1.c8 = 1))
select D1.c1 as c1, D1.c2 as c2, D1.c3 as c3, D1.c4 as c4,
       D1.c5 as c5, D1.c6 as c6, D1.c7 as c7
from SAWITH7 D1
order by c1, c2;
}
