# owner: dachuan.sdc
#tags: pl, optimizer
# owner group: sql2
# description:
#
# test of  parallel window function
# tag: random_mode


--disable_warnings
drop database if exists austin;
--enable_warnings
create database austin;
use austin;


drop table if exists t1;
drop table if exists t2;

create table t1(v1 int, v2 int) partition by hash(v1) partitions 4;
create table t2(v1 int, v2 int) partition by hash(v1) partitions 4;

insert into t1 values(1,2), (3,5), (6,7), (8,9), (10, 11);

--disable_result_log
select count(*) from t1;
select count(*) from t2;
--enable_result_log

--enable_sorted_result
--result_format 4

### basic test
explain select /*+ parallel(1)*/*, sum(v1) over() from t1;
explain select /*+ parallel(2)*/*, sum(v1) over(partition by v2) from t1;
explain select /*+ parallel(2)*/*, sum(v1) over() from t1;
select /*+ parallel(2)*/*, sum(v1) over() from t1;
select /*+ parallel(3)*/*, sum(v1) over() from t1;
select /*+ parallel(4)*/*, sum(v1) over() from t1;
select /*+ parallel(3)*/*, sum(v1) over() from t2;

explain select /*+ parallel(1)*/*, count(v1) over() from t1;
explain select /*+ parallel(2)*/*, count(v1) over(partition by v2) from t1;
explain select /*+ parallel(2)*/*, count(v1) over() from t1;
select /*+ parallel(2)*/*, count(v1) over() from t1;
select /*+ parallel(3)*/*, count(v1) over() from t1;
select /*+ parallel(4)*/*, count(v1) over() from t1;

explain select /*+ parallel(1)*/*, max(v1) over() from t1;
explain select /*+ parallel(2)*/*, max(v1) over(partition by v2) from t1;
explain select /*+ parallel(2)*/*, max(v1) over() from t1;
select /*+ parallel(2)*/*, max(v1) over() from t1;
select /*+ parallel(3)*/*, max(v1) over() from t1;
select /*+ parallel(4)*/*, max(v1) over() from t1;

explain select /*+ parallel(1)*/*, min(v1) over() from t1;
explain select /*+ parallel(2)*/*, min(v1) over(partition by v2) from t1;
explain select /*+ parallel(2)*/*, min(v1) over() from t1;
select /*+ parallel(2)*/*, min(v1) over() from t1;
select /*+ parallel(3)*/*, min(v1) over() from t1;
select /*+ parallel(4)*/*, min(v1) over() from t1;

### mix test
select /*+ parallel(1)*/*, max(v1) over(), min(v1) over(), sum(v2) over(), count(v1) over() from t1;
explain select /*+ parallel(2)*/*, max(v1) over(), min(v1) over(), sum(v2) over(), count(v1) over() from t1;
select /*+ parallel(2)*/*, max(v1) over(), min(v1) over(), sum(v2) over(), count(v1) over() from t1;


explain select /*+ parallel(2)*/*, max(v1) over(order by v1), max(v1) over( order by v2), max(v2) over( order by v1, v2), max(v1) over(order by v2,v1) from t1;
select /*+ parallel(2)*/*, max(v1) over(order by v1), max(v1) over(order by v2), max(v2) over(order by v1, v2), max(v1) over(order by v2,v1) from t1;

--disable_warnings
drop table if exists t_rorga9ozl;
--enable_warnings

CREATE TABLE `t_rorga9ozl` (
  `c_i5z1k` int(11) NOT NULL,
  PRIMARY KEY (`c_i5z1k`),
  KEY `main_index` (`c_i5z1k`) BLOCK_SIZE 16384 LOCAL
) partition by hash(c_i5z1k) partitions 10;

insert into t_rorga9ozl values(510015201), 
( 1755815427 ),
( 1553838752 ),
( 1494601190 ),
(   71418386 ),
( 1181907733 ),
(  123476562 ),
(   36118568 ),
(          7 ),
(   27846463 ),
(  304295801 ),
( 1675419181 ),
(  533030836 ),
(  758693493 ),
( 1583849826 );

explain select /*+no_rewrite*/ (select /*+win_magic */ (select avg(c_i5z1k) from t_rorga9ozl) as c0         from   t_rorga9ozl as ref_5         where  ( ref_0.c_i5z1k between ref_5.c_i5z1k and ref_0.c_i5z1k )         order  by c0 asc limit  1) as      c5 from   t_rorga9ozl as ref_0 order  by c5 desc;
select /*+no_rewrite*/ (select /*+win_magic */ (select avg(c_i5z1k) from t_rorga9ozl) as c0         from   t_rorga9ozl as ref_5         where  ( ref_0.c_i5z1k between ref_5.c_i5z1k and ref_0.c_i5z1k )         order  by c0 asc limit  1) as      c5 from   t_rorga9ozl as ref_0 order  by c5 desc;

drop table t_rorga9ozl;