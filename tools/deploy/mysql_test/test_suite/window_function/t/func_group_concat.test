--result_format 3
--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
set @@recyclebin = off;
drop table if exists t1;
--enable_warnings

create table t1 (c1 int primary key, c2 int, c3 int, c4 varchar(100));
insert into t1 values (1,1,3, 'fdsf');
insert into t1 values (2,2,2, '1fdfdsf');
insert into t1 values (3,2,1, 'kkkkk');
insert into t1 values (4,3,2, '8y77');
insert into t1 values (5,3,6, 'fdfd');
insert into t1 values (6,3,6, 'mnn');
insert into t1 values (7,4,2, '6fe');
insert into t1 values (8,4,1, 'kk');
insert into t1 values (9,4,1, 'kk');
insert into t1 values (10,4,3, 'kk');

select *, group_concat(c1) over (), group_concat(c1) over (partition by c1), group_concat(c1) over (partition by c2), group_concat(c1) over (partition by c4) from t1;

# distinct 
select group_concat(c2) over (order by c1), group_concat(distinct c2) over (order by c1) from t1;

# order by 
select group_concat(c1 order by c1 desc) over () from t1;

set @@recyclebin = off;
drop table t1;

##bug:

--disable_warnings
drop table if exists cftm_crod_t86_corp_cust_score_sum_03;
--enable_warnings

CREATE TABLE `cftm_crod_t86_corp_cust_score_sum_03` (
`AUTO_ID` bigint(20) NOT NULL AUTO_INCREMENT,
`DC_START_DATE` date DEFAULT NULL,
`DC_END_DATE` date DEFAULT NULL,
`STAT_DT` date DEFAULT NULL,
`CUST_NAME` varchar(200) COLLATE utf8mb4_bin DEFAULT NULL,
`CUST_NO` varchar(30) COLLATE utf8mb4_bin DEFAULT NULL,
`CRM_CUST_NO` varchar(30) COLLATE utf8mb4_bin DEFAULT NULL,
`CREDIT_CODE` varchar(20) COLLATE utf8mb4_bin DEFAULT NULL,
`CUST_TYPE` char(1) COLLATE utf8mb4_bin DEFAULT NULL,
`IS_CMBC` char(1) COLLATE utf8mb4_bin DEFAULT NULL,
`VAL_SBDV_LEVEL` char(2) COLLATE utf8mb4_bin DEFAULT NULL,
`FUND_SCORE` decimal(18,2) DEFAULT NULL,
`SHAREHOLDER_SCORE` decimal(18,2) DEFAULT NULL,
`DEBT_SCORE` decimal(18,2) DEFAULT NULL,
`RELATER_SCORE` decimal(18,2) DEFAULT NULL,
`RELATER_FMLY_SCORE` decimal(18,2) DEFAULT NULL,
`COMPRE_SCORE` decimal(18,2) DEFAULT NULL,
`CORP_CNT` int(4) DEFAULT NULL,
`RELA_CNT` bigint(8) DEFAULT NULL,
`IS_FUND_NEW` char(3) COLLATE utf8mb4_bin DEFAULT NULL,
`IS_SHRHOLD_NEW` char(3) COLLATE utf8mb4_bin DEFAULT NULL,
`IS_DEBT_NEW` char(3) COLLATE utf8mb4_bin DEFAULT NULL,
`IS_RELATER_NEW` char(3) COLLATE utf8mb4_bin DEFAULT NULL,
`IS_RELATER_FMLY_NEW` char(3) COLLATE utf8mb4_bin DEFAULT NULL,
`IS_COMPRE_NEW` char(3) COLLATE utf8mb4_bin DEFAULT NULL,
`FUND_CERT` char(1) COLLATE utf8mb4_bin DEFAULT NULL,
`SHRHOLD_CERT` char(1) COLLATE utf8mb4_bin DEFAULT NULL,
`DEBT_CERT` char(1) COLLATE utf8mb4_bin DEFAULT NULL,
`RELATER_CERT` char(1) COLLATE utf8mb4_bin DEFAULT NULL,
`RELATER_FMLY_CERT` char(1) COLLATE utf8mb4_bin DEFAULT NULL,
`COMPRE_CERT` char(1) COLLATE utf8mb4_bin DEFAULT NULL,
UNIQUE KEY `index_uk_1` (`AUTO_ID`, `STAT_DT`, `CUST_NAME`) BLOCK_SIZE 16384 GLOBAL,
KEY `INDEX0` (`STAT_DT`, `FUND_CERT`, `IS_FUND_NEW`, `FUND_SCORE`, `COMPRE_SCORE`) BLOCK_SIZE 16384 LOCAL,
KEY `INDEX1` (`STAT_DT`, `SHRHOLD_CERT`, `IS_SHRHOLD_NEW`, `SHAREHOLDER_SCORE`, `COMPRE_SCORE`) BLOCK_SIZE 16384 LOCAL,
KEY `INDEX2` (`STAT_DT`, `DEBT_CERT`, `IS_DEBT_NEW`, `DEBT_SCORE`, `COMPRE_SCORE`) BLOCK_SIZE 16384 LOCAL,
KEY `INDEX3` (`STAT_DT`, `RELATER_CERT`, `IS_RELATER_NEW`, `RELATER_SCORE`, `COMPRE_SCORE`) BLOCK_SIZE 16384 LOCAL,
KEY `INDEX4` (`STAT_DT`, `RELATER_FMLY_CERT`, `IS_RELATER_FMLY_NEW`, `RELATER_FMLY_SCORE`, `COMPRE_SCORE`) BLOCK_SIZE 16384 LOCAL,
KEY `INDEX5` (`STAT_DT`, `COMPRE_CERT`, `IS_COMPRE_NEW`, `COMPRE_SCORE`) BLOCK_SIZE 16384 LOCAL
);

SELECT ss.CUST_NAME custName,max(ss.COMPRE_SCORE) compreScore,max(ss.FUND_SCORE) fundScore, max(ss.SHAREHOLDER_SCORE) shareholderScore,max(ss.DEBT_SCORE) debtScore, max(ss.RELATER_SCORE) relaterScore,max(ss.RELATER_FMLY_SCORE) relaterFmlyScore,max(ss.CORP_CNT) corpCnt, max(ss.RELA_CNT) relaCnt,max(ss.CREDIT_CODE) creditCode, group_concat(concat_ws(',',ss.CUST_NO,ss.CRM_CUST_NO,ss.CUST_TYPE,ss.VAL_SBDV_LEVEL) separator '::') custInfo 
FROM CFTM_CROD_T86_CORP_CUST_SCORE_SUM_03 ss 
WHERE ss.STAT_DT = '2020-12-31' and ss.COMPRE_CERT = '2' and ss.IS_COMPRE_NEW in ('001','011','101','111') AND ss.CUST_TYPE = '1' AND ss.VAL_SBDV_LEVEL in ( 'A1' , 'B1' ) 
group by ss.CUST_NAME ORDER BY max(COMPRE_SCORE) desc 
LIMIT 10 OFFSET 0 ;


