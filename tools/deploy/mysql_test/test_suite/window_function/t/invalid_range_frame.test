# description:
#

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
set @@recyclebin = off;
drop table if exists test;
--enable_warnings

create table test (c1 int primary key, c2 int, c3 int, c4 varchar(100));
insert into test values(1,2,4,'fsa');
insert into test values(2,2,9,'a');
insert into test values(3,1,5,'bfd');

## invalid win which can be decided during resolving
--error 5561
select sum(1) over (order by c1 rows between current row and 2 preceding) from test;
--error 5561
select sum(1) over (order by c1 range between 1 following and current row) from test;
--error 5561
select sum(1) over (order by c1 range between 1 following and 1 preceding) from test;

## range interval expr should be numeric
--error 1064
select sum(1) over (order by c1 range between current row and c4 following) from test;


set @@recyclebin = off;
drop table test;















