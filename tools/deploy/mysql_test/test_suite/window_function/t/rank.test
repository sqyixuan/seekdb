# owner group: sql1
# description:
#
# test of rank

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
set @@recyclebin = off;
drop table if exists rank_test;
--enable_warnings

create table rank_test (c1 int primary key, c2 int, c3 int);
insert into rank_test values (1,1,3);
insert into rank_test values (2,2,2);
insert into rank_test values (3,2,1);
insert into rank_test values (4,3,2);
insert into rank_test values (5,3,6);
insert into rank_test values (6,3,6);
insert into rank_test values (7,4,2);
insert into rank_test values (8,4,1);
insert into rank_test values (9,4,1);
insert into rank_test values (10,4,3);
insert into rank_test values (11,5,5);
insert into rank_test values (12,5,10);
insert into rank_test values (13,5,1);
insert into rank_test values (14,5,2);
insert into rank_test values (15,5,2);

select * from rank_test;

## one partition
select rank() over (order by c1), c1, c2, c3 from rank_test;
## two order by item
select rank() over (order by c2, c3 desc), c1, c2, c3 from rank_test;

--echo "test partition"
select rank() over (partition by c2 order by c1), c1, c2, c3 from rank_test;
select rank() over (partition by c2 order by c1 desc), c1, c2, c3 from rank_test;
select rank() over (partition by c1 order by c1), c1, c2, c3 from rank_test;

# should no contain param
--error ER_PARSE_ERROR 
select rank(-1) over (order by c2), c1, c2 from rank_test;

##should contail order by clause
#--error 5300
#select rank() over (partition by c1), c1, c2 from rank_test;

##should not contail window clause
#--error ER_SYNTAX_ERROR
#select rank() over (partition by c2 order by c1 rows between unbounded preceding and unbounded following), c1, c2 from rank_test;
#--error ER_SYNTAX_ERROR 
#select rank() over (partition by c2 order by c1 rows between unbounded preceding and unbounded following), c1, c2 from rank_test;
#--error ER_SYNTAX_ERROR 
#select rank() over (partition by c2 order by c1 rows between current row and unbounded following), c1, c2 from rank_test;

set @@recyclebin = off;
drop table rank_test;















