# owner group: sql1
# description:
#

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
set @@recyclebin = off;
drop table if exists test;
--enable_warnings

create table test (c1 int primary key, c2 int, c3 int);
insert into test values (1,1,3);
insert into test values (2,2,2);
insert into test values (3,2,1);
insert into test values (4,3,2);
insert into test values (5,3,6);
insert into test values (6,3,6);
insert into test values (7,4,2);
insert into test values (8,4,1);
insert into test values (9,4,1);

select * from (select *, row_number() over(partition by c2 order by c3) as rn from test) a where rn = 1;

# prduce error after pruning, we fix it by forbiding pruning!
select c1 from (select c1, row_number() over(order by c2) as rn from test) v;

# agg result type
drop table if exists test;
create table test(a int, b int, c decimal(10,2) DEFAULT NULL);
insert into test values (1, 1, 1.11),(2,2,2.22);
--source kv.inc
let $cnt = `select count(1) from kv where k = 'agg_func'`;
let $i = 0;

# group_concat结果是错的，已知，等bug修复：
while ($cnt)
{
  let $sql = select v from kv where k = 'agg_func' limit 1 offset $i;
  let $func = query_get_value($sql, v, 1);
  eval select * from (select $func(c) over() as v, c from test) as V where V.c  = V.v;
  dec $cnt;
  inc $i;
}
