# owner: bin.lb
#tags: optimizer
# owner group: sql2
#
# 
# BUG: rank() result is big int in mysql, the range distributed window function only handle the decimal rank().
#
--disable_warnings
drop table if exists t1;
--enable_warnings


create table t1 (c1 int, c2 int, c3 int);
--disable_query_log
let $i = 1;
while ($i < 100)
{
	eval insert into t1 (c1, c2, c3) values (round($i/20, 0), round($i/5, 0), $i);
	inc $i;
}
--enable_query_log

select /*+ parallel(3) PQ_DISTRIBUTE_WINDOW(LIST) */ c1, c2, c3, avg(c3) over (partition by c1 order by c2) v from t1 order by c1, c2, c3, v;
select /*+ parallel(3) PQ_DISTRIBUTE_WINDOW(LIST) */ c1, c2, c3, sum(c3) over (partition by c1 order by c2 range between unbounded preceding and current row) v from t1 order by c1, c2, c3, v;
select /*+ parallel(3) PQ_DISTRIBUTE_WINDOW(LIST) */ c1, c2, count(c3) over (partition by c1 order by c2 rows between unbounded preceding and current row) v from t1 order by c1, c2, v;
select /*+ no_rewrite parallel(3) */ c1, c2, max(v) from (select /*+ PQ_DISTRIBUTE_WINDOW(LIST) */c1, c2, c3, max(c3) over (partition by c1 order by c2 rows between unbounded preceding and current row) v from t1) group by c1, c2 order by c1, c2;
select /*+ no_rewrite parallel(3) */ c1, c2, min(v) from (select /*+ PQ_DISTRIBUTE_WINDOW(LIST) */c1, c2, c3, min(c3) over (partition by c1 order by c2 rows between unbounded preceding and current row) v from t1) group by c1, c2 order by c1, c2;
select /*+ no_rewrite parallel(3) */ c1, c2, max(v) from (select /*+ PQ_DISTRIBUTE_WINDOW(LIST) */c1, c2, c3, sum(c3) over (partition by c1 order by c2 rows between unbounded preceding and current row) v from t1) group by c1, c2 order by c1, c2;
select /*+ parallel(3) PQ_DISTRIBUTE_WINDOW(LIST) */ c1, c2, c3, min(c3) over (partition by c1 order by c2 range between unbounded preceding and current row) v from t1 order by c1, c2, c3, v;
select /*+ parallel(3) PQ_DISTRIBUTE_WINDOW(LIST) */ c1, c2, c3, max(c3) over (partition by c1 order by c2 range between unbounded preceding and current row) v from t1 order by c1, c2, c3, v;
select /*+ parallel(3) PQ_DISTRIBUTE_WINDOW(LIST)  */ c1, c2, c3, count(c3) over (partition by c1 order by c2 range between unbounded preceding and current row) v from t1 order by c1, c2, c3, v;
select /*+ parallel(3) PQ_DISTRIBUTE_WINDOW(LIST)  */ c1, c2, c3, rank() over (partition by c1 order by c2) v from t1 order by c1, c2, c3, v;
select /*+ parallel(3) PQ_DISTRIBUTE_WINDOW(LIST)  */ c1, c2, c3, sum(c3) over (partition by c1 order by c2, c3 rows between unbounded preceding and current row) v from t1 order by c1, c2, c3, v;

drop table t1;

create table t1(a int, b int, c int);

insert into t1 select uniform(1, 1000, random(1)), uniform(1, 1000, random(2)), uniform(1, 1000, random(3)) from table(generator(36));

# row_number do not support range dist
explain basic select /*+parallel(2) pq_distribute_window((0, 1) list)*/ row_number() over (partition by a order by b), rank() over(partition by a order by b) from t1 order by 1, 2;

select /*+parallel(2) pq_distribute_window((0, 1) list)*/ row_number() over (partition by a order by b), rank() over(partition by a order by b) from t1 order by 1, 2;

explain basic select /*+parallel(2) pq_distribute_window((0, 1) list)*/ last_value(c) over (partition by a order by b), rank() over(partition by a order by b) from t1 order by 1, 2;
select /*+parallel(2) pq_distribute_window((0, 1) list)*/ last_value(c) over (partition by a order by b), rank() over(partition by a order by b) from t1 order by 1, 2;

explain basic select /*+parallel(2) pq_distribute_window((0, 1) list)*/ cume_dist() over (partition by a order by b), rank() over(partition by a order by b) from t1 order by 1, 2;
select /*+parallel(2) pq_distribute_window((0, 1) list)*/ cume_dist() over (partition by a order by b), rank() over(partition by a order by b) from t1 order by 1, 2;


explain basic select /*+parallel(2) pq_distribute_window((0, 1) list)*/ sum(c) over (partition by a order by b), rank() over(partition by a order by b) from t1 order by 1, 2;
select /*+parallel(2) pq_distribute_window((0, 1) list)*/ sum(c) over (partition by a order by b), rank() over(partition by a order by b) from t1 order by 1, 2;