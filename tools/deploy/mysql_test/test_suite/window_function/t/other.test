#owner: zongmei.zzm
#owner group: sql1
# tags: optimizer
#description:

--disable_warnings
drop database if exists wf;
create database wf;
use wf;
--disable_warnings

create table t1(a int primary key, b int, c varchar(20), d int);

insert into t1 values(1, 1, "121", 4);
insert into t1 values(2, -1, "3f1", 400);
insert into t1 values(3, 4, "hh1", 19);
insert into t1 values(4, 6, "c1", 4);
insert into t1 values(5, 2, "c1", 23);
insert into t1 values(6, -3, "a1", 4);
insert into t1 values(7, 3, "21", 41);
insert into t1 values(8, 8, "b1", 32);
insert into t1 values(9, 3, "ha", 1);
insert into t1 values(10, 19, "he", 3);

# subquery, filter
select * from (select *, row_number() over(order by a) as rn from t1) a where rn <= 3;

--error 1111
select count(count(count(1))) over() from t1;
--error 1064 
select count(1) + 1 over() from t1;
--disable_result_log
select count(count(1)) over() from t1;
select 1 + count(1) over() from t1;
--enable_result_log

set global ob_enable_sql_audit = false;

# plan cache in window function的功能已经已经关闭
# bug: 
#let $test_sql = select row_number() over(order by a) as rnkkkk from t1;
#--disable_result_log
#eval $test_sql;
#--enable_result_log
#let $max_request_id = `select /*+ QUERY_TIMEOUT (100000000) */ max(request_id) from oceanbase.gv\\\$sql_audit`;
#--disable_result_log
#eval $test_sql;
#--enable_result_log
#--disable_query_log
#eval select /*+ QUERY_TIMEOUT (100000000) */ is_hit_plan from oceanbase.GV\$OB_SQL_AUDIT where query_sql = '$test_sql' and request_id > $max_request_id;
#--enable_query_log

# serialization
create table t2(a int primary key, b int) partition by hash(a) partitions 4;
insert into t2 values(1, 1);
insert into t2 values(2, -1);
insert into t2 values(3, 4);
insert into t2 values(4, 6);
insert into t2 values(5, 2);
insert into t2 values(6, -3);
insert into t2 values(7, 3);
insert into t2 values(8, 8);
insert into t2 values(9, 3);
insert into t2 values(10, 19);
explain select count(1) over(partition by a) from t2 order by a;
select count(1) over(partition by a) from t2 order by a;

set global ob_enable_sql_audit = true;

--disable_warnings
drop database if exists wf;
--disable_warnings

