#owner: zongmei.zzm
#owner group: sql1
#description: 这个case最初是兼容oracle禁止某些函数指定frame的, 兼容mysql后其实就名存实亡了

--disable_warnings
drop database if exists wf;
create database wf;
use wf;
--disable_warnings

create table t1(a int primary key, b int, c varchar(20), d int);

# not allowed
#--error ER_SYNTAX_ERROR
#select ntile(1) over(order by 1 rows between 1 preceding and 2 following) from t1;
#--error ER_SYNTAX_ERROR
#select row_number() over(order by 1 rows between 1 preceding and 2 following) from t1;
#--error ER_SYNTAX_ERROR
#select cume_dist() over(order by 1 rows between 1 preceding and 2 following) from t1;
#--error ER_SYNTAX_ERROR
#select lag(1) over(order by 1 rows between 1 preceding and 2 following) from t1;
#--error ER_SYNTAX_ERROR
#select lead(1) over(order by 1 rows between 1 preceding and 2 following) from t1;
#--error ER_SYNTAX_ERROR
#select rank() over(order by 1 rows between 1 preceding and 2 following) from t1;
#--error ER_SYNTAX_ERROR
#select percent_rank() over(order by 1 rows between 1 preceding and 2 following) from t1;
#--error ER_SYNTAX_ERROR
#select dense_rank() over(order by 1 rows between 1 preceding and 2 following) from t1;

# allowed
--error 3592
select sum(1) over(order by 1 rows between 1 preceding and 2 following) from t1;
--error 3592
select count(1) over(order by 1 rows between 1 preceding and 2 following) from t1;
--error 3592
select min(1) over(order by 1 rows between 1 preceding and 2 following) from t1;
--error 3592
select max(1) over(order by 1 rows between 1 preceding and 2 following) from t1;
--error 3592
select avg(1) over(order by 1 rows between 1 preceding and 2 following) from t1;
--error 3592
select group_concat(1) over(order by 1 rows between 1 preceding and 2 following) from t1;
--error 3592
select first_value(1) over(order by 1 rows between 1 preceding and 2 following) from t1;
--error 3592
select last_value(1) over(order by 1 rows between 1 preceding and 2 following) from t1;
--error 3592
select nth_value(a, 2) over(order by 1 rows between 1 preceding and 2 following) from t1;
--error 3592
select listagg(a) over(order by 1 rows between 1 preceding and 2 following) from t1;


--disable_warnings
drop database if exists wf;
--disable_warnings

