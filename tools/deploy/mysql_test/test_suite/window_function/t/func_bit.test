# owner: sean.yyj
# owner group: sql3
# description: test for bit_and, bit_or and bit_xor in window function
 
--result_format 3
--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1 (c1 int primary key, c2 int, c3 int, c4 varchar(100));
insert into t1 values (1, 1, 3, 'fdsf');
insert into t1 values (2, 2, 2, '1fdfdsf');
insert into t1 values (3, 2, 1, 'kkkkk');
insert into t1 values (4, 3, 2, '8y77');
insert into t1 values (5, 3, 6, 'fdfd');
insert into t1 values (6, 3, 6, 'mnn');
insert into t1 values (7, 4, 2, '6fe');
insert into t1 values (8, 4, NULL, 'kk');
insert into t1 values (9, 4, 1, 'kk');
insert into t1 values (10, 4, 3, 'kk');

--echo normal query
select *, bit_and(c1) over (), bit_and(c1) over (partition by c1), bit_and(c1) over (partition by c2), bit_and(c1) over (partition by c4) from t1 order by c1;
select *, bit_or(c1) over (), bit_or(c1) over (partition by c1), bit_or(c1) over (partition by c2), bit_or(c1) over (partition by c4) from t1 order by c1;
select *, bit_xor(c1) over (), bit_xor(c1) over (partition by c1), bit_xor(c1) over (partition by c2), bit_xor(c1) over (partition by c4) from t1 order by c1;

--echo with named_window
select *, bit_and(c1) over w, bit_or(c2) over w, bit_xor(c3) over w from t1 window w as (partition by c1) order by c1;

select c1, bit_and(c1) over (w order by c2 rows between 2 preceding and 1 preceding) from t1 window w as (partition by c1) order by c1;
select c1, bit_or(c1) over (w order by c2 rows between 2 preceding and 1 preceding) from t1 window w as (partition by c1) order by c1;
select c1, bit_xor(c1) over (w order by c2 rows between 2 preceding and 1 preceding) from t1 window w as (partition by c1) order by c1;

--echo return UINT_MAX/0 when invalid window
select c1, bit_and(c1) over (order by c2 rows between 1 preceding and 2 preceding) from t1;
select c1, bit_or(c1) over (order by c2 rows between 1 preceding and 2 preceding) from t1;
select c1, bit_xor(c1) over (order by c2 rows between 1 preceding and 2 preceding) from t1;

--echo return UINT_MAX/0 when window is empty
select c1, bit_and(c1) over (order by c2 rows between 2 preceding and 1 preceding) from t1;
select c1, bit_or(c1) over (order by c2 rows between 2 preceding and 1 preceding) from t1;
select c1, bit_xor(c1) over (order by c2 rows between 2 preceding and 1 preceding) from t1;

drop table t1;



--echo for distrubute scene
create table t1(c1 int, c2 int, c3 int, c4 int) PARTITION BY hash(c4) partitions 4;
insert into t1 values (NULL, 1, 3, 1);
insert into t1 values (NULL, 2, 2, 1);
insert into t1 values (NULL, 2, 1, 1);
insert into t1 values (NULL, 3, 2, 1);
insert into t1 values (NULL,  4, 1, 3);
insert into t1 values (1,  3, 6, 2);
insert into t1 values (2,  3, 6, 2);
insert into t1 values (3,  4, 2, 2);
insert into t1 values (5,  4, 8, 3);
insert into t1 values (11, 4, 3, 3);
insert into t1 values (7,  4, 0, 4);
insert into t1 values (13, 4, 1, 4);
insert into t1 values (10, 4, 3, 4);

--echo p1 all row are NULL, p3 has one NULL
select c1, bit_and(c1) over (partition by c3) from t1;
select c1, bit_or(c1) over (partition by c3) from t1;
select c1, bit_xor(c1) over (partition by c3) from t1;

--echo p4 has no row
select c1, bit_and(c1) over (partition by c3) from t1 where c4 != 4;
select c1, bit_or(c1) over (partition by c3) from t1 where c4 != 4;
select c1, bit_xor(c1) over (partition by c3) from t1 where c4 != 4;

--echo return UINT_MAX/0 when invalid window
select c1, bit_and(c1) over (order by c2 rows between 1 preceding and 2 preceding) from t1;
select c1, bit_or(c1) over (order by c2 rows between 1 preceding and 2 preceding) from t1;
select c1, bit_xor(c1) over (order by c2 rows between 1 preceding and 2 preceding) from t1;

--echo return UINT_MAX/0 when window is empty
select c1, bit_and(c1) over (order by c2 rows between 2 preceding and 1 preceding) from t1;
select c1, bit_or(c1) over (order by c2 rows between 2 preceding and 1 preceding) from t1;
select c1, bit_xor(c1) over (order by c2 rows between 2 preceding and 1 preceding) from t1;

drop table t1;