#owner: zongmei.zzm
#owner group: sql1
#description:

--disable_warnings
drop database if exists nw;
create database nw;
use nw;
--result_format 3
--disable_warnings

create table t1(a int primary key, b int, c varchar(20), d int);

insert into t1 values(1, 1, "121", 4);
insert into t1 values(2, -1, "3f1", 400);
insert into t1 values(3, 4, "hh1", 19);
insert into t1 values(4, 6, "c1", 4);
insert into t1 values(5, 2, "c1", 23);
insert into t1 values(6, 3, "a1", 4);
insert into t1 values(7, 3, "21", 41);
insert into t1 values(8, 8, "b1", 32);
insert into t1 values(9, 3, "ha", 1);
insert into t1 values(10, 6, "he", 3);

# 错误码待梳理
--error 3581
select count(1) over (w partition by a) from t1 window w as ();
--error 3581
select count(1) over (w partition by a) from t1 window w as (partition by a);
--error 3583
select count(1) over (w order by b) from t1 window w as (partition by a order by b);
--error 3582
select count(1) over (w rows 1 preceding) from t1 window w as (partition by a order by b rows 1 preceding);
--error 5929
select count(1) over w from t1 window w1 as ();
--error 5929
select count(1) over w3 from t1 window w as (), w2 as ();
--error 1235
select count(1) over w from t1 window w as (), w2 as (w3);
--error 1235
select count(1) over w from t1 window w as (w2), w2 as (w);
--error ER_PARSE_ERROR
select count(1) over w from t1 window w as (), w2 as w;
--error ER_PARSE_ERROR
select count(1) over w from t1 window w as partition by a;
--error ER_PARSE_ERROR
select count(1) over w from t1 window w as () group by a;
--error ER_PARSE_ERROR
select count(1) over w from t1 group by a window w as () having a;
--error ER_PARSE_ERROR
select count(1) over w from t1 order by a window w as ();

select *, count(1) over w from t1 window w as ();
select *, count(1) over (w) from t1 window w as ();
select *, count(1) over w from t1 window w as (partition by b);
select *, listagg(a) over (w order by a) from t1 window w as (partition by b);
select *, listagg(a) over (w2 rows 1 preceding) from t1 window w as (partition by b), w2 as (w order by a);
select *, listagg(a) over w, listagg(a) over (w) from t1 window w as (partition by b order by a rows 1 preceding);
select *, listagg(sum(a)) over w2 from t1 group by b having 1 window w2 as (w order by b), w as ();

select *, sum(a) over w, avg(a) over w, rank() over w2, count(a) over w3 from t1 window w as (partition by b), w2 as (w order by d), w3 as (w2 rows 5 preceding) order by a;


--disable_warnings
drop database if exists nw;
--disable_warnings

