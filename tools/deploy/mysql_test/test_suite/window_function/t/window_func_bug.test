--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: zongmei.zzm
# owner group: SQL1
# description: window function relation bugs


--result_format 4


##bug: 

--disable_warnings
drop table if exists tb;
--enable_warnings

set @@sql_mode ='STRICT_ALL_TABLES,NO_ZERO_IN_DATE,ONLY_FULL_GROUP_BY ';

CREATE TABLE tb(a INT, b INT);
insert into tb values(1,1),(1,2),(2,2),(3,3);
SELECT a, SUM(a) OVER () FROM tb GROUP BY a;

--error 1055
SELECT a, SUM(b) OVER () FROM tb GROUP BY a;
--error 1140
SELECT sum(a), SUM(b) OVER () FROM tb;

set @@sql_mode=default;

drop table tb;

##bug: 

--disable_warnings
drop table if exists t_time;
--enable_warnings

CREATE TABLE t_time(t TIME, ts TIMESTAMP);
INSERT INTO t_time VALUES ('12:30', '2016-07-05 08:30:42');

--error 3586
SELECT t, FIRST_VALUE(t) OVER (ORDER BY t RANGE INTERVAL -1 HOUR PRECEDING) FROM t_time;
--error 3586
SELECT t, FIRST_VALUE(t) OVER (ORDER BY t RANGE INTERVAL NULL HOUR PRECEDING) FROM t_time;
--error 3586
SELECT t, FIRST_VALUE(t) OVER (ORDER BY t RANGE BETWEEN INTERVAL -1 HOUR PRECEDING AND INTERVAL 2 HOUR PRECEDING) FROM t_time;
--error 3590
SELECT t, FIRST_VALUE(t) OVER (ORDER BY t RANGE INTERVAL t HOUR PRECEDING) FROM t_time;

drop table t_time;

##bug:

--disable_warnings
drop table if exists t1;
--enable_warnings

CREATE TABLE t1 (id INTEGER, sex CHAR(1));
INSERT INTO t1 VALUES (1, 'M');
INSERT INTO t1 VALUES (2, 'F');
INSERT INTO t1 VALUES (3, 'F');
INSERT INTO t1 VALUES (4, 'F');
INSERT INTO t1 VALUES (5, 'M');
INSERT INTO t1 VALUES (10, NULL);
INSERT INTO t1 VALUES (11, NULL);

--error 1064
SELECT sex, COUNT(id) OVER (ORDER BY id RANGE -1 PRECEDING) FROM t1;
--error 1064
SELECT sex, COUNT(id) OVER (ORDER BY id RANGE -0.1 PRECEDING) FROM t1;

drop table t1;


##bug:

--disable_warnings
drop table if exists t1, t2;
--enable_warnings

CREATE TABLE t1 (id INTEGER, sex CHAR(1));
INSERT INTO t1 VALUES (1, 'M');
INSERT INTO t1 VALUES (2, 'F');
INSERT INTO t1 VALUES (3, 'F');
INSERT INTO t1 VALUES (4, 'F');
INSERT INTO t1 VALUES (5, 'M');
CREATE TABLE t2 (user_id INTEGER NOT NULL, date DATE);
INSERT INTO t2 VALUES (1, '2002-06-09');
INSERT INTO t2 VALUES (2, '2002-06-09');
INSERT INTO t2 VALUES (1, '2002-06-09');
INSERT INTO t2 VALUES (3, '2002-06-09');
INSERT INTO t2 VALUES (4, '2002-06-09');
INSERT INTO t2 VALUES (4, '2002-06-09');
INSERT INTO t2 VALUES (5, '2002-06-09');

SELECT  sex, AVG(id) AS uids, RANK() OVER w `rank` 
FROM t1 u, t2
WHERE t2.user_id = u.id 
GROUP BY sex
WINDOW w AS (ORDER BY AVG(id));

SELECT  sex, AVG(id) AS uids, RANK() OVER w 
FROM t1 u, t2
WHERE t2.user_id = u.id 
GROUP BY sex
WINDOW w AS (ORDER BY id);

drop table t1;
drop table t2;


