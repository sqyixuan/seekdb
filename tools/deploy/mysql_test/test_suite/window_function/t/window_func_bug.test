##bug:

--disable_warnings
drop table if exists t1. t2;
--enable_warnings

CREATE TABLE t1 (id INTEGER, sex CHAR(1));
INSERT INTO t1 VALUES (1, 'M');
INSERT INTO t1 VALUES (2, 'F');
INSERT INTO t1 VALUES (3, NULL);
INSERT INTO t1 VALUES (NULL, 'M');

--error 3589
SELECT NTILE(5) OVER w, ROW_NUMBER() OVER w, id, SUM(id) OVER w
FROM t1
WINDOW w AS (ORDER BY id DESC RANGE INTERVAL 2 MONTH PRECEDING);

CREATE TABLE t2 (user_id INTEGER NOT NULL, date DATE);
INSERT INTO t2 VALUES (1, '2002-06-09');
INSERT INTO t2 VALUES (2, '2002-06-09');
INSERT INTO t2 VALUES (1, '2002-06-09');
INSERT INTO t2 VALUES (3, '2002-06-09');
INSERT INTO t2 VALUES (4, '2002-06-09');
INSERT INTO t2 VALUES (4, '2002-06-09');
INSERT INTO t2 VALUES (5, '2002-06-09');

--error 3588
SELECT user_id, date, COUNT(*) OVER (ORDER BY date RANGE 1 PRECEDING)
FROM t2;

drop table t1, t2;

##bug:

--disable_warnings
drop table if exists t6;
--enable_warnings

CREATE TABLE t6(t TIME, ts TIMESTAMP);
INSERT INTO t6 VALUES ('12:30', '2016-07-05 08:30:42');
INSERT INTO t6 VALUES ('22:30', '2015-07-05 08:30:43');
INSERT INTO t6 VALUES ('13:30', '2014-07-05 08:30:44');

--error 3582
SELECT t, COUNT(t) OVER w1
FROM t6
WINDOW w1 AS (ORDER BY t RANGE BETWEEN CURRENT ROW AND INTERVAL 1 DAY FOLLOWING), w2 AS (w1);

--error 3582
SELECT t, COUNT(t) OVER w1 FROM t6 WINDOW w1 AS (ORDER BY t ROWS UNBOUNDED PRECEDING), w2 AS (w1);

drop table t6;

##bug:

--disable_warnings
drop table if exists t6;
drop view if exists v1;
--enable_warnings

CREATE TABLE t6(t TIME, ts TIMESTAMP);
INSERT INTO t6 VALUES ('12:30', '2016-07-05 08:30:42');
INSERT INTO t6 VALUES ('22:30', '2015-07-05 08:30:43');
INSERT INTO t6 VALUES ('13:30', '2014-07-05 08:30:44');
INSERT INTO t6 VALUES ('01:30', '2013-07-05 08:30:45');

SELECT  COUNT(*) OVER w1 FROM t6
WINDOW w1 AS (ORDER BY t RANGE INTERVAL '1.1' SECOND_MICROSECOND PRECEDING);

CREATE or replace VIEW v1 AS
SELECT  COUNT(*) OVER w1
FROM t6
WINDOW w1 AS (ORDER BY t RANGE INTERVAL '1.1' SECOND_MICROSECOND PRECEDING);

SELECT * FROM v1;
desc v1;

SELECT  COUNT(*) OVER w1 FROM t6
WINDOW w1 AS (ORDER BY t RANGE INTERVAL '1-1' YEAR_MONTH PRECEDING);

CREATE or replace VIEW v1 AS
SELECT  COUNT(*) OVER w1
FROM t6
WINDOW w1 AS (ORDER BY t RANGE INTERVAL '1-1' YEAR_MONTH PRECEDING);

SELECT * FROM v1;
desc v1;

SELECT  COUNT(*) OVER w1 FROM t6
WINDOW w1 AS (ORDER BY t RANGE INTERVAL 1 MICROSECOND PRECEDING);

CREATE or replace VIEW v1 AS
SELECT  COUNT(*) OVER w1
FROM t6
WINDOW w1 AS (ORDER BY t RANGE INTERVAL 1 MICROSECOND PRECEDING);

SELECT * FROM v1;
desc v1;

SELECT  COUNT(*) OVER w1 FROM t6
WINDOW w1 AS (ORDER BY t RANGE INTERVAL 1 DAY PRECEDING);

CREATE or replace VIEW v1 AS
SELECT  COUNT(*) OVER w1
FROM t6
WINDOW w1 AS (ORDER BY t RANGE INTERVAL 1 DAY PRECEDING);

SELECT * FROM v1;
desc v1;

DROP VIEW v1;
drop table t6;

##bug:

--disable_warnings
drop table if exists t1;
--enable_warnings

CREATE TABLE t1 (id INTEGER, sex CHAR(1));
INSERT INTO t1 VALUES (1, 'M');
INSERT INTO t1 VALUES (2, 'F');
INSERT INTO t1 VALUES (3, 'F');

--error 1210
SELECT id, NTILE(NULL) OVER w
FROM t1
WINDOW w AS (ORDER BY id);

SET @a=NULL;
--error 1210
SELECT id, NTILE(@s) OVER w
FROM t1
WINDOW w AS (ORDER BY id);

--error 1210
SELECT id, NTILE('1') OVER w
FROM t1
WINDOW w AS (ORDER BY id);

PREPARE p FROM "SELECT id, NTILE(?) OVER w FROM t1 WINDOW w AS (ORDER BY id)";
SET @p1= '1';
--error 1210
EXECUTE p USING @p1;

drop table t1;

