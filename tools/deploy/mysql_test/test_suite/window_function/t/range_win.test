#

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
set @@recyclebin = off;
drop table if exists test;
--enable_warnings

create table test (c1 int, c2 float, c3 int);
insert into test values (1,1.1,3);
insert into test values (2,1.2,2);
insert into test values (2,2.1,1);
insert into test values (4,2.3,2);
insert into test values (5,2.4,6);
insert into test values (5,2.5,6);
insert into test values (5,4,2);
insert into test values (8,4.8,1);
insert into test values (9,4.1,1);
insert into test values (9,4.2,1);
insert into test values (9,4.3,1);
insert into test values (9,4.6,1);

select *, sum(c3) over(partition by c1 order by c2 range between 0.1 preceding and 0.1 following) from test;

--error 5561
select sum(c3) over(order by c2,c1 range between 1 preceding and 1 following) from test;

select sum(c3) over(order by c2,c1 range between unbounded preceding and current row) from test;
select sum(c3) over(order by c2 range between 1 preceding and 1 following) from test;
select sum(c3) over(order by c2,c1 rows between 1 preceding and 1 following) from test;











