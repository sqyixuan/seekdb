# owner: nijia.nj
# owner group: sql2
# description:
#
# test of remote

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
set @@recyclebin = off;
drop database if exists nijia;
create database nijia;
--enable_warnings

alter system set enable_rebalance = 'false';

create table nijia.t1 (c1 int primary key, c2 int, c3 int) partition by hash(c1) partitions 5;
insert into nijia.t1 values (1,1,3);
insert into nijia.t1 values (2,2,2);
insert into nijia.t1 values (3,2,1);
insert into nijia.t1 values (4,3,2);

--disable_query_log
let $svr = `select @svr_ip:=concat(svr_ip,':',svr_port) from oceanbase.__all_server where svr_ip != host_ip()`
let $cnt = 5
while($cnt)
{
  eval select @svr_ip:=concat(svr_ip,':',svr_port) from oceanbase.__all_meta_table where tenant_id = 1 and table_id = $tid and role = 2 limit 1;
  let $tid = `select table_id from oceanbase.__all_virtual_table where tenant_id = 1 and database_id in (select database_id from oceanbase.__all_virtual_database where database_name ='nijia')`;
  eval select @svr_ip:=concat(svr_ip,':',svr_port) from oceanbase.__all_meta_table where tenant_id = 1 and table_id = $tid and role = 2 limit 1;
  let $svr=`select @svr_ip`;
  alter system switch replica leader partition_id='0%5@$tid' server='$svr';
  dec $cnt;
}
--sleep 10
eval select count(1) >= 2 from (select 1 from oceanbase.__all_meta_table where tenant_id = 1 and table_id = $tid and role = 1 group by svr_ip, svr_port) a;
--enable_query_log

explain select /*+ READ_CONSISTENCY(weak)*/ * from (select *,row_number() over (partition by c2 order by c3) as rn from nijia.t1) a where rn = 1;
select /*+ READ_CONSISTENCY(weak)*/ * from (select *,row_number() over (partition by c2 order by c3) as rn from nijia.t1) a where rn = 1;

--disable_warnings
set @@recyclebin = off;
#drop database nijia;
--enable_warnings














