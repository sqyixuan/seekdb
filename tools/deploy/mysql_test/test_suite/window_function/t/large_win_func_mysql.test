# owner: yibo.tyf
# owner group: sql1
# tags: optimizer,windown_function
# description:
#
# test number of win func greater than 32
# link: 

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1(c1 int, c2 int, c3 int);
insert into t1(c1, c2, c3) values(1, 2, 3), (3, 4, 5), (4, 5, 6), (6, 7, 8);

--explain_protocol 2
--result_format 4

let $cnt= 1;
let $win_expr =;
while($cnt < 200)
{
  let $win_expr=$win_expr min(c1 + $cnt) over() w$cnt, ;
  inc $cnt;
}
--echo window func
let $sql=explain select $win_expr min(c1 + 201) over() w201 from t1;
eval $sql;
let $sql=select $win_expr min(c1 + 201) over() w201 from t1;
eval $sql;

--echo named window
let $cnt= 1;
let $named_win_select =;
let $named_win_def =;
while($cnt < 126)
{
  let $named_win_select=$named_win_select min(c1 + $cnt) over w$cnt as c$cnt, ;
  let $named_win_def=$named_win_def w$cnt as (order by c1 + $cnt), ;
  inc $cnt;
}

let $sql=explain select $named_win_select min(c1 + 126) over w126 as c126 from t1 WINDOW $named_win_def w126 as (order by c1 + 126);
eval $sql;
let $sql=select $named_win_select min(c1 + 126) over w126 as c126 from t1 WINDOW $named_win_def w126 as (order by c1 + 126);
--echo coredumped when executed: $sql
#eval $sql;

--echo ref named window
let $cnt= 1;
let $named_win_select =;
let $named_win_def =;
let $w0_def = WINDOW w0 as (order by c1);
while($cnt < 126)
{
  let $named_win_select=$named_win_select min(c1 + $cnt) over w$cnt as c$cnt, ;
  let $named_win_def=$named_win_def w$cnt as (w0), ;
  inc $cnt;
}

let $sql=explain select $named_win_select min(c1 + 126) over w126 as c126 from t1 $w0_def, $named_win_def w126 as (order by c1 + 126);
eval $sql;
let $sql=select $named_win_select min(c1 + 126) over w126 as c126 from t1 $w0_def, $named_win_def w126 as (order by c1 + 126);
--echo coredumped when executed: $sql
#eval $sql;

--explain_protocol 0
--result_format 4
drop table if exists t1;
