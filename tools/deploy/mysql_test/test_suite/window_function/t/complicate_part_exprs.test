#owner: zongmei.zzm
#owner group: sql2
#description:

--result_format 4

--disable_warnings
drop table if exists table1000_key_pk_parts_8_int;
--enable_warnings

 CREATE TABLE `table1000_key_pk_parts_8_int` (
  `col_int` int(11) DEFAULT NULL,
  `col_varchar_200` varchar(200) DEFAULT NULL,
  `col_varchar_512` varchar(512) DEFAULT NULL,
  `col_bigint` bigint(20) DEFAULT NULL,
  `pk` int(11) NOT NULL,
  PRIMARY KEY (`pk`)
) DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0 LOB_INROW_THRESHOLD=0
 partition by key(pk)
(partition `p0`,
partition `p1`,
partition `p2`,
partition `p3`,
partition `p4`,
partition `p5`,
partition `p6`,
partition `p7`) WITH COLUMN GROUP(each column);

--source mysql_test/include/copy_data_for_load.inc
load data infile 'data_for_mysqltest_loaddata/table1000_key_pk_parts_8_int.csv' into table table1000_key_pk_parts_8_int fields terminated by ',';

SELECT pk, LEAD(pk) over (partition by SQRT( col_bigint ) ORDER BY pk, col_int ), DENSE_RANK() over (partition by SQRT( col_bigint ) ORDER BY pk, col_int ) from table1000_key_pk_parts_8_int  ORDER BY pk, col_bigint desc;