#
# test of ntile

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
set @@recyclebin = off;
drop table if exists ntile_test;
drop table if exists ntile_test2;
--enable_warnings

create table ntile_test (c1 int primary key, c2 int);
insert into ntile_test values (1,1);
insert into ntile_test values (2,2);
insert into ntile_test values (3,2);
insert into ntile_test values (4,3);
insert into ntile_test values (5,3);
insert into ntile_test values (6,3);
insert into ntile_test values (7,4);
insert into ntile_test values (8,4);
insert into ntile_test values (9,4);
insert into ntile_test values (10,4);
insert into ntile_test values (11,5);
insert into ntile_test values (12,5);
insert into ntile_test values (13,5);
insert into ntile_test values (14,5);
insert into ntile_test values (15,5);

set @ntile_var = 1;
select ntile(@ntile_var) over () from ntile_test;

set @ntile_var = 1.0;
--error 1210
select ntile(@ntile_var) over () from ntile_test;

--disable_warnings
drop procedure if exists test_p;
drop procedure if exists test_p2;
--enable_warnings

delimiter //;
create procedure test_p()
begin
declare b double;
select 1.0 from dual into b;
select ntile(b) over() from ntile_test;
end;
//

create procedure test_p2()
begin
declare b int;
select 1 from dual into b;
select ntile(b) over() from ntile_test;
end;
//

delimiter ;//
--error 1210
call test_p();

call test_p2();

select * from ntile_test;
--error ER_WRONG_ARGUMENTS
select ntile(0) over (order by c2), c1, c2 from ntile_test;
--error ER_WRONG_ARGUMENTS
select ntile(-1) over (order by c2), c1, c2 from ntile_test;
--error ER_WRONG_ARGUMENTS
select ntile(1 - 2.3) over (order by c2), c1, c2 from ntile_test;

## select 1<<63 is 9223372036854775808
--error 1210
select ntile(9223372036854775808) over (order by c2), c1, c2 from ntile_test;
--error 0,1264
select ntile(9223372036854775808-1) over (order by c2), c1, c2 from ntile_test;

--error 1210
select ntile(1 << 63) over (order by c2), c1, c2 from ntile_test;
select ntile((1 << 63) - 1) over (order by c2), c1, c2 from ntile_test;

--error 1210
select ntile(power(2,2)) over (order by c2), c1, c2 from ntile_test;
#select ntile(c1 + 1) over (order by c2), c1, c2 from ntile_test;
--error 1210
select ntile(1 + 1.2) over (order by c2), c1, c2 from ntile_test;
## one partition
select ntile(1) over (order by c1), c1, c2 from ntile_test;
select ntile(2) over (order by c1), c1, c2 from ntile_test;
select ntile(3) over (order by c1), c1, c2 from ntile_test;
select ntile(4) over (order by c1), c1, c2 from ntile_test;
select ntile(5) over (order by c1), c1, c2 from ntile_test;
select ntile(6) over (order by c1), c1, c2 from ntile_test;
select ntile(7) over (order by c1), c1, c2 from ntile_test;
select ntile(8) over (order by c1), c1, c2 from ntile_test;
select ntile(9) over (order by c1), c1, c2 from ntile_test;
select ntile(10) over (order by c1), c1, c2 from ntile_test;
select ntile(11) over (order by c1), c1, c2 from ntile_test;
select ntile(12) over (order by c1), c1, c2 from ntile_test;
select ntile(13) over (order by c1), c1, c2 from ntile_test;
select ntile(14) over (order by c1), c1, c2 from ntile_test;
select ntile(15) over (order by c1), c1, c2 from ntile_test;
select ntile(16) over (order by c1), c1, c2 from ntile_test;

--echo "test partition"
select ntile(3) over (partition by c2 order by (c1)), c1, c2 from ntile_test;
select ntile(3) over (partition by c2 order by (c1) desc), c1, c2 from ntile_test;

select ntile(1) over (partition by c1 order by c1), c1, c2 from ntile_test;

##not specifiy order by clause
#--error 5300
#select ntile(3) over (partition by c1), c1, c2 from ntile_test;

#--error ER_SYNTAX_ERROR
#select ntile(3) over (partition by c2 order by c1 rows between unbounded preceding and unbounded following), c1, c2 from ntile_test;
#--error ER_SYNTAX_ERROR
#select ntile(3) over (partition by c2 order by c1 rows between unbounded preceding and unbounded following), c1, c2 from ntile_test;
#--error ER_SYNTAX_ERROR
#select ntile(3) over (partition by c2 order by c1 rows between current row and unbounded following), c1, c2 from ntile_test;


## test order by
create table ntile_test2 (id int primary key, c1 int, c2 int, c3 int, c4 int) partition by key(id) partitions 3;
insert into ntile_test2 values (1, 1, 1, 1, 1);
insert into ntile_test2 values (2, 2, 2, 2, 2);
insert into ntile_test2 values (3, 3, 3, 3, 3);
insert into ntile_test2 values (4, 4, 4, 4, 4);

insert into ntile_test2 values (5, 10, 20, 30, 40);
insert into ntile_test2 values (6, 10, 20, 40, 30);
insert into ntile_test2 values (7, 10, 30, 20, 40);
insert into ntile_test2 values (8, 10, 30, 40, 20);
insert into ntile_test2 values (9, 10, 40, 20, 30);
insert into ntile_test2 values (10, 10, 40, 30, 20);

insert into ntile_test2 values (12, 20, 10, 30, 40);
insert into ntile_test2 values (13, 20, 10, 40, 30);
insert into ntile_test2 values (14, 20, 30, 10, 40);
insert into ntile_test2 values (15, 20, 30, 40, 10);
insert into ntile_test2 values (16, 20, 40, 10, 30);
insert into ntile_test2 values (17, 20, 40, 30, 10);

insert into ntile_test2 values (18, 30, 10, 20, 40);
insert into ntile_test2 values (19, 30, 10, 40, 20);
insert into ntile_test2 values (20, 30, 20, 10, 40);
insert into ntile_test2 values (21, 30, 20, 40, 10);
insert into ntile_test2 values (22, 30, 40, 10, 20);
insert into ntile_test2 values (23, 30, 40, 20, 10);

insert into ntile_test2 values (24, 40, 10, 20, 30);
insert into ntile_test2 values (25, 40, 10, 30, 20);
insert into ntile_test2 values (26, 40, 20, 10, 30);
insert into ntile_test2 values (27, 40, 20, 30, 10);
insert into ntile_test2 values (28, 40, 30, 10, 20);
insert into ntile_test2 values (29, 40, 30, 20, 10);


select ntile(2) over (partition by c1 order by c1, id), *  from ntile_test2;
select ntile(3) over (partition by c3 order by c3, id), *  from ntile_test2;

select ntile(2) over (partition by c1 order by c1, id desc), *  from ntile_test2;
select ntile(2) over (partition by c1 order by c2, id desc), *  from ntile_test2;

select ntile(2) over (partition by c1 order by c1, c2, c3, c4), *  from ntile_test2;
--error 5301
select ntile(c1) over (order by id), * from ntile_test2;
--error 5301
select ntile(c1 + 1) over (order by id), * from ntile_test2;
--error 5301
select ntile(c1 + id) over (order by id), * from ntile_test2;
--error 5301
select ntile((select 1 from ntile_test2)) over (order by id) from ntile_test2;
--error 1210
select ntile((select length('abc') )) over (order by id) from ntile_test2;

# 
--disable_warnings
drop table if exists t1;
drop table if exists t1_temp_ntile;
--enable_warnings
create table t1(a int, b int, c int, d int, e int, primary key(a, b, c, d));

insert into t1 values(1, 2, 3, 4, 5);
insert into t1 values(1, 2, 3, 6, 6);
insert into t1 values(2, 2, 3, 6, 6);
insert into t1 values(2, 4, 3, 6, 6);
insert into t1 values(3, 3, 3, 3, null);
insert into t1 values(3, 4, 4, 4, null);


select t1.a, ntile(10) over(partition by t1.a order by t1.b) ntl from t1;
create table t1_temp_ntile as select t1.a, ntile(10) over(partition by t1.a order by t1.b) ntl from t1;
desc t1_temp_ntile;
drop table t1_temp_ntile;

set @@recyclebin = off;
drop table ntile_test;
drop table ntile_test2;















