# owner: zongmei.zzm
# owner group: sql1
# description:
# tags: optimizer
#
--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1(c1 int, c2 int) partition by hash(c1) partitions 4;

--disable_query_log
--disable_result_log
insert into t1 values (1, 1);
insert into t1 values (2, 2);
insert into t1 values (3, 3);
insert into t1 values (4, 4);
select count(*) from t1;
--enable_query_log
--enable_result_log

--result_format 4
--explain_protocol 2

select max((select length('abc') )) from t1;
select /*+no_rewrite*/max((select length('abc') )) from t1;

select max((select length('abc') )) over() from t1;
select /*+no_rewrite*/max((select length('abc') )) over() from t1;

select max((select length('abc') )) over(order by c1) from t1;
select /*+no_rewrite*/max((select length('abc') )) over(order by c1) from t1;
--error 1210
select ntile((select length('abc') )) over(order by c1) from t1;
--error 1210
select /*+no_rewrite*/ntile((select length('abc') )) over(order by c1) from t1;

drop table t1;
