# owner group: sql1
# description:
#
# test of first_value/last_value

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
set @@recyclebin = off;
drop table if exists test;
--enable_warnings

create table test (c1 int primary key, c2 int, c3 int);
insert into test values (1,1,3);
insert into test values (2,2,2);
insert into test values (3,2,1);
insert into test values (4,3,2);
insert into test values (5,3,6);
insert into test values (6,3,6);
insert into test values (7,4,2);
insert into test values (8,4,1);
insert into test values (9,4,1);
insert into test values (10,4,3);
insert into test values (11,5,5);
insert into test values (12,5,10);
insert into test values (13,5,1);
insert into test values (14,5,2);
insert into test values (15,5,2);
insert into test values (16,5,NULL);

select * from test;

select *, first_value(c3) over(order by c3 rows between unbounded preceding and unbounded following) from test;
select *, first_value(c3) ignore nulls over(order by c3 rows between unbounded preceding and unbounded following) from test;
select *, first_value(c3) respect nulls over(order by c3 rows between unbounded preceding and unbounded following) from test;
select *, first_value(c3 ignore nulls) over(order by c3 rows between unbounded preceding and unbounded following) from test;
select *, first_value(c3) over(order by c3 rows between unbounded preceding and unbounded following) from test;

select *, last_value(c3) over(order by c3 rows between unbounded preceding and unbounded following) from test;
select *, last_value(c3) ignore nulls over(order by c3 rows between unbounded preceding and unbounded following) from test;
select *, last_value(c3) respect nulls over(order by c3 rows between unbounded preceding and unbounded following) from test;
select *, last_value(c3 ignore nulls) over(order by c3 rows between unbounded preceding and unbounded following) from test;
select *, last_value(c3) over(order by c3 rows between unbounded preceding and unbounded following) from test;













