--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
drop table if exists v0;
--enable_warnings

--result_format 4

CREATE TABLE v0 ( v1 FLOAT , v2 INTEGER , v3 INTEGER ) ;
INSERT INTO v0 VALUES ( 4 , 2147483647 , -128 ) ;
INSERT INTO v0 VALUES ( 98 , 25 , 16 ) ;
--error 1064
SELECT v1 , SUM ( v1 ) OVER win1 FROM v0 WINDOW win1 AS ( ORDER BY v3 ROWS 'x' % v3 - 0 PRECEDING ) ORDER BY TRUE DESC , v2 , v3 ASC ;
--error 1064
SELECT v1 , SUM ( v1 ) OVER win1 FROM v0 WINDOW v4 AS ( ORDER BY v3 ROWS 'x' % v3 - 0 PRECEDING ) ORDER BY TRUE DESC , v2 , v3 ASC ;