#owner: zongmei.zzm
#owner group: sql1
#description:

--disable_warnings
drop database if exists wf;
create database wf;
use wf;
--disable_warnings

create table t1(a int primary key, b int, c varchar(20), d int);

insert into t1 values(1, 1, "121", 4);
insert into t1 values(2, -1, "3f1", 400);
insert into t1 values(3, 4, "hh1", 19);
insert into t1 values(4, 6, "c1", 4);
insert into t1 values(5, 2, "c1", 23);
insert into t1 values(6, -3, "a1", 4);
insert into t1 values(7, 3, "21", 41);
insert into t1 values(8, 8, "b1", 32);
insert into t1 values(9, 3, "ha", 1);
insert into t1 values(10, 3, "he", 3);

# current row for rows
select *, count(1) over(order by b rows between current row and current row) from t1 where a in (7,9,10);
# current row for range
select *, count(1) over(order by b range between current row and current row) from t1 where a in (7,9,10);
# interval for rows
select *, count(1) over(order by b rows 1 preceding) from t1 where a in (3,5,7,9,10) ;
# interval for range
select *, count(1) over(order by b range 1 preceding) from t1 where a in (3,5,7,9,10);

# float interval rows, ceiling it!
--error 3586
select *, count(1) over(order by b rows 1.99 preceding) from t1 where a in (3,5,7,9,10);

# following not allowd when upper specified only
--error ER_SYNTAX_ERROR
select *, count(1) over(order by b range 1 following) from t1;

# preceding and following cannot be specified after current row
--error ER_PARSE_ERROR
select *, count(1) over(order by b range between current row preceding and current row) from t1 ;
--error ER_PARSE_ERROR
select *, count(1) over(order by b range between current row and current row following) from t1 ;
--error 1064
select *, count(1) over(order by b rows a + 1 preceding) from t1;
--error ER_PARSE_ERROR 
select *, count(1) over(order by b rows b, a + 1 preceding) from t1;

# FIXME
--error 1064
select *, count(1) over(order by b rows count(1) preceding) from t1;

--disable_warnings
drop database if exists wf;
--disable_warnings

