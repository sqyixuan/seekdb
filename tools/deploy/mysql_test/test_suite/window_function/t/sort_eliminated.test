# owner: zongmei.zzm
# owner group: sql1
# tags: optimizer
# description:
#

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
set @@recyclebin = off;
drop database if exists nijia;
create database nijia;
use nijia;
create table t1(c1 int, c2 int, c3 int, primary key(c1, c2));
--enable_warnings

insert into t1 values (1,1,1);
insert into t1 values (1,2,2);
insert into t1 values (2,1,1);
insert into t1 values (1,3,2);
insert into t1 values (3,1,5);

explain select sum(c1) over (order by c1,c2) from t1;
explain select sum(c1) over (partition by c1 order by c2) from t1;
explain select sum(c1) over (order by c2) from t1 where c1 = 1;
explain select sum(c1) over (partition by c1) from t1 where c2 = 1;
explain select sum(c1) over (partition by c3) from (select * from t1 order by c3);
explain select sum(c1) over (order by c1,c2,c3) from (select * from t1 order by c1,c2,c3);

# reverse scan + partition by
create table table_history(tenant_id int, table_id int, schema_version int, table_name varchar(50), primary key(tenant_id, table_id, schema_version)) partition by hash(tenant_id) partitions 8;
explain select *, row_number() over w as rn from
    (select * from table_history where tenant_id = 1 and table_id < 1099511627777 order by table_id desc, schema_version desc limit 100)
    window w as (partition by table_id order by schema_version desc);












