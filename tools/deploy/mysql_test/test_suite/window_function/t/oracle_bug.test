--result_format 3
--disable_warnings
drop database if exists wf;
create database wf;
use wf;
--disable_warnings

create table test (c1 int primary key, c2 int, c3 int, c4 varchar(50), c5 float);
insert into test values(1,1,2, 'afd', 1.1);
insert into test values(2,1,2, '1d', 3.6);
insert into test values(3,3,2, 'fds', 10);
insert into test values(4,4,2, 'lllllllllllllllll', 0.9);
insert into test values(5,2,2, '78', 1.3);
insert into test values(6,9,3, 'nn', -1.1);
insert into test values(7,7,3, '78', 1.1);
insert into test values(8,8,3, 'nn', 0.8);
insert into test values(9,7,3, '57', 31.2);
insert into test values(10,1,4, 'nn', -19);
insert into test values(11,4,4, '8', 1.1);
insert into test values(12,1,4, '8', 3.6);
insert into test values(13,3,4, 'erw', 10);
insert into test values(14,5,2, 'llfsdfdsfdf', 0.9);
insert into test values(15,0,2, '478', 1.3);
insert into test values(16,9,2, 'vd', -1.1);
insert into test values(17,12,2, '11', 1.1);
insert into test values(18,10,2, 'nn', 0.8);
insert into test values(19,17,2, '57', 31.2);
insert into test values(20,18,2, '33', -19);
--error 1064
select c4,c1,c2, sum(c1) over (partition by c4 order by c1 range between 1 preceding and c2 preceding) r0 from test where c4 in ('78','8') order by c4,c1;
select c4,c1,c2, sum(c1) over (partition by c4 order by c1 range between 1 preceding and 1 preceding) r0 from test where c4 in ('78','8') order by c4,c1;

