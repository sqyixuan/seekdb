--disable_warnings
drop database if exists wf;
create database wf;
use wf;
--disable_warnings

create table t1(a int primary key, b int);

--error 5338 
insert into t1 values(1, count(1) over ());
--error 5338 
update t1 set a = count(1) over ();
--error 5338 
update t1 set a = 1 where count(1) over ();
--error 5338 
delete from t1 where count(1) over ();
--error 5561
delete from t1 order by count(1) over ();

--disable_warnings
drop database if exists wf;
--disable_warnings

