#

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
set @@recyclebin = off;
drop table if exists test;
--enable_warnings

create table test (c1 int primary key, c2 int, c3 int);

## invalid win which can be decided during resolving
--error 5561
select sum(1) over (order by c1 rows between current row and 2 preceding) from test;
--error 5561
select sum(1) over (order by c1 range between 1 following and current row) from test;
--error 5561
select sum(1) over (order by c1 range between 1 following and 1 preceding) from test;

--error 3028
SELECT 2 AS x UNION SELECT 1.1 ORDER BY MIN(x) OVER (ORDER BY x, LEAD(x, 3, -1) OVER (ORDER BY x));

--error 3028
SELECT 2 AS x UNION SELECT 1.1 ORDER BY rank() OVER (ORDER BY x, LEAD(x, 3, -1) OVER (ORDER BY x));
set @@recyclebin = off;
drop table test;















