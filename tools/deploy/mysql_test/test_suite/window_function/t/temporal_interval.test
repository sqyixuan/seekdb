#owner: zongmei.zzm
#owner group: sql1
#description:

--disable_warnings
drop database if exists temporal;
create database temporal;
use temporal;
--disable_warnings
--result_format 3

# basic
create table t1(a int auto_increment primary key, b date);
insert into t1(b) values('2018-05-27' - interval 2 day);
insert into t1(b) values('2018-05-27');
insert into t1(b) values('2018-05-27');
insert into t1(b) values('2018-05-27' + interval 2 day);
select *, listagg(a) over (order by b range between interval 0 day preceding and interval 0 day following) from t1;
select *, listagg(a) over (order by b range between interval 1 day preceding and interval 2 day following) from t1;
select *, listagg(a) over (order by b range between interval 1 day preceding and interval 2 * 23 hour following) from t1;
select *, listagg(a) over (order by b range between interval 1 day preceding and interval 2 * 24 hour following) from t1;
select *, listagg(a) over (order by b range between interval 1 day preceding and interval 2 * 25 hour following) from t1;
drop table t1;

# multi dimension
create table t1(a int auto_increment primary key, b datetime);
let $val='2018-05-27 10:10:10';
let $interval_1=interval '2:2' MINUTE_SECOND;
let $interval_2=interval '2:1' MINUTE_SECOND;
eval insert into t1(b) values($val - $interval_1);
eval insert into t1(b) values($val - $interval_1);
eval insert into t1(b) values($val - $interval_2);
eval insert into t1(b) values($val - $interval_2);
eval insert into t1(b) values($val);
eval insert into t1(b) values($val);
eval insert into t1(b) values($val + $interval_2);
eval insert into t1(b) values($val + $interval_2);
eval insert into t1(b) values($val + $interval_1);
eval insert into t1(b) values($val + $interval_1);
eval select *,
            listagg(a) over w1,
            listagg(a) over w2,
            listagg(a) over w3,
            listagg(a) over w4
     from t1
     window w as (order by b),
            w1 as (w range between $interval_1 preceding and $interval_1 following),
            w2 as (w range between $interval_2 preceding and $interval_2 following),
            w3 as (w range between $interval_1 preceding and $interval_2 following),
            w4 as (w range between $interval_2 preceding and $interval_1 following)
     ;



--disable_warnings
drop database if exists temporal;
--disable_warnings

