--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
set @@recyclebin = off;
drop table if exists test;
drop table if exists t1;
--enable_warnings

create table test (c1 int primary key, c2 int, c3 int);
insert into test values (1,1,3);
insert into test values (2,2,2);
insert into test values (3,2,1);
insert into test values (4,3,2);
insert into test values (5,3,6);
insert into test values (6,3,6);
insert into test values (7,4,2);
insert into test values (8,4,1);
insert into test values (9,4,1);
insert into test values (10,4,3);
insert into test values (11,5,5);
insert into test values (12,5,10);
insert into test values (13,5,1);
insert into test values (14,5,2);
insert into test values (15,5,2);
insert into test values (16,5,NULL);

create table t1 (a int, b int, c int, d int, e int, f int, g int);
insert into t1 values(1, 2, 3, 4, 5, 6, 7);
insert into t1 values(10, 20, 30, 40, 50, 60, 70);
insert into t1 values(1, 2, 3, 4, 5, 60, 70);
insert into t1 values(10, 20, 30, 40, 50, 600, 700);
insert into t1 values(1, 2, 3, 4, 5, 6, 70);
insert into t1 values(10, 20, 30, 40, 500, 600, 700);
insert into t1 values(10, 20, 30, 400, 500, 600, 700);

--disable_query_log
--disable_result_log
select * from test;
select * from t1;
--enable_query_log
--enable_result_log

select *, min(c1) over(partition by c2) from test;
select *, max(c1) over(partition by c2) from test;
select *, sum(c1) over(partition by c2) from test;
select *, count(c1) over(partition by c2) from test;
select *, avg(c1) over(partition by c2) from test;
select *, group_concat(c1) over(partition by c2) from test;
select *, APPROX_COUNT_DISTINCT(c1) over(partition by c2) from test;
select *, APPROX_COUNT_DISTINCT_SYNOPSIS(c1) over(partition by c2) from test;
#select *, APPROX_COUNT_DISTINCT_SYNOPSIS_MERGE(c1) over(partition by c2) from test;

