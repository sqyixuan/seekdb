select pk, GROUP_CONCAT(ASCII(SPACE(col_smallint_unsigned)) < col_numeric_key order by col_int_unsigned_unique ASC, col_decimal_unique ASC, col_numeric_unique DESC, col_decimal_unique ASC, pk DESC SEPARATOR ' ') 
over (partition by col_double_65_20_key, col_bit_key order by col_smallint_unsigned DESC, col_float_unsigned_unique, pk DESC RANGE BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) 
from t1 order by pk;

drop table t1;

#bug 57896306
create table t1 (i INT NOT NULL primary key); 
explain SELECT AVG(i) FROM t1  ORDER BY RANK() OVER (PARTITION BY AVG(i) ORDER BY i);
SELECT AVG(i) FROM t1  ORDER BY RANK() OVER (PARTITION BY AVG(i) ORDER BY i);
