drop table test;
drop table t1;

CREATE TABLE `t1` (
  `col_bit_key` bit(1) DEFAULT NULL,
  `pk` int(11) NOT NULL,
  `col_numeric_key` decimal(10,0) DEFAULT NULL,
  `col_double_65_20_key` double(65,20) DEFAULT NULL,
  `col_numeric_unique` decimal(10,0) DEFAULT NULL,
  `col_int_unsigned_unique` int(10) unsigned DEFAULT NULL,
  `col_float_unsigned_unique` float unsigned DEFAULT NULL,
  `col_smallint_unsigned` smallint(5) unsigned DEFAULT NULL,
  `col_decimal_unique` decimal(10,0) DEFAULT NULL,
  PRIMARY KEY (`pk`)
) DEFAULT CHARSET = utf8mb4 COLLATE = utf8mb4_bin ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0;

