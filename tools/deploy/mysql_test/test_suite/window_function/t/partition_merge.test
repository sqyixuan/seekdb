# owner: zongmei.zzm
# owner group: sql1
# tags: optimizer
# description:
#

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
set @@recyclebin = off;
drop table if exists test,t1,empsalary;
--enable_warnings

create table test (c1 int primary key, c2 int, c3 int, c4 int, c5 int);

explain select *, sum(c1) over(partition by c2 order by c3), max(c1) over(partition by c2) from test;

explain select *, sum(c1) over(partition by c2,c2 order by c3), max(c1) over(partition by c2,c3), sum(c1) over(partition by c2,c3 order by c3,c4), sum(c1) over(partition by c3,c2 order by c2,c3,c4) from test;

explain select *, sum(c1) over(partition by c2 order by c3), max(c1) over() from test;

explain select *, sum(c1) over(partition by c2,c3), max(c1) over(partition by c3,c2) from test;

create table t1(c1 int, c2 int,c3 int);
insert into t1 values(1,1,1),(1,1,2),(1,2,3),(1,2,4);
select sum(1) over (partition by c1,c2,c3), sum(1) over(partition by c1,c2),  sum(1) over(partition by c1) from t1;

CREATE TABLE empsalary (depname varchar(50), empno bigint, salary int, enroll_date date);
explain sELECT sum(salary), row_number() OVER (ORDER BY depname), sum(sum(salary)) OVER (ORDER BY depname DESC) FROM empsalary GROUP BY depname;
explain sELECT sum(salary), row_number() OVER (ORDER BY depname), sum(sum(salary)) OVER (ORDER BY depname) FROM empsalary GROUP BY depname;
