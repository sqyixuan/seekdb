# test of nth_value

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
set @@recyclebin = off;
drop table if exists test;
--enable_warnings

create table test (c1 int primary key, c2 int, c3 int);
insert into test values (1,1,3);
insert into test values (2,2,2);
insert into test values (3,2,1);
insert into test values (4,3,2);
insert into test values (5,3,6);
insert into test values (6,3,6);
insert into test values (7,4,2);
insert into test values (8,4,1);
insert into test values (9,4,1);
insert into test values (10,4,3);
insert into test values (11,5,5);
insert into test values (12,5,10);
insert into test values (13,5,1);
insert into test values (14,5,2);
insert into test values (15,5,2);
insert into test values (16,5,NULL);

select * from test;

select *, nth_value(c3, 1) over(order by c3 rows between unbounded preceding and unbounded following) from test;
select *, nth_value(c3, 1) from last ignore nulls over(order by c3 rows between unbounded preceding and unbounded following) from test;
select *, nth_value(c3, 1) from last respect nulls over(order by c3 rows between unbounded preceding and unbounded following) from test;
select *, nth_value(c3, 1) from first ignore nulls over(order by c3 rows between unbounded preceding and unbounded following) from test;
select *, nth_value(c3, 1) from first respect nulls over(order by c3 rows between unbounded preceding and unbounded following) from test;
select *, nth_value(c3, 1) ignore nulls over(order by c3 rows between unbounded preceding and unbounded following) from test;
select *, nth_value(c3, 1) over(order by c3 rows between unbounded preceding and unbounded following) from test;

##bug:

--disable_warnings
drop table if exists t1;
--enable_warnings

CREATE TABLE t1 (d DOUBLE, id INT, sex CHAR(1));
INSERT INTO t1 VALUES (1.0, 1, 'M'),
                      (2.0, 2, 'F'),
                      (3.0, 3, 'F'),
                      (4.0, 4, 'F'),
                      (5.0, 5, 'M'),
                      (NULL, NULL, 'M'),
                      (10.0, 10, NULL),
                      (10.0, 10, NULL),
                      (11.0, 11, NULL);


SELECT id, sex, NTH_VALUE(id, @oijlkjlkjxozijqlj) OVER () FROM t1;

PREPARE p FROM "SELECT id, sex, NTH_VALUE(id, ?) OVER () FROM t1";
SET @p1= NULL;
EXECUTE p USING @p1;

--error 1210
SELECT id, sex, NTH_VALUE(id, '1') OVER () FROM t1;
--error 1210
SELECT id, sex, NTH_VALUE(id, 1.2) OVER () FROM t1;
--error 1210
SELECT id, sex, NTH_VALUE(id, 0) OVER () FROM t1;
--error 1210
SELECT id, sex, NTH_VALUE(id, -1) OVER () FROM t1;