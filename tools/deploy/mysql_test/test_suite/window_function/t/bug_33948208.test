# owner group: sql1

--echo bug:
--disable_warnings
DROP TABLE IF EXISTS wf_table3 ;
DROP TABLE IF EXISTS cume_test;
DROP TABLE IF EXISTS percent_rank_test;
DROP TABLE IF EXISTS lag_test;
DROP TABLE IF EXISTS lead_test;
--enable_warnings

create table wf_table3(a date);
insert into wf_table3 values(date'2020-10-30');
insert into wf_table3 values(date'2020-10-10');
insert into wf_table3 values(date'2020-10-20');
insert into wf_table3 values(date'2020-10-20');
insert into wf_table3 values(date'2020-10-20');
insert into wf_table3 values(date'2020-01-10');
#cume_dist/percent rank test
select a,cume_dist() over w as wf1 from wf_table3 window w as (partition by a order by a desc rows unbounded preceding) order by a;
select a,cume_dist() over w as wf1 from wf_table3 window w as (order by a desc rows unbounded preceding) order by a;
select a,percent_rank() over w as wf1 from wf_table3 window w as (partition by a order by a desc rows unbounded preceding) order by a;
select a,percent_rank() over w as wf1 from wf_table3 window w as (order by a desc rows unbounded preceding) order by a;

#return type test
create table cume_test as select a,cume_dist() over w as wf1 from wf_table3 window w as (partition by a order by a desc rows unbounded preceding) order by a;
desc cume_test;
create table percent_rank_test as select a,percent_rank() over w as wf1 from wf_table3 window w as (order by a desc rows unbounded preceding) order by a;
desc percent_rank_test;
#lead/lag test
select a,lag(a,1,0) over w as wf1 from wf_table3 window w as (partition by a order by a desc rows unbounded preceding) order by a;
select a,lag(a,1,'20201111') over w as wf1 from wf_table3 window w as (order by a desc rows unbounded preceding) order by a;
select a,lag(a,1,date'20201111') over w as wf1 from wf_table3 window w as (order by a desc rows unbounded preceding) order by a;
select a,lead(a,1,0) over w as wf1 from wf_table3 window w as (partition by a order by a desc rows unbounded preceding) order by a;
select a,lead(a,1,'20201111') over w as wf1 from wf_table3 window w as (order by a desc rows unbounded preceding) order by a;

#return type test
create table lag_test as select a,lag(a,1,0) over w as wf1 from wf_table3 window w as (partition by a order by a desc rows unbounded preceding) order by a;
desc lag_test;
create table lead_test select a,lead(a,1,0) over w as wf1 from wf_table3 window w as (partition by a order by a desc rows unbounded preceding) order by a;
desc lead_test;

--echo bug:
--disable_warnings
DROP TABLE IF EXISTS wf_table1;
DROP TABLE IF EXISTS dense_test;
DROP TABLE IF EXISTS rank_test;
DROP TABLE IF EXISTS row_number_test;
--enable_warnings

CREATE TABLE wf_table1(num INT,name varchar(200),money char(20),perimeter NUMERIC(20,10) AS (2 * 3.14159265 * num));
INSERT INTO wf_table1(num,name,money) VALUES(1,'Bing',-100);
INSERT INTO wf_table1(num,name,money) VALUES(2,'Bing',+104564564646.11514);
INSERT INTO wf_table1(num,name,money) VALUES(3,'Reachl',-0.23566000);
INSERT INTO wf_table1(num,name,money) VALUES(4,'Reachl',0.23566000);
INSERT INTO wf_table1(num,name,money) VALUES(5,'friends','');
INSERT INTO wf_table1(num,name,money) VALUES(6,'@#￥！%……&*~',NULL);
INSERT INTO wf_table1(num,name,money) VALUES(2,'Bing',10);
INSERT INTO wf_table1(num,name,money) VALUES(NULL,'NULL',NULL);

SELECT name, DENSE_RANK() OVER(PARTITION BY name) AS wf1 FROM wf_table1 ORDER BY name;
SELECT name, RANK() OVER(PARTITION BY name) AS wf1 FROM wf_table1 ORDER BY name;
SELECT name, ROW_NUMBER() OVER(PARTITION BY name) AS wf1 FROM wf_table1 ORDER BY name;

#return type test
create table dense_test as SELECT name, DENSE_RANK() OVER(PARTITION BY name) AS wf1 FROM wf_table1 ORDER BY name;
desc dense_test;
create table rank_test as SELECT name, RANK() OVER(PARTITION BY name) AS wf1 FROM wf_table1 ORDER BY name;
desc rank_test;
create table row_number_test as SELECT name, ROW_NUMBER() OVER(PARTITION BY name) AS wf1 FROM wf_table1 ORDER BY name;
desc row_number_test;

--echo bug:
--disable_warnings
drop table if exists t1,t2;
drop view if exists v1,v2;
--enable_warnings

create table t1(c1 int);
create table t2(c1 double);
insert into t1 values(1);
insert into t2 values(1.2);

SELECT
          /*+  NO_USE_HASH_AGGREGATION tracing(1,4)*/
          cume_dist() OVER ()
 FROM     t1
EXCEPT SELECT  c1  FROM     t2;

create view v1 as 
SELECT
          /*+  NO_USE_HASH_AGGREGATION tracing(1,4)*/
          cume_dist() OVER ()
 FROM     t1
EXCEPT SELECT  c1  FROM     t2;
desc v1;

SELECT
          /*+  NO_USE_HASH_AGGREGATION tracing(1,4)*/
          percent_rank() OVER ()
 FROM     t1
EXCEPT SELECT  c1  FROM     t2;

create view v2 as
SELECT
          /*+  NO_USE_HASH_AGGREGATION tracing(1,4)*/
          percent_rank() OVER ()
 FROM     t1
EXCEPT SELECT  c1  FROM     t2;
desc v2;

drop view if exists v1,v2;

drop table t1,t2;