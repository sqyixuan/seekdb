# owner: zongmei.zzm
# owner group: sql1
# description:
#

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
set @@recyclebin = off;
drop table if exists test;
--enable_warnings

create table test (c1 int primary key, c2 int, c3 int);
insert into test values (1,1,3);
insert into test values (2,2,2);
insert into test values (3,2,1);
insert into test values (4,3,2);
insert into test values (5,3,6);
insert into test values (6,3,6);
insert into test values (7,4,2);
insert into test values (8,4,1);
insert into test values (9,4,1);

select *, 1 + 2 * sum(sum(c3)) over(partition by c2 order by c3 rows between unbounded preceding and unbounded following) from test;
--error ER_INVALID_GROUP_FUNC_USE 
select *, sum(sum(sum(c3))) over() from test;
--error ER_INVALID_GROUP_FUNC_USE 
select *, sum(sum(c3)) from test;

select *, avg(sum(c3)) over() from test;
--error ER_INVALID_GROUP_FUNC_USE 
select *, avg(sum(sum(c3))) over() from test;
select *, group_concat(sum(c3)) over() from test;
--error ER_INVALID_GROUP_FUNC_USE 
select *, group_concat(sum(sum(c3))) over() from test;

--source kv.inc
let $cnt = `select count(1) from kv where k = 'agg_func'`;
let $i = 0;
while ($cnt)
{
  let $sql = select v from kv where k = 'agg_func' limit 1 offset $i;
  let $func = query_get_value($sql, v, 1);

  --error ER_INVALID_GROUP_FUNC_USE
  eval select $func(sum(sum(c3))) over() from test;

  eval select $func(sum(c3)) over() from test;

  --error ER_INVALID_GROUP_FUNC_USE
  eval select $func(sum(c3)) from test;

  dec $cnt;
  inc $i;
}



