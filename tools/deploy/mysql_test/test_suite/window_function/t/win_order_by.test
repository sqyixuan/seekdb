--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

# owner: link.zt
# owner group: sql1
# tags: optimizer
# description:

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1 (c1 int primary key, c2 int, c3 int, c4 int,
    index idx_c2_c4    (c2, c4),
    index idx_c2_c3_c4 (c2, c3, c4));

--disable_query_log
insert into t1 values (1, 1, 1, 6);
insert into t1 values (2, 2, 2, 5);
insert into t1 values (3, 1, 3, 4);
insert into t1 values (4, 2, 1, 3);
insert into t1 values (5, 1, 2, 2);
insert into t1 values (6, 2, 3, 1);
--enable_query_log

--source mysql_test/include/minor_merge_tenant.inc
call dbms_stats.gather_table_stats('TEST', 'T1', method_opt=>'for all columns size 10');

--explain_protocol 2
--result_format 4

## windown function 索引访问方向的选择
select c1, avg(c1) over () v2 from t1 order by c2 desc;
select c1, avg(c1) over () v2 from t1 where c2 = 2 order by c3 desc;
select c1, avg(c1) over (order by c2) v2 from t1 order by c3 desc;
select c1, avg(c1) over (order by c2 desc) v2 from t1 order by c3 desc;
select c1, avg(c1) over (order by c2, c3 desc) v2 from t1 where c2 = 2 order by c3 desc;
select c1, avg(c1) over (partition by c2, c3) v2 from t1 order by c2 desc;
select c1, avg(c1) over (partition by c2, c3 order by c4 desc) v2 from t1;
select c1, avg(c1) over (partition by c2 order by c3 desc) v2 from t1 order by c3 desc;
select c1, avg(c1) over (partition by c2 order by c3 desc) v2 from t1 where c2 = 2 order by c3 desc;
select c1, avg(c1) over (order by c2 desc) v2, sum(c1) over (order by c3 desc) v3 from t1 order by c3 desc;
select c1, avg(c1) over (order by c2 desc) v2, sum(c1) over (order by c3 desc) v3 from t1 where c2 = 2 order by c3 desc;
select c1, avg(c1) over (partition by c2) v2, sum(c1) over (order by c2 desc) v3 from t1 order by c2 desc, c3 desc;

drop table t1;
