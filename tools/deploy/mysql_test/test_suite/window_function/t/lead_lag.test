--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: zongmei.zzm
#owner group: sql1
# description:
#
# test of LEAD/LAG 

--disable_warnings
set @@recyclebin = off;
drop table if exists lead_lag_test;
drop table if exists lead_lag_test_with_nulls;

create table lead_lag_test (c1 int, c2 int);
insert into lead_lag_test values (1,1);
insert into lead_lag_test values (2,2);
insert into lead_lag_test values (3,2);
insert into lead_lag_test values (4,3);
insert into lead_lag_test values (5,3);
insert into lead_lag_test values (6,3);
insert into lead_lag_test values (7,4);
insert into lead_lag_test values (8,4);
insert into lead_lag_test values (9,4);
insert into lead_lag_test values (10,4);
insert into lead_lag_test values (11,5);
insert into lead_lag_test values (12,5);
insert into lead_lag_test values (13,5);
insert into lead_lag_test values (14,5);
insert into lead_lag_test values (15,5);

# lead_lag_test_with_nulls is almost the same as lead_lag_test, except that it contains some NULL values.
create table lead_lag_test_with_nulls (c1 int, c2 int);
insert into lead_lag_test_with_nulls values (1,1);
insert into lead_lag_test_with_nulls values (2,2);
insert into lead_lag_test_with_nulls values (3,2);
insert into lead_lag_test_with_nulls values (4,3);
insert into lead_lag_test_with_nulls values (NULL,3);
insert into lead_lag_test_with_nulls values (6,3);
insert into lead_lag_test_with_nulls values (7,NULL);
insert into lead_lag_test_with_nulls values (8,4);
insert into lead_lag_test_with_nulls values (9,4);
insert into lead_lag_test_with_nulls values (NULL,4);
insert into lead_lag_test_with_nulls values (11,5);
insert into lead_lag_test_with_nulls values (12,5);
insert into lead_lag_test_with_nulls values (13,5);
insert into lead_lag_test_with_nulls values (NULL,5);
insert into lead_lag_test_with_nulls values (15,5);

--enable_warnings

# base cases
select c1,
       lead(c1) over (order by c1),
       lead(c1, 1) over (order by c1),
       lead(c1, 2) over (order by c1),
       lead(c1, 3, 1234567) over (order by c1),
       lead(c1, 4, -7654321) over (order by c1),
       lead(c1, 5, 233333) over (order by c1),
       lead(c1, 6, 66666) over (order by c1)
from lead_lag_test;

select c1,
       lag(c1) over (order by c1),
       lag(c1, 1) over (order by c1),
       lag(c1, 2) over (order by c1),
       lag(c1, 3, 1234567) over (order by c1),
       lag(c1, 4, -7654321) over (order by c1),
       lag(c1, 5, 233333) over (order by c1),
       lag(c1, 6, 66666) over (order by c1)
from lead_lag_test;

select c2,
       lead(c2) over (order by c1, c2),
       lead(c2, 1) over (order by c1, c2),
       lead(c2, 2) over (order by c1, c2),
       lead(c2, 3, 1234567) over (order by c1, c2),
       lead(c2, 4, -7654321) over (order by c1, c2),
       lead(c2, 5, 233333) over (order by c1, c2),
       lead(c2, 6, 66666) over (order by c1, c2)
from lead_lag_test;

select c2,
       lag(c2) over (order by c1, c2),
       lag(c2, 1) over (order by c1, c2),
       lag(c2, 2) over (order by c1, c2),
       lag(c2, 3, 1234567) over (order by c1, c2),
       lag(c2, 4, -7654321) over (order by c1, c2),
       lag(c2, 5, 233333) over (order by c1, c2),
       lag(c2, 6, 66666) over (order by c1, c2)
from lead_lag_test;

# test float numbers (x -> floor(x))
select c1,
       lead(c1) over (order by c1),
       lead(c1, 1.3) over (order by c1),
       lead(c1, 2.5) over (order by c1),
       lead(c1, 3.7, 1234567) over (order by c1),
       lead(c1, 4.8, -7654321) over (order by c1),
       lead(c1, 5.9, 233333) over (order by c1),
       lead(c1, 6.0, 66666) over (order by c1)
from lead_lag_test;

select c1,
       lag(c1) over (order by c1),
       lag(c1, 1.3) over (order by c1),
       lag(c1, 2.5) over (order by c1),
       lag(c1, 3.7, 1234567) over (order by c1),
       lag(c1, 4.8, -7654321) over (order by c1),
       lag(c1, 5.9, 233333) over (order by c1),
       lag(c1, 6.0, 66666) over (order by c1)
from lead_lag_test;

# test respect/ignore nulls.
select c1,
       lead(c1) over (order by c1),
       lead(c1 RESPECT NULLS) over (order by c1),
       lead(c1) RESPECT NULLS over (order by c1),
       lead(c1 IGNORE NULLS) over (order by c1),
       lead(c1) IGNORE NULLS over (order by c1),
       lead(c1, 3, 55555) over (order by c1),
       lead(c1 RESPECT NULLS, 3, 55555) over (order by c1),
       lead(c1, 3, 55555) RESPECT NULLS over (order by c1),
       lead(c1 IGNORE NULLS, 3, 55555) over (order by c1),
       lead(c1, 3, 55555) IGNORE NULLS over (order by c1)
from lead_lag_test_with_nulls;

select c1,
       lag(c1) over (order by c1),
       lag(c1 RESPECT NULLS) over (order by c1),
       lag(c1) RESPECT NULLS over (order by c1),
       lag(c1 IGNORE NULLS) over (order by c1),
       lag(c1) IGNORE NULLS over (order by c1),
       lag(c1, 3, 55555) over (order by c1),
       lag(c1 RESPECT NULLS, 3, 55555) over (order by c1),
       lag(c1, 3, 55555) RESPECT NULLS over (order by c1),
       lag(c1 IGNORE NULLS, 3, 55555) over (order by c1),
       lag(c1, 3, 55555) IGNORE NULLS over (order by c1)
from lead_lag_test_with_nulls;

# test with partiton by
select c1, lead(c1) over (partition by c2 order by c1) from lead_lag_test;
select c1, lead(c1, 2) over (partition by c2 order by c1) from lead_lag_test;
select c1, lead(c1, 2, 555) over (partition by c2 order by c1) from lead_lag_test;

select c1, lag(c1) over (partition by c2 order by c1) from lead_lag_test;
select c1, lag(c1, 2) over (partition by c2 order by c1) from lead_lag_test;
select c1, lag(c1, 2, 555) over (partition by c2 order by c1) from lead_lag_test;

# test with join
select lead(lead_lag_test.c1) over (partition by lead_lag_test.c2 order by lead_lag_test.c1) from lead_lag_test, lead_lag_test_with_nulls where lead_lag_test.c1 = lead_lag_test_with_nulls.c1;
select lag(lead_lag_test.c1) over (partition by lead_lag_test.c2 order by lead_lag_test.c1) from lead_lag_test, lead_lag_test_with_nulls where lead_lag_test.c1 = lead_lag_test_with_nulls.c1;

# test with group by
select c2, lead(c2) over (order by c2) from lead_lag_test group by c2;
select c2, lag(c2) over (order by c2) from lead_lag_test group by c2;

# test with order by
select c1, lead(c1) over (partition by c2 order by c1) from lead_lag_test order by c2;
select c1, lag(c1) over (partition by c2 order by c1) from lead_lag_test order by c2;

# test error cases
#   1. Invalid number of arguments(standard: (LEAD | LAG) (expr, [, offset[, default]]))
--error 1064
select lead() over (order by c2) from lead_lag_test;
--error 1064
select lag() over (order by c2) from lead_lag_test;
--error 1210
select lead(c1, 2, 3, 4) over (order by c2) from lead_lag_test;
--error 1210
select lag(c1, 2, 3, 4) over (order by c2) from lead_lag_test;

#   2. Invalid offset(should be positive number)

select lead(c1, 0) over (order by c1) from lead_lag_test;
--error 5674
select lead(c1, -1) over (order by c1) from lead_lag_test;
--error 5674
select lead(c1, -1, 3) over (order by c1) from lead_lag_test;
--error 5674
select lag(c1, -1) over (order by c1) from lead_lag_test;
--error 5674
select lag(c1, -1, 3) over (order by c1) from lead_lag_test;
#   3. with window_clause(not allowed in LEAD/LAG)

#--error ER_SYNTAX_ERROR
#select lead(c1) over (partition by c2 order by c1 rows between unbounded preceding and unbounded following), c1, c2 from lead_lag_test;
#--error ER_SYNTAX_ERROR
#select lead(c1) over (partition by c2 order by c1 rows between unbounded preceding and unbounded following), c1, c2 from lead_lag_test;
#--error ER_SYNTAX_ERROR
#select lead(c1) over (partition by c2 order by c1 rows between current row and unbounded following), c1, c2 from lead_lag_test;
#
#--error ER_SYNTAX_ERROR
#select lag(c1) over (partition by c2 order by c1 rows between unbounded preceding and unbounded following), c1, c2 from lead_lag_test;
#--error ER_SYNTAX_ERROR
#select lag(c1) over (partition by c2 order by c1 rows between unbounded preceding and unbounded following), c1, c2 from lead_lag_test;
#--error ER_SYNTAX_ERROR
#select lag(c1) over (partition by c2 order by c1 rows between current row and unbounded following), c1, c2 from lead_lag_test;

#   4. without order by(not allowed in LEAD/LAG)
#--error 5300
#select lead(c1) over (partition by c2) from lead_lag_test;
#--error 5300
#select lag(c1) over (partition by c2) from lead_lag_test;

set @@recyclebin = off;
drop table if exists lead_lag_test, lead_lag_test_with_nulls;

#Bugfix:
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(c1 set ('Alice','Bob','Charlie','David') default 'Alice', c2 int);
insert into t1 values('Alice',1);
insert into t1 values('Bob',2);

explain SELECT lead(c1, 1, NULL) OVER () FROM t1;
SELECT lead(c1, 1, NULL) OVER () FROM t1;
explain SELECT lead(c1, 1, c2) OVER () FROM t1;
SELECT lead(c1, 1, c2) OVER () FROM t1;
explain SELECT lead(c1, 1, c1) OVER () FROM t1;
SELECT lead(c1, 1, c1) OVER () FROM t1;

explain SELECT lag(c1, 1, NULL) OVER () FROM t1;
SELECT lag(c1, 1, NULL) OVER () FROM t1;
explain SELECT lag(c1, 1, c2) OVER () FROM t1;
SELECT lag(c1, 1, c2) OVER () FROM t1;
explain SELECT lag(c1, 1, c1) OVER () FROM t1;
SELECT lag(c1, 1, c1) OVER () FROM t1;
drop table t1;

#BUG: 
create table t1 (c1 float, c2 float unsigned, c3 float(10, 2), c4 float(10, 2) unsigned);
insert into t1 values (1, 2, 3, 4);
insert into t1 values (1, 2, 3, 4);
insert into t1 values (1, 2, 3, 4);
SELECT lag(c1, 1, NULL) OVER (), lead(c1, 1, NULL) OVER () FROM t1;
SELECT lag(c2, 1, NULL) OVER (), lead(c2, 1, NULL) OVER () FROM t1;
SELECT lag(c3, 1, NULL) OVER (), lead(c3, 1, NULL) OVER () FROM t1;
SELECT lag(c4, 1, NULL) OVER (), lead(c4, 1, NULL) OVER () FROM t1;
drop table t1;

create table t1 (c1 double, c2 double unsigned, c3 double(10, 2), c4 double(10, 2) unsigned);
insert into t1 values (1, 2, 3, 4);
insert into t1 values (1, 2, 3, 4);
insert into t1 values (1, 2, 3, 4);
SELECT lag(c1, 1, NULL) OVER (), lead(c1, 1, NULL) OVER () FROM t1;
SELECT lag(c2, 1, NULL) OVER (), lead(c2, 1, NULL) OVER () FROM t1;
SELECT lag(c3, 1, NULL) OVER (), lead(c3, 1, NULL) OVER () FROM t1;
SELECT lag(c4, 1, NULL) OVER (), lead(c4, 1, NULL) OVER () FROM t1;
drop table t1;
