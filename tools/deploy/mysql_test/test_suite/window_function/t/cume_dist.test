# test of cume_dist

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
set @@recyclebin = off;
drop table if exists cume_dist_test;
drop table if exists cume_dist_test2;

create table cume_dist_test (c1 int primary key, c2 int);
insert into cume_dist_test values (1,1);
insert into cume_dist_test values (2,2);
insert into cume_dist_test values (3,2);
insert into cume_dist_test values (4,3);
insert into cume_dist_test values (5,3);
insert into cume_dist_test values (6,3);
insert into cume_dist_test values (7,4);
insert into cume_dist_test values (8,4);
insert into cume_dist_test values (9,4);
insert into cume_dist_test values (10,4);
insert into cume_dist_test values (11,5);
insert into cume_dist_test values (12,5);
insert into cume_dist_test values (13,5);
insert into cume_dist_test values (14,5);
insert into cume_dist_test values (15,5);

create table cume_dist_test2 (id int primary key, c1 int, c2 float, c3 decimal(60,30), c4 varchar(5)) partition by key(id) partitions 3;
insert into cume_dist_test2 values (1, 1, 1, 1, 'a1');
insert into cume_dist_test2 values (2, 2, 2, 2, 'a2');
insert into cume_dist_test2 values (3, 3, 3, 3, 'a3');
insert into cume_dist_test2 values (4, 4, 4, 4, 'a4');

insert into cume_dist_test2 values (5, 10, 30, 40, 'a40');
insert into cume_dist_test2 values (6, 10, 40, 30, 'a30');
insert into cume_dist_test2 values (7, 10, 20, 40, 'a40');
insert into cume_dist_test2 values (8, 10, 40, 20, 'a20');
insert into cume_dist_test2 values (9, 10, 20, 30, 'a30');
insert into cume_dist_test2 values (10, 10, 30, 20, 'a20');

insert into cume_dist_test2 values (12, 20, 30, 40, 'a40');
insert into cume_dist_test2 values (13, 20, 40, 30, 'a30');
insert into cume_dist_test2 values (14, 20, 10, 40, 'a40');
insert into cume_dist_test2 values (15, 20, 40, 10, 'a10');
insert into cume_dist_test2 values (16, 20, 10, 30, 'a30');
insert into cume_dist_test2 values (17, 20, 30, 10, 'a10');

insert into cume_dist_test2 values (18, 30, 20, 40, 'a40');
insert into cume_dist_test2 values (19, 30, 40, 20, 'a20');
insert into cume_dist_test2 values (20, 30, 10, 40, 'a40');
insert into cume_dist_test2 values (21, 30, 40, 10, 'a10');
insert into cume_dist_test2 values (22, 30, 10, 20, 'a20');
insert into cume_dist_test2 values (23, 30, 20, 10, 'a10');

insert into cume_dist_test2 values (24, 40, 20, 30, 'a30');
insert into cume_dist_test2 values (25, 40, 30, 20, 'a20');
insert into cume_dist_test2 values (26, 40, 10, 30, 'a30');
insert into cume_dist_test2 values (27, 40, 30, 10, 'a10');
insert into cume_dist_test2 values (28, 40, 10, 20, 'a20');
insert into cume_dist_test2 values (29, 40, 20, 10, 'a10');

--enable_warnings


##not specifiy order by clause
#--error 5300
#select cume_dist() over (partition by c1), c1, c2 from cume_dist_test;

#--error ER_SYNTAX_ERROR
#select cume_dist() over (partition by c2 order by c1 rows between unbounded preceding and unbounded following), c1, c2 from cume_dist_test;
#--error ER_SYNTAX_ERROR
#select cume_dist() over (partition by c2 order by c1 rows between unbounded preceding and unbounded following), c1, c2 from cume_dist_test;
#--error ER_SYNTAX_ERROR
#select cume_dist() over (partition by c2 order by c1 rows between current row and unbounded following), c1, c2 from cume_dist_test;

select *, cume_dist() over (partition by c2 order by c1) from cume_dist_test order by c1;
select *, cume_dist() over (order by c1) from cume_dist_test order by c1;
select *, cume_dist() over (order by c2) from cume_dist_test order by c1;
select *, cume_dist() over (partition by c2 order by c1, c2) from cume_dist_test order by c1;

## test order by

select cume_dist() over (partition by c2 order by c1, id), *  from cume_dist_test2;

select cume_dist() over (partition by c1 order by c2), *  from cume_dist_test2 order by id;
select cume_dist() over (partition by c1 order by c3), *  from cume_dist_test2 order by id;
select cume_dist() over (partition by c1 order by c4), *  from cume_dist_test2 order by id;

select cume_dist() over (partition by c1 order by c4, c4), *  from cume_dist_test2 order by id;
select cume_dist() over (partition by NULL order by c4), *  from cume_dist_test2 order by id;
select cume_dist() over (partition by NULL order by NULL), *  from cume_dist_test2 order by id;

set @@recyclebin = off;
drop table cume_dist_test;
drop table cume_dist_test2;
