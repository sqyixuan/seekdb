# owner group: sql1
# description:
#
# test of percent_rank

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
set @@recyclebin = off;
drop table if exists test;
--enable_warnings

create table test (c1 int primary key, c2 int, c3 int);
insert into test values (1,1,3);
insert into test values (2,2,2);
insert into test values (3,2,1);
insert into test values (4,3,2);
insert into test values (5,3,6);
insert into test values (6,3,6);
insert into test values (7,4,2);
insert into test values (8,4,1);
insert into test values (9,4,1);
insert into test values (10,4,3);
insert into test values (11,5,5);
insert into test values (12,5,10);
insert into test values (13,5,1);
insert into test values (14,5,2);
insert into test values (15,5,2);

select * from test;

## one partition
select percent_rank() over (order by c1), c1, c2, c3 from test;
## two order by item
select percent_rank() over (order by c2, c3 desc), c1, c2, c3 from test;

--echo "test partition"
select percent_rank() over (partition by c2 order by c1), c1, c2, c3 from test;
select percent_rank() over (partition by c2 order by c1 desc), c1, c2, c3 from test;
select percent_rank() over (partition by c1 order by c1), c1, c2, c3 from test;

# should no contain param
--error ER_PARSE_ERROR 
select percent_rank(-1) over (order by c2), c1, c2 from test;

##should contail order by clause
#--error 5300
#select percent_rank() over (partition by c1), c1, c2 from test;

##should not contail window clause
#--error ER_SYNTAX_ERROR
#select percent_rank() over (partition by c2 order by c1 rows between unbounded preceding and unbounded following), c1, c2 from test;
#--error ER_SYNTAX_ERROR 
#select percent_rank() over (partition by c2 order by c1 rows between unbounded preceding and unbounded following), c1, c2 from test;
#--error ER_SYNTAX_ERROR 
#select percent_rank() over (partition by c2 order by c1 rows between current row and unbounded following), c1, c2 from test;

set @@recyclebin = off;
drop table test;















