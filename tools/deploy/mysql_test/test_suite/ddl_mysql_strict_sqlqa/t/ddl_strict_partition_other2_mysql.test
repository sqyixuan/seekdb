#设置SQL为严格模式
SET sql_mode='STRICT_TRANS_TABLES,STRICT_ALL_TABLES';
#查询sql模式
SELECT @@sql_mode;

--disable_warnings
DROP TABLE IF EXISTS Z0CASE;
--enable_warnings

--echo 二进制分区 PARTITION-->RANGE

CREATE TABLE Z0CASE (Z0_TEST0 BIT(25),Z0_TEST1 TINYINT)
PARTITION BY RANGE (Z0_TEST0)
( PARTITION part_1 VALUES LESS THAN (20),
  PARTITION part_2 VALUES LESS THAN (100),
  PARTITION part_3 VALUES LESS THAN ( MAXVALUE ));
INSERT INTO  Z0CASE (Z0_TEST0,Z0_TEST1)VALUES(b'000011111100101','111');
INSERT INTO  Z0CASE (Z0_TEST0,Z0_TEST1)VALUES(0,'2');
INSERT INTO  Z0CASE (Z0_TEST0,Z0_TEST1)VALUES(b'1010101','30');
INSERT INTO  Z0CASE (Z0_TEST0,Z0_TEST1)VALUES(b'101','121');
SELECT * FROM Z0CASE ORDER BY Z0_TEST1;
--source mysql_test/test_suite/ddl_mysql_non_strict_sqlqa/include/check_table_id.inc

ALTER TABLE Z0CASE MODIFY column z0_test0 BIT(26);
SELECT Z0_TEST1 FROM Z0CASE ORDER BY Z0_TEST1;
SELECT * FROM Z0CASE ORDER BY Z0_TEST1;
--source mysql_test/test_suite/ddl_mysql_non_strict_sqlqa/include/check_table_id.inc

ALTER TABLE Z0CASE MODIFY column z0_test0 BIT(25);
SELECT * FROM Z0CASE ORDER BY Z0_TEST1;
DESC Z0CASE;
--source mysql_test/test_suite/ddl_mysql_non_strict_sqlqa/include/check_table_id.inc

