#设置SQL为严格模式
SET sql_mode='STRICT_TRANS_TABLES,STRICT_ALL_TABLES';
#查询sql模式
SELECT @@sql_mode;

--disable_warnings
DROP TABLE IF EXISTS Z0CASE;
--enable_warnings

--echo CHAR
CREATE TABLE Z0CASE(Z0_TEST0 CHAR(100), Z0_TEST1 VARCHAR(50),Z0_TEST2 INT) with column group (all columns, each column);
INSERT INTO  Z0CASE (z0_test0,z0_test1,Z0_TEST2)VALUES('abc ABC','abc ABC',1);
INSERT INTO  Z0CASE (z0_test0,z0_test1,Z0_TEST2)VALUES('中文字符@!#$%^','中文字符@!#$%^',12);
INSERT INTO  Z0CASE (z0_test0,z0_test1,Z0_TEST2)VALUES(NULL,NULL,0);
INSERT INTO  Z0CASE (z0_test0,z0_test1,Z0_TEST2)VALUES(111,111,11);
INSERT INTO  Z0CASE (z0_test0,z0_test1,Z0_TEST2)VALUES('1111.1111','1111.1111',100);
INSERT INTO  Z0CASE (z0_test0,z0_test1,Z0_TEST2)VALUES('2011-11-11 11:11:11','2011-11-11 11:11:11',20);
INSERT INTO  Z0CASE (z0_test0,z0_test1,Z0_TEST2)VALUES(20111111,20111111,13);
INSERT INTO  Z0CASE (z0_test0,z0_test1,Z0_TEST2)VALUES(NULL,NULL,40);
INSERT INTO  Z0CASE (z0_test0,z0_test1,Z0_TEST2)VALUES('','',10);
INSERT INTO  Z0CASE (z0_test0,z0_test1,Z0_TEST2)VALUES('    ',' ',250);
SELECT * FROM Z0CASE ORDER BY Z0_TEST2;
--source mysql_test/test_suite/ddl_mysql_non_strict_sqlqa/include/check_table_id.inc

--echo CHAR --> CHAR

ALTER TABLE Z0CASE MODIFY COLUMN  z0_test0 CHAR(100);
DESC Z0CASE;
SELECT * FROM Z0CASE ORDER BY Z0_TEST2;
--source mysql_test/test_suite/ddl_mysql_non_strict_sqlqa/include/check_table_id.inc

ALTER TABLE Z0CASE MODIFY COLUMN  z0_test0 CHAR(101);
