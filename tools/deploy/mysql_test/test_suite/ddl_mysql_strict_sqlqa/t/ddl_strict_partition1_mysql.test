DROP TABLE Z0CASE;
CREATE TABLE Z0CASE (Z0_TEST0 INT ,Z0_TEST1 INT,
	CONSTRAINT cst check (Z0_TEST0=Z0_TEST1)) PARTITION BY LIST columns (Z0_TEST0)
	(PARTITION p0 VALUES IN (1,2,3,4,5),
     PARTITION p1 VALUES IN (10,100,111));
INSERT INTO Z0CASE (Z0_TEST0,Z0_TEST1)VALUES('1','111');
