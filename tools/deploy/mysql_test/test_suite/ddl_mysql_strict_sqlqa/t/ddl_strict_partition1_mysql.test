--echo LIST PARTITION

DROP TABLE Z0CASE;
CREATE TABLE Z0CASE (Z0_TEST0 CHAR(100),Z0_TEST1 CHAR(100))
PARTITION BY LIST columns(Z0_TEST0)
( PARTITION part_1 VALUES IN ('abc','123'),
  PARTITION part_2 VALUES IN ('cba','321'));
INSERT INTO  Z0CASE (Z0_TEST0,Z0_TEST1)VALUES('abc','111');
INSERT INTO  Z0CASE (Z0_TEST0,Z0_TEST1)VALUES('cba','2');
INSERT INTO  Z0CASE (Z0_TEST0,Z0_TEST1)VALUES('123','30');
INSERT INTO  Z0CASE (Z0_TEST0,Z0_TEST1)VALUES('321','11');
SELECT * FROM Z0CASE ORDER BY Z0_TEST1*1;
--source mysql_test/test_suite/ddl_mysql_non_strict_sqlqa/include/check_table_id.inc

