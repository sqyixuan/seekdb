--echo 唯一索引 + 外键
DROP TABLE Z0CASE;
DROP TABLE Z1CASE;
CREATE TABLE Z1CASE(  Z1_TEST0 CHAR(100) , Z1_TEST1 VARCHAR(100));
CREATE UNIQUE  INDEX Z1CASE_index ON Z1CASE (Z1_TEST0);
CREATE TABLE Z0CASE(  Z0_TEST0 CHAR(100) , Z0_TEST1 VARCHAR(100), FOREIGN KEY (Z0_TEST0) REFERENCES Z1CASE(Z1_TEST0));

INSERT INTO  Z1CASE (Z1_TEST0,Z1_TEST1)VALUES('1111.1111','1111.1111');
INSERT INTO  Z1CASE (Z1_TEST0,Z1_TEST1)VALUES(2011,2011);
INSERT INTO  Z1CASE (Z1_TEST0,Z1_TEST1)VALUES(20111111,20111111);
INSERT INTO  Z1CASE (Z1_TEST0,Z1_TEST1)VALUES('ABC','ABC');
INSERT INTO  Z1CASE (Z1_TEST0,Z1_TEST1)VALUES('ABC123','ABC123');
INSERT INTO  Z1CASE (Z1_TEST0,Z1_TEST1)VALUES(null,NULL);
INSERT INTO  Z0CASE (Z0_TEST0,Z0_TEST1)VALUES('1111.1111','1111.1111');
INSERT INTO  Z0CASE (Z0_TEST0,Z0_TEST1)VALUES(2011,2011);
INSERT INTO  Z0CASE (Z0_TEST0,Z0_TEST1)VALUES(20111111,20111111);
INSERT INTO  Z0CASE (Z0_TEST0,Z0_TEST1)VALUES('ABC','ABC');
INSERT INTO  Z0CASE (Z0_TEST0,Z0_TEST1)VALUES('ABC123','ABC123');
SELECT * FROM Z1CASE ORDER BY Z1_TEST0;
SELECT * FROM Z0CASE ORDER BY Z0_TEST0;

ALTER TABLE Z1CASE MODIFY COLUMN Z1_TEST0  CHAR(100);
SELECT * FROM Z1CASE ORDER BY Z1_TEST0;
DESC Z1CASE;
ALTER TABLE Z0CASE MODIFY COLUMN Z0_TEST0  CHAR(100);
SELECT * FROM Z0CASE ORDER BY Z0_TEST0;
DESC Z1CASE;
