#设置SQL为严格模式
SET sql_mode='STRICT_TRANS_TABLES,STRICT_ALL_TABLES';
#查询sql模式
SELECT @@sql_mode;

--disable_warnings
DROP TABLE IF EXISTS Z0CASE;
--enable_warnings

--echo TINYINT/ SMALLINT/ MEDIUMINT	/ INT/ BIGINT
CREATE TABLE Z0CASE(Z0_TEST0 TINYINT, Z0_TEST1 SMALLINT,Z0_TEST2 MEDIUMINT	,Z0_TEST3 INT,z0_test4 BIGINT) with column group (all columns, each column);
INSERT INTO  Z0CASE (z0_test0,z0_test1,Z0_TEST2,Z0_TEST3,z0_test4)VALUES(0,0,0,0,0);
INSERT INTO  Z0CASE (z0_test0,z0_test1,Z0_TEST2,Z0_TEST3,z0_test4)VALUES(111,111,111,111,111);
INSERT INTO  Z0CASE (z0_test0,z0_test1,Z0_TEST2,Z0_TEST3,z0_test4)VALUES(127,127.333,127.333,127.333,127.333);
INSERT INTO  Z0CASE (z0_test0,z0_test1,Z0_TEST2,Z0_TEST3,z0_test4)VALUES(-3.3333,-128.333,-128.333,-128.333,-128.333);
INSERT INTO  Z0CASE (z0_test0,z0_test1,Z0_TEST2,Z0_TEST3,z0_test4)VALUES(NULL,NULL,NULL,NULL,NULL);
SELECT * FROM Z0CASE ORDER BY Z0_TEST1;
--source mysql_test/test_suite/ddl_mysql_non_strict_sqlqa/include/check_table_id.inc

ALTER TABLE Z0CASE MODIFY COLUMN z0_test0 TINYINT  DEFAULT 0;
SELECT * FROM Z0CASE ORDER BY Z0_TEST1;
DESC Z0CASE;
--source mysql_test/test_suite/ddl_mysql_non_strict_sqlqa/include/check_table_id.inc

