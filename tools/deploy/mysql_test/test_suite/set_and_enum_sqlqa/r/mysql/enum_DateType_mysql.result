drop database  IF EXISTS  zrytest;
create database zrytest  character set utf8;
use zrytest;
#通过性测试
create table z0case(z_test varchar(100));
insert into z0case values('ABCdefg');
drop table z0case;
#obmysql-set/enum-1-1-1 成员个数
create table z0case(z_test enum());
ERROR 42000: You have an error in your SQL syntax; check the manual that corresponds to your OceanBase version for the right syntax to use near '))' at line 1
create table z0case(z_test enum(''));
create table z0case(z_test enum(null));
ERROR 42000: You have an error in your SQL syntax; check the manual that corresponds to your OceanBase version for the right syntax to use near 'null))' at line 1
drop table z0case;
#创建字节大于8个字节的字段
create table z0case(z_test enum('中文123213asd12ASDSA131121321321esdasc1大声大声道232132132132131123213asd12ASDSA131121321321esdasc1大声大声道23213213213213112321321sadsadasd12321321321321321字符'));
drop table z0case;
obmysql-set/enum-2-1 参数类型
#字符类型
create table z0case(z_test1 enum('123183','中文字符','ABCabc','!@#$%^&*'),z_test0 enum('123183','中文字符','ABCabc','!@#$%^&*'));
drop table z0case;
#数字类型
create table z0case(z_test0 char(200),z_test1 enum('123183',123.123,12321321));
ERROR 42000: You have an error in your SQL syntax; check the manual that corresponds to your OceanBase version for the right syntax to use near '123.123,12321321))' at line 1
日期格式
create table z0case(z_test0 char(200),z_test1 enum('2020-10-10 10:10:10','2020-10-10','10:10:10'));
drop table z0case;
obmysql-set/enum-2-1-2 #异常值
#重复的数据
create table z0case(z_test1 enum('中文字符','中文字符','ABCabc','!@#$%^&*'));
ERROR HY000: Column 'z_test1' has duplicated value '中文字符' in ENUM 
create table z0case(z_test1 enum('中文字符',' 中文字符','ABCabc','!@#$%^&*'));
drop table z0case;
create table z0case(z_test1 enum('中文字符','中文字符 ','ABCabc','!@#$%^&*'));
ERROR HY000: Column 'z_test1' has duplicated value '中文字符' in ENUM 
create table z0case(z_test1 enum('中文字符','中文 字符','ABCabc','!@#$%^&*'));
drop table z0case;
create table z0case(z_test1 enum('123','123.00','ABCabc','!@#$%^&*'));
drop table z0case;
create table z0case(z_test1 enum('123','00123','ABCabc','!@#$%^&*'));
drop table z0case;
NULL
create table z0case(z_test1 enum(NULL,'ABCabc','!@#$%^&*'));
ERROR 42000: You have an error in your SQL syntax; check the manual that corresponds to your OceanBase version for the right syntax to use near 'NULL,'ABCabc','!@#$%^&*'))' at line 1
create table z0case(z_test1 enum('','ABCabc','!@#$%^&*'));
空格
drop table z0case;
create table z0case(z_test1 enum(' ','      ','ABCabc','!@#$%^&*'));
ERROR HY000: Column 'z_test1' has duplicated value '' in ENUM 
create table z0case(z_test1 enum('','      ','ABCabc','!@#$%^&*'));
ERROR HY000: Column 'z_test1' has duplicated value '' in ENUM 
区分大小写
create table z0case(z_test1 enum('ABC','abc','ABCabc','!@#$%^&*'));
ERROR HY000: Column 'z_test1' has duplicated value 'ABC' in ENUM 
create table z0case(z_test1 enum('中文ABC123','中文abc123','ABCabc','!@#$%^&*'));
ERROR HY000: Column 'z_test1' has duplicated value '中文ABC123' in ENUM 
#包含逗号
create table z0case(z_test1 enum('!@#$%,^&*','中文ab,c123','ABCa,bc','!@#$%^&*',','));
drop table z0case;
create table z0case(z_test1 enum('!@#$%。^&*','中文abc123','ABCabc','!@#$%^&*'));
drop table z0case;
