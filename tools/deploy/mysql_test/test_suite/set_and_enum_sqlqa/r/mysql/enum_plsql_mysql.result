与各字符类型比较
create procedure SetProce()
begin
declare setSQL0 enum('中文字符','123456','ABCabc','!@#$%^&*','2020-10-10');
declare setSQL1  char(100);
select  'ABCabc' into setSQL0;
select  'ABCab' into setSQL1;
insert into z1case select z0_test0, z0_test0 from z0case where setSQL0>setSQL1;
end;
//
call SetProce;
SELECT * FROM z1case;
z1_test0	z1_test1
中文字符	中文字符
123456	123456
ABCabc	ABCabc
!@#$%^&*	!@#$%^&*
2020-10-10	2020-10-10
NULL	NULL
DELETE FROM z1case;
DROP PROCEDURE SetProce;
create procedure SetProce()
begin
declare setSQL0 enum('中文字符','123456','ABCabc','!@#$%^&*','2020-10-10');
declare setSQL1  varchar(100); 
select  'ABCabc' into setSQL0;
select  'ABCab' into setSQL1;
insert into z1case select z0_test0, z0_test0 from z0case where setSQL0>setSQL1;
end;
//
call SetProce;
SELECT * FROM z1case;
z1_test0	z1_test1
中文字符	中文字符
123456	123456
ABCabc	ABCabc
!@#$%^&*	!@#$%^&*
2020-10-10	2020-10-10
NULL	NULL
DELETE FROM z1case;
DROP PROCEDURE SetProce;
