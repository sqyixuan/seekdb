drop database  IF EXISTS  zrytest;
create database zrytest  character set utf8;
use zrytest;
function
create table z0case(z0_test0 set('中文字符','123456','ABCabc','!@#$%^&*','2020-10-10','2020-10-10 10:10:10','10:10:10'),z0_test1 char(100) );
insert into z0case values('中文字符','中文字符');
insert into z0case values('123456','123456');
insert into z0case values('ABCabc','ABC abc');
insert into z0case values('!@#$%^&*','!@#$%^&*');
insert into z0case values('2020-10-10','2020-10-10');
insert into z0case values('','');
insert into z0case values(null,null);
自定义set类型字符
CREATE FUNCTION SetFunction(setSQL char(100)) RETURNS varchar(100) no sql
BEGIN
declare a set('中文字符 ','123456','ABCabc ','!@#$%^&*','2020-11-11');
select z0_test0 from z0case e where z0_test0 =setSQL into a;
return a;
end;
//
select SetFunction('中文字符') from dual;
SetFunction('中文字符')
中文字符
select SetFunction('2020-10-10') from dual;
ERROR 01000: Data truncated for argument
输入set类型字符
drop FUNCTION SetFunction;
CREATE FUNCTION SetFunction(setSQL set('中文字符 ','123456','ABCabc ','!@#$%^&*','2020-11-10')) RETURNS varchar(100)
BEGIN
declare a set('中文字符 ','123456','ABCabc ','!@#$%^&*','2020-11-11');
select z0_test0 from z0case e where z0_test0 =setSQL into a;
return a;
end;
//
select SetFunction('2020-11-11') from dual;
ERROR 01000: Data truncated for argument
select SetFunction('2020-10-10') from dual;
ERROR 01000: Data truncated for argument
#30613652 自定义函数，返回set类型字段，输入一个不存在set集合中的数据，mysql报错，ob正常通过PL
返回set类型
drop FUNCTION SetFunction;
CREATE FUNCTION SetFunction(setSQL varchar(100)) RETURNS set('中文字符 ','123456','ABCabc ','!@#$%^&*','2020-09-09')
BEGIN
declare a set('中文字符 ','123456','ABCabc ','!@#$%^&*','2020-10-10');
declare b varchar(100);
select z0_test0 from z0case e where z0_test0 =setSQL into b;
return b;
end;
//
select SetFunction('2020-10-10') from dual;
ERROR 01000: Data truncated for argument
select SetFunction('中文字符') from dual;
SetFunction('中文字符')
中文字符
insert
drop FUNCTION SetFunction;
CREATE FUNCTION SetFunction(setSQL varchar(100)) RETURNS varchar(20)
BEGIN
insert into z0case values(setSQL,'2020-10-10');
return setSQL;
end;
//
#30615693 自定义函数，insert 和 update 一个不符合set类型的数据，mysql报错，ob正常通过，
select SetFunction('中文 字符') from dual;
ERROR 01000: Data truncated for column 'z0_test0' at row 1
update
drop FUNCTION SetFunction;
CREATE FUNCTION SetFunction(setSQL varchar(100)) RETURNS varchar(20)
BEGIN
insert into z0case values(setSQL,'2020-10-10');
return setSQL;
end;
//
select SetFunction('中文 字符') from dual;
ERROR 01000: Data truncated for column 'z0_test0' at row 1
drop FUNCTION SetFunction;
自定义set类型变量
create table z1case(z1_test0 set('中文字符','123456','ABCabc','!@#$%^&*','2020-10-10','2020-10-10 10:10:10','10:10:10'),z1_test1 char(100));
select * from z1case;
z1_test0	z1_test1
create procedure SetProce ()
begin
declare setSQL0 set('中文字符','123456','ABCabc','!@#$%^&*','2010-10-10');
select  123456 into setSQL0;
insert into z1case values(setSQL0,setSQL0);
end;
//
call SetProce;
ERROR 01000: Data truncated for argument
DELETE FROM z1case;
DROP PROCEDURE SetProce;
create procedure SetProce ()
begin
declare setSQL0 set('中文字符','12345,6','ABCabc','!@#$%^&*','2010-10-10');
select  '中文字符' into setSQL0;
insert into z1case values(setSQL0,setSQL0);
end;
//
Warnings:
Warning	5002	Resolve error
call SetProce;
ERROR 22007: Illegal set '12345,6' value found during parsing
DELETE FROM z1case;
DROP PROCEDURE SetProce;
create procedure SetProce ()
begin
declare setSQL0 set('中文字符','123456','ABCabc','!@#$%^&*','2010-10-10');
select  '123456,123456' into setSQL0;
insert into z1case values(setSQL0,setSQL0);
end;
//
call SetProce;
DELETE FROM z1case;
DROP PROCEDURE SetProce;
insert
create procedure SetProce ()
begin
declare setSQL0 set('中文字符','123456','ABCabc','!@#$%^&*','2010-10-10');
select  '2010-10-10' into setSQL0;
insert into z1case values(setSQL0,setSQL0);
end;
//
call SetProce;
ERROR 01000: Data truncated for column 'z1_test0' at row 1
SELECT * FROM z1case;
z1_test0	z1_test1
DELETE FROM z1case;
DROP PROCEDURE SetProce;
update
create procedure SetProce ()
begin
declare setSQL0 varchar(100);
set setSQL0:='Abc abc  ';
update z0case  set z0_test0=setSQL0,z0_test1=setSQL0 limit 1;
end;
//
#30644339 存储过程，自定义set类型的变量，转换成DECIMAL类型，然后将该变量插入 有set类型字段的表中，mysql正常通过，ob报错
call SetProce;
ERROR 01000: Data truncated for column 'z0_test0' at row 1
SELECT * FROM z1case;
z1_test0	z1_test1
DELETE FROM z1case;
DROP PROCEDURE SetProce;
set 运算
create procedure SetProce ()
begin
declare setSQL0 set('i中文字符','123456','ABCabc','!@#$%^&*','2010-10-10');
select  '123456' into setSQL0;
insert into z1case values(setSQL0,setSQL0+1);
end;
//
call SetProce;
SELECT * FROM z1case;
z1_test0	z1_test1
123456	3
DELETE FROM z1case;
DROP PROCEDURE SetProce;
date
create procedure SetProce ()
begin
declare setSQL0 set('中文字符','123456','ABCabc','!@#$%^&*','2010-10-10');
declare setSQL1 date;set setSQL1:='2020-10-10';
select  'ABCabc' into setSQL0;
insert into z1case values(setSQL0,setSQL0+setSQL0);
insert into z1case values(setSQL0,setSQL0-setSQL1);
end;
//
call SetProce;
ERROR 42S22: Unknown column ' ' in 'field list'
SELECT * FROM z1case;
z1_test0	z1_test1
DELETE FROM z1case;
DROP PROCEDURE SetProce;
#char、varcahr
create procedure SetProce ()
begin
declare setSQL0 set('中文字符','123456','ABCabc','!@#$%^&*','2010-10-10');
declare setSQL1 char(100);
declare setSQL2 varchar(100);
select 'ABCabc' into setSQL1;
select 'ABCabc' into setSQL2;
select  'ABCabc' into setSQL0;
insert into z1case values(setSQL0,SUBSTRING(setSQL0+setSQL1,0,5));
insert into z1case values(setSQL0,setSQL0-setSQL2);
end;
//
call SetProce;
ERROR 42S22: Unknown column ' ' in 'field list'
SELECT * FROM z1case;
z1_test0	z1_test1
DELETE FROM z1case;
DROP PROCEDURE SetProce;
函数嵌套
create procedure SetProce ()
begin
declare setSQL0 set('中文字符','123456','ABCabc','!@#$%^&*','2020-10-10');
select  'ABCabc' into setSQL0;
insert into z1case values(setSQL0,concat(setSQL0, '%Y/%M/%d'));
insert into z1case values(upper(setSQL0),upper(setSQL0));
insert into z1case values(lower(setSQL0),lower(setSQL0));
insert into z1case values(setSQL0,length(setSQL0));
insert into z1case values(setSQL0,SUBSTRING(setSQL0,2,5));
insert into z1case values(TRIM(setSQL0),TRIM(setSQL0));
end;
//
call SetProce;
SELECT * FROM z1case;
z1_test0	z1_test1
ABCabc	ABCabc%Y/%M/%d
ABCabc	ABCABC
ABCabc	abcabc
ABCabc	6
ABCabc	BCabc
ABCabc	ABCabc
DELETE FROM z1case;
DROP PROCEDURE SetProce;
create procedure SetProce ()
begin
declare setSQL0 set('中文字符','123456','ABCabc','!@#$%^&*','2010-10-10');
select  '2020-10-10' into setSQL0;
insert into z1case values(setSQL0,DATE_FORMAT(setSQL0, '%Y/%M/%d'));
end;
//
call SetProce;
ERROR 42S22: Unknown column ' ' in 'field list'
SELECT * FROM z1case;
z1_test0	z1_test1
DELETE FROM z1case;
DROP PROCEDURE SetProce;
类型转换
char、BINARY
create procedure SetProce ()
begin
declare setSQL0 set('中文字符','123456','ABCabc','!@#$%^&*','2010-10-10');
select  'ABCabc' into setSQL0;
insert into z1case values(cast(setSQL0 as char),cast(setSQL0 as char));
insert into z1case values(cast(setSQL0 as BINARY),cast(setSQL0 as BINARY));
end;
//
call SetProce;
SELECT * FROM z1case;
z1_test0	z1_test1
ABCabc	ABCabc
ABCabc	ABCabc
DELETE FROM z1case;
DROP PROCEDURE SetProce;
DECIMAL
create procedure SetProce ()
begin
declare setSQL0 set('中文字符','123456','ABCabc','!@#$%^&*','2010-10-10');
select  '123456' into setSQL0;
insert into z1case values(cast(setSQL0 as DECIMAL),cast(setSQL0 as DECIMAL));
end;
//
call SetProce;
SELECT * FROM z1case;
z1_test0	z1_test1
123456	2
DELETE FROM z1case;
DROP PROCEDURE SetProce;
date
create procedure SetProce ()
begin
declare setSQL0 set('中文字符','123456','ABCabc','!@#$%^&*','2020-10-10');
select  '2020-10-10' into setSQL0;
insert into z1case values(cast(setSQL0 as date),cast(setSQL0 as date));
end;
//
call SetProce;
SELECT * FROM z1case;
z1_test0	z1_test1
2020-10-10	2020-10-10
DELETE FROM z1case;
DROP PROCEDURE SetProce;
与各字符类型比较
create procedure SetProce ()
begin
declare setSQL0 set('中文字符','123456','ABCabc','!@#$%^&*','2020-10-10');
declare setSQL1  char(100);
select  'ABCabc' into setSQL0;
select  'ABCab' into setSQL1;
insert into z1case select z0_test0, z0_test0 from z0case where setSQL0>setSQL1;
end;
//
call SetProce;
SELECT * FROM z1case;
z1_test0	z1_test1
中文字符	中文字符
123456	123456
ABCabc	ABCabc
!@#$%^&*	!@#$%^&*
2020-10-10	2020-10-10
	
NULL	NULL
DELETE FROM z1case;
DROP PROCEDURE SetProce;
create procedure SetProce ()
begin
declare setSQL0 set('中文字符','123456','ABCabc','!@#$%^&*','2020-10-10');
declare setSQL1  varchar(100);
select  'ABCabc' into setSQL0;
select  'ABCab' into setSQL1;
insert into z1case select z0_test0, z0_test0 from z0case where setSQL0>setSQL1;
end;
//
call SetProce;
SELECT * FROM z1case;
z1_test0	z1_test1
中文字符	中文字符
123456	123456
ABCabc	ABCabc
!@#$%^&*	!@#$%^&*
2020-10-10	2020-10-10
	
NULL	NULL
DELETE FROM z1case;
DROP PROCEDURE SetProce;
