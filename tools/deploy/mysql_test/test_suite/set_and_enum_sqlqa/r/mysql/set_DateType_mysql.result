obmysql-set/enum-2-1 参数类型
字符类型
create table z0case(z_test1 set('123183','中文字符','ABCabc','!@#$%^&*'),z_test0 set('123183','中文字符','ABCabc','!@#$%^&*'));
#数字类型
create table z0case(z_test0 char(200),z_test1 set('123183',123.123,12321321));
ERROR 42000: You have an error in your SQL syntax; check the manual that corresponds to your OceanBase version for the right syntax to use near '123.123,12321321))' at line 1
drop table z0case;
日期格式
create table z0case(z_test0 char(200),z_test1 set('2020-10-10 10:10:10','2020-10-10','10:10:10'));
drop table z0case;
obmysql-set/enum-2-1-2 #异常值
#重复的数据
create table z0case(z_test1 set('中文字符','中文字符','ABCabc','!@#$%^&*'));
ERROR HY000: Column 'z_test1' has duplicated value '中文字符' in SET 
create table z0case(z_test1 set('中文字符',' 中文字符','ABCabc','!@#$%^&*'));
drop table z0case;
create table z0case(z_test1 set('中文字符','中文字符 ','ABCabc','!@#$%^&*'));
ERROR HY000: Column 'z_test1' has duplicated value '中文字符' in SET 
create table z0case(z_test1 set('中文字符','中文 字符','ABCabc','!@#$%^&*'));
drop table z0case;
create table z0case(z_test1 set('123','123.00','ABCabc','!@#$%^&*'));
drop table z0case;
create table z0case(z_test1 set('123','00123','ABCabc','!@#$%^&*'));
NULL
create table z0case(z_test1 set(NULL,'ABCabc','!@#$%^&*'));
