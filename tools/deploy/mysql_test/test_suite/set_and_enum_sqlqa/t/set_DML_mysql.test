--echo  where like、in

select z0_test0 from z0case where z0_test0 like '%A%' ;
select z0_test0 from z0case where z0_test0 like '%A%' or length(z0_test0)<7;
select z0_test0 from z0case where z0_test0 in ('中文字符',123456,'ABCabc ',NULL,'2020-10-10 10:10:10');


--echo FIND_IN_SET
#
--echo #30567656 set类型，内容为空格的字段 转换成Time类型的字符，ob输出00:00:00，mysql输出为null

SELECT * FROM z0case WHERE FIND_IN_SET('中文字符',z0_test0)>0;
SELECT * FROM z0case WHERE FIND_IN_SET('123456',z0_test0)>0;
