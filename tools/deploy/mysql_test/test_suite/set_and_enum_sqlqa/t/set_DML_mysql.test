--echo insert date
create table z0case(z0_test0 set('中文字符','123456','ABCabc','!@#$%^&*','2020-10-10','2020-10-10 10:10:10','10:10:10') , z0_test1 dateTime);
create table z1case(z1_test0 dateTime);
insert into z1case values('2020-10-10');
insert into z1case values('2020-10-10 10:10:10');
insert into z1case values('10:10:10');
insert into z1case values(null);
--error 1265
insert into z0case select z1_test0,z1_test0 from z1case where z1_test0='2020-10-10';
insert into z0case select z1_test0,z1_test0 from z1case where z1_test0='2020-10-10 10:10:10';
--error 1265
insert into z0case select z1_test0,z1_test0 from z1case where z1_test0='10:10:10';
insert into z0case select z1_test0,z1_test0 from z1case where z1_test0 is null;
insert into z0case VALUES (cast('2020-10-10 10:10:10' as date),cast('2020-10-10 10:10:10' as date));
select * from z0case;

select cast('2020-10-10 10:10:10' as date),cast('2020-10-10 10:10:10' as date) from dual;
--error 1265
insert into z0case values (DATE_FORMAT('2020-10-10','%Y/%m/%d'),DATE_FORMAT('2020-10-10','%Y/%m/%d')) ;  

drop table z0case;
drop table z1case;


--echo insert FLOAT、DECIMAL
create table z0case(z0_test0 set('中文字符','123456','ABCabc','!@#$%^&*','2020-10-10','2020-10-10 10:10:10','10:10:10'),z0_test1 FLOAT);
create table z1case(z1_test0 FLOAT);
insert into z1case values(123456);
insert into z1case values(123456.00);
insert into z1case values(00123456);
insert into z1case values(123456.00000000000000001);
insert into z1case values(null);


--error 1265
insert into z0case select z1_test0,z1_test0 from z1case where z1_test0=123456;
--error 1265
