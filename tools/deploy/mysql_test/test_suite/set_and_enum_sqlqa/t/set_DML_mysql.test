INSERT INTO z0case VALUES ('123456,123456,123456');
INSERT INTO z0case VALUES ('ABCABC,中文字符,123456,123456,123456');
select * from z0case;


create table z1case(z1_test0 char(100),z1_test1 varchar(100),z1_test2 BLOB,z1_test3 TEXT,z1_test4 date,z1_test5 DECIMAL);
insert into z1case values('中文字符','中文字符','中文字符','中文字符','2020-10-10','123456');
insert into z1case values('123456','123456','123456','123456','2020-10-10','123456.00000');
insert into z1case values('ABCabc','ABCabc','ABCabc','ABCabc','2020-10-10','123456.00000001');
insert into z1case values('2020-10-10 10:10:10','2020-10-10 10:10:10','2020-10-10 10:10:10','2020-10-10 10:10:10','2020-10-10','123456');
insert into z1case values('','','','','2020-10-10','000123456');
insert into z1case values(null,null,null,null,null,null);
insert into z1case values('123456,中文字符,ABCabc','123456,中文字符,ABCabc','123456,中文字符,ABCabc','123456,中文字符,ABCabc',NULL,'123456');
--echo where 
--echo char
select z0_test0,z1_test0 from z0case,z1case where z0_test0 > (select z1_test0 from z1case where z1_test0='中文字符');
select z0_test0,z1_test0 from z0case,z1case where z0_test0 = (select z1_test0 from z1case where z1_test0='中文字符');
select z0_test0,z1_test0 from z0case,z1case where z0_test0 > (select z1_test0 from z1case where z1_test0='123456');
select z0_test0,z1_test0 from z0case,z1case where z0_test0 = (select z1_test0 from z1case where z1_test0='123456');
select z0_test0,z1_test0 from z0case,z1case where z0_test0 > (select z1_test0 from z1case where z1_test0='ABCabc');
select z0_test0,z1_test0 from z0case,z1case where z0_test0 = (select z1_test0 from z1case where z1_test0='ABCabc');
select z0_test0,z1_test0 from z0case,z1case where z0_test0 > (select z1_test0 from z1case where z1_test0='2020-10-10 10:10:10');
select z0_test0,z1_test0 from z0case,z1case where z0_test0 = (select z1_test0 from z1case where z1_test0='2020-10-10 10:10:10');

select z0_test0,z1_test0 from z0case,z1case where z0_test0 > (select z1_test0 from z1case where z1_test0='');
select z0_test0,z1_test0 from z0case,z1case where z0_test0 = (select z1_test0 from z1case where z1_test0='');
select z0_test0,z1_test0 from z0case,z1case where z0_test0 is null;
select z0_test0,z1_test0 from z0case,z1case where z0_test0 is not null;
select z0_test0,z1_test0 from z0case,z1case where z0_test0 > (select z1_test0 from z1case where z1_test0='123456,中文字符,ABCabc');
select z0_test0,z1_test0 from z0case,z1case where z0_test0 = (select z1_test0 from z1case where z1_test0='123456,中文字符,ABCabc');

