--echo where 与char比较
drop table z0case;
create table z0case(z0_test0 set('中文字符','123456','ABCabc','!@#$%^&*','2020-10-10','2020-10-10 10:10:10','10:10:10'));
insert into z0case values('中文字符');
insert into z0case values('123456');
insert into z0case values('ABCabc');
insert into z0case values('!@#$%^&*');
