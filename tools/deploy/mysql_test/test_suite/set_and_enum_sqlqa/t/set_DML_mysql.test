--disable_warnings
drop database  IF EXISTS  zrytest;
--enable_warnings
create database zrytest  character set utf8;
use zrytest;


--echo obmysql-set/enum-3-2 #insert
create table z0case(z_test1 set('中文字符','123456','ABCabc','!@#$%^&*','2020-10-10','2020-10-10 10:10:10','10:10:10'));

insert into z0case values('中文字符');
insert into z0case values('123456');
insert into z0case values('ABCabc');
insert into z0case values('!@#$%^&*');
insert into z0case values('2020-10-10');
insert into z0case values('2020-10-10 10:10:10');
insert into z0case values('10:10:10');

--echo insert 空值
insert into z0case values(null);
insert into z0case values('');
--error 1265
insert into z0case values(' ');
--error 1265
insert into z0case values(' 中文字符');
--error 1265
insert into z0case values('中文 字符');
insert into z0case values('中文字符 ');
insert into z0case values('中文字符  ');
insert into z0case values('abCabc');

insert into z0case values('1');
insert into z0case values(127.99999999999);
--error 1265
insert into z0case values(128);
insert into z0case values(0);
--error 1265
insert into z0case values(123456);
drop table z0case;

--echo insert 多个值
create table z1case(z1_test0 set('中文字符','123456','ABCabc','!@#$%^&*','2020-10-10','2020-10-10 10:10:10','10:10:10',' '),z1_test1 char(100) );

--error 1265
INSERT INTO z1case VALUES (('123456,null,null'),null);
INSERT INTO z1case VALUES (('123456,123456,123456'),null);
--error 1265
INSERT INTO z1case VALUES (('123456,''123456'',123456'),null);
--error 1265
INSERT INTO z1case VALUES (('ABCabc,ABCabc ,ABCabc'),null);
INSERT INTO z1case VALUES (('ABCABC,abcabc,ABCabc'),null);
INSERT INTO z1case VALUES (('ABCABC,中文字符,123456,123456,123456'),null);
INSERT INTO z1case VALUES ((',,123456,123456,,   '),null);
--error 1265
INSERT INTO z1case VALUES (('1234567,,123456,123456'),null);
select * from z1case;
drop table z1case;


--echo #insert不同类型的字符
