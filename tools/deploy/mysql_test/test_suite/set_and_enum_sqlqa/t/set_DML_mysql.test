insert into z0case select z1_test0,z1_test0 from z1case where z1_test0 is null;

--error 1265
insert into z0case values (cast('123456'  AS  DECIMAL),cast('123456'  AS  DECIMAL));

select * from z0case;

drop table z0case;
drop table z1case;

