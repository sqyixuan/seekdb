--disable_warnings
drop database  IF EXISTS  zrytest;
--enable_warnings
create database zrytest  character set utf8;
use zrytest;

create table z1case(z1_test0 char(100),z1_test1 varchar(100),z1_test2 BLOB,z1_test3 TEXT,z1_test4 date,z1_test5 DECIMAL);
insert into z1case values('中文字符','中文字符','中文字符','中文字符','2020-10-10','123456');
insert into z1case values('123456','123456','123456','123456','2020-10-10','123456.00000');
insert into z1case values('ABCabc','ABCabc','ABCabc','ABCabc','2020-10-10','123456.00000001');
insert into z1case values('2020-10-10 10:10:10','2020-10-10 10:10:10','2020-10-10 10:10:10','2020-10-10 10:10:10','2020-10-10','123456');
insert into z1case values('','','','','2020-10-10','000123456');
insert into z1case values(null,null,null,null,null,null);

create table z2case(z2_test0 set('中文 字符','654321','ABCDabcd ','!@#$%^&*','2020-10-10','2020-10-10 10:10:10','10:10:10'));
insert into z2case values('中文 字符');
insert into z2case values('654321');
insert into z2case values('ABCDabcd');
insert into z2case values('!@#$%^&*');
insert into z2case values('2020-10-10');
insert into z2case values('2020-10-10 10:10:10');
insert into z2case values('10:10:10');
insert into z2case values('');
insert into z2case values(null);

--echo 约束 not null
create table z0case(z0_test0 set('中文字符','123456','ABCabc','!@#$%^&*','2020-10-10','2020-10-10 10:10:10','10:10:10') not NULL);
--echo insert
insert into z0case values('中文字符');
insert into z0case values('123456');
insert into z0case values('ABCabc');
insert into z0case values('!@#$%^&*');
insert into z0case values('2020-10-10');
insert into z0case values('2020-10-10 10:10:10');
insert into z0case values('10:10:10');
insert into z0case values('');
--error 1048
insert into z0case values(null);
--error 1265
insert into z0case values(' ');
insert into z0case values('中文字符  ');
--error 1265
insert into z0case values(123456);
insert into z0case values('abcabc');
--error 1048
insert into z0case values(nullif('中文字符','中文字符'));
--error 1048
insert into z0case select z2_test0 from z2case where z2_test0 is null;

select upper(z0_test0) from z0case;
select lower(z0_test0) from z0case;
select length(z0_test0) from z0case;
select * from z0case group by z0_test0 having length(z0_test0)>6 ;
select SUBSTRING(z0_test0,2,5) from z0case;
select COUNT(z0_test0) from z0case;
select min(z0_test0) from z0case;
select MAX(z0_test0) from z0case;
select INSERT(z0_test0,1,2,'A') from z0case;
select LEFT(z0_test0,3)from z0case;
select nvl(z0_test0,NULL) from z0case;
select nullif(z0_test0,'中文字符') from z0case;
select nullif(z0_test0,123456) from z0case;
select STRCMP(z0_test0,z1_test0) from z0case,z1case where z0_test0=z1_test0;
select STRCMP(z0_test0,z1_test1) from z0case,z1case where z0_test0=z1_test0;
select STRCMP(z0_test0,z1_test2) from z0case,z1case where z0_test0=z1_test0;
select STRCMP(z0_test0,z1_test3) from z0case,z1case where z0_test0=z1_test0;
select STRCMP(z0_test0,z1_test4) from z0case,z1case where z0_test0=z1_test0;
select STRCMP(z0_test0,z1_test5) from z0case,z1case where z0_test0=z1_test0;

select CONCAT(z0_test0,z1_test0) from z0case,z1case;
select CONCAT(z0_test0,z1_test1) from z0case,z1case;
select CONCAT(z0_test0,z1_test2) from z0case,z1case;
select CONCAT(z0_test0,z1_test4) from z0case,z1case;
select CONCAT(z0_test0,z1_test5) from z0case,z1case;
select TRIM(z0_test0) from z0case;
select RPAD(z0_test0,10,1232) from z0case;
