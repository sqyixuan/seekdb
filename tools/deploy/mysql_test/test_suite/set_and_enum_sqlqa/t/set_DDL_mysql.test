--echo view
drop table z0case;
create table z0case(z0_test0 set('中文字符','123456','ABCabc','!@#$%^&*','2020-10-10','2020-10-10 10:10:10','10:10:10'),z0_test1 set('中文字符','123456','ABC abc','!@#$%^&*','2020-10-10') );

