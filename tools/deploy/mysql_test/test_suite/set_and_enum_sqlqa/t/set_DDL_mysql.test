drop table z0case;


--echo primary key
create table z0case(z0_test0 set('中文字符','123456','ABCabc','!@#$%^&*','2020-10-10','2020-10-10 10:10:10','10:10:10') primary KEY,z0_test1 set('中文字符','123456','ABC abc','!@#$%^&*','2020-10-10') );

insert into z0case values('中文字符','中文字符');
insert into z0case values('123456','123456');
insert into z0case values('ABCabc','ABC abc');
insert into z0case values('!@#$%^&*','!@#$%^&*');
insert into z0case values('2020-10-10','2020-10-10');
insert into z0case values('','');
--error 1048
insert into z0case values(null,null);
--error 1062
insert into z0case values('中文字符 ',null);
--error 1062
insert into z0case values('abcabc  ',null);
--error 1062
insert into z0case values('ABCABC ',null);
--error 1062
update z0case set z0_test0=(select cast(123456 as BINARY) from dual) limit 1;
--error 1062
update z0case set z0_test0=(select cast('中文字符' as BINARY) from dual) limit 1;
update z0case set z0_test0=(select cast('' as BINARY) from dual) limit 1;
--error 1048
update z0case set z0_test0=(select cast(null as BINARY) from dual) limit 1;
select * from z0case where z0_test0 like '%A%';
select * from z0case where z0_test0> z0_test1;



--echo index
drop table z0case;
create table z0case(z0_test0 set('中文字符','123456','ABCabc','!@#$%^&*','2020-10-10','2020-10-10 10:10:10','10:10:10'),z0_test1 set('中文字符','123456','ABC abc','!@#$%^&*','2020-10-10') );

