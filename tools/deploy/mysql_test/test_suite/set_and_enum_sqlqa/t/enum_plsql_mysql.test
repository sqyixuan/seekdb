#description: set类型
#tags: pl, 参数个数,参数类型,异常值
#author:wb-zry774348



--disable_warnings
drop database  IF EXISTS  zrytest;
--enable_warnings
create database zrytest  character set utf8;
use zrytest;



--echo function
create table z0case(z0_test0 enum('中文字符','123456','ABCabc','!@#$%^&*','2020-10-10','2020-10-10 10:10:10','10:10:10'),z0_test1 char(100) );

insert into z0case values('中文字符','中文字符');
insert into z0case values('123456','123456');
insert into z0case values('ABCabc','ABC abc');
insert into z0case values('!@#$%^&*','!@#$%^&*');
insert into z0case values('2020-10-10','2020-10-10');
--error 1265
insert into z0case values('','');
insert into z0case values(null,null);

--echo 自定义enum类型字符
delimiter //;
CREATE FUNCTION EnumFunction(enumSQL char(100)) RETURNS varchar(100)
BEGIN
	declare a enum('中文字符 ','123456','ABCabc ','!@#$%^&*','2020-11-11');
	select z0_test0 from z0case e where z0_test0 =enumSQL into a;
	return a;
end;
//
delimiter ;//

select EnumFunction('中文字符') from dual;
--error 1265
select EnumFunction('2020-10-10') from dual;


--echo 输入enum类型字符
drop FUNCTION EnumFunction;
delimiter //;
CREATE FUNCTION EnumFunction(enumSQL enum('中文字符 ','123456','ABCabc ','!@#$%^&*','2020-11-10')) RETURNS varchar(100)
BEGIN
	declare a enum('中文字符 ','123456','ABCabc ','!@#$%^&*','2020-11-11');
	select z0_test0 from z0case e where z0_test0 =enumSQL into a;
	return a;
end;
//
delimiter ;//
--error 1265
select EnumFunction('2020-11-11');
--error 1265
select EnumFunction('2020-10-10');


--echo 返回enum类型
drop FUNCTION EnumFunction;
delimiter //;
CREATE FUNCTION EnumFunction(enumSQL varchar(100)) RETURNS enum('中文字符 ','123456','ABCabc ','!@#$%^&*','2020-09-09')
BEGIN
	declare a enum('中文字符 ','123456','ABCabc ','!@#$%^&*','2020-10-10');
	declare b varchar(100);
	select z0_test0 from z0case e where z0_test0 =enumSQL into b;
	return b;
end;
//
delimiter ;//
--error 1265
select EnumFunction('2020-10-10') from dual;
select EnumFunction('中文字符') from dual;

--echo insert
drop FUNCTION EnumFunction;
delimiter //;
CREATE FUNCTION EnumFunction(enumSQL varchar(100)) RETURNS varchar(20)
BEGIN
    insert into z0case values(enumSQL,'2020-10-10');
	return enumSQL;
end;
//
delimiter ;//
--error 1265
select EnumFunction('中文 字符') from dual;


--echo update
drop FUNCTION EnumFunction;
delimiter //;
CREATE FUNCTION EnumFunction(enumSQL varchar(100)) RETURNS varchar(20)
BEGIN
    insert into z0case values(enumSQL,'2020-10-10');
	return enumSQL;
end;
//
delimiter ;//
--error 1265
select EnumFunction('中文 字符') from dual;
drop FUNCTION EnumFunction;


#存储过程
--echo 自定义enum类型变量
create table z1case(z1_test0 enum('中文字符','123456','ABCabc','!@#$%^&*','2020-10-10','2020-10-10 10:10:10','10:10:10'),z1_test1 char(100));
select * from z1case;

delimiter //;
create procedure EnumProce ()
begin
	declare enumSQL0 enum('中文字符','123456','ABCabc','!@#$%^&*','2010-10-10');
    select  123456 into enumSQL0;
	insert into z1case values(enumSQL0,enumSQL0);
end;
//
delimiter ;//
--error 1265
call EnumProce;
SELECT * FROM z1case;
DELETE FROM z1case;
DROP PROCEDURE EnumProce;


delimiter //;
create procedure EnumProce ()
begin
declare enumSQL0 enum('中文字符','12345,6','ABCabc','!@#$%^&*','2010-10-10');
select  '中文字符' into enumSQL0;
insert into z1case values(enumSQL0,enumSQL0);
end;
//
delimiter ;//

--error 1305
call SetProce;
SELECT * FROM z1case;
DELETE FROM z1case;
DROP PROCEDURE EnumProce;


delimiter //;
create procedure SetProce ()
begin
declare enumSQL0 enum('中文字符','123456','ABCabc','!@#$%^&*','2010-10-10');
select  '123456,123456' into enumSQL0;
insert into z1case values(enumSQL0,enumSQL0);
end;
//
delimiter ;//
--error 1265
call SetProce;
SELECT * FROM z1case;
DELETE FROM z1case;
DROP PROCEDURE SetProce;

--echo insert
delimiter //;
create procedure SetProce ()
begin
declare enumSQL0 enum('中文字符','123456','ABCabc','!@#$%^&*','2010-10-10');
select  '2010-10-10' into enumSQL0;
insert into z1case values(enumSQL0,enumSQL0);
end;
//
delimiter ;//
--error 1265
call SetProce;
SELECT * FROM z1case;
DELETE FROM z1case;
DROP PROCEDURE SetProce;

--echo update
delimiter //;
create procedure SetProce ()
begin
declare enumSQL0 varchar(100);
set enumSQL0:='Abc abc  ';
update z0case  set z0_test0=enumSQL0,z0_test1=enumSQL0 limit 1;
end;
//
delimiter ;//

--error 1265
call SetProce;
SELECT * FROM z1case;
DELETE FROM z1case;
DROP PROCEDURE SetProce;


--echo enum 运算
delimiter //;
create procedure SetProce ()
begin
declare enumSQL0 enum('中文字符','123456','ABCabc','!@#$%^&*','2010-10-10');
select  '123456' into enumSQL0;
insert into z1case values(enumSQL0,enumSQL0+1);
end;
//
delimiter ;//

call SetProce;
SELECT * FROM z1case;
DELETE FROM z1case;
DROP PROCEDURE SetProce;

--echo date
delimiter //;
create procedure SetProce ()
begin
declare enumSQL0 enum('中文字符','123456','ABCabc','!@#$%^&*','2010-10-10');
declare enumSQL1 date;
set enumSQL1:='2020-10-10';
select  'ABCabc' into enumSQL0;
insert into z1case values(enumSQL0,enumSQL0+enumSQL1);
insert into z1case values(enumSQL0,enumSQL0-enumSQL1);
end;
//
delimiter ;//

--error 1054
call SetProce;
SELECT * FROM z1case;
DELETE FROM z1case;
DROP PROCEDURE SetProce;

--echo char、varcahr
delimiter //;
create procedure SetProce ()
begin
declare enumSQL0 enum('中文字符','123456','ABCabc','!@#$%^&*','2010-10-10');
declare enumSQL1 char(100);
declare enumSQL2 varchar(100);
set enumSQL1:='ABCabc';
select  'ABCabc' into enumSQL0;
select  'ABCabc' into enumSQL1;
select  'ABCabc' into enumSQL2;
insert into z1case values(enumSQL0,enumSQL0+enumSQL1);
insert into z1case values(enumSQL0,enumSQL0-enumSQL2);
end;
//
delimiter ;//

--error 1054
call SetProce;
SELECT * FROM z1case;
DELETE FROM z1case;
DROP PROCEDURE SetProce;


--echo  函数嵌套
delimiter //;
create procedure SetProce ()
begin
declare setSQL0 enum('中文字符','123456','ABCabc','!@#$%^&*','2020-10-10');
select  'ABCabc' into setSQL0;
insert into z1case values(setSQL0,concat(setSQL0, '%Y/%M/%d'));
insert into z1case values(upper(setSQL0),upper(setSQL0));
insert into z1case values(lower(setSQL0),lower(setSQL0));
insert into z1case values(setSQL0,length(setSQL0));
insert into z1case values(setSQL0,SUBSTRING(setSQL0,2,5));
insert into z1case values(TRIM(setSQL0),TRIM(setSQL0));
end;
//
delimiter ;//

call SetProce;
SELECT * FROM z1case;
DELETE FROM z1case;
DROP PROCEDURE SetProce;

delimiter //;
create procedure SetProce ()
begin
declare setSQL0 enum('中文字符','123456','ABCabc','!@#$%^&*','2010-10-10');
select  '2020-10-10' into setSQL0;
insert into z1case values(setSQL0,DATE_FORMAT(setSQL0, '%Y/%M/%d'));
end;
//
delimiter ;//

--error 1054
call SetProce;
SELECT * FROM z1case;
DELETE FROM z1case;
DROP PROCEDURE SetProce;

--echo 类型转换
--echo char、BINARY
delimiter //;
create procedure SetProce ()
begin
declare setSQL0 enum('中文字符','123456','ABCabc','!@#$%^&*','2010-10-10');
select  'ABCabc' into setSQL0;
insert into z1case values(cast(setSQL0 as char),cast(setSQL0 as char));
insert into z1case values(cast(setSQL0 as BINARY),cast(setSQL0 as BINARY));
end;
//
delimiter ;//

call SetProce;
SELECT * FROM z1case;
DELETE FROM z1case;
DROP PROCEDURE SetProce;


--echo DECIMAL
delimiter //;
create procedure SetProce ()
begin
declare setSQL0 enum('中文字符','123456','ABCabc','!@#$%^&*','2010-10-10');	
select  '123456' into setSQL0;  
insert into z1case values(cast(setSQL0 as DECIMAL),cast(setSQL0 as DECIMAL));
end;
//
delimiter ;//
call SetProce;
SELECT * FROM z1case;
DELETE FROM z1case;
DROP PROCEDURE SetProce;

--echo date
delimiter //;
create procedure SetProce ()
begin
declare setSQL0 enum('中文字符','123456','ABCabc','!@#$%^&*','2020-10-10');
select  '2020-10-10' into setSQL0;
insert into z1case values(cast(setSQL0 as date),cast(setSQL0 as date));
end;
//
delimiter ;//

call SetProce;
SELECT * FROM z1case;
DELETE FROM z1case;
DROP PROCEDURE SetProce;


--echo 与各字符类型比较
delimiter //;
create procedure SetProce()
begin
declare setSQL0 enum('中文字符','123456','ABCabc','!@#$%^&*','2020-10-10');
declare setSQL1  char(100);
select  'ABCabc' into setSQL0;
select  'ABCab' into setSQL1;
insert into z1case select z0_test0, z0_test0 from z0case where setSQL0>setSQL1;
end;
//
delimiter ;//

call SetProce;
SELECT * FROM z1case;
DELETE FROM z1case;
DROP PROCEDURE SetProce;

delimiter //;
create procedure SetProce()
begin
declare setSQL0 enum('中文字符','123456','ABCabc','!@#$%^&*','2020-10-10');
declare setSQL1  varchar(100); 
select  'ABCabc' into setSQL0;
select  'ABCab' into setSQL1;
insert into z1case select z0_test0, z0_test0 from z0case where setSQL0>setSQL1;
end;
//
delimiter ;//

call SetProce;
SELECT * FROM z1case;
DELETE FROM z1case;
DROP PROCEDURE SetProce;
