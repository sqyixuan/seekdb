
#owner: zuojiao.hzj
#owner group:SQL-SQL2
#description: enum类型
#tags: 参数个数,参数类型,异常值
#author:wb-zry774348


--disable_warnings
drop database  IF EXISTS  zrytest;
--enable_warnings
create database zrytest  character set utf8;
use zrytest;

--echo #通过性测试
create table z0case(z_test varchar(100));
insert into z0case values('ABCdefg');
drop table z0case;
--echo #obmysql-set/enum-1-1-1 成员个数
--error 1064
create table z0case(z_test enum());
create table z0case(z_test enum(''));
--error 1064
create table z0case(z_test enum(null));
drop table z0case;

--echo #创建字节大于8个字节的字段
create table z0case(z_test enum('中文123213asd12ASDSA131121321321esdasc1大声大声道232132132132131123213asd12ASDSA131121321321esdasc1大声大声道23213213213213112321321sadsadasd12321321321321321字符'));

drop table z0case;


--echo obmysql-set/enum-2-1 参数类型
--echo #字符类型
create table z0case(z_test1 enum('123183','中文字符','ABCabc','!@#$%^&*'),z_test0 enum('123183','中文字符','ABCabc','!@#$%^&*'));
drop table z0case;
--echo #数字类型
--error 1064
create table z0case(z_test0 char(200),z_test1 enum('123183',123.123,12321321));
--echo 日期格式
create table z0case(z_test0 char(200),z_test1 enum('2020-10-10 10:10:10','2020-10-10','10:10:10'));
drop table z0case;


--echo obmysql-set/enum-2-1-2 #异常值
--echo #重复的数据
--error 1291
create table z0case(z_test1 enum('中文字符','中文字符','ABCabc','!@#$%^&*'));

create table z0case(z_test1 enum('中文字符',' 中文字符','ABCabc','!@#$%^&*'));
drop table z0case;
--error 1291
create table z0case(z_test1 enum('中文字符','中文字符 ','ABCabc','!@#$%^&*'));
create table z0case(z_test1 enum('中文字符','中文 字符','ABCabc','!@#$%^&*'));
drop table z0case;
create table z0case(z_test1 enum('123','123.00','ABCabc','!@#$%^&*'));
drop table z0case;
create table z0case(z_test1 enum('123','00123','ABCabc','!@#$%^&*'));
drop table z0case;
--ECHO NULL
--ERROR 1064
create table z0case(z_test1 enum(NULL,'ABCabc','!@#$%^&*'));

create table z0case(z_test1 enum('','ABCabc','!@#$%^&*'));
--echo 空格
drop table z0case;
--error 1291
create table z0case(z_test1 enum(' ','      ','ABCabc','!@#$%^&*'));
--error 1291
create table z0case(z_test1 enum('','      ','ABCabc','!@#$%^&*'));
--echo 区分大小写
--error 1291
create table z0case(z_test1 enum('ABC','abc','ABCabc','!@#$%^&*'));
--error 1291
create table z0case(z_test1 enum('中文ABC123','中文abc123','ABCabc','!@#$%^&*'));

--echo #包含逗号
create table z0case(z_test1 enum('!@#$%,^&*','中文ab,c123','ABCa,bc','!@#$%^&*',','));
drop table z0case;
create table z0case(z_test1 enum('!@#$%。^&*','中文abc123','ABCabc','!@#$%^&*'));
drop table z0case;



connection default;
--disable_warnings
--error 0,600
--enable_warnings





