# owner: zhenling.zzg
# owner group: SQL1
# tags: optimizer

--disable_warnings
--disable_query_log
drop database link if exists my_link1;
eval create database link my_link1 connect to admin database test identified by 'admin'  host '$OBMYSQL_MS0:$OBMYSQL_PORT';

drop database link if exists my_link2;
eval create database link my_link2 connect to admin database test identified by 'admin'  host '$OBMYSQL_MS0:$OBMYSQL_PORT';
--enable_query_log

drop sequence if exists seq1;
drop sequence if exists seq2;
drop sequence if exists seq3;

create sequence seq1;
create sequence seq2;
create sequence seq3;

drop table if exists t1;
drop table if exists t2;

create table t1(c1 int);
insert into t1 values(1);
create table t2(c1 int);
insert into t2 values(1);
--enable_warnings

--disable_result_log

select seq1.nextval as local_nextval from t1;


select seq1.currval as local_currval from t1;


select seq1.nextval@my_link1 as link1_nextval from t1;


select seq1.currval@my_link1 as link1_currval from t1;


select seq1.currval as local_currval from t1;


select seq1.nextval@my_link2 as link2_nextval from t1;


select seq1.currval@my_link2 as link2_currval from t1;


select seq1.currval@my_link1 as link1_currval from t1;


select seq1.currval as local_currval from t1;


select seq1.nextval@my_link1 as link1_nextval, seq1.nextval@my_link2 as link2_nextval from t1;


select seq1.currval@my_link2 as link2_currval from t1;


select seq1.currval@my_link1 as link1_currval from t1;


select seq1.currval as local_currval from t1;


select seq1.nextval@my_link1 as link1_nextval,seq1.nextval@my_link1 as link1_nextval from t1;


select seq1.currval@my_link2 as link2_currval from t1;


select seq1.currval@my_link1 as link1_currval from t1;


select seq1.currval as local_currval from t1;


select seq1.nextval@my_link1 as link1_nextval,seq1.nextval as local_nextval from t1;


select seq1.currval@my_link2 as link2_currval from t1;


select seq1.currval@my_link1 as link1_currval from t1;


select seq1.currval as local_currval from t1;


select seq1.nextval@my_link1 as link1_nextval, seq1.nextval@my_link2 as link2_nextval,seq1.nextval as local_nextval from t1;


select seq1.currval@my_link2 as link2_currval from t1;


select seq1.currval@my_link1 as link1_currval from t1;


select seq1.currval as local_currval from t1;


select seq1.nextval@my_link1 as link1_nextval, seq1.nextval@my_link1 as link1_nextval,seq1.nextval as local_nextval from t1;


select seq1.currval@my_link2 as link2_currval from t1;


select seq1.currval@my_link1 as link1_currval from t1;


select seq1.currval as local_currval from t1;


select seq1.nextval@my_link1 as link1_nextval from t1@my_link2;


select seq1.currval@my_link2 as link2_currval from t1;


select seq1.currval@my_link1 as link1_currval from t1;


select seq1.currval as local_currval from t1;


select seq1.nextval@my_link1 as link1_nextval from t1@my_link1;


select seq1.currval@my_link2 as link2_currval from t1;


select seq1.currval@my_link1 as link1_currval from t1;


select seq1.currval as local_currval from t1;

--error 1235
insert into t1@my_link2 select eq1.nextval@my_link1 from t1;

--error 1235
insert into t1@my_link2 select eq1.nextval@my_link1 from t1@my_link1;

--error 1235
insert into t1@my_link2  select seq1.nextval@my_link2 from t1@my_link1;


select seq1.currval@my_link2 as link2_currval from t1;


select seq1.nextval@my_link1 as link1_nextval from t2@my_link1;

select seq1.currval@my_link1 as link1_currval from t2@my_link1;


select seq1.nextval@my_link1 as link1_nextval from t2;

select seq1.currval@my_link1 as link1_currval from t2@my_link1;


select seq1.nextval@my_link1 as link1_nextval from t2@my_link1;

select seq1.currval@my_link1 as link1_currval from t2;

drop database link if exists my_link1;
--error 5835
select seq1.nextval@my_link1 as link1_nextval from t2;

--disable_query_log
eval create database link my_link1 connect to admin database test identified by 'admin'  host '$OBMYSQL_MS0:$OBMYSQL_PORT';
--enable_query_log
select seq1.nextval@my_link1 as link1_nextval from t2;

--enable_result_log
