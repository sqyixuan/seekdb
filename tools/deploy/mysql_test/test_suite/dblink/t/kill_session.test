# owner: dachuan.sdc
# owner group: SQL2
#description: kill session with dblink
# tags: dblink

--disable_warnings
--disable_query_log
drop database link if exists my_link1;
eval create database link my_link1 connect to admin database test identified by 'admin'  host '$OBMYSQL_MS0:$OBMYSQL_PORT';

--enable_query_log
drop table if exists t1;
create table t1(c1 int, c2 char(200));
--enable_warnings

insert into t1 values(0, 'abcdef一二三四五六七八九十abcdef一二三四五六七八九十abcdef一二三四五六七八九十abcdef一二三四五六七八九十abcdef一二三四五六七八九十');

connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn_sys,$OBMYSQL_MS0,root@sys,,*NO-ONE*,$OBMYSQL_PORT);

--echo test wait at mysql_real_query
connection conn1;
set ob_query_timeout = 1000000000;
send select sleep(1000) from t1@my_link1;

connection conn_sys;
let $ssid = query_get_value(select id from oceanbase.__all_virtual_processlist where info like 'select sleep(1000) from t1@%', id, 1);
--disable_query_log
eval kill $ssid;
--enable_query_log

connection conn1;
--error 2013,5066
reap;

--echo test wait at mysql_fetch_row
connection default;
insert into t1 select * from t1;
insert into t1 select * from t1;
insert into t1 select * from t1;
insert into t1 select * from t1;
insert into t1 select * from t1;
insert into t1 select * from t1;
insert into t1 select * from t1;
insert into t1 select * from t1;
insert into t1 select * from t1;
insert into t1 select * from t1;
insert into t1 select * from t1;
insert into t1 select * from t1;
insert into t1 values(1000, 'a');

connect (conn2,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
send select sleep(c1), c2 from t1@my_link1;

connection conn_sys;
let $ssid = query_get_value(select id from oceanbase.__all_virtual_processlist where info like 'select sleep(c1)_ c2 from t1@%', id, 1);
--disable_query_log
eval kill $ssid;
--enable_query_log

connection conn2;
--error 2013,5066
reap;

connection default;
drop table t1;