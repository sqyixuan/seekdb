#owner:zhuhuashi.zhs
#owner group: sql1
# tags: optimizer, global_index
--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--result_format 4
--enable_info
--enable_sorted_result


--disable_warnings
drop database if exists das_ref_lookup_task;
--enable_warnings
create database das_ref_lookup_task;
use das_ref_lookup_task;
sleep 5;


--disable_warnings
drop table if exists t1;
drop table if exists t2;
--enable_warnings

create table t1(a int primary key, b int, c int);
create table t2(a int primary key, b int, c int);

let $startup_mode =query_get_value(show parameters where name = 'ob_startup_mode', value, 1);
if($startup_mode=="NORMAL") {
## shared nothing  
  create index i1 on t2(b) global partition by hash(b) partitions 2000;
} 
if($startup_mode=="shared_storage") {
## shared storage create index is slower, so reduce partition count to avoid case timeout
  create index i1 on t2(b) global partition by hash(b) partitions 200;
}
--disable_info
--disable_query_log
--let $count = 1
while($count <= 100)
{
  --let $stmt=insert into t1(a, b, c) values ($count, $count, $count)
  eval $stmt;
  inc $count;
}
--enable_query_log

--explain_protocol 3

connect (conn_admin, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection default;
select /*+ query_timeout(100000000) leading(t1 t2) use_nl(t1 t2) index(t2 i1)*/ count(*) from t1,t2 where t1.a > t2.b;

drop table t1;
drop table t2;
drop database if exists das_ref_lookup_task;

