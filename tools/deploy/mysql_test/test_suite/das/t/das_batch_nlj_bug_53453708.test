--disable_warnings
drop table if exists pdm_productday;
drop table if exists pdm_product;
--enable_warnings


CREATE TABLE pdm_productday (
  id INT AUTO_INCREMENT PRIMARY KEY,
  product_code VARCHAR(50) NOT NULL,
  nav_date DATE NOT NULL,
  amount DECIMAL(10, 2) NOT NULL,
  INDEX (product_code, nav_date)
);
INSERT INTO pdm_productday (product_code, nav_date, amount) VALUES ('P001', '2021-06-01', 1000.00);
INSERT INTO pdm_productday (product_code, nav_date, amount) VALUES ('P001', '2021-06-02', 1500.50);
INSERT INTO pdm_productday (product_code, nav_date, amount) VALUES ('P001', '2021-06-03', 1200.00);
INSERT INTO pdm_productday (product_code, nav_date, amount) VALUES ('P002', '2021-06-01', 3000.00);
INSERT INTO pdm_productday (product_code, nav_date, amount) VALUES ('P002', '2021-06-02', 2500.00);
INSERT INTO pdm_productday (product_code, nav_date, amount) VALUES ('P002', '2021-06-03', 3200.50);
INSERT INTO pdm_productday (product_code, nav_date, amount) VALUES ('P003', '2021-06-01', 1800.00);
INSERT INTO pdm_productday (product_code, nav_date, amount) VALUES ('P003', '2021-06-02', 2300.00);

CREATE TABLE pdm_product (
  product_code VARCHAR(50) NOT NULL,
  product_name VARCHAR(255) NOT NULL,
  PRIMARY KEY (product_code),
  UNIQUE INDEX (product_name)
);

insert into pdm_product values('P001', 'aaaaaa');
insert into pdm_product values('P002', 'bbbbbb');

explain select /*+use_nl(t1 t)*/ t1.*, t.* from pdm_product t1 join (SELECT    product_code,   nav_date,   amount,   ROW_NUMBER() OVER (PARTITION BY product_code ORDER BY nav_date DESC) AS row_num FROM  pdm_productday) t where t.product_code=t1.product_code;
select /*+use_nl(t1 t)*/ t1.*, t.* from pdm_product t1 join (SELECT    product_code,   nav_date,   amount,   ROW_NUMBER() OVER (PARTITION BY product_code ORDER BY nav_date DESC) AS row_num FROM  pdm_productday) t where t.product_code=t1.product_code;

explain select /*+use_nl(t1 t)*/ t1.*, t.* from pdm_product t1 join (SELECT    product_code,   nav_date,   amount,   ROW_NUMBER() OVER (PARTITION BY product_code ORDER BY nav_date asc) AS row_num FROM  pdm_productday) t where t.product_code=t1.product_code;
select /*+use_nl(t1 t)*/ t1.*, t.* from pdm_product t1 join (SELECT    product_code,   nav_date,   amount,   ROW_NUMBER() OVER (PARTITION BY product_code ORDER BY nav_date asc) AS row_num FROM  pdm_productday) t where t.product_code=t1.product_code;

drop table pdm_productday;
drop table pdm_product;