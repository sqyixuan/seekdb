--enable_info

--explain_protocol 3
SELECT DISTINCT OUTR . `col_date_key` AS X FROM C AS OUTR2 LEFT JOIN C AS OUTR ON ( OUTR2 . `col_datetime` <= OUTR . `col_date` ) WHERE OUTR . `pk` IN ( SELECT  INNR . `pk` AS Y FROM BB AS INNR WHERE OUTR . `col_datetime` <> '2004-12-24' ORDER BY INNR . `col_varchar_10_key` ) AND OUTR . `col_datetime` BETWEEN '2000-02-26' AND '2008-08-24' OR OUTR . `col_date` IS NULL  ORDER BY OUTR . `col_int` , OUTR . `pk`;

--disable_info
--disable_warnings
--disable_query_log
DROP TABLE IF EXISTS `bb`;
DROP TABLE IF EXISTS `c`;

create table batch_nlj_t_13(c1 int, c2 int);
create table batch_nlj_t_14(c1 int, c2 int);
create index batch_nlj_index_1 on batch_nlj_t_14(c1);
insert into batch_nlj_t_13 values(1, 1),(1, 2),(1, 3),(2, 3),(2, 4);
insert into batch_nlj_t_14 values(1, 1),(2, 2),(2, 2);

select /*+no_rewrite leading(batch_nlj_t_13, batch_nlj_t_14) use_nl(batch_nlj_t_13, batch_nlj_t_14) index(batch_nlj_t_14, batch_nlj_index_1) */ * from batch_nlj_t_13 where exists(select 1 from batch_nlj_t_14 where batch_nlj_t_13.c1 = batch_nlj_t_14.c1) order by batch_nlj_t_13.c1;

drop table batch_nlj_t_13;
drop table batch_nlj_t_14;

drop database if exists das_batch_spf;
--enable_info
--enable_query_log
--enable_warnings

connection conn_admin;
alter system set_tp tp_no = 311, error_code = 2, frequency = 0;
connection default;
