--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner:zhuhuashi.zhs
#owner group: sql1
# tags: das, global_index

--result_format 4
--enable_info
--enable_sorted_result

--disable_warnings
--disable_query_log
connect (conn_admin, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn_admin;
alter system set_tp tp_no = 311, error_code = 2, frequency = 1;

connection default;
drop database if exists das_batch_spf;
create database das_batch_spf;
use das_batch_spf;
sleep 5;
DROP TABLE IF EXISTS `bb`;
DROP TABLE IF EXISTS `c`;
drop table if exists batch_nlj_t_13;
drop table if exists batch_nlj_t_14;
--enable_query_log
--enable_warnings

CREATE TABLE `bb` (
  `col_datetime_key` datetime DEFAULT NULL,
  `col_date` date DEFAULT NULL,
  `col_date_key` date DEFAULT NULL,
  `col_int` int(11) DEFAULT NULL,
  `col_datetime` datetime DEFAULT NULL,
  `col_varchar_20` varchar(20) DEFAULT NULL,
  `col_varchar_10_key` varchar(10) DEFAULT NULL,
  `pk` int(11) NOT NULL,
  `col_varchar_10` varchar(10) DEFAULT NULL,
  `col_varchar_20_key` varchar(20) DEFAULT NULL,
  `col_int_key` int(11) DEFAULT NULL,
  PRIMARY KEY (`pk`),
  KEY `idx9` (`pk`, `col_datetime_key`) ,
  KEY `idx7` (`pk`, `col_date_key`) ,
  KEY `idx3` (`pk`, `col_varchar_10_key`) ,
  KEY `idx5` (`pk`, `col_varchar_20_key`) ,
  KEY `idx1` (`pk`, `col_int_key`)
);

CREATE TABLE `c` (
  `col_varchar_20_key` varchar(20) DEFAULT NULL,
  `col_varchar_10` varchar(10) DEFAULT NULL,
  `col_varchar_20` varchar(20) DEFAULT NULL,
  `col_date_key` date DEFAULT NULL,
  `col_datetime` datetime DEFAULT NULL,
  `pk` int(11) NOT NULL,
  `col_int` int(11) DEFAULT NULL,
  `col_datetime_key` datetime DEFAULT NULL,
  `col_varchar_10_key` varchar(10) DEFAULT NULL,
  `col_date` date DEFAULT NULL,
  `col_int_key` int(11) DEFAULT NULL,
  PRIMARY KEY (`pk`),
  KEY `idx5` (`pk`, `col_varchar_20_key`) ,
  KEY `idx7` (`pk`, `col_date_key`) ,
  KEY `idx9` (`pk`, `col_datetime_key`) ,
  KEY `idx3` (`pk`, `col_varchar_10_key`) ,
  KEY `idx1` (`pk`, `col_int_key`)
);

--disable_info
--disable_query_log
