#owner:zhuhuashi.zhs
#owner group: sql1
# tags: optimizer, global_index
--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
connect (conn_admin, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn_admin;
alter system set_tp tp_no = 367, error_code = 20, frequency = 1;
connection default;
--enable_query_log

--result_format 4
--enable_info
--enable_sorted_result

--disable_warnings
--disable_query_log
drop database if exists das_multi_batch_nlj;
create database das_multi_batch_nlj;
use das_multi_batch_nlj;
sleep 5;
drop table if exists t1;
drop table if exists t2;
drop table if exists t3;
drop table if exists t4;
--enable_query_log
--enable_warnings

create table t1 (a int, b int, c int, primary key (a, b));
create table t2 (a int, b int, c int, primary key (a, b));
create table t3 (a int, b int , c int, primary key (b, c));

--disable_info
--disable_query_log
--let $count = 1
--let $count1 = 1
while($count1 <= 101)
{
  --let $count2 = 1
  while($count2 <= 10) {
    --let $stmt=insert into t1(a, b, c) values ($count1, $count, $count1)
    eval $stmt;
    inc $count2;
    inc $count;
  }
  inc $count1;
}
--let $count = 1
--let $count1 = 1
while($count1 <= 101) {
  --let $count2 = 1
  while($count2 <= 10) {
    --let $stmt=insert into t2(a, b, c) values ($count1, $count, $count)
    eval $stmt;
    inc $count2;
    inc $count;
  }
  inc $count1;
}
--let $count = 1
--let $count1 = 1
while($count1 <= 101) {
  --let $count2 = 1
  while($count2 <= 10) {
    --let $stmt=insert into t3(a, b, c) values ($count, $count, $count1)
    eval $stmt;
    inc $count2;
    inc $count;
  }
  inc $count1;
}
--enable_query_log
--enable_info

--explain_protocol 0
select (select count(*) from t1) as 't1', (select count(*) from t2) as 't2', (select count(*) from t3) as 't3';
--explain_protocol 3
select /*+no_rewrite leading(t1 v) use_nl(t1 v)*/ count(*), sum(t1.a+t1.b+t1.c+v.a+v.b+v.c) from t1, (select /*+no_rewrite leading(t2 t3) use_nl(t2 t3)*/ t2.a, t2.b, t3.c from t2, t3 where t2.c = t3.b) v where t1.a = v.c and t1.c = v.a;
create table t4(pk int primary key, c1 int, c2 int) partition by hash(pk) partitions 2;
insert into t4 values(1,1,1);
insert into t4 values(2,2,1);

create index i1 on t4(c1) global;
create index i2 on t4(c2) global;

select /*+no_rewrite leading(a b) use_nl(b) index(a primary)*/  a.pk, a.c1, b.c2 from t4 a left join (select /*+leading(b a) use_merge(a) index(a i2)*/ a.c2 from  t4 a left join t4 b on a.c1 = b.c2 and b.c2 > 3) b on a.c1 = b.c2 order by 1, 2, 3;

--disable_info
--disable_warnings
--disable_query_log
drop table if exists t1;
drop table if exists t2;
drop table if exists t3;
drop table if exists t4;
drop database if exists das_multi_batch_nlj;
--enable_info
--enable_query_log
--enable_warnings
--disable_query_log
connection conn_admin;
alter system set_tp tp_no = 367, error_code = 20, frequency = 0;
connection default;
--enable_query_log
