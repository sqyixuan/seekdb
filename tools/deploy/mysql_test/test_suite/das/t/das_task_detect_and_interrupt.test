# 异步、非分区、填结果
connection default;
--disable_warnings
drop table if exists t;
--enable_warnings
CREATE TABLE t(
  id INTEGER,
  k INTEGER DEFAULT '0' NOT NULL,
  c CHAR(120) DEFAULT 'xxxxxxxxx' NOT NULL,
  PRIMARY KEY (id)
);

--disable_info
--disable_query_log
--let $count = 1
while($count <= 10000)
{
  --let $stmt=insert into t(id) values ($count)
  eval $stmt;
  inc $count;
}
--enable_query_log
--enable_info

connection conn_admin;
alter system set_tp tp_no = 301, error_code = 1, frequency = 1;
alter system set_tp tp_no = 317, error_code = 1000, frequency = 1;
alter system set_tp tp_no = 318, error_code = 0, frequency = 1;

connection conn_follower;
set ob_query_timeout = 2000000;

explain select /*+use_das(t), opt_param('rowsets_enabled', 'FALSE') */ * from t;
