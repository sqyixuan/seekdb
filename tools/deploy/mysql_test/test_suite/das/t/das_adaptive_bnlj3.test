#owner:zhuhuashi.zhs
#owner group: IMF
# tags: optimizer, das

--disable_abort_on_error
--disable_warnings
drop table if exists t1,t2,t3,t4,t5;
drop procedure if exists gen_data;
--enable_warnings

connect (conn_admin, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn_admin;
alter system set _rowsets_max_rows = 2 tenant=sys;
alter system set _rowsets_max_rows = 2 tenant=all_user;
alter system set _rowsets_max_rows = 2 tenant=all_meta;
alter system set_tp tp_no = 311, error_code = 4, frequency = 1;
connection default;
--enable_sorted_result

## 生成数据的PL
delimiter /;
create procedure gen_data (in row_cnt int)
begin
  declare num int;
  set num = 0;
  while num <= row_cnt do
    insert into t1 values (num, num, num, num);
    insert into t2 values (num, num, num, num);
    insert into t3 values (num, num, num, num);
    insert into t4 values (num, num, num, num);
    insert into t5 values (num, num, num, num);
    set num =num +1;
  end while;
end ;
/

delimiter ;/

create table t1 (c1 int primary key, c2 int, c3 int, c4 int);
create table t2 (c1 int primary key, c2 int, c3 int, c4 int);
create table t3 (c1 int primary key, c2 int, c3 int, c4 int);
create table t4 (c1 int primary key, c2 int, c3 int, c4 int);
create table t5 (c1 int primary key, c2 int, c3 int, c4 int);

create index t1_ind_local on t1(c2) local;
create index t1_ind_global on t1(c3) global partition by hash(c3) partitions 3;

create index t2_ind_local on t2(c2) local;
create index t2_ind_global on t2(c3) global partition by hash(c3) partitions 3;

create index t3_ind_local on t3(c2) local;
create index t3_ind_global on t3(c3) global partition by hash(c3) partitions 3;

create index t4_ind_local on t4(c2) local;
create index t4_ind_global on t4(c3) global partition by hash(c3) partitions 3;

create index t5_ind_local on t5(c2) local;
create index t5_ind_global on t5(c3) global partition by hash(c3) partitions 3;

call gen_data(2000);
#--explain_protocol 2


--source das_skip_scan.inc

connection conn_admin;
alter system set _rowsets_max_rows = 10 tenant=sys;
alter system set _rowsets_max_rows = 10 tenant=all_user;
alter system set _rowsets_max_rows = 10 tenant=all_meta;
alter system set_tp tp_no = 311, error_code = 10, frequency = 1;
connection default;

--source das_skip_scan.inc

connection conn_admin;
alter system set _rowsets_max_rows = 30 tenant=sys;
alter system set _rowsets_max_rows = 30 tenant=all_user;
alter system set _rowsets_max_rows = 30 tenant=all_meta;
alter system set_tp tp_no = 311, error_code = 100, frequency = 1;
connection default;

--source das_skip_scan.inc

connection conn_admin;
alter system set _rowsets_max_rows = 100 tenant=sys;
alter system set _rowsets_max_rows = 100 tenant=all_user;
alter system set _rowsets_max_rows = 100 tenant=all_meta;
alter system set_tp tp_no = 311, error_code = 100, frequency = 1;
connection default;

--source das_skip_scan.inc

connection conn_admin;
alter system set _rowsets_max_rows = 1 tenant=sys;
alter system set _rowsets_max_rows = 1 tenant=all_user;
alter system set _rowsets_max_rows = 1 tenant=all_meta;
alter system set_tp tp_no = 311, error_code = 1, frequency = 1;
connection default;

--source das_skip_scan.inc

connection conn_admin;
alter system set _rowsets_max_rows = 2 tenant=sys;
alter system set _rowsets_max_rows = 2 tenant=all_user;
alter system set _rowsets_max_rows = 2 tenant=all_meta;
alter system set_tp tp_no = 311, error_code = 10, frequency = 1;
connection default;

--source das_skip_scan.inc

drop table t1, t2, t3, t4, t5;
create table t1 (c1 int primary key, c2 int, c3 int, c4 int) partition by hash(c1) partitions 3;
create table t2 (c1 int primary key, c2 int, c3 int, c4 int) partition by hash(c1) partitions 3;
create table t3 (c1 int primary key, c2 int, c3 int, c4 int) partition by hash(c1) partitions 3;
create table t4 (c1 int primary key, c2 int, c3 int, c4 int) partition by hash(c1) partitions 3;
create table t5 (c1 int primary key, c2 int, c3 int, c4 int) partition by hash(c1) partitions 3;

create index t1_ind_local on t1(c2) local;
create index t1_ind_global on t1(c3) global partition by hash(c3) partitions 3;

create index t2_ind_local on t2(c2) local;
create index t2_ind_global on t2(c3) global partition by hash(c3) partitions 3;

create index t3_ind_local on t3(c2) local;
create index t3_ind_global on t3(c3) global partition by hash(c3) partitions 3;

create index t4_ind_local on t4(c2) local;
create index t4_ind_global on t4(c3) global partition by hash(c3) partitions 3;

create index t5_ind_local on t5(c2) local;
create index t5_ind_global on t5(c3) global partition by hash(c3) partitions 3;

call gen_data(2000);

connection conn_admin;
alter system set _rowsets_max_rows = 2 tenant=sys;
alter system set _rowsets_max_rows = 2 tenant=all_user;
alter system set _rowsets_max_rows = 2 tenant=all_meta;
alter system set_tp tp_no = 311, error_code = 2, frequency = 1;
connection default;

--source das_skip_scan.inc

connection conn_admin;
alter system set _rowsets_max_rows = 256 tenant=sys;
alter system set _rowsets_max_rows = 256 tenant=all_user;
alter system set _rowsets_max_rows = 256 tenant=all_meta;
alter system set_tp tp_no = 311, error_code = 4, frequency = 0;
connection default;
--enable_abort_on_error

drop table t1, t2, t3, t4, t5;


