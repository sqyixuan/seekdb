#owner:zhuhuashi.zhs
#owner group: sql1
# tags: optimizer, global_index
--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
connect (conn_admin, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn_admin;
alter system set_tp tp_no = 367, error_code = 20, frequency = 1;
connection default;
--enable_query_log

--result_format 4
--enable_info
--enable_sorted_result

--disable_warnings
--disable_query_log
drop database if exists das_multi_batch_nlj;
create database das_multi_batch_nlj;
use das_multi_batch_nlj;
sleep 5;
drop table if exists t1;
drop table if exists t2;
drop table if exists t3;
DROP TABLE IF EXISTS `bb`;
DROP TABLE IF EXISTS `c`;
--enable_query_log
--enable_warnings

create table t1 (c1 int primary key, c2 int, c3 int, c4 int);
create table t2 (c1 int primary key, c2 int, c3 int, c4 int);
create table t3 (c1 int primary key, c2 int, c3 int, c4 int);
CREATE TABLE `bb` (
  `col_int` int(11) DEFAULT NULL,
  `col_varchar_10` varchar(10) DEFAULT NULL,
  `col_datetime` datetime DEFAULT NULL,
  `col_int_key` int(11) DEFAULT NULL,
  `col_date` date DEFAULT NULL,
  `col_date_key` date DEFAULT NULL,
  `col_varchar_20` varchar(20) DEFAULT NULL,
  `pk` int(11) NOT NULL,
  `col_varchar_10_key` varchar(10) DEFAULT NULL,
  `col_datetime_key` datetime DEFAULT NULL,
  `col_varchar_20_key` varchar(20) DEFAULT NULL,
  PRIMARY KEY (`pk`),
  KEY `idx1` (`pk`, `col_int_key`) LOCAL,
  KEY `idx7` (`pk`, `col_date_key`) LOCAL,
  KEY `idx3` (`pk`, `col_varchar_10_key`) LOCAL,
  KEY `idx9` (`pk`, `col_datetime_key`) LOCAL,
  KEY `idx5` (`pk`, `col_varchar_20_key`) LOCAL
);
CREATE TABLE `c` (
 `col_int` int(11) DEFAULT NULL,
 `col_varchar_10` varchar(10) DEFAULT NULL,
 `col_int_key` int(11) DEFAULT NULL,
 `col_varchar_10_key` varchar(10) DEFAULT NULL,
 `col_varchar_20_key` varchar(20) DEFAULT NULL,
 `pk` int(11) NOT NULL,
 `col_date` date DEFAULT NULL,
 `col_date_key` date DEFAULT NULL,
 `col_datetime` datetime DEFAULT NULL,
 `col_varchar_20` varchar(20) DEFAULT NULL,
 `col_datetime_key` datetime DEFAULT NULL,
 PRIMARY KEY (`pk`),
 KEY `idx1` (`pk`, `col_int_key`) LOCAL,
 KEY `idx3` (`pk`, `col_varchar_10_key`) LOCAL,
 KEY `idx5` (`pk`, `col_varchar_20_key`) LOCAL,
 KEY `idx7` (`pk`, `col_date_key`) LOCAL,
 KEY `idx9` (`pk`, `col_datetime_key`) LOCAL
);
--disable_info
--disable_query_log
--let $count = 1
while($count <= 2)
{
  --let $stmt=insert into t1(c1, c2, c3, c4) values ($count, $count, $count, $count)
  eval $stmt;
  inc $count;
}
--let $count = 1
while($count <= 10)
{
  --let $stmt=insert into t2(c1, c2, c3, c4) values ($count, $count, $count, $count)
  eval $stmt;
  --let $stmt=insert into t3(c1, c2, c3, c4) values ($count, $count, $count, $count)
  eval $stmt;
  inc $count;
}
