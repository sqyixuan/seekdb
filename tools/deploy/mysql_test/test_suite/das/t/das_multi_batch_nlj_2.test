INSERT INTO `c` VALUES (3,'efmdgqvnp',1831862272,'cefmdgqvn','HMZNT',1,'2007-03-12','2007-04-04','2000-09-18 10:52:03','he\'s','2001-11-19 20:36:52'),(NULL,'a',1,'ACXPU','KPAPT',2,'2005-08-26','2005-12-20','2007-08-06 23:25:03','the','2000-03-05 02:21:43');
--enable_query_log
--enable_info

--explain_protocol 0
select (select count(*) from t1) as 't1', (select count(*) from t2) as 't2', (select count(*) from t3) as 't3';
#
--explain_protocol 2
select /*+ no_rewrite leading(t1 v) use_nl(t1 v)*/ count(*), sum(t1.c1+t1.c2+t1.c3+v.c1+v.c2+v.c3) from t1 join (select /*+ no_rewrite leading(t2 t3) use_nl(t2 t3)*/ t2.c1, t2.c2, t3.c3 from t2 join t3 on t2.c2 = t3.c1) v on t1.c1 = v.c3 and t1.c3 = v.c1;
SET _NLJ_BATCHING_ENABLED=false;
select /*+ no_rewrite leading(t1 v) use_nl(t1 v)*/ count(*), sum(t1.c1+t1.c2+t1.c3+v.c1+v.c2+v.c3) from t1 join (select /*+ no_rewrite leading(t2 t3) use_nl(t2 t3)*/ t2.c1, t2.c2, t3.c3 from t2 join t3 on t2.c2 = t3.c1) v on t1.c1 = v.c3 and t1.c3 = v.c1;
SET _NLJ_BATCHING_ENABLED=true;

#
--explain_protocol 2
SELECT DISTINCT OUTR . `col_datetime_key` AS X FROM C AS OUTR WHERE OUTR . `pk` IN ( SELECT DISTINCT INNR . `pk` AS Y FROM BB AS INNR2 LEFT JOIN BB AS INNR ON ( INNR2 . `pk` > INNR . `col_int` ) WHERE INNR . `col_int` > INNR . `pk` AND INNR . `col_varchar_10_key` >= INNR . `col_varchar_10` ORDER BY INNR . `col_varchar_20_key` ) AND OUTR . `col_varchar_20_key` IS NOT NULL HAVING X <= '2005-12-22 09:11:57' ORDER BY OUTR . `col_int` , OUTR . `pk`;
SET _NLJ_BATCHING_ENABLED=false;
SELECT DISTINCT OUTR . `col_datetime_key` AS X FROM C AS OUTR WHERE OUTR . `pk` IN ( SELECT DISTINCT INNR . `pk` AS Y FROM BB AS INNR2 LEFT JOIN BB AS INNR ON ( INNR2 . `pk` > INNR . `col_int` ) WHERE INNR . `col_int` > INNR . `pk` AND INNR . `col_varchar_10_key` >= INNR . `col_varchar_10` ORDER BY INNR . `col_varchar_20_key` ) AND OUTR . `col_varchar_20_key` IS NOT NULL HAVING X <= '2005-12-22 09:11:57' ORDER BY OUTR . `col_int` , OUTR . `pk`;
SET _NLJ_BATCHING_ENABLED=true;

--explain_protocol 0
--disable_warnings
--disable_query_log
drop table if exists t1;
drop table if exists t2;
drop table if exists t3;
--enable_query_log
--enable_warnings

create table t1 (pk int not null, col_bigint bigint, col_varchar_20_index varchar(20), index idx10(col_varchar_20_index), primary key (pk));
create table t2 (pk int not null, col_bigint bigint, col_double double, col_varchar_20_index varchar(20), col_decimal_20_0 decimal(20,0), primary key (pk), index idx10(col_varchar_20_index));
create table t3 (pk int not null, col_double_unique_index double, col_double double, primary key (pk), index idx5(col_double_unique_index ));

--disable_info
--disable_query_log
