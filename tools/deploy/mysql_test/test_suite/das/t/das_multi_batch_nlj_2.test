#
--explain_protocol 2
select /*+ no_rewrite leading(t1 v) use_nl(t1 v)*/ t1.pk as "t1.pk", v.pk as "t2.pk" from t1, (select /*+ no_rewrite leading(t2 t3) use_nl(t2 t3)*/ t2.* from t2, t3 where t2.col_bigint < t3.col_double_unique_index and t3.col_double = t2.col_double) as v where t1.col_varchar_20_index <= v.col_varchar_20_index and t1.col_bigint >= v.col_decimal_20_0 order by 1,2;

--disable_info
--disable_warnings
--disable_query_log
