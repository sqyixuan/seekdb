#owner group: sql1
# tags: das,dml,nlj


--disable_warnings
drop table if exists t1,t2;
--enable_warnings

create table t1(a int, b int);
create table t2(a int, b int, c int, index i2(a, b));

insert into t1 values(1, 1), (2, 2), (3, 3), (4, 4);
insert into t2 select 1, 10, 100 from table(generator(1500)) t;
insert into t2 select 2, 20, 200 from table(generator(1500)) t;
insert into t2 select 3, 30, 300 from table(generator(1500)) t;
insert into t2 select 4, 40, 400 from table(generator(1500)) t;

explain select /*+use_nl(t1 t)*/ * from t1 left join (select /*+index(t2 i2)*/ a, b, c, sum(c) from t2 where b>0 and b <100 and c in (100, 400) group by a) t on t1.a=t.a;

select /*+use_nl(t1 t)*/ * from t1 left join (select /*+index(t2 i2)*/ a, b, c, sum(c) from t2 where b>0 and b <100 and c in (100, 400) group by a) t on t1.a=t.a;

drop table t2;
drop table t1;