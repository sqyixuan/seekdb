--disable_warnings
drop table if exists t1,t2,t3, pt1, pt2,pt3,pt4,pt5,pt6,pt7,pt8,pt9,pkey1,pkey2,pkey3,pkey4,pr1,pr2,pr3,pr4,prc1,prc2,prc3,prc4,sp1,sp2,sp3,t_r4_int,t_r4_date;
--enable_warnings

connection conn_admin;
alter system set _enable_partition_level_retry=False;
alter system set_tp tp_no = 303, error_code = 0, frequency = 1;
connection default;
