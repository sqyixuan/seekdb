#owner:zhuhuashi.zhs
#owner group: sql1
# tags: optimizer, global_index
--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
connect (conn_admin, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn_admin;
connection default;
--enable_query_log

--result_format 4
--enable_info
--enable_sorted_result

--disable_warnings
--disable_query_log
drop database if exists das_group_rescan;
create database das_group_rescan;
use das_group_rescan;
sleep 5;
drop table if exists t1;
drop table if exists t2;
drop table if exists t3;
create table t1 (a int primary key, b int, c int) partition by hash(a) partitions 10;
create table t2 (a int primary key, b int, c int) partition by hash(a) partitions 10;
create index i2 on t2(b) local;
create table t3 (a int primary key, b int, c int) partition by hash(a) partitions 10;
create index i3 on t3(b) local;
--enable_query_log
--enable_warnings

--echo case 1) no more than 10 partitions without dynamic partition pruning => das group rescan should be true
--explain_protocol 1
select /*+ use_das(t1), use_das(t2), index(t2 i2), use_nl(t1 t2), leading(t1 t2) */ count(1) from t1 join t2 where t1.b = t2.b;
select /*+ no_rewrite, use_das(t1), use_nl(t1 tt), leading(t1 tt) */ count(1) from t1 join (select /*+ use_das(t2), index(t2 i2) */ * from t2) as tt where t1.b = tt.b;
select /*+ no_rewrite, use_das(t1), use_nl(t1 tt), leading(t1 tt) */ count(1) from t1 join (select /*+ use_das(t2), index(t2 i2) */ * from t2 union all select /*+ use_das(t3), index(t3 i3) */ * from t3) as tt where t1.b = tt.b;

--disable_warnings
--disable_query_log
drop table if exists t1;
drop table if exists t2;
drop table if exists t3;
create table t1 (a int primary key, b int, c int) partition by hash(a) partitions 11;
create table t2 (a int primary key, b int, c int) partition by hash(a) partitions 11;
create index i2 on t2(b) local;
create table t3 (a int primary key, b int, c int) partition by hash(a) partitions 11;
create index i3 on t3(b) local;
--enable_query_log
--enable_warnings

--echo case 2) more than 10 partitions without dynamic partition pruning => das group rescan should be false
select /*+ use_das(t1), use_das(t2), index(t2 i2), use_nl(t1 t2), leading(t1 t2) */ count(1) from t1 join t2 where t1.b = t2.b;
select /*+ no_rewrite, use_das(t1), use_nl(t1 tt), leading(t1 tt) */ count(1) from t1 join (select /*+ use_das(t2), index(t2 i2) */ * from t2) as tt where t1.b = tt.b;
select /*+ no_rewrite, use_das(t1), use_nl(t1 tt), leading(t1 tt) */ count(1) from t1 join (select /*+ use_das(t2), index(t2 i2) */ * from t2 union all select /*+ use_das(t3), index(t3 i3) */ * from t3) as tt where t1.b = tt.b;

--echo case 3) with dynamic partition pruning => das group rescan should be true
select /*+ use_das(t1), use_das(t2), use_nl(t1 t2), leading(t1 t2) */ count(1) from t1 join t2 where t1.a = t2.a;
select /*+ no_rewrite, use_das(t1), use_nl(t1 tt), leading(t1 tt) */ count(1) from t1 join (select /*+ use_das(t2) */ * from t2) as tt where t1.a = tt.a;
select /*+ no_rewrite, use_das(t1), use_nl(t1 tt), leading(t1 tt) */ count(1) from t1 join (select /*+ use_das(t2) */ * from t2 union all select /*+ use_das(t3) */ * from t3) as tt where t1.a = tt.a;

--echo case 4) with dynamic partition pruning => das group rescan should be true
select /*+ use_das(t1), use_das(t2), use_nl(t1 t2), leading(t1 t2) */ count(1) from t1 join t2 where t1.a > t2.a;
select /*+ no_rewrite, use_das(t1), use_nl(t1 tt), leading(t1 tt) */ count(1) from t1 join (select /*+ use_das(t2) */ * from t2) as tt where t1.a > tt.a;
select /*+ no_rewrite, use_das(t1), use_nl(t1 tt), leading(t1 tt) */ count(1) from t1 join (select /*+ use_das(t2) */ * from t2 union all select /*+ use_das(t3) */ * from t3) as tt where t1.a > tt.a;

--disable_info
--disable_warnings
--disable_query_log
drop table if exists t1;
drop table if exists t2;
drop table if exists t3;
drop database if exists das_group_rescan;
--enable_info
--enable_query_log
--enable_warnings
--disable_query_log
connection conn_admin;
connection default;
--enable_query_log
