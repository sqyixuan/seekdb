--disable_warnings
DROP TABLE IF EXISTS t1,t2,t3,t4, tpart;
DROP TABLE IF EXISTS t1,t2,t3,t4;
--enable_warnings

--enable_warnings
--explain_protocol 3
--enable_sorted_result

CREATE TABLE t1 (a int, b int, c int, primary key(a, b), index(b) global) 
partition by hash(a) partitions 2;
CREATE TABLE t2 (a int, b int, c int, primary key(a, b), index(b) global) 
partition by hash(a) partitions 2;

INSERT INTO t1 VALUES (1,2,0), (2,2,0);
INSERT INTO t2 VALUES (3,2,0), (4,2,0);

##nl with single partition global index table
SELECT /*+leading(t1 t2) use_nl(t1 t2)*/ t1.a, t1.b, t2.a, t2.b 
FROM t1, t2 where t1.b = t2.b;

SELECT /*+leading(t1 t2) use_nl(t1 t2) parallel(2)*/ t1.a, t1.b, t2.a, t2.b 
FROM t1, t2 where t1.b = t2.b;

SELECT /*+leading(t1 t2) use_nl(t1 t2) parallel(10)*/ t1.a, t1.b, t2.a, t2.b 
FROM t1, t2 where t1.b = t2.b;

##subplan filter with single partition global index table
SELECT /*+no_rewrite*/ t1.a, t1.b FROM t1 
where exists (select 1 from t2 where t1.b = t2.b);

SELECT /*+no_rewrite parallel(2)*/ t1.a, t1.b FROM t1 
where exists (select 1 from t2 where t1.b = t2.b);

SELECT /*+no_rewrite parallel(10)*/ t1.a, t1.b FROM t1 
where exists (select 1 from t2 where t1.b = t2.b);

DROP TABLE t1,t2;

CREATE TABLE t1 (c1 int, c2 int, c3 int) partition by hash(c1) partitions 5;
CREATE TABLE t2 (c1 int primary key, c2 int, c3 int) partition by hash(c1) partitions 5;
CREATE TABLE t3 (c1 int, c2 int, c3 int) partition by hash(c1) partitions 5;

INSERT INTO t1 VALUES (1,1,1), (2,2,2), (3,3,3);
INSERT INTO t2 VALUES (1,1,1), (2,2,2), (3,3,3);
INSERT INTO t3 VALUES (1,1,1), (2,2,2), (3,3,3);

create index idx_t1_c2 on t1(c2) partition by hash(c2) partitions 5;
create index idx_t2_c2 on t2(c2) partition by hash(c2) partitions 5;
create index idx_t3_c2 on t3(c2) partition by hash(c2) partitions 5;

##nl with multi partition global index table
SELECT /*+leading(t1 t2) use_nl(t1 t2)*/ t1.c1, t1.c2, t2.c1, t2.c2 
FROM t1, t2 where t1.c2 = t2.c2;

SELECT /*+leading(t1 t2) use_nl(t1 t2) parallel(2)*/ t1.c1, t1.c2, t2.c1, t2.c2 
FROM t1, t2 where t1.c2 = t2.c2;

SELECT /*+leading(t1 t2) use_nl(t1 t2) parallel(10)*/ t1.c1, t1.c2, t2.c1, t2.c2 
FROM t1, t2 where t1.c2 = t2.c2;

##subplan filter with multi partition global index table
SELECT /*+no_rewrite*/ t1.c1, t1.c2 FROM t1
where exists (select /*+no_merge*/1 from t2 where t1.c2 = t2.c2)
and exists (select /*+no_merge*/1 from t3 where t1.c2 = t3.c2);

SELECT /*+no_rewrite parallel(2)*/ t1.c1, t1.c2 FROM t1
where exists (select /*+no_merge*/1 from t2 where t1.c2 = t2.c2)
and exists (select /*+no_merge*/1 from t3 where t1.c2 = t3.c2);

SELECT /*+no_rewrite parallel(10)*/ t1.c1, t1.c2 FROM t1
where exists (select /*+no_merge*/1 from t2 where t1.c2 = t2.c2)
and exists (select /*+no_merge*/1 from t3 where t1.c2 = t3.c2);


drop index idx_t1_c2 on t1;
drop index idx_t2_c2 on t2;
drop index idx_t3_c2 on t3;

#nested nl with pushdown 2 conditions
create index idx_t3_c2c3 on t3(c2, c3) global;

select /*+leading(t1 v) use_nl(v)*/t1.* from t1, 
(select /*+no_merge leading(t2 t3) use_nl(t3)*/t3.c3 from t2, t3 where t2.c2 = t3.c2) v 
where t1.c3 = v.c3;

select /*+leading(t1 v) use_nl(v) parallel(2)*/t1.* from t1, 
(select /*+no_merge leading(t2 t3) use_nl(t3)*/t3.c3 from t2, t3 where t2.c2 = t3.c2) v 
where t1.c3 = v.c3;

select /*+leading(t1 v) use_nl(v) parallel(10)*/t1.* from t1, 
(select /*+no_merge leading(t2 t3) use_nl(t3)*/t3.c3 from t2, t3 where t2.c2 = t3.c2) v 
where t1.c3 = v.c3;


#nested top nl use pwj
select /*+leading(t1 v) use_nl(v)*/t1.* from t1, 
(select /*+no_merge leading(t2 t3) use_nl(t3)*/t2.c1 from t2, t3 where t2.c2 = t3.c2) v 
where t1.c1 = v.c1;

select /*+leading(t1 v) use_nl(v) parallel(2)*/t1.* from t1, 
(select /*+no_merge leading(t2 t3) use_nl(t3)*/t2.c1 from t2, t3 where t2.c2 = t3.c2) v 
where t1.c1 = v.c1;

select /*+leading(t1 v) use_nl(v) parallel(10)*/t1.* from t1, 
(select /*+no_merge leading(t2 t3) use_nl(t3)*/t2.c1 from t2, t3 where t2.c2 = t3.c2) v 
where t1.c1 = v.c1;

drop index idx_t3_c2c3 on t3;
create index idx_t3_c2c3 on t3(c2, c3) global partition by hash(c2) partitions 5;

select /*+leading(t1 v) use_nl(v)*/t1.* from t1, 
(select /*+no_merge leading(t2 t3) use_nl(t3)*/t3.c3 from t2, t3 where t2.c2 = t3.c2) v 
where t1.c3 = v.c3;

select /*+leading(t1 v) use_nl(v) parallel(2)*/t1.* from t1, 
(select /*+no_merge leading(t2 t3) use_nl(t3)*/t3.c3 from t2, t3 where t2.c2 = t3.c2) v 
where t1.c3 = v.c3;

select /*+leading(t1 v) use_nl(v) parallel(10)*/t1.* from t1, 
(select /*+no_merge leading(t2 t3) use_nl(t3)*/t3.c3 from t2, t3 where t2.c2 = t3.c2) v 
where t1.c3 = v.c3;

#nested top nl use pwj
select /*+leading(t1 v) use_nl(v)*/t1.* from t1, 
(select /*+no_merge leading(t2 t3) use_nl(t3)*/t2.c1 from t2, t3 where t2.c2 = t3.c2) v 
where t1.c1 = v.c1;

select /*+leading(t1 v) use_nl(v) parallel(2)*/t1.* from t1, 
(select /*+no_merge leading(t2 t3) use_nl(t3)*/t2.c1 from t2, t3 where t2.c2 = t3.c2) v 
where t1.c1 = v.c1;

select /*+leading(t1 v) use_nl(v) parallel(10)*/t1.* from t1, 
(select /*+no_merge leading(t2 t3) use_nl(t3)*/t2.c1 from t2, t3 where t2.c2 = t3.c2) v 
where t1.c1 = v.c1;


create index idx_t3_c2 on t3(c2) global partition by hash(c2) partitions 5;

select /*+leading(t1 v) use_nl(v)*/t1.* from t1, 
(select /*+no_merge leading(t2 t3) use_nl(t3)*/t3.c2 from t2, t3 where t2.c2 = t3.c2) v 
where t1.c2 = v.c2;

select /*+leading(t1 v) use_nl(v) parallel(2)*/t1.* from t1, 
(select /*+no_merge leading(t2 t3) use_nl(t3)*/t3.c2 from t2, t3 where t2.c2 = t3.c2) v 
where t1.c2 = v.c2;

select /*+leading(t1 v) use_nl(v) parallel(10)*/t1.* from t1, 
(select /*+no_merge leading(t2 t3) use_nl(t3)*/t3.c2 from t2, t3 where t2.c2 = t3.c2) v 
where t1.c2 = v.c2;

select /*+leading(t1 v) use_nl(v) parallel(2)*/t1.* from t1, 
(select /*+no_merge leading(t2 t3) use_nl(t3)*/t2.c1 from t2, t3 where t2.c2 = t3.c2) v 
where t1.c1 = v.c1;

select /*+leading(t1 v) use_nl(v) parallel(10)*/t1.* from t1, 
(select /*+no_merge leading(t2 t3) use_nl(t3)*/t2.c1 from t2, t3 where t2.c2 = t3.c2) v 
where t1.c1 = v.c1;


#nested spf 
SELECT /*+no_rewrite*/ t1.c1, t1.c2 FROM t1 where exists 
(select /*+no_merge leading(t2 t3) use_nl(t3)*/t3.c3 from t2, t3
where t2.c2 = t3.c2 and t1.c3 = t3.c3);

SELECT /*+no_rewrite parallel(2)*/ t1.c1, t1.c2 FROM t1 where exists 
(select /*+no_merge leading(t2 t3) use_nl(t3)*/t3.c3 from t2, t3
where t2.c2 = t3.c2 and t1.c3 = t3.c3);

SELECT /*+no_rewrite parallel(10)*/ t1.c1, t1.c2 FROM t1 where exists 
(select /*+no_merge leading(t2 t3) use_nl(t3)*/t3.c3 from t2, t3
where t2.c2 = t3.c2 and t1.c3 = t3.c3);


#nested spf pwj
SELECT /*+no_rewrite*/ t1.c1, t1.c2 FROM t1 where exists 
(select /*+no_merge leading(t2 t3) use_nl(t3)*/t2.c1 from t2, t3 
where t2.c2 = t3.c2 and t1.c1 = t2.c1);

SELECT /*+no_rewrite parallel(2)*/ t1.c1, t1.c2 FROM t1 where exists 
(select /*+no_merge leading(t2 t3) use_nl(t3)*/t2.c1 from t2, t3 
where t2.c2 = t3.c2 and t1.c1 = t2.c1);

SELECT /*+no_rewrite parallel(10)*/ t1.c1, t1.c2 FROM t1 where exists 
(select /*+no_merge leading(t2 t3) use_nl(t3)*/t2.c1 from t2, t3 
where t2.c2 = t3.c2 and t1.c1 = t2.c1);

DROP TABLE t1,t2,t3;

CREATE TABLE t1 (
  id int NOT NULL PRIMARY KEY,
  ct int DEFAULT NULL,
  pc int DEFAULT NULL,
  INDEX idx_ct (ct) global,
  INDEX idx_pc (pc) global
) partition by hash(id) partitions 2;
INSERT INTO t1 VALUES
 (1,NULL,NULL),(2,NULL,NULL),(3,NULL,NULL),(4,NULL,NULL),(5,NULL,NULL);

CREATE TABLE t2 (
  id int NOT NULL PRIMARY KEY,
  sr int NOT NULL,
  nm varchar(255) NOT NULL,
  INDEX idx_sr (sr) global
) partition by hash(id) partitions 2;
INSERT INTO t2 VALUES
  (2441905,4308,'LesAbymes'),(2441906,4308,'Anse-Bertrand');

CREATE TABLE t3 (
  id int NOT NULL PRIMARY KEY,
  ct int NOT NULL,
  ln int NOT NULL,
  INDEX idx_ct (ct) global,
  INDEX idx_ln (ln) global
) partition by hash(id) partitions 2;

SELECT /*+no_rewrite*/t1.* FROM t1 LEFT JOIN  t2 ON t1.ct=t2.id WHERE t1.id='5';

SELECT t1.* FROM t1 LEFT JOIN (t2 LEFT JOIN t3 ON t3.ct=t2.id AND t3.ln='5')
ON t1.ct=t2.id WHERE t1.id='5';

DROP TABLE t1,t2,t3;

create table t1 (c1 int, c2 int, c3 int) partition by hash(c1) partitions 2;
create table t2 (c1 int, c2 int, c3 int) partition by hash(c1) partitions 2;
create table t3 (c1 int, c2 int, c3 int) partition by hash(c1) partitions 2;

create index das_spf_idx1_c2 on t1(c2) global partition by hash(c2) partitions 2;
create index das_spf_idx2_c2 on t2(c2) global partition by hash(c2) partitions 2;
create index das_spf_idx3_c2 on t3(c2) global partition by hash(c2) partitions 2;

select
    c1, c2, c3,
    /*+ index(t1 das_spf_idx1_c2) */ c1 in
        (select /*+ index(t2 das_spf_idx2_c2) */ c1
            from t2 where c2 = t1.c2
        ) as col1,
    /*+ index(t1 das_spf_idx1_c2) */ c1 in
        (select /*+ index(t3 das_spf_idx3_c2) */ c1
            from t3 where c2 = t1.c2
        ) as col2
from t1
order by c1;

DROP TABLE t1,t2,t3;

create table t1(a int, b int);
create table t2(a int, b int, filler char(200), key(a), id int primary key) partition by hash(id) partitions 2;
create table t3(a int, b int, filler char(200), key(a), id int primary key) partition by hash(id) partitions 2;
create table t4(a int, b int, filler char(200), key(a), id int primary key) partition by hash(id) partitions 2;

select t3.a, t3.b, t3.filler, t1.a, t1.b, t2.a, t2.b, t2.filler, t4.a, t4.b, t4.filler 
from t3 join t1 left join (t2 join t4 on t4.a=t2.b) on t2.a=t1.b where t3.a<=>t2.b;

DROP TABLE t1,t2,t3,t4;

create table t1 (c1 int primary key, c2 varchar(50),c3 DECIMAL(8,2),c4 date)
partition by range (c1) (partition p0 values less than (3),partition p1 values less than (6));
