CREATE TABLE t1(c0 INT,c1 INT)
PARTITION BY LIST(c1)
(PARTITION l1 VALUES IN (0,NULL,1,2,3,4),
PARTITION l2 VALUES IN (10,11,12,13,14)
);
CREATE TABLE t2(c0 INT,c1 INT)
PARTITION BY LIST(c1)
(PARTITION l1 VALUES IN (0,1,2,3,4,5,6),
PARTITION l2 VALUES IN (10,NULL,12,13,14,15,16)
);

INSERT INTO t1 VALUES(1,0),(2,NULL),(3,1),(4,1),(5,2),(6,2),(7,3),(7,4),(8,10),(9,11),(10,12),(10,12);
INSERT INTO t2 VALUES(1,0),(2,2),(3,1),(4,NULL),(5,3),(6,5),(7,6),(8,10),(8,12),(9,13),(9,14),(10,14);
SELECT/*+parallel(2) USE_HASH(t1 t2)*/t1.c0, t2.c1
FROM t1 JOIN t2 ON t1.c0=t2.c0 WHERE t2.c1 IN (SELECT c1 FROM t2 where c1 > 1);

DROP TABLE T1, T2;
create table t1(c1 int primary key) partition by hash(c1) partitions 3;
create table t2(c1 int primary key);

insert into t1 values(1);
insert into t1 values(2);
insert into t1 values(3);
insert into t2 values(2);
insert into t2 values(3);
insert into t2 values(6);
select /*+ parallel(2) pq_distribute(t1 partition none) */ * from t1, t2 where t1.c1= t2.c1;

DROP TABLE T1, T2;

create table t1(c1 int, c2 int, c3 int) partition by hash(c1) partitions 5;
create table t2(c1 int, c2 int, c3 int) partition by hash(c1) partitions 6;
insert into t1 values(1,1,1);
insert into t2 values(1,1,1);
select /*+parallel(2)*/ (select /*+no_unnest*/ count(*) from t2 where t1.c2 = t2.c2) from t1;

create index i_t2c2 on t2(c2);
select /*+parallel(2)*/ (select /*+no_unnest*/ count(*) from t2 where t1.c2 = t2.c2) from t1;


DROP TABLE T1, T2;

create table t1(a int primary key, b int, c int) partition by hash(a) partitions 4;
create index i1 on t1(b) partition by hash(b) partitions 4;
create table t2 like t1;
explain extended_noaddr select /*+parallel(10) use_nl(t1 t2)*/ * from t1 join t2 on t1.b=t2.b where t1.a>0 and t1.a<10;


DROP TABLE T1, T2;

create table t1(a int, b int, c int primary key);
create table t2(a int, b int, c int primary key, key i1(a,b) LOCAL) partition by hash(c) partitions 2;
explain extended_noaddr select * from t1 left join (select a, max(b) as b, max(c)as c from t2 group by a) t on t1.a=t.a and t1.b=t.b where t1.c=10;


DROP TABLE T1, T2;
