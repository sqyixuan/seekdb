#owner:zhuhuashi.zhs
#owner group: sql1
# tags: optimizer, global_index
--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
connect (conn_admin, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn_admin;
alter system set_tp tp_no = 367, error_code = 20, frequency = 1;
connection default;
--enable_query_log

--result_format 4
--enable_info
--enable_sorted_result

--disable_warnings
drop database if exists das_multi_batch_nlj;
--enable_warnings
create database das_multi_batch_nlj;
use das_multi_batch_nlj;
sleep 5;

create table t1 (a int primary key, b int, c int);
create table t1_empty (a int primary key, b int, c int);
create table t2 (a int , b int primary key, c int);
create table t2_empty (a int , b int primary key, c int);
create table t3 (a int, b int , c int primary key);
create table t3_empty (a int, b int , c int primary key);
--disable_info
--disable_query_log
delete from t1;
delete from t2;
delete from t3;
--let $count = 1
while($count <= 1)
{
  --let $stmt=insert into t1(a, b, c) values ($count, $count, $count)
  eval $stmt;
  --let $stmt=insert into t2(a, b, c) values ($count, $count, $count)
  eval $stmt;
  --let $stmt=insert into t3(a, b, c) values ($count, $count, $count)
  eval $stmt;
  inc $count;
}
--enable_query_log
--enable_info

--echo 1.1 t1 is empty, overall output should be empty
--explain_protocol 0
select (select count(*) from t1_empty) as 't1_empty',
       (select count(*) from t2) as 't2',
       (select count(*) from t3) as 't3';
--explain_protocol 3
select /*+leading(t1_empty v) use_nl(v)*/ *
from t1_empty, (select /*+ no_merge */ t2.b, t3.c from t2, t3 where t2.c = t3.c) v
where t1_empty.a = v.c and t1_empty.b = v.b;

--echo 1.2 t2 is empty, overall output should be empty
--explain_protocol 0
select (select count(*) from t1) as 't1',
       (select count(*) from t2_empty) as 't2_empty',
       (select count(*) from t3) as 't3';
--explain_protocol 3
select /*+leading(t1 v) use_nl(v)*/ *
from t1, (select /*+ no_merge */ t2_empty.b, t3.c from t2_empty, t3 where t2_empty.c = t3.c) v
where t1.a = v.c and t1.b = v.b;

--echo 1.3 t3 is empty, overall output should be empty
--explain_protocol 0
select (select count(*) from t1) as 't1',
       (select count(*) from t2) as 't2',
       (select count(*) from t3_empty) as 't3_empty';
--explain_protocol 3
select /*+leading(t1 v) use_nl(v)*/ *
from t1, (select /*+ no_merge */ t2.b, t3_empty.c from t2, t3_empty where t2.c = t3_empty.c) v
where t1.a = v.c and t1.b = v.b;

--echo 2.1 t1.b = t2.b produces empty set, overall output should be empty
--explain_protocol 0
--disable_info
--disable_query_log
delete from t1;
delete from t2;
delete from t3;
--let $count = 1
while($count <= 1000)
{
  --let $stmt=insert into t1(a, b, c) values ($count, 1000+$count, $count)
  eval $stmt;
  --let $stmt=insert into t2(a, b, c) values ($count, $count, $count)
  eval $stmt;
  --let $stmt=insert into t3(a, b, c) values ($count, $count, $count)
  eval $stmt;
  inc $count;
}
--enable_query_log
--enable_info
select (select count(*) from t1) as 't1',
       (select count(*) from t2) as 't2',
       (select count(*) from t3) as 't3',
       (select count(*) from t1, t2 where t1.b = t2.b) as 't1.b = t2.b';
--explain_protocol 3
select /*+leading(t1 v) use_nl(v)*/ *
from t1, (select /*+ no_merge */ t2.b, t3.c from t2, t3 where t2.c = t3.c) v
where t1.a = v.c and t1.b = v.b;

--echo 2.2 t1.a = t3.c produces empty set, overall output should be empty
--explain_protocol 0
--disable_info
--disable_query_log
delete from t1;
delete from t2;
delete from t3;
--let $count = 1
while($count <= 1000)
{
  --let $stmt=insert into t1(a, b, c) values (1000+$count, $count, $count)
  eval $stmt;
  --let $stmt=insert into t2(a, b, c) values ($count, $count, $count)
  eval $stmt;
  --let $stmt=insert into t3(a, b, c) values ($count, $count, $count)
  eval $stmt;
  inc $count;
}
--enable_query_log
--enable_info
select (select count(*) from t1) as 't1',
       (select count(*) from t2) as 't2',
       (select count(*) from t3) as 't3',
       (select count(*) from t1, t3 where t1.a = t3.c) as 't1.a = t3.c';
--explain_protocol 3
select /*+leading(t1 v) use_nl(v)*/ *
from t1, (select /*+ no_merge */ t2.b, t3.c from t2, t3 where t2.c = t3.c) v
where t1.a = v.c and t1.b = v.b;

--echo 2.3 t2.c = t3.c produces empty set, overall output should be empty
--explain_protocol 0
--disable_info
--disable_query_log
delete from t1;
delete from t2;
delete from t3;
--let $count = 1
while($count <= 1000)
{
  --let $stmt=insert into t1(a, b, c) values ($count, $count, $count)
  eval $stmt;
  --let $stmt=insert into t2(a, b, c) values ($count, $count, 1000+$count)
  eval $stmt;
  --let $stmt=insert into t3(a, b, c) values ($count, $count, $count)
  eval $stmt;
  inc $count;
}
--enable_query_log
--enable_info
select (select count(*) from t1) as 't1',
       (select count(*) from t2) as 't2',
       (select count(*) from t3) as 't3',
       (select count(*) from t2, t3 where t2.c = t3.c) as 't2.c = t3.c';
--explain_protocol 3
select /*+leading(t1 v) use_nl(v)*/ *
from t1, (select /*+ no_merge */ t2.b, t3.c from t2, t3 where t2.c = t3.c) v
where t1.a = v.c and t1.b = v.b;

--disable_info
--disable_warnings
--disable_query_log
drop table if exists t1;
drop table if exists t2;
drop table if exists t3;
drop table if exists t1_empty;
drop table if exists t2_empty;
drop table if exists t3_empty;
drop database if exists das_multi_batch_nlj;
--enable_info
--enable_query_log
--enable_warnings
--disable_query_log
connection conn_admin;
alter system set_tp tp_no = 367, error_code = 20, frequency = 0;
connection default;
--enable_query_log
