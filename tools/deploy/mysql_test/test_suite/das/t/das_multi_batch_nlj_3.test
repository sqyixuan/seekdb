#owner:zhuhuashi.zhs
#owner group: IMF
# tags: das, join

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
connect (conn_admin, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn_admin;
alter system set_tp tp_no = 311, error_code = 2, frequency = 1;
alter system set _rowsets_max_rows=2 tenant=all_user;
connection default;
--enable_query_log

--disable_warnings
--disable_query_log
sleep 5;
drop table if exists t1;
drop table if exists t2;
drop table if exists t3;
--enable_query_log
--enable_warnings

create table t1 (c11 int primary key, c12 int, c13 int);
create table t2 (c21 int primary key, c22 int, c23 int);
create index ind_t2 on t2(c22);
create table t3 (c31 int primary key, c32 int, c33 int);
create index ind_t3 on t3(c32);

insert into t1 values (1,1,1),(2,2,2),(3,3,3),(4,4,4),(5,5,5),(6,6,6),(7,7,7),(8,8,8),(9,9,9),(10,10,10);

insert into t2 values (1,1,1),(2,1,1),(3,1,1);
insert into t2 values (4,2,2),(5,2,2),(6,2,2);
insert into t2 values (7,3,3),(8,3,3),(9,3,3);
insert into t2 values (10,4,4),(11,4,4),(12,4,4);
insert into t2 values (13,4,4),(14,4,4),(15,4,4);
insert into t2 values (16,5,5),(17,5,5),(18,5,5);

insert into t3 values (1,1,1),(2,1,1),(3,1,1);
insert into t3 values (4,2,2),(5,2,2),(6,2,2);
insert into t3 values (7,3,3),(8,3,3),(9,3,3);
insert into t3 values (10,4,4),(11,4,4),(12,4,4);
insert into t3 values (13,4,4),(14,4,4),(15,4,4);
insert into t3 values (16,5,5),(17,5,5),(18,5,5);

# the group size of batch nlj is 4
select/*+ use_nl(t1,v), leading(t1,v) no_rewrite*/ t1.c11, v.c33 from t1, (select /*+ use_nl(t2,t3) */  * from t2,t3 where t3.c32 = t2
.c22) v where v.c22 = t1.c12;

select/*+ use_nl(t1,v), leading(t1,v) no_rewrite*/ count(*) from t1, (select /*+ use_nl(t2,t3) */  * from t2,t3 where t3.c32 = t2
.c22) v where v.c22 = t1.c12;

select/*+ use_nl(t1,v), leading(t1,v) no_rewrite*/ distinct(c33) from t1, (select /*+ use_nl(t2,t3) */  * from t2,t3 where t3.c32 = t2
.c22) v where v.c22 = t1.c12;

select/*+ use_nl(t1,v), leading(t1,v) no_rewrite*/ t1.c11, v.c33 from t1, (select /*+ use_nl(t2,t3) */  * from t2,t3 where t3.c32 = t2
.c22) v where v.c22 = t1.c12 order by t1.c11 limit 10;

select/*+ use_nl(t1,v), leading(t1,v) no_rewrite*/ t1.c11, v.c33 from t1, (select /*+ use_nl(t2,t3) */  * from t2,t3 where t3.c32 = t2
.c22) v where v.c22 = t1.c12 order by t1.c12 limit 10;

drop table t1;
drop table t2;
drop table t3;

connection conn_admin;
alter system set_tp tp_no = 311, error_code = 2, frequency = 0;
alter system set _rowsets_max_rows=256 tenant=all_user;
connection default;