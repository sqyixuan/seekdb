# owner group: imf
# bug url: 
--disable_abort_on_error
--result_format 4

--disable_warnings
drop table if exists t1;
alter system flush plan cache;

create table t1 as select * from oceanbase.__all_database where in_recyclebin = 0 and 0 = sys_privilege_check('db_acc', `tenant_id`, `database_name`, '') order by tenant_id desc limit 2;
create index idx_db_name on t1(tenant_id, in_recyclebin, database_name) global partition by hash(tenant_id) partitions 2;

explain SELECT /*+index(t1 idx_db_name)*/ `database_name` AS `Database` FROM t1 WHERE tenant_id = 0 and in_recyclebin = 0 and 0 = sys_privilege_check('db_acc', `tenant_id`, `database_name`, '') order by database_name asc;
# if buggy, below select would have empty set on slave mode.
SELECT /*+index(t1 idx_db_name)*/ `database_name` AS `Database` FROM t1 WHERE tenant_id = 0 and in_recyclebin = 0 and 0 = sys_privilege_check('db_acc', `tenant_id`, `database_name`, '') order by database_name asc;

drop table t1;
