#owner: zhuhuashi.zhs
#owner group: IMF
# tags: das

--disable_abort_on_error
--disable_query_log
connection default;
--result_format 4
--enable_query_log

--disable_warnings
drop table if exists t1,t2;
--enable_warnings

create table t1(c1 int primary key, c2 int, c3 int, c4 int);
create table t2(c1 int, c2 int, c3 int, c4 int) partition by hash(c1) partitions 10;
create index i2 on t2(c2) local;

--disable_query_log
let i=0;
while($i<5000) {
  eval INSERT INTO t1 VALUES($i, $i, $i, $i);
  eval INSERT INTO t2 VALUES($i, $i, $i, $i);
  inc $i;
}
--enable_query_log

set ob_query_timeout = 200000000;
explain select max(c1) from (select /*+no_rewrite*/ c1, (select count(c1) from t2 where t2.c2 > t1.c2 and t2.c1 = 100), (select count(c2) from t2 where t2.c2 > t1.c2 and t2.c1 = 100), (select count(c3) from t2 where t2.c2 > t1.c2 and t2.c1 = 100), (select count(c4) from t2 where t2.c2 > t1.c2 and t2.c1 = 100), (select sum(c1) from t2 where t2.c2 > t1.c2 and t2.c1 = 100), (select sum(c2) from t2 where t2.c2 > t1.c2 and t2.c1 = 100), (select sum(c3) from t2 where t2.c2 > t1.c2 and t2.c1 = 100), (select sum(c4) from t2 where t2.c2 > t1.c2 and t2.c1 = 100) from t1);
select max(c1) from (select /*+no_rewrite*/ c1, (select count(c1) from t2 where t2.c2 > t1.c2 and t2.c1 = 100), (select count(c2) from t2 where t2.c2 > t1.c2 and t2.c1 = 100), (select count(c3) from t2 where t2.c2 > t1.c2 and t2.c1 = 100), (select count(c4) from t2 where t2.c2 > t1.c2 and t2.c1 = 100), (select sum(c1) from t2 where t2.c2 > t1.c2 and t2.c1 = 100), (select sum(c2) from t2 where t2.c2 > t1.c2 and t2.c1 = 100), (select sum(c3) from t2 where t2.c2 > t1.c2 and t2.c1 = 100), (select sum(c4) from t2 where t2.c2 > t1.c2 and t2.c1 = 100) from t1);