explain select
   (
     select count(*) from (
       select
         /*+ parallel(auto) index(t2 idx11) */
         t2.pk
       from table10_hash_pk_parts_10_int_not_null as t2
       where t2.col_varchar_20_unique_index < t1.col_varchar_20_unique_index
         and t1.col_bigint_unique_index < 8
       order by 1 asc
       limit 1
     )
   ) c2,
   (
     select count(*) from (
       select
         /*+ parallel(auto) full(t2)*/
         t2.pk
       from table10_range_pk_part_p1__50_part_p2__maxvalue_int_not_null as t2
       where t2.col_varchar_20_unique_index <= t1.col_varchar_20_unique_index
         and t2.pk <= 3
       order by 1
       limit 1
     )) c3
 from table10_hash_pk_parts_10_int_not_null as t1
 order by 1;

select
   (
     select count(*) from (
       select
         /*+ parallel(auto) index(t2 idx11) */
         t2.pk
       from table10_hash_pk_parts_10_int_not_null as t2
       where t2.col_varchar_20_unique_index < t1.col_varchar_20_unique_index
         and t1.col_bigint_unique_index < 8
       order by 1 asc
       limit 1
     )
   ) c2,
   (
     select count(*) from (
       select
         /*+ parallel(auto) full(t2)*/
         t2.pk
       from table10_range_pk_part_p1__50_part_p2__maxvalue_int_not_null as t2
       where t2.col_varchar_20_unique_index <= t1.col_varchar_20_unique_index
         and t2.pk <= 3
       order by 1
       limit 1
     )) c3
 from table10_hash_pk_parts_10_int_not_null as t1
 order by 1;

# test parameter and hint
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(c1 int primary key, c2 int, c3 int) partition by hash(c1) partitions 3;
create index c2 on t1(c2) global;
create index c3 on t1(c3) local;
explain select /*+use_das(t1)*/ * from t1 order by c1;
explain select /*+opt_param('enable_das_keep_order', 'false') use_das(t1)*/ * from t1 order by c1;
explain select /*+use_das(t1) index(t1 c2)*/ * from t1 order by c2;
explain select /*+opt_param('enable_das_keep_order', 'false') use_das(t1) index(t1 c2)*/ * from t1 order by c2;
explain select /*+use_das(t1) index(t1 c3)*/ * from t1 order by c3;
explain select /*+opt_param('enable_das_keep_order', 'false') use_das(t1) index(t1 c3)*/ * from t1 order by c3;

alter system set _enable_das_keep_order=false;
explain select /*+use_das(t1)*/ * from t1 order by c1;
explain select /*+opt_param('enable_das_keep_order', 'true') use_das(t1)*/ * from t1 order by c1;
explain select /*+use_das(t1) index(t1 c2)*/ * from t1 order by c2;
explain select /*+opt_param('enable_das_keep_order', 'true') use_das(t1) index(t1 c2)*/ * from t1 order by c2;
explain select /*+use_das(t1) index(t1 c3)*/ * from t1 order by c3;
explain select /*+opt_param('enable_das_keep_order', 'true') use_das(t1) index(t1 c3)*/ * from t1 order by c3;
alter system set _enable_das_keep_order=true;

--disable_warnings
drop table if exists t1,t2,t3,t4,t5;
--enable_warnings

connection conn_admin;
alter system set _rowsets_max_rows = 256 tenant=sys;
alter system set _rowsets_max_rows = 256 tenant=all_user;
alter system set _rowsets_max_rows = 256 tenant=all_meta;
alter system set_tp tp_no=554, error_code=1, frequency=0;
alter system set_tp tp_no=311, error_code=2, frequency=0;
alter system set_tp tp_no=400, error_code=4, frequency=0;
alter system set_tp tp_no=315, error_code=1, frequency=0;
connection default;