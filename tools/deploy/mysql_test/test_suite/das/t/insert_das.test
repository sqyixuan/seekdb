connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
begin;
insert into oceanbase.__all_tenant_info(tenant_id, tenant_role, switchover_status,  switchover_epoch, sync_scn, replayable_scn, readable_scn) values(1, "primary", "normal", 1,1,1,1),
(2, "primary", "normal", 1,1,1,1),(3, "primary", "normal", 1,1,1,1), (4, "primary", "normal", 1,1,1,1);
select tenant_id, tenant_role, switchover_status,  switchover_epoch, sync_scn, replayable_scn, readable_scn from oceanbase.__all_tenant_info where tenant_id in (1, 2, 3, 4) order by tenant_id;
rollback;
connection default;
