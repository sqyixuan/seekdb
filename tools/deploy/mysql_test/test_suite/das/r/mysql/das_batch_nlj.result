## test left table not match with right table, expected empty result
select /*+query_timeout(1000000000), index(t1 i1), index(t2 i1), use_nl(t1 t2)*/ * from t1 join t2 where t1.b>2 and t1.b<10000 and t1.b-10000=t2.b;
