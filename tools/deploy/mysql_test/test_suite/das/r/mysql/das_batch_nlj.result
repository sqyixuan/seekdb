## test batch row count is less than partition count
select /*+index(t1 i1), index(t2 i1), use_nl(t1 t2)*/ * from t1 join t2 where t1.b>1 and t1.b<3 and t1.b=t2.b;
+---+------+------+---+------+------+
| a | b    | c    | a | b    | c    |
+---+------+------+---+------+------+
| 1 |    2 |    3 | 1 |    2 |    3 |
+---+------+------+---+------+------+
## test nested loop cartesian join, expected unuse batch nlj opt
select /*+index(t1 primary), index(t2 primary), use_nl(t1 t2)*/ * from t1, t2 where t1.a=t2.a and t1.a=100;
