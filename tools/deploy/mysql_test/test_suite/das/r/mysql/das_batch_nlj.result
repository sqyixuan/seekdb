create table bnlj_t1(a int, b int, c int, primary key (a,b))
partition by range columns(a) subpartition by hash(b) subpartitions 3
(
  partition p100 values less than (100),
  partition p200 values less than (200),
  partition p300 values less than (300),
  partition pMax values less than (MAXVALUE)
);
create table bnlj_t2(a int, b int, c int, primary key (a, b))
partition by range columns(a) subpartition by hash(b) subpartitions 2
(
  partition p100 values less than (100),
  partition p200 values less than (200),
  partition p300 values less than (300),
  partition pMax values less than (MAXVALUE)
);
insert into bnlj_t1 (a, b, c) values (5, 5, 5), (7, 7, 7), (105, 105, 105), (107, 107, 107), (205, 205, 205), (207, 207, 207), (305, 305, 305), (307, 307, 307), (405, 405, 405), (407, 407, 407);
insert into bnlj_t2 (a, b, c) values (5, 5, 5), (6, 6, 6), (105, 105, 105), (106, 106, 106), (205, 205, 205), (206, 206, 206), (305, 305, 305), (306, 306, 306), (405, 405, 405), (406, 406, 406);

explain extended_noaddr select /*+leading(tb ta) use_nl(ta tb)*/ * from (select a, b, c from bnlj_t2 group by a, c) as ta join bnlj_t1 as tb on ta.a = tb.a and ta.b = tb.c;
