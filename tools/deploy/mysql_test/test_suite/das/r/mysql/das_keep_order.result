drop table if exists t1;
create table t1(c1 int primary key, c2 int) partition by hash(c1) partitions 5;
alter table t1 add column (c3 int generated always as (c1+1) stored);
alter table t1 add column (c4 int generated always as (c2-1) stored);
alter table t1 add column (c5 int generated always as (c1+c2) virtual);
alter table t1 add column (c6 int generated always as (c1 * 2) virtual);
create index gi1 on t1(c3) global partition by hash(c3) partitions 3;
create index li1 on t1(c4) local;
create index gi2 on t1(c5) global partition by hash(c5) partitions 3;
create index li2 on t1(c6) local;
explain select * from t1 where c3 > 10 order by c3 limit 10;
