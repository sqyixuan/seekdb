explain select
   (
     select count(*) from (
       select
         /*+ parallel(auto) index(t2 idx11) */
         t2.pk
       from table10_hash_pk_parts_10_int_not_null as t2
       where t2.col_varchar_20_unique_index < t1.col_varchar_20_unique_index
         and t1.col_bigint_unique_index < 8
       order by 1 asc
       limit 1
     )
   ) c2,
   (
     select count(*) from (
       select
         /*+ parallel(auto) full(t2)*/
         t2.pk
       from table10_range_pk_part_p1__50_part_p2__maxvalue_int_not_null as t2
       where t2.col_varchar_20_unique_index <= t1.col_varchar_20_unique_index
         and t2.pk <= 3
       order by 1
       limit 1
     )) c3
 from table10_hash_pk_parts_10_int_not_null as t1
 order by 1;
