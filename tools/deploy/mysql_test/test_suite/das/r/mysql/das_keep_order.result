drop table if exists t1, t2;
create table t1 (c1 int primary key, c2 int, c3 int, c4 int, c5 int) partition by hash(c1) partitions 5;
create table t2 (c1 int primary key, c2 int, c3 int) partition by hash(c1) partitions 7;
create index g_i on t1(c2, c3) global partition by hash(c2) partitions 3;
create index l_i on t1(c4);
