drop table if exists t1;
create table t1(c1 int primary key, c2 varchar(100) collate utf8mb4_bin, c3 varchar(100) collate utf8mb4_general_ci) partition by hash(c1) partitions 5;
create index g_i on t1(c2) global partition by key(c2) partitions 3;
create index l_i on t1(c3) local;
insert into t1 values (1,NULL,NULL),(2,NULL,NULL),(3,'A','A'),(4,'abc','abc'),(5,'hhh','hhh'),(6,'ABC','ABC'),(7,'123','456'),(8,'OceanBase','OceanBase'),(9,'Abc','Abc'),(10,'oceanbase','oceanbase');
