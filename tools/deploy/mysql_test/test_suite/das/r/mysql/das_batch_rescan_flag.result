result_format: 4
drop table if exists t1,t2;
create table t1(c1 int primary key, c2 int, c3 int);
create table t2(c1 int primary key, c2 int, c3 int, c4 int, c5 int) partition by hash(c1) partitions 2;
create index i2 on t2(c2,c3,c4) global partition by hash(c2) partitions 2;

## global index filter
explain select /*+no_rewrite*/ * from t1 where exists (select /*+index(t2 i2) use_das(t2)*/ * from t2 where t2.c2 > t1.c2 and t2.c4 > 1);
Query Plan
================================================================
|ID|OPERATOR                      |NAME  |EST.ROWS|EST.TIME(us)|
----------------------------------------------------------------
|0 |SUBPLAN FILTER                |      |1       |47          |
|1 |├─TABLE FULL SCAN             |t1    |1       |3           |
|2 |└─DISTRIBUTED TABLE RANGE SCAN|t2(i2)|1       |45          |
================================================================
Outputs & filters:
-------------------------------------
