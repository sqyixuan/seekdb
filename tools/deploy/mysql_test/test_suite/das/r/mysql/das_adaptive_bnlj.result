update t2 set c1 = c1 -1 where c1 < 100;
update t3 set c1 = c1 -1 where c1 < 150;
SELECT /*+ no_rewrite leading(t1,T) ure_nl(t1, T) */ t1.*
FROM t1
JOIN (
SELECT * FROM t2
MINUS
SELECT * FROM t2
) T
ON t1.c1 = T.c1;
c1	c2	c3
drop table t1;
drop table t2;
drop table t3;
drop procedure gen_data;
alter system set _rowsets_max_rows = 256 tenant=sys;
alter system set _rowsets_max_rows = 256 tenant=all_user;
alter system set _rowsets_max_rows = 256 tenant=all_meta;
alter system set_tp tp_no = 554, error_code = 1, frequency = 0;
