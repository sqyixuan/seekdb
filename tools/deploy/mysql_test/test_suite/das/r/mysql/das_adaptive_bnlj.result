SELECT /*+ leading(t1,T) use_nl(t1, T)*/ t1.*
FROM t1
JOIN (
SELECT * FROM t2 where t2.c1 > 100
MINUS
SELECT * FROM t2 where t2.c1 > 150
) T
ON t1.c1 = T.c1;
