result_format: 4
drop table if exists t1,t2;
create table t1(c1 int primary key, c2 int, c3 int, c4 int);
create table t2(c1 int, c2 int, c3 int, c4 int) partition by hash(c1) partitions 10;
create index i2 on t2(c2) local;

set ob_query_timeout = 200000000;
explain select max(c1) from (select /*+no_rewrite*/ c1, (select count(c1) from t2 where t2.c2 > t1.c2 and t2.c1 = 100), (select count(c2) from t2 where t2.c2 > t1.c2 and t2.c1 = 100), (select count(c3) from t2 where t2.c2 > t1.c2 and t2.c1 = 100), (select count(c4) from t2 where t2.c2 > t1.c2 and t2.c1 = 100), (select sum(c1) from t2 where t2.c2 > t1.c2 and t2.c1 = 100), (select sum(c2) from t2 where t2.c2 > t1.c2 and t2.c1 = 100), (select sum(c3) from t2 where t2.c2 > t1.c2 and t2.c1 = 100), (select sum(c4) from t2 where t2.c2 > t1.c2 and t2.c1 = 100) from t1);
