drop table t1,t2,t3,t4;
create procedure gen_data ()
begin
declare num int;
set num = 0;
while num <= 10000 do
insert into t1 values (num, '1','1','1','1'),(num + 1, '2','2','2','2'),(num + 2, '3','3','3','3'),(num + 3, '4','4','4','4'),(num + 4,'5','5','5','5'),(num + 5, '6','6','6','6'),(num + 6, '7','7','7','7'),(num + 7, '8','8','8','8'),(num + 8, '9','9','9','9'),(num + 9, '10','10','10','10');
set num =num + 10;
end while;
end ;
/
create table t1 (c0 int primary key, c1 varchar(1000), c2 varchar(1000), c3 varchar(1000), c4 varchar(1000));
create table t2 (c0 int primary key, c1 varchar(1000), c2 varchar(1000), c3 varchar(1000), c4 varchar(1000));
create table t3 (c0 int primary key, c1 varchar(1000), c2 varchar(1000), c3 varchar(1000), c4 varchar(1000));
create table t4 (c0 int primary key, c1 varchar(1000), c2 varchar(1000), c3 varchar(1000), c4 varchar(1000));
call gen_data();
EXPLAIN BASIC insert into t2 select * from t1;
