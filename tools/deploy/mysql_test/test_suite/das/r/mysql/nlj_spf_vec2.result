CREATE TABLE `t1` (
`c1` int(11) DEFAULT NULL,
`c2` varchar(10) DEFAULT NULL,
`c3` int(11) DEFAULT NULL
) DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC
partition by hash(c1)
(partition `p0`,
partition `p1`,
partition `p2`,
partition `p3`);
CREATE TABLE `t2` (
`c1` int(11) DEFAULT NULL,
`c2` varchar(10) DEFAULT NULL,
`c3` int(11) DEFAULT NULL
) DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC
partition by hash(c1)
(partition `p0`,
partition `p1`,
partition `p2`,
partition `p3`);
