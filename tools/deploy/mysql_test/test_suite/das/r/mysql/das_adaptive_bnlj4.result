drop table if exists t4,t5;
create table t4(c1 int primary key, c2 int, c3 varchar(10));
create table t5(c1 int, c2 int, c3 varchar(10));
create index c1 on t5(c1) local;
insert into t4 values (1,1,'aaa'),(2,1,'aaa'),(3,2,'bbb'),(4,1,'ccc'),(5,3,'aaa');
insert into t5 values (1,2,'aaa'),(1,1,'aaa'),(2,3,'bbb'),(2,2,'ccc'),(3,3,'aaa'),(4,1,'bbb');
explain select /*+use_nl(a b) leading(a b)*/ * from t4 a join (SELECT *, ROW_NUMBER() OVER (PARTITION BY c1 ORDER BY c3) AS row_num FROM t5) b where a.c1=b.c1;
