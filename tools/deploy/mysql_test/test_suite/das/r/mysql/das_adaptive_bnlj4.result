result_format: 4
drop table if exists t1,t2,t3;
create table t1(c1 int primary key, c2 int, c3 int) partition by hash(c1) partitions 3;
create table t2(c1 int primary key, c2 int, c3 int) partition by hash(c1) partitions 4;
create table t3(c1 int primary key, c2 int, c3 int) partition by hash(c1) partitions 5;
create index g_i_1 on t1(c2) global partition by hash(c2) partitions 2;
create index g_i_2 on t2(c2) global partition by hash(c2) partitions 2;
create index g_i_3 on t3(c2) global partition by hash(c2) partitions 2;
create index l_i_1 on t1(c3) local;
create index l_i_2 on t2(c3) local;
create index l_i_3 on t3(c3) local;

