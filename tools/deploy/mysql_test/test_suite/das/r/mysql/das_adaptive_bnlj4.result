drop table if exists t1,t2,t3;
create table t1(c1 int, c2 int, c3 int, key c2(c2) local);
insert into t1 values (1,1,1),(2,2,2);
create table t2(c1 int, c2 int, c3 int, key c2(c2) local);
insert into t2 values (1,1,1);
create table t3(c1 int, c2 int, c3 int, key c2(c2) local);
insert into t3 values (2,2,2);
explain select /*+use_nl(a, b)*/ a.c1, a.c2,b.c1,b.c2 from t1 a left join (select /*+no_rewrite*/ * from t1 where exists (select 1 from t2 where t2.c2=t1.c1 limit 1) or exists (select 1 from t3 where c2 > 1 limit 1)) b on a.c1=b.c2;
