  ( OUTR.col_varchar_20 , OUTR.col_varchar_20_key ) IN ( SELECT INNR.col_varchar_20 AS X, INNR.col_varchar_20_key AS Y FROM t1 INNR) 
    AND 
  ( OUTR.col_varchar_20, OUTR.col_varchar_20_key ) NOT IN ( SELECT DISTINCT INNR.col_varchar_20 AS X , INNR.col_varchar_20_key AS Y FROM t1 INNR WHERE INNR.col_varchar_20_key <= INNR.col_varchar_20));
