drop table if exists tnn1, tnn2, tnn3, tnn8;
create table tnn1(c1 int primary key, c2 int, c3 int, c4 int, c5 int);
create table tnn2(c1 int primary key, c2 int, c3 int, c4 int, c5 int);
create table tnn3(c1 int primary key, c2 int, c3 int, c4 int, c5 int);
create table tnn8(c1 int primary key, c2 int, c3 int, c4 int, c5 int) partition by hash(c1) partitions 2;
create index i2 on tnn8(c2, c3, c4) global partition by hash(c2) partitions 2;
insert into tnn1 values (1,2,3,4,3),(2,3,4,5,4),(3,4,5,6,5);
insert into tnn2 values (1,2,3,4,3),(2,3,4,5,4),(3,4,5,6,5);
insert into tnn3 values (1,2,3,4,3),(2,3,4,5,4),(3,4,5,6,5);
insert into tnn8 values (1,2,3,4,3),(2,3,4,5,4),(3,4,5,6,5);
explain select /*+no_rewrite*/ c1 from tnn1 where exists (select /*+index(tnn8 i2) use_das(tnn8)*/ * from tnn8 where tnn8.c1 > tnn1.c1 and tnn8.c1 > 1  and NOT EXISTS (select /*+no_rewrite*/ c1 from tnn1 where tnn1.c1 in (select /*+use_das(tnn2)*/ c1 from tnn2 where tnn2.c1 > 1 order by 1) and exists (select /*+use_das(tnn3)*/ * from tnn3 where tnn3.c1 > tnn1.c1 order by 1)) order by 1);
