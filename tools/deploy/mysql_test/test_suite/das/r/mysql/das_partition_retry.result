drop table if exists t1,t2,t3, pt1, pt2,pt3,pt4,pt5,pt6,pt7,pt8,pt9,pkey1,pkey2,pkey3,pkey4,pr1,pr2,pr3,pr4,prc1,prc2,prc3,prc4,sp1,sp2,sp3,t_r4_int,t_r4_date;
create table t1(a int, b int);
create table pt1(a int, b int) partition by hash(a) partitions 5;
create table pt2(a int, b int, c int) partition by hash(a) partitions 5;
create table pt3(a int, b int, c int) partition by hash(a) partitions 4;
create table pt4(a int, b int) partition by hash(a+1) partitions 5;
create table pt5(a int, b int) partition by hash(a+0) partitions 5;
create table pt6(a int, b int) partition by hash(a+1) partitions 5;
create table pt7(a int, b int, primary key(a,b)) partition by hash(a+b) partitions 5;
create table pt8(a int, b int, primary key(a,b)) partition by hash(a+b) partitions 5;
create table pt9(a int, b int, c int) partition by hash(a) partitions 5;
create table pkey1(a int, b int) partition by key(a) partitions 5;
create table pkey2(a int, b int) partition by key(a) partitions 5;
create table pkey3(a int, b int, primary key(a,b)) partition by key(a, b) partitions 5;
create table pkey4(a int, b int, primary key(a,b)) partition by key(a, b) partitions 5;
create table pr1(a int, b int) partition by range(a) (
partition p0 values less than (100),
partition p1 values less than (200));
create table pr2(a int, b int) partition by range(a) (
partition p0 values less than (100),
partition p1 values less than (200));
create table pr3(a int, b int) partition by range(a) (
partition p0 values less than (99),
partition p1 values less than (200));
create table pr4(a int, b int) partition by range(a) (
partition p0 values less than (100),
partition p1 values less than (200));
create table prc1(a datetime, b int) partition by range columns(a) (
partition p0 values less than ('2011-01-01'),
partition p1 values less than ('2116-01-01'));
create table prc2(a datetime, b int) partition by range columns(a) (
partition p0 values less than ('2011-01-01'),
partition p1 values less than ('2115-01-01'));
create table prc3(a datetime, b int) partition by range columns(a) (
partition p0 values less than ('2011-01-01'),
partition p1 values less than ('2115-01-01'));
create table prc4(a datetime, b int) partition by range columns(a) (
partition p0 values less than ('2011-01-01'),
partition p1 values less than ('2115-01-01'));
create table sp1(a int, b datetime, primary key(a, b)) partition by hash(a) 
subpartition by range columns(b) 
subpartition template (
subpartition p0 values less than ('2016-10-10'),  
subpartition p1 values less than ('2116-3-30')) partitions 2;
create table sp2(a int, b datetime, primary key(a, b)) partition by hash(a)
subpartition by range columns(b)
subpartition template (
subpartition p0 values less than ('2016-10-10'),
subpartition p1 values less than ('2116-3-30')) partitions 2;
create table sp3(a int, b datetime, primary key(a, b)) partition by hash(a)
subpartition by range columns(b)
subpartition template (
subpartition p0 values less than ('2016-10-10'),
subpartition p1 values less than ('2116-3-30')) partitions 2;
create table t_r4_int(a int, b int, c date, primary key (a))
partition by range columns(a)
(
partition p6 values less than (6),
partition p11 values less than (11),
partition p16 values less than (16),
partition pm values less than (MAXVALUE)
);
create table t_r4_date(a int, b int, c date, primary key (c))
partition by range columns(c)
(
partition p11 values less than ("20161101"),
partition p12 values less than ("20161201"),
partition p171 values less than ("20170101"),
partition pm values less than (MAXVALUE)
);
create table t2(a int, b int) partition by range(a) (
partition p0 values less than (100),
partition p1 values less than (200));
create table t3(a int, b int) partition by range(a) (
partition p0 values less than (100),
partition p1 values less than (MAXVALUE));
