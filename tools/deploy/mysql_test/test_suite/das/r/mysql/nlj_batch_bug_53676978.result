      group(nil), agg_func([T_FUN_SUM(t2.c)])
  4 - output([t2.b], [t2.c], [t2.a]), filter([t2.c IN (100, 400)]), rowset=16
      access([GROUP_ID], [t2.__pk_increment], [t2.b], [t2.c], [t2.a]), partitions(p0)
