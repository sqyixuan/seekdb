      sort_keys([t1.database_name, ASC])
  1 - output([t1.database_name]), filter([0 = sys_privilege_check('db_acc', cast(effective_tenant_id(), BIGINT(-1, 0)), t1.database_name, '')], [t1.in_recyclebin 
      = 0]), rowset=16
      access([t1.in_recyclebin], [t1.database_name]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false,false], 
