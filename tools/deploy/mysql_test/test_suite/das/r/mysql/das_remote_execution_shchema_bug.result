result_format: 4
drop table if exists t1;
alter system flush plan cache;

create table t1 as select * from oceanbase.__all_database where in_recyclebin = 0 and 0 = sys_privilege_check('db_acc', effective_tenant_id(), `database_name`, '') limit 2;

explain SELECT /*+index(t1 idx_db_name)*/ `database_name` AS `Database` FROM t1 WHERE in_recyclebin = 0 and 0 = sys_privilege_check('db_acc', effective_tenant_id(), `database_name`, '') order by database_name asc;
