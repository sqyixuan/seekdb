select /*+ no_rewrite */ t1.c1 from t1 where exists (select t2.c3 from t2 where t2.c2 = t1.c1 and t2.c1 > 10 and t2.c1 < 20) and t1.c3 in (select t3.c3 from t3 where t3.c2 = t1.c1 and t3.c1 > 12);
c1
11
12
