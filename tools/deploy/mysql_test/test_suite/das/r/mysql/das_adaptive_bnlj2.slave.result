drop table pdm_productday;
drop table pdm_product;
create table t1(a int primary key, b int);
insert into t1 values(1, 1), (2, 2), (3, 3), (4, 4);
create table t2(a int, b int, c int) partition by hash(a) partitions 2;
create index i2 on t2(b) global;
insert into t2 values(1, 1, 1), (2, 2, 2), (2, 2, 2), (2, 2, 2), (3, 3, 3), (3, 3, 3), (3, 3, 3), (4, 4, 4);
create table t3(a int, b int, c int) partition by hash(a) partitions 2;
create index i3 on t3(b) global;
insert into t3 values(1, 1, 1), (2, 2, 2), (2, 2, 2), (2, 2, 2), (3, 3, 3), (3, 3, 3), (3, 3, 3), (4, 4, 4);
create table t4(a int, b int);
create index i4 on t4(a);
insert into t4 values(1, 1), (2, 2), (3, 3);
select /*+use_nl(t1 VIEW1)*/ * from t1 where exists(select /*+index(t3 i3), use_nl(t3, t2, t4), leading(t3, t2, t4)*/ t2.c from t2, t3, t4 where t3.b=t1.a and t3.c=t2.b and t2.c=t4.a and t4.b=t1.a);
a	b
1	1
3	3
2	2
drop table t1;
drop table t2;
drop table t3;
drop table t4;
create table t3 (c4 int primary key);
create table t4 (c4 int primary key);
insert into t3 values (1),(2),(3),(4),(-5),(6);
insert into t4 values (1),(2);
explain select /*+no_rewrite leading(A,B) use_nl(B,A)*/ B.c4 from t3 A, (select c4 from ((select c4 from t4) except (select c4 from t4))) B where A.c4 >= B.c4 and A.c4 <= B.c4;
Query Plan
======================================================================
|ID|OPERATOR                              |NAME|EST.ROWS|EST.TIME(us)|
----------------------------------------------------------------------
|0 |EXCHANGE IN REMOTE                    |    |1       |251         |
|1 |└─EXCHANGE OUT REMOTE                 |    |1       |251         |
|2 |  └─NESTED-LOOP JOIN                  |    |1       |250         |
|3 |    ├─TABLE FULL SCAN                 |A   |6       |4           |
|4 |    └─SUBPLAN SCAN                    |B   |1       |41          |
|5 |      └─MERGE EXCEPT DISTINCT         |    |1       |41          |
|6 |        ├─DISTRIBUTED TABLE RANGE SCAN|t4  |1       |21          |
|7 |        └─DISTRIBUTED TABLE RANGE SCAN|t4  |1       |21          |
======================================================================
Outputs & filters:
-------------------------------------
  0 - output([B.c4]), filter(nil)
  1 - output([B.c4]), filter(nil)
  2 - output([B.c4]), filter(nil), rowset=2
      conds(nil), nl_params_([A.c4(:0)]), use_batch=true
  3 - output([A.c4]), filter(nil), rowset=2
      access([A.c4]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([A.c4]), range(MIN ; MAX)always true
  4 - output([B.c4]), filter(nil), rowset=2
      access([B.c4])
  5 - output([EXCEPT([1])]), filter(nil), rowset=2
  6 - output([t4.c4]), filter(nil), rowset=2
      access([GROUP_ID], [t4.c4]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t4.c4]), range(MIN ; MAX)always true, 
      range_cond([:0 >= t4.c4], [:0 <= t4.c4])
  7 - output([t4.c4]), filter(nil), rowset=2
      access([GROUP_ID], [t4.c4]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t4.c4]), range(MIN ; MAX)always true, 
      range_cond([:0 >= t4.c4], [:0 <= t4.c4])
select /*+no_rewrite leading(A,B) use_nl(B,A)*/ B.c4 from t3 A, (select c4 from ((select c4 from t4) except (select c4 from t4))) B where A.c4 >= B.c4 and A.c4 <= B.c4;
c4
drop table t3;
drop table t4;
