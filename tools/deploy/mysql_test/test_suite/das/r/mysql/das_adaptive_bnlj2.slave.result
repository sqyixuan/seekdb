drop table if exists pdm_productday;
drop table if exists pdm_product;
drop table if exists t1,t2,t3,t4,t5;
alter system set _rowsets_max_rows = 2 tenant=sys;
alter system set _rowsets_max_rows = 2 tenant=all_user;
alter system set _rowsets_max_rows = 2 tenant=all_meta;
alter system set_tp tp_no = 554, error_code = 1, frequency = 1;
CREATE TABLE pdm_productday (
id INT AUTO_INCREMENT PRIMARY KEY,
product_code VARCHAR(50) NOT NULL,
nav_date DATE NOT NULL,
amount DECIMAL(10, 2) NOT NULL,
INDEX (product_code, nav_date)
);
INSERT INTO pdm_productday (product_code, nav_date, amount) VALUES ('P001', '2021-06-01', 1000.00);
INSERT INTO pdm_productday (product_code, nav_date, amount) VALUES ('P001', '2021-06-02', 1500.50);
INSERT INTO pdm_productday (product_code, nav_date, amount) VALUES ('P001', '2021-06-03', 1200.00);
INSERT INTO pdm_productday (product_code, nav_date, amount) VALUES ('P002', '2021-06-01', 3000.00);
INSERT INTO pdm_productday (product_code, nav_date, amount) VALUES ('P002', '2021-06-02', 2500.00);
INSERT INTO pdm_productday (product_code, nav_date, amount) VALUES ('P002', '2021-06-03', 3200.50);
INSERT INTO pdm_productday (product_code, nav_date, amount) VALUES ('P003', '2021-06-01', 1800.00);
INSERT INTO pdm_productday (product_code, nav_date, amount) VALUES ('P003', '2021-06-02', 2300.00);
CREATE TABLE pdm_product (
product_code VARCHAR(50) NOT NULL,
product_name VARCHAR(255) NOT NULL,
PRIMARY KEY (product_code),
UNIQUE INDEX (product_name)
);
insert into pdm_product values('P001', 'aaaaaa');
insert into pdm_product values('P002', 'bbbbbb');
select /*+use_nl(t1 t)*/ t1.*, t.* from pdm_product t1 join (SELECT    product_code,   nav_date,   amount,   ROW_NUMBER() OVER (PARTITION BY product_code ORDER BY nav_date DESC) AS row_num FROM  pdm_productday) t where t.product_code=t1.product_code;
product_code	product_name	product_code	nav_date	amount	row_num
P001	aaaaaa	P001	2021-06-03	1200.00	1
P001	aaaaaa	P001	2021-06-02	1500.50	2
P001	aaaaaa	P001	2021-06-01	1000.00	3
P002	bbbbbb	P002	2021-06-03	3200.50	1
P002	bbbbbb	P002	2021-06-02	2500.00	2
P002	bbbbbb	P002	2021-06-01	3000.00	3
explain select /*+use_nl(t1 t)*/ t1.*, t.* from pdm_product t1 join (SELECT    product_code,   nav_date,   amount,   ROW_NUMBER() OVER (PARTITION BY product_code ORDER BY nav_date asc) AS row_num FROM  pdm_productday) t where t.product_code=t1.product_code;
Query Plan
==============================================================================================
|ID|OPERATOR                              |NAME                        |EST.ROWS|EST.TIME(us)|
----------------------------------------------------------------------------------------------
|0 |EXCHANGE IN REMOTE                    |                            |2       |65          |
|1 |└─EXCHANGE OUT REMOTE                 |                            |2       |61          |
|2 |  └─NESTED-LOOP JOIN                  |                            |2       |53          |
|3 |    ├─TABLE FULL SCAN                 |t1                          |2       |4           |
|4 |    └─SUBPLAN SCAN                    |t                           |1       |24          |
|5 |      └─WINDOW FUNCTION               |                            |1       |24          |
|6 |        └─DISTRIBUTED TABLE RANGE SCAN|pdm_productday(product_code)|1       |23          |
==============================================================================================
Outputs & filters:
-------------------------------------
  0 - output([t1.product_code], [t1.product_name], [t.product_code], [t.nav_date], [t.amount], [t.row_num]), filter(nil)
  1 - output([t1.product_code], [t1.product_name], [t.product_code], [t.nav_date], [t.amount], [t.row_num]), filter(nil)
  2 - output([t1.product_code], [t1.product_name], [t.product_code], [t.nav_date], [t.amount], [t.row_num]), filter(nil), rowset=2
      conds(nil), nl_params_([t1.product_code(:0)]), use_batch=true
  3 - output([t1.product_code], [t1.product_name]), filter(nil), rowset=2
      access([t1.product_code], [t1.product_name]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t1.product_code]), range(MIN ; MAX)always true
  4 - output([t.product_code], [t.nav_date], [t.amount], [t.row_num]), filter(nil), rowset=2
      access([t.product_code], [t.nav_date], [t.amount], [t.row_num])
  5 - output([pdm_productday.product_code], [pdm_productday.nav_date], [pdm_productday.amount], [T_WIN_FUN_ROW_NUMBER()]), filter(nil), rowset=2
      win_expr(T_WIN_FUN_ROW_NUMBER()), partition_by(nil), order_by([pdm_productday.nav_date, ASC]), window_type(RANGE), upper(UNBOUNDED PRECEDING), lower(UNBOUNDED 
      FOLLOWING)
  6 - output([pdm_productday.product_code], [pdm_productday.nav_date], [pdm_productday.amount]), filter(nil), rowset=2
      access([GROUP_ID], [pdm_productday.id], [pdm_productday.product_code], [pdm_productday.nav_date], [pdm_productday.amount]), partitions(p0)
      is_index_back=true, is_global_index=false, 
      range_key([pdm_productday.product_code], [pdm_productday.nav_date], [pdm_productday.id]), range(MIN,MIN,MIN ; MAX,MAX,MAX)always true, 
      range_cond([pdm_productday.product_code = :0])
select /*+use_nl(t1 t)*/ t1.*, t.* from pdm_product t1 join (SELECT    product_code,   nav_date,   amount,   ROW_NUMBER() OVER (PARTITION BY product_code ORDER BY nav_date asc) AS row_num FROM  pdm_productday) t where t.product_code=t1.product_code;
