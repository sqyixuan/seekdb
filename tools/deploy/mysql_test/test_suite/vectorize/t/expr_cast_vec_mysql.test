# owner: dachuan.sdc
#tags: optimizer
# owner group: sql2
--result_format 4
--explain_protocol 0

connect (syscon, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection syscon;
alter system set _rowsets_enabled=true tenant=sys;
alter system set _rowsets_enabled=true tenant=all_user;
alter system set _rowsets_enabled=true tenant=all_meta;
alter system set _rowsets_max_rows = 10 tenant=sys;
alter system set _rowsets_max_rows = 10 tenant=all_user;
alter system set _rowsets_max_rows = 10 tenant=all_meta;
--sleep 2

connection default;
--disable_warnings
drop table if exists t_cast_vec_1;
drop table if exists t_cast_vec_2;
--enable_warnings

## prepare data
create table t_cast_vec_1(c1 char(10));
create table t_cast_vec_2(c1 char(10));
let $cnt = 105;
let $idx = 1;
while ($idx <= $cnt)
{
  insert into t_cast_vec_1 values('12345');
  insert into t_cast_vec_1 values('67890');
  insert into t_cast_vec_2 values('1');
  insert into t_cast_vec_2 values('2');
  inc $idx;
}

## implicit
select count(1) from t_cast_vec_1, t_cast_vec_2 where t_cast_vec_2.c1 = substr(t_cast_vec_1.c1, 1, 3) in ('123');

## explicit
select cast(c1 as number) from t_cast_vec_1 order by c1;

## clean up
drop table t_cast_vec_1;
drop table t_cast_vec_2;
connection syscon;
alter system set _rowsets_max_rows = 256 tenant=sys;
alter system set _rowsets_max_rows = 256 tenant=all_user;
alter system set _rowsets_max_rows = 256 tenant=all_meta;
