# owner: zuojiao.hzj
# owner group: sql2

--result_format 4
--explain_protocol 0
connect (syscon, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection syscon;
alter system set _rowsets_enabled=true tenant=sys;
alter system set _rowsets_enabled=true tenant=all_user;
alter system set _rowsets_enabled=true tenant=all_meta;
alter system set _rowsets_max_rows = 128 tenant=sys;
alter system set _rowsets_max_rows = 128 tenant=all_user;
alter system set _rowsets_max_rows = 128 tenant=all_meta;
--sleep 2
connection default;

--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1 (a decimal(20,10), b decimal(20,10));
insert into t1 (a, b) values (1.2, 0.2), (1.2, 2), (0.12, 2), (0.12, 0.2), (1.2, 20), (100000000.2, 20), (100000000.2, 21),(2, 21), (1.1, 1.1), (1.2, 1.2), (null, null), (1.2, -0.2), (-1.2, 0.2), (-1.2, -0.2), (1100000000.2, 0.2), (1100000000.2, 2), (1100000000, 2), (1, 0.0000000001), (0.0000000001, 1), (1.0000000001, 1), (1.0000000001, 1.1);


##do select ahead of explain to let optimizer know exact cost
select * from t1;

explain select a*b, b*a, a, b from t1;
select a*b, b*a, a, b from t1;

--disable_warnings
drop table if exists t1;
--enable_warnings
connection syscon;
alter system set _rowsets_max_rows = 256 tenant=sys;
alter system set _rowsets_max_rows = 256 tenant=all_user;
alter system set _rowsets_max_rows = 256 tenant=all_meta;
--sleep 2
