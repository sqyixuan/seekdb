# owner: dengzhi.ldz
# description: padding column check for vectorized engine

--disable_query_log
set global max_allowed_packet=60000000;
disconnect default;
sleep 1;
connect (default,$OBMYSQL_MS0,admin,admin,test,$OBMYSQL_PORT);
set @@recyclebin = off;
set ob_query_timeout=1000000000;
set ob_trx_timeout=1000000000;

--disable_warnings
drop table if exists t1;
--enable_warnings

# major table
create table t1 (c1 bigint auto_increment primary key, c2 char(200), c3 char(200)) row_format = compressed block_size = 2048;
insert into t1 (c2, c3) values(repeat("a", 50), repeat('ab', 50));
insert into t1 (c2, c3) values(repeat("cb", 50), repeat("ab", 50));
insert into t1 (c2, c3) values(repeat("ac", 50), repeat("cc", 50));
insert into t1 (c2, c3) values(repeat("bc", 50), repeat("abcd", 50));
insert into t1 (c2, c3) values("***abcd ", repeat("a", 100));
insert into t1 (c2, c3) values("a    ", repeat("bb", 50));
insert into t1 (c2, c3) values("     b", repeat("aa", 50));
--let $loop=5
while($loop > 0)
{
  eval insert into t1 (c2, c3) select c2, c3 from t1;
  dec $loop;
}
select count(1) from t1;

--disable_query_log
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
alter system set _rowsets_enabled=true tenant=all;
alter system flush plan cache global;
--enable_query_log

alter system major freeze tenant = all;
--source mysql_test/include/wait_daily_merge.inc

# memtable
insert into t1 (c2, c3) values("     c", repeat('ab ', 50));
insert into t1 (c2, c3) values("*c     ", repeat('cc', 50));

SET sql_mode = 'STRICT_ALL_TABLES,PAD_CHAR_TO_FULL_LENGTH';
select count(1) from t1;
select c2, c3 from t1 where c1 > 20 and c1 < 30 order by c1;
select max(c2), max(c3) from t1;
select count(1) from t1 where c2 >= c3;
select char_length(c2), char_length(c3) from t1 where c1 < 10 order by c1;
select c2 from t1 where c3 < "abc"; 
select c3 from t1 where c2 > "abc"; 

# drop table t1;

--disable_query_log
set global max_allowed_packet=16777216;
set @@recyclebin = on;
connection obsys;
SET sql_mode = 'STRICT_ALL_TABLES';
alter system flush plan cache global;
--enable_query_log
