# owner: xiaoyi.xy
#tags: optimizer
# owner group: sql2

--result_format 4

connect (admin,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection admin;
alter system set _rowsets_enabled=true tenant=sys;
alter system set _rowsets_enabled=true tenant=all_user;
alter system set _rowsets_enabled=true tenant=all_meta;
alter system set _rowsets_max_rows = 4 tenant=sys;
alter system set _rowsets_max_rows = 4 tenant=all_user;
alter system set _rowsets_max_rows = 4 tenant=all_meta;

connection default;
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(c1 int, c2 int);
insert into t1 values(1,1),(1,2),(2,3);

--echo
--echo ## test one batch
explain select/*+USE_HASH_AGGREGATION one_batch*/ c1, count(c2), avg(c2), sum(c2 + 1), min(c2*2), max(c2 - 1) from t1 group by  c1;
select/*+USE_HASH_AGGREGATION one_batch*/ c1, count(c2), avg(c2), sum(c2 + 1), min(c2*2), max(c2 - 1) from t1 group by  c1;
select/*+one_batch*/ count(c2), avg(c2), sum(c2 + 1), min(c2*2), max(c2 - 1) from t1;

--echo
--echo ## test one batch with skip
explain select/*+USE_HASH_AGGREGATION one_batch*/ c1, count(c2), avg(c2), sum(c2 + 1), min(c2*2), max(c2 - 1) from t1 where c2 % 2 = 1 group by  c1;
select/*+USE_HASH_AGGREGATION one batch*/ c1, count(c2), avg(c2), sum(c2 + 1), min(c2*2), max(c2 - 1) from t1 where c2 % 2 = 1 group by  c1;
select/*+one batch*/ count(c2), avg(c2), sum(c2 + 1), min(c2*2), max(c2 - 1) from t1 where c2 % 2 = 1;

--echo
--echo ## test multi batch
insert into t1 values(2,4),(2,5),(2,6), (2,7), (null,8), (3,9), (3,10), (3,11), (3,null), (3,null), (3,14), (3,15), (3,16), (4,1);

explain select/*+USE_HASH_AGGREGATION multi_batch*/ c1, count(c2), sum(c2 + 1), avg(c2 * 5) from t1 group by  c1;
select/*+USE_HASH_AGGREGATION multi_batch*/ c1, count(c2), avg(c2), sum(c2 + 1), min(c2*2), max(c2 - 1) from t1 group by  c1;
select/*+multi_batch*/ count(c2), avg(c2), sum(c2 + 1), min(c2*2), max(c2 - 1) from t1;

--echo
--echo ## test multi batch with skip
explain select/*+USE_HASH_AGGREGATION multi_batch*/ c1, count(c2), avg(c2), sum(c2 + 1), min(c2*2), max(c2 - 1) from t1 where c2 % 2 = 0 group by  c1;
select/*+USE_HASH_AGGREGATION multi_batch*/ c1, count(c2), avg(c2), sum(c2 + 1), min(c2*2), max(c2 - 1) from t1 where c2 % 2 = 0 group by  c1;

--echo ## test implicit agg
select/*+multi_batch*/ c1, count(c2), sum(c2), avg(c1) from t1 where c2 % 2 = 0;

drop table t1;

connection admin;
alter system set _rowsets_max_rows = 256 tenant=sys;
alter system set _rowsets_max_rows = 256 tenant=all_user;
alter system set _rowsets_max_rows = 256 tenant=all_meta;
