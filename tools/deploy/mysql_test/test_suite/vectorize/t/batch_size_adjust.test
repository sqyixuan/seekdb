# owner: zuojiao.hzj
# owner group: sql2
--result_format 4
--explain_protocol 1

connect (syscon, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection syscon;
alter system set _rowsets_enabled=true tenant=sys;
alter system set _rowsets_enabled=true tenant=all_user;
alter system set _rowsets_enabled=true tenant=all_meta;
alter system set _rowsets_max_rows = 65535 tenant=sys;
alter system set _rowsets_max_rows = 65535 tenant=all_user;
alter system set _rowsets_max_rows = 65535 tenant=all_meta;
--sleep 2

connection default;
--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1 (c1 int, c2 varchar(255), c3 varchar(255));
select c1 from t1;
select c1,c2 from t1;
select c1,c2,c3 from t1;

drop table t1;
connection syscon;
alter system set _rowsets_max_rows = 256 tenant=sys;
alter system set _rowsets_max_rows = 256 tenant=all_user;
alter system set _rowsets_max_rows = 256 tenant=all_meta;
