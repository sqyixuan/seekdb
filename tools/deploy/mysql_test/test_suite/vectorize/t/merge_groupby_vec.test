# owner: zuojiao.hzj
# owner group: sql2

--result_format 4
--explain_protocol 0
connect (syscon, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection syscon;
alter system set _rowsets_enabled=true tenant=sys;
alter system set _rowsets_enabled=true tenant=all_user;
alter system set _rowsets_enabled=true tenant=all_meta;
alter system set _rowsets_max_rows = 2 tenant=sys;
alter system set _rowsets_max_rows = 2 tenant=all_user;
alter system set _rowsets_max_rows = 2 tenant=all_meta;
--sleep 2
connection default;

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1 (c1 number, c2 number, primary key(c1,c2));
insert into t1 values (1,11),(2,12),(3,13),(4,14),(5,15),(6,16),(7,17),(8,18),(9,19),(10,20),(11,21),(12,22),(13,23),(14,24),(15,25),(16,26),(17,27),(18,28),(19,29),(20,30),(21,31),(22,32),(23,33),(24,34),(25,35),(26,36),(27,37),(28,38),(29,39),(30,40),(31,41),(32,42),(33,43),(34,44),(35,45),(36,46),(37,47),(38,48),(39,49),(40,50);

##do select ahead of explain to let optimizer know exact cost
select * from t1;

explain select c1,c2,sum(c1),count(c1) from t1 group by c1;
select c1,c2,sum(c1),count(c1) from t1 group by c1;

explain select c1,c2,sum(c1*c2),count(c1) from t1 group by c1;
select c1,c2,sum(c1*c2),count(c1) from t1 group by c1;

explain select c1,c2,sum(c1+c2),count(c1) from t1 group by c1;
select c1,c2,sum(c1+c2),count(c1) from t1 group by c1;

explain select c1,c2,sum(2*c2),count(2*c1) from t1 group by c1;
select c1,c2,sum(2*c2),count(2*c1) from t1 group by c1;

--echo ## test empty table
delete from t1;

select * from t1;
explain select c1,sum(c1),count(c1) from t1 group by c1;
select c1,sum(c1),count(c1) from t1 group by c1;

--disable_warnings
drop table if exists t1;
--enable_warnings
connection syscon;
alter system set _rowsets_max_rows = 256 tenant=sys;
alter system set _rowsets_max_rows = 256 tenant=all_user;
alter system set _rowsets_max_rows = 256 tenant=all_meta;
--sleep 2
