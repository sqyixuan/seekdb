# owner: xiaoyi.xy
#tags: optimizer
# owner group: SQL2
#

connect (syscon, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
alter system flush plan cache  global;
alter system set _rowsets_enabled =  true tenant=sys;
alter system set _rowsets_enabled =  true tenant=all_user;
alter system set _rowsets_enabled =  true tenant=all_meta;
alter system set _rowsets_max_rows = 100 tenant=sys;
alter system set _rowsets_max_rows = 100 tenant=all_user;
alter system set _rowsets_max_rows = 100 tenant=all_meta;

--disable_query_log
#call oceanbase.drop_tenant_force('dump_tenant');
#call oceanbase.create_mysql_tenant_mini('dump_tenant');
--source mysql_test/include/check_tenant_sync.inc
--enable_query_log

let $t_id = query_get_value(select 1 as t_id,t_id, 1);
--enable_result_log
--enable_query_log
--source mysql_test/include/check_tenant_sync.inc
sleep 2;

connect (conn1,$OBMYSQL_MS0,root,,test,$OBMYSQL_PORT);
alter system set _rowsets_enabled =  true;
alter system set _rowsets_max_rows = 100;

--disable_warnings
--error 0,1051
drop table t333_var;
--enable_warnings

set  ob_query_timeout=400000000;
set  ob_trx_timeout=400000000;

create table t333_var(c0 bigint ,c1 varchar(4000), c2 varchar(4000), c3 varchar(4000), c4 varchar(4000), c5 varchar(4000),c6 varchar(4000), c7 varchar(4000));

insert into t333_var values(1,repeat('ab',1000),repeat('ab',1000),repeat('ab',1000),repeat('ab',1000),repeat('ab',1000),repeat('ab',1000),repeat('a',4000));
insert into t333_var select c0+1,c1,c2,c3,c4,c5,c6,c7 from t333_var;
insert into t333_var select c0+10,c1,c2,c3,c4,c5,c6,c7 from t333_var;
insert into t333_var select c0+100,c1,c2,c3,c4,c5,c6,c7 from t333_var;
insert into t333_var select c0+1000,c1,c2,c3,c4,c5,c6,c7 from t333_var;
insert into t333_var select c0+10000,c1,c2,c3,c4,c5,c6,c7 from t333_var;
insert into t333_var select c0+100000,c1,c2,c3,c4,c5,c6,c7 from t333_var;
insert into t333_var select c0+1000000,c1,c2,c3,c4,c5,c6,c7 from t333_var;
insert into t333_var select c0+10000000,c1,c2,c3,c4,c5,c6,c7 from t333_var;
insert into t333_var select c0+100000000,c1,c2,c3,c4,c5,c6,c7 from t333_var;
insert into t333_var select c0+1000000000,c1,c2,c3,c4,c5,c6,c7 from t333_var;
insert into t333_var select c0+10000000000,c1,c2,c3,c4,c5,c6,c7 from t333_var;
insert into t333_var select c0+100000000000,c1,c2,c3,c4,c5,c6,c7 from t333_var;
commit;

create index idx_t333_01 on t333_var(c0);



alter system set _sort_area_size='2M';
alter system set _hash_area_size='4M';
##hash groupby
explain select/*+USE_HASH_AGGREGATION*/ min(a.c0), sum(length(a.c1)),sum(length(a.c2)),sum(length(a.c3)),sum(length(a.c4)),sum(length(a.c5)),sum(length(a.c6)),sum(length(a.c7)) from t333_var a group by a.c0,a.c1,a.c2,a.c3,a.c4,a.c4,a.c5,a.c6,a.c7 order by 1;
select/*+USE_HASH_AGGREGATION*/ min(a.c0), sum(length(a.c1)),sum(length(a.c2)),sum(length(a.c3)),sum(length(a.c4)),sum(length(a.c5)),sum(length(a.c6)),sum(length(a.c7)) from t333_var a group by a.c0,a.c1,a.c2,a.c3,a.c4,a.c4,a.c5,a.c6,a.c7 order by 1;

alter system set _sort_area_size='100M';
alter system set _hash_area_size='100M';
sleep 2;


alter system set _force_hash_groupby_dump = true;
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(c1 int, c2 int);
insert into t1 values(1,1),(1,2),(2,3);

--echo
--echo ## test one batch
explain select/*+USE_HASH_AGGREGATION one_batch*/ c1, count(c2), avg(c2), sum(c2 + 1), min(c2*2), max(c2 - 1) from t1 group by  c1;
select/*+USE_HASH_AGGREGATION one_batch*/ c1, count(c2), avg(c2), sum(c2 + 1), min(c2*2), max(c2 - 1) from t1 group by  c1;
select/*+one_batch*/ count(c2), avg(c2), sum(c2 + 1), min(c2*2), max(c2 - 1) from t1;

--echo
--echo ## test one batch with skip
explain select/*+USE_HASH_AGGREGATION one_batch*/ c1, count(c2), avg(c2), sum(c2 + 1), min(c2*2), max(c2 - 1) from t1 where c2 % 2 = 1 group by  c1;
select/*+USE_HASH_AGGREGATION one batch*/ c1, count(c2), avg(c2), sum(c2 + 1), min(c2*2), max(c2 - 1) from t1 where c2 % 2 = 1 group by  c1;
select/*+one batch*/ count(c2), avg(c2), sum(c2 + 1), min(c2*2), max(c2 - 1) from t1 where c2 % 2 = 1;

--echo
--echo ## test multi batch
insert into t1 values(2,4),(2,5),(2,6), (2,7), (null,8), (3,9), (3,10), (3,11), (3,null), (3,null), (3,14), (3,15), (3,16), (4,1);

explain select/*+USE_HASH_AGGREGATION multi_batch*/ c1, count(c2), sum(c2 + 1), avg(c2 * 5) from t1 group by  c1;
select/*+USE_HASH_AGGREGATION multi_batch*/ c1, count(c2), avg(c2), sum(c2 + 1), min(c2*2), max(c2 - 1) from t1 group by  c1;
select/*+multi_batch*/ count(c2), avg(c2), sum(c2 + 1), min(c2*2), max(c2 - 1) from t1;

--echo
--echo ## test multi batch with skip
explain select/*+USE_HASH_AGGREGATION multi_batch*/ c1, count(c2), avg(c2), sum(c2 + 1), min(c2*2), max(c2 - 1) from t1 where c2 % 2 = 0 group by  c1;
select/*+USE_HASH_AGGREGATION multi_batch*/ c1, count(c2), avg(c2), sum(c2 + 1), min(c2*2), max(c2 - 1) from t1 where c2 % 2 = 0 group by  c1;

--echo ## test implicit agg
select/*+multi_batch*/ c1, count(c2), sum(c2), avg(c1) from t1 where c2 % 2 = 0;

drop table t1;
alter system set _force_hash_groupby_dump = false;

connection conn1;
drop table t333_var;

connection syscon;
--disable_query_log
#call oceanbase.drop_tenant_force('dump_tenant');
--enable_query_log
alter system set _rowsets_max_rows = 256 tenant=sys;
alter system set _rowsets_max_rows = 256 tenant=all_user;
alter system set _rowsets_max_rows = 256 tenant=all_meta;
