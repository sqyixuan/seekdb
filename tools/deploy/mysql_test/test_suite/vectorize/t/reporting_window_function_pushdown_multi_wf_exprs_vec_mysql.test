# owner: dachuan.sdc
# owner group: sql2
# tags: optimizer, px
--result_format 4

## VECTORIZED
connect (syscon, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection syscon;
## 使用错误注入 EN_ENFORCE_PUSH_DOWN_WF，无视 ndv 和 dop 的关系，强行让可以走两阶段下压的 window function 走两阶段下压
alter system set_tp tp_no = 247, error_code = 4000, frequency = 1;
--sleep 2
connection default;
alter system set _rowsets_enabled = true;
alter system set _rowsets_max_rows = 16;

## 准备数据
--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE TABLE t1
WITH RECURSIVE my_cte(c1, c2, c3, c4) AS
(
  SELECT 0, 0, 1, 1
  UNION ALL
  SELECT round((c4 + 1) / 5, 0), round((c4 + 1) / 3, 0), round((c4 + 1) / 2, 0), c4 + 1  FROM my_cte WHERE c4 < 15
)
SELECT * FROM my_cte;
call dbms_stats.gather_table_stats('TEST', 'T1', method_opt=>'for all columns size auto', estimate_percent=>100);
select * from t1;

## 默认开启 reporting wf 两阶段下压
#alter session force parallel query parallel 3;
set _windowfunc_optimization_settings = 0;

alter system set _rowsets_max_rows = 16;
--source mysql_test/test_suite/vectorize/t/reporting_window_function_pushdown_multi_wf_exprs_test.sql

alter system set _rowsets_max_rows = 8;
--source mysql_test/test_suite/vectorize/t/reporting_window_function_pushdown_multi_wf_exprs_test.sql

alter system set _rowsets_max_rows = 4;
--source mysql_test/test_suite/vectorize/t/reporting_window_function_pushdown_multi_wf_exprs_test.sql

alter system set _rowsets_max_rows = 2;
--source mysql_test/test_suite/vectorize/t/reporting_window_function_pushdown_multi_wf_exprs_test.sql

alter system set _rowsets_max_rows = 1;
--source mysql_test/test_suite/vectorize/t/reporting_window_function_pushdown_multi_wf_exprs_test.sql



## 关闭 reporting wf 两阶段下压
set _windowfunc_optimization_settings = 2;
alter system flush plan cache;

alter system set _rowsets_max_rows = 16;
--source mysql_test/test_suite/vectorize/t/reporting_window_function_pushdown_multi_wf_exprs_test.sql

alter system set _rowsets_max_rows = 8;
--source mysql_test/test_suite/vectorize/t/reporting_window_function_pushdown_multi_wf_exprs_test.sql

alter system set _rowsets_max_rows = 4;
--source mysql_test/test_suite/vectorize/t/reporting_window_function_pushdown_multi_wf_exprs_test.sql

alter system set _rowsets_max_rows = 2;
--source mysql_test/test_suite/vectorize/t/reporting_window_function_pushdown_multi_wf_exprs_test.sql

alter system set _rowsets_max_rows = 1;
--source mysql_test/test_suite/vectorize/t/reporting_window_function_pushdown_multi_wf_exprs_test.sql

## clean up
connection syscon;
alter system set_tp tp_no = 247, error_code = 4000, frequency = 0;

connection default;
alter system set _rowsets_enabled = true;
set _windowfunc_optimization_settings = 0;
drop table t1;
