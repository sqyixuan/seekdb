# owner: zongmei.zzm
# owner group: sql2

--disable_abort_on_error
--result_format 4

connect (syscon, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection syscon;
--disable_query_log
alter system set _rowsets_enabled=true tenant=sys;
alter system set _rowsets_enabled=true tenant=all_user;
alter system set _rowsets_enabled=true tenant=all_meta;
--enable_query_log

--sleep 1
connection default;

# small table test
--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1 (a int, b float, c double, d varchar(32), e char(32));

insert into t1 values (1, 2.1234, 3.4567, "is_not_null_vec_test", "test_is_not_null_vec");
insert into t1 values (null, 2.1234, 3.4567, "is_not_null_vec_test", "test_is_not_null_vec");
insert into t1 values (1, null, 3.4567, "is_not_null_vec_test", "test_is_not_null_vec");
insert into t1 values (1, 2.1234, null, "is_not_null_vec_test", "test_is_not_null_vec");
insert into t1 values (1, 2.1234, 3.4567, null, "test_is_not_null_vec");
insert into t1 values (1, 2.1234, 3.4567, "is_not_null_vec_test", null);
insert into t1 values (null, null, null, null, null);

select (a is not null), (b is not null), (c is not null), (d is not null), (e is not null) from t1;

--enable_query_log
drop table t1;
