select partition_key(c2), partition_key(c1, c2), partition_key(c1, c2, c3, c4), partition_key(c1, 1), partition_key(1, c2) from t1;
select partition_key(c2), partition_key(c1, c2), partition_key(c1, c2, c3, c4), partition_key(c1, 1), partition_key(1, c2) from t1;

--disable_warnings
drop table if exists t1;
--enable_warnings
connection syscon;
alter system set _rowsets_max_rows = 256 tenant=sys;
alter system set _rowsets_max_rows = 256 tenant=all_user;
alter system set _rowsets_max_rows = 256 tenant=all_meta;
--sleep 2
