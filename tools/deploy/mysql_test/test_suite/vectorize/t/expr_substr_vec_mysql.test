set _enable_rich_vector_format = true;
select substr(c1, 1) from t_god_of_war;
select substr(c1, 1, 2) from t_god_of_war;
select substr(c1, -3) from t_god_of_war;
select substr(c1, -3, 2) from t_god_of_war;
select substr(lower(c1), 1) from t_god_of_war;
select substr(upper(c1), 1) from t_god_of_war;
select lower(substr(c1, 1)) from t_god_of_war;
select upper(substr(c1, 1)) from t_god_of_war;

--disable_warnings
drop table t_god_of_war;
--enable_warnings

connection syscon;
alter system set _rowsets_max_rows = 256 tenant=sys;
alter system set _rowsets_max_rows = 256 tenant=all_user;
alter system set _rowsets_max_rows = 256 tenant=all_meta;
