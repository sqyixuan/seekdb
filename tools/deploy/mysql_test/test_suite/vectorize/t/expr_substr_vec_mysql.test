# owner: dachuan.sdc
#tags: optimizer
# owner group: sql2
--result_format 4
--explain_protocol 0

connect (syscon, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection syscon;
alter system set _rowsets_enabled=true tenant=sys;
alter system set _rowsets_enabled=true tenant=all_user;
alter system set _rowsets_enabled=true tenant=all_meta;
alter system set _rowsets_max_rows = 3 tenant=sys;
alter system set _rowsets_max_rows = 3 tenant=all_user;
alter system set _rowsets_max_rows = 3 tenant=all_meta;
--sleep 2

connection default;
--disable_warnings
drop table if exists t_god_of_war;
--enable_warnings


create table t_god_of_war (c1 char(30), c2 int, c3 int);
