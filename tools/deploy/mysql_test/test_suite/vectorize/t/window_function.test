# owner: dachuan.sdc
# owner group: sql2
# description: test vectorized window function

connect (syscon, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection syscon;
alter system set _rowsets_enabled=true tenant=sys;
alter system set _rowsets_enabled=true tenant=all_user;
alter system set _rowsets_enabled=true tenant=all_meta;
alter system set _rowsets_max_rows = 256 tenant=sys;
alter system set _rowsets_max_rows = 256 tenant=all_user;
alter system set _rowsets_max_rows = 256 tenant=all_meta;


connection default;

--disable_warnings
drop table if exists t15;
drop table if exists t17;
drop table if exists t2;
drop table if exists t10;
drop table if exists t14;
drop table if exists t18;
drop table if exists t7;
drop table if exists t9;
drop table if exists t13;
drop table if exists t12;
--enable_warnings

create table t15(c1 int, c14 int, c2 int);
create table t17(c6 int, c3 int);
create table t2(c1 int, c14 int, c2 int, c8 int);
create table t10(c1 int, c14 int, c2 int, c8 int, c6 int);
create table t14(c6 int, c3 int);
create table t18(c6 int, c3 int);
create table t7(c6 int, c3 int);
create table t9(c6 int, c3 int);
create table t13(c2 int, c6 int);
create table t12(c8 int);

select   7 as sc0,  if( EXISTS ( select   59 as sc0,  84 as sc1,  ref_2.c2 as sc2,  6 as sc3,  subq_0.sc1 as sc4,  54 as sc5,  32 as sc6,  23 as sc7,  if( EXISTS ( select   81 as sc0,  81 as sc1,  20 as sc2,  88 as sc3,  27 as sc4,  78 as sc5 from  t17 as ref_3 where EXISTS ( select   25 as sc0,  8 as sc1,  33 as sc2,  59 as sc3,  23 as sc4,  90 as sc5 from  t15 as ref_4 where (55 + 26)  and (55 - 7) limit 62)) , 44 , 44 )  as sc8,  55 as sc9,  5 as sc10,   LAST_VALUE( cast(cast(null as CHAR) as CHAR)) over (partition by ref_2.c14,subq_0.sc1 order by ref_2.c8) as sc11,  5 as sc12,  99 as sc13,  case when 1 then 43 else 47 end  as sc14,  23 as sc15,  36 as sc16,  if( EXISTS ( select   100 as sc0 from  t2 as ref_5 where 1 < 96 limit 154) , 78 , 76 )  as sc17,  ref_2.c6 as sc18,  51 as sc19,  45 as sc20,  89 as sc21,  98 as sc22 from  t10 as ref_2 where ref_2.c14 in ( ref_2.c14,  98)) , case when 81 < 38 then 87 else subq_0.sc1 end  , subq_0.sc1 )  as sc1,  cast(coalesce(subq_0.sc1, (select c3 from t14 order by 1 desc  limit 1 offset 2) ) as DECIMAL) as sc2 from  (select   ref_0.c6 as sc0,  cast(sleep(1) as DECIMAL) as sc1 from  t14 as ref_0 where (EXISTS ( select   76 as sc0,  73 as sc1,  21 as sc2,  1 as sc3,  15 as sc4,  20 as sc5 from  t10 as ref_1 where 15 not  in ( 85,  45,  24)))  or (69 in ( 1))) as subq_0 where EXISTS ( select   22 as sc0 from  t13 as ref_6 where EXISTS ( select   ref_6.c2 as sc0 from  (t12 as ref_7 right join t18 as ref_8 on (ref_7.c8 = ref_8.c3 )) where EXISTS ( select distinct  41 as sc0,  22 as sc1,  37 as sc2,  50 as sc3,  69 as sc4,  25 as sc5,  20 as sc6,  83 as sc7,  62 as sc8 from  t9 as ref_9 where EXISTS ( select   11 as sc0,  67 as sc1,  5 as sc2,  99 as sc3,  80 as sc4,  8 as sc5,  12 as sc6,  77 as sc7,  84 as sc8,  63 as sc9 from  t17 as ref_10 where EXISTS ( select   60 as sc0,  17 as sc1 from  t9 as ref_11 where EXISTS ( select   53 as sc0,  94 as sc1,  59 as sc2,  71 as sc3 from  t7 as ref_12 where 79 in ( 100,  43)) limit 75) limit 82))) limit 144);

drop table if exists t15;
drop table if exists t17;
drop table if exists t2;
drop table if exists t10;
drop table if exists t14;
drop table if exists t18;
drop table if exists t7;
drop table if exists t9;
drop table if exists t13;
drop table if exists t12;

connection syscon;
--sleep 2
