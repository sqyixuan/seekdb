##do select ahead of explain to let optimizer know exact cost
select * from t1;

explain select c1, c2, c3, c4, count(c1), count(c2), count(c3), count(c4), sum(c1), sum(c2), sum(c3), sum(c4), min(c1), min(c2), min(c3), min(c4), max(c1), max(c2), max(c3), max(c4), avg(c1), avg(c2), avg(c3), avg(c4) from t1;
select c1, c2, c3, c4, count(c1), count(c2), count(c3), count(c4), sum(c1), sum(c2), sum(c3), sum(c4), min(c1), min(c2), min(c3), min(c4), max(c1), max(c2), max(c3), max(c4), avg(c1), avg(c2), avg(c3), avg(c4) from t1;

--echo ##no vectorization for distinct
explain select c1, c2, c3, c4, count(distinct c1), count(c2), count(c3), count(c4), sum(c1), sum(c2), sum(c3), sum(c4), min(c1), min(c2), min(c3), min(c4), max(c1), max(c2), max(c3), max(c4), avg(c1), avg(c2), avg(c3), avg(c4) from t1;
select c1, c2, c3, c4, count(distinct c1), count(c2), count(c3), count(c4), sum(c1), sum(c2), sum(c3), sum(c4), min(c1), min(c2), min(c3), min(c4), max(c1), max(c2), max(c3), max(c4), avg(c1), avg(c2), avg(c3), avg(c4) from t1;

--disable_warnings
drop table if exists t1;
--enable_warnings

--echo ## scalar group by on generated colunm, and the table is empty
create table t1(c1 int primary key, c2 int generated always as (c1 + 1) stored);
explain select c2, max(c2) as aggr FROM t1  where c2 in (select c2 FROM t1  where c2 > 1);
select c2, max(c2) as aggr FROM t1  where c2 in (select c2 FROM t1  where c2 > 1);
drop table t1;

create table t1(c1 int primary key, c2 int generated always as (c1 + 1) virtual);
explain select c2, max(c2) as aggr FROM t1  where c2 in (select c2 FROM t1  where c2 > 1);
select c2, max(c2) as aggr FROM t1  where c2 in (select c2 FROM t1  where c2 > 1);
drop table t1;

--disable_warnings
drop table if exists t1;
--enable_warnings
connection syscon;
alter system set _rowsets_max_rows = 256 tenant=sys;
alter system set _rowsets_max_rows = 256 tenant=all_user;
alter system set _rowsets_max_rows = 256 tenant=all_meta;
--sleep 2
