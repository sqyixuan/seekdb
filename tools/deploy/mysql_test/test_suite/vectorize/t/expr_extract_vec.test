# owner: dachuan.sdc
#tags: optimizer
# owner group: sql2
--result_format 4
--explain_protocol 0

connect (syscon, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection syscon;
alter system set _rowsets_enabled=true tenant=sys;
alter system set _rowsets_enabled=true tenant=all_user;
alter system set _rowsets_enabled=true tenant=all_meta;
alter system set _rowsets_max_rows = 10 tenant=sys;
alter system set _rowsets_max_rows = 10 tenant=all_user;
alter system set _rowsets_max_rows = 10 tenant=all_meta;
--sleep 2

connection default;
--disable_warnings
drop table if exists t_extract_vec_1;
drop table if exists t_extract_vec_2;
--enable_warnings


## prepare data
create table t_extract_vec_1(c1 datetime, c2 timestamp, c3 date, c4 time);
create table t_extract_vec_2(c1 bigint, c2 float, c3 double, c4 varchar(30), c5 varchar(30), c6 varchar(30));
let $cnt = 10;
let $idx = 1;
while ($idx <= $cnt)
{
  insert into t_extract_vec_1 values('1234-12-12 01:23:45', '2020-01-01 01:23:45', '1234-12-12', '01:23:45');
  insert into t_extract_vec_1 values('2000-2-29 01:23:45.678', '2000-2-29 01:23:45.678', '2000-2-29', '01:23:45.678');
