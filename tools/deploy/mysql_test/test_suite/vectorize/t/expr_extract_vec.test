  inc $idx;
}


## test when param2 is null 
select extract(MICROSECOND from null) from t_extract_vec_1;
select extract(SECOND from null) from t_extract_vec_1;
select extract(MINUTE from null) from t_extract_vec_1;
select extract(HOUR from null) from t_extract_vec_1;
select extract(DAY from null) from t_extract_vec_1;
select extract(WEEK from null) from t_extract_vec_1;
select extract(MONTH from null) from t_extract_vec_1;
select extract(QUARTER from null) from t_extract_vec_1;
select extract(YEAR from null) from t_extract_vec_1;
select extract(SECOND_MICROSECOND from null) from t_extract_vec_1;
select extract(MINUTE_MICROSECOND from null) from t_extract_vec_1;
select extract(MINUTE_SECOND from null) from t_extract_vec_1;
select extract(HOUR_MICROSECOND from null) from t_extract_vec_1;
select extract(HOUR_SECOND from null) from t_extract_vec_1;
select extract(HOUR_MINUTE from null) from t_extract_vec_1;
select extract(DAY_MICROSECOND from null) from t_extract_vec_1;
select extract(DAY_SECOND from null) from t_extract_vec_1;
select extract(DAY_MINUTE from null) from t_extract_vec_1;
select extract(DAY_HOUR from null) from t_extract_vec_1;
select extract(YEAR_MONTH from null) from t_extract_vec_1;


## test in t_extract_vec_1
let $cnt = 3;
let $idx = 1;
while ($idx <= $cnt)
{
  eval select c$idx, extract(MICROSECOND from c$idx) from t_extract_vec_1;
  eval select c$idx, extract(SECOND from c$idx) from t_extract_vec_1;
  eval select c$idx, extract(MINUTE from c$idx) from t_extract_vec_1;
  eval select c$idx, extract(HOUR from c$idx) from t_extract_vec_1;
  eval select c$idx, extract(DAY from c$idx) from t_extract_vec_1;
  eval select c$idx, extract(WEEK from c$idx) from t_extract_vec_1;
  eval select c$idx, extract(MONTH from c$idx) from t_extract_vec_1;
  eval select c$idx, extract(QUARTER from c$idx) from t_extract_vec_1;
  eval select c$idx, extract(YEAR from c$idx) from t_extract_vec_1;
  eval select c$idx, extract(SECOND_MICROSECOND from c$idx) from t_extract_vec_1;
  eval select c$idx, extract(MINUTE_MICROSECOND from c$idx) from t_extract_vec_1;
  eval select c$idx, extract(MINUTE_SECOND from c$idx) from t_extract_vec_1;
  eval select c$idx, extract(HOUR_MICROSECOND from c$idx) from t_extract_vec_1;
  eval select c$idx, extract(HOUR_SECOND from c$idx) from t_extract_vec_1;
  eval select c$idx, extract(HOUR_MINUTE from c$idx) from t_extract_vec_1;
  eval select c$idx, extract(DAY_MICROSECOND from c$idx) from t_extract_vec_1;
  eval select c$idx, extract(DAY_SECOND from c$idx) from t_extract_vec_1;
  eval select c$idx, extract(DAY_MINUTE from c$idx) from t_extract_vec_1;
  eval select c$idx, extract(DAY_HOUR from c$idx) from t_extract_vec_1;
  eval select c$idx, extract(YEAR_MONTH from c$idx) from t_extract_vec_1;
  inc $idx;
}


