  insert into t_extract_vec_2 values(12366, 12366.56, 12366.56, '12366', '1:23:66', '1-23-66');
  insert into t_extract_vec_2 values(80506, 80506.56, 80506.56, '80506.5', '8:05:06', '8-05-06');
  insert into t_extract_vec_2 values(123456, 123456.12, 123456.12, '123456', '12:34:56', '12-34-56');
  insert into t_extract_vec_2 values(123456, 123456.12, 123456.12, '123456.1', '12:34:56.1', '12-34-56.1');
  insert into t_extract_vec_2 values(120320, 120320.12, 120320.12, '120320.1', '12:03:20.5', '12-03-20.5');
  insert into t_extract_vec_2 values(8385959, 8385959.12, 8385959.12, '8385959', '838:59:59', '838-59-59');
