# owner: xiaoyi.xy
#tags: optimizer
# owner group: SQL2
--result_format 4
--explain_protocol 2

connect (syscon, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);

alter system flush plan cache  global;
alter system set _rowsets_enabled=true tenant=sys;
alter system set _rowsets_enabled=true tenant=all_user;
alter system set _rowsets_enabled=true tenant=all_meta;
alter system set _rowsets_max_rows = 100 tenant=sys;
alter system set _rowsets_max_rows = 100 tenant=all_user;
alter system set _rowsets_max_rows = 100 tenant=all_meta;

#--disable_query_log
#call oceanbase.drop_tenant_force('dump_tenant');
#call oceanbase.create_mysql_tenant_mini('dump_tenant');
--source mysql_test/include/check_tenant_sync.inc

let $t_id = query_get_value(select tenant_id as t_id from oceanbase.__all_tenant where tenant_name = 'sys' limit 1,t_id, 1);
--enable_result_log
--enable_query_log
sleep 2;

connect (conn1,$OBMYSQL_MS0,root,,test,$OBMYSQL_PORT);

alter system set _rowsets_enabled=true;
alter system set _rowsets_max_rows = 100;
--disable_warnings
--error 0,1051
drop table t1;
--error 0,1051
drop table t111_var;
--error 0,1051
drop table t333_var;
--enable_warnings

create table t111_var(c0 bigint primary key,c1 varchar(4000), c2 varchar(4000), c3 varchar(4000), c4 varchar(4000), c5 varchar(4000),c6 varchar(4000), c7 varchar(4000));

set ob_query_timeout = 1000000000;
set  ob_query_timeout=400000000;
set  ob_trx_timeout=400000000;
insert/*trace*/ into t111_var values(1,repeat('ab',1000),repeat('ab',1000),repeat('ab',1000),repeat('ab',1000),repeat('ab',1000),repeat('ab',1000),repeat('a',4000));
insert/*trace*/ into t111_var select c0+1,c1,c2,c3,c4,c5,c6,c7 from t111_var;
insert/*trace*/ into t111_var select c0+10,c1,c2,c3,c4,c5,c6,c7 from t111_var;
insert/*trace*/ into t111_var select c0+100,c1,c2,c3,c4,c5,c6,c7 from t111_var;
insert/*trace*/ into t111_var select c0+1000,c1,c2,c3,c4,c5,c6,c7 from t111_var;
insert/*trace*/ into t111_var select c0+10000,c1,c2,c3,c4,c5,c6,c7 from t111_var;
insert/*trace*/ into t111_var select c0+100000,c1,c2,c3,c4,c5,c6,c7 from t111_var;
insert/*trace*/ into t111_var select c0+1000000,c1,c2,c3,c4,c5,c6,c7 from t111_var;
insert/*trace*/ into t111_var select c0+10000000,c1,c2,c3,c4,c5,c6,c7 from t111_var;
insert/*trace*/ into t111_var select c0+100000000,c1,c2,c3,c4,c5,c6,c7 from t111_var;
insert/*trace*/ into t111_var select c0+1000000000,c1,c2,c3,c4,c5,c6,c7 from t111_var;
insert/*trace*/ into t111_var select c0+10000000000,c1,c2,c3,c4,c5,c6,c7 from t111_var;
insert/*trace*/ into t111_var select c0+100000000000,c1,c2,c3,c4,c5,c6,c7 from t111_var;
commit;
create table t333_var(c0 bigint ,c1 varchar(4000), c2 varchar(4000), c3 varchar(4000), c4 varchar(4000), c5 varchar(4000),c6 varchar(4000), c7 varchar(4000));

insert/*trace*/ into t333_var values(1,repeat('ab',1000),repeat('ab',1000),repeat('ab',1000),repeat('ab',1000),repeat('ab',1000),repeat('ab',1000),repeat('a',4000));
insert/*trace*/ into t333_var select c0+1,c1,c2,c3,c4,c5,c6,c7 from t333_var;
insert/*trace*/ into t333_var select c0+10,c1,c2,c3,c4,c5,c6,c7 from t333_var;
insert/*trace*/ into t333_var select c0+100,c1,c2,c3,c4,c5,c6,c7 from t333_var;
insert/*trace*/ into t333_var select c0+1000,c1,c2,c3,c4,c5,c6,c7 from t333_var;
insert/*trace*/ into t333_var select c0+10000,c1,c2,c3,c4,c5,c6,c7 from t333_var;
insert/*trace*/ into t333_var select c0+100000,c1,c2,c3,c4,c5,c6,c7 from t333_var;
insert/*trace*/ into t333_var select c0+1000000,c1,c2,c3,c4,c5,c6,c7 from t333_var;
insert/*trace*/ into t333_var select c0+10000000,c1,c2,c3,c4,c5,c6,c7 from t333_var;
insert/*trace*/ into t333_var select c0+100000000,c1,c2,c3,c4,c5,c6,c7 from t333_var;
insert/*trace*/ into t333_var select c0+1000000000,c1,c2,c3,c4,c5,c6,c7 from t333_var;
insert/*trace*/ into t333_var select c0+10000000000,c1,c2,c3,c4,c5,c6,c7 from t333_var;
--error 0, 4013
insert/*trace*/ into t333_var select c0+100000000000,c1,c2,c3,c4,c5,c6,c7 from t333_var;
commit;


alter system set _sort_area_size='2M';
alter system set _hash_area_size='4M';
#alter system set workarea_size_policy = 'MANUAL';
#alter system set _force_hash_join_spill = true;
#alter system set _sort_area_size='100M';
#alter system set _hash_area_size='100M';
--error 0, 4013
select /*+ use_hash(a b) */ sum(a.c0),sum(length(a.c1)),sum(length(a.c2)),sum(length(a.c3)),sum(length(a.c4)),sum(length(a.c5)),sum(length(a.c6)),sum(length(a.c7)),
                            sum(b.c0),sum(length(b.c1)),sum(length(b.c2)),sum(length(b.c3)),sum(length(b.c4)),sum(length(b.c5)),sum(length(b.c6)),sum(length(b.c7))
from t111_var a,t333_var b where a.c0=b.c0;
drop table t333_var;

connection syscon;
alter system set _sort_area_size='100M';
alter system set _hash_area_size='100M';
alter system set _rowsets_max_rows = 3 tenant=sys;
alter system set _rowsets_max_rows = 3 tenant=all_user;
alter system set _rowsets_max_rows = 3 tenant=all_meta;

connection conn1;
alter system set _force_hash_join_spill = true;

--disable_warnings
drop table if exists t1, t2;
--enable_warnings
create table t1(c1 int, c2 int);
create table t2(c1 int, c2 int);
insert/*trace*/ into t1 values(1,1),(1,2), (2,3), (2,4), (3,5), (3,6), (4,7), (5,8), (6,9), (6,10);
insert/*trace*/ into t2 values(1,1),(1,2), (2,3), (5,8), (6,9), (6,10), (7,11);

--echo
--echo ***** test inner join
select /*+leading(t1,t2)*/ * from t1, t2 where t1.c1 = t2.c1;
select /*+leading(t2,t1)*/ * from t1, t2 where t1.c1 = t2.c1;

--echo
--echo ***** test inner join with other condition
select /*+leading(t1,t2)*/ * from t1, t2 where t1.c1 = t2.c1 and t1.c2 > t2.c2;
select /*+leading(t2,t1)*/ * from t1, t2 where t1.c1 = t2.c1 and t1.c2 > t2.c2;

--echo
--echo ***** test anti join
select /*+leading(t1,t2) use_hash(t2, t1)*/ * from t1 where not exists (select 1 from t2 where t1.c1 = t2.c1);
select /*+leading(t2, t1) use_hash(t2, t1)*/ * from t1 where not exists (select 1 from t2 where t1.c1 = t2.c1);

--echo
--echo *** test anti join with other condition
select /*+leading(t1,t2) use_hash(t2, t1)*/ * from t1 where not exists (select 1 from t2 where t1.c1 = t2.c1 and t1.c2 > t2.c2);
select /*+leading(t2, t1) use_hash(t2, t1)*/ * from t1 where not exists (select 1 from t2 where t1.c1 = t2.c1 and t1.c2 > t2.c2);

--echo
--echo ***** test semi join
select /*+leading(t1,t2) use_hash(t2, t1)*/ * from t1 where c1 in (select c1 from t2);
select /*+leading(t2, t1) use_hash(t2, t1)*/ * from t1 where c1 in (select c1 from t2);

--echo
--echo ***** test semi join with other condition
select /*+leading(t2, t1) USE_HASH(t1, t2)*/ * from t1 where exists (select 1 from t2 where t1.c1 = t2.c1 and t1.c2 > t2.c2);
select /*+leading(t1, t2) USE_HASH(t1, t2)*/ * from t1 where exists (select 1 from t2 where t1.c1 = t2.c1 and t1.c2 > t2.c2);

--echo
--echo ***** test left join
select /*+leading(t1,t2) use_hash(t1,t2)*/ * from t1 left join t2 on t1.c1 = t2.c1;
select /*+leading(t2, t1) use_hash(t1,t2)*/ * from t1 right join t2 on t1.c1 = t2.c1;

--echo
--echo ***** test left join with other condition
select /*+leading(t1,t2) use_hash(t1,t2)*/ * from t1 left join t2 on t1.c1 = t2.c1 and t1.c2 > t2.c2;
select /*+leading(t2, t1) use_hash(t1,t2)*/ * from t1 right join t2 on t1.c1 = t2.c1 and t1.c2 > t2.c2;

--echo
--echo ***** test right join
select /*+leading(t1,t2) use_hash(t1,t2)*/ * from t1 right join t2 on t1.c1 = t2.c1;
select /*+leading(t2, t1) use_hash(t1,t2)*/ * from t1 left join t2 on t1.c1 = t2.c1;

--echo
--echo ***** test right join with other condition
select /*+leading(t1,t2) use_hash(t1,t2)*/ * from t1 right join t2 on t1.c1 = t2.c1 and t1.c2 > t2.c2;
select /*+leading(t2, t1) use_hash(t1,t2)*/ * from t1 left join t2 on t1.c1 = t2.c1 and t1.c2 > t2.c2;

--echo
--echo ***** test full join
select /*+leading(t1,t2) use_hash(t1,t2)*/ * from t1 full join t2 on t1.c1 = t2.c1;
select /*+leading(t2, t1) use_hash(t1,t2)*/ * from t1 full join t2 on t1.c1 = t2.c1;

--echo
--echo ***** test full join with other condition
select /*+leading(t1,t2) use_hash(t1,t2)*/ * from t1 full join t2 on t1.c1 = t2.c1 and t1.c2 > t2.c2;
select /*+leading(t2, t1) use_hash(t1,t2)*/ * from t1 full join t2 on t1.c1 = t2.c1 and t1.c2 > t2.c2;

drop table t1, t2;
alter system set _force_hash_join_spill = false;

connection syscon;
alter system set _rowsets_max_rows = 256 tenant=sys;
alter system set _rowsets_max_rows = 256 tenant=all_user;
alter system set _rowsets_max_rows = 256 tenant=all_meta;
--disable_query_log
call oceanbase.drop_tenant_force('dump_tenant');
--enable_query_log
