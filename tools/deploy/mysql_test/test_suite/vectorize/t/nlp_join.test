# owner: xiaoyi.xy
#tags: optimizer
# owner group: sql2

--result_format 4
--explain_protocol 2

connect (admin,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection admin;
alter system flush plan cache global;
alter system set _rowsets_enabled=true tenant=sys;
alter system set _rowsets_enabled=true tenant=all_user;
alter system set _rowsets_enabled=true tenant=all_meta;
alter system set _rowsets_max_rows = 3 tenant=sys;
alter system set _rowsets_max_rows = 3 tenant=all_user;
alter system set _rowsets_max_rows = 3 tenant=all_meta;

connection default;
set _nlj_batching_enabled = false;

--disable_warnings
drop table if exists t1,t2;
--enable_warnings
create table t1(c1 int, c2 int);
create table t2(c1 int, c2 int);
insert/*trace*/ into t1 values(1,1),(1,2), (2,3), (2,4), (3,5), (3,6), (4,7), (5,8), (6,9), (6,10);
insert/*trace*/ into t2 values(1,1),(1,2), (2,3), (5,8), (6,9), (6,10), (7,11);

--echo
--echo ***** test inner join
select /*+leading(t1,t2) use_nl(t1, t2)*/ * from t1, t2 where t1.c1 = t2.c1;
select /*+leading(t2,t1) use_nl(t1, t2)*/ * from t1, t2 where t1.c1 = t2.c1;

--echo
--echo ***** test inner join with other condition
select /*+leading(t1,t2) use_nl(t1, t2)*/ * from t1, t2 where t1.c1 = t2.c1 and t1.c2 > t2.c2;
select /*+leading(t2,t1) use_nl(t1, t2)*/ * from t1, t2 where t1.c1 = t2.c1 and t1.c2 > t2.c2;

--echo
--echo ***** test semi join
select /*+leading(t1,t2) use_nl(t2, t1)*/ * from t1 where c1 in (select c1 from t2);
select /*+leading(t2, t1) use_nl(t2, t1)*/ * from t1 where c1 in (select c1 from t2);

--echo
--echo ***** test semi join with other condition
select /*+leading(t2, t1) use_nl(t1, t2)*/ * from t1 where exists (select 1 from t2 where t1.c1 = t2.c1 and t1.c2 > t2.c2);
select /*+leading(t1, t2) use_nl(t1, t2)*/ * from t1 where exists (select 1 from t2 where t1.c1 = t2.c1 and t1.c2 > t2.c2);

--echo
--echo ***** test anti join
select /*+leading(t1,t2) use_nl(t2, t1)*/ * from t1 where not exists (select 1 from t2 where t1.c1 = t2.c1);
select /*+leading(t2, t1) use_nl(t2, t1)*/ * from t1 where not exists (select 1 from t2 where t1.c1 = t2.c1);

--echo
--echo *** test anti join with other condition
select /*+leading(t1,t2) use_nl(t2, t1)*/ * from t1 where not exists (select 1 from t2 where t1.c1 = t2.c1 and t1.c2 > t2.c2);
select /*+leading(t2, t1) use_nl(t2, t1)*/ * from t1 where not exists (select 1 from t2 where t1.c1 = t2.c1 and t1.c2 > t2.c2);

--echo
--echo ***** test left join
select /*+leading(t1,t2) use_nl(t1,t2)*/ * from t1 left join t2 on t1.c1 = t2.c1;
select /*+leading(t2, t1) use_nl(t1,t2)*/ * from t1 right join t2 on t1.c1 = t2.c1;

--echo
--echo ***** test left join with other condition
select /*+leading(t1,t2) use_nl(t1,t2)*/ * from t1 left join t2 on t1.c1 = t2.c1 and t1.c2 > t2.c2;
select /*+leading(t2, t1) use_nl(t1,t2)*/ * from t1 right join t2 on t1.c1 = t2.c1 and t1.c2 > t2.c2;

drop table t1, t2;

--echo
--echo
--echo ***** test semi join
create table t1(c1 int, c2 int);
insert/*trace*/ into t1 values(1,1),(1,2),(1,3),(2,3),(2,4);
create table t2(c1 int, c2 int);
create index idx on t2(c1);
insert/*trace*/ into t2 values(1,1), (2,2), (2,2);
select/*+ leading(t1,t2) use_nl(t1, t2) index(t2, idx)*/ * from t1 where exists (select 1 from t2 where t1.c1 = t2.c1);
drop table t1, t2;

--echo
--echo ***** test inner join use bnlp
create table t1(c1 int, c2 int);
create table t2(c1 int primary key, c2 int);
insert/*trace*/ into t1 values(1,1),(1,2), (2,3), (2,4), (3,5), (3,6), (4,7), (5,8), (6,9), (6,10);
insert/*trace*/ into t2 values(1,1), (2,3), (5,8), (6,9), (7,11);
set _nlj_batching_enabled = true;
explain extended_noaddr select /*+leading(t1,t2) use_nl(t1, t2)*/ * from t1, t2 where t1.c1 = t2.c1;
select/*+leading(t1,t2) use_nl(t1, t2)*/ * from t1, t2 where t1.c1 = t2.c1;

--echo
--echo
--echo *** bug:
explain select /*+leading(t1,t2) use_nl(t1, t2)*/ t1.c1, t2.c1, t1.c1 + t2.c1 -1 from t1, t2 where t1.c1 = t2.c1;
select /*+leading(t1,t2) use_nl(t1, t2)*/ t1.c1, t2.c1, t1.c1 + t2.c1 -1 from t1, t2 where t1.c1 = t2.c1;
drop table t1, t2;


--echo
--echo
--echo ***** test batch semi join
create table t1(c1 int, c2 int);
insert/*trace*/ into t1 values(1,1),(1,2),(1,3),(2,3),(2,4);
create table t2(c1 int, c2 int);
create index idx on t2(c1);
insert/*trace*/ into t2 values(1,1), (2,2), (2,2);
explain extended_noaddr select/*+ leading(t1,t2) use_nl(t1, t2) index(t2, idx)*/ * from t1 where exists (select 1 from t2 where t1.c1 = t2.c1);
select/*+leading(t1,t2) use_nl(t1, t2) index(t2, idx)*/ * from t1 where exists (select 1 from t2 where t1.c1 = t2.c1);
drop table t1, t2;

--echo #bug: 

create table t1(c1 int, c2 int);
create table t2(c1 int , c2 int, index idx(c1, c2));
--disable_query_log
--disable_result_log
--let $loop=2000
while($loop > 0)
{
  eval insert/*trace*/ into t1 (c1, c2) values($loop % 100, $loop);
  dec $loop;
}
--let $loop=100
while($loop > 0)
{
  eval insert/*trace*/ into t2 (c1, c2) values($loop % 50, $loop);
  dec $loop;
}
--enable_query_log
--enable_result_log
explain extended_noaddr select /*+leading(t1,t2) use_nl(t1, t2)*/ * from t1, t2 where t1.c1 = t2.c1 and t1.c1 % 5 != 0 order by 1,2,3;
select/*+leading(t1,t2) use_nl(t1, t2)*/ * from t1, t2 where t1.c1 = t2.c1 and t1.c1 % 3 != 0 order by 1,2,3;

connection admin;
alter system set _rowsets_max_rows = 256 tenant=sys;
alter system set _rowsets_max_rows = 256 tenant=all_user;
alter system set _rowsets_max_rows = 256 tenant=all_meta;
set _nlj_batching_enabled = false;
