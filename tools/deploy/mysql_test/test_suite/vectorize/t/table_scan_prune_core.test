# owner: bin.lb
#tags: optimizer
# owner group: sql2

--result_format 4
--explain_protocol 0
connect (syscon, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection syscon;
alter system set _rowsets_enabled=true tenant=sys;
alter system set _rowsets_enabled=true tenant=all_user;
alter system set _rowsets_enabled=true tenant=all_meta;
--sleep 2
connection default;

--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1 (c1 int primary key, c2 int, c3 int, c4 varchar(100)) partition by key(c1) partitions 8;
insert into t1 (c1, c2, c3, c4) values
(1, 0, 1, 'abc1'), (2, 0, 0, 'abc2'), (3, 1, 1, 'abc3'), (4, 1, 1, 'abc4'), (5, 1, 0, 'abc5'), (6, 2, 1, 'abc6'), (7, 2, 1, 'abc7'), (8, 2, 0, 'abc8'), (9, 3, 1, 'abc9'), (10, 3, 1, 'abc10'), (11, 3, 0, 'abc11'), (12, 4, 1, 'abc12'), (13, 4, 1, 'abc13'), (14, 4, 0, 'abc14'), (15, 5, 1, 'abc15'), (16, 5, 1, 'abc16'), (17, 5, 0, 'abc17'), (18, 6, 1, 'abc18'), (19, 6, 1, 'abc19'), (20, 6, 0, 'abc20'), (21, 7, 1, 'abc21'), (22, 7, 1, 'abc22'), (23, 7, 0, 'abc23'), (24, 8, 1, 'abc24'), (25, 8, 1, 'abc25'), (26, 8, 0, 'abc26'), (27, 9, 1, 'abc27'), (28, 9, 1, 'abc28'), (29, 9, 0, 'abc29'), (30, 10, 1, 'abc30'), (31, 10, 1, 'abc31'), (32, 10, 0, 'abc32'), (33, 11, 1, 'abc33'), (34, 11, 1, 'abc34'), (35, 11, 0, 'abc35'), (36, 12, 1, 'abc36'), (37, 12, 1, 'abc37'), (38, 12, 0, 'abc38'), (39, 13, 1, 'abc39'), (40, 13, 1, 'abc40'), (41, 13, 0, 'abc41'), (42, 14, 1, 'abc42'), (43, 14, 1, 'abc43'), (44, 14, 0, 'abc44'), (45, 15, 1, 'abc45'), (46, 15, 1, 'abc46'), (47, 15, 0, 'abc47'), (48, 16, 1, 'abc48'), (49, 16, 1, 'abc49'), (50, 16, 0, 'abc50'), (51, 17, 1, 'abc51'), (52, 17, 1, 'abc52'), (53, 17, 0, 'abc53'), (54, 18, 1, 'abc54'), (55, 18, 1, 'abc55'), (56, 18, 0, 'abc56'), (57, 19, 1, 'abc57'), (58, 19, 1, 'abc58'), (59, 19, 0, 'abc59'), (60, 20, 1, 'abc60'), (61, 20, 1, 'abc61'), (62, 20, 0, 'abc62'), (63, 21, 1, 'abc63'), (64, 21, 1, 'abc64');

