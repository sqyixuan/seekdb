# owner: dengzhi.ldz
# description: pushdown status check for vectorized engine

--disable_query_log
set global max_allowed_packet=60000000;
set global ob_sql_work_area_percentage=80;
disconnect default;
sleep 1;
connect (default,$OBMYSQL_MS0,admin,admin,test,$OBMYSQL_PORT);
set @@recyclebin = off;
set ob_query_timeout=1000000000;
set ob_trx_timeout=1000000000;

--disable_warnings
drop table if exists t1;
--enable_warnings

# major table
create table t1 (a bigint auto_increment primary key, b bigint, c char(100), d varchar(1000)) row_format = dynamic block_size = 2048;
create index t_i on t1(b) local;
insert into t1 (a, b, c, d) values(1, 9, "a", repeat('a', 1000));
insert into t1 (a, b, c, d) values(2, 2, "ab", repeat("ab", 500));
insert into t1 (a, b, c, d) values(3, 5, "abcd", repeat("ab", 500));
insert into t1 (a, b, c, d) values(4, 7, NULL, repeat("abcd", 250));
insert into t1 (a, b, c, d) values(5, NULL, "ab c ", repeat("a", 1000));
insert into t1 (a, b, c, d) values(6, 9, NULL, repeat("abbb", 250));
insert into t1 (a, b, c, d) values(7, 1, "abc ", repeat("abcd", 250));
insert into t1 (a, b, c, d) values(8, 3, "abcde", NULL);
insert into t1 (a, b, c, d) values(9, 100, "abd", repeat("abc", 200));
--let $loop=5
while($loop > 0)
{
  eval insert into t1 (a, b, c, d) select a * 10 + $loop, b + 1, c, d from t1;
  dec $loop;
}
select count(1) from t1;

--disable_query_log
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
alter system set _rowsets_enabled=true tenant=sys;
alter system set _rowsets_enabled=true tenant=all_user;
alter system set _rowsets_enabled=true tenant=all_meta;
alter system flush plan cache global;
--enable_query_log

alter system major freeze tenant = sys;
alter system major freeze tenant = all_user;
alter system major freeze tenant = all_meta;
--source mysql_test/include/wait_daily_merge.inc

# minor table
--let $loop=5
while($loop > 0)
{
  eval insert into t1 (a, b, c, d) values($loop * 1000 + 90, 50, "ab", repeat("ab", 500));
  dec $loop;
}
select count(1) from t1;

connection obsys;
alter system minor freeze tenant = sys;
alter system minor freeze tenant = all_user;
alter system minor freeze tenant = all_meta;
--source mysql_test/include/wait_minor_merge.inc

# memtable
insert into t1 (a, b, c, d) values(10000, 0, "ab c", repeat('ab ', 300));
insert into t1 (a, b, c, d) values(1000000, 50, "abcd", repeat('abcd', 100));

# basic
select count(1) from t1;
select sum(a), sum(b) from t1;
select max(a), max(b), max(c) from t1;
select count(1) from t1 where b is null;
select count(1) from t1 where b is not null;
select sum(a + b) from t1 where c is null;
select sum(a + b) from t1 where c > "ab";

# get
select count(1) from t1 where a = 3;
select count(1) from t1 where a = 3 or a = 8 or a = 100;
select count(1) from t1 where a in (select b from t1 where b is not null);

# index back
create index t1_b_idx on t1(b);
select /*+ index(t1 primary) */ count(c) from t1 where b > 0;
select /*+ index(t1 t1_b_idx) */ count(c) from t1 where b > 0;
select /*+ index(t1 primary) */ count(c) from t1 where b is not null;
select /*+ index(t1 t1_b_idx) */ count(c) from t1 where b is not null;
select /*+ index(t1 primary) */ max(d) from t1 where b <> 8;
select /*+ index(t1 t1_b_idx) */ max(d) from t1 where b <> 8;

connection obsys;
alter system set _rowsets_max_rows = 8;
alter system flush plan cache;

connection default;
select /*+ index(t1 primary) */ count(c) from t1 where b > 0;
select /*+ index(t1 t1_b_idx) */ count(c) from t1 where b > 0;
select /*+ index(t1 primary) */ count(c) from t1 where b is not null;
select /*+ index(t1 t1_b_idx) */ count(c) from t1 where b is not null;
select /*+ index(t1 primary) */ max(d) from t1 where b <> 8;
select /*+ index(t1 t1_b_idx) */ max(d) from t1 where b <> 8;

connection obsys;
alter system set _rowsets_max_rows = 256;
alter system flush plan cache;

# pushdown status change
connection default;
select count(1) from t1 where b < 1;
select sum(b) from t1 where b > 1;
select sum(a + b) from t1 where c < "ab";

# skip micro block with empty rows returned
select sum(b) from t1 where b > 20;
select sum(a + b) from t1 where c > "abc";

# black/white filter 
select sum(a + b) from t1 where c like "abc%";
select sum(b) from t1 where c = "ab ";
select max(d) from t1 where c > "ab";
select sum(b) from t1 where c is null;
select sum(b) from t1 where b <> 8;
select max(c) from t1 where b is null;
select max(c) from t1 where b is not null;
select concat(d, c) from t1 where b > 4 and c > "ab ";
select sum(b) from t1 where a < 30 and a > 10 and b > 4 and c > "ab ";

# skip minor table
insert into t1 (a, b, c, d) values(1000001, 10, "a", repeat('a', 300));
select sum(b) from t1 where c < "ab";

# skip minor table and memtable
select * from t1 where b > 60;

# index back
select /*+ index(t1 t_i) */ * from t1 where b > 60;

drop table t1;

--disable_query_log
set global max_allowed_packet=16777216;
set global ob_sql_work_area_percentage=5;
set @@recyclebin = on;
connection obsys;
alter system flush plan cache global;
--enable_query_log
