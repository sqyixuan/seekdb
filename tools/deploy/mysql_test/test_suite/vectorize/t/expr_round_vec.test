--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: huangweixiang.hwx
# owner group: SQL2
# Test of round batch functions

--disable_abort_on_error
--result_format 4
connect (conn_admin, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,oceanbase,$OBMYSQL_PORT);
connection conn_admin;
alter system set _rowsets_enabled=true tenant=sys;
alter system set _rowsets_enabled=true tenant=all_user;
alter system set _rowsets_enabled=true tenant=all_meta;

--echo // sleep 2
--sleep 2

--disable_warnings
drop table if exists tbl_check_result, tbl_check_type;
--enable_warnings

create table tbl_check_result(col_int bigint, col_double double, col_decimal decimal(60, 5), col_varchar varchar(100));
insert into tbl_check_result values(null, null, null, null);
insert into tbl_check_result values(100, 100.0, 100.0, '100.0');
insert into tbl_check_result values(-100, -100.0, -100.0, '-100.0');
insert into tbl_check_result values(100.999, 100.999, 100.999, '100.999');
insert into tbl_check_result values(-100.999, -100.999, -100.999, '-100.999');
insert into tbl_check_result values(100.123, 100.123, 100.123, '100.123');
insert into tbl_check_result values(-100.123, -100.123, -100.123, '-100.123');
insert into tbl_check_result values(9223372036854775806.123, 9223372036854775807.123, 9223372036854775807.123, '9223372036854775807.123');
insert into tbl_check_result values(-9223372036854775806.123, -9223372036854775807.123, -9223372036854775807.123, '-9223372036854775807.123');
insert into tbl_check_result values(9223372036854775806.999, 9223372036854775807.999, 9223372036854775807.999, '9223372036854775807.999');
insert into tbl_check_result values(-9223372036854775806.999, -9223372036854775807.999, -9223372036854775807.999, '-9223372036854775807.999');

create table tbl_check_type (c1 int, c2 int unsigned, 
    c3 tinyint, c4 tinyint unsigned,
    c5 smallint, c6 smallint unsigned,
    c7 mediumint, c8 mediumint unsigned,
    c9 integer, c10 integer unsigned,
    c11 bigint, c12 bigint unsigned,
    c13 float, c14 float unsigned, 
    c15 double, c16 double unsigned, 
    c17 decimal, c18 decimal unsigned, 
    c19 datetime, c20 timestamp, 
    c21 varchar(30), c22 char(30));
    
insert into tbl_check_type values(1, 2, 
    1, 2, 
    1, 2, 
    1, 2, 
    1, 2, 
    1, 2, 
    3.5, 4.5, 
    5.5, 6.5,
    7.5, 8.5,
    '2019-12-01 12:00:00', '2019-12-03 06:00:00', 
    '9.5', '10.5');
insert into tbl_check_type values(-1, 2, 
    -1, 2, 
    -1, 2, 
    -1, 2, 
    -1, 2, 
    -1, 2, 
    -3.5, 4.5, 
    -5.5, 6.5,
    -7.5, 8.5,
    '2019-12-01 12:00:00', '2019-12-03 06:00:00', 
    '-9.5', '10.5');

set @@ob_enable_plan_cache = 0;
--echo // sleep 2
--sleep 2

--echo // Case1: 正确性验证

select round(col_int), round(col_double), round(col_decimal), round(col_varchar) from tbl_check_result;
select round(col_int, 1000), round(col_double, 1000), round(col_decimal, 1000), round(col_varchar, 1000) from tbl_check_result;
select round(col_int, -1000), round(col_double, -1000), round(col_decimal, -1000), round(col_varchar, -1000) from tbl_check_result;
select round(col_int, 2), round(col_double, 2), round(col_decimal, 2), round(col_varchar, 2) from tbl_check_result;
select round(col_int, -2), round(col_double, -2), round(col_decimal, -2), round(col_varchar, -2) from tbl_check_result;
select round(col_int, 0), round(col_double, 0), round(col_decimal, 0), round(col_varchar, 0) from tbl_check_result;
select round(col_int, 1), round(col_double, 1), round(col_decimal, 1), round(col_varchar, 1) from tbl_check_result;
select round(col_int, -1), round(col_double, -1), round(col_decimal, -1), round(col_varchar, -1) from tbl_check_result;
select round(col_int, null), round(col_double, null), round(col_decimal, null), round(col_varchar, null) from tbl_check_result;

--echo // Case2: TODO: 验证下round结果的scale设置，需要使用create view as

--echo // Case3: 各种类型无脑验证

let $cnt=22;
let $left=1;
while ($left <= $cnt)
{
  eval select round(c$left) from tbl_check_type;
  let $right=1;
  while ($right <= $cnt)
  {
    eval select round(c$left, c$right) from tbl_check_type;
    inc $right;
  }
  inc $left;
}

--echo // Case4: integer test
select round(123, 1);

select round(123, -1);
select round(123, -2);
select round(123, -3);
select round(123, -4);
select round(123, -100);

--echo // Case5: big integer test
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(c1 bigint unsigned, c2 bigint);
insert into t1 values(18446744073709551615, 9223372036854775807);
select c1, round(c1, -19), c2, round(c2, -18) from t1;
select c1, round(c1, -20), c2, round(c2, -19) from t1;
select c1, round(c1, -21), c2, round(c2, -20) from t1;
select c1, round(c1, -100), c2, round(c2, -100) from t1;
drop table t1;

create table t1(c1 decimal(10, 2), c2 int);
insert into t1 values(11.1, 1), (-0.1, 2), (12232334.1234, 3);
select avg(c1), round(avg(round(c1))), round(avg(round(c1, -1)), -1), round(avg(round(c1, 1)), 1) from t1;
select avg(c2), round(avg(round(c2))), round(avg(round(c2, -1)), -1), round(avg(round(c2, 1)), 1) from t1;
select sum(c1), round(sum(round(c1))), round(sum(round(c1, -1)), -1), round(sum(round(c1, 1)), 1) from t1;
select sum(c2), round(sum(round(c2))), round(sum(round(c2, -1)), -1), round(sum(round(c2, 1)), 1) from t1;
drop table t1;

drop table tbl_check_result;
drop table tbl_check_type;

--echo
--echo // round integer scale test(30306488)
--echo // expect scale is 0
select LEAST( ROUND( 0 , 8 ) , ROUND( 1 / 2 ) * 2 - 1 );
--echo // same test, but more exprs
select TRIM( SUBSTR( SUBSTR( CAST( ( LEAST( ROUND( 0 , 8 ) , ABS( ( ROUND( EXTRACT( MINUTE FROM '2015-06-15 10:00:00.000001' ) + 1 / ( ROUND( LENGTH( SUBSTR( CAST( ( ( ROUND( LENGTH( 'OGKDL' ) ) * 2 - 1 ) ) AS CHAR(100) ) , 1 , 20 ) ) ) * 2 - 1 ) ) * 2 - 1 ) ) ) ) AS CHAR(100) ) , 1 , 20 ) , 1 , 20 ) ) as tri_str;


