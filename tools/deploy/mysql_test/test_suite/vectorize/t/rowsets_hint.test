--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: zuojiao.hzj
# owner group: sql2
# tags: hint, outline
--result_format 4

connect (syscon, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection syscon;
alter system set _rowsets_enabled=true tenant=sys;
alter system set _rowsets_enabled=true tenant=all_user;
alter system set _rowsets_enabled=true tenant=all_meta;
--sleep 2

connection default;
--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1 (c1 int, c2 varchar(255), c3 varchar(255));

explain outline select /*+ opt_param('rowsets_enabled', 'false') */ c1,c2,c3 from t1;
explain outline select /*+ opt_param('rowsets_max_rows', 128) */ c1,c2,c3 from t1;
explain outline select /*+ opt_param('rowsets_enabled', 'true') opt_param('rowsets_max_rows', 128) */ c1,c2,c3 from t1;

explain select c1,c2,c3 from t1;
explain select /*+ opt_param('rowsets_enabled', 'false') */ c1,c2,c3 from t1;
explain select /*+ opt_param('rowsets_enabled', 'true') */ c1,c2,c3 from t1;
explain select /*+ opt_param('rowsets_max_rows', 16) */ c1,c2,c3 from t1;
explain select /*+ opt_param('rowsets_max_rows', 32) */ c1,c2,c3 from t1;
explain select /*+ opt_param('rowsets_enabled', 'false') opt_param('rowsets_max_rows', '32') */ c1,c2,c3 from t1;


alter system set _rowsets_enabled=false;
--sleep 2

explain select c1,c2,c3 from t1;
explain select /*+ opt_param('rowsets_enabled', 'false') */ c1,c2,c3 from t1;
explain select /*+ opt_param('rowsets_enabled', 'true') */ c1,c2,c3 from t1;
explain select /*+ opt_param('rowsets_max_rows', 16) */ c1,c2,c3 from t1;
explain select /*+ opt_param('rowsets_max_rows', 32) */ c1,c2,c3 from t1;
explain select /*+ opt_param('rowsets_enabled', 'true') opt_param('rowsets_max_rows', 32) */ c1,c2,c3 from t1;

drop table t1;
connection syscon;
alter system set _rowsets_enabled=true tenant=sys;
alter system set _rowsets_enabled=true tenant=all_user;
alter system set _rowsets_enabled=true tenant=all_meta;
