# owner: dachuan.sdc
# owner group: sql2
# tags: optimizer, px
--result_format 4

## VECTORIZED
alter system set _rowsets_enabled = 1;
alter system set _rowsets_max_rows = 256;

## 准备数据
--disable_warnings
drop table if exists t1;
--enable_warnings

CREATE TABLE t1
WITH RECURSIVE my_cte(c1, c2, c3) AS
(
  SELECT 0, 0, 1
  UNION ALL
  SELECT round((c3 + 1) / 100, 0), round((c3 + 1) / 5, 0), c3 + 1  FROM my_cte WHERE c3 < 999
)
SELECT * FROM my_cte;

call dbms_stats.gather_table_stats('TEST', 'T1', method_opt=>'for all columns size auto', estimate_percent=>100);

## 默认开启 reporting wf 两阶段下压
#alter session force parallel query parallel 3;
set _windowfunc_optimization_settings = 0;

alter system set _rowsets_max_rows = 256;
--source mysql_test/test_suite/vectorize/t/reporting_window_function_pushdown_test.sql

alter system set _rowsets_max_rows = 128;
--source mysql_test/test_suite/vectorize/t/reporting_window_function_pushdown_test.sql

alter system set _rowsets_max_rows = 64;
--source mysql_test/test_suite/vectorize/t/reporting_window_function_pushdown_test.sql

alter system set _rowsets_max_rows = 32;
--source mysql_test/test_suite/vectorize/t/reporting_window_function_pushdown_test.sql

alter system set _rowsets_max_rows = 16;
--source mysql_test/test_suite/vectorize/t/reporting_window_function_pushdown_test.sql

alter system set _rowsets_max_rows = 8;
--source mysql_test/test_suite/vectorize/t/reporting_window_function_pushdown_test.sql

alter system set _rowsets_max_rows = 4;
--source mysql_test/test_suite/vectorize/t/reporting_window_function_pushdown_test.sql

alter system set _rowsets_max_rows = 2;
--source mysql_test/test_suite/vectorize/t/reporting_window_function_pushdown_test.sql

alter system set _rowsets_max_rows = 1;
--source mysql_test/test_suite/vectorize/t/reporting_window_function_pushdown_test.sql



## 关闭 reporting wf 两阶段下压
set _windowfunc_optimization_settings = 2;
alter system flush plan cache;

alter system set _rowsets_max_rows = 256;
--source mysql_test/test_suite/vectorize/t/reporting_window_function_pushdown_test.sql

alter system set _rowsets_max_rows = 128;
--source mysql_test/test_suite/vectorize/t/reporting_window_function_pushdown_test.sql

alter system set _rowsets_max_rows = 64;
--source mysql_test/test_suite/vectorize/t/reporting_window_function_pushdown_test.sql

alter system set _rowsets_max_rows = 32;
--source mysql_test/test_suite/vectorize/t/reporting_window_function_pushdown_test.sql

alter system set _rowsets_max_rows = 16;
--source mysql_test/test_suite/vectorize/t/reporting_window_function_pushdown_test.sql

alter system set _rowsets_max_rows = 8;
--source mysql_test/test_suite/vectorize/t/reporting_window_function_pushdown_test.sql

alter system set _rowsets_max_rows = 4;
--source mysql_test/test_suite/vectorize/t/reporting_window_function_pushdown_test.sql

alter system set _rowsets_max_rows = 2;
--source mysql_test/test_suite/vectorize/t/reporting_window_function_pushdown_test.sql

alter system set _rowsets_max_rows = 1;
--source mysql_test/test_suite/vectorize/t/reporting_window_function_pushdown_test.sql

## clean up
set _windowfunc_optimization_settings = 0;
drop table t1;
