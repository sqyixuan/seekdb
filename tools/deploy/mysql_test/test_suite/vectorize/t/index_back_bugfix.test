# owner group: sql2
--result_format 4
--explain_protocol 1

connect (syscon, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection syscon;
alter system set _rowsets_enabled=true tenant=sys;
alter system set _rowsets_enabled=true tenant=all_user;
alter system set _rowsets_enabled=true tenant=all_meta;
alter system set _rowsets_max_rows=11 tenant=sys;
alter system set _rowsets_max_rows=11 tenant=all_user;
alter system set _rowsets_max_rows=11 tenant=all_meta;
--sleep 2

connection default;
--disable_warnings
DROP TABLE IF EXISTS `d`;
--enable_warnings

CREATE TABLE `d` (
  `col_int_key` int(11) DEFAULT NULL,
  `col_varchar_10` varchar(10) DEFAULT NULL,
  `col_varchar` varchar(1) DEFAULT NULL,
  `col_varchar_key` varchar(1) DEFAULT NULL,
  `pk` int(11) NOT NULL,
  `col_varchar_20_key` varchar(20) DEFAULT NULL,
  `col_int` int(11) DEFAULT NULL,
  `col_varchar_10_key` varchar(10) DEFAULT NULL,
  `col_varchar_20` varchar(20) DEFAULT NULL,
  PRIMARY KEY (`pk`),
  KEY `idx1` (`pk`, `col_int_key`) BLOCK_SIZE 16384 LOCAL,
  KEY `idx3` (`pk`, `col_varchar_key`) BLOCK_SIZE 16384 LOCAL,
  KEY `idx7` (`pk`, `col_varchar_20_key`) BLOCK_SIZE 16384 LOCAL,
  KEY `idx5` (`pk`, `col_varchar_10_key`) BLOCK_SIZE 16384 LOCAL
);

