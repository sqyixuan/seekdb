#owner: zongmei.zzm
#owner group: sql2

--result_format 4

# enable table scan vectorization for lob data

--disable_warnings
drop table if exists t1;
drop table if exists t2;
drop table if exists t3;
drop table if exists t4;
--enable_warnings

create table t1(a json) with column group (each column);

insert into t1 values ('{"sal": 800, "empno": 7369, "ename": "clerk"}'), ('{"sal": 1250, "empno": 7521, "ename": "ward"}');

explain select * from t1;
select * from t1;

create table t2(a GEOMETRY) with column group (each column);
insert into t2 values (ST_GeomFromText('POINT(0 1)')), (ST_GeomFromText('POINT(10 1)'));

explain select ST_ASTEXT(a) from t2;
select ST_ASTEXT(a) from t2;


create table t3(a longtext) with column group (each column);
insert into t3 values ("hello lob"), ("hi lob");
explain select * from t3;
select * from t3;

create table t4(a mediumtext) with column group (each column);
insert into t4 values ("hello medium"), ("hi medium");
explain select * from t4;
select * from t4;

drop table t1;
drop table t2;
drop table t3;
drop table t4;

