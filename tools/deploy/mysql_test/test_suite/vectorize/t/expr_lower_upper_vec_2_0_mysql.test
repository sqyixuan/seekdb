# owner: huangweixiang.hwx
# tags: optimizer
# owner group: sql2
--result_format 4
--explain_protocol 0

connect (syscon, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection syscon;
alter system set _rowsets_enabled=true tenant=all;
alter system set _rowsets_max_rows = 4 tenant=all;
--sleep 2

connection default;
set _enable_rich_vector_format = true;
--disable_warnings
drop table if exists t_utf8, t_utf16, t_gbk, t_gb18030;
--enable_warnings

create table t_utf8(c_varchar varchar(10), c_char char(10)) charset utf8mb4;
create table t_utf16(c_varchar varchar(10), c_char char(10)) charset utf16;
create table t_gbk(c_varchar varchar(10), c_char char(10)) charset gbk;
create table t_gb18030(c_varchar varchar(10), c_char char(10)) charset gb18030;

--disable_query_log
--let $loop=10
while($loop > 0)
{
  insert into t_utf8 values('Aa中 uY[^;,', 'Aa中 uY[^;,');
  insert into t_utf8 values(null, null);
  insert into t_utf16 values('Aa中 uY[^;,', 'Aa中 uY[^;,');
  insert into t_utf16 values(null, null);
  insert into t_gbk values('Aa中 uY[^;,', 'Aa中 uY[^;,');
  insert into t_gbk values(null, null);
  insert into t_gb18030 values('Aa中 uY[^;,', 'Aa中 uY[^;,');
  insert into t_gb18030 values(null, null);
  dec $loop;
}

select upper(c_varchar), upper(c_char), lower(c_varchar), lower(c_char) from t_utf8;
select upper(c_varchar), upper(c_char), lower(c_varchar), lower(c_char) from t_utf16;
select upper(c_varchar), upper(c_char), lower(c_varchar), lower(c_char) from t_gbk;
select upper(c_varchar), upper(c_char), lower(c_varchar), lower(c_char) from t_gb18030;

--enable_query_log

--explain_protocol 1

--explain_protocol 0

--disable_warnings
drop table t_utf8, t_utf16, t_gbk, t_gb18030;
--enable_warnings

connection syscon;
alter system set _rowsets_max_rows = 256 tenant=all;
