# owner: bin.lb
#tags: optimizer
# owner group: sql2

--result_format 4
--explain_protocol 0
connect (syscon, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection syscon;
alter system set _rowsets_enabled=true tenant=sys;
alter system set _rowsets_enabled=true tenant=all_user;
alter system set _rowsets_enabled=true tenant=all_meta;
--sleep 2
connection default;

--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1 (c1 int, c2 varchar(100));

--disable_query_log
--let $loop=300
while($loop > 0)
{
  eval insert into t1 (c1, c2) values ($loop, concat("abc", $loop));
  dec $loop;
}
--enable_query_log

update t1 set c2 = null where c1 % 7 = 0 or c1 % 5 = 0;

connection syscon;
alter system major freeze tenant = sys;
alter system major freeze tenant = all_user;
alter system major freeze tenant = all_meta;
--source mysql_test/include/wait_daily_merge.inc
connection default;

select c1, c2 from t1 where c2 like 'abc%';
select c1, c2 from t1 where c2 like 'abc2%';

drop table if exists t1;
--enable_warnings
