--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: peihan.dph
#tags: pl, optimizer
# owner group: SQL2
# tags: distinct
# description:
#

--disable_warnings
--error 0,1051
drop table t1;
--error 0,1051
drop table t2;
--error 0, 1305
drop procedure insert_t1;
set _groupby_nopushdown_cut_ratio = 1;
create table t1 (c1 int, c2 varchar(40000)) partition by hash(c1) partitions 5;
create table t2 (c1 int);
delimiter //;
create procedure insert_t1()
 begin
 declare a int;
 set a=0;
 while a<=1000 do
insert into t1 values(a, repeat('ab', 1500+a ));
 set a=a+1;
 end while;
end;
//
DELIMITER ;//
call insert_t1();

insert into t2 values(0);
insert into t2 values(1);
insert into t2 values(2);
insert into t2 values(3);
insert into t2 values(4);
insert into t2 values(5);

--enable_sorted_result

explain select count(*) from (select distinct c2 from t1);
select count(*) from (select distinct c2 from t1);

select /*+use_nl(t2 t)*/* from  t2 inner join (select distinct c1 d, c2 e from t1) t on c1=d;

drop table t1;
drop table t2;

connect (syscon, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection syscon;
alter system set_tp tp_no = 254, error_code = 2147483647, frequency = 1;
sleep 3;
connection default;

create table t1 (c1 varchar(20), c2 int, c3 int);
insert into t1 values('A', 1998, 1);
insert into t1 values('A', 1998, 1);
insert into t1 values('A', 1998, 1);
insert into t1 values('A', 1998, 1);
insert into t1 values('A', 1998, 1);
insert into t1 values('A', 1998, 1);
insert into t1 values('A', 1998, 1);
insert into t1 values('A', 1998, 1);
insert into t1 values('A', 1998, 1);
insert into t1 values('A', 1998, 1);

insert into t1 values('A', 1997, 1);
insert into t1 values('A', 1997, 1);
insert into t1 values('A', 1997, 1);
insert into t1 values('A', 1997, 1);
insert into t1 values('A', 1997, 1);
insert into t1 values('A', 1997, 1);
insert into t1 values('A', 1997, 1);
insert into t1 values('A', 1997, 1);
insert into t1 values('A', 1997, 1);
insert into t1 values('A', 1997, 1);

explain select /*+use_hash_aggregation parallel(2)*/ c1, abs(c2), count(c3) from t1 group by c1, abs(c2);
select /*+use_hash_aggregation parallel(2)*/ c1, abs(c2), count(c3) from t1 group by c1, abs(c2);

alter system set _rowsets_enabled = false;
alter system flush plan cache;

explain select /*+use_hash_aggregation parallel(2)*/ c1, abs(c2), count(c3) from t1 group by c1, abs(c2);
select /*+use_hash_aggregation parallel(2)*/ c1, abs(c2), count(c3) from t1 group by c1, abs(c2);

alter system set _rowsets_enabled = true;

drop table t1;


set _groupby_nopushdown_cut_ratio = 3;
drop procedure insert_t1;


create table t1 (c1 int, c2 int, c3 int unsigned, c4 decimal(10, 5), c5 float, c6 double);
insert into t1 values(0, 1, 2, 3.5, 3.5, 3.5);
insert into t1 values(null, null, null, null, null, null);
insert into t1 select c1+1, c2+1, c3+1, c4+1, c5+1, c6+1 from t1;
insert into t1 select c1+1, c2+1, c3+1, c4+1, c5+1, c6+1 from t1;
insert into t1 select c1+1, c2+1, c3+1, c4+1, c5+1, c6+1 from t1;
insert into t1 select c1+1, c2+1, c3+1, c4+1, c5+1, c6+1 from t1;
insert into t1 select c1+1, c2+1, c3+1, c4+1, c5+1, c6+1 from t1;
insert into t1 select c1+1, c2+1, c3+1, c4+1, c5+1, c6+1 from t1;
insert into t1 select c1+1, c2+1, c3+1, c4+1, c5+1, c6+1 from t1;
insert into t1 select c1+1, c2+1, c3+1, c4+1, c5+1, c6+1 from t1;
insert into t1 select c1+1, c2+1, c3+1, c4+1, c5+1, c6+1 from t1;

select /*+parallel(2)*/ min(c2), max(c2), sum(c2), count(c2), 
                        min(c3), max(c3), sum(c3), count(c3), 
                        min(c4), max(c4), sum(c4), count(c4),
                        min(c5), max(c5), sum(c5), count(c5),
                        min(c6), max(c6), sum(c6), count(c6) from t1 group by c1 order by 1,2,3,4,5,6,7,8;
drop table t1;


connection syscon;
alter system set_tp tp_no = 254, error_code = 0, frequency = 1;
sleep 3;
