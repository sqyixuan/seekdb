result_format: 4
alter system set _rowsets_enabled=true;

drop table if exists t1;
Test format_pico_time_batch
create table t1 (c1 double);
insert into t1 values (123),(123000),(123456789),(NULL),(24000000);

SELECT c1, format_pico_time(c1) AS a from t1;
+-----------+-----------+
| c1        | a         |
+-----------+-----------+
|       123 | 123 ps    |
|    123000 | 123.00 ns |
| 123456789 | 123.46 us |
|      NULL | NULL      |
|  24000000 | 24.00 us  |
+-----------+-----------+

drop table t1;
