result_format: 4
explain_protocol: 2
alter system flush plan cache global;
alter system set _rowsets_enabled=true tenant=sys;
alter system set _rowsets_enabled=true tenant=all_user;
alter system set _rowsets_enabled=true tenant=all_meta;
alter system set _rowsets_max_rows = 3 tenant=sys;
alter system set _rowsets_max_rows = 3 tenant=all_user;
alter system set _rowsets_max_rows = 3 tenant=all_meta;

set _nlj_batching_enabled = false;

drop table if exists t1,t2;
create table t1(c1 int, c2 int);
create table t2(c1 int, c2 int);
insert/*trace*/ into t1 values(1,1),(1,2), (2,3), (2,4), (3,5), (3,6), (4,7), (5,8), (6,9), (6,10);
insert/*trace*/ into t2 values(1,1),(1,2), (2,3), (5,8), (6,9), (6,10), (7,11);


***** test inner join
EXPLAIN select /*+leading(t1,t2) use_nl(t1, t2)*/ * from t1, t2 where t1.c1 = t2.c1;
Query Plan
===================================================
|ID|OPERATOR           |NAME|EST.ROWS|EST.TIME(us)|
---------------------------------------------------
|0 |NESTED-LOOP JOIN   |    |12      |7           |
|1 |├─TABLE FULL SCAN  |t1  |10      |3           |
|2 |└─MATERIAL         |    |7       |3           |
|3 |  └─TABLE FULL SCAN|t2  |7       |3           |
===================================================
Outputs & filters:
-------------------------------------
  0 - output([t1.c1], [t1.c2], [t2.c1], [t2.c2]), filter(nil), rowset=3
      conds([t1.c1 = t2.c1]), nl_params_(nil), use_batch=false
  1 - output([t1.c1], [t1.c2]), filter(nil), rowset=3
      access([t1.c1], [t1.c2]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t1.__pk_increment]), range(MIN ; MAX)always true
  2 - output([t2.c1], [t2.c2]), filter(nil), rowset=3
  3 - output([t2.c1], [t2.c2]), filter(nil), rowset=3
      access([t2.c1], [t2.c2]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t2.__pk_increment]), range(MIN ; MAX)always true
select /*+leading(t1,t2) use_nl(t1, t2)*/ * from t1, t2 where t1.c1 = t2.c1;
+------+------+------+------+
| c1   | c2   | c1   | c2   |
+------+------+------+------+
|    1 |    1 |    1 |    1 |
|    1 |    1 |    1 |    2 |
|    1 |    2 |    1 |    1 |
|    1 |    2 |    1 |    2 |
|    2 |    3 |    2 |    3 |
|    2 |    4 |    2 |    3 |
|    5 |    8 |    5 |    8 |
|    6 |    9 |    6 |    9 |
|    6 |    9 |    6 |   10 |
|    6 |   10 |    6 |    9 |
|    6 |   10 |    6 |   10 |
+------+------+------+------+
