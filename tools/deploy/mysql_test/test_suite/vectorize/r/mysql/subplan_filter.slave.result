result_format: 4
explain_protocol: 1

drop table if exists t1;
drop table if exists t2;
create table t1 (c1 int primary key, c2 decimal, c3 int, c4 varchar(20));
create table t2 (c1 int primary key, c2 decimal, c3 int, c4 varchar(20));
insert/*trace*/ into t1 (c1, c2, c3, c4) values (1, 1, 1, 'a');
insert/*trace*/ into t1 (c1, c2, c3, c4) values (2, 2, null, 'a');
insert/*trace*/ into t1 (c1, c2, c3, c4) values (3, 3, null, 'a');
insert/*trace*/ into t1 (c1, c2, c3, c4) values (4, 4, null, 'a');
insert/*trace*/ into t2 (c1, c2, c3, c4) values (1, 1, 1, 'a');
insert/*trace*/ into t2 (c1, c2, c3, c4) values (2, 2, null, 'a');
insert/*trace*/ into t2 (c1, c2, c3, c4) values (3, 3, null, 'a');
insert/*trace*/ into t2 (c1, c2, c3, c4) values (4, 4, null, 'a');
insert/*trace*/ into t2 (c1, c2, c3, c4) values (5, 5, null, 'a');

alter system set _rowsets_enabled = true;
alter system set _rowsets_max_rows = 2;
set ob_enable_transformation = off;

