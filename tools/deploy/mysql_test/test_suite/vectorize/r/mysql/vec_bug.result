alter system set _rowsets_enabled = 1;
alter system set _rowsets_max_rows = 256;
drop table if exists testwn1cp;
drop procedure if exists insert_p1;
create table testwn1cp (a int, b number, c int, d number, e number, f number)
partition by range (a) subpartition by hash (c) subpartitions 2
(partition p1 values less than (3),
partition p2 values less than (6),
partition p3 values less than (maxvalue));
create procedure insert_p1()
begin
declare i int;
set i = 0;
while i < 999 do
insert into testwn1cp values (mod(i, 10), mod(i, 100), mod(i, 1000),
mod(i, 1000), mod(i, 100), mod(i, 10));
set i = i + 1;
end while;
end
//
call insert_p1();
select /*+ parallel(testwn1cp, 3) */
a, b, rank() over (order by a, b desc) as w1,
rank() over (partition by a, b order by c) as w2
from testwn1cp group by b, a, c order by c, b;
