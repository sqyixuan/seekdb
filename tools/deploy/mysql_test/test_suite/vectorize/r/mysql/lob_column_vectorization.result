result_format: 4
drop table if exists t1;
drop table if exists t2;
drop table if exists t3;
drop table if exists t4;
create table t1(a json) with column group (each column);

insert into t1 values ('{"sal": 800, "empno": 7369, "ename": "clerk"}'), ('{"sal": 1250, "empno": 7521, "ename": "ward"}');

explain select * from t1;
Query Plan
======================================================
|ID|OPERATOR              |NAME|EST.ROWS|EST.TIME(us)|
------------------------------------------------------
|0 |COLUMN TABLE FULL SCAN|t1  |2       |22          |
======================================================
Outputs & filters:
-------------------------------------
  0 - output([t1.a]), filter(nil), rowset=16
      access([t1.a]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t1.__pk_increment]), range(MIN ; MAX)always true
select * from t1;
+-----------------------------------------------+
| a                                             |
+-----------------------------------------------+
| {"sal": 800, "empno": 7369, "ename": "clerk"} |
| {"sal": 1250, "empno": 7521, "ename": "ward"} |
+-----------------------------------------------+

create table t2(a GEOMETRY) with column group (each column);
insert into t2 values (ST_GeomFromText('POINT(0 1)')), (ST_GeomFromText('POINT(10 1)'));

explain select ST_ASTEXT(a) from t2;
Query Plan
======================================================
|ID|OPERATOR              |NAME|EST.ROWS|EST.TIME(us)|
------------------------------------------------------
|0 |COLUMN TABLE FULL SCAN|t2  |2       |20          |
======================================================
Outputs & filters:
-------------------------------------
  0 - output([ST_ASTEXT(t2.a)]), filter(nil)
      access([t2.a]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t2.__pk_increment]), range(MIN ; MAX)always true
select ST_ASTEXT(a) from t2;
+--------------+
| ST_ASTEXT(a) |
+--------------+
| POINT(0 1)   |
| POINT(10 1)  |
+--------------+

