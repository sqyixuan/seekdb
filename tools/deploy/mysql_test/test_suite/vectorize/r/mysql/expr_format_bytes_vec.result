result_format: 4
alter system set _rowsets_enabled=true;

drop table if exists t1;
Test format_bytes_batch
create table t1 (c1 double);
insert into t1 values (123),(123000),(123456789),(NULL),(24000000);

SELECT c1, format_bytes(c1) AS a from t1;
+-----------+------------+
| c1        | a          |
+-----------+------------+
|       123 |  123 bytes |
|    123000 | 120.12 KiB |
| 123456789 | 117.74 MiB |
|      NULL | NULL       |
|  24000000 | 22.89 MiB  |
+-----------+------------+

drop table t1;
