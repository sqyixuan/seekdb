### BUG: 
drop table if exists mail, mail2;
create table mail
(
t decimal(6,2),
srcuser varchar(200) character set gbk,
srchost char(200) character set gbk,
dstuser varchar(200) character set gbk,
dsthost char(200) character set gbk,
size BIGINT,
index (`srcuser`)
)DEFAULT CHARACTER SET = gbk partition by hash(size) partitions 4;

