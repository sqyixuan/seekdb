drop table if exists t_utf8, t_utf16, t_gbk, t_gb18030;
create table t_utf8(c_varchar varchar(10), c_char char(10)) charset utf8mb4;
create table t_utf16(c_varchar varchar(10), c_char char(10)) charset utf16;
create table t_gbk(c_varchar varchar(10), c_char char(10)) charset gbk;
create table t_gb18030(c_varchar varchar(10), c_char char(10)) charset gb18030;

