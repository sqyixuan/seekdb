      group([t1.c1]), agg_func([T_FUN_COUNT(t1.c2)], [T_FUN_SUM(t1.c2 + 1)], [T_FUN_SUM(t1.c2 * 5)], [T_FUN_COUNT(t1.c2 * 5)])
