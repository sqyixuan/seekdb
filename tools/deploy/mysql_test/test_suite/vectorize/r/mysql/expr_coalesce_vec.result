result_format: 4
alter system set _rowsets_enabled=true tenant=sys;
alter system set _rowsets_enabled=true tenant=all_user;
alter system set _rowsets_enabled=true tenant=all_meta;


drop table if exists t1;
create table t1(a int, b varchar(128), c float, d number);

insert into t1 values (1, 'hello coalesce', 1.2, 3.1415926);
Warnings:
Warning	1265	Data truncated for column 'd' at row 1
insert into t1 values (null, 'hello mysqltest', 1.3, 3.1415927);
Warnings:
Warning	1265	Data truncated for column 'd' at row 1
insert into t1 values (null, null, 1.4, 3.1415928);
Warnings:
Warning	1265	Data truncated for column 'd' at row 1
insert into t1 values (null, null, null, 4.1415929);
Warnings:
Warning	1265	Data truncated for column 'd' at row 1
insert into t1 values (null, null, null, null);

select coalesce(a, b, c, d) from t1;
+----------------------+
| coalesce(a, b, c, d) |
+----------------------+
| 1                    |
| hello mysqltest      |
| 1.4                  |
| 4                    |
| NULL                 |
+----------------------+
select coalesce(a, b, c, d, 'test') from t1;
+------------------------------+
| coalesce(a, b, c, d, 'test') |
+------------------------------+
| 1                            |
| hello mysqltest              |
| 1.4                          |
| 4                            |
| test                         |
+------------------------------+
select coalesce(null, a, b, c, d) from t1;
+----------------------------+
| coalesce(null, a, b, c, d) |
+----------------------------+
| 1                          |
| hello mysqltest            |
| 1.4                        |
| 4                          |
| NULL                       |
+----------------------------+

select coalesce('test_coalesce', a, b, c, d) from t1;
+---------------------------------------+
| coalesce('test_coalesce', a, b, c, d) |
+---------------------------------------+
| test_coalesce                         |
| test_coalesce                         |
| test_coalesce                         |
| test_coalesce                         |
| test_coalesce                         |
+---------------------------------------+

drop table t1;
