result_format: 4
explain_protocol: 0
alter system set _rowsets_enabled=true tenant=sys;
alter system set _rowsets_enabled=true tenant=all_user;
alter system set _rowsets_enabled=true tenant=all_meta;

drop table if exists t1;
create table t1 (i1 int, v2 varchar(80), i3 char(20),i4 float, d4 datetime(6),i5 decimal(5,3), primary key(i1));
insert into t1 values(1,'now','haha',1.6256,'2014-05-04 12:00:00',-10.235);
insert into t1 values(2,'now','haha',-1.6256,'2014-05-04 12:00:00',1.243);
insert into t1 values(3,'now','haha',1.656,'2014-05-04 12:00:00',-1.45);
set ob_log_level = 'debug';
select /*+ USE_HASH_DISTINCT */ distinct abs(i1*3-i4) as abc ,i1*3-i4  from t1 where  abs(i1*3-i4)<100 order by  abs(i1*3-i4);
+-------------------+-------------------+
| abc               | i1*3-i4           |
+-------------------+-------------------+
| 1.374400019645691 | 1.374400019645691 |
| 7.343999981880188 | 7.343999981880188 |
| 7.625599980354309 | 7.625599980354309 |
+-------------------+-------------------+

drop table if exists t1;
