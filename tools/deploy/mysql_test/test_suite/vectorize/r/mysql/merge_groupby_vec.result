explain select c1,c2,sum(c1),count(c1) from t1 group by c1;
Query Plan
=================================================
|ID|OPERATOR         |NAME|EST.ROWS|EST.TIME(us)|
-------------------------------------------------
|0 |MERGE GROUP BY   |    |40      |8           |
|1 |└─TABLE FULL SCAN|t1  |40      |4           |
=================================================
Outputs & filters:
-------------------------------------
  0 - output([t1.c1], [t1.c2], [T_FUN_SUM(t1.c1)], [T_FUN_COUNT(t1.c1)]), filter(nil), rowset=2
      group([t1.c1]), agg_func([T_FUN_SUM(t1.c1)], [T_FUN_COUNT(t1.c1)])
  1 - output([t1.c1], [t1.c2]), filter(nil), rowset=2
      access([t1.c1], [t1.c2]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t1.c1], [t1.c2]), range(MIN,MIN ; MAX,MAX)always true
