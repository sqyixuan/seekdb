drop table if exists t1;
## scalar group by on generated colunm, and the table is empty
create table t1(c1 int primary key, c2 int generated always as (c1 + 1) stored);
explain select c2, max(c2) as aggr FROM t1  where c2 in (select c2 FROM t1  where c2 > 1);
Query Plan
========================================================
|ID|OPERATOR               |NAME |EST.ROWS|EST.TIME(us)|
--------------------------------------------------------
|0 |SCALAR GROUP BY        |     |1       |5           |
|1 |└─HASH RIGHT SEMI JOIN |     |1       |5           |
|2 |  ├─SUBPLAN SCAN       |VIEW1|1       |3           |
|3 |  │ └─TABLE FULL SCAN  |t1   |1       |3           |
|4 |  └─TABLE FULL SCAN    |t1   |1       |3           |
========================================================
Outputs & filters:
-------------------------------------
  0 - output([t1.c2], [T_FUN_MAX(t1.c2)]), filter(nil), rowset=16
      group(nil), agg_func([T_FUN_MAX(t1.c2)])
  1 - output([t1.c2]), filter(nil), rowset=16
      equal_conds([VIEW1.c2 = t1.c2]), other_conds(nil)
  2 - output([VIEW1.c2]), filter(nil), rowset=16
      access([VIEW1.c2])
  3 - output([t1.c2]), filter([t1.c2 > 1]), rowset=16
      access([t1.c2]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([t1.c1]), range(MIN ; MAX)always true
  4 - output([t1.c2]), filter([t1.c2 > 1]), rowset=16
      access([t1.c2]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([t1.c1]), range(MIN ; MAX)always true
select c2, max(c2) as aggr FROM t1  where c2 in (select c2 FROM t1  where c2 > 1);
