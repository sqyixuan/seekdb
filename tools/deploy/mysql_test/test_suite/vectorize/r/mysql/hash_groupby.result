result_format: 4
alter system set _rowsets_enabled=true tenant=sys;
alter system set _rowsets_enabled=true tenant=all_user;
alter system set _rowsets_enabled=true tenant=all_meta;
alter system set _rowsets_max_rows = 4 tenant=sys;
alter system set _rowsets_max_rows = 4 tenant=all_user;
alter system set _rowsets_max_rows = 4 tenant=all_meta;

drop table if exists t1;
create table t1(c1 int, c2 int);
insert into t1 values(1,1),(1,2),(2,3);


## test one batch
explain select/*+USE_HASH_AGGREGATION one_batch*/ c1, count(c2), avg(c2), sum(c2 + 1), min(c2*2), max(c2 - 1) from t1 group by  c1;
Query Plan
=================================================
|ID|OPERATOR         |NAME|EST.ROWS|EST.TIME(us)|
-------------------------------------------------
|0 |HASH GROUP BY    |    |3       |4           |
|1 |└─TABLE FULL SCAN|t1  |3       |3           |
=================================================
Outputs & filters:
-------------------------------------
  0 - output([t1.c1], [T_FUN_COUNT(t1.c2)], [cast(cast(T_FUN_SUM(t1.c2), DECIMAL_INT(65, 32)) / cast(T_FUN_COUNT(t1.c2), DECIMAL_INT(20, 0)), DECIMAL(15,
       4))], [cast(cast(T_FUN_SUM(t1.c2), DECIMAL_INT(63, 0)) + cast(T_FUN_COUNT(t1.c2), DECIMAL_INT(20, 0)) * cast(1, DECIMAL_INT(42, 0)), DECIMAL_INT(42, 0))],
       [T_FUN_MIN(t1.c2 * 2)], [T_FUN_MAX(t1.c2 + -1)]), filter(nil), rowset=4
      group([t1.c1]), agg_func([T_FUN_COUNT(t1.c2)], [T_FUN_MIN(t1.c2 * 2)], [T_FUN_MAX(t1.c2 + -1)], [T_FUN_SUM(t1.c2)])
  1 - output([t1.c1], [t1.c2]), filter(nil), rowset=4
      access([t1.c1], [t1.c2]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t1.__pk_increment]), range(MIN ; MAX)always true
select/*+USE_HASH_AGGREGATION one_batch*/ c1, count(c2), avg(c2), sum(c2 + 1), min(c2*2), max(c2 - 1) from t1 group by  c1;
+------+-----------+---------+-------------+-----------+-------------+
| c1   | count(c2) | avg(c2) | sum(c2 + 1) | min(c2*2) | max(c2 - 1) |
+------+-----------+---------+-------------+-----------+-------------+
|    1 |         2 |  1.5000 |           5 |         2 |           1 |
|    2 |         1 |  3.0000 |           4 |         6 |           2 |
+------+-----------+---------+-------------+-----------+-------------+
select/*+one_batch*/ count(c2), avg(c2), sum(c2 + 1), min(c2*2), max(c2 - 1) from t1;
+-----------+---------+-------------+-----------+-------------+
| count(c2) | avg(c2) | sum(c2 + 1) | min(c2*2) | max(c2 - 1) |
+-----------+---------+-------------+-----------+-------------+
|         3 |  2.0000 |           9 |         2 |           2 |
+-----------+---------+-------------+-----------+-------------+


## test one batch with skip
explain select/*+USE_HASH_AGGREGATION one_batch*/ c1, count(c2), avg(c2), sum(c2 + 1), min(c2*2), max(c2 - 1) from t1 where c2 % 2 = 1 group by  c1;
Query Plan
=================================================
|ID|OPERATOR         |NAME|EST.ROWS|EST.TIME(us)|
-------------------------------------------------
|0 |HASH GROUP BY    |    |2       |3           |
|1 |└─TABLE FULL SCAN|t1  |2       |3           |
=================================================
Outputs & filters:
-------------------------------------
  0 - output([t1.c1], [T_FUN_COUNT(t1.c2)], [cast(cast(T_FUN_SUM(t1.c2), DECIMAL_INT(65, 32)) / cast(T_FUN_COUNT(t1.c2), DECIMAL_INT(20, 0)), DECIMAL(15,
       4))], [cast(cast(T_FUN_SUM(t1.c2), DECIMAL_INT(63, 0)) + cast(T_FUN_COUNT(t1.c2), DECIMAL_INT(20, 0)) * cast(1, DECIMAL_INT(42, 0)), DECIMAL_INT(42, 0))],
       [T_FUN_MIN(t1.c2 * 2)], [T_FUN_MAX(t1.c2 + -1)]), filter(nil), rowset=4
      group([t1.c1]), agg_func([T_FUN_COUNT(t1.c2)], [T_FUN_MIN(t1.c2 * 2)], [T_FUN_MAX(t1.c2 + -1)], [T_FUN_SUM(t1.c2)])
  1 - output([t1.c2], [t1.c1]), filter([t1.c2 % 2 = 1]), rowset=4
      access([t1.c2], [t1.c1]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([t1.__pk_increment]), range(MIN ; MAX)always true
select/*+USE_HASH_AGGREGATION one batch*/ c1, count(c2), avg(c2), sum(c2 + 1), min(c2*2), max(c2 - 1) from t1 where c2 % 2 = 1 group by  c1;
+------+-----------+---------+-------------+-----------+-------------+
| c1   | count(c2) | avg(c2) | sum(c2 + 1) | min(c2*2) | max(c2 - 1) |
+------+-----------+---------+-------------+-----------+-------------+
|    1 |         1 |  1.0000 |           2 |         2 |           0 |
|    2 |         1 |  3.0000 |           4 |         6 |           2 |
+------+-----------+---------+-------------+-----------+-------------+
select/*+one batch*/ count(c2), avg(c2), sum(c2 + 1), min(c2*2), max(c2 - 1) from t1 where c2 % 2 = 1;
+-----------+---------+-------------+-----------+-------------+
| count(c2) | avg(c2) | sum(c2 + 1) | min(c2*2) | max(c2 - 1) |
+-----------+---------+-------------+-----------+-------------+
|         2 |  2.0000 |           6 |         2 |           2 |
+-----------+---------+-------------+-----------+-------------+


## test multi batch
insert into t1 values(2,4),(2,5),(2,6), (2,7), (null,8), (3,9), (3,10), (3,11), (3,null), (3,null), (3,14), (3,15), (3,16), (4,1);

explain select/*+USE_HASH_AGGREGATION multi_batch*/ c1, count(c2), sum(c2 + 1), avg(c2 * 5) from t1 group by  c1;
Query Plan
=================================================
|ID|OPERATOR         |NAME|EST.ROWS|EST.TIME(us)|
-------------------------------------------------
|0 |HASH GROUP BY    |    |17      |9           |
|1 |└─TABLE FULL SCAN|t1  |17      |3           |
=================================================
Outputs & filters:
-------------------------------------
  0 - output([t1.c1], [T_FUN_COUNT(t1.c2)], [T_FUN_SUM(t1.c2 + 1)], [cast(cast(T_FUN_SUM(t1.c2 * 5), DECIMAL_INT(74, 32)) / cast(T_FUN_COUNT(t1.c2 * 5),
       DECIMAL_INT(20, 0)), DECIMAL(19, 4))]), filter(nil), rowset=4
      group([t1.c1]), agg_func([T_FUN_COUNT(t1.c2)], [T_FUN_SUM(t1.c2 + 1)], [T_FUN_SUM(t1.c2 * 5)], [T_FUN_COUNT(t1.c2 * 5)])
  1 - output([t1.c1], [t1.c2], [t1.c2 * 5]), filter(nil), rowset=4
      access([t1.c1], [t1.c2]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t1.__pk_increment]), range(MIN ; MAX)always true
select/*+USE_HASH_AGGREGATION multi_batch*/ c1, count(c2), avg(c2), sum(c2 + 1), min(c2*2), max(c2 - 1) from t1 group by  c1;
+------+-----------+---------+-------------+-----------+-------------+
| c1   | count(c2) | avg(c2) | sum(c2 + 1) | min(c2*2) | max(c2 - 1) |
+------+-----------+---------+-------------+-----------+-------------+
|    1 |         2 |  1.5000 |           5 |         2 |           1 |
|    2 |         5 |  5.0000 |          30 |         6 |           6 |
| NULL |         1 |  8.0000 |           9 |        16 |           7 |
|    3 |         6 | 12.5000 |          81 |        18 |          15 |
|    4 |         1 |  1.0000 |           2 |         2 |           0 |
+------+-----------+---------+-------------+-----------+-------------+
select/*+multi_batch*/ count(c2), avg(c2), sum(c2 + 1), min(c2*2), max(c2 - 1) from t1;
+-----------+---------+-------------+-----------+-------------+
| count(c2) | avg(c2) | sum(c2 + 1) | min(c2*2) | max(c2 - 1) |
+-----------+---------+-------------+-----------+-------------+
|        15 |  7.4667 |         127 |         2 |          15 |
+-----------+---------+-------------+-----------+-------------+


## test multi batch with skip
explain select/*+USE_HASH_AGGREGATION multi_batch*/ c1, count(c2), avg(c2), sum(c2 + 1), min(c2*2), max(c2 - 1) from t1 where c2 % 2 = 0 group by  c1;
Query Plan
=================================================
|ID|OPERATOR         |NAME|EST.ROWS|EST.TIME(us)|
-------------------------------------------------
|0 |HASH GROUP BY    |    |9       |6           |
|1 |└─TABLE FULL SCAN|t1  |9       |4           |
=================================================
Outputs & filters:
-------------------------------------
  0 - output([t1.c1], [T_FUN_COUNT(t1.c2)], [cast(cast(T_FUN_SUM(t1.c2), DECIMAL_INT(65, 32)) / cast(T_FUN_COUNT(t1.c2), DECIMAL_INT(20, 0)), DECIMAL(15,
       4))], [cast(cast(T_FUN_SUM(t1.c2), DECIMAL_INT(63, 0)) + cast(T_FUN_COUNT(t1.c2), DECIMAL_INT(20, 0)) * cast(1, DECIMAL_INT(42, 0)), DECIMAL_INT(42, 0))],
       [T_FUN_MIN(t1.c2 * 2)], [T_FUN_MAX(t1.c2 + -1)]), filter(nil), rowset=4
      group([t1.c1]), agg_func([T_FUN_COUNT(t1.c2)], [T_FUN_MIN(t1.c2 * 2)], [T_FUN_MAX(t1.c2 + -1)], [T_FUN_SUM(t1.c2)])
  1 - output([t1.c2], [t1.c1]), filter([t1.c2 % 2 = 0]), rowset=4
      access([t1.c2], [t1.c1]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([t1.__pk_increment]), range(MIN ; MAX)always true
select/*+USE_HASH_AGGREGATION multi_batch*/ c1, count(c2), avg(c2), sum(c2 + 1), min(c2*2), max(c2 - 1) from t1 where c2 % 2 = 0 group by  c1;
+------+-----------+---------+-------------+-----------+-------------+
| c1   | count(c2) | avg(c2) | sum(c2 + 1) | min(c2*2) | max(c2 - 1) |
+------+-----------+---------+-------------+-----------+-------------+
|    1 |         1 |  2.0000 |           3 |         4 |           1 |
|    2 |         2 |  5.0000 |          12 |         8 |           5 |
| NULL |         1 |  8.0000 |           9 |        16 |           7 |
|    3 |         3 | 13.3333 |          43 |        20 |          15 |
+------+-----------+---------+-------------+-----------+-------------+

## test implicit agg
select/*+multi_batch*/ c1, count(c2), sum(c2), avg(c1) from t1 where c2 % 2 = 0;
+------+-----------+---------+---------+
| c1   | count(c2) | sum(c2) | avg(c1) |
+------+-----------+---------+---------+
|    1 |         7 |      60 |  2.3333 |
+------+-----------+---------+---------+

drop table t1;

alter system set _rowsets_max_rows = 256 tenant=sys;
alter system set _rowsets_max_rows = 256 tenant=all_user;
alter system set _rowsets_max_rows = 256 tenant=all_meta;
