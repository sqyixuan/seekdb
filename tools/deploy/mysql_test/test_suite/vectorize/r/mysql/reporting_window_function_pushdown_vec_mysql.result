result_format: 4
## VECTORIZED
alter system set _rowsets_enabled = 1;
alter system set _rowsets_max_rows = 256;

## 准备数据
drop table if exists t1;
CREATE TABLE t1
WITH RECURSIVE my_cte(c1, c2, c3) AS
(
  SELECT 0, 0, 1
  UNION ALL
  SELECT round((c3 + 1) / 100, 0), round((c3 + 1) / 5, 0), c3 + 1  FROM my_cte WHERE c3 < 999
)
SELECT * FROM my_cte;

call dbms_stats.gather_table_stats('TEST', 'T1', method_opt=>'for all columns size auto', estimate_percent=>100);

## 默认开启 reporting wf 两阶段下压
set _windowfunc_optimization_settings = 0;

alter system set _rowsets_max_rows = 256;
explain_protocol: 1
EXPLAIN BASIC select /*+parallel(3) */c1, sum(c2) over (partition by c1) from t1 order by c1;
Query Plan
========================================================
|ID|OPERATOR                                  |NAME    |
--------------------------------------------------------
|0 |PX COORDINATOR MERGE SORT                 |        |
|1 |└─EXCHANGE OUT DISTR                      |:EX10001|
|2 |  └─MATERIAL                              |        |
|3 |    └─WINDOW FUNCTION CONSOLIDATOR        |        |
|4 |      └─EXCHANGE IN MERGE SORT DISTR      |        |
|5 |        └─EXCHANGE OUT DISTR (HASH HYBRID)|:EX10000|
|6 |          └─WINDOW FUNCTION               |        |
|7 |            └─SORT                        |        |
|8 |              └─PX BLOCK ITERATOR         |        |
|9 |                └─TABLE FULL SCAN         |t1      |
========================================================
