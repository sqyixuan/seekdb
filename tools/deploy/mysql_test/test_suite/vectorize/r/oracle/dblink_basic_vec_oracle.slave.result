result_format: 4
alter system set _rowsets_enabled=true tenant=sys;
alter system set _rowsets_enabled=true tenant=all_user;
alter system set _rowsets_enabled=true tenant=all_meta;


drop table dlt5;
create table dlt5 (
  bf1 binary_float,
  bd1 binary_double,
  n1  int,
  n2  number,
  n3  number(10, -2),
  n4  number(20),
  f1  float,
  v1  varchar2(100),
  c1  char(20),
  r1  raw(100),
  nv1 nvarchar2(100),
  nc1 nchar(20),
  l1  blob,
  l2  clob,
  d1  date,
  tz1 timestamp(1) with time zone,
  tz2 timestamp(2) with local time zone,
  t3  timestamp(3),
  i1  interval year(4) to month,
  i2  interval day(5) to second(6),
  ur urowid
);
set nls_date_format = 'YYYY-MM-DD HH24:MI:SS';
set nls_timestamp_format = 'YYYY-MM-DD HH24:MI:SS.FF';
set nls_timestamp_tz_format = 'YYYY-MM-DD HH24:MI:SS.FF TZR TZD';
insert into dlt5 values (1, 2, 3, 4, 5, 6, 7, '阿里巴巴v1', '支付宝c1', '7231', '阿里巴巴nv1', '支付宝nc1', '6c31', 'l2', '2020-07-28', '2020-07-28 12:34:56', '2020-07-28 12:34:56', '2020-07-28 12:34:56', '1-1', '1 12:34:56', 'gAADFAsAAAAAAQ==');
insert into dlt5 values (1, 2, 3, 4, 5, 6, 7, '阿里巴巴v1', '支付宝c1', '7231', '阿里巴巴nv1', '支付宝nc1', '6c31', 'l2', '2020-07-28', '2020-07-28 12:34:56', '2020-07-28 12:34:56', '2020-07-28 12:34:56', '1-1', '1 12:34:56', 'gAADFAsAAAAAAQ==');
commit;

