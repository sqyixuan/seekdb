| MOD(A,3) | COUNT(X) |
+----------+----------+
|        1 |        3 |
|        2 |        2 |
|        0 |        2 |
+----------+----------+
select mod(a, 3), count(x) from dlt1 group by mod(a, 3) having count(x) < 3;
