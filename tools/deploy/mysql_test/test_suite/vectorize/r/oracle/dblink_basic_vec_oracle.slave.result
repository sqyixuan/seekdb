select a - 3, concat(b, concat('-', x)) from dlt1;
+------+-------------------------+
| A-3  | CONCAT(B,CONCAT('-',X)) |
+------+-------------------------+
|   -2 | 123-abc                 |
|   -1 | 234-bcd                 |
|    0 | 345-cde                 |
|    1 | 456-def                 |
|   97 | 000-xxx                 |
|   98 | 111-yyy                 |
|   99 | 222-zzz                 |
+------+-------------------------+
select a + 10, concat(b, concat('-', x)) from dlt1;
