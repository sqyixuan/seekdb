with a as (select distinct n.y, m.x from dlt1 m join dlt2 n on m.a = n.c), b as (select t.x from (select n.y, m.x from dlt1 m, dlt2 n) t)
select a.y, a.x, b.x from a, b where trim(a.x) = trim(b.x)
order by 1, 2;
