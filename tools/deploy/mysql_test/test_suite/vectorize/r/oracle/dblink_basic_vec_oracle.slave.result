explain_protocol: 0
drop table dlt4_dup;
create table dlt4_dup as
  select dlt3.a c1, dlt4.a c2, dlt4.b c3, dlt4.x c4 from (select a from dlt1 minus select c a from dlt2 minus select 1 a from dual) dlt3, dlt1 dlt4 where dlt3.a = dlt4.a;
select c1, c2, c3, c4 from dlt4_dup;
+------+------+------+------+
| C1   | C2   | C3   | C4   |
+------+------+------+------+
|  100 |  100 | 000  | xxx  |
|  101 |  101 | 111  | yyy  |
|  102 |  102 | 222  | zzz  |
+------+------+------+------+
delete from dlt4_dup;
insert into dlt4_dup
  select dlt3.a c1, dlt4.a c2, dlt4.b c3, dlt4.x c4 from (select a from dlt1 minus select c a from dlt2 minus select 1 a from dual) dlt3, dlt1 dlt4 where dlt3.a = dlt4.a;
select c1, c2, c3, c4 from dlt4_dup;
+------+------+------+------+
| C1   | C2   | C3   | C4   |
+------+------+------+------+
|  100 |  100 | 000  | xxx  |
|  101 |  101 | 111  | yyy  |
|  102 |  102 | 222  | zzz  |
+------+------+------+------+
drop table dlt4_dup;

