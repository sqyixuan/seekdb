| A+10 | CONCAT(B,CONCAT('-',X)) |
+------+-------------------------+
|   11 | 123-abc                 |
|   12 | 234-bcd                 |
|   13 | 345-cde                 |
|   14 | 456-def                 |
|  110 | 000-xxx                 |
|  111 | 111-yyy                 |
|  112 | 222-zzz                 |
+------+-------------------------+

select mod(a, 3), count(x) from dlt1 group by mod(a, 3);
