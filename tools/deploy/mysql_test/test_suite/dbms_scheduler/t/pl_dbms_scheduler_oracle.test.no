#owner group: system
#tags: pl
#description: test dbms_scheduler

--result_format 4

--disable_warnings

--source output_print_enable.inc

delimiter /;

--echo #### for declare job action
CREATE OR REPLACE PACKAGE JOB_UTILS IS
  PROCEDURE insert_date;
  PROCEDURE insert_date_program ( job IN VARCHAR2, job_name IN VARCHAR2); 
END;
/

CREATE OR REPLACE PACKAGE BODY JOB_UTILS IS
  PROCEDURE insert_date IS
  BEGIN
    INSERT INTO T VALUES(sysdate);
  END;
  PROCEDURE insert_date_program ( job IN VARCHAR2, job_name IN VARCHAR2) IS
  BEGIN
    INSERT INTO T2 VALUES(sysdate, job, job_name);
  END;

END;
/

--error 0,942
DROP TABLE t;
/
CREATE TABLE t(col date);
/

--error 0,942
DROP TABLE t2;
/
CREATE TABLE t2(col date, job varchar(128), job_name varchar(128));
/

--echo #### normal action call...
BEGIN
  dbms_scheduler.create_job(job_name => dbms_scheduler.generate_job_name,
    job_type => 'STORED_PROCEDURE',
    job_action => 'JOB_UTILS.insert_date',
    repeat_interval => 'FREQ=SECONDLY; INTERVAL=8',
    end_date => '2022-06-22 14:11:15.648735',
    enabled => true,
    auto_drop => false,
    max_run_duration => 20);
  COMMIT;
END;/
SELECT * FROM SYS.ALL_VIRTUAL_TENANT_SCHEDULER_JOB_REAL_AGENT;/
SELECT * FROM DBA_SCHEDULER_JOBS;/

