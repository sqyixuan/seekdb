#owner: dingjincheng.djc
##owner group: SQL1
##description: test time literals use in ODBC

--disable_warnings
drop view if exists v1, v2;
--enable_warnings

--result_format 4

select {d '20221009'};
select {d '20221010'};
select {t '10:12:13'};
select {t '12:12:15.123'};
select {ts '2022-10-09 10:12:13'};
select {ts '2022-10-09 10:12:14.456'};
select {d '20221009'}, {t '10:12:13'} , {ts '2022-10-09 10:12:13'};
select {d '20221010'}, {t '12:12:15:23.123'} , {ts '2022-10-09 10:12:14.456'};
create view v1 as select {d '20221011'} as c1, {t '12:12:15.1235'} as c2, {ts '2022-10-09 10:12:14.4563'} as c3;
select * from v1;

##like mysql, invalid time literals just ignore the action and reserve the literals.
select {d '202210092'};
select {t '101213'};
select {ts '20221009 10:12:13'};
select {d '2022100922'}, {t '1012134'} , {ts '20221009 10:12:13.333'};
create view v2 as select {d '20221009241112'} as c1, {t '10:1213.12'} as c2, {ts '20221009 10:12:13.4444'} as c3;
select * from v2;

##like mysql, invalid action just ignore the action and reserve the literals.
select {dd '20221009'};
select {tt '10:12:13'};
select {tts '2022-10-09 10:12:13'};
select {dd '20221009'}, {tt '10:12:13'} , {tts '2022-10-09 10:12:13'};

drop view v1, v2;