#owner: dingjincheng.djc
##owner group: SQL1
##description: test outer join use in ODBC

--disable_warnings
drop table if exists t1, t2;
drop view if exists v1;
--enable_warnings

--result_format 4

create table t1(c1 int, c2 varchar(10));
create table t2(c1 int, c2 varchar(10));
insert into t1 values (1, 'aaaaaa'), (3, 'bbbbbb'), (5, 'cccccc');
insert into t2 values (1, 'aaaaaa'), (2, 'bbbbbb'), (4, 'cccccc');

select * from {oj t1};
select * from {oj t1 left outer join t2 on t1.c1=t2.c1};
select * from {oj t1 right outer join t2 on t1.c1=t2.c1};
select * from {oj t1}, t2 where t1.c1 = t2.c1;
select * from {oj t1}, {oj t2} where t1.c1 = t2.c1;

select {d '20221009'}, {fn ifnull(min(c1),0)}  from {oj t1};
select {fn substring(t1.c2,1,3)}, {t '12:12:15.123'} from {oj t1 left outer join t2 on t1.c1=t2.c1};
select {fn abs(-1)}, {ts '2022-10-09 10:12:13'} from {oj t1 right outer join t2 on t1.c1=t2.c1};
select {fn left(t1.c2,1)}, {fn left(t2.c2,2)} from {oj t1}, t2 where t1.c1 = t2.c1;
select {fn left(t1.c2,1)} as c1,
       {fn substring(t2.c2,1,3)} as c2,
       {d '20221001'} as c3,
       {t '12:13:15.123'} as c4,
       {ts '2022-10-09 10:11:12.456'} as c5 from {oj t1}, {oj t2} where t1.c1 = t2.c1;

create view v1 as select {fn ifnull(min(t1.c1),0)} as c1,
                         {fn substring(t2.c2,1,3)} as c2,
                         {d '20221001'} as c3,
                         {t '12:13:15.123'} as c4,
                         {ts '2022-10-09 10:11:12.456'} as c5 from {oj t1}, {oj t2} where t1.c1 = t2.c1;
desc v1;

##invalid test
--error 1064
select * from {oj1 t1};
--error 1064
select * from {nlj t1 left outer join t2 on t1.c1=t2.c1};

drop table t1;
drop view v1;