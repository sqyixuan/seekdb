drop view if exists v1, v2;
result_format: 4
select {d '20221009'};
+----------------+
| {d '20221009'} |
+----------------+
| 2022-10-09     |
+----------------+
select {d '20221010'};
+----------------+
| {d '20221010'} |
+----------------+
| 2022-10-10     |
+----------------+
select {t '10:12:13'};
+----------------+
| {t '10:12:13'} |
+----------------+
| 10:12:13       |
+----------------+
select {t '12:12:15.123'};
+--------------------+
| {t '12:12:15.123'} |
+--------------------+
| 12:12:15.123       |
+--------------------+
select {ts '2022-10-09 10:12:13'};
+----------------------------+
| {ts '2022-10-09 10:12:13'} |
+----------------------------+
| 2022-10-09 10:12:13        |
+----------------------------+
select {ts '2022-10-09 10:12:14.456'};
+--------------------------------+
| {ts '2022-10-09 10:12:14.456'} |
+--------------------------------+
| 2022-10-09 10:12:14.456        |
+--------------------------------+
select {d '20221009'}, {t '10:12:13'} , {ts '2022-10-09 10:12:13'};
+----------------+----------------+----------------------------+
| {d '20221009'} | {t '10:12:13'} | {ts '2022-10-09 10:12:13'} |
+----------------+----------------+----------------------------+
| 2022-10-09     | 10:12:13       | 2022-10-09 10:12:13        |
+----------------+----------------+----------------------------+
select {d '20221010'}, {t '12:12:15:23.123'} , {ts '2022-10-09 10:12:14.456'};
+----------------+-----------------------+--------------------------------+
| {d '20221010'} | {t '12:12:15:23.123'} | {ts '2022-10-09 10:12:14.456'} |
+----------------+-----------------------+--------------------------------+
| 2022-10-10     | 12:12:15              | 2022-10-09 10:12:14.456        |
+----------------+-----------------------+--------------------------------+
create view v1 as select {d '20221011'} as c1, {t '12:12:15.1235'} as c2, {ts '2022-10-09 10:12:14.4563'} as c3;
select * from v1;
+------------+---------------+--------------------------+
| c1         | c2            | c3                       |
+------------+---------------+--------------------------+
| 2022-10-11 | 12:12:15.1235 | 2022-10-09 10:12:14.4563 |
+------------+---------------+--------------------------+

##like mysql, invalid time literals just ignore the action and reserve the literals.
select {d '202210092'};
+-----------------+
| {d '202210092'} |
+-----------------+
| 202210092       |
+-----------------+
select {t '101213'};
+--------------+
| {t '101213'} |
+--------------+
| 10:12:13     |
+--------------+
select {ts '20221009 10:12:13'};
+--------------------------+
| {ts '20221009 10:12:13'} |
+--------------------------+
| 20221009 10:12:13        |
+--------------------------+
select {d '2022100922'}, {t '1012134'} , {ts '20221009 10:12:13.333'};
+------------------+---------------+------------------------------+
| {d '2022100922'} | {t '1012134'} | {ts '20221009 10:12:13.333'} |
+------------------+---------------+------------------------------+
| 2022100922       | 101:21:34     | 20221009 10:12:13.333        |
+------------------+---------------+------------------------------+
create view v2 as select {d '20221009241112'} as c1, {t '10:1213.12'} as c2, {ts '20221009 10:12:13.4444'} as c3;
select * from v2;
+----------------+------------+------------------------+
| c1             | c2         | c3                     |
+----------------+------------+------------------------+
| 20221009241112 | 10:1213.12 | 20221009 10:12:13.4444 |
+----------------+------------+------------------------+

##like mysql, invalid action just ignore the action and reserve the literals.
select {dd '20221009'};
+-----------------+
| {dd '20221009'} |
+-----------------+
| 20221009        |
+-----------------+
select {tt '10:12:13'};
+-----------------+
| {tt '10:12:13'} |
+-----------------+
| 10:12:13        |
+-----------------+
select {tts '2022-10-09 10:12:13'};
+-----------------------------+
| {tts '2022-10-09 10:12:13'} |
+-----------------------------+
| 2022-10-09 10:12:13         |
+-----------------------------+
select {dd '20221009'}, {tt '10:12:13'} , {tts '2022-10-09 10:12:13'};
+-----------------+-----------------+-----------------------------+
| {dd '20221009'} | {tt '10:12:13'} | {tts '2022-10-09 10:12:13'} |
+-----------------+-----------------+-----------------------------+
| 20221009        | 10:12:13        | 2022-10-09 10:12:13         |
+-----------------+-----------------+-----------------------------+

drop view v1, v2;
