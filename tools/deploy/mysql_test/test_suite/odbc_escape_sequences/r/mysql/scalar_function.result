drop table if exists t1;
drop view if exists v1;
result_format: 4
create table t1(c1 int, c2 varchar(10));
insert into t1 values (null,'bbbbbb');

select {fn ifnull(min(c1),0)} from t1;
+------------------------+
| {fn ifnull(min(c1),0)} |
+------------------------+
|                      0 |
+------------------------+
select {fn left('aaaaaa',1)} from t1;
+-----------------------+
| {fn left('aaaaaa',1)} |
+-----------------------+
| a                     |
+-----------------------+
select {fn left('aaaaaa',2)} from t1;
+-----------------------+
| {fn left('aaaaaa',2)} |
+-----------------------+
| aa                    |
+-----------------------+
select {fn left('aaaaaa',3)} from t1;
+-----------------------+
| {fn left('aaaaaa',3)} |
+-----------------------+
| aaa                   |
+-----------------------+
select {fn left(c2,3)} from t1;
+-----------------+
| {fn left(c2,3)} |
+-----------------+
| bbb             |
+-----------------+
select {fn substring(c2,0,3)} from t1;
+------------------------+
| {fn substring(c2,0,3)} |
+------------------------+
|                        |
+------------------------+
select {fn substring(c2,1,3)} from t1;
+------------------------+
| {fn substring(c2,1,3)} |
+------------------------+
| bbb                    |
+------------------------+
select {fn substring(c2,3)} from t1;
+----------------------+
| {fn substring(c2,3)} |
+----------------------+
| bbbb                 |
+----------------------+
select {fn abs(-1)} from dual;
+--------------+
| {fn abs(-1)} |
+--------------+
|            1 |
+--------------+
select {fn left({fn substring(c2,1,3)}, 2)} from t1;
+--------------------------------------+
| {fn left({fn substring(c2,1,3)}, 2)} |
+--------------------------------------+
| bb                                   |
+--------------------------------------+
select max({fn left(c2,3)}) from t1;
+----------------------+
| max({fn left(c2,3)}) |
+----------------------+
| bbb                  |
+----------------------+
select * from t1 where {fn substring(c2,1,3)} = 'bbb';
+------+--------+
| c1   | c2     |
+------+--------+
| NULL | bbbbbb |
+------+--------+

create view v1 as select {fn ifnull(min(c1),0)} as cc from t1;
desc v1;
+-------+-----------+------+-----+---------+-------+
| Field | Type      | Null | Key | Default | Extra |
+-------+-----------+------+-----+---------+-------+
| cc    | bigint(1) | NO   |     |         |       |
+-------+-----------+------+-----+---------+-------+

##like mysql, invalid action just ignore the action and reserve the expr.
select {ff ifnull(min(c1),0)} from t1;
+------------------------+
| {ff ifnull(min(c1),0)} |
+------------------------+
|                      0 |
+------------------------+
select {ttt left('aaaaaa',3)} from t1;
+------------------------+
| {ttt left('aaaaaa',3)} |
+------------------------+
| aaa                    |
+------------------------+
select {t1t2 substring(c2,0,3)} from t1;
+--------------------------+
| {t1t2 substring(c2,0,3)} |
+--------------------------+
|                          |
+--------------------------+
select {zzzz abs(-1)} from dual;
+----------------+
| {zzzz abs(-1)} |
+----------------+
|              1 |
+----------------+
select {mmmmmmm left({fn substring(c2,1,3)}, 2)} from t1;
+-------------------------------------------+
| {mmmmmmm left({fn substring(c2,1,3)}, 2)} |
+-------------------------------------------+
| bb                                        |
+-------------------------------------------+

