select utl_raw.bit_complement(c13) from t_data;

--error 600,932
select utl_raw.bit_complement(c14) from t_data;

--error 600,932
select utl_raw.bit_complement(c15) from t_data;
# this bug is found when write testcase. dev has set this bug to wonfix. the correct behavior is this select should be return select result
--echo know issue 22428856
--error 600,932
select utl_raw.bit_complement(c16) from t_data;

select utl_raw.bit_complement(c17) from t_data;

--error 600,932
select utl_raw.bit_complement(ora_rowscn)  from t_data;

select utl_raw.bit_complement(c1),utl_raw.bit_complement(c2), utl_raw.bit_complement(c8), utl_raw.bit_complement(c17) from t_data;

--echo ##mutil-row
insert into t_data(c1,c2,c3,c4,c5,c6,c7,c8,c9,c10,c11,c12,c13,c14,c15,c16) values('1234567890abcdefABCDEF11', 'abcdefABCDEF11', 'abcdefABCDEF11', 2.22222, 2.22222, 2, 2, '1234567890abcdefABCDEF002', date '1992-4-14', TIMESTAMP '1992-4-14 00:00:00 America/Los_Angeles', TIMESTAMP '1992-4-14 00:00:00', TIMESTAMP '1992-4-14 00:00:00', INTERVAL '9999999-2' YEAR(9) TO MONTH, INTERVAL '10 23:14:09' Day(9) TO second, '1234567890abcdefABCDEF', '1234567890abcdefABCDEF' );
insert into t_data(c1,c2,c3,c4,c5,c6,c7,c8,c9,c10,c11,c12,c13,c14,c15,c16) values('1234567890abcdefABCDEF12', 'abcdefABCDEF12', 'abcdefABCDEF12', 3333333, 3333333, 3, 3, '1234567890abcdefABCDEF003', date '1993-4-14', TIMESTAMP '1993-4-14 00:00:00 Asia/Shanghai', TIMESTAMP '1993-4-14 00:00:00', TIMESTAMP '1993-4-14 00:00:00', INTERVAL '9999999-2' YEAR(9) TO MONTH, INTERVAL '10 23:14:09' Day(9) TO second, '1234567890abcdefABCDEF', '1234567890abcdefABCDEF' );

select  utl_raw.bit_complement(ttd.c1) utl_c1 from t_data ttd;

select  utl_raw.bit_complement(t_data.c2) from t_data;

select  utl_raw.bit_complement("TDD"."C2") from t_data tdd;

select  utl_raw.bit_complement("T_DATA".c2) from t_data;

select utl_raw.bit_complement(c1),utl_raw.bit_complement(c2), utl_raw.bit_complement(c8),  utl_raw.bit_complement(c17) from t_data;
--error 1465
select utl_raw.bit_complement(c3) from t_data order by c7;

select utl_raw.bit_complement((select c1 || c2 ||  c8  || c17 from t_data where c7 =1)) || c1 || c2 || c17 from t_data;


--echo ##参数是sub-query
--echo ###多层次测试
select utl_raw.bit_complement((select utl_raw.bit_complement((select utl_raw.bit_complement((select utl_raw.bit_complement((select utl_raw.bit_complement((select utl_raw.bit_complement((select utl_raw.bit_complement((select utl_raw.bit_complement((select utl_raw.bit_complement((c8)) from t_data where c7 =3)) from t_data where c7 =3)) from t_data where c7 =3)) from t_data where c7 =3)) from t_data where c7 =3)) from t_data where c7 =3)) from t_data where c7 =3)) from t_data where c7 =3)) from t_data;

select utl_raw.bit_complement((select utl_raw.bit_complement((select utl_raw.bit_complement((select utl_raw.bit_complement((select utl_raw.bit_complement((select utl_raw.bit_complement((select utl_raw.bit_complement((select utl_raw.bit_complement((c4 || c6 || c7 || '1aacde')) from t_data where c7 =3)) from t_data where c7 =3)) from t_data where c7 =3)) from t_data where c7 =3)) from t_data where c7 =3)) from t_data where c7 =3)) from t_data where c7 =3)) from t_data ;

--echo ###子查询返单行单列
select utl_raw.bit_complement((select utl_raw.bit_complement((c1 || c2 || c8 || '1aacde')) from t_data where c7 =3)) from t_data;

--echo ###子查询返多行单列
--error 1427
select utl_raw.bit_complement((select utl_raw.bit_complement((c1 || c2 || c8 || '1aacde')) from t_data where c7 <> 3)) from t_data;

--echo ###子查询返多行多列
--error 913
select utl_raw.bit_complement((select utl_raw.bit_complement((c1 || c2 || c8 || '1aacde')), utl_raw.bit_complement(c1) from t_data where c7 <> 3)) from t_data;

--echo ###子查询返单行多列
--error 913
select utl_raw.bit_complement((select utl_raw.bit_complement((c1 || c2 || c8 || '1aacde')),utl_raw.bit_complement(c1) from t_data where c7 = 1)) from t_data;

--echo ##返回值做表达式
select utl_raw.bit_complement(c1) || '111' from t_data;

--echo #where子部分
select utl_raw.bit_complement(c1 || c2 || c8 )  as cc from t_data where c17 <= utl_raw.bit_complement(c1 || c8);

select utl_raw.bit_complement(c1 || c2 || c8)  as cc from t_data where utl_raw.bit_complement(c17) between utl_raw.bit_complement(c1) and  utl_raw.bit_complement(c1 || c2 || c8);

select utl_raw.bit_complement(c1 || c2 || c8)  as cc from t_data where utl_raw.bit_complement(c17) like '%F%';

select utl_raw.bit_complement(c1 || c2 || c8 )  as cc from t_data where utl_raw.bit_complement(c17) in (select c1 || c2 || c8 from t_data) order by utl_raw.bit_complement(c17);

select utl_raw.bit_complement(c1 || c2 || c8)  as cc from t_data where utl_raw.bit_complement(c17) > any (select c1 || c2 || c8 from t_data) order by utl_raw.bit_complement(c17);

select utl_raw.bit_complement(c1 || c2 || c8)  as cc from t_data where utl_raw.bit_complement(c17) >= all (select c1 || c2 || c8 from t_data) order by utl_raw.bit_complement(c17);
--error 1427
select utl_raw.bit_complement(c1 || c2 || c8)  as cc from t_data where (utl_raw.bit_complement(c17),utl_raw.bit_complement(c17)) = (select c1,c2 from t_data) order by utl_raw.bit_complement(c17);

select utl_raw.bit_complement(c1 || c2 || c8)  as cc from t_data where utl_raw.bit_complement(c17) in (select utl_raw.bit_complement(c1 || c2 || c8) from t_data) order by utl_raw.bit_complement(c17);


--echo #group by and having  + order
select avg(c7),count(c17) from t_data group by utl_raw.bit_complement(c1) having  utl_raw.bit_complement(utl_raw.cast_to_raw(avg(c7))) < utl_raw.bit_complement(c1) order by utl_raw.bit_complement(utl_raw.cast_to_raw(avg(c7)));

--echo #over子句
select avg(utl_raw.length(utl_raw.bit_complement(c1))) over(partition by (utl_raw.bit_complement(c2)) order by utl_raw.length(utl_raw.bit_complement(c8)) desc range between 1000 preceding and 2000 following) from t_data order by utl_raw.bit_complement(c1);

insert into t_cons(c1,c2,c3,c4,c5,c6,c7,c8,c9,c10,c11,c12,c13,c14,c15,c16) values('1234567890abcdefABCDEF', 'abcdefABCDEF', 'abcdefABCDEF', 1, 1, 1, 1, 'abcdef1234567890', date '1990-4-14', TIMESTAMP '1990-4-14 00:00:00 America/Los_Angeles', TIMESTAMP '1990-4-14 00:00:00', TIMESTAMP '1990-4-14 00:00:00', INTERVAL '9999999-2' YEAR(9) TO MONTH, INTERVAL '10 23:14:09' Day(9) TO second, '1234567890abcdefABCDEF', '1234567890abcdefABCDEF' );
insert into t_cons(c1,c2,c3,c4,c5,c6,c7,c8,c9,c10,c11,c12,c13,c14,c15,c16) values('1234567890abcdefABCDEF11', 'abcdefABCDEF11', 'abcdefABCDEF11', 2.22222, 2.22222, 2, 2, '1234567890abcdefABCDEF002', date '1992-4-14', TIMESTAMP '1992-4-14 00:00:00 America/Los_Angeles', TIMESTAMP '1992-4-14 00:00:00', TIMESTAMP '1992-4-14 00:00:00', INTERVAL '9999999-2' YEAR(9) TO MONTH, INTERVAL '10 23:14:09' Day(9) TO second, '1234567890abcdefABCDEF', '1234567890abcdefABCDEF' );
insert into t_cons(c1,c2,c3,c4,c5,c6,c7,c8,c9,c10,c11,c12,c13,c14,c15,c16) values('1234567890abcdefABCDEF12', 'abcdefABCDEF12', 'abcdefABCDEF12', 3333333, 3333333, 3, 3, '1234567890abcdefABCDEF003', date '1993-4-14', TIMESTAMP '1993-4-14 00:00:00 Asia/Shanghai', TIMESTAMP '1993-4-14 00:00:00', TIMESTAMP '1993-4-14 00:00:00', INTERVAL '9999999-2' YEAR(9) TO MONTH, INTERVAL '10 23:14:09' Day(9) TO second, '1234567890abcdefABCDEF', '1234567890abcdefABCDEF' );

--echo #join on
select utl_raw.bit_complement(ttd.c1),utl_raw.bit_complement(tcd.c2),  utl_raw.bit_complement(tcd.c8),utl_raw.bit_complement(ttd.c17) from  t_data ttd inner join t_cons tcd on utl_raw.bit_complement(ttd.c1) >= utl_raw.bit_complement(tcd.c1) order by utl_raw.bit_complement(ttd.c1),utl_raw.bit_complement(tcd.c2);

--echo #start with connect by
select c1 from t_data start with c7 = 1 connect  by nocycle prior c1 <> c2;

select utl_raw.bit_complement(c17) from t_data start with utl_raw.bit_complement(c1) = utl_raw.bit_complement('1234567890abcdefABCDEF')  connect  by nocycle prior utl_raw.bit_complement(c1) <> utl_raw.bit_complement(c2);

select  utl_raw.bit_complement(c1),utl_raw.bit_complement(c2),utl_raw.bit_complement(c8) from t_data start with utl_raw.bit_complement(c1) = utl_raw.bit_complement('1234567890abcdefABCDEF')  connect  by nocycle prior utl_raw.bit_complement(c1) <> utl_raw.bit_complement(c2);

select utl_raw.bit_complement(c1),utl_raw.bit_complement(c2),utl_raw.bit_complement(c8) from t_data connect  by nocycle prior utl_raw.bit_complement(c1) <> utl_raw.bit_complement(c2);

select utl_raw.bit_complement(c1),utl_raw.bit_complement(c2),utl_raw.bit_complement(c8) from t_data connect  by nocycle prior utl_raw.bit_complement(c1) <> utl_raw.bit_complement(c2) start with utl_raw.bit_complement(c1) = utl_raw.bit_complement('1234567890abcdefABCDEF');

--echo #with-as
with ttest1(c1) as (select utl_raw.bit_complement(c1) from t_data), ttest2(c8) as (select utl_raw.bit_complement(c8) from t_data) select /*+no_rewrite*/ utl_raw.bit_complement(r1.c1), r2.c8, utl_raw.bit_complement(r3.c17) from ttest1 r1, ttest2 r2, t_data r3 where r1.c1 = utl_raw.bit_complement(r3.c1) or r2.c8 = utl_raw.bit_complement(r3.c8) order by r1.c1,r2.c8,r3.c17;

with ttest(c1,c2,c17) as ((select utl_raw.bit_complement(c1),utl_raw.bit_complement(c2),utl_raw.bit_complement(c17) from t_data where c7 = 1) union all(select utl_raw.bit_complement(r2.c1),utl_raw.bit_complement(r2.c2),utl_raw.bit_complement(r2.c17) from t_data r1, ttest r2 where utl_raw.bit_complement(r2.c1) = utl_raw.bit_complement(utl_raw.bit_complement(r1.c1)))) select c1,c2,c17 from ttest order by c1;

--error 32044
with ttest(c1,c2,c17) as ((select utl_raw.bit_complement(c1),utl_raw.bit_complement(c2),utl_raw.bit_complement(c17) from t_data where c7 = 1) union all(select utl_raw.bit_complement(r2.c1),utl_raw.bit_complement(r2.c2),utl_raw.bit_complement(r2.c17) from t_data r1, ttest r2 where utl_raw.bit_complement(r2.c1) <> utl_raw.bit_complement(utl_raw.bit_complement(r1.c1)))) select c1,c2,c17 from ttest order by c1;

with ttest(c1,c2) as ((select utl_raw.bit_complement(c1),utl_raw.bit_complement(c2) from t_data where c7 = 1) union all(select utl_raw.bit_complement(r2.c1),utl_raw.bit_complement(r2.c2) from t_data r1, ttest r2 where utl_raw.bit_complement(r2.c1) < utl_raw.bit_complement(utl_raw.bit_complement(r1.c1)) and utl_raw.length(r2.c1) <=1000 )) SEARCH DEPTH FIRST BY c1 SET order1 CYCLE c1 SET is_cycle TO 'Y' DEFAULT 'N' select c1,c2 from ttest order by c1;

--echo #case语句
select case utl_raw.bit_complement(c1) when utl_raw.bit_complement('1234567890abcdefABCDEF12') then utl_raw.bit_complement(c8) else utl_raw.bit_complement(c17) end from t_data order by utl_raw.bit_complement(c1);

select case when utl_raw.bit_complement(c1) = utl_raw.bit_complement('1234567890abcdefABCDEF12') then utl_raw.bit_complement(c8)  else utl_raw.bit_complement(c17) end from t_data order by utl_raw.bit_complement(c1);

--echo #作为参数
--echo ##普通字符串函数
select length(utl_raw.bit_complement(c1)) from t_data;
select lengthb(utl_raw.bit_complement(c1)) from t_data;

select length(c8) from t_data;
select lengthb(c8) from t_data;

select concat(utl_raw.bit_complement(c1), utl_raw.bit_complement(c1)) from t_data;

select concat(c8,c8) from t_data order by utl_raw.bit_complement(c1);

select concat(c1,c8) from t_data order by utl_raw.bit_complement(c1);

select upper(utl_raw.bit_complement(c1)) from t_data order by utl_raw.bit_complement(c1);

select lower(utl_raw.bit_complement(c1)) from t_data order by utl_raw.bit_complement(c1);

select lower(c8) from t_data order by utl_raw.bit_complement(c1);

select substr(utl_raw.bit_complement(c1), 2) from t_data order by utl_raw.bit_complement(c1);

select lengthb(utl_raw.bit_complement(c1)) from t_data order by utl_raw.bit_complement(c1);


select decode(utl_raw.bit_complement(c1), utl_raw.bit_complement('1234567890abcdefABCDEF12'), utl_raw.bit_complement(c1), utl_raw.bit_complement(c17)) from t_data;

select to_number(utl_raw.bit_complement(utl_raw.bit_complement(utl_raw.cast_to_raw(c7)))) from t_data order by utl_raw.bit_complement(c1);

select trim(utl_raw.bit_complement(c1 || c2)) from t_data order by utl_raw.bit_complement(c1);

select lpad(utl_raw.bit_complement(c1 || c2),20) from t_data order by utl_raw.bit_complement(c1);

select coalesce(utl_raw.bit_complement(c1), utl_raw.bit_complement(c2),  utl_raw.bit_complement(c8), utl_raw.bit_complement(c17)) from t_data order by utl_raw.bit_complement(c1);

select nvl(utl_raw.bit_complement(c1),'aaaaaaaaaa') from t_data order by utl_raw.bit_complement(c1);

select nvl(utl_raw.bit_complement(null),utl_raw.bit_complement(c1)) from t_data order by utl_raw.bit_complement(c1);

select nvl(utl_raw.bit_complement(null),c8) from t_data order by utl_raw.bit_complement(c1);

select least(utl_raw.bit_complement(c8), utl_raw.bit_complement(c1),utl_raw.bit_complement(c2)) from t_data order by utl_raw.bit_complement(c1);
select greatest(utl_raw.bit_complement(c8), utl_raw.bit_complement(c1),utl_raw.bit_complement(c2)) from t_data order by utl_raw.bit_complement(c1);
select least(c8, utl_raw.bit_complement(c1),utl_raw.bit_complement(c2)) from t_data order by utl_raw.bit_complement(c1);
select greatest(c8, utl_raw.bit_complement(c1),utl_raw.bit_complement(c2)) from t_data order by utl_raw.bit_complement(c1);

--echo ##聚合函数
select count(utl_raw.bit_complement(c8)) from t_data;

--echo ##utl_raw包函数
select utl_raw.length(utl_raw.bit_complement(c8)) from t_data order by utl_raw.bit_complement(c1);
select utl_raw.cast_to_raw(utl_raw.bit_complement(c8)) from t_data order by utl_raw.bit_complement(c1);
select utl_raw.BIT_COMPLEMENT(utl_raw.bit_complement(c8)), utl_raw.BIT_COMPLEMENT(utl_raw.bit_complement(c1)) , utl_raw.BIT_COMPLEMENT(utl_raw.bit_complement(c2)) from t_data order by utl_raw.bit_complement(c1);
