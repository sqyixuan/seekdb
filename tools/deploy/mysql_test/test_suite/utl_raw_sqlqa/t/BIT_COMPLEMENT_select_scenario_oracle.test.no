#description: utl_raw.bit_complement 系统函数测试-select

--source mysql_test/test_suite/otimestamp/t/otimestamp_import_time_zone.inc

alter session set nls_date_format = 'YYYY-MM-DD HH24:MI:SS';
alter session set NLS_TIMESTAMP_FORMAT = 'YYYY-MM-DD HH24:MI:SS.FF';
alter session set NLS_TIMESTAMP_TZ_FORMAT = 'YYYY-MM-DD HH24:MI:SS.FF TZR TZD';
alter session SET TIME_ZONE = 'ASIA/SHANGHAI';

--disable_warnings
--error 0,942
DROP TABLE t_data CASCADE CONSTRAINTS purge;
--error 0,942
DROP TABLE t_cons CASCADE CONSTRAINTS purge;
--enable_warnings

create table t_data(c1 varchar2(4000),c2 varchar(4000), c3 char(1000), c4 number, c5 numeric, c6 int, c7 smallint, c8 raw(2000), c9 date, c10 timestamp, c11 timestamp with time zone, c12 timestamp with local time zone, c13 interval year(9) to month, c14 interval day(9) to second, c15 clob, c16 blob, c17 generated always as(c1 || c2 || c8));
create table t_cons(c1 varchar2(4000),c2 varchar(4000), c3 char(1000), c4 number, c5 numeric, c6 int, c7 smallint, c8 raw(2000), c9 date, c10 timestamp, c11 timestamp with time zone, c12 timestamp with local time zone, c13 interval year(9) to month, c14 interval day(9) to second, c15 clob, c16 blob, c17 generated always as(c1 || c2 || c8));

--echo #select子部分
--echo ##空表

select utl_raw.bit_complement(c1) from t_data;

select utl_raw.bit_complement(c2) from t_data;

select utl_raw.bit_complement(c3) from t_data;

--error 600,932
select utl_raw.bit_complement(c4) from t_data;

