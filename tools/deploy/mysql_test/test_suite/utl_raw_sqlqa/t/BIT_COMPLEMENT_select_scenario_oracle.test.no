select utl_raw.bit_complement(c6) from t_data;

--error 600,932
select utl_raw.bit_complement(c7) from t_data;

select utl_raw.bit_complement(c8) from t_data;

--error 600,932
select utl_raw.bit_complement(c9) from t_data;

--error 600,932
select utl_raw.bit_complement(c10) from t_data;

--error 600,932
select utl_raw.bit_complement(c11) from t_data;

