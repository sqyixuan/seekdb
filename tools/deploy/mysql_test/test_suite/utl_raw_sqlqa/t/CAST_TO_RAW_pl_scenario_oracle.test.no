--source mysql_test/test_suite/otimestamp/t/otimestamp_import_time_zone.inc

alter session set nls_date_format = 'YYYY-MM-DD HH24:MI:SS';
alter session set NLS_TIMESTAMP_FORMAT = 'YYYY-MM-DD HH24:MI:SS.FF';
alter session set NLS_TIMESTAMP_TZ_FORMAT = 'YYYY-MM-DD HH24:MI:SS.FF TZR TZD';
alter session SET TIME_ZONE = 'ASIA/SHANGHAI';

--disable_warnings
--error 0,942
DROP TABLE t_data CASCADE CONSTRAINTS purge;

--error 0,600
drop FUNCTION print;

--error 0,600
drop procedure type_produce_in;

--enable_warnings
call dbms_output.enable();

create table t_data(c1 varchar2(4000),c2 varchar(4000), c3 char(1000), c4 number, c5 numeric, c6 int, c7 smallint, c8 raw(2000), c9 date, c10 timestamp, c11 timestamp with time zone, c12 timestamp with local time zone, c13 interval year(9) to month, c14 interval day(9) to second, c15 clob, c16 blob);
insert into t_data(c1,c2,c3,c4,c5,c6,c7,c8,c9,c10,c11,c12,c13,c14,c15,c16) values('c1-utl_raw_test-varchar2', 'c2-utl_raw_test-varchar(4000)', 'c3-utl_raw_test-char(2000)', 1, 1, 1, 1, '1234567890abcdefABCDEF', date '1990-4-14', TIMESTAMP '1990-4-14 00:00:00 America/Los_Angeles', TIMESTAMP '1990-4-14 00:00:00', TIMESTAMP '1990-4-14 00:00:00', INTERVAL '9999999-2' YEAR(9) TO MONTH, INTERVAL '10 23:14:09' Day(9) TO second, '1234567890abcdefABCDEF', '1234567890abcdefABCDEF' );
insert into t_data(c1,c2,c3,c4,c5,c6,c7,c8,c9,c10,c11,c12,c13,c14,c15,c16) values('c1-utl_raw_test-varchar2-002', 'c2-utl_raw_test-varchar(4000)-002', 'c3-utl_raw_test-char(2000)-002', 2.22222, 2.22222, 2, 2, '1234567890abcdefABCDEF002', date '1992-4-14', TIMESTAMP '1992-4-14 00:00:00 America/Los_Angeles', TIMESTAMP '1992-4-14 00:00:00', TIMESTAMP '1992-4-14 00:00:00', INTERVAL '9999999-2' YEAR(9) TO MONTH, INTERVAL '10 23:14:09' Day(9) TO second, '1234567890abcdefABCDEF', '1234567890abcdefABCDEF' );
insert into t_data(c1,c2,c3,c4,c5,c6,c7,c8,c9,c10,c11,c12,c13,c14,c15,c16) values('c1-utl_raw_test-varchar2-003', 'c2-utl_raw_test-varchar(4000)-003', 'c3-utl_raw_test-char(2000)-003', 3333333, 3333333, 3, 3, '1234567890abcdefABCDEF003', date '1993-4-14', TIMESTAMP '1993-4-14 00:00:00 Asia/Shanghai', TIMESTAMP '1993-4-14 00:00:00', TIMESTAMP '1993-4-14 00:00:00', INTERVAL '9999999-2' YEAR(9) TO MONTH, INTERVAL '10 23:14:09' Day(9) TO second, '1234567890abcdefABCDEF', '1234567890abcdefABCDEF' );

delimiter /;
CREATE OR REPLACE FUNCTION print RETURN VARCHAR2 IS
  r VARCHAR2(4000);
  t INT;
  r1 VARCHAR2(4000);
BEGIN
  DBMS_OUTPUT.GET_LINE(r, t);
  WHILE t != 1 LOOP
    DBMS_OUTPUT.GET_LINE(r1, t);
    r := r || ' ' || r1;
  END LOOP;
  RETURN r;
END;
/

create or replace function func_utl(tp raw) return raw is
begin
	return utl_raw.cast_to_raw(tp);
end;
/

# in/out paramter
create or replace procedure type_produce_in(tp1 varchar,tp2 varchar2,tp3 char,tp4 raw, tp5 clob) is
begin
        dbms_output.put_line(tp1);
        dbms_output.put_line(tp2);
        dbms_output.put_line(tp3);
        dbms_output.put_line(tp4);
		dbms_output.put_line(tp5);
end;
/

--disable_warnings
create or replace procedure type_produce_out_clob(tp1 out clob) is
begin
	tp1 := utl_raw.cast_to_raw('111this is the test for procedure test-out!!');

end;
/
--enable_warnings
create or replace procedure type_produce_out_tmp_clob is
	tt1 clob;	
begin
	 type_produce_out_clob(tt1);
	dbms_output.put_line(tt1);
end;
/

create or replace procedure type_produce_out(tp1 out varchar,tp2 out varchar2,tp3 out char,tp4 out raw) is
begin
	tp1 := utl_raw.cast_to_raw('111this is the test for procedure test-out!!');
	tp2 := utl_raw.cast_to_raw('111this is the test for procedure test-out!!');
	tp3 := utl_raw.cast_to_raw('111this is the test for procedure test-out!!');
	tp4 := utl_raw.cast_to_raw('111this is the test for procedure test-out!!');

end;
/

create or replace procedure type_produce_out_tmp is
	tt1 varchar(4000);
	tt2 varchar2(4000);
	tt3 char(1000);
	tt4 raw(2000);
begin
	type_produce_out(tt1,tt2,tt3,tt4);
    dbms_output.put_line(tt1);
    dbms_output.put_line(tt2);
    dbms_output.put_line(tt3);
    dbms_output.put_line(tt4);
end;
/

create or replace procedure proceduce_sql is
ttrwo1 t_data%rowtype;
begin
        select utl_raw.cast_to_raw(c1),utl_raw.cast_to_raw(c2),utl_raw.cast_to_raw(c8)  into ttrwo1.c1,ttrwo1.c2,ttrwo1.c8 from t_data where utl_raw.cast_to_raw(c7) = utl_raw.cast_to_raw(2);
        insert into t_data(c1,c2,c8) values(utl_raw.cast_to_raw(ttrwo1.c1),utl_raw.cast_to_raw(ttrwo1.c2),utl_raw.cast_to_raw(ttrwo1.c8));
        update t_data set c1 = utl_raw.cast_to_raw(ttrwo1.c1) where c7 is null;
        delete from t_data where utl_raw.cast_to_raw(c7) = utl_raw.cast_to_raw(2);
end;
/

create or replace function proceduce_cur return raw is
tt1 t_data.c1%type;
tt2 t_data.c2%type;
tt8 t_data.c8%type;
ttt raw(2000);
CURSOR utl_CURSOR is
        select utl_raw.cast_to_raw(c1),utl_raw.cast_to_raw(c2),utl_raw.cast_to_raw(c8) from t_data;
begin
        ttt := utl_raw.cast_to_raw('1');
        open utl_CURSOR;
        Loop
                FETCH utl_CURSOR into tt1,tt2,tt8;
                exit when utl_CURSOR%NOTFOUND;
                ttt := utl_raw.concat(ttt,tt1);
                ttt := utl_raw.concat(ttt,tt2);
                ttt := utl_raw.concat(ttt,tt8);
        end loop;

        return ttt;
end;
/


delimiter ;/

select func_utl(utl_raw.cast_to_raw('abcdefaa')) from dual;

#utl_raw.cast_to_raw的结果不能给clob
--error 600, 932
call type_produce_in(utl_raw.cast_to_raw('111this is the test for procedure test!!'),utl_raw.cast_to_raw('111this is the test for procedure test!!'),utl_raw.cast_to_raw('111this is the test for procedure test!!'),utl_raw.cast_to_raw('111this is the test for procedure test!!'),utl_raw.cast_to_raw('111this is the test for procedure test!!'));

call type_produce_in(utl_raw.cast_to_raw('111this is the test for procedure test!!'),utl_raw.cast_to_raw('111this is the test for procedure test!!'),utl_raw.cast_to_raw('111this is the test for procedure test!!'),utl_raw.cast_to_raw('111this is the test for procedure test!!'),'111this is the test for procedure test!!');
select print() from dual;

call type_produce_out_tmp_clob();
select print() from dual;

call type_produce_out_tmp();
select print() from dual;

call proceduce_sql();
select proceduce_cur() from dual;

--disable_warnings
--error 0,942
DROP TABLE t_data CASCADE CONSTRAINTS purge;
--enable_warnings
