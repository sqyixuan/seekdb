--source mysql_test/test_suite/otimestamp/t/otimestamp_import_time_zone.inc

alter session set nls_date_format = 'YYYY-MM-DD HH24:MI:SS';
alter session set NLS_TIMESTAMP_FORMAT = 'YYYY-MM-DD HH24:MI:SS.FF';
alter session set NLS_TIMESTAMP_TZ_FORMAT = 'YYYY-MM-DD HH24:MI:SS.FF TZR TZD';
alter session SET TIME_ZONE = 'ASIA/SHANGHAI';


--disable_warnings
--error 0,942
DROP TABLE t_data CASCADE CONSTRAINTS purge;
--error 0,942
DROP TABLE t_cons CASCADE CONSTRAINTS purge;
--enable_warnings
call dbms_output.enable();

--source load_zone_name.inc


#create table t_data(c1 varchar2(4000),c2 varchar(4000) unique, c3 char(1000), c4 number, c5 numeric, c6 int, c7 smallint, c8 raw(2000), c9 date, c10 timestamp, c11 timestamp with time zone, c12 timestamp with local time zone, c13 interval year(9) to month, c14 interval day(9) to second, c15 clob, c16 blob, c17 generated always as(c1 || c2 || c8),constraint tdata_pk primary key(c1,c8)) pctfree 3  pctused 3 initrans 3  enable row movement PARTITION BY hash(c8) partitions 5;
#create table t_cons(c1 varchar2(4000),c2 varchar(4000) unique, c3 char(1000), c4 number, c5 numeric, c6 int, c7 smallint, c8 raw(2000), c9 date, c10 timestamp, c11 timestamp with time zone, c12 timestamp with local time zone, c13 interval year(9) to month, c14 interval day(9) to second, c15 clob, c16 blob, c17 generated always as(c1 || c2 || c8),constraint tcons_pk primary key(c1,c8)) pctfree 3  pctused 3 initrans 3  enable row movement PARTITION BY hash(c8) partitions 5;

eval create table t_data(c1 varchar2(4000),c2 varchar(4000) unique, c3 char(1000), c4 number, c5 numeric, c6 int, c7 smallint, c8 raw(2000), c9 date, c10 timestamp, c11 timestamp with time zone, c12 timestamp with local time zone, c13 interval year(9) to month, c14 interval day(9) to second, c15 clob, c16 blob, c17 generated always as(c1 || c2 || c8),constraint tdata_pk primary key(c1,c8)) primary_zone='$zone_1' pctfree 3  pctused 3 initrans 3  enable row movement PARTITION BY hash(c8) partitions 5;
eval create table t_cons(c1 varchar2(4000),c2 varchar(4000) unique, c3 char(1000), c4 number, c5 numeric, c6 int, c7 smallint, c8 raw(2000), c9 date, c10 timestamp, c11 timestamp with time zone, c12 timestamp with local time zone, c13 interval year(9) to month, c14 interval day(9) to second, c15 clob, c16 blob, c17 generated always as(c1 || c2 || c8),constraint tcons_pk primary key(c1,c8)) primary_zone='$zone_2' pctfree 3  pctused 3 initrans 3  enable row movement PARTITION BY hash(c8) partitions 5;

set session ob_query_timeout = 400000000;
create unique index t_data_idx_local on t_data(c2, c8) local visible;
create index  t_data_idx_global on t_data(c1) global PARTITION by hash(c1) PARTITIONS 20;
set session ob_query_timeout = 10000000;

insert into t_data(c1,c2,c3,c4,c5,c6,c7,c8,c9,c10,c11,c12,c13,c14,c15,c16) values('1234567890abcdefABCDEF', 'abcdefABCDEF', 'abcdefABCDEF', 1, 1, 1, 1, 'abcdef1234567890', date '1990-4-14', TIMESTAMP '1990-4-14 00:00:00 America/Los_Angeles', TIMESTAMP '1990-4-14 00:00:00', TIMESTAMP '1990-4-14 00:00:00', INTERVAL '9999999-2' YEAR(9) TO MONTH, INTERVAL '10 23:14:09' Day(9) TO second, '1234567890abcdefABCDEF', '1234567890abcdefABCDEF' );
insert into t_data(c1,c2,c3,c4,c5,c6,c7,c8,c9,c10,c11,c12,c13,c14,c15,c16) values('1234567890abcdefABCDEF11', 'abcdefABCDEF11', 'abcdefABCDEF11', 2.22222, 2.22222, 2, 2, '1234567890abcdefABCDEF002', date '1992-4-14', TIMESTAMP '1992-4-14 00:00:00 America/Los_Angeles', TIMESTAMP '1992-4-14 00:00:00', TIMESTAMP '1992-4-14 00:00:00', INTERVAL '9999999-2' YEAR(9) TO MONTH, INTERVAL '10 23:14:09' Day(9) TO second, '1234567890abcdefABCDEF', '1234567890abcdefABCDEF' );
insert into t_data(c1,c2,c3,c4,c5,c6,c7,c8,c9,c10,c11,c12,c13,c14,c15,c16) values('1234567890abcdefABCDEF12', 'abcdefABCDEF12', 'abcdefABCDEF12', 3333333, 3333333, 3, 3, '1234567890abcdefABCDEF003', date '1993-4-14', TIMESTAMP '1993-4-14 00:00:00 Asia/Shanghai', TIMESTAMP '1993-4-14 00:00:00', TIMESTAMP '1993-4-14 00:00:00', INTERVAL '9999999-2' YEAR(9) TO MONTH, INTERVAL '10 23:14:09' Day(9) TO second, '1234567890abcdefABCDEF', '1234567890abcdefABCDEF' );



--echo 使用存储过程插入100行
--disable_warnings
delimiter /;

create or replace procedure insert10krows(rp raw) is
	isize number;
	rtp raw(2000);
begin
	isize:=1;
	while isize <= 100 Loop
		rtp := utl_raw.concat(rp, utl_raw.cast_to_raw(to_char(isize)));
		rtp := utl_raw.concat(utl_raw.cast_to_raw(to_char(isize)),rtp);
		insert into t_data ( c1,c2,c4,c5,c6,c7,c8,c9,c10,c11,c12) values(rtp,rtp,isize+123,isize+1234,isize+127,isize+3,rtp,date '1992-4-14', TIMESTAMP '1992-4-14 00:00:00 America/Los_Angeles', TIMESTAMP '1992-4-14 00:00:00', TIMESTAMP '1992-4-14 00:00:00');
		isize := isize + 1;
	end loop;
	commit;
end;
/

delimiter ;/

--enable_warnings

call insert10krows(utl_raw.cast_to_raw('def1234567890ab234567890abcdef1234567890abcdef1234567890abcdef123456789cdef1234567890abcdef1234567890abcdef1234567890abcdef1234567890abcdef1890abcdef1234567890abcdef1234567890abcdef1234567890abcdef1234567890abcdef34567890abcdef1234567890abcdef123456789034567890abcdef1234567890abcdef1234567890abc'));
alter table t_cons drop column c17;

insert into  t_cons(c1,c2,c3,c4,c5,c6,c7,c8,c9,c10,c11,c12,c13,c14,c15,c16) select c1,c2,c3,c4,c5,c6,c7,c8,c9,c10,c11,c12,c13,c14,c15,c16 from t_data where mod(c7,3) = 1 ;

