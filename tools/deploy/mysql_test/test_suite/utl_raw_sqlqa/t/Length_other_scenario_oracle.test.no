#(select utl_raw.length(c1), utl_raw.length(c2), utl_raw.length(c8) from t_data) union all (select utl_raw.length(t1.c1 || t2.c1), utl_raw.length(t1.c2 || t2.c2), utl_raw.length(t1.c8 || t2.c8) from  t_data t1 right outer join t_cons t2 on utl_raw.length(t1.c8) >= utl_raw.length(t2.c8)) where mod(t1.c5,31) <= 1 order by t1.c5;
#set session ob_query_timeout = 10000000;

select utl_raw.length(t1.c1 || t2.c1) a1, utl_raw.length(t1.c2 || t2.c2) a2, utl_raw.length(t1.c8 || t2.c8) a3 from  t_data t1 right outer join t_cons t2 on utl_raw.length(t1.c8) >= utl_raw.length(t2.c8) where mod(t1.c5,31) <= 1 order by a1,a2,a3;
--source mysql_test/include/minorfreeze.inc
sleep 60;
select utl_raw.length(t1.c1 || t2.c1) a1, utl_raw.length(t1.c2 || t2.c2) a2, utl_raw.length(t1.c8 || t2.c8) a3 from  t_data t1 right outer join t_cons t2 on utl_raw.length(t1.c8) >= utl_raw.length(t2.c8) where mod(t1.c5,31) <= 1 order by a1,a2,a3;
TRUNCATE TABLE t_cons;

insert into  t_cons(c1,c2,c3,c4,c5,c6,c7,c8,c9,c10,c11,c12,c13,c14,c15,c16) select c1,c2,c3,c4,c5,c6,c7,c8,c9,c10,c11,c12,c13,c14,c15,c16 from t_data where mod(c7,3) = 0 ;

select utl_raw.length(t1.c1 || t2.c1) a1, utl_raw.length(t1.c2 || t2.c2) a2, utl_raw.length(t1.c8 || t2.c8) a3 from  t_data t1 right outer join t_cons t2 on utl_raw.length(t1.c8) >= utl_raw.length(t2.c8) where mod(t1.c5,31) <= 1 order by a1,a2,a3;
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
select utl_raw.length(t1.c1 || t2.c1) a1, utl_raw.length(t1.c2 || t2.c2) a2, utl_raw.length(t1.c8 || t2.c8) a3 from  t_data t1 right outer join t_cons t2 on utl_raw.length(t1.c8) >= utl_raw.length(t2.c8) where mod(t1.c5,31) <= 1 order by a1,a2,a3;


