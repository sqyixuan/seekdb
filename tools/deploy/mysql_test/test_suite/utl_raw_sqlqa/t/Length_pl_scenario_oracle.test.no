#description: utl_raw.length 系统函数测试-同义词，视图，insert， update and delete 子句

--source mysql_test/test_suite/otimestamp/t/otimestamp_import_time_zone.inc

alter session set nls_date_format = 'YYYY-MM-DD HH24:MI:SS';
alter session set NLS_TIMESTAMP_FORMAT = 'YYYY-MM-DD HH24:MI:SS.FF';
alter session set NLS_TIMESTAMP_TZ_FORMAT = 'YYYY-MM-DD HH24:MI:SS.FF TZR TZD';
alter session SET TIME_ZONE = 'ASIA/SHANGHAI';

--disable_warnings
--error 0,942
DROP TABLE t_data CASCADE CONSTRAINTS purge;

--error 0,600
drop FUNCTION print;

--error 0,600
drop procedure type_produce_in;

--enable_warnings
call dbms_output.enable();

create table t_data(c1 varchar2(4000),c2 varchar(4000), c3 char(1000), c4 number, c5 numeric, c6 int, c7 smallint, c8 raw(2000), c9 date, c10 timestamp, c11 timestamp with time zone, c12 timestamp with local time zone, c13 interval year(9) to month, c14 interval day(9) to second, c15 clob, c16 blob);
insert into t_data(c1,c2,c3,c4,c5,c6,c7,c8,c9,c10,c11,c12,c13,c14,c15,c16) values('1234567890abcdefABCDEF', 'abcdefABCDEF', 'abcdefABCDEF', 1, 1, 1, 1, 'abcdef1234567890', date '1990-4-14', TIMESTAMP '1990-4-14 00:00:00 America/Los_Angeles', TIMESTAMP '1990-4-14 00:00:00', TIMESTAMP '1990-4-14 00:00:00', INTERVAL '9999999-2' YEAR(9) TO MONTH, INTERVAL '10 23:14:09' Day(9) TO second, '1234567890abcdefABCDEF', '1234567890abcdefABCDEF' );
insert into t_data(c1,c2,c3,c4,c5,c6,c7,c8,c9,c10,c11,c12,c13,c14,c15,c16) values('1234567890abcdefABCDEF11', 'abcdefABCDEF11', 'abcdefABCDEF11', 2.22222, 2.22222, 2, 2, '1234567890abcdefABCDEF002', date '1992-4-14', TIMESTAMP '1992-4-14 00:00:00 America/Los_Angeles', TIMESTAMP '1992-4-14 00:00:00', TIMESTAMP '1992-4-14 00:00:00', INTERVAL '9999999-2' YEAR(9) TO MONTH, INTERVAL '10 23:14:09' Day(9) TO second, '1234567890abcdefABCDEF', '1234567890abcdefABCDEF' );
insert into t_data(c1,c2,c3,c4,c5,c6,c7,c8,c9,c10,c11,c12,c13,c14,c15,c16) values('1234567890abcdefABCDEF12', 'abcdefABCDEF12', 'abcdefABCDEF12', 3333333, 3333333, 3, 3, '1234567890abcdefABCDEF003', date '1993-4-14', TIMESTAMP '1993-4-14 00:00:00 Asia/Shanghai', TIMESTAMP '1993-4-14 00:00:00', TIMESTAMP '1993-4-14 00:00:00', INTERVAL '9999999-2' YEAR(9) TO MONTH, INTERVAL '10 23:14:09' Day(9) TO second, '1234567890abcdefABCDEF', '1234567890abcdefABCDEF' );

delimiter /;
CREATE OR REPLACE FUNCTION print RETURN VARCHAR2 IS
  r VARCHAR2(4000);
  t INT;
  r1 VARCHAR2(4000);
BEGIN
  DBMS_OUTPUT.GET_LINE(r, t);
  WHILE t != 1 LOOP
    DBMS_OUTPUT.GET_LINE(r1, t);
    r := r || ' ' || r1;
  END LOOP;
  RETURN r;
END;
/

create or replace function func_utl(tp raw) return int is
begin
	return utl_raw.length(tp);
end;
/

# in/out paramter
create or replace procedure type_produce_in(tp1 int) is
begin
        dbms_output.put_line(tp1);
end;
/



create or replace procedure type_produce_out(tp1 out int) is
begin
	tp1 := utl_raw.length('aaabbbeeeee111111111');
end;
/

create or replace procedure type_produce_out_tmp is
	tt1 int;
begin
	type_produce_out(tt1);
    dbms_output.put_line(tt1);
end;
/

create or replace procedure proceduce_sql is
ttrwo1 t_data%rowtype;
begin
        select utl_raw.length(c1),utl_raw.length(c2),utl_raw.length(c8)  into ttrwo1.c4,ttrwo1.c5,ttrwo1.c6 from t_data where utl_raw.length(c1) = 11;
		
        insert into t_data(c4,c5,c6) values(ttrwo1.c4,ttrwo1.c5,ttrwo1.c6);
		
		select c1,c2,c8 into ttrwo1.c1,ttrwo1.c2,ttrwo1.c8 from t_data where utl_raw.length(c1) = 11;
		insert into t_data(c4,c5,c6) values(utl_raw.length(ttrwo1.c1)+1,utl_raw.length(ttrwo1.c2)+1,utl_raw.length(ttrwo1.c8)+1);
		
        update t_data set c1 = utl_raw.length(ttrwo1.c8) where c7 is null;
        delete from t_data where utl_raw.length(c1) = 11;
end;
/

create or replace function proceduce_cur return int is
tt1 t_data.c6%type;
tt2 t_data.c6%type;
tt8 t_data.c6%type;
ttt int;
CURSOR utl_CURSOR is
        select utl_raw.length(c1),utl_raw.length(c2),utl_raw.length(c8) from t_data where utl_raw.length(c8) is not null;
begin
        ttt := utl_raw.length('1');
        open utl_CURSOR;
        Loop
                FETCH utl_CURSOR into tt1,tt2,tt8;
                exit when utl_CURSOR%NOTFOUND;
                ttt := ttt + tt1 + tt2 + tt8;
        end loop;

        return ttt;
end;
/


delimiter ;/

select func_utl(utl_raw.length('abcdefaa') || 'aaaaa') from dual;

call type_produce_in(utl_raw.length('1112222222222222222222'));
select print() from dual;


call type_produce_out_tmp();
select print() from dual;

call proceduce_sql();
select proceduce_cur() from dual;

--disable_warnings
--error 0,942
DROP TABLE t_data CASCADE CONSTRAINTS purge;
--enable_warnings
