#description: utl_raw.length 系统函数测试-basic

--source mysql_test/test_suite/otimestamp/t/otimestamp_import_time_zone.inc

alter session set nls_date_format = 'YYYY-MM-DD HH24:MI:SS';
alter session set NLS_TIMESTAMP_FORMAT = 'YYYY-MM-DD HH24:MI:SS.FF';
alter session set NLS_TIMESTAMP_TZ_FORMAT = 'YYYY-MM-DD HH24:MI:SS.FF TZR TZD';
alter session SET TIME_ZONE = 'ASIA/SHANGHAI';

--disable_warnings
--error 0,942
DROP TABLE t_time CASCADE CONSTRAINTS purge;
--error 0,942
DROP TABLE t_raw CASCADE CONSTRAINTS purge;
--error 0,942
DROP TABLE t_lob CASCADE CONSTRAINTS purge;
--error 0,942
DROP TABLE t_data CASCADE CONSTRAINTS purge;
--enable_warnings

create table t_time(c1 date, c2 timestamp, c3 timestamp with time zone, c4 timestamp with local time zone);
CREATE TABLE t_lob(c1 clob, c2 blob);
create table t_data(c1 int,c2 varchar(4000));
create table t_raw(c1 int,c2 raw(2000));
insert into t_time values(TIMESTAMP '1990-4-14 00:00:00', TIMESTAMP '1990-4-14 00:00:00', TIMESTAMP '1990-4-14 00:00:00', TIMESTAMP '1990-4-14 00:00:00');
insert into t_lob values('aaaaaabbbbbb', 'cccdddddeeeee');
insert into t_data values(1, '');
insert into t_data values(2, '');
insert into t_data values(3, '');
insert into t_data values(4, '0');
insert into t_data values(5, 'F');
insert into t_data values(6, '00');
insert into t_data values(7, 'FF');
insert into t_raw values(1, '');
insert into t_raw values(2, '');
insert into t_raw values(3, '');
insert into t_raw values(4, '0');
insert into t_raw values(5, 'F');
insert into t_raw values(6, '00');
insert into t_raw values(7, 'FF');
--echo #参数测试
--echo ##参数数目测试
--error 600,909
select utl_raw.length() from dual;

--error 600,909
select utl_raw.length(c2,c2) from t_raw order by c1;

select utl_raw.length(c2) from t_raw order by c1;

--echo ##参数类型
--echo ###数字-not supported
--error 600, 932
select utl_raw.length(1) from dual;
--error 600, 932
select utl_raw.length(1.111111111111111111111111111E+3) from dual;

--echo ###date
--error 600, 932
select utl_raw.length(date '1990-4-14') from dual;
--echo ###timestamp
--error 600, 932
select utl_raw.length(TIMESTAMP '1990-4-14 00:00:00') from dual;
--error 600, 932
select utl_raw.length(TIMESTAMP '1990-4-14 00:00:00 America/Los_Angeles') from dual;
--error 600, 932
select utl_raw.length(TIMESTAMP '1990-4-14 00:00:00 -4:00') from dual;
--error 600, 932
select utl_raw.length(TIMESTAMP '1990-4-14 00:00:00' - TIMESTAMP '1990-2-14 06:24:00') from dual;
--error 600, 932
select utl_raw.length(INTERVAL '9999999-2' YEAR(9) TO MONTH) from dual;
--error 600, 932
select utl_raw.length(INTERVAL '10 23:14:09' Day(9) TO second) from dual;

select (select c3 from t_time) from dual;
--error 600, 932
select utl_raw.length((select c3 from t_time)) from dual;
--error 600, 932
select utl_raw.length((select c4 from t_time)) from dual;

--echo ###raw
select utl_raw.length(utl_raw.cast_to_raw(111111111111111111111111111111111111111)) from dual;

--echo ###clob/blob
--error 600, 932
select utl_raw.length((select c1 from t_lob)) from dual;
# this bug is found when write testcase. dev has set this bug to wonfix. the correct behavior is this select should be return select result
--echo known issue  22428856
--error 600, 932
select utl_raw.length((select c2 from t_lob)) from dual;

--echo ##str测试
--error 1465
select utl_raw.length('qazwsxedcrfvtgbyhnujmik,ol.p;/[]1234567890-=''~!@#$%^&*()_+?><:"{}| 阿里巴巴，蚂蚁，支付宝') from dual;
--error 1465
select utl_raw.length('q') from dual;

--echo ####空格
--error 1465
select utl_raw.length(' ') from dual;

select utl_raw.length('0123456789abcdefABCDEF') from dual;

--echo #参数
--echo ##null
select utl_raw.length(null) from dual;

select utl_raw.length(null || 1) from dual;
select utl_raw.length(null || '1') from dual;

select utl_raw.length('0') from dual;

select utl_raw.length('') from dual;


--echo ##最短
select utl_raw.length('0') from dual;
select utl_raw.length('00') from dual;
select utl_raw.length('000') from dual;
select utl_raw.length('F') from dual;
select utl_raw.length('FF') from dual;
select utl_raw.length('FFF') from dual;

--echo ##最长+函数+子查询 oracle和ob都限制为2000字符
select utl_raw.length(concat(concat((select c2 from t_data where c1 =1),(select c2 from t_data where c1 =1)),concat((select c2 from t_data where c1 =1),(select c2 from t_data where c1 =1)))) from dual;
--error 25137
select utl_raw.length(concat(concat((select c2 from t_data where c1 =1),(select c2 from t_data where c1 =1)),concat((select c2 from t_data where c1 =1),(select c2 from t_data where c1 =1))) || 'a') from dual;

select utl_raw.length(utl_raw.concat(utl_raw.concat((select c2 from t_data where c1 =1),(select c2 from t_data where c1 =1)),utl_raw.concat((select c2 from t_data where c1 =1),(select c2 from t_data where c1 =1)))) from dual;
--error 25137
select utl_raw.length(utl_raw.concat(utl_raw.concat((select c2 from t_data where c1 =1),(select c2 from t_data where c1 =1)),utl_raw.concat((select c2 from t_data where c1 =1),(select c2 from t_data where c1 =1))) || '1') from dual;

select utl_raw.length(utl_raw.concat(utl_raw.concat((select c2 from t_raw where c1 =1),(select c2 from t_raw where c1 =1)),utl_raw.concat((select c2 from t_raw where c1 =1),(select c2 from t_raw where c1 =1)))) from dual;
--error 25137
select utl_raw.length(utl_raw.concat(utl_raw.concat((select c2 from t_raw where c1 =1),(select c2 from t_raw where c1 =1)),utl_raw.concat((select c2 from t_raw where c1 =1),(select c2 from t_raw where c1 =1))) || '0') from dual;


# this bug is found when write testcase. dev not fix for long time. the correct behavior is this select should be return select result
--echo known issue 22330168
select utl_raw.length(concat((select c2 from t_data where c1 =1),(select c2 from t_data where c1 =1))),utl_raw.length(concat((select c2 from t_data where c1 =1),(select c2 from t_data where c1 =1))),utl_raw.length(concat((select c2 from t_data where c1 =1),(select c2 from t_data where c1 =1))),utl_raw.length(concat((select c2 from t_data where c1 =1),(select c2 from t_data where c1 =1))),utl_raw.length(concat((select c2 from t_data where c1 =1),(select c2 from t_data where c1 =1))),utl_raw.length(concat((select c2 from t_data where c1 =1),(select c2 from t_data where c1 =1))),utl_raw.length(concat((select c2 from t_data where c1 =1),(select c2 from t_data where c1 =1))),utl_raw.length(concat((select c2 from t_data where c1 =1),(select c2 from t_data where c1 =1))),utl_raw.length(concat((select c2 from t_data where c1 =1),(select c2 from t_data where c1 =1))),utl_raw.length(concat((select c2 from t_data where c1 =1),(select c2 from t_data where c1 =1))) from dual;

select utl_raw.length(c2) from t_data order by c1;
select utl_raw.length(c2) from t_raw order by c1;


--echo ##表达式
#+/*-
--error 600, 932
select utl_raw.length('134343431' + 1+(2 || '111')+3*(4+5)/7+555-7) from dual;

select utl_raw.length('134343431' + 1+(2 || '111') || 'a') from dual;


--echo ##非法值
--error 900
select utl_raw.length(raw) from dual;
--error 900
select utl_raw.length(.) from dual;
--error 600, 932
select utl_raw.length(100 || 'X' + 3) from dual;

--echo known issue 我们处理引号没有同oracle兼容
select utl_raw.length('') from dual;
--error 1465
select utl_raw.length('''') from dual;

#select utl_raw.length(") from dual;

#select utl_raw.length("") from dual;

#select utl_raw.length(""") from dual;

#select utl_raw.length("a") from dual;






--disable_warnings
--error 0,942
DROP TABLE t_time CASCADE CONSTRAINTS purge;
--error 0,942
DROP TABLE t_raw CASCADE CONSTRAINTS purge;
--error 0,942
DROP TABLE t_lob CASCADE CONSTRAINTS purge;
--error 0,942
DROP TABLE t_data CASCADE CONSTRAINTS purge;
--enable_warnings
