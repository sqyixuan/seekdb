#description: utl_raw.cast_to_varchar2 系统函数测试-同义词，视图，insert， update and delete 子句

--source mysql_test/test_suite/otimestamp/t/otimestamp_import_time_zone.inc

alter session set nls_date_format = 'YYYY-MM-DD HH24:MI:SS';
alter session set NLS_TIMESTAMP_FORMAT = 'YYYY-MM-DD HH24:MI:SS.FF';
alter session set NLS_TIMESTAMP_TZ_FORMAT = 'YYYY-MM-DD HH24:MI:SS.FF TZR TZD';
alter session SET TIME_ZONE = 'ASIA/SHANGHAI';

--disable_warnings
--error 0,942
DROP TABLE t_data CASCADE CONSTRAINTS purge;

--error 0,600
drop FUNCTION print;

--error 0,600
drop procedure type_produce_in;

--enable_warnings
call dbms_output.enable();

create table t_data(c1 varchar2(4000),c2 varchar(4000), c3 char(1000), c4 number, c5 numeric, c6 int, c7 smallint, c8 raw(2000), c9 date, c10 timestamp, c11 timestamp with time zone, c12 timestamp with local time zone, c13 interval year(9) to month, c14 interval day(9) to second, c15 clob, c16 blob);
insert into t_data(c1,c2,c3,c4,c5,c6,c7,c8,c9,c10,c11,c12,c13,c14,c15,c16) values('3132333435363738394041424344454647484950', '31323334353637383940414243444546474849503131', '31323334353637383940414243444546474849503232', 1, 1, 1, 1, '313233343536373839404142434445464748495032323333', date '1990-4-14', TIMESTAMP '1990-4-14 00:00:00 America/Los_Angeles', TIMESTAMP '1990-4-14 00:00:00', TIMESTAMP '1990-4-14 00:00:00', INTERVAL '9999999-2' YEAR(9) TO MONTH, INTERVAL '10 23:14:09' Day(9) TO second, '3132333435363738394041424344454647484950323233', '31323334353637383940414243444546474849503232333f4f' );
insert into t_data(c1,c2,c3,c4,c5,c6,c7,c8,c9,c10,c11,c12,c13,c14,c15,c16) values('31323334353637383940414243444546474849503434', '313233343536373839404142434445464748495031313232', '313233343536373839404142434445464748495031313535', 2.22222, 2.22222, 2, 2, '3132333435363738394041424344454647484950323233333736', date '1992-4-14', TIMESTAMP '1992-4-14 00:00:00 America/Los_Angeles', TIMESTAMP '1992-4-14 00:00:00', TIMESTAMP '1992-4-14 00:00:00', INTERVAL '9999999-2' YEAR(9) TO MONTH, INTERVAL '10 23:14:09' Day(9) TO second, '3132333435363738394041424344454647484950323233', '3132333435363738394041424344454647484950323233' );
insert into t_data(c1,c2,c3,c4,c5,c6,c7,c8,c9,c10,c11,c12,c13,c14,c15,c16) values('31323334353637383940414243444546474849503535', '313233343536373839404142434445464748495031313333', '313233343536373839404142434445464748495031313536', 3333333, 3333333, 3, 3, '3132333435363738394041424344454647484950323233333232', date '1993-4-14', TIMESTAMP '1993-4-14 00:00:00 Asia/Shanghai', TIMESTAMP '1993-4-14 00:00:00', TIMESTAMP '1993-4-14 00:00:00', INTERVAL '9999999-2' YEAR(9) TO MONTH, INTERVAL '10 23:14:09' Day(9) TO second, '3132333435363738394041424344454647484950323233', '3132333435363738394041424344454647484950323233' );
insert into t_data(c1,c2,c3,c4,c5,c6,c7,c8,c9,c10,c11,c12,c13,c14,c15,c16) values('3333333333333333333333333333333333333333333333333333333333333333', '3333333333333333333333333333333333333333333333333333333333333333', '3333333333333333333333333333333333333333333333333333333333333333', 4, 4, 4, 4, '', date '1990-4-14', TIMESTAMP '1990-4-14 00:00:00 America/Los_Angeles', TIMESTAMP '1990-4-14 00:00:00', TIMESTAMP '1990-4-14 00:00:00', INTERVAL '9999999-2' YEAR(9) TO MONTH, INTERVAL '10 23:14:09' Day(9) TO second, '3132333435363738394041424344454647484950323233', '31323334353637383940414243444546474849503232333f4f' );

delimiter /;
CREATE OR REPLACE FUNCTION print RETURN VARCHAR2 IS
  r VARCHAR2(4000);
  t INT;
  r1 VARCHAR2(4000);
BEGIN
  DBMS_OUTPUT.GET_LINE(r, t);
  WHILE t != 1 LOOP
    DBMS_OUTPUT.GET_LINE(r1, t);
    r := r || ' ' || r1;
  END LOOP;
  RETURN r;
END;
/

create or replace function func_utl(tp raw) return varchar2 is
begin
	return utl_raw.cast_to_varchar2(tp);
end;
/

# in/out paramter utl_raw.cast_to_varchar2的返回值为varchar2
create or replace procedure type_produce_in(tp1 varchar,tp2 varchar2,tp3 char,tp4 raw,tp7 int) is
begin
        dbms_output.put_line(tp1);
        dbms_output.put_line(tp2);
        dbms_output.put_line(tp3);
        dbms_output.put_line(tp4);
		dbms_output.put_line(tp7);

end;
/


create or replace procedure type_produce_out(tp1 out varchar,tp2 out varchar2,tp3 out char,tp4 out raw,tp7 out int) is
begin
	tp1 := utl_raw.cast_to_varchar2('33');
	tp2 := utl_raw.cast_to_varchar2('3333');
	tp3 := utl_raw.cast_to_varchar2('333333');
	tp4 := utl_raw.cast_to_varchar2('33333333');
	tp7 := utl_raw.cast_to_varchar2('333333');

end;
/

create or replace procedure type_produce_out_tmp is
	tt1 varchar(4000);
	tt2 varchar2(4000);
	tt3 char(1000);
	tt4 raw(2000);
	tt5 clob;
	tt6 blob;
	tt7 int;
begin
	type_produce_out(tt1,tt2,tt3,tt4,tt7);
    dbms_output.put_line(tt1);
    dbms_output.put_line(tt2);
    dbms_output.put_line(tt3);
    dbms_output.put_line(tt4);
	dbms_output.put_line(tt7);
end;
/

create or replace procedure proceduce_sql is
ttrwo1 t_data%rowtype;
begin
        select utl_raw.cast_to_varchar2(c1),utl_raw.cast_to_varchar2(c2),utl_raw.cast_to_varchar2(c8)  into ttrwo1.c1,ttrwo1.c2,ttrwo1.c8 from t_data where utl_raw.cast_to_varchar2(c1) = utl_raw.cast_to_varchar2('3333333333333333333333333333333333333333333333333333333333333333');
        insert into t_data(c1,c2,c8) values(utl_raw.cast_to_varchar2(ttrwo1.c1),utl_raw.cast_to_varchar2(ttrwo1.c2),utl_raw.cast_to_varchar2(ttrwo1.c8));
        update t_data set c1 = utl_raw.cast_to_varchar2(ttrwo1.c1) where c7 is null;
        delete from t_data where utl_raw.cast_to_varchar2(c1) <> utl_raw.cast_to_varchar2('3333333333333333333333333333333333333333333333333333333333333333');
end;
/

create or replace function proceduce_cur return varchar2 is
tt1 t_data.c1%type;
tt2 t_data.c2%type;
tt8 t_data.c8%type;
ttt varchar2(2000);
CURSOR utl_CURSOR is
        select utl_raw.cast_to_varchar2(c1),utl_raw.cast_to_varchar2(c2),utl_raw.cast_to_varchar2(c8) from t_data;
begin
        ttt := utl_raw.cast_to_varchar2('1');
        open utl_CURSOR;
        Loop
                FETCH utl_CURSOR into tt1,tt2,tt8;
                exit when utl_CURSOR%NOTFOUND;
                ttt := concat(ttt,tt1);
                ttt := concat(ttt,tt2);
                ttt := concat(ttt,utl_raw.cast_to_varchar2(utl_raw.cast_to_raw(tt8)));
        end loop;

        return ttt;
end;
/


delimiter ;/

select func_utl(utl_raw.cast_to_varchar2('3333333333333333')) from dual;

call type_produce_in(utl_raw.cast_to_varchar2('3333333333333333'),utl_raw.cast_to_varchar2('33333333333333'),utl_raw.cast_to_varchar2('333333333333'),utl_raw.cast_to_varchar2('33'),utl_raw.cast_to_varchar2('3333'));
select print() from dual;


call type_produce_out_tmp();
select print() from dual;

call proceduce_sql();
select proceduce_cur() from dual;

--disable_warnings
--error 0,942
DROP TABLE t_data CASCADE CONSTRAINTS purge;
--enable_warnings
