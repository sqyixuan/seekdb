select utl_raw.bit_or(c2,c2) from t_data order by c1;
select utl_raw.bit_or(c2,c2) from t_raw order by c1;

select utl_raw.bit_or(t1.c2,t1.c2) from t_raw t1,t_raw t2 where t1.c1 = t2.c1 order by t1.c1,t2.c1;



--echo ##表达式
#+/*-
--error 600, 932
select utl_raw.bit_or('134343431' + 1+(2 || '111')+3*(4+5)/7+555-7,'a') from dual;

select utl_raw.bit_or('134343431' + 1+(2 || '111') || 'a','a') from dual;

select utl_raw.bit_or('134343431' + 1+(2 || '111') || 'a','a' || 'a' || 'bb') from dual;



--echo ##非法值
--error 900
select utl_raw.bit_or(raw,'a') from dual;
--error 900
select utl_raw.bit_or('a',.) from dual;
--error 600, 932
select utl_raw.bit_or(100 || 'X' + 3,'a') from dual;

--echo known issue 我们处理引号没有同oracle兼容
