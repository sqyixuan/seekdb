select utl_raw.bit_or(concat((select c2 from t_data where c1 =1),(select c2 from t_data where c1 =1)),concat((select c2 from t_data where c1 =1),(select c2 from t_data where c1 =1))),utl_raw.bit_or(concat((select c2 from t_data where c1 =1),(select c2 from t_data where c1 =1)),concat((select c2 from t_data where c1 =1),(select c2 from t_data where c1 =1))),utl_raw.bit_or(concat((select c2 from t_data where c1 =1),(select c2 from t_data where c1 =1)),concat((select c2 from t_data where c1 =1),(select c2 from t_data where c1 =1))),utl_raw.bit_or(concat((select c2 from t_data where c1 =1),(select c2 from t_data where c1 =1)),concat((select c2 from t_data where c1 =1),(select c2 from t_data where c1 =1))) from dual;

