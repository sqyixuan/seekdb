#author: wb-gfq587009
#description: utl_raw.bit_complement 系统函数测试-同义词，视图，insert， update and delete 子句

--source mysql_test/test_suite/otimestamp/t/otimestamp_import_time_zone.inc

alter session set nls_date_format = 'YYYY-MM-DD HH24:MI:SS';
alter session set NLS_TIMESTAMP_FORMAT = 'YYYY-MM-DD HH24:MI:SS.FF';
alter session set NLS_TIMESTAMP_TZ_FORMAT = 'YYYY-MM-DD HH24:MI:SS.FF TZR TZD';
alter session SET TIME_ZONE = 'ASIA/SHANGHAI';

--disable_warnings
--error 0,942
DROP TABLE t_data CASCADE CONSTRAINTS purge;
--error 0,942
drop view t_view;
--error 0,600
drop synonym t_synonym;
--enable_warnings

--echo #ddl test
--error 904
create table t_data(c1 raw(2000) default utl_raw.bit_complement('aaa'));

--echo not deterministic function
--error 904
create table t_data(c1 raw(2000), c2 generated always  as (utl_raw.bit_complement(c1)));

create table t_data(c1 varchar2(4000),c2 varchar(4000), c3 char(1000), c4 number, c5 numeric, c6 int, c7 smallint, c8 raw(2000), c9 date, c10 timestamp, c11 timestamp with time zone, c12 timestamp with local time zone, c13 interval year(9) to month, c14 interval day(9) to second, c15 clob, c16 blob, c17 generated always as(c1 || c2 || c8));

create or replace  view t_view as select * from t_data;
create or replace  synonym t_synonym for t_data;

insert into t_data(c1,c2,c3,c4,c5,c6,c7,c8,c9,c10,c11,c12,c13,c14,c15,c16) values('1234567890abcdefABCDEF', 'abcdefABCDEF', 'abcdefABCDEF', 1, 1, 1, 1, 'abcdef1234567890', date '1990-4-14', TIMESTAMP '1990-4-14 00:00:00 America/Los_Angeles', TIMESTAMP '1990-4-14 00:00:00', TIMESTAMP '1990-4-14 00:00:00', INTERVAL '9999999-2' YEAR(9) TO MONTH, INTERVAL '10 23:14:09' Day(9) TO second, '1234567890abcdefABCDEF', '1234567890abcdefABCDEF' );
insert into t_data(c1,c2,c3,c4,c5,c6,c7,c8,c9,c10,c11,c12,c13,c14,c15,c16) values('1234567890abcdefABCDEF11', 'abcdefABCDEF11', 'abcdefABCDEF11', 2.22222, 2.22222, 2, 2, '1234567890abcdefABCDEF002', date '1992-4-14', TIMESTAMP '1992-4-14 00:00:00 America/Los_Angeles', TIMESTAMP '1992-4-14 00:00:00', TIMESTAMP '1992-4-14 00:00:00', INTERVAL '9999999-2' YEAR(9) TO MONTH, INTERVAL '10 23:14:09' Day(9) TO second, '1234567890abcdefABCDEF', '1234567890abcdefABCDEF' );
insert into t_data(c1,c2,c3,c4,c5,c6,c7,c8,c9,c10,c11,c12,c13,c14,c15,c16) values('1234567890abcdefABCDEF12', 'abcdefABCDEF12', 'abcdefABCDEF12', 3333333, 3333333, 3, 3, '1234567890abcdefABCDEF003', date '1993-4-14', TIMESTAMP '1993-4-14 00:00:00 Asia/Shanghai', TIMESTAMP '1993-4-14 00:00:00', TIMESTAMP '1993-4-14 00:00:00', INTERVAL '9999999-2' YEAR(9) TO MONTH, INTERVAL '10 23:14:09' Day(9) TO second, '1234567890abcdefABCDEF', '1234567890abcdefABCDEF' );

--echo #view test
select utl_raw.bit_complement(c1) from t_view order by c7;
select utl_raw.bit_complement(c2) from t_view order by c7;
--error 1465
select utl_raw.bit_complement(c3) from t_view order by c7;
--error 600, 932
select utl_raw.bit_complement(c4) from t_view order by c7;
--error 600, 932
select utl_raw.bit_complement(c5) from t_view order by c7;
--error 600, 932
select utl_raw.bit_complement(c6) from t_view order by c7;
--error 600, 932
select utl_raw.bit_complement(c7) from t_view order by c7;

select utl_raw.bit_complement(c8) from t_view order by c7;
--error 600, 932
select utl_raw.bit_complement(c9) from t_view order by c7;
--error 600, 932
select utl_raw.bit_complement(c10) from t_view order by c7;
--error 600, 932
select utl_raw.bit_complement(c11) from t_view order by c7;
--error 600, 932
select utl_raw.bit_complement(c12) from t_view order by c7;
--error 600, 932
select utl_raw.bit_complement(c13) from t_view order by c7;
--error 600, 932
select utl_raw.bit_complement(c14) from t_view order by c7;
--error 600, 932
select utl_raw.bit_complement(c15) from t_view order by c7;
# this bug is found when write testcase. dev has set this bug to wonfix. the correct behavior is this select should be return select result
--echo known issue 22428856
--error 600, 932
select utl_raw.bit_complement(c16) from t_view order by c7;

select utl_raw.bit_complement(c17) from t_view order by c7;
select utl_raw.bit_complement(c1),utl_raw.bit_complement(c2), utl_raw.bit_complement(c8), utl_raw.bit_complement(c17) from t_view order by c1;

create or replace  view t_view as select utl_raw.bit_complement(c1) cc1, utl_raw.bit_complement(c2) cc2, utl_raw.bit_complement(c8) cc3 from t_data;
select utl_raw.bit_complement(cc1) from t_view order by cc1;
select utl_raw.bit_complement(cc2) from t_view order by cc1;
select utl_raw.bit_complement(cc3) from t_view order by cc1;

--echo #synonym test
select utl_raw.bit_complement(c1) from t_synonym order by c7;
select utl_raw.bit_complement(c2) from t_synonym order by c7;
--error 1465
select utl_raw.bit_complement(c3) from t_synonym order by c7;
--error 600, 932
select utl_raw.bit_complement(c4) from t_synonym order by c7;
--error 600, 932
select utl_raw.bit_complement(c5) from t_synonym order by c7;
--error 600, 932
select utl_raw.bit_complement(c6) from t_synonym order by c7;
--error 600, 932
select utl_raw.bit_complement(c7) from t_synonym order by c7;
select utl_raw.bit_complement(c8) from t_synonym order by c7;
select utl_raw.bit_complement(c17) from t_synonym order by c7;
select utl_raw.bit_complement(c1),utl_raw.bit_complement(c2), utl_raw.bit_complement(c8), utl_raw.bit_complement(c17) from t_synonym;

--echo #insert test
insert into t_data(c1,c2,c3,c8) values(utl_raw.bit_complement('abcdefABCEDF123455'),utl_raw.bit_complement('abcdefABCEDF123455'),utl_raw.bit_complement('abcdefABCEDF123455'),utl_raw.bit_complement('abcdefABCEDF123455'));

insert into t_data(c15,c16) values(utl_raw.bit_complement('abcdefABCEDF123455'),utl_raw.bit_complement('abcdefABCEDF123455'));

insert into t_data(c1,c2,c3 ,c8) select utl_raw.bit_complement(c1), utl_raw.bit_complement(c2), utl_raw.bit_complement(c2), utl_raw.bit_complement(c8) from t_data;
--error 600, 932
insert into t_data(c15,c16) select utl_raw.bit_complement(c15), utl_raw.bit_complement(c15) from t_data;
--error 600, 932
insert into t_data(c5) values(utl_raw.bit_complement(1));

--echo #update
update t_data set c1 = utl_raw.bit_complement('abcdefABCEDF123455') where utl_raw.bit_complement(c1) = utl_raw.bit_complement('1234567890abcdefABCDEF11');
update t_data set c2 = utl_raw.bit_complement('abcdefABCEDF123455') where utl_raw.bit_complement(c1) = utl_raw.bit_complement('abcdefABCEDF123455');

update t_data set c3 = utl_raw.bit_complement('abcdefABCEDF123455') where utl_raw.bit_complement(c1) = utl_raw.bit_complement('abcdefABCEDF123455');

update t_data set c8 = utl_raw.bit_complement('abcdefABCEDF123455') where utl_raw.bit_complement(c1) = utl_raw.bit_complement('abcdefABCEDF123455');

update t_data set c15 = utl_raw.bit_complement('abcdefABCEDF123455') where utl_raw.bit_complement(c1) = utl_raw.bit_complement('abcdefABCEDF123455');

update t_data set c16 = utl_raw.bit_complement('abcdefABCEDF123455') where utl_raw.bit_complement(c1) = utl_raw.bit_complement('abcdefABCEDF123455');

--error 600, 932
update t_data set c6 = utl_raw.bit_complement(1) where c7 = 1;

update t_data set (c1,c2,c8) = (select utl_raw.bit_complement(c1), utl_raw.bit_complement(c2), utl_raw.bit_complement(c8) from t_data where utl_raw.bit_complement(c1) = utl_raw.bit_complement('abcdefABCEDF123455')) where utl_raw.bit_complement(c1) = utl_raw.bit_complement('abcdefABCEDF123455');

update t_data set (c15,c16) = (select utl_raw.bit_complement(c2), utl_raw.bit_complement(c8) from t_data where utl_raw.bit_complement(c1) = utl_raw.bit_complement('abcdefABCEDF123455')) where utl_raw.bit_complement(c1) = utl_raw.bit_complement('abcdefABCEDF123455');

--echo #delete
delete from t_data where utl_raw.bit_complement(c1) = utl_raw.bit_complement('abcdefABCEDF123455');


--disable_warnings
--error 0,942
DROP TABLE t_data CASCADE CONSTRAINTS purge;
--error 0,942
drop view t_view;
--error 0,600
drop synonym t_synonym;
--enable_warnings
