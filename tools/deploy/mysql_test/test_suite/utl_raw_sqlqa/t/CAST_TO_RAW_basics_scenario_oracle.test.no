#owner: dachuan.sdc
#owner group: SQLQA
#tags: package
#author: wb-gfq587009
#description: utl_raw.cast_to_raw 系统函数测试-basic

--source mysql_test/test_suite/otimestamp/t/otimestamp_import_time_zone.inc

alter session set nls_date_format = 'YYYY-MM-DD HH24:MI:SS';
alter session set NLS_TIMESTAMP_FORMAT = 'YYYY-MM-DD HH24:MI:SS.FF';
alter session set NLS_TIMESTAMP_TZ_FORMAT = 'YYYY-MM-DD HH24:MI:SS.FF TZR TZD';
alter session SET TIME_ZONE = 'ASIA/SHANGHAI';

--disable_warnings
--error 0,942
DROP TABLE t_time CASCADE CONSTRAINTS purge;
--error 0,942
DROP TABLE t_lob CASCADE CONSTRAINTS purge;
--error 0,942
DROP TABLE t_data CASCADE CONSTRAINTS purge;
--enable_warnings

create table t_time(c1 date, c2 timestamp, c3 timestamp with time zone, c4 timestamp with local time zone);
CREATE TABLE t_lob(c1 clob, c2 blob);
create table t_data(c1 int,c2 varchar(2000));
insert into t_time values(TIMESTAMP '1990-4-14 00:00:00', TIMESTAMP '1990-4-14 00:00:00', TIMESTAMP '1990-4-14 00:00:00', TIMESTAMP '1990-4-14 00:00:00');
insert into t_lob values('aaaaaabbbbbb', 'cccdddddeeeee');
insert into t_data values(1, '');
insert into t_data values(2, '');
insert into t_data values(3, '');
--echo #参数测试
--echo ##参数数目测试
--error 600,909
select utl_raw.cast_to_raw() from dual;

--error 600,909
select utl_raw.cast_to_raw('a','a') from dual;

select utl_raw.cast_to_raw('a,a') from dual;

select utl_raw.cast_to_raw('郭复强') from dual;

--echo ##参数类型
# this issue is found when stddev related test. dev not plan to fix it recently. 
--echo ###数字  -----精度/格式问题 known issue: 22330417
select utl_raw.cast_to_raw(111111111111111111111111111111111111111) from dual;
select utl_raw.cast_to_raw(1111111111111111111111111111111111111111) from dual;
select utl_raw.cast_to_raw(11111111111111111111111111111111111111111) from dual;
select utl_raw.cast_to_raw(1111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111111) from dual;

select utl_raw.cast_to_raw(11111111111111111111111111111111111.111111111111111111111111111111111111111111111111111111111111111111111111111111111111111) from dual;

select utl_raw.cast_to_raw(1.111111111111111111111111111E+3) from dual;

select utl_raw.cast_to_raw(1.) from dual;
select utl_raw.cast_to_raw(.1) from dual;

--echo ###date

--echo ###timestamp
select utl_raw.cast_to_raw(TIMESTAMP '1990-4-14 00:00:00') from dual;
select utl_raw.cast_to_raw(TIMESTAMP '1990-4-14 00:00:00') from dual;
select utl_raw.cast_to_raw(date '1990-4-14') from dual;

select utl_raw.cast_to_raw(TIMESTAMP '1990-4-14 00:00:00' - TIMESTAMP '1990-2-14 06:24:00') from dual;

select utl_raw.cast_to_raw(INTERVAL '9999999-2' YEAR(9) TO MONTH) from dual;

select utl_raw.cast_to_raw(INTERVAL '10 23:14:09' Day(9) TO second) from dual;

select utl_raw.cast_to_raw(TIMESTAMP '1990-4-14 00:00:00 -4:00') from dual;

select TIMESTAMP '1990-4-14 00:00:00 America/Los_Angeles' from dual;
select utl_raw.cast_to_raw(TIMESTAMP '1990-4-14 00:00:00 America/Los_Angeles') from dual;

select (select c3 from t_time) from dual;
select utl_raw.cast_to_raw((select c3 from t_time)) from dual;
select utl_raw.cast_to_raw((select c4 from t_time)) from dual;

--echo ###raw
select utl_raw.cast_to_raw(utl_raw.cast_to_raw(111111111111111111111111111111111111111)) from dual;

--echo ###clob/blob
select utl_raw.cast_to_raw((select c1 from t_lob)) from dual;
--error 600
select utl_raw.cast_to_raw((select c2 from t_lob)) from dual;


--echo #参数
--echo ##null
select utl_raw.cast_to_raw(null) from dual;

select utl_raw.cast_to_raw(null + 1) from dual;
select utl_raw.cast_to_raw(null + '1') from dual;

select utl_raw.cast_to_raw(0) from dual;

select utl_raw.cast_to_raw('') from dual;

--echo ##最短
select utl_raw.cast_to_raw('0') from dual;
select utl_raw.cast_to_raw(0) from dual;
select utl_raw.cast_to_raw(.1) from dual;

--echo ##最长+函数+子查询 oracle和ob都限制为2000字符
select utl_raw.cast_to_raw(concat((select c2 from t_data where c1 =1),(select c2 from t_data where c1 =1))) from dual;
--error 6502
select utl_raw.cast_to_raw(concat((select c2 from t_data where c1 =1),(select c2 from t_data where c1 =1)) || 'A') from dual;
# this bug is found when write testcase. dev not fix for long time. the correct behavior is this select should be return select result
--echo known issue 22330168
select utl_raw.cast_to_raw(concat((select c2 from t_data where c1 =1),(select c2 from t_data where c1 =1))),utl_raw.cast_to_raw(concat((select c2 from t_data where c1 =1),(select c2 from t_data where c1 =1))),utl_raw.cast_to_raw(concat((select c2 from t_data where c1 =1),(select c2 from t_data where c1 =1))),utl_raw.cast_to_raw(concat((select c2 from t_data where c1 =1),(select c2 from t_data where c1 =1))),utl_raw.cast_to_raw(concat((select c2 from t_data where c1 =1),(select c2 from t_data where c1 =1))),utl_raw.cast_to_raw(concat((select c2 from t_data where c1 =1),(select c2 from t_data where c1 =1))),utl_raw.cast_to_raw(concat((select c2 from t_data where c1 =1),(select c2 from t_data where c1 =1))),utl_raw.cast_to_raw(concat((select c2 from t_data where c1 =1),(select c2 from t_data where c1 =1))),utl_raw.cast_to_raw(concat((select c2 from t_data where c1 =1),(select c2 from t_data where c1 =1))),utl_raw.cast_to_raw(concat((select c2 from t_data where c1 =1),(select c2 from t_data where c1 =1))) from dual;

--echo ##表达式
#+/*-
select utl_raw.cast_to_raw('134343431' + 1+(2 || '111')+3*(4+5)/7+555-7) from dual;


--echo ##非法值
--error 900
select utl_raw.cast_to_raw(raw) from dual;
--error 900
select utl_raw.cast_to_raw(.) from dual;
--error 1722
select utl_raw.cast_to_raw(100 || 'X' + 3) from dual;

--echo known issue 我们处理引号没有同oracle兼容
select utl_raw.cast_to_raw(') from dual;

select utl_raw.cast_to_raw(''') from dual;

select utl_raw.cast_to_raw('''') from dual;

#select utl_raw.cast_to_raw(") from dual;

#select utl_raw.cast_to_raw("") from dual;

#select utl_raw.cast_to_raw(""") from dual;

#select utl_raw.cast_to_raw("a") from dual;


--echo ##str测试
select utl_raw.cast_to_raw('qazwsxedcrfvtgbyhnujmik,ol.p;/[]1234567890-=''~!@#$%^&*()_+?><:"{}| 阿里巴巴，蚂蚁，支付宝') from dual;


--disable_warnings
--error 0,942
DROP TABLE t_time CASCADE CONSTRAINTS purge;
--error 0,942
DROP TABLE t_lob CASCADE CONSTRAINTS purge;
--error 0,942
DROP TABLE t_data CASCADE CONSTRAINTS purge;
--enable_warnings
