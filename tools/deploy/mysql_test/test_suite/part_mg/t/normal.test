--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: nijia.nj
#owner group: sql2
# tags: optimizer
#description: todo

--disable_warnings
drop database if exists db;
create database db;
use db;
--enable_warnings

#需要删除最后一个以后，再增加一个partition的场景
#删除中间一个partition以后，需要插入一次。并且需要select一边partition
#最好使用where语句来查一遍，测试一下ObTableLocation是否有问题。
#最好删到一个不剩试试。
#最好第一个partition删除一次
#maxvalue最好能出现一次.

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1(c1 int, c2 int, primary key(c1,c2)) partition by range(c1) (partition p0 values less than(10), partition p1 values less than(MAXVALUE));
insert into t1 values(1, 1);
insert into t1 values(10000, 1);
alter table t1 drop partition (p1);
--error ER_NO_PARTITION_FOR_GIVEN_VALUE
insert into t1 values(20000, 1);
alter table t1 add partition (partition p1 values less than(20000));
--error ER_NO_PARTITION_FOR_GIVEN_VALUE
insert into t1 values(20000, 1);
alter table t1 drop partition (p1);
alter table t1 add partition (partition p1 values less than(20001));
insert into t1 values(20000, 1);
select * from t1;
--error ER_NO_PARTITION_FOR_GIVEN_VALUE
insert into t1 values(20001, 1);
alter table t1 drop partition (p1);
alter table t1 add partition (partition p1 values less than(MAXVALUE));
insert into t1 values(20001, 1);
select * from t1;
alter table t1 drop partition (p1);
alter table t1 add partition (partition p1 values less than(20), partition p2 values less than(30));
insert into t1 values(11, 1);
insert into t1 values(12, 1);
insert into t1 values(13, 1);
select * from t1 partition(p1);
alter table t1 drop partition (p1);
--error ER_UNKNOWN_PARTITION
select * from t1 partition(p1);
select * from t1 partition(p2);
insert into t1 values(11, 1);
insert into t1 values(12, 1);
insert into t1 values(13, 1);
select * from t1 partition(p2);
explain select * from t1 where c1 < 10;
alter table t1 drop partition (p0);
explain select * from t1 where c1 < 10;
alter table t1 add partition (partition p3 values less than(40), partition p4 values less than(50));
explain select * from t1 where c1 <= 40;
explain select * from t1 where c1 < 40;
alter table t1 drop partition (p3, p4);
--error ER_DROP_LAST_PARTITION
alter table t1 drop partition (p2);

--disable_warnings
drop database if exists db;
--enable_warnings
