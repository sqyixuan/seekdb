#owner: msy164651
#owner group: rs
#description: 空empty分裂立刻结束
set @@recyclebin = off;
--disable_warnings
drop database if exists db;
create database db;
use db;
drop table if exists t1, t2, t3;
drop tablegroup if exists tg;
--enable_warnings
# case 1 分裂为hash分区
create tablegroup tg binding = true;
alter tablegroup tg partition by hash partitions 10;
--source mysql_test/include/check_split_partition_ok.inc
