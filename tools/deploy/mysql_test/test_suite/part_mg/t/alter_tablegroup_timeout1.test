#owner: msy164651
#owner group: rs
#description: alter tablegroup 超时测试
#建100张表，分裂100个partition
connect (conn_sys,$OBMYSQL_MS0,root@sys,,*NO-ONE*,$OBMYSQL_PORT);
connection default;

--disable_warnings
set @@recyclebin = off;
drop database if exists db;
create database db;
use db;
drop tablegroup if exists tgmsy11;
--enable_warnings

set @@session.ob_query_timeout=1000000000;
#分裂list
create tablegroup tgmsy11 partition by list (partition p0 values in (default));
let $cnt=100;
while($cnt) 
{

  eval create table t_$cnt (c1 int primary key, c2 int) tablegroup = tgmsy11 partition by list(c1) (partition p0 values in (default));
  dec $cnt;
}

--let $sql=alter tablegroup tgmsy11 reorganize partition p0 into(
let $cnt=50;
while($cnt)
{
  --let $sql=$sql partition p$cnt values in ($cnt),
  dec $cnt;
}
--let $sql=$sql partition pdefault values in (default));
eval $sql;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t_1; 
let $cnt=100;
while($cnt) 
{

  eval drop table t_$cnt;
  dec $cnt;
}
drop tablegroup tgmsy11;
