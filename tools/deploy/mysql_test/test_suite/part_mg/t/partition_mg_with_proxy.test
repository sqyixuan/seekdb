#owner: msy164651
#owner group: rs
#description: 测试分区管理功能对proxy虚拟表的支持
#1. 表分裂range 分区，增加分区，删除分区，分区分
#2. 表分裂list 分区，增加分区，删除分区，分区分
#3. 表分裂hash 分区，增加分区，删除分区，分区分裂

set @@recyclebin = off;
--disable_warnings
drop database if exists db;
create database db;
use db;
drop table if exists t1, t2, t3;
drop tablegroup if exists tg;
--enable_warnings
# case 1
create table t1 (c1 int primary key ,c2 int ,c3 int);
insert into t1 values (2,1,1),(9,8,8),(12,12,12),(16,16,16),(111,111,111),(555,555,111);
alter table t1 partition by range(c1) (partition p1 values less than (maxvalue));
connect (conn_sys,$OBMYSQL_MS0,root@sys,,*NO-ONE*,$OBMYSQL_PORT);
connection conn_sys;
let $tenant_id = query_get_value(select tenant_id from oceanbase.__all_tenant where tenant_name = 'sys', tenant_id,1);
let $db_id = query_get_value(select database_id from oceanbase.__all_virtual_database where database_name = 'db' and tenant_id = $tenant_id, database_id, 1);
let $t1_id = query_get_value(select table_id from oceanbase.__all_virtual_table where table_name ='t1' and database_id = $db_id, table_id, 1);
--disable_query_log
eval select part_id, part_position, part_name, status, low_bound_val, high_bound_val from oceanbase.__all_virtual_proxy_partition where tenant_name = 'sys' and table_id = $t1_id;
--enable_query_log
connection default;
use db;
alter table t1 reorganize partition p1 into (partition p0 values less than (10), partition p1 values less than (100),partition p2 values less than (1000), partition p3 values less than (maxvalue));
connection conn_sys;
--disable_query_log
eval select part_id, part_position, part_name, status, low_bound_val, high_bound_val from oceanbase.__all_virtual_proxy_partition where tenant_name = 'sys' and table_id = $t1_id;
--enable_query_log
--source mysql_test/include/check_split_partition_ok.inc
connection default;
use db;
alter table t1 drop partition p1, p3;
connection conn_sys;
--disable_query_log
eval select part_id, part_position, part_name, status, low_bound_val, high_bound_val from oceanbase.__all_virtual_proxy_partition where tenant_name = 'sys' and table_id = $t1_id;
--enable_query_log
connection default;
use db;
alter table t1 add partition (partition p1 values less than (20000), partition p3 values less than(100000));
connection conn_sys;
--disable_query_log
eval select part_id, part_position, part_name, status, low_bound_val, high_bound_val from oceanbase.__all_virtual_proxy_partition where tenant_name = 'sys' and table_id = $t1_id;
--enable_query_log
connection default;
use db;
--source mysql_test/include/show_create_table_old_version.inc
show create table t1;
drop table t1;

#case 2
create table t1 (c1 int primary key ,c2 int ,c3 int);
insert into t1 values (2,1,1),(9,8,8),(12,12,12),(16,16,16),(111,111,111),(555,555,111);
alter table t1 partition by list(c1) (partition p1 values in (default));
connection conn_sys;
--disable_query_log
let $t1_id = query_get_value(select table_id from oceanbase.__all_virtual_table where table_name ='t1' and database_id = $db_id, table_id, 1);
eval select part_id, part_position, part_name, status, low_bound_val, high_bound_val from oceanbase.__all_virtual_proxy_partition where tenant_name = 'sys' and table_id = $t1_id;
--enable_query_log
connection default;
use db;
alter table t1 reorganize partition p1 into (partition p0 values in (1,2,3,4,5), partition p1 values in (9,12,16), partition p2 values in (111,555), partition p3 values in (default));
connection conn_sys;
--disable_query_log
eval select part_id, part_position, part_name, status, low_bound_val, high_bound_val from oceanbase.__all_virtual_proxy_partition where tenant_name = 'sys' and table_id = $t1_id;
--enable_query_log
--source mysql_test/include/check_split_partition_ok.inc
connection default;
use db;
alter table t1 drop partition p1, p3;
connection conn_sys;
--disable_query_log
eval select part_id, part_position, part_name, status, low_bound_val, high_bound_val from oceanbase.__all_virtual_proxy_partition where tenant_name = 'sys' and table_id = $t1_id;
--enable_query_log
connection default;
use db;
alter table t1 add partition (partition p1 values in (default));
connection conn_sys;
--disable_query_log
eval select part_id, part_position, part_name, status, low_bound_val, high_bound_val from oceanbase.__all_virtual_proxy_partition where tenant_name = 'sys' and table_id = $t1_id;
--enable_query_log
connection default;
use db;
--source mysql_test/include/show_create_table_old_version.inc
show create table t1;
drop table t1;

#case 3
create table t1 (c1 int primary key ,c2 int ,c3 int);
insert into t1 values (2,1,1),(9,8,8),(12,12,12),(16,16,16),(111,111,111),(555,555,111);
alter table t1 partition by hash(c1) partitions 10;
connection conn_sys;
let $t1_id = query_get_value(select table_id from oceanbase.__all_virtual_table where table_name ='t1' and database_id = $db_id, table_id, 1);
--disable_query_log
eval select part_id, part_position, part_name, status, low_bound_val, high_bound_val from oceanbase.__all_virtual_proxy_partition where tenant_name = 'sys' and table_id = $t1_id;
--enable_query_log
connection default;
use db;
--source mysql_test/include/show_create_table_old_version.inc
show create table t1;
drop table t1;

