#owner: msy164651
#owner group: rs
#description: range分区分裂测试

#测试分裂后，表结构是正确的，数据是一致的
#case1 增加分区
#case2 删除增加的分区
#case3 增加删除的分区

connect (conn_sys,$OBMYSQL_MS0,root@sys,,*NO-ONE*,$OBMYSQL_PORT);
connection default;
--disable_warnings
set @@recyclebin = off;
drop database if exists db;
create database db;
use db;
drop table if exists t1, t2, t3;
drop tablegroup if exists tgmsy;
drop tablegroup if exists tgmsy2;
drop tablegroup if exists tgmsy3;
--enable_warnings

create tablegroup tgmsy binding true partition by range (partition p0 values less than (10),partition p1 values less than (100),partition p2 values less than (1000));
create table t1 (c1 int primary key ,c2 int ,c3 int) tablegroup ='tgmsy' partition by range (c1) (partition p0 values less than (10),partition p1 values less than (100),partition p2 values less than (1000));
create tablegroup tgmsy2 binding true partition by range  (partition p0 values less than (10),partition p1 values less than (3436),partition p2 values less than (maxvalue));
create tablegroup tgmsy3 binding true partition by range columns 2 (partition p0 values less than (3,4),partition p1 values less than(12,345),partition p2 values less than (324543,3435));
create table t3 (c1 int ,c2 int ,c3 int, primary key (c1,c2)) tablegroup ='tgmsy3' partition by range columns (c1,c2) (partition p0 values less than (3,4),partition p1 values less than(12,345),partition p2 values less than (324543,3435));
insert into t1 values (2,1,1),(7,8,8),(10,12,12),(20,16,16),(100,111,111),(203,555,111),(9,9,9);
insert into t3 values (1,2,1),(3,4,8),(11,13,12),(12,345,16),(111,111,111),(555,555,111),(324542,3434,45464547);
connection conn_sys;
let $tenant_id = query_get_value(select tenant_id from oceanbase.__all_tenant where tenant_name = 'sys', tenant_id,1);
let $db_id = query_get_value(select database_id from oceanbase.__all_virtual_database where database_name = 'db' and tenant_id = $tenant_id, database_id, 1);
let $t1_id = query_get_value(select table_id from oceanbase.__all_virtual_table where table_name = 't1' and database_id = $db_id, table_id, 1);
let $t3_id = query_get_value(select table_id from oceanbase.__all_virtual_table where table_name = 't3' and database_id = $db_id, table_id, 1);
let $tgmsy_id = query_get_value(select tablegroup_id from oceanbase.__all_virtual_tablegroup where tablegroup_name ='tgmsy' and tenant_id = $tenant_id, tablegroup_id, 1);
let $tgmsy3_id = query_get_value(select tablegroup_id from oceanbase.__all_virtual_tablegroup where tablegroup_name ='tgmsy3' and tenant_id = $tenant_id, tablegroup_id, 1);
connection default;
#case1
--error 1493,14037 
alter tablegroup tgmsy add partition (partition p3 values less than(4));
--error 1517 
alter tablegroup tgmsy add partition (partition p2 values less than(123));
alter tablegroup tgmsy add partition (partition p3 values less than(123000), partition p4 values less than(341000));
--echo "t1 tgmsy part and t1 gc"
--disable_query_log
connection conn_sys;
eval select count(*) from oceanbase.__all_virtual_part where table_id=$t1_id;
eval select count(*) from oceanbase.__all_virtual_part where table_id=$tgmsy_id;
connection default;
eval select count(*) from oceanbase.__all_tenant_gc_partition_info where table_id = $t1_id;
--enable_query_log
insert into t1 values(24000,25,24),(123000,4535,77),(213000,234,678);
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create tablegroup tgmsy;

select * from t1 partition(p3);
select * from t1 partition(p4);

#case 1.1
--error 1493,14037
alter tablegroup tgmsy3 add partition (partition p3 values less than (2,6));
alter tablegroup tgmsy3 add partition (partition p3 values less than (660000,77000));
--echo "t3 tgmsy3 part and t3 gc"
--disable_query_log
connection conn_sys;
eval select count(*) from oceanbase.__all_virtual_part where table_id=$t3_id;
eval select count(*) from oceanbase.__all_virtual_part where table_id=$tgmsy3_id;
connection default;
eval select count(*) from oceanbase.__all_tenant_gc_partition_info where table_id = $t3_id;
--enable_query_log
insert into t3 values (22,33,44),(550000,77,55);
select * from t1 partition(p3);
#case2
--error 1507
alter tablegroup tgmsy drop partition (p6);
--error 1507 
alter tablegroup tgmsy drop partition (p6,p4);
--error 1508 
alter tablegroup tgmsy drop partition (p0,p1,p2,p3,p4);

alter tablegroup tgmsy drop partition (p3,p4);
--error 1735
select * from t1 partition(p3);
--error 1735
select * from t1 partition(p4);

alter tablegroup tgmsy3 drop partition (p3);
--error 1735
select * from t3 partition (p3);

#case3
alter tablegroup tgmsy add partition (partition p3 values less than(1230000), partition p4 values less than(3410000));
--echo "t1 tgmsy part and t1 gc"
--disable_query_log
connection conn_sys;
eval select count(*) from oceanbase.__all_virtual_part where table_id=$t1_id;
eval select count(*) from oceanbase.__all_virtual_part where table_id=$tgmsy_id;
connection default;
eval select count(*) from oceanbase.__all_tenant_gc_partition_info where table_id = $t1_id;
--enable_query_log
insert into t1 values(240000,25,24),(1230000,4535,77),(2130000,234,678);
select * from t1 partition(p3);
select * from t1 partition(p4);

alter tablegroup tgmsy3 add partition(partition p4 values less than  (maxvalue,770000));
--echo "t3 tgmsy3 part and t3 gc"
--disable_query_log
connection conn_sys;
eval select count(*) from oceanbase.__all_virtual_part where table_id=$t3_id;
eval select count(*) from oceanbase.__all_virtual_part where table_id=$tgmsy3_id;
connection default;
eval select count(*) from oceanbase.__all_tenant_gc_partition_info where table_id = $t3_id;
--enable_query_log
insert into t3 values (22000000,33,44),(66000000,77,55);
select * from t3 partition(p4);

#case5
alter tablegroup tgmsy add partition (partition p6 values less than(maxvalue));
--error 1653
alter tablegroup tgmsy2 add partition (partition p3 values less than(123534221,2332143534));
alter tablegroup tgmsy2 drop partition (p2);
alter tablegroup tgmsy2 add partition (partition p5 values less than(2332143534));
alter tablegroup tgmsy3 add partition (partition p6 values less than(maxvalue, maxvalue));
insert into t3 values (1235542,23,23);
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create tablegroup tgmsy; 
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create tablegroup tgmsy2;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create tablegroup tgmsy3;
drop table if exists t1,t2,t3;
drop tablegroup tgmsy;
drop tablegroup tgmsy2;
drop tablegroup tgmsy3;

