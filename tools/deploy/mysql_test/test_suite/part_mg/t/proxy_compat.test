--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: feizhi.cfz
#owner group: storage1
#description: todo

connect (conn_sys,$OBMYSQL_MS0,root@sys,,*NO-ONE*,$OBMYSQL_PORT);
connection default;

--disable_warnings
drop database if exists db;
create database db;
use db;
--enable_warnings

--disable_warnings
drop table if exists t1;
--enable_warnings

--disable_result_log
create table t1(c1 int, c2 int, primary key(c1,c2)) partition by range(c1) (partition p0 values less than(10), partition p1 values less than(MAXVALUE));

alter table t1 drop partition (p1);

connection conn_sys;
select * from oceanbase.__all_virtual_proxy_schema WHERE tenant_name = 'sys' AND database_name = 'db' AND table_name = 't1' and tablet_id = 0 ORDER BY role ASC LIMIT 99999;
connection default;

alter table t1 add partition (partition p1 values less than(20001));
connection conn_sys;
select * from oceanbase.__all_virtual_proxy_schema WHERE tenant_name = 'sys' AND database_name = 'db' AND table_name = 't1' and tablet_id = 1 ORDER BY role ASC LIMIT 99999;
connection default;

alter table t1 drop partition (p0);
connection conn_sys;
select * from oceanbase.__all_virtual_proxy_schema WHERE tenant_name = 'sys' AND database_name = 'db' AND table_name = 't1' and tablet_id = 0 ORDER BY role ASC LIMIT 99999;
connection default;

alter table t1 add partition (partition p3 values less than(40000), partition p4 values less than(50000));
connection conn_sys;
select * from oceanbase.__all_virtual_proxy_schema WHERE tenant_name = 'sys' AND database_name = 'db' AND table_name = 't1' and tablet_id = 2 ORDER BY role ASC LIMIT 99999;
# old id
select * from oceanbase.__all_virtual_proxy_schema WHERE tenant_name = 'sys' AND database_name = 'db' AND table_name = 't1' and tablet_id = 1 ORDER BY role ASC LIMIT 99999;
# invalid id
select * from oceanbase.__all_virtual_proxy_schema WHERE tenant_name = 'sys' AND database_name = 'db' AND table_name = 't1' and tablet_id = 12345678 ORDER BY role ASC LIMIT 99999;
connection default;

--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(c1 int, c2 int, primary key(c1,c2)) partition by range(c1) subpartition by hash(c2) subpartitions 3 (partition p0 values less than(10), partition p1 values less than(MAXVALUE));
alter table t1 drop partition (p1);
alter table t1 add partition (partition p1 values less than(20000));
connection conn_sys;
select * from oceanbase.__all_virtual_proxy_schema WHERE tenant_name = 'sys' AND database_name = 'db' AND table_name = 't1' and tablet_id = 0 ORDER BY role ASC LIMIT 99999;
connection default;

alter table t1 drop partition (p1);
alter table t1 add partition (partition p1 values less than(20001));
connection conn_sys;
select * from oceanbase.__all_virtual_proxy_schema WHERE tenant_name = 'sys' AND database_name = 'db' AND table_name = 't1' and tablet_id = 0 ORDER BY role ASC LIMIT 99999;
connection default;

alter table t1 drop partition (p1);
alter table t1 add partition (partition p1 values less than(MAXVALUE));
connection conn_sys;
select * from oceanbase.__all_virtual_proxy_schema WHERE tenant_name = 'sys' AND database_name = 'db' AND table_name = 't1' and tablet_id = 1152921509170249728 ORDER BY role ASC LIMIT 99999;
connection default;

alter table t1 drop partition (p1);
alter table t1 add partition (partition p1 values less than(20), partition p2 values less than(30));
connection conn_sys;
select * from oceanbase.__all_virtual_proxy_schema WHERE tenant_name = 'sys' AND database_name = 'db' AND table_name = 't1' and tablet_id = 0 ORDER BY role ASC LIMIT 99999;
connection default;

--disable_warnings
drop database if exists db;
--enable_warnings
