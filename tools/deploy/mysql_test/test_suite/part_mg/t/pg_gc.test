#owner: msy164651
#owner group: rs
#pg下的表是没有gc信息的

set @@recyclebin = off;
--disable_warnings
drop database if exists db;
create database db;
use db;
drop table if exists t1, t2, t3, t4, t5;
drop tablegroup if exists tg;
drop tablegroup if exists tg2;
drop tablegroup if exists tg3;
drop tablegroup if exists tg4;
--enable_warnings
# case 1
create tablegroup tg binding true;
create table t1 (c1 int primary key ,c2 int ,c3 int) tablegroup = 'tg';
create tablegroup tg2 binding true partition by range (partition p0 values less than(10), partition p1 values less than (20));
create table t2 (c1 int primary key ,c2 int ,c3 int) tablegroup = 'tg2' partition by range(c1) (partition p0 values less than(10), partition p1 values less than (20));
create tablegroup tg3;
create table t3 (c1 int primary key ,c2 int ,c3 int) tablegroup = 'tg3';
create tablegroup tg4 partition by range (partition p0 values less than(10), partition p1 values less than (20));
create table t4 (c1 int primary key ,c2 int ,c3 int) tablegroup = 'tg4' partition by range(c1) (partition p0 values less than(10), partition p1 values less than (20));
create table t5 (c1 int primary key ,c2 int ,c3 int);

insert into t1 values (2,1,1),(9,8,8),(12,12,12),(16,16,16);
insert into t2 values (2,1,1),(9,8,8),(12,12,12),(16,16,16);
insert into t3 values (2,1,1),(9,8,8),(12,12,12),(16,16,16);
insert into t4 values (2,1,1),(9,8,8),(12,12,12),(16,16,16);
insert into t5 values (2,1,1),(9,8,8),(12,12,12),(16,16,16);
use oceanbase;
--disable_query_log
--echo "tg and t1 gc info"
let $tg_id = query_get_value(select tablegroup_id from __all_tablegroup where tablegroup_name = 'tg', tablegroup_id, 1); 
eval select count(*) from __all_tenant_gc_partition_info where table_id = $tg_id;
let $tid = query_get_value(select table_id from __all_table where table_name = 't1' and tablegroup_id = $tg_id, table_id, 1);
eval select count(*) from __all_tenant_gc_partition_info where table_id = $tid;
--echo "tg2 and t2 gc info"
let $tg_id = query_get_value(select tablegroup_id from __all_tablegroup where tablegroup_name = 'tg2', tablegroup_id, 1); 
eval select count(*) from __all_tenant_gc_partition_info where table_id = $tg_id;
let $tid = query_get_value(select table_id from __all_table where table_name = 't2' and tablegroup_id = $tg_id, table_id, 1);
eval select count(*) from __all_tenant_gc_partition_info where table_id = $tid;

--echo "tg3 and t3 gc info"
let $tg_id = query_get_value(select tablegroup_id from __all_tablegroup where tablegroup_name = 'tg3', tablegroup_id, 1); 
eval select count(*) from __all_tenant_gc_partition_info where table_id = $tg_id;
let $tid = query_get_value(select table_id from __all_table where table_name = 't3' and tablegroup_id = $tg_id, table_id, 1);
eval select count(*) from __all_tenant_gc_partition_info where table_id = $tid;

--echo "tg4 and t4 gc info"
let $tg_id = query_get_value(select tablegroup_id from __all_tablegroup where tablegroup_name = 'tg4', tablegroup_id, 1); 
eval select count(*) from __all_tenant_gc_partition_info where table_id = $tg_id;
let $tid = query_get_value(select table_id from __all_table where table_name = 't4' and tablegroup_id = $tg_id, table_id, 1);
eval select count(*) from __all_tenant_gc_partition_info where table_id = $tid;

--echo "t5 gc info"
let $tid = query_get_value(select table_id from __all_table where table_name = 't5', table_id, 1);
eval select count(*) from __all_tenant_gc_partition_info where table_id = $tid;

--enable_query_log
use db;
drop table t1;
drop table t2;
drop table t3;
drop table t4;
drop table t5;

drop tablegroup tg;
drop tablegroup tg2;
drop tablegroup tg3;
drop tablegroup tg4;
