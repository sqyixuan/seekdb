--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: nijia.nj
#owner group: sql2
#description: todo

--disable_warnings
drop database if exists db;
create database db;
use db;
--enable_warnings

create table t1_garbage(c1 int, c2 int, primary key(c1,c2)) partition by range(c1) (partition p0 values less than(10), partition p1 values less than(20));
alter table t1_garbage drop partition (p0);

--real_sleep 60
--disable_query_log
# avtive_version will be NULL if partition is dropped
#echo select active_version from oceanbase.__all_virtual_partition_info where tenant_id = 1 and table_id = $table_id and partition_idx = 0;
#2.0 下,如果分区被gc, 将不会出现在这张表里
#eval select distinct 1 from oceanbase.__all_virtual_partition_info where tenant_id = 1 and table_id = $table_id and partition_idx = 0;
--enable_query_log


--disable_warnings
drop database if exists db;
--enable_warnings
