--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: nijia.nj
#owner group: sql2
# tags: optimizer
#description: todo

--disable_warnings
drop database if exists db;
create database db;
use db;
--enable_warnings

create table t1(c1 int, c2 int, primary key(c1,c2)) partition by range(c1) (partition p0 values less than(10));
alter table t1 add partition (partition p1 values less than(20));
alter table t1 add partition (partition p2 values less than(30));

insert into t1 values(15,1);
insert into t1 values(25,1);

explain select *  from t1;
explain select * from t1 partition(p0);
explain select * from t1 partition(p1);
explain select * from t1 partition(p2);

select * from t1 partition(p0);
select * from t1 partition(p1);
select * from t1 partition(p2);

select * from t1 partition(p1);
select * from t1;

alter table t1 drop partition (p1);

--error 1735
select * from t1 partition(p1);
select * from t1;


#fix for bug range columns分区判断向量大小有误: 
#negative cases
--error ER_RANGE_NOT_INCREASING_ERROR
create table jx_t1 (c1 int, c2 int) partition by range columns(c1,c2) (partition p0 values less than (10,1), partition p1 values less than (10,1));
--error ER_RANGE_NOT_INCREASING_ERROR
create table jx_t1 (c1 int, c2 int) partition by range columns(c1,c2) (partition p0 values less than (11,0), partition p1 values less than (10,1));
--error ER_RANGE_NOT_INCREASING_ERROR
create table jx_t1 (c1 int, c2 int) partition by range columns(c1,c2) (partition p0 values less than (10,2), partition p1 values less than (10,1));
--error ER_RANGE_NOT_INCREASING_ERROR
create table jx_t1 (c1 int, c2 int) partition by range columns(c1,c2) (partition p0 values less than (10,1), partition p1 values less than (9,1));
--error ER_RANGE_NOT_INCREASING_ERROR
create table jx_t1 (c1 int, c2 int) partition by range columns(c1,c2) (partition p0 values less than (10,1), partition p1 values less than (10,0));

create table jx_t1 (c1 int, c2 int) partition by range columns(c1,c2) (partition p0 values less than (10,1), partition p1 values less than (10,3));
insert into jx_t1 values(9,0);
insert into jx_t1 values(9,1);
insert into jx_t1 values(9,3);
# values for p1
insert into jx_t1 values(10,1);
--error ER_NO_PARTITION_FOR_GIVEN_VALUE
insert into jx_t1 values(10,3);
--error ER_RANGE_NOT_INCREASING_ERROR
alter table jx_t1 add partition(partition p2 values less than(10,2));
alter table jx_t1 add partition(partition p2 values less than(11,0));
insert into jx_t1 values(10,3);
select * from jx_t1;

drop table jx_t1;
create table jx_t1 (c1 int, c2 int) partition by range columns(c1,c2) (partition p0 values less than (10,1));
insert into jx_t1 values(9,1);
--error ER_NO_PARTITION_FOR_GIVEN_VALUE
insert into jx_t1 values(10,1);
drop table jx_t1;
create table jx_t1 (c1 int, c2 int, c3 int) partition by range columns(c1,c2, c3) (partition p0 values less than (10,10,10), partition p1 values less than (11,9,10), partition p2 values less than (11,10,9));
insert into jx_t1 values(11,9,10);
drop table jx_t1;

## verify for template subrange
#hash_range
create table hash_range(c1 varchar(20), c2 datetime, primary key(c3, c2),c3 int) partition by hash(c3) subpartition by range columns(c2) subpartition template (subpartition p0 values less than ('2013-10-10'),  subpartition p1 values less than ('2016-3-30')) partitions 16;
drop table hash_range;

create table hash_range(c1 int, c2 int, c3 int, primary key(c1, c2, c3)) partition by hash(c3) subpartition by range columns(c1, c2) subpartition template (subpartition p0 values less than (1, 11),  subpartition p1 values less than (2,22)) partitions 6;
drop table hash_range;
--error ER_RANGE_NOT_INCREASING_ERROR
create table hash_range(c1 int, c2 int, c3 int, primary key(c1, c2, c3)) partition by hash(c3) subpartition by range columns(c1, c2) subpartition template (subpartition p0 values less than (1,11),  subpartition p1 values less than (1,5)) partitions 6;
--error ER_RANGE_NOT_INCREASING_ERROR
create table hash_range(c1 int, c2 int, c3 int, primary key(c1, c2, c3)) partition by hash(c3) subpartition by range columns(c1, c2) subpartition template (subpartition p0 values less than (3,1),  subpartition p1 values less than (2,1)) partitions 6;
--error ER_RANGE_NOT_INCREASING_ERROR
create table hash_range(c1 int, c2 int, c3 int, primary key(c1, c2, c3)) partition by hash(c3) subpartition by range columns(c1, c2) subpartition template (subpartition p0 values less than (3,1),  subpartition p1 values less than (2,5)) partitions 6;
--error ER_RANGE_NOT_INCREASING_ERROR
create table hash_range(c1 int, c2 int, c3 int, primary key(c1, c2, c3)) partition by hash(c3) subpartition by range columns(c1, c2) subpartition template (subpartition p0 values less than (3,1),  subpartition p1 values less than (3,0)) partitions 6;

--disable_warnings
drop database if exists db;
--enable_warnings
