#owner: msy164651
#owner group: rs
#description: 分区分裂测试
#在tablegroup的分裂过程中加table，分裂可以正常结束

connect (conn_sys,$OBMYSQL_MS0,root@sys,,*NO-ONE*,$OBMYSQL_PORT);
connection default;

--disable_warnings
set @@recyclebin = off;
drop database if exists db;
create database db;
use db;
drop table if exists t1, t2, t3;
drop tablegroup if exists tgmsy;
--enable_warnings

create tablegroup tgmsy;
create table t1 (c1 int primary key ,c2 int ,c3 int) tablegroup = 'tgmsy';
insert into t1 values (2,1,1);
insert into t1 values(9,8,8);
insert into t1 values(12,12,12);
insert into t1 values(16,16,16);
insert into t1 values(111,111,111);
insert into t1 values(555,555,111);
alter table t1 partition by range (c1) (partition p0 values less than(maxvalue));
--error 1235
alter tablegroup tgmsy partition by list (partition p0 values in (1,2,3), partition p1 values in (default));
alter tablegroup tgmsy partition by range (partition p0 values less than (10),partition p1 values less than (100),partition p2 values less than (1000), partition p3 values less than (maxvalue));
--source mysql_test/include/check_logical_split_partition_ok.inc
connection conn_sys;
let $te_id = query_get_value(select tenant_id from oceanbase.__all_tenant where tenant_name = 'sys', tenant_id, 1);
let $db_id = query_get_value(select database_id from oceanbase.__all_virtual_database where database_name = 'db', database_id, 1);
let $tgmsy_id = query_get_value(select tablegroup_id from oceanbase.__all_virtual_tablegroup where tablegroup_name='tgmsy' and tenant_id = $te_id, tablegroup_id,1);
let $t1_id = query_get_value(select table_id from oceanbase.__all_virtual_table where table_name ='t1' and tenant_id = $te_id and database_id = $db_id, table_id, 1);
connection default;
--error 1235
create table t2 (c1 int primary key,c2 int) tablegroup = 'tgmsy' partition by range (c1)(partition p0 values less than (10),partition p1 values less than (100),partition p2 values less than (1000), partition p3 values less than (maxvalue));
create table t2 (c1 int primary key,c2 int) partition by range (c1)(partition p0 values less than (10),partition p1 values less than (100),partition p2 values less than (1000), partition p3 values less than (maxvalue));
--error 1235
alter table t2 set tablegroup ='tgmsy';
--error 4179
alter tablegroup tgmsy add table t2;
connection conn_sys;
--source mysql_test/include/check_split_partition_ok.inc
connection default;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t2;
drop table t1,t2;
drop tablegroup tgmsy;
