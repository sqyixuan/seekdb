--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: nijia.nj
#owner group: sql2
#description: todo

--disable_warnings
drop database if exists db;
create database db;
use db;
--enable_warnings

#
# operation on non-partition table
#
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(c1 int);
--error ER_PARTITION_MGMT_ON_NONPARTITIONED
alter table t1 add partition (partition p0 values less than(100));
--error ER_PARTITION_MGMT_ON_NONPARTITIONED
alter table t1 drop partition (p0);

#
#operation on twopart table
#
--disable_warnings
drop table if exists t1;
--enable_warnings
#create table t1(c1 int,c2 int,primary key(c1,c2)) partition by range(c1) subpartition by hash(c2) subpartitions 2 (partition p0 values less than(10));
#alter table t1 add partition (partition p0 values less than(20));
#alter table t1 drop partition (P2);
create table t1(c1 int,c2 int,primary key(c1,c2)) partition by hash(c1) subpartition by range(c2) subpartition template (subpartition p0 values less than(10)) partitions 10;
--error ER_NOT_SUPPORTED_YET
alter table t1 add partition (partition p0 values less than(20));
--error ER_NOT_SUPPORTED_YET 
alter table t1 drop partition (P2);

#
# add/drop on range
#
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(c1 int, c2 int, primary key(c1,c2)) partition by range(c1) (partition p0 values less than(10), partition p1 values less than(20));

# add
--error ER_SAME_NAME_PARTITION
alter table t1 add partition (partition p0 values less than(20));
--error ER_RANGE_NOT_INCREASING_ERROR
alter table t1 add partition (partition p2 values less than(20));
--error ER_RANGE_NOT_INCREASING_ERROR
alter table t1 add partition (partition p2 values less than(30), partition p3 values less than(30));

# drop
--error ER_DROP_PARTITION_NON_EXISTENT
alter table t1 drop partition (p2);
--error ER_DROP_PARTITION_NON_EXISTENT
alter table t1 drop partition (P2);
--error ER_DROP_LAST_PARTITION
alter table t1 drop partition (p0,p1);
--error ER_SAME_NAME_PARTITION # not compatible with mysql
alter table t1 drop partition (p0,p0);
alter table t1 drop partition (p0);
--error ER_DROP_LAST_PARTITION
alter table t1 drop partition (p1);
--error ER_DROP_LAST_PARTITION
alter table t1 drop partition (p0);

#
# range columns
#
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(c1 int, c2 int, primary key(c1,c2)) partition by range columns(c1,c2) (partition p0 values less than(10,20), partition p1 values less than(20,30));
--error ER_RANGE_NOT_INCREASING_ERROR
alter table t1 add partition (partition p2 values less than(20,30));
--error ER_RANGE_NOT_INCREASING_ERROR
alter table t1 add partition (partition p2 values less than(30,30), partition p3 values less than(30,30));

#
# date/time/datetime
#
#datetime
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(c1 int,c2 datetime,primary key(c1,c2)) partition by range columns(c2) (partition p0 values less than('2010-01-01 10:10:10'));
--error ER_RANGE_NOT_INCREASING_ERROR
alter table t1 add partition (partition p1 values less than('2010-01-01 10:10:10'));
--error ER_RANGE_NOT_INCREASING_ERROR
alter table t1 add partition (partition p1 values less than('2010-01-01 10:10:09'));
alter table t1 add partition (partition p1 values less than('2010-01-01 10:10:11'));
#date
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(c1 int,c2 date,primary key(c1,c2)) partition by range columns(c2) (partition p0 values less than('2010-01-01'));
--error ER_RANGE_NOT_INCREASING_ERROR
alter table t1 add partition (partition p1 values less than('2010-01-01'));
--error ER_RANGE_NOT_INCREASING_ERROR
alter table t1 add partition (partition p1 values less than('2009-01-01'));
alter table t1 add partition (partition p1 values less than('2010-01-02'));
#time
#--disable_warnings
#drop table if exists t1;
#--enable_warnings
#create table t1(c1 int,c2 time,primary key(c1,c2)) partition by range columns(c2) (partition p0 values less than('10:10:10'));
#--error ER_RANGE_NOT_INCREASING_ERROR
#alter table t1 add partition (partition p1 values less than('10:10:10'));
#--error ER_RANGE_NOT_INCREASING_ERROR
#alter table t1 add partition (partition p1 values less than('10:10:09'));
#alter table t1 add partition (partition p1 values less than('10:10:11'));


#
# range columns multi version
#
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(c1 int,c2 datetime,primary key(c1,c2)) partition by range columns(c1,c2) (partition p0 values less than(10, '2010-01-01 10:10:10'));
--error ER_RANGE_NOT_INCREASING_ERROR
alter table t1 add partition (partition p1 values less than(10, '2010-01-01 10:10:10'));
--error ER_RANGE_NOT_INCREASING_ERROR
alter table t1 add partition (partition p1 values less than(9, '2010-01-01 10:10:10'));
--error ER_RANGE_NOT_INCREASING_ERROR
alter table t1 add partition (partition p1 values less than(10, '2010-01-01 10:10:09'));
alter table t1 add partition (partition p1 values less than(11, '2010-01-01 10:10:11'));


--disable_warnings
drop database if exists db;
--enable_warnings
