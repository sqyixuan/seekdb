#owner: msy164651
#owner group: rs
#description: 分区分裂测试

#测试分裂后，表结构是正确的，数据是一致的
#case1 分裂第一个分区
#case2 分裂中间的分区
#case3 分裂最后一个分区
#case4 分裂max_Value的分区
#case5 分裂n多个分区
#case6 分裂的分区超过表的分区限制
#case7 分裂超大表的分区
#case8 错误验证

connection default;
set @@recyclebin = off;
--disable_warnings
drop table if exists t1, t2, t3;
--enable_warnings
#connect (conn_sys,$OBMYSQL_MS0,root@sys,,*NO-ONE*,$OBMYSQL_PORT);
create table t1 (c1 int primary key ,c2 int ,c3 int) partition by range (c1)(partition p0 values less than (10),partition p1 values less than (100),partition p2 values less than (1000));
create table t2 (c1 int primary key ,c2 int ,c3 int) partition by range (c1)(partition p0 values less than (10),partition p1 values less than (100),partition p2 values less than (MAXVALUE));
create table t3 (c1 int ,c2 int ,c3 int, primary key (c1,c2)) partition by range columns (c1,c2)(partition p0 values less than (10,10),partition p1 values less than (100,100),partition p2 values less than (maxvalue,maxvalue));
insert into t1 values (2,1,1),(9,8,8),(12,12,12),(16,16,16),(111,111,111),(555,555,111);
insert into t2 values (2,1,1),(9,8,8),(12,12,12),(16,16,16),(111,111,111),(555,555,111),(324543,3435,45464547);
insert into t3 values (2,1,1),(9,8,8),(12,12,12),(16,16,16),(111,111,111),(555,555,111),(324543,3435,45464547);
let $db_id = query_get_value(select database_id from oceanbase.__all_database where database_name = 'test', database_id, 1);
let $t1_id = query_get_value(select table_id from oceanbase.__all_table where table_name ='t1' and database_id = $db_id, table_id, 1);
#数据验证
select * from t1 partition(p0);
select * from t2 partition(p1);
select * from t3 partition(p2);
#case1
alter table t1 reorganize partition p0 into (partition p00 values less than (0), partition p01 values less than (10));
--source mysql_test/include/check_split_partition_ok.inc
connection default;
--error 1735
select * from t1 partition(p0);
select * from t1 partition(p00);
select * from t1 partition(p01);
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1 ;
#2
alter table t1 reorganize partition p1 into (partition p10 values less than (11), partition p11 values less than (16), partition p12 values less than (100));
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1 ;
--source mysql_test/include/check_split_partition_ok.inc
connection default;
--error 1735
select * from t1 partition(p1);
select * from t1 partition(p10);
select * from t1 partition(p11);
select * from t1 partition(p12);

#3
alter table t1 reorganize partition p2 into (partition p21 values less than (112), partition p22 values less than (212), partition p23 values less than (1000));
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1 ;
--source mysql_test/include/check_split_partition_ok.inc
connection default;
--error 1735
select * from t1 partition(p2);
select * from t1 partition(p21);
select * from t1 partition(p22);
select * from t1 partition(p23);
#4
alter table t2 reorganize partition p2 into (partition p21 values less than (112), partition p22 values less than (212), partition p23 values less than (1000), partition p24 values less than (maxvalue));
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t2;
--source mysql_test/include/check_split_partition_ok.inc
connection default;
--error 1735
select * from t2 partition(p2);
select * from t2 partition(p21);
select * from t2 partition(p22);
select * from t2 partition(p23);

#5
alter table t3 reorganize partition p0 into (partition p0 values less than  (4,3), partition pj values less than (10,10));
--source mysql_test/include/check_split_partition_ok.inc
connection default;
select * from t3 partition(p0);
select * from t3 partition(pj);

#6
drop table t2;
create table t2 (c1 int primary key ,c2 int ,c3 int) partition by range (c1)(partition p0 values less than (10),partition p1 values less than (100),partition p2 values less than (MAXVALUE));
--let $cnt=1001
--disable_query_log
while ($cnt)
{
 eval INSERT INTO t2 VALUES($cnt, $cnt, $cnt);
 dec $cnt;
}

--let $sql=alter table t2 reorganize partition p2 into(
--let $count=101
while($count<110)
{
  --let $sql=$sql partition p$count values less than ($count),
  inc $count;
}
--let $sql=$sql partition p$count values less than(maxvalue))
set @@session.ob_query_timeout=1000000000;
set @@session.ob_trx_timeout=1000000000;
eval $sql;
--enable_query_log
#--source mysql_test/include/check_split_partition_ok.inc
while($count>101) 
{
  eval select * from t2 partition (p$count);
  dec $count;
}

#case 8
--disable_warnings
drop table if exists t1, t2, t3;
--enable_warnings

create table t1 (c1 int primary key ,c2 int ,c3 int) partition by range (c1)(partition p0 values less than (10),partition p1 values less than (100),partition p2 values less than (1000));
create table t2 (c1 int primary key ,c2 int, c3 int) partition by list(c1) (partition p0 values in (1,2,3), partition p1 values in (4,5));
create table t3 (c1 int ,c2 int) partition by range (c1)(partition p0 values less than (10),partition p1 values less than (100),partition p2 values less than (1000));
insert into t1 values (2,1,1),(9,8,8),(12,12,12),(16,16,16),(111,111,111),(555,555,111);
#只支持一个分区的分裂
--error 1235
alter table t1 reorganize partition p0,p1 into (partition p1 values less than (100));
#分列后的分区名不可重复
--error 1517
alter table t1 reorganize partition p0 into (partition p1 values less than (10), partition p2 values less than (100));
#分裂必须有多个
--disable_result_log
--error 5599
alter table t1 reorganize partition p0 into (partition pi values less than (10));
--enable_result_log
#分裂必须有多个，并且分区前后的范围应该是一致的
--error 1520
alter table t1 reorganize partition p0 into (partition pj values less than (5),partition pi values less than (100));
#分裂后的范围必须是一致的
--error 1493,14037
alter table t1 reorganize partition p1 into (partition pi values less than (10), partition pj values less than (20));
#分裂后的最大值应该还是要保持递增的顺序
--error 1493,14037
alter table t1 reorganize partition p1 into (partition pi values less than (10), partition pj values less than (100));
#顺序不对
--error 1493,14037
alter table t1 reorganize partition p1 into (partition pi values less than (100), partition pj values less than (50));
#分区名重复
--error 1517
alter table t1 reorganize partition p1 into (partition p1 values less than (30), partition p2 values less than (100));
#分区名重复
--error 1517
alter table t1 reorganize partition p1 into (partition p1 values less than (30), partition p1 values less than (100));
#分区表必须有主键列
--error 1235
alter table t3 reorganize partition p1 into (partition p1 values less than (30), partition p5 values less than (100));
drop table t1;
drop table t3;
drop table t2;

--disable_query_log
--disable_result_log
connect (conn_admin,$OBMYSQL_MS0,admin@sys,admin,*NO-ONE*,$OBMYSQL_PORT);
--enable_result_log
--enable_query_log
