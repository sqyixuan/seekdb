#owner: msy164651
#owner group: rs
#description: oracle 模式下tablegroup级别的基础分区管理测试
#创建tablegroup和table
#1. 表分裂range 分区，增加分区，删除分区，分区分裂，truncate 分区


set @@recyclebin = off;
--disable_warnings
drop database if exists db;
create database db;
use db;
drop table if exists t1, t2, t3;
drop tablegroup if exists tg;
--enable_warnings
# case 1
create tablegroup tg binding true;
create table t1 (c1 int primary key ,c2 int ,c3 int) tablegroup = 'tg';
create table t2 (c1 int primary key ,c2 int ,c3 int) tablegroup = 'tg';
create table t3 (c1 int primary key ,c2 int ,c3 int) tablegroup = 'tg';
create table t4 (c1 int primary key ,c2 int ,c3 int) tablegroup = 'tg';
create table t5 (c1 int primary key ,c2 int ,c3 int) tablegroup = 'tg';
create table t6 (c1 int primary key ,c2 int ,c3 int) tablegroup = 'tg';
create table t7 (c1 int primary key ,c2 int ,c3 int) tablegroup = 'tg';
create table t8 (c1 int primary key ,c2 int ,c3 int) tablegroup = 'tg';
create table t9 (c1 int primary key ,c2 int ,c3 int) tablegroup = 'tg';
create table t10 (c1 int primary key ,c2 int ,c3 int) tablegroup = 'tg';

insert into t1 values (2,1,1),(9,8,8),(12,12,12),(16,16,16),(111,111,111),(555,555,111);
insert into t2 values (2,1,1),(9,8,8),(12,12,12),(16,16,16),(111,111,111),(555,555,111);
insert into t3 values (2,1,1),(9,8,8),(12,12,12),(16,16,16),(111,111,111),(555,555,111);
insert into t4 values (2,1,1),(9,8,8),(12,12,12),(16,16,16),(111,111,111),(555,555,111);
insert into t5 values (2,1,1),(9,8,8),(12,12,12),(16,16,16),(111,111,111),(555,555,111);
insert into t6 values (2,1,1),(9,8,8),(12,12,12),(16,16,16),(111,111,111),(555,555,111);
insert into t7 values (2,1,1),(9,8,8),(12,12,12),(16,16,16),(111,111,111),(555,555,111);
insert into t8 values (2,1,1),(9,8,8),(12,12,12),(16,16,16),(111,111,111),(555,555,111);
insert into t9 values (2,1,1),(9,8,8),(12,12,12),(16,16,16),(111,111,111),(555,555,111);
insert into t10 values (2,1,1),(9,8,8),(12,12,12),(16,16,16),(111,111,111),(555,555,111);

alter table t1 partition by range(c1) (partition p1 values less than (maxvalue));
alter table t2 partition by range(c1) (partition p1 values less than (maxvalue));
alter table t3 partition by range(c1) (partition p1 values less than (maxvalue));
alter table t4 partition by range(c1) (partition p1 values less than (maxvalue));
alter table t5 partition by range(c1) (partition p1 values less than (maxvalue));
alter table t6 partition by range(c1) (partition p1 values less than (maxvalue));
alter table t7 partition by range(c1) (partition p1 values less than (maxvalue));
alter table t8 partition by range(c1) (partition p1 values less than (maxvalue));
alter table t9 partition by range(c1) (partition p1 values less than (maxvalue));
alter table t10 partition by range(c1) (partition p1 values less than (maxvalue));

alter tablegroup tg partition by range (partition p0 values less than (10), partition p1 values less than (100),partition p2 values less than (1000), partition p3 values less than (maxvalue));
--source mysql_test/include/check_logical_split_partition_ok.inc

select * from t1;
select * from t4;
select * from t8;

--source mysql_test/include/check_split_partition_ok.inc
alter tablegroup tg drop partition p2;
#alter table t1 truncate partition p3;
alter tablegroup tg reorganize partition p0 into (partition p0 values less than (2), partition p01 values less than(10));
--source mysql_test/include/check_logical_split_partition_ok.inc

select * from t1;
select * from t4;
select * from t8;


