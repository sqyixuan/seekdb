#owner: msy164651
#owner group: rs
#description: 分区管理测试

#测试分裂后，表结构是正确的，数据是一致的
#case1 表分裂，没有max_value的处理
#case2 list分区指定part ID建表
#case3 list column的varchar的处理
set @@recyclebin = off;
--disable_warnings
drop database if exists db;
drop table if exists t1,t2,t3;
drop tablegroup if exists tg1111;
--enable_warnings
create database db;
use db;
#case 1
create table t1 (c1 int primary key,c2 int);
insert into t1 values (100000000,109);
--error 1526
alter table t1 partition by range(c1) (partition p1 values less than (1));
--error 1526
alter table t1 partition by range(c1) (partition p1 values less than (1), partition p3 values less than (10000000));
--error 1526
alter table t1 partition by list(c1) (partition p1 values in (100000));
--error 1526
alter table t1 partition by list(c1) (partition p1 values in (10000000), partition p3 values in (1000000000,230945465546));
alter table t1 partition by list(c1) (partition p343y values in (default));
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;

drop table t1;
create table t1 (c1 int primary key,c2 int);
insert into t1 values (100000000,109);
alter table t1 partition by range(c1) (partition p1 values less than (maxvalue));
drop table t1;

--disable_warnings
eval create user if not exists __oceanbase_inner_drc_user;
grant all privileges on *.* to __oceanbase_inner_drc_user;
sleep 10;
drop database if exists ym_db;
eval create database ym_db;
--enable_warnings
connect (conn_drc,$OBMYSQL_MS0,__oceanbase_inner_drc_user,,*NO-ONE*,$OBMYSQL_PORT);
connection conn_drc;
use ym_db;
#case 2
--error 1064
create table t1 (c1 int ,c2 int ,c3 int ,primary key(c1,c3)) max_used_part_id = -1 partition by list columns(c1,c3) (partition p0 values in ((1,3),(1,4)));

create table t1 (c1 int ,c2 int ,c3 int ,primary key(c1,c3)) max_used_part_id = 1 partition by list columns(c1,c3) (partition p0 values in ((1,3),(1,4)) id 0);
drop table t1;
--error 1210
create table t1 (c1 int ,c2 int ,c3 int ,primary key(c1,c3)) max_used_part_id = 0 partition by list columns(c1,c3) (partition p0 values in ((1,3),(1,4)) id 1);
--error 1210
create table t1 (c1 int ,c2 int ,c3 int ,primary key(c1,c3)) max_used_part_id = 2 partition by list columns(c1,c3) (partition p0 values in ((1,3),(1,4)) id 3);
create table t1 (c1 int ,c2 int ,c3 int ,primary key(c1,c3)) max_used_part_id = 3 partition by list columns(c1,c3) (partition p0 values in ((1,3),(1,4)) id 3);
drop table t1;
create table t1 (c1 int ,c2 int ,c3 int ,primary key(c1,c3)) max_used_part_id = 103465675634235462 partition by list columns(c1,c3) (partition p0 values in ((1,3),(1,4))id  23436548776);
drop table t1;
create table t1 (c1 int ,c2 int ,c3 int ,primary key(c1,c3)) max_used_part_id = 10 partition by list columns(c1,c3) (partition p0 values in ((1,3),(1,4)), partition p1 values in ((2,3),(4,5)), partition p2 values in (default));
drop table t1;
--error 1210
create table t1 (c1 int ,c2 int ,c3 int ,primary key(c1,c3)) max_used_part_id = 10 partition by list columns(c1,c3) (partition p0 values in ((1,3),(1,4)) id  3, partition p1 values in ((2,3),(4,5)), partition p2 values in (default));
--error 1210
create table t1 (c1 int ,c2 int ,c3 int ,primary key(c1,c3)) max_used_part_id = 10 partition by list columns(c1,c3) (partition p0 values in ((1,3),(1,4)), partition p1 values in ((2,3),(4,5)) id  4, partition p2 values in (default));
--error 1210
create table t1 (c1 int ,c2 int ,c3 int ,primary key(c1,c3)) max_used_part_id = 10 partition by list columns(c1,c3) (partition p0 values in ((1,3),(1,4)), partition p1 values in ((2,3),(4,5)), partition p2 values in (default) id  100);
--error 1652
create table t1 (c1 int ,c2 int ,c3 int ,primary key(c1,c3)) max_used_part_id = 10 partition by list columns(c1,c3) (partition p0 values in ((1,3),(1,4)) id 3, partition p1 values in ((2,3),(4,5)) id  3, partition p2 values in (default) id 3 );
--error 1064
create table t1 (c1 int ,c2 int ,c3 int ,primary key(c1,c3)) max_used_part_id = 10 partition by list columns(c1,c3) (partition p0 values in ((1,3),(1,4)) id  -1 , partition p1 values in ((2,3),(4,5)) id  12, partition p2 values in (default) id  -1);
--error 1210
create table t1 (c1 int ,c2 int ,c3 int ,primary key(c1,c3)) max_used_part_id = 10 partition by list columns(c1,c3) (partition p0 values in ((1,3),(1,4)) id  1, partition p1 values in ((2,3),(4,5)) id 10, partition p2 values in (default) id 90);
--error 4179
create table t1 (c1 int ,c2 int ,c3 int ,primary key(c1,c3))  partition by list columns(c1,c3) (partition p0 values in ((1,3),(1,4)) id 1, partition p1 values in ((2,3),(4,5)) id 2, partition p2 values in (default) id 3);
create table t1 (c1 int ,c2 int ,c3 int ,primary key(c1,c3)) max_used_part_id = 10 partition by list columns(c1,c3) (partition p0 values in ((1,3),(1,4)) id 1, partition p1 values in ((2,3),(4,5)) id 7, partition p2 values in (default) id 3);
drop table t1;
#case 3
connection default;
create table t1 (c1 int ,c2 varchar(19), c3 int, primary key(c1,c2)) ;
--error 1526
alter table t1 partition by list columns(c1,c2) (partition p0 values in ((1,'1'),(1,'4')));
alter table t1 partition by list columns(c1,c2) (partition p0 values in ((1,'1'),(1,'4')), partition p1 values in (default));
--source mysql_test/include/check_split_partition_ok.inc
connection default;
alter table t1 drop partition p1;
alter table t1 add partition (partition p1 values in ((2,'a'),(3,'c')));
--error 1654
alter table t1 add partition (partition p2 values in ((2,2),(3,'d')));
alter table t1 add partition (partition p132436 values in (default));
alter table t1 reorganize partition p132436 into (partition p3 values in ((5,"fdsg")), partition p4 values in (default));
#case 4
use db;
drop table t1;

create tablegroup tg1111;
create table t1 (c1 int,c2 varchar(2),c3 int,primary key(c1,c2)) tablegroup='tg1111';
alter table t1 partition by list columns(c1,c2) (partition p0 values in (default));
--error 1526
alter tablegroup tg1111 partition by list columns 2 (partition p0 values in ((1,'1')));
alter tablegroup tg1111 partition by list columns 2 (partition p0 values in ((1,'1')),partition p1 values in (default));
drop table t1;
drop tablegroup tg1111;



