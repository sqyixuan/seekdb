--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: nijia.nj
#owner group: sql2
#description: todo

--disable_warnings
drop database if exists db;
create database db;
use db;
--enable_warnings

#
# forbiden partition-management when index unavailable
#
create table t1(c1 int, c2 int, c3 int, primary key(c1)) partition by range(c1) (partition p0 values less than(10));
create table t2(c1 int, c2 int, c3 int, primary key(c1)) partition by range(c1) (partition p0 values less than(10));
create table t3(c1 int, c2 int, c3 int, index(c3) local, primary key(c1)) partition by range(c1) (partition p0 values less than(10));
alter table t1 add partition (partition p1 values less than(20));
alter table t2 add partition (partition p1 values less than(20));
alter table t3 add partition (partition p1 values less than(20));
create index t1_idx on t1(c3) local;
create unique index t2_uidx on t2(c1, c3) local;

#--error ER_NOT_SUPPORTED_YET
#alter table t1 add partition (partition p2 values less than(30));
#--error ER_NOT_SUPPORTED_YET
#alter table t2 add partition (partition p2 values less than(30));

#--source mysql_test/include/majorfreeze.inc
#--source mysql_test/include/wait_daily_merge.inc
--real_sleep 10
alter table t1 add partition (partition p2 values less than(30));
# 1.0 uniq index 合并两轮生效, 现在索引立即生效, case本意是希望索引生效之前不允许加分区
#--error ER_NOT_SUPPORTED_YET
#alter table t2 add partition (partition p2 values less than(30));

#--source mysql_test/include/majorfreeze.inc
#--source mysql_test/include/wait_daily_merge.inc
#--real_sleep 10
alter table t2 add partition (partition p2 values less than(30));

--disable_warnings
drop database db;
--enable_warnings
