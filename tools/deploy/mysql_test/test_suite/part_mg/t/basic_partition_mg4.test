#owner: msy164651
#owner group: rs
#description: mysql模式下tablegroup级别的基础分区管理测试
#创建tablegroup和table
#5. .. hash分区 ..
#6. .. list 分区 ..

set @@recyclebin = off;
--disable_warnings
drop database if exists db;
create database db;
use db;
drop table if exists t1, t2, t3;
drop tablegroup if exists tg;
--enable_warnings

create tablegroup tg;
create table t1 (c1 int, c2 int, c3 int, c4 int, primary key (c1,c2,c3)) tablegroup = 'tg';
insert into t1 values (2,1,1,11),(9,8,8,11),(12,12,12,11),(16,16,16,11),(111,111,111,111),(555,555,111,111);
alter table t1 partition by hash(c1) partitions 1;
alter tablegroup tg partition by hash partitions 10;
create table t2 (c1 int, c2 int, c3 int, c4 int, primary key (c1,c2,c3));
insert into t2 values (2,1,1,11),(9,8,8,11),(12,12,12,11),(16,16,16,11),(111,111,111,111),(555,555,111,111);
alter table t2 partition by key(c1) partitions 19;
#--source mysql_test/include/check_split_partition_ok.inc
#alter table t1 truncate partition p1,p2,p3,p4,p5,p6,p7;
#alter table t2 truncate partition p1,p2,p3,p4,p5,p6,p7;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t2;
drop table t1;
drop table t2;
drop tablegroup tg;
