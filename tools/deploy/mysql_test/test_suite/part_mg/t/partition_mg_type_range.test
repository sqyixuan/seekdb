#owner: msy164651
##owner group: rs

# description:
#
# test of range partition add drop and reorganize split

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
drop database if exists db1;
--enable_warnings
create database db1;
use db1;
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
let $database_id = query_get_value(select database_id from oceanbase.__all_virtual_database where tenant_id = 1002 and database_name = 'db1', database_id, 1);
disconnect obsys;
connection default;
##
create table t_tinyint(c1 tinyint(1) primary key) partition by range(c1)
(partition p0 values less than (-2500),
 partition p1 values less than (-129),
 partition p2 values less than (-128),
 partition p3 values less than (0),
 partition p4 values less than (127),
 partition p5 values less than (128));

alter table t_tinyint add partition (partition p6 values less than(2500));
alter table t_tinyint drop partition (p6);
alter table t_tinyint add partition (partition p6 values less than(2500), partition p7 values less than (MAXVALUE));
alter table t_tinyint drop partition (p6);
alter table t_tinyint reorganize partition p7 into (partition p6 values less than(2500), partition p7 values less than (MAXVALUE));
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
let $t_tinyint_id= query_get_value(select table_id from oceanbase.__all_virtual_table where tenant_id = 1002 and table_name = 't_tinyint' and database_id = $database_id, table_id, 1);
--disable_query_log
--echo part value for t_tinyint
eval select part_name, part_id, high_bound_val from oceanbase.__all_virtual_part where tenant_id = 1002 and table_id = $t_tinyint_id;
eval select partition_id from oceanbase.__all_virtual_tenant_gc_partition_info where tenant_id = 1002 and table_id = $t_tinyint_id;
disconnect obsys;
connection default;
--enable_query_log

create table t_tinyuint(c1 tinyint(1) unsigned primary key) partition by range(c1)
(partition p1 values less than (0),
 partition p2 values less than (255),
 partition p3 values less than (256),
 partition p4 values less than (2500),
 partition p5 values less than (MAXVALUE));
alter table t_tinyuint drop partition (p5,p3);
alter table t_tinyuint add partition (partition p5 values less than (MAXVALUE));
alter table t_tinyuint reorganize partition p4 into (partition p3 values less than (256),partition p4 values less than (2500));
--disable_query_log
--echo part value for t_tinyuint
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
let $t_tinyuint_id= query_get_value(select table_id from oceanbase.__all_virtual_table where tenant_id = 1002 and table_name = 't_tinyuint' and database_id = $database_id, table_id, 1);
eval select part_name, part_id, high_bound_val from oceanbase.__all_virtual_part where tenant_id = 1002 and table_id = $t_tinyuint_id;
disconnect obsys;
connection default;
--enable_query_log

create table t_smallint(c1 smallint(1) primary key) partition by range(c1)
(partition p0 values less than (-50000),
 partition p1 values less than (-32769),
 partition p2 values less than (-32768),
 partition p3 values less than (0),
 partition p4 values less than (32767),
 partition p5 values less than (32768),
 partition p6 values less than (50000),
 partition p7 values less than (MAXVALUE));
alter table t_smallint drop partition (p0,p1,p2);
alter table t_smallint reorganize partition p3 into (partition p0 values less than (-50000),partition p1 values less than (-32769),partition p2 values less than (-32768),partition p3 values less than (0));
--disable_query_log
--echo part value for t_smallint
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
let $t_smallint_id= query_get_value(select table_id from oceanbase.__all_virtual_table where tenant_id = 1002 and table_name = 't_smallint' and database_id = $database_id, table_id, 1);
eval select part_name, part_id, high_bound_val from oceanbase.__all_virtual_part where tenant_id = 1002 and table_id = $t_smallint_id;
disconnect obsys;
connection default;
--enable_query_log

create table t_mediumint(c1 mediumint(1) primary key) partition by range(c1)
(partition p0 values less than (-10000000),
 partition p1 values less than (-8388609),
 partition p2 values less than (-8388608),
 partition p3 values less than (0),
 partition p4 values less than (8388607),
 partition p5 values less than (8388608),
 partition p6 values less than (10000000),
 partition p7 values less than (MAXVALUE));
alter table t_mediumint drop partition (p3,p4,p5,p6);
alter table t_mediumint reorganize partition p7 into (partition p3 values less than (0),partition p4 values less than (8388607),partition p5 values less than (8388608),partition p7 values less than (MAXVALUE));
--disable_query_log
--echo part value for t_mediumint
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
let $t_mediumint_id = query_get_value(select table_id from oceanbase.__all_virtual_table where tenant_id = 1002 and table_name = 't_mediumint' and database_id = $database_id, table_id, 1);
eval select part_name, part_id, high_bound_val from oceanbase.__all_virtual_part where tenant_id = 1002 and table_id = $t_mediumint_id;
disconnect obsys;
connection default;
--enable_query_log


create table t1 (c1 bigint primary key) partition by range(c1) (partition p1000 values less than (-9223372036854));
--error ER_VALUES_IS_NOT_INT_TYPE_ERROR
alter table t1 add partition (partition p0 values less than (-9223372036854775809));
alter table t1 add partition (partition p0 values less than (9223372036854775808));
--error ER_VALUES_IS_NOT_INT_TYPE_ERROR 
alter table t1 add partition (partition p0 values less than (18446744073709551616));
alter table t1 add partition (partition p1 values less than (maxvalue));
--error ER_VALUES_IS_NOT_INT_TYPE_ERROR 
alter table t1 reorganize partition p0 into (partition p0 values less than (-9223372036854775809), partition p1 values less than (maxvalue));
--error ER_REORG_OUTSIDE_RANGE
alter table t1 reorganize partition p0 into (partition p2 values less than (9223372036854775808), partition p3 values less than (maxvalue));
--error ER_VALUES_IS_NOT_INT_TYPE_ERROR 
alter table t1 reorganize partition p0 into (partition p0 values less than (18446744073709551616), partition p1 values less than (maxvalue));


drop database db1;
