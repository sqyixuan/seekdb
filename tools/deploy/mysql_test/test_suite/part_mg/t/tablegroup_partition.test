#
#
#owner:msy164651
#非分区的tablegroup分裂需要指定所有的table的分区键
#指定过程中，需要保证每个表的分区方式都是一样的

set @@recyclebin = off;
--disable_warnings
drop database if exists db;
create database db;
use db;
drop table if exists t1, t2;
drop tablegroup if exists tgtest;
drop tablegroup if exists tgtest1;
drop tablegroup if exists test2_tablegroup;
--enable_warnings

#建tablegroup，建表
create tablegroup tgtest; 
create table t1 (c1 int primary key, c2 int) tablegroup = tgtest;
create table t2 (c1 int primary key, c2 int) tablegroup = tgtest;

#不指定分区键分裂tablegroup失败
--error 1235
alter tablegroup tgtest partition by list columns 1 (partition p0 values in (default));
--error 1235
alter tablegroup tgtest partition by range columns 1 (partition p0 values less than (maxvalue));

#对table指定不同的分区键
alter table t1 partition by list columns(c1) (partition p0 values in (default));
--error 4179
alter table t2 partition by range columns(c1) (partition p0 values less than (maxvalue));
--error 1235
alter tablegroup tgtest partition by list columns 1 (partition p0 values in (default));
--error 1235
alter tablegroup tgtest partition by range columns 1 (partition p0 values less than (maxvalue));
#指定相同的分区键分裂

alter table t2 partition by list columns(c1) (partition p0 values in (default));
--error 1235
alter tablegroup tgtest partition by range columns 1 (partition p0 values less than (maxvalue));
alter tablegroup tgtest partition by list columns 1 (partition p0 values in(default));

create tablegroup test2_tablegroup partition by list columns 1 (partition pdefault values in (default));
create tablegroup tgtest1 partition by range columns 1 (partition p0 values less than (maxvalue));
#非分区表转换为单分区,不用实质性的分裂
--source mysql_test/include/check_split_partition_ok.inc
#分区分裂, 从一个分区到多个分区
alter tablegroup tgtest reorganize partition p0 into (partition p0 values in (1,23,4,5,6), partition p1 values in (7,8,9,10), partition p2 values in (default));
--error 5599
alter tablegroup test2_tablegroup reorganize partition pdefault into (partition p0 values in(default));
alter tablegroup tgtest1 reorganize partition p0 into (partition p0 values less than (10), partition p1 values less than(maxvalue));
drop table t1, t2; 
drop tablegroup if exists tgtest;
drop tablegroup if exists tgtest1;
drop tablegroup if exists test2_tablegroup;

