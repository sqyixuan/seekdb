#owner: msy164651
#owner group: rs
#description: 
#修改表的属性，不应该修改全局索引表的tablegroup
#创建表，创建全局索引表
#1.把表加入到一个tablegroup中，全局索引表不会进入
#2.移除这个tablegroup，全局索引不变
#3.修改表的渐进合并，全局索引表渐进合并个数也修改了
#4.分裂这张表，全局索引表不分裂，
--disable_warnings
set @@recyclebin = off;
drop database if exists db;
create database db;
use db;
drop table if exists t1, t2, t3;
drop tablegroup if exists tg1234;
--enable_warnings
connect (conn_sys,$OBMYSQL_MS0,root@sys,,*NO-ONE*,$OBMYSQL_PORT);
connection default;

create table t1(c1 int primary key, c2 int, c3 int);
create index il on t1(c1) global partition by hash(c1) partitions 10;
create unique index il1 on t1(c1) global partition by hash(c1) partitions 10;
create tablegroup tg1234; 
#case 1
alter table t1 set tablegroup=tg1234;
connection conn_sys;
use oceanbase;
#1
let $tenant_id = query_get_value(select tenant_id from oceanbase.__all_tenant where tenant_name = 'sys', tenant_id,1);
let $table_id =  query_get_value(select table_id from __all_virtual_table where tablegroup_id = (select tablegroup_id from __all_virtual_tablegroup where tablegroup_name = 'tg1234' and tenant_id = $tenant_id), table_id, 1);
--disable_query_log
eval select count(*) from __all_virtual_table where tablegroup_id = (select tablegroup_id from __all_virtual_tablegroup where tablegroup_name = 'tg1234' and tenant_id = $tenant_id);
--enable_query_log
#case 2
connection default;
alter table t1 set tablegroup = '';
connection conn_sys;
use oceanbase;
--disable_query_log
eval select count(*) from __all_virtual_table where tablegroup_id = (select tablegroup_id from __all_virtual_tablegroup where tablegroup_name = 'tg1234' and tenant_id = $tenant_id);
--enable_query_log

connection default;
alter table t1 set tablegroup=tg1234;
connection conn_sys;
use oceanbase;
--disable_query_log
eval select count(*) from __all_virtual_table where tablegroup_id = (select tablegroup_id from __all_virtual_tablegroup where tablegroup_name = 'tg1234' and tenant_id = $tenant_id);
--enable_query_log
#case 3
connection default;
alter table t1 set progressive_merge_num=3;
connection conn_sys;
use oceanbase;
--disable_query_log
eval select progressive_merge_num from __all_virtual_table where table_id = $table_id;
eval select progressive_merge_num from __all_virtual_table where data_table_id = $table_id;
eval select count(*) from __all_virtual_table where tablegroup_id = (select tablegroup_id from __all_virtual_tablegroup where tablegroup_name = 'tg1234' and tenant_id = $tenant_id);
--enable_query_log
connection default;
#case 4
--source mysql_test/include/check_all_idx_ok.inc
alter table t1 partition by hash(c1) partitions 1;
alter tablegroup tg1234 partition by hash partitions 1;
connection conn_sys;
use oceanbase;
--disable_query_log
eval select part_num from __all_virtual_table where table_id = $table_id;
eval select part_num from __all_virtual_table where data_table_id = $table_id;
eval select count(*) from __all_virtual_table where tablegroup_id = (select tablegroup_id from __all_virtual_tablegroup where tablegroup_name = 'tg1234' and tenant_id = $tenant_id);
--enable_query_log
