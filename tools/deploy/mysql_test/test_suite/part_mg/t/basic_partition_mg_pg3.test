#owner: msy164651
#owner group: rs
#description: mysql 模式下tablegroup级别的基础分区管理测试
#创建tablegroup和table
#3. .. range column ..

set @@recyclebin = off;
--disable_warnings
drop database if exists db;
create database db;
use db;
drop table if exists t1, t2, t3;
drop tablegroup if exists tg;
drop tablegroup if exists tg1;
--enable_warnings

#case3
create tablegroup tg binding true;
create table t1 (c1 int, c2 int, c3 int, c4 int, primary key (c1,c2,c3)) tablegroup = 'tg';
insert into t1 values (2,1,1,11),(9,8,8,11),(12,12,12,11),(16,16,16,11),(111,111,111,111),(555,555,111,111);
alter table t1 partition by range columns(c1,c2,c3) (partition pi values less than(maxvalue, maxvalue,maxvalue));
alter tablegroup tg partition by range columns 3 (partition p0  values less than(2,3,4), partition p1 values less than (3,4,5), partition p2 values less than (111,222,3333), partition p3 values less than(555,6666,4444), partition p4 values less than(maxvalue,maxvalue,maxvalue));

create tablegroup tg1 binding true;
create table t2 (c1 int, c2 int, c3 int, c4 int, primary key (c1,c2,c3)) tablegroup = 'tg1';
insert into t2 values (2,1,1,11),(9,8,8,11),(12,12,12,11),(16,16,16,11),(111,111,111,111),(555,555,111,111);
alter table t2 partition by list columns(c1,c2,c3) (partition p0 values in (default));
alter tablegroup tg1 partition by list columns 3 (partition p1 values in ((2,1,1),(9,8,8),(12,12,12)), partition p2 values in ((16,16,16),(111,111,111)), partition p3 values in (default));
--source mysql_test/include/check_split_partition_ok.inc
alter tablegroup tg drop partition p2, p1, p3;
#alter table t1 truncate partition p0,p4;
alter tablegroup tg reorganize partition p4 into (partition p2 values less than (111,222,333), partition p3 values less than (555,665654,777), partition p4 values less than(maxvalue,maxvalue,maxvalue));
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;

#alter table t2 truncate partition p1,p3;
alter tablegroup tg1 drop partition p1, p3;
alter tablegroup tg1 add partition (partition p1 values in ((555,555,555)));
alter tablegroup tg1 reorganize partition p2 into (partition p3 values in ((16,16,16)), partition p2 values in ((111,111,111)));
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t2;

drop table t1, t2;
drop tablegroup tg;
drop tablegroup tg1;

