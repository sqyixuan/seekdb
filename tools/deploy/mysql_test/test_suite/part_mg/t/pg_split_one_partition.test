#owner: msy164651
#owner group: rs
#description: pg分裂为一个分区的处理情况
#创建tablegroup和table


set @@recyclebin = off;
--disable_warnings
drop database if exists db;
create database db;
use db;
drop table if exists t1, t2, t3;
drop tablegroup if exists tg;
--enable_warnings
# case 1 分裂为hash分区
create tablegroup tg binding = true;
create table t1 (c1 int primary key ,c2 int ,c3 int) tablegroup = 'tg';
--error 1235
alter table t1 partition by hash(c1) partitions 1;
insert into t1 values (2,1,1),(9,8,8),(12,12,12),(16,16,16),(111,111,111),(555,555,111);
--error 1235
alter tablegroup tg partition by hash partitions 1;
delete from t1;
insert into t1 values (2,1,1),(9,8,8),(12,12,12),(16,16,16),(111,111,111),(555,555,111);
drop table t1;
drop tablegroup tg;

#case 2 分裂为range分区
create tablegroup tg binding = true;
create table t1 (c1 int primary key ,c2 int ,c3 int) tablegroup = 'tg';
--error 1235
alter table t1 partition by range(c1) (partition p0 values less than(maxvalue));
insert into t1 values (2,1,1),(9,8,8),(12,12,12),(16,16,16),(111,111,111),(555,555,111);
--error 1235
alter tablegroup tg partition by range (partition p0 values less than(maxvalue));
delete from t1;
insert into t1 values (2,1,1),(9,8,8),(12,12,12),(16,16,16),(111,111,111),(555,555,111);
drop table t1;
drop tablegroup tg;

#case3 分裂为list分区
create tablegroup tg binding = true;
create table t1 (c1 int primary key ,c2 int ,c3 int) tablegroup = 'tg';
--error 1235
alter table t1 partition by list(c1) (partition p0 values in (default));
insert into t1 values (2,1,1),(9,8,8),(12,12,12),(16,16,16),(111,111,111),(555,555,111);
--error 1235
alter tablegroup tg partition by list (partition p0 values in (default));
delete from  t1;
insert into t1 values (2,1,1),(9,8,8),(12,12,12),(16,16,16),(111,111,111),(555,555,111);
drop table t1;
drop tablegroup tg;
