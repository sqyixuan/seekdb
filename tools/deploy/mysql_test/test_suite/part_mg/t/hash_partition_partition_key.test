#owner: msy164651
#group: rs
#
#测试hash一级、二级分区的partition key level的查询是正确的

connect (conn_sys,$OBMYSQL_MS0,root@sys,,*NO-ONE*,$OBMYSQL_PORT);
connection default;
set @@recyclebin = off;
--disable_warnings
drop database if exists db;
drop table if exists t1,t2,t3;
drop tablegroup if exists tg1111;
--enable_warnings
create database db;
use db;
#hash 1 级分区
use db;
create table t1(c1 int, c2 int, c3 int, primary key(c1,c2)) partition by key(c1) partitions 10;
connection conn_sys;
let $te_id = query_get_value(select 1 as tenant_id, tenant_id, 1);
let $db_id = query_get_value(select database_id from oceanbase.__all_virtual_database where database_name = 'db', database_id, 1);
let $t1_id = query_get_value(select table_id from oceanbase.__all_virtual_table where table_name = 't1' and database_id = $db_id, table_id, 1);
--disable_query_log
eval select part_key_level, part_key_name FROM oceanbase.__all_virtual_proxy_partition_info WHERE tenant_name = 'sys' AND table_id = $t1_id;
--enable_query_log
connection default;
use db;
drop table t1; 

create table t1(c1 int, c2 int, c3 int, primary key(c1,c2)) partition by key(c1, c2) partitions 10;
connection conn_sys;
let $te_id = query_get_value(select 1 as tenant_id, tenant_id, 1);
let $db_id = query_get_value(select database_id from oceanbase.__all_virtual_database where database_name = 'db', database_id, 1);
let $t1_id = query_get_value(select table_id from oceanbase.__all_virtual_table where table_name = 't1' and database_id = $db_id, table_id, 1);
--disable_query_log
eval select part_key_level, part_key_name FROM oceanbase.__all_virtual_proxy_partition_info WHERE tenant_name = 'sys' AND table_id = $t1_id;
--enable_query_log
connection default;
use db;
drop table t1;

create table t1(c1 int, c2 int, c3 int, primary key(c1,c2)) partition by hash(c1) partitions 1;
connection conn_sys;
let $te_id = query_get_value(select 1 as tenant_id, tenant_id, 1);
let $db_id = query_get_value(select database_id from oceanbase.__all_virtual_database where database_name = 'db', database_id, 1);
let $t1_id = query_get_value(select table_id from oceanbase.__all_virtual_table where table_name = 't1' and database_id = $db_id, table_id, 1);
--disable_query_log
eval select part_key_level, part_key_name FROM oceanbase.__all_virtual_proxy_partition_info WHERE tenant_name = 'sys' AND table_id = $t1_id;
--enable_query_log
connection default;
use db;
drop table t1;

#hash + range

create table t1(c1 int, c2 int, c3 int, primary key(c1,c2)) partition by key(c1) subpartition by range(c2) subpartition template (subpartition p0 values less than (10), subpartition p1 values less than (20)) partitions 10;
connection conn_sys;
let $te_id = query_get_value(select 1 as tenant_id, tenant_id, 1);
let $db_id = query_get_value(select database_id from oceanbase.__all_virtual_database where database_name = 'db', database_id, 1);
let $t1_id = query_get_value(select table_id from oceanbase.__all_virtual_table where table_name = 't1' and database_id = $db_id, table_id, 1);
--disable_query_log
eval select part_key_level, part_key_name FROM oceanbase.__all_virtual_proxy_partition_info WHERE tenant_name = 'sys' AND table_id = $t1_id;
--enable_query_log
connection default;
use db;
drop table t1;

create table t1(c1 int, c2 int, c3 int, c4 int, c5 int, primary key(c1,c2,c3,c4)) partition by key(c1, c2) subpartition by range columns (c3, c4) subpartition template (subpartition p0 values less than (10,11), subpartition p1 values less than (20,34)) partitions 10;
connection conn_sys;
let $te_id = query_get_value(select 1 as tenant_id, tenant_id, 1);
let $db_id = query_get_value(select database_id from oceanbase.__all_virtual_database where database_name = 'db', database_id, 1);
let $t1_id = query_get_value(select table_id from oceanbase.__all_virtual_table where table_name = 't1' and database_id = $db_id, table_id, 1);
--disable_query_log
eval select part_key_level, part_key_name FROM oceanbase.__all_virtual_proxy_partition_info WHERE tenant_name = 'sys' AND table_id = $t1_id;
--enable_query_log
connection default;
use db;
drop table t1;

#hash + list
create table t1(c1 int, c2 int, c3 int, primary key(c1,c2)) partition by hash(c1) subpartition by list(c2) subpartition template (subpartition p0 values in (10,11), subpartition p1 values in (20, 30)) partitions 10;
connection conn_sys;
let $te_id = query_get_value(select 1 as tenant_id, tenant_id, 1);
let $db_id = query_get_value(select database_id from oceanbase.__all_virtual_database where database_name = 'db', database_id, 1);
let $t1_id = query_get_value(select table_id from oceanbase.__all_virtual_table where table_name = 't1' and database_id = $db_id, table_id, 1);
--disable_query_log
eval select part_key_level, part_key_name FROM oceanbase.__all_virtual_proxy_partition_info WHERE tenant_name = 'sys' AND table_id = $t1_id;
--enable_query_log
connection default;
use db;
drop table t1;

create table t1(c1 int, c2 int, c3 int, c4 int, c5 int, primary key(c1,c2,c3,c4)) partition by key(c1, c2) subpartition by list columns (c3, c4) subpartition template (subpartition p0 values in ((10,11)), subpartition p1 values in (default)) partitions 10;
connection conn_sys;
let $te_id = query_get_value(select 1 as tenant_id, tenant_id, 1);
let $db_id = query_get_value(select database_id from oceanbase.__all_virtual_database where database_name = 'db', database_id, 1);
let $t1_id = query_get_value(select table_id from oceanbase.__all_virtual_table where table_name = 't1' and database_id = $db_id, table_id, 1);
--disable_query_log
eval select part_key_level, part_key_name FROM oceanbase.__all_virtual_proxy_partition_info WHERE tenant_name = 'sys' AND table_id = $t1_id;
--enable_query_log
connection default;
use db;
drop table t1;

#range + hash
create table t1(c1 int, c2 int, c3 int, primary key(c1,c2)) partition by range (c1) subpartition by hash(c2) subpartitions 10 (partition p0 values less than (10), partition p1 values less than(20)) ;
connection conn_sys;
let $te_id = query_get_value(select 1 as tenant_id, tenant_id, 1);
let $db_id = query_get_value(select database_id from oceanbase.__all_virtual_database where database_name = 'db', database_id, 1);
let $t1_id = query_get_value(select table_id from oceanbase.__all_virtual_table where table_name = 't1' and database_id = $db_id, table_id, 1);
--disable_query_log
eval select part_key_level, part_key_name FROM oceanbase.__all_virtual_proxy_partition_info WHERE tenant_name = 'sys' AND table_id = $t1_id;
--enable_query_log
connection default;
use db;
drop table t1;

create table t1(c1 int, c2 int, c3 int, c4 int, c5 int, primary key(c1,c2,c3,c4)) partition by range columns (c1, c2) subpartition by key (c3, c4) subpartitions 10 (partition p0 values less than (10,11), partition p1 values less than (20,34));
connection conn_sys;
let $te_id = query_get_value(select 1 as tenant_id, tenant_id, 1);
let $db_id = query_get_value(select database_id from oceanbase.__all_virtual_database where database_name = 'db', database_id, 1);
let $t1_id = query_get_value(select table_id from oceanbase.__all_virtual_table where table_name = 't1' and database_id = $db_id, table_id, 1);
--disable_query_log
eval select part_key_level, part_key_name FROM oceanbase.__all_virtual_proxy_partition_info WHERE tenant_name = 'sys' AND table_id = $t1_id;
--enable_query_log
connection default;
use db;
drop table t1;

#list + hash
create table t1(c1 int, c2 int, c3 int, primary key(c1,c2)) partition by list(c1) subpartition by hash(c2) subpartitions 10 (partition p0 values in (10,11), partition p1 values in (20, 30));
connection conn_sys;
let $te_id = query_get_value(select 1 as tenant_id, tenant_id, 1);
let $db_id = query_get_value(select database_id from oceanbase.__all_virtual_database where database_name = 'db', database_id, 1);
let $t1_id = query_get_value(select table_id from oceanbase.__all_virtual_table where table_name = 't1' and database_id = $db_id, table_id, 1);
--disable_query_log
eval select part_key_level, part_key_name FROM oceanbase.__all_virtual_proxy_partition_info WHERE tenant_name = 'sys' AND table_id = $t1_id;
--enable_query_log
connection default;
use db;
drop table t1;

create table t1(c1 int, c2 int, c3 int, c4 int, c5 int, primary key(c1,c2,c3,c4)) partition by list columns(c1, c2) subpartition by key(c3, c4) subpartitions 10 (partition p0 values in ((10,11)), partition p1 values in (default));
connection conn_sys;
let $te_id = query_get_value(select 1 as tenant_id, tenant_id, 1);
let $db_id = query_get_value(select database_id from oceanbase.__all_virtual_database where database_name = 'db', database_id, 1);
let $t1_id = query_get_value(select table_id from oceanbase.__all_virtual_table where table_name = 't1' and database_id = $db_id, table_id, 1);
--disable_query_log
eval select part_key_level, part_key_name FROM oceanbase.__all_virtual_proxy_partition_info WHERE tenant_name = 'sys' AND table_id = $t1_id;
--enable_query_log
connection default;
use db;
drop table t1;

