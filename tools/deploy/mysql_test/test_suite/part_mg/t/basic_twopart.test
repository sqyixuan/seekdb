--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: nijia.nj
#owner group: sql2
# tags: optimizer
#description: todo

--disable_warnings
drop database if exists db;
create database db;
use db;
--enable_warnings

create table t1(c1 int, c2 int, primary key(c1,c2)) partition by range(c1) subpartition by hash(c2) subpartitions 3 (partition p0 values less than(10));
alter table t1 add partition (partition p1 values less than(20));
alter table t1 add partition (partition p2 values less than(30));

insert into t1 values(15,1); # p1sp1
insert into t1 values(25,1); # p2sp1
insert into t1 values(25,2); # p2sp2
insert into t1 values(25,3); # p2sp0

select * from t1 partition(p0sp0);
select * from t1 partition(p1sp1);
select * from t1 partition(p2sp1);
select * from t1 partition(p2sp2);
select * from t1 partition(p2sp0);

select * from t1;

alter table t1 drop partition (p1);

--error 1735
select * from t1 partition(p1sp0);
select * from t1;


--disable_warnings
drop database if exists db;
--enable_warnings
