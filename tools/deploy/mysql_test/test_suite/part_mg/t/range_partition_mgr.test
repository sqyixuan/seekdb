#owner: msy164651
#owner group: rs
#description: range分区分裂测试
#range的分区表，加分区，减分区，分裂
#带局部索引
#在tablegroup下面
#带全局索引
--disable_warnings
drop database if exists db;
create database db;
use db;
drop table if exists t1, t2, t3;
--enable_warnings
connect (conn_sys,$OBMYSQL_MS0,root@sys,,*NO-ONE*,$OBMYSQL_PORT);
connection default;

#range
create table t1 (c1 int primary key ,c2 int ,c3 int) partition by range (c1)(partition p0 values less than (10),partition p1 values less than (100),partition p2 values less than (1000));
insert into t1 values(1,1,1),(2,2,2),(3,3,3),(10,12,13),(111,112,234);
select * from t1 order by c1; 
alter table t1 drop partition p2; 
select * from t1 order by c1; 
alter table t1 add partition(partition p2 values less than (maxvalue));
insert into t1 values (12343,345,657);
alter table t1 drop partition p2; 
select * from t1 order by c1; 
alter table t1 add partition(partition p2 values less than (maxvalue));
insert into t1 values (12343,345,657);
alter table t1 reorganize partition p2 into (partition p2 values less than(12345), partition p3 values less than(maxvalue));
--source mysql_test/include/check_logical_split_partition_ok.inc
select * from t1 order by c1; 
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;
drop table t1;

#range with index
create table t1 (c1 int primary key ,c2 int ,c3 int) partition by range (c1)(partition p0 values less than (10),partition p1 values less than (100),partition p2 values less than (1000));
create index il on t1 (c2) local;
--source mysql_test/include/check_all_idx_ok.inc
insert into t1 values(1,1,1),(2,2,2),(3,3,3),(10,12,13),(111,112,234);
select * from t1 order by c1; 
alter table t1 add partition (partition p3 values less than (1900));
insert into t1 values (1890,23,1);
select * from t1 order by c1; 
alter table t1 add partition(partition p4 values less than (maxvalue));
insert into t1 values (12343,345,657);
alter table t1 drop partition p4; 
select * from t1 order by c1; 
alter table t1 add partition(partition p4 values less than (maxvalue));
insert into t1 values (12343,345,657);
alter table t1 reorganize partition p4 into (partition p4 values less than(12345), partition p5 values less than(maxvalue));
--source mysql_test/include/check_logical_split_partition_ok.inc
select * from t1 order by c1; 
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;
drop table t1;

#range with tablegroup
create tablegroup tg123456 partition by range (partition p0 values less than (10),partition p1 values less than (100),partition p2 values less than (MAXVALUE));
create table t2 (c1 int primary key ,c2 int ,c3 int) tablegroup = tg123456 partition by range (c1)(partition p0 values less than (10),partition p1 values less than (100),partition p2 values less than (MAXVALUE));
insert into t2 values(1,1,1),(2,2,2),(3,3,3),(10,12,13),(111,112,234);
alter tablegroup tg123456 drop partition p2;
select * from t2 order by c1;
alter tablegroup tg123456 add partition (partition p2 values less than(12345), partition p3 values less than(maxvalue));
insert into t2 values (12343,13,12), (324351,3431,23);
select * from t2 order by c1;
alter tablegroup tg123456 reorganize partition p2 into (partition p21 values less than (999), partition p22 values less than(12345));
--source mysql_test/include/check_logical_split_partition_ok.inc
select * from t2 order by c1; 
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t2;
drop table t2;
drop tablegroup tg123456;

#range with column and global index
create tablegroup tg123456 partition by range (partition p0 values less than (10),partition p1 values less than (100),partition p2 values less than (1000));
create table t2 (c1 int primary key, c2 int, c3 int) tablegroup = tg123456 partition by range(c1) (partition p0 values less than (10),partition p1 values less than (100),partition p2 values less than (1000));
create index il on t2 (c2);
#不能删除分区
--source mysql_test/include/check_all_idx_ok.inc
insert into t2 values(1,1,1),(2,2,2),(3,3,3),(10,12,13),(111,112,234);
select * from t2 order by c1; 
--error 1235
alter tablegroup tg123456 drop partition p2;
alter tablegroup tg123456 add partition (partition p3 values less than(12345), partition p4 values less than(maxvalue));
insert into t2 values (12343,13,12), (324351,3431,23);
select * from t2 order by c1;
alter tablegroup tg123456 reorganize partition p3 into (partition p21 values less than (1999), partition p22 values less than(12345));
--source mysql_test/include/check_logical_split_partition_ok.inc
select * from t2 order by c1; 
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t2;
drop table t2;
drop tablegroup tg123456;

--disable_warnings
drop table if exists t1, t2, t3;
--enable_warnings

create table t1 (c1 int primary key ,c2 int ,c3 int) partition by range (c1)(partition p0 values less than (10),partition p1 values less than (100),partition p2 values less than (1000));
create table t2 (c1 int primary key ,c2 int, c3 int) partition by list(c1) (partition p0 values in (1,2,3), partition p1 values in (4,5));
create table t3 (c1 int ,c2 int) partition by range (c1)(partition p0 values less than (10),partition p1 values less than (100),partition p2 values less than (1000));
insert into t1 values (2,1,1),(9,8,8),(12,12,12),(16,16,16),(111,111,111),(555,555,111);
#只支持一个分区的分裂
--error 1235
alter table t1 reorganize partition p0,p1 into (partition p1 values less than (100));
#分列后的分区名不可重复
--error 1517
alter table t1 reorganize partition p0 into (partition p1 values less than (10), partition p2 values less than (100));
#分裂必须有多个
--disable_result_log
--error 5599
alter table t1 reorganize partition p0 into (partition pi values less than (10));
--enable_result_log
#分裂必须有多个，并且分区前后的范围应该是一致的
--error 1520
alter table t1 reorganize partition p0 into (partition pj values less than (5),partition pi values less than (100));
#分裂后的范围必须是一致的
--error 1493,14037
alter table t1 reorganize partition p1 into (partition pi values less than (10), partition pj values less than (20));
#分裂后的最大值应该还是要保持递增的顺序
--error 1493,14037
alter table t1 reorganize partition p1 into (partition pi values less than (10), partition pj values less than (100));
#顺序不对
--error 1493,14037
alter table t1 reorganize partition p1 into (partition pi values less than (100), partition pj values less than (50));
#分区名重复
--error 1517
alter table t1 reorganize partition p1 into (partition p1 values less than (30), partition p2 values less than (100));
#分区名重复
--error 1517
alter table t1 reorganize partition p1 into (partition p1 values less than (30), partition p1 values less than (100));
#分区表必须有主键列
--error 1235
alter table t3 reorganize partition p1 into (partition p1 values less than (30), partition p5 values less than (100));
drop table t1;
drop table t2;
drop table t3;

