#owner: msy164651
#owner group: rs
#测试：非分区表转分区表，有global local index， unique index应该满足索引建包括所有的分区键，主键包含所有分区键这些限制
#同理在一个单分区的表，有global local index的情况下，也不能分裂
#非分区表转分区表
--disable_warnings
set @@recyclebin = off;
drop database if exists db;
create database db;
use db;
drop table if exists t1;
sleep 3;
drop tablegroup if exists tg490;
--enable_warnings

create table t1 (c1 int ,c2 int, c3 int ,c4 int ,c5 int, primary key(c1,c2), unique index (c3, c4) local); 
--error 1503
alter table t1 partition by hash(c1) partitions 1; 
--error 1503
alter table t1 partition by key(c1, c2) partitions 1; 
--error 1503
alter table t1 partition by key(c1, c2, c3) partitions 1; 
--error 1503
alter table t1 partition by key(c1, c2,c3,c4) partitions 1; 
drop table t1;

create table t1 (c1 int ,c2 int, c3 int ,c4 int ,c5 int, primary key(c1,c2), unique index (c3, c4));
--error 1235
alter table t1 partition by hash(c1) partitions 1;
drop table t1;

create table t1 (c1 int ,c2 int, c3 int ,c4 int ,c5 int, primary key(c1,c2));
create index il on t1(c3) local;
--source mysql_test/include/check_all_idx_ok.inc
alter table t1 partition by hash(c1) partitions 1; 
drop table t1; 
#单分区分裂 建索引，在分裂失败
create table t1 (c1 int, c2 int, c3 int, primary key (c1,c3));
alter table t1 partition by range columns(c1,c3) (partition p0 values less than (maxvalue, maxvalue));
--error 1503
create unique index il on t1(c2) local;
create unique index il on t1(c2);
--source mysql_test/include/check_all_idx_ok.inc
alter table t1 reorganize partition p0 into (partition p0 values less than (1,1), partition p1 values less than(maxvalue, maxvalue));
drop table t1; 
 
create tablegroup tg490;
create table t1 (c1 int ,c2 int, c3 int ,c4 int ,c5 int, primary key(c1,c2), unique index (c3, c4) local) tablegroup = tg490;
--error 1503
alter table t1 partition by hash(c1) partitions 1;

drop table t1; 
create table t1 (c1 int ,c2 int, c3 int ,c4 int ,c5 int, primary key(c1,c2)) tablegroup = tg490;
alter table t1 partition by hash(c1) partitions 1;
--error 1503
create unique index il on t1(c2) local;
 
