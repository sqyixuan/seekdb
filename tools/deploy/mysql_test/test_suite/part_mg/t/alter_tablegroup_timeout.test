#owner: msy164651
#owner group: rs
#description: alter tablegroup 超时测试
#case 1 :建tablegroup，建200张表

--disable_warnings
set @@recyclebin = off;
drop database if exists db;
create database db;
use db;
drop tablegroup if exists tgmsy11;
--enable_warnings

set @@session.ob_query_timeout=1000000000;
create tablegroup tgmsy11;
let $cnt=3;
while($cnt) 
{
  eval create table t_$cnt (c1 int primary key, c2 int) tablegroup = tgmsy11;
  dec $cnt;
}

#分裂hash
#给所有的table指定分区键
let $cnt=3;
while($cnt) 
{

  eval alter table t_$cnt partition by hash(c1) partitions 1;
  dec $cnt;
}

alter tablegroup tgmsy11 partition by hash partitions 500;
let $cnt=3;
while($cnt) 
{

  eval drop table t_$cnt;
  dec $cnt;
}
drop tablegroup tgmsy11;


