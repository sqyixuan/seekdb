set @@recyclebin = off;
drop database if exists db;
create database db;
use db;
drop tablegroup if exists tgmsy11;
set @@session.ob_query_timeout=1000000000;
create tablegroup tgmsy11;
create table t_3 (c1 int primary key, c2 int) tablegroup = tgmsy11;
create table t_2 (c1 int primary key, c2 int) tablegroup = tgmsy11;
create table t_1 (c1 int primary key, c2 int) tablegroup = tgmsy11;
alter table t_3 partition by hash(c1) partitions 1;
alter table t_2 partition by hash(c1) partitions 1;
alter table t_1 partition by hash(c1) partitions 1;
alter tablegroup tgmsy11 partition by hash partitions 500;
drop table t_3;
drop table t_2;
drop table t_1;
drop tablegroup tgmsy11;
