drop database if exists db;
create database db;
use db;
drop table if exists t1, t2, t3;
create table t1 (c1 int primary key ,c2 int ,c3 int) partition by range (c1)(partition p0 values less than (10),partition p1 values less than (100),partition p2 values less than (1000));
create table t2 (c1 int primary key ,c2 int, c3 int) partition by list(c1) (partition p0 values in (1,2,3), partition p1 values in (4,5));
create table t3 (c1 int ,c2 int) partition by range (c1)(partition p0 values less than (10),partition p1 values less than (100),partition p2 values less than (1000));
insert into t1 values (2,1,1),(9,8,8),(12,12,12),(16,16,16),(111,111,111),(555,555,111);
alter table t1 reorganize partition p0,p1 into (partition p1 values less than (100));
