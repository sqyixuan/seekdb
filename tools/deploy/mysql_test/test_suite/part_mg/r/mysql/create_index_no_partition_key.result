set @@recyclebin = off;
drop database if exists db;
create database db;
use db;
drop table if exists t1, t2, t3, t4,t5;
create table t1 (c1 int,c2 int ,c3 int) partition by range(c1) (partition p0 values less than (10), partition p1 values less than (100),partition p2 values less than (1000), partition p3 values less than (maxvalue));
insert into t1 values (2,1,1),(9,8,8),(12,12,12),(16,16,16),(111,111,111),(555,555,111);
create index il on t1(c1);
create index il1 on t1(c2);
create unique index il2 on t1(c1,c2);
create unique index il3 on t1(c2) local;
ERROR HY000: A UNIQUE INDEX must include all columns in the table's partitioning function
select * from t1 order by c1;
c1	c2	c3
2	1	1
9	8	8
12	12	12
16	16	16
111	111	111
555	555	111
alter table t1 reorganize partition p3 into(partition p3 values less than(19999999), partition p4 values less than(maxvalue));
ERROR HY000: reorganize partition not allowed
drop table t1;
create table t1 (c1 int,c2 int ,c3 int, key il (c2)) partition by range(c1) (partition p0 values less than (10), partition p1 values less than (100),partition p2 values less than (1000), partition p3 values less than (maxvalue));
create table t2 (c1 int,c2 int ,c3 int, key il (c2) local) partition by list(c1)(partition p0 values in(default));
create table t3 (c1 int,c2 int ,c3 int, key il (c2, c1) local) partition by list(c1)(partition p0 values in(default));
create table t4 (c1 int,c2 int ,c3 int, key il (c2, c1)) partition by list(c1)(partition p0 values in(default));
create table t5 (c1 int,c2 int ,c3 int);
alter table t5 partition by list(c1)(partition p0 values in(default));
ERROR HY000: partitioned table not allowed
drop table t1, t2, t3,t4,t5;
