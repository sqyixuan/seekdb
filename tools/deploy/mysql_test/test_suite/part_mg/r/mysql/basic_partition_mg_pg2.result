set @@recyclebin = off;
drop database if exists db;
create database db;
use db;
drop table if exists t1, t2, t3;
drop tablegroup if exists tg;
create tablegroup tg binding true;
create table t1 (c1 int primary key ,c2 int ,c3 int) tablegroup = 'tg';
insert into t1 values (2,1,1),(9,8,8),(12,12,12),(16,16,16),(111,111,111),(555,555,111);
alter table t1 partition by list (c1) (partition p1 values in (default));
alter tablegroup tg partition by list (partition p0 values in (1,2,3,4,5,6,7,8), partition p1 values in (9,12,16), partition p2 values in (default));
alter tablegroup tg drop partition p2;
alter tablegroup tg add partition (partition p2 values in (111), partition p3 values in (555));
alter tablegroup tg reorganize partition p0 into (partition p0 values in (1,2,3,4), partition p01 values in (5,6,7,8));
show create table t1;
Table	Create Table
t1	CREATE TABLE `t1` (
  `c1` int(11) NOT NULL,
  `c2` int(11) DEFAULT NULL,
  `c3` int(11) DEFAULT NULL,
  PRIMARY KEY (`c1`)
) DEFAULT CHARSET = utf8mb4 COMPRESSION = 'lz4_1.0' REPLICA_NUM = NUM BLOCK_SIZE = SIZE USE_BLOOM_FILTER = FALSE TABLET_SIZE = SIZE PCTFREE = 10 TABLEGROUP = 'tg'
 partition by list(c1)
(partition p0 values in (1,2,3,4),
partition p01 values in (5,6,7,8),
partition p1 values in (9,12,16),
partition p2 values in (111),
partition p3 values in (555))
drop table t1;
drop tablegroup tg;
