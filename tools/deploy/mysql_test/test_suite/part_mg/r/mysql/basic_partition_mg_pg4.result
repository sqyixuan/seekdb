  `c3` int(11) NOT NULL,
  `c4` int(11) DEFAULT NULL,
  PRIMARY KEY (`c1`, `c2`, `c3`)
) DEFAULT CHARSET = utf8mb4 COMPRESSION = 'lz4_1.0' REPLICA_NUM = NUM BLOCK_SIZE = SIZE USE_BLOOM_FILTER = FALSE TABLET_SIZE = SIZE PCTFREE = 10 TABLEGROUP = 'tg'
 partition by hash(c1)
