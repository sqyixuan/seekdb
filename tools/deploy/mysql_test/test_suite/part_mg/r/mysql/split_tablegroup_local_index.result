set @@recyclebin = off;
drop database if exists db;
create database db;
use db;
drop table if exists t1, t2, t3;
drop tablegroup if exists tgmsy;
create tablegroup tgmsy;
create table t1 (c1 int primary key ,c2 int ,c3 int) tablegroup = 'tgmsy';
create index il on t1(c2) local;
insert into t1 values (2,1,1);
insert into t1 values(9,8,8);
insert into t1 values(12,12,12);
insert into t1 values(16,16,16);
insert into t1 values(111,111,111);
insert into t1 values(555,555,111);
alter table t1 add column c4 int ;
alter table t1 partition by range (c1) (partition p0 values less than(maxvalue));
ERROR 0A000: can't modify table partition in tablegroup not supported
alter tablegroup tgmsy partition by range (partition p0 values less than (10),partition p1 values less than (100),partition p2 values less than (1000), partition p3 values less than (maxvalue));
ERROR 0A000: Not supported feature or function
drop table t1;
drop tablegroup tgmsy;
