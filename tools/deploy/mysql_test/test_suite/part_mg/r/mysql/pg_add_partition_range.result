set @@recyclebin = off;
drop database if exists db;
create database db;
use db;
drop table if exists t1, t2, t3;
drop tablegroup if exists tgmsy;
drop tablegroup if exists tgmsy2;
drop tablegroup if exists tgmsy3;
create tablegroup tgmsy binding true partition by range (partition p0 values less than (10),partition p1 values less than (100),partition p2 values less than (1000));
create table t1 (c1 int primary key ,c2 int ,c3 int) tablegroup ='tgmsy' partition by range (c1) (partition p0 values less than (10),partition p1 values less than (100),partition p2 values less than (1000));
create tablegroup tgmsy2 binding true partition by range  (partition p0 values less than (10),partition p1 values less than (3436),partition p2 values less than (maxvalue));
create tablegroup tgmsy3 binding true partition by range columns 2 (partition p0 values less than (3,4),partition p1 values less than(12,345),partition p2 values less than (324543,3435));
create table t3 (c1 int ,c2 int ,c3 int, primary key (c1,c2)) tablegroup ='tgmsy3' partition by range columns (c1,c2) (partition p0 values less than (3,4),partition p1 values less than(12,345),partition p2 values less than (324543,3435));
