drop database if exists db;
create database db;
use db;
drop table if exists t1;
create table t1(c1 int, c2 int, primary key(c1,c2)) partition by range(c1) subpartition by hash(c2) subpartitions 3 (partition p0 values less than(10), partition p1 values less than(MAXVALUE));
