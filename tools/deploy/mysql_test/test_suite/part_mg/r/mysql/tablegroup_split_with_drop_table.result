set @@recyclebin = off;
drop database if exists db;
create database db;
use db;
drop table if exists t1, t2;
drop tablegroup if exists tgtest;
drop tablegroup if exists tgtest1;
drop tablegroup if exists test2_tablegroup;
set @@recyclebin = on;
create tablegroup tgtest;
create table t1 (c1 int primary key, c2 int) tablegroup = tgtest;
create table t2 (c1 int primary key, c2 int) tablegroup = tgtest;
alter table t1 partition by list columns(c1) (partition p0 values in (default));
alter table t2 partition by list columns(c1) (partition p0 values in (default));
alter tablegroup tgtest partition by list columns 1 (partition p0 values in (1,2,3,4), partition p1 values in(default));
drop table t2;
create table t2 (c1 int primary key, c2 int) tablegroup = tgtest partition by list columns(c1)  (partition p0 values in (1,2,3,4), partition p1 values in(default));
alter tablegroup tgtest reorganize partition p1 into(partition p1 values in (7,8,9), partition p2 values in (default));
drop table t1;
create table t1 (c1 int primary key, c2 int) partition by list columns(c1) (partition p0 values in (default));
alter table t1 reorganize partition p0 into(partition p1 values in (7,8,9), partition p2 values in (default));
drop table t1;
set @@recyclebin = on;
drop table t2;
drop tablegroup if exists tgtest;
