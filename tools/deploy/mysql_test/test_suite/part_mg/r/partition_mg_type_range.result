drop database if exists db1;
create database db1;
use db1;
create table t_tinyint(c1 tinyint(1) primary key) partition by range(c1)
(partition p0 values less than (-2500),
partition p1 values less than (-129),
partition p2 values less than (-128),
partition p3 values less than (0),
partition p4 values less than (127),
partition p5 values less than (128));
alter table t_tinyint add partition (partition p6 values less than(2500));
alter table t_tinyint drop partition (p6);
alter table t_tinyint add partition (partition p6 values less than(2500), partition p7 values less than (MAXVALUE));
alter table t_tinyint drop partition (p6);
alter table t_tinyint reorganize partition p7 into (partition p6 values less than(2500), partition p7 values less than (MAXVALUE));
