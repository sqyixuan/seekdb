drop database if exists db;
create database db;
use db;
create table t1(c1 int, c2 int, primary key(c1,c2)) partition by range(c1) subpartition by hash(c2) subpartitions 3 (partition p0 values less than(10));
alter table t1 add partition (partition p1 values less than(20));
alter table t1 add partition (partition p2 values less than(30));
insert into t1 values(15,1);
insert into t1 values(25,1);
insert into t1 values(25,2);
insert into t1 values(25,3);
explain select *  from t1;
