drop database if exists db;
create database db;
use db;
>> test for level-one
create table t1(c1 int, c2 int, primary key(c1,c2)) partition by range(c1) (partition p0 values less than(10));
alter table t1 add partition (partition p1 values less than(20));
alter table t1 drop partition (p1);
alter table t1 add partition (partition p1 values less than(20));
>> t1 partition_id from schema
select group_concat(distinct part_id) from oceanbase.__all_virtual_part where mock_filter;
group_concat(distinct part_id)
0,2
create table t2 like t1;
>> t2 partition_id from partition_table && schema
select group_concat(distinct partition_id) from oceanbase.__all_virtual_meta_table where mock_filter;
group_concat(distinct partition_id)
0,1
select group_concat(distinct part_id) from oceanbase.__all_virtual_part where mock_filter;
group_concat(distinct part_id)
0,1
truncate table t1;
>> t1(after truncate) partition_id from partition_table && schema
select group_concat(distinct partition_id) from oceanbase.__all_virtual_meta_table where mock_filter;
group_concat(distinct partition_id)
0,1
select group_concat(distinct part_id) from oceanbase.__all_virtual_part where mock_filter;
group_concat(distinct part_id)
0,1
drop table t1;
drop table t2;
>> test for level-two
create table t1(c1 int, c2 int, primary key(c1,c2)) partition by range(c1) subpartition by hash(c2) subpartitions 3 (partition p0 values less than(10));
alter table t1 add partition (partition p1 values less than(20));
alter table t1 drop partition (p1);
alter table t1 add partition (partition p1 values less than(20));
>> t1 partition_id(level_one) from schema
select group_concat(distinct part_id) from oceanbase.__all_virtual_part where mock_filter;
group_concat(distinct part_id)
0,2
create table t2 like t1;
>> t2 partition_id(level_one) from partition_table && schema
select group_concat(distinct partition_id >> 32 & 0x0FFFFFFF) from oceanbase.__all_virtual_meta_table where mock_filter;
group_concat(distinct partition_id >> 32 & 0x0FFFFFFF)
0,1
select group_concat(distinct part_id) from oceanbase.__all_virtual_part where mock_filter;
group_concat(distinct part_id)
0,1
truncate table t1;
>> t1(after truncate) partition_id(level-one) from meta && schema
select group_concat(distinct partition_id >> 32 & 0x0FFFFFFF) from oceanbase.__all_virtual_meta_table where mock_filter;
group_concat(distinct partition_id >> 32 & 0x0FFFFFFF)
0,1
select group_concat(distinct part_id) from oceanbase.__all_virtual_part where mock_filter;
group_concat(distinct part_id)
0,1
drop database if exists db;
