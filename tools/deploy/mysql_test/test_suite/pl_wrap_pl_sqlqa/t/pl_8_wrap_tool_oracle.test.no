#owner: haohao.hao
#owner group: PL/SQL
#description: pl wrap 435bp1
#tags: pl
#author:whh01047778

--result_format 4
connection default;

--disable_warnings
--error 0,600
drop user user_whhtest1 cascade;
create user user_whhtest1 IDENTIFIED BY 123;
grant all on *.* to user_whhtest1 WITH GRANT OPTION;
grant all privileges to user_whhtest1;
grant dba,resource,connect to user_whhtest1;
--enable_warnings

--source mysql_test/include/check_schema_sync.inc
connect (conn1,$OBMYSQL_MS0,user_whhtest1@oracle,123,user_whhtest1,$OBMYSQL_PORT);
connection conn1;

set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;
ALTER SESSION SET NLS_DATE_FORMAT='YYYY-MM-DD HH24:MI:SS';
ALTER SESSION SET NLS_TIMESTAMP_FORMAT='YYYY-MM-DD HH24:MI:SS.FF';
ALTER SESSION SET NLS_TIMESTAMP_TZ_FORMAT='YYYY-MM-DD HH24:MI:SS.FF TZR TZD';

--echo #-----------------------------------------------------------------------------
--echo # 测试场景：2.1、WRAP CLI 工具 测试
--echo #-----------------------------------------------------------------------------

--echo ### WRAP 工具加密 before_case 文件夹下 obmysqltest 用例到 after_case 文件夹下
--exec cd ..
--exec sh pl_warp_before_case.sh


--echo ### WRAP 工具加密 warp_cli_tool/input_file 文件夹下加密用例到 output_file 文件夹下
--exec cd ../warp_cli_tool/
--exec sh pl_warp_input.sh



connection default;
--disable_warnings
--error 0,600
drop user user_whhtest1 cascade;
--enable_warnings

purge recyclebin;
