delimiter ;/
--error 0,942
drop table s_log;
--error 0,942
drop table s_table;

create table s_log(filename varchar2(500));
insert into s_log values('MCBBJ_00_SP_INFO_20080128.txt');
insert into s_log values('MCBBJ_01_SP_INFO_20080128.txt');


CREATE TABLE s_table ("SERV_TYPE" VARCHAR2(10), "SP_CODE" VARCHAR2(20), "SP_NAME" VARCHAR2(50), "SP_TYPE" VARCHAR2(2), "SERV_CODE" VARCHAR2(24), "PROV_CODE" VARCHAR2(4), "BAL_PROV" VARCHAR2(4), "DEV_CODE" VARCHAR2(15), "VALID_DATE" DATE, "EXPIRE_DATE" DATE, "DESCRIPTION" VARCHAR2(20), "SOURFILENAME" VARCHAR2(30), "ERRORCODE" VARCHAR2(8), "DEVICETYPE" NUMBER(4,0), "PROCESSTIME" DATE, "BILLINGCYCLE" NUMBER(8,0));
insert into s_table(sourfilename,serv_type) values('MCBBJ____SP_INFO_20080128.txt', '001102');
insert into s_table(sourfilename,serv_type) values('MCBBJ____SP_INFO_20080128.txt', '008002');
insert into s_table(sourfilename,serv_type) values('MCBBJ____SP_INFO_20080128.txt', '000204');

delimiter /;

declare
  v_filename     VARCHAR2(40);
  v_date     VARCHAR2(40);
  v_lastfilename_0 VARCHAR2(40);
  v_lastfilename_1 VARCHAR2(40);
BEGIN
  v_date     := '20080128';
  v_filename   := 'MCBBJ____SP_INFO_20080128.txt';

  SELECT MAX(filename)
    INTO v_lastfilename_0
    FROM s_log
   WHERE filename LIKE 'MCBBJ_00_SP_INFO%';
  SELECT MAX(filename)
    INTO v_lastfilename_1
    FROM s_log
   WHERE filename LIKE 'MCBBJ_01_SP_INFO%';
  dbms_output.put_line('游标循环上.....');
  FOR c1 IN --今天数据与上次处理数据对比
   (SELECT serv_type,
           sp_code,
           serv_code,
           sp_name,
           prov_code,
           dev_code,
           valid_date,
           expire_date
      FROM s_table
     WHERE sourfilename LIKE v_filename
    MINUS
    SELECT serv_type,
           sp_code,
           serv_code,
           sp_name,
           prov_code,
           dev_code,
           valid_date,
           expire_date
      FROM s_table
     WHERE sourfilename = v_lastfilename_0
        OR sourfilename = v_lastfilename_1)
  LOOP
    dbms_output.put_line('loop执行了');
  end loop;
end AP_SPDATALOAD_OLD;
/

select println() from dual;
/

