--echo #### 
--error 0,942
drop table yd;
create table yd(id number,name varchar2(20));

delimiter /;

CREATE OR REPLACE PACKAGE char_pkg AS
  SUBTYPE mysub IS varchar2(40) not null;
  PROCEDURE p1 (name1 mysub,name2 in out mysub);
  function f1(name mysub)return mysub;
END;
/

CREATE OR REPLACE PACKAGE BODY char_pkg AS
  PROCEDURE p1 (name1 mysub,name2 in out mysub) IS
  BEGIN
    DBMS_OUTPUT.PUT_LINE (name1);
    DBMS_OUTPUT.PUT_LINE (name2);
  END;
  function f1(name mysub)return mysub IS
  BEGIN
    return name;
  END;
END;
/

declare
  v yd%rowtype;
  CURSOR c IS SELECT name FROM yd;
  friend c%ROWTYPE;
begin
   v.name:='as';
   friend.name:='lisi';
   char_pkg.p1(v.name,v.name);
end;
/

select println() from dual;
/

drop package char_pkg;
/
drop table yd;
/

