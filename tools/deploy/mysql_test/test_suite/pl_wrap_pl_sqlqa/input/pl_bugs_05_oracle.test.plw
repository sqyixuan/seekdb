DECLARE
  SUBTYPE s1 IS VARCHAR2(1000);
  SUBTYPE s2 IS VARCHAR2(1000);
  PROCEDURE p1(p1 s1) IS
  BEGIN
    DBMS_OUTPUT.PUT_LINE('CALL s1(p1 s1);');
  END;
  PROCEDURE p2(p2 s2) IS
  BEGIN
    DBMS_OUTPUT.PUT_LINE('CALL s2(p2 s2);');
  END;
BEGIN
  p1(p1=>'123');
END;
