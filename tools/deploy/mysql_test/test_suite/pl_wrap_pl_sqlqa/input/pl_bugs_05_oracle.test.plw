declare
TYPE sum_multiples IS TABLE OF PLS_INTEGER INDEX BY PLS_INTEGER;
FUNCTION f1 return sum_multiples as
s sum_multiples;
begin
s(1) := 1;
return s;
end f1;
begin
null;
end;
/


declare
TYPE sum_multiples IS TABLE OF PLS_INTEGER INDEX BY PLS_INTEGER;
x int := 0;
FUNCTION f1 return sum_multiples as
s sum_multiples;
begin
s(1) := 1;
return s;
end f1;
begin
x := f1().count();
dbms_output.put_line(x);
end;
/

declare
TYPE sum_multiples IS TABLE OF PLS_INTEGER INDEX BY PLS_INTEGER;
x sum_multiples;
FUNCTION f1 return sum_multiples as
s sum_multiples;
begin
s(1) := 1;
return s;
end f1;
begin
x := f1();
dbms_output.put_line(x.count);
end;
/
