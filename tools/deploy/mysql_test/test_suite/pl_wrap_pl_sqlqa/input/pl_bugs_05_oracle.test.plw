DECLARE
  x dbms_debug.runtime_info;
BEGIN
  pack.proc(x, 1024);
  x := pack.func(x, 1025);
END;
/
DECLARE
  x dbms_debug.runtime_info;
  PROCEDURE proc(x dbms_debug.runtime_info, y dbms_debug.default_timeout%type) IS
  BEGIN
    DBMS_OUTPUT.PUT_LINE('y = ' || y);
  END;
  FUNCTION func(x dbms_debug.runtime_info, y dbms_debug.default_timeout%type) RETURN dbms_debug.runtime_info IS
  BEGIN
    DBMS_OUTPUT.PUT_LINE('y = ' || y);
    RETURN x;
  END;
BEGIN
  proc(x, 1026);
  x := func(x, 1027);
END;
/
