## 
create table TBL_USERS
(
PROVINCE CHAR(2),
MERCHCODE CHAR(8),
OPERID CHAR(4),
EMPLOYEE CHAR(9),
OPER_CODE CHAR(20) not null,
GROUPCODE NUMBER(2),
OPER_NAME CHAR(20),
OPER_LEVEL CHAR(1),
USR_FLAG NUMBER(1),
ONLINE_FLAG NUMBER(1),
BIND_FLAG NUMBER(1),
PKI_FLAG NUMBER(1),
UKEY_FLAG NUMBER(1),
id_type char(2),
id_code char(20),
GENDER CHAR(1),
TELNO CHAR(20),
CREATE_DATE CHAR(8),
PINDATE CHAR(8),
OFFDATE CHAR(8),
CHANGE_DATE CHAR(8),
LGNDATE CHAR(8),
LGNTIME CHAR(8),
EXP_PWD CHAR(8),
PASSWD CHAR(32),
PWD_FLAG NUMBER(1),
PWD_ERRCNT NUMBER(2),
LGN_ERRCNT NUMBER(4),
PASSWD1 CHAR(32),
PASSWD2 CHAR(32),
PASSWD3 CHAR(32),
PASSWD4 CHAR(32),
PASSWD5 CHAR(32),
primary key (PROVINCE, OPER_CODE)
)
;

insert into tbl_users (PROVINCE, MERCHCODE, OPERID, EMPLOYEE, OPER_CODE, GROUPCODE, OPER_NAME, OPER_LEVEL, USR_FLAG, ONLINE_FLAG, BIND_FLAG, PKI_FLAG, UKEY_FLAG, ID_TYPE, ID_CODE, GENDER, TELNO, CREATE_DATE, PINDATE, OFFDATE, CHANGE_DATE, LGNDATE, LGNTIME, EXP_PWD, PASSWD, PWD_FLAG, PWD_ERRCNT, LGN_ERRCNT, PASSWD1, PASSWD2, PASSWD3, PASSWD4, PASSWD5)
values ('21', '30250867', '', '', 'bhjqdh', 30, '全东海', '0', 0, 1, 0, 0, 0, null, null, 'M', '', '20160612', '20180508', '20180508', '20160612', '20200103', '17192204', '20180806', '603736313033323D3C3F3E39383B3A25', 0, 0, 5, '6033323534373639383B3A3D3C3F3E21', '', '', '603031363734353A3B38393E3F3C3D22', '603736313033323D3C3F3E39383B3A25');

delimiter /;


declare
str varchar(2000);
begin
for cr in (
SELECT C.CONSTRAINT_NAME,lower(CC.COLUMN_NAME) as COLUMN_NAME,
CC.POSITION,C.OWNER,C.TABLE_NAME,ccc.data_type
FROM ALL_CONSTRAINTS C, ALL_CONS_COLUMNS CC, USER_TAB_COLUMNS ccc
WHERE C.OWNER = CC.OWNER
AND C.CONSTRAINT_TYPE = 'P'
AND C.CONSTRAINT_NAME = CC.CONSTRAINT_NAME
AND C.TABLE_NAME = CC.TABLE_NAME
and CC.table_name = ccc.table_name
and cc.COLUMN_NAME = ccc.COLUMN_NAME
and c.TABLE_NAME = upper('tbl_users')
ORDER BY 4, 1, 3
) loop
if cr.data_type in ('CHAR') then
null;
elsif cr.data_type in ('NUMBER') then
null;
end if;
end loop;

for cr in (select lower(column_name) as column_name,data_type,data_length from USER_TAB_COLUMNS
where table_name = upper('tbl_users')
order by column_id
) loop
if cr.data_type in ('CHAR') then
null;
elsif cr.data_type in ('NUMBER') then
null;
end if;
end loop;
end;
/

