--echo #### 
--echo #### resolve_symbol时支持系统视图

DECLARE
  x USER_PROCEDURES%ROWTYPE;
BEGIN
  x.OBJECT_NAME := 'x';
  DBMS_OUTPUT.PUT_LINE('x');
END;
/

--echo #### 作为routine的参数
CREATE OR REPLACE PROCEDURE proc(x USER_PROCEDURES%ROWTYPE)
IS
BEGIN
  DBMS_OUTPUT.PUT_LINE(x.object_name);
END;
/
DECLARE
  x USER_PROCEDURES%ROWTYPE;
BEGIN
  x.object_name := 'TEST';
  proc(x);
END;
/

--echo #### 自定义类型中包含系统视图的访问
DECLARE
  TYPE TY IS TABLE OF USER_PROCEDURES.OBJECT_NAME%TYPE;
  x TY := ty('OBJECT_NAME');
BEGIN
  DBMS_OUTPUT.PUT_LINE('x = ' || x(1));
END;
/

--echo #### 作为package全局变量的类型
CREATE OR REPLACE PACKAGE pack IS
  x USER_PROCEDURES%rowtype;
END;
/
BEGIN
  pack.x.object_name := '123';
  DBMS_OUTPUT.PUT_LINE('x.object_name = ' || pack.x.object_name);
END;
/

--echo #### 作为package中routine的参数类型
CREATE OR REPLACE PACKAGE pack IS
  PROCEDURE PROC(x USER_PROCEDURES%rowtype);
END;
/
CREATE OR REPLACE PACKAGE BODY pack IS
  PROCEDURE PROC(x USER_PROCEDURES%rowtype) IS
  BEGIN
    DBMS_OUTPUT.PUT_LINE('x.object_name = ' || x.object_name);
  END;
END;
/
DECLARE
  x USER_PROCEDURES%rowtype;
BEGIN
  x.object_name := 'AAAAA';
  pack.proc(x);
END;
/

--echo #### Aone
DECLARE
  TYPE INDEX_TYPE IS TABLE OF USER_INDEXES.INDEX_NAME%TYPE;
  INDEX_NAME_REC INDEX_TYPE := INDEX_TYPE('BBBBBB');
BEGIN
  DBMS_OUTPUT.PUT_LINE(INDEX_NAME_REC(1));
END;
/

