DECLARE
  TYPE FQGUO_REC_TYPE IS RECORD(C1 NUMBER, C2 NUMBER);
  TYPE FQGUO_REF_CURSOR_TYPE_STR IS REF CURSOR RETURN FQGUO_REC_TYPE;
  FQGUO_REF_CUR_STR_VAR FQGUO_REF_CURSOR_TYPE_STR;
  TYPE FQGUO_REF_CURSOR_TYPE_STR2 IS REF CURSOR RETURN FQGUO_REF_CUR_STR_VAR%ROWTYPE;
  FQGUO_REF_CUR_STR_VAR_2 FQGUO_REF_CURSOR_TYPE_STR2;
  X NUMBER;
  Y NUMBER;
BEGIN
  OPEN FQGUO_REF_CUR_STR_VAR FOR SELECT * FROM T;
  FETCH FQGUO_REF_CUR_STR_VAR INTO X, Y;
  CLOSE FQGUO_REF_CUR_STR_VAR;
  DBMS_OUTPUT.PUT_LINE('X = ' || X || ' Y = ' || Y);
  OPEN FQGUO_REF_CUR_STR_VAR_2 FOR SELECT * FROM T;
  FETCH FQGUO_REF_CUR_STR_VAR_2 INTO X, Y;
  CLOSE FQGUO_REF_CUR_STR_VAR_2;
  DBMS_OUTPUT.PUT_LINE('X = ' || X || ' Y = ' || Y);
END;
/
DECLARE
  CURSOR C1 RETURN T%ROWTYPE IS SELECT * FROM T;
  TYPE FQGUO_REF_CURSOR_TYPE_STR IS REF CURSOR RETURN C1%ROWTYPE;
  FQGUO_REF_CUR_STR_VAR FQGUO_REF_CURSOR_TYPE_STR;
  X NUMBER;
  Y NUMBER;
BEGIN
  OPEN FQGUO_REF_CUR_STR_VAR FOR SELECT * FROM T;
  FETCH FQGUO_REF_CUR_STR_VAR INTO X, Y;
  CLOSE FQGUO_REF_CUR_STR_VAR;
  DBMS_OUTPUT.PUT_LINE('X = ' || X || ' Y = ' || Y);
END;
/
DROP TABLE T;
/
