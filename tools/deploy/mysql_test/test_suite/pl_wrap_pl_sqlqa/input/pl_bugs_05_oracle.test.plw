--echo ## test end

--error 0, 942
drop table W0CASE;
CREATE TABLE W0CASE (W0_TEST0 VARCHAR2(100));

delimiter /;

--echo # test case when with same condition
DECLARE
    N VARCHAR2(10) := 'd@iqdoqdj';
BEGIN
    CASE
        WHEN N LIKE '%@%' THEN INSERT INTO W0CASE VALUES('A1');dbms_output.put_line('case1');
        WHEN N LIKE '%@%' THEN INSERT INTO W0CASE VALUES('A2');dbms_output.put_line('case2');
        WHEN N LIKE '%@%' THEN INSERT INTO W0CASE VALUES('A3');dbms_output.put_line('case3');
    END CASE;
END;
/

--echo #test case when with different condition
DECLARE
    N VARCHAR2(10) := 'd@iqdoqdj';
BEGIN
    CASE
        WHEN N LIKE '%@%' THEN INSERT INTO W0CASE VALUES('A1'); dbms_output.put_line('case1');
        WHEN N LIKE '%#%' THEN INSERT INTO W0CASE VALUES('A2'); dbms_output.put_line('case2');
    END CASE;
END;
/

--echo #test result with null
BEGIN
    CASE
        WHEN NOT 'Z' < 'A' AND NOT NULL THEN INSERT INTO W0CASE VALUES('B1'); dbms_output.put_line('b1');
        ELSE INSERT INTO W0CASE VALUES('B2');dbms_output.put_line('b2');
    END CASE;
END;
/

--echo #test result with null
BEGIN
    CASE
        WHEN NOT NULL THEN INSERT INTO W0CASE VALUES('B1'); dbms_output.put_line('b1');
        ELSE INSERT INTO W0CASE VALUES('B2');dbms_output.put_line('b2');
    END CASE;
END;
/

select * from W0CASE;
/

