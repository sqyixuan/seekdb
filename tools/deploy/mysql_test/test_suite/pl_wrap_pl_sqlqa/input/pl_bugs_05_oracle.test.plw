CREATE OR REPLACE TRIGGER tri_1 BEFORE UPDATE OR INSERT OR DELETE ON test1
  REFERENCING NEW AS new_1 OLD AS old_1 FOR EACH ROW WHEN (new_1.f1 IS NOT NULL)
BEGIN
  :new_1.f1:=utl_raw.cast_to_raw('test-test');
  INSERT INTO test2 VALUES(:new_1.f1);
  INSERT INTO test2 VALUES(:old_1.f1);
END;
