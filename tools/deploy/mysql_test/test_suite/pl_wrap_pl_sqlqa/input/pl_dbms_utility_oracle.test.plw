# 
# some package routine is invoker right even the package is definer right
# such as dbms_utility's name_resolve. 

--error 0, 942
drop table c_1; /
create table c_1 (a int, b int);
/

declare
v_schema varchar2(200);
v_part1 varchar2(200);
v_part2 varchar2(200);
v_dblink varchar2(200);
v_part1_type number;
v_object_number number;
begin
dbms_utility.name_resolve('c_1',0,v_schema,v_part1,v_part2,v_dblink,v_part1_type,v_object_number);
dbms_output.put_line('v_schema:'||v_schema);
dbms_output.put_line(' v_part1:'||v_part1);
dbms_output.put_line(' v_part2:'||v_part2);
dbms_output.put_line(' v_dblink:'||v_dblink);
dbms_output.put_line(' v_part1_type:'||v_part1_type);
dbms_output.put_line(' v_object_number:'||regexp_replace(v_object_number, '\d', '#'));
end;
/

select println() from dual;
/

