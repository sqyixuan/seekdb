ERROR 42000: internal error code, arguments: -5555, Incorrect number of arguments

declare
  sqls dbms_sql.varchar2s;
  res dbms_sql.varchar2s;
  c number;
  r number;
begin
  sqls(1) := 'create or replace package pkg as end;';
  res := dbms_ddl.wrap(ddl=>sqls, lb=>1, ub=>sqls.count);
  c := dbms_sql.open_cursor;
  dbms_output.put_line(sqls.count);
  dbms_sql.parse(c, res, 1, sqls.count, false, dbms_sql.native);
  r := dbms_sql.execute(c);
  dbms_sql.close_cursor(c);
end;
$

drop package pkg;
drop package pkg1;
drop package pkg2;
drop package pkg3;
drop package pkg4;
drop package pkg5;
drop package pkg6;
drop package pkg7;
drop package pkg8;

create or replace procedure pro_test(ddl varchar2,lb PLS_INTEGER,ub PLS_INTEGER) is
  sqls dbms_sql.varchar2s;
  res dbms_sql.varchar2s;
  c number;
  r number;
begin
  sqls(1) := ddl;
  res := dbms_ddl.wrap(sqls, lb=>lb, ub=>ub);
  c := dbms_sql.open_cursor;
  dbms_sql.parse(c, res, 1, sqls.count, false, dbms_sql.native);
  r := dbms_sql.execute(c);
  dbms_sql.close_cursor(c);
end;
$

