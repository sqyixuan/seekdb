declare
  res varchar2(5000);
begin
res := dbms_ddl.wrap(
'create or replace function f0(a in out tb) return int is'      || chr(10) ||
'begin'      || chr(10) ||
'a.extend();'      || chr(10) ||
'return a.count;'      || chr(10) ||
'end;');
EXECUTE IMMEDIATE res;
res := dbms_ddl.wrap(
'create or replace package pkg1 as'      || chr(10) ||
'a tb:=tb(1);'      || chr(10) ||
'b int:=f0(a);'      || chr(10) ||
'function f1 return int parallel_enable;'      || chr(10) ||
'procedure p1;'      || chr(10) ||
'end;');
EXECUTE IMMEDIATE res;
res := dbms_ddl.wrap(
'create or replace package body pkg1 as'      || chr(10) ||
'function f1 return int parallel_enable is'      || chr(10) ||
'begin'      || chr(10) ||
'return a.count;'      || chr(10) ||
'end;'      || chr(10) ||
'procedure p1 is'      || chr(10) ||
'begin'      || chr(10) ||
'for i in 1..10 loop'      || chr(10) ||
'a.extend();'      || chr(10) ||
'end loop;'      || chr(10) ||
'end;'      || chr(10) ||
'end;');
  EXECUTE IMMEDIATE res;
end;
$

