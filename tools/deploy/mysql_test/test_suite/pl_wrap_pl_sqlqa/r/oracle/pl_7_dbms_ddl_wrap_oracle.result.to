#### case 3: 加密 - 包
drop table tab0;
create table tab0(c0 int,c1 int);

drop table tab1;
create table tab1(c0 int)partition by hash(c0)partitions 4;
insert into tab1 values(0);
insert into tab1 values(1);
insert into tab1 values(2);
commit;

declare
  res varchar2(5000);
begin
  res := dbms_ddl.wrap(
'create or replace package pkg1 as'      || chr(10) ||
'type rd is record(c0 int,c1 int);'      || chr(10) ||
'type tb is table of rd index by pls_integer;'      || chr(10) ||
't tb;'      || chr(10) ||
'a rd;'      || chr(10) ||
'procedure p1 ;'      || chr(10) ||
'function f1 return int parallel_enable;'      || chr(10) ||
'end;'
);
EXECUTE IMMEDIATE res;
res := dbms_ddl.wrap(
'create or replace package body pkg1 as'      || chr(10) ||
'procedure p0(a out rd) is'      || chr(10) ||
'begin'      || chr(10) ||
'a.c0:=0;'      || chr(10) ||
'end;'      || chr(10) ||
'function f0(a out rd)return rd is'      || chr(10) ||
'begin'      || chr(10) ||
'a.c0:=0;'      || chr(10) ||
'return a;'      || chr(10) ||
'end;'      || chr(10) ||
'procedure p1 is'      || chr(10) ||
'begin'      || chr(10) ||
'for i in 1..1000 loop'      || chr(10) ||
'a:=f0(t(i));'      || chr(10) ||
'end loop;'      || chr(10) ||
'for i in 1..1000 loop'      || chr(10) ||
'p0(t(i));'      || chr(10) ||
'end loop;'      || chr(10) ||
'end;'      || chr(10) ||
'function f1 return int is begin'      || chr(10) ||
'return t.count;'      || chr(10) ||
'end;'      || chr(10) ||
'end;'
);
  EXECUTE IMMEDIATE res;
end;
$

