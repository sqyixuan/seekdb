#### case 9: 加密 - TYPE
declare
  res varchar2(5000);
begin
  res := dbms_ddl.wrap(
'create  OR REPLACE TYPE secondmaximpl AS OBJECT'      || chr(10) ||
'('      || chr(10) ||
'max number,'      || chr(10) ||
'secmax number,'      || chr(10) ||
'STATIC FUNCTION ODCIAGGREGATEINITIALIZE(SCTX IN OUT secondmaximpl) RETURN NUMBER,'      || chr(10) ||
'MEMBER FUNCTION ODCIAGGREGATEITERATE(SELF IN OUT secondmaximpl,value in number) RETURN NUMBER,'      || chr(10) ||
'MEMBER FUNCTION ODCIAGGREGATETERMINATE(SELF IN secondmaximpl,'      || chr(10) ||
'RETURNVALUE OUT number,'      || chr(10) ||
'FLAGS IN NUMBER)'      || chr(10) ||
'RETURN NUMBER,'      || chr(10) ||
'MEMBER FUNCTION ODCIAGGREGATEMERGE(SELF IN OUT secondmaximpl,'      || chr(10) ||
'SCTX2 IN  secondmaximpl) RETURN NUMBER);');
EXECUTE IMMEDIATE res;
res := dbms_ddl.wrap(
'CREATE OR REPLACE TYPE BODY secondmaximpl IS'      || chr(10) ||
'STATIC FUNCTION ODCIAGGREGATEINITIALIZE(SCTX IN OUT secondmaximpl)'      || chr(10) ||
'RETURN NUMBER'      || chr(10) ||
'IS'      || chr(10) ||
'BEGIN'      || chr(10) ||
'SCTX := secondmaximpl(0,0);'      || chr(10) ||
'RETURN ODCICONST.SUCCESS;'      || chr(10) ||
'END;'      || chr(10) ||
'MEMBER FUNCTION ODCIAGGREGATEITERATE(SELF IN OUT secondmaximpl,'      || chr(10) ||
'value in number)RETURN NUMBER IS'      || chr(10) ||
'BEGIN'      || chr(10) ||
'if value > self.max then'      || chr(10) ||
'   self.secmax := self.max;'      || chr(10) ||
'   self.max := value;'      || chr(10) ||
'elsif value > self.secmax then'      || chr(10) ||
'   self.secmax :=value;'      || chr(10) ||
'END IF;'      || chr(10) ||
'RETURN ODCICONST.SUCCESS;'      || chr(10) ||
'END;'      || chr(10) ||
''      || chr(10) ||
'MEMBER FUNCTION ODCIAGGREGATETERMINATE(SELF IN secondmaximpl,'      || chr(10) ||
'RETURNVALUE OUT number,FLAGS IN NUMBER)'      || chr(10) ||
'RETURN NUMBER IS'      || chr(10) ||
'BEGIN'      || chr(10) ||
'  RETURNVALUE := self.secmax ;'      || chr(10) ||
'RETURN ODCICONST.SUCCESS;'      || chr(10) ||
'END;'      || chr(10) ||
'MEMBER FUNCTION ODCIAGGREGATEMERGE(SELF IN OUT secondmaximpl,'      || chr(10) ||
'SCTX2 IN secondmaximpl)'      || chr(10) ||
'RETURN NUMBER'      || chr(10) ||
'IS'      || chr(10) ||
'BEGIN'      || chr(10) ||
'if sctx2.max >self.max then'      || chr(10) ||
'  if sctx2.secmax>self.secmax then'      || chr(10) ||
'     self.secmax:=sctx2.secmax;'      || chr(10) ||
'  else'      || chr(10) ||
'     self.secmax:=self.max;'      || chr(10) ||
'  end if;'      || chr(10) ||
'elsif sctx2.max >self.secmax then'      || chr(10) ||
'  self.secmax:=sctx2.max;'      || chr(10) ||
'end if;'      || chr(10) ||
'RETURN ODCICONST.SUCCESS;'      || chr(10) ||
'END;'      || chr(10) ||
'END;');
EXECUTE IMMEDIATE res;
res := dbms_ddl.wrap(
'CREATE OR REPLACE FUNCTION secmax (input number) RETURN number '      || chr(10) ||
'parallel_enable AGGREGATE '      || chr(10) ||
'USING secondmaximpl;');
EXECUTE IMMEDIATE res;
end;
$

create or replace synonym syn_secondmaximpl for secondmaximpl;

