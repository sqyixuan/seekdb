declare
  obj obj_typ1;
begin
  obj := obj_typ1();
  dbms_output.put_line('obj.c1:' || obj.c1);
  dbms_output.put_line('obj.c2:' || obj.c2);
  obj := obj_typ1(5, 6);
  dbms_output.put_line('obj.c1:' || obj.c1);
  dbms_output.put_line('obj.c2:' || obj.c2);
end;
$

