#### case 8: 加密 - udt带构造函数'
drop table t0;
create table t0(c0 varchar2(10),c1 varchar2(10));
insert into t0 values('a','b');

declare
  res varchar2(5000);
begin
  res := dbms_ddl.wrap(
'create or replace package pkg1 as'      || chr(10) ||
'cursor c is select * from t0;'      || chr(10) ||
'procedure p1;'      || chr(10) ||
'function f1(a int) return int;'      || chr(10) ||
'end;');
EXECUTE IMMEDIATE res;
res :=  dbms_ddl.wrap(
'create or replace package body pkg1 as'      || chr(10) ||
'procedure p1 is'      || chr(10) ||
'a int;'      || chr(10) ||
'begin'      || chr(10) ||
'for rec in c loop'      || chr(10) ||
'null;'      || chr(10) ||
'end loop;'      || chr(10) ||
'end;'      || chr(10) ||
'function f1(a int) return int is'      || chr(10) ||
'begin'      || chr(10) ||
'return a+1;'      || chr(10) ||
'end;'      || chr(10) ||
'end;');
EXECUTE IMMEDIATE res;
res :=  dbms_ddl.wrap(
'create or replace type obj0 force as object(c0 int, c1 int,'      || chr(10) ||
'member procedure p1,'      || chr(10) ||
'member function f1 return int,'      || chr(10) ||
'constructor function obj0(c0 int) return self as result,'      || chr(10) ||
'constructor function obj0(c0 int, c1 int) return self as result'      || chr(10) ||
');');
EXECUTE IMMEDIATE res;
res :=  dbms_ddl.wrap(
'create or replace type body obj0 as'      || chr(10) ||
'member procedure p1 is'      || chr(10) ||
'cursor c is select * from t0 where c0=1;'      || chr(10) ||
'begin'      || chr(10) ||
'pkg1.p1();'      || chr(10) ||
'for rec in c loop'      || chr(10) ||
'null;'      || chr(10) ||
'end loop;'      || chr(10) ||
'end;'      || chr(10) ||
'member function f1 return int is'      || chr(10) ||
'begin'      || chr(10) ||
'return pkg1.f1(c0);'      || chr(10) ||
'end;'      || chr(10) ||
'constructor function obj0(c0 int) return self as result is'      || chr(10) ||
'begin'      || chr(10) ||
'self.c0:=pkg1.f1(c0);'      || chr(10) ||
'self.c0:=self.c0;'      || chr(10) ||
'return ;'      || chr(10) ||
'end;'      || chr(10) ||
'constructor function obj0(c0 int, c1 int) return self as result is'      || chr(10) ||
'begin'      || chr(10) ||
'self.c0:=pkg1.f1(c0);'      || chr(10) ||
'self.c1:=pkg1.f1(c1);'      || chr(10) ||
'return ;'      || chr(10) ||
'end;'      || chr(10) ||
'end;');
EXECUTE IMMEDIATE res;
end;
$

