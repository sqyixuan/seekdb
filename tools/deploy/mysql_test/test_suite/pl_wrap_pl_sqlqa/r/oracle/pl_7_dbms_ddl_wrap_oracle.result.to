begin
  res := dbms_ddl.wrap(
'create or replace type obj_typ1 is object('      || chr(10) ||
'  c1 int,'      || chr(10) ||
'  c2 int,'      || chr(10) ||
'  constructor function obj_typ1(c1 in int :=2, c2 in int:=3) return self as result'      || chr(10) ||
');');
EXECUTE IMMEDIATE res;
res := dbms_ddl.wrap(
'create or replace type body obj_typ1 is'      || chr(10) ||
'  constructor function obj_typ1 (c1 in int :=2, c2 in int:=3) return self as result is'      || chr(10) ||
'  begin'      || chr(10) ||
'    self.c1 := c1;'  || chr(10) ||
'    self.c2 := c2;'  || chr(10) ||
'    return;'  || chr(10) ||
'  end;'      || chr(10) ||
'end;');
EXECUTE IMMEDIATE res;
end;
$

