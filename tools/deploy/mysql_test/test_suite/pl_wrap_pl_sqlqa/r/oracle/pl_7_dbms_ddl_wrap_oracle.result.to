drop table t0;
create table t0(id int ,salary int);
insert into t0 values(0,10);
insert into t0 values(0,100);
insert into t0 values(0,20);
insert into t0 values(1,10);
insert into t0 values(1,40);
insert into t0 values(1,30);
insert into t0 values(1,50);
insert into t0 values(1,100);

select case when secmax(salary)>10 then 1 else 0 end, id from t0 group by id having secmax(salary)>30;
