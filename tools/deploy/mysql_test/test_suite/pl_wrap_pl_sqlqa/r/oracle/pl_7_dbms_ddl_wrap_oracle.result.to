#### case 6: 加密 -  TYPE，包
declare
res varchar2(5000);
begin
res := dbms_ddl.wrap(
'create or replace type obj0 force as object (c0 int,c1 tb,'      || chr(10) ||
'constructor function obj0(o in out obj0)return self as result'      || chr(10) ||
');');
EXECUTE IMMEDIATE res;
res := dbms_ddl.wrap(
'create or replace type body obj0 as'      || chr(10) ||
'constructor function obj0(o in out obj0)return self as result is'      || chr(10) ||
'begin'      || chr(10) ||
'o.c1.extend(1);'      || chr(10) ||
'self:=o;'      || chr(10) ||
'return;'      || chr(10) ||
'end;'      || chr(10) ||
'end;');
EXECUTE IMMEDIATE res;
res := dbms_ddl.wrap(
'create or replace package pkg1 as'      || chr(10) ||
'a obj0:=obj0(1,tb(1,2));'      || chr(10) ||
'b obj0:=obj0(a);'      || chr(10) ||
'function f1 return int parallel_enable;'      || chr(10) ||
'end;');
EXECUTE IMMEDIATE res;
res := dbms_ddl.wrap(
'create or replace package body pkg1 as'      || chr(10) ||
'function f1 return int parallel_enable is'      || chr(10) ||
'begin'      || chr(10) ||
'return a.c1.count;'      || chr(10) ||
'end;'      || chr(10) ||
'end;');
EXECUTE IMMEDIATE res;
end;
$

