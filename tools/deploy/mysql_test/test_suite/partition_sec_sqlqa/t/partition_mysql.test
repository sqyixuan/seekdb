--echo partition-4-1-1      字符串     一个一级分区对多个二级分区
DROP table   if  exists EMP;
create TABLE EMP(empno   int,ename   VARCHAR(100),job  VARCHAR(100),mgr   int,hiredate DATE,sal   float(9,0),comm   float(9,0),deptno  int,
comid   int)
partition by range  columns(ename)
subpartition by range  columns(job)
subpartition template
(
subpartition  part01   values  less than('A'),
subpartition  part02   values  less than('B'),
subpartition  part03   values  less than('C'),
subpartition  part04   values  less than('D'),
subpartition  part05   values  less than('E'),
subpartition  part06   values  less than('F'),
subpartition  part07   values  less than('G'),
subpartition  part08   values  less than('H'),
subpartition  part09   values  less than('I'),
subpartition  part010 values  less than('J')
)
(
partition p1 values  less than('M')
);



--echo partition-4-1-2      多个一级子分区对一个二级分区

DROP table   if  exists EMP;
create TABLE EMP(empno   int,ename   VARCHAR(100),job  VARCHAR(100),mgr   int,hiredate DATE,sal   float(9,0),comm   float(9,0),deptno  int,
comid   int)
partition by range columns(ename)
subpartition by range columns(job)
subpartition template
(
subpartition   part01   values  less than('Y')
)
(
partition A values  less than('A'),
partition B values  less than('B'),
partition C values  less than('C'),
partition D values  less than('D'),
partition E values  less than('E'),
partition F values  less than('F'),
partition G values  less than('G'),
partition H values  less than('H'),
partition I values  less than('I'),
partition J values  less than('J'),
partition K values  less than('K'),
partition  L   values  less than('L')
);


--echo partition-4-1-3   多个一级子分区对多个二级分区

DROP table   if  exists EMP;
create TABLE EMP(empno   int,ename   VARCHAR(100),job  VARCHAR(100),mgr   int,hiredate DATE,sal   float(9,0),comm   float(9,0),deptno  int,
comid   int)
partition by range columns(ename)
subpartition by range columns(job)
subpartition template
(
subpartition A values  less than('A'),
subpartition B values  less than('B'),
subpartition C values  less than('C'),
subpartition D values  less than('D'),
subpartition E values  less than('E'),
subpartition F values  less than('F'),
subpartition G values  less than('G'),
subpartition H values  less than('H'),
subpartition I values  less than('I'),
subpartition J values  less than('J'),
subpartition K values  less than('K'),
subpartition  L   values  less than('L')
)
(
partition A values  less than('A'),
partition B values  less than('B'),
partition C values  less than('C'),
partition D values  less than('D'),
partition E values  less than('E'),
partition F values  less than('F'),
partition G values  less than('G'),
partition H values  less than('H'),
partition I values  less than('I'),
partition J values  less than('J'),
partition K values  less than('K'),
partition  L   values  less than('L')
);



