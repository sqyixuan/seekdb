--echo partition-1-2-1-1-2   hash-hash   二级分区子分区名字相同同      (子分区的名字无效)
drop   table  if  exists   emp;
create TABLE   EMP(empno   int,ename   VARCHAR(100) ,job  VARCHAR(100),mgr   int ,hiredate DATE,sal   float(8,0) ,comm   int ,deptno  int,comid   int)partition by hash(empno)
subpartition by hash(empno)subpartition template
(subpartition part001,subpartition part002)
(partition p1000,partition p2000);

select  e.table_name a,e.partition_name b,e.subpartition_name c,e.partition_ordinal_position d,e.subpartition_ordinal_position e,e.partition_method f,e.partition_expression g,e.partition_description h,e.SUBPARTITION_METHOD i,
e.SUBPARTITION_EXPRESSION j  from    information_schema.partitions   e  where table_name = 'emp'  and   e.table_schema  ='ob100x';


--echo partition-1-2-1-1-3   hash-hash   二级分区子分区数量不同
drop   table  if  exists   emp;
create TABLE   EMP(empno   int,ename   VARCHAR(100) ,job  VARCHAR(100),mgr   int ,hiredate DATE,sal   float(8,0) ,comm   int ,deptno  int,comid   int)partition by hash(empno)
subpartition by hash(empno)
(partition p0(
subpartition part01,
subpartition part02,
subpartition part03,
subpartition part04,
subpartition part05,
subpartition part06),

partition p1(subpartition part07,
subpartition part08,
subpartition part09));

