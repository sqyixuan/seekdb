INSERT INTO EMP001 VALUES(200,'CLARK','MANAGER',7839,'1986-12-12',2450,NULL,20,9999);
INSERT INTO EMP001 VALUES(300,'SCOTT','ANALYST',7566,'1987-12-12',3000,NULL,30,9999);

--echo    partition-2-5-1-1    创建局部前缀索引；分区键作为索引定义的第一列
--error 0 ,  1091
DROP   index     local_index001  on    EMP001;
create index local_index001 on EMP001 (empno, deptno) local;


--echo    partition-2-5-1-2   --创建局部非前缀索引；分区键未作为索引定义的第一列

--error 0 ,  1091
DROP   INDEX     local_index001 on    EMP001;
create index local_index001 on EMP001 (sal,ename, empno) local;



--echo    partition-2-5-1-3   全局索引只有一类，即全局前缀索引（prefixed global index），索引分区键必须作为索引定义的第一列，否则执行会报错。

--error 0 ,  1091
DROP   INDEX     global_index001  on    EMP001;
create index global_index001 on EMP001(deptno,empno) global
partition by range (deptno)(partition index_part1 values less than(15),partition index_part2 values less than(25),partition index_partmax values less than (maxvalue));

--echo    partition-2-5-2   视图创建成功
