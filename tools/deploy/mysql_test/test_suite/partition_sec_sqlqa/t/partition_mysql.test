SELECT * FROM emp001  e   where   e.ename   LIKE   '%S'   order by  empno;
SELECT * FROM emp002  e   where   e.ename   LIKE  '%S'   order by  empno;
SELECT * FROM emp003  e   where   e.ename   LIKE  '%S'    order by  empno;


--echo   partition-2-1-2  with 语句
--error   1064
with   temp001  as(select *  FROM  emp001)temp002  as (select *  FROM  emp002) SELECT   e.*     FROM    temp001 e,temp002 r;

--echo   partition-2-1-3   distinct
SELECT    DISTINCT(sal)     FROM emp001  e  order by  empno;
SELECT    DISTINCT(sal)     FROM emp002  e   order by  empno;
SELECT     DISTINCT(sal)     FROM emp003  e   order by  empno;

--echo   partition-2-1-4-1   自连接
select * from emp001 where empno=(select EMPNO from emp001 where ename='SMITH')  order by  empno;
select * from emp002 where empno=(select EMPNO from emp002 where ename='SMITH')  order by  empno;
select * from emp003 where empno=(select EMPNO from emp002 where ename='SMITH')  order by  empno;


--echo   partition-2-1-4-2   笛卡儿乘积
SELECT   count(*)   from emp001,emp002;
SELECT   count(*)   from emp002,emp003;



--echo   partition-2-1-4-3   左外连接：left join
SELECT   *    from emp001  e   left   join   emp002   r   ON    e.empno=r.empno  order by e.empno;
SELECT   *    from emp001  e   left   outer  join   emp002   r   ON    e.empno=r.empno  order by e.empno;
SELECT   *    from emp001  e   left   outer  join   emp003   r   ON    e.empno=r.empno   order by r.empno;


--echo   partition-2-1-4-4  右外连接：right join
SELECT   *    from emp001  e   right   join   emp002   r   ON    e.empno=r.empno   order by e.empno;
SELECT   *    from emp001  e   right   outer  join   emp002   r   ON    e.empno=r.empno   order by e.empno;
SELECT   *    from emp002  e   right   outer  join   emp003   r   ON    e.empno=r.empno  order by r.empno;


--echo   partition-2-1-4-5  全连接：full join
select    *    from emp001 e full join emp002 d on e.DEPTNO=d.DEPTNO  order by e.empno,d.empno;
select    *    from emp001 e full join emp003 d on e.DEPTNO=d.DEPTNO  order by e.empno,d.empno;


--echo     partition-2-1-5-1   =、!=、<>、<=、>=
SELECT   *    from emp001  e   WHERE   e.empno=1  order by e.empno;
SELECT   *    from emp002  e   WHERE   e.empno=1  order by e.empno;
SELECT   *    from emp003  e   WHERE   e.empno=1  order by e.empno;

SELECT   *    from emp001  e   WHERE   e.empno!=1  order by e.empno;
SELECT   *    from emp002  e   WHERE   e.empno!=1  order by e.empno;
SELECT   *    from emp003  e   WHERE   e.empno!=1  order by e.empno;

SELECT   *    from emp001  e   WHERE   e.empno>=1  order by e.empno;
SELECT   *    from emp002  e   WHERE   e.empno>=1  order by e.empno;
SELECT   *    from emp003  e   WHERE   e.empno>=1  order by e.empno;

SELECT   *    from emp001  e   WHERE   e.empno<=1  order by e.empno;
SELECT   *    from emp002  e   WHERE   e.empno<=1  order by e.empno;
SELECT   *    from emp003  e   WHERE   e.empno<=1  order by e.empno;


SELECT   *    from emp001  e   WHERE   e.empno<>1  order by e.empno;
SELECT   *    from emp002  e   WHERE   e.empno<>1  order by e.empno;
SELECT   *    from emp003  e   WHERE   e.empno<>1  order by e.empno;

--echo     partition-2-1-5-2
SELECT   *    from emp001  e   WHERE   e.empno   BETWEEN    1  and   5    order by e.empno;
SELECT   *    from emp002  e   WHERE   e.empno   BETWEEN    1  and   5    order by e.empno;
SELECT   *    from emp003  e   WHERE   e.empno   BETWEEN    1  and   5    order by e.empno;


--echo     partition-2-1-5-3  in、not in     or
SELECT   *    from emp001  e   WHERE   e.empno  IN(1,2,5)    order by e.empno;
SELECT   *    from emp001  e   WHERE   e.empno   NOT IN(1,2,5)    order by e.empno;
SELECT   *    from emp001  e   WHERE   e.empno   =1 OR  empno=100    order by e.empno;

SELECT   *    from emp002  e   WHERE   e.empno  IN(1,2,5)    order by e.empno;
SELECT   *    from emp002  e   WHERE   e.empno   NOT IN(1,2,5)    order by e.empno;
SELECT   *    from emp002  e   WHERE   e.empno   =1 OR  empno=100    order by e.empno;

SELECT   *    from emp003  e   WHERE   e.empno  IN(1,2,5)   order by e.empno;
SELECT   *    from emp003  e   WHERE   e.empno   NOT IN(1,2,5)   order by e.empno;
SELECT   *    from emp003  e   WHERE   e.empno   =1 OR  empno=100   order by e.empno;


--echo  partition-2-1-6-1    sum
SELECT  sum(sal)   from emp001  e;
SELECT  sum(sal)   from emp002  e;
SELECT  sum(sal)   from emp003  e;

--echo  partition-2-1-6-2    count
SELECT  count(*)  from emp001  e;
SELECT  count(*)  from emp002  e;
SELECT  count(*)  from emp003  e;

--echo  partition-2-1-6-3    max
SELECT  max(sal)  from emp001  e;
SELECT  max(comm)  from emp002  e;
SELECT  max(comm)  from emp003  e;

--echo  partition-2-1-6-4    min
SELECT  min(sal)  from emp001  e;
SELECT  min(comm)  from emp002  e;
SELECT  min(comm)  from emp002  e;

--echo  partition-2-1-6-5    avg
SELECT  avg(sal)  from emp001  e;
SELECT  avg(comm)  from emp002  e;
SELECT  avg(comm)  from emp003  e;


--echo partition-2-1-7   group by[ having]
SELECT  deptno,max(sal)  from emp001  e    GROUP  BY   e.deptno   HAVING   e.deptno>10   order by  e.deptno>10;
SELECT  deptno,max(sal)  from emp002  e    GROUP  BY   e.deptno   HAVING   e.deptno>10   order by  e.deptno>10;
SELECT  deptno,max(sal)  from emp003  e    GROUP  BY   e.deptno   HAVING   e.deptno>10   order by  e.deptno>10;

--echo partition-2-1-8  order  by
SELECT  deptno,max(sal)  from emp001  e    GROUP  BY   e.deptno   HAVING   e.deptno>10   ORDER BY   sum(e.sal);
SELECT  deptno,max(sal)  from emp002  e    GROUP  BY   e.deptno   HAVING   e.deptno>10   ORDER BY   sum(e.sal);
SELECT  deptno,max(sal)  from emp003  e    GROUP  BY   e.deptno   HAVING   e.deptno>10   ORDER BY   sum(e.sal);


--echo   partition-2-2-1    insert into select
select * from EMP001 partition(p0) order by   empno,sal,job,hiredate;
select * from EMP001 partition(p1) order by   empno,sal,job,hiredate;

select * from EMP002 partition(p0) order by   empno,sal,job,hiredate;
select * from EMP002 partition(p1) order by   empno,sal,job,hiredate;

select * from EMP003 partition(p0) order by   empno,sal,job,hiredate;
select * from EMP003 partition(p1) order by   empno,sal,job,hiredate;


--echo    partition-2-2-1-1   表里插入数据
insert INTO  EMP001   SELECT  *    FROM     EMP002;
insert INTO  EMP001    select * from EMP002 partition(p0) order by   empno,sal,job,hiredate;
select * from EMP001  order by   empno,sal,job,hiredate;

insert INTO  EMP003   SELECT  *    FROM     EMP002;
insert INTO  EMP003    select * from EMP002 partition(p0) order by   empno,sal,job,hiredate;
select * from EMP003  order by   empno,sal,job,hiredate;


--echo    partition-2-2-1-2  分区里插入数据
insert INTO    EMP001 partition(p0)   select * from EMP002 partition(p0);
select * from EMP001 partition(p0)   order by   empno,sal,job,hiredate;


insert INTO    EMP003 partition(p0)   select * from EMP002 partition(p0);
select * from EMP003 partition(p0)   order by   empno,sal,job,hiredate;


--echo    partition-2-2-1-3  子分区里插入数据
--error   1748
