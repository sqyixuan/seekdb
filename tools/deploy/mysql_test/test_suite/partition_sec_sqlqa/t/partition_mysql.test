comid   int default  999,constraint T_SCORE002   foreign key (ename)  references EMP001 (ename))
partition    by  list(empno)
subpartition by range(empno)
(
partition   p0  values in (1,2,3,4,1000,2000,3000,5000,999)
(
subpartition part01  VALUES  less than (1000),
subpartition part02  VALUES  less than (3000),
subpartition part03  VALUES  less than (6000),
subpartition part04  VALUES  less than (8000),
subpartition part05   VALUES  less than (9999)),
partition     p1  values in (100,200,300,400)
(
subpartition part06 VALUES  less than (1000),
subpartition part07  VALUES  less than (2000),
subpartition part08   VALUES  less than (7000))
);
--error 1452
INSERT INTO EMP003(ename)VALUES('SMITH');



drop   table  if  exists   emp003;
drop   table  if  exists   emp002;

--echo    partition-2-5-4  常用sql功能正常
SELECT   *  FROM    EMP001  e  WHERE   e.deptno> 10  ;
SELECT   deptno  FROM    EMP001  e  WHERE   e.deptno> 10   GROUP BY e.deptno   HAVING e.deptno> 10   ORDER BY  deptno;





--echo   partition-3-1  --给表增加一级分区
#二级分区 模板化  不支持新增分区
drop   table  if  exists   emp;
create TABLE   emp(empno   int,ename   VARCHAR(100) ,job  VARCHAR(100),mgr   int ,hiredate DATE,sal   float(8,0) ,comm   int ,deptno  int,comid   int)partition by  range(empno)
subpartition by hash(empno)subpartition template(subpartition part001,subpartition part002)(partition p0 values  less than(15),partition p1 values  less than(500));
ALTER TABLE emp  PARTITION by RANGE(empno)(PARTITION p10 VALUES LESS THAN (600),PARTITION p11 VALUES LESS THAN (700),PARTITION p12 VALUES LESS THAN (800),PARTITION p13 VALUES LESS THAN (900),PARTITION p14 VALUES LESS THAN MAXVALUE);


#二级分区 非模板化   不支持新增分区
drop   table  if  exists   emp;
create TABLE   emp(empno   int,ename   VARCHAR(100) ,job  VARCHAR(100),mgr   int ,hiredate DATE,sal   float(8,0) ,comm   int ,deptno  int,comid   int)partition by  range(empno)
subpartition by hash(empno)
(partition p0 values  less than(15)(subpartition part001,subpartition part002) ,partition p1 values  less than(500)(subpartition part003,subpartition part004));
ALTER TABLE emp  PARTITION by RANGE(empno)(PARTITION p10 VALUES LESS THAN (600),PARTITION p11 VALUES LESS THAN (700),PARTITION p12 VALUES LESS THAN (800),PARTITION p13 VALUES LESS THAN (900),PARTITION p14 VALUES LESS THAN MAXVALUE);


#一级分区支持新增分区
drop   table  if  exists   emp;
create TABLE   emp(empno   int primary key,ename   VARCHAR(100) ,job  VARCHAR(100),mgr   int ,hiredate DATE,sal   float(8,0) ,comm   int ,deptno  int,comid   int)PARTITION by RANGE(empno)(PARTITION p10 VALUES LESS THAN (600),PARTITION p11 VALUES LESS THAN (700),PARTITION p12 VALUES LESS THAN (800),PARTITION p13 VALUES LESS THAN (900),PARTITION p14 VALUES LESS THAN MAXVALUE);

