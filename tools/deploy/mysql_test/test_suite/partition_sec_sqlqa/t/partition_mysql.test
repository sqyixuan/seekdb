--echo  partition-1-1-3-2   分区表：时间分区
drop   table  if  exists   emp;
create TABLE   EMP(empno   int,ename   VARCHAR(100) ,job  VARCHAR(100),mgr   int ,hiredate DATE,sal   float(8,0) ,comm   int ,deptno  int,comid   int)
partition by list(year(hiredate))
(
    PARTITION a VALUES IN (1980),
    PARTITION b VALUES IN (1981),
    PARTITION c VALUES IN (1982),
    PARTITION d VALUES IN (1983)
);
