SELECT   *    FROM     emp001_view   order by   empno,sal,job,hiredate;

create or replace view emp003_view   as   SELECT    *     from    emp003 ;

SELECT   *    FROM     emp003_view   order by   empno,sal,job,hiredate;






--echo    partition-2-5-3-1    primary key
drop   table  if  exists   emp001;
create TABLE EMP001(empno   int  primary key,ename   VARCHAR(100) ,job  VARCHAR(100),mgr   int,hiredate DATE,sal   float(9,0),comm   int,deptno int,comid   int)
partition by range(empno)
subpartition by range(empno)
(partition bujige values  less than(25)
(subpartition  part01   values  less than(15),subpartition   part02   values  less than(25)),
partition  jige   values  less than(35)
(subpartition  part03   values  less than(15),subpartition   part04   values  less than(25)));

