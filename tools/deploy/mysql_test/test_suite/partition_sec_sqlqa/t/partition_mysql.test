create TABLE   EMP(empno   int,ename   VARCHAR(100) ,job  VARCHAR(100),mgr   int ,hiredate DATE,sal   float(8,0) ,comm   int ,deptno  int,comid   int)partition by  list columns(ename)
(partition    part01 values  in ('SMITH','ALLEN','WARD','JONES'),PARTITION  part02     values  in  ('BLAKE','CLARK','SCOTT','FORD'),partition     part03 values  in ('KING','TURNER','ADAMS','JAMES'));

