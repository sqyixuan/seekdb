select * from EMP001 partition(p0) order by   empno,sal,job,hiredate;

UPDATE  EMP003 e   SET   e.empno    =100    WHERE    e.ename = 'CLARK';
select * from EMP003 partition(p0) order by   empno,sal,job,hiredate;


--echo   partition-2-4-1  删除当前分区的数据
DELETE   FROM    EMP001 partition(p0)   e   WHERE   empno=2;
select * from EMP001 partition(p0) order by   empno,sal,job,hiredate;

DELETE   FROM    EMP003 partition(p0)   e   WHERE   empno=2;
select * from EMP003  partition(p0) order by   empno,sal,job,hiredate;

--echo   partition-2-4-2  跨过分区删除数据
select * from EMP001 partition(p0) order by   empno,sal,job,hiredate;
select * from EMP001 partition(p1) order by   empno,sal,job,hiredate;
DELETE   FROM    EMP001   WHERE   empno IN (3,300);
select * from EMP001 partition(p0) order by   empno,sal,job,hiredate;
select * from EMP001 partition(p1) order by   empno,sal,job,hiredate;

select * from EMP003 partition(p0) order by   empno,sal,job,hiredate;
select * from EMP003 partition(p1) order by   empno,sal,job,hiredate;
DELETE   FROM    EMP003   WHERE   empno IN (3,300);
select * from EMP003 partition(p0) order by   empno,sal,job,hiredate;
select * from EMP003 partition(p1) order by   empno,sal,job,hiredate;


--echo   创建局部前缀索引
drop   table  if  exists   emp001;
create TABLE EMP001(empno   int,ename   VARCHAR(100),job  VARCHAR(100),mgr   int,hiredate DATE,sal   float(9,0),comm   float(9,0),deptno  int,
comid   float)
partition by range(empno)
subpartition by range(deptno)
(partition p001 values  less than(15)

(subpartition  part01   values  less than(15),
subpartition   part02   values  less than(35)),

partition  p002   values  less than(2000)
(subpartition  part03   values  less than(15),
subpartition   part04   values  less than(35))
);

