#  hash 和 range
drop   table  if  exists   emp001;
create table emp001 (c1 int, c2 int, c3 int, primary key (c1,c2))
partition by hash(c1) subpartition by range (c2) subpartition template
(subpartition rp0 values less than (100),
subpartition rp1 values less than (200),
subpartition rp2 values less than (300)
)partitions 10;

drop   table  if  exists   emp002;
create table emp002 (c1 int, c2 int, c3 int, primary key (c1,c2))
partition by hash(c1)subpartition by range (c2) subpartition template
(subpartition rp0 values less than (100),
subpartition rp1 values less than (200),
subpartition rp2 values less than (300)
) partitions 10;

drop   table  if  exists   emp003;
create table emp003 (c1 int, c2 int, c3 int, primary key (c1,c2))
partition by hash(c1)subpartition by range (c2) subpartition template
(subpartition rp0 values less than (100),
subpartition rp1 values less than (150),
subpartition rp2 values less than (200),
subpartition rp3 values less than (300)
) partitions 10;


EXPLAIN   select t1.* from emp001 t1, emp002 t2 where t1.c1 = t2.c1 and t1.c2 = t2.c2 and t1.c2 > 150  UNION   select t1.* from emp001 t1, emp003 t2 where t1.c1 = t2.c1 and t1.c2 = t2.c2 and t1.c2 > 150;



EXPLAIN      select t1.* from emp001 t1, emp002 t2 where t1.c1 = t2.c1 and t1.c2 = t2.c2 and t1.c2 > 150  intersect    select * from emp003 t3 where t3.c2 > 150;



EXPLAIN   select t1.* from emp001 t1, emp002 t2 where t1.c1 = t2.c1 and t1.c2 = t2.c2 and t1.c2 > 150  minus    select * from emp003 t3 where t3.c2 > 150;




