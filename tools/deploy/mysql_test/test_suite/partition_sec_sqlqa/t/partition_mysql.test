drop   table  if  exists   emp003;
create TABLE EMP003(empno   int,ename  VARCHAR(100),job  VARCHAR(100),mgr   int,hiredate DATE,sal   int,comm   int,deptno  int,
comid   int)
partition    by  list(empno)
subpartition by range(sal)
(
partition   p0  values in (1,2,3,4,1000,2000,3000,5000)
(
subpartition part01  VALUES  less than (1000),
subpartition part02  VALUES  less than (3000),
subpartition part03  VALUES  less than (6000),
subpartition part04  VALUES  less than (8000),
subpartition part05   VALUES  less than (9999)),
partition     p1  values in (100,200,300,400)
(
subpartition part06 VALUES  less than (1000),
subpartition part07  VALUES  less than (2000),
subpartition part08   VALUES  less than (7000))
);

