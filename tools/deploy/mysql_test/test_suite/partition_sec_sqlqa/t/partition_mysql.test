create TABLE   emp(empno   int primary key,ename   VARCHAR(100) ,job  VARCHAR(100),mgr   int ,hiredate DATE,sal   float(8,0) ,comm   int ,deptno  int,comid   int)PARTITION by RANGE(empno)(PARTITION p10 VALUES LESS THAN (600),PARTITION p11 VALUES LESS THAN (700),PARTITION p12 VALUES LESS THAN (800),PARTITION p13 VALUES LESS THAN (900),PARTITION p14 VALUES LESS THAN MAXVALUE);

