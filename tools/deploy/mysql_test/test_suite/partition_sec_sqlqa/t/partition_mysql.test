);

drop   table  if  exists   emp002;
create TABLE   EMP002(c1   int,c2  int ,c3 DATE)partition by  range columns(c1)
subpartition by range columns(c2)
(
partition p0 values LESS THAN(10)(
subpartition part01 values  LESS THAN(10),
subpartition part02 values  LESS THAN(20),
subpartition part03 values  LESS THAN(30)),

partition p00 values LESS THAN(200)(
subpartition part001 values  LESS THAN(100),
subpartition part002 values  LESS THAN(200),
subpartition part003 values  LESS THAN(300)),

partition p1 values LESS THAN(300)(
subpartition part04 values  LESS THAN(111),
subpartition part05 values  LESS THAN(222),
subpartition part06 values  LESS THAN(333))
);

EXPLAIN  select * from  emp001  t1  union   all  select * from   emp002  t2  where t2.c1<200;





