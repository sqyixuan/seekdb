connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;

#--error 0,5157
#drop tenant tenant_udt force;
#--error 0, 4650
#drop resource pool tenant_udt_pool;
#--error 0, 4648
#drop resource unit tenant_udt_unit;
--disable_warnings
#建unit， 后面内存大小可以适当调大
#create resource unit if not exists tenant_udt_unit max_cpu=1,memory_size='2G';
#create resource pool if not exists tenant_udt_pool unit='tenant_udt_unit', unit_num=1;
#create tenant if not exists tenant_udt RESOURCE_POOL_LIST=('tenant_udt_pool')set ob_tcp_invited_nodes='%',ob_compatibility_mode='mysql';
#create tenant if not exists tenant_udt RESOURCE_POOL_LIST=('tenant_udt_pool') , primary_zone = 'zone1'   set ob_tcp_invited_nodes='%',ob_compatibility_mode='mysql';
--source mysql_test/include/check_tenant_sync.inc
disconnect obsys;


#连接新建的租户
let $__tenant_name__ = 'sys';
--source mysql_test/include/get_tenant_server.inc
connect (conn1, $TE_SERVER_IP, root,,*NO-ONE*, $TE_SERVER_PORT);
connection conn1;

--echo  partition-1-1-1-1   range 分区表：数字类型
--disable_warnings
drop database  IF EXISTS  ob100x;
create database ob100x  character set utf16;
use ob100x;
select database();

drop   table  if  exists   emp;
create TABLE   EMP(empno   int,ename   VARCHAR(100) ,job  VARCHAR(100),mgr   int ,hiredate DATE,sal   float(8,0) ,comm   int ,deptno  int,comid   int)
partition by range(empno)
(
partition    bujige values  less than(10),
PARTITION  jige      values  less than(1000),
partition     youxiu  values  less than(maxvalue)
);
INSERT INTO EMP VALUES(1,'SMITH','CLERK',7902,'1980-12-12',800,NULL,20,9999);
INSERT INTO EMP VALUES(2,'ALLEN','SALESMAN',7698,'1981-12-12',1600,300,30,9999);
INSERT INTO EMP VALUES(3,'WARD','SALESMAN',7698,'1982-12-12',1250,500,30,9999);
INSERT INTO EMP VALUES(4,'JONES','MANAGER',7839,'1983-12-12',2975,NULL,20,9999);
INSERT INTO EMP VALUES(5,'MARTIN','SALESMAN',7698,'1984-12-12',1250,1400,30,9999);
INSERT INTO EMP VALUES(100,'BLAKE','MANAGER',7839,'1985-12-12',2850,NULL,30,9999);
INSERT INTO EMP VALUES(200,'CLARK','MANAGER',7839,'1986-12-12',2450,NULL,10,9999);
INSERT INTO EMP VALUES(300,'SCOTT','ANALYST',7566,'1987-12-12',3000,NULL,20,9999);
INSERT INTO EMP VALUES(400,'KING','PRESIDENT',NULL,'1988-12-12',5000,NULL,10,9999);
INSERT INTO EMP VALUES(1000,'TURNER','SALESMAN',7698,'1989-12-12',1500,0,30,9999);
INSERT INTO EMP VALUES(2000,'ADAMS','CLERK',7788,'1990-12-12',1100,NULL,20,9999);
INSERT INTO EMP VALUES(3000,'JAMES','CLERK',7698,'1991-12-12',950,NULL,30,9999);
INSERT INTO EMP VALUES(4000,'FORD','ANALYST',7566,'1992-12-12',3000,NULL,20,9999);
INSERT INTO EMP VALUES(5000,'MILLER','CLERK',7782,'1993-12-12',1300,NULL,10,9999);

select * from EMP partition(bujige) order by   empno;
select * from EMP partition(jige)  order by   empno;
select * from EMP partition(youxiu)  order by   empno;

select  e.table_name a,e.partition_name b,e.subpartition_name c,e.partition_ordinal_position d,e.subpartition_ordinal_position e,e.partition_method f,e.partition_expression g,e.partition_description h,e.table_rows i ,e.avg_row_length j,e.data_length k
from    information_schema.partitions   e  where table_name = 'emp'  and   e.table_schema  ='ob100x';


--echo  partition-1-1-1-2   分区表：时间分区
drop   table  if  exists   emp;
CREATE TABLE emp(id INT auto_increment,createdate DATETIME,primary key (id,createdate))
PARTITION BY RANGE (TO_DAYS(createdate))
(
   PARTITION p201801 VALUES LESS THAN ( TO_DAYS('20180201') ),
   PARTITION p201802 VALUES LESS THAN ( TO_DAYS('20180301') ),
   PARTITION p201803 VALUES LESS THAN ( TO_DAYS('20180401') ),
   PARTITION p201804 VALUES LESS THAN ( TO_DAYS('20180501') ),
   PARTITION p201805 VALUES LESS THAN ( TO_DAYS('20180601') ),
   PARTITION p201806 VALUES LESS THAN ( TO_DAYS('20180701') ),
   PARTITION p201807 VALUES LESS THAN ( TO_DAYS('20180801') ),
   PARTITION p201808 VALUES LESS THAN ( TO_DAYS('20180901') ),
   PARTITION p201809 VALUES LESS THAN ( TO_DAYS('20181001') ),
   PARTITION p201810 VALUES LESS THAN ( TO_DAYS('20181101') ),
   PARTITION p201811 VALUES LESS THAN ( TO_DAYS('20181201') ),
   PARTITION p201812 VALUES LESS THAN ( TO_DAYS('20190101') )
);

