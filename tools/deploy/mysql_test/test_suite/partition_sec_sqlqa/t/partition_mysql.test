--echo partition-6-3-2-3   其他
#sql涉及到的一级分区下面的二级分区个数大于一个，一级分区的个数大于1时，要求连接条件中存在t1.c1
drop   table  if  exists   emp001;
create TABLE   EMP001(c1   int,c2  int ,c3 DATE)partition by list(c1)
subpartition by hash(c2)
(
partition p0 values in  (1,2,3)(
subpartition part01,
subpartition part03
),
partition p1 values in  (10,20,30)(
subpartition part05,
subpartition part06)
);

drop   table  if  exists   emp002;
create TABLE   EMP002(c1   int,c2  int ,c3 DATE);


EXPLAIN  select * FROM  emp001  t1,   emp002  t2 where t1.c2 = t2.c2   and   t1.c1 =  t2.c1  and  t1.c1 in(1,10);






--echo   partition-7-1-1     无参数的存储过程
drop procedure if exists myproc1;
delimiter //;
create procedure myproc1()
begin
INSERT INTO EMP VALUES(1,'SMITH','CLERK',7902,'1980-12-12',800,NULL,10,9999);
INSERT INTO EMP VALUES(2,'ALLEN','SALESMAN',7698,'1981-12-12',1600,300,20,9999);
INSERT INTO EMP VALUES(3,'WARD','SALESMAN',7698,'1982-12-12',1250,500,30,9999);

INSERT INTO EMP VALUES(100,'BLAKE','MANAGER',7839,'1985-12-12',2850,NULL,10,9999);
INSERT INTO EMP VALUES(200,'CLARK','MANAGER',7839,'1986-12-12',2450,NULL,20,9999);
INSERT INTO EMP VALUES(300,'SCOTT','ANALYST',7566,'1987-12-12',3000,NULL,30,9999);
end //

call myproc1();//
select * from EMP partition(p0)  order by   empno;//
select * from EMP partition(p1)  order by   empno;//


--echo   partition-7-1-2    B:只有一个 in 参数的存储过程
drop procedure if exists myproc1;//
create procedure myproc1(in userId int)
begin
INSERT INTO EMP VALUES(userId,'BLAKE','MANAGER',7839,'1985-12-12',2850,NULL,10,9999);
end
//
set @dum =400;//
call myproc1(@dum);//
SELECT * from emp order by   empno,job,sal;//

--echo   partition-7-1-3    :包含 in 参数和 out 参数的存储过程,只能将一行的查询到的用户名赋值给username
drop procedure if exists myproc1;//
create procedure myproc1(in userId int, out username varchar(20))
begin
set username= userId;
INSERT INTO EMP VALUES(username,'BLAKE','MANAGER',7839,'1985-12-12',2850,NULL,10,9999);
end
//
call myproc1(500,@username);//
SELECT * from emp order by   empno,job,sal;//


--echo   partition-7-1-4  D:包含 inout 参数的存储过程
drop procedure if exists myproc1;//
create procedure myproc1(inout a int)
begin
INSERT INTO EMP VALUES(a,'BLAKE','MANAGER',7839,'1985-12-12',2850,NULL,10,9999);
end
//
set @num =350;//
call  myproc1(@num);//
SELECT * from emp order by   empno,job,sal;//



-- echo partition-7-2-1 无参数的函数
drop function  IF EXISTS salemp001;//
CREATE FUNCTION salemp001()RETURNS DOUBLE
BEGIN
DECLARE ag DOUBLE DEFAULT 0;
SELECT  AVG(SAL) INTO ag  FROM emp e;
RETURN ag;
end
//
SELECT salemp001();//

-- echo   partition-7-2-2    2.有参数的函数，并把函数的返回值当做参数
drop function  IF EXISTS salemp002;//
CREATE FUNCTION salemp002(saller002 DOUBLE) RETURNS DOUBLE
BEGIN
DECLARE ag DOUBLE DEFAULT 0;#定义局部变量并初始化
SELECT  AVG(SAL) INTO ag   FROM emp e  where  e.sal >saller002;#为局部变量赋值
RETURN ag;
end
//
SELECT salemp002(salemp001());//
