#select to_char(avg(sal)) from emp order by   empno,job,sal;

--echo     partition-5-12  to_number    函数不存在
#select to_number(avg(sal)) from emp order by   empno,job,sal;

--echo     partition-5-13  cast   函数不存在
#select cast(avg(sal) as varchar2(10))    from emp order by   empno,job,sal;


