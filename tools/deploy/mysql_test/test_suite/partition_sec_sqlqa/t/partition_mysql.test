select * from EMP partition(part02) order by   empno;
select * from EMP partition(part03) order by   empno;
select  e.table_name a,e.partition_name b,e.subpartition_name c,e.partition_ordinal_position d,e.subpartition_ordinal_position e,e.partition_method f,e.partition_expression g,e.partition_description h,e.table_rows i ,e.avg_row_length j,e.data_length k
from    information_schema.partitions   e  where table_name = 'emp'  and   e.table_schema  ='ob100x';




