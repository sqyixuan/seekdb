--echo partition-1-2-1-1-1   hash-hash   二级分区子分区名字不同
#mysql执行报错 但是ob是OK的  没问题。
drop   table  if  exists   emp;
create TABLE   EMP(empno   int,ename   VARCHAR(100) ,job  VARCHAR(100),mgr   int ,hiredate DATE,sal   float(8,0) ,comm   int ,deptno  int,comid   int)partition by hash(empno)
subpartition by hash(empno)
(partition p0(subpartition part01,subpartition part02,subpartition part03),
partition p1(subpartition part04,subpartition part05,subpartition part06));


