--echo   partition-3-3    新增已存在的一级分区
ALTER TABLE emp  PARTITION by RANGE(empno)(PARTITION p10 VALUES LESS THAN (600),PARTITION p11 VALUES LESS THAN (700),PARTITION p12 VALUES LESS THAN (800),PARTITION p13 VALUES LESS THAN (900),PARTITION p14 VALUES LESS THAN MAXVALUE);





 --echo   partition-3-4 --删除子分区

drop   table  if  exists   emp;
create TABLE   emp(empno   int,ename   VARCHAR(100) ,job  VARCHAR(100),mgr   int ,hiredate DATE,sal   float(8,0) ,comm   int ,deptno  int,comid   int)partition by  range(empno)
subpartition by hash(empno)subpartition template(subpartition part001,subpartition part002)(partition p0 values  less than(15),partition p1 values  less than(500));
alter table EMP drop PARTITION  P0;

#mysql模式不支持二级分区管理的语法，因为mysql本身就不支持
--error 1235
alter table EMP drop subpartition  part001;

select  e.table_name a,e.partition_name b,e.subpartition_name c,e.partition_ordinal_position d,e.subpartition_ordinal_position e,e.partition_method f,e.partition_expression g,e.partition_description h,e.SUBPARTITION_METHOD i,
e.SUBPARTITION_EXPRESSION j  from    information_schema.partitions   e  where table_name = 'emp'  and   e.table_schema  ='ob100x';


--echo   partition-3-5 --删除一级分区  那它下面的子分区也删除了
