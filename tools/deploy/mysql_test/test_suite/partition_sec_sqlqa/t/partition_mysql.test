EXPLAIN  select * FROM  emp001  t1,   emp002  t2 where t1.c2 = t2.c2  and   t1.c1 in(15);



--echo partition-6-3-2-2-36 range columns range columns和 range columns range columns
drop   table  if  exists   emp001;
create TABLE   EMP001(c1   int,c2  int ,c3 DATE)partition by  range columns(c1)
subpartition by range columns(c2)
(
partition p0 values LESS THAN(10)(
subpartition part01 values  LESS THAN(10),
subpartition part02 values  LESS THAN(20),
subpartition part03 values  LESS THAN(30)),

partition p1 values LESS THAN(30)(
subpartition part04 values  LESS THAN(100),
subpartition part05 values  LESS THAN(200),
subpartition part06 values  LESS THAN(300))
);

drop   table  if  exists   emp002;
create TABLE   EMP002(c1   int,c2  int ,c3 DATE);


EXPLAIN  select * FROM  emp001  t1,   emp002  t2 where t1.c2 = t2.c2  and   t1.c1 in(15);



--echo partition-6-3-2-2-36    其他和多次连接的场景

#  list 和 range
drop   table  if  exists   emp001;
create table emp001 (c1 int, c2 int, c3 int, primary key (c1,c2))
partition by list(c1) subpartition by range (c2) subpartition template
(subpartition rp0 values less than (100),
subpartition rp1 values less than (200),
subpartition rp2 values less than (300)
)(
partition    p1   values   in  (10),
partition    p2   values   in  (20)
);

drop   table  if  exists   emp002;
create table emp002 (c1 int, c2 int, c3 int, primary key (c1,c2))
partition by list(c1)subpartition by range (c2) subpartition template
(subpartition rp0 values less than (100),
subpartition rp1 values less than (200),
subpartition rp2 values less than (300)
)(
partition    p1   values   in  (100),
partition    p2   values   in  (200)
);

drop   table  if  exists   emp003;
create table emp003 (c1 int, c2 int, c3 int, primary key (c1,c2));


EXPLAIN     select   * from   (select t1.* from emp001 t1, emp002 t2 where    t1.c1 in(10)  and   t1.c2 = t2.c2)e,emp003 r   where e.c2 = r.c2;



