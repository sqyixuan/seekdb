--echo     partition-4-2-1    一个一级分区对多个二级分区
drop   table  if  exists   emp;
create TABLE EMP(empno   int,ename   VARCHAR(100),job  VARCHAR(100),mgr   int,hiredate DATE,sal   float(9,0),comm   float(9,0),deptno  int,
comid   int)
partition by range columns(ename)
subpartition by range columns(empno)
(partition bujige values  less than('Z')
(
subpartition  part01   values  less than(10),
subpartition  part02   values  less than(20),
subpartition  part03   values  less than(30),
subpartition  part04  values  less than(40),
subpartition  part05   values  less than(50),
subpartition  part06   values  less than(60),
subpartition  part07   values  less than(70),
subpartition  part08   values  less than(80),
subpartition  part09   values  less than(90),
subpartition  part10   values  less than(100))
);


--echo     partition-4-2-2    多个一级子分区对一个二级分区

drop   table  if  exists   emp;
create TABLE EMP(empno   int,ename   VARCHAR(100),job  VARCHAR(100),mgr   int,hiredate DATE,sal   float(9,0),comm   float(9,0),deptno  int,
comid   int)
partition by range columns(ename)
subpartition by range columns(job)
(partition P1 values  less than('A')
(
subpartition   part01   values  less than('A'))
,
partition  P2   values  less than('B')
(
subpartition   part02   values  less than('A'))
,
partition  P3   values  less than('C')
(
subpartition   part03   values  less than('A'))
,
partition  P4   values  less than('D')
(
subpartition   part04   values less than('A'))
,
partition  P5   values  less than('E')
(
subpartition   part05   values less than('A'))
,
partition  P6   values  less than('F')
(
subpartition   part06   values less than('A'))
,
partition  P7   values  less than('G')
(
subpartition   part07   values  less than('A'))
,
partition  P8   values  less than('H')
(
subpartition   part08   values  less than('A'))
,
partition  P9   values  less than('I')
(
subpartition   part09   values less than('A'))
,
partition  P10   values  less than('J')
(
subpartition   part10   values less than('A'))
);

--echo     partition-4-2-3    多个一级子分区对多个二级分区

drop   table  if  exists   emp;

create TABLE EMP(empno   int,ename   VARCHAR(100),job  VARCHAR(100),mgr   int,hiredate DATE,sal   float(9,0),comm   float(9,0),deptno  int,
comid   int)
partition by range columns(ename)
subpartition by range columns(job)
(partition P1 values  less than('M')

(subpartition  part01   values  less than('A'),
subpartition  part02   values  less than('B'),
subpartition  part03   values  less than('C'),
subpartition  part04   values  less than('D'),
subpartition   part05   values  less than('E')),

partition  P2   values  less than('Z')
(subpartition  part06   values  less than('A'),
subpartition   part07   values  less than('B'),
subpartition   part08   values  less than('C'),
subpartition   part09   values  less than('D'),
subpartition   part10   values  less than('E'))
);


--echo     partition-4-2-4    一级分区最大分区数测试

#DROP table   if  exists EMP;
#create table emp(ob_num varchar(10),ob_name varchar(20),ob_room varchar(3),ob_score int) partition by hash(ob_score)    PARTITIONS 7100;

#DROP table   if  exists EMP;
#create table emp(ob_num varchar(10),ob_name varchar(20),ob_room varchar(3),ob_score int) partition by hash(ob_score)    PARTITIONS 8192;


drop   table  if  exists   emp;
create TABLE   emp(empno   int,ename   VARCHAR(100) ,job  VARCHAR(100),mgr   int ,hiredate DATE,sal   float(8,0) ,comm   int ,deptno  int,comid   int)partition by  range columns(empno,deptno)
subpartition by hash(deptno)(partition p0 values  less than(15,100)(subpartition part01,subpartition part02,subpartition part03),partition p1 values  less than(500,100)(subpartition part04,subpartition part05,subpartition part06));


INSERT INTO emp VALUES(1,'SMITH','CLERK',7902,'1980-12-12',800,NULL,10,9999);
INSERT INTO emp VALUES(2,'ALLEN','SALESMAN',7698,'1981-12-12',1600,300,20,9999);
INSERT INTO emp VALUES(3,'WARD','SALESMAN',7698,'1982-12-12',1250,500,30,9999);

INSERT INTO emp VALUES(100,'BLAKE','MANAGER',7839,'1985-12-12',2850,NULL,10,9999);
INSERT INTO emp VALUES(200,'CLARK','MANAGER',7839,'1986-12-12',2450,NULL,20,9999);
INSERT INTO emp VALUES(300,'SCOTT','ANALYST',7566,'1987-12-12',3000,NULL,30,9999);
select * from emp partition(p0) order by   empno,sal,job,hiredate;
select * from emp partition(p1) order by   empno,sal,job,hiredate;

--echo    partition-5-1     contact
SELECT CONCAT(ename,job) from emp order by   empno,job,sal;

--echo     partition-5-2   instr
select instr(ename,'S') from emp order by   empno,job,sal;


--echo     partition-5-3   length
select length(ename) from emp order by   empno,job,sal;

--echo     partition-5-4   nvl
select   nvl(e.comm,1000)  eee   from     emp  e   order by eee;

--echo     partition-5-5   replace
select replace(ename,'S','中国') from emp order by   empno,job,sal;


--echo     partition-5-6   abs
select abs(comm-sal) from emp order by   empno,job,sal;

--echo     partition-5-7   ceil
select ceil(avg(sal)) from emp order by   empno,job,sal;

--echo     partition-5-8   floor
select floor(avg(sal)) from emp order by   empno,job,sal;

--echo     partition-5-9  trunc     函数不存在
#select trunc(avg(sal)) from emp order by   empno,job,sal;


--echo     partition-5-10  round
select round(avg(sal),2) from emp order by   empno,job,sal;

