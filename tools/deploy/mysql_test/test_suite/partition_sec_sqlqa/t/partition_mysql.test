--echo   partition-6-1-1-1-1    数字类型   range

drop   table  if  exists   emp001;
create TABLE   EMP001(c1 int primary key, c2 int, c3 int)
partition by range(c1)
(
partition    bujige values  less than(10),
PARTITION  jige      values  less than(1000),
partition     youxiu  values  less than(maxvalue)
);


drop   table  if  exists   emp002;
create TABLE   EMP002(c1 int primary key, c2 int, c3 int)
partition by range(c1)
(
partition    bujige values  less than(10),
PARTITION  jige      values  less than(1000),
partition     youxiu  values  less than(maxvalue)
);

