--echo   partition-2-3-1   修改后的数据符合本子分区要求
UPDATE  EMP001 e   SET   e.empno    =10   WHERE    e.ename = 'CLARK';
select * from EMP001 partition(p0) order by   empno,sal,job,hiredate;

UPDATE  EMP003 e   SET   e.empno    =2   WHERE    e.empno = 1;
select * from EMP003 partition(p0) order by   empno,sal,job,hiredate;

--echo   partition-2-3-2   修改后的数据符合其他子分区要求
--error  1526
UPDATE  EMP001 e   SET  e.empno    =501    WHERE    e.ename = 'CLARK';

--error  1526
UPDATE  EMP003 e   SET   e.empno    =10000   WHERE    e.empno = 1000;


--echo   partition-2-3-3   修改后的数据不符合其子分区要求
