创建局部前缀索引
drop   table  if  exists   emp001;
create TABLE EMP001(empno   int,ename   VARCHAR(100),job  VARCHAR(100),mgr   int,hiredate DATE,sal   float(9,0),comm   float(9,0),deptno  int,
comid   float)
partition by range(empno)
subpartition by range(deptno)
(partition p001 values  less than(15)
(subpartition  part01   values  less than(15),
subpartition   part02   values  less than(35)),
partition  p002   values  less than(2000)
(subpartition  part03   values  less than(15),
subpartition   part04   values  less than(35))
);
