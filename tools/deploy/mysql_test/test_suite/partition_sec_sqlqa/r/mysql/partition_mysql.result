分区表的常用sql功能
drop   table  if  exists   emp001;
create TABLE   EMP001(empno   int,ename   VARCHAR(100) ,job  VARCHAR(100),mgr   int ,hiredate DATE,sal   float(8,0) ,comm   int ,deptno  int,comid   int)
partition by  range columns(empno,deptno)
subpartition by hash(empno)(partition p0 values  less than(15,100)
(subpartition part01,subpartition part02,subpartition part03),partition p1 values  less than(500,100)(subpartition part04,subpartition part05,subpartition part06));
