(partition p0(subpartition part01  values  less than(15,100),subpartition part02 values  less than(25,1000),subpartition part03 values  less than(35,6000))
,partition p1(
subpartition part04  values  less than(15,100),
subpartition part05 values   less than(25,1000),
subpartition part06 values   less than(35,2000),
subpartition part07 values   less than(45,3000),
subpartition part08 values   less than(55,6000)));
