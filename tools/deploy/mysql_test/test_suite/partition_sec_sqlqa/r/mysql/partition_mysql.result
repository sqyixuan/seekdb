drop   table  if  exists   emp001;
create TABLE   EMP001(c1   int,c2  int ,c3 DATE)partition by list(c1)
subpartition by hash(c2)
(
partition p0 values in  (1,2,3)(
subpartition part01,
subpartition part03
),
partition p1 values in  (10,20,30)(
subpartition part05,
subpartition part06)
);
drop   table  if  exists   emp002;
create TABLE   EMP002(c1   int,c2  int ,c3 DATE);
EXPLAIN  select * FROM  emp001  t1,   emp002  t2 where t1.c2 = t2.c2   and   t1.c1 =  t2.c1  and  t1.c1 in(1,10);
