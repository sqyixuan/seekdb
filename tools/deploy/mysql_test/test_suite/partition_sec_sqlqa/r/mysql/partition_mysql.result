drop   table  if  exists   emp001;
create table emp001 (c1 int primary key, c2 int, c3 int) partition by range(c1)
(
partition p0 values less than (100),
partition p1 values less than (200),
partition p2 values less than (300),
partition p3 values less than (400)
);
drop   table  if  exists   emp002;
create table emp002 (c1 int primary key, c2 int, c3 int) partition by range(c1)
(
partition p0 values less than (100),
partition p1 values less than (150),
partition p2 values less than (200),
partition p3 values less than (300),
partition p4 values less than (400)
);
EXPLAIN  select * from  emp001  t1,  emp002  t2 where t1.c1=t2.c1 and t1.c1>100  and   t2.c1>150;
