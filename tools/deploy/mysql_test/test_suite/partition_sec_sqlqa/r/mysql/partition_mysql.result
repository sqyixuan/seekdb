partition-7-2-1 无参数的函数
drop function  IF EXISTS salemp001;//
CREATE FUNCTION salemp001()RETURNS DOUBLE
BEGIN
DECLARE ag DOUBLE DEFAULT 0;
SELECT  AVG(SAL) INTO ag  FROM emp e;
RETURN ag;
end
//
SELECT salemp001();//
salemp001()
2163.3333333333335
partition-7-2-2    2.有参数的函数，并把函数的返回值当做参数
drop function  IF EXISTS salemp002;//
CREATE FUNCTION salemp002(saller002 DOUBLE) RETURNS DOUBLE
BEGIN
DECLARE ag DOUBLE DEFAULT 0;#定义局部变量并初始化
SELECT  AVG(SAL) INTO ag   FROM emp e  where  e.sal >saller002;#为局部变量赋值
RETURN ag;
end
//
SELECT salemp002(salemp001());//
salemp002(salemp001())
2794.4444444444443
