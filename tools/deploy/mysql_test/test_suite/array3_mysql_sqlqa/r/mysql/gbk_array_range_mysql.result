DROP MATERIALIZED VIEW LOG ON tt4;
CREATE MATERIALIZED VIEW LOG ON tt4 WITH PRIMARY KEY, ROWID,SEQUENCE(d,c2,c3,c4,v) INCLUDING NEW VALUES;
DROP MATERIALIZED VIEW  mv1;
create materialized view mv1(primary key(id1))  REFRESH FAST  as 
select t1.id as id1,t2.id as id2 , array_range(t1.id) v1,array_range(t2.id,t1.id,t1.id) v2 from tt4 t1 inner join tt4 t2 on array_range(t1.id)=array_range(t2.id);
