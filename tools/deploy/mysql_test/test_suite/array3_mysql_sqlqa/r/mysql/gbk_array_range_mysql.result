drop table if exists tt4;
CREATE TABLE tt4 (id int primary key, d varchar(50), c2 int[],c3 array(float unsigned),c4 varchar(256)[][],v vector(2));
drop view if exists vtt4;
create view vtt4 as select * from tt4;
