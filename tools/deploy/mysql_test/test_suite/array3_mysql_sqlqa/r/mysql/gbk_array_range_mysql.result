drop table if exists tt3;
create table tt3(id int  primary key,a0 BOOL ,a1 BOOLEAN ,a2 TINYINT unsigned,a3 SMALLINT unsigned,a4 MEDIUMINT unsigned, a5 INTEGER unsigned,a6 BIGINT unsigned,a7 SERIAL );
drop view if exists vtt3;
create view vtt3 as select * from tt3;
