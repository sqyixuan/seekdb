drop table if exists tt3;
create table tt3(id int ,a0 BOOL ,a1 BOOLEAN ,a2 TINYINT unsigned,a3 SMALLINT unsigned,a4 MEDIUMINT , a5 INTEGER unsigned,a6 BIGINT ,a7 SERIAL )PARTITION BY range COLUMNS(a7)(
PARTITION p0 values less than(19),
PARTITION p1 values less than(25),
PARTITION p2 values less than(30)
);
drop view if exists vtt3;
create view vtt3 as select * from tt3;
insert into tt3 values(1,2,1,3,5,5,8,9,10);
