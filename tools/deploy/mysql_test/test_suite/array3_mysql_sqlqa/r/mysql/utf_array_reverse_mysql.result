DROP MATERIALIZED VIEW  mv1;
create materialized view mv1  REFRESH FAST  as 
select t1.id as id1,t2.id as id2 ,reverse(t1.c2) a0,reverse(t1.c3) a1,reverse(t1.c4) a2,reverse(t2.v) v from tt4 t1 inner join tt4 t2 on t1.c3=t2.c3;
