drop PROCEDURE p_test01;
CREATE  PROCEDURE p_test01()
begin
declare  a int;
declare  b double;
select array_sum([1,2,4,5,5]);
select array_sum([1,2,4,5,5]) into a;
select a;
select array_sum(a1) into b from tt5 where id=1;
select b;
end;
