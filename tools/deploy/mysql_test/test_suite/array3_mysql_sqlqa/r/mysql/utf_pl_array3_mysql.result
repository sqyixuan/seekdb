drop trigger tr_test;
CREATE  trigger tr_test after insert on tt4
for each row 
BEGIN
declare i int;
declare i1 int;
select  array_sum([1,2,34]) into i;
select  array_position([['test'],['test1']],['test1']) into i1;
insert into tt3 values(array_sum([1,2,3]),array_difference([1,2,3,4,5,6,6]),array_slice([29233E-4,2.3],1),reverse(['test','test1']));
