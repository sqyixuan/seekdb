DROP MATERIALIZED VIEW  mv1;
create materialized view mv1  REFRESH FAST  as 
select t1.id as id1,t2.id as id2 ,array_slice(t1.c2,t2.id,t2.id) a0,array_slice(t1.c3,t2.id,t2.id) a1,array_slice(t1.c4,t2.id,t2.id) a2,array_slice(t2.v,t2.id,t2.id) v from tt4 t1 inner join tt4 t2 on array_slice(t1.c2,t1.id)=array_slice(t2.c2,t2.id);
