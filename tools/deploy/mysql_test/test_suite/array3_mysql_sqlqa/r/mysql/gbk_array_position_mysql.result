drop table if exists tt3;
CREATE TABLE tt3 (id int primary key, d varchar(50), c2 int[],c3 array(float unsigned),c4 varchar(256)[][],v vector(2)) partition by hash(id);
drop view if exists vtt3;
create view vtt3 as select * from tt3;
