purge recyclebin;
drop database IF EXISTS oblrp;
create database oblrp character set gbk;
use oblrp;
set names gbk;
set timestamp = 1600000000;
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;
SET SESSION group_concat_max_len = 100000000;
result_format: 4
drop table tt1;
create table tt1(id int primary key,c1 array(int), c2 array(varchar(256)), c3 array(tinyint), c4 array(bigint), c5 array(float), c6 array(double), c7 array(smallint),v array(vector(2))) character set gbk;
