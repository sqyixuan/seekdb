DROP MATERIALIZED VIEW LOG ON tt4;
CREATE MATERIALIZED VIEW LOG ON tt4 WITH PRIMARY KEY, ROWID,SEQUENCE(a0,a1,a2,v) INCLUDING NEW VALUES;
DROP MATERIALIZED VIEW  mv1;
create materialized view mv1  REFRESH FAST  as 
select t1.id as id1,t2.id as id2 ,array_difference(t1.a0) a0,array_difference(t1.a1) a1,array_difference(t1.a2) a2,array_difference(t2.v) v from tt4 t1 inner join tt4 t2 on array_difference(t1.a0)=array_difference(t2.a0);
bug 2025022500107329596   《[obmysql_array3]outlow 存储，创建物化视图后，写入array等数据到基本表中,ob报1235》
insert into tt4 values(6,'[]','[]','[]','[1,2,3,5]');
call DBMS_MVIEW.REFRESH('mv1','f');
call DBMS_MVIEW.REFRESH('mv1','F');
