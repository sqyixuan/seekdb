#ddl
#create table /view
#create table/view as 
drop table if exists tt3;
create table tt3(id int  primary key,a0 int[],a1 float[],a2 double[],v vector(4));
drop view if exists vtt3;
create view vtt3 as select * from tt3;
insert into tt3 values(1,'[1,2,4,5]','[1.2,5456E-3]','[-1.2,5456E-3]',[1,2,3,4]);
insert into tt3 values(2,'[1,2,4,5]','[1.2,5456E-3]','[-1.2,5456E-3]',[1,2,3,4]);
insert into tt3 values(3,null,null,null,null);
insert into tt3(id) values(4);
insert into tt3 values(5,'[]','[]','[]','[1,2,3,5]');
select array_difference(a0),array_difference(a1),array_difference(a2),array_difference(v) from tt3;
drop table if exists tt4;
create table tt4 as select array_difference([100,160,-200]) a;
desc tt4;
insert into tt4 values([1,2,46,-8]);
select * from tt4;
delete from tt4;
truncate tt4;

drop table if exists tt4;
create table tt4 as select array_difference(a0) a0,array_difference(a1) a1,array_difference(a2) a2 ,array_difference(v) v from tt3 ;
desc tt4;
insert into tt4 values('[1,2,4,5]','[1.2,5456E-3]','[-1.2,5456E-3]',[1,2,3,4]);
select * from tt4;
delete from tt4;
truncate tt4;
drop view if exists vtt4;
create view vtt4 as select array_difference([100,160,-200]) a;
