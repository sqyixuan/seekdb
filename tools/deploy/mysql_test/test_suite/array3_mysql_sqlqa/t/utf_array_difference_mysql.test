--error 0,9757
DROP MATERIALIZED VIEW  mv1;
create materialized view mv1  REFRESH FAST  as 
select t1.id as id1,t2.id as id2 ,array_difference(t1.a0) a0,array_difference(t1.a1) a1,array_difference(t1.a2) a2,array_difference(t2.v) v from tt4 t1 inner join tt4 t2 on array_difference(t1.a0)=array_difference(t2.a0);
