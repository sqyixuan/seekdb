#sql场景
#select
drop table if exists tt3;
CREATE TABLE tt3 (id int primary key, d varchar(50), c2 int[],c3 array(float),c4 varchar(256)[][],v vector(2)) partition by hash(id);
insert into tt3 values(1,1,[1,2,3,5],[2.123,2.123,3.123,4.123],[['中文ing123',1,'1']],[1,23]);
insert into tt3 values(2,2,[2,3,4,5],[2.123,2.123,3.123,4.123],[[null,'a','sss']],[1,23]);
insert into tt3 values(3,3,[3,3,3,3],[3.123,2.123,3.123,4.123],[['null','a','sss'],null],[1,23]);
insert into tt3 values(4,4,[2,3,4,5],[4.123,2.123,3.123,4.123],[[2,3,4,5],null],[1,23]);
insert into tt3 values(5,null,null,null,null,null);
insert into tt3(id) values(7);
insert into tt3 values(8,8,'[]','[]','[[]]','[1,2]');
insert into tt3 values(9,9,'[-12,7347]','[1,2,5,6]',[[1,'test'],[2,3,NULL],NULL],'[25,-50]');

drop view if exists vtt3;
create view vtt3 as select * from tt3;
select array_difference(c2) c2,array_difference(c3) c3,array_difference(v) v from tt3 where id  in (1,2,3,4,5,7,8);
select *,array_difference(c2) c2,array_difference(c3) c3,array_difference(v) v from vtt3 where id  in (1,2,3,4,5,7,8);
#order by
--error 5083
select *,array_difference(c2) c2,array_difference(c3) c3,array_difference(v) v from tt3 where id  in (1,2,3,4,5,7,8) ORDER BY array_difference(c2);
--error 5083
select *,array_difference(c2) c2,array_difference(c3) c3,array_difference(v) v from vtt3 where id  in (1,2,3,4,5,7,8) ORDER BY array_difference(c2) desc;

select *,array_difference(c2) c2,array_difference(c3) c3,array_difference(v) v from tt3 where id  in (1,2,3,4,5,7,8) ORDER BY array_difference([1,2,3,4]) desc;
--echo bug 2024121300106464859   《[obmysql_array]order by 两列 含有array类型，ob未判断校验》
--error 5083
select *,array_difference(c2) cc2,array_difference(c3) c3,array_difference(v) v from tt3 where id  in (1,2,3,4,5,7,8) ORDER BY d desc ,c2 asc;
#group by
--error 5083
select *,array_difference(c2) ,array_difference(c3) ,array_difference(v)  from tt3 where id  in (1,2,3,4,5,7,8) group by array_difference(c2);
--error 5083
select *,array_difference(c2) ,array_difference(c3) ,array_difference(v)  from tt3 where id  in (1,2,3,4,5,7,8) group by array_difference(c2) ,c3;

select *,array_difference(c2) ,array_difference(c3) ,array_difference(v)  from tt3 where id  in (1,2,3,4,5,7,8) group by id,d;
--error 5083
select *,array_difference(c2) ,array_difference(c3) ,array_difference(v)  from tt3 where id  in (1,2,3,4,5,7,8) group by id,d having  array_difference(c3)>array_difference(c3);
--echo bug 2024121300106464859   《[obmysql_array]order by 两列 含有array类型，ob未判断校验》
--error 5083
select *,array_difference(c2) ,array_difference(c3) ,array_difference(v)  from tt3  where id  in (1,2,3,4,5,7,8)  group by id,d order by d,c2 ;
--echo bug 2024121300106464859   《[obmysql_array]order by 两列 含有array类型，ob未判断校验》
--error 5083
select *,array_difference(c2) ,array_difference(c3) ,array_difference(v)  from vtt3  where id  in (1,2,3,4,5,7,8)  group by id,d order by d,c2 ;
#distinct
--error 5083
select distinct array_difference(c2)  from tt3 where id  in (1,2,3,4,5,7,8) ;
--error 5083
select distinct array_difference(c2)  from vtt3 where id  in (1,2,3,4,5,7,8) ;

--error 5083
select distinct array_difference(t1.v) b from tt3 t1 inner join tt3 t2 on array_difference(t1.c2) =array_difference(t2.c2);

#limit
select *, array_difference(c2) b from tt3 limit 1;
select *, array_difference(t1.v) b from tt3 t1 inner join tt3 t2 on array_difference(t1.c2) =array_difference(t2.c2)  limit 2;
#with as
WITH Alice_Students AS (
 select *, array_difference(c2) b from tt3
)
SELECT * FROM Alice_Students;
WITH Alice_Students AS (
 select *, array_difference(v) b from vtt3
)
SELECT * FROM Alice_Students;

WITH Alice_Students AS (
select  array_difference(t1.v) b from tt3 t1 inner join tt3 t2 on array_difference(t1.c2) =array_difference(t2.c2)
)
SELECT * FROM Alice_Students;

WITH Alice_Students AS (
 select *, array_difference([1,2,3,4,5,6,7,8]) b from vtt3
)
SELECT * FROM Alice_Students;

#case when
SELECT CASE array_difference(t1.c2) WHEN array_difference(t1.c2) THEN  array_difference(t1.c2) WHEN  array_difference(t1.c3)  THEN  array_difference(t1.c3) END from tt3 t1;
SELECT CASE array_difference(t1.c2) WHEN array_difference(t1.c2) THEN  array_difference(t1.c2) WHEN  array_difference(t1.c3)  THEN  array_difference(t1.c3) else array_difference([1,2,3,4,5]) END from tt3 t1;
SELECT CASE 'test' WHEN 'test' THEN  array_difference(array_difference([1,2,3,4,59])) WHEN  'test1'  THEN  array_difference(array_range(20)) else array_difference(array_range(30)) END;
SELECT CASE array_difference(array_range(t1.id)) WHEN array_difference(array_range(t1.id)) THEN  array_difference(array_range(t1.id)) WHEN  array_difference(array_range(t1.id))  THEN  array_difference(array_range(t1.id)) END from tt3 t1;

SELECT CASE array_difference(array_range(t2.id)) WHEN array_difference(array_range(t1.id)) THEN  array_difference(array_range(t2.id))
 WHEN  array_difference(array_range(t1.id))  THEN  array_difference(array_range(t2.id)) END from tt3 t1 ,tt3 t2;

SELECT CASE array_difference(array_range(t1.id)) WHEN array_difference(array_range(t1.id)) THEN  array_difference(array_range(t2.id))
 WHEN  array_difference(array_range(t1.id))  THEN  array_difference(array_range(t2.id)) END from tt3 t1 ,tt3 t2;


