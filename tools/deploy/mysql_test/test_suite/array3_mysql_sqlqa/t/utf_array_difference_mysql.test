#join
drop table if exists tt3;
create table tt3(id int primary key,id1 bigint unsigned,a int[]);
drop view if exists vtt3;
create view vtt3 as select * from tt3;
insert into tt3 values(1,241,[1,3,4]);
insert into tt3 values(2,211,[12,3]);

drop table if exists tt4;
create table tt4(id int ,id1 bigint unsigned,a bigint[]);
drop view if exists vtt4;
create view vtt4 as select * from tt4;
insert into tt4 values(1,241,[1,2,3,4,5]);
insert into tt4 values(2,211,[12,3]);

select t3.*,array_difference(t3.a) from tt3 t3 inner join tt4 t4 on array_difference(t3.a)=array_difference(t4.a);
select t3.*,array_difference(t3.a) from tt3 t3 right join tt4 t4 on  array_difference(t3.a)=array_difference(t4.a);
select t3.*,array_difference(t3.a) from tt3 t3 left join tt4 t4 on  array_difference(t3.a)=array_difference(t4.a);
select t3.*,array_difference(t3.a) from tt3 t3  join tt4 t4 on  array_difference(t3.a)=array_difference(t4.a);
#union
select t3.*,array_difference(t3.a) from tt3 t3 inner join tt4 t4 on array_difference(t3.a)=array_difference(t4.a) union select t3.*,array_difference(t3.a) from tt3 t3 inner join tt4 t4 on array_difference(t3.a)=array_difference(t4.a);
select t3.*,array_difference(t3.a) from tt3 t3 right join tt4 t4 on  array_difference(t3.a)=array_difference(t4.a) MINUS select t3.*,array_difference(t3.a) from tt3 t3 right join tt4 t4 on  array_difference(t3.a)=array_difference(t4.a);
select t3.*,array_difference(t3.a) from tt3 t3 left join tt4 t4 on  array_difference(t3.a)=array_difference(t4.a) UNION ALL select t3.*,array_difference(t3.a) from tt3 t3 left join tt4 t4 on  array_difference(t3.a)=array_difference(t4.a);
select t3.*,array_difference(t3.a) from tt3 t3  join tt4 t4 on  array_difference(t3.a)=array_difference(t4.a) INTERSECT select t3.*,array_difference(t3.a) from tt3 t3  join tt4 t4 on  array_difference(t3.a)=array_difference(t4.a);

