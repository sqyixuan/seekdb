#case when
SELECT CASE array_slice(t1.c2,1) WHEN array_slice(t1.c2,1) THEN  array_slice(t1.c2,1) WHEN  array_slice(t1.c3,1)  THEN  array_slice(t1.c3,1) END from tt3 t1;
SELECT CASE array_slice(t1.c2,1) WHEN array_slice(t1.c2,1) THEN  array_slice(t1.c2,1) WHEN  array_slice(t1.c3,1)  THEN  array_slice(t1.c3,1) else array_slice([1,2,3,4,5],1) END from tt3 t1;
SELECT CASE 'test' WHEN 'test' THEN  array_slice([1,2,3,4,59],2) WHEN  'test1'  THEN  array_slice(array_range(20),3) else array_slice(array_range(30),-4,5) END;
SELECT CASE array_slice(array_range(t1.id),1) WHEN array_slice(array_range(t1.id),2) THEN  array_slice(array_range(t1.id),2) WHEN  array_slice(array_range(t1.id),2)  THEN  array_slice(array_range(t1.id),3) END from tt3 t1 ;

SELECT CASE array_slice(array_range(t2.id),1) WHEN array_slice(array_range(t1.id),1) THEN  array_slice(array_range(t2.id),1)
 WHEN  array_slice(array_range(t1.id),1,1)  THEN  array_slice(array_range(t2.id),-2,-2) END from tt3 t1 ,tt3 t2;

SELECT CASE array_slice(array_range(t1.id),1) WHEN array_slice(array_range(t1.id),1) THEN  array_slice(array_range(t2.id),1)
 WHEN  array_slice(array_range(t1.id),1)  THEN  array_slice(array_range(t2.id),1) END from tt3 t1 ,tt3 t2;

