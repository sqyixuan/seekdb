[1.7976931348623157E+30,1.2,2.2250738585072014E-308,false],[1,0,32767,0],[[89.5,-78E-1]]);
insert into tt2 values(20,null,null,null,null,null,null,null,null);

drop view if exists vtt2;
create view vtt2 as select * from tt2 order by id;
