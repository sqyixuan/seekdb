drop table if exists tt3;
create table tt3(id int primary key,id1 int unsigned,a float, v vector(2));
drop view if exists vtt3;
create view vtt3 as select * from tt3;
insert into tt3 values(1,1,1.2,[89,97]);
insert into tt3 values(2,2,452.454E-2,[1.2,84.89]);
insert into tt3 values(3,2,452.454E-2,[-1,3]);
insert into tt3 values(4,2,452.454E-2,[-3.402823466E+38,3.402823466E+38]);
select *,array_slice(v,2) from tt3 order by id;
select v,array_slice([v],2) from tt3 order by id;
select [id,id1,a],array_slice([id,id1,a],2) from tt3 order by id;

select [[id,a],v],array_slice([[id,a],v],2) from tt3 order by id;
select [[id,a],v],array_slice([[id,a],v],2) from vtt3 order by id;

drop table if exists tt3;
create table tt3(id int primary key,id1 int unsigned,a float, v vector(2))partition by hash(id);
drop view if exists vtt3;
create view vtt3 as select * from tt3;
insert into tt3 values(1,1,1.2,[89,97]);
insert into tt3 values(2,2,452.454E-2,[1.2,84.89]);
insert into tt3 values(3,2,452.454E-2,[-1,3]);
insert into tt3 values(4,2,452.454E-2,[-3.402823466E+38,3.402823466E+38]);
select *,array_slice(v,2) from tt3 order by id;
select v,array_slice([v],2) from tt3 order by id;
select [id,id1,a],array_slice([id,id1,a],2) from tt3 order by id;
select [[id,a],v],array_slice([[id,a],v],2) from tt3 order by id;
select [[id,a],v],array_slice([[id,a],v],2) from vtt3 order by id;
