drop table if exists tt4;
create table tt4(id int ,id1 bigint unsigned,a bigint[]);
drop view if exists vtt4;
create view vtt4 as select * from tt4;
insert into tt4 values(1,241,[1,2,3,4,5]);
insert into tt4 values(2,211,[12,3]);

select t3.*,array_slice(t3.a,1) from tt3 t3 inner join tt4 t4 on array_slice(t3.a,1)=array_slice(t4.a,1);
select t3.*,array_slice(t3.a,1) from tt3 t3 right join tt4 t4 on  array_slice(t3.a,1)=array_slice(t4.a,1);
select t3.*,array_slice(t3.a,1) from tt3 t3 left join tt4 t4 on  array_slice(t3.a,1)=array_slice(t4.a,1);
select t3.*,array_slice(t3.a,1) from tt3 t3  join tt4 t4 on  array_slice(t3.a,1)=array_slice(t4.a,1);
#union
select t3.*,array_slice(t3.a,1) from tt3 t3 inner join tt4 t4 on array_slice(t3.a,1)=array_slice(t4.a,1) union select t3.*,array_slice(t3.a,1) from tt3 t3 inner join tt4 t4 on array_slice(t3.a,1)=array_slice(t4.a,1);
select t3.*,array_slice(t3.a,1) from tt3 t3 right join tt4 t4 on  array_slice(t3.a,1)=array_slice(t4.a,1) MINUS select t3.*,array_slice(t3.a,1) from tt3 t3 right join tt4 t4 on  array_slice(t3.a,1)=array_slice(t4.a,1);
select t3.*,array_slice(t3.a,1) from tt3 t3 left join tt4 t4 on  array_slice(t3.a,2)=array_slice(t4.a,2) UNION ALL select t3.*,array_slice(t3.a,1) from tt3 t3 left join tt4 t4 on  array_slice(t3.a,1)=array_slice(t4.a,1);
select t3.*,array_slice(t3.a,1) from tt3 t3  join tt4 t4 on  array_slice(t3.a,1)=array_slice(t4.a,1) INTERSECT select t3.*,array_slice(t3.a,1) from tt3 t3  join tt4 t4 on  array_slice(t3.a,1)=array_slice(t4.a,1);

