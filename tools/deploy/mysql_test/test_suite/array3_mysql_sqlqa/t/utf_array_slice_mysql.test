[1.7976931348623157E+308,0, 2.2250738585072014E-308],[-32768,0,32767],[[1,2]]);

insert into tt1 values(2,[-2147483648,0,true, 2147483647,4],['test',false],[127,0,-128,6,77,true],[-9223372036854775808,true,9223372036854775807,775,808,2,0,1],[3.402,false, 0, 1.175,4],
[-1.7976931348623157E+30,1.2,2.2250738585072014E-308,false],[-32768,0,32767,0],[[89.5,-78E-1]]);
insert into tt1 values(3,null,null,null,null,null,null,null,null);
drop view if exists vtt1;
create view vtt1 as select * from tt1 order by id;

drop table if exists tt2;
create table tt2(id int ,c1 array(int unsigned), c2 array(varchar(256)), c3 array(tinyint unsigned), c4 array(bigint unsigned), c5 array(float unsigned), c6 array(double unsigned), c7 array(smallint unsigned),v array(vector(2)))
PARTITION BY range COLUMNS(id)(
PARTITION p0 values less than(19),
PARTITION p1 values less than(25),
PARTITION p2 values less than(30)
);
insert into tt2 values(1,[1,0, 2147483647],['test',null],[127,0,2],[9223372036854775808,9223372036854775809,9223372036854775811,null],[5.4E+2,null,1.584,false,0],
