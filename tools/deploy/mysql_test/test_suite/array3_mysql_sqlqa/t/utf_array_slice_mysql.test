insert into tt3 values(9,9,'[-12,7347]','[1,2,5,6]',[[1,'test'],[2,3,NULL],NULL],'[25,-50]');
drop view if exists vtt3;
create view vtt3 as select * from tt3;
select array_slice(v,id,id) from vtt3;
select array_slice(c2,id,id) from tt3;
select array_slice(c3,id,id) from tt3;
select array_slice(c4,id,id) from tt3;
select array_slice(t2.c3,t1.id,t2.id) from tt3 t1,tt3 t2 where t1.c2=t2.c2;
select array_slice(t2.c3,t1.id,t2.id) from tt3 t1 right join tt3 t2 on t1.c2=t2.c2;
select array_slice(t1.v,t1.id,t2.id) from tt3 t1 right join tt3 t2 on t1.c2=t2.c2;

