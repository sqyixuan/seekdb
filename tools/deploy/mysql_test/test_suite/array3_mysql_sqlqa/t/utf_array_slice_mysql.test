purge recyclebin;
--disable_warnings
drop database IF EXISTS oblrp;
--enable_warnings
create database oblrp;
use oblrp;
set timestamp = 1600000000;
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;
SET SESSION group_concat_max_len = 100000000;
set ob_default_lob_inrow_threshold = 0;
--result_format 4
drop table if exists tt1;
create table tt1(id int primary key,c1 array(int), c2 array(varchar(256)), c3 array(tinyint), c4 array(bigint), c5 array(float), c6 array(double), c7 array(smallint),v array(vector(2)));
insert into tt1 values(1,[-2147483648,0, 2147483647],['test',null,false],[127,0,-128,null],[9223372036854775807,922337203685477580,-922337203685477581],[5.4E+2,-67E-4,1.584,false,0],
[1.7976931348623157E+308,0, 2.2250738585072014E-308],[-32768,0,32767],[[1,2]]);
