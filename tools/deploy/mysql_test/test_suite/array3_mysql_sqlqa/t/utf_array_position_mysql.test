drop table if exists tt3;
create table tt3(a varchar(262144));
insert into tt3 values(repeat('x',262144));
--disable_result_log
select array_position([a,a],a) from tt3;
select array_position([[a],[a]],[a]) from tt3;
--enable_result_log

#向量类型
drop table if exists tt3;
CREATE TABLE tt3 (id int primary key, d varchar(50), c2 array(int unsigned),c3 array(float),c4 varchar(256)[][],v vector(2)) partition by hash(id);
insert into tt3 values(1,1,[1,2],[2.123,2.123,3.123,4.123],[['中文ing123',1,'1']],[1,23]);
insert into tt3 values(2,2,[2,3],[2.123,2.123,3.123,4.123],[[null,'a','sss']],[1,0]);
insert into tt3 values(3,3,[3,3],[3.123,2.123,3.123,4.123],[['null','a','sss'],null],[1,23]);
insert into tt3 values(4,4,[2,3],[4.123,2.123,3.123,4.123],[[2,3,4,5],null],[1,23E-1]);
insert into tt3 values(5,null,null,null,null,null);
insert into tt3 values(6,null,[null],[null],[[null]],[1,23]);
insert into tt3(id) values(7);
insert into tt3 values(8,8,'[]','[]','[[]]','[1,2]');
insert into tt3 values(9,9,'[12,7347]','[1,2,5,6]',[[1,'test'],array_remove(['test'],'test'),[2,3,NULL],NULL,array_remove(['test'],'test')],'[25,-50]');
drop view if exists vtt3;
create view vtt3 as select * from tt3;
select array_position(t1.v,23) from vtt3 t1,tt3 t2 ;
select array_position([t1.v],[23,3]) from vtt3 t1,tt3 t2 ;
select array_position(c2,5) from tt3;
select array_position(v,1) from tt3;
select array_position(v,23E-1) from tt3;


select array_position(v,'1') from tt3;
select array_position(v,'test') from tt3;
select c4,array_position(c4,null) from tt3;
--echo bug 2025012300107114016   《【obmysql_array3】array_position 参数1和参数2 为array 和向量数据，执行相同的sql，返回不同的值》
select [v],array_position([v],c2) from tt3  where id not in (6,8);
select [c2],c3,array_position([c2],c3) from tt3 ;
--echo bug 2025012300107114016   《【obmysql_array3】array_position 参数1和参数2 为array 和向量数据，执行相同的sql，返回不同的值》
--error 7600
select [v],array_position([v],[1,2,3,5]) from tt3 ;
select [v], /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */ array_position([v],[1,2]) from tt3 ;
select [v], /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */ array_position([[1,2]],v) from tt3 ;
select [v], /*+ OPT_PARAM('rowsets_enabled', 'FALSE') */ array_position([[1,2]],v) from tt3 ;
select [v], /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */ array_position([v],[1,2]) from tt3 ;
select [v],v,array_position([v],v) from tt3 ;
select [c2],c3,array_position([c2],c3) from tt3 ;
--echo bug 2025012300107114016   《【obmysql_array3】array_position 参数1和参数2 为array 和向量数据，执行相同的sql，返回不同的值》
select [c2],c3,array_position([c2,v],c2) from tt3 where id not in (6,8);
--echo bug 2025012300107114016   《【obmysql_array3】array_position 参数1和参数2 为array 和向量数据，执行相同的sql，返回不同的值》
select [c2],c3,array_position([c2,v],v) from tt3 where id not in (6,8);
--echo bug 2025012300107114016   《【obmysql_array3】array_position 参数1和参数2 为array 和向量数据，执行相同的sql，返回不同的值》
select [c2],c3,array_position([[c2,v]],[v]) from tt3 where id not in (6,8);
--echo bug 2025011000106964888   《【obmysql_array】多层array元素数值，字符，浮点转化array向量元素，报错》
select [c2],c3,array_position([[c2,v]],[[1,23]]) from tt3 where id not in (6,8);
--echo bug 2025011000106964888   《【obmysql_array】多层array元素数值，字符，浮点转化array向量元素，报错》
select [c2],[v],array_position([[c2],[v]],[[1,23]]) from tt3 ;
select c4,c2 ,array_position(c4,c2) from tt3 ;
select id,d, array_position([id,d],d) from tt3 ;
select id,d, array_position([d,id],d) from tt3 ;


