#sql
#select 
drop table if exists tt3;
CREATE TABLE tt3 (id int primary key, d varchar(50), c2 int[],c3 array(float unsigned),c4 varchar(256)[][],v vector(2)) partition by hash(id);
drop view if exists vtt3;
create view vtt3 as select * from tt3;
insert into tt3 values(1,1,[1,2,3,5],[2.123,2.123,3.123,4.123],[['中文ing123',1,'1']],[1,23]);
insert into tt3 values(2,2,[2,3,4,5],[2.123,2.123,3.123,4.123],[[null,'a','sss']],[1,23]);
insert into tt3 values(3,3,[3,3,3,3],[3.123,2.123,3.123,4.123],[['null','a','sss'],null],[1,23]);
insert into tt3 values(4,4,[2,3,4,5],[4.123,2.123,3.123,4.123],[[2,3,4,5],null],[1,23]);
insert into tt3 values(5,null,null,null,null,null);
insert into tt3(id) values(7);
insert into tt3 values(8,8,'[]','[]','[[]]','[1,2]');
insert into tt3 values(9,9,'[-12,7347]','[1,2,5,6]',[[1,'test'],[2,3,NULL],NULL],'[25,-50]');
insert into tt3 values(10,10,'[1,2,5,6,null]','[197734E-3,2.3,988]','[null,[],[1,"test"],[2,3,NULL],NULL,[]]','[25,-50]');
select * from tt3;

#order by
select *,array_position(c2,id) c2,array_position(c3,id) c3,array_position(v,id) v from tt3 ORDER BY array_position(c2,id);
select *,array_position(c2,id) c2,array_position(c3,id) c3,array_position(v,id) v from tt3 ORDER BY array_position(c2,id),array_position(v,id),array_position(c3,id);
select *,array_position(c2,id) c2,array_position(c3,id) c3,array_position(v,id) v from vtt3 ORDER BY array_position(c2,id);
select *,array_position(c2,id) c2,array_position(c3,id) c3,array_position(v,id) v from vtt3 ORDER BY array_position(c2,id),array_position(v,id),array_position(c3,id);
#group by 
select  array_position(c2,id) c2,array_position(c3,id) c3,array_position(v,id) v from tt3 group BY array_position(c2,id);
select *,array_position(c2,id) cc2,array_position(c3,id) cc3,array_position(v,id) vv from tt3 group by array_position(c2,id),array_position(v,id),array_position(c3,id);
select *,array_position(c2,id) c0,array_position(c3,id) c3,array_position(v,id) v from vtt3 group BY array_position(c2,id);
select *,array_position(c2,id) cc2,array_position(c3,id) cc3,array_position(v,id) vv from vtt3 group by array_position(c2,id),array_position(v,id),array_position(c3,id);
select *,array_position(c2,id) c0,array_position(c3,id) c3,array_position(v,id) vv from tt3 group BY array_position(c2,id) having array_position(v,id)<=3;

#distinct
select distinct array_position(c2,1)  from tt3;
select distinct array_position(c2,1)  from vtt3;
select distinct array_position(t1.v,1) b from tt3 t1 inner join tt3 t2 on array_position(t1.c2,1) =array_position(t2.c2,1);
#limit
select *, array_position(c2,1) b from tt3 limit 1;
select *, array_position(t1.v,4) b from tt3 t1 inner join tt3 t2 on array_position(t1.c2,1) =array_position(t2.c2,1)  limit 2;
#cast 
select cast(array_position(c2,id)as unsigned) from tt1;
select cast(array_position(c2,id)as UNSIGNED) from tt1;
select cast(array_position(c2,id)as char(10)) from tt1;
select cast(array_position(c2,id)as binary(10)) from tt1;
select cast(array_position(c2,id)as SIGNED) from tt1;
select cast(array_position(c2,id)as date) from tt1;
select cast(array_position(c2,id)as DATETIME) from tt1;
select cast(array_position(c2,id)as TIME) from tt1;
select cast(array_position(c2,id)as FLOAT) from tt1;
select cast(array_position(c2,id)as year) from tt1;
select cast(array_position(c2,id)as DOUBLE) from tt1;
select cast(array_position(c2,id)as DECIMAL) from tt1;
select cast(array_position(c2,id)as NUMERIC) from tt1;
select cast(array_position(c2,id)as dec) from tt1;
select cast(array_position(c2,id)as FIXED) from tt1;
--error 3037
select cast(array_position(c2,id)as  point) from tt1;
--error 3037
select cast(array_position(c2,id)as  point) from tt1;
#with as
WITH Alice_Students AS (
 select *, array_position(c2,1) b from tt3
)
SELECT * FROM Alice_Students;
WITH Alice_Students AS (
 select *, array_position(v,1) b from vtt3
)
SELECT * FROM Alice_Students;

WITH Alice_Students AS (
select  array_position(t1.v,2) b from tt3 t1 inner join tt3 t2 on array_position(t1.c2,1) =array_position(t2.c2,1)
)
SELECT * FROM Alice_Students;

WITH Alice_Students AS (
 select *, array_position([1,2,3,4,5,6,7,8],8) b from vtt3
)
SELECT * FROM Alice_Students;

#case when
SELECT CASE array_position(t1.c2,id) WHEN array_position(t1.c2,id) THEN  array_position(t1.c2,id) WHEN  array_position(t1.c3,id)  THEN  array_position(t1.c3,id) END from tt3 t1;
SELECT CASE array_position(t1.c2,id) WHEN array_position(t1.c2,id) THEN  array_position(t1.c2,id) WHEN  array_position(t1.c3,id)  THEN  array_position(t1.c3,id) else array_position([1,2,3,4,5],id) END from tt3 t1;
SELECT CASE 'test' WHEN 'test' THEN  array_position([1,2,3,4,59],2) WHEN  'test1'  THEN  array_position(array_range(20),2) else array_position(array_range(30),3) END;
SELECT CASE array_position(array_range(t1.id),t1.id) WHEN array_position(array_range(t1.id),t1.id) THEN  array_position(array_range(t1.id),t1.id) WHEN  array_position(array_range(t1.id),t1.id)  THEN  array_position(array_range(t1.id),t1.id) END from tt3 t1 ;
SELECT CASE array_position(array_range(t2.id),t1.id) WHEN array_position(array_range(t1.id),t1.id) THEN  array_position(array_range(t2.id),t2.id)
 WHEN  array_position(array_range(t1.id),t2.id)  THEN  array_position(array_range(t2.id),t1.id) END from tt3 t1 ,tt3 t2;
SELECT CASE array_position(array_range(t1.id),t1.id) WHEN array_position(array_range(t1.id),t1.id) THEN  array_position(array_range(t2.id),t2.id)
 WHEN  array_position(array_range(t1.id),t2.id)  THEN  array_position(array_range(t2.id),t2.id) END from tt3 t1 ,tt3 t2;

#子查询
drop table if exists tt3;
CREATE TABLE tt3 (id int primary key, d varchar(50), c2 int[],c3 array(float unsigned),c4 varchar(256)[][],v vector(2)) partition by hash(id);
drop view if exists vtt3;
create view vtt3 as select * from tt3;
insert into tt3 values(1,1,[1,2,3,5],[2.123,2.123,3.123,4.123],[['中文ing123',1,'1']],[1,23]);
insert into tt3 values(2,2,[2,3,4,5],[2.123,2.123,3.123,4.123],[[null,'a','sss']],[1,23]);
insert into tt3 values(3,3,[3,3,3,3],[3.123,2.123,3.123,4.123],[['null','a','sss'],null],[1,23]);
insert into tt3 values(4,4,[2,3,4,5],[4.123,2.123,3.123,4.123],[[2,3,4,5],null],[1,23]);
insert into tt3 values(5,null,null,null,null,null);
insert into tt3(id) values(7);
insert into tt3 values(8,8,'[]','[]','[[]]','[1,2]');
insert into tt3 values(9,9,'[-12,7347]','[1,2,5,6]',[[1,'test'],[2,3,NULL],NULL],'[25,-50]');
insert into tt3 values(10,10,'[1,2,5,6,null]','[197734E-3,2.3,988]','[null,[],[1,"test"],[2,3,NULL],NULL,[]]','[25,-50]');

drop view if exists vtt3;
create view vtt3 as select * from tt3;

select array_position([1,2,3,4,5,5],1) a from (select array_position([1,2,3,4,5,5],5) b);
select array_position([1,2,3,4,5,5],5) a from  dual where array_position([1,2,3,4,5,5],5) in (select array_position([1,2,3,4,5,5],5) b);
select (select array_position(c2,id) from tt3 where id=1);

SELECT (SELECT array_position(c2,id) FROM tt3 where id=1) FROM dual;
SELECT array_position([1,2,3,4,5,5],5)  FROM dual WHERE array_position([1,2,3,4,5,5],4)= (SELECT array_position([1,2,3,4,5,5],4) FROM dual);
SELECT * FROM tt1
 WHERE ROW(id,id) = (SELECT array_position(c1,id), array_position(c2,id) FROM tt2 where id=1 );

#join
drop table if exists tt3;
create table tt3(id int primary key,id1 bigint unsigned,a int[]);
drop view if exists vtt3;
create view vtt3 as select * from tt3;
insert into tt3 values(1,241,[1,3,4]);
insert into tt3 values(2,211,[12,3]);

drop table if exists tt4;
create table tt4(id int ,id1 bigint unsigned,a bigint[]);
drop view if exists vtt4;
create view vtt4 as select * from tt4;
insert into tt4 values(1,241,[1,2,3,4,5]);
insert into tt4 values(2,211,[12,3]);

select t3.*,array_position(t3.a,t3.id) from tt3 t3 inner join tt4 t4 on array_position(t3.a,t3.id)=array_position(t4.a,t4.id);
select t3.*,array_position(t3.a,t3.id) from tt3 t3 right join tt4 t4 on  array_position(t3.a,t3.id)=array_position(t4.a,t4.id);
select t3.*,array_position(t3.a,t3.id) from tt3 t3 left join tt4 t4 on  array_position(t3.a,t3.id)=array_position(t4.a,t4.id);
