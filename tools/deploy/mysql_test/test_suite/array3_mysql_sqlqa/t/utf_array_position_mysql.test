#owner: xuqijia.xqj
#owner group: 多模组
#description:array_position() 语法，使用场景
#tags:array
#author: wb-lrp01026356
purge recyclebin;
--disable_warnings
drop database IF EXISTS oblrp;
--enable_warnings
create database oblrp;
use oblrp;
set timestamp = 1600000000;
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;
SET SESSION group_concat_max_len = 100000000;
set ob_default_lob_inrow_threshold = 0;
--sorted_result
--result_format 4
drop table if exists tt1;
create table tt1(id int primary key,c1 array(int), c2 array(varchar(256)), c3 array(tinyint), c4 array(bigint), c5 array(float), c6 array(double), c7 array(smallint),v array(vector(2)));
insert into tt1 values(1,[-2147483648,0, 2147483647],['test',null,false],[127,0,-128,null],[9223372036854775807,922337203685477580,-922337203685477581],[5.4E+2,-67E-4,1.584,false,0],
[1.7976931348623157E+308,0, 2.2250738585072014E-308],[-32768,0,32767],[[1,2]]);
insert into tt1 values(4,[-2147483648,0, 2147483647],['test'],[127,0,-128],[-9223372036854775808,9223372036854775807,775,808,2,0],[5.4E+2,-67E-4,1.584,false,0],
[1.7976931348623157E+308,0, 2.2250738585072014E-308],[-32768,0,32767],[[1,2]]);

insert into tt1 values(2,[-2147483648,0,true, 2147483647,4],['test',false],[127,0,-128,6,77,true],[-9223372036854775808,true,9223372036854775807,775,808,2,0,1],[3.402,false, 0, 1.175,4],
[-1.7976931348623157E+30,1.2,2.2250738585072014E-308,false],[-32768,0,32767,0],[[89.5,-78E-1]]);
insert into tt1 values(3,null,null,null,null,null,null,null,null);
insert into tt1 values(6,'[]','[]','[]','[]','[]','[]','[]','[[]]');
insert into tt1(id) values(5);
drop view if exists vtt1;
create view vtt1 as select * from tt1;

drop table if exists tt2;
create table tt2(id int ,c1 array(int unsigned), c2 array(varchar(256)), c3 array(tinyint unsigned), c4 array(bigint unsigned), c5 array(float unsigned), c6 array(double unsigned), c7 array(smallint unsigned),v array(vector(2)))
PARTITION BY range COLUMNS(id)(
PARTITION p0 values less than(19),
PARTITION p1 values less than(25),
PARTITION p2 values less than(30)
);
insert into tt2 values(1,[1,0, 2147483647],['test',null],[127,0,2],[9223372036854775808,9223372036854775809,9223372036854775811,null],[5.4E+2,null,1.584,false,0],
