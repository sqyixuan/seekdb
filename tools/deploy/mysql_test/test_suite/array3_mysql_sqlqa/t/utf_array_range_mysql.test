#参数从表/视图获取整型
drop table if exists tt3;
create table tt3(id int unsigned primary key,a0 BOOL,a1 BOOLEAN ,a2 TINYINT,a3 SMALLINT,a4 MEDIUMINT, a5 INTEGER,a6 BIGINT,a7 SERIAL UNIQUE ,index index_1(a2),UNIQUE index index_2(a5));
drop view if exists vtt3;
create view vtt3 as select * from tt3;
insert into tt3 values(1,2,1,3,5,5,8,9,10);
insert into tt3 values(2,-2,-2,-2,-2,-2,-2,-2,11);
insert into tt3 values(3,null,null,null,null,null,null,null,null);
insert into tt3(id) values(4);
select id, array_range(id,10,2) from tt3 order by id;
select a0, array_range(a0,10,2) from tt3 order by id;
select a1, array_range(a1,-10,-2) from tt3 order by id;
select a2, array_range(a2,-10,-2) from tt3 order by id;
select a3, array_range(a3,-10,-2) from tt3 order by id;
select a4, array_range(a4,-10,-2) from tt3 order by id;
select a5, array_range(a5,-10,-2) from tt3 order by id;
select a6, array_range(a6,-10,-2) from tt3 order by id;
select *,a7, array_range(a7,-10,-2) from tt3 order by id;

select *,id, array_range(id) from tt3 order by id;

select t1.id, array_range(t1.id,10,t2.id) from tt3 t1,tt3 t2 order by t2.id;

--error 1210
select *,a0, array_range(a0) from tt3 order by id;
select *,a0, array_range(a0) from tt3 where id in(1,3,4) order by id ;
select *,a0, array_range(10,a0,-1) from tt3 order by id;
select *,a0, array_range(10,a0,-1) from vtt3 order by id;

