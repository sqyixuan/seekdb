select t3.*,array_range(t3.id) from tt3 t3 inner join tt1 t1 on array_range(t3.id)=array_range(t1.id);
select t3.*,array_range(t3.id) from tt3 t3 right join tt1 t1 on array_range(t3.id)=array_range(t1.id);
select t3.*,array_range(t3.id) from tt3 t3 left join tt1 t1 on array_range(t3.id)=array_range(t1.id);
select t3.*,array_range(t3.id) from tt3 t3  join tt1 t1 on array_range(t3.id)=array_range(t1.id);
#union
select t3.*,array_range(t3.id) from tt3 t3 inner join tt1 t1 on array_range(t3.id)=array_range(t1.id) union select t3.*,array_range(t3.id) from tt3 t3 right join tt1 t1 on array_range(t3.id)=array_range(t1.id);
select t3.*,array_range(t3.id) from tt3 t3 inner join tt1 t1 on array_range(t3.id)=array_range(t1.id) MINUS select t3.*,array_range(t3.id) from tt3 t3 right join tt1 t1 on array_range(t3.id)=array_range(t1.id);
select t3.*,array_range(t3.id) from tt3 t3 inner join tt1 t1 on array_range(t3.id)=array_range(t1.id) UNION ALL select t3.*,array_range(t3.id) from tt3 t3 right join tt1 t1 on array_range(t3.id)=array_range(t1.id);
select t3.*,array_range(t3.id) from tt3 t3 inner join tt1 t1 on array_range(t3.id)=array_range(t1.id) INTERSECT select t3.*,array_range(t3.id) from tt3 t3 right join tt1 t1 on array_range(t3.id)=array_range(t1.id);

