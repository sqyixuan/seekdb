#order by 
drop table if exists tt3;
create table tt3(id int primary key,id1 bigint unsigned,a int[]);
drop view if exists vtt3;
create view vtt3 as select * from tt3;
insert into tt3 values(1,241,[1,3,4]);
insert into tt3 values(2,211,[12,3]);
--error 5083
select *,array_range(20) from tt3 order by array_range(id);
select *,array_range(20) from tt3 order by array_range(20);
--error 5083
select *,array_range(t2.id1) from tt3 t1,tt3 t2 order by array_range(t1.id);
#group by
--error 5083
select *,array_range(id),array_range(id1) a from tt3 group by array_range(id1);
--error 5083
select *,array_range(id),array_range(id1) a from tt3 group by array_range(id1),array_range(id);
--error 5083
select *,array_range(id),array_range(id1) a from tt3 group by array_range(id1),array_range(id);
--error 5083
select *,array_range(t4.id),array_range(t3.id1) a from tt3 t3,tt3 t4 group by array_range(t3.id1),array_range(t4.id);

select *,array_range(id),array_range(id1) a from tt3 group by id having array_range(id1)=array_range(id1);

select *,array_range(t4.id),array_range(t3.id1) a from tt3 t3,tt3 t4 group by t4.id,t3.id having array_range(t3.id1)=array_range(t4.id1);
--error 5083
select *,array_range(t4.id),array_range(t3.id1) a from tt3 t3,tt3 t4 group by t4.id,t3.id having array_range(t3.id1)>array_range(t4.id1);
select *,array_range(t4.id),array_range(t3.id1) a from tt3 t3,tt3 t4 group by t4.id,t3.id having array_range(t3.id1)=[123];
#distinct
--error 5083
select distinct array_range(id) b from tt3;
--error 5083
select distinct array_range(id) b from vtt3;
--error 5083
select distinct array_range(t2.id) b from tt3 t1 inner join tt3 t2 on array_range(t1.id1)=array_range(t2.id1);
#limit
select *, array_range(id) b from tt3 limit 1;
select *, array_range(t2.id) b from tt3 t1 inner join tt3 t2 on array_range(t1.id1)=array_range(t2.id1) limit 2;
#with as
WITH Alice_Students AS (
 select *, array_range(id) b from tt3
)
SELECT * FROM Alice_Students;
WITH Alice_Students AS (
 select *, array_range(id) b from vtt3
)
SELECT * FROM Alice_Students;

WITH Alice_Students AS (
select t1.*, array_range(t2.id) b from tt3 t1 inner join tt3 t2 on array_range(t1.id1)=array_range(t2.id1)
)
SELECT * FROM Alice_Students;
#case when
SELECT CASE array_range(t1.id1) WHEN array_range(t1.id1) THEN  array_range(t1.id1) WHEN  array_range(t1.id)  THEN  array_range(t1.id) END from tt3 t1;
SELECT CASE array_range(10) WHEN array_range(t1.id1) THEN  array_range(t1.id1) WHEN  array_range(t1.id)  THEN  array_range(t1.id)  else array_range(10) END from tt3 t1;
SELECT CASE array_range(10) WHEN array_range(10) THEN  array_range(10) WHEN  array_range(20)  THEN  array_range(20) else array_range(30) END;
SELECT CASE 'test' WHEN 'test' THEN  array_range(10) WHEN  'test1'  THEN  array_range(20) else array_range(30) END;
SELECT CASE array_range(t1.id1) WHEN array_range(t1.id1) THEN  array_range(t1.id1) WHEN  array_range(t1.id)  THEN  array_range(t1.id) END from tt3 t1 union SELECT CASE array_range(t1.id1) WHEN array_range(t1.id1) THEN  array_range(t1.id1) WHEN  array_range(t1.id)  THEN  array_range(t1.id) END from tt3 t1;
SELECT CASE array_range(t2.id1) WHEN array_range(t1.id1) THEN  array_range(t2.id1) WHEN  array_range(t1.id)  THEN  array_range(t2.id) END from tt3 t1 ,tt3 t2;
