DROP MATERIALIZED VIEW  mv1;
create materialized view mv1  REFRESH FAST  as 
select t1.id as id1,t2.id as id2 ,array_sum(t1.c2) a2 from tt4 t1 inner join tt4 t2 on array_sum(t1.c2)=array_sum(t2.c2);
