select array_sum([1,2,3,4,5,5]) a from (select array_sum([1,2,3,4,5,5]) b);

select array_sum([1,2,3,4,5,5]) a from  dual where array_sum([1,2,3,4,5,5]) in (select array_sum([1,2,3,4,5,5]) b);
select (select array_sum(c2) from tt3 where id=1);

SELECT (SELECT array_sum(c2) FROM tt3 where id=1) FROM dual;
SELECT array_sum([1,2,3,4,5,5])  FROM dual WHERE array_sum([1,2,3,4,5,5])= (SELECT array_sum([1,2,3,4,5,5]) FROM dual);
SELECT * FROM tt3
 WHERE ROW(id,id) = (SELECT array_sum(c3), array_sum(c2) FROM tt3 WHERE id = 1);
--error 5083
 SELECT * FROM tt3
 WHERE ROW(c3,c2) = (SELECT array_sum(c3), array_sum(c2) FROM tt3 WHERE id = 1);

#join
drop table if exists tt3;
create table tt3(id int primary key,id1 double unsigned[],a int[]);
drop view if exists vtt3;
create view vtt3 as select * from tt3;
insert into tt3 values(1,[241,3.6,54E-2],[1,3,4]);
insert into tt3 values(2,[211,4.8744E+3],[12,3]);

drop table if exists tt4;
create table tt4(id int primary key,id1 double unsigned[],a int[]);
drop view if exists vtt4;
create view vtt4 as select * from tt4;
insert into tt4 values(1,[241,3.6,54E-2],[1,3,4]);
insert into tt4 values(2,[211,4.8744E+3],[12,3]);

select t3.*,array_sum(t3.a) ,array_sum(t3.id1) from tt3 t3 inner join tt4 t4 on array_sum(t3.a)=array_sum(t4.a);
select t3.*,array_sum(t3.a) ,array_sum(t3.id1)  from tt3 t3 right join tt4 t4 on  array_sum(t3.id1)=array_sum(t4.a);
select t3.*,array_sum(t3.a) ,array_sum(t3.id1)  from tt3 t3 left join tt4 t4 on  array_sum(t3.id1)=array_sum(t4.id1);
select t3.*,array_sum(t3.a) ,array_sum(t3.id1)  from tt3 t3  join tt4 t4 on  array_sum(t3.a)=array_sum(t4.a);
#union
select t3.*,array_sum(t3.a) ,array_sum(t3.id1) from tt3 t3 inner join tt4 t4 on array_sum(t3.a)=array_sum(t4.a) union select t3.*,array_sum(t3.a) ,array_sum(t3.id1) from tt3 t3 inner join tt4 t4 on array_sum(t3.a)=array_sum(t4.a);
select t3.*,array_sum(t3.a) ,array_sum(t3.id1)  from tt3 t3 right join tt4 t4 on  array_sum(t3.id1)=array_sum(t4.a) MINUS select t3.*,array_sum(t3.a) ,array_sum(t3.id1)  from tt3 t3 right join tt4 t4 on  array_sum(t3.id1)=array_sum(t4.a);
select t3.*,array_sum(t3.a) ,array_sum(t3.id1)  from tt3 t3 left join tt4 t4 on  array_sum(t3.id1)=array_sum(t4.id1) UNION ALL select t3.*,array_sum(t3.a) ,array_sum(t3.id1)  from tt3 t3 left join tt4 t4 on  array_sum(t3.id1)=array_sum(t4.id1);
select t3.*,array_sum(t3.a) ,array_sum(t3.id1)  from tt3 t3  join tt4 t4 on  array_sum(t3.a)=array_sum(t4.a) INTERSECT select t3.*,array_sum(t3.a) ,array_sum(t3.id1)  from tt3 t3  join tt4 t4 on  array_sum(t3.a)=array_sum(t4.a);

