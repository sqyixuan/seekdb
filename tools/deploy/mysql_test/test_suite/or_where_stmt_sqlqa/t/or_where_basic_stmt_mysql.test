--echo TOP-K 场景中 查询不包含 group by/window function/distinct
--disable_query_log  
--disable_result_log  
INSERT INTO t1 (c1, c2, c4) VALUES (2, 'Text for c2 1', true);
--enable_query_log  
--enable_result_log
--explain_protocol 1
select /*+ USE_CONCAT */ distinct c2 from t1 where c2 = '1' or c2 = 'Text for c2 1' order by c1 limit 10;
select distinct c1,c2 from t1 where c2 = '1' or c2 = 'Text for c2 1' order by c1 limit 10;

select /*+ USE_CONCAT */ max(c1) from t1 where c1 in (1,2) group by c2 order by c2 limit 10;
select c1, c2 from t1 where c1 in (1,2) group by c1,c2 order by c2 limit 10;

select MAX(c1) OVER(PARTITION BY c2 ORDER BY c2), c2 from t1 where c1 = 1 or c1 = 2 order by c2 limit 10; 

