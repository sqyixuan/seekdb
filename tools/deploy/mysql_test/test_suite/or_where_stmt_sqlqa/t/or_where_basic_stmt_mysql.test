select /*+ USE_CONCAT */ c1, c2 from t1 where c2 in ('Text for c2 1','2') order by c1 limit 10;
select /*+ USE_CONCAT */`VIEW1`.`t1.c1`,`VIEW1`.`t1.c2` from ((select /*+ USE_CONCAT */`test`.`t1`.`c1` AS `t1.c1`,`test`.`t1`.`c2` AS `t1.c2` from `test`.`t1` 
where (`test`.`t1`.`c2` = 'Text for c2 1')) 
union (select /*+ USE_CONCAT */`test`.`t1`.`c1` AS `t1.c1`,`test`.`t1`.`c2` AS `t1.c2` from `test`.`t1` where (`test`.`t1`.`c2` = '2'))) `VIEW1` order by 1 limit 10;

--echo TOP-K 场景  分区表 

select grp_id, trx_grp from obright_part where grp_id in (1,2) or row_id = 1 or glike like '%a%' order by trx_grp limit 10;

select /*+ USE_CONCAT */ c1, c2 from obright_part where grp_id in (1,2) or row_id = 1 or glike like '%a%' order by trx_grp limit 10;

select /*+ USE_CONCAT */ grp_id, row_id from obright_part where grp_id in (1,2) or row_hex like '%a%' order by row_id limit 10;

select /*+ USE_CONCAT */`VIEW1`.`obright_part.grp_id`,`VIEW1`.`obright_part.row_id` from 
((select /*+ USE_CONCAT */`test`.`obright_part`.`row_id` AS `obright_part.row_id`,`test`.`obright_part`.`grp_id` AS `obright_part.grp_id` from `test`.`obright_part` 
where (`test`.`obright_part`.`grp_id` in (1,2))) union  all 
(select /*+ USE_CONCAT */`test`.`obright_part`.`row_id` AS `obright_part.row_id`,`test`.`obright_part`.`grp_id` AS `obright_part.grp_id` from `test`.`obright_part` 
where lnnvl((`test`.`obright_part`.`grp_id` in (1,2))) and (`test`.`obright_part`.`row_hex` like '%a%' escape '\\'))) `VIEW1` order by 2 limit 10;

--echo TOP-K 场景  内联视图

