select /*+ USE_CONCAT */ c1, c2 from (select  c1, c2 from (select * from t1) where c1 = 1 or c1 = 2) where c2 = '1' or c2 = 'Text for c2 1' order by c1 limit 10;

select /*+ USE_CONCAT */`VIEW1`.`t1.c1`,`VIEW1`.`t1.c2` from 
((select /*+ USE_CONCAT */`test`.`t1`.`c1` AS `t1.c1`,`test`.`t1`.`c2` AS `t1.c2` from `test`.`t1` 
where ((`test`.`t1`.`c1` = 1) or (`test`.`t1`.`c1` = 2)) and (`test`.`t1`.`c2` = '1')) 
union (select /*+ USE_CONCAT */`test`.`t1`.`c1` AS `t1.c1`,`test`.`t1`.`c2` AS `t1.c2` from `test`.`t1` 
where ((`test`.`t1`.`c1` = 1) or (`test`.`t1`.`c1` = 2)) and (`test`.`t1`.`c2` = 'Text for c2 1'))) `VIEW1` order by 1 limit 10;

