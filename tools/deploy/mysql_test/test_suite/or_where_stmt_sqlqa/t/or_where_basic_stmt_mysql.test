union  all (select `test`.`obright`.`c1` AS `c1`,`test`.`obright`.`c2` AS `c2` from `test`.`obright` where lnnvl((`test`.`obright`.`row_id` = 1)) and lnnvl((`test`.`obright`.`trx_grp` = 1)) and (`test`.`obright`.`ac1` = 1)) 
