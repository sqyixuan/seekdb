select c1, c2 from t1 where c1 = 1 or c2 = '1';

select c1, c2 from t1 where c1 = 1 union all 
select c1, c2 from t1 where lnnvl(c1 = 1) and c2 = '1';

select /*+ USE_CONCAT */ c1, c2 from t1 where c1 = 1 union all 
select /*+ USE_CONCAT */ c1, c2 from t1 where lnnvl(c1 = 1) and c2 = '1';

