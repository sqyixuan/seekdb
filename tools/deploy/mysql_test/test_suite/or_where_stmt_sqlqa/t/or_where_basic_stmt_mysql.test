--echo 子查询场景

select c1, c2 from t1 where c3 = 1111 or exists (select 1 from obright_part where grp_id = t1.c1);

(select `test`.`t1`.`c1` AS `c1`,`test`.`t1`.`c2` AS `c2` from `test`.`t1` where (`test`.`t1`.`c3` = 1111)) 
union  all (select `test`.`t1`.`c1` AS `c1`,`test`.`t1`.`c2` AS `c2` from `test`.`t1` left join 
(select `test`.`obright_part`.`grp_id` AS `obright_part.grp_id` from `test`.`obright_part`) `VIEW1` 
on (`VIEW1`.`obright_part.grp_id` = `test`.`t1`.`c1`) where lnnvl((`test`.`t1`.`c3` = 1111)));

select /*+ USE_CONCAT */ c1, c2 from t1 where c3 = 1111 or exists (select 1 from obright_part where grp_id = t1.c1);

(select /*+ USE_CONCAT */`test`.`t1`.`c1` AS `c1`,`test`.`t1`.`c2` AS `c2` from `test`.`t1` where (`test`.`t1`.`c3` = 1111)) 
union  all (select /*+ USE_CONCAT */`test`.`t1`.`c1` AS `c1`,`test`.`t1`.`c2` AS `c2` from `test`.`t1` where lnnvl((`test`.`t1`.`c3` = 1111)) 
and exists((select 1 from `test`.`obright_part` where (`test`.`obright_part`.`grp_id` = `test`.`t1`.`c1`) limit 1)));

select /*+ USE_CONCAT */ c2,c3 from t1 where exists (select 1 from obright_part where grp_id <> t1.c1) or exists (select 1 from obright where grp_id = t1.c1);

select `VIEW1`.`c2`,`VIEW1`.`c3` from 
((select /*+ USE_CONCAT */`test`.`t1`.`c2` AS `c2`,`test`.`t1`.`c3` AS `c3`,`test`.`t1`.`c1` AS `t1.c1` from `test`.`t1` 
where exists((select 1 from `test`.`obright_part` where (`test`.`obright_part`.`grp_id` <> `test`.`t1`.`c1`) limit 1))) 
union (select /*+ USE_CONCAT */`test`.`t1`.`c2` AS `c2`,`test`.`t1`.`c3` AS `c3`,`test`.`t1`.`c1` AS `t1.c1` from `test`.`t1` 
where exists((select 1 from `test`.`obright` where (`test`.`obright`.`grp_id` = `test`.`t1`.`c1`) limit 1)))) `VIEW1`;

--echo 子查询场景 + 内联视图

select  c1, c2 from (select * from t1) t1 where c3 = 1111 or exists (select 1 from obright_part where grp_id = t1.c1);

(select `test`.`t1`.`c1` AS `c1`,`test`.`t1`.`c2` AS `c2` from `test`.`t1` where (`test`.`t1`.`c3` = 1111)) 
union  all (select `test`.`t1`.`c1` AS `c1`,`test`.`t1`.`c2` AS `c2` from `test`.`t1` where lnnvl((`test`.`t1`.`c3` = 1111)) 
and exists((select 1 from `test`.`obright_part` where (`test`.`obright_part`.`grp_id` = `test`.`t1`.`c1`) limit 1)));


