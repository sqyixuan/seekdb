select row_id, row_hex from obright_part where row_id = 1 or row_hex = 1;

select /*+ USE_CONCAT */ t1.c1, t2.c2 from t1 INNER JOIN obright_part t2 on t1.c1 = t2.grp_id where t1.c1 = 1 or t2.c2 = 1;

(select /*+ USE_CONCAT */`test`.`t1`.`c1` AS `c1`,`t2`.`c2` AS `c2` from `test`.`t1`,`test`.`obright_part` `t2` where (`test`.`t1`.`c1` = `t2`.`grp_id`) and (`test`.`t1`.`c1` = 1)) 
union  all (select /*+ USE_CONCAT */`test`.`t1`.`c1` AS `c1`,`t2`.`c2` AS `c2` from `test`.`t1`,`test`.`obright_part` `t2` 
where (`test`.`t1`.`c1` = `t2`.`grp_id`) and lnnvl((`test`.`t1`.`c1` = 1)) and (`t2`.`c2` = 1));

select /*+ USE_CONCAT */ * from obright_part where row_id = 1 or trx_grp = 1 or ac1 = 1 or glike like '%a%' or t1 = 1 or dec1 = 1;
select /*+ USE_CONCAT */ t1.c1, t2.c2 from t1,obright_part t2 where t1.c1 = t2.row_id and (t1.c1 = 1 or t1.c2 = 1);
