--echo 函数索引 前缀索引 

--error 0,1051
drop table t1;
create table t1(c1 bigint,
c2 varchar(200),
c3 int, 
c4 boolean,
c5 bigint,
c6 varchar(10) GENERATED ALWAYS AS (substr(c2,1,10)) virtual,
c7 varchar(10) GENERATED ALWAYS AS (substr(c2,1,10)) stored);

CREATE INDEX t1_idx1 ON t1((LOG10(c3)));
CREATE INDEX t1_idx2 ON t1(c2(10));
--disable_query_log  
--disable_result_log  
INSERT INTO t1 (c1, c2, c3, c4, c5) VALUES (1, 'Sample text 1', 100, TRUE, 123456);
INSERT INTO t1 (c1, c2, c3, c4, c5) VALUES (2, 'Sample text 2', 200, FALSE, 789101);
INSERT INTO t1 (c1, c2, c3, c4, c5) VALUES (3, 'Sample text 3', 300, TRUE, 112131);
--enable_query_log  
--enable_result_log
select c1, c2 from t1 where c3 = 1 or c2 = 'Sample text 1';
select /*+ USE_CONCAT */ c1, c2 from t1 where c3 = 1 or c2 = 'Sample text 1' order by c3 limit 10;
select /*+ USE_CONCAT */ c1, c2 from t1 where c3 in (100, 200,300) order by c2 limit 10;

--echo 十万条数据执行
--disable_query_log  
--disable_result_log  
--error 0,1305
drop PROCEDURE InsertDemoData;

delete from t1;
DELIMITER //;

CREATE PROCEDURE InsertDemoData()
BEGIN
  DECLARE i INT DEFAULT 1;
  
  WHILE i <= 10000 DO
    INSERT INTO t1 (c1, c2, c5) VALUES (i,CONCAT('Text for c2  ', i) ,true);
    SET i = i + 1;
  END WHILE;
  
END //

DELIMITER ;//

CALL InsertDemoData();

--error 0,1305
drop PROCEDURE InsertDemoData;
delete from obright_part;
DELIMITER //;

CREATE PROCEDURE InsertDemoData()
BEGIN
  DECLARE i INT DEFAULT 1;
  
  WHILE i <= 10000 DO
    INSERT INTO obright_part (
    grp_id, row_id, row_hex, trx_grp, v1, v1_check, v2, v2_check,
    r1, r2, glike, c1, c2, c3, c4, c5, c6, c7, c8, c9, c10, v3,
    t2, dec1, dec2, dec3, b1, d1
) VALUES (
    i, i, CONCAT('Text for c2  ', i), i, 'This is a test v1.', 1, 'This is a test v2.', 1,
    1, 2, 'glike value', 1, 2, 3, 4, 5, 1, 7, 8, 9, 10, 'v3 value',
    '2021-01-01 00:00:00.000000', 123.4567, 234.5678, 345.678901, true, 0
);
    SET i = i + 1;
  END WHILE;
  
END //

DELIMITER ;//

CALL InsertDemoData();
--enable_query_log  
--enable_result_log
select c1, c2 from t1 where c1 = 1 or c2 = '1';
select /*+ USE_CONCAT */ row_id, row_hex from obright_part where abs(row_id) = 1 or row_hex = '1';

select /*+ USE_CONCAT */ grp_id, trx_grp from obright_part where grp_id in (1,2) or row_id = 1 or glike like '%a%' order by trx_grp limit 9;

select /*+ USE_CONCAT */ c1, c2 from t1 where c3 = 1111 or exists (select 1 from obright_part where grp_id = t1.c1) limit 9;
select /*+ USE_CONCAT */ c2,c3 from t1 where exists (select 1 from obright_part where grp_id <> t1.c1) or exists (select 1 from obright where grp_id = t1.c1) limit 9;
select c2,c3 from t1 where exists (select 1 from obright_part where grp_id <> t1.c1) or exists (select 1 from obright where grp_id = t1.c1) limit 9;

