drop table obright;
create table obright(grp_id bigint, row_id bigint, row_hex varchar(2048), trx_grp bigint,
v1 varchar(65536), v1_check bigint, v2 varchar(65536), v2_check bigint, r1 int, r2 int, glike varchar(4096),
c1 bigint, c2 bigint, c3 bigint, c4 bigint, c5 bigint, c6 tinyint, c7 bigint, c8 bigint, c9 bigint, c10 bigint, v3 varchar(1024),
t1 timestamp(6) null, t2 datetime(6),
dec1 decimal(16,4), dec2 decimal(16,4), dec3 decimal(16,6),
b1 boolean, d1 bigint default 0, ac1 bigint auto_increment,
gen_v1 varchar(10) GENERATED ALWAYS AS (substr(v1,1,10)) virtual,
gen_v2 varchar(10) GENERATED ALWAYS AS (substr(v1,1,10)) stored,
primary key(grp_id, row_id, row_hex),
index obright1(row_id),
index obright2(trx_grp,row_id, ac1),
index obright3(glike),
index obright4(t1,dec1,dec2) storing(v1,v1_check,r1,r2),
index obright5(v1_check,v2_check),
index obright6(row_hex,v1_check) storing(glike,t1,r1),
unique index obright1_uniq(t1,grp_id,row_id,row_hex),
unique index obright2_uniq(trx_grp,r1,row_hex,row_id,grp_id),
unique index obright3_uniq(row_hex,grp_id,row_id),
unique index obright4_uniq(dec1,row_id));
explain_protocol: 1
