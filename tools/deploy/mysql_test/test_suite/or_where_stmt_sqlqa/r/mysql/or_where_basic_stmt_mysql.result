дҪҝз”ЁеӨҡзҙўеј•  еҲҶеҢәиЎЁ + еӨҡдёӘзҙўеј•
drop table obright_part;
create table obright_part(grp_id bigint, row_id bigint, row_hex varchar(2048), trx_grp bigint,
v1 varchar(65536), v1_check bigint, v2 varchar(65536), v2_check bigint, r1 int, r2 int, glike varchar(4096),
c1 bigint, c2 bigint, c3 bigint, c4 bigint, c5 bigint, c6 tinyint, c7 bigint, c8 bigint, c9 bigint, c10 bigint, v3 varchar(1024),
t1 timestamp(6) null, t2 datetime(6),
dec1 decimal(16,4), dec2 decimal(16,4), dec3 decimal(16,6),
b1 boolean, d1 bigint default 0, ac1 bigint auto_increment,
gen_v1 varchar(10) GENERATED ALWAYS AS (substr(v1,1,10)) virtual,
gen_v2 varchar(10) GENERATED ALWAYS AS (substr(v1,1,10)) stored,
primary key(grp_id, row_id, row_hex),
index obright_part2(trx_grp,row_id, ac1) global,
index obright_part3(glike) global,
index obright_part4(t1,dec1,dec2) storing(v1,v1_check,r1,r2) global,
index obright_part5(v1_check,v2_check) global,
index obright_part6(row_hex,v1_check) storing(glike,t1,r1) global,
index obright_part7(grp_id,row_id,row_hex,trx_grp,v1_check,r1,r2) storing(v1) LOCAL,
index obright_part8(ac1) LOCAL,
index obright_part9(grp_id,row_id,row_hex) LOCAL,
index obright_part10(gen_v1,gen_v2) LOCAL,
unique index obright_part1_uniq(t1,grp_id,row_id,row_hex) global,
unique index obright_part2_uniq(trx_grp,r1,row_hex,row_id,grp_id) global,
unique index obright_part3_uniq(row_hex,grp_id,row_id) global,
unique index obright_part4_uniq(trx_grp,row_hex,grp_id) storing(v1,v1_check,r1,r2) LOCAL)
partition by key (grp_id) partitions 100;
