drop DATABASE test;
CREATE DATABASE test;
use test;
drop table t1;
create table t1(c1 bigint,
c2 varchar(200),
c3 int DEFAULT 111, 
c4 boolean,
c5 bigint,
c6 varchar(10) GENERATED ALWAYS AS (substr(c2,1,10)) virtual,
c7 varchar(10) GENERATED ALWAYS AS (substr(c2,1,10)) stored,
primary key(c1, c2),
index t1_ind1(c2),
unique index t1_ind2(c1));
explain_protocol: 1
