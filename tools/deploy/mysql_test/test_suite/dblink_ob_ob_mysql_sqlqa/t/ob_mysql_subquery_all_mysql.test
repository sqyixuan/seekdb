select * from test333 where a < any (select b from test332)  ORDER BY 1;
select * from test333 where a < all (select b from test332)  ORDER BY 1;
select * from test333 where a >= any (select b from test332) ORDER BY 1;
select * from test333 where a >= all (select b from test332) ORDER BY 1;
