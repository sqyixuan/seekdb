--echo #mysql_dblink_read-09-06	子查询测试，子查询补充测试2

select a,(select * from (select count(distinct test161.b) as sum from test161,test162 where test161.a=test162.a and test162.b > 0 and test161.a <= test163.b group by test161.a order by sum) limit 1) from test163 ORDER BY 1;
select a,(select * from (select count(distinct tt1.b) sum from  test161@my_link1 tt1,test162@my_link1 tt2 where tt1.a=tt2.a and tt2.b > 0 and tt1.a <= tt2.b group by tt1.a order by sum )
limit 1) from test163@my_link1 tt3 ORDER BY 1;
select a,(select * from (select count(distinct tt1.b) sum from  test161@my_link1 tt1,test162@my_link2 tt2 where tt1.a=tt2.a and tt2.b > 0 and tt1.a <= tt2.b group by tt1.a order by sum )
limit 1) from test163@my_link2 tt3 ORDER BY 1;

select * from test164 where exists (select s1 from test165 group by s1 having max(test165.s1)=test164.s1) ORDER BY 1;
select * from test164@my_link1 tt4 where exists (select s1 from test165@my_link1 tt5 group by s1 having max(tt5.s1)=tt4.s1) ORDER BY 1;
select * from test164@my_link1 tt4 where exists (select s1 from test165@my_link2 tt5 group by s1 having max(tt5.s1)=tt4.s1) ORDER BY 1;

SELECT * FROM test161
  WHERE test161.a NOT IN (SELECT test162.a FROM test162 LEFT JOIN test163 ON test162.b=test163.b
                       WHERE test163.b IS NOT NULL OR test162.a > 0) ORDER BY 1;
					   
SELECT * FROM test161@my_link1 test161
  WHERE test161.a NOT IN (SELECT test162.a FROM test162@my_link1 test162 LEFT JOIN test163@my_link1 test163 ON test162.b=test163.b
                       WHERE test163.b IS NOT NULL OR test162.a > 0) ORDER BY 1;
					   
SELECT * FROM test161@my_link1 test161
  WHERE test161.a NOT IN (SELECT test162.a FROM test162@my_link2 test162 LEFT JOIN test163@my_link2 test163 ON test162.b=test163.b
                       WHERE test163.b IS NOT NULL OR test162.a > 0) ORDER BY 1;		
					   
SELECT * FROM test161@my_link2 test161
  WHERE test161.a NOT IN (SELECT test162.a FROM test162@my_link1 test162 LEFT JOIN test163@my_link2 test163 ON test162.b=test163.b
                       WHERE test163.b IS NOT NULL OR test162.a > 0) ORDER BY 1;	
				  
SELECT a.*, b.* FROM (SELECT * FROM test166) a JOIN test167 b on a.id=b.id ORDER BY 1;
SELECT a.*, b.* FROM (SELECT * FROM test166@my_link1 test166) a JOIN test167@my_link1 b on a.id=b.id ORDER BY 1;
SELECT a.*, b.* FROM (SELECT * FROM test166@my_link1 test166) a JOIN test167@my_link2 b on a.id=b.id ORDER BY 1;

select * from (select min(i) from test168 where j=(select * from (select min(j) from test168) test162)) test163 ORDER BY 1;
select * from (select min(i) from test168@my_link1 test161 where j=(select * from (select min(j) from test168@my_link1 test161) test162)) test163 ORDER BY 1;

SELECT a, MAX(b),
  (SELECT t.c FROM test169 t WHERE test169.a=t.a AND t.b=MAX(test169.b + 0)) test
  FROM test169 GROUP BY a; 
SELECT a, MAX(b),
  (SELECT t.c FROM test169@my_link1 AS t WHERE test169.a=t.a AND t.b=MAX(test169.b + 0)) as test
  FROM test169 GROUP BY a;

SELECT id, st FROM test170
  WHERE st IN ('GA','FL') AND EXISTS(SELECT 1 FROM test171 WHERE test171.id=test170.id) ORDER BY 1;

SELECT id, st FROM test170@my_link1 test170
WHERE st IN ('GA','FL') AND EXISTS(SELECT 1 FROM test171@my_link1 test171 WHERE test171.id=test170.id) ORDER BY 1;

select a, b, (a,b) in (select a, min(b) from test173 group by a) Z from test172;
select a, b, (a,b) in (select a, min(b) from test173@my_link1 test173 group by a) Z from test172@my_link1 test172;
select a, b, (a,b) in (select a, min(b) from test173@my_link2 test173 group by a) Z from test172@my_link1 test172;
select a, b, (a,b) in (select a, min(b) from test173@my_link1 test173 group by a) Z from test172@my_link2 test172;

SELECT  table1.pk
FROM ( test174 table1 JOIN test174 table2 ON (table1.col_varchar =
                                          table2.col_varchar) )
WHERE ( 1, 2 ) IN ( SELECT SUBQUERY1_t1.pk AS SUBQUERY1_field1,
                           SUBQUERY1_t1.pk AS SUBQUERY1_field2
                    FROM ( test174 SUBQUERY1_t1 JOIN test174 SUBQUERY1_t2
                           ON (SUBQUERY1_t2.col_varchar =
                               SUBQUERY1_t1.col_varchar) ) )
ORDER BY 1;

SELECT  table1.pk
FROM ( test174@my_link1 table1 JOIN test174@my_link1 table2 ON (table1.col_varchar =
                                          table2.col_varchar) )
WHERE ( 1, 2 ) IN ( SELECT SUBQUERY1_t1.pk AS SUBQUERY1_field1,
                           SUBQUERY1_t1.pk AS SUBQUERY1_field2
                    FROM (  test174@my_link1 SUBQUERY1_t1 JOIN  test174@my_link1 SUBQUERY1_t2
                           ON (SUBQUERY1_t2.col_varchar =
                               SUBQUERY1_t1.col_varchar) ) )
ORDER BY 1;

SELECT  table1.pk
FROM ( test174@my_link1 table1 JOIN test174@my_link2 table2 ON (table1.col_varchar =
                                          table2.col_varchar) )
WHERE ( 1, 2 ) IN ( SELECT SUBQUERY1_t1.pk AS SUBQUERY1_field1,
                           SUBQUERY1_t1.pk AS SUBQUERY1_field2
                    FROM (  test174@my_link2 SUBQUERY1_t1 JOIN  test174@my_link1 SUBQUERY1_t2
                           ON (SUBQUERY1_t2.col_varchar =
                               SUBQUERY1_t1.col_varchar) ) )
ORDER BY 1;

CREATE OR REPLACE VIEW v1 AS
SELECT test175.c1 AS c1,test175.c2 AS c2,test175.c3 AS c3 FROM test175;

CREATE OR REPLACE VIEW v2 AS
SELECT test176.c1 AS c1 FROM test176;

SELECT test161.c3
FROM v1 test161 JOIN v2 test162 ON test161.c1 < test162.c1
WHERE test161.c3 BETWEEN 2 AND 6 OR
      (test161.c3 IN(4) AND test161.c3 <> 2) OR test161.c2 >= 8 ORDER BY 1;
	  

SELECT test161.c3
FROM test175@my_link1 test161 JOIN test176@my_link1 test162 ON test161.c1 < test162.c1
WHERE test161.c3 BETWEEN 2 AND 6 OR
      (test161.c3 IN(4) AND test161.c3 <> 2) OR test161.c2 >= 8 ORDER BY 1;


SELECT test161.c3
FROM  v1 test161 JOIN v2 test162 ON test161.c1 < test162.c1
WHERE test161.c3 BETWEEN (SELECT i1 FROM test177 WHERE i1 = 2) AND
                    (SELECT i1 FROM test177 WHERE i1 = 6)  OR
      test161.c3 IN((SELECT i1 FROM test177 WHERE i1 = 4)) AND
      test161.c3 <>(SELECT i1 FROM test177 WHERE i1 = 2) OR
      test161.c2 >=(SELECT i1 FROM test177 WHERE i1 = 8) ORDER BY 1;
	  
SELECT test161.c3
FROM  test175 test161 JOIN test176 test162 ON test161.c1 < test162.c1
WHERE test161.c3 BETWEEN (SELECT i1 FROM test177 WHERE i1 = 2) AND
                    (SELECT i1 FROM test177 WHERE i1 = 6)  OR
      test161.c3 IN((SELECT i1 FROM test177 WHERE i1 = 4)) AND
      test161.c3 <>(SELECT i1 FROM test177 WHERE i1 = 2) OR
      test161.c2 >=(SELECT i1 FROM test177 WHERE i1 = 8) ORDER BY 1;


SELECT test161.c3
FROM test175@my_link1 test161 JOIN test176@my_link1 test162 ON test161.c1 < test162.c1
WHERE test161.c3 BETWEEN (SELECT i1 FROM test177@my_link1 test177 WHERE i1 = 2) AND
                    (SELECT i1 FROM test177@my_link1 test177 WHERE i1 = 6)  OR
      test161.c3 IN((SELECT i1 FROM test177@my_link1 test177 WHERE i1 = 4)) AND
      test161.c3 <>(SELECT i1 FROM test177@my_link1 test177 WHERE i1 = 2) OR
      test161.c2 >=(SELECT i1 FROM test177@my_link1 test177 WHERE i1 = 8);
	  
SELECT test161.c3
FROM test175@my_link1 test161 JOIN test176@my_link1 test162 ON test161.c1 < test162.c1
WHERE test161.c3 BETWEEN (SELECT i1 FROM test177@my_link1 WHERE i1 = 2) AND
                    (SELECT i1 FROM test177@my_link1 WHERE i1 = 6)  OR
      test161.c3 IN((SELECT i1 FROM test177@my_link1 WHERE i1 = 4)) AND
      test161.c3 <>(SELECT i1 FROM test177@my_link1 WHERE i1 = 2) OR
      test161.c2 >=(SELECT i1 FROM test177@my_link1 WHERE i1 = 8);


--echo #mysql_dblink_read-09-06	子查询测试，子查询补充测试3
select
  groupstuff.*,
  test181.categoryid,
  test182.courseid
from test182
join test181 on test182.courseid=test181.courseid
join
(
  select
    test185.userid,
    parentid,
    parentgroup,
    childid,
    groupname,
    grouptypeid
  from test185
  join
  (
     select test184.id as parentid,
       test184.name as parentgroup,
       test184.id as childid,
       test184.name as groupname,
       test184.grouptypeid
     from test184
  ) gin on test185.groupid=gin.childid
) groupstuff on test182.userid = groupstuff.userid ORDER BY 1;


select
  groupstuff.*,
  test181.categoryid,
  test182.courseid
from test182@my_link1 test182
join test181@my_link1 test181 on test182.courseid=test181.courseid
join
(
  select
    test185.userid,
    parentid,
    parentgroup,
    childid,
    groupname,
    grouptypeid
  from test185@my_link1 test185
  join
  (
     select test184.id as parentid,
       test184.name as parentgroup,
       test184.id as childid,
       test184.name as groupname,
       test184.grouptypeid
     from test184@my_link1 test184
  ) gin on test185.groupid=gin.childid
) groupstuff on test182.userid = groupstuff.userid ORDER BY 1;

