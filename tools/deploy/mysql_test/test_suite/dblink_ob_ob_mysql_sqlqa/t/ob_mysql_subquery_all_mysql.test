--error 1054
select (select a from test331@my_link1 test331 where test331.a = a1) as a2, (select b from test332@my_link1 test332 where test332.b=a2) as a1  from test331@my_link1 test331;

select (select a from test331 where test331.a=test332.a), a from test332 ORDER BY 1;
select (select a from test331 where test331.a=test332.b), a from test332 ORDER BY 1;
select (select a from test331@my_link1 test331 where test331.a=test332.a), a from test332@my_link1 test332 ORDER BY 1;
select (select a from test331@my_link1 test331 where test331.a=test332.b), a from test332@my_link1 test332 ORDER BY 1;

select (select a from test331 limit 1), a, (select * from ((select 1 from dual limit 1) union select 2 from dual limit 1) limit 1 ) from test332 ORDER BY 1;
select (select a from test331@my_link1 test331 limit 1), a, (select * from ((select 1 from dual limit 1)  union select 2 from dual limit 1 ) limit 1 ) from test332@my_link1 test332 ORDER BY 1;

select * from test332 where test332.a=(select a from test332 limit 1) ORDER BY 1;
select * from test332@my_link1 test332 where test332.a=(select a from test331@my_link1 test331 limit 1) ORDER BY 1;

select * from test332 where test332.b=(select a from test333 limit 1) ORDER BY 1;
select * from test332@my_link1 test332 where test332.b=(select a from test333@my_link1 test333 limit 1) ORDER BY 1;

(select * from test332 where test332.b=(select a from test333 limit 1)) union (select * from test334 limit 1 ) ORDER BY 1;
(select * from test332@my_link1 test332 where test332.b=(select a from test333@my_link1 test333 limit 1 )) union (select * from test334@my_link1 test334 limit 1) ORDER BY 1;

(select * from test332 where test332.b=(select a from test333 limit 1)) union (select * from test334 where test334.b=(select max(test332.a)*4 from test332));
(select * from test332@my_link1 test332 where test332.b=(select a from test333@my_link1 test333 limit 1)) 
union (select * from test334@my_link1 test334 where test334.b=(select max(test332.a)*4 from test332@my_link1 test332));

select (select test333.a from test333 where a<8 limit 1 ), a from
(select * from test332 where a>1) tt ORDER BY 1;
select (select test333.a from test333@my_link1 test333 where a<8 limit 1), a from
(select * from test332@my_link2 test332 where a>1) tt ORDER BY 1;

select * from test331 where test331.a=(select test332.a from test332 where test332.b=(select max(a) from test333) limit 1) ORDER BY 1;
select * from test331@my_link1 test331 where test331.a=(select test332.a from test332@my_link1 test332 where test332.b=(select max(a) from test333@my_link1 test333) limit 1) ORDER BY 1;


select * from test331 where test331.a=(select test332.a from test332 where test332.b=(select max(a) from test333 where test333.a > test331.a) limit 1 ) ORDER BY 1;
select * from test331 where test331.a=(select test332.a from test332 where test332.b=(select max(a) from test333 where test333.a < test331.a) limit 1 ) ORDER BY 1;
select * from test333 where exists (select * from test332 where test332.b=test333.a) ORDER BY 1;
select * from test333 where not exists (select * from test332 where test332.b=test333.a) ORDER BY 1;
