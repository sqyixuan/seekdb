#owner group: sql2
#description: dblink:ob-omysql连接oracle，select远端表
#tags: dml
#author:wb-sl672505

connection default;
--error 0,4112
purge recyclebin;

--echo #新建本地用户
connect(sys_ora,$OBMYSQL_MS0,root,,test,$OBMYSQL_PORT);
connection sys_ora;
--error 0,1396
drop user lcq1 ;
create user 'lcq1' identified by 'lcq';
GRANT all privileges ON *.* TO 'lcq1'@'%' WITH GRANT OPTION;

--error 0,1396
drop user lcq2 ;
create user 'lcq2' identified by 'lcq';
GRANT all privileges ON *.* TO 'lcq2'@'%' WITH GRANT OPTION;

--error 0,1396
drop user lcq3 ;
create user 'lcq3' identified by 'lcq';
GRANT all privileges ON *.* TO 'lcq3'@'%' WITH GRANT OPTION;

connect (conn_lcq_1,$OBMYSQL_MS0,lcq1,lcq,test,$OBMYSQL_PORT);
connect (conn_lcq_2,$OBMYSQL_MS0,lcq2,lcq,test,$OBMYSQL_PORT);
connect (conn_lcq_3,$OBMYSQL_MS0,lcq3,lcq,test,$OBMYSQL_PORT);

--echo #新建远端dblink租户、用户
let $char_charset = 'UTF8';

--source mysql_test/test_suite/dblink_ob_ob_mysql_sqlqa/include/create_tenant_by_charset.inc
--source mysql_test/test_suite/dblink_ob_ob_mysql_sqlqa/include/conn_tenant.inc
disconnect conn_charset_test_user;

connect(sys_ora1,$OBMYSQL_MS0,root@tenant_charset_test,,test,$OBMYSQL_PORT);
connection sys_ora1;

--error 0,1396
drop user lcq1 ;
create user 'lcq1' identified by 'lcq';
GRANT all privileges ON *.* TO 'lcq1'@'%' WITH GRANT OPTION;

--error 0,1396
drop user lcq2 ;
create user 'lcq2' identified by 'lcq';
GRANT all privileges ON *.* TO 'lcq2'@'%' WITH GRANT OPTION;

--error 0,1396
drop user lcq3 ;
create user 'lcq3' identified by 'lcq';
GRANT all privileges ON *.* TO 'lcq3'@'%' WITH GRANT OPTION;

connect (conn_lcq_11,$OBMYSQL_MS0,lcq1@tenant_charset_test,lcq,test,$OBMYSQL_PORT);
connect (conn_lcq_21,$OBMYSQL_MS0,lcq2@tenant_charset_test,lcq,test,$OBMYSQL_PORT);

connection conn_lcq_11;
--source mysql_test/test_suite/dblink_ob_ob_mysql_sqlqa/include/ob_mysql_prepare_tableall.inc

connection conn_lcq_21;
--source mysql_test/test_suite/dblink_ob_ob_mysql_sqlqa/include/ob_mysql_prepare_tableall.inc

connection conn_lcq_3;
--source mysql_test/test_suite/dblink_ob_ob_mysql_sqlqa/include/ob_mysql_prepare_tableall.inc

connection conn_lcq_3;
set autocommit = on;
###本地新建dblink
--disable_query_log
--error 0, 2024
drop database link if exists my_link1;
eval create database link if not exists my_link1 connect to lcq1@tenant_charset_test database test identified by 'lcq' host '$OBMYSQL_MS0:$OBMYSQL_PORT';

--error 0, 2024
drop database link if exists my_link2;
eval create database link if not exists my_link2 connect to lcq2@tenant_charset_test database test identified by 'lcq' host '$OBMYSQL_MS0:$OBMYSQL_PORT';

--enable_query_log
set autocommit = on;
set ob_query_timeout=99900000000;
set ob_trx_timeout = 1000000000;  
SET NAMES UTF8;

CREATE OR REPLACE VIEW v_class1 AS SELECT * FROM class150@my_link1;
CREATE OR REPLACE VIEW v_stu1 AS SELECT * FROM stu150@my_link1;
CREATE OR REPLACE VIEW v_class2 AS SELECT * FROM class233@my_link2;
CREATE OR REPLACE VIEW v_stu2 AS SELECT * FROM stu233@my_link2;
CREATE OR REPLACE VIEW syn_class1  AS SELECT * FROM class150@my_link1;
CREATE OR REPLACE VIEW syn_stu1  AS SELECT * FROM stu150@my_link1;
CREATE OR REPLACE VIEW syn_class2  AS SELECT * FROM class233@my_link2;
CREATE OR REPLACE VIEW syn_stu2  AS SELECT * FROM stu233@my_link2;

--echo #mysql_dblink_read-08-03	函数
--echo #mysql_dblink_read-08-03-1、mysql_dblink_read-08-03-2	条件、循环语句（if、while），不带参数的函数
--disable_warnings
DROP TABLE if exists class3_1;
--enable_warnings

CREATE TABLE class3_1 AS SELECT * FROM class333 where 1=0;

delimiter //;
DROP FUNCTION IF EXISTS p1;//
CREATE FUNCTION p1()
RETURNS INT
DETERMINISTIC
BEGIN
DECLARE done INT DEFAULT FALSE;
DECLARE id INT;
DECLARE name VARCHAR(255);
DECLARE ts TIMESTAMP;
DECLARE cur CURSOR FOR SELECT id,name,create_time FROM class150@my_link1;
DECLARE CONTINUE HANDLER FOR NOT FOUND SET done = TRUE;
OPEN cur;
read_loop: LOOP
FETCH cur INTO id, name, ts;
IF done THEN
LEAVE read_loop;
END IF;
IF id = 102 THEN
INSERT INTO class3_1 VALUES((SELECT max(id)+1 FROM class150@my_link1),'shuxue','yuhang',STR_TO_DATE('25-09-2002 12:01:33.3333','%d-%m-%Y %H:%i:%s.%f'));
INSERT INTO class3_1(name) VALUES((SELECT name FROM v_class2 WHERE id=102));
END IF;
END LOOP;
CLOSE cur;
RETURN 1;
END //
delimiter ;//
SELECT p1();
SELECT * FROM class3_1 order by 1,2,3,4;
delete from class3_1;


delimiter //;

DROP FUNCTION IF EXISTS p1;//
CREATE FUNCTION p1()
RETURNS INT
DETERMINISTIC
BEGIN
DECLARE done INT DEFAULT FALSE;
DECLARE id INT;
DECLARE name VARCHAR(255);
DECLARE ts TIMESTAMP;
DECLARE cur CURSOR FOR SELECT id,name,create_time FROM v_class1;
DECLARE CONTINUE HANDLER FOR NOT FOUND SET done = TRUE;
OPEN cur;
read_loop: LOOP
FETCH cur INTO id, name, ts;
IF done THEN
LEAVE read_loop;
END IF;
IF id = 102 THEN
INSERT INTO class3_1 VALUES((SELECT max(id)+1 FROM v_class1),'shuxue','yuhang',STR_TO_DATE('25-09-2002 12:01:33.3333','%d-%m-%Y %H:%i:%s.%f'));
INSERT INTO class3_1(name) VALUES((SELECT name FROM v_class2 WHERE id=102));
END IF;
END LOOP;
CLOSE cur;
RETURN 1;
END //
delimiter ;//
SELECT p1();
SELECT * FROM class3_1 order by 1,2,3,4;
delete from class3_1;

delimiter //;
DROP FUNCTION IF EXISTS my_func;//
CREATE FUNCTION my_func(in1 INT) RETURNS INT
BEGIN
DECLARE cnt INT DEFAULT 0;
DECLARE id INT;
DECLARE name VARCHAR(50);
DECLARE ts TIMESTAMP;
DECLARE cur CURSOR FOR SELECT id, name, create_time FROM class150;
DECLARE CONTINUE HANDLER FOR NOT FOUND SET cnt = -1;
OPEN cur;
read_loop: LOOP
FETCH cur INTO id, name, ts;
IF cnt = -1 THEN
LEAVE read_loop;
END IF;
IF id = in1 THEN
UPDATE class150 SET name = CONCAT(name, '_new') WHERE id = id;
INSERT INTO class150(id, name, create_time) VALUES(id+1, CONCAT(name, '_new'), NOW());
END IF;
END LOOP;
CLOSE cur;
RETURN cnt;
END //
delimiter ;//
SELECT my_func(10);
SELECT * FROM class3_1 order by 1,2,3,4;
delete from class3_1;

--echo #mysql_dblink_read-08-04	触发器
--disable_warnings
DROP TABLE if exists class3_1;
--enable_warnings

CREATE TABLE class3_1 AS SELECT * FROM class333 where 1=0;

--disable_warnings
DROP TABLE if exists stu3_1;
--enable_warnings

CREATE TABLE stu3_1 AS SELECT * FROM stu333 where 1=0;

delimiter //;
DROP TRIGGER if exists test_trig;//
CREATE TRIGGER test_trig
BEFORE INSERT ON stu3_1
FOR EACH ROW
BEGIN
IF 1>0 THEN
INSERT INTO class3_1(id, name, location) VALUES((SELECT MAX(id)+1 FROM class233@my_link2), 'shuxue', 'yuhang');
INSERT INTO class3_1(name) VALUES((SELECT name FROM syn_class1 WHERE id=102));
END IF;
END //
delimiter ;//
DELETE FROM stu3_1 WHERE id=1001;
INSERT INTO stu3_1 SELECT * FROM stu333 ;
SELECT * FROM class3_1 order by 1,2,3,4;
SELECT * FROM stu3_1 order by 1,2,3,4,5,6,7;
drop trigger test_trig;

--echo #清理环境
--source mysql_test/test_suite/dblink_ob_ob_mysql_sqlqa/include/drop_tenant.inc
--error 0,4112
purge recyclebin;
sleep 5;
