connection default;
--error 0,4112
purge recyclebin;

--echo #新建本地用户
connect(sys_ora,$OBMYSQL_MS0,root,,test,$OBMYSQL_PORT);
connection sys_ora;
--error 0,1396
drop user lcq1 ;
create user 'lcq1' identified by 'lcq';
GRANT all privileges ON *.* TO 'lcq1'@'%' WITH GRANT OPTION;

--error 0,1396
drop user lcq2 ;
create user 'lcq2' identified by 'lcq';
GRANT all privileges ON *.* TO 'lcq2'@'%' WITH GRANT OPTION;

--error 0,1396
drop user lcq3 ;
create user 'lcq3' identified by 'lcq';
GRANT all privileges ON *.* TO 'lcq3'@'%' WITH GRANT OPTION;

connect (conn_lcq_1,$OBMYSQL_MS0,lcq1,lcq,test,$OBMYSQL_PORT);
connect (conn_lcq_2,$OBMYSQL_MS0,lcq2,lcq,test,$OBMYSQL_PORT);
connect (conn_lcq_3,$OBMYSQL_MS0,lcq3,lcq,test,$OBMYSQL_PORT);

--echo #新建远端dblink租户、用户
let $char_charset = 'UTF8';

--source mysql_test/test_suite/dblink_ob_ob_mysql_sqlqa/include/create_tenant_by_charset.inc
--source mysql_test/test_suite/dblink_ob_ob_mysql_sqlqa/include/conn_tenant.inc
disconnect conn_charset_test_user;

connect(sys_ora1,$OBMYSQL_MS0,root@tenant_charset_test,,test,$OBMYSQL_PORT);
connection sys_ora1;

--error 0,1396
drop user lcq1 ;
create user 'lcq1' identified by 'lcq';
GRANT all privileges ON *.* TO 'lcq1'@'%' WITH GRANT OPTION;

--error 0,1396
drop user lcq2 ;
create user 'lcq2' identified by 'lcq';
GRANT all privileges ON *.* TO 'lcq2'@'%' WITH GRANT OPTION;

--error 0,1396
drop user lcq3 ;
create user 'lcq3' identified by 'lcq';
GRANT all privileges ON *.* TO 'lcq3'@'%' WITH GRANT OPTION;

connect (conn_lcq_11,$OBMYSQL_MS0,lcq1@tenant_charset_test,lcq,test,$OBMYSQL_PORT);
connect (conn_lcq_21,$OBMYSQL_MS0,lcq2@tenant_charset_test,lcq,test,$OBMYSQL_PORT);

connection conn_lcq_11;
--source mysql_test/test_suite/dblink_ob_ob_mysql_sqlqa/include/ob_mysql_prepare_tableall.inc

connection conn_lcq_21;
--source mysql_test/test_suite/dblink_ob_ob_mysql_sqlqa/include/ob_mysql_prepare_tableall.inc

connection conn_lcq_3;
--source mysql_test/test_suite/dblink_ob_ob_mysql_sqlqa/include/ob_mysql_prepare_tableall.inc

connection conn_lcq_3;
set autocommit = on;
###本地新建dblink
--disable_query_log
--error 0, 2024
drop database link if exists my_link1;
eval create database link if not exists my_link1 connect to lcq1@tenant_charset_test database test identified by 'lcq' host '$OBMYSQL_MS0:$OBMYSQL_PORT';

--error 0, 2024
drop database link if exists my_link2;
eval create database link if not exists my_link2 connect to lcq2@tenant_charset_test database test identified by 'lcq' host '$OBMYSQL_MS0:$OBMYSQL_PORT';

--enable_query_log
set autocommit = on;
set ob_query_timeout=99900000000;
set ob_trx_timeout = 1000000000;  
SET NAMES UTF8;

--echo #mysql_dblink_read-09-08
delete /*+ parallel(10) enable_parallel_dml */ from test192 where pk = (select pk from  test190 where pk in (2,3,4,5));

insert /*+ parallel(6) enable_parallel_dml */ into test192 (select CASE WHEN a.COL_NUMBER_29_0 = 0 AND
                   b.name LIKE 'SMIT%'
                THEN 255555
              WHEN a.COL_VARCHAR2_200 != 'A' AND
                   b.job  = 'ANALYST'
                THEN 266666
			  WHEN a.pk = 9
                THEN 2
              ELSE a.pk + 266666
           END as abc,CASE WHEN a.COL_NUMBER_29_0 = 0 AND
                   b.name LIKE 'SMIT%'
                THEN 255555
              WHEN a.COL_VARCHAR2_200 != 'A' AND
                   b.job  = 'ANALYST'
                THEN 266666
			  WHEN a.pk = 9
                THEN 2
              ELSE a.pk + 266666
           END as abcd,a.COL_TS,'Asdf..faseF',a.COL_NUMBER_29_0,a.COL_DATE, a.COL_DECIMAL_21_2 from test190 a 
left join test191 b on a.pk = b.num);

update /*+ parallel(6) enable_parallel_dml */ test192 set COL_INT= (select CASE WHEN a.COL_NUMBER_29_0 = 0 AND
                   b.name LIKE 'SMIT%'
                THEN 200000
              WHEN a.COL_VARCHAR2_200 <> 'A' AND
                   b.job  = 'ANALYST' 
                THEN 211111
			WHEN a.pk = 6
                THEN 3
			WHEN a.pk = 7
                THEN 4
			WHEN a.pk = 8
                THEN 5
              ELSE a.pk + 211111
           END as abc from test190 a 
left join test191 b on a.pk = b.num 
where a.pk = 6), COL_NUMBER_29_0 = (select CASE WHEN a.COL_NUMBER_29_0 = 0 AND
                   b.name LIKE 'SMIT%'
                THEN 200000
              WHEN a.COL_VARCHAR2_200 <> 'A' AND
                   b.job  = 'ANALYST' 
                THEN 211111
			WHEN a.pk = 6
                THEN 3
			WHEN a.pk = 7
                THEN 4
			WHEN a.pk = 8
                THEN 5
              ELSE a.pk + 211111
           END as abc from test190 a 
left join test191 b on a.pk = b.num 
where a.pk = 7 ), COL_VARCHAR2_200 = (select CASE WHEN a.COL_NUMBER_29_0 = 0 AND
                   b.name LIKE 'SMIT%'
                THEN 200000
              WHEN a.COL_VARCHAR2_200 <> 'A' AND
                   b.job  = 'ANALYST' 
                THEN 211111
			WHEN a.pk = 6
                THEN 3
			WHEN a.pk = 7
                THEN 4
			WHEN a.pk = 8
                THEN 5
              ELSE a.pk + 211111
           END as abc from test190 a 
left join test191 b on a.pk = b.num 
where a.pk = 8 );
  
--error 1235 
delete /*+ parallel(10) enable_parallel_dml */ from test192@my_link1 where pk = (select pk from  test190 where pk in (2,3,4,5));
--error 1242
select /*+ parallel(10) enable_parallel_dml */ * from test192@my_link1 where pk = (select pk from test192@my_link1 where pk in (2,3,4,5)) order by 1;

select /*+ parallel(10) enable_parallel_dml */ * from test192@my_link1 where pk IN (select pk from test192@my_link1 where pk in (2,3,4,5)) order by 1;


