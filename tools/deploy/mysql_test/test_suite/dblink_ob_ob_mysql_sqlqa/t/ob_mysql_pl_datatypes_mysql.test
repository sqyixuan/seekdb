eval create database link if not exists my_link2 connect to lcq2@tenant_charset_test database test identified by 'lcq' host '$OBMYSQL_MS0:$OBMYSQL_PORT';

--enable_query_log
set autocommit = on;
set ob_query_timeout=99900000000;
set ob_trx_timeout = 1000000000;  
SET NAMES UTF8;


--echo #mysql_dblink_read-08-05	pl
delimiter //;
DROP PROCEDURE IF EXISTS student_info;//
CREATE PROCEDURE student_info()
BEGIN
DECLARE done INT DEFAULT FALSE;
DECLARE name VARCHAR(500);
DECLARE age VARCHAR(500);
DECLARE cur CURSOR FOR SELECT stuname, stuage FROM studentdblink;
DECLARE CONTINUE HANDLER FOR NOT FOUND SET done = TRUE;
OPEN cur;
read_loop: LOOP
FETCH cur INTO name, age;
IF done THEN
LEAVE read_loop;
END IF;
SELECT CONCAT('姓名为:', name, ' 年龄为:', age) AS info;
END LOOP;
CLOSE cur;
END; //

CALL student_info();//

