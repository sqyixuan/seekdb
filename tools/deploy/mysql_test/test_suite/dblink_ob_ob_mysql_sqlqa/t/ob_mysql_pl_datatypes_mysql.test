### 查询所有的数据类型。
DROP PROCEDURE IF EXISTS sample_query;//
CREATE PROCEDURE `sample_query`()
BEGIN
  SELECT * FROM `sample_table`;
END; //

CALL `sample_query`();//

DROP PROCEDURE IF EXISTS sample_query;//
CREATE PROCEDURE `sample_query`()
BEGIN
  SELECT * FROM sample_table@my_link1;
END; //

CALL `sample_query`();//

DROP PROCEDURE IF EXISTS show_sample_table_data;//
CREATE PROCEDURE `show_sample_table_data`()
BEGIN
  -- 查询int_col字段
  SELECT int_col AS 'Int Column' FROM sample_table@my_link1
  UNION
  -- 查询tinyint_col字段
  SELECT tinyint_col AS 'Tinyint Column' FROM sample_table@my_link1
  UNION
  -- 查询smallint_col字段
  SELECT smallint_col AS 'Smallint Column' FROM sample_table@my_link1
  UNION
  -- 查询mediumint_col字段
  SELECT mediumint_col AS 'Mediumint Column' FROM sample_table@my_link1
  UNION
  -- 查询bigint_col字段
  SELECT bigint_col AS 'Bigint Column' FROM sample_table@my_link1
  UNION
  -- 查询float_col字段
  SELECT float_col AS 'Float Column' FROM sample_table@my_link1
  UNION
  -- 查询double_col字段
  SELECT double_col AS 'Double Column' FROM sample_table@my_link1
  UNION
  -- 查询decimal_col字段
  SELECT decimal_col AS 'Decimal Column' FROM sample_table@my_link1
  UNION
  -- 查询date_col字段
  SELECT date_col AS 'Date Column' FROM sample_table@my_link1
  UNION
  -- 查询datetime_col字段
  SELECT datetime_col AS 'Datetime Column' FROM sample_table@my_link1
  UNION
  -- 查询timestamp_col字段
  SELECT timestamp_col AS 'Timestamp Column' FROM sample_table@my_link1
  UNION
  -- 查询time_col字段
  SELECT time_col AS 'Time Column' FROM sample_table@my_link1
  UNION
  -- 查询year_col字段
  SELECT year_col AS 'Year Column' FROM sample_table@my_link1
  UNION
  -- 查询char_col字段
  SELECT char_col AS 'Char Column' FROM sample_table@my_link1
  UNION
  -- 查询varchar_col字段
  SELECT varchar_col AS 'Varchar Column' FROM sample_table@my_link1
  UNION
  -- 查询binary_col字段
  SELECT binary_col AS 'Binary Column' FROM sample_table@my_link1
  UNION
  -- 查询varbinary_col字段
  SELECT varbinary_col AS 'Varbinary Column' FROM sample_table@my_link1
  UNION
  -- 查询tinyblob_col字段
  SELECT tinyblob_col AS 'Tinyblob Column' FROM sample_table@my_link1
  UNION
  -- 查询blob_col字段
  SELECT blob_col AS 'Blob Column' FROM sample_table@my_link1
  UNION
  -- 查询mediumblob_col字段
  SELECT mediumblob_col AS 'Mediumblob Column' FROM sample_table@my_link1
  UNION
  -- 查询longblob_col字段
  SELECT longblob_col AS 'Longblob Column' FROM sample_table@my_link1
  UNION
  -- 查询tinytext_col字段
  SELECT tinytext_col AS 'Tinytext Column' FROM sample_table@my_link1
  UNION
  -- 查询text_col字段
  SELECT text_col AS 'Text Column' FROM sample_table@my_link1
  UNION
  -- 查询mediumtext_col字段
  SELECT mediumtext_col AS 'Mediumtext Column' FROM sample_table@my_link1
  UNION
  -- 查询longtext_col字段
  SELECT longtext_col AS 'Longtext Column' FROM sample_table@my_link1
  UNION
  -- 查询enum_col字段
  SELECT enum_col AS 'Enum Column' FROM sample_table@my_link1
  UNION
  -- 查询set_col字段
  SELECT set_col AS 'Set Column' FROM sample_table@my_link1;

END //

CALL `show_sample_table_data`();//

### 本地PL所有数据类型作对比
DROP PROCEDURE IF EXISTS show_data_types;//
CREATE PROCEDURE `show_data_types`()
BEGIN
  -- 整数型
  DECLARE tinyint_col TINYINT DEFAULT 1;
  DECLARE smallint_col SMALLINT DEFAULT 2;
  DECLARE mediumint_col MEDIUMINT DEFAULT 3;
  DECLARE int_col INT DEFAULT 4;
  DECLARE bigint_col BIGINT DEFAULT 5;
  
  -- 小数型
  DECLARE float_col FLOAT DEFAULT 3.14;
  DECLARE double_col DOUBLE DEFAULT 3.14159265358979323846;
  DECLARE decimal_col DECIMAL(10, 2) DEFAULT 12345.67;
  
  -- 时间和日期类型
  DECLARE date_col DATE DEFAULT '2021-08-01';
  DECLARE time_col TIME DEFAULT '12:34:56';
  DECLARE datetime_col DATETIME DEFAULT '2021-08-01 12:34:56';
  DECLARE timestamp_col TIMESTAMP DEFAULT '2021-08-01 12:34:56';
  
  -- 字符串类型
  DECLARE char_col CHAR(10) DEFAULT 'hello';
  DECLARE varchar_col VARCHAR(20) DEFAULT 'world';
  DECLARE text_col TEXT DEFAULT 'Hello, World!';
  
  -- 二进制类型
  DECLARE binary_col BINARY(10) DEFAULT 'binary';
  DECLARE varbinary_col VARBINARY(20) DEFAULT 'varbinary';
  DECLARE blob_col BLOB;
  
  -- 枚举类型
  DECLARE enum_col ENUM('value1', 'value2', 'value3') DEFAULT 'value1';
  
  -- 集合类型
  DECLARE set_col SET('value1', 'value2', 'value3') DEFAULT 'value1,value2';
  
  -- 打印出所有数据类型和对应的值
  SELECT 'TINYINT' AS `data_type`, tinyint_col AS `value`;
  SELECT 'SMALLINT' AS `data_type`, smallint_col AS `value`;
  SELECT 'MEDIUMINT' AS `data_type`, mediumint_col AS `value`;
  SELECT 'INT' AS `data_type`, int_col AS `value`;
  SELECT 'BIGINT' AS `data_type`, bigint_col AS `value`;
  
  SELECT 'FLOAT' AS `data_type`, float_col AS `value`;
  SELECT 'DOUBLE' AS `data_type`, double_col AS `value`;
  SELECT 'DECIMAL' AS `data_type`, decimal_col AS `value`;
  
  SELECT 'DATE' AS `data_type`, date_col AS `value`;
  SELECT 'TIME' AS `data_type`, time_col AS `value`;
  SELECT 'DATETIME' AS `data_type`, datetime_col AS `value`;
  SELECT 'TIMESTAMP' AS `data_type`, timestamp_col AS `value`;
  
  SELECT 'CHAR' AS `data_type`, char_col AS `value`;
  SELECT 'VARCHAR' AS `data_type`, varchar_col AS `value`;
  SELECT 'TEXT' AS `data_type`, text_col AS `value`;
  
  SELECT 'BINARY' AS `data_type`, binary_col AS `value`;
  SELECT 'VARBINARY' AS `data_type`, varbinary_col AS `value`;
  SELECT 'BLOB' AS `data_type`, blob_col AS `value`;
  
  SELECT 'ENUM' AS `data_type`, enum_col AS `value`;
  
  SELECT 'SET' AS `data_type`, set_col AS `value`;
  
END //

CALL `show_data_types`();//
DELIMITER ;//

--echo #清理环境
