#owner: dachuan.sdc
#owner group: sql2
#description: dblink:ob-omysql连接oracle，select远端表
#tags: dml
#author:wb-sl672505

connection default;
--error 0,4112
purge recyclebin;

--echo #新建本地用户
connect(sys_ora,$OBMYSQL_MS0,root,,test,$OBMYSQL_PORT);
connection sys_ora;
--error 0,1396
drop user lcq1 ;
create user 'lcq1' identified by 'lcq';
GRANT all privileges ON *.* TO 'lcq1'@'%' WITH GRANT OPTION;

--error 0,1396
drop user lcq2 ;
create user 'lcq2' identified by 'lcq';
GRANT all privileges ON *.* TO 'lcq2'@'%' WITH GRANT OPTION;

--error 0,1396
drop user lcq3 ;
create user 'lcq3' identified by 'lcq';
GRANT all privileges ON *.* TO 'lcq3'@'%' WITH GRANT OPTION;

connect (conn_lcq_1,$OBMYSQL_MS0,lcq1,lcq,test,$OBMYSQL_PORT);
connect (conn_lcq_2,$OBMYSQL_MS0,lcq2,lcq,test,$OBMYSQL_PORT);
connect (conn_lcq_3,$OBMYSQL_MS0,lcq3,lcq,test,$OBMYSQL_PORT);

--echo #新建远端dblink租户、用户
let $char_charset = 'UTF8';

--source mysql_test/test_suite/dblink_ob_ob_mysql_sqlqa/include/create_tenant_by_charset.inc
--source mysql_test/test_suite/dblink_ob_ob_mysql_sqlqa/include/conn_tenant.inc
disconnect conn_charset_test_user;

connect(sys_ora1,$OBMYSQL_MS0,root@tenant_charset_test,,test,$OBMYSQL_PORT);
connection sys_ora1;

--error 0,1396
drop user lcq1 ;
create user 'lcq1' identified by 'lcq';
GRANT all privileges ON *.* TO 'lcq1'@'%' WITH GRANT OPTION;

--error 0,1396
drop user lcq2 ;
create user 'lcq2' identified by 'lcq';
GRANT all privileges ON *.* TO 'lcq2'@'%' WITH GRANT OPTION;

--error 0,1396
drop user lcq3 ;
create user 'lcq3' identified by 'lcq';
GRANT all privileges ON *.* TO 'lcq3'@'%' WITH GRANT OPTION;

connect (conn_lcq_11,$OBMYSQL_MS0,lcq1@tenant_charset_test,lcq,test,$OBMYSQL_PORT);
connect (conn_lcq_21,$OBMYSQL_MS0,lcq2@tenant_charset_test,lcq,test,$OBMYSQL_PORT);

connection conn_lcq_11;
--source mysql_test/test_suite/dblink_ob_ob_mysql_sqlqa/include/ob_mysql_prepare_tableall.inc

connection conn_lcq_21;
--source mysql_test/test_suite/dblink_ob_ob_mysql_sqlqa/include/ob_mysql_prepare_tableall.inc

connection conn_lcq_3;
--source mysql_test/test_suite/dblink_ob_ob_mysql_sqlqa/include/ob_mysql_prepare_tableall.inc

connection conn_lcq_3;
set autocommit = on;
###本地新建dblink
--disable_query_log
--error 0, 2024
drop database link if exists my_link1;
eval create database link if not exists my_link1 connect to lcq1@tenant_charset_test database test identified by 'lcq' host '$OBMYSQL_MS0:$OBMYSQL_PORT';

--error 0, 2024
drop database link if exists my_link2;
eval create database link if not exists my_link2 connect to lcq2@tenant_charset_test database test identified by 'lcq' host '$OBMYSQL_MS0:$OBMYSQL_PORT';

--enable_query_log
set autocommit = on;
set ob_query_timeout=99900000000;
set ob_trx_timeout = 1000000000;  
SET NAMES UTF8;

###--echo #mysql_dblink_read-04 常用函数
--error 1064
SELECT LN(c2,0) FROM gbktable@my_link1 order by 1;
SELECT LN(0) FROM gbktable@my_link2 order by 1;

SELECT sum(a.c0),count(*),avg(a.c0+b.c0),max(a.c9/b.c9),min(a.c9-b.c9) FROM gbktable@my_link1 a,gbktable@my_link2 b WHERE a.c1=b.c1 GROUP BY a.c0 order by 1,4,5;
SELECT LOWER(a.c2),UPPER(a.c2),LENGTH(b.c2) FROM gbktable@my_link1 a,gbktable@my_link2 b WHERE a.c2=b.c2 AND mod(a.c0,b.c0)>275 order by 1;
SELECT * FROM gbktable@my_link1 t;
select STR_TO_DATE('25-09-2005 12:01:33.3333','%d-%m-%Y %H:%i:%s.%f') from gbktable@my_link1 t where t.c0 = 7 order by 1;
--error 1582
select decode(t.c1,'中文测试001','好的','aaabbb','不好','20060604','再说') from gbktable t order by 1;

###replace

select t.c1 from gbktable@my_link1 t where replace(t.c1,'中文测试00','好的好的') = '好的好的1' order by 1;
select replace(t.c2,'中文测试00','好的好的') from gbktable@my_link1 t order by 1;
select t.c1 from gbktable@my_link1 t where replace(t.c2,'中文测试00','好的好的') = '好的好的1' order by 1;
select t1.c1,t2.c1 from gbktable@my_link1 t1,gbktable@my_link2 t2 where replace(t1.c1,'中文测试00','好的好的') = '好的好的1' 
AND  replace(t2.c1,'中文测试00','好的好的') = '好的好的1' order by 1,2;

###length
select length(t.c1) 返回值 from gbktable@my_link1 t order by 1;
select t.c1 from gbktable@my_link1 t where length(t.c1) = 7 order by 1;
select t1.c1 from gbktable@my_link1 t1,gbktable@my_link2 t2 where length(t1.c1) = 7 AND length(t2.c2) = 7 order by 1;

###abs
select abs(t.c1) from gbktable@my_link1 t where t.c0 = 7 order by 1;

###concat
select concat(t.c1,t.c2) from gbktable@my_link1 t order by 1;
select t.c1 from gbktable@my_link1 t where concat(t.c1,t.c2) = '中文测试001中文测试001' order by 1;
select t.c1 from gbktable@my_link1 t where concat(t.c1,t.c2) = '中文测试001中文测试001' and concat(t.c1,t.c2) = concat(t.c2,t.c1) order by 1;
select concat(concat(t.c1,t.c2),t.c7) from gbktable@my_link1 t order by 1;
select t.c1 from gbktable@my_link1 t where trim(concat(concat(t.c1,t.c2),t.c7)) = '中文测试001中文测试001a' order by 1;

###rpad
SELECT t.c1 ORA_STR,
LENGTH(t.c1) ORA_STR_LENGTH,
RPAD(t.c1, 30, '$') ORA_RPAD_STR,
LENGTH(RPAD(t.c1, 20, '$')) ORA_RPAD_STR_LENGTH
FROM gbktable@my_link1 t where t.c1 = '中文测试001' and RPAD(t.c1, 10, '$') = '中文测试00' order by 1;

SELECT t1.c1 ORA_STR,
LENGTH(t1.c1) ORA_STR_LENGTH,
RPAD(t1.c1, 30, '$') ORA_RPAD_STR,
LENGTH(RPAD(t1.c1, 20, '$')) ORA_RPAD_STR_LENGTH
FROM gbktable@my_link1 t1 where t1.c1 = '中文测试001' and RPAD(t1.c1, 10, '$') = '中文测试00' order by 1;

SELECT t1.c1 ORA_STR,
LENGTH(t1.c1) ORA_STR_LENGTH,
RPAD(t1.c1, 30, '$') ORA_RPAD_STR,
LENGTH(RPAD(t1.c1, 20, '$')) ORA_RPAD_STR_LENGTH
FROM gbktable@my_link1 t1,gbktable@my_link2 t2 where t1.c1 = '中文测试001' and RPAD(t2.c1, 10, '$') = '中文测试00' order by 1;

###lpad
SELECT t.c1 ORA_STR,
LENGTH(t.c1) ORA_STR_LENGTH,
LPAD(t.c1, 30, '$') ORA_RPAD_STR,
LENGTH(LPAD(t.c1, 20, '$')) ORA_RPAD_STR_LENGTH
FROM gbktable@my_link1 t where t.c1 = '中文测试001' and LPAD(t.c1, 10, '$') = '中文测试00' order by 1;

###instr
select instr(t.c1,'文测') from gbktable@my_link1 t order by 1;
select t.c1 from gbktable@my_link1 t where instr(t.c1,'文测') = 2 order by 1;

###substr
select substr(t.c1,3,5) from gbktable@my_link1 t order by 1;
select t.c1 from gbktable@my_link1 t where substr(t.c1,3,5) = '测试001' order by 1;

###coalesce
SELECT COALESCE(NULL,NULL,t.c1) FROM gbktable@my_link1 t order by 1;
SELECT t.c1 FROM gbktable@my_link1 t where COALESCE(NULL,NULL,t.c1) = '?????' order by 1;
SELECT t1.c1 FROM gbktable@my_link1 t1,gbktable@my_link2 t2 where COALESCE(NULL,NULL,t1.c1) = '?????' AND COALESCE(NULL,NULL,t2.c1) = '?????' order by 1;
SELECT COALESCE(NULL,NULL,t.c2) FROM gbktable@my_link1 t order by 1;
SELECT COALESCE(NULL,NULL,t.c7) FROM gbktable@my_link1 t order by 1;

###lower
select lower(t.c1) from gbktable@my_link1 t order by 1;
select t.c1 from gbktable@my_link1 t where lower(t.c1) = '中文测试001' order by 1;
select lower(t.c2) from gbktable@my_link1 t order by 1;
select t.c1 from gbktable@my_link1 t where lower(t.c2) = '中文测试001' order by 1;

###upper
select upper(t.c1) from gbktable@my_link1 t order by 1;
select t.c1 from gbktable@my_link1 t where upper(t.c1) = '中文测试001' order by 1;
select upper(t.c2) from gbktable@my_link1 t order by 1;
select t.c1 from gbktable@my_link1 t where upper(t.c2) = '中文测试001' order by 1;

###trim
###ltrim
###rtrim

SELECT TRIM(t.c1) FROM gbktable@my_link1 t order by 1;
SELECT TRIM(t.c2) FROM gbktable@my_link1 t order by 1;
SELECT LTRIM(t.c1) FROM gbktable@my_link1 t order by 1;
SELECT RTRIM(t.c1) FROM gbktable@my_link1 t order by 1;

SELECT trim(leading '中' from t.c1) FROM gbktable@my_link1 t order by 1;
SELECT t.c1 FROM gbktable@my_link1 t where trim(leading '中' from t.c1) = 'aaabbb' order by 1;

SELECT trim(both '中' from t.c1) FROM gbktable@my_link1 t order by 1;
SELECT t.c1 FROM gbktable@my_link1 t where trim(both '中' from t.c1) = 'aaabbb' order by 1;

SELECT trim(trailing '中' from t.c1) FROM gbktable@my_link1 t order by 1;
SELECT t.c1 FROM gbktable@my_link1 t where trim(trailing '中' from t.c1) = 'aaabbb' order by 1;

###nvl
select nvl(null,t.c1) from gbktable@my_link1 t order by 1;
select nvl(null,t.c2) from gbktable@my_link1 t order by 1;
select nvl(t.c1,null) from gbktable@my_link1 t order by 1;
select nvl(t.c2,null) from gbktable@my_link1 t order by 1;
select t.c1 from gbktable@my_link1 t where nvl(null,t.c1) = nvl(null,t.c2) and nvl(null,t.c1) = '中文测试001' order by 1;
select count(*) from gbktable@my_link1 t where nvl(null,t.c1) = nvl(t.c1,null) order by 1;

###asin
select asin(t.c1 - 20060603) from gbktable@my_link1 t where t.c0 = 7 order by 1;
select asin(t.c2 - 20060603) from gbktable@my_link1 t where t.c0 = 7 order by 1;

###sign
select sign(t.c1 - 20060603) from gbktable@my_link1 t where t.c0 = 7 order by 1;
select sign(t.c1 - 20060604) from gbktable@my_link1 t where t.c0 = 7 order by 1;
select sign(t.c1 - 20060605) from gbktable@my_link1 t where t.c0 = 7 order by 1;

###is
###is_not
select t.c1,t.c2 from gbktable@my_link1 t where t.c1 is NULL order by 1;
select t.c1,t.c2 from gbktable@my_link1 t where t.c1 is NOT NULL order by 1;

###between
###not_between

select t.c1,t.c2 from gbktable@my_link1 t where t.c1 between '中文测试001' and '中文测试003' order by 1;
select t.c1,t.c2 from gbktable@my_link1 t where t.c1 not between '中文测试001' and '中文测试003' order by 1;

###like
select t.c1,t.c2 from gbktable@my_link1 t where t.c1 like '中文测试00%' order by 1;

###!
select t.c1 from gbktable@my_link1 t where t.c2 != '中文测试001' order by 1;
select t.c1 from gbktable@my_link1 t where t.c1 != '中文测试001' order by 1;

###&&  -- &&用来创建一个持久变量，当用&&命令引用这个变量时，不会每次遇到该变量就提示用户键入值，而只是在第一次遇到时提示一次
###||
select t.c1||t.c2 from gbktable@my_link1 t order by 1;
select t.c1 from gbktable@my_link1 t where t.c1||t.c2 = '中文测试001中文测试001' order by 1;

###in
###not_in

select t.c1 from gbktable@my_link1 t where t.c1 in ('中文测试001','中文测试002','中文测试003','aaabbb','20060604','2006-06-04','中文测试009') order by 1;
select t.c1 from gbktable@my_link1 t where t.c1 not in ('中文测试001','中文测试002','中文测试003','aaabbb','20060604','2006-06-04','中文测试009') order by 1;
select t.c1 from gbktable@my_link1 t where t.c2 in ('中文测试001','中文测试002','中文测试003','aaabbb','20060604','2006-06-04','中文测试009') order by 1;
select t.c1 from gbktable@my_link1 t where t.c2 not in ('中文测试001','中文测试002','中文测试003','aaabbb','20060604','2006-06-04','中文测试009') order by 1;

###arg_case
###case
select case when t.c1 between '中文测试001' and '中文测试001' then 'low好的'
            when t.c1 between '中文测试002' and '中文测试008' then 'mid不好'
            when t.c1 between '中文测试008' and '中文测试009' then 'highnice啊'
            else 'unknow'
       end
from gbktable@my_link1 t order by 1;

###exists
###not exists
select t.c1 from gbktable@my_link1 t where exists (select * from gbktable@my_link1 where c1 like '%中文%') order by 1;
select t.c1 from gbktable@my_link1 t where not exists (select * from gbktable@my_link1 where c1 like '%中文%') order by 1;

###power
select power(t.c1,2) from gbktable@my_link1 t where t.c0 = 7 order by 1;
select power(t.c2,2) from gbktable@my_link1 t where t.c0 = 7 order by 1;

###ln
###log
select ln(t.c1) from gbktable@my_link1 t where t.c0 = 7 order by 1;
select ln(t.c2) from gbktable@my_link1 t where t.c0 = 7 order by 1;
select log(t.c1,2) from gbktable@my_link1 t where t.c0 = 7 order by 1;
select log(t.c2,2) from gbktable@my_link1 t where t.c0 = 7 order by 1;

--echo #清理环境
--source mysql_test/test_suite/dblink_ob_ob_mysql_sqlqa/include/drop_tenant.inc
--error 0,4112
purge recyclebin;
sleep 5;