select mySmallint from myTable1@my_link1 where myFloat is true order by myTinyint limit 1,1;
select myTinyint from myTable1@my_link1 order by myDecimal limit 1;
SELECT AVG(t1.myDecimal) AS median
FROM (
    SELECT @rownum:=@rownum+1 as `row_number`, t.myDecimal
    FROM myTable1@my_link1 t, (SELECT @rownum:=0) r
    ORDER BY t.myDecimal
) as t1,
(
    SELECT count(*) as total_rows
    FROM myTable1@my_link1
) as t2
WHERE 1
AND t1.row_number in ( floor((total_rows+1)/2), floor((total_rows+2)/2) );

