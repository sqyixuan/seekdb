--echo ##创建复制表
drop table if exists t1 ;
drop table if exists t2 ;
drop table if exists t3 ;
drop table if exists t4 ;
create table t1 as select max(char_col) from myTable3@my_link1 where mediumtext_col like '%10中文%' order by id desc ;
create table t2 as select count(mediumtext_col),count(tinyblob_col),count(blob_col),count(id) from myTable3@my_link1 where mediumtext_col like '%10中文%' order by id desc ;
create table t3 as select count(longtext_col) as a ,count(blob_col)as b ,count(0) as c ,count(null)as d from myTable3@my_link1 where mediumtext_col like '%10中文%' order by id desc ;
create table t4 as select count(longtext_col) as 中文ing,count(mediumtext_col) as 體1,count(0) as count,count(false)-1 as asd from myTable3@my_link1 where mediumtext_col like '%10中文%' order by id desc;
desc t1;
desc t2;
desc t3;
desc t4;
drop table if exists t1 ;
drop table if exists t2 ;
drop table if exists t3 ;
drop table if exists t4 ;

--echo ##内置函数验证
