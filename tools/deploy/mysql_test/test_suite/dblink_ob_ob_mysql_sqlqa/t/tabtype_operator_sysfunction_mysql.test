SELECT avg(a.f1+b.f1) FROM test147@my_link1 a,test231@my_link2 b WHERE a.f2>300 GROUP BY a.f1,b.f1 HAVING b.f1<35679 order by 1;
SELECT avg(a.f1+b.f1) FROM test147@my_link1 a,test231@my_link2 b
WHERE a.f2>300 GROUP BY a.f1,b.f1 HAVING b.f1<(SELECT max(f1)-10000 FROM test146@my_link1) order by 1;
SELECT avg(a.f1+b.f1) FROM test147@my_link1 a,test231@my_link2 b
WHERE a.f2>300 GROUP BY a.f1,b.f1 HAVING b.f1=(select * from (SELECT f1 FROM test146@my_link1 order by 1) LIMIT 1) order by 1;

SELECT avg(a.f1+b.f1) FROM test147@my_link1 a,test231@my_link2 b WHERE a.f2>300 GROUP BY a.f1,b.f1 HAVING b.f1<35679 order by 1;
SELECT avg(a.f1+b.f1) FROM test147@my_link1 a,test231@my_link2 b
WHERE a.f2>300 GROUP BY a.f1,b.f1 HAVING b.f1<(SELECT max(f1)-10000 FROM test146@my_link1) order by 1;
SELECT avg(a.f1+b.f1) FROM test147@my_link1 a,test231@my_link2 b
WHERE a.f2>300 GROUP BY a.f1,b.f1 HAVING b.f1=(select * from (SELECT f1 FROM test146@my_link1 order by 1) LIMIT 1) order by 1;

