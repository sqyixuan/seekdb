#owner group: sql2
#description: dblink:ob-omysql连接oracle，select远端表
#tags: dml
#author:wb-sl672505

connection default;
--error 0,4112
purge recyclebin;

--echo #新建本地用户
connect(sys_ora,$OBMYSQL_MS0,root,,test,$OBMYSQL_PORT);
connection sys_ora;
--error 0,1396
drop user lcq1 ;
create user 'lcq1' identified by 'lcq';
GRANT all privileges ON *.* TO 'lcq1'@'%' WITH GRANT OPTION;

--error 0,1396
drop user lcq2 ;
create user 'lcq2' identified by 'lcq';
GRANT all privileges ON *.* TO 'lcq2'@'%' WITH GRANT OPTION;

--error 0,1396
drop user lcq3 ;
create user 'lcq3' identified by 'lcq';
GRANT all privileges ON *.* TO 'lcq3'@'%' WITH GRANT OPTION;

connect (conn_lcq_1,$OBMYSQL_MS0,lcq1,lcq,test,$OBMYSQL_PORT);
connect (conn_lcq_2,$OBMYSQL_MS0,lcq2,lcq,test,$OBMYSQL_PORT);
connect (conn_lcq_3,$OBMYSQL_MS0,lcq3,lcq,test,$OBMYSQL_PORT);

--echo #新建远端dblink租户、用户
let $char_charset = 'UTF8';

--source mysql_test/test_suite/dblink_ob_ob_mysql_sqlqa/include/create_tenant_by_charset.inc
--source mysql_test/test_suite/dblink_ob_ob_mysql_sqlqa/include/conn_tenant.inc
disconnect conn_charset_test_user;

connect(sys_ora1,$OBMYSQL_MS0,root@tenant_charset_test,,test,$OBMYSQL_PORT);
connection sys_ora1;

--error 0,1396
drop user lcq1 ;
create user 'lcq1' identified by 'lcq';
GRANT all privileges ON *.* TO 'lcq1'@'%' WITH GRANT OPTION;

--error 0,1396
drop user lcq2 ;
create user 'lcq2' identified by 'lcq';
GRANT all privileges ON *.* TO 'lcq2'@'%' WITH GRANT OPTION;

--error 0,1396
drop user lcq3 ;
create user 'lcq3' identified by 'lcq';
GRANT all privileges ON *.* TO 'lcq3'@'%' WITH GRANT OPTION;

connect (conn_lcq_11,$OBMYSQL_MS0,lcq1@tenant_charset_test,lcq,test,$OBMYSQL_PORT);
connect (conn_lcq_21,$OBMYSQL_MS0,lcq2@tenant_charset_test,lcq,test,$OBMYSQL_PORT);

connection conn_lcq_11;
--source mysql_test/test_suite/dblink_ob_ob_mysql_sqlqa/include/ob_mysql_prepare_tableall.inc

connection conn_lcq_21;
--source mysql_test/test_suite/dblink_ob_ob_mysql_sqlqa/include/ob_mysql_prepare_tableall.inc

connection conn_lcq_3;
--source mysql_test/test_suite/dblink_ob_ob_mysql_sqlqa/include/ob_mysql_prepare_tableall.inc

connection conn_lcq_3;
set autocommit = on;
###本地新建dblink
--disable_query_log
--error 0, 2024
drop database link if exists my_link1;
eval create database link if not exists my_link1 connect to lcq1@tenant_charset_test database test identified by 'lcq' host '$OBMYSQL_MS0:$OBMYSQL_PORT';

--error 0, 2024
drop database link if exists my_link2;
eval create database link if not exists my_link2 connect to lcq2@tenant_charset_test database test identified by 'lcq' host '$OBMYSQL_MS0:$OBMYSQL_PORT';

--enable_query_log
set autocommit = on;
set ob_query_timeout=99900000000;
set ob_trx_timeout = 1000000000;  
SET NAMES UTF8;

--echo #mysql_dblink_read-09-05
--echo #用户场景1

SELECT
NVL(SUM(C1),C1) FROM
(SELECT id AS C1,
CASE WHEN (name)='yinyue'
THEN (name)
ELSE (name)
END AS C2
FROM class150@my_link1) SAMPLESUB group by C1,C2;

--echo #用户场景2

SELECT /*+parallel(a,10)*/COUNT(*) FROM class333 A WHERE NOT EXISTS (SELECT 1 FROM class150@my_link1 WHERE id=101 AND A.name ='yinyue' AND A.location='binjiang');

--echo #用户场景3 

SELECT COUNT(1) FROM class150@my_link1 WHERE id = 101 AND name = 'dianzi';
SELECT COUNT(*) FROM class150@my_link1 WHERE id = 101 AND name = 'dianzi';

--echo #用户场景4 

--error 1064
SELECT COUNT(1) FROM class150.SEQUENCE.NEXTVAL@my_link1 WHERE id = 101 AND name = 'dianzi';


--echo #用户场景5 

SELECT LPAD(id,20,'0')||LPAD(name,20,'0')||LPAD(location,20,'0')||LPAD(create_time,20,'0')||LPAD(id,20,'0')||LPAD(name,20,'0') FROM class150@my_link1 WHERE id = 101 AND name = 'YINYUE';
SELECT LPAD(id,20,'0')||LPAD(name,20,'0')||LPAD(location,20,'0')||LPAD(create_time,20,'0')||LPAD(id,20,'0')||LPAD(name,20,'0') FROM class150@my_link1 WHERE id = 101 AND name = 'yinyue';

--echo #用户场景6 

SELECT IFNULL(SUM(A1.id),0) FROM class150@my_link1 A1 
WHERE A1.name='yinyue' AND A1.id=CAST(DATE_FORMAT(LAST_DAY(CURRENT_DATE()), '%Y%m%d') AS UNSIGNED) AND (A1.id LIKE '1605%' OR A1.id LIKE '1606%');
SELECT IFNULL(SUM(A1.id),0) FROM class150@my_link1 A1 
WHERE A1.name='yinyue' AND A1.id=CAST(DATE_FORMAT(LAST_DAY(CURRENT_DATE()), '%Y%m%d') AS UNSIGNED) AND (A1.id LIKE '1605%' OR A1.id LIKE '1606%');
SELECT * FROM class150@my_link1 A1 
WHERE A1.name='yinyue' AND A1.id=CAST(DATE_FORMAT(LAST_DAY(CURRENT_DATE()), '%Y%m%d') AS UNSIGNED) AND (A1.id LIKE '1605%' OR A1.id LIKE '1606%');
SELECT * FROM class333 A1 
WHERE A1.name='yinyue' AND A1.id=CAST(DATE_FORMAT(LAST_DAY(CURRENT_DATE()), '%Y%m%d') AS UNSIGNED) AND (A1.id LIKE '1605%' OR A1.id LIKE '1606%');
SELECT * FROM class150@my_link1 A1 
WHERE (A1.id LIKE '1605%' OR A1.id LIKE '1606%');
SELECT * FROM class150@my_link1 A1 
WHERE A1.name='yinyue' AND A1.id=CAST(DATE_FORMAT(LAST_DAY(CURRENT_DATE()), '%Y%m%d') AS UNSIGNED) AND (A1.id LIKE '1605%' OR A1.id LIKE '1606%');

--echo #用户场景7 

SELECT name from class150@my_link1
WHERE create_time between DATE_SUB(CURRENT_DATE(), INTERVAL 1 DAY) and CURRENT_DATE()
AND
(name not like 'bosscron%'
AND name not like 'root%'
AND name not like 'vsearch%'
AND name != 'NEWRPT'
AND name != 'HWWH_WANGHM'
AND name != 'PRO_MUSER'
AND name != 'TRANSDATA'
AND name != 'MONITOR_YY'
AND name NOT LIKE 'I3%'
and upper(location) not like '%ALTER%MOVE%'
and upper(location) not like '%ALTER%REBUILD%'
and upper(location) not like '%ALTER%SPLIT%'
and upper(location) not like '%ALTER%DROP%'
AND create_time not like 'oracle@%'
and location not like '%(TNS V1-V3)%'
AND location not like '%Precise%')
AND location not like 'SYS_IOT_%'
GROUP BY name;


--echo #用户场景8 

SELECT A1.id,A1.name,A1.location,A1.create_time,A1.id,A1.name,A1.location,A1.create_time
FROM class150@my_link1 A1  WHERE A1.name='yinyue' AND A1.create_time>CURRENT_DATE()-INTERVAL 20000 DAY;

--echo #用户场景9 

SELECT A1.name,COUNT(*) FROM class150@my_link1 A1  WHERE A1.id=CAST(DATE_FORMAT(CURRENT_DATE(), '%Y%m%d') AS UNSIGNED) 
AND A1.name<>A1.location AND A1.id=102 GROUP BY A1.name;

--echo #用户场景10

SELECT IFNULL(SUM(C1),C1) FROM 
(SELECT id AS C1, 
CASE WHEN CAST(name AS CHAR)='yinyue'
THEN CAST(name AS CHAR) 
ELSE CAST(name AS CHAR) 
END AS C2 
FROM class150@my_link1) SAMPLESUB group by C1,C2;

--echo #用户场景11

SELECT  /*+leading(p) */ 
       CAST(sr.id AS char), 
       p.id, 
       (SELECT name FROM stu333 WHERE name=p.name), 
       s.name, 
       s.id, 
       (SELECT name FROM stu333 p WHERE p.c_id=s.id), 
       (SELECT name FROM stu333 p WHERE p.p_id=sr.p_id), 
       (SELECT l.alias FROM stu333 l WHERE l.alias = sr.alias), 
       (SELECT ar.name FROM class150@my_link1 ar WHERE ar.id=sr.c_id AND ar.name=s.name) actionname, 
       FLOOR(sr.p_id/100), 
       sr.alias, 
       (SELECT d.name FROM stu150@my_link1 d WHERE d.id=sr.id), 
       sr.birth, 
       sr.weight, 
       sr.c_id, 
       p.location, 
       (SELECT c_id FROM stu333 WHERE name=p.name), 
       (SELECT y.name FROM class333 y, class150@my_link1 x WHERE y.name=x.name AND y.id=sr.c_id AND y.id=102), 
       (SELECT y.name FROM stu333 y, stu150@my_link1 x, class150@my_link1 pc WHERE y.name=x.name AND y.c_id=pc.id AND y.alias=sr.alias AND x.id = 1002 )
FROM class150@my_link1 p, stu150@my_link1 sr, class333 s
WHERE sr.c_id=s.id
AND p.id LIKE '2%'
AND sr.p_id LIKE '3%' 
AND CAST(sr.id AS char) LIKE '4%' 
AND p.name IN ('yinyue','dianzi')
AND p.id=sr.c_id
AND p.id>101
AND sr.alias IN ('zs','ls','ww','wl')
AND p.id BETWEEN 100 AND 106
AND sr.id > 1000 
AND s.id > 100 
AND p.id != 109;


--echo #用户场景12

SELECT A1.ID, A1.NAME, A1.location, A1.create_time, A1.id
FROM class150@my_link1 A1
WHERE A1.id=101 AND A1.name='yinyue' 
AND (IFNULL(A1.create_time,CURRENT_DATE()+1)>DATE_SUB(CURRENT_DATE(), INTERVAL 1 DAY)
AND IFNULL(A1.create_time,CURRENT_DATE()+1)<CURRENT_DATE() 
OR A1.create_time>CURRENT_DATE()-INTERVAL 100000/3 DAY)
AND A1.location<>'stcmNml'
AND A1.id<>1;

--echo #用户场景13

SELECT COUNT(*) FROM class150@my_link1 A1 WHERE TIMESTAMPDIFF(MINUTE, A1.create_time, CURRENT_TIMESTAMP()) > 5 * 60;

--echo #清理环境
--source mysql_test/test_suite/dblink_ob_ob_mysql_sqlqa/include/drop_tenant.inc
--error 0,4112
purge recyclebin;
sleep 5;