select case when 1 in (select 1 from grouping_rollup_t01 where COL_DECIMAL_20_2 = abs(a.COL_DECIMAL_20_2)+1 ) then 1 else 0 end COL_DECIMAL_20_2 from grouping_rollup_t01 a group by abs(COL_DECIMAL_20_2)+1;
select case when 1 in (select 1 from grouping_rollup_t01 where COL_DECIMAL_20_2 = a.COL_DECIMAL_20_2+1 union all select 1 from grouping_rollup_t01 where COL_DECIMAL_20_2 = a.COL_DECIMAL_20_2+1 ) then 1 else 0 end COL_DECIMAL_20_2 from grouping_rollup_t01 a group by COL_DECIMAL_20_2;
select concat(col_varchar2_20,col_int),col_date,min(col_timestamp),max(col_timestamp) from grouping_rollup_t01 where col_varchar2_20 < 'd' group by col_varchar2_20,col_int,col_date;
select concat(col_varchar2_21,min(col_int)),col_varchar2_20 from grouping_rollup_t01 where col_varchar2_21 < 'd' group by col_varchar2_21,col_int,col_varchar2_20;
select concat(col_varchar2_21,min(col_int)),col_varchar2_20,max(col_int) from grouping_rollup_t01 where col_varchar2_21 < 'd' group by col_varchar2_21,col_int,col_varchar2_20;
