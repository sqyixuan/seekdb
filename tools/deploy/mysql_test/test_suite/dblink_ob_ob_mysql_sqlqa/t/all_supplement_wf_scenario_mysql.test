connection default;
--error 0,4112
purge recyclebin;

--echo #新建本地用户
connect(sys_ora,$OBMYSQL_MS0,root,,test,$OBMYSQL_PORT);
connection sys_ora;
--error 0,1396
drop user lcq1 ;
create user 'lcq1' identified by 'lcq';
GRANT all privileges ON *.* TO 'lcq1'@'%' WITH GRANT OPTION;

--error 0,1396
drop user lcq2 ;
create user 'lcq2' identified by 'lcq';
GRANT all privileges ON *.* TO 'lcq2'@'%' WITH GRANT OPTION;

--error 0,1396
drop user lcq3 ;
create user 'lcq3' identified by 'lcq';
GRANT all privileges ON *.* TO 'lcq3'@'%' WITH GRANT OPTION;

connect (conn_lcq_1,$OBMYSQL_MS0,lcq1,lcq,test,$OBMYSQL_PORT);
connect (conn_lcq_2,$OBMYSQL_MS0,lcq2,lcq,test,$OBMYSQL_PORT);
connect (conn_lcq_3,$OBMYSQL_MS0,lcq3,lcq,test,$OBMYSQL_PORT);

--echo #新建远端dblink租户、用户
let $char_charset = 'UTF8';

--source mysql_test/test_suite/dblink_ob_ob_mysql_sqlqa/include/create_tenant_by_charset.inc
--source mysql_test/test_suite/dblink_ob_ob_mysql_sqlqa/include/conn_tenant.inc
disconnect conn_charset_test_user;

connect(sys_ora1,$OBMYSQL_MS0,root@tenant_charset_test,,test,$OBMYSQL_PORT);
connection sys_ora1;

--error 0,1396
drop user lcq1 ;
create user 'lcq1' identified by 'lcq';
GRANT all privileges ON *.* TO 'lcq1'@'%' WITH GRANT OPTION;

--error 0,1396
drop user lcq2 ;
create user 'lcq2' identified by 'lcq';
GRANT all privileges ON *.* TO 'lcq2'@'%' WITH GRANT OPTION;

--error 0,1396
drop user lcq3 ;
create user 'lcq3' identified by 'lcq';
GRANT all privileges ON *.* TO 'lcq3'@'%' WITH GRANT OPTION;

connect (conn_lcq_11,$OBMYSQL_MS0,lcq1@tenant_charset_test,lcq,test,$OBMYSQL_PORT);
connect (conn_lcq_21,$OBMYSQL_MS0,lcq2@tenant_charset_test,lcq,test,$OBMYSQL_PORT);

connection conn_lcq_11;
--source mysql_test/test_suite/dblink_ob_ob_mysql_sqlqa/include/ob_mysql_prepare_tableall2.inc

connection conn_lcq_21;
--source mysql_test/test_suite/dblink_ob_ob_mysql_sqlqa/include/ob_mysql_prepare_tableall2.inc

connection conn_lcq_3;
--source mysql_test/test_suite/dblink_ob_ob_mysql_sqlqa/include/ob_mysql_prepare_tableall2.inc

connection conn_lcq_3;
set autocommit = on;
###本地新建dblink
--disable_query_log
--error 0, 2024
drop database link if exists my_link1;
eval create database link if not exists my_link1 connect to lcq1@tenant_charset_test database test identified by 'lcq' host '$OBMYSQL_MS0:$OBMYSQL_PORT';

--error 0, 2024
drop database link if exists my_link2;
eval create database link if not exists my_link2 connect to lcq2@tenant_charset_test database test identified by 'lcq' host '$OBMYSQL_MS0:$OBMYSQL_PORT';

--enable_query_log
set autocommit = on;
set ob_query_timeout=99900000000;
set ob_trx_timeout = 1000000000;  
SET NAMES UTF8;


--echo ####mysql_dblink_read-09-09 窗口函数

select 1 from grouping1 order by min(COL_DECIMAL_20_2);
select 1 from grouping1@my_link1 order by min(COL_DECIMAL_20_2);
select 1 from grouping1@my_link1 order by min(COL_DECIMAL_20_2);
select 1 from wf_test1 a group by case when COL_DECIMAL_20_2 > (select avg(b.COL_DECIMAL_20_2) from wf_test1 b) then 1 else 0 end;
select case when COL_DECIMAL_20_2 in (select a.COL_DECIMAL_20_2 from wf_test1 b) then 1 else 0 end COL_DECIMAL_20_2 from wf_test1 a group by case when COL_DECIMAL_20_2 in (select a.COL_DECIMAL_20_2 from wf_test1 b) then 1 else 0 end;

select 1 from wf_test1@my_link1 a group by case when COL_DECIMAL_20_2 > (select avg(b.COL_DECIMAL_20_2) from wf_test1@my_link1 b) then 1 else 0 end;
select case when COL_DECIMAL_20_2 in (select a.COL_DECIMAL_20_2 from wf_test1@my_link1 b) then 1 else 0 end COL_DECIMAL_20_2 from wf_test1@my_link1 a group by case when COL_DECIMAL_20_2 in (select a.COL_DECIMAL_20_2 from wf_test1@my_link1 b) then 1 else 0 end;

### grouping11@my_link1
select grouping(col_varchar2_20), grouping(col_date), grouping(col_int), col_varchar2_20, col_date, max(col_int), max(distinct col_int), min(col_int), min(distinct col_int), sum(col_int),
sum(distinct col_int), count(*), count(col_int), count(distinct col_int) from grouping11@my_link1 group by col_varchar2_20, col_date, col_int WITH ROLLUP order by grouping(col_int), grouping(col_date);

###cume_group@my_link1
select pk,ceil(cumedistvalue) cumedistvalue,count(*) from (select pk,cume_dist() over (order by grouping(col_varchar2_20),grouping(pk) desc ) cumedistvalue from cume_group@my_link1 where (COL_INT between 300 and 887266517765 and COL_DECIMAL_20_2 = 522654.38) or COL_DATE is NULL and abs(COL_NUMBER) <> 9999999 group by pk,col_varchar2_20 with rollup order by pk asc) group by pk,ceil(cumedistvalue);

select col_number, min(col_int), max(col_int) from grouping_rollup_t00 group by col_number order by 1,2,3 ;
select col_number,sum(col_int) from grouping_rollup_t00 where COL_DECIMAL_20_2>1 group by col_number having col_number>1 order by col_number;
select abs(COL_DECIMAL_20_2)+1+2 from grouping_rollup_t00 group by abs(COL_DECIMAL_20_2)+1 order by 1 ;
select COL_DECIMAL_20_2, max(col_number), CASE max(col_int) when 4 then 4 when 43 then 43 else 0 end from grouping_rollup_t00 group by COL_DECIMAL_20_2 order by 1 ;
select COL_DECIMAL_20_2, max(col_number), CONCAT(max(col_number), '43') from grouping_rollup_t00 group by COL_DECIMAL_20_2 order by 3;

select COL_DECIMAL_20_2+1, case when 1 in (select count(a.COL_DECIMAL_20_2 + 1) from grouping_rollup_t00  ) then 1 else 0 end COL_DECIMAL_20_2 from grouping_rollup_t00 a group by COL_DECIMAL_20_2+1 order by 1,2 ;
select COL_DECIMAL_20_2+1, (select a.COL_DECIMAL_20_2+1 from dual) from grouping_rollup_t00 a group by COL_DECIMAL_20_2+1 order by 2 ;
select COL_DECIMAL_20_2 d1 from grouping_rollup_t00 group by COL_DECIMAL_20_2 having COL_DECIMAL_20_2 > 0 order by 1;
select COL_DECIMAL_20_2, col_number, col_int, count(*) from grouping_rollup_t00 group by COL_DECIMAL_20_2, col_number, col_int order by 1,3 desc  ;
select COL_DECIMAL_20_2,col_int from grouping_rollup_t00 group by COL_DECIMAL_20_2,col_int order by col_int ;
select COL_DECIMAL_20_2,col_int, (select a.COL_DECIMAL_20_2 from dual) from grouping_rollup_t00 a group by COL_DECIMAL_20_2,col_int order by 3 ;
select COL_DECIMAL_20_2 from grouping_rollup_t00 group by COL_DECIMAL_20_2 having COL_DECIMAL_20_2>0 order by 1 ;
select COL_DECIMAL_20_2 from grouping_rollup_t00 group by COL_DECIMAL_20_2 having (select count(grouping_rollup_t00.COL_DECIMAL_20_2) from grouping_rollup_t00 t limit 1)>0 order by 1;

select COL_DECIMAL_20_2+1,(select a.COL_DECIMAL_20_2+1 from dual),COL_DECIMAL_20_2+1 from grouping_rollup_t00 a group by COL_DECIMAL_20_2+1 order by 1 ;
select col_int, sum(COL_DECIMAL_20_2), count(COL_DECIMAL_20_2), avg(COL_DECIMAL_20_2), max(COL_DECIMAL_20_2), min(COL_DECIMAL_20_2) from grouping_rollup_t00 group by col_int order by 1,2,3,4,5,6 desc ;

