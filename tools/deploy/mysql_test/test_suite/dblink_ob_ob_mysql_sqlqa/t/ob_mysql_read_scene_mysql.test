--echo # group by rollup

SELECT DISTINCT stu150.p_id AS C5, stu150.id AS C1, stu150.name AS C6, stu150.alias AS C7,
SUM(DISTINCT stu150.id) OVER (PARTITION BY stu150.id) AS sum1
FROM stu150
WHERE concat(stu150.p_id, stu150.c_id) LIKE '%Ab%'
GROUP BY  stu150.p_id, stu150.id, stu150.name, stu150.alias with rollup;

SELECT DISTINCT stu150.p_id AS C5, stu150.id AS C1, stu150.name AS C6, stu150.alias AS C7,
SUM(DISTINCT stu150.id) OVER (PARTITION BY stu150.id) AS sum1
FROM stu150@my_link1 stu150
WHERE concat(stu150.p_id, stu150.c_id) LIKE '%Ab%'
GROUP BY  stu150.p_id, stu150.id, stu150.name, stu150.alias with rollup;

--echo # 子查询*2

SELECT T23_90.C10, T23_90.C7
FROM
(SELECT stu150.id AS C1, stu150.p_id AS C2, stu150.name AS C3, stu150.alias AS C4, stu150.birth AS C5, stu150.weight AS C6,
(SELECT MIN(stu150.c_id) FROM stu150) AS C7, stu150.birth AS C8, stu150.weight AS C9, stu150.id AS C10, stu150.name AS C11,
stu150.alias AS C12, stu150.birth AS C13, (SELECT MAX(stu150.c_id) FROM stu150) AS C14, stu150.weight AS C15, stu150.p_id AS C16,
(SELECT c_id FROM stu150 ORDER BY c_id ASC LIMIT 1) AS C17
FROM stu150
WHERE stu150.p_id LIKE '%Ab%' ) T23_90
WHERE 9 IN (T23_90.C14, T23_90.C14) OR T23_90.C4 > (SELECT T23_90.C4 FROM stu150 ORDER BY 1 LIMIT 1)
GROUP BY T23_90.C10, T23_90.C7;

SELECT T23_90.C10, T23_90.C7
FROM
(SELECT stu150.id AS C1, stu150.p_id AS C2, stu150.name AS C3, stu150.alias AS C4, stu150.birth AS C5, stu150.weight AS C6,
(SELECT MIN(stu150.c_id) FROM stu150) AS C7, stu150.birth AS C8, stu150.weight AS C9, stu150.id AS C10, stu150.name AS C11,
stu150.alias AS C12, stu150.birth AS C13, (SELECT MAX(stu150.c_id) FROM stu150) AS C14, stu150.weight AS C15, stu150.p_id AS C16,
(SELECT c_id FROM stu150 ORDER BY c_id ASC LIMIT 1) AS C17
FROM stu150@my_link1 stu150
WHERE stu150.p_id LIKE '%Ab%' ) T23_90
WHERE 9 IN (T23_90.C14, T23_90.C14) OR T23_90.C4 > (SELECT T23_90.C4 FROM stu150 ORDER BY 1 LIMIT 1)
GROUP BY T23_90.C10, T23_90.C7;


--echo # no_rewrite

SELECT stu150.name
FROM stu150
WHERE stu150.id = (SELECT stu150.id FROM stu150 ORDER BY 1 DESC LIMIT 1)
OR stu150.alias > stu150.birth AND 1=2;

SELECT /*+no_rewrite*/ stu150.name
FROM stu150@my_link1 stu150
WHERE stu150.id = (SELECT /*+no_rewrite*/ stu150.id FROM stu150 ORDER BY 1 DESC LIMIT 1)
OR stu150.alias > stu150.birth AND 1=2;


--echo # 子查询参数位置

SELECT s.id, s.name, s.birth, s.c_id
FROM (SELECT DISTINCT id, name, birth, c_id FROM stu150) s
JOIN class150 c ON c.id = s.c_id
WHERE s.id < 1005;

SELECT s.id, s.name, s.birth, s.c_id
FROM (SELECT DISTINCT id, name, birth, c_id FROM stu150@my_link1) s
JOIN class150@my_link2 c ON c.id = s.c_id
WHERE s.id < 1005;

--echo #  集合查询

SELECT b.id, b.name, b.location
FROM
(SELECT c_id FROM stu150 WHERE id > 1001 GROUP BY c_id HAVING c_id > 101 ORDER BY c_id) a
JOIN class150 b ON a.c_id = b.id
UNION ALL
SELECT b.id, b.name, b.location
FROM
(SELECT c_id FROM stu150 WHERE id > 1001 GROUP BY c_id HAVING c_id > 101 ORDER BY c_id) a
RIGHT JOIN class150 b ON a.c_id = b.id;


SELECT b.id, b.name, b.location
FROM
(SELECT c_id FROM stu150@my_link1 WHERE id > 1001 GROUP BY c_id HAVING c_id > 101 ORDER BY c_id) a
JOIN class150@my_link1 b ON a.c_id = b.id
UNION ALL
SELECT b.id, b.name, b.location
FROM
(SELECT c_id FROM stu150@my_link1 WHERE id > 1001 GROUP BY c_id HAVING c_id > 101 ORDER BY c_id) a
RIGHT JOIN class150 b ON a.c_id = b.id;

--echo # JOIN后where条件限制

SELECT s.*
FROM stu150 s
INNER JOIN class150 c ON s.c_id = c.id
WHERE s.id > 1004;

SELECT s.*
FROM stu150@my_link1 s
INNER JOIN class150@my_link1 c ON s.c_id = c.id
WHERE s.id > 1004;

SELECT b.id, b.name, b.location
FROM
(SELECT c_id FROM stu150 WHERE id > 1001 GROUP BY c_id HAVING c_id > 101 ORDER BY c_id) a
JOIN class150 b ON a.c_id = b.id;

SELECT b.id, b.name, b.location
FROM
(SELECT c_id FROM stu150@my_link1 WHERE id > 1001 GROUP BY c_id HAVING c_id > 101 ORDER BY c_id) a
JOIN class150@my_link1 b ON a.c_id = b.id;

SELECT b.id, b.name, b.location
FROM
(SELECT c_id FROM stu150 WHERE id > 1004 GROUP BY c_id HAVING c_id > 101
UNION
SELECT c_id FROM stu150 WHERE id < 1003 GROUP BY c_id HAVING c_id = 101 ORDER BY c_id) a
JOIN class150 b ON a.c_id = b.id;

SELECT b.id, b.name, b.location
FROM
(SELECT c_id FROM stu150@my_link1 WHERE id > 1004 GROUP BY c_id HAVING c_id > 101
UNION
SELECT c_id FROM stu150@my_link1 WHERE id < 1003 GROUP BY c_id HAVING c_id = 101 ORDER BY c_id) a
JOIN class150@my_link1 b ON a.c_id = b.id;


SELECT s.* , c.*
FROM stu150 s
LEFT OUTER JOIN class150 c ON s.c_id = c.id
WHERE s.id > 1004;

SELECT s.* , c.*
FROM stu150@my_link1 s
LEFT OUTER JOIN class150@my_link1 c ON s.c_id = c.id
WHERE s.id > 1004;


--echo # 递归公用表达式 (CTE)

WITH RECURSIVE 
odd_no (sr_no, n) AS
(
SELECT 1, id FROM class150 where id = 101
union all
SELECT sr_no+1, n+2 from odd_no where sr_no < 5 
)
SELECT * FROM odd_no;  

WITH RECURSIVE 
odd_no (sr_no, n) AS
(
SELECT 1, id FROM class150@my_link1 where id = 101
union all
SELECT sr_no+1, n+2 from odd_no where sr_no < 5 
)
SELECT * FROM odd_no;  


WITH RECURSIVE cte AS (
SELECT id, name, CAST(FLOOR(LOG(p_id)) AS UNSIGNED) AS p_id_level, c_id
FROM stu150@my_link1
WHERE FLOOR(LOG(p_id)) IN (SELECT FLOOR(LOG(id)) FROM stu150@my_link1 WHERE id < 103 UNION SELECT FLOOR(LOG(id)) FROM stu150@my_link2 WHERE id > 103)
UNION ALL
SELECT s.id, s.name, CAST(FLOOR(LOG(s.p_id)) AS UNSIGNED) AS p_id_level, s.c_id
FROM stu150 s
JOIN cte ON CAST(FLOOR(LOG(s.p_id)) AS UNSIGNED) = cte.p_id_level AND s.id =1001
)
SELECT * FROM cte;


WITH RECURSIVE temp(id, p_id, name, level) AS (
SELECT id, p_id, name, 1 FROM stu150 WHERE FLOOR(log(id) * 100000) > (SELECT MIN(a.m) FROM (SELECT FLOOR(log(id) * 100000) m FROM class150) a INNER JOIN (SELECT FLOOR(log(id) * 100000) n,FLOOR(log(id) * 1200000) FROM class150) b ON a.m=b.n)/0.8 AND name='zhaoliu' AND id > (998 + (SELECT MIN(b.n) FROM (SELECT FLOOR(log(id) * 100000) m FROM class150) a INNER JOIN (SELECT FLOOR(log(id) * 100000) n,FLOOR(log(id) * 1200000) FROM class150) b ON a.m=b.n WHERE FLOOR(log(3)) = 0))
UNION ALL
SELECT s.id, s.p_id, s.name, t.level+1 FROM stu150 s, temp t WHERE s.p_id = t.id
)
SELECT FLOOR(log(temp.id) * 100000), temp.name FROM temp INNER JOIN class150 ON temp.id = class150.id ORDER BY temp.id;

WITH RECURSIVE temp(id, p_id, name, level) AS (
SELECT id, p_id, name, 1 FROM stu150@my_link1 WHERE FLOOR(log(id) * 100000) > (SELECT MIN(a.m) FROM (SELECT FLOOR(log(id) * 100000) m FROM class150) a INNER JOIN (SELECT FLOOR(log(id) * 100000) n,FLOOR(log(id) * 1200000) FROM class150) b ON a.m=b.n)/0.8 AND name='zhaoliu' AND id > (998 + (SELECT MIN(b.n) FROM (SELECT FLOOR(log(id) * 100000) m FROM class150) a INNER JOIN (SELECT FLOOR(log(id) * 100000) n,FLOOR(log(id) * 1200000) FROM class150@my_link2) b ON a.m=b.n WHERE FLOOR(log(3)) = 0))
UNION ALL
SELECT s.id, s.p_id, s.name, t.level+1 FROM stu150@my_link2 s, temp t WHERE s.p_id = t.id
)
SELECT FLOOR(log(temp.id) * 100000), temp.name FROM temp INNER JOIN class150 ON temp.id = class150.id ORDER BY temp.id;

--echo #  NATURAL JOIN

SELECT * FROM (SELECT c_id FROM stu150 WHERE id>1004 GROUP BY c_id HAVING c_id>101 UNION SELECT c_id FROM stu150 WHERE id<1003 GROUP BY c_id HAVING c_id=101 ORDER BY c_id) a NATURAL JOIN (SELECT DISTINCT id,name,location FROM class150) b WHERE a.c_id=b.id;

SELECT * FROM (SELECT c_id FROM stu150@my_link1 WHERE id>1004 GROUP BY c_id HAVING c_id>101 UNION SELECT c_id FROM stu150@my_link2 WHERE id<1003 GROUP BY c_id HAVING c_id=101 ORDER BY c_id) a NATURAL JOIN (SELECT DISTINCT id,name,location FROM class150) b WHERE a.c_id=b.id;

--echo # 笛卡尔积

SELECT s.id,s.name,c.location,c.create_time FROM stu150 s, class150 c WHERE s.id=1004;
SELECT s.id,s.name,c.location,c.create_time FROM stu150@my_link1 s, class150@my_link2 c WHERE s.id=1004;


--echo # 子查询获取元素

SELECT t.c0, t.c1, 70 AS c2 FROM (
SELECT ref_2.id AS c0, ref_1.name AS c1 FROM (
SELECT * FROM stu150
UNION ALL
SELECT NULL, NULL, NULL, NULL, NULL, NULL, NULL
) ref_1 LEFT JOIN (
SELECT * FROM class150
UNION ALL
SELECT NULL, NULL, NULL, NULL
) ref_2 ON ref_2.id <= ref_2.id
) t WHERE 75 IS NOT NULL;

SELECT t.c0, t.c1, 70 AS c2 FROM (
SELECT ref_2.id AS c0, ref_1.name AS c1 FROM (
SELECT * FROM stu150@my_link1
UNION ALL
SELECT NULL, NULL, NULL, NULL, NULL, NULL, NULL
) ref_1 LEFT JOIN (
SELECT * FROM class150@my_link1
UNION ALL
SELECT NULL, NULL, NULL, NULL
) ref_2 ON ref_2.id <= ref_2.id
) t WHERE 75 IS NOT NULL;


--echo # LIMIT 边界值

SELECT * FROM stu150 WHERE id > 6 LIMIT 5, 9223372036854775800;
SELECT * FROM stu150@my_link1 WHERE id > 6 LIMIT 5, 9223372036854775800;

--echo # 表、列 别名

SELECT shenle.id , MAX(shenle.p_id ) FROM stu150@my_link1 shenle JOIN stu150 ON shenle.id = stu150.id WHERE shenle.id = 39 GROUP BY shenle.id, shenle.p_id ORDER BY stu150.p_id DESC;


--echo #  多dblink表子查询

SELECT DISTINCT T32_1.id
FROM 
    class150 T32_1, 
    stu150 T1_176_1
WHERE (EXISTS (SELECT stu150.id FROM stu150 WHERE stu150.id = T32_1.id)) 
AND T1_176_1.id <= 2 
AND T32_1.id <= 2 
AND T1_176_1.c_id = T32_1.id 
AND (
    SELECT COUNT(*) FROM (
        SELECT stu150.id FROM stu150
    ) AS subquery
) > 0;


SELECT DISTINCT T32_1.id
FROM 
    class150@my_link1 T32_1, 
    stu150@my_link1 T1_176_1
WHERE (EXISTS (SELECT stu150.id FROM stu150@my_link2 WHERE stu150.id = T32_1.id)) 
AND T1_176_1.id <= 2 
AND T32_1.id <= 2 
AND T1_176_1.c_id = T32_1.id 
AND (
    SELECT COUNT(*) FROM (
        SELECT stu150.id FROM stu150@my_link2
    ) AS subquery
) > 0;


--echo # 常用查询

SELECT c_id, AVG(weight) AS avg_weight FROM stu150@my_link1 GROUP BY c_id ORDER BY avg_weight DESC LIMIT 3;
SELECT location, COUNT(*) AS record_count FROM class150@my_link1 GROUP BY location ORDER BY record_count DESC;
SELECT s.name, c.location FROM stu150@my_link1 s INNER JOIN class150@my_link1 c ON s.c_id = c.id WHERE s.id BETWEEN 1001 AND 1002;
SELECT location FROM class150@my_link1 WHERE id IN (101,102) ORDER BY create_time ASC LIMIT 1;
SELECT s.name, s.weight, s.birth FROM stu150@my_link1 s INNER JOIN (SELECT c_id, MAX(weight) AS max_weight FROM stu150@my_link1 GROUP BY c_id) m ON s.c_id = m.c_id AND s.weight = m.max_weight ORDER BY s.birth DESC;

SELECT c.location, COUNT(*) AS record_count, MAX(s.birth) AS max_birth, MIN(s.weight) AS min_weight
FROM class150 c
LEFT JOIN (SELECT * FROM stu150 WHERE birth > '1990-01-01') s ON c.id = s.c_id
WHERE c.id IN (101, 102)
GROUP BY c.location
HAVING record_count > 0
ORDER BY max_birth DESC, min_weight ASC
LIMIT 3;

SELECT c.location, COUNT(*) AS record_count, MAX(s.birth) AS max_birth, MIN(s.weight) AS min_weight
FROM class150@my_link1 c
LEFT JOIN (SELECT * FROM stu150@my_link2 WHERE birth > '1990-01-01') s ON c.id = s.c_id
WHERE c.id IN (101, 102)
GROUP BY c.location
HAVING record_count > 0
ORDER BY max_birth DESC, min_weight ASC
LIMIT 3;


SELECT c.location, AVG(s.weight) AS avg_weight, RANK() OVER (ORDER BY AVG(s.weight) DESC) AS weight_rank, 
SUM(AVG(s.weight)) OVER (ORDER BY AVG(s.weight) DESC ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) AS cumulative_weight 
FROM (
    SELECT * FROM class150
) AS c
LEFT JOIN (
    SELECT * FROM stu150 WHERE birth >= DATE_SUB(CURDATE(), INTERVAL 30 DAY)
) AS s ON c.id = s.c_id
GROUP BY c.id
ORDER BY avg_weight DESC;


SELECT c.location, AVG(s.weight) AS avg_weight, RANK() OVER (ORDER BY AVG(s.weight) DESC) AS weight_rank, 
SUM(AVG(s.weight)) OVER (ORDER BY AVG(s.weight) DESC ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) AS cumulative_weight 
FROM (
    SELECT * FROM class150@my_link1
) AS c
LEFT JOIN (
    SELECT * FROM stu150@my_link2 WHERE birth >= DATE_SUB(CURDATE(), INTERVAL 30 DAY)
) AS s ON c.id = s.c_id
GROUP BY c.id
ORDER BY avg_weight DESC;

