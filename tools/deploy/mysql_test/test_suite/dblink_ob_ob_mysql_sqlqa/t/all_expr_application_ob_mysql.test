connection default;
--error 0,4112
purge recyclebin;

--echo #新建本地用户
connect(sys_ora,$OBMYSQL_MS0,root,,test,$OBMYSQL_PORT);
connection sys_ora;
--error 0,1396
drop user lcq1 ;
create user 'lcq1' identified by 'lcq';
GRANT all privileges ON *.* TO 'lcq1'@'%' WITH GRANT OPTION;

--error 0,1396
drop user lcq2 ;
create user 'lcq2' identified by 'lcq';
GRANT all privileges ON *.* TO 'lcq2'@'%' WITH GRANT OPTION;

--error 0,1396
drop user lcq3 ;
create user 'lcq3' identified by 'lcq';
GRANT all privileges ON *.* TO 'lcq3'@'%' WITH GRANT OPTION;

connect (conn_lcq_1,$OBMYSQL_MS0,lcq1,lcq,test,$OBMYSQL_PORT);
connect (conn_lcq_2,$OBMYSQL_MS0,lcq2,lcq,test,$OBMYSQL_PORT);
connect (conn_lcq_3,$OBMYSQL_MS0,lcq3,lcq,test,$OBMYSQL_PORT);

--echo #新建远端dblink租户、用户
let $char_charset = 'UTF8';

--source mysql_test/test_suite/dblink_ob_ob_mysql_sqlqa/include/create_tenant_by_charset.inc
--source mysql_test/test_suite/dblink_ob_ob_mysql_sqlqa/include/conn_tenant.inc
disconnect conn_charset_test_user;

connect(sys_ora1,$OBMYSQL_MS0,root@tenant_charset_test,,test,$OBMYSQL_PORT);
connection sys_ora1;

--error 0,1396
drop user lcq1 ;
create user 'lcq1' identified by 'lcq';
GRANT all privileges ON *.* TO 'lcq1'@'%' WITH GRANT OPTION;

--error 0,1396
drop user lcq2 ;
create user 'lcq2' identified by 'lcq';
GRANT all privileges ON *.* TO 'lcq2'@'%' WITH GRANT OPTION;

--error 0,1396
drop user lcq3 ;
create user 'lcq3' identified by 'lcq';
GRANT all privileges ON *.* TO 'lcq3'@'%' WITH GRANT OPTION;

connect (conn_lcq_11,$OBMYSQL_MS0,lcq1@tenant_charset_test,lcq,test,$OBMYSQL_PORT);
connect (conn_lcq_21,$OBMYSQL_MS0,lcq2@tenant_charset_test,lcq,test,$OBMYSQL_PORT);

connection conn_lcq_11;
--source mysql_test/test_suite/dblink_ob_ob_mysql_sqlqa/include/ob_mysql_prepare_tableall.inc

connection conn_lcq_21;
--source mysql_test/test_suite/dblink_ob_ob_mysql_sqlqa/include/ob_mysql_prepare_tableall.inc

connection conn_lcq_3;
--source mysql_test/test_suite/dblink_ob_ob_mysql_sqlqa/include/ob_mysql_prepare_tableall.inc

connection conn_lcq_3;
set autocommit = on;
###本地新建dblink
--disable_query_log
--error 0, 2024
drop database link if exists my_link1;
eval create database link if not exists my_link1 connect to lcq1@tenant_charset_test database test identified by 'lcq' host '$OBMYSQL_MS0:$OBMYSQL_PORT';

--error 0, 2024
drop database link if exists my_link2;
eval create database link if not exists my_link2 connect to lcq2@tenant_charset_test database test identified by 'lcq' host '$OBMYSQL_MS0:$OBMYSQL_PORT';

--enable_query_log
set autocommit = on;
set ob_query_timeout=99900000000;
set ob_trx_timeout = 1000000000;  
SET NAMES UTF8;

--echo #mysql_dblink_read-05 简单表达式

###SELECT TO_CHAR(TRUNC(SYSDATE+7)) FROM gbktable@my_link1;

--error 1064
SELECT gbktable@my_link1.列名 FROM gbktable@my_link1;
--error 1054
SELECT t.列名 FROM gbktable@my_link1 t;

--error 1064
SELECT N 'this is an NCHAR string' FROM DUAL@my_link1;
--error 1064
SELECT 'this is a text string' FROM DUAL@my_link1;
--error 1064
SELECT 10 FROM DUAL@my_link1;
--error 1064
SELECT 'this is a text string' FROM DUAL@my_link1;


--echo # 复合表达式
--error 1064
SELECT ('CLARK' || 'SMITH') FROM DUAL@my_link1;
--error 1064
SELECT LENGTH('MOOSE') * 57 FROM DUAL@my_link1;
--error 1064
SELECT SORT(144) + 72 FROM DUAL@my_link1;
--error 1064
SELECT my_fun(TO_CHAR(sysdate, 'DD-MMM-YY')) FROM DUAL@my_link1;

SELECT (c0||c1 || c2) FROM gbktable@my_link2;
SELECT LENGTH('字段') * 57 FROM gbktable@my_link2;

--echo # 条件表达式
SELECT c1,
    CASE c2
    WHEN '100' THEN 'Low'
    WHEN '5000' THEN 'High'
    ELSE 'Medium' END AS credit
FROM gbktable@my_link1
ORDER BY c1, credit;

SELECT c1,
    CASE c2
    WHEN 100 THEN 'Low'
    WHEN 5000 THEN 'High'
    ELSE 'Medium' END AS credit
FROM gbktable@my_link2
ORDER BY c1, credit;

--echo # 日期时间表达式
SELECT timestamp '2020-01-01 10:00:00' FROM DUAL;
SELECT date '2020-01-01 10:00:00' FROM DUAL;


--echo # 间隔表达式
--echo # 标量子查询，向量比较

select /*+use_index(t_deduce_length idx_3)*/ * from t_deduce_length where c_number > (select min(c_number) from t_deduce_length) and c_number < (select max(c_number2) from t_deduce_length2)  ORDER BY t_deduce_length.c_int;

select /*+use_index(t_deduce_length@my_link1 idx_3)*/ * from t_deduce_length@my_link1 t_deduce_length 
where c_number > (select min(c_number) from t_deduce_length@my_link1) 
and c_number < (select max(c_number) from t_deduce_length@my_link1)  ORDER BY t_deduce_length.c_int;

select /*+index(bmsql_oorder gkey17)*/ o_id, o_entry_d, o_carrier_id FROM 
bmsql_oorder@my_link1 where o_w_id = 36 AND o_d_id = 7 AND o_c_id = 169 AND o_id = (select max(o_id) 
FROM bmsql_oorder@my_link1 WHERE o_w_id = 36 AND o_d_id = 7 AND o_c_id = 169);


###子查询测试###
select * from t_deduce_length@my_link1 where c_int = (select c_int2 from t_deduce_length2 where c_number2>0 LIMIT 1) ORDER BY t_deduce_length.c_int;
select * from t_deduce_length@my_link1 join t_deduce_length2 on t_deduce_length.c_int = t_deduce_length2.c_int2 where t_deduce_length.c_number>2  ORDER BY t_deduce_length.c_int;
select * from t_deduce_length@my_link1 left join t_deduce_length2 on t_deduce_length.c_int = t_deduce_length2.c_int2 where t_deduce_length.c_number='5'  ORDER BY t_deduce_length.c_int;
select * from t_deduce_length@my_link1 right join t_deduce_length2 on t_deduce_length.c_int = t_deduce_length2.c_int2 where t_deduce_length.c_number='6'  ORDER BY t_deduce_length.c_int;
select * from t_deduce_length@my_link1 where c_number > (select min(c_number) from t_deduce_length) and c_number < (select max(c_number2) from t_deduce_length2)  ORDER BY t_deduce_length.c_int;
select * from t_deduce_length@my_link1 where c_number in (select c_number2 from t_deduce_length2 where c_int2<>'1111')  ORDER BY t_deduce_length.c_int;
select * from t_deduce_length@my_link1 where c_number > any (select c_number2 from t_deduce_length2 where c_int = 8)  ORDER BY t_deduce_length.c_int;
select * from t_deduce_length@my_link1 where c_number > all (select c_number2 from t_deduce_length2 where c_int = 9)  ORDER BY t_deduce_length.c_int;
select * from t_deduce_length@my_link1 f where c_number > (select avg(c_number2) from t_deduce_length2 where c_int2 = f.c_int) order by c_int;

####index回表，查询不带index列###
select t_deduce_length.c_number from t_deduce_length@my_link1 where c_int = (select c_int2 from t_deduce_length2 where c_number2='1' LIMIT 1)  ORDER BY t_deduce_length.c_int;
select t_deduce_length.c_number from t_deduce_length@my_link1 join t_deduce_length2 on t_deduce_length.c_int = t_deduce_length2.c_int2 where t_deduce_length.c_number='2'  ORDER BY t_deduce_length.c_int;
select t_deduce_length.c_number from t_deduce_length@my_link1 left join t_deduce_length2 on t_deduce_length.c_int = t_deduce_length2.c_int2 where t_deduce_length.c_number='5'  ORDER BY t_deduce_length.c_int;
select t_deduce_length.c_number from t_deduce_length@my_link1 right join t_deduce_length2 on t_deduce_length.c_int = t_deduce_length2.c_int2 where t_deduce_length.c_number='3'  ORDER BY t_deduce_length.c_int;
select t_deduce_length.c_number from t_deduce_length@my_link1 left join t_deduce_length2 on t_deduce_length.c_int = t_deduce_length2.c_int2 where t_deduce_length.c_number='3' and t_deduce_length2.c_int2 IS NULL ORDER BY t_deduce_length.c_int;
select t_deduce_length.c_number from t_deduce_length@my_link1 right join t_deduce_length2 on t_deduce_length.c_int = t_deduce_length2.c_int2 where t_deduce_length.c_number='5' and t_deduce_length.c_int IS NULL ORDER BY t_deduce_length.c_int;
select t_deduce_length.c_number from t_deduce_length@my_link1 left join t_deduce_length2 on t_deduce_length.c_int = t_deduce_length2.c_int2 where t_deduce_length.c_number='3' union
select t_deduce_length.c_number from t_deduce_length@my_link1 right join t_deduce_length2 on t_deduce_length.c_int = t_deduce_length2.c_int2 where t_deduce_length.c_number='3';
select t_deduce_length.c_number from t_deduce_length@my_link1 left join t_deduce_length2 on t_deduce_length.c_int = t_deduce_length2.c_int2 where t_deduce_length.c_number='3' and t_deduce_length2.c_int2 IS NULL union
select t_deduce_length.c_number from t_deduce_length@my_link1 right join t_deduce_length2 on t_deduce_length.c_int = t_deduce_length2.c_int2 where t_deduce_length.c_number='3' and t_deduce_length.c_int IS NULL ;


####向量相关

select * from t_deduce_length@my_link1,
(select t_deduce_length2.c_int2 cint,count(*) as countnum from t_deduce_length2 where t_deduce_length2.c_number2>2 group by t_deduce_length2.c_int2 ) 
t_deduce_lengthtest where t_deduce_length.c_int = 14 and t_deduce_length.c_int = t_deduce_lengthtest.cint;

select t_deduce_length.c_int cint,t_deduce_length.c_number as sumnumber from t_deduce_length@my_link1 join t_deduce_length2 on t_deduce_length.c_int = t_deduce_length2.c_int2 
where t_deduce_length.c_number>2 or t_deduce_length2.c_number2>2 or t_deduce_length.c_int < 20;

select t_deduce_length2.c_int2 cint,count(*) as countnum from t_deduce_length2 where t_deduce_length2.c_number2>1 group by t_deduce_length2.c_int2;

select  c_int + 100, c_number from t_deduce_length where c_int < 100 and c_number = 2 order by c_int;

select * from (
select * from 
(select t_deduce_length.c_int cint,t_deduce_length.c_number as sumnumber from t_deduce_length@my_link1 join t_deduce_length2 on t_deduce_length.c_int = t_deduce_length2.c_int2 where t_deduce_length.c_number>2) a
join
(select t_deduce_length.c_int cint2,t_deduce_length.c_number as sumnumber2 from t_deduce_length@my_link1 join t_deduce_length2 on t_deduce_length.c_int = t_deduce_length2.c_int2 where t_deduce_length.c_number>2) b
on a.cint = b.cint2 LIMIT 1)
LIMIT 1;

select  * from t_deduce_length where (c_int,c_number,c_number_l) in ((1,1,1),(2,2,2),(3,3,3),(4,4,4),(5,5,5)) order by c_int,c_number,c_number_l;
select  * from t_deduce_length where (c_int,c_number,c_number_l) not in ((1,1,1),(2,2,2),(3,3,3),(4,4,4),(5,5,5)) order by c_int,c_number,c_number_l;

select  * from t_deduce_length where (c_int,c_number,c_number_l) < (1,3,5) order by c_int,c_number,c_number_l;
select  * from t_deduce_length where (c_int,c_number,c_number_l) > (1,1,1) order by c_int,c_number,c_number_l;

