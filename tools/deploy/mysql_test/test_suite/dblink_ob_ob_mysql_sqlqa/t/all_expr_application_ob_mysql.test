SELECT * FROM employees
    WHERE (ENAME, JOB) IN
        (('SMITH', 'CLERK'),('ALLEN', 'SALESMAN'));
		
SELECT JOB, MIN(EMPNO) min, MAX(EMPNO) max FROM employees 
    GROUP BY JOB,EMPNO
    ORDER BY EMPNO;
	
SELECT * FROM employees@my_link1
    WHERE (ENAME, JOB) IN
        (('SMITH', 'CLERK'),('ALLEN', 'SALESMAN'));

