SELECT * FROM class333_1 order by 1,2,3,4;
DELETE FROM class333_1 WHERE 1=1;

INSERT INTO class333_1(id,name,location)
	SELECT b.* FROM (SELECT c_id FROM stu233@my_link2 WHERE id>1001 GROUP BY c_id HAVING c_id>101 ORDER BY c_id) a JOIN (SELECT DISTINCT id,name,location FROM class150@my_link1) b ON a.c_id=b.id
	INTERSECT
	SELECT b.* FROM (SELECT c_id FROM stu333 WHERE id>1001 GROUP BY c_id HAVING c_id>101 ORDER BY c_id) a RIGHT JOIN (SELECT DISTINCT id,name,location FROM class333) b ON a.c_id=b.id;
SELECT * FROM class333_1 order by 1,2,3,4;
DELETE FROM class333_1 WHERE 1=1;

INSERT INTO stu333_1(name,alias) 
	WITH a AS (SELECT * FROM stu150@my_link1),
		b AS (SELECT * FROM class150@my_link1) 
		SELECT m.e,m.r FROM (SELECT a.id q,b.id w,a.name e,b.name r FROM a,b) m;
SELECT * FROM stu333_1 order by 1,2,3,4,5,6,7;
DELETE FROM stu333_1 WHERE 1=1;

--echo #mysql_dblink_read-06-7	update
--disable_warnings
DROP TABLE stu333_1 ;
DROP TABLE class333_1 ;
--enable_warnings
CREATE TABLE class333_1 AS SELECT * FROM class333;
CREATE TABLE stu333_1 AS SELECT * FROM stu333;

--echo #mysql_dblink_read-06-7-1	update 本地表 set ...=(select远端表) where ...
UPDATE stu333_1 SET id=(SELECT max(id)+1 FROM stu150@my_link1),name=(SELECT ''''||name||'''' FROM stu233@my_link2 WHERE id=1005)
WHERE id=1001;
SELECT * FROM stu333_1 order by 1,2,3,4,5,6,7;

UPDATE stu333_1 SET id=(SELECT (CASE max(id)+1 WHEN 1003 THEN 1009 ELSE 1010 END) FROM stu150@my_link1 WHERE id BETWEEN 1002 AND 1003 GROUP BY c_id HAVING c_id>101)
WHERE id=1002;
SELECT * FROM stu333_1 order by 1,2,3,4,5,6,7;

UPDATE stu333_1 SET name=(SELECT * FROM (WITH a AS (SELECT DISTINCT n.id,m.name FROM stu233@my_link2 m JOIN class333 n ON n.id=m.c_id),
	b AS (SELECT t.name FROM (SELECT n.id,m.name FROM stu333 m,class150@my_link1 n) t)
	SELECT DISTINCT b.name FROM a,b WHERE trim(a.name)=trim(b.name) ORDER BY 1) LIMIT 1)
WHERE id=1004;
SELECT * FROM stu333_1 order by 1,2,3,4,5,6,7;

UPDATE stu333_1 SET id=(SELECT min(id) FROM (SELECT c_id FROM stu150@my_link1 WHERE id>1004 GROUP BY c_id HAVING c_id>101 UNION SELECT c_id FROM stu333 WHERE id<1003 GROUP BY c_id HAVING c_id=101 ORDER BY c_id) a 
	RIGHT JOIN (SELECT DISTINCT id,name,location FROM class233@my_link2) b ON a.c_id=b.id)
WHERE id=1004;
SELECT * FROM stu333_1 order by 1,2,3,4,5,6,7;

UPDATE stu333_1 SET id=(SELECT c_id FROM (SELECT DISTINCT id,name,birth,c_id FROM stu150@my_link1) s, class333 c WHERE c.id=s.c_id AND s.id<1008 MINUS
	SELECT c_id FROM (SELECT DISTINCT id,name,birth,c_id FROM stu150@my_link1) s, class233@my_link2 c WHERE c.id=s.c_id AND s.id<1005)
WHERE id=1005;
SELECT * FROM stu333_1 order by 1,2,3,4,5,6,7;

--echo #mysql_dblink_read-06-7-2	update 本地表 set ... where (select远端表)

UPDATE class333_1 SET name='user' 
WHERE id=(SELECT (CASE max(id)+1 WHEN 1003 THEN 100 ELSE 101 END) FROM stu150@my_link1 WHERE id BETWEEN 1002 AND 1003 GROUP BY c_id HAVING c_id>101);
SELECT * FROM class333_1 order by 1,2,3,4;

UPDATE class333_1 SET name='qazxsw' 
WHERE (id,name)=(SELECT t-902,'user' FROM (SELECT max(id)+1 t FROM stu233@my_link2 GROUP BY c_id ORDER BY c_id) LIMIT 1);
SELECT * FROM class333_1 order by 1,2,3,4;

UPDATE class333_1 SET location='lalala' 
WHERE name<>(SELECT * FROM (WITH a AS (SELECT DISTINCT n.id,m.name FROM stu233@my_link2 m JOIN class233@my_link2 n ON n.id=m.c_id),
	b AS (SELECT t.name FROM (SELECT n.id,m.name FROM stu333 m,class150@my_link1 n) t)
	SELECT DISTINCT b.name FROM a,b WHERE trim(a.name)=trim(b.name) order by 1) LIMIT 1);
SELECT * FROM class333_1 order by 1,2,3,4;

UPDATE class333_1 SET location='binjiang' 
WHERE id<=(SELECT min(id) FROM (SELECT c_id FROM stu150@my_link1 WHERE id>1004 GROUP BY c_id HAVING c_id>101 UNION SELECT c_id FROM stu233@my_link2 WHERE id<1003 GROUP BY c_id HAVING c_id=101 ORDER BY c_id) a 
	RIGHT JOIN (SELECT DISTINCT id,name,location FROM class333) b ON a.c_id=b.id);
SELECT * FROM class333_1 order by 1,2,3,4;

UPDATE class333_1 SET location='xixi' 
WHERE id<=(SELECT c_id FROM (SELECT DISTINCT id,name,birth,c_id FROM stu150@my_link1) s, class333 c WHERE c.id=s.c_id AND s.id<1008 MINUS
	SELECT c_id FROM (SELECT DISTINCT id,name,birth,c_id FROM stu233@my_link2) s, class333 c WHERE c.id=s.c_id AND s.id<1005);
SELECT * FROM class333_1 order by 1,2,3,4;


