#owner: dachuan.sdc
#owner group: sql2
#description: dblink:ob-omysql连接oracle，select远端表
#tags: dml
#author:wb-sl672505

connection default;
--error 0,4112
purge recyclebin;

--echo #新建本地用户
connect(sys_ora,$OBMYSQL_MS0,root,,test,$OBMYSQL_PORT);
connection sys_ora;
--error 0,1396
drop user lcq1 ;
create user 'lcq1' identified by 'lcq';
GRANT all privileges ON *.* TO 'lcq1'@'%' WITH GRANT OPTION;

--error 0,1396
drop user lcq2 ;
create user 'lcq2' identified by 'lcq';
GRANT all privileges ON *.* TO 'lcq2'@'%' WITH GRANT OPTION;

--error 0,1396
drop user lcq3 ;
create user 'lcq3' identified by 'lcq';
GRANT all privileges ON *.* TO 'lcq3'@'%' WITH GRANT OPTION;

connect (conn_lcq_1,$OBMYSQL_MS0,lcq1,lcq,test,$OBMYSQL_PORT);
connect (conn_lcq_2,$OBMYSQL_MS0,lcq2,lcq,test,$OBMYSQL_PORT);
connect (conn_lcq_3,$OBMYSQL_MS0,lcq3,lcq,test,$OBMYSQL_PORT);

--echo #新建远端dblink租户、用户
let $char_charset = 'UTF8';

--source mysql_test/test_suite/dblink_ob_ob_mysql_sqlqa/include/create_tenant_by_charset.inc
--source mysql_test/test_suite/dblink_ob_ob_mysql_sqlqa/include/conn_tenant.inc
disconnect conn_charset_test_user;

connect(sys_ora1,$OBMYSQL_MS0,root@tenant_charset_test,,test,$OBMYSQL_PORT);
connection sys_ora1;

--error 0,1396
drop user lcq1 ;
create user 'lcq1' identified by 'lcq';
GRANT all privileges ON *.* TO 'lcq1'@'%' WITH GRANT OPTION;

--error 0,1396
drop user lcq2 ;
create user 'lcq2' identified by 'lcq';
GRANT all privileges ON *.* TO 'lcq2'@'%' WITH GRANT OPTION;

--error 0,1396
drop user lcq3 ;
create user 'lcq3' identified by 'lcq';
GRANT all privileges ON *.* TO 'lcq3'@'%' WITH GRANT OPTION;

connect (conn_lcq_11,$OBMYSQL_MS0,lcq1@tenant_charset_test,lcq,test,$OBMYSQL_PORT);
connect (conn_lcq_21,$OBMYSQL_MS0,lcq2@tenant_charset_test,lcq,test,$OBMYSQL_PORT);

connection conn_lcq_11;
--source mysql_test/test_suite/dblink_ob_ob_mysql_sqlqa/include/ob_mysql_prepare_tableall.inc

connection conn_lcq_21;
--source mysql_test/test_suite/dblink_ob_ob_mysql_sqlqa/include/ob_mysql_prepare_tableall.inc

connection conn_lcq_3;
--source mysql_test/test_suite/dblink_ob_ob_mysql_sqlqa/include/ob_mysql_prepare_tableall.inc

connection conn_lcq_3;
set autocommit = on;
###本地新建dblink
--disable_query_log
--error 0, 2024
drop database link if exists my_link1;
eval create database link if not exists my_link1 connect to lcq1@tenant_charset_test database test identified by 'lcq' host '$OBMYSQL_MS0:$OBMYSQL_PORT';

--error 0, 2024
drop database link if exists my_link2;
eval create database link if not exists my_link2 connect to lcq2@tenant_charset_test database test identified by 'lcq' host '$OBMYSQL_MS0:$OBMYSQL_PORT';

--enable_query_log
set autocommit = on;
set ob_query_timeout=99900000000;
set ob_trx_timeout = 1000000000;  
SET NAMES UTF8;

	
--echo #dblink语法验证,OB暂不支持,mysql_dblink_read-09-02,mysql_dblink_read-09-04
--error 1064
create public database link my_link4 using 'dbl';
--error 1064
create public database link linkname connect to yyl_dblink identified by '123' using 'dbl';

--disable_result_log
--error 0,1146
select owner,db_link ,username from all_db_links;
--error 0,1146
select owner,db_link,USERNAME from dba_db_links;
--error 0,1146
select owner,object_name from dba_objects where object_type='DATABASE LINK';
--error 0,1146
select * from global_name;
--error 1064
select * from user_sys_privs t
　　where t.privilege like upper('%link%');
--error 1064
grant CREATE PUBLIC DATABASE LINK,DROP PUBLIC DATABASE LINK to yyl_dblink;
--enable_result_log

--echo #dblink  JOIN,mysql_dblink_read-09-07
select * from outer_join_B b left join outer_join_C c on b.varchar_2=c.varchar_2 WHERE c.varchar_1 like 'A%';
--error 1054
select * from outer_join_A a,outer_join_C c left join outer_join_B b on a.varchar_1=b.varchar_1 where a.varchar_2=c.varchar_2;

select * from outer_join_A@my_link1 a,outer_join_B@my_link1 b,outer_join_C@my_link1 c 
where a.varchar_1=b.varchar_1 and a.varchar_1=c.varchar_1 and b.varchar_1=c.varchar_1 order by 1;
select * from outer_join_B@my_link1 b left join outer_join_C@my_link1 c on b.varchar_2=c.varchar_2 WHERE c.varchar_1 like 'A%' order by 1;
--error 1054
select * from outer_join_A@my_link1 a, outer_join_C@my_link1 c left join outer_join_B@my_link1 b on a.varchar_1=b.varchar_1 where a.varchar_2=c.varchar_2 order by 1;

select * from outer_join_A@my_link2 a,outer_join_B@my_link2 b,outer_join_C@my_link2 c where a.varchar_1=b.varchar_1 and a.varchar_1=c.varchar_1 and b.varchar_1=c.varchar_1 order by 1;
select * from outer_join_B@my_link2 b left join outer_join_C@my_link1 c on b.varchar_2=c.varchar_2 WHERE c.varchar_1 like 'A%' order by 1;
--error 1054
select * from outer_join_A@my_link1 a, outer_join_C@my_link2 c left join outer_join_B@my_link2 b on a.varchar_1=b.varchar_1 where a.varchar_2=c.varchar_2 order by 1;

--echo #清理环境
--source mysql_test/test_suite/dblink_ob_ob_mysql_sqlqa/include/drop_tenant.inc
--error 0,4112
purge recyclebin;
sleep 5;