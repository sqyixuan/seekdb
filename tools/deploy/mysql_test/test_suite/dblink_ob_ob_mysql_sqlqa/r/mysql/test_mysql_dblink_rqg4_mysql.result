select   col_varchar_10_key,date_format(col_datetime,'%y-%m-%d %h:%i:%s'),ntile(1) over (partition by col_int_key order by pk,col_tinyint_key,col_int_key,col_smallint,col_smallint_key,col_integer,col_int,col_integer_key,col_mediumint_key,col_tinyint,col_varchar_10_key,col_varchar_10 desc range between current row and unbounded following) as wf1,ntile(1) over (partition by date_format(col_timestamp,'%y-%m-%d %h:%i:%s'),col_int_key order by pk,col_tinyint_key,col_int_key,col_smallint,col_smallint_key,col_integer,col_int,col_integer_key,col_mediumint_key,col_tinyint,col_varchar_10_key,col_varchar_10 desc ) as wf2,ntile(1) over (partition by col_tinyint, pk, col_varchar_10_key order by pk,col_tinyint_key,col_int_key,col_smallint,col_smallint_key,col_integer,col_int,col_integer_key,col_mediumint_key,col_tinyint,col_varchar_10_key,col_varchar_10 asc range between current row and unbounded following) as wf3,ntile(1) over (partition by col_integer_key, pk, col_varchar_10_key order by pk,col_tinyint_key,col_int_key,col_smallint,col_smallint_key,col_integer,col_int,col_integer_key,col_mediumint_key,col_tinyint,col_varchar_10_key,col_varchar_10 desc range unbounded preceding) as wf4 from table30_key_pk_parts_2_bigint@my_link1 where (regexp_like(col_varchar_10_key, '^[a-za-z]') or col_mediumint = -9999999999999999999999999999999999999999) and col_varchar_10 like ' %a b%';
#清理环境
purge recyclebin;
