DROP TABLE IF EXISTS testbak;
CREATE TABLE testbak AS WITH 
tmp1 AS (SELECT * FROM tmp_hash@my_link1 m left JOIN tmp_hash n ON n.a=m.a),
tmp2 AS (SELECT * FROM (SELECT * FROM temp_fee@my_link1 m,temp_qwe@my_link1 n) t)
SELECT * FROM tmp1,tmp2;
ERROR 42S21: Duplicate column name 'a'
CREATE TABLE testbak AS WITH 
tmp1 AS (SELECT m.a ma,n.b nb FROM tmp_hash@my_link1 m JOIN tmp_hash n ON n.b=m.b),
tmp2 AS (SELECT * FROM (SELECT m.MONTH_ID mm,n.PROV_ID nn FROM temp_fee@my_link1 m,temp_qwe@my_link1 n) t)
SELECT ma,nb,mm,nn FROM tmp1,tmp2;
select * from testbak;
