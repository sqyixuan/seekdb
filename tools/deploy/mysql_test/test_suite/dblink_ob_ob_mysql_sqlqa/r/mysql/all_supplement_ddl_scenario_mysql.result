36	7	1	169	1	NULL	NULL	NULL
DROP TABLE IF EXISTS bmsql_oorder;
create table bmsql_oorder as select * from bmsql_oorder@my_link1;
drop table bmsql_oorder@my_link1;
ERROR HY000: DDL operations are not allowed on a remote database
drop PROCEDURE if exists p_execute_ddl;
CREATE PROCEDURE p_execute_ddl(IN p_ddl VARCHAR(1000))
BEGIN
SET @stmt = p_ddl;
PREPARE stmt FROM @stmt;
EXECUTE stmt;
DEALLOCATE PREPARE stmt;
END //
select * from bmsql_oorder;
o_w_id	o_d_id	o_id	o_c_id	o_carrier_id	o_ol_cnt	o_all_local	o_entry_d
36	7	1	169	1	NULL	NULL	NULL
call p_execute_ddl('drop table bmsql_oorder');
call p_execute_ddl('SELECT * FROM bmsql_oorder@my_link1');
o_w_id	o_d_id	o_id	o_c_id	o_carrier_id	o_ol_cnt	o_all_local	o_entry_d
36	7	1	169	1	NULL	NULL	NULL
