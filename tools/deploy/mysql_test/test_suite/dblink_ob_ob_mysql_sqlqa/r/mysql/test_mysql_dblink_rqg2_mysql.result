select  ntile(1) over (partition by col_varchar_10,date_format(col_date,'%y-%m-%d %h:%i:%s'),date_format(col_timestamp,'%y-%m-%d %h:%i:%s') order by pk,col_tinyint_key,col_int_key,col_smallint,col_smallint_key,col_integer,col_int,col_integer_key,col_mediumint_key,col_tinyint,col_varchar_10_key,col_varchar_10 desc ) as wf1,ntile(1) over (partition by col_int,col_int_key,col_int_key order by pk,col_tinyint_key,col_int_key,col_smallint,col_smallint_key,col_integer,col_int,col_integer_key,col_mediumint_key,col_tinyint,col_varchar_10_key,col_varchar_10 desc range current row) as wf2 from table10_key_pk_parts_2_bigint@my_link2 where (col_smallint_key in (0.55555,0.000) and col_varchar_10 not like '%b%') or col_integer_key = '' order by 1,2 asc;
select /*+ no_expand */ a.col_smallint_key,a.col_varchar_10_key,date_format(a.col_datetime,'%y-%m-%d %h:%i:%s') from table10_hash_pk_parts_4_bigint@my_link1 a inner join ((select /*+ no_use_nl_materialization(table10_hash_pk_parts_4_bigint@my_link1) */ * from table1@my_link1 b)) b on a.col_date = b.col_date where a.col_date = b.col_date order by 1 desc;
select /*+ ordered pq_distribute(table10_key_pk_parts_2_bigint@my_link2 partition, none) use_hash (table1_hash_pk_parts_4@my_link2)*/  binary a.col_smallint from table1@my_link1 a right outer join table10_hash_pk_parts_4@my_link1 b on a.col_char_30 = b.col_char_30 where a.col_char_30 = b.col_char_30;
select /*+ disable_parallel_dml*/  a.col_varchar_10_key,b.col_varchar_10_key from table30_key_pk_parts_2_bigint@my_link1 a,table30_key_pk_parts_2_bigint@my_link1 b,table10_hash_pk_parts_4@my_link1 c where a.col_smallint_key = b.pk and b.col_tinyint_key = c.col_integer_key;
select /*+ ordered pq_distribute(table30_hash_pk_parts_4_bigint@my_link1 none, broadcast) use_hash (table1@my_link1)*/  b.col_varchar_10,b.col_varchar_10_key,date_format(b.col_timestamp,'%y-%m-%d %h:%i:%s') from table10_bigint@my_link2 a left outer join table10_hash_pk_parts_4_bigint@my_link1 b on a.col_datetime = b.col_datetime where a.col_datetime = b.col_datetime;
select   interval(date_format(col_date_key,'%y-%m-%d %h:%i:%s'), col_int_key, col_mediumint_key, col_varchar_10_key, date_format(col_date_key,'%y-%m-%d %h:%i:%s')) from table1_key_pk_parts_2_bigint@my_link2 where col_int >= 9999999999999999999999999999999999999999 or col_tinyint_key not like -9999999999999999999999999999999999999999;
select /*+ materialize*/ ntile(1) over (partition by substring(col_varchar_10, 3),ucase(col_varchar_10),length(date_format(col_timestamp_key,'%y-%m-%d %h:%i:%s')),unhex(col_varchar_10_key) order by pk,col_tinyint_key,col_int_key,col_smallint,col_smallint_key,col_integer,col_int,col_integer_key,col_mediumint_key,col_tinyint,col_varchar_10_key,col_varchar_10 asc rows current row) as wf1 from table1_hash_pk_parts_4@my_link2 where regexp_like(pk, '1000') or col_int = '' and (regexp_like(col_tinyint_key, '^[^0-9]+') and col_integer = 2);
select /*+ no_use_hash_aggregation */  col_smallint,col_varchar_10_key,ntile(1) over (partition by col_int_key,col_tinyint,col_int_key,col_int_key order by pk,col_tinyint_key,col_int_key,col_smallint,col_smallint_key,col_integer,col_int,col_integer_key,col_mediumint_key,col_tinyint,col_varchar_10_key,col_varchar_10 asc range between unbounded preceding and unbounded following) as wf1,ntile(1) over (partition by col_smallint_key order by pk,col_tinyint_key,col_int_key,col_smallint,col_smallint_key,col_integer,col_int,col_integer_key,col_mediumint_key,col_tinyint,col_varchar_10_key,col_varchar_10 desc range between current row and unbounded following) as wf2,ntile(1) over (partition by pk order by pk,col_tinyint_key,col_int_key,col_smallint,col_smallint_key,col_integer,col_int,col_integer_key,col_mediumint_key,col_tinyint,col_varchar_10_key,col_varchar_10 asc range current row) as wf3,ntile(1) over (partition by null order by pk,col_tinyint_key,col_int_key,col_smallint,col_smallint_key,col_integer,col_int,col_integer_key,col_mediumint_key,col_tinyint,col_varchar_10_key,col_varchar_10 asc rows current row) as wf4 from table1_hash_pk_parts_4_bigint@my_link2 where col_integer in ('1000','') or col_varchar_10 like '%' and col_mediumint_key = 3.2455 order by 1 asc,2 asc;
