#mysql_dblink_read-09-06	子查询测试，子查询补充测试，复杂查询2
#mysql_dblink_read-09-06	子查询测试，子查询补充测试，复杂查询改写3
WITH 
temp AS (
SELECT DISTINCT e.deptno,p.ename,c.dname,d.c6,d.cot,f.sal,q.mgr FROM test551@my_link1 e INNER JOIN test552@my_link1 p ON e.deptno = p.deptno 
INNER JOIN (SELECT e.dname,e.deptno,p.ename FROM t1_view e,t2_view p WHERE e.deptno = p.deptno AND p.sal BETWEEN 1000 AND 2000 
AND e.dname IN (SELECT dname FROM (SELECT dname,COUNT(job) FROM t5_view WHERE sal BETWEEN 1000 AND 2000 AND job IS NOT NULL GROUP BY dname HAVING COUNT(*) >= 8 ORDER BY 1,2)) ) c ON p.deptno = c.deptno 
INNER JOIN (SELECT e.c6,p.c1,COUNT(p.c8)cot FROM t3_view e RIGHT JOIN test553@my_link1 p ON e.c1 = p.c1 GROUP BY e.c6,p.c1  ORDER BY 1,2)d ON c.deptno = d.c1 
INNER JOIN (SELECT e.deptno,(p.sal+e.ssal)sal,p.job FROM t4_view e LEFT JOIN test555 p ON e.deptno = p.deptno WHERE p.deptno IS NOT NULL AND p.comm + p.sal > 0 )f ON d.c1 = f.deptno
INNER JOIN (SELECT e.deptno,e.ename,e.mgr FROM test555 e WHERE empno = (SELECT mgr FROM (SELECT mgr,COUNT(*) FROM test555 
WHERE ename IN (SELECT ename FROM test552@my_link1 WHERE sal BETWEEN 1500 AND 3000) GROUP BY mgr HAVING COUNT(*) <2  ORDER BY 1,2 )))q ON  f.deptno = q.deptno
WHERE p.sal < (SELECT DISTINCT sal FROM t6_view e,t1_view p WHERE e.deptno = p.deptno  AND dname NOT IN ('ReSeaRch','AccounTing') AND empno = (SELECT mgr FROM t6_view WHERE ename = 'WARD' AND sal > 1000))
AND f.sal > (SELECT SUM(p.sal + (SELECT sal FROM (SELECT SUM(e.sal)sal,p.dname FROM test555 e,test554 p WHERE e.deptno = p.deptno GROUP BY p.dname HAVING SUM(e.sal) > 5000))
+CASE (SELECT DISTINCT e.sal FROM t5_view e,test551@my_link1 p WHERE e.deptno = p.deptno AND p.dname = 'ReSeaRch' AND e.sal BETWEEN 1000 AND 2000) WHEN 1100 THEN 1100+200 ELSE 2000 END)/3.3 FROM test551 e,test552 p WHERE e.deptno = p.deptno
GROUP BY e.dname HAVING SUM(p.sal + (SELECT sal FROM (SELECT SUM(e.sal)sal,p.dname FROM test555 e,test554 p WHERE e.deptno = p.deptno GROUP BY p.dname HAVING SUM(e.sal) > 5000))
+CASE (SELECT DISTINCT e.sal FROM t5_view e,test551@my_link1 p WHERE e.deptno = p.deptno AND p.dname = 'ReSeaRch' AND e.sal BETWEEN 1000 AND 2000) WHEN 1100 THEN 1100+200 ELSE 2000 END) < 50000) 
AND EXISTS (SELECT e.dname,SUM(p.sal+c.sal) FROM test551@my_link1 e,test552@my_link1
p,test555 c WHERE e.deptno = p.deptno AND p.deptno = c.deptno GROUP BY e.dname HAVING SUM(p.sal+c.sal) > (SELECT SUM(ssal) FROM t4_view WHERE deptno <>1))
ORDER BY 1,2,3,4
),
test1 AS (
SELECT DISTINCT e.deptno,e.sal,p.c6,c.ssal,d.mgr,f.c7,q.ename FROM t2_view e,t3_view p,t4_view c,t6_view d,test556 f,t7_view q WHERE e.deptno = p.c1 AND p.c1 = c.deptno AND c.deptno = d.deptno AND d.deptno = f.c1 AND f.c1 = q.deptno
AND EXISTS (SELECT e.dname,SUM(p.sal+c.sal) FROM test551@my_link1 e,test552@my_link1
p,test555 c WHERE e.deptno = p.deptno AND p.deptno = c.deptno GROUP BY e.dname HAVING SUM(p.sal+c.sal) > (SELECT SUM(ssal) FROM t4_view WHERE deptno <>1))
AND  e.sal < (SELECT DISTINCT sal FROM t6_view e,t1_view p WHERE e.deptno = p.deptno  AND dname NOT IN ('ReSeaRch','AccounTing') AND empno = (SELECT mgr FROM t6_view WHERE ename = 'WARD' AND sal > 1000))
AND c.ssal < ALL(SELECT sal FROM temp ) AND p.c6 IN (SELECT DISTINCT c6 FROM temp) AND d.empno != (SELECT DISTINCT mgr FROM temp)  
AND NOT EXISTS (SELECT * FROM test551@my_link1 e,test552@my_link1 p,test553@my_link1 q WHERE e.deptno = p.deptno AND p.deptno = q.c1 AND p.sal < (SELECT sal FROM temp WHERE mgr = (SELECT MAX(p.empno) FROM test551@my_link1 e,test552@my_link1
p WHERE e.deptno = p.deptno AND e.dname 
NOT IN (SELECT DISTINCT dname FROM temp WHERE c6 = (SELECT c6 FROM t3_view WHERE c5 = 'r' AND c8 = 'd')
AND sal = ALL(SELECT AVG(sal) FROM temp GROUP BY ename))))
AND p.ename NOT IN (SELECT ename FROM temp WHERE c6 = (SELECT c6 FROM t3_view WHERE c5 = 'r' AND c8 = 'd')) AND sal > 4000 AND comm IS NOT NULL) 
AND f.c7 > ALL(SELECT cot FROM temp) AND e.sal >ALL(SELECT * FROM (SELECT sal FROM test551@my_link1 e,test555 p WHERE e.deptno = p.deptno ORDER BY 1) LIMIT 2 ) ORDER BY 1,2,3,4
)
SELECT e.ename,COUNT(*) FROM test1 e INNER JOIN temp p ON e.deptno = p.deptno GROUP BY e.ename ORDER BY 1,2;
ERROR 21000: Subquery returns more than 1 row
#清理环境
purge recyclebin;
