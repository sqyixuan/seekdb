#mysql_dblink_read-09-06	子查询测试，子查询补充测试，嵌套其他dblink再次查询
SELECT a.deptno,a.ename,a.sam,b.cnt FROM 
(
SELECT e.deptno,e.ename,p.sam FROM (SELECT e.deptno,p.ename,p.job,p.loc FROM test551@my_link1 e,t1_view p WHERE e.deptno = p.deptno AND p.ename IS NOT NULL 
AND p.loc = SOME (SELECT loc FROM (SELECT p.loc,SUM(e.sal) FROM t7_view e,test554@my_link2 p WHERE e.deptno = p.deptno AND e.sal > 1500 GROUP BY p.loc HAVING SUM(e.sal) > 2000)))e 
LEFT JOIN (SELECT e.deptno,SUM(e.sal+p.comm)sam FROM test552@my_link1 e,t2_view p WHERE e.deptno = p.deptno AND e.comm+p.comm > 0
AND p.sal + e.sal > ALL( SELECT e.sal+e.comm FROM test552@my_link2 e,test551 p WHERE e.deptno = p.deptno AND p.loc IN ('DallAs','ChiCaGo') AND e.sal+e.comm IS NOT NULL) GROUP BY e.deptno)p ON e.deptno = p.deptno 
ORDER BY 1
)a,
(
SELECT p.deptno,COUNT(*)cnt FROM test551@my_link1 e,test552@my_link2 p,test553@my_link2 c,test554@my_link1 d,test555@my_link1 q,test556@my_link1 y WHERE e.deptno = p.deptno  
GROUP BY p.deptno HAVING COUNT(*) > 10 ORDER BY 1,2)b
WHERE a.deptno = b.deptno ORDER BY 1;
