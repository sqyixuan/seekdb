#mysql_dblink_read-09-06	子查询测试，子查询补充测试1
#mysql_dblink_read-09-06	子查询测试，子查询补充测试，复杂查询1
#mysql_dblink_read-09-06	子查询测试，子查询补充测试，复杂查询1改写
SELECT a.deptno,a.ename,a.sam,b.cnt FROM 
(
SELECT e.deptno,e.ename,p.sam,c.c7,d.dname,q.cot FROM (SELECT e.deptno,p.ename,p.job,p.loc FROM test551@my_link1 e,t1_view p WHERE e.deptno = p.deptno AND p.ename IS NOT NULL 
AND p.loc = SOME (SELECT loc FROM (SELECT p.loc,SUM(e.sal) FROM t7_view e,test554@my_link1 p WHERE e.deptno = p.deptno AND e.sal > 1500 GROUP BY p.loc HAVING SUM(e.sal) > 2000)))e 
LEFT JOIN (SELECT e.deptno,SUM(e.sal+p.comm)sam FROM test552@my_link1 e,t2_view p WHERE e.deptno = p.deptno AND e.comm+p.comm > 0
AND p.sal + e.sal > ALL( SELECT e.sal+e.comm FROM test552@my_link1 e,test551@my_link1 p WHERE e.deptno = p.deptno AND p.loc IN ('DallAs','ChiCaGo') AND e.sal+e.comm IS NOT NULL) GROUP BY e.deptno)p ON e.deptno = p.deptno 
INNER JOIN (SELECT e.c1,e.c7,p.c6 FROM test553@my_link1 e,t3_view p WHERE e.c1 = p.c1 AND e.c5 IS NOT NULL AND (p.c6 LIKE '%f%' OR e.c6 LIKE '%k%') AND e.c8 IS NOT NULL AND p.c6 = ANY (SELECT c6 FROM t5_view WHERE job = 'MANAGER'))c ON p.deptno = c.c1 RIGHT JOIN 
(SELECT e.deptno,e.dname,p.ssal FROM test554@my_link1 e,t4_view p WHERE e.deptno = p.deptno AND p.ssal > ANY(SELECT ssal FROM (SELECT e.loc,SUM(p.sal)ssal FROM test551@my_link1 e,test552@my_link1 p WHERE e.deptno = p.deptno GROUP BY e.loc)) )d ON c.c1 = d.deptno INNER JOIN
(SELECT  e.deptno,COUNT(ename)cot FROM test555@my_link1 e,t5_view p WHERE e.deptno = p.deptno AND e.comm IS NOT NULL AND p.c6 = ANY(SELECT p.c8 FROM test553@my_link1 e,test556@my_link1 p WHERE e.c1 = p.c1 AND e.c7 = 0 AND p.c8 IS NOT NULL ) 
AND p.job = SOME(SELECT DISTINCT e.job FROM t1_view e,t6_view p WHERE e.deptno = p.deptno AND p.sal BETWEEN 2000 AND 5000 AND e.job IS NOT NULL) GROUP BY e.deptno HAVING COUNT(*) >= 20)q ON d.deptno = q.deptno 
WHERE e.job = SOME(SELECT job FROM (SELECT p.job,COUNT(e.deptno) FROM test551@my_link1 e,test552@my_link1 p WHERE e.deptno = p.deptno AND p.job != 'SALESMAN' GROUP BY p.job HAVING COUNT(e.deptno) >= 3)) AND p.sam-d.ssal > (SELECT SUM(ssal) FROM t4_view)ORDER BY 1,2,3,4
)a,
(
SELECT p.deptno,COUNT(*)cnt FROM test551@my_link1 e,test552@my_link1 p,test553@my_link1 c,test554@my_link1 d,test555@my_link1 q,test556@my_link1 y WHERE e.deptno = p.deptno AND p.deptno = c.c1 AND c.c1 = d.deptno AND d.deptno = q.deptno AND q.deptno = y.c1 
AND e.loc = ANY (SELECT DISTINCT e.loc FROM t1_view e,t4_view p WHERE e.deptno = p.deptno AND e.ename IS NOT NULL AND p.ssal > 9000) 
AND (p.sal+q.sal+p.comm+q.comm > ALL(SELECT cot FROM (SELECT COUNT(*)/2 AS cot,e.deptno FROM t2_view e,t6_view p,t7_view c,t1_view d WHERE e.deptno = p.deptno AND p.deptno = c.deptno AND c.deptno = d.deptno GROUP BY e.deptno HAVING SUM(e.sal) > 10000) )
OR EXISTS (SELECT * FROM t1_view e,t2_view p,t3_view c,t4_view f WHERE e.deptno = p.deptno AND p.deptno = c.c1 AND c.c1 = f.deptno AND f.ssal 
> ALL (SELECT sal FROM (SELECT SUM(e.sal+p.sal-f.sal)/100 AS sal,e.job FROM t5_view e,t6_view p,t7_view f WHERE e.deptno = p.deptno AND p.deptno = f.deptno GROUP BY e.job HAVING SUM(e.sal+p.sal-f.sal)/100 > 10000))))
AND y.c6 = ALL(SELECT DISTINCT c6 FROM t3_view WHERE c7 = 2)  GROUP BY p.deptno HAVING COUNT(*) > 10 ORDER BY 1,2
)b
WHERE a.deptno = b.deptno ORDER BY 1,2,3,4;
