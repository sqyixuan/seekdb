#mysql_dblink_read-07-1	表：创建本地表——create table ... as 
DROP TABLE IF EXISTS test1111;
CREATE TABLE test1111 AS SELECT id||name basic,birth, round(LN(weight),5) other FROM stu150@my_link1 WHERE id <=1002+p_id AND round(id/33,5)<1000;
SELECT * FROM test1111 order by 1,2,3;
basic	birth	other
1	1992-09-25	4.05178
1	1993-09-25	4.21213
1	1994-09-25	4.35028
1	1995-09-25	4.47164
1	1996-09-25	3.62434
1	1997-09-25	4.57985
DROP TABLE IF EXISTS test1111;
CREATE TABLE test1111 AS SELECT max(id) a FROM stu233@my_link2 GROUP BY c_id HAVING c_id>102 ORDER BY a;
SELECT * FROM test1111 order by 1;
a
1007
WITH 
T1 AS (SELECT id||name basic,birth, round(LN(weight),5) other FROM stu150@my_link1 WHERE id <=1002+p_id AND round(id/33,5)<1000),
T2 AS (SELECT max(id) a FROM stu233@my_link2 GROUP BY c_id HAVING c_id>102 ORDER BY a)
SELECT * FROM T1,T2;
basic	birth	other	a
1	1992-09-25	4.05178	1007
1	1993-09-25	4.21213	1007
1	1994-09-25	4.35028	1007
1	1995-09-25	4.47164	1007
1	1996-09-25	3.62434	1007
1	1997-09-25	4.57985	1007
