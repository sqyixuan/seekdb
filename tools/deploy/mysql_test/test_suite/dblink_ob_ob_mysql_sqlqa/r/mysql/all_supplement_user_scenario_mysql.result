#用户场景7 
SELECT name from class150@my_link1
WHERE create_time between DATE_SUB(CURRENT_DATE(), INTERVAL 1 DAY) and CURRENT_DATE()
AND
(name not like 'bosscron%'
AND name not like 'root%'
AND name not like 'vsearch%'
AND name != 'NEWRPT'
AND name != 'HWWH_WANGHM'
AND name != 'PRO_MUSER'
AND name != 'TRANSDATA'
AND name != 'MONITOR_YY'
AND name NOT LIKE 'I3%'
and upper(location) not like '%ALTER%MOVE%'
and upper(location) not like '%ALTER%REBUILD%'
and upper(location) not like '%ALTER%SPLIT%'
and upper(location) not like '%ALTER%DROP%'
AND create_time not like 'oracle@%'
and location not like '%(TNS V1-V3)%'
AND location not like '%Precise%')
AND location not like 'SYS_IOT_%'
GROUP BY name;
name
