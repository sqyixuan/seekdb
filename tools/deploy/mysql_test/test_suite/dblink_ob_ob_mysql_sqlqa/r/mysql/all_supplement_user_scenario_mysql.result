#用户场景11
SELECT  /*+leading(p) */ 
CAST(sr.id AS char), 
p.id, 
(SELECT name FROM stu333 WHERE name=p.name), 
s.name, 
s.id, 
(SELECT name FROM stu333 p WHERE p.c_id=s.id), 
(SELECT name FROM stu333 p WHERE p.p_id=sr.p_id), 
(SELECT l.alias FROM stu333 l WHERE l.alias = sr.alias), 
(SELECT ar.name FROM class150@my_link1 ar WHERE ar.id=sr.c_id AND ar.name=s.name) actionname, 
FLOOR(sr.p_id/100), 
sr.alias, 
(SELECT d.name FROM stu150@my_link1 d WHERE d.id=sr.id), 
sr.birth, 
sr.weight, 
sr.c_id, 
p.location, 
(SELECT c_id FROM stu333 WHERE name=p.name), 
(SELECT y.name FROM class333 y, class150@my_link1 x WHERE y.name=x.name AND y.id=sr.c_id AND y.id=102), 
(SELECT y.name FROM stu333 y, stu150@my_link1 x, class150@my_link1 pc WHERE y.name=x.name AND y.c_id=pc.id AND y.alias=sr.alias AND x.id = 1002 )
FROM class150@my_link1 p, stu150@my_link1 sr, class333 s
WHERE sr.c_id=s.id
AND p.id LIKE '2%'
AND sr.p_id LIKE '3%' 
AND CAST(sr.id AS char) LIKE '4%' 
AND p.name IN ('yinyue','dianzi')
AND p.id=sr.c_id
AND p.id>101
AND sr.alias IN ('zs','ls','ww','wl')
AND p.id BETWEEN 100 AND 106
AND sr.id > 1000 
AND s.id > 100 
AND p.id != 109;
CAST(sr.id AS char)	id	(SELECT name FROM stu333 WHERE name=p.name)	name	id	(SELECT name FROM stu333 p WHERE p.c_id=s.id)	(SELECT name FROM stu333 p WHERE p.p_id=sr.p_id)	(SELECT l.alias FROM stu333 l WHERE l.alias = sr.alias)	actionname	FLOOR(sr.p_id/100)	alias	(SELECT d.name FROM stu150@my_link1 d WHERE d.id=sr.id)	birth	weight	c_id	location	(SELECT c_id FROM stu333 WHERE name=p.name)	(SELECT y.name FROM class333 y, class150@my_link1 x WHERE y.name=x.name AND y.id=sr.c_id AND y.id=102)	(SELECT y.name FROM stu333 y, stu150@my_link1 x, class150@my_link1 pc WHERE y.name=x.name AND y.c_id=pc.id AND y.alias=sr.alias AND x.id = 1002 )
#用户场景12
SELECT A1.ID, A1.NAME, A1.location, A1.create_time, A1.id
FROM class150@my_link1 A1
WHERE A1.id=101 AND A1.name='yinyue' 
AND (IFNULL(A1.create_time,CURRENT_DATE()+1)>DATE_SUB(CURRENT_DATE(), INTERVAL 1 DAY)
AND IFNULL(A1.create_time,CURRENT_DATE()+1)<CURRENT_DATE() 
OR A1.create_time>CURRENT_DATE()-INTERVAL 100000/3 DAY)
AND A1.location<>'stcmNml'
AND A1.id<>1;
