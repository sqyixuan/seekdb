#用户场景1
SELECT
NVL(SUM(C1),C1) FROM
(SELECT id AS C1,
CASE WHEN (name)='yinyue'
THEN (name)
ELSE (name)
END AS C2
FROM class150@my_link1) SAMPLESUB group by C1,C2;
NVL(SUM(C1),C1)
101
102
103
104
106
