DROP TRIGGER if exists test_trig;//
Warnings:
Note	1360	Trigger does not exist
CREATE TRIGGER test_trig
BEFORE INSERT ON stu3_1
FOR EACH ROW
BEGIN
IF 1>0 THEN
INSERT INTO class3_1(id, name, location) VALUES((SELECT MAX(id)+1 FROM class233@my_link2), 'shuxue', 'yuhang');
INSERT INTO class3_1(name) VALUES((SELECT name FROM syn_class1 WHERE id=102));
END IF;
END //
