#mysql_dblink_read-08-03	函数
#mysql_dblink_read-08-03-1、mysql_dblink_read-08-03-2	条件、循环语句（if、while），不带参数的函数
DROP TABLE if exists class3_1;
CREATE TABLE class3_1 AS SELECT * FROM class333 where 1=0;
DROP FUNCTION IF EXISTS p1;//
CREATE FUNCTION p1()
RETURNS INT
DETERMINISTIC
BEGIN
DECLARE done INT DEFAULT FALSE;
DECLARE id INT;
DECLARE name VARCHAR(255);
DECLARE ts TIMESTAMP;
DECLARE cur CURSOR FOR SELECT id,name,create_time FROM class150@my_link1;
DECLARE CONTINUE HANDLER FOR NOT FOUND SET done = TRUE;
OPEN cur;
read_loop: LOOP
FETCH cur INTO id, name, ts;
IF done THEN
LEAVE read_loop;
END IF;
IF id = 102 THEN
INSERT INTO class3_1 VALUES((SELECT max(id)+1 FROM class150@my_link1),'shuxue','yuhang',STR_TO_DATE('25-09-2002 12:01:33.3333','%d-%m-%Y %H:%i:%s.%f'));
INSERT INTO class3_1(name) VALUES((SELECT name FROM v_class2 WHERE id=102));
END IF;
END LOOP;
CLOSE cur;
RETURN 1;
END //
SELECT p1();
p1()
1
SELECT * FROM class3_1 order by 1,2,3,4;
id	name	location	create_time
delete from class3_1;
DROP FUNCTION IF EXISTS p1;//
CREATE FUNCTION p1()
RETURNS INT
DETERMINISTIC
BEGIN
DECLARE done INT DEFAULT FALSE;
DECLARE id INT;
DECLARE name VARCHAR(255);
DECLARE ts TIMESTAMP;
DECLARE cur CURSOR FOR SELECT id,name,create_time FROM v_class1;
DECLARE CONTINUE HANDLER FOR NOT FOUND SET done = TRUE;
OPEN cur;
read_loop: LOOP
FETCH cur INTO id, name, ts;
IF done THEN
LEAVE read_loop;
END IF;
IF id = 102 THEN
INSERT INTO class3_1 VALUES((SELECT max(id)+1 FROM v_class1),'shuxue','yuhang',STR_TO_DATE('25-09-2002 12:01:33.3333','%d-%m-%Y %H:%i:%s.%f'));
INSERT INTO class3_1(name) VALUES((SELECT name FROM v_class2 WHERE id=102));
END IF;
END LOOP;
CLOSE cur;
RETURN 1;
END //
SELECT p1();
p1()
