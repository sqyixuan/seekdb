SELECT * FROM class3_1 order by 1,2,3,4;
id	name	location	create_time
delete from class3_1;
DROP FUNCTION IF EXISTS my_func;//
CREATE FUNCTION my_func(in1 INT) RETURNS INT
BEGIN
DECLARE cnt INT DEFAULT 0;
DECLARE id INT;
DECLARE name VARCHAR(50);
DECLARE ts TIMESTAMP;
DECLARE cur CURSOR FOR SELECT id, name, create_time FROM class150;
DECLARE CONTINUE HANDLER FOR NOT FOUND SET cnt = -1;
OPEN cur;
read_loop: LOOP
FETCH cur INTO id, name, ts;
IF cnt = -1 THEN
LEAVE read_loop;
END IF;
IF id = in1 THEN
UPDATE class150 SET name = CONCAT(name, '_new') WHERE id = id;
INSERT INTO class150(id, name, create_time) VALUES(id+1, CONCAT(name, '_new'), NOW());
END IF;
END LOOP;
CLOSE cur;
RETURN cnt;
END //
SELECT my_func(10);
my_func(10)
-1
SELECT * FROM class3_1 order by 1,2,3,4;
id	name	location	create_time
delete from class3_1;
#mysql_dblink_read-08-04	触发器
