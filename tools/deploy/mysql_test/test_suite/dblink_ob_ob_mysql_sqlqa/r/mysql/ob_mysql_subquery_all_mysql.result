#mysql_dblink_read-09-06	子查询测试，子查询补充测试3
select
groupstuff.*,
test181.categoryid,
test182.courseid
from test182
join test181 on test182.courseid=test181.courseid
join
(
select
test185.userid,
parentid,
parentgroup,
childid,
groupname,
grouptypeid
from test185
join
(
select test184.id as parentid,
test184.name as parentgroup,
test184.id as childid,
test184.name as groupname,
test184.grouptypeid
from test184
) gin on test185.groupid=gin.childid
) groupstuff on test182.userid = groupstuff.userid ORDER BY 1;
userid	parentid	parentgroup	childid	groupname	grouptypeid	categoryid	courseid
