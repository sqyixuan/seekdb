5141	12	group2	12	group2	5	2	53
5141	12	group2	12	group2	5	5	12
5141	12	group2	12	group2	5	1	86
5141	12	group2	12	group2	5	1	87
5141	12	group2	12	group2	5	2	88
5141	12	group2	12	group2	5	2	89
