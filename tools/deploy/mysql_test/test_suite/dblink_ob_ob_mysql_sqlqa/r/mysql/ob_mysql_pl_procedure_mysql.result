SET NAMES UTF8;
CREATE OR REPLACE VIEW v_class1 AS SELECT * FROM class150@my_link1;
CREATE OR REPLACE VIEW v_stu1 AS SELECT * FROM stu150@my_link1;
CREATE OR REPLACE VIEW v_class2 AS SELECT * FROM class233@my_link2;
CREATE OR REPLACE VIEW v_stu2 AS SELECT * FROM stu233@my_link2;
CREATE OR REPLACE VIEW syn_class1  AS SELECT * FROM class150@my_link1;
CREATE OR REPLACE VIEW syn_stu1  AS SELECT * FROM stu150@my_link1;
CREATE OR REPLACE VIEW syn_class2  AS SELECT * FROM class233@my_link2;
CREATE OR REPLACE VIEW syn_stu2  AS SELECT * FROM stu233@my_link2;
#mysql_dblink_read-08-02	存储过程
#mysql_dblink_read-08-02-1、mysql_dblink_read-08-02-2	条件、循环语句（if、for），不带参数的存储过程
DROP TABLE if exists class3_1;
CREATE TABLE class3_1 AS SELECT * FROM class333 where 1=0;
DROP PROCEDURE IF EXISTS p1;//
CREATE PROCEDURE p1()
BEGIN
DECLARE done INT DEFAULT FALSE;
DECLARE id INT;
DECLARE name VARCHAR(255);
DECLARE ts TIMESTAMP;
DECLARE cur CURSOR FOR SELECT id,name,create_time FROM class150@my_link1 ORDER BY id;
DECLARE CONTINUE HANDLER FOR NOT FOUND SET done = TRUE;
OPEN cur;
read_loop: LOOP
FETCH cur INTO id, name, ts;
IF done THEN
LEAVE read_loop;
END IF;
IF id = 102 THEN
INSERT INTO class3_1 VALUES((SELECT max(id)+1 FROM class150@my_link1),'shuxue','yuhang',STR_TO_DATE('25-09-2002 12:01:33.3333','%d-%m-%Y %H:%i:%s.%f'));
INSERT INTO class3_1(name) VALUES((SELECT name FROM v_class2 WHERE id=102));
END IF;
END LOOP;
CLOSE cur;
END //
CALL p1();
SELECT * FROM class3_1 order by 1,2,3,4;
id	name	location	create_time
delete from class3_1;
DROP PROCEDURE IF EXISTS p1;//
CREATE PROCEDURE p1()
BEGIN
DECLARE done INT DEFAULT FALSE;
DECLARE id INT;
DECLARE name VARCHAR(255);
DECLARE ts TIMESTAMP;
DECLARE cur CURSOR FOR SELECT id,name,create_time FROM v_class1 ORDER BY id;
DECLARE CONTINUE HANDLER FOR NOT FOUND SET done = TRUE;
OPEN cur;
read_loop: LOOP
FETCH cur INTO id, name, ts;
IF done THEN
LEAVE read_loop;
END IF;
IF id = 102 THEN
INSERT INTO class3_1 VALUES((SELECT max(id)+1 FROM v_class1),'shuxue','yuhang',STR_TO_DATE('25-09-2002 12:01:33.3333','%d-%m-%Y %H:%i:%s.%f'));
INSERT INTO class3_1(name) VALUES((SELECT name FROM v_class2 WHERE id=102));
END IF;
END LOOP;
CLOSE cur;
END //
CALL p1();
SELECT * FROM class3_1 order by 1,2,3,4;
id	name	location	create_time
delete from class3_1;
#mysql_dblink_read-08-02-3	带in类型参数的存储过程
DELETE FROM class3_1 WHERE 1=1;
DROP PROCEDURE IF EXISTS p1;//
CREATE PROCEDURE p1(IN in1 INT)
BEGIN
DECLARE done INT DEFAULT FALSE;
DECLARE cid INT;
DECLARE str VARCHAR(500);
DECLARE cur CURSOR FOR SELECT id FROM v_class2 ORDER BY id;
DECLARE CONTINUE HANDLER FOR NOT FOUND SET done = TRUE;
OPEN cur;
read_loop: LOOP
FETCH cur INTO cid;
IF done THEN
LEAVE read_loop;
END IF;
IF cid = 102 THEN
SET str = CONCAT('INSERT INTO class3_1(id,name,location)
SELECT b.* FROM (
SELECT c_id FROM stu150@my_link1 WHERE id>1001 GROUP BY c_id 
) a
JOIN (
SELECT DISTINCT id,name,location FROM v_class2
) b ON a.c_id=b.id
INTERSECT
SELECT b.* FROM (
SELECT c_id FROM stu333 WHERE id>1001 GROUP BY c_id 
) a
RIGHT JOIN (
SELECT DISTINCT id,name,location FROM syn_class1
) b ON a.c_id=b.id');
SET @query = str;
PREPARE stmt FROM @query;
EXECUTE stmt;
DEALLOCATE PREPARE stmt;
END IF;
END LOOP;
CLOSE cur;
END //
CALL p1(101);
SELECT * FROM class3_1 order by 1,2,3,4;
id	name	location	create_time
101	yinyue	binjiang	NULL
102	dianzi	xixi	NULL
103	jisuanji	binjiang	NULL
#清理环境
purge recyclebin;
