#dblink语法验证,OB暂不支持,mysql_dblink_read-09-02,mysql_dblink_read-09-04
create public database link my_link4 using 'dbl';
ERROR 42000: You have an error in your SQL syntax; check the manual that corresponds to your OceanBase version for the right syntax to use near 'public database link my_link4 using 'dbl'' at line 1
create public database link linkname connect to yyl_dblink identified by '123' using 'dbl';
ERROR 42000: You have an error in your SQL syntax; check the manual that corresponds to your OceanBase version for the right syntax to use near 'public database link linkname connect to yyl_dblink identified by '123' using 'd' at line 1
select owner,db_link ,username from all_db_links;
select owner,db_link,USERNAME from dba_db_links;
select owner,object_name from dba_objects where object_type='DATABASE LINK';
select * from global_name;
select * from user_sys_privs t
　　where t.privilege like upper('%link%');
grant CREATE PUBLIC DATABASE LINK,DROP PUBLIC DATABASE LINK to yyl_dblink;
#dblink  JOIN,mysql_dblink_read-09-07
select * from outer_join_B b left join outer_join_C c on b.varchar_2=c.varchar_2 WHERE c.varchar_1 like 'A%';
id	varchar_1	varchar_2	id	varchar_1	varchar_2
1	A	aa	1	A%%	aa
2	BB	b	1	A	b
3	C	c	1	A 	c
4	DD	d	2	A A	d
select * from outer_join_A a,outer_join_C c left join outer_join_B b on a.varchar_1=b.varchar_1 where a.varchar_2=c.varchar_2;
ERROR 42S22: Unknown column 'a.varchar_1' in 'on clause'
