#dblink
SELECT t1.c3
FROM test11111@my_link1 t1 JOIN test11112@my_link1 t2 ON t1.c1 < t2.c1
WHERE t1.c3 BETWEEN (SELECT i1 FROM test11113@my_link1 WHERE i1 = 2) AND
