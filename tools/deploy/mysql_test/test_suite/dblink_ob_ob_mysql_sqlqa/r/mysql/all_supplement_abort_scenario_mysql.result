DROP FUNCTION IF EXISTS get_cname;//
CREATE FUNCTION get_cname(v_id INT) RETURNS VARCHAR(50)
BEGIN
DECLARE v_name VARCHAR(50);
SELECT c0 INTO v_name FROM gbktable WHERE c0 = v_id;
IF v_name IS NULL THEN
SIGNAL SQLSTATE '45000' SET MESSAGE_TEXT = '你输入的ID无效！';
END IF;
RETURN v_name;
END;//
