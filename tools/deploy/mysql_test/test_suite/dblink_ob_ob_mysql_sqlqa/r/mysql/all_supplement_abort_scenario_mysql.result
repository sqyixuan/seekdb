CREATE OR REPLACE VIEW v1 (f1,f2,f3,f4) AS SELECT id,p_id,name,birth FROM stu150@my_link1;
CREATE OR REPLACE VIEW v AS SELECT a.f1,b.f4 FROM v1 a full join v1 b on a.f1=b.f1;
