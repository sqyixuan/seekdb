WITH a AS (SELECT count(*) m FROM stu1121@my_link1 s LEFT JOIN class150@my_link1 c ON s.c_id=c.id GROUP BY c.id HAVING c.id IN (SELECT id FROM class150@my_link1)),
b AS (SELECT DISTINCT s.name t,c.name FROM stu2121@my_link2 s JOIN class233@my_link2 c ON s.c_id=c.id INTERSECT SELECT m.e,m.r FROM (SELECT s.id q,c.id w,s.name e,c.name r FROM stu333 s,class333 c) m)
SELECT DISTINCT a.m,b.t FROM a,b order by 1,2;
