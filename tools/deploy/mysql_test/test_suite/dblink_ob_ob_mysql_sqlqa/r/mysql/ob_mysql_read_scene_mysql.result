# 表、列 别名
SELECT shenle.id , MAX(shenle.p_id ) FROM stu150@my_link1 shenle JOIN stu150 ON shenle.id = stu150.id WHERE shenle.id = 39 GROUP BY shenle.id, shenle.p_id ORDER BY stu150.p_id DESC;
id	MAX(shenle.p_id )
#  多dblink表子查询
SELECT DISTINCT T32_1.id
FROM 
class150 T32_1, 
stu150 T1_176_1
WHERE (EXISTS (SELECT stu150.id FROM stu150 WHERE stu150.id = T32_1.id)) 
AND T1_176_1.id <= 2 
AND T32_1.id <= 2 
AND T1_176_1.c_id = T32_1.id 
AND (
SELECT COUNT(*) FROM (
SELECT stu150.id FROM stu150
) AS subquery
) > 0;
id
SELECT DISTINCT T32_1.id
FROM 
class150@my_link1 T32_1, 
stu150@my_link1 T1_176_1
WHERE (EXISTS (SELECT stu150.id FROM stu150@my_link2 WHERE stu150.id = T32_1.id)) 
AND T1_176_1.id <= 2 
AND T32_1.id <= 2 
AND T1_176_1.c_id = T32_1.id 
AND (
SELECT COUNT(*) FROM (
SELECT stu150.id FROM stu150@my_link2
) AS subquery
) > 0;
id
