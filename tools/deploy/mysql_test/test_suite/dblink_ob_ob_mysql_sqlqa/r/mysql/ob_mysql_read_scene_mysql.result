# 递归公用表达式 (CTE)
WITH RECURSIVE 
odd_no (sr_no, n) AS
(
SELECT 1, id FROM class150 where id = 101
union all
SELECT sr_no+1, n+2 from odd_no where sr_no < 5 
)
SELECT * FROM odd_no;
sr_no	n
1	101
2	103
3	105
4	107
5	109
WITH RECURSIVE 
odd_no (sr_no, n) AS
(
SELECT 1, id FROM class150@my_link1 where id = 101
union all
SELECT sr_no+1, n+2 from odd_no where sr_no < 5 
)
SELECT * FROM odd_no;
sr_no	n
1	101
2	103
3	105
4	107
5	109
WITH RECURSIVE cte AS (
SELECT id, name, CAST(FLOOR(LOG(p_id)) AS UNSIGNED) AS p_id_level, c_id
FROM stu150@my_link1
WHERE FLOOR(LOG(p_id)) IN (SELECT FLOOR(LOG(id)) FROM stu150@my_link1 WHERE id < 103 UNION SELECT FLOOR(LOG(id)) FROM stu150@my_link2 WHERE id > 103)
UNION ALL
SELECT s.id, s.name, CAST(FLOOR(LOG(s.p_id)) AS UNSIGNED) AS p_id_level, s.c_id
FROM stu150 s
JOIN cte ON CAST(FLOOR(LOG(s.p_id)) AS UNSIGNED) = cte.p_id_level AND s.id =1001
)
SELECT * FROM cte;
id	name	p_id_level	c_id
1007	wangliu	6	103
1006	liwu	6	103
1005	zhangsi	6	103
1004	zhaoliu	6	102
1003	wangwu	6	102
1002	lisi	6	101
WITH RECURSIVE temp(id, p_id, name, level) AS (
SELECT id, p_id, name, 1 FROM stu150 WHERE FLOOR(log(id) * 100000) > (SELECT MIN(a.m) FROM (SELECT FLOOR(log(id) * 100000) m FROM class150) a INNER JOIN (SELECT FLOOR(log(id) * 100000) n,FLOOR(log(id) * 1200000) FROM class150) b ON a.m=b.n)/0.8 AND name='zhaoliu' AND id > (998 + (SELECT MIN(b.n) FROM (SELECT FLOOR(log(id) * 100000) m FROM class150) a INNER JOIN (SELECT FLOOR(log(id) * 100000) n,FLOOR(log(id) * 1200000) FROM class150) b ON a.m=b.n WHERE FLOOR(log(3)) = 0))
UNION ALL
SELECT s.id, s.p_id, s.name, t.level+1 FROM stu150 s, temp t WHERE s.p_id = t.id
)
SELECT FLOOR(log(temp.id) * 100000), temp.name FROM temp INNER JOIN class150 ON temp.id = class150.id ORDER BY temp.id;
FLOOR(log(temp.id) * 100000)	name
WITH RECURSIVE temp(id, p_id, name, level) AS (
SELECT id, p_id, name, 1 FROM stu150@my_link1 WHERE FLOOR(log(id) * 100000) > (SELECT MIN(a.m) FROM (SELECT FLOOR(log(id) * 100000) m FROM class150) a INNER JOIN (SELECT FLOOR(log(id) * 100000) n,FLOOR(log(id) * 1200000) FROM class150) b ON a.m=b.n)/0.8 AND name='zhaoliu' AND id > (998 + (SELECT MIN(b.n) FROM (SELECT FLOOR(log(id) * 100000) m FROM class150) a INNER JOIN (SELECT FLOOR(log(id) * 100000) n,FLOOR(log(id) * 1200000) FROM class150@my_link2) b ON a.m=b.n WHERE FLOOR(log(3)) = 0))
UNION ALL
SELECT s.id, s.p_id, s.name, t.level+1 FROM stu150@my_link2 s, temp t WHERE s.p_id = t.id
)
SELECT FLOOR(log(temp.id) * 100000), temp.name FROM temp INNER JOIN class150 ON temp.id = class150.id ORDER BY temp.id;
FLOOR(log(temp.id) * 100000)	name
