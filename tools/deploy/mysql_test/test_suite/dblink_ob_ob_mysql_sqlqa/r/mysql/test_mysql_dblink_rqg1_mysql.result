select   grouping(col_bigint) as col_number_alias,grouping(col_bigint) as col_number_alias2,grouping(col_bigint) as col_number_alias3 from table1@my_link1 where col_integer = 100000 or (regexp_like(col_varchar_10_key, '^[a-za-z]') and col_varchar_10 like '%b_') or col_bigint = -1 group by pk,col_tinyint_key,col_int_key,col_bigint,col_smallint,col_smallint_key,col_int,col_integer_key,col_mediumint_key,col_tinyint,col_bigint_key,col_mediumint,col_varchar_10_key,col_varchar_10 with rollup order by pk desc;
select   if(grouping(col_tinyint_key), 'all test numbers', '111') as col_number_alias, if(grouping(col_varchar_10), 'all test numbers', '111') as col_number_alias2,count(*) from table30_key_pk_parts_2_bigint@my_link2 where (col_tinyint = -1 and col_tinyint in (3,4,0)) or col_integer_key = 10 group by pk,col_tinyint_key,col_int_key,col_bigint,col_smallint,col_smallint_key,col_int,col_integer_key,col_mediumint_key,col_tinyint,col_bigint_key,col_mediumint,col_varchar_10_key,col_varchar_10 with rollup order by 1;
select /*+ no_use_bnl(table30_bigint@my_link2 table10_hash_pk_parts_4_bigint@my_link1) */  if(grouping(col_varchar_10_key), 'all test numbers', '111') as col_number_alias from table10_key_pk_parts_2@my_link1 where regexp_like(col_mediumint_key, '1000') group by pk,col_tinyint_key,col_int_key,col_bigint,col_smallint,col_smallint_key,col_int,col_integer_key,col_mediumint_key,col_tinyint,col_bigint_key,col_mediumint,col_varchar_10_key,col_varchar_10 with rollup order by substr(col_char_30_key,length(col_char_30_key)-2);
select /*+ leading(table30_key_pk_parts_2_bigint@my_link2 table10_hash_pk_parts_4@my_link2) */  if(grouping(a.col_tinyint_key), 'all test numbers', '111') as col_number_alias from table10@my_link1 a left join table1_key_pk_parts_2@my_link1 b on a.col_tinyint_key = b.col_tinyint_key where a.col_bigint > 1003 group by a.col_tinyint_key with rollup;
select /*+ no_use_late_materialization */  if(grouping(col_tinyint), 'all test numbers', '111') as col_number_alias, if(grouping(col_integer_key), 'all test numbers', '111') as col_number_alias2, if(grouping(col_int_key), 'all test numbers', '111') as col_number_alias3 from table30_bigint@my_link2 where col_integer_key = 10 and (col_mediumint_key <> 40 or col_integer in ('1000')) and col_bigint_key in (9999999999999999999999999999999999999999,-3.533333333333333333333333333) group by pk,col_tinyint_key,col_int_key,col_bigint,col_smallint,col_smallint_key,col_int,col_integer_key,col_mediumint_key,col_tinyint,col_bigint_key,col_mediumint,col_varchar_10_key,col_varchar_10 with rollup order by col_varchar_10;
#清理环境
purge recyclebin;
