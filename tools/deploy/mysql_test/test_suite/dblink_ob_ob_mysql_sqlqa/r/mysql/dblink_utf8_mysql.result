创建复制表
drop table if exists t1 ;
drop table if exists t2 ;
drop table if exists t3 ;
Warnings:
Note	1051	Unknown table 'test.t3'
create table t1 as select myDate, myTime from myTable2@my_link1 order by id ;
create table t2 as select  myYear , myDatetime, myTimestamp from myTable2@my_link1 order by id ;
create table t3 as SELECT COUNT(DISTINCT myYear) FROM myTable2@my_link1;
desc t1;
Field	Type	Null	Key	Default	Extra
myDate	date	YES		NULL	
myTime	time	YES		NULL	
desc t2;
Field	Type	Null	Key	Default	Extra
myYear	year(0)	YES		NULL	
myDatetime	datetime	YES		NULL	
myTimestamp	timestamp	YES		NULL	
desc t3;
Field	Type	Null	Key	Default	Extra
COUNT(DISTINCT myYear)	bigint(20)	NO		NULL	
drop table if exists t1 ;
drop table if exists t2 ;
drop table if exists t3 ;
