create table t1 as select myTinyint as a from myTable1 order by id;
create table t2 as select max(myDouble)  as a from myTable1 order by id;
create table t3 as select myTinyint as a ,mySmallint as b  from myTable1 order by id;
create table t4 as select max(myFloat) as a ,min(myDouble) as b  from myTable1 order by id;
desc t1;
