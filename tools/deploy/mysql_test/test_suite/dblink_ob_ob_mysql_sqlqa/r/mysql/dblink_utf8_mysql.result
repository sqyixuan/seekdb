desc t3;
Field	Type	Null	Key	Default	Extra
a	tinyint(4)	YES		NULL	
b	smallint(6)	YES		NULL	
desc t4;
Field	Type	Null	Key	Default	Extra
a	float(8,2)	YES		NULL	
b	double(10,2)	YES		NULL	
