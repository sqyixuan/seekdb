DELETE FROM class333_1 WHERE id=(SELECT MIN(id) FROM (WITH a AS (SELECT DISTINCT n.id,m.name FROM stu233@my_link2 m JOIN class333 n ON n.id=m.c_id),
b AS (SELECT t.name FROM (SELECT n.id,m.name FROM stu333 m,class150@my_link1 n) t)
SELECT DISTINCT a.id FROM a,b WHERE trim(a.name)=trim(b.name)));
DELETE FROM class333_1 WHERE id IN 
(SELECT id FROM (SELECT c_id FROM stu333 WHERE id>1004 GROUP BY c_id HAVING c_id>101 
UNION SELECT c_id FROM stu233@my_link2 WHERE id<1003 GROUP BY c_id HAVING c_id=101 ORDER BY c_id) a 
RIGHT JOIN (SELECT DISTINCT id,name,location FROM class333) b ON a.c_id=b.id);
