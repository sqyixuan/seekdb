102	2
SELECT e.id,count(e.name) from stu150@my_link1 e INNER JOIN class233@my_link2 d on e.c_id = d.id where e.c_id = d.id and e.name ='wangwu' group by e.id having count(e.name) >=1 order by e.id;
id	count(e.name)
1003	1
WITH 
T1 AS (SELECT e.id,count(e.name) from class150@my_link1 e INNER JOIN class233@my_link2 d on e.id = d.id where e.name = d.name and e.name ='dianzi' group by e.id having count(e.name) >=1 order by e.id),
T2 AS (SELECT e.id,count(e.name) from stu150@my_link1 e INNER JOIN stu150@my_link2 d on e.id = d.id where e.name = d.name and e.name ='wangwu' group by e.id having count(e.name) >=1 order by e.id),
T3 AS (SELECT e.id,count(e.name) from class150@my_link1 e INNER JOIN stu150@my_link2 d on e.id = d.c_id where e.id = d.c_id and e.name ='dianzi' group by e.id having count(e.name) >=1 order by e.id),
T4 AS (SELECT e.id,count(e.name) from stu150@my_link1 e INNER JOIN class233@my_link2 d on e.c_id = d.id where e.c_id = d.id and e.name ='wangwu' group by e.id having count(e.name) >=1 order by e.id)
SELECT * FROM T1,T2,T3,T4;
id	count(e.name)	id	count(e.name)	id	count(e.name)	id	count(e.name)
