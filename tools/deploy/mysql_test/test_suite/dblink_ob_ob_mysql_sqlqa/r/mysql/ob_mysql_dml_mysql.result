#mysql_dblink_read-06-1-4	case when
SELECT sum(CASE WHEN round(LN(id),5)>0 THEN id-100 ELSE 1 END ) FROM class150@my_link1 WHERE id IN (SELECT DISTINCT c_id FROM stu233@my_link2) order by 1;
sum(CASE WHEN round(LN(id),5)>0 THEN id-100 ELSE 1 END )
6
SELECT sum(round(LN(CASE WHEN  round(LN(id),5)>0 THEN 2 ELSE 1 END),5)/round(LN(c_id),5)) FROM stu150@my_link1 order by 1;
sum(round(LN(CASE WHEN  round(LN(id),5)>0 THEN 2 ELSE 1 END),5)/round(LN(c_id),5))
1.048791619
SELECT sum(round(LN(CASE id WHEN 101 THEN round(LN(id),5) WHEN 102 THEN round(LN(id+100),5) ELSE 10 END),5)/round(LN(id),5)) t1 FROM class233@my_link2 order by 1;
t1
2.178646012
SELECT sum(round(LN(CASE round(LN(id),5) WHEN round(LN(1002),5) THEN 1 ELSE 2 END),5)) FROM stu233@my_link2 order by 1;
sum(round(LN(CASE round(LN(id),5) WHEN round(LN(1002),5) THEN 1 ELSE 2 END),5))
4.15890
SELECT sum(CASE WHEN round(LN(id),5)>0 THEN id-100 ELSE 1 END ) FROM class150@my_link1 UNION SELECT sum(round(LN(CASE WHEN  round(LN(id),5)>0 THEN 2 ELSE 1 END),5)/round(LN(c_id),5)) FROM stu233@my_link2 order by 1;
sum(CASE WHEN round(LN(id),5)>0 THEN id-100 ELSE 1 END )
1.048791619
16.000000000
#mysql_dblink_read-06-2	层级查询
#mysql_dblink_read-06-2-1	select ... from ... where ... start with ... connect by ... order by ...
WITH RECURSIVE subcategories AS (
SELECT id, name, p_id
FROM stu233
WHERE id = 102
UNION ALL
SELECT c.id, c.name, c.p_id
FROM stu233 c
JOIN subcategories s ON s.id = c.p_id
)
SELECT id, name
FROM subcategories
WHERE id != 1002;
id	name
WITH RECURSIVE subcategories AS (
SELECT id, name, p_id
FROM stu233@my_link1
WHERE id = 102
UNION ALL
SELECT c.id, c.name, c.p_id
FROM stu233@my_link2 c
JOIN subcategories s ON s.id = c.id
)
SELECT id, name
FROM subcategories
WHERE id != 1002;
id	name
#mysql_dblink_read-06-3	子查询
select * from (select id + p_id, c_id from stu150@my_link1 t1 where id < 1005) v where c_id > 1 order by c_id,1;
id + p_id	c_id
NULL	101
2003	101
2004	102
2006	102
select /*+ no_rewrite */* from (select id + p_id, c_id from stu150@my_link1 t1 where id < 1005) v where c_id > 1 order by c_id,1;
id + p_id	c_id
NULL	101
2003	101
2004	102
2006	102
#本地表嵌套远端表
SELECT round(LN((SELECT MIN(id) FROM class150@my_link1)),5) FROM dual;
round(LN((SELECT MIN(id) FROM class150@my_link1)),5)
4.61512
SELECT * FROM (SELECT DISTINCT id,name,birth,c_id FROM stu150@my_link1) s, class233@my_link2 c WHERE c.id=s.c_id AND s.id<1005 order by 1,2,3,4,5,6,7,8;
id	name	birth	c_id	id	name	location	create_time
1001	zhangsan	1991-09-25	101	101	yinyue	binjiang	2005-09-25 12:01:33.33330
1002	lisi	1992-09-25	101	101	yinyue	binjiang	2005-09-25 12:01:33.33330
1003	wangwu	1993-09-25	102	102	dianzi	xixi	2008-09-25 12:01:33.33330
1004	zhaoliu	1994-09-25	102	102	dianzi	xixi	2008-09-25 12:01:33.33330
