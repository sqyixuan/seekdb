drop table if exists t1;
create table t1(pk int primary key, content longtext);
insert into t1 values(1, repeat('abcdefghijklmnopqrstuvwxyz', 1000000));
select length(content), substr(content, 261, 26), substr(content, 26001, 26) from t1;
length(content)	substr(content, 261, 26)	substr(content, 26001, 26)
26000000	abcdefghijklmnopqrstuvwxyz	abcdefghijklmnopqrstuvwxyz
insert into t1 values(2, repeat('abcdety', 13421773));
select substr(content, 1, 10) from t1 where pk = 2;
substr(content, 1, 10)
abcdetyabc
