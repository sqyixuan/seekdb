4	8db3b9bafffe4ae844c425b781db6e2a
select pk, md5(make_set(1|2|4, null, c1, null)) from t1;
pk	md5(make_set(1|2|4, null, c1, null))
1	d41d8cd98f00b204e9800998ecf8427e
2	d41d8cd98f00b204e9800998ecf8427e
3	b26e49b624645749bbfecd3f2a9794f2
4	be7de975daa5d553eb50f221ff5b1a1e
select pk, md5(make_set(1, null)) from t1;
pk	md5(make_set(1, null))
1	d41d8cd98f00b204e9800998ecf8427e
2	d41d8cd98f00b204e9800998ecf8427e
3	d41d8cd98f00b204e9800998ecf8427e
4	d41d8cd98f00b204e9800998ecf8427e
select pk, md5(make_set(1|2|4, 'x', c1, c2)) from t1;
pk	md5(make_set(1|2|4, 'x', c1, c2))
1	9dd4e461268c8034f5c8564e155c67a6
2	0e503e6ba8df74a61723be29415bcdc5
