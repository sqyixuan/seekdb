drop table if exists t1;
create table t1(nr int, a longtext, b longblob);
insert into t1 values(1, repeat('a', 5000000), repeat('a', 5000000));
insert into t1 values(1, repeat('a', 1000000), repeat('a', 1000000));
insert into t1 select * from t1;
insert into t1 select * from t1;
select nr, sum(length(a)), sum(length(b)) from t1 group by nr order by nr asc;
nr	sum(length(a))	sum(length(b))
1	24000000	24000000
alter system major freeze tenant = sys;
alter system major freeze tenant = all_user;
alter system major freeze tenant = all_meta;
select nr, sum(length(a)), sum(length(b)) from t1 group by nr order by nr asc;
nr	sum(length(a))	sum(length(b))
1	24000000	24000000
drop table t1;
drop table if exists t1;
create table t1 (nr int primary key, a tinyblob, b text, c mediumblob, d longtext);
insert into t1 values(1, 'a', 'b', repeat('c', 100000), repeat('d', 1000000));
insert into t1 values(2, 'aa', 'bb', repeat('c', 200000), repeat('d', 2000000));
insert into t1 values(3, 'aaa', 'bbb', repeat('c', 300000), repeat('d', 3000000));
insert into t1 values(4, null, null, null, null);
insert into t1 values(5, '', '', '', '');
select nr, a, b, length(c), length(d) from t1 order by nr asc;
nr	a	b	length(c)	length(d)
1	a	b	100000	1000000
2	aa	bb	200000	2000000
3	aaa	bbb	300000	3000000
4	NULL	NULL	NULL	NULL
5			0	0
delete from t1 where a is null;
update t1 set c = 'updatemedium', d = 'updatelong' where b = 'bbb';
select nr, a, b, length(c), length(d) from t1 order by nr asc;
nr	a	b	length(c)	length(d)
1	a	b	100000	1000000
2	aa	bb	200000	2000000
3	aaa	bbb	12	10
5			0	0
alter system major freeze tenant = sys;
alter system major freeze tenant = all_user;
alter system major freeze tenant = all_meta;
select nr, a, b, length(c), length(d) from t1 order by nr asc;
nr	a	b	length(c)	length(d)
1	a	b	100000	1000000
2	aa	bb	200000	2000000
3	aaa	bbb	12	10
5			0	0
delete from t1 where a < 'aa';
select nr, a, b, length(c), length(d) from t1 order by nr asc;
nr	a	b	length(c)	length(d)
2	aa	bb	200000	2000000
3	aaa	bbb	12	10
drop table t1;
