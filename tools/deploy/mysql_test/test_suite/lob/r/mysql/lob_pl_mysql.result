drop table if exists t1;
drop function if exists f1;
create table t1(c1 mediumtext) lob_inrow_threshold = 0;
insert into t1 values ('[{"k": "1111"}, {"k": "2222" }]');
CREATE FUNCTION f1(in_str MEDIUMTEXT) RETURNS VARCHAR(64) BEGIN
DECLARE k1 VARCHAR(64);
SET k1 = (SELECT JSON_UNQUOTE(JSON_EXTRACT(in_str,'$[1].k'))); 
return k1;
END
//
select f1(c1) from t1;
f1(c1)
2222
select f1(c1) from t1;
f1(c1)
2222
drop function f1;
drop table t1;
