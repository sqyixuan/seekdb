drop table t1;
create table t1(pk int primary key, c1 longtext);
insert into t1 values(1, repeat('1', 786432));
update t1 set c1 = repeat('2', 786432);
drop table t1;
set ob_default_lob_inrow_threshold=786433;
ERROR HY000: Incorrect arguments to lob inrow threshold, should be [0, 786432]
create table lob_t1(pk int primary key, c1 longtext) lob_inrow_threshold = 4097;
insert into lob_t1 values(1, repeat('1', 786432));
select lob_inrow_threshold from oceanbase.__all_table where table_name='lob_t1';
lob_inrow_threshold
4097
alter table lob_t1 set lob_inrow_threshold = 1026;
select lob_inrow_threshold from oceanbase.__all_table where table_name='lob_t1';
lob_inrow_threshold
1026
run offline ddl
alter table lob_t1 set lob_inrow_threshold = 1027;
select lob_inrow_threshold from oceanbase.__all_table where table_name='lob_t1';
lob_inrow_threshold
1027
run online ddl
drop table lob_t1;
