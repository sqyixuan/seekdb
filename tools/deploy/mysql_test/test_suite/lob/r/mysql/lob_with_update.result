create table if not exists blob_test_table(pk bigint auto_increment primary key, 
c1_longblob longblob,
c1_int int,
c2_longblob longblob,
c2_int int,
c3_longblob longblob,
c3_int int,
c4_longblob longblob,
c4_int int,
gmt_create  timestamp(6) NULL DEFAULT CURRENT_TIMESTAMP(6), 
gmt_modified timestamp(6) NULL DEFAULT CURRENT_TIMESTAMP(6) ON UPDATE CURRENT_TIMESTAMP(6));
alter system minor freeze tenant = sys;
alter system minor freeze tenant = all_user;
alter system minor freeze tenant = all_meta;
update blob_test_table set c1_longblob = repeat(concat(now(6), '*'),50000), 
c3_longblob = repeat(concat(now(6), '$'),50000),
c2_longblob = repeat(concat(now(6), '@'),50000),
c4_longblob = repeat(concat(now(6), '#'),50000);
alter system minor freeze tenant = sys;
alter system minor freeze tenant = all_user;
alter system minor freeze tenant = all_meta;
alter system minor freeze tenant = sys;
alter system minor freeze tenant = all_user;
alter system minor freeze tenant = all_meta;
select count(*) from blob_test_table where c1_longblob like "%*%";
count(*)
10
select count(*) from blob_test_table where c2_longblob like "%@%";
count(*)
10
select count(*) from blob_test_table where c3_longblob like "%$%";
count(*)
10
select count(*) from blob_test_table where c4_longblob like "%#%";
count(*)
10
drop table if exists blob_test_table;
