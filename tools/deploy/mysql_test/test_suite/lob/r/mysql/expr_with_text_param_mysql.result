drop table if exists t10, t9, t8, t7, t6, t5, t4, t3, t2, t1;
create table t1(c1 tinytext, c2 mediumtext, c3 text, c4 longtext);
insert into t1 values('31323334', '31323334','31323334','31323334');
create table t2 as select format(c1, 4), format(c2, 4), format(c3, 4), format(c4, 4) from t1;
desc t2;
Field	Type	Null	Key	Default	Extra
format(c1, 4)	varchar(373)	YES		NULL	
format(c2, 4)	longtext	YES		NULL	
format(c3, 4)	longtext	YES		NULL	
format(c4, 4)	longtext	YES		NULL	
create table t3 as select left(c1, 1), left(c2, 1), left(c3, 1), left(c4, 1) from t1;
desc t3;
Field	Type	Null	Key	Default	Extra
left(c1, 1)	varchar(1)	YES		NULL	
left(c2, 1)	varchar(1)	YES		NULL	
left(c3, 1)	varchar(1)	YES		NULL	
left(c4, 1)	varchar(1)	YES		NULL	
create table t4 as select reverse(c1), reverse(c2), reverse(c3), reverse(c4) from t1;
desc t4;
Field	Type	Null	Key	Default	Extra
reverse(c1)	varchar(255)	YES		NULL	
reverse(c2)	longtext	YES		NULL	
reverse(c3)	longtext	YES		NULL	
reverse(c4)	longtext	YES		NULL	
create table t5 as select substr(c1, 1.5), substr(c2, 1), substr(c3, 1), substr(c4, 1) from t1;
desc t5;
Field	Type	Null	Key	Default	Extra
substr(c1, 1.5)	text	YES		NULL	
substr(c2, 1)	longtext	YES		NULL	
substr(c3, 1)	longtext	YES		NULL	
substr(c4, 1)	longtext	YES		NULL	
create table t6 as select lower(c1), lower(c2), lower(c3), lower(c4) from t1;
desc t6;
Field	Type	Null	Key	Default	Extra
lower(c1)	varchar(255)	YES		NULL	
lower(c2)	longtext	YES		NULL	
lower(c3)	longtext	YES		NULL	
lower(c4)	longtext	YES		NULL	
create table t7 as select hex(c1), hex(c2), hex(c3), hex(c4) from t1;
desc t7;
Field	Type	Null	Key	Default	Extra
hex(c1)	text	YES		NULL	
hex(c2)	longtext	YES		NULL	
hex(c3)	longtext	YES		NULL	
hex(c4)	longtext	YES		NULL	
create table t8 as select unhex(c1), unhex(c2), unhex(c3), unhex(c4) from t1;
desc t8;
Field	Type	Null	Key	Default	Extra
unhex(c1)	varbinary(383)	YES		NULL	
unhex(c2)	longblob	YES		NULL	
unhex(c3)	longblob	YES		NULL	
unhex(c4)	longblob	YES		NULL	
CREATE TABLE t9 (col1 LONGTEXT, INDEX idx1 ((SUBSTRING(col1, 1, 10))));
desc t9;
Field	Type	Null	Key	Default	Extra
col1	longtext	YES		NULL	
create table t10 as select concat(c1,'a'), concat('a',c2), concat('a','b',c3,'c'), concat('a','b','c',c4) from t1;
desc t10;
Field	Type	Null	Key	Default	Extra
concat(c1,'a')	varchar(256)	YES		NULL	
concat('a',c2)	longtext	YES		NULL	
concat('a','b',c3,'c')	longtext	YES		NULL	
concat('a','b','c',c4)	longtext	YES		NULL	
drop table if exists t10, t9, t8, t7, t6, t5, t4, t3, t2, t1;
create table t1(c1 longtext, c2 varbinary(10));
create table t2 as select concat(c1, c2) as c1 from t1;
desc t2;
Field	Type	Null	Key	Default	Extra
c1	longblob	YES		NULL	
create table t3 as select concat(rpad('-', cast(30 as signed), '-'), char(10)) as c1 from dual;
desc t3;
Field	Type	Null	Key	Default	Extra
c1	longblob	YES		NULL	
drop table t1, t2, t3;
