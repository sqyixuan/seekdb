insert into trade_base (trade_no,tnt_inst_id,out_trade_no,memo,partner_id,trans_amount) values ('da3788ccdb54cc737ca1d4ce1f5c24b2',1,'',1,1,1);

select   ref_0.c3_longblob as c0,  ref_0.c3_md5 as c1,  ref_0.c4_md5 as c3 from  obbigpartition as ref_0 where EXISTS ( select distinct  ref_4.trans_amount as c0,  ref_4.memo as c1 from  trade_base as ref_4 where ref_4.trade_no in ( ref_0.c2_md5,  ref_0.c4_longtext,  ref_0.c4_md5,  ref_0.c4_md5) limit 1);
+------+------+------+
| c0   | c1   | c3   |
+------+------+------+
+------+------+------+

drop table trade_base;
drop table obbigpartition;

drop table if exists t1;
create table t1(
c1 tinyint(3) unsigned NOT NULL,
c2 double NOT NULL DEFAULT '4222.682974508274',
PRIMARY KEY (c1));

insert into t1 (c1) values (1);
insert into t1 values (2, 12313.123213);
insert into t1 values (3, 8989.172397);

alter table t1 add column c3 json not null;

select c3, max(c2) from t1;
+------+--------------+
| c3   | max(c2)      |
+------+--------------+
| null | 12313.123213 |
+------+--------------+

drop table t1;

drop database if exists db1;
drop database if exists db2;
create database db1;
create database db2;
create table db1.t1(c1 text);
insert into db1.t1 values(repeat('a', 6000));
rename table db1.t1 to db2.t1;
drop database db1;
purge recyclebin;
select substr(c1, 1, 10) from db2.t1;
+-------------------+
| substr(c1, 1, 10) |
+-------------------+
| aaaaaaaaaa        |
+-------------------+
drop database db2;

