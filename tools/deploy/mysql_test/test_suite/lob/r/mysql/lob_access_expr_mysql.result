DROP TABLE IF EXISTS t0;
CREATE TABLE IF NOT EXISTS t0(c0 TINYTEXT  , c1 DOUBLE(19, 17) ZEROFILL , c2 TINYINT(219)   UNIQUE KEY, c3 LONGTEXT );
REPLACE INTO t0(c0, c1, c2, c3) VALUES ROW("_7[LaN\\O]7i}K'9", 93.55431863822935, -8, 'on');
INSERT INTO t0(c1, c2) VALUES ROW(7, -8) ON DUPLICATE KEY UPDATE c2=-6;
select * from t0;
+-----------------+----------------------+------+------+
| c0              | c1                   | c2   | c3   |
+-----------------+----------------------+------+------+
| _7[LaN\O]7i}K'9 | 93.55431863822935000 |   -6 | on   |
+-----------------+----------------------+------+------+
UPDATE t0 SET c3='';
select * from t0;
+-----------------+----------------------+------+------+
| c0              | c1                   | c2   | c3   |
+-----------------+----------------------+------+------+
| _7[LaN\O]7i}K'9 | 93.55431863822935000 |   -6 |      |
+-----------------+----------------------+------+------+
drop table t0;
set ob_default_lob_inrow_threshold=4096;

create table t0(pk int primary key, c1 text, c2 varchar(100)) lob_inrow_threshold=0;
insert into t0 values (1,'v0', 'v0');
select pk, md5(c1), md5(c2) from t0;
