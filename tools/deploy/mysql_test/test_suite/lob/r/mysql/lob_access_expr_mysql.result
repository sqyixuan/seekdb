drop table if exists obbigpartition;
drop table if exists trade_base;
CREATE TABLE `obbigpartition` (
  `pk` bigint(20) NOT NULL AUTO_INCREMENT,
  `c1_blob` blob DEFAULT NULL,
  `c2_text` text DEFAULT NULL,
  `c3_longblob` longblob DEFAULT NULL,
  `c4_longtext` longtext DEFAULT NULL,
  `c1_md5` varchar(1024) DEFAULT NULL,
  `c2_md5` varchar(1024) DEFAULT NULL,
  `c3_md5` varchar(1024) DEFAULT NULL,
  `c4_md5` varchar(1024) DEFAULT NULL,
  `gmt_create` timestamp(6) NULL DEFAULT CURRENT_TIMESTAMP(6),
  `gmt_modified` timestamp(6) NULL DEFAULT CURRENT_TIMESTAMP(6) ON UPDATE CURRENT_TIMESTAMP(6),
  PRIMARY KEY (`pk`)
) AUTO_INCREMENT = 12000001 AUTO_INCREMENT_MODE = 'ORDER' DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0;

CREATE TABLE `trade_base` (
  `trade_no` varchar(64) NOT NULL,
  `tnt_inst_id` varchar(32) NOT NULL,
  `out_trade_no` varchar(64) NOT NULL,
  `memo` varchar(500) DEFAULT NULL,
  `partner_id` varchar(32) DEFAULT NULL,
  `trans_amount` bigint(20) DEFAULT NULL,
  `partition_id` varchar(2) GENERATED ALWAYS AS (substr(`trade_no`,15,2)) VIRTUAL,
  `gmt_create` datetime(6) DEFAULT CURRENT_TIMESTAMP(6),
  `gmt_modified` datetime(6) DEFAULT CURRENT_TIMESTAMP(6),
  PRIMARY KEY (`trade_no`, `tnt_inst_id`),
  UNIQUE KEY `out_trade_no` (`out_trade_no`, `tnt_inst_id`, `partner_id`, `partition_id`) BLOCK_SIZE 16384 LOCAL
) DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
 partition by list columns(partition_id)
