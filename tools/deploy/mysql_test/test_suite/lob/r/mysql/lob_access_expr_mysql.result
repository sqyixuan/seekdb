insert ignore into tbl_38  values ( 'Bob','uyKfM$AVZ',0,'Alice' ), ( 'Bob','D%5~yS)SnQd-pQVg2',0,'Alice' ) on duplicate key update  col_163 = 0, col_161 = 'cL!_4weJgoMESZnhm@', col_160 = 'Bob', col_164 = 'Alice';
