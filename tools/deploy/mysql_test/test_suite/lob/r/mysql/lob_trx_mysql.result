drop table if exists t1;
create table t1(a longtext, b longblob, c longtext);
insert into t1 values(repeat('a', 5242880), repeat('a', 5242880), repeat('a', 5242880));
start transaction;
insert into t1 select * from t1;
commit;
select substr(a, 10000, 10), substr(b, 10000, 10), substr(c, 10000, 10) from t1;
substr(a, 10000, 10)	substr(b, 10000, 10)	substr(c, 10000, 10)
aaaaaaaaaa	aaaaaaaaaa	aaaaaaaaaa
aaaaaaaaaa	aaaaaaaaaa	aaaaaaaaaa
truncate t1;
begin;
insert into t1 values(repeat('a', 5242880), repeat('a', 5242880), repeat('a', 5242880));
insert into t1 select * from t1;
select substr(a, 10000, 10), substr(b, 10000, 10), substr(c, 10000, 10) from t1;
substr(a, 10000, 10)	substr(b, 10000, 10)	substr(c, 10000, 10)
aaaaaaaaaa	aaaaaaaaaa	aaaaaaaaaa
aaaaaaaaaa	aaaaaaaaaa	aaaaaaaaaa
rollback;
select substr(a, 10000, 10), substr(b, 10000, 10), substr(c, 10000, 10) from t1;
substr(a, 10000, 10)	substr(b, 10000, 10)	substr(c, 10000, 10)
drop table t1;
drop table if exists t1;
create table t1 (id int primary key, a tinyblob, b text, c mediumblob, d longtext);
insert into t1 values(1, 'a', 'b', 'c', 'd');
insert into t1 values(2, 'aa', 'bb', 'cc', 'dd');
commit;
start transaction;
update t1 set a = '123', c = 'abc' where id = 1;
update t1 set b = 'hello', d = 'hello ob' where id = 2;
select * from t1;
id	a	b	c	d
1	123	b	abc	d
2	aa	hello	cc	hello ob
rollback;
select * from t1;
id	a	b	c	d
1	a	b	c	d
2	aa	bb	cc	dd
drop table t1;
drop table if exists t1;
create table t1 (id int primary key, a tinyblob, b text, c mediumblob, d longtext);
insert into t1 values(1, 'a', 'b', 'c', 'd');
insert into t1 values(2, 'aa', 'bb', 'cc', 'dd');
commit;
start transaction;
delete from t1 where id = 1;
select * from t1;
id	a	b	c	d
2	aa	bb	cc	dd
rollback;
select * from t1;
id	a	b	c	d
1	a	b	c	d
2	aa	bb	cc	dd
drop table t1;
