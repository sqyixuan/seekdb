drop table if exists lob_test;
create table lob_test(pk int primary key , c1 longtext);
insert into lob_test values(1, repeat('Nm2R', 1000000));
insert into lob_test values(2, repeat('Nm2R', 10000));
insert into lob_test values(3, repeat('Nm2R', 100));
select length(c1), md5(c1) from lob_test;
length(c1)	md5(c1)
4000000	09e387e436fc17eea9591ec465b31bb5
40000	b08cd19925873b8a2f548011796ab910
400	1d5ad00a4db5b5016b6d0ac476f0f9ce
select length(soundex(c1)), md5(soundex(c1)) from lob_test;
length(soundex(c1))	md5(soundex(c1))
2000000	d18e9d40a12a2ceb5bde24b0e99a935a
20000	061e7e39cbdb06765cc77a2b72c97e59
200	3c819ca3775873b8e623ebf86e3d0ef5
