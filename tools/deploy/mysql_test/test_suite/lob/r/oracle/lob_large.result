set global max_allowed_packet=60000000;
drop table if exists t1, t2, t3;
create table t1(pk int, a clob, b blob);
create table t2(pk int, a clob, b blob, c clob);
create table t3(pk int, a clob);
select pk, length(a), length(b) from t1;
pk	length(a)	length(b)
1	200000	200000
2	200000	200000
select pk, length(a), length(b), length(c) from t2;
pk	length(a)	length(b)	length(c)
1	100000	60000	255
2	100000	60000	255
select pk, length(a) from t3;
pk	length(a)
1	50000
1	50000
explain basic select pk, length(a), substr(a, 1, 5), length(b), substr(b, 1, 5) from t1 where (t1.a, t1.b) in( select a,b from t1 order by pk desc limit 1);
