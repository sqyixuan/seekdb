  4 - output([t1.a], [t1.b], [t1.pk]), filter(nil), 
      access([t1.a], [t1.b], [t1.pk]), partitions(p0)
  5 - output([t1.a], [t1.b], [t1.pk], [length(t1.a)], [substr(t1.a, 1, 5)], [length(t1.b)], [substr(t1.b, 1, 5)]), filter(nil), 
      access([t1.a], [t1.b], [t1.pk]), partitions(p0)

