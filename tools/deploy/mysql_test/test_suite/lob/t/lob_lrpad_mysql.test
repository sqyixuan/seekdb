# owner: aozeliu.azl
# owner group: shenzhen
# description: test for lpad and rpad expr for mysql
# tags: text,blob

set global max_allowed_packet=default;
disconnect default;
sleep 1;
connect (default,$OBMYSQL_MS0,admin,admin,test,$OBMYSQL_PORT);

--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1 (c1 text, c2 text) lob_inrow_threshold=0;

# in mysql mode, lpad and rpad input is lob, but output is varchar

insert into t1 value(repeat('1', 100), repeat('x', 5000));
insert into t1 value(repeat('2', 100), repeat('x', 5000));
insert into t1 value(repeat('3', 100), repeat('x', 5000));
# length is negative
select lpad(c1, -1, '2'), md5(rpad(c2, 6000, 'y')) from t1;
# length is zero
select lpad(c1, 0, '2'), md5(rpad(c2, 6000, 'y')) from t1;
# length is less than input
select lpad(c1, 1, '2'), md5(rpad(c2, 6000, 'y')) from t1;
select lpad(c1, 10, '2'), md5(rpad(c2, 6000, 'y')) from t1;
select lpad(c1, 19, '2'), md5(rpad(c2, 6000, 'y')) from t1;
select lpad(c1, 67, '2'), md5(rpad(c2, 6000, 'y'))from t1;
# length is equal to input
select lpad(c1, 100, '2'), md5(rpad(c2, 6000, 'y')) from t1;
# length is large than input
select lpad(c1, 101, '2'), md5(rpad(c2, 6000, 'y')) from t1;
select lpad(c1, 200, '2'), md5(rpad(c2, 6000, 'y')) from t1;

# pad_str is NULL
select lpad(c1, 200, NULL), md5(rpad(c2, 6000, 'y')) from t1;
# pad_str is NULL
select lpad(c1, 200, ''), md5(rpad(c2, 6000, 'y')) from t1;

# exceed max_allowed_packet
show variables like 'max_allowed_packet';
select length(lpad(c1, 16777216, 'z')), md5(lpad(c1, 16777216, 'z')) from t1;
select length(lpad(c1, 16777217, 'z')), md5(lpad(c1, 16777217, 'z')) from t1;

# same for rpad above
select rpad(c1, -1, '2'), md5(lpad(c2, 6000, 'y')) from t1;
select rpad(c1, 0, '2'), md5(lpad(c2, 6000, 'y')) from t1;
select rpad(c1, 1, '2'), md5(lpad(c2, 6000, 'y')) from t1;
select rpad(c1, 10, '2'), md5(lpad(c2, 6000, 'y')) from t1;
select rpad(c1, 19, '2'), md5(lpad(c2, 6000, 'y')) from t1;
select rpad(c1, 67, '2'), md5(lpad(c2, 6000, 'y'))from t1;
select rpad(c1, 100, '2'), md5(lpad(c2, 6000, 'y')) from t1;
select rpad(c1, 101, '2'), md5(lpad(c2, 6000, 'y')) from t1;
select rpad(c1, 200, '2'), md5(lpad(c2, 6000, 'y')) from t1;
select rpad(c1, 200, NULL), md5(lpad(c2, 6000, 'y')) from t1;
select rpad(c1, 200, ''), md5(lpad(c2, 6000, 'y')) from t1;
select length(rpad(c1, 16777216, 'z')), md5(rpad(c1, 16777216, 'z')) from t1;
select length(rpad(c1, 16777217, 'z')), md5(rpad(c1, 16777217, 'z')) from t1;
drop table if exists t1;
