# owner: aozeliu.azl
# description: test lob load data
# tags: text,blob

# Prepare
let $LOAD_SOURCE_DATA_FOLDER = "$PWD/mysql_test/test_suite/lob/t/data/*";
--source mysql_test/include/copy_data_for_load_dir.inc
--disable_warnings
drop table if exists lob_test;
--enable_warnings

create table lob_test(pk int primary key, c1 text) DEFAULT_LOB_INROW_THRESHOLD=10240;
load data  /*+ append */  infile 'data_for_mysqltest_loaddata/lob_inrow_threshold_load_data_mysql.dat'  into table lob_test fields terminated by ',';

select pk, md5(c1) from lob_test;

# Clean Up

drop table lob_test;