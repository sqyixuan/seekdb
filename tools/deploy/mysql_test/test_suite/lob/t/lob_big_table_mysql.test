--enable_query_log

--let $filed_count=775
--let $value=
while($filed_count > 328)
{
  --let value = $value , NULL
  dec $filed_count;
}
while($filed_count > 0)
{
  --let value = $value , repeat('1', 10000)
  dec $filed_count;
}
--let insert_sql = insert into opm_t_group_inventory_plan values(repeat('1', 150) $value)
eval $insert_sql;

select md5(FMA_AFI_FOURTH_SALE_NUMBER), md5(FMA_AFI_FIRST_SALE_AMOUNT) from opm_t_group_inventory_plan;

alter table opm_t_group_inventory_plan add c1_text text;
alter table opm_t_group_inventory_plan add c2_text text;
alter table opm_t_group_inventory_plan add c3_text text;
update opm_t_group_inventory_plan set c1_text = repeat('1', 100), c2_text = repeat('2', 3000), c3_text = repeat('3', 5000);
select md5(c1_text), md5(c2_text), md5(c3_text) from opm_t_group_inventory_plan;

delete from opm_t_group_inventory_plan;