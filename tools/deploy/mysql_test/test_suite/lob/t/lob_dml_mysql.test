# owner: luohongdi.lhd
# owner group: SQL1
# description: basic dml test for blob and text column
# tags: text,blob
--disable_query_log
--disable_result_log

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;

--enable_result_log
--disable_query_log

set global max_allowed_packet=60000000;
set global ob_sql_work_area_percentage=90;
disconnect obsys;

sleep 1;

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);

set @@session.explicit_defaults_for_timestamp=off;
set @@recyclebin = off;
set ob_query_timeout=1000000000;
set ob_trx_timeout=1000000000;
--enable_query_log

#
# basic insert test for text/blob
#
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(a int primary key, b tinyblob, c text, d mediumblob, e longtext);
insert into t1 values(1, 'b', 'c', 'd', 'e');
insert into t1 values(2, 'bb', 'cc', 'dd', 'ee');
insert into t1 values(3, '', '', '', '');
insert into t1 values(4, null, null, null, null);
select * from t1 order by a;
insert into t1 values(5, repeat('~', 255), repeat('~', 65535), repeat('~', 16777215), repeat('~', 12582912));
select a, length(b), length(c), length(d), length(e) from t1  order by a;
--error 1406
insert into t1 values(6, repeat('~', 257), repeat('~', 65536), repeat('~', 2621440), repeat('~', 524288));
--error 1406
insert into t1 values(6, repeat('~', 256), repeat('~', 65537), repeat('~', 2621440), repeat('~', 524288));
--error 1406
insert into t1 values(6, repeat('~', 256), repeat('~', 65536), repeat('~', 16777217), repeat('~', 524288));
--error 1406
insert into t1 values(6, repeat('~', 256), repeat('~', 65536), repeat('~', 16777216), repeat('~', 50331649));
drop table t1;

#
# basic incremental update test for text/blob
#
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(a int primary key, b tinyblob, c text, d mediumblob, e longtext);
insert into t1 values(1, 'b', 'c', 'd', 'e');
insert into t1 values(2, 'bb', 'cc', 'dd', 'ee');

#length($a) == 400
--let $a=''
--let $loop=2
while ($loop)
{
	--disable_query_log
	eval update t1 set c=concat(c, $a) where a = 2;
	eval update t1 set d=concat(d, $a) where a = 1;
	eval update t1 set e=concat(e, $a) where a = 2;
	--enable_query_log
	select a, length(b), length(c), length(d), length(e) from t1 order by a;
	dec $loop;
}
drop table t1;

#
# basic decremental update test for text
#
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(a int primary key, b tinyblob, c text, d mediumblob, e longtext);
insert into t1 values(1, repeat('~', 255), repeat('~', 65535), repeat('~', 16777215), repeat('~', 16777216));
insert into t1 values(2, repeat('~', 255), repeat('~', 65535), repeat('~', 16777215), repeat('~', 16777216));
insert into t1 values(3, repeat('~', 255), repeat('~', 65535), repeat('~', 16777215), repeat('~', 16777216));
insert into t1 values(4, repeat('~', 255), repeat('~', 65535), repeat('~', 16777215), repeat('~', 16777216));
select a, length(b), length(c), substr(c, 100, 3), length(d), substr(d, 1000000, 10), length(e), substr(e, 10000000, 5) from t1 order by a;
--let $loop=2
while ($loop)
{
  update t1 set b = substr(b, 1, length(b) / 2) where a = 1;
  update t1 set c = substr(c, 1, length(c) / 2) where a = 2;
  update t1 set d = substr(d, 1, length(d) / 2) where a = 3;
  update t1 set e = substr(e, 1, length(e) / 2) where a = 4;
  select a, length(b), length(c), length(d), length(e) from t1 order by a;
  dec $loop;
}

let $__table_id__=query_get_value(select /*+QUERY_TIMEOUT(10000000000)*/ table_id from oceanbase.__all_virtual_table where table_name='t1', table_id, 1);

disconnect obsys;
--source mysql_test/include/minorfreeze.inc
--real_sleep 10
--source mysql_test/include/wait_minor_merge.inc
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);

drop table t1;

#
# basic delete test for text/blob
#
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(a int primary key, b tinyblob, c text, d mediumblob, e longtext);
insert into t1 values(1, 'b', 'c', 'd', 'e');
insert into t1 values(2, 'bb', 'cc', 'dd', 'ee');
insert into t1 values(3, '', '', '', '');
insert into t1 values(4, null, null, null, null);
insert into t1 values(5, repeat('~', 10), repeat('~', 10), repeat('~', 16777215), repeat('~', 16777215));
select a, b, c, length(d), substr(d, 1000000, 10), length(e), substr(e, 10000000, 5) from t1 order by a;
delete from t1 where b is null;
select a, b, c, length(d), substr(d, 1000000, 10), length(e), substr(e, 10000000, 5) from t1 order by a;
delete from t1 where c like '%cc%';
select a, b, c, length(d), substr(d, 1000000, 10), length(e), substr(e, 10000000, 5) from t1 order by a;
delete from t1 where length(d) = 0;
select a, b, c, length(d), substr(d, 1000000, 10), length(e), substr(e, 10000000, 5) from t1 order by a;
delete from t1 where e < 'z';
select a, b, c, length(d), substr(d, 1000000, 10), length(e), substr(e, 10000000, 5) from t1 order by a;
drop table t1;

#
# large value insert test for text
#
--disable_warnings
drop table if exists t1,t2,t3,t4;
--enable_warnings
create table t1(a int primary key, b tinytext, c text, d mediumtext, e longtext);
create table t2(a int primary key, b tinyblob, c blob, d mediumblob, e longblob);
#length($b) == 256
--let $b=repeat('b', 255)
--disable_query_log
eval replace into t1 values(1, $b, $b, $b, $b);
eval replace into t2 values(1, $b, $b, $b, $b);
--enable_query_log
select a, length(b), length(c), length(d), length(e) from t1 order by a;
select a, length(b), length(c), length(d), length(e) from t2 order by a;
--let $c=repeat('c', 65535)
--disable_query_log
eval replace into t1 values(2, $b, $c, $c, $c);
eval replace into t2 values(2, $b, $c, $c, $c);
--enable_query_log
select a, length(b), length(c), length(d), length(e) from t1 order by a;
select a, length(b), length(c), length(d), length(e) from t2 order by a;
--let $d=repeat('d', 2097152)
--disable_query_log
eval replace into t1 values(3, $b, $c, $d, $d);
eval replace into t2 values(3, $b, $c, $d, $d);
--enable_query_log
select a, length(b), length(c), length(d), length(e) from t1 order by a;
select a, length(b), length(c), length(d), length(e) from t2 order by a;
--let $e=repeat('e', 8388608)
--disable_query_log
eval replace into t1 values(4, $b, $c, $d, $e);
eval replace into t2 values(4, $b, $c, $d, $e);
--enable_query_log
select a, length(b), length(c), length(d), length(e) from t1 order by a;
select a, length(b), length(c), length(d), length(e) from t2 order by a;
create table t3(b tinytext, c text, d mediumtext, e longtext);
create table t4(b tinyblob, c blob, d mediumblob, e longblob);
--disable_query_log
eval replace into t3 values($b, $c, $d, $e);
eval replace into t4 values($b, $c, $d, $e);
--enable_query_log
--let $loop=2
while ($loop)
{
  insert into t3 select * from t3;
  insert into t4 select * from t4;
  dec $loop;
  #select /*+read_consistency(weak)*/ count(1) from t3 order by b,c,d,e;
  #select /*+read_consistency(weak)*/ count(1) from t4 order by b,c,d,e;
  select  count(1) from t3;
  select  count(1) from t4;
}
drop table t1,t2,t3,t4;


## bugfix 
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(c1 MEDIUMTEXT NOT NULL);
insert ignore into t1 values(NULL);
select * from t1;

set sql_mode='';
CREATE TABLE IF NOT EXISTS lob_test (c2 TEXT NOT NULL);
insert into lob_test values(repeat('1', 10000));
select md5(c2) from lob_test;
UPDATE lob_test SET c2 = DEFAULT;
select md5(c2) from lob_test;
drop table lob_test;
set sql_mode=default;

## bugfix text column stat online gather
--disable_warnings
drop table if exists t1;
drop table if exists t2;
--enable_warnings
create table t1 (c1 text);
insert into t1 select randstr(20000, random()) c1 from table(generator(100));
create table t2 (c1 text);
insert/*+enable_parallel_dml parallel(4) */ into t2 select /*+ opt_param('rowsets_enabled', 'false') */ c1 from t1;
drop table t1;
drop table t2;

create table t1(c1 tinytext CHARSET gbk);
create table t2(c1 varchar(100));
insert into t1 values('1');
select * from t1;
insert t2 select c1 from t1;
select * from t2;
drop table t1;
drop table t2;

CREATE TABLE t1 (c1 decimal(29,5) PRIMARY KEY, c2 blob) LOB_INROW_THRESHOLD=0;
insert into t1 values (1, '');
select * from t1;
update t1 set c1 = 2, c2 = 'abc1' , c2 = 'xyzzz';
select * from t1;
drop table t1;

SET NAMES latin1 COLLATE latin1_swedish_ci;
create table t1 select 2 as a, concat(repeat('MySQL', 100 * 1024),  ';') as b;
select a, length(b), md5(b) from t1;
drop table t1;
SET NAMES utf8mb4;

--disable_query_log
set global max_allowed_packet=16777216;
set global ob_sql_work_area_percentage=5;
set @@recyclebin = on;
--enable_query_log
