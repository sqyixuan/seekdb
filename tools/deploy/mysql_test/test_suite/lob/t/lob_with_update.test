# owner: aozeliu.azl
# owner group: shenzhen
# description: test for lob column with update
# tags: blob,blob

--disable_query_log
set global max_allowed_packet=60000000;
set global ob_sql_work_area_percentage=80;
sleep 1;

connect (conn0,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,oceanbase,$OBMYSQL_PORT);
connect (conn1,$OBMYSQL_MS0,root@sys,,test,$OBMYSQL_PORT);

set @@session.explicit_defaults_for_timestamp=off;
set @@recyclebin = off;
set ob_query_timeout=1000000000;
set ob_trx_timeout=1000000000;
--enable_query_log

connection conn1;
create table if not exists blob_test_table(pk bigint auto_increment primary key, 
c1_longblob longblob,
c1_int int,
c2_longblob longblob,
c2_int int,
c3_longblob longblob,
c3_int int,
c4_longblob longblob,
c4_int int,
gmt_create  timestamp(6) NULL DEFAULT CURRENT_TIMESTAMP(6), 
gmt_modified timestamp(6) NULL DEFAULT CURRENT_TIMESTAMP(6) ON UPDATE CURRENT_TIMESTAMP(6));

connection conn0;
let $__table_id__=query_get_value(select /*+QUERY_TIMEOUT(10000000)*/ table_id from oceanbase.__all_virtual_table where table_name= 'blob_test_table', table_id, 1);
#alter system set minor_compact_trigger = 10;


connection conn1;
--disable_query_log
# insert rows
let $cnt = 0;
while ($cnt < 10)
{
  eval insert into blob_test_table(c1_int, c2_int, c3_int, c4_int, 
  c1_longblob,c2_longblob,c3_longblob,c4_longblob)
   values($cnt, $cnt, $cnt, $cnt, 
   repeat(concat(now(6), '?'),50000),
   repeat(concat(now(6), '?'),50000),
   repeat(concat(now(6), '?'),50000),
   repeat(concat(now(6), '?'),50000));
  inc $cnt;
}
--enable_query_log

connection conn0;
alter system minor freeze tenant = sys;
alter system minor freeze tenant = all_user;
alter system minor freeze tenant = all_meta;
--source mysql_test/include/wait_minor_merge.inc

connection conn1;
update blob_test_table set c1_longblob = repeat(concat(now(6), '*'),50000), 
  c3_longblob = repeat(concat(now(6), '$'),50000),
  c2_longblob = repeat(concat(now(6), '@'),50000),
  c4_longblob = repeat(concat(now(6), '#'),50000);
connection conn0;
alter system minor freeze tenant = sys;
alter system minor freeze tenant = all_user;
alter system minor freeze tenant = all_meta;
--source mysql_test/include/wait_minor_merge.inc

connection conn0;
alter system minor freeze tenant = sys;
alter system minor freeze tenant = all_user;
alter system minor freeze tenant = all_meta;
--source mysql_test/include/wait_minor_merge.inc

connection conn1;
select count(*) from blob_test_table where c1_longblob like "%*%";
select count(*) from blob_test_table where c2_longblob like "%@%";
select count(*) from blob_test_table where c3_longblob like "%$%";
select count(*) from blob_test_table where c4_longblob like "%#%";

connection conn1;
--disable_warnings
drop table if exists blob_test_table;
