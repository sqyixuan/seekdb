--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: luohongdi.lhd
# owner group: SQL1
# description: basic compare test for blob and text column
# tags: text,blob

#
# basic compare test for text/blob
#
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(a int primary key, b tinyblob, c text, d mediumblob, e longtext, f varchar(256), g varbinary(256));
insert into t1 values(1, '1', '1', '1', '1', '1', '1');
insert into t1 values(2, 'aa', 'aa', 'aa', 'aa', 'aa', 'aa');
insert into t1 values(3, '', '', '', '', '', '');
insert into t1 values(4, null, null, null, null, null, null);
insert into t1 values(5, '2', '2', '2', '2', '1', '1');
insert into t1 values(6, 'aa', 'aa', 'aa', 'aa', 'bb', 'bb');
insert into t1 values(7, 'hello', 'hello', 'hello', 'hello', 'hello', 'hello');
insert into t1 values(8, 'HELLO', 'HELLO', 'HELLO', 'HELLO', 'HELLO', 'HELLO');
insert into t1 values(9, 'HELLO OB', 'HELLO OB', 'HELLO OB', 'HELLO OB', 'HELLO OB', 'HELLO OB');
insert into t1 values(10, 'OB HELLO', 'OB HELLO', 'OB HELLO', 'OB HELLO', 'OB HELLO', 'OB HELLO');
insert into t1 values(11, 'HeLlO', 'HeLlO', 'HeLlO', 'HeLlO', 'HeLlO', 'HeLlO');

select * from t1 where b=g and c=f and d=g and e=f order by a;
select * from t1 where b<g and c<f and d<g and e<f order by a;
select * from t1 where b<>g and c<>f and d<>g and e<>f order by a;
select * from t1 where b>f and c>g and d>f and e>g order by a;
select * from t1 where b>a or c>f or d<g or e is null order by a;
select * from t1 where b > 0 and c > '0' order by a;
select * from t1 where d < 'cc' and length(e) > 1 order by a;
select * from t1 where c > 'hello' and b like 'HE%' order by a;
select * from t1 where b < 'hello' and c like '%OB' order by a;
select * from t1 where c not like '%hello%' order by a;
select * from t1 where e not like '%hello%' order by a;
select * from t1 where c > 'hello' and b like binary 'HE%' order by a;
select * from t1 where b < 'hello' and c like binary '%OB' order by a;
select * from t1 where c not like binary '%hello%' order by a;
select * from t1 where e not like binary '%hello%' order by a;

select * from t1 where c = 'hello' order by a;
select * from t1 where c = 'hello ' order by a;
select * from t1 where c = 'hELLo ' order by a;
select * from t1 where c = ' hello' order by a;
select * from t1 where c between 'hello' and 'hello ob' order by a;
select * from t1 where instr(c, 'ob') > 1 order by a;
select a, strcmp(b,f), strcmp(d,f), strcmp(c,f), strcmp(e,f) from t1 order by a;
select a, strcmp(b,f), strcmp(c,d), strcmp(e,g) from t1 order by a;
select * from t1 where b < 2 and c > -1 order by a;
select * from t1 where e < 2.0 and d > -1.23 order by a;
select * from t1 where c < hex(123) order by a;
drop table t1;

#
# basic compare test for text/blob in chinese
#
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(a int primary key, b tinytext, c text, d mediumtext, e longtext, f varchar(256), g varbinary(256));
insert into t1 values(1, '1', '1', '1', '1', '2', '3');
insert into t1 values(2, 'aa', 'aa', 'aa', 'aa', 'bb', 'cc');
insert into t1 values(3, '', '', '', '', '', '');
insert into t1 values(4, null, null, null, null, null, null);
insert into t1 values(5, '世界', '世界', '世界', '世界', '和平', '和平');
insert into t1 values(6, '自由', '自由', '自由', '自由', '平等', '平等');
insert into t1 values(7, '世界和平', '世界和平', '世界和平', '世界和平', '世界和平', '世界和平');
insert into t1 values(8, '世界和平么', '世界和平么', '世界和平么', '世界和平么', '世界和平么', '世界和平么');
insert into t1 values(9, ' 世界不会和平么 ', ' 世界不会和平么 ', ' 世界不会和平么 ', ' 世界不会和平么 ', ' 世界不会和平么 ', ' 世界不会和平么 ');
insert into t1 values(10, 'OB世界和平OB', 'OB世界和平OB', 'OB世界和平OB', 'OB世界和平OB', 'OB世界和平OB', 'OB世界和平OB');
insert into t1 values(11, '世界OB→和平', '世界OB→和平', '世界OB→和平', '世界OB→和平', '世界OB→和平', '世界OB→和平');

select * from t1 where b=g and c=f and d=g and e=f order by a;
select * from t1 where b<g and c<f and d<g and e<f order by a;
select * from t1 where b<>g and c<>f and d<>g and e<>f order by a;
select * from t1 where b>f and c>g and d>f and e>g order by a;
select * from t1 where b>a or c>f or d<g or e is null order by a;
select * from t1 where b > 0 and c > '0' order by a;
select * from t1 where d < '世界和平' and length(e) > 1 order by a;
select * from t1 where c > '和平' and b like 'HE%' order by a;
select * from t1 where b < '和平' and c like '%OB' order by a;
select * from t1 where c not like '%和平%' order by a;
select * from t1 where e not like '%和平%' order by a;
select * from t1 where c = '自由' order by a;
select * from t1 where c = '自由 ' order by a;
select * from t1 where c = '自由 ' order by a;
select * from t1 where c = ' 自由' order by a;
select * from t1 where c between '世界' and '自由' order by a;
select * from t1 where instr(c, 'ob') > 1 order by a;
select a, strcmp(b,f), strcmp(d,f), strcmp(c,f), strcmp(e,f) from t1 order by a;
select a, strcmp(b,f), strcmp(c,d), strcmp(e,g) from t1 order by a;
select * from t1 where b < 2 and c > -1 order by a;
select * from t1 where e < 2.0 and d > -1.23 order by a;
select * from t1 where c < hex(123) order by a;
drop table t1;

create table t1(c3 text, c4 tinytext) lob_inrow_threshold=0 block_size=1024;
insert into t1 select repeat('a', 100), repeat('a', 100) from table(generator(1000));
alter system major freeze;
--source mysql_test/include/wait_daily_merge.inc
select count(*) from t1 WHERE c4 <= (SELECT c3 FROM t1 ORDER BY 1 LIMIT 1);
drop table t1;