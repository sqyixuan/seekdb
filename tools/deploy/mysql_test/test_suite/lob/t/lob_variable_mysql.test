# owner: aozeliu.azl
# description: test lob column into user variable
# tags: text,blob

set ob_default_lob_inrow_threshold=0;
--disable_warnings
drop table if exists lob_test_t;
--enable_warnings
set @lob_var = '';
select length(@lob_var), md5(@lob_var);

# text
create table lob_test_t(pk int primary key, c1 longtext, c2 varchar(100));
insert into lob_test_t values(1, repeat('1', 1001000), '111111');

# sql
set @lob_var = '';
select c1 into @lob_var from lob_test_t;
select length(@lob_var), md5(@lob_var);

# pl
set @lob_var = '';
drop PROCEDURE if exists mylobProcedure;
DELIMITER //;
create PROCEDURE mylobProcedure()
BEGIN
SELECT c1 into @lob_var From lob_test_t;
select length(@lob_var), md5(@lob_var);
END
//
DELIMITER ;//
call mylobProcedure();
drop PROCEDURE mylobProcedure;
drop table lob_test_t;


# blob
create table lob_test_t(pk int primary key, c1 longblob, c2 varchar(100));
insert into lob_test_t values(1, unhex('000000000104000000040000000101000000000000000000F03F000000000000F03F010100000000000000000026400000000000002640010100000000000000000026400000000000003540010100000000000000000035400000000000003540'), '111111');

# sql
set @lob_var = '';
select c1 into @lob_var from lob_test_t;
select length(@lob_var), md5(@lob_var);

# pl
set @lob_var = '';
drop PROCEDURE if exists mylobProcedure;
DELIMITER //;
create PROCEDURE mylobProcedure()
BEGIN
SELECT c1 into @lob_var From lob_test_t;
select length(@lob_var), md5(@lob_var);
END
//
DELIMITER ;//
call mylobProcedure();
drop PROCEDURE mylobProcedure;
drop table lob_test_t;


