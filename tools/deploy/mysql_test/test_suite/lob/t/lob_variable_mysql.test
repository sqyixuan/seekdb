create table lob_test_t(pk int primary key, c1 longtext, c2 varchar(100));
insert into lob_test_t values(1, repeat('1', 1001), '111111');
select c1 into @lob_var from lob_test_t;
create table lob_test_t_2(c0 longtext);
prepare ps_t from 'insert into lob_test_t_2 values(?)';
execute ps_t using @lob_var;
select length(c0), md5(c0) from lob_test_t_2;
select params_value from oceanbase.gv$ob_sql_audit where query_sql='insert into lob_test_t_2 values(?)';

drop table lob_test_t;
drop table lob_test_t_2;


# mutli set
create table lob_test_t(pk int primary key, c1 geometry, c2 varchar(100), c3 longtext, c4 json, c5 longblob);

insert into lob_test_t values(1, ST_GeomFromText('MULTIPOINT(1 1, 11 11, 11 21, 21 21)'), '111111', repeat('1', 1001), json_object('k1', repeat('1', 1000)), 'xyz123xyzzzzzzzzz');

SELECT pk, c1, c2, c3, c4, c5 into @lob_var_0, @lob_var_1, @lob_var_2, @lob_var_3, @lob_var_4, @lob_var_5  From lob_test_t;
select length(@lob_var_0), md5(@lob_var_0);
select length(@lob_var_1), md5(@lob_var_1);
select length(@lob_var_2), md5(@lob_var_2);
select length(@lob_var_3), md5(@lob_var_3);
select length(@lob_var_4), md5(@lob_var_4);
select length(@lob_var_5), md5(@lob_var_5);

set @lob_var_0 = '', @lob_var_1 = '', @lob_var_2 = '', @lob_var_3 = '';
DELIMITER //;
create PROCEDURE mylobProcedure()
BEGIN
SELECT pk, c1, c2, c3, c4, c5 into @lob_var_0, @lob_var_1, @lob_var_2, @lob_var_3, @lob_var_4, @lob_var_5  From lob_test_t;
select length(@lob_var_0), md5(@lob_var_0);
select length(@lob_var_1), md5(@lob_var_1);
select length(@lob_var_2), md5(@lob_var_2);
select length(@lob_var_3), md5(@lob_var_3);
select length(@lob_var_4), md5(@lob_var_4);
select length(@lob_var_5), md5(@lob_var_5);
END //
DELIMITER ;//
call mylobProcedure();
drop PROCEDURE mylobProcedure;
drop table lob_test_t;


create table lob_test_t(pk int primary key, c1 longtext, c2 varchar(100));
set @lob_var = '';
select length(@lob_var), md5(@lob_var), @lob_var;
begin;
insert into lob_test_t values(1, repeat('a', 11), '111111');
select c1 into @lob_var from lob_test_t;
rollback;
drop table lob_test_t;
commit;
select length(@lob_var), md5(@lob_var), @lob_var;

create table lob_test_t(c1 int, c2 longtext) lob_inrow_threshold = 10;
insert into lob_test_t values(1, repeat('a', 2));
set @lob_var1 = (select c2 from lob_test_t where c1 = 1);
select @lob_var1;
insert into lob_test_t values(2, repeat('a', 100));
set @lob_var1 = (select c2 from lob_test_t where c1 = 2);
select @lob_var1;
drop table lob_test_t;
