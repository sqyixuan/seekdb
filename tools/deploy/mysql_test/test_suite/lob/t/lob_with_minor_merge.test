# owner: lixia.yq
# owner group: storage
# description: test for lob column with minor merge
# tags: text,blob

--disable_query_log
set global max_allowed_packet=60000000;
set global ob_sql_work_area_percentage=80;
sleep 1;

connect (conn0,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,oceanbase,$OBMYSQL_PORT);
connect (conn1,$OBMYSQL_MS0,admin@sys,admin,test,$OBMYSQL_PORT);

set @@session.explicit_defaults_for_timestamp=off;
set @@recyclebin = off;
set ob_query_timeout=1000000000;
set ob_trx_timeout=1000000000;
--enable_query_log

connection conn1;
create table if not exists blob_test_table(pk bigint auto_increment primary key,
c1_blob blob, c2_text text, c3_longblob longblob, c4_longtext longtext,
c1_md5 varchar(1024),c2_md5 varchar(1024),c3_md5 varchar(1024),c4_md5 varchar(1024),
gmt_create  timestamp(6) NULL DEFAULT CURRENT_TIMESTAMP(6),
gmt_modified timestamp(6) NULL DEFAULT CURRENT_TIMESTAMP(6) ON UPDATE CURRENT_TIMESTAMP(6));

connection conn0;
let $__tenant_id__=query_get_value(select /*+QUERY_TIMEOUT(10000000)*/ tenant_id from oceanbase.__all_virtual_table where table_name= 'blob_test_table', tenant_id, 1);
let $__table_id__=query_get_value(select /*+QUERY_TIMEOUT(10000000)*/ table_id from oceanbase.__all_virtual_table where table_name= 'blob_test_table', table_id, 1);

connection conn1;
--disable_query_log
# insert rows
let $cnt = 0;
while ($cnt < 20)
{
  eval insert into blob_test_table(c1_blob,c2_text,c3_longblob,c4_longtext,c1_md5,c2_md5,c3_md5,c4_md5) values(
            repeat(concat(now(6), '?'),1984),repeat(concat(now(6), '?'),1984),repeat(concat(now(6), '?'),50000),
            repeat(concat(now(6), '?'),50000),md5(c1_blob),md5(c2_text),md5(c3_longblob),md5(c4_longtext));
  inc $cnt;
}
--enable_query_log

connection conn1;
alter system minor freeze;
--source mysql_test/include/wait_minor_merge.inc

connection conn1;
--disable_query_log
# insert rows
let $cnt = 0;
while ($cnt < 20)
{
  eval insert into blob_test_table(c1_blob,c2_text,c3_longblob,c4_longtext,c1_md5,c2_md5,c3_md5,c4_md5) values(
            repeat(concat(now(6), '?'),1984),repeat(concat(now(6), '?'),1984),repeat(concat(now(6), '?'),50000),
            repeat(concat(now(6), '?'),50000),md5(c1_blob),md5(c2_text),md5(c3_longblob),md5(c4_longtext));
  inc $cnt;
}
--enable_query_log

connection conn1;
alter system minor freeze;
--source mysql_test/include/wait_minor_merge.inc
sleep 10;

connection conn1;
let $__now_time__ = query_get_value(select now() as c, c, 1);
alter system set minor_compact_trigger = 1;
--source mysql_test/include/wait_mini_minor_merge_for_table.inc

--disable_query_log
connection conn1;
# insert rows
let $cnt = 0;
while ($cnt < 10)
{
  eval insert into blob_test_table(c1_blob,c2_text,c3_longblob,c4_longtext,c1_md5,c2_md5,c3_md5,c4_md5) values(
            repeat(concat(now(6), '?'),1984),repeat(concat(now(6), '?'),1984),repeat(concat(now(6), '?'),50000),
            repeat(concat(now(6), '?'),50000),md5(c1_blob),md5(c2_text),md5(c3_longblob),md5(c4_longtext));
  inc $cnt;
}
--enable_query_log

connection conn1;
alter system major freeze;
--source mysql_test/include/wait_daily_merge.inc

connection conn1;
--disable_query_log
let $cnt = 0;
while ($cnt < 10)
{
  eval insert into blob_test_table(c1_blob,c2_text,c3_longblob,c4_longtext,c1_md5,c2_md5,c3_md5,c4_md5) values(
            repeat(concat(now(6), '?'),1984),repeat(concat(now(6), '?'),1994),repeat(concat(now(6), '?'),50000),
            repeat(concat(now(6), '?'),50000),md5(c1_blob),md5(c2_text),md5(c3_longblob),md5(c4_longtext));
  inc $cnt;
}
--enable_query_log

#should be 50
select count(*) from blob_test_table where length(c1_blob) = length(c2_text);

connection conn1;
--disable_warnings
drop table if exists blob_test_table;
alter system set minor_compact_trigger = 2;