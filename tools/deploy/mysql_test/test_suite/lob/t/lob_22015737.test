--disable_query_log
set global max_allowed_packet=60000000;
set global ob_sql_work_area_percentage=90;
set @@session.explicit_defaults_for_timestamp=off;
disconnect default;
sleep 1;
connect (default,$OBMYSQL_MS0,admin,admin,test,$OBMYSQL_PORT);
set @@session.explicit_defaults_for_timestamp=off;
set @@recyclebin = off;
set ob_query_timeout=1000000000;
set ob_trx_timeout=1000000000;
--enable_query_log
# owner: luohongdi.lhd
# owner group: storage2
# description: test for blob and text column after daily merge
# tags: text,blob

--disable_warnings
drop table if exists lob_bug_22015737;
--enable_warnings
create table lob_bug_22015737(a int, b int, c longtext, index i1 (b));

insert into lob_bug_22015737 values(1, 1, 'aaa');
insert into lob_bug_22015737 values(2, 2, 'aaa');
insert into lob_bug_22015737 values(3, 3, 'aaa');
insert into lob_bug_22015737 values(4, 4, 'aaa');
insert into lob_bug_22015737 select * from lob_bug_22015737;
insert into lob_bug_22015737 select * from lob_bug_22015737;
insert into lob_bug_22015737 select * from lob_bug_22015737;
insert into lob_bug_22015737 select * from lob_bug_22015737;
insert into lob_bug_22015737 select * from lob_bug_22015737;
insert into lob_bug_22015737 select * from lob_bug_22015737;
insert into lob_bug_22015737 select * from lob_bug_22015737;
insert into lob_bug_22015737 select * from lob_bug_22015737;
insert into lob_bug_22015737 select * from lob_bug_22015737;
insert into lob_bug_22015737 values(5, 5, repeat('a', 10000000));
insert into lob_bug_22015737 values(6, 6, repeat('a', 10000000));

--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc

select /*+INDEX(lob_bug_22015737 i1)*/ a,b,length(c) from lob_bug_22015737 where a <=6 and b > 0 order by b;

--disable_query_log
set global max_allowed_packet=16777216;
set global ob_sql_work_area_percentage=5;
