#owner: aozeliu.azl
#owner group: shenzhen
--echo # ----------------------------------------------------------------------
--echo # Test Lob concat expr in mysql mode
--echo # ----------------------------------------------------------------------

--disable_warnings
drop table if exists t1;
drop table if exists t2;
drop table if exists t3;
drop table if exists t4;
drop table if exists t5;
drop table if exists t6;
--enable_warnings

create table t1 (pk int primary key, c1 longtext, c2 text, c3 varchar(65535));
insert into t1 values('1', null, null, '');
insert into t1 values('2', '', null, null);
insert into t1 values('3', repeat('3', 1024), repeat('3', 10000), repeat('3', 6666));
insert into t1 values('4', repeat('4', 3 * 1024 * 1024), repeat('4', 1024), repeat('3', 5555));

# test user case
select pk, md5(concat_ws(',', pk, c1)) from t1;

# test larger result
select pk, md5(concat_ws(',', ',', pk, c1, c1, c1,c1,c1,c1,c1,c1,c1,c1,c1,c1,c1,c1,c1,c1,c1,c1,c1,c1,c1,c1,c1,c1,c1,c1,c1,c1,c1,c1,c1,c1,c1,c1,c1,c1,c1,c1,c1,c1,c1,c1,c1,c1,c1,c1,c1,c1)) from t1;

# test sep is null
select pk, md5(concat_ws(null, 'x', c1, c1)) from t1;
select pk, md5(concat_ws(null, ',', pk, c1)) from t1;

# test word is null
select pk, md5(concat_ws(',', 'x', c1, null)) from t1;
select pk, md5(concat_ws(',', null, c1, null)) from t1;
select pk, md5(concat_ws(c1, null)) from t1;

# test persist inrow/outrow
select pk, md5(concat_ws(',', 'x', c1, c2)) from t1;
select pk, md5(concat_ws(',', 'x', c2, c1)) from t1;

# test persist inrow/outrow and temp inrow
select pk, md5(concat_ws(',', 'x', c1, c2, repeat('1', 10000))) from t1;

# test persist inrow/outrow and varchar
select pk, md5(concat_ws(',', 'x', c1, c2, repeat('1', 10000), c3)) from t1;

drop table t1;
# test create table type
create table t1 (pk int primary key, c1 text);
create table t2 as select concat_ws(',', c1, 'a') from t1;
SELECT data_type, character_octet_length, character_maximum_length FROM information_schema.columns where table_name='t2';
drop table t1;
drop table t2;

create table t3 (pk int primary key, c1 text);
desc t3;

create table t4 as select concat_ws(c1, 'x', 'a') from t3;
desc t4;

create table t5 as select concat_ws(null, c1, 'a') from t3;
desc t5;

create table t6 as select concat_ws(',', c1, 'a') from t3;
desc t6;

drop table t3;
drop table t4;
drop table t5;
drop table t6;
