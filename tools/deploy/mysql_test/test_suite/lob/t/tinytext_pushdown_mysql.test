#owner: aozeliu.azl
#owner group: shenzhen
#tags: text,lob

--result_format 4
--explain_protocol 0
--disable_query_log
connect (syscon, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection syscon;
alter system set ob_compaction_schedule_interval = '3s';
--sleep 2
connection default;

--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1 (c1 int auto_increment primary key, c2 bigint, c3 mediumtext, c4 tinytext)  row_format = compressed block_size = 2048;

--let $loop=200
while($loop > 0)
{
  eval insert into t1 (c2, c3, c4) values ($loop, repeat('a', 100), repeat('a', 100));
  dec $loop;
}

alter system major freeze;
connection syscon;
--source mysql_test/include/wait_daily_merge.inc
connection default;

--enable_query_log
# mediumtext compare tinytext
select count(*) from t1 WHERE c3 <= (SELECT c4 FROM t1 ORDER BY 1 LIMIT 1);
SELECT c4 FROM t1 WHERE c3 <= (SELECT c4 FROM t1 ORDER BY 1 LIMIT 1);
# tinytext compare mediumtext. use strcmp just compare raw data wtih lob header. is bug ?
select count(*) from t1 WHERE c4 <= (SELECT c3 FROM t1 ORDER BY 1 LIMIT 1);
SELECT c4 FROM t1 WHERE c4 <= (SELECT c3 FROM t1 ORDER BY 1 LIMIT 1);


#drop table t1;

--enable_warnings
--disable_query_log
connection syscon;
--enable_query_log
