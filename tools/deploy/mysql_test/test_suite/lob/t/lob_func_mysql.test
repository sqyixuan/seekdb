--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: luohongdi.lhd
# owner group: SQL1
# description: basic operator test for blob and text column
# tags: text,blob

#
# basic string func test for text
#
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(a int primary key, b tinytext, c text, d mediumtext, e longtext);

insert into t1 values(1, '1', '1', '1', '1');
insert into t1 values(2, 'aa', 'aa', 'aa', 'aa');
insert into t1 values(3, '', '', '', '');
insert into t1 values(4, null, null, null, null);
insert into t1 values(5, '2  ', '2  ', '2  ', '2  ');
insert into t1 values(6, '  aa  ', '  aa  ', '  aa  ', '  aa  ');
insert into t1 values(7, 'hello', 'hello', 'hello', 'hello');
insert into t1 values(8, 'HELLO', 'HELLO', 'HELLO', 'HELLO');
insert into t1 values(9, '世界和平', '世界和平', '世界和平', '世界和平');
insert into t1 values(10, 'OB世界和平OB', 'OB世界和平OB', 'OB世界和平OB', 'OB世界和平OB');
insert into t1 values(11, '世界OB→和平', '世界OB→和平', '世界OB→和平', '世界OB→和平');

select a, length(b), length(c), length(d), length(e) from t1 order by a;
select a, char_length(b), char_length(c), char_length(d), char_length(e) from t1 order by a;
select a, reverse(b), reverse(c), reverse(d), reverse(e) from t1 order by a;
select a, upper(b), upper(c), upper(d), upper(e) from t1 order by a;
select a, lower(b), lower(c), lower(d), lower(e) from t1 order by a;
select a, substr(b, 1, 3), substr(c, 1, 3), substr(d, 1, 3), substr(e, 1, 3) from t1 order by a;
select a, right(b, 3), right(c, 3), right(d, 3), right(e, 3) from t1 order by a;
select a, left(b, 3), left(c, 3), left(d, 3), left(e, 3) from t1 order by a;
select a, trim(b), trim(c), trim(d), trim(e) from t1 order by a;
drop table t1;

#
# basic string func test for blob
#
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(a int primary key, b tinyblob, c blob, d mediumblob, e longblob);

insert into t1 values(1, '1', '1', '1', '1');
insert into t1 values(2, 'aa', 'aa', 'aa', 'aa');
insert into t1 values(3, '', '', '', '');
insert into t1 values(4, null, null, null, null);
insert into t1 values(5, '2  ', '2  ', '2  ', '2  ');
insert into t1 values(6, '  aa  ', '  aa  ', '  aa  ', '  aa  ');
insert into t1 values(7, 'hello', 'hello', 'hello', 'hello');
insert into t1 values(8, 'HELLO', 'HELLO', 'HELLO', 'HELLO');

select a, length(b), length(c), length(d), length(e) from t1 order by a;
select a, char_length(b), char_length(c), char_length(d), char_length(e) from t1 order by a;
select a, reverse(b), reverse(c), reverse(d), reverse(e) from t1 order by a;
select a, upper(b), upper(c), upper(d), upper(e) from t1 order by a;
select a, lower(b), lower(c), lower(d), lower(e) from t1 order by a;
select a, substr(b, 1, 3), substr(c, 1, 3), substr(d, 1, 3), substr(e, 1, 3) from t1 order by a;
select a, right(b, 3), right(c, 3), right(d, 3), right(e, 3) from t1 order by a;
select a, left(b, 3), left(c, 3), left(d, 3), left(e, 3) from t1 order by a;
select a, trim(b), trim(c), trim(d), trim(e) from t1 order by a;
drop table t1;

--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1 (c1 int primary key, c2 longtext);
insert into t1 values (1, 'abcdefg');
insert into t1 values (2, 'Lob测试');
insert into t1 values (3, lpad('test', 10000, 'abc'));
insert into t1 values (4, rpad('test', 10000, 'abc'));
select c1, reverse(c2) from t1 where c1 < 3 order by c1;
select c1, substr(c2, 1, 50) from t1 where c1 = 3;
select c1, substr(c2, -50) from t1 where c1 = 3;

select c1, substr(reverse(c2), 1, 50) from t1 where c1 = 3;
select c1, substr(reverse(c2), -50) from t1 where c1 = 3;

drop table t1;

--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1 (c1 int primary key, c2 tinytext);
insert into t1 values (1, 'abcdefg');
insert into t1 values (2, 'Lob测试');
insert into t1 values (3, lpad('test', 60, 'abc'));
insert into t1 values (4, rpad('test', 60, 'abc'));
select c1, reverse(c2) from t1 where c1 < 3 order by c1;
select c1, substr(c2, 0, 50) from t1 where c1 = 3;
select c1, substr(c2, 1, 50) from t1 where c1 = 3;
select c1, substr(c2, -50) from t1 where c1 = 3;

select c1, substr(reverse(c2), 1, 50) from t1 where c1 = 3;
select c1, substr(reverse(c2), -50) from t1 where c1 = 3;

drop table t1;

--disable_warnings
drop table if exists t2;
--enable_warnings
create table t2(c1 int primary key, c2 tinytext, c3 tinytext);
insert into t2 values(1, 'www.tcx.se', 'www.tcx.se');
insert into t2 values(2, '.tcx.se', '.tcx.se');
insert into t2 values(3, 'the king of the  the hill', 'the king of the  the hill');

select substring_index(c2,'.',-2),substring_index(c2,'.',1) from t2 where c1 = 1;
select substring_index(c2,'tcx',1),substring_index(c2,'tcx',-1) from t2  where c1 = 1;
select substring_index(c2,'.',-2),substring_index(c2,'.tcx',-1) from t2  where c1 = 2;

select substring_index(c2,' the ',-1) from t2 where c1 = 3;
select substring_index(c2,' the ',-2) from t2 where c1 = 3;
select substring_index(c2,' the ',-3) from t2 where c1 = 3;

select substring_index(c2,' the ',1) from t2 where c1 = 3;
select substring_index(c2,' the ',2) from t2 where c1 = 3;
select substring_index(c2,' the ',3) from t2 where c1 = 3;

select substring_index(c2,' ',-1) from t2 where c1 = 3;
select substring_index(c2,' ',-2) from t2 where c1 = 3;
select substring_index(c2,' ',-3) from t2 where c1 = 3;


select substring_index(c3,'.',-2),substring_index(c3,'.',1) from t2 where c1 = 1;
select substring_index(c3,'tcx',1),substring_index(c3,'tcx',-1) from t2 where c1 = 1;
select substring_index(c3,'.',-2),substring_index(c3,'.tcx',-1) from t2 where c1 = 2;

select substring_index(c3,' the ',-1) from t2 where c1 = 3;
select substring_index(c3,' the ',-2) from t2 where c1 = 3;
select substring_index(c3,' the ',-3) from t2 where c1 = 3;

select substring_index(c3,' the ',1) from t2 where c1 = 3;
select substring_index(c3,' the ',2) from t2 where c1 = 3;
select substring_index(c3,' the ',3) from t2 where c1 = 3;

select substring_index(c3,' ',-1) from t2 where c1 = 3;
select substring_index(c3,' ',-2) from t2 where c1 = 3;
select substring_index(c3,' ',-3) from t2 where c1 = 3;


select substring_index('www.tcx.se','.',-2),substring_index('www.tcx.se','.',1);
select substring_index('www.tcx.se','tcx',1),substring_index('www.tcx.se','tcx',-1);
select substring_index('.tcx.se','.',-2),substring_index('.tcx.se','.tcx',-1);

select substring_index('the king of the  the hill',' the ',-1);
select substring_index('the king of the  the hill',' the ',-2);
select substring_index('the king of the  the hill',' the ',-3);

select substring_index('the king of the  the hill',' the ',1);
select substring_index('the king of the  the hill',' the ',2);
select substring_index('the king of the  the hill',' the ',3);

select substring_index('the king of the  the hill',' ',-1);
select substring_index('the king of the  the hill',' ',-2);
select substring_index('the king of the  the hill',' ',-3);

drop table t2;

--disable_warnings
drop table if exists t0, t1;
--enable_warnings
# tiny
create table t0(c1 int primary key, c2 tinytext);
insert into t0 values(1, repeat('abcdefg', 10));

select instr(c2, 'efg') from t0;

select concat_ws('-', c2, c2) from t0;

insert into t0 values(2, '#3556 in bugdb');
select soundex(c2) from t0 where c1=2;


# other
create table t1(c1 int primary key, c2 longtext);
insert into t1 values(1, repeat('abcdefg', 100));
select instr(c2, 'efg') from t1;

select concat_ws('-', c2, c2) from t1;

insert into t1 values(2, '#3556 in bugdb');
select soundex(c2) from t1 where c1=2;

drop table t0, t1;

## bugfix#issue/47608475
create table t1(c1 bit(24));
create table t2(c1 text);
insert into t2 values('6164');
(select c1 from t1) union (select unhex(c1) from t2);
(select c1 from t1) union (select reverse(c1) from t2);
drop table t1;

## bugfix#issue/48312197
--disable_warnings
CREATE TABLE t0(c0 LONGTEXT );
CREATE TABLE t1(c0 INT ZEROFILL) ;
INSERT INTO t1(c0) VALUES(2);
INSERT INTO t0(c0) VALUES(1),('    1k');
REPLACE INTO t0(c0) select c0 from t1;
SELECT * from t0;
SELECT * from t0 where c0;
drop table t0, t1;
--enable_warnings

## bugfix#issue/49757950
--disable_warnings
DROP TABLE IF exists T0;
DROP TABLE IF exists T1;
--enable_warnings
CREATE TABLE t0(c0 TINYINT ZEROFILL  COMMENT 'asdf' , c1 DECIMAL(44, 0) ZEROFILL  COMMENT 'asdf'  UNIQUE KEY, c2 MEDIUMTEXT , c3 SMALLINT(213)  COMMENT 'asdf' , c4 TEXT  COMMENT 'asdf'  NULL)  BLOCK_SIZE =  32768 , AUTO_INCREMENT = 6254498573763272 TABLE_MODE = 'QUEUING' ;
CREATE TABLE t1(c0 INT   COMMENT 'asdf' , c1 DOUBLE ZEROFILL  NULL COMMENT 'asdf' , c2 SMALLINT(164) ZEROFILL , c3 DECIMAL(52, 0)   COMMENT 'asdf' , c4 FLOAT ZEROFILL )  PARTITION BY HASH(c2)  SUBPARTITION BY KEY (c3, c2, c0, c1) subpartitions 14 partitions 19;
REPLACE INTO t0(c1, c4, c3, c2) select c1, c4, c3, c2 from t0 ORDER BY RAND() limit 3;
REPLACE INTO t0(c3) VALUES(48);
REPLACE INTO t0(c2, c3, c1, c4, c0) VALUES('b-4~?RfHpa[&?+GFv%*OqH0hs5}', 27, 3.3112275132548264E16, "", 3);
REPLACE INTO t1(c1) VALUES(7.92893965E8), (2.06357055E8), (48.0);
DELETE FROM t1 WHERE t1.c3;
INSERT /*+parallel(5) enable_parallel_dml GATHER_OPTIMIZER_STATISTICS */ INTO t1(c3) VALUES(2.3114387828360786E18);
INSERT /*+NO_GATHER_OPTIMIZER_STATISTICS parallel(10) enable_parallel_dml */ INTO t0(c3) VALUES(60) ON DUPLICATE KEY UPDATE c3=5;
REPLACE INTO t1(c4, c3, c1, c0) VALUES(57.0, -2.21991891950446336E18, 50.0, 313575620);
INSERT /*+NO_GATHER_OPTIMIZER_STATISTICS */ INTO t0(c4, c0, c3, c1) VALUES("77", 3, 47, 3.5156651961280584E16), ("-101", 2, -30, 3.1206638723432036E16) ON DUPLICATE KEY UPDATE c2="<*7sQy?n";
INSERT /*+parallel(8) enable_parallel_dml GATHER_OPTIMIZER_STATISTICS */ INTO t1(c2, c3, c0, c4, c1) VALUES(1, 1.63971049888435584E17, -712779253, 1.664688174E9, 60.0);
SELECT /*+ USE_MERGE (t1) */ concat(t0.c0,'') FROM t0, t1 WHERE ((concat(t1.c2,'')) = (t0.c4)) AND ((+ (t0.c4)));
drop table t0, t1;

create table t1(c1 longtext CHARACTER SET latin1 DEFAULT NULL);
insert into t1 values(repeat('a', 3*1024*1024));
insert into t1 values(repeat('a', 1024));
select md5(upper(c1)) from t1;
select /*+ opt_param('enable_rich_vector_format', 'true') */ length(upper(c1)) from t1;
select md5(lower(c1)) from t1;
select /*+ opt_param('enable_rich_vector_format', 'true') */ length(lower(c1)) from t1;
drop table t1;
