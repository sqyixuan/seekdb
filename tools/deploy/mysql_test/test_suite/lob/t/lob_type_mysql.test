--disable_warnings
drop table if exists cc_tdatasource;
drop FUNCTION if exists `nlnull`;
--enable_warnings
CREATE TABLE `cc_tdatasource` (
`VC_TENANT_ID` varchar(32) CHARACTER SET utf8mb4 COLLATE utf8mb4_bin NOT NULL COMMENT '租户ID',
`L_FILE_IMP_VERSION` decimal(10,0) DEFAULT NULL COMMENT '文件导入小版本号'
);
insert into cc_tdatasource values("1002", 11111);
insert into cc_tdatasource values("1003", null);
delimiter /;
CREATE FUNCTION `nlnull`(str1 TINYTEXT, str2 TINYTEXT) RETURNS tinytext CHARSET utf8mb4 COLLATE utf8mb4_bin
DETERMINISTIC
begin
declare c TINYTEXT;
select case when str1 is null then str2 when str1 = ' ' then str2 else str1 end into c;
return c;
end
/
delimiter ;/

select nlnull(l_file_imp_version,'0') from cc_tdatasource;
drop FUNCTION `nlnull`;
drop table cc_tdatasource;

create table t1(pk int primary key, c_lob longtext);
insert into t1 values(1, 'a');
insert into t1 values(2, 'a');
insert into t1 values(3, 'b');
insert into t1 values(4, 'b');
select distinct c_lob from t1;
select distinct pk, c_lob from t1;
select * from t1 order by c_lob;
select * from t1 order by pk, c_lob;
select count(*) from t1 group by c_lob;
select count(*) from t1 group by pk, c_lob;

drop table t1;