--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
set @@recyclebin = off;
--enable_query_log
# owner: luohongdi.lhd
# owner group: SQL1
# description: basic type test for blob and text column
# tags: text,blob

#
# Check syntax for creating blob/text
#
--disable_warnings
drop table if exists t1,t2,t3,t4;
--enable_warnings
create table t1 (a text, b text(32), c text(256), d text(65536), e text(10240));
show full columns from t1;
create table t2 (a blob, b blob(255), c blob(257), d blob(65537), e blob(262145));
show full columns from t2;
create table t3 (a tinytext, b text, c mediumtext, d longtext);
show full columns from t3;
create table t4 (a tinyblob, b blob, c mediumblob, d longblob);
show full columns from t4;
drop table t1,t2,t3,t4;

#
# Check create text with option
#
--disable_warnings
drop table if exists t1,t2,t3,t4;
--enable_warnings
create table t1 (a text charset utf8 collate utf8_general_ci);
show full columns from t1;
create table t2 (a tinytext binary);
show full columns from t2;
create table t3 (a mediumtext default null);
show full columns from t3;
create table t4 (a longtext binary charset utf8 collate utf8_general_ci not null);
show full columns from t4;
drop table t1,t2,t3,t4;

#
# Check create blob with option
#
--disable_warnings
drop table if exists t1,t2;
--enable_warnings
create table t1 (a tinyblob default null, b blob default null, c mediumblob default null, d longblob default null);
show full columns from t1;
create table t2 (a tinyblob not null, b blob not null, c mediumblob not null, d longblob not null);
show full columns from t2;
drop table t1,t2;

#
# Check length errors with text/blob
#
--disable_warnings
drop table if exists t1;
--enable_warnings

--error 1064
create table t1 (a tinytext(65));
--error 1064
create table t1 (a mediumtext(4194305));
--error 1064
create table t1 (a longtext(12582913));
create table t1 (a text(131073));
--error 1064
create table t1 (a tinyblob(257));
--error 1064
create table t1 (a mediumblob(16777217));
--error 1064
create table t1 (a longblob(50331649));
create table t2 (a blob(524289));
drop table t1,t2;

#
# Check column option errors with text/blob
#
--disable_warnings
drop table if exists t1;
--enable_warnings

--error 1067
create table t1 (a tinytext default 'a');
--error 1067
create table t1 (a blob default 'a');
--error 1063
create table t1 (a mediumtext auto_increment);
--error 1063
create table t1 (a longblob auto_increment);
--error 1167
create table t1 (a tinytext primary key);
--error 1167
create table t1 (a blob, primary key (a));
--error 1167
create table t1 (a mediumtext unique);
--error 1167
create table t1 (a longblob, unique(a));

#
# Check create index errors with text/blob
#
--disable_warnings
drop table if exists t1,t2;
--enable_warnings
create table t1 (a int, b tinyblob, c text, d mediumblob, e longtext);
--error 1167
create index i1 on t1(b);
--error 1167
create index i1 on t1(c);
--error 1167
create index i1 on t1(d);
--error 1167
create index i1 on t1(e);
--error 1167
create table t2(a int, b tinyblob, key(b) local);
--error 1167
create table t2(a int, b text, key(a, b) local);
drop table t1;


#
# basic op test of text and blob
#
--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1 (nr int primary key, a1 tinyblob, a2 text(1024), a3 mediumblob, a4 longtext);
show full columns from t1;
insert into t1 values (1, NULL,NULL,NULL,NULL);
insert into t1 values (2, "","","","");
insert into t1 values (3, "hello","hello","hello","hello");
insert into t1 values (4, "HELLO","HELLO","HELLO","HELLO");
insert into t1 values (5, "HELLO MY","HELLO MY","HELLO MY","HELLO MY");
insert into t1 values (6, "a","a","a","a");
insert into t1 values (7, 1,1,1,1);
insert into t1 values (8, NULL,NULL,NULL,NULL);
update t1 set a3 = '', a2=null where a3 = '1';
select distinct * from t1 order by nr asc;
--let $count=4
while($count>0)
{
  eval select a$count from t1 where a$count like "hello" order by nr asc;
  eval select a$count from t1 where a$count like "%HELLO%" order by nr asc;
  eval select a$count from t1 having a$count like "hello" order by nr asc;
	eval select distinct a$count from t1 order by nr asc;
	eval select a$count, count(*) from t1 order by nr asc;
	dec $count;
}

drop table t1;

#
# Check create prefix index errors with text/blob
#
--disable_warnings
drop table if exists t1,t2,t3,t4;
--enable_warnings
create table t1 (a int, b tinyblob, c text, d mediumblob, e longtext, key b_i (b(20)), key c_i (c(100)), key d_i (d(200)), key e_i (e(500)));
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;
create table t2 (a int, b mediumtext, c mediumblob, key bc_i (b(1000), c(2000)));
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t2;
--error 1167
create table t3 (a int, b mediumtext, c mediumblob, key bc_i (b(1000), c));
--error 1071
create table t3 (a int, b mediumtext, c mediumblob, key b_i (b(18000)));
--error 1071
create table t3 (a int, b mediumtext, c mediumblob, key bc_i (b(9000), c(9000)));
create table t3 (a int, b mediumtext, c mediumblob, d varchar(200), key bd_i (b(1000), d));
--error 1071
create index c_i on t3(c(20000));
--error 1071
create index bc_i on t3(b(9000), c(9000));
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t3;
create table t4 (a int, b longtext, c longblob, d varchar(100));
create index b_i on t4(b(100));
create index bc_i on t4(b(100), c(200));
create index bd_i on t4(b(100), d);
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t4;
drop table t1,t2,t3,t4;


