# owner: luohongdi.lhd
# owner group: SQL1
# description: test for blob and text column after daily merge
# tags: text,blob
# temporarily disable large row

--disable_query_log
set global max_allowed_packet=60000000;
set global ob_sql_work_area_percentage=80;
disconnect default;
sleep 1;
connect (default,$OBMYSQL_MS0,admin,admin,test,$OBMYSQL_PORT);
set @@session.explicit_defaults_for_timestamp=off;
set @@recyclebin = off;
set ob_query_timeout=1000000000;
set ob_trx_timeout=1000000000;
--enable_query_log

#
# test of basic insert with text/blob after daily merge
#
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(nr int, a longtext, b longblob);

insert into t1 values(1, repeat('a', 5000000), repeat('a', 5000000));
insert into t1 values(1, repeat('a', 1000000), repeat('a', 1000000));
--let $loop=2
while($loop > 0)
{
  insert into t1 select * from t1;
  dec $loop;
}
select nr, sum(length(a)), sum(length(b)) from t1 group by nr order by nr asc;
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
connection default;
select nr, sum(length(a)), sum(length(b)) from t1 group by nr order by nr asc;
drop table t1;

#
# mix test of some dml with text/blob after daily merge
#
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1 (nr int primary key, a tinyblob, b text, c mediumblob, d longtext);

insert into t1 values(1, 'a', 'b', repeat('c', 100000), repeat('d', 1000000));
insert into t1 values(2, 'aa', 'bb', repeat('c', 200000), repeat('d', 2000000));
insert into t1 values(3, 'aaa', 'bbb', repeat('c', 300000), repeat('d', 3000000));
insert into t1 values(4, null, null, null, null);
insert into t1 values(5, '', '', '', '');
select nr, a, b, length(c), length(d) from t1 order by nr asc;
delete from t1 where a is null;
update t1 set c = 'updatemedium', d = 'updatelong' where b = 'bbb';
select nr, a, b, length(c), length(d) from t1 order by nr asc;
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc
connection default;
select nr, a, b, length(c), length(d) from t1 order by nr asc;
delete from t1 where a < 'aa';
select nr, a, b, length(c), length(d) from t1 order by nr asc;
drop table t1;

--disable_query_log
set global max_allowed_packet=16777216;
set global ob_sql_work_area_percentage=5;
set @@recyclebin = on;
--enable_query_log
