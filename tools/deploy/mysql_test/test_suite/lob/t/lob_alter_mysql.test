--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1 (a varchar(20), primary key(a));
--error 1167
alter table t1 modify a text;
--error 1167
alter table t1 modify a longtext;
--error 1167
alter table t1 modify a blob;
drop table t1;

# disable mediumtext -> longtext
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1 (nr int, a varchar(20), b mediumtext, primary key(nr));
alter table t1 modify a tinytext;
alter table t1 modify a text;
alter table t1 modify a mediumtext;
alter table t1 modify b longtext;
drop table t1;


--disable_query_log
set global max_allowed_packet=16777216;
--enable_query_log
