# owner: luohongdi.lhd
# owner group: SQL1
# description: basic alter column test for blob and text column
# tags: text,blob

--disable_query_log
set global max_allowed_packet=60000000;
disconnect default;
sleep 1;
connect (default,$OBMYSQL_MS0,admin,admin,test,$OBMYSQL_PORT);
set @@session.explicit_defaults_for_timestamp=off;
set @@recyclebin = off;
set ob_query_timeout=1000000000;
set ob_trx_timeout=1000000000;
--enable_query_log

#
# basic alter column test for text
#
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(a tinytext, b text, c mediumtext, d longtext);
insert into t1 values(repeat('a', 255), repeat('a', 65535), repeat('a', 1000000), repeat('a', 5000000));
insert into t1 values(repeat('a', 255), repeat('a', 65535), repeat('a', 1000000), repeat('a', 5000000));
insert into t1 values(repeat('a', 255), repeat('a', 65535), repeat('a', 1000000), repeat('a', 5000000));
insert into t1 values(repeat('a', 255), repeat('a', 65535), repeat('a', 1000000), repeat('a', 5000000));
show full columns from t1;
alter table t1 modify column a tinytext not null;
show full columns from t1;
#alter table t1 modify column b text charset utf8;
show full columns from t1;
#alter table t1 modify column c mediumtext collate utf8mb4_bin;
alter table t1 modify d longtext not null;
alter table t1 modify column b text binary;
--error 1167
alter table t1 modify column a tinytext primary key;
--error 1167
alter table t1 add index xx1(c);
drop table t1;

#
# basic alter column test for blob
#
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(a tinyblob, b blob, c mediumblob, d longblob);
insert into t1 values(repeat('a', 255),repeat('a', 65535), repeat('a', 10000000),  repeat('a', 18000000));
insert into t1 values(repeat('a', 255),repeat('a', 65535), repeat('a', 10000000),  repeat('a', 18000000));
insert into t1 values(repeat('a', 255),repeat('a', 65535), repeat('a', 10000000),  repeat('a', 18000000));
insert into t1 values(repeat('a', 255),repeat('a', 65535), repeat('a', 10000000),  repeat('a', 18000000));
show full columns from t1;
alter table t1 modify column a tinyblob not null;
show full columns from t1;
#--error 1064
#alter table t1 modify column b blob charset utf8;
#--error 1064
#alter table t1 modify column c mediumblob collate utf8mb4_bin;
alter table t1 modify d longblob not null;
--error 1167
alter table t1 modify column a tinyblob primary key;
--error 1167
alter table t1 add index xx1(c);
drop table t1;


#
# basic add/drop column test for text
#
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(a int, b tinytext);
insert into t1 values(1, repeat('a', 128));
select a, length(b) from t1 order by a;
alter table t1 add column c text default null;
insert into t1 values(2, repeat('a', 63), repeat('a', 16383));
select a, length(b), length(c) from t1 order by a;
alter table t1 add column d mediumtext not null;
insert into t1 values(3, repeat('a', 63), repeat('a', 16383), repeat('a', 1000000));
select a, length(b), length(c), length(d) from t1 order by a;
alter table t1 add column e longtext not null;
insert into t1 values(4, repeat('a', 63), repeat('a', 16383), repeat('a', 1000000), repeat('a', 5000000));
select a, length(b), length(c), length(d), length(e) from t1 order by a;
alter table t1 drop column e;
insert into t1 values(5, repeat('a', 63), repeat('a', 16383), repeat('a', 1000000));
select a, length(b), length(c), length(d) from t1 order by a;
alter table t1 drop column d;
insert into t1 values(6, repeat('a', 63), repeat('a', 16383));
select a, length(b), length(c) from t1 order by a;
alter table t1 drop column c;
insert into t1 values(7, repeat('a', 63));
select a, length(b) from t1 order by a;
alter table t1 drop column b;
insert into t1 values(8);
select * from t1 order by a;
drop table t1;

#
# basic add/drop column test for blob
#
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(a int, b tinyblob);
insert into t1 values(1, repeat('a', 128));
select a, length(b) from t1 order by a;
alter table t1 add column c blob default null;
insert into t1 values(2, repeat('a', 128), repeat('a', 65535));
select a, length(b), length(c) from t1 order by a;
alter table t1 add column d mediumblob not null;
insert into t1 values(3, repeat('a', 128), repeat('a', 65535), repeat('a', 16000000));
select a, length(b), length(c), length(d) from t1 order by a;
alter table t1 add column e longblob not null;
insert into t1 values(4, repeat('a', 128), repeat('a', 65535), repeat('a', 16000000), repeat('a', 20000000));
select a, length(b), length(c), length(d), length(e) from t1 order by a;
alter table t1 drop column e;
insert into t1 values(5, repeat('a', 128), repeat('a', 65535), repeat('a', 16000000));
select a, length(b), length(c), length(d) from t1 order by a;
alter table t1 drop column d;
insert into t1 values(6, repeat('a', 128), repeat('a', 65535));
select a, length(b), length(c) from t1 order by a;
alter table t1 drop column c;
insert into t1 values(7, repeat('a', 128));
select a, length(b) from t1 order by a;
alter table t1 drop column b;
insert into t1 values(8);
select * from t1 order by a;
drop table t1;

#
# alter generated column test for text/blob
#
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(id int primary key, a text);
insert into t1 values(1, 'abcdefghijklmnopqrstuvwxyz');
select * from t1 order by id;
alter table t1 add column b tinytext as(substr(a, 1, 20)) stored;
alter table t1 add column c longtext as(concat(a, '1234567890')) stored;
alter table t1 add column d tinyblob as(substr(a, 1, 20)) stored;
alter table t1 add column e mediumblob as(concat(a, '1234567890')) stored;
select * from t1 order by id;
show full columns from t1;
drop table t1;

#
# alter column with rowsize limit test test for text/blob
#
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1 (a longtext, b longblob);
alter table t1 add column c longtext;
alter table t1 add column d longblob;
alter table t1 drop column a;
drop table t1;

