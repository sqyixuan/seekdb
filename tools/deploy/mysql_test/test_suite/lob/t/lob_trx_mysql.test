# owner: luohongdi.lhd
# owner group: STORAGE2
# description: basic transaction test for blob and text column
# tags: text,blob

--disable_query_log
set global max_allowed_packet=60000000;
set global ob_sql_work_area_percentage=50;
disconnect default;
sleep 1;
connect (default,$OBMYSQL_MS0,admin,admin,test,$OBMYSQL_PORT);
set @@session.explicit_defaults_for_timestamp=off;
set @@session.autocommit=0;
set @@recyclebin = off;
set ob_query_timeout=1000000000;
set ob_trx_timeout=1000000000;
--enable_query_log

#
# insert with transaction test for text/blob
#
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(a longtext, b longblob, c longtext);
insert into t1 values(repeat('a', 5242880), repeat('a', 5242880), repeat('a', 5242880));
start transaction;
insert into t1 select * from t1;
commit;
select substr(a, 10000, 10), substr(b, 10000, 10), substr(c, 10000, 10) from t1;
truncate t1;
begin;
insert into t1 values(repeat('a', 5242880), repeat('a', 5242880), repeat('a', 5242880));
insert into t1 select * from t1;
select substr(a, 10000, 10), substr(b, 10000, 10), substr(c, 10000, 10) from t1;
rollback;
select substr(a, 10000, 10), substr(b, 10000, 10), substr(c, 10000, 10) from t1;
drop table t1;

#
# update with transaction test for text/blob
#
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1 (id int primary key, a tinyblob, b text, c mediumblob, d longtext);
insert into t1 values(1, 'a', 'b', 'c', 'd');
insert into t1 values(2, 'aa', 'bb', 'cc', 'dd');
commit;
start transaction;
update t1 set a = '123', c = 'abc' where id = 1;
update t1 set b = 'hello', d = 'hello ob' where id = 2;
select * from t1;
rollback;
select * from t1;
drop table t1;

#
# update with transaction test for text/blob
#
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1 (id int primary key, a tinyblob, b text, c mediumblob, d longtext);
insert into t1 values(1, 'a', 'b', 'c', 'd');
insert into t1 values(2, 'aa', 'bb', 'cc', 'dd');
commit;
start transaction;
delete from t1 where id = 1;
select * from t1;
rollback;
select * from t1;
drop table t1;

--disable_query_log
set global max_allowed_packet=16777216;
set global ob_sql_work_area_percentage=5;
--enable_query_log
