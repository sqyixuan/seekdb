--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: luohongdi.lhd
# owner group: SQL1
# description: select test for blob and text column
# tags: text,blob

#
# test of basic func with text/blob
#
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1 (nr int, a tinyblob, b text, c mediumblob, d longtext);
insert into t1 values(1, 'a', 'b', 'c', 'd');
insert into t1 values(2, 'aa', 'bb', 'cc', 'dd');
insert into t1 values(3, 'aaa', 'bbb', 'ccc', 'ddd');
insert into t1 values(4, null, null, null, null);
insert into t1 values(5, '', '', '', '');
insert into t1 values(6, 'aaa', 'BBB', 'ccc', 'DDD');
insert into t1 values(7, 'AA', 'bb', 'CC', 'dd');

select distinct(a) from t1 order by nr asc;
select distinct(b) from t1 order by nr asc;
select max(b), min(c) from t1;
select * from t1 order by nr asc;
select * from t1 order by nr desc;
#collation with null value in ob is abnormal
select collation(a), collation(b) from t1 where a is not null and b is not null;
drop table t1;

#
# test of select union with text/blob
#
--disable_warnings
drop table if exists t1,t2;
--enable_warnings
create table t1 (nr int, a tinyblob, b text, c mediumblob, d longtext);
create table t2 (nr int, a int, b varchar(20), c decimal(10,2), d timestamp);
insert into t1 values(1, 'a', 'b', 'c', 'd');
insert into t1 values(2, 'aa', 'bb', 'cc', 'dd');
insert into t1 values(3, 'aaa', 'bbb', 'ccc', 'ddd');
insert into t2 values(1, 1, 'abc', 12.3, '2017-08-01 17:00:00');
select nr, a from t1 union select nr, a from t2 order by nr asc;
select nr, b from t1 union select nr, b from t2 order by nr asc;
select nr, c from t1 union select nr, c from t2 order by nr asc;
select nr, d from t1 union select nr, d from t2 order by nr asc;
drop table t1,t2;

#
# test of group by with text/blob
#
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1 (nr int, a tinyblob, b text, c mediumblob, d longtext);
insert into t1 values(1, 'a', 'b', 'c', 'd');
insert into t1 values(2, 'aa', 'bb', 'cc', 'dd');
insert into t1 values(3, 'aaa', 'bbb', 'ccc', 'ddd');
insert into t1 values(4, null, null, null, null);
insert into t1 values(5, '', '', '', '');
insert into t1 values(6, 'aaa', 'BBB', 'ccc', 'DDD');
insert into t1 values(7, 'AA', 'bb', 'CC', 'dd');

select b, max(a), min(c) from t1 order by nr asc;
select c, sum(b), avg(d) from t1 order by nr asc;
select a, d, count(*) from t1 order by nr asc;
select b from t1 order by nr asc limit 1;
select c from t1 order by nr asc limit 2, 2;
select b, max(a), min(c) from t1 having min(c) > 'c';
drop table t1;


#
# test of full join with text/blob
#
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1 (nr int(5) not null auto_increment, b text, c blob, primary key (nr));
insert into t1 values (null, "a", "A");
insert into t1 values (null, "bbb", "BBB");
insert into t1 values (null, "ccc", "CCC");
select * from t1, t1 as t2 order by t1.nr,t2.nr;
drop table t1;


#
# test of basic join with text/blob
#
--disable_warnings
drop table if exists t1,t2;
--enable_warnings
create table t1 (nr1 int(5) not null auto_increment, a text, b blob, primary key (nr1));
create table t2 (nr2 int(5) not null auto_increment, c text, d blob, primary key (nr2));
insert into t1 values (null, "a", "A");
insert into t1 values (null, "bbb", "BBB");
insert into t1 values (null, "ccc", "CCC");
insert into t2 values (null, "a", "A");
insert into t2 values (null, "bbb", "BAB");
insert into t2 values (null, "cbc", "CCC");
select * from t1 join t2 on b = c;
select * from t1 join t2 on a = c order by nr1, nr2;
select * from t1 join t2 on b = d order by nr1, nr2;
select * from t1 full join t2 on b = d order by nr1, nr2;
select * from t1 cross join t2 order by nr1, nr2;
select * from t1 full join t2 on a = c order by nr1, nr2;
select * from t1 left join t2 on a = d order by nr1, nr2;
select * from t1 left join t2 on a = c where c is null order by nr1, nr2;
#left semi
select * from t1 where a in (select c from t2) order by nr1;
#left anti semi
select * from t1 where not exists (select c from t2 where d like b) order by nr1;
drop table t1,t2;


#
# test of cast func with text/blob
#
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1 (nr int primary key, a1 tinyblob, a2 text, a3 mediumblob, a4 longtext);
insert into t1 values(1, 'aa', 'bb', 'cc', 'dd');
insert into t1 values(2, 'AA', 'BB', 'CC', 'DD');
insert into t1 values(3, 'aaa', '世界', 'ccc', '和平');
--let $count=1
while($count<5)
{
	eval select cast(a$count AS datetime) from t1 order by nr asc;
	eval select cast(a$count as decimal(9,2)) from t1 order by nr asc;
	eval select cast(a$count as decimal(9)) from t1 order by nr asc;
	eval select cast(a$count as binary) from t1 order by nr asc;
	eval select cast(a$count as char) from t1 order by nr asc;
	eval select cast(a$count as date) from t1 order by nr asc;
	eval select cast(a$count as char(2)) from t1 order by nr asc;
	eval select hex(cast(a$count as binary(2))) from t1 order by nr asc;
	eval select cast(a$count as signed integer) from t1 order by nr asc;
	eval select cast(a$count as unsigned) from t1 order by nr asc;
	eval select cast(a$count as time) from t1 order by nr asc;
	eval select cast(a$count as signed) from t1 order by nr asc;
	eval select cast(a$count as signed) from t1 order by nr asc;
	inc $count;
}
drop table t1;

create table t1(c1 blob);
insert into t1 values('123');
insert into t1 values(null);
select * from t1 where c1 is null;
select * from t1 where c1 is not null;
drop table t1;

--disable_warnings
drop table if exists v0;
--enable_warnings
CREATE TABLE v0 ( v2 MEDIUMTEXT CHARSET BINARY , v1 ENUM ( 'x' ) BINARY DEFAULT _GB18030 'x' UNIQUE PRIMARY KEY ) ;
INSERT INTO v0 VALUES ( v2 > ( ( v2 , v2 ) IN ( SELECT * FROM v0 WHERE ( - - - 0 - ( + - - 1 ) , - - - 39 NOT BETWEEN - - - - - 8 AND ( - - - - -1 NOT LIKE 57269311.000000 ) ) IN ( SELECT * FROM v0 WHERE ( - 51 NOT LIKE 'x' ) - - - -1 AND ( v2 , v2 ) IN ( SELECT v2 / v1 , ( - 80061002.000000 >= v1 IS NOT NULL = - - - -2147483648 AND v1 = - -1 ) OR v2 = v2 ) ) ) AND v2 > - - - - -1 ) , _GBK 'x' ) ;
TRUNCATE TABLE v0 ;
INSERT . v0 VALUES ( 51 , CASE WHEN -1 > -128 THEN v1 ELSE v2 END ) ;
SELECT * FROM v0;
DROP TABLE v0;

--disable_warnings
drop table if exists t1;
--enable_warnings
CREATE table t1(c1 bigint PRIMARY key AUTO_INCREMENT,c2 text);
insert into t1(c2) values(hex('示范单位发'));
insert into t1(c2) values(hex('ewojgrew'));
select * from t1;
insert into t1(c2) values(hex(c2));
select * from t1;
drop table t1;


create table t1(c0 int, c1 longtext);
insert into t1 values(1, 'c1-a001');
SELECT * FROM t1 WHERE t1.c1 IN (select 'c1-a001');
SELECT /*+no_rewrite*/* FROM t1 WHERE t1.c1 IN (select 'c1-a001');

create table t2(c0 int, c1 varchar(100));
insert into t2 values(2, 'c1-a001');
SELECT * FROM t2 WHERE t2.c1 IN (select t1.c1 from t1);
SELECT /*+no_rewrite*/* FROM t2 WHERE t2.c1 IN (select t1.c1 from t1);

drop table t1;
drop table t2;
