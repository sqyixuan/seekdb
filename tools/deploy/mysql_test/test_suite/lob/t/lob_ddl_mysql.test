#owner: aozeliu.azl
#owner group: shenzhen
--echo # ----------------------------------------------------------------------
--echo # Test Lob DDL in mysql mode
--echo # ----------------------------------------------------------------------

--disable_query_log
--disable_warnings
drop table if exists t1;
--enable_warnings
--enable_query_log

create table t1 (c1 text);
show create table t1;
drop table t1;

create table t1 (c1 text) DEFAULT_LOB_INROW_THRESHOLD=4444;
show create table t1;
drop table t1;

create table t1 (c1 text) DEFAULT_LOB_INROW_THRESHOLD=4444;
show create table t1;
alter table t1 add column (c2 text);
show create table t1;
alter table t1 set DEFAULT_LOB_INROW_THRESHOLD = 5555;
show create table t1;
drop table t1;

create table t1 (c1 text, c2 text) DEFAULT_LOB_INROW_THRESHOLD=4444;
show create table t1;
drop table t1;

create table t1 (c1 text, c2 text) LOB_INROW_THRESHOLD=4444;
show create table t1;
drop table t1;

set ob_default_lob_inrow_threshold=6666;
create table t1 (c1 text);
show create table t1;
drop table t1;

create table t1(pk int primary key, c2 varchar(100), j text) DEFAULT_LOB_INROW_THRESHOLD=10000;
insert into t1 values(1, '2222', repeat('x', 8127)); 
select pk, md5(j) as md5 from t1;
alter table t1 drop column c2;
select pk, md5(j) as md5 from t1;
drop table t1;

create table t1(pk int primary key, c1 mediumtext, c2 longtext, c3 longtext);
--error 1210
alter table t1 set lob_inrow_threshold = 786433;
--error 1210
alter table t1 set lob_inrow_threshold = 786432;
drop table t1;

create table t1(pk int primary key, c1 longtext);
insert into t1 values(1, repeat('1', 786432));
update t1 set c1 = repeat('2', 786432);
drop table t1;

--error 1210
set ob_default_lob_inrow_threshold=786433;

create table lob_t1(pk int primary key, c1 longtext) lob_inrow_threshold = 4097;
insert into lob_t1 values(1, repeat('1', 786432));
select lob_inrow_threshold from oceanbase.__all_table where table_name='lob_t1';
let $before_table_id = query_get_value(select table_id as cnt from oceanbase.__all_table where table_name='lob_t1', cnt, 1);
# offline ddl if dec
alter table lob_t1 set lob_inrow_threshold = 1026;
select lob_inrow_threshold from oceanbase.__all_table where table_name='lob_t1';
let $after_table_id_1 = query_get_value(select table_id as cnt from oceanbase.__all_table where table_name='lob_t1', cnt, 1);
if($before_table_id != $after_table_id_1)
{
  --echo run offline ddl
}
# online ddl if inc
alter table lob_t1 set lob_inrow_threshold = 1027;
select lob_inrow_threshold from oceanbase.__all_table where table_name='lob_t1';
let $after_table_id_2 = query_get_value(select table_id as cnt from oceanbase.__all_table where table_name='lob_t1', cnt, 1);
if($after_table_id_1 == $after_table_id_2)
{
  --echo run online ddl
}
drop table lob_t1;

create table t1(c1 longtext, c2 longtext) lob_inrow_threshold=786432;
insert into t1 values(repeat('1', 786432), repeat('2', 786432));
select md5(c1), md5(c2) from t1;
alter table t1 set lob_inrow_threshold=393216;
alter table t1 add c3 longtext;
select md5(c1), md5(c2), md5(c3) from t1;
update t1 set c3 = repeat('2', 386432);
select md5(c1), md5(c2), md5(c3) from t1;
alter table t1 add c4 longtext;
select md5(c1), md5(c2), md5(c3), md5(c4) from t1;
update t1 set c4 = repeat('2', 386432);
select md5(c1), md5(c2), md5(c3), md5(c4) from t1;
delete from t1;
drop table t1;
create table t1 (pk int primary key, c1 longtext);
let $main_table_id = query_get_value(select table_id as cnt from oceanbase.__all_table where table_name='t1', cnt, 1);
let $lob_meta_tablet_id = query_get_value(select tablet_id as cnt from oceanbase.__all_table where data_table_id=$main_table_id and table_name like '%_AUX_LOB_META_%', cnt, 1);
let $lob_piece_tablet_id = query_get_value(select tablet_id as cnt from oceanbase.__all_table where data_table_id=$main_table_id and table_name like '%_AUX_LOB_PIECE_%', cnt, 1);

if ($lob_meta_tablet_id == 0) {
  --echo incorrect lob meta tablet id
}
if ($lob_piece_tablet_id == 0) {
  --echo incorrect lob meta tablet id
}
drop table t1;

--disable_warnings
drop table if exists lob_t1;
--enable_warnings
create table lob_t1 (pk int primary key, c1 longtext) partition by hash(pk) partitions 4;
let $main_table_id = query_get_value(select table_id as cnt from oceanbase.__all_table where table_name='lob_t1', cnt, 1);
let $lob_meta_tablet_id = query_get_value(select tablet_id as cnt from oceanbase.__all_table where data_table_id=$main_table_id and table_name like '%_AUX_LOB_META_%', cnt, 1);
let $lob_piece_tablet_id = query_get_value(select tablet_id as cnt from oceanbase.__all_table where data_table_id=$main_table_id and table_name like '%_AUX_LOB_PIECE_%', cnt, 1);

# tablet_id of partition table of lob aux table should be zero
if ($lob_meta_tablet_id != 0) {
  --echo incorrect lob meta tablet id : $lob_meta_tablet_id
}
if ($lob_piece_tablet_id != 0) {
  --echo incorrect lob meta tablet id : $lob_meta_tablet_id
}
drop table lob_t1;

create table lob_t1( c0 int, c1 varchar(65535), c2 varchar(65535), c3 varchar(65535), c4 varchar(65535), c5 varchar(65535), c6 varchar(65407));
--error 1118
alter table lob_t1 add c7 longtext;
--error 4055
alter table lob_t1 add c7 longtext, modify column c3 varchar(65535) after c4;
drop table lob_t1;
--error 1118
create table lob_t1( c0 int, c1 varchar(65535), c2 varchar(65535), c3 varchar(65535), c4 varchar(65535), c5 varchar(65535), c6 varchar(65407), c7 longtext);
