#owner: luohongdi.lhd
#owner group: sql2
#temporarily disable large row

--disable_query_log
set global max_allowed_packet=134217728;
disconnect default;
sleep 1;
connect (default,$OBMYSQL_MS0,admin,admin,test,$OBMYSQL_PORT);
set @@session.explicit_defaults_for_timestamp=off;
set @@recyclebin = off;
set ob_query_timeout=1000000000;
set ob_trx_timeout=1000000000;
--enable_query_log

--disable_abort_on_error
--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1(pk int primary key, content longtext);

#--let $insert_sql=replace into t1 values(1
#--let $value=1
#--let $kb=3000
#--let $
#while($kb)
#{
    #--let $value=$value$byte
    #dec $kb;
#}

#--let $insert_sql=$insert_sql , '$value' )
#--disable_query_log
#eval $insert_sql;

insert into t1 values(1, repeat('abcdefghijklmnopqrstuvwxyz', 1000000));

select length(content), substr(content, 261, 26), substr(content, 26001, 26) from t1;

insert into t1 values(2, repeat('abcdety', 13421773));

select substr(content, 1, 10) from t1 where pk = 2;

--disable_query_log
drop table t1;
set global max_allowed_packet=16777216;
--enable_query_log
