# owner: luohongdi.lhd
# owner group: STORAGE2
# description: test for blob and text column with minor merge
# tags: text,blob


--disable_query_log
connection default;
set @@session.explicit_defaults_for_timestamp=off;
set @@recyclebin = off;
set ob_query_timeout=1000000000;
set ob_trx_timeout=1000000000;
--enable_query_log

#
# bug 
#

--disable_warnings
drop table if exists test_lob;
--enable_warnings

create table test_lob(a bigint auto_increment, b longtext, c longblob, primary key (a));

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
let $__table_id__=query_get_value(select /*+QUERY_TIMEOUT(10000000000)*/ table_id from oceanbase.__all_virtual_table where table_name='test_lob', table_id, 1);
disconnect obsys;
connection default;

insert into test_lob (b,c) values (repeat('a', 3000000), repeat('A', 3000000));
insert into test_lob (b,c) values (repeat('b', 3000000), repeat('B', 3000000));
insert into test_lob (b,c) values (repeat('c', 3000000), repeat('C', 3000000));
insert into test_lob (b,c) values (repeat('d', 3000000), repeat('D', 3000000));
insert into test_lob (b,c) values (repeat('e', 3000000), repeat('E', 3000000));
insert into test_lob (b,c) values (repeat('f', 3000000), repeat('F', 3000000));
insert into test_lob (b,c) values (repeat('g', 3000000), repeat('G', 3000000));
insert into test_lob (b,c) values (repeat('h', 3000000), repeat('H', 3000000));
insert into test_lob (b,c) values (repeat('i', 3000000), repeat('I', 3000000));
insert into test_lob (b,c) values (repeat('j', 3000000), repeat('J', 3000000));
--let $loop=10
while($loop > 0)
{
  insert into test_lob (b,c) values (repeat('a', 300000), repeat('A', 300000));
  insert into test_lob (b,c) values (repeat('b', 300000), repeat('B', 300000));
  insert into test_lob (b,c) values (repeat('c', 300000), repeat('C', 300000));
  insert into test_lob (b,c) values (repeat('d', 300000), repeat('D', 300000));
  insert into test_lob (b,c) values (repeat('e', 300000), repeat('E', 300000));
  insert into test_lob (b,c) values (repeat('f', 300000), repeat('F', 300000));
  insert into test_lob (b,c) values (repeat('g', 300000), repeat('G', 300000));
  insert into test_lob (b,c) values (repeat('h', 300000), repeat('H', 300000));
  insert into test_lob (b,c) values (repeat('i', 300000), repeat('I', 300000));
  insert into test_lob (b,c) values (repeat('j', 300000), repeat('J', 300000));
  dec $loop;
}

--source mysql_test/include/minorfreeze.inc
connection default;
--real_sleep 10
--source mysql_test/include/wait_minor_merge.inc
connection default;
select count(1) from test_lob;

insert into test_lob (b,c) values (repeat('a', 3000000), repeat('A', 3000000));
insert into test_lob (b,c) values (repeat('b', 3000000), repeat('B', 3000000));
insert into test_lob (b,c) values (repeat('c', 3000000), repeat('C', 3000000));
insert into test_lob (b,c) values (repeat('d', 3000000), repeat('D', 3000000));
insert into test_lob (b,c) values (repeat('e', 3000000), repeat('E', 3000000));
insert into test_lob (b,c) values (repeat('f', 3000000), repeat('F', 3000000));

--let $loop=10
while($loop > 0)
{
  insert into test_lob (b,c) values (repeat('a', 300000), repeat('A', 300000));
  insert into test_lob (b,c) values (repeat('b', 300000), repeat('B', 300000));
  insert into test_lob (b,c) values (repeat('c', 300000), repeat('C', 300000));
  insert into test_lob (b,c) values (repeat('d', 300000), repeat('D', 300000));
  insert into test_lob (b,c) values (repeat('e', 300000), repeat('E', 300000));
  insert into test_lob (b,c) values (repeat('f', 300000), repeat('F', 300000));
  insert into test_lob (b,c) values (repeat('g', 300000), repeat('G', 300000));
  insert into test_lob (b,c) values (repeat('h', 300000), repeat('H', 300000));
  insert into test_lob (b,c) values (repeat('i', 300000), repeat('I', 300000));
  insert into test_lob (b,c) values (repeat('j', 300000), repeat('J', 300000));
  dec $loop;
}
--source mysql_test/include/minorfreeze.inc
connection default;
--real_sleep 10
--source mysql_test/include/wait_minor_merge.inc
connection default;

select count(1) from test_lob;

insert into test_lob (b,c) values (repeat('a', 3000000), repeat('A', 3000000));
insert into test_lob (b,c) values (repeat('b', 3000000), repeat('B', 3000000));
insert into test_lob (b,c) values (repeat('c', 3000000), repeat('C', 3000000));
insert into test_lob (b,c) values (repeat('d', 3000000), repeat('D', 3000000));
insert into test_lob (b,c) values (repeat('e', 3000000), repeat('E', 3000000));
