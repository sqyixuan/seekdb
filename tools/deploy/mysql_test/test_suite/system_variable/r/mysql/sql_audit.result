result_format: 4
alter system flush sql audit global;
alter system flush plan cache global;
set global ob_sql_audit_percentage = 50;


##################### enable_sql_audit = true, enable_perf_event from true to false to true ###############
show parameters like 'enable_sql_audit';
zone	svr_type	name	data_type	value	info	section	scope	source	edit_level	default_value	isdefault
#	observer	#	#	True	specifies whether SQL audit is turned on. The default value is TRUE. Value: TRUE: turned on FALSE: turned off	OBSERVER	#	DEFAULT	DYNAMIC_EFFECTIVE	true	1
show parameters like 'enable_perf_event';
zone	svr_type	name	data_type	value	info	section	scope	source	edit_level	default_value	isdefault
#	observer	#	#	True	specifies whether to enable perf event feature. The default value is True.	OBSERVER	#	DEFAULT	DYNAMIC_EFFECTIVE	True	1
alter system set enable_perf_event = false;
alter system set enable_perf_event = true;
##################### enable_perf_event = true, enable_sql_audit from true to false to true ###############
show parameters like 'enable_sql_audit';
zone	svr_type	name	data_type	value	info	section	scope	source	edit_level	default_value	isdefault
#	observer	#	#	True	specifies whether SQL audit is turned on. The default value is TRUE. Value: TRUE: turned on FALSE: turned off	OBSERVER	#	DEFAULT	DYNAMIC_EFFECTIVE	true	1
show parameters like 'enable_perf_event';
zone	svr_type	name	data_type	value	info	section	scope	source	edit_level	default_value	isdefault
#	observer	#	#	True	specifies whether to enable perf event feature. The default value is True.	OBSERVER	#	DEFAULT	DYNAMIC_EFFECTIVE	True	1
alter system set enable_sql_audit = false;
alter system set enable_sql_audit = true;
##################### enable_sql_audit = false, enable_perf_event from true to false to true ###############
alter system set enable_sql_audit = false;
show parameters like 'enable_sql_audit';
zone	svr_type	name	data_type	value	info	section	scope	source	edit_level	default_value	isdefault
#	observer	#	#	False	specifies whether SQL audit is turned on. The default value is TRUE. Value: TRUE: turned on FALSE: turned off	OBSERVER	#	DEFAULT	DYNAMIC_EFFECTIVE	true	0
show parameters like 'enable_perf_event';
zone	svr_type	name	data_type	value	info	section	scope	source	edit_level	default_value	isdefault
#	observer	#	#	True	specifies whether to enable perf event feature. The default value is True.	OBSERVER	#	DEFAULT	DYNAMIC_EFFECTIVE	True	1
alter system set enable_perf_event = false;
alter system set enable_perf_event = true;
##################### enable_perf_event = false, enable_sql_audit from true to false to true ###############
alter system set enable_perf_event = false;
show parameters like 'enable_sql_audit';
zone	svr_type	name	data_type	value	info	section	scope	source	edit_level	default_value	isdefault
#	observer	#	#	False	specifies whether SQL audit is turned on. The default value is TRUE. Value: TRUE: turned on FALSE: turned off	OBSERVER	#	DEFAULT	DYNAMIC_EFFECTIVE	true	0
show parameters like 'enable_perf_event';
zone	svr_type	name	data_type	value	info	section	scope	source	edit_level	default_value	isdefault
#	observer	#	#	False	specifies whether to enable perf event feature. The default value is True.	OBSERVER	#	DEFAULT	DYNAMIC_EFFECTIVE	True	0
alter system set enable_sql_audit = false;
alter system set enable_sql_audit = true;


drop table if exists t_sql_audit;
create table t_sql_audit(c int);

########################## enable_sql_audit = true, enable_perf_event = true ######################
alter system flush sql audit global;
alter system flush plan cache global;
alter system set enable_sql_audit = true;
alter system set enable_perf_event = true;
select * from t_sql_audit order by c;
+------+
| c    |
+------+
+------+
