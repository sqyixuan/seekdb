result_format: 4
##1.have_query_cache
show variables like 'have_query_cache';
Variable_name	Value
have_query_cache	NO

set have_query_cache='YES';
ERROR HY000: Variable 'have_query_cache' is a read only variable
set global have_query_cache='YES';
ERROR HY000: Variable 'have_query_cache' is a read only variable

##2.query_cache_limit
show variables like 'query_cache_limit';
Variable_name	Value
query_cache_limit	0

set global query_cache_limit=1048576;
set global query_cache_limit=default;

set query_cache_limit=0;
ERROR HY000: Variable 'query_cache_limit' is a GLOBAL variable and should be set with SET GLOBAL

