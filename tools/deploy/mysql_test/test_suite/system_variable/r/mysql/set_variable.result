result_format: 4
## test resolve and execute both static engine.
SET TIMESTAMP = LEAST( ABS( 6 ), 2147483647 );
select @@TIMESTAMP;
+-------------+
| @@TIMESTAMP |
+-------------+
|           6 |
+-------------+

## test expr ctx
SET TIMESTAMP = rand(1);
select @@TIMESTAMP;
+---------------------+
| @@TIMESTAMP         |
+---------------------+
| 0.40540353712197724 |
+---------------------+
SET TIMESTAMP = ('a' like 'b') + rand(1);
select @@TIMESTAMP;
+---------------------+
| @@TIMESTAMP         |
+---------------------+
| 0.40540353712197724 |
+---------------------+
### test multiple variable assignment
set timestamp = rand(1), autocommit = 'a' like 'b';
select @@timestamp, @@autocommit;
+-------------+--------------+
| @@timestamp | @@autocommit |
+-------------+--------------+
|    0.405404 |            0 |
+-------------+--------------+

## test WARN_ON_FAIL when set user variable
set @st_test1 = time('900:00:00');
set @st_test2 = 'a' + 1;
Warnings:
Warning	1292	Truncated incorrect DOUBLE value: 'a'
select @st_test1, @st_test2;
+------------------+-----------+
| @st_test1        | @st_test2 |
+------------------+-----------+
| 838:59:59.000000 |         1 |
+------------------+-----------+
set autocommit = 'a' + 1;
ERROR 01000: Truncated incorrect DOUBLE value


SET TIMESTAMP = LEAST( ABS( 6 ), 2147483647 );
select @@TIMESTAMP;
+-------------+
| @@TIMESTAMP |
+-------------+
|           6 |
+-------------+

## test expr ctx
SET TIMESTAMP = rand(1);
select @@TIMESTAMP;
+---------------------+
| @@TIMESTAMP         |
+---------------------+
| 0.40540353712197724 |
+---------------------+
SET TIMESTAMP = ('a' like 'b') + rand(1);
select @@TIMESTAMP;
+---------------------+
| @@TIMESTAMP         |
+---------------------+
| 0.40540353712197724 |
+---------------------+
### test multiple variable assignment
set timestamp = rand(1), autocommit = 'a' like 'b';
select @@timestamp, @@autocommit;
+-------------+--------------+
| @@timestamp | @@autocommit |
+-------------+--------------+
|    0.405404 |            0 |
+-------------+--------------+
set timestamp = default, autocommit = default;

## test WARN_ON_FAIL when set user variable
set @st_test3 = time('900:00:00');
set @st_test4 = 'a' + 1;
Warnings:
Warning	1292	Truncated incorrect DOUBLE value: 'a'
select @st_test3, @st_test4;
+------------------+-----------+
| @st_test3        | @st_test4 |
+------------------+-----------+
| 838:59:59.000000 |         1 |
+------------------+-----------+
set autocommit = 'a' + 1;
ERROR 01000: Truncated incorrect DOUBLE value

select @@innodb_strict_mode;
+----------------------+
| @@innodb_strict_mode |
+----------------------+
|                    1 |
+----------------------+
set innodb_strict_mode = false;
select @@innodb_strict_mode;
+----------------------+
| @@innodb_strict_mode |
+----------------------+
|                    0 |
+----------------------+
set innodb_strict_mode = true;
select @@innodb_strict_mode;
+----------------------+
| @@innodb_strict_mode |
+----------------------+
|                    1 |
+----------------------+

select @@_optimizer_gather_stats_on_load;
+-----------------------------------+
| @@_optimizer_gather_stats_on_load |
+-----------------------------------+
|                                 1 |
+-----------------------------------+
set _optimizer_gather_stats_on_load = false;
select @@_optimizer_gather_stats_on_load;
+-----------------------------------+
| @@_optimizer_gather_stats_on_load |
+-----------------------------------+
|                                 0 |
+-----------------------------------+
set _optimizer_gather_stats_on_load = true;
select @@_optimizer_gather_stats_on_load;
+-----------------------------------+
| @@_optimizer_gather_stats_on_load |
+-----------------------------------+
|                                 1 |
+-----------------------------------+

select @@sql_mode;
+-------------------------------------------------------+
| @@sql_mode                                            |
+-------------------------------------------------------+
| STRICT_ALL_TABLES,NO_ZERO_IN_DATE,NO_AUTO_CREATE_USER |
+-------------------------------------------------------+
SET sql_mode=(SELECT CONCAT(@@sql_mode, ',PIPES_AS_CONCAT,NO_ENGINE_SUBSTITUTION'));
select @@sql_mode;
+----------------------------------------------------------------------------------------------+
| @@sql_mode                                                                                   |
+----------------------------------------------------------------------------------------------+
| PIPES_AS_CONCAT,STRICT_ALL_TABLES,NO_ZERO_IN_DATE,NO_AUTO_CREATE_USER,NO_ENGINE_SUBSTITUTION |
+----------------------------------------------------------------------------------------------+

select @@global.lock_wait_timeout;
+----------------------------+
| @@global.lock_wait_timeout |
+----------------------------+
|                   31536000 |
+----------------------------+
select @@session.lock_wait_timeout;
+-----------------------------+
| @@session.lock_wait_timeout |
+-----------------------------+
|                    31536000 |
+-----------------------------+

set global lock_wait_timeout := 10000;
select @@global.lock_wait_timeout;
+----------------------------+
| @@global.lock_wait_timeout |
+----------------------------+
|                      10000 |
+----------------------------+

set @@global.lock_wait_timeout := 10001;
select @@global.lock_wait_timeout;
+----------------------------+
| @@global.lock_wait_timeout |
+----------------------------+
|                      10001 |
+----------------------------+

set global lock_wait_timeout := (select 10002 from dual);
select @@global.lock_wait_timeout;
+----------------------------+
| @@global.lock_wait_timeout |
+----------------------------+
|                      10002 |
+----------------------------+

set @@lock_wait_timeout := 10003;
select @@session.lock_wait_timeout;
+-----------------------------+
| @@session.lock_wait_timeout |
+-----------------------------+
|                       10003 |
+-----------------------------+

set @@session.lock_wait_timeout := 10004;
select @@session.lock_wait_timeout;
+-----------------------------+
| @@session.lock_wait_timeout |
+-----------------------------+
|                       10004 |
+-----------------------------+

set session lock_wait_timeout := 10004;
select @@session.lock_wait_timeout;
+-----------------------------+
| @@session.lock_wait_timeout |
+-----------------------------+
|                       10004 |
+-----------------------------+

set session lock_wait_timeout := (select 10006 from dual);
select @@session.lock_wait_timeout;
+-----------------------------+
| @@session.lock_wait_timeout |
+-----------------------------+
|                       10006 |
+-----------------------------+

set global lock_wait_timeout := 31536000;
select @@global.lock_wait_timeout;
+----------------------------+
| @@global.lock_wait_timeout |
+----------------------------+
|                   31536000 |
+----------------------------+

