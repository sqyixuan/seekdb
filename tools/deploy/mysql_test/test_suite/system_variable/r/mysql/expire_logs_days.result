set global expire_logs_days = default;
select name,value,default_value from oceanbase.DBA_OB_SYS_VARIABLES where NAME = "expire_logs_days";
name	value	default_value
expire_logs_days	0	0
set global expire_logs_days = 1;
select name,value,default_value from oceanbase.DBA_OB_SYS_VARIABLES where NAME = "expire_logs_days";
name	value	default_value
expire_logs_days	1	0
set global expire_logs_days = 0;
select name,value,default_value from oceanbase.DBA_OB_SYS_VARIABLES where NAME = "expire_logs_days";
name	value	default_value
expire_logs_days	0	0
