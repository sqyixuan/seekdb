set global log_bin_trust_function_creators = default;
select name,value,default_value from oceanbase.DBA_OB_SYS_VARIABLES where NAME = "log_bin_trust_function_creators";
name	value	default_value
log_bin_trust_function_creators	0	0
set global log_bin_trust_function_creators = 1;
select name,value,default_value from oceanbase.DBA_OB_SYS_VARIABLES where NAME = "log_bin_trust_function_creators";
name	value	default_value
log_bin_trust_function_creators	1	0
set global log_bin_trust_function_creators = 0;
select name,value,default_value from oceanbase.DBA_OB_SYS_VARIABLES where NAME = "log_bin_trust_function_creators";
name	value	default_value
log_bin_trust_function_creators	0	0
