result_format: 4

select IFNULL(max(t1.request_id)-min(t1.request_id)+1,0) = count(1) from (select request_id from oceanbase.v$ob_sql_audit order by request_id limit 100) t1;
+--------------------------------------------------------------+
| IFNULL(max(t1.request_id)-min(t1.request_id)+1,0) = count(1) |
+--------------------------------------------------------------+
|                                                            1 |
+--------------------------------------------------------------+
