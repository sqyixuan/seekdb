--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: wenkai.cwk
# owner group: SQL2
set global log_slave_updates = default;
select name,value,default_value from oceanbase.DBA_OB_SYS_VARIABLES where NAME = "log_slave_updates";
set global log_slave_updates = ON;
select name,value,default_value from oceanbase.DBA_OB_SYS_VARIABLES where NAME = "log_slave_updates";
set global log_slave_updates = OFF;
select name,value,default_value from oceanbase.DBA_OB_SYS_VARIABLES where NAME = "log_slave_updates";
set log_slave_updates = ON;
show variables like '%log_slave_updates%';
set log_slave_updates = OFF;
show variables like '%log_slave_updates%';