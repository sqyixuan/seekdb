--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: yibo.tyf
#owner group: sql1
#description: 测试mysql系统变量，相关需求:

--result_format 4

##1.have_query_cache
show variables like 'have_query_cache';

--error 1238
set have_query_cache='YES';
--error 1238
set global have_query_cache='YES';

##2.query_cache_limit
show variables like 'query_cache_limit';

set global query_cache_limit=1048576;
set global query_cache_limit=default;

--error 1229
set query_cache_limit=0;

##3.query_cache_min_res_unit
show variables like 'query_cache_min_res_unit';

set global query_cache_min_res_unit=4096;
set global query_cache_min_res_unit=default;

--error 1229
set query_cache_limit=default;

##4.query_cache_size
show variables like 'query_cache_size';

set global query_cache_size=1048576;
set global query_cache_size=default;

--error 1229
set query_cache_size=default;

##5.query_cache_type
show variables like 'query_cache_type';

--error 1238
set query_cache_type='ON';
--error 1238
set global query_cache_type=2;

##6.query_cache_wlock_invalidate
show variables like 'query_cache_wlock_invalidate';

set global query_cache_wlock_invalidate=1;
set global query_cache_wlock_invalidate=default;

set query_cache_wlock_invalidate=1;
show variables like 'query_cache_wlock_invalidate';
set query_cache_wlock_invalidate=default;
show variables like 'query_cache_wlock_invalidate';