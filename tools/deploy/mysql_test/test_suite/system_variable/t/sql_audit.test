alter system flush plan cache global;
alter system set enable_sql_audit = false;
alter system set enable_perf_event = true;
--sleep 3
connection default;
select * from t_sql_audit order by c;
select query_sql, sql_id, event is null, p1text is null, p1 is null, p2text is null, p2 is null, p3text is null, p3 is null, level is null, wait_class_id is null, `wait_class#` is null,
       wait_class is null, state is null, wait_time_micro is null, total_wait_time_micro is null, total_waits is null, rpc_count is null, application_wait_time is null, concurrency_wait_time is null,
       user_io_wait_time is null, schedule_time is null, row_cache_hit is null, fuse_row_cache_hit is null, bloom_filter_cache_hit is null, block_cache_hit is null, disk_reads is null,
       memstore_read_row_count is null, ssstore_read_row_count is null, data_block_read_cnt is null, data_block_cache_hit is null, index_block_read_cnt is null, index_block_cache_hit is null,
       blockscan_block_cnt is null, blockscan_row_cnt is null, pushdown_storage_filter_row_cnt is null from oceanbase.gv$ob_sql_audit where query_sql like 'select * from t_sql_audit order by c';

########################## enable_sql_audit = false, enable_perf_event = false  ###################

connection con;
alter system flush sql audit global;
alter system flush plan cache global;
alter system set enable_sql_audit = false;
alter system set enable_perf_event = false;
--sleep 3
connection default;
select * from t_sql_audit order by c;
select query_sql, sql_id, event is null, p1text is null, p1 is null, p2text is null, p2 is null, p3text is null, p3 is null, level is null, wait_class_id is null, `wait_class#` is null,
       wait_class is null, state is null, wait_time_micro is null, total_wait_time_micro is null, total_waits is null, rpc_count is null, application_wait_time is null, concurrency_wait_time is null,
       user_io_wait_time is null, schedule_time is null, row_cache_hit is null, fuse_row_cache_hit is null, bloom_filter_cache_hit is null, block_cache_hit is null, disk_reads is null,
       memstore_read_row_count is null, ssstore_read_row_count is null, data_block_read_cnt is null, data_block_cache_hit is null, index_block_read_cnt is null, index_block_cache_hit is null,
       blockscan_block_cnt is null, blockscan_row_cnt is null, pushdown_storage_filter_row_cnt is null from oceanbase.gv$ob_sql_audit where query_sql like 'select * from t_sql_audit order by c';



connection default;
drop table t_sql_audit;

connection con;
alter system flush sql audit global;
set global ob_sql_audit_percentage = 3;
alter system set enable_sql_audit = true;
alter system set enable_perf_event = true;
--sleep 3
--replace_column 1 # 3 # 4 # 8 #
show parameters like 'enable_sql_audit';
--replace_column 1 # 3 # 4 # 8 #
show parameters like 'enable_perf_event';
