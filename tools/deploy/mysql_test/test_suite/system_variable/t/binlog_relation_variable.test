--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: yibo.tyf
#owner group: sql1
#description: 测试兼容mysql的binlog相关的系统变量

##1.binlog_format
show variables like 'binlog_format';
--error 1238
set binlog_format = 'ROW';
--error 1238
set global binlog_format = default;

##2.binlog_checksum
show variables like 'binlog_checksum';
--error 1238
set binlog_checksum = 'CRC32';
--error 1238
set global binlog_checksum = default;

##3.binlog_rows_query_log_events
show variables like 'binlog_rows_query_log_events';
--error 1238
set binlog_rows_query_log_events = 'ROW';
--error 1238
set global binlog_rows_query_log_events = default;

##4.log_bin
show variables like 'log_bin';
--error 1238
set log_bin = 0;
--error 1238
set global log_bin = default;

##5.server_id
show variables like 'server_id';
--error 1229
set server_id = 0;
set global server_id = default;

##6.server_uuid
--disable_result_log
show variables like 'server_uuid';
--enable_result_log
--error 1238
set server_uuid = 'ABD';
--error 1238
set global server_uuid = 'ABD';
select length(value) from oceanbase.__all_sys_variable where name = 'server_uuid';