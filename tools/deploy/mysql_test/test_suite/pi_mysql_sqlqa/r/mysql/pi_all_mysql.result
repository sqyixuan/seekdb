drop database if exists pi1;
create database pi1;
use pi1;
#pi-1-1 有参数
select pi(1);
ERROR 42000: Incorrect parameter count in the call to native function 'pi'
select pi('a');
ERROR 42000: Incorrect parameter count in the call to native function 'pi'
select pi('*');
ERROR 42000: Incorrect parameter count in the call to native function 'pi'
#pi-1-2 无参数
select pi();
pi()
3.141593
#pi-2-1-1 select 精准位数查询
select     pi()    +    0.000000;
pi()    +    0.000000
3.141593
select     pi()    +    0.0000000;
pi()    +    0.0000000
3.1415927
select     pi()    +    0.00000000;
pi()    +    0.00000000
3.14159265
select     pi()    +    0.000000000;
pi()    +    0.000000000
3.141592654
select     pi()    +    0.0000000000;
pi()    +    0.0000000000
3.1415926536
#最高到11位
select     pi()    +    0.00000000000;
pi()    +    0.00000000000
3.14159265359
create table t1 (id int,name char(20),yy double);
insert into t1 values (1,'zhangsan',pi()),(1,'lisi',3.13999),(2,'wangwu',3.15000),(2,'maliu',3);
insert into t1 values (3,'zhangsan',3.5),(3,'lisi',pi()),(4,'wangwu',pi()),(4,'maliu',pi());
insert into t1 values (5,'zhangsan',3.00),(5,'lisi',3.15),(6,'wangwu',pi()),(6,'maliu',2.9999);
# pi-2-1-2  where
select   *   from   t1   where   yy   =    pi()  order  by  pi()  desc limit 0,1;
id	name	yy
1	zhangsan	3.141592653589793
select   *   from   t1   where   yy   >    pi()  order  by  pi()  asc  limit 1,3;
id	name	yy
3	zhangsan	3.5
5	lisi	3.15
select   *   from   t1   where   yy   >=   pi()  order  by  pi()  desc limit 0,10;
id	name	yy
1	zhangsan	3.141592653589793
2	wangwu	3.15
3	zhangsan	3.5
3	lisi	3.141592653589793
4	wangwu	3.141592653589793
4	maliu	3.141592653589793
5	lisi	3.15
6	wangwu	3.141592653589793
select   *   from   t1   where   yy   <    pi()  order  by  pi()  desc limit 0,5;
id	name	yy
1	lisi	3.13999
2	maliu	3
5	zhangsan	3
6	maliu	2.9999
select   *   from   t1   where   yy   <=   pi()  order  by  pi()  asc  limit 1,2;
id	name	yy
1	lisi	3.13999
2	maliu	3
select   *   from   t1   where   yy   !=   pi()  order  by  pi()  desc limit 0,3;
id	name	yy
1	lisi	3.13999
2	wangwu	3.15
2	maliu	3
select   *   from   t1   where   yy   <>   pi()  order  by  pi()  asc  limit 0,2;
id	name	yy
1	lisi	3.13999
2	wangwu	3.15
# pi-2-1-3  order by
select * from t1 where yy != pi() and id >1 order by pi() asc limit 0,4;
id	name	yy
2	wangwu	3.15
2	maliu	3
3	zhangsan	3.5
5	zhangsan	3
select * from t1 where yy != pi() order by pi() desc limit 0,5;
id	name	yy
1	lisi	3.13999
2	wangwu	3.15
2	maliu	3
3	zhangsan	3.5
5	zhangsan	3
# pi-2-1-4 group by
select * from t1 where id > 1 group by pi();
id	name	yy
2	wangwu	3.15
select name,yy,id from t1 group by pi() order by yy asc;
name	yy	id
zhangsan	3.141592653589793	1
select * from t1 where yy > pi() group by id order by pi();
id	name	yy
2	wangwu	3.15
3	zhangsan	3.5
5	lisi	3.15
# pi-2-1-5 group by having
select name,yy,id from t1 group by id having yy!=pi() order by yy;
name	yy	id
zhangsan	3	5
wangwu	3.15	2
zhangsan	3.5	3
select * from t1 where  yy !=  pi()  group by id having yy<pi() order by pi();
id	name	yy
1	lisi	3.13999
5	zhangsan	3
6	maliu	2.9999
# pi-2-1-6 like
select   *   from   t1   where   yy   like  '3.%'  order  by  pi()  asc  limit 1,1;
id	name	yy
1	lisi	3.13999
select   *   from   t1   where   yy   like  '%14%' order  by  pi()  desc limit 0,5;
id	name	yy
1	zhangsan	3.141592653589793
3	lisi	3.141592653589793
4	wangwu	3.141592653589793
4	maliu	3.141592653589793
6	wangwu	3.141592653589793
select   *   from   t1   where   yy   like  'pi()' order  by  pi()  asc  limit 1,3;
id	name	yy
drop table t1;
# case when
create table t1(c1 int,c2 double,c3 float);
insert into t1 values(1,pi(),3.1),(2,3.1415,pi()),(3,2.9999,3.1415),(4,pi(),pi());
select c1,c2,c3,case c3 when pi() then 3.15159 else pi() end as new_c3 from  t1;
c1	c2	c3	new_c3
1	3.141592653589793	3.1	3.141593
2	3.1415	3.14159	3.141593
3	2.9999	3.1415	3.141593
4	3.141592653589793	3.14159	3.141593
select c1,c2,c3,case when c2=pi() then 1 else 0 end as new_c2 from t1;
c1	c2	c3	new_c2
1	3.141592653589793	3.1	1
2	3.1415	3.14159	0
3	2.9999	3.1415	0
4	3.141592653589793	3.14159	1
select c1,c2,c3,case when c3>=pi() and c3<3.1416 then 1 else 0 end as new_c3 from t1;
c1	c2	c3	new_c3
1	3.141592653589793	3.1	0
2	3.1415	3.14159	1
3	2.9999	3.1415	0
4	3.141592653589793	3.14159	1
drop table t1;
