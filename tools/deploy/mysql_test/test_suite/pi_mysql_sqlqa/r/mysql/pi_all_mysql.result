select  name  from  t2  where  tid  <=  (select  id  from  t1  where  yy  >  pi()) order by tid asc  limit 0,1;
name
zhangsan
select  name  from  t2  where  tid  !=  (select  id  from  t1  where  yy  =  pi()) order by tid asc limit 0,1;
name
wangwu
select  name  from  t2  where  tid  <>  (select  id  from  t1  where  yy  =  pi()) order by tid desc limit 0,2;
