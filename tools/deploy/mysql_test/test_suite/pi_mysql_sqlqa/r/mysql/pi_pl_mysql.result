# 有参数
drop   table        if   exists   t1;
drop   function   if   exists   func1;
create table t1(aa double,bb double);
create function func1(a double) returns double
begin
declare  i int;
set  i  =  3;
if    i<a   then
insert into t1 values(pi()+a,pi()-a);
end if;
insert into t1 values(pi(),pi());
return pi();
end//
