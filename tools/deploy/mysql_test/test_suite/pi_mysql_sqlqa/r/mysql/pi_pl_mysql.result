create table t1 (aa double,bb int);
create procedure pro1()
begin
declare  i   int;
set    i  =  1;
while  i  <round(pi())
do
insert into t1 values(pi()+i,i);
set i=i+1;
end  while;
select sum(aa) from t1;
end//
