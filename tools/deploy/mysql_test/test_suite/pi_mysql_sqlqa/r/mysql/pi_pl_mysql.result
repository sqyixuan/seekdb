#  有参数
drop   table        if   exists   t1;
drop   function   if   exists   func1;
create table t1(aa int,bb varchar(50));
create function func1(a double)  returns double
begin
declare i int;
set i =1;
while i<a
do
insert into t1 values(i,concat(a,i));
set i=i+1;
end while;
return  pi();
end//
select func1(pi());
func1(pi())
