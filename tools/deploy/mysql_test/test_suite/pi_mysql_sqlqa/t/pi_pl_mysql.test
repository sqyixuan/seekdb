--disable_warnings
drop database if exists pi1;
--enable_warnings
create database pi1;
use pi1;

--echo  #    pi-6-1  function
--echo   #    无参数
drop   table      if   exists   t1;
drop   function   if   exists   func1;
create table  t1 (aa  double , bb double);
delimiter //;
create  function  func1()   returns  double
begin
      declare  i    int;
      set   i = 1;
      if    i < pi()  then
        insert into t1 values(pi(),pi()+pi());
      end if;
        return pi();
end//
delimiter ;//
select func1();
select   *   from   t1;



--echo    #  无参数
drop   table        if   exists   t1;
drop   function   if   exists   func1;
create table t1(a double);
delimiter //;
create function func1() returns int
begin
    declare i double;
    set i = pi();
    insert into t1 values(i);
    return round(pi());
end//
delimiter ;//
select func1();
select * from t1;


--echo    #  有参数
drop   table        if   exists   t1;
drop   function   if   exists   func1;
create table t1(aa int,bb varchar(50));
delimiter //;
create function func1(a double)  returns double
begin
      declare i int;
      set i =1;
      while i<a
      do
           insert into t1 values(i,concat(a,i));
           set i=i+1;
      end while;
      return  pi();
end//
delimiter ;//
select func1(pi());
select * from t1;


--echo    # 有参数

drop   table        if   exists   t1;
drop   function   if   exists   func1;
create table t1(aa double,bb double);
delimiter //;
create function func1(a double) returns double
begin
        declare  i int;
        set  i  =  3;
        if    i<a   then
        insert into t1 values(pi()+a,pi()-a);
        end if;
        insert into t1 values(pi(),pi());
        return pi();
end//
delimiter ;//
select func1(pi());
select * from t1;
drop function func1;
drop table t1;




--echo    #  pi-6-2  procedure
--echo    #  无参数
drop  table     if exists t1;
drop  procedure if exists pro1;
delimiter //;

create procedure pro1()
begin
    declare i double;
    set i = pi();
    create table t1(a double);
    insert into t1 values(i);
    select * from t1;
end//

delimiter ;//
call pro1();
select  *  from  t1;


--echo    #  无参数
drop   table     if   exists   t1;
drop   procedure if   exists   pro1;
create table t1 (aa double,bb int);
delimiter //;
create procedure pro1()
begin
        declare  i   int;
        set    i  =  1;
        while  i  <round(pi())
        do
             insert into t1 values(pi()+i,i);
             set i=i+1;
        end  while;
        select sum(aa) from t1;
end//
delimiter ;//
call pro1();
select * from t1;


--echo    #  有参数  if
drop   table     if   exists   t1;
drop   procedure if   exists   pro1;
create table t1(aa double,bb double);
delimiter //;
create procedure pro1(a double)
begin
        declare  i int;
        set  i  =  3;
        if    i<a   then
        insert into t1 values(pi()+a,pi()-a);
        end if;
        insert into t1 values(pi(),pi());
end//
delimiter ;//
call   pro1(pi());
select   *   from  t1;


--echo    #  有参数 while
drop   table     if   exists   t1;
drop   procedure if   exists   pro1;
create table t1(aa int,bb varchar(50));
delimiter //;
create procedure pro1(a double)
begin
      declare i int;
      set i =1;
      while i<a
      do
           insert into t1 values(i,concat(a,i));
           set i=i+1;
      end while;
end//
delimiter ;//
call pro1(pi());
select * from t1;
drop procedure pro1;
drop table t1;

