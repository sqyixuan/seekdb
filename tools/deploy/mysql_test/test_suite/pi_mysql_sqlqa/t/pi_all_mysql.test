--echo      # pi-2-2-6  date类型
create   table   t1   (a date);
--error  1292
insert   into    t1   VALUES  (pi());
drop     table   t1;

--echo      # pi-2-2-7  time类型
create   table   t1   (a time);
insert   into    t1   VALUES   (pi());
SELECT    *      FROM    t1;
drop     table   t1;

--echo	# datatime类型
create   table   t1   (a datetime);
--error  1292
insert   into    t1   VALUES  (pi());
drop     table   t1;

--echo	# timestamp类型
create   table   t1   (a timestamp);
--error  1292
insert   into    t1   VALUES  (pi());
drop     table   t1;

--echo	# year类型
create   table   t1   (a timestamp);
--error  1292
insert   into    t1   VALUES  (pi());
drop     table   t1;

--echo	#  bit类型
create   table   t1   (a bit);
--error  1406
insert   into    t1   VALUES  (pi());
drop     table   t1;


create table t1(id int,name char(20),yy double);
insert into t1 values (1,'zhangsan',pi()),(1,'lisi',pi()),(2,'wangwu',pi()),(2,'maliu',pi());
select  *  from  t1;

--echo  #pi-2-3-1    update 单列
update   t1  set   yy  =  3  where  yy  =  pi() limit 1;
select * from t1;
update   t1  set   yy  =  3  where  yy  =  pi()  and  name  =  'zhangsan';
select  *  from  t1;
--echo  # pi-2-3-2    多列
update   t1  set   yy  = 3;
select * from  t1;
update   t1  set   yy  =  pi();
select  *  from  t1;
--echo  # pi-2-4-1    delete 单行
delete   from  t1  where  yy  =  pi() and name = 'maliu';
select  *  from  t1;
--echo  # pi-2-4-2    多行
delete   from  t1  where  yy  =  pi();
select  *  from  t1;

--echo  # pi-2-5      truncate
insert into t1 values (1,'zhangsan',pi()),(1,'lisi',pi()),(2,'wangwu',pi()),(2,'maliu',pi());
truncate t1;
select   *   from   t1;
desc  t1;

--echo   # pi-2-6      replace
replace   into  t1  values  (1,'zhangsan',pi());
replace   into  t1  (id,name,yy)  values  (1,'zhangsan',pi());
drop table  t1;

--echo    #   pi-3-1视图  select 
create   table  t1  (id int,name char(20),yy double);
create   view   v1   as   select   *   from   t1;
insert   into   v1   values   (1,'zhangsan',pi()),(1,'lisi',3.13999),(2,'wangwu',3.15000),(2,'maliu',3);
select    *     from   v1;

--echo     #  pi-3-1-2    where
select   *   from   v1   where   yy   =   pi() order  by  yy  desc limit 0,1;
select   *   from   v1   where   yy   >   pi() order  by  yy  asc  limit 0,5 ;
select   *   from   v1   where   yy   <   pi() order  by  yy  asc  limit 1,3;
select   *   from   v1   where   yy   !=  pi() order  by  yy  desc limit 0,2;

--echo      # pi-3-1-3    order by
select * from v1 where yy != pi() order by pi() asc limit 0,10;
select * from v1 where yy != pi() order by pi() desc limit 1,5;


--echo      # pi-2-1-4 group by
select name,yy,id from v1 group by id order by pi() asc limit 0,2;


--echo      # pi-2-1-5 group by having
select name,yy,id from v1 group by id having yy!=pi() order by pi();

--echo      # pi-2-1-6 like
select   *   from   v1   where   yy   like  '3.%'  order  by  pi()  desc limit 0,1;
select   *   from   v1   where   yy   like  '%14%' order  by  pi()  asc limit 0,10;
select   *   from   v1   where   yy   like  'pi()' order  by  pi()  desc limit 1,3;

drop   table   t1;
drop   view    v1;

--echo      # pi-3-2-1     int类型
create   table   t1   (a int , b int , c int );
create   view    v1   as   select  *  from  t1;
insert   into    v1   values   (pi(),pi()+pi(),pi()*pi()-pi());
select    *      from    v1;
drop     table   t1;
drop     view    v1;

--echo      #  pi-3-2-2    double  类型
create   table   t1   (a double , b double ,c double);
create   view    v1   as   select  *  from  t1;
insert   into    v1   values   (pi(), pi()/pi(),pi()/pi()+pi());
select    *      from    v1;
drop     table   t1;
drop     view    v1;

--echo      #  pi-3-2-3     float  类型
create   table   t1   (a float , b float , c float);
create   view    v1   as   select  *  from  t1;
insert   into    v1   values   (1-pi(),pi(),2*pi());
select    *      from    v1;
drop     table   t1;
drop     view    v1;

--echo      #  pi-3-2-4      char类型
create   table   t1   (a char(30) , b char(30), c char(30));
create   view    v1   as   select  *  from  t1;
insert   into    v1   values   (pi(),'1+pi()','a+pi()');
select    *      from    v1;
drop     table   t1;
drop     view    v1;

--echo      #  pi-3-2-5      varchar类型
create   table   t1   (a varchar(60),b varchar(60),c varchar(60));
create   view    v1   as   select  *  from  t1;
insert   into    v1   values   (pi()+pi(),pi(),'pi()+pi()');
select    *      from    v1;
drop     table   t1;
drop     view    v1;

--echo      #  pi-3-2-6      date类型
create   table   t1   (a date);
create   view    v1   as   select  *  from  t1;
--error 1292
insert   into    v1   values   (pi());
drop     table   t1;
drop     view    v1;

--echo      #  pi-3-2-7      time类型
create   table   t1   (a time);
create   view    v1   as   select  *  from  t1;
insert   into    v1   values   (pi());
select    *      from    v1;
drop     table   t1;
drop     view    v1;


create table t1(id int,name char(20),yy double);
create view  v1 as select * from t1;
insert into v1 values (1,'zhangsan',pi()),(1,'lisi',pi()),(2,'wangwu',3.14),(2,'maliu',pi());
select  *  from  v1;

--echo      # pi-3-3-1 update   单列
update   v1  set   yy  =  3  where  yy  =  pi()  and  name  =  'zhangsan';
select  *  from  v1;
--echo      # pi-3-3-2  多列
update   v1  set   yy  =  pi();
select  *  from  v1;
--echo      # pi-3-4-1    delete 单行
delete   from  v1  where  yy  =  pi() and name = 'maliu';
select  *  from  v1;
--echo      # pi-3-4-2    多行
delete   from  v1  where  yy  =  pi();
select  *  from  v1;

--echo      # pi-3-5      truncate
insert into v1 values (1,'zhangsan',pi()),(1,'lisi',pi()),(2,'wangwu',pi()),(2,'maliu',pi());
--error 1146 
truncate v1;
select   *   from   v1;
desc  v1;

--echo      # pi-3-6      replace
replace   into  v1  values  (1,'zhangsan',pi());
replace   into  v1  (id,name,yy)  values  (1,'zhangsan',pi());
drop  table  t1;
drop  view   v1;


create   table t1   (id int,yy double);
insert   into  t1   values(1,pi()),(2,3.1415),(3,3.1399),(4,3),(5,pi());
create   table t2   (tid int,name char(20));
insert   into  t2   values(1,'zhangsan'),(2,'wangwu'),(3,'maliu'),(4,'tianqi');
select * from t1,t2 where t1.id=t2.tid;

--echo     # pi-3-7 多表查询  3-7-1 join on
select * from t1 inner join t2 on t1.id = t2.tid;
select * from t1 inner join t2 on t1.id = t2.tid order by pi();
select * from t1 inner join t2 on t1.id = t2.tid where yy<pi() order by pi() asc;
select * from t1 inner join t2 on t1.id = t2.tid group by pi() order by pi() desc;
select * from t1 inner join t2 on t1.id = t2.tid where yy!=pi() group by pi() order by pi() asc;
select * from t1 inner join t2 on t1.id = t2.tid where id<pi() group by id having yy<pi() order by pi() desc;

--echo    #  pi-3-7-2    left join
select * from t1 left join t2 on t1.id = t2.tid;
select * from t1 left join t2 on t1.id = t2.tid order by pi();
select * from t1 left join t2 on t1.id = t2.tid where id<pi() order by pi() asc;
select * from t1 left join t2 on t1.id = t2.tid group by pi() order by pi() desc;
select * from t1 left join t2 on t1.id = t2.tid where yy<>pi() group by pi() order by pi() asc;
select * from t1 left join t2 on t1.id = t2.tid where yy<pi() group by id having yy<pi() order by pi() desc;

--echo    #  pi-3-7-3    right join
select * from t1 right join t2 on t1.id = t2.tid;
select * from t1 right join t2 on t1.id = t2.tid order by pi();
select * from t1 right join t2 on t1.id = t2.tid where yy<pi() order by pi() asc;
select * from t1 right join t2 on t1.id = t2.tid group by pi() order by pi() desc;
select * from t1 right join t2 on t1.id = t2.tid where yy!=pi() group by pi() order by pi() asc;
select * from t1 right join t2 on t1.id = t2.tid where id<pi() group by id having yy<>pi() order by pi() desc;


--echo    #  pi-3-7-4    full join  #mysql不支持 ob支持
select * from t1 full  join t2 on t1.id = t2.tid;
drop tables t1,t2; 

create table t1(id int,yy double);
insert into t1 values(1,pi()),(2,3.6),(3,3.1399);

create table t2(tid int,name char(20));
insert into t2 values(1,'zhangsan'),(2,'wangwu'),(3,'maliu');

--echo    #  pi-3-8 子查询 3-8-1  带in关键字子查询
select  *  from  t2  where  tid  in (select  id  from  t1  where  yy  <  pi());

--echo    #  pi-3-8-2   带比较运算符的子查询

select  name  from  t2  where  tid  =   (select  id  from  t1  where  yy  =  pi()) order by tid desc limit 0,1;
select  name  from  t2  where  tid  >   (select  id  from  t1  where  yy  >  pi()) order by tid asc limit 0,3 ;
select  name  from  t2  where  tid  <   (select  id  from  t1  where  yy  <  pi()) order by tid desc limit 0,1 ;
select  name  from  t2  where  tid  >=  (select  id  from  t1  where  yy  <  pi()) order by tid desc limit 0,4;
select  name  from  t2  where  tid  <=  (select  id  from  t1  where  yy  >  pi()) order by tid asc  limit 0,1;
select  name  from  t2  where  tid  !=  (select  id  from  t1  where  yy  =  pi()) order by tid asc limit 0,1;
select  name  from  t2  where  tid  <>  (select  id  from  t1  where  yy  =  pi()) order by tid desc limit 0,2;


--echo    #  pi-3-8-3   带exists的子查询
select  *  from  t2  where  exists (select  id  from  t1  where yy  <  pi()) order by tid desc limit 0,2;

--echo    #  pi-3-8-4   带any的子查询
select  *  from  t2  where  tid  >  any  (select  id  from  t1  where  yy  <  pi()) order by tid asc limit 0,1;
drop tables t1,t2;

--echo    #  pi-4 函数嵌套  4-1 concat
select  concat  (pi(),atan(1));
select  concat  (pi(),'abc');
select  concat  (pi(),123);
select  concat  (pi(),'++');
select  concat  (pi(),'张');
select  concat  (pi()+pi()*1000,atan(1)+floor(pi()));
select  concat  (pi()+atan(1)+123,'abc'+'张');

--echo    #  pi-4-3 ceil
select  ceil(pi());
select  ceil(pi()+atan(pi()));
select  ceil(pi()*pi()*1000%pi()-pi()+pi());
select  ceil(concat  (pi()+pi()*1000,atan(1)+floor(pi())));

--echo    #  pi-4-4 round
select  round(pi());
select  round(pi()+ceil(pi()));
select  round(pi()*atan(pi())*10000+pi()%pi()-pi());
select  round(concat  (pi()+atan(1)+123,'abc'+'张'));

--echo    #  pi-4-5 floor
select  floor(pi());
select  floor(pi()+ceil(pi())-round(pi()));
select  floor(pi()*ceil(pi())+atan(pi())*pi()-pi()%round(pi()));
select  floor(concat((pi()*pi()*1000%pi()-pi()+pi()),(pi()*atan(pi())*10000+pi()%pi()-pi())));


--echo    #  pi-4-6 cast
--error 1064
select  cast(pi() as int);
--echo  #mysql执行结果报错,OB执行成功
select  cast(pi() as double);

select  cast(pi() as float);
--error 1064
select  cast(pi() as varchar);
select  cast(pi() as char);
select  cast(pi()+pi()*pi()*10000 as char);
select  cast(pi() as date);
select  cast(pi() as datetime);
--error 1064
select  cast(pi() as timestamp);

select  cast(pi() as year);
--error 1064
select  cast(pi() as bit);
select  cast(pi() as decimal);
select  cast(pi()*atan(pi())+floor(pi()) as date);
select  cast(pi() as time);
select  cast(pi()+concat  (pi()+pi()*1000,atan(1)+floor(pi())) as time);


--echo    #  pi-4-7 abs
select  abs(pi());
select  abs(pi()-pi()-pi());
select  abs(-pi());
select  abs(cast(pi()+pi()*pi()*10000 as char));
select  abs(-ceil(concat  (pi()+pi()*1000,atan(1)+floor(pi()))));
select  abs(-floor(concat((pi()*pi()*1000%pi()-pi()+pi()),(pi()*atan(pi())*10000+pi()%pi()-pi()))));

--echo    #  pi-4-8 
select substr(pi(),6);
select substr(pi()+abs(-ceil(concat  (pi()+pi()*1000,atan(1)+floor(pi())))),10);
select substr(pi(),3,6);
select substr(pi()*cast(pi()+concat  (pi()+pi()*1000,atan(1)+floor(pi())) as time),1,100);
select substr(floor(concat((pi()*pi()*1000%pi()-pi()+pi()),(pi()*atan(pi())*10000+pi()%pi()-pi()))),1);

--echo    #  pi-4-9
select hex(pi());
select mod(pi(),3);

create  table  t1  (c1  int,c2 char(20),c3 double);
insert  into  t1  values  (1,'abc',pi()),(2,'张',pi()*ceil(pi())),(3,'123',pi()*1000),(4,'a1b2c3',abs(-pi()*atan(pi()))),(5,'a王1',pi());
--echo    #  pi4-10 聚合函数 4-10-1  sum
select  sum(c1),sum(c2),sum(c3)   from  t1;
select  sum(c1+c2+c3) from t1;
select  sum(pi()) from t1;
select  sum(pi()+ceil(pi())+atan(pi())+floor(pi()));
select  sum(floor(concat((pi()*pi()*1000%pi()-pi()+pi())+(pi()*atan(pi())*10000+pi()%pi()-pi()))));

--echo    #  pi4-10-2 avg
select  avg(c1),avg(c2),avg(c3) from t1;
select  avg(pi()) from t1;
select  avg(pi()+atan(pi())+ceil(pi())+floor(pi()));
select  avg(abs(-floor(concat((pi()*pi()*1000%pi()-pi()+pi()),(pi()*atan(pi())*10000+pi()%pi()-pi())))));

--echo    #  pi4-10-3 max
select  max(c1),max(c2),max(c3) from t1;
select  max(pi()) from t1;
select  max(pi()+atan(pi())+ceil(pi())+floor(pi()));
select  max(substr(pi(),3,6)+floor(pi()*ceil(pi())+atan(pi())*pi()-pi()%round(pi())));

--echo    #  pi4-10-4 min
select  min(c1),min(c2),min(c3) from t1;
select  min(pi()) from t1;
select  min(pi()+ceil(pi())+round(pi())+floor(pi()));
select  min(ceil(pi()*pi()*1000%pi()-pi()+pi())+round(pi()*atan(pi())*10000+pi()%pi()-pi()));

--echo    #  pi4-10-5 count
select count(c1),count(c2),count(c3) from t1;
select count(pi()) from t1;
select count(pi()+ceil(pi())+round(pi())+floor(pi()));
select count(ceil(pi()*pi()*1000%pi()-pi()+pi())+round(pi()*atan(pi())*10000+pi()%pi()-pi()));
drop    table   t1;

--echo    #  pi-5运算符   5-1算术运算符  5-1-1  +
select  pi() +  pi();
select  pi() +  atan(1);
select  pi() +  1111111;
select  pi() +  'aaaaaa';
select  pi() +  '中';
select  pi() +  0;
select  pi() +  null;

--echo    #  pi5-1-2   -
select  pi()  -  pi();
select  pi()  -  floor(pi());
select  pi()  -  3333333;
select  pi()  -  'qwertyu';
select  pi()  -  '前';
select  pi()  -  0;
select  pi()  -  null;

--echo    #  pi5-1-3   *
select  pi()  *  pi();
select  pi()  *  ceil(pi());
select  pi()  *  100000;
select  pi()  *  'zxcvbn';
select  pi()  *  '后';
select  pi()  *  0;
select  pi()  *  null;

--echo    #  pi5-1-4   /
select  pi()  /  pi();
select  pi()  /  round(pi());
select  pi()  /  0.31415926;
select  pi()  /  'asdfgh';
select  pi()  /  '左';
select  pi()  /  0;
select  pi()  /  null;

--echo    #  pi5-1-5   %
select  pi()*100000000  %  pi();
select  pi()  %  length(pi());
select  pi()  %  1;
select  pi()  %  'a';
select  pi()  %  '右';
select  pi()  %  0;
select  pi()  %  null;

--echo	  # mod
select  pi()*1000  mod  pi();
select  pi()  mod  length(pi());
select  pi()  mod  1;
select  pi()  mod  'a';
select  pi()  mod  '右';
select  pi()  mod  0;
select  pi()  mod  null;

select  pi()*pi()/pi()*1000000%pi()-pi()+pi()%1 mod pi();
select  pi()*length(pi())/round(pi())+ceil(pi())-floor(pi())%1 mod pi();

--echo    #  pi5-2  逻辑运算符  5-2-1 not
select  not   pi();

--echo    #  pi5-2-2   and
select  pi()  and  pi();
select  pi()  and  1;
select  pi()  and  'a';
select  pi()  and  '/';
select  pi()  and  '州';
select  pi()  and  null;

--echo    #  pi5-2-3   or
select  pi()  or   pi();
select  pi()  or   1;
select  pi()  or   'a';
select  pi()  or   '/';
select  pi()  or   '州';
select  pi()  or   null;

--echo    #  pi5-2-4  xor
select  pi()  xor  pi();
select  pi()  xor  1;
select  pi()  xor  'a';
select  pi()  xor  '/';
select  pi()  xor  '州';
select  pi()  xor  null;

--echo    #  pi5-3  比较运算符  5-3-1 =
select  pi()   =   pi();
--echo  #OB与MYSQL 执行结果不一致 BUG 
#select  pi()   =   3.141593;
select  pi()   =   null;

--echo    #  pi5-3-2  >
select  pi()   >   pi();
select  pi()   >   3.141593;
select  pi()   >   floor(pi());
select  pi()   >   'a';
select  pi()   >   '一';
select  pi()   >   '+';
select  pi()   >   null;

--echo    #  pi5-3-3  >=
select  pi()   >=   pi();
--echo  #OB与MYSQL 执行结果不一致
#select  pi()   >=   3.141593;
select  pi()   >=   floor(pi());
select  pi()   >=   'a';
select  pi()   >=   '二';
select  pi()   >=   '+';
select  pi()   >=   null;

--echo    #  pi5-3-4  <
select  pi()   <   pi();
--echo  #OB与MYSQL 执行结果不一致
#select  pi()   <   3.141593;
select  pi()   <   round(pi());
select  pi()   <   'a';
select  pi()   <   '三';
select  pi()   <   '+';
select  pi()   <   null;

--echo    #  pi5-3-5  <=
select  pi()   <=   pi();
select  pi()   <=   3.141593;
select  pi()   <=   round(pi());
select  pi()   <=   'a';
select  pi()   <=   '四';
select  pi()   <=   '+';
select  pi()   <=   null;

--echo    #  pi5-3-6  !=
select  pi()   !=   pi();
--echo  #OB与MYSQL 执行结果不一致
#select  pi()   !=   3.141593;
select  pi()   !=   round(pi());
select  pi()   !=   'a';
select  pi()   !=   '五';
select  pi()   !=   '+';
select  pi()   !=   null;

--echo    #  pi5-3-7  <>
select  pi()   <>   pi();
--echo  #OB与MYSQL 执行结果不一致
#select  pi()   <>   3.141593;
select  pi()   <>   round(pi());
select  pi()   <>   'a';
select  pi()   <>   '六';
select  pi()   <>   '+';
select  pi()   <>   null;

drop database pi1;

