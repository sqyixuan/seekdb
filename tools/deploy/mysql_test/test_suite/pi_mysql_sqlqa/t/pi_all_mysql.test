--disable_warnings
drop database if exists pi1;
--enable_warnings
create database pi1;
use pi1;


--echo #pi-1-1 有参数
--error 1582
select pi(1);
--error 1582
select pi('a');
--error 1582
select pi('*');

--echo #pi-1-2 无参数
select pi();
--echo #pi-2-1-1 select 精准位数查询
select     pi()    +    0.000000;
select     pi()    +    0.0000000;
select     pi()    +    0.00000000;
select     pi()    +    0.000000000;
select     pi()    +    0.0000000000;
--echo #最高到11位
select     pi()    +    0.00000000000;

create table t1 (id int,name char(20),yy double);
insert into t1 values (1,'zhangsan',pi()),(1,'lisi',3.13999),(2,'wangwu',3.15000),(2,'maliu',3);
insert into t1 values (3,'zhangsan',3.5),(3,'lisi',pi()),(4,'wangwu',pi()),(4,'maliu',pi());
insert into t1 values (5,'zhangsan',3.00),(5,'lisi',3.15),(6,'wangwu',pi()),(6,'maliu',2.9999);

--echo # pi-2-1-2  where
select   *   from   t1   where   yy   =    pi()  order  by  pi()  desc limit 0,1;
select   *   from   t1   where   yy   >    pi()  order  by  pi()  asc  limit 1,3;
select   *   from   t1   where   yy   >=   pi()  order  by  pi()  desc limit 0,10;
select   *   from   t1   where   yy   <    pi()  order  by  pi()  desc limit 0,5;
select   *   from   t1   where   yy   <=   pi()  order  by  pi()  asc  limit 1,2;
select   *   from   t1   where   yy   !=   pi()  order  by  pi()  desc limit 0,3;
select   *   from   t1   where   yy   <>   pi()  order  by  pi()  asc  limit 0,2;


--echo      # pi-2-1-3  order by
select * from t1 where yy != pi() and id >1 order by pi() asc limit 0,4;
select * from t1 where yy != pi() order by pi() desc limit 0,5;

--echo      # pi-2-1-4 group by
select * from t1 where id > 1 group by pi();
select name,yy,id from t1 group by pi() order by yy asc;
select * from t1 where yy > pi() group by id order by pi();

--echo      # pi-2-1-5 group by having
select name,yy,id from t1 group by id having yy!=pi() order by yy;
select * from t1 where  yy !=  pi()  group by id having yy<pi() order by pi();

--echo      # pi-2-1-6 like
select   *   from   t1   where   yy   like  '3.%'  order  by  pi()  asc  limit 1,1;
select   *   from   t1   where   yy   like  '%14%' order  by  pi()  desc limit 0,5;
select   *   from   t1   where   yy   like  'pi()' order  by  pi()  asc  limit 1,3;
drop table t1;


--echo	    # case when
create table t1(c1 int,c2 double,c3 float);
insert into t1 values(1,pi(),3.1),(2,3.1415,pi()),(3,2.9999,3.1415),(4,pi(),pi());
select c1,c2,c3,case c3 when pi() then 3.15159 else pi() end as new_c3 from  t1;
select c1,c2,c3,case when c2=pi() then 1 else 0 end as new_c2 from t1;
select c1,c2,c3,case when c3>=pi() and c3<3.1416 then 1 else 0 end as new_c3 from t1;
drop table t1;


--echo      # pi-2-2-1 insert int 类型
create   table   t1   (a int);
insert   into    t1   values   (pi());
select    *      from    t1;
drop     table   t1;

--echo      # pi-2-2-2  double 类型
create   table   t1   (a double);
insert   into    t1   VALUES   (pi());
SELECT    *      FROM    t1;
drop     table   t1;

--echo      # pi-2-2-3  float 类型
create   table   t1   (a float);
insert   into    t1   VALUES   (pi());
SELECT    *      FROM    t1;
drop     table   t1;

