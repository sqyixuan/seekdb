--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: link.zt
#owner group: sql1
connect (my_obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection default;

--disable_query_log
--source mysql_test/include/index_quick_major.inc

--real_sleep 3
--disable_warnings
drop table if exists t1;
--enable_warnings
--enable_query_log

create table t1(pk int primary key, a int);
create index iloveidx on t1(a);

insert into t1 values(1,0),(2,0),(4,0),(3,0);
insert into t1 values(0,0);
insert into t1 values(5,0),(6,0),(8,0),(7,0);

update t1 set a=1 where pk = 0;
update t1 set a=1 where pk = 1;


delete from t1 where pk=0;
replace into t1(pk, a) values(0,2);
delete from t1 where pk=2;
replace into t1(pk, a) values(2,2);


delete from t1 where pk = 2;
delete from t1 where pk = 1;
delete from t1 where pk = 5;

--source mysql_test/include/check_all_idx_ok.inc

--sorted_result
select * from t1;
select  /*+ index(t1 iloveidx) */ * from t1;

--source mysql_test/include/tenant_major_freeze.inc
--source mysql_test/include/wait_daily_merge.inc

--sorted_result
select * from t1;
select  /*+ index(t1 iloveidx) */ * from t1;

insert into t1 values(100,0),(200,0),(101,0);
insert into t1 values(102,0);
insert into t1 values(104,0),(103,0);
insert into t1 values(2,0);

update  t1 set a=1 where pk = 7;
update  t1 set a=1 where pk = 3;

delete from t1 where pk=0;
delete from t1 where pk=7;
delete from t1 where pk=103;

--sorted_result
select * from t1;
select  /*+ index(t1 iloveidx) */ * from t1;

--source mysql_test/include/tenant_major_freeze.inc
--source mysql_test/include/wait_daily_merge.inc
--sorted_result
select * from t1;
select  /*+ index(t1 iloveidx) */ * from t1;

insert into t1 values(0,0),(7,0);
insert into t1 values(307,0),(103,0);
insert into t1 values(300,0),(305,0),(301,0);
insert into t1 values(302,0);
insert into t1 values(304,0),(303,0);

update  t1 set a=1 where pk = 7;
update  t1 set a=1 where pk = 3;
update  t1 set a=1 where pk = 102;
update  t1 set a=1 where pk = 101;

delete from t1 where pk=4;
delete from t1 where pk=200;
delete from t1 where pk=300;
--sorted_result
select * from t1;
drop table t1;

create table t1 (id int primary key, k int);
insert into t1 values(1,1);
alter table t1 add column f int default 0;
alter table t1 add key(f);
create index f_t1 on t1(f);
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_tenant_major_merge.inc
--sorted_result
select * from t1;
drop table t1;
connection default;

create table t1 (id int primary key, k int);
insert into t1 values(2,2);
create index k_t1 on t1(k);
--source mysql_test/include/check_all_idx_ok.inc
alter table t1 modify k BIGINT;
--source mysql_test/include/tenant_major_freeze.inc
--source mysql_test/include/wait_tenant_major_merge.inc
drop table t1;

create table t1 (c1 int primary key, c2 int);
insert into t1 values(1,1);
--source mysql_test/include/tenant_major_freeze.inc
--source mysql_test/include/wait_tenant_major_merge.inc
alter table t1 add column c3 int default 0;
update t1 set c2 = 2 where c1 = 1;
create index c3_t on t1 (c3);
--source mysql_test/include/check_all_idx_ok.inc
drop table t1;
