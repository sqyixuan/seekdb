# owner: bin.lb
# owner group: sql2
# error in static typing engine, since enum_to_str() not added.

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1 (sex enum('male','female') not null default 'male');

insert into t1 (sex) values ('male');
insert into t1 (sex) values ('female');

select * from t1 union select * from t1 order by sex desc;
