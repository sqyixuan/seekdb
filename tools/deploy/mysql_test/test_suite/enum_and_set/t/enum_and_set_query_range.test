create index i3 on t1(size, tag);
SELECT  t1.id, t1.size FROM t1 WHERE t1.SIZE <=> 1;
SELECT  t1.id, t1.tag FROM t1 WHERE t1.tag <=> 1;

SELECT  t1.id, t1.size FROM t1 WHERE t1.SIZE in ('small', 'large');
SELECT  t1.id, t1.tag FROM t1 WHERE t1.tag in ('winter', 'men');

SELECT  t1.id, t1.size FROM t1 WHERE (t1.SIZE, t1.TAG) = (1, 2);
SELECT  t1.id, t1.size FROM t1 WHERE (t1.SIZE, t1.TAG) = ('small', 'winter');

drop table t1, t2;

CREATE TABLE `t1` (
  `c0` enum('aaa','bbb') DEFAULT NULL,
  `c1` float DEFAULT NULL,
  KEY `i410` (`c0`) BLOCK_SIZE 16384 LOCAL
)
 partition by key(c1, c0)
(partition `p0`,
partition `p1`,
partition `p2`);

SELECT * FROM t1 WHERE (t1.c0,35) IN (('aaa',-2075954));
SELECT * FROM t1 WHERE t1.c0 IN ('aaa',-2075954);
SELECT * FROM t1 WHERE t1.c0 = 'aaa';
drop table t1;

create table t1(c1 enum('a') primary key);
select * from t1 where c1 = 'a';
drop table t1;
