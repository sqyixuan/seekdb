#owner: zuojiao.hzj
#owner group: SQL4
#description: 验证enum和set column的create,alter,show相关结果
##tags: datatype

set @ori_mode = @@sql_mode;
--disable_warnings
drop database if exists ytsdb;
--enable_warnings
create database ytsdb;
use ytsdb;

########################  test for create enum column ###########################################

--echo
--echo
--echo ##### case 1: test for empty string value #####

create table e1_1(c1 enum(""));
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table e1_1;
create table s1_1(c1 set(""));
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table s1_1;
create table e1_2(c1 enum("1","","2"));
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table e1_2;
create table s1_2(c1 set("1","","2"));
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table s1_2;

--echo
--echo
--echo ##### case 2: test for trim tail space #####
