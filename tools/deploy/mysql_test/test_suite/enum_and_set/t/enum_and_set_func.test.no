insert into test_enum1 value(null, 11, -1, 1, -1, -1,1,110,1,1,1, 1.0,11.0, 2.0,33.0, 3.0,33.0, "2016-01-01 00:01:02", "2016-01-02 00:01:02", "1999-01-01", "02:02:02", "1901", "100varchar", "20aaa", /*"tinytext", "text", "mtext", "longtext",*/ 0x43, 4, 2, 4);

