drop table t_set;
create table t_set(c1 int primary key, c2 set("b", "100", '3', ''));
insert into t_set value(1,1),(2,2),(3,4),(4,8);
insert into t_set(c1) value(5);

select field(c2, 'a', 'b', 'c'), field(c2, null, 'a', 'b'), field(c2, 'a', null, 'b'), c2, c2+1-1 from t_set;
select field(c2, 2, 3, 100), field(c2, null, 2, 3), field(c2, 2, null, 3), c2, c2+1-1 from t_set;
select field(c2, 2, '3', 100), field(c2, null, 2, '3'), field(c2, 2, null, '3'), c2, c2+1-1 from t_set;

select field('100', c2, 'a', 'b', 'c'), field('100', null, c2, 'b'), field('100', 'a', null, c2), c2, c2+1-1 from t_set;
select field(1, c2, 3, 100), field(1, null, c2, 3), field(1, c2, null, 3), c2, c2+1-1 from t_set;
select field(4, c2, 2, '3', 100), field(4, null, c2, '3'), field(4, 2, null, c2), c2, c2+1-1 from t_set;

