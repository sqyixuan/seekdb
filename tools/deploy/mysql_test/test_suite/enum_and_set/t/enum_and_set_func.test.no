select c_enum_t or null, c_enum_t or c_tinyint, c_enum_t or c_smallint, c_enum_t or c_mint, c_enum_t or c_int, c_enum_t or c_bigint, c_enum_t or c_utinyint, c_enum_t or c_usmallint, c_enum_t or c_umint, c_enum_t or c_uint, c_enum_t or c_ubigint, c_enum_t or c_float, c_enum_t or c_double, c_enum_t or c_ufloat, c_enum_t or c_udouble, c_enum_t or c_dec, c_enum_t or c_udec, c_enum_t or c_datetime, c_enum_t or c_timestamp, c_enum_t or c_date , c_enum_t or c_time, c_enum_t or c_year, c_enum_t or c_varchar, c_enum_t or c_char, /*c_enum_t or c_tinytext, c_enum_t or c_text, c_enum_t or c_mtext, c_enum_t or c_ltext,*/ c_enum_t or c_bit, c_enum_t or c_enum, c_enum_t or c_set from test_enum1;
select null or c_enum_t , c_tinyint or c_enum_t , c_smallint or c_enum_t , c_mint or c_enum_t , c_int or c_enum_t , c_bigint or c_enum_t , c_utinyint or c_enum_t , c_usmallint or c_enum_t , c_umint or c_enum_t , c_uint or c_enum_t , c_ubigint or c_enum_t , c_float or c_enum_t , c_double or c_enum_t , c_ufloat or c_enum_t , c_udouble or c_enum_t , c_dec or c_enum_t , c_udec or c_enum_t , c_datetime or c_enum_t , c_timestamp or c_enum_t , c_date  or c_enum_t , c_time or c_enum_t , c_year or c_enum_t , c_varchar or c_enum_t , c_char or c_enum_t , /*c_tinytext or c_enum_t , c_text or c_enum_t , c_mtext or c_enum_t , c_ltext or c_enum_t ,*/ c_bit or c_enum_t , c_enum or c_enum_t , c_set or c_enum_t  from test_enum1;

