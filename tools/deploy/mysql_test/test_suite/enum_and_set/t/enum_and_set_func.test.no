create table test_enum(c1 int, c2 enum('-1', '23', '45'), c3 enum('-2', '3', '5'));
insert into test_enum value(1,1,1),(2,2,2), (3,3,3);
insert into test_enum value(5,5,5);
insert into test_enum(c1) value(4);
#---------------------------------greatest()------------------------------------#
select greatest('20', c2), greatest(20, c2), greatest('20', 2, c2), greatest(null, c2), greatest(c2, c3) from test_enum;

#---------------------------------least()------------------------------------#
select least('20', c2), least(20, c2), least('20', 2, c2), least(null, c2), least(c2,c3) from test_enum;

