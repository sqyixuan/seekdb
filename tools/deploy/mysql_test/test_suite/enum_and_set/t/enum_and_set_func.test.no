#---------------------------------str_to_date()------------------------------------#
drop table t_enum;
create table t_enum(c1 int primary key, c2 enum('01,01,2015', '%d', '%d,%m,%y', 'aaa'));
insert into t_enum value(1,1),(2,2),(3,3), (4,4);
insert into t_enum(c1) value(5);
select str_to_date('01,05,2013', c2), str_to_date(c2, '%d') from test_enum;

drop table t_enum;
create table t_enum(c1 int primary key, c2 enum('www.oceanbase.com', '.', 'ha!ha!ha!ha!ha', ''));
insert into t_enum value(1,1),(2,2),(3,3), (4,4);
insert into t_enum(c1) value(5);
select substring_index(c2, '.', 2), c2 from t_enum where c1=1 or c1=5;
select substring_index(c2, '.', -2), c2 from t_enum where c1=1 or c1=5;
select substring_index(c2, '!', 2), c2 from t_enum where c1=3 or c1=5;
select substring_index(c2, '!', 2), c2 from t_enum where c1=4 or c1=5;
select substring_index('ha.ha.ha.ha', c2, 2), c2 from t_enum where c1=2 or c1=5;

#---------------------------------timediff()------------------------------------#
drop table t_enum;
create table t_enum(c1 int primary key, c2 enum('07:00:00', '2016-01-01 08:00:00', '2016-01-01'));
insert into t_enum values(1,1),(2,2),(3,3),(4,4);
insert into t_enum(c1) values(5);
select timediff(c2, '2016-01-01'), timediff(c2, '2016-01-01 00:00:00'), timediff(c2, '00:00:00'), c2 from t_enum;
select timediff('2016-01-01', c2 ), timediff('2016-01-01 00:00:00', c2), timediff('00:00:00', c2), c2 from t_enum;

#---------------------------------year()------------------------------------#
select year(c2), c2 from t_enum;

--error 1659
create table tt_enum(c1 int primary key, c2 enum("b", "100", '3', '')) partition by hash(c2);
create table tt_enum(c1 int, c2 enum("b", "100", '3', '') primary key) partition by key(c2);

drop table test_enum1;
create table test_enum1(c_null int default null, c_tinyint tinyint, c_smallint smallint, c_mint mediumint, c_int int, c_bigint bigint, c_utinyint tinyint unsigned, c_usmallint smallint  unsigned, c_umint mediumint unsigned, c_uint int unsigned, c_ubigint bigint unsigned, c_float float, c_double double, c_ufloat float unsigned, c_udouble double unsigned, c_dec decimal, c_udec decimal unsigned, c_datetime datetime, c_timestamp timestamp default '2016-01-01 00:01:02', c_date date, c_time time, c_year year, c_varchar varchar(16), c_char char(16), /* c_tinytext tinytext, c_text text, c_mtext mediumtext, c_ltext longtext,*/ c_bit bit(16), c_enum enum('2016-01-29 00:01:12', 'b', 'c'), c_set set('2016-01-29 00:01:11', 'b', 'c'), c_enum_t enum('2016-01-29 00:01:12', 'b', 'c'));
insert into test_enum1 value(null,11 , -1, 1, -1, -1,1,110,1,1,1, 1.0,11.0, 2.0,33.0, 3.0,33.0, "2016-01-01 00:01:02", "2016-01-02 00:01:02", "1999-01-01", "02:02:02", "1901", "100varchar", "20aaa", /*"tinytext", "text", "mtext", "longtext",*/ 0x43, 1, 1, 1);
