create table test_set1(c_tinyint tinyint, c_smallint smallint, c_mint mediumint, c_int int, c_bigint bigint, c_utinyint tinyint unsigned, c_usmallint smallint  unsigned, c_umint mediumint unsigned, c_uint int unsigned, c_ubigint bigint unsigned, c_float float, c_double double, c_ufloat float unsigned, c_udouble double unsigned, c_dec decimal, c_udec decimal unsigned, c_datetime datetime, c_timestamp timestamp default '2016-01-01 00:01:02', c_date date, c_time time, c_year year, c_varchar varchar(16), c_char char(16), /* c_tinytext tinytext, c_text text, c_mtext mediumtext, c_ltext longtext,*/ c_bit bit(16), c_enum enum('a', 'b', 'c'), c_set set('a', 'b', 'c'), c_set_t set('a', 'b', 'c'));
insert into test_set1 (c_set_t) value(1);
insert into test_set1 (c_set_t) value(null);

#---------------------------------sleep()------------------------------------#
select sleep(c_set_t) from test_set1 where c_set_t =1;
select sleep(c_set_t) from test_set1 where c_set_t !=1;

#---------------------------------default()------------------------------------#
create table t_set(c1 int primary key, c2 set('a', 'b', 'c'), c3 set('aa', 'bb', 'cc') default 'cc', c4 set('aa', 'bb', 'cc') not null);
--error 1364
select default(c4) from t_set;
select default(c2), default(c3), default(c2)+1, default(c3)+1, concat(default(c2), 'yy'), concat(default(c3), 'yy') from t_set;
drop table t_set;

#---------------------------------values()------------------------------------#
create table t_set(c1 int primary key, c2 set('a', 'b', 'c'));
insert into t_set values(1,1),(4,2);
insert into t_set values(1,2) on duplicate key update c1=values(c2);

#---------------------------------coalesce()------------------------------------#
insert into t_set(c1) values(3);
select 1 in (coalesce(null, c2)), 'a' in  (coalesce(null, c2)), c2+1-1, c2, coalesce(null, c2), coalesce(null, c2)+1 from t_set where c1 = 1;
select 1 in (coalesce(null, c2)), 'a' in  (coalesce(null, c2)), c2+1-1, c2, coalesce(null, c2), coalesce(null, c2)+1 from t_set where c1 = 3;
drop table t_set;

