#---------------------------------str_to_date()------------------------------------#
drop table t_set;
create table t_set(c1 int primary key, c2 set('01-01-2015', '%d', '%d-%m-%y', 'aaa'));
insert into t_set value(1,1),(2,2),(3,4), (4,8);
insert into t_set(c1) value(5);
select str_to_date('01,05,2013', c2), str_to_date(c2, '%d') from test_set;

drop table t_set;
create table t_set(c1 int primary key, c2 set('www.oceanbase.com', '.', 'ha!ha!ha!ha!ha', ''));
insert into t_set value(1,1),(2,2),(3,3), (4,4);
insert into t_set(c1) value(5);
select substring_index(c2, '.', 2), c2 from t_set where c1=1 or c1=5;
select substring_index(c2, '.', -2), c2 from t_set where c1=1 or c1=5;
select substring_index(c2, '!', 2), c2 from t_set where c1=3 or c1=5;
select substring_index(c2, '!', 2), c2 from t_set where c1=4 or c1=5;
select substring_index('ha.ha.ha.ha', c2, 2), c2 from t_set where c1=2 or c1=5;

#---------------------------------timediff()------------------------------------#
drop table t_set;
create table t_set(c1 int primary key, c2 set('07:00:00', '2016-01-01 08:00:00', '2016-01-01'));
insert into t_set values(1,1),(2,2),(3,4),(4,8);
insert into t_set(c1) values(5);
select timediff(c2, '2016-01-01'), timediff(c2, '2016-01-01 00:00:00'), timediff(c2, '00:00:00'), c2 from t_set;
select timediff('2016-01-01', c2 ), timediff('2016-01-01 00:00:00', c2), timediff('00:00:00', c2), c2 from t_set;

#---------------------------------year()------------------------------------#
select year(c2), c2 from t_set;

