select nullif(c_enum_t, null), nullif(c_enum_t, c_tinyint), nullif(c_enum_t, c_smallint), nullif(c_enum_t, c_mint), nullif(c_enum_t, c_int), nullif(c_enum_t, c_bigint), nullif(c_enum_t, c_utinyint), nullif(c_enum_t, c_usmallint), nullif(c_enum_t, c_umint), nullif(c_enum_t, c_uint), nullif(c_enum_t, c_ubigint), nullif(c_enum_t, c_float), nullif(c_enum_t, c_double), nullif(c_enum_t, c_ufloat), nullif(c_enum_t, c_udouble), nullif(c_enum_t, c_dec), nullif(c_enum_t, c_udec), nullif(c_enum_t, c_datetime), nullif(c_enum_t, c_timestamp), nullif(c_enum_t, c_date ), nullif(c_enum_t, c_time), nullif(c_enum_t, c_year), nullif(c_enum_t, c_varchar), nullif(c_enum_t, c_char), /*nullif(c_enum_t, c_tinytext), nullif(c_enum_t, c_text), nullif(c_enum_t, c_mtext), nullif(c_enum_t, c_ltext,*/ nullif(c_enum_t, c_bit), nullif(c_enum_t, c_enum), nullif(c_enum_t, c_set) from test_enum1;

