#---------------------------------not()------------------------------------#
insert into t_enum values(6,6);
select not(c2), c2+1-1 from t_enum;


#---------------------------------nullif()------------------------------------#
select nullif(c2, 3), nullif(c2, 33), nullif(c2, 'b'), nullif(c2, 'aaa'), nullif(c2,c2), nullif (null, c2), nullif(c2, null)  from t_enum;

#---------------------------------or()------------------------------------#
select c2 or 0, c2 or 1.0, c2 or 0.0, c2 or 'false', c2 or 'true', c2+1-1, c2 from t_enum;

#---------------------------------pow()------------------------------------#
select pow(2, c2), pow(c2, 2), pow(c2,-2), c2+1-1 from t_enum where c2 != 0;

#---------------------------------sign()------------------------------------#
select sign(c2), c2, c2+1-1, sign('b') from t_enum;

