# owner: zuojiao.hzj
# owner group: sql2
# tags: enumset, datatype
# description: test enum set with subschema
--result_format 4

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
drop database if exists new_enumset;
--enable_warnings

create database new_enumset;
use new_enumset;

--echo issue51194972: insert subquery
CREATE TABLE test1 (f1 set('first','second','third'),f2 set('one','two','three'));
create table test2(a int primary key,b varchar(100) );

explain INSERT INTO test2 VALUES((SELECT f1 FROM test1 WHERE f2>'admin2'),(SELECT f2 FROM test1 WHERE f1='test2'));
--error 1048
INSERT INTO test2 VALUES((SELECT f1 FROM test1 WHERE f2>'admin2'),(SELECT f2 FROM test1 WHERE f1='test2'));
drop table test1, test2;

--echo issue50713462: trigger collation
create TABLE t1 (a int not null primary key, b int);
ALTER TABLE t1 MODIFY COLUMN a SET('a1','a2','xx');

CREATE TRIGGER t1_before_update BEFORE UPDATE ON t1 FOR EACH ROW SET NEW.b = CONCAT("new a: ", NEW.a, " new b: ", NEW.b);
drop table t1;

