--echo ddl checksum issue
create table t1 (a set ('', 'ABC', '12321'), b int);
insert into t1 values (1, 1);
alter table t1 modify b varchar(20);
select * from t1;
drop table t1;

create table t1 (a enum ('', 'ABC', '12321'), b int);
insert into t1 values (1, 1);

alter table t1 modify b varchar(20);
select a+0, b from t1;
drop table t1;

create table t1 (a enum ('', 'ABC', '12321'), b int);
insert into t1 values (1, 1);

alter table t1 modify a  enum ('', 'ABC', '12321');
select a+0, b from t1;
drop table t1;

create table t1 (a enum ('', 'ABC', '12321'), b int);
insert into t1 values (1, 1);

alter table t1 modify a  enum ('', 'ABC', '1232');
select a+0, b from t1;
drop table t1;

create table t1 (a enum ('', 'ABC', '12321'), b int);
insert into t1 values (1, 1);
create table t2 as select * from t1;
select a+0,b from t2;
drop table t1,t2;

create table t1 (a set ('', 'ABC', '12321'), b int);
insert into t1 values (1, 1);

alter table t1 modify b varchar(20);
select a+0, b from t1;
drop table t1;

create table t1 (a set ('', 'ABC', '12321'), b int);
insert into t1 values (1, 1);

alter table t1 modify a  set ('', 'ABC', '12321');
select a+0, b from t1;
drop table t1;

create table t1 (a set ('', 'ABC', '12321'), b int);
insert into t1 values (1, 1);

alter table t1 modify a  set ('', 'ABC', '1232');
select a+0, b from t1;
drop table t1;

create table t1 (a set ('', 'ABC', '12321'), b int);
insert into t1 values (1, 1);
create table t2 as select * from t1;
select a+0,b from t2;
drop table t1,t2;

CREATE TABLE `t1` (
  `col_1193` set('Alice','Bob','Charlie','David') DEFAULT NULL,
  `col_1194` datetime NOT NULL DEFAULT '2024-12-11 00:00:00'
) DEFAULT CHARSET = binary;

explain select  nvl( t1.col_1194 , t1.col_1193 ) as r1 from t1;
drop table t1;

CREATE TABLE `t1` (
  `c0` float DEFAULT NULL,
  `c1` enum('aaa','bbb') DEFAULT NULL COMMENT 'asdf',
  `c2` enum('aaa','bbb') DEFAULT NULL COMMENT 'asdf',
  `c3` float(13,8) unsigned zerofill NOT NULL COMMENT 'asdf',
  PRIMARY KEY (`c3`),
  UNIQUE KEY `c3` (`c3`) BLOCK_SIZE 16384 LOCAL
) partition by key(c3) partitions 10;

explain UPDATE t1 SET    c1='aaa', c2=(t1.c1,'aaa',t1.c2) NOT IN (('aaa', t1.c1, "aaa"));
UPDATE t1 SET    c1='aaa', c2=(t1.c1,'aaa',t1.c2) NOT IN (('aaa', t1.c1, "aaa"));
explain UPDATE t1 SET    c1 = 'aaa', c2 = ( ( t1.c1, 'aaa') NOT IN ( ( 'aaa', t1.c1), ( t1.c1, t1.c1)) );
UPDATE t1 SET    c1 = 'aaa', c2 = ( ( t1.c1, 'aaa') NOT IN ( ( 'aaa', t1.c1), ( t1.c1, t1.c1)) );
drop table t1;

CREATE TABLE `t1` (
  `col_1246` set('Alice','Bob','Charlie','David') DEFAULT 'Alice',
  `col_1734` set('Alice','Bob','Charlie','David') character set binary
);
explain select * from t1 where  Cast(NULL AS CHAR) IN ( col_1246, col_1734 );
drop table t1;

create table t1(c2 set('a', 'b'));
explain select 1 from t1 where exists (select t1.c2 from dual);
drop table t1;

create table t1 (
`col_1756` set('Alice','Bob','Charlie','David') DEFAULT NULL
) DEFAULT CHARSET = binary;

explain SELECT replace(cast(ref_0.col_1756 AS CHAR), cast(NULL AS CHAR), '1') AS sc0 FROM t1 AS ref_0;
SELECT replace(cast(ref_0.col_1756 AS CHAR), cast(NULL AS CHAR), '1') AS sc0 FROM t1 AS ref_0;
drop table t1;

CREATE TABLE `t1` (
  `col_83` set('Alice','Bob','Charlie','David') NOT NULL DEFAULT 'Alice',
  `col_93` set('Alice','Bob','Charlie','David') DEFAULT NULL
) DEFAULT CHARSET = latin1;

explain SELECT ifnull(repeat(cast(ref_0.col_93 AS CHAR), cast(56 AS DECIMAL)), 1) FROM (t1 ref_0);
SELECT ifnull(repeat(cast(ref_0.col_93 AS CHAR), cast(56 AS DECIMAL)), 1) FROM (t1 ref_0);
drop table t1;

CREATE TABLE t1(c1 ENUM('a','2020-01-01') NULL, c2 SET('a','2020-01-01') NULL);
insert into t1 values (1, 1);
insert into t1 values (2, 2);
explain SELECT TO_DAYS(c1), TO_DAYS(c2) FROM t1 ;
SELECT TO_DAYS(c1), TO_DAYS(c2) FROM t1 ;
explain SELECT /*+opt_param('enable_enum_set_subschema', 'false')*/ TO_DAYS(c1), TO_DAYS(c2) FROM t1 ;
SELECT /*+opt_param('enable_enum_set_subschema', 'false')*/ TO_DAYS(c1), TO_DAYS(c2) FROM t1 ;
drop table t1;

drop database new_enumset;
