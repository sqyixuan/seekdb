# owner: zuojiao.hzj
# owner group: sql2
# tags: enumset, datatype
# description: test enum set with subschema
--result_format 4

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
drop database if exists new_enumset;
--enable_warnings

create database new_enumset;
use new_enumset;
create table t1 (c1 enum('abc', 'def'), c2 set('xyz','123'));
insert into t1 values (1, 2);

alter system set _enable_enum_set_subschema = false;
sleep 5;

explain select concat(c1, c2) from t1;
select concat(c1, c2) from t1;
explain outline select /*+opt_param('enable_enum_set_subschema', 'false')*/ concat(c1, c2) from t1;
select /*+opt_param('enable_enum_set_subschema', 'false')*/ concat(c1, c2) from t1;
explain outline select /*+opt_param('enable_enum_set_subschema', 'true')*/ concat(c1, c2) from t1;
select /*+opt_param('enable_enum_set_subschema', 'true')*/ concat(c1, c2) from t1;
explain outline select /*+opt_param('enable_enum_set_subschema', 'x')*/ concat(c1, c2) from t1;
select /*+opt_param('enable_enum_set_subschema', 'x')*/ concat(c1, c2) from t1;

alter system set _enable_enum_set_subschema = true;
sleep 5;

explain select concat(c1, c2) from t1;
select concat(c1, c2) from t1;
explain outline select /*+opt_param('enable_enum_set_subschema', 'false')*/ concat(c1, c2) from t1;
select /*+opt_param('enable_enum_set_subschema', 'false')*/ concat(c1, c2) from t1;
explain outline select /*+opt_param('enable_enum_set_subschema', 'true')*/ concat(c1, c2) from t1;
select /*+opt_param('enable_enum_set_subschema', 'true')*/ concat(c1, c2) from t1;
explain outline select /*+opt_param('enable_enum_set_subschema', 'x')*/ concat(c1, c2) from t1;
select /*+opt_param('enable_enum_set_subschema', 'x')*/ concat(c1, c2) from t1;

drop table t1;
drop database new_enumset;
