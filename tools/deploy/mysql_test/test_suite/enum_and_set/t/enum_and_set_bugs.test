      PRIMARY KEY (`col_79`),
      KEY `idx_23` (`col_71`) BLOCK_SIZE 16384 LOCAL,
      KEY `idx_24` (`col_72`, `col_73`) BLOCK_SIZE 16384 LOCAL
    ) ;


 CREATE TABLE `tbl_6` (
      `col_36` smallint(5) unsigned DEFAULT '27088',
      `col_37` double DEFAULT '3805.2986065916916',
      `col_38` enum('Alice','Bob','Charlie','David') COLLATE utf8mb4_unicode_ci NOT NULL,
      `col_39` year(4) NOT NULL,
