cREATE TABLE `tbl_12` (
      `col_44` time NOT NULL DEFAULT '19:51:55',
      `col_45` smallint(6) DEFAULT NULL,
      `col_46` smallint(5) unsigned NOT NULL,
      `col_47` bit(44) DEFAULT NULL,
      PRIMARY KEY (`col_46`, `col_44`),
      UNIQUE KEY `idx_16` (`col_46`, `col_45`) BLOCK_SIZE 16384 LOCAL,
      KEY `idx_14` (`col_45`, `col_46`, `col_47`) BLOCK_SIZE 16384 LOCAL
    ) DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 3 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
     partition by hash(col_46)
    (partition p0,
    partition p1,
    partition p2,
    partition p3,
    partition p4);


