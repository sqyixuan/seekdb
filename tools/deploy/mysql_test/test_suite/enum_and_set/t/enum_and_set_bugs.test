#owner: zuojiao.hzj
#owner group: SQL4
#description: 验证enum和set的bug
##tags: datatype
set @ori_mode = @@sql_mode;
--disable_warnings
drop database if exists ytsdb;
--enable_warnings
create database ytsdb;
use ytsdb;

--echo ############################# test for bug : #12561356 ###########################

### test primary key ###

create table t_12561356(c1 enum('c','b','a') primary key);
insert into t_12561356 values(1);
insert into t_12561356 values(2);
select * from t_12561356;

### test sort ###
truncate table t_12561356;
insert into t_12561356 values('a'),('b'),('c');
select * from t_12561356 order by c1;
select * from t_12561356 order by c1 desc;

### test relation operation of enum and set ###
create table t_12561356_1(c1 enum('c','b','a'), c2 enum('c','b','a'));
insert into t_12561356_1 values(1,3),(2,2),(3,1);
select c1, c2 , c1 > c2, c1 = c2, c1 < c2 from t_12561356_1;

--echo ############################# test for enum/set in information_schema.columns ###########################
create table columns_set(c1 enum('a','b','c'), c2 set('a','b','c'));
select table_name, data_type, column_type from information_schema.columns where table_name = 'columns_set';

--echo ############################# test for bug #12605919 ###########################
create table t_12605919(c1 int, c2 enum('a','b','c'));
insert into t_12605919 values(1,1);
insert into t_12605919 values(1,1);

create table t_12605919_1(c1 int, c2 set('a','b','c'));
insert into t_12605919_1 values(1,1);
insert into t_12605919_1 values(1,1);

--echo ############################# test for bug #12638416 ###########################
create table t_12638416(c1 enum('a','b','c'), c2 set('a','b','c'), c3 double, c4 decimal);
insert into t_12638416 values(1,1,1,1);
select c1 > c3, c1 > c4, c2 > c3, c2 > c4 from t_12638416;
select c1 from t_12638416 where c3 = (select c1 from t_12638416);
select c1 from t_12638416 where c3 = (select c2 from t_12638416);
select c1 from t_12638416 where c4 = (select c1 from t_12638416);
select c1 from t_12638416 where c4 = (select c2 from t_12638416);

--echo ############################# test for bug #30312479 ###########################
create table t_30312479(c1 enum('aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa', 'bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb', 'cccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccc'));
select data_type, column_type from information_schema.columns where table_name='t_30312479' and column_name='c1';
desc t_30312479;

--echo ############################# test for bug #36717487 ###########################
CREATE TABLE t_36717487 (W0_TEST0 CHAR(10), W0_TEST1 VARCHAR(10),W0_TEST2 TINYTEXT,W0_TEST3 TEXT, W0_TEST4 MEDIUMTEXT, W0_TEST5 LONGTEXT, W0_TEST6 ENUM('1','g'), W0_TEST7 SET('2','h'));
insert into t_36717487(`W0_TEST1`,`W0_TEST0`,`W0_TEST4`,`W0_TEST3`,`W0_TEST2`,`W0_TEST5`,`W0_TEST7`,`W0_TEST6`) values ('A0','A1','A2','A3','A4','A5','2','g');
--error 1265
insert into t_36717487(`W0_TEST1`,`W0_TEST0`,`W0_TEST4`,`W0_TEST3`,`W0_TEST2`,`W0_TEST5`,`W0_TEST7`,`W0_TEST6`) values ('A0','A1','A2','A3','A4','A5','1','h');
insert into t_36717487(`W0_TEST1`,`W0_TEST0`,`W0_TEST4`,`W0_TEST3`,`W0_TEST2`,`W0_TEST7`,`W0_TEST5`,`W0_TEST6`) values ('A0','A1','A2','A3','A4','2','A5','g');
insert into t_36717487(`W0_TEST7`,`W0_TEST6`) values ('2','g');
select * from t_36717487;
drop table t_36717487;

CREATE TABLE t_src (W0_TEST0 CHAR(10), W0_TEST1 VARCHAR(10),W0_TEST2 TINYTEXT,W0_TEST3 TEXT, W0_TEST4 MEDIUMTEXT, W0_TEST5 LONGTEXT, W0_TEST6 ENUM('1','g'), W0_TEST7 SET('2','h'));
CREATE TABLE t_dst (W0_TEST0 CHAR(10), W0_TEST1 VARCHAR(10),W0_TEST2 TINYTEXT,W0_TEST3 TEXT, W0_TEST4 MEDIUMTEXT, W0_TEST5 LONGTEXT, W0_TEST6 ENUM('1','g'), W0_TEST7 SET('2','h'));
insert into t_src(`W0_TEST1`,`W0_TEST0`,`W0_TEST4`,`W0_TEST3`,`W0_TEST2`,`W0_TEST5`,`W0_TEST7`,`W0_TEST6`) values ('A0','A1','A2','A3','A4','A5','2','g');
insert into t_dst(`W0_TEST1`,`W0_TEST0`,`W0_TEST4`,`W0_TEST3`,`W0_TEST2`,`W0_TEST5`,`W0_TEST7`,`W0_TEST6`) select `W0_TEST1`,`W0_TEST0`,`W0_TEST4`,`W0_TEST3`,`W0_TEST2`,`W0_TEST5`,`W0_TEST7`,`W0_TEST6` from t_src;
select * from t_dst;
drop table t_src;
drop table t_dst;

--echo ############################# test for bug #30567656 ###########################
create table t30567656(z0_test0 set('中文字符','123456','ABCabc','!@#$%^&*','2020-10-10','2020-10-10 10:10:10','10:10:10'),z0_test1 char(100));
insert into t30567656 values('中文字符','中文字符');
insert into t30567656 values('123456','123456');
insert into t30567656 values('ABCabc','ABC abc');
insert into t30567656 values('!@#$%^&*','!@#$%^&*');
insert into t30567656 values('2020-10-10','2020-10-10');
insert into t30567656 values('','');
insert into t30567656 values(null,null);
delimiter //;
CREATE FUNCTION SetFunction(setSQL char(100)) RETURNS varchar(100)
BEGIN
declare a set('中文字符 ','123456','ABCabc ','!@#$%^&*','2020-11-11');
select z0_test0 from t30567656 e where z0_test0 =setSQL into a;
return a;
end//
delimiter ;//
select SetFunction('中文字符') from dual;
select SetFunction('123456') from dual;
drop table t30567656;

SET sql_mode='STRICT_TRANS_TABLES,STRICT_ALL_TABLES';
CREATE TABLE Z0CASE(Z0_TEST0 VARCHAR(100), Z0_TEST1 VARCHAR(50),Z0_TEST2 INT);
INSERT INTO  Z0CASE (z0_test0,z0_test1,Z0_TEST2)VALUES(111,111,11);
INSERT INTO  Z0CASE (z0_test0,z0_test1,Z0_TEST2)VALUES('1111.1111','1111.1111',100);
INSERT INTO  Z0CASE (z0_test0,z0_test1,Z0_TEST2)VALUES('2011-11-11 11:11:11','2011-11-11 11:11:11',20);
INSERT INTO  Z0CASE (z0_test0,z0_test1,Z0_TEST2)VALUES(20111111,20111111,1);
INSERT INTO  Z0CASE (z0_test0,z0_test1,Z0_TEST2)VALUES(NULL,NULL,0);
INSERT INTO  Z0CASE (z0_test0,z0_test1,Z0_TEST2)VALUES(' ','',10);
--error 1265
ALTER TABLE Z0CASE MODIFY COLUMN z0_test0 SET('abc ABC','中文字符@!#$%^',' ') ;
select * from z0case;

SET sql_mode='';
DROP TABLE Z0CASE;
CREATE TABLE Z0CASE(Z0_TEST0 VARCHAR(100), Z0_TEST1 VARCHAR(50),Z0_TEST2 INT);
INSERT INTO  Z0CASE (z0_test0,z0_test1,Z0_TEST2)VALUES(111,111,11);
INSERT INTO  Z0CASE (z0_test0,z0_test1,Z0_TEST2)VALUES('1111.1111','1111.1111',100);
INSERT INTO  Z0CASE (z0_test0,z0_test1,Z0_TEST2)VALUES('2011-11-11 11:11:11','2011-11-11 11:11:11',20);
INSERT INTO  Z0CASE (z0_test0,z0_test1,Z0_TEST2)VALUES(20111111,20111111,1);
INSERT INTO  Z0CASE (z0_test0,z0_test1,Z0_TEST2)VALUES(NULL,NULL,0);
INSERT INTO  Z0CASE (z0_test0,z0_test1,Z0_TEST2)VALUES(' ','',10);
