create table t1
(c1 enum("","0","1","2","3","5","6","7","8","9"),c2 set("","0","1","2","3","5","6","7","8","9"));
create table t2
(a1 enum("","0","1","2","3","5","6","7","8","9"),a2 set("","0","1","2","3","5","6","7","8","9"));
insert into t1 values('0','1'),('1','2'),('2','3'),('3','3') ,('5','5');
insert into t2 values('0','1'),('1','2'),('2','3'),('3','3') ;
explain select  * from t1  where c1 in(select a2 from t2);
select  * from t1  where c1 in(select a1 from t2);
explain select  * from t1  where c1 in(select a2 from t2);
select  * from t1  where c1 in(select a2 from t2);
drop table t1,t2;

--echo issue 
--disable_warnings
--explain_protocol 0
--result_format 4
drop table if exists t1, t2;
create table t1(c1 enum ('alice', 'bob', 'tt'), c2 char(10), c3 set('test1', 'test2', 'test3'));
create table t2(c1 char(10));
insert into t1 values('alice', 'test', 'test1');
insert into t2 values('alice'), ('test'), ('test1');
--enable_warnings
--explain_protocol 2
select * from t1 where c2 in (select c1 from t2 where t1.c1 = 'alice');
select * from t1 where c2 in (select c1 from t2 where 'alice' = t1.c1);
select * from t1 where c2 in (select c1 from t2 where t1.c1 in ('alice', 'bob'));
select * from t1 where c2 in (select c1 from t2 where t1.c3 = 'test1');

update t1 set c2 = (select max(c1) from t2 where t1.c1 = t2.c1);
drop table if exists t1, t2;

