--echo case13 : test for decimal #####
--echo
--echo test for enum
create table t13_1(c1 enum('a','b','c'));
set @@sql_mode="STRICT_ALL_TABLES";
create table decimal_t(c1 decimal(30,10));

truncate decimal_t; truncate t13_1;
insert into decimal_t values(-1.1);
--error 1265
insert into t13_1 select * from decimal_t;
select * from t13_1;


truncate decimal_t; truncate t13_1;
insert into decimal_t values(0);
--error 1265
insert into t13_1 select * from decimal_t;
select * from t13_1;

truncate decimal_t; truncate t13_1;
insert into decimal_t values(1.1),(1.0);
insert into t13_1 select * from decimal_t;
select * from t13_1;

truncate decimal_t; truncate t13_1;
insert into decimal_t values(4.1),(4.0);
--error 1265
insert into t13_1 select * from decimal_t;
select * from t13_1;

truncate decimal_t; truncate t13_1;
insert into decimal_t values(18446744073709551616.1),(18446744073709551616.0);
