--echo ##### case11 : test for float #####
--echo
--echo ################### test for enum
create table t11_1(c1 enum('a','b','c'));
set @@sql_mode="STRICT_ALL_TABLES";
create table float_t(c1 float);

truncate float_t; truncate t11_1;
insert into float_t values(-1.1);
--error 1265
insert into t11_1 select * from float_t;
select * from t11_1;


truncate float_t; truncate t11_1;
insert into float_t values(0);
--error 1265
insert into t11_1 select * from float_t;
select * from t11_1;

truncate float_t; truncate t11_1;
insert into float_t values(1.1),(1.0);
insert into t11_1 select * from float_t;
select * from t11_1;

truncate float_t; truncate t11_1;
insert into float_t values(4.1),(4.0);
--error 1265
insert into t11_1 select * from float_t;
select * from t11_1;

truncate float_t; truncate t11_1;
insert into float_t values(18446744073709551616.1),(18446744073709551616.0);
--error 1265
insert into t11_1 select * from float_t;
select * from t11_1;

set @@sql_mode="";
truncate float_t; truncate t11_1;
insert into float_t values(-1.1);
insert into t11_1 select * from float_t;
select * from t11_1;


truncate float_t; truncate t11_1;
insert into float_t values(0);
insert into t11_1 select * from float_t;
select * from t11_1;

truncate float_t; truncate t11_1;
insert into float_t values(1.1),(1.0);
insert into t11_1 select * from float_t;
select * from t11_1;

truncate float_t; truncate t11_1;
insert into float_t values(4.1),(4.0);
insert into t11_1 select * from float_t;
select * from t11_1;

truncate float_t; truncate t11_1;
insert into float_t values(18446744073709551617.1),(18446744073709551617.0);
insert into t11_1 select * from float_t;
select * from t11_1;

--echo
--echo ################### test for set
create table t11_2(c1 set('a','b','c'));
set @@sql_mode="STRICT_ALL_TABLES";

truncate float_t; truncate t11_2;
insert into float_t values(-1.1);
--error 1265
