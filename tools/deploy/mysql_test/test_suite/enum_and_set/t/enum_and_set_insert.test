#owner: zuojiao.hzj
#owner group: SQL4
#description: 验证向enum和set column 插入数据时的表现
##tags: datatype
set @ori_mode = @@sql_mode;
--disable_warnings
drop database if exists ytsdb;
--enable_warnings
create database ytsdb;
use ytsdb;


--echo
--echo
--echo  ######################## test for different insert values ###########################
create table v_e1(c1 enum('a','b','c'));
insert into v_e1 values(1),(2),(3);
create table v_e2(c2 int, c1 enum('a','b','c'));
insert into v_e2(c1) values(1),(2),(3);
insert into v_e2 values(1, 1),(2, 2),(3, 3);
#create table v_e3(c1 enum('a','b','c') primary key);
#insert into v_e3 values(1),(2),(3);
create table v_e4(c2 int primary key, c1 enum('a','b','c'));
insert into v_e4 values(10, 1),(20, 2),(30, 3);
create table i_t(c1 int, c2 int);
insert into i_t values(1,1),(2,2);
insert into v_e4 select * from i_t;

--echo
--echo
--echo  ######################## test for replace ###########################
create table r_e1(c1 enum('a','b','c'));
replace into r_e1 values(1),(2),(3);
create table r_e2(c2 int, c1 enum('a','b','c'));
replace into r_e2(c1) values(1),(2),(3);
replace into r_e2 values(1, 1),(2, 2),(3, 3);
#create table r_e3(c1 enum('a','b','c') primary key);
#replace into r_e3 values(1),(2),(3);
create table r_e4(c2 int primary key, c1 enum('a','b','c'));
replace into r_e4 values(1, 1),(2, 2),(3, 3);
#replace into r_e4 select * from i_t;

--echo
--echo
--echo  ######################## test for update ###########################
create table u_e1(c1 enum('a','b','c'));
insert into u_e1 values(1),(2),(3) ON DUPLICATE KEY UPDATE c1=c1+1;
create table u_e2(c2 int, c1 enum('a','b','c'));
insert into u_e2(c1) values(1),(2),(3) ON DUPLICATE KEY UPDATE c1=c1+1;
insert into u_e2 values(1, 1),(2, 2),(3, 3) ON DUPLICATE KEY UPDATE c1=c1+1;
#create table u_e3(c1 enum('a','b','c') primary key);
#insert into u_e3 values(1),(2),(3);
create table u_e4(c2 int primary key, c1 enum('a','b','c'));
insert into u_e4 values(1, 1),(2, 2),(3, 3) ON DUPLICATE KEY UPDATE c1=c1+1;
#insert into u_e4 select * from i_t ON DUPLICATE KEY UPDATE u_e4.c1=u_e4.c1+1;

--echo
--echo
--echo  ######################## test for different date type ############################

--echo
--echo
--echo ##### case1 : test for integer date type #####
create table t1_1 (c1 enum('c', 'b', 'a'), c2 set('3','2','1'));
set @@sql_mode="STRICT_ALL_TABLES";
insert into t1_1 values(3, 3);
insert into t1_1 values(3, 0);
insert into t1_1 values(cast(3 as unsigned), cast(3 as unsigned));
insert into t1_1 values(cast(3 as unsigned), cast(0 as unsigned));
--error 1265
insert into t1_1 values(cast(0 as unsigned), cast(3 as unsigned));
--error 1265
insert into t1_1 values(0, 3);
--error 1265
insert into t1_1 values(3, -1);
--error 1265
insert into t1_1 values(-1, 3);
--error 1265
insert into t1_1 values(4, 3);
--error 1265
insert into t1_1 values(cast(4 as unsigned), cast(3 as unsigned));
--error 1265
insert into t1_1 values(3, 8);
--error 1265
insert into t1_1 values(cast(3 as unsigned), cast(8 as unsigned));
select * from t1_1;

set @@sql_mode="";
truncate t1_1;
insert into t1_1 values(3, 3);
insert into t1_1 values(3, 0);
insert into t1_1 values(0, 3);
insert into t1_1 values(3, -1);
insert into t1_1 values(-1, 3);
insert into t1_1 values(4, 3);
insert into t1_1 values(3, 8);
select * from t1_1;

create table t1_2(c1 enum('a','b','c'));
insert into t1_2 values(-1),(0),(8),(9),(10),(11),(12),(13),(14),(15);
##select * from t1_2;

create table t1_3(c1 set('a','b','c'));
insert into t1_3 values(-1),(0),(8),(9),(10),(11),(12),(13),(14),(15);
select * from t1_3;

--echo
--echo
--echo ##### case2 : test for string date type #####
set @@sql_mode = 'STRICT_ALL_TABLES';
create table t2_1(c1 enum('a','b','c'));
insert into t2_1 values('a'),('b'),('c');
select * from t2_1;
--error 1265
insert into t2_1 values('');

create table t2_2(c1 set('a','b','c'));
insert into t2_2 values('a'),('b'),('c');
insert into t2_2 values('a,b'),('a,c'),('b,c');
insert into t2_2 values('a,b,c');
insert into t2_2 values('a,a');
insert into t2_2 values('b,a');
insert into t2_2 values('');
select * from t2_2;
--error 1265
insert into t2_2 values('a,');
--error 1265
insert into t2_2 values(',');
--error 1265
insert into t2_2 values('a,,b');
