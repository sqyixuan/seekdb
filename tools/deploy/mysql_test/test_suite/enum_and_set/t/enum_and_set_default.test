#owner: zuojiao.hzj
#owner group: SQL4
#description: 验证向enum和set column不同default值的表现
##tags: datatype
set @ori_mode = @@sql_mode;
--disable_warnings
drop database if exists ytsdb;
--enable_warnings
create database ytsdb;
use ytsdb;


--echo
--echo
--echo ##### test for create table default value #####

--echo
--echo ## case 1 : test for NULL default value
create table cd1(c1 enum('a','b','c') default NULL);
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table cd1;
desc cd1;
--error 1067
create table cd2(c1 enum('a','b','c') default 'NULL');
--error 1067
create table cd3(c1 enum('a','b','c') not NULL default NULL);
--error 1067
create table cd4(c1 enum('a','b','c') not NULL default 'NULL');

create table cds1(c1 set('a','b','c') default NULL);
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table cds1;
desc cds1;
--error 1067
create table cds2(c1 set('a','b','c') default 'NULL');
--error 1067
create table cds3(c1 set('a','b','c') not NULL default NULL);
--error 1067
create table cds4(c1 set('a','b','c') not NULL default 'NULL');

--echo
--echo ## case 2 : test for different collation
set @@collation_connection = 'utf8mb4_general_ci';

