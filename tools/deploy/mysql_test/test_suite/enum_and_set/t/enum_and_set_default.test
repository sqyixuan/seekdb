--error 1067
alter table me2 modify c1 enum('a','b','c') default 0;
--error 1067
alter table me2 modify c1 enum('a','b','c') default 1;
--error 1067
alter table me2 modify c1 enum('a','b','c') default 97;


create table ms2(c1 set('a','b','c') default 'c,c,c', c2 int);
alter table ms2 modify c1 set('a','b','c') default 'a';
desc ms2;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table ms2;
alter table ms2 modify c1 set('a','b','c') default '';
desc ms2;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table ms2;
alter table ms2 modify c1 set('a','b','c') default 'a,a,a';
desc ms2;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table ms2;
alter table ms2 modify c1 set('a','b','c') default 'c,b,a';
desc ms2;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table ms2;
--error 1067
alter table ms2 modify c1 set('a','b','c') default 'c ,b ,a   ';
alter table ms2 modify c1 set('a ','b ','c ') default 'c,b,a';
desc ms2;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table ms2;
--error 1067
alter table ms2 modify c1 set('a','b','c') default 'c, b,a';
--error 1067
alter table ms2 modify c1 set('a','b','c') default 'c,b,d';
alter table ms2 modify c1 set('a','b','c') default 'a,a';
desc ms2;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table ms2;
alter table ms2 modify c1 set('a','b','c') default 'a,c,b,c';
desc ms2;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table ms2;
--error 1067
alter table ms2 modify c1 set('a','b','c') default 'a,d';
create table ms3(c1 set('a','','c'));
alter table ms3 modify c1 set('a','','c') default ',,,,,,';
desc ms3;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table ms3;
alter table ms3 modify c1 set('a','','c') default ',,a,,c,,';
desc ms3;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table ms3;

