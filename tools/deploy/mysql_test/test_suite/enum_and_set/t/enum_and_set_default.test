--echo
--echo ##### case : test for alter table default value #####

--echo
--echo ## case 1 : test for add column
create table ae1(c1 int);
alter table ae1 add column(c2 enum('a','b','c') default NULL);
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table ae1;
desc ae1;
--error 1067
alter table ae1 add column(c3 enum('a','b','c') default 'NULL');
--error 1067
alter table ae1 add column(c3 enum('a','b','c') not NULL default NULL);
--error 1067
alter table ae1 add column(c4 enum('a','b','c') not NULL default 'NULL');

create table as1(c1 int);
--error 1067
alter table as1 add column(c2 set('a','b','c') collate utf8mb4_bin default 'A');
alter table as1 add column(c2 set('a','b','c') collate utf8mb4_general_ci default 'A');
desc as1;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table as1;


--echo
--echo ## case 2 : test for modify column
create table me2(c1 enum('a','b','c'), c2 int);
alter table me2 modify c1 enum('a','b','c') default 0x61;
desc me2;
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table me2;
alter table me2 modify c1 enum('a','b','c') default 0b1100001;
desc me2;
