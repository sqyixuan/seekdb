--echo
--echo
--echo test for insert with default_expr / default_function
set @@sql_mode='STRICT_ALL_TABLES';
create table def_enum(c1 enum('a','b','c') NOT NULL, c2 int default 3);
## yyy bug
## insert into def_enum()values();
truncate def_enum;
insert into def_enum(c2) values(1);
select * from def_enum;
truncate def_enum;
insert into def_enum(c1, c2) values(default, default);
select * from def_enum;
## mysql bug:http://bugs.mysql.com/bug.php?id=84055
truncate def_enum;
insert into def_enum(c1, c2) values(default(c1), default(c1));
select * from def_enum;
truncate def_enum;
insert into def_enum(c1, c2) values(default(c2), default(c2));
select * from def_enum;
truncate def_enum;
insert into def_enum(c1, c2) values(default(c1), default(c2));
select * from def_enum;

create table def_set(c1 set('a','b','c') NOT NULL, c2 int default 3);
--error 1364
insert into def_set()values();
--error 1364
insert into def_set(c2) values(1);
--error 1364
insert into def_set(c1, c2) values(default, default);
truncate def_set;
insert into def_set(c1, c2) values(default(c2), default(c2));
select * from def_set;

set @@sql_mode='';
create table def1_enum(c1 enum('a','b','c') NOT NULL, c2 int default 3);
## yyy bug
## insert into def1_enum()values();
truncate def1_enum;
insert into def1_enum(c2) values(1);
select * from def1_enum;
truncate def1_enum;
insert into def1_enum(c1, c2) values(default, default);
select * from def1_enum;
truncate def1_enum;
insert into def1_enum(c1, c2) values(default(c1), default(c1));
select * from def1_enum;
truncate def1_enum;
insert into def1_enum(c1, c2) values(default(c2), default(c2));
select * from def1_enum;
truncate def1_enum;
insert into def1_enum(c1, c2) values(default(c1), default(c2));
select * from def1_enum;

create table def1_set(c1 set('a','b','c') NOT NULL, c2 int default 3);
## yyy bug
## insert into def1_set()values();
truncate def1_set;
insert /*+USE_PLAN_CACHE(NONE)*/ into def1_set(c2) values(1);
select * from def1_set;
truncate def1_set;
insert into def1_set(c1, c2) values(default, default);
select * from def1_set;
truncate def1_set;
--error 1364
insert into def1_set(c1, c2) values(default(c1), default(c1));
select * from def1_set;
truncate def1_set;
insert into def1_set(c1, c2) values(default(c2), default(c2));
select * from def1_set;
truncate def1_set;
--error 1364
insert into def1_set(c1, c2) values(default(c1), default(c2));
select * from def1_set;

drop database ytsdb;
set @@sql_mode = @ori_mode;
