--echo
--echo ## case 4 : test for default "default value"
set @@sql_mode='STRICT_ALL_TABLES';
create table e4_1(c1 int, c2 enum('a','b','c'));
insert into e4_1(c1) values(1);
select * from e4_1;
create table e4_2(c1 int, c2 enum('a','b','c') NOT NULL);
insert into e4_2(c1) values(1);
select * from e4_2;
set @@sql_mode='';
create table e4_3(c1 int, c2 enum('a','b','c'));
insert into e4_3(c1) values(1);
select * from e4_3;
create table e4_4(c1 int, c2 enum('a','b','c') NOT NULL);
insert into e4_4(c1) values(1);
select * from e4_4;

set @@sql_mode='STRICT_ALL_TABLES';
create table s4_1(c1 int, c2 set('a','b','c'));
insert into s4_1(c1) values(1);
select * from s4_1;
create table s4_2(c1 int, c2 set('a','b','c') NOT NULL);
--error 1364
insert into s4_2(c1) values(1);
select * from s4_2;

set @@sql_mode='';
create table s4_3(c1 int, c2 set('a','b','c'));
insert into s4_3(c1) values(1);
select * from s4_3;
create table s4_4(c1 int, c2 set('a','b','c') NOT NULL);
insert /*+USE_PLAN_CACHE(NONE)*/ into s4_4(c1) values(1);
#select * from s4_4;


