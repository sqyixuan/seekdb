set @ori_mode = @@sql_mode;
drop database if exists ytsdb;
create database ytsdb;
use ytsdb;
############################# test for bug : #12561356 ###########################
create table t_12561356(c1 enum('c','b','a') primary key);
insert into t_12561356 values(1);
insert into t_12561356 values(2);
select * from t_12561356;
c1
c
b
truncate table t_12561356;
insert into t_12561356 values('a'),('b'),('c');
select * from t_12561356 order by c1;
c1
c
b
a
select * from t_12561356 order by c1 desc;
c1
a
b
c
create table t_12561356_1(c1 enum('c','b','a'), c2 enum('c','b','a'));
insert into t_12561356_1 values(1,3),(2,2),(3,1);
select c1, c2 , c1 > c2, c1 = c2, c1 < c2 from t_12561356_1;
c1	c2	c1 > c2	c1 = c2	c1 < c2
c	a	1	0	0
b	b	0	1	0
a	c	0	0	1
############################# test for enum/set in information_schema.columns ###########################
create table columns_set(c1 enum('a','b','c'), c2 set('a','b','c'));
select table_name, data_type, column_type from information_schema.columns where table_name = 'columns_set';
table_name	data_type	column_type
columns_set	enum	enum('a','b','c')
columns_set	set	set('a','b','c')
############################# test for bug #12605919 ###########################
create table t_12605919(c1 int, c2 enum('a','b','c') unique key);
insert into t_12605919 values(1,1);
insert into t_12605919 values(1,1);
ERROR 23000: Duplicate entry '1' for key 'c2'
create table t_12605919_1(c1 int, c2 set('a','b','c') unique key);
insert into t_12605919_1 values(1,1);
insert into t_12605919_1 values(1,1);
ERROR 23000: Duplicate entry '1' for key 'c2'
############################# test for bug #12638416 ###########################
create table t_12638416(c1 enum('a','b','c'), c2 set('a','b','c'), c3 double, c4 decimal);
insert into t_12638416 values(1,1,1,1);
select c1 > c3, c1 > c4, c2 > c3, c2 > c4 from t_12638416;
c1 > c3	c1 > c4	c2 > c3	c2 > c4
0	0	0	0
select c1 from t_12638416 where c3 = (select c1 from t_12638416);
c1
a
select c1 from t_12638416 where c3 = (select c2 from t_12638416);
c1
a
select c1 from t_12638416 where c4 = (select c1 from t_12638416);
c1
a
select c1 from t_12638416 where c4 = (select c2 from t_12638416);
c1
a
drop database ytsdb;
set @@sql_mode = @ori_mode;
