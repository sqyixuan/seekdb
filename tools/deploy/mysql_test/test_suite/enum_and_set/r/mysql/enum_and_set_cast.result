set @ori_mode = @@sql_mode;
drop database if exists ytsdb;
create database ytsdb;
use ytsdb;


##### case1 : query range cast to enum/set type #####
create table te1(c1 enum('a','b','c') primary key);
select * from te1 where c1 between  'a' and 'c';
c1
create table ts1(c1 set('a','b','c') primary key);
select * from ts1 where c1 between 'a' and 'c';
c1
create table te1_1(c1 enum('a','b','c') primary key) partition by key(c1);
select * from te1 where c1 = 'a';
c1
create table ts1_1(c1 set('a','b','c') primary key) partition by key(c1);
select * from ts1 where c1 = 'a';
c1
############################# test for bug #30567656 ###########################
ENUM cast to TIME
create table z0case(z0_test0 enum('中文字符','123456','ABCabc','!@#$%^&*','2020-10-10','2020-10-10 10:10:10','10:10:10'));
insert into z0case values('中文字符');
insert into z0case values('123456');
insert into z0case values('ABCabc');
insert into z0case values('!@#$%^&*');
insert into z0case values('2020-10-10');
insert into z0case values('2020-10-10 10:10:10');
insert into z0case values('10:10:10');
insert into z0case values(null);
SELECT z0_test0, cast(z0_test0 as TIME) a FROM z0case;
z0_test0	a
中文字符	00:00:00
123456	12:34:56
ABCabc	00:00:00
!@#$%^&*	00:00:00
2020-10-10	00:20:20
2020-10-10 10:10:10	10:10:10
10:10:10	10:10:10
NULL	NULL
drop table z0case;
SET cast to TIME
create table z0case(z0_test0 set('中文字符','123456','ABCabc','!@#$%^&*','2020-10-10','2020-10-10 10:10:10','10:10:10'));
insert into z0case values('中文字符');
insert into z0case values('123456');
insert into z0case values('ABCabc');
insert into z0case values('!@#$%^&*');
insert into z0case values('2020-10-10');
insert into z0case values('2020-10-10 10:10:10');
insert into z0case values('10:10:10');
insert into z0case values('');
insert into z0case values(null);
SELECT z0_test0, cast(z0_test0 as TIME) a FROM z0case;
z0_test0	a
中文字符	00:00:00
123456	12:34:56
ABCabc	00:00:00
!@#$%^&*	00:00:00
2020-10-10	00:20:20
2020-10-10 10:10:10	10:10:10
10:10:10	10:10:10
	NULL
NULL	NULL
drop table z0case;
drop database ytsdb;
set @@sql_mode = @ori_mode;
