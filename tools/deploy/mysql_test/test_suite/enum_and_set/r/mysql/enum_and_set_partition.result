set @ori_mode = @@sql_mode;
drop database if exists ytsdb;
create database ytsdb;
use ytsdb;
############################# test for range partition ###########################
create table t_range(c1 enum('a','b','c') NOT NULL, c2 int)
partition by range(c1) (partition p0 values less than (1), partition p1 values less than maxvalue);
ERROR HY000: Field 'c1' is of a not allowed type for this type of partitioning
create table t_range(c1 set('a','b','c') NOT NULL, c2 int)
partition by range(c1) (partition p0 values less than (1), partition p1 values less than maxvalue);
ERROR HY000: Field 'c1' is of a not allowed type for this type of partitioning
############################# test for hash partition ###########################
create table t_hash(c1 enum('a','b','c') NOT NULL, c2 int) partition by hash(c1) partitions 4;
ERROR HY000: Field 'c1' is of a not allowed type for this type of partitioning
create table t_hash(c1 set('a','b','c') NOT NULL, c2 int) partition by hash(c1) partitions 4;
ERROR HY000: Field 'c1' is of a not allowed type for this type of partitioning
############################# test for key partition ###########################
create table t_key(c1 enum('a','b','c','d','e','f','g') primary key, c2 int) partition by key(c1) partitions 4;
insert into t_key values(1,1);
insert into t_key values(2,2);
insert into t_key values(3,3);
insert into t_key values(4,4);
insert into t_key values(5,5);
insert into t_key values(6,6);
insert into t_key values(7,7);
select * from t_key order by c1;
c1	c2
a	1
b	2
c	3
d	4
e	5
f	6
g	7
drop database ytsdb;
set @@sql_mode = @ori_mode;
