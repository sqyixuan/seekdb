result_format: 4
drop database if exists new_enumset;
create database new_enumset;
use new_enumset;
create table t1 (c1 enum('abc', 'def'), c2 set('xyz','123'));
insert into t1 values (1, 2);

alter system set _enable_enum_set_subschema = false;

explain select concat(c1, c2) from t1;
Query Plan
===============================================
|ID|OPERATOR       |NAME|EST.ROWS|EST.TIME(us)|
-----------------------------------------------
|0 |TABLE FULL SCAN|t1  |1       |3           |
===============================================
Outputs & filters:
-------------------------------------
  0 - output([concat(enum_to_str('', t1.c1), set_to_str('', t1.c2))]), filter(nil), rowset=16
      access([t1.c1], [t1.c2]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t1.__pk_increment]), range(MIN ; MAX)always true
select concat(c1, c2) from t1;
+----------------+
| concat(c1, c2) |
+----------------+
| abc123         |
+----------------+
