result_format: 4
drop table if exists t1, t2;
CREATE TABLE t1 (
  id int,
  size ENUM('small', 'medium', 'large'),
  tag  SET('summer', 'winter', 'men', 'women')

);

insert into t1 values (1, 'small', 'summer'),
                      (2, 'medium', 'winter'),
                      (3, 'medium', 'winter,men'),
                      (4, 'large', 'men');

create index i1 on t1(size);

create table t2 (c1 int, c2 int unsigned, 
    c3 float, c4 float unsigned, 
    c5 double, c6 double unsigned, 
    c7 decimal(11,3), c8 decimal(11,3) unsigned, 
    c9 datetime, c10 timestamp, 
    c11 year, c12 date, c13 time, 
    c14 varchar(30), c15 char(30),
    c16 varbinary(30), c17 binary(30),
    c18 text, c19 bit(32)
    );

insert into t2 values(0, 0, 0, 0, 0, 0, 0, 0, '2019-12-01 12:00:00', '2019-12-13 06:00:00', 0,
        '2020-01-01','12:34:56', 'small', 'small', 'small', 'small', 'small', 0);

insert into t2 values(1, 1, 1, 1, 1, 1, 1, 1, '2019-12-01 12:00:00', '2019-12-13 06:00:00', 1,
        '2020-01-01','12:34:56', 'small', 'small', 'small', 'small', 'small', 1);

insert into t2 values(2, 2, 2, 2, 2, 2, 2, 2, '2019-12-01 12:00:00', '2019-12-13 06:00:00', 2,
        '2020-01-01','12:34:56', 'medium', 'medium', 'medium', 'medium', 'medium', 2);

insert into t2 values(3, 3, 3, 3, 3, 3, 3, 3, '2019-12-01 12:00:00', '2019-12-13 06:00:00', 3,
        '2020-01-01','12:34:56', 'large', 'large', 'large', 'large', 'large', 3);

insert into t2 values(4, 4, 3.1, 3.1, 3.1, 3.1, 3.1, 3.1, '2019-12-01 12:00:00', '2019-12-13 06:00:00', 4,
        '2020-01-01','12:34:56', 'llll', 'llll', 'llll', 'llll', 'llll', 3.1);

create index idx_c1 on t2(c1);
create index idx_c2 on t2(c2);
create index idx_c3 on t2(c3);
create index idx_c4 on t2(c4);
create index idx_c5 on t2(c5);
create index idx_c6 on t2(c6);
create index idx_c7 on t2(c7);
create index idx_c8 on t2(c8);
create index idx_c9 on t2(c9);
create index idx_c10 on t2(c10);
create index idx_c11 on t2(c11);
create index idx_c12 on t2(c12);
create index idx_c13 on t2(c13);
create index idx_c14 on t2(c14);
create index idx_c15 on t2(c15);
create index idx_c16 on t2(c16);
create index idx_c17 on t2(c17);
create index idx_c19 on t2(c19);

result_format: 4
explain_protocol: 1
EXPLAIN BASIC SELECT /*+ LEADING(t2 t1) USE_NL(t1) */ t1.id, t1.size, t2.c2, t2.c1 FROM t1, t2 WHERE t1.SIZE = t2.c1;
