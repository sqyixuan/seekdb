insert into t30567656 values('ABCabc','ABC abc');
insert into t30567656 values('!@#$%^&*','!@#$%^&*');
insert into t30567656 values('2020-10-10','2020-10-10');
insert into t30567656 values('','');
insert into t30567656 values(null,null);
CREATE FUNCTION SetFunction(setSQL char(100)) RETURNS varchar(100)
BEGIN
declare a set('中文字符 ','123456','ABCabc ','!@#$%^&*','2020-11-11');
select z0_test0 from t30567656 e where z0_test0 =setSQL into a;
return a;
end//
select SetFunction('中文字符') from dual;
SetFunction('中文字符')
中文字符
select SetFunction('123456') from dual;
SetFunction('123456')
123456
