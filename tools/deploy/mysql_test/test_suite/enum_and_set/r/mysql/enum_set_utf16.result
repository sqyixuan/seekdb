drop table if exists t1;
drop table if exists t2;
create table t1 (c1 enum('a', 'b', 'c', 'd') charset utf16, c2 enum('a', 'b', 'c', 'd'));
insert into t1 (c1, c2) values ('a', 'b');
desc t1;
Field	Type	Null	Key	Default	Extra
c1	enum('a','b','c','d')	YES		NULL	
c2	enum('a','b','c','d')	YES		NULL	
show create table t1;
Table	Create Table
t1	CREATE TABLE `t1` (
  `c1` enum('a','b','c','d') CHARACTER SET utf16 DEFAULT NULL,
  `c2` enum('a','b','c','d') DEFAULT NULL
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 COMPRESSION = 'lz4_1.0' REPLICA_NUM = NUM BLOCK_SIZE = SIZE USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = SIZE PCTFREE = 10
select hex(c1), hex(c2), hex(concat(c1, c2)), hex(concat(c1, c1)) from t1;
hex(c1)	hex(c2)	hex(concat(c1, c2))	hex(concat(c1, c1))
0061	62	6162	00610061
create table t2 (c1 set('a', 'b', 'c', 'd') charset utf16, c2 set('a', 'b', 'c', 'd'));
desc t2;
Field	Type	Null	Key	Default	Extra
c1	set('a','b','c','d')	YES		NULL	
c2	set('a','b','c','d')	YES		NULL	
show create table t2;
Table	Create Table
t2	CREATE TABLE `t2` (
  `c1` set('a','b','c','d') CHARACTER SET utf16 DEFAULT NULL,
  `c2` set('a','b','c','d') DEFAULT NULL
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 COMPRESSION = 'lz4_1.0' REPLICA_NUM = NUM BLOCK_SIZE = SIZE USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = SIZE PCTFREE = 10
insert into t2 (c1, c2) values ('a', 'b');
insert into t2 (c1, c2) values ('c,a', 'd,b');
select hex(c1), hex(c2), hex(concat(c1, c2)), hex(concat(c1, c1)) from t2;
hex(c1)	hex(c2)	hex(concat(c1, c2))	hex(concat(c1, c1))
0061	62	6162	00610061
0061002C0063	622C64	612C63622C64	0061002C00630061002C0063
select * from t1, t2 where t1.c1 = t2.c1;
c1	c2	c1	c2
a	b	a	b
drop table t1;
drop table t2;
create table t1 (c1 date);
insert into t1 values ('2020-10-19');
create table t2 (c1 enum('a', '2020-10-19', 'b') charset utf16);
insert into t2 select * from t1;
select * from t2;
c1
2020-10-19
