test for insert with default_expr / default_function
set @@sql_mode='STRICT_ALL_TABLES';
create table def_enum(c1 enum('a','b','c') NOT NULL, c2 int default 3);
truncate def_enum;
insert into def_enum(c2) values(1);
select * from def_enum;
c1	c2
a	1
truncate def_enum;
insert into def_enum(c1, c2) values(default, default);
select * from def_enum;
c1	c2
a	3
truncate def_enum;
insert into def_enum(c1, c2) values(default(c1), default(c1));
select * from def_enum;
c1	c2
a	1
truncate def_enum;
insert into def_enum(c1, c2) values(default(c2), default(c2));
select * from def_enum;
c1	c2
c	3
truncate def_enum;
insert into def_enum(c1, c2) values(default(c1), default(c2));
select * from def_enum;
c1	c2
a	3
create table def_set(c1 set('a','b','c') NOT NULL, c2 int default 3);
insert into def_set()values();
ERROR HY000: Field 'c1' doesn't have a default value
insert into def_set(c2) values(1);
ERROR HY000: Field 'c1' doesn't have a default value
insert into def_set(c1, c2) values(default, default);
ERROR HY000: Field doesn't have a default value
truncate def_set;
insert into def_set(c1, c2) values(default(c2), default(c2));
select * from def_set;
c1	c2
a,b	3
