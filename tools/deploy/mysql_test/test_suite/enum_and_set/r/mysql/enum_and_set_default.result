set @ori_mode = @@sql_mode;
drop database if exists ytsdb;
create database ytsdb;
use ytsdb;


##### test for create table default value #####

## case 1 : test for NULL default value
create table cd1(c1 enum('a','b','c') default NULL);
show create table cd1;
Table	Create Table
cd1	CREATE TABLE `cd1` (
  `c1` enum('a','b','c') DEFAULT NULL
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 COMPRESSION = 'lz4_1.0' REPLICA_NUM = NUM BLOCK_SIZE = SIZE USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = SIZE PCTFREE = 10
desc cd1;
Field	Type	Null	Key	Default	Extra
c1	enum('a','b','c')	YES		NULL	
create table cd2(c1 enum('a','b','c') default 'NULL');
ERROR 42000: Invalid default value for 'c1'
create table cd3(c1 enum('a','b','c') not NULL default NULL);
ERROR 42000: Invalid default value for 'c1'
create table cd4(c1 enum('a','b','c') not NULL default 'NULL');
ERROR 42000: Invalid default value for 'c1'
create table cds1(c1 set('a','b','c') default NULL);
show create table cds1;
Table	Create Table
cds1	CREATE TABLE `cds1` (
  `c1` set('a','b','c') DEFAULT NULL
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 COMPRESSION = 'lz4_1.0' REPLICA_NUM = NUM BLOCK_SIZE = SIZE USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = SIZE PCTFREE = 10
desc cds1;
Field	Type	Null	Key	Default	Extra
c1	set('a','b','c')	YES		NULL	
create table cds2(c1 set('a','b','c') default 'NULL');
ERROR 42000: Invalid default value for 'c1'
create table cds3(c1 set('a','b','c') not NULL default NULL);
ERROR 42000: Invalid default value for 'c1'
create table cds4(c1 set('a','b','c') not NULL default 'NULL');
ERROR 42000: Invalid default value for 'c1'

