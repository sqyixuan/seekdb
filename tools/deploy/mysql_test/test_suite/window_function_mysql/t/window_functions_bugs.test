## fix bugs
--disable_warnings
drop table if exists t1, wf_table1;
--enable_warnings

create table t1(c1 int, c2 int, c3 int);
CREATE TABLE wf_table1(num INT,name varchar(200),money char(20),perimeter NUMERIC(20,10) AS (2 * 3.14159265 * num));

--disable_query_log
--disable_result_log
INSERT INTO t1 VALUES(1, 1, 1);
INSERT INTO t1 VALUES(2, 2, 2);
INSERT INTO t1 VALUES(3, 3, 3);
INSERT INTO wf_table1(num,name,money) VALUES(1,'Bing',-100);
INSERT INTO wf_table1(num,name,money) VALUES(2,'Bing',+104564564646.11514);
INSERT INTO wf_table1(num,name,money) VALUES(3,'Reachl',-0.23566000);
INSERT INTO wf_table1(num,name,money) VALUES(4,'Reachl',0.23566000);
INSERT INTO wf_table1(num,name,money) VALUES(5,'friends','');
INSERT INTO wf_table1(num,name,money) VALUES(6,'@#￥！%……&*~',NULL);
INSERT INTO wf_table1(num,name,money) VALUES(2,'Bing',10);
INSERT INTO wf_table1(num,name,money) VALUES(NULL,'NULL',NULL);
select count(*) from t1;
select count(*) from wf_table1;
--enable_query_log
--enable_result_log

## 
select last_value(c1) over (order by c2), last_value(c1) over (order by c2 rows between unbounded preceding and unbounded following) FROM t1;

## 
SELECT name, SUM(money) OVER(ROWS UNBOUNDED PRECEDING) AS wf1 FROM wf_table1 ORDER BY name;

## 
--error 3587
SELECT name, SUM(money) OVER(PARTITION BY money RANGE 1 PRECEDING) AS wf1 FROM wf_table1 ORDER BY name;

