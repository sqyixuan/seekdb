--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: zongmei.zzm
#owner group: sql1
# tags: optimizer,window_function
# description: test of window function redunancy
#

--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(a int, b int, c int, d int);
--disable_query_log
insert into t1 values (1,1,1,1);
Insert into t1 values (1,2,3,4);
insert into t1 values (1,1,4,1);
insert into t1 values (1,1,5,1);
insert into t1 values (2,1,1,2);
insert into t1 values (2,1,1,3);
insert into t1 values (2,1,2,3);
insert into t1 values (3,1,1,4);
insert into t1 values (3,1,4,4);
--enable_query_log

--disable_query_log
--disable_result_log
select * from t1;
--enable_query_log
--enable_result_log

--explain_protocol 2
--result_format 4

select a,b,sum(c) over(),avg(c) over() from t1; #窗口分区及排序为空，窗口部分相同
select a,b,sum(c) over(),count(c) over(),avg(c) over() from t1; #窗口分区及排序为空，窗口部分相同
select a,b,sum(c) over(partition by a),avg(c) over(partition by a) from t1; #窗口排序为空，窗口部分相同
select a,b,sum(c) over(order by a),avg(c) over(order by a) from t1; #窗口分区为空，窗口部分相同
select a,b,sum(c) over(partition by a order by b),avg(c) over(order by a) from t1; #窗口不同不能去重
select a,b,sum(c) over(partition by a order by b),avg(c) over(partition by a order by b) from t1; #窗口相同要去重
select a,b,sum(c) over(partition by a order by b),ntile(10) over(partition by a order by b) from t1; #窗口相同，函数不同
select a,b,sum(c) over(partition by a order by b),ntile(10) over(partition by a order by b),ntile(10) over(partition by a order by b) from t1; #窗口相同，函数不同
select a,b,sum(c) over(partition by a order by b),count(c) over(partition by a order by b),stddev(c) over(partition by a order by b) from t1;
select a,b,sum(c*c) over(partition by a order by b),stddev(c) over(partition by a order by b) from t1; #聚集函数嵌套表达式
select a,b,rank() over(partition by a order by b),rank() over() from t1; #窗口不同，不去重
select a,b,rank() over(partition by a order by b),rank() over(partition by a order by b) from t1; #窗口相同，去重
select a,b,dense_rank() over (partition by a order by b),dense_rank() over (partition by a) from t1; #窗口不同，不去重
select a,b,dense_rank() over (partition by a order by b),dense_rank() over (partition by a order by b) from t1; #窗口不同，不去重
select a,b,row_number() over (partition by a order by b),row_number() over (partition by a) from t1; #窗口不同，不去重
select a,b,row_number() over (partition by a order by b),row_number() over (partition by a order by b) from t1; #窗口不同，不去重

drop table t1;

