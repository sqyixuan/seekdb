--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: zongmei.zzm
#owner group: sql1
# tags: optimizer,window_function
# description: test of stddev/variance/stddev_samp/stddev_pop 
#

--disable_warnings
drop table if exists t1;
drop table if exists t1_dist;
--enable_warnings
create table t1(a int, b int, c int, d int);
create table t1_dist(a int, b int, c int, d int) partition by hash(a+b) partitions 4;
--disable_query_log
insert into t1 values (1,1,1,1);
Insert into t1 values (1,2,3,4);
insert into t1 values (1,1,4,1);
insert into t1 values (1,1,5,1);
insert into t1 values (2,1,1,2);
insert into t1 values (2,1,1,3);
insert into t1 values (2,1,2,3);
insert into t1 values (3,1,1,4);
insert into t1 values (3,1,4,4);
insert into t1 values (4,1,2,1);
insert into t1 values (4,4,2,5);
insert into t1 values (5,1,2,2);
insert into t1 values (5,1,6,3);
insert into t1 values (6,2,3,1);
insert into t1 values (6,9,1,3);
insert into t1 values (7,2,3,4);
insert into t1 values (7,2,4,5);
insert into t1 values (8,2,3,3);
insert into t1 values (8,2,9,8);
insert into t1 values (9,2,3,4);
insert into t1_dist select * from t1;
--enable_query_log

--disable_query_log
--disable_result_log
select * from t1;
select * from t1_dist;
--enable_query_log
--enable_result_log

--explain_protocol 2
--result_format 4

#基本功能
select a,b, avg(c) over (partition by a order by b,c rows between 1 preceding and 2 following) from t1;
select a,b, avg(c) over (partition by a order by b,c rows between 1 preceding and 2 following) from t1_dist order by a,b;
select a,b, variance(c) over (partition by a order by b,c rows between 1 preceding and 2 following) from t1;
select a,b, variance(c) over (partition by a order by b,c rows between 1 preceding and 2 following) from t1_dist order by a,b;
select a,b, stddev(c) over (partition by a order by b,c rows between 1 preceding and 2 following) from t1;
select a,b, stddev(c) over (partition by a order by b,c rows between 1 preceding and 2 following) from t1_dist order by a,b;
select a,b, stddev_samp(c) over (partition by a order by b,c rows between 1 preceding and 2 following) from t1;
select a,b, stddev_samp(c) over (partition by a order by b,c rows between 1 preceding and 2 following) from t1_dist order by a,b;
select a,b, stddev_pop(c) over (partition by a order by b,c rows between 1 preceding and 2 following) from t1;
select a,b, stddev_pop(c) over (partition by a order by b,c rows between 1 preceding and 2 following) from t1_dist order by a,b;
select a,b, stddev(c) over (partition by a,b order by c rows between 1 preceding and 2 following) from t1;
select a,b, stddev(c) over (partition by a,b order by c rows between 1 preceding and 2 following) from t1_dist order by a,b;

#测试含有distinct的场景
--error 0,5797
select a,b, avg(distinct c) over (partition by a order by b,c rows between 1 preceding and 2 following) from t1;
--error 0,5797
select a,b, avg(distinct c) over (partition by a order by b,c rows between 1 preceding and 2 following) from t1_dist order by a,b;

#多个窗口函数混合
select a,b, variance(c) over (partition by a order by b,c rows between 1 preceding and 2 following), stddev(c) over (partition by a order by b,c rows between 1 preceding and 2 following) from t1;
select a,b, variance(c) over (partition by a order by b,c rows between 1 preceding and 2 following), stddev(c) over (partition by a order by b,c rows between 1 preceding and 2 following) from t1_dist order by a,b;
drop table t1;
drop table t1_dist;

##bug:

--disable_warnings
drop table if exists bug22555;
--enable_warnings

--explain_protocol 0

create table bug22555 (i smallint, s1 smallint, s2 smallint, o1 double, o2 double, e1 decimal, e2 decimal);
insert into bug22555 values (1,53,78,53,78,53,78),(2,17,78,17,78,17,78),(3,18,76,18,76,18,76);
select std(s1/s2) from bug22555 where i=1;
select stddev(s1/s2) from bug22555 where i=2;
select STDDEV_POP(s1/s2) from bug22555 where i=2;
select i, count(*), std(e1/e2) from bug22555 group by i order by i;
select i, count(*), variance(e1/e2) from bug22555 group by i order by i;

--echo 实现方式不同,精度受损,导致结果不同
select i, count(*), std(o1/o2) from bug22555 group by i order by i;
--echo 实现方式不同,精度受损,导致结果不同
select i, count(*), variance(o1/o2) from bug22555 group by i order by i;
