# tags: optimizer,window_function
##description:
--disable_abort_on_error
SET windowing_use_high_precision= ON;
--disable_warnings
drop database if exists window_std_var_db;
--enable_warnings
create database window_std_var_db;
use window_std_var_db;

--source include/window_std_var.inc

SET windowing_use_high_precision= default;
drop database window_std_var_db;
