drop table if exists t1;
drop table if exists t1_dist;
create table t1(a int, b int, c int, d int);
create table t1_dist(a int, b int, c int, d int) partition by hash(a+b) partitions 4;
explain_protocol: 2
result_format: 4
EXPLAIN select a,b, avg(c) over (partition by a order by b,c rows between 1 preceding and 2 following) from t1;
Query Plan
===================================================
|ID|OPERATOR           |NAME|EST.ROWS|EST.TIME(us)|
---------------------------------------------------
|0 |WINDOW FUNCTION    |    |20      |35          |
|1 |└─SORT             |    |20      |7           |
|2 |  └─TABLE FULL SCAN|t1  |20      |4           |
===================================================
Outputs & filters:
-------------------------------------
  0 - output([t1.a], [t1.b], [cast(cast(T_FUN_SUM(t1.c), DECIMAL_INT(65, 32)) / cast(T_FUN_COUNT(t1.c), DECIMAL_INT(20, 0)), DECIMAL(15, 4))]), filter(nil), rowset=256
      win_expr(T_FUN_SUM(t1.c)), partition_by([t1.a]), order_by([t1.b, ASC], [t1.c, ASC]), window_type(ROWS), upper(1 PRECEDING), lower(2 FOLLOWING)
      win_expr(T_FUN_COUNT(t1.c)), partition_by([t1.a]), order_by([t1.b, ASC], [t1.c, ASC]), window_type(ROWS), upper(1 PRECEDING), lower(2 FOLLOWING)
  1 - output([t1.c], [t1.a], [t1.b]), filter(nil), rowset=256
      sort_keys([t1.a, ASC], [t1.b, ASC], [t1.c, ASC])
  2 - output([t1.a], [t1.b], [t1.c]), filter(nil), rowset=256
      access([t1.a], [t1.b], [t1.c]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t1.__pk_increment]), range(MIN ; MAX)always true
