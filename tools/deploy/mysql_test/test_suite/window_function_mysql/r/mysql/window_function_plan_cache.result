result_format: 4

alter system flush plan cache global;


set ob_trx_timeout = 1000000000;

drop table if exists t1;
create table t1 (a int, b int);

begin;
// CASE#1: WINDOW FUNCTION ROWS
SELECT a, SUM(a) OVER (ORDER BY a ROWS 1 PRECEDING) FROM t1;
+------+-------------------------------------------+
| a    | SUM(a) OVER (ORDER BY a ROWS 1 PRECEDING) |
+------+-------------------------------------------+
|    1 |                                         1 |
|    2 |                                         3 |
|    3 |                                         5 |
|    4 |                                         7 |
+------+-------------------------------------------+
SELECT a, SUM(a) OVER (ORDER BY a ROWS 2 PRECEDING) FROM t1;
+------+-------------------------------------------+
| a    | SUM(a) OVER (ORDER BY a ROWS 2 PRECEDING) |
+------+-------------------------------------------+
|    1 |                                         1 |
|    2 |                                         3 |
|    3 |                                         6 |
|    4 |                                         9 |
+------+-------------------------------------------+
SELECT a, SUM(a) OVER (ORDER BY a ROWS 3 PRECEDING) FROM t1;
+------+-------------------------------------------+
| a    | SUM(a) OVER (ORDER BY a ROWS 3 PRECEDING) |
+------+-------------------------------------------+
|    1 |                                         1 |
|    2 |                                         3 |
|    3 |                                         6 |
|    4 |                                        10 |
+------+-------------------------------------------+
select hit_count, sql_id from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement = 'SELECT a, SUM(a) OVER (ORDER BY a ROWS ? PRECEDING) FROM t1';
+-----------+----------------------------------+
| hit_count | sql_id                           |
+-----------+----------------------------------+
|         2 | 9D61BB1AFAEEE71440D3B8CBC35F1C41 |
+-----------+----------------------------------+
commit;

begin;
// CASE#2: WINDOW FUNCTION RANGE
SELECT a, LAST_VALUE(a) OVER w FROM t1 WINDOW w AS (ORDER BY a RANGE BETWEEN 1 PRECEDING AND 1 FOLLOWING);
+------+----------------------+
| a    | LAST_VALUE(a) OVER w |
+------+----------------------+
|    1 |                    2 |
|    2 |                    3 |
|    3 |                    4 |
|    4 |                    4 |
+------+----------------------+
SELECT a, LAST_VALUE(a) OVER w FROM t1 WINDOW w AS (ORDER BY a RANGE BETWEEN 1 PRECEDING AND 2 FOLLOWING);
+------+----------------------+
| a    | LAST_VALUE(a) OVER w |
+------+----------------------+
|    1 |                    3 |
|    2 |                    4 |
|    3 |                    4 |
|    4 |                    4 |
+------+----------------------+
SELECT a, LAST_VALUE(a) OVER w FROM t1 WINDOW w AS (ORDER BY a RANGE BETWEEN 2 PRECEDING AND 3 FOLLOWING);
+------+----------------------+
| a    | LAST_VALUE(a) OVER w |
+------+----------------------+
|    1 |                    4 |
|    2 |                    4 |
|    3 |                    4 |
|    4 |                    4 |
+------+----------------------+

select hit_count, sql_id from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement = 'SELECT a, LAST_VALUE(a) OVER w FROM t1 WINDOW w AS (ORDER BY a RANGE BETWEEN ? PRECEDING AND ? FOLLOWING)';
+-----------+--------+
| hit_count | sql_id |
+-----------+--------+
+-----------+--------+
commit;

drop table t1;

