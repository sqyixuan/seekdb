CREATE TABLE T1 (C1 INT, C2 INT, C3 INT, D1 INT, D2 INT);
CREATE INDEX IDX_D1 ON T1(D1);
CREATE INDEX IDX_D2 ON T1(D2);

EXPLAIN SELECT /*+use_concat*/ AVG(C1) OVER (PARTITION BY C2 ) S1,
       STDDEV(C1) OVER (PARTITION BY C3) S2
       FROM T1
       WHERE D1 = 1 OR D2 = 2;
