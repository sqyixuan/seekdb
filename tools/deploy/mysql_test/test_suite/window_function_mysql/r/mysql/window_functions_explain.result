View	Create View	character_set_client	collation_connection
v	CREATE VIEW `v` AS select `window_func_explain_db`.`t1`.`id` AS `id`,sum(`window_func_explain_db`.`t1`.`id`) over( PARTITION BY `window_func_explain_db`.`t1`.`sex` ORDER BY `window_func_explain_db`.`t1`.`id` ASC  ROWS BETWEEN 2 PRECEDING  AND 1 PRECEDING ) AS `SUM(id) OVER w`,`window_func_explain_db`.`t1`.`sex` AS `sex` from `window_func_explain_db`.`t1`	utf8mb4	utf8mb4_general_ci
