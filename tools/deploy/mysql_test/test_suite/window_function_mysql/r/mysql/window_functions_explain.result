# Explain of SQL window functions.
# ----------------------------------------------------------------------
SET NAMES utf8;
drop database if exists window_func_explain_db;
create database window_func_explain_db;
use window_func_explain_db;
Single window function (plus ORDER BY).
CREATE TABLE t(i INT, j INT);
INSERT INTO t VALUES (1,1), (1,4), (1,2), (1,4);
ANALYZE TABLE t;
Single partition, no sorting
EXPLAIN  SELECT i, j, SUM(i+j) OVER (ROWS UNBOUNDED PRECEDING) foo FROM t;
Query Plan
=================================================
|ID|OPERATOR         |NAME|EST.ROWS|EST.TIME(us)|
-------------------------------------------------
|0 |WINDOW FUNCTION  |    |4       |6           |
|1 |└─TABLE FULL SCAN|t   |4       |3           |
=================================================
Outputs & filters:
-------------------------------------
  0 - output([t.i], [t.j], [T_FUN_SUM(t.i + t.j)]), filter(nil), rowset=16
      win_expr(T_FUN_SUM(t.i + t.j)), partition_by(nil), order_by(nil), window_type(ROWS), upper(UNBOUNDED PRECEDING), lower(CURRENT ROW)
  1 - output([t.i], [t.j]), filter(nil), rowset=16
      access([t.i], [t.j]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t.__pk_increment]), range(MIN ; MAX)always true
