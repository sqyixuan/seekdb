View with window function
CREATE VIEW v AS
SELECT i, j, SUM(i+j) OVER (ORDER BY j DESC ROWS UNBOUNDED PRECEDING) foo FROM t;
SHOW CREATE VIEW v;
View	Create View	character_set_client	collation_connection
v	CREATE VIEW `v` AS select `window_func_explain_db`.`t`.`i` AS `i`,`window_func_explain_db`.`t`.`j` AS `j`,sum((`window_func_explain_db`.`t`.`i` + `window_func_explain_db`.`t`.`j`)) over( ORDER BY `window_func_explain_db`.`t`.`j` DESC  ROWS BETWEEN  UNBOUNDED  PRECEDING  AND  CURRENT ROW ) AS `foo` from `window_func_explain_db`.`t`	utf8mb4	utf8mb4_general_ci
EXPLAIN  SELECT * FROM v;
