# Explain of SQL window functions.
# ----------------------------------------------------------------------
SET NAMES utf8;
drop database if exists window_func_explain_db;
create database window_func_explain_db;
use window_func_explain_db;
Single window function (plus ORDER BY).
CREATE TABLE t(i INT, j INT);
INSERT INTO t VALUES (1,1), (1,4), (1,2), (1,4);
ANALYZE TABLE t;
ERROR 42000: You have an error in your SQL syntax; check the manual that corresponds to your OceanBase version for the right syntax to use near 't' at line 1
Single partition, no sorting
EXPLAIN  SELECT i, j, SUM(i+j) OVER (ROWS UNBOUNDED PRECEDING) foo FROM t;
Query Plan
========================================
|ID|OPERATOR       |NAME|EST. ROWS|COST|
----------------------------------------
|0 |WINDOW FUNCTION|    |4        |38  |
|1 | TABLE SCAN    |t   |4        |37  |
========================================

Outputs & filters: 
-------------------------------------
  0 - output([t.i], [t.j], [T_FUN_SUM(t.i + t.j)]), filter(nil), 
      win_expr(T_FUN_SUM(t.i + t.j)), partition_by(nil), order_by(nil), window_type(RANGE), upper(UNBOUNDED PRECEDING), lower(UNBOUNDED FOLLOWING)
  1 - output([t.i], [t.j], [t.i + t.j]), filter(nil), 
      access([t.i], [t.j]), partitions(p0)

