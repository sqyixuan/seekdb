# Test of SQL window functions.
# ----------------------------------------------------------------------
Single window function (plus ORDER BY).
drop table t;
CREATE TABLE t(i INT, j INT);
INSERT INTO t VALUES (1,1);
INSERT INTO t VALUES (1,4);
INSERT INTO t VALUES (1,2);
INSERT INTO t VALUES (1,4);
Single partition, no sorting
SELECT i, j, SUM(i+j) OVER (ROWS UNBOUNDED PRECEDING) foo FROM t;
I	J	FOO
1	1	15
1	2	15
1	4	15
1	4	15
SELECT i, j, SUM(i+j) OVER (ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) foo FROM t;
I	J	FOO
1	1	15
1	2	15
1	4	15
1	4	15
SELECT i, j, SUM(i+j) OVER (ROWS UNBOUNDED PRECEDING) foo FROM t ORDER BY foo;
I	J	FOO
1	1	15
1	2	15
1	4	15
1	4	15
SELECT i, j, SUM(i+j) OVER (ROWS UNBOUNDED PRECEDING) foo FROM t ORDER BY foo DESC;
I	J	FOO
1	1	15
1	2	15
1	4	15
1	4	15
Check that we eliminate redundant sorting in ORDER BY even with wfs
Also check that EXPLAIN prints the right number of "using_temporary_table"
SELECT i, j, SUM(i+j) OVER (ROWS UNBOUNDED PRECEDING) foo FROM t ORDER BY NULL DESC;
I	J	FOO
1	1	15
1	2	15
1	4	15
1	4	15
EXPLAIN  SELECT i, j, SUM(i+j) OVER (ROWS UNBOUNDED PRECEDING) foo FROM t ORDER BY NULL DESC;
Query Plan


      access([T.I], [T.J]), partitions(p0)
      win_expr(T_FUN_SUM(T.I + T.J)), partition_by(nil), order_by(nil), window_type(RANGE), upper(UNBOUNDED PRECEDING), lower(UNBOUNDED FOLLOWING)
  0 - output([T.I], [T.J], [T_FUN_SUM(T.I + T.J)]), filter(nil), 
  1 - output([T.I], [T.J], [T.I + T.J]), filter(nil), 
-------------------------------------
----------------------------------------
========================================
========================================
Outputs & filters: 
|0 |WINDOW FUNCTION|    |4        |38  |
|1 | TABLE SCAN    |T   |4        |37  |
|ID|OPERATOR       |NAME|EST. ROWS|COST|
With LIMIT
SELECT * from (select rownum rn, i, j, SUM(i+j) OVER (ROWS UNBOUNDED PRECEDING) foo FROM t ORDER BY foo DESC)
where rn <= 3;
RN	I	J	FOO
1	1	1	15
2	1	4	15
3	1	2	15
With LIMIT when last tmp file step is optimized away
