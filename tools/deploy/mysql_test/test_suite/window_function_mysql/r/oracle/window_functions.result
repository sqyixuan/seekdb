ERROR 42S22: invalid identifier 'A' in 'field list'
SELECT  ABS(ROW_NUMBER() OVER (ORDER BY s1,s2))
- ROW_NUMBER() OVER (ORDER BY s1,s2) AS X FROM t1;
X
