Query Plan


      access([T1.A]), partitions(p0)
      win_expr(T_WIN_FUN_RANK()), partition_by(nil), order_by([T1.A, ASC]), window_type(RANGE), upper(UNBOUNDED PRECEDING), lower(UNBOUNDED FOLLOWING)
      win_expr(T_WIN_FUN_RANK()), partition_by(nil), order_by([T1.A, ASC]), window_type(RANGE), upper(UNBOUNDED PRECEDING), lower(UNBOUNDED FOLLOWING)
      win_expr(T_WIN_FUN_RANK()), partition_by(nil), order_by([T1.A, DESC]), window_type(RANGE), upper(UNBOUNDED PRECEDING), lower(UNBOUNDED FOLLOWING)
      win_expr(T_WIN_FUN_RANK()), partition_by(nil), order_by([T1.A, DESC]), window_type(RANGE), upper(UNBOUNDED PRECEDING), lower(UNBOUNDED FOLLOWING)
  0 - output([T1.A], [T_WIN_FUN_RANK()], [T_WIN_FUN_RANK()], [T_WIN_FUN_RANK() + T_WIN_FUN_RANK()]), filter(nil), 
  1 - output([T1.A], [T_WIN_FUN_RANK()], [T_WIN_FUN_RANK()]), filter(nil), sort_keys([T1.A, DESC])
  2 - output([T1.A], [T_WIN_FUN_RANK()], [T_WIN_FUN_RANK()]), filter(nil), 
  3 - output([T1.A]), filter(nil), sort_keys([T1.A, ASC])
  4 - output([T1.A]), filter(nil), 
