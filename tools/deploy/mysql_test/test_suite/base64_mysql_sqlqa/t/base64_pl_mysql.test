--error 0,1051
DROP TABLE base_test1;
CREATE TABLE base_test1(  
  c1 int,  
  c2 float, 
  c3 DECIMAL(5,2) DEFAULT 8.8, 
  c4 VARCHAR(100), 
  c5 bit(10),
  c6 datetime, 
  c7 json NOT NULL,
  c8 SET('a', 'b', 'c', 'd'));
  
CREATE INDEX INDEX_base_test1_T1 ON base_test1(c4);
ALTER TABLE `base_test1` ADD INDEX INDEX_base_test1_T3 (c6, c1); 
CREATE INDEX INDEX_base_test1_T5 USING HASH ON base_test1(c8);

insert into base_test1 values(from_base64(to_base64(0)),from_base64('MS4xMTEx'),2.2,from_base64(to_base64('asd汉字！@#￥%……!@@^&*&*()+{}:>?|')),from_base64(to_base64(b'1000001')),
from_base64(to_base64('2020-12-31 23:59:59.999999')),'[{"abs":123},"汉字123！@#$%^&*()_+",[0]]',from_base64(to_base64('b,d')));

--error 0,1305
DROP PROCEDURE base_pl;
DELIMITER //;
CREATE  PROCEDURE base_pl(in a DATE)
begin
DECLARE i int;
    set i=20101005;
    while from_base64(to_base64(i)) <= from_base64(to_base64(20101010)) DO
            if a = (select (select date('2020-12-12'))) then
               insert into base_test1 values(from_base64(to_base64(0)),
			   from_base64('MS4xMTEx'),
			   2.2,
			   from_base64(to_base64('asd汉字')),
			   from_base64(to_base64(b'1000001')),
			   from_base64(to_base64('2020-10-10 23:59:59.999999')),
			   '[{"abs":123}]',
			   from_base64(to_base64('a,d')));

            elseif (select '2011-11-11')>a then
                   update base_test1 set c4 = to_base64('测试'),
							c6 = from_base64('MjAyMC0xMi0yMiAyMzo1OTo1OS45OTk5OTk=');
                else
                   replace into base_test1 values(from_base64(to_base64(0)),
				   from_base64('MS4xMTEx'),
				   2.2,
				   from_base64(to_base64('asd')),
				   from_base64(to_base64(b'1000001')),
				   from_base64(to_base64('2020-12-31 23:59:59.999999')),
				   '[{"abs":123},"汉字123！@#$%^&*()_+",[0]]',
				   from_base64(to_base64('b,d')));
                end if;
                set i = i + 1;
    end WHILE;
end;
//
DELIMITER ;//

select * from base_test1;
call base_pl((select (select date('2020-12-12'))));
select * from base_test1;
call base_pl((select (select date('2011-11-10'))));
select * from base_test1;
call base_pl((select (select date('2011-11-12'))));
select * from base_test1;

--error 0,1305
DROP PROCEDURE base_pl;

