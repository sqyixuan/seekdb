# description: 不同字符集场景应用to_base64 from_base64函数
# author: wb-zc01084078
# tags:

#purge recyclebin;

--result_format 4

##待修复的case##
select from_base64('    ');
select from_base64(' ');
select from_base64('\n');
select from_base64('\r');
select from_base64('\t');

SELECT TO_BASE64('1.23'),FROM_BASE64('1.23');
SELECT TO_BASE64(-100),FROM_BASE64(-100);

##待验证case##
select from_base64(cast('20:59:59.000000' as time));
select from_base64('!@#$');
select from_base64('dj测试');


