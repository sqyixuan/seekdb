insert into base_test1 values(from_base64(to_base64(0)),from_base64('MS4xMTEx'),2.2,from_base64(to_base64('asd汉字！@#￥%……!@@^&*&*()+{}:>?|')),from_base64(to_base64(b'1000001')),
from_base64(to_base64('2020-12-31 23:59:59.999999')),'[{"abs":123},"汉字123！@#$%^&*()_+",[0]]',from_base64(to_base64('b,d')));
DROP FUNCTION base_pl;
CREATE FUNCTION base_pl (a SMALLINT,b VARCHAR(20)) RETURNS INT DETERMINISTIC
BEGIN
	loop1: LOOP
		if a < 5 then
		   insert into base_test1 values(from_base64(to_base64(a)),
		   from_base64('MS4xMTEx'),
		   2.2,
		   from_base64(to_base64(b)),
		   from_base64(to_base64(b'1000001')),
		   from_base64(to_base64('2020-10-10 23:59:59.999999')),
		   '[{"abs":123}]',
		   from_base64(to_base64('a,d')));

		elseif 8 = a then
			   update base_test1 set c4 = to_base64(b),
						c6 = from_base64('MjAyMC0xMi0yMiAyMzo1OTo1OS45OTk5OTk=') where c1 < 3;
			LEAVE loop1;
		else
			   replace into base_test1 values(from_base64(to_base64(a)),
			   from_base64('MS4xMTEx'),
			   2.2,
			   from_base64(to_base64(b)),
			   from_base64(to_base64(b'1000001')),
			   from_base64(to_base64('2020-12-31 23:59:59.999999')),
			   '[{"abs":123},"汉字123！@#$%^&*()_+",[0]]',
			   from_base64(to_base64('b,d')));
				
		end if;
                set a = a + 1;

    end LOOP loop1;
	RETURN from_base64(to_base64(a));
END;
//
