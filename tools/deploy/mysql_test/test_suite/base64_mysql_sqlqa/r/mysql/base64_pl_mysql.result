base64-4-3 触发器 
DROP TABLE base_test1;
CREATE TABLE base_test1(  
  c1 int,  
  c2 float, 
  c3 DECIMAL(5,2) DEFAULT 8.8, 
  c4 VARCHAR(100), 
  c5 bit(10),
  c6 datetime, 
  c7 json NOT NULL,
  c8 SET('a', 'b', 'c', 'd'));
CREATE INDEX INDEX_base_test1_T1 ON base_test1(c4);
ALTER TABLE `base_test1` ADD INDEX INDEX_base_test1_T3 (c6, c1);
CREATE INDEX INDEX_base_test1_T5 USING HASH ON base_test1(c8);
DROP TABLE base_test2;
CREATE TABLE base_test2(  
  c1 int,  
  c2 float, 
  c3 DECIMAL(5,2) DEFAULT 8.8, 
  c4 VARCHAR(100), 
  c5 bit(10),
  c6 datetime, 
  c7 json NOT NULL,
  c8 SET('a', 'b', 'c', 'd'));
DROP TRIGGER base_pl;
CREATE TRIGGER base_pl BEFORE INSERT
ON base_test2 FOR EACH ROW
BEGIN
DECLARE a int;
DECLARE b VARCHAR(20);
set a=1;
set b='insert';
loop1: LOOP
		if a < 4 then
		   insert into base_test1 values(from_base64(to_base64(a)),
		   from_base64('MS4xMTEx'),
		   2.2,
		   from_base64(to_base64(b)),
		   from_base64(to_base64(b'1000001')),
		   from_base64(to_base64('2020-10-10 23:59:59.999999')),
		   '[{"abs":123}]',
		   from_base64(to_base64('a,d')));

		elseif 6 = a then
			   update base_test1 set c4 = to_base64(b),
						c6 = from_base64('MjAyMC0xMi0yMiAyMzo1OTo1OS45OTk5OTk=') where c1 < 3;
			LEAVE loop1;
		else
			   replace into base_test1 values(from_base64(to_base64(a)),
			   from_base64('MS4xMTEx'),
			   2.2,
			   from_base64(to_base64('replace')),
			   from_base64(to_base64(b'1000001')),
			   from_base64(to_base64('2020-12-31 23:59:59.999999')),
			   '[{"abs":123},"汉字123！@#$%^&*()_+",[0]]',
			   from_base64(to_base64('b,d')));
				
		end if;
                set a = a + 1;

    end LOOP loop1;
END;
//
