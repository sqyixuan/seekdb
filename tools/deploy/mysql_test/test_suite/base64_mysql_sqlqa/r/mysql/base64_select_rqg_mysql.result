purge recyclebin;
result_format: 4
base64-2 select + group by/join/where + 函数
DROP TABLE TEST_D1;
CREATE TABLE TEST_D1 (
col_timestamp_6 timestamp(6) NULL DEFAULT NULL,
col_bigint bigint,
col_char_20 char(20),
pk bigint,
col_decimal_20_0 decimal(20,0),
col_varchar_20 varchar(20),
primary key (pk) ) ;
INSERT INTO TEST_D1 VALUES  ('2002-07-25 10:56:54.011238', -4081105687327801344, 'gjq', 1, 2794202093806682112, 'kgjqy') ;
COMMIT;
DROP TABLE TEST_D2;
CREATE TABLE TEST_D2 (
col_char_20 char(20),
col_decimal_20_0 decimal(20,0),
col_bigint bigint,
col_varchar_20 varchar(20),
col_timestamp_6 timestamp(6) NULL DEFAULT NULL,
pk bigint,
primary key (pk) )  PARTITION BY key (pk) partitions 3 ;
INSERT INTO TEST_D2 VALUES  ('bzij', -951666896258727936, 7385621913910902784, 'lbzij', '2004-03-15 08:43:19.041319', 1) ;
commit;
DROP TABLE TEST_D3;
CREATE TABLE TEST_D3 (
col_timestamp_6 timestamp(6) NULL DEFAULT NULL,
col_decimal_20_0 decimal(20,0),
col_varchar_20 varchar(20),
pk bigint,
col_bigint bigint,
col_char_20 char(20),
primary key (pk) ) 
PARTITION BY hash (pk) partitions 15 ;
