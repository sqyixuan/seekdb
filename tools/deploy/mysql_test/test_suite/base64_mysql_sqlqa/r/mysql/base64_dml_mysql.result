base64-3-6 dml + 生成列
DROP TABLE base_test1;
CREATE TABLE base_test1(  
  c1 int primary key,  
  c2 float, 
  c3 DECIMAL(5,2) DEFAULT null, 
  c4 VARCHAR(100), 
  c5 bit(10),
  c6 datetime, 
  c7 json NOT NULL,
  c8 SET('a', 'b', 'c', 'd'),
  c9 VARCHAR(200) AS (to_base64(c2)) virtual,
  c10 VARCHAR(200) AS (concat(from_base64(to_base64('abc')),c4)) stored);
