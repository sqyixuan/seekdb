base64-3-4 dml + range分区表+ 视图 + 约束 + 索引
DROP TABLE base_test2;
CREATE TABLE base_test2(  
  c1 int primary key,  
  c2 float unique, 
  c3 DECIMAL(5,2) DEFAULT null, 
  c4 VARCHAR(100), 
  c5 bit(10),
  c6 datetime, 
  c7 json NOT NULL,
  c8 SET('a', 'b', 'c', 'd'));
DROP TABLE base_test1;
CREATE TABLE base_test1(  
  c1 int primary key,  
  c2 float, 
  c3 DECIMAL(5,2) DEFAULT 8.8, 
  c4 VARCHAR(100), 
  c5 bit(10),
  c6 datetime, 
  c7 json NOT NULL,
  c8 SET('a', 'b', 'c', 'd'))
  PARTITION BY RANGE (c1)(
PARTITION less_2 VALUES less than (2),
PARTITION b_2_4 VALUES less than (4),
PARTITION b_4_2000 VALUES less than (2000),
PARTITION greater_2000 VALUES less than MAXVALUE);
CREATE INDEX INDEX_base_test1_T1 ON base_test1(c4);
ALTER TABLE `base_test1` ADD INDEX INDEX_base_test1_T3 (c6, c1);
CREATE INDEX INDEX_base_test1_T5 USING HASH ON base_test1(c8);
drop view view_test1;
CREATE VIEW view_test1 AS select * from base_test1;
