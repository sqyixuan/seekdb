create table t11 (v1 varbinary(100));
insert into t11 values(sm4_encrypt('how', 'oceanbase'));
insert into t11 values(sm4_encrypt('long', 'oceanbase'));
insert into t11 values(sm4_encrypt('is', 'oceanbase'));
insert into t11 values(sm4_encrypt('forever', 'oceanbase'));
