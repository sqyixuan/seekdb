select sm4_decrypt(v1, 'oceanbase') from t11;
+------------------------------+
| sm4_decrypt(v1, 'oceanbase') |
+------------------------------+
| how                          |
| long                         |
| is                           |
| forever                      |
+------------------------------+

set block_encryption_mode = 18;
select hex(sm4_encrypt('', '')) from dual;
+----------------------------------+
| hex(sm4_encrypt('', ''))         |
+----------------------------------+
| A83F90CC9F35CAC4DAF66BFA071C4182 |
+----------------------------------+
select hex(sm4_encrypt('','abc')) from dual;
+----------------------------------+
| hex(sm4_encrypt('','abc'))       |
+----------------------------------+
| F7374BA38B12961AFEF6D110EEC67A0A |
+----------------------------------+
select hex(sm4_encrypt('abc','')) from dual;
+----------------------------------+
| hex(sm4_encrypt('abc',''))       |
+----------------------------------+
| FCEFA67A1D7C873CCD5812601E28A729 |
+----------------------------------+
select hex(sm4_encrypt(null, null)) from dual;
+------------------------------+
| hex(sm4_encrypt(null, null)) |
+------------------------------+
| NULL                         |
+------------------------------+
select hex(sm4_encrypt(null, 'abc')) from dual;
+-------------------------------+
| hex(sm4_encrypt(null, 'abc')) |
+-------------------------------+
| NULL                          |
+-------------------------------+
select hex(sm4_encrypt('abc', null)) from dual;
+-------------------------------+
| hex(sm4_encrypt('abc', null)) |
+-------------------------------+
| NULL                          |
+-------------------------------+
select hex(sm4_encrypt(123, null)) from dual;
+-----------------------------+
| hex(sm4_encrypt(123, null)) |
+-----------------------------+
| NULL                        |
+-----------------------------+

select sm4_encrypt(aasd) from dual;
ERROR 42000: Incorrect parameter count in the call to native function 'sm4_encrypt'
select sm4_encrypt(1) from dual;
ERROR 42000: Incorrect parameter count in the call to native function 'sm4_encrypt'
select sm4_encrypt('1','2','3','4') from dual;
ERROR 42000: Incorrect parameter count in the call to native function 'sm4_encrypt'
select sm4_encrypt(1,2,3,4) from dual;
ERROR 42000: Incorrect parameter count in the call to native function 'sm4_encrypt'
select sm4_encrypt(hahaha) from dual;
ERROR 42000: Incorrect parameter count in the call to native function 'sm4_encrypt'
select sm4_encrypt('') from dual;
ERROR 42000: Incorrect parameter count in the call to native function 'sm4_encrypt'

set block_encryption_mode = 19;
select sm4_encrypt(1, 2) from dual;
ERROR 42000: Incorrect parameter count in the call to native function 'sm4_encrypt'
select sm4_encrypt(1, 2, 3, 4) from dual;
ERROR 42000: Incorrect parameter count in the call to native function 'sm4_encrypt'
select sm4_encrypt('a','') from dual;
ERROR 42000: Incorrect parameter count in the call to native function 'sm4_encrypt'
select sm4_encrypt(null, 'a') from dual;
+------------------------+
| sm4_encrypt(null, 'a') |
+------------------------+
| NULL                   |
+------------------------+
select sm4_decrypt('a', null) from dual;
+------------------------+
| sm4_decrypt('a', null) |
+------------------------+
| NULL                   |
+------------------------+

select sm4_encrypt('a','b','c') from dual;
ERROR HY000: The initialization vector supplied is too short. Must be at least 16 bytes long
