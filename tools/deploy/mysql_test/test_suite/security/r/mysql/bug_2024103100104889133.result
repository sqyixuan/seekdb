DROP USER IF EXISTS test_u1;
DROP USER IF EXISTS test_u2;
SET GLOBAL validate_password_length = 8;
CREATE USER test_u1;
GRANT ALL ON *.* to test_u1;
SET GLOBAL validate_password_policy = low;
SHOW VARIABLES LIKE "%validate_password_length";
Variable_name	Value
validate_password_length	8
SHOW VARIABLES LIKE "%validate_password_policy";
Variable_name	Value
validate_password_policy	low
CREATE USER test_u2 IDENTIFIED BY '123';
ERROR HY000: Your password does not satisfy the current policy requirements
CREATE USER test_u2 IDENTIFIED BY '12345678';
DROP USER test_u2;
SET GLOBAL validate_password_policy = medium;
SHOW VARIABLES LIKE "%validate_password_length";
Variable_name	Value
validate_password_length	8
SHOW VARIABLES LIKE "%validate_password_policy";
Variable_name	Value
validate_password_policy	medium
CREATE USER test_u2 IDENTIFIED BY '123';
ERROR HY000: Your password does not satisfy the current policy requirements
CREATE USER test_u2 IDENTIFIED BY '12345678';
DROP USER test_u2;
DROP USER test_u1;
SET GLOBAL validate_password_length = 0;
SET GLOBAL validate_password_policy = low;
