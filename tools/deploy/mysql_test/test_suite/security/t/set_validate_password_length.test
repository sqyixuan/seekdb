# tags: security

set global validate_password_check_user_name = 0;
set global validate_password_mixed_case_count = 0;
set global validate_password_number_count = 0;
set global validate_password_policy = 0;
set global validate_password_special_char_count = 0;
set global validate_password_length = 0;

--source mysql_test/include/check_schema_sync.inc
connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
show variables like '%password%';
disconnect conn1;
connection default;

--echo # set one system variable at a time
set global validate_password_mixed_case_count = 3;

--source mysql_test/include/check_schema_sync.inc
connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
show variables like '%password%';
disconnect conn1;
connection default;

set global validate_password_number_count = 3;

--source mysql_test/include/check_schema_sync.inc
connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
show variables like '%password%';
disconnect conn1;
connection default;

set global validate_password_special_char_count = 3;

--source mysql_test/include/check_schema_sync.inc
connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
show variables like '%password%';
disconnect conn1;
connection default;

--echo # reset
set global validate_password_mixed_case_count = 0;
set global validate_password_number_count = 0;
set global validate_password_special_char_count = 0;
set global validate_password_length = 0;

--source mysql_test/include/check_schema_sync.inc
connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
show variables like '%password%';
disconnect conn1;
connection default;

set global validate_password_length = 10;

--source mysql_test/include/check_schema_sync.inc
connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
show variables like '%password%';
disconnect conn1;
connection default;

set global validate_password_number_count = 1;
set global validate_password_number_count = 1;
set global validate_password_special_char_count = 1;

--source mysql_test/include/check_schema_sync.inc
connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
show variables like '%password%';
disconnect conn1;
connection default;

set global validate_password_length = 2;

--source mysql_test/include/check_schema_sync.inc
connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
show variables like '%password%';
disconnect conn1;
connection default;

set global validate_password_length = 5;

--source mysql_test/include/check_schema_sync.inc
connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
show variables like '%password%';
disconnect conn1;
connection default;

--echo # reset
set global validate_password_mixed_case_count = 0;
set global validate_password_number_count = 0;
set global validate_password_special_char_count = 0;
set global validate_password_length = 0;

--source mysql_test/include/check_schema_sync.inc
connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
show variables like '%password%';
disconnect conn1;
connection default;

--echo # set more than one system variables at a time
set global validate_password_mixed_case_count = 2, global validate_password_number_count = 3, global validate_password_special_char_count = 1;

--source mysql_test/include/check_schema_sync.inc
connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
show variables like '%password%';
disconnect conn1;
connection default;

set global validate_password_length = 4, global validate_password_mixed_case_count = 1, global validate_password_number_count = 1;

--source mysql_test/include/check_schema_sync.inc
connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
show variables like '%password%';
disconnect conn1;
connection default;

set global validate_password_mixed_case_count = 5, global validate_password_length = 4, global validate_password_mixed_case_count = 1;

--source mysql_test/include/check_schema_sync.inc
connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
show variables like '%password%';
disconnect conn1;
connection default;

set global validate_password_length = 4, global validate_password_mixed_case_count = 2;

--source mysql_test/include/check_schema_sync.inc
connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
show variables like '%password%';
disconnect conn1;
connection default;

# cleanup
set global validate_password_check_user_name = 0;
set global validate_password_mixed_case_count = 0;
set global validate_password_number_count = 0;
set global validate_password_policy = 0;
set global validate_password_special_char_count = 0;
set global validate_password_length = 0;

