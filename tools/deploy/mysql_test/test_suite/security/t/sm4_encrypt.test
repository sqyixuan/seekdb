# owner:sean.yyj
# owner group: SQL3
# tags: funcs
# descrpt: 测试加密解密函数sm4_encrypt,sm4_decrypt

--result_format 4

--disable_warnings
drop database if exists yishen;
--enable_warnings
create database yishen;
use yishen;


#basic test
set block_encryption_mode = 18;
show variables like 'block_encryption_mode';
--source mysql_test/test_suite/security/include/sm4_three_param.inc
--source mysql_test/test_suite/security/include/sm4_two_param.inc
select hex(sm4_encrypt('asdasdasdasd', '12312313123', 'asdas'));

set block_encryption_mode = 19;
show variables like 'block_encryption_mode';
--source mysql_test/test_suite/security/include/sm4_three_param.inc

set block_encryption_mode = 20;
show variables like 'block_encryption_mode';
--source mysql_test/test_suite/security/include/sm4_three_param.inc

set block_encryption_mode = 21;
show variables like 'block_encryption_mode';
--source mysql_test/test_suite/security/include/sm4_three_param.inc

# other test
set block_encryption_mode = 18;
create table t1 as select sm4_encrypt('abc', 'cd') from dual;
create table t2 as select sm4_encrypt('ab19371289047238947238947c', 'cd') from dual;
create table t3 as select sm4_encrypt('ab12391290381209381209381092380129830129381290309123810923801298301283190238102380129381023809c', 'cd') from dual;
create table t4 as select sm4_encrypt('ab1289371289371928371923789c', 'cd') from dual;
desc t1;
desc t2;
desc t3;
desc t4;

  
create table t5 as select sm4_decrypt('abc', 'cd') from dual;
create table t6 as select sm4_decrypt('ab19371289047238947238947c', 'cd') from dual;
create table t7 as select sm4_decrypt('ab12391290381209381209381092380129830129381290309123810923801298301283190238102380129381023809c', 'cd') from dual;
create table t8 as select sm4_decrypt('ab1289371289371928371923789c', 'cd') from dual;
desc t5;
desc t6;
desc t7;
desc t8;

create table t11 (v1 varbinary(100));
insert into t11 values(sm4_encrypt('how', 'oceanbase'));
insert into t11 values(sm4_encrypt('long', 'oceanbase'));
insert into t11 values(sm4_encrypt('is', 'oceanbase'));
insert into t11 values(sm4_encrypt('forever', 'oceanbase'));
select hex(v1) from t11;
select sm4_decrypt(v1, 'oceanbase') from t11;

#corner test
set block_encryption_mode = 18;
select hex(sm4_encrypt('', '')) from dual;
select hex(sm4_encrypt('','abc')) from dual;
select hex(sm4_encrypt('abc','')) from dual;
select hex(sm4_encrypt(null, null)) from dual;
select hex(sm4_encrypt(null, 'abc')) from dual;
select hex(sm4_encrypt('abc', null)) from dual;
select hex(sm4_encrypt(123, null)) from dual;

#negative test
--error 1582
select sm4_encrypt(aasd) from dual;
--error 1582
select sm4_encrypt(1) from dual;
--error 1582
select sm4_encrypt('1','2','3','4') from dual;
--error 1582
select sm4_encrypt(1,2,3,4) from dual;
--error 1582
select sm4_encrypt(hahaha) from dual;
--error 1582
select sm4_encrypt('') from dual;

set block_encryption_mode = 19;
--error 1582
select sm4_encrypt(1, 2) from dual;
--error 1582
select sm4_encrypt(1, 2, 3, 4) from dual;
--error 1582
select sm4_encrypt('a','') from dual;
#--error 0, 1582
select sm4_encrypt(null, 'a') from dual;
select sm4_decrypt('a', null) from dual;

--error 1882
select sm4_encrypt('a','b','c') from dual;
--error 1882
select sm4_encrypt('a','b','c131231213') from dual;

drop database yishen;
