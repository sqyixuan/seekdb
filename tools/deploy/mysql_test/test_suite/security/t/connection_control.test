# owner: sean.yyj
# owner group: SQL3
# tags: security
# description: test connection control in mysql mode



--disable_warnings
--error 0,ER_CANNOT_USER
drop user u_conn_control;
--error 0,ER_CANNOT_USER
drop user u_conn_control@'%%';
--error 0,ER_CANNOT_USER
drop user u_conn_control@'not_exist';
--enable_warnings

--echo # prepare
create user u_conn_control identified by '123';
create user u_conn_control@'%%' identified by '321';
create user u_conn_control@'not_exist' identified by '456';
grant all on *.* to u_conn_control;
grant all on *.* to u_conn_control@'%%';
grant all on *.* to u_conn_control@'not_exist';
--source mysql_test/include/check_schema_fast_sync.inc
connection default;
--result_format 3
select user,host from mysql.user where user = 'u_conn_control';
select * from information_schema.connection_control_failed_login_attempts where userhost like '%u_conn_control%';

--echo # test when connection_control is disabled
connect (conn_correct,$OBMYSQL_MS0,u_conn_control,'123',test,$OBMYSQL_PORT);
disconnect conn_correct;
connection default;
alter system set connection_control_failed_connections_threshold = 0;
alter system set connection_control_min_connection_delay = 1000;
alter system set connection_control_max_connection_delay = 2147483647;
sleep 5;
# show parameters like '%connection_control%';
--disable_query_log
--error 1045
connect (conn_wrong,$OBMYSQL_MS0,u_conn_control,'12',test,$OBMYSQL_PORT);
--enable_query_log
select * from information_schema.connection_control_failed_login_attempts where userhost like '%u_conn_control%';

--echo # test when connection_control is enabled
alter system set connection_control_failed_connections_threshold = 2;
alter system set connection_control_min_connection_delay = 5000;
alter system set connection_control_max_connection_delay = 10000;
sleep 5;
# show parameters like '%connection_control%';
--disable_query_log
--error 1045
connect (conn_wrong,$OBMYSQL_MS0,u_conn_control,'12',test,$OBMYSQL_PORT);
--error 1045
connect (conn_wrong,$OBMYSQL_MS0,u_conn_control,'12',test,$OBMYSQL_PORT);
connection default;
--enable_query_log
select * from information_schema.connection_control_failed_login_attempts where userhost like '%u_conn_control%';
select user_name,host,is_locked from oceanbase.__all_user where user_name = 'u_conn_control';
--disable_query_log
sleep 5;
--error 1045
connect (conn_wrong,$OBMYSQL_MS0,u_conn_control,'12',test,$OBMYSQL_PORT);
--echo # the user is locked no matter how whether the password is correct
--error 3118
connect (conn_wrong,$OBMYSQL_MS0,u_conn_control,'12',test,$OBMYSQL_PORT);
--error 3118
connect (conn_correct,$OBMYSQL_MS0,u_conn_control,'123',test,$OBMYSQL_PORT);
sleep 5;
--echo # wait a moment until the user is unlocked
--error 1045
connect (conn_wrong,$OBMYSQL_MS0,u_conn_control,'12',test,$OBMYSQL_PORT);
connection default;
--enable_query_log
select * from information_schema.connection_control_failed_login_attempts where userhost like '%u_conn_control%';
sleep 5;
--echo # connect with the right password to clear the fail login stat and unlock user
connect (conn_correct,$OBMYSQL_MS0,u_conn_control,'123',test,$OBMYSQL_PORT);
select * from information_schema.connection_control_failed_login_attempts where userhost like '%u_conn_control%';
select user_name,host,is_locked from oceanbase.__all_user where user_name = 'u_conn_control';
disconnect conn_correct;

# cleanup
connection default;
drop user u_conn_control, u_conn_control@'%%', u_conn_control@'not_exist';
alter system set connection_control_failed_connections_threshold = 0;
alter system set connection_control_min_connection_delay = 1000;
alter system set connection_control_max_connection_delay = 2147483647;
--result_format 1
