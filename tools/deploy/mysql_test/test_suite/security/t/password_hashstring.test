#owner: zhuangyifeng.zyf
#owner group: SQL1
#description: 设置 hashstring 密码不需要通过 password_policy 策略校验
#tags: security

--disable_warnings
drop user if exists foo;
drop user if exists tester;
drop user if exists tester2;
--enable_warnings

create user foo;
grant all privileges on *.* to foo with grant option;
# 测试用 set password 语法将密码置空
SET PASSWORD FOR 'foo'@'%' = '';

show variables like "%validate_password%";

connect (conn_foo,$OBMYSQL_MS0,foo,,test,$OBMYSQL_PORT);
SET GLOBAL validate_password_policy='medium';
SET GLOBAL validate_password_number_count=1;
SET GLOBAL validate_password_special_char_count=1;
SET GLOBAL validate_password_mixed_case_count=1;
SET GLOBAL validate_password_check_user_name='ON';
SET GLOBAL validate_password_length=18;
--source mysql_test/include/check_schema_sync.inc
disconnect conn_foo;

sleep 5;

connect (conn_foo,$OBMYSQL_MS0,foo,,test,$OBMYSQL_PORT);
show variables like "%validate_password%";

# === CREATE USER ===
# 测试是否可以将一个合法的 hash 串设置为密文密码
# 可以通过 identified by password 'hashstring' 设置密码
CREATE USER 'tester'@'%' IDENTIFIED BY PASSWORD '*3525F0A5F304AFBC769CC3D054EAB1F958038A97';

# 测试是否可以将一个非法的 hash 串设置为密文密码
# 长度不足
--error 1827
CREATE USER 'tester2'@'%' IDENTIFIED BY PASSWORD '*3525F0A5F304AFBC769CC3D054EAB1F958038A9';
# hash 串不以 * 开头
--error 1827
CREATE USER 'tester2'@'%' IDENTIFIED BY PASSWORD '3525F0A5F304AFBC769CC3D054EAB1F958038A97';
# hash 串中包含非字母或数字的字符
--error 1827
CREATE USER 'tester2'@'%' IDENTIFIED BY PASSWORD '3525F0A5F304AFBC769CC3D054EAB1F958038A9_';

# 测试是否可以将一个非法的字符串设置为明文密码
# 只包含大写和数字
--error 1819
CREATE USER 'tester2'@'%' IDENTIFIED BY '*3525F0A5F304AFBC769CC3D054EAB1F958038A97';
# 只包含小写和数字
--error 1819
CREATE USER 'tester2'@'%' IDENTIFIED BY '*123456789abcdefg123456789abcdefg12345678';
# 不包含数字
--error 1819
CREATE USER 'tester2'@'%' IDENTIFIED BY '*AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAb';
# 长度不足
--error 1819
CREATE USER 'tester2'@'%' IDENTIFIED BY '*Aa123456789';

# 这是一个满足密码强度校验规则的合法明文密码
CREATE USER 'tester2'@'%' IDENTIFIED BY '*3525F0A5F304AFBC769CC3D054EAB1F958038a97';

drop user tester;
drop user tester2;

# === GRANT ===
# 测试是否可以将一个合法的 hash 串设置为密文密码
# grant 语句创建用户时, 可以通过 identified by password 'hashstring' 设置密文密码
GRANT select on *.* to 'tester'@'%' IDENTIFIED BY PASSWORD '*3525F0A5F304AFBC769CC3D054EAB1F958038A97';

# 测试是否可以将一个非法的 hash 串设置为密文密码
# 长度不足
--error 1827
GRANT select on *.* to 'tester2'@'%' IDENTIFIED BY PASSWORD '*3525F0A5F304AFBC769CC3D054EAB1F958038A9';
# hash 串不以 * 开头
--error 1827
GRANT select on *.* to 'tester2'@'%' IDENTIFIED BY PASSWORD '3525F0A5F304AFBC769CC3D054EAB1F958038A97';
# hash 串中包含非字母或数字的字符
--error 1827
GRANT select on *.* to 'tester2'@'%' IDENTIFIED BY PASSWORD '3525F0A5F304AFBC769CC3D054EAB1F958038A9_';

# 测试是否可以将一个非法的字符串设置为明文密码
# 只包含大写和数字
--error 1819
GRANT select on *.* to 'tester2'@'%' IDENTIFIED BY '*3525F0A5F304AFBC769CC3D054EAB1F958038A97';
# 只包含小写和数字
--error 1819
GRANT select on *.* to 'tester2'@'%' IDENTIFIED BY '*123456789abcdefg123456789abcdefg12345678';
# 不包含数字
--error 1819
GRANT select on *.* to 'tester2'@'%' IDENTIFIED BY '*AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAb';
# 长度不足
--error 1819
GRANT select on *.* to 'tester2'@'%' IDENTIFIED BY '*Aa123456789';

# 这是一个满足密码强度校验规则的合法明文密码
GRANT select on *.* to 'tester2'@'%' IDENTIFIED BY '*3525F0A5F304AFBC769CC3D054EAB1F958038a97';

drop user tester;
drop user tester2;

# === SET PASSWORD ===
CREATE USER 'tester'@'%' IDENTIFIED BY PASSWORD '*3525F0A5F304AFBC769CC3D054EAB1F958038A97';

# 测试是否可以将一个合法的 hash 串设置为密文密码
# 注: 此处和 mysql 的行为不一致, mysql 的 set password 的两种语法传入的都是明文密码
--error 1819
SET PASSWORD FOR 'tester'@'%' = '*3525F0A5F304AFBC769CC3D054EAB1F958038A98';

# 测试是否可以将一个非法的字符串设置为明文密码
# 只包含大写和数字
--error 1819
SET PASSWORD FOR 'tester'@'%' = PASSWORD('*3525F0A5F304AFBC769CC3D054EAB1F958038A97');
# 只包含小写和数字
--error 1819
SET PASSWORD FOR 'tester'@'%' = PASSWORD('*123456789abcdefg123456789abcdefg12345678');
# 不包含数字
--error 1819
SET PASSWORD FOR 'tester'@'%' = PASSWORD('*AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAb');
# 长度不足
--error 1819
SET PASSWORD FOR 'tester'@'%' = PASSWORD('*Aa123456789');

# 这是一个满足密码强度校验规则的合法明文密码
SET PASSWORD FOR 'tester'@'%' = PASSWORD('*3525F0A5F304AFBC769CC3D054EAB1F958038a97');

drop user tester;
disconnect conn_foo;

connection default;
drop user foo;

SET GLOBAL validate_password_policy=default;
SET GLOBAL validate_password_number_count=default;
SET GLOBAL validate_password_special_char_count=default;
SET GLOBAL validate_password_mixed_case_count=default;
SET GLOBAL validate_password_check_user_name=default;
SET GLOBAL validate_password_length=0;
--source mysql_test/include/check_schema_sync.inc

sleep 5;