# owner: zhuangyifeng.zyf
# owner group: SQL1
# tags: security
# descrption: 测试 validate_password_policy 为 medium 时, validate_password_length 的有效性

--disable_warnings
DROP USER IF EXISTS test_u1;
DROP USER IF EXISTS test_u2;
--enable_warnings

let $vpl = query_get_value(SHOW VARIABLES LIKE 'validate_password_length', Value, 1);
let $vpp = query_get_value(SHOW VARIABLES LIKE 'validate_password_policy', Value, 1);
SET GLOBAL validate_password_length = 8;

CREATE USER test_u1;
GRANT ALL ON *.* to test_u1;

# validate_password_policy = low 时密码长度不足，创建用户会失败
SET GLOBAL validate_password_policy = low;
connect(test_u1,$OBMYSQL_MS0,test_u1,,test,$OBMYSQL_PORT);
SHOW VARIABLES LIKE "%validate_password_length";
SHOW VARIABLES LIKE "%validate_password_policy";
-- error 1819
CREATE USER test_u2 IDENTIFIED BY '123';
CREATE USER test_u2 IDENTIFIED BY '12345678';
DROP USER test_u2;
disconnect test_u1;

# validate_password_policy = medium 时密码长度不足，创建用户也要失败
connection default;
SET GLOBAL validate_password_policy = medium;
connect(test_u1,$OBMYSQL_MS0,test_u1,,test,$OBMYSQL_PORT);
SHOW VARIABLES LIKE "%validate_password_length";
SHOW VARIABLES LIKE "%validate_password_policy";
-- error 1819
CREATE USER test_u2 IDENTIFIED BY '123';
CREATE USER test_u2 IDENTIFIED BY '12345678';
DROP USER test_u2;
disconnect test_u1;

connection default;
DROP USER test_u1;
eval SET GLOBAL validate_password_length = $vpl;
eval SET GLOBAL validate_password_policy = $vpp;