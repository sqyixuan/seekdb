
# owner: zhuangyifeng.zyf
# owner group: SQL1
# tags: funcs
# descrption: 测试 user lock 超时时间

--disable_warnings
drop user if exists u1;
--enable_warnings

create user u1 identified by '123';
grant all on *.* to u1;
-- echo # 设置用户登录失败锁定次数为 1 次
alter system set connection_control_failed_connections_threshold = 1;
-- echo # 设置锁定用户时间为 15s
alter system set connection_control_min_connection_delay = 15000;

-- echo # 使用错误密码登录失败
-- disable_query_log
-- error 1045,3118
connect (conn_u1,$OBMYSQL_MS0,u1,'1',test,$OBMYSQL_PORT);
-- enable_query_log
-- echo 用户锁定
-- disable_query_log
-- error 1045,3118
connect (conn_u1,$OBMYSQL_MS0,u1,'1',test,$OBMYSQL_PORT);
-- enable_query_log

sleep 10;
-- echo # 等待 10s, 使用正确密码登录, 仍然在锁定期间内, 登录失败
-- disable_query_log
-- error 1045,3118
connect (conn_u1,$OBMYSQL_MS0,u1,'123',test,$OBMYSQL_PORT);
-- enable_query_log

sleep 10;
-- echo # 再等待 10s, 登录成功
connect (conn_u1,$OBMYSQL_MS0,u1,'123',test,$OBMYSQL_PORT);
disconnect conn_u1;

connection default;

alter system reset connection_control_failed_connections_threshold;
alter system reset connection_control_min_connection_delay;

drop user u1;