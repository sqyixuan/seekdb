# other test
set block_encryption_mode = 0;
create table t1 as select aes_encrypt('abc', 'cd') from dual;
create table t2 as select aes_encrypt('ab19371289047238947238947c', 'cd') from dual;
create table t3 as select aes_encrypt('ab12391290381209381209381092380129830129381290309123810923801298301283190238102380129381023809c', 'cd') from dual;
create table t4 as select aes_encrypt('ab1289371289371928371923789c', 'cd') from dual;
desc t1;
desc t2;
desc t3;
desc t4;

  
create table t5 as select aes_decrypt('abc', 'cd') from dual;
create table t6 as select aes_decrypt('ab19371289047238947238947c', 'cd') from dual;
create table t7 as select aes_decrypt('ab12391290381209381209381092380129830129381290309123810923801298301283190238102380129381023809c', 'cd') from dual;
create table t8 as select aes_decrypt('ab1289371289371928371923789c', 'cd') from dual;
desc t5;
desc t6;
desc t7;
desc t8;

create table t11 (v1 varbinary(100));
insert into t11 values(aes_encrypt('how', 'oceanbase'));
insert into t11 values(aes_encrypt('long', 'oceanbase'));
insert into t11 values(aes_encrypt('is', 'oceanbase'));
insert into t11 values(aes_encrypt('forever', 'oceanbase'));
select hex(v1) from t11;
select aes_decrypt(v1, 'oceanbase') from t11;

#corner test
set block_encryption_mode = 0;
select hex(aes_encrypt('', '')) from dual;
select hex(aes_encrypt('','abc')) from dual;
select hex(aes_encrypt('abc','')) from dual;
select hex(aes_encrypt(null, null)) from dual;
select hex(aes_encrypt(null, 'abc')) from dual;
select hex(aes_encrypt('abc', null)) from dual;
select hex(aes_encrypt(123, null)) from dual;

#negative test
--error 1582
select aes_encrypt(aasd) from dual;
--error 1582
select aes_encrypt(1) from dual;
--error 1582
select aes_encrypt('1','2','3','4') from dual;
--error 1582
select aes_encrypt(1,2,3,4) from dual;
--error 1582
select aes_encrypt(hahaha) from dual;
--error 1582
select aes_encrypt('') from dual;

set block_encryption_mode = 5;
--error 1582
select aes_encrypt(1, 2) from dual;
--error 1582
select aes_encrypt(1, 2, 3, 4) from dual;
--error 1582
select aes_encrypt('a','') from dual;
#--error 0, 1582
select aes_encrypt(null, 'a') from dual;
select aes_decrypt('a', null) from dual;

--error 1882
select aes_encrypt('a','b','c') from dual;
--error 1882
select aes_encrypt('a','b','c131231213') from dual;

drop database yishen;
