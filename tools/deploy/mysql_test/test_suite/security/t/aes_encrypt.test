# owner:sean.yyj
# owner group: SQL3
# tags: funcs
# descrpt: 测试加密解密函数aes_encrypt,aes_decrypt

--result_format 4

--disable_warnings
drop database if exists yishen;
--enable_warnings
create database yishen;
use yishen;


#basic test
set block_encryption_mode = 0;
show variables like '%encrypt%mode';
--source mysql_test/test_suite/security/include/aes_three_param.inc
--source mysql_test/test_suite/security/include/aes_two_param.inc
select hex(aes_encrypt('asdasdasdasd', '12312313123', 'asdas'));
set block_encryption_mode = 1;
show variables like '%encrypt%mode';
--source mysql_test/test_suite/security/include/aes_three_param.inc
--source mysql_test/test_suite/security/include/aes_two_param.inc
select hex(aes_encrypt('asdasdasdasd', '12312313123', 'asdas'));
set block_encryption_mode = 2;
show variables like '%encrypt%mode';
--source mysql_test/test_suite/security/include/aes_three_param.inc
--source mysql_test/test_suite/security/include/aes_two_param.inc
select hex(aes_encrypt('asdasdasdasd', '12312313123', 'asdas'));
