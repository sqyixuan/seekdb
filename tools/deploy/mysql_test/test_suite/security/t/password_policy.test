# owner:sean.yyj
# owner group: SQL3
# tags: security
# descrpt: 测试Mysql租户下密码过期和密码强度控制



--disable_warnings
drop database if exists yishen_mysql_encrypt;
--enable_warnings

create database yishen_mysql_encrypt;
use yishen_mysql_encrypt;


set global validate_password_check_user_name = 0;
set global validate_password_mixed_case_count = 0;
set global validate_password_number_count = 0;
set global validate_password_policy = 0;
set global validate_password_special_char_count = 0;
set global validate_password_length = 0;

--source mysql_test/include/check_schema_sync.inc
connection default;
use yishen_mysql_encrypt;

show variables like '%password%';

--echo '在policy为low的情况下, 检查密码长度, 先设置密码长度至少为8位, 再建一个7位的密码用户看是否报错'
set global validate_password_length = 8;
--source mysql_test/include/check_schema_sync.inc
connection default;
use yishen_mysql_encrypt;
connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
--error 1819
create user test_pw identified by '1234567';
disconnect conn1;
connection default;

set global validate_password_length = 0;
set global validate_password_policy = 1;
set global validate_password_check_user_name = on;
--source mysql_test/include/check_schema_sync.inc
connection default;
use yishen_mysql_encrypt;
--echo '在policy为medium的情况下, 依次设置相关系统变量检查是否符合预期'

connect (conn2,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn2;
--error 1819
create user test_yishen_user_name identified by 'admin';
--error 1819
grant all privileges on *.* to test_yishen_user_name identified by 'admin';
create user test_yishen_user_name identified by 'test_yishen_user_name_haha';
--error 1819
alter user test_yishen_user_name identified by 'admin';
drop user test_yishen_user_name;
disconnect conn2;
connection default;

set global validate_password_mixed_case_count = 1;
--source mysql_test/include/check_schema_sync.inc
connection default;
use yishen_mysql_encrypt;
connect (conn3,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn3;
--error 1819
create user test_yishen_user_name_mix_case identified by 'test_user';
--error 1819
grant all privileges on *.* to test_yishen_user_name_mix_case identified by 'test_user';
create user test_yishen_user_name_mix_case identified by 'test_useR';
--error 1819
alter user test_yishen_user_name_mix_case identified by 'test_user';
drop user test_yishen_user_name_mix_case;

disconnect conn3;
connection default;

set global validate_password_mixed_case_count = 0;
set global validate_password_number_count = 1;
--source mysql_test/include/check_schema_sync.inc
connection default;
use yishen_mysql_encrypt;
connect (conn4,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn4;
--error 1819
create user test_yishen_user_name_number_count identified by 'test_user';
--error 1819
grant all privileges on *.* to test_yishen_user_name_number_count identified by 'test_user';
create user test_yishen_user_name_number_count identified by 'test_user1';
--error 1819
alter user test_yishen_user_name_number_count identified by 'test_user';
drop user test_yishen_user_name_number_count;

disconnect conn4;
connection default;

set global validate_password_number_count = 0;
set global validate_password_special_char_count = 1;

--source mysql_test/include/check_schema_sync.inc
connection default;
use yishen_mysql_encrypt;
connect (conn5,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn5;
--error 1819
create user test_yishen_user_special_char identified by 'testuser';
--error 1819
grant all privileges on *.* to test_yishen_user_special_char identified by 'testuser';
create user test_yishen_user_special_char identified by 'testuser$';
--error 1819
alter user test_yishen_user_special_char identified by 'testuser';
alter user test_yishen_user_special_char identified by 'testuser@';
alter user test_yishen_user_special_char identified by 'testuser中文';
drop user test_yishen_user_special_char;

disconnect conn5;
connection default;

# cleanup
set global validate_password_check_user_name = 0;
set global validate_password_mixed_case_count = 0;
set global validate_password_number_count = 0;
set global validate_password_policy = 0;
set global validate_password_special_char_count = 0;
set global validate_password_length = 0;

