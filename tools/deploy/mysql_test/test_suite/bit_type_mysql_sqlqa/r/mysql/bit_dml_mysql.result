bit2-2   update
create table t1 (id bit(8),name char(20));
create table t2 (id bit(8),sex char(2));
insert into t1 values(b'1','zhangsan'),(b'11','lisi'),(b'111','wangwu'),(b'1111','maliu');
insert into t2 values(b'1','1'),(b'11','2'),(b'111','3'),(b'1111','4');
bit2-2-1 in
update t1 set name = 'zhangsan' where id in(select id from t2 where id<b'11');
bit2-2-2 compare
update t1 set name='lilei' where id = (select bin(id) from t2 where sex=1);
update t1 set name = 'fawai' where id>(select id from t2 where id =b'111');
update t1 set name = 'maliu' where id<(select id from t2 where id =b'11');
update t1 set name = 'maliu' where id>=(select id from t2 where id =b'1111');
update t1 set name = 'maliu' where id>=(select id from t2 where id =b'1111');
update t1 set name = 'hangzhou' where id<>(select id from t2 where id >b'111');
update t1 set name = 'hzhou' where id!=(select id from t2 where id =b'111');
bit2-2-3 exists
update t1 set name = 'zhangsan' where exists(select id from t2);
bit2-2-4 any
update t1 set name = 'lisi' where id < any(select id from t2 where id >b'111');
Single row
update t1 set name = 'wangwu' where id=b'1' and name='lisi';
Multiple columns
update t1 set name = 'xiaom'  where name = 'lisi';
drop tables t1,t2;
bit2-3 delete
create table t1 (id bit(8),aa int);
insert into t1 values(b'1',1),(b'11',2),(b'111',2),(b'1111',3);
Single row
delete from t1 where id = 1 and aa = 1;
Multiple columns
delete from t1 where aa=2;
delete from t1;
drop table t1;
bit2-4	select 
bit2-4-1 Multi-table query
create table t1(id bit(8),name varchar(20));
insert into t1 values(b'11','zhaengsan'),(b'111','lisi'),(b'1111','wangwu'),(b'11111','maliu');
create table t2(id bit(8),sex bit);
insert into t2 values(b'11',0),( b'111',1),( b'1111',0),( b'11111',1);
bit2-4-1-1   join on
select bin(t1.id),name,bin(t2.id),bin(sex) from t1 join t2 on t1.id=t2.id;
bin(t1.id)	name	bin(t2.id)	bin(sex)
11	zhaengsan	11	0
111	lisi	111	1
1111	wangwu	1111	0
11111	maliu	11111	1
bit2-4-1-2   left join
select bin(sex) from t1 left join t2 on t1.id=t2.id where name='zhangsan';
bin(sex)
bit2-4-1-2   rigth join
select name from t1 right join t2 on t1.id=t2.id where t1.id=b'11';
name
zhaengsan
drop tables t1;
bit2-4-2 Different base expressions
create table t3(id bit(64));
insert into t3 values(b'1111111111'),(b'010101011010'),(b'00000000000111'),(b'111110101');
select bin(id) from t3;
bin(id)
1111111111
10101011010
111
111110101
select hex(id) from t3;
hex(id)
3FF
55A
7
1F5
select oct(id) from t3;
oct(id)
1777
2532
7
765
drop table t3;
create table t1(id bit(64),name varchar(20),sex bit);
