drop table t1;
create table t1(a1 bit(8),b1 bit(8));
insert into t1 values(b'1111',b'10000000');
select bit_and(a1) from t1;
bit_and(a1)
15
select bit_or(a1) from t1;
bit_or(a1)
15
select bit_xor(a1) from t1;
bit_xor(a1)
15
drop table t1;
create table t1 (c1 bit(8),c2 bit(8),c3 bit(8));
insert into t1 values(b'1111',16,b'1110');
select greatest(c1,c2) from t1;
greatest(c1,c2)
16
select least(c1,c2) from t1;
least(c1,c2)
15
drop table t1;
create table t1(a1 bit(8),c1 date,c2 time,c3 year,c4 datetime,c5 timestamp);
insert into t1 values(b'1010','2021-01-01','16:28:59','2016','2021-06-04 16:33:59','20210604163459');
select a1 - c2  from t1;
a1 - c2
-162849
select a1 -c4  from t1;
a1 -c4
-20210604163349
select a1- c5  from t1;
a1- c5
-20210604163449
drop table t1;
create  table  t1(c1 bit(64));
create  table  t2(c1 year);
insert  into  t2  values('2021'),('1999'),('2018');
insert  into  t1  select  *  from  t2;
select  hex(c1)   from    t1;
hex(c1)
