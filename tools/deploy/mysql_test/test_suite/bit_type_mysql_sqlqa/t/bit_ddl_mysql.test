--disable_warnings
drop database if exists bit1;
--enable_warnings

create database bit1;
use bit1;

--echo	bit1- ddl;
--echo	bit-1-1		create

--error 1064
create table t1(id bit());
--error 1064
create table t1(id bit(-1));
## OB success,mysql error 3013
## create table t1(id bit(0));
create table t2(id bit(1));
create table t3(id bit(64));
--error 1439
create table t4(id bit(65));
create table t5(id bit);

#--bit1-2 drop
drop tables t3,t5;
drop table  t2;

#--bit1-3 alter
create table t1(id bit(1));

## OB error 1138,mysql success
## alter  table t1 change id id bit(64) not null;

## OB error 1235,mysql success
## alter table t1 add tid bit(64) primary key;
alter table t1 add tid bit(64);

alter table t1 change id id bit(8);
desc t1;

alter table t1 change id id int;
desc t1;

alter table t1 drop tid;
desc t1;
drop  table t1;

##--bit1-4 truncat
create table t1(id bit(8)); 
insert into t1 values(b'11111');
truncate table t1;
select bin(id) from t1;

drop table t1;

##--bit1-5 comment
create table t1(id bit comment'用户id')comment='表的注释';

alter table t1 change column id id bit comment'测试id';

alter table t1 comment'修改后的注释';

alter table t1 modify column id bit comment'修改后的字段注释';

show full columns from t1;

show create table t1;
drop table t1;


##--bit1-6 view
create table vt(id bit(8),sex bit);
create view v1 as (select * from vt);
desc v1;
create view v2(id) as (select id from vt);
desc v2;
drop view v1,v2;

##--bit1-7 index
create table t3(id bit not null,unique index uniqueidx(id));

show index from t3;

create table t4(id bit not null,sex bit not null,index Multildx(id,sex));

##create index
create table t1 (id bit(64));

alter table t1 add index xid(id);

alter table t1 add unique index uxid(id);

create index idx_t1 on t1(id);

create unique index u_xid on t1(id);

create table tt1(id bit(8),sex bit);

alter table tt1 add index zuheidx(id,sex);

drop tables tt1,t1,t3,t4;

##--bit3 The constraint
--echo	NOT NULL
create table t1(id bit not null);
desc t1;

--echo	PRIMARY KEY
create table t2(id bit(8) primary key);
desc t2;

--echo	UNIQUE
create table t3(id bit(8),unique(id));
desc t3;

--echo  FOREIGN KEY
create table t4(id bit(8) primary key,tid bit(8),constraint fk_tid foreign key(tid)references t2(id));
desc t4;

--echo  CHECK
##OB error 1064,mysql success
##create table t5(id bit(64) check(id>10 and id<1000));

drop tables t1,t2,t3,t4;


##--bit4 partition
--echo		#hash
create  table part1(id bit(64)) partition by hash(id);
insert  into  part1  values(1),(3),(5);
delete  from  part1  where  id = 3;
update  part1 set id = b'111'  where id = 5;
select  hex(id)  from part1;
drop    table part1;

--echo		#key
create  table part1(id bit(64)) partition by key(id);
insert  into  part1  values(1),(3),(5);
delete  from  part1  where  id = 3;
update  part1 set id = b'111'  where id = 5;
select  hex(id)  from part1;
drop    tables part1;


--echo		#range
create  table part1(id bit(64)) partition by range(id)(partition p0 values less than maxvalue);
insert  into  part1  partition(p0)  values(1),(3),(5);
delete  from  part1  partition(p0)  where  id = 3;
update  part1 partition(p0) set  id = b'111'  where id = 5;
select  hex(id)  from  part1 partition(p0);

insert  into  part1  values(3);
delete  from  part1  where  id = 1;
update  part1 set id = b'111'  where id = 3;
select  hex(id)  from part1;

drop 	tables part1;


--echo		#list
create 	table part1(id bit(64)) partition by list(id)(partition p0 values in(1,2));
insert  into  part1  partition(p0)  values(1),(2);
delete  from  part1  partition(p0)  where  id = 1;
update  part1 partition(p0) set  id = b'111'  where id = 1;
select  hex(id)  from  part1 partition(p0);

insert  into  part1  values(1),(2);
delete  from  part1  where  id = 1;
update  part1 set id = b'111'  where id = 3;
select  hex(id)  from part1;
drop    tables part1;


##OB error 1659, mysql success
##create 	table part1(id bit(64)) partition by range columns(id)(partition p0 values less than maxvalue);

--error 1659  
create 	table part1(id bit(64)) partition by list columns(id) (partition p0 values in (1,2));

drop database bit1;
