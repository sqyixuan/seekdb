--echo 		bit2-1   insert
--disable_warnings
drop database if exists bit1;
--enable_warnings

create database bit1;
use bit1;

--echo		bit2-1   insert
create table t1(id bit);
--error 1406
insert into t1 values(b'111');
insert into t1 values(b'0');
insert into t1 values(b'1');
insert into t1 values(1);
insert into t1 values(null);
--error 1406
insert into t1 values(2);
--error 1054
insert into t1 values(a);
--error 1406
insert into t1 values(-1);
--error 1064
insert into t1 values(=);
drop tables t1;

create table t1(id bit(8));
create table t2(id bit(64));
insert into t1 values(b'0');
insert into t1 values(b'11111111');
--error 1406
insert into t1 values(b'111111111');
insert into t2 values(b'0');
insert into t2 values(b'1111111111111111111111111111111111111111111111111111111111111111');
--error 1406
insert into t2 values(b'11111111111111111111111111111111111111111111111111111111111111111');
drop tables t1,t2;


--echo		bit2-2   update
create table t1 (id bit(8),name char(20));
create table t2 (id bit(8),sex char(2));
insert into t1 values(b'1','zhangsan'),(b'11','lisi'),(b'111','wangwu'),(b'1111','maliu');
insert into t2 values(b'1','1'),(b'11','2'),(b'111','3'),(b'1111','4');

--echo          bit2-2-1 in
update t1 set name = 'zhangsan' where id in(select id from t2 where id<b'11');

--echo 		bit2-2-2 compare
update t1 set name='lilei' where id = (select bin(id) from t2 where sex=1);
update t1 set name = 'fawai' where id>(select id from t2 where id =b'111');
update t1 set name = 'maliu' where id<(select id from t2 where id =b'11');
update t1 set name = 'maliu' where id>=(select id from t2 where id =b'1111');
update t1 set name = 'maliu' where id>=(select id from t2 where id =b'1111');
update t1 set name = 'hangzhou' where id<>(select id from t2 where id >b'111');
update t1 set name = 'hzhou' where id!=(select id from t2 where id =b'111');

--echo          bit2-2-3 exists
update t1 set name = 'zhangsan' where exists(select id from t2);

--echo          bit2-2-4 any
update t1 set name = 'lisi' where id < any(select id from t2 where id >b'111');

--echo         Single row
update t1 set name = 'wangwu' where id=b'1' and name='lisi';

--echo         Multiple columns
update t1 set name = 'xiaom'  where name = 'lisi';
drop tables t1,t2;

--echo		bit2-3 delete
create table t1 (id bit(8),aa int);
insert into t1 values(b'1',1),(b'11',2),(b'111',2),(b'1111',3);
--echo         Single row
delete from t1 where id = 1 and aa = 1;
--echo         Multiple columns
delete from t1 where aa=2;
delete from t1;
drop table t1;



--echo		bit2-4	select 

--echo		bit2-4-1 Multi-table query
create table t1(id bit(8),name varchar(20));
insert into t1 values(b'11','zhaengsan'),(b'111','lisi'),(b'1111','wangwu'),(b'11111','maliu');
create table t2(id bit(8),sex bit);
insert into t2 values(b'11',0),( b'111',1),( b'1111',0),( b'11111',1);

--echo		bit2-4-1-1   join on
select bin(t1.id),name,bin(t2.id),bin(sex) from t1 join t2 on t1.id=t2.id;

--echo		bit2-4-1-2   left join
select bin(sex) from t1 left join t2 on t1.id=t2.id where name='zhangsan';

--echo		bit2-4-1-2   rigth join
select name from t1 right join t2 on t1.id=t2.id where t1.id=b'11';

drop tables t1;

--echo		bit2-4-2 Different base expressions
create table t3(id bit(64));
insert into t3 values(b'1111111111'),(b'010101011010'),(b'00000000000111'),(b'111110101');
select bin(id) from t3;        
select hex(id) from t3;         
select oct(id) from t3; 
drop table t3;

create table t1(id bit(64),name varchar(20),sex bit);
insert into t1 values(b'11','zhangsan',b'0'),(b'111','lisi',b'1');
insert into t1 values(b'1111','wangwu',b'1'),(b'11011','maliu',b'0'),(b'0111','tianqi',b'1');

--echo		bit2-4-3 where
select bin(id) from t1 where id=b'1111' ;
select bin(id) from t1 where id>b'1111' order by id;
select bin(id) from t1 where id>=b'1111' order by id;
select bin(id) from t1 where id<b'1111' order by id desc;
select bin(id) from t1 where id<=b'1111' order by id desc;
select bin(id) from t1 where id<>b'1111' order by id ;
select bin(id) from t1 where id!=b'1111' order by id desc;


--echo		bit2-4-4 group by
select name,bin(sex) from t1 group by sex;

--echo		bit2-4-5 group by having
select count(id) from t1 group by sex having count(id)=1;

--echo		bit2-4-6  distinct
select distinct bin(sex) from t1;


--echo		bit2-4-7  order by
select bin(id),name ,bin(sex) from t1 order by id;
select bin(id),name ,bin(sex) from t1 order by id desc;

--echo		bit2-4-8  like
select bin(id),name ,bin(sex) from t1 where bin(id) like '111%';

select bin(id),name ,bin(sex) from t1 where bin(id) like '%11%';

--echo		bit2-5    replace
replace	 into  t1  values(b'111111111','liuc',b'1');
replace  into  t1(id,name,sex)  values(b'1010101010','eric',b'0');

drop database bit1;

