--disable_warnings
drop database if exists bit1;
--enable_warnings

create database bit1;
use bit1;

create table t1(a1 bit(8),b1 bit(8));
insert into t1 values(b'1111',b'10000000');

##--bit6 bit function
select bit_count(a1) from t1;
select bit_length(a1) from t1;
select bit_and(a1) from t1;
select bit_or(a1) from t1;
select bit_xor(a1) from t1;
drop table t1;

##--bit7  function
--echo		concat
create table t1(c1 bit(64),c2 int,c3 double,c4 date,c5 time,c6 char(20));
insert into  t1  values(b'11111',123,123.123,'20210630','173805','111');
select  concat(bin(c1),c2)   from t1;
select  concat(bin(c1),c3)   from t1;
select  concat(bin(c1),c4)   from t1;
select  concat(bin(c1),c5)   from t1;
select  concat(bin(c1),c6)   from t1;
select  concat(c2,bin(c1))   from t1;
select  concat(c3,bin(c1))   from t1;
select  concat(c4,bin(c1))   from t1;
select  concat(c5,bin(c1))   from t1;
select  concat(c6,bin(c1))   from t1;
drop    table   t1;


--echo		length
create table t1(c1 bit(8),c2 bit(16));
insert into t1 values(b'11111111',64);
select length(c1) from t1;
select length(c2) from t1;
select length(c1+c2) from t1;
select length(c1-c2) from t1;
--error 1690
select length(c2-c1) from t1;
drop 	table	t1;


--echo		ceil
create table t1(c1 bit(8),c2 bit(8));
insert into t1 values(b'11111111',16);
select ceil(c1) from t1;
select ceil(c2)	from t1;
select ceiling(c1) from t1;
select ceiling(c2) from t1;
drop	table   t1;


--echo		floor
create table t1(c1 bit(8),c2 bit(8));
insert into t1 values(b'11111111',64);
select floor(c1) from t1;
select floor(c2) from t1;
drop	table	t1;


--echo		round
create table t1(c1 bit(8),c2 bit(8));
insert into t1 values(b'11111111',64);
select round(c1) from t1;
select round(c2) from t1;
drop	table	t1;


--echo		abs
create table t1(c1 bit(8),c2 bit(8));
insert into t1 values(b'11111111',64);
select abs(c1) from t1;
select abs(c2) from t1;
select abs(-c1)	from t1;
select abs(-c2)	from t1;
drop	table	t1;                                
               

--echo		bin
create table t1(c1 bit(8),c2 bit(8));
insert into t1 values(b'11111111',64);     
select bin(c1) from t1;
select bin(c2) from t1;
drop	table   t1;


--echo		char         
create table t1(c1 bit(8),c2 bit(8));
insert into t1 values(b'1111',b'1111');
update t1 set c2 = CHAR(123) where c1 = b'1111';
select bin(c1),bin(c2) from t1;
drop	table	t1;


--echo		greatest
create table t1 (c1 bit(8),c2 bit(8),c3 bit(8));
insert into t1 values(b'1111',16,b'1110');
# BUG,
select greatest(c1,c2) from t1;
select greatest(c1,c3) from t1;
select greatest(c3,c2) from t1;
drop table t1;


--echo		least
create table t1 (c1 bit(8),c2 bit(8),c3 bit(8));
insert into t1 values(b'1111',16,b'1110');
# BUG,
select least(c1,c2) from t1;
select least(c1,c3) from t1;
select least(c3,c2) from t1;
drop table t1;



--echo		cast
select cast(b'1100100' as binary);
select cast(b'1100100' as char);
select cast(b'1100100' as date);
select cast(b'1100100' as datetime);
select cast(b'1100100' as time);
select cast(b'1100100' as decimal);
select cast(b'1100100' as signed);
select cast(b'1100100' as unsigned);


--echo		Aggregation function
create table t1(c1 bit(16));
insert into t1 values(b'1110'),(20),(b'1010101'),(60),(b'10');
select sum(c1) from t1;
select avg(c1) from t1;
select min(hex(c1)) from t1;
select min(hex(c1)) from t1;
select count(c1) from t1;
drop table t1;




##bit8 procedure and  function
--echo		 no parameter
drop procedure if exists pro1;
create  table  t1(c1 bit(8));
delimiter //;
create procedure pro1()
begin
        declare  i  bit(8);
        set    i = b'11111111';
        insert into t1 values(i);
        select bin(c1) from t1;
end//
delimiter ;//
call pro1();
select bin(c1) from t1;



drop table if exists t1;
drop procedure if exists pro1;
create  table  t1(c1 bit(8));
delimiter //;
create procedure pro1()
begin
        declare  i   int;
        set    i  =  1;
        while  i  <b'1111'
        do
             insert into t1 values(b'101010');
             set i=i+1; 
        end  while;
        select bin(c1) from t1;
end//
delimiter ;//
call pro1();
select bin(c1) from t1;


--echo		A parameter
drop table if exists t1;
drop procedure if exists pro1;
create table t1(c1 bit(64));
delimiter //;
create procedure pro1(a bit(64))
begin
      declare i int;
      set i =1;
      while i<a     
      do
           insert into t1 values(b'100010');
           set i=i+1;
      end while;
end//
delimiter ;//     
call pro1(b'110');
select  bin(c1) from t1;


--echo		#function
##no parameter
drop table if exists t1;
drop function if exists func1;
create  table  t1(c1 bit(8));
delimiter //;
create function  func1() returns int
begin
        declare  i  bit(8);
        set    i = b'11111111';
        insert into t1 values(i);
        return  1;
end//
delimiter ;//
select func1();
select hex(c1) from t1;




drop table if exists t1;
drop function if exists func1;
create  table  t1(c1 bit(8));
delimiter //;
create function func1() returns int
begin
        declare  i   int;
        set    i  =  1;
        while  i  <b'1111'
        do
             insert into t1 values(b'101010');
             set i=i+1; 
        end  while;
        return 1;
end//
delimiter ;//
select func1();
select hex(c1) from t1;



##A parameter
drop table if exists t1;
drop function if exists func1;
create table t1(c1 bit(64));
delimiter //;
create function func1(a bit(64)) returns int
begin
      declare i int;
      set i =1;
      while i<a     
      do
           insert into t1 values(b'100010');
           set i=i+1;
      end while;
      return 1;
end//
delimiter ;//     
select func1(10);
select  hex(c1) from t1;



drop database bit1;
