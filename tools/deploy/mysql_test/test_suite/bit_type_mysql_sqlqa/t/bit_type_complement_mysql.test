##Bit5 The operation
--disable_warnings
drop database if exists bit1;
--enable_warnings

create database bit1;
use bit1;

##Bit5-1 An operator
create table t1(a bit(10),b bit(10),c bit(10));
insert into t1 values(b'11111111',b'11111110',b'11111101');
select a & b from t1;
select b >> 2 from t1;
select a|b from t1;
select b << 1 from t1;
select a ^ b from t1;
select ~ c from t1;
drop tables t1;

##Bit5-2 The arithmetic operator
create table t2(a1 bit(64),b1 bit(64),c1 bit(64),d1 bit(64));
insert into t2 values(b'111111111111',b'1111111111111110',b'11111111111111011',b'1111111111111111111111111111100000000000000011111111111111');
select a1 + b1 from t2;
select c1 - a1 from t2;
--error 1690 
select d1 * d1 from t2;
select c1 / a1 from t2;
select b1 % a1 from t2;
--error  1690  
select a1 + b1 -c1 from t2;
select b1 - c1 / a1 from t2;
--error  1690
select a1 * b1 * d1 / c1 from t2;
select c1 % a1 / b1 *c1 from t2;
drop tables t2;

##Bit5-3 Comparison operator
create table t1(a1 bit(8),b1 bit(8));
insert into t1 values(b'11111111',b'11111110');
select a1 = b1 from t1;
select a1 > b1 from t1;
select a1 < b1 from t1;
select a1 >= b1 from t1;
select a1 <= b1 from t1;
select a1 != b1 from t1;
select a1 <> b1 from t1;
drop tables t1;


##Bit9 Bit interaction with other types 
##Interact with the int
create table t1(a1 bit(8),b1 int);
insert into t1 values(b'11111111',65535);
select a1 + b1 from t1;
--error  1690
select a1 - b1 from t1;
select a1 -(- b1) from t1;
select a1 / b1 from t1;
select a1 * b1 from t1;

select a1 = b1 from t1;
select a1 < b1 from t1;
select a1 > b1 from t1;
select a1 <= b1 from t1;
select a1 >= b1 from t1;
select a1 != b1 from t1;
select a1 <> b1 from t1;



drop tables t1;



##Interact with double/float
create table t1(a1 bit(8),b1 double,c1 float);
insert into t1 values(b'11111100',65535.25,255.80);
select a1 + b1 + c1 from t1;
select a1 - b1 - c1 from t1;
select a1 / b1 /c1 from t1;
select a1 * b1 * c1 from t1;
select a1 * b1 / c1 from t1;

select a1 = b1 from t1;
select a1 > b1 from t1;
select a1 < b1 from t1;
select a1 >= b1 from t1;
select a1 <= b1 from t1;
select a1 != b1 from t1;
select a1 <> b1 from t1;

select a1 = c1 from t1;
select a1 > c1 from t1;
select a1 < c1 from t1;
select a1 >= c1 from t1;
select a1 <= c1 from t1;
select a1 != c1 from t1;
select a1 <> c1 from t1;



drop tables t1;

##Interact with char/varchar
create table t1(a1 bit(10),b1 char(10),c1 varchar(20));
insert into t1 values(b'1111100','c','eeeeeeee');

select a1+b1 from t1;
select a1-b1 from t1;
select a1*b1 from t1;
select a1/b1 from t1;


select a1+c1 from t1;
select a1-c1 from t1;
select a1*c1 from t1;
select a1/c1 from t1;


select a1 = b1 from t1;
select a1 > b1 from t1;
select a1 < b1 from t1;
select a1 >= b1 from t1;
select a1 <= b1 from t1;
select a1 != b1 from t1;
select a1 <> b1 from t1;

select a1 = c1 from t1;
select a1 > c1 from t1;
select a1 < c1 from t1;
select a1 >= c1 from t1;
select a1 <= c1 from t1;
select a1 != c1 from t1;
select a1 <> c1 from t1;



drop tables t1;

##Interact with  date/time/year/datetime/timestamp
create table t1(a1 bit(8),c1 date,c2 time,c3 year,c4 datetime,c5 timestamp);
insert into t1 values(b'1111100','2024-01-01','16:28:59','2016','2025-06-04 16:33:59','19710604163459');
select a1 + c1 from t1;
--error 1690
select a1 - c1 from t1;
select a1 * c1 from t1;
select a1 / c1 from t1;

select a1 + c2  from t1;
##mysql error 1690
##select a1 - c2  from t1;
select a1 * c2  from t1;
select a1 / c2  from t1;

select a1 + c3  from t1;
--error 1690
select a1 - c3  from t1;
select a1 * c3  from t1;
select a1 / c3  from t1;

select a1 +c4  from t1;
#mysql error 1690
##select a1 -c4  from t1;
select a1 *c4  from t1;
select a1 /c4  from t1;

select a1+ c5  from t1;
#mysql error 1690
##select a1- c5  from t1;
select a1* c5  from t1;
select a1/ c5  from t1;

select a1 = c1 from t1;
select a1 > c1 from t1;
select a1 < c1 from t1;
select a1 >= c1 from t1;
select a1 <= c1 from t1;
select a1 != c1 from t1;
select a1 <> c1 from t1;

select a1 = c2 from t1;
select a1 > c2 from t1;
select a1 < c2 from t1;
select a1 >= c2 from t1;
select a1 <= c2 from t1;
select a1 != c2 from t1;
select a1 <> c2 from t1;

select a1 = c3 from t1;
select a1 > c3 from t1;
select a1 < c3 from t1;
select a1 >= c3 from t1;
select a1 <= c3 from t1;
select a1 != c3 from t1;
select a1 <> c3 from t1;

select a1 = c4 from t1;
select a1 > c4 from t1;
select a1 < c4 from t1;
select a1 >= c4 from t1;
select a1 <= c4 from t1;
select a1 != c4 from t1;
select a1 <> c4 from t1;


select a1 = c5 from t1;
select a1 > c5 from t1;
select a1 < c5 from t1;
select a1 >= c5 from t1;
select a1 <= c5 from t1;
select a1 != c5 from t1;
select a1 <> c5 from t1;

create table t2(a1 set('a','b','c'),id bit(8));
insert into t2 values('a',b'11110000');
select a1 + id  from t2;
select a1 - id  from t2;
select a1 * id  from t2;
select a1 / id  from t2;

select a1 = id from t2;
select a1 > id from t2;
select a1 < id from t2;
select a1 >= id from t2;
select a1 <= id from t2;
select a1 != id from t2;
select a1 <> id from t2;

drop tables t1;

##Interaction between types through functions
--echo	#NULL
create table t1(c1 bit(64));
insert into t1 values(b'11111100011');
select least(c1, NULL), greatest(c1, NULL) from t1;
drop table t1;


--echo 	#int
create table t1(c1 bit(32), c2 int, c3 int unsigned);
insert into t1 value(b'1111111111111110', 255, 65535);
select least(c1, c2), greatest(c1, c3), least(c2, c1), greatest(c3, c1) from t1;
drop table t1;


--echo  #float/double
create table t1(c1 bit(32), c2 float, c3 double);
insert into t1 values(b'1111111111111110', 254.999, 255.001);
select least(c1, c2), greatest(c1, c3), least(c2, c1), greatest(c3, c1) from t1;
drop table t1;


--echo	#decimal
create table t1(c1 bit(64), c2 decimal(30, 5), c3 decimal(30, 5));
insert into t1 values(b'1000000', 65534.99999, 65535.00001);
select least(c1, c2), greatest(c1, c2), least(c2, c1), greatest(c3, c1) from t1;
drop table t1;


--echo	#char / varchar
create table t1(c1 bit(36), c2 varchar(20), c3 char(20));
insert into t1 values(b'1111111111111110', "65535", "255");
select least(c1, c2), greatest(c1, c2), least(c2, c1), greatest(c3, c1) from t1;
drop table t1;


--echo	#time
create table t1(c1 bit(64), c2 time, c3 time);
insert into t1 values(65535, "65535", "6:55:35");
select least(c1, c2), greatest(c1, c2), least(c2, c1), greatest(c3, c1) from t1;
drop table t1;


--echo	#date
create table t1(c1 bit(64), c2 date, c3 date);
--error 1292
insert into t1 values(20480630, "20480629", "2048-06-31");
select least(c1, c2), greatest(c1, c2), least(c2, c1), greatest(c3, c1) from t1;
drop table t1;


--echo	#year
create table t1(c1 bit(64), c2 year, c3 year);
insert into t1 values(4096, "2048", "2025");
select least(c1, c2), greatest(c1, c2), least(c2, c1), greatest(c3, c1) from t1;
drop table t1;


--echo	#datetime
create table t1(c1 bit(64), c2 datetime, c3 datetime);
--error 1292
insert into t1 values(20250630, "20250629", "2025-06-31 11:00:00");
select least(c1, c2), greatest(c1, c2), least(c2, c1), greatest(c3, c1) from t1;
drop table t1;


--echo	#timestamp
create table t1(c1 bit(64), c2 timestamp, c3 timestamp);
--error 1292
insert into t1 values(20250630, "20250629", "2025-06-31 11:00:00");
select least(c1, c2), greatest(c1, c2), least(c2, c1), greatest(c3, c1) from t1;
drop table t1;


--echo	#bit
create table t1(c1 bit(36), c2 bit(48), c3 bit(64));
insert into t1 values(256, 255, 257);
select hex(least(c1, c2)), hex(greatest(c1, c3)), hex(least(c2, c1)), hex(greatest(c3, c1)) from t1;
drop table t1;


##type is bit,insert other type

--echo	#int ----> bit
create 	table t1 (c1 bit(64));
insert 	into  t1 values(2),(128);
insert  into  t1 values(-2),(-4096);
select  hex(c1)  from t1;
drop  table  t1,t2;

--echo	#float/double ---->bit
create  table t1(c1 bit(16), c2 bit(16));
create  table t2(c1 float, c2 double);
insert  into  t2  values(1,2048),(2.2, 2222.2222),(2248.99, 2248.99999);
insert  into  t2  values(-1,2048),(-2.2, -2222.2222),(-2248.99, -2248.99999);
set @@sql_mode = "";
insert  into  t1  select  c1, c2  from t2;
set @@sql_mode = "STRICT_ALL_TABLES";
--error 1406
insert  into  t1  select  c1, c2   from t2;
select  hex(c1), bin(c2) from t1;
create  table t3(c1 float, c2 double);
set @@sql_mode = "";
insert  into  t3  values(4444.4444,4444.4444), (-4444.4444,4444.4444);
insert  into  t1  select  c1, c2  from  t3;
select  hex(c1), bin(c2) from t1;
set @@sql_mode = "STRICT_ALL_TABLES";
--error 1406
insert  into  t1  select  c1, c2  from  t3;
drop 	table t1,t2,t3;


--echo	#decimal ---->bit
create  table  t1(c1 bit(64));
create  table  t2(c1 decimal(16,4));
insert  into   t2  values(222222222.2222),(2222.2222);
insert  into   t2  values(-222222222.2222),(-2222.2222);
set @@sql_mode = "";
insert  into   t1  select  c1  from  t2;
set @@sql_mode = "STRICT_ALL_TABLES";
--error 1264
insert  into   t1  select  c1  from  t2;
select 	hex(c1)  from   t1;
create 	table  t3(c1 decimal(16,4));
insert  into   t3  values(2222.2222), (-2222.2222);
set @@sql_mode = "";
insert  into   t1  select  c1  from  t3;
set @@sql_mode = "STRICT_ALL_TABLES";
--error 1264
insert  into   t1  select  c1  from  t3;
select  hex(c1)	 from   t1;
drop tables t1,t2,t3;


--echo	#datetime ---->bit
create  table  t1(c1 bit(64));
set @@sql_mode = "";
insert  into   t1   values(cast(20480630 as date)), (cast(19700000 as date)), (cast(19991231 as date));
select  hex(c1)  from  t1;
set @@sql_mode = "STRICT_ALL_TABLES";
--error 1406
insert  into   t1   values(cast(20480630 as date)), (cast(19700000 as date)), (cast(19991231 as date));
drop    table  t1;


--echo 	#date ---->bit
create  table  t1(c1 bit(64));
set @@sql_mode = "";
insert  into t1 values(20480630),("20480629"),("2025-06-31");
select  hex(c1)  from  t1;
set @@sql_mode = "STRICT_ALL_TABLES";
--error 1406
insert  into   t1 values(20480630),("20480629"),("2025-06-31");
drop    table  t1;


