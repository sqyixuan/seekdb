--echo	#char/ varchar ---->bit
create  table  t1(c1 bit(64));
create  table  t2(c1 char(20));
create  table  t3(c1 varchar(20));
insert  into   t2  values('654321'),('123456');
insert  into   t3  values('654321'),('123456');
insert  into   t1   select * from t2;
insert  into   t1   select * from t3;
select  hex(c1)    from  t1;
drop    tables t1,t2,t3;

--echo	#cast_mode test
create  table  t1(c1 decimal(38, 0));
create  table  t2(c1 bigint(5));
insert  into   t1  values('1000000000000000000000000000000000000');
set @@sql_mode = "STRICT_ALL_TABLES";
--error 1292
insert into t2 select c1 | 1 from t1;
--error 1292
insert into t2 select c1 & 1 from t1;
--error 1292
insert into t2 select c1 ^ 1 from t1;
--error 1292
insert into t2 select c1 << 1 from t1;
--error 1292
insert into t2 select c1 >> 1 from t1;
set @@sql_mode = "";
insert into t2 select c1 | 1 from t1;
insert into t2 select c1 & 1 from t1;
insert into t2 select c1 ^ 1 from t1;
insert into t2 select c1 << 1 from t1;
insert into t2 select c1 >> 1 from t1;

select * from t2;

drop    tables t1,t2;

--echo	#cast_string_int test 
--echo  #should not have any warning
create  table  t1(c1 varchar(20));
insert  into   t1  values('9.5');
insert  into   t1  values('-9.5');
insert  into   t1  values('19.5');

select c1, null >> c1 from t1;
select c1, null << c1 from t1;
select c1, null & c1 from t1;
select c1, null | c1 from t1;

--echo	#should present warning

select c1, c1 >> null from t1;
select c1, c1 << null from t1;
select c1, c1 & null from t1;
select c1, c1 | null from t1;

set @@sql_mode = "STRICT_ALL_TABLES,NO_ZERO_IN_DATE,NO_AUTO_CREATE_USER";
drop    tables t1;

drop database bit1;
