# 特殊嵌套查询
--error 0,1051
drop table tt3;
create table tt3(a bigint[]);
insert into tt3 values((SELECT CONCAT('[', GROUP_CONCAT(number ORDER BY number SEPARATOR ', '), ']') AS nums
FROM (
     SELECT FLOOR(1+RAND() * 10) AS number
    FROM TABLE(GENERATOR(10000))
) AS temp));
select array_length(a) from tt3;

# 函数嵌套
select [array_length([3,4])];
select array_length(array_agg('test'));
select array_length([[array_agg('test')]]);
select array_length(Array(1,2));
select array_length(array_append(Array(1,2),3));
select array_append(Array(1,2),array_length([0]));

select array_length( array_distinct(Array(1,2,2)));

select array_distinct(array(array_length([1,2,3,null,6,5])));
select array_length(array_map((x,y)->(x+y), array_map(x2->(x2+1),[1,2,3]),array_map(x1->(x1+2),[1,2,3])));
select array_map((x)->(array_length(x)),[[3]]);

select array_length(array_agg(1));
select array_agg(array_length([1,null]));
select array_length([1,4]+[1,3]);
select array_length([1,4]-[1,3]);
select [[[[[array_length([1,4]-[1,3])]]]]];


select array_length([1]) = ANY([1,2,3]);
select array_length(c1) = ANY(c1) from tt1;
--error 5083
select array_length(JSON_ARRAY(1,2,3));
select id, array_length(c3) from tt1 where array_length(array_compact(c4)) > 3 and id > 1 order by id desc;

select array_length(c1),array_length(c3),array_length(c4),array_length(c5),array_length(c6),array_length(c7),array_length(c2) from tt1 group by array_length(array_compact(c1)) desc;

select id, array_length(c1),array_length(c3),array_length(c4),array_length(c5),array_length(c6),array_length(c7),array_length(c2) from tt1 group by array_length(array_compact(c1)) with rollup;
select id, array_length(c1),array_length(c3),array_length(c4),array_length(c5),array_length(c6),array_length(c7),array_length(c2) from tt1 group by array_length(array_compact(c1)) with rollup having count(*)>0 order by id;

# with as
with test_1 as (
   select id, array_length(c1),array_length(c3),array_length(c4),array_length(c5),array_length(c6),array_length(c7),array_length(c2) from tt1 group by array_length(array_compact(c1)) with rollup having count(*)>0
)
select * from test_1;

WITH Alice_Students AS (
select  array_length(t1.c1) c from tt1 t1 inner join tt1 t2 on array_length(t1.c2) =array_length(t2.c2)
)
SELECT * FROM Alice_Students;

# ddl case

drop table if exists tt3;
CREATE TABLE tt3 (id int primary key, d varchar(50), c2 int[],c3 array(float),c4 varchar(256)[][],v vector(2)) partition by hash(id);
insert into tt3 values(1,1,[1,2,3,5],[2.123,2.123,3.123,4.123],[['中文ing123',1,'1']],[1,23]);
insert into tt3 values(2,2,[2,3,4,5],[2.123,2.123,3.123,4.123],[[null,'a','sss']],[1,23]);
insert into tt3 values(3,3,[3,3,3,3],[3.123,2.123,2.123,2.123,4.123],[['null','a','sss'],null],[1,23]);
insert into tt3 values(4,4,[2,3,4,5],[4.123,2.123,3.123,4.123],[[2,3,4,5],null],[1,23]);
insert into tt3 values(5,null,null,null,null,null);
insert into tt3(id) values(7);
insert into tt3 values(8,8,'[]','[]',[[1,'test'],[2,3,NULL],NULL],'[1,2]');
insert into tt3 values(9,9,'[-12,7347]','[1,2,5,6]',[[1,'test'],[2,3,NULL],NULL],'[25,-50]');

drop view if exists vtt3;
create view vtt3 as select * from tt3;

delete from tt3 where array_length(array_compact(c2)) > 0 limit 2;
select array_length(tt3.c3) from tt3 for update;
select * from tt3 where array_length(array_compact(tt3.c3))>2 limit 2 for update;
UPDATE tt3 SET d = "test" WHERE  array_length(array_compact(tt3.c3))>0 limit 1;
select * from tt3;
DELETE FROM tt3 WHERE array_length(array_compact(tt3.c2))<2 LIMIT 2;
select * from tt3;
desc tt3;

# 事务
begin;
select * from tt3 where array_length(array_compact(tt3.c3))>2 limit 2 for update;
update tt3 set c4 = array_compact([[""],["[]"],["[]"],array_remove([""],""),["[]["]]) where id >3;
# truncate tt3;
alter table tt3 add a1 int after c3;

update tt3 set a1 = array_length(array_compact([[""],["[]"],["[]"],array_remove([""],""),["[]["]])) where id >3;

replace /*+ direct(true,100) enable_parallel_dml parallel(2) append*/ into tt3(id,a1) values(2,array_length(array_compact(c3)));
select /*+no_rewrite opt_param('PUSHDOWN_STORAGE_LEVEL', 0) opt_param('PUSHDOWN_STORAGE_LEVEL', 0) filter_pushdown_single_column.yaml */ array_length(array_compact(tt3.c2)) from tt3 left join tt1 on tt3.id = tt1.id;
select * from tt3; 
commit;

# case when

SELECT CASE array_length(t1.c2) WHEN array_length(t1.c2) THEN  array_length(t1.c2) WHEN  array_length(t1.c3)  THEN  array_length(t1.c3) END from tt3 t1;
SELECT CASE array_length(t1.c2) WHEN array_length(t1.c2) THEN  array_length(t1.c2) WHEN  array_length(t1.c3)  THEN  array_length(t1.c3) else array_length([1,2,3,4,5]) END from tt3 t1;
--error 5083
SELECT CASE 'test' WHEN 'test' THEN  array_length(array_length([1,2,3,4,59])) WHEN  'test1'  THEN  array_length(array_range(20)) else array_length(array_range(30)) END;
SELECT CASE array_length(array_range(t1.id)) WHEN array_length(array_range(t1.id)) THEN  array_length(array_range(t1.id)) WHEN  array_length(array_range(t1.id))  THEN  array_length(array_range(t1.id)) END from tt3 t1;

SELECT CASE array_length(array_range(t2.id)) WHEN array_length(array_range(t1.id)) THEN  array_length(array_range(t2.id))
 WHEN  array_length(array_range(t1.id))  THEN  array_length(array_range(t2.id)) END from tt3 t1 ,tt3 t2;

SELECT CASE array_length(array_range(t1.id)) WHEN array_length(array_range(t1.id)) THEN  array_length(array_range(t2.id))
 WHEN  array_length(array_range(t1.id))  THEN  array_length(array_range(t2.id)) END from tt3 t1 ,tt3 t2;

# group by/having
select * from tt3 group by array_length(c2) having id > 2 order by id desc; 
select array_compact(c2) ,c3, c4 from tt3 group by id having array_length(c3) > 2 order by array_length(c4) desc;
select * ,array_compact(c2), c4,c2 from tt3 order by array_length(c2) asc ;
select * ,array_compact(c3), c3,c2 from tt3 where id=1  order by array_length(c3) desc ;


