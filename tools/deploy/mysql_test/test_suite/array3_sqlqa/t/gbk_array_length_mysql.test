# where
drop table tt1;
create table tt1(id int,c1 array(int), c2 array(varchar(256)), c3 array(tinyint), c4 array(bigint), c5 array(float), c6 array(double), c7 array(smallint));
insert into tt1 values(1,[-2147483648,0, 2147483647],['test'],[127,0,-128],[-9223372036854775808,9223372036854775807,775,808,2,0],[3.402, 0, 1.175],
[1.7976931348623157E+308, 2.2250738585072014E-308],[-32768,0,32767]);

insert into tt1 values(2,[-2147483648,0, 2147483647,4],['test'],[127,0,-128,6,77],[-9223372036854775808,9223372036854775807,775,808,2,0,1],[3.402, 0, 1.175,4],
[-1.7976931348623157E+30,1.2,2.2250738585072014E-308],[-32768,0,32767,0]);
insert into tt1 values(3,null,null,null,null,null,null,null);

select *,array_length(c1) from tt1 where array_length(c1) =3;

select * from tt1 where array_length(c1) =3;
select * from tt1 where  array_length(c1)=array_length(c5);

select * from tt1 where array_length(c5)<4;

select * from tt1 where array_length(c5)<=>3;

select * from tt1 where array_length(c5)!= cardinality([1,2,34,5,6]);

select * from tt1 where array_length(c5) BETWEEN array_length(c1) AND array_length(c3);
select * from tt1 where array_length(c5) not BETWEEN array_length(c1) AND array_length(c3);

select * from tt1 where array_length(c1) not in (array_length(c1),cardinality([1,2,5,7])) ;

select * from tt1 where array_length(c5) like array_length(c1);

select * from tt1 where array_length(c1) not like array_length(c5);

select * from tt1 where array_length(c1) is true;
select * from tt1 where array_length(c2)  is not true;
select * from tt1 where array_length(c3)   is false;
select * from tt1 where array_length(c4)   is not false;

select * from tt1 where array_length(c5)  is not null;
select * from tt1 where array_length(c1 )  is  null;


# order by
drop table tt2;
create table tt2(id int,c1 array(int unsigned), c2 array(varchar(256)), c3 array(tinyint unsigned), c4 array(bigint unsigned), c5 array(float), c6 array(double), c7 array(smallint unsigned))
PARTITION BY range COLUMNS(id)(
PARTITION p0 values less than(19),
PARTITION p1 values less than(25),
PARTITION p2 values less than(30)
);
insert into tt2 values(1,[2147483648,0, 2147483647],['test'],[52,0,5],[ 852,9223372036854775807,775,808,2,0],[3.402, 0, 1.175],
[1.7976931348623157E+308, 2.2250738585072014E-308],[88,0,32767]);

insert into tt2 values(2,[87666,0, 2147483647,4],['test'],[5,0,7,6,50],[1,100000,9223372036854775807,775,808,2,0,1],[3.402, 0, 1.175,4],
[1.7976931348623157E+308,1.2,2.2250738585072014E-308],[68,0,32767,0,1]);
insert into tt2 values(3,null,null,null,null,null,null,null);

--error 0,1051
drop view vtt2;
create view vtt2 as select * from tt2;

SELECT *, array_length(c1) FROM tt2 ORDER BY array_length(c1);

select * ,array_length(c1), c1,c2 from tt2 where id=1  order by array_length(c1) desc ;
select * ,array_length(c1), c1,c2 from tt2  where id=1  order by array_length(c2) asc ;
select * ,array_length(c1)from vtt2 where id=1 order by array_length(c1);
select * ,array_length(c1), c1,c2 from vtt2 where id=1  order by array_length(c1) desc ;
select * ,array_length(c1),c1 ,c2 from vtt2  where id=1  order by array_length(c2) asc ;

