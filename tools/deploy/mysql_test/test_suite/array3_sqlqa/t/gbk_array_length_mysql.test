drop table test;
create table test(id int,a varchar(262144));
insert into test values(1,repeat('x',262));
select array_length([array(a),array(a)]) from test;
select array_length([array(a),[3]]) from test;
select array_length([array(a),['xxxxxxxx']]) from test;
select array_length([['[1]'],['[1]','test']]);
select array_length([['test','test1','test2'],['[1]','test']]);
select array_length([["aaaa","teset"],['aaaa','testet']]);

select array_length([['test],[test1'],['test1']]);

# array类型的null
--error 0,1051
drop table tt1;
create table tt1(id int,c1 array(array(int)), c2 array(array(varchar(256))), c3 array(array(tinyint)), c4 array(array(bigint)), c5 array(array(float)), c6 array(array(double)), c7 array(array(smallint)));

insert into tt1 values(1,[null,null,[-2147483648,-2147483647,0,77777],[null]],[[''],[''],['test','test'],['test',null],null,null],[[127,0,-128],[127,0,-128],null,null],[[-9223372036854775808,775,808,2,0],[-9223372036854775808,775,808,2,0],[null],null],[[3.402, 0, 1.175],null,null],
[[1.7976931348623157E+308, 2.2250738585072014E-308,2.2250738585072014E-308],null,null],[null,null,[-32768,0,32767,32767],[-32768,0,32767,32767]]);

insert into tt1 values(2,[null,null,[null],[null]],[[null,null],[''],['']],[null,null,[null],[null]],[null,null,[null],[null]],[null,null,[null],[null]],[null,null,[null],[null]],[null,null,[null],[null]]);

insert into tt1 values(3,null,null,null,null,null,null,null);

select * from tt1;
select array_length(tt1.c1) from tt1; 
select array_length(tt1.c2) from tt1; 
select array_length(tt1.c3) from tt1; 
select array_length(tt1.c4) from tt1; 
select array_length(tt1.c5) from tt1; 
select array_length(tt1.c6) from tt1; 
select array_length(tt1.c7) from tt1;
desc tt1; 

# 没有元素的array[]
--error 0,1051
drop table tt1;
create table tt1(id int,c1 array(array(int)), c2 array(array(varchar(256))), c3 array(array(tinyint)), c4 array(array(bigint)), c5 array(array(float)), c6 array(array(double)), c7 array(array(smallint)));

insert into tt1 values(1,[null,null,[-2147483648,-2147483647,0,77777],[null]],[['[]'],['[]'],['['],['],['],[''],[''],['test','test'],['test',null],null,null],[[127,0,-128],[127,0,-128],null,null],[[-9223372036854775808,775,808,2,0],[-9223372036854775808,775,808,2,0],[null],null],[[3.402, 0, 1.175],null,null],
[[1.7976931348623157E+308, 2.2250738585072014E-308,2.2250738585072014E-308],null,null],[null,null,[-32768,0,32767,32767],[-32768,0,32767,32767]]);

insert into tt1 values(2,[null,null,[null],[null]],[[null,null],[''],[''],['[]'],['[]'],['],['],['']],[null,null,[null],[null]],[null,null,[null],[null]],[null,null,[null],[null]],[null,null,[null],[null]],[null,null,[null],[null]]);

insert into tt1 values(3,null,null,null,null,null,null,null);

insert into tt1 values(4,null,array(array_remove([1],1)),array(array_remove([1],1)),array(array_remove([1],1)),null,null,null);

select array_length(tt1.c1) from tt1; 
select array_length(tt1.c2) from tt1; 
select array_length(tt1.c3) from tt1; 
select array_length(tt1.c4) from tt1; 
select array_length(tt1.c5) from tt1; 
select array_length(tt1.c6) from tt1; 
select array_length(tt1.c7) from tt1; 
desc tt1;

--error 0,1051
drop table test;
create table test as select array_length(tt1.c2) from tt1;
desc test;
drop table test;

# array_remove()继续空[]
--error 0,1051
drop table tt1; 
create table tt1(id int,c1 array(array(varchar(256))), c2 array(array(varchar(256))));
insert into tt1 values(1,[null,null,[null],[null]],[null,null,[''],[''],array_remove([1,''],1),array_remove([2,''],''),array_remove([''],'')]);
insert into tt1 values(2,[null,null,array_remove([1,''],''),array_remove([2,''],''),array_remove(['',']','['],'[')],[null,null,array_remove(['',null],'')]);

select * from tt1;
select array_length(tt1.c1) from tt1; 
select array_length(tt1.c2) from tt1; 


