# join
--error 0,1051
DROP TABLE tt1;
CREATE table tt1(id int , a int[]);
INSERT INTO tt1 values
(1, [1,2,3]),(2,[4,5,6]),(3,[null,1,2,3]);
--error 0,1051
DROP TABLE tt2;
CREATE table tt2(id int , a int[]);
INSERT INTO tt2 values
(1, [1,2,3]),(2,[4,5,6]);

select t1.* FROM tt1 t1 JOIN tt2 t2 on array_length(t1.a) = array_length(t2.a);

select t1.* FROM tt1 t1 LEFT JOIN tt2 t2 on array_length(t1.a) = array_length(t2.a);

select t1.* FROM tt1 t1 RIGHT JOIN tt2 t2 on array_length(t1.a) = array_length(t2.a);

select t1.* FROM tt1 t1 JOIN tt2 t2 on array_length(t1.a) = array_length(t2.a) UNION select t1.* FROM tt1 t1 JOIN tt2 t2 on array_length(t1.a) = array_length(t2.a);

select t1.* FROM tt1 t1, tt2 t2 WHERE array_length(t1.a) = array_length(t2.a);



