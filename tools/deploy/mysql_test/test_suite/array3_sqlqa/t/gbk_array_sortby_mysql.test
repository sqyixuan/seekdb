(select array_sortby((x)->(x*x),[1,3,3,4,2,2,3])),(select array_compact([3,2,1,2,1,1,null])),(select array_sortby((x)->(!x),[null,1,null]) )) ON DUPLICATE KEY UPDATE  id=array_length([1,2]);

