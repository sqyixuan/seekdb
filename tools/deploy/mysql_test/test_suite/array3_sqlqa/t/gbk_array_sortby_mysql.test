#owner: xuqijia.xqj
#owner group: shenzhen
#author: xiekejian.xkj
# description: array array_sortby(array) 使用和测试场景
# tags: array

purge recyclebin;
--disable_warnings
drop database  IF EXISTS  testkj;
--enable_warnings
create DATABASE testkj character set gbk;
USE testkj;
SET timestamp = 1600000000;
SET ob_trx_timeout = 10000000000;
SET ob_query_timeout = 100000000000;
SET SESSION group_concat_max_len = 100000000;

# 一些基础的功能性case
--sorted_result
--result_format 4

select array_sortby(x ->(x is null),null);
select array_sortby(x -> (x),[1]);
select array_sortby((x,y,z) -> (x is null and y is not null or z is not null), [[1]], [1],['abc']);
select array_sortby((x,y) -> (x + y),[1], [2]);
select array_sortby((a,A) -> (a + A),[1], [2]);
select array_sortby((x,y) -> (x),[1], [2]);
select array_sortby((x,y) -> (y),[1], [2]);
select array_sortby((x,y) -> (1),[1], [2]);
select array_sortby((x,y)->((x is null) and (y is null)), [1232], [[['abc']]]);
select array_sortby((x,y)->(x+y), array_sortby(x2->(x2+1),[1,2,3]),array_sortby(x1->(x1+2),[1,2,3]));
select array_sortby(x ->(x*2 + x*2), [1,3]);
select array_sortby((x,y) ->(x*2+y+x*2), [1,3],[4,5]);
select array_sortby((x,y) -> (if(x>1.5,log(x),x+y)), [1,2,3], [11,12,13]);
select array_sortby(x ->(upper(x)), ['efg','abc']);
select array_sortby(x -> (round(x,1)), [1.22, 3.44, 5.33]);
select array_sortby(x ->(length(x)), ['abceeee', 'efgaa']);
select array_sortby((x, y)->(floor((y - x) / x)), [4, 5, 6], [3,8,5]);

SELECT array_sortby(x ->(x LIKE '%World%'), ['Hello', 'abc World','World','null']);
select array_sortby(x1->(x1+1.66),[1,2,3]);
--error 1690
select array_sortby((x, y) -> (x + 1 + y + 1), [(9223372036854775798), (null)], [(9223372036854775798), (9223372036854775798)]);
select array_sortby(x1->(x1+9223372036854775800),[1,2,3,-2,-4,0]);
select array_sortby(x1->(x1*null),[2,1,null,3,1]);


# 空值
select array_sortby((x) ->(x + 1),[1,3,2,2,null]);
select array_sortby((x) ->(x%2),[3,2,1,4,3,5,6]);
select array_sortby(x ->(x*2), [1,'c',NULL,'a',NULL]);
SELECT array_sortby(x ->(x LIKE '%World%'), ['Hello', 'abc World','World','null',null]);
select array_sortby((x,y)->(x),[null,4],[3,2]);
select array_sortby((x,y)->(x*2),[null,6,2,3],[2,4,2,4]);
select array_sortby((x,y)->(length(y)),[null,'null',3,5,2],[null,'null',2,3,3]);
select array_sortby(x->length(x),[null,'null,null','null']);
select array_sortby((x,y) -> (x + y),[1,null], [null,2]);
select array_sortby((a,A) -> (a + A),[1,null], [null,2]);
select array_sortby((x,y)->(y),[null,4,3,2,1],[null,1,2,3,4]);
select array_sortby((x)->(x+x),[null,2,1,null]);
select array_sortby((x,y)->(y+y),[null,'null',22,"a"],[4,1,3,null]);
--error 5083
select array_sortby((x)->(array_compact(x)),[[null,"aaa华侨城",123,'','null'],[4,2,3,1,2,3],["111",11,1,NULL,'NULL']]);
select array_sortby((x)->array_length(x),[[1,'test','test'],[2,2,3,3,null,NULL],null]);
select array_sortby((x)->null,[null,[null]]);


# value overflow
select array_sortby(x1->(x1+1000000000000000000000),[1,2,3]);
select array_sortby((a)-> (0),['中文'])  from dual ;
select array_sortby((a)-> (-1.1111),['中文'])  from dual ;
select array_sortby((a)-> (1.123456),['中文'])  from dual ;
select array_sortby((a)-> ('zhongwen'),['zhongwen'])  from dual ;
--error 1054
select array_sortby((中文ing) -> (中文 is not null),[2])  from dual ;
select array_sortby((中文ing) -> (中文ing is not null),[2,'null',null])  from dual ;
select array_sortby((中文ing) -> ('中文' is not null),[2,null,'null'])  from dual ;

--error 5058
select array_sortby((x,x) -> (x), [1,null],[2,null]);
--error 5083
select array_sortby((x) -> (array(x)), [1]);
--error 5083
select array_sortby((x) -> (array(x)), [3,5,1,2,3]);

select array_sortby((x,y) ->(y),[['a'],['b'],['c']],[1,3,2]);
select array_sortby(x2->(x2),[1]);
--error 5083
select array_sortby(x2->(x2),[['2'],['1']]);
select array_sortby((x,y)->(x+y),[1,2,NULL], [NULL,3,4]);
--error 5083
select array_sortby((x)->(array_sortby((x)->(x),[1])),[1]);
--error 5083
select array_sortby((z)->(z+array_sortby((x)->(x),[1])),[2]);


select array_sortby((x,y)->(x/y),[3,1,null],[1,2,null]);
select array_sortby((x,y)->(x%y),[null],[null]);

select array_sortby((x,y)->(x/y),[null,1,null],[null,5,null]);

select array_sortby((x,y)->(x*y),[null,1,2,3,4],[4,3,2,1,null]);
select array_sortby((x,y)->(x+y),[null,1,2,3,4],[4,3,2,1,null]);
select array_sortby((x,y)->(x-2*y),[null,1,2,3,4],[4,3,2,1,null]);
select array_sortby((x,y)->(x*2-y/x),[null,1,2,3,4],[4,3,2,1,null]);

# 嵌套数组的array格式
select array_sortby((x1,x2)->(array_length(x1)>2),[[null,3,2,1,1,2]],[[5,4,6,4,3,null]]);
select array_sortby((x1,x2)->(array_compact(x1)!=[1,2,3]),[[1,1,1,12,2,2,3,3,3,4,5,null]],[[1,2,3]]);
select array_sortby(x1->(array_sort(x1)!=[1,2,3]),[[1,2,3,null],[3,2,1],[3,1,2]]);
select array_sortby((x,y)->(x*y),array_compact([1,1,1,2,3,null]),array_compact([2,2,2,1,3,null]));


# join
--error 0,1051
drop table tt3;
create table tt3(id int,a int[]);
insert into tt3 values(1,[1,2,3,3]);
insert into tt3 values(2,[5,6,7,7,null]);
insert into tt3 values(3,[5,6,7]);
--error 0,1051
drop table tt4;
create table tt4(id int,a int[]);
insert into tt4 values(1,[1,2,3]);
insert into tt4 values(2,[5,6,7,7,null]);
insert into tt4 values(3,[9]);

select t3.* from tt3 t3 inner join tt4 t4 on array_sortby(x1->(x1*x1),t3.a)=array_sortby(x1->(x1*x1),t4.a);
select t3.* from tt3 t3 right join tt4 t4 on array_sortby(x1->(x1 or 1),t3.a)=array_sortby(x1 ->(x1 or 1),t4.a);
select t3.* from tt3 t3 full join tt4 t4 on array_sortby(x1->(x1*2),t3.a)=array_sortby(x1->(x1*2),t4.a);
select array_sortby(x->(x),tt3.a) from tt3;

# union
select * from tt3 union select * from tt4;
(select array_sortby((x,y)->(!x/y),t3.a,t3.a) from tt3 t3) union distinct(select array_sortby((x,y)->(!x/y),t4.a,t4.a) from tt4 t4);

(SELECT array_sortby((x, y) -> (x+y), t3.a, t3.a) FROM tt3 t3 WHERE t3.a IS NOT NULL) UNION DISTINCT (SELECT array_sortby((x, y) -> (y+x), t4.a, t4.a)FROM tt4 t4 WHERE t4.a is not null);

(SELECT array_sortby((x, y) -> (y - x), t3.a, t3.a)FROM tt3 t3) UNION (SELECT array_sortby((x, y) -> (y - x), t4.a, t4.a)FROM tt4 t4);

SELECT * FROM (
    (SELECT array_sortby((x, y) -> (y - x), t3.a, t3.a) FROM tt3 t3)
    UNION
    (SELECT array_sortby((x, y) -> (y - x), t4.a, t4.a) FROM tt4 t4)
) AS combined_results;

(SELECT t3.a FROM tt3 t3 ORDER BY t3.a IS NULL DESC, t3.a DESC) UNION (SELECT t4.a FROM tt4 t4 ORDER BY t4.a IS NULL DESC, t4.a DESC);

