insert into tt3 values((select array_length([3,4,3])),
(select array_compact(c3) from tt1 limit 1),(select array_sortby((x)->(x+x),c1) from tt1 limit 1),(select array_sortby(x->!x,[1,null]) from vtt1 limit 1)) ON DUPLICATE KEY UPDATE  id=array_length([1]);

