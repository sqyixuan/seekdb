--error 0,1051
drop view vtt2;
create view vtt2 as select * from tt2;

select id, c3 , array_compact(c3) from tt1 order by id;
select id, c4, array_compact(c4) from vtt2 order by id;
select id, c8 ,array_compact(c8) from tt1 order by id desc;

select id, c3, array_compact([tt1.c8,[1,2,3]]) from tt1 order by id;


