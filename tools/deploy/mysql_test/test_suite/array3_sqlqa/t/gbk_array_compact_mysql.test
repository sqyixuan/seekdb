# 事务
begin;
select * from tt3 where array_length(array_compact(tt3.c3))>2 limit 2 for update;
update tt3 set c4 = array_compact([[""],["[]"],["[]"],array_remove([""],""),["[]["]]) where id >3;
# truncate tt3;
update tt3 set c4 = array_compact([[""],["[]"],["[]"],array_remove([""],""),["[]["]]) where id >3;

commit;

