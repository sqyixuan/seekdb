purge recyclebin;
--disable_warnings
drop database  IF EXISTS  testkj;
--enable_warnings
CREATE DATABASE testkj character set gbk;

USE testkj;
SET timestamp = 1600000000;
SET ob_trx_timeout = 10000000000;
SET ob_query_timeout = 100000000000;
SET SESSION group_concat_max_len = 100000000;

--sorted_result
--result_format 4
--error 0,1051
drop table tt1;
create table tt1(id int,c1 array(int), c2 array(varchar(256)), c3 array(tinyint), c4 array(bigint), c5 array(float), c6 array(double), c7 array(smallint), c8 vector(3)) 
PARTITION BY range COLUMNS(id)(
PARTITION p0 values less than(1),
PARTITION p1 values less than(2),
PARTITION p2 values less than(MAXVALUE)
);
create index idx_tt1 on tt1(id);
create UNIQUE index idx_tt1_id on tt1(id);
CREATE INDEX tt1_func_idx1 on tt1((array_length(array_compact(c1))));
CREATE INDEX tt1_func_idx2 on tt1((array_length(c2)));
CREATE INDEX tt1_func_idx3 on tt1((array_min(c5)));
CREATE INDEX idx_tt1_cg on tt1(id) WITH COLUMN GROUP(each column);
