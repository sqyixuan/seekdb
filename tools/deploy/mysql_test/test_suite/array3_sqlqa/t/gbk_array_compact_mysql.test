# array参数类型
# 常规的空值null
select array_compact([null]);
select array_compact([null,null]);
select array_compact([[1,2,3,3,4],null,null]);
select array_compact([[1,2,3,4,4,null,null],null,null]);
select array_compact([["null","123"],["null","123","check"],["null","123","check"]]);
select array_compact([[true,false,true,null],[true,null,false,true],["true",null,"false","true"]]);
select array_compact([[true,false,true,null],[true,null,false,true]]);
select array_compact([[true,false,true,null],[true,false,true,null],["true",null,"false","true"]]);
--error 1064
select array_compact([[],[]]);
--error 1064
select array_compact([]);
select array_compact([[null],[NULL]]);
select array_compact(([[""],null]));
select array_compact([[null],[null],[""]]);

# 字符串以及含空情况
select array_compact([[-1,-3,"check"],[-1,-3,"check"],[true,false,-1,-3,"check"]]);
select array_compact([["ttt","123123","ses"],["ttt","123123","ses"],["a","b","c"]]);
select array_compact([["ttt","123123","ses"],["ttt","123123","ses"],["ttt","123123","ses"]]);
select array_compact([[""],[""]]);
select array_compact(["","",""]);

select array_compact(["",'[]','[]',"array_remove[]"]);
select array_compact([['',''],['','']]);
select array_compact([[['','']],[['','']]]);
select array_compact([[null,''],[null,'']]);


select array_compact(['test1',null,null,'test1']);
select array_compact([['test1',null],['test1',null],[null],[null],['null'],['null']]);
select array_compact([[null,'test'],[null]]);
select array_compact([[null],['test']]);

--error 0,1051
drop table test;
create table test(id int,a varchar(262144));
insert into test values(1,repeat('x',262));
select array_compact([array(a),array(a)]) from test;
select array_compact([array(a),[3]]) from test;
select array_compact([array(a),['xxxxxxxx']]) from test;
select array_compact([['[1]'],['[1]','test']]);
select array_compact([['test','test1','test2'],['[1]','test']]);
select array_compact([["aaaa","teset"],['aaaa','testet']]);

select array_compact([['test],[test1'],['test1']]);

