(select array_compact(c3) from tt1 limit 1),(select array_compact(c2) from tt3 limit 1),(select array_compact(c7) from vtt1 limit 1));

insert into tt3 values((select array_length([1,3,3])),(select array_compact(c3) from tt1 limit 1),
(select array_compact([2,4]) from tt2 limit 1),(select array_compact(c7) from vtt1 limit 1));
