--error 0,1051
drop table test;
create table test(a bigint[],a1 bigint[]);
insert into test values((SELECT CONCAT('[', GROUP_CONCAT(number ORDER BY number SEPARATOR ', '), ']') AS nums
FROM (
     SELECT FLOOR(1+RAND() * 10) AS number
    FROM TABLE(GENERATOR(10000))
) AS temp),(SELECT CONCAT('[', GROUP_CONCAT(number ORDER BY number SEPARATOR ', '), ']') AS nums
FROM (
     SELECT FLOOR(1+RAND() * 100) AS number
    FROM TABLE(GENERATOR(10000))
) AS temp));
select array_compact(a1) from test;

# dml语句细化

### select/group by/order by/limit

--error 0,1051
drop table tt1;
create table tt1(id int,c1 array(int), c2 array(varchar(256)), c3 array(tinyint), c4 array(bigint), c5 array(float), c6 array(double), c7 array(smallint), c8 vector(3))
PARTITION BY range COLUMNS(id)(
PARTITION p0 values less than(1),
PARTITION p1 values less than(2),
PARTITION p2 values less than(MAXVALUE)
);
create index idx_tt1 on tt1(id);
create UNIQUE index idx_tt1_id on tt1(id);
CREATE INDEX tt1_func_idx2 on tt1((array_max(c2)));
CREATE INDEX tt1_func_idx3 on tt1((array_min(c5)));
CREATE INDEX idx_tt1_cg on tt1(id) WITH COLUMN GROUP(each column);
insert into tt1 values(1,[-2147483648.5,-2147483648.5 ,0, 2147483647.4999998],['test','test',null,null],[127.499999999999992,127.499999999999992,0,-128.5,-128.5],[-9223372036854775808,9223372036854775807,0],[3.402, 0,0,0,0.175], [1.7976931348623157E+308,0, 2.2250738585072014E-308,2.2250738585072014E-308,2.2250738585072014E-308],[-32768.5,0,32767.499999999998],[0.1,2.2,2.2]);
insert into tt1 values(2,[-2147483648.5 ,0, null, 2147483647.4999998],['test','a',null,null,'null','null'],[127.499999999999992,0, null, null, -128.5],[-9223372036854775808, null,9223372036854775807,0],[null,null, 0,3.402,1.175], [-1.7976931348623157E+308, null, 0,2.2250738585072014E-308],[-32768.5,-32768.5,0,null,null,32767.499999999998],[1,2,3]);
insert into tt1 values(3,null,null,null,null,null,null,null,null);
insert into tt1 values(4,'[]','[]','[]','[]','[]','[]','[]',[1,2,3]);
insert into tt1 values(5,array_remove([1],1),array_remove([1],1),array_remove([1],1),array_remove([1],1),array_remove([1],1),array_remove([1],1),array_remove([1],1),[1,2,3]);

#show create table tt1;

--error 0,1051
drop view vtt1;
create view vtt1 as select * from tt1;

--sorted_result
select *,array_compact(c1) as a from tt1;
--sorted_result
select array_compact(c1),array_compact(c3),array_compact(c4),array_compact(c5),array_compact(c6),array_compact(c7),array_compact(c8) from tt1;
--sorted_result
select array_compact(c1),array_compact(c3),array_compact(c4),array_compact(c5),array_compact(c6),array_compact(c7),array_compact(c8) from vtt1;

--error 5083
select distinct array_compact(c1),array_compact(c3),array_compact(c4),array_compact(c5),array_compact(c6),array_compact(c7),array_compact(c8) from tt1;
--sorted_result
select distinct array_compact([1,1,1,2,3,3,3,5]) from tt1;
--sorted_result
select array_compact(c1),array_compact(c3),array_compact(c4),array_compact(c5),array_compact(c6),array_compact(c7),array_compact(c8) from tt1 where array_length(array_compact(c5))>0;
--sorted_result
select array_compact(c1),array_compact(c3),array_compact(c4),array_compact(c5),array_compact(c6),array_compact(c7),array_compact(c8) from tt1 group by array_length(array_compact(c1)) desc;
--sorted_result
select array_compact(c1),array_compact(c3),array_compact(c4),array_compact(c5),array_compact(c6),array_compact(c7),array_compact(c8) from tt1 group by array_length(array_compact(c1)) with rollup;
--sorted_result
select c1,array_compact(c1),array_compact(c3),array_compact(c4),array_compact(c5),array_compact(c6),array_compact(c7),array_compact(c8) from tt1 group by id with rollup having array_length(array_compact(c1)) > 0;
select c1,array_compact(c1),array_compact(c3),array_compact(c4),array_compact(c5),array_compact(c6),array_compact(c7),array_compact(c8) from tt1 group by id desc having array_length(array_compact(c1)) > 0;
--sorted_result
select array_compact(c1),array_compact(c3),array_compact(c4),array_compact(c5),array_compact(c6),array_compact(c7),array_compact(c8) from vtt1 group by array_length(array_compact(c1)) with rollup;
--sorted_result
select array_compact(c1),array_compact(c3),array_compact(c4),array_compact(c5),array_compact(c6),array_compact(c7),array_compact(c8) from tt1 rollup FOR UPDATE;
--sorted_result
select array_compact(c1),array_compact(c3),array_compact(c4),array_compact(c5),array_compact(c6),array_compact(c7),array_compact(c8) from tt1 order by id;
--sorted_result
select array_compact(c1),array_compact(c3),array_compact(c4),array_compact(c5),array_compact(c6),array_compact(c7),array_compact(c8) from tt1 order by array_length(array_compact(c5));
--sorted_result
select array_compact(c1),array_compact(c3),array_compact(c4),array_compact(c5),array_compact(c6),array_compact(c7),array_compact(c8) from tt1 order by array_avg(array_compact(c5)) desc;
--sorted_result
select array_compact(c1),array_compact(c3),array_compact(c4),array_compact(c5),array_compact(c6),array_compact(c7),array_compact(c8) from tt1 limit 1;
--sorted_result
select c1,array_compact(c1),array_compact(c3),array_compact(c4),array_compact(c5),array_compact(c6),array_compact(c7),array_compact(c8) from tt1 where array_compact(c5) is not null group by array_avg(array_compact(c1)) having array_length(array_compact(c1)) > 0 order by id desc;
--sorted_result
select array_compact(c1),array_compact(c3),array_compact(c4),array_compact(c5),array_compact(c6),array_compact(c7)from tt1 union all select array_compact(c1),array_compact(c3),array_compact(c4),array_compact(c5),array_compact(c6),array_compact(c7) from tt2;


