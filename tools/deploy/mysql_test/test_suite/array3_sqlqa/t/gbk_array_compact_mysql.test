select /*+ ENABLE_PARALLEL_DML parallel(256) */  array_filter(x->(array_length(array_compact(x))>0),tt3.c4) from tt3;
desc tt3;
alter table tt3 change COLUMN c2 c2 varchar(256)[];
UPDATE tt3 /*+ ENABLE_PARALLEL_DML parallel(256) */ SET c2 = (SELECT 
array_compact(tt3.c3));

select /*+read_consistency(weak) */  distinct array_compact(array_agg(array_compact(tt3.c3))) from tt3;
select * from tt3;

