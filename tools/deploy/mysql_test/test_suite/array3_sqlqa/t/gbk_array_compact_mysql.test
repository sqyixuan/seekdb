--error 1051
drop table tt2;
create table tt2(id int,c1 array(int unsigned), c2 array(varchar(256)), c3 array(tinyint unsigned), c4 array(bigint unsigned), c5 array(float), c6 array(double), c7 array(smallint unsigned),c8 vector(3))
PARTITION BY range COLUMNS(id)(
PARTITION p0 values less than(19),
PARTITION p1 values less than(25),
PARTITION p2 values less than(30)
);

create index idx_tt2 on tt2(id);
create UNIQUE index idx_tt2_id on tt2(id);

create index func_idx1 on tt2 ((array_length(c1)));
create index func_idx2 on tt2 ((array_length(c3))); 
create index func_idx3 on tt2 ((array_length(array_compact(c4)))); 
create index func_group on tt2(id) with column group (each column);  

