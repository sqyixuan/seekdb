replace into tt3 values(2,(select array_compact([1,3,3,4])),(select array_compact([2,4])),(select array_compact([null])));
select * from tt3;

insert into tt3 values((select array_length([3,4,3])),
(select array_compact(c3) from tt1 limit 1),(select array_compact(c3) from tt2 limit 1),(select array_compact([1,null]) from vtt1 limit 1)) ON DUPLICATE KEY UPDATE  id=array_length([1]);

insert into tt3 values((select array_length([3,4,3])),
(select array_compact([1,3,3,4,2,2,3])),(select array_compact([3,2,1,2,1,1,null])),(select array_compact([1,null]) )) ON DUPLICATE KEY UPDATE  id=array_length([1,2]);

