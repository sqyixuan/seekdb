drop view if exists vtt4;
create view vtt4 as select * from tt4;

select t3.*,array_compact(t3.c2) from tt3 t3 inner join tt4 t4 on array_compact(t3.c2)=array_compact(t4.c2);
select t3.*,array_compact(t3.c3) from tt3 t3 right join tt4 t4 on  array_compact(t3.c3)=array_compact(t4.c3);
select t3.*,array_compact(t3.c4) from tt3 t3 left join tt4 t4 on  array_compact(t3.c4)=array_compact(t4.c4);
select t3.*,array_compact(t3.v) from tt3 t3  join tt4 t4 on  array_compact(t3.v)=array_compact(t4.v);
#union
select t3.*,array_compact(t3.c2) from tt3 t3 inner join tt4 t4 on array_compact(t3.c2)=array_compact(t4.c2) union select t3.*,array_compact(t3.c2) from tt3 t3 inner join tt4 t4 on array_compact(t3.c2)=array_compact(t4.c2);
select t3.*,array_compact(t3.c3) from tt3 t3 right join tt4 t4 on  array_compact(t3.c3)=array_compact(t4.c3) MINUS select t3.*,array_compact(t3.c3) from tt3 t3 right join tt4 t4 on  array_compact(t3.c3)=array_compact(t4.c3);
select t3.*,array_compact(t3.c4) from tt3 t3 left join tt4 t4 on  array_compact(t3.c4)=array_compact(t4.c4) UNION ALL select t3.*,array_compact(t3.c4) from tt3 t3 left join tt4 t4 on  array_compact(t3.c4)=array_compact(t4.c4);
select t3.*,array_compact(t3.v) from tt3 t3  join tt4 t4 on  array_compact(t3.v)=array_compact(t4.v) INTERSECT select t3.*,array_compact(t3.v) from tt3 t3  join tt4 t4 on  array_compact(t3.v)=array_compact(t4.v);

