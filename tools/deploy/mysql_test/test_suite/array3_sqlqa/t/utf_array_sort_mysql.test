#owner group: shenzhen
#author: xiekejian.xkj
# description: array array_sort(array) 使用和测试场景
# tags: array

purge recyclebin;
--disable_warnings
drop database  IF EXISTS  testkj;
--enable_warnings
create DATABASE testkj;
USE testkj;
SET timestamp = 1600000000;
SET ob_trx_timeout = 10000000000;
SET ob_query_timeout = 100000000000;
SET SESSION group_concat_max_len = 100000000;

--result_format 4
--error 0,1051
drop table tt1;
create table tt1(id int,c1 array(int), c2 array(varchar(256)), c3 array(tinyint), c4 array(bigint), c5 array(float), c6 array(double), c7 array(smallint),c8 array(int));
insert into tt1 values(1,[-2147483648,-2147483647,0,77777],['test','test'],[127,0,-128],[-9223372036854775808,9223372036854775807,775,808,2,0],[3.402, 0, 1.175],
[1.7976931348623157E+308, 2.2250738585072014E-308,2.2250738585072014E-308],[-32768,0,32767,32767],[5,3,2,1,4]);

insert into tt1 values(2,[-2147483648,0, 2147483647,4,3,2,1,26,5,2147483647,null],['test',null],[-128,127,0,-128,6,77],[-9223372036854775808,9223372036854775807,775,808,2,0,1],[3.402, 0, 1.175, 1.175, 4],
[-1.7976931348623157E+30,1.2,2.2250738585072014E-308,2.2250738585072014E-308],[-32768,0,32767,0],[14444,2,32,6565,3333,222]);
insert into tt1 values(3,null,null,null,null,null,null,null,null);

--error 0,1051
drop view vtt1;
create view vtt1 as select * from tt1;

--error 0,1051
drop table tt2;
create table tt2(id int,c1 array(int unsigned), c2 array(varchar(256)), c3 array(tinyint unsigned), c4 array(bigint unsigned), c5 array(float), c6 array(double), c7 array(smallint unsigned))
PARTITION BY range COLUMNS(id)(
PARTITION p0 values less than(19),
PARTITION p1 values less than(25),
PARTITION p2 values less than(30)
);
insert into tt2 values(1,[2147483648, 2147483648,0],['test'],[52,0,5,0,5,3,8,7,7,67,9],[ 852,9223372036854775807,775,808,2,0,9223372036854775807],[3.402, 0, 1.175,1.175,1.1750001,1.2212],
[1.7976931348623157E+308, 2.2250738585072014E-308,2.2250738585072014E-308],[88,0,32767,32767]);

insert into tt2 values(2,[87666,0, 2147483647,4],['test'],[5,0,7,6,50],[1,100000,9223372036854775807,775,808,2,0,1],[3.402, 0, 1.175,4],
[1.7976931348623157E+308,1.2,2.2250738585072014E-308],[68,0,32767,32766,1]);
insert into tt2 values(3,null,null,null,null,null,null,null);

--error 0,1051
drop view vtt2;
create view vtt2 as select * from tt2;

# 关闭向量优化和batch的优化
select /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */ array_sort(c2) a from tt2;
select /*+ OPT_PARAM('rowsets_enabled', 'FALSE') */ array_sort(c2) a from tt2;

select /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */ array_sort(c2) a from vtt2;
select /*+ OPT_PARAM('rowsets_enabled', 'FALSE') */ array_sort(c2) a from vtt2;

select /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */ array_sort(c2) a from vtt1;
select /*+ OPT_PARAM('rowsets_enabled', 'FALSE') */ array_sort(c2) a from vtt1;
select /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */ array_sort(c2) a from tt1;
select /*+ OPT_PARAM('rowsets_enabled', 'FALSE') */ array_sort(c2) a from tt1;

select /*+ OPT_PARAM('rowsets_enabled', 'FALSE') */ /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */ array_sort(c2) a from tt2;

# array参数类型,注意不支持嵌套数组
# 空值,以及字符串
select array_sort([null]);
select array_sort([null,null]);
select array_sort([null,null,null]);
select array_sort([4,2,1,4,5,3,4,4,6,4,null,null]);
select array_sort(["null","123","check"]);
select array_sort([true,false,true,null]);
select array_sort(["true",null,"false","true",true,false]);
select array_sort([null,""]);
select array_sort([null,"null","","null,null"]);
select array_sort(['a',null,'null','']);
select array_sort(['[1]','[1]','test']);
select array_sort(['test','test1','test2','[1]','test']);
select array_sort(["aaaa","teset",'aaaa','testet']);
select array_sort(['',"",null,"aa","aaa","aaaa",'[]']);
select array_sort(['test],[test1','test1','test1']);
select array_sort(["","",""]);
select array_sort(["",'[]','[]','array_remove([1],1)']);

--error 1235
select array_sort([['test],[test1'],['test1']]);


# 参数校验
--error 1235
select array_sort([b'111',b'101']);
--error 1235 
select array_sort([cast('{}' as json)]);

select array_sort([true,1]);
--error 1235
select array_sort([x'01',1,2]);
--error 1235
select array_sort([11,0x010101000000]);

--error 1235
select array_sort([11,0x0000000001010000000000000000002E400000000000003440,0x0000000001010000000000000000002E400000000000003440]);

select array_sort([18446744073709551614,9223372036854775808,18446744073709551616]);

# 数值类型
select array_sort([-9223372036854775808,-9223372036854775808]);
select array_sort([5.00,3.02,5.00,3.02]);
select array_sort([-5.0,10000000.02,-5.00,10000000.02]);
select array_sort([--5.0,1000000.02,-0.00,--5.0,1000000.02,-0.00,true,false,null]);

select array_sort([5.0,-200000.02,200000.03,0.62622,5.0,-200000.02,200000.03,0.62622,'test',null,null,'test']);

--error 1367
select array_sort([-2.7976931348623157E+308,-2.7976931348623157E+308,-2.7976931348623157E+308]);

# dml语句
select array_sort(c1) from tt1;
select array_sort(c2) from tt1;
select array_sort(c3) from tt1;
select array_sort(c4) from tt1;
select array_sort(c5) from tt1;
select array_sort(c6) from tt1;
select array_sort(c7) from tt1;

select array_sort(c1) from vtt2;
select array_sort(c1) from tt2;
select *, array_sort(c7) from vtt1;
select *,array_sort(c7) from vtt2;
select *,array_sort(c5) from tt2;

select *,array_sort([null,null,1,4,2,3,5,4,4,null,3,null]) from tt1;

#hint
select /*+enable_parallel_dml parallel(3) */ array_sort(c1) from tt2;
select /*+enable_parallel_dml parallel(3) */ array_sort(c2) from tt1;
select /*+enable_parallel_dml parallel(3) */ array_sort(c3) from vtt2;
select /*+enable_parallel_dml parallel(3) */ array_sort(c4) from vtt1;



select array_sort([cast(1 as unsigned),cast(1 as unsigned)]);
select array_sort([cast(null as unsigned),cast(null as unsigned)]);

# group by/group by having
select * from tt1 group by array_length(c1);
select array_sort(c1) from tt1 group by array_length(c3);
select * ,array_sort(c1) from vtt1 group by id having array_length(c2)>1;
select * ,array_sort(c5) from tt2 group by id having array_length(c4)>2;

# order by
select * ,array_sort(c1), c1 from tt1 order by array_length(c1);
select * ,array_sort(c1), c1,c2 from tt1 order by array_length(c1) desc ;
select * ,array_sort(c2), c1,c2 from tt1 order by array_length(c2) asc ;

select * ,array_sort(c1), c1 from vtt1 order by array_length(c1);
select * ,array_sort(c1), c1,c2 from vtt1 order by array_length(c1) desc ;
select * ,array_sort(c2), c1,c2 from vtt1 order by array_length(c2) asc ;

select * ,array_sort(c1), c1 from tt2 where id=1 order by array_length(c1);
select * ,array_sort(c1), c1,c2 from tt2 where id=1  order by array_length(c1) desc ;
select * ,array_sort(c2), c1,c2 from tt2  where id=1  order by array_length(c5) asc ;
select * ,array_sort(c1), c1 from vtt2 where id=1 order by array_length(c1);
select * ,array_sort(c1), c1,c2 from vtt2 where id=1  order by array_length(c1) desc ;
select * ,array_sort(c2), c1,c2 from vtt2  where id=1  order by array_length(c2) asc ;

# distinct
--error 5083
select distinct array_sort(c1) from tt1;

# cast
--error 5083
select cast(array_sort(c4) as unsigned) from tt1;
--error 5083
select cast(array_sort(c4) as point) from 
tt1;
--error 5083
select cast(array_sort(c4) as json) from tt1;
--error 5083
select cast(array_sort(c4) as roaringbitmap) from tt1;

# where
select * ,array_sort(c1) from tt1 where array_length(c1) = 4;
select * from tt1 where array_sort(c2) = array_sort(c2);
select * from tt1 where array_sort(c8) = [1,2,3,4,5];
select * from tt1 where array_sort(c8) <>[1,2,3,4,5];
select * from tt1 where array_sort(c8) !=[1,2,3,4,5];
select * from tt1 where array_sort(c8)!= [cardinality([1,2,3,4,5])];
select * from tt1 where array_length(array_sort(c5)) BETWEEN array_length(c2) AND array_length(c1);

select * from tt1 where array_length(c1) like array_length(c1);
select * from tt1 where array_length(c1) not like array_length(c1);

select * from tt1 where array_sort(c8) is not null;
select * from tt1 where array_sort(c8) is null;

