# join
--error 0,1051
drop table tt3;
create table tt3(id int,a int[]);
insert into tt3 values(1,[1,4,3,2,3,2]);
insert into tt3 values(2,[6,5,7,7,null]);
insert into tt3 values(3,[5,7,6,2,3,1]);
--error 0,1051
drop table tt4;
create table tt4(id int,a int[]);
insert into tt4 values(1,[1,4,3,2,3,2]);
insert into tt4 values(2,[5,7,6,1,2,null]);
insert into tt4 values(3,[9]);

select t3.* ,array_sort(t3.a) from tt3 t3 inner join tt4 t4 on array_sort(t3.a)=array_sort(t4.a);
select t3.* ,array_sort(t3.a) from tt3 t3 inner join tt4 t4 on array_sort(t3.a)=array_sort(t4.a);
select t3.* ,array_sort(t4.a) from tt3 t3 right join tt4 t4 on array_sort(t3.a)=array_sort(t4.a);
select t3.* ,array_sort(t4.a) from tt3 t3 full join tt4 t4 on array_sort(t3.a)=array_sort(t4.a);
select array_sort(tt3.a) from tt3;

# union
select * from tt3 union select * from tt4;
(select array_sort(t3.a) from tt3 t3) union distinct(select array_sort(t4.a) from tt4 t4);


