# join
--error 0,1051
drop table tt3;
create table tt3(id int,a int[]);
insert into tt3 values(1,[1,2,3,3]);
insert into tt3 values(2,[5,6,7,7,null]);
insert into tt3 values(3,[5,6,7]);
--error 0,1051
drop table tt4;
create table tt4(id int,a int[]);
insert into tt4 values(1,[1,2,3]);
insert into tt4 values(2,[5,6,7,7,null]);
insert into tt4 values(3,[9]);

select t3.* from tt3 t3 inner join tt4 t4 on array_filter(x1->(x1*x1),t3.a)=array_filter(x1->(x1*x1>12),t4.a);
select t3.* from tt3 t3 right join tt4 t4 on array_filter(x1->(x1 or 1),t3.a)=array_filter(x1 ->(x1 or 1),t4.a);
select t3.* from tt3 t3 full join tt4 t4 on array_filter(x1->(x1*2),t3.a)=array_filter(x1->(x1*2 >= 20),t4.a);
select array_filter(x->(x),tt3.a) from tt3;

# union
select * from tt3 union select * from tt4;

(SELECT array_filter((x, y) -> (x+y)>4, t3.a, t3.a) FROM tt3 t3 WHERE t3.a IS NOT NULL) UNION DISTINCT (SELECT array_filter((x, y) -> (y+x)>3, t4.a, t4.a)FROM tt4 t4 WHERE t4.a is not null);

(SELECT array_filter((x, y) -> !(y - x), t3.a, t3.a)FROM tt3 t3) UNION (SELECT array_filter((x, y) -> !(y - x), t4.a, t4.a)FROM tt4 t4);

SELECT * FROM (
    (SELECT array_filter((x, y) -> !(y - x), t3.a, t3.a) FROM tt3 t3)
    UNION
    (SELECT array_filter((x, y) -> !(y - x), t4.a, t4.a) FROM tt4 t4)
) AS combined_results;

(SELECT t3.a FROM tt3 t3 ORDER BY t3.a IS NULL DESC, t3.a DESC) UNION (SELECT t4.a FROM tt4 t4 ORDER BY t4.a IS NULL DESC, t4.a DESC);

