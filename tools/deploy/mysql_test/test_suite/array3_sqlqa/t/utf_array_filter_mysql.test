# 索引函数
--error 0,1051
drop table tt3;
--error 0,3758
create table tt3(id int,a varchar(50),INDEX index_1((array_filter((x) -> (x=x),[null]))))PARTITION BY range COLUMNS(id)(
PARTITION p0 values less than(19),
PARTITION p1 values less than(25),
PARTITION p2 values less than(30)
);

--error 0,1051
drop table tt3;
--error 0,3758
create table tt3(id int,c1 int[], INDEX index_1((array_filter((x) -> (x=x),c1))))PARTITION BY range COLUMNS(id)(
PARTITION p0 values less than(19),
PARTITION p1 values less than(25),
PARTITION p2 values less than(30)
);

