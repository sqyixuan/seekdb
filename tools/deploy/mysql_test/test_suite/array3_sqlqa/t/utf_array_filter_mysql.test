--error 0,1051
drop table tt4;
create table tt4(id int primary key,id1 int[])
PARTITION BY range(id)(
PARTITION p0 values less than(0),
PARTITION p1 values less than(20),
PARTITION p2 values less than(MAXVALUE)
) WITH COLUMN GROUP(each column);
--error 0,1051
drop view vtt4;
create view vtt4 as select * from tt4;
INSERT /*+ DIRECT(true, 0, 'inc_replace') enable_parallel_dml parallel(16) */ INTO tt4 (id,id1) SELECT 10, array_filter((x) -> (x=x),[id*8,10]) from tt3 limit 3;

update tt3 set id1=array_filter((x) -> (x=x),[912,0,5]) limit 1;
update tt3 set id1=array_filter((x) -> (x=x),[12,3,833,9,0,5]),id2=array_filter((x) -> (x=x),[null]) where array_filter((x) -> (x=x),[id])<>null limit 3;

update ignore tt3 set id1=array_filter((x) -> (x=x),[12,3,8,9,0,50]) where array_filter((x) -> (x=x),[id])<>null order by id limit 5;
update tt3 set id1 =(select array_filter((x) -> (x=x),id2) from tt3 where id=1) order by id desc limit 3;
#select * from tt3;
#select * from vtt3;

update  /*+ OPT_PARAM('rowsets_enabled', 'FALSE') */ /*+ OPT_PARAM('rowsets_enabled', 'FALSE') */ vtt3 set id1=array_filter((x) -> (x=x),[12,3,8,90,0,5]) limit 1;
update vtt3 set id1=array_filter((x) -> (x=x),[12,3,8,9,0,5]);
update  /*+ OPT_PARAM('rowsets_enabled', 'FALSE') */  tt3 set id2=array_filter((x) -> (x=x),[9,0,5,78754]) limit 1;
#select * from tt3;

delete from tt3 where array(id) =array_filter((x) -> (x=x),[1]);
delete from tt3 where id1 <>array_filter((x) -> (x=x),[0,null]);
delete from tt3 where id1=array_filter((x) -> (x=x),[12,6,0]) limit 1;
delete from tt3 where id1 =(select array_filter((x) -> (x=x),id1) from tt3 where id=1);
delete from tt3 order by id limit 3;
delete tt3,tt4 from tt3 inner join tt4 on array_filter((x) -> (x=x),[tt3.id])=array_filter((x) -> (x=x),[tt4.id]) where array_filter((x) -> (x=x),[tt3.id]) <> null;

