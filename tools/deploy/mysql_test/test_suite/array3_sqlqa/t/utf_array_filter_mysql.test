# 嵌套数组的array格式
select array_filter((x1,x2)->(array_length(x1)>2),[[null,3,2,1,1,2]],[[5,4,6,4,3,null]]);
select array_filter((x1,x2)->(array_compact(x1)!=[1,2,3]),[[1,1,1,12,2,2,3,3,3,4,5,null]],[[1,2,3]]);
select array_filter(x1->(array_sort(x1)!=[1,2,3]),[[1,2,3,null],[3,2,1],[3,1,2]]);
select array_filter((x,y)->(x*y),array_compact([1,1,1,2,3,null]),array_compact([2,2,2,1,3,null]));
select array_filter((x, y) ->(y),array_sort([1,2,3,3,4,3,4,5,8,7,6,null]),[3,2,1,null,-1,-1,0,1,null,1,4,3]);
select array_filter((x,y)->(y),array_sortby(x->x/x,[1,null,6,5,4,3,8,-4,0]),[3,0,null,4,2,6,-1,0,null]);

--error 0,1051
drop table tt1;
create table tt1(id int,c1 array(int), c2 array(varchar(256)), c3 array(tinyint), c4 array(bigint), c5 array(float), c6 array(double), c7 array(smallint), c8 vector(3)) CHARACTER SET utf8mb4
PARTITION BY range COLUMNS(id)(
PARTITION p0 values less than(1),
PARTITION p1 values less than(2),
PARTITION p2 values less than(MAXVALUE)
);
create index idx_tt1 on tt1(id);
create UNIQUE index idx_tt1_id on tt1(id);
CREATE INDEX tt1_func_idx1 on tt1((array_avg(c1)));
CREATE INDEX tt1_func_idx2 on tt1((array_max(c2)));
CREATE INDEX tt1_func_idx3 on tt1((array_min(c5)));
CREATE INDEX idx_tt1_cg on tt1(id) WITH COLUMN GROUP(each column);
