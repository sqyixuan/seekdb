## insert/replace/update/delete
--error 0,1051
drop table tt3;
create table tt3(id int primary key,id1 int[],id2 int[])
PARTITION BY range(id)(
PARTITION p0 values less than(10),
PARTITION p1 values less than(20),
PARTITION p2 values less than(MAXVALUE)
);
--error 0,1051
drop view vtt3;
create view vtt3 as select * from tt3;
insert into tt3 values(1, array_filter((x) -> (x=x),[1,2,34]),array_filter((x) -> (x=x),[1,2,34]));
insert into tt3 values(2, array_filter((x) -> (x=x),[2,2,null]),(array_filter((x) -> (x=x),[1,2,34])));
insert into tt3 values(3, array_filter((x) -> (x=x),[3,9,null]),array_filter((x) -> (x=x),[false]));
insert into tt3 partition (p0) values(4, array_filter((x) -> (x=x),[4,-50]),array_filter((x) -> (x=x),[false]));
insert into tt3 partition (p0) (id,id1) values(5, array_filter((x) -> (x=x),[5,-11,null]));
insert into tt3 partition (p1) (id,id1,id2) values(16, array_filter((x) -> (x=x),[16,10]),array_filter((x) -> (x=x),[true,false,false]));
insert ignore into tt3 values(8, array_filter((x) -> (x=x),[15,2,34]),array_filter((x) -> (x=x),[1,2,34])) ON DUPLICATE KEY UPDATE  id1=array_filter((x) -> (x=x),array_compact([3,3,3,9,9,9,null]));

