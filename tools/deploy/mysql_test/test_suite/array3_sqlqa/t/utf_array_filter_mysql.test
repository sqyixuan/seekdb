# description: array array_filter(array) 使用和测试场景
# tags: array

purge recyclebin;
--disable_warnings
drop database  IF EXISTS  testkj;
--enable_warnings
create DATABASE testkj;

USE testkj;
SET timestamp = 1600000000;
SET ob_trx_timeout = 10000000000;
SET ob_query_timeout = 100000000000;
SET SESSION group_concat_max_len = 100000000;

# 一些基础的功能性case
--sorted_result
--result_format 4
select array_filter(x ->(x is null),null);
select array_filter(x -> (x),[1]);
select array_filter((x,y,z) -> (x is null and y is not null or z is not null), [[1],['null'],[null],[2,1,3,null]], [1,2,3,null],['abc','null','',null]);
select array_filter((x,y) -> (x + y > 3),[1,4,3,2], [2,6,5,4]);
select array_filter((a,A) -> (a + A),[1], [2]);
select array_filter((a,A) -> (a + A),[1], [0]);
select array_filter((a,A) -> (a + A),[1], [null]);

select array_filter((x,y) -> (x),[1,-1], [-2,2]);
select array_filter((x,y) -> (y),[1,4,3,2], [2,8,6,4]);
select array_filter((x,y) -> (1),[1], [2]);
select array_filter((x,y)->((x is null) and (y is null)), [1232], [[['abc']]]);
select array_filter((x,y)->(x+y), array_filter(x2->(x2+1),[1,2,3]),array_filter(x1->(x1+2),[1,2,3]));
select array_filter(x ->(x*2>3), [1,3]);
select array_filter((x,y) ->(x*2+y+x*2), [1,3],[4,5]);

SELECT array_filter(x ->(x LIKE '%World%'), ['Hello', 'abc World','World','null']);

--error 1690
select array_filter((x, y) -> (x + 1 + y + 1), [(9223372036854775798), (null)], [(9223372036854775798), (9223372036854775798)]);
select array_filter(x1->(x1+9223372036854775800),[1,2,3,-2,-4,0]);

select array_filter(x1->((x1+2)>3),[2,1,null,3,1]);

# array参数类型
# 常规的空值null
select array_filter((x) ->(x + 1),[1,3,2,2,null]);
select array_filter((x) ->(x%2),[3,2,1,4,3,5,6]);

SELECT array_filter(x ->(x LIKE '%World%'), ['Hello', 'abc World','World','null',null]);
select array_filter((x, y) ->(y), [['a'],['b','c',null],['d']], [1,1,0]);
select array_filter((x,y)->(x),[null,4],[3,2]);
select array_filter((x,y)->(x*2),[null,6,2,3],[2,4,2,4]);
select array_filter((x,y)->(length(y)),[null,'null',3,5,2],[null,'null',2,3,3]);
select array_filter(x->length(x),[null,'null,null','null']);

select array_filter(x->(x is null),[null,'null[',null,'']);

select array_filter((x,y) -> (x + y),[1,null], [null,2]);
select array_filter((a,A) -> (a + A),[1,null], [0,2]);
select array_filter((a,A) -> (a + A),[1,null], [null,0]);
select array_filter((x,y)->(y),[null,4,3,2,1],[null,1,0,-1,4]);
select array_filter((x)->(x+x),[null,2,1,null]);
select array_filter((x,y)->(y+y),[null,'null',22,"a"],[4,1,3,null]);
--error 5083
select array_filter((x)->(array_compact(x)),[[null,"aaa华侨城",123,'','null'],[4,2,3,1,2,3],["111",11,1,NULL,'NULL']]);
select array_filter((x)->array_length(x),[[1,'test','test'],[2,2,3,3,null,NULL],null]);
select array_filter((x)->null,[null,[null]]);


