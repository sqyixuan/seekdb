insert into tt3 values(2,[5,6,7]);
insert into tt3 values(3,null);
insert into tt3 values(4,'[]');
--error 0,1051
drop table tt4;
create table tt4(id int,a int[]);
insert into tt4 values(1,[1,2,3]);
insert into tt4 values(2,[5,6,7]);
insert into tt4 values(3,null);
insert into tt4 values(4,'[]');

select array_filter((x) -> (x=x),t1.a) from tt3 t1 join tt3 t2 on array_filter((x) -> (x=x),t1.a)=array_filter((x) -> (x=x),t2.a);
select array_filter((x) -> (x=x),t1.a) from tt3 t1 inner join tt3 t2 on array_filter((x) -> (x=x),t1.a)=array_filter((x) -> (x=x),t2.a);
select array_filter((x) -> (x=x),t1.a) from tt3 t1 left join tt3 t2 on array_filter((x) -> (x=x),t1.a)=array_filter((x) -> (x=x),t2.a);
select array_filter((x) -> (x=x),t1.a) from tt3 t1 right join tt3 t2 on array_filter((x) -> (x=x),t1.a)=array_filter((x) -> (x=x),t2.a);
select array_filter((x) -> (x=x),t1.a) from tt3 t1 full join tt3 t2 on array_filter((x) -> (x=x),t1.a)=array_filter((x) -> (x=x),t2.a);
select array_filter((x) -> (x=x),t1.a) from tt3 t1 cross join tt3 t2 on array_filter((x) -> (x=x),t1.a)=array_filter((x) -> (x=x),t2.a);

select array_filter((x) -> (x=x),[[t2.a]]) from tt3 t1 join (select array_filter((x) -> (x=x),t1.a) a from tt3 t1 full join tt3 t2 on array_filter((x) -> (x=x),t1.a)=array_filter((x) -> (x=x),t2.a)) t2 on array_length(t1.a)=array_length(t2.a);
select array_filter((x) -> (x=x),[[t2.a]]) from tt3 t1 inner join (select array_filter((x) -> (x=x),t1.a) a from tt3 t1 full join tt3 t2 on array_filter((x) -> (x=x),t1.a)=array_filter((x) -> (x=x),t2.a)) t2 on array_length(t1.a)=array_length(t2.a);
select array_filter((x) -> (x=x),[[t2.a]]) from tt3 t1 left join (select array_filter((x) -> (x=x),t1.a) a from tt3 t1 full join tt3 t2 on array_filter((x) -> (x=x),t1.a)=array_filter((x) -> (x=x),t2.a)) t2 on array_length(t1.a)=array_length(t2.a);
select array_filter((x) -> (x=x),[[t2.a]]) from tt3 t1 right join (select array_filter((x) -> (x=x),t1.a) a from tt3 t1 full join tt3 t2 on array_filter((x) -> (x=x),t1.a)=array_filter((x) -> (x=x),t2.a)) t2 on array_length(t1.a)=array_length(t2.a);


select array_filter((x) -> (x=x),t3.a),array_filter((x) -> (x=x),[t3.id,t4.id]) from tt3 t3 join tt4 t4 on array_filter((x) -> (x=x),t3.a)=array_filter((x) -> (x=x),t4.a);
select array_filter((x) -> (x=x),t3.a),array_filter((x) -> (x=x),[t3.id,t4.id]) from tt3 t3 join tt4 t4 where array_filter((x) -> (x=x),t3.a)=array_filter((x) -> (x=x),t4.a);
select array_filter((x) -> (x=x),t3.a),array_filter((x) -> (x=x),[t3.id,t4.id]) from tt3 t3 inner join tt4 t4 on array_compact(t4.a) =  array_filter((x) -> (x=x),t4.a);
select array_filter((x) -> (x=x),t3.a),array_filter((x) -> (x=x),[t3.id,t4.id]) from tt3 t3 left join tt4 t4 on array_compact(t4.a) =  array_filter((x) -> (x=x),t4.a);
select array_filter((x) -> (x=x),t3.a),array_filter((x) -> (x=x),[t3.id,t4.id]) from tt3 t3 right join tt4 t4 on t3.id=t4.id;

select array_filter((x) -> (x=x),t3.a),array_filter((x) -> (x=x),[t3.id,t4.id]) from tt3 t3 full join tt4 t4 on array_filter((x) -> (x=x),t3.a)<>array_filter((x) -> (x=x),t4.a);
select array_filter((x) -> (x=x),t3.a),array_filter((x) -> (x=x),[t3.id,t4.id]) from tt3 t3 cross join tt4 t4 on array_filter((x) -> (x=x),t3.a)!=array_filter((x) -> (x=x),t4.a);

select t3.* from tt3 t3 join tt4 t4 on array_filter((x) -> (x=x),t3.a)=array_filter((x) -> (x=x),t4.a);
select t3.* from tt3 t3 left join tt4 t4 on array_filter((x) -> (x=x),t3.a)=array_filter((x) -> (x=x),t4.a);
select * from tt3 t3 full join tt4 t4 on array_compact(t4.a) <> array_filter((x) -> (x=x),[1,2,45,67]);
select * from tt3 t3 cross join tt4 t4 on array_compact(t4.a) <> array_filter((x) -> (x=x),[1,2,45,67]);
select t3.* from (select array_filter((x) -> (x=x),t3.a) a,array_filter((x) -> (x=x),[t3.id,t4.id]) b from tt3 t3 join tt4 t4 on array_filter((x) -> (x=x),t3.a)=array_filter((x) -> (x=x),t4.a)) as t3 join (select array_filter((x) -> (x=x),t3.a) a,array_filter((x) -> (x=x),[t3.id,t4.id]) b from tt3 t3 join tt4 t4 where array_filter((x) -> (x=x),t3.a)=array_filter((x) -> (x=x),t4.a)) as t4;
select * from (select t3.* from tt3 t3 join tt4 t4 on array_filter((x) -> (x=x),t3.a)=array_filter((x) -> (x=x),t4.a)) as t3 join (select t4.* from tt3 t3 right join tt4 t4 on array_compact(t4.a)!=array_filter((x) -> (x=x),t3.a)) as t4 on array_filter((x) -> (x=x),t3.a)=array_filter((x) -> (x=x),t4.a);

