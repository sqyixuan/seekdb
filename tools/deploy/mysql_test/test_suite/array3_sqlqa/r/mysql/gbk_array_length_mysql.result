drop table tt3;
create table tt3(a bigint[]);
insert into tt3 values((SELECT CONCAT('[', GROUP_CONCAT(number ORDER BY number SEPARATOR ', '), ']') AS nums
FROM (
     SELECT FLOOR(1+RAND() * 10) AS number
    FROM TABLE(GENERATOR(10000))
) AS temp));
