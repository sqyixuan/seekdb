DROP MATERIALIZED VIEW  mv1;
create materialized view mv1  as select array_compact(c2) c2,array_compact(c3) c3,array_compact(c4) c4, array_compact(v) v from tt3;
desc mv1;
+-------+----------------------------+------+-----+---------+-------+
| Field | Type                       | Null | Key | Default | Extra |
+-------+----------------------------+------+-----+---------+-------+
| c2    | ARRAY(ARRAY(ARRAY(INT)))   | YES  |     | NULL    |       |
| c3    | ARRAY(FLOAT UNSIGNED)      | YES  |     | NULL    |       |
| c4    | ARRAY(ARRAY(VARCHAR(256))) | YES  |     | NULL    |       |
| v     | VECTOR(2)                  | YES  |     | NULL    |       |
+-------+----------------------------+------+-----+---------+-------+
