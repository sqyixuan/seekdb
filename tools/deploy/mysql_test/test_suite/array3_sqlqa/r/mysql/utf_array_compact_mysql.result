call DBMS_MVIEW.REFRESH('mv1','c');
call DBMS_MVIEW.REFRESH('mv1','C');
call DBMS_MVIEW.REFRESH('mv1','A');
call DBMS_MVIEW.REFRESH('mv1','a');
call DBMS_MVIEW.REFRESH('mv1','?');
create materialized view mv2  as select array_compact(c2) c2,array_compact(c3) c3,array_compact(c4) c4, array_compact(v) v from mv1;
call DBMS_MVIEW.REFRESH('mv2','c');
DROP MATERIALIZED VIEW LOG ON tt4;
CREATE MATERIALIZED VIEW LOG ON tt4 WITH PRIMARY KEY, ROWID,SEQUENCE(d,c2,c3,c4,v) INCLUDING NEW VALUES;
DROP MATERIALIZED VIEW  mv1;
create materialized view mv1  REFRESH FAST  as 
select t1.id as id1,t2.id as id2 ,array_compact(t1.c2) a0,array_compact(t1.c3) a1,array_compact(t1.c4) a2,array_compact(t2.v) v from tt4 t1 inner join tt4 t2 on t1.c3=t2.c3;

