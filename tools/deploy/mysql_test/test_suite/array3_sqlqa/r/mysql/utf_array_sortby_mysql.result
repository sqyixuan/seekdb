+----------------------------+

select * from tt3 union select * from tt4;
+------+----------------+
| id   | a              |
+------+----------------+
|    1 | [1,2,3,3]      |
|    2 | [5,6,7,7,NULL] |
|    3 | [5,6,7]        |
|    1 | [1,2,3]        |
|    3 | [9]            |
+------+----------------+
(select array_sortby((x,y)->(!x/y),t3.a,t3.a) from tt3 t3) union distinct(select array_sortby((x,y)->(!x/y),t4.a,t4.a) from tt4 t4);
+---------------------------------------+
| array_sortby((x,y)->(!x/y),t3.a,t3.a) |
+---------------------------------------+
| [1,2,3,3]                             |
| [5,6,7,7,NULL]                        |
| [5,6,7]                               |
| [1,2,3]                               |
| [9]                                   |
+---------------------------------------+

(SELECT array_sortby((x, y) -> (x+y), t3.a, t3.a) FROM tt3 t3 WHERE t3.a IS NOT NULL) UNION DISTINCT (SELECT array_sortby((x, y) -> (y+x), t4.a, t4.a)FROM tt4 t4 WHERE t4.a is not null);
+-------------------------------------------+
| array_sortby((x, y) -> (x+y), t3.a, t3.a) |
+-------------------------------------------+
| [1,2,3,3]                                 |
| [5,6,7,7,NULL]                            |
| [5,6,7]                                   |
| [1,2,3]                                   |
| [9]                                       |
+-------------------------------------------+

(SELECT array_sortby((x, y) -> (y - x), t3.a, t3.a)FROM tt3 t3) UNION (SELECT array_sortby((x, y) -> (y - x), t4.a, t4.a)FROM tt4 t4);
+---------------------------------------------+
| array_sortby((x, y) -> (y - x), t3.a, t3.a) |
+---------------------------------------------+
| [1,2,3,3]                                   |
| [5,6,7,7,NULL]                              |
| [5,6,7]                                     |
| [1,2,3]                                     |
| [9]                                         |
+---------------------------------------------+

SELECT * FROM (
    (SELECT array_sortby((x, y) -> (y - x), t3.a, t3.a) FROM tt3 t3)
    UNION
    (SELECT array_sortby((x, y) -> (y - x), t4.a, t4.a) FROM tt4 t4)
) AS combined_results;
+---------------------------------------------+
| array_sortby((x, y) -> (y - x), t3.a, t3.a) |
+---------------------------------------------+
| [1,2,3,3]                                   |
| [5,6,7,7,NULL]                              |
| [5,6,7]                                     |
| [1,2,3]                                     |
| [9]                                         |
+---------------------------------------------+

(SELECT t3.a FROM tt3 t3 ORDER BY t3.a IS NULL DESC, t3.a DESC) UNION (SELECT t4.a FROM tt4 t4 ORDER BY t4.a IS NULL DESC, t4.a DESC);
+----------------+
| a              |
+----------------+
| [1,2,3,3]      |
| [5,6,7,7,NULL] |
| [5,6,7]        |
| [1,2,3]        |
| [9]            |
+----------------+

