drop table tt3;
create table tt3(id int,a int[]);
insert into tt3 values(1,[1,2,3,3]);
insert into tt3 values(2,[5,6,7,7,null]);
insert into tt3 values(3,[5,6,7]);
drop table tt4;
create table tt4(id int,a int[]);
insert into tt4 values(1,[1,2,3]);
insert into tt4 values(2,[5,6,7,7,null]);
insert into tt4 values(3,[9]);

select t3.* from tt3 t3 inner join tt4 t4 on array_sortby(x1->(x1*x1),t3.a)=array_sortby(x1->(x1*x1),t4.a);
+------+----------------+
| id   | a              |
+------+----------------+
|    2 | [5,6,7,7,NULL] |
+------+----------------+
select t3.* from tt3 t3 right join tt4 t4 on array_sortby(x1->(x1 or 1),t3.a)=array_sortby(x1 ->(x1 or 1),t4.a);
+------+----------------+
| id   | a              |
+------+----------------+
|    2 | [5,6,7,7,NULL] |
| NULL | NULL           |
| NULL | NULL           |
+------+----------------+
