update tt3 set id1=array_sortby((x) -> (x=x),[12,3,833,9,0,5]),id2=array_sortby((x) -> (x=x),[null]) where array_sortby((x) -> (x=x),[id])<>null limit 3;

update ignore tt3 set id1=array_sortby((x) -> (x=x),[12,3,8,9,0,50]) where array_sortby((x) -> (x=x),[id])<>null order by id limit 5;
update tt3 set id1 =(select array_sortby((x) -> (x=x),id2) from tt3 where id=1) order by id desc limit 3;
update  /*+ OPT_PARAM('rowsets_enabled', 'FALSE') */ /*+ OPT_PARAM('rowsets_enabled', 'FALSE') */ vtt3 set id1=array_sortby((x) -> (x=x),[12,3,8,90,0,5]) limit 1;
update vtt3 set id1=array_sortby((x) -> (x=x),[12,3,8,9,0,5]);
update  /*+ OPT_PARAM('rowsets_enabled', 'FALSE') */  tt3 set id2=array_sortby((x) -> (x=x),[9,0,5,78754]) limit 1;
delete from tt3 where array(id) =array_sortby((x) -> (x=x),[1]);
delete from tt3 where id1 <>array_sortby((x) -> (x=x),[0,null]);
delete from tt3 where id1=array_sortby((x) -> (x=x),[12,6,0]) limit 1;
delete from tt3 where id1 =(select array_sortby((x) -> (x=x),id1) from tt3 where id=1);
delete from tt3 order by id limit 3;
delete tt3,tt4 from tt3 inner join tt4 on array_sortby((x) -> (x=x),[tt3.id])=array_sortby((x) -> (x=x),[tt4.id]) where array_sortby((x) -> (x=x),[tt3.id]) <> null;

drop table tt2;
create table tt2(id int,c1 array(int unsigned), c2 array(varchar(256)), c3 array(tinyint unsigned), c4 array(bigint unsigned), c5 array(float unsigned), c6 array(double unsigned), c7 array(smallint unsigned), c8 vector(3)) CHARACTER SET gbk
PARTITION BY range COLUMNS(id)(
PARTITION p0 values less than(1),
PARTITION p1 values less than(2),
PARTITION p2 values less than(MAXVALUE)
);
create index idx_tt2 on tt2(id);
create UNIQUE index idx_tt2_id on tt2(id);
CREATE INDEX tt2_func_idx1 on tt2((array_avg(c1)));
CREATE INDEX tt2_func_idx2 on tt2((array_max(c2)));
CREATE INDEX tt2_func_idx3 on tt2((array_min(c5)));
CREATE INDEX idx_tt2_cg on tt2(id) WITH COLUMN GROUP(each column);
