drop table tt4;
create table tt4(id int primary key,id1 int[])
PARTITION BY range(id)(
PARTITION p0 values less than(0),
PARTITION p1 values less than(20),
PARTITION p2 values less than(MAXVALUE)
) WITH COLUMN GROUP(each column);
drop view vtt4;
