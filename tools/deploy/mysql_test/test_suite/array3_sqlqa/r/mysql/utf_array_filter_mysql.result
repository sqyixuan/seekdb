drop table tt5;
create table tt5(id int primary key,v vector(2), a varchar(100),d double,a1 array(float),a2 array(int))
PARTITION BY range COLUMNS(id)(
PARTITION p0 values less than(19),
PARTITION p1 values less than(25),
PARTITION p2 values less than(30)
);
drop view vtt5;
create view vtt5 as select * from tt5;
