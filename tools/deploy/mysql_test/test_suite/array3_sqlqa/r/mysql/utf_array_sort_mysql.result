select array_sort([null]);
+--------------------+
| array_sort([null]) |
+--------------------+
| [NULL]             |
+--------------------+
select array_sort([null,null]);
+-------------------------+
| array_sort([null,null]) |
+-------------------------+
| [NULL,NULL]             |
+-------------------------+
select array_sort([null,null,null]);
+------------------------------+
| array_sort([null,null,null]) |
+------------------------------+
| [NULL,NULL,NULL]             |
+------------------------------+
select array_sort([4,2,1,4,5,3,4,4,6,4,null,null]);
+---------------------------------------------+
| array_sort([4,2,1,4,5,3,4,4,6,4,null,null]) |
+---------------------------------------------+
| [1,2,3,4,4,4,4,4,5,6,NULL,NULL]             |
+---------------------------------------------+
select array_sort(["null","123","check"]);
+------------------------------------+
| array_sort(["null","123","check"]) |
+------------------------------------+
| ["123","check","null"]             |
+------------------------------------+
select array_sort([true,false,true,null]);
+------------------------------------+
| array_sort([true,false,true,null]) |
+------------------------------------+
| [0,1,1,NULL]                       |
+------------------------------------+
select array_sort(["true",null,"false","true",true,false]);
+-----------------------------------------------------+
| array_sort(["true",null,"false","true",true,false]) |
+-----------------------------------------------------+
| ["0","1","false","true","true",NULL]                |
+-----------------------------------------------------+
select array_sort([null,""]);
+-----------------------+
| array_sort([null,""]) |
+-----------------------+
| ["",NULL]             |
+-----------------------+
select array_sort([null,"null","","null,null"]);
+------------------------------------------+
| array_sort([null,"null","","null,null"]) |
+------------------------------------------+
| ["","null","null,null",NULL]             |
+------------------------------------------+
select array_sort(['a',null,'null','']);
+----------------------------------+
| array_sort(['a',null,'null','']) |
+----------------------------------+
| ["","a","null",NULL]             |
+----------------------------------+
select array_sort(['[1]','[1]','test']);
+----------------------------------+
| array_sort(['[1]','[1]','test']) |
+----------------------------------+
| ["[1]","[1]","test"]             |
+----------------------------------+
select array_sort(['test','test1','test2','[1]','test']);
+---------------------------------------------------+
| array_sort(['test','test1','test2','[1]','test']) |
+---------------------------------------------------+
| ["[1]","test","test","test1","test2"]             |
+---------------------------------------------------+
select array_sort(["aaaa","teset",'aaaa','testet']);
+----------------------------------------------+
| array_sort(["aaaa","teset",'aaaa','testet']) |
+----------------------------------------------+
| ["aaaa","aaaa","teset","testet"]             |
+----------------------------------------------+
select array_sort(['',"",null,"aa","aaa","aaaa",'[]']);
+-------------------------------------------------+
| array_sort(['',"",null,"aa","aaa","aaaa",'[]']) |
+-------------------------------------------------+
| ["","","[]","aa","aaa","aaaa",NULL]             |
+-------------------------------------------------+
select array_sort(['test],[test1','test1','test1']);
+----------------------------------------------+
| array_sort(['test],[test1','test1','test1']) |
+----------------------------------------------+
| ["test1","test1","test],[test1"]             |
+----------------------------------------------+
select array_sort(["","",""]);
+------------------------+
| array_sort(["","",""]) |
+------------------------+
| ["","",""]             |
+------------------------+
select array_sort(["",'[]','[]','array_remove([1],1)']);
+--------------------------------------------------+
| array_sort(["",'[]','[]','array_remove([1],1)']) |
+--------------------------------------------------+
| ["","[]","[]","array_remove([1],1)"]             |
+--------------------------------------------------+

