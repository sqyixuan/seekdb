### ddl
drop table tt3;
create table tt3 as select array_sort([0,1,1,1,1,1,null,true,false]) as a;
desc tt3;
+-------+---------------+------+-----+---------+-------+
| Field | Type          | Null | Key | Default | Extra |
+-------+---------------+------+-----+---------+-------+
| a     | ARRAY(BIGINT) | YES  |     | NULL    |       |
+-------+---------------+------+-----+---------+-------+
insert into tt3 values(array_sort([2343,3,3,4,2,7,5,5,4,0,null]));
replace into tt3 values(array_sort([2343,0,0,4,3,2,6,5,4,7,6,7,50]));
update tt3 set a=array_sort([2343,0,0,2,2,2,111,4]) limit 1;
select * from tt3;
+---------------------------------+
| a                               |
+---------------------------------+
| [0,0,2,2,2,4,111,2343]          |
| [0,2,3,3,4,4,5,5,7,2343,NULL]   |
| [0,0,2,3,4,4,5,6,6,7,7,50,2343] |
+---------------------------------+
truncate tt3;
delete from tt3;

drop table tt3;
create table tt3 (a int[] NOT NULL) ;
