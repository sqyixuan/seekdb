#list partition
DROP TABLE Z0CASE;
CREATE TABLE Z0CASE(z0_test0 varchar(10)  , z0_test1 char(10) ,z0_test2 smallint AS(z0_test0-z0_test1) ) 
partition by list (z0_test2)
(
partition part_1 values in ( 10,15),
partition part_2 values in ( 20,30),
partition part_default values in ( 50,100 )
);
