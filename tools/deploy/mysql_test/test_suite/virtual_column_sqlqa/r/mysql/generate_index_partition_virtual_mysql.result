partition
#range partition
DROP TABLE Z0CASE;
CREATE TABLE Z0CASE(z0_test0 float(10)  , z0_test1 int ,z0_test2 bigint AS(concat(z0_test0,z0_test1)) ) 
partition by range (z0_test2)
(
partition part_1 values less than (10),
partition part_2 values less than (20 ),
partition part_3 values less than ( maxvalue )
);
INSERT INTO  Z0CASE (z0_test0,z0_test1)values(1.111,222);
INSERT INTO  Z0CASE (z0_test0,z0_test1)values(1,9);
INSERT INTO  Z0CASE (z0_test0,z0_test1)values(0,0);
INSERT INTO  Z0CASE (z0_test0,z0_test1)values(10,10);
SELECT * FROM Z0CASE partition(part_1);
z0_test0	z0_test1	z0_test2
1.111	222	1
0	0	0
SELECT * FROM Z0CASE partition(part_2);
z0_test0	z0_test1	z0_test2
1	9	19
