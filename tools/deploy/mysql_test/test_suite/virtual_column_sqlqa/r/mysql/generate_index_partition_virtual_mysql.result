60	40	20
#subpartition
DROP TABLE Z0CASE;
create table Z0CASE
(z0_test0 int,z0_test1 date,z0_test2 int as (ceil(2*z0_test0)),z0_test3 date as (ADDDATE(z0_test1,7)))
partition by range(z0_test2)
subpartition by hash(year(z0_test3))
subpartitions 3
(partition p1 values less than (2000),
partition p2 values less than maxvalue);
