--disable_warnings
#创建数据库mysql_test
CREATE DATABASE IF NOT EXISTS mysql_test DEFAULT CHARSET utf8 COLLATE utf8_general_ci;
USE mysql_test;
--enable_warnings

--echo 表达式
--echo AUTO_INCREMENT

--disable_warnings
--error 0,1051
DROP TABLE Z0CASE;
--enable_warnings
--error 1235
CREATE TABLE Z0CASE(z0_test0 int AUTO_INCREMENT , z0_test1 char(100),z0_test2 varchar(100) AS (z0_test0 ) stored);

--echo 运算

--disable_warnings
--error 0,1051
DROP TABLE Z0CASE;
--enable_warnings


CREATE TABLE Z0CASE(z0_test0 char(100) , z0_test1 char(100),z0_test2 varchar(100) AS (z0_test0+z0_test1)stored,z0_test3 varchar(100) AS (z0_test0-z0_test1)stored);


INSERT INTO  Z0CASE (z0_test0,z0_test1)values(NULL,NULL);
INSERT INTO  Z0CASE (z0_test0,z0_test1)values(1.111,222);
select column_name,data_type from information_schema.columns  where table_name='Z0CASE' ORDER BY 1,2;
SELECT z0_test0 , z0_test1 ,z0_test2 FROM Z0CASE ORDER BY 1,2;

--disable_warnings
--error 0,1051
DROP TABLE Z0CASE;
--enable_warnings

CREATE TABLE Z0CASE(z0_test0 char(100) , z0_test1 char(100),z0_test2 varchar(100) AS (z0_test0+z0_test1)stored,z0_test3 varchar(100) AS (z0_test0||z0_test1)stored);

INSERT INTO  Z0CASE (z0_test0,z0_test1)values(NULL,NULL);
INSERT INTO  Z0CASE (z0_test0,z0_test1)values(1.111,222);
select column_name,data_type from information_schema.columns  where table_name='Z0CASE' ORDER BY 1,2;
SELECT z0_test0 , z0_test1 ,z0_test2 FROM Z0CASE ORDER BY 1,2;


--echo ASCII

--disable_warnings
--error 0,1051
DROP TABLE Z0CASE;
--enable_warnings

CREATE TABLE Z0CASE(z0_test0 varchar(100) , z0_test1 char(50),z0_test2 char(100) AS (ASCII(z0_test0))stored);

INSERT INTO  Z0CASE (z0_test0,z0_test1)values(NULL,NULL);
INSERT INTO  Z0CASE (z0_test0,z0_test1)values(1.111,222);
INSERT INTO  Z0CASE (z0_test0,z0_test1)values('ABCabc','ABCabc');
INSERT INTO  Z0CASE (z0_test0,z0_test1)values('2011-11-11 11:11:11','ABCabc');
select column_name,data_type from information_schema.columns  where table_name='Z0CASE' ORDER BY 1,2;
SELECT z0_test0 , z0_test1 ,z0_test2 FROM Z0CASE ORDER BY 1,2;

--echo CHAR_LENGTH

--disable_warnings
--error 0,1051
DROP TABLE Z0CASE;
--enable_warnings

CREATE TABLE Z0CASE(z0_test0 blob , z0_test1 char(100),z0_test2 varchar(100) AS (CHAR_LENGTH(z0_test0))stored);

INSERT INTO  Z0CASE (z0_test0,z0_test1)values(NULL,NULL);
INSERT INTO  Z0CASE (z0_test0,z0_test1)values(1.111,222);
INSERT INTO  Z0CASE (z0_test0,z0_test1)values('ABCabc','ABCabc');
INSERT INTO  Z0CASE (z0_test0,z0_test1)values('2011-11-11 11:11:11','2011-11-11 11:11:11');
select column_name,data_type from information_schema.columns  where table_name='Z0CASE' ORDER BY 1,2;
SELECT z0_test0 , z0_test1 ,z0_test2 FROM Z0CASE ORDER BY 1,2;


--echo CONCAT

--disable_warnings
--error 0,1051
DROP TABLE Z0CASE;
--enable_warnings

CREATE TABLE Z0CASE(z0_test0  char(100) , z0_test1 char(100),z0_test2 varchar(100) AS (CONCAT(z0_test0,z0_test1))stored);

INSERT INTO  Z0CASE (z0_test0,z0_test1)values(NULL,NULL);
INSERT INTO  Z0CASE (z0_test0,z0_test1)values(1.111,222);
INSERT INTO  Z0CASE (z0_test0,z0_test1)values('ABCabc','ABCabc');
INSERT INTO  Z0CASE (z0_test0,z0_test1)values('2011-11-11 11:11:11','2011-11-11 11:11:11');
select column_name,data_type from information_schema.columns  where table_name='Z0CASE' ORDER BY 1,2;
SELECT z0_test0 , z0_test1 ,z0_test2 FROM Z0CASE ORDER BY 1,2;


