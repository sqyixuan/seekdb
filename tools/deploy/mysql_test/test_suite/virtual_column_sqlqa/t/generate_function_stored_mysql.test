--disable_warnings
--error 0,1051
DROP TABLE Z0CASE;
--enable_warnings
CREATE TABLE Z0CASE(z0_test0  char(100) , z0_test1 char(100),z0_test2 varchar(100) AS (FIELD(z0_test0,z0_test1))stored);

INSERT INTO  Z0CASE (z0_test0,z0_test1)values(NULL,NULL);
INSERT INTO  Z0CASE (z0_test0,z0_test1)values(1.111,222);
INSERT INTO  Z0CASE (z0_test0,z0_test1)values('ABCabc','ABCabc');
INSERT INTO  Z0CASE (z0_test0,z0_test1)values('2011-11-11 11:11:11','2011-11-11 11:11:11');
select column_name,data_type from information_schema.columns  where table_name='Z0CASE' ORDER BY 1,2;
SELECT z0_test0 , z0_test1 ,z0_test2 FROM Z0CASE ORDER BY 1,2;

--echo FIND_IN_SET

--disable_warnings
--error 0,1051
DROP TABLE Z0CASE;
--enable_warnings

CREATE TABLE Z0CASE(z0_test0  char(100) , z0_test1 varchar(100),z0_test2 varchar(100) AS (FIND_IN_SET(z0_test0,z0_test1))stored);

INSERT INTO  Z0CASE (z0_test0,z0_test1)values(NULL,NULL);
INSERT INTO  Z0CASE (z0_test0,z0_test1)values(1.111,222);
INSERT INTO  Z0CASE (z0_test0,z0_test1)values('ABCabc','ABCabc');
INSERT INTO  Z0CASE (z0_test0,z0_test1)values('2011-11-11 11:11:11','2011-11-11 11:11:11');
select column_name,data_type from information_schema.columns  where table_name='Z0CASE' ORDER BY 1,2;
SELECT z0_test0 , z0_test1 ,z0_test2 FROM Z0CASE ORDER BY 1,2;


--echo FORMAT

--disable_warnings
--error 0,1051
DROP TABLE Z0CASE;
--enable_warnings
CREATE TABLE Z0CASE(z0_test0 date  , z0_test1 DOUBLE ,z0_test2 varchar(20)  AS (FORMAT(z0_test0,'2'))stored) ;
INSERT INTO  Z0CASE (z0_test0,z0_test1)values(NULL,NULL);
INSERT INTO  Z0CASE (z0_test0,z0_test1)values('2011-11-11 11:11:11','2');
INSERT INTO  Z0CASE (z0_test0,z0_test1)values('2011-11-11 ','3');

SELECT z0_test0 , z0_test1 ,z0_test2 FROM Z0CASE ORDER BY 1,2;

--echo CONCAT_WS

--disable_warnings
--error 0,1051
DROP TABLE Z0CASE;
--enable_warnings
CREATE TABLE Z0CASE(z0_test0 varchar(20)   , z0_test1 DOUBLE ,z0_test2 blob  AS (CONCAT_WS(',',z0_test0,null,z0_test1))stored) ;
INSERT INTO  Z0CASE (z0_test0,z0_test1)values(NULL,NULL);
INSERT INTO  Z0CASE (z0_test0,z0_test1)values(1.111,222);
INSERT INTO  Z0CASE (z0_test0,z0_test1)values('ABCabc','1');
INSERT INTO  Z0CASE (z0_test0,z0_test1)values('2011-11-11 11:11:11','2');
INSERT INTO  Z0CASE (z0_test0,z0_test1)values('2011-11-11 ','3');

select column_name,data_type from information_schema.columns  where table_name='Z0CASE' ORDER BY 1,2;
SELECT z0_test0 , z0_test1 ,z0_test2 FROM Z0CASE ORDER BY 1,2;


