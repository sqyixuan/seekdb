--disable_warnings
--error 0,1051
DROP TABLE Z0CASE;
--enable_warnings
CREATE TABLE Z0CASE(z0_test0 varchar(20)   , z0_test1 blob ,z0_test2 DOUBLE  AS (FIELD('a',z0_test0,z0_test1))stored) ;
