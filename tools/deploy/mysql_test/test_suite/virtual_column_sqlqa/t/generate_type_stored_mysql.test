--disable_warnings
#创建数据库mysql_test
CREATE DATABASE IF NOT EXISTS mysql_test DEFAULT CHARSET utf8 COLLATE utf8_general_ci;
USE mysql_test;
--enable_warnings


--echo 指定函数 
--echo char

--disable_warnings
--error 0,1051
DROP TABLE Z0CASE;
--enable_warnings
CREATE TABLE Z0CASE(z0_test0 char(100) , z0_test1 char(100),z0_test2  char  GENERATED ALWAYS AS (z0_test0+z0_test1) STORED);

--disable_warnings
--error 0,1051
DROP TABLE Z0CASE;
--enable_warnings
CREATE TABLE Z0CASE(z0_test0 char(100) , z0_test1 char(100),z0_test2  char(12)  GENERATED ALWAYS AS (z0_test0||z0_test1) STORED);

ALTER TABLE Z0CASE DROP COLUMN z0_test2;
ALTER TABLE Z0CASE add  z0_test2 char(120) GENERATED ALWAYS AS (concat(z0_test1,z0_test0)) STORED;

 
INSERT INTO  Z0CASE (z0_test0,z0_test1)values('abc ABC','abc%%^#AB C');
INSERT INTO  Z0CASE (z0_test0,z0_test1)values(NULL,NULL);
INSERT INTO  Z0CASE (z0_test0,z0_test1)values(111,222);
INSERT INTO  Z0CASE (z0_test0,z0_test1)values(' ',' ');
INSERT INTO  Z0CASE (z0_test0,z0_test1)values('2011-11-11','2011-11-11');
SELECT * FROM Z0CASE ORDER BY 1,2;

ALTER TABLE Z0CASE DROP COLUMN z0_test2;
--error 1111
ALTER TABLE Z0CASE add  z0_test2 char(120) GENERATED ALWAYS AS (MAX(z0_test1)) STORED;

--disable_warnings
--error 0,1051
DROP TABLE Z0CASE;
--enable_warnings
CREATE TABLE Z0CASE(z0_test0 char(100), z0_test1 char(20));

INSERT INTO  Z0CASE (z0_test0,z0_test1)values('abc ABC','abc%%^#AB C');
INSERT INTO  Z0CASE (z0_test0,z0_test1)values(NULL,NULL);
INSERT INTO  Z0CASE (z0_test0,z0_test1)values(111,222);
INSERT INTO  Z0CASE (z0_test0,z0_test1)values(' ',' ');
INSERT INTO  Z0CASE (z0_test0,z0_test1)values('2011-11-11','2011-11-11');

ALTER TABLE Z0CASE add  z0_test2 char(20) GENERATED ALWAYS AS (cast(z0_test1 as char)) STORED;

SELECT z0_test0,z0_test1,Z0_TEST2 FROM Z0CASE ORDER BY 1,2;
DELETE FROM Z0CASE WHERE 1=1;





--disable_warnings
--error 0,1051
DROP TABLE Z0CASE;
--enable_warnings
CREATE TABLE Z0CASE(z0_test0 char(100), z0_test1 char(20));
ALTER TABLE Z0CASE add  z0_test2 char(120) GENERATED ALWAYS AS (concat(z0_test1,z0_test0)) STORED;

INSERT INTO  Z0CASE (z0_test0,z0_test1)values('abc ABC','abc%%^#AB C');
INSERT INTO  Z0CASE (z0_test0,z0_test1)values(NULL,NULL);
INSERT INTO  Z0CASE (z0_test0,z0_test1)values(111,222);
INSERT INTO  Z0CASE (z0_test0,z0_test1)values(' ',' ');
INSERT INTO  Z0CASE (z0_test0,z0_test1)values('2011-11-11','2011-11-11');

SELECT * FROM  Z0CASE WHERE z0_test2 LIKE '%A%';
SELECT z0_test2 FROM Z0CASE GROUP BY z0_test2 HAVING LENGTH(z0_test2)>3;
--error 3105
UPDATE Z0CASE SET z0_test2='' WHERE 1=1;
UPDATE Z0CASE SET z0_test1='!@#$%中俄字符' WHERE LENGTH(z0_test2)>3 ;


--disable_warnings
--error 0,1051
DROP TABLE Z0CASE;
--enable_warnings
CREATE TABLE Z0CASE(z0_test0 char(50), z0_test1 char(50),z0_test2 char(100)  GENERATED ALWAYS AS (z0_test0+z0_test1) STORED);
INSERT INTO  Z0CASE (z0_test0,z0_test1)values('111.111','2222.222');



--echo char->char

--disable_warnings
--error 0,1051
DROP TABLE Z0CASE;
