--disable_warnings
#创建数据库mysql_test
CREATE DATABASE IF NOT EXISTS mysql_test DEFAULT CHARSET utf8 COLLATE utf8_general_ci;
USE mysql_test;
--enable_warnings



--echo index
--echo 单行索引

--disable_warnings
--error 0,1051
DROP TABLE Z0CASE;
--enable_warnings

CREATE TABLE Z0CASE(z0_test0 char(100)  , z0_test1 varchar(100) ,z0_test2 char(100) AS( concat(z0_test0,z0_test1)) ) ;
create index z_index on Z0CASE(z0_test2);

INSERT INTO  Z0CASE (z0_test0,z0_test1)values(NULL,NULL);
INSERT INTO  Z0CASE (z0_test0,z0_test1)values(1.111,222);
INSERT INTO  Z0CASE (z0_test0,z0_test1)values('01-02','ABCabc');
INSERT INTO  Z0CASE (z0_test0,z0_test1)values('2011-11-11 11:11:11','ABCabc');
INSERT INTO  Z0CASE (z0_test0,z0_test1)values('2011-11-11 ','ABCabc');
select column_name,data_type from information_schema.columns  where table_name='Z0CASE' ORDER BY 1,2;
SELECT z0_test0 , z0_test1 ,z0_test2 FROM Z0CASE ORDER BY 1,2;



--echo 联合索引

--disable_warnings
--error 0,1051
DROP TABLE Z0CASE;
--enable_warnings

CREATE TABLE Z0CASE(z0_test0 char(100)  , z0_test1 varchar(100) ,z0_test2 char(100) AS( LENGTH(z0_test0)) ,z0_test3 double AS( LENGTH(z0_test0))) ;
create index z_index on Z0CASE(z0_test2,z0_test3);

INSERT INTO  Z0CASE (z0_test0,z0_test1)values(NULL,NULL);
INSERT INTO  Z0CASE (z0_test0,z0_test1)values(1.111,222);
INSERT INTO  Z0CASE (z0_test0,z0_test1)values('01-02','ABCabc');
INSERT INTO  Z0CASE (z0_test0,z0_test1)values('2011-11-11 11:11:11','ABCabc');
INSERT INTO  Z0CASE (z0_test0,z0_test1)values('2011-11-11 ','ABCabc');
select column_name,data_type from information_schema.columns  where table_name='Z0CASE' ORDER BY 1,2;
SELECT z0_test0 , z0_test1 ,z0_test2 FROM Z0CASE ORDER BY 1,2;

--echo 唯一索引

--disable_warnings
--error 0,1051
DROP TABLE Z0CASE;
--enable_warnings


CREATE TABLE Z0CASE(z0_test0 char(100)  , z0_test1 varchar(100) ,z0_test2 char(100) AS( concat(z0_test0,z0_test1)) ,z0_test3 text AS( LENGTH(z0_test0))) ;

CREATE UNIQUE INDEX z_index ON Z0CASE(z0_test2);

INSERT INTO  Z0CASE (z0_test0,z0_test1)values(NULL,NULL);
INSERT INTO  Z0CASE (z0_test0,z0_test1)values(1.111,222);
INSERT INTO  Z0CASE (z0_test0,z0_test1)values('01-02','ABCabc');
INSERT INTO  Z0CASE (z0_test0,z0_test1)values('2011-11-11 11:11:11','ABCabc');
INSERT INTO  Z0CASE (z0_test0,z0_test1)values('2011-11-11 ','ABCabc');
select column_name,data_type from information_schema.columns  where table_name='Z0CASE' ORDER BY 1,2;
SELECT z0_test0 , z0_test1 ,z0_test2 FROM Z0CASE ORDER BY 1,2;


--echo 二级索引


--disable_warnings
--error 0,1051
DROP TABLE Z0CASE;
--enable_warnings

CREATE TABLE Z0CASE(z0_test0 int(20) PRIMARY key , z0_test1 float(10) ,z0_test2  DECIMAL(10,2) as (z0_test0+z0_test1)) ;
INSERT INTO  Z0CASE (z0_test0,z0_test1)values(1.111,222);
INSERT INTO  Z0CASE (z0_test0,z0_test1)values(111,222);
INSERT INTO  Z0CASE (z0_test0,z0_test1)values(0000,111.1111);

ALTER TABLE Z0CASE ADD INDEX index_test2(z0_test2);
select * from Z0CASE;


--echo  partition


--echo  #range partition
--disable_warnings
--error 0,1051
DROP TABLE Z0CASE;
--enable_warnings
CREATE TABLE Z0CASE(z0_test0 float(10)  , z0_test1 int ,z0_test2 bigint AS(concat(z0_test0,z0_test1)) ) 
partition by range (z0_test2)
(
  partition part_1 values less than (10),
  partition part_2 values less than (20 ),
  partition part_3 values less than ( maxvalue )
);

INSERT INTO  Z0CASE (z0_test0,z0_test1)values(1.111,222);
INSERT INTO  Z0CASE (z0_test0,z0_test1)values(1,9);
INSERT INTO  Z0CASE (z0_test0,z0_test1)values(0,0);
INSERT INTO  Z0CASE (z0_test0,z0_test1)values(10,10);


SELECT * FROM Z0CASE partition(part_1);
SELECT * FROM Z0CASE partition(part_2);



--echo  #hash partition
--disable_warnings
--error 0,1051
DROP TABLE Z0CASE;
--enable_warnings

CREATE TABLE Z0CASE(z0_test0 varchar(50)  , z0_test1 varchar(50) ,z0_test2 int AS((z0_test0+z0_test1)) ) 
partition by hash (abs(z0_test2))
PARTITIONS 3;

INSERT INTO  Z0CASE (z0_test0,z0_test1)values(NULL,NULL);
INSERT INTO  Z0CASE (z0_test0,z0_test1)values(1.111,222);
INSERT INTO  Z0CASE (z0_test0,z0_test1)values(0000,'0000');
INSERT INTO  Z0CASE (z0_test0,z0_test1)values('12312321','4123123');
INSERT INTO  Z0CASE (z0_test0,z0_test1)values('-123213 ','123');


SELECT z0_test0 , z0_test1 ,z0_test2 FROM Z0CASE ORDER BY 1,2;


--echo  #list partition
--disable_warnings
--error 0,1051
DROP TABLE Z0CASE;
--enable_warnings


CREATE TABLE Z0CASE(z0_test0 varchar(10)  , z0_test1 char(10) ,z0_test2 smallint AS(z0_test0-z0_test1) ) 
partition by list (z0_test2)
(
  partition part_1 values in ( 10,15),
  partition part_2 values in ( 20,30),
  partition part_default values in ( 50,100 )
);

INSERT INTO  Z0CASE (z0_test0,z0_test1)values('100','0.00001');
INSERT INTO  Z0CASE (z0_test0,z0_test1)values('60','40');

SELECT * FROM Z0CASE partition(part_1);
SELECT * FROM Z0CASE partition(part_2);

SELECT * FROM Z0CASE partition(part_default);

SELECT z0_test0 , z0_test1 ,z0_test2 FROM Z0CASE ORDER BY 1,2;

--echo  #subpartition

--disable_warnings
--error 0,1051
DROP TABLE Z0CASE;
--enable_warnings

create table Z0CASE
(z0_test0 int,z0_test1 date,z0_test2 int as (ceil(2*z0_test0)),z0_test3 date as (ADDDATE(z0_test1,7)))
partition by range(z0_test2)
subpartition by hash(year(z0_test3))
subpartitions 3
(partition p1 values less than (2000),
partition p2 values less than maxvalue);

INSERT INTO  Z0CASE (z0_test0,z0_test1)values(NULL,NULL);
INSERT INTO  Z0CASE (z0_test0,z0_test1)values(1.111,222);
INSERT INTO  Z0CASE (z0_test0,z0_test1)values('123','2020-11-11 11:11:11');
INSERT INTO  Z0CASE (z0_test0,z0_test1)values('000','2011-11-11 11:11:11');
INSERT INTO  Z0CASE (z0_test0,z0_test1)values(' 12321312','2011-11-11');
select column_name,data_type from information_schema.columns  where table_name='Z0CASE' ORDER BY 1,2;
SELECT z0_test0 , z0_test1 ,z0_test2 FROM Z0CASE ORDER BY 1,2;

--echo  view 

--disable_warnings
--error 0,1051
DROP TABLE Z0CASE;
--enable_warnings
CREATE TABLE Z0CASE(z0_test0 char(100)  , z0_test1 varchar(100) ,z0_test2 blob AS(upper(UCASE(z0_test1))) ,z0_test3 char(100)AS(concat(z0_test0,z0_test1))) ;

INSERT INTO  Z0CASE (z0_test0,z0_test1)values(NULL,NULL);
INSERT INTO  Z0CASE (z0_test0,z0_test1)values(1.111,222);
INSERT INTO  Z0CASE (z0_test0,z0_test1)values('01-02','ABCabc');
INSERT INTO  Z0CASE (z0_test0,z0_test1)values('2011-11-11 11:11:11','ABCabc');
INSERT INTO  Z0CASE (z0_test0,z0_test1)values('2011-11-11 ','ABCabc');
select column_name,data_type from information_schema.columns  where table_name='Z0CASE' ORDER BY 1,2;
SELECT z0_test0 , z0_test1 ,z0_test2 FROM Z0CASE ORDER BY 1,2;


create or replace view view1 as SELECT z0_test2 ,z0_test3 FROM Z0CASE WHERE LENGTH(z0_test2)>1;
SELECT * FROM view1;


DROP view view1;

create view view1 as SELECT z0_test0, z0_test2 ,z0_test3 FROM Z0CASE WHERE LENGTH(z0_test2)>1;
SELECT * FROM view1;
INSERT INTO view1 (z0_test0)VALUES ('abcABC');
--error 3105
INSERT INTO view1 VALUES (1,2,3);
--error 3105
UPDATE  view1 SET z0_test2=0 WHERE 1=1;

PURGE RECYCLEBIN;