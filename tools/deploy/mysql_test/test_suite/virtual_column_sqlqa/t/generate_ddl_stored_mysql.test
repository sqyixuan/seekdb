--ERROR 3108
ALTER TABLE Z0CASE  DROP  z0_test1 ;
--ERROR 3106
ALTER TABLE Z0CASE  ADD  z0_test3 INT AS (z0_test2);
--ERROR 1235,3106
ALTER TABLE Z0CASE MODIFY z0_test2 int(10);

ALTER TABLE Z0CASE MODIFY z0_test0 int;
--ERROR 1235,3106
ALTER TABLE Z0CASE CHANGE z0_test2 z0_test3 BIGINT as(z0_test0);

alter table Z0CASE change z0_test2 times_score_new  DECIMAL(10,2) as (z0_test0+z0_test1) stored;
alter table Z0CASE change times_score_new z0_test2 DECIMAL(10,2) as (z0_test0+z0_test1) stored;

--ERROR 1235,3106
ALTER TABLE Z0CASE MODIFY z0_test2 BIGINT NOT NULL DEFAULT 100;

--ERROR 1235,3106
ALTER TABLE Z0CASE ALTER z0_test2 SET DEFAULT 1000;

--error 0,1051
DROP TABLE Z0CASE1;
