--disable_warnings
#创建数据库mysql_test
CREATE DATABASE IF NOT EXISTS mysql_test DEFAULT CHARSET utf8 COLLATE utf8_general_ci;
USE mysql_test;
--enable_warnings

--disable_warnings
--error 0,1051
DROP TABLE Z0CASE;
--enable_warnings
CREATE TABLE Z0CASE(z0_test0 char(100)  , z0_test1 varchar(100) ,z0_test2 char(100) AS(z0_test0)stored) ;
INSERT INTO  Z0CASE (z0_test0,z0_test1)values(NULL,NULL);
INSERT INTO  Z0CASE (z0_test0,z0_test1)values(1.111,222);
INSERT INTO  Z0CASE (z0_test0,z0_test1)values('01-02','ABCabc');
INSERT INTO  Z0CASE (z0_test0,z0_test1)values('2011-11-11 11:11:11','ABCabc');
INSERT INTO  Z0CASE (z0_test0,z0_test1)values('2011-11-11 ','ABCabc');
select column_name,data_type from information_schema.columns  where table_name='Z0CASE' ORDER BY 1,2;
SELECT z0_test0 , z0_test1 ,z0_test2 FROM Z0CASE ORDER BY 1,2;


--disable_warnings
--error 0,1051
DROP TABLE Z0CASE;
--enable_warnings
CREATE TABLE Z0CASE(z0_test0 char(50) , z0_test1 varchar(100) ) ;
ALTER TABLE Z0CASE ADD z0_test2 int  AS('')stored;

--disable_warnings
--error 0,1051
DROP TABLE Z0CASE;
--enable_warnings
CREATE TABLE Z0CASE(z0_test2 dateTime AS(''),z0_test3 int AS ('')stored) ;


--echo  定义为 null

--disable_warnings
--error 0,1051
DROP TABLE Z0CASE;
--enable_warnings

CREATE TABLE Z0CASE(z0_test0 char(100)  , z0_test1 varchar(100) ,z0_test2 char(100)AS(null)stored,z0_test3 char(100) AS(null)stored) ;



--disable_warnings
--error 0,1051
DROP TABLE Z0CASE;
--enable_warnings
CREATE TABLE Z0CASE(z0_test0 char(50) , z0_test1 varchar(100) ) ;

ALTER TABLE Z0CASE ADD z0_test3 int as(z0_test0||z0_test1)stored;
INSERT INTO  Z0CASE (z0_test0,z0_test1)values(1.111,222);
SELECT z0_test0 , z0_test1 ,z0_test3 FROM Z0CASE;



--disable_warnings
--error 0,1051
DROP TABLE Z0CASE;
--enable_warnings
CREATE TABLE Z0CASE(z0_test0 char(100)  , z0_test1 varchar(100) ,z0_test2 char(100) AS(null) stored not null) ;




--disable_warnings
--error 0,1051
DROP TABLE Z0CASE;
--enable_warnings
CREATE TABLE Z0CASE(z0_test0 char(100)  , z0_test1 varchar(100) ,z0_test2 char(100) AS(null)stored  not null) ;
--error 1048
INSERT INTO  Z0CASE (z0_test0,z0_test1)values(NULL,NULL);
--error 1048
INSERT INTO  Z0CASE (z0_test0,z0_test1)values(1.111,222);

--echo 引用虚拟列
--disable_warnings
--error 0,1051
DROP TABLE Z0CASE;
--enable_warnings
--error 3106
CREATE TABLE Z0CASE(z0_test0 char(100) , z0_test1 varchar(100) ,z0_test2  char(100)AS(z0_test0+z0_test1)stored,z0_test3 char(100) AS(upper(z0_test2))stored) ;

CREATE TABLE Z0CASE(z0_test0 char(100) , z0_test1 varchar(100) ,z0_test2 char(100) AS(z0_test0+z0_test1)stored) ;
--error 3106
ALTER TABLE Z0CASE ADD z0_test3 date AS(upper(z0_test2))stored;
--disable_warnings
--error 0,1051
DROP TABLE Z0CASE;
--enable_warnings
--error 3106
CREATE TABLE Z0CASE(z0_test0 char(100) , z0_test1 varchar(100) ,z0_test2 char(100) AS(z0_test2 )stored) ;

CREATE TABLE Z0CASE(z0_test0 char(100) , z0_test1 varchar(100) ,z0_test2 char(100) AS(z0_test3 )stored,z0_test3 char(100) AS(z0_test0 )stored) ;

