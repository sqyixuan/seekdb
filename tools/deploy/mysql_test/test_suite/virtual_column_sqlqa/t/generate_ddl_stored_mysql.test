select * from Z0CASE ORDER BY 1;

--echo create like
--disable_warnings
--error 0,1051
DROP TABLE Z0CASE;
--enable_warnings

CREATE TABLE Z0CASE(z0_test0 char(50) , z0_test1 varchar(100) ,z0_test2  blob as (z0_test0)stored) ;

INSERT INTO  Z0CASE (z0_test0,z0_test1)values(NULL,NULL);
INSERT INTO  Z0CASE (z0_test0,z0_test1)values(1.111,222);
INSERT INTO  Z0CASE (z0_test0,z0_test1)values('01-02','ABCabc');
INSERT INTO  Z0CASE (z0_test0,z0_test1)values('2011-11-11 11:11:11','ABCabc');
INSERT INTO  Z0CASE (z0_test0,z0_test1)values('2011-11-11 ','ABCabc');

--error 0,1051
DROP TABLE Z1CASE;
create table Z1CASE like Z0CASE;

select * from Z0CASE ORDER BY 1;

INSERT INTO  Z1CASE (z0_test0,z0_test1)values(NULL,NULL);
INSERT INTO  Z1CASE (z0_test0,z0_test1)values(1.111,222);
INSERT INTO  Z1CASE (z0_test0,z0_test1)values('01-02','ABCabc');
INSERT INTO  Z1CASE (z0_test0,z0_test1)values('2011-11-11 11:11:11','ABCabc');
INSERT INTO  Z1CASE (z0_test0,z0_test1)values('2011-11-11 ','ABCabc');
select * from Z1CASE;



--echo create as
--disable_warnings
--error 0,1051
DROP TABLE Z0CASE;
--enable_warnings

CREATE TABLE Z0CASE(z0_test0 char(50) , z0_test1 varchar(100) ,z0_test2  blob as (z0_test0)stored) ;

INSERT INTO  Z0CASE (z0_test0,z0_test1)values(NULL,NULL);
INSERT INTO  Z0CASE (z0_test0,z0_test1)values(1.111,222);
INSERT INTO  Z0CASE (z0_test0,z0_test1)values('01-02','ABCabc');
INSERT INTO  Z0CASE (z0_test0,z0_test1)values('2011-11-11 11:11:11','ABCabc');
