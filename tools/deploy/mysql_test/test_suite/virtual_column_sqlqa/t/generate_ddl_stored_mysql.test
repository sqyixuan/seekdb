INSERT INTO  Z1CASE (z0_test0,z0_test1)values('01-02','ABCabc');
INSERT INTO  Z1CASE (z0_test0,z0_test1)values('2011-11-11 11:11:11','ABCabc');
INSERT INTO  Z1CASE (z0_test0,z0_test1)values('2011-11-11 ','ABCabc');
select * from Z1CASE;

--echo 精度

--disable_warnings
--error 0,1051
DROP TABLE Z0CASE;
--enable_warnings

CREATE TABLE Z0CASE(z0_test0 int(20) , z0_test1 float(10) ,z0_test2  int(2) as (z0_test0+z0_test1)stored) ;
INSERT INTO  Z0CASE (z0_test0,z0_test1)values(NULL,NULL);
INSERT INTO  Z0CASE (z0_test0,z0_test1)values(1.111,222);
INSERT INTO  Z0CASE (z0_test0,z0_test1)values(111,222);
INSERT INTO  Z0CASE (z0_test0,z0_test1)values(0000,111.1111);
select * from Z0CASE ORDER BY 1;




--disable_warnings
--error 0,1051
DROP TABLE Z0CASE;
--enable_warnings

CREATE TABLE Z0CASE(z0_test0 int(20) , z0_test1 float(10) ,z0_test2  DECIMAL(10,2) as (z0_test0+z0_test1)stored) ;
INSERT INTO  Z0CASE (z0_test0,z0_test1)values(NULL,NULL);
INSERT INTO  Z0CASE (z0_test0,z0_test1)values(1.111,222);
INSERT INTO  Z0CASE (z0_test0,z0_test1)values(111,222);
INSERT INTO  Z0CASE (z0_test0,z0_test1)values(0000,111.1111);
select * from Z0CASE ORDER BY 1;



--ECHO  ALTER
--disable_warnings
--error 0,1051
DROP TABLE Z0CASE;
--enable_warnings

CREATE TABLE Z0CASE(z0_test0 int(20) , z0_test1 float(10) ,z0_test2  DECIMAL(10,2) as (z0_test0+z0_test1)stored) ;
INSERT INTO  Z0CASE (z0_test0,z0_test1)values(NULL,NULL);
INSERT INTO  Z0CASE (z0_test0,z0_test1)values(1.111,222);
INSERT INTO  Z0CASE (z0_test0,z0_test1)values(111,222);
INSERT INTO  Z0CASE (z0_test0,z0_test1)values(0000,111.1111);
select * from Z0CASE ORDER BY 1;
ALTER TABLE Z0CASE  DROP  z0_test2 ;


--disable_warnings
--error 0,1051
DROP TABLE Z0CASE;
--enable_warnings

CREATE TABLE Z0CASE(z0_test0 int(20) , z0_test1 float(10) ,z0_test2  DECIMAL(10,2) as (z0_test0+z0_test1)stored) ;
INSERT INTO  Z0CASE (z0_test0,z0_test1)values(NULL,NULL);
INSERT INTO  Z0CASE (z0_test0,z0_test1)values(1.111,222);
INSERT INTO  Z0CASE (z0_test0,z0_test1)values(111,222);
INSERT INTO  Z0CASE (z0_test0,z0_test1)values(0000,111.1111);
