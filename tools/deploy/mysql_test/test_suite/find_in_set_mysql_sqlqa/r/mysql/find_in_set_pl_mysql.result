#循环语句
DROP FUNCTION f_FIND_IN_SET;//
CREATE FUNCTION f_FIND_IN_SET(invalue varchar(200)) returns varchar(200) DETERMINISTIC
begin
declare a varchar(200);
declare i int default 27;
SELECT FIND_IN_SET(invalue,invalue) into a FROM dual;
WHILE i <= 28 do
INSERT INTO FIND_IN_SET_table VALUES(i,'FUNCTION-While循环','字符比较',FIND_IN_SET('abc','efg'));
set i := i+1;
END WHILE;
loop_name:LOOP
INSERT INTO FIND_IN_SET_table VALUES(i,'FUNCTION-Loop循环','数字比较',FIND_IN_SET(i+1,i));
SET i := i+1;
IF i > 30 THEN 
LEAVE loop_name;
END IF;
END LOOP loop_name;
REPEAT
INSERT INTO FIND_IN_SET_table VALUES(i,'FUNCTION-Repeat循环','特殊符号比较',FIND_IN_SET('$%^','*&%'));
SET i := i+1;
until i > 32	
END REPEAT;
return a;
END;
//
SELECT f_FIND_IN_SET(FIND_IN_SET('FIND_IN_SET','substring'));
f_FIND_IN_SET(FIND_IN_SET('FIND_IN_SET','substring'))
