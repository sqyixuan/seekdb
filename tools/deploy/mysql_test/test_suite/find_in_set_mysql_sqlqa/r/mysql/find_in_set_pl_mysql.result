#循环语句
DROP PROCEDURE pro_FIND_IN_SET;//
CREATE PROCEDURE pro_FIND_IN_SET()
begin
declare i int default 13;
WHILE i <= 15 do
INSERT INTO FIND_IN_SET_table VALUES(i,'PROCEDURE-While循环','FIND_IN_SET(i,15)',FIND_IN_SET(i,15));
set i := i+1;
END WHILE;
loop_name:LOOP
INSERT INTO FIND_IN_SET_table VALUES(i,'PROCEDURE-Loop循环','FIND_IN_SET(i,17)',FIND_IN_SET(i,17));
SET i := i+1;
IF i > 17 THEN 
LEAVE loop_name;
END IF;
END LOOP loop_name;
REPEAT
INSERT INTO FIND_IN_SET_table VALUES(i,'PROCEDURE-Repeat循环','FIND_IN_SET(i,19)',FIND_IN_SET(i,19));
SET i := i+1;
until i > 19	
END REPEAT;
END;
//
CALL pro_FIND_IN_SET();
SELECT * FROM FIND_IN_SET_table ORDER BY 1;
