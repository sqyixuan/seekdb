1	MYSQL	mysql	1
2	oceanbase	oceanbase mysql	0
3	i=	3	0
4	i=	4	0
5	invalue=	10	1
5	invalue=	0	0
6	invalue=	10	1
6	invalue=	0	0
##包含out参数的存储过程
DROP PROCEDURE pro_FIND_IN_SET;//
CREATE  PROCEDURE pro_FIND_IN_SET(out outa varchar(200))
begin
declare i int default 7;
SELECT count(FIND_IN_SET(c1,c2)) into outa FROM FIND_IN_SET_table WHERE FIND_IN_SET(c1,'oceanbase') like '%0%';
WHILE i <= 8 do
INSERT INTO FIND_IN_SET_table VALUES(i,'i=',i,FIND_IN_SET(i,10));
SET i := i + 1;
END WHILE;
END;
//
CALL pro_FIND_IN_SET(@outa);
SELECT * FROM FIND_IN_SET_table ORDER BY 1;
id	c1	c2	c3
1	MYSQL	mysql	1
2	oceanbase	oceanbase mysql	0
3	i=	3	0
4	i=	4	0
5	invalue=	10	1
5	invalue=	0	0
6	invalue=	10	1
6	invalue=	0	0
7	i=	7	0
8	i=	8	0
SELECT @outa;
@outa
7
##包含inout参数的存储过程
DROP PROCEDURE pro_FIND_IN_SET;//
CREATE  PROCEDURE pro_FIND_IN_SET(INOUT inouta varchar(200))
begin
declare invalue varchar(200);
declare i int default 9;
set invalue := inouta;
SELECT FIND_IN_SET(c1,c2) into inouta FROM FIND_IN_SET_table WHERE FIND_IN_SET(c1,c2) = invalue limit 1;
WHILE i <= 10 do
INSERT INTO FIND_IN_SET_table VALUES(i,'i=',i,FIND_IN_SET(i,10));
set i := i+1;
END WHILE;
END;
//
SET @inouta=FIND_IN_SET('FIND_IN_SET','FIND_IN_SET()');
CALL pro_FIND_IN_SET(@inouta);
