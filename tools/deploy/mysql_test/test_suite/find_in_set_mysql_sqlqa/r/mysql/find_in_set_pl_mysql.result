##游标
DROP PROCEDURE pro_FIND_IN_SET;//
CREATE PROCEDURE pro_FIND_IN_SET()
BEGIN
DECLARE a varchar(200);
DECLARE b varchar(200);
DECLARE done INT DEFAULT 0;
DECLARE FIND_IN_SET_cursor CURSOR FOR SELECT id,FIND_IN_SET(c1,c2) FROM FIND_IN_SET_table;
DECLARE CONTINUE HANDLER FOR SQLSTATE '02000' SET done=1;
OPEN FIND_IN_SET_cursor;
FETCH FIND_IN_SET_cursor INTO a,b;
WHILE done<>1 DO
INSERT INTO FIND_IN_SET_table VALUES(a,'id','FIND_IN_SET(c1,c2)=',b);
FETCH FIND_IN_SET_cursor INTO a,b;
END WHILE;
CLOSE FIND_IN_SET_cursor;
END;
//
