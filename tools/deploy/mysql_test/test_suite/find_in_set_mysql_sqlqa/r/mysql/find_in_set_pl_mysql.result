### 标签：FIND_IN_SET-3-2 函数      
#定义一个无参的函数
DROP FUNCTION f_FIND_IN_SET;//
CREATE FUNCTION f_FIND_IN_SET() returns varchar(200) READS SQL DATA 
begin
declare a varchar(200);
SELECT FIND_IN_SET('function','function compare') into a FROM dual;
return a;
END;
//
SELECT  f_FIND_IN_SET();
f_FIND_IN_SET()
0
#定义一个有参的函数
DROP FUNCTION f_FIND_IN_SET;//
CREATE FUNCTION f_FIND_IN_SET(invalue varchar(200)) returns  varchar(200) READS SQL DATA 
begin
declare a varchar(200);
SELECT FIND_IN_SET(1,invalue) into a FROM dual;
return a;
END ;
//
SELECT f_FIND_IN_SET(FIND_IN_SET('function','in'));
f_FIND_IN_SET(FIND_IN_SET('function','in'))
0
##dml语句
#条件语句
DROP FUNCTION f_FIND_IN_SET;//
CREATE FUNCTION f_FIND_IN_SET(invalue varchar(200),ina varchar(200),inb varchar(200))returns varchar(200) DETERMINISTIC
begin
IF invalue = 0 THEN 
INSERT INTO FIND_IN_SET_table VALUES(25,'FUNCTION-If条件','invalue=0',FIND_IN_SET(invalue,inb));
ELSE 
INSERT INTO FIND_IN_SET_table VALUES(26,'FUNCTION-If条件','invalue!=0',FIND_IN_SET(invalue,ina));
END IF;
return FIND_IN_SET(ina,inb);
END;
//
SET @invalue := FIND_IN_SET('in','inout');
SET @ina := 'ina';
SET @inb := 'inb';
SELECT f_FIND_IN_SET(@invalue,@ina,@inb);
f_FIND_IN_SET(@invalue,@ina,@inb)
0
