DROP PROCEDURE pro_FIND_IN_SET;//
CREATE PROCEDURE pro_FIND_IN_SET(IN invalue varchar(200),IN ina varchar(200),IN inb varchar(200))
begin
IF invalue = FIND_IN_SET('B','b') THEN 
INSERT INTO FIND_IN_SET_table VALUES(11,'PROCEDURE-If条件','dml语句',FIND_IN_SET(ina,inb));
ELSE 
INSERT INTO FIND_IN_SET_table VALUES(12,ina,inb,FIND_IN_SET(ina,inb));
END IF;
END;
//
SET @invalue := FIND_IN_SET('A','a');
SET @ina := '1';
SET @inb := '2';
CALL pro_FIND_IN_SET(@invalue,@ina,@inb);
