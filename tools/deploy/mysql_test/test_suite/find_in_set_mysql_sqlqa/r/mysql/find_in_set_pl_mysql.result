##动态sql
DROP PROCEDURE pro_FIND_IN_SET;//
CREATE PROCEDURE pro_FIND_IN_SET()
BEGIN
SET @s = 'INSERT INTO FIND_IN_SET_table VALUES(?,"动态sql插入的数据","abc123 abc1234",?);';
PREPARE stmFIND_IN_SET_table FROM @s;
SET @a = 20;
SET @b = FIND_IN_SET('abc123','abc1234');
EXECUTE stmFIND_IN_SET_table USING @a,@b;
SET @s = 'SELECT * FROM FIND_IN_SET_table WHERE id = 20';
PREPARE stmt2 FROM @s;
EXECUTE stmt2; 
END;
//
CALL pro_FIND_IN_SET();
id	c1	c2	c3
20	动态sql插入的数据	abc123 abc1234	0
DROP PROCEDURE pro_FIND_IN_SET;//
CREATE PROCEDURE pro_FIND_IN_SET()
BEGIN
SET @s = 'update FIND_IN_SET_table set c1 = ?,c2 = ?,c3 = ? WHERE id = 20;';
PREPARE stmFIND_IN_SET_table FROM @s;
SET @a = '动态sql更新的数据';
SET @b = 'mysql Mysql';
SET @c = FIND_IN_SET('mysql','Mysql');
EXECUTE stmFIND_IN_SET_table USING @a,@b,@c;
SET @s = 'SELECT * FROM FIND_IN_SET_table WHERE id = 20';
PREPARE stmt2 FROM @s;
EXECUTE stmt2; 
SET @s = 'delete FROM FIND_IN_SET_table WHERE c2 = ?;';
PREPARE stmFIND_IN_SET_table FROM @s;
SET @a = 'mysql Mysql';
EXECUTE stmFIND_IN_SET_table USING @a;
SET @s = 'SELECT * FROM FIND_IN_SET_table WHERE id = 20';
PREPARE stmt2 FROM @s;
EXECUTE stmt2; 
END;
//
CALL pro_FIND_IN_SET();
id	c1	c2	c3
id	c1	c2	c3
20	动态sql更新的数据	mysql Mysql	1
