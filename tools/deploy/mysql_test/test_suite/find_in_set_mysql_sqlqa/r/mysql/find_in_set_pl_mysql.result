######################## 标签：FIND_IN_SET-4 PL/SQL场景  ########################
DROP TABLE FIND_IN_SET_table;
CREATE TABLE FIND_IN_SET_table(
id int,
c1 varchar(200),
c2 varchar(200),
c3 varchar(200))
PARTITION BY RANGE COLUMNS(id) (   
PARTITION p0 VALUES LESS THAN (5),    
PARTITION p1 VALUES LESS THAN (10),     
PARTITION p2 VALUES LESS THAN MAXVALUE );
INSERT INTO FIND_IN_SET_table VALUES(1,'MYSQL','mysql',NULL);
INSERT INTO FIND_IN_SET_table VALUES(2,'oceanbase','oceanbase mysql',NULL);
######## FIND_IN_SET-4-1  存储过程
###### 参数
### 无参数的存储过程
DROP PROCEDURE pro_FIND_IN_SET;//
CREATE PROCEDURE pro_FIND_IN_SET()
begin
declare var varchar(200);
declare i int default 3;
SELECT FIND_IN_SET(c1,c2) into var FROM FIND_IN_SET_table WHERE FIND_IN_SET(c1,c2) is not null and id = 1;
UPDATE FIND_IN_SET_table SET c3 = var WHERE id = 1;
WHILE i <= 4 do
INSERT INTO FIND_IN_SET_table VALUES(i,'i=',i,FIND_IN_SET(i,10));
SET i := i + 1;
END while;
END;
//
CALL pro_FIND_IN_SET();
SELECT * FROM FIND_IN_SET_table ORDER BY 1;
id	c1	c2	c3
1	MYSQL	mysql	1
2	oceanbase	oceanbase mysql	NULL
3	i=	3	0
4	i=	4	0
##只有一个in参数的存储过程
DROP PROCEDURE pro_FIND_IN_SET;//
CREATE PROCEDURE pro_FIND_IN_SET(in invalue varchar(200))
begin
declare var varchar(200);
declare i int default 5;
SELECT FIND_IN_SET(c1,c2) into var FROM FIND_IN_SET_table WHERE FIND_IN_SET(c1,c2) is not null and id = 2;
UPDATE FIND_IN_SET_table SET c3 = var WHERE id = 2;
WHILE i <= 6 do
INSERT INTO FIND_IN_SET_table VALUES(i,'invalue=',invalue,FIND_IN_SET(invalue,10));
SET i := i + 1;
END while;
END;
//
CALL pro_FIND_IN_SET(10);
SELECT * FROM FIND_IN_SET_table ORDER BY 1;
id	c1	c2	c3
1	MYSQL	mysql	1
2	oceanbase	oceanbase mysql	0
3	i=	3	0
4	i=	4	0
5	invalue=	10	1
6	invalue=	10	1
CALL pro_FIND_IN_SET(FIND_IN_SET('mysql','oracle'));
SELECT * FROM FIND_IN_SET_table ORDER BY 1;
