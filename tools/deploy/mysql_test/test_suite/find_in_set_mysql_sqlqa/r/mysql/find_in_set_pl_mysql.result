### 标签：FIND_IN_SET-3-3 触发器
DROP TABLE t1;
CREATE TABLE t1(id int,c1 varchar(200));
DROP TRIGGER base_pl;//
CREATE TRIGGER base_pl BEFORE INSERT ON t1 FOR EACH ROW
BEGIN
DECLARE a int;
DECLARE b VARCHAR(20);
set a = 33;
set b = '36';
loop1: LOOP
if a < 38 then
INSERT INTO FIND_IN_SET_table VALUES(a,'触发器-插入数据','a b',FIND_IN_SET(a,b));
elseif a = 39 then
update FIND_IN_SET_table set c1 = '触发器-更新数据',c2='b a',c3=FIND_IN_SET(b,a)  WHERE id >= 34;
LEAVE loop1;
else
delete FROM FIND_IN_SET_table WHERE id = 35;	
end if;
set a = a + 1;
end LOOP loop1;
END;
//
