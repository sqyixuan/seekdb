ERROR HY000: Illegal mix of collations (utf8mb4_general_ci,EXPLICIT), (gbk_chinese_ci,EXPLICIT)
select FIND_IN_SET(_binary '繁體ing',_gbk '繁體ing') as binary_res from dual;
binary_res
1
