SELECT FIND_IN_SET(binary'b','a,b,c,d');
FIND_IN_SET(binary'b','a,b,c,d')
2
SELECT FIND_IN_SET(date'2023.6.20','a,2023-06-20,c,d');
FIND_IN_SET(date'2023.6.20','a,2023-06-20,c,d')
2
SELECT FIND_IN_SET(_latin1 '2023','a,2023-06-20,2023,d');
FIND_IN_SET(_latin1 '2023','a,2023-06-20,2023,d')
3
SELECT FIND_IN_SET(_gb18030 '繁體ing','a,繁體ing,2023,d');
FIND_IN_SET(_gb18030 '繁體ing','a,繁體ing,2023,d')
0
SELECT FIND_IN_SET(_utf8mb4 '繁體ing','a,繁體ing,2023,d');
FIND_IN_SET(_utf8mb4 '繁體ing','a,繁體ing,2023,d')
2
SELECT FIND_IN_SET(_gbk '繁體ing','a,繁體ing,2023,d,绻侀珨ing');
FIND_IN_SET(_gbk '繁體ing','a,繁體ing,2023,d,绻侀珨ing')
5
SELECT FIND_IN_SET(_gb18030 '繁體ing','a,繁體ing,2023,d,绻侀珨ing');
FIND_IN_SET(_gb18030 '繁體ing','a,繁體ing,2023,d,绻侀珨ing')
5
SELECT FIND_IN_SET(_gb18030 '繁體ing',_gb18030_2022 '繁體ing');
ERROR HY000: Illegal mix of collations (gb18030_chinese_ci,COERCIBLE), (gb18030_2022_chinese_ci,COERCIBLE)
set @a='helloworld';
drop table if exists EMP;
create table EMP(a BLOB(20));
insert into EMP values('helloworld');
select FIND_IN_SET(a,'@a,helloworld') from EMP;
FIND_IN_SET(a,'@a,helloworld')
2
select FIND_IN_SET(@a,a) from EMP;
FIND_IN_SET(@a,a)
1
#### 函数参数是不同字符集/排序规则
select FIND_IN_SET(_gbk '繁體1ing' COLLATE gbk_chinese_ci,_binary '繁體1ing') as gbk from dual;
gbk
1
select FIND_IN_SET(_gbk '繁體1ing' COLLATE gbk_chinese_ci,_utf16 '繁體1ing' COLLATE utf16_general_ci) as gbk from dual;
ERROR HY000: Illegal mix of collations (gbk_chinese_ci,EXPLICIT), (utf16_general_ci,EXPLICIT)
select FIND_IN_SET(_gbk '繁體1ing' COLLATE gbk_chinese_ci,_utf8mb4 '繁體1ing' COLLATE utf8mb4_general_ci) as gbk from dual;
ERROR HY000: Illegal mix of collations (gbk_chinese_ci,EXPLICIT), (utf8mb4_general_ci,EXPLICIT)
select FIND_IN_SET(_gbk 'abc' COLLATE gbk_chinese_ci,_gb18030 'abc' COLLATE gb18030_chinese_ci) as gbk from dual;
ERROR HY000: Illegal mix of collations (gbk_chinese_ci,EXPLICIT), (gb18030_chinese_ci,EXPLICIT)
select FIND_IN_SET(_gbk '123ing' COLLATE gbk_chinese_ci,_latin1 '123ing' COLLATE latin1_swedish_ci) as gbk from dual;
ERROR HY000: Illegal mix of collations (gbk_chinese_ci,EXPLICIT), (latin1_swedish_ci,EXPLICIT)
select FIND_IN_SET(_gbk '繁體' COLLATE gbk_chinese_ci,_latin1 '繁體' COLLATE latin1_swedish_ci) as gbk from dual;
ERROR HY000: Illegal mix of collations (gbk_chinese_ci,EXPLICIT), (latin1_swedish_ci,EXPLICIT)
#### 函数参数是相同字符集，不同排序规则
select FIND_IN_SET(_gbk 'mysql' COLLATE gbk_chinese_ci,_gbk 'mysql' COLLATE gbk_bin) as gbk_res from dual;
ERROR HY000: Illegal mix of collations (gbk_chinese_ci,EXPLICIT), (gbk_bin,EXPLICIT)
select FIND_IN_SET(_latin1 'A' COLLATE latin1_swedish_ci,_latin1 'A' COLLATE latin1_bin) as gbk_res from dual;
ERROR HY000: Illegal mix of collations (latin1_swedish_ci,EXPLICIT), (latin1_bin,EXPLICIT)
select FIND_IN_SET(_utf16 'ab' COLLATE utf16_general_ci,_utf16 'ab' COLLATE utf16_bin) as gbk_res from dual;
ERROR HY000: Illegal mix of collations (utf16_general_ci,EXPLICIT), (utf16_bin,EXPLICIT)
select FIND_IN_SET(_utf16 'ab' COLLATE utf16_general_ci,_utf16 'ab' COLLATE utf16_unicode_ci) as gbk_res from dual;
ERROR HY000: Illegal mix of collations (utf16_general_ci,EXPLICIT), (utf16_unicode_ci,EXPLICIT)
select FIND_IN_SET(_utf16 'ab' COLLATE utf16_general_ci,_utf16 'ab' COLLATE utf16_unicode_ci) as gbk_res from dual;
ERROR HY000: Illegal mix of collations (utf16_general_ci,EXPLICIT), (utf16_unicode_ci,EXPLICIT)
select FIND_IN_SET( _utf8mb4 'x' COLLATE utf8mb4_unicode_ci,_utf8mb4 'x' COLLATE utf8mb4_general_ci) as gbk_res from dual;
ERROR HY000: Illegal mix of collations (utf8mb4_unicode_ci,EXPLICIT), (utf8mb4_general_ci,EXPLICIT)
select FIND_IN_SET( _utf8mb4 'x' COLLATE utf8mb4_unicode_ci,_utf8mb4 'x' COLLATE utf8mb4_bin) as gbk_res from dual;
ERROR HY000: Illegal mix of collations (utf8mb4_unicode_ci,EXPLICIT), (utf8mb4_bin,EXPLICIT)
select FIND_IN_SET(_gb18030 '我爱你' COLLATE gb18030_chinese_ci,_gb18030 '我爱你' COLLATE gb18030_bin) as gbk_res from dual;
ERROR HY000: Illegal mix of collations (gb18030_chinese_ci,EXPLICIT), (gb18030_bin,EXPLICIT)
# Clean up users
drop user ljh@'%';
