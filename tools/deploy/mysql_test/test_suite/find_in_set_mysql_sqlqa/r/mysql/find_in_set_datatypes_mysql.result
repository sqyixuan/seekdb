###### 日期时间类型
DROP TABLE date_table1;
CREATE TABLE date_table1( 
c1 date, 
c2 time, 
c3 year, 
c4 datetime, 
c5 timestamp
);
insert into date_table1 values('9999-12-31','23:59:59.99999999','2022','2022-12-31 23:59:59.999999','2022-01-01 03:26:07.999999');
select * from date_table1 where FIND_IN_SET(c1,c1) = 1 order by 1;
c1	c2	c3	c4	c5
9999-12-31	24:00:00	2022	2023-01-01 00:00:00	2022-01-01 03:26:08
select FIND_IN_SET(c1,'') < 1 from date_table1 order by 1;
