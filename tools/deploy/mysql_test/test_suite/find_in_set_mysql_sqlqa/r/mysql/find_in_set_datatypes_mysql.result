###### 数值类型
DROP TABLE num_table1;
CREATE TABLE num_table1( 
c1 tinyint, 
c2 smallint,
c3 mediumint, 
c4 int, 
c5 bigint, 
c6 float, 
c7 double, 
c8 decimal(5,2), 
c9 bit(10),
c10 bool
);
