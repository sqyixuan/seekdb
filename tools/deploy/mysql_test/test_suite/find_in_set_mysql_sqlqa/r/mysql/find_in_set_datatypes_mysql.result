gbk_res
1
select FIND_IN_SET(_gb18030_2022 '繁體ing123' COLLATE gb18030_2022_chinese_ci,_gb18030_2022 '繁體ing123' COLLATE gb18030_2022_chinese_ci) as gbk_res from dual;
gbk_res
1
select FIND_IN_SET(_binary '繁體ing',_binary '繁體ing') as binary_res from dual;
binary_res
1
select FIND_IN_SET(_latin1 '繁體ing' COLLATE latin1_swedish_ci,_latin1 '繁體ing' COLLATE latin1_swedish_ci) as latin1_res from dual;
latin1_res
1
select FIND_IN_SET(_utf16 '繁體ing' COLLATE utf16_general_ci,_utf16 '繁體ing' COLLATE utf16_general_ci) as utf16_res from dual;
utf16_res
1
select FIND_IN_SET(_utf8mb4 '繁體ing' COLLATE utf8mb4_general_ci,_utf8mb4 '繁體ing' COLLATE utf8mb4_general_ci) as utf8mb4_res from dual;
utf8mb4_res
1
