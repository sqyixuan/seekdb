######################## 标签：FIND_IN_SET-1 参数部分  ########################
######## FIND_IN_SET-1-1  参数个数
###### 0个
select FIND_IN_SET() from dual;
ERROR 42000: Incorrect parameter count in the call to native function 'FIND_IN_SET'
###### 1个
select FIND_IN_SET(1) from dual;
