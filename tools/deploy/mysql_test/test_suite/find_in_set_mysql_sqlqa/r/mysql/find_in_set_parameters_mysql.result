DROP TABLE num_table1;
CREATE TABLE num_table1( 
c1 tinyint, 
c2 smallint,
c3 mediumint, 
c4 int, 
c5 bigint, 
c6 float, 
c7 double, 
c8 DECIMAL(5,2), 
c9 bit(10)
);
insert into num_table1 values(127,32767,8388607,127,12345678912345678,1.1111,123.1231123,1.1,b'1000001');
select FIND_IN_SET(c1,c1) from num_table1;
