#### str1,str2 两个参数是全局变量
DROP TABLE res_table;
CREATE TABLE res_table(
id int,
c1 varchar(200), 
c2 varchar(200));
DROP PROCEDURE p_sha;
CREATE PROCEDURE p_sha(IN ina varchar(200),IN inb varchar(200))
begin
declare a varchar(200) default 'mysql1';
declare b varchar(200) default 'mysql1';
INSERT INTO res_table VALUES(1,'变量',find_in_set(a,b));
INSERT INTO res_table VALUES(2,'in参数',find_in_set(ina,inb));
INSERT INTO res_table VALUES(3,'变量、参数',find_in_set(1,'true,1'));
END;
//
CALL p_sha('mysql','mysql');
SELECT * FROM res_table ORDER BY id;
id	c1	c2
1	变量	1
2	in参数	1
3	变量、参数	2
#### str1,str2 两个参数是用户自定义变量
SET @s1 = 'mysql';
SET @s2 = 'mysql';
SET @s3 = 'MYSQL';
SET @s4 = '';
SET @s5 = rpad('a',4194304,'a');
select find_in_set(@s1,'@s1,@s3,@s2,MYSQL,mysql') from dual;
find_in_set(@s1,'@s1,@s3,@s2,MYSQL,mysql')
4
select find_in_set(@s4,',') from dual;
find_in_set(@s4,',')
1
select find_in_set(@s2,@s3) from dual;
find_in_set(@s2,@s3)
1
select find_in_set(@s5,rpad('a',4194304,'a')) from dual;
find_in_set(@s5,rpad('a',4194304,'a'))
1
#### str1,str2 两个参数是自定义函数的返回值
DROP FUNCTION func1;
CREATE FUNCTION func1(flg int,invalue varchar(200)) RETURNS varchar(200) READS SQL DATA 
BEGIN
declare a varchar(200) default 'hello';
IF flg = 1 THEN 
RETURN a;
ELSE 
RETURN invalue;
END IF;
END;
//
select find_in_set(func1(1,''),func1(2,'hello')) from dual;
find_in_set(func1(1,''),func1(2,'hello'))
1
select find_in_set('hello',func1(2,'hello')) from dual;
find_in_set('hello',func1(2,'hello'))
1
select find_in_set(func1(1,''),'hello,111,') from dual;
find_in_set(func1(1,''),'hello,111,')
1
###### 多个
select find_in_set('str1','str2',3) from dual;
ERROR 42000: Incorrect parameter count in the call to native function 'find_in_set'
