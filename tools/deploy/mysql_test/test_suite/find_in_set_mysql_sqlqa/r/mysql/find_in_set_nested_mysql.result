DROP TABLE IF EXISTS T4;
CREATE TABLE T4(C1 float(0),C2 float(10,10));
INSERT INTO T4 VALUES (-1,NULL);
SELECT C1 FROM T4 GROUP BY C1,C1 WITH ROLLUP HAVING C1 = C1 AND FIND_IN_SET(C1,1) NOT BETWEEN 0.8 - 0.8 AND C1 - 1 MINUS  SELECT MIN(C2) FROM T4 GROUP BY C1;
C1
-1
