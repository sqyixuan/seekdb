purge recyclebin;
drop user ljh@'%';
create user ljh identified by 'ljh';
grant all on *.* to ljh WITH GRANT OPTION;
SET character_set_client = 'utf8mb4';
SET character_set_connection = 'utf8mb4';
SET character_set_results = 'utf8mb4';
--------------------------------------------------------------------------
######################## 标签：FIND_IN_SET-5 运算符    ########################
### 标签：FIND_IN_SET-5-1 算术运算符
select FIND_IN_SET(6+2-3,3*2/3),FIND_IN_SET(5 DIV 2,5 MOD 3) from dual;
FIND_IN_SET(6+2-3,3*2/3)	FIND_IN_SET(5 DIV 2,5 MOD 3)
0	1
select FIND_IN_SET(1,1) + FIND_IN_SET('a','b') * 2 /3 from dual;
FIND_IN_SET(1,1) + FIND_IN_SET('a','b') * 2 /3
1.0000
### 标签：FIND_IN_SET-5-2 比较运算符
select FIND_IN_SET(not 1,3 and 1),FIND_IN_SET(5 or 2,5 xor 3) from dual;
FIND_IN_SET(not 1,3 and 1)	FIND_IN_SET(5 or 2,5 xor 3)
0	0
select FIND_IN_SET(1,2) and FIND_IN_SET('a','b') or not FIND_IN_SET('a','b') xor FIND_IN_SET('a','b') from dual;
FIND_IN_SET(1,2) and FIND_IN_SET('a','b') or not FIND_IN_SET('a','b') xor FIND_IN_SET('a','b')
1
### 标签：FIND_IN_SET-5-3 位运算符
select FIND_IN_SET(6&3,3|3),FIND_IN_SET(5 ^ 2,5 MOD !3),FIND_IN_SET(5<<2,5>>3) from dual;
FIND_IN_SET(6&3,3|3)	FIND_IN_SET(5 ^ 2,5 MOD !3)	FIND_IN_SET(5<<2,5>>3)
0	NULL	0
select FIND_IN_SET(1,1) & FIND_IN_SET('a','b,a'),FIND_IN_SET(1,2) | FIND_IN_SET('a','b') from dual;
FIND_IN_SET(1,1) & FIND_IN_SET('a','b,a')	FIND_IN_SET(1,2) | FIND_IN_SET('a','b')
0	0
select FIND_IN_SET(1,1) ^ FIND_IN_SET('a','a,b'),FIND_IN_SET(1,1) | ! FIND_IN_SET('a','a') from dual;
FIND_IN_SET(1,1) ^ FIND_IN_SET('a','a,b')	FIND_IN_SET(1,1) | ! FIND_IN_SET('a','a')
0	1
select FIND_IN_SET(1,1) >> FIND_IN_SET('a','b,a'),FIND_IN_SET(1,2) << FIND_IN_SET('a','b') from dual;
FIND_IN_SET(1,1) >> FIND_IN_SET('a','b,a')	FIND_IN_SET(1,2) << FIND_IN_SET('a','b')
0	0
### 标签：FIND_IN_SET-5-4 比较运算符
select FIND_IN_SET(6!=3,3=3),FIND_IN_SET(5 > 2,5 < 3),FIND_IN_SET(5<>2,5>=3) from dual;
FIND_IN_SET(6!=3,3=3)	FIND_IN_SET(5 > 2,5 < 3)	FIND_IN_SET(5<>2,5>=3)
1	0	1
select FIND_IN_SET(6,3 in (1,2,3)),FIND_IN_SET(5,5 between 1 and 2),FIND_IN_SET(2,5 is null) from dual;
FIND_IN_SET(6,3 in (1,2,3))	FIND_IN_SET(5,5 between 1 and 2)	FIND_IN_SET(2,5 is null)
0	0	0
select FIND_IN_SET(1 <=> null,5 is null),FIND_IN_SET(null <=> null,5 is not null) from dual;
FIND_IN_SET(1 <=> null,5 is null)	FIND_IN_SET(null <=> null,5 is not null)
1	1
select FIND_IN_SET('a' like '%a%','abc' rlike '%a%'),FIND_IN_SET('a' regexp 'a',5) from dual;
FIND_IN_SET('a' like '%a%','abc' rlike '%a%')	FIND_IN_SET('a' regexp 'a',5)
0	0
select FIND_IN_SET(1,2) >= FIND_IN_SET('a','b'),FIND_IN_SET(1,2) <= FIND_IN_SET('a','b') from dual;
FIND_IN_SET(1,2) >= FIND_IN_SET('a','b')	FIND_IN_SET(1,2) <= FIND_IN_SET('a','b')
1	1
select FIND_IN_SET(1,2) = FIND_IN_SET('a','b'),FIND_IN_SET(1,2) <> FIND_IN_SET('a','b') from dual;
FIND_IN_SET(1,2) = FIND_IN_SET('a','b')	FIND_IN_SET(1,2) <> FIND_IN_SET('a','b')
1	0
select FIND_IN_SET(1,2) != FIND_IN_SET('a','b'),FIND_IN_SET(1,2) < FIND_IN_SET('a','b') from dual;
FIND_IN_SET(1,2) != FIND_IN_SET('a','b')	FIND_IN_SET(1,2) < FIND_IN_SET('a','b')
0	0
select FIND_IN_SET(1,'true,1') in (FIND_IN_SET(1,1),FIND_IN_SET(1,2),FIND_IN_SET(2,1)) from dual;
FIND_IN_SET(1,'true,1') in (FIND_IN_SET(1,1),FIND_IN_SET(1,2),FIND_IN_SET(2,1))
0
select FIND_IN_SET('str','string') is null from dual;
FIND_IN_SET('str','string') is null
0
select FIND_IN_SET('a','b,a') between 0+0 and 1+1 from dual;
FIND_IN_SET('a','b,a') between 0+0 and 1+1
1
select FIND_IN_SET('a','b,a') between false and true from dual;
FIND_IN_SET('a','b,a') between false and true
0
select FIND_IN_SET('b','b,a') <=> FIND_IN_SET(2,5 MOD 3) from dual;
FIND_IN_SET('b','b,a') <=> FIND_IN_SET(2,5 MOD 3)
1
select FIND_IN_SET('a','b,a') from dual where FIND_IN_SET('a','b,a') LIKE FIND_IN_SET('b','a,b');
FIND_IN_SET('a','b,a')
2
select FIND_IN_SET('a','b,a') from dual where FIND_IN_SET('a','b,a') RLIKE '2';
FIND_IN_SET('a','b,a')
2
select FIND_IN_SET('a','b,a') from dual where FIND_IN_SET('a','b,a') REGEXP '%2%';
FIND_IN_SET('a','b,a')
