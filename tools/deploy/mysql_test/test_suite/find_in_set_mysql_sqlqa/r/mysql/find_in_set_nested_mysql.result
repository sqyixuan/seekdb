SELECT 
CASE 
WHEN FIND_IN_SET('apple', 'apple,orange,banana') > 0 THEN 'fruit'
        WHEN FIND_IN_SET('carrot', 'carrot,potato,pepper') > 0 THEN 'vegetable'
        ELSE 'unknown'
    END AS category;
category
fruit
