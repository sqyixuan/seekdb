purge recyclebin;
--error 0,1396
drop user ljh@'%';
--enable_warnings
create user ljh identified by 'ljh';
grant all on *.* to ljh WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,ljh,ljh,test,$OBMYSQL_PORT);

SET character_set_client = 'utf8mb4';
SET character_set_connection = 'utf8mb4';
SET character_set_results = 'utf8mb4';

--echo --------------------------------------------------------------------------
--echo ######################## 标签：FIND_IN_SET-2 SQL操作  ########################
--echo ######## FIND_IN_SET-3-1  select
--error 0,1051
DROP TABLE t1;
CREATE TABLE t1(
  id int, 
  name varchar(100), 
  age int,
  city varchar(100),
  depno int not null,
  sal int, 
  PRIMARY KEY (id,age))
PARTITION BY RANGE (age) ( 
  PARTITION p0 VALUES LESS THAN (20), 
  PARTITION p1 VALUES LESS THAN (30),  
  PARTITION p2 VALUES LESS THAN MAXVALUE);

INSERT INTO t1 VALUES(1,'程程',20,'杭州',101,8000);
INSERT INTO t1 VALUES(2,'依依',25,'广州',101,7000);
INSERT INTO t1 VALUES(3,'阿布',30,'苏州',102,6000);
INSERT INTO t1 VALUES(4,'一诺',31,'苏州',103,5000);

--error 0,1051
DROP TABLE t2;
CREATE TABLE t2(
  id int,
  depno int,
  depname varchar(200),
  INDEX index_name (depno))
PARTITION BY LIST(depno)( 
  PARTITION p0 VALUES IN (101,102),
  PARTITION p1 VALUES IN (103,104),
  PARTITION p2 VALUES IN (105,106));

INSERT INTO t2 VALUES(1,101,'蚂蚁');
INSERT INTO t2 VALUES(2,102,'淘宝');
INSERT INTO t2 VALUES(3,103,'支付');

--error 0,1051
DROP TABLE t3;
CREATE TABLE t3(
  id int,
  c1 varchar(200),
  c2 varchar(200),
  c3 varchar(200))
PARTITION BY HASH(id) PARTITIONS 3;

INSERT INTO t3 VALUES(1,'张','章',NULL);
INSERT INTO t3 VALUES(2,'陈','陈',NULL);
INSERT INTO t3 VALUES(3,'王','望',NULL);

--error 0,1051
DROP VIEW v1;
CREATE VIEW v1 as SELECT id,name,age FROM t1;

--echo ###### select 普通查询
SELECT FIND_IN_SET(name,'依依') FROM t1 ORDER BY 1;
SELECT FIND_IN_SET(depno,102) FROM t2 ORDER BY 1;
SELECT FIND_IN_SET(c1,c2) FROM t3 ORDER BY 1;
SELECT FIND_IN_SET(age,20+3) FROM v1 ORDER BY 1;


--echo ###### where 子句
SELECT * FROM t1 WHERE FIND_IN_SET(name,'依依') = 0 ORDER BY 1;
SELECT * FROM t2 WHERE FIND_IN_SET(depno,102) != 0 ORDER BY 1;
SELECT * FROM t2 WHERE FIND_IN_SET(depno,102) < 0 ORDER BY 1;
SELECT * FROM t3 WHERE FIND_IN_SET(c1,c2) > 0 ORDER BY 1;
SELECT * FROM v1 WHERE FIND_IN_SET(age,20+3) <= FIND_IN_SET(age,age-3) ORDER BY 1;


--echo ##order by 子句
SELECT * FROM t1 WHERE FIND_IN_SET(name,'依依') = 0 ORDER BY FIND_IN_SET(name,name);
SELECT * FROM t2 WHERE FIND_IN_SET(depno,102) < 0 ORDER BY FIND_IN_SET(depno,102);
SELECT * FROM t3 WHERE FIND_IN_SET(c1,c2) > 0 ORDER BY FIND_IN_SET(c1,c2);
SELECT * FROM v1 WHERE FIND_IN_SET(age,20+5) = 0 ORDER BY FIND_IN_SET(age,25);
SELECT * FROM v1 ORDER BY FIND_IN_SET(age,NULL);
SELECT * FROM v1 ORDER BY FIND_IN_SET(NULL,NULL);


--echo ##group by having 子句
SELECT * FROM t1 WHERE FIND_IN_SET(name,'依依') = 0 GROUP BY FIND_IN_SET(name,'') ORDER BY 1;
SELECT * FROM t2 WHERE FIND_IN_SET(depno,102) != 0 GROUP BY FIND_IN_SET(depname,'') HAVING FIND_IN_SET(depno,102) != 0 ORDER BY 1;
SELECT * FROM t3 WHERE FIND_IN_SET(c1,c2) > 0 GROUP BY FIND_IN_SET(c1,'') ORDER BY 1;
SELECT * FROM v1 WHERE FIND_IN_SET(age,20+3) <= FIND_IN_SET(age,name) GROUP BY FIND_IN_SET(age,20) ORDER BY 1;


--echo #DISTINCT
SELECT DISTINCT FIND_IN_SET(city,'苏州') FROM t1 WHERE FIND_IN_SET(name,'依依') = 0 ORDER BY 1;
SELECT DISTINCT FIND_IN_SET(depno,103) FROM t2 WHERE FIND_IN_SET(depno,102) < 0 ORDER BY 1;
SELECT DISTINCT FIND_IN_SET(c1,c2) FROM t3 WHERE FIND_IN_SET(c1,c2) > 0 ORDER BY 1;
SELECT DISTINCT FIND_IN_SET(age,25) FROM v1 ORDER BY 1;


--echo #CASE WHEN
SELECT id,name,sal,FIND_IN_SET(CASE WHEN sal < 6000 THEN NULL ELSE sal END,sal) FIND_IN_SET_sal FROM t1 ORDER BY 1;
SELECT id,depno,depname,CASE FIND_IN_SET(depno,102) WHEN 1 THEN 'depno>102' WHEN 0 THEN 'depno=102' ELSE 'depno<102' END FIND_IN_SET_depo FROM t2 ORDER BY 1; 
SELECT id,c1,c2,CASE WHEN FIND_IN_SET(c1,c2)=0 THEN 'c1=c2' WHEN FIND_IN_SET(c1,c2)>0 THEN 'c1>c2' ELSE 'c1<c2' END FROM t3 ORDER BY 1 ; 


--echo ##连接查询
SELECT e.*,p.*,FIND_IN_SET(e.depno,p.depno) FROM t1 e, t2 p WHERE FIND_IN_SET(e.depno,p.depno) = 0 ORDER BY 1;
SELECT e.*,p.*,FIND_IN_SET(e.id,p.depno)  FROM t1 e LEFT JOIN t2 p ON FIND_IN_SET(e.depno,p.depno) = 0 ORDER BY 1;
SELECT e.*,p.*,FIND_IN_SET(e.name,p.depname)  FROM t1 e RIGHT JOIN t2 p ON FIND_IN_SET(e.depno,p.depno) = 0 ORDER BY 1;
SELECT e.*,p.*,FIND_IN_SET(e.depno,NULL)  FROM t1 e INNER JOIN t2 p ON FIND_IN_SET(e.depno,p.depno) = 0 ORDER BY 1;


--echo ##select嵌套
--echo #SELECT
SELECT id,name,age,FIND_IN_SET(sal,5000) FROM (SELECT * FROM t1 WHERE FIND_IN_SET(age,30) = 1 ORDER BY 1) t1 ORDER BY 1;
SELECT id,depno,depname,FIND_IN_SET(depno,102) FROM t2 where depno = (SELECT depno FROM t1 WHERE FIND_IN_SET(depno,102) <= 0 limit 1) ORDER BY 1;


--echo #EXISTS AND NOT EXISTS
SELECT id,name,age,FIND_IN_SET(sal,5000) FROM t1 WHERE EXISTS (SELECT * FROM t2 where FIND_IN_SET(depno,102)) ORDER BY 1;
SELECT id,depno,depname,FIND_IN_SET(depno,102) FROM t2 WHERE NOT EXISTS (SELECT * FROM t3 WHERE FIND_IN_SET(c1,'wang') != 0) ORDER BY 1;

--echo #ANY
SELECT id,name,age,FIND_IN_SET(sal,5000) FROM t1 WHERE FIND_IN_SET(sal,5000) = ANY (SELECT FIND_IN_SET(age,25) FROM t1) ORDER BY 1;
SELECT id,depno,depname,FIND_IN_SET(depno,102) FROM t2 WHERE FIND_IN_SET(depno,102) <= ANY (SELECT FIND_IN_SET(depno,25) FROM t1) ORDER BY 1;
SELECT id,c1,c2,FIND_IN_SET(c1,c2) FROM t3 WHERE FIND_IN_SET(c1,c2) >= ANY (SELECT FIND_IN_SET(c1,'a') FROM t3) ORDER BY 1;


--echo #ALL 
SELECT id,name,age,FIND_IN_SET(sal,5000) FROM t1 WHERE FIND_IN_SET(sal,5000) = ALL (SELECT FIND_IN_SET(age,25) FROM t1) ORDER BY 1;
SELECT id,depno,depname,FIND_IN_SET(depno,102) FROM t2 WHERE FIND_IN_SET(depno,102) <= ALL (SELECT FIND_IN_SET(depno,25) FROM t1) ORDER BY 1;
SELECT id,c1,c2,FIND_IN_SET(c1,c2) FROM t3 WHERE FIND_IN_SET(c1,c2) >= ALL (SELECT FIND_IN_SET(c1,'a') FROM t3) ORDER BY 1;


--echo #CREATE AS
--error 0,1051
DROP TABLE t4;
CREATE TABLE t4 AS SELECT id,name,age,FIND_IN_SET(sal,6000) FROM t1; 
SELECT * FROM t4;


--echo #INSERT INTO AS
INSERT INTO t3 SELECT id,name,FIND_IN_SET(age,20),FIND_IN_SET(sal,6000) FROM t1 WHERE FIND_IN_SET(name,'程程') = 0;
SELECT * FROM t3 ORDER BY 1;


--echo #UPDATE SET
UPDATE t3 e INNER JOIN  t1 p ON e.id = p.id SET e.c2 = FIND_IN_SET(p.sal,6000) where FIND_IN_SET(p.name,'程程') = 0;
SELECT * FROM t3 ORDER BY 1;


--echo #WITH AS的SELECT
WITH a AS (SELECT id,name,city,FIND_IN_SET(name,'a'),FIND_IN_SET(city,'a') name2 FROM t1) SELECT * FROM a ORDER BY 1;
WITH a AS (SELECT id,depno,depname,FIND_IN_SET(depno,102),FIND_IN_SET(depname,'a') FROM t2 where FIND_IN_SET(depno,102) = 0) SELECT * FROM a ORDER BY 1;


--echo #模糊查询like 
SELECT id,name,age,FIND_IN_SET(sal,5000) FROM t1 WHERE FIND_IN_SET(sal,5000) LIKE '%1%';
SELECT id,depno,depname,FIND_IN_SET(depno,102) FROM t2 WHERE FIND_IN_SET(depno,102) LIKE '%0%';


--echo ### 标签：FIND_IN_SET-3-2 insert
INSERT INTO t3 VALUES(4,FIND_IN_SET('wang','Wan'),FIND_IN_SET(2022,2023),FIND_IN_SET(NULL,0));
INSERT INTO t3 SELECT id,name,age,FIND_IN_SET(sal,6000) FROM t1 WHERE FIND_IN_SET(name,'一诺')=0 ORDER BY 1;
SELECT * FROM  t3 ORDER BY 1;


--echo ### 标签：FIND_IN_SET-3-3 update
UPDATE t3 SET c2 = FIND_IN_SET(c2,'a'),c3 = FIND_IN_SET(c1,c2)  where FIND_IN_SET(concat(c1,c2),'陈陈') = 0;
SELECT * FROM t3 ORDER BY 1;


--echo ### 标签：FIND_IN_SET-3-4 delete
DELETE FROM t3 WHERE c3 = FIND_IN_SET(1,2);
SELECT * FROM  t3 ORDER BY 1;


--echo ### 标签：FIND_IN_SET-3-5 replace   
replace into t1 values(5,'replace',28,'杭州',103,9000);
select * from t1 where id = 5;

replace into t1 values(5,'replace',28,'杭州',103,FIND_IN_SET(9000,null));
select * from t1 where id = 5;


drop table t1;
CREATE table t1(id bigint PRIMARY key AUTO_INCREMENT,c1 varchar(20),c2 FLOAT,c3 datetime);
insert into t1(c1,c2,c3) values('不是放入额我确认',513514,'2023-06-20 01:01:01');
insert into t1(c1,c2,c3) values('sgfwrertew',-5164564,'2023-06-21 02:01:01');
insert into t1(c1,c2,c3) values('sgfwr散热问问如果',0.5164564,'2023-06-22 03:01:01');
insert into t1(c1,c2,c3) values('nusfwhif',null,'2023-06-23 04:01:01');
insert into t1(c1,c2,c3) values('54wmd国土】【】',3.5464,'2023-06-24 05:01:01');
select * from t1 order by id asc;
select * from t1 where id=FIND_IN_SET((select c2 from t1 where id=2),'-5164564,,0.01,2023-06-22 03:01:01');
select * from t1 where id=1;
select * from t1 where FIND_IN_SET((select c2 from t1 where id=2),'-5164564,,0.01,2023-06-22 03:01:01') or FIND_IN_SET((select c2 from t1 where id=2),'-5164564,,0.01,2023-06-22 03:01:01');


SELECT * FROM t1 WHERE id=FIND_IN_SET('1+1', CONCAT(true,'+',true));
SELECT * FROM t1 WHERE id=FIND_IN_SET('1+1', '2,1+1,2');
SELECT * FROM t1 WHERE FIND_IN_SET('54wmd国土', CONCAT(54, 'wmd', '国土'));
SELECT * FROM t1 WHERE FIND_IN_SET('value1','value2') and FIND_IN_SET('value2','value2');
SELECT FIND_IN_SET(1,1) FROM dual WHERE abs(1) OR 2;

SELECT FIND_IN_SET(-1.0e-131,0) FROM dual;

drop table t1;
CREATE table t1(id bigint PRIMARY key AUTO_INCREMENT,c1 FLOAT);
insert into t1(c1) values(12356);
insert into t1(c1) values(-8654491);
insert into t1(c1) values(null);
insert into t1(c1) values(0.512334);
insert into t1(c1) values(3.1415926);
select * from t1 order by id asc;
select * from t1 where id=FIND_IN_SET((select c1 from t1 where id=2),'-8654490,-8654491');
select * from t1 where id=FIND_IN_SET((select c1 from t1 where id=2),'-8654491');

--error 0,1051
drop table tt1;
create table tt1 as select FIND_IN_SET(NULL,'null') from dual;
desc tt1;
select * from tt1;

drop table tt1;
create table tt1 as select FIND_IN_SET(1,'str,99 1,1,999') from dual;
desc tt1;
select * from tt1;

drop table tt1;
create table tt1 as select FIND_IN_SET('',',') from dual;
desc tt1;
select * from tt1;
drop table tt1;

select FIND_IN_SET(NULL,'null') from dual;
select FIND_IN_SET(NULL,'str,null') from dual;

select FIND_IN_SET(1,'str,99 1,1,999') from dual;

select FIND_IN_SET('',',') from dual;
select FIND_IN_SET('','str,') from dual;
select FIND_IN_SET('','str,,null,') from dual;

select FIND_IN_SET(' ','str') from dual;
select FIND_IN_SET(' ','str, ') from dual;
select FIND_IN_SET(' ','str, ,null') from dual; 

select FIND_IN_SET(0,'0.123000000000000000000000000000,0');

drop table t1;
create table t1(c1 set('中文字符','123456','ABCabc','!@#$%^&*','2020-10-10','2020-10-10 10:10:10','10:10:10'));
