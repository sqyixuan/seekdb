insert into t1 values('123456');
insert into t1 values('ABCabc');
insert into t1 values('!@#$%^&*');
insert into t1 values('2020-10-10');
insert into t1 values('2020-10-10 10:10:10');
insert into t1 values('10:10:10');
select FIND_IN_SET('中文字符',c1) from t1;
select FIND_IN_SET('123456',c1) from t1;

select FIND_IN_SET('',c1) from t1;
SELECT * FROM t1 WHERE FIND_IN_SET('',c1)=1;


drop table t1;
create table t1(c1 varchar(20));
insert into t1 values('中文字符');
insert into t1 values('123456');
insert into t1 values('ABCabc');
insert into t1 values('!@#$%^&*');
insert into t1 values('2020-10-10');
insert into t1 values('2020-10-10 10:10:10');
insert into t1 values('10:10:10');
insert into t1 values('');
SELECT * FROM t1 WHERE FIND_IN_SET(' ',c1) > -100;
select FIND_IN_SET('123456',c1) from t1;

SELECT FIND_IN_SET(_GBK 'YOU are very good', _GBK'good ,very , are, you,YOUareverygood,YOU are very good');
SELECT FIND_IN_SET(binary LOWER('??'),'我,y,-,10,??');
SELECT FIND_IN_SET(binary upper('y'),'我,y,-,10');
SELECT FIND_IN_SET(binary '我',binary '我,y,-,10'); 
SELECT FIND_IN_SET(ASCII('A'),'ABS(-65),1,65'); 

