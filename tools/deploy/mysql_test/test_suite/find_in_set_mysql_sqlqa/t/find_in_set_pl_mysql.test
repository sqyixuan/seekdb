create user ljh identified by 'ljh';
grant all on *.* to ljh WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,ljh,ljh,test,$OBMYSQL_PORT);
 
SET character_set_client = 'utf8mb4';
SET character_set_connection = 'utf8mb4';
SET character_set_results = 'utf8mb4';

--echo ######################## 标签：FIND_IN_SET-4 PL/SQL场景  ########################
--error 0,1051
DROP TABLE FIND_IN_SET_table;
CREATE TABLE FIND_IN_SET_table(
  id int,
  c1 varchar(200),
  c2 varchar(200),
  c3 varchar(200))
PARTITION BY RANGE COLUMNS(id) (   
  PARTITION p0 VALUES LESS THAN (5),    
  PARTITION p1 VALUES LESS THAN (10),     
  PARTITION p2 VALUES LESS THAN MAXVALUE );

INSERT INTO FIND_IN_SET_table VALUES(1,'MYSQL','mysql',NULL);
INSERT INTO FIND_IN_SET_table VALUES(2,'oceanbase','oceanbase mysql',NULL);


--echo ######## FIND_IN_SET-4-1  存储过程
--echo ###### 参数
--echo ### 无参数的存储过程
DELIMITER //;
--error 0,1305
DROP PROCEDURE pro_FIND_IN_SET;//
CREATE PROCEDURE pro_FIND_IN_SET()
begin
	declare var varchar(200);
	declare i int default 3;
	SELECT FIND_IN_SET(c1,c2) into var FROM FIND_IN_SET_table WHERE FIND_IN_SET(c1,c2) is not null and id = 1;
    UPDATE FIND_IN_SET_table SET c3 = var WHERE id = 1;
	WHILE i <= 4 do
	  INSERT INTO FIND_IN_SET_table VALUES(i,'i=',i,FIND_IN_SET(i,10));
	  SET i := i + 1;
	END while;
END;
//
DELIMITER ;//
 
CALL pro_FIND_IN_SET();
SELECT * FROM FIND_IN_SET_table ORDER BY 1;


--echo ##只有一个in参数的存储过程
DELIMITER //;
--error 0,1305
DROP PROCEDURE pro_FIND_IN_SET;//
CREATE PROCEDURE pro_FIND_IN_SET(in invalue varchar(200))
begin
	declare var varchar(200);
	declare i int default 5;
	SELECT FIND_IN_SET(c1,c2) into var FROM FIND_IN_SET_table WHERE FIND_IN_SET(c1,c2) is not null and id = 2;
    UPDATE FIND_IN_SET_table SET c3 = var WHERE id = 2;
	WHILE i <= 6 do
	  INSERT INTO FIND_IN_SET_table VALUES(i,'invalue=',invalue,FIND_IN_SET(invalue,10));
	  SET i := i + 1;
	END while;
END;
//
DELIMITER ;//

CALL pro_FIND_IN_SET(10);
SELECT * FROM FIND_IN_SET_table ORDER BY 1;
CALL pro_FIND_IN_SET(FIND_IN_SET('mysql','oracle'));
SELECT * FROM FIND_IN_SET_table ORDER BY 1;


--echo ##包含out参数的存储过程
DELIMITER //;
--error 0,1305
DROP PROCEDURE pro_FIND_IN_SET;//
CREATE  PROCEDURE pro_FIND_IN_SET(out outa varchar(200))
begin
    declare i int default 7;
	SELECT count(FIND_IN_SET(c1,c2)) into outa FROM FIND_IN_SET_table WHERE FIND_IN_SET(c1,'oceanbase') like '%0%';
	WHILE i <= 8 do
	   INSERT INTO FIND_IN_SET_table VALUES(i,'i=',i,FIND_IN_SET(i,10));
	SET i := i + 1;
	END WHILE;
END;
//
DELIMITER ;//
 
CALL pro_FIND_IN_SET(@outa);
SELECT * FROM FIND_IN_SET_table ORDER BY 1;
SELECT @outa;


--echo ##包含inout参数的存储过程
DELIMITER //;
--error 0,1305
DROP PROCEDURE pro_FIND_IN_SET;//
CREATE  PROCEDURE pro_FIND_IN_SET(INOUT inouta varchar(200))
begin
    declare invalue varchar(200);
    declare i int default 9;
	set invalue := inouta;
	SELECT FIND_IN_SET(c1,c2) into inouta FROM FIND_IN_SET_table WHERE FIND_IN_SET(c1,c2) = invalue limit 1;
	WHILE i <= 10 do
	  INSERT INTO FIND_IN_SET_table VALUES(i,'i=',i,FIND_IN_SET(i,10));
	  set i := i+1;
	END WHILE;
END;
//
DELIMITER ;//

SET @inouta=FIND_IN_SET('FIND_IN_SET','FIND_IN_SET()');
CALL pro_FIND_IN_SET(@inouta);
SELECT * FROM FIND_IN_SET_table ORDER BY 1;
SELECT @inouta;


--echo ###### dml语句
--echo ## 条件语句
DELIMITER //;
--error 0,1305
DROP PROCEDURE pro_FIND_IN_SET;//
CREATE PROCEDURE pro_FIND_IN_SET(IN invalue varchar(200),IN ina varchar(200),IN inb varchar(200))
begin
    IF invalue = FIND_IN_SET('B','b') THEN 
	   INSERT INTO FIND_IN_SET_table VALUES(11,'PROCEDURE-If条件','dml语句',FIND_IN_SET(ina,inb));
    ELSE 
	   INSERT INTO FIND_IN_SET_table VALUES(12,ina,inb,FIND_IN_SET(ina,inb));
    END IF;
END;
//
DELIMITER ;//

SET @invalue := FIND_IN_SET('A','a');
SET @ina := '1';
SET @inb := '2';
CALL pro_FIND_IN_SET(@invalue,@ina,@inb);
SELECT * FROM FIND_IN_SET_table ORDER BY 1;


SET @invalue := 1;
SET @ina := '1';
SET @inb := '2';
CALL pro_FIND_IN_SET(@invalue,@ina,@inb);
SELECT * FROM FIND_IN_SET_table ORDER BY 1;


--echo #循环语句
DELIMITER //;
--error 0,1305
DROP PROCEDURE pro_FIND_IN_SET;//
CREATE PROCEDURE pro_FIND_IN_SET()
begin
    declare i int default 13;
    WHILE i <= 15 do
      INSERT INTO FIND_IN_SET_table VALUES(i,'PROCEDURE-While循环','FIND_IN_SET(i,15)',FIND_IN_SET(i,15));
      set i := i+1;
    END WHILE;
 
    loop_name:LOOP
      INSERT INTO FIND_IN_SET_table VALUES(i,'PROCEDURE-Loop循环','FIND_IN_SET(i,17)',FIND_IN_SET(i,17));
      SET i := i+1;
      IF i > 17 THEN 
	    LEAVE loop_name;
      END IF;
    END LOOP loop_name;
 
    REPEAT
      INSERT INTO FIND_IN_SET_table VALUES(i,'PROCEDURE-Repeat循环','FIND_IN_SET(i,19)',FIND_IN_SET(i,19));
      SET i := i+1;
      until i > 19	
    END REPEAT;
END;
//
DELIMITER ;//

CALL pro_FIND_IN_SET();
SELECT * FROM FIND_IN_SET_table ORDER BY 1;


--echo ##游标
DELIMITER //;
--error 0,1305
DROP PROCEDURE pro_FIND_IN_SET;//
CREATE PROCEDURE pro_FIND_IN_SET()
BEGIN
  DECLARE a varchar(200);
  DECLARE b varchar(200);
  DECLARE done INT DEFAULT 0;
  DECLARE FIND_IN_SET_cursor CURSOR FOR SELECT id,FIND_IN_SET(c1,c2) FROM FIND_IN_SET_table;
  DECLARE CONTINUE HANDLER FOR SQLSTATE '02000' SET done=1;
  OPEN FIND_IN_SET_cursor;
  FETCH FIND_IN_SET_cursor INTO a,b;
  WHILE done<>1 DO
    INSERT INTO FIND_IN_SET_table VALUES(a,'id','FIND_IN_SET(c1,c2)=',b);
    FETCH FIND_IN_SET_cursor INTO a,b;
  END WHILE;
  CLOSE FIND_IN_SET_cursor;
END;
//
DELIMITER ;//

CALL pro_FIND_IN_SET();
SELECT * FROM FIND_IN_SET_table ORDER BY 1;


--echo ##动态sql
DELIMITER //;
--error 0,1305
DROP PROCEDURE pro_FIND_IN_SET;//
CREATE PROCEDURE pro_FIND_IN_SET()
BEGIN
  SET @s = 'INSERT INTO FIND_IN_SET_table VALUES(?,"动态sql插入的数据","abc123 abc1234",?);';
  PREPARE stmFIND_IN_SET_table FROM @s;
  SET @a = 20;
  SET @b = FIND_IN_SET('abc123','abc1234');
  EXECUTE stmFIND_IN_SET_table USING @a,@b;
 
  SET @s = 'SELECT * FROM FIND_IN_SET_table WHERE id = 20';
  PREPARE stmt2 FROM @s;
  EXECUTE stmt2; 
END;
//
DELIMITER ;//

CALL pro_FIND_IN_SET();


DELIMITER //;
--error 0,1305
DROP PROCEDURE pro_FIND_IN_SET;//
CREATE PROCEDURE pro_FIND_IN_SET()
BEGIN
  SET @s = 'update FIND_IN_SET_table set c1 = ?,c2 = ?,c3 = ? WHERE id = 20;';
  PREPARE stmFIND_IN_SET_table FROM @s;
  SET @a = '动态sql更新的数据';
  SET @b = 'mysql Mysql';
  SET @c = FIND_IN_SET('mysql','Mysql');
  EXECUTE stmFIND_IN_SET_table USING @a,@b,@c;
 
  SET @s = 'SELECT * FROM FIND_IN_SET_table WHERE id = 20';
  PREPARE stmt2 FROM @s;
  EXECUTE stmt2; 
  
  SET @s = 'delete FROM FIND_IN_SET_table WHERE c2 = ?;';
  PREPARE stmFIND_IN_SET_table FROM @s;
  SET @a = 'mysql Mysql';
  EXECUTE stmFIND_IN_SET_table USING @a;
 
  SET @s = 'SELECT * FROM FIND_IN_SET_table WHERE id = 20';
  PREPARE stmt2 FROM @s;
  EXECUTE stmt2; 
END;
//
DELIMITER ;//

CALL pro_FIND_IN_SET();


--echo ##函数返回值作为存储过程的参数传递
DELIMITER //;
--error 0,1305
DROP FUNCTION f_FIND_IN_SET;//
CREATE FUNCTION f_FIND_IN_SET() RETURNS varchar(200) READS SQL DATA 
BEGIN
  declare a varchar(200);
  SELECT FIND_IN_SET('function','procedure') into a FROM dual;
  RETURN a;
END;
//

--error 0,1305
DROP PROCEDURE pro_FIND_IN_SET;//
CREATE PROCEDURE pro_FIND_IN_SET(in infun varchar(200))
begin
	declare a varchar(200);
	declare b varchar(200);
	declare i int;
	set a := '变量1';
	set b := '变量2';
  	INSERT INTO FIND_IN_SET_table VALUES(21,infun,concat(a,b),FIND_IN_SET(a,b));
END;
//
DELIMITER ;//


CALL pro_FIND_IN_SET(f_FIND_IN_SET());
SELECT * FROM FIND_IN_SET_table ORDER BY 1;


-- echo #自定义变量，全局变量，in 参数作为FIND_IN_SET函数的参数
DELIMITER //;
--error 0,1305
DROP PROCEDURE pro_FIND_IN_SET;//
CREATE PROCEDURE pro_FIND_IN_SET(IN ina varchar(200),IN inb varchar(200))
begin
  declare a varchar(200) default 'var1';
  declare b varchar(200) default 'var2';
 
  INSERT INTO FIND_IN_SET_table VALUES(22,'自定义变量','var1 var2',FIND_IN_SET(a,b));
  INSERT INTO FIND_IN_SET_table VALUES(23,'全局变量','user var USER VAR',FIND_IN_SET(@mya,@myb));
  INSERT INTO FIND_IN_SET_table VALUES(24,'参数变量','wang huan huan chen zhi heng',FIND_IN_SET(ina,inb));
END;
//
DELIMITER ;//

SET @mya := 'user var';
SET @myb := 'USER VAR';
CALL pro_FIND_IN_SET('wang huan huan','chen zhi heng');
SELECT * FROM FIND_IN_SET_table ORDER BY 1;


--echo ### 标签：FIND_IN_SET-3-2 函数      
--echo #定义一个无参的函数
DELIMITER //;
--error 0,1305
DROP FUNCTION f_FIND_IN_SET;//
CREATE FUNCTION f_FIND_IN_SET() returns varchar(200) READS SQL DATA 
begin
  declare a varchar(200);
  SELECT FIND_IN_SET('function','function compare') into a FROM dual;
  return a;
END;
//
DELIMITER ;//

SELECT  f_FIND_IN_SET();


--echo #定义一个有参的函数
DELIMITER //;
--error 0,1305
DROP FUNCTION f_FIND_IN_SET;//
CREATE FUNCTION f_FIND_IN_SET(invalue varchar(200)) returns  varchar(200) READS SQL DATA 
begin
  declare a varchar(200);
    SELECT FIND_IN_SET(1,invalue) into a FROM dual;
  return a;
END ;
//
DELIMITER ;//

SELECT f_FIND_IN_SET(FIND_IN_SET('function','in'));


--echo ##dml语句
--echo #条件语句
DELIMITER //;
--error 0,1305
DROP FUNCTION f_FIND_IN_SET;//
CREATE FUNCTION f_FIND_IN_SET(invalue varchar(200),ina varchar(200),inb varchar(200))returns varchar(200) DETERMINISTIC
begin
  IF invalue = 0 THEN 
     INSERT INTO FIND_IN_SET_table VALUES(25,'FUNCTION-If条件','invalue=0',FIND_IN_SET(invalue,inb));
  ELSE 
     INSERT INTO FIND_IN_SET_table VALUES(26,'FUNCTION-If条件','invalue!=0',FIND_IN_SET(invalue,ina));
  END IF;
  return FIND_IN_SET(ina,inb);
END;
//
DELIMITER ;//

SET @invalue := FIND_IN_SET('in','inout');
SET @ina := 'ina';
SET @inb := 'inb';
SELECT f_FIND_IN_SET(@invalue,@ina,@inb);
SELECT * FROM FIND_IN_SET_table ORDER BY 1;

SET @invalue := FIND_IN_SET('FIND_IN_SET_table','FIND_IN_SET_TABLE');
SET @ina := 'str1';
SET @inb := 'str2';
SELECT f_FIND_IN_SET(@invalue,@ina,@inb);
SELECT * FROM FIND_IN_SET_table ORDER BY 1;


--echo #循环语句
DELIMITER //;
--error 0,1305
DROP FUNCTION f_FIND_IN_SET;//
CREATE FUNCTION f_FIND_IN_SET(invalue varchar(200)) returns varchar(200) DETERMINISTIC
begin
  declare a varchar(200);
  declare i int default 27;
  SELECT FIND_IN_SET(invalue,invalue) into a FROM dual;
  
  WHILE i <= 28 do
    INSERT INTO FIND_IN_SET_table VALUES(i,'FUNCTION-While循环','字符比较',FIND_IN_SET('abc','efg'));
    set i := i+1;
  END WHILE;
  
  loop_name:LOOP
    INSERT INTO FIND_IN_SET_table VALUES(i,'FUNCTION-Loop循环','数字比较',FIND_IN_SET(i+1,i));
    SET i := i+1;
    IF i > 30 THEN 
      LEAVE loop_name;
    END IF;
  END LOOP loop_name;
  
  REPEAT
    INSERT INTO FIND_IN_SET_table VALUES(i,'FUNCTION-Repeat循环','特殊符号比较',FIND_IN_SET('$%^','*&%'));
    SET i := i+1;
    until i > 32	
  END REPEAT;
  return a;
END;
//
DELIMITER ;//

SELECT f_FIND_IN_SET(FIND_IN_SET('FIND_IN_SET','substring'));
SELECT * FROM FIND_IN_SET_table ORDER BY 1;


--echo ### 标签：FIND_IN_SET-3-3 触发器
--error 0,1051
DROP TABLE t1;
CREATE TABLE t1(id int,c1 varchar(200));

DELIMITER //;
--error 0,1360
DROP TRIGGER base_pl;//
CREATE TRIGGER base_pl BEFORE INSERT ON t1 FOR EACH ROW
BEGIN
  DECLARE a int;
  DECLARE b VARCHAR(20);
  set a = 33;
  set b = '36';
  loop1: LOOP
    if a < 38 then
      INSERT INTO FIND_IN_SET_table VALUES(a,'触发器-插入数据','a b',FIND_IN_SET(a,b));
    elseif a = 39 then
      update FIND_IN_SET_table set c1 = '触发器-更新数据',c2='b a',c3=FIND_IN_SET(b,a)  WHERE id >= 34;
      LEAVE loop1;
    else
      delete FROM FIND_IN_SET_table WHERE id = 35;	
    end if;
    set a = a + 1;
  end LOOP loop1;
END;
//
DELIMITER ;//

INSERT INTO t1 VALUES(1,'t1 触发触发器');
SELECT * FROM FIND_IN_SET_table ORDER BY 1;
 
 
