purge recyclebin;
--error 0,1396
drop user ljh@'%';
--enable_warnings
create user ljh identified by 'ljh';
grant all on *.* to ljh WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,ljh,ljh,test,$OBMYSQL_PORT);

SET character_set_client = 'utf8mb4';
SET character_set_connection = 'utf8mb4';
SET character_set_results = 'utf8mb4';

--echo --------------------------------------------------------------------------
--echo ######################## 标签：FIND_IN_SET-5 运算符    ########################
--echo ### 标签：FIND_IN_SET-5-1 算术运算符
select FIND_IN_SET(6+2-3,3*2/3),FIND_IN_SET(5 DIV 2,5 MOD 3) from dual;
select FIND_IN_SET(1,1) + FIND_IN_SET('a','b') * 2 /3 from dual;
 
 
--echo ### 标签：FIND_IN_SET-5-2 比较运算符
select FIND_IN_SET(not 1,3 and 1),FIND_IN_SET(5 or 2,5 xor 3) from dual;
select FIND_IN_SET(1,2) and FIND_IN_SET('a','b') or not FIND_IN_SET('a','b') xor FIND_IN_SET('a','b') from dual;
 
 
--echo ### 标签：FIND_IN_SET-5-3 位运算符
select FIND_IN_SET(6&3,3|3),FIND_IN_SET(5 ^ 2,5 MOD !3),FIND_IN_SET(5<<2,5>>3) from dual;
select FIND_IN_SET(1,1) & FIND_IN_SET('a','b,a'),FIND_IN_SET(1,2) | FIND_IN_SET('a','b') from dual;
select FIND_IN_SET(1,1) ^ FIND_IN_SET('a','a,b'),FIND_IN_SET(1,1) | ! FIND_IN_SET('a','a') from dual;
select FIND_IN_SET(1,1) >> FIND_IN_SET('a','b,a'),FIND_IN_SET(1,2) << FIND_IN_SET('a','b') from dual;
 
 
--echo ### 标签：FIND_IN_SET-5-4 比较运算符
select FIND_IN_SET(6!=3,3=3),FIND_IN_SET(5 > 2,5 < 3),FIND_IN_SET(5<>2,5>=3) from dual;
select FIND_IN_SET(6,3 in (1,2,3)),FIND_IN_SET(5,5 between 1 and 2),FIND_IN_SET(2,5 is null) from dual;
select FIND_IN_SET(1 <=> null,5 is null),FIND_IN_SET(null <=> null,5 is not null) from dual;
select FIND_IN_SET('a' like '%a%','abc' rlike '%a%'),FIND_IN_SET('a' regexp 'a',5) from dual;
select FIND_IN_SET(1,2) >= FIND_IN_SET('a','b'),FIND_IN_SET(1,2) <= FIND_IN_SET('a','b') from dual;
select FIND_IN_SET(1,2) = FIND_IN_SET('a','b'),FIND_IN_SET(1,2) <> FIND_IN_SET('a','b') from dual;
select FIND_IN_SET(1,2) != FIND_IN_SET('a','b'),FIND_IN_SET(1,2) < FIND_IN_SET('a','b') from dual;
select FIND_IN_SET(1,'true,1') in (FIND_IN_SET(1,1),FIND_IN_SET(1,2),FIND_IN_SET(2,1)) from dual;
select FIND_IN_SET('str','string') is null from dual;
select FIND_IN_SET('a','b,a') between 0+0 and 1+1 from dual;
select FIND_IN_SET('a','b,a') between false and true from dual;
select FIND_IN_SET('b','b,a') <=> FIND_IN_SET(2,5 MOD 3) from dual;
select FIND_IN_SET('a','b,a') from dual where FIND_IN_SET('a','b,a') LIKE FIND_IN_SET('b','a,b');
select FIND_IN_SET('a','b,a') from dual where FIND_IN_SET('a','b,a') RLIKE '2';
select FIND_IN_SET('a','b,a') from dual where FIND_IN_SET('a','b,a') REGEXP '%2%';
 
 
--echo ---------------------------------------------------------------------------
--echo ######################## 标签：FIND_IN_SET-6 函数间嵌套 ########################
--echo ### 标签：FIND_IN_SET-6-1，FIND_IN_SET-6-2 嵌套其他函数，被其他函数嵌套
--echo ## 数字函数
SELECT FIND_IN_SET('a','b'),ABS(FIND_IN_SET('a','b,a')) FROM dual;
SELECT ABS(-1),FIND_IN_SET(ABS(-1),1) FROM dual;

SELECT FIND_IN_SET('a','b'),AVG(FIND_IN_SET('a','b,a')) FROM dual;
SELECT AVG(-1),FIND_IN_SET(AVG(-1),1) FROM dual;

SELECT FIND_IN_SET('a','b'),ceil(FIND_IN_SET('a','b,a')) FROM dual;
SELECT ceil(3.1415),FIND_IN_SET(ceil(3.1415),3) FROM dual;

SELECT FIND_IN_SET('a','b'),sin(FIND_IN_SET('a','b,a')) FROM dual;
SELECT sin(3.1415),FIND_IN_SET(sin(3.1415),3) FROM dual;

SELECT FIND_IN_SET('a','b'),cos(FIND_IN_SET('a','b,a')) FROM dual;
SELECT cos(3.1415),FIND_IN_SET(cos(3.1415),3) FROM dual;

SELECT FIND_IN_SET('a','b'),sign(FIND_IN_SET('a','b,a')) FROM dual;
SELECT sign(3.1415),FIND_IN_SET(sign(3.1415),3) FROM dual;

SELECT FIND_IN_SET('a','b'),floor(FIND_IN_SET('a','b,a')) FROM dual;
SELECT floor(3.1415),FIND_IN_SET(floor(3.1415),3) FROM dual;

SELECT FIND_IN_SET('a','b'),power(FIND_IN_SET('a','b,a'),2) FROM dual;
SELECT power(3,2),FIND_IN_SET(power(3,2),3) FROM dual;

SELECT FIND_IN_SET('a','b'),max(FIND_IN_SET('a','b,a')) FROM dual;
SELECT max(3.1415),FIND_IN_SET(max(3.1415),3) FROM dual;

SELECT FIND_IN_SET('a','b'),min(FIND_IN_SET('a','b,a')) FROM dual;
SELECT min(3.1415),FIND_IN_SET(min(3.1415),3.1415) FROM dual;

SELECT FIND_IN_SET('a','b'),mod(FIND_IN_SET('a','b,a'),2) FROM dual;
SELECT mod(3,2),FIND_IN_SET(mod(3,2),3) FROM dual;

SELECT FIND_IN_SET('a','ab'),round(FIND_IN_SET('a','ab,a')) FROM dual;
SELECT round(3.1415),FIND_IN_SET(round(3.1415),3) FROM dual;

SELECT FIND_IN_SET('a','b'),truncate(FIND_IN_SET('a','b,a'),2) FROM dual;
SELECT truncate(3.1415926,2),FIND_IN_SET(truncate(3.1415926,2),3) FROM dual;

SELECT FIND_IN_SET('a','b'),sqrt(FIND_IN_SET('a','b,a')) FROM dual;
SELECT sqrt(3.1415),FIND_IN_SET(sqrt(3.1415),3.1415) FROM dual;

SELECT FIND_IN_SET('a','b'),sum(FIND_IN_SET('a','b,a')) FROM dual;
SELECT sum(3.1415),FIND_IN_SET(sum(3.1415),3.1415) FROM dual;
SELECT sum(3.1415),FIND_IN_SET('@[]',';,;,@[]') FROM dual;

--echo ## 字符函数
SELECT FIND_IN_SET('mysql','MySQL'),upper(FIND_IN_SET('mysql','MySQL')) FROM dual;
SELECT upper('oceanbase'),FIND_IN_SET(upper('oceanbase'),'OCEANBASE') FROM dual;

SELECT FIND_IN_SET('mysql','MySQL'),lower(FIND_IN_SET('mysql','MySQL')) FROM dual;
SELECT lower('oceanbase'),FIND_IN_SET(lower('oceanbase'),'OCEANBASE') FROM dual;

SELECT FIND_IN_SET('mysql','MySQL'),instr(FIND_IN_SET('mysql','MySQL'),'1') FROM dual;
SELECT instr('oceanbase','b'),FIND_IN_SET(instr('oceanbase','b'),'OCEANBASE') FROM dual;

SELECT FIND_IN_SET('mysql','MySQL'),length(FIND_IN_SET('mysql','MySQL')) FROM dual;
SELECT length('oceanbase'),FIND_IN_SET(length('oceanbase'),8) FROM dual;

SELECT FIND_IN_SET('mysql','MySQL'),replace(FIND_IN_SET('mysql','MySQL'),'1','&') FROM dual;
SELECT replace('oceanbase','e','@'),FIND_IN_SET(replace('oceanbase','e','@'),'OCEANBASE') FROM dual;

SELECT FIND_IN_SET('mysql','MySQL'),substr(FIND_IN_SET('mysql','MySQL'),0,2) FROM dual;
SELECT substr('oceanbase',1,5),FIND_IN_SET(substr('oceanbase',1,5),'OCEANBASE') FROM dual;

SELECT FIND_IN_SET('mysql','MySQL'),concat(FIND_IN_SET('mysql','MySQL'),'--') FROM dual;
SELECT concat('oceanbase',' mysql'),FIND_IN_SET(concat('oceanbase',' mysql'),'oceanbase mysql') FROM dual;


--echo ## 日期函数
SELECT FIND_IN_SET(SYSDATE(),'2023-06-25') FROM dual;

SELECT FIND_IN_SET('oracle','oracle'),FROM_DAYS(FIND_IN_SET('mysql','mysql')) FROM dual;
SELECT FROM_DAYS(199),FIND_IN_SET(FROM_DAYS('199'),'20220910') FROM dual;


--echo ##通用函数
SELECT FIND_IN_SET('mysql','oracle'),ifnull(null,FIND_IN_SET('mysql','oracle')) FROM dual;
SELECT ifnull('oceanbase',null),FIND_IN_SET(ifnull('oceanbase',null),'OCEANBASE') FROM dual;

SELECT FIND_IN_SET('mysql','oracle'),coalesce(null,FIND_IN_SET('mysql','oracle')) FROM dual;
SELECT coalesce('oceanbase',null),FIND_IN_SET(coalesce('oceanbase',null),'OCEANBASE') FROM dual;


--echo ### 标签：FIND_IN_SET-6-3 多级函数嵌套  
SELECT FIND_IN_SET(FIND_IN_SET(FIND_IN_SET(FIND_IN_SET(FIND_IN_SET(FIND_IN_SET('china','china'),'1'),'1'),'1'),'1'),'1') FROM dual;
SELECT FIND_IN_SET('1',FIND_IN_SET('1',FIND_IN_SET('1',FIND_IN_SET('1',FIND_IN_SET('1',FIND_IN_SET('china','china'))))))  FROM dual;
SELECT FIND_IN_SET(FIND_IN_SET(FIND_IN_SET('a','ab'),'1'),FIND_IN_SET(FIND_IN_SET(FIND_IN_SET('a','ab'),'0'),'0')) FROM dual;

SELECT FIND_IN_SET(upper('oceanbase'),FIND_IN_SET(lower('oceanbase'),length('oceanbase'))) FROM dual;
SELECT ABS(FIND_IN_SET(floor(floor(floor(3.1415))),lower(upper('oceanbase')))) FROM dual;


SELECT FIND_IN_SET('"phone": "+118000000"','"phone": "+118000000"') FROM dual;
SELECT FIND_IN_SET('@!=a','@!=a') FROM dual;



--disable_warnings
DROP TABLE IF EXISTS T4;
--enable_warnings

CREATE TABLE T4(C1 float(0),C2 float(10,10));

INSERT INTO T4 VALUES (-1,NULL);

SELECT C1 FROM T4 GROUP BY C1,C1 WITH ROLLUP HAVING C1 = C1 AND FIND_IN_SET(C1,1) NOT BETWEEN 0.8 - 0.8 AND C1 - 1 MINUS  SELECT MIN(C2) FROM T4 GROUP BY C1;

select FIND_IN_SET(0,'a,0,z');
select FIND_IN_SET(null,'a,0,z,null');
select FIND_IN_SET('1,null','1,null');
select FIND_IN_SET(0,'a,0,z');
select FIND_IN_SET(0,'a,0,z');
select FIND_IN_SET('','a,0,z');
select FIND_IN_SET('ascs','a,0,z,');
select FIND_IN_SET("c,d","a,b;c,d");

--error 0,1051
drop table test;
CREATE TABLE test (
  id INT AUTO_INCREMENT PRIMARY KEY,
  decimal_1 DECIMAL(5,2),
  decimal_2 DECIMAL(6,4),
  decimal_3 DECIMAL(10,6)
);

INSERT INTO test (decimal_1, decimal_2, decimal_3) VALUES
  (12.4, 12.4, 12.4),
  (12.4, 12.4, 12.4),
  (12.4, 12.4, 12.4);

 
select FIND_IN_SET(decimal_1,decimal_2) from test;
select FIND_IN_SET(decimal_2,decimal_3) from test;
select FIND_IN_SET(decimal_3,decimal_1) from test;


SELECT REVERSE(bin('1')),FIND_IN_SET(1,'1,2,3,4,5') FIND_IN_SET FROM DUAL;
--error 1582
SELECT REVERSE(bin('1.5')),FIND_IN_SET('1.5','str1','str2','str3','str4','str5') FIND_IN_SET FROM DUAL;

SELECT REVERSE(bin('1')),FIND_IN_SET(1,'1,2,3,4,5') FIND_IN_SET FROM DUAL;
SELECT REVERSE(bin('1.5')),FIND_IN_SET(1.5,'1,2,3,4,5') FIND_IN_SET FROM DUAL;

SELECT REVERSE(bin('2')),FIND_IN_SET(0.5,'1,2,3,4,0.5') FIND_IN_SET FROM DUAL;
SELECT FIND_IN_SET(cast(1.23 as float),'1.230,繁體ing') a FROM DUAL;
SELECT REVERSE(bin(FIND_IN_SET(0.5,'1,2,3,4,0.5'))),FIND_IN_SET('2.5','str1,str2,str3,str4,str5') FIND_IN_SET FROM DUAL;

select FIND_IN_SET(CONCAT('test','obclient', NULL),'testobclient1.0') from DUAL;
select FIND_IN_SET(BINARY HEX(255),CONCAT('F','F')) from DUAL;

SELECT CONCAT('test','obclient', '1.0'), CONCAT('test','obclient', NULL) from dual;


SELECT 
    CASE 
        WHEN FIND_IN_SET('apple', 'apple,orange,banana') > 0 THEN 'fruit'
        WHEN FIND_IN_SET('carrot', 'carrot,potato,pepper') > 0 THEN 'vegetable'
        ELSE 'unknown'
    END AS category;

--echo # Clean up users
connection default;
--disable_warnings
--error 0,1396
drop user ljh@'%';
--enable_warnings
