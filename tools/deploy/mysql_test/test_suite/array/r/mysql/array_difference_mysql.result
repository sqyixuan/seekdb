array_difference([1,5,3])
[0,4,-2]
select array_difference([10]);
array_difference([10])
[0]
select array_difference([1,2,3,NULL]);
ERROR 0A000: array_difference with array contains null element not supported
select array_difference([1/3]);
array_difference([1/3])
[0]
select array_difference([1.1,2.2,4.4]);
array_difference([1.1,2.2,4.4])
[0,1.1,2.2]
select array_difference(['a','b','c','d']);
ERROR 0A000: array_difference with non-numeric type not supported
select array_difference(["hello", "hi"]);
ERROR 0A000: array_difference with non-numeric type not supported
select array_difference([[NULL],NULL]);
ERROR 0A000: array_difference with multi-dimension array not supported
select array_difference([[1,2]]);
ERROR 0A000: array_difference with multi-dimension array not supported
select array_difference([[1],[2]]);
ERROR 0A000: array_difference with multi-dimension array not supported
select array_difference(array_append([1,2,3], 4));
array_difference(array_append([1,2,3], 4))
[0,1,1,1]
