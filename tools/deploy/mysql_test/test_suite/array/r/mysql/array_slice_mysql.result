select array_slice([1,2,3], 1, 2);
array_slice([1,2,3], 1, 2)
[1,2]
select array_slice([1,2,3], 1, 4);
array_slice([1,2,3], 1, 4)
[1,2,3]
select array_slice([1,2,3], 1, 0);
array_slice([1,2,3], 1, 0)
[]
select array_slice([1,2,3], 1, -1);
array_slice([1,2,3], 1, -1)
[1,2]
select array_slice([1,2,3], 1, -2);
array_slice([1,2,3], 1, -2)
[1]
select array_slice([1,2,3], 1, -7);
array_slice([1,2,3], 1, -7)
[]
select array_slice([1,2,3], -2, -1);
array_slice([1,2,3], -2, -1)
[2]
select array_slice([1,2,3], "-100", "-1");
array_slice([1,2,3], "-100", "-1")
[1,2]
select array_slice([1,2,3], "1a", "2a");
array_slice([1,2,3], "1a", "2a")
[1,2]
