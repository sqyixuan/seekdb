drop database if exists array_rollup;
create database array_rollup;
use array_rollup;
create table t0 (c1 int, c2 bigint, c3 array(int), c4 array(varchar(16)), c5 varchar(100), c6 decimal(20,2), c7 map(int,float), c8 map(varchar(100),varchar(100)), c9 map(int,array(int)));
