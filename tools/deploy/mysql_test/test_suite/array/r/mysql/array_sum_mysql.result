drop table if exists t1;
select array_sum([9223372036854775807,1]);
ERROR 22003: Array value is out of range in 'BIGINT'
select array_sum([-9223372036854775808,-1]);
ERROR 22003: Array value is out of range in 'BIGINT'
select array_sum([1.7976931348623157E+308,1.1E+300]);
ERROR 22003: Array value is out of range in 'DOUBLE'
select array_sum([1.7976931348623157E+308,1.0E+308]);
ERROR 22003: Array value is out of range in 'DOUBLE'
select array_sum([18446744073709551615,18446744073709551614]);
ERROR 22003: Array value is out of range in 'BIGINT UNSIGNED'
select array_sum([NULL]);
array_sum([NULL])
0
select array_sum([1,2,3]);
array_sum([1,2,3])
6
select array_sum([1,2,4]);
array_sum([1,2,4])
7
select array_sum([1,2,-4]);
array_sum([1,2,-4])
-1
select array_sum([1.1,2.2,4.4]);
array_sum([1.1,2.2,4.4])
7.700000000000001
select array_sum([1,3,NULL,3]);
array_sum([1,3,NULL,3])
7
select array_sum([18446744073709551615]);
array_sum([18446744073709551615])
18446744073709551615
select array_sum([[1,2]]);
ERROR 0A000: array_sum with multi-dimension array not supported
select array_sum([[1],[2]]);
ERROR 0A000: array_sum with multi-dimension array not supported
select array_sum(['1','2']);
ERROR 0A000: array_sum with non-numeric element type not supported
select array_sum(array_append([1,2,3],4));
array_sum(array_append([1,2,3],4))
10
