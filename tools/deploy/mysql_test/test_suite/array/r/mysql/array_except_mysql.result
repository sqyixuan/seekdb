arr_utint Array(TINYINT UNSIGNED),
arr_usint Array(SMALLINT UNSIGNED),
arr_usbigint Array(BIGINT UNSIGNED),
arr_vchar Array(VARCHAR(10)),
arr_double Array(DOUBLE),
arr_float Array(FLOAT),
c3 ARRAY(ARRAY(FLOAT)),
c4 ARRAY(ARRAY(double)),
c5 ARRAY(ARRAY(INT)),
c6 ARRAY(ARRAY(SMALLINT))
);
