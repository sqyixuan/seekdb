# ----------------------------------------------------------------------
# Test of array_slice.
# ----------------------------------------------------------------------
select array_except([1,2,3], [1,2]);
array_except([1,2,3], [1,2])
[3]
select array_except([1,1,2,2,3], [1,2]);
array_except([1,1,2,2,3], [1,2])
[3]
select array_except([1,2,3], [1,1,2]);
array_except([1,2,3], [1,1,2])
[3]
select array_except([1.1,2.2,1], [1]);
array_except([1.1,2.2,1], [1])
[1.1,2.2]
select array_except(["test", "array"], ["test"]);
array_except(["test", "array"], ["test"])
["array"]
select array_except(["test", "array"], [1,2]);
array_except(["test", "array"], [1,2])
["test","array"]
select array_except([1, null], [null]);
array_except([1, null], [null])
[1]
select array_except(null, [1]);
array_except(null, [1])
NULL
select array_except(array_remove([1],1),array_remove([1],1));
array_except(array_remove([1],1),array_remove([1],1))
[]
select array_except(array_remove([1],1), [1,2,3]);
array_except(array_remove([1],1), [1,2,3])
[]
select array_except([1,2,3], array_remove([1],1));
array_except([1,2,3], array_remove([1],1))
[1,2,3]
select array_except(["test", "array"], array_remove(["A"],"A"));
array_except(["test", "array"], array_remove(["A"],"A"))
["test","array"]
select array_except(array_remove(["A"],"A"), ["test", "array"]);
array_except(array_remove(["A"],"A"), ["test", "array"])
[]
select array_except([[1],[1],[3]],array_remove([[1]],[1]));
array_except([[1],[1],[3]],array_remove([[1]],[1]))
[[1],[3]]
select array_except(array_remove([[1]],[1]), [[1],[2],[3]]);
array_except(array_remove([[1]],[1]), [[1],[2],[3]])
[]
select array_except([1,2,3], NULL);
array_except([1,2,3], NULL)
NULL
select array_except(NULL, [1,2,3]);
array_except(NULL, [1,2,3])
NULL
select array_except(1, null);
