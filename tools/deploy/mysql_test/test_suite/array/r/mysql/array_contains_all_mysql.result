CREATE TABLE arr_t1(c1 int, c2 ARRAY(varchar(16)), c3 ARRAY(ARRAY(varchar(16))));
insert into arr_t1 values(1, ["hello", null, "hi", "what", "are you?"], [["hello", "world"], null, ["are you?"]]);
insert into arr_t1 values(2, ["hello", "world", null, "what", "Are you?"], [["hello", "world"], ["hi", "what"], ["Are you?"]]);
insert into arr_t1 values(3, ["hello", "world", "hi", "hat", "are you?"], [["hello", "world"], ["hi", "hat"], ["are you?"]]);
insert into arr_t1 values(4, ["hello", "world", "hi", null, "are You?"], [["hello", "world"], ["hi", "what"], ["are You?"]]);
insert into arr_t1 values(5, NULL, NULL);
