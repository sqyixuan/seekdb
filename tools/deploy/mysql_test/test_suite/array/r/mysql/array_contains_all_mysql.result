insert into arr_t1 values(4,  [1, 2, 3, 3], [[100, 314, 456, 788], [555, 787, 44]]);
insert into arr_t1 values(5,  NULL, NULL);
insert into arr_t2 values(1,  [2, 2, 3, 4], [[1, 2, 3, 4], [2, 2, 3, 4], [3, 2, 3, 4]]);
insert into arr_t2 values(2,  [1, 1, 3, 4], [[1, 2, 3, 4], [1, 3, 3, 4], [1, 2, 3, 5]]);
insert into arr_t2 values(3,  [1, 2, 2, 4], [[1, 2, 3, 4], [1, 3, 3, 4], [1, 2, 3, 5]]);
insert into arr_t2 values(4,  [1, 2, 3, 3], [[100, 314, 456, 788], [555, 787, 44]]);
insert into arr_t2 values(5,  NULL, NULL);
select t1.c1, t2.c1 from arr_t1 t1, arr_t2 t2 where array_contains_all(t1.c2, t2.c2);
