# ----------------------------------------------------------------------
# Test of vector basic.
# ----------------------------------------------------------------------
drop database if exists yjl_vec;
create database yjl_vec;
use yjl_vec;
drop table if exists t_vec;
create table t_vec(c1 int, c2 vector(3), primary key(c2));
ERROR 42000: The used storage engine can't index column 'c2'
create table t_vec(c1 int, c2 vector(3), primary key(c1), index idx1(c2));
ERROR 0A000: vector column index but not vector index is not supported
create table t_vec(c1 int, c2 vector(3), primary key(c1));
create index idx1 on t_vec(c2);
ERROR 0A000: create index on vector or array column is not supported
create unique index idx1 on t_vec(c2);
ERROR 0A000: create index on vector or array column is not supported
alter table t_vec add index idx1(c2);
ERROR 0A000: create index on vector column is not supported
create table t_vec (c1 int, c2 vector(3), c3 vector(3), c4 vector(3), c5 vector(3), c6 vector(3)) LOB_INROW_THRESHOLD=393216;
ERROR 42000: Row size too large
create table t_vec (c1 int, c2 roaringbitmap, c3 roaringbitmap, c4 roaringbitmap, c5 roaringbitmap, c6 roaringbitmap) LOB_INROW_THRESHOLD=393216;
ERROR 42000: Row size too large
drop table if exists t_vec;
drop database if exists yjl_vec;
