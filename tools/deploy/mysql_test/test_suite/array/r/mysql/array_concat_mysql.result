# ----------------------------------------------------------------------
# Test of array_concat.
# ----------------------------------------------------------------------
drop table if exists t1, t2, t3;
select array_concat([1,2,3]);
array_concat([1,2,3])
[1,2,3]
select array_concat([1,2,3], [4]);
array_concat([1,2,3], [4])
[1,2,3,4]
select array_concat([1], [2,3,4]);
array_concat([1], [2,3,4])
[1,2,3,4]
select array_concat(NULL, [2,3,4]);
array_concat(NULL, [2,3,4])
NULL
select array_concat([1,2,3], [4], [5,6]);
array_concat([1,2,3], [4], [5,6])
[1,2,3,4,5,6]
select array_concat([1,2,3], [4.4]);
array_concat([1,2,3], [4.4])
[1,2,3,4.4]
select array_concat([1,2,3], [4.4], [NULL]);
array_concat([1,2,3], [4.4], [NULL])
[1,2,3,4.4,NULL]
select array_concat([1,2,3], [1/3]);
array_concat([1,2,3], [1/3])
[1,2,3,0.333333333]
select array_concat([1,2,3], ['a']);
array_concat([1,2,3], ['a'])
["1","2","3","a"]
select array_concat([1,2,3], [-4], [5.5,6]);
array_concat([1,2,3], [-4], [5.5,6])
[1,2,3,-4,5.5,6]
select array_concat([1.1,2.2,3]);
array_concat([1.1,2.2,3])
[1.1,2.2,3]
select array_concat([1.1,2.2,3], [4]);
array_concat([1.1,2.2,3], [4])
[1.1,2.2,3,4]
select array_concat(['hi', 'hello']);
array_concat(['hi', 'hello'])
["hi","hello"]
select array_concat(['hi', 'hello'], NULL);
array_concat(['hi', 'hello'], NULL)
NULL
select array_concat(['hi', 'hello'], ['oceanbase']);
array_concat(['hi', 'hello'], ['oceanbase'])
["hi","hello","oceanbase"]
select array_concat(['hi', 'hello'], ['oceanbase'], ['1','a']);
array_concat(['hi', 'hello'], ['oceanbase'], ['1','a'])
["hi","hello","oceanbase","1","a"]
select array_concat(['hi', 'hello'], [1]);
array_concat(['hi', 'hello'], [1])
["hi","hello","1"]
select array_concat([1,2,3], [[1]]);
ERROR 22000: array type mismatch found between definition and data
select array_concat([[1,2,3]],[[11]]);
array_concat([[1,2,3]],[[11]])
[[1,2,3],[11]]
select array_concat([[1,2,3]],[[11],[22,44]]);
array_concat([[1,2,3]],[[11],[22,44]])
[[1,2,3],[11],[22,44]]
select array_concat([[1,2,3]],[[11],[22,44],[5.5]]);
array_concat([[1,2,3]],[[11],[22,44],[5.5]])
[[1,2,3],[11],[22,44],[5.5]]
select array_concat([[1,2,3]],[[11],[22,44,NULL],[5.5]]);
array_concat([[1,2,3]],[[11],[22,44,NULL],[5.5]])
[[1,2,3],[11],[22,44,NULL],[5.5]]
select array_concat([[1,2,3]],[[11],[22,44,NULL],[5.5]], NULL);
array_concat([[1,2,3]],[[11],[22,44,NULL],[5.5]], NULL)
NULL
select array_concat([[1,2,3]],[[11],[22,44]],[[5.5]]);
array_concat([[1,2,3]],[[11],[22,44]],[[5.5]])
[[1,2,3],[11],[22,44],[5.5]]
select array_concat([[1,2,3]],[[11],[22,44]],[['a']]);
array_concat([[1,2,3]],[[11],[22,44]],[['a']])
[["1","2","3"],["11"],["22","44"],["a"]]
select array_concat([['hi', 'hello']], [['oceanbase'], ['how', 'are', 'you']]);
array_concat([['hi', 'hello']], [['oceanbase'], ['how', 'are', 'you']])
[["hi","hello"],["oceanbase"],["how","are","you"]]
