# ----------------------------------------------------------------------
# Test of cardinality.
# ----------------------------------------------------------------------
drop table if exists t1, t2;
select cardinality([NULL]);
cardinality([NULL])
1
select cardinality([1,2,3]);
cardinality([1,2,3])
3
select cardinality([1,2,3,NULL]);
cardinality([1,2,3,NULL])
4
select cardinality([1.1,2.2]);
cardinality([1.1,2.2])
2
select cardinality(['a','b','c','d']);
cardinality(['a','b','c','d'])
4
select cardinality(["hello", "hi"]);
cardinality(["hello", "hi"])
2
select cardinality([[NULL],NULL]);
cardinality([[NULL],NULL])
1
select cardinality([[1,2,3],[4]]);
cardinality([[1,2,3],[4]])
4
select cardinality([[1,2,3,NULL],[4,NULL]]);
cardinality([[1,2,3,NULL],[4,NULL]])
6
select cardinality([[1,2],[NULL,NULL]]);
cardinality([[1,2],[NULL,NULL]])
4
select cardinality([['a','b','c','d']]);
cardinality([['a','b','c','d']])
4
select cardinality([['a','b','c'],['d']]);
cardinality([['a','b','c'],['d']])
4
select cardinality([['a','b',NULL,'c'],[NULL,'d']]);
cardinality([['a','b',NULL,'c'],[NULL,'d']])
6
select cardinality([['a','b',NULL,'c'],[NULL,'d'],NULL]);
cardinality([['a','b',NULL,'c'],[NULL,'d'],NULL])
6
select cardinality([["hello", "world"], ["hi", "what"], ["are you?"]]);
cardinality([["hello", "world"], ["hi", "what"], ["are you?"]])
5
select cardinality(element_at([1,2,3], 2));
ERROR 22000: invalid obj type for type promotion: left_type=ARRAY right_type=BIGINT
select cardinality(element_at([[1,2],[3,4]], 1));
cardinality(element_at([[1,2],[3,4]], 1))
2
select cardinality(element_at([[1,2],[3,4]], 10));
cardinality(element_at([[1,2],[3,4]], 10))
NULL
select cardinality(element_at([["hello", "world"], ["hi", "what"], ["are you?"]], 3));
cardinality(element_at([["hello", "world"], ["hi", "what"], ["are you?"]], 3))
1
select cardinality(array_append([1,2,3], 4));
cardinality(array_append([1,2,3], 4))
4
select cardinality(array_append([["hello", "world"], ["hi", "what"], ["are you?"]], [NULL, "OceanBase"]));
cardinality(array_append([["hello", "world"], ["hi", "what"], ["are you?"]], [NULL, "OceanBase"]))
7
CREATE TABLE t1 (id int, c1 Array(BigInt), c2 Array(double), c3 Array(varchar(1)), c4 Array(varchar(10)), c5 vector(3));
INSERT INTO t1(id) VALUES(1);
INSERT INTO t1 VALUES(2, [NULL], [NULL], [NULL], [NULL], [0,0,0]);
INSERT INTO t1 VALUES(3, [1,2,NULL,3], [1.1,2.2,NULL,3.3], ['a','b',NULL,'c'], ['hello','world',NULL,'Ocean'], [1,2,3]);
select id, cardinality(c1), cardinality(c2), cardinality(c3), cardinality(c4), cardinality(c5) from t1;
id	cardinality(c1)	cardinality(c2)	cardinality(c3)	cardinality(c4)	cardinality(c5)
1	NULL	NULL	NULL	NULL	NULL
2	1	1	1	1	3
3	4	4	4	4	3
select /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */ id, cardinality(c1), cardinality(c2), cardinality(c3), cardinality(c4), cardinality(c5) from t1;
id	cardinality(c1)	cardinality(c2)	cardinality(c3)	cardinality(c4)	cardinality(c5)
1	NULL	NULL	NULL	NULL	NULL
2	1	1	1	1	3
3	4	4	4	4	3
select /*+ OPT_PARAM('rowsets_enabled', 'FALSE') */ id, cardinality(c1), cardinality(c2), cardinality(c3), cardinality(c4), cardinality(c5) from t1;
id	cardinality(c1)	cardinality(c2)	cardinality(c3)	cardinality(c4)	cardinality(c5)
1	NULL	NULL	NULL	NULL	NULL
2	1	1	1	1	3
3	4	4	4	4	3
create table t2 (id int, c1 int[][], c2 float[][], c3 varchar(1)[][], c4 varchar(10)[][]);
INSERT INTO t2(id) VALUES(1);
INSERT INTO t2 VALUES(2, [[NULL]], [[NULL]], [[NULL]], [[NULL]]);
INSERT INTO t2 VALUES(3, [[1,2,3],[4,NULL]], [[1.1,2.2,3.3],[4.4,NULL]], [['a','b','c'],['d',NULL]], [['hello', 'world'], ['hi',NULL]]);
INSERT INTO t2 VALUES(4, [[1,2,3],[4,NULL],NULL], [[1.1,2.2,3.3],[4.4,NULL],NULL], [['a','b','c'],['d',NULL],NULL], [['hello', 'world'], ['hi',NULL],NULL]);
select id, cardinality(c1), cardinality(c2), cardinality(c3), cardinality(c4) from t2;
id	cardinality(c1)	cardinality(c2)	cardinality(c3)	cardinality(c4)
1	NULL	NULL	NULL	NULL
2	1	1	1	1
3	5	5	5	4
4	5	5	5	4
select /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */ id, cardinality(c1), cardinality(c2), cardinality(c3), cardinality(c4) from t2;
id	cardinality(c1)	cardinality(c2)	cardinality(c3)	cardinality(c4)
1	NULL	NULL	NULL	NULL
2	1	1	1	1
3	5	5	5	4
4	5	5	5	4
select /*+ OPT_PARAM('rowsets_enabled', 'FALSE') */ id, cardinality(c1), cardinality(c2), cardinality(c3), cardinality(c4) from t2;
id	cardinality(c1)	cardinality(c2)	cardinality(c3)	cardinality(c4)
1	NULL	NULL	NULL	NULL
2	1	1	1	1
3	5	5	5	4
4	5	5	5	4
