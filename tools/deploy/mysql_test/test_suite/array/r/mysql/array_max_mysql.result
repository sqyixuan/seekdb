drop table if exists t_create;
create table t_create as select array_max(NULL), array_max([1,2,3,4]), array_min(NULL), array_min([1,2,3,4]);
desc t_create;
Field	Type	Null	Key	Default	Extra
array_max(NULL)	tinyint unsigned	YES		NULL	
array_max([1,2,3,4])	bigint(20)	YES		NULL	
array_min(NULL)	tinyint unsigned	YES		NULL	
array_min([1,2,3,4])	bigint(20)	YES		NULL	
select * from t_create;
array_max(NULL)	array_max([1,2,3,4])	array_min(NULL)	array_min([1,2,3,4])
NULL	4	NULL	1
drop table t_create;
create table t_create as select array_max(NULL), array_max(arr_tint), array_min(NULL), array_min(arr_tint) from t1;
desc t_create;
Field	Type	Null	Key	Default	Extra
array_max(NULL)	tinyint unsigned	YES		NULL	
array_max(arr_tint)	tinyint(4)	YES		NULL	
array_min(NULL)	tinyint unsigned	YES		NULL	
array_min(arr_tint)	tinyint(4)	YES		NULL	
select * from t_create;
array_max(NULL)	array_max(arr_tint)	array_min(NULL)	array_min(arr_tint)
NULL	NULL	NULL	NULL
NULL	2	NULL	-1
NULL	127	NULL	-128
drop table t_create;
with array_data as (
select id, arr_tint from t1
where id IN (2, 3)
)
select id, array_max(arr_tint), array_min(arr_tint) from array_data order by id;
id	array_max(arr_tint)	array_min(arr_tint)
2	2	-1
3	127	-128
with tmax as (
select id, array_max(arr_tint), array_min(arr_tint) from t1
)
select * from tmax order by id;
id	array_max(arr_tint)	array_min(arr_tint)
1	NULL	NULL
2	2	-1
3	127	-128
INSERT IGNORE INTO t1(id, arr_tint) select id + 2, [array_max(arr_tint), array_min(arr_tint)] from t1;
INSERT INTO t1(id, arr_tint) VALUES(6, [array_max(null)]);
INSERT INTO t1(id, arr_tint) VALUES(7, [null]);
REPLACE INTO t1(id, arr_tint) VALUES(7, [array_max([1,2,4]), array_min([1,2,4])]);
select id, arr_tint from t1 order by id;
id	arr_tint
1	NULL
2	[-1,2,1]
