# ----------------------------------------------------------------------
# Test of array_max.
# ----------------------------------------------------------------------
drop table if exists t1;
select array_max([NULL]);
array_max([NULL])
NULL
select array_max([1,2,3]);
array_max([1,2,3])
3
select array_max([1,2,4]);
array_max([1,2,4])
4
select array_max([1,2,-4]);
array_max([1,2,-4])
2
select array_max([1.1,2.2,4.4]);
array_max([1.1,2.2,4.4])
4.4
select array_max([1,2,NULL,3]);
array_max([1,2,NULL,3])
3
select array_max([[1,2]]);
ERROR 0A000: nested array not supported
select array_max([[1],[2]]);
ERROR 0A000: nested array not supported
select array_max(['1','2']);
array_max(['1','2'])
2
select array_max(['a','b','c','d']);
array_max(['a','b','c','d'])
d
select array_max(["hello", "hi"]);
array_max(["hello", "hi"])
hi
select array_max(['a','b',NULL,'c','d',NULL]);
array_max(['a','b',NULL,'c','d',NULL])
d
select array_max(array_append([1,2,3],4));
array_max(array_append([1,2,3],4))
4
select array_max(array_append(["hello", "world"],'OceanBase'));
array_max(array_append(["hello", "world"],'OceanBase'))
world
select array_min([NULL]);
array_min([NULL])
NULL
select array_min([1,2,3]);
array_min([1,2,3])
1
select array_min([1,2,4]);
array_min([1,2,4])
1
select array_min([1,2,-4]);
array_min([1,2,-4])
-4
select array_min([1.1,2.2,4.4]);
array_min([1.1,2.2,4.4])
1.1
select array_min([1,2,NULL,3]);
array_min([1,2,NULL,3])
1
select array_min([[1,2]]);
ERROR 0A000: nested array not supported
select array_min([[1],[2]]);
ERROR 0A000: nested array not supported
select array_min(['1','2']);
array_min(['1','2'])
1
select array_min(['a','b','c','d']);
array_min(['a','b','c','d'])
a
select array_min(["hello", "hi"]);
array_min(["hello", "hi"])
hello
select array_min(['a','b',NULL,'c','d',NULL]);
array_min(['a','b',NULL,'c','d',NULL])
a
select array_min(array_append([1,2,3],4));
array_min(array_append([1,2,3],4))
1
select array_min(array_append(["hello", "world"],'OceanBase'));
array_min(array_append(["hello", "world"],'OceanBase'))
OceanBase
