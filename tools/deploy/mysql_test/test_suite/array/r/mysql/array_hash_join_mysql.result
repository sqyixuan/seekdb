alter system set _rowsets_max_rows = 3 tenant=all_meta;


drop database if exists array_hash_join;
create database array_hash_join;
use array_hash_join;

create table t1 (c1 int, c2 bigint, c3 array(int), c4 array(varchar(16)), c5 varchar(100), c6 decimal(20,2));
