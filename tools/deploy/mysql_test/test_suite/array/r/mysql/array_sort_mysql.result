drop table if exists t_create;
create table t_create as select array_sort(NULL), array_sort([1,2,5,4]);
desc t_create;
Field	Type	Null	Key	Default	Extra
array_sort(NULL)	binary(0)	YES		NULL	
array_sort([1,2,5,4])	ARRAY(BIGINT)	YES		NULL	
select * from t_create;
