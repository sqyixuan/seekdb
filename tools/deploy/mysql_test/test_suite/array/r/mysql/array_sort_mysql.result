# ----------------------------------------------------------------------
# Test of array_sort.
# ----------------------------------------------------------------------
drop table if exists t1;
select array_sort([NULL]);
array_sort([NULL])
[NULL]
select array_sort([NULL,NULL,NULL]);
array_sort([NULL,NULL,NULL])
[NULL,NULL,NULL]
select array_sort([2,1,3]);
array_sort([2,1,3])
[1,2,3]
select array_sort([2,-1,3]);
array_sort([2,-1,3])
[-1,2,3]
select array_sort([2.1,3,1,1]);
array_sort([2.1,3,1,1])
[1,1,2.1,3]
select array_sort([NULL,1,2,NULL,2,NULL,NULL]);
array_sort([NULL,1,2,NULL,2,NULL,NULL])
[1,2,2,NULL,NULL,NULL,NULL]
select array_sort([1.1,2.2]);
array_sort([1.1,2.2])
[1.1,2.2]
select array_sort([1.1,2.3,2.2]);
array_sort([1.1,2.3,2.2])
[1.1,2.2,2.3]
select array_sort(['a','b','c','d']);
array_sort(['a','b','c','d'])
["a","b","c","d"]
select array_sort(['a','a','A',NULL]);
array_sort(['a','a','A',NULL])
["A","a","a",NULL]
select array_sort(["hello", "hi"]);
array_sort(["hello", "hi"])
["hello","hi"]
select array_sort(["hello","hello",NULL,NULL,"OceanBase"]);
array_sort(["hello","hello",NULL,NULL,"OceanBase"])
["OceanBase","hello","hello",NULL,NULL]
select array_sort([[NULL],NULL]);
ERROR 0A000: array_sort with multi-dimension array not supported
select array_sort([[1,2,3],[4]]);
ERROR 0A000: array_sort with multi-dimension array not supported
select array_sort(element_at([1,2,3], 2));
ERROR 22000: invalid obj type for type promotion: left_type=ARRAY right_type=BIGINT
select array_sort(element_at([[1,2],[3,4]], 1));
array_sort(element_at([[1,2],[3,4]], 1))
[1,2]
CREATE TABLE t1 (id int primary key, c1 Array(BigInt), c2 Array(BigInt UNSIGNED), c3 Array(double), c4 vector(3));
INSERT INTO t1(id) VALUES(1);
INSERT INTO t1 VALUES(2, [NULL], [NULL], [NULL], [0,0,0]);
INSERT INTO t1 VALUES(3, [-9223372036854775808,9223372036854775807,NULL,0,NULL], [cast(9223372036854775807 as unsigned),18446744073709551615,NULL,cast(0 as unsigned),NULL], [1.1,1.2,NULL,3.3], [1,3,2]);
select id, array_sort(c1), array_sort(c2), array_sort(c3), array_sort(c4) from t1;
