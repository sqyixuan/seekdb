# ----------------------------------------------------------------------
# Test of array_length.
# ----------------------------------------------------------------------
select array_length([NULL]);
array_length([NULL])
1
select array_length([0,1,2]);
array_length([0,1,2])
3
select array_length([NULL,1,2]);
array_length([NULL,1,2])
3
select array_length([1.5,2.5]);
array_length([1.5,2.5])
2
select array_length(['a','b','c','d']);
array_length(['a','b','c','d'])
4
select array_length(["hello", "hi"]);
array_length(["hello", "hi"])
2
select array_length([[NULL],NULL]);
array_length([[NULL],NULL])
2
select array_length([[1,2,3],[4]]);
array_length([[1,2,3],[4]])
2
select array_length([[1,2,3,NULL],[4,NULL]]);
array_length([[1,2,3,NULL],[4,NULL]])
2
select array_length([[1,2],[NULL,NULL]]);
array_length([[1,2],[NULL,NULL]])
2
select array_length([['a','b','c','d']]);
array_length([['a','b','c','d']])
1
select array_length([['a','b','c'],['d']]);
array_length([['a','b','c'],['d']])
2
select array_length([['a','b',NULL,'c'],[NULL,'d']]);
array_length([['a','b',NULL,'c'],[NULL,'d']])
2
select array_length([['a','b',NULL,'c'],[NULL,'d'],NULL]);
array_length([['a','b',NULL,'c'],[NULL,'d'],NULL])
3
select array_length([["hello", "world"], ["hi", "what"], ["are you?"]]);
array_length([["hello", "world"], ["hi", "what"], ["are you?"]])
3
drop table if exists array_test;
CREATE TABLE array_test (
id int primary key, 
c1 Array(BigInt), 
c2 Array(double), 
c3 Array(varchar(10)), 
c4 vector(3),
c5 Array(Array(BigInt)),
c6 Array(Array(varchar(10)))
);
INSERT INTO array_test VALUES(1, [NULL], [NULL], [NULL], [0,0,0], [[NULL]], [[NULL]]);
INSERT INTO array_test VALUES(2, [1,2,NULL,3], [1.1,2.2,NULL,3.3], ['hello','world',NULL,'Ocean'], [1,2,3], [[1,2],[3]], [['what'],['yes','no']]);
select id, array_length(c1), array_length(c2), array_length(c3), array_length(c4), array_length(c5), array_length(c6) from array_test;
id	array_length(c1)	array_length(c2)	array_length(c3)	array_length(c4)	array_length(c5)	array_length(c6)
1	1	1	1	3	1	1
2	4	4	4	3	2	2
select /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */ id, array_length(c1), array_length(c2), array_length(c3), array_length(c4), array_length(c5), array_length(c6) from array_test;
id	array_length(c1)	array_length(c2)	array_length(c3)	array_length(c4)	array_length(c5)	array_length(c6)
1	1	1	1	3	1	1
2	4	4	4	3	2	2
select /*+ OPT_PARAM('rowsets_enabled', 'FALSE') */ id, array_length(c1), array_length(c2), array_length(c3), array_length(c4), array_length(c5), array_length(c6) from array_test;
id	array_length(c1)	array_length(c2)	array_length(c3)	array_length(c4)	array_length(c5)	array_length(c6)
1	1	1	1	3	1	1
2	4	4	4	3	2	2
drop table if exists t_create;
create table t_create as select array_length(NULL), array_length([1,3,5]);
desc t_create;
Field	Type	Null	Key	Default	Extra
array_length(NULL)	int(10) unsigned	YES		NULL	
array_length([1,3,5])	int(10) unsigned	YES		NULL	
select * from t_create;
array_length(NULL)	array_length([1,3,5])
NULL	3
drop table t_create;
create table t_create as select array_length(NULL), array_length(c1) from array_test;
desc t_create;
Field	Type	Null	Key	Default	Extra
array_length(NULL)	int(10) unsigned	YES		NULL	
array_length(c1)	int(10) unsigned	YES		NULL	
select * from t_create;
array_length(NULL)	array_length(c1)
NULL	1
NULL	4
drop table t_create;
with array_data as (
select id, c1 from array_test
)
select id, array_length(c1) from array_data order by id;
id	array_length(c1)
1	1
2	4
with tlen as (
select id, array_length(c1) from array_test
)
select * from tlen order by id;
id	array_length(c1)
1	1
2	4
insert IGNORE into array_test(id, c1) select id + 2, [array_length(c1)] from array_test;
insert into array_test(id, c1) VALUES(6, [array_length(null)]);
REPLACE into array_test(id, c1) VALUES(5, [array_length(null)]);
select id, c1 from array_test order by id;
id	c1
1	[NULL]
2	[1,2,NULL,3]
3	[1]
4	[4]
5	[NULL]
6	[NULL]
update /*+ ENABLE_PARALLEL_DML parallel(256) */
array_test set c1 = [array_length(c1), array_length(c2), array_length(c3)];
update array_test set c1 = [array_length(null), array_length(c2), array_length(c3)] where id = 1;
select id, c1 from array_test order by id;
id	c1
1	[NULL,1,1]
2	[4,4,4]
3	[1,NULL,NULL]
4	[1,NULL,NULL]
5	[1,NULL,NULL]
6	[1,NULL,NULL]
drop table array_test;
select array_length(NULL);
array_length(NULL)
NULL
select array_length();
ERROR 42000: Incorrect parameter count in the call to native function 'array_length'
select array_length(1);
ERROR 22000: invalid obj type for type promotion: left_type=ARRAY right_type=BIGINT
drop table if exists table_21;
create table table_21(id int, c1 tinyint, array1 array(tinyint));
insert into table_21 values(1, 1, [1]);
insert into table_21 values(1, 0, null);
insert into table_21 values(1, 0, [null]);
insert into table_21 values(1, 0, [127,0,-128,null]);
select  array_prepend(array1,c1) from  table_21;
array_prepend(array1,c1)
[1,1]
NULL
[0,NULL]
[0,127,0,-128,NULL]
alter table table_21 add column (c2 int GENERATED ALWAYS AS (array_length(array1))  STORED);
alter table table_21 add column (c3 int GENERATED ALWAYS AS (array_length(array1))  VIRTUAL);
alter table table_21 drop column c2;
alter table table_21 drop column c3;
alter table table_21 add column (c2 int GENERATED ALWAYS AS (array_length(array1))  VIRTUAL);
alter table table_21 add column (c3 int GENERATED ALWAYS AS (array_length(array1))  STORED);
desc table_21;
Field	Type	Null	Key	Default	Extra
id	int(11)	YES		NULL	
c1	tinyint(4)	YES		NULL	
array1	ARRAY(TINYINT)	YES		NULL	
c2	int(11)	YES		array_length(`array1`)	VIRTUAL GENERATED
c3	int(11)	YES		array_length(`array1`)	STORED GENERATED
select * from table_21;
id	c1	array1	c2	c3
1	1	[1]	1	1
1	0	NULL	NULL	NULL
1	0	[NULL]	1	1
1	0	[127,0,-128,NULL]	4	4
drop table if exists table_21;
drop table if exists tt;
create table tt(id int, arr_int int[], arr_dint array(array(int)), arr_vec array(vector(1)), arr_char array(varchar(10)));
insert into tt values(1, [1], [[1], [2]], [[1], [2]], ['a', 'b']);
insert into tt values(2, null, [[1], [2]], [[1], [2]], ['a', 'b']);
insert into tt values(3, array_remove([1], 1), [[1], [2]], [[1], [2]], ['a', 'b']);
