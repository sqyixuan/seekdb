# ----------------------------------------------------------------------
# Test of element_at.
# ----------------------------------------------------------------------
drop table if exists t1, t2;
select element_at([1,2,3], '1');
element_at([1,2,3], '1')
1
select element_at([1,2,3], 1.1);
element_at([1,2,3], 1.1)
1
select element_at([1,2,3], 1.6);
element_at([1,2,3], 1.6)
2
select element_at([1,2,3], "1a");
element_at([1,2,3], "1a")
1
Warnings:
Warning	1292	Truncated incorrect INTEGER value: '1a'
select element_at([1,2,3], "1.6");
element_at([1,2,3], "1.6")
1
Warnings:
Warning	1292	Truncated incorrect INTEGER value: '1.6'
select element_at([1,2,3], '25e-1');
element_at([1,2,3], '25e-1')
NULL
Warnings:
Warning	1292	Truncated incorrect INTEGER value: '25e-1'
select element_at([1,2,3], 2);
element_at([1,2,3], 2)
2
select element_at([1,2,3], 0);
element_at([1,2,3], 0)
NULL
select element_at([1,2,3], 4);
element_at([1,2,3], 4)
NULL
select element_at([1,2,3], -1);
element_at([1,2,3], -1)
NULL
select element_at([1,NULL,3], 2);
element_at([1,NULL,3], 2)
NULL
select element_at([1.1,2.2,3.3], 2);
element_at([1.1,2.2,3.3], 2)
2.2
select element_at(['a','b','c'], 2);
element_at(['a','b','c'], 2)
b
select element_at(['a','bb','ccc'], 2);
element_at(['a','bb','ccc'], 2)
bb
select element_at(['a',NULL,'bb','ccc'], 2);
element_at(['a',NULL,'bb','ccc'], 2)
NULL
select element_at(['a',NULL,'bb','ccc'], 4);
element_at(['a',NULL,'bb','ccc'], 4)
ccc
select element_at([[1,2],[3,4]], 1);
element_at([[1,2],[3,4]], 1)
[1,2]
select element_at([[1.1,2.2],[3.3,4.4]], 2);
element_at([[1.1,2.2],[3.3,4.4]], 2)
[3.3,4.4]
select element_at([["a", "b"]], 1);
element_at([["a", "b"]], 1)
["a","b"]
select element_at([["hello", "world"], ["hi", "what"], ["are you?"]], 3);
element_at([["hello", "world"], ["hi", "what"], ["are you?"]], 3)
["are you?"]
