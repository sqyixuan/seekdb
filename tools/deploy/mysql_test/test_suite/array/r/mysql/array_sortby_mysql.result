[["a"],["b"],["c"]]
create table t2 (id int, vec vector(3));
insert into t2 values (1, [1.0, 4.0, 7.0]);
insert into t2 values (2, [2.0, 5.0, 8.0]);
insert into t2 values (3, [3.0, 6.0, 9.0]);
select array_sortby((x) -> (x), vec) from t2;
array_sortby((x) -> (x), vec)
[1,4,7]
[2,5,8]
[3,6,9]
select array_sortby((x) -> (x), [vec]) from t2;
ERROR 22000: Invalid data type for the operation
select array_sortby((x,y) -> (y), [[vec], [vec]], [2,1]) from t2;
array_sortby((x,y) -> (y), [[vec], [vec]], [2,1])
[[[1,4,7]],[[1,4,7]]]
[[[2,5,8]],[[2,5,8]]]
[[[3,6,9]],[[3,6,9]]]
select array_sortby((x,y) -> (y), vec, [3,1,2]) from t2;
array_sortby((x,y) -> (y), vec, [3,1,2])
[4,7,1]
[5,8,2]
[6,9,3]
