# ----------------------------------------------------------------------
# Test of array_sortby.
# ----------------------------------------------------------------------
select array_sortby(x ->(x),null);
array_sortby(x ->(x),null)
NULL
select array_sortby(x ->(x is null),null);
array_sortby(x ->(x is null),null)
NULL
select array_sortby(x ->(x),[1]);
array_sortby(x ->(x),[1])
[1]
select array_sortby(x ->(x),[1.1]);
array_sortby(x ->(x),[1.1])
[1.1]
select array_sortby(x ->(1),[1.1,2.2]);
array_sortby(x ->(1),[1.1,2.2])
[1.1,2.2]
select array_sortby(x ->(1),['hello','hi','world']);
array_sortby(x ->(1),['hello','hi','world'])
["hello","hi","world"]
select array_sortby(x ->(0),[[1],[2,3],NULL,[4,NULL],NULL]);
array_sortby(x ->(0),[[1],[2,3],NULL,[4,NULL],NULL])
[[1],[2,3],NULL,[4,NULL],NULL]
select array_sortby(x ->(x), [4,2,1,3]);
array_sortby(x ->(x), [4,2,1,3])
[1,2,3,4]
select array_sortby(x ->(x), [-4,2,1,-3,0]);
array_sortby(x ->(x), [-4,2,1,-3,0])
[-4,-3,0,1,2]
select array_sortby(x ->(x), [4.4,2.2,1.1,3.3]);
array_sortby(x ->(x), [4.4,2.2,1.1,3.3])
[1.1,2.2,3.3,4.4]
select array_sortby(x ->(x), ['c','b','a','d']);
array_sortby(x ->(x), ['c','b','a','d'])
["a","b","c","d"]
select array_sortby(x ->(x), ['hello','hi','world']);
array_sortby(x ->(x), ['hello','hi','world'])
["hello","hi","world"]
select array_sortby(x ->(x), [[4],[2,1],[3]]);
ERROR 22000: Invalid data type for the operation
select array_sortby(x ->(x), [4,NULL,1,3,NULL]);
array_sortby(x ->(x), [4,NULL,1,3,NULL])
[1,3,4,NULL,NULL]
select array_sortby(x ->(x), [4.4,NULL,1.1,3.3,NULL]);
array_sortby(x ->(x), [4.4,NULL,1.1,3.3,NULL])
[1.1,3.3,4.4,NULL,NULL]
select array_sortby(x ->(x), ['c',NULL,'a',NULL]);
array_sortby(x ->(x), ['c',NULL,'a',NULL])
["a","c",NULL,NULL]
select array_sortby(x ->(x),[-9223372036854775808, 0, 9223372036854775807]);
array_sortby(x ->(x),[-9223372036854775808, 0, 9223372036854775807])
[-9223372036854775808,0,9223372036854775807]
select array_sortby(x ->(x),[cast(0 as unsigned),18446744073709551615]);
array_sortby(x ->(x),[cast(0 as unsigned),18446744073709551615])
[0,18446744073709551615]
select array_sortby((x,y) ->(y),['a','b','c'], [2,1,3]);
array_sortby((x,y) ->(y),['a','b','c'], [2,1,3])
["b","a","c"]
select array_sortby((x,y,z) ->(y+z),['a','b','c'], [2,1,3], [4,0,2]);
array_sortby((x,y,z) ->(y+z),['a','b','c'], [2,1,3], [4,0,2])
["b","c","a"]
select array_sortby((x,y) ->(y),['a','b','c'], [NULL,1,3]);
array_sortby((x,y) ->(y),['a','b','c'], [NULL,1,3])
["b","c","a"]
select array_sortby(x ->(NULL), [[4],[2,1],[3]]);
array_sortby(x ->(NULL), [[4],[2,1],[3]])
[[4],[2,1],[3]]
select array_sortby(x ->(NULL), [4,NULL,1,3,NULL]);
array_sortby(x ->(NULL), [4,NULL,1,3,NULL])
[4,NULL,1,3,NULL]
select array_sortby(x ->(NULL), [4.4,NULL,1.1,3.3,NULL]);
array_sortby(x ->(NULL), [4.4,NULL,1.1,3.3,NULL])
[4.4,NULL,1.1,3.3,NULL]
select array_sortby(x ->(NULL), ['c',NULL,'a',NULL]);
array_sortby(x ->(NULL), ['c',NULL,'a',NULL])
["c",NULL,"a",NULL]
select array_sortby((x,x) -> (x+1), [1],[1]);
