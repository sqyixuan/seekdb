create table t1(c1 int primary key, c2 int[],c3 vector(3) , c4 vector(3),
VECTOR INDEX vector_idx(c4) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40)) partition by hash(c1) partitions 4;
replace into t1(c1, c2, c3) values(1,'[1,1,2]','[2,2,3]');
replace into t1(c1, c2, c3) values(2,'[1,-1,3]','[1,0,3]');
replace into t1(c1, c2, c3) values(3,null,null);
replace into t1(c1, c2, c3,c4) values(4,null,null,[1,2,3]);
select array_append([[c4]],[[1,2,3]]) from t1 order by c1;
array_append([[c4]],[[1,2,3]])
[[NULL],[[1,2,3]]]
[[NULL],[[1,2,3]]]
[[NULL],[[1,2,3]]]
[[[1,2,3]],[[1,2,3]]]
select array_append([[c2]],[[1,2,3]]) from t1 order by c1;
array_append([[c2]],[[1,2,3]])
