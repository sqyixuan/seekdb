select array_first(x ->(x = 'hi' ),['hello','hi','world']);
array_first(x ->(x = 'hi' ),['hello','hi','world'])
hi
select array_first((x,y,z) -> (x is null and y is not null or z is not null), [[1]], [1],['abc']);
array_first((x,y,z) -> (x is null and y is not null or z is not null), [[1]], [1],['abc'])
[1]
select array_first((x,y) ->(x > y),[1,2,3], [2,1,3]);
array_first((x,y) ->(x > y),[1,2,3], [2,1,3])
2
select array_first(x ->(array_contains(x, 10)), [[1,2,3],[10,11,12],[20,21,22]]);
array_first(x ->(array_contains(x, 10)), [[1,2,3],[10,11,12],[20,21,22]])
[10,11,12]
select array_first(x ->(array_contains(x, 'OceanBase')), [['Hello', 'World'],['hi'],['OB','OceanBase']]);
array_first(x ->(array_contains(x, 'OceanBase')), [['Hello', 'World'],['hi'],['OB','OceanBase']])
["OB","OceanBase"]
