drop table if exists t1, t2, t3;
create table t1 as select array_first(x -> (x > 2), [1.22, 3.44, 5.33]);
select * from t1;
array_first(x -> (x > 2), [1.22, 3.44, 5.33])
3.44
drop table t1;
create table t1 (id int PRIMARY KEY, c1 array(TINYINT), c2 array(BIGINT), c3 array(BIGINT UNSIGNED)) partition by hash(id) partitions 3;
insert into t1 (id) values (1);
insert into t1 values (2, [1,0,NULL], [1,0,NULL], [1,0,NULL]);
insert into t1 values (3, [-128, 0, 127], [-9223372036854775808,0,9223372036854775807], [cast(0 as unsigned), 9223372036854775808, 18446744073709551615]);
select id, array_first((x,y) -> (y), ['a','b','c'], c1) from t1 order by id;
id	array_first((x,y) -> (y), ['a','b','c'], c1)
1	NULL
2	a
3	a
select id, array_first((x,y) -> (y), [['a'],['b'],['c']], c1) from t1 order by id;
