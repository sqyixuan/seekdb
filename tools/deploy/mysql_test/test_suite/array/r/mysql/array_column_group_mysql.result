alter system set_tp tp_name = "EN_COMPACTION_DISABLE_ROW_COL_SWITCH", error_code = 4016, frequency = 1;
drop table if exists ct1,ct2,ct3,ct4;
set session ob_trx_timeout=100000000000;
set ob_query_timeout = 1000000000;
create table ct1(c1 int, id int, c2 array(int), c3 array(varchar(16)), c4 vector(1536)) with column group (all columns, each column);
create table ct2(c1 int, id int, c2 array(int), c3 array(varchar(16)), c4 vector(1536)) partition by hash (c1) partitions 5 with column group (all columns, each column);
create table ct3(c1 int, id int, c2 map(int,float), c3 map(varchar(100),varchar(100)), c4 map(int,array(int))) with column group (all columns, each column);
create table ct4(c1 int, id int, c2 map(int,float), c3 map(varchar(100),varchar(100)), c4 map(int,array(int))) partition by hash (c1) partitions 5 with column group (all columns, each column);
alter system minor freeze;
alter system major freeze;
select c1 from ct1 order by cardinality(c4) limit 100;
