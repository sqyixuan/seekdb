# ----------------------------------------------------------------------
# Test of array_compact.
# ----------------------------------------------------------------------
drop table if exists t1, t2;
select array_compact([NULL]);
array_compact([NULL])
[NULL]
select array_compact([NULL,NULL,NULL]);
array_compact([NULL,NULL,NULL])
[NULL]
select array_compact([1,2,3]);
array_compact([1,2,3])
[1,2,3]
select array_compact([1,1,2,1,1]);
array_compact([1,1,2,1,1])
[1,2,1]
select array_compact([NULL,NULL,1,2,NULL,2,NULL,NULL]);
array_compact([NULL,NULL,1,2,NULL,2,NULL,NULL])
[NULL,1,2,NULL,2,NULL]
select array_compact([1.1,2.2]);
array_compact([1.1,2.2])
[1.1,2.2]
select array_compact([1.1,2.2,2.2]);
array_compact([1.1,2.2,2.2])
[1.1,2.2]
select array_compact(['a','b','c','d']);
array_compact(['a','b','c','d'])
["a","b","c","d"]
select array_compact(['a','a','A',NULL]);
array_compact(['a','a','A',NULL])
["a","A",NULL]
select array_compact(["hello", "hi"]);
array_compact(["hello", "hi"])
["hello","hi"]
select array_compact(["hello","hello",NULL,NULL,"OceanBase"]);
array_compact(["hello","hello",NULL,NULL,"OceanBase"])
["hello",NULL,"OceanBase"]
select array_compact([[NULL],NULL]);
array_compact([[NULL],NULL])
[[NULL],NULL]
select array_compact([[1,2,3],[4]]);
array_compact([[1,2,3],[4]])
[[1,2,3],[4]]
select array_compact([[1,2,3],[1,2,3],[4],[4]]);
array_compact([[1,2,3],[1,2,3],[4],[4]])
[[1,2,3],[4]]
select array_compact([[1,2,3],NULL,NULL,[4,5],[4]]);
array_compact([[1,2,3],NULL,NULL,[4,5],[4]])
[[1,2,3],NULL,[4,5],[4]]
select array_compact([[1,2,3,NULL],[4,NULL],[4,NULL]]);
array_compact([[1,2,3,NULL],[4,NULL],[4,NULL]])
[[1,2,3,NULL],[4,NULL]]
select array_compact([[1.1],[1.1],[1.1,2.2],NULL,NULL]);
array_compact([[1.1],[1.1],[1.1,2.2],NULL,NULL])
[[1.1],[1.1,2.2],NULL]
select array_compact([['a','b','c','d'],['a','b','c','d'],['a','b','c','d']]);
array_compact([['a','b','c','d'],['a','b','c','d'],['a','b','c','d']])
[["a","b","c","d"]]
select array_compact([NULL,NULL,['a',NULL],['a',NULL],['d']]);
array_compact([NULL,NULL,['a',NULL],['a',NULL],['d']])
[NULL,["a",NULL],["d"]]
select array_compact([["hello", "world"],["hi", "what"],["hi", "what"],["are you?"]]);
array_compact([["hello", "world"],["hi", "what"],["hi", "what"],["are you?"]])
[["hello","world"],["hi","what"],["are you?"]]
select array_compact(element_at([1,2,3], 2));
ERROR 22000: invalid obj type for type promotion: left_type=ARRAY right_type=BIGINT
select array_compact(element_at([[1,2],[3,4]], 1));
array_compact(element_at([[1,2],[3,4]], 1))
[1,2]
select array_compact(element_at([[1,1],[4,4]], 1));
array_compact(element_at([[1,1],[4,4]], 1))
[1]
select array_compact(element_at([[1,2],[3,4]], 10));
array_compact(element_at([[1,2],[3,4]], 10))
NULL
select array_compact(element_at([["hello", "world"], ["hi", "what"], ["are you?"]], 3));
array_compact(element_at([["hello", "world"], ["hi", "what"], ["are you?"]], 3))
["are you?"]
select array_compact(array_append([1,2,3], 3));
array_compact(array_append([1,2,3], 3))
[1,2,3]
select array_compact(array_append([["hello", "world"], ["hi", "what"], ["are you?"]], ["hi", "what"]));
array_compact(array_append([["hello", "world"], ["hi", "what"], ["are you?"]], ["hi", "what"]))
[["hello","world"],["hi","what"],["are you?"],["hi","what"]]
CREATE TABLE t1 (id int primary key, c1 Array(BigInt), c2 Array(double), c3 Array(varchar(1)), c4 Array(varchar(10)), c5 vector(3));
INSERT INTO t1(id) VALUES(1);
INSERT INTO t1 VALUES(2, [NULL], [NULL], [NULL], [NULL], [0,0,0]);
INSERT INTO t1 VALUES(3, [1,1,NULL,3], [1.1,1.1,NULL,3.3], ['a','a',NULL,'c'], ['hello','hello',NULL,'Ocean'], [1,1,3]);
select id, array_compact(c1), array_compact(c2), array_compact(c3), array_compact(c4), array_compact(c5) from t1;
