drop table if exists t_create;
create table t_create as select array_compact(NULL), array_compact([1,2,3,4]);
desc t_create;
Field	Type	Null	Key	Default	Extra
array_compact(NULL)	binary(0)	YES		NULL	
array_compact([1,2,3,4])	ARRAY(BIGINT)	YES		NULL	
select * from t_create;
array_compact(NULL)	array_compact([1,2,3,4])
NULL	[1,2,3,4]
drop table t_create;
create table t_create as select array_compact(NULL), array_compact(c1) from t1;
desc t_create;
Field	Type	Null	Key	Default	Extra
array_compact(NULL)	binary(0)	YES		NULL	
array_compact(c1)	ARRAY(BIGINT)	YES		NULL	
select * from t_create;
array_compact(NULL)	array_compact(c1)
NULL	NULL
NULL	[NULL]
NULL	[1,NULL,3]
drop table t_create;
INSERT IGNORE t1(id, c1) select id + 2, array_compact(c1) from t1;
select id, c1 from t1 order by id;
id	c1
1	NULL
2	[NULL]
3	[1,1,NULL,3]
4	[NULL]
5	[1,NULL,3]
update /*+ ENABLE_PARALLEL_DML parallel(256) */
t1 set c1 = array_compact(c1) where id > 1;
update t1 set c1 = array_compact([null, 1, 1, 2]) where id = 1;
select id, c1 from t1 order by id;
id	c1
1	[NULL,1,2]
2	[NULL]
3	[1,NULL,3]
4	[NULL]
5	[1,NULL,3]
