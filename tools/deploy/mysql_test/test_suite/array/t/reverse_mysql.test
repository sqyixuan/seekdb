#owner: xuqijia.xqj
#owner group: shenzhen
--echo # ----------------------------------------------------------------------
--echo # Test of reverse(array).
--echo # ----------------------------------------------------------------------


--disable_warnings
drop table if exists t1, t2;
--enable_warnings

select reverse([NULL]);
select reverse([1,2,3]);
select reverse([1,2,3,NULL]);
select reverse([1.1,2.2]);
select reverse(['a','b','c','d']);
select reverse(["hello", "hi"]);
select reverse([[NULL],NULL]);
select reverse([[1,2,3],[4]]);
select reverse([[1,2,3,NULL],[4,NULL]]);
select reverse([[1,2],[NULL,NULL]]);
select reverse([['a','b','c','d']]);
select reverse([['a','b','c'],['d']]);
select reverse([['a','b',NULL,'c'],[NULL,'d']]);
select reverse([['a','b',NULL,'c'],[NULL,'d'],NULL]);
select reverse([["hello", "world"], ["hi", "what"], ["are you?"]]);

select reverse(element_at([[1,2],[3,4]], 1));
select reverse(element_at([[1,2],[3,4]], 10));
select reverse(element_at([["hello", "world"], ["hi", "what"], ["are you?"]], 3));
select reverse(array_append([1,2,3], 4));
select reverse(array_append([["hello", "world"], ["hi", "what"], ["are you?"]], [NULL, "OceanBase"]));

CREATE TABLE t1 (id int primary key, c1 Array(BigInt), c2 Array(double), c3 Array(varchar(1)), c4 Array(varchar(10)), c5 vector(3));
INSERT INTO t1(id) VALUES(1);
INSERT INTO t1 VALUES(2, [NULL], [NULL], [NULL], [NULL], [0,0,0]);
INSERT INTO t1 VALUES(3, [1,2,NULL,3], [1.1,2.2,NULL,3.3], ['a','b',NULL,'c'], ['hello','world',NULL,'Ocean'], [1,2,3]);
select id, reverse(c1), reverse(c2), reverse(c3), reverse(c4), reverse(c5) from t1;

create table t2 (id int, c1 int[][], c2 float[][], c3 varchar(1)[][], c4 varchar(10)[][]);
INSERT INTO t2(id) VALUES(1);
INSERT INTO t2 VALUES(2, [[NULL]], [[NULL]], [[NULL]], [[NULL]]);
INSERT INTO t2 VALUES(3, [[1,2,3],[4,NULL]], [[1.1,2.2,3.3],[4.4,NULL]], [['a','b','c'],['d',NULL]], [['hello', 'world'], ['hi',NULL]]);
INSERT INTO t2 VALUES(4, [[1,2,3],[4,NULL],NULL], [[1.1,2.2,3.3],[4.4,NULL],NULL], [['a','b','c'],['d',NULL],NULL], [['hello', 'world'], ['hi',NULL],NULL]);
select id, reverse(c1), reverse(c2), reverse(c3), reverse(c4) from t2;

--disable_warnings
drop table if exists t_create;
--enable_warnings
create table t_create as select reverse(NULL), reverse([1,2,3,4]);
desc t_create;
select * from t_create;
drop table t_create;
create table t_create as select reverse(NULL), reverse(c1) from t1;
desc t_create;
select * from t_create;
drop table t_create;
select reverse(null);

with array_data as (
  select id, c1 from t1
)
select id, reverse(c1) from array_data;

with treverse as (
  select id, reverse(c1) from t1
)
select * from treverse;

# insert

INSERT IGNORE INTO t1(id, c1) select id + 2, reverse(c1) from t1;
INSERT INTO t1(id, c1) VALUES(7, reverse(null));
REPLACE INTO t1(id, c1) VALUES(5, reverse(null));

select id, c1 from t1 order by id;

# update

update /*+ ENABLE_PARALLEL_DML parallel(256) */
t1 set c1 = reverse(c1);

update t1 set c1 = reverse(c1) where id = 1;

select id, c1 from t1 order by id;

--disable_warnings
drop table if exists t1, t2;
--enable_warnings



--disable_warnings
drop table if exists tt;
--enable_warnings

create table tt(id int, arr_int int[], arr_dint array(array(int)), arr_vec array(vector(1)), arr_char array(varchar(10)));
insert into tt values(1, [1], [[1], [2]], [[1], [2]], ['a', 'b']);
insert into tt values(2, null, [[1], [2]], [[1], [2]], ['a', 'b']);
insert into tt values(3, array_remove([1], 1), [[1], [2]], [[1], [2]], ['a', 'b']);
insert into tt values(4, [null, 1], [[1], [2]], [[1], [2]], ['a', 'b']);
insert into tt values(5, [null], [[1], [2]], [[1], [2]], ['a', 'b']);
insert into tt values(6, [1], null, [[1], [2]], ['a', 'b']);
insert into tt values(7, [1], array_remove([[1]], [1]), [[1], [2]], ['a', 'b']);
insert into tt values(8, [1], [null, [2]], [[1], [2]], ['a', 'b']);
insert into tt values(9, [1], array_append(array_remove([[1]],[1]), null), [[1], [2]], ['a', 'b']);
insert into tt values(10, [1], [[null], [2]], [[1], [2]], ['a', 'b']);
insert into tt values(11, [1], [[null, 1], [2]], [[1], [2]], ['a', 'b']);
insert into tt values(12, [1], [array_remove([1], 1)], [[1], [2]], ['a', 'b']);
insert into tt values(13, [1], [array_remove([1], 1), [2]], [[1], [2]], ['a', 'b']);
insert into tt values(14, [1], [[1], [2]], null, ['a', 'b']);
insert into tt values(15, [1], [[1], [2]], array_remove([[1]], [1]), ['a', 'b']);
insert into tt values(16, [1], [[1], [2]], array_append(array_remove([[1]],[1]), null), ['a', 'b']);
insert into tt values(17, [1], [[1], [2]], [[1], [2]], null);
insert into tt values(18, [1], [[1], [2]], [[1], [2]], array_remove(['a'], 'a'));
insert into tt values(19, [1], [[1], [2]], [[1], [2]], array_append(array_remove(['a'],'a'), null));

select id, reverse(arr_int) from tt;
select id, reverse(arr_dint) from tt;
select id, reverse(arr_vec) from tt;
select id, reverse(arr_char) from tt;

--disable_warnings
drop table if exists tt;
--enable_warnings

