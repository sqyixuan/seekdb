--disable_warnings
drop table if exists tt1;
--enable_warnings
CREATE TABLE tt1 (c1 VARBINARY(32), c2 vector(3));
insert into tt1 values('[1,1,2]','[2,2,3]');
insert into tt1 values('[2,2,3]','[3,2,3]');
--error 1235
select array_append(['a'],c1) from tt1;
select array_append([[1,2,3]],c2) from tt1;
drop table tt1;

# bugfix

--disable_warnings
drop table if exists t1;
--enable_warnings

alter system set ob_vector_memory_limit_percentage =44;

sleep 5;
create table t1(c1 int primary key, c2 int[],c3 vector(3) , c4 vector(3),
VECTOR INDEX vector_idx(c4) 
WITH (distance=l2, lib=vsag, type=hnsw, m=10, ef_construction=100, ef_search=40)) partition by hash(c1) partitions 4;
replace into t1(c1, c2, c3) values(1,'[1,1,2]','[2,2,3]');
replace into t1(c1, c2, c3) values(2,'[1,-1,3]','[1,0,3]');
replace into t1(c1, c2, c3) values(3,null,null);
replace into t1(c1, c2, c3,c4) values(4,null,null,[1,2,3]);

select array_append([[c4]],[[1,2,3]]) from t1 order by c1;
select array_append([[c2]],[[1,2,3]]) from t1 order by c1;

--disable_warnings
drop table if exists t1;
--enable_warnings

--disable_warnings
drop table if exists tt;
--enable_warnings

create table tt(id int, arr_int int[], arr_dint array(array(int)), arr_vec array(vector(1)), arr_char array(varchar(10)));
insert into tt values(1, [1], [[1], [2]], [[1], [2]], ['a', 'b']);
insert into tt values(2, null, [[1], [2]], [[1], [2]], ['a', 'b']);
insert into tt values(3, array_remove([1], 1), [[1], [2]], [[1], [2]], ['a', 'b']);
insert into tt values(4, [null, 1], [[1], [2]], [[1], [2]], ['a', 'b']);
insert into tt values(5, [null], [[1], [2]], [[1], [2]], ['a', 'b']);
insert into tt values(6, [1], null, [[1], [2]], ['a', 'b']);
insert into tt values(7, [1], array_remove([[1]], [1]), [[1], [2]], ['a', 'b']);
insert into tt values(8, [1], [null, [2]], [[1], [2]], ['a', 'b']);
insert into tt values(9, [1], array_append(array_remove([[1]],[1]), null), [[1], [2]], ['a', 'b']);
insert into tt values(10, [1], [[null], [2]], [[1], [2]], ['a', 'b']);
insert into tt values(11, [1], [[null, 1], [2]], [[1], [2]], ['a', 'b']);
insert into tt values(12, [1], [array_remove([1], 1)], [[1], [2]], ['a', 'b']);
insert into tt values(13, [1], [array_remove([1], 1), [2]], [[1], [2]], ['a', 'b']);
insert into tt values(14, [1], [[1], [2]], null, ['a', 'b']);
insert into tt values(15, [1], [[1], [2]], array_remove([[1]], [1]), ['a', 'b']);
insert into tt values(16, [1], [[1], [2]], array_append(array_remove([[1]],[1]), null), ['a', 'b']);
insert into tt values(17, [1], [[1], [2]], [[1], [2]], null);
insert into tt values(18, [1], [[1], [2]], [[1], [2]], array_remove(['a'], 'a'));
insert into tt values(19, [1], [[1], [2]], [[1], [2]], array_append(array_remove(['a'],'a'), null));

select id, array_append(arr_int, 2) from tt;
select id, array_append(arr_dint, [2]) from tt;
select id, array_append(arr_vec, [1]) from tt;
select id, array_append(arr_char, 'c') from tt;

--disable_warnings
drop table if exists tt;
--enable_warnings
