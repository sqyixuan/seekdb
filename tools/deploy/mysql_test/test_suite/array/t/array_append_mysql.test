select array_append([1,2,3], [2]);
select array_append([1,2,3], 'hi');
select array_append([1,2,3], 2.1);
select array_append([1.1,2.2,3.3], 4);
select array_append([1.1,2.2,3.3], '4');
select array_append([100, 3.14159268888, 4.56, 7.88], 3.14159);
select array_append(["hello", "hi"], "OceanBase");
