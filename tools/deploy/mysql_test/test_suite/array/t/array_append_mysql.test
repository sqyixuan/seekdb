select array_append([1,2,3], 2);
select array_append([1,2,3], 0);
select array_append([1,2,3], -1);
select array_append([1,2,3], 4);
select array_append([1,2,3], NULL);
select array_append([NULL], 1);
select array_append([NULL], NULL);
select array_append([1,NULL,3], 2);
select array_append(['a','b','c'], 2);
select array_append([1,2,3], '2');
