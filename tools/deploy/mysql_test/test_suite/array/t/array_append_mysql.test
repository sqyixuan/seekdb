select array_append(["1", "2", "a"], "OceanBase");
select array_append(["hello", "hi"], 1);
select array_append(["hello", "hi"], NULL);
select array_append([[1,2],[3,4]], [5]);
select array_append([[1,2],[3,4]], NULL);
select array_append([[1,2],[3,4]], ['5']);
select array_append([[1,2],[3,4]], ['55']);
select array_append([[1,2],[3,4]], [NULL]);
select array_append([[1,2],[3,4]], [5.5,6.6]);
select array_append([[1,2],[3,4]], [5.5,NULL]);
select array_append([[100, 3.14159268888, 4.56, 7.88]], [3.14159]);
select array_append([[1.1,2.2],[3.3,4.4]], [5]);
select array_append([[1.1,2.2],[3.3,4.4]], ['a']);
select array_append([[1.1,2.2],[3.3,4.4]], ['Hello','OceanBase']);
select array_append([["a", "b"]], [5.5,NULL]);
select array_append([["hello", "world"]], [5.5,NULL]);
--error 5083
select array_append([[1,2],[3,4]], 5);
select array_append([["hello", "world"], ["hi", "what"], ["are you?"]], ["are you?"]);

