--echo # ----------------------------------------------------------------------
--echo # Test of array_position.
--echo # ----------------------------------------------------------------------

select array_position(null, 1);
select array_position([1,2,3], 2);
select array_position([1,2,3], 6);
select array_position([1,2,3], 2.0);
select array_position([1.1,2.2,3.3], 2.2);
select array_position(["hello", "hi"], "hel");
select array_position(["hello", "hi"], "hi");
select array_position([[1,2],[3,4]], [3,4]);
select array_position([[1,2],[3,4]], [3.0,4.0]);
select array_position([[1,2],[3,4]], [2,3]);
select array_position([["hello", "world"], ["hi", "what"], ["are you?"]], ["are you?"]);
select array_position([["hello", "world"], ["hi", "what"], ["are you?"]], ["hi", "what"]);
select array_position([["hello", "world"], ["hi", "what"], ["are you?"]], ["world", "hi"]);
select array_position([["hello", "world"], ["hi", "what"], ["are you?"]], ["are You?"]);
select array_position([100, 3.14159268888, 4.56, 7.88], 3.14159);
select array_position([100, 3.14159268888, 4.56, 7.88], 3.14159268888);
select array_position([100, 3.1415926, 4.56, 7.88], 3.14159268888);
--error 5083
select array_position([1,3,34,5,5,6,null,20241115],cast(20241115 as datetime));
--error 5083
select array_position([1,3,34,5,5,6,null,20241115],cast(20241115 as time));
--error 5083
select array_position([1,3,34,5,5,6,null,20241115],cast(20241115 as year));

--disable_warnings
drop table if exists arr_t1;
--enable_warnings

CREATE TABLE arr_t1(c1 int, c2 ARRAY(ARRAY(double)), c3 ARRAY(ARRAY(FLOAT)), c4 array(int), c5 array(double));
insert into arr_t1 values(1, [[5.55,7.87,44],[66,123.67,95.27],[1.28,3.1415,289.33]],[[5.55,7.87,44],[66,123.67,95.27],[1.28,3.1415,289.33]], [1, 2, 3, 4], [1.33, 2.44, 3.55, 4.66]);
insert into arr_t1 values(2, [[5.55,7.87,44],[66,123.66,95.27],[1.28,3.1415,289.33]],[[5.55,7.87,44],[66,123.67,95.27],[1.28,3.1415,289.33]], [1, 2, 3, 4], [1.33, 2.44, 3.55, 4.66]);
insert into arr_t1 values(3, [[5.55,7.87,44],[66,123.67,95.27],[1.28,3.1415,289.33]],[[5.55,7.87,44],[66,123.67,95.27],[1.28,3.1415,289.33]], [1, 2, 3, 4], [1.33, 2.44, 3.52, 4.66]);
insert into arr_t1 values(4, [[5.55,7.87,44],[66,123.67,95.27],[1.28,3.1415,289.33]],[[5.55,7.87,44],[66,123.67,95.27],[1.28,3.1415,289.33]], [1, 2, 2, 4], [1.33, 2.44, 3.55, 4.66]);

select array_position(c2, [66,123.67,95.27]) from arr_t1 order by c1;
select c1 from arr_t1 where array_position(c2, [66,123.67,95.27]) > 0 order by c1;
select c1 from arr_t1 where array_position(c2, [66,123.67,95.27]) = false order by c1;
select array_position(c3, [66,123.67,95.27]) from arr_t1 order by c1;
select array_position(c4, 3) from arr_t1 order by c1;
select c1 from arr_t1 where array_position(c4, 3) > 0 order by c1;
select array_position(c5, 3.55) from arr_t1 order by c1;
select c1 from arr_t1 where array_position(c5, 3.55) > 0 order by c1;
select c1 from arr_t1 where array_position(c4, c1) = 1 order by c1;
select /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */ array_position(c2, [66,123.67,95.27]) from arr_t1 order by c1;
select /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */ c1 from arr_t1 where array_position(c2, [66,123.67,95.27]) > 0 order by c1;
select /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */ c1 from arr_t1 where array_position(c2, [66,123.67,95.27]) = false order by c1;
select /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */ array_position(c3, [66,123.67,95.27]) from arr_t1 order by c1;
select /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */ array_position(c4, 3) from arr_t1 order by c1;
select /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */ c1 from arr_t1 where array_position(c4, 3) order by c1;
select /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */ array_position(c5, 3.55) from arr_t1 order by c1;
select /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */ c1 from arr_t1 where array_position(c5, 3.55) order by c1;
select /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */ c1 from arr_t1 where array_position(c4, c1) = 1 order by c1;
select /*+ OPT_PARAM('rowsets_enabled', 'FALSE') */ array_position(c2, [66,123.67,95.27]) from arr_t1 order by c1;
select /*+ OPT_PARAM('rowsets_enabled', 'FALSE') */ c1 from arr_t1 where array_position(c2, [66,123.67,95.27]) > 0 order by c1;
select /*+ OPT_PARAM('rowsets_enabled', 'FALSE') */ c1 from arr_t1 where array_position(c2, [66,123.67,95.27]) = false order by c1;
select /*+ OPT_PARAM('rowsets_enabled', 'FALSE') */ array_position(c3, [66,123.67,95.27]) from arr_t1 order by c1;
select /*+ OPT_PARAM('rowsets_enabled', 'FALSE') */ array_position(c4, 3) from arr_t1 order by c1;
select /*+ OPT_PARAM('rowsets_enabled', 'FALSE') */ c1 from arr_t1 where array_position(c4, 3) order by c1;
select /*+ OPT_PARAM('rowsets_enabled', 'FALSE') */ array_position(c5, 3.55) from arr_t1 order by c1;
select /*+ OPT_PARAM('rowsets_enabled', 'FALSE') */ c1 from arr_t1 where array_position(c5, 3.55) > 0  order by c1;
select /*+ OPT_PARAM('rowsets_enabled', 'FALSE') */ c1 from arr_t1 where array_position(c4, c1) = 1 order by c1;

# 参数个数不同的排列组合
--error 1582
select array_position([1,2,3]);
--error 1582
select array_position([1,2,3], 2, 3);
--error 1582
select array_position([1,2,3], 2, 3, 4);

# order by

select c1, array_position(c5, 3.55) from arr_t1 order by c1; 
select c1, array_position(c5, 3.55) from arr_t1 having c1 + 1 >= 2  order by c1;
select * from arr_t1 having array_position(c2, [66,123.67,95.27]) > 0  order by c1;
select c1, array_position(c2, [66,123.67,95.27]) from arr_t1 where array_position(c2, [66,123.67,95.27]) > 0 order by c1;
select c1, array_position(c2, [66,123.67,95.27]) from arr_t1  order by c1 for update;
--sorted_result
sleep 5;
select /*+read_consistency(weak) */ c1, array_position(c2, [66,123.66,95.27]) from arr_t1 order by c1;
select /*+ ENABLE_PARALLEL_DML parallel(256) */ c1, array_position(c2, [66,123.66,95.27]) from arr_t1 order by c1;

with array_data as (
  select c1, c2 from arr_t1
  where c1 IN(2,3)
)
select c1, array_position(c2, [66,123.66,95.27]) from array_data order by c1;

with tpos as (
  select c1, array_position(c2, [66,123.66,95.27]) as pos from arr_t1
)
select * from tpos order by c1;

# insert

INSERT IGNORE INTO arr_t1(c1, c4) select c1 + 4, [array_position(c5, 3.55)] from arr_t1;
INSERT INTO arr_t1(c1, c4) VALUES(9, [array_position([1,2,3.55], 3.55) + 5]);
INSERT INTO arr_t1(c1, c4) VALUES(10, [array_position([1,2,3.55], 3.55) + 5]) ON DUPLICATE KEY UPDATE c5 = [1.33, 2.44, 3.52, 4.66];
REPLACE INTO arr_t1(c1, c4) VALUES (11, [array_position([1,2,3.55], 3.55)]);
INSERT IGNORE INTO arr_t1(c1, c4) VALUES (12 ,[array_position([1,2,3.55], 3.55)]);

select * from arr_t1 order by c1;

