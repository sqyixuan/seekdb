#owner: xuqijia.xqj
#owner group: shenzhen
--echo # ----------------------------------------------------------------------
--echo # Test of array_concat.
--echo # ----------------------------------------------------------------------


--disable_warnings
drop table if exists t1, t2, t3;
--enable_warnings

select array_concat([1,2,3]);
select array_concat([1,2,3], [4]);
select array_concat([1], [2,3,4]);
select array_concat(NULL, [2,3,4]);
select array_concat([1,2,3], [4], [5,6]);
select array_concat([1,2,3], [4.4]);
select array_concat([1,2,3], [4.4], [NULL]);
select array_concat([1,2,3], [1/3]);
select array_concat([1,2,3], ['a']);
select array_concat([1,2,3], [-4], [5.5,6]);
select array_concat([1.1,2.2,3]);
select array_concat([1.1,2.2,3], [4]);
select array_concat(['hi', 'hello']);
select array_concat(['hi', 'hello'], NULL);
select array_concat(['hi', 'hello'], ['oceanbase']);
select array_concat(['hi', 'hello'], ['oceanbase'], ['1','a']);
select array_concat(['hi', 'hello'], [1]);
--error 7602
select array_concat([1,2,3], [[1]]);
select array_concat([[1,2,3]],[[11]]);
select array_concat([[1,2,3]],[[11],[22,44]]);
select array_concat([[1,2,3]],[[11],[22,44],[5.5]]);
select array_concat([[1,2,3]],[[11],[22,44,NULL],[5.5]]);
select array_concat([[1,2,3]],[[11],[22,44,NULL],[5.5]], NULL);

select array_concat([[1,2,3]],[[11],[22,44]],[[5.5]]);
select array_concat([[1,2,3]],[[11],[22,44]],[['a']]);
select array_concat([['hi', 'hello']], [['oceanbase'], ['how', 'are', 'you']]);

CREATE TABLE t1 (id int, arr_tint Array(TINYINT), arr_sint Array(SMALLINT), arr_int Array(INT), arr_bint Array(BIGINT),
                 arr_utint Array(TINYINT UNSIGNED), arr_usint Array(SMALLINT UNSIGNED), arr_uint Array(INT UNSIGNED), arr_ubint Array(BIGINT UNSIGNED),
                 arr_flt Array(FLOAT), arr_dob Array(DOUBLE));
INSERT INTO t1(id) VALUES(1);
INSERT INTO t1 VALUES(2, [NULL], [NULL], [NULL], [NULL], [NULL], [NULL], [NULL], [NULL], [NULL], [NULL]);
INSERT INTO t1 VALUES(3, [-128,127], [-32768,32767], [-2147483648,2147483647], [-9223372036854775808,9223372036854775807],
                      [0,255], [0,65535], [0,4294967295], [0,9223372036854775807],
                      [-3.402823466E+38, -1.175494351E-38], [-1.7976931348623157E+308, -2.2250738585072014E-308]);
SELECT array_concat([1], arr_tint), array_concat([1.1], arr_tint) from t1;
SELECT array_concat([1], arr_sint), array_concat([1], arr_sint) from t1;
SELECT array_concat([1], arr_int), array_concat([1], arr_int)  from t1;
SELECT array_concat([1], arr_bint), array_concat([1], arr_bint) from t1;
SELECT array_concat([1], arr_utint), array_concat([1], arr_utint) from t1;
SELECT array_concat([1], arr_usint), array_concat([1], arr_usint) from t1;
SELECT array_concat([1], arr_uint), array_concat([1], arr_uint) from t1;
SELECT array_concat([1], arr_ubint), array_concat([1], arr_ubint) from t1;
SELECT array_concat([1], arr_flt), array_concat([1], arr_flt) from t1;
SELECT array_concat([1], arr_dob), array_concat([1], arr_dob) from t1;
SELECT array_concat(arr_tint, arr_tint), array_concat(arr_tint, arr_sint), array_concat(arr_tint, arr_int), array_concat(arr_tint, arr_bint),
       array_concat(arr_tint, arr_utint), array_concat(arr_tint, arr_usint), array_concat(arr_tint, arr_uint), array_concat(arr_tint, arr_ubint),
       array_concat(arr_tint, arr_flt), array_concat(arr_tint, arr_dob)from t1;
SELECT array_concat(arr_sint, arr_tint), array_concat(arr_sint, arr_sint), array_concat(arr_sint, arr_int), array_concat(arr_sint, arr_bint),
       array_concat(arr_sint, arr_utint), array_concat(arr_sint, arr_usint), array_concat(arr_sint, arr_uint), array_concat(arr_sint, arr_ubint),
       array_concat(arr_sint, arr_flt), array_concat(arr_sint, arr_dob)from t1;
SELECT array_concat(arr_int, arr_tint), array_concat(arr_int, arr_sint), array_concat(arr_int, arr_int), array_concat(arr_int, arr_bint),
       array_concat(arr_int, arr_utint), array_concat(arr_int, arr_usint), array_concat(arr_int, arr_uint), array_concat(arr_int, arr_ubint),
       array_concat(arr_int, arr_flt), array_concat(arr_int, arr_dob)from t1;
SELECT array_concat(arr_bint, arr_tint), array_concat(arr_bint, arr_sint), array_concat(arr_bint, arr_int), array_concat(arr_bint, arr_bint),
       array_concat(arr_bint, arr_utint), array_concat(arr_bint, arr_usint), array_concat(arr_bint, arr_uint), array_concat(arr_bint, arr_ubint),
       array_concat(arr_bint, arr_flt), array_concat(arr_bint, arr_dob)from t1;
SELECT array_concat(arr_utint, arr_tint), array_concat(arr_utint, arr_sint), array_concat(arr_utint, arr_int), array_concat(arr_utint, arr_bint),
       array_concat(arr_utint, arr_utint), array_concat(arr_utint, arr_usint), array_concat(arr_utint, arr_uint), array_concat(arr_utint, arr_ubint),
       array_concat(arr_utint, arr_flt), array_concat(arr_utint, arr_dob)from t1;
SELECT array_concat(arr_usint, arr_tint), array_concat(arr_usint, arr_sint), array_concat(arr_usint, arr_int), array_concat(arr_usint, arr_bint),
       array_concat(arr_usint, arr_utint), array_concat(arr_usint, arr_usint), array_concat(arr_usint, arr_uint), array_concat(arr_usint, arr_ubint),
       array_concat(arr_usint, arr_flt), array_concat(arr_usint, arr_dob)from t1;
SELECT array_concat(arr_uint, arr_tint), array_concat(arr_uint, arr_sint), array_concat(arr_uint, arr_int), array_concat(arr_uint, arr_bint),
       array_concat(arr_uint, arr_utint), array_concat(arr_uint, arr_usint), array_concat(arr_uint, arr_uint), array_concat(arr_uint, arr_ubint),
       array_concat(arr_uint, arr_flt), array_concat(arr_uint, arr_dob)from t1;
SELECT array_concat(arr_ubint, arr_tint), array_concat(arr_ubint, arr_sint), array_concat(arr_ubint, arr_int), array_concat(arr_ubint, arr_bint),
       array_concat(arr_ubint, arr_utint), array_concat(arr_ubint, arr_usint), array_concat(arr_ubint, arr_uint), array_concat(arr_ubint, arr_ubint),
       array_concat(arr_ubint, arr_flt), array_concat(arr_ubint, arr_dob)from t1;
SELECT array_concat(arr_flt, arr_tint), array_concat(arr_flt, arr_sint), array_concat(arr_flt, arr_int), array_concat(arr_flt, arr_bint),
       array_concat(arr_flt, arr_utint), array_concat(arr_flt, arr_usint), array_concat(arr_flt, arr_uint), array_concat(arr_flt, arr_ubint),
       array_concat(arr_flt, arr_flt), array_concat(arr_flt, arr_dob)from t1;
SELECT array_concat(arr_dob, arr_tint), array_concat(arr_dob, arr_sint), array_concat(arr_dob, arr_int), array_concat(arr_dob, arr_bint),
       array_concat(arr_dob, arr_utint), array_concat(arr_dob, arr_usint), array_concat(arr_dob, arr_uint), array_concat(arr_dob, arr_ubint),
       array_concat(arr_dob, arr_flt), array_concat(arr_dob, arr_dob)from t1;

