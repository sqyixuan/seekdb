CREATE TABLE t2 (id int, arr_int Array(INT), vec vector(3));
INSERT INTO t2(id) VALUES(1);
INSERT INTO t2 VALUES(2, [1,2,3], [1,2,3]);
--error 5083
SELECT array_concat([1], vec) from t2 where id = 1;
--error 5083
SELECT array_concat(arr_int, vec) from t2 where id = 2;

CREATE TABLE t3 (id int primary key, c1 Array(varchar(2)), c2 Array(varchar(10)), c3 Array(int), c4 Array(double));
INSERT INTO t3(id) VALUES(1);
INSERT INTO t3 VALUES(2, [NULL], [NULL], [NULL], [NULL]);
INSERT INTO t3 VALUES(3, ['aa','b'], ['ccc','ddddd'], [1,2], [1.1, 2.2]);
SELECT array_concat(['h'], c1), array_concat(['hello'], c1) from t3;
SELECT array_concat(['h'], c2), array_concat(['hello'], c2) from t3;
SELECT array_concat(c1, c1), array_concat(c1, c2), array_concat(c2, c1), array_concat(c2, c2)from t3;
SELECT array_concat(c1, c3), array_concat(c1, c4), array_concat(c2, c3), array_concat(c2, c4)from t3;

SELECT /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */ array_concat(['h'], c1), array_concat(['hello'], c1) from t3;
SELECT /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */ array_concat(['h'], c2), array_concat(['hello'], c2) from t3;
SELECT /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */ array_concat(c1, c1), array_concat(c1, c2), array_concat(c2, c1), array_concat(c2, c2)from t3;
SELECT /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */ array_concat(c1, c3), array_concat(c1, c4), array_concat(c2, c3), array_concat(c2, c4)from t3;

SELECT /*+ OPT_PARAM('rowsets_enabled', 'FALSE') */ array_concat(['h'], c1), array_concat(['hello'], c1) from t3;
SELECT /*+ OPT_PARAM('rowsets_enabled', 'FALSE') */ array_concat(['h'], c2), array_concat(['hello'], c2) from t3;
SELECT /*+ OPT_PARAM('rowsets_enabled', 'FALSE') */ array_concat(c1, c1), array_concat(c1, c2), array_concat(c2, c1), array_concat(c2, c2)from t3;
SELECT /*+ OPT_PARAM('rowsets_enabled', 'FALSE') */ array_concat(c1, c3), array_concat(c1, c4), array_concat(c2, c3), array_concat(c2, c4)from t3;


--disable_warnings
drop table if exists t_create;
--enable_warnings
create table t_create as select array_concat(NULL), array_concat([1],[2]);
desc t_create;
select * from t_create;
drop table t_create;
create table t_create as select array_concat(NULL), array_concat([1], arr_tint) from t1;
desc t_create;
select * from t_create;
drop table t_create;
# select 

with array_data as (
  select id, c1, c2 from t3
  where id IN (2, 3)
)
select id, array_concat(c1, c2) from array_data order by id;

with aconcat as (
  select id, array_concat(c1, c2) from t3
)
select * from aconcat order by id;

# insert

INSERT IGNORE INTO t3(id, c1) select id + 2, array_concat(c1, c2) from t3;

select * from t3 order by id;

INSERT INTO t3(id, c1) VALUES(6, array_concat(['aa','b'], ['c']));
INSERT INTO t3(id, c1) VALUES(7, NULL);
REPLACE INTO t3(id, c1) VALUES(7, array_concat(['aa','b'], ['c']));

# INSERT INTO t3(id, c1) VALUES(8, array_concat(NULL, NULL));

select * from t3 order by id;

# update 

# update /*+ ENABLE_PARALLEL_DML parallel(256) */ t3 set c1 = array_concat(c1, c2) where id = 1;
# update t3 set c1 = array_concat(c1, c2) where id = 1;

select * from t3 order by id;

# delete

delete /*+ ENABLE_PARALLEL_DML parallel(256) */ from t3 where c1 = array_concat(c1, c2);

select * from t3 order by id;

# corner cases
--error 1582
select array_concat();
--error 5083
select array_concat('.');
--error 5083
select array_concat(1);
select array_concat(NULL);
select array_concat(NULL, NULL);
select array_concat([NULL]);
--error 5083
select array_concat(null, 1);

--disable_warnings
drop table if exists t1, t2, t3;
--enable_warnings

--disable_warnings
drop table if exists tt;
--enable_warnings

create table tt(id int, arr_int int[], arr_dint array(array(int)), arr_vec array(vector(1)), arr_char array(varchar(10)));
insert into tt values(1, [1], [[1], [2]], [[1], [2]], ['a', 'b']);
insert into tt values(2, null, [[1], [2]], [[1], [2]], ['a', 'b']);
insert into tt values(3, array_remove([1], 1), [[1], [2]], [[1], [2]], ['a', 'b']);
insert into tt values(4, [null, 1], [[1], [2]], [[1], [2]], ['a', 'b']);
insert into tt values(5, [null], [[1], [2]], [[1], [2]], ['a', 'b']);
insert into tt values(6, [1], null, [[1], [2]], ['a', 'b']);
insert into tt values(7, [1], array_remove([[1]], [1]), [[1], [2]], ['a', 'b']);
insert into tt values(8, [1], [null, [2]], [[1], [2]], ['a', 'b']);
insert into tt values(9, [1], array_append(array_remove([[1]],[1]), null), [[1], [2]], ['a', 'b']);
insert into tt values(10, [1], [[null], [2]], [[1], [2]], ['a', 'b']);
insert into tt values(11, [1], [[null, 1], [2]], [[1], [2]], ['a', 'b']);
insert into tt values(12, [1], [array_remove([1], 1)], [[1], [2]], ['a', 'b']);
insert into tt values(13, [1], [array_remove([1], 1), [2]], [[1], [2]], ['a', 'b']);
insert into tt values(14, [1], [[1], [2]], null, ['a', 'b']);
insert into tt values(15, [1], [[1], [2]], array_remove([[1]], [1]), ['a', 'b']);
insert into tt values(16, [1], [[1], [2]], array_append(array_remove([[1]],[1]), null), ['a', 'b']);
insert into tt values(17, [1], [[1], [2]], [[1], [2]], null);
insert into tt values(18, [1], [[1], [2]], [[1], [2]], array_remove(['a'], 'a'));
insert into tt values(19, [1], [[1], [2]], [[1], [2]], array_append(array_remove(['a'],'a'), null));

select id, array_concat(arr_int, [1]) from tt;
select id, array_concat(arr_dint, [[1]]) from tt;
select id, array_concat(arr_vec, [[1]]) from tt;
select id, array_concat(arr_char, ['a']) from tt;

--disable_warnings
drop table if exists tt;
--enable_warnings
