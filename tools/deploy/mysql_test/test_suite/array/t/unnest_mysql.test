--disable_warnings
drop table if exists t1, t2, t3;
--enable_warnings
create table t1(id int primary key, a1 array(int), a2 array(int));
insert into t1 values (1, [1,2,3], [11,22]), (2, [4,5], [44,55,66]), (3, NULL, [77]);
select id, unnest from t1, unnest(a1);
select id, unnest.unnest from t1, unnest(a1);
select id, unnest from t1, unnest(a1) as unnest_table;
--error 1064
select id, unnest from t1, unnest(a1) as (arr1);
select id, unnest_table.unnest from t1, unnest(a1) unnest_table;
select id, unnest_table.arr1 from t1, unnest(a1) as unnest_table(arr1);

select id, unnest.* from t1, unnest(a1, a2);
select id, unnest_table.* from t1, unnest(a1, a2) as unnest_table;
select id, unnest_table.* from t1, unnest(a1, a2) unnest_table;
select id, unnest_table.* from t1, unnest(a1, a2) as unnest_table(arr1, arr2);
select id, unnest_table.* from t1, unnest(a1, a2) unnest_table(arr1, arr2);
select id, unnest_table.* from t1, unnest(a1, a2) unnest_table(col_test, col_test);
--error 1052
select id, unnest_table.col_test from t1, unnest(a1, a2) unnest_table(col_test, col_test);
--error 1582
select id, unnest_table.* from t1, unnest(a1, a2) unnest_table(arr1);
--error 1064
select id, unnest_table.* from t1, unnest(a1, a2) unnest_table();
--error 1052
select id, unnest_table.unnest from t1, unnest(a1, a2) as unnest_table;
--error 1054
select id, unnest_table from t1, unnest(a1, a2) as unnest_table;
--error 1582
select id, unnest_table.* from t1, unnest(a1, a2) as unnest_table(arr1);
--error 1582
select id, unnest_table.* from t1, unnest(a1, a2) as unnest_table(arr1, arr2, arr3);
--error 1052
select id, col from t1, unnest(a1) as a(col), unnest(a1) as b(col);

--error 1064
select * from unnest();
--error 3064
select * from unnest(NULL);
--error 3064
select * from unnest('a');
select * from unnest([1]);
# diff
select * from unnest([NULL]);
select * from unnest([[NULL]]);
select * from unnest([[NULL],[1]]);
select * from unnest([1, 2, 3]);
select * from unnest([1, NULL, 3], [11, NULL, 33]);
select * from unnest([1, 2, NULL], [11, 22, NULL]);
select * from unnest([1, 2, NULL], [11, 22]);
--error 3064
select * from unnest([1, 2, 3], NULL);
select * from unnest([1, NULL, 3]);
select * from unnest([1.1, 2.2, 3.3]);
select * from unnest(['a', 'b', 'c']);
select * from unnest([1, 2, 3], [1.1, 2.2, 3.3], ['a', 'b', 'c']);
select * from unnest([1, 2, 3], [1.1, 2.2, 3.3], ['a', 'b', 'c']) as unnest_table(arr1, arr2, arr3);
select * from unnest([1, NULL, 3], [1, 2]);
select * from unnest([[1, 2], [11, 22]]);
select * from t1, unnest([1, 2, 3], a2);
select * from t1, unnest(a2, [1]);

create table t2(c1 int[], c2 varchar(256)[], c3 bigint[], c4 TINYINT[], c5 float[], c6 double[], c7 SMALLINT[]);
insert into t2 values ([NULL], [NULL], [NULL], [NULL], [NULL], [NULL], [NULL]);
select * from t2;
insert into t2 values ([1,2,3], ['a','b','c'], [11,22,33], [1,2,3], [1.1,2.2,3.3], [1.11,2.22,3.33], [1,2,3]);
select * from t2, unnest(c1, c2, c3, c4, c5, c6, c7);

create table t3(id int, c1 int[], c2 int[][], c3 int[][][], c4 int[][][][], c5 int[][][][][], c6 int[][][][][][]);
insert into t3 values (1, [1], [[1]], [[[1]]], [[[[1]]]], [[[[[1]]]]], [[[[[[1]]]]]]);
insert into t3 values (2, [1,2], [[1],[2]], [[[1]],[[2]]], [[[[1]]],[[[2]]]], [[[[[1]]]],[[[[2]]]]], [[[[[[1]]]]],[[[[[2]]]]]]);

select id, unnest.* from t3, unnest(c1, c2, c3, c4, c5, c6);
select * from unnest([[1]]);
select * from unnest([[[1]]]);
select * from unnest([[[[1]]]]);
select * from unnest([[[[[1]]]]]);
select * from unnest([[[[[[1]]]]]]);
--error 1235
select * from unnest([[[[[[[1]]]]]]]);

--error 0, 1051
drop view v;
