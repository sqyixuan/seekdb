SELECT * FROM v;
SHOW CREATE VIEW v;
DROP VIEW v;

--error 0, 1051
drop view v;
CREATE VIEW v AS select id, unnest_table.* from t1, unnest(a1) unnest_table;
SELECT * FROM v;
SHOW CREATE VIEW v;
DROP VIEW v;

--error 0, 1051
drop view v;
CREATE VIEW v AS select id, unnest_table.* from t1, unnest(a1) unnest_table(arr1);
SELECT * FROM v;
SHOW CREATE VIEW v;
DROP VIEW v;

--error 0, 1051
drop view v;
--error 1060
CREATE VIEW v AS SELECT * from unnest([1, NULL, 3], [11, NULL, 33]);

--error 0, 1051
drop view v;
CREATE VIEW v AS SELECT * from unnest([1, NULL, 3], [11, NULL, 33]) as unnest_table(arr1, arr2);
SELECT * FROM v;
SHOW CREATE VIEW v;
DROP VIEW v;

--error 0, 1051
drop view v;
--error 1060
CREATE VIEW v AS select id, unnest.* from t1, unnest(a1, a2);

--error 0, 1051
drop view v;
CREATE VIEW v AS select id, unnest_table.* from t1, unnest(a1, a2) as unnest_table(arr1, arr2);
SELECT * FROM v;
SHOW CREATE VIEW v;
DROP VIEW v;

