#owner: ht353245
#owner group: shenzhen
#description: merge vec  for array
#author: ht353245


--disable_warnings
drop database if exists array_merge;
--enable_warnings
create database array_merge;
use array_merge;

create sequence s1 cache 1000000 noorder;
create table t1(c1 bigint, c2 bigint, c3 bigint, c4 bigint, c5 array(int), c6 map(int,varchar(10000)), primary key(c1,c2,c3,c4)) with column group(each column);
create table t2(c1 bigint, c2 bigint, c3 bigint, c4 bigint, c5 array(int), c6 map(int,varchar(10000)), primary key(c1,c2,c3,c4)) with column group(each column);
insert /*+ append enable_parallel_dml parallel(8) */ignore into t1 select s1.nextval, s1.nextval, s1.nextval, s1.nextval, [s1.nextval, s1.nextval, s1.nextval], map(s1.nextval,  s1.nextval) from table(generator(500));
insert /*+ append enable_parallel_dml parallel(8) */ignore into t1 select s1.nextval, s1.nextval, s1.nextval, s1.nextval, null, null from table(generator(1));
insert /*+ append enable_parallel_dml parallel(8) */ignore into t1 select s1.nextval, s1.nextval, s1.nextval, s1.nextval, '[]', '{}' from table(generator(1));
insert /*+ append enable_parallel_dml parallel(8) */ignore into t1 select s1.nextval, s1.nextval, s1.nextval, s1.nextval, [s1.nextval, s1.nextval, s1.nextval], map(s1.nextval,  s1.nextval) from table(generator(500));
ALTER SEQUENCE s1 RESTART;
insert /*+ append enable_parallel_dml parallel(8) */ignore into t2 select s1.nextval, s1.nextval, s1.nextval, s1.nextval, [s1.nextval, s1.nextval, s1.nextval], map(s1.nextval,  s1.nextval) from table(generator(500));
insert /*+ append enable_parallel_dml parallel(8) */ignore into t2 select s1.nextval, s1.nextval, s1.nextval, s1.nextval, null, null from table(generator(1));
insert /*+ append enable_parallel_dml parallel(8) */ignore into t2 select s1.nextval, s1.nextval, s1.nextval, s1.nextval, '[]', '{}' from table(generator(1));

explain basic select * from (select c1,c2,c3,c5,c6 from t1 union select c1,c2,c3,c5,c6 from t2);
explain basic select * from (select c1,c2,c3,c5,c6 from t1 union all select c1,c2,c3,c5,c6 from t2);
explain basic select * from (select c1,c2,c3,c5,c6 from t1 intersect select c1,c2,c3,c5,c6 from t2);
explain basic select * from (select c1,c2,c3,c5,c6 from t1 except select c1,c2,c3,c5,c6 from t2);
explain basic select * from (select c1,c2,c3,c5,c6 from t1 intersect select c1,c2,c3,c5,c6 from t2 intersect select c1,c2,c3,c5,c6 from t2);
explain basic select /*+NO_USE_HASH_SET*/ * from (select c1,c2,c3,c5,c6  from t1 union select c1,c2,c3,c5,c6 from t2);
explain basic select /*+NO_USE_HASH_SET*/ * from (select c1,c2,c3,c5,c6 from t1 union all select c1,c2,c3,c5,c6 from t2);
explain basic select /*+NO_USE_HASH_SET*/ * from (select c1,c2,c3,c5,c6 from t1 intersect select c1,c2,c3,c5,c6 from t2);
explain basic select /*+NO_USE_HASH_SET*/ * from (select c1,c2,c3,c5,c6 from t1 except select c1,c2,c3,c5,c6 from t2);
explain basic select /*+NO_USE_HASH_SET*/ * from (select c1,c2,c3,c5,c6 from t1 intersect select c1,c2,c3,c5,c6 from t2 intersect select c1,c2,c3,c5,c6 from t2);


alter system major freeze;
--source mysql_test/include/wait_daily_merge.inc

select * from (select c1,c2,c3,c5 from t1 union select c1,c2,c3,c5 from t2);
select * from (select c1,c2,c3,c5 from t1 union all select c1,c2,c3,c5 from t2);
select * from (select c1,c2,c3,c5 from t1 intersect select c1,c2,c3,c5 from t2);
select * from (select c1,c2,c3,c5 from t1 except select c1,c2,c3,c5 from t2);
select * from (select c1,c2,c3,c5 from t1 intersect select c1,c2,c3,c5 from t2 intersect select c1,c2,c3,c5 from t2);

--error 5083
select /*+NO_USE_HASH_SET*/ * from (select c1,c2,c3,c5 from t1 union select c1,c2,c3,c5 from t2);
select /*+NO_USE_HASH_SET*/ * from (select c1,c2,c3,c5 from t1 union all select c1,c2,c3,c5 from t2);
--error 5083
select /*+NO_USE_HASH_SET*/ * from (select c1,c2,c3,c5 from t1 intersect select c1,c2,c3,c5 from t2);
--error 5083
select /*+NO_USE_HASH_SET*/ * from (select c1,c2,c3,c5 from t1 except select c1,c2,c3,c5 from t2);
--error 5083
select /*+NO_USE_HASH_SET*/ * from (select c1,c2,c3,c5 from t1 intersect select c1,c2,c3,c5 from t2 intersect select c1,c2,c3,c5 from t2);

drop database array_merge;
