#owner: ht353245
#owner group: shenzhen

--disable_query_log
set ob_query_timeout = 10000000000;

--source mysql_test/include/select_into_outfile/get_host_ip.inc
let $DATA_FOLDER_NAME = select_into_outfile_lob;

--source mysql_test/include/select_into_outfile/delete_dir.inc
--source mysql_test/include/select_into_outfile/mkdir_for_dump.inc

--disable_warnings
drop table if exists arr_t1, arr_t2, arr_t3, arr_t4;
--enable_warnings
--enable_query_log

create table arr_t1(c1 int, arr1 array(int), vec1 vector(3), arr2 array(double), arr3 array(varchar(16)), arr4 varchar(16)[][]);

--disable_query_log
--let $count = 0
while($count < 10)
{
   eval insert into arr_t1 values($count * 10, [5, 2, 5], [2.1, 3.2, 4.3], [2.111144455, 3.444555666], ["hello", "world", "hi", "我", "你好hi"], [["hello", "world"], ["hi"]]),
                                  ($count * 10 + 1, [2, 3, 5], [2.1, 3.2, 4.3], [2.111144455, 3.444555666], ["hello", "world", "我", "你好hi"], [["我"], ["hi"]]),
                                  ($count * 10 + 2, null, null, null, null, null),
                                  ($count * 10 + 3, [5, 2, 5], [2.1, 3.2, 4.3], [2.111144455, 3.444555666], ["hello", "world", "hi", "我", "你好hi"], [["hello", "world"], ["hi"]]),
                                  ($count * 10 + 4, [2, 3, 5], [2.1, 3.2, 4.3], [2.111144455, 3.444555666], ["hello", "world", "我", "你好hi"], [["我"], ["hi"]]),
                                  ($count * 10 + 5, null, null, null, null, null),
                                  ($count * 10 + 6, [5, 2, 5], [2.1, 3.2, 4.3], [2.111144455, 3.444555666], ["hello", "world", "hi", "我", "你好hi"], [["hello", "world"], ["hi"]]),
                                  ($count * 10 + 7, [2, 3, 5], [2.1, 3.2, 4.3], [2.111144455, 3.444555666], ["hello", "world", "我", "你好hi"], [["我"], ["hi"]]),
                                  ($count * 10 + 8, null, null, null, null, null),
                                  ($count * 10 + 9, [5, 2, 5], [2.1, 3.2, 4.3], [2.111144455, 3.444555666], ["hello", "world", "hi", "我", "你好hi"], [["hello", "world"], ["hi"]]);
  --inc $count
}
--enable_query_log

--source mysql_test/include/select_into_outfile/delete_files.inc
eval select * from arr_t1 into outfile '$DATA_FOLDER_NAME/array_data1' single=false;
--source mysql_test/include/select_into_outfile/list_dir.inc
let $FILE_NAME = array_data1_0.csv;
--source mysql_test/include/select_into_outfile/cat_file.inc

create table arr_t2 like arr_t1;
create table arr_t3 like arr_t1;
create table arr_t4(c1 int, arr1 array(int), vec1 vector(3), arr2 array(double), arr3 array(varchar(16)), arr4 varchar(16)[][]) partition by hash (c1) partitions 3;

--disable_query_log
eval load data /*+ parallel(8) direct(true, 0) */ infile "$DATA_FOLDER_NAME/array_data1_0.csv" into table arr_t3;
eval load data /*+ parallel(8) direct(true, 0) */ infile "$DATA_FOLDER_NAME/array_data1_0.csv" into table arr_t4;
eval load data infile "$DATA_FOLDER_NAME/array_data1_0.csv" into table arr_t2;
--enable_query_log

select * from arr_t2 order by c1;
select * from arr_t3 order by c1;
select * from arr_t4 order by c1;

--source mysql_test/include/select_into_outfile/delete_dir.inc
drop table arr_t1;
drop table arr_t2;
drop table arr_t3;
drop table arr_t4;
