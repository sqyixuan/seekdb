select id, array_overlaps(arr_vec, [null]) from tt;
select id, array_overlaps(arr_vec, arr_vec) from tt;
select id, array_overlaps(arr_char, ['a']) from tt;
select id, array_overlaps(arr_char, [null]) from tt;
select id, array_overlaps(arr_char, arr_char) from tt;

