--disable_warnings
drop table if exists arr_t1, arr_t2;
--enable_warnings
# join
create table arr_t1(c1 int, c2 array(int), c3 array(array(int)));
create table arr_t2(c1 int, c2 array(int));

insert into arr_t1 values(1,  [2, 2, 3, 4], [[1, 2, 3, 4], [2, 2, 3, 4], [3, 2, 3, 4]]);
insert into arr_t1 values(2,  [1, 1, 3, 4], [[1, 2, 3, 4], [1, 3, 3, 4], [1, 2, 3, 5]]);
insert into arr_t1 values(3,  [1, 2, 2, 4], [[1, 2, 3, 4], [1, 3, 3, 4], [1, 2, 3, 5]]);
insert into arr_t1 values(4,  [1, 2, 3, 3], [[100, 314, 456, 788], [555, 787, 44]]);

insert into arr_t2 values(1,  [1, 1, 1, 1]);
insert into arr_t2 values(2,  [2, 2, 2, 2]);
insert into arr_t2 values(3,  [3, 3, 3, 3]);
insert into arr_t2 values(4,  [4, 4, 4, 4]);

select t1.c1, t2.c1 from arr_t1 t1, arr_t2 t2 where array_overlaps(t1.c2, t2.c2);
drop table arr_t1;
drop table arr_t2;

--disable_warnings
drop table if exists tt1;
--enable_warnings
create table tt1(id int,c1 array(int), c2 array(varchar(256)), c3 array(tinyint), c4 array(bigint), c5 array(float), c6 array(double), c7 array(smallint));
insert into tt1 values(1,[-2147483648,0, 2147483647],['test'],[127,0,-128],[-9223372036854775808,9223372036854775807,775,808,2,0],[3.402, 0, 1.175],
[1.7976931348623157E+308, 2.2250738585072014E-308],[-32768,0,32767]);

insert into tt1 values(2,[-2147483648,0, 2147483647,4],['test'],[127,0,-128,6,77],[-9223372036854775808,9223372036854775807,775,808,2,0,1],[3.402, 0, 1.175,4],
