--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1(c1 int,c2 tinyint[],c3 vector(3),c4 smallint[],c5 varchar(30),c6 int[],c7 vector(3) as (c5*c4+c6)) PARTITION BY KEY(c1) PARTITIONS 3;
insert into t1(c1,c2,c3,c4,c5,c6) values(1,'[1,1,2]','[2,2,3]',array(1,3,2),'[1,2,3]',[2,3,4]);
insert into t1(c1,c2,c3,c4,c5,c6) values(2,'[1,0,3]','[1,0,3]',array(2,3,2),'[2,2,3]',[5,3,4]);
insert into t1(c1,c2,c3,c4,c5,c6) values(3,'[-1,2,2]','[-3,2,3]',array(4,3,3),'[3,2,3]',[6,3,4]);
insert into t1(c1,c2,c3,c4,c5,c6) values(4,'[-1,-2,-2]','[-4,2,3]',array(4,2,3),'[4,2,3]',[1,2,4]);
insert into t1(c1,c2,c3,c4,c5,c6) values(7,null,'[-1,-2,-2]',array(2,3,1),'[5,2,3]',[5,3,4]);

select  /*+enable_parallel_dml parallel(2) */ cardinality(c4) from t1 group by cardinality(c4);
select  /*+enable_parallel_dml parallel(2) */ *,cardinality(c4) from t1 group by c1 having cardinality(c4)>2 order by c1;
select  /*+enable_parallel_dml parallel(2) */ * ,abs(c1) from t1 group by abs(c1) order by c1;
select  /*+enable_parallel_dml parallel(2) */ array_overlaps(c2,c2) from t1 group by array_overlaps(c2,c2);
select  /*+enable_parallel_dml parallel(2) */ * ,array_overlaps(c4,c4) from t1 group by c1 having array_overlaps(c4,c4) order by c1;
drop table t1;

