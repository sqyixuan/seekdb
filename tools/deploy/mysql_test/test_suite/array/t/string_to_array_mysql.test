CREATE TABLE t3 (id int, c1 TINYTEXT, c2 TEXT, c3 MEDIUMTEXT, c4 LONGTEXT);
insert into t3 values (1, repeat('a',255), repeat('a',65535), repeat('a',262144), repeat('a',262144));
insert into t3 values (2, repeat('a,',255/2-1), repeat('a,',65535/2-1), repeat('a,',262144), repeat('a,',262144));
insert into t3 values (3, repeat('a',255), repeat('a',65535), repeat(concat(repeat('a',262144),','), 10), repeat(concat(repeat('a',262144),','), 10));
select id, cardinality(string_to_array(c1, ',')), cardinality(string_to_array(c2, ',')), cardinality(string_to_array(c3, ',')), cardinality(string_to_array(c4, ',')) from t3;
select /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */ id, cardinality(string_to_array(c1, ',')), cardinality(string_to_array(c2, ',')), cardinality(string_to_array(c3, ',')), cardinality(string_to_array(c4, ',')) from t3;
select /*+ OPT_PARAM('rowsets_enabled', 'FALSE') */ id, cardinality(string_to_array(c1, ',')), cardinality(string_to_array(c2, ',')), cardinality(string_to_array(c3, ',')), cardinality(string_to_array(c4, ',')) from t3;

