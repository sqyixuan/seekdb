# params type test
select string_to_array('1,2,3', ',');
select string_to_array('1, 2, 3', ',');
select string_to_array('1逗号2逗号3', '逗号');
select string_to_array('1and2and3and', 'and');
select string_to_array(',1,,2,3,,', ',');
select string_to_array('1,2,3', '');
select string_to_array('1,2,3', NULL);
select string_to_array('', ',');
select string_to_array('', NULL);
select string_to_array(NULL, ',');
--error 5083
select string_to_array(1, ',');
--error 5083
select string_to_array('1,2,3', 1);
select string_to_array(',1,,2,3,,', ',');
select string_to_array(',1,,2,3,,', ',', '');
select string_to_array(',1,,2,3,,', ',', ',');
select string_to_array(',1,,2,3,,', ',', NULL);
select string_to_array(',NN,1,,NN2,3NN,,', ',', 'NN');
select string_to_array(',空,1,,2空, 空,,空', ',', '空');
--error 5083
select string_to_array(x'0100', 1);
--error 5083
select string_to_array('1,2,3', x'01');
--error 5083
select string_to_array('1,2,3', ',', x'01');
select string_to_array(array_to_string([1,2,NULL,3],'d','n'),'d','n');
--error 1406
select string_to_array(repeat('a',262145), ',');

--disable_warnings
drop table if exists t1, t2, t3;
--enable_warnings

CREATE TABLE t1 (id int, c1 array(int), c2 array(int unsigned), c3 array(float), c4 array(array(int)), c5 array(varchar(10)), c6 vector(3));
insert into t1 (id, c1) values (1, string_to_array('1,2,,3', ',', ''));
insert into t1 (id, c2) values (2, string_to_array('1,2,,3', ',', ''));
insert into t1 (id, c3) values (3, string_to_array('1,2,,3', ',', ''));
--error 7602
insert into t1 (id, c4) values (4, string_to_array('1,2,,3', ',', ''));
insert into t1 (id, c5) values (5, string_to_array('1,2,,3', ',', ''));
--error 7600
insert into t1 (id, c6) values (6, string_to_array('1,2,,3', ',', ''));
insert into t1 (id, c6) values (6, string_to_array('1,2,3', ',', ''));
--error 1366
insert into t1 (id, c1) values (11, string_to_array('a,bb,,ccc', ',', ''));
--error 1366
insert into t1 (id, c2) values (12, string_to_array('a,bb,,ccc', ',', ''));
--error 1265
insert into t1 (id, c3) values (13, string_to_array('a,bb,,ccc', ',', ''));
--error 7602
insert into t1 (id, c4) values (14, string_to_array('a,bb,,ccc', ',', ''));
insert into t1 (id, c5) values (15, string_to_array('a,bb,,ccc', ',', ''));
--error 7600
insert into t1 (id, c6) values (16, string_to_array('a,bb,,ccc', ',', ''));
--error 1265
insert into t1 (id, c6) values (16, string_to_array('a,bb,ccc', ',', ''));
select * from t1;

--error 5083
select array_to_string(x'0100',',');
CREATE TABLE t2 (id int, c1 varchar(100), c2 char(100), c3 text, c4 blob, c5 nchar(100), c6 nvarchar(100));
INSERT INTO t2 values (1, 'a,bb,,ccc', 'a,bb,,ccc', 'a,bb,,ccc', 'a,bb,,ccc',  'a,bb,,ccc', 'a,bb,,ccc');
INSERT INTO t2 values (2, ',', ',', ',', ',', ',', ',');
INSERT INTO t2 values (3, NULL, NULL, NULL, NULL, NULL, NULL);
SELECT string_to_array(c1, ',', '') from t2 where id = 1;
SELECT string_to_array(c2, ',', '') from t2 where id = 1;
SELECT string_to_array(c3, ',', '') from t2 where id = 1;
--error 5083
SELECT string_to_array(c4, ',', '') from t2 where id = 1;
SELECT string_to_array(c5, ',', '') from t2 where id = 1;
SELECT string_to_array(c6, ',', '') from t2 where id = 1;
SELECT string_to_array('a,bb,,ccc', c1, '') from t2 where id = 2;
SELECT string_to_array('a,bb,,ccc', c2, '') from t2 where id = 2;
--error 5083
SELECT string_to_array('a,bb,,ccc', c3, '') from t2 where id = 2;
--error 5083
SELECT string_to_array('a,bb,,ccc', c4, '') from t2 where id = 2;
SELECT string_to_array('a,bb,,ccc', c5, '') from t2 where id = 2;
SELECT string_to_array('a,bb,,ccc', c6, '') from t2 where id = 2;
SELECT string_to_array('a,bb,,ccc', ',', c1) from t2 where id = 3;
SELECT string_to_array('a,bb,,ccc', ',', c2) from t2 where id = 3;

SELECT /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */  string_to_array(c1, ',', '') from t2 where id = 1;
SELECT /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */  string_to_array(c2, ',', '') from t2 where id = 1;
