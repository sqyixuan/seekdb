SELECT /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */  string_to_array('a,bb,,ccc', ',', c1) from t2 where id = 3;
SELECT /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */  string_to_array('a,bb,,ccc', ',', c2) from t2 where id = 3;

SELECT /*+ OPT_PARAM('rowsets_enabled', 'FALSE') */  string_to_array(c1, ',', '') from t2 where id = 1;
SELECT /*+ OPT_PARAM('rowsets_enabled', 'FALSE') */  string_to_array(c2, ',', '') from t2 where id = 1;
