#owner: xuqijia.xqj
#owner group: shenzhen
--echo # ----------------------------------------------------------------------
--echo # Test of array_max.
--echo # ----------------------------------------------------------------------

--disable_warnings
drop table if exists t1;
--enable_warnings

select array_max([NULL]);
select array_max([1,2,3]);
select array_max([1,2,4]);
select array_max([1,2,-4]);
select array_max([1.1,2.2,4.4]);
select array_max([1,2,NULL,3]);
--error 1235
select array_max([[1,2]]);
--error 1235
select array_max([[1],[2]]);
select array_max(['1','2']);
select array_max(['a','b','c','d']);
select array_max(["hello", "hi"]);
select array_max(['a','b',NULL,'c','d',NULL]);
select array_max(array_append([1,2,3],4));
select array_max(array_append(["hello", "world"],'OceanBase'));

select array_min([NULL]);
select array_min([1,2,3]);
select array_min([1,2,4]);
select array_min([1,2,-4]);
select array_min([1.1,2.2,4.4]);
select array_min([1,2,NULL,3]);
--error 1235
select array_min([[1,2]]);
--error 1235
select array_min([[1],[2]]);
select array_min(['1','2']);
select array_min(['a','b','c','d']);
select array_min(["hello", "hi"]);
select array_min(['a','b',NULL,'c','d',NULL]);
select array_min(array_append([1,2,3],4));
select array_min(array_append(["hello", "world"],'OceanBase'));

CREATE TABLE t1 (id int primary key, arr_tint Array(TINYINT), arr_sint Array(SMALLINT), arr_int Array(INT), arr_bint Array(BIGINT),
                 arr_utint Array(TINYINT UNSIGNED), arr_usint Array(SMALLINT UNSIGNED), arr_uint Array(INT UNSIGNED), arr_ubint Array(BIGINT UNSIGNED),
                 arr_flt Array(FLOAT), arr_dob Array(DOUBLE), vec vector(3), vchar Array(varchar(10)));
INSERT INTO t1(id) VALUES(1);
INSERT INTO t1 VALUES(2, [-1,2,1], [-1,2,1], [-1,2,1], [-1,2,1],
                      [0,2,1], [0,2,1], [0,2,1], [0,2,1],
                      [-1,2,1], [-1,2,1], [-1,2,1], ["hello", "world", "OceanBase"]);
INSERT INTO t1 VALUES(3, [-128,NULL,127], [-32768,NULL,32767], [-2147483648,NULL,2147483647], [-9223372036854775808,NULL,9223372036854775807],
                      [0,NULL,255], [0,NULL,65535], [0,NULL,4294967295], [0,NULL,9223372036854775807],
                      [-3.402823466E+38,NULL,-1.175494351E-38], [-1.7976931348623157E+308,NULL,-2.2250738585072014E-308], [0,0,0], ["hello",NULL,"hi"]);

