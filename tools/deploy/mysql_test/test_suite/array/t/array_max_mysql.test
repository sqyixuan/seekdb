--disable_warnings
drop table if exists t_create;
--enable_warnings
create table t_create as select array_max(NULL), array_max([1,2,3,4]), array_min(NULL), array_min([1,2,3,4]);
desc t_create;
select * from t_create;
drop table t_create;
create table t_create as select array_max(NULL), array_max(arr_tint), array_min(NULL), array_min(arr_tint) from t1;
desc t_create;
select * from t_create;
drop table t_create;
with array_data as (
  select id, arr_tint from t1
  where id IN (2, 3)
)
select id, array_max(arr_tint), array_min(arr_tint) from array_data order by id;

with tmax as (
  select id, array_max(arr_tint), array_min(arr_tint) from t1
)
select * from tmax order by id;

# insert

INSERT IGNORE INTO t1(id, arr_tint) select id + 2, [array_max(arr_tint), array_min(arr_tint)] from t1;
INSERT INTO t1(id, arr_tint) VALUES(6, [array_max(null)]);
INSERT INTO t1(id, arr_tint) VALUES(7, [null]);
REPLACE INTO t1(id, arr_tint) VALUES(7, [array_max([1,2,4]), array_min([1,2,4])]);
select id, arr_tint from t1 order by id;

# update

update /*+ ENABLE_PARALLEL_DML parallel(256) */
t1 set arr_tint = [array_max(null), array_min([-1, 2, 3])] where id = 2;

update t1 set arr_tint = [array_min([-1, 2, 3]), array_max(null)] where id = 3;

select id, arr_tint from t1 order by id;

# delete

delete /*+ ENABLE_PARALLEL_DML parallel(256) */ from t1 where array_max(arr_tint) > 1;

select id, arr_tint from t1 order by id;

# corner cases
--error 1582
select array_max();
--error 5083
select array_max(1);
select array_max(NULL);

--error 1582
select array_min();
--error 5083
select array_min(1);
select array_min(NULL);

--disable_warnings
drop table if exists t1;
--enable_warnings

# bugfix: 2024123100106765849
--disable_warnings
drop table if exists tt1;
--enable_warnings
create table tt1(c1 array(int));
select array_min([null]) from tt1;
select array_max([null]) from tt1;
insert into tt1 values([1,2,3]);
select array_min([null]) from tt1;
select array_max([null]) from tt1;

--disable_warnings
drop table if exists tt;
--enable_warnings

create table tt(id int, arr_int int[], arr_dint array(array(int)), arr_vec array(vector(1)), arr_char array(varchar(10)));
insert into tt values(1, [1], [[1], [2]], [[1], [2]], ['a', 'b']);
insert into tt values(2, null, [[1], [2]], [[1], [2]], ['a', 'b']);
insert into tt values(3, array_remove([1], 1), [[1], [2]], [[1], [2]], ['a', 'b']);
insert into tt values(4, [null, 1], [[1], [2]], [[1], [2]], ['a', 'b']);
insert into tt values(5, [null], [[1], [2]], [[1], [2]], ['a', 'b']);
insert into tt values(6, [1], null, [[1], [2]], ['a', 'b']);
insert into tt values(7, [1], array_remove([[1]], [1]), [[1], [2]], ['a', 'b']);
insert into tt values(8, [1], [null, [2]], [[1], [2]], ['a', 'b']);
insert into tt values(9, [1], array_append(array_remove([[1]],[1]), null), [[1], [2]], ['a', 'b']);
insert into tt values(10, [1], [[null], [2]], [[1], [2]], ['a', 'b']);
insert into tt values(11, [1], [[null, 1], [2]], [[1], [2]], ['a', 'b']);
insert into tt values(12, [1], [array_remove([1], 1)], [[1], [2]], ['a', 'b']);
insert into tt values(13, [1], [array_remove([1], 1), [2]], [[1], [2]], ['a', 'b']);
insert into tt values(14, [1], [[1], [2]], null, ['a', 'b']);
insert into tt values(15, [1], [[1], [2]], array_remove([[1]], [1]), ['a', 'b']);
insert into tt values(16, [1], [[1], [2]], array_append(array_remove([[1]],[1]), null), ['a', 'b']);
insert into tt values(17, [1], [[1], [2]], [[1], [2]], null);
insert into tt values(18, [1], [[1], [2]], [[1], [2]], array_remove(['a'], 'a'));
insert into tt values(19, [1], [[1], [2]], [[1], [2]], array_append(array_remove(['a'],'a'), null));

select id, array_max(arr_int) from tt;
select id, array_min(arr_int) from tt;

--disable_warnings
drop table if exists tt;
--enable_warnings

