select ref_25.c5 as c0,  ref_25.c7 as c1,  cast(coalesce(ref_25.c11, cast(null as BINARY)) as BINARY) as c3,  (select min(f1) from vector_test.t1 order by 1)  as c4  from  vector_test.t1 as ref_25 where EXISTS ( select   86 as c0 from  (vector_test.t as ref_26 inner join vector_test.t1 as ref_27 on (ref_26.c1 = ref_27.v1 )));
select   subq_0.c3 as c0,  subq_0.c1 as c1,   avg( cast(cast(null as DECIMAL(10, 2)) as DECIMAL(10, 2))) over (partition by subq_0.c3 order by subq_0.c3) as c2 from  (select   ref_0.id as c0,  88 as c1,  ref_1.c3 as c2,  ref_1.c2 as c3 from  ((vector_test.t as ref_0 right join vector_test.t1 as ref_1 on (94 not  in ( 62,  3,  79,  61,  36,  22))) full join vector_test.t as ref_2 on (ref_0.c1 = ref_2.c1 )) where EXISTS ( select   49 as c0,  39 as c1,  45 as c2 from  vector_test.t1 as ref_3 where 90 not  in ( 10,  6)) limit 113) as subq_0 where (EXISTS ( select distinct  72 as c0,  53 as c1,  case when EXISTS ( select distinct  27 as c0,  80 as c1,  42 as c2,  1 as c3,  100 as c4,  38 as c5 from  vector_test.test as ref_5 where 0) then 32 else 77 end  as c2,  if( 61 not  in ( 61,  1,  51,  45) , 83 , 71 )  as c3,  subq_0.c2 as c4,  ref_4.c2 as c5,  74 as c6 from  vector_test.t1 as ref_4 where subq_0.c0 * ref_4.c1))  or (EXISTS ( select   case when (EXISTS ( select   68 as c0,  36 as c1 from  vector_test.t as ref_7 where EXISTS ( select   68 as c0 from  vector_test.t2 as ref_8 where 44 in ( 3,  4,  80,  88) limit 57) limit 149))  and (21 >> 1) then 99 else 2 end  as c0,  27 as c1,  (select c3 from vector_test.test order by 1 limit 1 offset 6)  as c2,  67 as c3,  53 as c4,  ref_6.avg_vector as c5,   count( cast(cast(null as CHAR) as CHAR)) over (partition by ref_6.avg_vector order by ref_6.avg_vector) as c6,  76 as c7,  17 as c8,  ref_6.avg_vector as c9,  74 as c10,  49 as c11,  ref_6.avg_vector as c12,  cast(ifnull(14, subq_0.c1) as DECIMAL) as c13,  27 as c14,  72 as c15 from  vector_test.tt1 as ref_6 where EXISTS ( select   3 as c0,  10 as c1,  54 as c2,  67 as c3,  59 as c4,  82 as c5,  98 as c6,  72 as c7,  76 as c8,  44 as c9,  58 as c10 from  vector_test.tt0 as ref_9 where 25 in ( 19,  72,  2,  86) limit 89) limit 81)) limit 24;


# disable join filter for array type
--disable_warnings
drop table if exists t1;
drop table if exists t2;
--enable_warnings

create table t1 (c1 int, c2 bigint, c3 array(int), c4 array(varchar(16)), c5 varchar(100), c6 decimal(20,2));
create table t2 like t1;

# basic type, join filter is enabled
explain basic select /*+leading(t1,t2) use_hash(t2) px_join_filter(t2) parallel(2)*/ * from t1, t2 where t1.c2 = t2.c2;

# array type, join filter is disabled
explain basic select /*+leading(t1,t2) use_hash(t2) px_join_filter(t2) parallel(2)*/ * from t1, t2 where t1.c3 = t2.c3;

drop database vector_test;

connection admin;
alter system set _rowsets_max_rows = 256 tenant=sys;
alter system set _rowsets_max_rows = 256 tenant=all_user;
alter system set _rowsets_max_rows = 256 tenant=all_meta;
