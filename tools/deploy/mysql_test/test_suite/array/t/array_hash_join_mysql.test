alter system major freeze;
--source mysql_test/include/wait_daily_merge.inc

--echo
--echo ***** test inner join
select /*+leading(t1,t2)*/ * from t1, t2 where t1.c3 = t2.c3;
select /*+leading(t1,t2)*/ * from t1, t2 where t1.c4 = t2.c4;
select /*+leading(t2,t1)*/ * from t1, t2 where t1.c3 = t2.c4;
select a.* from t1 a join t1 b on a.c3=b.c3 union select a.* from t1 a join t1 b on a.c3=b.c3;

--echo
--echo ***** test inner join with other condition
select /*+leading(t1,t2)*/ * from t1, t2 where t1.c3 = t2.c3 and t1.c2 < t2.c2;
select /*+leading(t2,t1)*/ * from t1, t2 where t1.c3 = t2.c3 and t1.c2 < t2.c2;

--echo
--echo ***** test semi join
select /*+leading(t1,t2) use_hash(t2, t1)*/ * from t1 where c2 in (select c2 from t2);
select /*+leading(t2, t1) use_hash(t2, t1)*/ * from t1 where c2 in (select c2 from t2);
select /*+leading(t1,t2) use_hash(t2, t1)*/ * from t1 where c2 in (select c2 from t2) union select /*+leading(t1,t2) use_hash(t2, t1)*/ * from t1 where c2 in (select c2 from t2);

--echo
--echo ***** test semi join with other condition
select /*+leading(t2, t1) USE_HASH(t1, t2)*/ * from t1 where exists (select 1 from t2 where t1.c4 = t2.c4 and t1.c2 < t2.c2);
select /*+leading(t1, t2) USE_HASH(t1, t2)*/ * from t1 where exists (select 1 from t2 where t1.c4 = t2.c4 and t1.c2 < t2.c2);
select /*+leading(t1, t2) USE_HASH(t1, t2)*/ * from t1 where exists (select 1 from t2 where t1.c4 = t2.c4 and t1.c2 < t2.c2) union select /*+leading(t1, t2) USE_HASH(t1, t2)*/ * from t1 where exists (select 1 from t2 where t1.c4 = t2.c4 and t1.c2 < t2.c2);

--echo
--echo ***** test anti join
select /*+leading(t1,t2) use_hash(t2, t1)*/ * from t1 where not exists (select 1 from t2 where t1.c3 = t2.c3);
select /*+leading(t2, t1) use_hash(t2, t1)*/ * from t1 where not exists (select 1 from t2 where t1.c3 = t2.c3);

--echo
--echo *** test anti join with other condition
select /*+leading(t1,t2) use_hash(t2, t1)*/ * from t1 where not exists (select 1 from t2 where t1.c3 = t2.c3 and t1.c2 < t2.c2);
select /*+leading(t2, t1) use_hash(t2, t1)*/ * from t1 where not exists (select 1 from t2 where t1.c3 = t2.c3 and t1.c2 < t2.c2);

--echo
--echo *** test anti join with other condition
select /*+ leading(t1, t2) use_hash(t1, t2)*/ * from t1 where exists (select 1 from t2 where t1.c3 = t2.c3 and t1.c2 < t2.c2);
select /*+ leading(t2, t1) use_hash(t1, t2)*/ * from t1 where exists (select 1 from t2 where t1.c3 = t2.c3 and t1.c2 < t2.c2);

--echo
--echo ***** test left join
select /*+leading(t1,t2) use_hash(t1,t2)*/ * from t1 left join t2 on t1.c3 = t2.c3;
select /*+leading(t2, t1) use_hash(t1,t2)*/ * from t1 right join t2 on t1.c3 = t2.c3;
select /*+leading(t1,t2) use_hash(t1,t2)*/ * from t1 left join t2 on t1.c3 = t2.c3 union select /*+leading(t2, t1) use_hash(t1,t2)*/ * from t1 right join t2 on t1.c3 = t2.c3; 

--echo
--echo ***** test left join with other condition
select /*+leading(t1,t2) use_hash(t1,t2)*/ * from t1 left join t2 on t1.c3 = t2.c3 and t1.c2 < t2.c2;
select /*+leading(t2, t1) use_hash(t1,t2)*/ * from t1 right join t2 on t1.c3 = t2.c3 and t1.c2 < t2.c2;

--echo
--echo ***** test right join
select /*+leading(t1,t2) use_hash(t1,t2)*/ * from t1 right join t2 on t1.c3 = t2.c3;
select /*+leading(t2, t1) use_hash(t1,t2)*/ * from t1 left join t2 on t1.c3 = t2.c3;

--echo
--echo ***** test right join with other condition
select /*+leading(t1,t2) use_hash(t1,t2)*/ * from t1 right join t2 on t1.c3 = t2.c3 and t1.c2 < t2.c2;
select /*+leading(t2, t1) use_hash(t1,t2)*/ * from t1 left join t2 on t1.c3 = t2.c3 and t1.c2 < t2.c2;

--echo
--echo ***** test full join
select /*+leading(t1,t2) use_hash(t1,t2)*/ * from t1 full join t2 on t1.c3 = t2.c3;
select /*+leading(t2, t1) use_hash(t1,t2)*/ * from t1 full join t2 on t1.c3 = t2.c3;

--echo
--echo ***** test full join with other condition
select /*+leading(t1,t2) use_hash(t1,t2)*/ * from t1 full join t2 on t1.c3 = t2.c3 and t1.c2 < t2.c2;
select /*+leading(t2, t1) use_hash(t1,t2)*/ * from t1 full join t2 on t1.c3 = t2.c3 and t1.c2 < t2.c2;
select /*+leading(t2, t1) use_hash(t1,t2)*/ * from t1 full join t2 on t1.c3 = t2.c3 and t1.c2 < t2.c2 union select /*+leading(t2, t1) use_hash(t1,t2)*/ * from t1 full join t2 on t1.c3 = t2.c3 and t1.c2 < t2.c2;

select array_agg(a.c3) from t1 a join t1 b on a.c4=b.c4 union select array_agg(a.c3) from t1 a join t1 b on a.c4=b.c4;

drop database array_hash_join;

--disable_warnings
drop database if exists vector_test;
--enable_warnings
create database vector_test;
use vector_test;

CREATE TABLE `tt0` (
  `a1` int(11) DEFAULT NULL,
  `a2` VECTOR(3) DEFAULT NULL,
  `a3` VECTOR(3) DEFAULT NULL,
  `a4` VECTOR(3) DEFAULT NULL
) DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 3 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0;
CREATE TABLE `t1` (
  `c1` int(11) DEFAULT NULL,
  `c2` char(30) DEFAULT NULL,
  `c3` varchar(30) DEFAULT NULL,
  `c4` binary(30) DEFAULT NULL,
  `c5` varbinary(30) DEFAULT NULL,
  `c6` tinytext DEFAULT NULL,
  `c7` tinytext DEFAULT NULL,
  `c8` mediumtext DEFAULT NULL,
  `c9` longtext DEFAULT NULL,
  `c10` tinyblob DEFAULT NULL,
  `c11` tinyblob DEFAULT NULL,
  `c12` mediumblob DEFAULT NULL,
  `c13` longblob DEFAULT NULL,
  `f1` float DEFAULT NULL,
  `v1` VECTOR(3) DEFAULT NULL
) DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 3 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0;
CREATE TABLE `t` (
  `id` int(11) NOT NULL,
  `c1` VECTOR(3) DEFAULT NULL,
  PRIMARY KEY (`id`)
) DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 3 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0;
CREATE TABLE `t2` (
  `c1` int(11) NOT NULL,
  `c2` VECTOR(3) DEFAULT NULL,
  `c3` VECTOR(3) DEFAULT NULL,
  `c4` VECTOR(3) DEFAULT NULL,
  PRIMARY KEY (`c1`)
) DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 3 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0;
CREATE TABLE `tt1` (
  `avg_vector` VECTOR(3) DEFAULT NULL
) DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 3 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0;
CREATE TABLE `test` (
  `id` int(11) DEFAULT NULL,
  `c1` VECTOR(3) DEFAULT NULL,
  `c2` VECTOR(3) DEFAULT NULL,
  `c3` VECTOR(4) DEFAULT NULL,
  `c4` ARRAY(INT) DEFAULT NULL
) DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 3 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0;
