#owner: xuqijia.xqj
#owner group: shenzhen
--echo # ----------------------------------------------------------------------
--echo # Test of array_sort.
--echo # ----------------------------------------------------------------------


--disable_warnings
drop table if exists t1;
--enable_warnings

select array_sort([NULL]);
select array_sort([NULL,NULL,NULL]);
select array_sort([2,1,3]);
select array_sort([2,-1,3]);
select array_sort([2.1,3,1,1]);
select array_sort([NULL,1,2,NULL,2,NULL,NULL]);
select array_sort([1.1,2.2]);
select array_sort([1.1,2.3,2.2]);
select array_sort(['a','b','c','d']);
select array_sort(['a','a','A',NULL]);
select array_sort(["hello", "hi"]);
select array_sort(["hello","hello",NULL,NULL,"OceanBase"]);
--error 1235
select array_sort([[NULL],NULL]);
--error 1235
select array_sort([[1,2,3],[4]]);
--error 5083
select array_sort(element_at([1,2,3], 2));
select array_sort(element_at([[1,2],[3,4]], 1));

CREATE TABLE t1 (id int primary key, c1 Array(BigInt), c2 Array(BigInt UNSIGNED), c3 Array(double), c4 vector(3));
INSERT INTO t1(id) VALUES(1);
INSERT INTO t1 VALUES(2, [NULL], [NULL], [NULL], [0,0,0]);
INSERT INTO t1 VALUES(3, [-9223372036854775808,9223372036854775807,NULL,0,NULL], [cast(9223372036854775807 as unsigned),18446744073709551615,NULL,cast(0 as unsigned),NULL], [1.1,1.2,NULL,3.3], [1,3,2]);
select id, array_sort(c1), array_sort(c2), array_sort(c3), array_sort(c4) from t1;
select /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */ id, array_sort(c1), array_sort(c2), array_sort(c3), array_sort(c4) from t1;
select /*+ OPT_PARAM('rowsets_enabled', 'FALSE') */ id, array_sort(c1), array_sort(c2), array_sort(c3), array_sort(c4) from t1;

--disable_warnings
drop table if exists t_create;
--enable_warnings
create table t_create as select array_sort(NULL), array_sort([1,2,5,4]);
desc t_create;
select * from t_create;
drop table t_create;
create table t_create as select array_sort(NULL), array_sort(c1) from t1;
desc t_create;
select * from t_create;
drop table t_create;
with array_data as (
  select id, c1 from t1
)
select id, array_sort(c1) from array_data;

with tsort as (
  select id, array_sort(c1) from t1
)
select * from tsort;

# insert 

INSERT IGNORE INTO t1(id, c1) select id + 2, array_sort(c1) from t1;
# INSERT INTO t1(id, c1) VALUES(6, array_sort(null));
# REPLACE INTO t1(id, c1) VALUES(5, array_sort(null));
REPLACE INTO t1(id, c1) VALUES(5, array_sort([NULL]));

select id, c1 from t1 order by id;

# update

update /*+ ENABLE_PARALLEL_DML parallel(256) */
t1 set c1 = array_sort(c1);

update t1 set c1 = array_sort(c1) where id = 1;

select id, c1 from t1 order by id;

# corner cases
--error 1582
select array_sort();
--error 5083
select array_sort(1);
select array_sort(NULL);

drop table t1;


--disable_warnings
drop table if exists tt;
--enable_warnings

create table tt(id int, arr_int int[], arr_dint array(array(int)), arr_vec array(vector(1)), arr_char array(varchar(10)));
insert into tt values(1, [1], [[1], [2]], [[1], [2]], ['a', 'b']);
insert into tt values(2, null, [[1], [2]], [[1], [2]], ['a', 'b']);
insert into tt values(3, array_remove([1], 1), [[1], [2]], [[1], [2]], ['a', 'b']);
insert into tt values(4, [null, 1], [[1], [2]], [[1], [2]], ['a', 'b']);
insert into tt values(5, [null], [[1], [2]], [[1], [2]], ['a', 'b']);
insert into tt values(6, [1], null, [[1], [2]], ['a', 'b']);
insert into tt values(7, [1], array_remove([[1]], [1]), [[1], [2]], ['a', 'b']);
insert into tt values(8, [1], [null, [2]], [[1], [2]], ['a', 'b']);
insert into tt values(9, [1], array_append(array_remove([[1]],[1]), null), [[1], [2]], ['a', 'b']);
insert into tt values(10, [1], [[null], [2]], [[1], [2]], ['a', 'b']);
insert into tt values(11, [1], [[null, 1], [2]], [[1], [2]], ['a', 'b']);
insert into tt values(12, [1], [array_remove([1], 1)], [[1], [2]], ['a', 'b']);
insert into tt values(13, [1], [array_remove([1], 1), [2]], [[1], [2]], ['a', 'b']);
insert into tt values(14, [1], [[1], [2]], null, ['a', 'b']);
insert into tt values(15, [1], [[1], [2]], array_remove([[1]], [1]), ['a', 'b']);
insert into tt values(16, [1], [[1], [2]], array_append(array_remove([[1]],[1]), null), ['a', 'b']);
insert into tt values(17, [1], [[1], [2]], [[1], [2]], null);
insert into tt values(18, [1], [[1], [2]], [[1], [2]], array_remove(['a'], 'a'));
insert into tt values(19, [1], [[1], [2]], [[1], [2]], array_append(array_remove(['a'],'a'), null));

select id, array_sort(arr_int) from tt;
select id, array_sort(arr_char) from tt;

--disable_warnings
drop table if exists tt;
--enable_warnings

