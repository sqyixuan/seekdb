#owner: xuqijia.xqj
#owner group: shenzhen
--echo # ----------------------------------------------------------------------
--echo # Test of array_to_string expr.
--echo # ----------------------------------------------------------------------

# params type test
--error 1582
select array_to_string([1,2,3]);
select array_to_string([1,2,3], '-');
select array_to_string([NULL], '-');
select array_to_string([1,2,3], '-.-');
--error 5083
select array_to_string([1,2,3], 1);
select array_to_string([1,2,3], NULL);
select array_to_string([1,2,3], '');
select array_to_string(array(1,2,3), '-');
--error 5083
select array_to_string('1,2,3', '-');
select array_to_string(NULL, '-');
--error 5083
select array_to_string(NULL, 1);
select array_to_string([1,2,3], '-', 'N');
select array_to_string([NULL,1,NULL,2,NULL,NULL,3,NULL], '-', 'N');
select array_to_string([NULL,1,NULL,2,NULL,NULL,3,NULL], ', ', 'is null value');
select array_to_string([NULL,1,NULL,2,NULL,NULL,3,NULL], '-', '');
select array_to_string([NULL,1,NULL,2,NULL,NULL,3,NULL], '-', NULL);
--error 5083
select array_to_string([NULL,1,NULL,2,NULL,NULL,3,NULL], '-', 1);

# array type test
select array_to_string([-1,2,-3], '&', 'N');
select array_to_string([NULL,'1',NULL,'2',NULL,NULL,'3',NULL], '-', 'N');
select array_to_string([NULL,'1a',NULL,'bb',NULL,NULL,'ccc3',NULL], '-', 'N');
select array_to_string([NULL,1.1,NULL,2.22,NULL,NULL,3.33,NULL], '-', 'N');
select array_to_string([[1,2,3]], '-', 'N');
select array_to_string([[1,2,3,NULL]], '-', 'N');
select array_to_string([[1,2,3],[11]], '-', 'N');
select array_to_string([[1,2,3],[11,NULL],NULL], '-', 'N');
select array_to_string([[NULL],[NULL]], '-');
select array_to_string([[NULL,NULL],[NULL],NULL], '-');
select array_to_string([[1,2,3],[11],[22,33]], '-', 'N');
select array_to_string([[[[[[1,2,3]]]]]], '-', 'N');

--disable_warnings
drop table if exists t1, t2;
--enable_warnings

CREATE TABLE t1 (id int, c1 array(int), c2 array(int unsigned), c3 array(float), c4 array(array(int)), c5 array(varchar(10)), c6 vector(3));
insert into t1 values(1, [1,-2,3], [1,2,3], [1.1,2.22,-3.33], [[1,2],[3]], ['a','b','c'], [1,2,3]);
insert into t1 values(2, [11,-22,NULL,33], [11,22,NULL,33], [1.1,2.22,NULL,-3.33], [[1,-2,NULL],[NULL],[3]], ['a*','2',NULL,'ccc'], [1.1, -2, -3.33]);
select id, array_to_string(c1, '|', 'N') from t1;
select id, array_to_string(c2, '|', 'N') from t1;
select id, array_to_string(c3, '|', 'N') from t1;
select id, array_to_string(c4, '|', 'N') from t1;
select id, array_to_string(c5, '|', 'N') from t1;
select id, array_to_string(c6, '|', 'N') from t1;
select /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */ id, array_to_string(c1, '|', 'N') from t1;
select /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */ id, array_to_string(c2, '|', 'N') from t1;
select /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */ id, array_to_string(c3, '|', 'N') from t1;
select /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */ id, array_to_string(c4, '|', 'N') from t1;
select /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */ id, array_to_string(c5, '|', 'N') from t1;
select /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */ id, array_to_string(c6, '|', 'N') from t1;
select /*+ OPT_PARAM('rowsets_enabled', 'FALSE') */ id, array_to_string(c1, '|', 'N') from t1;
select /*+ OPT_PARAM('rowsets_enabled', 'FALSE') */ id, array_to_string(c2, '|', 'N') from t1;
select /*+ OPT_PARAM('rowsets_enabled', 'FALSE') */ id, array_to_string(c3, '|', 'N') from t1;
select /*+ OPT_PARAM('rowsets_enabled', 'FALSE') */ id, array_to_string(c4, '|', 'N') from t1;
select /*+ OPT_PARAM('rowsets_enabled', 'FALSE') */ id, array_to_string(c5, '|', 'N') from t1;
select /*+ OPT_PARAM('rowsets_enabled', 'FALSE') */ id, array_to_string(c6, '|', 'N') from t1;

CREATE TABLE t2 (id int, str varchar(100));
INSERT INTO t2 VALUES (1, array_to_string([1,2,3], '-'));
INSERT INTO t2 VALUES (2, array_to_string([1,2,3], NULL));
INSERT INTO t2 VALUES (3, array_to_string([NULL], '-'));
INSERT INTO t2 VALUES (4, array_to_string(NULL, '-'));
select * from t2;

