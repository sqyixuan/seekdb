--disable_warnings
drop table if exists t_create;
--enable_warnings
create table t_create as select array_slice(NULL,1,2), array_slice([1,2,3,4],1,2);
desc t_create;
select * from t_create;
drop table t_create;
create table t_create as select array_slice(NULL,1,2), array_slice(arr_tint,1,2) from arr_t1;
desc t_create;
select * from t_create;
drop table t_create;

# 参数个数不同的排列组合
select array_slice(arr_tint, 1, 2) from arr_t1 order by id;
select array_slice(arr_tint, 1) from arr_t1 order by id;
--error 1582
select array_slice(arr_tint) from arr_t1;
--error 1582
select array_slice() from arr_t1;
--error 1582
select array_slice(arr_tint, 1, 2, 3) from arr_t1;

with array_data as (
  select id, arr_int from arr_t1
  where id IN(2, 3)
)
select id, array_slice(arr_int, id) from array_data order by id;

with tslice as (
  select id, array_slice(arr_int, id) from arr_t1
)
select * from tslice order by id;

# insert 

INSERT IGNORE INTO arr_t1(id, arr_int) select id + 7, array_slice(arr_int, c1, c2) from arr_t1 where arr_int is not null;
INSERT INTO arr_t1(id, arr_int) VALUES(14, array_slice([1,2,3], -1, 2));

select id, arr_int from arr_t1 order by id;

--disable_warnings
drop table if exists t1;
--enable_warnings

CREATE TABLE t1 (id int primary key, arr_tint Array(TINYINT), arr_sint Array(SMALLINT), arr_int Array(INT), arr_bint Array(BIGINT),
                 arr_utint Array(TINYINT UNSIGNED), arr_usint Array(SMALLINT UNSIGNED), arr_uint Array(INT UNSIGNED), arr_ubint Array(BIGINT UNSIGNED),
                 arr_flt Array(FLOAT), arr_dob Array(DOUBLE), vec vector(3))
                 PARTITION BY RANGE (id) (
                 PARTITION p1 VALUES LESS THAN (2),
                 PARTITION p3 VALUES LESS THAN (10)
                 );
INSERT INTO t1(id) VALUES(1);
INSERT INTO t1 VALUES(2, [-1,2,1], [-1,2,1], [-1,2,1], [-1,2,1],
                      [0,2,1], [0,2,1], [0,2,1], [0,2,1],
                      [-1,2,1], [-1,2,1], [-1,2,1]);
INSERT INTO t1 VALUES(3, [-128,127], [-32768,32767], [-2147483648,2147483647], [-9223372036854775808,9223372036854775807],
                      [0,255], [0,65535], [0,4294967295], [0,9223372036854775807],
                      [-3.402823466E+38,-1.175494351E-38], [-1.7976931348623157E+308,-2.2250738585072014E-308], [0,0,0]);

# UPDATE

UPDATE t1
SET id = 8
WHERE id = 1;

update /*+ ENABLE_PARALLEL_DML parallel(256) */ 
t1 set arr_int = array_slice(arr_int, 1, 2) where id = 2;

update t1 set arr_int = array_slice(arr_int, 1, 2) where id = 3;

# delete

delete /*+ ENABLE_PARALLEL_DML parallel(256) */ from t1 where array_sum(arr_bint) = 2;
delete from t1 partition(p1);
delete from t1 where id in (select id from t1 where array_sum(arr_bint) >= 1);

--disable_warnings
drop table if exists t1;
--enable_warnings

--disable_warnings
drop table if exists arr_t1;
--enable_warnings

CREATE TABLE arr_t1(c1 int, c2 ARRAY(varchar(16)), c3 ARRAY(ARRAY(varchar(16))), c4 int);
insert into arr_t1 values(1, ["hello", "world", "hi", "what", "are you?"], [["hello", "world"], ["hi", "what"], ["are you?"]], 4);
insert into arr_t1 values(2, ["hello", "world", "hi", "what", "Are you?"], [["hello", "world"], ["hi", "what"], ["Are you?"]], 3);
insert into arr_t1 values(3, ["hello", "world", "hi", "hat", "are you?"], [["hello", "world"], ["hi", "hat"], ["are you?"]], 2);
insert into arr_t1 values(4, ["hello", "world", "hi", "what", "are You?"], [["hello", "world"], ["hi", "what"], ["are You?"]], 1);
--let $loop=30
while($loop > 0)
{
  insert into arr_t1 values(2, ["hello", "world", "hi", "what", "are you?"], [["hello", "world"], ["hi", "what"], ["are you?"]], -1);
  dec $loop;
}

select array_slice(c2, 1, 2) from arr_t1 order by c1;
select array_slice(c3, 1, 2) from arr_t1 order by c1;
select array_slice(c2, c1, c4) from arr_t1 order by c1;

--disable_warnings
drop table arr_t1;
--enable_warnings

