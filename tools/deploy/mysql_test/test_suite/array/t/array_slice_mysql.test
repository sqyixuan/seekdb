# 测试第二、三个参数的其余类型

CREATE TABLE t2 (id int,
                 arr_vchar Array(VARCHAR(10)),
                 c2 BOOL,
                 c3 VARCHAR(10),
                 c4 TINYINT,
                 c5 SMALLINT,
                 c6 INT,
                 c7 BIGINT,
                 c8 FLOAT,
                 c9 DOUBLE,
                 c10 DATETIME,
                 c11 TIMESTAMP,
                 c12 DATE,
                 c13 TIME, 
                 c14 YEAR,
                 c15 BLOB,
                 c16 ENUM('a','b','c'),
                 c17 SET('a','b','c'),
                 c18 JSON,
                 c19 GEOMETRY
                 );

