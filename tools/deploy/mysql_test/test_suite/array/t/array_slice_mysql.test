select array_slice([1,2,3], 1, 2);
select array_slice([1,2,3], 1, 4);
select array_slice([1,2,3], 1, 0);
select array_slice([1,2,3], 1, -1);
select array_slice([1,2,3], 1, -2);
select array_slice([1,2,3], 1, -7);
select array_slice([1,2,3], -2, -1);
select array_slice([1,2,3], "-100", "-1");
select array_slice([1,2,3], "1a", "2a");
select array_slice([1,2,3], "1a", "4a");
select array_slice([1,2,3], "1a", "0a");
select array_slice([1,2,3], "1a", "-1a");
select array_slice([1,2,3], "1a", "-2a");
select array_slice([1,2,3], "1a", "-7a");
select array_slice([1,2,3], "-2a", "-1a");
select array_slice([1,2,3], "-100a", "-1a");
select array_slice([1,2,3], "1.5", "2.5");
select array_slice([1,2,3], '1e-1', '2e-1');
select array_slice([1,2,3], 1.2, 2.2);
select array_slice([1,2,3], 1.2, 4.2);
select array_slice([1,2,3], 1.2, 0.2);
select array_slice([1,2,3], 1.2, -1.2);
select array_slice([1,2,3], 1.2, -2.2);
select array_slice([1,2,3], 1.2, -7.2);
select array_slice([1,2,3], -2.2, -1.2);
SELECT array_slice([1,2,3], -9223372036854775808, 1);
select array_slice([1,2,3], 1, -9223372036854775808);
select array_slice([1,2,3], -9223372036854775808, -9223372036854775808);
select array_slice([1,2,3], 9223372036854775807, 1);
select array_slice([1,2,3], 1, 9223372036854775807);
select array_slice([1,2,3], 9223372036854775807, -9223372036854775808);
