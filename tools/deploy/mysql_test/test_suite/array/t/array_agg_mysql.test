--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1(a int, b int, c array(int));

--error 5083
select sum(a) over(partition by c) from t1;
--error 5083
select sum(a) over(partition by b order by c) from t1;

insert into t1 values (1, 1, [1, 1]);
insert into t1 values (2, 2, [2, 2]);
insert into t1 values (3, 3, [3, 3]);
insert into t1 values (4, 4, [4, 4]);

select b, lead(c) over(order by b) from t1;
select b, lag(c) over(order by b) from t1;

select b, first_value(c) over (order by b) from t1;
select b, last_value(c) over (order by b) from t1;
select b, last_value(c) over (order by b rows between unbounded preceding and unbounded following) from t1;

select b, nth_value(c, 2) over (order by b) from t1;
select b, nth_value(c, 3) over (order by b) from t1;
drop table t1;
