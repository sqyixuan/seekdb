select array_agg(distinct 1);
select array_agg(distinct 'test');
select array_agg(distinct [1]);
--disable_warnings
drop function if exists b;
--enable_warnings
create function b() returns int return 1;
select array_agg(distinct b order by b desc nulls last);
drop function b;

--disable_warnings
drop table if exists ss;
--enable_warnings

CREATE TABLE `ss` (
  `id` int(11) NULL COMMENT "",
  `name` varchar(255) NULL COMMENT "",
  `subject` varchar(255) NULL COMMENT "",
  `score` float NULL COMMENT "",
   arr array(int)
);

insert into ss values (1,"Tom","English",90.5, [1,2]);
insert into ss values (1,"Tom","Math",80.8, [1,2]);
insert into ss values (2,"Tom","English",NULL,[1]);
insert into ss values (2,"Tom",NULL,NULL,null);
insert into ss values (3,"May",NULL,NULL,[2]);
insert into ss values (3,"Ti","English",98.3, [null]);
insert into ss values (4,NULL,NULL,NULL,null);
insert into ss values (NULL,NULL,NULL,NULL,null);
insert into ss values (NULL,"Ti","欢乐谷Valley",99,[3,4]);
insert into ss values (11,"你在干什么我在加班","大南山sky",98.3,[0,2]);
insert into ss values (11,"世界之窗1301","aaa华侨城看看看看",78.5,[1]);
insert into ss values (12,"深圳湾华侨城","桔钓沙看海啊",NULL,[89]);
insert into ss values (2,"香蜜湖桔钓沙","红树林钓鱼",22,[23]);
insert into ss values (3,"大梅沙小梅沙","南头古城啊啊",NULL,[1]);

select max(id), array_agg(distinct name), count(distinct id), array_agg(name) from ss where id < 2  order by 1;
select max(id), array_agg(distinct name) from ss where id < 2  order by 1;
select max(id), array_agg(distinct name), array_agg(distinct (score > 0)) from ss where id < 2 order by 1;
select max(id),array_agg(distinct name), count(distinct id), array_agg(name) from ss where id < 2  order by 1;
select max(id),array_agg(distinct name) from ss where id < 2  order by 1;
--error 1064
select max(id),array_agg(name), array_agg(name,score order by 1,2) from ss where id < 2  order by 1;
select max(id),array_agg(name), array_agg(distinct name) from ss where id < 2 order by 1;
select max(id),array_agg(distinct name), array_agg(distinct (score > 0)) from ss where id < 2 order by 1;

select id, array_agg(distinct name), count(distinct score), array_agg(name) from ss where id < 2 group by id order by 1;
select id, array_agg(distinct name) from ss where id < 2 group by id order by id;
--error 1064
select id, array_agg(name), array_agg(name,score order by 1,2) from ss where id < 2 group by id order by 1;
select id, array_agg(name), array_agg(distinct name) from ss where id < 2 group by id order by 1;
select id, array_agg(distinct name), array_agg(distinct (score > 1)) from ss where id < 2 group by id order by 1;
select score, array_agg(distinct name), count(distinct id), array_agg(name) from ss where id < 2 group by score order by 1;
select score, array_agg(distinct name) from ss where id < 2 group by score order by score;
--error 1064
select score, array_agg(name), array_agg(name,score order by 1,2) from ss where id < 2 group by score order by 1;
select score, array_agg(name), array_agg(distinct name) from ss where id < 2 group by score order by 1;
select score, array_agg(distinct name), array_agg(distinct (score > 1)) from ss where id < 2 group by score order by 1;

# order by number isn't supported, ignore order by
select array_agg(name order by 1 asc), array_agg(name order by 1 desc) from ss group by id order by id;
select array_agg(name order by 1 desc nulls first), array_agg(name order by 1 desc nulls last) from ss group by id order by id;
select array_agg(name order by 1 desc nulls first), array_agg(name order by 1 desc nulls last) from ss group by id order by id;
select array_agg(name order by 1 nulls first), array_agg(name order by 1 nulls last) from ss group by id order by id;

select array_agg(name order by name asc), array_agg(name order by name desc) from ss group by id order by id;
select array_agg(name order by name desc nulls first), array_agg(name order by name desc nulls last) from ss group by id order by id;
select array_agg(name order by name desc nulls first), array_agg(name order by name desc nulls last) from ss group by id order by id;
select array_agg(name order by name nulls first), array_agg(name order by name nulls last) from ss group by id order by id;

select array_agg(distinct name order by name asc), array_agg(name order by name desc) from ss order by id;
select array_agg(distinct name order by name asc), array_agg(distinct name order by name desc) from ss order by id;
select array_agg(name order by name asc), array_agg(name order by name desc) from ss order by id;
select array_agg(name order by name desc nulls first), array_agg(name order by name desc nulls last) from ss order by id;
select array_agg(name order by name desc nulls first), array_agg(name order by name desc nulls last) from ss order by id;
select array_agg(name order by name nulls first), array_agg(name order by name nulls last) from ss order by id;

select array_agg(distinct subject order by 1, name) from ss group by id order by id;
select array_agg(distinct name order by 1), cardinality(array_agg(distinct name order by 1)) from ss group by id order by id;
select array_agg(name order by name), array_agg(distinct name order by name, score) from ss group by id order by id;

select array_agg(score order by score asc), array_agg(score order by score desc) from ss order by id;
select array_agg(distinct score order by score asc), array_agg(distinct score order by score desc) from ss order by id;
select array_agg(score order by name asc), array_agg(score order by name desc) from ss order by id;
select array_agg(score order by score desc nulls first), array_agg(score order by score desc nulls last) from ss order by id;
select array_agg(score order by name desc nulls first), array_agg(score order by name desc nulls last) from ss order by id;
select array_agg(score order by score nulls first), array_agg(score order by score nulls last) from ss order by id;

# order by array type isn't supported 
--error 5083
select array_agg(arr order by arr asc), array_agg(arr order by arr desc) from ss;
select array_agg(arr), array_agg(distinct arr) from ss;

--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1 as select array_agg(score),
                          array_agg(distinct score order by score asc),
                          array_agg(distinct score order by score desc nulls last),
                          array_agg(arr) from ss;
select * from t1;
drop table t1;

# corner cases
--error 1064
select array_agg();
--error 1064
select array_agg() from ss;
select array_agg('.');
select array_agg(null);
select array_agg("奥星贝斯" order by id) from ss;
select array_agg([2,2,2]) from ss;

--disable_warnings
drop table if exists tt3;
--enable_warnings
create table tt3(id int,b bigint ,a varchar(100));
insert into tt3 values(1,1,'test1');
insert into tt3 values(2,1,'test3');
insert into tt3 values(3,3,null);
insert into tt3 values(4,3,null);
insert into tt3 values(5,2,'test3');

select array_agg(a order by a nulls first,b nulls last) from tt3;
select array_agg(a order by a nulls first,b ) from tt3;
select array_agg(a order by b nulls first,a nulls last) from tt3;
select array_agg(a order by b nulls first,a nulls first) from tt3;
drop table tt3;

