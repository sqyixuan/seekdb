#owner: xuqijia.xqj
#owner group: shenzhen
--echo # ----------------------------------------------------------------------
--echo # Test of array_compact.
--echo # ----------------------------------------------------------------------


--disable_warnings
drop table if exists t1, t2;
--enable_warnings

select array_compact([NULL]);
select array_compact([NULL,NULL,NULL]);
select array_compact([1,2,3]);
select array_compact([1,1,2,1,1]);
select array_compact([NULL,NULL,1,2,NULL,2,NULL,NULL]);
select array_compact([1.1,2.2]);
select array_compact([1.1,2.2,2.2]);
select array_compact(['a','b','c','d']);
select array_compact(['a','a','A',NULL]);
select array_compact(["hello", "hi"]);
select array_compact(["hello","hello",NULL,NULL,"OceanBase"]);
select array_compact([[NULL],NULL]);
select array_compact([[1,2,3],[4]]);
select array_compact([[1,2,3],[1,2,3],[4],[4]]);
select array_compact([[1,2,3],NULL,NULL,[4,5],[4]]);
select array_compact([[1,2,3,NULL],[4,NULL],[4,NULL]]);
select array_compact([[1.1],[1.1],[1.1,2.2],NULL,NULL]);
select array_compact([['a','b','c','d'],['a','b','c','d'],['a','b','c','d']]);
select array_compact([NULL,NULL,['a',NULL],['a',NULL],['d']]);
select array_compact([["hello", "world"],["hi", "what"],["hi", "what"],["are you?"]]);

--error 5083
select array_compact(element_at([1,2,3], 2));
select array_compact(element_at([[1,2],[3,4]], 1));
select array_compact(element_at([[1,1],[4,4]], 1));
select array_compact(element_at([[1,2],[3,4]], 10));
select array_compact(element_at([["hello", "world"], ["hi", "what"], ["are you?"]], 3));
select array_compact(array_append([1,2,3], 3));
select array_compact(array_append([["hello", "world"], ["hi", "what"], ["are you?"]], ["hi", "what"]));

CREATE TABLE t1 (id int primary key, c1 Array(BigInt), c2 Array(double), c3 Array(varchar(1)), c4 Array(varchar(10)), c5 vector(3));
INSERT INTO t1(id) VALUES(1);
INSERT INTO t1 VALUES(2, [NULL], [NULL], [NULL], [NULL], [0,0,0]);
INSERT INTO t1 VALUES(3, [1,1,NULL,3], [1.1,1.1,NULL,3.3], ['a','a',NULL,'c'], ['hello','hello',NULL,'Ocean'], [1,1,3]);
select id, array_compact(c1), array_compact(c2), array_compact(c3), array_compact(c4), array_compact(c5) from t1;
select /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */ id, array_compact(c1), array_compact(c2), array_compact(c3), array_compact(c4), array_compact(c5) from t1;
select /*+ OPT_PARAM('rowsets_enabled', 'FALSE') */ id, array_compact(c1), array_compact(c2), array_compact(c3), array_compact(c4), array_compact(c5) from t1;

create table t2 (id int, c1 int[][], c2 float[][], c3 varchar(1)[][], c4 varchar(10)[][]);
INSERT INTO t2(id) VALUES(1);
INSERT INTO t2 VALUES(2, [[NULL]], [[NULL]], [[NULL]], [[NULL]]);
INSERT INTO t2 VALUES(3, [[NULL],[NULL]], [[NULL],[NULL]], [[NULL],[NULL]], [[NULL],[NULL]]);
INSERT INTO t2 VALUES(4, [[1,2],[1,2],NULL,NULL], [[1.1,2.2],[1.1,2.2],NULL,NULL], [['a','b'],['a','b'],NULL,NULL], [['hello', 'world'],['hello', 'world'],NULL,NULL]);
select id, array_compact(c1), array_compact(c2), array_compact(c3), array_compact(c4) from t2;
select /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */ id, array_compact(c1), array_compact(c2), array_compact(c3), array_compact(c4) from t2;
select /*+ OPT_PARAM('rowsets_enabled', 'FALSE') */ id, array_compact(c1), array_compact(c2), array_compact(c3), array_compact(c4) from t2;

--disable_warnings
drop table if exists t_create;
--enable_warnings
create table t_create as select array_compact(NULL), array_compact([1,2,3,4]);
desc t_create;
select * from t_create;
drop table t_create;
create table t_create as select array_compact(NULL), array_compact(c1) from t1;
desc t_create;
select * from t_create;
drop table t_create;
# insert

INSERT IGNORE t1(id, c1) select id + 2, array_compact(c1) from t1;
# INSERT INTO t1(id, c1) VALUES(6, array_compact(null));
# REPLACE INTO t1(id, c1) VALUES(5, array_compact(null));
select id, c1 from t1 order by id;

# update

update /*+ ENABLE_PARALLEL_DML parallel(256) */
t1 set c1 = array_compact(c1) where id > 1;

update t1 set c1 = array_compact([null, 1, 1, 2]) where id = 1;

select id, c1 from t1 order by id;

# corner cases
--error 1582
select array_compact();
--error 5083
select array_compact(1);
select array_compact(NULL);

drop table t1, t2;

--disable_warnings
drop table if exists tt;
--enable_warnings

create table tt(id int, arr_int int[], arr_dint array(array(int)), arr_vec array(vector(1)), arr_char array(varchar(10)));
insert into tt values(1, [1], [[1], [2]], [[1], [2]], ['a', 'b']);
insert into tt values(2, null, [[1], [2]], [[1], [2]], ['a', 'b']);
insert into tt values(3, array_remove([1], 1), [[1], [2]], [[1], [2]], ['a', 'b']);
insert into tt values(4, [null, 1], [[1], [2]], [[1], [2]], ['a', 'b']);
insert into tt values(5, [null], [[1], [2]], [[1], [2]], ['a', 'b']);
insert into tt values(6, [1], null, [[1], [2]], ['a', 'b']);
insert into tt values(7, [1], array_remove([[1]], [1]), [[1], [2]], ['a', 'b']);
insert into tt values(8, [1], [null, [2]], [[1], [2]], ['a', 'b']);
insert into tt values(9, [1], array_append(array_remove([[1]],[1]), null), [[1], [2]], ['a', 'b']);
insert into tt values(10, [1], [[null], [2]], [[1], [2]], ['a', 'b']);
insert into tt values(11, [1], [[null, 1], [2]], [[1], [2]], ['a', 'b']);
insert into tt values(12, [1], [array_remove([1], 1)], [[1], [2]], ['a', 'b']);
insert into tt values(13, [1], [array_remove([1], 1), [2]], [[1], [2]], ['a', 'b']);
insert into tt values(14, [1], [[1], [2]], null, ['a', 'b']);
insert into tt values(15, [1], [[1], [2]], array_remove([[1]], [1]), ['a', 'b']);
insert into tt values(16, [1], [[1], [2]], array_append(array_remove([[1]],[1]), null), ['a', 'b']);
insert into tt values(17, [1], [[1], [2]], [[1], [2]], null);
insert into tt values(18, [1], [[1], [2]], [[1], [2]], array_remove(['a'], 'a'));
insert into tt values(19, [1], [[1], [2]], [[1], [2]], array_append(array_remove(['a'],'a'), null));

select id, array_compact(arr_int) from tt;
select id, array_compact(arr_dint) from tt;
select id, array_compact(arr_vec) from tt;
select id, array_compact(arr_char) from tt;

--disable_warnings
drop table if exists tt;
--enable_warnings

