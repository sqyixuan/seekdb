--disable_warnings
drop table if exists arr_test, t1;
drop view if exists v1;
--enable_warnings

CREATE TABLE `arr_test` (
  `id` int(11) NULL COMMENT "",
  `name` varchar(255) NULL COMMENT "",
  `subject` varchar(255) NULL COMMENT "",
  `score` float NULL COMMENT "",
   arr array(int)
);

insert into arr_test values (1,"Tom","English",90.5, [1,2]);
insert into arr_test values (1,"Tom","Math",80.8, [1,2]);
insert into arr_test values (2,"Tom","English",NULL,[1]);
insert into arr_test values (2,"Tom",NULL,NULL,null);
insert into arr_test values (3,"May",NULL,NULL,[2]);
insert into arr_test values (3,"Ti","English",98.3, [null]);
insert into arr_test values (4,NULL,NULL,NULL,null);
insert into arr_test values (NULL,NULL,NULL,NULL,null);
insert into arr_test values (NULL,"Ti","欢乐谷Valley",99,[3,4]);
insert into arr_test values (11,"你在干什么我在加班","大南山sky",98.3,[0,2]);
insert into arr_test values (11,"世界之窗1301","aaa华侨城看看看看",78.5,[1]);
insert into arr_test values (12,"深圳湾华侨城","桔钓沙看海啊",NULL,[89]);
insert into arr_test values (2,"香蜜湖桔钓沙","红树林钓鱼",22,[23]);
insert into arr_test values (3,"大梅沙小梅沙","南头古城啊啊",NULL,[1]);

select array_map(x->(x+12), array_agg(score)) from arr_test;
select array_map(x->(x > 90), array_agg(score)) from arr_test;
select array_map(x->(x + id), [1]) from arr_test;
select array_map(x->(concat(x, '!!!')), array_agg(name)) from arr_test;
select array_map(x->(length(x) > 3), array_agg(name)) from arr_test;
select array_map(x ->(upper(x)), array_agg(subject)) from arr_test;
select array_map((x,y)->(concat(concat(x, ' : '), y)), array_agg(name), array_agg(subject)) from arr_test;
create table t1 as select array_map(x->(concat(x, '!!!')), array_agg(name)) from arr_test;
select * from t1;
drop table t1;
drop table arr_test;

# partition table
CREATE TABLE `arr_test` (
  `id` int(11) NULL COMMENT "",
  `name` varchar(255) NULL COMMENT "",
  `subject` varchar(255) NULL COMMENT "",
  `score` float NULL COMMENT "",
   arr array(int)
) partition by hash(id) partitions 3;

insert into arr_test values (1,"Tom","English",90.5, [1,2]);
insert into arr_test values (1,"Tom","Math",80.8, [1,2]);
insert into arr_test values (2,"Tom","English",NULL,[1]);
insert into arr_test values (2,"Tom",NULL,NULL,null);
insert into arr_test values (3,"May",NULL,NULL,[2]);
insert into arr_test values (3,"Ti","English",98.3, [null]);

select array_map(x->(x+12), array_agg(score)) from arr_test;
select array_map(x->(x + id), [1]) from arr_test;
select array_map(x->(concat(x, '!!!')), array_agg(name)) from arr_test;
select array_map(x->(x > 90), array_agg(score)) from arr_test;
drop table arr_test;

create table t1 as select array_map(x -> (round(x,1)), [1.22, 3.44, 5.33]);
select * from t1;
drop table t1;
create table t1 as select array_map((x,y)->(x+y), array_map(x2->(x2+1),[1,2,3]),array_map(x1->(x1+2),[1,2,3]));
select * from t1;
drop table t1;
create table t1 as select array_map((x) -> (1), null);
select * from t1;
drop table t1;
create view v1 as  select array_map((x,y) -> (x+y), [1],[1]);
select * from v1;
drop view v1;

