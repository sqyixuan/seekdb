--disable_warnings
drop materialized view if exists mv1;
--enable_warnings
CREATE TABLE t1 (c1 int primary key, c2 int[], c3 float[]);
insert into t1(c1,c2,c3) values(1,'[1,1,2]',[2,2,3]);
insert into t1(c1,c2,c3) values(2,'[2,2,3]',[3,2,3]);
create materialized view mv1(primary key(c1))  as select c1,array_map((x,y) -> (x*y), c2,c2) c2  from t1 ;
select * from mv1;
drop table t1;
drop materialized view mv1;

CREATE TABLE t1 (c1 int primary key, c2 int[],c3 float[],c4 varchar(256)[][])partition by hash(c1) partitions 4;
insert into t1 values(1,[1,2,3,5],[2.123,2.123,3.123,4.123],[['中文ing123',1,'1']]);
insert into t1 values(2,[2,3,4,5],[2.123,2.123,3.123,4.123],[[null,'a','sss']]);
insert into t1 values(3,[3,3,3,3],[3.123,2.123,3.123,4.123],[['null','a','sss']]);
insert into t1 values(4,[2,3,4,5],[4.123,2.123,3.123,4.123],[[2,3,4,5]]);
insert into t1 values(5,null,null,null);
select array_map((x) -> ([c4]), [1]) from t1;
drop table t1;

CREATE TABLE t1 (c1 float UNSIGNED[],c2 double UNSIGNED[], c3 tinyint UNSIGNED[],c4 smallint UNSIGNED[],c5 int UNSIGNED[],c6 bigint UNSIGNED[], c7 smallint[], c8 int primary key AUTO_INCREMENT) ;
insert into t1 (c1,c2,c3,c4,c5,c6,c7) values([1],[1],[1],[1],[1],[1],[1]);
select array_map((x) -> (x), c1) from t1;
select array_map((x) -> (x), c2) from t1;
select array_map((x) -> (x), c3) from t1;
select array_map((x) -> (x), c4) from t1;
select array_map((x) -> (x), c5) from t1;
select array_map((x) -> (x), c6) from t1;
select array_map((x) -> (x), c7) from t1;
drop table t1;

