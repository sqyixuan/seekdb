select array_map(x -> (round(x,1)), [1.22, 3.44, 5.33]);
select array_map(x ->(length(x)), ['abc', 'efgaa']);
select array_map((x, y)->(floor((y - x) / x)), [4, 5, 6], [3,8,5]);
SELECT array_map(x ->(x LIKE '%World%'), ['Hello', 'abc World']);
select array_map(x1->(x1+1.66),[1,2,3]);
select array_map(x1->(x1+9223372036854775800),[1,2,3]);
