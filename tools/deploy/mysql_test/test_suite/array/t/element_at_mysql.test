#owner group: shenzhen
--echo # ----------------------------------------------------------------------
--echo # Test of element_at.
--echo # ----------------------------------------------------------------------


--disable_warnings
drop table if exists t1, t2;
--enable_warnings

select element_at([1,2,3], '1');
select element_at([1,2,3], 1.1);
select element_at([1,2,3], 1.6);
select element_at([1,2,3], "1a");
select element_at([1,2,3], "1.6");
select element_at([1,2,3], '25e-1');
select element_at([1,2,3], 2);
select element_at([1,2,3], 0);
select element_at([1,2,3], 4);
select element_at([1,2,3], -1);
select element_at([1,NULL,3], 2);
select element_at([1.1,2.2,3.3], 2);
select element_at(['a','b','c'], 2);
select element_at(['a','bb','ccc'], 2);
select element_at(['a',NULL,'bb','ccc'], 2);
select element_at(['a',NULL,'bb','ccc'], 4);
select element_at([[1,2],[3,4]], 1);
select element_at([[1.1,2.2],[3.3,4.4]], 2);
select element_at([["a", "b"]], 1);
select element_at([["hello", "world"], ["hi", "what"], ["are you?"]], 3);

CREATE TABLE t1 (id int, c1 Array(BigInt), c2 Array(double), c3 Array(varchar(1)), c4 Array(varchar(10)), c5 vector(3));
INSERT INTO t1(id) VALUES(1);
INSERT INTO t1 VALUES(2, [NULL], [NULL], [NULL], [NULL], [0,0,0]);
INSERT INTO t1 VALUES(3, [1,2,NULL,3], [1.1,2.2,NULL,3.3], ['a','b',NULL,'c'], ['hello','world',NULL,'Ocean'], [1,2,3]);
select id, element_at(c1, 1), element_at(c1, 3), element_at(c1, 5) from t1;
select id, element_at(c2, 1), element_at(c2, 3), element_at(c2, 5) from t1;
select id, element_at(c3, 1), element_at(c3, 3), element_at(c3, 5) from t1;
select id, element_at(c4, 1), element_at(c4, 3), element_at(c4, 5) from t1;
select id, element_at(c5, 1), element_at(c5, 3), element_at(c5, 5) from t1;
select /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */ id, element_at(c1, 1), element_at(c1, 3), element_at(c1, 5) from t1;
select /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */ id, element_at(c2, 1), element_at(c2, 3), element_at(c2, 5) from t1;
select /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */ id, element_at(c3, 1), element_at(c3, 3), element_at(c3, 5) from t1;
select /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */ id, element_at(c4, 1), element_at(c4, 3), element_at(c4, 5) from t1;
select /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */ id, element_at(c5, 1), element_at(c5, 3), element_at(c5, 5) from t1;
select /*+ OPT_PARAM('rowsets_enabled', 'FALSE') */ id, element_at(c1, 1), element_at(c1, 3), element_at(c1, 5) from t1;
select /*+ OPT_PARAM('rowsets_enabled', 'FALSE') */ id, element_at(c2, 1), element_at(c2, 3), element_at(c2, 5) from t1;
select /*+ OPT_PARAM('rowsets_enabled', 'FALSE') */ id, element_at(c3, 1), element_at(c3, 3), element_at(c3, 5) from t1;
select /*+ OPT_PARAM('rowsets_enabled', 'FALSE') */ id, element_at(c4, 1), element_at(c4, 3), element_at(c4, 5) from t1;
select /*+ OPT_PARAM('rowsets_enabled', 'FALSE') */ id, element_at(c5, 1), element_at(c5, 3), element_at(c5, 5) from t1;

create table t2 (id int, c1 int[][], c2 float[][], c3 varchar(1)[][], c4 varchar(10)[][]);
INSERT INTO t2(id) VALUES(1);
INSERT INTO t2 VALUES(2, [[NULL]], [[NULL]], [[NULL]], [[NULL]]);
INSERT INTO t2 VALUES(3, [[1,2,3],[4,NULL],NULL], [[1.1,2.2,3.3],[4.4,NULL],NULL], [['a','b','c'],['d',NULL],NULL], [['hello', 'world'], ['hi',NULL],NULL]);
select id, element_at(c1, 1), element_at(c1, 3), element_at(c1, 5) from t2;
select id, element_at(c2, 1), element_at(c2, 3), element_at(c2, 5) from t2;
select id, element_at(c3, 1), element_at(c3, 3), element_at(c3, 5) from t2;
select id, element_at(c4, 1), element_at(c4, 3), element_at(c4, 5) from t2;
select /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */ id, element_at(c1, 1), element_at(c1, 3), element_at(c1, 5) from t2;
select /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */ id, element_at(c2, 1), element_at(c2, 3), element_at(c2, 5) from t2;
select /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */ id, element_at(c3, 1), element_at(c3, 3), element_at(c3, 5) from t2;
select /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */ id, element_at(c4, 1), element_at(c4, 3), element_at(c4, 5) from t2;
select /*+ OPT_PARAM('rowsets_enabled', 'FALSE') */ id, element_at(c1, 1), element_at(c1, 3), element_at(c1, 5) from t2;
select /*+ OPT_PARAM('rowsets_enabled', 'FALSE') */ id, element_at(c2, 1), element_at(c2, 3), element_at(c2, 5) from t2;
select /*+ OPT_PARAM('rowsets_enabled', 'FALSE') */ id, element_at(c3, 1), element_at(c3, 3), element_at(c3, 5) from t2;
select /*+ OPT_PARAM('rowsets_enabled', 'FALSE') */ id, element_at(c4, 1), element_at(c4, 3), element_at(c4, 5) from t2;

# corner cases
--error 1582
select element_at();
--error 5083
select element_at('.',2);
select element_at(NULL,2);
select element_at([NULL], 1);
select element_at([1,2,3], NULL);

--disable_warnings
drop table if exists t1, t2;
--enable_warnings

# bugfix: 2024120600106035705 / 2024120600106050116
--disable_warnings
drop table if exists tt1;
--enable_warnings
CREATE TABLE tt1 (id int PRIMARY KEY, vec vector(3));
insert into tt1 values (1, [1,1,1]);
insert into tt1 values (2, [1,2,3]);
insert into tt1 values (3, NULL);
select element_at(vec,2) from tt1;
select element_at([vec],1) from tt1;
select element_at([[vec]],1) from tt1;
select /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */ element_at(vec,2) from tt1;
select /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */ element_at([vec],1) from tt1;
select /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */ element_at([[vec]],1) from tt1;
select /*+ OPT_PARAM('rowsets_enabled', 'FALSE') */ element_at(vec,2) from tt1;
select /*+ OPT_PARAM('rowsets_enabled', 'FALSE') */ element_at([vec],1) from tt1;
select /*+ OPT_PARAM('rowsets_enabled', 'FALSE') */ element_at([[vec]],1) from tt1;

select array_append(vec, 4) from tt1;
--error 7602
select array_append(vec, [4]) from tt1;
--error 5083
select array_append([vec], 4) from tt1;
-- error 7600
select array_append([vec], [4]) from tt1;
select array_append([vec], [4,5,6]) from tt1;
select array_append([[vec]], [[4,5,6]]) from tt1;
select array_append([[vec]], [vec]) from tt1;

select array_remove(vec, 4) from tt1;
--error 7602
select array_remove(vec, [4]) from tt1;
--error 5083
select array_remove([vec], 4) from tt1;
-- error 7600
select array_remove([vec], [4]) from tt1;
select array_remove([vec], [4,5,6]) from tt1;
select array_remove([[vec]], [[4,5,6]]) from tt1;
select array_remove([[vec]], [vec]) from tt1;

select * from tt1,unnest([vec]);
select * from tt1,unnest([vec, vec]);

drop table tt1;

# bugfix: 2025012200107094530
create table tt1 (id int, c1 int[]);
insert into tt1 values (1, '[]');
select element_at(c1, 1), element_at(c1, 100), element_at(c1, 1620078759), element_at(c1, 4294967296) from tt1;
select /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */ element_at(c1, 1), element_at(c1, 100), element_at(c1, 1620078759), element_at(c1, 4294967296) from tt1;
select /*+ OPT_PARAM('rowsets_enabled', 'FALSE') */ element_at(c1, 1), element_at(c1, 100), element_at(c1, 1620078759), element_at(c1, 4294967296) from tt1;
drop table tt1;

--disable_warnings
drop table if exists tt;
--enable_warnings

create table tt(id int, arr_int int[], arr_dint array(array(int)), arr_vec array(vector(1)), arr_char array(varchar(10)));
insert into tt values(1, [1], [[1], [2]], [[1], [2]], ['a', 'b']);
insert into tt values(2, null, [[1], [2]], [[1], [2]], ['a', 'b']);
insert into tt values(3, array_remove([1], 1), [[1], [2]], [[1], [2]], ['a', 'b']);
insert into tt values(4, [null, 1], [[1], [2]], [[1], [2]], ['a', 'b']);
insert into tt values(5, [null], [[1], [2]], [[1], [2]], ['a', 'b']);
insert into tt values(6, [1], null, [[1], [2]], ['a', 'b']);
insert into tt values(7, [1], array_remove([[1]], [1]), [[1], [2]], ['a', 'b']);
insert into tt values(8, [1], [null, [2]], [[1], [2]], ['a', 'b']);
insert into tt values(9, [1], array_append(array_remove([[1]],[1]), null), [[1], [2]], ['a', 'b']);
insert into tt values(10, [1], [[null], [2]], [[1], [2]], ['a', 'b']);
insert into tt values(11, [1], [[null, 1], [2]], [[1], [2]], ['a', 'b']);
insert into tt values(12, [1], [array_remove([1], 1)], [[1], [2]], ['a', 'b']);
insert into tt values(13, [1], [array_remove([1], 1), [2]], [[1], [2]], ['a', 'b']);
insert into tt values(14, [1], [[1], [2]], null, ['a', 'b']);
insert into tt values(15, [1], [[1], [2]], array_remove([[1]], [1]), ['a', 'b']);
insert into tt values(16, [1], [[1], [2]], array_append(array_remove([[1]],[1]), null), ['a', 'b']);
insert into tt values(17, [1], [[1], [2]], [[1], [2]], null);
insert into tt values(18, [1], [[1], [2]], [[1], [2]], array_remove(['a'], 'a'));
insert into tt values(19, [1], [[1], [2]], [[1], [2]], array_append(array_remove(['a'],'a'), null));

select * from tt;

select id, element_at(arr_int, 1), element_at(arr_int, NULL) from tt;
select id, element_at(arr_dint, 1), element_at(arr_dint, NULL) from tt;
select id, element_at(arr_vec, 1), element_at(arr_vec, NULL) from tt;
select id, element_at(arr_char, 1), element_at(arr_char, NULL) from tt;
select /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */ id, element_at(arr_int, 1), element_at(arr_int, NULL) from tt;
select /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */ id, element_at(arr_dint, 1), element_at(arr_dint, NULL) from tt;
select /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */ id, element_at(arr_vec, 1), element_at(arr_vec, NULL) from tt;
select /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */ id, element_at(arr_char, 1), element_at(arr_char, NULL) from tt;

--disable_warnings
drop table if exists tt;
--enable_warnings


# bugfix

--disable_warnings
drop table if exists tt3;
--enable_warnings

create table tt3(id int ,a1 varchar(50),a2 binary(10),a3 varbinary(10),a4 text,a5 blob);
insert into tt3 values(1,'3','3','3','3','3');

select element_at([1,2,3,4],a2) from tt3;
select element_at([1,2,3,4],a3) from tt3;
select element_at([1,2,3,4],a4) from tt3;
select element_at([1,2,3,4],a5) from tt3;

--disable_warnings
drop table if exists tt3;
--enable_warnings
