select s_1, array_remove(s_1, 'a'), array_contains(s_1, 'a') from array_test;
select s_1, array_remove(s_1, null), array_contains(s_1, null) from array_test;
select i_1, array_remove(i_1, 3), array_contains(i_1, 3) from array_test;
select i_1, array_remove(i_1, 3.11), array_contains(i_1, 3.11) from array_test;
select i_1, array_remove(i_1, null), array_contains(i_1, null) from array_test;
select f_1, array_remove(f_1, 2.1), array_contains(f_1, 2.1) from array_test;
select f_1, array_remove(f_1, 10), array_contains(f_1, 10) from array_test;
select f_1, array_remove(f_1, null), array_contains(f_1, null) from array_test;
select d_1, array_remove(d_1, 3.2), array_contains(d_1, 3.2) from array_test;
