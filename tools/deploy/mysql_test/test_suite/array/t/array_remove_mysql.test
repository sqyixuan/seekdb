select array_remove([1,2,3], 2);
select array_remove([1,2,3], 6);
select array_remove([1,2,3], 2.0);
select array_remove([1.1,2.2,3.3], 2.2);
select array_remove(["hello", "hi"], "hel");
select array_remove(["hello", "hi"], "hi");
select array_remove([[1,2],[3,4]], [3,4]);
select array_remove([[1,2],[3,4]], [3.0,4.0]);
select array_remove([[1,2],[3,4]], [2,3]);
select array_remove([["hello", "world"], ["hi", "what"], ["are you?"]], ["are you?"]);
select array_remove([["hello", "world"], ["hi", "what"], ["are you?"]], ["hi", "what"]);
select array_remove([["hello", "world"], ["hi", "what"], ["are you?"]], ["world", "hi"]);
select array_remove([["hello", "world"], ["hi", "what"], ["are you?"]], ["are You?"]);
select array_remove([100, 3.14159268888, 4.56, 7.88], 3.14159);
select array_remove([100, 3.14159268888, 4.56, 7.88], 3.14159268888);
select array_remove([100, 3.1415926, 4.56, 7.88], 3.14159268888);
select array_remove(['abdc','2','a'],2);
select array_remove([1,2,3], '2');
select array_remove([1234567,3,34,5,5,6,null],cast(1.123 as float));
select array_remove([1234567,3,34,5,5,6,null,1.123],cast(1.123 as float));
select array_remove([1,3,34,5,5,6,null,1.123],cast(1.123 as float));
--error 5083
select array_remove([1,3,34,5,5,6,null,20241115],cast(20241115 as datetime));
--error 5083
select array_remove([1,3,34,5,5,6,null,20241115],cast(20241115 as time));
--error 5083
select array_remove([1,3,34,5,5,6,null,20241115],cast(20241115 as year));
select array_remove([18446744073709551615,18446744073709551614],9223372036854775808);
select array_remove([18446744073709551615,18446744073709551614],18446744073709551615);

--disable_warnings
drop table if exists array_test;
--enable_warnings

CREATE TABLE array_test ( 
pk bigint not null ,
s_1   Array(varchar(64)), 
i_1   Array(BigInt),
f_1   Array(float),
d_1   Array(double),
d_2   Array(double),
d_3   Array(double),
d_4   Array(double) ,
d_5   Array(double),
d_6   Array(double) ,
ai_1  Array(Array(BigInt)),
as_1  Array(Array(varchar(64))),
aas_1 Array(Array(Array(varchar(64)))),
aad_1 Array(Array(Array(double)))
);

