select d_1, array_remove(d_1, null), array_contains(d_1, null) from array_test;
select d_2, array_remove(d_2, 100), array_contains(d_2, 100) from array_test;
select d_2, array_remove(d_2, null), array_contains(d_2, null) from array_test;
select ai_1, array_remove(ai_1, [5, 2, 6, 4]), array_contains(ai_1, [5, 2, 6, 4]) from array_test;
select ai_1, array_remove(ai_1, null), array_contains(ai_1, null) from array_test;
