#owner: jiahuan.wjh
#owner group: shenzhen
--echo # ----------------------------------------------------------------------
--echo # Test of array_union.
--echo # ----------------------------------------------------------------------

select array_union([1,2,3], [1,2]);
select array_union([1,1,2,2,3], [1,2]);
select array_union([1,2,3], [1,1,2]);
select array_union([1.1,2.2,1], [1]);
select array_union([1], [2], [3]);
select array_union(["test", "array"], ["test"]);
select array_union(["test", "array"], [1,2]);
select array_union([1, null], [null]);
select array_union(null, [1]);
select array_union(array_remove([1],1),array_remove([1],1));
select array_union(array_remove([1],1), [1,2,3]);
select array_union([1,2,3], array_remove([1],1));
select array_union([1,2,3],[1,2,3], array_remove([1],1));
select array_union(["test", "array"], array_remove(["A"],"A"));
select array_union(array_remove(["A"],"A"), ["test", "array"]);
select array_union(["test", "array"], ["test", "array"], array_remove(["A"],"A"));
select array_union([[1],[1],[3]],array_remove([[1]],[1]));
select array_union([[1],[1],[3]], [[1],[2],[3]], array_remove([[1]],[1]));
select array_union(array_remove([[1]],[1]), [[1],[2],[3]]);
select array_union([1,2,3], NULL);
select array_union(NULL, [1,2,3]);

--error 5083
select array_union(1, null);
--error 5083
select array_union(1, 1, 1);
--error 1582
select array_union([1]);
--error 1582
select array_union();

--disable_warnings
drop table if exists arr_t1;
--enable_warnings

CREATE TABLE arr_t1(id int,
                    c1 int,
                    c2 double,
                    arr_tint Array(TINYINT),
                    arr_sint Array(SMALLINT),
                    arr_int Array(INT),
                    arr_bint Array(BIGINT),
                    arr_uint Array(INT UNSIGNED),
                    arr_utint Array(TINYINT UNSIGNED),
                    arr_usint Array(SMALLINT UNSIGNED),
                    arr_usbigint Array(BIGINT UNSIGNED),
                    arr_vchar Array(VARCHAR(10)),
                    arr_double Array(DOUBLE),
                    arr_float Array(FLOAT),
                    c3 ARRAY(ARRAY(FLOAT)),
                    c4 ARRAY(ARRAY(double)),
                    c5 ARRAY(ARRAY(INT)),
                    c6 ARRAY(ARRAY(SMALLINT))
                    );

