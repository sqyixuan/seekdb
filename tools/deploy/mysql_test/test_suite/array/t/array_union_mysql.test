with array_data as (
  select id, arr_tint, arr_sint from arr_t1
  where id IN(5, 6)
)
select id, array_union(arr_tint, arr_sint) from array_data order by id;

with tunion as (
  select id, array_union(arr_tint, arr_sint) from arr_t1
  where id IN(5, 6)
)
select * from tunion order by id;

