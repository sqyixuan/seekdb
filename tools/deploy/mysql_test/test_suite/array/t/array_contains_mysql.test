--error 5083
select array_contains([1,3,34,5,5,6,null,20241115],cast(20241115 as time));
--error 5083
select array_contains([1,3,34,5,5,6,null,20241115],cast(20241115 as year));

--disable_warnings
drop table if exists arr_t1;
--enable_warnings

CREATE TABLE arr_t1(c1 int, c2 ARRAY(ARRAY(double)), c3 ARRAY(ARRAY(FLOAT)), c4 array(int), c5 array(double));
insert into arr_t1 values(1, [[5.55,7.87,44],[66,123.67,95.27],[1.28,3.1415,289.33]],[[5.55,7.87,44],[66,123.67,95.27],[1.28,3.1415,289.33]], [1, 2, 3, 4], [1.33, 2.44, 3.55, 4.66]);
insert into arr_t1 values(2, [[5.55,7.87,44],[66,123.66,95.27],[1.28,3.1415,289.33]],[[5.55,7.87,44],[66,123.67,95.27],[1.28,3.1415,289.33]], [1, 2, 3, 4], [1.33, 2.44, 3.55, 4.66]);
insert into arr_t1 values(3, [[5.55,7.87,44],[66,123.67,95.27],[1.28,3.1415,289.33]],[[5.55,7.87,44],[66,123.67,95.27],[1.28,3.1415,289.33]], [1, 2, 3, 4], [1.33, 2.44, 3.52, 4.66]);
insert into arr_t1 values(4, [[5.55,7.87,44],[66,123.67,95.27],[1.28,3.1415,289.33]],[[5.55,7.87,44],[66,123.67,95.27],[1.28,3.1415,289.33]], [1, 2, 2, 4], [1.33, 2.44, 3.55, 4.66]);
--let $loop=30
while($loop > 0)
{
  insert into arr_t1 values(5, [[5.55,7.87,44],[66,123.67,95.27],[1.28,3.1415,289.33]],[[5.55,7.87,44],[66,123.67,95.27],[1.28,3.1415,289.33]], [1, 2, 3, 4], [1.33, 2.44, 3.55, 4.66]);
  dec $loop;
}
select array_contains(c2, [66,123.67,95.27]) from arr_t1;
select c1 from arr_t1 where array_contains(c2, [66,123.67,95.27]);
select c1 from arr_t1 where array_contains(c2, [66,123.67,95.27]) = false;
select c1 from arr_t1 where [66,123.67,95.27] = ANY(c2);
select array_contains(c3, [66,123.67,95.27]) from arr_t1;
select c1 from arr_t1 where [66,123.67,95.27] = ANY(c3);
select array_contains(c4, 3) from arr_t1;
select c1 from arr_t1 where array_contains(c4, 3);
select c1 from arr_t1 where 3 = ANY(c4);
select array_contains(c5, 3.55) from arr_t1;
select c1 from arr_t1 where array_contains(c5, 3.55);
select c1 from arr_t1 where 3.55 = ANY(c5);
select c1 from arr_t1 where array_contains(c4, c1) = 1;
select c1 from arr_t1 where c1 = ANY(c4);
drop table arr_t1;

CREATE TABLE arr_t1(c1 int, c2 ARRAY(varchar(16)), c3 ARRAY(ARRAY(varchar(16))));
insert into arr_t1 values(1, ["hello", "world", "hi", "what", "are you?"], [["hello", "world"], ["hi", "what"], ["are you?"]]);
insert into arr_t1 values(2, ["hello", "world", "hi", "what", "Are you?"], [["hello", "world"], ["hi", "what"], ["Are you?"]]);
insert into arr_t1 values(3, ["hello", "world", "hi", "hat", "are you?"], [["hello", "world"], ["hi", "hat"], ["are you?"]]);
insert into arr_t1 values(4, ["hello", "world", "hi", "what", "are You?"], [["hello", "world"], ["hi", "what"], ["are You?"]]);
--let $loop=30
while($loop > 0)
{
  insert into arr_t1 values(5, ["hello", "world", "hi", "what", "are you?"], [["hello", "world"], ["hi", "what"], ["are you?"]]);
  dec $loop;
}
select array_contains(c3, ["are you?"]) from arr_t1;
select array_contains(c3, ["hi", "what"]) from arr_t1;
select array_contains(c3, ["world", "hi"]) from arr_t1;
select array_contains(c3, ["are You?"]) from arr_t1;
select c1 from arr_t1 where array_contains(c3, ["are you?"]);
select c1 from arr_t1 where array_contains(c3, ["hi", "what"]);
select c1 from arr_t1 where array_contains(c3, ["world", "hi"]);
select c1 from arr_t1 where array_contains(c3, ["are You?"]);
select c1 from arr_t1 where ["world", "hi"] = ANY(c3);
select array_contains(c2, "are you?") from arr_t1;
select array_contains(c2, "what") from arr_t1;
select array_contains(c2, "hi") from arr_t1;
select array_contains(c2, "are You?") from arr_t1;
select c1 from arr_t1 where array_contains(c2, "are you?");
select c1 from arr_t1 where array_contains(c2, "what");
select c1 from arr_t1 where array_contains(c2, "hi");
select c1 from arr_t1 where array_contains(c2, "are You?");
select c1 from arr_t1 where "what" = ANY(c2);

drop table arr_t1;
create table arr_t1(c1 array(double), c2 array(float), c3 float, c4 double);
