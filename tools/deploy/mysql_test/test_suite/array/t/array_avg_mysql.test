--echo # ----------------------------------------------------------------------
--echo # Test of array_avg.
--echo # ----------------------------------------------------------------------

--disable_warnings
drop table if exists t1;
--enable_warnings

--error 1690
select array_avg([9223372036854775807,1]);
--error 1690
select array_avg([-9223372036854775808,-1]);
--error 1690
select array_avg([1.7976931348623157E+308,1.1E+300]);
--error 1690
select array_avg([1.7976931348623157E+308,1.0E+308]);
--error 1690
select array_avg([18446744073709551615,18446744073709551614]);

select array_avg([NULL]);
select array_avg([1,2,3]);
select array_avg([1,2,4]);
select array_avg([1,2,-4]);
select array_avg([1.1,2.2,4.4]);
select array_avg([1,2,NULL,3]);
select array_avg([18446744073709551615]);
--error 1235
select array_avg([[1,2]]);
--error 1235
select array_avg([[1],[2]]);
--error 1235
select array_avg(['1','2']);
select array_avg(array_append([1,2,3],4));

CREATE TABLE t1 (id int primary key, arr_tint Array(TINYINT), arr_sint Array(SMALLINT), arr_int Array(INT), arr_bint Array(BIGINT),
                 arr_utint Array(TINYINT UNSIGNED), arr_usint Array(SMALLINT UNSIGNED), arr_uint Array(INT UNSIGNED), arr_ubint Array(BIGINT UNSIGNED),
                 arr_flt Array(FLOAT), arr_dob Array(DOUBLE), vec vector(3));
INSERT INTO t1(id) VALUES(1);
INSERT INTO t1 VALUES(2, [-1,2,1], [-1,2,1], [-1,2,1], [-1,2,1],
                      [0,2,1], [0,2,1], [0,2,1], [0,2,1],
                      [-1,2,1], [-1,2,1], [-1,2,1]);
INSERT INTO t1 VALUES(3, [-128,127], [-32768,32767], [-2147483648,2147483647], [-9223372036854775808,9223372036854775807],
                      [0,255], [0,65535], [0,4294967295], [0,9223372036854775807],
                      [-3.402823466E+38,-1.175494351E-38], [-1.7976931348623157E+308,-2.2250738585072014E-308], [0,0,0]);

select arr_tint, array_avg(arr_tint) from t1;
select arr_sint, array_avg(arr_sint) from t1;
select arr_int, array_avg(arr_int) from t1;
select arr_bint, array_avg(arr_bint) from t1;
select arr_utint, array_avg(arr_utint) from t1;
select arr_usint, array_avg(arr_usint) from t1;
select arr_uint, array_avg(arr_uint) from t1;
select arr_ubint, array_avg(arr_ubint) from t1;
select arr_flt, array_avg(arr_flt) from t1;
select arr_dob, array_avg(arr_dob) from t1;
select vec, array_avg(vec) from t1;

select /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */ arr_tint, array_avg(arr_tint) from t1;
select /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */ arr_sint, array_avg(arr_sint) from t1;
select /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */ arr_int, array_avg(arr_int) from t1;
select /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */ arr_bint, array_avg(arr_bint) from t1;
select /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */ arr_utint, array_avg(arr_utint) from t1;
select /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */ arr_usint, array_avg(arr_usint) from t1;
select /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */ arr_uint, array_avg(arr_uint) from t1;
select /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */ arr_ubint, array_avg(arr_ubint) from t1;
select /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */ arr_flt, array_avg(arr_flt) from t1;
select /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */ arr_dob, array_avg(arr_dob) from t1;
select /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */ vec, array_avg(vec) from t1;

select /*+ OPT_PARAM('rowsets_enabled', 'FALSE') */ arr_tint, array_avg(arr_tint) from t1;
select /*+ OPT_PARAM('rowsets_enabled', 'FALSE') */ arr_sint, array_avg(arr_sint) from t1;
select /*+ OPT_PARAM('rowsets_enabled', 'FALSE') */ arr_int, array_avg(arr_int) from t1;
select /*+ OPT_PARAM('rowsets_enabled', 'FALSE') */ arr_bint, array_avg(arr_bint) from t1;
select /*+ OPT_PARAM('rowsets_enabled', 'FALSE') */ arr_utint, array_avg(arr_utint) from t1;
select /*+ OPT_PARAM('rowsets_enabled', 'FALSE') */ arr_usint, array_avg(arr_usint) from t1;
select /*+ OPT_PARAM('rowsets_enabled', 'FALSE') */ arr_uint, array_avg(arr_uint) from t1;
select /*+ OPT_PARAM('rowsets_enabled', 'FALSE') */ arr_ubint, array_avg(arr_ubint) from t1;
select /*+ OPT_PARAM('rowsets_enabled', 'FALSE') */ arr_flt, array_avg(arr_flt) from t1;
select /*+ OPT_PARAM('rowsets_enabled', 'FALSE') */ arr_dob, array_avg(arr_dob) from t1;
select /*+ OPT_PARAM('rowsets_enabled', 'FALSE') */ vec, array_avg(vec) from t1;

--disable_warnings
drop table if exists t_create;
--enable_warnings
create table t_create as select array_avg(NULL), array_avg([1,2,3,4]);
desc t_create;
select * from t_create;
drop table t_create;
create table t_create as select array_avg(NULL), array_avg(arr_tint) from t1;
desc t_create;
select * from t_create;
drop table t_create;
with array_data as (
  select id, arr_int from t1
  where id IN (2, 3)
)
select id, array_avg(arr_int) from array_data order by id;

with tavg as (
  select id, array_avg(arr_int) from t1
)
select * from tavg order by id;

# insert 

INSERT IGNORE INTO t1(id, arr_int) 
select id + 2, [array_avg(arr_bint), array_avg(arr_tint), array_avg(arr_int)]
from t1;

# INSERT INTO t1(id, arr_int) VALUES(6, array_avg(null));
# REPLACE INTO t1(id, arr_int) VALUES(2, array_avg(null));

select id, arr_int from t1 order by id;

# UPDATE

update /*+ ENABLE_PARALLEL_DML parallel(256) */
t1 set arr_int = [array_avg(null), array_avg(arr_bint), array_avg(arr_tint)]
where id = 2;

update t1 set arr_int = [array_avg(null), array_avg(arr_bint), array_avg(arr_tint)]
where id = 3;

select id, arr_int from t1 order by id;

# delete

delete /*+ ENABLE_PARALLEL_DML parallel(256) */ from t1 where array_avg(arr_int) <= 0;

select id, arr_int from t1 order by id;

# corner cases
--error 1582
select array_avg();
--error 5083
select array_avg(1);
select array_avg(NULL);

--disable_warnings
drop table if exists t1;
--enable_warnings

# bug fix

select array_avg([9223372036854775604,-9223372036854775808]);
select array_avg([9223372036854775604]);
select array_avg([-9223372036854775808]);

--disable_warnings
drop table if exists tt;
--enable_warnings

create table tt(id int, arr_int int[], arr_dint array(array(int)), arr_vec array(vector(1)), arr_char array(varchar(10)));
insert into tt values(1, [1], [[1], [2]], [[1], [2]], ['a', 'b']);
insert into tt values(2, null, [[1], [2]], [[1], [2]], ['a', 'b']);
insert into tt values(3, array_remove([1], 1), [[1], [2]], [[1], [2]], ['a', 'b']);
insert into tt values(4, [null, 1], [[1], [2]], [[1], [2]], ['a', 'b']);
insert into tt values(5, [null], [[1], [2]], [[1], [2]], ['a', 'b']);
insert into tt values(6, [1], null, [[1], [2]], ['a', 'b']);
insert into tt values(7, [1], array_remove([[1]], [1]), [[1], [2]], ['a', 'b']);
insert into tt values(8, [1], [null, [2]], [[1], [2]], ['a', 'b']);
insert into tt values(9, [1], array_append(array_remove([[1]],[1]), null), [[1], [2]], ['a', 'b']);
insert into tt values(10, [1], [[null], [2]], [[1], [2]], ['a', 'b']);
insert into tt values(11, [1], [[null, 1], [2]], [[1], [2]], ['a', 'b']);
insert into tt values(12, [1], [array_remove([1], 1)], [[1], [2]], ['a', 'b']);
insert into tt values(13, [1], [array_remove([1], 1), [2]], [[1], [2]], ['a', 'b']);
insert into tt values(14, [1], [[1], [2]], null, ['a', 'b']);
insert into tt values(15, [1], [[1], [2]], array_remove([[1]], [1]), ['a', 'b']);
insert into tt values(16, [1], [[1], [2]], array_append(array_remove([[1]],[1]), null), ['a', 'b']);
insert into tt values(17, [1], [[1], [2]], [[1], [2]], null);
insert into tt values(18, [1], [[1], [2]], [[1], [2]], array_remove(['a'], 'a'));
insert into tt values(19, [1], [[1], [2]], [[1], [2]], array_append(array_remove(['a'],'a'), null));

select id, array_avg(arr_int) from tt;

--disable_warnings
drop table if exists tt;
--enable_warnings

