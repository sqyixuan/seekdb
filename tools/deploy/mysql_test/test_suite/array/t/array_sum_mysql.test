--disable_warnings
drop table if exists t1;
--enable_warnings

--error 1690
select array_sum([9223372036854775807,1]);
--error 1690
select array_sum([-9223372036854775808,-1]);
--error 1690
select array_sum([1.7976931348623157E+308,1.1E+300]);
--error 1690
select array_sum([1.7976931348623157E+308,1.0E+308]);
--error 1690
select array_sum([18446744073709551615,18446744073709551614]);


select array_sum([NULL]);
select array_sum([1,2,3]);
select array_sum([1,2,4]);
select array_sum([1,2,-4]);
select array_sum([1.1,2.2,4.4]);
select array_sum([1,3,NULL,3]);
select array_sum([18446744073709551615]);
--error 1235
select array_sum([[1,2]]);
--error 1235
select array_sum([[1],[2]]);
--error 1235
select array_sum(['1','2']);
select array_sum(array_append([1,2,3],4));

CREATE TABLE t1 (id int, arr_tint Array(TINYINT), arr_sint Array(SMALLINT), arr_int Array(INT), arr_bint Array(BIGINT),
                 arr_utint Array(TINYINT UNSIGNED), arr_usint Array(SMALLINT UNSIGNED), arr_uint Array(INT UNSIGNED), arr_ubint Array(BIGINT UNSIGNED),
                 arr_flt Array(FLOAT), arr_dob Array(DOUBLE), vec vector(3));
INSERT INTO t1(id) VALUES(1);
INSERT INTO t1 VALUES(2, [-1,2,1], [-1,2,1], [-1,2,1], [-1,2,1],
                      [0,2,1], [0,2,1], [0,2,1], [0,2,1],
                      [-1,2,1], [-1,2,1], [-1,2,1]);
INSERT INTO t1 VALUES(3, [-128,127], [-32768,32767], [-2147483648,2147483647], [-9223372036854775808,9223372036854775807],
                      [0,255], [0,65535], [0,4294967295], [0,9223372036854775807],
                      [-3.402823466E+38,-1.175494351E-38], [-1.7976931348623157E+308,-2.2250738585072014E-308], [0,0,0]);


select arr_tint, array_sum(arr_tint) from t1 order by id;
select arr_sint, array_sum(arr_sint) from t1 order by id;
select arr_int, array_sum(arr_int) from t1 order by id;
select arr_bint, array_sum(arr_bint) from t1 order by id;
select arr_utint, array_sum(arr_utint) from t1 order by id;
select arr_usint, array_sum(arr_usint) from t1 order by id;
select arr_uint, array_sum(arr_uint) from t1 order by id;
select arr_ubint, array_sum(arr_ubint) from t1 order by id;
select arr_flt, array_sum(arr_flt) from t1 order by id;
select arr_dob, array_sum(arr_dob) from t1 order by id;
select vec, array_sum(vec) from t1 order by id;

select /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */ arr_tint, array_sum(arr_tint) from t1 order by id;
select /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */ arr_sint, array_sum(arr_sint) from t1 order by id;
select /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */ arr_int, array_sum(arr_int) from t1 order by id;
select /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */ arr_bint, array_sum(arr_bint) from t1 order by id;
select /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */ arr_utint, array_sum(arr_utint) from t1 order by id;
select /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */ arr_usint, array_sum(arr_usint) from t1 order by id;
select /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */ arr_uint, array_sum(arr_uint) from t1 order by id;
select /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */ arr_ubint, array_sum(arr_ubint) from t1 order by id;
select /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */ arr_flt, array_sum(arr_flt) from t1 order by id;
select /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */ arr_dob, array_sum(arr_dob) from t1 order by id;
select /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */ vec, array_sum(vec) from t1 order by id;

select /*+ OPT_PARAM('rowsets_enabled', 'FALSE') */ arr_tint, array_sum(arr_tint) from t1 order by id;
select /*+ OPT_PARAM('rowsets_enabled', 'FALSE') */ arr_sint, array_sum(arr_sint) from t1 order by id;
select /*+ OPT_PARAM('rowsets_enabled', 'FALSE') */ arr_int, array_sum(arr_int) from t1 order by id;
select /*+ OPT_PARAM('rowsets_enabled', 'FALSE') */ arr_bint, array_sum(arr_bint) from t1 order by id;
select /*+ OPT_PARAM('rowsets_enabled', 'FALSE') */ arr_utint, array_sum(arr_utint) from t1 order by id;
select /*+ OPT_PARAM('rowsets_enabled', 'FALSE') */ arr_usint, array_sum(arr_usint) from t1 order by id;
select /*+ OPT_PARAM('rowsets_enabled', 'FALSE') */ arr_uint, array_sum(arr_uint) from t1 order by id;
select /*+ OPT_PARAM('rowsets_enabled', 'FALSE') */ arr_ubint, array_sum(arr_ubint) from t1 order by id;
select /*+ OPT_PARAM('rowsets_enabled', 'FALSE') */ arr_flt, array_sum(arr_flt) from t1 order by id;
select /*+ OPT_PARAM('rowsets_enabled', 'FALSE') */ arr_dob, array_sum(arr_dob) from t1 order by id;
select /*+ OPT_PARAM('rowsets_enabled', 'FALSE') */ vec, array_sum(vec) from t1 order by id;

--disable_warnings
drop table if exists t_create;
--enable_warnings
create table t_create as select array_sum(NULL), array_sum([1,3,5]);
desc t_create;
select * from t_create;
drop table t_create;
create table t_create as select array_sum(NULL), array_sum(arr_tint) from t1;
desc t_create;
select * from t_create;
drop table t_create;

# corner cases
--error 1582
select array_sum();
--error 5083
select array_sum(1);
select array_sum(NULL);

# 参数个数不同的排列组合

--error 1582
select array_sum();
--error 1582
select array_sum(arr_bint, arr_bint) from t1;
--error 1582
select array_sum(arr_bint, arr_bint, arr_bint) from t1;

# 参数类型嵌套

--error 1235
select array_sum([[1,2],[3,4]]);

# order by

select id, array_sum(arr_bint) from t1 order by array_sum(arr_bint);
select id, array_sum(arr_bint) from t1 having id + 1 >= 2;
select * from t1 having array_sum(arr_bint) >= 1 order by id;
select id, array_sum(arr_bint) from t1 where array_sum(arr_bint) >= 1 order by id;
select id, array_sum(arr_bint) AS total_sum from t1 order by id for update;
select /*+read_consistency(weak) */ id, array_sum(arr_bint) from t1 order by id;
select /*+ ENABLE_PARALLEL_DML parallel(256) */ id, array_sum(arr_bint) from t1 order by id;

with array_data as (
  select id, arr_int from t1 
  where id IN(2,3)
) 
select id, array_sum(arr_int) from array_data order by id;

with tsum as (
  select id, array_sum(arr_bint) AS total_sum from t1
)
select * from tsum order by id;

# insert

INSERT IGNORE INTO t1(id) SELECT array_sum(arr_bint) from t1 where arr_bint IS NOT NULL;
INSERT INTO t1(id, arr_bint) VALUES(array_sum([1,2,3]), [1,2,3]);
INSERT INTO t1(id, arr_bint) VALUES(array_sum([1,2,3]), [1,2,3]) ON DUPLICATE KEY UPDATE arr_bint = [1,2,4];
REPLACE INTO t1(id, arr_int) VALUES(array_sum([1,2,3]), [1,2,4]);
INSERT IGNORE INTO t1(id, arr_int) VALUES(array_sum([1,2,3]), [1,2,4]);
insert /*+ direct(true,100) enable_parallel_dml parallel(2) append*/ into t1 select * from t1;
insert /*+ direct(true,100,'inc') enable_parallel_dml parallel(2)*/ into t1 select * from t1;


--disable_warnings
drop table if exists t1;
--enable_warnings

CREATE TABLE t1 (id int primary key, arr_tint Array(TINYINT), arr_sint Array(SMALLINT), arr_int Array(INT), arr_bint Array(BIGINT),
                 arr_utint Array(TINYINT UNSIGNED), arr_usint Array(SMALLINT UNSIGNED), arr_uint Array(INT UNSIGNED), arr_ubint Array(BIGINT UNSIGNED),
                 arr_flt Array(FLOAT), arr_dob Array(DOUBLE), vec vector(3))
                 PARTITION BY RANGE (id) (
                 PARTITION p1 VALUES LESS THAN (2),
                 PARTITION p3 VALUES LESS THAN (10)
                 );
INSERT INTO t1(id) VALUES(1);
INSERT INTO t1 VALUES(2, [-1,2,1], [-1,2,1], [-1,2,1], [-1,2,1],
                      [0,2,1], [0,2,1], [0,2,1], [0,2,1],
                      [-1,2,1], [-1,2,1], [-1,2,1]);
INSERT INTO t1 VALUES(3, [-128,127], [-32768,32767], [-2147483648,2147483647], [-9223372036854775808,9223372036854775807],
                      [0,255], [0,65535], [0,4294967295], [0,9223372036854775807],
                      [-3.402823466E+38,-1.175494351E-38], [-1.7976931348623157E+308,-2.2250738585072014E-308], [0,0,0]);

INSERT INTO t1(id, arr_int) VALUES(6, [array_sum(null)]);

select id, arr_int from t1 order by id;

# UPDATE

UPDATE t1
SET id = 8
WHERE id = 1;

update /*+ ENABLE_PARALLEL_DML parallel(256) */ 
t1 set id = array_sum(arr_bint) where id = 2;

update t1 set id = array_sum(arr_bint) where id = 3;

# delete

delete /*+ ENABLE_PARALLEL_DML parallel(256) */ from t1 where array_sum(arr_bint) = 2;
delete from t1 partition(p1);
delete from t1 where id in (select id from t1 where array_sum(arr_bint) >= 1);

# offline ddl

ALTER TABLE t1 ADD arr_tint2 Array(TINYINT) AFTER arr_tint;
ALTER TABLE t1 ADD arr_tint3 Array(TINYINT) FIRST;
ALTER TABLE t1 MODIFY id INT AUTO_INCREMENT;
ALTER TABLE t1 MODIFY id TINYINT;

--disable_warnings
drop table if exists t1;
--enable_warnings

CREATE TABLE t1 (id int, arr_tint Array(TINYINT), arr_sint Array(SMALLINT), arr_int Array(INT), arr_bint Array(BIGINT),
                 arr_utint Array(TINYINT UNSIGNED), arr_usint Array(SMALLINT UNSIGNED), arr_uint Array(INT UNSIGNED), arr_ubint Array(BIGINT UNSIGNED),
                 arr_flt Array(FLOAT), arr_dob Array(DOUBLE), vec vector(3))
                 PARTITION BY RANGE (id) (
                 PARTITION p0 VALUES LESS THAN (2),
                 PARTITION p3 VALUES LESS THAN (10)
                 );
INSERT INTO t1(id) VALUES(1);
INSERT INTO t1 VALUES(2, [-1,2,1], [-1,2,1], [-1,2,1], [-1,2,1],
                      [0,2,1], [0,2,1], [0,2,1], [0,2,1],
                      [-1,2,1], [-1,2,1], [-1,2,1]);
INSERT INTO t1 VALUES(3, [-128,127], [-32768,32767], [-2147483648,2147483647], [-9223372036854775808,9223372036854775807],
                      [0,255], [0,65535], [0,4294967295], [0,9223372036854775807],
                      [-3.402823466E+38,-1.175494351E-38], [-1.7976931348623157E+308,-2.2250738585072014E-308], [0,0,0]);

ALTER TABLE t1 ADD PRIMARY KEY (id);
ALTER TABLE t1 DROP PRIMARY KEY;
ALTER TABLE t1 ADD COLUMN sum INT AS (array_sum(arr_bint) + array_sum(arr_int));
ALTER TABLE t1 DROP COLUMN sum;
ALTER TABLE t1 DROP COLUMN arr_bint;
ALTER TABLE t1 
    MODIFY COLUMN id TINYINT,
    ADD department VARCHAR(100),
    DROP COLUMN arr_int;

TRUNCATE TABLE t1;
ALTER TABLE t1 CONVERT TO CHARACTER SET utf8mb4;

ALTER TABLE t1 DROP PARTITION p0;
ALTER TABLE t1 TRUNCATE PARTITION p3;
ALTER TABLE t1 PARTITION BY HASH(id) PARTITIONS 4;

--disable_warnings
drop MATERIALIZED VIEW if exists mv;
drop view if exists vw;
--enable_warnings

CREATE MATERIALIZED VIEW mv 
as
select id, array_sum(arr_tint) from t1;

CREATE VIEW vw
as
select id, array_sum(arr_tint) from t1;

--disable_warnings
drop MATERIALIZED VIEW if exists mv;
drop view if exists vw;
--enable_warnings

