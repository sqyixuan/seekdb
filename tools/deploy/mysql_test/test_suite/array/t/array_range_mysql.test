--echo # ----------------------------------------------------------------------
--echo # Test of array_range.
--echo # ----------------------------------------------------------------------


--disable_warnings
drop table if exists t1, t2;
--enable_warnings

select array_range(NULL);
select array_range(NULL, NULL);
select array_range(NULL, NULL, NULL);
select array_range(0);
select array_range(1);
select array_range(10);
select array_range(10.1);
select array_range(10.6);
select array_range("10.5a");
select array_range('2.5');
select cardinality(array_range(2000000));
--error 4019
select array_range(2000001);

--error 1210
select array_range(-1);
select array_range(1.1);
select array_range('a');

select array_range(-2, 5);
--error 4019
select array_range(-2, 1999999);

select array_range(0, NULL);
select array_range(3, 3);
select array_range(3, 2);
select array_range('1.5','4.5');
select array_range('10e-1','25e-1');

select array_range(-100,9223372036854775806,9223372036854775804);
select array_range(-9223372036854775808,9223372036854775807,9223372036854775807);
select array_range(100,-9223372036854775806,-9223372036854775804);
select array_range(-100,9223372036854775806,922337203685477580);
select array_range(100,-9223372036854775806,-922337203685477580);
select array_range(9223372036854775807,-9223372036854775808,-92233720368547758);
select array_range(9223372036854775807,-9223372036854775808,-9223372036854775808);

select array_range(-2, 6, 2);
select array_range(-2, 6.4, 2);
select array_range(-2, 5.7, 2);
select array_range(-2, "6a", 2);
select array_range(-2, 6, 2.3);
select array_range(-2, 6, 1.5);
select array_range(-2, 6, "2a");
select array_range(-2, 6, -1);
select array_range(4, -6, -2);
select array_range(4, -6, 1);
select array_range(-2, 6, NULL);
select array_range('1.5','4.5','1.5');
select array_range('10e-1','25e-1','15e-1');
--error 4019
select array_range(-2000000, 2000002, 2);

create table t1 (id int primary key, c1 tinyint[]);
insert into t1 values (1, array_range(10));
insert into t1 values (2, array_range(2, -6, -1));
insert into t1 values (3, array_range(NULL));
--error 1264
insert into t1 values (4, array_range(200));
select * from t1;

with array_data as (
  select id from t1
) 
select id, array_range(id) from array_data order by id;

with trange as (
  select id, array_range(id) from t1
)
select * from trange order by id;

# INSERT

INSERT IGNORE INTO t1 (id, c1) select id + 2, array_range(id) from t1;
INSERT INTO t1 (id, c1) VALUES(6, array_range(null));
REPLACE INTO t1 (id, c1) VALUES(5, array_range(null));

select * from t1 order by id;

# update

update /*+ ENABLE_PARALLEL_DML parallel(256) */
t1 set c1 = array_range(id);

update t1 set c1 = array_range(null) where id = 1;

select id, c1 from t1 order by id;

drop table t1;

# bugfix

--disable_warnings
drop table if exists tt3;
--enable_warnings

create table tt3(id int ,a1 varchar(50),a2 binary(10),a3 varbinary(10),a4 text,a5 blob);
insert into tt3 values(1,'3','3','3','3','3');

select array_range(a3) from tt3;
select array_range(a2) from tt3;
select array_range(a4) from tt3;
select array_range(a5) from tt3;

--disable_warnings
drop table if exists tt3;
--enable_warnings

