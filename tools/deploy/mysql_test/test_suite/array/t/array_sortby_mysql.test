#owner: xuqijia.xqj
#owner group: shenzhen
--echo # ----------------------------------------------------------------------
--echo # Test of array_sortby.
--echo # ----------------------------------------------------------------------

select array_sortby(x ->(x),null);
select array_sortby(x ->(x is null),null);
select array_sortby(x ->(x),[1]);
select array_sortby(x ->(x),[1.1]);
select array_sortby(x ->(1),[1.1,2.2]);
select array_sortby(x ->(1),['hello','hi','world']);
select array_sortby(x ->(0),[[1],[2,3],NULL,[4,NULL],NULL]);

select array_sortby(x ->(x), [4,2,1,3]);
select array_sortby(x ->(x), [-4,2,1,-3,0]);
select array_sortby(x ->(x), [4.4,2.2,1.1,3.3]);
select array_sortby(x ->(x), ['c','b','a','d']);
select array_sortby(x ->(x), ['hello','hi','world']);
--error 5083
select array_sortby(x ->(x), [[4],[2,1],[3]]);
select array_sortby(x ->(x), [4,NULL,1,3,NULL]);
select array_sortby(x ->(x), [4.4,NULL,1.1,3.3,NULL]);
select array_sortby(x ->(x), ['c',NULL,'a',NULL]);
select array_sortby(x ->(x),[-9223372036854775808, 0, 9223372036854775807]);
select array_sortby(x ->(x),[cast(0 as unsigned),18446744073709551615]);
select array_sortby((x,y) ->(y),['a','b','c'], [2,1,3]);
select array_sortby((x,y,z) ->(y+z),['a','b','c'], [2,1,3], [4,0,2]);
select array_sortby((x,y) ->(y),['a','b','c'], [NULL,1,3]);
select array_sortby(x ->(NULL), [[4],[2,1],[3]]);
select array_sortby(x ->(NULL), [4,NULL,1,3,NULL]);
select array_sortby(x ->(NULL), [4.4,NULL,1.1,3.3,NULL]);
select array_sortby(x ->(NULL), ['c',NULL,'a',NULL]);

--error 5058
select array_sortby((x,x) -> (x+1), [1],[1]);
--error 1064
select array_sortby(x,y -> (x + y),[1], [2]);
--error 1054
select array_sortby(x ->(z),[1]);
--error 1582
select array_sortby(x -> (x),[1],[2]);
--error 5083
select array_sortby(x ->(x+1), 1);
--error 1064
select array_sortby((x,y) -> (x+1));
--error 1064
select array_sortby();
--error 1064
select array_sortby(null);
--error 1064
select array_sortby(null,[1]);
--error 1064
select array_sortby(null,null);
--error 5083
select array_sortby((x,y) ->(x*2 + y  + x*2), [1,3],[4,5,6]);
# aggr expr isn't supported
--error 1235
select array_sortby((x) -> (min(x)), [23]);
--error 1235
select array_sortby((x) -> ((select x)), [23]);

--disable_warnings
drop table if exists t1, t2;
--enable_warnings

create table t1 (id int, c1 array(TINYINT), c2 array(BIGINT), c3 array(BIGINT UNSIGNED));
insert into t1 (id) values (1);
insert into t1 values (2, [1,0,NULL], [1,0,NULL], [1,0,NULL]);
insert into t1 values (3, [-128, 0, 127], [-9223372036854775808,0,9223372036854775807], [cast(0 as unsigned), 9223372036854775808, 18446744073709551615]);
select array_sortby((x,y) -> (y), ['a','b','c'], c1) from t1;
select array_sortby((x,y) -> (y), [['a'],['b'],['c']], c1) from t1;
select array_sortby((x,y) -> (y), ['a','b','c'], c2) from t1;
select array_sortby((x,y) -> (y), [['a'],['b'],['c']], c2) from t1;
select array_sortby((x,y) -> (y), ['a','b','c'], c3) from t1;
select array_sortby((x,y) -> (y), [['a'],['b'],['c']], c3) from t1;

create table t2 (id int, vec vector(3));
insert into t2 values (1, [1.0, 4.0, 7.0]);
insert into t2 values (2, [2.0, 5.0, 8.0]);
insert into t2 values (3, [3.0, 6.0, 9.0]);

select array_sortby((x) -> (x), vec) from t2;
--error 5083
select array_sortby((x) -> (x), [vec]) from t2;
select array_sortby((x,y) -> (y), [[vec], [vec]], [2,1]) from t2;
select array_sortby((x,y) -> (y), vec, [3,1,2]) from t2;

drop table t1, t2;

--disable_warnings
drop table if exists tt;
--enable_warnings

create table tt(id int, arr_int int[], arr_dint array(array(int)), arr_vec array(vector(1)), arr_char array(varchar(10)));
insert into tt values(1, [1], [[1], [2]], [[1], [2]], ['a', 'b']);
insert into tt values(2, null, [[1], [2]], [[1], [2]], ['a', 'b']);
insert into tt values(3, array_remove([1], 1), [[1], [2]], [[1], [2]], ['a', 'b']);
insert into tt values(4, [null, 1], [[1], [2]], [[1], [2]], ['a', 'b']);
insert into tt values(5, [null], [[1], [2]], [[1], [2]], ['a', 'b']);
insert into tt values(6, [1], null, [[1], [2]], ['a', 'b']);
insert into tt values(7, [1], array_remove([[1]], [1]), [[1], [2]], ['a', 'b']);
insert into tt values(8, [1], [null, [2]], [[1], [2]], ['a', 'b']);
insert into tt values(9, [1], array_append(array_remove([[1]],[1]), null), [[1], [2]], ['a', 'b']);
insert into tt values(10, [1], [[null], [2]], [[1], [2]], ['a', 'b']);
insert into tt values(11, [1], [[null, 1], [2]], [[1], [2]], ['a', 'b']);
insert into tt values(12, [1], [array_remove([1], 1)], [[1], [2]], ['a', 'b']);
insert into tt values(13, [1], [array_remove([1], 1), [2]], [[1], [2]], ['a', 'b']);
insert into tt values(14, [1], [[1], [2]], null, ['a', 'b']);
insert into tt values(15, [1], [[1], [2]], array_remove([[1]], [1]), ['a', 'b']);
insert into tt values(16, [1], [[1], [2]], array_append(array_remove([[1]],[1]), null), ['a', 'b']);
insert into tt values(17, [1], [[1], [2]], [[1], [2]], null);
insert into tt values(18, [1], [[1], [2]], [[1], [2]], array_remove(['a'], 'a'));
insert into tt values(19, [1], [[1], [2]], [[1], [2]], array_append(array_remove(['a'],'a'), null));

select * from tt;

select id, array_sortby(x ->(x), arr_int) from tt;
select id, array_sortby(x ->(x), arr_char) from tt;

--disable_warnings
drop table if exists tt;
--enable_warnings



#bugfix

select array_sortby((x,y)->(x/y),[null,null],[null,null]);
