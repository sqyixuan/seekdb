--error 1690
select /*+ OPT_PARAM('rowsets_enabled', 'FALSE') */ arr_bint, array_difference(arr_bint) from t1;
select /*+ OPT_PARAM('rowsets_enabled', 'FALSE') */ arr_utint, array_difference(arr_utint) from t1;
