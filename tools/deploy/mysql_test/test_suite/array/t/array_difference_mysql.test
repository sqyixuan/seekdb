select /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */ arr_uint, array_difference(arr_uint) from t1;
select /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */ arr_ubint, array_difference(arr_ubint) from t1;
select /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */ arr_flt, array_difference(arr_flt) from t1;
select /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */ arr_dob, array_difference(arr_dob) from t1;
