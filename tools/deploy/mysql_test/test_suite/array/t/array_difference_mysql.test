--echo # ----------------------------------------------------------------------
--echo # Test of array_difference.
--echo # ----------------------------------------------------------------------

--disable_warnings
drop table if exists t1, t2;
--enable_warnings

--error 1690
select array_difference([9223372036854775807,-2]);
--error 1690
select array_difference([-9223372036854775808,1]);
--error 1690
select array_difference([1.7976931348623157E+308,-1.1E+300]);
--error 1690
select array_difference([1.7976931348623157E+308,-1.0E+308]);

--error 1235
select array_difference([NULL]);
select array_difference([1,2,3]);
select array_difference([1,5,3]);
select array_difference([10]);
--error 1235
select array_difference([1,2,3,NULL]);
select array_difference([1/3]);
select array_difference([1.1,2.2,4.4]);
--error 1235
select array_difference(['a','b','c','d']);
--error 1235
select array_difference(["hello", "hi"]);
--error 1235
select array_difference([[NULL],NULL]);
--error 1235
select array_difference([[1,2]]);
--error 1235
select array_difference([[1],[2]]);
#select array_difference(element_at([[1,2,3],[3,4]], 1));
select array_difference(array_append([1,2,3], 4));

CREATE TABLE t1 (id int, arr_tint Array(TINYINT), arr_sint Array(SMALLINT), arr_int Array(INT), arr_bint Array(BIGINT),
                 arr_utint Array(TINYINT UNSIGNED), arr_usint Array(SMALLINT UNSIGNED), arr_uint Array(INT UNSIGNED), arr_ubint Array(BIGINT UNSIGNED),
                 arr_flt Array(FLOAT), arr_dob Array(DOUBLE), vec vector(3));
INSERT INTO t1(id) VALUES(1);
INSERT INTO t1 VALUES(2, [-1,2,1], [-1,2,1], [-1,2,1], [-1,2,1],
                      [0,2,1], [0,2,1], [0,2,1], [0,2,1],
                      [-1,2,1], [-1,2,1], [-1,2,1]);
INSERT INTO t1 VALUES(3, [-128,127], [-32768,32767], [-2147483648,2147483647], [-9223372036854775808,9223372036854775807],
                      [0,255], [0,65535], [0,4294967295], [0,9223372036854775807],
                      [-3.402823466E+38,-1.175494351E-38], [-1.7976931348623157E+308,-2.2250738585072014E-308], [0,0,0]);
INSERT INTO t1 VALUES(4, [127,-128], [32767, -32768], [2147483647,-2147483648], [9223372036854775807, -9223372036854775808],
                      [255,0], [65535,0], [4294967295,0], [9223372036854775807,0],
                      [-1.175494351E-38,-3.402823466E+38], [-2.2250738585072014E-308,-1.7976931348623157E+308], [1,2,3]);

select arr_tint, array_difference(arr_tint) from t1;
select arr_sint, array_difference(arr_sint) from t1;
select arr_int, array_difference(arr_int) from t1;
--error 1690
select arr_bint, array_difference(arr_bint) from t1;
select arr_utint, array_difference(arr_utint) from t1;
select arr_usint, array_difference(arr_usint) from t1;
select arr_uint, array_difference(arr_uint) from t1;
select arr_ubint, array_difference(arr_ubint) from t1;
select arr_flt, array_difference(arr_flt) from t1;
select arr_dob, array_difference(arr_dob) from t1;
select vec, array_difference(vec) from t1;

select /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */ arr_tint, array_difference(arr_tint) from t1;
select /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */ arr_sint, array_difference(arr_sint) from t1;
select /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */ arr_int, array_difference(arr_int) from t1;
--error 1690
select /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */ arr_bint, array_difference(arr_bint) from t1;
select /*+ OPT_PARAM('enable_rich_vector_format', 'FALSE') */ arr_utint, array_difference(arr_utint) from t1;
