select /*+ OPT_PARAM('rowsets_enabled', 'FALSE') */ arr_ubint, array_difference(arr_ubint) from t1;
select /*+ OPT_PARAM('rowsets_enabled', 'FALSE') */ arr_flt, array_difference(arr_flt) from t1;
