create table t2 (id int, c1 array(float));
insert into t2 values (1, '[-5499947736863565866,-1933705571976982709,-1492803351447805505,3219757370883778824]');
insert into t2 values(2, null);
insert into t2 values(3, '[-6798202070419082386,-1886662336319581078,-1311313309244097420]');
select array_distinct(c1), array_first((x)->(array_distinct(c1) is null), c1) from t2;
select array_distinct(c1), array_first((x)->(array_distinct(c1) is not null), c1) from t2;
select array_distinct(c1), array_map((x)->(array_distinct(c1) is null), c1) from t2;
drop table t2;
create table t3 (id int, c1 array(array(float)));
insert into t3 values (1, '[[-5499947736863565866,-1933705571976982709,-1492803351447805505,3219757370883778824]]');
insert into t3 values(2, null);
insert into t3 values(3, '[NULL,[-6798202070419082386,-1886662336319581078,-1311313309244097420]]');
select array_distinct(c1), array_first((x)->(array_distinct(x) is not null), c1) from t3;
select array_distinct(c1), array_map((x)->(array_distinct(x) is not null), c1) from t3;
