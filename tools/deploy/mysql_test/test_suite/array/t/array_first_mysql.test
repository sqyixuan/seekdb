--echo # ----------------------------------------------------------------------
--echo # Test of array_first.
--echo # ----------------------------------------------------------------------

select array_first(x ->(x),null);
select array_first(x ->(x is null),null);
select array_first(x ->(x),[1]);
--error 5083
select array_first(x ->(x),[1.1]);
select array_first(x ->(1),[1.1,2.2]);
select array_first(x ->(0),[1,2]);
--error 5083
select array_first(x ->(1.1),[1,2]);
select array_first(x ->(x + 1 > 2),[1,2,3,4]);
select array_first(x ->(x > 5),[1,2,3,4]);
select array_first(x ->(x - 2),[1,2,3,4]);
select array_first(x ->(x = 'hi' ),['hello','hi','world']);
select array_first((x,y,z) -> (x is null and y is not null or z is not null), [[1]], [1],['abc']);
select array_first((x,y) ->(x > y),[1,2,3], [2,1,3]);
select array_first(x ->(array_contains(x, 10)), [[1,2,3],[10,11,12],[20,21,22]]);
select array_first(x ->(array_contains(x, 'OceanBase')), [['Hello', 'World'],['hi'],['OB','OceanBase']]);
--error 5083
select array_first(x ->(x), [['Hello', 'World'],['hi'],['OB','OceanBase']]);
--error 5083
select array_first(x ->(x > 5),[1,2,3,NULL]);
select array_first(x ->(x > 2),[1,2,3,NULL]);
--error 5083
select array_first((x, y) ->(x), [0,NULL,22], [NULL,NULL,NULL]);
select array_first((x, y) ->(x), [0,1,NULL], [NULL,NULL,NULL]);
select array_first((x, y) ->(x is null), [0,1,NULL], [NULL,NULL,NULL]);
select array_first((中文ing) -> (中文ing is not null),[2])  from dual ;
SELECT array_first(x ->(x LIKE '%World%'), ['Hello', 'abc World']);

--error 5058
select array_first((x,x) -> (x+1), [1],[1]);
--error 1064
select array_first(x,y -> (x + y),[1], [2]);
--error 1054
select array_first(x ->(z),[1]);
--error 1582
select array_first(x -> (x),[1],[2]);
--error 5083
select array_first(x ->(x+1), 1);
--error 1064
select array_first((x,y) -> (x+1));
--error 1064
select array_first();
--error 1064
select array_first(null);
--error 1064
select array_first(null,[1]);
--error 1064
select array_first(null,null);
--error 5083
select array_first((x,y) ->(x*2 + y  + x*2), [1,3],[4,5,6]);
# aggr expr isn't supported
--error 1235
select array_first((x) -> (min(x)), [23]);
--error 1235
select array_first((x) -> ((select x)), [23]);
select array_first((x) -> (cardinality(array(x))), [NULL]);
select array_first((x) -> (cardinality(array(x))), [10,20]);
select array_first(x2->cardinality((x2)),[[1]]);
select array_first((x)->(cardinality(array_map((x)->(x),[1]))),[[1]]);
select array_first((x)->(array_first((x)->(x),[1])),[[1]]);
select array_first((x)-> (cardinality(array_map((x)->(cardinality(array_map((x)->(x),x))),[[1]]))), [2]);

--disable_warnings
drop table if exists t1, t2, t3;
--enable_warnings
create table t1 as select array_first(x -> (x > 2), [1.22, 3.44, 5.33]);
select * from t1;
drop table t1;

create table t1 (id int PRIMARY KEY, c1 array(TINYINT), c2 array(BIGINT), c3 array(BIGINT UNSIGNED)) partition by hash(id) partitions 3;
insert into t1 (id) values (1);
insert into t1 values (2, [1,0,NULL], [1,0,NULL], [1,0,NULL]);
insert into t1 values (3, [-128, 0, 127], [-9223372036854775808,0,9223372036854775807], [cast(0 as unsigned), 9223372036854775808, 18446744073709551615]);
select id, array_first((x,y) -> (y), ['a','b','c'], c1) from t1 order by id;
select id, array_first((x,y) -> (y), [['a'],['b'],['c']], c1) from t1 order by id;
select id, array_first((x,y) -> (y), ['a','b','c'], c2) from t1 order by id;
select id, array_first((x,y) -> (y), [['a'],['b'],['c']], c2) from t1 order by id;
select id, array_first((x,y) -> (y), ['a','b','c'], c3) from t1 order by id;
select id, array_first((x,y) -> (y), [['a'],['b'],['c']], c3) from t1 order by id;

create table t2 (id int PRIMARY KEY, vec vector(3));
insert into t2 values (1, [0.0, 4.0, 7.0]);
insert into t2 values (2, [2.0, 5.0, 8.0]);
insert into t2 values (3, [3.0, 6.0, 9.0]);

--disable_warnings
drop table if exists t_create;
--enable_warnings
create table t_create as select array_first(x->(x),[0,1,2]), array_first(x->(1),[[0,1,2],[3]]), array_first(x->(1), c1) from t1;
desc t_create;
select * from t_create;
drop table t_create;

--error 5083
select array_first((x) -> (x), vec) from t2;
--error 5083
select array_first((x) -> (x), [vec]) from t2;
select id, array_first((x) -> (cast(x as signed)), vec) from t2 order by id;
select id, array_first((x) -> (x > 4), vec) from t2 order by id;
select id, array_first((x,y) -> (y), [[vec], [vec]], [2,1]) from t2 order by id;
select id, array_first((x,y) -> (y), vec, [3,1,2]) from t2 order by id;

drop table t1, t2;

--disable_warnings
drop table if exists tt;
--enable_warnings

create table tt(id int, arr_int int[], arr_dint array(array(int)), arr_vec array(vector(1)), arr_char array(varchar(10)));
insert into tt values(1, [1], [[1], [2]], [[1], [2]], ['a', 'b']);
insert into tt values(2, null, [[1], [2]], [[1], [2]], ['a', 'b']);
insert into tt values(3, array_remove([1], 1), [[1], [2]], [[1], [2]], ['a', 'b']);
insert into tt values(4, [null, 1], [[1], [2]], [[1], [2]], ['a', 'b']);
insert into tt values(5, [null], [[1], [2]], [[1], [2]], ['a', 'b']);
insert into tt values(6, [1], null, [[1], [2]], ['a', 'b']);
insert into tt values(7, [1], array_remove([[1]], [1]), [[1], [2]], ['a', 'b']);
insert into tt values(8, [1], [null, [2]], [[1], [2]], ['a', 'b']);
insert into tt values(9, [1], array_append(array_remove([[1]],[1]), null), [[1], [2]], ['a', 'b']);
insert into tt values(10, [1], [[null], [2]], [[1], [2]], ['a', 'b']);
insert into tt values(11, [1], [[null, 1], [2]], [[1], [2]], ['a', 'b']);
insert into tt values(12, [1], [array_remove([1], 1)], [[1], [2]], ['a', 'b']);
insert into tt values(13, [1], [array_remove([1], 1), [2]], [[1], [2]], ['a', 'b']);
insert into tt values(14, [1], [[1], [2]], null, ['a', 'b']);
insert into tt values(15, [1], [[1], [2]], array_remove([[1]], [1]), ['a', 'b']);
insert into tt values(16, [1], [[1], [2]], array_append(array_remove([[1]],[1]), null), ['a', 'b']);
insert into tt values(17, [1], [[1], [2]], [[1], [2]], null);
insert into tt values(18, [1], [[1], [2]], [[1], [2]], array_remove(['a'], 'a'));
insert into tt values(19, [1], [[1], [2]], [[1], [2]], array_append(array_remove(['a'],'a'), null));

select * from tt;

select id, array_first(x -> (x), arr_int) from tt where array_contains(arr_int, null) = 0;

--disable_warnings
drop table if exists tt;
--enable_warnings

