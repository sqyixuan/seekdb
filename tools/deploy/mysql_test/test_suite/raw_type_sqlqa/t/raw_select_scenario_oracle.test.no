create table t_raw_tmp(c1cc raw(2000) not null unique, c2cc raw(1) not null, c3cc raw(1993) default '0FF' not null, c1dd generated always as(c2cc || c3cc), c4cc raw(200) unique, c1 int, c2 number, c3 date, c4 interval day to second, c5 timestamp, c6 number(10), c7 number(10,4), c9 timestamp with time zone, c10 timestamp with local time zone, c11 interval year to month, c13 interval day to second, c14 blob, c15 clob, c16 varchar(100), c11cc raw(1999) unique, c12cc raw(2) not null, c13cc raw(1993) default '0FF' not null, c11dd raw(2000) generated always as(c12cc || c13cc), c17 smallint,c18 char(200), c21cc raw(1998) unique, c22cc raw(3) not null, c23cc raw(1993) default '0FF' not null, c21dd raw(2000) generated always as(c22cc || c23cc),constraint pkc1_c22 primary key(c1cc,c11cc,c21cc), constraint fk_c22 FOREIGN KEY(c3cc,c13cc,c23cc) REFERENCES t_raw_tmp(c1cc,c11cc,c21cc), constraint c22cc_check check((c2cc || c12cc || c22cc) not in ('0A0A0A','0B0B0B','0C0C0C','0D0D0D','0E0E0E'))) primary_zone='zone1' pctfree 3  pctused 3 initrans 3  enable row movement PARTITION BY hash(c1cc) SUBPARTITION BY range(c1cc) SUBPARTITION TEMPLATE (SUBPARTITION  t_raw_p0 VALUES LESS THAN ('1aaaaaaaaaaaaa'),SUBPARTITION  t_raw_p1 VALUES LESS THAN ('2aaaaaaaaaaaaa11'),SUBPARTITION  t_raw_p2 VALUES LESS THAN ('3aaaaaaaaaaaaa1122'),SUBPARTITION  t_raw_p3 VALUES LESS THAN ('4aaaaaaaaaaaaa112244'),SUBPARTITION  t_raw_p4 VALUES LESS THAN ('5aaaaaaaaaaaaa11224455'),SUBPARTITION  t_raw_pp VALUES LESS THAN (MAXVALUE)) PARTITIONS 10 ;
create table t_raw_tmp2(c1cc raw(2000) not null unique, c2cc raw(1) not null, c3cc raw(1993) default '0FF' not null, c1dd generated always as(c2cc || c3cc), c4cc raw(200) unique, c1 int, c2 number, c3 date, c4 interval day to second, c5 timestamp, c6 number(10), c7 number(10,4), c9 timestamp with time zone, c10 timestamp with local time zone, c11 interval year to month, c13 interval day to second, c14 blob, c15 clob, c16 varchar(100), c11cc raw(1999) unique, c12cc raw(2) not null, c13cc raw(1993) default '0FF' not null, c11dd raw(2000) generated always as(c12cc || c13cc), c17 smallint,c18 char(200), c21cc raw(1998) unique, c22cc raw(3) not null, c23cc raw(1993) default '0FF' not null, c21dd raw(2000) generated always as(c22cc || c23cc),constraint pkc1_c33 primary key(c1cc,c11cc,c21cc), constraint fk_c33 FOREIGN KEY(c3cc,c13cc,c23cc) REFERENCES t_raw_tmp2(c1cc,c11cc,c21cc), constraint c33cc_check check((c2cc || c12cc || c22cc) not in ('0A0A0A','0B0B0B','0C0C0C','0D0D0D','0E0E0E'))) primary_zone='zone2' pctfree 3  pctused 3 initrans 3  enable row movement PARTITION BY hash(c1cc) SUBPARTITION BY range(c1cc) SUBPARTITION TEMPLATE (SUBPARTITION  t_raw_p0 VALUES LESS THAN ('1aaaaaaaaaaaaa'),SUBPARTITION  t_raw_p1 VALUES LESS THAN ('2aaaaaaaaaaaaa11'),SUBPARTITION  t_raw_p2 VALUES LESS THAN ('3aaaaaaaaaaaaa1122'),SUBPARTITION  t_raw_p3 VALUES LESS THAN ('4aaaaaaaaaaaaa112244'),SUBPARTITION  t_raw_p4 VALUES LESS THAN ('5aaaaaaaaaaaaa11224455'),SUBPARTITION  t_raw_pp VALUES LESS THAN (MAXVALUE)) PARTITIONS 10 ;

