insert into t_raw( c1cc,c2cc,c3cc, c4cc, c1, c11cc,c12cc,c13cc,c18,c21cc,c22cc,c23cc ) select tt.c1,t1.c2cc,t1.c3cc, '1131', t1.c1, tt.c1,t1.c12cc,t1.c13cc,t1.c18,tt.c1 ,t1.c22cc,t1.c23cc from t_raw t1, t_raw_tmp tt where  t1.c4cc = '1128';

--echo ### select 子句测试
select * from t_raw order by c1cc;
select c1cc,c2cc,c3cc, c4cc, c1, c11cc,c12cc,c13cc,c18,c21cc,c22cc,c23cc from t_raw order by c1cc;

--echo ob修改varchar2的size，扩大到32767
select c1cc || c11cc || c21cc from t_raw order by c1cc || c11cc || c21cc;

--echo  || 测试
select c2cc || c4cc from t_raw;

--echo  函数
select utl_raw.length(c1dd||c4cc),utl_raw.length(c11dd) from t_raw order by c1cc;
--echo 16级函数调用
set session ob_query_timeout = 400000000;
select utl_raw.cast_to_varchar2(utl_raw.cast_to_raw(utl_raw.cast_to_varchar2(utl_raw.cast_to_raw(utl_raw.cast_to_varchar2(utl_raw.cast_to_raw(utl_raw.cast_to_varchar2(utl_raw.cast_to_raw(utl_raw.cast_to_varchar2(utl_raw.cast_to_raw(utl_raw.cast_to_varchar2(utl_raw.cast_to_raw(utl_raw.cast_to_varchar2(utl_raw.cast_to_raw(utl_raw.cast_to_varchar2(utl_raw.cast_to_raw(utl_raw.cast_to_varchar2(utl_raw.cast_to_raw(c2cc))))))))))))))))))  from t_raw order by c1cc;
set session ob_query_timeout = 10000000;

--echo  别名
select utl_raw.length(c2cc || c4cc) as length1 from t_raw order by c1cc;
--echo  select子句
select (select c1cc from t_raw where c4cc = '1119'),c4cc from t_raw order by c1cc;

select (select c1cc from t_raw where c4cc = '1119'),c4cc, (select c1cc from t_raw where c4cc = '1119'), utl_raw.length(c2cc || c4cc), utl_raw.length(c2cc || c4cc),utl_raw.length(c2cc || c4cc || c12cc || c22cc), (select sum(utl_raw.length(c2cc || c4cc))+ sum(utl_raw.length(c2cc || c4cc || c12cc || c22cc)) from t_raw)  from t_raw order by c1cc;

select utl_raw.length(c1dd||c4cc),utl_raw.cast_to_raw(c11dd) from t_raw where utl_raw.length(c1cc) > 500 order by c1cc;

--echo ### where 子句测试
select utl_raw.length(c1dd||c4cc),utl_raw.length(c11dd) from t_raw where utl_raw.length(c1cc) > 500 order by c1cc;

--error 932
select utl_raw.length(c1dd||c4cc),utl_raw.length(c11dd) from t_raw where c4cc > 500 order by c1cc;

select utl_raw.length(c1dd||c4cc),utl_raw.length(c11dd) from t_raw where c4cc > '1500' order by c1cc;

select utl_raw.length(c1dd||c4cc),utl_raw.length(c11dd) from t_raw where c4cc >= '1500' order by c1cc;

select utl_raw.length(c1dd||c4cc),utl_raw.length(c11dd) from t_raw where c4cc < '1500' order by c1cc;

select utl_raw.length(c1dd||c4cc),utl_raw.length(c11dd) from t_raw where c4cc <= '1500' order by c1cc;

select utl_raw.length(c1dd||c4cc),utl_raw.length(c11dd) from t_raw where c4cc = '1500' order by c1cc;

select utl_raw.length(c1dd||c4cc),utl_raw.length(c11dd) from t_raw where c4cc <> '1500' order by c1cc;

select utl_raw.length(c1dd||c4cc),utl_raw.length(c11dd) from t_raw where '-' || c4cc <= '-1500' order by c1cc;

select utl_raw.length(c1dd||c4cc),utl_raw.length(c11dd) from t_raw where '-' || c4cc || '-1500' is null order by c1cc;

select utl_raw.length(c1dd||c4cc),utl_raw.length(c11dd) from t_raw where c2cc is not null order by c1cc;

select utl_raw.length(c1dd||c4cc),utl_raw.length(c11dd) from t_raw where (c2cc,c12cc) =  ('FF', 'FFFF') order by c1cc;
set session ob_query_timeout = 400000000;
select utl_raw.length(c1dd||c4cc),utl_raw.length(c11dd) from t_raw where (c2cc,c12cc) = (utl_raw.cast_to_raw('FF'), utl_raw.cast_to_raw('FFFF')) order by c1cc;

select utl_raw.length(c1dd||c4cc),utl_raw.length(c11dd) from t_raw where (c2cc,c12cc) in  (('FF', 'FFFF'),('01','02')) order by c1cc;

select utl_raw.length(c1dd||c4cc),utl_raw.length(c11dd) from t_raw where (c2cc,c12cc) not in ((utl_raw.cast_to_raw('FF'), utl_raw.cast_to_raw('FFFF')),(utl_raw.cast_to_raw('01'), utl_raw.cast_to_raw('11'))) order by c1cc;

select utl_raw.length(c1dd||c4cc),utl_raw.length(c11dd) from t_raw where (c2cc,c12cc) in ((utl_raw.cast_to_raw('FF'), utl_raw.cast_to_raw('FFFF')),(utl_raw.cast_to_raw('01'), utl_raw.cast_to_raw('11'))) order by c1cc;

select utl_raw.length(c1dd||c4cc),utl_raw.length(c11dd) from t_raw where c2cc in (utl_raw.cast_to_raw('FF')) order by c1cc;
set session ob_query_timeout = 10000000;

select utl_raw.length(c1dd||c4cc),utl_raw.length(c11dd) from t_raw where c2cc like ('%%') order by c1cc;

select utl_raw.length(c1dd||c4cc),utl_raw.length(c11dd) from t_raw where c2cc like ('%') order by c1cc;

select utl_raw.length(c1dd||c4cc),utl_raw.length(c11dd) from t_raw where c2cc like ('FF') order by c1cc;

select utl_raw.length(c1dd||c4cc),utl_raw.length(c11dd) from t_raw where c2cc like ('%F') order by c1cc;

select utl_raw.length(c1dd||c4cc),utl_raw.length(c11dd) from t_raw where c2cc not like ('%F') order by c1cc;

select utl_raw.length(c1dd||c4cc),utl_raw.length(c11dd) from t_raw where c2cc between '00' and '1A' order by c1cc;

select utl_raw.length(c1dd||c4cc),utl_raw.length(c11dd) from t_raw where c1cc || c4cc like ('%F%') order by c1cc;

select utl_raw.length(c1dd||c4cc),utl_raw.length(c11dd) from t_raw where c2cc not in ('FF') order by c1cc;

select utl_raw.length(c1dd||c4cc),utl_raw.length(c11dd) from t_raw where c2cc > any (select c12cc from t_raw where c4cc > '1500') order by c1cc;
select utl_raw.length(c1dd||c4cc),utl_raw.length(c11dd) from t_raw where c2cc > all (select c12cc from t_raw where c4cc > '1500') order by c1cc;

select utl_raw.length(c1dd||c4cc),utl_raw.length(c11dd) from t_raw where (c2cc, c12cc) in (select c2cc,c12cc from t_raw where c4cc > '1500') order by c1cc;

select utl_raw.length(c1dd||c4cc),utl_raw.length(c11dd) from t_raw where (c2cc, c12cc) in (select c2cc,c12cc from t_raw where c4cc > '1500') order by c1cc;

select utl_raw.length(c1dd||c4cc),utl_raw.length(c11dd) from t_raw where (c2cc, c12cc) not in (select c2cc,c12cc from t_raw where c4cc > '1500') and c1cc like '500' order by c1cc;

select utl_raw.length(c1dd||c4cc),utl_raw.length(c11dd) from t_raw where (c2cc, c12cc) in (select c2cc,c12cc from t_raw where c4cc > '1500') or c1cc > '500' order by c1cc;

select sum(utl_raw.length(c1dd||c4cc)),sum(to_number(utl_raw.cast_to_raw(c11dd))) from t_raw where c1cc like ('%F%') group by utl_raw.length(c1cc);
select count(*),sum(to_number(utl_raw.cast_to_raw(c11dd))) from t_raw where c1cc like ('%F%') group by utl_raw.length(c1cc);
select count(*),sum(to_number(utl_raw.cast_to_raw(c11dd))) from t_raw where c1cc like ('%F%') group by c2cc;
select count(*),sum(to_number(utl_raw.cast_to_raw(c11dd))) from t_raw where c1cc like ('%') group by c2cc order by  sum(to_number(utl_raw.cast_to_raw(c11dd)));

--echo ### select over测试
select sum(to_number(utl_raw.cast_to_raw(c11dd))) over() from t_raw;
select avg(to_number(utl_raw.cast_to_raw(c11dd))) over (partition by (c2cc)) from t_raw;
select avg(to_number(utl_raw.cast_to_raw(c11dd))) over (partition by(utl_raw.length(c3cc))) from t_raw;
select avg(to_number(utl_raw.cast_to_raw(c11dd))) over (partition by (c2cc) order by c1cc) from t_raw;
select avg(to_number(utl_raw.cast_to_raw(c11dd))) over (partition by (c2cc) order by c1cc asc) from t_raw;
select avg(to_number(utl_raw.cast_to_raw(c11dd))) over (partition by (c2cc) order by c1cc desc) from t_raw;
select avg(to_number(utl_raw.cast_to_raw(c11dd))) over (partition by (c2cc) order by c1cc desc) from t_raw;
set session ob_query_timeout = 400000000;
select avg(to_number(utl_raw.cast_to_raw(c11dd))) over (partition by (utl_raw.length(c3cc)) order  by utl_raw.length(c1cc) desc range between 1 preceding and 10 following) from t_raw;
select c4cc, avg(to_number(utl_raw.cast_to_raw(c11dd))) over (partition by (c2cc) order by to_number(c4cc) desc range between 1000 preceding and 2000 following) from t_raw;
set session ob_query_timeout = 10000000;
--error 932
select c4cc, avg(to_number(utl_raw.cast_to_raw(c11dd))) over ( order by c4cc  range between 1000 preceding and 2000 following) from t_raw;

select c4cc, avg(to_number(utl_raw.cast_to_raw(c11dd))) over (partition by (c2cc) order by c4cc rows CURRENT ROW) from t_raw;

--echo ### with as测试
with ttest_raw as (select c1cc from t_raw) ,ttest_raw2 as (select c11cc from t_raw) select r1.c1cc, r2.c11cc, r3.c21dd from ttest_raw r1, ttest_raw2 r2, t_raw r3 where r1.c1cc = r3.c1cc  and r2.c11cc = r3.c11cc;
with ttest_raw(c1cc,c2cc,c3cc,c4cc,c1dd) as ((select c1cc,c2cc,c3cc,c4cc,c1dd from t_raw where c2cc = '02') union all(select r1.c1cc, r1.c2cc, r1.c3cc, r1.c4cc,r1.c1dd from ttest_raw r1, t_raw r2 where r2.c1cc = r1.c2cc)) select * from ttest_raw;

--error 32044
with ttest_raw(c1cc,c2cc,c3cc,c4cc,c1dd) as ((select c1cc,c2cc,c3cc,c4cc,c1dd from t_raw where c2cc = '01') union all(select r1.c1cc, r1.c2cc, r1.c3cc, r1.c4cc,r1.c1dd from ttest_raw r1, t_raw r2 where r2.c1cc = r1.c2cc)) select * from ttest_raw;

with ttest_raw(c1cc,c2cc,c3cc,c4cc,c1dd) as ((select c1cc,c2cc,c3cc,c4cc,c1dd from t_raw where c2cc = '01') union all(select r1.c1cc, r1.c2cc, r1.c3cc, r1.c4cc,r1.c1dd from ttest_raw r1, t_raw r2 where r2.c1cc = r1.c2cc)) SEARCH DEPTH FIRST BY c1cc SET order1 CYCLE c1cc SET is_cycle TO 'Y' DEFAULT 'N' select * from ttest_raw;

