tablegroup
DROP TABLEGROUP TABLE_GROUP1;
CREATE TABLEGROUP TABLE_GROUP1 SHARDING = 'NONE';
drop table t1;
CREATE TABLE t1(
c1 int primary key,
c2 varchar(30)
)TABLEGROUP = TABLE_GROUP1
PARTITION BY RANGE (c1) (
PARTITION p1 VALUES LESS THAN (15),
PARTITION p2 VALUES LESS THAN (35),
PARTITION p3 VALUES LESS THAN (50)
);
insert into t1(c1) values(20),(29),(35),(40),(15),(18);
drop table t2;
CREATE TABLE t2(
c1 int primary key,
c2 varchar(30)
);
insert into t2 values(21,'AA'),(9,null),(29,'SE'),(45,'GG');
只有一张表在tablegroup，进行交换
ALTER TABLE t1 EXCHANGE PARTITION p2 WITH TABLE t2 WITHOUT VALIDATION;
ERROR HY000: Tables have different definitions
ALTER TABLEGROUP TABLE_GROUP1 ADD t2;
都在同一tablegroup，进行交换
ALTER TABLE t1 EXCHANGE PARTITION p2 WITH TABLE t2 WITHOUT VALIDATION;
select * from t1 partition(p2);
c1	c2
9	NULL
21	AA
29	SE
45	GG
select * from t2;
c1	c2
15	NULL
18	NULL
20	NULL
29	NULL
DROP TABLEGROUP TABLE_GROUP2;
CREATE TABLEGROUP TABLE_GROUP2 SHARDING = 'NONE';
在不同表组tablegroup，进行交换
ALTER TABLEGROUP TABLE_GROUP2 ADD t2;
ALTER TABLE t1 EXCHANGE PARTITION p2 WITH TABLE t2 WITHOUT VALIDATION;
ERROR HY000: Tables have different definitions
drop table t1;
drop table t2;
DROP TABLEGROUP TABLE_GROUP2;
DROP TABLEGROUP TABLE_GROUP1;
TABLESPACE
目前外表不支持分区表
drop table t1;
CREATE TABLE t1(
c1 int,
c2 int,
c3 varchar(30)
)
PARTITION BY RANGE (c1) (
PARTITION p1 VALUES LESS THAN (15),
PARTITION p2 VALUES LESS THAN (35),
PARTITION p3 VALUES LESS THAN (50)
);
insert into t1(c1) values(20),(29),(35),(40),(15),(18);
drop table ex_ex_t1;
create external table ex_ex_t1 (
c1 int,
c2 int,
c3 varchar(30)
)
location='../include'
format (
type = 'csv'
	LINE_DELIMITER = '\n'
)
PATTERN = 'ex_nt.csv'
;
ALTER TABLE t1 EXCHANGE PARTITION p2 WITH TABLE ex_ex_t1 WITHOUT VALIDATION;
ERROR 0A000: alter table type not supported
存储过程
drop table t1;
CREATE TABLE t1(
c1 int primary key,
c2 varchar(30)
)
PARTITION BY RANGE (c1) (
PARTITION p1 VALUES LESS THAN (15),
PARTITION p2 VALUES LESS THAN (35),
PARTITION p3 VALUES LESS THAN (50)
);
insert into t1(c1) values(20),(29),(35),(40),(15),(18);
drop table t2;
CREATE TABLE t2(
c1 int primary key,
c2 varchar(30)
);
insert into t2 values(21,'AA'),(9,null),(29,'SE'),(45,'GG');
ALTER TABLE t1 EXCHANGE PARTITION p2 WITH TABLE t2 WITHOUT VALIDATION;
select * from t1 partition(p2);
c1	c2
9	NULL
21	AA
29	SE
45	GG
select * from t2;
c1	c2
15	NULL
18	NULL
20	NULL
29	NULL
drop PROCEDURE proc_name;
CREATE PROCEDURE proc_name()
BEGIN
PREPARE stmt FROM 'ALTER TABLE t1 EXCHANGE PARTITION p2 WITH TABLE t2 WITHOUT VALIDATION';
EXECUTE stmt;
DEALLOCATE PREPARE stmt;
END //
CALL proc_name();
select * from t1 partition(p2);
c1	c2
15	NULL
18	NULL
20	NULL
29	NULL
select * from t2;
c1	c2
9	NULL
21	AA
29	SE
45	GG
drop PROCEDURE proc_name;
触发器
drop TRIGGER trg2_t;
CREATE TRIGGER trg2_t BEFORE INSERT ON t1 FOR EACH ROW 
BEGIN
INSERT INTO t2(c1) VALUES (2222222);
END;
//
insert触发器，分区交换不会触发
ALTER TABLE t1 EXCHANGE PARTITION p2 WITH TABLE t2 WITHOUT VALIDATION;
select * from t1 partition(p2);
c1	c2
9	NULL
21	AA
29	SE
45	GG
select * from t2;
c1	c2
15	NULL
18	NULL
20	NULL
29	NULL
drop TRIGGER trg2_t;
CREATE TRIGGER trg2_t BEFORE UPDATE ON t1 FOR EACH ROW 
BEGIN
INSERT INTO t2(c1) VALUES (2222222);
END;
//
UPDATE触发器，分区交换不会触发
ALTER TABLE t1 EXCHANGE PARTITION p2 WITH TABLE t2 WITHOUT VALIDATION;
select * from t1 partition(p2);
c1	c2
15	NULL
18	NULL
20	NULL
29	NULL
select * from t2;
c1	c2
9	NULL
21	AA
29	SE
45	GG
drop TRIGGER trg2_t;
CREATE TRIGGER trg2_t BEFORE DELETE ON t1 FOR EACH ROW 
BEGIN
INSERT INTO t2(c1) VALUES (2222222);
END;
//
DELETE触发器，分区交换不会触发
ALTER TABLE t1 EXCHANGE PARTITION p2 WITH TABLE t2 WITHOUT VALIDATION;
select * from t1 partition(p2);
c1	c2
9	NULL
21	AA
29	SE
45	GG
select * from t2;
c1	c2
15	NULL
18	NULL
20	NULL
29	NULL
drop TRIGGER trg2_t;
drop table t1;
drop table t2;
