drop table test1;
CREATE TABLE test1(
c1 int primary key,
c2 varchar(30)
)
PARTITION BY RANGE (c1)
(
PARTITION c1_15 VALUES LESS THAN (15),
PARTITION c1_35 VALUES LESS THAN (35),
PARTITION c1_50 VALUES LESS THAN (50)
);
insert into test1(c1) values(1);
insert into test1(c1) values(2);
insert into test1(c1) values(36);
insert into test1(c1) values(38);
insert into test1(c1) values(40);
insert into test1(c1) values(45);
select * from test1;
c1	c2
1	NULL
2	NULL
36	NULL
38	NULL
40	NULL
45	NULL
drop table test2;
CREATE TABLE test2(
c1 int primary key,
c2 varchar(30)
);
insert into test2(c1) values(40),(60);
select * from test2;
c1	c2
40	NULL
60	NULL
#OB支持语法
ALTER TABLE test1 EXCHANGE PARTITION c1_35 WITH TABLE test2 WITHOUT VALIDATION;
select * from test1 partition(c1_35);
c1	c2
40	NULL
60	NULL
#不加 without validation,预期报错   
ALTER TABLE test1 EXCHANGE PARTITION c1_35 WITH TABLE test2;
ERROR 42000: You have an error in your SQL syntax; check the manual that corresponds to your OceanBase version for the right syntax to use near 'test2' at line 1
#带有update indexes 预期报错
ALTER TABLE test1 EXCHANGE PARTITION c1_35 WITH TABLE test2 UPDATE INDEXES;
ERROR 42000: You have an error in your SQL syntax; check the manual that corresponds to your OceanBase version for the right syntax to use near 'UPDATE INDEXES' at line 1
ALTER TABLE test1 EXCHANGE PARTITION c1_35 WITH TABLE test2 UPDATE GLOBAL INDEXES;
ERROR 42000: You have an error in your SQL syntax; check the manual that corresponds to your OceanBase version for the right syntax to use near 'UPDATE GLOBAL INDEXES' at line 1
#with VALIDATION 预期报错
ALTER TABLE test1 EXCHANGE PARTITION c1_35 WITH TABLE test2 WITH VALIDATION;
ERROR 42000: You have an error in your SQL syntax; check the manual that corresponds to your OceanBase version for the right syntax to use near 'WITH VALIDATION' at line 1
