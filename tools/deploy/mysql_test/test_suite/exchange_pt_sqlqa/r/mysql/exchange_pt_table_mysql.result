ERROR HY000: Non matching attribute 'ROW_FORMAT' between partition and table
#不同db的NT/PT表 进行分区交换
DROP DATABASE db1;
create database db1;
use db1;
drop table db1_test1;
CREATE TABLE db1_test1(
c1 int primary key,
c2 varchar(30)
)PARTITION BY RANGE (c1)
(
PARTITION p1 VALUES LESS THAN (20),
PARTITION p2 VALUES LESS THAN (40),
PARTITION p3 VALUES LESS THAN (60)
);
insert into db1_test1(c1) values(19),(20),(22),(36),(40),(59);
DROP DATABASE db2;
create database db2;
use db2;
drop table db2_test1;
CREATE TABLE db2_test1(
c1 int primary key,
c2 varchar(30)
);
select * from db1.db1_test1 partition(p2);
c1	c2
20	NULL
22	NULL
36	NULL
ALTER TABLE db1.db1_test1 EXCHANGE PARTITION p2 WITH TABLE db2_test1 WITHOUT VALIDATION;
select * from db1.db1_test1 partition(p2);
c1	c2
use db1;
ALTER TABLE db1_test1 EXCHANGE PARTITION p2 WITH TABLE db2.db2_test1 WITHOUT VALIDATION;
select * from db1.db1_test1 partition(p2);
c1	c2
20	NULL
22	NULL
36	NULL
#列名 不一致交换
drop table test1;
CREATE TABLE test1(
c1 int primary key,
c2 varchar(30)
)PARTITION BY RANGE (c1)
(
PARTITION p1 VALUES LESS THAN (20),
PARTITION p2 VALUES LESS THAN (40),
PARTITION p3 VALUES LESS THAN (60)
);
insert into test1(c1) values(19),(20),(22),(36),(40),(59);
drop table test2;
CREATE TABLE test2(
cl1 int primary key,
c2 varchar(30)
);
insert into test2 values(-80,'ADX'),(9999,'CD'),(0,'ZXV');
ALTER TABLE test1 EXCHANGE PARTITION p2 WITH TABLE test2 WITHOUT VALIDATION;
