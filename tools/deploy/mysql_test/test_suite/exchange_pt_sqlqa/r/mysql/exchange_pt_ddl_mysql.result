ddl_mysql  列操作 删除列 drop column
drop table pt_unique_test1;
CREATE TABLE pt_unique_test1 (
c1 INT UNIQUE KEY ,
c2 VARCHAR(50) NOT NULL,
c3 int
)
PARTITION BY RANGE(c1) (
PARTITION p1 VALUES LESS THAN (10),
PARTITION p2 VALUES LESS THAN (20),
PARTITION p3 VALUES LESS THAN (30)
);
create index test on pt_unique_test1(c3);
insert into pt_unique_test1(c1,c2) values(1,'CC'),(21,'dhh'),(15,'mh'),(7,'CC');
drop table nt_unique_test1;
CREATE TABLE nt_unique_test1 (
c1 INT UNIQUE KEY,
c2 VARCHAR(50) NOT NULL,
c3 int
);
create index test on nt_unique_test1(c3);
insert into nt_unique_test1(c1,c2) values(2,'CC'),(12,'dhh'),(22,'mh'),(7,'CC');
ALTER TABLE pt_unique_test1 EXCHANGE PARTITION p2 WITH TABLE nt_unique_test1 WITHOUT VALIDATION;
select * from pt_unique_test1;
c1	c2	c3
1	CC	NULL
7	CC	NULL
2	CC	NULL
12	dhh	NULL
22	mh	NULL
7	CC	NULL
21	dhh	NULL
select * from pt_unique_test1 partition(p2);
c1	c2	c3
2	CC	NULL
12	dhh	NULL
22	mh	NULL
7	CC	NULL
删除列的操作是两表ddl，会重新构建和之前一样的表，如果上面存在索引的话，会去校验数据，如果表中存在不符合要求的数据的时候，就报错
ALTER TABLE pt_unique_test1 DROP COLUMN c3;
ERROR 23000: Duplicated primary key
select * from pt_unique_test1;
c1	c2	c3
1	CC	NULL
7	CC	NULL
2	CC	NULL
12	dhh	NULL
22	mh	NULL
7	CC	NULL
21	dhh	NULL
select * from pt_unique_test1 partition(p2);
c1	c2	c3
2	CC	NULL
12	dhh	NULL
22	mh	NULL
7	CC	NULL
ALTER TABLE nt_unique_test1 DROP COLUMN c3;
select * from nt_unique_test1;
c1	c2
15	mh
ddl_mysql  列操作 修改分区键列类型
drop table pt_decimal_test1;
CREATE TABLE pt_decimal_test1 (
c1 INT  ,
c2 decimal(10,5),
c3 float NOT null,
c4 double DEFAULT 3.14159
)
PARTITION BY RANGE(c1) (
PARTITION p1 VALUES LESS THAN (10),
PARTITION p2 VALUES LESS THAN (20),
PARTITION p3 VALUES LESS THAN (30)
);
insert into pt_decimal_test1(c1,c2,c3,c4) values(1,1,1,1),(12,12,12,12),(23,23,23,23),(4,4,4,4);
drop table nt_decimal_test1;
CREATE TABLE nt_decimal_test1 (
c1 INT ,
c2 decimal(10,5),
c3 float NOT null,
c4 double DEFAULT 3.14159
);
insert into nt_decimal_test1(c1,c2,c3,c4) values(1,1,1,1),(12,12,12,12),(23,23,23,23),(4,4,4,4);
ALTER TABLE pt_decimal_test1 EXCHANGE PARTITION p2 WITH TABLE nt_decimal_test1 WITHOUT VALIDATION;
select * from pt_decimal_test1;
c1	c2	c3	c4
1	1.00000	1	1
4	4.00000	4	4
1	1.00000	1	1
12	12.00000	12	12
23	23.00000	23	23
4	4.00000	4	4
23	23.00000	23	23
select * from pt_decimal_test1 partition(p2);
c1	c2	c3	c4
1	1.00000	1	1
12	12.00000	12	12
23	23.00000	23	23
4	4.00000	4	4
ALTER TABLE pt_decimal_test1 MODIFY c1 tinyint;
select * from pt_decimal_test1;
c1	c2	c3	c4
1	1.00000	1	1
4	4.00000	4	4
1	1.00000	1	1
4	4.00000	4	4
12	12.00000	12	12
23	23.00000	23	23
23	23.00000	23	23
select * from pt_decimal_test1 partition(p2);
c1	c2	c3	c4
12	12.00000	12	12
select * from nt_decimal_test1;
c1	c2	c3	c4
12	12.00000	12	12
ALTER TABLE nt_decimal_test1 MODIFY  c1 tinyint;
select * from nt_decimal_test1;
c1	c2	c3	c4
12	12.00000	12	12
ddl_mysql  列操作 修改列类型(非分区键)
drop table pt_decimal_test1;
CREATE TABLE pt_decimal_test1 (
c1 INT  ,
c2 decimal(10,5),
c3 float NOT null,
c4 double DEFAULT 3.14159
)
PARTITION BY RANGE(c1) (
PARTITION p1 VALUES LESS THAN (10),
PARTITION p2 VALUES LESS THAN (20),
PARTITION p3 VALUES LESS THAN (30)
);
insert into pt_decimal_test1(c1,c2,c3,c4) values(1,1,1,1),(12,12,12,12),(23,23,23,23),(4,4,4,4);
drop table nt_decimal_test1;
CREATE TABLE nt_decimal_test1 (
c1 INT ,
c2 decimal(10,5),
c3 float NOT null,
c4 double DEFAULT 3.14159
);
insert into nt_decimal_test1(c1,c2,c3,c4) values(1,1,1,1),(12,12,12,12),(23,23,23,23),(4,4,4,4);
ALTER TABLE pt_decimal_test1 EXCHANGE PARTITION p2 WITH TABLE nt_decimal_test1 WITHOUT VALIDATION;
select * from pt_decimal_test1;
c1	c2	c3	c4
1	1.00000	1	1
4	4.00000	4	4
1	1.00000	1	1
12	12.00000	12	12
23	23.00000	23	23
4	4.00000	4	4
23	23.00000	23	23
select * from pt_decimal_test1 partition(p2);
c1	c2	c3	c4
1	1.00000	1	1
12	12.00000	12	12
23	23.00000	23	23
4	4.00000	4	4
删除列的操作是两表ddl，会重新构建和之前一样的表，如果上面存在索引的话，会去校验数据，如果表中存在不符合要求的数据的时候，就报错
ALTER TABLE pt_decimal_test1 MODIFY c2 char(20);
ERROR 23000: Duplicated primary key
select * from pt_decimal_test1;
c1	c2	c3	c4
1	1.00000	1	1
4	4.00000	4	4
1	1.00000	1	1
12	12.00000	12	12
23	23.00000	23	23
4	4.00000	4	4
23	23.00000	23	23
select * from pt_decimal_test1 partition(p2);
c1	c2	c3	c4
1	1.00000	1	1
12	12.00000	12	12
23	23.00000	23	23
4	4.00000	4	4
ddl_mysql  列操作 修改分区键上约束 添加主键约束 不符合分区的数据还是存在  删除主键不符合分区的数据还是不存在
drop table pt_varchar_test1;
CREATE TABLE pt_varchar_test1 (
c1 INT ,
c2 varchar(30) NOT null,
c3 char(30) DEFAULT 3.14159,
c4 char(10)
)
PARTITION BY RANGE(c1) (
PARTITION p1 VALUES LESS THAN (10),
PARTITION p2 VALUES LESS THAN (20),
PARTITION p3 VALUES LESS THAN (30)
);
insert into pt_varchar_test1(c1,c2,c3,c4) values(1,1,1,1),(12,12,12,12),(23,23,23,23),(4,4,4,4);
drop table nt_varchar_test1;
CREATE TABLE nt_varchar_test1 (
c1 INT ,
c2 varchar(30) NOT null,
c3 char(30) DEFAULT 3.14159,
c4 char(10)
);
insert into nt_varchar_test1(c1,c2,c3,c4) values(1,1,1,1),(12,12,12,12),(23,23,23,23),(4,4,4,4);
ALTER TABLE pt_varchar_test1 EXCHANGE PARTITION p2 WITH TABLE nt_varchar_test1 WITHOUT VALIDATION;
select * from pt_varchar_test1 order by c1;
