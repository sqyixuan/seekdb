7	2022-07-12	CC	2022
13	2022-08-08	nhj	2022
17	2022-09-12	CC	2022
ALTER TABLE pt_stored_test EXCHANGE PARTITION p2020 WITH TABLE nt_stored_test WITHOUT VALIDATION;
select * from pt_stored_test;
c1	c2	c3	c4
60	2000-01-20	mh	2000
-80	2021-08-20	dhh	2021
777	2024-01-12	CC	2024
