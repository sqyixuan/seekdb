ddl_mysql  主键操作 添加主键
drop table if exists t1;
CREATE TABLE t1(
c1 int,
c2 varchar(30)
)
PARTITION BY RANGE (c1) (
PARTITION p1 VALUES LESS THAN (15),
PARTITION p2 VALUES LESS THAN (35),
PARTITION p3 VALUES LESS THAN (50)
);
insert into t1(c1) values(20),(29),(35),(40),(15),(18);
drop table if exists t2;
CREATE TABLE t2(
c1 int,
c2 varchar(30)
);
insert into t2 values(21,'AA'),(9,null),(29,'SE'),(45,'GG');
ALTER TABLE t1 EXCHANGE PARTITION p2 WITH TABLE t2 WITHOUT VALIDATION;
select * from t1;
c1	c2
21	AA
9	NULL
29	SE
45	GG
35	NULL
40	NULL
select * from t1 partition(p2);
c1	c2
21	AA
9	NULL
29	SE
45	GG
select * from t2;
c1	c2
20	NULL
29	NULL
15	NULL
18	NULL
ALTER TABLE t1 ADD PRIMARY KEY (c1);
select * from t1;
c1	c2
9	NULL
21	AA
29	SE
35	NULL
40	NULL
45	GG
select * from t1 partition(p2);
c1	c2
21	AA
29	SE
select * from t2;
c1	c2
20	NULL
29	NULL
15	NULL
18	NULL
ddl_mysql  列操作 添加列 add column
drop table pt_stored_test;
CREATE TABLE pt_stored_test (
c1 INT NOT NULL,
c2 DATE NOT NULL,
c3 VARCHAR(50) NOT NULL,
c4 INT AS (YEAR(c2)) STORED, 
PRIMARY KEY (c2)
)
PARTITION BY RANGE(YEAR(c2)) (
PARTITION p2019 VALUES LESS THAN (2020),
PARTITION p2020 VALUES LESS THAN (2021),
PARTITION p2021 VALUES LESS THAN (2022),
PARTITION p2022 VALUES LESS THAN (2023)
);
insert into pt_stored_test(c1,c2,c3) values(1,'2020-02-20','CC'),(2,'2020-08-20','dhh'),(5,'2021-09-20','mh'),(7,'2022-07-12','CC');
insert into pt_stored_test(c1,c2,c3) values(11,'2020-05-30','ruh'),(13,'2022-08-08','nhj'),(15,'2021-11-21','m11111h'),(17,'2022-09-12','CC');
drop table nt_stored_test;
CREATE TABLE nt_stored_test (
c1 INT NOT NULL,
c2 DATE NOT NULL,
c3 VARCHAR(50) NOT NULL,
c4 INT AS (YEAR(c2)) STORED,
PRIMARY KEY (c2)
);
insert into nt_stored_test(c1,c2,c3) values(30,'2030-02-20','CC'),(-80,'2021-08-20','dhh'),(60,'2000-01-20','mh'),(777,'2024-01-12','CC');
select * from pt_stored_test;
