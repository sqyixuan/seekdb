1	1	1	1
1	1	1	1
4	4	4	4
4	4	4	4
12	12	12	12
23	23	23	23
23	23	23	23
select * from pt_varchar_test1 partition(p2);
c1	c2	c3	c4
1	1	1	1
12	12	12	12
23	23	23	23
4	4	4	4
ALTER TABLE pt_varchar_test1 MODIFY COLUMN c1 INT NOT NULL;
select * from pt_varchar_test1 order by c1;
c1	c2	c3	c4
1	1	1	1
1	1	1	1
4	4	4	4
4	4	4	4
12	12	12	12
23	23	23	23
23	23	23	23
select * from pt_varchar_test1 partition(p2);
c1	c2	c3	c4
1	1	1	1
12	12	12	12
23	23	23	23
4	4	4	4
ALTER TABLE pt_varchar_test1 MODIFY COLUMN c1 INT PRIMARY KEY;
ERROR 23000: Duplicated primary key
