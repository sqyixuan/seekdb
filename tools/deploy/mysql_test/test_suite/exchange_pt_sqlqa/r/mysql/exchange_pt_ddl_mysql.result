ddl_mysql  列操作 rename 非分区键,  分区键不允许重命名
drop table pt_varchar_test1;
CREATE TABLE pt_varchar_test1 (
c1 INT PRIMARY KEY,
c2 varchar(30) NOT null,
c3 char(30) DEFAULT 3.14159,
c4 char(10)
)
PARTITION BY RANGE(c1) (
PARTITION p1 VALUES LESS THAN (10),
PARTITION p2 VALUES LESS THAN (20),
PARTITION p3 VALUES LESS THAN (30)
);
insert into pt_varchar_test1(c1,c2,c3,c4) values(1,1,1,1),(12,12,12,12),(23,23,23,23),(4,4,4,4);
drop table nt_varchar_test1;
CREATE TABLE nt_varchar_test1 (
c1 INT PRIMARY KEY,
c2 varchar(30) NOT null,
c3 char(30) DEFAULT 3.14159,
c4 char(10)
);
insert into nt_varchar_test1(c1,c2,c3,c4) values(2,2,2,3),(13,13,13,13),(24,24,24,24),(5,5,5,5);
ALTER TABLE pt_varchar_test1 EXCHANGE PARTITION p2 WITH TABLE nt_varchar_test1 WITHOUT VALIDATION;
select * from pt_varchar_test1 order by c1;
