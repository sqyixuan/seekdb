5	2021-09-20	mh	2021
15	2021-11-21	m11111h	2021
7	2022-07-12	CC	2022
13	2022-08-08	nhj	2022
17	2022-09-12	CC	2022
select * from pt_stored_test partition(p2020);
c1	c2	c3	c4
60	2000-01-20	mh	2000
-80	2021-08-20	dhh	2021
777	2024-01-12	CC	2024
30	2030-02-20	CC	2030
ALTER TABLE pt_stored_test ADD COLUMN c5 int;
select * from pt_stored_test;
c1	c2	c3	c4	c5
