--echo  生成列上创建索引

--error 0,1051
drop table pt_index_test1;
CREATE TABLE pt_index_test1 (
    c1 INT ,
    c2 varchar(30) NOT null,
    c3 char(30) DEFAULT 3.14159,
	c4 int AS (c1 + 1) STORED
)
PARTITION BY RANGE COLUMNS(c4) (
    PARTITION p1 VALUES LESS THAN (10),
    PARTITION p2 VALUES LESS THAN (20),
    PARTITION p3 VALUES LESS THAN (30)
);

insert into pt_index_test1(c1,c2,c3) values(1,1,1),(12,12,12),(23,23,23),(4,4,4);
--error 0,1051
drop table nt_index_test1;
CREATE TABLE nt_index_test1 (
    c1 INT ,
    c2 varchar(30) NOT null,
    c3 char(30) DEFAULT 3.14159,
	c4 int AS (c1 + 1) STORED
);

insert into nt_index_test1(c1,c2,c3) values(2,2,2),(13,13,13),(24,24,24),(5,5,5);


--error 0,1091
