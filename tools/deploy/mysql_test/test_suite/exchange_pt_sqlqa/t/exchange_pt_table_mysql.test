--error 0,1051
drop table test1;
CREATE TABLE test1(
c1 int primary key,
c2 varchar(30)
)
PARTITION BY RANGE (c1)
(
  PARTITION c1_15 VALUES LESS THAN (15),
  PARTITION c1_35 VALUES LESS THAN (35),
  PARTITION c1_50 VALUES LESS THAN (50)
);


insert into test1(c1) values(1);
insert into test1(c1) values(2);
insert into test1(c1) values(36);
insert into test1(c1) values(38);
insert into test1(c1) values(40);
insert into test1(c1) values(45);

select * from test1;
--error 0,1051
drop table test2;
CREATE TABLE test2(
c1 int primary key,
c2 varchar(30)
);

insert into test2(c1) values(40),(60);

select * from test2;


--echo	#OB支持语法
ALTER TABLE test1 EXCHANGE PARTITION c1_35 WITH TABLE test2 WITHOUT VALIDATION;
select * from test1 partition(c1_35);

--echo	#不加 without validation,预期报错   
--error 1064
ALTER TABLE test1 EXCHANGE PARTITION c1_35 WITH TABLE test2;

--echo	#带有update indexes 预期报错
--error 1064
ALTER TABLE test1 EXCHANGE PARTITION c1_35 WITH TABLE test2 UPDATE INDEXES;
--error 1064
ALTER TABLE test1 EXCHANGE PARTITION c1_35 WITH TABLE test2 UPDATE GLOBAL INDEXES;


--echo	#with VALIDATION 预期报错
--error 1064
ALTER TABLE test1 EXCHANGE PARTITION c1_35 WITH TABLE test2 WITH VALIDATION;



--echo	#表压缩与编码
--echo	#row_format=compressed
--error 0,1051
drop table pt_compressed;
CREATE TABLE pt_compressed(
c1 int primary key,
c2 varchar(30)
)row_format=compressed
PARTITION BY RANGE (c1)
(
  PARTITION c1_15 VALUES LESS THAN (15),
  PARTITION c1_35 VALUES LESS THAN (35),
  PARTITION c1_50 VALUES LESS THAN (50)
);
insert into pt_compressed(c1) values(20),(29),(35),(40),(15),(18);

--error 0,1051
drop table nt_compressed;
CREATE TABLE nt_compressed(
c1 int primary key,
c2 varchar(30)
)row_format=compressed;

insert into nt_compressed values(200,'AA'),(90,null),(32,'SE'),(15,'GG');

select * from pt_compressed;
select * from nt_compressed;

ALTER TABLE pt_compressed EXCHANGE PARTITION c1_35 WITH TABLE nt_compressed WITHOUT VALIDATION;

select * from pt_compressed;
select * from pt_compressed partition(c1_35);
select * from nt_compressed;


--echo	#row_format=redundant
--error 0,1051
drop table pt_redundant;
CREATE TABLE pt_redundant(
c1 int primary key,
c2 varchar(30)
)row_format=redundant
PARTITION BY RANGE (c1)
(
  PARTITION c1_15 VALUES LESS THAN (15),
  PARTITION c1_35 VALUES LESS THAN (35),
  PARTITION c1_50 VALUES LESS THAN (50)
);
insert into pt_redundant(c1) values(20),(29),(35),(40),(15),(18);


--error 0,1051
drop table nt_redundant;
CREATE TABLE nt_redundant(
c1 int primary key,
c2 varchar(30)
)row_format=redundant;

insert into nt_redundant values(200,'AA'),(90,null),(32,'SE'),(15,'GG');

select * from pt_redundant;
select * from nt_redundant;

ALTER TABLE pt_redundant EXCHANGE PARTITION c1_35 WITH TABLE nt_redundant WITHOUT VALIDATION;

select * from pt_redundant;
select * from pt_redundant partition(c1_35);
select * from nt_redundant;

--echo	#两个nt表交换 ，预期报错
--error 1505
ALTER TABLE nt_redundant EXCHANGE PARTITION c1_35 WITH TABLE nt_redundant WITHOUT VALIDATION;

--echo	#两个pt表交换，预期报错
--error 1066
ALTER TABLE pt_redundant EXCHANGE PARTITION c1_35 WITH TABLE pt_redundant WITHOUT VALIDATION;

--echo	#语法中nt/pt表位置调换执行，预期报错
--error 1505
ALTER TABLE nt_redundant EXCHANGE PARTITION c1_35 WITH TABLE pt_redundant WITHOUT VALIDATION;

--echo	#PT表与PT表 编码格式不同 进行交换，预期报错。
--error 1235
ALTER TABLE pt_compressed EXCHANGE PARTITION c1_35 WITH TABLE pt_redundant WITHOUT VALIDATION;

--echo	#NT表与NT表编码格式不同进行交换，预期报错。
--error 1505
ALTER TABLE nt_compressed EXCHANGE PARTITION c1_35 WITH TABLE nt_redundant WITHOUT VALIDATION;

--echo	#编码格式不同的PT和NT表进行交换。预期报错。
--error 1731
ALTER TABLE pt_compressed EXCHANGE PARTITION c1_35 WITH TABLE nt_redundant WITHOUT VALIDATION;


