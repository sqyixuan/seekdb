--echo 目前外表不支持分区表
--error 0,1051
drop table t1;
CREATE TABLE t1(
c1 int,
c2 int,
c3 varchar(30)
)
PARTITION BY RANGE (c1) (
    PARTITION p1 VALUES LESS THAN (15),
    PARTITION p2 VALUES LESS THAN (35),
    PARTITION p3 VALUES LESS THAN (50)
);
insert into t1(c1) values(20),(29),(35),(40),(15),(18);
--error 0,1051
drop table ex_ex_t1;
create external table ex_ex_t1 (
c1 int,
c2 int,
c3 varchar(30)
)
location='../include'
format (
    type = 'csv'
	LINE_DELIMITER = '\n'
)
PATTERN = 'ex_nt.csv'
;

--error 1235
ALTER TABLE t1 EXCHANGE PARTITION p2 WITH TABLE ex_ex_t1 WITHOUT VALIDATION;


--echo 存储过程
--error 0,1051
drop table t1;
CREATE TABLE t1(
    c1 int primary key,
    c2 varchar(30)
)
PARTITION BY RANGE (c1) (
    PARTITION p1 VALUES LESS THAN (15),
    PARTITION p2 VALUES LESS THAN (35),
    PARTITION p3 VALUES LESS THAN (50)
);
insert into t1(c1) values(20),(29),(35),(40),(15),(18);
--error 0,1051
drop table t2;
CREATE TABLE t2(
c1 int primary key,
c2 varchar(30)
);

insert into t2 values(21,'AA'),(9,null),(29,'SE'),(45,'GG');

ALTER TABLE t1 EXCHANGE PARTITION p2 WITH TABLE t2 WITHOUT VALIDATION;
select * from t1 partition(p2);
select * from t2;

--error 0,1305
drop PROCEDURE proc_name;

delimiter //;
--disable_warnings

CREATE PROCEDURE proc_name()
   BEGIN
	PREPARE stmt FROM 'ALTER TABLE t1 EXCHANGE PARTITION p2 WITH TABLE t2 WITHOUT VALIDATION';
    EXECUTE stmt;
    DEALLOCATE PREPARE stmt;
   END //

delimiter ;//
--enable_warnings


CALL proc_name();

select * from t1 partition(p2);
select * from t2;

--error 0,1305
drop PROCEDURE proc_name;

--echo 触发器

--error 0,1360
drop TRIGGER trg2_t;

delimiter //;
--disable_warnings

CREATE TRIGGER trg2_t BEFORE INSERT ON t1 FOR EACH ROW 
BEGIN
  INSERT INTO t2(c1) VALUES (2222222);
END;
//

delimiter ;//
--enable_warnings

--echo insert触发器，分区交换不会触发
ALTER TABLE t1 EXCHANGE PARTITION p2 WITH TABLE t2 WITHOUT VALIDATION;
select * from t1 partition(p2);
select * from t2;

--error 0,1360
drop TRIGGER trg2_t;

delimiter //;
--disable_warnings

CREATE TRIGGER trg2_t BEFORE UPDATE ON t1 FOR EACH ROW 
BEGIN
  INSERT INTO t2(c1) VALUES (2222222);
END;
//

delimiter ;//
--enable_warnings

--echo UPDATE触发器，分区交换不会触发
ALTER TABLE t1 EXCHANGE PARTITION p2 WITH TABLE t2 WITHOUT VALIDATION;
select * from t1 partition(p2);
select * from t2;

--error 0,1360
drop TRIGGER trg2_t;

delimiter //;
--disable_warnings

CREATE TRIGGER trg2_t BEFORE DELETE ON t1 FOR EACH ROW 
BEGIN
  INSERT INTO t2(c1) VALUES (2222222);
END;
//

delimiter ;//
--enable_warnings

--echo DELETE触发器，分区交换不会触发
ALTER TABLE t1 EXCHANGE PARTITION p2 WITH TABLE t2 WITHOUT VALIDATION;
select * from t1 partition(p2);
select * from t2;

--error 0,1360
drop TRIGGER trg2_t;
--error 0,1051
drop table t1;
--error 0,1051
drop table t2;
