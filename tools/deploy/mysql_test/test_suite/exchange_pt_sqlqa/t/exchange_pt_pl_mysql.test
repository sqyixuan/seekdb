--echo tablegroup
--error 0,5151
DROP TABLEGROUP TABLE_GROUP1;
CREATE TABLEGROUP TABLE_GROUP1 SHARDING = 'NONE';
--error 0,1051
drop table t1;
CREATE TABLE t1(
    c1 int primary key,
    c2 varchar(30)
)TABLEGROUP = TABLE_GROUP1
PARTITION BY RANGE (c1) (
    PARTITION p1 VALUES LESS THAN (15),
    PARTITION p2 VALUES LESS THAN (35),
    PARTITION p3 VALUES LESS THAN (50)
);
insert into t1(c1) values(20),(29),(35),(40),(15),(18);
--error 0,1051
drop table t2;
CREATE TABLE t2(
c1 int primary key,
c2 varchar(30)
);

insert into t2 values(21,'AA'),(9,null),(29,'SE'),(45,'GG');

--echo 只有一张表在tablegroup，进行交换
--error 1736
ALTER TABLE t1 EXCHANGE PARTITION p2 WITH TABLE t2 WITHOUT VALIDATION;


ALTER TABLEGROUP TABLE_GROUP1 ADD t2;

--echo 都在同一tablegroup，进行交换
ALTER TABLE t1 EXCHANGE PARTITION p2 WITH TABLE t2 WITHOUT VALIDATION;

select * from t1 partition(p2);
select * from t2;

--error 0,5151
DROP TABLEGROUP TABLE_GROUP2;
CREATE TABLEGROUP TABLE_GROUP2 SHARDING = 'NONE';
--echo 在不同表组tablegroup，进行交换
ALTER TABLEGROUP TABLE_GROUP2 ADD t2;
--error 1736
ALTER TABLE t1 EXCHANGE PARTITION p2 WITH TABLE t2 WITHOUT VALIDATION;
--error 0,1051
drop table t1;
--error 0,1051
drop table t2;
--error 0,5151
DROP TABLEGROUP TABLE_GROUP2;
--error 0,5151
DROP TABLEGROUP TABLE_GROUP1;

