result_format: 4
SET NAMES utf8mb4;
## create table with normal path
create external table ex_hdfs_t1 (
    id INT, 
    name VARCHAR(50), 
    c_date    DATE
)
location='hdfs://100.88.106.200:9000/mysqltest/scenes/empty_path/real_p3'
format (
  TYPE = 'CSV'
  FIELD_DELIMITER = ','
  FIELD_OPTIONALLY_ENCLOSED_BY ='\''
)
PATTERN = 'test_tbl1.csv';
select * from ex_hdfs_t1;
+------+---------+------------+
| id   | name    | c_date     |
+------+---------+------------+
|    1 | Emma    | 2021-09-01 |
|    2 | William | 2021-09-02 |
|    3 | Olivia  | 2021-09-03 |
+------+---------+------------+
## create table with only empty path
create external table ex_hdfs_t2 (
    id INT, 
    name VARCHAR(50), 
    c_date    DATE
)
location='hdfs://100.88.106.200:9000/mysqltest/scenes/empty_path/empty_p1'
format (
  TYPE = 'CSV'
  FIELD_DELIMITER = ','
  FIELD_OPTIONALLY_ENCLOSED_BY ='\''
);
select * from ex_hdfs_t2;
+------+------+--------+
| id   | name | c_date |
+------+------+--------+
+------+------+--------+
## create table with empty path and normal path
create external table ex_hdfs_t3 (
    id INT, 
    name VARCHAR(50), 
    c_date    DATE
)
location='hdfs://100.88.106.200:9000/mysqltest/scenes/empty_path'
format (
  TYPE = 'CSV'
  FIELD_DELIMITER = ','
  FIELD_OPTIONALLY_ENCLOSED_BY ='\''
)
PATTERN = 'test_tbl1.csv';
select * from ex_hdfs_t3;
+------+---------+------------+
| id   | name    | c_date     |
+------+---------+------------+
|    1 | Emma    | 2021-09-01 |
|    2 | William | 2021-09-02 |
|    3 | Olivia  | 2021-09-03 |
+------+---------+------------+
