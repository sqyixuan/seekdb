# owner: xutengting.xtt
# owner group: SQL3
# tags: external_table
# description: test create external table hdfs

--result_format 4

connection default;
SET NAMES utf8mb4;
--disable_query_log
--error 0,1051
drop table ex_hdfs_t1;
--error 0,1051
drop table ex_hdfs_t2;
--error 0,1051
drop table ex_hdfs_t3;
--enable_query_log

## create table with normal path
eval create external table ex_hdfs_t1 (
    id INT, 
    name VARCHAR(50), 
    c_date    DATE
)
location='hdfs://100.88.106.200:9000/mysqltest/scenes/empty_path/real_p3'
format (
  TYPE = 'CSV'
  FIELD_DELIMITER = ','
  FIELD_OPTIONALLY_ENCLOSED_BY ='\''
)
PATTERN = 'test_tbl1.csv';

select * from ex_hdfs_t1;

## create table with only empty path
eval create external table ex_hdfs_t2 (
    id INT, 
    name VARCHAR(50), 
    c_date    DATE
)
location='hdfs://100.88.106.200:9000/mysqltest/scenes/empty_path/empty_p1'
format (
  TYPE = 'CSV'
  FIELD_DELIMITER = ','
  FIELD_OPTIONALLY_ENCLOSED_BY ='\''
);

select * from ex_hdfs_t2;

## create table with empty path and normal path
eval create external table ex_hdfs_t3 (
    id INT, 
    name VARCHAR(50), 
    c_date    DATE
)
location='hdfs://100.88.106.200:9000/mysqltest/scenes/empty_path'
format (
  TYPE = 'CSV'
  FIELD_DELIMITER = ','
  FIELD_OPTIONALLY_ENCLOSED_BY ='\''
)
PATTERN = 'test_tbl1.csv';

select * from ex_hdfs_t3;

##可以查看外表的信息
#select * from  oceanbase.__all_external_table_file;

--disable_query_log
--error 0,1051
drop table ex_hdfs_t1;
--error 0,1051
drop table ex_hdfs_t2;
--error 0,1051
drop table ex_hdfs_t3;

--enable_query_log
