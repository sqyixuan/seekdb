drop user zwc cascade;
create user zwc identified by zwc;
grant all on *.* to zwc with grant option;
grant dba to zwc;
#设置超时等待时间
SET wait_timeout=30000000;
SET ob_trx_timeout = 100000000;
SET ob_query_timeout = 100000000;
create table t2(deptno number primary key,dname varchar2(20),loc varchar2(20));
create table t1(empno number(4),ename varchar2(20),job nvarchar2(9),mgr number(4),hiredate date,sal number(7,2),comm number(7,2),deptno number(2));
