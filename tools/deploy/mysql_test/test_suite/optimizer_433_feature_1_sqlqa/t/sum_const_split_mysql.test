--echo 聚合函数的param是简单的列表达式
--echo 含有case when 不会下压
select /*+place_group_by*/ distinct min(abs(c1)), max(case when c4 < 10 then 1 when c4 <20 then 20 else c4 end ), count(c2) , sum(c1), avg(c1), c2 from ( select * from uniontest1 union all  select * from uniontest2) t1 where c4 > 2  group by c1,c2 having c2 <9999 order by 1,2;
explain basic select /*+place_group_by*/ distinct min(abs(c1)), max(case when c4 < 10 then 1 when c4 <20 then 20 else c4 end ), count(c2) , sum(c1), avg(c1), c2 from ( select * from uniontest1 union all  select * from uniontest2) t1 where c4 > 2  group by c1,c2 having c2 <9999 order by 1,2;

--echo 层次查询，

WITH RECURSIVE cte1 AS (select c1, c2 from uniontest1  UNION ALL  select c1, c2 from uniontest2) SELECT /*+place_group_by*/ sum(c1), c2 FROM cte1 group by c2 order by 1,2;
explain basic WITH RECURSIVE cte1 AS (select c1, c2 from uniontest1  UNION ALL  select c1, c2 from uniontest2) SELECT /*+place_group_by*/ sum(c1), c2 FROM cte1 group by c2 order by 1,2;

WITH RECURSIVE cte2 AS ( SELECT c1, c2, c3, c4, c5, c6, 1 AS level FROM uniontest1 WHERE c5 IS NULL UNION ALL SELECT u.c1, u.c2, u.c3, u.c4, u.c5, u.c6, h.level + 1 FROM uniontest1 u JOIN cte2 h ON u.c5 = h.c1) SELECT /*+place_group_by*/ sum(c1), c2 FROM cte2 group by c2 order by 1,2;
explain basic WITH RECURSIVE cte2 AS ( SELECT c1, c2, c3, c4, c5, c6, 1 AS level FROM uniontest1 WHERE c5 IS NULL UNION ALL SELECT u.c1, u.c2, u.c3, u.c4, u.c5, u.c6, h.level + 1 FROM uniontest1 u JOIN cte2 h ON u.c5 = h.c1) SELECT /*+place_group_by*/ sum(c1), c2 FROM cte2 group by c2 order by 1,2;

