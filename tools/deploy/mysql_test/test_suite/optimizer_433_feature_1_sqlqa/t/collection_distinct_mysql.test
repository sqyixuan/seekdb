#owner: guohanyun.ghy
#owner group: 技术部-SQL-优化器
#description: 435优化器技改 UNION、 INTERSECT、 EXCEPT/MINUS 这几种查询的情况下的并行集合里，提前分配 distinct 去重
#tags:
#author: wb-lyq858317

--result_format 4
purge recyclebin;
--disable_warnings
drop table if exists lyqtest1;
--enable_warnings
CREATE TABLE lyqtest1 (
    c1 INT,
    c2 VARCHAR(255),
    c3 DATETIME,
    c4 FLOAT,
    c5 VARCHAR(255),
    c6 DATE,
    INDEX idx_c1_c2_c3 (c1, c2, c3),
    INDEX idx_t1_c1 (c1)
);

INSERT INTO lyqtest1 (c1, c2, c3, c4, c5, c6) VALUES
(1, 'example1', '2023-10-01 12:00:00', 10.5, 'data1', '2023-10-01');

INSERT INTO lyqtest1 (c1, c2, c3, c4, c5, c6) VALUES
(2, null, '2023-11-01 13:00:00', 20.5, 'data2', '2023-11-01');

INSERT INTO lyqtest1 (c1, c2, c3, c4, c5, c6) VALUES
(3, 'example3', '2023-12-01 14:00:00', 30.5, 'data3', '2023-12-01');

--error 0,1051
drop table lyqtest2;
CREATE TABLE lyqtest2 (
    c1 INT,
    c2 VARCHAR(255),
    c3 DATETIME,
    c4 FLOAT,
    c5 VARCHAR(255),
    c6 DATE,
    INDEX idx_c1 (c1),
    INDEX idx_c2 (c2),
    INDEX idx_c5 (c5)
) 
PARTITION BY RANGE (YEAR(c6)) (
    PARTITION p2020 VALUES LESS THAN (2021),
    PARTITION p2021 VALUES LESS THAN (2022),
    PARTITION p2022 VALUES LESS THAN (2023),
    PARTITION p2023 VALUES LESS THAN MAXVALUE
);

INSERT INTO lyqtest2 (c1, c2, c3, c4, c5, c6) VALUES
(1, 'example1', '2023-09-01 15:00:00', 40.5, 'data4', '2023-09-01');

INSERT INTO lyqtest2 (c1, c2, c3, c4, c5, c6) VALUES
(2, 'example2', '2023-08-01 16:00:00', 50.5, 'data5', '2023-08-01');

INSERT INTO lyqtest2 (c1, c2, c3, c4, c5, c6) VALUES
(null, 'example6', '2023-07-01 17:00:00', 60.5, 'data6', '2023-07-01');

--error 0,1051
drop table lyqtest3;
CREATE TABLE lyqtest3 AS SELECT * FROM lyqtest2;

--echo union
--echo UNION DISTINCT 算子下面直接接着 PX COORDINATOR 或者 EXCHANGE 的情况，会在 EXCHANGE 下面分配一个 DISTINCT
--echo 会下推
select c1 from lyqtest1 union select c1 from lyqtest2;
explain basic select c1 from lyqtest1 union select c1 from lyqtest2;

SELECT c5, LENGTH(c2) AS len_c2 FROM lyqtest2 WHERE c4 > 100.0 AND c2 IS NOT NULL
UNION
SELECT c5, LENGTH(c2) FROM lyqtest3 WHERE c1 < 10;
explain basic SELECT c5, LENGTH(c2) AS len_c2 FROM lyqtest2 WHERE c4 > 100.0 AND c2 IS NOT NULL
UNION
SELECT c5, LENGTH(c2) FROM lyqtest3 WHERE c1 < 10;

SELECT c1, c2, CASE  WHEN c1 > 100 THEN 'High' ELSE 'Low' END AS c1_category FROM lyqtest1 WHERE c2 IS NOT NULL
UNION
SELECT c1, c2, CASE WHEN c1 > 100 THEN 'High' ELSE 'Low' END AS c1_category FROM lyqtest2 WHERE c2 IS NOT NULL;
explain basic SELECT c1, c2, CASE  WHEN c1 > 100 THEN 'High' ELSE 'Low' END AS c1_category FROM lyqtest1 WHERE c2 IS NOT NULL
UNION
SELECT c1, c2, CASE WHEN c1 > 100 THEN 'High' ELSE 'Low' END AS c1_category FROM lyqtest2 WHERE c2 IS NOT NULL;

SELECT c1, c2 FROM (SELECT c1, c2 FROM lyqtest2 WHERE c1 < 50) AS sub1
UNION
SELECT c1, c2 FROM (SELECT c1, c2 FROM lyqtest3 WHERE c1 < 50) AS sub2;
explain basic SELECT c1, c2 FROM (SELECT c1, c2 FROM lyqtest2 WHERE c1 < 50) AS sub1
UNION
SELECT c1, c2 FROM (SELECT c1, c2 FROM lyqtest3 WHERE c1 < 50) AS sub2;

SELECT DISTINCT c1, CASE WHEN c4 % 2 = 0 THEN 'Even' ELSE 'Odd' END AS parity FROM lyqtest1 WHERE c4 IS NOT NULL
UNION
SELECT DISTINCT c1, CASE WHEN c4 % 2 = 0 THEN 'Even' ELSE 'Odd' END FROM lyqtest2 WHERE c4 IS NOT NULL;
explain basic SELECT DISTINCT c1, CASE WHEN c4 % 2 = 0 THEN 'Even' ELSE 'Odd' END AS parity FROM lyqtest1 WHERE c4 IS NOT NULL
UNION
SELECT DISTINCT c1, CASE WHEN c4 % 2 = 0 THEN 'Even' ELSE 'Odd' END FROM lyqtest2 WHERE c4 IS NOT NULL;

--echo 能判断出来唯一，就不会分配 distinct
SELECT c1, COUNT(DISTINCT c5) AS unique_c5_count FROM lyqtest1 WHERE YEAR(c3) > 2020 GROUP BY c1 
UNION
SELECT c1, COUNT(DISTINCT c5) FROM lyqtest2 WHERE c4 > 100.0 GROUP BY c1;
explain basic SELECT c1, COUNT(DISTINCT c5) AS unique_c5_count FROM lyqtest1 WHERE YEAR(c3) > 2020 GROUP BY c1 
UNION
SELECT c1, COUNT(DISTINCT c5) FROM lyqtest2 WHERE c4 > 100.0 GROUP BY c1;

SELECT UPPER(c2) AS upper_c2, AVG(c4) FROM lyqtest2 WHERE c1 BETWEEN 1 AND 50 GROUP BY UPPER(c2)
UNION
SELECT UPPER(c2), AVG(c4) FROM lyqtest3 WHERE c6 < '2022-01-01' GROUP BY UPPER(c2);
explain basic SELECT UPPER(c2) AS upper_c2, AVG(c4) FROM lyqtest2 WHERE c1 BETWEEN 1 AND 50 GROUP BY UPPER(c2)
UNION
SELECT UPPER(c2), AVG(c4) FROM lyqtest3 WHERE c6 < '2022-01-01' GROUP BY UPPER(c2);

--echo 不会下推  因为 UNION DISTINCT 算子下面 不是PX COORDINATOR 或者 EXCHANGE 的
SELECT c1, CONCAT(c2, ' - ', c5) AS combined FROM lyqtest1 WHERE c4 < 50.0
UNION
SELECT c1, CONCAT(c2, ' - ', c5) FROM lyqtest3 WHERE c4 > 50.0;
explain basic SELECT c1, CONCAT(c2, ' - ', c5) AS combined FROM lyqtest1 WHERE c4 < 50.0
UNION
SELECT c1, CONCAT(c2, ' - ', c5) FROM lyqtest3 WHERE c4 > 50.0;

SELECT DATE_FORMAT(a.c6, '%Y-%m') AS month_year, COUNT(*) AS record_count FROM lyqtest1 a JOIN lyqtest2 b ON a.c1 = b.c1 WHERE a.c4 IS NOT NULL GROUP BY DATE_FORMAT(a.c6, '%Y-%m')
UNION 
SELECT DATE_FORMAT(c.c6, '%Y-%m'), COUNT(*) FROM lyqtest3 c JOIN lyqtest1 d ON c.c1 = d.c1 WHERE c.c2 LIKE 'B%' GROUP BY DATE_FORMAT(c.c6, '%Y-%m');
explain basic SELECT DATE_FORMAT(a.c6, '%Y-%m') AS month_year, COUNT(*) AS record_count FROM lyqtest1 a JOIN lyqtest2 b ON a.c1 = b.c1 WHERE a.c4 IS NOT NULL GROUP BY DATE_FORMAT(a.c6, '%Y-%m')
UNION 
SELECT DATE_FORMAT(c.c6, '%Y-%m'), COUNT(*) FROM lyqtest3 c JOIN lyqtest1 d ON c.c1 = d.c1 WHERE c.c2 LIKE 'B%' GROUP BY DATE_FORMAT(c.c6, '%Y-%m');

SELECT a.c1 FROM lyqtest1 a JOIN lyqtest2 b ON a.c1 = b.c1 WHERE YEAR(a.c3) = 2021 AND b.c4 > 50.0
UNION
SELECT c.c1 FROM lyqtest3 c JOIN lyqtest1 d ON c.c1 = d.c1 WHERE MONTH(c.c3) = 12 AND d.c4 < 100.0;
explain basic SELECT a.c1 FROM lyqtest1 a JOIN lyqtest2 b ON a.c1 = b.c1 WHERE YEAR(a.c3) = 2021 AND b.c4 > 50.0
UNION
SELECT c.c1 FROM lyqtest3 c JOIN lyqtest1 d ON c.c1 = d.c1 WHERE MONTH(c.c3) = 12 AND d.c4 < 100.0;

SELECT c1, c4 FROM lyqtest1 WHERE c4 > (SELECT AVG(c4) FROM lyqtest1)
UNION
SELECT c1, c4 FROM lyqtest2 WHERE c4 > (SELECT AVG(c4) FROM lyqtest2);
explain basic SELECT c1, c4 FROM lyqtest1 WHERE c4 > (SELECT AVG(c4) FROM lyqtest1)
UNION
SELECT c1, c4 FROM lyqtest2 WHERE c4 > (SELECT AVG(c4) FROM lyqtest2);

--echo INTERSECT
--echo INTERSECT DISTINCT 算子下面直接接着 PX COORDINATOR 或者 EXCHANGE 的情况，会在 EXCHANGE 下面分配一个 DISTINCT
--echo 会下推
select c1 from lyqtest1 INTERSECT select c1 from lyqtest2;
explain basic select c1 from lyqtest1 INTERSECT select c1 from lyqtest2;

SELECT c5, LENGTH(c2) AS len_c2 FROM lyqtest2 WHERE c4 < 100.0 AND c2 IS NOT NULL
INTERSECT
SELECT c5, LENGTH(c2) FROM lyqtest3 WHERE c1 < 10;
explain basic SELECT c5, LENGTH(c2) AS len_c2 FROM lyqtest2 WHERE c4 < 100.0 AND c2 IS NOT NULL
INTERSECT
SELECT c5, LENGTH(c2) FROM lyqtest3 WHERE c1 < 10;

SELECT c1, c2, CASE  WHEN c1 > 100 THEN 'High' ELSE 'Low' END AS c1_category FROM lyqtest1 WHERE c2 IS NOT NULL
INTERSECT
SELECT c1, c2, CASE WHEN c1 > 100 THEN 'High' ELSE 'Low' END AS c1_category FROM lyqtest2 WHERE c2 IS NOT NULL;
explain basic SELECT c1, c2, CASE  WHEN c1 > 100 THEN 'High' ELSE 'Low' END AS c1_category FROM lyqtest1 WHERE c2 IS NOT NULL
INTERSECT
SELECT c1, c2, CASE WHEN c1 > 100 THEN 'High' ELSE 'Low' END AS c1_category FROM lyqtest2 WHERE c2 IS NOT NULL;

SELECT c1, c2 FROM (SELECT c1, c2 FROM lyqtest2 WHERE c1 < 50) AS sub1
INTERSECT
SELECT c1, c2 FROM (SELECT c1, c2 FROM lyqtest3 WHERE c1 < 50) AS sub2;
explain basic SELECT c1, c2 FROM (SELECT c1, c2 FROM lyqtest2 WHERE c1 < 50) AS sub1
INTERSECT
SELECT c1, c2 FROM (SELECT c1, c2 FROM lyqtest3 WHERE c1 < 50) AS sub2;

SELECT DISTINCT c1, CASE WHEN c4 % 2 = 0 THEN 'Even' ELSE 'Odd' END AS parity FROM lyqtest1 WHERE c4 IS NOT NULL
INTERSECT
SELECT DISTINCT c1, CASE WHEN c4 % 2 = 0 THEN 'Even' ELSE 'Odd' END FROM lyqtest2 WHERE c4 IS NOT NULL;
explain basic SELECT DISTINCT c1, CASE WHEN c4 % 2 = 0 THEN 'Even' ELSE 'Odd' END AS parity FROM lyqtest1 WHERE c4 IS NOT NULL
INTERSECT
SELECT DISTINCT c1, CASE WHEN c4 % 2 = 0 THEN 'Even' ELSE 'Odd' END FROM lyqtest2 WHERE c4 IS NOT NULL;

--echo 能判断出来唯一，就不会分配 distinct
SELECT UPPER(c2) AS upper_c2, AVG(c4) FROM lyqtest2 WHERE c1 BETWEEN 1 AND 50 GROUP BY UPPER(c2)
INTERSECT
SELECT UPPER(c2), AVG(c4) FROM lyqtest3 WHERE c6 > '2022-01-01' GROUP BY UPPER(c2);
explain basic SELECT UPPER(c2) AS upper_c2, AVG(c4) FROM lyqtest2 WHERE c1 BETWEEN 1 AND 50 GROUP BY UPPER(c2)
INTERSECT
SELECT UPPER(c2), AVG(c4) FROM lyqtest3 WHERE c6 > '2022-01-01' GROUP BY UPPER(c2);

--echo 不会下推  因为INTERSECT DISTINCT 算子下面 不是PX COORDINATOR 或者 EXCHANGE 的
SELECT a.c1 FROM lyqtest1 a JOIN lyqtest2 b ON a.c1 = b.c1
INTERSECT
SELECT c.c1 FROM lyqtest3 c JOIN lyqtest1 d ON c.c1 = d.c1;
explain basic SELECT a.c1 FROM lyqtest1 a JOIN lyqtest2 b ON a.c1 = b.c1
INTERSECT
SELECT c.c1 FROM lyqtest3 c JOIN lyqtest1 d ON c.c1 = d.c1;

--echo EXCEPT/MINUS
--echo EXCEPT/MINUS DISTINCT 算子下面直接接着 PX COORDINATOR 或者 EXCHANGE 的情况，会在 EXCHANGE 下面分配一个 DISTINCT
--echo 会下推
select c1 from lyqtest1 EXCEPT select c1 from lyqtest2;
explain basic select c1 from lyqtest1 EXCEPT select c1 from lyqtest2;

SELECT c5, LENGTH(c2) AS len_c2 FROM lyqtest2 WHERE c4 < 100.0 AND c2 IS NOT NULL
EXCEPT
SELECT c5, LENGTH(c2) FROM lyqtest3 WHERE c1 < 10;
explain basic SELECT c5, LENGTH(c2) AS len_c2 FROM lyqtest2 WHERE c4 < 100.0 AND c2 IS NOT NULL
EXCEPT
SELECT c5, LENGTH(c2) FROM lyqtest3 WHERE c1 < 10;

SELECT c1, c2, CASE  WHEN c1 > 100 THEN 'High' ELSE 'Low' END AS c1_category FROM lyqtest1 WHERE c2 IS NOT NULL
EXCEPT
SELECT c1, c2, CASE WHEN c1 > 100 THEN 'High' ELSE 'Low' END AS c1_category FROM lyqtest2 WHERE c2 IS NOT NULL;
explain basic SELECT c1, c2, CASE  WHEN c1 > 100 THEN 'High' ELSE 'Low' END AS c1_category FROM lyqtest1 WHERE c2 IS NOT NULL
EXCEPT
SELECT c1, c2, CASE WHEN c1 > 100 THEN 'High' ELSE 'Low' END AS c1_category FROM lyqtest2 WHERE c2 IS NOT NULL;

SELECT c1, c2 FROM (SELECT c1, c2 FROM lyqtest2 WHERE c1 < 50) AS sub1
MINUS
SELECT c1, c2 FROM (SELECT c1, c2 FROM lyqtest3 WHERE c1 < 2) AS sub2;
explain basic SELECT c1, c2 FROM (SELECT c1, c2 FROM lyqtest2 WHERE c1 < 50) AS sub1
MINUS
SELECT c1, c2 FROM (SELECT c1, c2 FROM lyqtest3 WHERE c1 < 2) AS sub2;

SELECT DISTINCT c1, CASE WHEN c4 % 2 = 0 THEN 'Even' ELSE 'Odd' END AS parity FROM lyqtest1 WHERE c4 IS NOT NULL
MINUS
SELECT DISTINCT c1, CASE WHEN c4 % 2 = 0 THEN 'Even' ELSE 'Odd' END FROM lyqtest2 WHERE c4 IS NOT NULL;
explain basic SELECT DISTINCT c1, CASE WHEN c4 % 2 = 0 THEN 'Even' ELSE 'Odd' END AS parity FROM lyqtest1 WHERE c4 IS NOT NULL
MINUS
SELECT DISTINCT c1, CASE WHEN c4 % 2 = 0 THEN 'Even' ELSE 'Odd' END FROM lyqtest2 WHERE c4 IS NOT NULL;

--echo 能判断出来唯一，就不会分配 distinct
SELECT c1, COUNT(DISTINCT c5) AS unique_c5_count FROM lyqtest1 WHERE YEAR(c3) > 2020 GROUP BY c1 
EXCEPT
