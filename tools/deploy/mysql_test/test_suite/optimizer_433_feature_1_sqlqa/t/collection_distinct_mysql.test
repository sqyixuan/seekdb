--error 0,1051
drop view v_union;
create view v_union as (select c1 from lyqtest1 union select c1 from lyqtest2);

--error 0,1051
drop view v_INTERSECT;
create view v_INTERSECT as (SELECT c5, LENGTH(c2) AS len_c2 FROM lyqtest2 WHERE c4 < 100.0 AND c2 IS NOT NULL
INTERSECT
SELECT c5, LENGTH(c2) FROM lyqtest3 WHERE c1 < 10);

--error 0,1051
drop view v_EXCEPT;
create view v_EXCEPT as (SELECT c1, c2, CASE  WHEN c1 > 100 THEN 'High' ELSE 'Low' END AS c1_category FROM lyqtest1 WHERE c2 IS NOT NULL
EXCEPT
SELECT c1, c2, CASE WHEN c1 > 100 THEN 'High' ELSE 'Low' END AS c1_category FROM lyqtest2 WHERE c2 IS NOT NULL);

select * from v_union;
explain basic  select * from v_union;
select * from v_INTERSECT;
explain basic select * from v_INTERSECT;
select * from v_EXCEPT;
explain basic select * from v_EXCEPT;

select * from  v_INTERSECT v1 ,(select v2.* from v_EXCEPT v2 left join v_union v3 on v2.c1= v3.c1) tt1 order by 1,2,3;
explain basic select * from  v_INTERSECT v1 ,(select v2.* from v_EXCEPT v2 left join v_union v3 on v2.c1= v3.c1) tt1 order by 1,2,3;

