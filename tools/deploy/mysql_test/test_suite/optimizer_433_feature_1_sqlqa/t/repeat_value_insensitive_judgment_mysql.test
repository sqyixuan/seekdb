--error 0,1051
drop table lyqtest3;
CREATE TABLE lyqtest3 AS SELECT * FROM lyqtest2;

--error 0,1051
drop view v_left_outer;
create view v_left_outer as (select distinct t1.* from lyqtest1 t1 left outer join lyqtest2 t2 on t1.c1 = t2.c1);

--error 0,1051
drop view v_semi;
create view v_semi as (select * from lyqtest1 t1 where exists (select 1 from lyqtest2 t2 where t1.c1 = t2.c1));

--echo Semi To Inner 的改动
--echo 位于上层 Semi 右表

select distinct view1.c1 from (select c1 from lyqtest1 t1 where exists (select 1 from lyqtest2 t2 where t1.c1 = t2.c1)) view1;
select distinct c1 from (select t1.c1 from lyqtest1 t1 inner join lyqtest2 t2 on t1.c1 = t2.c1) view1;
explain basic select distinct view1.c1 from (select c1 from lyqtest1 t1 where exists (select 1 from lyqtest2 t2 where t1.c1 = t2.c1)) view1;
explain basic select distinct c1 from (select t1.c1 from lyqtest1 t1 inner join lyqtest2 t2 on t1.c1 = t2.c1) view1;
explain basic select distinct view1.c1 from (select /*+ NO_REWRITE */ c1 from lyqtest1 t1 where exists (select 1 from lyqtest2 t2 where t1.c1 = t2.c1)) view1;

select * from lyqtest3 where c1 in (select c1 from lyqtest1 t1 where exists (select 1 from lyqtest2 t2 where t1.c1 = t2.c1));
explain basic select * from lyqtest3 where c1 in (select c1 from lyqtest1 t1 where exists (select 1 from lyqtest2 t2 where t1.c1 = t2.c1));
explain basic select * from lyqtest3 where c1 in (select /*+ NO_REWRITE */ c1 from lyqtest1 t1 where exists (select 1 from lyqtest2 t2 where t1.c1 = t2.c1));

select * from lyqtest3 where c1 in (select c1 from lyqtest1 t1 where c2 = any (select c2 from lyqtest2 t2 where t1.c1 = t2.c1));
explain basic select * from lyqtest3 where c1 in (select c1 from lyqtest1 t1 where c2 = any (select c2 from lyqtest2 t2 where t1.c1 = t2.c1));
explain basic select * from lyqtest3 where c1 in (select /*+ NO_REWRITE */ c1 from lyqtest1 t1 where c2 = any (select c2 from lyqtest2 t2 where t1.c1 = t2.c1));

select * from lyqtest3 where c1 in (select c1 from lyqtest1 t1 where c2 = all (select c2 from lyqtest2 t2 where t1.c1 = t2.c1));
explain basic select * from lyqtest3 where c1 in (select c1 from lyqtest1 t1 where c2 = all (select c2 from lyqtest2 t2 where t1.c1 = t2.c1));
explain basic select * from lyqtest3 where c1 in (select /*+ NO_REWRITE */ c1 from lyqtest1 t1 where c2 = all (select c2 from lyqtest2 t2 where t1.c1 = t2.c1));

--echo 位于 set distinct

select c1 from lyqtest1 t1 where exists (select 1 from lyqtest2 t2 where t1.c1 = t2.c1)
union
select c1 from lyqtest3 order by 1;
explain basic select c1 from lyqtest1 t1 where exists (select 1 from lyqtest2 t2 where t1.c1 = t2.c1)
union
select c1 from lyqtest3 order by 1;
explain basic select /*+ NO_REWRITE */ c1 from lyqtest1 t1 where exists (select 1 from lyqtest2 t2 where t1.c1 = t2.c1)
union
select c1 from lyqtest3 order by 1;

select c1 from lyqtest1 t1 where c2 = any (select c2 from lyqtest2 t2 where t1.c1 = t2.c1)
union
select c1 from lyqtest3 order by 1;
select c1 from lyqtest1 t1 where c2 = all (select c2 from lyqtest2 t2 where t1.c1 = t2.c1)
union
select c1 from lyqtest3 order by 1;

--echo 本层有重复值不敏感聚合

select max(c1) from lyqtest1 t1 where exists (select 1 from lyqtest2 t2 where t1.c1 = t2.c1);
explain basic select max(c1) from lyqtest1 t1 where exists (select 1 from lyqtest2 t2 where t1.c1 = t2.c1);
explain basic select  /*+ NO_REWRITE */ max(c1) from lyqtest1 t1 where exists (select 1 from lyqtest2 t2 where t1.c1 = t2.c1);

select max(c1),min(c4) from lyqtest1 t1 where exists (select 1 from lyqtest2 t2 where t1.c1 = t2.c1);
explain basic select max(c1),min(c4) from lyqtest1 t1 where exists (select 1 from lyqtest2 t2 where t1.c1 = t2.c1);
explain basic select /*+ NO_REWRITE */ max(c1),min(c4) from lyqtest1 t1 where exists (select 1 from lyqtest2 t2 where t1.c1 = t2.c1);

select avg(c1) from lyqtest1 t1 where exists (select 1 from lyqtest2 t2 where t1.c1 = t2.c1);
explain basic select avg(c1) from lyqtest1 t1 where exists (select 1 from lyqtest2 t2 where t1.c1 = t2.c1);
explain basic select /*+ NO_REWRITE */ avg(c1) from lyqtest1 t1 where exists (select 1 from lyqtest2 t2 where t1.c1 = t2.c1);

select count(c1) from lyqtest1 t1 where exists (select 1 from lyqtest2 t2 where t1.c1 = t2.c1);
explain basic select count(c1) from lyqtest1 t1 where exists (select 1 from lyqtest2 t2 where t1.c1 = t2.c1);
explain basic select /*+ NO_REWRITE */ count(c1) from lyqtest1 t1 where exists (select 1 from lyqtest2 t2 where t1.c1 = t2.c1);

--echo 本层有 Distinct

select distinct c1 from lyqtest1 t1 where exists (select * from lyqtest2 t2 where t1.c1 = t2.c1);
explain basic select distinct c1 from lyqtest1 t1 where exists (select * from lyqtest2 t2 where t1.c1 = t2.c1);
explain basic select /*+ NO_REWRITE */ distinct c1 from lyqtest1 t1 where exists (select * from lyqtest2 t2 where t1.c1 = t2.c1);

select distinct max(c1) from lyqtest1 t1 where exists (select * from lyqtest2 t2 where t1.c1 = t2.c1);
explain basic select distinct max(c1) from lyqtest1 t1 where exists (select * from lyqtest2 t2 where t1.c1 = t2.c1);

explain basic select distinct avg(c1) from lyqtest1 t1 where exists (select 1 from lyqtest2 t2 where t1.c1 = t2.c1);

--echo 上层有 Distinct

select distinct view1.c1 from lyqtest3,(select c1 from lyqtest1 t1 where exists (select 1 from lyqtest2 t2 where t1.c1 = t2.c1)) view1;
explain basic select distinct view1.c1 from lyqtest3,(select c1 from lyqtest1 t1 where exists (select 1 from lyqtest2 t2 where t1.c1 = t2.c1)) view1;
explain basic select distinct view1.c1 from lyqtest3,(select /*+ NO_REWRITE */ c1 from lyqtest1 t1 where exists (select 1 from lyqtest2 t2 where t1.c1 = t2.c1)) view1;

select distinct max(view1.c1) from lyqtest3,(select c1 from lyqtest1 t1 where exists (select 1 from lyqtest2 t2 where t1.c1 = t2.c1)) view1;
explain basic select distinct max(view1.c1) from lyqtest3,(select c1 from lyqtest1 t1 where exists (select 1 from lyqtest2 t2 where t1.c1 = t2.c1)) view1;

--echo 组合

select distinct max(view1.c1) from lyqtest3,(select distinct max(c1) c1 from lyqtest1 t1 where exists (select 1 from lyqtest2 t2 where t1.c1 = t2.c1)) view1;
explain basic select distinct max(view1.c1) from lyqtest3,(select distinct max(c1) c1 from lyqtest1 t1 where exists (select 1 from lyqtest2 t2 where t1.c1 = t2.c1)) view1;

select distinct max(view1.c1) from lyqtest3,(select distinct max(c1) c1 from lyqtest1 t1 where exists (select 1 from lyqtest2 t2 where t1.c1 = t2.c1)) view1
union
select c1 from lyqtest3 order by 1;
explain basic select distinct max(view1.c1) from lyqtest3,(select distinct max(c1) c1 from lyqtest1 t1 where exists (select 1 from lyqtest2 t2 where t1.c1 = t2.c1)) view1
union
select c1 from lyqtest3 order by 1;

select * from lyqtest3 where c1 in (select distinct max(c1) from lyqtest1 t1 where exists (select 1 from lyqtest2 t2 where t1.c1 = t2.c1));
explain basic  select * from lyqtest3 where c1 in (select distinct max(c1) from lyqtest1 t1 where exists (select 1 from lyqtest2 t2 where t1.c1 = t2.c1));


--echo Outer Join Elimination 的改动

select distinct t1.* from lyqtest1 t1 left join lyqtest2 t2 on t1.c1 = t2.c1;
explain basic  select distinct t1.* from lyqtest1 t1 left join lyqtest2 t2 on t1.c1 = t2.c1;
explain basic  select /*+ NO_REWRITE */ distinct t1.* from lyqtest1 t1 left join lyqtest2 t2 on t1.c1 = t2.c1;

--echo 本层有重复值不敏感聚合

select max(t1.c1) from lyqtest1 t1 left join lyqtest2 t2 on t1.c1 = t2.c1;
explain basic  select max(t1.c1) from lyqtest1 t1 left join lyqtest2 t2 on t1.c1 = t2.c1;
explain basic  select /*+ NO_REWRITE */ max(t1.c1) from lyqtest1 t1 left join lyqtest2 t2 on t1.c1 = t2.c1;

select avg(t1.c1) from lyqtest1 t1 left join lyqtest2 t2 on t1.c1 = t2.c1;
explain basic select avg(t1.c1) from lyqtest1 t1 left join lyqtest2 t2 on t1.c1 = t2.c1;


--echo 上层有 Distinct
select distinct t3.c1 from lyqtest3 t3,(select t1.* from lyqtest1 t1 left join lyqtest2 t2 on t1.c1 = t2.c1) vvvv1;
explain basic  select distinct t3.c1 from lyqtest3 t3,(select t1.* from lyqtest1 t1 left join lyqtest2 t2 on t1.c1 = t2.c1) vvvv1;
explain basic  select /*+ NO_REWRITE */ distinct t3.c1 from lyqtest3 t3,(select /*+ NO_REWRITE */ t1.* from lyqtest1 t1 left join lyqtest2 t2 on t1.c1 = t2.c1) vvvv1;

--echo 组合
select distinct t3.c1 from lyqtest3 t3,(select distinct t1.* from lyqtest1 t1 left join lyqtest2 t2 on t1.c1 = t2.c1) vvvv1 order by 1;
explain basic select distinct t3.c1 from lyqtest3 t3,(select distinct t1.* from lyqtest1 t1 left join lyqtest2 t2 on t1.c1 = t2.c1) vvvv1 order by 1;

select  max(t3.c1) from lyqtest3 t3,(select t1.* from lyqtest1 t1 left join lyqtest2 t2 on t1.c1 = t2.c1) vvvv1;
explain basic  select  max(t3.c1) from lyqtest3 t3,(select t1.* from lyqtest1 t1 left join lyqtest2 t2 on t1.c1 = t2.c1) vvvv1;

select  max(t3.c1) from lyqtest3 t3,(select distinct t1.* from lyqtest1 t1 left join lyqtest2 t2 on t1.c1 = t2.c1) vvvv1;
explain basic  select  max(t3.c1) from lyqtest3 t3,(select distinct t1.* from lyqtest1 t1 left join lyqtest2 t2 on t1.c1 = t2.c1) vvvv1;

select  max(t3.c1) from (select distinct max(view1.c1) c1 from lyqtest3,(select distinct max(c1) c1 from lyqtest1 t1 where exists (select 1 from lyqtest2 t2 where t1.c1 = t2.c1)) view1) t3,(select distinct t1.* from lyqtest1 t1 left join lyqtest2 t2 on t1.c1 = t2.c1) vvvv1;
explain basic  select  max(t3.c1) from (select distinct max(view1.c1) c1 from lyqtest3,(select distinct max(c1) c1 from lyqtest1 t1 where exists (select 1 from lyqtest2 t2 where t1.c1 = t2.c1)) view1) t3,(select distinct t1.* from lyqtest1 t1 left join lyqtest2 t2 on t1.c1 = t2.c1) vvvv1;

select  max(t3.c1) from lyqtest3 t3,(select t1.* from lyqtest1 t1 left join lyqtest2 t2 on t1.c1 = t2.c1) vvvv1
union
select distinct max(view1.c1) from lyqtest3,(select distinct max(c1) c1 from lyqtest1 t1 where exists (select 1 from lyqtest2 t2 where t1.c1 = t2.c1)) view1 order by 1;
explain basic select  max(t3.c1) from lyqtest3 t3,(select t1.* from lyqtest1 t1 left join lyqtest2 t2 on t1.c1 = t2.c1) vvvv1
union
select distinct max(view1.c1) from lyqtest3,(select distinct max(c1) c1 from lyqtest1 t1 where exists (select 1 from lyqtest2 t2 where t1.c1 = t2.c1)) view1 order by 1;

select  max(t3.c1) from lyqtest3 t3,v_left_outer
union
select distinct max(v_semi.c1) from lyqtest3,v_semi order by 1;
explain basic select  max(t3.c1) from lyqtest3 t3,v_left_outer
union
select distinct max(v_semi.c1) from lyqtest3,v_semi order by 1;


