result_format: 4
purge recyclebin;
drop table if exists lyqtest1;
CREATE TABLE lyqtest1 (
    c1 INT,
    c2 VARCHAR(255),
    c3 DATETIME,
    c4 FLOAT,
    c5 VARCHAR(255),
    c6 DATE,
    INDEX idx_c1_c2_c3 (c1, c2, c3),
    INDEX idx_t1_c1 (c1)
);
INSERT INTO lyqtest1 (c1, c2, c3, c4, c5, c6) VALUES
(1, 'example1', '2023-10-01 12:00:00', 10.5, 'data1', '2023-10-01');
INSERT INTO lyqtest1 (c1, c2, c3, c4, c5, c6) VALUES
(2, null, '2023-11-01 13:00:00', 20.5, 'data2', '2023-11-01');
INSERT INTO lyqtest1 (c1, c2, c3, c4, c5, c6) VALUES
(3, 'example3', '2023-12-01 14:00:00', 30.5, 'data3', '2023-12-01');
drop table lyqtest2;
CREATE TABLE lyqtest2 (
    c1 INT,
    c2 VARCHAR(255),
    c3 DATETIME,
    c4 FLOAT,
    c5 VARCHAR(255),
    c6 DATE,
    INDEX idx_c1 (c1),
    INDEX idx_c2 (c2),
    INDEX idx_c5 (c5)
) 
PARTITION BY RANGE (YEAR(c6)) (
    PARTITION p2020 VALUES LESS THAN (2021),
    PARTITION p2021 VALUES LESS THAN (2022),
    PARTITION p2022 VALUES LESS THAN (2023),
    PARTITION p2023 VALUES LESS THAN MAXVALUE
);
INSERT INTO lyqtest2 (c1, c2, c3, c4, c5, c6) VALUES
(1, 'example1', '2023-09-01 15:00:00', 40.5, 'data4', '2023-09-01');
INSERT INTO lyqtest2 (c1, c2, c3, c4, c5, c6) VALUES
(2, 'example2', '2023-08-01 16:00:00', 50.5, 'data5', '2023-08-01');
INSERT INTO lyqtest2 (c1, c2, c3, c4, c5, c6) VALUES
(null, 'example6', '2023-07-01 17:00:00', 60.5, 'data6', '2023-07-01');
drop table lyqtest3;
CREATE TABLE lyqtest3 AS SELECT * FROM lyqtest2;
union
UNION DISTINCT 算子下面直接接着 PX COORDINATOR 或者 EXCHANGE 的情况，会在 EXCHANGE 下面分配一个 DISTINCT
会下推
select c1 from lyqtest1 union select c1 from lyqtest2;
+------+
| c1   |
+------+
|    1 |
|    2 |
|    3 |
| NULL |
+------+
explain basic select c1 from lyqtest1 union select c1 from lyqtest2;
Query Plan
=========================================================
|ID|OPERATOR                     |NAME                  |
---------------------------------------------------------
|0 |HASH UNION DISTINCT          |                      |
|1 |├─TABLE FULL SCAN            |lyqtest1(idx_c1_c2_c3)|
|2 |└─PX COORDINATOR             |                      |
|3 |  └─EXCHANGE OUT DISTR       |:EX10000              |
|4 |    └─HASH DISTINCT          |                      |
|5 |      └─PX PARTITION ITERATOR|                      |
|6 |        └─TABLE FULL SCAN    |lyqtest2(idx_c1)      |
=========================================================
Outputs & filters:
-------------------------------------
  0 - output([UNION([1])]), filter(nil), rowset=16
  1 - output([lyqtest1.c1]), filter(nil), rowset=16
      access([lyqtest1.c1]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([lyqtest1.c1], [lyqtest1.c2], [lyqtest1.c3], [lyqtest1.__pk_increment]), range(MIN,MIN,MIN,MIN ; MAX,MAX,MAX,MAX)always true
  2 - output([lyqtest2.c1]), filter(nil), rowset=16
  3 - output([lyqtest2.c1]), filter(nil), rowset=16
      dop=1
  4 - output([lyqtest2.c1]), filter(nil), rowset=16
      distinct([lyqtest2.c1])
  5 - output([lyqtest2.c1]), filter(nil), rowset=16
      force partition granule
  6 - output([lyqtest2.c1]), filter(nil), rowset=16
      access([lyqtest2.c1]), partitions(p[0-3])
      is_index_back=false, is_global_index=false, 
      range_key([lyqtest2.c1], [lyqtest2.__pk_increment]), range(MIN,MIN ; MAX,MAX)always true
SELECT c5, LENGTH(c2) AS len_c2 FROM lyqtest2 WHERE c4 > 100.0 AND c2 IS NOT NULL
UNION
SELECT c5, LENGTH(c2) FROM lyqtest3 WHERE c1 < 10;
+-------+--------+
| c5    | len_c2 |
+-------+--------+
| data4 |      8 |
| data5 |      8 |
+-------+--------+
explain basic SELECT c5, LENGTH(c2) AS len_c2 FROM lyqtest2 WHERE c4 > 100.0 AND c2 IS NOT NULL
UNION
SELECT c5, LENGTH(c2) FROM lyqtest3 WHERE c1 < 10;
