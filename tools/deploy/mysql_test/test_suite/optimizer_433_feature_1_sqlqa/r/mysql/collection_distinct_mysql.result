      access([lyqtest2.c4], [lyqtest2.c2], [lyqtest2.c5]), partitions(p[0-3])
      is_index_back=false, is_global_index=false, filter_before_indexback[false,false], 
      range_key([lyqtest2.__pk_increment]), range(MIN ; MAX)always true
  6 - output([lyqtest3.c5], [LENGTH(lyqtest3.c2)]), filter([lyqtest3.c1 < 10]), rowset=16
      access([lyqtest3.c1], [lyqtest3.c5], [lyqtest3.c2]), partitions(p0)
