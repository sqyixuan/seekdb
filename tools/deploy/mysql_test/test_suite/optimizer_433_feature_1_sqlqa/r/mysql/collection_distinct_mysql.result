SELECT c1, c2, CASE  WHEN c1 > 100 THEN 'High' ELSE 'Low' END AS c1_category FROM lyqtest1 WHERE c2 IS NOT NULL
UNION
SELECT c1, c2, CASE WHEN c1 > 100 THEN 'High' ELSE 'Low' END AS c1_category FROM lyqtest2 WHERE c2 IS NOT NULL;
+------+----------+-------------+
| c1   | c2       | c1_category |
+------+----------+-------------+
|    1 | example1 | Low         |
|    3 | example3 | Low         |
|    2 | example2 | Low         |
| NULL | example6 | Low         |
+------+----------+-------------+
