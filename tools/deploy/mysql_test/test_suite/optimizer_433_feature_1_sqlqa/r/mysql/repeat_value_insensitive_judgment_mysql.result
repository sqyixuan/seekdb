result_format: 4
purge recyclebin;
重复值不敏感判定
drop table lyqtest1;
CREATE TABLE lyqtest1 (
    c1 INT,
    c2 VARCHAR(255),
    c3 DATETIME,
    c4 FLOAT,
    c5 VARCHAR(255),
    c6 DATE,
    INDEX idx_c1_c2_c3 (c1, c2, c3),
    INDEX idx_t1_c1 (c1)
);
INSERT INTO lyqtest1 (c1, c2, c3, c4, c5, c6) VALUES
(1, 'example1', '2023-10-01 12:00:00', 10.5, 'data1', '2023-10-01');
INSERT INTO lyqtest1 (c1, c2, c3, c4, c5, c6) VALUES
(2, null, '2023-11-01 13:00:00', 20.5, 'data2', '2023-11-01');
INSERT INTO lyqtest1 (c1, c2, c3, c4, c5, c6) VALUES
(3, 'example3', '2023-12-01 14:00:00', 30.5, 'data3', '2023-12-01');
drop table lyqtest2;
CREATE TABLE lyqtest2 (
    c1 INT,
    c2 VARCHAR(255),
    c3 DATETIME,
    c4 FLOAT,
    c5 VARCHAR(255),
    c6 DATE,
    INDEX idx_c1 (c1),
    INDEX idx_c2 (c2),
    INDEX idx_c5 (c5)
) 
PARTITION BY RANGE (YEAR(c6)) (
    PARTITION p2020 VALUES LESS THAN (2021),
    PARTITION p2021 VALUES LESS THAN (2022),
    PARTITION p2022 VALUES LESS THAN (2023),
    PARTITION p2023 VALUES LESS THAN MAXVALUE
);
INSERT INTO lyqtest2 (c1, c2, c3, c4, c5, c6) VALUES
(1, 'example1', '2023-09-01 15:00:00', 40.5, 'data4', '2023-09-01');
INSERT INTO lyqtest2 (c1, c2, c3, c4, c5, c6) VALUES
(2, 'example2', '2023-08-01 16:00:00', 50.5, 'data5', '2023-08-01');
INSERT INTO lyqtest2 (c1, c2, c3, c4, c5, c6) VALUES
(null, 'example6', '2023-07-01 17:00:00', 60.5, 'data6', '2023-07-01');
drop table lyqtest3;
CREATE TABLE lyqtest3 AS SELECT * FROM lyqtest2;
drop view v_left_outer;
create view v_left_outer as (select distinct t1.* from lyqtest1 t1 left outer join lyqtest2 t2 on t1.c1 = t2.c1);
drop view v_semi;
create view v_semi as (select * from lyqtest1 t1 where exists (select 1 from lyqtest2 t2 where t1.c1 = t2.c1));
Semi To Inner 的改动
位于上层 Semi 右表
select distinct view1.c1 from (select c1 from lyqtest1 t1 where exists (select 1 from lyqtest2 t2 where t1.c1 = t2.c1)) view1;
+------+
| c1   |
+------+
|    1 |
|    2 |
+------+
select distinct c1 from (select t1.c1 from lyqtest1 t1 inner join lyqtest2 t2 on t1.c1 = t2.c1) view1;
+------+
| c1   |
+------+
|    1 |
|    2 |
+------+
explain basic select distinct view1.c1 from (select c1 from lyqtest1 t1 where exists (select 1 from lyqtest2 t2 where t1.c1 = t2.c1)) view1;
Query Plan
===================================================
|ID|OPERATOR                     |NAME            |
---------------------------------------------------
|0 |HASH DISTINCT                |                |
|1 |└─HASH JOIN                  |                |
|2 |  ├─TABLE FULL SCAN          |t1(idx_c1_c2_c3)|
|3 |  └─PX COORDINATOR           |                |
|4 |    └─EXCHANGE OUT DISTR     |:EX10000        |
|5 |      └─PX PARTITION ITERATOR|                |
|6 |        └─TABLE FULL SCAN    |t2(idx_c1)      |
===================================================
Outputs & filters:
-------------------------------------
  0 - output([t1.c1]), filter(nil), rowset=16
      distinct([t1.c1])
  1 - output([t1.c1]), filter(nil), rowset=16
      equal_conds([t1.c1 = t2.c1]), other_conds(nil)
  2 - output([t1.c1]), filter(nil), rowset=16
      access([t1.c1]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t1.c1], [t1.c2], [t1.c3], [t1.__pk_increment]), range(MIN,MIN,MIN,MIN ; MAX,MAX,MAX,MAX)always true
  3 - output([t2.c1]), filter(nil), rowset=16
  4 - output([t2.c1]), filter(nil), rowset=16
      dop=1
  5 - output([t2.c1]), filter(nil), rowset=16
      force partition granule
  6 - output([t2.c1]), filter(nil), rowset=16
      access([t2.c1]), partitions(p[0-3])
      is_index_back=false, is_global_index=false, 
      range_key([t2.c1], [t2.__pk_increment]), range(MIN,MIN ; MAX,MAX)always true
explain basic select distinct c1 from (select t1.c1 from lyqtest1 t1 inner join lyqtest2 t2 on t1.c1 = t2.c1) view1;
