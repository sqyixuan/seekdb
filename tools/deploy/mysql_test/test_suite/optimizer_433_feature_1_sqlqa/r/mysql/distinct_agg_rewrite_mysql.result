result_format: 4
purge recyclebin;
drop table lyqtest1;
CREATE TABLE lyqtest1 (
    c1 INT,
    c2 VARCHAR(255),
    c3 DATETIME,
    c4 FLOAT,
    c5 VARCHAR(255),
    c6 DATE,
    INDEX idx_c1_c2_c3 (c1, c2, c3),
    INDEX idx_t1_c1 (c1)
);
INSERT INTO lyqtest1 (c1, c2, c3, c4, c5, c6) VALUES
(1, 'example1', '2023-10-01 12:00:00', 10.5, 'data1', '2023-10-01');
INSERT INTO lyqtest1 (c1, c2, c3, c4, c5, c6) VALUES
(2, null, '2023-11-01 13:00:00', 20.5, 'data2', '2023-11-01');
INSERT INTO lyqtest1 (c1, c2, c3, c4, c5, c6) VALUES
(3, 'example3', '2023-12-01 14:00:00', 30.5, 'data3', '2023-12-01');
drop table lyqtest2;
CREATE TABLE lyqtest2 (
    c1 INT,
    c2 VARCHAR(255),
    c3 DATETIME,
    c4 FLOAT,
    c5 VARCHAR(255),
    c6 DATE,
    INDEX idx_c1 (c1),
    INDEX idx_c2 (c2),
    INDEX idx_c5 (c5)
) 
PARTITION BY RANGE (YEAR(c6)) (
    PARTITION p2020 VALUES LESS THAN (2021),
    PARTITION p2021 VALUES LESS THAN (2022),
    PARTITION p2022 VALUES LESS THAN (2023),
    PARTITION p2023 VALUES LESS THAN MAXVALUE
);
INSERT INTO lyqtest2 (c1, c2, c3, c4, c5, c6) VALUES
(1, 'example1', '2023-09-01 15:00:00', 40.5, 'data4', '2023-09-01');
INSERT INTO lyqtest2 (c1, c2, c3, c4, c5, c6) VALUES
(2, 'example2', '2023-08-01 16:00:00', 50.5, 'data5', '2023-08-01');
INSERT INTO lyqtest2 (c1, c2, c3, c4, c5, c6) VALUES
(null, 'example6', '2023-07-01 17:00:00', 60.5, 'data6', '2023-07-01');
drop table lyqtest3;
CREATE TABLE lyqtest3 AS SELECT * FROM lyqtest2;
只有一个聚合函数有 distinct 或者 distinct 聚合函数 distinct 的都是同一列的情况下，是不需要 dup 数据的，可以去掉一个阶段
select count(distinct c1), sum(distinct c1), sum(c4) from lyqtest1 group by c2 order by 1,2;
+--------------------+------------------+---------+
| count(distinct c1) | sum(distinct c1) | sum(c4) |
+--------------------+------------------+---------+
|                  1 |                1 |    10.5 |
|                  1 |                2 |    20.5 |
|                  1 |                3 |    30.5 |
+--------------------+------------------+---------+
explain basic select count(distinct c1), sum(distinct c1), sum(c4) from lyqtest1 group by c2 order by 1,2;
Query Plan
=====================================
|ID|OPERATOR               |NAME    |
-------------------------------------
|0 |SORT                   |        |
|1 |└─HASH GROUP BY        |        |
|2 |  └─SUBPLAN SCAN       |VIEW1   |
|3 |    └─HASH GROUP BY    |        |
|4 |      └─TABLE FULL SCAN|lyqtest1|
=====================================
Outputs & filters:
-------------------------------------
  0 - output([T_FUN_COUNT(VIEW1.lyqtest1.c1)], [T_FUN_SUM(VIEW1.lyqtest1.c1)], [T_FUN_SUM(VIEW1.T_FUN_SUM(cast(lyqtest1.c4, DOUBLE(-1, -1))))]), filter(nil), rowset=16
      sort_keys([T_FUN_COUNT(VIEW1.lyqtest1.c1), ASC], [T_FUN_SUM(VIEW1.lyqtest1.c1), ASC])
  1 - output([T_FUN_COUNT(VIEW1.lyqtest1.c1)], [T_FUN_SUM(VIEW1.lyqtest1.c1)], [T_FUN_SUM(VIEW1.T_FUN_SUM(cast(lyqtest1.c4, DOUBLE(-1, -1))))]), filter(nil), rowset=16
      group([VIEW1.lyqtest1.c2]), agg_func([T_FUN_SUM(VIEW1.T_FUN_SUM(cast(lyqtest1.c4, DOUBLE(-1, -1))))], [T_FUN_COUNT(VIEW1.lyqtest1.c1)], [T_FUN_SUM(VIEW1.lyqtest1.c1)])
  2 - output([VIEW1.T_FUN_SUM(cast(lyqtest1.c4, DOUBLE(-1, -1)))], [VIEW1.lyqtest1.c1], [VIEW1.lyqtest1.c2]), filter(nil), rowset=16
      access([VIEW1.T_FUN_SUM(cast(lyqtest1.c4, DOUBLE(-1, -1)))], [VIEW1.lyqtest1.c1], [VIEW1.lyqtest1.c2])
  3 - output([T_FUN_SUM(cast(lyqtest1.c4, DOUBLE(-1, -1)))], [lyqtest1.c1], [lyqtest1.c2]), filter(nil), rowset=16
      group([lyqtest1.c2], [lyqtest1.c1]), agg_func([T_FUN_SUM(cast(lyqtest1.c4, DOUBLE(-1, -1)))])
  4 - output([lyqtest1.c1], [lyqtest1.c4], [lyqtest1.c2]), filter(nil), rowset=16
      access([lyqtest1.c1], [lyqtest1.c4], [lyqtest1.c2]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([lyqtest1.__pk_increment]), range(MIN ; MAX)always true
