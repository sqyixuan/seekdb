--echo select语句，区间比较的查询条件  exists ,all, any
--echo 不会裁剪  含有子查询的表达式不会用于分区裁剪
select id,int_col,small_int_col from lyq_test3 where exists (select id,int_col,small_int_col from lyq_test3 where int_col > 3) order by 1,2;
explain basic select id,int_col,small_int_col from lyq_test3 where exists (select id,int_col,small_int_col from lyq_test3 where int_col > 3) order by 1,2;
select id,int_col,small_int_col from lyq_test3 where int_col + 1 >= (select int_col from lyq_test3 where small_int_col >= 7 ) order by 1,2;
explain basic select id,int_col,small_int_col from lyq_test3 where int_col + 1 >= (select int_col from lyq_test3 where small_int_col >= 7 ) order by 1,2;


--echo select语句，区间比较的查询条件 between...and, >, in ，not in <,  >=, <= ,<> ,!=
--echo 可以裁剪
select id,int_col,small_int_col from lyq_test3 where int_col = 3 order by 1,2;
explain basic select id,int_col,small_int_col from lyq_test3 where int_col = 3 order by 1,2;
select id,int_col,small_int_col from lyq_test3 where int_col > 3 order by 1,2;
explain basic select id,int_col,small_int_col from lyq_test3 where int_col > 3 order by 1,2;
select id,int_col,small_int_col from lyq_test3 where small_int_col > 3 order by 1,2;
explain basic select id,int_col,small_int_col from lyq_test3 where small_int_col > 3 order by 1,2;
select id,int_col,small_int_col from lyq_test3 where int_col >= 4 and id <= 3 order by 1,2;
explain basic select id,int_col,small_int_col from lyq_test3 where int_col >= 4 and id <= 3 order by 1,2;
select id,int_col,small_int_col from lyq_test3 where int_col >= 4 and small_int_col <= 3 order by 1,2;
explain basic select id,int_col,small_int_col from lyq_test3 where int_col >= 4 and small_int_col <= 3 order by 1,2;
select small_int_col from lyq_test3 group by small_int_col having small_int_col <> 5 order by 1;
explain basic select small_int_col from lyq_test3 group by small_int_col having small_int_col <> 5 order by 1;
select small_int_col from lyq_test3 where int_col < 1 group by small_int_col having small_int_col < 1 order by 1;
explain basic select small_int_col from lyq_test3 where int_col < 1 group by small_int_col having small_int_col < 1 order by 1;
select id,int_col,small_int_col from lyq_test3 where int_col between 4 and 6 order by 1,2;
explain basic select id,int_col,small_int_col from lyq_test3 where int_col between 4 and 6 order by 1,2;
select id,int_col,small_int_col from lyq_test3 where int_col in (1,3,null) order by 1,2;
explain basic select id,int_col,small_int_col from lyq_test3 where int_col in (1,3,null) order by 1,2;
select id,int_col,small_int_col from lyq_test3 where small_int_col not in (2,5) order by 1,2;
explain basic select id,int_col,small_int_col from lyq_test3 where small_int_col not in (2,5) order by 1,2;

--echo 不裁剪 可以分区裁剪的条件是分区表达式中只包含分区键  裁剪二级分区的时候只能用到只包含二级分区键的条件
select id,int_col,small_int_col from lyq_test3 where (int_col between 4 and 100 ) or small_int_col > 5 order by 1,2;
explain basic select id,int_col,small_int_col from lyq_test3 where (int_col between 4 and 100 ) or small_int_col > 5 order by 1,2;

--echo 有null，不能查询出结果
select id,int_col,small_int_col from lyq_test3 where small_int_col not in (2,5,null) order by 1,2;
explain basic select id,int_col,small_int_col from lyq_test3 where small_int_col not in (2,5,null) order by 1,2;

--echo 复杂查询(c1,c2) > (1,2)、c1 + c2 < 1、func(c1) < 1
--echo (c1,c2) > (1,2)  c1 + c2 < 1 不裁剪 可以分区裁剪的条件是分区表达式中只包含分区键  裁剪二级分区的时候只能用到只包含二级分区键的条件
select id,int_col,small_int_col from lyq_test3 where (int_col, small_int_col) < ( 6 , 5) order by 1,2;
explain basic select id,int_col,small_int_col from lyq_test3 where (int_col, small_int_col) < ( 6 , 5) order by 1,2;
select id,int_col,small_int_col from lyq_test3 where (int_col, tiny_int_col) < ( 6 , 30) order by 1,2;
explain basic select id,int_col,small_int_col from lyq_test3 where (int_col, tiny_int_col) < ( 6 , 30) order by 1,2;
select id,int_col,small_int_col from lyq_test3 where int_col + tiny_int_col < 44 order by 1,2;
explain basic select id,int_col,small_int_col from lyq_test3 where int_col + tiny_int_col < 44 order by 1,2;

--echo func(c1) < 1
--echo 不裁剪
select id,int_col,small_int_col from lyq_test3 where POW(int_col, small_int_col) > 243 order by 1,2;
explain basic select id,int_col,small_int_col from lyq_test3 where POW(int_col, small_int_col) > 243 order by 1,2;
--echo 会裁剪
select id,int_col,small_int_col from lyq_test3 where POW(int_col, 2) > 9 order by 1,2;
explain basic select id,int_col,small_int_col from lyq_test3 where POW(int_col, 2) > 9 order by 1,2;
select id,int_col,small_int_col from lyq_test3 where SIN(small_int_col) > 0 order by 1,2;
explain basic select id,int_col,small_int_col from lyq_test3 where SIN(small_int_col) > 0 order by 1,2;

--echo dml语句
update lyq_test3 set tiny_int_col = 11 where int_col > 3;
explain basic update lyq_test3 set tiny_int_col = 11 where int_col > 3;
select id,tiny_int_col,int_col,small_int_col from lyq_test3;
update lyq_test3 set tiny_int_col = 22 where int_col > 3 and small_int_col > 5;
explain basic update lyq_test3 set tiny_int_col = 22 where int_col > 3 and small_int_col > 5;
select id,tiny_int_col,int_col,small_int_col from lyq_test3;

--echo 一级分区是hash分区，二级分区是list
--echo  非模版化 hash + list 二级分区表  分区键函数 不存在default 分区
--error 0,1051
drop table lyq_test4;
CREATE TABLE lyq_test4 (
    id INT,
    tiny_int_col TINYINT,
    small_int_col SMALLINT,
    int_col INT,
    date_col DATE,
    datetime_col DATETIME,
    char_col CHAR(10),
    varchar_col VARCHAR(255),
    binary_col BINARY(16)
) PARTITION BY hash (small_int_col)
       SUBPARTITION BY list (floor(int_col))
       (PARTITION p0
		(SUBPARTITION sp0 VALUES in (1,2), 
         SUBPARTITION sp1 VALUES in (3,4), 
         SUBPARTITION sp2 VALUES in (5,6,7,8,9)),
        PARTITION p1
         (SUBPARTITION sp3 VALUES in (1,2), 
         SUBPARTITION sp4 VALUES in (3,4), 
         SUBPARTITION sp5 VALUES in (5,6,7,8,9)),
        PARTITION p2
		 (SUBPARTITION sp6 VALUES in (1,2), 
         SUBPARTITION sp7 VALUES in (3,4), 
         SUBPARTITION sp8 VALUES in (5,6,7,8,9))
        );

