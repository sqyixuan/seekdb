--echo inner join 
--echo 分区裁剪条件放在on中
--echo ****** 分区裁剪条件包含主/副表分区键   (两个表都走分区裁剪)
select t1.id, t1.int_col,t2.small_int_col from lyq_test t1 inner join lyq_test2 t2 on t1.id = t2.id and t1.int_col < 3 and t2.small_int_col < 8;
explain basic select t1.id, t1.int_col,t2.small_int_col from lyq_test t1 inner join lyq_test2 t2 on t1.id = t2.id and t1.int_col < 3 and t2.small_int_col < 8;

--echo ****** 分区裁剪条件只包含主表分区键 只主表裁剪
select t1.id, t1.int_col,t2.small_int_col from lyq_test t1 inner join lyq_test2 t2 on t1.id = t2.id and t1.int_col < 3;
explain basic select t1.id, t1.int_col,t2.small_int_col from lyq_test t1 inner join lyq_test2 t2 on t1.id = t2.id and t1.int_col < 3;

--echo ****** 分区裁剪条件只包含副表分区键 只副表裁剪
select t1.id, t1.int_col,t2.small_int_col from lyq_test t1 inner join lyq_test2 t2 on t1.id = t2.id and t2.small_int_col < 8;
explain basic select t1.id, t1.int_col,t2.small_int_col from lyq_test t1 inner join lyq_test2 t2 on t1.id = t2.id and t2.small_int_col < 8;

--echo ******  (分区裁剪条件放在where中)
--echo ****** 分区裁剪条件包含主/副表分区键  (两个表都走分区裁剪)
select t1.id, t1.int_col,t2.small_int_col from lyq_test t1 inner join lyq_test2 t2 on t1.id = t2.id where t1.int_col < 3 and t2.small_int_col < 8;
explain basic select t1.id, t1.int_col,t2.small_int_col from lyq_test t1 inner join lyq_test2 t2 on t1.id = t2.id where t1.int_col < 3 and t2.small_int_col < 8;

--echo ****** 分区裁剪条件只包含主表分区键 主表裁剪
select t1.id, t1.int_col,t2.small_int_col from lyq_test t1 inner join lyq_test2 t2 on t1.id = t2.id where t1.int_col < 3;
explain basic select t1.id, t1.int_col,t2.small_int_col from lyq_test t1 inner join lyq_test2 t2 on t1.id = t2.id where t1.int_col < 3;

--echo ****** 分区裁剪条件只包含副表分区键 副表裁剪
select t1.id, t1.int_col,t2.small_int_col from lyq_test t1 inner join lyq_test2 t2 on t1.id = t2.id where t2.small_int_col < 8;
explain basic select t1.id, t1.int_col,t2.small_int_col from lyq_test t1 inner join lyq_test2 t2 on t1.id = t2.id where t2.small_int_col < 8;

--echo left outer join 
--echo ******  (分区裁剪条件放在on中)
--echo ****** 分区裁剪条件包含主/副表分区键 主表未裁剪，  副表裁剪
select t1.id, t1.int_col,t2.small_int_col from lyq_test t1 left outer join  lyq_test2 t2 on t1.id = t2.id and t1.int_col < 3 and t2.small_int_col < 8;
explain basic select t1.id, t1.int_col,t2.small_int_col from lyq_test t1 left outer join  lyq_test2 t2 on t1.id = t2.id and t1.int_col < 3 and t2.small_int_col < 8;

--echo ****** 分区裁剪条件只包含主表分区键 不裁剪
select t1.id, t1.int_col,t2.small_int_col from lyq_test t1 left outer join  lyq_test2 t2 on t1.id = t2.id and t1.int_col < 3 ;
explain basic select t1.id, t1.int_col,t2.small_int_col from lyq_test t1 left outer join  lyq_test2 t2 on t1.id = t2.id and t1.int_col < 3;

--echo ****** 分区裁剪条件只包含副表分区键 副表裁剪
select t1.id, t1.int_col,t2.small_int_col from lyq_test t1 left outer join  lyq_test2 t2 on t1.id = t2.id and t2.small_int_col < 8;
explain basic select t1.id, t1.int_col,t2.small_int_col from lyq_test t1 left outer join  lyq_test2 t2 on t1.id = t2.id and t2.small_int_col < 8;

--echo ****** (分区裁剪条件放在where中)
--echo ****** 分区裁剪条件包含主/副表分区键 (两个表都走分区裁剪)
select t1.id, t1.int_col,t2.small_int_col from lyq_test t1 left outer join  lyq_test2 t2 on t1.id = t2.id where t1.int_col < 3 and t2.small_int_col < 8;
explain basic select t1.id, t1.int_col,t2.small_int_col from lyq_test t1 left outer join  lyq_test2 t2 on t1.id = t2.id where t1.int_col < 3 and t2.small_int_col < 8;

--echo ****** 分区裁剪条件只包含主表分区键 主表裁剪
select t1.id, t1.int_col,t2.small_int_col from lyq_test t1 left outer join  lyq_test2 t2 on t1.id = t2.id where t1.int_col < 3;
explain basic select t1.id, t1.int_col,t2.small_int_col from lyq_test t1 left outer join  lyq_test2 t2 on t1.id = t2.id where t1.int_col < 3;

--echo ****** 分区裁剪条件只包含副表分区键 副表裁剪
select t1.id, t1.int_col,t2.small_int_col from lyq_test t1 left outer join  lyq_test2 t2 on t1.id = t2.id where t2.small_int_col < 8;
explain basic select t1.id, t1.int_col,t2.small_int_col from lyq_test t1 left outer join  lyq_test2 t2 on t1.id = t2.id where t2.small_int_col < 8;

--echo right outer join 
--echo ****** (分区裁剪条件放在on中)
--echo ****** 分区裁剪条件包含主/副表分区键 左表裁剪，右表未裁剪
select t1.id, t1.int_col,t2.small_int_col from lyq_test t1 right outer join  lyq_test2 t2 on t1.id = t2.id and t1.int_col < 3 and t2.small_int_col < 8;
explain basic select t1.id, t1.int_col,t2.small_int_col from lyq_test t1 right outer join  lyq_test2 t2 on t1.id = t2.id and t1.int_col < 3 and t2.small_int_col < 8;

--echo ****** 分区裁剪条件只包含主表分区键 左表裁剪，右表未裁剪
select t1.id, t1.int_col,t2.small_int_col from lyq_test t1 right outer join  lyq_test2 t2 on t1.id = t2.id and t1.int_col < 3;
explain basic select t1.id, t1.int_col,t2.small_int_col from lyq_test t1 right outer join  lyq_test2 t2 on t1.id = t2.id and t1.int_col < 3;

--echo ****** 分区裁剪条件只包含副表分区键 都不裁剪
select t1.id, t1.int_col,t2.small_int_col from lyq_test t1 right outer join  lyq_test2 t2 on t1.id = t2.id and t2.small_int_col < 8;
explain basic select t1.id, t1.int_col,t2.small_int_col from lyq_test t1 right outer join  lyq_test2 t2 on t1.id = t2.id and t2.small_int_col < 8;

--echo ****** (分区裁剪条件放在where中)
--echo ****** 分区裁剪条件包含主/副表分区键 都裁剪
select t1.id, t1.int_col,t2.small_int_col from lyq_test t1 right outer join  lyq_test2 t2 on t1.id = t2.id where t1.int_col < 3 and t2.small_int_col < 8;
explain basic select t1.id, t1.int_col,t2.small_int_col from lyq_test t1 right outer join  lyq_test2 t2 on t1.id = t2.id where t1.int_col < 3 and t2.small_int_col < 8;

--echo ****** 分区裁剪条件只包含主表分区键 左表裁剪，右表未裁剪
select t1.id, t1.int_col,t2.small_int_col from lyq_test t1 right outer join  lyq_test2 t2 on t1.id = t2.id where t1.int_col < 3;
explain basic select t1.id, t1.int_col,t2.small_int_col from lyq_test t1 right outer join  lyq_test2 t2 on t1.id = t2.id where t1.int_col < 3;

--echo ****** 分区裁剪条件只包含副表分区键 左表未裁剪，右表裁剪
select t1.id, t1.int_col,t2.small_int_col from lyq_test t1 right outer join  lyq_test2 t2 on t1.id = t2.id where t2.small_int_col < 8;
explain basic select t1.id, t1.int_col,t2.small_int_col from lyq_test t1 right outer join  lyq_test2 t2 on t1.id = t2.id where t2.small_int_col < 8;

--echo 一级分区是list分区，二级分区不是
--echo  非模版化 List + range 二级分区表  不存在default 分区
--error 0,1051
drop table lyq_test3;
CREATE TABLE lyq_test3 (
    id INT,
    tiny_int_col TINYINT,
    small_int_col SMALLINT,
    int_col INT,
    date_col DATE,
    datetime_col DATETIME,
    char_col CHAR(10),
    varchar_col VARCHAR(255),
    binary_col BINARY(16)
) PARTITION BY LIST (int_col)
       SUBPARTITION BY range (small_int_col)
       (PARTITION p0 VALUES in (1,3)
		(SUBPARTITION sp0 VALUES LESS THAN (3), 
         SUBPARTITION sp1 VALUES LESS THAN (6), 
         SUBPARTITION sp2 VALUES LESS THAN (9)),
        PARTITION p1 VALUES in (4,6)
         (SUBPARTITION sp3 VALUES LESS THAN (3), 
         SUBPARTITION sp4 VALUES LESS THAN (6), 
         SUBPARTITION sp5 VALUES LESS THAN (9)),
        PARTITION p2 VALUES in (7,9)
		 (SUBPARTITION sp6 VALUES LESS THAN (3), 
         SUBPARTITION sp7 VALUES LESS THAN (6), 
         SUBPARTITION sp8 VALUES LESS THAN (9))
        );
                
