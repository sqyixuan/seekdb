--echo select语句，区间比较的查询条件  exists ,all, any
--echo 不会裁剪  含有子查询的表达式不会用于分区裁剪,但子查询会裁剪
select id,char_col from lyq_test where exists (select id,char_col from lyq_test where int_col > 20) order by 1,2;
explain basic select id,char_col from lyq_test where exists (select id,char_col from lyq_test where int_col > 20) order by 1,2;
select id,char_col from lyq_test where exists (select id,char_col from lyq_test where int_col > 2 and char_col < 'G') order by 1,2;
explain basic select id,char_col from lyq_test where exists (select id,char_col from lyq_test where int_col > 2 and char_col < 'G') order by 1,2;
select id,char_col from lyq_test where int_col > (select date_col from lyq_test where int_col >= 2 and char_col = 'B') order by 1,2;
explain basic select id,char_col from lyq_test where int_col > (select date_col from lyq_test where int_col >= 2 and char_col = 'B') order by 1,2;

