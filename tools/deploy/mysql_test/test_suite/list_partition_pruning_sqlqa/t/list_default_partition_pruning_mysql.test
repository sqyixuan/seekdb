--result_format 4
purge recyclebin;

--echo  一级分区，default 联合分区键
--echo  一级分区,分区键为medium_int_col decimal_col
--error 0,1051
drop table lyq_test;
CREATE TABLE lyq_test (
    id INT AUTO_INCREMENT,
    tiny_int_col TINYINT,
    small_int_col SMALLINT,
    medium_int_col MEDIUMINT,
    int_col INT,
    big_int_col BIGINT,
    date_col DATE,
    time_col TIME,
    datetime_col DATETIME,
    char_col CHAR(10),
    varchar_col VARCHAR(255),
    binary_col BINARY(16),
    varbinary_col VARBINARY(255),
    PRIMARY KEY (id, int_col, char_col)
)
PARTITION BY LIST COLUMNS(int_col, char_col) (
    PARTITION p0 VALUES IN ((1, 'A'), (2, 'B'), (3, 'C')),
    PARTITION p1 VALUES IN ((4, 'D'), (5, 'E'), (6, 'F')),
    PARTITION p2 VALUES IN ((7, 'G'), (8, 'H'), (9, 'I')),
    PARTITION p3 VALUES IN ((10, 'J'), (11, 'K'), (12, 'L')),
    PARTITION p4 VALUES IN ((13, 'M'), (14, 'N'), (15, 'O')),
    PARTITION p5 VALUES IN ((16, 'P'), (17, 'Q'), (18, 'R')),
    PARTITION p6 VALUES IN ((19, 'S'), (20, 'T'), (21, 'U')),
    PARTITION p7 VALUES IN ((22, 'V'), (23, 'W'), (24, 'X')),
    PARTITION p8 VALUES IN ((25, 'Y'), (26, 'Z')),
    PARTITION p_default VALUES IN (DEFAULT)
);

