#owner: yibo.tyf
#owner group: 技术部-SQL-优化器
#description: 过滤条件中存在伪列场景补充
#tags:
#author: wb-lyq858317

--result_format 4
purge recyclebin;

--echo  过滤条件中存在伪列场景补充
--error 0,1051
drop table lyq_test3;
CREATE TABLE lyq_test3 (
    id INT,
    tiny_int_col TINYINT,
    small_int_col SMALLINT,
    int_col INT,
    date_col DATE,
    datetime_col DATETIME,
    char_col CHAR(10),
    varchar_col VARCHAR(255),
    binary_col BINARY(16)
) PARTITION BY LIST (int_col)
       SUBPARTITION BY range (small_int_col)
       (PARTITION p0 VALUES in (1,3)
		(SUBPARTITION sp0 VALUES LESS THAN (3), 
         SUBPARTITION sp1 VALUES LESS THAN (6), 
         SUBPARTITION sp2 VALUES LESS THAN (9)),
        PARTITION p1 VALUES in (4,6)
         (SUBPARTITION sp3 VALUES LESS THAN (3), 
         SUBPARTITION sp4 VALUES LESS THAN (6), 
         SUBPARTITION sp5 VALUES LESS THAN (9)),
        PARTITION p2 VALUES in (7,9)
		 (SUBPARTITION sp6 VALUES LESS THAN (3), 
         SUBPARTITION sp7 VALUES LESS THAN (6), 
         SUBPARTITION sp8 VALUES LESS THAN (9))
        );
                
INSERT INTO lyq_test3 (id, tiny_int_col, small_int_col, int_col, date_col, datetime_col, char_col, varchar_col, binary_col)
VALUES (1, 10, 2, 1, '2023-01-01', '2023-01-01 12:00:00', 'char10', 'varchar255', BINARY 'binary2');

