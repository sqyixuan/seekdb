VALUES (2, 20, 5, 3, '2023-02-01', '2023-02-01 13:00:00', 'char10', 'varchar255', BINARY 'binary2');

INSERT INTO lyq_test3 (id, tiny_int_col, small_int_col, int_col, date_col, datetime_col, char_col, varchar_col, binary_col)
VALUES (3, 30, 8, 7, '2023-03-01', '2023-03-01 14:00:00', 'char10', 'varchar255', BINARY 'binary2');

INSERT INTO lyq_test3 (id, tiny_int_col, small_int_col, int_col, date_col, datetime_col, char_col, varchar_col, binary_col)
VALUES (4, 40, 2, 4, '2023-04-01', '2023-04-01 15:00:00', 'char10', 'varchar255', BINARY 'binary2');

INSERT INTO lyq_test3 (id, tiny_int_col, small_int_col, int_col, date_col, datetime_col, char_col, varchar_col, binary_col)
VALUES (5, 50, 5, 6, '2023-05-01', '2023-05-01 16:00:00', 'char10', 'varchar255', BINARY 'binary2');

--echo cte

WITH RECURSIVE cte1 AS (
    SELECT id,int_col,small_int_col
    FROM lyq_test3
    WHERE int_col is null 
    UNION ALL
    SELECT e.id,e.int_col,e.small_int_col
    FROM lyq_test3 e
    INNER JOIN cte1 e2 ON e.int_col = e2.int_col
)
SELECT *
FROM cte1
WHERE small_int_col > 1;

WITH RECURSIVE cte1 AS (
    SELECT id,int_col,small_int_col
    FROM lyq_test3
    WHERE int_col < 3
    UNION ALL
    SELECT e.id,e.int_col,e.small_int_col
    FROM lyq_test3 e
    INNER JOIN cte1 e2 ON e.int_col = e2.small_int_col
)
SELECT *
FROM cte1
WHERE small_int_col > 1;

explain basic WITH RECURSIVE cte1 AS (
    SELECT id,int_col,small_int_col
    FROM lyq_test3
    WHERE int_col < 3
    UNION ALL
    SELECT e.id,e.int_col,e.small_int_col
    FROM lyq_test3 e
    INNER JOIN cte1 e2 ON e.int_col = e2.small_int_col
)
SELECT *
FROM cte1
WHERE small_int_col > 1;

--echo ORA_ROWSCN 伪列

select id,int_col,small_int_col from lyq_test3 where ORA_ROWSCN > 0 order by 1,2;
explain basic  select id,int_col,small_int_col from lyq_test3 where ORA_ROWSCN > 0 order by 1,2;

--echo 序列
--error 0,4298
drop SEQUENCE s1;
CREATE SEQUENCE s1 START WITH 1 INCREMENT BY 1 NOORDER CACHE 10000;
--error 4315
select id,int_col,small_int_col from lyq_test3 where s1.currval > 0 order by 1,2;

--error 0,1051
drop table lyq_test3;
--error 0,4298
drop SEQUENCE s1;

