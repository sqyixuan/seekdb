--result_format 4
purge recyclebin;

--echo  LIST COLUMNS一级分区，区间比较的查询条件(如 between...and, >, <,  >=, <= ,<> ,!=,  in , not in , exists
--echo  LIST COLUMNS一级分区,分区键为date_col
--error 0,1051
drop table lyq_test;
CREATE TABLE lyq_test (
    id INT AUTO_INCREMENT,
    tiny_int_col TINYINT,
    small_int_col SMALLINT,
    medium_int_col MEDIUMINT,
    int_col INT,
    big_int_col BIGINT,
    float_col FLOAT,
    double_col DOUBLE,
    decimal_col DECIMAL(10,2),
    numeric_col NUMERIC(10,2),
    date_col DATE,
    time_col TIME,
    datetime_col DATETIME,
    char_col CHAR(10),
    varchar_col VARCHAR(255),
    binary_col BINARY(16),
    varbinary_col VARBINARY(255)
) PARTITION BY LIST COLUMNS (date_col) (
    PARTITION p0 VALUES IN ('2023-01-01', '2023-01-02'),
    PARTITION p1 VALUES IN ('2023-02-01', '2023-02-02'),
    PARTITION p2 VALUES IN ('2023-03-01', '2023-03-02'),
    PARTITION p3 VALUES IN ('2023-04-01', '2023-04-02')
);

