--echo inner join 
--echo 分区裁剪条件放在on中
--echo ****** 分区裁剪条件包含主/副表分区键   (两个表都走分区裁剪)
select t1.id, t1.date_col,t2.tiny_int_col from lyq_test t1 inner join lyq_test2 t2 on t1.id = t2.id and t1.date_col < '2023-03-01' and t2.tiny_int_col > 4;
explain basic select t1.id, t1.date_col,t2.tiny_int_col from lyq_test t1 inner join lyq_test2 t2 on t1.id = t2.id and t1.date_col < '2023-03-01' and t2.tiny_int_col > 4;

--echo ****** 分区裁剪条件只包含主表分区键 (左边表 v，右边表 x)
select t1.id, t1.date_col,t2.tiny_int_col from lyq_test t1 inner join lyq_test2 t2 on t1.id = t2.id and t1.date_col < '2023-03-01';
explain basic select t1.id, t1.date_col,t2.tiny_int_col from lyq_test t1 inner join lyq_test2 t2 on t1.id = t2.id and t1.date_col < '2023-03-01';

--echo ****** 分区裁剪条件只包含副表分区键 (左边表 x，右边表 v)
select t1.id, t1.date_col,t2.tiny_int_col from lyq_test t1 inner join lyq_test2 t2 on t1.id = t2.id  and t2.tiny_int_col > 4;
explain basic select t1.id, t1.date_col,t2.tiny_int_col from lyq_test t1 inner join lyq_test2 t2 on t1.id = t2.id  and t2.tiny_int_col > 4;


--echo ******  (分区裁剪条件放在where中)
--echo ****** 分区裁剪条件包含主/副表分区键  (两个表都走分区裁剪)
select t1.id, t1.date_col,t2.tiny_int_col from lyq_test t1 inner join lyq_test2 t2 on t1.id = t2.id where t1.date_col < '2023-03-01' and t2.tiny_int_col > 4;
explain basic select t1.id, t1.date_col,t2.tiny_int_col from lyq_test t1 inner join lyq_test2 t2 on t1.id = t2.id where t1.date_col < '2023-03-01' and t2.tiny_int_col > 4;

--echo ****** 分区裁剪条件只包含主表分区键 主表裁剪
select t1.id, t1.date_col,t2.tiny_int_col from lyq_test t1 inner join lyq_test2 t2 on t1.id = t2.id where  t1.date_col < '2023-03-01';
explain basic select t1.id, t1.date_col,t2.tiny_int_col from lyq_test t1 inner join lyq_test2 t2 on t1.id = t2.id where t1.date_col < '2023-03-01';

--echo ****** 分区裁剪条件只包含副表分区键 副表裁剪
select t1.id, t1.date_col,t2.tiny_int_col from lyq_test t1 inner join lyq_test2 t2 on t1.id = t2.id  where t2.tiny_int_col > 4;
explain basic select t1.id, t1.date_col,t2.tiny_int_col from lyq_test t1 inner join lyq_test2 t2 on t1.id = t2.id  where t2.tiny_int_col > 4;

--echo left outer join 
--echo ******  (分区裁剪条件放在on中)
--echo ****** 分区裁剪条件包含主/副表分区键 主表未裁剪，  副表裁剪
select t1.id, t1.date_col,t2.tiny_int_col from lyq_test t1 left outer join lyq_test2 t2 on t1.id = t2.id and t1.date_col < '2023-03-01' and t2.tiny_int_col > 4;
explain basic select t1.id, t1.date_col,t2.tiny_int_col from lyq_test t1 left outer join lyq_test2 t2 on t1.id = t2.id and t1.date_col < '2023-03-01' and t2.tiny_int_col > 4;

--echo ****** 分区裁剪条件只包含主表分区键 不裁剪
select t1.id, t1.date_col,t2.tiny_int_col from lyq_test t1 left outer join lyq_test2 t2 on t1.id = t2.id and  t1.date_col < '2023-03-01';
explain basic select t1.id, t1.date_col,t2.tiny_int_col from lyq_test t1 left outer join lyq_test2 t2 on t1.id = t2.id and t1.date_col < '2023-03-01';

--echo ****** 分区裁剪条件只包含副表分区键 副表裁剪
select t1.id, t1.date_col,t2.tiny_int_col from lyq_test t1 left outer join lyq_test2 t2 on t1.id = t2.id  and t2.tiny_int_col > 4;
explain basic select t1.id, t1.date_col,t2.tiny_int_col from lyq_test t1 left outer join lyq_test2 t2 on t1.id = t2.id  and t2.tiny_int_col > 4;

--echo ****** (分区裁剪条件放在where中)
--echo ****** 分区裁剪条件包含主/副表分区键 (两个表都走分区裁剪)
select t1.id, t1.date_col,t2.tiny_int_col from lyq_test t1 left outer join lyq_test2 t2 on t1.id = t2.id where t1.date_col < '2023-03-01' and t2.tiny_int_col > 4;
explain basic select t1.id, t1.date_col,t2.tiny_int_col from lyq_test t1 left outer join lyq_test2 t2 on t1.id = t2.id where t1.date_col < '2023-03-01' and t2.tiny_int_col > 4;

--echo ****** 分区裁剪条件只包含主表分区键 主表裁剪
select t1.id, t1.date_col,t2.tiny_int_col from lyq_test t1 left outer join lyq_test2 t2 on t1.id = t2.id where  t1.date_col < '2023-03-01';
explain basic select t1.id, t1.date_col,t2.tiny_int_col from lyq_test t1 left outer join lyq_test2 t2 on t1.id = t2.id where t1.date_col < '2023-03-01';

--echo ****** 分区裁剪条件只包含副表分区键 副表裁剪
select t1.id, t1.date_col,t2.tiny_int_col from lyq_test t1 left outer join lyq_test2 t2 on t1.id = t2.id  where t2.tiny_int_col > 4;
explain basic select t1.id, t1.date_col,t2.tiny_int_col from lyq_test t1 left outer join lyq_test2 t2 on t1.id = t2.id  where t2.tiny_int_col > 4;

--echo right outer join 
--echo ****** (分区裁剪条件放在on中)
--echo ****** 分区裁剪条件包含主/副表分区键 左表裁剪，右表未裁剪
select t1.id, t1.date_col,t2.tiny_int_col from lyq_test t1 right outer join lyq_test2 t2 on t1.id = t2.id and t1.date_col < '2023-03-01' and t2.tiny_int_col > 4;
explain basic select t1.id, t1.date_col,t2.tiny_int_col from lyq_test t1 right outer join lyq_test2 t2 on t1.id = t2.id and t1.date_col < '2023-03-01' and t2.tiny_int_col > 4;

--echo ****** 分区裁剪条件只包含主表分区键 左表裁剪，右表未裁剪
select t1.id, t1.date_col,t2.tiny_int_col from lyq_test t1 right outer join lyq_test2 t2 on t1.id = t2.id and t1.date_col < '2023-03-01';
explain basic select t1.id, t1.date_col,t2.tiny_int_col from lyq_test t1 right outer join lyq_test2 t2 on t1.id = t2.id and t1.date_col < '2023-03-01';

--echo ****** 分区裁剪条件只包含副表分区键 都不裁剪
select t1.id, t1.date_col,t2.tiny_int_col from lyq_test t1 right outer join lyq_test2 t2 on t1.id = t2.id  and t2.tiny_int_col > 4;
explain basic select t1.id, t1.date_col,t2.tiny_int_col from lyq_test t1 right outer join lyq_test2 t2 on t1.id = t2.id  and t2.tiny_int_col > 4;


--echo ****** (分区裁剪条件放在where中)
--echo ****** 分区裁剪条件包含主/副表分区键 都裁剪
select t1.id, t1.date_col,t2.tiny_int_col from lyq_test t1 right outer join lyq_test2 t2 on t1.id = t2.id where t1.date_col < '2023-03-01' and t2.tiny_int_col > 4;
explain basic select t1.id, t1.date_col,t2.tiny_int_col from lyq_test t1 right outer join lyq_test2 t2 on t1.id = t2.id where t1.date_col < '2023-03-01' and t2.tiny_int_col > 4;

--echo ****** 分区裁剪条件只包含主表分区键 左表裁剪，右表未裁剪
select t1.id, t1.date_col,t2.tiny_int_col from lyq_test t1 right outer join lyq_test2 t2 on t1.id = t2.id where t1.date_col < '2023-03-01';
explain basic select t1.id, t1.date_col,t2.tiny_int_col from lyq_test t1 right outer join lyq_test2 t2 on t1.id = t2.id where t1.date_col < '2023-03-01';

--echo ****** 分区裁剪条件只包含副表分区键 左表未裁剪，右表裁剪
select t1.id, t1.date_col,t2.tiny_int_col from lyq_test t1 right outer join lyq_test2 t2 on t1.id = t2.id where t2.tiny_int_col > 4;
explain basic select t1.id, t1.date_col,t2.tiny_int_col from lyq_test t1 right outer join lyq_test2 t2 on t1.id = t2.id where  t2.tiny_int_col > 4;

--echo  视图
--error 0,1051
drop view v1;
CREATE VIEW v1 AS SELECT * FROM lyq_test where date_col > '2023-03-01';

SELECT * FROM v1;
explain basic SELECT * FROM v1;

SELECT * FROM v1 where date_col >= '2023-04-01';
explain basic SELECT * FROM v1 where date_col >= '2023-04-01';

--error 0,1051
drop view v2;
CREATE VIEW v2 AS select t1.id, t1.date_col,t2.tiny_int_col from lyq_test t1 inner join lyq_test2 t2 on t1.id = t2.id and t1.date_col < '2023-03-01' and t2.tiny_int_col > 4;

SELECT * FROM v2;
explain basic SELECT * FROM v2;

SELECT * FROM v2 left outer join lyq_test t1 on v2.id = t1.id where t1.date_col <= '2023-01-02' and v2.tiny_int_col >= 5;
explain basic SELECT * FROM v2 left outer join lyq_test t1 on v2.id = t1.id where t1.date_col <= '2023-01-02' and v2.tiny_int_col >= 5;



