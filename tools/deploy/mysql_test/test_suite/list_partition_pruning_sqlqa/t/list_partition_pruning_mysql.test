--echo select语句，区间比较的查询条件  exists ,all, any
--echo 不会裁剪  含有子查询的表达式不会用于分区裁剪
select id,date_col from lyq_test where exists (select id,date_col from lyq_test where date_col > '2023-02-01') limit 5;
explain basic select id,date_col from lyq_test where exists (select id,date_col from lyq_test where date_col > '2023-02-01') limit 5;
select id,date_col from lyq_test where date_col > (select date_col from lyq_test where int_col = 2000) limit 5;
explain basic select id,date_col from lyq_test where date_col > (select date_col from lyq_test where int_col = 2000) limit 5;
select id,date_col from lyq_test where date_col > any(select date_col from lyq_test) limit 5;
explain basic select id,date_col from lyq_test where date_col > any(select date_col from lyq_test) limit 5;
--echo 含有子查询的表达式不会用于分区裁剪，但子查询会裁剪
select id,date_col from lyq_test where date_col > all(select date_col from lyq_test where date_col < '2023-03-01') limit 5;
explain basic select id,date_col from lyq_test where date_col > all(select date_col from lyq_test where date_col < '2023-03-01') limit 5;

