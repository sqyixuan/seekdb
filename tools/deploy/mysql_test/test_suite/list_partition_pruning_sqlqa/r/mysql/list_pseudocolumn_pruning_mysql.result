cte
WITH RECURSIVE cte1 AS (
    SELECT id,int_col,small_int_col
    FROM lyq_test3
    WHERE int_col is null 
    UNION ALL
    SELECT e.id,e.int_col,e.small_int_col
    FROM lyq_test3 e
    INNER JOIN cte1 e2 ON e.int_col = e2.int_col
)
SELECT *
FROM cte1
WHERE small_int_col > 1;
+------+---------+---------------+
| id   | int_col | small_int_col |
+------+---------+---------------+
+------+---------+---------------+
WITH RECURSIVE cte1 AS (
    SELECT id,int_col,small_int_col
    FROM lyq_test3
    WHERE int_col < 3
    UNION ALL
    SELECT e.id,e.int_col,e.small_int_col
    FROM lyq_test3 e
    INNER JOIN cte1 e2 ON e.int_col = e2.small_int_col
)
SELECT *
FROM cte1
WHERE small_int_col > 1;
+------+---------+---------------+
| id   | int_col | small_int_col |
+------+---------+---------------+
|    1 |       1 |             2 |
+------+---------+---------------+
explain basic WITH RECURSIVE cte1 AS (
    SELECT id,int_col,small_int_col
    FROM lyq_test3
    WHERE int_col < 3
    UNION ALL
    SELECT e.id,e.int_col,e.small_int_col
    FROM lyq_test3 e
    INNER JOIN cte1 e2 ON e.int_col = e2.small_int_col
)
SELECT *
FROM cte1
WHERE small_int_col > 1;
Query Plan
================================================
|ID|OPERATOR                         |NAME     |
------------------------------------------------
|0 |SUBPLAN SCAN                     |cte1     |
|1 |└─RECURSIVE UNION ALL            |         |
|2 |  ├─PX COORDINATOR               |         |
|3 |  │ └─EXCHANGE OUT DISTR         |:EX10000 |
|4 |  │   └─PX PARTITION ITERATOR    |         |
|5 |  │     └─TABLE FULL SCAN        |lyq_test3|
|6 |  └─HASH JOIN                    |         |
|7 |    ├─TABLE FULL SCAN            |e2       |
|8 |    └─MATERIAL                   |         |
|9 |      └─PX COORDINATOR           |         |
|10|        └─EXCHANGE OUT DISTR     |:EX20000 |
|11|          └─PX PARTITION ITERATOR|         |
|12|            └─TABLE FULL SCAN    |e        |
================================================
