序列
drop SEQUENCE s1;
CREATE SEQUENCE s1 START WITH 1 INCREMENT BY 1 NOORDER CACHE 10000;
select id,int_col,small_int_col from lyq_test3 where s1.currval > 0 order by 1,2;
