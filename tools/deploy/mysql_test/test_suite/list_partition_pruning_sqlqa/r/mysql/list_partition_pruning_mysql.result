    tiny_int_col, small_int_col, medium_int_col, int_col, big_int_col, 
    float_col, double_col, decimal_col, numeric_col, date_col, 
    time_col, datetime_col, char_col, varchar_col, binary_col, varbinary_col
) VALUES (
