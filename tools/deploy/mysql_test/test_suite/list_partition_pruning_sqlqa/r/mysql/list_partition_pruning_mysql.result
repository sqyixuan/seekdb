purge recyclebin;
LIST COLUMNS一级分区，区间比较的查询条件(如 between...and, >, <,  >=, <= ,<> ,!=,  in , not in , exists
LIST COLUMNS一级分区,分区键为date_col
drop table lyq_test;
CREATE TABLE lyq_test (
    id INT AUTO_INCREMENT,
    tiny_int_col TINYINT,
    small_int_col SMALLINT,
    medium_int_col MEDIUMINT,
    int_col INT,
    big_int_col BIGINT,
    float_col FLOAT,
    double_col DOUBLE,
    decimal_col DECIMAL(10,2),
    numeric_col NUMERIC(10,2),
    date_col DATE,
    time_col TIME,
    datetime_col DATETIME,
    char_col CHAR(10),
    varchar_col VARCHAR(255),
    binary_col BINARY(16),
    varbinary_col VARBINARY(255)
) PARTITION BY LIST COLUMNS (date_col) (
    PARTITION p0 VALUES IN ('2023-01-01', '2023-01-02'),
    PARTITION p1 VALUES IN ('2023-02-01', '2023-02-02'),
    PARTITION p2 VALUES IN ('2023-03-01', '2023-03-02'),
    PARTITION p3 VALUES IN ('2023-04-01', '2023-04-02')
);
INSERT INTO lyq_test (tiny_int_col, small_int_col, medium_int_col, int_col, big_int_col, 
    float_col, double_col, decimal_col, numeric_col, date_col, time_col, 
    datetime_col, char_col, varchar_col, binary_col, varbinary_col)
VALUES
    (1, 123, 12345, 123456, 1234567890, 
    1.23, 1.234567, 12345.67, 12345.67, '2023-01-01', '12:34:56', 
    '2023-01-01 12:34:56', 'char_data', 'varchar_data', BINARY('binary_data'), BINARY('varbinary_data'));
