result_format: 4
purge recyclebin;
二级分区场景
模版化 List + List 二级分区表  存在default 分区
drop table lyq_test;
CREATE TABLE lyq_test (
    id INT,
    tiny_int_col TINYINT,
    small_int_col SMALLINT,
    int_col INT,
    date_col DATE,
    datetime_col DATETIME,
    char_col CHAR(10),
    varchar_col VARCHAR(255),
    binary_col BINARY(16)
) PARTITION BY LIST COLUMNS(int_col)
       SUBPARTITION BY LIST COLUMNS(small_int_col)
       SUBPARTITION TEMPLATE 
        (SUBPARTITION sp0 VALUES IN(2), 
         SUBPARTITION sp1 VALUES IN(5), 
         SUBPARTITION sp2 VALUES IN(8),
         subpartition spdefault values in (default)
        ) 
        (PARTITION p0 VALUES IN(1,3),
         PARTITION p1 VALUES IN(4,6),
         PARTITION p2 VALUES IN(7,9),
         PARTITION pdefault VALUES in (default)
        );
INSERT INTO lyq_test (id, tiny_int_col, small_int_col, int_col, date_col, datetime_col, char_col, varchar_col, binary_col)
VALUES (1, 10, 2, 1, '2023-01-01', '2023-01-01 12:00:00', 'char10', 'varchar255', BINARY 'binary2');
