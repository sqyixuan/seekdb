select语句，区间比较的查询条件  exists ,all, any
不会裁剪  含有子查询的表达式不会用于分区裁剪
select id,int_col,small_int_col from lyq_test where exists (select id,int_col,small_int_col from lyq_test where int_col > 3) order by 1,2;
+------+---------+---------------+
| id   | int_col | small_int_col |
+------+---------+---------------+
|    1 |       1 |             2 |
|    2 |       3 |             5 |
|    3 |       7 |             8 |
|    4 |       4 |             2 |
|    5 |       6 |             5 |
|    6 |    NULL |          NULL |
+------+---------+---------------+
explain basic select id,int_col,small_int_col from lyq_test where exists (select id,int_col,small_int_col from lyq_test where int_col > 3) order by 1,2;
