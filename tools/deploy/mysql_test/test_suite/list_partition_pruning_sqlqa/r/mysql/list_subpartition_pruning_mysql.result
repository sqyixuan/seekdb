一级分区是hash分区，二级分区是list
非模版化 hash + list 二级分区表  分区键函数 不存在default 分区
drop table lyq_test4;
CREATE TABLE lyq_test4 (
    id INT,
    tiny_int_col TINYINT,
    small_int_col SMALLINT,
    int_col INT,
    date_col DATE,
    datetime_col DATETIME,
    char_col CHAR(10),
    varchar_col VARCHAR(255),
    binary_col BINARY(16)
) PARTITION BY hash (small_int_col)
       SUBPARTITION BY list (floor(int_col))
       (PARTITION p0
		(SUBPARTITION sp0 VALUES in (1,2), 
         SUBPARTITION sp1 VALUES in (3,4), 
         SUBPARTITION sp2 VALUES in (5,6,7,8,9)),
        PARTITION p1
         (SUBPARTITION sp3 VALUES in (1,2), 
         SUBPARTITION sp4 VALUES in (3,4), 
         SUBPARTITION sp5 VALUES in (5,6,7,8,9)),
        PARTITION p2
		 (SUBPARTITION sp6 VALUES in (1,2), 
         SUBPARTITION sp7 VALUES in (3,4), 
         SUBPARTITION sp8 VALUES in (5,6,7,8,9))
        );
