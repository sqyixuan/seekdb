(99, 99, 999, 99, 9999, '2023-10-06', '15:00:00', '2023-10-06 15:00:00', 'AAAA', 'Test AAAA', B'00000001', B'00000001');
select语句，区间比较的查询条件  exists ,all, any
不会裁剪  含有子查询的表达式不会用于分区裁剪,但子查询会裁剪
select id,char_col from lyq_test where exists (select id,char_col from lyq_test where int_col > 20) order by 1,2;
+----+----------+
| id | char_col |
+----+----------+
|  1 | A        |
|  2 | B        |
|  3 | C        |
|  4 | D        |
|  5 | E        |
|  6 | AAAA     |
+----+----------+
