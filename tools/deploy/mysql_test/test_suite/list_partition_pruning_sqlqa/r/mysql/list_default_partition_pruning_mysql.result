1000个分区，裁剪
drop table lyq_test;
drop PROCEDURE CreateLyqTestTable;
CREATE PROCEDURE CreateLyqTestTable()
BEGIN
    DECLARE i INT DEFAULT 0;
    DECLARE date1 DATE;
    DECLARE date2 DATE;
    DECLARE start_date DATE DEFAULT '2023-01-01';
    DECLARE sql_partitions TEXT DEFAULT '';
    DECLARE partition_statement TEXT;

    SET @partition_template = 'PARTITION p%p% VALUES IN (''%d1%'', ''%d2%'')';

    WHILE i < 1000 DO
        SET date1 = DATE_ADD(start_date, INTERVAL i*2 DAY);
        SET date2 = DATE_ADD(start_date, INTERVAL i*2+1 DAY);
        SET partition_statement = REPLACE(REPLACE(REPLACE(@partition_template, '%p%', i), '%d1%', date1), '%d2%', date2);

        IF i = 0 THEN
            SET sql_partitions = partition_statement;
        ELSE
            SET sql_partitions = CONCAT(sql_partitions, ',', partition_statement);
        END IF;

        SET i = i + 1;
    END WHILE;
    SET @sql = CONCAT('CREATE TABLE lyq_test (\n        id INT,\n        date_col DATE\n    ) PARTITION BY LIST COLUMNS (date_col) (', sql_partitions, ');');
    
    PREPARE stmt FROM @sql;
    EXECUTE stmt;
    DEALLOCATE PREPARE stmt;
END//
CALL CreateLyqTestTable();
