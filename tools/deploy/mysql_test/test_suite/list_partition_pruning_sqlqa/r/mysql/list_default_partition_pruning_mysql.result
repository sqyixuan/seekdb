(3, 30, 300, 3, 3000, '2023-10-03', '12:00:00', '2023-10-03 12:00:00', 'C', 'Test C', B'00000011', B'11110000');
INSERT INTO lyq_test (tiny_int_col, small_int_col, medium_int_col, int_col, big_int_col,date_col, time_col, datetime_col, char_col, varchar_col,binary_col, varbinary_col) VALUES
(4, 40, 400, 4, 4000, '2023-10-04', '13:00:00', '2023-10-04 13:00:00', 'D', 'Test D', B'00000100', B'00001111');
