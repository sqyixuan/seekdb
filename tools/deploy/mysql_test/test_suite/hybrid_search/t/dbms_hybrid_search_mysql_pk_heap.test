                {"term" : {"brand" : "InnovateTech"}}
              ],
              "minimum_should_match" : 4
            }
          }
        ]
    }
  }
}';

set @multiply_minimum_should_match_with_per = '{
    "query": {
      "bool": {
        "must_not": [
          {"match": {"product_name": "SmartX"}},
          {"match": {"description": "Crystal"}},
          {
            "bool": {
              "should": [
                {"match": {"description": "customizable"}},
                {"match": {"description": "Electronics"}},
                {"term" : {"brand" : "InnovateTech"}}
              ],
              "minimum_should_match" : "150%"
            }
          }
        ]
    }
  }
}';

call dbms_index_manager.refresh();
SELECT dbms_hybrid_search.get_sql('products', @multiply_minimum_should_match);
call dbms_index_manager.refresh();
SELECT dbms_hybrid_search.search('products', @multiply_minimum_should_match);
call dbms_index_manager.refresh();
SELECT json_pretty(dbms_hybrid_search.search('products', @multiply_minimum_should_match));
call dbms_index_manager.refresh();
SELECT dbms_hybrid_search.get_sql('products', @multiply_minimum_should_match) = dbms_hybrid_search.get_sql('products', @multiply_minimum_should_match_with_per);

# minimum_should_match == should
set @multiply_minimum_should_match = '{
    "query": {
      "bool": {
        "must_not": [
          {"match": {"product_name": "SmartX"}},
          {"match": {"description": "Crystal"}},
          {
            "bool": {
              "should": [
                {"match": {"description": "customizable"}},
                {"match": {"description": "Electronics"}},
                {"term" : {"brand" : "InnovateTech"}}
              ],
              "minimum_should_match" : 3
            }
          }
        ]
    }
  }
}';

set @multiply_minimum_should_match_with_per = '{
    "query": {
      "bool": {
        "must_not": [
          {"match": {"product_name": "SmartX"}},
          {"match": {"description": "Crystal"}},
          {
            "bool": {
              "should": [
                {"match": {"description": "customizable"}},
                {"match": {"description": "Electronics"}},
                {"term" : {"brand" : "InnovateTech"}}
              ],
              "minimum_should_match" : "130%"
            }
          }
        ]
    }
  }
}';
call dbms_index_manager.refresh();
SELECT dbms_hybrid_search.get_sql('products', @multiply_minimum_should_match);
call dbms_index_manager.refresh();
SELECT dbms_hybrid_search.search('products', @multiply_minimum_should_match);
call dbms_index_manager.refresh();
SELECT json_pretty(dbms_hybrid_search.search('products', @multiply_minimum_should_match));
call dbms_index_manager.refresh();
SELECT dbms_hybrid_search.get_sql('products', @multiply_minimum_should_match) = dbms_hybrid_search.get_sql('products', @multiply_minimum_should_match_with_per);

--disable_warnings
drop table if exists books;
--enable_warnings

CREATE TABLE books (
    book_id INT,
    title VARCHAR(200),
    author VARCHAR(100),
    category VARCHAR(50),
    description TEXT,
    price DECIMAL(8,2),
    PRIMARY KEY (book_id),
    vector_embedding vector(4),
    vector index idx_vector(vector_embedding) with (distance=l2, type=hnsw, lib=vsag),
    fulltext index idx_title(title),
    fulltext index idx_author(author),
    fulltext index idx_category(category),
    fulltext index idx_description(description)
) ORGANIZATION HEAP;

CREATE INDEX book_id_author_index ON books(book_id, author);
CREATE INDEX title_author_index ON books(title, author);

INSERT INTO books (book_id, title, author, category, description, price, vector_embedding) VALUES 
(1, 'The Great Gatsby', 'F. Scott Fitzgerald', 'Fiction', 'A classic American novel about the Jazz Age and the American Dream, featuring Jay Gatsby and his mysterious past.', 12.99, '[0.1,0.2,0.3,0.4]'),
(2, 'To Kill a Mockingbird', 'Harper Lee', 'Fiction', 'A powerful story about racial injustice in the American South, told through the eyes of young Scout Finch.', 14.50, '[0.5,0.6,0.7,0.8]'),
(3, '1984', 'George Orwell', 'Science Fiction', 'A dystopian novel about totalitarianism and surveillance society, featuring Winston Smith and Big Brother.', 11.99, '[0.9,0.1,0.2,0.3]'),
(4, 'Pride and Prejudice', 'Jane Austen', 'Romance', 'A beloved romance novel about Elizabeth Bennet and Mr. Darcy, exploring themes of love and social class.', 13.75, '[0.4,0.5,0.6,0.7]'),
(5, 'The Hobbit', 'J.R.R. Tolkien', 'Fantasy', 'An adventure story about Bilbo Baggins, a hobbit who embarks on a journey with thirteen dwarves to reclaim their homeland.', 15.25, '[0.8,0.9,0.1,0.2]'),
(6, 'Moby-Dick', 'Herman Melville', 'Fiction', 'A sailor Ishmael narrates the obsessive quest of Ahab for the white whale Moby Dick.', 10.99, '[0.2,0.3,0.4,0.5]'),
(7, 'The Catcher in the Rye', 'J.D. Salinger', 'Fiction', 'Holden Caulfield recounts days in New York City after being expelled from prep school.', 9.99, '[0.3,0.4,0.5,0.6]'),
(8, 'Brave New World', 'Aldous Huxley', 'Science Fiction', 'A dystopian future of engineered citizens and state control.', 12.50, '[0.6,0.7,0.2,0.1]'),
(9, 'The Lord of the Rings', 'J.R.R. Tolkien', 'Fantasy', 'An epic journey to destroy the One Ring in the fires of Mount Doom.', 29.99, '[0.7,0.1,0.3,0.8]'),
(10, 'Crime and Punishment', 'Fyodor Dostoevsky', 'Classic', 'Raskolnikov wrestles with guilt after committing a murder.', 13.20, '[0.15,0.25,0.35,0.45]'),
(11, 'The Alchemist', 'Paulo Coelho', 'Fiction', 'A shepherd boy embarks on a journey to find his personal legend.', 8.80, '[0.22,0.18,0.44,0.31]'),
(12, 'Sapiens', 'Yuval Noah Harari', 'Nonfiction', 'A brief history of humankind exploring cognitive revolution and modern society.', 18.00, '[0.55,0.12,0.33,0.21]'),
(13, 'Thinking, Fast and Slow', 'Daniel Kahneman', 'Nonfiction', 'Explores the dual systems of thought that drive decisions.', 16.50, '[0.11,0.22,0.66,0.33]'),
(14, 'The Name of the Rose', 'Umberto Eco', 'Mystery', 'A friar investigates a series of murders in a medieval monastery.', 11.70, '[0.25,0.36,0.47,0.58]'),
(15, 'Dune', 'Frank Herbert', 'Science Fiction', 'The story of Paul Atreides on the desert planet Arrakis.', 17.40, '[0.9,0.2,0.4,0.6]');

