# --minimum_should_match must be integer and percentage

set @minimum_is_string = '{
    "query": {
      "bool": {
        "must_not": [
          {"match": {"product_name": "SmartX"}},
          {"match": {"description": "Crystal"}},
          {"match": {"product_name": "Aura"}},
          {
            "bool": {
              "should": [
                {"match": {"description": "customizable"}},
                {"match": {"description": "Electronics"}},
                {"term" : {"brand" : "InnovateTech"}}
              ],
              "minimum_should_match" : " 2 "
            }
          }
        ],
        "should": [
          {"match": {"description": "yoga"}},
          {"match": {"description": "sustainable"}},
          {"match": {"description": "materials"}}
        ],
        "minimum_should_match" : 2
    }
