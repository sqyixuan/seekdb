# query_string & knn with filter
set @query_str_knn = '{
  "query": {
    "bool" : {
      "must" : [
        {"query_string": {
          "fields": ["query", "content"],
          "query": "hello what oceanbase mysql"}
        }
      ],
      "filter" : [
        {"range": {"c1": {"gte" : 2}}}
      ]
    }
  },
  "knn" : {
    "field": "vector",
    "k": 5,
    "num_candidates": 10,
    "query_vector": [1,2,3],
    "boost": 0.7,
    "filter" : [
      {"range": {"c1": {"gte" : 2}}}
    ]
  },
  "_source" : ["query", "content", "c1", "vector", "_keyword_score", "_semantic_score"]
}';

call dbms_index_manager.refresh();
select dbms_hybrid_search.get_sql('doc_table', @query_str_knn);
call dbms_index_manager.refresh();
select json_pretty(dbms_hybrid_search.search('doc_table', @query_str_knn));

# query_string & knn with query_string filter
set @query_str_knn = '{
  "query": {
    "bool" : {
      "must" : [
        {"query_string": {
          "fields": ["query", "content"],
          "query": "hello what oceanbase mysql"}
        }
      ],
      "filter" : [
        {"range": {"c1": {"gte" : 2}}}
      ]
    }
  },
  "knn" : {
    "field": "vector",
    "k": 5,
    "num_candidates": 10,
    "query_vector": [1,2,3],
    "boost": 0.7,
    "filter" : [
      {"query_string": {
        "fields": ["query^0.3", "content^0.5"],
        "query": "hello^0.4 what^0.2 oceanbase^0.3 mysql^0.3"}
      }
    ]
  },
  "_source" : ["query", "content", "c1", "vector", "_keyword_score", "_semantic_score"]
}';
call dbms_index_manager.refresh();
select dbms_hybrid_search.get_sql('doc_table', @query_str_knn);
call dbms_index_manager.refresh();
select * from hybrid_search('doc_table', @query_str_knn);
call dbms_index_manager.refresh();
select json_pretty(dbms_hybrid_search.search('doc_table', @query_str_knn));
call dbms_index_manager.refresh();
select * from json_table(dbms_hybrid_search.search('doc_table', @query_str_knn),
                                                   '$[*]' COLUMNS (score double PATH '$._score', 
                                                    c1 int PATH '$.c1', 
                                                    query varchar(255) PATH '$.query',
                                                    content varchar(255) PATH '$.content',
                                                    semantic_score double PATH '$._semantic_score',
                                                    keyword_score double PATH '$._keyword_score')) t;

# distance=inner_product

--disable_warnings
drop table if exists t1;
--enable_warnings
set @query_str_knn = '{
  "query": {
    "bool" : {
      "must" : [
        {"query_string": {
          "fields": ["c3"],
          "query": "computer University system"}
        }
      ],
      "filter" : [
        {"range": {"c1": {"gte" : 2}}}
      ]
    }
  },
  "knn" : {
    "field": "c2",
    "k": 5,
    "query_vector": [0.1,0.2,0.3],
    "filter" : [
      {"range": {"c1": {"gte" : 2}}}
    ]
  },
  "_source" : ["c3", "c2", "c1", "_keyword_score", "_semantic_score"]
}';
create table t1 (c1 int, c2 vector(3), c3 varchar(4096),  PRIMARY KEY (c1), vector index idx1(c2) with (type=hnsw, distance=inner_product), fulltext index idx2(c3)) ORGANIZATION HEAP;
insert into t1 values(1, '[0.203846,0.205289,0.880265]', "Gerard A. Gerry Salton (8 March 1927 – 28 August 1995) was a professor of Computer Science at Cornell University. Salton was perhaps the leading computer scientist working in the field of information retrieval during his time, and the father of Information Retrieval");
insert into t1 values(2, '[0.735541,0.670776,0.903237]', "Edgar Frank Ted Codd (19 August 1923 – 18 April 2003) was an English computer scientist who, while working for IBM, invented the relational model for database management, the theoretical basis for relational databases and relational database management systems. ");
insert into t1 values(3, '[0.327936,0.048756,0.084670]', "Michael Ralph Stonebraker (born October 11, 1943[6]) is a computer scientist specializing in database systems. Through a series of academic prototypes and commercial startups, Stonebraker's research and products are central to many relational databases. ");
insert into t1 values(4, '[0.148869,0.878546,0.028024]', "Geoffrey Everest Hinton CC FRS FRSC (born 6 December 1947) is a British-Canadian computer scientist and cognitive psychologist, most noted for his work on artificial neural networks.");
insert into t1 values(5, '[0.334970,0.857377,0.886132]', "Yann André LeCun[1] (born 8 July 1960) is a Turing Award winning French computer scientist working primarily in the fields of machine learning, computer vision, mobile robotics and computational neuroscience.");
insert into t1 values(6, '[0.117582,0.302352,0.471198]', "Kenneth Lane Thompson (born February 4, 1943) is an American pioneer of computer science. Thompson worked at Bell Labs for most of his career where he designed and implemented the original Unix operating system. ");
insert into t1 values(7, '[0.551185,0.231134,0.075354]', "Gordon David Plotkin, FRS FRSE MAE (born 9 September 1946) is a theoretical computer scientist in the School of Informatics at the University of Edinburgh. Plotkin is probably best known for his introduction of structural operational semantics (SOS) and his work on denotational semantics.");
insert into t1 values(8, '[0.185221,0.315131,0.558301]', "Leslie B. Lamport (born February 7, 1941) is an American computer scientist and mathematician. Lamport is best known for his seminal work in distributed systems, and as the initial developer of the document preparation system LaTeX");
insert into t1 values(9, '[0.928764,0.254038,0.272721]', "asdavoiajf oweirjweoifjsofmcspodkow cmdowm owejocwpe fowecofow ow weor pksdkm foe owei");
insert into t1 values(10, '[0.345999,0.254102,0.950869]', "pqowepqo pweuijkfn dmclsjrqowep kdlsnvkfdjh oweifj oqfj oewijfpqwo kpew jfpqokd wpqkc owq");
call dbms_index_manager.refresh();
select dbms_hybrid_search.get_sql('t1', @query_str_knn);
call dbms_index_manager.refresh();
select json_pretty(dbms_hybrid_search.search('t1', @query_str_knn));

