--echo # ----------------------------------------------------------------------
--echo # Test of search.
--echo # ----------------------------------------------------------------------

alter system set ob_vector_memory_limit_percentage = 44;
alter system set default_table_organization = 'heap';
sleep 3;

--disable_warnings
drop table if exists doc_table;
--enable_warnings
create table doc_table(c1 int, vector vector(3), query varchar(255), content varchar(255), vector index idx1(vector) with (distance=l2, type=hnsw, lib=vsag), fulltext idx2(query), fulltext idx3(content)) ORGANIZATION HEAP;
insert into doc_table values(1, '[1,2,3]', "hello world", "oceanbase Elasticsearch database"),
                            (2, '[1,2,1]', "hello world, what is your name", "oceanbase mysql database"),
                            (3, '[1,1,1]', "hello world, how are you", "oceanbase oracle database"),
                            (4, '[1,3,1]', "real world, where are you from", "postgres oracle database"),
                            (5, '[1,3,2]', "real world, how old are you", "redis oracle database"),
                            (6, '[2,1,1]', "hello world, where are you from", "starrocks oceanbase database");

set @parm = '{
      "query": {
        "bool": {
          "must": [
            {"match": {"query": "hi hello"}}, 
            {"match": { "content": "oceanbase mysql" }}
          ]
        }
      },
       "knn" : {
          "field": "vector",
          "k": 5,
          "num_candidates": 10,
          "query_vector": [1,2,3],
          "boost": 0.7
      },
      "_source" : ["query", "content", "_keyword_score", "_semantic_score"]
    }';
call dbms_index_manager.refresh();
select dbms_hybrid_search.search('doc_table', @parm);
call dbms_index_manager.refresh();
select dbms_hybrid_search.search('test.doc_table', @parm);
call dbms_index_manager.refresh();
select json_pretty(dbms_hybrid_search.search('doc_table', @parm));
call dbms_index_manager.refresh();
select dbms_hybrid_search.get_sql('doc_table', @parm);
call dbms_index_manager.refresh();
select * from hybrid_search('doc_table', @parm);

set @param_rank_feature = '{
      "query": {
        "bool": {
          "must": [
            {"match": {"query": "hi hello"}}, 
            {"match": { "content": "oceanbase mysql" }}
          ]
        },
        "rank_feature": {
          "field" : "c1",
          "saturation": {"pivot": 2}
        }
      },
      "_source" : ["query", "content", "c1", "vector"]
    }';

call dbms_index_manager.refresh();
--error 1210
select dbms_hybrid_search.search('doc_table', @param_rank_feature);
call dbms_index_manager.refresh();
--error 1210
select * from hybrid_search('doc_table', @param_rank_feature);

set @param_rank_feature = '{
      "query": {
        "bool": {
          "must": [
            {"match": {"query": "hi hello"}}, 
            {"match": { "content": "oceanbase mysql" }}
          ]
        },
        "rank_feature": {
          "field" : "c1",
          "query": "world, how, are^2.3",
          "knn" : {
            "field": "vector",
            "k": 8,
            "similarity": 23,
            "query_vector": "[-0.052001953125,0.00897216796875,-0.00470733642578125]",
            "filter":[
              {"range": {"c1": {"gte" : 3}}}
            ]
          },
          "saturation": {"pivot": 2}
        }
      },
      "_source" : ["query", "content", "c1", "vector"]
    }';

call dbms_index_manager.refresh();
--error 1210
select dbms_hybrid_search.search('doc_table', @param_rank_feature);

# query_string & knn
set @query_str_knn = '{
  "query": {
    "query_string": {
      "fields": ["query", "content"],
      "query": "hello what oceanbase mysql"
    }
  },
  "knn" : {
    "field": "vector",
    "k": 5,
    "num_candidates": 10,
    "query_vector": [1,2,3],
    "boost": 0.7
  },
  "_source" : ["query", "content", "c1", "vector", "_keyword_score", "_semantic_score"]
}';
call dbms_index_manager.refresh();
select dbms_hybrid_search.get_sql('doc_table', @query_str_knn);
call dbms_index_manager.refresh();
select json_pretty(dbms_hybrid_search.search('doc_table', @query_str_knn));
call dbms_index_manager.refresh();
select * from hybrid_search('doc_table', @query_str_knn);

