--echo # ----------------------------------------------------------------------
--echo # Test of hybrid search in heap table with partitions.
--echo # ----------------------------------------------------------------------
alter system set _enable_index_merge=false;

--disable_warnings
# HASH - RANGE (with expression in partition key)
drop table if exists t1_hash_range;
create table t1_hash_range (
    id int,
    part_key1 int,
    part_key2 int,
    subpart_key int,
    title varchar(200),
    content text,
    vector_emb vector(4),
    fulltext index idx_title(title),
    fulltext index idx_content(content),
    vector index idx_vector(vector_emb) with (distance=l2, type=hnsw, lib=vsag)
) ORGANIZATION HEAP partition by hash(part_key1 + part_key2) partitions 2
  subpartition by range(subpart_key) subpartition template (
    subpartition sp0 values less than (100),
    subpartition sp1 values less than (200),
    subpartition sp2 values less than maxvalue);

