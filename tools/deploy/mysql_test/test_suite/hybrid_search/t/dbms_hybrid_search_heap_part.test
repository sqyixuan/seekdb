# KEY - LIST (simple column partition key)
drop table if exists t2_key_list;
create table t2_key_list (
    id int,
    part_key1 int,
    part_key2 int,
    subpart_key int,
    title varchar(200),
    content text,
    vector_emb vector(4),
    fulltext index idx_title(title),
    fulltext index idx_content(content),
    vector index idx_vector(vector_emb) with (distance=l2, type=hnsw, lib=vsag)
) ORGANIZATION HEAP partition by key(part_key1, part_key2) partitions 2
  subpartition by list(subpart_key) subpartition template (
    subpartition sp0 values in (1, 2, 3),
    subpartition sp1 values in (4, 5, 6),
    subpartition sp2 values in (7, 8, 9));

