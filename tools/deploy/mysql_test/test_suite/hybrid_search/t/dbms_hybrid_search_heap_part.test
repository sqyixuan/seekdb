# RANGE COLUMNS - LIST COLUMNS
drop table if exists t7_range_cols_list_cols;
create table t7_range_cols_list_cols (
    id int,
    part_key1 int,
    part_key2 varchar(50),
    subpart_key1 int,
    subpart_key2 varchar(50),
    title varchar(200),
    content text,
    vector_emb vector(4),
    fulltext index idx_title(title),
    fulltext index idx_content(content),
    vector index idx_vector(vector_emb) with (distance=l2, type=hnsw, lib=vsag)
) ORGANIZATION HEAP partition by range columns(part_key1, part_key2)
  subpartition by list columns(subpart_key1, subpart_key2) subpartition template (
    subpartition sp0 values in ((1, 'a'), (2, 'b')),
    subpartition sp1 values in ((3, 'c'), (4, 'd')),
    subpartition sp2 values in ((5, 'e'), (6, 'f'))
  ) (
    partition p0 values less than (100, 'm'),
    partition p1 values less than (200, 'z'),
    partition p2 values less than (maxvalue, maxvalue));

