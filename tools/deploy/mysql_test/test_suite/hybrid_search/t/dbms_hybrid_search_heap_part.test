# t1_hash_range queries
set @t1_fts_query = '{
  "query": {
    "query_string": {
      "fields": ["title", "content"],
      "query": "fiction adventure story",
      "minimum_should_match": 2
    }
  },
  "_source": ["id", "part_key1", "part_key2", "subpart_key", "__pk_increment"],
  "size": 5
}';

set @t1_vec_query1 = '{
  "knn": {
    "field": "vector_emb",
    "k": 3,
    "query_vector": [0.1234, 0.2345, 0.3456, 0.4567]
  },
  "_source": ["id", "part_key1", "part_key2", "subpart_key", "__pk_increment"],
  "size": 3
}';

