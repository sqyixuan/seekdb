# RANGE COLUMNS - RANGE COLUMNS
drop table if exists t4_range_cols_key;
create table t4_range_cols_key (
    id int,
    part_key1 int,
    part_key2 int,
    subpart_key1 int,
    subpart_key2 int,
    title varchar(200),
    content text,
    vector_emb vector(4),
    fulltext index idx_title(title),
    fulltext index idx_content(content),
    vector index idx_vector(vector_emb) with (distance=l2, type=hnsw, lib=vsag)
) ORGANIZATION HEAP partition by range columns(part_key1, part_key2)
  subpartition by range columns(subpart_key1, subpart_key2) subpartition template (
    subpartition sp0 values less than (50, 50),
    subpartition sp1 values less than (100, 100),
    subpartition sp2 values less than (maxvalue, maxvalue)
  ) (
    partition p0 values less than (100, 100),
    partition p1 values less than (200, 200),
    partition p2 values less than (maxvalue, maxvalue));

