# HASH (expression with multiple columns) - RANGE (expression)
drop table if exists t6_hash_expr_range_expr;
create table t6_hash_expr_range_expr (
    id int,
    part_key1 int,
    part_key2 int,
    part_key3 int,
    subpart_key1 int,
    subpart_key2 int,
    title varchar(200),
    content text,
    vector_emb vector(4),
    fulltext index idx_title(title),
    fulltext index idx_content(content),
    vector index idx_vector(vector_emb) with (distance=l2, type=hnsw, lib=vsag)
) ORGANIZATION HEAP partition by hash(part_key1 + part_key2 * part_key3) partitions 2
  subpartition by range(subpart_key1 - subpart_key2) subpartition template (
    subpartition sp0 values less than (0),
    subpartition sp1 values less than (50),
    subpartition sp2 values less than maxvalue);

