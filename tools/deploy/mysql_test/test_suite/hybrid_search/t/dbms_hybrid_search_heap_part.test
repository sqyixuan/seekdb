# LIST (with expression) - RANGE COLUMNS
drop table if exists t5_list_range_cols;
create table t5_list_range_cols (
    id int,
    part_key1 int,
    part_key2 int,
    subpart_key1 int,
    subpart_key2 varchar(50),
    title varchar(200),
    content text,
    vector_emb vector(4),
    fulltext index idx_title(title),
    fulltext index idx_content(content),
    vector index idx_vector(vector_emb) with (distance=l2, type=hnsw, lib=vsag)
) ORGANIZATION HEAP partition by list(part_key1 + part_key2)
  subpartition by range columns(subpart_key1, subpart_key2) subpartition template (
    subpartition sp0 values less than (10, 'm'),
    subpartition sp1 values less than (20, 'z'),
    subpartition sp2 values less than (maxvalue, maxvalue)
  ) (
    partition p0 values in (100, 200, 300),
    partition p1 values in (400, 500, 600),
    partition p2 values in (700, 800, 900));

