# issue/2025101700111474204
set @test_vec = '[-0.052001953125,0.00897216796875,-0.00470733642578125]';
set @vec1='[-0.051953125,0.0089723452345236875,-0.005463642578125]';
set @vec2='[-0.041953125,-0.02347234523456875,-0.6567642578125]';

--disable_warnings
drop table if exists doc_table;
--enable_warnings
create table doc_table(c1 int , vector vector(3),v2 vector(3), v3 vector(3), brand varchar(256), query varchar(255), content varchar(255), test varchar(256),  
vector index idx1(vector) with (distance=l2, type=hnsw, lib=vsag), vector index idx2(v2) with (distance=l2, type=hnsw, lib=vsag), vector index idx3(v3) with (distance=l2, type=hnsw, lib=vsag), fulltext idxtext1(query), 
fulltext idxtext2(content));

insert into doc_table values(1, @test_vec ,@vec1, @vec2, "InnovateTech", "hello world oceanbase tools deploy", "oceanbase Elasticsearch database","qwerty"),
                            (2, @test_vec ,@vec1, @vec2, "dewfdscfxzcas","hello world, what is your name", "oceanbase mysql database","qqqqqq"),
                            (3, @test_vec ,@vec1, @vec2, "aaaaaaaa","hello world, how are you", "oceanbase oracle database","asdfgh"),
                            (4, @test_vec ,@vec1, @vec2, "aaagergdfgdva" ,"real world, where are you from", "postgres oracle database","zxcvbn"),
                            (5, @test_vec ,@vec1, @vec2,  "a234fcdscdbvxaa","real world, how old are you", "redis oracle database","yuiop["),
                            (6, @test_vec ,@vec1, @vec2, "adfsfvdfaaa", "hello world, where are you from", "starrocks oceanbase database","ghjklj");

set @parm='{
  "query": {
     "bool": {
        "should": [
            {
              "query_string": {
                  "fields": ["query"], 
                  "query": "oceanbase^3.333 oracle^4"
              }
            }
        ]
    }
  },
  "knn" : {
    "field": "vector",
    "k": 8,
    "filter" : [
      {
        "bool":{
          "should":[
            {"term":{"content": "database"}},
            {"term":{"content": "and"}},
            {
              "query_string": {
                "fields": ["query^0.2", "content^0.1"],
                "query": "love^0.1 journey^0.4 story^0.2",
                "type": "best_fields",
                "minimum_should_match" : 2
              }
            }
          ],
          "minimum_should_match" : 2
        }
      }
    ],
    "similarity": 23,
    "query_vector": "[-0.52001953125,0.8996875,-0.42578125]"
  },
  "_source" : ["query", "content"],
  "from": 1,
  "size": 13,
  "es_mode": true
}';

select dbms_hybrid_search.get_sql('doc_table', @parm);
select * from hybrid_search('doc_table', @parm);
SELECT json_pretty(dbms_hybrid_search.search('doc_table', @parm));

--echo # ----------------------------------------------------------------------
--echo # ÍÙÍ´'-'Ódatabase_nameÐtable_nameÐcolumn_name
--echo # ----------------------------------------------------------------------
--disable_warnings
drop database if exists `test-db`;
--enable_warnings
create database `test-db`;
use `test-db`;
--disable_warnings
drop table if exists `books-1`;
--enable_warnings
CREATE TABLE `books-1` (
    `book-id` INT,
    title VARCHAR(200),
    `author-1` VARCHAR(100),
    `category-2` VARCHAR(50),
    description TEXT,
    price DECIMAL(8,2),
    vector_embedding vector(4),
    vector index idx_vector(vector_embedding) with (distance=l2, type=hnsw, lib=vsag),
    fulltext index idx_title(title),
    fulltext index idx_author(`author-1`),
    fulltext index idx_category(`category-2`),
    fulltext index idx_description(description)
);

