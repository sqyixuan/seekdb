        {
          "query_string": {
            "fields": ["title^0.2", "author^0.1", "category^0.4"],
            "query": "love journey story fiction",
            "type": "most_fields",
            "minimum_should_match" : "80%"
          }
        }
      ],
      "minimum_should_match" : 2
    }
  },
  "knn": {
    "field": "vector_embedding",
    "k": 5,
    "query_vector": [0.1, 0.2, 0.3, 0.4],
    "boost": 0.4,
    "num_candidates" : 10
  },
  "size" : 4,
  "from" : 1
}';
SELECT dbms_hybrid_search.get_sql('books', @mixed2);
SELECT json_pretty(dbms_hybrid_search.search('books', @mixed2));


