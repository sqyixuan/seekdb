set @best_fields_with_must_not = '{
  "query": {
    "bool" : {
      "must_not" : [
        {
          "query_string": {
            "fields": ["title^0.2", "author^0.1", "category^0.4", "description^0.3"],
            "query": "love^0.1 journey^0.4 story^0.2 fiction^0.3",
            "type": "best_fields",
            "minimum_should_match" : 2
          }
        }
      ]
    }
  }
}';
SELECT dbms_hybrid_search.get_sql('books', @best_fields_with_must_not);
SELECT dbms_hybrid_search.search('books', @best_fields_with_must_not);
SELECT json_pretty(dbms_hybrid_search.search('books', @best_fields_with_must_not));

set @mixed1 = '{
  "query": {
    "bool" : {
      "should" : [
        {
          "query_string": {
            "fields": ["title^0.2", "author^0.1", "category^0.4", "description^0.3"],
            "query": "love^0.1 journey^0.4 story^0.2 fiction^0.3",
            "type": "best_fields",
            "minimum_should_match" : 2
          }
        },
          {"match": {"category": "journey"}},
          {"match": {"description": "fiction"}}
      ],
        "must" : [
        {
          "query_string": {
            "fields": ["title^0.2", "author^0.1", "category^0.4"],
            "query": "love journey story fiction",
            "type": "most_fields",
            "minimum_should_match" : "80%"
          }
        }
      ],
      "minimum_should_match" : 2
    }
  }
}';
SELECT dbms_hybrid_search.get_sql('books', @mixed1);
SELECT dbms_hybrid_search.search('books', @mixed1);
SELECT json_pretty(dbms_hybrid_search.search('books', @mixed1));

set @mixed2 = '{
  "query": {
    "bool" : {
      "should" : [
        {
          "query_string": {
            "fields": ["title^0.2", "author^0.1", "category^0.4", "description^0.3"],
            "query": "love^0.1 journey^0.4 story^0.2 fiction^0.3",
            "type": "best_fields",
            "minimum_should_match" : 2
          }
        },
          {"match": {"category": "journey"}},
          {"match": {"description": "fiction"}},
          {
            "rank_feature": {
              "field" : "book_id",
              "saturation": {"pivot": 2}
            }
          }
