# multi_match - best_fields
set @football_multi_match_best = '{
  "query": {
    "multi_match": {
      "query": "non-Asian qdqx_xw1^^2xx1",
      "fields": ["technical_stats^3", "player_code^2", "social_media_handle^1.5"],
      "type": "best_fields",
      "boost": 1.0
    }
  },
  "_source": ["id", "name", "position", "age", "team"],
  "es_mode": true
}';
SELECT dbms_hybrid_search.get_sql('football_players', @football_multi_match_best);
-- error 1235
SELECT dbms_hybrid_search.search('football_players', @football_multi_match_best);

# multi_match - most_fields
set @football_multi_match_most = '{
  "query": {
    "multi_match": {
      "query": "LM10_2024 @leomessi dribbling_success_rate",
      "fields": ["player_code^2", "social_media_handle^1.5", "technical_stats^3"],
      "type": "most_fields",
      "boost": 1.2
    }
  },
  "_source": ["id", "name", "position", "age", "team"],
  "es_mode": true
}';
SELECT dbms_hybrid_search.get_sql('football_players', @football_multi_match_most);
SELECT dbms_hybrid_search.search('football_players', @football_multi_match_most);
SELECT json_pretty(dbms_hybrid_search.search('football_players', @football_multi_match_most));

