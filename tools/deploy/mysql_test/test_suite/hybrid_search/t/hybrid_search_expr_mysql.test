select * from hybrid_search('test_table_new', @basic_query);
select a.* from hybrid_search('test_table_new', @basic_query) as a;
select a.* from hybrid_search('test_table_new', @basic_query) a;

--echo # change user variable define
set @basic_query = '{
  "query": {
    "bool": {
      "must": [
        {"match": {"title": "machine learning"}},
        {"match": {"content": "algorithms"}}
      ]
    }
  },
  "knn": {
    "field": "vector_col",
    "k": 3,
    "query_vector": [0.1, 0.2, 0.3, 0.4],
    "boost": 0.8
  },
  "_source": ["title", "content"]
}';

select * from hybrid_search('test_table', @basic_query);
select a.* from hybrid_search('test_table', @basic_query) as a;
select a.* from hybrid_search('test_table', @basic_query) a;
select * from hybrid_search('test_table_new', @basic_query);
select a.* from hybrid_search('test_table_new', @basic_query) as a;
select a.* from hybrid_search('test_table_new', @basic_query) a;

--echo # input params
--error 1064
select * from hybrid_search('test_table');
set @table_name = 'test_table';
--error 1064
select * from hybrid_search(@table_name, @basic_query);
--error 1210
select * from hybrid_search('', @basic_query);
--error 1210
select * from hybrid_search(NULL, @basic_query);
--error 1146
select * from hybrid_search('中文', @basic_query);
--error 1146
select * from hybrid_search('non_existent_table', @basic_query);
--error 1064
select * from hybrid_search(concat('tast_','table'), @basic_query);
--error 1146
select * from hybrid_search(1.1, @basic_query);
--error 1146
select * from hybrid_search(1, @basic_query);
--error 1210
select * from hybrid_search('test_table', '');
--error 1210
select * from hybrid_search('test_table', NULL);
--error 3140
select * from hybrid_search('test_table', 'abc');
--error 3140
select * from hybrid_search('test_table', '中文');
