select * from hybrid_search('test.test_table', @basic_query);
--error 1064
select hybrid_search('test_table', @basic_query);

--echo # sql应用场景
set @basic_query = '{
  "query": {
    "bool": {
      "must": [
        {"match": {"title": "machine learning"}},
        {"match": {"content": "algorithms"}}
      ]
    }
  },
  "knn": {
    "field": "vector_col",
    "k": 3,
    "query_vector": [0.1, 0.2, 0.3, 0.4],
    "boost": 0.8
  },
  "_source": ["id", "title", "content", "_keyword_score", "_semantic_score"]
}';

--echo # 1.1 比较运算符 (=, <, <=, >=, <>, !=)
select * from hybrid_search('test_table', @basic_query) where id = 1;
select * from hybrid_search('test_table', @basic_query) where id < 5;
select * from hybrid_search('test_table', @basic_query) where id <= 3;
select * from hybrid_search('test_table', @basic_query) where id >= 7;
select * from hybrid_search('test_table', @basic_query) where id <> 1;
select * from hybrid_search('test_table', @basic_query) where id != 2;
select * from hybrid_search('test_table', @basic_query) where title = 'Database Systems';
--echo # 1.2 逻辑运算符 (AND, OR)
select * from hybrid_search('test_table', @basic_query) where id > 2 and id < 8;
select * from hybrid_search('test_table', @basic_query) where id = 1 or id = 5;
select * from hybrid_search('test_table', @basic_query) where (id > 3 and id < 7) or id = 1;
--echo # 1.3 BETWEEN AND
select * from hybrid_search('test_table', @basic_query) where id between 3 and 7;
select * from hybrid_search('test_table', @basic_query) where _score between 0.5 and 2.0;
--echo # 1.4 LIKE, NOT LIKE
select * from hybrid_search('test_table', @basic_query) where title like '%Learning%';
select * from hybrid_search('test_table', @basic_query) where title not like '%Python%';
select * from hybrid_search('test_table', @basic_query) where content like 'Introduction%';
--echo # 1.5 EXISTS, ANY, ALL, IN
select * from hybrid_search('test_table', @basic_query) where id in (1, 3, 5, 7);
select * from hybrid_search('test_table', @basic_query) where id not in (2, 4, 6);
select * from hybrid_search('test_table', @basic_query) where id = any(select id from test_table_new where id > 5);
select * from hybrid_search('test_table', @basic_query) where id < all(select id from test_table_new);
--echo # 1.6 IS, IS NOT (FALSE, TRUE, NULL)
select * from hybrid_search('test_table', @basic_query) where _keyword_score is not null;
select * from hybrid_search('test_table', @basic_query) where _semantic_score is null or _semantic_score > 0;

--echo # 2. 嵌套SELECT测试
select * from (
    select * from hybrid_search('test_table', @basic_query) 
    where _score > 0.5
) t where t.id > 3;

select * from hybrid_search('test_table', @basic_query) 
where id in (
    select id from test_table_new 
    where title like '%Machine%'
);

select * from (
    select id, title, _score from hybrid_search('test_table', @basic_query)
    union
    select id, title, 0 as _score from test_table_new where id > 5
) combined order by _score desc;

--echo # 3. 多表查询测试
--echo # 3.1 Self-Join
select t1.title, t1._score, t2.title as other_title
from hybrid_search('test_table', @basic_query) t1
join hybrid_search('test_table', @basic_query) t2 on t1.id != t2.id
where t1._score > t2._score;

--echo # 3.2 INNER JOIN
select hs.title, hs._score, tn.title as new_title
from hybrid_search('test_table', @basic_query) hs
inner join test_table_new tn on hs.id = tn.id;

--echo # 3.3 LEFT JOIN
select hs.title, hs._score, tn.title as new_title
from hybrid_search('test_table', @basic_query) hs
left join test_table_new tn on hs.id != tn.id;

--echo # 3.4 RIGHT JOIN
select hs.title, hs._score, tn.title as new_title
from hybrid_search('test_table', @basic_query) hs
right join test_table_new tn on hs.id = tn.id limit 3;

--echo # 3.5 UNION
select id, title, _score from hybrid_search('test_table', @basic_query)
union
select id, title, 0 as _score from test_table_new
order by _score desc;

--echo # 3.6 UNION ALL
select (
  (select count(*) from hybrid_search('test_table', @basic_query)) +
  (select count(*) from hybrid_search('test_table_new', @basic_query))
) - (
  select count(*) from (
    select 1 as tag from hybrid_search('test_table', @basic_query)
    union all
    select 2 as tag from hybrid_search('test_table_new', @basic_query)
  ) u2
) as diff;

--echo # 3.6 等值连接和不等值连接
select hs1.title, hs1._score, hs2.title as other_title
from hybrid_search('test_table', @basic_query) hs1
join hybrid_search('test_table', @basic_query) hs2 on hs1.id = hs2.id + 1;

select hs1.title, hs1._score, hs2.title as other_title
from hybrid_search('test_table', @basic_query) hs1
join hybrid_search('test_table', @basic_query) hs2 on hs1.id < hs2.id;

--echo # 4. ORDER BY测试
select * from hybrid_search('test_table', @basic_query) order by _score desc;
select * from hybrid_search('test_table', @basic_query) order by id asc, _score desc;
select * from hybrid_search('test_table', @basic_query) order by title;

--echo # 5. GROUP BY / GROUP BY HAVING测试
select count(*) as cnt, avg(_score) as avg_score
from hybrid_search('test_table', @basic_query)
group by substring(title, 1, 1);

select substring(title, 1, 1) as first_char, count(*) as cnt, avg(_score) as avg_score
from hybrid_search('test_table', @basic_query)
group by substring(title, 1, 1)
having count(*) = 1;

--echo # 6. 运算符测试
select id, title, _score, _score * 2 as double_score
from hybrid_search('test_table', @basic_query);

select id, title, _score, _score + _keyword_score as total_score
from hybrid_search('test_table', @basic_query);

--echo # 7. CAST测试
select id, title, cast(_score as decimal(10,2)) as score_decimal
from hybrid_search('test_table', @basic_query);

select id, title, cast(_score as char(10)) as score_char
from hybrid_search('test_table', @basic_query);

--echo # 8. DISTINCT测试
select distinct substring(title, 1, 1) as first_char
from hybrid_search('test_table', @basic_query);

--echo # 9. WITH AS测试
with high_score_results as (
    select * from hybrid_search('test_table', @basic_query) 
    where _score > 0.6
)
select * from high_score_results order by _score desc;

with score_stats as (
    select avg(_score) as avg_score, max(_score) as max_score
    from hybrid_search('test_table', @basic_query)
)
select hs.*, ss.avg_score, ss.max_score
from hybrid_search('test_table', @basic_query) hs
cross join score_stats ss
where hs._score > ss.avg_score;

--echo # 10. CASE WHEN测试
select id, title, _score,
    case 
        when _score > 2.0 then 'High'
        when _score > 1.0 then 'Medium'
        else 'Low'
    end as score_level
from hybrid_search('test_table', @basic_query);

select id, title, _score,
    case _score
        when 0 then 'Zero'
        when 1 then 'One'
        else 'Other'
    end as score_category
from hybrid_search('test_table', @basic_query);

--echo # 11. LIMIT测试
select * from hybrid_search('test_table', @basic_query) limit 3;
select * from hybrid_search('test_table', @basic_query) order by _score desc limit 2;

--echo # 12. FOR UPDATE测试
select * from hybrid_search('test_table', @basic_query) where id = 1 for update;

--echo # 13. 虚拟列作为过滤条件测试
select * from hybrid_search('test_table', @basic_query) 
where _keyword_score > 0 and _semantic_score > 0;

select * from hybrid_search('test_table', @basic_query) 
where (_keyword_score + _semantic_score) > 1.5;

--echo # 14. 聚合函数测试
select count(*) as total_count,
       avg(_score) as avg_score,
       max(_score) as max_score,
       min(_score) as min_score,
       sum(_score) as total_score
from hybrid_search('test_table', @basic_query);

--echo # 15. 窗口函数测试
select id, title, _score,
       row_number() over (order by _score desc) as rank_num,
       dense_rank() over (order by _score desc) as dense_rank_num,
       rank() over (order by _score desc) as rank_val,
       lag(_score, 1) over (order by _score desc) as prev_score,
       lead(_score, 1) over (order by _score desc) as next_score
from hybrid_search('test_table', @basic_query);

select id, title, _score,
       sum(_score) over (order by _score desc rows between unbounded preceding and current row) as running_total,
       avg(_score) over (order by _score desc rows between 1 preceding and 1 following) as moving_avg
from hybrid_search('test_table', @basic_query);

--echo # 16. 其他函数测试
select id, title, _score,
       length(title) as title_length,
       upper(title) as title_upper,
       lower(title) as title_lower,
       concat(title, ' - Score: ', _score) as title_with_score
from hybrid_search('test_table', @basic_query);

select id, title, _score,
       substring(title, 1, 10) as title_short,
       replace(title, 'Learning', 'Study') as title_replaced
from hybrid_search('test_table', @basic_query);

--echo # 17. IN子查询
select * from test_table where title in (select title from hybrid_search('test_table', @basic_query));

--echo # Cleanup
--disable_warnings
drop table if exists test_table，test_table_new, t1;
--enable_warnings
alter system set ob_vector_memory_limit_percentage = 0;
