set @mixed_single_term = '{
  "query": {
    "bool": {
      "should" : [
        {
          "bool" : {
            "must": [
              {"match" : {
                "description" : 
                  {
                    "query" : "American",
                    "boost" : 2
                  }
                }
              },
              {"term" : 
                {
                  "book_id": {
                    "value" : 3,
                    "boost": 2
                  }
                }
              }
            ]
          }
        },
        {
          "match": {
            "description": "dystopian"
          }
        },
        {
          "range": {
            "price": {
              "gte": 10,
              "lte": 20,
              "boost": 2
            }
          }
        },
        {
          "term" : {"title" : "J.D. Salinger"}
        }
      ],
      "minimum_should_match": 2,
      "boost" : 3.58
    }
  }
}';
SELECT dbms_hybrid_search.get_sql('books', @mixed_single_term);
dbms_hybrid_search.get_sql('books', @mixed_single_term)
SELECT /*+ opt_param('hidden_column_visible', 'true') union_merge( books idx_description idx_description)*/`book_id`, `title`, `author`, `category`, `description`, `price`, `vector_embedding`, ((match(`description`) against('American' in natural language mode) * 2 + (`book_id` = 3) * 2 + match(`description`) against('dystopian' in natural language mode) + (`price` >= 10 AND `price` <= 20) * 2 + (`title` = 'J.D. Salinger')) * 3.58) as `_score` FROM `test`.`books` WHERE (match(`description`) against('American' in natural language mode) AND `book_id` = 3 AND match(`description`) against('dystopian' in natural language mode)) OR (match(`description`) against('American' in natural language mode) AND `book_id` = 3 AND `price` >= 10 AND `price` <= 20) OR (match(`description`) against('American' in natural language mode) AND `book_id` = 3 AND `title` = 'J.D. Salinger') OR (match(`description`) against('dystopian' in natural language mode) AND `price` >= 10 AND `price` <= 20) OR (match(`description`) against('dystopian' in natural language mode) AND `title` = 'J.D. Salinger') OR (`price` >= 10 AND `price` <= 20 AND `title` = 'J.D. Salinger') ORDER BY `_score` DESC, `__pk_increment` LIMIT 10
SELECT json_pretty(dbms_hybrid_search.search('books', @mixed_single_term));
json_pretty(dbms_hybrid_search.search('books', @mixed_single_term))
