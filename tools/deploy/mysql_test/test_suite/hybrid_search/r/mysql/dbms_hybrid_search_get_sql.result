('prod-004', 'Gamer-Pro Mechanical Keyboard', 'A responsive mechanical keyboard with customizable RGB lighting for the ultimate gaming experience.', 'GamerZone', 'Gaming', 'best-seller,gaming-gear,rgb', 149.00, 100, '2023-07-20', 1, '[0.5, 0.1, 0.6, 0.9]'),
('prod-005', 'Urban Commuter Backpack', 'A stylish and durable backpack with a dedicated laptop compartment.', 'UrbanStyle', 'Accessories', 'durable,new-arrival', 79.99, 250, '2023-08-18', 1, '[0.3, 0.4, 0.5, 0.0]'),
