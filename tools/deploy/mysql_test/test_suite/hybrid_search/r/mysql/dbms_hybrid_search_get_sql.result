 natural language mode) * 0.4, match(`description`) against('story' in natural language mode) * 0.3) * 0.2 as `_fts_sub_score_3`, GREATEST(match(`title`) against('fiction' in natural language mode) * 0.2, match(`author`) against('fiction' in natural language mode) * 0.1, match(`category`) against('fiction' in natural language mode) * 0.4, match(`description`) against('fiction' in natural language mode) * 0.3) * 0.3 as `_fts_sub_score_4`, match(`category`) against('journey' in natural language mode) as `_fts_sub_score_5`, match(`description`) against('fiction' in natural language mode) as `_fts_sub_score_6`, `book_id` / (`book_id` + 2) as `_fts_sub_score_7`, `__pk_increment` FROM `test`.`books` WHERE (match(`title`) against('love journey story fiction' in natural language mode) OR match(`author`) against('love journey story fiction' in natural language mode) OR match(`category`) against('love journey story fiction' in natural language mode)) AND (match(`title`) against('love journey story fiction' in natural language mode) OR match(`author`) against('love journey story fiction' in natural language mode) OR match(`category`) against('love journey story fiction' in natural language mode) OR match(`description`) against('love journey story fiction' in natural language mode) OR match(`category`) against('journey' in natural language mode) OR match(`description`) against('fiction' in natural language mode) OR `book_id` IS NOT NULL)) `_fts_sub` WHERE ((`_fts_sub_score_1` > 0) + (`_fts_sub_score_2` > 0) + (`_fts_sub_score_3` > 0) + (`_fts_sub_score_4` > 0) >= 2 > 0) + (`_fts_sub_score_5` > 0) + (`_fts_sub_score_6` > 0) + (`_fts_sub_score_7` > 0) >= 2 ORDER BY `_keyword_score` DESC LIMIT 100) `_fts` full join (SELECT /*+ opt_param('hidden_column_visible', 'true') */l2_distance(`vector_embedding`, '[0.1, 0.2, 0.3, 0.4]') as `_distance`, `__pk_increment`, `book_id`, `title`, `author`, `category`, `description`, `price`, `vector_embedding`, (round(1 / (1 + l2_distance(`vector_embedding`, '[0.1, 0.2, 0.3, 0.4]')), 8) * 0.4) as `_semantic_score` FROM `test`.`books` ORDER BY `_distance` APPROXIMATE LIMIT 5) `_vs` on `_fts`.`__pk_increment` = `_vs`.`__pk_increment`) ORDER BY `_score` DESC, ifnull(`_vs`.`__pk_increment`, `_fts`.`__pk_increment`) LIMIT 1, 4
