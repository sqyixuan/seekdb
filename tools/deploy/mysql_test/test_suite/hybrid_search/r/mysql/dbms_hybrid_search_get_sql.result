drop table if exists doc_table;
create table doc_table(c1 int , vector vector(3),v2 vector(3), v3 vector(3), brand varchar(256), query varchar(255), content varchar(255), test varchar(256),  
vector index idx1(vector) with (distance=l2, type=hnsw, lib=vsag), vector index idx2(v2) with (distance=l2, type=hnsw, lib=vsag), vector index idx3(v3) with (distance=l2, type=hnsw, lib=vsag), fulltext idxtext1(query), 
fulltext idxtext2(content));
