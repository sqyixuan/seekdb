SELECT ifnull(`_fts`.`title`, `_vs`.`title`) as `title`, ifnull(`_fts`.`author-1`, `_vs`.`author-1`) as `author-1`, ifnull(`_fts`.`category-2`, `_vs`.`category-2`) as `category-2`, ifnull(`_fts`.`description`, `_vs`.`description`) as `description`, `_keyword_score`, `_semantic_score`, (ifnull(`_fts`.`_keyword_score`, 0) + ifnull(`_vs`.`_semantic_score`, 0)) as `_score` FROM ((SELECT /*+ opt_param('hidden_column_visible', 'true') */`__pk_increment`, `title`, `author-1`, `category-2`, `description`, (((match(`title`) against('Gatsby' in natural language mode) * 0.3 + match(`author-1`) against('Gatsby' in natural language mode) * 0.2 + match(`category-2`) against('Gatsby' in natural language mode) * 0.2 + match(`description`) against('Gatsby' in natural language mode) * 0.3) * 0.4 + (match(`title`) against('Fitzgerald' in natural language mode) * 0.3 + match(`author-1`) against('Fitzgerald' in natural language mode) * 0.2 + match(`category-2`) against('Fitzgerald' in natural language mode) * 0.2 + match(`description`) against('Fitzgerald' in natural language mode) * 0.3) * 0.3 + (match(`title`) against('American' in natural language mode) * 0.3 + match(`author-1`) against('American' in natural language mode) * 0.2 + match(`category-2`) against('American' in natural language mode) * 0.2 + match(`description`) against('American' in natural language mode) * 0.3) * 0.2 + (match(`title`) against('Dream' in natural language mode) * 0.3 + match(`author-1`) against('Dream' in natural language mode) * 0.2 + match(`category-2`) against('Dream' in natural language mode) * 0.2 + match(`description`) against('Dream' in natural language mode) * 0.3) * 0.1) * 0.6) as `_keyword_score` FROM `test-db`.`books-1` WHERE match(`title`) against('Gatsby Fitzgerald American Dream' in natural language mode) OR match(`author-1`) against('Gatsby Fitzgerald American Dream' in natural language mode) OR match(`category-2`) against('Gatsby Fitzgerald American Dream' in natural language mode) OR match(`description`) against('Gatsby Fitzgerald American Dream' in natural language mode) ORDER BY `_keyword_score` DESC LIMIT 120) `_fts` full join (SELECT /*+ opt_param('hidden_column_visible', 'true') */l2_distance(`vector_embedding`, '[0.1, 0.2, 0.3, 0.4]') as `_distance`, `__pk_increment`, `title`, `author-1`, `category-2`, `description`, (round(1 / (1 + l2_distance(`vector_embedding`, '[0.1, 0.2, 0.3, 0.4]')), 8) * 0.4) as `_semantic_score` FROM `test-db`.`books-1` ORDER BY `_distance` APPROXIMATE LIMIT 5) `_vs` on `_fts`.`__pk_increment` = `_vs`.`__pk_increment`) ORDER BY `_score` DESC, ifnull(`_vs`.`__pk_increment`, `_fts`.`__pk_increment`) LIMIT 2, 4
