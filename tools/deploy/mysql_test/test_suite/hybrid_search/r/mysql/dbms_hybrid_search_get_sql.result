set @mixed = '{
  "query": {
    "bool" : {
      "must": [
        {
          "query_string": {
            "fields": ["title^0.3", "author^0.2", "category^0.2", "description^0.3"],
            "query": "Gatsby^0.4 Fitzgerald^0.3 American^0.2 Dream^0.1",
            "type": "best_fields",
            "boost": 0.6,
            "minimum_should_match": "45%"
          }
        },
        {
          "query_string": {
            "fields": ["title^0.3", "author^0.2", "category^0.2", "description^0.3"],
            "query": "Gatsby^0.4 Fitzgerald^0.3 American^0.2 Dream^0.1",
            "type": "most_fields",
            "boost": 0.6,
            "minimum_should_match": "80%"
          }
        }
      ],
      "should" : [
        {
          "query_string": {
            "fields": ["title^0.3", "author^0.2", "category^0.2", "description^0.3"],
            "query": "Gatsby Fitzgerald American Dream",
            "type": "phrase",
            "boost": 0.6,
            "minimum_should_match": "3"
          }
        }
      ]
    }
  }
}';
SELECT dbms_hybrid_search.get_sql('books', @mixed);
dbms_hybrid_search.get_sql('books', @mixed)
SELECT `book_id`, `title`, `author`, `category`, `description`, `price`, `vector_embedding`, ((`_fts_sub_score_0` + `_fts_sub_score_1` + `_fts_sub_score_2` + `_fts_sub_score_3`) * 0.6 + (`_fts_sub_score_4` + `_fts_sub_score_5` + `_fts_sub_score_6` + `_fts_sub_score_7`) * 0.6 + `_fts_sub_score_8` * 0.6) as `_score` FROM (SELECT /*+ opt_param('hidden_column_visible', 'true') */*, GREATEST(match(`title`) against('Gatsby' in natural language mode) * 0.3, match(`author`) against('Gatsby' in natural language mode) * 0.2, match(`category`) against('Gatsby' in natural language mode) * 0.2, match(`description`) against('Gatsby' in natural language mode) * 0.3) * 0.4 as `_fts_sub_score_0`, GREATEST(match(`title`) against('Fitzgerald' in natural language mode) * 0.3, match(`author`) against('Fitzgerald' in natural language mode) * 0.2, match(`category`) against('Fitzgerald' in natural language mode) * 0.2, match(`description`) against('Fitzgerald' in natural language mode) * 0.3) * 0.3 as `_fts_sub_score_1`, GREATEST(match(`title`) against('American' in natural language mode) * 0.3, match(`author`) against('American' in natural language mode) * 0.2, match(`category`) against('American' in natural language mode) * 0.2, match(`description`) against('American' in natural language mode) * 0.3) * 0.2 as `_fts_sub_score_2`, GREATEST(match(`title`) against('Dream' in natural language mode) * 0.3, match(`author`) against('Dream' in natural language mode) * 0.2, match(`category`) against('Dream' in natural language mode) * 0.2, match(`description`) against('Dream' in natural language mode) * 0.3) * 0.1 as `_fts_sub_score_3`, (match(`title`) against('Gatsby' in natural language mode) * 0.3 + match(`author`) against('Gatsby' in natural language mode) * 0.2 + match(`category`) against('Gatsby' in natural language mode) * 0.2 + match(`description`) against('Gatsby' in natural language mode) * 0.3) * 0.4 as `_fts_sub_score_4`, (match(`title`) against('Fitzgerald' in natural language mode) * 0.3 + match(`author`) against('Fitzgerald' in natural language mode) * 0.2 + match(`category`) against('Fitzgerald' in natural language mode) * 0.2 + match(`description`) against('Fitzgerald' in natural language mode) * 0.3) * 0.3 as `_fts_sub_score_5`, (match(`title`) against('American' in natural language mode) * 0.3 + match(`author`) against('American' in natural language mode) * 0.2 + match(`category`) against('American' in natural language mode) * 0.2 + match(`description`) against('American' in natural language mode) * 0.3) * 0.2 as `_fts_sub_score_6`, (match(`title`) against('Dream' in natural language mode) * 0.3 + match(`author`) against('Dream' in natural language mode) * 0.2 + match(`category`) against('Dream' in natural language mode) * 0.2 + match(`description`) against('Dream' in natural language mode) * 0.3) * 0.1 as `_fts_sub_score_7`, GREATEST(match(`title`) against('Gatsby Fitzgerald American Dream' in match phrase mode) * 0.3, match(`author`) against('Gatsby Fitzgerald American Dream' in match phrase mode) * 0.2, match(`category`) against('Gatsby Fitzgerald American Dream' in match phrase mode) * 0.2, match(`description`) against('Gatsby Fitzgerald American Dream' in match phrase mode) * 0.3) as `_fts_sub_score_8`, `__pk_increment` FROM `test`.`books` WHERE (match(`title`) against('Gatsby Fitzgerald American Dream' in natural language mode) OR match(`author`) against('Gatsby Fitzgerald American Dream' in natural language mode) OR match(`category`) against('Gatsby Fitzgerald American Dream' in natural language mode) OR match(`description`) against('Gatsby Fitzgerald American Dream' in natural language mode)) AND (match(`title`) against('Gatsby Fitzgerald American Dream' in natural language mode) OR match(`author`) against('Gatsby Fitzgerald American Dream' in natural language mode) OR match(`category`) against('Gatsby Fitzgerald American Dream' in natural language mode) OR match(`description`) against('Gatsby Fitzgerald American Dream' in natural language mode)) AND (match(`title`) against('Gatsby Fitzgerald American Dream' in match phrase mode) OR match(`author`) against('Gatsby Fitzgerald American Dream' in match phrase mode) OR match(`category`) against('Gatsby Fitzgerald American Dream' in match phrase mode) OR match(`description`) against('Gatsby Fitzgerald American Dream' in match phrase mode))) `_fts_sub` WHERE (`_fts_sub_score_4` > 0) + (`_fts_sub_score_5` > 0) + (`_fts_sub_score_6` > 0) + (`_fts_sub_score_7` > 0) >= 3 ORDER BY `_score` DESC, `__pk_increment` LIMIT 10
