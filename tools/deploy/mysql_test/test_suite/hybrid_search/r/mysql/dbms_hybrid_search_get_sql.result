    "match" : {
      "description" : {
        "query" : "American",
        "boost" : 2
      }
    }
  }
}';
SELECT dbms_hybrid_search.get_sql('books', @single_match);
dbms_hybrid_search.get_sql('books', @single_match)
SELECT /*+ opt_param('hidden_column_visible', 'true') */`book_id`, `title`, `author`, `category`, `description`, `price`, `vector_embedding`, (match(`description`) against('American' in natural language mode) * 2) as `_score` FROM `test`.`books` WHERE match(`description`) against('American' in natural language mode) ORDER BY `_score` DESC, `__pk_increment` LIMIT 10
set @empty_match2 = '{
  "query": {
    "match" : {
      "category" : []
    }
  }
}';
SELECT dbms_hybrid_search.get_sql('books', @empty_match2);
