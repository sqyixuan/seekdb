al language mode)) AND (match(`title`) against('love journey story fiction' in natural language mode) OR match(`author`) against('love journey story fiction' in natural language mode) OR match(`category`) against('love journey story fiction' in natural language mode) OR match(`description`) against('love journey story fiction' in natural language mode) OR match(`title`) against('Gatsby Fitzgerald American Dream' in natural language mode) OR match(`author`) against('Gatsby Fitzgerald American Dream' in natural language mode) OR match(`category`) against('Gatsby Fitzgerald American Dream' in natural language mode) OR match(`author`) against('Fitzgerald' in natural language mode))) `_fts_sub` WHERE (`_fts_sub_score_0` > 0) + (`_fts_sub_score_1` > 0) + (`_fts_sub_score_2` > 0) + (`_fts_sub_score_3` > 0) >= 2 AND (`_fts_sub_score_4` > 0) + (`_fts_sub_score_5` > 0) + (`_fts_sub_score_6` > 0) + (`_fts_sub_score_7` > 0) >= 2 AND (`_fts_sub_score_8` > 0) + (`_fts_sub_score_9` > 0) + (`_fts_sub_score_10` > 0) + (`_fts_sub_score_11` > 0) >= 2 AND (`_fts_sub_score_12` > 0) + (`_fts_sub_score_13` > 0) + (`_fts_sub_score_14` > 0) + (`_fts_sub_score_15` > 0) >= 3 ORDER BY `_score` DESC, `__pk_increment` LIMIT 10
