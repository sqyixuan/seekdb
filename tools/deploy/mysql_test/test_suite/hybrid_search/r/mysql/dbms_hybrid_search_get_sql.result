# ----------------------------------------------------------------------
# JSON expression
# ----------------------------------------------------------------------
drop table if exists `books-json-expression`;
CREATE TABLE `books-json-expression` (
_id INT PRIMARY KEY,
document string,
embedding vector(4),
metadata json,
`(The title of book)` VARCHAR(256),
FULLTEXT INDEX idx_fts(document),
VECTOR INDEX idx_vec (embedding) WITH (DISTANCE=l2, TYPE=hnsw, LIB=vsag)
) ORGANIZATION = HEAP;
