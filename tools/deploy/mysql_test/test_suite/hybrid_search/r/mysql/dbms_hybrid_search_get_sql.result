(4, @test_vec ,@vec1, @vec2, "aaagergdfgdva" ,"real world, where are you from", "postgres oracle database","zxcvbn"),
(5, @test_vec ,@vec1, @vec2,  "a234fcdscdbvxaa","real world, how old are you", "redis oracle database","yuiop["),
(6, @test_vec ,@vec1, @vec2, "adfsfvdfaaa", "hello world, where are you from", "starrocks oceanbase database","ghjklj");
set @parm='{
  "query": {
     "bool": {
        "should": [
            {
              "query_string": {
                  "fields": ["query"], 
                  "query": "oceanbase^3.333 oracle^4"
              }
            }
        ]
    }
  },
  "knn" : {
    "field": "vector",
    "k": 8,
    "filter" : [
      {
        "bool":{
          "should":[
            {"term":{"content": "database"}},
            {"term":{"content": "and"}},
            {
              "query_string": {
                "fields": ["query^0.2", "content^0.1"],
                "query": "love^0.1 journey^0.4 story^0.2",
                "type": "best_fields",
                "minimum_should_match" : 2
              }
            }
          ],
          "minimum_should_match" : 2
        }
      }
    ],
    "similarity": 23,
    "query_vector": "[-0.52001953125,0.8996875,-0.42578125]"
  },
  "_source" : ["query", "content"],
  "from": 1,
  "size": 13,
  "es_mode": true
}';
select dbms_hybrid_search.get_sql('doc_table', @parm);
dbms_hybrid_search.get_sql('doc_table', @parm)
SELECT ifnull(`_fts`.`query`, `_vs`.`query`) as `query`, ifnull(`_fts`.`content`, `_vs`.`content`) as `content`, (ifnull(`_fts`.`_keyword_score`, 0) + ifnull(`_vs`.`_semantic_score`, 0)) as `_score` FROM ((SELECT /*+ opt_param('hidden_column_visible', 'true') */`__pk_increment`, `query`, `content`, (match(`query`) against('oceanbase' in natural language mode) * 3.333 + match(`query`) against('oracle' in natural language mode) * 4) as `_keyword_score` FROM `test`.`doc_table` WHERE match(`query`) against('oceanbase oracle' in natural language mode) ORDER BY `_keyword_score` DESC LIMIT 280) `_fts` full join (SELECT `query`, `content`, `__pk_increment`, `_score` as `_semantic_score` FROM (SELECT /*+ opt_param('hidden_column_visible', 'true') */*, l2_distance(`vector`, '[-0.52001953125,0.8996875,-0.42578125]') as `_distance`, `__pk_increment`, round(1 / (1 + l2_distance(`vector`, '[-0.52001953125,0.8996875,-0.42578125]')), 8) as `_score` FROM `test`.`doc_table` WHERE (`content` = 'database' AND `content` = 'and') OR (`content` = 'database' AND (((match(`query`) against('love' in natural language mode) OR match(`content`) against('love' in natural language mode)) AND (match(`query`) against('journey' in natural language mode) OR match(`content`) against('journey' in natural language mode))) OR ((match(`query`) against('love' in natural language mode) OR match(`content`) against('love' in natural language mode)) AND (match(`query`) against('story' in natural language mode) OR match(`content`) against('story' in natural language mode))) OR ((match(`query`) against('journey' in natural language mode) OR match(`content`) against('journey' in natural language mode)) AND (match(`query`) against('story' in natural language mode) OR match(`content`) against('story' in natural language mode))))) OR (`content` = 'and' AND (((match(`query`) against('love' in natural language mode) OR match(`content`) against('love' in natural language mode)) AND (match(`query`) against('journey' in natural language mode) OR match(`content`) against('journey' in natural language mode))) OR ((match(`query`) against('love' in natural language mode) OR match(`content`) against('love' in natural language mode)) AND (match(`query`) against('story' in natural language mode) OR match(`content`) against('story' in natural language mode))) OR ((match(`query`) against('journey' in natural language mode) OR match(`content`) against('journey' in natural language mode)) AND (match(`query`) against('story' in natural language mode) OR match(`content`) against('story' in natural language mode))))) ORDER BY `_distance` APPROXIMATE LIMIT 8) `_vs0` WHERE `_vs0`.`_distance` <= 23) `_vs` on `_fts`.`__pk_increment` = `_vs`.`__pk_increment`) ORDER BY `_score` DESC, ifnull(`_vs`.`__pk_increment`, `_fts`.`__pk_increment`) LIMIT 1, 13
