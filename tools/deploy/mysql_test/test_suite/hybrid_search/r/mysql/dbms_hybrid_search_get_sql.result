e mode) * 0.1, match(`category`) against('fiction' in natural language mode) * 0.4, match(`description`) against('fiction' in natural language mode) * 0.3) * 0.3 as `_fts_sub_score_11`, match(`title`) against('love journey story fiction' in natural language mode) * 0.2 + match(`author`) against('love journey story fiction' in natural language mode) * 0.1 + match(`category`) against('love journey story fiction' in natural language mode) * 0.4 as `_fts_sub_score_12`, match(`author`) against('Fitzgerald' in natural language mode) as `_fts_sub_score_13`, `__pk_increment` FROM `test`.`books` WHERE (match(`title`) against('love journey story fiction' in natural language mode) OR match(`author`) against('love journey story fiction' in natural language mode) OR match(`category`) against('love journey story fiction' in natural language mode) OR match(`description`) against('love journey story fiction' in natural language mode)) AND (match(`title`) against('Gatsby Fitzgerald American Dream' in natural language mode) OR match(`author`) against('Gatsby Fitzgerald American Dream' in natural language mode) OR match(`category`) against('Gatsby Fitzgerald American Dream' in natural language mode) OR match(`description`) against('Gatsby Fitzgerald American Dream' in natural language mode)) AND (match(`title`) against('love journey story fiction' in natural language mode) OR match(`author`) against('love journey story fiction' in natural language mode) OR match(`category`) against('love journey story fiction' in natural language mode) OR match(`description`) against('love journey story fiction' in natural language mode) OR match(`title`) against('love journey story fiction' in natural language mode) OR match(`author`) against('love journey story fiction' in natural language mode) OR match(`category`) against('love journey story fiction' in natural language mode) OR match(`author`) against('Fitzgerald' in natural language mode))) `_fts_sub` WHERE (`_fts_sub_score_0` > 0) + (`_fts_sub_