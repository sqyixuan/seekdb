alter system set ob_vector_memory_limit_percentage = 44;
alter system set _enable_index_merge=true;
drop table if exists products;
CREATE TABLE products (
product_id VARCHAR(50),
product_name VARCHAR(255),
description TEXT,
brand VARCHAR(100),
category VARCHAR(100),
tags VARCHAR(255),
price DECIMAL(10, 2),
stock_quantity INT,
release_date DATETIME,
is_on_sale TINYINT(1),
vec vector(4),
FULLTEXT INDEX idx_product_name(product_name),
FULLTEXT INDEX idx_description(description),
FULLTEXT INDEX idx_tags(tags),
vector index vec_idx(vec) with (distance=l2, type=hnsw, lib=vsag)
);
INSERT INTO products (product_id, product_name, description, brand, category, tags, price, stock_quantity, release_date, is_on_sale, vec) VALUES 
('prod-001', 'SmartX Pro Phone', 'The latest flagship phone with an amazing AI camera and long-lasting battery.', 'InnovateTech', 'Electronics', 'new-arrival,smart-device,sale', 999.99, 150, '2023-09-01', 1, '[0.9, 0.1, 0.9, 0.0]'),
