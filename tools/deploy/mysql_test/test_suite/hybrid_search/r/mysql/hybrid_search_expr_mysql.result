      access([_fts.__pk_increment], [_fts.title], [_fts.content], [_fts._keyword_score])
  4 - output([test_table.__pk_increment], [test_table.title], [test_table.content], [MATCH(test_table.title) AGAINST('machine learning') + MATCH(test_table.content) 
      AGAINST('algorithms')]), filter(nil), rowset=16
      sort_keys([MATCH(test_table.title) AGAINST('machine learning') + MATCH(test_table.content) AGAINST('algorithms'), DESC]), topn(200)
