      access([ANONYMOUS_VIEW1.title], [ANONYMOUS_VIEW1.content], [ANONYMOUS_VIEW1._keyword_score], [ANONYMOUS_VIEW1._semantic_score], [ANONYMOUS_VIEW1._score])
