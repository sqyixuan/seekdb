# 14. 聚合函数测试
select count(*) as total_count,
avg(_score) as avg_score,
max(_score) as max_score,
min(_score) as min_score,
sum(_score) as total_score
from hybrid_search('test_table', @basic_query);
total_count	avg_score	max_score	min_score	total_score
3	2.600886093114552	6.564563047343657	0.571428568	7.802658279343657
# 15. 窗口函数测试
select id, title, _score,
row_number() over (order by _score desc) as rank_num,
dense_rank() over (order by _score desc) as dense_rank_num,
rank() over (order by _score desc) as rank_val,
lag(_score, 1) over (order by _score desc) as prev_score,
lead(_score, 1) over (order by _score desc) as next_score
from hybrid_search('test_table', @basic_query);
id	title	_score	rank_num	dense_rank_num	rank_val	prev_score	next_score
1	Machine Learning Basics	6.564563047343657	1	1	1	NULL	0.6666666640000001
6	Database Systems	0.6666666640000001	2	2	2	6.564563047343657	0.571428568
8	Cloud Computing	0.571428568	3	3	3	0.6666666640000001	NULL
select id, title, _score,
sum(_score) over (order by _score desc rows between unbounded preceding and current row) as running_total,
avg(_score) over (order by _score desc rows between 1 preceding and 1 following) as moving_avg
from hybrid_search('test_table', @basic_query);
id	title	_score	running_total	moving_avg
1	Machine Learning Basics	6.564563047343657	6.564563047343657	3.6156148556718284
6	Database Systems	0.6666666640000001	7.231229711343657	2.600886093114552
8	Cloud Computing	0.571428568	7.802658279343657	0.619047616
