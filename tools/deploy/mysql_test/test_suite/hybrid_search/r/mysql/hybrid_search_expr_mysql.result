      sort_keys([ifnull(_fts._keyword_score, cast(0, DOUBLE(-1, -1))) + ifnull(_vs._semantic_score, cast(0, DOUBLE(25, 8))), DESC], [ifnull(_vs.__pk_increment,
       _fts.__pk_increment), ASC]), topn(10)
  2 - output([_fts._keyword_score], [_vs._semantic_score], [_fts.__pk_increment], [_vs.__pk_increment], [_fts.title], [_fts.content], [_vs.title], [_vs.content]), filter(nil), rowset=16
      equal_conds([_fts.__pk_increment = _vs.__pk_increment]), other_conds(nil)
