# ----------------------------------------------------------------------
# Test of hybrid_search expression function.
# ----------------------------------------------------------------------
alter system set ob_vector_memory_limit_percentage = 44;
drop table if exists test_table, test_table_new, t1;
create table test_table(
id int, 
title varchar(255), 
content text, 
vector_col vector(4),
vector index idx_vector(vector_col) with (distance=l2, type=hnsw, lib=vsag), 
fulltext index idx_title(title),
fulltext index idx_content(content)
);
insert into test_table values
(1, 'Machine Learning Basics', 'Introduction to machine learning algorithms and techniques', '[0.1,0.2,0.3,0.4]'),
(2, 'Deep Learning Tutorial', 'Comprehensive guide to deep neural networks and applications', '[0.5,0.6,0.7,0.8]'),
(3, 'Data Science Handbook', 'Complete reference for data analysis and visualization', '[0.9,0.1,0.2,0.3]'),
(4, 'Python Programming', 'Learn Python programming from beginner to advanced', '[0.4,0.5,0.6,0.7]'),
(5, 'Artificial Intelligence', 'AI concepts, algorithms, and real-world applications', '[0.8,0.9,0.1,0.2]'),
(6, 'Database Systems', 'Relational database design and SQL optimization', '[0.2,0.3,0.4,0.5]'),
(7, 'Web Development', 'Modern web development with HTML, CSS, and JavaScript', '[0.6,0.7,0.8,0.9]'),
(8, 'Cloud Computing', 'Introduction to cloud platforms and services', '[0.3,0.4,0.5,0.6]'),
(9, 'Cybersecurity', 'Network security and data protection strategies', '[0.7,0.8,0.9,0.1]'),
(10, 'Mobile App Development', 'iOS and Android app development fundamentals', '[0.1,0.9,0.3,0.7]');
# Basic hybrid_search expression with match query and knn
set @basic_query = '{
  "query": {
    "bool": {
      "must": [
        {"match": {"title": "machine learning"}},
        {"match": {"content": "algorithms"}}
      ]
    }
  },
  "knn": {
    "field": "vector_col",
    "k": 3,
    "query_vector": [0.1, 0.2, 0.3, 0.4],
    "boost": 0.8
  },
  "_source": ["title", "content", "_keyword_score", "_semantic_score"]
}';
select json_pretty(dbms_hybrid_search.search('test_table', @basic_query));
json_pretty(dbms_hybrid_search.search('test_table', @basic_query))
[
  {
    "title": "Machine Learning Basics",
    "_score": 6.564563047343657,
    "content": "Introduction to machine learning algorithms and techniques",
    "_keyword_score": 5.764563047343657,
    "_semantic_score": 0.8
  },
  {
    "title": "Database Systems",
    "_score": 0.6666666640000001,
    "content": "Relational database design and SQL optimization",
    "_keyword_score": null,
    "_semantic_score": 0.6666666640000001
  },
  {
    "title": "Cloud Computing",
    "_score": 0.571428568,
    "content": "Introduction to cloud platforms and services",
    "_keyword_score": null,
    "_semantic_score": 0.571428568
  }
]
select dbms_hybrid_search.get_sql('test_table', @basic_query);
dbms_hybrid_search.get_sql('test_table', @basic_query)
SELECT ifnull(`_fts`.`title`, `_vs`.`title`) as `title`, ifnull(`_fts`.`content`, `_vs`.`content`) as `content`, `_keyword_score`, `_semantic_score`, (ifnull(`_fts`.`_keyword_score`, 0) + ifnull(`_vs`.`_semantic_score`, 0)) as `_score` FROM ((SELECT /*+ opt_param('hidden_column_visible', 'true') union_merge( test_table idx_title idx_content)*/`__pk_increment`, `title`, `content`, (match(`title`) against('machine learning' in natural language mode) + match(`content`) against('algorithms' in natural language mode)) as `_keyword_score` FROM `test`.`test_table` WHERE match(`title`) against('machine learning' in natural language mode) AND match(`content`) against('algorithms' in natural language mode) ORDER BY `_keyword_score` DESC LIMIT 200) `_fts` full join (SELECT /*+ opt_param('hidden_column_visible', 'true') */l2_distance(`vector_col`, '[0.1, 0.2, 0.3, 0.4]') as `_distance`, `__pk_increment`, `title`, `content`, (round(1 / (1 + l2_distance(`vector_col`, '[0.1, 0.2, 0.3, 0.4]')), 8) * 0.8) as `_semantic_score` FROM `test`.`test_table` ORDER BY `_distance` APPROXIMATE LIMIT 3) `_vs` on `_fts`.`__pk_increment` = `_vs`.`__pk_increment`) ORDER BY `_score` DESC, ifnull(`_vs`.`__pk_increment`, `_fts`.`__pk_increment`) LIMIT 10
select * from (SELECT title, content, _keyword_score, _semantic_score, (ifnull(_fts._keyword_score, 0) + ifnull(_vs._semantic_score, 0)) as _score FROM ((SELECT /*+ opt_param('hidden_column_visible', 'true') union_merge( test_table idx_title idx_content)*/__pk_increment, (match(title) against('machine learning' in boolean mode) + match(content) against('algorithms' in boolean mode)) as _keyword_score FROM test.test_table WHERE match(title) against('machine learning' in boolean mode) AND match(content) against('algorithms' in boolean mode) ORDER BY _keyword_score DESC) _fts right join (SELECT /*+ opt_param('hidden_column_visible', 'true') */l2_distance(vector_col, '[0.1, 0.2, 0.3, 0.4]') as _distance, __pk_increment, title, content, (round((1 / (1 + l2_distance(vector_col, '[0.1, 0.2, 0.3, 0.4]'))), 8) * 0.8) as _semantic_score FROM test.test_table ORDER BY _distance APPROXIMATE LIMIT 3) _vs on (_fts.__pk_increment = _vs.__pk_increment)) ORDER BY _score DESC);
