# change user variable define
set @basic_query = '{
  "query": {
    "bool": {
      "must": [
        {"match": {"title": "machine learning"}},
        {"match": {"content": "algorithms"}}
      ]
    }
  },
  "knn": {
    "field": "vector_col",
    "k": 3,
    "query_vector": [0.1, 0.2, 0.3, 0.4],
    "boost": 0.8
  },
  "_source": ["title", "content"]
}';
select * from hybrid_search('test_table', @basic_query);
title	content	_score
Machine Learning Basics	Introduction to machine learning algorithms and techniques	6.564563047343657
Database Systems	Relational database design and SQL optimization	0.6666666640000001
Cloud Computing	Introduction to cloud platforms and services	0.571428568
select a.* from hybrid_search('test_table', @basic_query) as a;
