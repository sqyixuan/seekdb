# 9. WITH AS测试
with high_score_results as (
select * from hybrid_search('test_table', @basic_query) 
where _score > 0.6
)
select * from high_score_results order by _score desc;
id	title	content	_keyword_score	_semantic_score	_score
1	Machine Learning Basics	Introduction to machine learning algorithms and techniques	5.764563047343657	0.80000000	6.564563047343657
6	Database Systems	Relational database design and SQL optimization	NULL	0.66666666	0.6666666640000001
with score_stats as (
select avg(_score) as avg_score, max(_score) as max_score
from hybrid_search('test_table', @basic_query)
)
select hs.*, ss.avg_score, ss.max_score
from hybrid_search('test_table', @basic_query) hs
cross join score_stats ss
where hs._score > ss.avg_score;
id	title	content	_keyword_score	_semantic_score	_score	avg_score	max_score
1	Machine Learning Basics	Introduction to machine learning algorithms and techniques	5.764563047343657	0.80000000	6.564563047343657	2.600886093114552	6.564563047343657
# 10. CASE WHEN测试
select id, title, _score,
case 
when _score > 2.0 then 'High'
        when _score > 1.0 then 'Medium'
        else 'Low'
    end as score_level
from hybrid_search('test_table', @basic_query);
id	title	_score	score_level
1	Machine Learning Basics	6.564563047343657	High
6	Database Systems	0.6666666640000001	Low
8	Cloud Computing	0.571428568	Low
select id, title, _score,
case _score
when 0 then 'Zero'
        when 1 then 'One'
        else 'Other'
    end as score_category
from hybrid_search('test_table', @basic_query);
id	title	_score	score_category
1	Machine Learning Basics	6.564563047343657	Other
6	Database Systems	0.6666666640000001	Other
8	Cloud Computing	0.571428568	Other
