    "bool": {
      "must": [
        {"match": {"title": "Gatsby"}},
        {"match": {"author": "Fitzgerald"}}
      ],
      "filter": [
        {"range": {"price": {"gte": 10}}}
      ]
    }
  },
  "knn": {
    "field": "vector_embedding",
    "k": 3,
    "query_vector": [0.1, 0.2, 0.3, 0.4],
    "boost": 0.8
  },
