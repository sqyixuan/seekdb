ode)) OR (match(description) against('American' in natural language mode) AND match(description) against('novel' in natural language mode) AND match(description) against('classic' in natural language mode) AND match(description) against('Gatsby' in natural language mode)) ORDER BY _score DESC, __pk_increment LIMIT 10
