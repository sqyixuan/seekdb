set @football_multi_match_knn_range = '{
  "query": {
    "bool": {
      "must": [
        {
          "multi_match": {
            "query": "forward goal machine",
            "fields": ["position^3", "description^2", "technical_stats^1.5"],
            "type": "most_fields",
            "operator": "OR",
            "boost": 1.2
          }
        }
      ],
      "filter": [
        {"range": {"goals_scored": {"gte": 100}}},
        {"range": {"market_value_million": {"gte": 20.0}}}
      ]
    }
  },
  "knn": {
    "field": "player_embedding",
    "query_vector": [0.8, 0.6, 0.4, 0.2, 0.1],
    "k": 3,
    "num_candidates": 8,
    "boost": 1.0
  }
}';
SELECT dbms_hybrid_search.get_sql('football_players_multi_match', @football_multi_match_knn_range);
dbms_hybrid_search.get_sql('football_players_multi_match', @football_multi_match_knn_range)
SELECT ifnull(_fts.id, _vs.id) as id, ifnull(_fts.name, _vs.name) as name, ifnull(_fts.position, _vs.position) as position, ifnull(_fts.team, _vs.team) as team, ifnull(_fts.nationality, _vs.nationality) as nationality, ifnull(_fts.age, _vs.age) as age, ifnull(_fts.height_cm, _vs.height_cm) as height_cm, ifnull(_fts.weight_kg, _vs.weight_kg) as weight_kg, ifnull(_fts.goals_scored, _vs.goals_scored) as goals_scored, ifnull(_fts.assists, _vs.assists) as assists, ifnull(_fts.market_value_million, _vs.market_value_million) as market_value_million, ifnull(_fts.description, _vs.description) as description, ifnull(_fts.skills, _vs.skills) as skills, ifnull(_fts.achievements, _vs.achievements) as achievements, ifnull(_fts.player_code, _vs.player_code) as player_code, ifnull(_fts.social_media_handle, _vs.social_media_handle) as social_media_handle, ifnull(_fts.technical_stats, _vs.technical_stats) as technical_stats, ifnull(_fts.contract_details, _vs.contract_details) as contract_details, ifnull(_fts.player_embedding, _vs.player_embedding) as player_embedding, (ifnull(_fts._keyword_score, 0) + ifnull(_vs._semantic_score, 0)) as _score FROM ((SELECT /*+ opt_param('hidden_column_visible', 'true') */__pk_increment, id, name, position, team, nationality, age, height_cm, weight_kg, goals_scored, assists, market_value_million, description, skills, achievements, player_code, social_media_handle, technical_stats, contract_details, player_embedding, ((match(position) against('forward' in natural language mode) * 3 + match(description) against('forward' in natural language mode) * 2 + match(technical_stats) against('forward' in natural language mode) * 1.5 + match(position) against('goal' in natural language mode) * 3 + match(description) against('goal' in natural language mode) * 2 + match(technical_stats) against('goal' in natural language mode) * 1.5 + match(position) against('machine' in natural language mode) * 3 + match(description) against('machine' in natural language mode) * 2 + match(technical_stats) against('machine' in natural language mode) * 1.5) * 1.2) as _keyword_score FROM test.football_players_multi_match WHERE (match(position) against('forward goal machine' in natural language mode) OR match(description) against('forward goal machine' in natural language mode) OR match(technical_stats) against('forward goal machine' in natural language mode)) AND goals_scored >= 100 AND market_value_million >= 20 ORDER BY _keyword_score DESC LIMIT 200) _fts full join (SELECT /*+ opt_param('hidden_column_visible', 'true') */l2_distance(player_embedding, '[0.8, 0.6, 0.4, 0.2, 0.1]') as _distance, __pk_increment, id, name, position, team, nationality, age, height_cm, weight_kg, goals_scored, assists, market_value_million, description, skills, achievements, player_code, social_media_handle, technical_stats, contract_details, player_embedding, round(1 / (1 + l2_distance(player_embedding, '[0.8, 0.6, 0.4, 0.2, 0.1]')), 8) as _semantic_score FROM test.football_players_multi_match ORDER BY _distance APPROXIMATE LIMIT 3) _vs on _fts.__pk_increment = _vs.__pk_increment) ORDER BY _score DESC, ifnull(_vs.__pk_increment, _fts.__pk_increment) LIMIT 10
SELECT dbms_hybrid_search.search('football_players_multi_match', @football_multi_match_knn_range);
dbms_hybrid_search.search('football_players_multi_match', @football_multi_match_knn_range)
