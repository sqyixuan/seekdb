set @football_underscore_hyphen = '{
  "query": {
    "multi_match": {
      "query": "non-Asian_heritage work_rate: 98/100",
      "fields": ["technical_stats^2", "description^1.5", "skills^1"],
      "type": "most_fields",
      "boost": 1.0
    }
  }
}';
SELECT dbms_hybrid_search.get_sql('football_players_multi_match', @football_underscore_hyphen);
dbms_hybrid_search.get_sql('football_players_multi_match', @football_underscore_hyphen)
SELECT /*+ opt_param('hidden_column_visible', 'true') */id, name, position, team, nationality, age, height_cm, weight_kg, goals_scored, assists, market_value_million, description, skills, achievements, player_code, social_media_handle, technical_stats, contract_details, player_embedding, (match(technical_stats) against('non' in natural language mode) * 2 + match(description) against('non' in natural language mode) * 1.5 + match(skills) against('non' in natural language mode) + match(technical_stats) against('Asian' in natural language mode) * 2 + match(description) against('Asian' in natural language mode) * 1.5 + match(skills) against('Asian' in natural language mode) + match(technical_stats) against('heritage' in natural language mode) * 2 + match(description) against('heritage' in natural language mode) * 1.5 + match(skills) against('heritage' in natural language mode) + match(technical_stats) against('work' in natural language mode) * 2 + match(description) against('work' in natural language mode) * 1.5 + match(skills) against('work' in natural language mode) + match(technical_stats) against('rate' in natural language mode) * 2 + match(description) against('rate' in natural language mode) * 1.5 + match(skills) against('rate' in natural language mode) + match(technical_stats) against('98' in natural language mode) * 2 + match(description) against('98' in natural language mode) * 1.5 + match(skills) against('98' in natural language mode) + match(technical_stats) against('100' in natural language mode) * 2 + match(description) against('100' in natural language mode) * 1.5 + match(skills) against('100' in natural language mode)) as _score FROM test.football_players_multi_match WHERE match(technical_stats) against('non Asian heritage work rate 98 100' in natural language mode) OR match(description) against('non Asian heritage work rate 98 100' in natural language mode) OR match(skills) against('non Asian heritage work rate 98 100' in natural language mode) ORDER BY _score DESC, __pk_increment LIMIT 10
SELECT dbms_hybrid_search.search('football_players_multi_match', @football_underscore_hyphen);
