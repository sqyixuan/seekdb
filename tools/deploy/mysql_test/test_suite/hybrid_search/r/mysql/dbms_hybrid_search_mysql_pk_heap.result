SELECT book_id, title, author, category, description, price, vector_embedding, (_fts_sub_score_0 + _fts_sub_score_1 + _fts_sub_score_2 + _fts_sub_score_3) as _score FROM (SELECT /*+ opt_param('hidden_column_visible', 'true') */*, GREATEST(match(title) against('love' in natural language mode) * 0.2, match(author) against('love' in natural language mode) * 0.1, match(category) against('love' in natural language mode) * 0.4, match(description) against('love' in natural language mode) * 0.3) * 0.1 as _fts_sub_score_0, GREATEST(match(title) against('journey' in natural language mode) * 0.2, match(author) against('journey' in natural language mode) * 0.1, match(category) against('journey' in natural language mode) * 0.4, match(description) against('journey' in natural language mode) * 0.3) * 0.4 as _fts_sub_score_1, GREATEST(match(title) against('story' in natural language mode) * 0.2, match(author) against('story' in natural language mode) * 0.1, match(category) against('story' in natural language mode) * 0.4, match(description) against('story' in natural language mode) * 0.3) * 0.2 as _fts_sub_score_2, GREATEST(match(title) against('fiction' in natural language mode) * 0.2, match(author) against('fiction' in natural language mode) * 0.1, match(category) against('fiction' in natural language mode) * 0.4, match(description) against('fiction' in natural language mode) * 0.3) * 0.3 as _fts_sub_score_3, __pk_increment FROM test.books WHERE match(title) against('love journey story fiction' in natural language mode) OR match(author) against('love journey story fiction' in natural language mode) OR match(category) against('love journey story fiction' in natural language mode) OR match(description) against('love journey story fiction' in natural language mode)) _fts_sub WHERE (_fts_sub_score_0 > 0) + (_fts_sub_score_1 > 0) + (_fts_sub_score_2 > 0) + (_fts_sub_score_3 > 0) >= 2 ORDER BY _score DESC, __pk_increment LIMIT 10
SELECT dbms_hybrid_search.search('books', @books_with_weight_with_minimum_should_match);
dbms_hybrid_search.search('books', @books_with_weight_with_minimum_should_match)
