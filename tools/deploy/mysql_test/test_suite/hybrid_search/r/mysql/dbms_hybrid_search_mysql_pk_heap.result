set @multiply_minimum_should_match = '{
    "query": {
      "bool": {
        "must_not": [
          {"match": {"product_name": "SmartX"}},
          {"match": {"description": "Crystal"}},
          {"match": {"product_name": "Aura"}},
          {
            "bool": {
              "should": [
                {"match": {"description": "customizable"}},
                {"match": {"description": "Electronics"}},
                {"term" : {"brand" : "InnovateTech"}}
              ],
              "minimum_should_match" : 0
            }
          }
        ],
        "should": [
          {"match": {"description": "yoga"}},
          {"match": {"description": "sustainable"}},
          {"match": {"description": "materials"}}
        ],
        "minimum_should_match" : 2
    }
  }
}';
set @multiply_minimum_should_match_with_percentage = '{
    "query": {
      "bool": {
        "must_not": [
          {"match": {"product_name": "SmartX"}},
          {"match": {"description": "Crystal"}},
          {"match": {"product_name": "Aura"}},
          {
            "bool": {
              "should": [
                {"match": {"description": "customizable"}},
                {"match": {"description": "Electronics"}},
                {"term" : {"brand" : "InnovateTech"}}
              ],
              "minimum_should_match" : "-10%"
            }
          }
        ],
        "should": [
          {"match": {"description": "yoga"}},
          {"match": {"description": "sustainable"}},
          {"match": {"description": "materials"}}
        ],
        "minimum_should_match" : " 2 "
    }
  }
}';
SELECT dbms_hybrid_search.get_sql('products', @multiply_minimum_should_match);
dbms_hybrid_search.get_sql('products', @multiply_minimum_should_match)
SELECT /*+ opt_param('hidden_column_visible', 'true') union_merge( products idx_description idx_description idx_description idx_product_name idx_description idx_product_name idx_description idx_description)*/product_id, product_name, description, brand, category, tags, price, stock_quantity, release_date, is_on_sale, vec, (match(description) against('yoga' in natural language mode) + match(description) against('sustainable' in natural language mode) + match(description) against('materials' in natural language mode)) as _score FROM test.products WHERE ((match(description) against('yoga' in natural language mode) AND match(description) against('sustainable' in natural language mode)) OR (match(description) against('yoga' in natural language mode) AND match(description) against('materials' in natural language mode)) OR (match(description) against('sustainable' in natural language mode) AND match(description) against('materials' in natural language mode))) AND NOT (match(product_name) against('SmartX' in natural language mode) OR match(description) against('Crystal' in natural language mode) OR match(product_name) against('Aura' in natural language mode) OR match(description) against('customizable' in natural language mode) OR match(description) against('Electronics' in natural language mode) OR brand = 'InnovateTech') ORDER BY _score DESC, __pk_increment LIMIT 10
