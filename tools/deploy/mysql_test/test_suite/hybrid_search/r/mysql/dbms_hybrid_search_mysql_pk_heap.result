drop table if exists football_players_multi_match;
CREATE TABLE football_players_multi_match (
id INT NOT NULL AUTO_INCREMENT,
PRIMARY KEY (id),
name VARCHAR(100) NOT NULL,
position VARCHAR(50) NOT NULL,
team VARCHAR(100) NOT NULL,
nationality VARCHAR(50) NOT NULL,
age INT NOT NULL,
height_cm INT NOT NULL,
weight_kg INT NOT NULL,
goals_scored INT DEFAULT 0,
assists INT DEFAULT 0,
market_value_million DECIMAL(10,2) DEFAULT 0.00,
description TEXT,
skills TEXT,
achievements TEXT,
player_code VARCHAR(50),
social_media_handle VARCHAR(100),
technical_stats TEXT,
contract_details TEXT,
player_embedding vector(5),
FULLTEXT INDEX idx_position (position),
FULLTEXT INDEX idx_team (team),
FULLTEXT INDEX idx_description (description),
FULLTEXT INDEX idx_skills (skills),
FULLTEXT INDEX idx_achievements (achievements),
FULLTEXT INDEX idx_player_code (player_code),
FULLTEXT INDEX idx_social_media_handle (social_media_handle),
FULLTEXT INDEX idx_technical_stats (technical_stats),
FULLTEXT INDEX idx_contract_details (contract_details)
) ORGANIZATION HEAP;
INSERT INTO football_players_multi_match (name, position, team, nationality, age, height_cm, weight_kg, goals_scored, assists, market_value_million, description, skills, achievements, player_code, social_media_handle, technical_stats, contract_details, player_embedding) VALUES
('Lionel Messi', 'Forward', 'Inter Miami', 'Argentina', 36, 170, 72, 800, 350, 50.00, 'Legendary forward known for incredible dribbling and goal-scoring ability. Considered one of the greatest players of all time.', 'Dribbling, Finishing, Vision, Free-kicks', '8 Ballon d\'Or, 4 Champions League titles, World Cup winner 2022', 'LM10_2024', '@leomessi', 'non-Asian qdqx_xw1^^2xx1 | dribbling_success_rate: 89.3% | xG_expected: 0.45', 'Contract: 2024-2027 | Salary: $50M/year | Release_clause: €500M', '[0.95,0.88,0.92,0.90,0.89]'),
('Cristiano Ronaldo', 'Forward', 'Al Nassr', 'Portugal', 39, 187, 83, 850, 250, 15.00, 'Prolific goal scorer with exceptional athleticism and aerial ability. One of the most decorated players in football history.', 'Shooting, Heading, Speed, Physicality', '5 Ballon d\'Or, 5 Champions League titles, Euro 2016 winner', 'CR7_GOAT', '@cristiano', 'Asian_style_play: false | header_accuracy: 92.1% | speed_kmh: 33.6', 'Contract: 2023-2025 | Salary: $200M/year | Bonus: €10M/goal', '[0.92,0.95,0.88,0.87,0.91]'),
('Kylian Mbappé', 'Forward', 'Real Madrid', 'France', 25, 178, 73, 300, 150, 180.00, 'Lightning-fast forward with incredible pace and finishing ability. The future of football.', 'Speed, Dribbling, Finishing, Versatility', 'World Cup winner 2018, Ligue 1 top scorer multiple times', 'KM7_SPEED', '@kylianmbappe', 'acceleration_0-30m: 3.2s | top_speed: 36.0km/h | non-European_style: true', 'Contract: 2024-2030 | Salary: €50M/year | Image_rights: 100%', '[0.89,0.94,0.91,0.85,0.88]'),
('Erling Haaland', 'Forward', 'Manchester City', 'Norway', 24, 194, 88, 200, 50, 150.00, 'Clinical striker with exceptional physical presence and goal-scoring instinct. A goal machine.', 'Finishing, Physicality, Positioning, Aerial ability', 'Premier League Golden Boot 2023, Champions League top scorer', 'EH9_MACHINE', '@erlinghaaland', 'goals_per_90min: 1.2 | xG_ratio: 1.8 | physical_duels_won: 78%', 'Contract: 2022-2027 | Salary: €20M/year | Release_clause: €200M', '[0.87,0.96,0.89,0.82,0.86]'),
('Kevin De Bruyne', 'Midfielder', 'Manchester City', 'Belgium', 33, 181, 70, 100, 200, 80.00, 'Creative midfielder with exceptional passing range and vision. The engine of Manchester City.', 'Passing, Vision, Long shots, Set pieces', 'Premier League Player of the Season, Champions League winner', 'KDB17_CREATOR', '@kevindebruyne', 'pass_accuracy: 89.7% | key_passes_per_game: 3.4 | long_shot_goals: 12', 'Contract: 2021-2025 | Salary: €15M/year | Extension_option: 2026', '[0.91,0.85,0.94,0.88,0.90]'),
('Luka Modrić', 'Midfielder', 'Real Madrid', 'Croatia', 38, 172, 66, 50, 150, 10.00, 'Elegant midfielder with incredible ball control and passing ability. A true maestro of the game.', 'Passing, Ball control, Vision, Leadership', 'Ballon d\'Or 2018, 5 Champions League titles, World Cup runner-up 2018', 'LM10_MAESTRO', '@lukamodric10', 'ball_control_rating: 95/100 | pass_completion: 91.2% | non-Asian_heritage: true', 'Contract: 2023-2024 | Salary: €8M/year | Coaching_role: post-retirement', '[0.88,0.89,0.93,0.91,0.87]'),
('Virgil van Dijk', 'Defender', 'Liverpool', 'Netherlands', 33, 193, 92, 20, 10, 40.00, 'Dominant center-back with exceptional defensive skills and leadership qualities. A defensive rock.', 'Tackling, Aerial ability, Leadership, Passing', 'Champions League winner, Premier League winner, UEFA Player of the Year', 'VVD4_WALL', '@virgilvandijk', 'tackle_success_rate: 87.3% | aerial_duels_won: 84.1% | clean_sheets: 23', 'Contract: 2022-2025 | Salary: €12M/year | Captain_bonus: €2M', '[0.86,0.90,0.87,0.89,0.85]'),
('Joshua Kimmich', 'Defender', 'Bayern Munich', 'Germany', 29, 176, 70, 30, 80, 60.00, 'Versatile defender who can play multiple positions. Excellent technical ability and work rate.', 'Versatility, Passing, Tackling, Work rate', 'Champions League winner, Bundesliga winner multiple times', 'JK6_VERSATILE', '@joshua_kimmich', 'position_versatility: RB/CDM/CB | work_rate: 95/100 | distance_covered: 12.5km', 'Contract: 2023-2027 | Salary: €18M/year | Loyalty_bonus: €5M', '[0.84,0.88,0.86,0.87,0.83]'),
('Thibaut Courtois', 'Goalkeeper', 'Real Madrid', 'Belgium', 32, 199, 96, 0, 0, 25.00, 'World-class goalkeeper with exceptional reflexes and commanding presence in the penalty area.', 'Shot-stopping, Commanding, Distribution, Reflexes', 'Champions League winner, La Liga winner, World Cup Golden Glove', 'TC1_WALL', '@thibautcourtois', 'save_percentage: 78.9% | clean_sheets: 18 | distribution_accuracy: 85.2%', 'Contract: 2024-2028 | Salary: €10M/year | Clean_sheet_bonus: €50K', '[0.82,0.85,0.88,0.84,0.86]'),
('Neymar Jr', 'Forward', 'Al Hilal', 'Brazil', 32, 175, 68, 400, 200, 20.00, 'Skilful forward with incredible dribbling ability and creativity. Known for his flair and trickery.', 'Dribbling, Creativity, Flair, Set pieces', 'Champions League winner, Olympic gold medal, Copa América winner', 'NJ10_SKILLS', '@neymarjr', 'dribbles_completed: 156 | skill_moves_per_game: 8.7 | non-European_style: true', 'Contract: 2023-2025 | Salary: €100M/year | Image_rights: 80%', '[0.90,0.87,0.89,0.86,0.88]'),
('Mohamed Salah', 'Forward', 'Liverpool', 'Egypt', 32, 175, 71, 250, 100, 70.00, 'Prolific winger with exceptional pace and finishing ability. Liverpool\'s Egyptian King.', 'Pace, Finishing, Dribbling, Versatility', 'Premier League Golden Boot, Champions League winner, African Player of the Year', 'MS11_KING', '@mosalah', 'pace_rating: 94/100 | goals_per_season: 25+ | African_heritage: true', 'Contract: 2022-2025 | Salary: €20M/year | Goal_bonus: €100K', '[0.88,0.92,0.85,0.89,0.87]'),
('Sadio Mané', 'Forward', 'Al Nassr', 'Senegal', 32, 175, 69, 200, 80, 15.00, 'Dynamic forward with incredible work rate and versatility. Known for his pace and finishing.', 'Pace, Work rate, Finishing, Versatility', 'Champions League winner, Premier League winner, African Cup of Nations winner', 'SM10_PACE', '@sadiomane', 'work_rate: 98/100 | pace_rating: 96/100 | versatility_score: 9.2/10', 'Contract: 2023-2026 | Salary: €25M/year | Performance_bonus: €5M', '[0.87,0.89,0.86,0.88,0.85]'),
('Robert Lewandowski', 'Forward', 'Barcelona', 'Poland', 36, 185, 81, 600, 150, 20.00, 'Clinical striker with exceptional goal-scoring record. One of the most consistent forwards in football.', 'Finishing, Positioning, Aerial ability, Hold-up play', 'Champions League winner, Bundesliga top scorer multiple times, Ballon d\'Or runner-up', 'RL9_CLINICAL', '@lewy_official', 'finishing_rating: 97/100 | xG_conversion: 1.3 | hold_up_play: 8.9/10', 'Contract: 2022-2026 | Salary: €15M/year | Goal_bonus: €75K', '[0.89,0.91,0.88,0.87,0.90]'),
('Manuel Neuer', 'Goalkeeper', 'Bayern Munich', 'Germany', 38, 193, 92, 0, 0, 5.00, 'Revolutionary goalkeeper known for his sweeper-keeper style and exceptional shot-stopping ability.', 'Shot-stopping, Sweeper-keeper, Distribution, Leadership', 'World Cup winner, Champions League winner, Bundesliga winner multiple times', 'MN1_SWEEPER', '@manuel_neuer', 'sweeper_actions: 45 | distribution_accuracy: 88.7% | leadership_rating: 95/100', 'Contract: 2023-2024 | Salary: €8M/year | Captain_bonus: €1M', '[0.85,0.87,0.89,0.86,0.88]'),
('Sergio Ramos', 'Defender', 'Sevilla', 'Spain', 38, 184, 82, 100, 30, 3.00, 'Aggressive center-back with exceptional leadership and goal-scoring ability from set pieces.', 'Leadership, Aerial ability, Tackling, Set pieces', 'World Cup winner, 2 Euro winners, 4 Champions League titles', 'SR4_CAPTAIN', '@sergioramos', 'leadership_rating: 99/100 | aerial_duels_won: 89.2% | set_piece_goals: 15', 'Contract: 2023-2024 | Salary: €3M/year | Leadership_bonus: €500K', '[0.83,0.86,0.84,0.87,0.82]');
set @football_multi_match_best = '{
  "query": {
    "multi_match": {
      "query": "non-Asian qdqx_xw1^^2xx1",
      "fields": ["technical_stats^3", "player_code^2", "social_media_handle^1.5"],
      "type": "best_fields",
      "boost": 1.0
    }
  }
}';
SELECT dbms_hybrid_search.get_sql('football_players_multi_match', @football_multi_match_best);
dbms_hybrid_search.get_sql('football_players_multi_match', @football_multi_match_best)
SELECT /*+ opt_param('hidden_column_visible', 'true') */id, name, position, team, nationality, age, height_cm, weight_kg, goals_scored, assists, market_value_million, description, skills, achievements, player_code, social_media_handle, technical_stats, contract_details, player_embedding, (GREATEST(match(technical_stats) against('non' in natural language mode) * 3, match(player_code) against('non' in natural language mode) * 2, match(social_media_handle) against('non' in natural language mode) * 1.5) + GREATEST(match(technical_stats) against('Asian' in natural language mode) * 3, match(player_code) against('Asian' in natural language mode) * 2, match(social_media_handle) against('Asian' in natural language mode) * 1.5) + GREATEST(match(technical_stats) against('qdqx' in natural language mode) * 3, match(player_code) against('qdqx' in natural language mode) * 2, match(social_media_handle) against('qdqx' in natural language mode) * 1.5) + GREATEST(match(technical_stats) against('xw1' in natural language mode) * 3, match(player_code) against('xw1' in natural language mode) * 2, match(social_media_handle) against('xw1' in natural language mode) * 1.5) + GREATEST(match(technical_stats) against('2xx1' in natural language mode) * 3, match(player_code) against('2xx1' in natural language mode) * 2, match(social_media_handle) against('2xx1' in natural language mode) * 1.5)) as _score FROM test.football_players_multi_match WHERE match(technical_stats) against('non Asian qdqx xw1 2xx1' in natural language mode) OR match(player_code) against('non Asian qdqx xw1 2xx1' in natural language mode) OR match(social_media_handle) against('non Asian qdqx xw1 2xx1' in natural language mode) ORDER BY _score DESC, __pk_increment LIMIT 10
SELECT dbms_hybrid_search.search('football_players_multi_match', @football_multi_match_best);
dbms_hybrid_search.search('football_players_multi_match', @football_multi_match_best)
