SELECT c1, c2, c4, c5, c3, sum(_score) as _score FROM ((SELECT /*+ opt_param('hidden_column_visible', 'true') */*, cosine_distance(c2, '[1, 2, 3]') as _distance, __pk_increment, round(1 - cosine_distance(c2, '[1, 2, 3]') / 2, 8) as _score FROM test.t1 WHERE c1 >= 2 ORDER BY _distance APPROXIMATE LIMIT 5)  UNION ALL (SELECT * FROM (SELECT /*+ opt_param('hidden_column_visible', 'true') */*, cosine_distance(c4, '[1, 2, 3]') as _distance, __pk_increment, round(1 - cosine_distance(c4, '[1, 2, 3]') / 2, 8) as _score FROM test.t1 ORDER BY _distance APPROXIMATE LIMIT 5) _vs0 WHERE _vs0._distance <= 0.5)  UNION ALL (SELECT /*+ opt_param('hidden_column_visible', 'true') */*, cosine_distance(c5, '[1, 2, 3]') as _distance, __pk_increment, (round(1 - cosine_distance(c5, '[1, 2, 3]') / 2, 8) * 0.8) as _score FROM test.t1 ORDER BY _distance APPROXIMATE LIMIT 5) ) GROUP BY __pk_increment ORDER BY _score DESC LIMIT 5
select json_pretty(dbms_hybrid_search.search('t1',@param_multi_knn));
json_pretty(dbms_hybrid_search.search('t1',@param_multi_knn))
