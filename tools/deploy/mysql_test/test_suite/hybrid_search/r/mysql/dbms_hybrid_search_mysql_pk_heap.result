set @football_hybrid_search = '{
  "query": {
    "bool": {
      "must": [
        {
          "multi_match": {
            "query": "forward goal scorer",
            "fields": ["position^2", "description^1.5", "skills^1"],
            "type": "best_fields"
          }
        }
      ],
      "filter": [
        {"range": {"goals_scored": {"gte": 200}}},
        {"range": {"age": {"lte": 35}}}
      ]
    }
  }
}';
SELECT dbms_hybrid_search.get_sql('football_players_multi_match', @football_hybrid_search);
dbms_hybrid_search.get_sql('football_players_multi_match', @football_hybrid_search)
SELECT /*+ opt_param('hidden_column_visible', 'true') */id, name, position, team, nationality, age, height_cm, weight_kg, goals_scored, assists, market_value_million, description, skills, achievements, player_code, social_media_handle, technical_stats, contract_details, player_embedding, (GREATEST(match(position) against('forward' in natural language mode) * 2, match(description) against('forward' in natural language mode) * 1.5, match(skills) against('forward' in natural language mode)) + GREATEST(match(position) against('goal' in natural language mode) * 2, match(description) against('goal' in natural language mode) * 1.5, match(skills) against('goal' in natural language mode)) + GREATEST(match(position) against('scorer' in natural language mode) * 2, match(description) against('scorer' in natural language mode) * 1.5, match(skills) against('scorer' in natural language mode))) as _score FROM test.football_players_multi_match WHERE (match(position) against('forward goal scorer' in natural language mode) OR match(description) against('forward goal scorer' in natural language mode) OR match(skills) against('forward goal scorer' in natural language mode)) AND goals_scored >= 200 AND age <= 35 ORDER BY _score DESC, __pk_increment LIMIT 10
SELECT dbms_hybrid_search.search('football_players_multi_match', @football_hybrid_search);
