set @knn_with_msm_in_filter = '{
  "query": {
    "bool": {
      "should": [
        {"match": {"title": "Gatsby"}},
        {"match": {"author": "Fitzgerald"}}
      ],
      "filter": [
        {"range": {"book_id": {"gt": 0}}}
      ]
    }
  },
  "size": 10,
  "from": 0,
  "knn": {
    "field": "vector_embedding",
    "k": " 5 ",
    "query_vector": [0.8, 0.1, 0.8, 0.2],
    "boost": 1.89,
    "filter": [
      {"query_string": {
        "fields": ["title^0.3", "description^0.5"],
        "query": "adventure^0.4 story^0.2 legend^0.3",
        "minimum_should_match": 2}
      }
    ]
  },
  "_source": ["book_id","title","description","_keyword_score","_semantic_score"]
}';
SELECT dbms_hybrid_search.get_sql('books', @knn_with_msm_in_filter);
dbms_hybrid_search.get_sql('books', @knn_with_msm_in_filter)
SELECT ifnull(_fts.book_id, _vs.book_id) as book_id, ifnull(_fts.title, _vs.title) as title, ifnull(_fts.description, _vs.description) as description, _keyword_score, _semantic_score, (ifnull(_fts._keyword_score, 0) + ifnull(_vs._semantic_score, 0)) as _score FROM ((SELECT /*+ opt_param('hidden_column_visible', 'true') union_merge( books idx_title idx_author)*/__pk_increment, book_id, title, description, (match(title) against('Gatsby' in natural language mode) + match(author) against('Fitzgerald' in natural language mode)) as _keyword_score FROM test.books WHERE book_id > 0 AND (match(title) against('Gatsby' in natural language mode) OR match(author) against('Fitzgerald' in natural language mode)) ORDER BY _keyword_score DESC LIMIT 200) _fts full join (SELECT book_id, title, description, __pk_increment, _score as _semantic_score FROM (SELECT /*+ opt_param('hidden_column_visible', 'true') */*, l2_distance(vector_embedding, '[0.8, 0.1, 0.8, 0.2]') as _distance, GREATEST(match(title) against('adventure' in natural language mode) * 0.3, match(description) against('adventure' in natural language mode) * 0.5) * 0.4 as _fts_sub_score_0, GREATEST(match(title) against('story' in natural language mode) * 0.3, match(description) against('story' in natural language mode) * 0.5) * 0.2 as _fts_sub_score_1, GREATEST(match(title) against('legend' in natural language mode) * 0.3, match(description) against('legend' in natural language mode) * 0.5) * 0.3 as _fts_sub_score_2, __pk_increment, (round(1 / (1 + l2_distance(vector_embedding, '[0.8, 0.1, 0.8, 0.2]')), 8) * 1.89) as _score FROM test.books WHERE match(title) against('adventure story legend' in natural language mode) OR match(description) against('adventure story legend' in natural language mode) ORDER BY _distance APPROXIMATE LIMIT 5) _vs_sub WHERE (_fts_sub_score_0 > 0) + (_fts_sub_score_1 > 0) + (_fts_sub_score_2 > 0) >= 2) _vs on _fts.__pk_increment = _vs.__pk_increment) ORDER BY _score DESC, ifnull(_vs.__pk_increment, _fts.__pk_increment) LIMIT 0, 10
SELECT json_pretty(dbms_hybrid_search.search('books', @knn_with_msm_in_filter));
json_pretty(dbms_hybrid_search.search('books', @knn_with_msm_in_filter))
