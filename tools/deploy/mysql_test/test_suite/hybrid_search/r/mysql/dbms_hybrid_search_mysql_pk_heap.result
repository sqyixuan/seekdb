set @football_multi_match_cross = '{
  "query": {
    "multi_match": {
      "query": "non-European_style xG_expected 89.3%",
      "fields": ["technical_stats^2", "contract_details^1.5", "player_code^3"],
      "type": "cross_fields",
      "boost": 0.8
    }
  }
}';
