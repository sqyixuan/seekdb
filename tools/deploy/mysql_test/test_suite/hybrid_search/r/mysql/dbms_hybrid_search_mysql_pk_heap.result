set @football_complex_special_chars = '{
  "query": {
    "multi_match": {
      "query": "qdqx_xw1^^2xx1 | acceleration_0-30m: 3.2s | €50M/year",
      "fields": ["technical_stats^3", "contract_details^2", "player_code^1.5"],
      "type": "best_fields",
      "boost": 1.0
    }
  }
}';
SELECT dbms_hybrid_search.get_sql('football_players_multi_match', @football_complex_special_chars);
dbms_hybrid_search.get_sql('football_players_multi_match', @football_complex_special_chars)
SELECT /*+ opt_param('hidden_column_visible', 'true') */id, name, position, team, nationality, age, height_cm, weight_kg, goals_scored, assists, market_value_million, description, skills, achievements, player_code, social_media_handle, technical_stats, contract_details, player_embedding, (GREATEST(match(technical_stats) against('qdqx' in natural language mode) * 3, match(contract_details) against('qdqx' in natural language mode) * 2, match(player_code) against('qdqx' in natural language mode) * 1.5) + GREATEST(match(technical_stats) against('xw1' in natural language mode) * 3, match(contract_details) against('xw1' in natural language mode) * 2, match(player_code) against('xw1' in natural language mode) * 1.5) + GREATEST(match(technical_stats) against('2xx1' in natural language mode) * 3, match(contract_details) against('2xx1' in natural language mode) * 2, match(player_code) against('2xx1' in natural language mode) * 1.5) + GREATEST(match(technical_stats) against('acceleration' in natural language mode) * 3, match(contract_details) against('acceleration' in natural language mode) * 2, match(player_code) against('acceleration' in natural language mode) * 1.5) + GREATEST(match(technical_stats) against('0' in natural language mode) * 3, match(contract_details) against('0' in natural language mode) * 2, match(player_code) against('0' in natural language mode) * 1.5) + GREATEST(match(technical_stats) against('30m' in natural language mode) * 3, match(contract_details) against('30m' in natural language mode) * 2, match(player_code) against('30m' in natural language mode) * 1.5) + GREATEST(match(technical_stats) against('3' in natural language mode) * 3, match(contract_details) against('3' in natural language mode) * 2, match(player_code) against('3' in natural language mode) * 1.5) + GREATEST(match(technical_stats) against('2s' in natural language mode) * 3, match(contract_details) against('2s' in natural language mode) * 2, match(player_code) against('2s' in natural language mode) * 1.5) + GREATEST(match(technical_stats) against('€50M' in natural language mode) * 3, match(contract_details) against('€50M' in natural language mode) * 2, match(player_code) against('€50M' in natural language mode) * 1.5) + GREATEST(match(technical_stats) against('year' in natural language mode) * 3, match(contract_details) against('year' in natural language mode) * 2, match(player_code) against('year' in natural language mode) * 1.5)) as _score FROM test.football_players_multi_match WHERE match(technical_stats) against('qdqx xw1 2xx1 acceleration 0 30m 3 2s €50M year' in natural language mode) OR match(contract_details) against('qdqx xw1 2xx1 acceleration 0 30m 3 2s €50M year' in natural language mode) OR match(player_code) against('qdqx xw1 2xx1 acceleration 0 30m 3 2s €50M year' in natural language mode) ORDER BY _score DESC, __pk_increment LIMIT 10
SELECT dbms_hybrid_search.search('football_players_multi_match', @football_complex_special_chars);
dbms_hybrid_search.search('football_players_multi_match', @football_complex_special_chars)
