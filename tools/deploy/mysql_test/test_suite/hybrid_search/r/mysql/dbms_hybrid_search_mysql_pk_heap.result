SELECT product_id, product_name, description, brand, category, tags, price, stock_quantity, release_date, is_on_sale, vec, ((_fts_sub_score_0 + _fts_sub_score_1 + _fts_sub_score_2) * 1.5) as _score FROM (SELECT /*+ opt_param('hidden_column_visible', 'true') */*, GREATEST(match(product_name) against('SmartX' in natural language mode) * 3, match(description) against('SmartX' in natural language mode) * 2.5, match(tags) against('SmartX' in natural language mode) * 1.5) * 2 as _fts_sub_score_0, GREATEST(match(product_name) against('Phone' in natural language mode) * 3, match(description) against('Phone' in natural language mode) * 2.5, match(tags) against('Phone' in natural language mode) * 1.5) * 0.8 as _fts_sub_score_1, GREATEST(match(product_name) against('camera' in natural language mode) * 3, match(description) against('camera' in natural language mode) * 2.5, match(tags) against('camera' in natural language mode) * 1.5) * 1.2 as _fts_sub_score_2, __pk_increment FROM test.products WHERE match(product_name) against('SmartX Phone camera' in natural language mode) OR match(description) against('SmartX Phone camera' in natural language mode) OR match(tags) against('SmartX Phone camera' in natural language mode)) _fts_sub WHERE (_fts_sub_score_0 > 0) + (_fts_sub_score_1 > 0) + (_fts_sub_score_2 > 0) >= 2 ORDER BY _score DESC, __pk_increment LIMIT 10
