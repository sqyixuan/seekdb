drop table if exists products;
CREATE TABLE products (
product_id VARCHAR(50) PRIMARY KEY,
product_name VARCHAR(255),
description TEXT,
brand VARCHAR(100),
category VARCHAR(100),
tags VARCHAR(255),
price DECIMAL(10, 2),
stock_quantity INT,
release_date DATETIME,
is_on_sale TINYINT(1),
vec vector(4),
FULLTEXT INDEX idx_product_name(product_name),
FULLTEXT INDEX idx_description(description),
FULLTEXT INDEX idx_tags(tags),
vector index vec_idx(vec) with (distance=l2, type=hnsw, lib=vsag)
) ORGANIZATION HEAP;
CREATE INDEX product_id_price ON products(product_id, price);
