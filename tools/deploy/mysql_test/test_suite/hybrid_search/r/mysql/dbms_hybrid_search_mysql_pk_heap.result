set @football_multi_match_and = '{
  "query": {
    "multi_match": {
      "query": "forward goal scorer",
      "fields": ["position^2", "description^1.5", "skills^1"],
      "type": "best_fields",
      "operator": "AND",
      "boost": 1.0
    }
  }
}';
SELECT dbms_hybrid_search.get_sql('football_players_multi_match', @football_multi_match_and);
dbms_hybrid_search.get_sql('football_players_multi_match', @football_multi_match_and)
SELECT /*+ opt_param('hidden_column_visible', 'true') */id, name, position, team, nationality, age, height_cm, weight_kg, goals_scored, assists, market_value_million, description, skills, achievements, player_code, social_media_handle, technical_stats, contract_details, player_embedding, (GREATEST(match(position) against('forward' in natural language mode) * 2, match(description) against('forward' in natural language mode) * 1.5, match(skills) against('forward' in natural language mode)) + GREATEST(match(position) against('goal' in natural language mode) * 2, match(description) against('goal' in natural language mode) * 1.5, match(skills) against('goal' in natural language mode)) + GREATEST(match(position) against('scorer' in natural language mode) * 2, match(description) against('scorer' in natural language mode) * 1.5, match(skills) against('scorer' in natural language mode))) as _score FROM test.football_players_multi_match WHERE (match(position) against('forward' in natural language mode) AND match(position) against('goal' in natural language mode) AND match(position) against('scorer' in natural language mode)) OR (match(description) against('forward' in natural language mode) AND match(description) against('goal' in natural language mode) AND match(description) against('scorer' in natural language mode)) OR (match(skills) against('forward' in natural language mode) AND match(skills) against('goal' in natural language mode) AND match(skills) against('scorer' in natural language mode)) ORDER BY _score DESC, __pk_increment LIMIT 10
SELECT dbms_hybrid_search.search('football_players_multi_match', @football_multi_match_and);
dbms_hybrid_search.search('football_players_multi_match', @football_multi_match_and)
NULL
SELECT json_pretty(dbms_hybrid_search.search('football_players_multi_match', @football_multi_match_and));
json_pretty(dbms_hybrid_search.search('football_players_multi_match', @football_multi_match_and))
NULL
set @football_multi_match_or = '{
  "query": {
    "multi_match": {
      "query": "Champions League Real Madrid",
      "fields": ["team^2", "achievements^3", "description^1.5"],
      "type": "most_fields",
      "operator": "OR",
      "boost": 1.2
    }
  }
}';
SELECT dbms_hybrid_search.get_sql('football_players_multi_match', @football_multi_match_or);
dbms_hybrid_search.get_sql('football_players_multi_match', @football_multi_match_or)
SELECT /*+ opt_param('hidden_column_visible', 'true') */id, name, position, team, nationality, age, height_cm, weight_kg, goals_scored, assists, market_value_million, description, skills, achievements, player_code, social_media_handle, technical_stats, contract_details, player_embedding, ((match(team) against('Champions' in natural language mode) * 2 + match(achievements) against('Champions' in natural language mode) * 3 + match(description) against('Champions' in natural language mode) * 1.5 + match(team) against('League' in natural language mode) * 2 + match(achievements) against('League' in natural language mode) * 3 + match(description) against('League' in natural language mode) * 1.5 + match(team) against('Real' in natural language mode) * 2 + match(achievements) against('Real' in natural language mode) * 3 + match(description) against('Real' in natural language mode) * 1.5 + match(team) against('Madrid' in natural language mode) * 2 + match(achievements) against('Madrid' in natural language mode) * 3 + match(description) against('Madrid' in natural language mode) * 1.5) * 1.2) as _score FROM test.football_players_multi_match WHERE match(team) against('Champions League Real Madrid' in natural language mode) OR match(achievements) against('Champions League Real Madrid' in natural language mode) OR match(description) against('Champions League Real Madrid' in natural language mode) ORDER BY _score DESC, __pk_increment LIMIT 10
SELECT dbms_hybrid_search.search('football_players_multi_match', @football_multi_match_or);
dbms_hybrid_search.search('football_players_multi_match', @football_multi_match_or)
