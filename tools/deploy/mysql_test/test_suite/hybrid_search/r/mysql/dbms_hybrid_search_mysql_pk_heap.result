set @multiply_minimum_should_match = '{
    "query": {
      "bool": {
        "must_not": [
          {"match": {"product_name": "SmartX"}},
          {"match": {"description": "Crystal"}},
          {
            "bool": {
              "should": [
                {"match": {"description": "customizable"}},
                {"match": {"description": "Electronics"}},
                {"term" : {"brand" : "InnovateTech"}}
              ],
              "minimum_should_match" : 3
            }
          }
        ]
    }
  }
}';
set @multiply_minimum_should_match_with_per = '{
    "query": {
      "bool": {
        "must_not": [
          {"match": {"product_name": "SmartX"}},
          {"match": {"description": "Crystal"}},
          {
            "bool": {
              "should": [
                {"match": {"description": "customizable"}},
                {"match": {"description": "Electronics"}},
                {"term" : {"brand" : "InnovateTech"}}
              ],
              "minimum_should_match" : "130%"
            }
          }
        ]
    }
  }
}';
SELECT dbms_hybrid_search.get_sql('products', @multiply_minimum_should_match);
dbms_hybrid_search.get_sql('products', @multiply_minimum_should_match)
SELECT /*+ opt_param('hidden_column_visible', 'true') union_merge( products idx_product_name idx_description idx_description idx_description)*/product_id, product_name, description, brand, category, tags, price, stock_quantity, release_date, is_on_sale, vec, 0 as _score FROM test.products WHERE NOT (match(product_name) against('SmartX' in natural language mode) OR match(description) against('Crystal' in natural language mode) OR (match(description) against('customizable' in natural language mode) AND match(description) against('Electronics' in natural language mode) AND brand = 'InnovateTech')) ORDER BY __pk_increment LIMIT 10
SELECT dbms_hybrid_search.search('products', @multiply_minimum_should_match);
dbms_hybrid_search.search('products', @multiply_minimum_should_match)
