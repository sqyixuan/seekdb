  "query": {
    "bool": {
      "must": [
        {
          "multi_match": {
            "query": "defender leadership",
            "fields": ["position^2", "skills^1.5", "description^1"],
            "type": "cross_fields",
            "operator": "AND",
            "boost": 1.0
          }
        },
        {
          "term": {
            "nationality": "Germany"
          }
        }
      ]
    }
  },
  "knn": {
    "field": "player_embedding",
    "query_vector": [0.3, 0.7, 0.1, 0.9, 0.2],
    "k": 4,
    "num_candidates": 12,
    "boost": 0.6
  }
}';
