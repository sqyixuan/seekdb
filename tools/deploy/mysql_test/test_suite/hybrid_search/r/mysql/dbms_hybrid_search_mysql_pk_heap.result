  "query": {
    "bool": {
      "should": [
        {"match": {"product_name": "SmartX"}},
        {"match" : {"description": "amazing"}},
        {"term" : {"product_name": "Aura Wireless Headphones"}}
      ]
    }
  }
}';
SELECT dbms_hybrid_search.get_sql('products', @query_str_should);
dbms_hybrid_search.get_sql('products', @query_str_should)
