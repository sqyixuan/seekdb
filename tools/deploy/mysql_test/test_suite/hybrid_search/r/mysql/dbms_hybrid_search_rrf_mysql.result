set @rrf_query_param = '{
  "query": {
    "query_string": {
      "fields": ["title", "author", "description"],
      "query": "fiction American Dream"
    }
  },
  "knn" : {
    "field": "vector_embedding",
    "k": 5,
    "query_vector": [0.1, 0.2, 0.3, 0.4]
  },
  "rank" : {
    "rrf" : {
      "rank_window_size" : 10,
      "rank_constant" : 60
    }
  }
}';
SELECT dbms_hybrid_search.get_sql('books', @rrf_query_param);
dbms_hybrid_search.get_sql('books', @rrf_query_param)
SELECT ifnull(_fts.book_id, _vs.book_id) as book_id, ifnull(_fts.title, _vs.title) as title, ifnull(_fts.author, _vs.author) as author, ifnull(_fts.category, _vs.category) as category, ifnull(_fts.description, _vs.description) as description, ifnull(_fts.price, _vs.price) as price, ifnull(_fts.vector_embedding, _vs.vector_embedding) as vector_embedding, (ifnull(1 / (_fts._keyword_rank + 60), 0) + ifnull(1 / (_vs._semantic_rank + 60), 0)) as _score FROM ((SELECT *, RANK() over( ORDER BY _keyword_score DESC) as _keyword_rank FROM (SELECT /*+ opt_param('hidden_column_visible', 'true') */__pk_increment, book_id, title, author, category, description, price, vector_embedding, GREATEST(match(title) against('fiction American Dream' in natural language mode), match(author) against('fiction American Dream' in natural language mode), match(description) against('fiction American Dream' in natural language mode)) as _keyword_score FROM test.books WHERE match(title) against('fiction American Dream' in natural language mode) OR match(author) against('fiction American Dream' in natural language mode) OR match(description) against('fiction American Dream' in natural language mode) ORDER BY _keyword_score DESC LIMIT 200) ) _fts full join (SELECT *, RANK() over( ORDER BY _semantic_score DESC) as _semantic_rank FROM (SELECT /*+ opt_param('hidden_column_visible', 'true') */l2_distance(vector_embedding, '[0.1, 0.2, 0.3, 0.4]') as _distance, __pk_increment, book_id, title, author, category, description, price, vector_embedding, round(1 / (1 + l2_distance(vector_embedding, '[0.1, 0.2, 0.3, 0.4]')), 8) as _semantic_score FROM test.books ORDER BY _distance APPROXIMATE LIMIT 5) ) _vs on _fts.__pk_increment = _vs.__pk_increment) ORDER BY _score DESC, ifnull(_vs.__pk_increment, _fts.__pk_increment) LIMIT 10
SELECT json_pretty(dbms_hybrid_search.search('books', @rrf_query_param));
json_pretty(dbms_hybrid_search.search('books', @rrf_query_param))
