dbms_hybrid_search.get_sql('t1_hash_range', @t1_multi_vec_query)
SELECT `id`, `part_key1`, `part_key2`, `subpart_key`, `__pk_increment`, sum(`_score`) as `_score` FROM ((SELECT /*+ opt_param('hidden_column_visible', 'true') */*, l2_distance(`vector_emb`, '[0.1234, 0.2345, 0.3456, 0.4567]') as `_distance`, `__pk_increment`, `part_key1` as `_part_col_0`, `part_key2` as `_part_col_1`, `subpart_key` as `_part_col_2`, round(1 / (1 + l2_distance(`vector_emb`, '[0.1234, 0.2345, 0.3456, 0.4567]')), 8) as `_score` FROM `test`.`t1_hash_range` ORDER BY `_distance` APPROXIMATE LIMIT 3) UNION ALL (SELECT /*+ opt_param('hidden_column_visible', 'true') */*, l2_distance(`vector_emb`, '[0.5678, 0.6789, 0.789, 0.8901]') as `_distance`, `__pk_increment`, `part_key1` as `_part_col_0`, `part_key2` as `_part_col_1`, `subpart_key` as `_part_col_2`, round(1 / (1 + l2_distance(`vector_emb`, '[0.5678, 0.6789, 0.789, 0.8901]')), 8) as `_score` FROM `test`.`t1_hash_range` ORDER BY `_distance` APPROXIMATE LIMIT 5)) GROUP BY `_part_col_0`, `_part_col_1`, `_part_col_2`, `__pk_increment` ORDER BY `_score` DESC LIMIT 5
select dbms_hybrid_search.get_sql('t1_hash_range', @t1_hybrid_query);
dbms_hybrid_search.get_sql('t1_hash_range', @t1_hybrid_query)
SELECT ifnull(`_fts`.`id`, `_vs`.`id`) as `id`, ifnull(`_fts`.`part_key1`, `_vs`.`part_key1`) as `part_key1`, ifnull(`_fts`.`part_key2`, `_vs`.`part_key2`) as `part_key2`, ifnull(`_fts`.`subpart_key`, `_vs`.`subpart_key`) as `subpart_key`, ifnull(`_fts`.`__pk_increment`, `_vs`.`__pk_increment`) as `__pk_increment`, (ifnull(`_fts`.`_keyword_score`, 0) + ifnull(`_vs`.`_semantic_score`, 0)) as `_score` FROM ((SELECT /*+ opt_param('hidden_column_visible', 'true') */`__pk_increment`, `part_key1` as `_part_col_0`, `part_key2` as `_part_col_1`, `subpart_key` as `_part_col_2`, `id`, `part_key1`, `part_key2`, `subpart_key`, GREATEST(match(`title`) against('fiction adventure story' in natural language mode), match(`content`) against('fiction adventure story' in natural language mode)) as `_keyword_score` FROM `test`.`t1_hash_range` WHERE match(`title`) against('fiction adventure story' in natural language mode) OR match(`content`) against('fiction adventure story' in natural language mode) ORDER BY `_keyword_score` DESC LIMIT 100) `_fts` full join (SELECT `id`, `part_key1`, `part_key2`, `subpart_key`, `_part_col_0`, `_part_col_1`, `_part_col_2`, `__pk_increment`, sum(`_score`) as `_semantic_score` FROM ((SELECT /*+ opt_param('hidden_column_visible', 'true') */*, l2_distance(`vector_emb`, '[0.1234, 0.2345, 0.3456, 0.4567]') as `_distance`, `__pk_increment`, `part_key1` as `_part_col_0`, `part_key2` as `_part_col_1`, `subpart_key` as `_part_col_2`, round(1 / (1 + l2_distance(`vector_emb`, '[0.1234, 0.2345, 0.3456, 0.4567]')), 8) as `_score` FROM `test`.`t1_hash_range` ORDER BY `_distance` APPROXIMATE LIMIT 3) UNION ALL (SELECT /*+ opt_param('hidden_column_visible', 'true') */*, l2_distance(`vector_emb`, '[0.5678, 0.6789, 0.789, 0.8901]') as `_distance`, `__pk_increment`, `part_key1` as `_part_col_0`, `part_key2` as `_part_col_1`, `subpart_key` as `_part_col_2`, round(1 / (1 + l2_distance(`vector_emb`, '[0.5678, 0.6789, 0.789, 0.8901]')), 8) as `_score` FROM `test`.`t1_hash_range` ORDER BY `_distance` APPROXIMATE LIMIT 5)) GROUP BY `_part_col_0`, `_part_col_1`, `_part_col_2`, `__pk_increment` ORDER BY `_score` DESC) `_vs` on `_fts`.`_part_col_0` = `_vs`.`_part_col_0` AND `_fts`.`_part_col_1` = `_vs`.`_part_col_1` AND `_fts`.`_part_col_2` = `_vs`.`_part_col_2` AND `_fts`.`__pk_increment` = `_vs`.`__pk_increment`) ORDER BY `_score` DESC, ifnull(`_vs`.`__pk_increment`, `_fts`.`__pk_increment`) LIMIT 5
select dbms_hybrid_search.search('t1_hash_range', @t1_fts_query);
dbms_hybrid_search.search('t1_hash_range', @t1_fts_query)
