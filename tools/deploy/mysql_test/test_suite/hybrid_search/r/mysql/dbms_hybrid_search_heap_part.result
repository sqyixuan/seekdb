drop table if exists t10_year_expr;
create table t10_year_expr (
id int,
part_key date,
title varchar(200),
content text,
vector_emb vector(4),
fulltext index idx_title(title),
fulltext index idx_content(content),
vector index idx_vector(vector_emb) with (distance=l2, type=hnsw, lib=vsag)
) ORGANIZATION HEAP partition by range(year(part_key) + 1)
subpartition by hash(day(part_key)) subpartitions 3 (
partition p0 values less than (2020),
partition p1 values less than (2025),
partition p2 values less than maxvalue);
