select dbms_hybrid_search.get_sql('t1_hash_range', @t1_fts_query);
dbms_hybrid_search.get_sql('t1_hash_range', @t1_fts_query)
SELECT /*+ opt_param('hidden_column_visible', 'true') */`id`, `part_key1`, `part_key2`, `subpart_key`, `__pk_increment`, GREATEST(match(`title`) against('fiction adventure story' in natural language mode), match(`content`) against('fiction adventure story' in natural language mode)) as `_score` FROM `test`.`t1_hash_range` WHERE match(`title`) against('fiction adventure story' in natural language mode) OR match(`content`) against('fiction adventure story' in natural language mode) ORDER BY `_score` DESC, `__pk_increment` LIMIT 5
select dbms_hybrid_search.get_sql('t1_hash_range', @t1_vec_query1);
dbms_hybrid_search.get_sql('t1_hash_range', @t1_vec_query1)
SELECT l2_distance(`vector_emb`, '[0.1234, 0.2345, 0.3456, 0.4567]') as `_distance`, `id`, `part_key1`, `part_key2`, `subpart_key`, `__pk_increment`, round(1 / (1 + l2_distance(`vector_emb`, '[0.1234, 0.2345, 0.3456, 0.4567]')), 8) as `_score` FROM `test`.`t1_hash_range` ORDER BY `_distance` APPROXIMATE LIMIT 3
select dbms_hybrid_search.get_sql('t1_hash_range', @t1_vec_query2);
dbms_hybrid_search.get_sql('t1_hash_range', @t1_vec_query2)
SELECT l2_distance(`vector_emb`, '[0.5678, 0.6789, 0.789, 0.8901]') as `_distance`, `id`, `part_key1`, `part_key2`, `subpart_key`, `__pk_increment`, round(1 / (1 + l2_distance(`vector_emb`, '[0.5678, 0.6789, 0.789, 0.8901]')), 8) as `_score` FROM `test`.`t1_hash_range` ORDER BY `_distance` APPROXIMATE LIMIT 5
