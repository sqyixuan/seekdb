drop table if exists t3_range_hash;
create table t3_range_hash (
id int,
part_key1 int,
part_key2 int,
subpart_key int,
title varchar(200),
content text,
vector_emb vector(4),
fulltext index idx_title(title),
fulltext index idx_content(content),
vector index idx_vector(vector_emb) with (distance=l2, type=hnsw, lib=vsag)
) ORGANIZATION HEAP partition by range(part_key1 * part_key2)
subpartition by hash(subpart_key) subpartitions 3 (
partition p0 values less than (1000),
partition p1 values less than (5000),
partition p2 values less than maxvalue);
insert into t3_range_hash values
(1, 10, 20, 1, 'Literature Review', 'Classic literature analysis', '[0.1,0.2,0.3,0.4]'),
