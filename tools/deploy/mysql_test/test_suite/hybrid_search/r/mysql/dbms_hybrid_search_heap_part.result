drop table if exists t12_complex_date_expr;
create table t12_complex_date_expr (
id int,
part_key datetime,
title varchar(200),
content text,
vector_emb vector(4),
fulltext index idx_title(title),
fulltext index idx_content(content),
vector index idx_vector(vector_emb) with (distance=l2, type=hnsw, lib=vsag)
) ORGANIZATION HEAP partition by range(year(part_key) * 10 + month(part_key))
subpartition by hash(day(part_key) + hour(part_key)) subpartitions 3 (
partition p0 values less than (20200),
partition p1 values less than (20250),
partition p2 values less than maxvalue);
