drop table if exists t13_same_col_diff_expr;
create table t13_same_col_diff_expr (
id int,
part_key int,
title varchar(200),
content text,
vector_emb vector(4),
fulltext index idx_title(title),
fulltext index idx_content(content),
vector index idx_vector(vector_emb) with (distance=l2, type=hnsw, lib=vsag)
) ORGANIZATION HEAP partition by hash(part_key + 10) partitions 2
subpartition by range(part_key * 2) subpartition template (
subpartition sp0 values less than (100),
subpartition sp1 values less than (200),
subpartition sp2 values less than maxvalue);
