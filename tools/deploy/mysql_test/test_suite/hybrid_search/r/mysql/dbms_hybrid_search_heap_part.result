drop table if exists t11_todays_expr;
create table t11_todays_expr (
id int,
part_key date,
subpart_key date,
title varchar(200),
content text,
vector_emb vector(4),
fulltext index idx_title(title),
fulltext index idx_content(content),
vector index idx_vector(vector_emb) with (distance=l2, type=hnsw, lib=vsag)
) ORGANIZATION HEAP partition by hash(to_days(part_key)) partitions 2
subpartition by range(month(subpart_key)) subpartition template (
subpartition sp0 values less than (4),
subpartition sp1 values less than (7),
subpartition sp2 values less than (10),
subpartition sp3 values less than maxvalue);
