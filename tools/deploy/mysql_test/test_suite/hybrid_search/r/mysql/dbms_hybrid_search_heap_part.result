t3_range_hash` ORDER BY `_distance` APPROXIMATE LIMIT 5)) GROUP BY `_part_col_0`, `_part_col_1`, `_part_col_2`, `__pk_increment` ORDER BY `_score` DESC) `_vs` on `_fts`.`_part_col_0` = `_vs`.`_part_col_0` AND `_fts`.`_part_col_1` = `_vs`.`_part_col_1` AND `_fts`.`_part_col_2` = `_vs`.`_part_col_2` AND `_fts`.`__pk_increment` = `_vs`.`__pk_increment`) ORDER BY `_score` DESC, ifnull(`_vs`.`__pk_increment`, `_fts`.`__pk_increment`) LIMIT 5
