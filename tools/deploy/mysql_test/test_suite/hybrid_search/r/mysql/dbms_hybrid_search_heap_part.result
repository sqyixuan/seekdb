drop table if exists t8_list_cols_hash;
create table t8_list_cols_hash (
id int,
part_key1 int,
part_key2 varchar(50),
subpart_key int,
title varchar(200),
content text,
vector_emb vector(4),
fulltext index idx_title(title),
fulltext index idx_content(content),
vector index idx_vector(vector_emb) with (distance=l2, type=hnsw, lib=vsag)
) ORGANIZATION HEAP partition by list columns(part_key1, part_key2)
subpartition by hash(subpart_key) subpartitions 3 (
partition p0 values in ((1, 'x'), (2, 'y')),
partition p1 values in ((3, 'z'), (4, 'w')),
partition p2 values in ((5, 'v'), (6, 'u')));
