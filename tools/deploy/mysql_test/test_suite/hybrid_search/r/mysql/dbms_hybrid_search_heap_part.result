# ----------------------------------------------------------------------
# Test of hybrid search in heap table with partitions.
# ----------------------------------------------------------------------
alter system set _enable_index_merge=false;
drop table if exists t1_hash_range;
create table t1_hash_range (
id int,
part_key1 int,
part_key2 int,
subpart_key int,
title varchar(200),
content text,
vector_emb vector(4),
fulltext index idx_title(title),
fulltext index idx_content(content),
vector index idx_vector(vector_emb) with (distance=l2, type=hnsw, lib=vsag)
) ORGANIZATION HEAP partition by hash(part_key1 + part_key2) partitions 2
subpartition by range(subpart_key) subpartition template (
subpartition sp0 values less than (100),
subpartition sp1 values less than (200),
subpartition sp2 values less than maxvalue);
insert into t1_hash_range values
(1, 10, 20, 50, 'Fiction Novel', 'A great fiction story about adventure', '[0.1,0.2,0.3,0.4]'),
(2, 10, 20, 150, 'Science Book', 'Introduction to quantum physics', '[0.5,0.6,0.7,0.8]'),
(3, 30, 40, 250, 'History Book', 'World war history', '[0.9,0.1,0.2,0.3]'),
(4, 30, 40, 50, 'Math Book', 'Advanced calculus', '[0.4,0.5,0.6,0.7]'),
(5, 50, 60, 150, 'Art Book', 'Renaissance art history', '[0.8,0.9,0.1,0.2]'),
(6, 10, 20, 80, 'Mystery Thriller', 'Suspenseful detective investigation', '[0.2,0.3,0.4,0.5]'),
(7, 10, 20, 120, 'Romance Story', 'Love and relationships narrative', '[0.3,0.4,0.5,0.6]'),
(8, 30, 40, 180, 'Biography Memoir', 'Personal life experiences', '[0.6,0.7,0.8,0.9]'),
(9, 30, 40, 220, 'Science Fiction', 'Future technology and space', '[0.7,0.8,0.9,0.1]'),
(10, 50, 60, 100, 'Poetry Collection', 'Emotional verses and rhymes', '[0.2,0.4,0.6,0.8]'),
(11, 50, 60, 200, 'Cookbook Guide', 'Recipes and cooking techniques', '[0.1,0.3,0.5,0.7]'),
(12, 70, 80, 60, 'Travel Guide', 'Destination recommendations', '[0.4,0.6,0.8,0.2]'),
(13, 70, 80, 140, 'Self Help Book', 'Personal development strategies', '[0.5,0.7,0.9,0.3]'),
(14, 90, 100, 90, 'Children Story', 'Fairy tales and adventures', '[0.3,0.5,0.7,0.9]'),
(15, 90, 100, 160, 'Business Guide', 'Entrepreneurship and management', '[0.6,0.8,0.2,0.4]');
set @t1_fts_query = '{
  "query": {
    "query_string": {
      "fields": ["title", "content"],
      "query": "fiction adventure story",
      "minimum_should_match": 2
    }
  },
  "_source": ["id", "part_key1", "part_key2", "subpart_key", "__pk_increment"],
  "size": 5
}';
set @t1_vec_query1 = '{
  "knn": {
    "field": "vector_emb",
    "k": 3,
    "query_vector": [0.1234, 0.2345, 0.3456, 0.4567]
  },
  "_source": ["id", "part_key1", "part_key2", "subpart_key", "__pk_increment"],
  "size": 3
}';
set @t1_vec_query2 = '{
  "knn": {
    "field": "vector_emb",
    "k": 5,
    "query_vector": [0.5678, 0.6789, 0.7890, 0.8901]
  },
  "_source": ["id", "part_key1", "part_key2", "subpart_key", "__pk_increment"],
  "size": 5
}';
set @t1_multi_vec_query = '{
  "knn": [
    {
      "field": "vector_emb",
      "k": 3,
      "query_vector": [0.1234, 0.2345, 0.3456, 0.4567]
    },
    {
      "field": "vector_emb",
      "k": 5,
      "query_vector": [0.5678, 0.6789, 0.7890, 0.8901]
    }
  ],
  "_source": ["id", "part_key1", "part_key2", "subpart_key", "__pk_increment"],
  "size": 5
}';
set @t1_hybrid_query = '{
  "query": {
    "query_string": {
      "fields": ["title", "content"],
      "query": "fiction adventure story",
      "minimum_should_match": 2
