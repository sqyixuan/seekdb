set @books_query_string_and_es_mode = '{
  "query": {
    "query_string": {
      "fields": ["title", "author", "category", "description"],
      "query": "Great Gatsby",
      "type": "most_fields",
      "default_operator": "AND"
    }
  },
  "_source": ["book_id", "title", "author"],
  "es_mode": true
}';
SELECT dbms_hybrid_search.get_sql('books', @books_query_string_and_es_mode);
dbms_hybrid_search.get_sql('books', @books_query_string_and_es_mode)
SELECT /*+ opt_param('hidden_column_visible', 'true') */book_id, title, author, (match(title) against('Great' in natural language mode) + match(author) against('Great' in natural language mode) + match(category) against('Great' in natural language mode) + match(description) against('Great' in natural language mode) + match(title) against('Gatsby' in natural language mode) + match(author) against('Gatsby' in natural language mode) + match(category) against('Gatsby' in natural language mode) + match(description) against('Gatsby' in natural language mode)) as _score FROM test.books WHERE (match(title) against('Great' in natural language mode) AND match(title) against('Gatsby' in natural language mode)) OR (match(author) against('Great' in natural language mode) AND match(author) against('Gatsby' in natural language mode)) OR (match(category) against('Great' in natural language mode) AND match(category) against('Gatsby' in natural language mode)) OR (match(description) against('Great' in natural language mode) AND match(description) against('Gatsby' in natural language mode)) ORDER BY _score DESC, __pk_increment LIMIT 10
set @books_query_string_cross_fields_es_mode = '{
  "query": {
    "query_string": {
      "fields": ["title", "author", "category", "description"],
      "query": "Great Gatsby",
      "type": "cross_fields",
      "default_operator": "OR",
      "minimum_should_match" : 2
    }
  },
  "_source": ["book_id", "title", "author"],
  "es_mode": true
}';
SELECT dbms_hybrid_search.get_sql('books', @books_query_string_cross_fields_es_mode);
dbms_hybrid_search.get_sql('books', @books_query_string_cross_fields_es_mode)
SELECT /*+ opt_param('hidden_column_visible', 'true') */book_id, title, author, (GREATEST(match(title) against('Great' in natural language mode), match(author) against('Great' in natural language mode), match(category) against('Great' in natural language mode), match(description) against('Great' in natural language mode)) + GREATEST(match(title) against('Gatsby' in natural language mode), match(author) against('Gatsby' in natural language mode), match(category) against('Gatsby' in natural language mode), match(description) against('Gatsby' in natural language mode))) as _score FROM test.books WHERE (match(title) against('Great' in natural language mode) OR match(author) against('Great' in natural language mode) OR match(category) against('Great' in natural language mode) OR match(description) against('Great' in natural language mode)) AND (match(title) against('Gatsby' in natural language mode) OR match(author) against('Gatsby' in natural language mode) OR match(category) against('Gatsby' in natural language mode) OR match(description) against('Gatsby' in natural language mode)) ORDER BY _score DESC, __pk_increment LIMIT 10
set @books_query_string_cross_fields_es_mode = '{
  "query": {
    "query_string": {
      "fields": ["title", "author", "category", "description"],
      "query": "Great Gatsby",
      "type": "phrase",
      "default_operator": "OR",
      "minimum_should_match" : 2
    }
  },
  "_source": ["book_id", "title", "author"],
  "es_mode": true
}';
SELECT dbms_hybrid_search.get_sql('books', @books_query_string_cross_fields_es_mode);
dbms_hybrid_search.get_sql('books', @books_query_string_cross_fields_es_mode)
SELECT /*+ opt_param('hidden_column_visible', 'true') */book_id, title, author, GREATEST(match(title) against('Great Gatsby' in match phrase mode), match(author) against('Great Gatsby' in match phrase mode), match(category) against('Great Gatsby' in match phrase mode), match(description) against('Great Gatsby' in match phrase mode)) as _score FROM test.books WHERE match(title) against('Great Gatsby' in match phrase mode) OR match(author) against('Great Gatsby' in match phrase mode) OR match(category) against('Great Gatsby' in match phrase mode) OR match(description) against('Great Gatsby' in match phrase mode) ORDER BY _score DESC, __pk_increment LIMIT 10
