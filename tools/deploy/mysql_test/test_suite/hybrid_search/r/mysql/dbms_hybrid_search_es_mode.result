set @football_multi_match_phrase = '{
  "query": {
    "multi_match": {
      "query": "Contract: 2024-2027 Salary: $50M/year",
      "fields": ["contract_details^2", "technical_stats^1.5", "social_media_handle^1"],
      "type": "phrase",
      "boost": 1.0
    }
  },
  "_source": ["id", "name", "position", "age", "team"],
  "es_mode": true
}';
SELECT dbms_hybrid_search.get_sql('football_players', @football_multi_match_phrase);
dbms_hybrid_search.get_sql('football_players', @football_multi_match_phrase)
SELECT /*+ opt_param('hidden_column_visible', 'true') */id, name, position, age, team, (GREATEST(match(contract_details) against('Contract' in match phrase mode) * 2, match(technical_stats) against('Contract' in match phrase mode) * 1.5, match(social_media_handle) against('Contract' in match phrase mode)) + GREATEST(match(contract_details) against('2024' in match phrase mode) * 2, match(technical_stats) against('2024' in match phrase mode) * 1.5, match(social_media_handle) against('2024' in match phrase mode)) + GREATEST(match(contract_details) against('2027' in match phrase mode) * 2, match(technical_stats) against('2027' in match phrase mode) * 1.5, match(social_media_handle) against('2027' in match phrase mode)) + GREATEST(match(contract_details) against('Salary' in match phrase mode) * 2, match(technical_stats) against('Salary' in match phrase mode) * 1.5, match(social_media_handle) against('Salary' in match phrase mode)) + GREATEST(match(contract_details) against('50M' in match phrase mode) * 2, match(technical_stats) against('50M' in match phrase mode) * 1.5, match(social_media_handle) against('50M' in match phrase mode)) + GREATEST(match(contract_details) against('year' in match phrase mode) * 2, match(technical_stats) against('year' in match phrase mode) * 1.5, match(social_media_handle) against('year' in match phrase mode))) as _score FROM test.football_players WHERE match(contract_details) against('Contract 2024 2027 Salary 50M year' in natural language mode) OR match(technical_stats) against('Contract 2024 2027 Salary 50M year' in natural language mode) OR match(social_media_handle) against('Contract 2024 2027 Salary 50M year' in natural language mode) ORDER BY _score DESC, __pk_increment LIMIT 10
SELECT dbms_hybrid_search.search('football_players', @football_multi_match_phrase);
dbms_hybrid_search.search('football_players', @football_multi_match_phrase)
