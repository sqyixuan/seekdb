SELECT /*+ opt_param('hidden_column_visible', 'true') */id, name, position, age, team, ((GREATEST(match(technical_stats) against('non' in natural language mode) * 2, match(contract_details) against('non' in natural language mode) * 1.5, match(player_code) against('non' in natural language mode) * 3) + GREATEST(match(technical_stats) against('European' in natural language mode) * 2, match(contract_details) against('European' in natural language mode) * 1.5, match(player_code) against('European' in natural language mode) * 3) + GREATEST(match(technical_stats) against('style' in natural language mode) * 2, match(contract_details) against('style' in natural language mode) * 1.5, match(player_code) against('style' in natural language mode) * 3) + GREATEST(match(technical_stats) against('xG' in natural language mode) * 2, match(contract_details) against('xG' in natural language mode) * 1.5, match(player_code) against('xG' in natural language mode) * 3) + GREATEST(match(technical_stats) against('expected' in natural language mode) * 2, match(contract_details) against('expected' in natural language mode) * 1.5, match(player_code) against('expected' in natural language mode) * 3) + GREATEST(match(technical_stats) against('89' in natural language mode) * 2, match(contract_details) against('89' in natural language mode) * 1.5, match(player_code) against('89' in natural language mode) * 3) + GREATEST(match(technical_stats) against('3' in natural language mode) * 2, match(contract_details) against('3' in natural language mode) * 1.5, match(player_code) against('3' in natural language mode) * 3)) * 0.8) as _score FROM test.football_players WHERE match(technical_stats) against('non European style xG expected 89 3' in natural language mode) OR match(contract_details) against('non European style xG expected 89 3' in natural language mode) OR match(player_code) against('non European style xG expected 89 3' in natural language mode) ORDER BY _score DESC, __pk_increment LIMIT 10
