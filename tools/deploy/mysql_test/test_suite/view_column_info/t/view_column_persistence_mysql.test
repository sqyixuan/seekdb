# descriotion: 
# 验证mysql模式下的视图列元信息


--result_format 4

#single table

--disable_warnings
drop table if exists t1, t2, t5;
drop view if exists v1, t1, t5;
--enable_warnings

create table t1 (c1 int);
create view v1 as select * from t1;

select * from information_schema.columns where TABLE_SCHEMA = 'TEST' AND TABLE_NAME = 'T1';
select * from information_schema.columns where TABLE_SCHEMA = 'TEST' AND TABLE_NAME = 'V1';

drop table t1;
select * from information_schema.columns where TABLE_SCHEMA = 'TEST' AND TABLE_NAME = 'V1';
create table t1 (c1 date);
select * from information_schema.columns where TABLE_SCHEMA = 'TEST' AND TABLE_NAME = 'V1';


drop table t1;
drop view v1;
create table t1 (c1 int, c2 int);
create view v1 as select * from t1;
select * from information_schema.columns where TABLE_SCHEMA = 'TEST' AND TABLE_NAME = 'V1';
drop table t1;
create table t1 (c1 date, c2 varchar(20));
select * from information_schema.columns where TABLE_SCHEMA = 'TEST' AND TABLE_NAME = 'V1';


drop table t1;
drop view v1;
--disable_warnings
drop view if exists v2;
--enable_warnings
create table t1 (c1 int);
create view v1 as select * from t1;
create view v2 as select * from v1;
select * from information_schema.columns where TABLE_SCHEMA = 'TEST' AND TABLE_NAME = 'V1';
select * from information_schema.columns where TABLE_SCHEMA = 'TEST' AND TABLE_NAME = 'V2';

drop table t1;
create table t1 (c1 date);
select * from information_schema.columns where TABLE_SCHEMA = 'TEST' AND TABLE_NAME = 'V1';
select * from information_schema.columns where TABLE_SCHEMA = 'TEST' AND TABLE_NAME = 'V2';

drop table t1;
drop view v1;
drop view v2;
--disable_warnings
drop function if exists f1;
--enable_warnings
CREATE FUNCTION f1(i INT) RETURNS INT RETURN i+1;
create view v1 as select f1(1) c1 from dual;
select * from information_schema.columns where TABLE_SCHEMA = 'TEST' AND TABLE_NAME = 'V1';
drop function f1;
select * from information_schema.columns where TABLE_SCHEMA = 'TEST' AND TABLE_NAME = 'V1';
CREATE FUNCTION f1(i INT) RETURNS INT RETURN i+1;
select * from information_schema.columns where TABLE_SCHEMA = 'TEST' AND TABLE_NAME = 'V1';
drop function f1;
drop view v1;

create table t2(c1 int);

create view t1 as select * from t2;

rename table t1 to t5, t2 to t1;

drop view t5;
drop table t1;

--disable_warnings
drop function if exists pkt_2;
drop function if exists pkt_1;
drop table if exists t3;
--enable_warnings
create function pkt_2() returns int return pkt_1();
create function pkt_1() returns int return (select max(c1) FROM t3 );
create view t3 as select pkt_2() c1 from dual;
--error ER_SP_NO_RECURSION
select  pkt_1();
drop view t3;
create table t3(c1 int);

drop table t3;
drop function pkt_2;
drop function pkt_1;