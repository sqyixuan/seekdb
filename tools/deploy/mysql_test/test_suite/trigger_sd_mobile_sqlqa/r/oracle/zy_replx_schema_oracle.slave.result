# 清理环境
drop user u_replx cascade;
drop user u_common cascade;
# 创建测试用户
create user u_replx IDENTIFIED BY ali1234;
grant all on *.* to u_replx WITH GRANT OPTION;
grant dba to u_replx;
grant all privileges to u_replx;
create user u_common IDENTIFIED BY ali1234;
grant all on *.* to u_common WITH GRANT OPTION;
grant dba to u_common;
grant all privileges to u_common;
