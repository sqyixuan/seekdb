# 切换u_replx账户执行测试用例
CREATE TABLE "REPLX_LOG" 
("REGION" NUMBER(4,0), 
"INSTANCE_ID" NUMBER(2,0), 
"SEQNUM" NUMBER(14,0), 
"TABLE_OWNER" VARCHAR2(32), 
"TABLE_NAME" VARCHAR2(64), 
"OPERATION" CHAR(1), 
"HASH_VAL" NUMBER(4,0), 
"ROW_ID" VARCHAR2(128), 
"PKEY" VARCHAR2(1024), 
"PRIORITY" NUMBER(2,0), 
"SCN" NUMBER(14,0), 
"SRC_DB" VARCHAR2(32), 
"DST_DB" VARCHAR2(32), 
"INTIME" DATE DEFAULT sysdate
) 
PARTITION BY LIST ("INSTANCE_ID") 
(PARTITION "REPLX_LOG_1"  VALUES (1) , 
PARTITION "REPLX_LOG_2"  VALUES (2) , 
PARTITION "REPLX_LOG_10"  VALUES (10) , 
PARTITION "REPLX_LOG_20"  VALUES (20) ) ;
CREATE TABLE "REPLICATE_SWITCH" 
("INSTANCE_ID" NUMBER(2,0), 
"SWITCH_FLAG" NUMBER(1,0), 
"POLL_INTERVAL" NUMBER(4,0), 
"SWITCH_TIME" DATE, 
"MEMO" VARCHAR2(256)
);
CREATE SEQUENCE "REPLX_SEQ"  MINVALUE 1 MAXVALUE 9999999999999 INCREMENT BY 1 START WITH 9539211 CACHE 20000 NOORDER  CYCLE ;
result_format: 4
#########  依赖的package  #########
CREATE OR REPLACE PACKAGE "PKG_REPLX_EVT" is
    -- Author  : L39860
    -- Created : 2005-10-20 10:17:58
    -- Purpose :
    procedure InsertLog(
        row_id in varchar2, --rowid
        towner in varchar2, --Table owner
        tname  in varchar2, --The table name
        operation in char,  --'IDU'
        key    in varchar2,
        hash_val in number, --Table hash value
        region in varchar2 := '300', --Region
        priority in number := 0
    );

    procedure SetTriggerFlag(flag in number);
    procedure SetSrcDBName(src_db in varchar2);
end pkg_replx_evt;
//
CREATE OR REPLACE PACKAGE BODY "PKG_REPLX_EVT" is
    --日志切换参数
    DateNow  date;  --当前时间
    NextTime date;  --下此刷新时间
    CurSID   number(2); --
    PollGAP  number(4);
    SwitchFlag number(1);
    instance_number number(2);
    db_name varchar2(32);
    if_trigger binary_integer;


    procedure InitParam;
    procedure InsertLog(
        row_id in varchar2, --rowid
        towner in varchar2, --table_owner
        tname  in varchar2, --The table name
        operation in char,  --'IDU'
        key    in varchar2,
        hash_val in number, --Table hash value
        region in varchar2, --Region
        priority in number
    )is
    begin
        if 0 = if_trigger then
            return;
        end if;

        DateNow := sysdate;
        if DateNow > NextTime then
            InitParam;
        end if;


        insert into replx_log
            (region, table_owner, table_name, operation, hash_val,
             row_id, pkey, instance_id,
             seqnum, priority, scn, src_db, intime)
        values
            (region, towner, tname, operation, hash_val,
             row_id, key, CurSID,
             replx_seq.nextval, priority, 0, db_name, DateNow);
    end;


    procedure SetTriggerFlag(flag in number)
    as
    begin
        if_trigger := flag;
    end;


    procedure SetSrcDBName(src_db in varchar2)
    as
    begin
        db_name := src_db;
    end;

    procedure InitParam
    is
    begin
        begin
            select switch_flag, poll_interval
              into SwitchFlag, PollGAP
              from replicate_switch
             where instance_id=instance_number and rownum<2;

            exception
                when others then
                    NextTime := DateNow+(1/24);
                    return;
        end;

        if SwitchFlag = 0 then
            CurSID := instance_number;
        else
            CurSID := instance_number*10;
        end if;
        NextTime := DateNow+(PollGAP/1440);
    end;

begin
    instance_number := sys_context('userenv', 'instance');
    db_name := sys_context('userenv', 'db_name');
    SwitchFlag := 0;
    PollGAP := 60;
    CurSID := instance_number;
    if_trigger := 1;


    DateNow := sysdate;
    NextTime := DateNow+(1/24);

    begin
        select switch_flag, poll_interval
          into SwitchFlag, PollGAP
          from replicate_switch
         where instance_id=instance_number and rownum<2;

        exception
            when others then
                return;
    end;

    if SwitchFlag <> 0 then
        CurSID := instance_number*10;
    end if;
    NextTime := DateNow+(PollGAP/1440);

end pkg_replx_evt;
//
#########  创建触发器  #########
# TRIG_REPLX30_1660303 触发器创建
CREATE OR REPLACE TRIGGER "TRIG_REPLX30_1660303"
    after insert or delete or update on U_COMMON.SA_DB_RESTYPE_SALEPRICE
    for each row
declare
    key_str   varchar(1024);
begin
    if INSERTING then
        key_str :='RES_TYPE_ID='||:new.RES_TYPE_ID||','||chr(3)||
                  'ORGID='||:new.ORGID||','||chr(3)||
                  'CHARGEITEMID='||:new.CHARGEITEMID||','||chr(3)||
                  'STARTTIME='||to_char(:new.STARTTIME, 'yyyymmddhh24miss')||','||chr(3)||
                  'PRICETYPE='||:new.PRICETYPE;
        pkg_replx_evt.InsertLog(
            row_id=>:new.rowid,
            towner=>'U_COMMON',
            tname=>'SA_DB_RESTYPE_SALEPRICE',
            key=>key_str,
            priority=>0,
            hash_val=>45,
            operation=>'I'
        );
        return;
    end if;



    key_str :='RES_TYPE_ID='||:old.RES_TYPE_ID||','||chr(3)||
              'ORGID='||:old.ORGID||','||chr(3)||
              'CHARGEITEMID='||:old.CHARGEITEMID||','||chr(3)||
              'STARTTIME='||to_char(:old.STARTTIME, 'yyyymmddhh24miss')||','||chr(3)||
              'PRICETYPE='||:old.PRICETYPE;
    if UPDATING then
        pkg_replx_evt.InsertLog(
            row_id=>:new.rowid,
            towner=>'U_COMMON',
            tname=>'SA_DB_RESTYPE_SALEPRICE',
            key=>key_str,
            priority=>0,
            hash_val=>45,
            operation=>'U'
        );
        return;
    end if;



    if DELETING then
        pkg_replx_evt.InsertLog(
            row_id=>:new.rowid,
            towner=>'U_COMMON',
            tname=>'SA_DB_RESTYPE_SALEPRICE',
            key=>key_str,
            priority=>0,
            hash_val=>45,
            operation=>'D'
        );
        return;
    end if;
end;
