1. to test drop database.
CREATE DATABASE YIREN_DB;
USE YIREN_DB;
drop table if exists t1, t2, t3;
CREATE TABLE T1 (C1 INT, C2 INT PRIMARY KEY) with column group (all columns, each column);
INSERT INTO T1 VALUES(1, 2);
CREATE TABLE T2(C1 INT, C2 INT) with column group (all columns, each column);
CREATE TABLE T3(C1 CHAR(100), C2 VARCHAR(100)) with column group (all columns, each column);
DROP TABLE T1, T2, T3;
DROP DATABASE YIREN_DB;
2. to test truncate, drop partition and drop table.
USE TEST;
drop table if exists t1;
CREATE TABLE T1 (C1 INT, C2 INT)
PARTITION BY RANGE(C1) SUBPARTITION BY HASH(C2) (
PARTITION P0 VALUES LESS THAN(10),
PARTITION P1 VALUES LESS THAN(100),
PARTITION P3 VALUES LESS THAN(MAXVALUE)
) with column group (all columns, each column);
INSERT INTO T1 VALUES(1, 2), (11, 12), (30, 50), (200, 300);
ALTER TABLE T1 TRUNCATE PARTITION P1;
ALTER TABLE T1 DROP PARTITION p1;
DROP TABLE T1;
4. to test drop table with long name.
create table t1(c1 int) with column group (all columns, each column);
drop table if exists t1, t2, abcdefghijklmnopqabcdefghijklmnopqabcdefghijklmnopqabcdefghijklm;
create table abcdefghijklmnopqabcdefghijklmnopqabcdefghijklmnopqabcdefghijklmn(c1 int) with column group (all columns, each column);
ERROR 42000: Identifier name 'abcdefghijklmnopqabcdefghijklmnopqabcdefghijklmnopqabcdefghijklmn' is too long
create table abcdefghijklmnopqabcdefghijklmnopqabcdefghijklmnopqabcdefghijklm(c1 int) with column group (all columns, each column);
create table t2(c1 int) with column group (all columns, each column);
drop table t2, abcdefghijklmnopqabcdefghijklmnopqabcdefghijklmnopqabcdefghijklmn;
ERROR 42000: Identifier name 'abcdefghijklmnopqabcdefghijklmnopqabcdefghijklmnopqabcdefghijklmn' is too long
drop table t2, abcdefghijklmnopqabcdefghijklmnopqabcdefghijklmnopqabcdefghijklD;
ERROR 42S02: Unknown table 'test.abcdefghijklmnopqabcdefghijklmnopqabcdefghijklmnopqabcdefghijkld'
drop table if exists abcdefghijklmnopqabcdefghijklmnopqabcdefghijklmnopqabcdefghijklm, abcdefghijklmnopqabcdefghijklmnopqabcdefghijklmnopqabcdefghijklD;
Warnings:
Note	1051	Unknown table 'test.abcdefghijklmnopqabcdefghijklmnopqabcdefghijklmnopqabcdefghijkld'
drop table if exists abcdefghijklmnopqabcdefghijklmnopqabcdefghijklmnopqabcdefghijklm;
Warnings:
Note	1051	Unknown table 'test.abcdefghijklmnopqabcdefghijklmnopqabcdefghijklmnopqabcdefghijklm'
