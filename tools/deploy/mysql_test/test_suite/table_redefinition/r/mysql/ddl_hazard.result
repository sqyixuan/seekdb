alter system set debug_sync_timeout = '60s';
set ob_global_debug_sync = 'reset';
set ob_query_timeout = 100000000;
set ob_query_timeout = 100000000;
set ob_query_timeout = 100000000;
set ob_query_timeout = 100000000;
set ob_query_timeout = 100000000;
drop table if exists t1;
drop table if exists t2;
drop table if exists t3;
drop table if exists t4;
drop table if exists t5;
drop table if exists t1x;
drop table if exists t2x;
drop database if exists db;

# timeout when modify not null take effect
create table t1(c1 char(10));
insert into t1 value (1);
set ob_global_debug_sync = 'MODIFY_HIDDEN_TABLE_NOT_NULL_COLUMN_STATE_BEFORE_PUBLISH_SCHEMA wait_for continue_signal execute 10000';
alter table t1 modify c1 int not null;
set ob_global_debug_sync = 'now signal continue_signal';
set ob_global_debug_sync = 'reset';
insert into t1 values (null);
ERROR 23000: Column 'c1' cannot be null
drop table t1;

# timeout when ddl take effect
create table t1(c1 int, c2 int);
set ob_global_debug_sync = 'SWAP_ORIG_AND_HIDDEN_TABLE_BEFORE_PUBLISH_SCHEMA wait_for continue_signal execute 10000';
alter table t1 add c0 int first;
insert into t1 values (1, 2);
Got one of the listed errors
select * from t1;
c0	c1	c2
set ob_global_debug_sync = 'now signal continue_signal';
set ob_global_debug_sync = 'reset';
select * from t1;
c0	c1	c2
drop table t1;

# schema version after ddl and snapshot version before ddl
create table t1(c1 int, c2 int) partition by hash(c1) partitions 3;
insert into t1 values (1, 11);
insert into t1 values (2, 21);
insert into t1 values (3, 31);
commit;
alter table t1 modify c2 char(10);
select * from t1;
c1	c2
3	31
1	11
2	21
ERROR HY000: Unable to read data -- Table definition has changed
drop table t1;

# parallel offline ddl
create table t1(c0 int, c1 int, c2 int, c3 int, c4 int, c5 int, c6 int, c7 int, c8 int, c9 int) partition by hash(c1) partitions 128;
create table t2(c0 int, c1 int, c2 int, c3 int, c4 int, c5 int, c6 int, c7 int, c8 int, c9 int) partition by hash(c1) partitions 128;
create table t3(c0 int, c1 int, c2 int, c3 int, c4 int, c5 int, c6 int, c7 int, c8 int, c9 int) partition by hash(c1) partitions 128;
create table t4(c0 int, c1 int, c2 int, c3 int, c4 int, c5 int, c6 int, c7 int, c8 int, c9 int) partition by hash(c1) partitions 128;
create table t5(c0 int, c1 int, c2 int, c3 int, c4 int, c5 int, c6 int, c7 int, c8 int, c9 int) partition by hash(c1) partitions 128;
drop table t1,t2,t3,t4,t5;

