# index canceled after take effect
set ob_global_debug_sync = 'CREATE_INDEX_TAKE_EFFECT wait_for continue_signal execute 10000';
create table t1(c1 int);
insert into t1 values (1);
create index i1 on t1(c1);
set ob_global_debug_sync = 'now signal continue_signal';
set ob_global_debug_sync = 'reset';
create index i1 on t1(c1);
ERROR 42000: Duplicate key name 'i1'
drop table t1;

# after rs swich, wait old data complement task finish
create table t1(c1 int);
insert into t1 values (1);
alter tenant sys set primary_zone = 'zone1';
set ob_global_debug_sync = 'AFTER_DDL_WRITE_MACRO_BLOCK wait_for continue_signal execute 10000';
create index i1 on t1(c1);
select ddl_type, execution_id, unhex(ddl_stmt_str) from __all_virtual_ddl_task_status;
ddl_type	execution_id	unhex(ddl_stmt_str)
5	1	
alter tenant sys set primary_zone = 'zone1';
select ddl_type, execution_id, unhex(ddl_stmt_str) from __all_virtual_ddl_task_status;
ddl_type	execution_id	unhex(ddl_stmt_str)
5	1	
set ob_global_debug_sync = 'now signal continue_signal';
set ob_global_debug_sync = 'reset';
drop table t1;
alter tenant sys set primary_zone = "zone1";
