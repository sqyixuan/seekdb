drop table if exists test;

double -> decimal
CREATE TABLE test (c1 DOUBLE)
PARTITION BY RANGE COLUMNS(c1) (
PARTITION p_neg_inf VALUES LESS THAN (-11.7976931343157),
PARTITION p_min VALUES LESS THAN (-2.2250738585072),
PARTITION p_zero VALUES LESS THAN (0),
PARTITION p_min_pos VALUES LESS THAN (2.03),
PARTITION p_pos_inf VALUES LESS THAN MAXVALUE
);
insert into test values(-10.000000000000001), (-5.1000102022), (0), (1.00000000002), (10.0000000000000000221);
alter table test modify column c1 DECIMAL;
drop table test;

decimal -> decimal
CREATE TABLE test (c1 DECIMAL(65,30)) 
PARTITION BY RANGE COLUMNS(c1) (
PARTITION p_neg_inf VALUES LESS THAN (-99999999999999999999999999999999999.999999999999999999999999999999),
PARTITION p_min VALUES LESS THAN (-0.000000000000000000000000000001),
PARTITION p_zero VALUES LESS THAN (0),
PARTITION p_min_pos VALUES LESS THAN (0.000000000000000000000000000001),
PARTITION p_max VALUES LESS THAN (99999999999999999999999999999999999.999999999999999999999999999999),
PARTITION p_pos_inf VALUES LESS THAN MAXVALUE
);
INSERT INTO test (c1) VALUES (-99999999999999999999999999999999999.999999999999999999999999999999), (-0.000000000000000000000000000001), (0), (0.000000000000000000000000000001), (99999999999999999999999999999999999.999999999999999999999999999999), (NULL);
SELECT * FROM test PARTITION(p_neg_inf) order by 1;
c1
NULL
SELECT * FROM test PARTITION(p_min) order by 1;
c1
-99999999999999999999999999999999999.999999999999999999999999999999
SELECT * FROM test PARTITION(p_zero) order by 1;
c1
-0.000000000000000000000000000001
SELECT * FROM test PARTITION(p_min_pos) order by 1;
c1
0.000000000000000000000000000000
SELECT * FROM test PARTITION(p_max) order by 1;
c1
0.000000000000000000000000000001
SELECT * FROM test PARTITION(p_pos_inf) order by 1;
c1
99999999999999999999999999999999999.999999999999999999999999999999
alter table test modify column c1 DECIMAL(19);
ERROR HY000: VALUES LESS THAN value must be strictly increasing for each partition
alter table test modify column c1 DECIMAL(18);
ERROR HY000: VALUES LESS THAN value must be strictly increasing for each partition
alter table test modify column c1 DECIMAL(65,0);
ERROR HY000: VALUES LESS THAN value must be strictly increasing for each partition
alter table test modify column c1 DECIMAL;
ERROR HY000: VALUES LESS THAN value must be strictly increasing for each partition
drop table test;

int -> NUMBER
CREATE TABLE test (c1 INT) 
PARTITION BY RANGE COLUMNS(c1) (
PARTITION p_neg_inf VALUES LESS THAN (-1000),
PARTITION p_min VALUES LESS THAN (-200),
PARTITION p_zero VALUES LESS THAN (0),
PARTITION p_min_pos VALUES LESS THAN (200),
PARTITION p_max VALUES LESS THAN (1000),
PARTITION p_pos_inf VALUES LESS THAN MAXVALUE
);
insert into test values(-10000), (-500), (-10), (3), (800), (100000000);
alter table test modify column c1 NUMBER;
drop table test;

TIMESTAMP -> date -> TIMESTAMP
CREATE TABLE test (c1 TIMESTAMP) 
PARTITION BY RANGE COLUMNS(c1) (
PARTITION p0 VALUES LESS THAN ('1970-01-01 00:00:01'),
PARTITION p1 VALUES LESS THAN ('2024-04-01 00:00:00'),
PARTITION p2 VALUES LESS THAN ('2038-01-19 03:14:07')
);
show create table test;
Table	Create Table
test	CREATE TABLE `test` (
  `c1` timestamp NULL DEFAULT NULL
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = replica_num BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
 partition by range columns(c1)
(partition `p0` values less than ('1970-01-01 00:00:01'),
partition `p1` values less than ('2024-04-01 00:00:00'),
partition `p2` values less than ('2038-01-19 03:14:07'))
INSERT INTO test (c1) VALUES('2038-01-19 03:14:06');
TRUNCATE TABLE test;
alter table test modify column c1 DATE;
show create table test;
Table	Create Table
test	CREATE TABLE `test` (
  `c1` date DEFAULT NULL
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = replica_num BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
 partition by range columns(c1)
(partition `p0` values less than ('1970-01-01'),
partition `p1` values less than ('2024-04-01'),
partition `p2` values less than ('2038-01-19'))
alter table test modify column c1 TIMESTAMP;
INSERT INTO test (c1) VALUES('2038-01-19 03:14:06');
ERROR HY000: Table has no partition for value
drop table test;
