create table t1 (c1 int, c2 char, c3 varchar(10), c4 int) 
partition by range(c1) subpartition by range columns(c2, c3, c4) 
subpartition template (subpartition rsp0 values less than ('A', 'aa', 10), 
subpartition rsp1 values less than ('M', 'mm', 10), 
subpartition rsp2 values less than ('Z', 'zz', 10)) 
(partition rp0 values less than (100), partition rp1 values less than (200), partition rp2 values less than (300)) with column group (all columns, each column);
insert into t1 values(10, 0, 'a0', 1), (150, 'K', 'abcd', 1), (260, 'Q', 'nndgj', 1);
