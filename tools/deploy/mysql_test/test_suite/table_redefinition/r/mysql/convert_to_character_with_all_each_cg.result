create table t1 (c0 char(10), c1 int, c2 char, c3 varchar(10), c4 int) 
partition by range columns(c0, c1) subpartition by list columns(c2, c3, c4) 
subpartition template (subpartition rsp0 values in ('A', 'aa', 10), 
subpartition rsp1 values in ('A', 'bbcd', 10), 
subpartition rsp2 values in ('A', 'bbcz', 10))
(partition rp0 values less than ('abcd', 10), partition rp1 values less than ('abcd', 200), partition rp2 values less than ('abcd', 300)) with column group (all columns, each column);
insert into t1 values('ab0', 0, 'A', 'aa', 10), ('abc0', 150, 'A', 'bbcd', 10), ('012345', 230, 'A', 'bbcz', 10);
