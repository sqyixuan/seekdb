drop table if exists t01, t1;

CASE 1: prefix index define on single column.
create table t01 (c1 char(20), c2 char(20), key idx (c1(3)) );
create index idx2 on t01((substring(c1, 1, 3)));
alter table t01 modify c1 varchar(20);
alter table t01 modify c1 varchar(2);
ERROR 0A000: Alter column that the prefix index column depends on not supported
alter table t01 modify c1 int;
ERROR 0A000: Alter column that the prefix index column depends on not supported
show create table t01;
Table	Create Table
t01	CREATE TABLE `t01` (
  `c1` varchar(20) DEFAULT NULL,
  `c2` char(20) DEFAULT NULL,
  KEY `idx` (`c1`(3)) BLOCK_SIZE 16384 LOCAL,
  KEY `idx2` ((substr(`c1`,1,3))) BLOCK_SIZE 16384 LOCAL
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = replica_num BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
drop table t01;

CASE 2: prefix index define on multiple column.
create table t01 (c1 char(20), c2 char(20), key idx (c1(3), c2(3)) );
create index idx2 on t01 ( (substring(c1, 1, 3)), (substring(c2, 1, 3)) );
alter table t01 modify c2 varchar(20);
alter table t01 modify c1 varchar(2);
ERROR 0A000: Alter column that the prefix index column depends on not supported
alter table t01 modify c2 int;
ERROR 0A000: Alter column that the prefix index column depends on not supported
show create table t01;
Table	Create Table
t01	CREATE TABLE `t01` (
  `c1` char(20) DEFAULT NULL,
  `c2` varchar(20) DEFAULT NULL,
  KEY `idx` (`c1`(3), `c2`(3)) BLOCK_SIZE 16384 LOCAL,
  KEY `idx2` ((substr(`c1`,1,3)), (substr(`c2`,1,3))) BLOCK_SIZE 16384 LOCAL
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = replica_num BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
drop table t01;

CASE 3: Normal case.
create table t01 (c1 char(20), c2 char(20), key idx1 (c1));
create index idx2 on t01(c2);
alter table t01 modify c1 varchar(20);
alter table t01 modify c1 int;
drop table t01;

CASE 4. alter prefix index column to enum or set.
create table t1 (a tinyint not null auto_increment, b blob not null, primary key (a));
insert into t1 (b) values("a"), ("ab");
ALTER TABLE t1 ADD KEY(b(50));
ALTER TABLE t1 MODIFY b ENUM('a', 'z', 'b', 'c') NOT NULL;
ERROR 0A000: Alter column that the prefix index column depends on not supported
ALTER TABLE t1 MODIFY b SET('a', 'z', 'b', 'c') NOT NULL;
ERROR 0A000: Alter column that the prefix index column depends on not supported
drop table t1;
create table t1 (a tinyint not null auto_increment, b blob not null, primary key (a));
insert into t1 (b) values("a"), ("ab");
ALTER TABLE t1 ADD KEY(b(50));
CREATE TRIGGER before_employee_update
BEFORE UPDATE ON t1
FOR EACH ROW
BEGIN
delete from t1;
END;
