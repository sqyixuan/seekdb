to test drop primary key
create table t1(c1 int, c2 char(20) default 'Mysql' not null, constraint cst_pk primary key(c1));
alter table t1 drop constraint cst_pk;
ERROR HY000: Constraint 'cst_pk' does not exist.
alter table t1 drop primary key, drop constraint cst_pk;
ERROR 0A000: Multiple complex DDLs about primary in single stmt not supported
alter table t1 add c3 int, drop primary key, add primary key(c2);
ERROR 0A000: Multiple complex DDLs about primary in single stmt not supported
alter table t1 drop primary key, add constraint cst_pk_new primary key(c1, c2);
alter table t1 drop primary key;
drop table t1;
to test disable drop primary key if the table is a implicit key partition table
create table t1 (c1 int, c2 int, primary key(c1)) partition by key(c1) partitions 5;
alter table t1 partition by key() partitions 7;
alter table t1 drop primary key;
ERROR HY000: Field in list of fields for partition function not found in table
drop table t1;
to test enable drop primary key if the table is a normal key partition table
create table t1 (c1 int, c2 int, primary key(c1)) partition by key(c1) partitions 5;
alter table t1 drop primary key;
drop table t1;

4. to test after drop primary key.
drop table if exists test;

4.1 pk with null default -> modify null -> drop pk -> modify null.
create table test(c1 int, c2 int, constraint const_pk_test primary key(c1));
alter table test modify c1 int null;
ERROR 42000: All parts of a PRIMARY KEY must be NOT NULL; if you need NULL in a key, use UNIQUE instead
insert into test values(NULL, 1);
ERROR 23000: Column 'c1' cannot be null
alter table test drop primary key;
insert into test values(NULL, 1);
ERROR 23000: Column 'c1' cannot be null
alter table test modify c1 int null;
insert into test values(NULL, 1);
insert into test values(NULL, 1);
drop table test;

4.2 pk with not null default -> modify null -> drop pk -> modify null.
create table test(c1 int not null, c2 int, constraint const_pk_test primary key(c1));
alter table test modify c1 int null;
ERROR 42000: All parts of a PRIMARY KEY must be NOT NULL; if you need NULL in a key, use UNIQUE instead
insert into test values(NULL, 1);
ERROR 23000: Column 'c1' cannot be null
alter table test drop primary key;
insert into test values(NULL, 1);
ERROR 23000: Column 'c1' cannot be null
alter table test modify c1 int null;
insert into test values(NULL, 1);
insert into test values(NULL, 1);
drop table test;

4.3 pk with not null default -> drop pk -> modify null -> modify null.
create table test(c1 int not null, c2 int, constraint const_pk_test primary key(c1));
insert into test values(NULL, 1);
ERROR 23000: Column 'c1' cannot be null
alter table test drop primary key;
insert into test values(NULL, 1);
ERROR 23000: Column 'c1' cannot be null
alter table test modify c1 int null;
insert into test values(NULL, 1);
insert into test values(NULL, 1);
alter table test modify c1 int null;
drop table test;

