1. drop pk is disallowed.
drop table if exists t3, t2, t1, t0;
create table t0(c1 int, c2 int);
alter table t0 drop primary key;
ERROR 42000: Can't DROP 'PRIMAY'; check that column/key exists
alter table t0 add primary key(c1);
alter table t0 add primary key(c2), drop primary key, drop primary key;
ERROR 0A000: Multiple complex DDLs about primary in single stmt not supported
alter table t0 add primary key(c2), add primary key(c1), drop primary key;
ERROR 0A000: Multiple complex DDLs about primary in single stmt not supported
alter table t0 add column c3 int, drop primary key;
ERROR 0A000: Multiple complex DDLs about primary in single stmt not supported
drop table t0;
create table t1(c1 int, c2 char(20), constraint pk1 primary key(c1));
create table t2(c1 int, c2 int, c3 int, constraint pk2 primary key(c1, c2), constraint fk2 foreign key (c1) references t1(c1));
create table t3(c1 int, c2 int, c3 int, constraint pk3 primary key(c2), constraint fk3 foreign key (c1) references t1(c1));
create index idx1 on t3 (c2);
create index idx2 on t3 (c1) storing(c3);
create unique index idx3 on t3(c3) storing (c2);
alter table t1 drop primary key;
ERROR HY000: unique/primary keys in table referenced by enabled foreign keys
alter table t2 drop primary key;
ERROR HY000: unique/primary keys in table referenced by enabled foreign keys
show create table t3;
Table	Create Table
t3	CREATE TABLE `t3` (
  `c1` int(11) DEFAULT NULL,
  `c2` int(11) NOT NULL,
  `c3` int(11) DEFAULT NULL,
  PRIMARY KEY (`c2`),
  CONSTRAINT `fk3` FOREIGN KEY (`c1`) REFERENCES `test`.`t1`(`c1`) ON UPDATE RESTRICT ON DELETE RESTRICT ,
  UNIQUE KEY `idx3` (`c3`) STORING (`c2`) BLOCK_SIZE 16384 LOCAL,
  KEY `idx1` (`c2`) BLOCK_SIZE 16384 LOCAL,
  KEY `idx2` (`c1`) STORING (`c3`) BLOCK_SIZE 16384 LOCAL
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = replica_num BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
alter table t3 drop primary key;
show create table t3;
Table	Create Table
t3	CREATE TABLE `t3` (
  `c1` int(11) DEFAULT NULL,
  `c2` int(11) NOT NULL,
  `c3` int(11) DEFAULT NULL,
  CONSTRAINT `fk3` FOREIGN KEY (`c1`) REFERENCES `test`.`t1`(`c1`) ON UPDATE RESTRICT ON DELETE RESTRICT ,
  UNIQUE KEY `idx3` (`c3`) STORING (`c2`) BLOCK_SIZE 16384 LOCAL,
  KEY `idx1` (`c2`) BLOCK_SIZE 16384 LOCAL,
  KEY `idx2` (`c1`) STORING (`c3`) BLOCK_SIZE 16384 LOCAL
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = replica_num BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
select count(*) from t3;
count(*)
2000
drop table t3, t2, t1;
2. to test partition table.
create table t1(c1 int, c2 char(20), c3 int, constraint pk1 primary key(c1, c2)) partition by hash(c1) partitions 3;
create index idx1 on t1(c1, c3);
create index idx2 on t1(c1) storing (c2, c3);
create index idx3 on t1(c2) storing (c3);
create unique index idx4 on t1(c2) storing (c1, c3);
ERROR HY000: A UNIQUE INDEX must include all columns in the table's partitioning function
create unique index idx4 on t1(c1, c3) storing (c2);
select (select count(*) from t1 partition (p0)) as p0_count, 
(select count(*) from t1 partition (p1)) as p1_count,
(select count(*) from t1 partition (p2)) as p2_count;
p0_count	p1_count	p2_count
667	667	666
show create table t1;
Table	Create Table
t1	CREATE TABLE `t1` (
  `c1` int(11) NOT NULL,
  `c2` char(20) NOT NULL,
  `c3` int(11) DEFAULT NULL,
  PRIMARY KEY (`c1`, `c2`),
  UNIQUE KEY `idx4` (`c1`, `c3`) STORING (`c2`) BLOCK_SIZE 16384 LOCAL,
  KEY `idx1` (`c1`, `c3`) BLOCK_SIZE 16384 LOCAL,
  KEY `idx2` (`c1`) STORING (`c2`, `c3`) BLOCK_SIZE 16384 LOCAL,
  KEY `idx3` (`c2`) STORING (`c3`) BLOCK_SIZE 16384 LOCAL
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = replica_num BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
 partition by hash(c1)
(partition `p0`,
partition `p1`,
partition `p2`)
alter table t1 drop primary key;
select (select count(*) from t1 partition (p0)) as p0_count, 
(select count(*) from t1 partition (p1)) as p1_count,
(select count(*) from t1 partition (p2)) as p2_count;
p0_count	p1_count	p2_count
667	667	666
