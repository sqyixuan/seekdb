drop table if exists tbl_247;
CREATE TABLE tbl_247 (
col_1776 set('Alice','Bob','Charlie','David') NOT NULL,
col_1780 int unsigned NOT NULL,
PRIMARY KEY (col_1780, col_1776)
) partition by range(col_1780) (
partition p0 values less than (719),
partition p1 values less than (4303),
partition p2 values less than (11775),
partition p3 values less than (19344),
partition p4 values less than (54377)
);
select part_name, high_bound_val from oceanbase.__all_part where table_id=(select table_id from oceanbase.__all_table where table_name='tbl_247');
part_name	high_bound_val
p0	719
p1	4303
p2	11775
p3	19344
p4	54377
alter table tbl_247 change column col_1780 col_5007 bit ( 58 );
select part_name, high_bound_val from oceanbase.__all_part where table_id=(select table_id from oceanbase.__all_table where table_name='tbl_247');
part_name	high_bound_val
p0	b'1011001111'
p1	b'1000011001111'
p2	b'10110111111111'
p3	b'100101110010000'
p4	b'1101010001101001'
drop table tbl_247;

test modify key partition 
drop table if exists Z0CASE;
test without part key specification.
create table Z0CASE (c1 int, c2 int, c3 text, primary key(c1, c3)) partition by key();
ERROR 42000: The used storage engine can't index column 'c3'
create table Z0CASE (c1 int, c2 int, c3 text, primary key(c1, c2)) partition by key();
drop table Z0CASE;
test with part key specification.
create table Z0CASE (c1 int, c2 int, c3 text) partition by key(c3);
ERROR HY000: Field 'c3' is of a not allowed type for this type of partitioning
create table Z0CASE (c1 int, c2 int, c3 text) partition by key(c1, c3);
ERROR HY000: Field 'c3' is of a not allowed type for this type of partitioning
create table Z0CASE (c1 int, c2 int, c3 int) partition by key(c1, c2);
alter table Z0CASE modify c2 text;
ERROR HY000: Field 'c2' is of a not allowed type for this type of partitioning
drop table Z0CASE;
test key subpartition.
create table Z0CASE (c1 int, c2 text, c3 int not null, primary key (c1, c3)) partition by range columns(c1) subpartition by key(c2) subpartitions 3
(
partition p201707 values less than (10),
partition p201808 values less than (26)
);
ERROR HY000: Field 'c2' is of a not allowed type for this type of partitioning
create table Z0CASE (c1 int, c2 int, c3 int not null, primary key (c1, c2, c3)) partition by range columns(c1) subpartition by key(c2) subpartitions 3
(
partition p201707 values less than (10),
partition p201808 values less than (26)
);
alter table Z0CASE modify c2 text;
ERROR HY000: Field 'c2' is of a not allowed type for this type of partitioning
alter table Z0CASE modify c2 blob;
ERROR HY000: Field 'c2' is of a not allowed type for this type of partitioning
drop table Z0CASE;
test modify part key of aux table
drop table if exists Z0CASE;

main table non partitioned, but index table partitioned.
CREATE TABLE Z0CASE(z0_test0 YEAR , z0_test1 char(50),z0_test2 int AS (z0_test0 ) VIRTUAL);
CREATE INDEX index_z on Z0CASE(Z0_TEST0,Z0_TEST1) global PARTITION BY range (Z0_TEST0) (PARTITION part_1 VALUES LESS THAN (1 ), PARTITION part_2 VALUES LESS THAN (10 ), PARTITION part_3 VALUES LESS THAN ( maxvalue));
insert into Z0CASE(z0_test0, z0_test1) values('2010', 'aaaaa');
ALTER TABLE Z0CASE MODIFY COLUMN z0_test0 CHAR(101);
ERROR HY000: alter part key of global index is not allowed
ALTER TABLE Z0CASE MODIFY COLUMN z0_test1 VARCHAR(50);
DROP TABLE Z0CASE;
CREATE TABLE Z0CASE (Z0_TEST0 BIT(64), Z0_TEST1 INT);
CREATE INDEX IDX1 ON Z0CASE(Z0_TEST0);
CREATE INDEX IDX2 ON Z0CASE(Z0_TEST0) PARTITION BY HASH(Z0_TEST0);
ALTER TABLE Z0CASE MODIFY COLUMN Z0_TEST0 SET ('','ABC','12321','0','123');
ERROR HY000: alter part key of global index is not allowed
DROP TABLE Z0CASE;

