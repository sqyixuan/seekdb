drop table if exists t1;
create TABLE t1(c1 int, c2 int not null);
create index i1 on t1(c2, c1);
insert into t1 values (4, 8);
insert into t1 values (3, 1);
insert into t1 values (0, 2);
insert into t1 values (2, 3);
insert into t1 values (1, 5);
insert into t1 values (7, 9);
insert into t1 values (1, 2);
insert into t1 values (3, 4);
insert into t1 values (5, 6);
insert into t1 values (2, 10);
alter table t1 add column c0 int as (c2 - c1) before c1;
drop table t1;

add inner generated column, like functional index column.
create table t1(c1 int, c2 int);
insert into t1 values(1, 1), (2, 2);
alter table t1 add index i1((c1+2));
alter table t1 add index i2((c1+2)), add column c3 int;
alter table t1 add index i3((c2+2)), add column c0 int before c1, add index i4((c1+c2));
show create table t1;
Table	Create Table
t1	CREATE TABLE `t1` (
  `c0` int(11) DEFAULT NULL,
  `c1` int(11) DEFAULT NULL,
  `c2` int(11) DEFAULT NULL,
  `c3` int(11) DEFAULT NULL,
  KEY `i1` ((`c1` + 2)) BLOCK_SIZE 16384 LOCAL,
  KEY `i2` ((`c1` + 2)) BLOCK_SIZE 16384 LOCAL,
  KEY `i3` ((`c2` + 2)) BLOCK_SIZE 16384 LOCAL,
  KEY `i4` ((`c1` + `c2`)) BLOCK_SIZE 16384 LOCAL
) ORGANIZATION INDEX DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE ENABLE_MACRO_BLOCK_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
show index from t1;
Table	Non_unique	Key_name	Seq_in_index	Column_name	Collation	Cardinality	Sub_part	Packed	Null	Index_type	Comment	Index_comment	Visible	Expression
t1	1	i1	1	SYS_NC18$	A	NULL	NULL	NULL	YES	BTREE	available		YES	(`c1` + 2)
t1	1	i2	1	SYS_NC18$	A	NULL	NULL	NULL	YES	BTREE	available		YES	(`c1` + 2)
t1	1	i3	1	SYS_NC21$	A	NULL	NULL	NULL	YES	BTREE	available		YES	(`c2` + 2)
t1	1	i4	1	SYS_NC22$	A	NULL	NULL	NULL	YES	BTREE	available		YES	(`c1` + `c2`)
drop table t1;
