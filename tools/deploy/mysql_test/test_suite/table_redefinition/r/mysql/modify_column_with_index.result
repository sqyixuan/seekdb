CREATE TABLE t1 (
`payment_id` varchar(32) NOT NULL,
`apply_id` varchar(32) DEFAULT NULL,
`partition_id` varchar(2) GENERATED ALWAYS AS (substr(`payment_id`,1,2)) VIRTUAL,
`gmt_create` timestamp(6) NULL DEFAULT CURRENT_TIMESTAMP(6),
`gmt_modified` timestamp(6) NULL DEFAULT CURRENT_TIMESTAMP(6),
PRIMARY KEY (`payment_id`),
UNIQUE KEY `i1` (`payment_id`, `apply_id`) BLOCK_SIZE 16384 LOCAL,
CONSTRAINT `partlist1` CHECK ((`partition_id` = substr(`apply_id`,1,2)))
) partition by list columns(partition_id) (partition p0 values in ('00'), partition p1 values in ('01'));
ERROR HY000: A UNIQUE INDEX must include all columns in the table's partitioning function
CREATE TABLE t1 (
`payment_id` varchar(32) NOT NULL,
`apply_id` varchar(32) DEFAULT NULL,
`partition_id` varchar(2) GENERATED ALWAYS AS (substr(`payment_id`,1,2)) VIRTUAL,
`gmt_create` timestamp(6) NULL DEFAULT CURRENT_TIMESTAMP(6),
`gmt_modified` timestamp(6) NULL DEFAULT CURRENT_TIMESTAMP(6),
PRIMARY KEY (`payment_id`),
UNIQUE KEY `i1` (`payment_id`, `apply_id`, `partition_id`) BLOCK_SIZE 16384 LOCAL,
CONSTRAINT `partlist1` CHECK ((`partition_id` = substr(`apply_id`,1,2)))
) partition by list columns(partition_id) (partition p0 values in ('00'), partition p1 values in ('01'));
