c1 TINYINT NOT NULL,
c2 TINYINT,
c3 INT NOT NULL
) PARTITION BY RANGE (c1)
SUBPARTITION BY LIST COLUMNS (c2) (
PARTITION p0 VALUES LESS THAN (10) (
SUBPARTITION p0_0 VALUES IN (-3, -2, -1),
SUBPARTITION p0_1 VALUES IN (0),
SUBPARTITION p0_2 VALUES IN (1, 2, 3)
),
PARTITION p1 VALUES LESS THAN (20) (
SUBPARTITION p1_0 VALUES IN (-6, -5, -4),
SUBPARTITION p1_1 VALUES IN (0),
SUBPARTITION p1_2 VALUES IN (4, 5, 6)
),
PARTITION p2 VALUES LESS THAN MAXVALUE (
SUBPARTITION p2_0 VALUES IN (-9, -8, -7),
SUBPARTITION p2_1 VALUES IN (0),
SUBPARTITION p2_2 VALUES IN (7, 8, 9)
)
);
