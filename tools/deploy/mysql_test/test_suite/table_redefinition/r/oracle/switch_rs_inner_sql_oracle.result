alter system set debug_sync_timeout = '600s';
set ob_global_debug_sync = 'reset';
drop table t1;

# test cancel ddl
set ob_global_debug_sync = 'END_DDL_IN_PX_SUBCOORD wait_for continue_signal execute 10000';
create table t1(c1 int);
insert into t1 values(1);
create index i1 on t1(c1);
ERROR HY000: internal error code, arguments: -4072, Operation canceled
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'now signal continue_signal';
drop table t1;

# test rs swich
alter tenant sys set primary_zone = 'zone1';
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'END_DDL_IN_PX_SUBCOORD wait_for continue_signal execute 10000';
create table t1(c1 int);
insert into t1 values(1);
create index i1 on t1(c1);
alter tenant sys set primary_zone = 'zone2';
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'now signal continue_signal';
drop table t1;

# create partitioned local index rs switch after reporting checksum
create table t1(c1 int) partition by hash(c1) partitions 10;
insert into t1 values(1);
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'END_DDL_IN_PX_SUBCOORD wait_for continue_signal execute 10000';
create index i1 on t1(c1) local;
alter tenant sys set primary_zone = 'zone1';
set ob_global_debug_sync = 'reset';
set ob_global_debug_sync = 'now signal continue_signal';
drop table t1;
