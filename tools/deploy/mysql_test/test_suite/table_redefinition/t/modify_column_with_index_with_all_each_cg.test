--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner : jianyun.sjy
#owner group: storage
#description: test add/modify column with index

--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(c1 int) with column group (all columns, each column);
insert into t1 values(1);
insert into t1 values(2);
insert into t1 values(3);
insert into t1 values(4);
alter table t1 add column c2 int unique;
select * from t1;

drop table t1;
create table t1(c1 int) with column group (all columns, each column);
insert into t1 values(1);
insert into t1 values(2);
insert into t1 values(3);
insert into t1 values(4);
alter table t1 add column c2 int unique auto_increment;
select * from t1;

drop table t1;
create table t1(c1 int, c2 varchar(80)) with column group (all columns, each column);
insert into t1 values(1, '1');
insert into t1 values(2, '2');
alter table t1 modify c2 int unique;

drop table t1;
create table t1(c1 int, c2 varchar(80)) with column group (all columns, each column);
insert into t1 values(1, '1');
insert into t1 values(2, '1');
--error 1062
alter table t1 modify c2 int unique;

drop table t1;
create table t1(c1 int) with column group (all columns, each column);
alter table t1 add column c2 int, add index i2(c2);

drop table t1;
create table t1(c1 int) with column group (all columns, each column);
alter table t1 add column c2 int, add unique index i2(c2);

drop table t1;
create table t1(c1 int) with column group (all columns, each column);
alter table t1 add column c2 int, add unique index i2(c2) global;
drop table t1;
create table t1(c1 int, c2 int) with column group (all columns, each column);
alter table t1 modify column c1 int, add index i2(c2);

drop table t1;
create table t1(c1 int, c2 int) with column group (all columns, each column);
alter table t1 modify column c1 tinyint, add index i2(c2);

drop table t1;
create table t1(c1 int, c2 int) with column group (all columns, each column);
alter table t1 modify column c1 bigint, add index i2(c2);

drop table t1;

--error 1503
CREATE TABLE t1 (
`payment_id` varchar(32) NOT NULL,
`apply_id` varchar(32) DEFAULT NULL,
`partition_id` varchar(2) GENERATED ALWAYS AS (substr(`payment_id`,1,2)) VIRTUAL,
`gmt_create` timestamp(6) NULL DEFAULT CURRENT_TIMESTAMP(6),
`gmt_modified` timestamp(6) NULL DEFAULT CURRENT_TIMESTAMP(6),
PRIMARY KEY (`payment_id`),
UNIQUE KEY `i1` (`payment_id`, `apply_id`) BLOCK_SIZE 16384 LOCAL,
CONSTRAINT `partlist1` CHECK ((`partition_id` = substr(`apply_id`,1,2)))
) partition by list columns(partition_id) (partition p0 values in ('00'), partition p1 values in ('01')) with column group (all columns, each column);

CREATE TABLE t1 (
`payment_id` varchar(32) NOT NULL,
`apply_id` varchar(32) DEFAULT NULL,
`partition_id` varchar(2) GENERATED ALWAYS AS (substr(`payment_id`,1,2)) VIRTUAL,
`gmt_create` timestamp(6) NULL DEFAULT CURRENT_TIMESTAMP(6),
`gmt_modified` timestamp(6) NULL DEFAULT CURRENT_TIMESTAMP(6),
PRIMARY KEY (`payment_id`),
UNIQUE KEY `i1` (`payment_id`, `apply_id`, `partition_id`) BLOCK_SIZE 16384 LOCAL,
CONSTRAINT `partlist1` CHECK ((`partition_id` = substr(`apply_id`,1,2)))
) partition by list columns(partition_id) (partition p0 values in ('00'), partition p1 values in ('01')) with column group (all columns, each column);

--error 1503
