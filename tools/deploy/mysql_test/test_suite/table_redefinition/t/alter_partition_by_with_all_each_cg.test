--echo 
--echo to test global index but local storage.
--disable_warnings
drop table if exists t0;
drop table if exists t1;
--enable_warnings
create table t0(c1 int, c2 int) with column group (all columns, each column);
create index idx_lcoal_t0 on t0(c1);
create index idx_gbl on t0(c1) global;
create unique index idx_gbl_uni on t0(c2) global;
alter table t0 partition by range(c1) (
  partition p0 values less than(100),
  partition p1 values less than(1000));
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t0;

--echo
create table t1(c1 int, c2 int) with column group (all columns, each column);
create index idx_lcoal on t1(c1);
create index idx_gbl on t1(c1) global;
create unique index idx_gbl_uni on t1(c2) global;
alter table t1 partition by range(c1) (
  partition p0 values less than(100));
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t1;

--echo
connection obsys;
--sleep 2
let $te_id = query_get_value(select tenant_id from oceanbase.__all_tenant where tenant_name = 'sys', tenant_id, 1);
let $db_id = query_get_value(select database_id from oceanbase.__all_virtual_database where tenant_id = $te_id and database_name = 'test', database_id, 1);
let $t0_id = query_get_value(select table_id from oceanbase.__all_virtual_table where tenant_id = $te_id and database_id = $db_id and table_name = 't0', table_id, 1);
let $t1_id = query_get_value(select table_id from oceanbase.__all_virtual_table where tenant_id = $te_id and database_id = $db_id and table_name = 't1', table_id, 1);

--replace_regex /tenant_id = [0-9]* and database_id = [0-9]* and data_table_id = [0-9]*/tenant_id = TENANT_ID and database_id = DB_ID and data_table_id = DATA_TABLE_ID/g
eval select index_status, index_type, part_num from oceanbase.__all_virtual_table where tenant_id = $te_id and database_id = $db_id and data_table_id = $t0_id order by table_id;
--replace_regex /tenant_id = [0-9]* and database_id = [0-9]* and data_table_id = [0-9]*/tenant_id = TENANT_ID and database_id = DB_ID and data_table_id = DATA_TABLE_ID/g
eval select index_status, index_type, part_num from oceanbase.__all_virtual_table where tenant_id = $te_id and database_id = $db_id and data_table_id = $t1_id order by table_id;


connection conn1;
drop table t0;
drop table t1;

connection default;
