--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner : zhuoran.zzr
#owner group: storage
#description: basic alter table partition by

connect (conn1,$OBMYSQL_MS0,root,,test,$OBMYSQL_PORT);
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,oceanbase,$OBMYSQL_PORT);
connection conn1;

let $tenant_id = `select effective_tenant_id() from dual`;

--disable_warnings
drop table if exists t1;
--enable_warnings

--echo
--echo # simple test
create table t1(c1 int primary key, c2 int, c3 int) partition by hash(c1) partitions 10 with column group (all columns, each column);
alter table t1 drop primary key, add primary key(c2, c1);
alter table t1 partition by hash(c2) partitions 10;
--source mysql_test/test_suite/online_ddl/t/include/check_table_schema.inc
alter table t1 drop primary key, add primary key(c2);
--error 1503
alter table t1 partition by hash(c2+c1) partitions 3;
--source mysql_test/test_suite/online_ddl/t/include/check_table_schema.inc
alter table t1 drop primary key;
alter table t1 partition by hash(c1+c2) partitions 4;
--source mysql_test/test_suite/online_ddl/t/include/check_table_schema.inc
alter table t1 partition by hash(c2+c1) partitions 3;
--source mysql_test/test_suite/online_ddl/t/include/check_table_schema.inc
alter table t1 partition by hash(c3) partitions 5;
--source mysql_test/test_suite/online_ddl/t/include/check_table_schema.inc
alter table t1 add primary key(c3);
drop table t1;

--echo
--echo subpartitions
create table t1(c1 int, c2 int, c3 int) partition by range(c1+c3) subpartition by hash(c2) subpartitions 3 (
  partition p0 values less than (10),
  partition p1 values less than (20),
  partition p2 values less than MAXVALUE
) with column group (all columns, each column);
alter table t1 partition by range(c3+c2) subpartition by hash(c2) subpartitions 5 (
  partition p0 values less than (100),
  partition p1 values less than (200),
  partition p2 values less than MAXVALUE
);
--source mysql_test/test_suite/online_ddl/t/include/check_table_schema.inc
alter table t1 add column c4 int;
alter table t1 partition by hash(c4+c1) partitions 10;
--source mysql_test/test_suite/online_ddl/t/include/check_table_schema.inc
drop table t1;

--echo
--echo #测试非分区表转换成一级分区表
create table t1(c1 int, c2 datetime, primary key(c1, c2)) with column group (all columns, each column);
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;
insert into t1 values(1,'2016-12-12');
alter table t1 partition by hash(c1) partitions 4;
--source mysql_test/test_suite/online_ddl/t/include/check_table_schema.inc
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;
drop table t1;

--echo
--echo #测试非分区表转换成模板二级分区表
create table t1(c1 int, c2 datetime, primary key(c1, c2)) with column group (all columns, each column);
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;
insert into t1 values(1,'2016-12-12');
alter table t1 partition by hash(c1)
                subpartition by range columns(c2)
                subpartition template(
                subpartition p1 values less than ('2016-10-10'),
                subpartition p2 values less than ('2116-3-30'))
                partitions 2;
--source mysql_test/test_suite/online_ddl/t/include/check_table_schema.inc
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;
drop table t1;

--echo
--echo #测试非分区表转换成非模板二级分区表
create table t1(c1 int, c2 datetime, primary key(c1, c2)) with column group (all columns, each column);
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;
insert into t1 values(1,'2016-12-12');
alter table t1 partition by range(c1) subpartition by key(c2) subpartitions 5 (partition p0 values less than(0), partition p1 values less than(100));
--source mysql_test/test_suite/online_ddl/t/include/check_table_schema.inc
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;
drop table t1;

--echo
--echo #测试一级分区表转换成一级分区表
create table t1(c1 int, c2 datetime, primary key(c1, c2)) partition by hash(c1) partitions 4 with column group (all columns, each column);
insert into t1 values(1,'2016-12-12');
alter table t1 partition by key(c1) partitions 10;
--source mysql_test/test_suite/online_ddl/t/include/check_table_schema.inc
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;
drop table t1;

--echo
--echo #测试一级分区表转换成模板二级分区表
create table t1(c1 int, c2 datetime, primary key(c1, c2)) partition by hash(c1) partitions 4 with column group (all columns, each column);
insert into t1 values(1,'2016-12-12');
alter table t1 partition by hash(c1)
                subpartition by range columns(c2)
                subpartition template(
                subpartition p1 values less than ('2016-10-10'),
                subpartition p2 values less than ('2116-3-30'))
                partitions 2;
--source mysql_test/test_suite/online_ddl/t/include/check_table_schema.inc
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;
drop table t1;

--echo
--echo #测试一级分区表转换成非模板二级分区表
create table t1(c1 int, c2 datetime, primary key(c1, c2)) partition by hash(c1) partitions 4 with column group (all columns, each column);
insert into t1 values(1,'2016-12-12');
alter table t1 partition by range(c1) subpartition by key(c2) subpartitions 5 (partition p0 values less than(0), partition p1 values less than(100));
--source mysql_test/test_suite/online_ddl/t/include/check_table_schema.inc
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;
drop table t1;

--echo
--echo #测试模板二级分区表转换成一级分区表
create table t1(c1 int, c2 datetime, primary key(c1, c2)) partition by hash(c1)
                subpartition by range columns(c2)
                subpartition template(
                subpartition p1 values less than ('2016-10-10'),
                subpartition p2 values less than ('2116-3-30'))
                partitions 2 with column group (all columns, each column);
insert into t1 values(1,'2016-12-12');
alter table t1 partition by hash(c1) partitions 4;
--source mysql_test/test_suite/online_ddl/t/include/check_table_schema.inc
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;
drop table t1;

--echo
--echo #测试模板二级分区表转换成模板二级分区表
create table t1(c1 int, c2 datetime, primary key(c1, c2)) partition by hash(c1)
                subpartition by range columns(c2)
                subpartition template(
                subpartition p1 values less than ('2016-10-10'),
                subpartition p2 values less than ('2116-3-30'))
                partitions 2 with column group (all columns, each column);
insert into t1 values(1,'2016-12-12');
alter table t1 partition by key(c1)
                subpartition by range columns(c2)
                subpartition template(
                subpartition p1 values less than ('2016-10-10'),
                subpartition p2 values less than ('2116-3-30'),
                subpartition p3 values less than ('2136-4-30'))
                partitions 10;
--source mysql_test/test_suite/online_ddl/t/include/check_table_schema.inc
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;
drop table t1;

--echo
--echo #测试模板二级分区表转换成非模板二级分区表
create table t1(c1 int, c2 datetime, primary key(c1, c2)) partition by hash(c1)
                subpartition by range columns(c2)
                subpartition template(
                subpartition p1 values less than ('2016-10-10'),
                subpartition p2 values less than ('2116-3-30'))
                partitions 2 with column group (all columns, each column);
insert into t1 values(1,'2016-12-12');
alter table t1 partition by range(c1) subpartition by key(c2) subpartitions 5 (partition p0 values less than(0), partition p1 values less than(100));
--source mysql_test/test_suite/online_ddl/t/include/check_table_schema.inc
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;
drop table t1;

--echo
--echo #测试非模板二级分区表转换成一级分区表
create table t1(c1 int, c2 datetime, primary key(c1, c2)) partition by range(c1)
                subpartition by key(c2)
                subpartitions 5 (
                partition p0 values less than(0),
                partition p1 values less than(100)) with column group (all columns, each column);
insert into t1 values(1,'2016-12-12');
alter table t1 partition by hash(c1) partitions 4;
--source mysql_test/test_suite/online_ddl/t/include/check_table_schema.inc
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;
drop table t1;

--echo
--echo #测试非模板二级分区表转换成一级分区表
create table t1(c1 int, c2 datetime, primary key(c1, c2)) partition by range(c1)
                subpartition by key(c2)
                subpartitions 5 (
                partition p0 values less than(0),
                partition p1 values less than(100)) with column group (all columns, each column);
insert into t1 values(1,'2016-12-12');
alter table t1 partition by hash(c1) partitions 4;
--source mysql_test/test_suite/online_ddl/t/include/check_table_schema.inc
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;
drop table t1;

--echo
--echo #测试非模板二级分区表转换成模板二级分区表
create table t1(c1 int, c2 datetime, primary key(c1, c2)) partition by range(c1)
                subpartition by key(c2)
                subpartitions 5 (
                partition p0 values less than(0),
                partition p1 values less than(100)) with column group (all columns, each column);
insert into t1 values(1,'2016-12-12');
alter table t1 partition by hash(c1)
                subpartition by range columns(c2)
                subpartition template(
                subpartition p1 values less than ('2016-10-10'),
                subpartition p2 values less than ('2116-3-30'))
                partitions 2;
--source mysql_test/test_suite/online_ddl/t/include/check_table_schema.inc
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;
drop table t1;

--echo
--echo #测试非模板二级分区表转换成非模板二级分区表
create table t1(c1 int, c2 datetime, primary key(c1, c2)) partition by range(c1)
                subpartition by key(c2)
                subpartitions 5 (
                partition p0 values less than(0),
                partition p1 values less than(100)) with column group (all columns, each column);
insert into t1 values(1,'2016-12-12');
alter table t1 partition by range(c1)
                subpartition by key(c2)
                subpartitions 5 (
                partition p0 values less than(0),
                partition p1 values less than(100),
                partition p2 values less than(200),
                partition p3 values less than(300),
                partition p4 values less than(400));
--source mysql_test/test_suite/online_ddl/t/include/check_table_schema.inc
--source mysql_test/include/show_create_table_old_version_replica2.inc
show create table t1;
drop table t1;

create table t1(c1 int, c2 int) partition by hash((c1+c2)) partitions 4 with column group (all columns, each column);
--error 01697
alter table t1 modify column c1 double;
drop table t1;

