#owner: fengzihan.fzh
#owner group: storage
#description: create unique index on duplicate keys under multiple parallel degrees

--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1 (c1 int);
insert into t1 values (1);
insert into t1 values (1);
alter system minor freeze;
--source mysql_test/include/wait_minor_merge.inc
alter system set _px_object_sampling = 100000;
--error 1062
create /*+parallel(10)*/ unique index idx1 on t1 (c1);
alter system set _px_object_sampling = 200;