#owner: beity.lhy
#owner group: storage
#description: test if column flag of index changes after alter table column.

--disable_warnings
--disable_result_log
drop table if exists t1;
--enable_result_log

create table t1 (c1 int, c2 int, c3 int, primary key(c1), index(c2) storing(c3));
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t1;
alter table t1 modify c3 int after c2;
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t1;


