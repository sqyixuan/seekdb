--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner : lihongqin.lhq
#owner group: storage 
#description: parallel table redefinition case

--disable_warnings
drop table if exists t1;
--enable_warnings
# test without any parallel speicification
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
set global ob_sql_audit_percentage = 50;
alter system flush sql audit global;
connection default;
set global ob_sql_audit_percentage = 50;
connection default;
create table t1(c1 int, c2 int) ;
insert into t1 values(1,1);
connection obsys;
let $count1 = query_get_value(select count(*) as cnt from oceanbase.__all_virtual_sql_audit where query_sql like 'insert%parallel(1)%parallel_table_redefinition_i1%t1%' and user_name != 'admin', cnt, 1);
connection default;
create index parallel_table_redefinition_i1 on t1(c1) storing(c2) with column group(all columns, each column);
connection obsys;
let $count2 = query_get_value(select count(*) as cnt from oceanbase.__all_virtual_sql_audit where query_sql like 'insert%parallel(1)%parallel_table_redefinition_i1%t1%' and user_name != 'admin', cnt, 1);
let $count = query_get_value( select $count2 - $count1 as cnt from dual, cnt, 1);
echo $count;
connection default;
drop index parallel_table_redefinition_i1 on t1;

# test parallel hint
connection obsys;
let $count1 = query_get_value(select count(*) as cnt from oceanbase.__all_virtual_sql_audit where query_sql like 'insert%parallel(10)%parallel_table_redefinition_i2%t1%' and user_name != 'admin', cnt, 1);
connection default;
create /*+ parallel(10) */ index parallel_table_redefinition_i2 on t1(c2) storing(c1) with column group(all columns, each column);
connection obsys;
let $count2 = query_get_value(select count(*) as cnt from oceanbase.__all_virtual_sql_audit where query_sql like 'insert%parallel(10)%parallel_table_redefinition_i2%t1%' and user_name != 'admin', cnt, 1);
let $count = query_get_value( select $count2 - $count1 as cnt from dual, cnt, 1);
echo $count;
connection default;
drop index parallel_table_redefinition_i2 on t1;

# test force parallel ddl
connection obsys;
let $count1 = query_get_value(select count(*) as cnt from oceanbase.__all_virtual_sql_audit where query_sql like 'insert%parallel(11)%parallel_table_redefinition_i3%t1%' and user_name != 'admin', cnt, 1);
connection default;
SET SESSION _FORCE_PARALLEL_DDL_DOP = 11;
create index parallel_table_redefinition_i3 on t1(c2) storing(c1) with column group(all columns, each column);
connection obsys;
let $count2 = query_get_value(select count(*) as cnt from oceanbase.__all_virtual_sql_audit where query_sql like 'insert%parallel(11)%parallel_table_redefinition_i3%t1%' and user_name != 'admin', cnt, 1);
let $count = query_get_value( select $count2 - $count1 as cnt from dual, cnt, 1);
echo $count;
connection default;
drop index parallel_table_redefinition_i3 on t1;

# test table dop of ddl
connection obsys;
let $count1 = query_get_value(select count(*) as cnt from oceanbase.__all_virtual_sql_audit where query_sql like 'insert%parallel(12)%parallel_table_redefinition_i4%t1%' and user_name != 'admin', cnt, 1);
connection default;
SET SESSION _FORCE_PARALLEL_DDL_DOP = 1;
SET SESSION _ENABLE_PARALLEL_DDL = 1;
create index parallel_table_redefinition_i4 on t1(c2) parallel 12 storing(c1) with column group(all columns, each column);
connection obsys;
let $count2 = query_get_value(select count(*) as cnt from oceanbase.__all_virtual_sql_audit where query_sql like 'insert%parallel(12)%parallel_table_redefinition_i4%t1%' and user_name != 'admin', cnt, 1);
let $count = query_get_value( select $count2 - $count1 as cnt from dual, cnt, 1);
echo $count;
connection default;
drop index parallel_table_redefinition_i4 on t1;

# test alter primary key force parallel ddl
connection obsys;
let $count1 = query_get_value(select count(*) as cnt from oceanbase.__all_virtual_sql_audit where query_sql like 'insert%parallel(13)%t1%' and user_name != 'admin', cnt, 1);
connection default;
drop table t1;
SET SESSION _FORCE_PARALLEL_DDL_DOP = 13;
create table t1(c1 int) ;
insert into t1 values(1);
alter table t1 add primary key(c1);
connection obsys;
let $count2 = query_get_value(select count(*) as cnt from oceanbase.__all_virtual_sql_audit where query_sql like 'insert%parallel(13)%t1%' and user_name != 'admin', cnt, 1);
let $count = query_get_value( select $count2 - $count1 as cnt from dual, cnt, 1);
echo $count;

# test alter primary key table dop
connection obsys;
let $count1 = query_get_value(select count(*) as cnt from oceanbase.__all_virtual_sql_audit where query_sql like 'insert%parallel(14)%t1%' and user_name != 'admin', cnt, 1);
connection default;
drop table t1;
SET SESSION _FORCE_PARALLEL_DDL_DOP = 1;
SET SESSION _ENABLE_PARALLEL_DDL = 1;
create table t1(c1 int) parallel 14 ;
insert into t1 values(1);
alter table t1 add primary key(c1);
connection obsys;
let $count2 = query_get_value(select count(*) as cnt from oceanbase.__all_virtual_sql_audit where query_sql like 'insert%parallel(14)%t1%' and user_name != 'admin', cnt, 1);
let $count = query_get_value( select $count2 - $count1 as cnt from dual, cnt, 1);
echo $count;
connection default;
drop table t1;
connection obsys;
set global ob_sql_audit_percentage = 3;
alter system flush sql audit global;
connection default;
set global ob_sql_audit_percentage = 3;
