# owner: lihongqin.lhq
# owner group: storage
# description: modify column type from timestamp to datetime
#

# Convert timestamp to datetime.
--disable_warnings
drop table if exists t;
--enable_warnings
create table t(c1 timestamp);
set time_zone = "+8:00";
insert into t(c1) values('2011-11-11 11:11:11');
insert into t(c1) values(0);
insert into t(c1) values(NULL);
select * from t;
set time_zone = "+9:00";
select * from t;
alter table t modify column c1 datetime;
select * from t;
set time_zone = "+8:00";
select * from t;
drop table t;

# Other table redefinition task must not modify timestamp.
create table t(c1 timestamp, c2 int);
set time_zone = "+8:00";
insert into t values ('2011-11-11 11:11:11', 111);
set time_zone = "+9:00";
alter table t modify column c2 float;
select * from t;
drop table t;

# Change to old engine
connect (my_obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection my_obsys;
connection default;

# Case 1 by old engine.
create table t(c1 timestamp);
set time_zone = "+8:00";
insert into t(c1) values('2011-11-11 11:11:11');
insert into t(c1) values(0);
insert into t(c1) values(NULL);
select * from t;
set time_zone = "+9:00";
select * from t;
alter table t modify column c1 datetime;
select * from t;
set time_zone = "+8:00";
select * from t;
drop table t;
