--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner : jianyun.sjy
#owner group: storage
#description: test modify column with some partition empty

--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(c1 int, c2 int, c3 int, primary key(c1)) partition by range(c1)(partition part_1 values less than (10), partition part_2 values less than (20), partition part_3 values less than (maxvalue)) with column group (all columns, each column);
insert into t1 values(1, 1, 1);
insert into t1 values(11, 11, 11);
alter table t1 modify column c2 varchar(20);
select * from t1;
drop table t1;

create table t1(c1 int, c2 int, c3 int, primary key(c1)) partition by range(c1)(partition part_1 values less than (10), partition part_2 values less than (20), partition part_3 values less than (maxvalue)) with column group (all columns, each column);
insert into t1 values(11, 11, 11);
insert into t1 values(21, 21, 21);
alter table t1 modify column c2 varchar(20);
select * from t1;
drop table t1;

create table t1(c1 int, c2 int, c3 int, primary key(c1)) partition by range(c1)(partition part_1 values less than (10), partition part_2 values less than (20), partition part_3 values less than (maxvalue)) with column group (all columns, each column);
insert into t1 values(1, 1, 1);
insert into t1 values(21, 21, 21);
