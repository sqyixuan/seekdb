--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner : jianyun.sjy
#owner group: storage 
#description: basic add/alter primary key case

--disable_warnings
drop table if exists t1, t2, t3;
--enable_warnings
# test table with index and check constraint
create table t1(c1 int, c2 int) ;
alter table t1 change c1 c1 int not null, add key i3(c2);
--error 1048
insert into t1 values(null, 1);
create table t2(c1 int, c2 int) ;
insert into t1 values(1,1);
insert into t2 values(1,2);
create unique index i1 on t1(c1, c2) with column group(all columns, each column);
create unique index i1 on t2(c1) storing(c2) with column group(all columns, each column);
create index i2 on t1(c2) storing(c1) with column group(all columns, each column);
alter table t1 add constraint check_cst11 check(c1 = c2);
alter table t1 add constraint fk1 foreign key(c1) references t2(c1);
--error 3819
alter table t1 add constraint check_cst12 check(c1 > c2);
--error 1215
alter table t1 add constraint fk2 foreign key(c2) references t2(c2);
create table t3(c1 int, c2 int) ;
insert into t3 values(3, null);
--error 1138
alter table t3 change c2 c2 int default 10 not null;
delete from t3;
alter table t3 add c3 bigint default 10 not null;
insert into t3 values(3, 1, 2);
--error 1067
alter table t3 add c4 bigint default null not null;
drop table t1;
drop table t2;
drop table t3;
