--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner : lihongqin.lhq
#owner group: storage
#description: test modify auto increment column

--disable_warnings
drop table if exists t1;
--enable_warnings

--echo #测试不需要双写的改自增列
create table t1(c1 int not null, c2 int) with column group (all columns, each column);
alter table t1 modify c1 int not null auto_increment;
insert into t1(c2) values(300);
select * from t1;
show create table t1;
drop table t1;

create table t1(c1 int not null, c2 int) with column group (all columns, each column);
insert into t1 values(100, 100);
insert into t1 values(200, 200);
select * from t1;
alter table t1 modify c1 int not null auto_increment;
insert into t1(c2) values(300);
select * from t1;
show create table t1;
drop table t1;

create table t1(c1 int unsigned not null, c2 int) with column group (all columns, each column);
insert into t1 values(100, 100);
insert into t1 values(200, 200);
select * from t1;
alter table t1 modify c1 int unsigned not null auto_increment;
insert into t1(c2) values(300);
select * from t1;
show create table t1;
drop table t1;

create table t1(c1 float not null, c2 int) with column group (all columns, each column);
insert into t1 values(100, 100);
insert into t1 values(200, 200);
select * from t1;
alter table t1 modify c1 float not null auto_increment;
insert into t1(c2) values(300);
select * from t1;
show create table t1;
drop table t1;

create table t1(c1 double not null, c2 int) with column group (all columns, each column);
insert into t1 values(100, 100);
insert into t1 values(200, 200);
select * from t1;
alter table t1 modify c1 double not null auto_increment;
insert into t1(c2) values(300);
select * from t1;
show create table t1;
drop table t1;

# TODO: add tests that modify autoinc with constraint, trigger, fk, index
--echo #测试需要双写的改自增列
create table t1(c1 int, c2 int) with column group (all columns, each column);
alter table t1 modify c1 int auto_increment;
insert into t1(c2) values(300);
select * from t1;
show create table t1;
drop table t1;

create table t1(c1 int, c2 int) with column group (all columns, each column);
insert into t1 values(NULL, NULL);
insert into t1 values(200, 200);
select * from t1;
alter table t1 modify c1 int unsigned auto_increment;
insert into t1(c2) values(300);
select * from t1;
show create table t1;
drop table t1;

create table t1(c1 int, c2 int) with column group (all columns, each column);
insert into t1 values(NULL, NULL);
insert into t1 values(200, 200);
select * from t1;
alter table t1 modify c1 float auto_increment;
insert into t1(c2) values(300);
select * from t1;
show create table t1;
drop table t1;

create table t1(c1 int, c2 int) with column group (all columns, each column);
insert into t1 values(NULL, NULL);
insert into t1 values(200, 200);
select * from t1;
alter table t1 modify c1 double auto_increment;
insert into t1(c2) values(300);
select * from t1;
show create table t1;
drop table t1;

create table t1(c1 varchar(100), c2 int) with column group (all columns, each column);
insert into t1 values(NULL, NULL);
insert into t1 values('200', 200);
select * from t1;
alter table t1 modify c1 int auto_increment;
insert into t1(c2) values(300);
select * from t1;
show create table t1;
drop table t1;

--echo #测试先加后删再加
create table t1(c1 int, c2 int) with column group (all columns, each column);
insert into t1 values(100, 100);
insert into t1 values(200, 200);
select * from t1;
alter table t1 modify c1 int auto_increment;
insert into t1(c2) values(300);
select * from t1;
show create table t1;
alter table t1 modify c1 int;
insert into t1(c2) values(400);
select * from t1;
alter table t1 modify c1 int auto_increment;
insert into t1(c2) values(500);
select * from t1;
show create table t1;
drop table t1;

create table t1(c1 int, c2 int) with column group (all columns, each column);
insert into t1 values(100, 100);
insert into t1 values(200, 200);
select * from t1;
alter table t1 modify c1 int auto_increment;
insert into t1(c2) values(300);
select * from t1;
show create table t1;
alter table t1 modify c1 int not null;
--error 1364
insert into t1(c2) values(400);
select * from t1;
alter table t1 modify c1 int not null auto_increment;
insert into t1(c2) values(500);
select * from t1;
show create table t1;
drop table t1;

create table t1(c1 int, c2 int not null auto_increment) with column group (all columns, each column);
insert into t1(c1) values(1);
insert into t1(c1) values(2);
insert into t1(c1) values(3);
insert into t1(c1) values(4);
alter table t1 modify c2 tinyint not null auto_increment;
show create table t1;
select * from t1;
drop table t1;

--echo 测试自增列相关的online ddl
create table t1(c1 int, c2 int not null auto_increment) with column group (all columns, each column);
alter table t1 modify c2 bigint not null auto_increment;
show create table t1;
alter table t1 modify c2 bigint not null;
show create table t1;
alter table t1 modify c2 bigint;
drop table t1;

--echo 测试corner cases
create table t1(c1 int, c2 int) with column group (all columns, each column);
insert into t1 values(-10, -10);
insert into t1 values(-2, -2);
insert into t1 values(-1, -1);
alter table t1 modify c1 int auto_increment;
show create table t1;
insert into t1 (c2) values(1);
select * from t1;
drop table t1;

create table t1(c1 bigint unsigned, c2 int) with column group (all columns, each column);
insert into t1 values(9223372036854775807, 1);
insert into t1 values(9223372036854775809, 2);
insert into t1 values(0, 3);
alter table t1 modify c1 bigint unsigned auto_increment;
show create table t1;
insert into t1 (c2) values(1);
select * from t1;
drop table t1;

create table t1(c1 bigint unsigned, c2 int, key(c1)) with column group (all columns, each column);
insert into t1 values(18446744073709551615, 2);
insert into t1 values(0, 3);
--error 1467
alter table t1 modify c1 bigint unsigned auto_increment;
show create table t1;
drop table t1;

create table t1(c1 bigint unsigned, c2 int) with column group (all columns, each column);
insert into t1 values(18446744073709551610, 1);
insert into t1 values(18446744073709551612, 2);
insert into t1 values(0, 3);
alter table t1 modify c1 bigint unsigned auto_increment;
show create table t1;
insert into t1 (c2) values(1);
select * from t1;
drop table t1;

create table t1(c1 int, c2 int) with column group (all columns, each column);
insert into t1(c2) values(1);
insert into t1(c2) values(2);
insert into t1(c2) values(3);
select * from t1;
alter table t1 modify c1 int auto_increment;
select * from t1;
drop table t1;
