# owner: liujixiong.ljx
# owner group: storage
# description: this case is used for test the offline ddl behavior on table with prefix index column.

--disable_warnings
drop table if exists t01, t1;
--enable_warnings

--echo 
--echo CASE 1: prefix index define on single column.
create table t01 (c1 char(20), c2 char(20), key idx (c1(3)) );

create index idx2 on t01((substring(c1, 1, 3)));

# support change column type from char to varchar on column with predix index
alter table t01 modify c1 varchar(20);

--error 1235
alter table t01 modify c1 varchar(2);

--error 1235
alter table t01 modify c1 int;

--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t01;
drop table t01;

--echo 
--echo CASE 2: prefix index define on multiple column.
create table t01 (c1 char(20), c2 char(20), key idx (c1(3), c2(3)) );

create index idx2 on t01 ( (substring(c1, 1, 3)), (substring(c2, 1, 3)) );

# support change column type from char to varchar on column with predix index
alter table t01 modify c2 varchar(20);

--error 1235
alter table t01 modify c1 varchar(2);

--error 1235
alter table t01 modify c2 int;

--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t01;
drop table t01;

--echo
--echo CASE 3: Normal case.
create table t01 (c1 char(20), c2 char(20), key idx1 (c1));
create index idx2 on t01(c2);

alter table t01 modify c1 varchar(20);
alter table t01 modify c1 int;
drop table t01;


--echo
--echo CASE 4. alter prefix index column to enum or set.
create table t1 (a tinyint not null auto_increment, b blob not null, primary key (a));
insert into t1 (b) values("a"), ("ab");
ALTER TABLE t1 ADD KEY(b(50));
--error 1235
ALTER TABLE t1 MODIFY b ENUM('a', 'z', 'b', 'c') NOT NULL;
--error 1235
ALTER TABLE t1 MODIFY b SET('a', 'z', 'b', 'c') NOT NULL;
drop table t1;

create table t1 (a tinyint not null auto_increment, b blob not null, primary key (a));
insert into t1 (b) values("a"), ("ab");
ALTER TABLE t1 ADD KEY(b(50));

DELIMITER //;
CREATE TRIGGER before_employee_update
BEFORE UPDATE ON t1
FOR EACH ROW
BEGIN
	delete from t1;
END;
//
DELIMITER ;//
--error 1235
ALTER TABLE t1 MODIFY b ENUM('a', 'z', 'b', 'c') NOT NULL;
--error 1235
ALTER TABLE t1 MODIFY b SET('a', 'z', 'b', 'c') NOT NULL;
drop table t1;
