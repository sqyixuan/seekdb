#owner : lihongqin.lhq
#owner group: storage
#description: test ddl sync stats info

--disable_warnings
drop table if exists t1;
drop table if exists t2;
--enable_warnings

--echo
--echo # table prefs after direct load
create table t2(c1 int);
insert into t2 values (1);
create table t1(c1 int);
call dbms_stats.set_table_prefs('test', 't1', 'degree', '4');
select dbms_stats.get_prefs('degree', 'test', 't1') from dual;
insert /*+append enable_parallel_dml parallel(8)*/ into t1 select * from t2;
select dbms_stats.get_prefs('degree', 'test', 't1') from dual;
drop table t1;
drop table t2;

--echo
--echo # table prefs after offline ddl
create table t1(c1 int);
insert into t1 values (1);
call dbms_stats.set_table_prefs('test', 't1', 'degree', '4');
select dbms_stats.get_prefs('degree', 'test', 't1') from dual;
alter table t1 modify c1 char(10);
select dbms_stats.get_prefs('degree', 'test', 't1') from dual;
drop table t1;

--echo
--echo # table prefs after mview refresh
create table t1(c1 int primary key, c2 int, c3 int, c4 int);
create materialized view log on t1 with primary key, sequence (c2, c3) including new values;
create materialized view mv1 refresh fast on demand as select c2 as c2, count(*) cnt, count(c3) cnt_c3, sum(c3) sum_c3 from t1 group by c2;
call dbms_stats.set_table_prefs('test', 'mv1', 'degree', '4');
select dbms_stats.get_prefs('degree', 'test', 'mv1') from dual;
call dbms_mview.refresh('mv1', 'c');
select dbms_stats.get_prefs('degree', 'test', 'mv1') from dual;
drop materialized view mv1;
drop materialized view log on t1;
drop table t1;

