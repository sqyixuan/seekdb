--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner : liujixiong.ljx
#owner group: storage 
#description: to test drop primary key.

--echo 1. drop pk is disallowed.
--disable_warnings
drop table if exists t3, t2, t1, t0;
--enable_warnings

create table t0(c1 int, c2 int);
--error 1091
alter table t0 drop primary key;
alter table t0 add primary key(c1);
--error 1235
alter table t0 add primary key(c2), drop primary key, drop primary key;
--error 1235
alter table t0 add primary key(c2), add primary key(c1), drop primary key;
--error 1235
alter table t0 add column c3 int, drop primary key;
drop table t0;

create table t1(c1 int, c2 char(20), constraint pk1 primary key(c1));
create table t2(c1 int, c2 int, c3 int, constraint pk2 primary key(c1, c2), constraint fk2 foreign key (c1) references t1(c1));
create table t3(c1 int, c2 int, c3 int, constraint pk3 primary key(c2), constraint fk3 foreign key (c1) references t1(c1));
create index idx1 on t3 (c2);
create index idx2 on t3 (c1) storing(c3);
create unique index idx3 on t3(c3) storing (c2);

--disable_query_log
let $cnt = 0;
while ($cnt < 2000) 
{
  eval insert into t1 (c1, c2) values ($cnt, 'OceanBase');
  eval insert into t2 (c1, c2, c3) values($cnt, $cnt, $cnt);
  eval insert into t3 (c1, c2, c3) values($cnt, $cnt, $cnt);
  inc $cnt;
}
--enable_query_log

--error 4714
alter table t1 drop primary key;
--error 4714
alter table t2 drop primary key;
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t3;
alter table t3 drop primary key;
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t3;
select count(*) from t3;
drop table t3, t2, t1;

--echo 2. to test partition table.
create table t1(c1 int, c2 char(20), c3 int, constraint pk1 primary key(c1, c2)) partition by hash(c1) partitions 3;
create index idx1 on t1(c1, c3);
create index idx2 on t1(c1) storing (c2, c3);
create index idx3 on t1(c2) storing (c3);
--error 1503
create unique index idx4 on t1(c2) storing (c1, c3);
create unique index idx4 on t1(c1, c3) storing (c2);

--disable_query_log
let $cnt = 0;
while ($cnt < 2000)
{
  eval insert into t1 (c1, c2, c3) values ($cnt, 'test', $cnt);
  inc $cnt;
}
--enable_query_log

select (select count(*) from t1 partition (p0)) as p0_count, 
       (select count(*) from t1 partition (p1)) as p1_count,
       (select count(*) from t1 partition (p2)) as p2_count;
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t1;
alter table t1 drop primary key;
select (select count(*) from t1 partition (p0)) as p0_count, 
       (select count(*) from t1 partition (p1)) as p1_count,
       (select count(*) from t1 partition (p2)) as p2_count;
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t1;

--disable_query_log
let $cnt = 2000;
while ($cnt < 3000)
{
  eval insert into t1 (c1, c2, c3) values($cnt, 'oceanbase', $cnt);
  inc $cnt;
}
--enable_query_log

select count(*) from t1;
alter table t1 add constraint pk1 primary key(c1, c3);
select count(*) from t1;
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
show create table t1;
drop table t1;

--echo
--echo to test drop primary key
create table t1(c1 int, c2 char(20) default 'Mysql' not null, constraint cst_pk primary key(c1));
--error 3940
alter table t1 drop constraint cst_pk;
--error 1235
alter table t1 drop primary key, drop constraint cst_pk;
--error 1235
alter table t1 add c3 int, drop primary key, add primary key(c2);
alter table t1 drop primary key, add constraint cst_pk_new primary key(c1, c2);
alter table t1 drop primary key;
drop table t1;

# 当前 Oceanbase 的 mysql模式下, 只支持隐藏key分区依赖主键, 因此当分区表是隐藏 key 分区表的时候, 此表的分区键默认是主键, 当删除主键的时候需要兼容原生mysql报错。
--echo to test disable drop primary key if the table is a implicit key partition table
create table t1 (c1 int, c2 int, primary key(c1)) partition by key(c1) partitions 5;
alter table t1 partition by key() partitions 7;
--error 1488
alter table t1 drop primary key;
drop table t1;
--echo to test enable drop primary key if the table is a normal key partition table
create table t1 (c1 int, c2 int, primary key(c1)) partition by key(c1) partitions 5;
alter table t1 drop primary key;
drop table t1;


--echo
--echo 4. to test after drop primary key.
--disable_warnings
drop table if exists test;
--enable_warnings
--echo
--echo 4.1 pk with null default -> modify null -> drop pk -> modify null.
create table test(c1 int, c2 int, constraint const_pk_test primary key(c1));
--error 1171
alter table test modify c1 int null;
--error 1048
insert into test values(NULL, 1);
alter table test drop primary key;
--error 1048
insert into test values(NULL, 1);
alter table test modify c1 int null;
insert into test values(NULL, 1);
insert into test values(NULL, 1);
drop table test;

--echo
--echo 4.2 pk with not null default -> modify null -> drop pk -> modify null.
create table test(c1 int not null, c2 int, constraint const_pk_test primary key(c1));
--error 1171
alter table test modify c1 int null;
--error 1048
insert into test values(NULL, 1);
alter table test drop primary key;
--error 1048
insert into test values(NULL, 1);
alter table test modify c1 int null;
insert into test values(NULL, 1);
insert into test values(NULL, 1);
drop table test;

--echo
--echo 4.3 pk with not null default -> drop pk -> modify null -> modify null.
create table test(c1 int not null, c2 int, constraint const_pk_test primary key(c1));
--error 1048
insert into test values(NULL, 1);
alter table test drop primary key;
--error 1048
insert into test values(NULL, 1);
alter table test modify c1 int null;
insert into test values(NULL, 1);
insert into test values(NULL, 1);
alter table test modify c1 int null;
drop table test;


--echo
--echo 4.4 pk with null default(with index) -> modify null -> drop pk -> modify null.
create table test(c1 int, c2 int, constraint const_pk_test primary key(c1));
create index idx_test_pk_and_null on test(c1, c2);
--error 1171
alter table test modify c1 int null;
--error 1048
insert into test values(NULL, 1);
alter table test drop primary key;
--error 1048
insert into test values(NULL, 1);
alter table test modify c1 int null;
insert into test values(NULL, 1);
insert into test values(NULL, 1);
drop table test;

--echo
--echo 4.5 pk with not null default(with index) -> modify null -> drop pk -> modify null.
create table test(c1 int not null, c2 int, constraint const_pk_test primary key(c1));
create index idx_test_pk_and_null on test(c1, c2);
--error 1171
alter table test modify c1 int null;
--error 1048
insert into test values(NULL, 1);
alter table test drop primary key;
--error 1048
insert into test values(NULL, 1);
alter table test modify c1 int null;
insert into test values(NULL, 1);
insert into test values(NULL, 1);
drop table test;

--echo
--echo 4.6 pk with not null default(with index) -> drop pk -> modify null -> modify null.
create table test(c1 int not null, c2 int, constraint const_pk_test primary key(c1));
create index idx_test_pk_and_null on test(c1, c2);
--error 1048
insert into test values(NULL, 1);
alter table test drop primary key;
--error 1048
insert into test values(NULL, 1);
alter table test modify c1 int null;
insert into test values(NULL, 1);
insert into test values(NULL, 1);
alter table test modify c1 int null;
drop table test;
