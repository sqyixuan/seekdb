--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
#owner : liujixiong.ljx
#owner group: storage 
#description: to check macro block meta like macro id, macro block data sequence after ddl.

set GLOBAL ob_query_timeout = 1000000000;
set GLOBAL ob_trx_timeout = 1000000000;

connect (obsys,$OBMYSQL_MS0,root@sys,,*NO-ONE*,$OBMYSQL_PORT);
connection default;

--echo 1. To test whether the macro data seq are different in different parallel threads.
--disable_warnings
drop table if exists ddl_dup_macro_test;
--enable_warnings

create table ddl_dup_macro_test (
  c0 char(200), c1 varchar(1024), c2 varchar(1024), c3 varchar(1024), c4 varchar(1024), c5 varchar(1024), 
  c6 varchar(1024), c7 varchar(1024), c8 varchar(1024), c9 longtext, c10 longtext) row_format = redundant, compression = 'none' with column group (all columns, each column);

# 10240 * 10KB, 100MB.
# In threshold time, minio can not support 10240 data rows.
insert /*+use_px,parallel(10) query_timeout(1000000000)*/ into ddl_dup_macro_test select     
  randstr(200, random()) c0,
  randstr(1024, random()) c1,
  randstr(1024, random()) c2,
  randstr(1024, random()) c3,
  randstr(1024, random()) c4,
  randstr(1024, random()) c5,
  randstr(1024, random()) c6,
  randstr(1024, random()) c7,
  randstr(1024, random()) c8,
  randstr(1024, random()) c9,
  randstr(10240, random()) c10
from 
  table(generator(2048));

connection obsys;
use oceanbase;
let $tenant_id = query_get_value(select 1 as tenant_id, tenant_id, 1);
let $data_table_id = query_get_value(select table_id from oceanbase.__all_virtual_table where table_name = 'ddl_dup_macro_test', table_id, 1);
eval select /*+query_timeout(1000000000)*/ tablet_id, macro_logic_version, count(distinct data_seq), count(1) from oceanbase.__all_virtual_tablet_sstable_macro_info where tablet_id in  (select distinct tablet_id from __all_virtual_tablet_to_ls where table_id in  (select table_id from oceanbase.__all_virtual_table where       (table_id = $data_table_id or data_table_id = $data_table_id)
    )
  ) group by tablet_id, macro_block_type, cg_idx, end_log_scn, macro_logic_version having count(distinct data_seq) <> count (1);

--echo
--echo modify column task.
connection default;
SET SESSION _FORCE_PARALLEL_DDL_DOP = 5;
alter table ddl_dup_macro_test modify c0 varchar(200);
connection obsys;
use oceanbase;
let $tenant_id = query_get_value(select 1 as tenant_id, tenant_id, 1);
let $data_table_id = query_get_value(select table_id from oceanbase.__all_virtual_table where table_name = 'ddl_dup_macro_test', table_id, 1);
eval select /*+query_timeout(1000000000)*/ tablet_id, macro_logic_version, count(distinct data_seq), count(1) from oceanbase.__all_virtual_tablet_sstable_macro_info where tablet_id in  (select distinct tablet_id from __all_virtual_tablet_to_ls where table_id in  (select table_id from oceanbase.__all_virtual_table where       (table_id = $data_table_id or data_table_id = $data_table_id)
    )
  ) group by tablet_id, macro_block_type, cg_idx, end_log_scn, macro_logic_version having count(distinct data_seq) <> count (1);

--echo 
--echo create index task.
connection default;
SET SESSION _FORCE_PARALLEL_DDL_DOP = 5;
create index idx_test on ddl_dup_macro_test(c1) parallel 10;
connection obsys;
use oceanbase;
let $tenant_id = query_get_value(select 1 as tenant_id, tenant_id, 1);
let $data_table_id = query_get_value(select table_id from oceanbase.__all_virtual_table where table_name = 'ddl_dup_macro_test', table_id, 1);
eval select /*+query_timeout(1000000000)*/ tablet_id, macro_logic_version, count(distinct data_seq), count(1) from oceanbase.__all_virtual_tablet_sstable_macro_info where tablet_id in  (select distinct tablet_id from __all_virtual_tablet_to_ls where table_id in  (select table_id from oceanbase.__all_virtual_table where       (table_id = $data_table_id or data_table_id = $data_table_id)
    )
  ) group by tablet_id, macro_block_type, cg_idx, end_log_scn, macro_logic_version having count(distinct data_seq) <> count (1);

--echo
--echo drop column task
connection default;
SET SESSION _FORCE_PARALLEL_DDL_DOP = 5;
alter table ddl_dup_macro_test drop column c0;
connection obsys;
use oceanbase;
let $tenant_id = query_get_value(select 1 as tenant_id, tenant_id, 1);
let $data_table_id = query_get_value(select table_id from oceanbase.__all_virtual_table where table_name = 'ddl_dup_macro_test', table_id, 1);
eval select /*+query_timeout(1000000000)*/ tablet_id, macro_logic_version, count(distinct data_seq), count(1) from oceanbase.__all_virtual_tablet_sstable_macro_info where tablet_id in  (select distinct tablet_id from __all_virtual_tablet_to_ls where table_id in  (select table_id from oceanbase.__all_virtual_table where       (table_id = $data_table_id or data_table_id = $data_table_id)
    )
  ) group by tablet_id, macro_block_type, cg_idx, end_log_scn, macro_logic_version having count(distinct data_seq) <> count (1);

connection default;
SET SESSION _FORCE_PARALLEL_DDL_DOP = 5;
alter table ddl_dup_macro_test drop column c1;
connection obsys;
use oceanbase;
let $tenant_id = query_get_value(select 1 as tenant_id, tenant_id, 1);
let $data_table_id = query_get_value(select table_id from oceanbase.__all_virtual_table where table_name = 'ddl_dup_macro_test', table_id, 1);
eval select /*+query_timeout(1000000000)*/ tablet_id, macro_logic_version, count(distinct data_seq), count(1) from oceanbase.__all_virtual_tablet_sstable_macro_info where tablet_id in  (select distinct tablet_id from __all_virtual_tablet_to_ls where table_id in  (select table_id from oceanbase.__all_virtual_table where       (table_id = $data_table_id or data_table_id = $data_table_id)
    )
  ) group by tablet_id, macro_block_type, cg_idx, end_log_scn, macro_logic_version having count(distinct data_seq) <> count (1);

--echo
--echo cleanup.
connection default;
drop table ddl_dup_macro_test;
