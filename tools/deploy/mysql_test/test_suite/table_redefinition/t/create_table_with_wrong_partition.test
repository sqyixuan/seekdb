#owner : beity.lhy
#owner group: storage 
#description: create a table that partitioned by wrong syntax;

--error 1064
# partition by应该用在external table中。
create table t2(a int,b int,CONSTRAINT "t1_pk" PRIMARY KEY (a)) partition by (a);

--error 1064
# partition by list应该有partition条件
create table t2(a int,b int,CONSTRAINT "t1_pk" PRIMARY KEY (a)) partition by list (a);
