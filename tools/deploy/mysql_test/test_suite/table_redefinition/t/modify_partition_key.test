--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner : liujixiong.ljx
#owner group: storage
#description: test modify partition key

--disable_warnings
drop table if exists tbl_247;
--enable_warnings
CREATE TABLE tbl_247 (
  col_1776 set('Alice','Bob','Charlie','David') NOT NULL,
  col_1780 int unsigned NOT NULL,
  PRIMARY KEY (col_1780, col_1776)
) partition by range(col_1780) (
  partition p0 values less than (719),
  partition p1 values less than (4303),
  partition p2 values less than (11775),
  partition p3 values less than (19344),
  partition p4 values less than (54377)
);

select part_name, high_bound_val from oceanbase.__all_part where table_id=(select table_id from oceanbase.__all_table where table_name='tbl_247');

alter table tbl_247 change column col_1780 col_5007 bit ( 58 );
select part_name, high_bound_val from oceanbase.__all_part where table_id=(select table_id from oceanbase.__all_table where table_name='tbl_247');

drop table tbl_247;

--echo 
--echo test modify key partition 

--disable_warnings
drop table if exists Z0CASE;
--enable_warnings

--echo test without part key specification.
--error 1167
create table Z0CASE (c1 int, c2 int, c3 text, primary key(c1, c3)) partition by key();

create table Z0CASE (c1 int, c2 int, c3 text, primary key(c1, c2)) partition by key();
drop table Z0CASE;

--echo test with part key specification.
--error 1659
create table Z0CASE (c1 int, c2 int, c3 text) partition by key(c3);
--error 1659
create table Z0CASE (c1 int, c2 int, c3 text) partition by key(c1, c3);

create table Z0CASE (c1 int, c2 int, c3 int) partition by key(c1, c2);
--error 1659
alter table Z0CASE modify c2 text;
drop table Z0CASE;

--echo test key subpartition.
--error 1659
create table Z0CASE (c1 int, c2 text, c3 int not null, primary key (c1, c3)) partition by range columns(c1) subpartition by key(c2) subpartitions 3
(
partition p201707 values less than (10),
partition p201808 values less than (26)
);

create table Z0CASE (c1 int, c2 int, c3 int not null, primary key (c1, c2, c3)) partition by range columns(c1) subpartition by key(c2) subpartitions 3
(
partition p201707 values less than (10),
partition p201808 values less than (26)
);

--error 1659
alter table Z0CASE modify c2 text;

--error 1659
alter table Z0CASE modify c2 blob;
drop table Z0CASE;

--echo test modify part key of aux table
--disable_warnings
drop table if exists Z0CASE;
--enable_warnings

--echo 
--echo main table non partitioned, but index table partitioned.
CREATE TABLE Z0CASE(z0_test0 YEAR , z0_test1 char(50),z0_test2 int AS (z0_test0 ) VIRTUAL);
CREATE INDEX index_z on Z0CASE(Z0_TEST0,Z0_TEST1) global PARTITION BY range (Z0_TEST0) (PARTITION part_1 VALUES LESS THAN (1 ), PARTITION part_2 VALUES LESS THAN (10 ), PARTITION part_3 VALUES LESS THAN ( maxvalue));
insert into Z0CASE(z0_test0, z0_test1) values('2010', 'aaaaa');
--error 4179
ALTER TABLE Z0CASE MODIFY COLUMN z0_test0 CHAR(101);
ALTER TABLE Z0CASE MODIFY COLUMN z0_test1 VARCHAR(50);
DROP TABLE Z0CASE;

CREATE TABLE Z0CASE (Z0_TEST0 BIT(64), Z0_TEST1 INT);
CREATE INDEX IDX1 ON Z0CASE(Z0_TEST0);
CREATE INDEX IDX2 ON Z0CASE(Z0_TEST0) PARTITION BY HASH(Z0_TEST0);
--error 4179
ALTER TABLE Z0CASE MODIFY COLUMN Z0_TEST0 SET ('','ABC','12321','0','123');
DROP TABLE Z0CASE;

--echo 
--echo test whether the key part is normal.
CREATE TABLE Z0CASE(Z0_TEST0 YEAR PRIMARY KEY, Z0_TEST1 CHAR(50)) PARTITION BY KEY();
CREATE INDEX IDX ON Z0CASE (Z0_TEST0);
insert into Z0CASE(z0_test0, z0_test1) values('2010', 'aaaaa');
ALTER TABLE Z0CASE MODIFY Z0_TEST0 CHAR(101);
--error 1659
ALTER TABLE Z0CASE MODIFY Z0_TEST0 blob;
DROP TABLE Z0CASE;

CREATE TABLE Z0CASE(Z0_TEST0 YEAR, Z0_TEST1 CHAR(50)) PARTITION BY KEY(Z0_TEST0);
CREATE INDEX IDX ON Z0CASE (Z0_TEST0);
insert into Z0CASE(z0_test0, z0_test1) values('2010', 'aaaaa');
ALTER TABLE Z0CASE MODIFY Z0_TEST0 CHAR(101);
--error 1659
ALTER TABLE Z0CASE MODIFY Z0_TEST0 blob;
DROP TABLE Z0CASE;

CREATE TABLE Z0CASE(z0_test0 YEAR , z0_test1 char(50),z0_test2 int AS (z0_test0 ) VIRTUAL);
CREATE INDEX index_z on Z0CASE(Z0_TEST0,Z0_TEST1) global PARTITION BY key (Z0_TEST0, z0_test1);
insert into Z0CASE(z0_test0, z0_test1) values('2010', 'aaaaa');
--error 4179
alter table Z0CASE modify COLUMN z0_test0 CHAR(101);
--error 4179
ALTER TABLE Z0CASE MODIFY COLUMN z0_test1 blob;
drop table Z0CASE;

--echo 
--echo Alter partition key may change partition definition order.
--disable_warnings
drop table if exists t1;
--enable_warnings
--error 1493
create table t1(c0 int, c1 bit(45)) partition by range(c1) (
  partition p0 values less than (-126),
  partition p1 values less than (-59),
  partition p2 values less than (30));

--echo
create table t1 ( col_8359 mediumint   not null ,col_8360 bit ( 42 )   not null ,col_8361 mediumint    default 1907944 ,col_8362 tinyint   not null default -8 ,col_8363 datetime    default '1998-04-26' ,col_8364 bigint   not null ,col_8365 boolean   not null ,col_8366 tinyint   not null default 34 ,col_8367 int  unsigned  default 3628097619 ,col_8368 boolean ,col_8369 decimal ( 43 , 18 )   not null default 931.4678 ,col_8370 char ( 222 )    default '' ,col_8371 tinyint  unsigned ,col_8372 smallint  unsigned not null default 36308 ,col_8373 char ( 53 )    default 'zgRU61Lhh_&!M嶊w' ,col_8374 tinyint  unsigned not null ,col_8375 blob ( 88 ) ,col_8376 double    default 8868.53394556956 ,col_8377 float   not null ,col_8378 bit ( 28 )    default 255335622 ,col_8379 int  unsigned  default 1073410002 ,col_8380 bit ( 60 )   not null default 1149686978348717759 ,col_8381 decimal ( 48 , 3 )   not null default 4802 ,col_8382 binary ( 83 )    default 'v-r' , key idx_1055 ( col_8362 ,col_8360 ,col_8373 ( 2 ) ) local )  partition by range ( col_8362 ) ( partition p0 values less than (-126), partition p1 values less than (-124), partition p2 values less than (-116), partition p3 values less than (-97), partition p4 values less than (-93), partition p5 values less than (-84), partition p6 values less than (-83), partition p7 values less than (-79), partition p8 values less than (-77), partition p9 values less than (-72), partition p10 values less than (-68), partition p11 values less than (-59), partition p12 values less than (-53), partition p13 values less than (-33), partition p14 values less than (-29), partition p15 values less than (-14), partition p16 values less than (-3), partition p17 values less than (7), partition p18 values less than (24), partition p19 values less than (28), partition p20 values less than (30), partition p21 values less than (32), partition p22 values less than (40), partition p23 values less than (47), partition p24 values less than (63), partition p25 values less than (75), partition p26 values less than (92), partition p27 values less than (105), partition p28 values less than (maxvalue) );
--error 1493
alter table t1 modify column col_8362 bit ( 45 ) not null first;
drop table t1;

--echo
create table t1(c0 int, c1 int) partition by range(c1) (
  partition p0 values less than (-126),
  partition p1 values less than (-59),
  partition p2 values less than (30));
--error 1493
alter table t1 modify c1 bit(45) first;
drop table t1;

--echo
create table t1(c1 int, c2 varchar(1), c3 char, c4 int) partition by hash(c1)
subpartition by range (c1)
subpartition template(
subpartition p0 values less than (-126),
subpartition p1 values less than (-59),
subpartition p2 values less than (30))
partitions 3;
--error 1493
alter table t1 modify c1 bit(45) first;
drop table t1;

--echo
create table t1(c0 int, c1 int) partition by range(c1) subpartition by hash(c0) subpartitions 5 (
  partition p0 values less than(-126), 
  partition p1 values less than(-59),
  partition p2 values less than(30));
--error 1493
alter table t1 modify c1 bit(45) first;
drop table t1;

--echo
create table t1(c1 int,c2 int ,c3 date) partition by list columns(c1) subpartition by hash(c2) (partition p0 values in (1,2,3)( subpartition part01), partition p1 values in (4,5,6)( subpartition part02), partition p2 values in (7,8,9) (subpartition part06));
--error 1659
alter table t1 modify c1 set('1', '2', '3');
drop table t1;
