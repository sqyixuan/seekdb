--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner : liujixiong.ljx
#owner group: storage 
#description: basic add/alter primary key case

--disable_warnings
drop table if exists t1, t2;
--enable_warnings
# test table with index and check constraint
create table t1(c1 int, c2 int);
create table t2(c1 int, c2 int);
insert into t1 values(1,1);
insert into t2 values(1,2);
create unique index i1 on t1(c1, c2);
create unique index i1 on t2(c1);
create index i2 on t1(c2);
alter table t1 add constraint check_cst11 check(c1 = c2);
alter table t1 add constraint fk1 foreign key(c1) references t2(c1);
alter table t1 add primary key(c1);
desc t1;
select * from t1;

--disable_warnings
drop table if exists z0CASE;
--enable_warnings
CREATE TABLE Z0CASE(Z0_TEST0 varchar(100) primary key, Z0_TEST1 text);
INSERT INTO z0case VALUES('11111', '222222');
INSERT INTO z0case VALUES('22222', '222222');
INSERT INTO z0case VALUES('33333', '222222');
INSERT INTO z0case VALUES('44444', '222222');
--error 1167
alter table Z0CASE drop primary key, add primary key(Z0_TEST1);

--disable_warnings
drop table if exists z0CASE;
--enable_warnings
CREATE TABLE Z0CASE(Z0_TEST0 int, Z0_TEST1 text);
INSERT INTO z0case VALUES(111, '222222');
INSERT INTO z0case VALUES(222, '222222');
INSERT INTO z0case VALUES(333, '222222');
INSERT INTO z0case VALUES(444, '222222');
--error 1167
alter table Z0CASE add primary key(Z0_TEST0, Z0_TEST1);

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
--disable_warnings
drop table if exists Z0CASE;
--enable_warnings
CREATE TABLE Z0CASE(Z0_TEST0 CHAR(100), Z0_TEST1 CHAR(100));
# alter table with lower case name.
ALTER TABLE z0case ADD PRIMARY KEY(Z0_TEST0);
DROP TABLE Z0CASE;

CREATE TABLE z0case(Z0_TEST0 CHAR(100), Z0_TEST1 CHAR(100));
# alter table with UPPER case name.
ALTER TABLE Z0CASE ADD PRIMARY KEY(Z0_TEST0);
DROP TABLE Z0CASE;

--echo to check the behavior for modify column and add primary key in one sql.
connection default;
--disable_warnings
drop table if exists z0case;
--enable_warnings
create table z0case(c1 char(10), c2 int, c3 int);
create index idx1 on z0case(c1, c2);
create index idx2 on z0case(c1, c3);
create unique index idx3 on z0case(c1, c3);
insert into z0case (c1, c2, c3) values('ab', 1, 2);
insert into z0case (c1, c2, c3) values('ab', 1, 3);
insert into z0case (c1, c2, c3) values('cd', 3, 4);
--error 1062
alter table z0case MODIFY COLUMN c2 BIGINT NOT NULL COMMENT "long ID", ADD PRIMARY KEY (c2);
--error 1062
alter table z0case MODIFY COLUMN c2 tinyint NOT NULL COMMENT "long ID", ADD PRIMARY KEY (c2);

# with NULL.
delete from z0case;
insert into z0case (c1, c3) values('ab', 2);
insert into z0case (c1, c2, c3) values('cd', 3, 4);
--error 1138
alter table z0case MODIFY COLUMN c2 BIGINT NOT NULL COMMENT "long ID", ADD PRIMARY KEY (c2);
--error 1138
alter table z0case MODIFY COLUMN c2 tinyint NOT NULL COMMENT "long ID", ADD PRIMARY KEY (c2);

delete from z0case;
insert into z0case (c1, c2, c3) values('ab', 1, 2);
insert into z0case (c1, c2, c3) values('cd', 3, 4);
alter table z0case MODIFY COLUMN c2 BIGINT NOT NULL COMMENT "long ID", ADD PRIMARY KEY (c2);
alter table z0case drop primary key;
alter table z0case MODIFY COLUMN c2 tinyint NOT NULL COMMENT "long ID", ADD PRIMARY KEY (c2);
alter table z0case drop primary key;
--error 1068
alter table z0case ADD PRIMARY KEY (c2), MODIFY COLUMN c2 BIGINT NOT NULL COMMENT "long ID", ADD primary key(c1);
--error 1068
alter table z0case ADD PRIMARY KEY (c2), MODIFY COLUMN c2 BIGINT NOT NULL COMMENT "long ID" primary key;
--error 1054
alter table z0case ADD PRIMARY KEY (c2), MODIFY COLUMN c2 BIGINT NOT NULL COMMENT "long ID", MODIFY COLUMN c2 tinyint NOT NULL COMMENT "long ID";
--error 1054
alter table z0case ADD PRIMARY KEY (c2), MODIFY COLUMN c2 tinyint NOT NULL COMMENT "long ID", MODIFY COLUMN c2 BIGINT NOT NULL COMMENT "long ID";
--error 1068
alter table z0case ADD PRIMARY KEY (c2), MODIFY COLUMN c2 BIGINT NOT NULL COMMENT "long ID", MODIFY COLUMN c3 bigint NOT NULL COMMENT "long ID" key;
alter table z0case MODIFY c1 varchar(10), ADD PRIMARY KEY (c2), MODIFY COLUMN c2 BIGINT NOT NULL COMMENT "long ID", MODIFY COLUMN c3 bigint NOT NULL COMMENT "long ID";
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = 1/g
show create table z0case;
show index from z0case;

--echo to check whether the indexes are correct.
connection obsys;
let $tenant_id = query_get_value(select 1 as tenant_id, tenant_id, 1);
let $z0case_id = query_get_value(select table_id from oceanbase.__all_virtual_table where table_name = 'z0case', table_id, 1);
--disable_query_log
eval select column_id, column_name, rowkey_position, index_position from oceanbase.__all_virtual_column where table_id in (select table_id from oceanbase.__all_virtual_table where data_table_id = $z0case_id);
--enable_query_log

connection default;
drop table z0case;

--echo to check the behavior for modify column and add primary key in one sql.
--disable_warnings
drop table if exists z0case;
--enable_warnings
create table z0case(c1 int, c2 int, c3 char(20));
insert into z0case values(1, 2, 'abcde');
insert into z0case values(3, 4, 'defgh');
--error 1064
alter table z0case drop column c1, add primary(c2);
--error 1235
alter table z0case change c1 c1_x bigint, add primary key(c2);
--error 1235
alter table z0case modify c3 varchar(10), add primary key(c2), change c1 c1_x bigint;
alter table z0case modify c3 varchar(10), add primary key(c2);
--error 1235
alter table z0case modify c3 varchar(10), drop primary key;
--error 1235
alter table z0case drop primary key, modify c3 varchar(10);
--error 1235
alter table z0case drop primary key, add primary key(c2), modify c3 varchar(10);
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = 1/g
show create table z0case;
drop table z0case;

--echo to check whether the order of primary key columns are correct.
--disable_warnings
drop table if exists z0case;
--enable_warnings
create table z0case(c1 int, c2 char(20), c3 double, primary key(c3, c1));
insert into z0case values(1, 'test', 0.000000111);
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = 1/g
show create table z0case;

alter table z0case drop primary key;
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = 1/g
show create table z0case;

alter table z0case add primary key(c2, c1, c3);
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = 1/g
show create table z0case;

alter table z0case drop primary key, add primary key(c3, c1, c2);
--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = 1/g
show create table z0case;

drop table z0case;
