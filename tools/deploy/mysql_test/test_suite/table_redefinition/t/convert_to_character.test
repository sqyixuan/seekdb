--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: liujixiong.ljx
# owner group: storage
# description: test convert to character.

--disable_warnings
drop database if exists yiren_db;
--enable_warnings
create database yiren_db;
use yiren_db;


--echo ================ test convert to character on non-partition table start ================
--echo check if row in correct partition.
DROP TABLE IF EXISTS Z0CASE;
CREATE TABLE Z0CASE (T1 CHAR(10) CHARACTER SET 'gb18030' PRIMARY KEY,T2 VARCHAR(10))
PARTITION BY KEY(T1) PARTITIONS 3 ;
INSERT INTO  Z0CASE VALUES(11,11);
INSERT INTO  Z0CASE VALUES('AbC','ABc');
INSERT INTO  Z0CASE VALUES('$%^&*()//','$%^&*()//');
INSERT INTO  Z0CASE VALUES('','');
ALTER TABLE Z0CASE MODIFY T1 CHAR(20) CHARACTER SET 'binary' COLLATE 'binary';
select hex(T1), hex(T2) from Z0CASE partition(p0) order by T1, T2;
select hex(T1), hex(T2) from Z0CASE partition(p1) order by T1, T2;
select hex(T1), hex(T2) from Z0CASE partition(p2) order by T1, T2;
DROP TABLE Z0CASE;

CREATE TABLE Z0CASE (T1 CHAR(20) CHARACTER SET 'binary' COLLATE 'binary'PRIMARY KEY,T2 VARCHAR(10))
PARTITION BY KEY(T1) PARTITIONS 3 ;
INSERT INTO  Z0CASE VALUES(11,11);
INSERT INTO  Z0CASE VALUES('AbC','ABc');
INSERT INTO  Z0CASE VALUES('$%^&*()//','$%^&*()//');
INSERT INTO  Z0CASE VALUES('','');

select hex(T1), hex(T2) from Z0CASE partition(p0) order by T1, T2;
select hex(T1), hex(T2) from Z0CASE partition(p1) order by T1, T2;
select hex(T1), hex(T2) from Z0CASE partition(p2) order by T1, T2;
DROP TABLE Z0CASE;
--echo ================ test convert to character on non-partition table end ================


--echo ================ test convert to character on partition table start ================
set sql_mode = "";

--echo 1. simple test.
--error 1659
create table t1(c1 char) partition by range(c1) (partition p0 values less than('A'));
--error 1659
create table t1(c1 char) partition by list(c1) (partition p0 values in ('A'));
--error 1659
create table t1(c1 char) partition by hash(c1);

--echo 2. key part test.
create table t1(c1 char) partition by key(c1);
insert into t1 values('A'), ('B');
--source mysql_test/test_suite/charset/include/character_transform.inc

select hex(c1) from t1 order by c1;
drop table t1;

--echo 3. range columns part test.
create table t1(c1 char, c2 int) partition by range columns(c1, c2)(partition p0 values less than('A', 10), partition p1 values less than('K', 10));
insert into t1 values(1, 1), (2, 2), ('B', 3);
select hex(c1), c2 from t1 partition(p0) order by c1, c2;
select hex(c1), c2 from t1 partition(p1) order by c1, c2;
--source mysql_test/test_suite/charset/include/character_transform.inc

select hex(c1), c2 from t1 partition(p0) order by c1, c2;
select hex(c1), c2 from t1 partition(p1) order by c1, c2;
drop table t1;

--echo 4. list columns part.
create table t1(c1 int, c2 char) partition by list columns(c1, c2)
(partition p0 values in((1, 'A'), (1, 'B'), (1, 'C')), partition p1 values in((1, 'D'), (1, 'E'), (1, 'F')));
insert into t1 values(1, 'A'), (1, 'D');
select c1, hex(c2) from t1 partition(p0) order by c1, c2;
select c1, hex(c2) from t1 partition(p1) order by c1, c2;
--source mysql_test/test_suite/charset/include/character_transform.inc

select c1, hex(c2) from t1 partition(p0) order by c1, c2;
select c1, hex(c2) from t1 partition(p1) order by c1, c2;
drop table t1;

--echo 5. test subpart.
create table t1(c1 int, c2 varchar(1), c3 char, c4 int) partition by hash(c1)
subpartition by range columns(c1, c2, c3, c4)
subpartition template(
subpartition p0 values less than (10, 'A', '1', 10),
subpartition p1 values less than (100, 'Z', '9', 50))
partitions 2;
insert into t1 values (1, 1, '0', 0), (10, 'A', '1', 10), (10, 'B', '1', 10);
select c1, hex(c2), hex(c3), c4 from t1 partition(p0) order by c1, c2, c3, c4;
select c1, hex(c2), hex(c3), c4 from t1 partition(p1) order by c1, c2, c3, c4;
--source mysql_test/test_suite/charset/include/character_transform.inc

select c1, hex(c2), hex(c3), c4 from t1 partition(p0) order by c1, c2, c3, c4;
select c1, hex(c2), hex(c3), c4 from t1 partition(p1) order by c1, c2, c3, c4;
drop table t1;

create table t1 (c1 int, c2 varchar(1), c3 int, c4 char, c5 int, primary key(c1, c2, c3, c4)) 
partition by list columns(c1, c2) subpartition by range columns(c3, c4) 
subpartition template (subpartition p0 values less than (100, 'A'), 
subpartition p1 values less than (200, 'Z')) 
(partition p0 values in ((100, 'B')), partition p1 values in ((200, 'B')));
insert into t1 values(100, 'B', 80, 1, 0), (100, 'B', 80, 'B', 0), (200, 'B', 150, 1, 0), (200, 'B', 150, 'B', 0);
select c1, hex(c2), c3, hex(c4), c5 from t1 partition(p0) order by c1, c2, c3, c4, c5;
select c1, hex(c2), c3, hex(c4), c5 from t1 partition(p1) order by c1, c2, c3, c4, c5;
--source mysql_test/test_suite/charset/include/character_transform.inc

select c1, hex(c2), c3, hex(c4), c5 from t1 partition(p0) order by c1, c2, c3, c4, c5;
select c1, hex(c2), c3, hex(c4), c5 from t1 partition(p1) order by c1, c2, c3, c4, c5;
drop table t1;

create table t1 (c1 int, c2 varchar(100), c3 int, c4 char(100), c5 int, primary key(c1, c2, c3, c4)) 
partition by list columns(c1, c2) subpartition by range columns(c3, c4) 
subpartition template (subpartition p0 values less than (100, 'AAAAAAAAAA'), 
subpartition p1 values less than (200, 'ZZZZZZZZZZ')) 
(partition p0 values in ((100, 'BBBBBBBBBB')), partition p1 values in ((200, 'BBBBBBBBBB')));
insert into t1 values(100, 'BBBBBBBBBB', 80, 1, 0), (100, 'BBBBBBBBBB', 80, 'B', 0), (200, 'BBBBBBBBBB', 150, 1, 0), (200, 'BBBBBBBBBB', 150, 'B', 0);
select c1, hex(c2), c3, hex(c4), c5 from t1 partition(p0) order by c1, c2, c3, c4, c5;
select c1, hex(c2), c3, hex(c4), c5 from t1 partition(p1) order by c1, c2, c3, c4, c5;
--source mysql_test/test_suite/charset/include/character_transform.inc

select c1, hex(c2), c3, hex(c4), c5 from t1 partition(p0) order by c1, c2, c3, c4, c5;
select c1, hex(c2), c3, hex(c4), c5 from t1 partition(p1) order by c1, c2, c3, c4, c5;
drop table t1;

--echo 6. test subpart template.
create table t1 (c1 int, c2 char, c3 varchar(10), c4 int) 
partition by range(c1) subpartition by range columns(c2, c3, c4) 
subpartition template (subpartition rsp0 values less than ('A', 'aa', 10), 
subpartition rsp1 values less than ('M', 'mm', 10), 
subpartition rsp2 values less than ('Z', 'zz', 10)) 
(partition rp0 values less than (100), partition rp1 values less than (200), partition rp2 values less than (300));
insert into t1 values(10, 0, 'a0', 1), (150, 'K', 'abcd', 1), (260, 'Q', 'nndgj', 1);
select c1, hex(c2), hex(c3), c4 from t1 partition(rp0) order by c1, c2, c3, c4;
select c1, hex(c2), hex(c3), c4 from t1 partition(rp1) order by c1, c2, c3, c4;
select c1, hex(c2), hex(c3), c4 from t1 partition(rp2) order by c1, c2, c3, c4;

--source mysql_test/test_suite/charset/include/character_transform.inc
select c1, hex(c2), hex(c3), c4 from t1 partition(rp0) order by c1, c2, c3, c4;
select c1, hex(c2), hex(c3), c4 from t1 partition(rp1) order by c1, c2, c3, c4;
select c1, hex(c2), hex(c3), c4 from t1 partition(rp2) order by c1, c2, c3, c4;

--echo test add partition.
alter table t1 add partition (partition rp3 values less than(1000));
--source mysql_test/test_suite/charset/include/character_transform.inc

select c1, hex(c2), hex(c3), c4 from t1 partition(rp0) order by c1, c2, c3, c4;
select c1, hex(c2), hex(c3), c4 from t1 partition(rp1) order by c1, c2, c3, c4;
select c1, hex(c2), hex(c3), c4 from t1 partition(rp2) order by c1, c2, c3, c4;
select c1, hex(c2), hex(c3), c4 from t1 partition(rp3) order by c1, c2, c3, c4;
drop table t1;

create table t1 (c0 char(10), c1 int, c2 char, c3 varchar(10), c4 int) 
partition by range columns(c0, c1) subpartition by list columns(c2, c3, c4) 
subpartition template (subpartition rsp0 values in ('A', 'aa', 10), 
subpartition rsp1 values in ('A', 'bbcd', 10), 
subpartition rsp2 values in ('A', 'bbcz', 10))
(partition rp0 values less than ('abcd', 10), partition rp1 values less than ('abcd', 200), partition rp2 values less than ('abcd', 300));
insert into t1 values('ab0', 0, 'A', 'aa', 10), ('abc0', 150, 'A', 'bbcd', 10), ('012345', 230, 'A', 'bbcz', 10);
select hex(c0), c1, hex(c2), hex(c3), c4 from t1 partition(rp0) order by c1, c2, c3, c4;
select hex(c0), c1, hex(c2), hex(c3), c4 from t1 partition(rp1) order by c1, c2, c3, c4;
select hex(c0), c1, hex(c2), hex(c3), c4 from t1 partition(rp2) order by c1, c2, c3, c4;
--source mysql_test/test_suite/charset/include/character_transform.inc

--echo test add partition.
alter table t1 add partition (partition rp3 values less than('abcd', 1000));
--source mysql_test/test_suite/charset/include/character_transform.inc

select hex(c0), c1, hex(c2), hex(c3), c4 from t1 partition(rp0) order by c1, c2, c3, c4;
select hex(c0), c1, hex(c2), hex(c3), c4 from t1 partition(rp1) order by c1, c2, c3, c4;
select hex(c0), c1, hex(c2), hex(c3), c4 from t1 partition(rp2) order by c1, c2, c3, c4;
select hex(c0), c1, hex(c2), hex(c3), c4 from t1 partition(rp3) order by c1, c2, c3, c4;
drop table t1;

drop database if exists yiren_db;
--echo ================ test convert to character on partition table end ================
