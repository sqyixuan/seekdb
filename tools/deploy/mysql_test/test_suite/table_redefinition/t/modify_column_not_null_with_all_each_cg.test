--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner : lihongqin.lhq
#owner group: storage 
#description: test ddl modify column not null

--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1(c1 int, c2 int not null, c3 varchar(200), c4 int) partition by hash(c1) partitions 3 with column group (all columns, each column);
insert into t1(c1,c2,c3) values(1,1,'a'),(2,2,'b'),(3,3,'c');
alter table t1 modify c1 int not null;
# now we can support change column name and add not null constraint
alter table t1 change column c3 c5 varchar(64) not null;
alter table t1 change column c5 c3 varchar(64) not null;
--error 1138
alter table t1 modify c4 int not null;

desc t1;
select * from t1;

drop table t1;

create table t1(c1 int, c2 int not null, c3 varchar(200), c4 int) partition by hash(c1) partitions 3 with column group (all columns, each column);
alter table t1 modify c1 int not null;
# now we can support change column name and add not null constraint
alter table t1 change column c3 c5 varchar(64) not null;
alter table t1 change column c5 c3 varchar(64) not null;
alter table t1 modify c4 int not null;

desc t1;
select * from t1;

drop table t1;
