--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner : lihongqin.lhq
#owner group: storage 
#description: basic add/alter primary key case

--disable_warnings
drop table if exists t1;
--enable_warnings
set @saved_sql_mode = @@session.sql_mode;
set @@session.sql_mode = 'STRICT_ALL_TABLES,PAD_CHAR_TO_FULL_LENGTH';
# test table with index and check constraint
create table t1(c1 int, c2 char(4)) ;
Insert into t1 values(1,'c');
alter table t1 add primary key(c1);
set @@session.sql_mode = 'STRICT_ALL_TABLES';
select length(c2) from t1;
create index i1 on t1(c2) storing(c1) with column group(all columns, each column);
select /*+ index(t1 i1) */ length(c2) from t1;
set @@session.sql_mode = @saved_sql_mode;
