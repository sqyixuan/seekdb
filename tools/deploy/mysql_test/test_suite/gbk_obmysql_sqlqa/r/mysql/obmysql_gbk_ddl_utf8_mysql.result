drop database  IF EXISTS  ob35x;
create database ob35x  character set utf8;
use ob35x;
########gbk||DDL constraint№ШБӘІвКФ·ЦОцobmysql-gbk-1-1-2##########
SET NAMES gbk;
drop table if exists test1;
create table test1(
id int(10),
name varchar(32) character set gbk not null,
email varchar(128) character set gbk,
unique(name,email)
)DEFAULT CHARACTER SET = gbk;
insert into test1(id,name,email) values(1,'xxx','qq.com');
insert into test1(id,name,email) values(2,'АПНх','qq.com');
SET NAMES utf8mb4;
select name, hex(name) from test1;
name	hex(name)
xxx	787878
иҖҒзҺӢ	C0CFCDF5
select length(name) from test1;
length(name)
3
4
drop table if exists test1;
########gbk||DDL utf8 constraint№ШБӘІвКФ·ЦОцobmysql-gbk-1-1-2##########
