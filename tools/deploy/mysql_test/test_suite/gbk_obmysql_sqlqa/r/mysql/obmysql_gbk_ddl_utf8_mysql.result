SET NAMES gbk;
drop table if exists t_student;
drop table if exists t_class;
create table t_class(
cno int(10) primary key,
cname varchar(128) character set gbk not null unique
)DEFAULT CHARACTER SET = gbk;
create table t_student(
sno int(10) primary key auto_increment,
sname varchar(32) character set gbk not null,
classno int(3),
foreign key(classno) references t_class(cno)
)DEFAULT CHARACTER SET = gbk;
insert into t_class(cno,cname) values(100,'ДгДгДгТФТФ');
insert into t_class(cno,cname) values(200,'№ю№ю№ю№ю№ю');
insert into t_student(sname,classno) values('¶Ф',100);
insert into t_student(sname,classno) values('ҙн',100);
insert into t_student(sname,classno) values('әГ',200);
SET NAMES utf8mb4;
select s.*,c.* from t_student s join t_class c on s.classno=c.cno;
sno	sname	classno	cno	cname
1	еҜ№	100	100	дҪ дҪ дҪ д»Ҙд»Ҙ
2	й”ҷ	100	100	дҪ дҪ дҪ д»Ҙд»Ҙ
3	еҘҪ	200	200	е“Ҳе“Ҳе“Ҳе“Ҳе“Ҳ
drop table if exists t_student;
drop table if exists t_class;
