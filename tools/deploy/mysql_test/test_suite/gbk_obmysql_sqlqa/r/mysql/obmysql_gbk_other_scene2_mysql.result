drop table  IF EXISTS  t1;
########gbk|| - collateІвКФ##########
SET NAMES gbk;
drop table if exists t1;
create table t1(c1 varchar(2) CHARACTER SET gbk COLLATE gbk_chinese_ci primary key,c2 varchar(10))DEFAULT CHARACTER SET = gbk;
replace into t1 (c1,c2) values ('ЦРОД','өЪТ»ёц');
replace into t1 (c1,c2) values (_binary'Т»Т»','¶ю¶ю¶ю');
replace into t1 (c1,c2) values (_gbk'Т»Т»'collate gbk_bin,'¶ю¶ю¶ю');
SET NAMES utf8mb4;
select * from t1;
c1	c2
дёҖдёҖ	дәҢдәҢдәҢ
дёӯж–Ү	з¬¬дёҖдёӘ
drop table if exists t1;
########||gbk utf8 - collateІвКФ##########
SET NAMES gbk;
drop table if exists t1;
create table t1(c1 varchar(2) character set utf8mb4 collate utf8mb4_general_ci primary key,c2 varchar(10))DEFAULT CHARACTER SET = utf8;
replace into t1 (c1,c2) values ('ЦРОД','өЪТ»ёц');
replace into t1 (c1,c2) values (_binary'Т»','¶ю¶ю¶ю');
replace into t1 (c1,c2) values (_gbk'Т»Т»'collate gbk_bin,'¶ю¶ю¶ю');
SET NAMES utf8mb4;
select * from t1;
c1	c2
Т»	дәҢдәҢдәҢ
дёҖдёҖ	дәҢдәҢдәҢ
дёӯж–Ү	з¬¬дёҖдёӘ
drop table if exists t1;
