########gbk||DML  obmysql-gbk-1-2-1-1##########
drop database  IF EXISTS  ob35x;
create database ob35x  character set gbk;
use ob35x;
SET NAMES gbk;
drop table if exists mail;
create table mail
(
t decimal(6,2),
srcuser varchar(8) character set gbk,
srchost varchar(20) character set gbk,
dstuser varchar(8) character set gbk,
dsthost varchar(20) character set gbk,
size BIGINT,
index(t)
)DEFAULT CHARACTER SET = gbk;
insert into mail values(1,'中文测试1','中文测试2','中文测试3','中文测试4',100);
insert into mail values(2,'中文测试5','中文测试6','中文测试7','中文测试8',100);
SET NAMES utf8mb4;
select t.srcuser as '中文测试ing' from mail t;
中文测试ing
涓枃娴嬭瘯1
涓枃娴嬭瘯5
select '33','!',ascii('!') from dual union all
select '34','"',ascii('"') from dual;
33	!	ascii('!')
33	!	33
34	"	34
drop table if exists mail;
########gbk||DML utf8 obmysql-gbk-1-2-1-1##########
drop database  IF EXISTS  ob35x;
create database ob35x  character set gbk;
use ob35x;
SET NAMES gbk;
drop table if exists mail;
create table mail
(
t decimal(6,2),
srcuser varchar(8) character set utf8,
srchost varchar(20) character set utf8,
dstuser varchar(8) character set utf8,
dsthost varchar(20) character set utf8,
size BIGINT,
index(t)
)DEFAULT CHARACTER SET = utf8;
insert into mail values(1,'中文测试1','中文测试2','中文测试3','中文测试4',100);
SET NAMES utf8mb4;
select t.srcuser as '中文测试ing' from mail t;
中文测试ing
涓枃娴嬭瘯1
select '33','!',ascii('!') from dual union all
select '34','"',ascii('"') from dual;
33	!	ascii('!')
33	!	33
34	"	34
drop table if exists mail;
########gbk||DML  obmysql-gbk-1-2-1-8##########
SET NAMES gbk;
drop table if exists employee_tbl;
CREATE TABLE `employee_tbl` (
`id` int(11) NOT NULL,
`name` char(10) character set gbk NOT NULL DEFAULT '',
`date` datetime NOT NULL,
`singin` tinyint(4) NOT NULL DEFAULT '0' ,
PRIMARY KEY (`id`)
)DEFAULT CHARSET=gbk;
INSERT INTO `employee_tbl` VALUES ('1', '小明', '2016-04-22 15:25:33', '1'), ('2', '小王', '2016-04-20 15:25:47', '3'), ('3', '小丽', '2016-04-19 15:26:02', '2'), ('4', '小王', '2016-04-07 15:26:14', '4'), ('5', '小明', '2016-04-11 15:26:40', '4'), ('6', '小明', '2016-04-04 15:26:54', '2');
SET NAMES utf8mb4;
SELECT name, COUNT(*) FROM   employee_tbl GROUP BY name;
name	COUNT(*)
灏忔槑	3
灏忕帇	2
灏忎附	1
SELECT name, COUNT(*) FROM   employee_tbl GROUP BY name having COUNT(*) >2;
name	COUNT(*)
灏忔槑	3
##gbk||DML  obmysql-gbk-1-2-1-9###
SELECT * FROM  employee_tbl order by name desc;
id	name	date	singin
2	灏忕帇	2016-04-20 15:25:47	3
4	灏忕帇	2016-04-07 15:26:14	4
1	灏忔槑	2016-04-22 15:25:33	1
5	灏忔槑	2016-04-11 15:26:40	4
6	灏忔槑	2016-04-04 15:26:54	2
3	灏忎附	2016-04-19 15:26:02	2
SELECT * FROM  employee_tbl order by name asc;
id	name	date	singin
3	灏忎附	2016-04-19 15:26:02	2
1	灏忔槑	2016-04-22 15:25:33	1
5	灏忔槑	2016-04-11 15:26:40	4
6	灏忔槑	2016-04-04 15:26:54	2
2	灏忕帇	2016-04-20 15:25:47	3
4	灏忕帇	2016-04-07 15:26:14	4
drop table if exists mail;
########gbk||DML utf8 obmysql-gbk-1-2-1-8##########
SET NAMES gbk;
drop table if exists employee_tbl;
CREATE TABLE `employee_tbl` (
`id` int(11) NOT NULL,
`name` char(10) character set utf8 NOT NULL DEFAULT '',
`date` datetime NOT NULL,
`singin` tinyint(4) NOT NULL DEFAULT '0' ,
PRIMARY KEY (`id`)
)DEFAULT CHARSET=utf8;
INSERT INTO `employee_tbl` VALUES ('1', '小明', '2016-04-22 15:25:33', '1'), ('2', '小王', '2016-04-20 15:25:47', '3'), ('3', '小丽', '2016-04-19 15:26:02', '2'), ('4', '小王', '2016-04-07 15:26:14', '4'), ('5', '小明', '2016-04-11 15:26:40', '4'), ('6', '小明', '2016-04-04 15:26:54', '2');
SET NAMES utf8mb4;
SELECT name, COUNT(*) FROM   employee_tbl GROUP BY name;
name	COUNT(*)
灏忔槑	3
灏忕帇	2
灏忎附	1
SELECT name, COUNT(*) FROM   employee_tbl GROUP BY name having COUNT(*) >2;
name	COUNT(*)
灏忔槑	3
##gbk||DML  obmysql-gbk-1-2-1-9###
SELECT * FROM  employee_tbl order by name desc;
id	name	date	singin
2	灏忕帇	2016-04-20 15:25:47	3
4	灏忕帇	2016-04-07 15:26:14	4
1	灏忔槑	2016-04-22 15:25:33	1
5	灏忔槑	2016-04-11 15:26:40	4
6	灏忔槑	2016-04-04 15:26:54	2
3	灏忎附	2016-04-19 15:26:02	2
SELECT * FROM  employee_tbl order by name asc;
id	name	date	singin
3	灏忎附	2016-04-19 15:26:02	2
1	灏忔槑	2016-04-22 15:25:33	1
5	灏忔槑	2016-04-11 15:26:40	4
6	灏忔槑	2016-04-04 15:26:54	2
2	灏忕帇	2016-04-20 15:25:47	3
4	灏忕帇	2016-04-07 15:26:14	4
drop table if exists mail;
########gbk||DML  update obmysql-gbk-1-2-3##########
SET NAMES gbk;
drop table if exists runoob_tbl;
CREATE TABLE IF NOT EXISTS `runoob_tbl`(
`runoob_id` INT UNSIGNED AUTO_INCREMENT,
`runoob_title` VARCHAR(100) character set gbk NOT NULL,
`runoob_author` VARCHAR(40) character set gbk NOT NULL,
`submission_date` DATE,
PRIMARY KEY ( `runoob_id` )
)DEFAULT CHARSET=gbk;
INSERT INTO runoob_tbl
(runoob_title, runoob_author, submission_date)
VALUES
("学习 PHP", "菜鸟教程", '2016-05-04');
INSERT INTO runoob_tbl
(runoob_title, runoob_author, submission_date)
VALUES
("学习 MySQL", "菜鸟教程", '2016-05-05');
INSERT INTO runoob_tbl
(runoob_title, runoob_author, submission_date)
VALUES
("JAVA 教程", "RUNOOB.COM", '2016-05-06');
