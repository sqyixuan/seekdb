SELECT * from runoob_tbl WHERE runoob_id=3;
runoob_id	runoob_title	runoob_author	submission_date
3	JAVA 鏁欑▼	RUNOOB.COM	2016-05-06
drop table if exists runoob_tbl;
########gbk||DML utf8 update obmysql-gbk-1-2-3##########
