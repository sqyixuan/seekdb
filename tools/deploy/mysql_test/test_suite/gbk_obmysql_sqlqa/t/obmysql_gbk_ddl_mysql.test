--echo  ########bugs verify-gbk 【gbk】字段转换 ##########

SET NAMES gbk;
###--character_set gbk

-- disable_warnings
drop table  IF EXISTS  varchar_gbk_1;
drop table  IF EXISTS  varchar_gbk_2;
-- enable_warnings


create table varchar_gbk_1(c1 varchar(1) character set gbk,c2 int)DEFAULT CHARACTER SET = gbk;
insert into varchar_gbk_1 values('啊',1);
alter table varchar_gbk_1 modify c1 char(1);
--error 1264
insert into varchar_gbk_1 values('呵',222222222222);

create table varchar_gbk_2(c1 TINYTEXT character set gbk,c2 int)DEFAULT CHARACTER SET = gbk;
insert into varchar_gbk_2 values('啊',1);
alter table varchar_gbk_2 modify c1 char(1);
DESC varchar_gbk_2;

###--character_set utf8mb4
SET NAMES utf8mb4;

desc varchar_gbk_1;
desc varchar_gbk_2;

-- disable_warnings
drop table  IF EXISTS  varchar_gbk_1;
drop table  IF EXISTS  varchar_gbk_2;
-- enable_warnings

--echo  ########bugs verify-gbk 【utf8】字段转换 ##########

SET NAMES gbk;
###--character_set gbk

-- disable_warnings
drop table  IF EXISTS  varchar_gbk_1;
drop table  IF EXISTS  varchar_gbk_2;
-- enable_warnings


create table varchar_gbk_1(c1 varchar(1) character set utf8,c2 int)DEFAULT CHARACTER SET = utf8;
insert into varchar_gbk_1 values('啊',1);
alter table varchar_gbk_1 modify c1 char(1);
--error 1264
insert into varchar_gbk_1 values('呵',222222222222);

create table varchar_gbk_2(c1 TINYTEXT character set utf8,c2 int)DEFAULT CHARACTER SET = utf8;
