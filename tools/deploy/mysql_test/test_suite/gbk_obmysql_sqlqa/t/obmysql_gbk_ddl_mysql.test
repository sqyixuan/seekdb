--echo  ########gbk||DDL index关联测试分析obmysql-gbk-1-1-4-2##########

SET NAMES gbk;
###--character_set gbk

--disable_warnings
drop table if exists user_test;
drop table if exists user_test2;
--enable_warnings

CREATE TABLE user_test (
	id INT AUTO_INCREMENT,
	fileuploadercode VARCHAR(128) character set gbk,
	projectid INT,
	filename VARCHAR (512) character set gbk,
	fileurl VARCHAR (512) character set gbk,
	filesize BIGINT,
    PRIMARY KEY (id),
	UNIQUE INDEX (projectid),
	INDEX (fileuploadercode)
)DEFAULT CHARSET = gbk;

insert into user_test values (NULL,'上海',2,'上海','上海',200);
--error 1062
insert into user_test values (NULL,'上海',2,'上海','上海',200);

CREATE TABLE user_test2 (
	id INT AUTO_INCREMENT,
	fileuploadercode VARCHAR(128) character set gbk,
	projectid INT,
	filename VARCHAR (512) character set gbk,
	fileurl VARCHAR (512) character set gbk,
	filesize BIGINT,
    PRIMARY KEY (id),
	UNIQUE INDEX (fileuploadercode,projectid)
)DEFAULT CHARSET = gbk;

insert into user_test2 values (NULL,'北京',2,'北京','北京',200);
--error 1062
insert into user_test2 values (NULL,'北京',2,'北京','北京',200);

###--character_set utf8mb4
SET NAMES utf8mb4;

select * from user_test;
select * from user_test2;

--disable_warnings
drop table if exists user_test;
drop table if exists user_test2;
--enable_warnings

