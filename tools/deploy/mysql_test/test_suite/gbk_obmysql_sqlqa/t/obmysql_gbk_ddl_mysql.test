--echo  ########gbk||DDL constraint关联测试分析obmysql-gbk-1-1-2##########

SET NAMES gbk;
###--character_set gbk

--disable_warnings
drop table if exists test1;
--enable_warnings

create table test1(
id int(10),
name varchar(32) character set gbk not null,
email varchar(128) character set gbk,
unique(name,email)
)DEFAULT CHARACTER SET = gbk;

insert into test1(id,name,email) values(1,'xxx','qq.com');
insert into test1(id,name,email) values(2,'老王','qq.com');
#bug id：28014934
###--error 1062
###insert into test1(id,name,email) values(3,'老王','qq.com');

###--character_set utf8mb4
SET NAMES utf8mb4;

select name, hex(name) from test1;
select length(name) from test1;

--disable_warnings
drop table if exists test1;
--enable_warnings

--echo  ########gbk||DDL utf8 constraint关联测试分析obmysql-gbk-1-1-2##########

SET NAMES gbk;
###--character_set gbk

--disable_warnings
drop table if exists test1;
--enable_warnings

create table test1(
id int(10),
name varchar(32) character set utf8 not null,
email varchar(128) character set utf8,
unique(name,email)
)DEFAULT CHARACTER SET = utf8;

insert into test1(id,name,email) values(1,'xxx','qq.com');
insert into test1(id,name,email) values(2,'老王','qq.com');
###--error 1062
###insert into test1(id,name,email) values(3,'老王','qq.com');

###--character_set utf8mb4
SET NAMES utf8mb4;

select name, hex(name) from test1;
select length(name) from test1;

--disable_warnings
drop table if exists test1;
--enable_warnings


--echo  ########gbk||DDL constraint关联测试分析obmysql-gbk-1-1-2##########

SET NAMES gbk;
###--character_set gbk

--disable_warnings
drop table if exists t_student;
drop table if exists t_class;
--enable_warnings

create table t_class(
cno int(10) primary key,
cname varchar(128) character set gbk not null unique
)DEFAULT CHARACTER SET = gbk;

create table t_student(
sno int(10) primary key auto_increment,
sname varchar(32) character set gbk not null,
classno int(3),
foreign key(classno) references t_class(cno)
)DEFAULT CHARACTER SET = gbk;

insert into t_class(cno,cname) values(100,'你你你以以');
insert into t_class(cno,cname) values(200,'哈哈哈哈哈');
insert into t_student(sname,classno) values('对',100);
insert into t_student(sname,classno) values('错',100);
insert into t_student(sname,classno) values('好',200);


###--character_set utf8mb4
SET NAMES utf8mb4;

select s.*,c.* from t_student s join t_class c on s.classno=c.cno;

--disable_warnings
drop table if exists t_student;
drop table if exists t_class;
--enable_warnings

--echo  ########gbk||DDL utf8 constraint关联测试分析obmysql-gbk-1-1-2##########

SET NAMES gbk;
###--character_set gbk

--disable_warnings
drop table if exists t_student;
drop table if exists t_class;
--enable_warnings

create table t_class(
cno int(10) primary key,
cname varchar(128) character set utf8 not null unique
)DEFAULT CHARACTER SET = utf8;

create table t_student(
sno int(10) primary key auto_increment,
sname varchar(32) character set utf8 not null,
classno int(3),
foreign key(classno) references t_class(cno)
)DEFAULT CHARACTER SET = utf8;

insert into t_class(cno,cname) values(100,'你你你以以');
insert into t_class(cno,cname) values(200,'哈哈哈哈哈');
insert into t_student(sname,classno) values('对',100);
insert into t_student(sname,classno) values('错',100);
insert into t_student(sname,classno) values('好',200);

###--character_set utf8mb4
SET NAMES utf8mb4;

select s.*,c.* from t_student s join t_class c on s.classno=c.cno;

--disable_warnings
drop table if exists t_student;
drop table if exists t_class;
--enable_warnings


