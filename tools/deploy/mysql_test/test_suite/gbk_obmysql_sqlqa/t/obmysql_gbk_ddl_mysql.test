###--character_set utf8mb4
SET NAMES utf8mb4;

desc varchar_gbk_1;
desc varchar_gbk_2;
select * from varchar_gbk_1;
select * from varchar_gbk_2;

-- disable_warnings
drop table  IF EXISTS  varchar_gbk_1;
drop table  IF EXISTS  varchar_gbk_2;
