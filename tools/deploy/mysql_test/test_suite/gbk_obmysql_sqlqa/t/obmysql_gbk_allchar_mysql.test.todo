--echo  ########allchar test-gbk database/obmysql-gbk-2##########

SET NAMES gbk;
###--character_set gbk

-- disable_warnings
drop database  IF EXISTS  ob35x;
-- enable_warnings
create database ob35x  character set gbk;
use ob35x;

-- disable_warnings
drop table  IF EXISTS  gbk_dml_001;
-- enable_warnings

###ERROR 1075 (42000): Incorrect table definition; there can be only one auto column and it must be defined as a key;ob暂无限制；
###create table gbk_dml_001(c0 varchar(5) character set gbk,c1 varchar(5) character set gbk,c2 char(5) character set gbk ,c4 varchar(1) character set gbk,c5 varchar(1) character set gbk,c3 int ###auto_increment)DEFAULT CHARACTER SET = gbk;
create table gbk_dml_001(c0 varchar(5) character set gbk,c1 varchar(5) character set gbk,c2 char(5) character set gbk ,c4 varchar(1) character set gbk,c5 varchar(1) character set gbk,c3 int auto_increment primary key)DEFAULT CHARACTER SET = gbk;
