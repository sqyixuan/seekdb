--echo  ########gbk||DML datatypes  obmysql-gbk-3 全量##########
--disable_warnings
drop database  IF EXISTS  ob35x;
--enable_warnings
create database ob35x  character set gbk;
use ob35x;

SET NAMES gbk;
###--character_set gbk

--disable_warnings
drop table if exists gbk_dml_002;
--enable_warnings

###create table gbk_dml_002(c0 BINARY(255) ,c1 VARBINARY(65535) )DEFAULT CHARACTER SET = gbk;
create table gbk_dml_002(c0 BINARY(255) ,c1 VARBINARY(5000) )DEFAULT CHARACTER SET = gbk;
insert into gbk_dml_002 values(' 字
龠 ',' 字
龠 ');

###--character_set utf8mb4
SET NAMES utf8mb4;

select * from gbk_dml_002;

--disable_warnings
drop table if exists gbk_dml_002;
--enable_warnings

--echo  ########gbk||utf8 DML datatypes##########
SET NAMES gbk;
###--character_set gbk

--disable_warnings
drop table if exists gbk_dml_002;
--enable_warnings

###create table gbk_dml_002(c0 BINARY(255) ,c1 VARBINARY(65535) )DEFAULT CHARACTER SET = utf8;
create table gbk_dml_002(c0 BINARY(255) ,c1 VARBINARY(5000) )DEFAULT CHARACTER SET = utf8;
insert into gbk_dml_002 values(' 字
龠 ',' 字
龠 ');

###--character_set utf8mb4
SET NAMES utf8mb4;

select * from gbk_dml_002;

--disable_warnings
drop table if exists gbk_dml_002;
--enable_warnings


--echo  ########gbk||time DML datatypes##########

SET NAMES gbk;
###--character_set gbk

--disable_warnings
drop table if exists gbk_dml_002;
--enable_warnings

create table gbk_dml_002(c0 TIME)DEFAULT CHARACTER SET = gbk;
##insert into gbk_dml_002(c0) values (now());
##insert into gbk_dml_002(c0) values (CURTIME());

###--character_set utf8mb4
SET NAMES utf8mb4;

select * from gbk_dml_002;

--disable_warnings
drop table if exists gbk_dml_002;
--enable_warnings



