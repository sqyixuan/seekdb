--echo  ########gbk||DML datatypes  obmysql-gbk-3-2/obmysql-gbk-5-6-5##########

SET NAMES gbk;
###--character_set gbk

--disable_warnings
drop table if exists gbk_dml_002;
--enable_warnings

create table gbk_dml_002(c0 TINYINT ,c1 SMALLINT,c2 MEDIUMINT,c3 INT,c4 BIGINT ,c5 Float,c6 Double,c7 Decimal)DEFAULT CHARACTER SET = gbk;
insert into gbk_dml_002 values(127,32767,8388607,2147483647,9223372036854775807,6.22,6.222,6.333);

###--character_set utf8mb4
SET NAMES utf8mb4;

select * from gbk_dml_002;

--disable_warnings
drop table if exists gbk_dml_002;
--enable_warnings


--echo  ########gbk||DML datatypes  obmysql-gbk-3-2##########

SET NAMES gbk;
###--character_set gbk

--disable_warnings
drop table if exists gbk_dml_002;
--enable_warnings

create table gbk_dml_002(c0 TINYINT ,c1 SMALLINT,c2 MEDIUMINT,c3 INT,c4 BIGINT ,c5 Float,c6 Double,c7 Decimal)DEFAULT CHARACTER SET = utf8;
insert into gbk_dml_002 values(127,32767,8388607,2147483647,9223372036854775807,6.22,6.222,6.333);

###--character_set utf8mb4
SET NAMES utf8mb4;

select * from gbk_dml_002;

--disable_warnings
drop table if exists gbk_dml_002;
--enable_warnings




