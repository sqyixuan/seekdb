t decimal(6,2),
srcuser varchar(8) character set utf8,
srchost varchar(20) character set utf8,
dstuser varchar(8) character set utf8,
dsthost varchar(20) character set utf8,
size BIGINT,
index(t)
)DEFAULT CHARACTER SET = utf8;

