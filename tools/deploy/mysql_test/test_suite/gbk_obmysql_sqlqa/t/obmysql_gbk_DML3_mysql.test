--echo  ########gbk||DML  obmysql-gbk-1-2-1-8##########

SET NAMES gbk;
###--character_set gbk

--disable_warnings
drop table if exists employee_tbl;
--enable_warnings

CREATE TABLE `employee_tbl` (
  `id` int(11) NOT NULL,
  `name` char(10) character set gbk NOT NULL DEFAULT '',
  `date` datetime NOT NULL,
  `singin` tinyint(4) NOT NULL DEFAULT '0' ,
  PRIMARY KEY (`id`)
)DEFAULT CHARSET=gbk;

INSERT INTO `employee_tbl` VALUES ('1', '小明', '2016-04-22 15:25:33', '1'), ('2', '小王', '2016-04-20 15:25:47', '3'), ('3', '小丽', '2016-04-19 15:26:02', '2'), ('4', '小王', '2016-04-07 15:26:14', '4'), ('5', '小明', '2016-04-11 15:26:40', '4'), ('6', '小明', '2016-04-04 15:26:54', '2');


###--character_set utf8mb4
SET NAMES utf8mb4;

SELECT name, COUNT(*) FROM   employee_tbl GROUP BY name;
SELECT name, COUNT(*) FROM   employee_tbl GROUP BY name having COUNT(*) >2;
###28163718：【Mysql GBK连接】connection、client、results、database为GBK，coalesce + group by 中文字段WITH ROLLUP， gbk连接，表和字段为utf8时，OB有乱码，MYSQL正常；
###SELECT name, SUM(singin) as singin_count FROM  employee_tbl GROUP BY name WITH ROLLUP;
###SELECT coalesce(name, '总数'), SUM(singin) as singin_count FROM  employee_tbl GROUP BY name WITH ROLLUP;

--echo  ##gbk||DML  obmysql-gbk-1-2-1-9###
SELECT * FROM  employee_tbl order by name desc;
SELECT * FROM  employee_tbl order by name asc;

--disable_warnings
drop table if exists mail;
--enable_warnings


--echo  ########gbk||DML utf8 obmysql-gbk-1-2-1-8##########

SET NAMES gbk;
###--character_set gbk

--disable_warnings
drop table if exists employee_tbl;
--enable_warnings

CREATE TABLE `employee_tbl` (
  `id` int(11) NOT NULL,
  `name` char(10) character set utf8 NOT NULL DEFAULT '',
  `date` datetime NOT NULL,
  `singin` tinyint(4) NOT NULL DEFAULT '0' ,
  PRIMARY KEY (`id`)
)DEFAULT CHARSET=utf8;

INSERT INTO `employee_tbl` VALUES ('1', '小明', '2016-04-22 15:25:33', '1'), ('2', '小王', '2016-04-20 15:25:47', '3'), ('3', '小丽', '2016-04-19 15:26:02', '2'), ('4', '小王', '2016-04-07 15:26:14', '4'), ('5', '小明', '2016-04-11 15:26:40', '4'), ('6', '小明', '2016-04-04 15:26:54', '2');


###--character_set utf8mb4
SET NAMES utf8mb4;

SELECT name, COUNT(*) FROM   employee_tbl GROUP BY name;
SELECT name, COUNT(*) FROM   employee_tbl GROUP BY name having COUNT(*) >2;
###28163718：【Mysql GBK连接】connection、client、results、database为GBK，coalesce + group by 中文字段WITH ROLLUP， gbk连接，表和字段为utf8时，OB有乱码，MYSQL正常；
###SELECT name, SUM(singin) as singin_count FROM  employee_tbl GROUP BY name WITH ROLLUP;
###SELECT coalesce(name, '总数'), SUM(singin) as singin_count FROM  employee_tbl GROUP BY name WITH ROLLUP;

--echo  ##gbk||DML  obmysql-gbk-1-2-1-9###
SELECT * FROM  employee_tbl order by name desc;
SELECT * FROM  employee_tbl order by name asc;

--disable_warnings
drop table if exists mail;
--enable_warnings



--echo  ########gbk||DML  update obmysql-gbk-1-2-3##########

SET NAMES gbk;
###--character_set gbk

--disable_warnings
drop table if exists runoob_tbl;
--enable_warnings

CREATE TABLE IF NOT EXISTS `runoob_tbl`(
`runoob_id` INT UNSIGNED AUTO_INCREMENT,
`runoob_title` VARCHAR(100) character set gbk NOT NULL,
`runoob_author` VARCHAR(40) character set gbk NOT NULL,
`submission_date` DATE,
PRIMARY KEY ( `runoob_id` )
)DEFAULT CHARSET=gbk;

INSERT INTO runoob_tbl
(runoob_title, runoob_author, submission_date)
VALUES
("学习 PHP", "菜鸟教程", '2016-05-04');

INSERT INTO runoob_tbl
(runoob_title, runoob_author, submission_date)
VALUES
("学习 MySQL", "菜鸟教程", '2016-05-05');

INSERT INTO runoob_tbl
(runoob_title, runoob_author, submission_date)
VALUES
("JAVA 教程", "RUNOOB.COM", '2016-05-06');
###mysqltest工具问题，注释掉
###UPDATE runoob_tbl SET runoob_title='学习 C++' WHERE runoob_id=3;
###UPDATE runoob_tbl SET runoob_title='学习 C++', runoob_author = '谁啊' WHERE runoob_id=3;
###UPDATE runoob_tbl SET runoob_author = '到底是谁' ;
###update a set col=(select b from c where a.d=c.d) where exists(select 1 from c where a.d=c.d)
###28166711：【嵌套子查询更新、删除】connection、client、results、database为GBK，在做mysql嵌套子查询更新时，mysql有限制报错，OB暂无
###update runoob_tbl set runoob_title=(select runoob_author from runoob_tbl where runoob_id=3) where exists(select 1 from runoob_tbl where runoob_id=3);
###delete from runoob_tbl  where exists(select 1 from runoob_tbl where runoob_id=3);


###--character_set utf8mb4
SET NAMES utf8mb4;

SELECT * from runoob_tbl WHERE runoob_id=3;

--disable_warnings
drop table if exists runoob_tbl;
--enable_warnings


--echo  ########gbk||DML utf8 update obmysql-gbk-1-2-3##########

SET NAMES gbk;
###--character_set gbk

--disable_warnings
drop table if exists runoob_tbl;
--enable_warnings

CREATE TABLE IF NOT EXISTS `runoob_tbl`(
`runoob_id` INT UNSIGNED AUTO_INCREMENT,
`runoob_title` VARCHAR(100) character set utf8 NOT NULL,
`runoob_author` VARCHAR(40) character set utf8 NOT NULL,
`submission_date` DATE,
PRIMARY KEY ( `runoob_id` )
)DEFAULT CHARSET=utf8;

INSERT INTO runoob_tbl
