--echo  ########gbk||DML  obmysql-gbk-4-1//obmysql-gbk-5-6##########
--disable_warnings
drop database  IF EXISTS  ob35x;
--enable_warnings
create database ob35x  character set gbk;
use ob35x;

SET NAMES gbk;
###--character_set gbk

--disable_warnings
drop table if exists usertest;
####--error 0,1396
####drop user "哈~"@'%';
####--error 0,1396
####drop user 简体用户名;
####--error 0,1396
####drop user 繁體;
####--error 0,1396
####drop user こんにちは;
####--error 0,1396
####drop user Здравствулте;
####--error 0,1396
####drop user 中文名测试_长度上限长长长长长_;
####--error 0,1396
####drop user "a简体字龘繁體 空格   制表符
####aa";
--error 0,1396
drop user abcdefghijklmnopqrstuvwxyz;
--error 0,1396
drop user ABCDEFGHIJKLMNOPQRSTUVWXYZ;
--error 0,1396
DROP USER ABCDEFGHIJKLMNOPQRSTUVWXYZ__30;
####--enable_warnings

###obmysql-gbk-5-6-1
###28175729：【Mysql GBK连接】connection、client、results、database为GBK，创建用户名中带中文+特殊字符时，MYSQL正常，OB有异常报错;
################# 对象中文名测试(简体、繁体、超大字符集中汉字、双引号+空格/回车/制表符) #################
--echo 用户名

