--echo  ########gbk||DML utf8 obmysql-gbk-4-1##########

SET NAMES gbk;
###--character_set gbk

--disable_warnings
drop table if exists usertest;
--error 0,1396
drop user abcdefghijklmnopqrstuvwxyz;
--error 0,1396
drop user ABCDEFGHIJKLMNOPQRSTUVWXYZ;
--error 0,1396
DROP USER ABCDEFGHIJKLMNOPQRSTUVWXYZ__30;
####--enable_warnings

################# 对象中文名测试(简体、繁体、超大字符集中汉字、双引号+空格/回车/制表符) #################
--echo 用户名

create user abcdefghijklmnopqrstuvwxyz  identified by 'abcdefghijklmnopqrstuvwxyz';
CREATE USER ABCDEFGHIJKLMNOPQRSTUVWXYZ  IDENTIFIED BY 'ABCDEFGHIJKLMNOPQRSTUVWXYZ';
CREATE USER ABCDEFGHIJKLMNOPQRSTUVWXYZ__30  IDENTIFIED BY 'ABCDEFGHIJKLMNOPQRSTUVWXYZ__30';

create table usertest 
(empno varchar(20) character set utf8 not null,
empname varchar(20) character set utf8,
deptno int,
birthdate date,
salary int
)DEFAULT CHARACTER SET = utf8;

###--character_set utf8mb4
SET NAMES utf8mb4;

--disable_warnings
drop table if exists usertest;
--error 0,1396
drop user abcdefghijklmnopqrstuvwxyz;
--error 0,1396
drop user ABCDEFGHIJKLMNOPQRSTUVWXYZ;
--error 0,1396
DROP USER ABCDEFGHIJKLMNOPQRSTUVWXYZ__30;
--enable_warnings


