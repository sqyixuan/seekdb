--echo  ########gbk||gbk DML cast##########

SET NAMES gbk;
###--character_set gbk

--disable_warnings
drop table if exists cast_test_table;
drop table if exists cast_test_table1;
--enable_warnings

create table cast_test_table(c1 varchar(50) character set gbk,c2  int)DEFAULT CHARACTER SET = gbk;
insert into cast_test_table values('士大夫',67);
insert into cast_test_table values('安\德森',63);
insert into cast_test_table values('201303第三方的',77);
insert into cast_test_table values('杜少府',68);
insert into cast_test_table values('公环銸境',97);
insert into cast_test_table values('试点乛范围',62);
insert into cast_test_table values('繁體字測試',87);

create table cast_test_table1(c1   varchar(10) character set gbk,c2     int,c3       int)DEFAULT CHARACTER SET = gbk;
insert into cast_test_table1 values('繁體字測試',1,'1000');
insert into cast_test_table1 values('出口i给v',2,'500');
insert into cast_test_table1 values('我欸如乘客',3,'100');

###--character_set utf8mb4
SET NAMES utf8mb4;


select * from cast_test_table;
select cast(c1 as char(2)) as empno from cast_test_table;
select cast(c1 as char(3)) as empno from cast_test_table;

select * from cast_test_table1;
SELECT c.c1,c.c2,b.c1,b.c3 FROM (SELECT c.*,ROW_NUMBER() OVER(ORDER BY c2 DESC) rn FROM cast_test_table c) c ,(SELECT b.c1,b.c3,ROW_NUMBER() OVER(ORDER BY b.c1) rn FROM cast_test_table1 b ) b WHERE c.rn=b.rn;
SELECT CAST('123.447654' AS decimal(5,2)) as result from dual;
SELECT CAST('123.4' AS decimal) as result from dual;

--disable_warnings
drop table if exists gbk_dml_002;
--enable_warnings

