--echo  ########bugs verify-gbk database gbk tables##########

SET NAMES gbk;
###--character_set gbk

-- disable_warnings
drop table  IF EXISTS  characterset;
-- enable_warnings

create table characterset(
id int not null auto_increment primary key,
fuhao varchar(100) character set gbk,
zifu char(100)  character set gbk not null,
sage tinyint(100) not null,
sdept char(40) not null)DEFAULT CHARACTER SET = gbk;

###--character_set utf8mb4
SET NAMES utf8mb4;

select fuhao, hex(fuhao) from characterset;
select zifu, hex(zifu) from characterset;

drop table  IF EXISTS  characterset;

--echo  ########bugs verify-gbk database utf8 tables##########

SET NAMES gbk;
###--character_set gbk

-- disable_warnings
drop table  IF EXISTS  characterset;
-- enable_warnings

create table characterset(
id int not null auto_increment primary key,
fuhao varchar(100) character set utf8,
zifu char(100)  character set utf8 not null,
sage tinyint(100) not null,
sdept char(40) not null)DEFAULT CHARACTER SET = utf8;


###--character_set utf8mb4
SET NAMES utf8mb4;

select fuhao, hex(fuhao) from characterset;
select zifu, hex(zifu) from characterset;

drop table  IF EXISTS  characterset;


--echo  ########bugs verify-gbk 【gbk】insert select ##########

SET NAMES gbk;
###--character_set gbk

-- disable_warnings
drop table  IF EXISTS  t1;
drop table  IF EXISTS  t2;
drop table  IF EXISTS  t3;
-- enable_warnings

create table t3(c1 char(255) character set gbk)DEFAULT CHARACTER SET = gbk;
insert into t3 values('先帝创业未半而中道崩殂，今天下三分，益州疲弊，此诚危急存亡之秋也。然侍卫之臣不懈于内，忠志之士忘身于外者，盖追先帝之殊遇，欲报之于陛下也。诚宜开张圣听，以光先帝遗德，恢弘志士之气，不宜妄自菲薄，引喻失义，以塞忠谏之路也。');
##create table t1(c1 int,c2 varchar(20) character set gbk,c3 timestamp,c4 date,c5 char(20)  character set gbk,c6 int,c7 number(6,2),c8 varchar(60)  character set gbk generated always as ##(concat(c1,c2)))DEFAULT CHARACTER SET = gbk primary_zone='zone1' partition by hash(c1)subpartition by range(c6)subpartition template(subpartition p1 values less than (8),subpartition p2 values less ##than (maxvalue))partitions 20 ;

##create table t1(c1 int,c2 varchar(20) character set gbk,c3 timestamp,c4 date,c5 char(20)  character set gbk,c6 int,c7 decimal(6,2),c8 varchar(60)  character set gbk generated always as (concat(c1,c2)))DEFAULT CHARACTER SET = gbk primary_zone='zone1' partition by hash(c1)subpartition by range(c6)subpartition template(subpartition p1 values less than (8),subpartition p2 values less than (maxvalue))partitions 20 ;
##
##create table t1(c1 int,c2 varchar(20) character set gbk,c3 timestamp,c4 date,c5 char(20)  character set gbk,c6 int,c7 decimal(6,2),c8 varchar(60)  character set gbk generated always as (concat(c1,c2)))DEFAULT CHARACTER SET = gbk partition by hash(c1)subpartition by range(c6)subpartition template(subpartition p1 values less than (8),subpartition p2 values less than (maxvalue))partitions 20 ;

create table t1(c1 int,c2 varchar(20) character set gbk,c3 timestamp,c4 date,c5 char(20)  character set gbk,c6 int,c7 decimal(6,2),c8 varchar(60)  character set gbk generated always as (concat(c1,c2)))DEFAULT CHARACTER SET = gbk partition by hash(c1) partitions 20 ;


##create table t2(c1 int,c2 char(20) character set gbk,c3 timestamp,c4 date,c5 char(20) character set gbk,c6 int,c7 number(6,2),c8 varchar(120) character set gbk generated always as (concat(c1,c2)))DEFAULT CHARACTER SET = gbk primary_zone='zone2' partition by hash(c6)subpartition by range(c1)subpartition template(subpartition p1 values less than (8),subpartition p2 values less than (maxvalue))partitions 20;

create table t2(c1 int,c2 char(20) character set gbk,c3 timestamp,c4 date,c5 char(20) character set gbk,c6 int,c7 decimal(6,2),c8 varchar(120) character set gbk generated always as (concat(c1,c2)))DEFAULT CHARACTER SET = gbk  partition by hash(c6) partitions 20;

insert into t1(c1,c2,c3,c4,c5,c6,c7) select 1,substr(c1,1*10,10),('2020-05-21 01:01:01'),('2020-05-21 01:01:02'),substr(c1,1*10+1,10),('202005'),1*4+1/7 from t3;

###--character_set utf8mb4
SET NAMES utf8mb4;

select * from  t1;
select * from  t2;
select * from  t3;

-- disable_warnings
drop table  IF EXISTS  t1;
drop table  IF EXISTS  t2;
drop table  IF EXISTS  t3;
-- enable_warnings

--echo  ########bugs verify-gbk 【utf8】insert select ##########

SET NAMES gbk;
###--character_set gbk

-- disable_warnings
drop table  IF EXISTS  t1;
drop table  IF EXISTS  t2;
drop table  IF EXISTS  t3;
-- enable_warnings

create table t3(c1 char(255) character set utf8)DEFAULT CHARACTER SET = utf8;
insert into t3 values('先帝创业未半而中道崩殂，今天下三分，益州疲弊，此诚危急存亡之秋也。然侍卫之臣不懈于内，忠志之士忘身于外者，盖追先帝之殊遇，欲报之于陛下也。诚宜开张圣听，以光先帝遗德，恢弘志士之气，不宜妄自菲薄，引喻失义，以塞忠谏之路也。');

create table t1(c1 int,c2 varchar(20) character set utf8,c3 timestamp,c4 date,c5 char(20)  character set utf8,c6 int,c7 decimal(6,2),c8 varchar(60)  character set utf8 generated always as (concat(c1,c2)))DEFAULT CHARACTER SET = utf8 partition by hash(c1) partitions 20 ;

create table t2(c1 int,c2 char(20) character set utf8,c3 timestamp,c4 date,c5 char(20) character set utf8,c6 int,c7 decimal(6,2),c8 varchar(120) character set utf8 generated always as (concat(c1,c2)))DEFAULT CHARACTER SET = utf8  partition by hash(c6) partitions 20;

insert into t1(c1,c2,c3,c4,c5,c6,c7) select 1,substr(c1,1*10,10),('2020-05-21 01:01:01'),('2020-05-21 01:01:02'),substr(c1,1*10+1,10),('202005'),1*4+1/7 from t3;

###--character_set utf8mb4
SET NAMES utf8mb4;

select * from  t1;
select * from  t2;
select * from  t3;
-- disable_warnings
drop table  IF EXISTS  t1;
drop table  IF EXISTS  t2;
drop table  IF EXISTS  t3;
-- enable_warnings


