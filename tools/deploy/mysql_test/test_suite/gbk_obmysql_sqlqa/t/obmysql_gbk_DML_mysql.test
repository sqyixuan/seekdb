SET NAMES gbk;
###--character_set gbk

-- disable_warnings
drop table  IF EXISTS  t1;
-- enable_warnings

create table t1(c1 varchar(50) character set utf8)DEFAULT CHARACTER SET = utf8;
insert into t1 values('杜少府');
insert into t1 values('繁體字');
insert into t1 values('asd');
insert into t1 values('ADS');

###--character_set utf8mb4
SET NAMES utf8mb4;

--error 1064
select cast(c1 as varchar(2)) as empno from cast_test_table;

-- disable_warnings
drop table  IF EXISTS  t1;
-- enable_warnings


