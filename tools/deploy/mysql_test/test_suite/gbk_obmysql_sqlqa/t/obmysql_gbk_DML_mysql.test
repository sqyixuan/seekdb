--echo  ########gbk||DML 查询特殊字符，配套函数##########
--disable_warnings
drop database  IF EXISTS  ob35x;
--enable_warnings
create database ob35x  character set gbk;
use ob35x;

SET NAMES gbk;
###--character_set gbk

--disable_warnings
drop table if exists gbk_dml_002;
--enable_warnings

create table gbk_dml_002(c0 varchar(200) character set gbk,c1 varchar(200) character set gbk,c2 char(200) character set gbk,c3 int)DEFAULT CHARACTER SET = gbk partition by hash(c3);
insert into gbk_dml_002 values('\x1abf4','\x1abf4','\x1abf4',1);
insert into gbk_dml_002 values('','','',2);
insert into gbk_dml_002 values(' 字龠 ',' 字龠 ',' 字龠 ',3);
insert into gbk_dml_002 values(' 字
龠 ',' 字
龠 ',' 字
龠 ',4);
insert into gbk_dml_002 values(' 字    龠 ',' 字 龠 ',' 字 龠 ',5);
insert into gbk_dml_002 values('字!@#$%^&*()_+龠','字!@#$%^&*()_+龠','字!@#$%^&*()_+龠',6);
insert into gbk_dml_002 values('十','十','十',90);
insert into gbk_dml_002 values('〡','〡','〡',91);
insert into gbk_dml_002 values('〢','〢','〢',92);
insert into gbk_dml_002 values('〣','〣','〣',93);
insert into gbk_dml_002 values('〤','〤','〤',94);
insert into gbk_dml_002 values('〥','〥','〥',95);
insert into gbk_dml_002 values('〦','〦','〦',96);
insert into gbk_dml_002 values('〧','〧','〧',97);
insert into gbk_dml_002 values('〨','〨','〨',98);
insert into gbk_dml_002 values('〩','〩','〩',99);
insert into gbk_dml_002 values('~','~','~',111);
insert into gbk_dml_002 values('!','!','!',112);
insert into gbk_dml_002 values('@','@','@',113);
insert into gbk_dml_002 values('#','#','#',114);
insert into gbk_dml_002 values('$','$','$',115);
insert into gbk_dml_002 values('%','%','%',116);
insert into gbk_dml_002 values('^','^','^',117);
insert into gbk_dml_002 values('&','&','&',118);
insert into gbk_dml_002 values('*','*','*',119);
insert into gbk_dml_002 values('(','(','(',110);
insert into gbk_dml_002 values(')',')',')',121);
insert into gbk_dml_002 values('_','_','_',122);
insert into gbk_dml_002 values('Q','Q','Q',123);
insert into gbk_dml_002 values('P','P','P',124);
insert into gbk_dml_002 values('{','{','{',125);
insert into gbk_dml_002 values('}','}','}',126);
insert into gbk_dml_002 values('|','|','|',127);
insert into gbk_dml_002 values('+','+','+',128);
insert into gbk_dml_002 values('|','|','|',129);
insert into gbk_dml_002 values('/','/','/',120);
insert into gbk_dml_002 values('`','`','`',130);
insert into gbk_dml_002 values('1','1','1',131);
insert into gbk_dml_002 values('-','-','-',132);
insert into gbk_dml_002 values('=','=','=',133);
insert into gbk_dml_002 values('<','<','<',135);
insert into gbk_dml_002 values('>','>','>',136);
insert into gbk_dml_002 values('?','?','?',137);
insert into gbk_dml_002 values(',',',',',',138);
insert into gbk_dml_002 values('.','.','.',139);
insert into gbk_dml_002 values('/','/','/',140);
insert into gbk_dml_002 values('.','.','.',141);
insert into gbk_dml_002 values('.','.','.',142);
insert into gbk_dml_002 values('+','+','+',143);
insert into gbk_dml_002 values('-','-','-',144);
insert into gbk_dml_002 values('*','*','*',145);
insert into gbk_dml_002 values('/','/','/',146);
insert into gbk_dml_002 values('''','''','''',147);
insert into gbk_dml_002 values('\\','\\','\\',148);
insert into gbk_dml_002 values('0xd1','0xd1','0xd1',149);
insert into gbk_dml_002 values('0XD1','0XD1','0XD1',150);
insert into gbk_dml_002 values('x616263FF','x616263FF','x616263FF',151);

###--character_set utf8mb4
SET NAMES utf8mb4;

###--echo lower、upper、replace、abs、floor、round

select lower(c0),lower(c1),lower(c2) from gbk_dml_002 order by c3;
select upper(c0),upper(c1),upper(c2) from gbk_dml_002 order by c3;
select replace(c0,'=','') from gbk_dml_002 order by c3;
--disable_warnings
select abs(c0),abs(c1),abs(c2) from gbk_dml_002 order by c3;
select floor(c0),floor(c1),floor(c2) from gbk_dml_002 order by c3;
select round(c0),round(c1),round(c2) from gbk_dml_002 order by c3;
--enable_warnings
select * from gbk_dml_002;

--disable_warnings
drop table if exists gbk_dml_002;
--enable_warnings


