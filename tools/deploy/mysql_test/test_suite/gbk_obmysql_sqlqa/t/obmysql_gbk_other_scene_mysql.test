create table gbk_dml_002(c0 varchar(200) character set gbk,c1 varchar(200) character set utf8,c2 char(200) character set utf8,c3 int)DEFAULT CHARACTER SET = utf8 partition by hash(c3);
insert into gbk_dml_002 values('\x1abf4','\x1abf4','\x1abf4',1);
insert into gbk_dml_002 values('0x61626364','0x61626364','0x61626364',6);



create table gbk_dml_003 like gbk_dml_002;
insert into gbk_dml_003 values('\x1abf4','\x1abf4','\x1abf4',1);

create table gbk_dml_004 like gbk_dml_002;
insert into gbk_dml_004 select * from gbk_dml_002;

