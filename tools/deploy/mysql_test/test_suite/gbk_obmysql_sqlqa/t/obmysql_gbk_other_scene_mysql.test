--echo  ########gbk||DML gbk和utf8混合字段使用，obmysql-gbk-5-3##########

SET NAMES gbk;
###--character_set gbk

--disable_warnings
drop table if exists gbk_dml_002;
--enable_warnings

create table gbk_dml_002(c0 varchar(200) character set gbk,c1 varchar(200) character set utf8,c2 char(200) character set utf8,c3 int)DEFAULT CHARACTER SET = utf8 partition by hash(c3);
insert into gbk_dml_002 values('\x1abf4','\x1abf4','\x1abf4',1);
insert into gbk_dml_002 values('','','',2);
insert into gbk_dml_002 values('十','十','十',90);
insert into gbk_dml_002 values('〡','〡','〡',91);
insert into gbk_dml_002 values('0xd1','0xd1','0xd1',149);
insert into gbk_dml_002 values('0XD1','0XD1','0XD1',150);
insert into gbk_dml_002 values('x616263FF','x616263FF','x616263FF',151);

###--character_set utf8mb4
SET NAMES utf8mb4;

###--echo lower、upper、replace、abs、floor、round

select lower(c0),lower(c1),lower(c2) from gbk_dml_002 order by c3;
select upper(c0),upper(c1),upper(c2) from gbk_dml_002 order by c3;
select replace(c0,'=','') from gbk_dml_002 order by c3;
--disable_warnings
select abs(c0),abs(c1),abs(c2) from gbk_dml_002 order by c3;
select floor(c0),floor(c1),floor(c2) from gbk_dml_002 order by c3;
select round(c0),round(c1),round(c2) from gbk_dml_002 order by c3;
--enable_warnings
select * from gbk_dml_002;

--disable_warnings
drop table if exists gbk_dml_002;
--enable_warnings

