--echo  ########gbk|| - collate测试##########
SET NAMES gbk;
###--character_set gbk
--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1(c1 varchar(2) CHARACTER SET gbk COLLATE gbk_chinese_ci primary key,c2 varchar(10))DEFAULT CHARACTER SET = gbk;
replace into t1 (c1,c2) values ('中文','第一个');
replace into t1 (c1,c2) values (_binary'一一','二二二');
replace into t1 (c1,c2) values (_gbk'一一'collate gbk_bin,'二二二');
###replace into t1 (c1,c2) values (_utf8mb4'一一'collate utf8mb4_bin,'二二二');

###bug id：28282679
###select replace(_utf8'abcv'collate utf8_general_ci,_utf8'BC'collate utf8_general_ci,_utf8'nan' collate utf8_general_ci);


###--character_set utf8mb4
SET NAMES utf8mb4;

select * from t1;

--disable_warnings
drop table if exists t1;
--enable_warnings


--echo  ########||gbk utf8 - collate测试##########
SET NAMES gbk;
###--character_set gbk
--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1(c1 varchar(2) character set utf8mb4 collate utf8mb4_general_ci primary key,c2 varchar(10))DEFAULT CHARACTER SET = utf8;
replace into t1 (c1,c2) values ('中文','第一个');
replace into t1 (c1,c2) values (_binary'一','二二二');
replace into t1 (c1,c2) values (_gbk'一一'collate gbk_bin,'二二二');
###replace into t1 (c1,c2) values (_utf8mb4'一一'collate utf8mb4_bin,'二二二');
###SELECT REVERSE(c1) FROM t1;

###--character_set utf8mb4
SET NAMES utf8mb4;

select * from t1;

--disable_warnings
drop table if exists t1;
--enable_warnings

