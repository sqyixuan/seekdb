--echo  ########bugs verify-gbk database gbk tables##########

--disable_warnings
drop database  IF EXISTS  ob35x;
--enable_warnings
create database ob35x  character set gbk;
use ob35x;


--echo  ########bugs verify-gbk  COLLATE##########

SET NAMES gbk;
###--character_set gbk

-- disable_warnings
drop table  IF EXISTS  t1;
-- enable_warnings

CREATE TABLE `t1` (
`master_no` varchar(64) NOT NULL ,
`biz_no` varchar(32) NOT NULL ,
`partition_id` varchar(2) CHARACTER SET gbk COLLATE gbk_chinese_ci GENERATED ALWAYS AS (substr(`master_no`,15,2)) VIRTUAL,
CONSTRAINT `cst` CHECK ((`partition_id` = substr(`biz_no`,15,2))))
partition by list columns(partition_id)
(partition p0 values in ('00','01'),
partition p1 values in ('94','95' ));
 
insert into t1(master_no,biz_no) values('2019030722001194311000165062-001','2019030722001194311000165062');

###--character_set utf8mb4
SET NAMES utf8mb4;

SELECT substr(`master_no`,15,2),substr(`biz_no`,15,2) FROM t1 where biz_no='2019030722001194311000165062';
SELECT substr(`master_no`,15,2),substr(`biz_no`,15,2) FROM t1 where master_no='2019030722001194311000165062-001';
SELECT substr(`master_no`,15,2),substr(`biz_no`,15,2) FROM t1 where partition_id='94';

SELECT substr(`master_no`,15,2),substr(`biz_no`,15,2) FROM t1  partition(p1) where biz_no='2019030722001194311000165062';
SELECT substr(`master_no`,15,2),substr(`biz_no`,15,2) FROM t1  partition(p1) where master_no='2019030722001194311000165062-001';

-- disable_warnings
drop table  IF EXISTS  t1;
-- enable_warnings


--echo  ########bugs verify-utf8 COLLATE ##########

SET NAMES gbk;
###--character_set gbk

-- disable_warnings
drop table  IF EXISTS  t1;
-- enable_warnings

CREATE TABLE `t1` (
`master_no` varchar(64) NOT NULL ,
`biz_no` varchar(32) NOT NULL ,
`partition_id` varchar(2) CHARACTER SET utf8mb4 COLLATE utf8mb4_bin GENERATED ALWAYS AS (substr(`master_no`,15,2)) VIRTUAL,
CONSTRAINT `cst` CHECK ((`partition_id` = substr(`biz_no`,15,2))))
partition by list columns(partition_id)
(partition p0 values in ('00','01'),
partition p1 values in ('94','95' ));
 
insert into t1(master_no,biz_no) values('2019030722001194311000165062-001','2019030722001194311000165062');

###--character_set utf8mb4
SET NAMES utf8mb4;

SELECT substr(`master_no`,15,2),substr(`biz_no`,15,2) FROM t1 where biz_no='2019030722001194311000165062';
SELECT substr(`master_no`,15,2),substr(`biz_no`,15,2) FROM t1 where master_no='2019030722001194311000165062-001';
SELECT substr(`master_no`,15,2),substr(`biz_no`,15,2) FROM t1 where partition_id='94';

SELECT substr(`master_no`,15,2),substr(`biz_no`,15,2) FROM t1  partition(p1) where biz_no='2019030722001194311000165062';
SELECT substr(`master_no`,15,2),substr(`biz_no`,15,2) FROM t1  partition(p1) where master_no='2019030722001194311000165062-001';

-- disable_warnings
drop table  IF EXISTS  t1;
-- enable_warnings


