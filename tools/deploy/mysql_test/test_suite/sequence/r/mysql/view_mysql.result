drop table t1;
drop sequence VIEW_TEST_SEQ1;
result_format: 4

create sequence VIEW_TEST_SEQ1 order cache 100 increment by 3 maxvalue 99999999999;

select  * from oceanbase.dba_sequences where SEQUENCE_NAME ='VIEW_TEST_SEQ1';
