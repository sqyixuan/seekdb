MERGE INTO FUNC_DEFAULT_TEST A USING (select B.OID OID,B.NEWID NEWID from FUNC_DEFAULT_TEST2 B) C ON (A.OID=C.OID)
WHEN MATCHED THEN
UPDATE SET A.NEWID=C.NEWID
WHEN NOT MATCHED THEN
INSERT(A.NEWID) VALUES(C.NEWID);
commit;
