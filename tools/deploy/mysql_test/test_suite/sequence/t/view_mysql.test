--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: zuojiao.hzj
#owner group: sql2
#tags: sequence
#description:

--disable_warnings
--error 0, 1051
drop table t1;
--error 0, 4298
drop sequence VIEW_TEST_SEQ1;
--enable_warnings

--result_format 4
--enable_sorted_result


create sequence VIEW_TEST_SEQ1 order cache 100 increment by 3 maxvalue 99999999999;

select  * from oceanbase.dba_sequences where SEQUENCE_NAME ='VIEW_TEST_SEQ1';

select VIEW_TEST_SEQ1.nextval from dual;

select  * from oceanbase.dba_sequences where SEQUENCE_NAME ='VIEW_TEST_SEQ1';

drop sequence VIEW_TEST_SEQ1;
