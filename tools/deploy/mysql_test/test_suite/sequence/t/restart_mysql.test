#owner: zuojiao.hzj
#owner group: sql3
#tags: sequence, optimizer
#description:

#########  basic ddl test ##########

--disable_warnings
--disable_query_log
--error 0,4316,4298
drop sequence seq1;
--error 0, 942,1051
drop table t1;
--enable_warnings
--enable_query_log

create table t1 (c1 int);
insert into t1 values (1);

create sequence seq1;
select seq1.nextval from t1;

alter sequence seq1 restart start with 10;
select seq1.nextval from t1;

alter sequence seq1 restart start with 1;
select seq1.nextval from t1;

alter sequence seq1 restart start with 2;
select seq1.nextval from t1;

alter sequence seq1 restart start with 10000;
select seq1.nextval from t1;

--error 4382
alter sequence seq1 restart restart;
--error 4324
alter sequence seq1 restart start with 10000 maxvalue 100;
select seq1.nextval from t1;
--error 4322
alter sequence seq1 restart start with -1;
select seq1.nextval from t1;


## default
select seq1.nextval from t1;
alter sequence seq1 restart;
select seq1.nextval from t1;
alter sequence seq1 restart minvalue -2;
select seq1.nextval from t1;
alter sequence seq1 restart minvalue -2 maxvalue 1000 increment by -1;
select seq1.nextval from t1;
select seq1.nextval from t1;
alter sequence seq1 minvalue -2 maxvalue 1000 increment by -1 start with 0 restart;

select seq1.nextval from t1;

