#owner: zuojiao.hzj
#owner group: sql2
#tags: sequence
#description: test mysql sequence create/drop/show syntax

--disable_warnings
drop database if exists mysql_sequence_syntax;
drop database if exists mysql_sequence_syntax2;
--enable_warnings
create database mysql_sequence_syntax;
use mysql_sequence_syntax;

#########  create/drop sequence test ##########

create sequence if not exists s1;
show sequences;
create sequence if not exists s1;
create sequence if not exists s2;
create sequence if not exists s3 order cache 100 increment by 3 maxvalue 99999999999;
show sequences;

drop sequence if exists s1;
show sequences;
drop sequence if exists s1;
drop sequence if exists s2;
drop sequence if exists s3;
show sequences;

#########  show sequence test ##########
create sequence s1;
create sequence s2;
create sequence a2;
show sequences;
show sequences like 'a%';
show sequences like 's%';
show sequences like '%2';

show sequences like 's%' in mysql_sequence_syntax;
create database mysql_sequence_syntax2;
use mysql_sequence_syntax2;
create sequence s22;
create sequence s21;
show sequences;
use mysql_sequence_syntax;
show sequences in mysql_sequence_syntax2;
show sequences like 's%2' in mysql_sequence_syntax2;

show sequences where sequence_name = 's1';
show sequences where sequence_name = 's2';
show sequences where sequence_name = 'sx';

--error 4298
drop sequence aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa;
--error 1059 
drop sequence aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa;

create sequence seq;
create table t1(c1 int);
insert into t1 values (1), (2), (3);
select seq.nextval from t1 limit 1;
select seq.nextval from t1 limit 1;
drop sequence seq;
drop table t1;

create table t1 (c1 int);
create sequence seq;
insert into t1 select seq.nextval from table(generator(100));
select seq.currval;
select c1, seq.nextval from t1 limit 20, 10;
select seq.currval;

explain select c1, seq.nextval from t1 limit 20, 10;
drop sequence seq;
drop table t1;

drop database mysql_sequence_syntax2;
drop database mysql_sequence_syntax;

