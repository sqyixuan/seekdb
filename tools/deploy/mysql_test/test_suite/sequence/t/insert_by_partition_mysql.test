#owner: zuojiao.hzj
#owner group: sql3
#tags: sequence
#description: 测试 insert 一个 sequence 到 partition 列

--disable_warnings
--disable_query_log
--error 0, 942, 1051
drop table t1;
--error 0,2289, 4298
drop sequence s;
--enable_warnings
--enable_query_log

create table t1 (id int primary key, user_val int) partition by hash(id) partitions 3;
create sequence s;
insert into t1 values (10, 1);
# bug fixed 
insert into t1 values (s.nextval, 0);
--sorted_result
select * from t1;
