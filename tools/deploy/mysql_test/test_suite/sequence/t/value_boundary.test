#owner: zuojiao.hzj
#owner group: sql3
#tags: sequence
#description: 测试 sequence 取值边界
--result_format 4

--disable_warnings
--error 0, 1051
drop table t1;
--error 0, 4298
drop sequence vb_seq1;
--enable_warnings

create table t1 (c1 int);
insert into t1 values (1);

create sequence vb_seq1 minvalue -92233720368547758099999 maxvalue 92233720368547758080000000;
select vb_seq1.nextval from t1;
select sequence_name, min_value, max_value from oceanbase.__all_sequence_object where sequence_name = 'vb_seq1';
drop sequence vb_seq1;


create sequence vb_seq1 minvalue 9223372036854775806 maxvalue 9223372036854775807;
select vb_seq1.nextval from t1;
select vb_seq1.nextval from t1;
--error 4332
select vb_seq1.nextval from t1;
select sequence_name, min_value, max_value from oceanbase.__all_sequence_object where sequence_name = 'vb_seq1';
drop sequence vb_seq1;

create sequence vb_seq1 minvalue 9223372036854775806 maxvalue 9223372036854775808;
select vb_seq1.nextval from t1;
select vb_seq1.nextval from t1;
--error 4332
select vb_seq1.nextval from t1;
select sequence_name, min_value, max_value from oceanbase.__all_sequence_object where sequence_name = 'vb_seq1';
drop sequence vb_seq1;


create sequence vb_seq1 maxvalue 2;
select vb_seq1.nextval from t1;
select vb_seq1.nextval from t1;
--error 4332
select vb_seq1.nextval from t1;
select sequence_name, min_value, max_value from oceanbase.__all_sequence_object where sequence_name = 'vb_seq1';
drop sequence vb_seq1;




drop table t1;
