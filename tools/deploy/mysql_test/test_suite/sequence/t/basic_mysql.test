#########  basic ddl test ##########

--disable_warnings
--disable_query_log
--error 0,4316,4298
drop sequence seq1;
--error 0,4316,4298
drop sequence testx;
--error 0,4316,4298
drop sequence s1;
--error 0,4316,4298
drop sequence a4;
--error 0,4316,4298
drop sequence a5;
--error 0,4316,4298
drop sequence ok;
--error 0, 942,1051
drop table t_s;
--error 0, 942,1051
drop table t_p;
--enable_warnings
--enable_query_log

create sequence seq1 order cache 100;
alter sequence seq1 noorder cache 30;
drop sequence seq1;


#########  error test ##########

