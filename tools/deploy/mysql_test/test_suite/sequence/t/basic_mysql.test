create sequence a5 minvalue 1 maxvalue 6 cache 4 increment by 1 nocycle;
select a5.nextval from dual;
select a5.nextval from dual;
select a5.nextval from dual;
select a5.nextval from dual;
select a5.nextval from dual;
select a5.nextval from dual;
