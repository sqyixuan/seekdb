#owner: zuojiao.hzj
#owner group: sql3
#tags: sequence
#description: 测试 sequence 关键字占用情况

--disable_warnings
--error 0, 1051
drop table t1;
--error 0, 1051
drop table t2;
--enable_warnings

create table t1 (minvalue int, nominvalue int, nomaxvalue int, cache int, nocache int, noorder int, sequence int, increment int, start int);
desc t1;

--error 1064
create table t2 (by int);
--error 1064
create table t2 (with int);
--error 1064
create table t2 (order int);
--error 1064
create table t2 (maxvalue int);

drop table t1;
