#owner: zuojiao.hzj
#owner group: sql3
#tags: sequence
#description: 测试 sequence  prefetch cache 某些情况下不会被使用
#
# issue: 

--result_format 4
--disable_warnings
--error 0, 1051
drop table t1;
--error 0, 4298
drop sequence seq_test1;
--enable_warnings

create table t1 (c1 int);
insert into t1 values (1);

create sequence seq_test1 INCREMENT BY 1 start with 1 minvalue 1 maxvalue 100;
select seq_test1.CURRVAL,seq_test1.NEXTVAL from t1;
select seq_test1.CURRVAL,seq_test1.NEXTVAL from t1;
ALTER SEQUENCE seq_test1 minvalue 0 INCREMENT BY -1;
select seq_test1.CURRVAL,seq_test1.NEXTVAL from t1;
select seq_test1.CURRVAL,seq_test1.NEXTVAL from t1;

drop sequence seq_test1;
drop table t1;
