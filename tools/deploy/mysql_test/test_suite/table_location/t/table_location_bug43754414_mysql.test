# tags: optimizer

--disable_warnings
drop table if exists t3;
--enable_warnings

create table t3 (c1 NUMERIC(64,15) ,c2 INTEGER(127) ,c3 DATETIME,c4 CHAR(152) ,c5 TIME,c6 BIGINT(127) ,c7 NUMERIC(64,13) ,c8 VARBINARY(64) ,c9 DATETIME,c10 NUMERIC(64,2) ,c11 TIME,c12 INTEGER(127) ,c13 DECIMAL(64,14) ,c14 VARBINARY(63) , primary key(c1,c14))  DEFAULT CHARSET = utf8mb4 COLLATE = utf8mb4_bin PARTITION BY KEY(c1,c14) PARTITIONS 20;

--explain_protocol 2
--result_format 4

UPDATE /*+ ENABLE_PARALLEL_DML parallel(2) */ t3 AS t3_142 SET t3_142.c1 = t3_142.c1, t3_142.c2 = (SELECT t3_142.c2 FROM t3 AS t3_142 ORDER BY 1 DESC LIMIT 1), t3_142.c3 = null, t3_142.c4 = 'VgBFIxU', t3_142.c5 = null, t3_142.c6 = null, t3_142.c7 = null, t3_142.c8 = 'wtwKR', t3_142.c9 = (SELECT t3_142.c9 FROM t3 AS t3_142 ORDER BY 1 LIMIT 1), t3_142.c10 = (SELECT MIN(t3_142.c10) FROM t3 AS t3_142), t3_142.c11 = '7:16:39', t3_142.c12 = (SELECT t3_142.c12 FROM t3 AS t3_142 ORDER BY 1 DESC LIMIT 1), t3_142.c13 = (SELECT t3_142.c13 FROM t3 AS t3_142 ORDER BY 1 LIMIT 1), t3_142.c14 = t3_142.c14 WHERE t3_142.c4 LIKE '%Ab%' AND t3_142.c12 = 51;
UPDATE /*+ ENABLE_PARALLEL_DML parallel(2) */t3 SET c10 = 1 WHERE c12 = 51;