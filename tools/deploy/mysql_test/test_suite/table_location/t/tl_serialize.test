#owner: xiaoyi.xy
#owner group: sql1
--result_format 4

--disable_warnings
drop table if exists t9, t4;
--enable_warnings

CREATE TABLE `t9` (
  `c1` int(127) NOT NULL,
  `c2` binary(143) DEFAULT NULL,
  `c3` int(127) DEFAULT NULL,
  `c4` bigint(127) NOT NULL AUTO_INCREMENT,
  `c5` binary(93) NOT NULL,
  `c6` decimal(64,6) NOT NULL,
  `c7` binary(141) NOT NULL,
  `c8` bigint(127) NOT NULL,
  `c9` decimal(64,29) DEFAULT NULL,
  `c10` bigint(127) DEFAULT NULL,
  `c11` int(127) NOT NULL,
  `c12` decimal(64,8) DEFAULT NULL,
  `c13` decimal(64,4) DEFAULT NULL,
  `c14` timestamp NOT NULL DEFAULT '0000-00-00 00:00:00',
  `c15` varchar(86) COLLATE utf8mb4_bin DEFAULT NULL,
  `c16` time DEFAULT NULL,
  PRIMARY KEY (`c1`, `c5`, `c8`, `c11`, `c6`, `c7`)
)
 partition by hash(c1+c8+c11)
(partition p0,
partition p1,
partition p2,
partition p3,
partition p4,
partition p5,
partition p6,
partition p7,
partition p8,
partition p9);

CREATE TABLE `t4` (
  `c1` year(4) DEFAULT NULL,
  `c2` time DEFAULT NULL,
  `c3` char(152) COLLATE utf8mb4_bin DEFAULT NULL,
  `c4` char(152) COLLATE utf8mb4_bin DEFAULT NULL,
  `c5` date DEFAULT NULL,
  `c6` time DEFAULT NULL,
  `c7` int(127) NOT NULL,
  `c8` decimal(64,22) DEFAULT NULL,
  `c9` year(4) DEFAULT NULL,
  `c10` int(127) NOT NULL,
  PRIMARY KEY (`c7`, `c10`)
)
 partition by hash(c7+c10)
(partition p0,
partition p1,
partition p2,
partition p3,
partition p4,
partition p5,
partition p6,
partition p7,
partition p8,
partition p9);

insert into t4(c3,c4,c7,c10) values('c3', 'c4', 10,20);

SELECT t4_10.c4 FROM t4 AS t4_10 ORDER BY 1 DESC LIMIT 1;

explain (SELECT (t4_10.c7 + t4_10.c10) AS c1 FROM
 (SELECT (SELECT MIN(t4.c1) FROM t4) AS c1,
 (SELECT t4.c2 FROM t4 ORDER BY 1 DESC LIMIT 1) AS c2, t4.c3,
 (SELECT MIN(t4.c4) FROM t4) AS c4, (SELECT MAX(t4.c5) FROM t4) AS c5,
 t4.c6, t4.c7, t4.c8, t4.c9, t4.c10 FROM t4) AS t4_10
 WHERE t4_10.c3 < (SELECT t4_10.c4 FROM t4 AS t4_10 ORDER BY 1 DESC LIMIT 1)
 GROUP BY t4_10.c7, t4_10.c10 ORDER BY 1 ASC)
 INTERSECT
 (SELECT (323 + 423)
 FROM t9 AS t9_6
 WHERE t9_6.c15 LIKE '%Ab%' OR t9_6.c15 LIKE '%Ab%'
      AND t9_6.c15 >= 'QsrlsBLynDZDMvmLkav' ORDER BY 1 ASC)
 ORDER BY 1;

(SELECT (t4_10.c7 + t4_10.c10) AS c1 FROM
 (SELECT (SELECT MIN(t4.c1) FROM t4) AS c1,
 (SELECT t4.c2 FROM t4 ORDER BY 1 DESC LIMIT 1) AS c2, t4.c3,
 (SELECT MIN(t4.c4) FROM t4) AS c4, (SELECT MAX(t4.c5) FROM t4) AS c5,
 t4.c6, t4.c7, t4.c8, t4.c9, t4.c10 FROM t4) AS t4_10
 WHERE t4_10.c3 < (SELECT t4_10.c4 FROM t4 AS t4_10 ORDER BY 1 DESC LIMIT 1)
 GROUP BY t4_10.c7, t4_10.c10 ORDER BY 1 ASC)
 INTERSECT
 (SELECT (323 + 423)
 FROM t9 AS t9_6
 WHERE t9_6.c15 LIKE '%Ab%' OR t9_6.c15 LIKE '%Ab%'
      AND t9_6.c15 >= 'QsrlsBLynDZDMvmLkav' ORDER BY 1 ASC)
 ORDER BY 1;

drop table t9,t4;
