--disable_warnings
drop table if exists obsavepoint2, obcachetable2;
--enable_warnings

CREATE TABLE `obsavepoint2` (
  `payment_id` varchar(32) NOT NULL,
  `partition_id` varchar(10) GENERATED ALWAYS AS (substr(`payment_id`,1,1)) VIRTUAL,
  `gmt_create` timestamp(6) NULL DEFAULT CURRENT_TIMESTAMP(6),
  PRIMARY KEY (`payment_id`)
) partition by list columns(partition_id)
(partition p0 values in ('0'),
partition p1 values in ('1'),
partition p2 values in ('2'),
partition p3 values in ('3'),
partition p4 values in ('4'),
partition p5 values in ('5'),
partition p6 values in ('6'),
partition p7 values in ('7'),
partition p8 values in ('8'),
partition p9 values in ('9'));

 CREATE TABLE `obcachetable2` (
  `pk` int(11) NOT NULL,
  `v1` varchar(1024) DEFAULT NULL,
  `v1_check` bigint(20) DEFAULT NULL,
  `gmt_create` timestamp(6) NULL DEFAULT CURRENT_TIMESTAMP(6),
  `gmt_modified` timestamp(6) NULL DEFAULT CURRENT_TIMESTAMP(6),
  PRIMARY KEY (`pk`),
  KEY `gmt_modified` (`gmt_modified`) LOCAL
);

--error 1048
INSERT INTO obsavepoint2 VALUES (NULL, DEFAULT, cast((SELECT pk FROM obcachetable2 LIMIT 1) AS DATETIME));
INSERT INTO obsavepoint2 VALUES ('123456789', DEFAULT, cast((SELECT pk FROM obcachetable2 LIMIT 1) AS DATETIME));

drop table obsavepoint2, obcachetable2;
