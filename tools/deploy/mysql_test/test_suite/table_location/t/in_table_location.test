#owner: yuchen.wyc
#owner group: sql3
# tags: optimizer

# 测试不带二级分区时候的in语句，这个是不走新的逻辑的
# 测试是二级分区，但是查询的in条件只有一个列的情况
# 测试二级分区的in语句，基本测试，包括有重复的查询，in条件都落在对角线上的partition时的情况，in超过200个时候的情况
# 测试partition column和in语句里面类型不一样的情况，还要测试某些点一样，某些点不一样的情况
# 测试plan cache里面已经有对应的plan，然后给的参数不一样时候的情况
# 测试二级分区的列不是单列的情况，目前我们是不支持的
# 测试给定的是另外filter条件，例如=加or的情况。作为对比
# 测试filter条件里面给定的不是普通列。而是表达式的情况

use test;
--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1 (c1 int, c2 int, c3 int, primary key(c1, c2)) partition by hash(c1) partitions 5;
explain select * from t1 where c1 in (1,2,3);
drop table t1;

create table t1 (c1 int, c2 int, c3 int) partition by range(c1) subpartition by hash(c2) subpartitions 5 (partition p0 values less than(0), partition p1 values less than(100), partition p2 values less than(1000));

insert into t1 (c1,c2,c3) values(-1,0,0), (10, 1, 0), (500,2,0);

select * from t1 where (c1, c2) in ((-1, 0), (10, 1), (500, 2));
explain select * from t1 where (c1, c2) in ((-1, 0), (10, 1), (500, 2));

select * from t1 where (c1, c2) in ((-1,0), (-1,0), (-1,0));
explain select * from t1 where (c1, c2) in ((-1,0), (-1,0), (-1,0));

select * from t1 where c1 in (-1, 10, 500);
explain select * from t1 where c1 in (-1, 10, 500);

select * from t1 where (c1, c2) in (('-1.0', '0.0'), ('10.0', '1.0'));
explain select * from t1 where (c1, c2) in (('-1.0', '0.0'), ('10.0', '1.0'));

select * from t1 where (c1, c2) in (('-1.9', '0.0'), ('10.0', '1.9'));
explain select * from t1 where (c1, c2) in (('-1.9', '0.0'), ('10.0', '1.9'));

select * from t1 where (c1, c2) in (('-1', '0'), ('10', '1'), ('500', '2'));
explain select * from t1 where (c1, c2) in (('-1', '0'), ('10', '1'), ('500', '2'));

select * from t1 where (c1, c2) in (('-1', '0'), (10, 1), ('500', '2'));
explain select * from t1 where (c1, c2) in (('-1', '0'), (10, 1), ('500', '2'));

select * from t1 where (c1, c2) in ((3-4, 0 + 0), (10 + 0, 1 - 0), (500 + 0, 2 + 0));
explain select * from t1 where (c1, c2) in ((3-4, 0 + 0), (10 + 0, 1 - 0), (500 + 0, 2 + 0));

select * from t1 where (c1 = -1 and c2 = 0) or (c1 = 10 and c2 = 1) or (c1 = 500 and c2 = 2); 
explain select * from t1 where (c1 = -1 and c2 = 0) or (c1 = 10 and c2 = 1) or (c1 = 500 and c2 = 2); 
drop table t1;


create table t1 (c1 int, c2 int, c3 int) partition by hash(c2) subpartition by range(c1) subpartition template (
subpartition p0 values less than(0), subpartition p1 values less than(100), subpartition p2 values less than(1000)) partitions 5;

insert into t1 (c1,c2,c3) values(-1,0,0), (10, 1, 0), (500,2,0);

select * from t1 where (c1, c2) in ((-1, 0), (10, 1), (500, 2));
explain select * from t1 where (c1, c2) in ((-1, 0), (10, 1), (500, 2));

select * from t1 where (c1, c2) in ((-1,0), (-1,0), (-1,0));
explain select * from t1 where (c1, c2) in ((-1,0), (-1,0), (-1,0));

select * from t1 where c1 in (-1, 10, 500);
explain select * from t1 where c1 in (-1, 10, 500);

select * from t1 where (c1, c2) in (('-1', '0'), ('10', '1'), ('500', '2'));
explain select * from t1 where (c1, c2) in (('-1', '0'), ('10', '1'), ('500', '2'));

select * from t1 where (c1, c2) in (('-1', '0'), (10, 1), ('500', '2'));
explain select * from t1 where (c1, c2) in (('-1', '0'), (10, 1), ('500', '2'));
drop table t1;



#patition 超过200的情况
create table t1 (c1 int, c2 int, c3 int) partition by range(c1) subpartition by hash(c2) subpartitions 20 (
partition p0 values less than (0),
partition p1 values less than (10),
partition p2 values less than (20),
partition p3 values less than (30),
partition p4 values less than (40),
partition p5 values less than (50),
partition p6 values less than (60),
partition p7 values less than (70),
partition p8 values less than (80),
partition p9 values less than (90),
partition p10 values less than (100),
partition p11 values less than (110),
partition p12 values less than (120),
partition p13 values less than (130),
partition p14 values less than (140),
partition p15 values less than (150),
partition p16 values less than (160),
partition p17 values less than (170),
partition p18 values less than (180),
partition p19 values less than (190));

insert into t1(c1,c2) values
(-1,   0),
(9,    1),
(19,   2),
(29,   3),
(39,   4),
(49,   5),
(59,   6),
(69,   7),
(79,   8),
(89,   9),
(99,   10),
(109,  11),
(119,  12),
(129,  13),
(139,  14),
(149,  15),
(159,  16),
(169,  17),
(179,  18),
(189,  19);

select * from t1 where (c1,c2) in (
(-1,   0),
(9,    1),
(19,   2),
(29,   3),
(39,   4),
(49,   5),
(59,   6),
(69,   7),
(79,   8),
(89,   9),
(99,   10),
(109,  11),
(119,  12),
(129,  13),
(139,  14),
(149,  15),
(159,  16),
(169,  17),
(179,  18),
(189,  19));

explain select * from t1 where (c1,c2) in (
(-1,   0),
(9,    1),
(19,   2),
(29,   3),
(39,   4),
(49,   5),
(59,   6),
(69,   7),
(79,   8),
(89,   9),
(99,   10),
(109,  11),
(119,  12),
(129,  13),
(139,  14),
(149,  15),
(159,  16),
(169,  17),
(179,  18),
(189,  19));
drop table t1;


create table t1 (c1 int, c2 int, c3 int) partition by key(c2) subpartition by range(c1) subpartition template (
subpartition p0 values less than(0), subpartition p1 values less than(100), subpartition p2 values less than(1000)) partitions 5;

insert into t1 (c1,c2,c3) values(-1,0,0), (10, 1, 0), (500,2,0);

select * from t1 where (c1, c2) in ((-1, 0), (10, 1), (500, 2));
explain select * from t1 where (c1, c2) in ((-1, 0), (10, 1), (500, 2));

select * from t1 where (c1, c2) in ((-1,0), (-1,0), (-1,0));
explain select * from t1 where (c1, c2) in ((-1,0), (-1,0), (-1,0));

select * from t1 where c1 in (-1, 10, 500);
explain select * from t1 where c1 in (-1, 10, 500);

select * from t1 where (c1, c2) in (('-1', '0'), ('10', '1'), ('500', '2'));
explain select * from t1 where (c1, c2) in (('-1', '0'), ('10', '1'), ('500', '2'));

select * from t1 where (c1, c2) in (('-1', '0'), (10, 1), ('500', '2'));
explain select * from t1 where (c1, c2) in (('-1', '0'), (10, 1), ('500', '2'));
drop table t1;


create table t1 (c1 varchar(5000), c2 int, c3 int) partition by range columns(c1) subpartition by hash(c2) subpartitions 5 (partition p0 values less than('0'), partition p1 values less than('5'), partition p2 values less than('9'));
select * from t1 where (c1, c2) in (('0',0), ('5',2));
explain select * from t1 where (c1, c2) in (('0',0), ('5',2));
drop table t1;

create table t1 (c1 varchar(5000), c2 int, c3 int) partition by range columns(c1, c2) subpartition by hash(c3) subpartitions 5 (partition p0 values less than('0', 0), partition p1 values less than('5', 0), partition p2 values less than('9', 0));
select * from t1 where (c1, c2, c3) in (('0',0, 0), ('5',0, 1), ('7',0, 2));
explain select * from t1 where (c1, c2, c3) in (('0',0, 0), ('5',0, 1), ('7',0, 2));
drop table t1;



create table t1 (c1 datetime, c2 int, c3 int) partition by range columns(c1) subpartition by hash(c2) subpartitions 5 (partition p0 values less than('2017-01-01'), partition p1 values less than('2017-05-01'), partition p2 values less than('2017-10-01'));
select * from t1 where (c1, c2) in (('2016-12-01',0), ('2017-04-01',2));
explain select * from t1 where (c1, c2) in (('2016-12-01',0), ('2017-04-01',2));

select * from t1 where (c1, c2) in ((2016,0), (2017,2));
explain select * from t1 where (c1, c2) in ((2016,0), (2017,2));
drop table t1;


create table t1 (c1 int, c2 datetime, c3 int, c4 int, c5 int, primary key(c1,c2,c3,c4,c5)) partition by range columns(c2) subpartition by hash(c1) subpartitions 5 (partition p0 values less than('2017-01-01'), partition p1 values less than('2017-05-01'), partition p2 values less than('2017-10-01'));
insert into t1 values(0, '2016-12-01', 0, 0, 0);
insert into t1 values(1, '2017-04-01', 0, 0, 0);
insert into t1 values(2, '2017-06-01', 0, 0, 0);

explain select * from t1 where (c1, c2, c3, c4, c5) in ((0, '2016-12-01', 0, 0, 0), (1, '2017-04-01', 0, 0, 0), (2, '2017-06-01', 0, 0, 0));
select * from t1 where (c1, c2, c3, c4, c5) in ((0, '2016-12-01', 0, 0, 0), (1, '2017-04-01', 0, 0, 0), (2, '2017-06-01', 0, 0, 0));
drop table t1;


