CREATE TABLE t0(c0 SMALLINT(101)  NULL COMMENT 'asdf' , c1 DATETIME , c2 BIGINT(140)  )  PARTITION BY HASH(c2)  SUBPARTITION BY HASH(c0)  subpartitions 20 partitions 10;
explain SELECT ALL * FROM t0 WHERE (t0.c2,t0.c0) IN ((t0.c0,-48), (-9223372036854775808,98), (-9223372036854775808,9));
