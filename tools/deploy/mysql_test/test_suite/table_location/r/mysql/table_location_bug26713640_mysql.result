drop table if exists t1;
create table t1 (c1 varchar(5000), c2 int, c3 int) partition by range columns(c1) 
subpartition by hash(c2) subpartitions 5 
( 
partition p0 values less than('0'),
partition p1 values less than('5'), 
partition p2 values less than('9')
);
insert into t1 values ('-1',0,0), ('-2',1,1), ('-3',2,2), ('3',3,3), ('5',5,5), ('10',10,10);
explain select * from t1 where (c1, c2) in (('-1', '0'), ('10', 1), ('500', '2'));
Query Plan
=============================================================
|ID|OPERATOR                 |NAME    |EST.ROWS|EST.TIME(us)|
-------------------------------------------------------------
|0 |PX COORDINATOR           |        |1       |10          |
|1 |└─EXCHANGE OUT DISTR     |:EX10000|1       |9           |
|2 |  └─PX PARTITION ITERATOR|        |1       |7           |
|3 |    └─TABLE FULL SCAN    |t1      |1       |7           |
=============================================================
Outputs & filters:
-------------------------------------
  0 - output([INTERNAL_FUNCTION(t1.c1, t1.c2, t1.c3)]), filter(nil), rowset=16
  1 - output([INTERNAL_FUNCTION(t1.c1, t1.c2, t1.c3)]), filter(nil), rowset=16
      dop=1
  2 - output([t1.c1], [t1.c2], [t1.c3]), filter(nil), rowset=16
      force partition granule
  3 - output([t1.c1], [t1.c2], [t1.c3]), filter([(t1.c1, t1.c2) IN (('-1', demote_cast('0', INT(11, 0))), ('10', 1), ('500', demote_cast('2', INT(11, 0))))]), rowset=16
      access([t1.c1], [t1.c2], [t1.c3]), partitions(p0sp0, p1sp1, p2sp2)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([t1.__pk_increment]), range(MIN ; MAX)always true
select * from t1 where (c1, c2) in (('-1', '0'), ('10', 1), ('500', '2'));
c1	c2	c3
-1	0	0
SET collation_connection='utf8mb4_unicode_ci';
