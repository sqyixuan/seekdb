NAME_CONST-TC-5
存储过程中的使用
预期name_const不能传形参aa,实际结果成功，BUG:45036290
drop procedure p1;
create procedure p1(in aa int)
 begin
  case 
  when aa < 60 then
    select name_const('score',60);
  when aa = 60 then
    select name_const('score','及格');
  else
  select name_const('score',aa);
  end case;
 end /
call p1(59);
+------------------------+
| name_const('score',60) |
+------------------------+
|                     60 |
+------------------------+
call p1(60);
+------------------------------+
| name_const('score','及格')   |
+------------------------------+
| 及格                         |
+------------------------------+
call p1(88);
+------------------------+
| name_const('score',aa) |
+------------------------+
|                     88 |
+------------------------+
call p1(name_const('score',66));
+------------------------+
| name_const('score',aa) |
+------------------------+
|                     66 |
+------------------------+
drop procedure p1;
create procedure p1(in a int,out b int)
 begin
  set b = name_const('age',18);
  if a > b then
    set b = name_const('年轻人',18);
  else 
	set b = name_const('老年人',18);
  end if;
 end /
call p1(20,@b);
ob警告但是过程创建成功，call报错，MySQL官方是直接报错
Warning | 5002 | Resolve error
drop procedure p1;
create procedure p1(inout name varchar(20))
begin
	set name = concat('id-',name_const('value',name));
end /
