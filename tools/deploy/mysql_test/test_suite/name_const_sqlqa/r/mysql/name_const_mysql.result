drop table t1;
create table t1(c1 int,c2 int);
insert into t1 values(1,111);
insert into t1 values(2,222);
insert into t1 values(3,333);
select case c1 when 1                  then name_const('c2',111)
               when name_const('c1',2) then 222
else '000'
end as CC
from t1;
+------+
| CC   |
+------+
| 111  |
| 222  |
| 000  |
+------+
select case when c1 = 1                  then name_const('c2',111)
            when c1 = name_const('c1',2) then 222
else '000'
end as CC
from t1;
+------+
| CC   |
+------+
| 111  |
| 222  |
| 000  |
+------+
