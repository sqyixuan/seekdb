--echo 补充字符集测试
--echo utf8、utf8mb4、utf16、binary、gbk、gb18030
select name_const('s1',_utf8'test');
select name_const(1,_utf8'test' collate utf8_general_ci);
select name_const(1,_utf8'test' collate utf8_unicode_ci);
select name_const(1,_utf8'test' collate utf8_bin);
select name_const('中国',_utf8mb4'test');
select name_const('！@#￥%……&*',_utf8mb4'test' collate utf8mb4_general_ci);
select name_const('123abc中国城',_utf8mb4'test' collate utf8mb4_unicode_ci);
select name_const('utf8mb4',_utf8mb4'test' collate utf8mb4_bin);
select name_const('1.0000000001',_utf16'test');
select name_const(true,_utf16'test' collate utf16_general_ci);
select name_const(false,_utf16'test' collate utf16_bin);
select name_const(0,_utf16'test' collate utf16_unicode_ci);
select name_const(1.234E+8,_binary'test');
select name_const('12:12:12',_gbk'test');
select name_const('null',_gbk'test' collate gbk_chinese_ci);
select name_const('2022-09-23 11:11:11',_gbk'test' collate gbk_bin);
select name_const('0',_gb18030'test');
select name_const('',_gb18030'test' collate gb18030_chinese_ci);
select name_const('value',_gb18030'test' collate gb18030_bin);

select name_const(_utf8'test', 's1');
select name_const(_utf8mb4'test', 1);
select name_const(_utf16'test', null);
select name_const(_binary'test', true);
select name_const(_gbk'test', '');
select name_const(_gb18030'test', '111aaa√√√中中中');

