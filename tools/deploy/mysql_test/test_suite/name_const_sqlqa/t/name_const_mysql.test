partition by list(c1)
(
partition p1 values in(name_const('test',1),name_const('test',2),name_const('test',3)),
partition p2 values in(name_const('test',4),name_const('test',5),name_const('test',6)),
partition p3 values in(name_const('test',7),name_const('test',8),name_const('test',9))
);


--echo list
--error 0,1051
drop table t1;
create table t1(c1 int,c2 int)
partition by key(c1)
partitions 2;

insert into t1 values(name_const('test',1),1);
insert into t1 values(name_const('test',2),2);
insert into t1 values(name_const('test',3),3);
insert into t1 values(name_const('test',4),4);
insert into t1 values(name_const('test',5),5);
insert into t1 values(name_const('test',6),6);
select * from t1 partition(p0);
delete from t1 partition(p0) where c1 > name_const('test',5);
update t1 partition(p0) set c1 = name_const('test',1) where c1 = 3;
select name_const('list分区','p0'),* from t1;



