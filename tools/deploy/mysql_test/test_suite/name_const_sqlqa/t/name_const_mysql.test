--echo NAME_CONST-TC-3
--echo DQL

--error 0,1051
drop table t1;
create table t1(c1 int,c2 int,c3 int);
insert into t1 values(1,11,111);
insert into t1 values(1,0,111);
insert into t1 values(2,22,222);
insert into t1 values(2,0,222);
insert into t1 values(3,33,333);
insert into t1 values(3,0,333);

select *,name_const('追加列','√') from t1;
--echo where
select c1 from t1 where c2 = name_const('c2',11);

select c1,name_const('cc1','+1') from t1 where c1 > 0;

--echo order by  因为name_const('c1','c2')的值是常量，所以没有按c2排序也没有报错
select c1,c2 from t1 order by name_const('c1','c2');

select c1,c2,name_const('column','row') from t1 order by 2;

select c1,c2,name_const('column','row') from t1 order by 3;

--echo group by 
select c1,c2 from t1 group by name_const('ccc','c1');

select c1,c2,name_const('column','row') from t1 group by c1;

select c1,c2,name_const('column','row') from t1 group by 3;

--echo group by + having
select c1,c2 from t1 group by name_const('ccc','c1') having c1 > 0;

select c1,c2,name_const('column','row') from t1 group by c1 having c2 > 0;

--echo 子查询

--echo exists,not exists
select c1,c2,c3 from t1 where  exists(select * from t1 where c1 > name_const('ccc',0));
select c1,name_const('ccc',0) from t1 where exists(select * from t1 where c1 > 0);
select c1,c2,c3 from t1 where  not exists(select * from t1 where c1 = name_const('ccc',0));
select c1,name_const('ccc',0) from t1 where not exists(select * from t1 where c1 > 0);

--echo in,not in
select c1,c2,c3 from t1 where c1 in (name_const('ccc',1));
select c1,name_const('c',1) from t1 where c1 in (1,2);
select c1,c2,c3 from t1 where c1 not in (name_const('ccc',1));
select c1,name_const('c',1) from t1 where c1 not in (3);
--echo any
select c1,name_const('ccc',1) from t1 where c1 > any(select c1 from t1);
select c1,c2 from t1 where c1 > any(select name_const('c',1));

--echo some
select c1,name_const('ccc',1) from t1 where c1 > some(select c1 from t1);
select c1 from t1 where c1 > some(select name_const('c',1));

--echo all
select c1,name_const('ccc',1) from t1 where c1 > all(select c1 from t1);
select c1 from t1 where c1 > all(select name_const('c',1));

--echo and or
select c1,name_const('c',1) from t1 where c1 = 1 and c2 = 11; 

select c1,name_const('c',1) from t1 where c1 = 1 or c2 = 22; 

--echo insert 
insert into t1 values(4,44,name_const('c3',444));
insert into t1 values(4,44,name_const('c3',444)),(5,44,name_const('c3',444)),(name_const('c1',6),44,name_const('c3',444));

--echo update
update t1 set c1 = name_const('c1',0) where c2 = 0;
update t1 set c1 = name_const('c1',-1) where c1 = name_const('c1',0);

--echo delete
delete from t1 where c1 = name_const('c1',-1);
delete from t1 where c1 = name_const('c1',4) and c2 < name_const('c1',55);



