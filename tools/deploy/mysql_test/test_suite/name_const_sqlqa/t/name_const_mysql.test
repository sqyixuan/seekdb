--echo NAME_CONST-TC-5
--echo 存储过程中的使用
--echo 预期name_const不能传形参aa,实际结果成功，BUG:45036290
--error 0,1305
drop procedure p1;
delimiter /;
create procedure p1(in aa int)
 begin
  case 
  when aa < 60 then
    select name_const('score',60);
  when aa = 60 then
    select name_const('score','及格');
  else
  select name_const('score',aa);
  end case;
 end /
delimiter ;/

call p1(59);
call p1(60);
call p1(88);
call p1(name_const('score',66));





--error 0,1305
drop procedure p1;
delimiter /;
create procedure p1(in a int,out b int)
 begin
  set b = name_const('age',18);
  if a > b then
    set b = name_const('年轻人',18);
  else 
	set b = name_const('老年人',18);
  end if;
 end /
delimiter ;/

call p1(20,@b);



