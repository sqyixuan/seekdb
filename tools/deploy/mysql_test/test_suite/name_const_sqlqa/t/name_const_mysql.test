--echo 分区表
--echo hash
--error 0,1051
drop table t1;
create table t1(c1 int,c2 int)
partition by hash(c1)
(
partition p0,
partition p1
);

insert into t1 values(name_const('test',1),1);
insert into t1 values(name_const('test',2),2);
insert into t1 values(name_const('test',3),3);
insert into t1 values(name_const('test',4),4);
insert into t1 values(name_const('test',5),5);
insert into t1 values(name_const('test',6),6);

select * from t1;

select * from t1 partition(p0) where c1 = name_const(2,2);
update t1 set c1 = name_const(7,7) where c1 = name_const(6,6);
delete from t1 where c1 = name_const(5,5);
select * from t1 partition(p0);




--echo range
--error 0,1051
drop table t1;
create table t1(c1 int,c2 int)
partition by range(c1)
(
partition p1 values less than(10),
partition p2 values less than(50),
partition pmax values less than (maxvalue)
);
insert into t1 values(name_const('test',1),1);
insert into t1 values(name_const('test',11),11);
insert into t1 values(name_const('test',22),22);
insert into t1 values(name_const('test',55),55);

select * from t1 partition(p2) where c1 = name_const('test',11) order by 1;
update t1 partition(p2) set c1 = name_const('test',12) where c1 = name_const('test',11); 
delete from t1 partition(p2) where c1 = name_const('test',22);
select * from t1;


