#owner: linyi.cl
#owner group: sql3
#tags: optimizer

--source mysql_test/include/select_into_outfile/get_host_ip.inc
let $DATA_FOLDER_NAME = data_for_mysqltest_select_into_outfile_parallel;

--source mysql_test/include/select_into_outfile/delete_dir.inc
--source mysql_test/include/select_into_outfile/mkdir_for_dump.inc

--disable_warnings
drop table if exists t1, t2, t3;
--enable_warnings


create table t1(c1 int);
insert into t1 values(1),(2),(3);
create table t2(c1 int);
insert into t2 values(1),(2),(3);

--echo =========== no parallel ============

--source mysql_test/include/select_into_outfile/delete_files.inc
eval select * from t1 into outfile '$DATA_FOLDER_NAME/data1' max_file_size=1 single=false;
explain select * from t1 into outfile '$DATA_FOLDER_NAME/data1' max_file_size=1 single=false;
--source mysql_test/include/select_into_outfile/cat_dir.inc

--source mysql_test/include/select_into_outfile/delete_files.inc
eval select * from t1 into outfile '$DATA_FOLDER_NAME/data2' max_file_size=2 single=false;
--source mysql_test/include/select_into_outfile/cat_dir.inc

--source mysql_test/include/select_into_outfile/delete_files.inc
eval select * from t1 into outfile '$DATA_FOLDER_NAME/data3' max_file_size=3 single=false;
--source mysql_test/include/select_into_outfile/cat_dir.inc

--source mysql_test/include/select_into_outfile/delete_files.inc
eval select * from t1 into outfile '$DATA_FOLDER_NAME/data4' max_file_size=4 single=false;
--source mysql_test/include/select_into_outfile/cat_dir.inc

--source mysql_test/include/select_into_outfile/delete_files.inc
eval select * from t1 into outfile '$DATA_FOLDER_NAME/data5' max_file_size=1;
--source mysql_test/include/select_into_outfile/cat_dir.inc

--source mysql_test/include/select_into_outfile/delete_files.inc
eval select * from t1 into outfile '$DATA_FOLDER_NAME/data6' max_file_size=4;
--source mysql_test/include/select_into_outfile/cat_dir.inc

--source mysql_test/include/select_into_outfile/delete_files.inc
eval select * from t1 into outfile '$DATA_FOLDER_NAME/data7' single=false;
--source mysql_test/include/select_into_outfile/cat_dir.inc 

--disable_query_log
delete from t1;
--let $count = 1
while($count <= 50)
{
  --let $stmt=insert into t1 values ($count)
  eval $stmt;
  inc $count;
}
--enable_query_log

select count(*) from t1;

--echo =========== parallel ============

--source mysql_test/include/select_into_outfile/delete_files.inc
eval select /*+parallel(2)*/* from t1 into outfile '$DATA_FOLDER_NAME/data8';
explain select /*+parallel(2)*/* from t1 into outfile '$DATA_FOLDER_NAME/data8';
--source mysql_test/include/select_into_outfile/cat_dir.inc

--source mysql_test/include/select_into_outfile/delete_files.inc
eval select /*+parallel(2)*/* from t1 into outfile '$DATA_FOLDER_NAME/data9' single false;
explain select /*+parallel(2)*/* from t1 into outfile '$DATA_FOLDER_NAME/data9' single false;
--source mysql_test/include/select_into_outfile/cat_dir.inc

--source mysql_test/include/select_into_outfile/delete_files.inc
eval select /*+parallel(2)*/* from t1 into outfile '$DATA_FOLDER_NAME/data10' max_file_size 12;
explain select /*+parallel(2)*/* from t1 into outfile '$DATA_FOLDER_NAME/data10' max_file_size 12;
--source mysql_test/include/select_into_outfile/cat_dir.inc

--source mysql_test/include/select_into_outfile/delete_files.inc
eval select /*+parallel(2)*/* from t1 into outfile '$DATA_FOLDER_NAME/data11' max_file_size=50 single=false;
explain select /*+parallel(2)*/* from t1 into outfile '$DATA_FOLDER_NAME/data11' max_file_size=50 single=false;
--source mysql_test/include/select_into_outfile/cat_dir.inc

--source mysql_test/include/select_into_outfile/delete_files.inc
eval select /*+parallel(2)*/* from t1 into outfile '$DATA_FOLDER_NAME/data12' max_file_size 25 single false;
--source mysql_test/include/select_into_outfile/cat_dir.inc

--source mysql_test/include/select_into_outfile/delete_files.inc
eval select /*+parallel(2)*/* from t1 into outfile '$DATA_FOLDER_NAME/data13' max_file_size=12 single=false;
--source mysql_test/include/select_into_outfile/cat_dir.inc

--source mysql_test/include/select_into_outfile/delete_files.inc
eval select /*+parallel(4)*/* from t1 into outfile '$DATA_FOLDER_NAME/data14' max_file_size=12 single=false;
--source mysql_test/include/select_into_outfile/cat_dir.inc

--source mysql_test/include/select_into_outfile/delete_files.inc
eval select /*+parallel(3)*/* from t1 into outfile '$DATA_FOLDER_NAME/data15' max_file_size=17 single=false;
--source mysql_test/include/select_into_outfile/cat_dir.inc 

--source mysql_test/include/select_into_outfile/delete_files.inc
eval select /*+parallel(2)*/* from t1 order by c1 desc into outfile '$DATA_FOLDER_NAME/data16' single=false;
explain select /*+parallel(2)*/* from t1 order by c1 desc into outfile '$DATA_FOLDER_NAME/data16' single=false;
explain select /*+parallel(2)*/* from t1 order by c1 desc into outfile '$DATA_FOLDER_NAME/data16';
--source mysql_test/include/select_into_outfile/cat_dir.inc

--source mysql_test/include/select_into_outfile/delete_files.inc
eval select /*+parallel(2)*/* from t1 order by c1 desc into outfile '$DATA_FOLDER_NAME/data17' max_file_size=12 single=false;
--source mysql_test/include/select_into_outfile/cat_dir.inc

--source mysql_test/include/select_into_outfile/delete_files.inc
eval select /*+parallel(4)*/* from t1 order by c1 desc into outfile '$DATA_FOLDER_NAME/data18' single=false;
--source mysql_test/include/select_into_outfile/cat_dir.inc

--source mysql_test/include/select_into_outfile/delete_files.inc
eval select /*+parallel(4)*/* from t1 order by c1 desc into outfile '$DATA_FOLDER_NAME/data19' max_file_size=12 single=false;
--source mysql_test/include/select_into_outfile/cat_dir.inc

--source mysql_test/include/select_into_outfile/delete_files.inc
explain select /*+parallel(4)*/* from t1 join t2 on t1.c1=t2.c1 into outfile '$DATA_FOLDER_NAME/data20' single=false;
eval select /*+parallel(4)*/* from t1 join t2 on t1.c1=t2.c1 into outfile '$DATA_FOLDER_NAME/data20' single=false;
--source mysql_test/include/select_into_outfile/cat_dir.inc

--source mysql_test/include/select_into_outfile/delete_files.inc
explain select /*+parallel(4)*/* from t1 where c1 > (select max(c1) from t2) into outfile '$DATA_FOLDER_NAME/data21' single=false;
eval select /*+parallel(4)*/* from t1 where c1 > (select max(c1) from t2) into outfile '$DATA_FOLDER_NAME/data21' single=false;
--source mysql_test/include/select_into_outfile/cat_dir.inc

--source mysql_test/include/select_into_outfile/delete_files.inc
eval select /*+parallel(2)*/* from t1 order by c1 desc into outfile '$DATA_FOLDER_NAME/data22' max_file_size='12B' single=false;
--source mysql_test/include/select_into_outfile/cat_dir.inc

--source mysql_test/include/select_into_outfile/delete_files.inc
eval select /*+parallel(2)*/* from t1 order by c1 desc into outfile '$DATA_FOLDER_NAME/' single=false;
--source mysql_test/include/select_into_outfile/cat_dir.inc


create table t3(c1 int, c2 varbinary(10), c3 binary(10), c4 varchar(20), c5 char(20),
                c6 varchar(20) charset gbk, c7 char(20) charset gbk);

insert into t3 values(1, b'1', b'1', 'abc', 'def', 'hhh涓瓃zz', 'hhh鍥絲zz');
insert into t3 values(2, b'101', b'101', 'abca', 'defb', 'hhh涓瓃鎺抸z', 'hhh鍥絲鐞儂z');
insert into t3 values(3, b'11', b'11', 'abc', 'def', 'hhh涓瓃zz', 'hhh鍥絲zz');
insert into t3 values(4, b'111', b'111', 'abc', 'def', 'hhh涓瓃zz鍖归厤', 'hhh鍥絲zz鍝佺墝');
insert into t3 values(5, b'1111', b'1111', 'abc', 'def', 'hhh涓瓃ziiz', 'hkkhh鍥絲zz');
insert into t3 values(6, b'10101', b'10101', 'abc', 'def', 'hhh涓瓃zz6', 'hhh鍥絲z66z');

--source mysql_test/include/select_into_outfile/delete_files.inc
eval select /*+parallel(3)*/* from t3 order by c1 into outfile '$DATA_FOLDER_NAME/' single=false;
--source mysql_test/include/select_into_outfile/cat_dir.inc

--source mysql_test/include/select_into_outfile/delete_files.inc
eval select /*+parallel(2)*/* from t3 order by c1 into outfile '$DATA_FOLDER_NAME/' single=false max_file_size=12;
--source mysql_test/include/select_into_outfile/cat_dir.inc

--source mysql_test/include/select_into_outfile/delete_files.inc
eval select /*+parallel(2)*/* from t3 order by c1 into outfile '$DATA_FOLDER_NAME/' charset GB18030 single=false;
--source mysql_test/include/select_into_outfile/cat_dir.inc

--source mysql_test/include/select_into_outfile/delete_files.inc
eval select /*+parallel(2)*/* from t3 order by c1 into outfile '$DATA_FOLDER_NAME/' charset gbk single=false;
--source mysql_test/include/select_into_outfile/cat_dir.inc

--source mysql_test/include/select_into_outfile/delete_files.inc
eval select /*+parallel(2)*/* from t3 order by c1 into outfile '$DATA_FOLDER_NAME/' charset utf8 single=false;
--source mysql_test/include/select_into_outfile/cat_dir.inc

drop table t3;
create table t3(c1 int, c2 double, c3 float, c4 varchar(20), c5 char(20), c6 date, c7 bool);
insert into t3 values(1, 1.324, 2.3, 'hhh涓瓃zz', 'hhh鍥絲zz', '2021-08-19', true);
insert into t3 values(2, 2.325, 3.2, 'hhh涓瓃鎺抸z', 'hhh鍥絲鐞儂z', '2022-08-19', 0);
insert into t3 values(3, 3.14, 4.2, 'hhh涓瓃zz', 'hhh鍥絲zz', '2023-08-19', 1);
insert into t3 values(4, 9.001, 5.10, 'hhh涓瓃zz鍖归厤', 'hhh鍥絲zz鍝佺墝', '2024-08-19', false);
insert into t3 values(5, 2.181, 6.7, 'hhh涓瓃ziiz', 'hkkhh鍥絲zz', '2025-08-19', TRUE);
insert into t3 values(6, 1010, 29, 'hhh涓瓃zz6', 'hhh鍥絲z66z', '2026-08-19', FALse);

--source mysql_test/include/select_into_outfile/delete_files.inc
eval select /*+parallel(2)*/* from t3 order by c1 into outfile '$DATA_FOLDER_NAME/' single=false;
--source mysql_test/include/select_into_outfile/cat_dir.inc

--source mysql_test/include/select_into_outfile/delete_files.inc
eval select /*+parallel(2)*/* from t3 order by c1 into outfile '$DATA_FOLDER_NAME/' charset GB18030 single=false;
--source mysql_test/include/select_into_outfile/cat_dir.inc

--source mysql_test/include/select_into_outfile/delete_files.inc
eval select /*+parallel(2)*/* from t3 order by c1 into outfile '$DATA_FOLDER_NAME/' charset gbk single=false;
--source mysql_test/include/select_into_outfile/cat_dir.inc

--source mysql_test/include/select_into_outfile/delete_dir.inc
drop table t1, t2, t3;
