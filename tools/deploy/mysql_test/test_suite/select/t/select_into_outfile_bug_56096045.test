#owner: linyi.cl
#owner group: sql3
#tags: optimizer

--source mysql_test/include/select_into_outfile/get_host_ip.inc
let $DATA_FOLDER_NAME = select_into_outfile_invalid_character;

--source mysql_test/include/select_into_outfile/delete_dir.inc
--source mysql_test/include/select_into_outfile/mkdir_for_dump.inc

--disable_warnings
drop table if exists t1, t2;
--enable_warnings

create table t1(c1 int);
create table t2(c1 varchar(10) collate utf8mb4_bin);
insert into t2 values('😊');
insert into t2 values('😊123');
insert into t2 values('123😊');
insert into t2 values('123😊123');

--source mysql_test/include/select_into_outfile/delete_files.inc
eval select * from t1 into outfile '$DATA_FOLDER_NAME/data1';
explain select * from t1 into outfile '$DATA_FOLDER_NAME/data1';
--source mysql_test/include/select_into_outfile/cat_dir.inc

--source mysql_test/include/select_into_outfile/delete_files.inc
eval select /*+parallel(2)*/ * from t1 into outfile '$DATA_FOLDER_NAME/data2';
explain select /*+parallel(2)*/ * from t1 into outfile '$DATA_FOLDER_NAME/data2';
--source mysql_test/include/select_into_outfile/cat_dir.inc

--source mysql_test/include/select_into_outfile/delete_files.inc
eval select * from t1 into outfile '$DATA_FOLDER_NAME/data3' single=false;
explain select * from t1 into outfile '$DATA_FOLDER_NAME/data3' single=false;
--source mysql_test/include/select_into_outfile/cat_dir.inc

--source mysql_test/include/select_into_outfile/delete_files.inc
eval select /*+parallel(2)*/ * from t1 into outfile '$DATA_FOLDER_NAME/data4' single=false;
explain select /*+parallel(2)*/ * from t1 into outfile '$DATA_FOLDER_NAME/data4' single=false;
--source mysql_test/include/select_into_outfile/cat_dir.inc

--source mysql_test/include/select_into_outfile/delete_files.inc
eval select * from t2 into outfile '$DATA_FOLDER_NAME/data5' character set gbk;
--source mysql_test/include/select_into_outfile/cat_dir.inc

--error 1235
select 'a' into outfile 'temp1' character set utf16;

--source mysql_test/include/select_into_outfile/delete_dir.inc
drop table t1,t2;