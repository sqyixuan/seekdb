#owner: linyi.cl
#owner group: sql3
#tags: optimizer

--source mysql_test/include/oss_config_for_import.inc

let $DATA_FOLDER_NAME = antsys-antsys-oceanbase-rd-sql/linyi.cl/select_into_outfile_lob_buffer_size;
let $FILE_PREFIX = data;

--source mysql_test/include/select_into_outfile/delete_dir_oss.inc
--source mysql_test/include/select_into_outfile/mkdir_for_dump_oss.inc

--disable_warnings
drop table if exists t1;
--enable_warnings

set ob_query_timeout = 10000000000;

create table t1(c1 int, c2 varchar(20), c3 text);

--echo ## 小于2MB的lob 文件总大小不超过10MB
insert /*+append enable_parallel_dml parallel(8) */ into t1
select UNIFORM(1, 10000, random(7)), RANDSTR(20, random(7)), repeat(RANDSTR(20, random(7)), 1000) from table(generator(100));

--source mysql_test/include/select_into_outfile/delete_files_oss.inc
--source mysql_test/include/select_into_outfile/replace_oss_info.inc
eval select * from t1 into outfile 'oss://$DATA_FOLDER_NAME/data1?host=$OSS_HOST&access_id=$OSS_ACCESS_ID&access_key=$OSS_ACCESS_KEY' buffer_size='2MB';
--source mysql_test/include/select_into_outfile/list_dir_oss.inc

--source mysql_test/include/select_into_outfile/delete_files_oss.inc
--source mysql_test/include/select_into_outfile/replace_oss_info.inc
eval select * from t1 into outfile 'oss://$DATA_FOLDER_NAME/?host=$OSS_HOST&access_id=$OSS_ACCESS_ID&access_key=$OSS_ACCESS_KEY' single=false max_file_size=1000000 buffer_size='2MB';
--source mysql_test/include/select_into_outfile/list_dir_oss.inc

--echo ## 小于2MB的lob 文件总大小超过10MB
insert /*+append enable_parallel_dml parallel(40) */ into t1
select UNIFORM(1, 10000, random(7)), RANDSTR(20, random(7)), repeat(RANDSTR(20, random(7)), 1000) from table(generator(1000));

--source mysql_test/include/select_into_outfile/delete_files_oss.inc
--source mysql_test/include/select_into_outfile/replace_oss_info.inc
eval select * from t1 into outfile 'oss://$DATA_FOLDER_NAME/data1?host=$OSS_HOST&access_id=$OSS_ACCESS_ID&access_key=$OSS_ACCESS_KEY' buffer_size='2MB';
--source mysql_test/include/select_into_outfile/list_dir_oss.inc

--source mysql_test/include/select_into_outfile/delete_files_oss.inc
--source mysql_test/include/select_into_outfile/replace_oss_info.inc
eval select * from t1 into outfile 'oss://$DATA_FOLDER_NAME/?host=$OSS_HOST&access_id=$OSS_ACCESS_ID&access_key=$OSS_ACCESS_KEY' single=false max_file_size=2100000 buffer_size='2MB';
--source mysql_test/include/select_into_outfile/list_dir_oss.inc

--source mysql_test/include/select_into_outfile/delete_files_oss.inc
--source mysql_test/include/select_into_outfile/replace_oss_info.inc
eval select /*+parallel(5)*/ * from t1 into outfile 'oss://$DATA_FOLDER_NAME/?host=$OSS_HOST&access_id=$OSS_ACCESS_ID&access_key=$OSS_ACCESS_KEY' single=false max_file_size=2100000 buffer_size='2MB';
--source mysql_test/include/select_into_outfile/list_dir_oss.inc

drop table t1;
create table t1(c1 int, c2 varchar(20), c3 longtext);

--echo ## 超过2MB的lob 文件总大小不超过10MB
insert /*+append enable_parallel_dml parallel(8) */ into t1
select UNIFORM(1, 10000, random(7)), RANDSTR(10, random(7)), repeat(RANDSTR(2200, random(7)), 1000) from table(generator(3));

--source mysql_test/include/select_into_outfile/delete_files_oss.inc
--source mysql_test/include/select_into_outfile/replace_oss_info.inc
eval select * from t1 into outfile 'oss://$DATA_FOLDER_NAME/data1?host=$OSS_HOST&access_id=$OSS_ACCESS_ID&access_key=$OSS_ACCESS_KEY' buffer_size='2MB';
--source mysql_test/include/select_into_outfile/list_dir_oss.inc

--source mysql_test/include/select_into_outfile/delete_files_oss.inc
--source mysql_test/include/select_into_outfile/replace_oss_info.inc
eval select * from t1 into outfile 'oss://$DATA_FOLDER_NAME/?host=$OSS_HOST&access_id=$OSS_ACCESS_ID&access_key=$OSS_ACCESS_KEY' single=false max_file_size=2000000 buffer_size='2MB';
--source mysql_test/include/select_into_outfile/list_dir_oss.inc

--echo ## 超过2MB的lob 文件总大小超过10MB
insert /*+append enable_parallel_dml parallel(8) */ into t1
select UNIFORM(1, 10000, random(7)), RANDSTR(10, random(7)), repeat(RANDSTR(2200, random(7)), 1000) from table(generator(10));

--source mysql_test/include/select_into_outfile/delete_files_oss.inc
--source mysql_test/include/select_into_outfile/replace_oss_info.inc
eval select * from t1 into outfile 'oss://$DATA_FOLDER_NAME/data1?host=$OSS_HOST&access_id=$OSS_ACCESS_ID&access_key=$OSS_ACCESS_KEY' buffer_size='2MB';
--source mysql_test/include/select_into_outfile/list_dir_oss.inc

--source mysql_test/include/select_into_outfile/delete_files_oss.inc
--source mysql_test/include/select_into_outfile/replace_oss_info.inc
eval select * from t1 into outfile 'oss://$DATA_FOLDER_NAME/?host=$OSS_HOST&access_id=$OSS_ACCESS_ID&access_key=$OSS_ACCESS_KEY' single=false max_file_size=2000000 buffer_size='2MB';
--source mysql_test/include/select_into_outfile/list_dir_oss.inc

--source mysql_test/include/select_into_outfile/delete_files_oss.inc
--source mysql_test/include/select_into_outfile/replace_oss_info.inc
eval select /*+parallel(5)*/ * from t1 into outfile 'oss://$DATA_FOLDER_NAME/?host=$OSS_HOST&access_id=$OSS_ACCESS_ID&access_key=$OSS_ACCESS_KEY' single=false max_file_size=2000000 buffer_size='2MB';
--source mysql_test/include/select_into_outfile/list_dir_oss.inc

--echo ## 超过2MB的lob 文件总大小超过256MB
insert /*+append enable_parallel_dml parallel(4) */ into t1
select UNIFORM(1, 10000, random(7)), RANDSTR(10, random(7)), repeat(RANDSTR(2200, random(7)), 1000) from table(generator(200));

--source mysql_test/include/select_into_outfile/delete_files_oss.inc
--source mysql_test/include/select_into_outfile/replace_oss_info.inc
eval select /*+parallel(5)*/ * from t1 into outfile 'oss://$DATA_FOLDER_NAME/?host=$OSS_HOST&access_id=$OSS_ACCESS_ID&access_key=$OSS_ACCESS_KEY' single=false max_file_size=32000000 buffer_size='2MB';
--source mysql_test/include/select_into_outfile/list_dir_oss.inc

drop table t1;
--source mysql_test/include/select_into_outfile/delete_dir_oss.inc
