--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: zhenjiang.xzj
#tags: optimizer
#owner group: storage
# test select for update bug
--disable_warnings
drop table if exists recon_alipay_detail_76;
--enable_warnings
CREATE TABLE `recon_alipay_detail_76` (
  `id` varchar(20) NOT NULL COMMENT '主键，8位日期+8位流水号(8位seq，需要循环)',
  `bill_no` varchar(30) NOT NULL COMMENT '业务单据号',
  `biz_type` varchar(10) NOT NULL COMMENT '业务类型，例如JF为公共事业缴费',
  `org_code` varchar(50) NOT NULL COMMENT '机构代码',
  `sub_org_code` varchar(50) DEFAULT NULL COMMENT '子机构代码，为空默认与orgCode相同(新产生的数据均不为空)',
  `batch_no` varchar(20) DEFAULT NULL COMMENT '对账批次号，对应recon_alipay_batch的主键',
  `business_date` timestamp(6) NOT NULL COMMENT '业务发生时间' DEFAULT CURRENT_TIMESTAMP(6),
  `business_amount` bigint(20) DEFAULT '0' COMMENT '业务发生金额',
  `extend_field` varchar(4000) DEFAULT NULL COMMENT '扩展属性,例如缴费可记录流水号，销账流水号，逗号分隔',
  `check_status` char(1) NOT NULL COMMENT '对账状态，1:已生成批次 2:已生成文件 3:对帐完成，4:对帐异常)',
  `acctrans_status` char(1) DEFAULT NULL COMMENT '账务状态(1:初始化; 4:已回充 5:已轧差-6:待提现-7:已提现)',
  `check_result` char(1) DEFAULT NULL COMMENT '对账结果（S，成功；F，失败，E，异常）',
  `status` char(1) NOT NULL default 'S' COMMENT '单据本身状态（S，成功；F，失败，I，处理中',
  `check_memo` varchar(500) DEFAULT NULL COMMENT '对账说明',
  `notify_status` char(1) DEFAULT NULL COMMENT '报送对账结果状态，I-未报送，P-等待报送，S-报送成功',
  `clearing_id` varchar(16) DEFAULT NULL COMMENT '清算流水ID',
  `notify_clearing_status` varchar(2) DEFAULT NULL COMMENT '报送清算结果状态，I-未报送，P-等待报送，S-报送成功',
  `notify_netting_status` varchar(2) DEFAULT NULL COMMENT '报送轧差结果状态，I-未报送，P-等待报送，S-报送成功',
  `net_amount` bigint(20) DEFAULT NULL COMMENT '业务净额（用于清算给机构，在净额清算模式下等于BUSINESS_AMOUNT扣除服务费）',
  `gmt_create` timestamp(6) NOT NULL DEFAULT CURRENT_TIMESTAMP(6) COMMENT '创建时间',
  `gmt_modified` timestamp(6) NOT NULL DEFAULT CURRENT_TIMESTAMP(6) ON UPDATE CURRENT_TIMESTAMP(6) COMMENT '修改时间',
  `flag` varchar(6) DEFAULT NULL COMMENT 'uid倒数23位',
  PRIMARY KEY (`id`),
  UNIQUE KEY `uk_bill_no` (`bill_no`) BLOCK_SIZE 16384,
  KEY `idx_recon_alipay_detail_stats` (`org_code`, `check_status`, `check_result`, `acctrans_status`, `biz_type`, `business_date`, `status`) BLOCK_SIZE 16384,
  KEY `idx_recon_wait_clearing` (`biz_type`, `org_code`, `sub_org_code`, `business_date`, `check_status`, `acctrans_status`) BLOCK_SIZE 16384,
  KEY `idx_recon_alipay_batch_query` (`biz_type`, `org_code`, `batch_no`) BLOCK_SIZE 16384,
  KEY `idx_recon_alipay_wait_make_file` (`biz_type`, `org_code`, `batch_no`, `check_status`, `check_result`, `acctrans_status`) BLOCK_SIZE 16384,
  KEY `idx_recon_alipay_after_make_file` (`biz_type`, `org_code`, `check_status`, `status`, `acctrans_status`, `check_result`) BLOCK_SIZE 16384,
  KEY `idx_recon_alipay_bill_no` (`biz_type`, `org_code`, `bill_no`) BLOCK_SIZE 16384,
  KEY `idx_recon_stat_query` (`biz_type`, `org_code`, `check_status`, `business_date`, `status`, `sub_org_code`) BLOCK_SIZE 16384,
  KEY `idx_batch_and_flag` (`biz_type`, `org_code`, `batch_no`, `flag`) BLOCK_SIZE 16384,
  KEY `idx_notify_billnos` (`notify_status`, `check_status`, `bill_no`) BLOCK_SIZE 16384,
  KEY `idx_notify_flag` (`biz_type`, `org_code`, `sub_org_code`, `notify_status`, `flag`) BLOCK_SIZE 16384
) DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.0' REPLICA_NUM = 3 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 10 COMMENT = '对账明细表';

