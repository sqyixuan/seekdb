--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: jim.wjh
#owner group: sql2
#tags: dml, optimizer

--source mysql_test/include/select_into_outfile/get_host_ip.inc
let $DATA_FOLDER_NAME = data_for_mysqltest_select_into_outfile;
--source mysql_test/include/select_into_outfile/mkdir_for_dump.inc 

--disable_warnings
DROP TABLE IF EXISTS TESTOSS8;
DROP TABLE IF EXISTS TESTOSS9;
--enable_warnings

--echo =======================

CREATE TABLE TESTOSS9(c22  TINYBLOB, c23 BLOB,c24 MEDIUMBLOB,c25 LONGBLOB,c26 TINYTEXT,c27 TEXT CHARSET GBK ,c28 MEDIUMTEXT ,c29 LONGTEXT);
INSERT INTO TESTOSS9 VALUES (1,20,200,'A20','中','中国','中国人','中国人abcedfg');


let $FILE_NAME = temp1;
--source mysql_test/include/select_into_outfile/delete_file.inc 
eval SELECT * INTO OUTFILE  '$DATA_FOLDER_NAME/$FILE_NAME' FIELDS TERMINATED BY ',' ENCLOSED BY '"' LINES TERMINATED BY '\n' FROM TESTOSS9;
--source mysql_test/include/select_into_outfile/cat_file.inc 

drop table TESTOSS9;


--echo =======================

CREATE TABLE TESTOSS8(c20 BINARY(200));
INSERT INTO TESTOSS8 VALUES (b'10000000');

let $FILE_NAME = temp2;
--source mysql_test/include/select_into_outfile/delete_file.inc 
eval SELECT * INTO OUTFILE  '$DATA_FOLDER_NAME/$FILE_NAME' FIELDS TERMINATED BY ',' ENCLOSED BY '"' LINES TERMINATED BY '\n' FROM TESTOSS8;
--source mysql_test/include/select_into_outfile/hexdump_file.inc 

drop table TESTOSS8;

--echo =======================

CREATE TABLE TESTOSS8(c20 BINARY(200));
INSERT INTO TESTOSS8 VALUES (b'10000000');

let $FILE_NAME = temp2;
--source mysql_test/include/select_into_outfile/delete_file.inc 
eval SELECT * INTO OUTFILE  '$DATA_FOLDER_NAME/$FILE_NAME' FIELDS TERMINATED BY x'2C' ENCLOSED BY x'22' LINES TERMINATED BY x'0A' FROM TESTOSS8;
--source mysql_test/include/select_into_outfile/hexdump_file.inc 

drop table TESTOSS8;


