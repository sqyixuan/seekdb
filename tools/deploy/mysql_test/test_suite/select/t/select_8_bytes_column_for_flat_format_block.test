# owner: dengzhi.ldz 
# owner group: storage
# description: for select 8 byte column with flat format block. 

#--disable_abort_on_error
--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;

connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn0,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,oceanbase,$OBMYSQL_PORT);

--let $value=1
--let $bytes=1024
--let $byte=1
while($bytes)
{
    --let $value=$value$byte
    dec $bytes;
}

connection conn1;
--disable_warnings
drop table if exists test_select_8_bytes_column_for_flat_format_block;
--enable_warnings
create table test_select_8_bytes_column_for_flat_format_block(c0 int primary key, c1 varchar(2048), c2 int, c3 binary(8)) ROW_FORMAT=redundant BLOCK_SIZE = 4096 COMPRESSION = 'none';

--let $cnt=100
--let $num=1
while($cnt)
{
  eval insert into test_select_8_bytes_column_for_flat_format_block values ($num, 'a$value', 0, 'a');
  inc $num;
  eval insert into test_select_8_bytes_column_for_flat_format_block values ($num, 'b$value', 0, 'bbbbbbbb');
  inc $num;
  eval insert into test_select_8_bytes_column_for_flat_format_block values ($num, 'c$value', 0, 'c');
  inc $num;
  eval insert into test_select_8_bytes_column_for_flat_format_block values ($num, 'd$value', 0, 'dddddddd');
  inc $num;
  eval insert into test_select_8_bytes_column_for_flat_format_block values ($num, 'e$value', 0, 'e');
  inc $num;
  eval insert into test_select_8_bytes_column_for_flat_format_block values ($num, 'f$value', 0, 'ffffffff');
  inc $num;
  eval insert into test_select_8_bytes_column_for_flat_format_block values ($num, 'g$value', 0, 'g');
  inc $num;
  eval insert into test_select_8_bytes_column_for_flat_format_block values ($num, 'h$value', 0, 'hhhhhhhh');
  inc $num;
  eval insert into test_select_8_bytes_column_for_flat_format_block values ($num, 'i$value', 0, 'i');
  inc $num;
  eval insert into test_select_8_bytes_column_for_flat_format_block values ($num, 'j$value', 0, 'jjjjjjjj');
  inc $num;
  eval insert into test_select_8_bytes_column_for_flat_format_block values ($num, 'k$value', 0, 'k');
  inc $num;
  dec $cnt;
}

alter table test_select_8_bytes_column_for_flat_format_block add column c4 int default 100; 
# Insert one row to make new schame valid for next minor merge. 
eval insert into test_select_8_bytes_column_for_flat_format_block (c0, c1, c2, c3, c4) values (2000, 'k$value', 0, 'k', 101);

connection conn0;
--disable_warnings
alter system minor freeze;
--source mysql_test/include/wait_minor_merge.inc
--enable_warnings

connection conn1;
select c0,c3,c4 from test_select_8_bytes_column_for_flat_format_block where c2 >= 0;

connection conn0;
--disable_warnings
alter system major freeze;
--source mysql_test/include/wait_daily_merge.inc
--enable_warnings

connection conn1;
select c0,c3,c4 from test_select_8_bytes_column_for_flat_format_block where c2 >= 0;
select c0,c3,c4 from test_select_8_bytes_column_for_flat_format_block where c2 >= 0; 

drop table test_select_8_bytes_column_for_flat_format_block;
