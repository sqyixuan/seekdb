--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: jim.wjh
#owner group: sql2
#tags: dml, optimizer

--source mysql_test/include/select_into_outfile/get_host_ip.inc
let $DATA_FOLDER_NAME = data_for_mysqltest_select_into_outfile;
--source mysql_test/include/select_into_outfile/mkdir_for_dump.inc 

set names gbk;

--disable_warnings
DROP TABLE IF EXISTS T1;
--enable_warnings

--echo =======================

CREATE TABLE t1(c1 varchar(100) collate utf8mb4_bin, c2 varchar(100) collate gbk_bin);
INSERT INTO t1 VALUES ('测试', '数据');


let $FILE_NAME = temp1;
--source mysql_test/include/select_into_outfile/delete_file.inc 
eval SELECT * INTO OUTFILE  '$DATA_FOLDER_NAME/$FILE_NAME' CHARSET GBK FIELDS TERMINATED BY '列分隔' ENCLOSED BY '"' LINES TERMINATED BY '换行\n' FROM t1;
--source mysql_test/include/select_into_outfile/cat_file.inc 

drop table t1;

--echo =======================

CREATE TABLE t1(c1 binary(10), c2 varbinary(100));
INSERT INTO t1 VALUES (x'1A4F', x'FF1F');


let $FILE_NAME = temp1;
--source mysql_test/include/select_into_outfile/delete_file.inc 
eval SELECT * INTO OUTFILE  '$DATA_FOLDER_NAME/$FILE_NAME' CHARSET GBK FIELDS TERMINATED BY ',' ENCLOSED BY '"' LINES TERMINATED BY '\n' FROM t1;
--source mysql_test/include/select_into_outfile/hexdump_file.inc 

drop table t1;

--echo =======================

CREATE TABLE t1(c1 varchar(1000) charset gbk);
INSERT INTO t1 VALUES (x'AFE5BEB7E59F8EE68A95534350303031');


let $FILE_NAME = temp1;
--source mysql_test/include/select_into_outfile/delete_file.inc 
eval SELECT * INTO OUTFILE  '$DATA_FOLDER_NAME/$FILE_NAME' CHARSET GBK FIELDS TERMINATED BY ',' ENCLOSED BY '"' LINES TERMINATED BY '\n' FROM t1;
--source mysql_test/include/select_into_outfile/hexdump_file.inc 

drop table t1;

