#owner: linyi.cl
#owner group: sql3
#tags: optimizer

--disable_query_log
set ob_query_timeout = 10000000000;

--source mysql_test/include/select_into_outfile/get_host_ip.inc
let $DATA_FOLDER_NAME = select_into_outfile_lob;

--source mysql_test/include/select_into_outfile/delete_dir.inc
--source mysql_test/include/select_into_outfile/mkdir_for_dump.inc

--disable_warnings
drop table if exists t1, big_json_table;
--enable_warnings
--enable_query_log

create table t1(c1 int, c2 varchar(20), c3 text);

--echo ## 小于2MB的lob 文件总大小不超过10MB
insert /*+append enable_parallel_dml parallel(8) */ into t1
select UNIFORM(1, 10000, random(7)), RANDSTR(20, random(7)), repeat(RANDSTR(20, random(7)), 1000) from table(generator(100));

--source mysql_test/include/select_into_outfile/delete_files.inc
eval select * from t1 into outfile '$DATA_FOLDER_NAME/data1';
--source mysql_test/include/select_into_outfile/list_dir.inc

--source mysql_test/include/select_into_outfile/delete_files.inc
eval select * from t1 into outfile '$DATA_FOLDER_NAME/data1' single=false max_file_size=1000000;
--source mysql_test/include/select_into_outfile/list_dir.inc

--echo ## 小于2MB的lob 文件总大小超过10MB
insert /*+append enable_parallel_dml parallel(40) */ into t1
select UNIFORM(1, 10000, random(7)), RANDSTR(20, random(7)), repeat(RANDSTR(20, random(7)), 1000) from table(generator(1000));

--source mysql_test/include/select_into_outfile/delete_files.inc
eval select * from t1 into outfile '$DATA_FOLDER_NAME/data1';
--source mysql_test/include/select_into_outfile/list_dir.inc

--source mysql_test/include/select_into_outfile/delete_files.inc
eval select * from t1 into outfile '$DATA_FOLDER_NAME/data1' single=false max_file_size=2100000;
--source mysql_test/include/select_into_outfile/list_dir.inc

--source mysql_test/include/select_into_outfile/delete_files.inc
eval select /*+parallel(5)*/ * from t1 into outfile '$DATA_FOLDER_NAME/data1' single=false max_file_size=2100000;
--source mysql_test/include/select_into_outfile/list_dir.inc

--echo ## 小于2MB的lob 文件总大小超过256MB
insert /*+append enable_parallel_dml parallel(40) */ into t1
select UNIFORM(1, 10000, random(7)), RANDSTR(20, random(7)), repeat(RANDSTR(20, random(7)), 1000) from table(generator(13000));

--source mysql_test/include/select_into_outfile/delete_files.inc
eval select * from t1 into outfile '$DATA_FOLDER_NAME/data1';
--source mysql_test/include/select_into_outfile/list_dir.inc

--source mysql_test/include/select_into_outfile/delete_files.inc
eval select * from t1 into outfile '$DATA_FOLDER_NAME/data1' single=false;
--source mysql_test/include/select_into_outfile/list_dir.inc

--source mysql_test/include/select_into_outfile/delete_files.inc
eval select /*+parallel(5)*/ * from t1 into outfile '$DATA_FOLDER_NAME/data1' single=false;
--source mysql_test/include/select_into_outfile/list_dir.inc

drop table t1;
create table t1(c1 int, c2 varchar(20), c3 longtext);

--echo ## 超过2MB的lob 文件总大小不超过10MB
insert /*+append enable_parallel_dml parallel(8) */ into t1
select UNIFORM(1, 10000, random(7)), RANDSTR(10, random(7)), repeat(RANDSTR(2200, random(7)), 1000) from table(generator(3));

--source mysql_test/include/select_into_outfile/delete_files.inc
eval select * from t1 into outfile '$DATA_FOLDER_NAME/data1';
--source mysql_test/include/select_into_outfile/list_dir.inc

--source mysql_test/include/select_into_outfile/delete_files.inc
eval select * from t1 into outfile '$DATA_FOLDER_NAME/data1' single=false max_file_size=2000000;
--source mysql_test/include/select_into_outfile/list_dir.inc

--echo ## 超过2MB的lob 文件总大小超过10MB
insert /*+append enable_parallel_dml parallel(8) */ into t1
select UNIFORM(1, 10000, random(7)), RANDSTR(10, random(7)), repeat(RANDSTR(2200, random(7)), 1000) from table(generator(10));

--source mysql_test/include/select_into_outfile/delete_files.inc
eval select * from t1 into outfile '$DATA_FOLDER_NAME/data1';
--source mysql_test/include/select_into_outfile/list_dir.inc

--source mysql_test/include/select_into_outfile/delete_files.inc
eval select * from t1 into outfile '$DATA_FOLDER_NAME/data1' single=false max_file_size=2000000;
--source mysql_test/include/select_into_outfile/list_dir.inc

--source mysql_test/include/select_into_outfile/delete_files.inc
eval select /*+parallel(5)*/ * from t1 into outfile '$DATA_FOLDER_NAME/data1' single=false max_file_size=2000000;
--source mysql_test/include/select_into_outfile/list_dir.inc

--echo ## 超过2MB的lob 文件总大小超过256MB
insert /*+append enable_parallel_dml parallel(4) */ into t1
select UNIFORM(1, 10000, random(7)), RANDSTR(10, random(7)), repeat(RANDSTR(2200, random(7)), 1000) from table(generator(200));

--source mysql_test/include/select_into_outfile/delete_files.inc
eval select * from t1 into outfile '$DATA_FOLDER_NAME/data1' single=false;
--source mysql_test/include/select_into_outfile/list_dir.inc

--source mysql_test/include/select_into_outfile/delete_files.inc
eval select /*+parallel(5)*/ * from t1 into outfile '$DATA_FOLDER_NAME/data1' single=false max_file_size=32000000;
--source mysql_test/include/select_into_outfile/list_dir.inc

# 
## 大于2MB的json
CREATE TABLE big_json_table (
    id INT AUTO_INCREMENT PRIMARY KEY,
    big_json JSON
);
SET @big_json = JSON_OBJECT('key1', REPEAT('This is a long text', 262144));
INSERT INTO big_json_table (big_json) VALUES (@big_json),(@big_json);

--source mysql_test/include/select_into_outfile/delete_files.inc
eval select * from big_json_table into outfile '$DATA_FOLDER_NAME/data1' single=false;
--source mysql_test/include/select_into_outfile/list_dir.inc

--source mysql_test/include/select_into_outfile/delete_files.inc
eval select /*+parallel(2)*/ * from big_json_table into outfile '$DATA_FOLDER_NAME/data1' single=false;
--source mysql_test/include/select_into_outfile/list_dir.inc

--source mysql_test/include/select_into_outfile/delete_dir.inc
drop table t1,big_json_table;
