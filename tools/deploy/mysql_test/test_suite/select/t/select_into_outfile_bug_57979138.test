#owner: linyi.cl
#owner group: sql3
#tags: optimizer

--source mysql_test/include/select_into_outfile/get_host_ip.inc
let $DATA_FOLDER_NAME = select_into_plan_cache;

--source mysql_test/include/select_into_outfile/delete_dir.inc
--source mysql_test/include/select_into_outfile/mkdir_for_dump.inc

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1(c1 int);

alter system flush plan cache global;
--source mysql_test/include/select_into_outfile/delete_files.inc
eval select * from t1 into outfile '$DATA_FOLDER_NAME/data1' single=false;
--source mysql_test/include/select_into_outfile/delete_files.inc
eval select * from t1 into outfile '$DATA_FOLDER_NAME/data1' single=false;

--source mysql_test/include/select_into_outfile/delete_files.inc
eval select * from t1 into outfile '$DATA_FOLDER_NAME/data1' single=true;
--source mysql_test/include/select_into_outfile/delete_files.inc
eval select * from t1 into outfile '$DATA_FOLDER_NAME/data1' single=true;
select hit_count, query_sql, statement, sql_id from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where sql_id='25FD07E89293D81FA1F5FFC6A8920FC8';
select hit_count, query_sql, statement, sql_id from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where sql_id='EBC95C5994C7E5F0D2AF2916F84C85E5';


--source mysql_test/include/select_into_outfile/delete_dir.inc
drop table t1;
