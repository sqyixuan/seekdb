# owner: dengzhi.ldz 
# owner group: storage
# description: for point select with different block format 

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

set GLOBAL ob_query_timeout = 1000000000000;
set GLOBAL ob_trx_timeout = 1000000000000;
set GLOBAL ob_trx_idle_timeout = 10000000000;

connect (conn2,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn0,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,oceanbase,$OBMYSQL_PORT);

connection conn0;
alter system set minor_compact_trigger = 10;

# point select in one sstable(flat format) with all rows committed.
connection conn1;
--disable_warnings
drop table if exists test_point_select_for_block_format;
--enable_warnings
create table test_point_select_for_block_format(c1 varchar(100) primary key, c2 int);

connection conn1;
insert into test_point_select_for_block_format values ('0',0);
insert into test_point_select_for_block_format values ('1',1);
insert into test_point_select_for_block_format values ('2',2);
insert into test_point_select_for_block_format values ('3',3);
insert into test_point_select_for_block_format values ('4',4);
insert into test_point_select_for_block_format values ('5',5);
insert into test_point_select_for_block_format values ('6',6);
insert into test_point_select_for_block_format values ('7',7);
insert into test_point_select_for_block_format values ('8',8);
insert into test_point_select_for_block_format values ('9',9);
insert into test_point_select_for_block_format values ('10',10);
insert into test_point_select_for_block_format values ('11',11);
insert into test_point_select_for_block_format values ('12',12);
insert into test_point_select_for_block_format values ('13','13');
insert into test_point_select_for_block_format values ('14','14');
insert into test_point_select_for_block_format values ('15',15);
insert into test_point_select_for_block_format values ('16',16);

connection conn0;
alter system minor freeze;
--source mysql_test/include/wait_minor_merge.inc

connection conn1;
select * from test_point_select_for_block_format where c1 = '0';
select * from test_point_select_for_block_format where c1 = '1';
select * from test_point_select_for_block_format where c1 = '2';
select * from test_point_select_for_block_format where c1 = '3';
select * from test_point_select_for_block_format where c1 = '4';
select * from test_point_select_for_block_format where c1 = '5';
select * from test_point_select_for_block_format where c1 = '6';
select * from test_point_select_for_block_format where c1 = '7';
select * from test_point_select_for_block_format where c1 = '8';
select * from test_point_select_for_block_format where c1 = '9';
select * from test_point_select_for_block_format where c1 = '10';
select * from test_point_select_for_block_format where c1 = '11';
select * from test_point_select_for_block_format where c1 = '12';
select * from test_point_select_for_block_format where c1 = '13';
select * from test_point_select_for_block_format where c1 = '14';
select * from test_point_select_for_block_format where c1 = '15';
select * from test_point_select_for_block_format where c1 = '16';

# point select in one sstable(flat format) with rows uncommitted and multi-version.
connection conn1;
--disable_warnings
drop table if exists test_point_select_for_block_format;
--enable_warnings
create table test_point_select_for_block_format(c1 varchar(100) primary key, c2 int);
insert into test_point_select_for_block_format values ('0',0);
insert into test_point_select_for_block_format values ('1',1);
insert into test_point_select_for_block_format values ('2',2);
insert into test_point_select_for_block_format values ('3',3);
insert into test_point_select_for_block_format values ('4',4);
insert into test_point_select_for_block_format values ('5',5);
insert into test_point_select_for_block_format values ('6',6);
insert into test_point_select_for_block_format values ('7',7);
insert into test_point_select_for_block_format values ('8',8);
insert into test_point_select_for_block_format values ('9',9);
insert into test_point_select_for_block_format values ('10',10);
insert into test_point_select_for_block_format values ('11',11);
insert into test_point_select_for_block_format values ('12',12);
insert into test_point_select_for_block_format values ('13','13');
insert into test_point_select_for_block_format values ('14','14');
insert into test_point_select_for_block_format values ('15',15);
insert into test_point_select_for_block_format values ('16',16);

connection conn2;
# default isolation level is read committed(select @@tx_isolation);
set session transaction isolation level repeatable read;
begin;
select * from test_point_select_for_block_format where c1 = '6';

connection conn1;
# produce multi-version row
update test_point_select_for_block_format set c2 = -6 where c1 = '6';
update test_point_select_for_block_format set c2 = -1 where c1 = '1';
# produce uncommitted row
begin;
insert into test_point_select_for_block_format values ('17',17);

connection conn0;
alter system minor freeze;
--source mysql_test/include/wait_minor_merge.inc

connection conn1;
commit;
select * from test_point_select_for_block_format where c1 = '0';
