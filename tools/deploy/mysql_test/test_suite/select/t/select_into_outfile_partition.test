#owner: linyi.cl
#owner group: sql3
#tags: optimizer

--source mysql_test/include/oss_config_for_import.inc

let $DATA_FOLDER_NAME = antsys-antsys-oceanbase-rd-sql/linyi.cl/select_into_outfile_partition;

--source mysql_test/include/select_into_outfile/delete_dir_oss.inc
--source mysql_test/include/select_into_outfile/mkdir_for_dump_oss.inc

--disable_warnings
drop table if exists t1;
--enable_warnings

let $FILE_PREFIX = 20;
create table t1(c1 int, c2 double, c3 float, c4 varchar(20), c5 char(20), c6 date, c7 bool, c8 time);
insert into t1 values(1, 1.324, 2.3, 'hhh中zzz', 'hhh国zzz', '2021-08-19', true, '00:00:00');
insert into t1 values(2, 2.325, 3.2, 'hhh中z排zz', 'hhh国z球zz', '2022-08-19', 0, '00:00:40');
insert into t1 values(3, 3.14, 4.2, 'hhh中zzz', 'hhh国zzz', '2023-08-19', 1, '00:03:00');
insert into t1 values(4, 9.001, 5.10, 'hhh中zzz匹配', 'hhh国zzz品牌', '2023-08-19', false, '02:00:00');
insert into t1 values(5, 2.181, 6.7, 'hhh中zziiz', 'hkkhh国zzz', '2021-08-19', TRUE, '00:00:00');
insert into t1 values(6, 1010, 29, 'hhh中zzz6', 'hhh国zz66z', '2023-08-19', FALse, '00:03:00');

--source mysql_test/include/select_into_outfile/delete_files_oss.inc
--source mysql_test/include/select_into_outfile/replace_oss_info.inc
eval select /*+parallel(2)*/* from t1 into outfile 'oss://$DATA_FOLDER_NAME/?host=$OSS_HOST&access_id=$OSS_ACCESS_ID&access_key=$OSS_ACCESS_KEY' partition by cast(c6 as char) single=false;
--source mysql_test/include/select_into_outfile/cat_dir_oss.inc

--source mysql_test/include/select_into_outfile/delete_files_oss.inc
--source mysql_test/include/select_into_outfile/replace_oss_info.inc
eval select /*+parallel(2)*/* from t1 into outfile 'oss://$DATA_FOLDER_NAME/?host=$OSS_HOST&access_id=$OSS_ACCESS_ID&access_key=$OSS_ACCESS_KEY' partition by cast(c6 as char) charset gbk single=false;
--source mysql_test/include/select_into_outfile/cat_dir_oss.inc

--source mysql_test/include/select_into_outfile/delete_files_oss.inc
--source mysql_test/include/select_into_outfile/replace_oss_info.inc
eval select /*+parallel(2)*/* from t1 into outfile 'oss://$DATA_FOLDER_NAME/?host=$OSS_HOST&access_id=$OSS_ACCESS_ID&access_key=$OSS_ACCESS_KEY' partition by concat(cast(c6 as char), '/', cast(c8 as char)) single=false;
--source mysql_test/include/select_into_outfile/cat_dir_oss.inc

--source mysql_test/include/select_into_outfile/delete_files_oss.inc
--source mysql_test/include/select_into_outfile/replace_oss_info.inc
eval select /*+parallel(3)*/* from t1 into outfile 'oss://$DATA_FOLDER_NAME/?host=$OSS_HOST&access_id=$OSS_ACCESS_ID&access_key=$OSS_ACCESS_KEY' partition by '2024-6-13' single=false;
--source mysql_test/include/select_into_outfile/cat_dir_oss.inc

--echo # 执行计划
--echo # single=true / parallel=1 / has limit / has order by and partition by expr is not const expr
--echo # local
explain select /*+parallel(2)*/* from t1 into outfile 'data1' single=true;
explain select * from t1 into outfile 'data1' single=false;
explain select /*+parallel(2)*/* from t1 order by c1 limit 2 into outfile 'data1' single=false;
explain select /*+parallel(2)*/* from t1 order by c1 into outfile 'data1' partition by c4 single=false;

--echo # single=false, has order by without limit, partition expr is null or const expr
--echo # range
explain select /*+parallel(2)*/* from t1 order by c1 into outfile 'data1' single=false;
explain select /*+parallel(2)*/* from t1 order by c1 into outfile 'data1' partition by 'a' single=false;

--echo # single=false, no order by, partition by expr is not const expr
--echo # hash
explain select /*+parallel(2)*/c1,c2 from t1 into outfile 'data1' partition by c4 single=false;
explain select /*+parallel(2)*/* from (select * from t1)v into outfile 'data' partition by v.c4 single=false;

--echo # single=false, no order by, partition expr is null or const expr
--echo # random
explain select /*+parallel(2)*/c1,c2 from t1 into outfile 'data1' single=false;
explain select /*+parallel(2)*/c1,c2 from t1 into outfile 'data1' partition by 'c' single=false;

--echo # 按分区导出只支持导出到oss且single=false, partition by expr的结果类型必须是字符串
--error 1235
select /*+parallel(2)*/* from t1 into outfile 'data1' partition by c6;
--error 1235
select /*+parallel(2)*/* from t1 into outfile 'data1' partition by cast(c6 as char);
--error 1235
select /*+parallel(2)*/* from t1 into outfile 'data1' partition by cast(c6 as char) single = true;
--error 1235
select /*+parallel(2)*/* from t1 into outfile 'data1' partition by cast(c6 as char) single = false;

set ob_query_timeout = 10000000000;

# nolob
drop table t1;
create table t1(c1 int, c2 varchar(200), c3 year, c4 time);
insert /*+append enable_parallel_dml parallel(8) */ into t1
select UNIFORM(1, 100, random(7)), RANDSTR(200, random(7)), UNIFORM(2020, 2025, random(7)), concat(cast(UNIFORM(10, 12, random(7)) as char),':00:00') from table(generator(10000));

--sorted_result
select distinct concat(cast(c3 as char), '/', cast(c4 as char)) from t1;

--source mysql_test/include/select_into_outfile/delete_files_oss.inc
--source mysql_test/include/select_into_outfile/replace_oss_info.inc
eval select /*+parallel(5)*/* from t1 into outfile 'oss://$DATA_FOLDER_NAME/?host=$OSS_HOST&access_id=$OSS_ACCESS_ID&access_key=$OSS_ACCESS_KEY' partition by cast(c3 as char) single=false;
--source mysql_test/include/select_into_outfile/list_dir_oss.inc

--source mysql_test/include/select_into_outfile/delete_files_oss.inc
--source mysql_test/include/select_into_outfile/replace_oss_info.inc
eval select /*+parallel(5)*/* from t1 into outfile 'oss://$DATA_FOLDER_NAME/?host=$OSS_HOST&access_id=$OSS_ACCESS_ID&access_key=$OSS_ACCESS_KEY' partition by concat(cast(c3 as char), '/', cast(c4 as char)) single=false;
--source mysql_test/include/select_into_outfile/list_dir_oss.inc

--source mysql_test/include/select_into_outfile/delete_files_oss.inc
--source mysql_test/include/select_into_outfile/replace_oss_info.inc
eval select /*+parallel(5)*/* from t1 into outfile 'oss://$DATA_FOLDER_NAME/?host=$OSS_HOST&access_id=$OSS_ACCESS_ID&access_key=$OSS_ACCESS_KEY' partition by '2026' single=false;
--source mysql_test/include/select_into_outfile/list_dir_oss.inc

--source mysql_test/include/select_into_outfile/delete_files_oss.inc
--source mysql_test/include/select_into_outfile/replace_oss_info.inc
eval select /*+parallel(5)*/* from t1 into outfile 'oss://$DATA_FOLDER_NAME/test?host=$OSS_HOST&access_id=$OSS_ACCESS_ID&access_key=$OSS_ACCESS_KEY' partition by '2026' single=false max_file_size=200000;
--source mysql_test/include/select_into_outfile/list_dir_oss.inc

insert /*+append enable_parallel_dml parallel(8) */ into t1
select UNIFORM(1, 100, random(7)), RANDSTR(200, random(7)), UNIFORM(2020, 2025, random(7)), concat(cast(UNIFORM(13, 24, random(7)) as char),':00:00') from table(generator(10000));

--sorted_result
select distinct concat(cast(c3 as char), '/', cast(c4 as char)) from t1;

--source mysql_test/include/select_into_outfile/delete_files_oss.inc
--source mysql_test/include/select_into_outfile/replace_oss_info.inc
eval select /*+parallel(5)*/* from t1 into outfile 'oss://$DATA_FOLDER_NAME/?host=$OSS_HOST&access_id=$OSS_ACCESS_ID&access_key=$OSS_ACCESS_KEY' partition by concat(cast(c3 as char), '/', cast(c4 as char)) single=false;
--source mysql_test/include/select_into_outfile/list_dir_oss.inc

# lob
drop table t1;
create table t1(c1 int, c2 varchar(20), c3 text);

--echo ## 小于2MB的lob 文件总大小不超过10MB
insert /*+append enable_parallel_dml parallel(8) */ into t1
select UNIFORM(1, 10, random(7)), concat('20', RANDSTR(1, random(7))), repeat(RANDSTR(20, random(7)), 1000) from table(generator(100));

--source mysql_test/include/select_into_outfile/delete_files_oss.inc
--source mysql_test/include/select_into_outfile/replace_oss_info.inc
eval select /*+parallel(5)*/* from t1 into outfile 'oss://$DATA_FOLDER_NAME/?host=$OSS_HOST&access_id=$OSS_ACCESS_ID&access_key=$OSS_ACCESS_KEY' partition by c2 single=false;
--source mysql_test/include/select_into_outfile/list_dir_oss.inc

--echo ## 小于2MB的lob 文件总大小超过10MB
insert /*+append enable_parallel_dml parallel(40) */ into t1
select UNIFORM(1, 10, random(7)), concat('20', RANDSTR(1, random(7))), repeat(RANDSTR(20, random(7)), 1000) from table(generator(1000));

--source mysql_test/include/select_into_outfile/delete_files_oss.inc
--source mysql_test/include/select_into_outfile/replace_oss_info.inc
eval select /*+parallel(5)*/* from t1 into outfile 'oss://$DATA_FOLDER_NAME/?host=$OSS_HOST&access_id=$OSS_ACCESS_ID&access_key=$OSS_ACCESS_KEY' partition by c2 single=false;
--source mysql_test/include/select_into_outfile/list_dir_oss.inc

drop table t1;
create table t1(c1 int, c2 varchar(20), c3 longtext);

--echo ## 超过2MB的lob 文件总大小不超过10MB
insert /*+append enable_parallel_dml parallel(8) */ into t1
select UNIFORM(201, 204, random(7)), concat('20', RANDSTR(1, random(7))), repeat(RANDSTR(2200, random(7)), 1000) from table(generator(3));

select count(distinct c2) from t1;

--source mysql_test/include/select_into_outfile/delete_files_oss.inc
--source mysql_test/include/select_into_outfile/replace_oss_info.inc
eval select /*+parallel(3)*/* from t1 into outfile 'oss://$DATA_FOLDER_NAME/?host=$OSS_HOST&access_id=$OSS_ACCESS_ID&access_key=$OSS_ACCESS_KEY' partition by c2 single=false;
--source mysql_test/include/select_into_outfile/list_dir_oss.inc

--echo ## 超过2MB的lob 文件总大小超过10MB
insert /*+append enable_parallel_dml parallel(8) */ into t1
select UNIFORM(201, 204, random(7)), concat('20', RANDSTR(1, random(7))), repeat(RANDSTR(2200, random(7)), 1000) from table(generator(10));

select count(distinct c2), count(distinct c1) from t1;

--source mysql_test/include/select_into_outfile/delete_files_oss.inc
--source mysql_test/include/select_into_outfile/replace_oss_info.inc
eval select /*+parallel(3)*/* from t1 into outfile 'oss://$DATA_FOLDER_NAME/?host=$OSS_HOST&access_id=$OSS_ACCESS_ID&access_key=$OSS_ACCESS_KEY' partition by c2 single=false;
--source mysql_test/include/select_into_outfile/list_dir_oss.inc

--source mysql_test/include/select_into_outfile/delete_files_oss.inc
--source mysql_test/include/select_into_outfile/replace_oss_info.inc
eval select /*+parallel(3)*/* from t1 into outfile 'oss://$DATA_FOLDER_NAME/?host=$OSS_HOST&access_id=$OSS_ACCESS_ID&access_key=$OSS_ACCESS_KEY' partition by c2 single=false max_file_size='2MB';
--source mysql_test/include/select_into_outfile/list_dir_oss.inc

--source mysql_test/include/select_into_outfile/delete_files_oss.inc
--source mysql_test/include/select_into_outfile/replace_oss_info.inc
eval select /*+parallel(3)*/* from t1 into outfile 'oss://$DATA_FOLDER_NAME/?host=$OSS_HOST&access_id=$OSS_ACCESS_ID&access_key=$OSS_ACCESS_KEY' partition by cast(c1 as char) single=false;
--source mysql_test/include/select_into_outfile/list_dir_oss.inc

--source mysql_test/include/select_into_outfile/delete_files_oss.inc
--source mysql_test/include/select_into_outfile/replace_oss_info.inc
eval select /*+parallel(3)*/* from t1 into outfile 'oss://$DATA_FOLDER_NAME/?host=$OSS_HOST&access_id=$OSS_ACCESS_ID&access_key=$OSS_ACCESS_KEY' partition by cast(c1 as char) single=false max_file_size='5MB';
--source mysql_test/include/select_into_outfile/list_dir_oss.inc


drop table t1;
--source mysql_test/include/select_into_outfile/delete_dir_oss.inc
