## test select temporal type into variables
--disable_warnings
drop table if exists t;
--enable_warnings
create table t(c1 int, c2 varchar(100), c3 number, c4 timestamp, c5 time, c6 datetime, c7 year, c9 text);
insert into t values(1, '2', 3, '2020-01-01 12:34:56', '10:10:10', '2020-01-01 12:34:56', 20, '9');
select * from t into @c1, @c2,  @c3, @c4, @c5, @c6, @c7, @c8;
select @c1, @c2,  @c3, @c4, @c5, @c6, @c7, @c8 from dual;
drop table t;

