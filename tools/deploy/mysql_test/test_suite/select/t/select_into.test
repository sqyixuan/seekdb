##bugfix: 
--disable_warnings
drop table if exists t1;
create table t1(v1 int);
insert into t1 values(1),(2),(3);
alter system set _rowsets_enabled = false;
--sleep 3
explain select sum(cnt)*1234 into @hi from (select count(1) as cnt from t1);
select sum(cnt)*1234 into @hi from (select count(1) as cnt from t1);
select @hi from dual;
select sum(cnt)*1234 into @hi from (select count(1) as cnt from t1 union all select count(1) as cnt from t1);

alter system set _rowsets_enabled = true;
--sleep 3
explain select sum(cnt)*1234 into @hi from (select count(1) as cnt from t1);
select sum(cnt)*1234 into @hi from (select count(1) as cnt from t1);
select @hi from dual;
select sum(cnt)*1234 into @hi from (select count(1) as cnt from t1 union all select count(1) as cnt from t1);
select @hi from dual;
explain select /*+parallel(2)*/ count(*) into @hi from t1;
select /*+parallel(2)*/ count(*) into @hi from t1;
select @hi from dual;
drop table t1;

