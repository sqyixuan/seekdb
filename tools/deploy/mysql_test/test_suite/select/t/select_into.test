--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: jim.wjh
#owner group: sql2
#tags: select into, optimizer


# TEST 1 select into var

select 2 into @a;
select @a;

select count(1) into @b;
select @b;

select 10 into @c from dual;
select @c;

--disable_warnings
drop view if exists v_select_into;
drop table if exists t_select_into;
drop table if exists t_select_into2;
drop table if exists t_select_into3;
drop table if exists t_select_into4;
drop table if exists t_select_into5;
drop table if exists t_select_into6;
--enable_warnings

create table t_select_into(c1 int);
insert into t_select_into values(1), (2), (3), (4), (5);

select count(c1) from t_select_into into @c;
select count(c1) from t_select_into;
select @c;

select @c + avg(c1) from t_select_into into @d;
select count(c1) + avg(c1) from t_select_into;
select @d;

select @c + sum(c1) into @e from t_select_into;
select count(c1) + sum(c1) from t_select_into;
select @e;

select 4 + count(c1) from t_select_into union all select 1 from dual where false into @f;
select 4 + count(c1) from t_select_into union all select 1 from dual where false;
select @f;

select 1, 2, 3 into @a, @b, @c;
select @a, @b, @c;

select 4, 5, 6 into @a, @b, @c from dual;
select @a, @b, @c;

select * from t_select_into where c1 < 3 limit 1 into @e;
select @e;

select * into @h from t_select_into where c1 < 3 limit 1;
select @h;

select * from t_select_into order by c1 desc limit 1 into @g;
select @g;

--echo # 验证经过优化器改写后select into仍然生效 
create view v_select_into as select * from t_select_into order by c1;
select * into @i from v_select_into limit 2,1;
select @i;
--exec ssh $OBMYSQL_MS0 'rm -rf $OBSERVER_DIR/view.outfile'
--disable_query_log
eval select * into outfile '$OBSERVER_DIR/view.outfile' from v_select_into;
--replace_regex /.*view.outfile/view.outfile/g 
--exec ssh $OBMYSQL_MS0 'ls $OBSERVER_DIR/view.outfile'
--exec ssh $OBMYSQL_MS0 'rm -rf $OBSERVER_DIR/view.outfile'
--enable_query_log

--error 1222
select 1, 2 into @a;

--error 1172
select * from t_select_into into @a;

drop view v_select_into;
drop table t_select_into; 

--error 5617
select 1 into @a union all select 2 from dual where false;
--error 5617
select 1 into @a from dual union all select 2 from dual where false;

# TEST 2 select into outfile


# TEST 2 select into outfile

CREATE TABLE t_select_into2 (
  `SYSCD` varchar(4) NOT NULL,
  `SVCTMTYP` varchar(4) NOT NULL,
  `CURTRFTABNM` varchar(1) NOT NULL,
  `BIZDT` varchar(8) NOT NULL,
  `STARTTM` varchar(19) DEFAULT NULL,
  `ENDTM` varchar(19) DEFAULT NULL,
  `LSTWRKDT` varchar(8) NOT NULL,
  `NXTWRKDT` varchar(8) NOT NULL,
  `SYSSTS` varchar(4) NOT NULL,
  `HOLIDAYFLG` varchar(4) NOT NULL,
  `LSTBIZDT` varchar(8) NOT NULL,
  `NCSSYSSTS` varchar(4) NOT NULL,
  `NCS1FLG` varchar(1) NOT NULL,
  `ADDINFO` varchar(128) DEFAULT NULL,
  `LSTSYSTS` varchar(4) DEFAULT NULL,
  `CURSELDT` varchar(8) DEFAULT NULL,
  `DAYFNLSTS` varchar(1) DEFAULT NULL,
  `CURCLRTAB` varchar(2) NOT NULL DEFAULT 'A',
  `CURCLRBAT` varchar(4) NOT NULL DEFAULT '1',
  `LSTCLRTAB` varchar(2) NOT NULL DEFAULT 'A',
  `LSTCLRBAT` varchar(4) NOT NULL DEFAULT '1',
  `CIRCLETAB` varchar(6) NOT NULL DEFAULT 'A|F',
  `TOTLEBATS` varchar(4) NOT NULL DEFAULT '5',
  `SWITCHSTS` varchar(2) NOT NULL DEFAULT '00',
  `OPRTIME` varchar(19) DEFAULT NULL,
  `CTRLFLAG` varchar(1) NOT NULL DEFAULT 'N',
  UNIQUE KEY `IDX_NPSMSYSTST` (`SVCTMTYP`, `SYSCD`) 
);

insert into t_select_into2 values ('NPS', 'ST24', 'A', '20200131', '2018-09-19T14:41:20', '2018-09-19T11:07:27', '20200130', '', 'ST02', '2', '20200130', 'N', '0', '', 'ST02', '20200130', '0', 'A', '1', 'E', '42', 'A|F', '10', '00', '2018-09-19 14:36:54', 'Y');

--exec ssh $OBMYSQL_MS0 'rm -rf $OBSERVER_DIR/jianhua*.outfile'

--disable_query_log
eval select * from t_select_into2 into outfile '$OBSERVER_DIR//jianhua1.outfile' fields terminated by ',' lines terminated by '\n';
eval select * from t_select_into2 into outfile '$OBSERVER_DIR//jianhua2.outfile' fields terminated by ',' lines terminated by '\n';
eval select * from t_select_into2 into outfile '$OBSERVER_DIR//jianhua3.outfile' fields terminated by ',' lines terminated by '\n';
eval select * from t_select_into2 into outfile '$OBSERVER_DIR//jianhua4.outfile' fields enclosed by '"';
eval select * from t_select_into2 into outfile '$OBSERVER_DIR//jianhua5.outfile' fields optionally enclosed by '"';

--replace_regex / .*jianhua/ jianhua/g 
--exec ssh $OBMYSQL_MS0 'md5sum $OBSERVER_DIR/jianhua*.outfile'
--exec ssh $OBMYSQL_MS0 'cat $OBSERVER_DIR/jianhua*.outfile'
--exec ssh $OBMYSQL_MS0 'rm -rf $OBSERVER_DIR/jianhua*.outfile'
--enable_query_log

drop table t_select_into2;

--echo # show plan for select into outfile
--echo # verify the expr is pushed down to the child operator
create table t_select_into3(c1 int, c2 int);
create table t_select_into4(d1 int, d2 int);
insert into t_select_into3 values (5,6), (1,2), (3,4);
insert into t_select_into4 values (1,2), (3,4);
--exec ssh $OBMYSQL_MS0 'rm -f $OBSERVER_DIR/px_*.outfile'
--explain_protocol 1
--disable_query_log
--echo ## non px plan
eval select * into outfile '$OBSERVER_DIR/px_non.outfile' fields terminated by ',' enclosed by '"' lines terminated by '\n' from t_select_into3;
--echo ## child operator is table scan
eval select /*+parallel(4)*/ * into outfile '$OBSERVER_DIR/px_tablescan.outfile' from t_select_into3;
--echo ## child operator is limit
eval select /*+parallel(4)*/ * into outfile '$OBSERVER_DIR/px_limit.outfile' from t_select_into3 limit 2;
--echo ## child operator is group by
eval select /*+parallel(4)*/ sum(c1), c2 into outfile '$OBSERVER_DIR/px_groupby.outfile' from t_select_into3 group by c2;
--echo ## child operator is sort
eval select /*+parallel(4)*/ * into outfile '$OBSERVER_DIR/px_sort.outfile' from t_select_into3 order by c1;
--echo ## child operator is join
eval select /*+parallel(4)*/ c1, d2 into outfile '$OBSERVER_DIR/px_join.outfile' from t_select_into3, t_select_into4 where c1 = d1;
--echo ## child operator is distinct
eval select /*+parallel(4)*/ distinct * into outfile '$OBSERVER_DIR/px_distince.outfile' from t_select_into3 order by c1;
--enable_query_log
--explain_protocol 0
--replace_regex /.*px_/px_/g 
--exec ssh $OBMYSQL_MS0 'ls $OBSERVER_DIR/px_*.outfile | sed -E "s/(.+)/echo \1 \&\& sort \1/g" | sh -'
--exec ssh $OBMYSQL_MS0 'rm -f $OBSERVER_DIR/px_*.outfile'

drop table t_select_into3;
drop table t_select_into4;

--echo # test fields escaped by option
create table t_select_into5(id int, c1 varchar(100), c2 varchar(100));
insert into t_select_into5 values(1, "a,b,c", "a,b,c");
insert into t_select_into5 values(2, "a\"b\"c", "a\"b\"c");
insert into t_select_into5 values(3, "a\nb\nc", "a\nb\nc");
insert into t_select_into5 values(4, null, null);
insert into t_select_into5 values(5, "a\0b\0c", "a\0b\0c");
insert into t_select_into5 values(6, "a\\b\\c", "a\\b\\c");
insert into t_select_into5 values(7, "a\tbc", "a\tbc");

--disable_query_log
--exec ssh $OBMYSQL_MS0 'rm -f $OBSERVER_DIR/with_escaped*.outfile'
--echo # fields escaped by ''
eval select * into outfile '$OBSERVER_DIR/with_escaped_1.outfile' fields escaped by '' from t_select_into5;
--exec ssh $OBMYSQL_MS0 'cat $OBSERVER_DIR/with_escaped_1.outfile'
--echo # fields escaped by '\\'
eval select * into outfile '$OBSERVER_DIR/with_escaped_2.outfile' fields escaped by '\\\\' from t_select_into5;
--exec ssh $OBMYSQL_MS0 'cat $OBSERVER_DIR/with_escaped_2.outfile'
--echo # fields terminated by ",b" enclosed by '"' escaped by '\\'
eval select * into outfile '$OBSERVER_DIR/with_escaped_3.outfile' fields terminated by ",b" enclosed by '"' escaped by '\\\\' from t_select_into5;
--exec ssh $OBMYSQL_MS0 'cat $OBSERVER_DIR/with_escaped_3.outfile'
--echo # fields escaped by 'b'
eval select * into outfile '$OBSERVER_DIR/with_escaped_4.outfile' fields escaped by 'b' from t_select_into5;
--exec ssh $OBMYSQL_MS0 'cat $OBSERVER_DIR/with_escaped_4.outfile'
--replace_regex / .*with_escaped/ with_escaped/g
--exec ssh $OBMYSQL_MS0 'md5sum $OBSERVER_DIR/with_escaped*.outfile'
--exec ssh $OBMYSQL_MS0 'rm -f $OBSERVER_DIR/with_escaped*.outfile'
--enable_query_log
drop table t_select_into5;

--echo # test gbk-encoding
create table t_select_into6(id int, c1 varchar(100), c2 varchar(100) character set gbk);
insert into t_select_into6 values(1, "a好b好c", "a好b好c");
insert into t_select_into6 values(2, "錦田", "錦田");
insert into t_select_into6 values(3, "a\0b\0c", "a\0b\0c");
--disable_query_log
--exec ssh $OBMYSQL_MS0 'rm -f $OBSERVER_DIR/gbk*.outfile'
eval select * into outfile '$OBSERVER_DIR/gbk_1.outfile' fields escaped by '\\\\' from t_select_into6;
--exec ssh $OBMYSQL_MS0 'cat $OBSERVER_DIR/gbk_1.outfile'
set character_set_results = gbk;
eval select * into outfile '$OBSERVER_DIR/gbk_2.outfile' fields escaped by '\\\\' from t_select_into6;
--exec ssh $OBMYSQL_MS0 'xxd $OBSERVER_DIR/gbk_2.outfile'
set character_set_results = utf8mb4;
--exec ssh $OBMYSQL_MS0 'rm -f $OBSERVER_DIR/gbk_*.outfile'
--enable_query_log
drop table t_select_into6;

