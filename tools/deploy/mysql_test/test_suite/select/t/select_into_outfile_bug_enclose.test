#owner: linyi.cl
#owner group: sql3
#tags: external table


--source mysql_test/include/select_into_outfile/get_host_ip.inc
let $DATA_FOLDER_NAME = data_for_mysqltest_select_into_outfile_enclose;

--source mysql_test/include/select_into_outfile/delete_dir.inc
--source mysql_test/include/select_into_outfile/mkdir_for_dump.inc

--disable_warnings
drop table if exists t1;
--enable_warnings
--result_format 4

CREATE TABLE t1(c18 datetime,c19 timestamp,c20 date,c21 time,c22 year,c23 char,c24 varchar(50),
c25 binary,c26 varbinary(50),c27 TINYBLOB,c28 BLOB,c29 MEDIUMBLOB,c30 LONGBLOB,c31 TINYTEXT,c32 TEXT,
c33 MEDIUMTEXT,c34 LONGTEXT,c35 ENUM('','a','1','中') CHARACTER SET utf16 ,
c36 set('a', '1','','中') CHARACTER SET utf16,c37 json);

INSERT INTO t1 VALUES
('2021-10-29 12:00:00', '2021-10-29 12:00:00', '2021-10-29', '12:00:00', 2021, 'a', 'varchar', b'1101001', b'1101001', 'tinyblob', 'blob', 'mediumblob', 'longblob', 'tinytext', 'text', 'mediumtext', 'longtext', 'a', 'a', '{"id": "1", "name": "Fred"}'),
('2021-10-29 12:00:00', '2021-10-29 12:00:00', '2021-10-29', '12:00:00', 2021, 'a', 'varchar', b'1101001', b'1101001', 'tinyblob', 'blob', 'mediumblob', 'longblob', 'tinytext', 'text', 'mediumtext', 'longtext', 'a', 'a', '{}');


--source mysql_test/include/select_into_outfile/delete_files.inc
eval select * from t1 into outfile '$DATA_FOLDER_NAME/data1' FIELDS OPTIONALLY ENCLOSED BY '"';
--source mysql_test/include/select_into_outfile/cat_dir.inc

eval load data infile '$DATA_FOLDER_NAME/data1' into table t1 FIELDS OPTIONALLY ENCLOSED BY '"';
select * from t1;

eval load data infile '$DATA_FOLDER_NAME/data1' into table t1 FIELDS ENCLOSED BY '"';
select * from t1;

--source mysql_test/include/select_into_outfile/delete_dir.inc
drop table t1;
