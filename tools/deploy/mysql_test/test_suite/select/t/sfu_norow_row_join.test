--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: xiaoyi.xy
# owner group: SQL3
# description: OUR GOAL: Make all this simple and effective!
####two session do select 
--disable_query_log
--source mysql_test/include/index_quick_major.inc
sleep 2;
--enable_query_log
--disable_warnings
drop table if exists tbl1,tbl2;
--enable_warnings
create table tbl1 (pk int,i1 int, v2 varchar(80), i3 char(20),i4 float, d4 datetime(6),i5 decimal(5,3),i6 bool, primary key(pk));
####一半静态数据，一半动态数据
insert into tbl1 values(1,1,'abc12','1agc',1.25,'2014-01-01 12:00:00',23.23,1),
                       (2,10,'23abc12','4agc1',-0.25,'2015-11-01 12:00:00',-23.230,0),
                       (3,201,'xx23abc12','cagc1',-2.25,'2015-11-21 11:20:10',3.231,1),
                       (4,80,'zx23abc12','zcagc1',2.25,'2013-01-21 11:20:10',-3.231,1),
                       (5,53,'cx23abc12','rcagc1',109.25,'2016-01-22 11:20:10',-13.131,0);
--source mysql_test/include/majorfreeze.inc
--source mysql_test/include/wait_daily_merge.inc


insert into tbl1 values (6,78,'tx23abc12','icagc1',-109.25,'2014-09-16 16:24:00',-13.531,1),(8,50,'vx23abc12','wcagc1',-85.85,'2014-09-10 16:20:21',93.131,1),(9,610,'ukx23abc12','pecagc1',-1.85,'2014-09-19 16:20:21',99.131,0),(10,42,'kx23abc12','ecagc1',-85.86,'2014-09-18 16:20:21',-99.131,1),(11,null,null,null,null,null,null,null);


connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn2,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);

connection conn1;
set autocommit=0;

connection conn2;
set autocommit=0;
###2个事务，一个事务用锁住many exists rows,and anothor trx lock many rows,都不存在；
connection conn1;
select * from tbl1  where pk>=100 for update; 

connection conn2;
select * from tbl1  where pk>=100 for update; 

connection conn1;
commit;

connection conn2;
commit;
###2个事务，锁住的空行部分交叉,都不存在
connection conn1;
select * from tbl1  where pk>=100 for update; 

connection conn2;
select * from tbl1  where pk>=200 for update; 
select * from tbl1  where pk between 80 and 199 for update; 

connection conn1;
commit;

connection conn2;
commit;

####2个sfu部分交叉，部分不存在；
connection conn1;
select * from tbl1  where pk>=200 or i1 in (1,10,80,100,2000) for update;


connection conn2;
select * from tbl1  where pk>=100 or i1 in (53,100,2000) for update;

connection conn1;
commit;

connection conn2;
commit;

####2个sfu部分无交叉，全部存在；
connection conn1;
select * from tbl1  where pk between 1 and 4 and  i1 in (1,10,80,201,503) for update;

connection conn2;
select * from tbl1  where pk between 5 and 10 and i1 in (78,400,50,610,42) for update;

connection conn1;
commit;
connection conn2;
commit;


####2个sfu部分无交叉，全部不存在；
connection conn1;
select * from tbl1  where pk between 300 and 400 and  i1 in (11,110,180,1201,1503) for update;

connection conn2;
select * from tbl1  where pk between 105 and 210 and i1 in (178,1400,150,1610,142) for update;

connection conn1;
commit;
connection conn2;
commit;


####2个sfu部分无交叉，部分不存在；
connection conn1;
select * from tbl1  where pk between -5 and 5 and  i1 in (-100,-50,1,10,80,201,503) for update;

connection conn2;
select * from tbl1  where pk between 6  and 20 and i1 in (78,400,50,610,42,557,675) for update;

connection conn1;
commit;
connection conn2;
commit;

select * from tbl1;
