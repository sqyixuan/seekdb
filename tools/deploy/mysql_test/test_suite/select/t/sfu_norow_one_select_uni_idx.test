###测试2个事务同时对不存在的行进行select for update
--disable_query_log
--source mysql_test/include/index_quick_major.inc
sleep 2;
--enable_query_log
--disable_warnings
drop table if exists tbl1,tbl2;
--enable_warnings
create table tbl1 (pk int,i1 int, v2 varchar(80), i3 char(20),i4 float, d4 datetime(6),i5 decimal(5,3),i6 bool, primary key(pk));
####一半静态数据，一半动态数据
insert into tbl1 values(1,1,'abc12','1agc',1.25,'2014-01-01 12:00:00',23.23,1),
                       (2,10,'23abc12','4agc1',-0.25,'2015-11-01 12:00:00',-23.230,0),
                       (3,201,'xx23abc12','cagc1',-2.25,'2015-11-21 11:20:10',3.231,1),
                       (4,80,'zx23abc12','zcagc1',2.25,'2013-01-21 11:20:10',-3.231,1),
                       (5,53,'cx23abc12','rcagc1',109.25,'2016-01-22 11:20:10',-13.131,0);
create unique index  idx1 on tbl1(i1);
create unique index  idx2 on tbl1(v2,i3);
--source mysql_test/include/check_all_idx_ok.inc

insert into tbl1 values (6,78,'tx23abc12','icagc1',-109.25,'2014-09-16 16:24:00',-13.531,1),(8,50,'vx23abc12','wcagc1',-85.85,'2014-09-10 16:20:21',93.131,1),(9,610,'ukx23abc12','pecagc1',-1.85,'2014-09-19 16:20:21',99.131,0),(10,42,'kx23abc12','ecagc1',-85.86,'2014-09-18 16:20:21',-99.131,1),(11,null,null,null,null,null,null,null);


connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn2,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);

connection conn1;
set autocommit=0;

connection conn2;
set autocommit=0;

connection conn1;
###在一个事务中对一个空行进行多次for update
connection conn1;
select * from tbl1 where pk=14 for update; 
select * from tbl1 where pk in (16,17+18,100+5) for update; 
select * from tbl1 where pk >=100 and pk<=150 for update; 
select * from tbl1 where pk >100 for update; 
select * from tbl1 where i1=14 for update; 
select * from tbl1 where i1 in (16,17+18,100+5) for update; 
select * from tbl1 where i1 >=100 and i1<=150 for update; 
select * from tbl1 where i1 >2000 for update; 
select * from tbl1 where pk >2000 for update; 
select * from tbl1 where i4>=1000 for update; 
select * from tbl1 where i4>=1000 for update; 
select * from tbl1 where v2 in ('a16','17+18','100+5') for update; 
select * from tbl1 where v2 >='z100' and v2<='z101' for update; 
select * from tbl1 where v2 >'zzzzzzzzzz' for update; 
select * from tbl1 where v2 ='z100' for update; 
select * from tbl1 where pk in (1,100,'2') for update; 
select * from tbl1 where pk in (3,100,'4') for update; 
select * from tbl1 where v2 in ('abc12','1+2','3+4') for update; 
select * from tbl1 where v2 in ('tx23abc12','5+2','6+4') for update; 
select * from tbl1 where pk =10000;
select * from tbl1 where pk =10000;
select * from tbl1 where i1 in (16,17+18,100+5) for update; 
select * from tbl1 where pk <=10000 and pk>=9999;
select * from tbl1 where pk <=10000 and pk>=9999;
select * from tbl1 where pk in (10000,'100001','100002');
select * from tbl1 where pk in (10000,'100001','100002');
select * from tbl1;


###在另外一个事务中执行同样的sql
connection conn2;
select * from tbl1 where pk=14 for update; 
select * from tbl1 where pk in (16,17+18,100+5) for update; 
select * from tbl1 where pk >=100 and pk<=150 for update; 
select * from tbl1 where pk >100 for update; 
select * from tbl1 where i1=14 for update; 
select * from tbl1 where i1 in (16,17+18,100+5) for update; 
select * from tbl1 where i1 >=100 and i1<=150 for update; 
select * from tbl1 where i1 >2000 for update; 
select * from tbl1 where pk >2000 for update; 
select * from tbl1 where i4>=1000 for update; 
select * from tbl1 where i4>=1000 for update; 
select * from tbl1 where v2 in ('a16','17+18','100+5') for update; 
select * from tbl1 where v2 >='z100' and v2<='z101' for update; 
select * from tbl1 where v2 >'zzzzzzzzzz' for update; 
select * from tbl1 where v2 ='z100' for update; 
select * from tbl1 where pk in (105,100,'200') for update; 
select * from tbl1 where pk in (306,100,'400') for update; 
select * from tbl1 where v2 in ('cx25abc12','1+2','3+4') for update; 
select * from tbl1 where v2 in ('zx63abc12','5+2','6+4') for update; 
select * from tbl1 where pk =10000;
select * from tbl1 where pk =10000;
select * from tbl1 where i1 in (1000,17+18,100+5) for update; 
select * from tbl1 where pk <=10000 and pk>=9999;
select * from tbl1 where pk <=10000 and pk>=9999;
select * from tbl1 where pk in (10000,'100001','100002');
select * from tbl1 where pk in (10000,'100001','100002');
select * from tbl1 where i1 in (16,17+18,100+5) and v2 in ('a16','17+18','100+5') for update; 
select * from tbl1 where i1 in (16,17+18,100+5) and v2 in ('a16','17+18','100+5') for update; 
select * from tbl1 where i1 in (16,17+18,100+5) and v2 >'zzzzzzzzzz' for update; 
select * from tbl1 where i1 in (16,17+18,100+5) and v2 >'zzzzzzzzzz' for update; 
--error 1205,4012
update tbl1 set i6=1;

connection conn1;
commit;
connection conn2;
commit;
###锁住唯一索引的空行
connection conn1;
select * from tbl1 where i1<=120 and pk>=10 ;


connection conn2;
insert into tbl1 values (120,79,'t23abc12','iagc1',-18.25,'2019-09-16 16:24:00',-33.531,1);

connection conn1;
send insert into tbl1 values (119,79,'t23abc12','iagc1',-18.25,'2019-09-16 16:24:00',-33.531,1);

connection conn2;
commit;
select * from tbl1 where i1=79;

connection conn1;
--error 1062
reap;
commit;


connection conn2;
update tbl1 set i1=i1+3 where i1=79;

connection conn1;
send update tbl1 set i1=i1+5 where pk=120;

connection conn2;
commit;
select * from tbl1 where pk=120;

connection conn1;
reap;
select * from tbl1 where pk=120;
commit;
select * from tbl1;











