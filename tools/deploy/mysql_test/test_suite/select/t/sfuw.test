--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: xiaoyi.xy
# owner group: SQL3
# description: OUR GOAL: Make all this simple and effective!
show variables like 'ob_query_timeout';

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1(pk int primary key, c1 int);
insert into t1 values(1,1);

connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn2,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);


connection conn1;
begin;
select *  from t1 where pk=1 for update wait 1;
update t1 set c1=c1+1 where pk=1;

connection conn2;
begin;
send select *  from t1 where pk=1 for update wait 5;
--real_sleep 2

connection conn1;
commit;

connection conn2;
reap;
update t1 set c1=c1+1 where pk=1;
commit;

select * from t1;



####################################
set autocommit = 1;
--disable_warnings
drop table if exists t1,t2;
--enable_warnings
create table t1(pk1 int , pk2 varchar(1024), pk3 datetime(6), a int, b varchar(1024), c datetime(6), primary key(pk1,pk2,pk3));
insert into t1 values(1,'conn1','2012-12-12 12:00:00',100, 'r100','2013-12-12 12:00:00' );
insert into t1 values(2,'conn2','2012-12-12 12:00:00',200, 'r200','2013-12-12 12:00:00' );

# case1: s1 lock r1, s2 update r1, commit
connection conn1;
begin;
select *  from t1 where pk1=1 and pk2='conn1' and pk3='2012-12-12 12:00:00' for update nowait;
update t1 set a=a+1 where pk1=1 and pk2='conn1' and pk3='2012-12-12 12:00:00';

connection conn2;
begin;
send select *  from t1 where pk1=1 and pk2='conn1' and pk3='2012-12-12 12:00:00' for update wait 0.5;

connection conn1;
commit;

connection conn2;
reap;
update t1 set b='abc' where pk1 = 1 and pk2 = 'conn1' and pk3 = '2012-12-12 12:00:00';
commit;

select * from t1;
replace into t1 values(1,'conn1','2012-12-12 12:00:00',100, 'r100','2013-12-12 12:00:00' );
replace into t1 values(2,'conn2','2012-12-12 12:00:00',200, 'r200','2013-12-12 12:00:00' );
commit;

#case2: s1 lock r1, s2 lock r2,r1, commit
connection conn1;
begin;
select *  from t1 where pk1=1 and pk2='conn1' and pk3='2012-12-12 12:00:00' for update wait 0.03;
update t1 set b = 'r2000' where pk1 = 1 and pk2 = 'conn1' and pk3 = '2012-12-12 12:00:00';

connection conn2;
begin;
update t1 set b = 'r2000' where pk1 = 2 and pk2 = 'conn2' and pk3 = '2012-12-12 12:00:00';
delete from t1 where pk1 = 2 and pk2 = 'conn2' and pk3 = '2012-12-12 12:00:00';
insert into t1 values(2,'conn2','2012-12-12 12:00:00',200, 'nr200','2013-12-12 12:00:00' );
send update t1 set b = 'r20000' where pk1 = 1 and pk2 = 'conn1' and pk3 = '2012-12-12 12:00:00';

connection conn1;
commit;

connection conn2;
reap;
commit;

select * from t1;
replace into t1 values(1,'conn1','2012-12-12 12:00:00',100, 'r100','2013-12-12 12:00:00' );
replace into t1 values(2,'conn2','2012-12-12 12:00:00',200, 'r200','2013-12-12 12:00:00' );
commit;

# case3: s1 lock r1, s2 update r1, rollback
connection conn1;
begin;
select *  from t1 where pk1=1 and pk2='conn1' and pk3='2012-12-12 12:00:00' for update nowait;
delete from t1 where pk1=1 and pk2='conn1' and pk3='2012-12-12 12:00:00';

connection conn2;
begin;
send select *  from t1 where pk1=1 and pk2='conn1' and pk3='2012-12-12 12:00:00' for update wait 0.5;

connection conn1;
rollback;

connection conn2;
reap;
update t1 set b='abc' where pk1 = 1 and pk2 = 'conn1' and pk3 = '2012-12-12 12:00:00';
commit;

select * from t1;
replace into t1 values(1,'conn1','2012-12-12 12:00:00',100, 'r100','2013-12-12 12:00:00' );
replace into t1 values(2,'conn2','2012-12-12 12:00:00',200, 'r200','2013-12-12 12:00:00' );
commit;

#case4: s1 lock r1, s2 lock r2,r1, commit
connection conn1;
begin;
select *  from t1 where pk1=1 and pk2='conn1' and pk3='2012-12-12 12:00:00' for update nowait;
delete from t1 where pk1 = 1 and pk2 = 'conn1' and pk3 = '2012-12-12 12:00:00';

connection conn2;
begin;
update t1 set b = 'r2000' where pk1 = 2 and pk2 = 'conn2' and pk3 = '2012-12-12 12:00:00';
delete from t1 where pk1 = 2 and pk2 = 'conn2' and pk3 = '2012-12-12 12:00:00';
insert into t1 values(2,'conn2','2012-12-12 12:00:00',200, 'nr200','2013-12-12 12:00:00' );
send update t1 set b = 'r20000' where pk1 = 1 and pk2 = 'conn1' and pk3 = '2012-12-12 12:00:00';

connection conn1;
rollback;

connection conn2;
reap;
commit;

select * from t1;
replace into t1 values(1,'conn1','2012-12-12 12:00:00',100, 'r100','2013-12-12 12:00:00' );
replace into t1 values(2,'conn2','2012-12-12 12:00:00',200, 'r200','2013-12-12 12:00:00' );
commit;

#case5: select for update + when 1
connection conn1;
begin;
update t1 set b='r1000' where pk1 = 1 and pk2 = 'conn1' and pk3 = '2012-12-12 12:00:00';
select * from t1 where pk1 = 1 and pk2 = 'conn1' and pk3 = '2012-12-12 12:00:00';

connection conn2;
send update t1 set b='r1000_2' where pk1 = 1 and pk2 = 'conn1' and pk3 = '2012-12-12 12:00:00';

connection conn1;
commit;

connection conn2;
reap;
commit;

select * from t1;
replace into t1 values(1,'conn1','2012-12-12 12:00:00',100, 'r100','2013-12-12 12:00:00' );
replace into t1 values(2,'conn2','2012-12-12 12:00:00',200, 'r200','2013-12-12 12:00:00' );
commit;

#case:select for update + when 2
connection conn1;
begin;
update t1 set b='r1000' where pk1 = 1 and pk2 = 'conn1' and pk3 = '2012-12-12 12:00:00';
send select * from t1 where pk1 = 1 and pk2 = 'conn1' and pk3 = '2012-12-12 12:00:00' for update wait 0.5;

connection conn2;
begin;
--real_sleep 1
send update t1 set b='r1000_2' where pk1 = 1 and pk2 = 'conn1' and pk3 = '2012-12-12 12:00:00';

connection conn1;
reap;
commit;

connection conn2;
reap;
commit;

select * from t1;
replace into t1 values(1,'conn1','2012-12-12 12:00:00',100, 'r100','2013-12-12 12:00:00' );
replace into t1 values(2,'conn2','2012-12-12 12:00:00',200, 'r200','2013-12-12 12:00:00' );
commit;

#case6: select for update + when 3
connection conn1;
begin;
send delete from t1 where pk1 = 1 and pk2 = 'conn1' and pk3 = '2012-12-12 12:00:00';

connection conn2;
begin;
--real_sleep 1
--error 1205,4012
update t1 set b='r1000' where pk1 = 1 and pk2 = 'conn1' and pk3 = '2012-12-12 12:00:00';
--error 1205,4012
select * from t1 where pk1 = 1 and pk2 = 'conn1' and pk3 = '2012-12-12 12:00:00' for update nowait;

connection conn1;
reap;
commit;

connection conn2;
commit;

select * from t1;
replace into t1 values(1,'conn1','2012-12-12 12:00:00',100, 'r100','2013-12-12 12:00:00' );
replace into t1 values(2,'conn2','2012-12-12 12:00:00',200, 'r200','2013-12-12 12:00:00' );
commit;

#case7: select for update + when 4
connection conn1;
begin;
send delete from t1 where pk1 = 1 and pk2 = 'conn1' and pk3 = '2012-12-12 12:00:00';

connection conn2;
begin;
--real_sleep 1
--error 1205,4012
update t1 set b='r1000' where pk1 = 1 and pk2 = 'conn1' and pk3 = '2012-12-12 12:00:00';
# send select * from t1 where pk1 = 1 and pk2 = 'conn1' and pk3 = '2012-12-12 12:00:00' for update wait 0.0001;

connection conn1;
reap;
rollback;

connection conn2;
#--error 4012
#reap;
#commit;

select * from t1;
replace into t1 values(1,'conn1','2012-12-12 12:00:00',100, 'r100','2013-12-12 12:00:00' );
replace into t1 values(2,'conn2','2012-12-12 12:00:00',200, 'r200','2013-12-12 12:00:00' );
commit;

#case8: select for update + when 5
create table t2(pk1 int , pk2 varchar(1024), pk3 datetime(6), a int, b varchar(1024), c datetime(6), primary key(pk1,pk2,pk3));
connection conn1;
begin;
insert into t2 values(2,'conn2','2012-12-12 12:00:00',200, 'r200','2013-12-12 12:00:00');
update t1 set b='r1000' where pk1 = 1 and pk2 = 'conn1' and pk3 = '2012-12-12 12:00:00' ;
send select * from t1 where pk1 = 1 and pk2 = 'conn1' and pk3 = '2012-12-12 12:00:00' for update nowait;

connection conn2;
begin;
--real_sleep 1
send select * from t1 where pk1 = 1 and pk2 = 'conn1' and pk3 = '2012-12-12 12:00:00' for update;

connection conn1;
reap;
commit;

connection conn2;
reap;
update t1 set b='r10000' where pk1 = 1 and pk2 = 'conn1' and pk3 = '2012-12-12 12:00:00';
commit;

select * from t1;
select * from t2;
