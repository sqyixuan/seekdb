--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: peihan.dph
# owner group: SQL2
# tags: optimizer
# description:
#
# 测试distinct block mode


connect (syscon, $OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
#alter system set _max_trx_size='1G';

--disable_query_log
#eval create resource unit new_box1 max_cpu 1, memory_size '2G';
#eval create resource pool new_pool1 unit = 'new_box1', unit_num = $obs_num;
#eval create tenant dump_tenant primary_zone='$zone_name', resource_pool_list('new_pool1') set ob_tcp_invited_nodes='%';

--enable_result_log
--enable_query_log
--source mysql_test/include/check_tenant_sync.inc
sleep 2;

connect (conn1,$OBMYSQL_MS0,root,,test,$OBMYSQL_PORT);

alter system set _sort_area_size='2M';
alter system set _hash_area_size='4M';

connection conn1;
--disable_warnings
--error 0,1051
drop table t1;
--error 0,1051
drop table t2;
--error 0,1051
drop table t111_var;
--error 0,1051
drop table t333_var;
--error 0,1051
drop table t222_var;
--enable_warnings

create table t1(c1 int primary key, c2 int) partition by hash (c1) partitions 5;
create table t2(c1 int primary key, c2 int, c3 varchar(32)) partition by hash (c1) partitions 3;

insert into t1 values(1,2);
insert into t1 values(2,3);
insert into t1 values(3,4);
insert into t1 values(4,5);
insert into t1 values(-4,5);

insert into t2 values(9,0,'a');
insert into t2 values(1,2,'a');
insert into t2 values(2,3,'b');
insert into t2 values(3,4,'c');
insert into t2 values(4,5,'d');
insert into t2 values(0,1,'e');
insert into t2 values(8,2,'f');

create index idx_t1_c2 on t1(c2) LOCAL;

create table t333_var(c0 bigint ,c1 varchar(4000), c2 varchar(4000), c3 varchar(4000), c4 varchar(4000), c5 varchar(4000),c6 varchar(4000), c7 longtext);
# partition by hash(c0) partitions 5;

insert into t333_var values(1,repeat('ab',1000),repeat('ab',1000),repeat('ab',1000),repeat('ab',1000),repeat('ab',1000),repeat('ab',1000),repeat('a',4000));
insert into t333_var select c0+1,c1,c2,c3,c4,c5,c6,c7 from t333_var;
insert into t333_var select c0+10,c1,c2,c3,c4,c5,c6,c7 from t333_var;
insert into t333_var select c0+100,c1,c2,c3,c4,c5,c6,c7 from t333_var;
insert into t333_var select c0+1000,c1,c2,c3,c4,c5,c6,c7 from t333_var;
insert into t333_var select c0+10000,c1,c2,c3,c4,c5,c6,c7 from t333_var;
insert into t333_var select c0+100000,c1,c2,c3,c4,c5,c6,c7 from t333_var;
insert into t333_var select c0+1000000,c1,c2,c3,c4,c5,c6,c7 from t333_var;
insert into t333_var select c0+10000000,c1,c2,c3,c4,c5,c6,c7 from t333_var;
insert into t333_var select c0+100000000,c1,c2,c3,c4,c5,c6,c7 from t333_var;
insert into t333_var select c0+1000000000,c1,c2,c3,c4,c5,c6,c7 from t333_var;
insert into t333_var select c0+10000000000,c1,c2,c3,c4,c5,c6,c7 from t333_var;
commit;


create table t222_var(c0 bigint ,c1 varchar(4000), c2 varchar(4000), c3 varchar(4000), c4 varchar(4000), c5 varchar(4000),c6 varchar(4000), c7 longtext);

insert into t222_var values(1,repeat('ab',1000),repeat('ab',1000),repeat('ab',1000),repeat('ab',1000),repeat('ab',1000),repeat('ab',1000),repeat('a',4000));
insert into t222_var select c0+1,c1,c2,c3,c4,c5,c6,c7 from t222_var;
insert into t222_var select c0+10,c1,c2,c3,c4,c5,c6,c7 from t222_var;
insert into t222_var select c0+100,c1,c2,c3,c4,c5,c6,c7 from t222_var;
insert into t222_var select c0+1000,c1,c2,c3,c4,c5,c6,c7 from t222_var;
insert into t222_var select c0+10000,c1,c2,c3,c4,c5,c6,c7 from t222_var;
insert into t222_var select c0+100000,c1,c2,c3,c4,c5,c6,c7 from t222_var;
insert into t222_var select c0+1000000,c1,c2,c3,c4,c5,c6,c7 from t222_var;
insert into t222_var select c0+10000000,c1,c2,c3,c4,c5,c6,c7 from t222_var;
insert into t222_var select c0+100000000,c1,c2,c3,c4,c5,c6,c7 from t222_var;
commit;
insert into t222_var select c0+1000000000,c1,c2,c3,c4,c5,c6,c7 from t222_var;
#insert into t222_var select c0+10000000000,c1,c2,c3,c4,c5,c6,c7 from t222_var;
commit;
select count(*) from t333_var;
select count(*) from t222_var;

--result_format 4
--explain_protocol 1

set  ob_query_timeout=200000000;
set  ob_trx_timeout=200000000;

select /*+ trac1ing(11)*/ sum(length(a.c1)),sum(d.c0),count(*)  from t222_var d
,
(select /*+ use_px parallel(2)  */ distinct a.c1,a.c2 from (select /*+ leading(b (c a) ) use_hash(b a) pq_distribute((a,c) hash hash) pq_distribute(a broadcast None) */
 a.*
from (select a.* from t222_var a, t222_var c where a.c0=c.c0)a,t333_var b  where a.c0=b.c0) a)a
where d.c1=a.c1;


select /*+ trac1ing(11)*/ sum(length(a.c1)),sum(d.c0),count(*)  from t222_var d
,
(select /*+ no_use_px */ distinct a.c1,a.c2 from (select /*+ leading(b (c a) ) use_hash(b a) pq_distribute((a,c) hash hash) pq_distribute(a broadcast None) */
 a.*
from (select a.* from t222_var a, t222_var c where a.c0=c.c0)a,t333_var b  where a.c0=b.c0) a)a
where d.c1=a.c1;

select count(*) from( select * from (select /*+ use_px parallel(2)  */ distinct a.c0,a.c1,a.c2 from (select /*+ leading(b (c a) ) use_hash(b a) pq_distribute((a,c) hash hash) pq_distribute(a broadcast None) */
 a.*
from (select a.* from t222_var a, t222_var c where a.c0=c.c0)a,t333_var b  where a.c0=b.c0) a)d
intersect
select * from
(select /*+ use_px parallel(2)  */ distinct a.c0,a.c1,a.c2 from (select /*+ leading(b (c a) ) use_hash(b a) pq_distribute((a,c) hash hash) pq_distribute(a broadcast None) */
 a.*
from (select a.* from t222_var a, t222_var c where a.c0=c.c0)a,t333_var b  where a.c0=b.c0) a)a
);

select count(*) from( select * from (select /*+ use_px parallel(2)  */ distinct a.c0,a.c1,a.c2 from (select /*+ leading(b (c a) ) use_hash(b a) pq_distribute((a,c) hash hash) pq_distribute(a broadcast None) */
 a.*
from (select a.* from t222_var a, t222_var c where a.c0=c.c0)a,t333_var b  where a.c0=b.c0) a)d
union
select * from
(select /*+ use_px parallel(2)  */ distinct a.c0,a.c1,a.c2 from (select /*+ leading(b (c a) ) use_hash(b a) pq_distribute((a,c) hash hash) pq_distribute(a broadcast None) */
 a.*
from (select a.* from t222_var a, t222_var c where a.c0=c.c0)a,t333_var b  where a.c0=b.c0) a)a
);

select count(*) from( select * from (select /*+ use_px parallel(2)  */ distinct a.c0,a.c1,a.c2 from (select /*+ leading(b (c a) ) use_hash(b a) pq_distribute((a,c) hash hash) pq_distribute(a broadcast None) */
 a.*
from (select a.* from t222_var a, t222_var c where a.c0=c.c0)a,t333_var b  where a.c0=b.c0) a)d
minus
select * from
(select /*+ use_px parallel(2)  */ distinct a.c0,a.c1,a.c2 from (select /*+ leading(b (c a) ) use_hash(b a) pq_distribute((a,c) hash hash) pq_distribute(a broadcast None) */
 a.*
from (select a.* from t222_var a, t222_var c where a.c0=c.c0)a,t333_var b  where a.c0=b.c0) a)a
);

select * from ((select c1 from t1) union (select c2 from t1) union (select c2 from t2)) order by 1;

select * from ((select /*+ parallel(2) */sum(c1) c1 from t1 group by c2+1) union (select c2 from t1) union (select c2 from t2)) order by 1;

alter system set _hash_area_size='4M';
sleep 2;

connection conn1;
##dump
select /*+ trac1ing(11)*/ count(*), sum(length(a.c1)), sum(length(a.c2)),sum(length(a.c3)),sum(length(a.c4)),sum(length(a.c5)),sum(length(a.c6)),sum(length(a.c7)), sum(length(a.c8)),sum(d.c0) from t222_var d
,
(select /*+ use_px parallel(2)  */ distinct a.c1, concat(a.c0, '1') c2,a.c2 c8,a.c3,a.c4,a.c5,.a.c6,a.c7 from (select /*+ leading(b (c a) ) use_hash(b a) pq_distribute((a,c) hash hash) pq_distribute(a broadcast None) */
 a.*
from (select a.* from t222_var a, t222_var c where a.c0=c.c0)a,t333_var b  where a.c0=b.c0) a)a
where concat(d.c0, '1') =a.c2;



select /*+ trac1ing(11)*/ count(*), sum(length(a.c1)), sum(length(a.c2)),sum(length(a.c3)),sum(length(a.c4)),sum(length(a.c5)),sum(length(a.c6)),sum(length(a.c7)), sum(length(a.c8)),sum(d.c0) from t222_var d
,
(select /*+ no_use_px */ distinct a.c1, concat(a.c0, '1') c2,a.c2 c8,a.c3,a.c4,a.c5,.a.c6,a.c7 from (select /*+ leading(b (c a) ) use_hash(b a) pq_distribute((a,c) hash hash) pq_distribute(a broadcast None) */
 a.*
from (select a.* from t222_var a, t222_var c where a.c0=c.c0)a,t333_var b  where a.c0=b.c0) a)a

where concat(d.c0, '1') =a.c2;


alter system set _sort_area_size='100M';
alter system set _hash_area_size='100M';
sleep 2;

connection conn1;
drop table t333_var;
drop table t222_var;

connection syscon;
#drop tenant dump_tenant force;
#drop resource pool new_pool1;
#drop resource unit new_box1;

