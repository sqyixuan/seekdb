#owner: buduo.jyh
#owner group: opensource
#tags: external_table

--source mysql_test/include/select_into_outfile/get_host_ip.inc
let $DATA_FOLDER_NAME = data_for_mysqltest_select_into_outfile_compression;

--source mysql_test/include/select_into_outfile/delete_dir.inc
--source mysql_test/include/select_into_outfile/mkdir_for_dump.inc

--disable_warnings
drop table if exists t1, t_gzip_external, t_deflate_external, t_zstd_external, t_lob, t_lob_external, t_buffer_size_external;
--enable_warnings

set ob_query_timeout = 10000000000;

create table t1(c1 int, c2 double, c3 float, c4 varchar(20), c5 char(20), c6 date, c7 bool, c8 time);
insert into t1 values(1, 1.324, 2.3, 'hhh中zzz', 'hhh国zzz', '2021-08-19', true, '00:00:00');
insert into t1 values(2, 2.325, 3.2, 'hhh中z排zz', 'hhh国z球zz', '2022-08-19', 0, '00:00:40');
insert into t1 values(3, 3.14, 4.2, 'hhh中zzz', 'hhh国zzz', '2023-08-19', 1, '00:03:00');
insert into t1 values(4, 9.001, 5.10, 'hhh中zzz匹配', 'hhh国zzz品牌', '2023-08-19', false, '02:00:00');
insert into t1 values(5, 2.181, 6.7, 'hhh中zziiz', 'hkkhh国zzz', '2021-08-19', TRUE, '00:00:00');
insert into t1 values(6, 1010, 29, 'hhh中zzz6', 'hhh国zz66z', '2023-08-19', FALse, '00:03:00');

--source mysql_test/include/select_into_outfile/delete_files.inc

--echo ## basic test

eval SELECT * FROM t1
into outfile '$DATA_FOLDER_NAME/data1.csv'
format = (TYPE = 'CSV',
          FIELD_DELIMITER = ',',
          ENCODING = 'utf8mb4',
          COMPRESSION = gzip);

eval create external table t_gzip_external (
    c1 int,
    c2 double,
    c3 float,
    c4 varchar(20),
    c5 char(20),
    c6 date,
    c7 bool,
    c8 time
)
format (type = 'CSV',
        FIELD_DELIMITER = ',',
        ENCODING = 'utf8mb4',
        compression = gzip) location '$DATA_FOLDER_NAME';

select * from t_gzip_external;

--source mysql_test/include/select_into_outfile/delete_files.inc

eval SELECT * FROM t1
into outfile '$DATA_FOLDER_NAME/data1.csv'
format = (TYPE = 'CSV',
          FIELD_DELIMITER = ',',
          ENCODING = 'utf8mb4',
          COMPRESSION = deflate);

eval create external table t_deflate_external (
    c1 int,
    c2 double,
    c3 float,
    c4 varchar(20),
    c5 char(20),
    c6 date,
    c7 bool,
    c8 time
)
format (type = 'CSV',
        FIELD_DELIMITER = ',',
        ENCODING = 'utf8mb4',
        compression = deflate) location '$DATA_FOLDER_NAME';

select * from t_deflate_external;

--source mysql_test/include/select_into_outfile/delete_files.inc

eval SELECT * FROM t1
into outfile '$DATA_FOLDER_NAME/data1.csv'
format = (TYPE = 'CSV',
          FIELD_DELIMITER = ',',
          ENCODING = 'utf8mb4',
          COMPRESSION = zstd);

eval create external table t_zstd_external (
    c1 int,
    c2 double,
    c3 float,
    c4 varchar(20),
    c5 char(20),
    c6 date,
    c7 bool,
    c8 time
)
format (type = 'CSV',
        FIELD_DELIMITER = ',',
        ENCODING = 'utf8mb4',
        compression = zstd) location '$DATA_FOLDER_NAME';

select * from t_zstd_external;
--source mysql_test/include/select_into_outfile/delete_files.inc

--echo ## with lob type

create table t_lob(c1 int, c2 varchar(20), c3 text);

insert /*+append enable_parallel_dml parallel(8) */ into t_lob
select UNIFORM(1, 10000, random(7)), RANDSTR(20, random(7)), repeat(RANDSTR(20, random(7)), 1000) from table(generator(100));

eval select /*+parallel(2)*/* from t_lob into outfile '$DATA_FOLDER_NAME/data1.csv'
format = (TYPE = 'CSV',
          FIELD_DELIMITER = ',',
          ENCODING = 'utf8mb4',
          COMPRESSION = zstd) single = false MAX_FILE_SIZE = 1048576;

eval create external table t_lob_external (c1 int, c2 varchar(20), c3 text)
format (type = 'CSV',
        FIELD_DELIMITER = ',',
        ENCODING = 'utf8mb4',
        compression = zstd) location '$DATA_FOLDER_NAME';
select count(*) from t_lob_external;

--source mysql_test/include/select_into_outfile/list_dir.inc
--source mysql_test/include/select_into_outfile/delete_files.inc

--echo ## with BUFFER_SIZE

eval SELECT /*+parallel(5)*/* FROM t_lob
into outfile '$DATA_FOLDER_NAME/data1.csv'
format = (TYPE = 'CSV',
          FIELD_DELIMITER = ',',
          ENCODING = 'utf8mb4',
          COMPRESSION = zstd) single = false MAX_FILE_SIZE=1048576 BUFFER_SIZE= '2KB';

eval create external table t_buffer_size_external (c1 int, c2 varchar(20), c3 text)
format (type = 'CSV',
        FIELD_DELIMITER = ',',
        ENCODING = 'utf8mb4',
        compression = zstd) location '$DATA_FOLDER_NAME';

select count(*) from t_buffer_size_external;

--source mysql_test/include/select_into_outfile/list_dir.inc


# --source mysql_test/include/select_into_outfile/delete_files.inc
# --source mysql_test/include/select_into_outfile/delete_dir.inc
DROP TABLE t1, t_gzip_external, t_deflate_external, t_zstd_external, t_lob, t_lob_external, t_buffer_size_external;

