#在内部表指定不存在分区的查询，不会立即抛错，会重试到超时
##内部表
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
--error 1735
select * from oceanbase.__all_virtual_database partition(p20);
disconnect obsys;
connection default;
##普通表
--disable_warnings
drop table if exists jx_ts;
--enable_warnings
create table jx_ts (id int, purchased date, primary key(id, purchased))partition by range(year(purchased)) subpartition by hash(to_days(purchased)) subpartitions 2 (partition p0 values less than (1990), partition p1 values less than (2000), partition p2 values less than maxvalue);
select * from jx_ts partition(p1sp0);
drop table jx_ts;
--disable_warnings
drop table if exists jx_t1;
--enable_warnings
create table jx_t1(c1 int primary key) partition by range(c1) (partition p0 values less than (10));
--error 1735
select * from jx_t1 partition(p10);
select * from jx_t1 partition(p0);
drop table jx_t1;

