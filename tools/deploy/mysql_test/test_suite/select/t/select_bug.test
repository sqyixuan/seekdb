#
connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn1;
use test;
--disable_warnings
drop table if exists test.a; 
drop table if exists test.b; 
drop table if exists test.c; 
--enable_warnings

create table a(a1 char(5));
create table b(b1 char(6));
create table c(c1 bigint);
insert into a values('a');
insert into b values('bbb');
insert into c values(12);

set @xxx = 'asd';
select @xxx;
select a1 from a into @xxx;
select @xxx;
sleep 0.5;
select @xxx;

select b1 from b into @xxx;
select @xxx;
sleep 0.5;
select @xxx;

select c1 from c into @xxx;
select @xxx;
sleep 0.5;
select @xxx;
disconnect conn1;

let $trycnt=5;
while($trycnt>0)
{
	connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
	connection conn1;
	set ob_read_consistency='weak';
	set @xxx = 'asd';
	select @xxx;
	select a1 from a into @xxx;
	select @xxx;
	sleep 0.5;
	select @xxx;
	
	select b1 from b into @xxx;
	select @xxx;
	sleep 0.5;
	select @xxx;
	
	select c1 from c into @xxx;
	select @xxx;
	sleep 0.5;
	select @xxx;
	
	disconnect conn1;
	dec $trycnt;
}
connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection conn1;
drop table a; 
drop table b; 
drop table c; 
drop database select_bug;
disconnect conn1;
