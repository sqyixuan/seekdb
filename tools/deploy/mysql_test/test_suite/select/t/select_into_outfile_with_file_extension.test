#owner: buduo.jyh
#owner group: opensource
#tags: external_table

--source mysql_test/include/select_into_outfile/get_host_ip.inc
let $DATA_FOLDER_NAME = data_for_mysqltest_select_into_outfile_compression;

--source mysql_test/include/select_into_outfile/delete_dir.inc
--source mysql_test/include/select_into_outfile/mkdir_for_dump.inc

--disable_warnings
drop table if exists t1;
--enable_warnings

set ob_query_timeout = 10000000000;

create table t1(c1 int);
insert into t1 values(1);
insert into t1 values(2);

--source mysql_test/include/select_into_outfile/delete_files.inc

--echo ## single = true

eval SELECT * FROM t1
into outfile '$DATA_FOLDER_NAME/data1'
format = (TYPE = 'CSV',
          FIELD_DELIMITER = ',',
          ENCODING = 'utf8mb4') single = true;

--source mysql_test/include/select_into_outfile/list_dir.inc
--source mysql_test/include/select_into_outfile/delete_files.inc

eval SELECT * FROM t1
into outfile '$DATA_FOLDER_NAME/data1'
format = (TYPE = 'CSV',
          FIELD_DELIMITER = ',',
          ENCODING = 'utf8mb4'
          FILE_EXTENSION = '.abc') single = true;

--source mysql_test/include/select_into_outfile/list_dir.inc
--source mysql_test/include/select_into_outfile/delete_files.inc

eval SELECT * FROM t1
into outfile '$DATA_FOLDER_NAME/data1'
format = (TYPE = 'PARQUET') single=true;

--source mysql_test/include/select_into_outfile/list_dir.inc
--source mysql_test/include/select_into_outfile/delete_files.inc

--echo ## single = false
eval SELECT * FROM t1
into outfile '$DATA_FOLDER_NAME/data1'
format = (TYPE = 'CSV',
          FIELD_DELIMITER = ',',
          ENCODING = 'utf8mb4') single=false;

--source mysql_test/include/select_into_outfile/list_dir.inc
--source mysql_test/include/select_into_outfile/delete_files.inc

eval SELECT * FROM t1
into outfile '$DATA_FOLDER_NAME/data1'
format = (TYPE = 'CSV',
          FIELD_DELIMITER = ',',
          ENCODING = 'utf8mb4',
          FILE_EXTENSION = '.abc') single=false;

--source mysql_test/include/select_into_outfile/list_dir.inc
--source mysql_test/include/select_into_outfile/delete_files.inc

eval SELECT * FROM t1
into outfile '$DATA_FOLDER_NAME/data1'
format = (TYPE = 'CSV',
          FIELD_DELIMITER = ',',
          ENCODING = 'utf8mb4',
          FILE_EXTENSION = 'abc') single=false;

--source mysql_test/include/select_into_outfile/list_dir.inc
--source mysql_test/include/select_into_outfile/delete_files.inc

eval SELECT /*parallel(2)*/* FROM t1
into outfile '$DATA_FOLDER_NAME/data1'
format = (TYPE = 'CSV',
          FIELD_DELIMITER = ',',
          ENCODING = 'utf8mb4',
          COMPRESSION = gzip) single=false;

--source mysql_test/include/select_into_outfile/list_dir.inc
--source mysql_test/include/select_into_outfile/delete_files.inc

eval SELECT /*parallel(2)*/* FROM t1
into outfile '$DATA_FOLDER_NAME/data1'
format = (TYPE = 'CSV',
          FIELD_DELIMITER = ',',
          ENCODING = 'utf8mb4',
          COMPRESSION = gzip,
          FILE_EXTENSION = '.abc') single=false;

--source mysql_test/include/select_into_outfile/list_dir.inc
--source mysql_test/include/select_into_outfile/delete_files.inc

eval SELECT /*parallel(2)*/* FROM t1
into outfile '$DATA_FOLDER_NAME/data1'
format = (TYPE = 'PARQUET') single=false;

--source mysql_test/include/select_into_outfile/list_dir.inc
--source mysql_test/include/select_into_outfile/delete_files.inc

eval SELECT /*parallel(2)*/* FROM t1
into outfile '$DATA_FOLDER_NAME/data1'
format = (TYPE = 'PARQUET'
          COMPRESSION = gzip) single=false;

--source mysql_test/include/select_into_outfile/list_dir.inc

--error 1210
SELECT * FROM t1
into outfile '$DATA_FOLDER_NAME/data1'
format = (TYPE = 'CSV',
          FILE_EXTENSION = 'xx/xxx') single=false;


--source mysql_test/include/select_into_outfile/delete_files.inc
--source mysql_test/include/select_into_outfile/delete_dir.inc
DROP TABLE t1;

