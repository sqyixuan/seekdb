--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: xiaoyi.xy
# owner group: SQL1
# description: 本case是为了测试分布式执行计划下found_rows的结果
# tags: optimizer, found_rows

--disable_warnings
drop table if exists t1,t2,t3,t4,t5,t6;
--enable_warnings

CREATE TABLE t1 (a int not null, b char (10) not null) partition by hash(a) partitions 3;
insert into t1 values(1,'a');
insert into t1 values(2,'b');
insert into t1 values(3,'c');
insert into t1 values(4,'d');

CREATE TABLE t2 (a int not null, b char (10) not null) partition by hash(a) partitions 3;
insert into t2 values (3,'c');
insert into t2 values (4,'d');
insert into t2 values (5,'f');
insert into t2 values (6,'e');

select a,b from t1 union distinct select a,b from t2;
select found_rows();
select a,b from t1 union all select a,b from t2;
select found_rows();
select a,b from t1 union all select a,b from t2 order by b;
select found_rows();
--sorted_result
select a,b from t1 union all select a,b from t2 union select 7,'g';
select found_rows();
--sorted_result
select 0,'#' union select a,b from t1 union all select a,b from t2 union select 7,'gg';
select found_rows();
select a,b from t1 union select a,b from t1;
select found_rows();
explain basic select 't1',b,count(*) from t1 group by b UNION select 't2',b,count(*) from t2 group by b;
explain basic select /*+no_use_px*/ 't1',b,count(*) from t1 group by b UNION select 't2',b,count(*) from t2 group by b;
--sorted_result
select /*+no_use_px*/ 't1',b,count(*) from t1 group by b UNION select 't2',b,count(*) from t2 group by b;
select found_rows();

# Test alternate syntax for unions
(select a,b from t1 limit 2)  union all (select a,b from t2 order by a) limit 4;
select found_rows();
(select a,b from t1 limit 2)  union all (select a,b from t2 order by a limit 1);
select found_rows();
(select a,b from t1 limit 2)  union all (select a,b from t2 order by a limit 1) order by b desc;
select found_rows();
(select sql_calc_found_rows  a,b from t1 limit 2)  union all (select a,b from t2 order by a) limit 2;
select found_rows();
select sql_calc_found_rows  a,b from t1  union all select a,b from t2 limit 2;
select found_rows();
--error 1222
select * from t1 where a = 1 union select 1;
--sorted_result
(select * from t1 limit 2) union (select * from t2 limit 3) limit 4;
select found_Rows();
--sorted_result
(select * from t1 limit 2) union (select * from t2 limit 3);
select found_Rows();
--sorted_result
(select * from t1 limit 2) union (select * from t2 limit 20,3);
select found_Rows();

(select * from t1 limit 2, 1) union (select * from t2 limit 20,3);
select found_Rows();
(select * from t1 limit 2, 1) union (select * from t2 limit 20,3) limit 4;
select found_Rows();
(select * from t1 limit 2, 1) union all(select * from t2 limit 20,3) limit 4;
select found_Rows();
(select * from t1 limit 2, 1) union all(select * from t2 limit 20,3);
select found_Rows();


# Test global limits
(SELECT SQL_CALC_FOUND_ROWS * FROM t1) UNION all (SELECT * FROM t2) LIMIT 1;
select found_rows();
(SELECT SQL_CALC_FOUND_ROWS * FROM t1 LIMIT 1) UNION all (SELECT * FROM t2) LIMIT 2;
select found_rows();

# Test cases where found_rows() should return number of returned rows
(SELECT SQL_CALC_FOUND_ROWS * FROM t1 LIMIT 1) UNION all (SELECT * FROM t2);
select found_rows();
(SELECT SQL_CALC_FOUND_ROWS * FROM t1) UNION all (SELECT * FROM t2 LIMIT 1);
select found_rows();
# This used to work in 4.0 but not anymore in 4.1

# In these case found_rows() should work
(SELECT SQL_CALC_FOUND_ROWS * FROM t1 LIMIT 1) UNION all (SELECT * FROM t2) LIMIT 2;
select found_rows();
(SELECT SQL_CALC_FOUND_ROWS * FROM t1 LIMIT 1) UNION all (SELECT * FROM t2 LIMIT 2);
select found_rows();

SELECT SQL_CALC_FOUND_ROWS * FROM t1 UNION all SELECT * FROM t2 LIMIT 2;
select found_rows();

# The following examples will not be exact
SELECT SQL_CALC_FOUND_ROWS * FROM t1 UNION SELECT * FROM t2 LIMIT 2;
select found_rows();
SELECT SQL_CALC_FOUND_ROWS * FROM t1 UNION SELECT * FROM t2 LIMIT 100;
select found_rows();
--sorted_result
(SELECT SQL_CALC_FOUND_ROWS * FROM t1 LIMIT 100) UNION (SELECT * FROM t2);
select found_rows();
--sorted_result
(SELECT SQL_CALC_FOUND_ROWS * FROM t1 LIMIT 1) UNION (SELECT * FROM t2);
select found_rows();
(SELECT SQL_CALC_FOUND_ROWS * FROM t1 LIMIT 1) UNION (SELECT * FROM t2 LIMIT 2);
select found_rows();
--sorted_result
(SELECT SQL_CALC_FOUND_ROWS * FROM t1 LIMIT 1) UNION (SELECT * FROM t2) LIMIT 2;
select found_rows();

SELECT SQL_CALC_FOUND_ROWS * FROM t1 UNION (SELECT * FROM t2) LIMIT 2,2;
select found_rows();
--sorted_result
(SELECT SQL_CALC_FOUND_ROWS * FROM t1 limit 2,2) UNION (SELECT * FROM t2);
select found_rows();
--sorted_result
SELECT SQL_CALC_FOUND_ROWS * FROM t1 UNION (SELECT * FROM t2 LIMIT 2,2);
select found_rows();
--sorted_result
(SELECT SQL_CALC_FOUND_ROWS * FROM t1 limit 2,2) UNION (SELECT * FROM t2) limit 2,1;
select found_rows();

SELECT SQL_CALC_FOUND_ROWS * FROM t1 UNION (SELECT * FROM t2) LIMIT 32,2;
select found_rows();
--sorted_result
(SELECT SQL_CALC_FOUND_ROWS * FROM t1 limit 23,2) UNION (SELECT * FROM t2);
select found_rows();
--sorted_result
SELECT SQL_CALC_FOUND_ROWS * FROM t1 UNION (SELECT * FROM t2 LIMIT 22,2);
select found_rows();
(SELECT SQL_CALC_FOUND_ROWS * FROM t1 limit 22,2) UNION (SELECT * FROM t2) limit 22,1;
select found_rows();


##多层union
select * from ((select * from t1 limit 1) union (select * from t1 limit 1) union (select * from t1 limit 1)) a;
select found_rows();
select * from ((((select * from t1))) union (select * from t1) union (select * from t1)) a;
select found_rows();
select * from ((select * from t1) union (((select * from t1))) union (select * from t1)) a;
select found_rows();
select SQL_CALC_FOUND_ROWS * from ((select * from t1 limit 1) union (select * from t1 limit 1) union (select * from t1 limit 1)) a;
select found_rows();
--error 1234
select * from ((((select SQL_CALC_FOUND_ROWS * from t1))) union (select * from t1) union (select * from t1)) a;
select found_rows();
--error 1234
select * from ((select * from t1) union (((select * from t1))) union (select SQL_CALC_FOUND_ROWS * from t1)) a;
select found_rows();



--disable_warnings
drop table if exists t1,t2;
--enable_warnings

create table t1 (a int not null auto_increment, b int not null, primary key(a, b)) partition by hash(b) partitions 3;
insert into t1 (b) values (2);
insert into t1 (b) values (3);
insert into t1 (b) values (5);
insert into t1 (b) values (5);
insert into t1 (b) values (5);
insert into t1 (b) values (6);
insert into t1 (b) values (7);
insert into t1 (b) values (9);
select SQL_CALC_FOUND_ROWS * from t1;
select found_rows();
select SQL_CALC_FOUND_ROWS * from t1 limit 1;
select found_rows();
select SQL_CALC_FOUND_ROWS * from t1 limit 1;
select found_rows();
select SQL_CALC_FOUND_ROWS * from t1 order by b desc limit 1;
select found_rows();
select SQL_CALC_FOUND_ROWS distinct b from t1 limit 1;
select found_rows();
select SQL_CALC_FOUND_ROWS b,count(*) as c from t1 group by b order by c desc limit 1;
select found_rows();
select SQL_CALC_FOUND_ROWS * from t1 left join t1 as t2 on (t1.b=t2.a) limit 2,1;
select found_rows();
drop table t1;

#
# Test SQL_CALC_FOUND_ROWS optimization when used with one table and filesort
#

create table t1 (a int not null primary key) partition by hash(a) partitions  3;
insert into t1 values (1);
insert into t1 values (2);
insert into t1 values (3);
insert into t1 values (4);
insert into t1 values (5);
select sql_calc_found_rows a from t1 where a in (1,2,3) order by a desc limit 0,2;
select FOUND_ROWS();
select sql_calc_found_rows a from t1 where a in (1,2,3) order by a+2 desc limit 0,2;
select FOUND_ROWS();
drop table t1;

#
# Test of SQL_CALC_FOUND_ROWS with DISTINCT
#

CREATE TABLE t1 (
`id` smallint(5) unsigned NOT NULL,
`kid` smallint(5) unsigned NOT NULL default '0',
PRIMARY KEY (`id`)
) partition by hash(`id`) partitions 3;

CREATE TABLE t2 (
  id smallint(5) unsigned NOT NULL,
  name varchar(50) NOT NULL default '',
  email varchar(50) NOT NULL default '',
  PRIMARY KEY  (id)) partition by key(id) partitions 3;

disable_query_log;
let $1=200;
let $2=0;
while ($1)
{
  inc $2;
  eval INSERT INTO t2 VALUES ($2,'name$2','email$2');
  dec $1;
}
enable_query_log;

#--eval EXPLAIN $query
--disable_result_log
SELECT SQL_CALC_FOUND_ROWS DISTINCT email FROM t2 LEFT JOIN t1  ON kid = t2.id WHERE t1.id IS NULL LIMIT 10;
--enable_result_log
#SHOW SESSION STATUS LIKE 'Sort_scan%';
show variables like 'sql_mode';
SELECT SQL_CALC_FOUND_ROWS DISTINCT email FROM t2 LEFT JOIN t1  ON kid = t2.id WHERE t1.id IS NULL LIMIT 10;

SELECT FOUND_ROWS();

SELECT SQL_CALC_FOUND_ROWS DISTINCT email FROM t2 LEFT JOIN t1  ON kid = t2.id WHERE t1.id IS NULL order by email LIMIT 10;
SELECT FOUND_ROWS();

SELECT DISTINCT email FROM t2 LEFT JOIN t1  ON kid = t2.id WHERE t1.id IS NULL LIMIT 10;
SELECT DISTINCT email FROM t2 LEFT JOIN t1  ON kid = t2.id WHERE t1.id IS NULL ORDER BY email LIMIT 10;
INSERT INTO `t1` (`id`, `kid`) VALUES ('0', '150');

SELECT SQL_CALC_FOUND_ROWS DISTINCT email FROM t2 LEFT JOIN t1  ON kid = t2.id WHERE t1.id IS NULL LIMIT 10;
SELECT FOUND_ROWS();

drop table t1,t2;

#
# Test bug when using range optimization
#

CREATE TABLE `t1` (
  `titre` char(80) NOT NULL default '',
  `numeropost` mediumint(8) unsigned NOT NULL,
  `maxnumrep` int(10) unsigned NOT NULL default '0',
  PRIMARY KEY  (`numeropost`)
  ) partition by hash(`numeropost`) partitions 3;
#) ENGINE=MyISAM ROW_FORMAT=FIXED;
INSERT INTO t1 (numeropost, titre,maxnumrep) VALUES (1, 'test1','1');
INSERT INTO t1 (numeropost, titre,maxnumrep) VALUES (2, 'test2','2');
INSERT INTO t1 (numeropost, titre,maxnumrep) VALUES (3, 'test3','3');
SELECT SQL_CALC_FOUND_ROWS titre,numeropost,maxnumrep FROM t1 WHERE numeropost IN (1,2) ORDER BY maxnumrep DESC LIMIT 0, 1;
SELECT FOUND_ROWS();
SELECT SQL_CALC_FOUND_ROWS 1 FROM (SELECT 1) as a LIMIT 0;
SELECT FOUND_ROWS();
SELECT SQL_CALC_FOUND_ROWS * FROM t1 WHERE numeropost > 1  LIMIT 0;
SELECT FOUND_ROWS();
SELECT SQL_CALC_FOUND_ROWS * FROM t1 LIMIT 0;
SELECT FOUND_ROWS();
SELECT SQL_CALC_FOUND_ROWS * FROM t1 ORDER BY numeropost  LIMIT 0;
SELECT FOUND_ROWS();
drop table t1;

#
# Test problem with impossible WHERE (Bug #1468)
#

create table t1 (id int, primary key (id)) partition by hash(id) partitions 3;
insert into t1 values (1);
insert into t1 values (2);
insert into t1 values (3);
insert into t1 values (4);
insert into t1 values (5);
select SQL_CALC_FOUND_ROWS * from t1 where id > 3 limit 0, 1;
select FOUND_ROWS();
select SQL_CALC_FOUND_ROWS * from t1 where id > 3 AND 1=2 limit 0, 1;
select FOUND_ROWS();
select SQL_CALC_FOUND_ROWS * from t1 where id > 6 limit 0, 1;
select FOUND_ROWS();
drop table t1;

#
# Other bugs with range optimization
#

# bug #2448

CREATE TABLE t1 ( a int not null, b int not null) partition by hash (a) partitions 3;
INSERT INTO t1 VALUES ( 47,    1  );
INSERT INTO t1 VALUES ( 70,    1  );
SELECT * FROM t1
WHERE
(
 ( b =1 AND a BETWEEN 14 AND 21 ) OR
 ( b =2 AND a BETWEEN 16 AND 18 ) OR
 ( b =3 AND a BETWEEN 15 AND 19 )
);
DROP TABLE t1;

# bug #2698

CREATE TABLE t1 ( a integer, u varchar(15), r integer, key uao_idx( r, a, u));
DELETE  FROM t1
WHERE (  r = 1 AND a IN ( 1, 2    ) AND ( u = 'w'   OR u LIKE 'w/%'   ) )
   OR (  r = 1 AND a IN (       3 ) AND ( u = 'w/U' OR u LIKE 'w/U/%' ) )
   OR (  r = 1 AND a IN ( 1, 2, 3 ) AND ( u = 'w'                     ) );
drop table t1;

#
# Bug #3738: we have a ref key
#

CREATE TABLE t1 (a VARCHAR(16)) partition by key(a) partitions 3;
INSERT INTO t1 VALUES ('1');
INSERT INTO t1 VALUES ('2');
INSERT INTO t1 VALUES ('3');
SELECT SQL_CALC_FOUND_ROWS * FROM t1 WHERE a = '2' LIMIT 0, 1;
SELECT FOUND_ROWS();
DROP TABLE t1;

#
# Bug #3845: group by, having and empty result
#

CREATE TABLE t1 (a INT) partition by key(a) partitions 3;
INSERT INTO t1 VALUES (0), (0);
INSERT INTO t1 VALUES (2), (2);
INSERT INTO t1 VALUES (1), (1);
SELECT SQL_CALC_FOUND_ROWS * FROM t1 WHERE a = 0 GROUP BY a HAVING a > 10;
SELECT FOUND_ROWS();
DROP TABLE t1;

#
# Bug #6089: queries which don't use any tables
#

SELECT 'foo';
SELECT FOUND_ROWS();
SELECT SQL_CALC_FOUND_ROWS 'foo';
SELECT FOUND_ROWS();
SELECT SQL_CALC_FOUND_ROWS 'foo' limit 0;
SELECT FOUND_ROWS();
SELECT FOUND_ROWS();

SELECT SQL_CALC_FOUND_ROWS 'foo' UNION SELECT 'bar' LIMIT 0;
SELECT FOUND_ROWS();

#
# Bug #7945: group by + distinct with constant expression + limit
#

CREATE TABLE t1 (a int, b int) partition by key(b) partitions 3;
INSERT INTO t1 VALUES (1,2);
INSERT INTO t1 VALUES (1,3);
INSERT INTO t1 VALUES (1,4);
INSERT INTO t1 VALUES (1,5);
SELECT SQL_CALC_FOUND_ROWS DISTINCT 'a' FROM t1 GROUP BY b LIMIT 2;
SELECT FOUND_ROWS();
DROP TABLE t1;



