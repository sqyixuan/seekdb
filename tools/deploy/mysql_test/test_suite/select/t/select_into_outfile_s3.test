#owner: linyi.cl
#owner group: sql3
#tags: optimizer

#--source mysql_test/include/oss_config_for_import.inc

let $RANDOM_NUM=query_get_value(select abs(random()) ran from dual,ran,1);
let $DATA_FOLDER_NAME = $S3_BUCKET/mysqltest_regression/select_into_outfile_s3_$RANDOM_NUM;

--disable_warnings
drop table if exists t1;
--enable_warnings

--result_format 4

create table t1(c1 int, c2 double, c3 float, c4 varchar(20), c5 char(20), c6 date, c7 bool);
insert into t1 values(1, 1.324, 2.3, 'hhhńŞşzzz', 'hhhňŤŻzzz', '2021-08-19', true);
insert into t1 values(2, 2.325, 3.2, 'hhhńŞşzŠÄĺzz', 'hhhňŤŻzšÉâzz', '2022-08-19', 0);
insert into t1 values(3, 3.14, 4.2, 'hhhńŞşzzz', 'hhhňŤŻzzz', '2023-08-19', 1);
insert into t1 values(4, 9.001, 5.10, 'hhhńŞşzzzňî╣ÚůŹ', 'hhhňŤŻzzzňôüšëî', '2024-08-19', false);
insert into t1 values(5, 2.181, 6.7, 'hhhńŞşzziiz', 'hkkhhňŤŻzzz', '2025-08-19', TRUE);
insert into t1 values(6, 1010, 29, 'hhhńŞşzzz6', 'hhhňŤŻzz66z', '2026-08-19', FALse);

--source mysql_test/include/select_into_outfile/delete_files_s3.inc
--source mysql_test/include/select_into_outfile/replace_s3_info.inc
eval select /*+parallel(2)*/* from t1 into outfile 's3://$DATA_FOLDER_NAME/?host=$S3_HOST&access_id=$S3_AK&access_key=$S3_SK&s3_region=$S3_REGION' single=false;
--source mysql_test/include/select_into_outfile/replace_s3_info.inc
eval select * from 's3://$DATA_FOLDER_NAME/?host=$S3_HOST&access_id=$S3_AK&access_key=$S3_SK&s3_region=$S3_REGION' (FORMAT( type='csv'));
--source mysql_test/include/select_into_outfile/list_dir_s3.inc

--source mysql_test/include/select_into_outfile/delete_files_s3.inc
--source mysql_test/include/select_into_outfile/replace_s3_info.inc
eval select /*+parallel(2)*/* from t1 order by c1 into outfile 's3://$DATA_FOLDER_NAME/?host=$S3_HOST&access_id=$S3_AK&access_key=$S3_SK&s3_region=$S3_REGION' single=false;
--source mysql_test/include/select_into_outfile/replace_s3_info.inc
eval select * from 's3://$DATA_FOLDER_NAME/?host=$S3_HOST&access_id=$S3_AK&access_key=$S3_SK&s3_region=$S3_REGION' (FORMAT( type='csv'));
--source mysql_test/include/select_into_outfile/list_dir_s3.inc

--source mysql_test/include/select_into_outfile/delete_files_s3.inc
--source mysql_test/include/select_into_outfile/replace_s3_info.inc
eval select /*+parallel(2)*/* from t1 into outfile 's3://$DATA_FOLDER_NAME/?host=$S3_HOST&access_id=$S3_AK&access_key=$S3_SK&s3_region=$S3_REGION' single=false max_file_size='120B';
--source mysql_test/include/select_into_outfile/replace_s3_info.inc
eval select * from 's3://$DATA_FOLDER_NAME/?host=$S3_HOST&access_id=$S3_AK&access_key=$S3_SK&s3_region=$S3_REGION' (FORMAT( type='csv'));
--source mysql_test/include/select_into_outfile/list_dir_s3.inc

drop table t1;

--source mysql_test/include/select_into_outfile/delete_files_s3.inc
