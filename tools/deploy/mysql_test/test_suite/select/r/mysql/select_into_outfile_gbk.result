set names gbk;
DROP TABLE IF EXISTS T1;
=======================
CREATE TABLE t1(c1 varchar(100) collate utf8mb4_bin, c2 varchar(100) collate gbk_bin);
INSERT INTO t1 VALUES ('测试', '数据');
SELECT * INTO OUTFILE  'data_for_mysqltest_select_into_outfile/temp1' CHARSET GBK FIELDS TERMINATED BY '列分隔' ENCLOSED BY '"' LINES TERMINATED BY '换行\n' FROM t1;

