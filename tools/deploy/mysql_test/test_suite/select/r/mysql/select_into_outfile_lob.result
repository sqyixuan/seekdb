CREATE TABLE big_json_table (
id INT AUTO_INCREMENT PRIMARY KEY,
big_json JSON
);
SET @big_json = JSON_OBJECT('key1', REPEAT('This is a long text', 262144));
INSERT INTO big_json_table (big_json) VALUES (@big_json),(@big_json);
select * from big_json_table into outfile 'select_into_outfile_lob/data1' single=false;
data1_0.csv
select /*+parallel(2)*/ * from big_json_table into outfile 'select_into_outfile_lob/data1' single=false;
data1_0_0_0.csv
data1_0_1_0.csv
drop table t1,big_json_table;
