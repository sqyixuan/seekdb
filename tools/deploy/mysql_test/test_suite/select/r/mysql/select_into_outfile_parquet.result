CREATE TABLE t1 (
    id INT,
    value_float FLOAT,
    value_double DOUBLE,
    value_date DATE,
    value_decimal32 DECIMAL(12, 2),
    value_decimal64 DECIMAL(20, 4),
    value_decimal128 DECIMAL(38, 6),
    value_datetime DATETIME(3),
    value_timestamp TIMESTAMP(3),
    value_varchar VARCHAR(255)
);

SELECT * FROM t1
into outfile 'data_for_mysqltest_select_into_outfile_parquet/data1.parquet'
format = (TYPE = 'PARQUET');
data1.parquet
create external table t1_ext (
    id int,
    value_float float,
    value_double double,
    value_date date,
    value_decimal32 decimal(12,2),
    value_decimal64 decimal(20,4),
    value_decimal128 decimal(38,6),
    value_datetime DATETIME(3),
    value_timestamp TIMESTAMP(3),
    value_varchar varchar(255)
)
format (type = 'PARQUET') location 'data_for_mysqltest_select_into_outfile_parquet' auto_refresh = IMMEDIATE;

select * from t1_ext;
