## with lob type
create table t_lob(c1 int, c2 varchar(20), c3 text);
insert /*+append enable_parallel_dml parallel(8) */ into t_lob
select UNIFORM(1, 10000, random(7)), RANDSTR(20, random(7)), repeat(RANDSTR(20, random(7)), 1000) from table(generator(100));
select /*+parallel(2)*/* from t_lob into outfile 'data_for_mysqltest_select_into_outfile_compression/data1.csv'
format = (TYPE = 'CSV',
FIELD_DELIMITER = ',',
ENCODING = 'utf8mb4',
COMPRESSION = zstd) single = false MAX_FILE_SIZE = 1048576;
create external table t_lob_external (c1 int, c2 varchar(20), c3 text)
format (type = 'CSV',
FIELD_DELIMITER = ',',
ENCODING = 'utf8mb4',
compression = zstd) location 'data_for_mysqltest_select_into_outfile_compression';
select count(*) from t_lob_external;
count(*)
100
data1.csv_0_0_0.csv.zst
data1.csv_0_1_0.csv.zst
## with BUFFER_SIZE
SELECT /*+parallel(5)*/* FROM t_lob
into outfile 'data_for_mysqltest_select_into_outfile_compression/data1.csv'
format = (TYPE = 'CSV',
FIELD_DELIMITER = ',',
ENCODING = 'utf8mb4',
COMPRESSION = zstd) single = false MAX_FILE_SIZE=1048576 BUFFER_SIZE= '2KB';
create external table t_buffer_size_external (c1 int, c2 varchar(20), c3 text)
format (type = 'CSV',
FIELD_DELIMITER = ',',
ENCODING = 'utf8mb4',
compression = zstd) location 'data_for_mysqltest_select_into_outfile_compression';
select count(*) from t_buffer_size_external;
count(*)
100
data1.csv_0_0_0.csv.zst
data1.csv_0_1_0.csv.zst
data1.csv_0_2_0.csv.zst
data1.csv_0_3_0.csv.zst
data1.csv_0_4_0.csv.zst
DROP TABLE t1, t_gzip_external, t_deflate_external, t_zstd_external, t_lob, t_lob_external, t_buffer_size_external;
