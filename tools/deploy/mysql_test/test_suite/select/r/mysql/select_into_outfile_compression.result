insert into t1 values(4, 9.001, 5.10, 'hhhńŞşzzzňî╣ÚůŹ', 'hhhňŤŻzzzňôüšëî', '2023-08-19', false, '02:00:00');
insert into t1 values(5, 2.181, 6.7, 'hhhńŞşzziiz', 'hkkhhňŤŻzzz', '2021-08-19', TRUE, '00:00:00');
insert into t1 values(6, 1010, 29, 'hhhńŞşzzz6', 'hhhňŤŻzz66z', '2023-08-19', FALse, '00:03:00');
## basic test
SELECT * FROM t1
into outfile 'data_for_mysqltest_select_into_outfile_compression/data1.csv'
format = (TYPE = 'CSV',
FIELD_DELIMITER = ',',
ENCODING = 'utf8mb4',
COMPRESSION = gzip);
create external table t_gzip_external (
c1 int,
c2 double,
c3 float,
c4 varchar(20),
c5 char(20),
c6 date,
c7 bool,
c8 time
)
format (type = 'CSV',
FIELD_DELIMITER = ',',
ENCODING = 'utf8mb4',
compression = gzip) location 'data_for_mysqltest_select_into_outfile_compression';
select * from t_gzip_external;
