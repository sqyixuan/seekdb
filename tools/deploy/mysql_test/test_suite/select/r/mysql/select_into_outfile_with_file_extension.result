drop table if exists t1;
set ob_query_timeout = 10000000000;
create table t1(c1 int);
insert into t1 values(1);
insert into t1 values(2);
## single = true
SELECT * FROM t1
into outfile 'data_for_mysqltest_select_into_outfile_compression/data1'
format = (TYPE = 'CSV',
FIELD_DELIMITER = ',',
ENCODING = 'utf8mb4') single = true;
data1
SELECT * FROM t1
into outfile 'data_for_mysqltest_select_into_outfile_compression/data1'
format = (TYPE = 'CSV',
FIELD_DELIMITER = ',',
ENCODING = 'utf8mb4'
          FILE_EXTENSION = '.abc') single = true;
data1
SELECT * FROM t1
into outfile 'data_for_mysqltest_select_into_outfile_compression/data1'
format = (TYPE = 'PARQUET') single=true;
data1
## single = false
SELECT * FROM t1
into outfile 'data_for_mysqltest_select_into_outfile_compression/data1'
format = (TYPE = 'CSV',
FIELD_DELIMITER = ',',
ENCODING = 'utf8mb4') single=false;
data1_0.csv
SELECT * FROM t1
into outfile 'data_for_mysqltest_select_into_outfile_compression/data1'
format = (TYPE = 'CSV',
FIELD_DELIMITER = ',',
ENCODING = 'utf8mb4',
FILE_EXTENSION = '.abc') single=false;
data1_0.abc
SELECT * FROM t1
into outfile 'data_for_mysqltest_select_into_outfile_compression/data1'
format = (TYPE = 'CSV',
FIELD_DELIMITER = ',',
ENCODING = 'utf8mb4',
FILE_EXTENSION = 'abc') single=false;
data1_0.abc
SELECT /*parallel(2)*/* FROM t1
into outfile 'data_for_mysqltest_select_into_outfile_compression/data1'
format = (TYPE = 'CSV',
FIELD_DELIMITER = ',',
ENCODING = 'utf8mb4',
COMPRESSION = gzip) single=false;
data1_0.csv.gz
SELECT /*parallel(2)*/* FROM t1
into outfile 'data_for_mysqltest_select_into_outfile_compression/data1'
format = (TYPE = 'CSV',
FIELD_DELIMITER = ',',
ENCODING = 'utf8mb4',
COMPRESSION = gzip,
FILE_EXTENSION = '.abc') single=false;
data1_0.abc.gz
SELECT /*parallel(2)*/* FROM t1
into outfile 'data_for_mysqltest_select_into_outfile_compression/data1'
format = (TYPE = 'PARQUET') single=false;
data1_0.parquet
SELECT /*parallel(2)*/* FROM t1
into outfile 'data_for_mysqltest_select_into_outfile_compression/data1'
format = (TYPE = 'PARQUET'
          COMPRESSION = gzip) single=false;
