--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: luofan.zp
# owner group: SQL3
# description: 本case是为了测试唯一索引中包含timestamp列的生效性问题。

connect (admin,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);

connection default;

--disable_warnings
drop table if exists ob_custid;
--enable_warnings

CREATE TABLE ob_custid (
gmt_create datetime default now()
, gmt_modify datetime default now()
, custid INT
, thedate TIMESTAMP
, cost INT
, PRIMARY KEY(custid, thedate)
) PROGRESSIVE_MERGE_NUM = 1, EXPIRE_INFO = (gmt_create < date_sub(merging_frozen_time(), INTERVAL 1 DAY)), COMPRESSION = 'snappy_1.0', DEFAULT CHARSET = 'utf8' ;
create unique index  idx1 on ob_custid(thedate,cost);

connection admin;
let $idx1 = query_get_value(select a.table_name from oceanbase.__all_virtual_table as a inner join (select * from oceanbase.__all_virtual_table where table_name='ob_custid') b on a.data_table_id=b.table_id, table_name, 1);

connection default;
insert into ob_custid(custid,thedate,cost) values(1,'2014-09-25 12:00:00',7);
insert into ob_custid(custid,thedate,cost) values(2,'2014-09-25 12:00:00',6);
insert into ob_custid(custid,thedate,cost) values(3,'2014-09-25 12:00:00',5);
insert into ob_custid(custid,thedate,cost) values(4,'2014-09-25 12:00:00',4);
insert into ob_custid(custid,thedate,cost) values(5,'2014-09-25 12:00:00',3);
insert into ob_custid(custid,thedate,cost) values(6,'2014-09-25 12:00:00',2);
insert into ob_custid(custid,thedate,cost) values(7,'2014-09-25 12:00:00',1);
sleep 1;
--error 1062
insert into ob_custid(custid,thedate,cost) values(7,'2014-09-25 12:00:00',3);
--error 1062
insert into ob_custid(custid,thedate,cost) values(8,'2014-09-25 12:00:00',1);
update ob_custid set custid=11 , thedate=now() where custid=1;
select  custid,cost from ob_custid where custid=11;
--source mysql_test/include/check_all_idx_ok_unq.inc
--source mysql_test/include/check_all_idx_ok.inc
--error 1062
insert into ob_custid(custid,thedate,cost) values(7,'2014-09-25 12:00:00',3);
--error 1062
insert into ob_custid(custid,thedate,cost) values(7,'2014-09-25 12:00:00',1);
update ob_custid set custid=11 , thedate=now() where custid=1;
drop table ob_custid;
