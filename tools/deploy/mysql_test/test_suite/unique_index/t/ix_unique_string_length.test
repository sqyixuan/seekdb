--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: luofan.zp
#owner group:sql1
#description:case trans from mysql
--disable_warnings
DROP TABLE IF EXISTS t3;
--enable_warnings
CREATE TABLE t3(c1 CHAR(50) NULL);
CREATE UNIQUE INDEX i1 ON t3(c1);
SHOW TABLES like 't3'; 
let $ENGINE=`select variable_value from information_schema.global_variables where variable_name='STORAGE_ENGINE'`;
#--replace_result $ENGINE ENGINE " PAGE_CHECKSUM=0" ""
 --source mysql_test/include/show_create_table_old_version.inc
 show create table t3; DROP TABLE t3; SHOW TABLES like 't3';
