drop table if exists ob_custid;
CREATE TABLE ob_custid (
gmt_create datetime default now()
, gmt_modify datetime default now()
, custid INT
, thedate TIMESTAMP
, cost INT
, PRIMARY KEY(custid, thedate)
) PROGRESSIVE_MERGE_NUM = 1, EXPIRE_INFO = (gmt_create < date_sub(merging_frozen_time(), INTERVAL 1 DAY)), COMPRESSION = 'snappy_1.0', DEFAULT CHARSET = 'utf8' ;
create unique index  idx1 on ob_custid(thedate,cost);
insert into ob_custid(custid,thedate,cost) values(1,'2014-09-25 12:00:00',7);
