##### owner: jingfeng.jf
##### owner group: SQL_3
##### description: query_record_size_limit = 67108864
##### author: wb-lyq858317
##### tags: sql_audit


--echo 使用67108864长度测试
alter system set _query_record_size_limit = 67108864;

sleep 5;
alter system flush sql audit global;
alter system flush plan cache global;

--echo 执行超长的sql
--disable_query_log  
--disable_result_log  

--source mysql_test/test_suite/sql_query_interface_sqlqa/include/audit_size1.sql

--enable_query_log  
--enable_result_log
--echo 显示完整sql
--echo 预期显示完整sql，目前这里有问题，会被截断，已提交问题
select QUERY_SQL from oceanbase.gv$ob_sql_audit where QUERY_SQL like '%sql_audit_query_sql_size%';
--echo 显示完整sql
select query_sql from oceanbase.__all_virtual_plan_stat where query_sql like '%sql_audit_query_sql_size_0%';

alter system flush sql audit global;
alter system flush plan cache global;

--echo 恢复默认长度
alter system set _query_record_size_limit = 65536;



