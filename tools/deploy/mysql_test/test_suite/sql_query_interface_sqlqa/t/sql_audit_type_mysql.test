--error 0,1051 
drop table tbl1;
create table tbl1(c1 char(10));
select QUERY_SQL,stmt_type from oceanbase.gv$ob_sql_audit where QUERY_SQL like "drop table tbl1%" limit 1;


ALTER TABLE tbl1 ADD c3 INT;
select QUERY_SQL,stmt_type from oceanbase.gv$ob_sql_audit where QUERY_SQL like "ALTER TABLE tbl1 ADD c3 INT%" limit 1;

ALTER TABLE tbl1 CHANGE COLUMN c1 c4 VARCHAR(50);
select QUERY_SQL,stmt_type from oceanbase.gv$ob_sql_audit where QUERY_SQL like "ALTER TABLE tbl1 CHANGE COLUMN c1 c4 VARCHAR(50)%" limit 1;

CREATE INDEX tbl1_index ON tbl1 (c3 ASC);
select QUERY_SQL,stmt_type from oceanbase.gv$ob_sql_audit where QUERY_SQL like "CREATE INDEX tbl1_index ON tbl1 (c3 ASC)%" limit 1;

DROP INDEX tbl1_index ON tbl1;
select QUERY_SQL,stmt_type from oceanbase.gv$ob_sql_audit where QUERY_SQL = "DROP INDEX tbl1_index ON tbl1" limit 1;

CREATE OR REPLACE VIEW v(vc1, vc2) AS SELECT c4, c3 FROM tbl1;
select QUERY_SQL,stmt_type from oceanbase.gv$ob_sql_audit where QUERY_SQL like "CREATE OR REPLACE VIEW v(vc1, vc2) AS SELECT c4, c3 FROM tbl1%" limit 1;

CREATE OR REPLACE VIEW view1 AS SELECT * FROM tbl1 WHERE c4 > 0 WITH LOCAL CHECK OPTION;
select QUERY_SQL,stmt_type from oceanbase.gv$ob_sql_audit where QUERY_SQL like "CREATE OR REPLACE VIEW view1 AS SELECT * FROM tbl1 WHERE c4 > 0 WITH LOCAL CHECK OPTION%" limit 1;

CREATE OR REPLACE VIEW view2 AS SELECT * FROM view1 WHERE c4 > 1 WITH CASCADED CHECK OPTION;
select QUERY_SQL,stmt_type from oceanbase.gv$ob_sql_audit where QUERY_SQL like "CREATE OR REPLACE VIEW view2 AS SELECT * FROM view1 WHERE c4 > 1 WITH CASCADED CHECK OPTION%" limit 1;

ALTER VIEW view2 AS SELECT * FROM tbl1;
select QUERY_SQL,stmt_type from oceanbase.gv$ob_sql_audit where QUERY_SQL like "ALTER VIEW view2 AS SELECT * FROM tbl1%" limit 1;

DROP VIEW view2;
select QUERY_SQL,stmt_type from oceanbase.gv$ob_sql_audit where QUERY_SQL like "DROP VIEW view2%" limit 1;

