--error 0,1051 
drop table tbl1;
create table tbl1(c1 char(10));

alter system flush sql audit global;
alter system set _query_record_size_limit = 65536;
sleep 5;

select c1 from tbl1;
select QUERY_SQL,stmt_type from oceanbase.gv$ob_sql_audit where QUERY_SQL like "select c1 from tbl1%" limit 1;


insert into tbl1 values('a');
select QUERY_SQL,stmt_type from oceanbase.gv$ob_sql_audit where QUERY_SQL like "insert into tbl1 values('a')%" limit 1;

INSERT INTO tbl1 SELECT 1;
select QUERY_SQL,stmt_type from oceanbase.gv$ob_sql_audit where QUERY_SQL like "INSERT INTO tbl1 SELECT%" limit 1;

