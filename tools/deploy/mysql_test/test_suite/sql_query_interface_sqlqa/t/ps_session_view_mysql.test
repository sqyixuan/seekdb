# tags: 


#tenant_id、svr_ip、svr_port、proxy_session_id、SESSION_ID 会变化，不方便递交

#ps_client_stmt_id
PREPARE proxy_session_id1 FROM 'SELECT SQRT(POW(?,2) + POW(?,2))';
select STMT_TYPE,PARAM_COUNT,REF_COUNT FROM oceanbase.GV$OB_SESSION_PS_INFO order by STMT_TYPE,PARAM_TYPES,REF_COUNT;

PREPARE session_id1 FROM 'SELECT SQRT(POW(?,2) + POW(?,2))';
--disable_result_log
select STMT_TYPE,PARAM_COUNT,REF_COUNT FROM oceanbase.GV$OB_SESSION_PS_INFO order by STMT_TYPE,PARAM_TYPES,REF_COUNT;
--enable_result_log
deallocate prepare proxy_session_id1;
select STMT_TYPE,PARAM_COUNT,REF_COUNT FROM oceanbase.GV$OB_SESSION_PS_INFO order by STMT_TYPE,PARAM_TYPES,REF_COUNT;
deallocate prepare session_id1;
select STMT_TYPE,PARAM_COUNT,REF_COUNT FROM oceanbase.GV$OB_SESSION_PS_INFO order by STMT_TYPE,PARAM_TYPES,REF_COUNT;

#stmt_type
#不同sql类型
--error 0,1051
drop table tbl1;
create table tbl1(c1 char(20));
insert into tbl1 values(2);

PREPARE param_count10 FROM 'ALTER TABLE tbl1 ADD c3 INT';
EXECUTE param_count10;
select STMT_TYPE,PARAM_COUNT,REF_COUNT FROM oceanbase.GV$OB_SESSION_PS_INFO order by STMT_TYPE,PARAM_TYPES,REF_COUNT;

PREPARE param_count11 FROM 'ALTER TABLE tbl1 DROP c3';
EXECUTE param_count11;
select STMT_TYPE,PARAM_COUNT,REF_COUNT FROM oceanbase.GV$OB_SESSION_PS_INFO order by STMT_TYPE,PARAM_TYPES,REF_COUNT;

PREPARE param_count20 FROM 'CREATE INDEX tbl1_index ON tbl1 (c1 ASC)';
EXECUTE param_count20;
select STMT_TYPE,PARAM_COUNT,REF_COUNT FROM oceanbase.GV$OB_SESSION_PS_INFO order by STMT_TYPE,PARAM_TYPES,REF_COUNT;

deallocate prepare param_count10;
select STMT_TYPE,PARAM_COUNT,REF_COUNT FROM oceanbase.GV$OB_SESSION_PS_INFO order by STMT_TYPE,PARAM_TYPES,REF_COUNT;
deallocate prepare param_count11;
select STMT_TYPE,PARAM_COUNT,REF_COUNT FROM oceanbase.GV$OB_SESSION_PS_INFO order by STMT_TYPE,PARAM_TYPES,REF_COUNT;

PREPARE param_count30 FROM 'drop INDEX tbl1_index ON tbl1';
EXECUTE param_count30;
select STMT_TYPE,PARAM_COUNT,REF_COUNT FROM oceanbase.GV$OB_SESSION_PS_INFO order by STMT_TYPE,PARAM_TYPES,REF_COUNT;

PREPARE param_count31 FROM 'INSERT INTO tbl1(c1) SELECT ? from dual;';
SET @a = 3;
EXECUTE param_count31 USING @a;
select STMT_TYPE,PARAM_COUNT,REF_COUNT FROM oceanbase.GV$OB_SESSION_PS_INFO order by STMT_TYPE,PARAM_TYPES,REF_COUNT;


deallocate prepare param_count20;
select STMT_TYPE,PARAM_COUNT,REF_COUNT FROM oceanbase.GV$OB_SESSION_PS_INFO order by STMT_TYPE,PARAM_TYPES,REF_COUNT;
deallocate prepare param_count30;
select STMT_TYPE,PARAM_COUNT,REF_COUNT FROM oceanbase.GV$OB_SESSION_PS_INFO order by STMT_TYPE,PARAM_TYPES,REF_COUNT;

PREPARE param_count32 FROM 'SELECT * from tbl1 where c1 > ? and c1 < ?;';
SET @a = 2;
SET @b = 4;
EXECUTE param_count32 USING @a, @b;
select distinct t1.STMT_TYPE FROM oceanbase.GV$OB_SESSION_PS_INFO t1 
right join oceanbase.GV$OB_PS_ITEM_INFO t2 on t1.CHECKSUM = t2.CHECKSUM  order by t1.STMT_TYPE;
alter system flush ps cache;
START TRANSACTION;

PREPARE param_count33 FROM 'UPDATE tbl1 SET c1 = ?  WHERE c1 = ?;';
SET @a = 3;
SET @b = 2;
EXECUTE param_count33 USING @a, @b;

select * from tbl1;
select STMT_TYPE,PARAM_COUNT,REF_COUNT FROM oceanbase.GV$OB_SESSION_PS_INFO order by STMT_TYPE,PARAM_TYPES,REF_COUNT;

rollback;
select * from tbl1;

select STMT_TYPE,PARAM_COUNT,REF_COUNT FROM oceanbase.GV$OB_SESSION_PS_INFO order by STMT_TYPE,PARAM_TYPES,REF_COUNT;

PREPARE param_count34 FROM 'DELETE FROM tbl1 WHERE c1 = ?;';
SET @a = 2;
EXECUTE param_count34 USING @a;
select distinct t1.STMT_TYPE FROM oceanbase.GV$OB_SESSION_PS_INFO t1 
left join oceanbase.GV$OB_PS_ITEM_INFO t2 on t1.CHECKSUM = t2.CHECKSUM where t2.STMT_TYPE = 4 order by t1.STMT_TYPE;

select * from tbl1;

PREPARE param_count30 FROM 'TRUNCATE TABLE tbl1;';
EXECUTE param_count30;
select distinct t1.STMT_TYPE FROM oceanbase.GV$OB_SESSION_PS_INFO t1 
inner join oceanbase.GV$OB_PS_ITEM_INFO t2 on t1.CHECKSUM = t2.CHECKSUM group by t1.STMT_TYPE order by t1.STMT_TYPE;


#param_count 
#ps的参数数量

PREPARE param_count0 FROM 'SELECT POW(2,2)';
select distinct t1.STMT_TYPE FROM oceanbase.GV$OB_SESSION_PS_INFO t1 
left join oceanbase.GV$OB_PS_ITEM_INFO t2 on t1.CHECKSUM = t2.CHECKSUM 
group by t2.STMT_TYPE having t2.STMT_TYPE >= 1 order by t1.STMT_TYPE;

PREPARE param_count12 FROM 'SELECT POW(?,2), POW(?,2), POW(?,2),POW(?,2), POW(?,2), POW(?,2),POW(?,2), POW(?,2), POW(?,2),POW(?,2), POW(?,2), POW(?,2),POW(?,2), POW(?,2), 
POW(?,2),POW(?,2), POW(?,2), POW(?,2),POW(?,2), POW(?,2), POW(?,2),POW(?,2), POW(?,2), POW(?,2),POW(?,2), POW(?,2), POW(?,2),POW(?,2), POW(?,2), POW(?,2),POW(?,2), POW(?,2), 
POW(?,2),POW(?,2), POW(?,2), POW(?,2),POW(?,2), POW(?,2), POW(?,2),POW(?,2), POW(?,2), POW(?,2),POW(?,2), POW(?,2), POW(?,2),POW(?,2), POW(?,2), POW(?,2),POW(?,2), POW(?,2), 
POW(?,2),POW(?,2), POW(?,2), POW(?,2),POW(?,2), POW(?,2), POW(?,2),POW(?,2), POW(?,2), POW(?,2),POW(?,2), POW(?,2), POW(?,2),POW(?,2), POW(?,2), POW(?,2),POW(?,2), POW(?,2), 
POW(?,2),POW(?,2), POW(?,2), POW(?,2),POW(?,2), POW(?,2), POW(?,2),POW(?,2), POW(?,2), POW(?,2),POW(?,2), POW(?,2), POW(?,2),POW(?,2), POW(?,2), POW(?,2),POW(?,2), POW(?,2), 
POW(?,2),POW(?,2), POW(?,2), POW(?,2),POW(?,2), POW(?,2), POW(?,2),POW(?,2), POW(?,2), POW(?,2),POW(?,2), POW(?,2), POW(?,2),POW(?,2), POW(?,2), POW(?,2),POW(?,2), POW(?,2), 
POW(?,2),POW(?,2), POW(?,2), POW(?,2)';
select distinct t1.STMT_TYPE FROM oceanbase.GV$OB_SESSION_PS_INFO t1 
join oceanbase.GV$OB_PS_ITEM_INFO t2 on t1.CHECKSUM = t2.CHECKSUM group by t1.STMT_TYPE order by t1.STMT_TYPE;


WITH RECURSIVE ps_t AS (
    SELECT STMT_TYPE FROM oceanbase.GV$OB_SESSION_PS_INFO t1 
    UNION ALL

    SELECT t1.STMT_TYPE
    FROM oceanbase.GV$OB_SESSION_PS_INFO t1 
    INNER JOIN oceanbase.GV$OB_PS_ITEM_INFO t2 ON t1.CHECKSUM = t2.CHECKSUM
)
SELECT distinct * FROM ps_t;

deallocate prepare param_count31;
deallocate prepare param_count32;
deallocate prepare param_count33;
deallocate prepare param_count34;
deallocate prepare param_count30;
deallocate prepare param_count0;
deallocate prepare param_count12;
select STMT_TYPE,PARAM_COUNT,REF_COUNT FROM oceanbase.GV$OB_SESSION_PS_INFO order by STMT_TYPE,PARAM_TYPES,REF_COUNT;
alter system flush ps cache;
--error 0,1051
drop table tbl1;