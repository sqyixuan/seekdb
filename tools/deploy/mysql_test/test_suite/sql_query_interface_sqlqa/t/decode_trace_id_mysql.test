#select decode_trace_id(last_trace_id()) from dual; 
select decode_trace_id('YE60364586D82-000612F99AE60B70-0-0') from dual; 

select decode_trace_id(upper('YE11111111D82-000612F99AE60B70-0-0')) from dual; 
select decode_trace_id(upper('YE11111111D82-000612F99AE60B70-9-9')) from dual; 
select decode_trace_id(upper('YE60364586D82-000612F99AE60B70-0-0')) from dual; 
select decode_trace_id(upper('Y0-0000000000000001-0-0')) from dual; 

#ipv4的都是以Y开头的字符串 ipv6的都是以Z开头的,  ipv6解析结果，上传递交会乱码，导致result文法正常查看，故注释
#select decode_trace_id(upper('ZE00000000D00-000000F00AE00B00-0-0')) from dual; 
#select decode_trace_id(upper('YE00000000D00-000000F00AE00B00-0-0')) from dual; 
#select decode_trace_id('ZE60364586D82-000612F99AE60B70-0-0') from dual; 
#select decode_trace_id('ZFFFFF-FFFFFFFF-FFFFF-0-0') from dual; 
