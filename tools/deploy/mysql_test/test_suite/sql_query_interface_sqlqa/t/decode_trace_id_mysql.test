#select decode_trace_id('ZFFFFF-FFFFFFFFFFFFFFFFFFFFFFF-1-1') from dual;
#select decode_trace_id('ZFFFFF-FFFFFFFF-1-1') from dual;
#select decode_trace_id('Z0000-00000000000-1-1') from dual;
#select decode_trace_id('ZAAAAA-AAAAAAAAAAA-1-1') from dual;
#select length(decode_trace_id('ZAAAAA-AAAAAAAAAAA-1-1')) from dual;
#

select decode_trace_id('YFFFFF-FFFFFFFF-FFFFF-0-0') from dual; 
--error 1210
select decode_trace_id('YFFFFF-FFFFFFFFFFFFFFFFFFFFFFF-1-1') from dual;
select decode_trace_id('YFFFFF-FFFFFFFF-1-1') from dual;
select decode_trace_id('Y0000-00000000000-1-1') from dual;
select decode_trace_id('YAAAAA-AAAAAAAAAAA-1-1') from dual;

--error 1210
select decode_trace_id(upper('YE6gasdg86D82-000612F99AE60B12-0-0')) from dual; 
--error 1210
select decode_trace_id(count('YE60364586D82-000612F99AE60B70')) from dual; 
#不符合格式要求的输出都是0.0.0.0:0
#符合格式的但是数据不对的，造成的解析失败都是报错的
#--error 1210
select decode_trace_id(lower('YE60364586D82-000612F99AE60B70-99-')) from dual; 
--error 1210
select decode_trace_id(11111111111111111111111) from dual; 

#--error 1210
select decode_trace_id('~!#@!#%$#^$%*^&^()') from dual; 
--error 1582
select decode_trace_id() from dual; 

#--error 1210
#select decode_trace_id(decode_trace_id(last_trace_id()) ) from dual; 

select length(decode_trace_id('YE60364586D82-000612F99AE60B70-0-0')) from dual;
select decode_trace_id('YE60364586D82-000612F99AE60B70-0-0') from dual where decode_trace_id('YE60364586D82-000612F99AE60B70-0-0') = 20;
select decode_trace_id('YE60364586D82-000612F99AE60B70-0-0') from dual where decode_trace_id('YE60364586D82-000612F99AE60B70-0-0') >= 20;
select decode_trace_id('YE60364586D82-000612F99AE60B70-0-0') from dual where decode_trace_id('YE60364586D82-000612F99AE60B70-0-0') <= 20;
select decode_trace_id('YE60364586D82-000612F99AE60B70-0-0') from dual where length(decode_trace_id('YE60364586D82-000612F99AE60B70-0-0')) = 20;

select decode_trace_id('YE60364586D82-000612F99AE60B70-0-0') from dual where decode_trace_id('YE60364586D82-000612F99AE60B70-0-0') >= 101;
select decode_trace_id('YE60364586D82-000612F99AE60B70-0-0') from dual where decode_trace_id('YE60364586D82-000612F99AE60B70-0-0') >= 100;
select decode_trace_id('YE60364586D82-000612F99AE60B70-0-0') from dual where decode_trace_id('YE60364586D82-000612F99AE60B70-0-0') = 100;
select decode_trace_id('YE60364586D82-000612F99AE60B70-0-0') from dual where decode_trace_id('YE60364586D82-000612F99AE60B70-0-0') = 100.88;

select decode_trace_id('YE60364586D82-000612F99AE60B70-0-0') * 2 from dual;
select decode_trace_id('YE60364586D82-000612F99AE60B70-0-0') - decode_trace_id('YE60364586D82-000612F99AE60B70-0-0') from dual; 
select decode_trace_id('YE60364586D82-000612F99AE60B70-0-0') / 2  from dual; 
select decode_trace_id('YE60364586D82-000612F99AE60B70-0-0') + decode_trace_id('YE11111111D82-000612F99AE60B70-0-0') from dual; 
