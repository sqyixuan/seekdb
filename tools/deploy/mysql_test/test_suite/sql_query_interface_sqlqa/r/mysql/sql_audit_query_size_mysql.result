result_format: 4
参数边界值测试
alter system set _query_record_size_limit = 10000000000000000000;
ERROR HY000: Invalid config
alter system set _query_record_size_limit = -10;
ERROR HY000: Invalid config
alter system set _query_record_size_limit = 1000.10;
ERROR HY000: Invalid config
alter system set _query_record_size_limit = '1263*42';
ERROR HY000: Invalid config
alter system set _query_record_size_limit = '100';
drop table t1;
CREATE TABLE t1 (c1 char(255));
使用0长度测试
alter system set _query_record_size_limit = 0;
alter system flush sql audit global;
alter system flush plan cache global;
执行sql
select c1 from t1;
+------+
| c1   |
+------+
+------+
查询不到记录，记录为空
select QUERY_SQL from oceanbase.gv$ob_sql_audit where QUERY_SQL = 'select c1 from t1';
+-----------+
| QUERY_SQL |
+-----------+
+-----------+
查询不到记录，记录为空
select query_sql from oceanbase.__all_virtual_plan_stat where query_sql = 'select c1 from t1';
+-----------+
| query_sql |
+-----------+
+-----------+
使用50长度测试
alter system set _query_record_size_limit = 50;
alter system flush sql audit global;
alter system flush plan cache global;
执行sql未超过50
select c1 as sql_audit from t1;
+-----------+
| sql_audit |
+-----------+
+-----------+
正常保存
select QUERY_SQL from oceanbase.gv$ob_sql_audit where QUERY_SQL like 'select c1 as sql_audit from%' limit 1;
+--------------------------------+
| QUERY_SQL                      |
+--------------------------------+
| select c1 as sql_audit from t1 |
+--------------------------------+
正常保存
select query_sql from oceanbase.__all_virtual_plan_stat where query_sql like 'select c1 as sql_audit from%' limit 1;
+--------------------------------+
| query_sql                      |
+--------------------------------+
| select c1 as sql_audit from t1 |
+--------------------------------+
alter system flush sql audit global;
alter system flush plan cache global;
执行sql超过50
select c1 as sql_audit_query_sql_size12345678987654321 from t1;
+-------------------------------------------+
| sql_audit_query_sql_size12345678987654321 |
+-------------------------------------------+
+-------------------------------------------+
被截断
select QUERY_SQL from oceanbase.gv$ob_sql_audit where QUERY_SQL like 'select c1 as sql_audit_query_sql_size%' limit 1;
+----------------------------------------------------+
| QUERY_SQL                                          |
+----------------------------------------------------+
| select c1 as sql_audit_query_sql_size1234567898765 |
+----------------------------------------------------+
被截断
select query_sql from oceanbase.__all_virtual_plan_stat where query_sql like 'select c1 as sql_audit_query_sql_size%' limit 1;
+----------------------------------------------------+
| query_sql                                          |
+----------------------------------------------------+
| select c1 as sql_audit_query_sql_size1234567898765 |
+----------------------------------------------------+
drop table t1;
alter system flush sql audit global;
alter system flush plan cache global;
恢复默认长度
alter system set _query_record_size_limit = 65536;
