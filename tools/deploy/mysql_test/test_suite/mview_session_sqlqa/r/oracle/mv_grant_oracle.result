DROP MATERIALIZED VIEW LOG ON t1;
drop materialized view mv1;
create materialized view mv1 REFRESH COMPLETE ON DEMAND ENABLE QUERY REWRITE DISABLE ON QUERY COMPUTATION AS select c3,c4,c6,count(*) a from t1 where to_char(c4) = '2023-01-01 00:00:00' group by c3,c4,c6;
