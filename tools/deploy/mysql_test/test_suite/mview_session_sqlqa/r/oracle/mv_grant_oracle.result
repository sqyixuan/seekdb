DROP MATERIALIZED VIEW LOG ON t1;
create materialized view log on t1 parallel 9 with PRIMARY KEY,rowid,sequence(c2,c3,c4,c5,c6,c7,c8,c10) including new values ;
DROP MATERIALIZED VIEW LOG ON t2;
create materialized view log on t2 parallel 9 with PRIMARY KEY,rowid,sequence(c2,c3,c4,c5,c6,c7,c8,c10) including new values ;
drop materialized view mv1;
create materialized view mv1(c3, c4, c5, a, PRIMARY KEY(c3)) REFRESH FAST ON DEMAND ENABLE QUERY REWRITE ENABLE ON QUERY COMPUTATION AS select t1.c3,t2.c4,t2.c5,count(*) a from t1 inner join t2 on t1.c1 = t2.c1 where to_char(t2.c5) = '2023-01-01 12:34:56.000000' group by t1.c3,t2.c4,t2.c5;
