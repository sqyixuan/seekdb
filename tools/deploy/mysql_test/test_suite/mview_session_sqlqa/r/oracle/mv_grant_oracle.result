DROP MATERIALIZED VIEW LOG ON t1;
drop table t1;
create table t1(c1 int,c2 varchar2(256),c3 TIMESTAMP, c4 DATE,c5 timestamp with local time zone,c6 TIMESTAMP(4),c7 timestamp(2) with time zone,c8 interval year(9) to month,c10 interval day(3) to second(4),primary key(c1));
