| C3                         | C4                  | C5                         | A    |
+----------------------------+---------------------+----------------------------+------+
| 2023-01-01 12:34:56.000000 | 2023-01-01 00:00:00 | 2023-01-01 12:34:56.000000 |    1 |
+----------------------------+---------------------+----------------------------+------+
select c3,c4,c5 from mv1 order by c4;
