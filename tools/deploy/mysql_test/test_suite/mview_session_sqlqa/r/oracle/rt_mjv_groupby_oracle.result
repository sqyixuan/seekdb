ALTER SESSION SET TIME_ZONE = '+08:00';
ALTER SESSION SET NLS_DATE_FORMAT = 'yyyy-mm-dd hh24:mi:ss';
ALTER SESSION SET nls_timestamp_format='YYYY-MM-DD HH24:MI:SS.FF';
ALTER SESSION SET nls_timestamp_tz_format='YYYY-MM-DD HH24:MI:SS.FF TZR TZD';
ALTER SESSION SET query_rewrite_enabled= true;
ALTER SESSION set QUERY_REWRITE_INTEGRITY = 'ENFORCED';
DROP MATERIALIZED VIEW LOG ON t1;
drop table t1;
create table t1(c1 int not null,c2 varchar2(256),c3 TIMESTAMP, c4 DATE,c5 timestamp with local time zone,c6 TIMESTAMP(4),c7 timestamp(2) with time zone,c8 interval year(9) to month,c10 interval day(3) to second(4),primary key(c1));
