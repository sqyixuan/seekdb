DROP MATERIALIZED VIEW LOG ON t1;
create materialized view log on t1 parallel 9 with PRIMARY KEY,rowid,sequence(c2,c3,c4,c5,c6,c7,c8,c10) including new values ;
DROP MATERIALIZED VIEW LOG ON t2;
create materialized view log on t2 with PRIMARY KEY,rowid,sequence(c2,c3,c4,c5,c6,c7,c8,c10) including new values ;
DROP MATERIALIZED VIEW LOG ON t3;
create materialized view log on t3  parallel 4 with PRIMARY KEY,rowid,sequence(c2,c3) including new values ;
drop materialized view mv1;
create materialized view mv1(c3, c4, c5, a, PRIMARY KEY(c3)) REFRESH COMPLETE ON DEMAND ENABLE QUERY REWRITE ENABLE ON QUERY COMPUTATION AS select t1.c3,t2.c4,t2.c5,count(*) a from t1 , t2 ,t3 where t1.c1 = t2.c1 and t2.c1 = t3.c1 group by t1.c3,t2.c4,t2.c5;
select t1.c3,t2.c4,t2.c5,count(*) a from t1 , t2 ,t3 where t1.c1 = t2.c1 and t2.c1 = t3.c1 group by t1.c3,t2.c4,t2.c5;
