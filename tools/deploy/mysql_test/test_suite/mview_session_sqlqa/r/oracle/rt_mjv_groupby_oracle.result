(1, 'example1', TIMESTAMP '2023-01-01 12:34:56', DATE '2023-01-01', 
TIMESTAMP '2023-01-01 12:34:56', TIMESTAMP '2023-01-01 12:34:56.1234', 
TIMESTAMP '2023-01-01 12:34:56.12 +00:00', INTERVAL '9-6' YEAR TO MONTH, INTERVAL '10 05:30:15.1234' DAY TO SECOND(4));
