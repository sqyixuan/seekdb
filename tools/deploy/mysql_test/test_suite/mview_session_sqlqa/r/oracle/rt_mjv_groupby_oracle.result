| C3                         | C4                  | C5                         |
+----------------------------+---------------------+----------------------------+
| 2023-01-01 12:34:56.000000 | 2023-01-01 00:00:00 | 2023-01-01 12:34:56.000000 |
+----------------------------+---------------------+----------------------------+
explain basic select t1.c3,t2.c4,t2.c5,count(*) a from t1 , t2 ,t3 where t1.c1 = t2.c1 and t2.c1 = t3.c1 group by t1.c3,t2.c4,t2.c5;
