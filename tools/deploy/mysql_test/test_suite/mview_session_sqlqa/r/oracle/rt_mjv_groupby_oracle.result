explain basic select t1.c3,t2.c4,t2.c5,count(*) a,count(t1.c1) countc1 from t1 inner join t2 on t1.c1 = t2.c1 inner join t3 on t2.c2 = t3.c2 group by t1.c3,t2.c4,t2.c5;
