全量刷新有group by的实时物化视图。
在time_zone='+08:00'下创建
time_zone='-08:00'查询 
SET time_zone='+08:00';
DROP MATERIALIZED VIEW LOG ON t1;
create materialized view log on t1 parallel 9 with PRIMARY KEY,rowid,sequence(c3,c4,c5,c6,c7,c8,c10,c11) including new values ;
drop materialized view mv1;
create materialized view mv1
REFRESH COMPLETE ON DEMAND
ENABLE QUERY REWRITE
ENABLE ON QUERY COMPUTATION
AS select c3,c4,c6,count(*) a from t1 group by c3,c4,c6;
变量参数设置一致时，原始查询/经过物化视图改写/直接使用物化视图的查询结果一致
select c3,c4,c6 from t1 group by c3,c4,c6 order by c4;
+----------------------------+------------+--------------------------+
| c3                         | c4         | c6                       |
+----------------------------+------------+--------------------------+
| 2023-01-01 12:34:56.123456 | 2023-01-01 | 2023-01-01 12:34:56.1234 |
| 2023-02-01 12:34:56.654321 | 2023-02-01 | 2023-02-01 12:34:56.6543 |
| 2023-03-01 12:34:56.000000 | 2023-03-01 | 2023-03-01 12:34:56.0000 |
+----------------------------+------------+--------------------------+
select /*+no_mv_rewrite*/ c4 from t1 group by c4 order by c4;
+------------+
| c4         |
+------------+
| 2023-01-01 |
| 2023-02-01 |
| 2023-03-01 |
+------------+
select /*+mv_rewrite(mv1)*/ c4 from t1 where CAST(c3 AS char(100)) >= '2023-01-01 12:34:56.123456' group by c4 order by c4;
+------------+
| c4         |
+------------+
| 2023-01-01 |
| 2023-02-01 |
| 2023-03-01 |
+------------+
select c3,c4,c6 from mv1  order by c4;
+----------------------------+------------+--------------------------+
| c3                         | c4         | c6                       |
+----------------------------+------------+--------------------------+
| 2023-01-01 12:34:56.123456 | 2023-01-01 | 2023-01-01 12:34:56.1234 |
| 2023-02-01 12:34:56.654321 | 2023-02-01 | 2023-02-01 12:34:56.6543 |
| 2023-03-01 12:34:56.000000 | 2023-03-01 | 2023-03-01 12:34:56.0000 |
+----------------------------+------------+--------------------------+
explain basic select c3,c4,c6 from t1 group by c3,c4,c6 order by c4;
