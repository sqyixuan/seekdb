增量刷新有主键，2表inner join的实时物化视图
在time_zone='+08:00'下创建
time_zone='-08:00'查询 
SET time_zone='+08:00';
DROP MATERIALIZED VIEW LOG ON t1;
create materialized view log on t1 parallel 9 with PRIMARY KEY,rowid,sequence(c3,c4,c5,c6,c7,c8,c10,c11) including new values ;
DROP MATERIALIZED VIEW LOG ON t2;
create materialized view log on t2 parallel 2 with PRIMARY KEY,rowid,sequence(c3,c4,c5,c6,c7,c8,c10,c11) including new values ;
drop materialized view mv1;
create materialized view mv1(c1, cc1 ,c2, cc2 , c3, c4, c6, PRIMARY KEY(c3))
REFRESH FAST ON DEMAND
ENABLE QUERY REWRITE
ENABLE ON QUERY COMPUTATION
AS select t1.c1 as aa, t2.c1 as bb,t1.c2 as aaa, t2.c2 as bbb,t1.c3 as a,t2.c4 as b ,t2.c6 as c from t1 inner join t2 on t1.c1 = t2.c1 ;
变量参数设置一致时，原始查询/经过物化视图改写/直接使用物化视图的查询结果一致
select /*+no_mv_rewrite*/ t1.c3 as a,t2.c4 as b ,t2.c6 as c from t1 inner join t2 on t1.c1 = t2.c1 order by t2.c4;
+----------------------------+------------+--------------------------+
| a                          | b          | c                        |
+----------------------------+------------+--------------------------+
| 2023-01-01 12:34:56.123456 | 2023-01-01 | 2023-01-01 12:34:56.1234 |
| 2023-02-01 12:34:56.654321 | 2023-02-01 | 2023-02-01 12:34:56.6543 |
| 2023-03-01 12:34:56.000000 | 2023-03-01 | 2023-03-01 12:34:56.0000 |
+----------------------------+------------+--------------------------+
select t1.c3 as a,t2.c4 as b ,t2.c6 as c from t1 inner join t2 on t1.c1 = t2.c1 order by t2.c4;
