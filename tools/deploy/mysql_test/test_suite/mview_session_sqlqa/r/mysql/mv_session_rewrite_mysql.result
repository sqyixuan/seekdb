| a                          | b          | c                        |
+----------------------------+------------+--------------------------+
| 2023-01-01 12:34:56.123456 | 2023-01-01 | 2023-01-01 12:34:56.1234 |
| 2023-02-01 12:34:56.654321 | 2023-02-01 | 2023-02-01 12:34:56.6543 |
| 2023-03-01 12:34:56.000000 | 2023-03-01 | 2023-03-01 12:34:56.0000 |
+----------------------------+------------+--------------------------+
select /*+mv_rewrite(mv1)*/  t1.c3 as a,t2.c4 as b ,t2.c6 as c from t1 inner join t2 on t1.c1 = t2.c1 order by t2.c4;
+----------------------------+------------+--------------------------+
| a                          | b          | c                        |
+----------------------------+------------+--------------------------+
| 2023-01-01 12:34:56.123456 | 2023-01-01 | 2023-01-01 12:34:56.1234 |
| 2023-02-01 12:34:56.654321 | 2023-02-01 | 2023-02-01 12:34:56.6543 |
| 2023-03-01 12:34:56.000000 | 2023-03-01 | 2023-03-01 12:34:56.0000 |
+----------------------------+------------+--------------------------+
select c3, c4, c6 from mv1 order by c4;
+----------------------------+------------+--------------------------+
| c3                         | c4         | c6                       |
+----------------------------+------------+--------------------------+
| 2023-01-01 12:34:56.123456 | 2023-01-01 | 2023-01-01 12:34:56.1234 |
| 2023-02-01 12:34:56.654321 | 2023-02-01 | 2023-02-01 12:34:56.6543 |
| 2023-03-01 12:34:56.000000 | 2023-03-01 | 2023-03-01 12:34:56.0000 |
+----------------------------+------------+--------------------------+
explain basic select /*+no_mv_rewrite*/ t1.c3 as a,t2.c4 as b ,t2.c6 as c from t1 inner join t2 on t1.c1 = t2.c1 order by t2.c4;
