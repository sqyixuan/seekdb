explain basic select /*+no_mv_rewrite*/ t1.c3 as a,t2.c4 as b ,t2.c6 as c from t1 inner join t2 on t1.c1 = t2.c1 group by t1.c3,t2.c4,t2.c6 order by t2.c4;
