result_format: 4
DROP USER lyq_test;
CREATE USER 'lyq_test' IDENTIFIED BY '123456';
GRANT ALL ON *.* TO lyq_test with grant option;
DROP MATERIALIZED VIEW LOG ON t1;
drop table t1;
create table t1(c1 bigint(20) NOT NULL COMMENT '用户ID',c2 varchar(256) COLLATE utf8mb4_bin NOT NULL,c3 timestamp(6) NULL DEFAULT NULL COMMENT '时间', c4 DATE,c5 DATETIME(4),c6 TIMESTAMP(4),c7 TIME(3),c8 YEAR(4),c10 BIT(2),c11 BINARY(2),gen_v1 DATETIME(0) GENERATED ALWAYS AS (CAST(c5 AS char(100))) virtual,gen_v2 TIMESTAMP(2) GENERATED ALWAYS AS (CAST(c6 AS char(100))) stored,primary key(c1, c2),index t1_ind1(c2),index t1_ind2(c1,c4),unique index t1_ind3(c1));
INSERT INTO t1 
(c1, c2, c3, c4, c5, c6, c7, c8, c10, c11) 
VALUES 
(1, 'example1', '2023-01-01 12:34:56.123456', '2023-01-01', '2023-01-01 12:34:56.1234', '2023-01-01 12:34:56.1234', '12:34:56.123', '2023', b'01', _binary '01');
INSERT INTO t1 
(c1, c2, c3, c4, c5, c6, c7, c8, c10, c11) 
VALUES 
(2, 'example2', '2023-02-01 12:34:56.654321', '2023-02-01', '2023-02-01 12:34:56.6543', '2023-02-01 12:34:56.6543', '12:34:56.654', '2024', b'10', _binary '10');
INSERT INTO t1 
(c1, c2, c3, c4, c5, c6, c7, c8, c10, c11) 
VALUES 
(3, 'example3', '2023-03-01 12:34:56.000000', '2023-03-01', '2023-03-01 12:34:56.0000', '2023-03-01 12:34:56.0000', '12:34:56.000', '2025', b'11', _binary '11');
select * from t1 order by c1;
+----+----------+----------------------------+------------+--------------------------+--------------------------+--------------+------+------+------+---------------------+------------------------+
| c1 | c2       | c3                         | c4         | c5                       | c6                       | c7           | c8   | c10  | c11  | gen_v1              | gen_v2                 |
+----+----------+----------------------------+------------+--------------------------+--------------------------+--------------+------+------+------+---------------------+------------------------+
|  1 | example1 | 2023-01-01 12:34:56.123456 | 2023-01-01 | 2023-01-01 12:34:56.1234 | 2023-01-01 12:34:56.1234 | 12:34:56.123 | 2023 |     | 01   | 2023-01-01 12:34:56 | 2023-01-01 12:34:56.12 |
|  2 | example2 | 2023-02-01 12:34:56.654321 | 2023-02-01 | 2023-02-01 12:34:56.6543 | 2023-02-01 12:34:56.6543 | 12:34:56.654 | 2024 |     | 10   | 2023-02-01 12:34:57 | 2023-02-01 12:34:56.65 |
|  3 | example3 | 2023-03-01 12:34:56.000000 | 2023-03-01 | 2023-03-01 12:34:56.0000 | 2023-03-01 12:34:56.0000 | 12:34:56.000 | 2025 |     | 11   | 2023-03-01 12:34:56 | 2023-03-01 12:34:56.00 |
+----+----------+----------------------------+------------+--------------------------+--------------------------+--------------+------+------+------+---------------------+------------------------+
DROP MATERIALIZED VIEW LOG ON t2;
drop table t2;
create table t2(c1 bigint(20) NOT NULL COMMENT '用户ID',c2 varchar(256) COLLATE utf8mb4_bin NOT NULL,c3 timestamp(6) NULL DEFAULT NULL COMMENT '时间', c4 DATE,c5 DATETIME(4),c6 TIMESTAMP(4),c7 TIME(3),c8 YEAR(4),c10 BIT(2),c11 BINARY(2),gen_v1 DATETIME(0) GENERATED ALWAYS AS (CAST(c5 AS char(100))) virtual,gen_v2 TIMESTAMP(2) GENERATED ALWAYS AS (CAST(c6 AS char(100))) stored,primary key(c1, c2),index t1_ind1(c2),index t1_ind2(c1,c4),unique index t1_ind3(c1));
INSERT INTO t2 
(c1, c2, c3, c4, c5, c6, c7, c8, c10, c11) 
