|  1 |  1 | example1 | example1 | 2023-01-01 12:34:56.123456 | 2023-01-01 | 2023-01-01 12:34:56.1234 |    1 | 1.0000 |     1 |       1 |
+----+----+----------+----------+----------------------------+------------+--------------------------+------+--------+-------+---------+
select * from mv1 order by c4;
