DROP MATERIALIZED VIEW LOG ON t1;
create materialized view log on t1 parallel 9 with PRIMARY KEY,rowid,sequence(c3,c4,c5,c6,c7,c8,c10,c11) including new values ;
DROP MATERIALIZED VIEW LOG ON t2;
create materialized view log on t2 parallel 2 with PRIMARY KEY,rowid,sequence(c3,c4,c5,c6,c7,c8,c10,c11) including new values ;
DROP MATERIALIZED VIEW LOG ON t3;
create materialized view log on t3 with PRIMARY KEY,rowid,sequence(c3) including new values ;
drop materialized view mv1;
create materialized view mv1 REFRESH COMPLETE ON DEMAND ENABLE QUERY REWRITE ENABLE ON QUERY COMPUTATION AS select t1.c3,t2.c4,t1.c6,count(*) a from t1 inner join t2 on t1.c1 = t2.c1 CROSS  join t3 on t3.c1 = t2.c1 group by t1.c3,t2.c4,t1.c6;
select t1.c3,t2.c4,t1.c6,count(*) a from t1 inner join t2 on t1.c1 = t2.c1 CROSS  join t3 on t3.c1 = t2.c1 group by t1.c3,t2.c4,t1.c6;
