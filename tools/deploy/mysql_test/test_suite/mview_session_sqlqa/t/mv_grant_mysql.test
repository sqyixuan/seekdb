--echo 预期查询物化视图报错，触发改写时会走其他计划，加hint 强行改写报错
--echo 切换default用户
connection default;
GRANT ALL ON *.* TO lyq_test with grant option;
REVOKE SELECT ON *.* FROM 'lyq_test';
REVOKE SELECT ON test.mv1 FROM 'lyq_test';
GRANT SELECT ON test.t1 to 'lyq_test';
GRANT SELECT ON test.t2 to 'lyq_test';

disconnect lyq_test;
connect(lyq_test,$OBMYSQL_MS0,lyq_test,123456,test,$OBMYSQL_PORT);

SET query_rewrite_enabled= true;
set QUERY_REWRITE_INTEGRITY = ENFORCED;

--sorted_result
select t1.c1 as aa, t2.c1 as bb,t1.c2 as aaa, t2.c2 as bbb,t1.c3 as a,t2.c4 as b ,t2.c6 as c from t1 inner join t2 on t1.c1 = t2.c1 where CAST(t1.c3 AS char(100)) >= '2023-01-01 12:34:56.123456' ;
select /*+no_mv_rewrite*/ t1.c3 from t1 inner join t2 on t1.c1 = t2.c1 where CAST(t1.c3 AS char(100)) >= '2023-01-01 12:34:56.123456' ;
--sorted_result
select /*+mv_rewrite(mv1)*/ t1.c3 from t1 inner join t2 on t1.c1 = t2.c1 where CAST(t1.c3 AS char(100)) >= '2023-01-01 12:34:56.123456' ;

--error 0, 1142
select * from mv1 order by c4;

--replace_regex /last_refresh_scn\([0-9]{6}\)/last_refresh_scn(xxxxxx)/
explain basic select t1.c1 as aa, t2.c1 as bb,t1.c2 as aaa, t2.c2 as bbb,t1.c3 as a,t2.c4 as b ,t2.c6 as c from t1 inner join t2 on t1.c1 = t2.c1 where CAST(t1.c3 AS char(100)) >= '2023-01-01 12:34:56.123456' ;
explain basic select /*+no_mv_rewrite*/ t1.c3 from t1 inner join t2 on t1.c1 = t2.c1 where CAST(t1.c3 AS char(100)) >= '2023-01-01 12:34:56.123456' ;
--replace_regex /last_refresh_scn\([0-9]{6}\)/last_refresh_scn(xxxxxx)/
explain basic select /*+mv_rewrite(mv1)*/ t1.c3 from t1 inner join t2 on t1.c1 = t2.c1 where CAST(t1.c3 AS char(100)) >= '2023-01-01 12:34:56.123456' ;


--echo 切换default用户
connection default;

--error 0,9755
DROP MATERIALIZED VIEW LOG ON t1;
--error 0,9755
DROP MATERIALIZED VIEW LOG ON t2;
--error 0,1051
drop table t1;
--error 0,1051
drop table t2;
--error 0,9757
drop materialized view mv1;


