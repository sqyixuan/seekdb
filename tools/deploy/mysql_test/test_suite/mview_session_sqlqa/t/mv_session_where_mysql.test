--error 0,12003
drop materialized view mv1;
create materialized view mv1(c1, cc1 ,c2, cc2 , c3, c4, c6, PRIMARY KEY(c3)) REFRESH FAST ON DEMAND ENABLE QUERY REWRITE ENABLE ON QUERY COMPUTATION AS select t1.c1 as aa, t2.c1 as bb,t1.c2 as aaa, t2.c2 as bbb,t1.c3 as a,t2.c4 as b ,t2.c6 as c from t1 inner join t2 on t1.c1 = t2.c1 where CAST(t1.c3 AS char(100)) >= '2023-01-01 12:34:56.123456' ;


--echo 变量参数设置一致时，原始查询/经过物化视图改写/直接使用物化视图的查询结果一致
