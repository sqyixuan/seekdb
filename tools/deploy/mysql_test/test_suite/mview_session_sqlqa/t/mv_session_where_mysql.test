select /*+no_mv_rewrite*/ t1.c3 from t1 inner join t2 on t1.c1 = t2.c1 where CAST(t1.c3 AS char(100)) >= '2023-01-01 12:34:56.123456' ;
select /*+mv_rewrite(mv1)*/ t1.c3 from t1 inner join t2 on t1.c1 = t2.c1 where CAST(t1.c3 AS char(100)) >= '2023-01-01 12:34:56.123456' ;
select * from mv1 order by c4;

