SET time_zone='+08:00';
--error 0,9757
drop materialized view mv1;
create materialized view mv1
REFRESH COMPLETE ON DEMAND
ENABLE QUERY REWRITE
DISABLE ON QUERY COMPUTATION
AS select * from t1;

--echo 变量参数设置一致时，原始查询/经过物化视图改写/直接使用物化视图的查询结果一致
select /*+no_mv_rewrite*/ c3,c4,c6 from t1 where CAST(c3 AS char(100)) >= '2023-01-01 12:34:56.123456';
select /*+mv_rewrite(mv1)*/ c3,c4,c6 from t1 where CAST(c3 AS char(100)) >= '2023-01-01 12:34:56.123456' order by c1;
explain basic select /*+mv_rewrite(mv1)*/ c3,c4,c6 from t1 where CAST(c3 AS char(100)) >= '2023-01-01 12:34:56.123456';
select * from mv1 order by c4;

