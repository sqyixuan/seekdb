--result_format 4
 
--error 0,1008
drop DATABASE test;
CREATE DATABASE test;
use test;

--echo ##设置相同sql_mode;
SET @@sql_mode='';

SET time_zone='+08:00';
SET query_rewrite_enabled= true;
set QUERY_REWRITE_INTEGRITY = stale_tolerated;

--error 0,1146
DROP MATERIALIZED VIEW LOG ON t1;
--error 0,1051
drop table t1;
create table t1(c1 bigint(20) NOT NULL COMMENT '用户ID',
c2 varchar(256) COLLATE utf8mb4_bin NOT NULL,
c3 timestamp(6) NULL DEFAULT NULL COMMENT '时间', 
c4 DATE,
c5 DATETIME(4),
c6 TIMESTAMP(4),
c7 TIME(3),
c8 YEAR(4),
c10 BIT(2),
c11 BINARY(2),
gen_v1 DATETIME(0) GENERATED ALWAYS AS (CAST(c5 AS char(100))) virtual,
gen_v2 TIMESTAMP(2) GENERATED ALWAYS AS (CAST(c6 AS char(100))) stored,
primary key(c1, c2),
index t1_ind1(c2),
index t1_ind2(c1,c4),
unique index t1_ind3(c1));

INSERT INTO t1 
(c1, c2, c3, c4, c5, c6, c7, c8, c10, c11) 
