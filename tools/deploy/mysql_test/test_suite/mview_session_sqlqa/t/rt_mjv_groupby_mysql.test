--echo 增量刷新有主键，2表inner join  group by的实时物化视图

--error 0,9755
DROP MATERIALIZED VIEW LOG ON t1;
create materialized view log on t1 parallel 9 with PRIMARY KEY,rowid,sequence(c3,c4,c5,c6,c7,c8,c10,c11) including new values ;

--error 0,9755
DROP MATERIALIZED VIEW LOG ON t2;
create materialized view log on t2 parallel 2 with PRIMARY KEY,rowid,sequence(c3,c4,c5,c6,c7,c8,c10,c11) including new values ;

--error 0,9755
DROP MATERIALIZED VIEW LOG ON t3;
create materialized view log on t3 with PRIMARY KEY,rowid,sequence(c3) including new values ;

--echo 不能使用left join
--error 0,12003,9757
drop materialized view mv1;
--error 9783
create materialized view mv1(c1, cc1 ,c2, cc2 , c3, c4, c6, a ,PRIMARY KEY(c3)) REFRESH FAST ON DEMAND ENABLE QUERY REWRITE ENABLE ON QUERY COMPUTATION AS select t1.c1 as aa, t2.c1 as bb,t1.c2 as aaa, t2.c2 as bbb,t1.c3 as a,t2.c4 as b ,t2.c6 as c , count(*) aaa from t1 left join t2 on t1.c1 = t2.c1 group by t1.c1,t2.c1,t1.c2,t2.c2,t1.c3,t2.c4,t2.c6;

--echo 使用inner join
--error 0,12003,9757
drop materialized view mv1;
create materialized view mv1(c1, cc1 ,c2, cc2 , c3, c4, c6, a ,PRIMARY KEY(c3)) REFRESH FAST ON DEMAND ENABLE QUERY REWRITE ENABLE ON QUERY COMPUTATION AS select t1.c1 as aa, t2.c1 as bb,t1.c2 as aaa, t2.c2 as bbb,t1.c3 as a,t2.c4 as b ,t2.c6 as c , count(*) aaa from t1 inner join t2 on t1.c1 = t2.c1 group by t1.c1,t2.c1,t1.c2,t2.c2,t1.c3,t2.c4,t2.c6;

select t1.c1 as aa, t2.c1 as bb,t1.c2 as aaa, t2.c2 as bbb,t1.c3 as a,t2.c4 as b ,t2.c6 as c , count(*) aaa from t1 inner join t2 on t1.c1 = t2.c1 group by t1.c1,t2.c1,t1.c2,t2.c2,t1.c3,t2.c4,t2.c6;
select * from mv1 order by c4;
--replace_regex /last_refresh_scn\([0-9]+\)/last_refresh_scn/  /:[0-9]+/:/
explain basic select t1.c1 as aa, t2.c1 as bb,t1.c2 as aaa, t2.c2 as bbb,t1.c3 as a,t2.c4 as b ,t2.c6 as c , count(*) aaa from t1 inner join t2 on t1.c1 = t2.c1 group by t1.c1,t2.c1,t1.c2,t2.c2,t1.c3,t2.c4,t2.c6;

--echo 使用CROSS  join
--error 0,12003
drop materialized view mv1;
create materialized view mv1(c1, cc1 ,c2, cc2 , c3, c4, c6, a ,PRIMARY KEY(c3)) REFRESH FAST ON DEMAND ENABLE QUERY REWRITE ENABLE ON QUERY COMPUTATION AS select t1.c1 as aa, t2.c1 as bb,t1.c2 as aaa, t2.c2 as bbb,t1.c3 as a,t2.c4 as b ,t2.c6 as c , count(*) aaa from t1 CROSS  join t2 on t1.c1 = t2.c1 group by t1.c1,t2.c1,t1.c2,t2.c2,t1.c3,t2.c4,t2.c6;

select t1.c1 as aa, t2.c1 as bb,t1.c2 as aaa, t2.c2 as bbb,t1.c3 as a,t2.c4 as b ,t2.c6 as c , count(*) aaa from t1 inner join t2 on t1.c1 = t2.c1 group by t1.c1,t2.c1,t1.c2,t2.c2,t1.c3,t2.c4,t2.c6;
select * from mv1 order by c4;
--replace_regex /last_refresh_scn\([0-9]+\)/last_refresh_scn/  /:[0-9]+/:/
explain basic select t1.c1 as aa, t2.c1 as bb,t1.c2 as aaa, t2.c2 as bbb,t1.c3 as a,t2.c4 as b ,t2.c6 as c , count(*) aaa from t1 inner join t2 on t1.c1 = t2.c1 group by t1.c1,t2.c1,t1.c2,t2.c2,t1.c3,t2.c4,t2.c6;



