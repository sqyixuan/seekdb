--error 0,9757
drop materialized view mv1;
create materialized view mv1 REFRESH COMPLETE ON DEMAND ENABLE QUERY REWRITE ENABLE ON QUERY COMPUTATION AS select t1.c3,t2.c4,t1.c6,count(*) a from t1 inner join t2 on t1.c1 = t2.c1 CROSS  join t3 on t3.c1 = t2.c1 group by t1.c3,t2.c4,t1.c6;

select t1.c3,t2.c4,t1.c6,count(*) a from t1 inner join t2 on t1.c1 = t2.c1 CROSS  join t3 on t3.c1 = t2.c1 group by t1.c3,t2.c4,t1.c6;
select c3, c4, c6 from mv1 order by c4;
--replace_regex /last_refresh_scn\([0-9]+\)/last_refresh_scn/  /:[0-9]+/:/
explain basic select t1.c3,t2.c4,t1.c6,count(*) a from t1 inner join t2 on t1.c1 = t2.c1 CROSS  join t3 on t3.c1 = t2.c1 group by t1.c3,t2.c4,t1.c6;

