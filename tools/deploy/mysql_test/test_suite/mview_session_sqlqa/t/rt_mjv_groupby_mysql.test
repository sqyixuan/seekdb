--error 0,12003
drop materialized view mv1;
create materialized view mv1(c1, cc1 ,c2, cc2 , c3, c4, c6, a , avgc1, sumc1, countc1, PRIMARY KEY(c3)) REFRESH FAST ON DEMAND ENABLE QUERY REWRITE ENABLE ON QUERY COMPUTATION AS select t1.c1 as aa, t2.c1 as bb,t1.c2 as aaa, t2.c2 as bbb,t1.c3 as a,t2.c4 as b ,t2.c6 as c , count(*) aaa, avg(t1.c1) avgc1, sum(t1.c1) sumc1 ,count(t1.c1) countc1 from t1 inner join t2 on t1.c1 = t2.c1 CROSS  join t3 on t3.c1 = t2.c1    where CAST(t1.c3 AS char(100)) <=> '2023-01-01 12:34:56.123456' group by t1.c1,t2.c1,t1.c2,t2.c2,t1.c3,t2.c4,t2.c6;

select t1.c1 as aa, t2.c1 as bb,t1.c2 as aaa, t2.c2 as bbb,t1.c3 as a,t2.c4 as b ,t2.c6 as c , count(*) aaa, avg(t1.c1) avgc1, sum(t1.c1) sumc1 ,count(t1.c1) countc1 from t1 inner join t2 on t1.c1 = t2.c1 CROSS  join t3 on t3.c1 = t2.c1    where CAST(t1.c3 AS char(100)) <=> '2023-01-01 12:34:56.123456' group by t1.c1,t2.c1,t1.c2,t2.c2,t1.c3,t2.c4,t2.c6;

select * from mv1 order by c4;
select sum(c1) from mv1 order by c4;
select sum(c1),max(cc1),avg(avgc1),min(sumc1) from mv1 order by c4;
select sum(c1),max(cc1),avg(avgc1),min(sumc1), RANK() OVER (PARTITION BY c1 ORDER BY cc1 DESC) AS rank,LAG(avgc1, 1) OVER (ORDER BY c1) AS prev_amount from mv1 order by c4;
