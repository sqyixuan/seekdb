select * from test1 where c2 =all(select c2 from test1 where c2=bin_to_uuid(uuid_to_bin('5fd29c12-493f-11ed-9307-7cd30abc95d8'),23));
select * from test1 where c2 >all(select c2 from test1 where c2=bin_to_uuid(uuid_to_bin('5fd29c12-493f-11ed-9307-7cd30abc95d8'),23));
select * from test1 where c2 <all(select c2 from test1 where c2=bin_to_uuid(uuid_to_bin('5fd29c12-493f-11ed-9307-7cd30abc95d8'),23));
