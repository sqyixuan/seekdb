--echo #Environmental cleaning
--disable_warnings
--enable_warnings
--error 0,1396
drop user hjw@'%';
--enable_warnings
create user hjw identified by 'hjw';
grant all on *.* to hjw WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,hjw,hjw,test,$OBMYSQL_PORT);
--echo     #function-1    参数个数
--echo     #function-2    参数类型
--echo     #function-1    参数个数
--echo     #function-1    参数个数=====>空参
--error 0,1582
select bin_to_uuid() from dual;
--error 0,1411
select bin_to_uuid('') from dual;
--error 0,1411
select bin_to_uuid("") from dual;
--error 0,1582
select bin_to_uuid(uuid_to_bin()) from dual;
--error 0,1411
select bin_to_uuid(uuid_to_bin('')) from dual;
--error 0,1411
select bin_to_uuid(uuid_to_bin("")) from dual;
--echo     #function-1    参数个数=====>只有一个参数
--error 0,1411
select bin_to_uuid('3fefcabf-4848-11ed-ae97-7cd30abc95d8') from dual;
--error 0,1054
select bin_to_uuid(3fefcabf-4848-11ed-ae97-7cd30abc95d8) from dual;
select bin_to_uuid(null) from dual;
--error 0,1054
select bin_to_uuid(nulls) from dual;
--error 0,1411
select bin_to_uuid((select uuid())) from dual;
--error 0,1411
select bin_to_uuid(1111111111111111111111111111111111) from dual;
--error 0,1411
select bin_to_uuid('1111111111111111111111111111111111') from dual;
select bin_to_uuid(uuid_to_bin("7b6f6d04-485e-11ed-ae97-7cd30abc95d8")) from dual;
--error 0,1064
select bin_to_uuid(uuid_to_bin(7b6f6d04-485e-11ed-ae97-7cd30abc95d8)) from dual;
--error 0,1411
select bin_to_uuid(uuid_to_bin(111111111111111111111111111111111111)) from dual;
--error 0,1411
select bin_to_uuid(1001110111111110111011001100101110111101) from dual;
--error 0,1411
select bin_to_uuid('1001110111111110111011001100101110111101') from dual;
--echo     #function-1    参数个数=====>两个或以上
select bin_to_uuid(uuid_to_bin("7b6f6d04-485e-11ed-ae97-7cd30abc95d8"),3) from dual;
--error 0,1582
select bin_to_uuid(uuid_to_bin("7b6f6d04-485e-11ed-ae97-7cd30abc95d8"),3,4) from dual;
select bin_to_uuid(null,3) from dual;
--error 0,1411
select bin_to_uuid(bin_to_uuid(uuid_to_bin("7b6f6d04-485e-11ed-ae97-7cd30abc95d8"),3),4) from dual;
select bin_to_uuid(uuid_to_bin("7b6f6d04-485e-11ed-ae97-7cd30abc95d8"),-3) from dual;
select bin_to_uuid(uuid_to_bin("7b6f6d04-485e-11ed-ae97-7cd30abc95d8"),-3.5) from dual;
select bin_to_uuid(uuid_to_bin("7b6f6d04-485e-11ed-ae97-7cd30abc95d8"),3.5) from dual;
select bin_to_uuid(uuid_to_bin("7b6f6d04-485e-11ed-ae97-7cd30abc95d8"),0.5) from dual;
select bin_to_uuid(uuid_to_bin("7b6f6d04-485e-11ed-ae97-7cd30abc95d8",3),-3) from dual;
--error 0,1582
select bin_to_uuid(uuid_to_bin("7b6f6d04-485e-11ed-ae97-7cd30abc95d8",3,7),-3) from dual;
--echo     #function-2    参数类型
--echo     #function-2-1  不带uuid_to_bin函数
--echo   #布尔值
--error 0,1411
select bin_to_uuid(true) from dual;
--error 0,1411
select bin_to_uuid(FALSE) from dual;
--error 0,1411
select bin_to_uuid('true') from dual;
--error 0,1411
select bin_to_uuid('FALSE') from dual;
--error 0,1411
select bin_to_uuid(0) from dual;
--error 0,1411
select bin_to_uuid(1) from dual;
--error 0,1411
select bin_to_uuid(0,6) from dual;
--error 0,1411
select bin_to_uuid(1,6) from dual;
--echo   #null
select bin_to_uuid(null) from dual;
--error 0,1054
select bin_to_uuid(nulls) from dual;
select bin_to_uuid(null,null) from dual;
--error 0,1582
select bin_to_uuid(null,null,null) from dual;
--error 0,1411
select bin_to_uuid('00d843e9-4863-11ed-ae97-7cd30abc95d8') from dual;
--error 0,1411
select bin_to_uuid('1100011') from dual;
--error 0,1411
select bin_to_uuid(1100011) from dual;
--echo   #uuid=====>正确的uuid
--error 0,1411
select bin_to_uuid('95ca0692-4867-11ed-ae97-7cd30abc95d8');
--error 0,1411
select bin_to_uuid('6ccd780cbaba102695645b8c656024db');
--error 0,1411
select bin_to_uuid('{6ccd780c-baba-1026-9564-5b8c656024db}');
--echo   #uuid=====>前八位纯数值
--error 0,1411
select bin_to_uuid('44444444-4867-11ed-ae97-7cd30abc95d8');
--error 0,1411
select bin_to_uuid('00000000baba102695645b8c656024db');
--error 0,1411
select bin_to_uuid('{33333333-baba-1026-9564-5b8c656024db}');
--echo   #uuid=====>前八位纯字母
--error 0,1411
select bin_to_uuid('aaaaaaaa-4867-11ed-ae97-7cd30abc95d8');
--error 0,1411
select bin_to_uuid('sdwfwfdgbaba102695645b8c656024db');
--error 0,1411
select bin_to_uuid('{DDDDDDDD-baba-1026-9564-5b8c656024db}');
--echo   #uuid=====>前八位纯汉字
--error 0,1411
select bin_to_uuid('过过过过过过过过-4867-11ed-ae97-7cd30abc95d8');
--error 0,1411
select bin_to_uuid('张张张张baba102695645b8c656024db');
--error 0,1411
select bin_to_uuid('{张张张张-baba-1026-9564-5b8c656024db}');
--echo   #uuid=====>前八位数值字母汉字混合
--error 0,1411
select bin_to_uuid('123abc汉字-4867-11ed-ae97-7cd30abc95d8');
--error 0,1411
select bin_to_uuid('123abc汉baba102695645b8c656024db');
--error 0,1411
select bin_to_uuid('{123abc汉-baba-1026-9564-5b8c656024db}');
--error 0,1411
select bin_to_uuid('123abccd-4867-11ed-ae97-7cd30abc95d8');
--error 0,1411
select bin_to_uuid('123韩韩韩韩韩-4867-11ed-ae97-7cd30abc95d8');
--error 0,1411
select bin_to_uuid('abd韩韩韩韩韩-4867-11ed-ae97-7cd30abc95d8');
--echo   #uuid=====>前八位特殊符号
--error 0,1411
select bin_to_uuid('????????-4867-11ed-ae97-7cd30abc95d8');
--error 0,1411
select bin_to_uuid('⚽⚽⚽⚽⚽⚽⚽⚽-4867-11ed-ae97-7cd30abc95d8');
--error 0,1411
select bin_to_uuid('🏀🏀🏀🏀🏀🏀🏀🏀-4867-11ed-ae97-7cd30abc95d8');
--error 0,1411
select bin_to_uuid('········-4867-11ed-ae97-7cd30abc95d8');
--error 0,1411
select bin_to_uuid('@@@@@@@@-4867-11ed-ae97-7cd30abc95d8');
--error 0,1411
select bin_to_uuid('########-4867-11ed-ae97-7cd30abc95d8');
--error 0,1411
select bin_to_uuid('$$$$$$$$-4867-11ed-ae97-7cd30abc95d8');
--error 0,1411
select bin_to_uuid('%%%%%%%%-4867-11ed-ae97-7cd30abc95d8');
--error 0,1411
select bin_to_uuid('^^^^^^^^-4867-11ed-ae97-7cd30abc95d8');
--error 0,1411
select bin_to_uuid('&&&&&&&&-4867-11ed-ae97-7cd30abc95d8');
--error 0,1411
select bin_to_uuid('********-4867-11ed-ae97-7cd30abc95d8');
--error 0,1411
select bin_to_uuid('!!!!!!!!-4867-11ed-ae97-7cd30abc95d8');
--error 0,1411
select bin_to_uuid('........-4867-11ed-ae97-7cd30abc95d8');
--error 0,1411
select bin_to_uuid('\\\\\\\\-4867-11ed-ae97-7cd30abc95d8');
--error 0,1411
select bin_to_uuid('""""""""-4867-11ed-ae97-7cd30abc95d8');
--error 0,1411
select bin_to_uuid('[[[[[[[[-4867-11ed-ae97-7cd30abc95d8');
--error 0,1411
select bin_to_uuid('((((((((-4867-11ed-ae97-7cd30abc95d8');
--error 0,1411
select bin_to_uuid('{{{{{{{{-4867-11ed-ae97-7cd30abc95d8');
--echo   #8进制
--error 0,1411
select oct(bin_to_uuid('null')) from dual;
select oct(bin_to_uuid(null)) from dual;
select bin_to_uuid(cot(null)) from dual;
--echo   #10进制
--error 0,1582
select conv(bin_to_uuid('null',10,2)) from dual;
--error 0,1582
select conv(bin_to_uuid(null,10,2)) from dual;
select bin_to_uuid(conv(null,10,2)) from dual;
--echo   #16进制
select hex(bin_to_uuid(null)) from dual;
select bin_to_uuid(hex(null)) from dual;
--echo   #2进制
select bin(bin_to_uuid(null)) from dual;
select bin_to_uuid(bin(null)) from dual;
--echo   #json值
--error 0,1411
select bin_to_uuid(
'{
        "Image": {
            "Width":  800,
            "Height": 600,
            "Title":  "View from 15th Floor",
            "Thumbnail": {
                "Url":    "http://www.example.com/image/481989943",
                "Height": 125,
                "Width":  100
            },
            "Animated" : false,
            "IDs": [116, 943, 234, 38793]
          }
      }
     ') from dual;
--error 0,1411
select bin_to_uuid('{ "NAME": "SAM",  "Height": 175, "Weight":  100，“Registered” : false}') from dual;
--error 0,1411
select bin_to_uuid('["abc", 10, null, true, false]') from dual;
--error 0,1411
select bin_to_uuid('[100, 0, -100, 100.11, -12.11, 10.22e2, -10.22e2]') from dual;
--error 0,1411
select bin_to_uuid(' {"Url":"https://www.baidu.com/"}') from dual;
