SELECT case bin_to_uuid(uuid_to_bin('6ccd780c-baba-1026-9564-5b8c656024db')) when bin_to_uuid(uuid_to_bin('6ccd780cbaba102695645b8c656024db')) then 1 when 2 then 2 end;
