--echo     #function-4-5    json函数
--error 0,1411
select bin_to_uuid(uuid_to_bin(JSON_ARRAY())) from dual;
select bin_to_uuid(uuid_to_bin(JSON_ARRAY_APPEND(@j, '$.b', 'x'))) from dual;
select bin_to_uuid(uuid_to_bin(JSON_ARRAY_APPEND(@j, '$.b', 'x'),JSON_ARRAY_APPEND(@j, '$.b', 'x'))) from dual;
select bin_to_uuid(uuid_to_bin(JSON_ARRAY_INSERT(@j, '$[1]', 'x'))) from dual;
select bin_to_uuid(uuid_to_bin(JSON_ARRAY_INSERT(@j, '$[1]', 'x'),JSON_ARRAY_INSERT(@j, '$[1]', 'x')+1)) from dual;
select bin_to_uuid(uuid_to_bin(JSON_CONTAINS(@j, @j2, '$.a'))) from dual;
select bin_to_uuid(uuid_to_bin(JSON_CONTAINS(@j, @j2, '$.a')),JSON_CONTAINS(@j, @j2, '$.a')+5) from dual;
SET @j = '{"a": 1, "b": 2, "c": {"d": 4}}';
--error 0,1411
select bin_to_uuid(uuid_to_bin(JSON_CONTAINS_PATH(@j, 'one', '$.a', '$.e'))) from dual;
--error 0,1411
select bin_to_uuid(uuid_to_bin(JSON_DEPTH('{}'))) from dual;
--error 0,1411
select bin_to_uuid(uuid_to_bin(JSON_EXTRACT('1', "$.id"))) from dual;
select bin_to_uuid(uuid_to_bin(JSON_EXTRACT('1', "$.id"),1)) from dual;
SET @j = '{ "a": 1, "b": [2, 3]}';
--error 0,1064
select bin_to_uuid(uuid_to_bin(JSON_INSERT(@j, '$.a', 10, '$.c', '[true, false]')))) from dual;
--error 0,1411
select bin_to_uuid(uuid_to_bin(JSON_KEYS('{"a": 1, "b": {"c": 30}}'))) from dual;
--error 0,1411
select bin_to_uuid(uuid_to_bin(JSON_LENGTH('[1, 2, {"a": 3}]'))) from dual;
--error 0,1411
select bin_to_uuid(uuid_to_bin(JSON_MERGE('[1, 2]', '[true, false]', '{"a":100}'))) from dual;
--error 0,1411
select bin_to_uuid(uuid_to_bin(JSON_MERGE_PATCH('[1, 2]', '[true, false]'))) from dual;
--error 0,1064
select bin_to_uuid(uuid_to_bin(JSON_MERGE_PRESERVE('[1, 2]', '[true, false]')))) from dual;
--error 0,1411
select bin_to_uuid(uuid_to_bin(JSON_OBJECT('id', 87, 'name', 'carrot'))) from dual;
--error 0,1064
select bin_to_uuid(uuid_to_bin(JSON_OVERLAPS("[1,3,5,7]", "[2,6,8]")))) from dual;
--error 0,1411
select bin_to_uuid(uuid_to_bin(JSON_PRETTY('{"a":"10","b":"15","x":"25"}'))) from dual;
--error 0,1411
select bin_to_uuid(uuid_to_bin(JSON_QUOTE('{"name":sam, "scores":[100,200,300]}'))) from dual;
SET @j = '["a", ["b", "c"], "d"]';
--error 0,1411
select bin_to_uuid(uuid_to_bin(JSON_REMOVE(@j, '$[8]'))) from dual;
SET @j = '{ "a": 1, "b": [2, 3]}';
--error 0,1411
select bin_to_uuid(uuid_to_bin(JSON_REPLACE(@j, '$.a', 10, '$.c', '[true, false]'))) from dual;
SET @j = '["abc", [{"k": "10"}, "def"], {"x":"abc"}, {"y":"bcd"}]';
--error 0,1411
select bin_to_uuid(uuid_to_bin(JSON_SEARCH(@j, 'all', '10', NULL, '$[*]'))) from dual;
SET @j = '{ "a": 1, "b": [2, 3]}';
--error 0,1411
select bin_to_uuid(uuid_to_bin(JSON_SET(@j, '$.a', 10, '$.c', '[true, false]'))) from dual;
SET @j = '[100, "sakila", [1, 3, 5], 425.05]';
--error 0,1411
select bin_to_uuid(uuid_to_bin(JSON_STORAGE_SIZE(@j))) from dual;
SET @j = '{"a": [10, true]}';
--error 0,1411
select bin_to_uuid(uuid_to_bin(JSON_TYPE(@j))) from dual;
SET @j = '"abc"';
--error 0,1411
select bin_to_uuid(uuid_to_bin(JSON_UNQUOTE(@j))) from dual;
--error 0,1411
select bin_to_uuid(uuid_to_bin(JSON_VALID('{"a": 1}'))) from dual;
--error 0,1411
select bin_to_uuid(uuid_to_bin(JSON_VALUE('{"fname": "Joe", "lname": "Palmer"}', '$.fname'))) from dual;
--error 0,1411
select bin_to_uuid(uuid_to_bin(JSON_ARRAYAGG('["color", "fabric", "color", "fabric"]'))) from dual;
--error 0,1064
select bin_to_uuid(uuid_to_bin(JSON_OBJECTAGG('{"key": 4}'))) from dual;
