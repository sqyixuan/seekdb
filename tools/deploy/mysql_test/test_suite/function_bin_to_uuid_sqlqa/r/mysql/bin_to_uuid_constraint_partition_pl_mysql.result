drop FUNCTION FUNCTION_1;
CREATE FUNCTION FUNCTION_1() RETURNS int
BEGIN
DECLARE v1 decimal(50,1) DEFAULT 20;
WHILE v1<30 DO
UPDATE test1 SET h1=h1+9 where id=bin_to_uuid(uuid_to_bin('8b40c560-47a5-11ed-aedd-7cd30abc95d8',0.5));
SET v1=v1+5;
END WHILE;
RETURN bin_to_uuid(uuid_to_bin('8b40c560-47a5-11ed-aedd-7cd30abc95d8',87));
END;
/
