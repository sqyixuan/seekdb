drop procedure procedure_1;
create procedure procedure_1(aa int,bb int)
begin
if aa = bb then
insert into test1 values(bin_to_uuid(uuid_to_bin('972d531f-47a1-11ed-aedd-7cd30abc95d8')));
insert into test1 values(bin_to_uuid(uuid_to_bin('972d531f-47a1-11ed-aedd-7cd30abc95d8')));
insert into test1 values(bin_to_uuid(uuid_to_bin('972d531f-47a1-11ed-aedd-7cd30abc95d8')));
insert into test1 values(bin_to_uuid(uuid_to_bin('972d531f-47a1-11ed-aedd-7cd30abc95d8')));
elseif aa > bb then
insert into test2 values(bin_to_uuid(uuid_to_bin('e6c39b4d-47a1-11ed-aedd-7cd30abc95d8',0)));
insert into test2 values(bin_to_uuid(uuid_to_bin('e6c39b4d-47a1-11ed-aedd-7cd30abc95d8',-3)));
insert into test2 values(bin_to_uuid(uuid_to_bin('e6c39b4d-47a1-11ed-aedd-7cd30abc95d8',9)));
insert into test2 values(bin_to_uuid(uuid_to_bin('e6c39b4d-47a1-11ed-aedd-7cd30abc95d8',9.5)));
else
insert into test3 values(bin_to_uuid(uuid_to_bin('054818d4-47a2-11ed-aedd-7cd30abc95d8',0),51));
insert into test3 values(bin_to_uuid(uuid_to_bin('054818d4-47a2-11ed-aedd-7cd30abc95d8',-3),2));
insert into test3 values(bin_to_uuid(uuid_to_bin('054818d4-47a2-11ed-aedd-7cd30abc95d8',9),-21));
insert into test3 values(bin_to_uuid(uuid_to_bin('054818d4-47a2-11ed-aedd-7cd30abc95d8',null),4));
end if;
end;
/
