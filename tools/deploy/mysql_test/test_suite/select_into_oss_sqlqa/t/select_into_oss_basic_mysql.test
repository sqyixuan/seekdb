--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner:jim.wjh
#owner group: SQL-SQL3
#description: select into oss basic function
#tags: dml,external_table
#author: wb-sl672505

connection default;
--source mysql_test/test_suite/select_into_oss_sqlqa/include/get_host_ip.inc
let $DATA_FOLDER_NAME = data_for_mysqltest_select_into_outfile;
--source mysql_test/test_suite/select_into_oss_sqlqa/include/mkdir_for_dump.inc

--echo  ##################еҹәзЎҖеҠҹиғҪжөӢиҜ•##################

--disable_query_log
--error 0,600,1396
drop user ossuser;
create user 'ossuser' identified by 'ossuser';
GRANT all privileges ON *.* TO 'ossuser'@'%' WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
--enable_query_log

### connect (obsys_for_select_into,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn_charset_test_user_mysql,$OBMYSQL_MS0,ossuser,ossuser,test,$OBMYSQL_PORT);
connection conn_charset_test_user_mysql;

#set global secure_file_priv='';
--disable_warnings
drop database IF EXISTS ob35x;
--enable_warnings

create database ob35x  character set utf8;
use ob35x;

#set global secure_file_priv='';
sleep 1;

--echo  ##################йҮҚж–°иҝһжҺҘdefaultпјҢзЎ®дҝқжңүжқғйҷҗжү§иЎҢselect into outfileиҜӯеҸҘ##################
disconnect conn_charset_test_user_mysql;
sleep 1;

connect (conn_charset_test_user_mysql,$OBMYSQL_MS0,ossuser,ossuser,test,$OBMYSQL_PORT);
connection conn_charset_test_user_mysql;
use ob35x;
--disable_query_log
--disable_warnings
drop table if exists t_deduce_length, t_deduce_length2;
--enable_warnings

create table t_deduce_length(
	c_int int,
    c_number float,
	c_number_l float,
	c_float float,
	c_binary_float float,
	c_binary_double double,
	c_blob LONGBLOB,
    c_date date,
    c_timestamp datetime,
    c_raw varchar(200),
    c_char char(200),
    c_char_c char(200),
    c_varchar2 varchar(200),
    c_varchar2_c varchar(200),
    c_varchar2_l varchar(200),
    c_nchar varchar(200),
    c_nvarchar varchar(200),
    c_nvarchar_l varchar(200),
    c_clob LONGTEXT
)partition by range(c_int)
subpartition by hash(c_int) subpartitions 4
(partition part1 values less than(5),
partition part2 values less than(10),
partition part3 values less than(15),
partition part4 values less than(200));

