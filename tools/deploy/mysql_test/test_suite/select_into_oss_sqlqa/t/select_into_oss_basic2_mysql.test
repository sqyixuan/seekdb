connection conn_charset_test_user_mysql;

#set global secure_file_priv='';
--disable_warnings
drop database IF EXISTS ob35x;
--enable_warnings

create database ob35x  character set utf8;
use ob35x;

#set global secure_file_priv='';
sleep 1;

--echo  ##################йҮҚж–°иҝһжҺҘdefaultпјҢзЎ®дҝқжңүжқғйҷҗжү§иЎҢselect into outfileиҜӯеҸҘ##################
disconnect conn_charset_test_user_mysql;
sleep 1;

connect (conn_charset_test_user_mysql,$OBMYSQL_MS0,ossuser,ossuser,test,$OBMYSQL_PORT);
connection conn_charset_test_user_mysql;
use ob35x;

--echo  ### еӯҳеӮЁиҝҮзЁӢжҸ’е…Ҙи¶…еӨ§ж•°жҚ®еә“иЎЁпјҢеҶҷеҮәеӨ§ж–Үд»¶
--disable_warnings
DROP TABLE IF EXISTS TESTOSS;
--enable_warnings

set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;
CREATE TABLE TESTOSS(GID INT, NAME VARCHAR(200) charset GBK, AGE VARCHAR(200), ADDR VARCHAR(20) charset GBK, CREATEDATE date, CLASS VARCHAR(20) charset GBK);
INSERT INTO TESTOSS VALUES ('100', 'еј дёү', '22', 'жІіеҚ—зңҒдҝЎйҳіеёӮж·®ж»ЁеҺҝи°·е Ҷд№Ўж —еӣӯжқ‘', '2021-08-19', 'е№је„ҝеӣӯеӨ§зҸӯ');
DROP PROCEDURE IF EXISTS inserttest;
delimiter //;
create procedure inserttest()
begin
declare i int default 0;
set i=0;
start transaction;
while i<100000 do
INSERT INTO TESTOSS(GID, NAME, AGE, ADDR, CREATEDATE, CLASS) VALUES (i, 'еј дёү', '22', 'жІіеҚ—зңҒдҝЎйҳіеёӮж·®ж»ЁеҺҝи°·е Ҷд№Ўж —еӣӯжқ‘', '2021-08-19', 'е№је„ҝеӣӯеӨ§зҸӯ');
set i=i+1;
end while;
commit;
end;
//

###call inserttest();
###//
delimiter ;//

--echo  ### жһ„йҖ еӨ§жү№йҮҸж•°жҚ®
DROP PROCEDURE IF EXISTS inserttest_2;
delimiter //;
create procedure inserttest_2()
begin
declare i int default 0;
set i=0;
   while i < 600 do
   call inserttest();
        set i = i + 1;
     END while;
commit;
END;
//
###и¶…еӨ§ж–Үд»¶пјҢmysqltestдёӯдёҚеҒҡжөӢиҜ•
