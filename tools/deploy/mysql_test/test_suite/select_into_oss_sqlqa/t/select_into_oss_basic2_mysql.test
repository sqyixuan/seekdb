INSERT INTO TESTOSS30 VALUES ('100', 'еј дёү', '22', 'жІіеҚ—зңҒдҝЎйҳіеёӮж·®ж»ЁеҺҝи°·е Ҷд№Ўж —еӣӯжқ‘', '2021-08-19', 'е№је„ҝеӣӯеӨ§зҸӯ');

DROP PROCEDURE IF EXISTS inserttest22;
delimiter //;
create procedure inserttest22()
begin
declare i int default 0;
set i=0;
start transaction;
while i<10 do
INSERT INTO TESTOSS30(GID, NAME, AGE, ADDR, CREATEDATE, CLASS) VALUES (i, 'еј дёү', '22', 'жІіеҚ—зңҒдҝЎйҳіеёӮж·®ж»ЁеҺҝи°·е Ҷд№Ўж —еӣӯжқ‘', '2021-08-19', 'е№је„ҝеӣӯеӨ§зҸӯ');
set i=i+1;
end while;
commit;
end;
//
delimiter ;//
call inserttest22();

