let $FILE_NAME =test006.txt;
--source mysql_test/test_suite/select_into_oss_sqlqa/include/delete_file.inc
--sorted_result
eval WITH a AS (SELECT * FROM t_deduce_length),
	b AS (SELECT * FROM t_deduce_length2) 
	SELECT * INTO OUTFILE  '$OBSERVER_DIR/$DATA_FOLDER_NAME/$FILE_NAME' FIELDS TERMINATED BY ',' ENCLOSED BY '"' LINES TERMINATED BY '\n' FROM (SELECT * FROM a,b) m order by 1,2;
--source mysql_test/test_suite/select_into_oss_sqlqa/include/cat_file.inc

###创建各种类型的索引，本地索引、全局非分区索引、全局分区索引、唯一索引、单列索引、多列索引、函数索引等。
create index idx_21 on t_deduce_length2(c_number2);
create unique index idx_22 on t_deduce_length2(c_int2);
ALTER TABLE t_deduce_length2 ADD INDEX idx_23(c_varchar2_l2);
ALTER TABLE t_deduce_length2 ADD INDEX idx_24(c_varchar2_l2,c_number2,c_char_c2);
create index idx_26 on t_deduce_length(c_int) global partition by range (c_int)
(partition GLOBAL1 values less than(5),
partition GLOBAL2 values less than(10),
partition GLOBAL3 values less than(15),
partition GLOBAL4 values less than (MAXVALUE));
create index idx_27 on t_deduce_length(c_int) global partition by hash(c_int) partitions 4;
create index idx_28 on t_deduce_length(c_int,c_number,c_char_c) global partition by hash(c_int) partitions 4;
create index idx_29 on t_deduce_length(c_int) global invisible;

