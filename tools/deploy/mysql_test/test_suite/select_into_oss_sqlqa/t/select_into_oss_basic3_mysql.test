--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner:jim.wjh
#owner group: SQL-SQL3
#description: select into oss basic function
#tags: dml,external_table
#author: wb-sl672505

connection default;
--source mysql_test/test_suite/select_into_oss_sqlqa/include/get_host_ip.inc
let $DATA_FOLDER_NAME = data_for_mysqltest_select_into_outfile;
--source mysql_test/test_suite/select_into_oss_sqlqa/include/mkdir_for_dump.inc

--echo  ##################基础功能测试##################

--disable_query_log
--disable_warnings
--error 0,600,1396
drop user ossuser;
--enable_warnings
create user 'ossuser' identified by 'ossuser';
GRANT all privileges ON *.* TO 'ossuser'@'%' WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
--enable_query_log

### connect (obsys_for_select_into,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn_charset_test_user_mysql,$OBMYSQL_MS0,ossuser,ossuser,test,$OBMYSQL_PORT);
connection conn_charset_test_user_mysql;

#set global secure_file_priv='';
--disable_warnings
drop database IF EXISTS ob35x;
--enable_warnings

create database ob35x  character set utf8;
use ob35x;

#set global secure_file_priv='';
sleep 1;

--echo  ##################重新连接default，确保有权限执行select into outfile语句##################
disconnect conn_charset_test_user_mysql;
sleep 1;

connect (conn_charset_test_user_mysql,$OBMYSQL_MS0,ossuser,ossuser,test,$OBMYSQL_PORT);
connection conn_charset_test_user_mysql;
use ob35x;

--disable_warnings
drop table if exists TESTOSS30,TESTOSS31;
--enable_warnings

CREATE TABLE TESTOSS30(GID INT, NAME VARCHAR(200) charset GBK, AGE VARCHAR(200), ADDR VARCHAR(20) charset GBK, CREATEDATE date, CLASS VARCHAR(20) charset GBK);
INSERT INTO TESTOSS30 VALUES ('100', '张三', '22', '河南省信阳市淮滨县谷堆乡栗园村', '2021-08-19', '幼儿园大班');
DROP PROCEDURE IF EXISTS inserttest22;

delimiter //;
create procedure inserttest22()
begin
declare i int default 0;
set i=0;
start transaction;
while i<10 do
INSERT INTO TESTOSS30(GID, NAME, AGE, ADDR, CREATEDATE, CLASS) VALUES (i, '张三', '22', '河南省信阳市淮滨县谷堆乡栗园村', '2021-08-19', '幼儿园大班');
set i=i+1;
end while;
commit;
end;
//

call inserttest22();
//

delimiter ;//
CREATE TABLE TESTOSS31(c0  BOOL, c1 BOOLEAN,c2 TINYINT(20),c3 SMALLINT,c4 MEDIUMINT,c5 INT(100) ZEROFILL,c6 INTEGER,c7 BIGINT,c8 DECIMAL(10, 5) ZEROFILL,c9 NUMERIC(10, 5),c10 FLOAT,c11 DOUBLE,c12 BIT(64)
,c13  DATE, c14 DATETIME,c15 TIMESTAMP(6),c16 TIME,c17 YEAR ,
c18  CHAR(200) CHARSET GBK, c19 VARCHAR(200) CHARSET GBK,c20 VARCHAR(200),c21 VARCHAR(200),
c22  TINYBLOB, c23 BLOB,c24 MEDIUMBLOB,c25 LONGBLOB,c26 TINYTEXT,c27 TEXT ,c28 MEDIUMTEXT ,c29 LONGTEXT,
c30 ENUM('T','F','1','中国') CHARSET GBK NOT NULL,
c31 SET('a', '中') CHARSET GBK NOT NULL,
c32 JSON NOT NULL )
;
INSERT INTO TESTOSS31 VALUES (0,true,45,11,11,11,11,9223372036854775807,10.2,10.2,-10.25,-13.45,b'10000000',
'0001-01-01','2099-12-31 23:59:59','2027-12-31 23:59:59.000000','-838:59:59.000000',2155,
'zhongguo人sfds111','zhongguo人sfds111','10000000','10000000',
1,20,200,'A20','中','中国','中国人','中国人abcedfg',
'中国',
'a,中',
'{"Url":    "http://www.example.com/image/481989943"}'
);


INSERT INTO TESTOSS31 VALUES (1,true,45,11,11,11,11,9223372036854775807,10.2,10.2,-10.25,-13.45,b'10000000',
'0001-01-01','2099-12-31 23:59:59','2027-12-31 23:59:59.000000','-838:59:59.000000',2155,
'zhongguo人sfds111','zhongguo人sfds111','10000000','10000000',
1,20,200,'A20','中','翯 翾','寗砼人','叄叅人abcedfg',
'中国',
'a,中',
'{"Url":    "http://www.example.com/image/481989943"}'
);

--disable_query_log
#### where 
select * from TESTOSS31 where c2 = 45 ;
select * from TESTOSS31 where c2 != 45 ;
select * from TESTOSS31 where c2 <> 45 ;
select * from TESTOSS31 where c2 <= 45 ;
select * from TESTOSS31 where c27 = '中';
select * from TESTOSS31 where c27 != '中';
select * from TESTOSS31 where c27 <> '中';
select * from TESTOSS31 where c27 <= '中';
select * from TESTOSS31 where c27 is NULL;
select * from TESTOSS31 where c26 is NULL;
select * from TESTOSS31 where c26 is NOT NULL;

let $FILE_NAME =TESTOSS400.txt;
--source mysql_test/test_suite/select_into_oss_sqlqa/include/delete_file.inc
--sorted_result
eval SELECT * INTO OUTFILE  '$OBSERVER_DIR/$DATA_FOLDER_NAME/$FILE_NAME' CHARACTER SET GBK FIELDS TERMINATED BY ',' ENCLOSED BY '"' LINES TERMINATED BY '\n' FROM TESTOSS31;
