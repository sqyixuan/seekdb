###创建各种类型的索引，本地索引、全局非分区索引、全局分区索引、唯一索引、单列索引、多列索引、函数索引等。
create index idx_1 on t_deduce_length(c_number);
create unique index idx_2 on t_deduce_length(c_int);
ALTER TABLE t_deduce_length ADD INDEX idx_3(c_varchar2_l);
ALTER TABLE t_deduce_length ADD INDEX idx_4(c_varchar2_l,c_number,c_char_c);
create index idx_6 on t_deduce_length(c_int) global partition by range (c_int)
(partition GLOBAL1 values less than(5),
partition GLOBAL2 values less than(10),
partition GLOBAL3 values less than(15),
partition GLOBAL4 values less than (MAXVALUE));
create index idx_7 on t_deduce_length(c_int) global partition by hash(c_int) partitions 4;
create index idx_8 on t_deduce_length(c_int,c_number,c_char_c) global partition by hash(c_int) partitions 4;
create index idx_9 on t_deduce_length(c_int) global invisible;

create table t_deduce_length2(
	c_int2 int,
    c_number2 float,
	c_number_l2 float,
	c_float2 float,
	c_binary_float2 float,
	c_binary_double2 double,
	c_blob2 varchar(200),
    c_date2 date,
    c_timestamp2 datetime,
    c_raw2 varchar(200),
    c_char2 char(200),
    c_char_c2 char(200),
    c_varchar22 varchar(200),
    c_varchar2_c2 varchar(200),
    c_varchar2_l2 varchar(200),
    c_nchar2 varchar(200),
    c_nvarchar2 varchar(200),
    c_nvarchar_l2 varchar(200),
    c_clob2 varchar(200)
)partition by range(c_int2)
subpartition by hash(c_int2) subpartitions 4
(partition part1 values less than(5),
partition part2 values less than(10),
partition part3 values less than(15),
partition part4 values less than(200));

