###使用索引/*+use_index(t_deduce_length idx_1)*/
let $FILE_NAME =TESTOSS510.txt;
--source mysql_test/test_suite/select_into_oss_sqlqa/include/delete_file.inc
--sorted_result
eval SELECT  /*+leading(t2 t1), use_index(t1 idx_1), use_nl(t1)*/ * INTO OUTFILE  '$OBSERVER_DIR/$DATA_FOLDER_NAME/$FILE_NAME' CHARACTER SET GBK FIELDS TERMINATED BY ',' ENCLOSED BY '"' LINES TERMINATED BY '\n'   from t_deduce_length t1, t_deduce_length2 t2 where t1.c_int = t2.c_int2 ORDER BY t1.c_int;
--source mysql_test/test_suite/select_into_oss_sqlqa/include/cat_file.inc

let $FILE_NAME =TESTOSS511.txt;
