--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: zhenling.zzg
#owner group: SQL1
#description: test for use_column_table hint
#tags: optimizer, outline

--result_format 4

--disable_warnings
drop table if exists t1;
drop table if exists t2;
--enable_warnings

create table t1(c1 int, c2 int, c3 int, c4 int);
create table t2(c1 int, c2 int, c3 int, c4 int)with column group (all columns, each column);

explain outline select c1 from t1;

explain outline select /*+use_column_table(t1)*/ c1 from t1;

explain outline select c1 from t2;

explain outline select /*+no_use_column_table(t2)*/ c1 from t2;

explain outline select /*+use_column_table(A) no_use_column_table(B)*/ A.c1, B.c1 from t2 A, t2 B;
