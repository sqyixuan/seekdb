--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: zhanyue.zzy
#owner group: SQL1
#description: test indedx ss hint
#tags: optimizer, outline

--result_format 4

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1(c1 int, c2 int, c3 int, c4 int, primary key(c1, c2, c3));
create index idx on t1(c1, c2, c3, c4) local;

explain extended_noaddr select /*+index_ss(t1 idx)*/ * from t1 where c1 <= 5 and c3 = 100;
explain extended_noaddr select /*+index_ss(t1 primary)*/ * from t1 where c1 <= 5 and c3 = 100;
explain extended_noaddr select /*+index_ss(t1 idx)*/ * from t1 where c1 <= 5;

explain extended_noaddr select /*+index_ss(b idx) leading(a b) use_nl(b)*/ * from t1 a, t1 b where a.c1 = b.c1 and b.c3 = 100;
explain extended_noaddr select /*+index_ss(b idx) leading(a b) use_nl(b)*/ * from t1 a, t1 b where a.c1 = b.c1;

explain extended_noaddr select /*+parallel(5) index_ss(t1 idx)*/ * from t1 where c1 <= 5 and c3 = 100;

drop table t1;

--disable_warnings
drop table if exists table10_key_pk_parts_2_int_not_null;
--enable_warnings

CREATE TABLE `table10_key_pk_parts_2_int_not_null` (
  `pk` int(11) NOT NULL,
  `col_double` double DEFAULT NULL,
  `col_decimal_20_0` decimal(20,0) DEFAULT NULL,
  `col_varchar_20` varchar(20) DEFAULT NULL,
  `col_bigint` bigint(20) DEFAULT NULL,
  `col_timestamp` timestamp NULL DEFAULT NULL,
  PRIMARY KEY (`pk`),
  KEY `in_expr_idx5` (`pk`, `col_bigint`, `col_varchar_20`, `col_timestamp`) BLOCK_SIZE 16384 LOCAL
) DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 3 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0
 partition by key(pk)
(partition p0,
partition p1);

explain extended_noaddr SELECT /*+ index_ss(table10_key_pk_parts_2_int_not_null in_expr_idx5) */ * FROM table10_key_pk_parts_2_int_not_null WHERE (col_timestamp) = ('2003-09-16 18:04:10.061570') and pk = 1;
explain extended_noaddr SELECT /*+ index_ss(table10_key_pk_parts_2_int_not_null in_expr_idx5) */ * FROM table10_key_pk_parts_2_int_not_null WHERE (col_timestamp) = ('2003-09-16 18:04:10.061570');

drop table table10_key_pk_parts_2_int_not_null;