--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: zhenling.zzg
#owner group: SQL1
#description: test for table_access_policy hint
#tags: optimizer

--result_format 4

--disable_warnings
drop table if exists t1;
drop table if exists t2;
drop table if exists t3;
--enable_warnings

create table t1(c1 int, c2 int, c3 int, c4 int);
create table t2(c1 int, c2 int, c3 int, c4 int)with column group(each column);
create table t3(c1 int, c2 int, c3 int, c4 int)with column group(each column, all columns);

create index t1_i1 on t1(c1);
create index t1_i2 on t1(c2)with column group(each column);
create index t1_i3 on t1(c3)with column group(each column, all columns);

create index t2_i1 on t2(c1);
create index t2_i2 on t2(c2)with column group(each column);
create index t2_i3 on t2(c3)with column group(each column, all columns);

create index t3_i1 on t3(c1);
create index t3_i2 on t3(c2)with column group(each column);
create index t3_i3 on t3(c3)with column group(each column, all columns);

--echo 预期走行存
explain select /*+use_column_table(A)*/ * from t1 A;
--echo 预期走列存
explain select /*+use_column_table(A)*/ * from t2 A;
--echo 预期走列存
explain select /*+use_column_table(A)*/ * from t3 A;

--echo 预期走行存
explain select /*+no_use_column_table(A)*/ * from t1 A;
--echo 预期走列存
explain select /*+no_use_column_table(A)*/ * from t2 A;
--echo 预期走行存
explain select /*+no_use_column_table(A)*/ * from t3 A;

set ob_table_access_policy=row_store;
--echo 预期主键索引
explain select * from t1 A where c2 = 1;
--echo 预期走i2索引
explain select /*+opt_param('OB_TABLE_ACCESS_POLICY','COLUMN_STORE')*/* from t1 A where c2 = 1;
--echo 预期走i2索引
explain select /*+opt_param('OB_TABLE_ACCESS_POLICY','AUTO')*/* from t1 A where c2 = 1;
--echo 预期走i2索引
explain select /*+index(A t1_i2)*/* from t1 A where c2 = 1;

--echo 预期走i1索引
explain select * from t2 A where c2 = 1;
--echo 预期走i2索引
explain select /*+opt_param('OB_TABLE_ACCESS_POLICY','COLUMN_STORE')*/* from t2 A where c2 = 1;
--echo 预期走i2索引
explain select /*+opt_param('OB_TABLE_ACCESS_POLICY','AUTO')*/* from t2 A where c2 = 1;
--echo 预期走i2索引
explain select /*+index(A t2_i2)*/* from t2 A where c2 = 1;

--echo 预期主键索引
explain select * from t3 A where c2 = 1;
--echo 预期走i2索引
explain select /*+opt_param('OB_TABLE_ACCESS_POLICY','COLUMN_STORE')*/* from t3 A where c2 = 1;
--echo 预期走i2索引
explain select /*+opt_param('OB_TABLE_ACCESS_POLICY','AUTO')*/* from t3 A where c2 = 1;
--echo 预期走i2索引
explain select /*+index(A t3_i2)*/* from t3 A where c2 = 1;

--echo 预期主键行存索引
explain select * from t3;

set ob_table_access_policy=column_store;

--echo 预期走i2索引
explain select * from t1 A where c1 = 1;
--echo 预期走i1索引
explain select /*+opt_param('OB_TABLE_ACCESS_POLICY','ROW_STORE')*/* from t1 A where c1 = 1;
--echo 预期走i1索引
explain select /*+opt_param('OB_TABLE_ACCESS_POLICY','AUTO')*/* from t1 A where c1 = 1;
--echo 预期走i1索引
explain select /*+index(A t1_i1)*/* from t1 A where c1 = 1;

--echo 预期主键列存索引
explain select * from t2 A where c1 = 1;
--echo 预期走i1索引
explain select /*+opt_param('OB_TABLE_ACCESS_POLICY','ROW_STORE')*/* from t2 A where c1 = 1;
--echo 预期走i1索引
explain select /*+opt_param('OB_TABLE_ACCESS_POLICY','AUTO')*/* from t2 A where c1 = 1;
--echo 预期走i1索引
explain select /*+index(A t2_i1)*/* from t2 A where c1 = 1;

--echo 预期主键列存索引
explain select * from t3 A where c1 = 1;
--echo 预期走i1索引
explain select /*+opt_param('OB_TABLE_ACCESS_POLICY','ROW_STORE')*/* from t3 A where c1 = 1;
--echo 预期走i1索引
explain select /*+opt_param('OB_TABLE_ACCESS_POLICY','AUTO')*/* from t3 A where c1 = 1;
--echo 预期走i1索引
explain select /*+index(A t3_i1)*/* from t3 A where c1 = 1;

--echo 预期主键列存索引
explain select * from t3;

set ob_table_access_policy=auto;