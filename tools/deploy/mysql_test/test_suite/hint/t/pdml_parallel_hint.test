#owner: zhanyue.zzy
#owner group: SQL1
#description: test hint for pdml
#tags: outline, optimizer

--result_format 4

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1(c1 int, c2 int, c3 int);

explain outline insert into t1 select /*+enable_parallel_dml dml_parallel(1) parallel(t1, 4)*/ * from t1;
explain outline insert into t1 select /*+enable_parallel_dml dml_parallel(2) parallel(t1, 4)*/ * from t1;
explain outline insert into t1 select /*+enable_parallel_dml dml_parallel(8) parallel(t1, 4)*/ * from t1;
explain outline insert into t1 select /*+dml_parallel(8) parallel(t1, 4)*/ * from t1;
explain outline insert into t1 select /*+parallel(auto) dml_parallel(2) parallel(t1, 4)*/ * from t1;

explain outline update /*+enable_parallel_dml dml_parallel(1) parallel(t1, 4)*/ t1 set c2 = 4;
explain outline update /*+enable_parallel_dml dml_parallel(2) parallel(t1, 4)*/ t1 set c2 = 4;
explain outline update /*+enable_parallel_dml dml_parallel(8) parallel(t1, 4)*/ t1 set c2 = 4;
explain outline update /*+dml_parallel(8) parallel(t1, 4)*/ t1 set c2 = 4;
explain outline update /*+parallel(auto) dml_parallel(2) parallel(t1, 4)*/ t1 set c2 = 4;

explain outline delete /*+enable_parallel_dml dml_parallel(1) parallel(t1, 4)*/ from t1 where c2 = 4;
explain outline delete /*+enable_parallel_dml dml_parallel(2) parallel(t1, 4)*/ from t1 where c2 = 4;
explain outline delete /*+enable_parallel_dml dml_parallel(8) parallel(t1, 4)*/ from t1 where c2 = 4;
explain outline delete /*+dml_parallel(8) parallel(t1, 4)*/ from t1 where c2 = 4;
explain outline delete /*+parallel(auto) dml_parallel(2) parallel(t1, 4)*/ from t1 where c2 = 4;

drop table t1;
