--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: zhanyue.zzy
#owner group: SQL1
#description: test for or query push down hint: merge/no_merge
#tags: optimizer, outline

--result_format 4

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1(c1 int, c2 int, c3 int, c4 int);

explain outline select * from (select c1 from t1 group by c1);

explain outline select * from (select /*+MERGE(@"SEL$2" < "SEL$1")*/c1 from t1 group by c1);

explain outline select * from (select /*+MERGE(@"SEL$1" < "SEL$2")*/c1 from t1 group by c1);

explain outline select * from (select /*+MERGE*/* from (select /*+MERGE(@"SEL$3" < "SEL$2")*/c1 from t1 group by c1));
explain outline select /*+MERGE(@"SEL$2" > "SEL$1") MERGE(@"SEL$3" < "SEL$2")*/ * from (select * from (select c1 from t1 group by c1));
explain outline select
  /*+
      BEGIN_OUTLINE_DATA
      MERGE(@"SEL$2" > "SEL$1")
      MERGE(@"SEL$3" < "SEL$CFEA49FE")
      END_OUTLINE_DATA
  */ * from (select * from (select c1 from t1 group by c1));

explain outline select * from (select /*+NO_MERGE*/c1 from t1 group by c1);
explain outline select * from (select /*+NO_REWRITE*/c1 from t1 group by c1);
explain outline select /*+NO_REWRITE*/ * from (select c1 from t1 group by c1);

explain outline select * from (select /*+NO_MERGE(@"SEL$2")*/c1 from t1 group by c1);

explain outline select * from (select /*+NO_MERGE*/* from (select /*+MERGE(@"SEL$3" < "SEL$2")*/c1 from t1 group by c1));
explain outline select /*+NO_MERGE(@"SEL$2") MERGE(@"SEL$3" < "SEL$2")*/* from (select * from (select c1 from t1 group by c1));

drop table t1;