--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: yibo.tyf
#owner group: sql1
#description: test for transform hint: left_to_anti/no_left_to_anti
#tags: outline, optimizer

--disable_warnings
drop table if exists t1, t2, t3, t4, t5;
--enable_warnings
create table t1(c1 int, c2 int);
create table t2(c1 int, c2 int);
create table t3(c1 int, c2 int);
create table t4(c1 int, c2 int);
create table t5(c1 int, c2 int);

--explain_protocol 0
explain outline select * from t1 left join t2 on t1.c1 = t2.c1 where t2.c1 is null;
explain outline select /*+left_to_anti*/ * from t1 left join t2 on t1.c1 = t2.c1 where t2.c1 is null;
explain outline select /*+left_to_anti(t1)*/ * from t1 left join t2 on t1.c1 = t2.c1 where t2.c1 is null;
explain outline select /*+left_to_anti(t2)*/ * from t1 left join t2 on t1.c1 = t2.c1 where t2.c1 is null;
explain outline select /*+left_to_anti(@"SEL$1")*/ * from t1 left join t2 on t1.c1 = t2.c1 where t2.c1 is null;
explain outline select /*+left_to_anti(@"SEL$1" t2)*/ * from t1 left join t2 on t1.c1 = t2.c1 where t2.c1 is null;
explain outline select /*+left_to_anti(@"SEL$1" t1)*/ * from t1 left join t2 on t1.c1 = t2.c1 where t2.c1 is null;
explain outline select /*+left_to_anti(@"SEL$233" t1)*/ * from t1 left join t2 on t1.c1 = t2.c1 where t2.c1 is null;
explain outline select /*+left_to_anti(V)*/ * from t1 left join (select c1 from t2) V on t1.c1 = V.c1 where V.c1 is null;
explain outline select /*+left_to_anti(@"SEL$1" t2)*/* from t1 left join t2 on t1.c1 = t2.c1, t3 left join t4 on t3.c1 = t4.c1 where t2.c1 is null and t4.c1 is null;
explain outline select /*+left_to_anti(t2)*/* from t1 left join t2 on t1.c1 = t2.c1, t3 left join t4 on t3.c1 = t4.c1 where t2.c1 is null and t4.c1 is null;
explain outline select /*+left_to_anti(t1 t2)*/* from t1 left join t2 on t1.c1 = t2.c1, t3 left join t4 on t3.c1 = t4.c1 where t2.c1 is null and t4.c1 is null;
explain outline select /*+left_to_anti(t4)*/* from t1 left join t2 on t1.c1 = t2.c1, t3 left join t4 on t3.c1 = t4.c1 where t2.c1 is null and t4.c1 is null;
explain outline select /*+left_to_anti(t2 t4)*/* from t1 left join t2 on t1.c1 = t2.c1, t3 left join t4 on t3.c1 = t4.c1 where t2.c1 is null and t4.c1 is null;
explain outline select /*+left_to_anti(t2 t4)*/* from t1 left join t2 on t1.c1 = t2.c1, t3 left join t4 on t3.c1 = t4.c1, t1 as tt left join t3 tt3 on tt.c1 = tt3.c1 where t2.c1 is null and t4.c1 is null and tt3.c1 is null;

explain outline select /*+left_to_anti((t2 t3))*/ * from t1 left join (t2 inner join t3 on t2.c2 = t3.c2) on t1.c1 = t2.c1 where t2.c1 is null;
explain outline select /*+left_to_anti(t2 (t4 t5))*/ * from t1 left join t2 on t1.c1 = t2.c1, (t3 left join (t4 inner join t5 on t4.c2 = t5.c2) on t3.c1 = t4.c1) where t2.c1 is null and t4.c1 is null;

explain outline select /*+no_left_to_anti*/ * from t1 left join t2 on t1.c1 = t2.c1 where t2.c1 is null;
explain outline select /*+no_left_to_anti(@"SEL$1")*/ * from t1 left join t2 on t1.c1 = t2.c1 where t2.c1 is null;
explain outline select /*+no_left_to_anti*/* from t1 left join t2 on t1.c1 = t2.c1, t3 left join t4 on t3.c1 = t4.c1, t1 as tt left join t3 tt3 on tt.c1 = tt3.c1 where t2.c1 is null and t4.c1 is null and tt3.c1 is null;
explain outline select /*+no_left_to_anti(@"SEL$1")*/* from t1 left join t2 on t1.c1 = t2.c1, t3 left join t4 on t3.c1 = t4.c1, t1 as tt left join t3 tt3 on tt.c1 = tt3.c1 where t2.c1 is null and t4.c1 is null and tt3.c1 is null;

--disable_warnings
drop table if exists t1, t2, t3, t4, t5;
--enable_warnings
