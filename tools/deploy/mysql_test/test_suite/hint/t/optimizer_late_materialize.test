--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: zhenling.zzg
#owner group: SQL1
#description: test for use_column_table hint
#tags: optimizer, outline

--result_format 4

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1(c1 int, c2 int, c3 int, c4 int)with column group(all columns, each column);

insert into t1 values(1,1,1,1);
insert into t1 values(1,1,1,1);
insert into t1 values(1,1,1,1);
insert into t1 values(1,1,1,1);
insert into t1 values(1,1,1,1);
insert into t1 values(1,1,1,1);

explain outline select /*+use_column_table(t1)*/ * from t1 order by c1 limit 1;

explain outline select  /*+use_column_table(t1)*/ c1 from t1 order by c1 limit 1;

explain outline select  /*+use_column_table(t1)*/ c2 from t1 order by c1 limit 1;

explain outline select /*+no_use_column_table(t1)*/ * from t1 order by c1 limit 1;

explain outline select /*+NO_USE_LATE_MATERIALIZATION use_column_table(t1)*/ * from t1 order by c1 limit 1;
