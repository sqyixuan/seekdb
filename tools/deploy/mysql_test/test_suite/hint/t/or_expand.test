--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: zhanyue.zzy
#owner group: SQL1
#description: test for or expansion hint: use_concat
#tags: optimizer, outline

--result_format 4

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1(c1 int, c2 int, c3 int, c4 int);

## use_concat test baisc
explain outline select /*+use_concat*/ * from t1 where c1 = 34 or c2 = 4;
explain outline select /*+use_concat()*/ * from t1 where c1 = 34 or c2 = 4;
explain outline select /*+use_concat(@sel$2)*/ * from t1 where exists (select * from t1 where c1 = 34 or c2 = 4);
explain outline select /*+use_concat*/ * from t1 where (c1 = 34 or c2 = 4) and (c3 = 3 or c4 = 2);

## use_concat expr string match test baisc
explain outline select /*+use_concat('t1.c1 = ? or t1.c2 = ?')*/ * from t1 where (c1 = 34 or c2 = 4) and (c3 = 3 or c4 = 2);
explain outline select /*+use_concat('t1.c3 = ? or t1.c4 = ?')*/ * from t1 where (c1 = 34 or c2 = 4) and (c3 = 3 or c4 = 2);
explain outline select /*+use_concat('t1.c1 + t1.c2 = ? or t1.c2 = ?')*/ * from t1 where c1+c2 = 34 or c2 = 4;
explain outline select /*+use_concat('t1.c1 + t1.c2 = ? or t1.c2 = sq(sel$2)')*/ * from t1 where c1+c2 = 34 or c2 = (select /*+no_unnest*/ c2 from t1);
explain outline select /*+use_concat('t1.c1 % t1.c2 = ? or t1.c2 != sq(sel$2)')*/ * from t1 where c1%c2 = 34 or c2 != (select /*+no_unnest*/ c2 from t1);
## expr string no match, do not transform
explain outline select /*+use_concat('t1.c2 = ? or t1.c1 = ?')*/ * from t1 where c1 = 34 or c2 = 4;

## test inner/outer join
explain outline select /*+use_concat*/ * from t1 a left join (t1 b join t1 c on b.c1 = c.c1 or b.c2 = c.c2) on 1 = 1;
explain outline select /*+use_concat('b.c1 = c.c1 or b.c2 = c.c2')*/ * from t1 a left join (t1 b join t1 c on b.c3 = c.c3 and (b.c1 = c.c1 or b.c2 = c.c2)) on 1 = 1;
explain outline select /*+use_concat*/ * from t1 a left join (t1 b left join t1 c on b.c1 = c.c1 or b.c2 = c.c2) on 1 = 1;
explain outline select /*+use_concat('b.c1 = c.c1 or b.c2 = c.c2')*/ * from t1 a left join (t1 b left join t1 c on b.c3 = c.c3 and (b.c1 = c.c1 or b.c2 = c.c2)) on 1 = 1;

## test semi/anti join
explain outline select /*+use_concat*/ * from t1 a where exists (select 1 from t1 b where a.c1 = b.c1 or a.c2 = b.c2);
explain outline select /*+use_concat('a.c1 = VIEW1.b.c1 OR a.c2 = VIEW1.b.c2')*/ * from t1 a where exists (select 1 from t1 b where b.c3 = a.c3 and (a.c1 = b.c1 or a.c2 = b.c2));
explain outline select * from t1 a where not exists (select 1 from t1 b where a.c1 = b.c1 or a.c2 = b.c2);
explain outline select /*+use_concat('a.c1 = VIEW1.b.c1 OR a.c2 = VIEW1.b.c2')*/ * from t1 a where not exists (select 1 from t1 b where a.c1 = b.c1 or a.c2 = b.c2);

## expr string match test
explain outline select /*+use_concat*/ a.c1, b.c1, c.c1
from t1 a left join (t1 b left join t1 c on b.c3 = 4 and (b.c1 = c.c1 or b.c2 = c.c2)) on a.c1 = b.c1
where (a.c2 = 3 or a.c3 = 4)
    and exists (select * from t1 d where a.c1 = d.c1 or a.c2 = d.c2);

explain outline select /*+use_concat('b.c1 = c.c1 or b.c2 = c.c2')*/ a.c1, b.c1, c.c1
from t1 a left join (t1 b left join t1 c on b.c3 = 4 and (b.c1 = c.c1 or b.c2 = c.c2)) on a.c1 = b.c1
where (a.c2 = 3 or a.c3 = 4)
    and exists (select * from t1 d where a.c1 = d.c1 or a.c2 = d.c2);

explain outline select /*+use_concat('a.c2 = ? or a.c3 = ?')*/ a.c1, b.c1, c.c1
from t1 a left join (t1 b left join t1 c on b.c3 = 4 and (b.c1 = c.c1 or b.c2 = c.c2)) on a.c1 = b.c1
where (a.c2 = 3 or a.c3 = 4)
    and exists (select * from t1 d where a.c1 = d.c1 or a.c2 = d.c2);

explain outline select /*+use_concat('a.c1 = VIEW1.d.c1 OR a.c2 = VIEW1.d.c2')*/ a.c1, b.c1, c.c1
from t1 a left join (t1 b left join t1 c on b.c3 = 4 and (b.c1 = c.c1 or b.c2 = c.c2)) on a.c1 = b.c1
where (a.c2 = 3 or a.c3 = 4)
    and exists (select * from t1 d where a.c1 = d.c1 or a.c2 = d.c2);

