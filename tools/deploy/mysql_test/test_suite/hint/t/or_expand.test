NOT ( LOWER( TRIM( SUBSTR( CONCAT(SUBSTR( SUBSTR( 'x' , 1, 20) FROM 5 + 1 ) , SUBSTR( SUBSTR( CAST( ( ROUND( SIGN( -99999 ) ) ) AS CHAR(100) ) , 1 , 20 ) , 2 , 1 ) ) , 1 , 20 ) ) ) LIKE LOWER( TRIM( SUBSTR( CONCAT(SUBSTR( 't' , 1, 20) , SUBSTR( 'k' , 1, 20) ) , 1 , 20 ) ) ) ESCAPE 'a' ) ) AND ( col_bigint in ( 15105 ) AND ( ROUND( ROUND( col_decimal_20_0 ) ) ) IS NULL ) AND col_decimal_20_0 NOT IN ( SELECT col_decimal_20_0 FROM table1_bigint WHERE pk = ( -10 ) ORDER BY col_char_20 DESC , pk ASC ) ORDER BY col_bigint  , col_char_20 DESC , pk DESC LIMIT 2;


DROP TABLE `table0_bigint`;
DROP TABLE `table1_bigint`;
DROP TABLE `table2_bigint`;


