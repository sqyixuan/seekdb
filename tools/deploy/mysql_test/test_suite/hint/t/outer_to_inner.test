#owner: yibo.tyf
#owner group: sql1
# tags: outline, optimizer

--disable_warnings
drop table if exists t1,t2;
--enable_warnings

create table t1(c1 int, c2 int, c3 int);
create table t2(d1 int, d2 int, d3 int);

insert into t1 values(1,1,1), (2,2,2) ,(3,3,3), (4,4,4), (5,5,5), (6,6,6), (7,7,7);
insert into t2 values(1,1,1), (2,2,2) ,(3,3,3), (4,4,4), (5,5,5);

explain outline select * from t1 left join t2 on c1 = d1 where d2 > 0;
select * from t1 left join t2 on c1 = d1 where d2 > 0;

explain outline select /*+no_outer_to_inner*/ * from t1 left join t2 on c1 = d1 where d2 > 0;
select /*+no_outer_to_inner*/ * from t1 left join t2 on c1 = d1 where d2 > 0;

explain outline select /*+no_outer_to_inner(@"SEL$1")*/ * from t1 left join t2 on c1 = d1 where d2 > 0;
select /*+no_outer_to_inner(@"SEL$1")*/ * from t1 left join t2 on c1 = d1 where d2 > 0;

explain outline select * from 
  (select c1, c2, d1, d2 from t1 left join t2 on c1 = d1 where d2 > 0 limit 5) v
where v.c1 > 2;
select * from 
  (select c1, c2, d1, d2 from t1 left join t2 on c1 = d1 where d2 > 0 limit 5) v
where v.c1 > 2;

explain outline select /*+NO_OUTER_TO_INNER(@"SEL$2")*/ * from 
  (select c1, c2, d1, d2 from t1 left join t2 on c1 = d1 where d2 > 0 limit 5) v
where v.c1 > 2;

select /*+NO_OUTER_TO_INNER(@"SEL$2")*/ * from 
  (select c1, c2, d1, d2 from t1 left join t2 on c1 = d1 where d2 > 0 limit 5) v
where v.c1 > 2;

drop table if exists t1,t2;