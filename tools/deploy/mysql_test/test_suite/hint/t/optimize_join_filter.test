--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: zhanyue.zzy
#owner group: SQL1
#description: test for optimize hint about join filter: px_join_filter, px_part_join_filter
#tags: optimizer, outline

--result_format 4

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1(c1 int, c2 int, c3 int, c4 int) partition by hash(c1) partitions 10;

## 1. basic test
explain outline select
/*+parallel(2) leading(a b) use_hash(b) PQ_DISTRIBUTE(b bc2host none)
px_join_filter(b)
px_part_join_filter(b)
*/ *
from t1 a, t1 b where a.c1 = b.c1;

explain outline select 
/*+ parallel(2) leading(a b) use_hash(b) PQ_DISTRIBUTE(b bc2host none) 
PX_PART_JOIN_FILTER(@"SEL$1" "b"@"SEL$1" "test"."a"@"SEL$1" "test"."t1"@"SEL$2") 
PX_JOIN_FILTER(@"SEL$1" "b"@"SEL$1" "test"."a"@"SEL$1" "test"."t1"@"SEL$2") 
*/ * 
from t1 a, (select /*+ no_merge */ * from t1) b where a.c1 = b.c1;

explain outline select
/*+parallel(2) leading(a b) use_hash(b) PQ_DISTRIBUTE(b bc2host none)
px_join_filter(b)
px_part_join_filter(b)
*/ *
from t1 a, t1 b where a.c1 = b.c1;

explain outline select
/*+parallel(2) leading(a b) use_hash(b) PQ_DISTRIBUTE(b bc2host none)
px_join_filter(b a)
px_part_join_filter(b a)
*/ *
from t1 a, t1 b where a.c1 = b.c1;

explain outline select
/*+parallel(2) leading(a b) use_hash(b) PQ_DISTRIBUTE(b bc2host none)
px_join_filter(b)
no_px_part_join_filter(b)
*/ *
from t1 a, t1 b where a.c1 = b.c1;

explain outline select
/*+parallel(2) leading(a b) use_hash(b) PQ_DISTRIBUTE(b bc2host none)
no_px_join_filter(b)
px_part_join_filter(b)
*/ *
from t1 a, t1 b where a.c1 = b.c1;

explain outline select
/*+parallel(2) leading(a b) use_hash(b) PQ_DISTRIBUTE(b bc2host none)
no_px_join_filter(b)
no_px_part_join_filter(b)
*/ *
from t1 a, t1 b where a.c1 = b.c1;

## 2. conflict deal, use disable hint
explain outline select
/*+parallel(2) leading(a b) use_hash(b) PQ_DISTRIBUTE(b bc2host none)
px_join_filter(b)
px_part_join_filter(b)
no_px_join_filter(b)
no_px_part_join_filter(b)
*/ *
from t1 a, t1 b where a.c1 = b.c1;

explain outline select
/*+parallel(2) leading(a b) use_hash(b) PQ_DISTRIBUTE(b bc2host none)
px_join_filter(b)
no_px_join_filter(b a)
no_px_part_join_filter(b)
*/ *
from t1 a, t1 b where a.c1 = b.c1;

explain outline select
/*+parallel(2) leading(a b) use_hash(b) PQ_DISTRIBUTE(b bc2host none)
no_px_join_filter(b)
px_join_filter(b a)
no_px_part_join_filter(b)
*/ *
from t1 a, t1 b where a.c1 = b.c1;

## 3. multi table test
explain outline select
/*+parallel(2) leading(a b c) use_hash(b c) PQ_DISTRIBUTE(b bc2host none) PQ_DISTRIBUTE(c bc2host none)
px_join_filter(c)
no_px_part_join_filter(c)
px_part_join_filter(b)
no_px_part_join_filter(b)
*/ *
from t1 a, t1 b, t1 c where a.c1 = c.c1 and b.c1 = c.c1;

explain outline select 
/*+parallel(2) leading(a b c) use_hash(b c) PQ_DISTRIBUTE(b bc2host none) PQ_DISTRIBUTE(c bc2host none) 
PX_JOIN_FILTER(@"SEL$1" "c"@"SEL$1" ("test"."a"@"SEL$1" "test"."b"@"SEL$1") "test"."t1"@"SEL$2")  
NO_PX_PART_JOIN_FILTER(@"SEL$1" "c"@"SEL$1" ("test"."a"@"SEL$1" "test"."b"@"SEL$1") "test"."t1"@"SEL$2") 
px_part_join_filter(b) no_px_part_join_filter(b) 
*/ * from t1 a, t1 b, (select /*+ no_merge */ * from t1) c where a.c1 = c.c1 and b.c1 = c.c1;

explain outline select
/*+parallel(2) leading(a (b c)) use_hash(c (b c)) PQ_DISTRIBUTE((b c) bc2host none) PQ_DISTRIBUTE(c bc2host none)
no_px_join_filter(c)
px_join_filter(b)
px_part_join_filter(c)
no_px_part_join_filter(b)
*/ *
from t1 a, t1 b, t1 c where a.c1 = c.c1 and b.c1 = c.c1;

explain outline select
/*+parallel(2) leading(a (b c)) use_hash(c (b c)) PQ_DISTRIBUTE((b c) bc2host none) PQ_DISTRIBUTE(c bc2host none)
no_px_join_filter(c)
no_px_join_filter(b)
no_px_part_join_filter(c)
no_px_part_join_filter(b)
px_join_filter(c a)
*/ *
from t1 a, t1 b, t1 c where a.c1 = c.c1 and b.c1 = c.c1;

explain outline select
/*+parallel(2) leading(a (b c)) use_hash(c (b c)) PQ_DISTRIBUTE((b c) bc2host none) PQ_DISTRIBUTE(c bc2host none)
no_px_join_filter(c)
no_px_join_filter(b)
no_px_part_join_filter(c)
no_px_part_join_filter(b)
px_join_filter(b a)
*/ *
from t1 a, t1 b, t1 c where a.c1 = c.c1 and b.c1 = c.c1;

explain outline select
/*+parallel(2) leading(a (b c)) use_hash(c (b c)) PQ_DISTRIBUTE((b c) bc2host none) PQ_DISTRIBUTE(c bc2host none)
no_px_join_filter(c)
no_px_join_filter(b a)
no_px_part_join_filter(c)
no_px_part_join_filter(b)
px_join_filter(b a)
*/ *
from t1 a, t1 b, t1 c where a.c1 = c.c1 and b.c1 = c.c1;
