#owner: yibo.tyf
#owner group: sql1
# tags: outline, optimizer

--disable_warnings
drop table if exists t1,t2,t3,t4;
--enable_warnings

create table t1(c1 int, c2 int, c3 int);
create table t2(d1 int, d2 int, d3 int);
create table t3(e1 int, e2 int, e3 int);
create table t4(f1 int, f2 int, f3 int);
call dbms_stats.gather_table_stats(NULL, 't1');
call dbms_stats.gather_table_stats(NULL, 't2');
call dbms_stats.gather_table_stats(NULL, 't3');
call dbms_stats.gather_table_stats(NULL, 't4');

explain outline select * from t1 where t1.c1 > (select avg(d1) from t2 where t1.c2 = t2.d2);

explain outline select * from t1 where t1.c1 > (select /*+NO_UNNEST*/ avg(d1) from t2 where t1.c2 = t2.d2);
explain outline select * from t1 where t1.c1 > (select /*+NO_AGGR_FIRST_UNNEST*/ avg(d1) from t2 where t1.c2 = t2.d2);
explain outline select * from t1 where t1.c1 > (select /*+NO_JOIN_FIRST_UNNEST*/ avg(d1) from t2 where t1.c2 = t2.d2);
explain outline select * from t1 where t1.c1 > (select /*+NO_AGGR_FIRST_UNNEST,NO_JOIN_FIRST_UNNEST*/ avg(d1) from t2 where t1.c2 = t2.d2);

explain outline select /*+NO_UNNEST(@"SEL$2")*/ * from t1 where t1.c1 > (select avg(d1) from t2 where t1.c2 = t2.d2);
explain outline select /*+NO_AGGR_FIRST_UNNEST(@"SEL$2")*/ * from t1 where t1.c1 > (select avg(d1) from t2 where t1.c2 = t2.d2);
explain outline select /*+NO_JOIN_FIRST_UNNEST(@"SEL$2")*/ * from t1 where t1.c1 > (select avg(d1) from t2 where t1.c2 = t2.d2);
explain outline select /*+NO_AGGR_FIRST_UNNEST(@"SEL$2"), NO_JOIN_FIRST_UNNEST(@"SEL$2")*/ * from t1 where t1.c1 > (select avg(d1) from t2 where t1.c2 = t2.d2);

explain outline select * from t1 where t1.c1 > (select avg(d1) from t2 where t1.c2 < t2.d2);
explain outline select * from t1 where t1.c1 > (select /*+NO_UNNEST*/ avg(d1) from t2 where t1.c2 < t2.d2);
explain outline select * from t1 where t1.c1 > (select /*+NO_AGGR_FIRST_UNNEST*/ avg(d1) from t2 where t1.c2 < t2.d2);
explain outline select * from t1 where t1.c1 > (select /*+NO_JOIN_FIRST_UNNEST*/ avg(d1) from t2 where t1.c2 < t2.d2);
explain outline select * from t1 where t1.c1 > (select /*+NO_AGGR_FIRST_UNNEST,NO_JOIN_FIRST_UNNEST*/ avg(d1) from t2 where t1.c2 < t2.d2);

explain outline select /*+NO_UNNEST(@"SEL$2")*/ * from t1 where t1.c1 > (select avg(d1) from t2 where t1.c2 < t2.d2);
explain outline select /*+NO_AGGR_FIRST_UNNEST(@"SEL$2")*/ * from t1 where t1.c1 > (select avg(d1) from t2 where t1.c2 < t2.d2);
explain outline select /*+NO_JOIN_FIRST_UNNEST(@"SEL$2")*/ * from t1 where t1.c1 > (select avg(d1) from t2 where t1.c2 < t2.d2);
explain outline select /*+NO_AGGR_FIRST_UNNEST(@"SEL$2"),NO_JOIN_FIRST_UNNEST(@"SEL$2")*/ * from t1 where t1.c1 > (select avg(d1) from t2 where t1.c2 < t2.d2);

## default transform sel$2 first
explain outline select * from t1 
where t1.c1 > (select avg(d1) from t2 where t1.c2 < t2.d2) 
            + (select avg(e1) from t3 where t1.c3 < t3.e3);

## outline requert transform sel$3 first 

## default transform sel$3 first by aggr first trans
explain outline select * from t1 
where t1.c1 > (select avg(d1) from t2 where t1.c2 < t2.d2) 
  and t1.c1 < (select avg(e1) from t3 where t1.c3 = t3.e3);

## default transform sel$4 first by aggr first trans
explain outline select * from t1 
where t1.c1 > (select avg(d1) from t2 where t1.c2 < t2.d2) 
  and t1.c1 > (select avg(f1) from t4 where t1.c2 < t4.f2) 
  and t1.c1 < (select avg(e1) from t3 where t1.c3 = t3.e3);

drop table if exists t1,t2,t3,t4;