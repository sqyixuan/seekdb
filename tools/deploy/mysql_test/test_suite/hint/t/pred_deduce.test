#owner: zhanyue.zzy
#owner group: sql3
# tags: optimizer, outline
##
## Test Name: pred_deduce.test

--disable_warnings
drop table if exists t1, t2, t3, part, lineitem;
--enable_warnings

create table t1 ( pk int ,c1 int not null, c2 int ,c3 int, primary key(pk));
create table t2 ( pk int ,c1 int not null, c2 int ,c3 int, primary key(pk));
create table t3 ( pk int ,c1 int not null, c2 int ,c3 int, primary key(pk));

explain outline
select c2, c3 from t1 where c2 is null
intersect
select c2, c3 from t2;

explain outline select /*+NO_SIMPLIFY_EXPR*/ * from (select /*+no_merge*/ * from t1 where c2 is not null) v where c2 is not null;

explain outline select * from t1 ,t2 where t1.c1 > 1 and t2.c1 > t1.c1;
explain outline select  /*+no_pred_deduce*/ * from t1 ,t2 where t1.c1 > 1 and t2.c1 > t1.c1;

explain outline select * from t1 ,t2 
where t1.c1 > 1 and t2.c1 > t1.c1 and 10 > (select count(*) from t2 a, t2 b where a.c1 >1 and b.c1>a.c1);

explain outline select  /*+no_rewrite*/ * from t1 ,t2 where t1.c1 > 1 and t2.c1 > t1.c1;

explain outline select /*+no_merge*/ * 
  from (select /*+no_merge*/ v1.c1,v1.c2 
    from (select /*+no_merge*/ t1.c1,t2.c2 from t1, t2 where t1.c1>0) v1 where v1.c1 >1) v2 
      where v2.c1 = v2.c2;

explain outline select /*+no_merge*/ * from (select /*+no_merge*/ v1.c1,v1.c2 
  from (select /*+no_merge +no_pred_deduce*/ t1.c1,t2.c2 
    from t1, t2 where t1.c1>0) v1 where v1.c1 >1) v2 where v2.c1 = v2.c2;

explain outline select /*+no_replace_const*/ * 
from (select * from t1) t1 where t1.c1=t1.c2 and t1.c2 = 1;


explain outline select /* +no_merge*/ * 
from (select /*+no_merge +no_pred_deduce*/ * 
      from (select /*+no_replace_const*/ * 
            from t1 where  t1.c1=t1.c2) t1) t1 
where t1.c2 = 1;

  explain outline select *  from (select /*+no_pred_deduce +no_merge*/ * from (select /*+no_merge +no_replace_const*/ * from t1 where  t1.c1=t1.c2) t1) t1 where t1.c2 = 1;
  

--disable_warnings
drop table if exists b1;
drop table if exists b2;
drop table if exists b3;
drop table if exists b4;
drop table if exists b5;
--enable_warnings
