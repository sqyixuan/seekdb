--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: zhanyue.zzy
#owner group: SQL1
#description: test for optimize hint about group by: use_hash_aggregation, gby_pushdown, pq_gby
#tags: optimizer, outline

--result_format 4

--disable_warnings
drop table if exists t1;
drop table if exists tp1;
--enable_warnings

create table t1(c1 int, c2 int, c3 int, c4 int);
create table tp1(c1 int, c2 int, c3 int, c4 int) partition by hash(c1) partitions 8;
create index tp1_idx_c4 on tp1(c4) local;

## aggregate function without distinct
explain outline select /*+use_hash_aggregation gby_pushdown*/ sum(c2) from t1 group by c1;
explain outline select /*+no_use_hash_aggregation gby_pushdown*/ sum(c2) from t1 group by c1;

explain outline select /*+use_hash_aggregation gby_pushdown parallel(2)*/ sum(c2) from t1 group by c1;
explain outline select /*+no_use_hash_aggregation gby_pushdown parallel(2)*/ sum(c2) from t1 group by c1;
explain outline select /*+use_hash_aggregation no_gby_pushdown parallel(2)*/ sum(c2) from t1 group by c1;
explain outline select /*+no_use_hash_aggregation no_gby_pushdown parallel(2)*/ sum(c2) from t1 group by c1;

explain outline select /*+ distinct_pushdown pq_gby(hash) */ sum(c2) from t1 group by c1;
explain outline select /*+ parallel(2)*/ sum(c2) from tp1 group by c1;
explain outline select /*+ parallel(16)*/ sum(c2) from tp1 group by c1;
explain outline select /*+ parallel(2) pq_gby(basic)*/ sum(c2) from tp1 group by c1;
explain outline select /*+ parallel(2) pq_gby(none)*/ sum(c2) from tp1 group by c1;
explain outline select /*+ parallel(16) pq_gby(none)*/ sum(c2) from tp1 group by c1;
explain outline select /*+ parallel(2) pq_gby(hash)*/ sum(c2) from tp1 group by c1;
explain outline select /*+ parallel(16) pq_gby(hash)*/ sum(c2) from tp1 group by c1;
explain outline select (select /*+ parallel(16) pq_gby(basic)*/ sum(c2) from tp1 where c4 = t1.c2 group by c1) from t1;
explain outline select (select /*+ parallel(16) pq_gby(none)*/ sum(c2) from tp1 where c4 = t1.c2 group by c1) from t1;
explain outline select (select /*+ parallel(16) pq_gby(hash)*/ sum(c2) from tp1 where c4 = t1.c2 group by c1) from t1;


## aggregate function with distinct
explain outline select /*+use_hash_aggregation gby_pushdown*/ sum(distinct c2), count(distinct c3) from t1 group by c1;

explain outline select /*+use_hash_aggregation gby_pushdown parallel(2)*/ sum(distinct c2), count(distinct c3) from t1 group by c1;
explain outline select /*+no_use_hash_aggregation gby_pushdown parallel(2)*/ sum(distinct c2), sum(distinct c3) from t1 group by c1;
explain outline select /*+use_hash_aggregation no_gby_pushdown parallel(2)*/ sum(distinct c2), sum(distinct c3) from t1 group by c1;
explain outline select /*+no_use_hash_aggregation no_gby_pushdown parallel(2)*/ sum(distinct c2), sum(distinct c3) from t1 group by c1;

explain outline select /*+ parallel(16) pq_gby(basic)*/ sum(distinct c2), sum(distinct c3) from tp1 group by c1;
explain outline select (select /*+ parallel(16) pq_gby(basic)*/ sum(distinct c2) + sum(distinct c3) from tp1 where c4 = t1.c2 group by c1) from t1;
explain outline select (select /*+ parallel(16) pq_gby(none)*/ sum(distinct c2) + sum(distinct c3) from tp1 where c4 = t1.c2 group by c1) from t1;
explain outline select (select /*+ parallel(16) pq_gby(hash)*/ sum(distinct c2) + sum(distinct c3) from tp1 where c4 = t1.c2 group by c1) from t1;

explain outline select /*+parallel(tp1 2) pq_gby(hash 4)*/ sum(distinct c2) + sum(distinct c3) from tp1 group by c1;

## scalar group by
explain outline select /*+use_hash_aggregation gby_pushdown*/ sum(c2) from t1;

explain outline select /*+use_hash_aggregation gby_pushdown parallel(2)*/ sum(c2) from t1;
explain outline select /*+use_hash_aggregation no_gby_pushdown parallel(2)*/ sum(c2) from t1;

explain outline select /*+use_hash_aggregation gby_pushdown*/ sum(distinct c2), count(distinct c3) from t1;

explain outline select /*+use_hash_aggregation gby_pushdown parallel(2)*/ sum(distinct c2), count(distinct c3) from t1;
explain outline select /*+no_use_hash_aggregation gby_pushdown parallel(2)*/ sum(distinct c2), sum(distinct c3) from t1;
explain outline select /*+use_hash_aggregation no_gby_pushdown parallel(2)*/ sum(distinct c2), sum(distinct c3) from t1;
explain outline select /*+no_use_hash_aggregation no_gby_pushdown parallel(2)*/ sum(distinct c2), sum(distinct c3) from t1;

explain outline select /*+ parallel(2) pq_gby(basic)*/ sum(distinct c2), count(distinct c3) from t1;
explain outline select /*+ parallel(16) pq_gby(basic)*/ sum(distinct c1) from tp1;
explain outline select (select /*+ parallel(16) pq_gby(basic)*/ sum(distinct c1) + count(distinct c1) from tp1 where c4 = t1.c2) from t1;
explain outline select (select /*+ parallel(16) pq_gby(none)*/ sum(distinct c1) + count(distinct c1) from tp1 where c4 = t1.c2) from t1;
explain outline select (select /*+ parallel(16) pq_gby(hash)*/ sum(distinct c1) + count(distinct c1) from tp1 where c4 = t1.c2) from t1;

explain outline select /*+parallel(2) pq_gby(hash 4)*/ sum(distinct c1) + sum(distinct c2) from tp1;

drop table t1;