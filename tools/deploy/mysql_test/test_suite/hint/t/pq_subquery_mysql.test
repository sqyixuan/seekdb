--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: zhanyue.zzy
#owner group: SQL1
#description: test for pq_subquery hint
#tags: optimizer, outline

--result_format 4

--disable_warnings
drop table if exists t1, t2;
--enable_warnings

create table t1(c1 int primary key, c2 int, c3 int, c4 int)
partition by hash(c1) partitions 10;
create table t2(c1 int primary key, c2 int, c3 int, c4 int);

explain outline
select (select c1 from t1 where c1 = t_a.c3) a
from t1 t_a order by (select a from t1 where c1 = t_a.c3);

## 1. only one subquery, can use hint without subquery qb name
explain outline
select /*+pq_subquery(local local) */ (select c1 from t1 where c1 = t_a.c3) a
from t1 t_a;
explain outline
select /*+pq_subquery(local local) */ (select /*+no_use_das(t1)*/ c1 from t1 where c1 = t_a.c3) a
from t1 t_a;
explain outline
select /*+pq_subquery(none all) */ (select c1 from t1 where c1 = t_a.c1) a
from t1 t_a;
explain outline
select /*+pq_subquery(partition none) */ (select c1 from t1 where c1 = t_a.c1) a
from t1 t_a;
explain outline
select /*+pq_subquery(none none) */ (select c1 from t1 where c1 = t_a.c1) a
from t1 t_a;
explain outline
select /*+pq_subquery(basic)*/ (select c1 from t1 where c1 = t_a.c3) a
from t2 t_a;
explain outline
select /*+pq_subquery()*/ (select c1 from t1 where c1 = t_a.c3) a
from t2 t_a;
explain outline
select /*+pq_subquery(@"SEL$1" ("SEL$2"))*/ (select c1 from t1 where c1 = t_a.c3) a
from t2 t_a;

## invalid hint,should be ignored
explain outline
select /*+pq_subquery(local)*/ (select c1 from t1 where c1 = t_a.c3) a
from t1 t_a;
explain outline
select /*+pq_subquery(local local local)*/ (select c1 from t1 where c1 = t_a.c3) a
from t1 t_a;

## 2. multi subqueries, must use hint with subquery qb name
## invlaid hint
explain outline
select /*+pq_subquery(local local) */ (select c1 from t1 where c1 = t_a.c3) a
from t1 t_a order by (select a from t1 where c1 = t_a.c3);
explain outline
select /*+pq_subquery((sel$2) local local) */ (select c1 from t1 where c1 = t_a.c3) a
from t1 t_a order by (select a from t1 where c1 = t_a.c3);
explain outline
select /*+pq_subquery((sel$3) local local) pq_subquery((sel$2) partition none)*/ (select c1 from t1 where c1 = t_a.c3) a
from t1 t_a order by (select a from t1 where c1 = t_a.c3);
explain outline
select /*+pq_subquery((sel$3) local local) pq_subquery((sel$2) none all)*/ (select c1 from t1 where c1 = t_a.c3) a
from t1 t_a order by (select a from t1 where c1 = t_a.c3);
explain outline
select /*+pq_subquery((sel$3) local local) pq_subquery((sel$2) none all)*/ (select c1 from t1 where c1 = t_a.c3) a
from t1 t_a order by (select /*+no_use_das(t1)*/ a from t1 where c1 = t_a.c3);

## 3. subquery in joined table. to make hint valid need use other hint to adjust the plan
explain outline
select /*+no_rewrite leading(t_a t_b) no_use_das(t_b)*/ *
from t1 t_a
inner join t1 t_b on t_a.c1 = t_b.c2 and t_a.c2 + (select c4 from t1 t1_sub where c1 = t_b.c1);
explain outline
select /*+no_rewrite leading(t_a t_b) no_use_das(t_b) pq_subquery(none none)*/ *
from t1 t_a
inner join t1 t_b on t_a.c1 = t_b.c2 and t_a.c2 + (select c4 from t1 t1_sub where c1 = t_b.c1);
explain outline
select /*+no_rewrite leading(t_a t_b) no_use_das(t_b) pq_subquery(none all)*/ *
from t1 t_a
inner join t1 t_b on t_a.c1 = t_b.c2 and t_a.c2 + (select c4 from t1 t1_sub where c1 = t_b.c1);
explain outline
select /*+no_rewrite leading(t_a t_b) no_use_das(t_b) pq_subquery(partition none)*/ *
from t1 t_a
inner join t1 t_b on t_a.c1 = t_b.c2 and t_a.c2 + (select c4 from t1 t1_sub where c1 = t_b.c1);
explain outline
select /*+no_rewrite leading(t_a t_b) no_use_das(t_b) pq_subquery(local local)*/ *
from t1 t_a
inner join t1 t_b on t_a.c1 = t_b.c2 and t_a.c2 + (select c4 from t1 t1_sub where c1 = t_b.c1);
explain outline
select /*+no_rewrite leading(t_a t_b) no_use_das(t_b) pq_subquery(local local)*/ *
from t1 t_a
inner join t1 t_b on t_a.c1 = t_b.c2 and t_a.c2 + (select /*+no_use_das(t1_sub)*/ c4 from t1 t1_sub where c1 = t_b.c1);

drop table t1;
drop table t2;
