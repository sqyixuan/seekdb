--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: zhanyue.zzy
#owner group: SQL1
#description: test for optimize hint about window function: pq_distribute_window
#tags: optimizer, outline

--result_format 4

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1(c1 int, c2 int, c3 int, c4 int);

explain outline select /*+parallel(2) */
    sum(c3) over(partition by c1 order by c2) w1,
    sum(c4) over(partition by c1 order by c2) w2,
    sum(c3 + c4) over(partition by c1 order by c2) w3 from t1;

## use hint with none/hash/range/list only, can not control partition_sort and pushdown for hash
explain outline select /*+parallel(2) pq_distribute_window(none) */
    sum(c3) over(partition by c1 order by c2) w1,
    sum(c4) over(partition by c1 order by c2) w2,
    sum(c3 + c4) over(partition by c1 order by c2) w3 from t1;

explain outline select /*+parallel(2) pq_distribute_window(hash) */
    sum(c3) over(partition by c1 order by c2) w1,
    sum(c4) over(partition by c1 order by c2) w2,
    sum(c3 + c4) over(partition by c1 order by c2) w3 from t1;

explain outline select /*+parallel(2) pq_distribute_window(range) */
    sum(c3) over(partition by c1 order by c2) w1,
    sum(c4) over(partition by c1 order by c2) w2,
    sum(c3 + c4) over(partition by c1 order by c2) w3 from t1;

explain outline select /*+parallel(2) pq_distribute_window(list) */
    sum(c3) over(partition by c1 order by c2) w1,
    sum(c4) over(partition by c1 order by c2) w2,
    sum(c3 + c4) over(partition by c1 order by c2) w3 from t1;

## explicit pq_distribute_window hint
explain outline select /*+parallel(2) pq_distribute_window((0) hash pushdown) */
    sum(c3) over(partition by c1) w1 from t1;

explain outline select /*+parallel(2) pq_distribute_window((0) hash partition_sort) */
    sum(c3) over(partition by c1) w1 from t1;

explain outline select /*+parallel(2) pq_distribute_window((0) hash partition_sort pushdown) */
    sum(c3) over(partition by c1) w1 from t1;

explain outline select /*+parallel(2) pq_distribute_window((0,1) list (2) hash) */
    sum(c3) over(partition by c1 order by c2) w1, 
    sum(c4) over(partition by c1 order by c2) w2,
    sum(c3 + c4) over(partition by c2) w3 from t1;

explain outline select /*+parallel(2) pq_distribute_window((0,1) list (2) hash pushdown) */
    sum(c3) over(partition by c1 order by c2) w1,
    sum(c4) over(partition by c1 order by c2) w2,
    sum(c3 + c4) over(partition by c2) w3 from t1;

explain outline select /*+parallel(2) pq_distribute_window((0,1) list (2) hash partition_sort) */
    sum(c3) over(partition by c1 order by c2) w1,
    sum(c4) over(partition by c1 order by c2) w2,
    sum(c3 + c4) over(partition by c2) w3 from t1;

explain outline select /*+parallel(2) pq_distribute_window((0,1) list (2) hash partition_sort pushdown) */
    sum(c3) over(partition by c1 order by c2) w1,
    sum(c4) over(partition by c1 order by c2) w2,
    sum(c3 + c4) over(partition by c2) w3 from t1;

explain outline select /*+parallel(2) pq_distribute_window((0) hash (1) range (2) list) */
    sum(c3) over(partition by c1 order by c2) w1,
    sum(c4) over(partition by c2 order by c3) w2,
    sum(c3 + c4) over(partition by c3 order by c2) w3 from t1;

explain outline select /*+parallel(2) pq_distribute_window((2) hash (0) range (1) list) */
    sum(c3) over(partition by c1 order by c2) w1,
    sum(c4) over(partition by c2 order by c3) w2,
    sum(c3 + c4) over(partition by c3 order by c2) w3 from t1;

drop table t1;