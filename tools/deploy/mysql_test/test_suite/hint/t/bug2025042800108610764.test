--disable_query_log
--enable_query_log
#owner: wuyuming.wym
#owner group: sql1
#tags: outline, optimizer

--disable_warnings
--explain_protocol 0
drop table if exists t1, t2;
--enable_warnings

create table t1(c1 int, c2 int);
create table t2(c1 int, c2 int, index i1(c1));

explain outline select /*+leading(t1 t2) use_nl(t2)*/ * from t1,(select c1,count(*) from t2 group by c1) t2 where t1.c1 = t2.c1;
explain outline select /*+
    BEGIN_OUTLINE_DATA
    LEADING(@"SEL$1" ("test"."t1"@"SEL$1" "t2"@"SEL$1"))
    USE_NL(@"SEL$1" "t2"@"SEL$1")
    FULL(@"SEL$1" "test"."t1"@"SEL$1")
    INDEX(@"SEL$2" "test"."t2"@"SEL$2" "i1")
    OPTIMIZER_FEATURES_ENABLE('')
    END_OUTLINE_DATA
*/ * from t1,(select c1,count(*) from t2 group by c1) t2 where t1.c1 = t2.c1;
explain outline select /*+
    BEGIN_OUTLINE_DATA
    LEADING(@"SEL$1" ("test"."t1"@"SEL$1" "t2"@"SEL$1"))
    USE_NL(@"SEL$1" "t2"@"SEL$1")
    NO_USE_NL_MATERIALIZATION(@"SEL$1" "t2"@"SEL$1")
    FULL(@"SEL$1" "test"."t1"@"SEL$1")
    INDEX(@"SEL$2" "test"."t2"@"SEL$2" "i1")
    OPTIMIZER_FEATURES_ENABLE('')
    END_OUTLINE_DATA
*/ * from t1,(select c1,count(*) from t2 group by c1) t2 where t1.c1 = t2.c1;

set _push_join_predicate = false;

explain outline select /*+leading(t1 t2) use_nl(t2)*/ * from t1,(select c1,count(*) from t2 group by c1) t2 where t1.c1 = t2.c1;
explain outline select /*+
    BEGIN_OUTLINE_DATA
    LEADING(@"SEL$1" ("test"."t1"@"SEL$1" "t2"@"SEL$1"))
    USE_NL(@"SEL$1" "t2"@"SEL$1")
    FULL(@"SEL$1" "test"."t1"@"SEL$1")
    INDEX(@"SEL$2" "test"."t2"@"SEL$2" "i1")
    OPTIMIZER_FEATURES_ENABLE('')
    END_OUTLINE_DATA
*/ * from t1,(select c1,count(*) from t2 group by c1) t2 where t1.c1 = t2.c1;
explain outline select /*+
    BEGIN_OUTLINE_DATA
    LEADING(@"SEL$1" ("test"."t1"@"SEL$1" "t2"@"SEL$1"))
    USE_NL(@"SEL$1" "t2"@"SEL$1")
    NO_USE_NL_MATERIALIZATION(@"SEL$1" "t2"@"SEL$1")
    FULL(@"SEL$1" "test"."t1"@"SEL$1")
    INDEX(@"SEL$2" "test"."t2"@"SEL$2" "i1")
    OPTIMIZER_FEATURES_ENABLE('')
    END_OUTLINE_DATA
*/ * from t1,(select c1,count(*) from t2 group by c1) t2 where t1.c1 = t2.c1;



## test nlj plan hash

alter system flush plan cache global;
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
alter system set_tp tp_name = "EN_EXPLAIN_GENERATE_PLAN_WITH_OUTLINE", error_code = 4016, frequency = 0;
connection default;

--explain_protocol 1
select /*+ 3hash_value
    BEGIN_OUTLINE_DATA
    LEADING(@"SEL$1" ("test"."t1"@"SEL$1" "t2"@"SEL$1"))
    USE_NL(@"SEL$1" "t2"@"SEL$1")
    FULL(@"SEL$1" "test"."t1"@"SEL$1")
    INDEX(@"SEL$2" "test"."t2"@"SEL$2" "i1")
    OPTIMIZER_FEATURES_ENABLE('')
    END_OUTLINE_DATA
*/ * from t1,(select c1,count(*) from t2 group by c1) t2 where t1.c1 = t2.c1;
select /*+ 4hash_value
    BEGIN_OUTLINE_DATA
    LEADING(@"SEL$1" ("test"."t1"@"SEL$1" "t2"@"SEL$1"))
    USE_NL(@"SEL$1" "t2"@"SEL$1")
    NO_USE_NL_MATERIALIZATION(@"SEL$1" "t2"@"SEL$1")
    FULL(@"SEL$1" "test"."t1"@"SEL$1")
    INDEX(@"SEL$2" "test"."t2"@"SEL$2" "i1")
    OPTIMIZER_FEATURES_ENABLE('')
    END_OUTLINE_DATA
*/ * from t1,(select c1,count(*) from t2 group by c1) t2 where t1.c1 = t2.c1;

--explain_protocol 0
select plan_hash, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where query_sql like '%hash_value%' and query_sql not like '%OB_PLAN_CACHE_PLAN_STAT%' order by query_sql, plan_hash;

--disable_warnings
drop table if exists t1, t2;
--enable_warnings

connection obsys;
alter system set_tp tp_name = "EN_EXPLAIN_GENERATE_PLAN_WITH_OUTLINE", error_code = 4016, frequency = 1;
connection default;