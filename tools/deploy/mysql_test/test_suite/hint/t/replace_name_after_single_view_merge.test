--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: zhanyue.zzy
#owner group: SQL1
#description: test hint contain table happend single table view merge
#tags: optimizer, outline

--result_format 4
--explain_protocol 1

--disable_warnings
drop table if exists t1, t2;
--enable_warnings

create table t1(c1 int, c2 int, c3 int, c4 int, unique index idx(c1));
create table t2(c1 int, c2 int, c3 int, c4 int);

## 1. index hint
select /*+index(v idx)*/ * from (select * from t1) v;
select /*+index(v idx)*/ * from (select c2, min(c1) from t1 group by c2) v;
select /*+index(view1 idx)*/ * from t2 where c1 in (select c1 from t1);

## 2. parallel hint for table
select /*+parallel(v 10)*/ * from (select * from t1) v;
select /*+parallel(v 10)*/ * from (select c2, min(c1) from t1 group by c2) v;
select /*+parallel(view1 10)*/ * from t2 where c1 in (select c1 from t1);

## 3. leading and use join
select /*+leading(t2 v) use_merge(v)*/ * from (select * from t1) v, t2 where v.c2 = t2.c2;
select /*+leading(v) use_merge(t2)*/ * from (select * from t1) v, t2 where v.c2 = t2.c2;

drop table t1,t2;