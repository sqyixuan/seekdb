--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: sean.yyj
#owner group: sql1
#description: test for transform hint: count_to_exists/no_count_to_exists
#tags: outline, optimizer

--disable_warnings
--explain_protocol 0
drop table if exists t1, t2;
--enable_warnings

create table t1(c1 int, c2 int);
create table t2(c1 int primary key, c2 int);

explain outline select * from t1 where (select count(*) from t2 where t1.c1 = t2.c1) = 0;
explain outline select /*+no_rewrite*/* from t1 where (select count(*) from t2 where t1.c1 = t2.c1) = 0;
explain outline select /*+count_to_exists*/* from t1 where (select count(*) from t2 where t1.c1 = t2.c1) > 0;
explain outline select /*+count_to_exists(@"SEL$1")*/* from t1 where (select count(*) from t2 where t1.c1 = t2.c1) > 0 and (select count(*) from t2) > 0;
explain outline select /*+count_to_exists(@"SEL$233" "SEL$2")*/* from t1 where (select count(*) from t2 where t1.c1 = t2.c1) > 0 and (select count(*) from t2) > 0;
explain outline select /*+count_to_exists(@"SEL$1" "SEL$2")*/* from t1 where (select count(*) from t2 where t1.c1 = t2.c1) > 0 and (select count(*) from t2) > 0;
explain outline select /*+count_to_exists(@"SEL$1" "SEL$233")*/* from t1 where (select count(*) from t2 where t1.c1 = t2.c1) > 0 and (select count(*) from t2) > 0;
explain outline select /*+count_to_exists(@"SEL$1" "SEL$2" "SEL$3")*/* from t1 where (select count(*) from t2 where t1.c1 = t2.c1) > 0 and (select count(*) from t2) > 0;
explain outline select /*+count_to_exists("SEL$2" "SEL$3")*/* from t1 where (select count(*) from t2 where t1.c1 = t2.c1) > 0 and (select count(*) from t2) > 0;
explain outline select /*+count_to_exists("SEL$3")*/* from t1 where (select count(*) from t2 where t1.c1 = t2.c1) > 0 and (select count(*) from t2) > 0;

explain outline select /*+no_count_to_exists*/* from t1 where (select count(*) from t2 where t1.c1 = t2.c1) > 0 and (select count(*) from t2) > 0;
explain outline select /*+no_count_to_exists(@"SEL$1")*/* from t1 where (select count(*) from t2 where t1.c1 = t2.c1) > 0 and (select count(*) from t2) > 0;
# 在内层
explain outline select * from (select /*+count_to_exists*/ c1 from t1 where (select count(*) from t2) > 0) V left join t2 on V.c1 = t2.c1;
explain outline select * from (select /*+count_to_exists(@"SEL$2")*/ c1 from t1 where (select count(*) from t2) > 0) V left join t2 on V.c1 = t2.c1;
explain outline select * from (select /*+no_count_to_exists*/ c1 from t1 where (select count(*) from t2) > 0) V left join t2 on V.c1 = t2.c1;
explain outline select * from (select /*+no_count_to_exists(@"SEL$1")*/ c1 from t1 where (select count(*) from t2) > 0) V left join t2 on V.c1 = t2.c1;

--disable_warnings
drop table if exists t1, t2;
--enable_warnings
