#owner: sean.yyj
#owner group: sql3
# tags: optimizer, outline
##
## Test Name: groupby_pullup.test
##
--source mysql_test/include/sql_import_opt_wisconsin.inc
--result_format 4
--explain_protocol 2

USE OPT_WISCONSIN;

select count(*) from g_4k;
select count(*) from h_4k;
select count(*) from t1_1;
select count(*) from t1_100;
select count(*) from t2_1;
select count(*) from t2_100;
select count(*) from t_4k;
select count(*) from t_5k;
select count(*) from t_10k;
select count(*) from t_part;
select count(*) from z_4k;

set autocommit = 0;

## pull up tests
explain outline select  t1.unique1, v.* from t1_100 t1, (select  /*+merge*/ t2.hundred, max(t2.thousand)  from t_4k t2 group by t2.hundred) v where t1.unique1 < 4 and t1.hundred = v.hundred order by t1.unique1;
explain outline select  t1.unique1, v.* from t1_100 t1, (select /*+no_merge*/ t2.hundred, max(t2.thousand)  from t_4k t2 group by t2.hundred) v where t1.unique1 < 4 and t1.hundred = v.hundred order by t1.unique1;
explain outline select /*+no_rewrite*/ t1.unique1, v.* from t1_100 t1, (select t2.hundred, max(t2.thousand)  from t_4k t2 group by t2.hundred) v where t1.unique1 < 4 and t1.hundred = v.hundred order by t1.unique1;
explain outline select  t1.unique1, v.* from t1_100 t1, (select /*+merge*/ t2.hundred, max(t2.thousand)  from t_4k t2 group by t2.hundred) v where t1.unique1 < 4 and t1.hundred = v.hundred order by t1.unique1;
explain outline select /*+merge(@"SEL$1")*/ t1.unique1, v.* from t1_100 t1, (select t2.hundred, max(t2.thousand)  from t_4k t2 group by t2.hundred) v where t1.unique1 < 4 and t1.hundred = v.hundred order by t1.unique1;
explain outline select /*+merge(@"SEL$2")*/ t1.unique1, v.* from t1_100 t1, (select t2.hundred, max(t2.thousand)  from t_4k t2 group by t2.hundred) v where t1.unique1 < 4 and t1.hundred = v.hundred order by t1.unique1;
explain outline select /*+no_merge(@"SEL$1")*/ t1.unique1, v.* from t1_100 t1, (select t2.hundred, max(t2.thousand)  from t_4k t2 group by t2.hundred) v where t1.unique1 < 4 and t1.hundred = v.hundred order by t1.unique1;
explain outline select /*+no_merge(@"SEL$2")*/ t1.unique1, v.* from t1_100 t1, (select t2.hundred, max(t2.thousand)  from t_4k t2 group by t2.hundred) v where t1.unique1 < 4 and t1.hundred = v.hundred order by t1.unique1;


set autocommit=1;
