--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: zhanyue.zzy
#owner group: SQL1
#tags: optimizer, outline

--result_format 4

--disable_warnings
drop table if exists t16;
--enable_warnings

create table t16 (
  c1 INTEGER(127) auto_increment, 
  c2 DATE, 
  c3 VARBINARY(71), 
  c4 INT(127), 
  c5 INTEGER(127), 
  c6 BIGINT(127), 
  c7 DECIMAL(64, 8), 
  c8 VARCHAR(86), 
  c9 BINARY(145), 
  c10 DECIMAL(64, 2), 
  c11 VARBINARY(72), 
  c12 TIME, 
  c13 DATE, 
  c14 BIGINT(127), 
  c15 DECIMAL(64, 8), 
  c16 VARBINARY(51), 
  c17 DATETIME, 
  c18 NUMERIC(64, 20), 
  c19 VARBINARY(59), 
  c20 VARBINARY(71), 
  c21 BINARY(135), 
  c22 BINARY(138), 
  c23 NUMERIC(64, 27), 
  c24 BINARY(77), 
  c25 TIME, 
  c26 DATE, 
  c27 TIME, 
  c28 INT(127), 
  c29 DATE, 
  c30 DECIMAL(64, 8), 
  c31 TIMESTAMP(2) NOT NULL default 0, 
  c32 YEAR(4), 
  c33 BIGINT(127), 
  c34 NUMERIC(64, 16), 
  c35 CHAR(152), 
  c36 CHAR(152), 
  c37 NUMERIC(64, 24), 
  c38 VARCHAR(86), 
  c39 VARCHAR(86), 
  c40 VARCHAR(86), 
  c41 VARBINARY(69), 
  c42 DECIMAL(64, 19), 
  c43 DATETIME, 
  c44 DATETIME, 
  c45 VARCHAR(86), 
  c46 DECIMAL(64, 22), 
  c47 TIMESTAMP NOT NULL default 0, 
  c48 VARCHAR(86), 
  primary key(
    c24, c18, c14, c16, c37, c15, c7, c38, 
    c19, c30, c21, c20, c45
  )
)PARTITION BY KEY(
  c24, c18, c14, c16, c37, c15, c7, c38, 
  c19, c30, c21, c20
) PARTITIONS 9;

explain outline
select count(*) from (
select 
/*+
      PQ_SET(@"SET$1"  NONE NONE)
      LEADING( ("VIEW2"@"SEL$2" "test"."t16_3"@"SEL$2"))
      USE_HASH( "test"."t16_3"@"SEL$2")
      PARALLEL( "test"."t16_3"@"SEL$2" 1)
      PQ_DISTRIBUTE( "test"."t16_3"@"SEL$2" ALL NONE)
      PARALLEL(@"SEL$4" "t16_3"@"SEL$4" 10)
      SEMI_TO_INNER
      OPT_PARAM('INLIST_REWRITE_THRESHOLD' 1)
  */
 1 FROM t16 AS t16_3 
WHERE t16_3.c38 IN ('eQTOR')
      and 'MEfVIBLINGijrHOgAnLjCyRdWFXANZwRhwquQnVa' IN (t16_3.c45, t16_3.c39)
      AND t16_3.c48 >= t16_3.c40
union all
select 1 FROM t16 AS t16_3 
WHERE t16_3.c18 = 26
      and 'MEfVIBLINGijrHOgAnLjCyRdWFXANZwRhwquQnVa' IN (t16_3.c45, t16_3.c39)
      AND t16_3.c48 >= t16_3.c40)
;

drop table t16;
