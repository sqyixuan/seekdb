#owner: dingjincheng.djc
#owner group: SQL1
#description: test ob_ddl_schema_version hint
#tags: optimizer

--result_format 4

--disable_warnings
drop table if exists t1;
drop table if exists t2;
--enable_warnings

create table t1(c1 int, c2 int);
create table t2(c1 int, c2 int);
--disable_query_log
insert into t1 values(1, 1);

--let $schema_version = query_get_value("select SCHEMA_VERSION from oceanbase.__all_table where TABLE_NAME = 'T1'", SCHEMA_VERSION, 1)
--let $schema_version_old = `select $schema_version - 1`
--let $sql1 = select /*+ ob_ddl_schema_version(t1, $schema_version) */ * from t1
eval $sql1;
--let $sql2 = select /*+ ob_ddl_schema_version(t1, $schema_version_old) */ * from t1
--error 5403
eval $sql2;
--let $sql3 = insert /*+ ob_ddl_schema_version(t1, $schema_version_old) */ into t2 select c1,c2 from t1
--error 5403
eval $sql3;

--enable_query_log

drop table t1;
drop table t2;
