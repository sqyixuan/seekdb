--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: zhenglailei.zll
#owner group: sql1
#description: test for transform hint: eliminate_join/no_eliminate_join
#tags: outline, optimizer

--disable_warnings
drop table if exists tff, tf, tp, t1, t2, t3;
--enable_warnings
create table t1(c1 int primary key, c2 int);
create table t2(c1 int primary key, c2 int);
create table t3(c1 int, c2 int);
create unique index idx on t3(c1);
create table tf(c1 int primary key, c2 int, foreign key (c1) references t2 (c1));
create table tff(c1 int, c2 int, foreign key (c1) references tf (c1));
create table tp(c1 int, c2 int) partition by range(c1) (partition p0 values less than (1), partition p1 values less than (10));
--explain_protocol 0

## self join, from table
explain outline select * from t1 tt1, t1 tt2 where tt1.c1 = tt2.c1;
explain outline select * from t1 tt1, t1 tt2, t1 tt3, t1 tt4 where tt1.c1 = tt2.c1 and tt1.c1 = tt2.c1 and tt1.c1 = tt3.c1;
explain outline select /*+eliminate_join*/* from t1 tt1, t1 tt2, t1 tt3, t1 tt4 where tt1.c1 = tt2.c1 and tt1.c1 = tt2.c1 and tt1.c1 = tt3.c1;
explain outline select /*+eliminate_join(tt2)*/* from t1 tt1, t1 tt2, t1 tt3, t1 tt4 where tt1.c1 = tt2.c1 and tt1.c1 = tt2.c1 and tt1.c1 = tt3.c1;
explain outline select /*+eliminate_join(tt2 tt3)*/* from t1 tt1, t1 tt2, t1 tt3, t1 tt4 where tt1.c1 = tt2.c1 and tt1.c1 = tt2.c1 and tt1.c1 = tt3.c1;
explain outline select /*+eliminate_join(tt2 tt3 tt4)*/* from t1 tt1, t1 tt2, t1 tt3, t1 tt4 where tt1.c1 = tt2.c1 and tt1.c1 = tt2.c1 and tt1.c1 = tt3.c1;
explain outline select /*+no_eliminate_join*/* from t1 tt1, t1 tt2, t1 tt3, t1 tt4 where tt1.c1 = tt2.c1 and tt1.c1 = tt2.c1 and tt1.c1 = tt3.c1;
explain outline select * from t1 tt1, t1 tt2, t2 tt3, t2 tt4 where tt1.c1 = tt2.c1 and tt3.c1 = tt4.c1;
explain outline select /*+eliminate_join(tt2)*/* from t1 tt1, t1 tt2, t2 tt3, t2 tt4 where tt1.c1 = tt2.c1 and tt3.c1 = tt4.c1;
explain outline select /*+eliminate_join(tt2 tt4)*/* from t1 tt1, t1 tt2, t2 tt3, t2 tt4 where tt1.c1 = tt2.c1 and tt3.c1 = tt4.c1;
explain outline select /*+no_eliminate_join*/* from t1 tt1, t1 tt2, t2 tt3, t2 tt4 where tt1.c1 = tt2.c1 and tt3.c1 = tt4.c1;
explain outline select * from t1, (select /*+eliminate_join(tt)*/* from t1 tt)  VIEW1 where t1.c1 > 0 and t1.c2 = VIEW1.c2 and t1.c1 = VIEW1.c1;
explain outline select * from t1, (select /*+no_eliminate_join*/* from t1 tt)  VIEW1 where t1.c1 > 0 and t1.c2 = VIEW1.c2 and t1.c1 = VIEW1.c1;

## self join, joined table
explain outline select tt1.* from t1 tt1 left join t1 tt2 on tt1.c1 = tt2.c1;
explain outline select /*+eliminate_join*/ tt1.* from t1 tt1 left join t1 tt2 on tt1.c1 = tt2.c1 left join t1 tt3 on tt1.c1 = tt3.c1;
explain outline select /*+eliminate_join(tt2)*/ tt1.* from t1 tt1 left join t1 tt2 on tt1.c1 = tt2.c1 left join t1 tt3 on tt1.c1 = tt3.c1;
explain outline select /*+eliminate_join(tt2 tt3)*/ tt1.* from t1 tt1 left join t1 tt2 on tt1.c1 = tt2.c1 left join t1 tt3 on tt1.c1 = tt3.c1;

## outer join
## always false outer join
explain outline select * from t1 left join t2 on 1 = 0 left join t3 on 1 = 0;
explain outline select /*+eliminate_join*/ * from t1 left join t2 on 1 = 0 left join t3 on 1 = 0;
explain outline select /*+eliminate_join(t2)*/ * from t1 left join t2 on 1 = 0 left join t3 on 1 = 0;
explain outline select /*+eliminate_join(t2 t3)*/ * from t1 left join t2 on 1 = 0 left join t3 on 1 = 0;
explain outline select /*+no_eliminate_join*/ * from t1 left join t2 on 1 = 0 left join t3 on 1 = 0;

## unique key outer join
explain outline select t1.* from t1 left join t2 on t1.c1 = t2.c1;
explain outline select /*+eliminate_join(t2)*/distinct t1.* from t1 left join t2 on t1.c2 = t2.c2;
explain outline select /*+eliminate_join*/ t1.* from t1 left join t2 on t1.c1 = t2.c1;
explain outline select /*+eliminate_join(t2)*/ t1.* from t1 left join t2 on t1.c1 = t2.c1;
explain outline select /*+eliminate_join*/ t1.* from t1 left join (t2 left join t3 on t2.c1 = t3.c1) on t1.c1 = t2.c1 left join t3 tt on t1.c1 = tt.c1;
explain outline select /*+eliminate_join((t2 t3))*/ t1.* from t1 left join (t2 left join t3 on t2.c1 = t3.c1) on t1.c1 = t2.c1 left join t3 tt on t1.c1 = tt.c1;
explain outline select /*+eliminate_join((t2 t3) tt)*/ t1.* from t1 left join (t2 left join t3 on t2.c1 = t3.c1) on t1.c1 = t2.c1 left join t3 tt on t1.c1 = tt.c1;
explain outline select /*+eliminate_join(tt)*/ t1.* from t1 left join (t2 left join t3 on t2.c1 = t3.c1) on t1.c1 = t2.c1 left join t3 tt on t1.c1 = tt.c1;
explain outline select /*+no_eliminate_join*/ t1.* from t1 left join (t2 left join t3 on t2.c1 = t3.c1) on t1.c1 = t2.c1 left join t3 tt on t1.c1 = tt.c1;

## foreign key join
explain outline select tff.* from tff left join tf on tff.c1 = tf.c1 left join t2 on tf.c1 = t2.c1;
explain outline select /*+eliminate_join*/ tff.* from tff left join tf on tff.c1 = tf.c1 left join t2 on tf.c1 = t2.c1;
explain outline select /*+eliminate_join(tf)*/ tff.* from tff left join tf on tff.c1 = tf.c1 left join t2 on tf.c1 = t2.c1;
explain outline select /*+eliminate_join(t2)*/ tff.* from tff left join tf on tff.c1 = tf.c1 left join t2 on tf.c1 = t2.c1;
explain outline select /*+eliminate_join(tf t2)*/ tff.* from tff left join tf on tff.c1 = tf.c1 left join t2 on tf.c1 = t2.c1;
explain outline select /*+no_eliminate_join*/ tff.* from tff left join tf on tff.c1 = tf.c1 left join t2 on tf.c1 = t2.c1;

## self semi join
explain outline select * from t1 where c2 in (select c2 from t1) and c1 > 0;
explain outline select /*+eliminate_join*/ * from t1 where c2 in (select c2 from t1) and c1 > 0;
explain outline select /*+no_eliminate_join*/* from t1 where c2 in (select c2 from t1) and c1 > 0;
explain outline select * from t1 where c1 in (select c1 from t1 tt where t1.c2 = tt.c2) and c1 > 0;
explain outline select /*+no_eliminate_join*/* from t1 where c1 in (select /*+no_eliminate_join*/c1 from t1 tt where t1.c2 = tt.c2) and c1 > 0;
explain outline select /*+no_eliminate_join*/* from t1 where c1 in (select /*+eliminate_join*/c1 from t1 tt where t1.c2 = tt.c2) and c1 > 0;
explain outline select /*+eliminate_join*/* from t1 where c1 in (select /*+no_eliminate_join*/c1 from t1 tt where t1.c2 = tt.c2) and c1 > 0;
explain outline select /*+eliminate_join*/* from t1 where c1 in (select /*+eliminate_join*/c1 from t1 tt where t1.c2 = tt.c2) and c1 > 0;

## foreign key semi join
explain outline select /*+eliminate_join*/* from tf where exists (select 1 from t2 where t2.c1 = tf.c1) and c1 in (select c1 from tf tt where tt.c2 = tf.c2);
explain outline select /*+eliminate_join(t2)*/* from tf where exists (select 1 from t2 where t2.c1 = tf.c1) and c1 in (select c1 from tf tt where tt.c2 = tf.c2);
explain outline select /*+eliminate_join(tt)*/* from tf where exists (select 1 from t2 where t2.c1 = tf.c1) and c1 in (select c1 from tf tt where tt.c2 = tf.c2);
explain outline select /*+eliminate_join(t2 tt)*/* from tf where exists (select 1 from t2 where t2.c1 = tf.c1) and c1 in (select c1 from tf tt where tt.c2 = tf.c2);

## redundant semi join
explain outline select /*+eliminate_join*/ * from t1 where exists (select 1 from t1 left join t2 on t1.c2 = t2.c2);
explain outline select /*+no_eliminate_join*/ * from t1 where exists (select 1 from t1 left join t2 on t1.c2 = t2.c2);

## anti join
explain outline select * from t1 where not exists (select 1 from t1 tt where tt.c1 = t1.c1);
explain outline select /*+no_eliminate_join*/* from t1 where not exists (select 1 from t1 tt where tt.c1 = t1.c1);

explain outline select /*+eliminate_join*/* from t1 where not exists (select 1 from t1 tt left join t2 on tt.c1 = t2.c1 where tt.c1 = t1.c1);
explain outline select /*+eliminate_join(t2)*/* from t1 where not exists (select 1 from t1 tt left join t2 on tt.c1 = t2.c1 where tt.c1 = t1.c1);
explain outline select /*+eliminate_join(tt)*/* from t1 where not exists (select 1 from t1 tt left join t2 on tt.c1 = t2.c1 where tt.c1 = t1.c1);
explain outline select /*+eliminate_join(tt)*/* from t1 where not exists (select /*+no_eliminate_join*/1 from t1 tt left join t2 on tt.c1 = t2.c1 where tt.c1 = t1.c1);
explain outline select /*+no_eliminate_join*/* from t1 where not exists (select 1 from t1 tt left join t2 on tt.c1 = t2.c1 where tt.c1 = t1.c1);

explain outline select * from tf where not exists (select 1 from t2 where t2.c1 = tf.c1);
explain outline select /*+no_eliminate_join*/* from tf where not exists (select 1 from t2 where t2.c1 = tf.c1);
explain outline select * from tf where not exists (select 1 from t2 where t2.c1 = tf.c1) and not exists(select 1 from tf tt where tf.c1 = tt.c1);
explain outline select /*+eliminate_join(tt)*/* from tf where not exists (select 1 from t2 where t2.c1 = tf.c1) and not exists(select 1 from tf tt where tf.c1 = tt.c1);
explain outline select /*+eliminate_join(t2)*/* from tf where not exists (select 1 from t2 where t2.c1 = tf.c1) and not exists(select 1 from tf tt where tf.c1 = tt.c1);
explain outline select /*+eliminate_join(tt t2)*/* from tf where not exists (select 1 from t2 where t2.c1 = tf.c1) and not exists(select 1 from tf tt where tf.c1 = tt.c1);
explain outline select /*+no_eliminate_join*/* from tf where not exists (select 1 from t2 where t2.c1 = tf.c1) and not exists(select 1 from tf tt where tf.c1 = tt.c1);

## update stmt
explain outline update t1 left join t1 tt on t1.c1 = tt.c1 set t1.c2 = 1 where t1.c2 > 0;
explain outline update /*+eliminate_join(tt)*/t1 left join t1 tt on t1.c1 = tt.c1 set t1.c2 = 1 where t1.c2 > 0;
explain outline update /*+no_eliminate_join*/t1 left join t1 tt on t1.c1 = tt.c1 set t1.c2 = 1 where t1.c2 > 0;
explain outline update tf left join t2 on tf.c1 = t2.c1 set tf.c2 = 1 where tf.c2 > 0;
explain outline update /*+eliminate_join(t2)*/tf left join t2 on tf.c1 = t2.c1 set tf.c2 = 1 where tf.c2 > 0;
explain outline update /*+no_eliminate_join*/tf left join t2 on tf.c1 = t2.c1 set tf.c2 = 1 where tf.c2 > 0;

## delete stmt
explain outline delete t1 from t1, t1 tt where t1.c1 = tt.c1;
explain outline delete /*+eliminate_join(tt)*/t1 from t1, t1 tt where t1.c1 = tt.c1;
explain outline delete /*+no_eliminate_join*/t1 from t1, t1 tt where t1.c1 = tt.c1;
explain outline delete tf from tf, t2 where tf.c1 = t2.c1;
explain outline delete /*+eliminate_join(t2)*/tf from tf, t2 where tf.c1 = t2.c1;
explain outline delete /*+no_eliminate_join*/tf from tf, t2 where tf.c1 = t2.c1;

## same stmt join
explain outline select * from (select c1, c2 from t1 where c1 > 0 group by c1, c2) V1, (select c1, c2 from t1 where c1 > 2 group by c1, c2) V2 where V1.c1 = V2.c1; 
explain outline select /*+eliminate_join*/* from (select c1, max(c2) as c2 from t1 where c1 > 0 group by c1, c2) V1, (select c1, max(c2) as c2 from t1 where c1 > 2 group by c1, c2) V2 where V1.c1 = V2.c1; 
explain outline select /*+eliminate_join(t1)*/* from (select c1, max(c2) as c2 from t1 where c1 > 0 group by c1, c2) V1, (select c1, max(c2) as c2 from t1 where c1 > 2 group by c1, c2) V2 where V1.c1 = V2.c1; 
explain outline select /*+eliminate_join(V2)*/* from (select /*+no_merge*/c1, max(c2) as c2 from t1 where c1 > 0 group by c1, c2) V1, (select /*+no_merge*/c1, max(c2) as c2 from t1 where c1 > 2 group by c1, c2) V2 where V1.c1 = V2.c1; 
explain outline select /*+eliminate_join(t233)*/* from (select /*+no_merge*/c1, max(c2) as c2 from t1 where c1 > 0 group by c1, c2) V1, (select /*+no_merge*/c1, max(c2) as c2 from t1 where c1 > 2 group by c1, c2) V2 where V1.c1 = V2.c1; 
explain outline select /*+no_eliminate_join*/* from (select /*+no_merge*/c1, max(c2) as c2 from t1 where c1 > 0 group by c1, c2) V1, (select /*+no_merge*/c1, max(c2) as c2 from t1 where c1 > 2 group by c1, c2) V2 where V1.c1 = V2.c1; 

--disable_warnings
drop table if exists tff, tf, tp, t1, t2, t3;
--enable_warnings

#eliminate_left_outer_join
--disable_warnings
drop table if exists t1, t2, t3;
--enable_warnings

create table t1(a int, b int, c int);
create table t2(a int primary key, b int, c int);
create table t3(a int, b int not null, c int);

explain outline select * from t1 left join (select t2.a, t3.b from t2 left join t3 on t2.a = t3.a where t2.a is null) tt2  on t1.a = tt2.a ;