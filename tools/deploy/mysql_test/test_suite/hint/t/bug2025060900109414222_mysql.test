--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: daifangyi.dfy
#owner group: sql1
#tags: rewrite, optimizer

--result_format 4

--disable_warnings
drop table if exists t1;
--enable_warnings

SET @a = '123abc';

CREATE TABLE t1 (
    id INT PRIMARY KEY AUTO_INCREMENT,
    a VARCHAR(255) 
);

INSERT INTO t1(a) VALUES 
('123abc'),
('abc123'),
('1xyz'),
('nothing'),
('');

--explain_protocol 1

SELECT /*+rewrite*/ REGEXP_SUBSTR(a, '1.*', 1) FROM t1 WHERE a = @a;

SELECT /*+no_rewrite*/ REGEXP_SUBSTR(a, '1.*', 1) FROM t1 WHERE a = @a;

select concat('(',regexp_substr(@a := 1, '1.*', 1), ')');

drop table t1;