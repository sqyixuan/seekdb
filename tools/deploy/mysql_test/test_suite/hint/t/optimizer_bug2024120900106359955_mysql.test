--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: zhanyue.zzy
#owner group: SQL1
#tags: optimizer

--result_format 4
--explain_protocol 1

--disable_warnings
drop table if exists t0;
drop table if exists t1;
--enable_warnings

CREATE TABLE t0 (
    c0 VARCHAR(123)
);
CREATE TABLE t1 LIKE t0;

SELECT /*+ TOPK (50 50)
          USE_COLUMN_TABLE(t1)
          USE_COLUMN_TABLE(t0)
         */
    true
FROM
    t0
    INNER JOIN t1
GROUP BY
    t1.c0
HAVING
    t1.c0
ORDER BY
    true
LIMIT
    50;

drop table t0;
drop table t1;
