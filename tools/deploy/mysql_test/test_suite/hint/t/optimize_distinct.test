--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: zhanyue.zzy
#owner group: SQL1
#description: test for optimize hint about distinct: use_hash_distinct, distinct_pushdown, pq_distinct
#tags: optimizer, outline

--result_format 4

--disable_warnings
drop table if exists t1;
drop table if exists tp1;
--enable_warnings

create table t1(c1 int, c2 int, c3 int, c4 int);
create table tp1(c1 int, c2 int, c3 int, c4 int) partition by hash(c1) partitions 8;
create index tp1_idx_c4 on tp1(c4) local;

## basic test
explain outline select /*+use_hash_distinct distinct_pushdown */ distinct c1 from t1;
explain outline select /*+use_hash_distinct distinct_pushdown parallel(2)*/ distinct c1 from t1;
explain outline select /*+no_use_hash_distinct distinct_pushdown parallel(2)*/ distinct c1 from t1;
explain outline select /*+use_hash_distinct no_distinct_pushdown parallel(2)*/ distinct c1 from t1;
explain outline select /*+no_use_hash_distinct no_distinct_pushdown parallel(2)*/ distinct c1 from t1;

explain outline select /*+ distinct_pushdown pq_distinct(hash) */ distinct c1 from t1;
explain outline select /*+ parallel(2)*/ distinct c1 from tp1;
explain outline select /*+ parallel(16)*/ distinct c1 from tp1;
explain outline select /*+ parallel(2) pq_distinct(none)*/ distinct c1 from tp1;
explain outline select /*+ parallel(16) pq_distinct(none)*/ distinct c1 from tp1;
explain outline select /*+ parallel(2) pq_distinct(hash)*/ distinct c1 from tp1;
explain outline select /*+ parallel(16) pq_distinct(hash)*/ distinct c1 from tp1;
explain outline select (select /*+ parallel(16) pq_distinct(basic)*/ distinct c1 from tp1 where c4 = t1.c2) from t1;
explain outline select (select /*+ parallel(16) pq_distinct(none)*/ distinct c1 from tp1 where c4 = t1.c2) from t1;
explain outline select (select /*+ parallel(16) pq_distinct(hash)*/ distinct c1 from tp1 where c4 = t1.c2) from t1;

drop table t1;