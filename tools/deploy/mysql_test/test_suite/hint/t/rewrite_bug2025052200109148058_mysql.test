--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: daifangyi.dfy
#owner group: SQL1
#tags: hint resolver rewrite

--result_format 4

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1(c1 int, c2 int, primary key(c1));

explain select  *
from t1 where c1 not in (1,2);

explain select  /*+ opt_param('ENABLE_RANGE_EXTRACTION_FOR_NOT_IN','false') */ *
from t1 where c1 not in (1,2);

explain select  /*+ opt_param('ENABLE_RANGE_EXTRACTION_FOR_NOT_IN','true') */ *
from t1 where c1 not in (1,2);

drop table t1;