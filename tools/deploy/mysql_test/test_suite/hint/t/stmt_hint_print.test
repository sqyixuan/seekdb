--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: zhanyue.zzy
#owner group: sql1
#description: test for stmt hint print for stmt printer
#tags: optimizer, outline

--result_format 4

## set stmt hint bug: workItemId=2025012400107123612
--disable_warnings
drop table if exists tp1;
--enable_warnings

create table tp1(c1 int, c2 int, c3 int) partition by hash(c1) partitions 4;

create or replace view hint_print_test_v1 as select /*+pq_set(@"SET$1" none random) full(tp1) full(@sel$2 tp1)*/ * from tp1 union all select * from tp1;
show create view hint_print_test_v1;

create or replace view hint_print_test_v1 as select * from tp1 union all select /*+pq_set(@"SET$1" none random) full(@sel$1 tp1) full(tp1)*/ * from tp1;
show create view hint_print_test_v1;

drop table tp1;
