# owner: zhanyue.zzy
# tags: sql1
# description: index prefix test

--disable_query_log
set global max_allowed_packet=60000000;
set global ob_sql_work_area_percentage=80;
sleep 1;
connection default;
set @@recyclebin = off;
set ob_query_timeout=1000000000;
set ob_trx_timeout=1000000000;
let $saved_skip_scan_enabled=`select value from oceanbase.__all_virtual_tenant_parameter_stat where name = '_optimizer_skip_scan_enabled'`;
let $saved_storage_cardinality=`select value from oceanbase.__all_sys_variable where name='_enable_storage_cardinality_estimation'`;

set _enable_storage_cardinality_estimation = false;
alter system set _optimizer_skip_scan_enabled = true;

--disable_warnings
drop table if exists t1,t2,pt1;
--enable_warnings
--enable_query_log

create table t1(pk1 int, c1 int, c2 int, primary key(pk1),unique key t1_idx1(c1,c2));
create table t2(pk1 int, pk2 int, c1 int, c2 int, c3 int, primary key(pk1, pk2),unique key t2_idx1(c1,c2), unique key t2_idx2(c1,c2,c3));
create table pt1(pk1 int, pk2 int, c1 int, c2 int, c3 int, primary key(pk1, pk2), unique key pt1_idx1(c1,c2,pk1) global) partition by hash(pk1) partitions 4;

--disable_query_log
alter system flush plan cache;
--let $loop=1
while($loop < 3001)
{
  eval insert into t1 (pk1,c1,c2) values ($loop, $loop % 3, $loop);
  eval insert into t2 (pk1,pk2,c1,c2,c3) values ($loop % 10, $loop, $loop % 3, $loop, $loop);
  eval insert into pt1(pk1,pk2,c1,c2,c3) values ($loop % 10, $loop, $loop % 3, $loop, $loop);
  inc $loop;
}

--enable_query_log
--explain_protocol 2
--result_format 4
--echo ============================================= 测试常规用法 ================================================

select /*+ index(t2 t2_idx1) */ * from t2 where c1= 1 and c2 = 1234;
select /*+ index(t2 t2_idx1 -2) */ * from t2 where c1= 1 and c2 = 1234;
select /*+ index(t2 t2_idx1 -1) */ * from t2 where c1= 1 and c2 = 1234;
select /*+ index(t2 t2_idx1 1) */ * from t2 where c1= 1 and c2 = 1234;
select /*+ index(t2 t2_idx1 2) */ * from t2 where c1= 1 and c2 = 1234;
select /*+ index(t2 t2_idx1 3) */ * from t2 where c1= 1 and c2 = 1234;
select /*+ index(t2 t2_idx1) */ * from t2 where c1 < 4000 and c2 = 2234;
select /*+ index(t2 t2_idx1 0) */ * from t2 where c1 < 4000 and c2 = 2234;
select /*+ index(t2 t2_idx1 1) */ * from t2 where c1 < 4000 and c2 = 2234;
select /*+ index(t2 t2_idx1 3) */ * from t2 where c1 < 4000 and c2 = 2234;

select /*+ index(t2 primary) */ * from t2 where pk1=0 and pk2=10;
select /*+ index(t2 primary -1) */ * from t2 where pk1=0 and pk2=10;
select /*+ index(t2 primary -2) */ * from t2 where pk1=0 and pk2=10;
select /*+ index(t2 primary 0) */ * from t2 where pk1=0 and pk2=10;
select /*+ index(t2 primary 1) */ * from t2 where pk1=0 and pk2=10;
select /*+ index(t2 primary 2) */ * from t2 where pk1=0 and pk2=10;
select /*+ index(t2 primary) */ * from t2 where pk1 < 4000 and pk2 = 2234;
select /*+ index(t2 primary -1) */ * from t2 where pk1 < 4000 and pk2 = 2234;
select /*+ index(t2 primary 0) */ * from t2 where pk1 < 4000 and pk2 = 2234;
select /*+ index(t2 primary 1) */ * from t2 where pk1 < 4000 and pk2 = 2234;
select /*+ index(t2 primary 3) */ * from t2 where pk1 < 4000 and pk2 = 2234;

select /*+ full(t2) */ * from t2 where pk1=0 and pk2=10;
select /*+ full(t2 -1) */ * from t2 where pk1=0 and pk2=10;
select /*+ full(t2 0) */ * from t2 where pk1=0 and pk2=10;

select /*+no_rewrite index(a t2_idx2) index(b t2_idx1) */ * from t2 a, t2 b
        where a.c1=1 and b.c1=a.c1 and b.c2=10 and b.c3=10 and a.c2 = 10;
select /*+no_rewrite index(a t2_idx2) index(b t2_idx1 1) */ * from t2 a, t2 b
        where a.c1=1 and b.c1=a.c1 and b.c2=10 and b.c3=10 and a.c2 = 10;
select /*+no_rewrite index(a t2_idx2 1) index(b t2_idx1) */ * from t2 a, t2 b
        where a.c1=1 and b.c1=a.c1 and b.c2=10 and b.c3=10 and a.c2 = 10;
select /*+no_rewrite index(a t2_idx2 1) index(b t2_idx1 1) */ * from t2 a, t2 b
        where a.c1=1 and b.c1=a.c1 and b.c2=10 and b.c3=10 and a.c2 = 10;

select /*+no_rewrite index(a primary 0) index(b primary 0) */ * from t2 a, t2 b
        where a.c1=1 and b.c1=a.c1 and b.c2=10 and b.c3=10 and a.c2 = 10;
select /*+no_rewrite index(a primary 1) index(b primary 1) */ * from t2 a, t2 b
        where a.pk1 = 0 and a.pk2 = 10 and b.pk1 = a.pk1 and b.pk2 = 10;
select /*+no_rewrite full(a 0) full(b 0) */ * from t2 a, t2 b
        where a.c1=1 and b.c1=a.c1 and b.c2=10 and b.c3=10 and a.c2 = 10;
select /*+no_rewrite full(a 1) full(b  1) */ * from t2 a, t2 b
        where a.pk1 = 0 and a.pk2 = 10 and b.pk1 = a.pk1 and b.pk2 = 10;


select /*+ index(pt1 pt1_idx1) */ * from pt1 where c1= 1 and c2 = 10;
select /*+ index(pt1 pt1_idx1 0) */ * from pt1 where c1= 1 and c2 = 10;
select /*+ index(pt1 primary) */ * from pt1 where pk1 = 0 and pk2 = 10;
select /*+ index(pt1 primary 0) */ * from pt1 where pk1 = 0 and pk2 = 10;
select /*+ full(pt1) */ * from pt1 where pk1 = 0 and pk2 = 10;
select /*+ full(pt1 0) */ * from pt1 where pk1 = 0 and pk2 = 10;

--echo ============================================= used_hint 展示 ================================================
--explain_protocol 3
select /*+ index(t2 t2_idx1 -1) */ * from t2 where c1= 1 and c2 = 1234;
select /*+ index(t2 t2_idx1 1) */ * from t2 where c1= 1 and c2 = 1234;
select /*+ index(t2 primary -1) */ * from t2 where pk1=0 and pk2=10;
select /*+ index(t2 primary 0) */ * from t2 where pk1=0 and pk2=10;
select /*+ full(t2) */ * from t2 where pk1 < 4000 and pk2 = 2234;
select /*+ full(t2 0) */ * from t2 where pk1=0 and pk2=10;
--explain_protocol 2

--echo ============================================= 多个hint正交 ================================================

--echo 多次指定前缀

select /*+ index(t2 t2_idx1 1) index(t2 t2_idx1 2) */ * from t2 where c1= 1 and c2 = 1234;
select /*+ index(t2 t2_idx1 1) index(t2 t2_idx1 2)  index(t2 t2_idx1 0) */ * from t2 where c1= 1 and c2 = 1234;


--echo 测试das路径
select /*+ use_das(t1) index(t1 t1_idx1) */ * from t1 where c1= 1 and c2 = 1234;
select /*+ use_das(t1) index(t1 t1_idx1 -1) */ * from t1 where c1 = 1 and c2 = 1234;
select /*+ use_das(t1) index(t1 t1_idx1 1) */ * from t1 where c1 = 1 and c2 = 1234;
select /*+ use_das(t1) index(t1 primary) */ * from t1 where pk1 = 1 and c2 = 1;
select /*+ use_das(t1) index(t1 primary -1) */ * from t1 where pk1 = 1 and c2 = 1;
select /*+ use_das(t1) index(t1 primary 0) */ * from t1 where pk1 = 1 and c2 = 1;
select /*+ use_das(t1) index(t1 primary 1) */ * from t1 where pk1 = 1 and c2 = 1;
select /*+ use_das(t1) full(t1) */ * from t1 where pk1 = 1 and c2 = 1;
select /*+ use_das(t1) full(t1 -1) */ * from t1 where pk1 = 1 and c2 = 1;
select /*+ use_das(t1) full(t1 0) */ * from t1 where pk1 = 1 and c2 = 1;
select /*+ use_das(t1) full(t1 1) */ * from t1 where pk1 = 1 and c2 = 1;

--echo no_index冲突hint失效
select /*+ no_index(t1 t1_idx1) */ * from t1 where c1= 1 and c2 = 1234;
select /*+ index(t1 t1_idx1) no_index(t1 t1_idx1) */ * from t1 where c1= 1 and c2 = 1234;
select /*+ index(t1 t1_idx1) no_index(t1 t1_idx1 -1) */ * from t1 where c1= 1 and c2 = 1234;
select /*+ index(t1 t1_idx1 0) no_index(t1 t1_idx1) */ * from t1 where c1= 1 and c2 = 1234;
select /*+ no_index(t1 primary) */ * from t1 where c1= 1 and c2 = 1234;
select /*+ index(t1 primary 0) no_index(t1 primary)*/ * from t1 where pk1 < 4000 and c2 = 2234;
select /*+ index(t1 primary 1) no_index(t1 primary)*/ * from t1 where pk1 < 4000 and c2 = 2234;
select /*+ full(t1) no_index(t1 primary)*/ * from t1 where pk1 < 4000 and c2 = 2234;
select /*+ full(t1 -1) no_index(t1 primary)*/ * from t1 where pk1 < 4000 and c2 = 2234;
select /*+ full(t1 0) no_index(t1 primary)*/ * from t1 where pk1 < 4000 and c2 = 2234;

--echo index_ss不受prefix影响
select /*+ index_ss(t1 t1_idx1) */ * from t1 where c2 = 1234;
select /*+ index_ss(t1 t1_idx1 2) */ * from t1 where c2 = 1234;
select /*+ index_ss(t1 t1_idx1) */ * from t1 where c1 < 4000 and c2 = 2234;
select /*+ index_ss(t1 t1_idx1 2) */ * from t1 where c1 < 4000 and c2 = 2234;

--echo ========================================== 内部表场景 ================================================
--echo #实体表
explain outline select /*+ index(a primary) */ * from oceanbase.__all_core_table a where row_id =1 and column_name = 'c1' and table_name='test';
explain outline select /*+ index(a primary 1) */ * from oceanbase.__all_core_table a where row_id =1 and column_name = 'c1' and table_name='test';
explain outline select /*+ full(a) */ * from oceanbase.__all_core_table a where row_id =1 and column_name = 'c1' and table_name='test';
explain outline select /*+ full(a 1) */ * from oceanbase.__all_core_table a where row_id =1 and column_name = 'c1' and table_name='test';

--echo #虚表
explain outline select /*+ index(a primary) */ * from oceanbase.__all_virtual_plan_cache_plan_explain a;
explain outline select /*+ index(a primary 1) */ * from oceanbase.__all_virtual_plan_cache_plan_explain a;
explain outline select /*+ full(a) */ * from oceanbase.__all_virtual_plan_cache_plan_explain a;
explain outline select /*+ full(a 1) */ * from oceanbase.__all_virtual_plan_cache_plan_explain a;

# clean
drop table if exists t1,t2,pt1;
eval set _enable_storage_cardinality_estimation = $saved_storage_cardinality;
eval alter system set _optimizer_skip_scan_enabled = $saved_skip_scan_enabled;
