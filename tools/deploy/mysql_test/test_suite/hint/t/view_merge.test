--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: zhenling.zzg
#owner group: SQL1
#description: test for unnest hint
#tags: optimizer, outline

--result_format 4

--disable_warnings
drop table if exists t1;
drop table if exists t2;
drop table if exists t3;
--enable_warnings

create table t1(c1 int, c2 int, c3 int, c4 int);
create table t2(c1 int, c2 int, c3 int, c4 int);
create table t3(c1 int, c2 int, c3 int, c4 int);

#basic
explain outline select * from (select /*+merge*/ * from t1);

explain outline select * from (select /*+no_merge*/ * from t1);

explain outline select * from (select /*+merge*/ * from t1)v1, (select /*+no_merge*/ * from t2)v2;

#control with qb_name

explain outline select /*+ no_merge(@"SEL$1") merge(@"SEL2")*/ * from (select /*+qb_name(SEL1)*/ * from t1)v1, (select /*+qb_name(SEL2)*/ * from t2)v2;

explain outline select /*+ merge(@"SEL$1") no_merge(@"SEL2")*/ * from (select /*+qb_name(SEL1)*/ * from t1)v1, (select /*+qb_name(SEL2)*/ * from t2)v2;

#conflict hint

explain outline select * from (select /*+no_merge no_merge*/ * from t1);

explain outline select * from (select /*+no_merge merge*/ * from t1);

#not used hint

explain outline select * from (select /*+merge*/ * from t1 limit 1) limit 1;
