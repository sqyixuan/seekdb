#owner: daifangyi.dfy
#owner group: sql1
# tags: parser

--result_format 4

--disable_warnings
--error 0,942
drop table t1;
--enable_warnings

create table t1(c1 int, c2 int);

create index idx1 on t1(c1);

explain extended_noaddr select /*+ index(t1 , idx1) */* from t1;

explain extended_noaddr select /*+ no_index(t1 , idx1) */* from t1;

explain extended_noaddr select /*+ index_desc(t1 , idx1) */* from t1;

explain extended_noaddr select /*+ index_asc(t1 , idx1) */* from t1;

drop table t1;