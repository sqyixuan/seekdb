--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: zhanyue.zzy
#owner group: SQL1
#description: test for optimize hint use_das
#tags: optimizer, outline

--result_format 4

--disable_warnings
drop table if exists t1, tp1;
drop table if exists t2, t3, t4;
--enable_warnings

create table t1(c1 int, c2 int, c3 int);
create table tp1(c1 int, c2 int, c3 int) partition by hash(c1) partitions 10;
create table t2 (c1 int primary key, c2 int, c3 int, c4 int) ;
create table t3 (c1 int primary key, c2 int, c3 int, c4 int) ;
create table t4 (c1 int primary key, c2 int, c3 int, c4 int) ;

explain outline select * from t1;
explain outline select /*+use_das(t1)*/ * from t1;
explain outline select /*+no_use_das(t1)*/ * from t1;

explain outline select /*+parallel(32)*/ * from t1;
explain outline select /*+use_das(t1) parallel(32)*/ * from t1;
explain outline select /*+no_use_das(t1) parallel(32)*/ * from t1;

explain outline select * from tp1;
explain outline select /*+use_das(tp1)*/ * from tp1;
explain outline select /*+no_use_das(tp1)*/ * from tp1;

explain outline select /*+parallel(32)*/ * from tp1;
explain outline select /*+use_das(tp1) parallel(32)*/ * from tp1;
explain outline select /*+no_use_das(tp1) parallel(32)*/ * from tp1;
explain outline select c1,c2,c3,(select /*+ no_use_das(t3) use_nl(t3 t4) leading(t3 t4) */ t3.c4 from t3 join t4 on t3.c2 = t4.c1 where t3.c1=t2.c1) from t2 ;

drop table t1;
drop table tp1;
drop table t2;
drop table t3;
drop table t4;
