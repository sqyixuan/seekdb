#owner: sean.yyj
#owner group: sql3
#tags: optimizer, outline

##Test Name: win_magic.test

--disable_warnings
drop table if exists t1, t2, t3, part, lineitem;
create table t1 ( pk int ,c1 int not null, c2 int ,c3 int, primary key(pk));
create table t2 ( pk int ,c1 int not null, c2 int ,c3 int, primary key(pk));
create table t3 ( pk int ,c1 int not null, c2 int ,c3 int, primary key(pk));
CREATE TABLE `part` (
  `p_partkey` bigint(20) NOT NULL,
  `p_name` varchar(55) DEFAULT NULL,
  `p_mfgr` char(25) DEFAULT NULL,
  `p_brand` char(10) DEFAULT NULL,
  `p_type` varchar(25) DEFAULT NULL,
  `p_size` bigint(20) DEFAULT NULL,
  `p_container` char(10) DEFAULT NULL,
  `p_retailprice` decimal(10,2) DEFAULT NULL,
  `p_comment` varchar(23) DEFAULT NULL,
  PRIMARY KEY (`p_partkey`)
);

CREATE TABLE `lineitem` (
  `l_orderkey` bigint(20) NOT NULL,
  `l_partkey` bigint(20) NOT NULL,
  `l_suppkey` bigint(20) NOT NULL,
  `l_linenumber` bigint(20) NOT NULL,
  `l_quantity` bigint(20) NOT NULL,
  `l_extendedprice` decimal(10,2) NOT NULL,
  `l_discount` decimal(10,2) NOT NULL,
  `l_tax` decimal(10,2) NOT NULL,
  `l_returnflag` char(1) DEFAULT NULL,
  `l_linestatus` char(1) DEFAULT NULL,
  `l_shipdate` date NOT NULL,
  `l_commitdate` date DEFAULT NULL,
  `l_receiptdate` date DEFAULT NULL,
  `l_shipinstruct` char(25) DEFAULT NULL,
  `l_shipmode` char(10) DEFAULT NULL,
  `l_comment` varchar(44) DEFAULT NULL,
  PRIMARY KEY (`l_orderkey`, `l_linenumber`, `l_shipdate`, `l_partkey`),
  KEY `i_l_orderkey` (`l_orderkey`) LOCAL  BLOCK_SIZE 16384
);
call dbms_stats.gather_table_stats(NULL, 't1');
call dbms_stats.gather_table_stats(NULL, 't2');
call dbms_stats.gather_table_stats(NULL, 't3');
call dbms_stats.gather_table_stats(NULL, 'part');
call dbms_stats.gather_table_stats(NULL, 'lineitem');

--enable_warnings
--disable_query_log

--disable_result_log
explain outline select count(*) from t1;
explain outline select count(*) from t2;
explain outline select count(*) from t3;
--enable_result_log
--enable_query_log

--result_format 4
--explain_protocol 2

#basic
explain outline select /*+win_magic*/ * from t1, (select avg(c1), c2 from t1 group by c2) v where t1.c2 = v.c2 order by t1.pk;
explain outline select /*+win_magic(t1 v)*/ * from t1, (select avg(c1), c2 from t1 group by c2) v where t1.c2 = v.c2 order by t1.pk;
explain outline select /*+win_magic(t1 v2)*/ * from t1, (select avg(c1), c2 from t1 group by c2) v where t1.c2 = v.c2 order by t1.pk;
explain outline select /*+win_magic(t1)*/ * from t1, (select avg(c1), c2 from t1 group by c2) v where t1.c2 = v.c2 order by t1.pk;
explain outline select /*+no_win_magic*/ * from t1, (select avg(c1), c2 from t1 group by c2) v where t1.c2 = v.c2 order by t1.pk;
explain outline select /*+win_magic(t1 t2 v)*/ * from t1, t2, (select max(t1.c1), t2.c2 from t1,t2 group by t2.c2) v where v.c2 = t2.c2 order by t1.pk,t2.pk;
explain outline select /*+win_magic(t1 t2)*/ * from t1, t2, (select max(t1.c1), t2.c2 from t1,t2 group by t2.c2) v where v.c2 = t2.c2 order by t1.pk,t2.pk;
EXPLAIN outline select  /*+win_maigc(t1 t2 v2)*/* from t1 left join t2 on t1.c1=t2.c1, (select max(t2.c1), t1.c2 from t1 left join t2 on t1.c1=t2.c1 group by t1.c2) v2 where t1.c2=v2.c2 order by t1.pk,t2.pk;
explain outline select /*+win_magic(a b v)*/ * from t1 a, t1 b, (select sum(c.c1), d.c1 from t1 c, t1 d group by d.c1) v where v.c1 = b.c1 order by a.pk,b.pk;
explain outline select /*+win_magic(v1 v2)*/ * from (select sum(c1) s from t1 group by c2) v1, (select sum(c1) s from t1) v2 order by v1.s, v2.s;
explain outline select /*+win_magic(v2 v1)*/ * from (select sum(c1) s from t1 group by c2) v1, (select sum(c1) s from t1) v2 order by v1.s, v2.s;
explain outline select /*+win_magic(v2 v1)*/ * from t1, (select sum(c1) s, c2 from t1 group by c2) v1, (select sum(c1) s from t1) v2 where t1.c2 = v1.c2 order by v1.s, v2.s;
explain outline select /*+win_magic(t1 v1)*/ * from t1, (select sum(c1) s, c2 from t1 group by c2) v1, (select sum(c1) s from t1) v2 where t1.c2 = v1.c2 order by v1.s, v2.s;
explain outline select /*+win_magic(t1 v1 v2)*/ * from t1, (select sum(c1) s, c2 from t1 group by c2) v1, (select sum(c1) s from t1) v2 where t1.c2 = v1.c2 order by v1.s, v2.s;
explain outline select /*+win_magic(view1 t2 V*/ V.agg as e from t2, (select avg(c1) as agg from t2 where c2 in (select c2 from t3 )) V where c2 in (select c2 from t3);
explain outline select /*+win_magic(t1 v)*/ * from t1, (select sum(c1) s, c2 from t1 group by c2) v, t3 where t1.c2 = v.c2 and t3.pk = v.c2 and t3.pk >10 order by t1.pk,v.c2,t3.pk,v.s;
explain outline select /*+win_magic(t1 v t3)*/ * from t1, (select sum(c1) s, c2 from t1 group by c2) v, t3 where t1.c2 = v.c2 and t3.pk = v.c2 and t3.pk >10 order by t1.pk,v.c2,t3.pk,v.s;
##no rewrite
explain outline select /*+win_magic*/ * from t1, (select avg(c1), c2 from t1 group by c2) v where t1.c2 = v.c2 order by t1.pk;
explain outline select * from t1, (select sum(c1) agg, c1, c2 from t1 group by c1, c2) v where t1.c2 = v.c2 and t1.c2 = v.c2 and v.agg > t1.c1 order by t1.pk;
explain outline select /*+no_win_magic*/ * from t1, (select sum(c1) agg, c1, c2 from t1 group by c1, c2) v where t1.c2 = v.c2 and t1.c2 = v.c2 and v.agg > t1.c1 order by t1.pk;


--disable_warnings
drop table if exists t1, t2, t3, part, lineitem;
--enable_warnings
