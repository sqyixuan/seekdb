#owner: yibo.tyf
#owner group: sql1
# tags: outline, optimizer

--disable_warnings
drop table if exists t1,t2,t3;
--enable_warnings

create table t1(c1 int, c2 int, c3 int);
create table t2(d1 int, d2 int, d3 int);
create table t3(e1 int, e2 int, e3 int);

insert into t1 values(1,1,1), (2,2,2) ,(3,3,3), (4,4,4), (5,5,5);
insert into t2 values(1,1,1), (2,2,2) ,(3,3,3), (4,4,4), (5,5,5);
insert into t3 values(1,1,1), (2,2,2) ,(3,3,3), (4,4,4), (5,5,5);

explain outline select c1,c2,d1,d2
from (select c1,c2,c3 from t1 limit 3) v1,
     (select d1,d2,d3 from t2 limit 3) v2
where v1.c1 = v2.d1;

explain outline select  c1,c2,d1,d2
from (select /*+NO_PROJECT_PRUNE*/c1,c2,c3 from t1 limit 3) v1,
     (select d1,d2,d3 from t2 limit 3) v2
where v1.c1 = v2.d1;

explain outline select /*+NO_PROJECT_PRUNE(@"SEL$2")*/ c1,c2,d1,d2
from (select c1,c2,c3 from t1 limit 3) v1,
     (select d1,d2,d3 from t2 limit 3) v2
where v1.c1 = v2.d1;

explain outline select c1,c2,d1,d2
from (select c1,c2,c3 from t1 limit 3) v1,
     (select /*+PROJECT_PRUNE*/d1,d2,d3 from t2 limit 3) v2
where v1.c1 = v2.d1;

explain outline select /*+PROJECT_PRUNE(@"SEL$3")*/ c1,c2,d1,d2
from (select c1,c2,c3 from t1 limit 3) v1,
     (select d1,d2,d3 from t2 limit 3) v2
where v1.c1 = v2.d1;

explain outline select *
from t3,
     (select c1,c2,d1,d2
      from (select c1,c2,c3 from t1 limit 3) v1,
           (select d1,d2,d3 from t2 limit 3) v2
      where v1.c1 = v2.d1 limit 2) v
where t3.e1 = v.c1;

explain outline select *
from t3,
     (select  c1,c2,d1,d2
      from (select /*+NO_PROJECT_PRUNE*/c1,c2,c3 from t1 limit 3) v1,
           (select /*+NO_PROJECT_PRUNE*/d1,d2,d3 from t2 limit 3) v2
      where v1.c1 = v2.d1 limit 2) v
where t3.e1 = v.c1;

explain outline select /*+NO_PROJECT_PRUNE(@"SEL$3")*/ *
from t3,
     (select c1,c2,d1,d2
      from (select c1,c2,c3 from t1 limit 3) v1,
           (select d1,d2,d3 from t2 limit 3) v2
      where v1.c1 = v2.d1 limit 2) v
where t3.e1 = v.c1;

drop table if exists t1,t2,t3;