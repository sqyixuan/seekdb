--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: zhenling.zzg
#owner group: SQL1
#description: test for unnest hint
#tags: optimizer, outline

--result_format 4

--disable_warnings
drop table if exists t1;
drop table if exists t2;
drop table if exists t3;
--enable_warnings

create table t1(c1 int, c2 int, c3 int, c4 int);
create table t2(c1 int, c2 int, c3 int, c4 int);
create table t3(c1 int, c2 int, c3 int, c4 int);

#basic
explain outline select /*+semi_to_inner(t2)*/ * from t1 where c1 in (select c2 from t2);

explain outline select /*+no_semi_to_inner*/ * from t1 where c1 in (select c2 from t2);

explain outline select /*+
semi_to_inner(t3)*/ * from t1 
where c1 in (select c2 from t2)
    and c2 in (select c3 from t3);

explain outline select /*+
semi_to_inner(t2)*/ * from t1 
where c1 in (select c2 from t2)
    and c2 in (select c3 from t3);

explain outline select /*+
semi_to_inner(t2 t3)*/ * from t1 
where c1 in (select c2 from t2)
    and c2 in (select c3 from t3);

explain outline select /*+
no_semi_to_inner*/ * from t1 
where c1 in (select c2 from t2 limit 1)
    and c2 in (select c3 from t3);

#control with qb_name
explain outline select /*+qb_name(SEL)*/ * from t1 
where c1 in (select /*+semi_to_inner(@"SEL" t2 t3)*/ c2 from t2)
    and c2 in (select c3 from t3);

#conflict hint
explain outline select /*+semi_to_inner(t2) semi_to_inner(t2)*/ * from t1 where c1 in (select c2 from t2);

explain outline select /*+semi_to_inner(t2) no_semi_to_inner*/ * from t1 where c1 in (select c2 from t2);

#not used hint
explain outline select /*+semi_to_inner(t2)*/ * from t1 where exists (select 1 from t2 where t1.c1 != t2.c1);
