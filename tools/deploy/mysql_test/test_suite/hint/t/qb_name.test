--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: zhanyue.zzy
#owner group: SQL1
#description: test qb_name hint
#tags: optimizer, outline

--result_format 4

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1(c1 int, c2 int, c3 int, c4 int);

explain outline select * from (select /*+qb_name(qb1)*/ * from t1 a) a, (select /*+qb_name(qb2)*/ * from t1 b)b;
explain outline select * from (select /*+qb_name(qb1) qb_name(qb2)*/ * from t1 a) a, (select /*+qb_name(qb2)*/ * from t1 b)b;
explain outline select * from (select /*+qb_name(qb1)*/ * from t1 a) a, (select /*+qb_name(qb1)*/ * from t1 b)b;
explain outline select /*+no_merge(@qb2)*/ * from (select /*+qb_name(qb1) qb_name(qb2)*/ * from t1 a) a, (select /*+qb_name(qb2)*/ * from t1 b)b;
explain outline SELECT /*+ QB_NAME(qb) FULL(@qb TABLE1),QB_NAME(qb) FULL(@qb TABLE1),QB_NAME(qb) FULL(@qb TABLE1) */ * FROM t1 TABLE1;

drop table t1;
