--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: zhenling.zzg
#owner group: sql1
#description: test for transform hint: push_limit/no_push_limit
#tags: outline, optimizer

--disable_warnings
drop table if exists t1, t2, t3;
--enable_warnings
create table t1(c1 int, c2 int);
create table t2(c1 int, c2 int);
create table t3(c1 int, c2 int);

--explain_protocol 0
explain outline select * from t1 left join t2 on t1.c1 = t2.c1 limit 5;
explain outline select /*+push_limit*/ * from t1 left join t2 on t1.c1 = t2.c1 limit 5;
explain outline select /*+push_limit(@"SEL$1")*/ * from t1 left join t2 on t1.c1 = t2.c1 limit 5;
explain outline select /*+push_limit(@"SEL$233")*/ * from t1 left join t2 on t1.c1 = t2.c1 limit 5;
explain outline select /*+no_push_limit*/ * from t1 left join t2 on t1.c1 = t2.c1 limit 5;
explain outline select /*+no_push_limit(@"SEL$1")*/ * from t1 left join t2 on t1.c1 = t2.c1 limit 5;
explain outline select /*+no_push_limit(@"SEL$233")*/ * from t1 left join t2 on t1.c1 = t2.c1 limit 5;

explain outline select * from t1, t2 limit 5;
explain outline select /*+push_limit*/ * from t1, t2 limit 5;
explain outline select /*+push_limit(@"SEL$1")*/ * from t1, t2 limit 5;
explain outline select /*+push_limit(@"SEL$233")*/ * from t1, t2 limit 5;
explain outline select /*+no_push_limit*/ * from t1, t2 limit 5;
explain outline select /*+no_push_limit(@"SEL$1")*/ * from t1, t2 limit 5;
explain outline select /*+no_push_limit(@"SEL$233")*/ * from t1, t2 limit 5;
explain outline select * from t1 where c1 in (select /*+no_unnest push_limit*/t2.c1 from t2, t3 limit 5);
explain outline select * from t1 where c1 in (select /*+no_unnest no_push_limit*/t2.c1 from t2, t3 limit 5);

explain outline select /*+push_limit*/* from (select /*+push_limit*/t1.c1 from t1 left join t2 on t1.c1 = t2.c1 limit 1) V, t2 limit 5;
explain outline select /*+push_limit*/* from (select /*+no_push_limit*/t1.c1 from t1 left join t2 on t1.c1 = t2.c1 limit 1) V, t2 limit 5;
explain outline select /*+no_push_limit*/* from (select /*+push_limit*/t1.c1 from t1 left join t2 on t1.c1 = t2.c1 limit 1) V, t2 limit 5;
explain outline select /*+no_push_limit*/* from (select /*+no_push_limit*/t1.c1 from t1 left join t2 on t1.c1 = t2.c1 limit 1) V, t2 limit 5;

--disable_warnings
drop table if exists t1, t2, t3;
--enable_warnings
