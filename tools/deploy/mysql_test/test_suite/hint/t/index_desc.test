# owner: wuyuming.wym
# tags: optimizer, outline

alter system set _optimizer_skip_scan_enabled = true;
set ob_enable_transformation = 0;
--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1(pk1 int, c1 int, c2 int, primary key(pk1), index i1(c1), index i2(c2, c1));
insert into t1 select row_number() over (), abs(random(1)) % 100, abs(random(1)) % 100 from table(generator(10000));
--enable_query_log

explain extended_noaddr select /*+index_asc(t1 primary)*/ * from t1 where c1 = 2 order by c2 desc limit 10;
explain extended_noaddr select /*+index_desc(t1 primary)*/ * from t1 where c1 = 2 order by c2 desc limit 10;
explain extended_noaddr select /*+index_asc(t1 i1)*/ * from t1 where c1 = 2 order by c2 desc limit 10;
explain extended_noaddr select /*+index_desc(t1 i1)*/ * from t1 where c1 = 2 order by c2 desc limit 10;
explain extended_noaddr select /*+index_ss_asc(t1 i2)*/ * from t1 where c1 = 2 order by c2 desc limit 10;
explain extended_noaddr select /*+index_ss_desc(t1 i2)*/ * from t1 where c1 = 2 order by c2 desc limit 10;
explain extended_noaddr select /*+index_asc(t1 i2 1)*/ * from t1 where c1 = 2 and c2 = 2 limit 10;
explain extended_noaddr select /*+index_desc(t1 i2 1)*/ * from t1 where c1 = 2 and c2 = 2 limit 10;

explain extended_noaddr select /*+index(t1 i2) index_desc(t1 i2)*/ * from t1 where c2 = 2 order by c1 desc limit 10;
explain extended_noaddr select /*+index(t1 i2) index_asc(t1 i2)*/ * from t1 where c2 = 2 order by c1 desc limit 10;
explain extended_noaddr select /*+index_desc(t1 i2) index_asc(t1 i2)*/ * from t1 where c2 = 2 order by c1 desc limit 10;
explain extended_noaddr select /*+index(t1 i2) index_desc(t1 i2) index_asc(t1 i2)*/ * from t1 where c2 = 2 order by c1 desc limit 10;

explain extended_noaddr select /*+index_ss(t1 i2) index_ss_desc(t1 i2)*/ * from t1 where c1 = 2 order by c1 desc limit 10;
explain extended_noaddr select /*+index_ss(t1 i2) index_ss_asc(t1 i2)*/ * from t1 where c1 = 2 order by c1 desc limit 10;
explain extended_noaddr select /*+index_ss_desc(t1 i2) index_ss_asc(t1 i2)*/ * from t1 where c1 = 2 order by c1 desc limit 10;
explain extended_noaddr select /*+index_ss(t1 i2) index_ss_desc(t1 i2) index_ss_asc(t1 i2)*/ * from t1 where c1 = 2 order by c1 desc limit 10;

explain outline select c1 from t1 order by c1 asc;
explain outline select /*+index(t1 i1)*/ c1 from t1 order by c1 asc;
explain outline select /*+index_asc(t1 i1)*/ c1 from t1 order by c1 asc;
explain outline select /*+index_desc(t1 i1)*/ c1 from t1 order by c1 asc;
explain outline select /*+index(t1 i2)*/ c1 from t1 order by c1 asc;
explain outline select /*+index_asc(t1 i2)*/ c1 from t1 order by c1 asc;
explain outline select /*+index_desc(t1 i2)*/ c1 from t1 order by c1 asc;
explain outline select /*+index_asc(t1 primary)*/ c1 from t1 order by c1 asc;
explain outline select /*+index_desc(t1 primary)*/ c1 from t1 order by c1 asc;

explain outline select c1 from t1 order by c1 desc;
explain outline select /*+index(t1 i1)*/ c1 from t1 order by c1 desc;
explain outline select /*+index_asc(t1 i1)*/ c1 from t1 order by c1 desc;
explain outline select /*+index_desc(t1 i1)*/ c1 from t1 order by c1 desc;
explain outline select /*+index(t1 i2)*/ c1 from t1 order by c1 desc;
explain outline select /*+index_asc(t1 i2)*/ c1 from t1 order by c1 desc;
explain outline select /*+index_desc(t1 i2)*/ c1 from t1 order by c1 desc;
explain outline select /*+index_asc(t1 primary)*/ c1 from t1 order by c1 desc;
explain outline select /*+index_desc(t1 primary)*/ c1 from t1 order by c1 desc;

explain outline select c1, c2 from t1 where c2 in (1,2,3) order by c1 asc limit 10;
explain outline select /*+index_asc(t1 i2)*/ c1, c2 from t1 where c2 in (1,2,3) order by c1 asc limit 10;
explain outline select /*+index_desc(t1 i2)*/ c1, c2 from t1 where c2 in (1,2,3) order by c1 asc limit 10;

explain outline select c1, c2 from t1 where c2 in (1,2,3) order by c1 desc limit 10;
explain outline select /*+index_asc(t1 i2)*/ c1, c2 from t1 where c2 in (1,2,3) order by c1 desc limit 10;
explain outline select /*+index_desc(t1 i2)*/ c1, c2 from t1 where c2 in (1,2,3) order by c1 desc limit 10;

explain outline select c1 from t1 where c1 = 2 order by c2 asc;
explain outline select /*+index_ss_asc(t1 i2)*/ c1 from t1 where c1 = 2 order by c2 asc;
explain outline select /*+index_ss_desc(t1 i2)*/ c1 from t1 where c1 = 2 order by c2 asc;

explain outline select c1 from t1 where c1 = 2 order by c2 asc;
explain outline select /*+index_ss_asc(t1 i2)*/ c1 from t1 where c1 = 2 order by c2 asc;
explain outline select /*+index_ss_desc(t1 i2)*/ c1 from t1 where c1 = 2 order by c2 asc;

explain outline select (select pk1 from t1 where c2 in (v1.c2, v1.c2 + 1) order by c1 desc limit 1) from t1 v1 limit 5;
explain outline select (select /*+index_asc(t1 i2)*/ pk1 from t1 where c2 in (v1.c2, v1.c2 + 1) order by c1 desc limit 1) from t1 v1 limit 5;
explain outline select (select /*+index_desc(t1 i2)*/ pk1 from t1 where c2 in (v1.c2, v1.c2 + 1) order by c1 desc limit 1) from t1 v1 limit 5;

drop table t1;
eval alter system set _optimizer_skip_scan_enabled = false;