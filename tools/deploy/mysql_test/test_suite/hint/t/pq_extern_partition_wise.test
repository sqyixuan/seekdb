--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: zhanyue.zzy
#owner group: SQL1
#description: pq_distribute and pq_set for DistAlgo::DIST_EXT_PARTITION_WISE and DistAlgo::DIST_SET_PARTITION_WISE;
#tags: optimizer, outline

--result_format 4

--disable_warnings
drop table if exists t1, tp1;
--enable_warnings

create table t1(c1 int, c2 int, c3 int);
create table tp1(c1 int, c2 int, c3 int) partition by hash(c1) partitions 8;

## expected extension partition wise join
explain basic
select /*+leading((a b) (c d)) parallel(4) use_hash(b d) pq_distribute(b hash hash) pq_distribute(d hash hash)*/ * from t1 a, t1 b, t1 c, t1 d where a.c1 = b.c1  and b.c1 = c.c1 and c.c1 = d.c1;
explain basic
select /*+leading((a b) (c d)) parallel(4) use_hash(b d) pq_distribute(b hash hash) pq_distribute((c d) none none)*/ * from t1 a, t1 b, t1 c, t1 d where a.c1 = b.c1  and b.c1 = c.c1 and c.c1 = d.c1;
explain basic
select /*+leading((a b) (c d)) parallel(4) use_hash(b d) pq_distribute(b hash hash)*/ * from t1 a, t1 b, t1 c, t1 d where a.c1 = b.c1  and b.c1 = c.c1 and c.c1 = d.c1;
explain basic
select /*+leading((a b) (c d)) parallel(4) use_hash(b d) pq_distribute((c d) none none)*/ * from t1 a, t1 b, t1 c, t1 d where a.c1 = b.c1  and b.c1 = c.c1 and c.c1 = d.c1;

## expected set partition wise
explain basic
select /*+parallel(16) pq_set(@set$1 none none)*/ * from tp1
union all
select c2, c1, c3 from tp1;

drop table t1, tp1;
