--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: zhenling.zzg
#owner group: SQL1
#description: test for unnest hint
#tags: optimizer, outline

--result_format 4

--disable_warnings
drop table if exists t1;
drop table if exists t2;
drop table if exists t3;
--enable_warnings

create table t1(c1 int, c2 int, c3 int, c4 int);
create table t2(c1 int, c2 int, c3 int, c4 int);
create table t3(c1 int, c2 int, c3 int, c4 int);

#basic
explain outline select /*+NO_COALESCE_SQ*/ * 
from t1 where c1 in (select c1 from t2) or c1 in (select c2 from t2);

explain outline select /*+COALESCE_SQ(@"SEL$1" ("SEL$2", "SEL$3"))*/ * 
from t1 where c1 in (select c1 from t2) or c1 in (select c2 from t2);

explain outline select /*+NO_COALESCE_SQ*/ * from t1 l where exists (select 1 from t2 r1 where l.c1 = r1.c1) 
and not exists (select 1 from t2 r2 where l.c1 = r2.c1 and l.c2 = r2.c2);

explain outline select /*+NO_COALESCE_SQ*/ * from t1 where t1.c1 in (select c1 from t2 where t2.c2 = t1.c2) 
and c1 not in (select c1 from t2 where t2.c2 = t1.c2);

explain outline select /*+NO_COALESCE_SQ*/ * from t1 where t1.c1 in (select c1 from t2 where t2.c2 = t1.c2) 
and c1 not in (select c1 from t2 where t2.c2 = t1.c2 and t2.c2 > 1) ;


explain outline update /*+coalesce_sq(("SEL1", "SEL2"))*/ t1 
set c1 = (select /*+qb_name(SEL1)*/ c1 from t2 A),
    c2 = (select /*+qb_name(SEL2)*/ c2 from t2 B),
    c3 = (select /*+qb_name(SEL3)*/ c3 from t2 C),
    c4 = (select /*+qb_name(SEL4)*/ c4 from t2 D);

explain outline update /*+no_coalesce_sq*/ t1 
set c1 = (select /*+qb_name(SEL1)*/ c1 from t2 A),
    c2 = (select /*+qb_name(SEL2)*/ c2 from t2 B),
    c3 = (select /*+qb_name(SEL3)*/ c3 from t2 C),
    c4 = (select /*+qb_name(SEL4)*/ c4 from t2 D);

explain outline update /*+no_coalesce_sq*/ t1 
set c1 = (select /*+qb_name(SEL1)*/ c1 from t2 A),
    c2 = (select /*+qb_name(SEL2)*/ c2 from t2 B),
    c3 = (select /*+qb_name(SEL3)*/ c3 from t2 C),
    c4 = (select /*+qb_name(SEL4)*/ c4 from t2 D);

#conflict hint
explain outline update /*+coalesce_sq(("SEL1", "SEL2")) coalesce_sq(("SEL3", "SEL4"))*/ t1 
set c1 = (select /*+qb_name(SEL1)*/ c1 from t2 A),
    c2 = (select /*+qb_name(SEL2)*/ c2 from t2 B),
    c3 = (select /*+qb_name(SEL3)*/ c3 from t2 C),
    c4 = (select /*+qb_name(SEL4)*/ c4 from t2 D);

explain outline update /*+coalesce_sq(("SEL1", "SEL2")) no_coalesce_sq*/ t1 
set c1 = (select /*+qb_name(SEL1)*/ c1 from t2 A),
    c2 = (select /*+qb_name(SEL2)*/ c2 from t2 B),
    c3 = (select /*+qb_name(SEL3)*/ c3 from t2 C),
    c4 = (select /*+qb_name(SEL4)*/ c4 from t2 D);

#not used hint
explain outline update /*+coalesce_sq(("SEL1", "SEL2"))*/ t1 
set c1 = (select /*+qb_name(SEL1)*/ c1 from t2 A),
    c2 = (select /*+qb_name(SEL2)*/ c2 from t3 B),
    c3 = (select /*+qb_name(SEL3)*/ c3 from t2 C),
    c4 = (select /*+qb_name(SEL4)*/ c4 from t2 D);
