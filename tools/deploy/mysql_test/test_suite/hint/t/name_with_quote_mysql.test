--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: zhanyue.zzy
#owner group: SQL1
#description: test table/index name with double quote and backtick
#tags: optimizer, outline

--result_format 4

--disable_warnings
drop table if exists `t-1`;
--enable_warnings

create table `t-1`(c1 int, c2 int, c3 int, c4 int);
create index idx on `t-1`(c1);
create index `idx-c2` on `t-1`(c2);

explain outline select * from `t-1` t where c1 = 1;
explain outline select /*+index(t idx-c2)*/ * from `t-1` t where c1 = 1;
explain outline select /*+index(t "idx-c2")*/ * from `t-1` t where c1 = 1;
explain outline select /*+index(t `idx-c2`)*/ * from `t-1` t where c1 = 1;
explain outline select /*+index(`t-1` "idx-c2")*/ * from `t-1` where c1 = 1;
explain outline select /*+index("t-1" `idx-c2`)*/ * from `t-1` where c1 = 1;
explain select /*+index("t-1" `idx-c2`)*/ * from `t-1` t where c1 = 1;

drop table `t-1`;
