--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: zhenling.zzg
#owner group: SQL1
#description: test for unnest hint
#tags: optimizer, outline

--result_format 4

--disable_warnings
drop table if exists t1;
drop table if exists t2;
drop table if exists t3;
--enable_warnings

create table t1(c1 int, c2 int, c3 int, c4 int);
create table t2(c1 int, c2 int, c3 int, c4 int);
create table t3(c1 int, c2 int, c3 int, c4 int);

#basic
explain outline select * from t1 
where exists(select /*+unnest*/ 1 from t2 where t1.c1 = t2.c1);

explain outline select * from t1 
where exists(select /*+no_unnest*/ 1 from t2 where t1.c1 = t2.c1);

explain outline select * from t1 
where exists(select /*+unnest*/ 1 from t2 where t1.c1 = t2.c1)
    and not exists(select /*+no_unnest*/ 1 from t3 where t1.c2 = t3.c2);

#control with qb_name
explain outline select /*+no_unnest(@"sel1") unnest(@"sel2")*/ * from t1 
where exists(select /*+qb_name(sel1)*/ 1 from t2 where t1.c1 = t2.c1)
    and not exists(select /*+qb_name(sel2)*/ 1 from t3 where t1.c2 = t3.c2);

#conflict hint
explain outline select * from t1 
where exists(select /*+no_unnest no_unnest*/ 1 from t2 where t1.c1 = t2.c1);

explain outline select * from t1 
where exists(select /*+unnest no_unnest*/ 1 from t2 where t1.c1 = t2.c1);

#not used hint
explain outline select * from t1 
where c2 in (select /*+unnest*/ c2 from t2 where t1.c1 = t2.c1 limit 1);

explain outline select * from t1 
where c2 in (select /*+no_unnest*/ c2 from t2 where t1.c1 = t2.c1 limit 1);
