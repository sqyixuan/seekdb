# tags: optimizer, outline
##
## Test Name: groupby_pushdown.test
##
--source mysql_test/include/sql_import_opt_wisconsin.inc
--result_format 4
--explain_protocol 2

USE OPT_WISCONSIN;

select count(*) from g_4k;
select count(*) from h_4k;
select count(*) from t1_1;
select count(*) from t1_100;
select count(*) from t2_1;
select count(*) from t2_100;
select count(*) from t_4k;
select count(*) from t_5k;
select count(*) from t_10k;
select count(*) from t_part;
select count(*) from z_4k;

## inner join tables
explain outline select min(l.thousand), max(l.thousand) from t1_100 l, t2_100 r where l.ten = r.ten group by l.ten having min(l.thousand) > 0;
explain outline select /*+place_group_by*/  min(l.thousand), max(l.thousand) from t1_100 l, t2_100 r where l.ten = r.ten group by l.ten having min(l.thousand) > 0;
explain outline select /*+place_group_by(l)*/  min(l.thousand), max(l.thousand) from t1_100 l, t2_100 r where l.ten = r.ten group by l.ten having min(l.thousand) > 0;
explain outline select /*+place_group_by(l r)*/  min(l.thousand), max(l.thousand) from t1_100 l, t2_100 r where l.ten = r.ten group by l.ten having min(l.thousand) > 0;
explain outline select /*+place_group_by(r)*/  min(l.thousand), max(l.thousand) from t1_100 l, t2_100 r where l.ten = r.ten group by l.ten having min(l.thousand) > 0;
explain outline select /*+no_place_group_by*/ min(l.thousand), max(l.thousand) from t1_100 l, t2_100 r where l.ten = r.ten group by l.ten having min(l.thousand) > 0;
explain outline select /*+place_group_by(l r)*/ min(l.thousand), max(l.thousand) from t1_100 l left join t2_100 r on l.ten = r.ten group by l.ten;
explain outline select /*+place_group_by((l r))*/ min(l.thousand), max(l.thousand) from t1_100 l left join t2_100 r on l.ten = r.ten group by l.ten;
explain outline select /*+place_group_by*/ sum(l.thousand) from t_4k l, t_5k r where l.unique2 = r.ten group by l.hundred, l.ten;
explain outline select /*+no_place_group_by*/ sum(l.thousand) from t_4k l, t_5k r where l.unique2 = r.ten group by l.hundred, l.ten;
explain outline select /*+no_rewrite*/ sum(l.thousand) from t_4k l, t_5k r where l.unique2 = r.ten group by l.hundred, l.ten;

explain outline select /*+place_group_by( (l r) s)*/ sum(l.thousand), sum(r.thousand) from t1_100 l, t2_100 r, t2_100 s where l.ten = r.ten and s.hundred = l.hundred group by l.ten + r.ten;
