--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: zhanyue.zzy
#owner group: sql1
#description: test for transform aggregate hint: fast_minmax/no_fast_minmax
#tags: optimizer, outline

--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1(c1 int primary key, c2 int);

--result_format 4

explain outline select max(c1) from t1;
explain outline select /*+FAST_MINMAX*/max(c1) from t1;
explain outline select /*+FAST_MINMAX(@"SEL$2")*/max(c1) from t1;
explain outline select /*+NO_REWRITE*/max(c1) from t1;
explain outline select /*+NO_FAST_MINMAX*/max(c1) from t1;
explain outline select /*+NO_FAST_MINMAX(@"SEL$1")*/max(c1) from t1;
explain outline select /*+NO_FAST_MINMAX(@"SEL$2")*/* from (select max(c1) from t1);

explain outline select min(c1) from t1;
explain outline select /*+FAST_MINMAX*/min(c1) from t1;
explain outline select /*+FAST_MINMAX(@"SEL$2")*/min(c1) from t1;
explain outline select /*+NO_REWRITE*/min(c1) from t1;
explain outline select /*+NO_FAST_MINMAX*/min(c1) from t1;
explain outline select /*+NO_FAST_MINMAX(@"SEL$1")*/min(c1) from t1;
explain outline select /*+NO_FAST_MINMAX(@"SEL$2")*/* from (select min(c1) from t1);

drop table t1;