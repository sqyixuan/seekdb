result_format: 4
drop table if exists t1;
SET @a = '123abc';

CREATE TABLE t1 (
    id INT PRIMARY KEY AUTO_INCREMENT,
    a VARCHAR(255) 
);

INSERT INTO t1(a) VALUES 
('123abc'),
('abc123'),
('1xyz'),
('nothing'),
('');

explain_protocol: 1
EXPLAIN BASIC SELECT /*+rewrite*/ REGEXP_SUBSTR(a, '1.*', 1) FROM t1 WHERE a = @a;
