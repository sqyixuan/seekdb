explain outline
select count(*) from (
select 
/*+
      PQ_SET(@"SET$1"  NONE NONE)
      LEADING( ("VIEW2"@"SEL$2" "test"."t16_3"@"SEL$2"))
      USE_HASH( "test"."t16_3"@"SEL$2")
      PARALLEL( "test"."t16_3"@"SEL$2" 1)
      PQ_DISTRIBUTE( "test"."t16_3"@"SEL$2" ALL NONE)
      PARALLEL(@"SEL$4" "t16_3"@"SEL$4" 10)
      SEMI_TO_INNER
      OPT_PARAM('INLIST_REWRITE_THRESHOLD' 1)
  */
 1 FROM t16 AS t16_3 
WHERE t16_3.c38 IN ('eQTOR')
      and 'MEfVIBLINGijrHOgAnLjCyRdWFXANZwRhwquQnVa' IN (t16_3.c45, t16_3.c39)
      AND t16_3.c48 >= t16_3.c40
union all
select 1 FROM t16 AS t16_3 
WHERE t16_3.c18 = 26
      and 'MEfVIBLINGijrHOgAnLjCyRdWFXANZwRhwquQnVa' IN (t16_3.c45, t16_3.c39)
      AND t16_3.c48 >= t16_3.c40)
;
