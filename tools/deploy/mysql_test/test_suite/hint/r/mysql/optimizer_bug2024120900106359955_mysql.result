result_format: 4
explain_protocol: 1
drop table if exists t0;
drop table if exists t1;
CREATE TABLE t0 (
    c0 VARCHAR(123)
);
CREATE TABLE t1 LIKE t0;

EXPLAIN BASIC SELECT /*+ TOPK (50 50)
          USE_COLUMN_TABLE(t1)
          USE_COLUMN_TABLE(t0)
         */
    true
FROM
    t0
    INNER JOIN t1
GROUP BY
    t1.c0
HAVING
    t1.c0
ORDER BY
    true
LIMIT
    50;
