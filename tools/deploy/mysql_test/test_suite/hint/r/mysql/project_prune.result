      BEGIN_OUTLINE_DATA
      LEADING(@"SEL$1" ("v1"@"SEL$1" "v2"@"SEL$1"))
      USE_HASH(@"SEL$1" "v2"@"SEL$1")
      FULL(@"SEL$2F8A4177" "test"."t1"@"SEL$2")
      FULL(@"SEL$02A956E8" "test"."t2"@"SEL$3")
      PROJECT_PRUNE(@"SEL$2")
      PROJECT_PRUNE(@"SEL$3")
      OPTIMIZER_FEATURES_ENABLE('')
      END_OUTLINE_DATA
  */
explain outline select  c1,c2,d1,d2
from (select /*+NO_PROJECT_PRUNE*/c1,c2,c3 from t1 limit 3) v1,
(select d1,d2,d3 from t2 limit 3) v2
where v1.c1 = v2.d1;
