drop table if exists t1,t2,t3;
create table t1(c1 int, c2 int, c3 int);
create table t2(d1 int, d2 int, d3 int);
create table t3(e1 int, e2 int, e3 int);
insert into t1 values(1,1,1), (2,2,2) ,(3,3,3), (4,4,4), (5,5,5);
insert into t2 values(1,1,1), (2,2,2) ,(3,3,3), (4,4,4), (5,5,5);
insert into t3 values(1,1,1), (2,2,2) ,(3,3,3), (4,4,4), (5,5,5);
explain outline select c1,c2,d1,d2
from (select c1,c2,c3 from t1 limit 3) v1,
(select d1,d2,d3 from t2 limit 3) v2
where v1.c1 = v2.d1;
Query Plan
===================================================
|ID|OPERATOR           |NAME|EST.ROWS|EST.TIME(us)|
---------------------------------------------------
|0 |HASH JOIN          |    |3       |6           |
|1 |├─SUBPLAN SCAN     |v1  |3       |3           |
|2 |│ └─TABLE FULL SCAN|t1  |3       |3           |
|3 |└─SUBPLAN SCAN     |v2  |3       |3           |
|4 |  └─TABLE FULL SCAN|t2  |3       |3           |
===================================================
Outputs & filters:
-------------------------------------
  0 - output([v1.c1], [v1.c2], [v2.d1], [v2.d2]), filter(nil), rowset=16
      equal_conds([v1.c1 = v2.d1]), other_conds(nil)
  1 - output([v1.c1], [v1.c2]), filter(nil), rowset=16
      access([v1.c1], [v1.c2])
  2 - output([t1.c1], [t1.c2]), filter(nil), rowset=16
      access([t1.c1], [t1.c2]), partitions(p0)
      limit(3), offset(nil), is_index_back=false, is_global_index=false, 
      range_key([t1.__pk_increment]), range(MIN ; MAX)always true
  3 - output([v2.d1], [v2.d2]), filter(nil), rowset=16
      access([v2.d1], [v2.d2])
  4 - output([t2.d1], [t2.d2]), filter(nil), rowset=16
      access([t2.d1], [t2.d2]), partitions(p0)
      limit(3), offset(nil), is_index_back=false, is_global_index=false, 
      range_key([t2.__pk_increment]), range(MIN ; MAX)always true
Outline Data: 
-------------------------------------
