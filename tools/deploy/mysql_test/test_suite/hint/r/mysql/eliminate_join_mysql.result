drop table if exists tff, tf, tp, t1, t2, t3;
drop table if exists t1, t2, t3;
create table t1(a int, b int, c int);
create table t2(a int primary key, b int, c int);
create table t3(a int, b int not null, c int);
explain outline select * from t1 left join (select t2.a, t3.b from t2 left join t3 on t2.a = t3.a where t2.a is null) tt2  on t1.a = tt2.a ;
