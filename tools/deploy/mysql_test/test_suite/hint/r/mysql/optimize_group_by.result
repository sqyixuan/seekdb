result_format: 4
drop table if exists t1;
drop table if exists tp1;
create table t1(c1 int, c2 int, c3 int, c4 int);
create table tp1(c1 int, c2 int, c3 int, c4 int) partition by hash(c1) partitions 8;
create index tp1_idx_c4 on tp1(c4) local;

## aggregate function without distinct
explain outline select /*+use_hash_aggregation gby_pushdown*/ sum(c2) from t1 group by c1;
Query Plan
=================================================
|ID|OPERATOR         |NAME|EST.ROWS|EST.TIME(us)|
-------------------------------------------------
|0 |HASH GROUP BY    |    |1       |3           |
|1 |└─TABLE FULL SCAN|t1  |1       |3           |
=================================================
Outputs & filters:
-------------------------------------
  0 - output([T_FUN_SUM(t1.c2)]), filter(nil), rowset=16
      group([t1.c1]), agg_func([T_FUN_SUM(t1.c2)])
  1 - output([t1.c2], [t1.c1]), filter(nil), rowset=16
      access([t1.c2], [t1.c1]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t1.__pk_increment]), range(MIN ; MAX)always true
