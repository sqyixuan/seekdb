  0 - output([t.c1], [t.c2], [t.c3], [t.c4]), filter(nil), rowset=16
      access([t.__pk_increment], [t.c1], [t.c2], [t.c3], [t.c4]), partitions(p0)
      is_index_back=true, is_global_index=false, 
      range_key([t.c1], [t.__pk_increment]), range(1,MIN ; 1,MAX), 
      range_cond([t.c1 = 1])
