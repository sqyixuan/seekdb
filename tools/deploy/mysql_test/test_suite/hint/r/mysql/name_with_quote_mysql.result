result_format: 4
drop table if exists `t-1`;
create table `t-1`(c1 int, c2 int, c3 int, c4 int);
create index idx on `t-1`(c1);
create index `idx-c2` on `t-1`(c2);

explain outline select * from `t-1` t where c1 = 1;
