create table t1(pk1 int, c1 int, c2 int, primary key(pk1),unique key t1_idx1(c1,c2));
create table t2(pk1 int, pk2 int, c1 int, c2 int, c3 int, primary key(pk1, pk2),unique key t2_idx1(c1,c2), unique key t2_idx2(c1,c2,c3));
create table pt1(pk1 int, pk2 int, c1 int, c2 int, c3 int, primary key(pk1, pk2), unique key pt1_idx1(c1,c2,pk1) global) partition by hash(pk1) partitions 4;
explain_protocol: 2
result_format: 4
============================================= 测试常规用法 ================================================
EXPLAIN select /*+ index(t2 t2_idx1) */ * from t2 where c1= 1 and c2 = 1234;
