result_format: 4
drop table if exists t1;
create table t1(c1 int, c2 int, c3 int, c4 int) partition by hash(c1) partitions 10;

## 1. basic test
explain outline select
/*+parallel(2) leading(a b) use_hash(b) PQ_DISTRIBUTE(b bc2host none)
px_join_filter(b)
px_part_join_filter(b)
*/ *
from t1 a, t1 b where a.c1 = b.c1;
Query Plan
============================================================================
|ID|OPERATOR                                |NAME    |EST.ROWS|EST.TIME(us)|
----------------------------------------------------------------------------
|0 |PX COORDINATOR                          |        |1       |25          |
|1 |└─EXCHANGE OUT DISTR                    |:EX10001|1       |24          |
|2 |  └─SHARED HASH JOIN                    |        |1       |23          |
|3 |    ├─JOIN FILTER CREATE                |:RF0001 |1       |12          |
|4 |    │ └─PART JOIN FILTER CREATE         |:RF0000 |1       |12          |
|5 |    │   └─EXCHANGE IN DISTR             |        |1       |12          |
|6 |    │     └─EXCHANGE OUT DISTR (BC2HOST)|:EX10000|1       |12          |
|7 |    │       └─PX BLOCK ITERATOR         |        |1       |11          |
|8 |    │         └─TABLE FULL SCAN         |a       |1       |11          |
|9 |    └─JOIN FILTER USE                   |:RF0001 |1       |11          |
|10|      └─PX BLOCK HASH JOIN-FILTER       |:RF0000 |1       |11          |
|11|        └─TABLE FULL SCAN               |b       |1       |11          |
============================================================================
Outputs & filters:
-------------------------------------
  0 - output([INTERNAL_FUNCTION(a.c1, a.c2, a.c3, a.c4, b.c1, b.c2, b.c3, b.c4)]), filter(nil), rowset=16
  1 - output([INTERNAL_FUNCTION(a.c1, a.c2, a.c3, a.c4, b.c1, b.c2, b.c3, b.c4)]), filter(nil), rowset=16
      dop=2
  2 - output([a.c1], [b.c1], [a.c2], [a.c3], [a.c4], [b.c2], [b.c3], [b.c4]), filter(nil), rowset=16
      equal_conds([a.c1 = b.c1]), other_conds(nil)
  3 - output([a.c1], [a.c2], [a.c3], [a.c4]), filter(nil), rowset=16
      RF_TYPE(in, range, bloom), RF_EXPR[a.c1]
  4 - output([a.c1], [a.c2], [a.c3], [a.c4]), filter(nil), rowset=16
      RF_TYPE(bloom), RF_EXPR[calc_tablet_id(a.c1)]
  5 - output([a.c1], [a.c2], [a.c3], [a.c4]), filter(nil), rowset=16
  6 - output([a.c1], [a.c2], [a.c3], [a.c4]), filter(nil), rowset=16
      dop=2
  7 - output([a.c1], [a.c2], [a.c3], [a.c4]), filter(nil), rowset=16
  8 - output([a.c1], [a.c2], [a.c3], [a.c4]), filter(nil), rowset=16
      access([a.c1], [a.c2], [a.c3], [a.c4]), partitions(p[0-9])
      is_index_back=false, is_global_index=false, 
      range_key([a.__pk_increment]), range(MIN ; MAX)always true
  9 - output([b.c1], [b.c2], [b.c3], [b.c4]), filter(nil), rowset=16
 10 - output([b.c1], [b.c2], [b.c3], [b.c4]), filter(nil), rowset=16
 11 - output([b.c1], [b.c2], [b.c3], [b.c4]), filter([RF_IN_FILTER(b.c1)], [RF_RANGE_FILTER(b.c1)], [RF_BLOOM_FILTER(b.c1)]), rowset=16
      access([b.c1], [b.c2], [b.c3], [b.c4]), partitions(p[0-9])
      is_index_back=false, is_global_index=false, filter_before_indexback[false,false,false], 
      range_key([b.__pk_increment]), range(MIN ; MAX)always true
