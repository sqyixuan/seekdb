result_format: 4
drop table if exists t1;
create table t1(c1 int, c2 int, c3 int, c4 int);

explain outline select /*+parallel(2) */
    sum(c3) over(partition by c1 order by c2) w1,
    sum(c4) over(partition by c1 order by c2) w2,
    sum(c3 + c4) over(partition by c1 order by c2) w3 from t1;
Query Plan
=======================================================================
|ID|OPERATOR                           |NAME    |EST.ROWS|EST.TIME(us)|
-----------------------------------------------------------------------
|0 |PX COORDINATOR                     |        |1       |5           |
|1 |└─EXCHANGE OUT DISTR               |:EX10001|1       |5           |
|2 |  └─WINDOW FUNCTION                |        |1       |4           |
|3 |    └─SORT                         |        |1       |3           |
|4 |      └─EXCHANGE IN DISTR          |        |1       |3           |
|5 |        └─EXCHANGE OUT DISTR (HASH)|:EX10000|1       |2           |
|6 |          └─PX BLOCK ITERATOR      |        |1       |2           |
|7 |            └─TABLE FULL SCAN      |t1      |1       |2           |
=======================================================================
Outputs & filters:
-------------------------------------
  0 - output([INTERNAL_FUNCTION(T_FUN_SUM(t1.c3), T_FUN_SUM(t1.c4), T_FUN_SUM(t1.c3 + t1.c4))]), filter(nil), rowset=16
  1 - output([INTERNAL_FUNCTION(T_FUN_SUM(t1.c3), T_FUN_SUM(t1.c4), T_FUN_SUM(t1.c3 + t1.c4))]), filter(nil), rowset=16
      dop=2
  2 - output([T_FUN_SUM(t1.c3)], [T_FUN_SUM(t1.c4)], [T_FUN_SUM(t1.c3 + t1.c4)]), filter(nil), rowset=16
      win_expr(T_FUN_SUM(t1.c3)), partition_by([t1.c1]), order_by([t1.c2, ASC]), window_type(RANGE), upper(UNBOUNDED PRECEDING), lower(CURRENT ROW)
      win_expr(T_FUN_SUM(t1.c4)), partition_by([t1.c1]), order_by([t1.c2, ASC]), window_type(RANGE), upper(UNBOUNDED PRECEDING), lower(CURRENT ROW)
      win_expr(T_FUN_SUM(t1.c3 + t1.c4)), partition_by([t1.c1]), order_by([t1.c2, ASC]), window_type(RANGE), upper(UNBOUNDED PRECEDING), lower(CURRENT ROW)
  3 - output([t1.c3], [t1.c1], [t1.c2], [t1.c4]), filter(nil), rowset=16
      sort_keys([t1.c1, ASC], [t1.c2, ASC])
  4 - output([t1.c3], [t1.c1], [t1.c2], [t1.c4]), filter(nil), rowset=16
  5 - output([t1.c3], [t1.c1], [t1.c2], [t1.c4]), filter(nil), rowset=16
      (#keys=1, [t1.c1]), dop=2
  6 - output([t1.c3], [t1.c1], [t1.c2], [t1.c4]), filter(nil), rowset=16
  7 - output([t1.c3], [t1.c1], [t1.c2], [t1.c4]), filter(nil), rowset=16
      access([t1.c3], [t1.c1], [t1.c2], [t1.c4]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t1.__pk_increment]), range(MIN ; MAX)always true
