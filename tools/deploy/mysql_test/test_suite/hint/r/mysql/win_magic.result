      win_expr(T_FUN_SUM(t1.c1)), partition_by([t1.c2]), order_by(nil), window_type(RANGE), upper(UNBOUNDED PRECEDING), lower(UNBOUNDED FOLLOWING)
      win_expr(T_FUN_COUNT(t1.c1)), partition_by([t1.c2]), order_by(nil), window_type(RANGE), upper(UNBOUNDED PRECEDING), lower(UNBOUNDED FOLLOWING)
  2 - output([t1.pk], [t1.c1], [t1.c2], [t1.c3]), filter(nil), rowset=16
      sort_keys([t1.c2, ASC])
  3 - output([t1.pk], [t1.c1], [t1.c2], [t1.c3]), filter([t1.c2 IS NOT NULL]), rowset=16
      access([t1.pk], [t1.c1], [t1.c2], [t1.c3]), partitions(p0)
