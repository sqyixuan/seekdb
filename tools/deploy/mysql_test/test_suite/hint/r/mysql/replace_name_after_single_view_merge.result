result_format: 4
explain_protocol: 1
drop table if exists t1, t2;
create table t1(c1 int, c2 int, c3 int, c4 int, unique index idx(c1));
create table t2(c1 int, c2 int, c3 int, c4 int);

## 1. index hint
EXPLAIN BASIC select /*+index(v idx)*/ * from (select * from t1) v;
