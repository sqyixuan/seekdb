EXPLAIN BASIC select /*+index(view1 idx)*/ * from t2 where c1 in (select c1 from t1);
Query Plan
================================
|ID|OPERATOR           |NAME   |
--------------------------------
|0 |MERGE JOIN         |       |
|1 |├─TABLE FULL SCAN  |t1(idx)|
|2 |└─SORT             |       |
|3 |  └─TABLE FULL SCAN|t2     |
================================
Outputs & filters:
-------------------------------------
  0 - output([t2.c1], [t2.c2], [t2.c3], [t2.c4]), filter(nil), rowset=16
      equal_conds([t2.c1 = t1.c1]), other_conds(nil)
      merge_directions([ASC])
  1 - output([t1.c1]), filter(nil), rowset=16
      access([t1.c1]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t1.c1], [t1.shadow_pk_0]), range(MIN,MIN ; MAX,MAX)always true
  2 - output([t2.c1], [t2.c2], [t2.c3], [t2.c4]), filter(nil), rowset=16
      sort_keys([t2.c1, ASC])
  3 - output([t2.c1], [t2.c2], [t2.c3], [t2.c4]), filter(nil), rowset=16
      access([t2.c1], [t2.c2], [t2.c3], [t2.c4]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t2.__pk_increment]), range(MIN ; MAX)always true
select /*+index(view1 idx)*/ * from t2 where c1 in (select c1 from t1);
