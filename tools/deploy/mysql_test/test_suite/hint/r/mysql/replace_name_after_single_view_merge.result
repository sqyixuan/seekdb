      access([t1.__pk_increment], [t1.c2], [t1.c1]), partitions(p0)
      is_index_back=true, is_global_index=false, 
      range_key([t1.c1], [t1.shadow_pk_0]), range(MIN,MIN ; MAX,MAX)always true
select /*+index(v idx)*/ * from (select c2, min(c1) from t1 group by c2) v;
