result_format: 4
drop table if exists t1, tp1;
drop table if exists t2, t3, t4;
create table t1(c1 int, c2 int, c3 int);
create table tp1(c1 int, c2 int, c3 int) partition by hash(c1) partitions 10;
create table t2 (c1 int primary key, c2 int, c3 int, c4 int) ;
create table t3 (c1 int primary key, c2 int, c3 int, c4 int) ;
create table t4 (c1 int primary key, c2 int, c3 int, c4 int) ;

