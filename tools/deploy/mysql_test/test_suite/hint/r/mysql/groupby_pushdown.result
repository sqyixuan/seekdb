      equal_conds([VIEW1.l.TEN = r.TEN]), other_conds(nil)
      merge_directions([ASC])
  2 - output([VIEW1.l.TEN], [VIEW1.T_FUN_MIN(l.THOUSAND)], [VIEW1.T_FUN_MAX(l.THOUSAND)]), filter(nil), rowset=256
      sort_keys([VIEW1.l.TEN, ASC])
