drop table if exists t1, t2, t3, part, lineitem;
create table t1 ( pk int ,c1 int not null, c2 int ,c3 int, primary key(pk));
create table t2 ( pk int ,c1 int not null, c2 int ,c3 int, primary key(pk));
create table t3 ( pk int ,c1 int not null, c2 int ,c3 int, primary key(pk));
explain outline
select c2, c3 from t1 where c2 is null
intersect
select c2, c3 from t2;
Query Plan
=======================================================
|ID|OPERATOR               |NAME|EST.ROWS|EST.TIME(us)|
-------------------------------------------------------
|0 |HASH INTERSECT DISTINCT|    |0       |5           |
|1 |├─TABLE FULL SCAN      |t1  |0       |3           |
|2 |└─TABLE FULL SCAN      |t2  |0       |3           |
=======================================================
Outputs & filters:
-------------------------------------
  0 - output([INTERSECT([1])], [INTERSECT([2])]), filter(nil), rowset=16
  1 - output([t1.c2], [t1.c3]), filter([t1.c2 IS NULL]), rowset=16
      access([t1.c2], [t1.c3]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([t1.pk]), range(MIN ; MAX)always true
  2 - output([t2.c2], [t2.c3]), filter([t2.c2 IS NULL]), rowset=16
      access([t2.c2], [t2.c3]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([t2.pk]), range(MIN ; MAX)always true
