drop table if exists t1,t2,t3,t4;
create table t1(c1 int, c2 int, c3 int);
create table t2(d1 int, d2 int, d3 int);
create table t3(e1 int, e2 int, e3 int);
create table t4(f1 int, f2 int, f3 int);
call dbms_stats.gather_table_stats(NULL, 't1');
call dbms_stats.gather_table_stats(NULL, 't2');
call dbms_stats.gather_table_stats(NULL, 't3');
call dbms_stats.gather_table_stats(NULL, 't4');
explain outline select * from t1 where t1.c1 > (select avg(d1) from t2 where t1.c2 = t2.d2);
Query Plan
======================================================
|ID|OPERATOR             |NAME |EST.ROWS|EST.TIME(us)|
------------------------------------------------------
|0 |HASH JOIN            |     |1       |5           |
|1 |├─SUBPLAN SCAN       |VIEW1|1       |3           |
|2 |│ └─HASH GROUP BY    |     |1       |3           |
|3 |│   └─TABLE FULL SCAN|t2   |1       |3           |
|4 |└─TABLE FULL SCAN    |t1   |1       |3           |
======================================================
Outputs & filters:
-------------------------------------
  0 - output([t1.c1], [t1.c2], [t1.c3]), filter(nil), rowset=16
      equal_conds([t1.c2 = VIEW1.t2.d2]), other_conds([cast(t1.c1, DECIMAL(11, 0)) > VIEW1.avg(d1)])
  1 - output([VIEW1.avg(d1)], [VIEW1.t2.d2]), filter(nil), rowset=16
      access([VIEW1.avg(d1)], [VIEW1.t2.d2])
  2 - output([cast(cast(T_FUN_SUM(t2.d1), DECIMAL_INT(65, 32)) / cast(T_FUN_COUNT(t2.d1), DECIMAL_INT(20, 0)), DECIMAL(15, 4))], [t2.d2]), filter(nil), rowset=16
      group([t2.d2]), agg_func([T_FUN_SUM(t2.d1)], [T_FUN_COUNT(t2.d1)])
  3 - output([t2.d2], [t2.d1]), filter(nil), rowset=16
      access([t2.d2], [t2.d1]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t2.__pk_increment]), range(MIN ; MAX)always true
  4 - output([t1.c2], [t1.c1], [t1.c3]), filter(nil), rowset=16
      access([t1.c2], [t1.c1], [t1.c3]), partitions(p0)
      is_index_back=false, is_global_index=false, 
      range_key([t1.__pk_increment]), range(MIN ; MAX)always true
Outline Data: 
-------------------------------------
