result_format: 4
drop table if exists t1, t2;
create table t1(c1 int primary key, c2 int, c3 int, c4 int)
partition by hash(c1) partitions 10;
create table t2(c1 int primary key, c2 int, c3 int, c4 int);

explain outline
select (select c1 from t1 where c1 = t_a.c3) a
from t1 t_a order by (select a from t1 where c1 = t_a.c3);
Query Plan
=======================================================================
|ID|OPERATOR                           |NAME    |EST.ROWS|EST.TIME(us)|
-----------------------------------------------------------------------
|0 |PX COORDINATOR MERGE SORT          |        |1       |355         |
|1 |└─EXCHANGE OUT DISTR               |:EX10001|1       |355         |
|2 |  └─SORT                           |        |1       |354         |
|3 |    └─SUBPLAN FILTER               |        |1       |354         |
|4 |      ├─EXCHANGE IN DISTR          |        |1       |175         |
|5 |      │ └─EXCHANGE OUT DISTR (PKEY)|:EX10000|1       |175         |
|6 |      │   └─SUBPLAN FILTER         |        |1       |175         |
|7 |      │     ├─PX PARTITION ITERATOR|        |1       |22          |
|8 |      │     │ └─TABLE FULL SCAN    |t_a     |1       |22          |
|9 |      │     └─DISTRIBUTED TABLE GET|t1      |1       |154         |
|10|      └─PX PARTITION ITERATOR      |        |1       |180         |
|11|        └─TABLE GET                |t1      |1       |180         |
=======================================================================
