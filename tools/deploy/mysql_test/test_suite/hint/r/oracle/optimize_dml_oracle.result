result_format: 4
drop table t1;
drop table t2;
drop table tp;
create table t1(c1 int, c2 int, c3 int, c4 int);
create table t2(c1 int, c2 int, c3 int, c4 int);
create table tp(c1 int, c2 int, c3 int, c4 int) partition by hash(c1) partitions 10;

