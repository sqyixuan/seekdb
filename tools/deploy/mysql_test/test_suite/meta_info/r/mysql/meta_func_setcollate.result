drop table if exists sb;
create table sb(a varchar(10) collate utf8mb4_general_ci, b binary(10), c varchar(10) collate utf8mb4_bin);
insert into sb values("hello","world","bar");
select a collate utf8mb4_bin from sb;
Catalog	Database	Table	Table_alias	Column	Column_alias	Type	Length	Max length	Is_null	Flags	Decimals	Charsetnr
def					a collate utf8mb4_bin	253	40	5	Y	128	0	45
a collate utf8mb4_bin
hello
select c collate utf8mb4_general_ci from sb;
Catalog	Database	Table	Table_alias	Column	Column_alias	Type	Length	Max length	Is_null	Flags	Decimals	Charsetnr
def					c collate utf8mb4_general_ci	253	40	3	Y	0	0	45
c collate utf8mb4_general_ci
bar
drop table sb;
