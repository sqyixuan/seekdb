set GLOBAL ob_query_timeout = 1000000000000;
set GLOBAL ob_trx_timeout = 10000000000000;
set GLOBAL ob_trx_idle_timeout = 10000000000;
drop table if exists t_range_hash1;
drop table if exists t_range_columns_hash2;
drop table if exists t_list_hash3;
drop table if exists t_list_columns_hash4;
drop table if exists t_hash_range;
alter system set _ob_enable_truncate_partition_preserve_global_index = true;
create table t_range_hash1(c1 int, c2 int, c3 int, c4 int, primary key(c1, c2))
partition by range(c1)
subpartition by hash(c2) subpartitions 2
(
partition p0 values less than (10),
partition p1 values less than (20),
partition p2 values less than (30),
partition p3 values less than (MAXVALUE)
);
create index i1 on t_range_hash1(c3) global;
create unique index i2 on t_range_hash1(c2) global;
insert into t_range_hash1 values (1, 1, 1, 1), (1, 100, 1, 2), (1, 1000, 1, 3);
insert into t_range_hash1 values (10, 2, 2, 1), (10, 200, 2, 2), (10, 2000, 2, 3);
insert into t_range_hash1 values (20, 3, 3, 1), (20, 300, 3, 2), (30, 3000, 3, 3);
alter table t_range_hash1 truncate partition p0, p3;
###print part info after truncate###
select/*+index(t_range_hash1 idx1)*/ c1,c2,c3 from t_range_hash1 order by c1, c2, c3 asc;
c1	c2	c3
10	2	2
10	200	2
10	2000	2
20	3	3
20	300	3
create table t_range_columns_hash2(c1 int, c2 int, c3 int, c4 int, primary key(c1, c2, c3, c4))
partition by range columns(c1, c3)
subpartition by hash(c2) subpartitions 2
(
partition p0 values less than (10, 10),
partition p1 values less than (20, 20),
partition p2 values less than (30, 30),
partition p3 values less than (MAXVALUE, MAXVALUE)
);
create index i1 on t_range_columns_hash2(c3) global;
create unique index i2 on t_range_columns_hash2(c2) global;
insert into t_range_columns_hash2 values (1, 1, 1, 1), (1, 100, 1, 2), (1, 1000, 1, 3);
insert into t_range_columns_hash2 values (10, 2, 2, 1), (10, 200, 2, 2), (10, 2000, 2, 3);
insert into t_range_columns_hash2 values (20, 3, 3, 1), (20, 300, 3, 2), (30, 3000, 3, 3);
alter table t_range_columns_hash2 truncate partition p0, p1;
select/*+index(t_range_columns_hash2 idx1)*/ c1,c2,c3 from t_range_columns_hash2 order by c1, c2, c3 asc;
c1	c2	c3
30	3000	3
create table t_list_hash3(c1 int, c2 int, c3 int, c4 int, primary key(c1, c2))
partition by list(c2)
subpartition by hash(c1) subpartitions 2
(
partition p0 values in (100, 200, 300),
partition p1 values in (400),
partition p2 values in (500),
partition p3 values in (DEFAULT)
);
create index i1 on t_list_hash3(c3) global;
create unique index i2 on t_list_hash3(c2) global;
insert into t_list_hash3 values (1, 1, 1, 1), (1, 100, 1, 2), (1, 1000, 1, 3);
insert into t_list_hash3 values (10, 2, 2, 1), (10, 200, 2, 2), (10, 2000, 2, 3);
insert into t_list_hash3 values (20, 3, 3, 1), (20, 300, 3, 2), (20, 3000, 3, 3);
alter table t_list_hash3 truncate partition p0, p1;
###print part info after truncate###
select/*+index(t_list_hash3 idx1)*/ c1,c2,c3 from t_list_hash3 order by c1, c2, c3 asc;
c1	c2	c3
1	1	1
1	1000	1
10	2	2
10	2000	2
20	3	3
20	3000	3
create table t_list_columns_hash4(c1 int, c2 int, c3 int, c4 int, primary key(c1, c2, c3))
partition by list columns(c2, c3)
subpartition by hash(c1) subpartitions 2
(
partition p0 values in ((100, 1), (200, 2), (300, 3)),
partition p1 values in ((400, 4)),
partition p2 values in ((500, 5)),
partition p3 values in (DEFAULT)
);
create index i1 on t_list_columns_hash4(c3) global;
create unique index i2 on t_list_columns_hash4(c2) global;
insert into t_list_columns_hash4 values (1, 1, 1, 1), (1, 100, 1, 2), (1, 1000, 1, 3);
insert into t_list_columns_hash4 values (10, 2, 2, 1), (10, 200, 2, 2), (10, 2000, 2, 3);
insert into t_list_columns_hash4 values (20, 3, 3, 1), (20, 300, 3, 2), (20, 3000, 3, 3);
alter table t_list_columns_hash4 truncate partition p1, p3;
###print part info after truncate###
select/*+index(t_list_columns_hash4 i1)*/ c1,c2,c3 from t_list_columns_hash4 order by c1, c2, c3 asc;
c1	c2	c3
1	100	1
10	200	2
20	300	3
CREATE TABLE t_hash_range (
order_id INT NOT NULL,
user_id INT NOT NULL,
order_year int NOT NULL,
amount DECIMAL(10,2)
) PARTITION BY HASH(user_id) PARTITIONS 4
SUBPARTITION BY RANGE (order_year)
SUBPARTITION TEMPLATE (
SUBPARTITION yr2023 VALUES LESS THAN (2023),
SUBPARTITION yr2024 VALUES LESS THAN (2024),
SUBPARTITION yr2025 VALUES LESS THAN (2026)
);
create index idx1 on t_hash_range(order_year) global;
alter table t_hash_range truncate partition p0;
ERROR 0A000: Drop hash partition not supported
alter table t_hash_range truncate subpartition p0syr2023;
alter system major freeze;
drop table t_range_hash1;
drop table t_range_columns_hash2;
drop table t_list_hash3;
drop table t_list_columns_hash4;
