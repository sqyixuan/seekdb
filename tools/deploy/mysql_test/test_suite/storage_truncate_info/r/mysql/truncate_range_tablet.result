drop table if exists t_range_int;
drop table if exists t_range_expr;
###############################
# create table t_range_int
###############################
alter system set _ob_enable_truncate_partition_preserve_global_index = true;
create table t_range_int(c1 int, c2 int, primary key(c1, c2)) partition by range(c2)
(partition p0 values less than (100),
partition p1 values less than (200),
partition p2 values less than (300),
partition p3 values less than (400),
partition p4 values less than (MAXVALUE));
create index idx1 on t_range_int(c2) global partition by hash(c2) partitions 2;
create unique index idx2 on t_range_int(c1) global partition by hash(c1) partitions 3;
insert into t_range_int values(1, 1), (100, 100), (200, 200), (300, 300), (400, 400);
alter table t_range_int truncate partition p1, p2, p4;
###print part info after truncate t_range_int###
select * from t_range_int order by c1,c2 asc;
c1	c2
1	1
300	300
alter table t_range_int truncate partition p0,p1,p2,p3,p4;
select * from t_range_int order by c1,c2 asc;
c1	c2
###############################
# create table t_range_expr
###############################
create table t_range_expr(c1 int, c2 int, c3 int, c4 int, primary key(c1, c2, c3))
partition by range(c1)
subpartition by range(c2 + c3)
(
partition p0 values less than (10)
(
subpartition p0sp0 values less than (100),
subpartition p0sp1 values less than (200),
subpartition p0sp2 values less than (MAXVALUE)
),
partition p1 values less than (20)
(
subpartition p1sp0 values less than (100),
subpartition p1sp1 values less than (200),
subpartition p1sp2 values less than (MAXVALUE)
),
partition p2 values less than (MAXVALUE)
(
subpartition p2sp0 values less than (100),
subpartition p2sp1 values less than (200),
subpartition p2sp2 values less than (MAXVALUE)
)
);
create index i1 on t_range_expr(c3) global;
create unique index i2 on t_range_expr(c2) global;
insert into t_range_expr values(1, 1, 1, 1), (10, 100, 100, 100), (20, 200, 200, 200), (40, 400, 400, 400);
alter table t_range_expr truncate partition p1, p2;
###print part info after truncate t_range_expr###
select * from t_range_expr order by c1,c2,c3,c4 asc;
c1	c2	c3	c4
1	1	1	1
###############################
# major merge
###############################
alter system major freeze;
select * from t_range_int order by c1,c2 asc;
c1	c2
drop table t_range_int;
drop table t_range_expr;
