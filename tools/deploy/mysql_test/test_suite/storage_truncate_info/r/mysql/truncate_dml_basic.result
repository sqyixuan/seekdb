alter system set _enable_defensive_check = 2;
set session ob_query_timeout=1000000000;
drop table if exists t_range1,t_list1,t1;
alter system set _ob_enable_truncate_partition_preserve_global_index = true;
CREATE TABLE `t_range1` (
`c1` int(11) NOT NULL,
`c2` int(11) NOT NULL,
`c3` int(11) DEFAULT NULL,
`c4` int(11) DEFAULT NULL,
PRIMARY KEY (`c1`, `c2`)
)partition by range(c2)
(partition `p0` values less than (10),
partition `p1` values less than (100),
partition `p2` values less than (MAXVALUE));
CREATE TABLE `t_list1` (
`c1` int(11) NOT NULL,
`c2` int(11) NOT NULL,
`c3` int(11) DEFAULT NULL,
`c4` int(11) DEFAULT NULL,
PRIMARY KEY (`c1`, `c2`)
) partition by list(c2)
(partition `p1` values in (2,3),
partition `p0` values in (1),
partition `p2` values in (DEFAULT));
create index t_range1_idx on t_range1(c3) global;
create unique index t_range1_idx_uni on t_range1(c3) global;
create index t_list1_idx on t_list1(c3) global;
create unique index t_list1_idx_uni on t_list1(c3) global;
create table t1(c1 int, c2 int, c3 int, c4 int, primary key(c1,c2)) partition by list(c2) (partition p0 values in (0), partition p1 values in (1));
create unique index t1_g1 on t1(c3) global;
insert into t1 values(0,1,2,3);
insert into t1 values(1,0,3,4);
delete from t1 where c1 = 0;
