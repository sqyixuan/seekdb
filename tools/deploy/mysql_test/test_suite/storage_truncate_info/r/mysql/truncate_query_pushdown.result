set session ob_query_timeout=1000000000;
drop table if exists t0,t1,t2,t3,t4,t_range2,tx1;
alter system set _ob_enable_truncate_partition_preserve_global_index = true;
create table t0(c1 int);
create table t1(c1 int, c2 int, c3 varchar(20), c4 varchar(40), c5 int,c6 int, primary key (c3,c1,c6)) partition by list(c6) (partition p0 values in (2000,2010), partition p1 values in (2020),partition p2 values in (DEFAULT));
create table t2(c1 int, c2 int, c3 varchar(20), c4 varchar(40), c5 int,c6 int, primary key (c3,c1,c6)) partition by range(c6) (partition p0 values less than (2000), partition p1 values less than (3000),partition p2 values less than (MAXVALUE));
create table t3(c1 int, c2 int, c3 varchar(20), c4 varchar(40), c5 int,c6 int, primary key (c3,c1,c6)) partition by list columns(c1,c6) (partition p0 values in ((2000,2000),(2010,2010)), partition p1 values in ((2020,2020)),partition p2 values in (DEFAULT));
create table t4(c1 int, c2 int, c3 varchar(20), c4 varchar(40), c5 int,c6 int, primary key (c3,c1,c6)) partition by range columns(c1,c6) (partition p0 values less than (2000,2000), partition p1 values less than (3000,3000),partition p2 values less than (MAXVALUE,MAXVALUE));
CREATE TABLE `t_range2` (
`c1` int(11) NOT NULL,
`c2` int(11) NOT NULL,
`c3` int(11) DEFAULT NULL,
`c4` int(11) DEFAULT NULL,
PRIMARY KEY (`c1`, `c2`)
)partition by range(c2)
(partition `p0` values less than (2000),
partition `p1` values less than (4000),
partition `p2` values less than (MAXVALUE));
create index t1_g1 on t1(c2) global partition by hash(c2) partitions 2;
create index t2_g1 on t2(c2) global partition by hash(c2) partitions 3;
create index t3_g1 on t3(c2) global partition by hash(c2) partitions 3;
create index t4_g1 on t4(c2) global partition by hash(c2) partitions 3;
create index t_range2_idx on t_range2(c3) global;
insert into t1 select c1,c1,concat('abcdef',c1),concat(c1,'abcdef'),c1,2000 from t0 limit 1000 offset 0;
insert into t1 select c1,c1,concat('abcdef',c1),concat(c1,'abcdef'),c1,2010 from t0 limit 1000 offset 1000;
insert into t1 select c1,c1,concat('abcdef',c1),concat(c1,'abcdef'),c1,2020 from t0 limit 1000 offset 2000;
insert into t1 select c1,c1,concat('abcdef',c1),concat(c1,'abcdef'),c1,2030 from t0 limit 1000 offset 3000;
insert into t2 select c1,c1,concat('abcdef',c1),concat(c1,'abcdef'),c1,1000 from t0 limit 1000 offset 0;
insert into t2 select c1,c1,concat('abcdef',c1),concat(c1,'abcdef'),c1,2000 from t0 limit 1000 offset 1000;
insert into t2 select c1,c1,concat('abcdef',c1),concat(c1,'abcdef'),c1,3000 from t0 limit 1000 offset 2000;
insert into t2 select c1,c1,concat('abcdef',c1),concat(c1,'abcdef'),c1,4000 from t0 limit 1000 offset 3000;
insert into t3 select c1,c1,concat('abcdef',c1),concat(c1,'abcdef'),c1,2000 from t0 limit 1000 offset 0;
insert into t3 select c1,c1,concat('abcdef',c1),concat(c1,'abcdef'),c1,2010 from t0 limit 1000 offset 1000;
insert into t3 select c1,c1,concat('abcdef',c1),concat(c1,'abcdef'),c1,2020 from t0 limit 1000 offset 2000;
insert into t3 select c1,c1,concat('abcdef',c1),concat(c1,'abcdef'),c1,2030 from t0 limit 1000 offset 3000;
insert into t4 select c1,c1,concat('abcdef',c1),concat(c1,'abcdef'),c1,1000 from t0 limit 1000 offset 0;
insert into t4 select c1,c1,concat('abcdef',c1),concat(c1,'abcdef'),c1,2000 from t0 limit 1000 offset 1000;
insert into t4 select c1,c1,concat('abcdef',c1),concat(c1,'abcdef'),c1,3000 from t0 limit 1000 offset 2000;
insert into t4 select c1,c1,concat('abcdef',c1),concat(c1,'abcdef'),c1,4000 from t0 limit 1000 offset 3000;
insert into t_range2 select c1,c1,c1,c1 from t0;
alter table t1 truncate partition p1;
alter table t2 truncate partition p1;
alter table t3 truncate partition p1;
alter table t4 truncate partition p1;
alter table t_range2 truncate partition p0,p1,p2;
create unique index t1_uniq_g2 on t1(c3,c6) global partition by key(c3) partitions 3;
create unique index t2_uniq_g2 on t2(c3,c6) global partition by key(c3) partitions 3;
create unique index t3_uniq_g2 on t3(c3,c6) global partition by key(c3) partitions 3;
create unique index t4_uniq_g2 on t4(c3,c6) global partition by key(c3) partitions 3;
