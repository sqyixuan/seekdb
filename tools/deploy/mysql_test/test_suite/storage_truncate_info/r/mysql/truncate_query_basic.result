set session ob_query_timeout=1000000000;
drop table if exists t_range1,t_range2,t_list1,t_range_columns,t_list_columns,t1,ct1;
alter system set _ob_enable_truncate_partition_preserve_global_index = true;
CREATE TABLE `t_range1` (
`c1` int(11) NOT NULL,
`c2` int(11) NOT NULL,
`c3` int(11) DEFAULT NULL,
PRIMARY KEY (`c1`, `c2`)
)partition by range(c2)
(partition `p0` values less than (10),
partition `p1` values less than (100),
partition `p2` values less than (MAXVALUE));
CREATE TABLE `t_list1` (
`c1` int(11) NOT NULL,
`c2` int(11) NOT NULL,
`c3` int(11) DEFAULT NULL,
PRIMARY KEY (`c1`, `c2`)
) partition by list(c2)
(partition `p1` values in (2,3),
partition `p0` values in (1),
partition `p2` values in (DEFAULT));
CREATE TABLE `t_range_columns` (
`c1` int(11) NOT NULL,
`c2` int(11) NOT NULL,
`c3` int(11) DEFAULT NULL,
PRIMARY KEY (`c1`, `c2`)
) partition by range columns(c1,c2)
(partition `p0` values less than (10,20),
partition `p1` values less than (100,200),
partition `p2` values less than (MAXVALUE,MAXVALUE));
CREATE TABLE `t_list_columns` (
`c1` int(11) NOT NULL,
`c2` int(11) NOT NULL,
`c3` int(11) DEFAULT NULL,
PRIMARY KEY (`c1`, `c2`)
) partition by list columns(c1,c2)
(partition `p0` values in ((1,1),(2,2)),
partition `p1` values in ((3,3)),
partition `p2` values in (DEFAULT));
CREATE TABLE `t1` (
`c1` int(11) NOT NULL,
`c2` int(11) DEFAULT NULL,
`c3` int(11) NOT NULL,
`c4` int(11) DEFAULT NULL,
`c5` int(11) DEFAULT NULL,
`c6` int(11) GENERATED ALWAYS AS ((`c1` + `c2`)) VIRTUAL,
`c7` int(11) GENERATED ALWAYS AS ((`c2` * `c3`)) STORED,
PRIMARY KEY (`c1`, `c3`),
UNIQUE KEY `t1_uniq_g2` (`c5`) STORING (`c4`) BLOCK_SIZE 16384 GLOBAL,
KEY `t1_g1` (`c4`) STORING (`c5`) BLOCK_SIZE 16384 GLOBAL,
KEY `t1_g3` (`c6`) BLOCK_SIZE 16384 GLOBAL,
KEY `t1_g4` (`c7`) STORING (`c6`) BLOCK_SIZE 16384 GLOBAL
) partition by list(c3)
(partition `p0` values in (2024),
partition `p1` values in (2025),
partition `p2` values in (DEFAULT));
create table ct1(c1 int, c2 int, c3 varchar(20), c4 varchar(40), c5 int,c6 int, primary key (c3,c1,c6)) partition by list(c6) (partition p0 values in (2000,2010), partition p1 values in (2020),partition p2 values in (DEFAULT)) with column group(each column);
create unique index ct1_uniq_g1 on ct1(c3,c6) global partition by key(c3) partitions 3;
create unique index ct1_uniq_g2 on ct1(c3,c6) global partition by key(c3) partitions 3 with column group(each column);
create index t_range1_idx on t_range1(c2) global;
create index t_list1_idx on t_list1(c2) global;
create index t_range_columns_idx on t_range_columns(c2) global;
create index t_list_columns_idx on t_list_columns(c2) global;
