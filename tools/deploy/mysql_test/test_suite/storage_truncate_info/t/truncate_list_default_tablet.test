# owner: lixia.yq
# owner group: storage
# description: 本case是为了测试基础的truncate list default分区行为

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn0,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,oceanbase,$OBMYSQL_PORT);

connection conn1;
--disable_warnings
drop table if exists t_list_default;
--enable_warnings

--echo ###############################
--echo # create table t_list_default
--echo ###############################
connection conn1;
alter system set _ob_enable_truncate_partition_preserve_global_index = true;
create table t_list_default (
  c1 varchar(400) default 'AaBbcCd1234',
  c2 mediumint default 2,
  c3 int auto_increment,
  c4 blob default null,
  c5 varchar(400) default 'aEFGHI01',
  c6 int(255) default 01,
  primary key (c3, c2)
) partition by list(c3) subpartition by list(c2) (
  partition p_list0 values in (100) (
    subpartition p_list0_list0 values in (10),
    subpartition p_list0_list1 values in (20),
    subpartition p_list0_list2 values in (default)
  ),
  partition p_list1 values in (500) (
    subpartition p_list1_list0 values in (30),
    subpartition p_list1_list1 values in (40),
    subpartition p_list1_list2 values in (default)
  ),
  partition p_list2 values in (default) (
    subpartition p_list2_list2 values in (default)
  )
);
create index idx1 on t_list_default(c3) global partition by hash(c3) partitions 2;
create unique index idx2 on t_list_default(c2) global partition by hash(c2) partitions 3;

connection conn1;
insert into t_list_default(c2,c3) values(10, 100), (20, 100), (30, 100), (50, 200), (40, 500), (300, 800);

select/*+index(t_list_default idx1)*/ c2,c3 from t_list_default order by c2,c3 asc;
select/*+index(t_list_default idx2)*/ c2,c3 from t_list_default order by c2,c3 asc;

alter table t_list_default truncate partition p_list2;
alter table t_list_default truncate subpartition p_list2_list2;

select/*+index(t_list_default idx1)*/ c2,c3 from t_list_default order by c2,c3 asc;
select/*+index(t_list_default idx2)*/ c2,c3 from t_list_default order by c2,c3 asc;

--echo ###############################
--echo # drop partition
--echo ###############################

connection conn1;
alter table t_list_default drop subpartition p_list0_list0;
alter table t_list_default drop subpartition p_list0_list1;
alter table t_list_default truncate subpartition p_list0_list2;

alter table t_list_default drop partition p_list0;
alter table t_list_default drop partition p_list1;
alter table t_list_default truncate partition p_list2;
alter table t_list_default truncate subpartition p_list2_list2;

select/*+index(t_list_default idx1)*/ c2,c3 from t_list_default order by c2,c3 asc;
select/*+index(t_list_default idx2)*/ c2,c3 from t_list_default order by c2,c3 asc;

connection conn1;
drop table t_list_default;