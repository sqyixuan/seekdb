select/*+index(t_list1 t_list1_idx)*/ c1,c2 from t_list1 where c1 > -1;
select/*+index(t_list1 t_list1_idx)*/ c1,c2 from t_list1 where c1 > 0;
select/*+index(t_list1 t_list1_idx)*/ c1,c2 from t_list1 where c1 > 2;
select/*+index(t_list1 t_list1_idx)*/ c1,c2 from t_list1 where c1 > 3;
select/*+index(t_list1 t_list1_idx)*/ c1,c2 from t_list1 where c1 > 4;

alter table t_list2 truncate partition p0;
alter table t_range_list1 truncate partition p_range0;
alter table t_range_list1 truncate subpartition p_range1_list0;
alter table t_list_range1 truncate partition p_list0;
alter table t_list_range1 truncate subpartition p_list_range1;
alter table t_list_list1 truncate partition p_list0;
alter table t_list_list1 truncate subpartition p_list0_list0;
alter table t_list_list2 truncate partition p_list0;
alter table t_list_list2 truncate subpartition p_list1_list0;
select/*+index(t_list2 t_list2_idx)*/ * from t_list2;
select/*+index(t_range_list1 t_range_list1_idx)*/ * from t_range_list1;
select/*+index(t_list_range1 t_list_range1_idx)*/ * from t_list_range1;
