# owner: yht146439
# owner group: storage
# description: basic query with truncate info

--disable_warnings
set session ob_query_timeout=1000000000;
drop table if exists t_range1,t_list1,t_list2,t_range_list1,t_list_range1,t_list_list1,t_list_list2;
--enable_warnings
alter system set _ob_enable_truncate_partition_preserve_global_index = true;
CREATE TABLE `t_range1` (
  `c1` int(11) NOT NULL,
  `c2` int(11) NOT NULL,
  `c3` int(11) DEFAULT NULL,
  PRIMARY KEY (`c1`, `c2`)
)partition by range(c2)
(partition `p0` values less than (10),
partition `p1` values less than (100),
partition `p2` values less than (MAXVALUE));

CREATE TABLE `t_list1` (
  `c1` int(11) NOT NULL,
  `c2` int(11) NOT NULL,
  `c3` int(11) DEFAULT NULL,
  PRIMARY KEY (`c1`, `c2`)
) partition by list(c2)
(partition `p1` values in (2,3),
partition `p0` values in (1),
partition `p2` values in (DEFAULT));

create table t_list2 (c1 int, c2 int, c3 int, primary key (c1,c2)) partition by list(c2) (partition p0 values in (default));
create table t_range_list1(c1 int, c2 int, c3 int, c4 int, primary key (c1,c2,c3)) partition by range(c2) subpartition by list(c3)
(
  partition p_range0 values less than(10) (
    subpartition p_range0_list0 values in (1),
    subpartition p_range0_list1 values in (default)
  ),
  partition p_range1 values less than(MAXVALUE) (
    subpartition p_range1_list0 values in (default)
  )
);
create table t_list_range1(c1 int, c2 int, c3 int, c4 int, primary key (c1,c2,c3)) partition by list(c2) subpartition by range(c3)
(
  partition p_list0 values in (default) (
    subpartition p_list_range0 values less than(10),
    subpartition p_list_range1 values less than(MAXVALUE)
  )
);
create table t_list_list1(c1 int, c2 int, c3 int, c4 int, primary key (c1,c2,c3)) partition by list(c2) subpartition by list(c3)
(
  partition p_list0 values in (default) (
    subpartition p_list0_list0 values in (default)
  )
);
create table t_list_list2(c1 int, c2 int, c3 int, c4 int, primary key (c1,c2,c3)) partition by list(c2) subpartition by list(c3)
(
  partition p_list0 values in (1) (
    subpartition p_list0_list0 values in (default)
  ),
  partition p_list1 values in (2) (
    subpartition p_list1_list0 values in (1),
    subpartition p_list1_list1 values in (default)
  )
);

create index t_range1_idx on t_range1(c2) global partition by hash(c2) partitions 4;
create index t_list1_idx on t_list1(c2) global partition by hash(c2) partitions 4;
create index t_list2_idx on t_list2(c3) global partition by hash(c3) partitions 3;
create index t_range_list1_idx on t_range_list1(c3) global partition by hash(c3) partitions 4;
create index t_list_range1_idx on t_list_range1(c3) global partition by hash(c3) partitions 4;
create index t_list_list1_idx on t_list_list1(c4) global partition by hash(c4) partitions 5;
create index t_list_list2_idx on t_list_list2(c4) global partition by hash(c4) partitions 5;

insert into t_range1 values(0,0,0),(1,1,1),(10,10,10),(11,11,11),(110,110,110),(111,111,111);
insert into t_list1 values(0,0,0),(1,1,1),(2,2,2),(3,3,3),(4,4,4);
insert into t_list2 values(0,0,0),(1,1,1),(2,2,2),(3,3,3),(4,4,4);
insert into t_range_list1 values(0,0,0,0),(1,1,1,1),(10,10,10,10),(11,11,11,11),(110,110,110,110),(111,111,111,111);
insert into t_list_range1 values(0,0,0,0),(1,1,1,1),(10,10,10,10),(11,11,11,11),(110,110,110,110),(111,111,111,111);
insert into t_list_list1 values(1,1,1,1),(2,2,2,2);
insert into t_list_list2 values(1,1,1,1),(2,2,2,2);

--enable_sorted_result
select/*+index(t_range1 t_range1_idx)*/ * from t_range1;
select/*+index(t_range1 t_range1_idx)*/ c2 from t_range1;
select/*+index(t_range1 t_range1_idx)*/ c1,c2 from t_range1 where c1 > 0;
select/*+index(t_range1 t_range1_idx)*/ c1,c2 from t_range1 where c1 > 10;
select/*+index(t_range1 t_range1_idx)*/ c1,c2 from t_range1 where c1 > 110;
select/*+index(t_range1 t_range1_idx)*/ c1,c2 from t_range1 where c1 > 111;

