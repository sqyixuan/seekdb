select/*+index(t_list1 t_list1_idx)*/ c1,c2 from t_list1 where c1 > -1;
select/*+index(t_list1 t_list1_idx)*/ c1,c2 from t_list1 where c1 > 0;
select/*+index(t_list1 t_list1_idx)*/ c1,c2 from t_list1 where c1 > 2;
