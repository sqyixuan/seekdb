alter table t_range_columns truncate partition p0,p1;
select/*+index(t_range_columns primary)*/ count(*) from t_range_columns;
select/*+index(t_range_columns t_range_columns_idx)*/ count(*) from t_range_columns;
select/*+index(t_range_columns primary)*/ * from t_range_columns where c2 is null;
select/*+index(t_range_columns t_range_columns_idx)*/ * from t_range_columns where c2 is null;

alter table t_range_columns truncate partition p2;
select/*+index(t_range_columns primary)*/ count(*) from t_range_columns;
select/*+index(t_range_columns t_range_columns_idx)*/ count(*) from t_range_columns;

alter table t_list_columns1 truncate partition p2;
select/*+index(t_list_columns1 primary)*/ count(*) from t_list_columns1;
select/*+index(t_list_columns1 t_list_columns1_idx)*/ count(*) from t_list_columns1;

alter table t_list_columns2 truncate partition p1;
