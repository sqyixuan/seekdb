select/*+index(t_list_columns3 t_list_columns3_idx)*/ count(*) from t_list_columns3;
alter table t_list_columns3 truncate partition p0,p2;
select/*+index(t_list_columns3 t_list_columns3_idx)*/ count(*) from t_list_columns3;

alter system minor freeze;
--source mysql_test/include/wait_minor_merge.inc

