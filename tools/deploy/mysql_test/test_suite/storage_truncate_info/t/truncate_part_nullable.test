# owner: yht146439
# owner group: storage
# description: nullable part col with truncate info

--disable_warnings
set session ob_query_timeout=1000000000;
drop table if exists t_range1,t_list1,t_list2,t_range_columns,t_list_columns1,t_list_columns2,t_list_columns3;
--enable_warnings
alter system set _ob_enable_truncate_partition_preserve_global_index = true;
CREATE TABLE `t_range1` (
  `c1` int(11) DEFAULT NULL,
  `c2` int(11) DEFAULT NULL,
  `c3` int(11) DEFAULT NULL
)partition by range(c2)
(partition `p0` values less than (10),
partition `p1` values less than (100),
partition `p2` values less than (MAXVALUE));

CREATE TABLE `t_list1` (
  `c1` int(11) DEFAULT NULL,
  `c2` int(11) DEFAULT NULL,
  `c3` int(11) DEFAULT NULL
) partition by list(c2)
(partition `p1` values in (2,3),
partition `p0` values in (1),
partition `p2` values in (null),
partition `p3` values in (DEFAULT));

CREATE TABLE `t_list2` (
  `c1` int(11) DEFAULT NULL,
  `c2` int(11) DEFAULT NULL,
  `c3` int(11) DEFAULT NULL
) partition by list(c2)
(partition `p1` values in (3),
partition `p0` values in (1,2,null),
partition `p2` values in (DEFAULT));

CREATE TABLE `t_range_columns` (
  `c1` int(11) DEFAULT NULL,
  `c2` int(11) DEFAULT NULL,
  `c3` int(11) DEFAULT NULL
) partition by range columns(c1,c2)
(partition `p0` values less than (10,20),
partition `p1` values less than (100,200),
partition `p2` values less than (MAXVALUE,MAXVALUE));

CREATE TABLE `t_list_columns1` (
  `c1` int(11) DEFAULT NULL,
  `c2` int(11) DEFAULT NULL,
  `c3` int(11) DEFAULT NULL
) partition by list columns(c1,c2)
(partition `p0` values in ((1,1),(2,2)),
partition `p1` values in ((3,3)),
partition `p2` values in (DEFAULT));

CREATE TABLE `t_list_columns2` (
  `c1` int(11) DEFAULT NULL,
  `c2` int(11) DEFAULT NULL,
  `c3` int(11) DEFAULT NULL
) partition by list columns(c1,c2)
(partition `p0` values in ((1,1),(2,2)),
partition `p1` values in ((null,null)),
partition `p2` values in (DEFAULT));

CREATE TABLE `t_list_columns3` (
  `c1` int(11) DEFAULT NULL,
  `c2` int(11) DEFAULT NULL,
  `c3` int(11) DEFAULT NULL
) partition by list columns(c1,c2)
(partition `p0` values in ((1,1),(2,2)),
partition `p1` values in ((3,3),(null,null)),
partition `p2` values in (DEFAULT));

create index t_range1_idx on t_range1(c2) global;
create unique index t_list1_idx on t_list1(c3) global;
create unique index t_list2_idx on t_list2(c3) global;
create unique index t_range_columns_idx on t_range_columns(c2) global;
create index t_list_columns1_idx on t_list_columns1(c2) global;
create unique index t_list_columns2_idx on t_list_columns2(c3) global;
create unique index t_list_columns3_idx on t_list_columns3(c3) global;

insert into t_range1 values(0,0,0),(1,1,1),(10,10,10),(11,11,11),(110,110,110),(111,111,111),(null,null,null),(null,null,null);
insert into t_list1 values(0,0,0),(1,1,1),(2,2,2),(3,3,3),(4,4,4),(null,null,null),(null,null,null);
insert into t_list2 values(0,0,0),(1,1,1),(2,2,2),(3,3,3),(4,4,4),(null,null,null),(null,null,null);

--disable_query_log
--let $count = 1
while($count < 151)
{
  --let $stmt1=insert into t_range_columns(c1,c2,c3) values ($count,$count,$count);
  --let $stmt2=insert into t_list_columns1(c1,c2,c3) values ($count%10,$count%10,$count);
  --let $stmt3=insert into t_list_columns2(c1,c2,c3) values ($count%10,$count%10,$count);
  --let $stmt4=insert into t_list_columns3(c1,c2,c3) values ($count%10,$count%10,$count);
  
  --let $stmt5=insert into t_range_columns(c1,c2,c3) values (null,null,null);
  --let $stmt6=insert into t_list_columns1(c1,c2,c3) values (null,null,null);
  --let $stmt7=insert into t_list_columns2(c1,c2,c3) values (null,null,null);
  --let $stmt8=insert into t_list_columns3(c1,c2,c3) values (null,null,null);
  
  eval $stmt1;
  eval $stmt2;
  eval $stmt3;
  eval $stmt4;

  eval $stmt5;
  eval $stmt6;
  eval $stmt7;
  eval $stmt8;
  inc $count;
}
--enable_query_log

--enable_sorted_result
alter table t_range1 truncate partition p0;
select/*+index(t_range1 primary)*/ c2 from t_range1;
select/*+index(t_range1 t_range1_idx)*/ c2 from t_range1;
select/*+index(t_range1 t_range1_idx)*/ c2 from t_range1 where c1 is null;

