# owner: lixia.yq
# owner group: storage
# description: 本case是为了测试基础的truncate list分区行为

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

connect (conn1,$OBMYSQL_MS0,$OBMYSQL_USR,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connect (conn0,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,oceanbase,$OBMYSQL_PORT);

connection conn1;
--disable_warnings
drop table if exists t_list_int;
--enable_warnings

--echo ###############################
--echo # create table t_list_int
--echo ###############################

connection conn1;
alter system set _ob_enable_truncate_partition_preserve_global_index = true;
create table t_list_int(c1 int, c2 int, primary key(c1, c2)) partition by list(c2) (
    partition p0 values in ((100)),
    partition p1 values in ((200), (300)),
    partition p2 values in ((400)),
    partition p3 values in ((500), (700)),
    partition p4 values in (DEFAULT));
create index idx1 on t_list_int(c2) global partition by hash(c2) partitions 2;
create unique index idx2 on t_list_int(c1) global partition by hash(c1) partitions 3;

connection conn1;
insert into t_list_int values(1, 1), (100, 100), (200, 200), (300, 300), (400, 400);

connection conn1;
# only remain (100, 100)
alter table t_list_int truncate partition p1,p2,p4;
--echo ###print part info after truncate###

connection conn1;
let $__table_name__ = 't_list_int';
let $__tenant_id__=query_get_value(select /*+QUERY_TIMEOUT(10000000)*/ tenant_id from oceanbase.__all_virtual_table where table_name= $__table_name__, tenant_id, 1);

alter system major freeze;

--source mysql_test/include/wait_daily_merge.inc
--source mysql_test/include/compaction/check_major_history_after_truncate.inc

connection conn1;
select/*+index(t_list_int idx1)*/ c1,c2 from t_list_int;
select/*+index(t_list_int idx2)*/ c1,c2 from t_list_int;

connection conn1;
insert into t_list_int values(50, 50), (300, 300), (400, 400);

connection conn1;
# only remain (50, 50), (100, 100), (300, 300)
alter table t_list_int truncate partition p1,p3;
--echo ###print part info after truncate###

connection conn1;
let $__table_name__ = 't_list_int';
let $__tenant_id__=query_get_value(select /*+QUERY_TIMEOUT(10000000)*/ tenant_id from oceanbase.__all_virtual_table where table_name= $__table_name__, tenant_id, 1);

alter system major freeze;

--source mysql_test/include/wait_daily_merge.inc
--source mysql_test/include/compaction/check_major_history_after_truncate.inc

connection conn1;
select/*+index(t_list_int idx1)*/ c1,c2 from t_list_int order by c1, c2 asc;
select/*+index(t_list_int idx2)*/ c1,c2 from t_list_int order by c1, c2 asc;

connection conn1;
alter table t_list_int truncate partition p0,p1,p2,p3,p4;

connection conn1;
select/*+index(t_list_int idx1)*/ c1,c2 from t_list_int order by c1, c2 asc;
select/*+index(t_list_int idx2)*/ c1,c2 from t_list_int order by c1, c2 asc;

connection conn1;
drop table t_list_int;