INSERT INTO t_double_range (c1) VALUES 
(-2.7976931348623157E308);
--error 1367
INSERT INTO t_double_range (c1) VALUES 
(-1.7976931348623157E310);
--error 1367
INSERT INTO t_double_range (c1) VALUES 
(2.7976931348623157E308);
--error 1367
INSERT INTO t_double_range (c1) VALUES 
(1.7976931348623157E310);

--error 1367
INSERT INTO t_double_range (c1) VALUES 
(-1.7976931348623159E308);
--error 1367
INSERT INTO t_double_range (c1) VALUES 
(1.7976931348623159E308);

INSERT INTO t_double_range (c1) VALUES 
(-1.7976931348623158E308);
INSERT INTO t_double_range (c1) VALUES 
(1.7976931348623158E308);
SELECT * FROM t_double_range PARTITION(p_neg_inf);
SELECT * FROM t_double_range PARTITION(p_min);
SELECT * FROM t_double_range PARTITION(p_zero);
SELECT * FROM t_double_range PARTITION(p_min_pos);
SELECT * FROM t_double_range PARTITION(p_max);
SELECT * FROM t_double_range PARTITION(p_pos_inf);

--echo ###  插入接近0但不等于0的极小正值和极小负值
INSERT INTO t_double_range (c1) VALUES 
(-1E-400), 
(1E-400);

SELECT * FROM t_double_range PARTITION(p_neg_inf);
SELECT * FROM t_double_range PARTITION(p_min);
SELECT * FROM t_double_range PARTITION(p_zero);
SELECT * FROM t_double_range PARTITION(p_min_pos);
SELECT * FROM t_double_range PARTITION(p_max);
SELECT * FROM t_double_range PARTITION(p_pos_inf);

--error 1265
INSERT INTO t_double_range (c1) VALUES 
('');
--error 1054
INSERT INTO t_double_range (c1) VALUES 
(NaN);
--error 1265
INSERT INTO t_double_range (c1) VALUES 
('NaN');

--echo ### double UNSIGNED、double ZEROFILL,预期不支持
--disable_warnings
DROP TABLE IF EXISTS t_double_range;
--enable_warnings
--error 1493
CREATE TABLE t_double_range (
    c1 DOUBLE UNSIGNED
) 
PARTITION BY RANGE COLUMNS(c1) (
    PARTITION p_neg_inf VALUES LESS THAN (-1.7976931348623157E308),
    PARTITION p_min VALUES LESS THAN (-2.2250738585072014E-308),
    PARTITION p_zero VALUES LESS THAN (0),
    PARTITION p_min_pos VALUES LESS THAN (2.2250738585072014E-308),
    PARTITION p_max VALUES LESS THAN (1.7976931348623157E308),
    PARTITION p_pos_inf VALUES LESS THAN MAXVALUE
);

--error 1493
CREATE TABLE t_double_range (
    c1 DOUBLE ZEROFILL
) 
PARTITION BY RANGE COLUMNS(c1) (
    PARTITION p_neg_inf VALUES LESS THAN (-1.7976931348623157E308),
    PARTITION p_min VALUES LESS THAN (-2.2250738585072014E-308),
    PARTITION p_zero VALUES LESS THAN (0),
    PARTITION p_min_pos VALUES LESS THAN (2.2250738585072014E-308),
    PARTITION p_max VALUES LESS THAN (1.7976931348623157E308),
    PARTITION p_pos_inf VALUES LESS THAN MAXVALUE
);

--echo ### 字段格式，DOUBLE(M,D)
--disable_warnings
DROP TABLE IF EXISTS t_double_range;
--enable_warnings

CREATE TABLE t_double_range (
    c1 DOUBLE(10,2)
) 
PARTITION BY RANGE COLUMNS(c1) (
    PARTITION p0 VALUES LESS THAN (0),
    PARTITION p1 VALUES LESS THAN (5.1),
    PARTITION p2 VALUES LESS THAN (10.1),
    PARTITION p3 VALUES LESS THAN (99999999.99),
    PARTITION p4 VALUES LESS THAN MAXVALUE
);

--error 1264
INSERT INTO t_double_range (c1) VALUES 
(-1.7976931348623157E308);
INSERT INTO t_double_range (c1) VALUES 
(-2.2250738585072014E-308), 
(2.2250738585072014E-308); 
INSERT INTO t_double_range (c1) VALUES 
(0),                     
(5.1),                   
(10.1),                  
(99999999.99);           

--error 1264
INSERT INTO t_double_range (c1) VALUES (1.7976931348623157E308);
--error 1264
INSERT INTO t_double_range (c1) VALUES (99999999.999);

SELECT * FROM t_double_range PARTITION (p0);
SELECT * FROM t_double_range PARTITION (p1);
SELECT * FROM t_double_range PARTITION (p2);
SELECT * FROM t_double_range PARTITION (p3);
SELECT * FROM t_double_range PARTITION (p4);

--disable_warnings
DROP TABLE IF EXISTS t_double_range;
--enable_warnings
CREATE TABLE t_double_range (
    c1 DOUBLE(15,0)
)
PARTITION BY RANGE COLUMNS(c1) (
    PARTITION p0 VALUES LESS THAN (0),
    PARTITION p1 VALUES LESS THAN (5),
    PARTITION p2 VALUES LESS THAN (10),
    PARTITION p3 VALUES LESS THAN (15),
    PARTITION p4 VALUES LESS THAN (999999999999999),
    PARTITION p5 VALUES LESS THAN MAXVALUE
);

--echo ###插入数据覆盖边界值
INSERT INTO t_double_range (c1) VALUES 
(0),                      
(-0),                     
(4.999),                  
(5),                      
(9.999),                  
(10),                     
(999999999999998),        
(999999999999999),        
(NULL);                   
--error 1264
INSERT INTO t_double_range (c1) VALUES 
(999999999999999 + 1);

SELECT c1 FROM t_double_range PARTITION (p0);
SELECT c1 FROM t_double_range PARTITION (p1);
SELECT c1 FROM t_double_range PARTITION (p2);
SELECT c1 FROM t_double_range PARTITION (p3);
SELECT c1 FROM t_double_range PARTITION (p4);
SELECT c1 FROM t_double_range PARTITION (p5);

--disable_warnings
DROP TABLE IF EXISTS t_double_range;
--enable_warnings

CREATE TABLE t_double_range (
    c1 DOUBLE(15,15)
)
PARTITION BY RANGE COLUMNS(c1) (
    PARTITION p0 VALUES LESS THAN (0),
    PARTITION p1 VALUES LESS THAN (5),
    PARTITION p2 VALUES LESS THAN (10),
    PARTITION p3 VALUES LESS THAN (15),
    PARTITION p4 VALUES LESS THAN MAXVALUE
);

INSERT INTO t_double_range (c1) VALUES 
(0),                       
(-0),                      
(0.55),          
(0.10),        
(NULL);                    

INSERT INTO t_double_range (c1) VALUES 
(0.999999999999999);

--error 1264
INSERT INTO t_double_range (c1) VALUES   
(4.99999999999999),
(999999999999999),           
(999999999999999 + 1);   

SELECT * FROM t_double_range PARTITION (p0);
SELECT * FROM t_double_range PARTITION (p1);
SELECT * FROM t_double_range PARTITION (p2);
SELECT * FROM t_double_range PARTITION (p3);
SELECT * FROM t_double_range PARTITION (p4);

--echo ###插入 INT, FLOAT, DECIMAL等类型数值
--disable_warnings
DROP TABLE IF EXISTS t_double_range;
--enable_warnings

CREATE TABLE t_double_range (
    c1 DOUBLE
) 
PARTITION BY RANGE COLUMNS(c1) (
    PARTITION p_neg_inf VALUES LESS THAN (-1.7976931348623157E308),
    PARTITION p_min VALUES LESS THAN (-2.2250738585072014E-308),
    PARTITION p_zero VALUES LESS THAN (0),
    PARTITION p_min_pos VALUES LESS THAN (2.2250738585072014E-308),
    PARTITION p_max VALUES LESS THAN (1.7976931348623157E308),
    PARTITION p_pos_inf VALUES LESS THAN MAXVALUE
);

INSERT INTO t_double_range (c1) VALUES 
(-1.7976931348623157E308), 
(-2.2250738585072014E-308),
(0),                       
(2.2250738585072014E-308), 
(1.7976931348623157E308),  
(NULL);                    

SELECT * FROM t_double_range PARTITION (p_neg_inf);
SELECT * FROM t_double_range PARTITION (p_min);
SELECT * FROM t_double_range PARTITION (p_zero);
SELECT * FROM t_double_range PARTITION (p_min_pos);
SELECT * FROM t_double_range PARTITION (p_max);
SELECT * FROM t_double_range PARTITION (p_pos_inf);

--echo ###尝试插入由其他数值类型转换而来的数值
INSERT INTO t_double_range (c1) VALUES 
(CAST(2.5 AS FLOAT)),     
(CAST(3.14159 AS DECIMAL(10,5))); 
INSERT INTO t_double_range (c1) VALUES 
(1);
SELECT * FROM t_double_range PARTITION (p_max);

--echo ###函数处理double数值

INSERT INTO t_double_range (c1) VALUES 
(ROUND(1.55)),      
(ROUND(1.55, 1)),   
(ROUND(-1.55)),     
(ROUND(-1.55, 1));  

INSERT INTO t_double_range (c1) VALUES 
(FLOOR(1.55)),   
(FLOOR(1.99)),   
(FLOOR(-1.55)),  
(FLOOR(-1.99));  

INSERT INTO t_double_range (c1) VALUES 
(CEIL(1.55)),     
(CEIL(1.01)),     
(CEIL(-1.55)),    
(CEILING(-1.01)); 

SELECT * FROM t_double_range PARTITION (p_neg_inf);
SELECT * FROM t_double_range PARTITION (p_min);
SELECT * FROM t_double_range PARTITION (p_zero);
SELECT * FROM t_double_range PARTITION (p_min_pos);
SELECT * FROM t_double_range PARTITION (p_max);
SELECT * FROM t_double_range PARTITION (p_pos_inf);

--echo ###其他类型。
INSERT INTO t_double_range (c1) VALUES 
(UNIX_TIMESTAMP('2022-01-01 00:00:00'));
INSERT INTO t_double_range (c1) VALUES 
(CAST('123.45' AS DOUBLE));

--error 1292
INSERT INTO t_double_range (c1) VALUES 
(CAST('not a number' AS DOUBLE));

SELECT * FROM t_double_range PARTITION (p_neg_inf);
SELECT * FROM t_double_range PARTITION (p_min);
SELECT * FROM t_double_range PARTITION (p_zero);
SELECT * FROM t_double_range PARTITION (p_min_pos);
SELECT * FROM t_double_range PARTITION (p_max);
SELECT * FROM t_double_range PARTITION (p_pos_inf);

--echo ###double同义词
--disable_warnings
DROP TABLE IF EXISTS t_double_range;
--enable_warnings

CREATE TABLE t_double_range (
    c1 DOUBLE PRECISION
) 
PARTITION BY RANGE COLUMNS(c1) (
    PARTITION p_neg_inf VALUES LESS THAN (-1.7976931348623157E308),
    PARTITION p_min VALUES LESS THAN (-2.2250738585072014E-308),
    PARTITION p_zero VALUES LESS THAN (0),
    PARTITION p_min_pos VALUES LESS THAN (2.2250738585072014E-308),
    PARTITION p_max VALUES LESS THAN (1.7976931348623157E308),
    PARTITION p_pos_inf VALUES LESS THAN MAXVALUE
);

INSERT INTO t_double_range (c1) VALUES 
(-1.7976931348623157E308), 
(-2.2250738585072014E-308),
(0),                       
(2.2250738585072014E-308), 
(1.7976931348623157E308),  
(NULL);                    

SELECT * FROM t_double_range PARTITION (p_neg_inf);
SELECT * FROM t_double_range PARTITION (p_min);
SELECT * FROM t_double_range PARTITION (p_zero);
SELECT * FROM t_double_range PARTITION (p_min_pos);
SELECT * FROM t_double_range PARTITION (p_max);
SELECT * FROM t_double_range PARTITION (p_pos_inf);

