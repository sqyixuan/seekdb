('2038-01-19 03:14:06'),
(NOW()),
(CURDATE()),
(FROM_UNIXTIME(UNIX_TIMESTAMP())),
('2024-01-01'),
('2024-01-01 12:00:00'),
('2024-02-01 12:34:56'),
('2024-04-01'),
('2024-04-01 12:00:00'),
('2024-04-01 12:00:00.000000'),
('2024-07-01 12:00:00'),
('2024-08-01 12:00:00'),
('2024-08-01'),
('2024-09-01 12:00:00'),
('2024-10-01 12:00:00'),
('2024-12-01 12:00:00');

SELECT * FROM t_timestamp_range1 PARTITION (p0);
SELECT * FROM t_timestamp_range1 PARTITION (p1);
SELECT * FROM t_timestamp_range1 PARTITION (p2);
SELECT * FROM t_timestamp_range1 PARTITION (p3);
SELECT * FROM t_timestamp_range1 PARTITION (p4);

