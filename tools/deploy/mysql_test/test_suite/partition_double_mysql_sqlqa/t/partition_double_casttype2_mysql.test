# owner: yibo.tyf
# owner group: sql1
# description: MySQL模式支持double等类型作为分区键,sql_mode = 'STRICT_ALL_TABLES'时列类型转换测试
# tags: partition
# author: wb-sl672505

purge recyclebin;
let $char_charset = 'utf8';
--disable_warnings
drop database if exists sltest;
--enable_warnings
create database sltest;
use sltest;
set timestamp = 1600000000;
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;
set @@session.explicit_defaults_for_timestamp=off;
--result_format 4
SET sql_mode = 'STRICT_ALL_TABLES,NO_ZERO_IN_DATE';

--echo -----------------------------------------------------------------------------------------------------------------
--echo ### 本次支持的类型：double、float、decimal、timestamp 作为range columns分区的分区键。
--echo ### 列类型转换
--disable_warnings
DROP TABLE IF EXISTS t_double_range;
--enable_warnings
CREATE TABLE t_double_range (
    c1 DOUBLE
) 
PARTITION BY RANGE COLUMNS(c1) (
    PARTITION p_neg_inf VALUES LESS THAN (-1.7976931348623157E308),
    PARTITION p_min VALUES LESS THAN (-2.2250738585072014E-308),
    PARTITION p_zero VALUES LESS THAN (0),
    PARTITION p_min_pos VALUES LESS THAN (2.2250738585072014E-308),
    PARTITION p_max VALUES LESS THAN (1.7976931348623157E308),
    PARTITION p_pos_inf VALUES LESS THAN MAXVALUE
);

--echo ### 插入最小值、最小值接近0的值、0、最大值接近0的值、最大值、NULL
INSERT INTO t_double_range (c1) VALUES 
(-1.7976931348623157E308), 
(-2.2250738585072014E-308), 
(0), (+0), (-0), 
(2.2250738585072014E-308), 
(1.7976931348623157E308), 
(NULL);

INSERT INTO t_double_range (c1) VALUES 
(-1.7976931348623157E308), 
(-2.2250738585072014E-308), 
(0), (+0), (-0), 
(2.2250738585072014E-308), 
(1.7976931348623157E308), 
(NULL);

INSERT INTO t_double_range (c1) VALUES 
(-1.7976931348623157E308-10000), 
(1.7976931348623157E308+10000);

INSERT INTO t_double_range (c1) VALUES 
(-1E-400), 
(1E-400);

SELECT * FROM t_double_range PARTITION(p_neg_inf);
SELECT * FROM t_double_range PARTITION(p_min);
SELECT * FROM t_double_range PARTITION(p_zero);
SELECT * FROM t_double_range PARTITION(p_min_pos);
SELECT * FROM t_double_range PARTITION(p_max);
SELECT * FROM t_double_range PARTITION(p_pos_inf);

--error 1493
alter table t_double_range modify column c1 DOUBLE UNSIGNED;
--error 1493
alter table t_double_range modify column c1 DOUBLE ZEROFILL;
--error 1493
alter table t_double_range modify column c1 FLOAT;

#### 
--error 1654
alter table t_double_range modify column c1 DECIMAL;
--error 1493
alter table t_double_range modify column c1 INT;
--error 1493
alter table t_double_range modify column c1 TINYINT;
--error 1493
alter table t_double_range modify column c1 SMALLINT;
--error 1493
alter table t_double_range modify column c1 MEDIUMINT;
--error 1493
alter table t_double_range modify column c1 BIGINT;

--echo ### INT类型
--disable_warnings
DROP TABLE IF EXISTS t_INT_range;
--enable_warnings
CREATE TABLE t_INT_range (
    c1 INT
) 
PARTITION BY RANGE COLUMNS(c1) (
    PARTITION p_neg_inf VALUES LESS THAN (-1000),
    PARTITION p_min VALUES LESS THAN (-200),
    PARTITION p_zero VALUES LESS THAN (0),
    PARTITION p_min_pos VALUES LESS THAN (200),
    PARTITION p_max VALUES LESS THAN (1000),
    PARTITION p_pos_inf VALUES LESS THAN MAXVALUE
);
--error 1493
alter table t_INT_range modify column c1 DOUBLE UNSIGNED;
--error 1493
alter table t_INT_range modify column c1 DOUBLE ZEROFILL;
alter table t_INT_range modify column c1 FLOAT;
alter table t_INT_range modify column c1 DOUBLE;
alter table t_INT_range modify column c1 INT;

--echo ### 浮点类型 -> INT PARTITION支持
--disable_warnings
DROP TABLE IF EXISTS t_double_range;
--enable_warnings
CREATE TABLE t_double_range (
    c1 DOUBLE
) 
PARTITION BY RANGE COLUMNS(c1) (
    PARTITION p_neg_inf VALUES LESS THAN (-1.7976931348623157E308),
    PARTITION p_min VALUES LESS THAN (-2.2250738585072014E-308),
    PARTITION p_zero VALUES LESS THAN (0),
    PARTITION p_min_pos VALUES LESS THAN (2.2250738585072014E-308),
    PARTITION p_max VALUES LESS THAN (1.7976931348623157E308),
    PARTITION p_pos_inf VALUES LESS THAN MAXVALUE
);
--error 1493
alter table t_double_range modify column c1 INT;

ALTER TABLE t_double_range PARTITION BY RANGE COLUMNS(c1) (
    PARTITION p_neg_inf VALUES LESS THAN (-1000),
    PARTITION p_min VALUES LESS THAN (-200),
    PARTITION p_zero VALUES LESS THAN (0),
    PARTITION p_min_pos VALUES LESS THAN (200),
    PARTITION p_max VALUES LESS THAN (1000),
    PARTITION p_pos_inf VALUES LESS THAN MAXVALUE
);
alter table t_double_range modify column c1 INT;

--echo ### FLOAT类型
--disable_warnings
DROP TABLE IF EXISTS t_float_range;
--enable_warnings
CREATE TABLE t_float_range (
    c1 FLOAT
) 
PARTITION BY RANGE COLUMNS(c1) (
    PARTITION p_neg_inf VALUES LESS THAN (- 3.402823466e+38),
    PARTITION p_min VALUES LESS THAN (-1.175494351e-38),
    PARTITION p_zero VALUES LESS THAN (0),
    PARTITION p_min_pos VALUES LESS THAN (1.175494351e-38),
    PARTITION p_max VALUES LESS THAN (3.402823466e+38),
    PARTITION p_pos_inf VALUES LESS THAN MAXVALUE
);

