('2024-03-31 23:59:59'),
('2024-04-01 00:00:00'),
('2024-07-31 23:59:59'),
('2024-08-01 00:00:00'),
('2024-11-30 23:59:59'),
('2024-12-01 00:00:00');

INSERT INTO t_timestamp_range1 (c1) VALUES
