# owner: yibo.tyf
# owner group: sql1
# description: MySQL模式支持double等类型作为分区键，二级分区表，DDL相关操作验证
# tags: partition
# author: wb-sl672505

purge recyclebin;
let $char_charset = 'utf8';
--disable_warnings
drop database if exists sltest;
--enable_warnings
create database sltest;
use sltest;
set timestamp = 1600000000;
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;
set @@session.explicit_defaults_for_timestamp=off;
--result_format 4
set sql_mode = '';

--echo -----------------------------------------------------------------------------------------------------------------
--echo ### 本次支持的类型：double、float、decimal、timestamp 作为range columns分区的分区键。
--echo ###  一级分区为 range columns（double、float、decimal、timestamp），二级分区表
--disable_warnings
drop table if exists EMP;
--enable_warnings

CREATE TABLE EMP (
    EMPNO DECIMAL,
    ENAME VARCHAR(100),
    JOB VARCHAR(100),
    MGR INT,
    HIREDATE DATE,
    SAL FLOAT(8,2),
    COMM INT,
    DEPTNO INT,
    COMID INT
)
PARTITION BY RANGE COLUMNS(EMPNO)
SUBPARTITION BY RANGE COLUMNS(EMPNO, DEPTNO) 
SUBPARTITION TEMPLATE (
    SUBPARTITION PART001 VALUES LESS THAN (15, 10),
    SUBPARTITION PART002 VALUES LESS THAN (1000, 20),
    SUBPARTITION PART003 VALUES LESS THAN (5000, 50)
)
(
    PARTITION P1000 VALUES LESS THAN (500),
    PARTITION P2000 VALUES LESS THAN (5000)
);

INSERT INTO EMP VALUES(1,'SMITH','CLERK',7902,'1980-12-12',800,NULL,20,9999);
INSERT INTO EMP VALUES(2,'ALLEN','SALESMAN',7698,'1981-12-12',1600,300,30,9999);
INSERT INTO EMP VALUES(3,'WARD','SALESMAN',7698,'1982-12-12',1250,500,30,9999);
INSERT INTO EMP VALUES(100,'BLAKE','MANAGER',7839,'1985-12-12',2850,NULL,30,9999);
INSERT INTO EMP VALUES(200,'CLARK','MANAGER',7839,'1986-12-12',2450,NULL,10,9999);
INSERT INTO EMP VALUES(300,'SCOTT','ANALYST',7566,'1987-12-12',3000,NULL,20,9999);
INSERT INTO EMP VALUES(400,'KING','PRESIDENT',NULL,'1988-12-12',5000,NULL,10,9999);
INSERT INTO EMP VALUES(1000,'TURNER','SALESMAN',7698,'1989-12-12',1500,0,30,9999);
INSERT INTO EMP VALUES(2000,'ADAMS','CLERK',7788,'1990-12-12',1100,NULL,20,9999);
INSERT INTO EMP VALUES(3000,'JAMES','CLERK',7698,'1991-12-12',950,NULL,30,9999);
INSERT INTO EMP VALUES(1000,'FORD','ANALYST',7566,'1992-12-12',3000,NULL,20,9999);

INSERT INTO EMP VALUES(400,'SMITH_BOUNDARY','BOUNDARY_JOB',7902,'1980-12-12',800,NULL,15,9999);
INSERT INTO EMP VALUES(4000,'ALLEN_BOUNDARY','BOUNDARY_JOB',7698,'1981-12-12',1600,300,30,9999);

INSERT INTO EMP VALUES(15,'WARD_BOUNDARY','BOUNDARY_JOB',7698,'1982-12-12',1250,500,10,9999);
INSERT INTO EMP VALUES(1000,'BLAKE_BOUNDARY','BOUNDARY_JOB',7839,'1985-12-12',2850,NULL,20,9999);
INSERT INTO EMP VALUES(4500,'CLARK_BOUNDARY','BOUNDARY_JOB',7839,'1986-12-12',2450,NULL,50,9999);

INSERT INTO EMP VALUES(1,'SMITH_BOUNDARY','BOUNDARY_JOB',7902,'1980-12-12',800,NULL,20,9999);
INSERT INTO EMP VALUES(2,'ALLEN_BOUNDARY','BOUNDARY_JOB',7698,'1981-12-12',1600,300,30,9999);
INSERT INTO EMP VALUES(15,'WARD_BOUNDARY','BOUNDARY_JOB',7698,'1982-12-12',1250,500,10,9999);
INSERT INTO EMP VALUES(1000,'BLAKE_BOUNDARY','BOUNDARY_JOB',7839,'1985-12-12',2850,NULL,20,9999);
INSERT INTO EMP VALUES(4500,'CLARK_BOUNDARY','BOUNDARY_JOB',7839,'1986-12-12',2450,NULL,50,9999);

SELECT * FROM EMP PARTITION(P1000) ORDER BY EMPNO,SAL,JOB; 
SELECT * FROM EMP PARTITION(P2000) ORDER BY EMPNO,SAL,JOB;

--echo ### 增加分区

--error 1064
ALTER TABLE EMP
  ADD PARTITION P3000 VALUES LESS THAN (5000)
  (SUBPARTITION P3000_SUB1 VALUES LESS THAN (15, 10),
   SUBPARTITION P3000_SUB2 VALUES LESS THAN (1000, 20),
   SUBPARTITION P3000_SUB3 VALUES LESS THAN (5000, 50));

--error 1064
ALTER TABLE EMP
  ADD PARTITION P3000 VALUES LESS THAN (7000)
  (SUBPARTITION P3000_SUB1 VALUES LESS THAN (15, 10),
   SUBPARTITION P3000_SUB2 VALUES LESS THAN (1000, 20),
   SUBPARTITION P3000_SUB3 VALUES LESS THAN (5000, 50));

ALTER TABLE EMP
ADD PARTITION (PARTITION P3000 VALUES LESS THAN (MAXVALUE));
ALTER TABLE EMP
DROP  PARTITION P3000;
--error 1064
ALTER TABLE EMP ADD PARTITION P3000 LESS THAN (MAXVALUE)(
SUBPARTITION PART001 VALUES LESS THAN (15, 10),
SUBPARTITION PART002 VALUES LESS THAN (1000, 20),
SUBPARTITION PART003 VALUES LESS THAN (5000, 50));
--error 1064
ALTER TABLE EMP ADD PARTITION P3000 LESS THAN (7000) SUBPARTITION BY RANGE COLUMNS(EMPNO, DEPTNO) 
SUBPARTITION TEMPLATE (
SUBPARTITION PART001 VALUES LESS THAN (15, 10),
SUBPARTITION PART002 VALUES LESS THAN (1000, 20),
SUBPARTITION PART003 VALUES LESS THAN (5000, 50));

--error 1064
ALTER TABLE EMP ADD PARTITION P3000 LESS THAN (MAXVALUE)
SUBPARTITION TEMPLATE (
SUBPARTITION PART001 VALUES LESS THAN (15, 10),
SUBPARTITION PART002 VALUES LESS THAN (1000, 20),
SUBPARTITION PART003 VALUES LESS THAN (5000, 50));

ALTER TABLE EMP
ADD PARTITION (PARTITION P3000 VALUES LESS THAN (MAXVALUE));

--echo ### 清空分区

--error 1507
ALTER TABLE EMP TRUNCATE PARTITION PART001;
--error 1507
ALTER TABLE EMP TRUNCATE PARTITION PART001,PART002,PART003;
ALTER TABLE EMP TRUNCATE PARTITION P1000,P2000;
ALTER TABLE EMP TRUNCATE PARTITION P1000;
ALTER TABLE EMP TRUNCATE PARTITION P2000;
ALTER TABLE EMP TRUNCATE PARTITION P3000;

--echo ### 删除分区
--error 1507
ALTER TABLE EMP DROP PARTITION PART001,PART002;
--error 4225
ALTER TABLE EMP DROP SUBPARTITION PART001,PART002;
--error 4225
ALTER TABLE EMP DROP SUBPARTITION PART001;
--error 4225
ALTER TABLE EMP DROP SUBPARTITION PART002;

--disable_result_log
select  e.table_name,e.partition_name,e.subpartition_name,e.partition_ordinal_position,e.subpartition_ordinal_position,e.partition_method,e.partition_expression,e.partition_description,e.table_rows,e.avg_row_length,e.data_length,e.create_time,e.update_time
from    information_schema.partitions   e  where table_name = 'EMP';
--enable_result_log

### 删除二级分区的语法
ALTER TABLE EMP DROP SUBPARTITION P2000sPART001;

ALTER TABLE EMP
DROP  PARTITION P3000;

--error 1508
ALTER TABLE EMP DROP PARTITION P1000,P2000;
ALTER TABLE EMP DROP PARTITION P1000;
--error 1508
ALTER TABLE EMP DROP PARTITION P2000;

ALTER TABLE EMP
ADD PARTITION (PARTITION P3000 VALUES LESS THAN (MAXVALUE));
ALTER TABLE EMP DROP PARTITION P2000;
--error 1508
ALTER TABLE EMP DROP PARTITION P1000,P2000;

### 删除二级分区的语法
ALTER TABLE EMP DROP SUBPARTITION P3000sPART001;
ALTER TABLE EMP DROP SUBPARTITION P3000sPART002;
--error 1508
ALTER TABLE EMP DROP SUBPARTITION P3000sPART003;

--echo ### 修改分区表
--disable_warnings
drop table if exists EMP;
--enable_warnings
CREATE TABLE EMP (
    EMPNO DECIMAL,
    ENAME VARCHAR(100),
    JOB VARCHAR(100),
    MGR INT,
    HIREDATE DATE,
    SAL FLOAT(8,2),
    COMM INT,
    DEPTNO INT,
    COMID INT
)
PARTITION BY RANGE COLUMNS(EMPNO)
SUBPARTITION BY RANGE COLUMNS(EMPNO, DEPTNO) 
SUBPARTITION TEMPLATE (
    SUBPARTITION PART001 VALUES LESS THAN (15, 10),
    SUBPARTITION PART002 VALUES LESS THAN (1000, 20),
    SUBPARTITION PART003 VALUES LESS THAN (5000, 50),
    SUBPARTITION PART004 VALUES LESS THAN (10000, 100)
)
(
    PARTITION P1000 VALUES LESS THAN (2000),
    PARTITION P2000 VALUES LESS THAN (10000),
	PARTITION P3000 VALUES LESS THAN (MAXVALUE)
);

--error 1517
ALTER TABLE EMP
ADD PARTITION(
    PARTITION P1000 VALUES LESS THAN (2000),
    PARTITION P2000 VALUES LESS THAN (10000),
	PARTITION P3000 VALUES LESS THAN (MAXVALUE)
);

ALTER TABLE EMP PARTITION BY RANGE COLUMNS(EMPNO)
SUBPARTITION BY RANGE COLUMNS(EMPNO, DEPTNO) 
SUBPARTITION TEMPLATE (
    SUBPARTITION PART001 VALUES LESS THAN (15, 10),
    SUBPARTITION PART002 VALUES LESS THAN (1000, 20),
    SUBPARTITION PART003 VALUES LESS THAN (5000, 50),
    SUBPARTITION PART004 VALUES LESS THAN (10000, 100)
)
(
    PARTITION P1000 VALUES LESS THAN (2000),
    PARTITION P2000 VALUES LESS THAN (10000),
	PARTITION P3000 VALUES LESS THAN (MAXVALUE)
);

ALTER TABLE EMP PARTITION BY RANGE COLUMNS(EMPNO)
SUBPARTITION BY RANGE COLUMNS(EMPNO, DEPTNO)
SUBPARTITION TEMPLATE (
    SUBPARTITION PART001 VALUES LESS THAN (15, 10),
    SUBPARTITION PART002 VALUES LESS THAN (1000, 20),
    SUBPARTITION PART003 VALUES LESS THAN (4000, 50),
    SUBPARTITION PART004 VALUES LESS THAN (10000, 100)
)
(
    PARTITION P1000 VALUES LESS THAN (1000),
    PARTITION P2000 VALUES LESS THAN (20000),
	PARTITION P3000 VALUES LESS THAN (MAXVALUE)
);

--echo ### 分区分裂/合并 
--disable_warnings
drop table if exists EMP;
--enable_warnings

CREATE TABLE EMP (
    EMPNO DECIMAL,
    ENAME VARCHAR(100),
    JOB VARCHAR(100),
    MGR INT,
    HIREDATE DATE,
    SAL FLOAT(8,2),
    COMM INT,
    DEPTNO INT,
    COMID INT
)
PARTITION BY RANGE COLUMNS(EMPNO)
SUBPARTITION BY RANGE COLUMNS(EMPNO, DEPTNO) 
SUBPARTITION TEMPLATE (
    SUBPARTITION PART001 VALUES LESS THAN (15, 10),
    SUBPARTITION PART002 VALUES LESS THAN (1000, 20),
    SUBPARTITION PART003 VALUES LESS THAN (5000, 50)
)
(
    PARTITION P1000 VALUES LESS THAN (500),
    PARTITION P2000 VALUES LESS THAN (5000)
);

