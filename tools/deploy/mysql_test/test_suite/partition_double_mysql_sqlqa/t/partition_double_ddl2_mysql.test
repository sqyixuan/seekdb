SELECT * FROM EMP PARTITION(P2000) ORDER BY EMPNO,SAL,JOB;

--ERROR 1235
ALTER TABLE EMP
REORGANIZE PARTITION P1000 INTO (
    PARTITION P1a VALUES LESS THAN (250),
    PARTITION p1b VALUES LESS THAN (500)
);

--ERROR 1235
ALTER TABLE EMP
REORGANIZE PARTITION P2000, p1a, p1b INTO (
    PARTITION p_combined VALUES LESS THAN (10000)
);

--ERROR 1235
ALTER TABLE EMP
REORGANIZE PARTITION p_combined INTO (
    PARTITION P1000 VALUES LESS THAN (500),
    PARTITION P2000 VALUES LESS THAN (5000)
);

--ERROR 1235
ALTER TABLE EMP
REORGANIZE PARTITION P1000 INTO (
    PARTITION P1000 VALUES LESS THAN (50)
);

--echo ### 分区重命名

ALTER TABLE EMP PARTITION BY RANGE COLUMNS(EMPNO)
SUBPARTITION BY RANGE COLUMNS(EMPNO, DEPTNO) 
SUBPARTITION TEMPLATE (
    SUBPARTITION PART001 VALUES LESS THAN (15, 10),
    SUBPARTITION PART002 VALUES LESS THAN (1000, 20),
    SUBPARTITION PART003 VALUES LESS THAN (5000, 50),
    SUBPARTITION PART004 VALUES LESS THAN (10000, 100)
)
(
    PARTITION P1000 VALUES LESS THAN (2000),
    PARTITION P2000 VALUES LESS THAN (10000),
	PARTITION P3000 VALUES LESS THAN (MAXVALUE)
);

--ERROR 1064
ALTER TABLE EMP RENAME PARTITION P1000 TO NEW_P0;
--ERROR 1064
ALTER TABLE EMP RENAME PARTITION P2000 TO NEW_P1;
--ERROR 1064
ALTER TABLE EMP RENAME PARTITION P3000 TO NEW_P2;
--ERROR 1064
ALTER TABLE EMP RENAME PARTITION NEW_P0 TO P1000;
--ERROR 1064
ALTER TABLE EMP RENAME PARTITION NEW_P1 TO P2000;
--ERROR 1064
ALTER TABLE EMP RENAME PARTITION NEW_P2 TO P3000;

--ERROR 1235
ALTER TABLE EMP
REORGANIZE PARTITION P2000 INTO (
    PARTITION p1_new VALUES LESS THAN (1000)
);

--ERROR 1235
ALTER TABLE EMP
REORGANIZE PARTITION p1_new INTO (
    PARTITION P2000 VALUES LESS THAN (1000)
);

--ERROR 1064
ALTER TABLE EMP
REORGANIZE SUBPARTITION PART001 INTO (
    SUBPARTITION PART001_new VALUES LESS THAN  (15, 10)
);

