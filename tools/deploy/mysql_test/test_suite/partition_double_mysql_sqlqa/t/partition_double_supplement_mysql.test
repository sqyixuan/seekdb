# owner: yibo.tyf
# owner group: sql1
# description: MySQL模式支持double等类型作为分区键，分区相关场景补充测试
# tags: partition
# author: wb-sl672505

purge recyclebin;
let $char_charset = 'utf8';
--disable_warnings
drop database if exists sltest;
--enable_warnings
create database sltest;
use sltest;
set timestamp = 1600000000;
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;
set @@session.explicit_defaults_for_timestamp=off;
--result_format 4
set sql_mode = '';

--echo -----------------------------------------------------------------------------------------------------------------
--echo ### 本次支持的类型：double、float、decimal、timestamp 作为range columns分区的分区键。
--DISABLE_WARNINGS
DROP TABLE IF EXISTS EMP;
--ENABLE_WARNINGS

CREATE TABLE EMP (
    EMPNO DOUBLE,
    ENAME VARCHAR(100),
    JOB VARCHAR(100),
    MGR INT,
    HIREDATE TIMESTAMP,
    SAL DOUBLE,
    COMM INT,
    DEPTNO DECIMAL,
    COMID INT
)
PARTITION BY RANGE COLUMNS(EMPNO) 
SUBPARTITION BY RANGE COLUMNS(SAL,DEPTNO,HIREDATE) 
SUBPARTITION TEMPLATE (
    SUBPARTITION PART001 VALUES LESS THAN (15.0, 10, '2000-01-01 00:00:00'),
    SUBPARTITION PART002 VALUES LESS THAN (1000.0, 20, '2010-01-01 00:00:00'),
    SUBPARTITION PART003 VALUES LESS THAN (5000.0, 50, '2020-01-01 00:00:00')
) (
    PARTITION P1000 VALUES LESS THAN (500.0),
    PARTITION P2000 VALUES LESS THAN (5000.0),
    PARTITION P3000 VALUES LESS THAN (15000.0)
);

INSERT INTO EMP (EMPNO, ENAME, JOB, MGR, HIREDATE, SAL, COMM, DEPTNO, COMID) VALUES 
(499.99, 'EMP_PART001', 'JOB1', 1, '1999-12-31 23:59:59', 14.99, 0, 9, 1), 
(499.99, 'EMP_PART002', 'JOB2', 2, '2009-12-31 23:59:59', 999.99, 0, 19, 2), 
(499.99, 'EMP_PART003', 'JOB3', 3, '2019-12-31 23:59:59', 4999.99, 0, 49, 3),

(4999.99, 'EMP_PART004', 'JOB4', 4, '1999-12-31 23:59:59', 14.99, 0, 9, 4), 
(4999.99, 'EMP_PART005', 'JOB5', 5, '2009-12-31 23:59:59', 999.99, 0, 19, 5), 
(4999.99, 'EMP_PART006', 'JOB6', 6, '2019-12-31 23:59:59', 4999.99, 0, 49, 6), 

(5000.00, 'EMP_PART007', 'JOB7', 7, '1999-12-31 23:59:59', 14.99, 0, 9, 7), 
(5000.00, 'EMP_PART008', 'JOB8', 8, '2009-12-31 23:59:59', 999.99, 0, 19, 8),
(5000.00, 'EMP_PART009', 'JOB9', 9, '2019-12-31 23:59:59', 4999.99, 0, 49, 9);  

SELECT * FROM EMP PARTITION(P1000) ORDER BY EMPNO,SAL,DEPTNO; 
SELECT * FROM EMP PARTITION(P2000) ORDER BY EMPNO,SAL,DEPTNO;
SELECT * FROM EMP PARTITION(P3000) ORDER BY EMPNO,SAL,DEPTNO;
SELECT * FROM EMP PARTITION(P1000sPART001) ORDER BY EMPNO,SAL,DEPTNO; 
SELECT * FROM EMP PARTITION(P2000sPART002) ORDER BY EMPNO,SAL,DEPTNO;
SELECT * FROM EMP PARTITION(P3000sPART003) ORDER BY EMPNO,SAL,DEPTNO;

--echo ##### 相关场景补充 CTAS
--DISABLE_WARNINGS
DROP TABLE IF EXISTS EMP_2;
--ENABLE_WARNINGS
CREATE TABLE EMP_2 AS SELECT * FROM EMP WHERE 1=2;
INSERT INTO EMP_2 SELECT * FROM EMP PARTITION(P1000) ORDER BY EMPNO,SAL,DEPTNO;  
INSERT INTO EMP_2 SELECT * FROM EMP PARTITION(P2000) ORDER BY EMPNO,SAL,DEPTNO; 
INSERT INTO EMP_2 SELECT * FROM EMP PARTITION(P3000) ORDER BY EMPNO,SAL,DEPTNO; 
INSERT INTO EMP_2 SELECT * FROM EMP PARTITION(P1000sPART001) ORDER BY EMPNO,SAL,DEPTNO; 
INSERT INTO EMP_2 SELECT * FROM EMP PARTITION(P2000sPART002) ORDER BY EMPNO,SAL,DEPTNO; 
INSERT INTO EMP_2 SELECT * FROM EMP PARTITION(P3000sPART003) ORDER BY EMPNO,SAL,DEPTNO; 
SELECT * FROM EMP_2; 

TRUNCATE TABLE EMP_2;
TRUNCATE TABLE EMP;
--echo ##### 相关场景补充 视图
--DISABLE_WARNINGS
DROP VIEW IF EXISTS EMP_VIEW;
--ENABLE_WARNINGS
CREATE OR REPLACE VIEW EMP_VIEW AS SELECT * FROM EMP;
SELECT * FROM EMP_VIEW;

### 查看分区裁剪结果
EXPLAIN SELECT * FROM EMP RIGHT OUTER JOIN EMP_2 ON EMP.EMPNO = EMP_2.EMPNO WHERE EMP_2.EMPNO < 1000.0;
EXPLAIN SELECT * FROM EMP RIGHT OUTER JOIN EMP_VIEW ON EMP.EMPNO = EMP_VIEW.EMPNO WHERE EMP_VIEW.EMPNO >= 5000.0 AND EMP.EMPNO < 10000.0;
EXPLAIN SELECT * FROM EMP RIGHT OUTER JOIN EMP_VIEW ON EMP.SAL = EMP_VIEW.SAL WHERE (EMP_VIEW.SAL,EMP_VIEW.HIREDATE) < ( 15,'2000-01-01 00:00:00');
EXPLAIN SELECT * FROM EMP RIGHT OUTER JOIN EMP_VIEW ON EMP.SAL = EMP_VIEW.SAL WHERE (EMP_VIEW.SAL,EMP.HIREDATE) = ( 15,'2000-01-01 00:00:00');
EXPLAIN SELECT * FROM EMP RIGHT OUTER JOIN EMP_VIEW ON EMP.SAL = EMP_VIEW.SAL WHERE (EMP_VIEW.SAL,EMP.HIREDATE) > ( 1500,'2020-01-01 00:00:00');
EXPLAIN SELECT * FROM EMP RIGHT OUTER JOIN EMP_VIEW ON EMP.SAL = EMP_VIEW.SAL WHERE (EMP_VIEW.SAL,EMP.DEPTNO,EMP.HIREDATE)<(5000.0, 50, '2020-01-01 00:00:00');
EXPLAIN SELECT * FROM EMP RIGHT OUTER JOIN EMP_VIEW ON EMP.SAL = EMP_VIEW.SAL WHERE (EMP_VIEW.SAL,EMP.DEPTNO,EMP.HIREDATE)=(15.0, 10, '2000-01-01 00:00:00');
EXPLAIN SELECT * FROM EMP RIGHT OUTER JOIN EMP_VIEW ON EMP.SAL = EMP_VIEW.SAL WHERE (EMP_VIEW.SAL,EMP.DEPTNO,EMP.HIREDATE)>(15.0, 10, '2000-01-01 00:00:00');
EXPLAIN SELECT * FROM EMP RIGHT OUTER JOIN EMP_VIEW ON EMP.EMPNO = EMP_VIEW.EMPNO AND EMP.SAL = EMP_VIEW.SAL WHERE EMP_VIEW.EMPNO < 5000.0 AND EMP.SAL < 1000.0;
EXPLAIN SELECT * FROM EMP RIGHT OUTER JOIN EMP_VIEW ON EMP.EMPNO = EMP_VIEW.EMPNO AND EMP.SAL = EMP_VIEW.SAL AND EMP.DEPTNO = EMP_VIEW.DEPTNO AND EMP.HIREDATE = EMP_VIEW.HIREDATE WHERE EMP.EMPNO < 5000.0 AND EMP.SAL < 1000.0 AND EMP.DEPTNO < 10.0 AND EMP.HIREDATE < '2010-01-01 00:00:00';
EXPLAIN SELECT * FROM EMP RIGHT OUTER JOIN EMP_VIEW ON EMP.EMPNO = EMP_VIEW.EMPNO WHERE EMP_VIEW.EMPNO = 499.99;
EXPLAIN SELECT * FROM EMP RIGHT OUTER JOIN EMP_VIEW ON EMP.EMPNO = EMP_VIEW.EMPNO WHERE EMP_VIEW.EMPNO IN (499.99, 4999.99);
EXPLAIN SELECT * FROM EMP RIGHT OUTER JOIN EMP_VIEW ON EMP.SAL = EMP_VIEW.SAL WHERE EMP_VIEW.SAL = 999.99;
EXPLAIN SELECT * FROM EMP RIGHT OUTER JOIN EMP_VIEW ON EMP.SAL = EMP_VIEW.SAL AND EMP.DEPTNO = EMP_VIEW.DEPTNO AND EMP.HIREDATE = EMP_VIEW.HIREDATE WHERE EMP.SAL = 999.99 AND EMP.DEPTNO = 19 AND EMP.HIREDATE = '2009-12-31 23:59:59';
EXPLAIN SELECT * FROM EMP RIGHT OUTER JOIN EMP_VIEW ON EMP.EMPNO = EMP_VIEW.EMPNO WHERE EMP_VIEW.EMPNO >= 1000.0 AND EMP_VIEW.EMPNO <= 5000.0;
EXPLAIN SELECT * FROM EMP RIGHT OUTER JOIN EMP_VIEW ON EMP.EMPNO = EMP_VIEW.EMPNO WHERE EMP_VIEW.EMPNO < 1000.0 OR EMP_VIEW.EMPNO > 5000.0;
EXPLAIN SELECT * FROM EMP RIGHT OUTER JOIN EMP_VIEW ON EMP.EMPNO = EMP_VIEW.EMPNO AND EMP.SAL = EMP_VIEW.SAL WHERE (EMP_VIEW.EMPNO < 500.0 AND EMP_VIEW.SAL > 100.0) OR (EMP_VIEW.DEPTNO > 30 AND EMP_VIEW.HIREDATE > '2010-01-01 00:00:00');
EXPLAIN SELECT * FROM EMP RIGHT OUTER JOIN EMP_VIEW ON EMP.EMPNO = EMP_VIEW.EMPNO WHERE EMP_VIEW.EMPNO BETWEEN 1000.0 AND 5000.0;
EXPLAIN SELECT * FROM EMP RIGHT OUTER JOIN EMP_VIEW ON EMP.EMPNO = EMP_VIEW.EMPNO WHERE EMP_VIEW.EMPNO > 1000.0 AND EMP_VIEW.EMPNO < 5000.0;
EXPLAIN SELECT * FROM EMP RIGHT OUTER JOIN EMP_VIEW ON EMP.SAL = EMP_VIEW.SAL WHERE EMP_VIEW.SAL <= 1000.00;
EXPLAIN SELECT * FROM EMP RIGHT OUTER JOIN EMP_VIEW ON EMP.EMPNO = EMP_VIEW.EMPNO AND EMP.HIREDATE = EMP_VIEW.HIREDATE WHERE EMP_VIEW.EMPNO <= 5000.0 AND EMP_VIEW.HIREDATE >= '2000-01-01 00:00:00';

--echo ##### 相关场景补充 sql_mode
SET sql_mode = 'STRICT_ALL_TABLES,NO_ZERO_IN_DATE';
SELECT * FROM EMP RIGHT OUTER JOIN EMP_VIEW ON EMP.EMPNO = EMP_VIEW.EMPNO WHERE EMP_VIEW.EMPNO < 1000.0 ORDER BY 1,2,3;
SELECT * FROM EMP RIGHT OUTER JOIN EMP_VIEW ON EMP.EMPNO = EMP_VIEW.EMPNO WHERE EMP_VIEW.EMPNO >= 5000.0 AND EMP.EMPNO < 10000.0ORDER BY 1,2,3;
SELECT * FROM EMP RIGHT OUTER JOIN EMP_VIEW ON EMP.SAL = EMP_VIEW.SAL WHERE (EMP_VIEW.SAL,EMP_VIEW.HIREDATE) < ( 15,'2000-01-01 00:00:00')ORDER BY 1,2,3;
SELECT * FROM EMP RIGHT OUTER JOIN EMP_VIEW ON EMP.SAL = EMP_VIEW.SAL WHERE (EMP_VIEW.SAL,EMP.HIREDATE) = ( 15,'2000-01-01 00:00:00')ORDER BY 1,2,3;
SELECT * FROM EMP RIGHT OUTER JOIN EMP_VIEW ON EMP.SAL = EMP_VIEW.SAL WHERE (EMP_VIEW.SAL,EMP.HIREDATE) > ( 1500,'2020-01-01 00:00:00')ORDER BY 1,2,3;
SELECT * FROM EMP RIGHT OUTER JOIN EMP_VIEW ON EMP.SAL = EMP_VIEW.SAL WHERE (EMP_VIEW.SAL,EMP.DEPTNO,EMP.HIREDATE)<(5000.0, 50, '2020-01-01 00:00:00')ORDER BY 1,2,3;
SELECT * FROM EMP RIGHT OUTER JOIN EMP_VIEW ON EMP.SAL = EMP_VIEW.SAL WHERE (EMP_VIEW.SAL,EMP.DEPTNO,EMP.HIREDATE)=(15.0, 10, '2000-01-01 00:00:00')ORDER BY 1,2,3;
SELECT * FROM EMP RIGHT OUTER JOIN EMP_VIEW ON EMP.SAL = EMP_VIEW.SAL WHERE (EMP_VIEW.SAL,EMP.DEPTNO,EMP.HIREDATE)>(15.0, 10, '2000-01-01 00:00:00')ORDER BY 1,2,3;
SELECT * FROM EMP RIGHT OUTER JOIN EMP_VIEW ON EMP.EMPNO = EMP_VIEW.EMPNO AND EMP.SAL = EMP_VIEW.SAL WHERE EMP_VIEW.EMPNO < 5000.0 AND EMP.SAL < 1000.0ORDER BY 1,2,3;
SELECT * FROM EMP RIGHT OUTER JOIN EMP_VIEW ON EMP.EMPNO = EMP_VIEW.EMPNO AND EMP.SAL = EMP_VIEW.SAL AND EMP.DEPTNO = EMP_VIEW.DEPTNO AND EMP.HIREDATE = EMP_VIEW.HIREDATE WHERE EMP.EMPNO < 5000.0 AND EMP.SAL < 1000.0 AND EMP.DEPTNO < 10.0 AND EMP.HIREDATE < '2010-01-01 00:00:00'ORDER BY 1,2,3;
SELECT * FROM EMP RIGHT OUTER JOIN EMP_VIEW ON EMP.EMPNO = EMP_VIEW.EMPNO WHERE EMP_VIEW.EMPNO = 499.99ORDER BY 1,2,3;
SELECT * FROM EMP RIGHT OUTER JOIN EMP_VIEW ON EMP.EMPNO = EMP_VIEW.EMPNO WHERE EMP_VIEW.EMPNO IN (499.99, 4999.99)ORDER BY 1,2,3;
SELECT * FROM EMP RIGHT OUTER JOIN EMP_VIEW ON EMP.SAL = EMP_VIEW.SAL WHERE EMP_VIEW.SAL = 999.99ORDER BY 1,2,3;
SELECT * FROM EMP RIGHT OUTER JOIN EMP_VIEW ON EMP.SAL = EMP_VIEW.SAL AND EMP.DEPTNO = EMP_VIEW.DEPTNO AND EMP.HIREDATE = EMP_VIEW.HIREDATE WHERE EMP.SAL = 999.99 AND EMP.DEPTNO = 19 AND EMP.HIREDATE = '2009-12-31 23:59:59'ORDER BY 1,2,3;
SELECT * FROM EMP RIGHT OUTER JOIN EMP_VIEW ON EMP.EMPNO = EMP_VIEW.EMPNO WHERE EMP_VIEW.EMPNO >= 1000.0 AND EMP_VIEW.EMPNO <= 5000.0ORDER BY 1,2,3;
SELECT * FROM EMP RIGHT OUTER JOIN EMP_VIEW ON EMP.EMPNO = EMP_VIEW.EMPNO WHERE EMP_VIEW.EMPNO < 1000.0 OR EMP_VIEW.EMPNO > 5000.0ORDER BY 1,2,3;
SELECT * FROM EMP RIGHT OUTER JOIN EMP_VIEW ON EMP.EMPNO = EMP_VIEW.EMPNO AND EMP.SAL = EMP_VIEW.SAL WHERE (EMP_VIEW.EMPNO < 500.0 AND EMP_VIEW.SAL > 100.0) OR (EMP_VIEW.DEPTNO > 30 AND EMP_VIEW.HIREDATE > '2010-01-01 00:00:00')ORDER BY 1,2,3;
SELECT * FROM EMP RIGHT OUTER JOIN EMP_VIEW ON EMP.EMPNO = EMP_VIEW.EMPNO WHERE EMP_VIEW.EMPNO BETWEEN 1000.0 AND 5000.0ORDER BY 1,2,3;
SELECT * FROM EMP RIGHT OUTER JOIN EMP_VIEW ON EMP.EMPNO = EMP_VIEW.EMPNO WHERE EMP_VIEW.EMPNO > 1000.0 AND EMP_VIEW.EMPNO < 5000.0ORDER BY 1,2,3;
SELECT * FROM EMP RIGHT OUTER JOIN EMP_VIEW ON EMP.SAL = EMP_VIEW.SAL WHERE EMP_VIEW.SAL <= 1000.00ORDER BY 1,2,3;
SELECT * FROM EMP RIGHT OUTER JOIN EMP_VIEW ON EMP.EMPNO = EMP_VIEW.EMPNO AND EMP.HIREDATE = EMP_VIEW.HIREDATE WHERE EMP_VIEW.EMPNO <= 5000.0 AND EMP_VIEW.HIREDATE >= '2000-01-01 00:00:00'ORDER BY 1,2,3;

--echo ##### 相关场景补充 并行查询
SET sql_mode = '';
SELECT /*+ PARALLEL(5) */ * FROM EMP RIGHT OUTER JOIN EMP_VIEW ON EMP.EMPNO = EMP_VIEW.EMPNO WHERE EMP_VIEW.EMPNO < 1000.0ORDER BY 1,2,3;
SELECT /*+ PARALLEL(1) */ * FROM EMP RIGHT OUTER JOIN EMP_VIEW ON EMP.EMPNO = EMP_VIEW.EMPNO WHERE EMP_VIEW.EMPNO >= 5000.0 AND EMP.EMPNO < 10000.0ORDER BY 1,2,3;
SELECT /*+ PARALLEL(2) */ * FROM EMP RIGHT OUTER JOIN EMP_VIEW ON EMP.SAL = EMP_VIEW.SAL WHERE (EMP_VIEW.SAL,EMP_VIEW.HIREDATE) < ( 15,'2000-01-01 00:00:00')ORDER BY 1,2,3;
SELECT /*+ PARALLEL(8) */ * FROM EMP RIGHT OUTER JOIN EMP_VIEW ON EMP.SAL = EMP_VIEW.SAL WHERE (EMP_VIEW.SAL,EMP.HIREDATE) = ( 15,'2000-01-01 00:00:00')ORDER BY 1,2,3;
SELECT /*+ NO_PARALLEL */ * FROM EMP RIGHT OUTER JOIN EMP_VIEW ON EMP.SAL = EMP_VIEW.SAL WHERE (EMP_VIEW.SAL,EMP.HIREDATE) > ( 1500,'2020-01-01 00:00:00')ORDER BY 1,2,3;
SELECT /*+ NO_PARALLEL */ * FROM EMP RIGHT OUTER JOIN EMP_VIEW ON EMP.SAL = EMP_VIEW.SAL WHERE (EMP_VIEW.SAL,EMP.DEPTNO,EMP.HIREDATE)<(5000.0, 50, '2020-01-01 00:00:00')ORDER BY 1,2,3;
SELECT /*+ NO_PARALLEL */ * FROM EMP RIGHT OUTER JOIN EMP_VIEW ON EMP.SAL = EMP_VIEW.SAL WHERE (EMP_VIEW.SAL,EMP.DEPTNO,EMP.HIREDATE)=(15.0, 10, '2000-01-01 00:00:00')ORDER BY 1,2,3;
SELECT /*+ NO_PARALLEL */ * FROM EMP RIGHT OUTER JOIN EMP_VIEW ON EMP.SAL = EMP_VIEW.SAL WHERE (EMP_VIEW.SAL,EMP.DEPTNO,EMP.HIREDATE)>(15.0, 10, '2000-01-01 00:00:00')ORDER BY 1,2,3;
SELECT  /*+ USE_PX PARALLEL(4)*/  * FROM EMP RIGHT OUTER JOIN EMP_VIEW ON EMP.EMPNO = EMP_VIEW.EMPNO AND EMP.SAL = EMP_VIEW.SAL WHERE EMP_VIEW.EMPNO < 5000.0 AND EMP.SAL < 1000.0ORDER BY 1,2,3;
SELECT /*+ USE_PX PARALLEL(1)*/ * FROM EMP RIGHT OUTER JOIN EMP_VIEW ON EMP.EMPNO = EMP_VIEW.EMPNO AND EMP.SAL = EMP_VIEW.SAL AND EMP.DEPTNO = EMP_VIEW.DEPTNO AND EMP.HIREDATE = EMP_VIEW.HIREDATE WHERE EMP.EMPNO < 5000.0 AND EMP.SAL < 1000.0 AND EMP.DEPTNO < 10.0 AND EMP.HIREDATE < '2010-01-01 00:00:00'ORDER BY 1,2,3;
SELECT /*+ USE_PX PARALLEL(2)*/ * FROM EMP RIGHT OUTER JOIN EMP_VIEW ON EMP.EMPNO = EMP_VIEW.EMPNO WHERE EMP_VIEW.EMPNO = 499.99ORDER BY 1,2,3;
SELECT /*+ USE_PX PARALLEL(8)*/ * FROM EMP RIGHT OUTER JOIN EMP_VIEW ON EMP.EMPNO = EMP_VIEW.EMPNO WHERE EMP_VIEW.EMPNO IN (499.99, 4999.99)ORDER BY 1,2,3;
SELECT /*+ USE_PX PARALLEL(3)*/ * FROM EMP RIGHT OUTER JOIN EMP_VIEW ON EMP.SAL = EMP_VIEW.SAL WHERE EMP_VIEW.SAL = 999.99ORDER BY 1,2,3;
SELECT /*+ USE_PX PARALLEL(10)*/ * FROM EMP RIGHT OUTER JOIN EMP_VIEW ON EMP.SAL = EMP_VIEW.SAL AND EMP.DEPTNO = EMP_VIEW.DEPTNO AND EMP.HIREDATE = EMP_VIEW.HIREDATE WHERE EMP.SAL = 999.99 AND EMP.DEPTNO = 19 AND EMP.HIREDATE = '2009-12-31 23:59:59'ORDER BY 1,2,3;
SELECT /*+ORDERED PQ_DISTRIBUTE(EMP HASH, HASH) USE_HASH (EMP)*/ * FROM EMP RIGHT OUTER JOIN EMP_VIEW ON EMP.EMPNO = EMP_VIEW.EMPNO WHERE EMP_VIEW.EMPNO >= 1000.0 AND EMP_VIEW.EMPNO <= 5000.0ORDER BY 1,2,3;
SELECT /*+ORDERED PQ_DISTRIBUTE(EMP HASH, HASH) USE_HASH (EMP)*/ * FROM EMP RIGHT OUTER JOIN EMP_VIEW ON EMP.EMPNO = EMP_VIEW.EMPNO WHERE EMP_VIEW.EMPNO < 1000.0 OR EMP_VIEW.EMPNO > 5000.0ORDER BY 1,2,3;
SELECT  /*+ORDERED PQ_DISTRIBUTE(EMP BROADCAST, NONE) USE_HASH (EMP) */  * FROM EMP RIGHT OUTER JOIN EMP_VIEW ON EMP.EMPNO = EMP_VIEW.EMPNO AND EMP.SAL = EMP_VIEW.SAL WHERE (EMP_VIEW.EMPNO < 500.0 AND EMP_VIEW.SAL > 100.0) OR (EMP_VIEW.DEPTNO > 30 AND EMP_VIEW.HIREDATE > '2010-01-01 00:00:00')ORDER BY 1,2,3;
SELECT /*+ORDERED PQ_DISTRIBUTE(EMP BROADCAST, NONE) USE_HASH (EMP) */  * FROM EMP RIGHT OUTER JOIN EMP_VIEW ON EMP.EMPNO = EMP_VIEW.EMPNO WHERE EMP_VIEW.EMPNO BETWEEN 1000.0 AND 5000.0ORDER BY 1,2,3;
SELECT /*+ORDERED PQ_DISTRIBUTE(EMP BROADCAST, NONE) USE_HASH (EMP) */  * FROM EMP RIGHT OUTER JOIN EMP_VIEW ON EMP.EMPNO = EMP_VIEW.EMPNO WHERE EMP_VIEW.EMPNO > 1000.0 AND EMP_VIEW.EMPNO < 5000.0ORDER BY 1,2,3;
SELECT /*+ORDERED PQ_DISTRIBUTE(EMP BROADCAST, NONE) USE_HASH (EMP) */  * FROM EMP RIGHT OUTER JOIN EMP_VIEW ON EMP.SAL = EMP_VIEW.SAL WHERE EMP_VIEW.SAL <= 1000.00ORDER BY 1,2,3;
SELECT /*+ORDERED PQ_DISTRIBUTE(EMP BROADCAST, NONE) USE_HASH (EMP) */  * FROM EMP RIGHT OUTER JOIN EMP_VIEW ON EMP.EMPNO = EMP_VIEW.EMPNO AND EMP.HIREDATE = EMP_VIEW.HIREDATE WHERE EMP_VIEW.EMPNO <= 5000.0 AND EMP_VIEW.HIREDATE >= '2000-01-01 00:00:00'ORDER BY 1,2,3;

--echo ##### 相关场景补充 分区表注释
--DISABLE_WARNINGS
DROP TABLE IF EXISTS EMP;
--ENABLE_WARNINGS

CREATE TABLE EMP (
    EMPNO DOUBLE COMMENT '列注释1' ,
    ENAME VARCHAR(100),
    JOB VARCHAR(100),
    MGR INT,
    HIREDATE TIMESTAMP COMMENT '列注释2',
    SAL DOUBLE COMMENT '列注释3',
    COMM INT,
    DEPTNO DECIMAL COMMENT '列注释4',
    COMID INT
) COMMENT '表注释1'
PARTITION BY RANGE COLUMNS(EMPNO) 
SUBPARTITION BY RANGE COLUMNS(SAL,DEPTNO,HIREDATE) 
SUBPARTITION TEMPLATE (
    SUBPARTITION PART001 VALUES LESS THAN (15.0, 10, '2000-01-01 00:00:00') ,
    SUBPARTITION PART002 VALUES LESS THAN (1000.0, 20, '2010-01-01 00:00:00'),
    SUBPARTITION PART003 VALUES LESS THAN (5000.0, 50, '2020-01-01 00:00:00')
) (
    PARTITION P1000 VALUES LESS THAN (500.0)  ,
    PARTITION P2000 VALUES LESS THAN (5000.0) ,
    PARTITION P3000 VALUES LESS THAN (15000.0)
);

ALTER TABLE EMP COMMENT = '这是表的注释信息';
ALTER TABLE EMP MODIFY COLUMN EMPNO FLOAT COMMENT '这是列的注释信息';
ALTER TABLE EMP MODIFY COLUMN EMPNO FLOAT COMMENT '';
ALTER TABLE EMP MODIFY COLUMN EMPNO DOUBLE COMMENT '';

--echo ######## 清空回收站，删除测试数据库 ########
--disable_warnings
drop database if exists sltest;
--enable_warnings
purge recyclebin;
