--disable_warnings
drop table if exists nt_varchar_testBAK;
--enable_warnings
CREATE TABLE nt_varchar_testBAK LIKE nt_varchar_test1;
ALTER TABLE pt_varchar_testBAK EXCHANGE PARTITION p2 WITH TABLE nt_varchar_testBAK WITHOUT VALIDATION;

ALTER TABLE pt_varchar_testBAK ADD COLUMN c5 DOUBLE;
ALTER TABLE nt_varchar_testBAK ADD COLUMN c5 DOUBLE;
