ALTER TABLE nt_varchar_test1 ADD COLUMN c5 DOUBLE;
ALTER TABLE pt_varchar_test1 EXCHANGE PARTITION p2 WITH TABLE nt_varchar_test1 WITHOUT VALIDATION;

