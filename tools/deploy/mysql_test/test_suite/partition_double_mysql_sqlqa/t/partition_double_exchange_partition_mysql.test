# owner: yibo.tyf
# owner group: sql1
# description: MySQL模式支持double等类型作为分区键，分区交换正交覆盖测试
# tags: partition
# author: wb-sl672505

purge recyclebin;
let $char_charset = 'utf8';
--disable_warnings
drop database if exists sltest;
--enable_warnings
create database sltest;
use sltest;
set timestamp = 1600000000;
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;
set @@session.explicit_defaults_for_timestamp=off;
--result_format 4
set sql_mode = '';

--echo -----------------------------------------------------------------------------------------------------------------
--echo ### 本次支持的类型：double、float、decimal、timestamp 作为range columns分区的分区键。
--echo ### 分区交换，基本功能验证。

--disable_warnings
drop table if exists t_range_partition_1;
--enable_warnings

CREATE TABLE t_range_partition_1 (
    c1 DOUBLE NOT NULL,
    c2 FLOAT NOT NULL,
    c3 DECIMAL(10, 2) NOT NULL,
    c4 TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP,
    UNIQUE KEY uidx_c1_c2_c3_c4 (c1, c3, c4)
) 
PARTITION BY RANGE COLUMNS(c1, c3, c4) (
    PARTITION p0 VALUES LESS THAN (-1E308, -9999999.99, '1970-01-01'),
    PARTITION p1 VALUES LESS THAN (0, 0.00, '2000-01-01'),
    PARTITION p2 VALUES LESS THAN (1E308, 9999999.99, '2038-01-19 03:14:07'),
    PARTITION p3 VALUES LESS THAN (1.1E308, 9999999.999, MAXVALUE)
);

INSERT INTO t_range_partition_1 (c1, c2, c3, c4) VALUES 
(-1E308, -1E+38, -9999999.99, '1969-12-31 23:59:59'),
(0.0, 0.0, 0.00, '1970-01-01 00:00:01'),
(1E-308, 1E-37, 0.01, '2000-01-02');

INSERT INTO t_range_partition_1 (c1, c2, c3, c4) VALUES 
(1E307, 1E+37, 9999999.99, '2038-01-19 03:14:07');
INSERT INTO t_range_partition_1 (c1, c2, c3, c4) VALUES 
(1E308, 1E+37, 9999999.999, '2038-01-19 03:14:08');

SELECT * FROM t_range_partition_1 PARTITION(p0);
SELECT * FROM t_range_partition_1 PARTITION(p1);
SELECT * FROM t_range_partition_1 PARTITION(p2);
SELECT * FROM t_range_partition_1 PARTITION(p3);

--echo ### 分区交换，NT表为分区表，预期报错
--disable_warnings
drop table if exists t_range_partition_2;
--enable_warnings

CREATE TABLE T_RANGE_PARTITION_2 (
    C1 DOUBLE,
    C2 FLOAT,
    C3 DECIMAL(10, 2),
    C4 TIMESTAMP
) 
PARTITION BY RANGE COLUMNS(C1, C3, C4) (
    PARTITION NEW_P0 VALUES LESS THAN (0, 0, '2000-01-01'),
    PARTITION NEW_P1 VALUES LESS THAN (1000, 1000, '2010-01-01'),
    PARTITION NEW_P2 VALUES LESS THAN (5000, 5000, '2020-01-01')
);

--error 1235
ALTER TABLE T_RANGE_PARTITION_1 EXCHANGE PARTITION P0 WITH TABLE T_RANGE_PARTITION_2 WITHOUT VALIDATION;

--echo ### 分区交换，NT表定义与PT表不一致，预期报错
--disable_warnings
drop table if exists t_range_partition_2;
--enable_warnings

CREATE TABLE T_RANGE_PARTITION_2 (
    C1 DOUBLE,
    C2 FLOAT,
    C3 DECIMAL(10, 2),
    C4 TIMESTAMP
);
--error 1736
ALTER TABLE T_RANGE_PARTITION_1 EXCHANGE PARTITION P0 WITH TABLE T_RANGE_PARTITION_2 WITHOUT VALIDATION;

--echo ### 分区交换，NT表定义与PT表一致，预期正常交换分区数据。
--disable_warnings
drop table if exists t_range_partition_2;
--enable_warnings

CREATE TABLE T_RANGE_PARTITION_2 (
    c1 DOUBLE NOT NULL,
    c2 FLOAT NOT NULL,
    c3 DECIMAL(10, 2) NOT NULL,
    c4 TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP,
    UNIQUE KEY uidx_c1_c2_c3_c4 (c1, c3, c4)
) ;
ALTER TABLE T_RANGE_PARTITION_1 EXCHANGE PARTITION P0 WITH TABLE T_RANGE_PARTITION_2 WITHOUT VALIDATION;
SELECT * FROM T_RANGE_PARTITION_1 PARTITION(P0);
SELECT * FROM T_RANGE_PARTITION_1 PARTITION(P1);
SELECT * FROM T_RANGE_PARTITION_1 PARTITION(P2);
SELECT * FROM T_RANGE_PARTITION_1 PARTITION(P3);

SELECT * FROM T_RANGE_PARTITION_2 PARTITION(P0);
--ERROR 1735
SELECT * FROM T_RANGE_PARTITION_2 PARTITION(P1);

SELECT * FROM T_RANGE_PARTITION_2;

--echo ### NT表为非分区表，没有分区信息。
--disable_result_log
SHOW CREATE TABLE T_RANGE_PARTITION_2;
SELECT  E.TABLE_NAME,E.PARTITION_NAME,E.SUBPARTITION_NAME,E.PARTITION_ORDINAL_POSITION,E.SUBPARTITION_ORDINAL_POSITION,E.PARTITION_METHOD,E.PARTITION_EXPRESSION,E.PARTITION_DESCRIPTION,E.TABLE_ROWS,E.AVG_ROW_LENGTH,E.DATA_LENGTH,E.CREATE_TIME,E.UPDATE_TIME
FROM    INFORMATION_SCHEMA.PARTITIONS   E  WHERE TABLE_NAME = 'T_RANGE_PARTITION_2';
--enable_result_log

INSERT INTO t_range_partition_1 (c1, c2, c3, c4) VALUES 
(-1E308, -1E+3, -9999999.99, '1901-12-31 23:59:59');
ALTER TABLE T_RANGE_PARTITION_1 EXCHANGE PARTITION P0 WITH TABLE T_RANGE_PARTITION_2 WITHOUT VALIDATION;
SELECT * FROM T_RANGE_PARTITION_1 PARTITION(P0);
SELECT * FROM T_RANGE_PARTITION_2 PARTITION(P0);

--echo ### 不在p0分区范围内的数据，可以交换成功。
--disable_warnings
drop table if exists t_range_partition_2;
--enable_warnings

CREATE TABLE T_RANGE_PARTITION_2 (
    c1 DOUBLE NOT NULL,
    c2 FLOAT NOT NULL,
    c3 DECIMAL(10, 2) NOT NULL,
    c4 TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP,
    UNIQUE KEY uidx_c1_c2_c3_c4 (c1, c3, c4)
) ;
INSERT INTO T_RANGE_PARTITION_2 (c1, c2, c3, c4) VALUES 
(-1E308, -1E+3, -9999999.99, '1971-12-31 23:59:59');
ALTER TABLE T_RANGE_PARTITION_1 EXCHANGE PARTITION P0 WITH TABLE T_RANGE_PARTITION_2 WITHOUT VALIDATION;
SELECT * FROM T_RANGE_PARTITION_1 PARTITION(P0);
SELECT * FROM T_RANGE_PARTITION_2 PARTITION(P0);

ALTER TABLE t_range_partition_1 EXCHANGE PARTITION p0 WITH TABLE T_RANGE_PARTITION_2 WITHOUT VALIDATION;
--error 1505
ALTER TABLE T_RANGE_PARTITION_2 EXCHANGE PARTITION p0 WITH TABLE t_range_partition_1 WITHOUT VALIDATION;

ALTER TABLE T_RANGE_PARTITION_1 EXCHANGE PARTITION P2 WITH TABLE T_RANGE_PARTITION_2 WITHOUT VALIDATION;
SELECT * FROM T_RANGE_PARTITION_1 PARTITION(P0);
SELECT * FROM T_RANGE_PARTITION_1 PARTITION(P2);
SELECT * FROM T_RANGE_PARTITION_2 PARTITION(P0);
--error 1735
SELECT * FROM T_RANGE_PARTITION_2 PARTITION(P2);


--echo ### 非P0分区交换查看结果。
--disable_warnings
drop table if exists t_range_partition_2;
--enable_warnings

CREATE TABLE T_RANGE_PARTITION_2 (
    c1 DOUBLE NOT NULL,
    c2 FLOAT NOT NULL,
    c3 DECIMAL(10, 2) NOT NULL,
    c4 TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP,
    UNIQUE KEY uidx_c1_c2_c3_c4 (c1, c3, c4)
) ;
INSERT INTO T_RANGE_PARTITION_2 (c1, c2, c3, c4) VALUES 
(-1E308, -1E+3, -9999999.99, '1971-12-31 23:59:59');

SELECT * FROM T_RANGE_PARTITION_1 PARTITION(P0);
SELECT * FROM T_RANGE_PARTITION_1 PARTITION(P1);
SELECT * FROM T_RANGE_PARTITION_1 PARTITION(P2);
SELECT * FROM T_RANGE_PARTITION_1 PARTITION(P3);
ALTER TABLE T_RANGE_PARTITION_1 EXCHANGE PARTITION P2 WITH TABLE T_RANGE_PARTITION_2 WITHOUT VALIDATION;
SELECT * FROM T_RANGE_PARTITION_1 PARTITION(P0);
SELECT * FROM T_RANGE_PARTITION_1 PARTITION(P2);
SELECT * FROM T_RANGE_PARTITION_2 PARTITION(P0);
--error 1735
SELECT * FROM T_RANGE_PARTITION_2 PARTITION(P2);

--echo ### 视图校验
--disable_warnings
drop VIEW if exists V_range_partition_1;
--enable_warnings
CREATE OR REPLACE VIEW V_range_partition_1 AS SELECT * FROM t_range_partition_2;
--error 1235
ALTER TABLE t_range_partition_1 EXCHANGE PARTITION p0 WITH TABLE V_range_partition_1 WITHOUT VALIDATION;

--echo ### 分区交换，自己内部交换、和其他缺失分区表进行交换，预期失败
--ERROR 1066
ALTER TABLE T_RANGE_PARTITION_1 EXCHANGE PARTITION P0 WITH TABLE T_RANGE_PARTITION_1 WITHOUT VALIDATION;
--ERROR 1064
ALTER TABLE T_RANGE_PARTITION_1 AS PT EXCHANGE PARTITION P0 WITH TABLE T_RANGE_PARTITION_1 AS NT WITHOUT VALIDATION;
--ERROR 1066
ALTER TABLE T_RANGE_PARTITION_1 EXCHANGE PARTITION P1 WITH TABLE T_RANGE_PARTITION_1 WITHOUT VALIDATION;

--ERROR 1064
ALTER TABLE T_RANGE_PARTITION_1 EXCHANGE PARTITION P3 WITH TABLE T_RANGE_PARTITION_2 P0 WITHOUT VALIDATION;
--ERROR 1064
ALTER TABLE T_RANGE_PARTITION_1 EXCHANGE PARTITION P3 WITH TABLE T_RANGE_PARTITION_2(P0) WITHOUT VALIDATION;


--echo ### 相同表结构的分区table，预期不支持交换。
--disable_warnings
drop table if exists temp_partition;
--enable_warnings

CREATE TABLE temp_partition LIKE t_range_partition_1;
ALTER TABLE temp_partition DROP PARTITION p0;
ALTER TABLE temp_partition DROP PARTITION p2;
--error 1235
ALTER TABLE t_range_partition_1 EXCHANGE PARTITION p1 WITH TABLE temp_partition WITHOUT VALIDATION;
--error 1064
ALTER TABLE temp_partition REMOVE PARTITIONING;

ALTER TABLE t_range_partition_1 DROP PARTITION p2;
--error 1493
ALTER TABLE t_range_partition_1
ADD PARTITION (PARTITION p2 VALUES LESS THAN (1E308, 9999999.99, '2038-01-19 03:14:07'));

ALTER TABLE t_range_partition_1 DROP PARTITION p3;
ALTER TABLE t_range_partition_1
ADD PARTITION (PARTITION p2 VALUES LESS THAN (1E308, 9999999.99, '2038-01-19 03:14:07'));
--error 1235
ALTER TABLE t_range_partition_1 EXCHANGE PARTITION p2 WITH TABLE temp_partition WITHOUT VALIDATION;

ALTER TABLE temp_partition DROP PARTITION p1;
--error 1508
ALTER TABLE temp_partition DROP PARTITION p3;

--disable_warnings
drop table if exists temp_partition;
--enable_warnings

--echo ### 相同表结构的非分区table，预期不支持交换。
--disable_warnings
drop table if exists t_range_partition_2;
--enable_warnings

CREATE TABLE T_RANGE_PARTITION_2 (
    c1 DOUBLE NOT NULL,
    c2 FLOAT NOT NULL,
    c3 DECIMAL(10, 2) NOT NULL,
    c4 TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP,
    UNIQUE KEY uidx_c1_c2_c3_c4 (c1, c3, c4)
) ;

--disable_warnings
drop table if exists t_range_partition_22;
--enable_warnings

CREATE TABLE t_range_partition_22 (
    c1 DOUBLE NOT NULL,
    c2 FLOAT NOT NULL,
    c3 DECIMAL(10, 2) NOT NULL,
    c4 TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP,
    UNIQUE KEY uidx_c1_c2_c3_c4 (c1, c3, c4)
) ;
--error 1505
ALTER TABLE t_range_partition_2 EXCHANGE PARTITION p0 WITH TABLE t_range_partition_22 WITHOUT VALIDATION;

--echo ### 分区交换，字段类型不同进行交换
--disable_warnings
drop table if exists t_range_partition_1;
--enable_warnings

CREATE TABLE t_range_partition_1 (
    c1 DOUBLE,
    c2 FLOAT,
    c3 DECIMAL(10, 2),
    c4 TIMESTAMP
) 
PARTITION BY RANGE COLUMNS(c1, c3, c4) (
    PARTITION p0 VALUES LESS THAN (0, 0, '2000-01-01'),
    PARTITION p1 VALUES LESS THAN (1000, 1000, '2010-01-01'),
    PARTITION p2 VALUES LESS THAN (5000, 5000, '2020-01-01')
);

INSERT INTO t_range_partition_1 (c1, c2, c3, c4) VALUES 
