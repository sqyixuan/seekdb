SELECT * FROM EMP PARTITION(P1000) ORDER BY EMPNO,SAL,DEPTNO; 
SELECT * FROM EMP PARTITION(P2000) ORDER BY EMPNO,SAL,DEPTNO;
SELECT * FROM EMP PARTITION(P3000) ORDER BY EMPNO,SAL,DEPTNO;
SELECT * FROM EMP PARTITION(P1000sPART001) ORDER BY EMPNO,SAL,DEPTNO; 
SELECT * FROM EMP PARTITION(P2000sPART002) ORDER BY EMPNO,SAL,DEPTNO;
SELECT * FROM EMP PARTITION(P3000sPART003) ORDER BY EMPNO,SAL,DEPTNO;

SELECT * FROM EMP PARTITION(P1000);
WITH emp_p1000 AS (SELECT * FROM EMP PARTITION(P1000))
SELECT * FROM emp_p1000;
SELECT DISTINCT ENAME FROM EMP PARTITION(P1000);
SELECT * FROM EMP PARTITION(P1000) WHERE ENAME LIKE 'EMP_PART%';
SELECT ENAME, AVG(SAL) AS AVG_SAL FROM EMP PARTITION(P1000)
GROUP BY ENAME
HAVING AVG_SAL > 1000;
SELECT * FROM EMP PARTITION(P1000)
UNION ALL
SELECT * FROM EMP PARTITION(P2000);
SELECT * FROM EMP PARTITION(P1000) ORDER BY SAL DESC;
SELECT * FROM EMP PARTITION(P1000) ORDER BY EMPNO LIMIT 5;
WITH emp_p1000 AS (
    SELECT * FROM EMP PARTITION(P1000) WHERE ENAME LIKE 'EMP_PART%'
)
SELECT DISTINCT emp_p1000.*, EMP.DEPTNO
FROM emp_p1000
JOIN EMP ON emp_p1000.DEPTNO = EMP.DEPTNO
WHERE emp_p1000.SAL > 500 
GROUP BY emp_p1000.ENAME
HAVING MAX(emp_p1000.SAL) < 4000
ORDER BY emp_p1000.SAL DESC
LIMIT 5;

--echo ### 分区裁剪- 查询条件只包含父分区的分区键
TRUNCATE TABLE EMP;
EXPLAIN SELECT * FROM EMP WHERE EMPNO < 1000.0;
EXPLAIN SELECT * FROM EMP WHERE EMPNO >= 5000.0 AND EMPNO < 10000.0;

--echo ### 分区裁剪- 查询条件只包含子分区的分区键。子分区通过向量比较裁剪
EXPLAIN SELECT * FROM EMP WHERE SAL < 15.0;
EXPLAIN SELECT * FROM EMP WHERE DEPTNO < 10.0;
EXPLAIN SELECT * FROM EMP WHERE HIREDATE < '2000-01-01 00:00:00';

EXPLAIN SELECT * FROM EMP WHERE (SAL,HIREDATE) < ( 15,'2000-01-01 00:00:00');
EXPLAIN SELECT * FROM EMP WHERE (SAL,HIREDATE) < ( 150,'2010-01-01 00:00:00');
EXPLAIN SELECT * FROM EMP WHERE (SAL,HIREDATE) < ( 1500,'2020-01-01 00:00:00');
EXPLAIN SELECT * FROM EMP WHERE (SAL,HIREDATE) = ( 15,'2000-01-01 00:00:00');
EXPLAIN SELECT * FROM EMP WHERE (SAL,HIREDATE) = ( 150,'2010-01-01 00:00:00');
EXPLAIN SELECT * FROM EMP WHERE (SAL,HIREDATE) = ( 1500,'2020-01-01 00:00:00');
EXPLAIN SELECT * FROM EMP WHERE (SAL,HIREDATE) > ( 15,'2000-01-01 00:00:00');
EXPLAIN SELECT * FROM EMP WHERE (SAL,HIREDATE) > ( 150,'2010-01-01 00:00:00');
EXPLAIN SELECT * FROM EMP WHERE (SAL,HIREDATE) > ( 1500,'2020-01-01 00:00:00');

EXPLAIN SELECT * FROM EMP WHERE (SAL,DEPTNO,HIREDATE)<(15.0, 10, '2000-01-01 00:00:00');
EXPLAIN SELECT * FROM EMP WHERE (SAL,DEPTNO,HIREDATE)<(1000.0, 20, '2010-01-01 00:00:00');
EXPLAIN SELECT * FROM EMP WHERE (SAL,DEPTNO,HIREDATE)<(5000.0, 50, '2020-01-01 00:00:00');
EXPLAIN SELECT * FROM EMP WHERE (SAL,DEPTNO,HIREDATE)=(15.0, 10, '2000-01-01 00:00:00');
EXPLAIN SELECT * FROM EMP WHERE (SAL,DEPTNO,HIREDATE)=(1000.0, 20, '2010-01-01 00:00:00');
EXPLAIN SELECT * FROM EMP WHERE (SAL,DEPTNO,HIREDATE)=(5000.0, 50, '2020-01-01 00:00:00');
EXPLAIN SELECT * FROM EMP WHERE (SAL,DEPTNO,HIREDATE)>(15.0, 10, '2000-01-01 00:00:00');
EXPLAIN SELECT * FROM EMP WHERE (SAL,DEPTNO,HIREDATE)>(1000.0, 20, '2010-01-01 00:00:00');
EXPLAIN SELECT * FROM EMP WHERE (SAL,DEPTNO,HIREDATE)>(5000.0, 50, '2020-01-01 00:00:00');

EXPLAIN SELECT * FROM EMP WHERE (SAL,DEPTNO,HIREDATE)<(1000.0, 200, '2010-01-01 00:00:00');
EXPLAIN SELECT * FROM EMP WHERE (SAL,DEPTNO,HIREDATE)=(1000.0, 20, '2010-01-01 00:00:01');
EXPLAIN SELECT * FROM EMP WHERE (SAL,DEPTNO,HIREDATE)>(9000.0, 20, '2010-01-01 00:00:00');

--echo ### 分区裁剪- 查询条件包含父/子分区的分区键
EXPLAIN SELECT * FROM EMP WHERE EMPNO < 5000.0 AND SAL < 1000;
EXPLAIN SELECT * FROM EMP WHERE EMPNO < 5000.0 AND SAL < 1000.0 AND DEPTNO < 10.0 AND HIREDATE < '2010-01-01 00:00:00';

--echo ### 分区裁剪- 等值比较的查询条件(如 in/= )
EXPLAIN SELECT * FROM EMP WHERE EMPNO = 499.99;
EXPLAIN SELECT * FROM EMP WHERE EMPNO IN (499.99, 4999.99);
EXPLAIN SELECT * FROM EMP WHERE SAL = 999.99;
EXPLAIN SELECT * FROM EMP WHERE SAL = 999.99 AND DEPTNO = 19 AND HIREDATE = '2009-12-31 23:59:59';

--echo ### 分区裁剪-  fn(col) 简单形式的查询条件
EXPLAIN SELECT * FROM EMP WHERE YEAR(HIREDATE) = 1999;
EXPLAIN SELECT * FROM EMP WHERE CEIL(EMPNO) = 5000;

--echo ### 分区裁剪- 查询条件是having，进行等值比较的查询
EXPLAIN SELECT DEPTNO, AVG(SAL) AS AVG_SALARY 
FROM EMP 
GROUP BY DEPTNO 
HAVING AVG_SALARY = 1000.0;

EXPLAIN SELECT EMPNO, COUNT(*) 
FROM EMP 
GROUP BY EMPNO 
HAVING EMPNO = 1000.0;

--echo ### 分区裁剪- 边界值查询(如 小于最小值)
EXPLAIN SELECT * FROM EMP WHERE EMPNO < 0;
EXPLAIN SELECT * FROM EMP WHERE HIREDATE < '1900-01-01 00:00:00';

--echo ### 分区裁剪- 多范围的查询条件(如 and, or)
EXPLAIN SELECT * FROM EMP WHERE EMPNO >= 1000.0 AND EMPNO <= 5000.0;
EXPLAIN SELECT * FROM EMP WHERE EMPNO < 1000.0 OR EMPNO > 5000.0;
EXPLAIN SELECT * FROM EMP WHERE (EMPNO < 500.0 AND SAL > 100.0) OR (DEPTNO > 30 AND HIREDATE > '2010-01-01 00:00:00');

--echo ### 分区裁剪- 区间比较的查询条件(如 between...and, >, <,  >=, <= )
EXPLAIN SELECT * FROM EMP WHERE EMPNO BETWEEN 1000.0 AND 5000.0;
EXPLAIN SELECT * FROM EMP WHERE EMPNO > 1000.0 AND EMPNO < 5000.0;
EXPLAIN SELECT * FROM EMP WHERE SAL <= 1000.00;
EXPLAIN SELECT * FROM EMP WHERE EMPNO <= 5000.0 AND HIREDATE >= '2000-01-01 00:00:00';

--echo ### 分区裁剪- inner join 条件放在on中。且包含以上各个场景
--DISABLE_WARNINGS
DROP TABLE IF EXISTS EMP_2;
--ENABLE_WARNINGS

CREATE TABLE EMP_2 (
    EMPNO DOUBLE,
    ENAME VARCHAR(100),
    JOB VARCHAR(100),
    MGR INT,
    HIREDATE TIMESTAMP,
    SAL DOUBLE,
    COMM INT,
    DEPTNO DECIMAL,
    COMID INT
)
PARTITION BY RANGE COLUMNS(EMPNO) 
SUBPARTITION BY RANGE COLUMNS(SAL,DEPTNO,HIREDATE) 
SUBPARTITION TEMPLATE (
    SUBPARTITION PART001 VALUES LESS THAN (15.0, 10, '2000-01-01 00:00:00'),
    SUBPARTITION PART002 VALUES LESS THAN (1000.0, 20, '2010-01-01 00:00:00'),
    SUBPARTITION PART003 VALUES LESS THAN (5000.0, 50, '2020-01-01 00:00:00')
) (
    PARTITION P1000 VALUES LESS THAN (500.0),
    PARTITION P2000 VALUES LESS THAN (5000.0),
    PARTITION P3000 VALUES LESS THAN (15000.0)
);

