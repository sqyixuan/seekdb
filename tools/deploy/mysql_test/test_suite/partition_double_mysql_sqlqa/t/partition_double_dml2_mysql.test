--echo ### 分区裁剪- 查询条件只包含父分区的分区键
TRUNCATE TABLE EMP_2;
EXPLAIN SELECT * FROM EMP INNER JOIN EMP_2 ON EMP.EMPNO = EMP_2.EMPNO WHERE EMP.EMPNO < 1000.0;
EXPLAIN SELECT * FROM EMP INNER JOIN EMP_2 ON EMP.EMPNO = EMP_2.EMPNO WHERE EMP.EMPNO >= 5000.0 AND EMP.EMPNO < 10000.0;

--echo ### 分区裁剪- 查询条件只包含子分区的分区键
EXPLAIN SELECT * FROM EMP INNER JOIN EMP_2 ON EMP.SAL = EMP_2.SAL WHERE (EMP.SAL,EMP.HIREDATE) < ( 15,'2000-01-01 00:00:00');
EXPLAIN SELECT * FROM EMP INNER JOIN EMP_2 ON EMP.SAL = EMP_2.SAL WHERE (EMP.SAL,EMP.HIREDATE) < ( 150,'2010-01-01 00:00:00');
EXPLAIN SELECT * FROM EMP INNER JOIN EMP_2 ON EMP.SAL = EMP_2.SAL WHERE (EMP.SAL,EMP.HIREDATE) < ( 1500,'2020-01-01 00:00:00');
EXPLAIN SELECT * FROM EMP INNER JOIN EMP_2 ON EMP.SAL = EMP_2.SAL WHERE (EMP.SAL,EMP.HIREDATE) = ( 15,'2000-01-01 00:00:00');
EXPLAIN SELECT * FROM EMP INNER JOIN EMP_2 ON EMP.SAL = EMP_2.SAL WHERE (EMP.SAL,EMP.HIREDATE) = ( 150,'2010-01-01 00:00:00');
EXPLAIN SELECT * FROM EMP INNER JOIN EMP_2 ON EMP.SAL = EMP_2.SAL WHERE (EMP.SAL,EMP.HIREDATE) = ( 1500,'2020-01-01 00:00:00');
EXPLAIN SELECT * FROM EMP INNER JOIN EMP_2 ON EMP.SAL = EMP_2.SAL WHERE (EMP.SAL,EMP.HIREDATE) > ( 15,'2000-01-01 00:00:00');
EXPLAIN SELECT * FROM EMP INNER JOIN EMP_2 ON EMP.SAL = EMP_2.SAL WHERE (EMP.SAL,EMP.HIREDATE) > ( 150,'2010-01-01 00:00:00');
EXPLAIN SELECT * FROM EMP INNER JOIN EMP_2 ON EMP.SAL = EMP_2.SAL WHERE (EMP.SAL,EMP.HIREDATE) > ( 1500,'2020-01-01 00:00:00');

EXPLAIN SELECT * FROM EMP INNER JOIN EMP_2 ON EMP.SAL = EMP_2.SAL WHERE (EMP.SAL,EMP.DEPTNO,EMP.HIREDATE)<(15.0, 10, '2000-01-01 00:00:00');
