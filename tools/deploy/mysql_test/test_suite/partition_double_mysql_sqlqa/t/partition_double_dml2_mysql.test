# owner: yibo.tyf
# owner group: sql1
# description: MySQL模式支持double等类型作为分区键，二级分区表，DML相关操作验证
# tags: partition
# author: wb-sl672505

purge recyclebin;
let $char_charset = 'utf8';
--disable_warnings
drop database if exists sltest;
--enable_warnings
create database sltest;
use sltest;
set timestamp = 1600000000;
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;
set @@session.explicit_defaults_for_timestamp=off;
--result_format 4
set sql_mode = '';

--echo -----------------------------------------------------------------------------------------------------------------
--echo ### 本次支持的类型：double、float、decimal、timestamp 作为range columns分区的分区键。

--DISABLE_WARNINGS
DROP TABLE IF EXISTS EMP;
--ENABLE_WARNINGS

CREATE TABLE EMP (
    EMPNO DOUBLE,
    ENAME VARCHAR(100),
    JOB VARCHAR(100),
    MGR INT,
    HIREDATE TIMESTAMP,
    SAL FLOAT(8,2),
    COMM INT,
    DEPTNO DECIMAL,
    COMID INT
)
PARTITION BY RANGE COLUMNS(EMPNO) 
SUBPARTITION BY RANGE COLUMNS(SAL,DEPTNO,HIREDATE) 
SUBPARTITION TEMPLATE (
    SUBPARTITION PART001 VALUES LESS THAN (15.0, 10.0, '2000-01-01 00:00:00'),
    SUBPARTITION PART002 VALUES LESS THAN (1000.0, 20.0, '2010-01-01 00:00:00'),
    SUBPARTITION PART003 VALUES LESS THAN (5000.0, 50.0, '2020-01-01 00:00:00')
) (
    PARTITION P1000 VALUES LESS THAN (500.0),
    PARTITION P2000 VALUES LESS THAN (5000.0),
    PARTITION P3000 VALUES LESS THAN (MAXVALUE)
);

INSERT INTO EMP (EMPNO, ENAME, JOB, MGR, HIREDATE, SAL, COMM, DEPTNO, COMID) VALUES 
(499.99, 'EMP_PART001', 'JOB1', 1, '1999-12-31 23:59:59', 14.99, 0, 9, 1), 
(499.99, 'EMP_PART002', 'JOB2', 2, '2009-12-31 23:59:59', 999.99, 0, 19, 2),
(499.99, 'EMP_PART003', 'JOB3', 3, '2019-12-31 23:59:59', 4999.99, 0, 49, 3),

(4999.99, 'EMP_PART004', 'JOB4', 4, '1999-12-31 23:59:59', 14.99, 0, 9, 4),
(4999.99, 'EMP_PART005', 'JOB5', 5, '2009-12-31 23:59:59', 999.99, 0, 19, 5),
(4999.99, 'EMP_PART006', 'JOB6', 6, '2019-12-31 23:59:59', 4999.99, 0, 49, 6),

(5000.00, 'EMP_PART007', 'JOB7', 7, '1999-12-31 23:59:59', 14.99, 0, 9, 7),
(5000.00, 'EMP_PART008', 'JOB8', 8, '2009-12-31 23:59:59', 999.99, 0, 19, 8),
(5000.00, 'EMP_PART009', 'JOB9', 9, '2019-12-31 23:59:59', 4999.99, 0, 49, 9);

SELECT * FROM EMP PARTITION(P1000) ORDER BY EMPNO,SAL,DEPTNO; 
SELECT * FROM EMP PARTITION(P2000) ORDER BY EMPNO,SAL,DEPTNO;
SELECT * FROM EMP PARTITION(P3000) ORDER BY EMPNO,SAL,DEPTNO;

--DISABLE_WARNINGS
DROP TABLE IF EXISTS EMP_2;
--ENABLE_WARNINGS

CREATE TABLE EMP_2 (
    EMPNO DOUBLE,
    ENAME VARCHAR(100),
    JOB VARCHAR(100),
    MGR INT,
    HIREDATE TIMESTAMP,
    SAL FLOAT(8,2),
    COMM INT,
    DEPTNO DECIMAL,
    COMID INT
)
PARTITION BY RANGE COLUMNS(EMPNO) 
SUBPARTITION BY RANGE COLUMNS(SAL, DEPTNO, HIREDATE) 
SUBPARTITION TEMPLATE (
    SUBPARTITION PART001 VALUES LESS THAN (10.0, 5.0, '1990-01-01 00:00:00'),
    SUBPARTITION PART002 VALUES LESS THAN (2000.0, 40.0, '2000-01-01 00:00:00'),
    SUBPARTITION PART003 VALUES LESS THAN (10000.0, 100.0, '2010-01-01 00:00:00')
) (
    PARTITION P100 VALUES LESS THAN (1000.0),
    PARTITION P200 VALUES LESS THAN (10000.0),
    PARTITION P300 VALUES LESS THAN (MAXVALUE)
);

INSERT INTO EMP_2 SELECT * FROM EMP;

SELECT * FROM EMP_2 PARTITION(P100) ORDER BY EMPNO,SAL,DEPTNO; 
SELECT * FROM EMP_2 PARTITION(P200) ORDER BY EMPNO,SAL,DEPTNO;
SELECT * FROM EMP_2 PARTITION(P300) ORDER BY EMPNO,SAL,DEPTNO;

--echo #### UPDATE 
UPDATE EMP 
SET 
    ENAME = CASE
                WHEN SAL < 15 AND DEPTNO < 10 THEN CONCAT(ENAME, '_UPDATED')
                ELSE ENAME
            END, 
    JOB = CASE
              WHEN SAL >= 15 AND SAL < 1000 AND DEPTNO >= 10 AND DEPTNO < 20 THEN CONCAT(JOB, '_CHANGED')
              ELSE JOB
          END 
WHERE 
    (EMPNO < 500 AND SAL < 15 AND DEPTNO < 10) OR 
    (EMPNO < 500 AND SAL >= 15 AND SAL < 1000 AND DEPTNO >= 10 AND DEPTNO < 20) OR 
    (EMPNO >= 500 AND EMPNO < 5000 AND SAL >= 1000 AND SAL < 5000 AND DEPTNO >= 20 AND DEPTNO < 50); 

SELECT * FROM EMP PARTITION(P1000) ORDER BY EMPNO,SAL,DEPTNO; 
SELECT * FROM EMP PARTITION(P2000) ORDER BY EMPNO,SAL,DEPTNO;
SELECT * FROM EMP PARTITION(P3000) ORDER BY EMPNO,SAL,DEPTNO;

UPDATE EMP
SET 
    EMPNO = EMPNO + 1000,
    SAL = SAL * 10,
    DEPTNO = DEPTNO * 2, 
    HIREDATE = DATE_ADD(HIREDATE, INTERVAL 10 YEAR)
WHERE 
    EMPNO < 500 AND SAL < 1000 AND DEPTNO < 20 AND
    (EMPNO + 1000) < 5000 AND (SAL * 10) < 5000 AND (DEPTNO * 2) < 50;
SELECT * FROM EMP PARTITION(P1000) ORDER BY EMPNO,SAL,DEPTNO; 
SELECT * FROM EMP PARTITION(P2000) ORDER BY EMPNO,SAL,DEPTNO;
SELECT * FROM EMP PARTITION(P3000) ORDER BY EMPNO,SAL,DEPTNO;

ALTER TABLE EMP
PARTITION BY RANGE COLUMNS(EMPNO) 
SUBPARTITION BY RANGE COLUMNS(SAL,DEPTNO,HIREDATE) 
SUBPARTITION TEMPLATE (
    SUBPARTITION PART001 VALUES LESS THAN (15.0, 10.0, '2000-01-01 00:00:00'),
    SUBPARTITION PART002 VALUES LESS THAN (1000.0, 20.0, '2010-01-01 00:00:00'),
    SUBPARTITION PART003 VALUES LESS THAN (5000.0, 50.0, '2020-01-01 00:00:00')
) (
    PARTITION P1000 VALUES LESS THAN (500.0),
    PARTITION P2000 VALUES LESS THAN (5000.0),
    PARTITION P3000 VALUES LESS THAN (15000.0)
);

--ERROR 1526
UPDATE EMP
SET EMPNO = EMPNO + 11000
WHERE EMPNO < 11000;

--echo #### DELETE 
DELETE FROM EMP WHERE EMPNO < 500.0;
DELETE FROM EMP WHERE EMPNO < 5000.0;
DELETE FROM EMP WHERE EMPNO < 15000.0;
DELETE FROM EMP PARTITION(P1000) WHERE EMPNO < 500.0;
DELETE FROM EMP PARTITION(P2000sPART001) WHERE EMPNO < 500.0;
--error 1064
DELETE FROM EMP SUBPARTITION(P2000sPART001) WHERE EMPNO < 500.0;
DELETE FROM EMP WHERE EMPNO < 15000.0;

--echo ####  分区裁剪补充测试
--DISABLE_WARNINGS
DROP TABLE IF EXISTS EMP;
--ENABLE_WARNINGS
CREATE TABLE EMP (
    EMPNO DOUBLE,
    SAL DOUBLE,
    DEPTNO DOUBLE,
    HIREDATE TIMESTAMP
)
PARTITION BY RANGE COLUMNS(EMPNO) 
SUBPARTITION BY RANGE COLUMNS(SAL,HIREDATE) 
SUBPARTITION TEMPLATE (
    SUBPARTITION PART001 VALUES LESS THAN ( 15,'2000-01-01 00:00:00'),
    SUBPARTITION PART002 VALUES LESS THAN ( 150,'2010-01-01 00:00:00'),
    SUBPARTITION PART003 VALUES LESS THAN ( 1500,'2020-01-01 00:00:00')
) (
    PARTITION P1000 VALUES LESS THAN (500),
    PARTITION P2000 VALUES LESS THAN (5000),
    PARTITION P3000 VALUES LESS THAN (15000)
);
EXPLAIN SELECT * FROM EMP WHERE HIREDATE < '2000-01-01 00:00:00';
EXPLAIN SELECT * FROM EMP WHERE (SAL,HIREDATE) < ( 15,'2000-01-01 00:00:00');
EXPLAIN SELECT * FROM EMP WHERE (SAL,HIREDATE) < ( 150,'2010-01-01 00:00:00');
EXPLAIN SELECT * FROM EMP WHERE (SAL,HIREDATE) < ( 1500,'2020-01-01 00:00:00');
EXPLAIN SELECT * FROM EMP WHERE (SAL,HIREDATE) = ( 15,'2000-01-01 00:00:00');
EXPLAIN SELECT * FROM EMP WHERE (SAL,HIREDATE) = ( 150,'2010-01-01 00:00:00');
EXPLAIN SELECT * FROM EMP WHERE (SAL,HIREDATE) = ( 1500,'2020-01-01 00:00:00');
EXPLAIN SELECT * FROM EMP WHERE (SAL,HIREDATE) > ( 15,'2000-01-01 00:00:00');
EXPLAIN SELECT * FROM EMP WHERE (SAL,HIREDATE) > ( 150,'2010-01-01 00:00:00');
EXPLAIN SELECT * FROM EMP WHERE (SAL,HIREDATE) > ( 1500,'2020-01-01 00:00:00');

--DISABLE_WARNINGS
DROP TABLE IF EXISTS EMP;
--ENABLE_WARNINGS
CREATE TABLE EMP (
    EMPNO DOUBLE,
    SAL DOUBLE,
    DEPTNO DOUBLE,
    HIREDATE TIMESTAMP
)
PARTITION BY RANGE COLUMNS(EMPNO) 
SUBPARTITION BY RANGE COLUMNS(HIREDATE) 
SUBPARTITION TEMPLATE (
    SUBPARTITION PART001 VALUES LESS THAN ( '2000-01-01 00:00:00'),
    SUBPARTITION PART002 VALUES LESS THAN ( '2010-01-01 00:00:00'),
    SUBPARTITION PART003 VALUES LESS THAN ( '2020-01-01 00:00:00')
) (
    PARTITION P1000 VALUES LESS THAN (500),
    PARTITION P2000 VALUES LESS THAN (5000),
    PARTITION P3000 VALUES LESS THAN (15000)
);
EXPLAIN SELECT * FROM EMP WHERE HIREDATE < '2000-01-01 00:00:00';

--echo #### SELECT 

--DISABLE_WARNINGS
DROP TABLE IF EXISTS EMP;
--ENABLE_WARNINGS

CREATE TABLE EMP (
    EMPNO DOUBLE,
    ENAME VARCHAR(100),
    JOB VARCHAR(100),
    MGR INT,
    HIREDATE TIMESTAMP,
    SAL DOUBLE,
    COMM INT,
    DEPTNO DECIMAL,
    COMID INT
)
PARTITION BY RANGE COLUMNS(EMPNO) 
SUBPARTITION BY RANGE COLUMNS(SAL,DEPTNO,HIREDATE) 
SUBPARTITION TEMPLATE (
    SUBPARTITION PART001 VALUES LESS THAN (15.0, 10, '2000-01-01 00:00:00'),
    SUBPARTITION PART002 VALUES LESS THAN (1000.0, 20, '2010-01-01 00:00:00'),
    SUBPARTITION PART003 VALUES LESS THAN (5000.0, 50, '2020-01-01 00:00:00')
) (
    PARTITION P1000 VALUES LESS THAN (500.0),
    PARTITION P2000 VALUES LESS THAN (5000.0),
    PARTITION P3000 VALUES LESS THAN (15000.0)
);

