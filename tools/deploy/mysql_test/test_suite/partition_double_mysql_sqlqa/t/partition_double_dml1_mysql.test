# owner: yibo.tyf
# owner group: sql1
# description: MySQL模式支持double等类型作为分区键，一级分区表，DML相关操作验证
# tags: partition
# author: wb-sl672505

purge recyclebin;
let $char_charset = 'utf8';
--disable_warnings
drop database if exists sltest;
--enable_warnings
create database sltest;
use sltest;
set timestamp = 1600000000;
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;
set @@session.explicit_defaults_for_timestamp=off;
--result_format 4
set sql_mode = '';

--echo -----------------------------------------------------------------------------------------------------------------
--echo ### 本次支持的类型：double、float、decimal、timestamp 作为range columns分区的分区键。
--echo ###  一级分区为 range columns（double、float、decimal、timestamp）
--disable_warnings
drop table if exists t_range_partition_1;
--enable_warnings

CREATE TABLE t_range_partition_1 (
    c1 DOUBLE NOT NULL,
    c2 FLOAT NOT NULL,
    c3 DECIMAL(10, 2) NOT NULL,
    c4 TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP,
    UNIQUE KEY uidx_c1_c2_c3_c4 (c1, c3, c4)
) 
PARTITION BY RANGE COLUMNS(c1, c3, c4) (
    PARTITION p0 VALUES LESS THAN (-1E308, -9999999.99, '1970-01-01'),
    PARTITION p1 VALUES LESS THAN (0, 0.00, '2000-01-01'),
    PARTITION p2 VALUES LESS THAN (1E308, 9999999.99, '2038-01-19 03:14:07'),
    PARTITION p3 VALUES LESS THAN (1.1E308, 9999999.999, MAXVALUE)
);

--echo # DML操作,insert
--error 1367
INSERT INTO t_range_partition_1 (c1, c2, c3, c4) VALUES 
(-1E309, -1E+39, -9999999.99, '1969-12-31 23:59:59');

INSERT INTO t_range_partition_1 (c1, c2, c3, c4) VALUES 
(-1E308, 0.0, -1.00, '1970-01-01 00:00:00'),
(0.0, 0.0, 0.00, '1999-12-31 23:59:59');

INSERT INTO t_range_partition_1 (c1, c2, c3, c4) VALUES 
(0.01, 1E-37, 0.01, '2000-01-02'),
(1E307, 1E+37, 9999999.99, '2038-01-18 03:14:07');

INSERT INTO t_range_partition_1 (c1, c2, c3, c4) VALUES 
(1E308, 1E+37, 9999999.999, '2038-01-19 03:14:08'),
(1.1E308, 1E+38, 10000000.00, '9999-12-31 23:59:59');

--error 1526
INSERT INTO t_range_partition_1 (c1, c2, c3, c4) VALUES 
(1.2E308, 1E+39, 10000000.00, '10000-01-01 00:00:00');

SELECT * FROM t_range_partition_1 PARTITION(p0);
SELECT * FROM t_range_partition_1 PARTITION(p1);
SELECT * FROM t_range_partition_1 PARTITION(p2);
SELECT * FROM t_range_partition_1 PARTITION(p3);

--disable_warnings
drop table if exists t_range_partition_11;
--enable_warnings

CREATE TABLE t_range_partition_11 AS SELECT * FROM t_range_partition_1 WHERE 1=0;
INSERT INTO t_range_partition_11 select * from t_range_partition_1;

--disable_warnings
drop table if exists t_range_partition_2;
--enable_warnings

CREATE TABLE t_range_partition_2 (
    c1 DOUBLE NOT NULL,
    c2 FLOAT NOT NULL,
    c3 DECIMAL(10, 2) NOT NULL,
    c4 TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP,
    UNIQUE KEY uidx_c1_c2_c3_c4 (c1, c3, c4)
) 
PARTITION BY RANGE COLUMNS(c1, c3, c4) (
    PARTITION p0 VALUES LESS THAN (-1E307, -9999999.00, '1960-01-01'),
    PARTITION p1 VALUES LESS THAN (1, 1.00, '2010-01-01'),
    PARTITION p2 VALUES LESS THAN (2E307, 5000000.00, '2040-01-01'),
    PARTITION p3 VALUES LESS THAN (MAXVALUE, MAXVALUE, MAXVALUE)
);

INSERT INTO t_range_partition_2 SELECT * FROM t_range_partition_1;

SELECT * FROM t_range_partition_2 PARTITION(p0);
SELECT * FROM t_range_partition_2 PARTITION(p1);
SELECT * FROM t_range_partition_2 PARTITION(p2);
SELECT * FROM t_range_partition_2 PARTITION(p3);

--echo # DML操作,update
UPDATE t_range_partition_1 
SET c1 = c1 - 1E5, c2 = c2 - 1E2, c3 = c3 - 1E2, c4 = '1969-01-01 00:00:00'
WHERE c1 < (-1E308) AND c3 < -9999999.99 AND c4 < '1970-01-01';

--error 1526
UPDATE t_range_partition_1 
SET c1 = c1 + 1E5, c2 = c2 + 1E2, c3 = c3 + 1E2, c4 = '1990-01-01 00:00:00'
WHERE c1 >= 0 AND c3 >= 0.00 AND c4 >= '2000-01-01';

UPDATE t_range_partition_1 
SET c1 = c1 - 1E5, c2 = c2 - 1E2, c3 = c3 - 1E2, c4 = '2030-01-01 00:00:00'
WHERE c1 >= 1E308 AND c3 >= 9999999.99 AND c4 >= '2038-01-19 03:14:07';

SELECT * FROM t_range_partition_1 PARTITION(p0);
SELECT * FROM t_range_partition_1 PARTITION(p1);
SELECT * FROM t_range_partition_1 PARTITION(p2);
SELECT * FROM t_range_partition_1 PARTITION(p3);

UPDATE t_range_partition_1
SET c1 = -100, c2 = -100, c3 = -100, c4 = '1990-01-01'
WHERE c1 < 0 AND c3 < 0 AND c4 BETWEEN '1970-01-01' AND '2000-01-01';
--error 1062
UPDATE t_range_partition_1
SET c1 = 4500, c2 = 4500, c3 = 4500, c4 = '2015-01-01'
WHERE c1 > 1000 AND c3 > 1000 AND c4 BETWEEN '2010-01-01' AND '2039-01-01';

SELECT * FROM t_range_partition_1 PARTITION(p0);
SELECT * FROM t_range_partition_1 PARTITION(p1);
SELECT * FROM t_range_partition_1 PARTITION(p2);
SELECT * FROM t_range_partition_1 PARTITION(p3);

UPDATE t_range_partition_1
SET c1 = c1 + 500, c2 = c2 + 0.5, c3 = c3 + 0.05, c4 = '2005-01-01'
WHERE c1 >= 0 AND c1 < 1000 AND c3 >= 0 AND c3 < 1000 AND c4 BETWEEN '2000-01-01' AND '2005-01-01';

SELECT * FROM t_range_partition_1 PARTITION(p0);
SELECT * FROM t_range_partition_1 PARTITION(p1);
SELECT * FROM t_range_partition_1 PARTITION(p2);
SELECT * FROM t_range_partition_1 PARTITION(p3);

--error 1367
UPDATE t_range_partition_1 
SET c1 = 2E308,  
    c3 = 10000000.00, 
    c4 = '10000-01-01 00:00:00'; 

ALTER TABLE t_range_partition_1
ADD PARTITION (PARTITION unclassified VALUES LESS THAN (MAXVALUE, MAXVALUE, MAXVALUE));

UPDATE t_range_partition_1
SET c1 = c1 + 10000000, c2 = c2 + 0.5, c3 = c3 + 0.05, c4 = '2025-01-01'
WHERE EXISTS (
    SELECT 1
    FROM t_range_partition_1
    WHERE c1 >= 0 AND c1 < 1000 AND c3 >= 0 AND c3 < 1000 AND c4 BETWEEN '2000-01-01' AND '2020-01-01'
);

SELECT * FROM t_range_partition_1 PARTITION(p0);
SELECT * FROM t_range_partition_1 PARTITION(p1);
SELECT * FROM t_range_partition_1 PARTITION(p2);
SELECT * FROM t_range_partition_1 PARTITION(p3);

--echo ### delete 
--disable_warnings
drop table if exists t_range_partition_1;
--enable_warnings

CREATE TABLE t_range_partition_1 (
    c1 DOUBLE NOT NULL,
    c2 FLOAT NOT NULL,
    c3 DECIMAL(10, 2) NOT NULL,
    c4 TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP,
    UNIQUE KEY uidx_c1_c2_c3_c4 (c1, c3, c4)
) 
PARTITION BY RANGE COLUMNS(c1, c3, c4) (
    PARTITION p0 VALUES LESS THAN (-1E308, -9999999.99, '1970-01-01'),
    PARTITION p1 VALUES LESS THAN (0, 0.00, '2000-01-01'),
    PARTITION p2 VALUES LESS THAN (1E308, 9999999.99, '2038-01-19 03:14:07'),
    PARTITION p3 VALUES LESS THAN (1.1E308, 9999999.999, MAXVALUE)
);

INSERT INTO t_range_partition_1 (c1, c2, c3, c4) VALUES 
(-1E308, 0.0, -1.00, '1970-01-01 00:00:00'),
(0.0, 0.0, 0.00, '1999-12-31 23:59:59');

INSERT INTO t_range_partition_1 (c1, c2, c3, c4) VALUES 
(0.01, 1E-37, 0.01, '2000-01-02'),
(1E307, 1E+37, 9999999.99, '2038-01-18 03:14:07');

INSERT INTO t_range_partition_1 (c1, c2, c3, c4) VALUES 
(1E308, 1E+37, 9999999.999, '2038-01-19 03:14:08'),
(1.1E308, 1E+38, 10000000.00, '9999-12-31 23:59:59');

SELECT * FROM t_range_partition_1 PARTITION(p0);
SELECT * FROM t_range_partition_1 PARTITION(p1);
SELECT * FROM t_range_partition_1 PARTITION(p2);
SELECT * FROM t_range_partition_1 PARTITION(p3);

DELETE FROM t_range_partition_1 
WHERE (c1, c3, c4) < (-1E308, -9999999.99, '1970-01-01');

DELETE FROM t_range_partition_1 
WHERE (c1, c3, c4) >= (-1E308, -9999999.99, '1970-01-01')
  AND (c1, c3, c4) < (0, 0.00, '2000-01-01');

DELETE FROM t_range_partition_1 
WHERE (c1, c3, c4) >= (0, 0.00, '2000-01-01')
  AND (c1, c3, c4) < (1E308, 9999999.99, '2038-01-19 03:14:07');

DELETE FROM t_range_partition_1 ;

INSERT INTO t_range_partition_1 (c1, c2, c3, c4) VALUES 
(-1E308, 0.0, -1.00, '1970-01-01 00:00:00'),
(0.0, 0.0, 0.00, '1999-12-31 23:59:59');

INSERT INTO t_range_partition_1 (c1, c2, c3, c4) VALUES 
(0.01, 1E-37, 0.01, '2000-01-02'),
(1E307, 1E+37, 9999999.99, '2038-01-18 03:14:07');

INSERT INTO t_range_partition_1 (c1, c2, c3, c4) VALUES 
(1E308, 1E+37, 9999999.999, '2038-01-19 03:14:08'),
(1.1E308, 1E+38, 10000000.00, '9999-12-31 23:59:59');

DELETE FROM t_range_partition_1 
WHERE c1 >= 0 AND c1 < 1E308;
DELETE FROM t_range_partition_1 ;

--echo ### SELECT 

INSERT INTO t_range_partition_1 (c1, c2, c3, c4) VALUES 
(-1E308, 0.0, -1.00, '1970-01-01 00:00:00'),
(0.0, 0.0, 0.00, '1999-12-31 23:59:59');

INSERT INTO t_range_partition_1 (c1, c2, c3, c4) VALUES 
(0.01, 1E-37, 0.01, '2000-01-02'),
(1E307, 1E+37, 9999999.99, '2038-01-18 03:14:07');

INSERT INTO t_range_partition_1 (c1, c2, c3, c4) VALUES 
(1E308, 1E+37, 9999999.999, '2038-01-19 03:14:08'),
(1.1E308, 1E+38, 10000000.00, '9999-12-31 23:59:59');

SELECT * FROM t_range_partition_1 PARTITION(p1);

WITH partition_data AS (SELECT * FROM t_range_partition_1 PARTITION(p1))
SELECT * FROM partition_data;

SELECT DISTINCT c1 FROM t_range_partition_1 PARTITION(p1);

SELECT a.* 
FROM t_range_partition_1 PARTITION(p2) a 
JOIN t_range_partition_2 b ON a.c1 = b.c1;

SELECT c1, AVG(c2) AS avg_c2 
FROM t_range_partition_1 PARTITION(p2) 
GROUP BY c1 
HAVING AVG(c2) > 50;

SELECT * FROM t_range_partition_1 PARTITION(p0)
UNION ALL
SELECT * FROM t_range_partition_2 PARTITION(p1);

SELECT * FROM t_range_partition_1 PARTITION(p1) 
ORDER BY c3 DESC;

SELECT * FROM t_range_partition_1 PARTITION(p2) 
LIMIT 10;

WITH partition_data AS (
  SELECT c1, c2, c3, c4 
  FROM t_range_partition_1 PARTITION(p1) 
  WHERE c2 BETWEEN -1000000000 AND 1000000000000
)
SELECT DISTINCT a.c1, a.c2, AVG(a.c3) AS avg_c3 
FROM partition_data a 
JOIN t_range_partition_1 PARTITION(p1) b ON a.c1 = b.c1 
GROUP BY a.c1, a.c2 
HAVING AVG(a.c3) < 0
ORDER BY avg_c3 DESC
LIMIT 5;

--echo ### 分区裁剪基础测试
--echo # 公共表
--disable_warnings
drop table if exists t_testdata;
--enable_warnings
create table t_testdata (n0 tinyint, n1 bool, n2 boolean, n3 smallint,n4 mediumint, n5 int, n6 integer,n7 bigint,n8 decimal, n9 dec, n10 float, n11 numeric,n12 double, n13 double precision, n14 real);
insert into t_testdata values(1,true,true,4,5,6,7,8,9.0,10,11.100,12,13.123,14.456,15);

--echo # double下的整数
--disable_warnings
drop table if exists t_part_range;
--enable_warnings
create table t_part_range (n0 double, n1 bool, n2 boolean, n3 smallint,n4 mediumint, n5 int, n6 integer,n7 bigint,n8 decimal, n9 dec, n10 float, n11 numeric,n12 double, n13 double precision, n14 real)
partition by range columns(n0)
(partition p0 values less than (1),
 partition p1 values less than (2),
 partition p2 values less than maxvalue);

--echo ### select语句
explain select n0,n1,n2 from t_part_range where n0 = -10 limit 5;
explain select n0,n1,n2 from t_part_range where n0 in (12,2,3) order by n0;
explain select n0,n1,n2 from t_part_range where n3 = -10 and n0 = n3;
explain select n0,n1,n2 from t_part_range group by n0 having n0=20;
explain select n0,n1,n2 from t_part_range where n0 = -10 group by n0 having n0 < 10;
explain select n0,n1,n2 from t_part_range where n0 > -10 and n0 < 10;
explain select n0,n1,n2 from t_part_range where (n0 between 1 and 9) or (n0 between -1 and -9);

--echo ### update语句
explain update t_part_range set n1 = 1 where n3 = 20 and n0 = n3;
explain update t_part_range set n1 = 1 where n0 = -2 or n0 = -8 or n0 = 9;
explain update t_part_range set n1 = 1 where n0 in (-12,12,15);
explain update t_part_range set n1 = 1 where abs(n0) = 15;

--echo ### delete语句
explain delete from t_part_range where n0 >= 20;
explain delete from t_part_range where n0 between 10 and 19;
explain delete from t_part_range where n0+n2 = 8;

--echo ### insert语句
explain insert into t_part_range(n0) values (NULL);
explain insert into t_part_range(n0) values (52);
explain insert into t_testdata(n0) select n0 from t_part_range where n0 = 0;
explain insert into t_part_range(n0) select n0 from t_testdata where n0 in (-12,12,15);

--echo ### 子查询中使用到分区表
explain select * from t_testdata t1 where n3 > (select t2.n3 from t_part_range t2 where t1.n0 > t2.n0 and t2.n0 = 19);

--echo # double下的浮点数
--disable_warnings
drop table if exists t_part_range;
--enable_warnings
create table t_part_range (n0 double, n1 bool, n2 boolean, n3 smallint,n4 mediumint, n5 int, n6 integer,n7 bigint,n8 decimal, n9 dec, n10 float, n11 numeric,n12 double, n13 double precision, n14 real)
partition by range columns(n0)
(partition p0 values less than (1),
 partition p1 values less than (2),
 partition p2 values less than maxvalue);

--echo ### select语句
explain select n0,n1,n2 from t_part_range where n0 = -10.111 limit 5;
explain select n0,n1,n2 from t_part_range where n0 in (12.2,2.2,3.3) order by n0;
explain select n0,n1,n2 from t_part_range where n3 = -10.222 and n0 = n3;
explain select n0,n1,n2 from t_part_range group by n0 having n0=20.333;
explain select n0,n1,n2 from t_part_range where n0 = -10.333 group by n0 having n0 < 10.333;
explain select n0,n1,n2 from t_part_range where n0 > -10.333 and n0 < 10.333;
explain select n0,n1,n2 from t_part_range where (n0 between 1.333 and 9.333) or (n0 between -1.333 and -9.333);

--echo ### update语句
explain update t_part_range set n1 = 1 where n3 = 20.333 and n0 = n3;
explain update t_part_range set n1 = 1 where n0 = -2.333 or n0 = -8.333 or n0 = 9.333;
explain update t_part_range set n1 = 1 where n0 in (-12.333,1.3332,15.333);
explain update t_part_range set n1 = 1 where abs(n0) = 15.333;

--echo ### delete语句
explain delete from t_part_range where n0 >= 20.333;
explain delete from t_part_range where n0 between 10.333 and 19.333;
explain delete from t_part_range where n0+n2 = 8.333;

--echo ### insert语句
explain insert into t_part_range(n0) values (NULL);
explain insert into t_part_range(n0) values (52.333);
explain insert into t_testdata(n0) select n0 from t_part_range where n0 = 0;
explain insert into t_part_range(n0) select n0 from t_testdata where n0 in (-12.333,1.333,1,11.100,15.333);

--echo ### 子查询中使用到分区表
explain select * from t_testdata t1 where n3 > (select t2.n3 from t_part_range t2 where t1.n0 > t2.n0 and t2.n0 = 1.333);

--echo # float下的浮点数
--disable_warnings
drop table if exists t_part_range;
--enable_warnings
create table t_part_range (n0 float, n1 bool, n2 boolean, n3 smallint,n4 mediumint, n5 int, n6 integer,n7 bigint,n8 decimal, n9 dec, n10 float, n11 numeric,n12 double, n13 double precision, n14 real)
partition by range columns(n0)
(partition p0 values less than (1),
 partition p1 values less than (2),
 partition p2 values less than maxvalue);

--echo ### select语句
#### float类型较多不一致。
explain select n0,n1,n2 from t_part_range where n0 = -10.111 limit 5;
explain select n0,n1,n2 from t_part_range where n0 = -10.00 limit 5;

explain select n0,n1,n2 from t_part_range where n0 in (12.2,2.2,3.3) order by n0;
explain select n0,n1,n2 from t_part_range where n3 = -10.222 and n0 = n3;
explain select n0,n1,n2 from t_part_range group by n0 having n0=20.333;
explain select n0,n1,n2 from t_part_range where n0 = -10.333 group by n0 having n0 < 10.333;
explain select n0,n1,n2 from t_part_range where n0 > -10.333 and n0 < 10.333;
explain select n0,n1,n2 from t_part_range where (n0 between 1.333 and 9.333) or (n0 between -1.333 and -9.333);

--echo ### update语句
explain update t_part_range set n1 = 1 where n3 = 20.333 and n0 = n3;
explain update t_part_range set n1 = 1 where n0 = -2.333 or n0 = -8.333 or n0 = 9.333;
explain update t_part_range set n1 = 1 where n0 in (-12.333,1.3332,15.333);
