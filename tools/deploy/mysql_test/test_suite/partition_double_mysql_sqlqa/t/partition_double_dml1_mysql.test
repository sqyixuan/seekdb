explain select n1,n2 from t_part_range where n1 = 10.2 limit 5;
explain select n1,n2 from t_part_range where n1 = 50.2 limit 5;

--disable_warnings
drop table if exists t_part_range;
--enable_warnings
create table t_part_range (n0 tinyint, n1 bool, n2 boolean, n3 smallint,n4 mediumint, n5 int, n6 integer,n7 bigint,n8 decimal, n9 dec, n10 float, n11 numeric,n12 double, n13 double precision, n14 real)
partition by range columns(n9)
(partition p0 values less than (10),
 partition p1 values less than (50),
 partition p2 values less than maxvalue);

--echo ### select
explain select n9,n1,n2 from t_part_range where n9 = -10.2 limit 5;
explain select n9,n1,n2 from t_part_range where n9 = 1 limit 5;
explain select n9,n1,n2 from t_part_range where n9 = 9.2 limit 5;
explain select n9,n1,n2 from t_part_range where n9 = 10.2 limit 5;
explain select n9,n1,n2 from t_part_range where n9 = 50.2 limit 5;

explain select n8,n1,n2 from t_part_range where n8 = 20 and n9 = n8;

#### 类似问题补充：OB使用浮点数的值，分布在p0,P1,P2,对decimal字段分区裁剪结果为P2,与MYSQL不一致。
explain select n9,n1,n2 from t_part_range where n9 in (12.5,50.1) order by n9;
explain select n9,n1,n2 from t_part_range group by n9 having n9 = 1.1;
explain select n9,n1,n2 from t_part_range group by n9 having n9 = 50.1;

explain select n9,n1,n2 from t_part_range where n9 = -9.52 group by n9 having n9 < 10;
explain select n9,n1,n2 from t_part_range where n9 > 10.1 and n9 < 15.2;
explain select n9,n1,n2 from t_part_range where n9 between 10 and 29;
explain select n9,n1,n2 from t_part_range where (n9 between 1 and 9) or (n9 between -1 and -9);

--echo ### update语句
#### 类似问题补充：OB使用浮点数的值，分布在p0,P1,P2,对decimal字段分区裁剪结果为P2,与MYSQL不一致。
explain update t_part_range set n1 = 1 where n9 = -10.2 or n9 = -8 or n9 = 9;

explain update t_part_range set n1 = 1 where n9 in (-12,12,15);
explain update t_part_range set n1 = 1 where ceiling(n9) = 15;

--echo ### delete语句
explain delete from t_part_range where n9 >= 49.1;
explain delete from t_part_range where n9 between 49.1 and 60.0;
explain delete from t_part_range where n9+n2 = 8;

--echo ### insert语句
explain insert into t_part_range(n9) values (NULL);
explain insert into t_part_range(n9) values (49.5);
explain insert into t_testdata(n9) select n9 from t_part_range where n9 = 0;

explain insert into t_part_range(n9) select n9 from t_testdata where n9 in (-12,12,15);

--echo ### 子查询中使用到分区表
explain select * from t_testdata t1 where n9 > (select t2.n9 from t_part_range t2 where t1.n9 > t2.n9 and t2.n9 = 20.0);

--echo ### 多列分区裁剪double/float/decimal
--disable_warnings
drop table if exists t_part_range;
--enable_warnings

create table t_part_range (n0 double, n1 float, n2 boolean, n3 smallint,n4 mediumint, n5 int, n6 integer,n7 bigint,n8 decimal, n9 dec, n10 float, n11 numeric,n12 double, n13 double precision, n14 real)
partition by range columns(n0,n1,n8)
(partition p0 values less than (1,1,1),
 partition p1 values less than (20,20,20),
 partition p2 values less than (maxvalue,maxvalue,maxvalue));

--echo ### select语句
explain select n0,n1,n2 from t_part_range where n0 = -10.111 limit 5;
explain select n0,n1,n2 from t_part_range where n0 in (12.2,2.2,3.3) order by n0;
explain select n0,n1,n2 from t_part_range where n3 = -10.222 and n0 = n3;
explain select n0,n1,n2 from t_part_range group by n0 having n0=20.333;
explain select n0,n1,n2 from t_part_range where n0 = -10.333 group by n0 having n0 < 10.333;
explain select n0,n1,n2 from t_part_range where n0 > -10.333 and n0 < 10.333;
explain select n0,n1,n2 from t_part_range where (n0 between 1.333 and 9.333) or (n0 between -1.333 and -9.333);

--echo ### update语句
explain update t_part_range set n1 = 1 where n3 = 20.333 and n0 = n3;
explain update t_part_range set n1 = 1 where n0 = -2.333 or n0 = -8.333 or n0 = 9.333;
explain update t_part_range set n1 = 1 where n0 in (-12.333,1.3332,15.333);
explain update t_part_range set n1 = 1 where abs(n0) = 15.333;

--echo ### delete语句
explain delete from t_part_range where n0 >= 20.333;
explain delete from t_part_range where n0 between 10.333 and 19.333;
explain delete from t_part_range where n0+n2 = 8.333;

--echo ### insert语句
explain insert into t_part_range(n0) values (NULL);
explain insert into t_part_range(n0) values (52.333);
explain insert into t_testdata(n0) select n0 from t_part_range where n0 = 0;
explain insert into t_part_range(n0) select n0 from t_testdata where n0 in (-12.333,1.333,1,11.100,15.333);

--echo ### 子查询中使用到分区表
explain select * from t_testdata t1 where n3 > (select t2.n3 from t_part_range t2 where t1.n0 > t2.n0 and t2.n0 = 1.333);

EXPLAIN SELECT n0,n1,n2 FROM t_part_range WHERE n0 = -10.111 AND n1 = 0 AND n8 = 0 LIMIT 5;
EXPLAIN SELECT n0,n1,n2 FROM t_part_range WHERE n0 = -10.111 AND n1 = 100 AND n8 = 10 LIMIT 5;

EXPLAIN SELECT n0,n1,n2 FROM t_part_range WHERE n0 in (12.2,2.2,3.3) AND n1 in (2.2,0) AND n8 in (2.2,0) ORDER BY n0; 
EXPLAIN SELECT n0,n1,n2 FROM t_part_range WHERE n3 = -10.222 AND n0 = n3 AND n1 = -10.222 AND n8 = -10.222; 
EXPLAIN SELECT n0,n1,n2 FROM t_part_range WHERE n0 = 20.333 AND n1 = 20.333 AND n8 = 20.333 GROUP BY n0 HAVING n0=20.333;
EXPLAIN SELECT n0,n1,n2 FROM t_part_range WHERE n0 = 20.333 AND n1 = 0.333 AND n8 = -10.333 GROUP BY n0 HAVING n0=20.333;

EXPLAIN SELECT n0,n1,n2 FROM t_part_range WHERE n0 = -10.333 AND n1 = -10.333 AND n8 = -10.333 GROUP BY n0 HAVING n0 < 10.333;
EXPLAIN SELECT n0,n1,n2 FROM t_part_range WHERE n0 > -10.333 AND n0 < 10.333 AND n1 > -10.333 AND n1 < 10.333 AND n8 > -10.333 AND n8 < 10.333;
EXPLAIN SELECT n0,n1,n2 FROM t_part_range WHERE (n0 between 1.333 and 9.333 AND n1 between 1.333 and 9.333 AND n8 between 1.333 and 9.333) OR (n0 between -1.333 and -9.333 AND n1 between -1.333 and -9.333 AND n8 between -1.333 and -9.333);

EXPLAIN UPDATE t_part_range SET n1 = 1 WHERE n3 = 20.333 AND n0 = n3 AND n1 = 20.333 AND n8 = 20.333;
EXPLAIN UPDATE t_part_range SET n1 = 1 WHERE n0 = -2.333 OR n0 = -8.333 OR n0 = 9.333 AND n1 = 0 AND n8 = 0;
EXPLAIN UPDATE t_part_range SET n1 = 1 WHERE n0 in (-12.333,1.3332,15.333) AND n1 in (-12.333,1.3332,15.333) AND n8 in (-12.333,1.3332,15.333);
EXPLAIN UPDATE t_part_range SET n1 = 1 WHERE abs(n0) = 15.333 AND abs(n1) = 15.333 AND abs(n8) = 15.333;

EXPLAIN DELETE FROM t_part_range WHERE n0 >= 20.333;
EXPLAIN DELETE FROM t_part_range WHERE n0 between 10.333 and 19.333;
EXPLAIN DELETE FROM t_part_range WHERE n0+n2 = 8.333 AND n1+n2 = 8.333 AND n8+n2 = 8.333;

EXPLAIN INSERT INTO t_part_range(n0) VALUES (NULL);
EXPLAIN INSERT INTO t_part_range(n0, n1, n8) VALUES (52.333, 52.333, 52.333);
EXPLAIN INSERT INTO t_testdata(n0) SELECT n0 FROM t_part_range WHERE n0 = 0;
EXPLAIN INSERT INTO t_part_range(n0, n1, n8) SELECT n0, n0, n0 FROM t_testdata WHERE n0 in (-12.333,1.333,1,11.100,15.333);

EXPLAIN SELECT * FROM t_testdata t1 WHERE n3 > (SELECT MAX(t2.n3) FROM t_part_range t2 WHERE t1.n0 > t2.n0 AND t2.n0 = 1.333 AND t2.n1 = t1.n1 AND t2.n8 = t1.n8);

--echo ### 多列分区裁剪double/double/double
--disable_warnings
drop table if exists t_part_range;
--enable_warnings

create table t_part_range (n0 double, n1 double, n2 boolean, n3 smallint,n4 mediumint, n5 int, n6 integer,n7 bigint,n8 double, n9 double, n10 float, n11 numeric,n12 double, n13 double precision, n14 real)
partition by range columns(n0,n1,n8)
(partition p0 values less than (1.1,1.1,1.1),
 partition p1 values less than (20.1,20.1,20.1),
 partition p2 values less than (maxvalue,maxvalue,maxvalue));

EXPLAIN SELECT n0,n1,n2 FROM t_part_range WHERE n0 = -10.111 AND n1 = 0 AND n8 = 0 LIMIT 5;
EXPLAIN SELECT n0,n1,n2 FROM t_part_range WHERE n0 = -10.111 AND n1 = 10 AND n8 = 100 LIMIT 5;

EXPLAIN SELECT n0,n1,n2 FROM t_part_range WHERE n0 in (12.2,2.2,3.3) AND n1 in (2.2,0) AND n8 in (2.2,0) ORDER BY n0; 
EXPLAIN SELECT n0,n1,n2 FROM t_part_range WHERE n0 in (1.1,10.1,20.1) AND n1 in (1.1,10.1,20.1) AND n8 in (1.1,10.1,20.1) ORDER BY n0;
 
EXPLAIN SELECT n0,n1,n2 FROM t_part_range WHERE n3 = -10.222 AND n0 = n3 AND n1 = -10.222 AND n8 = -10.222; 
EXPLAIN SELECT n0,n1,n2 FROM t_part_range WHERE n0 = 20.333 AND n1 = 20.333 AND n8 = 20.333 GROUP BY n0 HAVING n0=20.333;
EXPLAIN SELECT n0,n1,n2 FROM t_part_range WHERE n0 = 20.333 AND n1 = 0.333 AND n8 = -10.333 GROUP BY n0 HAVING n0=20.333;

EXPLAIN SELECT n0,n1,n2 FROM t_part_range WHERE n0 = -10.333 AND n1 = -10.333 AND n8 = -10.333 GROUP BY n0 HAVING n0 < 10.333;
EXPLAIN SELECT n0,n1,n2 FROM t_part_range WHERE n0 > -10.333 AND n0 < 10.333 AND n1 > -10.333 AND n1 < 10.333 AND n8 > -10.333 AND n8 < 10.333;
EXPLAIN SELECT n0,n1,n2 FROM t_part_range WHERE (n0 between 1.333 and 9.333 AND n1 between 1.333 and 9.333 AND n8 between 1.333 and 9.333) OR (n0 between -1.333 and -9.333 AND n1 between -1.333 and -9.333 AND n8 between -1.333 and -9.333);
EXPLAIN SELECT n0,n1,n2 FROM t_part_range WHERE (n0 between 1.1 and 20.1 AND n1 between 1.333 and 9.333 AND n8 between 1.333 and 9.333);
EXPLAIN SELECT n0,n1,n2 FROM t_part_range WHERE (n0 between -1.333 and -9.333 AND n1 between -1.333 and -9.333 AND n8 between -1.333 and -9.333);

EXPLAIN SELECT n0,n1,n2 FROM t_part_range WHERE (n0 between 1.1 and 20.1);

#### 理论结果p1，实际结果p1-p2，
EXPLAIN SELECT n0,n1,n2 FROM t_part_range WHERE (n0 between 1.1 and 25.1 AND n1 between 1.333 and 9.333 AND n8 between 1.333 and 9.333);
EXPLAIN SELECT n0,n1,n2 FROM t_part_range WHERE (n0 between 1.1 and 25.1 AND n1 between 1.333 and 9.333 AND n8 between 1.333 and 9.333)
OR (n0 between -1.333 and -9.333 AND n1 between -1.333 and -9.333 AND n8 between -1.333 and -9.333);

EXPLAIN UPDATE t_part_range SET n1 = 1 WHERE n3 = 20.333 AND n0 = n3 AND n1 = 20.333 AND n8 = 20.333;
EXPLAIN UPDATE t_part_range SET n1 = 1 WHERE n0 = -2.333 OR n0 = -8.333 OR n0 = 9.333 AND n1 = 0 AND n8 = 0;
EXPLAIN UPDATE t_part_range SET n1 = 1 WHERE n0 in (-12.333,1.3332,15.333) AND n1 in (-12.333,1.3332,15.333) AND n8 in (-12.333,1.3332,15.333);
EXPLAIN UPDATE t_part_range SET n1 = 1 WHERE n0 in (-12.333,1.3332,15.333) AND n1 in (-12.333,1.3332,20.333) AND n8 in (-12.333,1.3332,20.333);
EXPLAIN UPDATE t_part_range SET n1 = 1 WHERE abs(n0) = 15.333 AND abs(n1) = 15.333 AND abs(n8) = 15.333;

EXPLAIN DELETE FROM t_part_range WHERE n0 >= 20.333;
EXPLAIN DELETE FROM t_part_range WHERE n0 between 10.333 and 19.333;
EXPLAIN DELETE FROM t_part_range WHERE n0+n2 = 8.333 AND n1+n2 = 8.333 AND n8+n2 = 8.333;

EXPLAIN INSERT INTO t_part_range(n0) VALUES (NULL);
EXPLAIN INSERT INTO t_part_range(n0, n1, n8) VALUES (52.333, 52.333, 52.333);
EXPLAIN INSERT INTO t_testdata(n0) SELECT n0 FROM t_part_range WHERE n0 = 0;
EXPLAIN INSERT INTO t_part_range(n0, n1, n8) SELECT n0, n0, n0 FROM t_testdata WHERE n0 in (-12.333,1.333,1,11.100,15.333);

EXPLAIN SELECT * FROM t_testdata t1 WHERE n3 > (SELECT MAX(t2.n3) FROM t_part_range t2 WHERE t1.n0 > t2.n0 AND t2.n0 = 1.333 AND t2.n1 = t1.n1 AND t2.n8 = t1.n8);

