explain insert into t_part_range(n0) select n0 from t_testdata where n0 in (-12.333,1.333,1,11.100,15.333);

--echo ### 子查询中使用到分区表
explain select * from t_testdata t1 where n3 > (select t2.n3 from t_part_range t2 where t1.n0 > t2.n0 and t2.n0 = 1.333);

--echo ### decimal
--disable_warnings
drop table if exists t_part_range;
--enable_warnings
create table t_part_range (n1 decimal, n2 dec)
partition by range columns(n1)
(partition p0 values less than (10),
 partition p1 values less than (50),
 partition p2 values less than maxvalue);

### OB使用浮点数的值，分布在p0,P1,P2,对decimal字段分区裁剪结果为P2,与MYSQL不一致。
explain select n1,n2 from t_part_range where n1 = -10.2 limit 5;
explain select n1,n2 from t_part_range where n1 = 9.2 limit 5;
explain select n1,n2 from t_part_range where n1 = 10.2 limit 5;
explain select n1,n2 from t_part_range where n1 = 50.2 limit 5;

### 补充测试内容
--disable_warnings
drop table if exists t_part_range;
--enable_warnings
create table t_part_range (n1 decimal, n2 dec)
partition by range(ceiling(n1))
(partition p0 values less than (10),
 partition p1 values less than (50),
 partition p2 values less than maxvalue);
 
