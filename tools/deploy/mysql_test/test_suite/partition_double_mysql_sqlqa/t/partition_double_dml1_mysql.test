--echo ### 多列分区裁剪double + 其他列混合
--disable_warnings
drop table if exists t_range_columns;
--enable_warnings

create table t_range_columns (n0 double, n1 bool, n2 boolean, n3 double,n4 mediumint, n5 int, n6 integer,n7 bigint,n8 decimal, n9 dec, n10 float, n11 numeric,n12 double, n13 double precision, n14 real) 
partition by range columns (n0,n1,n2,n3)
(PARTITION p0 VALUES LESS THAN (1.01,0,0,1.01),
  PARTITION p1 VALUES LESS THAN (2.01,1,1,2.01),
  PARTITION p2 VALUES LESS THAN (MAXVALUE,MAXVALUE,MAXVALUE,MAXVALUE));

--echo ### select语句
explain select n0,n1,n2,n3 from t_range_columns where n0 = 1.01 and n1 = true and n2 = n1 and n3 = n0 limit 5;
explain select n0,n1,n2,n3 from t_range_columns where n0 = 1.01 and n1 = true and n2 = true and n3 = 4 limit 5;
explain select n0,n1,n2,n3 from t_range_columns where n0 in (1.01,2.01) and n1 in (true) and n2 in (true) and n3 in (4.01,5.01) order by n1;
explain select n0,n1,n2,n3 from t_range_columns group by n0,n1,n2,n3 having n0 = 1.01 and n1 = false and n2 = true and n3 = 4;
explain select n0,n1,n2,n3 from t_range_columns where (n0 between 1.01 and 2.01) and n1 = true and n2 = false and (n3 between 3.01 and 4.01);

--echo ### update语句
explain update t_range_columns set n3 = 3.01 where n0 = 1.00 and n1 = false and n2 = false and n3 = 4;
explain update t_range_columns set n3 = 3.01 where n0 in (1.01,2.01) and n1 in (true) and n2 in (false) and n3 in (4.01,5.01);

--echo ### delete语句
explain delete from t_range_columns where (n0 >= 1.01 and n0 <= 2.01) and n1 = true and n2 = false and (n3 >= 4.01 and n3 <= 5.01);
explain delete from t_range_columns where n0+1 = 5.01 and n1 = true and n2 = false and n3 = 4.01;

--echo ### insert语句
explain insert into t_range_columns(n0,n1,n2,n3) values (null,null,null,null);
explain insert into t_range_columns(n0,n1,n2,n3) values (null,true,null,2.01);
explain insert into t_testdata(n0,n1,n2,n3) select n0,n1,n2,n3 from t_range_columns where n0 = 1.01 and n1 = true and n2 = true and n3 = 4.01;
explain insert into t_range_columns(n0,n1,n2,n3) select n0,n1,n2,n3 from t_testdata where n0 in (1.01,2.01) and n1 in (true) and n2 in (true) and n3 in (4.01,5.01);

--echo ### timestamp类型验证

--echo # 公共表
--disable_warnings
drop table if exists t_testdata;
--enable_warnings
create table t_testdata (c1 date, c2 time, c3 year, c4 datetime, c5 timestamp);
insert into t_testdata values('2022-12-01','12:00:00.1000','2020','2022-12-01 12:00:00.1000','2022-12-01 12:00:00.1000');
### insert into t_testdata values('2022-12-02','13:00:00.1000','2021','2022-12-02 13:00:00.1000','2022-12-02 12:00:00.1001');
### insert into t_testdata values('2022-12-03','14:00:00.1000','2022','2022-12-03 14:00:00.1000','2022-12-03 12:00:00.1002');
### insert into t_testdata values('2022-12-04','15:00:00.1000','2023','2022-12-04 15:00:00.1000','2022-12-04 12:00:00.1003');

--echo ######################## RANGE COLUMNS 分区 - 分区键 timestamp ########################
--disable_warnings
drop table if exists t_range_columns;
--enable_warnings
create table t_range_columns (c1 timestamp, c2 time, c3 year, c4 datetime, c5 timestamp) partition by range columns(c1)
(PARTITION p0 VALUES LESS THAN ('2000-01-01'),
  PARTITION p1 VALUES LESS THAN ('2022-01-01'),
  PARTITION p2 VALUES LESS THAN (MAXVALUE));

--echo ### select语句
explain select c1,c2 from t_range_columns where c1 = '2022-12-01' limit 5;
explain select c1,c2 from t_range_columns where c4 = '2022-12-01' and c1 = c4;
explain select c1,c2 from t_range_columns where c1 in ('2022-12-01','2022-12-05') order by c1;
explain select c1,c2 from t_range_columns group by c1 having c1 = '2022-02-01';
explain select c1,c2 from t_range_columns where c1 between '2021-02-10'and '2021-02-15';
explain select c1,c2 from t_range_columns where c1 >= '2021-02-11' and c1 <= '2021-02-15';
explain select c1,c2 from t_range_columns where to_days(c1) = to_days('2000-01-01');

--echo ### update语句
explain update t_range_columns set c1 = '2021-12-29' where c1 = '2022-12-29';
explain update t_range_columns set c1 = '2021-12-29' where c1 in ('2021-01-16','2021-01-15');

--echo ### delete语句
explain delete from t_range_columns where c1 between '2021-02-10'and '2021-02-15';
explain delete from t_range_columns where c1 >= '2021-02-11' and c1 <= '2021-02-15';

--echo ### insert语句
explain insert into t_range_columns(c1) values (null);
explain insert into t_range_columns(c1) values ('2021-01-16');
explain insert into t_range_columns(c1) select c1 from t_testdata where c1 = '2021-02-01'limit 5;
explain insert into t_testdata(c1) select c1 from t_range_columns where c1 = '2021-02-10';

--echo ### 子查询中使用到分区表
explain select * from t_testdata t1 where c3 > (select t2.c3 from t_range_columns t2 where t1.c1 > t2.c1 and t2.c1 = '2022-12-01');

--echo ### timestamp 精确到时分秒
--disable_warnings
drop table if exists t_range_columns;
--enable_warnings
create table t_range_columns (c1 timestamp, c2 time, c3 year, c4 datetime, c5 timestamp) partition by range columns(c1)
(PARTITION p0 VALUES LESS THAN ('2000-01-01 01:01:01'),
  PARTITION p1 VALUES LESS THAN ('2022-01-01 01:01:01'),
  PARTITION p2 VALUES LESS THAN ('2038-01-19 03:14:07'),
  PARTITION p3 VALUES LESS THAN (MAXVALUE));

--echo ### select语句
EXPLAIN SELECT c1, c2 FROM t_range_columns WHERE c1 = '2038-01-19 03:14:07' LIMIT 5;
EXPLAIN SELECT c1, c2 FROM t_range_columns WHERE c4 = '2022-01-01 01:01:01' AND c1 = c4;
EXPLAIN SELECT c1, c2 FROM t_range_columns WHERE c1 IN ('2022-01-01 01:01:01','2000-01-01 01:01:01') ORDER BY c1;
EXPLAIN SELECT c1, c2 FROM t_range_columns GROUP BY c1 HAVING c1 = '2000-01-01 01:01:01';
EXPLAIN SELECT c1, c2 FROM t_range_columns WHERE c1 BETWEEN '2000-01-01 01:01:01' AND '2038-01-19 03:14:07';
EXPLAIN SELECT c1, c2 FROM t_range_columns WHERE c1 >= '2000-01-01 01:01:01' AND c1 <= '2038-01-19 03:14:07';
EXPLAIN SELECT c1, c2 FROM t_range_columns WHERE TO_DAYS(c1) = TO_DAYS('2000-01-01 01:01:01');

--echo ### update语句
EXPLAIN UPDATE t_range_columns SET c1 = '2021-12-29 01:01:01' WHERE c1 = '2038-01-19 03:14:07';
EXPLAIN UPDATE t_range_columns SET c1 = '2021-12-29 01:01:01' WHERE c1 IN ('2038-01-19 03:14:07','2022-01-01 01:01:01');

--echo ### delete语句
EXPLAIN DELETE FROM t_range_columns WHERE c1 BETWEEN '2000-01-01 01:01:01' AND '2038-01-19 03:14:07';
EXPLAIN DELETE FROM t_range_columns WHERE c1 >= '2000-01-01 01:01:01' AND c1 <= '2038-01-19 03:14:07';

--echo ### insert语句
EXPLAIN INSERT INTO t_range_columns(c1) VALUES (null);
EXPLAIN INSERT INTO t_range_columns(c1) VALUES ('2021-01-16 01:01:01');
EXPLAIN INSERT INTO t_range_columns(c1) SELECT c1 FROM t_testdata WHERE c1 = '2022-01-01 01:01:01' LIMIT 5;
EXPLAIN INSERT INTO t_testdata(c1) SELECT c1 FROM t_range_columns WHERE c1 = '2022-01-01 01:01:01';

--echo ### 子查询中使用到分区表
EXPLAIN SELECT * FROM t_testdata t1 WHERE c3 > (SELECT t2.c3 FROM t_range_columns t2 WHERE t1.c1 > t2.c1 AND t2.c1 = '2022-01-01 01:01:01');

--echo ### timestamp 多列分区裁剪
--disable_warnings
drop table if exists t_range_columns;
--enable_warnings
create table t_range_columns (c1 timestamp, c2 timestamp, c3 year, c4 datetime, c5 timestamp) partition by range columns(c1,c2)
(PARTITION p0 VALUES LESS THAN ('2000-01-01 01:01:01','2000-01-01 01:01:01'),
  PARTITION p1 VALUES LESS THAN ('2022-01-01 01:01:01','2022-01-01 01:01:01'),
  PARTITION p2 VALUES LESS THAN ('2038-01-19 03:14:07','2038-01-19 03:14:07'),
  PARTITION p3 VALUES LESS THAN (MAXVALUE,MAXVALUE));

--echo ### select语句，OB的partition by range columns(timestamp,timestamp)表现结果与MYSQL datetime类型一致。
EXPLAIN SELECT c1, c2 FROM t_range_columns WHERE c1 = '2038-01-19 03:14:07' LIMIT 5;
EXPLAIN SELECT c1, c2 FROM t_range_columns WHERE c1 = '2038-01-20 03:14:07' LIMIT 5;
EXPLAIN SELECT c1, c2 FROM t_range_columns WHERE c4 = '2022-01-01 01:01:01' AND c1 = '2022-01-01 01:01:01';
EXPLAIN SELECT c1, c2 FROM t_range_columns WHERE c4 = '2022-01-01 01:01:01' AND c1 = '2000-01-01 01:01:01';

EXPLAIN SELECT c1, c2 FROM t_range_columns WHERE c1 IN ('2022-01-01 01:01:01','2000-01-01 01:01:01') ORDER BY c1;
EXPLAIN SELECT c1, c2 FROM t_range_columns WHERE c1 = '2000-01-01 01:01:01' GROUP BY c1;

EXPLAIN SELECT c1, c2 FROM t_range_columns WHERE c1 BETWEEN '2000-01-01 01:01:01' AND '2038-01-19 03:14:07';
EXPLAIN SELECT c1, c2 FROM t_range_columns WHERE (c1 BETWEEN '2000-01-01 01:01:01' AND '2038-01-19 03:14:07') AND (c2 BETWEEN '2021-01-01 01:01:01' AND '2021-01-19 03:14:07');

EXPLAIN SELECT c1, c2 FROM t_range_columns WHERE c1 >= '2000-01-01 01:01:01' AND c1 <= '2038-01-19 03:14:07';
EXPLAIN SELECT c1, c2 FROM t_range_columns WHERE TO_DAYS(c1) = TO_DAYS('2000-01-01 01:01:01');

--echo ### update语句
EXPLAIN UPDATE t_range_columns SET c1 = '2021-12-29 01:01:01' WHERE c1 = '2038-01-19 03:14:07';
EXPLAIN UPDATE t_range_columns SET c1 = '2021-12-29 01:01:01' WHERE c1 IN ('2038-01-19 03:14:07','2022-01-01 01:01:01');

--echo ### delete语句
EXPLAIN DELETE FROM t_range_columns WHERE c1 BETWEEN '2000-01-01 01:01:01' AND '2038-01-19 03:14:07';
EXPLAIN DELETE FROM t_range_columns WHERE c1 >= '2000-01-01 01:01:01' AND c1 <= '2038-01-19 03:14:07';

--echo ### insert语句
EXPLAIN INSERT INTO t_range_columns(c1, c2) VALUES (NULL, NULL);
EXPLAIN INSERT INTO t_range_columns(c1, c2) VALUES ('2021-01-16 01:01:01', '2021-01-16 01:01:01');
EXPLAIN INSERT INTO t_range_columns(c1, c2) SELECT c1, c1 FROM t_testdata WHERE c1 = '2022-01-01 01:01:01' LIMIT 5;
EXPLAIN INSERT INTO t_testdata(c1, c3) SELECT c1, c3 FROM t_range_columns WHERE c1 = '2022-01-01 01:01:01';

--echo ### 子查询中使用到分区表
EXPLAIN SELECT * FROM t_testdata t1 WHERE c3 > (SELECT t2.c3 FROM t_range_columns t2 WHERE t1.c1 > t2.c1 AND t2.c1 = '2022-01-01 01:01:01' AND t2.c2 = '2022-01-01 01:01:01');

--echo ### 新增DML查询c1、c2列各分区边界交叉的场景用例
EXPLAIN SELECT c1, c2 FROM t_range_columns WHERE (c1, c2) = ('2000-01-01 01:01:01', '2000-01-01 01:01:01');
EXPLAIN SELECT c1, c2 FROM t_range_columns WHERE (c1, c2) IN (('2022-01-01 01:01:01', '2022-01-01 01:01:01'), ('2038-01-19 03:14:07', '2038-01-19 03:14:07'));

--echo ### timestamp 多列分区裁剪timestamp + DOUBLE
--disable_warnings
drop table if exists t_range_columns;
--enable_warnings

CREATE TABLE t_range_columns (
    c1 TIMESTAMP,
    c2 TIMESTAMP,
    c3 YEAR,
    c4 DATETIME,
    c5 TIMESTAMP,
    c6 DOUBLE
) 
PARTITION BY RANGE COLUMNS(c1, c6) (
    PARTITION p0 VALUES LESS THAN ('2000-01-01 01:01:01', 1.0),
    PARTITION p1 VALUES LESS THAN ('2022-01-01 01:01:01', 20.0),
    PARTITION p2 VALUES LESS THAN ('2038-01-19 03:14:07', 3000.0),
    PARTITION p3 VALUES LESS THAN (MAXVALUE, MAXVALUE)
);

### INSERT INTO t_range_columns(c1,c6) VALUES('2038-01-19 03:14:07',15.0);
SELECT  * FROM t_range_columns PARTITION(p1);
SELECT  * FROM t_range_columns PARTITION(p2);
--echo ### select语句
EXPLAIN SELECT c1, c2 FROM t_range_columns WHERE c1 = '2038-01-19 03:14:07' AND c6 < 20.0 LIMIT 5;
EXPLAIN SELECT c1, c2 FROM t_range_columns WHERE c4 = '2022-01-01 01:01:01' AND c1 = c4 AND c6 < 20.0;
EXPLAIN SELECT c1, c2 FROM t_range_columns WHERE c1 IN ('2022-01-01 01:01:01', '2000-01-01 01:01:01') AND c6 < 20.0 ORDER BY c1;
EXPLAIN SELECT c1, c2 FROM t_range_columns GROUP BY c1 HAVING c1 = '2000-01-01 01:01:01';
EXPLAIN SELECT c1, c2 FROM t_range_columns WHERE c1 BETWEEN '2000-01-01 01:01:01' AND '2038-01-19 03:14:07' AND c6 BETWEEN 1.0 AND 3000.0;
EXPLAIN SELECT c1, c2 FROM t_range_columns WHERE c1 BETWEEN '2000-01-01 01:01:01' AND '2038-01-19 03:14:07' AND c6 BETWEEN 1.0 AND 10.0;
EXPLAIN SELECT c1, c2 FROM t_range_columns WHERE c1 >= '2000-01-01 01:01:01' AND c1 <= '2038-01-19 03:14:07' AND c6 < 3000.0;

--echo ### update语句
EXPLAIN UPDATE t_range_columns SET c1 = '2021-12-29 01:01:01', c6 = 20.0 WHERE c1 = '2038-01-19 03:14:07' AND c6 < 3000.0;
EXPLAIN UPDATE t_range_columns SET c1 = '2021-12-29 01:01:01', c6 = 20.0 WHERE c1 IN ('2038-01-19 03:14:07', '2022-01-01 01:01:01') AND c6 < 3000.0;

--echo ### delete语句
EXPLAIN DELETE FROM t_range_columns WHERE c1 BETWEEN '2000-01-01 01:01:01' AND '2038-01-19 03:14:07' AND c6 BETWEEN 1.0 AND 3000.0;
EXPLAIN DELETE FROM t_range_columns WHERE c1 >= '2000-01-01 01:01:01' AND c1 <= '2038-01-19 03:14:07' AND c6 < 3000.0;

--echo ### insert语句
EXPLAIN INSERT INTO t_range_columns(c1, c6) VALUES ('2021-01-16 01:01:01', 20.0);
EXPLAIN INSERT INTO t_range_columns(c1, c6) SELECT c1, 20.0 FROM t_testdata WHERE c1 = '2022-01-01 01:01:01' LIMIT 5;
EXPLAIN INSERT INTO t_testdata(c1) SELECT c1 FROM t_range_columns WHERE c1 = '2022-01-01 01:01:01' AND c6 < 20.0;

--echo ### 子查询中使用到分区表
EXPLAIN SELECT * FROM t_testdata t1 WHERE c3 > (SELECT t2.c3 FROM t_range_columns t2 WHERE t1.c1 > t2.c1 AND t2.c1 = '2022-01-01 01:01:01' AND t2.c6 < 20.0);

--echo ### 新增DML查询c1，c6列各分区边界交叉的场景用例
EXPLAIN SELECT c1, c6 FROM t_range_columns WHERE (c1, c6) = ('2000-01-01 01:01:01', 1.0);
EXPLAIN SELECT c1, c6 FROM t_range_columns WHERE (c1, c6) IN (('2022-01-01 01:01:01', 20.0), ('2038-01-19 03:14:07', 3.0));

--disable_warnings
drop table if exists t_range_columns;
--enable_warnings
create table t_range_columns (c1 date, c2 time, c3 year, c4 timestamp, c5 timestamp) partition by range columns(c1,c4)
(PARTITION p0 VALUES LESS THAN ('2010-01-01','2010-01-01 12:00:00.1000'),
  PARTITION p1 VALUES LESS THAN ('2020-01-01','2020-01-01 12:00:00.1000'),
  PARTITION p2 VALUES LESS THAN (MAXVALUE,MAXVALUE));

--echo ### -1（select语句）
explain select c1,c2 from t_range_columns where c1 = '2020-01-01' and c4 = c1;
explain select c1,c2 from t_range_columns where c1 = '2021-02-12' and c4 = '2020-01-01 10:00:00' group by c1 having c1 < '2021-12-31';
explain select c1,c2 from t_range_columns where c1 in ('2021-01-16','2021-01-15') and c4 in ('2020-01-01 10:00:00','2021-01-01 12:00:00');
explain select c1,c4 from t_range_columns group by c1,c4 having c1 = '2021-02-01' and c4 = '2022-01-01 10:00:00' limit 5;
explain select c1,c2 from t_range_columns where (c1 between '2021-02-10'and '2021-02-15') and (c4 between '2020-01-01 10:00:00'and '2021-01-01 13:00:00');
explain select c1,c2 from t_range_columns where (c1 >= '2021-02-11' and c1 <= '2021-02-15') and (c4 >= '2008-01-01 10:00:00' and c4 <= '2009-01-01 13:00:00');

--echo ### -2（update语句）
explain update t_range_columns set c1 = '2021-12-29' where c1 = '2008-02-02' and c4 = '2008-01-01 10:00:00';
explain update t_range_columns set c1 = '2021-12-29' where c1 in ('2021-01-10','2021-01-15') and c4 in ('2011-01-01 01:00:00','2012-01-01 10:00:00');
explain update t_range_columns set c1 = '2021-12-29' where (c1 between '2021-02-10'and '2021-02-15') and (c4 between '2021-01-01 10:00:00'and '2022-01-01 18:00:00');


--echo ### -3（delete语句）
explain delete from t_range_columns where c1 = '2021-02-02' and c4 = '2008-01-01 10:00:00';
explain delete from t_range_columns where c1 in ('2021-01-16','2021-01-15') and c4 in ('2011-01-01 01:00:00','2012-01-01 10:00:00');
explain delete from t_range_columns where (c1 >= '2021-02-14' and c1 <= '2021-02-15') and (c4 >= '2008-01-01 10:00:00' and c4 <= '2009-01-01 13:00:00');

--echo ### -4（insert语句）
explain insert into t_range_columns(c1,c4) values (null,null);
explain insert into t_range_columns(c1,c4) values (null,'2022-02-10 10:00:00');
explain insert into t_range_columns(c1,c4) values ('2021-02-10',null);
explain insert into t_range_columns(c1,c4) values ('2021-02-12','2021-02-12 10:00:00');
explain insert into t_testdata(c1,c4) select c1,c4 from t_range_columns where c1 = '2021-02-01' and c4= '2021-02-10 10:00:00' limit 5;
explain insert into t_range_columns(c1,c4) select c1,'2021-02-10 10:00:00' from t_testdata where c1 = '2021-02-10';

--echo ### -5（子查询中使用到分区表）
explain select * from t_testdata t1 where c3 > (select t2.c3 from t_range_columns t2 where t1.c1 > t2.c1 and t2.c1 = '2022-01-15' and t2.c4 = '2021-02-10 10:00:00');

--echo # 查询条件不包含分区键
explain select c1,c2 from t_range_columns where c3 = '2022-01-01';

--echo # 查询条件包含部分分区键
explain select c1,c2 from t_range_columns where c1 = '2021-01-01';
explain select c1,c2 from t_range_columns having c1 < '2010-01-01';
explain select c1,c2 from t_range_columns where c4 = '2021-01-01 10:00:00';
explain select c1,c2 from t_range_columns group by c1 having c1 = '2021-02-12' and c2 = '10:00:00';

--echo # 没有查询条件
explain select c1,c2 from t_range_columns limit 2;
explain select c1,c2 from t_range_columns group by c1,c2;

--echo # 查询范围大于分区数
explain select c1,c4 from t_range_columns where c1 > '2009-01-01' and c4 > '2009-01-01 12:00:00.1000';

--echo # 查询条件(如 not in/!= )
explain delete from t_range_columns where c1 != '2021-02-01' and c4 != '2020-01-01 01:00:00';
explain delete from t_range_columns where c1 not in ('2021-01-10','2021-01-15') and c2 not in ('2009-01-01 01:00:00','2009-01-01 21:00:00');

--echo # 分区表达式 fn(col)形式 ,查询条件也是 fn(col) 形式指定范围
explain select c1,c4 from t_range_columns where datediff(c1,c1) < 0 and c4 = '2009-01-01 10:00:00';
explain select c1,c4 from t_range_columns where to_days(c1) = 0 and c4 = '2009-01-01 10:00:00';

--echo # INSERT ... SELECT  常数
explain insert into t_range_columns(c1,c2) select '2021-02-11','2009-01-01 12:00:00';

--echo ### 分区裁剪补充测试
--disable_warnings
drop table if exists t_range_columns;
--enable_warnings
create table t_range_columns (c1 timestamp, c2 timestamp, c3 year, c4 datetime, c5 timestamp) partition by range columns(c1,c2)
(PARTITION p0 VALUES LESS THAN ('2000-01-01 01:01:01','2000-01-01 01:01:01'),
  PARTITION p1 VALUES LESS THAN ('2022-01-01 01:01:01','2022-01-01 01:01:01'),
  PARTITION p2 VALUES LESS THAN ('2038-01-19 03:14:07','2038-01-19 03:14:07'),
  PARTITION p3 VALUES LESS THAN (MAXVALUE,MAXVALUE));

--echo ### to_seconds
explain select c1,c2 from t_range_columns where to_seconds(c1) = to_seconds('2000-06-01');
--echo ### to_days
explain select c1,c2 from t_range_columns where to_days(c1) < '2038-01-19 03:14:07';

--DISABLE_WARNINGS
DROP TABLE IF EXISTS T_PART_SUB;
--ENABLE_WARNINGS

CREATE TABLE T_PART_SUB (C1 DATE, C2 TIMESTAMP, C3 YEAR, C4 DATETIME, C5 TIMESTAMP)
PARTITION BY RANGE COLUMNS (C2)
SUBPARTITION BY HASH( TO_DAYS(C1))(
   PARTITION P0 VALUES LESS THAN ('2000-01-01 01:01:01')(
     SUBPARTITION SUB0, 
	 SUBPARTITION SUB1),
   PARTITION P1 VALUES LESS THAN ('2022-01-01 01:01:01')(
     SUBPARTITION SUB2, 
	 SUBPARTITION SUB3),
   PARTITION P2 VALUES LESS THAN MAXVALUE(
     SUBPARTITION SUB4, 
     SUBPARTITION SUB5));

--echo ### 子分区名称问题，by design。     
EXPLAIN SELECT C1,C2 FROM T_PART_SUB WHERE C1 = '2022-01-13' GROUP BY C1;   

--DISABLE_WARNINGS
DROP TABLE IF EXISTS t_range_partition_1_sub_1;
--ENABLE_WARNINGS
CREATE TABLE t_range_partition_1_sub_1 (
    c1 DOUBLE,
    c2 FLOAT,
    c3 DECIMAL(10, 2),
    c4 TIMESTAMP
)
PARTITION BY RANGE COLUMNS(c1) 
SUBPARTITION BY RANGE COLUMNS (c2)(
    PARTITION p0 VALUES LESS THAN (1000) (
        SUBPARTITION sp0001 VALUES LESS THAN (0),
        SUBPARTITION sp0002 VALUES LESS THAN (1000)
    ),
    PARTITION p1 VALUES LESS THAN (5000) (
        SUBPARTITION sp1111 VALUES LESS THAN (2000),
        SUBPARTITION sp1112 VALUES LESS THAN (5000)
    )
);
--echo ### 超出分区范围的值，OB默认选用第一个分区
EXPLAIN SELECT C1,C2 FROM t_range_partition_1_sub_1 WHERE C1 = '5500' GROUP BY C1;   

--echo ### join分区裁剪
--DISABLE_WARNINGS
DROP TABLE IF EXISTS t_left;
--ENABLE_WARNINGS

create table t_left (n1 int, c1 timestamp, c2 time, c3 year, c4 datetime, c5 timestamp) partition by range columns(c1)
(partition p0 values less than ('2000-01-13'),
 partition p1 values less than ('2022-01-13'),
 partition p2 values less than maxvalue);

--DISABLE_WARNINGS
DROP TABLE IF EXISTS t_right;
--ENABLE_WARNINGS

create table t_right (n1 int, c1 timestamp, c2 time, c3 year, c4 datetime, c5 timestamp) partition by range columns(c1)
(partition p0 values less than ('2000-01-13'),
 partition p1 values less than ('2022-01-13'),
 partition p2 values less than maxvalue);

explain select t_left.n1, t_left.c1 from t_left left outer join t_right on t_left.n1 = t_right.n1 where t_left.c1 = '2022-01-13 01:01:01' and t_right.c1 = '2022-01-13 01:01:01';
explain select t_left.n1, t_left.c1 from t_left  left outer join t_right on t_left.n1 = t_right.n1 where t_right.c1 = '2022-01-13 01:01:01';


--DISABLE_WARNINGS
DROP TABLE IF EXISTS t_left;
--ENABLE_WARNINGS

create table t_left (n1 double, c1 timestamp, c2 time, c3 year, c4 datetime, c5 timestamp) partition by range columns(n1)
(partition p0 values less than (2000.21),
 partition p1 values less than (2022.22),
 partition p2 values less than maxvalue);

--DISABLE_WARNINGS
DROP TABLE IF EXISTS t_right;
--ENABLE_WARNINGS

create table t_right (n1 double, c1 timestamp, c2 time, c3 year, c4 datetime, c5 timestamp) partition by range columns(n1)
(partition p0 values less than (2000.21),
 partition p1 values less than (2022.22),
 partition p2 values less than maxvalue);

explain select t_left.n1, t_left.c1 from t_left left outer join t_right on t_left.n1 = t_right.n1 where t_left.n1 = 2022.22 and t_right.n1 = 2022.22;
explain select t_left.n1, t_left.c1 from t_left  left outer join t_right on t_left.n1 = t_right.n1 where t_right.n1 = 2022.22;

--echo ### 等值传递 double 处理int传递
--DISABLE_WARNINGS
DROP TABLE IF EXISTS t_part_range;
--ENABLE_WARNINGS
create table t_part_range (n0 double, n1 bool, n2 boolean, n3 smallint,n4 mediumint, n5 int, n6 integer,n7 bigint,n8 decimal, n9 dec, n10 float, n11 numeric,n12 double, n13 double precision, n14 real)
partition by range columns(n0)
(partition p0 values less than (10),
 partition p1 values less than (20),
 partition p2 values less than maxvalue);
explain select n0,n1,n2 from t_part_range where n3 = 5 and n0 = n3;
explain select n0,n1,n2 from t_part_range where n3 = 5 and n0 = n3 + 10;

--echo ### 等值传递  double 处理 .0的小数传递，没有分区裁剪;

--DISABLE_WARNINGS
DROP TABLE IF EXISTS t_part_range;
--ENABLE_WARNINGS
create table t_part_range (n0 double, n1 bool, n2 boolean, n3 smallint,n4 mediumint, n5 int, n6 integer,n7 bigint,n8 decimal, n9 dec, n10 float, n11 numeric,n12 double, n13 double precision, n14 real)
partition by range columns(n0)
(partition p0 values less than (10.0),
 partition p1 values less than (20.0),
 partition p2 values less than maxvalue);
explain select n0,n1,n2 from t_part_range where n3 = 5.0 and n0 = n3;
explain select n0,n1,n2 from t_part_range where n3 = 5.0 and n0 = n3 + 10.0;

--echo ### 查询条件是NOT IN 或 !=,  目前OB不会做分区裁剪，by design
--DISABLE_WARNINGS
DROP TABLE IF EXISTS t_part_range;
--ENABLE_WARNINGS

CREATE TABLE t_part_range (a double, b varchar(255))
PARTITION BY RANGE COLUMNS(a)
(PARTITION p0 VALUES LESS THAN (1),
 PARTITION p1 VALUES LESS THAN (2),
 partition p2 values less than maxvalue);
### INSERT INTO t_part_range VALUES (0, "0"), (1,"1");

EXPLAIN SELECT * FROM t_part_range WHERE a != 1;
EXPLAIN SELECT * FROM t_part_range WHERE a NOT IN (-1,1);

--echo ### text/enum/set数据类型
--DISABLE_WARNINGS
DROP TABLE IF EXISTS t_part_range;
--ENABLE_WARNINGS
--error 1659
CREATE TABLE t_part_range (a double,s2 tinytext,s3 text, s4 mediumtext, s5 longtext, s6 enum('1','2','3','4'), s7 set('1','2','3','4'))
PARTITION BY RANGE COLUMNS(a,s2)
(PARTITION p0 VALUES LESS THAN (1,'1'),
 PARTITION p1 VALUES LESS THAN (2,'2'),
 partition p2 values less than maxvalue);
--error 1659
CREATE TABLE t_part_range (a double,s2 tinytext,s3 text, s4 mediumtext, s5 longtext, s6 enum('1','2','3','4'), s7 set('1','2','3','4'))
PARTITION BY RANGE COLUMNS(a,s6)
(PARTITION p0 VALUES LESS THAN (1,'1'),
 PARTITION p1 VALUES LESS THAN (2,'2'),
 partition p2 values less than maxvalue);
--error 1659
CREATE TABLE t_part_range (a double,s2 tinytext,s3 text, s4 mediumtext, s5 longtext, s6 enum('1','2','3','4'), s7 set('1','2','3','4'))
PARTITION BY RANGE COLUMNS(a,s7)
(PARTITION p0 VALUES LESS THAN (1,'1'),
 PARTITION p1 VALUES LESS THAN (2,'2'),
 partition p2 values less than maxvalue);

