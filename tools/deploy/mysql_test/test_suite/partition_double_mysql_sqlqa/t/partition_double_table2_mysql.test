--enable_warnings
--ERROR 1659
CREATE TABLE   EMP(EMPNO   DECIMAL,ENAME   VARCHAR(100) ,JOB  VARCHAR(100),MGR   INT ,HIREDATE DATE,SAL   FLOAT(8,2) ,COMM   INT ,DEPTNO  INT,COMID   INT)PARTITION BY RANGE COLUMNS(EMPNO)
SUBPARTITION BY LIST  COLUMNS(EMPNO,DEPTNO) 
(PARTITION P0 VALUES  LESS THAN(100) (SUBPARTITION    PART01 VALUES  IN ((0,10),(2,10)),SUBPARTITION  PART02     VALUES  IN ((100,20),(300,20)),SUBPARTITION     PART03 VALUES  IN ((1000,20),(3000,30))),
PARTITION P1 VALUES  LESS THAN(5000) (SUBPARTITION     PART04 VALUES  IN ((0,10),(2,10)),SUBPARTITION  PART05     VALUES  IN ((100,20),(300,20)),SUBPARTITION     PART06 VALUES  IN ((1000,20),(3000,30))));

CREATE TABLE   EMP(EMPNO   DECIMAL,ENAME   VARCHAR(100) ,JOB  VARCHAR(100),MGR   INT ,HIREDATE DATE,SAL   FLOAT(8,2) ,COMM   INT ,DEPTNO  INT,COMID   INT)PARTITION BY RANGE COLUMNS(EMPNO)
SUBPARTITION BY LIST  COLUMNS(MGR,DEPTNO) 
(PARTITION P0 VALUES  LESS THAN(100) (SUBPARTITION    PART01 VALUES  IN ((0,10),(2,10)),SUBPARTITION  PART02     VALUES  IN ((100,20),(300,20)),SUBPARTITION     PART03 VALUES  IN ((1000,20),(3000,30))),
PARTITION P1 VALUES  LESS THAN(5000) (SUBPARTITION     PART04 VALUES  IN ((0,10),(2,10)),SUBPARTITION  PART05     VALUES  IN ((100,20),(300,20)),SUBPARTITION     PART06 VALUES  IN ((1000,20),(3000,30))));

--disable_warnings
DROP TABLE IF EXISTS EMP;
--enable_warnings
CREATE TABLE   EMP(EMPNO   DOUBLE,ENAME   VARCHAR(100) ,JOB  VARCHAR(100),MGR   INT ,HIREDATE DATE,SAL   FLOAT(8,2) ,COMM   INT ,DEPTNO  DECIMAL,COMID   INT)PARTITION BY  RANGE COLUMNS(EMPNO,DEPTNO)
SUBPARTITION BY RANGE COLUMNS(DEPTNO,EMPNO)
(PARTITION P0 VALUES  LESS THAN(15,100)(SUBPARTITION PART01  VALUES  LESS THAN(15,100),SUBPARTITION PART02 VALUES  LESS THAN(25,1000),SUBPARTITION PART03 VALUES  LESS THAN(35,6000))
,PARTITION P1 VALUES  LESS THAN(500,100)(SUBPARTITION PART04  VALUES  LESS THAN(15,100),SUBPARTITION PART05 VALUES  LESS THAN(25,1000),SUBPARTITION PART06 VALUES  LESS THAN(35,6000)));

