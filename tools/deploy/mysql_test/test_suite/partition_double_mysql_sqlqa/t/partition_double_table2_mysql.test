--echo ####一级分区分别为 range、range columns（非 double、float、decimal、timestamp） 、hash、key、list、list columns等
--echo ####hash + range columns
--disable_warnings
drop table if exists t_range_partition_1_sub_1;
--enable_warnings
CREATE TABLE t_range_partition_1_sub_1 (
    c1 DOUBLE,
    c2 FLOAT,
    c3 DECIMAL(10, 2),
    c4 date,
	c5 INT
)
PARTITION BY HASH(c5)
SUBPARTITION BY RANGE COLUMNS(c1)(PARTITION P0(SUBPARTITION PART01  VALUES  LESS THAN(15),SUBPARTITION PART02 VALUES  LESS THAN(25),SUBPARTITION PART03 VALUES  LESS THAN(35)),PARTITION P1(SUBPARTITION PART04 VALUES  LESS THAN(15),SUBPARTITION PART05 VALUES  LESS THAN(25),SUBPARTITION PART06 VALUES  LESS THAN(35)));

--disable_warnings
drop table if exists t_range_partition_1_sub_1;
--enable_warnings
CREATE TABLE t_range_partition_1_sub_1 (
    c1 DOUBLE,
    c2 FLOAT,
    c3 DECIMAL(65, 30),
    c4 date,
	c5 INT
)
PARTITION BY HASH(c5)
SUBPARTITION BY RANGE COLUMNS(c1,c3,c4)(PARTITION P0(
SUBPARTITION PART01 VALUES LESS THAN(-2.2250738585072014E-308, -0.000000000000000000000000000001, '1970-01-01 00:00:01'),
SUBPARTITION PART02 VALUES LESS THAN(0, 0, '2024-04-01 00:00:00'),
SUBPARTITION PART03 VALUES LESS THAN(1.7976931348623157E308, 99999999999999999999999999999999999.999999999999999999999999999999, '2038-01-19 03:14:07')),
PARTITION P1(
SUBPARTITION PART04 VALUES  LESS THAN(1000, 1000, '2025-04-01 00:00:01'),
SUBPARTITION PART05 VALUES  LESS THAN(100000, 100000, '2030-04-01 00:00:01'),
SUBPARTITION PART06 VALUES  LESS THAN(1.7976931348623157E308, 99999999999999999999999999999999999.999999999999999999999999999999, '2038-01-19 03:14:07')));

