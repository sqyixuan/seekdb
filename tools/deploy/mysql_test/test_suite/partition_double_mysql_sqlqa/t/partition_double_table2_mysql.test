--enable_warnings
CREATE TABLE   EMP(EMPNO   DECIMAL,ENAME   VARCHAR(100) ,JOB  VARCHAR(100),MGR   INT ,HIREDATE DATE,SAL   FLOAT(8,2) ,COMM   INT ,DEPTNO  INT,COMID   INT)PARTITION BY RANGE COLUMNS(EMPNO)
SUBPARTITION BY KEY(DEPTNO)(PARTITION P0 VALUES  LESS THAN(100)(SUBPARTITION PART01,SUBPARTITION PART02,SUBPARTITION PART03),PARTITION P1 VALUES  LESS THAN(5000)(SUBPARTITION PART04,SUBPARTITION PART05,SUBPARTITION PART06));

