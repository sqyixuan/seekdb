--disable_warnings
DROP TABLE IF EXISTS EMP;
--enable_warnings
CREATE TABLE   EMP(EMPNO   DECIMAL,ENAME   VARCHAR(100) ,JOB  VARCHAR(100),MGR   INT ,HIREDATE DATE,SAL   FLOAT(8,2) ,COMM   INT ,DEPTNO  INT,COMID   INT)PARTITION BY RANGE COLUMNS(EMPNO)
SUBPARTITION BY RANGE(DEPTNO)
(PARTITION P0 VALUES  LESS THAN(100)(SUBPARTITION PART01  VALUES  LESS THAN(15),SUBPARTITION PART02 VALUES  LESS THAN(25),SUBPARTITION PART03 VALUES  LESS THAN(35)),
PARTITION P1 VALUES  LESS THAN(5000)(SUBPARTITION PART04 VALUES  LESS THAN(15),SUBPARTITION PART05 VALUES  LESS THAN(25),SUBPARTITION PART06 VALUES  LESS THAN(35)));

