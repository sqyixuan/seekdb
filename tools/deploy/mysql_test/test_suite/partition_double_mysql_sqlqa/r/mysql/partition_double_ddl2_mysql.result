  (SUBPARTITION P3000_SUB1 VALUES LESS THAN (15, 10),
   SUBPARTITION P3000_SUB2 VALUES LESS THAN (1000, 20),
   SUBPARTITION P3000_SUB3 VALUES LESS THAN (5000, 50));
