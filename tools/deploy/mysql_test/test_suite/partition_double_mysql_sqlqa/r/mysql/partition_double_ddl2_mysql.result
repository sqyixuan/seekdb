purge recyclebin;
drop database if exists sltest;
create database sltest;
use sltest;
set timestamp = 1600000000;
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;
set @@session.explicit_defaults_for_timestamp=off;
result_format: 4
set sql_mode = '';
-----------------------------------------------------------------------------------------------------------------
### 本次支持的类型：double、float、decimal、timestamp 作为range columns分区的分区键。
###  一级分区为 range columns（double、float、decimal、timestamp），二级分区表
drop table if exists EMP;
CREATE TABLE EMP (
    EMPNO DECIMAL,
    ENAME VARCHAR(100),
    JOB VARCHAR(100),
    MGR INT,
    HIREDATE DATE,
    SAL FLOAT(8,2),
    COMM INT,
    DEPTNO INT,
    COMID INT
)
PARTITION BY RANGE COLUMNS(EMPNO)
SUBPARTITION BY RANGE COLUMNS(EMPNO, DEPTNO) 
SUBPARTITION TEMPLATE (
    SUBPARTITION PART001 VALUES LESS THAN (15, 10),
    SUBPARTITION PART002 VALUES LESS THAN (1000, 20),
    SUBPARTITION PART003 VALUES LESS THAN (5000, 50)
)
(
    PARTITION P1000 VALUES LESS THAN (500),
    PARTITION P2000 VALUES LESS THAN (5000)
);
