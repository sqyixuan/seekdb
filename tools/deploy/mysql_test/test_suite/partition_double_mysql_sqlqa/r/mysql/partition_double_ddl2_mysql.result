### 清空分区
ALTER TABLE EMP TRUNCATE PARTITION PART001;
ERROR HY000: Error in list of partitions to DROP
ALTER TABLE EMP TRUNCATE PARTITION PART001,PART002,PART003;
ERROR HY000: Error in list of partitions to DROP
ALTER TABLE EMP TRUNCATE PARTITION P1000,P2000;
ALTER TABLE EMP TRUNCATE PARTITION P1000;
ALTER TABLE EMP TRUNCATE PARTITION P2000;
ALTER TABLE EMP TRUNCATE PARTITION P3000;
### 删除分区
ALTER TABLE EMP DROP PARTITION PART001,PART002;
ERROR HY000: Error in list of partitions to DROP
ALTER TABLE EMP DROP SUBPARTITION PART001,PART002;
ERROR HY000: Partition entry not exists
ALTER TABLE EMP DROP SUBPARTITION PART001;
ERROR HY000: Partition entry not exists
ALTER TABLE EMP DROP SUBPARTITION PART002;
ERROR HY000: Partition entry not exists
select  e.table_name,e.partition_name,e.subpartition_name,e.partition_ordinal_position,e.subpartition_ordinal_position,e.partition_method,e.partition_expression,e.partition_description,e.table_rows,e.avg_row_length,e.data_length,e.create_time,e.update_time
from    information_schema.partitions   e  where table_name = 'EMP';
### 删除二级分区的语法
ALTER TABLE EMP DROP SUBPARTITION P2000sPART001;
ALTER TABLE EMP
DROP  PARTITION P3000;
ALTER TABLE EMP DROP PARTITION P1000,P2000;
ERROR HY000: Cannot remove all partitions, use DROP TABLE instead
ALTER TABLE EMP DROP PARTITION P1000;
ALTER TABLE EMP DROP PARTITION P2000;
ERROR HY000: Cannot remove all partitions, use DROP TABLE instead
ALTER TABLE EMP
ADD PARTITION (PARTITION P3000 VALUES LESS THAN (MAXVALUE));
ALTER TABLE EMP DROP PARTITION P2000;
ALTER TABLE EMP DROP PARTITION P1000,P2000;
ERROR HY000: Cannot remove all partitions, use DROP TABLE instead
### 删除二级分区的语法
ALTER TABLE EMP DROP SUBPARTITION P3000sPART001;
ALTER TABLE EMP DROP SUBPARTITION P3000sPART002;
ALTER TABLE EMP DROP SUBPARTITION P3000sPART003;
ERROR HY000: Cannot remove all partitions, use DROP TABLE instead
### 修改分区表
drop table if exists EMP;
CREATE TABLE EMP (
    EMPNO DECIMAL,
    ENAME VARCHAR(100),
    JOB VARCHAR(100),
    MGR INT,
    HIREDATE DATE,
    SAL FLOAT(8,2),
    COMM INT,
    DEPTNO INT,
    COMID INT
)
PARTITION BY RANGE COLUMNS(EMPNO)
SUBPARTITION BY RANGE COLUMNS(EMPNO, DEPTNO) 
SUBPARTITION TEMPLATE (
    SUBPARTITION PART001 VALUES LESS THAN (15, 10),
    SUBPARTITION PART002 VALUES LESS THAN (1000, 20),
    SUBPARTITION PART003 VALUES LESS THAN (5000, 50),
    SUBPARTITION PART004 VALUES LESS THAN (10000, 100)
)
(
    PARTITION P1000 VALUES LESS THAN (2000),
    PARTITION P2000 VALUES LESS THAN (10000),
	PARTITION P3000 VALUES LESS THAN (MAXVALUE)
);
ALTER TABLE EMP
ADD PARTITION(
    PARTITION P1000 VALUES LESS THAN (2000),
    PARTITION P2000 VALUES LESS THAN (10000),
	PARTITION P3000 VALUES LESS THAN (MAXVALUE)
);
ERROR HY000: Duplicate partition name 'P1000'
ALTER TABLE EMP PARTITION BY RANGE COLUMNS(EMPNO)
SUBPARTITION BY RANGE COLUMNS(EMPNO, DEPTNO) 
SUBPARTITION TEMPLATE (
    SUBPARTITION PART001 VALUES LESS THAN (15, 10),
    SUBPARTITION PART002 VALUES LESS THAN (1000, 20),
    SUBPARTITION PART003 VALUES LESS THAN (5000, 50),
    SUBPARTITION PART004 VALUES LESS THAN (10000, 100)
)
(
    PARTITION P1000 VALUES LESS THAN (2000),
    PARTITION P2000 VALUES LESS THAN (10000),
	PARTITION P3000 VALUES LESS THAN (MAXVALUE)
);
ALTER TABLE EMP PARTITION BY RANGE COLUMNS(EMPNO)
SUBPARTITION BY RANGE COLUMNS(EMPNO, DEPTNO)
SUBPARTITION TEMPLATE (
    SUBPARTITION PART001 VALUES LESS THAN (15, 10),
    SUBPARTITION PART002 VALUES LESS THAN (1000, 20),
    SUBPARTITION PART003 VALUES LESS THAN (4000, 50),
    SUBPARTITION PART004 VALUES LESS THAN (10000, 100)
)
(
    PARTITION P1000 VALUES LESS THAN (1000),
    PARTITION P2000 VALUES LESS THAN (20000),
	PARTITION P3000 VALUES LESS THAN (MAXVALUE)
);
### 分区分裂/合并 
drop table if exists EMP;
CREATE TABLE EMP (
    EMPNO DECIMAL,
    ENAME VARCHAR(100),
    JOB VARCHAR(100),
    MGR INT,
    HIREDATE DATE,
    SAL FLOAT(8,2),
    COMM INT,
    DEPTNO INT,
    COMID INT
)
PARTITION BY RANGE COLUMNS(EMPNO)
SUBPARTITION BY RANGE COLUMNS(EMPNO, DEPTNO) 
SUBPARTITION TEMPLATE (
    SUBPARTITION PART001 VALUES LESS THAN (15, 10),
    SUBPARTITION PART002 VALUES LESS THAN (1000, 20),
    SUBPARTITION PART003 VALUES LESS THAN (5000, 50)
)
(
    PARTITION P1000 VALUES LESS THAN (500),
    PARTITION P2000 VALUES LESS THAN (5000)
);
