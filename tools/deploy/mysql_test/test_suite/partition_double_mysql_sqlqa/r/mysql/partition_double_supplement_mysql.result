  1 - output([emp.EMPNO], [emp.ENAME], [emp.JOB], [emp.MGR], [emp.HIREDATE], [emp.SAL], [emp.COMM], [emp.DEPTNO], [emp.COMID]), filter(nil), rowset=16
  2 - output([emp.EMPNO], [emp.ENAME], [emp.JOB], [emp.MGR], [emp.HIREDATE], [emp.SAL], [emp.COMM], [emp.DEPTNO], [emp.COMID]), filter(nil), rowset=16
      dop=1
  3 - output([emp.EMPNO], [emp.SAL], [emp.DEPTNO], [emp.HIREDATE], [emp.ENAME], [emp.JOB], [emp.MGR], [emp.COMM], [emp.COMID]), filter(nil), rowset=16
      force partition granule
  4 - output([emp.EMPNO], [emp.SAL], [emp.DEPTNO], [emp.HIREDATE], [emp.ENAME], [emp.JOB], [emp.MGR], [emp.COMM], [emp.COMID]), filter([emp.EMPNO <= cast(5000.0,
       DOUBLE(-1, -1))], [emp.HIREDATE >= cast('2000-01-01 00:00:00', TIMESTAMP(-1, -1))]), rowset=16
      access([emp.EMPNO], [emp.SAL], [emp.DEPTNO], [emp.HIREDATE], [emp.ENAME], [emp.JOB], [emp.MGR], [emp.COMM], [emp.COMID]), partitions(p0sp[0-2], p1sp[0-2],
       p2sp[0-2])
      is_index_back=false, is_global_index=false, filter_before_indexback[false,false], 
      range_key([emp.__pk_increment]), range(MIN ; MAX)always true
  5 - output([emp.EMPNO], [emp.ENAME], [emp.JOB], [emp.MGR], [emp.HIREDATE], [emp.SAL], [emp.COMM], [emp.DEPTNO], [emp.COMID]), filter(nil), rowset=16
  6 - output([emp.EMPNO], [emp.ENAME], [emp.JOB], [emp.MGR], [emp.HIREDATE], [emp.SAL], [emp.COMM], [emp.DEPTNO], [emp.COMID]), filter(nil), rowset=16
      dop=1
  7 - output([emp.EMPNO], [emp.SAL], [emp.DEPTNO], [emp.HIREDATE], [emp.ENAME], [emp.JOB], [emp.MGR], [emp.COMM], [emp.COMID]), filter(nil), rowset=16
      force partition granule
  8 - output([emp.EMPNO], [emp.SAL], [emp.DEPTNO], [emp.HIREDATE], [emp.ENAME], [emp.JOB], [emp.MGR], [emp.COMM], [emp.COMID]), filter([cast(5000.0, DOUBLE(-1,
       -1)) >= emp.EMPNO], [emp.HIREDATE >= cast('2000-01-01 00:00:00', TIMESTAMP(-1, -1))]), rowset=16
      access([emp.EMPNO], [emp.SAL], [emp.DEPTNO], [emp.HIREDATE], [emp.ENAME], [emp.JOB], [emp.MGR], [emp.COMM], [emp.COMID]), partitions(p0sp[0-2], p1sp[0-2],
       p2sp[0-2])
      is_index_back=false, is_global_index=false, filter_before_indexback[false,false], 
      range_key([emp.__pk_increment]), range(MIN ; MAX)always true
