TRUNCATE TABLE EMP_2;
TRUNCATE TABLE EMP;
##### 相关场景补充 视图
DROP VIEW IF EXISTS EMP_VIEW;
CREATE OR REPLACE VIEW EMP_VIEW AS SELECT * FROM EMP;
SELECT * FROM EMP_VIEW;
+-------+-------+------+------+----------+------+------+--------+-------+
| EMPNO | ENAME | JOB  | MGR  | HIREDATE | SAL  | COMM | DEPTNO | COMID |
+-------+-------+------+------+----------+------+------+--------+-------+
+-------+-------+------+------+----------+------+------+--------+-------+
### 查看分区裁剪结果
EXPLAIN SELECT * FROM EMP RIGHT OUTER JOIN EMP_2 ON EMP.EMPNO = EMP_2.EMPNO WHERE EMP_2.EMPNO < 1000.0;
Query Plan
===============================================================
|ID|OPERATOR                   |NAME    |EST.ROWS|EST.TIME(us)|
---------------------------------------------------------------
|0 |HASH OUTER JOIN            |        |1       |24          |
|1 |├─TABLE FULL SCAN          |emp_2   |1       |3           |
|2 |└─PX COORDINATOR           |        |1       |21          |
|3 |  └─EXCHANGE OUT DISTR     |:EX10000|1       |19          |
|4 |    └─PX PARTITION ITERATOR|        |1       |13          |
|5 |      └─TABLE FULL SCAN    |emp     |1       |13          |
===============================================================
Outputs & filters:
-------------------------------------
  0 - output([emp.EMPNO], [emp.ENAME], [emp.JOB], [emp.MGR], [emp.HIREDATE], [emp.SAL], [emp.COMM], [emp.DEPTNO], [emp.COMID], [emp_2.EMPNO], [emp_2.ENAME],
       [emp_2.JOB], [emp_2.MGR], [emp_2.HIREDATE], [emp_2.SAL], [emp_2.COMM], [emp_2.DEPTNO], [emp_2.COMID]), filter(nil), rowset=16
      equal_conds([emp.EMPNO = emp_2.EMPNO]), other_conds(nil)
  1 - output([emp_2.EMPNO], [emp_2.ENAME], [emp_2.JOB], [emp_2.MGR], [emp_2.HIREDATE], [emp_2.SAL], [emp_2.COMM], [emp_2.DEPTNO], [emp_2.COMID]), filter([emp_2.EMPNO 
      < cast(1000.0, DOUBLE(-1, -1))]), rowset=16
      access([emp_2.EMPNO], [emp_2.ENAME], [emp_2.JOB], [emp_2.MGR], [emp_2.HIREDATE], [emp_2.SAL], [emp_2.COMM], [emp_2.DEPTNO], [emp_2.COMID]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([emp_2.__pk_increment]), range(MIN ; MAX)always true
  2 - output([emp.EMPNO], [emp.ENAME], [emp.JOB], [emp.MGR], [emp.HIREDATE], [emp.SAL], [emp.COMM], [emp.DEPTNO], [emp.COMID]), filter(nil), rowset=16
  3 - output([emp.EMPNO], [emp.ENAME], [emp.JOB], [emp.MGR], [emp.HIREDATE], [emp.SAL], [emp.COMM], [emp.DEPTNO], [emp.COMID]), filter(nil), rowset=16
      dop=1
  4 - output([emp.EMPNO], [emp.SAL], [emp.DEPTNO], [emp.HIREDATE], [emp.ENAME], [emp.JOB], [emp.MGR], [emp.COMM], [emp.COMID]), filter(nil), rowset=16
      force partition granule
  5 - output([emp.EMPNO], [emp.SAL], [emp.DEPTNO], [emp.HIREDATE], [emp.ENAME], [emp.JOB], [emp.MGR], [emp.COMM], [emp.COMID]), filter([cast(1000.0, DOUBLE(-1,
       -1)) > emp.EMPNO]), rowset=16
      access([emp.EMPNO], [emp.SAL], [emp.DEPTNO], [emp.HIREDATE], [emp.ENAME], [emp.JOB], [emp.MGR], [emp.COMM], [emp.COMID]), partitions(p0sp[0-2], p1sp[0-2])
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([emp.__pk_increment]), range(MIN ; MAX)always true
EXPLAIN SELECT * FROM EMP RIGHT OUTER JOIN EMP_VIEW ON EMP.EMPNO = EMP_VIEW.EMPNO WHERE EMP_VIEW.EMPNO >= 5000.0 AND EMP.EMPNO < 10000.0;
Query Plan
===============================================================
|ID|OPERATOR                   |NAME    |EST.ROWS|EST.TIME(us)|
---------------------------------------------------------------
|0 |HASH JOIN                  |        |1       |30          |
|1 |├─PX COORDINATOR           |        |1       |15          |
|2 |│ └─EXCHANGE OUT DISTR     |:EX10000|1       |12          |
|3 |│   └─PX PARTITION ITERATOR|        |1       |7           |
|4 |│     └─TABLE FULL SCAN    |emp     |1       |7           |
|5 |└─PX COORDINATOR           |        |1       |15          |
|6 |  └─EXCHANGE OUT DISTR     |:EX20000|1       |12          |
|7 |    └─PX PARTITION ITERATOR|        |1       |7           |
|8 |      └─TABLE FULL SCAN    |emp     |1       |7           |
===============================================================
Outputs & filters:
-------------------------------------
  0 - output([emp.EMPNO], [emp.ENAME], [emp.JOB], [emp.MGR], [emp.HIREDATE], [emp.SAL], [emp.COMM], [emp.DEPTNO], [emp.COMID], [emp.EMPNO], [emp.ENAME],
       [emp.JOB], [emp.MGR], [emp.HIREDATE], [emp.SAL], [emp.COMM], [emp.DEPTNO], [emp.COMID]), filter(nil), rowset=16
      equal_conds([emp.EMPNO = emp.EMPNO]), other_conds(nil)
  1 - output([emp.EMPNO], [emp.ENAME], [emp.JOB], [emp.MGR], [emp.HIREDATE], [emp.SAL], [emp.COMM], [emp.DEPTNO], [emp.COMID]), filter(nil), rowset=16
  2 - output([emp.EMPNO], [emp.ENAME], [emp.JOB], [emp.MGR], [emp.HIREDATE], [emp.SAL], [emp.COMM], [emp.DEPTNO], [emp.COMID]), filter(nil), rowset=16
      dop=1
  3 - output([emp.EMPNO], [emp.SAL], [emp.DEPTNO], [emp.HIREDATE], [emp.ENAME], [emp.JOB], [emp.MGR], [emp.COMM], [emp.COMID]), filter(nil), rowset=16
      force partition granule
  4 - output([emp.EMPNO], [emp.SAL], [emp.DEPTNO], [emp.HIREDATE], [emp.ENAME], [emp.JOB], [emp.MGR], [emp.COMM], [emp.COMID]), filter([emp.EMPNO >= cast(5000.0,
       DOUBLE(-1, -1))], [cast(10000.0, DOUBLE(-1, -1)) > emp.EMPNO]), rowset=16
      access([emp.EMPNO], [emp.SAL], [emp.DEPTNO], [emp.HIREDATE], [emp.ENAME], [emp.JOB], [emp.MGR], [emp.COMM], [emp.COMID]), partitions(p2sp[0-2])
      is_index_back=false, is_global_index=false, filter_before_indexback[false,false], 
      range_key([emp.__pk_increment]), range(MIN ; MAX)always true
  5 - output([emp.EMPNO], [emp.ENAME], [emp.JOB], [emp.MGR], [emp.HIREDATE], [emp.SAL], [emp.COMM], [emp.DEPTNO], [emp.COMID]), filter(nil), rowset=16
  6 - output([emp.EMPNO], [emp.ENAME], [emp.JOB], [emp.MGR], [emp.HIREDATE], [emp.SAL], [emp.COMM], [emp.DEPTNO], [emp.COMID]), filter(nil), rowset=16
      dop=1
  7 - output([emp.EMPNO], [emp.SAL], [emp.DEPTNO], [emp.HIREDATE], [emp.ENAME], [emp.JOB], [emp.MGR], [emp.COMM], [emp.COMID]), filter(nil), rowset=16
      force partition granule
  8 - output([emp.EMPNO], [emp.SAL], [emp.DEPTNO], [emp.HIREDATE], [emp.ENAME], [emp.JOB], [emp.MGR], [emp.COMM], [emp.COMID]), filter([emp.EMPNO < cast(10000.0,
       DOUBLE(-1, -1))], [emp.EMPNO >= cast(5000.0, DOUBLE(-1, -1))]), rowset=16
      access([emp.EMPNO], [emp.SAL], [emp.DEPTNO], [emp.HIREDATE], [emp.ENAME], [emp.JOB], [emp.MGR], [emp.COMM], [emp.COMID]), partitions(p2sp[0-2])
      is_index_back=false, is_global_index=false, filter_before_indexback[false,false], 
      range_key([emp.__pk_increment]), range(MIN ; MAX)always true
