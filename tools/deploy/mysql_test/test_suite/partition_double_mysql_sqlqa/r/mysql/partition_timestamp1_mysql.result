purge recyclebin;
drop database if exists sltest;
create database sltest;
use sltest;
set timestamp = 1600000000;
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;
set @@session.explicit_defaults_for_timestamp=off;
result_format: 4
set sql_mode = '';
-----------------------------------------------------------------------------------------------------------------
### 本次支持的类型：double、float、decimal、timestamp 作为range columns分区的分区键。
### 1970-01-01 00:00:01 UTC到2038-01-19 03:14:07 UTC
DROP TABLE IF EXISTS t_timestamp_range1;
CREATE TABLE t_timestamp_range1 (
    c1 TIMESTAMP
) 
PARTITION BY RANGE COLUMNS(c1) (
    PARTITION p0 VALUES LESS THAN ('2024-04-01 00:00:00'),
    PARTITION p1 VALUES LESS THAN ('2024-08-01 00:00:00'),
    PARTITION p2 VALUES LESS THAN ('2024-12-01 00:00:00')
);
INSERT INTO t_timestamp_range1 (c1) VALUES
('2024-12-01 00:00:00');
ERROR HY000: Table has no partition for value
INSERT INTO t_timestamp_range1 (c1) VALUES
('2024-03-31 23:59:59'), 
('2024-04-01 00:00:00'), 

('2024-07-31 23:59:59'), 
('2024-08-01 00:00:00'), 

('2024-11-30 23:59:59');
SELECT * FROM t_timestamp_range1 PARTITION (p0);
+---------------------+
| c1                  |
+---------------------+
| 2024-03-31 23:59:59 |
+---------------------+
SELECT * FROM t_timestamp_range1 PARTITION (p1);
+---------------------+
| c1                  |
+---------------------+
| 2024-04-01 00:00:00 |
| 2024-07-31 23:59:59 |
+---------------------+
SELECT * FROM t_timestamp_range1 PARTITION (p2);
+---------------------+
| c1                  |
+---------------------+
| 2024-08-01 00:00:00 |
| 2024-11-30 23:59:59 |
+---------------------+
DROP TABLE IF EXISTS t_timestamp_range1;
CREATE TABLE t_timestamp_range1 (
    c1 TIMESTAMP
) 
PARTITION BY RANGE COLUMNS(c1) (
    PARTITION p0 VALUES LESS THAN ('1970-01-01 00:00:01'),
    PARTITION p1 VALUES LESS THAN ('2024-04-01 00:00:00'),
    PARTITION p2 VALUES LESS THAN ('2024-08-01 00:00:00'),
    PARTITION p3 VALUES LESS THAN ('2024-12-01 00:00:00'),
    PARTITION p4 VALUES LESS THAN ('2038-01-19 03:14:07')
);
INSERT INTO t_timestamp_range1 (c1) VALUES
('2038-01-19 03:14:07');
ERROR HY000: Table has no partition for value
INSERT INTO t_timestamp_range1 (c1) VALUES
('1970-01-01 00:00:01'), 
('2024-03-31 23:59:59'), 
('2024-04-01 00:00:00'), 
('2024-07-31 23:59:59'), 
('2024-08-01 00:00:00'), 
('2024-11-30 23:59:59'), 
('2024-12-01 00:00:00');
SELECT * FROM t_timestamp_range1 PARTITION (p0);
+----+
| c1 |
+----+
+----+
SELECT * FROM t_timestamp_range1 PARTITION (p1);
+---------------------+
| c1                  |
+---------------------+
| 1970-01-01 00:00:01 |
| 2024-03-31 23:59:59 |
+---------------------+
SELECT * FROM t_timestamp_range1 PARTITION (p2);
+---------------------+
| c1                  |
+---------------------+
| 2024-04-01 00:00:00 |
| 2024-07-31 23:59:59 |
+---------------------+
SELECT * FROM t_timestamp_range1 PARTITION (p3);
+---------------------+
| c1                  |
+---------------------+
| 2024-08-01 00:00:00 |
| 2024-11-30 23:59:59 |
+---------------------+
SELECT * FROM t_timestamp_range1 PARTITION (p4);
+---------------------+
| c1                  |
+---------------------+
| 2024-12-01 00:00:00 |
+---------------------+
INSERT INTO t_timestamp_range1 (c1) VALUES
('1970-01-01 00:00:01'),
('2038-01-19 03:14:06'),
(NOW()),
(CURDATE()),
(FROM_UNIXTIME(UNIX_TIMESTAMP())),
('2024-01-01'),
('2024-01-01 12:00:00'),
('2024-02-01 12:34:56'),
('2024-04-01'),
('2024-04-01 12:00:00'),
('2024-04-01 12:00:00.000000'),
('2024-07-01 12:00:00'),
('2024-08-01 12:00:00'),
('2024-08-01'),
('2024-09-01 12:00:00'),
('2024-10-01 12:00:00'),
('2024-12-01 12:00:00');
SELECT * FROM t_timestamp_range1 PARTITION (p0);
SELECT * FROM t_timestamp_range1 PARTITION (p1);
SELECT * FROM t_timestamp_range1 PARTITION (p2);
SELECT * FROM t_timestamp_range1 PARTITION (p3);
SELECT * FROM t_timestamp_range1 PARTITION (p4);
DROP TABLE IF EXISTS t_timestamp_range1;
CREATE TABLE t_timestamp_range1 (
    c1 TIMESTAMP
) 
PARTITION BY RANGE COLUMNS(c1) (
    PARTITION p0 VALUES LESS THAN ('1969-01-01 00:00:01'),
    PARTITION p1 VALUES LESS THAN ('2024-04-01 00:00:00'),
    PARTITION p2 VALUES LESS THAN ('2024-08-01 00:00:00'),
    PARTITION p3 VALUES LESS THAN ('2024-12-01 00:00:00'),
    PARTITION p4 VALUES LESS THAN ('2039-01-19 03:14:07')
);
#### 超过最大值，OB与MYSQL实现不一致。
INSERT INTO t_timestamp_range1 (c1) VALUES
('1968-01-01 00:00:00'), 
('1970-01-01 00:00:00'), 
('2024-11-30 23:59:59'), 
('2038-01-19 03:14:07'), 
('2038-01-20 03:14:07'), 
('2039-01-18 03:14:07');
SELECT * FROM t_timestamp_range1 PARTITION (p0);
+---------------------+
| c1                  |
+---------------------+
| 1968-01-01 00:00:00 |
+---------------------+
SELECT * FROM t_timestamp_range1 PARTITION (p1);
+---------------------+
| c1                  |
+---------------------+
| 1970-01-01 00:00:00 |
+---------------------+
SELECT * FROM t_timestamp_range1 PARTITION (p2);
+----+
| c1 |
+----+
+----+
SELECT * FROM t_timestamp_range1 PARTITION (p3);
+---------------------+
| c1                  |
+---------------------+
| 2024-11-30 23:59:59 |
+---------------------+
SELECT * FROM t_timestamp_range1 PARTITION (p4);
+---------------------+
| c1                  |
+---------------------+
| 2038-01-19 03:14:07 |
| 2038-01-20 03:14:07 |
| 2039-01-18 03:14:07 |
+---------------------+
### LESS THAN 日期混用
DROP TABLE IF EXISTS t_timestamp_range1;
CREATE TABLE t_timestamp_range1 (
    c1 TIMESTAMP
) 
PARTITION BY RANGE COLUMNS(c1) (
    PARTITION p0 VALUES LESS THAN ('1969-01-01 00:00:01'),
    PARTITION p1 VALUES LESS THAN (timestamp '2024-04-01 00:00:00'),
    PARTITION p2 VALUES LESS THAN (date '2024-08-01'),
    PARTITION p3 VALUES LESS THAN (time '08:00:00'),
    PARTITION p4 VALUES LESS THAN ('2039-01-19 03:14:07')
);
ERROR HY000: VALUES LESS THAN value must be strictly increasing for each partition
CREATE TABLE t_timestamp_range1 (
    c1 TIMESTAMP
) 
PARTITION BY RANGE COLUMNS(c1) (
    PARTITION p0 VALUES LESS THAN (timestamp '1969-01-01 00:00:01'),
    PARTITION p1 VALUES LESS THAN (timestamp '2024-04-01 00:00:00'),
    PARTITION p2 VALUES LESS THAN (date '2024-08-01'),
    PARTITION p3 VALUES LESS THAN (timestamp '2024-12-01 00:00:00'),
    PARTITION p4 VALUES LESS THAN ('2039-01-19 03:14:07')
);
#### 超过最大值，OB与MYSQL实现不一致。
INSERT INTO t_timestamp_range1 (c1) VALUES
('1968-01-01 00:00:00'),  
('1970-01-01 00:00:00'),  
(timestamp '1968-01-01 00:00:00'),
(timestamp '1970-01-01 00:00:00'),
(timestamp '2024-11-30 23:59:59'),
('2038-01-19 03:14:07'), 
('2038-01-20 03:14:07'), 
('2039-01-18 03:14:07');
SELECT * FROM t_timestamp_range1 PARTITION (p0);
SELECT * FROM t_timestamp_range1 PARTITION (p1);
SELECT * FROM t_timestamp_range1 PARTITION (p2);
SELECT * FROM t_timestamp_range1 PARTITION (p3);
SELECT * FROM t_timestamp_range1 PARTITION (p4);
INSERT INTO t_timestamp_range1 (c1) VALUES
(date '1968-01-01'), 
(time '00:00:00'),
(timestamp'2039-01-18 03:14:07');
SELECT * FROM t_timestamp_range1 PARTITION (p0);
SELECT * FROM t_timestamp_range1 PARTITION (p1);
SELECT * FROM t_timestamp_range1 PARTITION (p2);
SELECT * FROM t_timestamp_range1 PARTITION (p3);
SELECT * FROM t_timestamp_range1 PARTITION (p4);
DROP TABLE IF EXISTS t_timestamp_range1;
CREATE TABLE t_timestamp_range1 (
    c1 TIMESTAMP
) 
PARTITION BY RANGE COLUMNS(c1) (
    PARTITION p0 VALUES LESS THAN ('0001-01-01 00:00:01'),
    PARTITION p1 VALUES LESS THAN ('1969-01-01 00:00:01'),
    PARTITION p2 VALUES LESS THAN ('1970-01-01 00:00:01'),
    PARTITION p3 VALUES LESS THAN ('1970-01-01 00:00:02'),
    PARTITION p4 VALUES LESS THAN ('2024-12-01 00:00:00'),
    PARTITION p5 VALUES LESS THAN ('2039-01-19 03:14:07'),
    PARTITION p6 VALUES LESS THAN ('2099-01-19 03:14:07')
);
INSERT INTO t_timestamp_range1 (c1) VALUES
('0001-01-01 00:00:00'),
('0001-01-01 00:00:01'),
('1968-01-01 00:00:00'),
('1970-01-01 00:00:00'),
('2013-02-29 23:59:59'),
('2024-11-30 23:59:59'),
('2038-01-19 03:14:07'),
('2038-01-20 03:14:07'),
('2039-01-20 03:14:07'),
('2099-01-18 03:14:07');
INSERT INTO t_timestamp_range1 (c1) VALUES (1600000000);
INSERT INTO t_timestamp_range1 (c1) VALUES (16000.00000);
INSERT INTO t_timestamp_range1 (c1) VALUES (CAST(2.5 AS DOUBLE));
INSERT INTO t_timestamp_range1 (c1) VALUES (CAST(3.14159 AS DECIMAL(10,5)));
INSERT INTO t_timestamp_range1 (c1) VALUES (CAST(1600000000 AS DOUBLE));
SELECT * FROM t_timestamp_range1 PARTITION (p0);
+---------------------+
| c1                  |
+---------------------+
| 0001-01-01 00:00:00 |
| 0000-00-00 00:00:00 |
| 0000-00-00 00:00:00 |
| 0000-00-00 00:00:00 |
| 0000-00-00 00:00:00 |
| 0000-00-00 00:00:00 |
| 0000-00-00 00:00:00 |
+---------------------+
SELECT * FROM t_timestamp_range1 PARTITION (p1);
+---------------------+
| c1                  |
+---------------------+
| 0001-01-01 00:00:01 |
| 1968-01-01 00:00:00 |
+---------------------+
SELECT * FROM t_timestamp_range1 PARTITION (p2);
+---------------------+
| c1                  |
+---------------------+
| 1970-01-01 00:00:00 |
+---------------------+
SELECT * FROM t_timestamp_range1 PARTITION (p3);
+----+
| c1 |
+----+
+----+
SELECT * FROM t_timestamp_range1 PARTITION (p4);
+---------------------+
| c1                  |
+---------------------+
| 2024-11-30 23:59:59 |
+---------------------+
SELECT * FROM t_timestamp_range1 PARTITION (p5);
+---------------------+
| c1                  |
+---------------------+
| 2038-01-19 03:14:07 |
| 2038-01-20 03:14:07 |
+---------------------+
SELECT * FROM t_timestamp_range1 PARTITION (p6);
+---------------------+
| c1                  |
+---------------------+
| 2039-01-20 03:14:07 |
| 2099-01-18 03:14:07 |
+---------------------+
DROP TABLE IF EXISTS t_timestamp_range1;
CREATE TABLE t_timestamp_range1 (
    c1 TIMESTAMP DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP
) 
PARTITION BY RANGE COLUMNS(c1) (
    PARTITION p_min VALUES LESS THAN ('1970-01-01 00:00:01'),
    PARTITION p0 VALUES LESS THAN ('2024-04-01 00:00:00'),
    PARTITION p1 VALUES LESS THAN ('2024-08-01 00:00:00'),
    PARTITION p2 VALUES LESS THAN ('2024-12-01 00:00:00'),
    PARTITION p_max VALUES LESS THAN ('2038-01-19 03:14:07')
);
### -- 假设我们将时区设置为 'America/New_York'
### SET time_zone = 'America/New_York';
set timestamp = 1200000000;
INSERT INTO t_timestamp_range1 (c1) VALUES
('2023-12-31 23:59:59'),
('2024-01-01 12:00:00'),
('2024-04-01 00:00:00'),
('2024-05-01 12:00:00'),
(NOW()),
(DEFAULT);
INSERT INTO t_timestamp_range1 (c1) VALUES
('0000-00-00 00:00:00'),
('2013-02-29 23:59:59');
SELECT * FROM t_timestamp_range1 PARTITION (p_min);
SELECT * FROM t_timestamp_range1 PARTITION (p0);
SELECT * FROM t_timestamp_range1 PARTITION (p1);
SELECT * FROM t_timestamp_range1 PARTITION (p2);
SELECT * FROM t_timestamp_range1 PARTITION (p_max);
SELECT * FROM t_timestamp_range1;
set timestamp = 1600000000;
######## 清空回收站，删除测试数据库 ########
drop database if exists sltest;
purge recyclebin;
