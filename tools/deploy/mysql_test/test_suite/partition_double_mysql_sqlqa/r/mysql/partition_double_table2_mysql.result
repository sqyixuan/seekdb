DROP TABLE IF EXISTS EMP;
CREATE TABLE   EMP(EMPNO   DECIMAL,ENAME   VARCHAR(100) ,JOB  VARCHAR(100),MGR   INT ,HIREDATE DATE,SAL   FLOAT(8,2) ,COMM   INT ,DEPTNO  INT,COMID   INT)PARTITION BY RANGE (MGR)
SUBPARTITION BY  RANGE COLUMNS(DEPTNO,EMPNO)SUBPARTITION TEMPLATE(SUBPARTITION PART001  VALUES  LESS THAN(15,100),SUBPARTITION PART002  VALUES  LESS THAN(25,1000),SUBPARTITION PART003  VALUES  LESS THAN(35,10000))
(PARTITION P1000 VALUES  LESS THAN(100),PARTITION P2000 VALUES  LESS THAN(5000));
SELECT * FROM EMP PARTITION(P1000) ORDER BY   EMPNO,SAL,JOB;
