DROP TABLE IF EXISTS EMP;
CREATE TABLE   EMP(EMPNO   INT,ENAME   VARCHAR(100) ,JOB  VARCHAR(100),MGR   INT ,HIREDATE DATE,SAL   FLOAT(8,2) ,COMM   INT ,DEPTNO  DECIMAL ,COMID   INT)PARTITION BY LIST COLUMNS(EMPNO,DEPTNO)
SUBPARTITION BY RANGE COLUMNS(DEPTNO)
(PARTITION P0 VALUES  IN((1,10),(2,20),(3,30))(SUBPARTITION PART01  VALUES  LESS THAN(15),SUBPARTITION PART02 VALUES  LESS THAN(25),SUBPARTITION PART03 VALUES  LESS THAN(35)),
PARTITION P1 VALUES  IN((100,10),(200,20),(300,30))(SUBPARTITION PART04 VALUES  LESS THAN(15),SUBPARTITION PART05 VALUES  LESS THAN(25),SUBPARTITION PART06 VALUES  LESS THAN(35)));
