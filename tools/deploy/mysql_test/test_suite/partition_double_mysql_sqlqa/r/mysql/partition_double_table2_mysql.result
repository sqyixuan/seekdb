CREATE TABLE   EMP(EMPNO   INT,ENAME   VARCHAR(100) ,JOB  VARCHAR(100),MGR   INT ,HIREDATE DATE,SAL   FLOAT(8,2) ,COMM   INT ,DEPTNO  DECIMAL ,COMID   INT)PARTITION BY LIST COLUMNS(EMPNO,MGR)
SUBPARTITION BY RANGE COLUMNS(DEPTNO)
(PARTITION P0 VALUES  IN((1,10),(2,20),(3,30))(SUBPARTITION PART01  VALUES  LESS THAN(15),SUBPARTITION PART02 VALUES  LESS THAN(25),SUBPARTITION PART03 VALUES  LESS THAN(35)),
PARTITION P1 VALUES  IN((100,10),(200,20),(300,30))(SUBPARTITION PART04 VALUES  LESS THAN(15),SUBPARTITION PART05 VALUES  LESS THAN(25),SUBPARTITION PART06 VALUES  LESS THAN(35)));
##非模板化分区
DROP TABLE IF EXISTS EMP;
CREATE TABLE EMP (
  EMPNO INT,
  ENAME VARCHAR(100),
  JOB VARCHAR(100),
  MGR INT,
  HIREDATE DATE,
  SAL FLOAT(8, 2),
  COMM INT,
  DEPTNO DECIMAL,
  COMID INT
)
PARTITION BY LIST COLUMNS (EMPNO, MGR)
SUBPARTITION BY RANGE COLUMNS (DEPTNO) (
  PARTITION P0 VALUES IN ((1, 10), (2, 20), (3, 30)) (
    SUBPARTITION PART01 VALUES LESS THAN (15),
    SUBPARTITION PART02 VALUES LESS THAN (25),
    SUBPARTITION PART03 VALUES LESS THAN (35)
  ),
  PARTITION P1 VALUES IN ((100, 10), (200, 20), (300, 30)) (
    SUBPARTITION PART04 VALUES LESS THAN (15),
    SUBPARTITION PART05 VALUES LESS THAN (25),
    SUBPARTITION PART06 VALUES LESS THAN (35)
  )
);
##模板化分区
DROP TABLE IF EXISTS EMP;
CREATE TABLE EMP (
  EMPNO INT,
  ENAME VARCHAR(100),
  JOB VARCHAR(100),
  MGR INT,
  HIREDATE DATE,
  SAL FLOAT(8, 2),
  COMM INT,
  DEPTNO DECIMAL,
  COMID INT
)
PARTITION BY LIST COLUMNS (EMPNO, MGR)
SUBPARTITION BY RANGE COLUMNS (DEPTNO) 
SUBPARTITION TEMPLATE(
    SUBPARTITION PART01 VALUES LESS THAN (15),
    SUBPARTITION PART02 VALUES LESS THAN (25),
    SUBPARTITION PART03 VALUES LESS THAN (35)
  )
(
PARTITION P0 VALUES IN ((1, 10), (2, 20), (3, 30)),
PARTITION P1 VALUES IN ((100, 10), (200, 20), (300, 30))
);
DROP TABLE IF EXISTS EMP;
CREATE TABLE EMP (
  EMPNO INT,
  ENAME VARCHAR(100),
  JOB VARCHAR(100),
  MGR INT,
  HIREDATE DATE,
  SAL FLOAT(8, 2),
  COMM INT,
  DEPTNO DECIMAL,
  COMID INT
)
PARTITION BY LIST COLUMNS (EMPNO, MGR)
SUBPARTITION BY RANGE COLUMNS (DEPTNO) (
  PARTITION P0 VALUES IN ((1, 10), (2, 20), (3, 30)) (
    SUBPARTITION PART01 VALUES LESS THAN (15),
    SUBPARTITION PART02 VALUES LESS THAN (25),
    SUBPARTITION PART03 VALUES LESS THAN (35)
  ),
  PARTITION P1 VALUES IN ((100, 10), (200, 20), (300, 30)) (
    SUBPARTITION PART04 VALUES LESS THAN (15),
    SUBPARTITION PART05 VALUES LESS THAN (25),
    SUBPARTITION PART06 VALUES LESS THAN (35)
  )
);
##对临时表创建分区
DROP TABLE IF EXISTS temp_t_range_partition_1;
CREATE TEMPORARY TABLE temp_t_range_partition_1 (
c1 DOUBLE,
c2 FLOAT,
c3 DECIMAL(10, 2),
c4 TIMESTAMP
)
PARTITION BY RANGE COLUMNS(c1, c3, c4) (
PARTITION p0 VALUES LESS THAN (0, 0, '2000-01-01'),
PARTITION p1 VALUES LESS THAN (1000, 1000, '2010-01-01'),
PARTITION p2 VALUES LESS THAN (5000, 5000, '2020-01-01')
);
