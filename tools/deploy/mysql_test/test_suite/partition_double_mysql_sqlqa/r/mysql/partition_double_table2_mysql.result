purge recyclebin;
drop database if exists sltest;
create database sltest;
use sltest;
set timestamp = 1600000000;
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;
set @@session.explicit_defaults_for_timestamp=off;
result_format: 4
set sql_mode = '';
-----------------------------------------------------------------------------------------------------------------
### 本次支持的类型：double、float、decimal、timestamp 作为range columns分区的分区键。
###  一级分区为 range columns（double、float、decimal、timestamp）
drop table if exists t_range_partition_1_sub_1;
CREATE TABLE t_range_partition_1_sub_1 (
    c1 DOUBLE,
    c2 FLOAT,
    c3 DECIMAL(10, 2),
    c4 TIMESTAMP
)
PARTITION BY RANGE COLUMNS(c1) (
    PARTITION p0 VALUES LESS THAN (0) (
        SUBPARTITION sp0 VALUES LESS THAN (0),
        SUBPARTITION sp1 VALUES LESS THAN (1000),
        SUBPARTITION sp2 VALUES LESS THAN (5000)
    ),
    PARTITION p1 VALUES LESS THAN (1000) (
        SUBPARTITION sp10 VALUES LESS THAN (0),
        SUBPARTITION sp11 VALUES LESS THAN (1000),
        SUBPARTITION sp12 VALUES LESS THAN (5000)
    ),
    PARTITION p2 VALUES LESS THAN (5000) (
        SUBPARTITION sp20 VALUES LESS THAN (0),
        SUBPARTITION sp21 VALUES LESS THAN (1000),
        SUBPARTITION sp22 VALUES LESS THAN (5000)
    )
);
ERROR 42000: Parse error
CREATE TABLE t_range_partition_1_sub_1 (
    c1 DOUBLE,
    c2 FLOAT,
    c3 DECIMAL(10, 2),
    c4 date
)
PARTITION BY RANGE COLUMNS(c1) 
  subpartition by hash(to_days(c4))
  subpartitions 3 
  (partition p0 values less than (0),
   partition p1 values less than (5000),
   partition p2 values less than maxvalue);
drop table if exists t_range_partition_1_sub_1;
CREATE TABLE t_range_partition_1_sub_1 (
    c1 DOUBLE,
    c2 FLOAT,
    c3 DECIMAL(10, 2),
    c4 date
)
PARTITION BY RANGE COLUMNS(c1) 
  subpartition by hash(to_days(c1+c4))
  subpartitions 3 
  (partition p0 values less than (0),
   partition p1 values less than (5000),
   partition p2 values less than maxvalue);
ERROR HY000: Constant or random or timezone-dependent expressions in (sub)partitioning function are not allowed
CREATE TABLE t_range_partition_1_sub_1 (
    c1 DOUBLE,
    c2 FLOAT,
    c3 DECIMAL(10, 2),
    c4 date
)
PARTITION BY RANGE COLUMNS(c1) 
  subpartition by hash(to_days(c2*c1))
  subpartitions 3 
  (partition p0 values less than (0),
   partition p1 values less than (5000),
   partition p2 values less than maxvalue);
ERROR HY000: Constant or random or timezone-dependent expressions in (sub)partitioning function are not allowed
drop table if exists t_range_partition_1_sub_1;
CREATE TABLE t_range_partition_1_sub_1 (
    c1 DOUBLE,
    c2 FLOAT,
    c3 DECIMAL(10, 2),
    c4 TIMESTAMP
)
PARTITION BY RANGE COLUMNS(c1) 
  subpartition by hash(to_days(c4))
  subpartitions 3 
  (partition p0 values less than (0),
   partition p1 values less than (5000),
   partition p2 values less than maxvalue);
ERROR HY000: Constant or random or timezone-dependent expressions in (sub)partitioning function are not allowed
drop table if exists t_range_partition_1_sub_1;
CREATE TABLE t_range_partition_1_sub_1 (
    c1 DOUBLE,
    c2 FLOAT,
    c3 DECIMAL(10, 2),
    c4 date
)
PARTITION BY RANGE COLUMNS(c1) 
  subpartition by key(c4)
  subpartitions 3 
  (partition p0 values less than (0),
   partition p1 values less than (5000),
   partition p2 values less than maxvalue);
drop table if exists t_range_partition_1_sub_1;
CREATE TABLE t_range_partition_1_sub_1 (
    c1 DOUBLE,
    c2 FLOAT,
    c3 DECIMAL(10, 2),
    c4 date
)
PARTITION BY RANGE COLUMNS(c1) 
  subpartition by key(c1,c2,c3,c4)
  subpartitions 3 
  (partition p0 values less than (0),
   partition p1 values less than (5000),
   partition p2 values less than maxvalue);
DROP TABLE IF EXISTS EMP;
CREATE TABLE   EMP(EMPNO   FLOAT,ENAME   VARCHAR(100) ,JOB  VARCHAR(100),MGR   INT ,HIREDATE DATE,SAL   FLOAT(8,2) ,COMM   INT ,DEPTNO  INT,COMID   INT)PARTITION BY RANGE COLUMNS(EMPNO)
SUBPARTITION BY HASH(to_days(HIREDATE))SUBPARTITION TEMPLATE(SUBPARTITION PART001,SUBPARTITION PART002)(PARTITION P1000 VALUES  LESS THAN(100),PARTITION P2000 VALUES  LESS THAN(5000));
DROP TABLE IF EXISTS EMP;
CREATE TABLE   EMP(EMPNO   FLOAT,ENAME   VARCHAR(100) ,JOB  VARCHAR(100),MGR   INT ,HIREDATE DATE,SAL   FLOAT(8,2) ,COMM   INT ,DEPTNO  INT,COMID   INT)PARTITION BY RANGE COLUMNS(EMPNO)
SUBPARTITION BY LIST(DEPTNO)(PARTITION P0 VALUES  LESS THAN(100)(SUBPARTITION PART01 VALUES IN(10),SUBPARTITION PART02 VALUES IN(20),SUBPARTITION PART03 VALUES IN(30)),PARTITION P1 VALUES  LESS THAN(5000)(SUBPARTITION PART04 VALUES IN(10),SUBPARTITION PART05 VALUES IN(20),SUBPARTITION PART06 VALUES IN(30)));
