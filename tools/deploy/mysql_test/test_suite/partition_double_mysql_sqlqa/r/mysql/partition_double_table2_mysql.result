##分区名称规则
#### 一二级分区任意设置名称，在计划里显示的都是这种写死的p0sp[0-2] ，不会根据设置的名称来变化。
DROP TABLE IF EXISTS EMP;
CREATE TABLE   EMP(EMPNO   INT,ENAME   VARCHAR(100) ,JOB  VARCHAR(100),MGR   INT ,HIREDATE DATE,SAL   FLOAT(8,2) ,COMM   INT ,DEPTNO  DECIMAL ,COMID   INT)PARTITION BY LIST COLUMNS(EMPNO,MGR)
SUBPARTITION BY RANGE COLUMNS(DEPTNO)
(PARTITION P222 VALUES  IN((1,10),(2,20),(3,30))(SUBPARTITION ppppp1  VALUES  LESS THAN(15),SUBPARTITION ppppp2 VALUES  LESS THAN(25),SUBPARTITION ppppp3 VALUES  LESS THAN(35)),
PARTITION P333 VALUES  IN((100,10),(200,20),(300,30))(SUBPARTITION ppppp4 VALUES  LESS THAN(15),SUBPARTITION ppppp5 VALUES  LESS THAN(25),SUBPARTITION ppppp6 VALUES  LESS THAN(35)));
select  e.table_name,e.partition_name,e.subpartition_name,e.partition_ordinal_position,e.subpartition_ordinal_position,e.partition_method,e.partition_expression,e.partition_description,e.table_rows,e.avg_row_length,e.data_length,e.create_time,e.update_time
from    information_schema.partitions   e  where table_name = 'EMP';
EXPLAIN SELECT EMPNO FROM EMP WHERE EMPNO = 2 GROUP BY EMPNO;
#### 一级分区任意设置名称，在计划里显示的都是这种写死的p0-Pn,可能会有歧义。
drop table if exists t_part_range;
create table t_part_range (n0 double, n1 double, n2 boolean, n3 smallint,n4 mediumint, n5 int, n6 integer,n7 bigint,n8 double, n9 double, n10 float, n11 numeric,n12 double, n13 double precision, n14 real)
partition by range columns(n0,n1,n8)
(partition p1 values less than (1.1,1.1,1.1),
 partition p2 values less than (20.1,20.1,20.1),
 partition p3 values less than (maxvalue,maxvalue,maxvalue));
EXPLAIN SELECT n0,n1,n2 FROM t_part_range WHERE n0 = 10.111 AND n1 = 10.111  AND n8 = 10.111  LIMIT 5;
