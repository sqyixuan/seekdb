### 多列验证
DROP TABLE IF EXISTS t_range_partition_1;
CREATE TABLE t_range_partition_1 (
    c1 DOUBLE,
    c2 FLOAT,
    c3 DECIMAL(10, 2),
    c4 DATE,
    c5 DOUBLE,
    c6 FLOAT,
    c7 DECIMAL(10, 2),
    c8 DATE,
    c9 DOUBLE,
    c10 FLOAT,
    c11 DECIMAL(10, 2),
    c12 DATE,
    c13 DOUBLE,
    c14 FLOAT,
    c15 DECIMAL(10, 2),
    c16 DATE
) 
PARTITION BY RANGE COLUMNS(c1, c3, c4, c5, c6, c7, c8, c9, c10, c11, c12, c13, c14, c15, c16) (
    PARTITION p0 VALUES LESS THAN (0, 0, '2000-01-01', 0, 0, 0, '2000-01-01', 0, 0, 0, '2000-01-01', 0, 0, 0, '2000-01-01'),
    PARTITION p1 VALUES LESS THAN (1000, 1000, '2010-01-01', 1000, 1000, 1000, '2010-01-01', 1000, 1000, 1000, '2010-01-01', 1000, 1000, 1000, '2010-01-01'),
    PARTITION p2 VALUES LESS THAN (5000, 5000, '2020-01-01', 5000, 5000, 5000, '2020-01-01', 5000, 5000, 5000, '2020-01-01', 5000, 5000, 5000, '2020-01-01')
);
DROP TABLE IF EXISTS t_range_partition_1;
CREATE TABLE t_range_partition_1 (
    c1 DOUBLE,
    c2 FLOAT,
    c3 DECIMAL(10, 2),
    c4 DATE,
    c5 DOUBLE,
    c6 FLOAT,
    c7 DECIMAL(10, 2),
    c8 DATE,
    c9 DOUBLE,
    c10 FLOAT,
    c11 DECIMAL(10, 2),
    c12 DATE,
    c13 DOUBLE,
    c14 FLOAT,
    c15 DECIMAL(10, 2),
    c16 DATE,
	c17 DATE
) 
PARTITION BY RANGE COLUMNS(c1,c2, c3, c4, c5, c6, c7, c8, c9, c10, c11, c12, c13, c14, c15, c16, c17) (
    PARTITION p0 VALUES LESS THAN (0, 0, 0, '2000-01-01', 0, 0, 0, '2000-01-01', 0, 0, 0, '2000-01-01', 0, 0, 0, '2000-01-01', '2000-01-01'),
    PARTITION p1 VALUES LESS THAN (1000, 1000, 1000, '2010-01-01', 1000, 1000, 1000, '2010-01-01', 1000, 1000, 1000, '2010-01-01', 1000, 1000, 1000, '2010-01-01', '2000-01-01'),
    PARTITION p2 VALUES LESS THAN (5000,5000, 5000, '2020-01-01', 5000, 5000, 5000, '2020-01-01', 5000, 5000, 5000, '2020-01-01', 5000, 5000, 5000, '2020-01-01', '2000-01-01')
);
ERROR HY000: Too many fields in 'list of partition fields'
### double、float、decimal、timestamp 组合基础case
DROP TABLE IF EXISTS t_range_partition_1;
### ERROR 1653 (HY000): Inconsistency in usage of column lists for partitioning，MAXVALUE问题。
CREATE TABLE t_range_partition_1 (
    c1 DOUBLE,
    c2 FLOAT,
    c3 DECIMAL(10, 2),
    c4 DATE
) 
PARTITION BY RANGE COLUMNS(c1, c3, c4) (
    PARTITION p0 VALUES LESS THAN (0, 0, '2000-01-01'),
    PARTITION p1 VALUES LESS THAN (1000, 1000, '2010-01-01'),
    PARTITION p2 VALUES LESS THAN (5000, 5000, '2020-01-01'),
    PARTITION p3 VALUES LESS THAN MAXVALUE
);
ERROR HY000: Inconsistency in usage of column lists for partitioning
CREATE TABLE t_range_partition_1 (
    c1 DOUBLE,
    c2 FLOAT,
    c3 DECIMAL(10, 2),
    c4 DATE
) 
PARTITION BY RANGE COLUMNS(c1, c3, c4) (
    PARTITION p0 VALUES LESS THAN (0, 0, '2000-01-01'),
    PARTITION p1 VALUES LESS THAN (1000, 1000, '2010-01-01'),
    PARTITION p2 VALUES LESS THAN (5000, 5000, '2020-01-01')
);
INSERT INTO t_range_partition_1 (c1, c2, c3, c4) VALUES 
(-100,  -100,  -100, '1990-01-01'),
(500,   500,   500,  '2005-01-01'),
(4500,  4500,  4500, '2015-01-01');
SELECT * FROM t_range_partition_1 PARTITION(p0);
+------+------+---------+------------+
| c1   | c2   | c3      | c4         |
+------+------+---------+------------+
| -100 | -100 | -100.00 | 1990-01-01 |
+------+------+---------+------------+
SELECT * FROM t_range_partition_1 PARTITION(p1);
+------+------+--------+------------+
| c1   | c2   | c3     | c4         |
+------+------+--------+------------+
|  500 |  500 | 500.00 | 2005-01-01 |
+------+------+--------+------------+
SELECT * FROM t_range_partition_1 PARTITION(p2);
+------+------+---------+------------+
| c1   | c2   | c3      | c4         |
+------+------+---------+------------+
| 4500 | 4500 | 4500.00 | 2015-01-01 |
+------+------+---------+------------+
DROP TABLE IF EXISTS t_combined_range_1;
CREATE TABLE t_combined_range_1 (
    c1 DOUBLE,
    c2 FLOAT,
    c3 DECIMAL(65, 30),
    c4 TIMESTAMP
) 
PARTITION BY RANGE COLUMNS(c1, c3, c4) (
    PARTITION p0 VALUES LESS THAN (-2.2250738585072014E-308, -0.000000000000000000000000000001, '1970-01-01 00:00:01'),
    PARTITION p1 VALUES LESS THAN (0, 0, '2024-04-01 00:00:00'),
    PARTITION p2 VALUES LESS THAN (1.7976931348623157E308, 99999999999999999999999999999999999.999999999999999999999999999999, '2038-01-19 03:14:07')
);
