| c1     | c2     | c3     |
+--------+--------+--------+
| -99.99 | -99.99 | -99.99 |
|  -0.01 |   0.00 |   0.00 |
|   0.00 |  -0.01 |   0.01 |
+--------+--------+--------+
SELECT * FROM t_range_partition_1 PARTITION(p1);
