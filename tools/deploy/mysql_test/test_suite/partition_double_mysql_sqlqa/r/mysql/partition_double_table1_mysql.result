### double、float、decimal、timestamp 与其他类型 组合
DROP TABLE IF EXISTS t_combined_range_1;
CREATE TABLE t_combined_range_1 (
    c1 INT,
    c2 DATE,
    c3 VARCHAR(10),
    c4 DECIMAL(10,2),
    c5 DATETIME
) 
PARTITION BY RANGE COLUMNS(c1, c2, c3, c4, c5) (
    PARTITION p0 VALUES LESS THAN (0, '1970-01-01', 'aaa', -99999999.99, '1970-01-01 00:00:01'),
    PARTITION p1 VALUES LESS THAN (10, '2020-01-01', 'zzz', 99999999.99, '2024-04-01 00:00:00'),
    PARTITION p2 VALUES LESS THAN (MAXVALUE, MAXVALUE, MAXVALUE, MAXVALUE, MAXVALUE)
);
