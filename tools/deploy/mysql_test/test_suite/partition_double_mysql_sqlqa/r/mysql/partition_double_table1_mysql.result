(0.00, -0.01, 0.01);
INSERT INTO t_range_partition_1 (c1, c2, c3) VALUES 
(10.00, -0.01, 10.89);
INSERT INTO t_range_partition_1 (c1, c2, c3) VALUES 
(9.99, 9.99, 10.89);
INSERT INTO t_range_partition_1 (c1, c2, c3) VALUES 
(5.00, 5.00, 5.00),        
(10.01, 10.01, 10.01),     
(99.99, 99.99, 99.99),     
(100.01, 100.01, 100.01);
INSERT INTO t_range_partition_1 (c1, c2, c3) VALUES 
(100.01, 99.99, 10.89);
SELECT * FROM t_range_partition_1 PARTITION(p0);
