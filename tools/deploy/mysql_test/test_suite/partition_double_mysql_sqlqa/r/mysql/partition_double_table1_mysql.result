purge recyclebin;
drop database if exists sltest;
create database sltest;
use sltest;
set timestamp = 1600000000;
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;
set @@session.explicit_defaults_for_timestamp=off;
result_format: 4
set sql_mode = '';
-----------------------------------------------------------------------------------------------------------------
### 本次支持的类型：double、float、decimal、timestamp 作为range columns分区的分区键。
### range、hash、key、list、list columns 不支持
DROP TABLE IF EXISTS t_double_range;
CREATE TABLE t_double_range (
    c1 DOUBLE
) 
PARTITION BY RANGE(c1) (
    PARTITION p_neg_inf VALUES LESS THAN (-1.7976931348623157E308),
    PARTITION p_min VALUES LESS THAN (-2.2250738585072014E-308),
    PARTITION p_zero VALUES LESS THAN (0),
    PARTITION p_min_pos VALUES LESS THAN (2.2250738585072014E-308),
    PARTITION p_max VALUES LESS THAN (1.7976931348623157E308),
    PARTITION p_pos_inf VALUES LESS THAN MAXVALUE
);
ERROR HY000: Field 'c1' is of a not allowed type for this type of partitioning
DROP TABLE IF EXISTS t_double_hash;
CREATE TABLE t_double_hash (
    c1 DOUBLE
) 
PARTITION BY HASH(c1)
PARTITIONS 4;
ERROR HY000: Field 'c1' is of a not allowed type for this type of partitioning
DROP TABLE IF EXISTS t_double_key;
CREATE TABLE t_double_key (
    c1 DOUBLE
) 
PARTITION BY KEY(c1)
PARTITIONS 4;
DROP TABLE IF EXISTS t_double_key;
DROP TABLE IF EXISTS t_double_list;
CREATE TABLE t_double_list (
    c1 DOUBLE
) 
PARTITION BY LIST(c1) (
    PARTITION p_neg VALUES IN (-1.7976931348623157E308, -2.2250738585072014E-308),
    PARTITION p_zero VALUES IN (0),
    PARTITION p_pos VALUES IN (2.2250738585072014E-308, 1.7976931348623157E308)
);
ERROR HY000: Field 'c1' is of a not allowed type for this type of partitioning
DROP TABLE IF EXISTS t_double_list_column;
CREATE TABLE t_double_list_column (
    c1 DOUBLE
) 
PARTITION BY LIST columns(c1) (
    PARTITION p_neg VALUES IN (-1.7976931348623157E308, -2.2250738585072014E-308),
    PARTITION p_zero VALUES IN (0),
    PARTITION p_pos VALUES IN (2.2250738585072014E-308, 1.7976931348623157E308)
);
ERROR HY000: Field 'c1' is of a not allowed type for this type of partitioning
DROP TABLE IF EXISTS t_float_range;
CREATE TABLE t_float_range (
    c1 FLOAT
) 
PARTITION BY RANGE (c1) (
    PARTITION p_neg_inf VALUES LESS THAN (- 3.402823466e+38),
    PARTITION p_min VALUES LESS THAN (-1.175494351e-38),
    PARTITION p_zero VALUES LESS THAN (0),
    PARTITION p_min_pos VALUES LESS THAN (1.175494351e-38),
    PARTITION p_max VALUES LESS THAN (3.402823466e+38),
    PARTITION p_pos_inf VALUES LESS THAN MAXVALUE
);
ERROR HY000: Field 'c1' is of a not allowed type for this type of partitioning
DROP TABLE IF EXISTS t_float_hash;
CREATE TABLE t_float_hash (
    c1 FLOAT
) 
PARTITION BY HASH(c1)
PARTITIONS 4;
ERROR HY000: Field 'c1' is of a not allowed type for this type of partitioning
DROP TABLE IF EXISTS t_float_key;
CREATE TABLE t_float_key (
    c1 float
) 
PARTITION BY KEY(c1)
PARTITIONS 4;
DROP TABLE IF EXISTS t_float_key;
DROP TABLE IF EXISTS t_float_list;
CREATE TABLE t_float_list (
    c1 float
) 
PARTITION BY LIST(c1) (
    PARTITION p_neg VALUES IN (-1.79, -2.22),
    PARTITION p_zero VALUES IN (0),
    PARTITION p_pos VALUES IN (2.22, 1.79)
);
ERROR HY000: Field 'c1' is of a not allowed type for this type of partitioning
DROP TABLE IF EXISTS t_float_list_column;
CREATE TABLE t_float_list_column (
    c1 float
) 
PARTITION BY LIST columns(c1) (
    PARTITION p_neg VALUES IN (-1.79, -2.225),
    PARTITION p_zero VALUES IN (0),
    PARTITION p_pos VALUES IN (2.22, 1.797)
);
ERROR HY000: Field 'c1' is of a not allowed type for this type of partitioning
DROP TABLE IF EXISTS t_decimal_range;
CREATE TABLE t_decimal_range (
    c1 DECIMAL(65,30)
) 
PARTITION BY RANGE(c1) (
    PARTITION p_neg_inf VALUES LESS THAN (-99999999999999999999999999999999999.999999999999999999999999999999),
    PARTITION p_min VALUES LESS THAN (-0.000000000000000000000000000001),
    PARTITION p_zero VALUES LESS THAN (0),
    PARTITION p_min_pos VALUES LESS THAN (0.000000000000000000000000000001),
    PARTITION p_max VALUES LESS THAN (99999999999999999999999999999999999.999999999999999999999999999999),
    PARTITION p_pos_inf VALUES LESS THAN MAXVALUE
);
ERROR HY000: Field 'c1' is of a not allowed type for this type of partitioning
