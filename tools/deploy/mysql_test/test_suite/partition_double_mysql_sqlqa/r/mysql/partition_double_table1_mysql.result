    c1 decimal
) 
PARTITION BY KEY(c1)
PARTITIONS 4;
DROP TABLE IF EXISTS t_decimal_key;
DROP TABLE IF EXISTS t_decimal_list;
CREATE TABLE t_decimal_list (
    c1 decimal
) 
PARTITION BY LIST(c1) (
    PARTITION p_neg VALUES IN (-179, -222),
    PARTITION p_zero VALUES IN (0),
    PARTITION p_pos VALUES IN (2225, 179)
);
ERROR HY000: Field 'c1' is of a not allowed type for this type of partitioning
DROP TABLE IF EXISTS t_decimal_list_column;
CREATE TABLE t_decimal_list_column (
    c1 decimal
) 
PARTITION BY LIST columns(c1) (
    PARTITION p_neg VALUES IN (-179, -222),
    PARTITION p_zero VALUES IN (0),
    PARTITION p_pos VALUES IN (2225, 179)
);
