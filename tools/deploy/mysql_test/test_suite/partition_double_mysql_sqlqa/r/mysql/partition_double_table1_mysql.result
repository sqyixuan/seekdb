DROP TABLE IF EXISTS t_timestamp_key;
CREATE TABLE t_timestamp_key (
    c1 timestamp
) 
PARTITION BY KEY(c1)
PARTITIONS 4;
DROP TABLE IF EXISTS t_timestamp_key;
DROP TABLE IF EXISTS t_timestamp_list;
CREATE TABLE t_timestamp_list (
    c1 timestamp
) 
PARTITION BY LIST(c1) (
    PARTITION p_neg VALUES IN (-1, -2),
    PARTITION p_zero VALUES IN (0),
    PARTITION p_pos VALUES IN (2.2250738585072014E-308, 1.7976931348623157E308)
);
ERROR HY000: Field 'c1' is of a not allowed type for this type of partitioning
DROP TABLE IF EXISTS t_timestamp_list_column;
CREATE TABLE t_timestamp_list_column (
    c1 timestamp
) 
PARTITION BY LIST columns(c1) (
    PARTITION p_neg VALUES IN ('1970-01-01 00:00:01', '2024-08-01 00:00:00'),
    PARTITION p_zero VALUES IN (0),
    PARTITION p_pos VALUES IN ('2024-12-01 00:00:00', '2038-01-19 03:14:07')
);
