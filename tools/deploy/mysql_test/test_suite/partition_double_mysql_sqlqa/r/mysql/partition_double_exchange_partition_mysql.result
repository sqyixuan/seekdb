purge recyclebin;
drop database if exists sltest;
create database sltest;
use sltest;
set timestamp = 1600000000;
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;
set @@session.explicit_defaults_for_timestamp=off;
result_format: 4
set sql_mode = '';
-----------------------------------------------------------------------------------------------------------------
### 本次支持的类型：double、float、decimal、timestamp 作为range columns分区的分区键。
### 分区交换，基本功能验证。
drop table if exists t_range_partition_1;
CREATE TABLE t_range_partition_1 (
    c1 DOUBLE NOT NULL,
    c2 FLOAT NOT NULL,
    c3 DECIMAL(10, 2) NOT NULL,
    c4 TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP,
    UNIQUE KEY uidx_c1_c2_c3_c4 (c1, c3, c4)
) 
PARTITION BY RANGE COLUMNS(c1, c3, c4) (
    PARTITION p0 VALUES LESS THAN (-1E308, -9999999.99, '1970-01-01'),
    PARTITION p1 VALUES LESS THAN (0, 0.00, '2000-01-01'),
    PARTITION p2 VALUES LESS THAN (1E308, 9999999.99, '2038-01-19 03:14:07'),
    PARTITION p3 VALUES LESS THAN (1.1E308, 9999999.999, MAXVALUE)
);
INSERT INTO t_range_partition_1 (c1, c2, c3, c4) VALUES 
(-1E308, -1E+38, -9999999.99, '1969-12-31 23:59:59'),
(0.0, 0.0, 0.00, '1970-01-01 00:00:01'),
(1E-308, 1E-37, 0.01, '2000-01-02');
INSERT INTO t_range_partition_1 (c1, c2, c3, c4) VALUES 
(1E307, 1E+37, 9999999.99, '2038-01-19 03:14:07');
INSERT INTO t_range_partition_1 (c1, c2, c3, c4) VALUES 
(1E308, 1E+37, 9999999.999, '2038-01-19 03:14:08');
Warnings:
Warning	1265	Data truncated for column 'c3' at row 1
SELECT * FROM t_range_partition_1 PARTITION(p0);
+--------+-------+-------------+---------------------+
| c1     | c2    | c3          | c4                  |
+--------+-------+-------------+---------------------+
| -1e308 | -1e38 | -9999999.99 | 1969-12-31 23:59:59 |
+--------+-------+-------------+---------------------+
SELECT * FROM t_range_partition_1 PARTITION(p1);
+----+----+------+---------------------+
| c1 | c2 | c3   | c4                  |
+----+----+------+---------------------+
|  0 |  0 | 0.00 | 1970-01-01 00:00:01 |
+----+----+------+---------------------+
SELECT * FROM t_range_partition_1 PARTITION(p2);
+--------+-------+------------+---------------------+
| c1     | c2    | c3         | c4                  |
+--------+-------+------------+---------------------+
| 1e-308 | 1e-37 |       0.01 | 2000-01-02 00:00:00 |
|  1e307 |  1e37 | 9999999.99 | 2038-01-19 03:14:07 |
+--------+-------+------------+---------------------+
SELECT * FROM t_range_partition_1 PARTITION(p3);
+-------+------+-------------+---------------------+
| c1    | c2   | c3          | c4                  |
+-------+------+-------------+---------------------+
| 1e308 | 1e37 | 10000000.00 | 2038-01-19 03:14:08 |
+-------+------+-------------+---------------------+
### 分区交换，NT表为分区表，预期报错
drop table if exists t_range_partition_2;
CREATE TABLE T_RANGE_PARTITION_2 (
    C1 DOUBLE,
    C2 FLOAT,
    C3 DECIMAL(10, 2),
    C4 TIMESTAMP
) 
PARTITION BY RANGE COLUMNS(C1, C3, C4) (
    PARTITION NEW_P0 VALUES LESS THAN (0, 0, '2000-01-01'),
    PARTITION NEW_P1 VALUES LESS THAN (1000, 1000, '2010-01-01'),
    PARTITION NEW_P2 VALUES LESS THAN (5000, 5000, '2020-01-01')
);
ALTER TABLE T_RANGE_PARTITION_1 EXCHANGE PARTITION P0 WITH TABLE T_RANGE_PARTITION_2 WITHOUT VALIDATION;
ERROR 0A000: Exchange partition except composite-partitioned and partitioned table is not supported
### 分区交换，NT表定义与PT表不一致，预期报错
drop table if exists t_range_partition_2;
CREATE TABLE T_RANGE_PARTITION_2 (
    C1 DOUBLE,
    C2 FLOAT,
    C3 DECIMAL(10, 2),
    C4 TIMESTAMP
);
ALTER TABLE T_RANGE_PARTITION_1 EXCHANGE PARTITION P0 WITH TABLE T_RANGE_PARTITION_2 WITHOUT VALIDATION;
ERROR HY000: Tables have different definitions
### 分区交换，NT表定义与PT表一致，预期正常交换分区数据。
drop table if exists t_range_partition_2;
CREATE TABLE T_RANGE_PARTITION_2 (
    c1 DOUBLE NOT NULL,
    c2 FLOAT NOT NULL,
    c3 DECIMAL(10, 2) NOT NULL,
    c4 TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP,
    UNIQUE KEY uidx_c1_c2_c3_c4 (c1, c3, c4)
) ;
ALTER TABLE T_RANGE_PARTITION_1 EXCHANGE PARTITION P0 WITH TABLE T_RANGE_PARTITION_2 WITHOUT VALIDATION;
