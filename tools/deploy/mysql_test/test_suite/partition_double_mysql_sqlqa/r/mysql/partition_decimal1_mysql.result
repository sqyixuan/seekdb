###插入 INT, FLOAT, DOUBLE等类型数值
DROP TABLE IF EXISTS t_decimal_range;
CREATE TABLE t_decimal_range (
    c1 DECIMAL(65,30)
)
PARTITION BY RANGE COLUMNS(c1) (
    PARTITION p_neg_inf VALUES LESS THAN (-1.402823466E+9),
    PARTITION p_min VALUES LESS THAN (-1),
    PARTITION p_zero VALUES LESS THAN (1),
    PARTITION p_min_pos VALUES LESS THAN (200),
    PARTITION p_max VALUES LESS THAN (1.402823466E+9),
    PARTITION p_pos_inf VALUES LESS THAN (1E+25)
);
###尝试插入由其他数值类型转换而来的数值
INSERT INTO t_decimal_range (c1) VALUES 
(CAST(2.5 AS DOUBLE)),     
(CAST(3.14159 AS DECIMAL(10,5)));
INSERT INTO t_decimal_range (c1) VALUES 
(1);
SELECT * FROM t_decimal_range PARTITION (p_min_pos);
+----------------------------------+
| c1                               |
+----------------------------------+
| 2.500000000000000000000000000000 |
| 3.141590000000000000000000000000 |
| 1.000000000000000000000000000000 |
+----------------------------------+
###函数处理DECIMAL数值
INSERT INTO t_decimal_range (c1) VALUES 
(ROUND(1.55)),      
(ROUND(1.55, 1)),   
(ROUND(-1.55)),     
(ROUND(-1.55, 1));
INSERT INTO t_decimal_range (c1) VALUES 
(FLOOR(1.55)),   
(FLOOR(1.99)),   
(FLOOR(-1.55)),  
(FLOOR(-1.99));
INSERT INTO t_decimal_range (c1) VALUES 
(CEIL(1.55)),     
(CEIL(1.01)),     
(CEIL(-1.55)),    
(CEILING(-1.01));
