#### UPDATE 
UPDATE EMP 
SET 
    ENAME = CASE
                WHEN SAL < 15 AND DEPTNO < 10 THEN CONCAT(ENAME, '_UPDATED')
                ELSE ENAME
            END, 
    JOB = CASE
              WHEN SAL >= 15 AND SAL < 1000 AND DEPTNO >= 10 AND DEPTNO < 20 THEN CONCAT(JOB, '_CHANGED')
              ELSE JOB
          END 
WHERE 
    (EMPNO < 500 AND SAL < 15 AND DEPTNO < 10) OR 
    (EMPNO < 500 AND SAL >= 15 AND SAL < 1000 AND DEPTNO >= 10 AND DEPTNO < 20) OR 
    (EMPNO >= 500 AND EMPNO < 5000 AND SAL >= 1000 AND SAL < 5000 AND DEPTNO >= 20 AND DEPTNO < 50);
