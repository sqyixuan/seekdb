WITH emp_p1000 AS (
    SELECT * FROM EMP PARTITION(P1000) WHERE ENAME LIKE 'EMP_PART%'
)
SELECT DISTINCT emp_p1000.*, EMP.DEPTNO
FROM emp_p1000
JOIN EMP ON emp_p1000.DEPTNO = EMP.DEPTNO
WHERE emp_p1000.SAL > 500 
GROUP BY emp_p1000.ENAME
HAVING MAX(emp_p1000.SAL) < 4000
ORDER BY emp_p1000.SAL DESC
LIMIT 5;
