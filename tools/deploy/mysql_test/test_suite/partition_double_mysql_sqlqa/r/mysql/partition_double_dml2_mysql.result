DROP TABLE IF EXISTS EMP;
CREATE TABLE EMP (
    EMPNO DOUBLE,
    SAL DOUBLE,
    DEPTNO DOUBLE,
    HIREDATE TIMESTAMP
)
PARTITION BY RANGE COLUMNS(EMPNO) 
SUBPARTITION BY RANGE COLUMNS(HIREDATE) 
SUBPARTITION TEMPLATE (
    SUBPARTITION PART001 VALUES LESS THAN ( '2000-01-01 00:00:00'),
    SUBPARTITION PART002 VALUES LESS THAN ( '2010-01-01 00:00:00'),
    SUBPARTITION PART003 VALUES LESS THAN ( '2020-01-01 00:00:00')
) (
    PARTITION P1000 VALUES LESS THAN (500),
    PARTITION P2000 VALUES LESS THAN (5000),
    PARTITION P3000 VALUES LESS THAN (15000)
);
