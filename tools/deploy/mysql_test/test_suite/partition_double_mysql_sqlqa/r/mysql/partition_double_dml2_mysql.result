purge recyclebin;
drop database if exists sltest;
create database sltest;
use sltest;
set timestamp = 1600000000;
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;
set @@session.explicit_defaults_for_timestamp=off;
result_format: 4
set sql_mode = '';
-----------------------------------------------------------------------------------------------------------------
### 本次支持的类型：double、float、decimal、timestamp 作为range columns分区的分区键。
DROP TABLE IF EXISTS EMP;
CREATE TABLE EMP (
    EMPNO DOUBLE,
    ENAME VARCHAR(100),
    JOB VARCHAR(100),
    MGR INT,
    HIREDATE TIMESTAMP,
    SAL FLOAT(8,2),
    COMM INT,
    DEPTNO DECIMAL,
    COMID INT
)
PARTITION BY RANGE COLUMNS(EMPNO) 
SUBPARTITION BY RANGE COLUMNS(SAL,DEPTNO,HIREDATE) 
SUBPARTITION TEMPLATE (
    SUBPARTITION PART001 VALUES LESS THAN (15.0, 10.0, '2000-01-01 00:00:00'),
    SUBPARTITION PART002 VALUES LESS THAN (1000.0, 20.0, '2010-01-01 00:00:00'),
    SUBPARTITION PART003 VALUES LESS THAN (5000.0, 50.0, '2020-01-01 00:00:00')
) (
    PARTITION P1000 VALUES LESS THAN (500.0),
    PARTITION P2000 VALUES LESS THAN (5000.0),
    PARTITION P3000 VALUES LESS THAN (MAXVALUE)
);
