###函数处理FLOAT数值
INSERT INTO t_float_range (c1) VALUES 
(ROUND(1.55)),      
(ROUND(1.55, 1)),   
(ROUND(-1.55)),     
(ROUND(-1.55, 1));
INSERT INTO t_float_range (c1) VALUES 
(FLOOR(1.55)),    
(FLOOR(1.99)),    
(FLOOR(-1.55)),   
(FLOOR(-1.99));
INSERT INTO t_float_range (c1) VALUES 
(CEIL(1.55)),      
(CEIL(1.01)),      
(CEIL(-1.55)),     
(CEILING(-1.01));
