### 使用double类型的边界值
DROP TABLE IF EXISTS t_float_range;
CREATE TABLE t_float_range (
    c1 FLOAT
) 
PARTITION BY RANGE COLUMNS(c1) (
    PARTITION p_neg_inf VALUES LESS THAN (-1.7976931348623157E308),
    PARTITION p_min VALUES LESS THAN (-2.2250738585072014E-308),
    PARTITION p_zero VALUES LESS THAN (0),
    PARTITION p_min_pos VALUES LESS THAN (2.2250738585072014E-308),
    PARTITION p_max VALUES LESS THAN (1.7976931348623157E308),
    PARTITION p_pos_inf VALUES LESS THAN MAXVALUE
);
ERROR HY000: VALUES LESS THAN value must be strictly increasing for each partition
### FLOAT UNSIGNED、FLOAT ZEROFILL,预期不支持
DROP TABLE IF EXISTS t_float_range;
CREATE TABLE t_float_range (
    c1 FLOAT UNSIGNED
) 
PARTITION BY RANGE COLUMNS(c1) (
    PARTITION p_neg_inf VALUES LESS THAN (- 3.402823466e+38),
    PARTITION p_min VALUES LESS THAN (-1.175494351e-38),
    PARTITION p_zero VALUES LESS THAN (0),
    PARTITION p_min_pos VALUES LESS THAN (1.175494351e-38),
    PARTITION p_max VALUES LESS THAN (3.402823466e+38),
    PARTITION p_pos_inf VALUES LESS THAN MAXVALUE
);
ERROR HY000: VALUES LESS THAN value must be strictly increasing for each partition
CREATE TABLE t_float_range (
    c1 FLOAT ZEROFILL
) 
PARTITION BY RANGE COLUMNS(c1) (
    PARTITION p_neg_inf VALUES LESS THAN (- 3.402823466e+38),
    PARTITION p_min VALUES LESS THAN (-1.175494351e-38),
    PARTITION p_zero VALUES LESS THAN (0),
    PARTITION p_min_pos VALUES LESS THAN (1.175494351e-38),
    PARTITION p_max VALUES LESS THAN (3.402823466e+38),
    PARTITION p_pos_inf VALUES LESS THAN MAXVALUE
);
ERROR HY000: VALUES LESS THAN value must be strictly increasing for each partition
### 字段格式，FLOAT(M,D)
DROP TABLE IF EXISTS t_float_range;
CREATE TABLE t_float_range (
    c1 FLOAT(10,2)
) 
PARTITION BY RANGE COLUMNS(c1) (
    PARTITION p0 VALUES LESS THAN (0),
    PARTITION p1 VALUES LESS THAN (5.1),
    PARTITION p2 VALUES LESS THAN (10.1),
    PARTITION p3 VALUES LESS THAN (99999999.99),
    PARTITION p4 VALUES LESS THAN MAXVALUE
);
INSERT INTO t_float_range (c1) VALUES 
(- 3.402823466e+38);
ERROR 22003: Out of range value for column 'c1' at row 1
INSERT INTO t_float_range (c1) VALUES 
(-1.175494351e-38), 
(1.175494351e-38);
