| 1e307 |  1e37 | 9999999.99 | 2038-01-18 03:14:07 |
+-------+-------+------------+---------------------+
WITH partition_data AS (
  SELECT c1, c2, c3, c4 
  FROM t_range_partition_1 PARTITION(p1) 
  WHERE c2 BETWEEN -1000000000 AND 1000000000000
)
SELECT DISTINCT a.c1, a.c2, AVG(a.c3) AS avg_c3 
FROM partition_data a 
JOIN t_range_partition_1 PARTITION(p1) b ON a.c1 = b.c1 
GROUP BY a.c1, a.c2 
HAVING AVG(a.c3) < 0
ORDER BY avg_c3 DESC
LIMIT 5;
+--------+----+-----------+
| c1     | c2 | avg_c3    |
+--------+----+-----------+
| -1e308 |  0 | -1.000000 |
+--------+----+-----------+
### 分区裁剪基础测试
# 公共表
drop table if exists t_testdata;
create table t_testdata (n0 tinyint, n1 bool, n2 boolean, n3 smallint,n4 mediumint, n5 int, n6 integer,n7 bigint,n8 decimal, n9 dec, n10 float, n11 numeric,n12 double, n13 double precision, n14 real);
insert into t_testdata values(1,true,true,4,5,6,7,8,9.0,10,11.100,12,13.123,14.456,15);
# double下的整数
drop table if exists t_part_range;
create table t_part_range (n0 double, n1 bool, n2 boolean, n3 smallint,n4 mediumint, n5 int, n6 integer,n7 bigint,n8 decimal, n9 dec, n10 float, n11 numeric,n12 double, n13 double precision, n14 real)
partition by range columns(n0)
(partition p0 values less than (1),
 partition p1 values less than (2),
 partition p2 values less than maxvalue);
### select语句
explain select n0,n1,n2 from t_part_range where n0 = -10 limit 5;
