purge recyclebin;
drop database if exists sltest;
create database sltest;
use sltest;
set timestamp = 1600000000;
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;
set @@session.explicit_defaults_for_timestamp=off;
result_format: 4
set sql_mode = '';
-----------------------------------------------------------------------------------------------------------------
### 本次支持的类型：double、float、decimal、timestamp 作为range columns分区的分区键。
###  一级分区为 range columns（double、float、decimal、timestamp）
drop table if exists t_range_partition_1;
CREATE TABLE t_range_partition_1 (
    c1 DOUBLE NOT NULL,
    c2 FLOAT NOT NULL,
    c3 DECIMAL(10, 2) NOT NULL,
    c4 TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP,
    UNIQUE KEY uidx_c1_c2_c3_c4 (c1, c3, c4)
) 
PARTITION BY RANGE COLUMNS(c1, c3, c4) (
    PARTITION p0 VALUES LESS THAN (-1E308, -9999999.99, '1970-01-01'),
    PARTITION p1 VALUES LESS THAN (0, 0.00, '2000-01-01'),
    PARTITION p2 VALUES LESS THAN (1E308, 9999999.99, '2038-01-19 03:14:07'),
    PARTITION p3 VALUES LESS THAN (1.1E308, 9999999.999, MAXVALUE)
);
# DML操作,insert
INSERT INTO t_range_partition_1 (c1, c2, c3, c4) VALUES 
(-1E309, -1E+39, -9999999.99, '1969-12-31 23:59:59');
