drop table if exists t_range_partition_11;
CREATE TABLE t_range_partition_11 AS SELECT * FROM t_range_partition_1 WHERE 1=0;
INSERT INTO t_range_partition_11 select * from t_range_partition_1;
drop table if exists t_range_partition_2;
CREATE TABLE t_range_partition_2 (
    c1 DOUBLE NOT NULL,
    c2 FLOAT NOT NULL,
    c3 DECIMAL(10, 2) NOT NULL,
    c4 TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP,
    UNIQUE KEY uidx_c1_c2_c3_c4 (c1, c3, c4)
) 
PARTITION BY RANGE COLUMNS(c1, c3, c4) (
    PARTITION p0 VALUES LESS THAN (-1E307, -9999999.00, '1960-01-01'),
    PARTITION p1 VALUES LESS THAN (1, 1.00, '2010-01-01'),
    PARTITION p2 VALUES LESS THAN (2E307, 5000000.00, '2040-01-01'),
    PARTITION p3 VALUES LESS THAN (MAXVALUE, MAXVALUE, MAXVALUE)
);
