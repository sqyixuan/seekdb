# float下的浮点数
drop table if exists t_part_range;
create table t_part_range (n0 float, n1 bool, n2 boolean, n3 smallint,n4 mediumint, n5 int, n6 integer,n7 bigint,n8 decimal, n9 dec, n10 float, n11 numeric,n12 double, n13 double precision, n14 real)
partition by range columns(n0)
(partition p0 values less than (1),
 partition p1 values less than (2),
 partition p2 values less than maxvalue);
