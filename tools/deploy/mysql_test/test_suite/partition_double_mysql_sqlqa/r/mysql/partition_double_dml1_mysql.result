### 等值传递  double 处理 .0的小数传递，没有分区裁剪;
DROP TABLE IF EXISTS t_part_range;
create table t_part_range (n0 double, n1 bool, n2 boolean, n3 smallint,n4 mediumint, n5 int, n6 integer,n7 bigint,n8 decimal, n9 dec, n10 float, n11 numeric,n12 double, n13 double precision, n14 real)
partition by range columns(n0)
(partition p0 values less than (10.0),
 partition p1 values less than (20.0),
 partition p2 values less than maxvalue);
explain select n0,n1,n2 from t_part_range where n3 = 5.0 and n0 = n3;
Query Plan
=======================================================
|ID|OPERATOR       |NAME        |EST.ROWS|EST.TIME(us)|
-------------------------------------------------------
|0 |TABLE FULL SCAN|t_part_range|1       |3           |
=======================================================
Outputs & filters:
-------------------------------------
  0 - output([t_part_range.n0], [t_part_range.n1], [t_part_range.n2]), filter([t_part_range.n3 = demote_cast(5.0, SMALLINT(6, 0))], [t_part_range.n0 = cast(cast(demote_cast(5.0,
       SMALLINT(6, 0)), SMALLINT(6, 0)), DOUBLE(-1, -1))]), rowset=16
      access([t_part_range.n0], [t_part_range.n3], [t_part_range.n1], [t_part_range.n2]), partitions(p0)
      is_index_back=false, is_global_index=false, filter_before_indexback[false,false], 
      range_key([t_part_range.__pk_increment]), range(MIN ; MAX)always true
explain select n0,n1,n2 from t_part_range where n3 = 5.0 and n0 = n3 + 10.0;
Query Plan
=======================================================
|ID|OPERATOR       |NAME        |EST.ROWS|EST.TIME(us)|
-------------------------------------------------------
|0 |TABLE FULL SCAN|t_part_range|1       |3           |
=======================================================
Outputs & filters:
-------------------------------------
  0 - output([t_part_range.n0], [t_part_range.n1], [t_part_range.n2]), filter([t_part_range.n3 = demote_cast(5.0, SMALLINT(6, 0))], [t_part_range.n0 = cast(cast(cast(demote_cast(5.0,
       SMALLINT(6, 0)), SMALLINT(6, 0)), DECIMAL_INT(8, 1)) + 10.0, DOUBLE(-1, -1))]), rowset=16
      access([t_part_range.n0], [t_part_range.n3], [t_part_range.n1], [t_part_range.n2]), partitions(p1)
      is_index_back=false, is_global_index=false, filter_before_indexback[false,false], 
      range_key([t_part_range.__pk_increment]), range(MIN ; MAX)always true
### 查询条件是NOT IN 或 !=,  目前OB不会做分区裁剪，by design
DROP TABLE IF EXISTS t_part_range;
CREATE TABLE t_part_range (a double, b varchar(255))
PARTITION BY RANGE COLUMNS(a)
(PARTITION p0 VALUES LESS THAN (1),
 PARTITION p1 VALUES LESS THAN (2),
 partition p2 values less than maxvalue);
### INSERT INTO t_part_range VALUES (0, "0"), (1,"1");
EXPLAIN SELECT * FROM t_part_range WHERE a != 1;
Query Plan
=================================================================
|ID|OPERATOR                 |NAME        |EST.ROWS|EST.TIME(us)|
-----------------------------------------------------------------
|0 |PX COORDINATOR           |            |1       |8           |
|1 |└─EXCHANGE OUT DISTR     |:EX10000    |1       |8           |
|2 |  └─PX PARTITION ITERATOR|            |1       |7           |
|3 |    └─TABLE FULL SCAN    |t_part_range|1       |7           |
=================================================================
Outputs & filters:
-------------------------------------
  0 - output([INTERNAL_FUNCTION(t_part_range.a, t_part_range.b)]), filter(nil), rowset=16
  1 - output([INTERNAL_FUNCTION(t_part_range.a, t_part_range.b)]), filter(nil), rowset=16
      dop=1
  2 - output([t_part_range.a], [t_part_range.b]), filter(nil), rowset=16
      force partition granule
  3 - output([t_part_range.a], [t_part_range.b]), filter([t_part_range.a != cast(1, DOUBLE(-1, -1))]), rowset=16
      access([t_part_range.a], [t_part_range.b]), partitions(p[0-2])
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([t_part_range.__pk_increment]), range(MIN ; MAX)always true
EXPLAIN SELECT * FROM t_part_range WHERE a NOT IN (-1,1);
Query Plan
=================================================================
|ID|OPERATOR                 |NAME        |EST.ROWS|EST.TIME(us)|
-----------------------------------------------------------------
|0 |PX COORDINATOR           |            |1       |8           |
|1 |└─EXCHANGE OUT DISTR     |:EX10000    |1       |8           |
|2 |  └─PX PARTITION ITERATOR|            |1       |7           |
|3 |    └─TABLE FULL SCAN    |t_part_range|1       |7           |
=================================================================
Outputs & filters:
-------------------------------------
  0 - output([INTERNAL_FUNCTION(t_part_range.a, t_part_range.b)]), filter(nil), rowset=16
  1 - output([INTERNAL_FUNCTION(t_part_range.a, t_part_range.b)]), filter(nil), rowset=16
      dop=1
  2 - output([t_part_range.a], [t_part_range.b]), filter(nil), rowset=16
      force partition granule
  3 - output([t_part_range.a], [t_part_range.b]), filter([(T_OP_NOT_IN, t_part_range.a, (cast(-1, DOUBLE(-1, -1)), cast(1, DOUBLE(-1, -1))))]), rowset=16
      access([t_part_range.a], [t_part_range.b]), partitions(p[0-2])
      is_index_back=false, is_global_index=false, filter_before_indexback[false], 
      range_key([t_part_range.__pk_increment]), range(MIN ; MAX)always true
### text/enum/set数据类型
DROP TABLE IF EXISTS t_part_range;
CREATE TABLE t_part_range (a double,s2 tinytext,s3 text, s4 mediumtext, s5 longtext, s6 enum('1','2','3','4'), s7 set('1','2','3','4'))
PARTITION BY RANGE COLUMNS(a,s2)
(PARTITION p0 VALUES LESS THAN (1,'1'),
 PARTITION p1 VALUES LESS THAN (2,'2'),
 partition p2 values less than maxvalue);
ERROR HY000: Field 's2' is of a not allowed type for this type of partitioning
CREATE TABLE t_part_range (a double,s2 tinytext,s3 text, s4 mediumtext, s5 longtext, s6 enum('1','2','3','4'), s7 set('1','2','3','4'))
PARTITION BY RANGE COLUMNS(a,s6)
(PARTITION p0 VALUES LESS THAN (1,'1'),
 PARTITION p1 VALUES LESS THAN (2,'2'),
 partition p2 values less than maxvalue);
ERROR HY000: Field 's6' is of a not allowed type for this type of partitioning
CREATE TABLE t_part_range (a double,s2 tinytext,s3 text, s4 mediumtext, s5 longtext, s6 enum('1','2','3','4'), s7 set('1','2','3','4'))
PARTITION BY RANGE COLUMNS(a,s7)
(PARTITION p0 VALUES LESS THAN (1,'1'),
 PARTITION p1 VALUES LESS THAN (2,'2'),
 partition p2 values less than maxvalue);
ERROR HY000: Field 's7' is of a not allowed type for this type of partitioning
