### timestamp 多列分区裁剪
drop table if exists t_range_columns;
create table t_range_columns (c1 timestamp, c2 timestamp, c3 year, c4 datetime, c5 timestamp) partition by range columns(c1,c2)
(PARTITION p0 VALUES LESS THAN ('2000-01-01 01:01:01','2000-01-01 01:01:01'),
  PARTITION p1 VALUES LESS THAN ('2022-01-01 01:01:01','2022-01-01 01:01:01'),
  PARTITION p2 VALUES LESS THAN ('2038-01-19 03:14:07','2038-01-19 03:14:07'),
  PARTITION p3 VALUES LESS THAN (MAXVALUE,MAXVALUE));
