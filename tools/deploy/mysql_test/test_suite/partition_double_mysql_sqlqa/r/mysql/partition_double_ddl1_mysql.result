ALTER TABLE t_range_partition_1
REORGANIZE PARTITION p1 INTO (
    PARTITION p1a VALUES LESS THAN (-500, -500, '2000-01-01'),
    PARTITION p1b VALUES LESS THAN (0, 0.00, '2000-01-01')
);
ERROR 0A000: reorganizing table without primary key(s) is not supported
