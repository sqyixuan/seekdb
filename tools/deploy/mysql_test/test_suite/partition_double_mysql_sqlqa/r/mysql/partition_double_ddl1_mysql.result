    PARTITION P4 VALUES LESS THAN (MAXVALUE, MAXVALUE, MAXVALUE)
);
### 增加分区,补充测试，RANGE-RANGE COLUMNS 同时增加一级分区、二级分区。
drop table if exists t_range_partition_1;
CREATE TABLE t_range_partition_1 (
    c1 INT,
    c2 FLOAT,
    c3 DECIMAL(10, 2),
    c4 DATE
) 
PARTITION BY RANGE (c1)
SUBPARTITION BY RANGE COLUMNS (c3, c4) (
    PARTITION p0 VALUES LESS THAN (0) (
        SUBPARTITION sp00 VALUES LESS THAN (0, '2000-01-01'),
        SUBPARTITION sp01 VALUES LESS THAN (1000, '2010-01-01'),
        SUBPARTITION sp02 VALUES LESS THAN (5000, '2020-01-01')
    ),
    PARTITION p1 VALUES LESS THAN (1000) (
        SUBPARTITION sp10 VALUES LESS THAN (0, '2000-01-01'),
        SUBPARTITION sp11 VALUES LESS THAN (1000, '2010-01-01'),
        SUBPARTITION sp12 VALUES LESS THAN (5000, '2020-01-01')
    ),
    PARTITION p2 VALUES LESS THAN (5000) (
        SUBPARTITION sp20 VALUES LESS THAN (0, '2000-01-01'),
        SUBPARTITION sp21 VALUES LESS THAN (1000, '2010-01-01'),
        SUBPARTITION sp22 VALUES LESS THAN (5000, '2020-01-01')
    )
);
ALTER TABLE t_range_partition_1
ADD PARTITION (
    PARTITION p3 VALUES LESS THAN (10000) (
        SUBPARTITION sp30 VALUES LESS THAN (0, '2000-01-01'),
        SUBPARTITION sp31 VALUES LESS THAN (1000, '2010-01-01'),
        SUBPARTITION sp32 VALUES LESS THAN (5000, '2020-01-01')
    )
);
ALTER TABLE t_range_partition_1
ADD PARTITION (
    PARTITION p4 VALUES LESS THAN (20000) (
        SUBPARTITION sp40 VALUES LESS THAN (1110, '2000-01-01'),
        SUBPARTITION sp41 VALUES LESS THAN (2000, '2010-01-01'),
        SUBPARTITION sp42 VALUES LESS THAN (9000, '2020-01-01'),
        SUBPARTITION sp43 VALUES LESS THAN (11000, '2020-01-01')
    )
);
### 增加分区,补充测试，RANGE COLUMNS，KEY -RANGE COLUMNS 同时增加一级分区、二级分区。
drop table if exists t_range_partition_1;
CREATE TABLE t_range_partition_1 (
    c1 INT,
    c2 FLOAT,
    c3 DECIMAL(10, 2),
    c4 DATE
) 
PARTITION BY RANGE COLUMNS (c1) 
SUBPARTITION BY RANGE COLUMNS (c3, c4) (
    PARTITION p0 VALUES LESS THAN (0) (
        SUBPARTITION sp00 VALUES LESS THAN (0, '2000-01-01'),
        SUBPARTITION sp01 VALUES LESS THAN (0, '2010-01-01')
    ),
    PARTITION p1 VALUES LESS THAN (1000) (
        SUBPARTITION sp10 VALUES LESS THAN (1000, '2010-01-01'),
        SUBPARTITION sp11 VALUES LESS THAN (1000, '2020-01-01')
    ),
    PARTITION p2 VALUES LESS THAN (5000) (
        SUBPARTITION sp20 VALUES LESS THAN (5000, '2020-01-01'),
        SUBPARTITION sp21 VALUES LESS THAN (5000, '2030-01-01')
    )
);
ALTER TABLE t_range_partition_1
ADD PARTITION (
    PARTITION p3 VALUES LESS THAN (10000) (
        SUBPARTITION sp30 VALUES LESS THAN (10000, '2030-01-01'),
        SUBPARTITION sp31 VALUES LESS THAN (10000, '2040-01-01')
    )
);
drop table if exists t_range_partition_1;
CREATE TABLE t_range_partition_1(col1 DOUBLE,col2 DOUBLE,col3 DOUBLE) 
       PARTITION BY KEY(col1)
       SUBPARTITION BY RANGE COLUMNS(col2,col3)
       SUBPARTITION TEMPLATE
        (SUBPARTITION p0 VALUES LESS THAN (1,3),
         SUBPARTITION p1 VALUES LESS THAN (4,6),
         SUBPARTITION p2 VALUES LESS THAN (7,9)
        )
       PARTITIONS 5;
ALTER TABLE t_range_partition_1
ADD PARTITION (
SUBPARTITION p3 VALUES LESS THAN (11,15)
);
ERROR 42000: You have an error in your SQL syntax; check the manual that corresponds to your OceanBase version for the right syntax to use near 'SUBPARTITION p3 VALUES LESS THAN (11,15)
)' at line 3
