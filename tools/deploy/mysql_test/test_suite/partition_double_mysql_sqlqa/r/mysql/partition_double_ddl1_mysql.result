purge recyclebin;
drop database if exists sltest;
create database sltest;
use sltest;
set timestamp = 1600000000;
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;
set @@session.explicit_defaults_for_timestamp=off;
result_format: 4
set sql_mode = '';
-----------------------------------------------------------------------------------------------------------------
### 本次支持的类型：double、float、decimal、timestamp 作为range columns分区的分区键。
###  一级分区为 range columns（double、float、decimal、timestamp）
drop table if exists t_range_partition_1;
CREATE TABLE t_range_partition_1 (
    c1 DOUBLE NOT NULL,
    c2 FLOAT NOT NULL,
    c3 DECIMAL(10, 2) NOT NULL,
    c4 TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP,
    UNIQUE KEY uidx_c1_c2_c3_c4 (c1, c3, c4)
) 
PARTITION BY RANGE COLUMNS(c1, c3, c4) (
    PARTITION p0 VALUES LESS THAN (-1E308, -9999999.99, '1970-01-01'),
    PARTITION p1 VALUES LESS THAN (0, 0.00, '2000-01-01'),
    PARTITION p2 VALUES LESS THAN (1E308, 9999999.99, '2038-01-19 03:14:07'),
    PARTITION p3 VALUES LESS THAN (1.1E308, 9999999.999, MAXVALUE)
);
INSERT INTO t_range_partition_1 (c1, c2, c3, c4) VALUES 
(-1E308, -1E+38, -9999999.99, '1969-12-31 23:59:59'),
(0.0, 0.0, 0.00, '1970-01-01 00:00:01'),
(1E-308, 1E-37, 0.01, '2000-01-02');
INSERT INTO t_range_partition_1 (c1, c2, c3, c4) VALUES 
(1E307, 1E+37, 9999999.99, '2038-01-19 03:14:07');
INSERT INTO t_range_partition_1 (c1, c2, c3, c4) VALUES 
(1E308, 1E+37, 9999999.999, '2038-01-19 03:14:08');
Warnings:
Warning	1265	Data truncated for column 'c3' at row 1
SELECT * FROM t_range_partition_1 PARTITION(p0);
+--------+-------+-------------+---------------------+
| c1     | c2    | c3          | c4                  |
+--------+-------+-------------+---------------------+
| -1e308 | -1e38 | -9999999.99 | 1969-12-31 23:59:59 |
+--------+-------+-------------+---------------------+
SELECT * FROM t_range_partition_1 PARTITION(p1);
+----+----+------+---------------------+
| c1 | c2 | c3   | c4                  |
+----+----+------+---------------------+
|  0 |  0 | 0.00 | 1970-01-01 00:00:01 |
+----+----+------+---------------------+
SELECT * FROM t_range_partition_1 PARTITION(p2);
+--------+-------+------------+---------------------+
| c1     | c2    | c3         | c4                  |
+--------+-------+------------+---------------------+
| 1e-308 | 1e-37 |       0.01 | 2000-01-02 00:00:00 |
|  1e307 |  1e37 | 9999999.99 | 2038-01-19 03:14:07 |
+--------+-------+------------+---------------------+
SELECT * FROM t_range_partition_1 PARTITION(p3);
+-------+------+-------------+---------------------+
| c1    | c2   | c3          | c4                  |
+-------+------+-------------+---------------------+
| 1e308 | 1e37 | 10000000.00 | 2038-01-19 03:14:08 |
+-------+------+-------------+---------------------+
### 增加分区
ALTER TABLE t_range_partition_1
ADD PARTITION (PARTITION p4 VALUES LESS THAN (1.1E308, 9999999.999, MAXVALUE));
ERROR HY000: VALUES LESS THAN value must be strictly increasing for each partition
ALTER TABLE t_range_partition_1
ADD PARTITION (PARTITION p3 VALUES LESS THAN (1.2E308, 9999999.999, MAXVALUE));
ERROR HY000: Duplicate partition name 'p3'
ALTER TABLE t_range_partition_1
ADD PARTITION (PARTITION p5 VALUES LESS THAN (MAXVALUE, MAXVALUE));
ERROR HY000: Inconsistency in usage of column lists for partitioning
ALTER TABLE t_range_partition_1
ADD PARTITION (PARTITION p5 VALUES IN(1,2,3,4,5,6));
ERROR 42000: You have an error in your SQL syntax; check the manual that corresponds to your OceanBase version for the right syntax to use
ALTER TABLE t_range_partition_1
ADD PARTITION (PARTITION p5 VALUES LESS THAN (1.3E308, MAXVALUE));
ERROR HY000: Inconsistency in usage of column lists for partitioning
ALTER TABLE t_range_partition_1
ADD PARTITION (PARTITION p5 VALUES LESS THAN (2E308, MAXVALUE, MAXVALUE));
ERROR 22007: Illegal double '2E308' value found during parsing
ALTER TABLE t_range_partition_1
ADD PARTITION (PARTITION p4 VALUES LESS THAN (MAXVALUE, MAXVALUE, MAXVALUE));
INSERT INTO t_range_partition_1 (c1, c2, c3, c4) VALUES 
(1.2E308, 1E+37, 9999999.999, '2038-01-19 03:14:08');
Warnings:
Warning	1265	Data truncated for column 'c3' at row 1
SELECT * FROM t_range_partition_1 PARTITION(p4);
+---------+------+-------------+---------------------+
| c1      | c2   | c3          | c4                  |
+---------+------+-------------+---------------------+
| 1.2e308 | 1e37 | 10000000.00 | 2038-01-19 03:14:08 |
+---------+------+-------------+---------------------+
### 清空分区
ALTER TABLE T_RANGE_PARTITION_1 TRUNCATE PARTITION P0;
ALTER TABLE T_RANGE_PARTITION_1 TRUNCATE PARTITION P1,P2;
ALTER TABLE T_RANGE_PARTITION_1 TRUNCATE PARTITION P2;
ALTER TABLE T_RANGE_PARTITION_1 TRUNCATE PARTITION P3;
ALTER TABLE T_RANGE_PARTITION_1 TRUNCATE PARTITION P4;
### 删除分区
ALTER TABLE T_RANGE_PARTITION_1 DROP PARTITION P0;
ALTER TABLE T_RANGE_PARTITION_1 DROP PARTITION P1,P2;
ALTER TABLE T_RANGE_PARTITION_1 DROP PARTITION P1;
ERROR HY000: Error in list of partitions to DROP
ALTER TABLE T_RANGE_PARTITION_1 DROP PARTITION P2;
ERROR HY000: Error in list of partitions to DROP
ALTER TABLE T_RANGE_PARTITION_1 DROP PARTITION P3;
ALTER TABLE T_RANGE_PARTITION_1 DROP PARTITION P4;
ERROR HY000: Cannot remove all partitions, use DROP TABLE instead
select  e.table_name,e.partition_name,e.subpartition_name,e.partition_ordinal_position,e.subpartition_ordinal_position,e.partition_method,e.partition_expression,e.partition_description,e.table_rows,e.avg_row_length,e.data_length,e.create_time,e.update_time
from    information_schema.partitions   e  where table_name = 'T_RANGE_PARTITION_1';
