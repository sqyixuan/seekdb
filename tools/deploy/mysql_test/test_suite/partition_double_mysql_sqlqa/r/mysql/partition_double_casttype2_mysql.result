(NULL);
SELECT * FROM t_timestamp_range3 PARTITION(p_neg_inf);
SELECT * FROM t_timestamp_range3 PARTITION(p_min);
SELECT * FROM t_timestamp_range3 PARTITION(p_zero);
SELECT * FROM t_timestamp_range3 PARTITION(p_min_pos);
SELECT * FROM t_timestamp_range3 PARTITION(p_max);
SELECT * FROM t_timestamp_range3 PARTITION(p_pos_inf);
alter table t_timestamp_range3 modify column c1 TIMESTAMP;
ALTER TABLE t_timestamp_range3 PARTITION BY RANGE COLUMNS(c1) (
    PARTITION p0 VALUES LESS THAN ('1970-01-01 00:00:01'),
    PARTITION p1 VALUES LESS THAN ('2024-04-01 00:00:00'),
    PARTITION p2 VALUES LESS THAN ('2024-08-01 00:00:00'),
    PARTITION p3 VALUES LESS THAN ('2024-12-01 00:00:00'),
    PARTITION p4 VALUES LESS THAN ('2038-01-19 03:14:07')
);
alter table t_timestamp_range3 modify column c1 DOUBLE;
alter table t_timestamp_range3 modify column c1 INT;
ALTER TABLE t_timestamp_range3 PARTITION BY RANGE COLUMNS(c1) (
    PARTITION p_neg_inf VALUES LESS THAN (-1000),
    PARTITION p_min VALUES LESS THAN (-200),
    PARTITION p_zero VALUES LESS THAN (0),
    PARTITION p_min_pos VALUES LESS THAN (200),
    PARTITION p_max VALUES LESS THAN (1000),
    PARTITION p_pos_inf VALUES LESS THAN MAXVALUE
);
alter table t_timestamp_range3 modify column c1 INT;
