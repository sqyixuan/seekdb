##int 转 TIMESTAMP单独验证
DROP TABLE IF EXISTS t_timestamp_range4;
CREATE TABLE t_timestamp_range4 (
    c1 INT
) 
PARTITION BY RANGE COLUMNS(c1) (
    PARTITION p_neg_inf VALUES LESS THAN (-1000),
    PARTITION p_min VALUES LESS THAN (-200),
    PARTITION p_zero VALUES LESS THAN (0),
    PARTITION p_min_pos VALUES LESS THAN (200),
    PARTITION p_max VALUES LESS THAN (1000),
    PARTITION p_pos_inf VALUES LESS THAN MAXVALUE
);
alter table t_timestamp_range4 modify column c1 TIMESTAMP;
DROP TABLE IF EXISTS t_binary_range4;
CREATE TABLE t_binary_range4 (
    c1 BINARY(10)
) 
PARTITION BY RANGE COLUMNS(c1) (
    PARTITION p_neg_inf VALUES LESS THAN (CAST('a' AS BINARY)),
    PARTITION p_min VALUES LESS THAN (CAST('j' AS BINARY)),
    PARTITION p_zero VALUES LESS THAN (CAST('m' AS BINARY)),
    PARTITION p_min_pos VALUES LESS THAN (CAST('t' AS BINARY)),
    PARTITION p_max VALUES LESS THAN (CAST('z' AS BINARY)),
    PARTITION p_pos_inf VALUES LESS THAN (MAXVALUE)
);
CREATE TABLE t_binary_range4 (
    c1 BINARY(10)
) 
PARTITION BY RANGE COLUMNS(c1) (
    PARTITION p_neg_inf VALUES LESS THAN ('a'),
    PARTITION p_min VALUES LESS THAN ('j'),
    PARTITION p_zero VALUES LESS THAN ('m'),
    PARTITION p_min_pos VALUES LESS THAN ('t'),
    PARTITION p_max VALUES LESS THAN ('z'),
    PARTITION p_pos_inf VALUES LESS THAN (MAXVALUE)
);
INSERT INTO t_binary_range4 (c1) VALUES
(CAST('apple' AS BINARY)),
(CAST('teach' AS BINARY)),
(CAST('zebra' AS BINARY));
alter table t_binary_range4 modify column c1 TIMESTAMP;
alter table t_binary_range4 modify column c1 INT;
alter table t_binary_range4 modify column c1 FLOAT;
alter table t_binary_range4 modify column c1 DOUBLE;
TRUNCATE TABLE t_binary_range4;
ALTER TABLE t_binary_range4 PARTITION BY RANGE COLUMNS(c1)(
PARTITION p_neg_inf VALUES LESS THAN ('a'),
PARTITION p_pos_inf VALUES LESS THAN MAXVALUE
);
alter table t_binary_range4 modify column c1 DOUBLE;
ALTER TABLE t_binary_range4 PARTITION BY RANGE COLUMNS(c1) (
    PARTITION p_neg_inf VALUES LESS THAN (- 3.402823466e+38),
    PARTITION p_min VALUES LESS THAN (-1.175494351e-38),
    PARTITION p_zero VALUES LESS THAN (0),
    PARTITION p_min_pos VALUES LESS THAN (1.175494351e-38),
    PARTITION p_max VALUES LESS THAN (3.402823466e+38),
    PARTITION p_pos_inf VALUES LESS THAN MAXVALUE
);
