## 数字类型
DROP TABLE IF EXISTS t_timestamp_range3;
CREATE TABLE t_timestamp_range3 (
    c1 TIMESTAMP
) 
PARTITION BY RANGE COLUMNS(c1) (
    PARTITION p0 VALUES LESS THAN ('1970-01-01 00:00:01'),
    PARTITION p1 VALUES LESS THAN ('2024-04-01 00:00:00'),
    PARTITION p2 VALUES LESS THAN ('2024-08-01 00:00:00'),
    PARTITION p3 VALUES LESS THAN ('2024-12-01 00:00:00'),
    PARTITION p4 VALUES LESS THAN ('2038-01-19 03:14:07')
);
INSERT INTO t_timestamp_range3 (c1) VALUES
('1970-01-01 00:00:01'),
('2038-01-19 03:14:06'),
(NOW()),
(CURDATE()),
(FROM_UNIXTIME(UNIX_TIMESTAMP())),
('2024-01-01'),
('2024-01-01 12:00:00'),
('2024-02-01 12:34:56'),
('2024-04-01'),
('2024-04-01 12:00:00'),
('2024-04-01 12:00:00.000000'),
('2024-07-01 12:00:00'),
('2024-08-01 12:00:00'),
('2024-08-01'),
('2024-09-01 12:00:00'),
('2024-10-01 12:00:00'),
('2024-12-01 12:00:00');
SELECT * FROM t_timestamp_range3;
TRUNCATE TABLE t_timestamp_range3;
alter table t_timestamp_range3 modify column c1 FLOAT;
