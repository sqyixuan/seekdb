DROP TABLE IF EXISTS t_binary_range5;
CREATE TABLE t_binary_range5 (
    c1 BINARY(10)
) 
PARTITION BY RANGE COLUMNS(c1) (
    PARTITION p_neg_inf VALUES LESS THAN ('a'),
    PARTITION p_min VALUES LESS THAN ('j'),
    PARTITION p_zero VALUES LESS THAN ('m'),
    PARTITION p_min_pos VALUES LESS THAN ('t'),
    PARTITION p_max VALUES LESS THAN ('z'),
    PARTITION p_pos_inf VALUES LESS THAN (MAXVALUE)
);
INSERT INTO t_binary_range5 (c1) VALUES
(CAST('a' AS BINARY)),
(CAST('b' AS BINARY)),
(CAST('c' AS BINARY));
alter table t_binary_range5 modify column c1 DOUBLE;
TRUNCATE TABLE t_binary_range5;
ALTER TABLE t_binary_range5 PARTITION BY RANGE COLUMNS(c1)(
PARTITION p0 VALUES LESS THAN ('a'),
PARTITION p1 VALUES LESS THAN ('m'),
PARTITION p2 VALUES LESS THAN ('z'),
PARTITION p_pos_inf VALUES LESS THAN MAXVALUE
);
alter table t_binary_range5 modify column c1 DOUBLE;
alter table t_binary_range5 modify column c1 FLOAT;
alter table t_binary_range5 modify column c1 VARCHAR(10);
alter table t_binary_range5 modify column c1 BINARY(10);
DROP TABLE IF EXISTS t_char_range4;
CREATE TABLE t_char_range4 (
    c1 CHAR(10)
) 
PARTITION BY RANGE COLUMNS(c1) (
    PARTITION p_neg_inf VALUES LESS THAN ('a'),
    PARTITION p_min VALUES LESS THAN ('j'),
    PARTITION p_zero VALUES LESS THAN ('m'),
    PARTITION p_min_pos VALUES LESS THAN ('t'),
    PARTITION p_max VALUES LESS THAN ('z'),
    PARTITION p_pos_inf VALUES LESS THAN (MAXVALUE)
);
alter table t_char_range4 modify column c1 DOUBLE;
alter table t_char_range4 modify column c1 FLOAT;
alter table t_char_range4 modify column c1 TIMESTAMP;
alter table t_char_range4 modify column c1 VARCHAR(10);
