### TIMESTAMP
DROP TABLE IF EXISTS t_timestamp_range1;
CREATE TABLE t_timestamp_range1 (
    c1 TIMESTAMP
) 
PARTITION BY RANGE COLUMNS(c1) (
    PARTITION p0 VALUES LESS THAN ('1970-01-01 00:00:01'),
    PARTITION p1 VALUES LESS THAN ('2024-04-01 00:00:00'),
    PARTITION p2 VALUES LESS THAN ('2024-08-01 00:00:00'),
    PARTITION p3 VALUES LESS THAN ('2024-12-01 00:00:00'),
    PARTITION p4 VALUES LESS THAN ('2038-01-19 03:14:07')
);
INSERT INTO t_timestamp_range1 (c1) VALUES
('1970-01-01 00:00:01'),
('2024-03-31 23:59:59'),
('2024-04-01 00:00:00'),
('2024-07-31 23:59:59'),
('2024-08-01 00:00:00'),
('2024-11-30 23:59:59'),
('2024-12-01 00:00:00');
INSERT INTO t_timestamp_range1 (c1) VALUES
('1970-01-01 00:00:01'),
('2038-01-19 03:14:06'),
(NOW()),
(CURDATE()),
(FROM_UNIXTIME(UNIX_TIMESTAMP())),
('2024-01-01'),
('2024-01-01 12:00:00'),
('2024-02-01 12:34:56'),
('2024-04-01'),
('2024-04-01 12:00:00'),
('2024-04-01 12:00:00.000000'),
('2024-07-01 12:00:00'),
('2024-08-01 12:00:00'),
('2024-08-01'),
('2024-09-01 12:00:00'),
('2024-10-01 12:00:00'),
('2024-12-01 12:00:00');
SELECT * FROM t_timestamp_range1 PARTITION (p0);
SELECT * FROM t_timestamp_range1 PARTITION (p1);
SELECT * FROM t_timestamp_range1 PARTITION (p2);
SELECT * FROM t_timestamp_range1 PARTITION (p3);
SELECT * FROM t_timestamp_range1 PARTITION (p4);
alter table t_timestamp_range1 modify column c1 DATE;
alter table t_timestamp_range1 modify column c1 DATETIME;
SELECT * FROM t_timestamp_range1 PARTITION (p0);
SELECT * FROM t_timestamp_range1 PARTITION (p1);
SELECT * FROM t_timestamp_range1 PARTITION (p2);
SELECT * FROM t_timestamp_range1 PARTITION (p3);
SELECT * FROM t_timestamp_range1 PARTITION (p4);
alter table t_timestamp_range1 modify column c1 TIME;
alter table t_timestamp_range1 modify column c1 YEAR;
DROP TABLE IF EXISTS t_date_range1;
CREATE TABLE t_date_range1 (
    c1 DATE
) 
PARTITION BY RANGE COLUMNS(c1) (
    PARTITION p0 VALUES LESS THAN ('1970-01-01 00:00:01'),
    PARTITION p1 VALUES LESS THAN ('2024-04-01 00:00:00'),
    PARTITION p2 VALUES LESS THAN ('2024-08-01 00:00:00'),
    PARTITION p3 VALUES LESS THAN ('2024-12-01 00:00:00'),
    PARTITION p4 VALUES LESS THAN ('2038-01-19 03:14:07')
);
