DROP TABLE IF EXISTS t_double_range;
CREATE TABLE t_double_range (
    id INT NOT NULL AUTO_INCREMENT,
    c1 DOUBLE NOT NULL DEFAULT 0,
    PRIMARY KEY (id,c1),
    UNIQUE KEY (c1)
) 
PARTITION BY RANGE COLUMNS(c1) (
    PARTITION p_neg_inf VALUES LESS THAN (-1.7976931348623157E308),
    PARTITION p_min VALUES LESS THAN (-2.2250738585072014E-308),
    PARTITION p_zero VALUES LESS THAN (0),
    PARTITION p_min_pos VALUES LESS THAN (2.2250738585072014E-308),
    PARTITION p_max VALUES LESS THAN (1.7976931348623157E308),
    PARTITION p_pos_inf VALUES LESS THAN MAXVALUE
);
INSERT INTO t_double_range (c1) VALUES (-1.7976931348623157E308);
INSERT INTO t_double_range (c1) VALUES (-2.2250738585072014E-308);
INSERT INTO t_double_range (c1) VALUES (0);
INSERT INTO t_double_range (c1) VALUES (2.2250738585072014E-308);
INSERT INTO t_double_range (c1) VALUES (1.7976931348623157E308);
SELECT * FROM t_double_range PARTITION (p_neg_inf);
+----+----+
| id | c1 |
+----+----+
+----+----+
SELECT * FROM t_double_range PARTITION (p_min);
+----+-------------------------+
| id | c1                      |
+----+-------------------------+
|  1 | -1.7976931348623157e308 |
+----+-------------------------+
SELECT * FROM t_double_range PARTITION (p_zero);
+----+--------------------------+
| id | c1                       |
+----+--------------------------+
|  2 | -2.2250738585072014e-308 |
+----+--------------------------+
SELECT * FROM t_double_range PARTITION (p_min_pos);
+----+----+
| id | c1 |
+----+----+
|  3 |  0 |
+----+----+
SELECT * FROM t_double_range PARTITION (p_max);
+----+-------------------------+
| id | c1                      |
+----+-------------------------+
|  4 | 2.2250738585072014e-308 |
+----+-------------------------+
SELECT * FROM t_double_range PARTITION (p_pos_inf);
+----+------------------------+
| id | c1                     |
+----+------------------------+
|  5 | 1.7976931348623157e308 |
+----+------------------------+
DROP TABLE IF EXISTS t_float_range;
CREATE TABLE t_float_range (
    id INT NOT NULL AUTO_INCREMENT PRIMARY KEY,
    c1 FLOAT NOT NULL DEFAULT 0,
    UNIQUE KEY (id,c1),
    UNIQUE KEY uidx_c1 (c1)
) 
PARTITION BY RANGE COLUMNS(c1) (
    PARTITION p_neg_inf VALUES LESS THAN (POW(-2, 1023)),
    PARTITION p_min VALUES LESS THAN (POW(-2, -126)),
    PARTITION p_zero VALUES LESS THAN (0),
    PARTITION p_min_pos VALUES LESS THAN (POW(2, -126)),
    PARTITION p_max VALUES LESS THAN (POW(2, 1023)),
    PARTITION p_pos_inf VALUES LESS THAN MAXVALUE
);
ERROR HY000: This partition function is not allowed
CREATE TABLE t_float_range (
    id INT NOT NULL AUTO_INCREMENT ,
    c1 FLOAT PRIMARY KEY NOT NULL  DEFAULT 0,
    UNIQUE KEY (id,c1),
    UNIQUE KEY uidx_c1 (c1,id)
) 
PARTITION BY RANGE COLUMNS(c1) (
    PARTITION p_neg_inf VALUES LESS THAN (-2013),
    PARTITION p_min VALUES LESS THAN ( -126),
    PARTITION p_zero VALUES LESS THAN (0),
    PARTITION p_min_pos VALUES LESS THAN (126),
    PARTITION p_max VALUES LESS THAN (2023),
    PARTITION p_pos_inf VALUES LESS THAN MAXVALUE
);
INSERT INTO t_float_range (c1) VALUES (POW(-2, 1023));
INSERT INTO t_float_range (c1) VALUES (POW(-2, -126));
INSERT INTO t_float_range (c1) VALUES (0);
INSERT INTO t_float_range (c1) VALUES (POW(2, -126));
ERROR 23000: Duplicate entry '1.17549e-38' for key 'PRIMARY'
INSERT INTO t_float_range (c1) VALUES (POW(2, 1023));
SELECT * FROM t_float_range PARTITION (p_neg_inf);
+----+-------------+
| id | c1          |
+----+-------------+
|  1 | -3.40282e38 |
+----+-------------+
SELECT * FROM t_float_range PARTITION (p_min);
+----+----+
| id | c1 |
+----+----+
+----+----+
SELECT * FROM t_float_range PARTITION (p_zero);
+----+----+
| id | c1 |
+----+----+
+----+----+
SELECT * FROM t_float_range PARTITION (p_min_pos);
+----+-------------+
| id | c1          |
+----+-------------+
|  3 |           0 |
|  2 | 1.17549e-38 |
+----+-------------+
SELECT * FROM t_float_range PARTITION (p_max);
+----+----+
| id | c1 |
+----+----+
+----+----+
SELECT * FROM t_float_range PARTITION (p_pos_inf);
+----+------------+
| id | c1         |
+----+------------+
|  5 | 3.40282e38 |
+----+------------+
DROP TABLE IF EXISTS t_decimal_range;
CREATE TABLE t_decimal_range (
    id INT NOT NULL AUTO_INCREMENT,
    c1 DECIMAL(65,30) NOT NULL,
    PRIMARY KEY (id,c1),
    UNIQUE KEY (c1,id)
) 
PARTITION BY RANGE COLUMNS(c1) (
    PARTITION p_neg_inf VALUES LESS THAN (-99999999999999999999999999999999999.999999999999999999999999999999),
    PARTITION p_min VALUES LESS THAN (-0.000000000000000000000000000001),
    PARTITION p_zero VALUES LESS THAN (0),
    PARTITION p_min_pos VALUES LESS THAN (0.000000000000000000000000000001),
    PARTITION p_max VALUES LESS THAN (99999999999999999999999999999999999.999999999999999999999999999999),
    PARTITION p_pos_inf VALUES LESS THAN MAXVALUE
);
INSERT INTO t_decimal_range (c1) VALUES (-99999999999999999999999999999999999.999999999999999999999999999999);
INSERT INTO t_decimal_range (c1) VALUES (-0.000000000000000000000000000001);
INSERT INTO t_decimal_range (c1) VALUES (0);
INSERT INTO t_decimal_range (c1) VALUES (0.000000000000000000000000000001);
INSERT INTO t_decimal_range (c1) VALUES (99999999999999999999999999999999999.999999999999999999999999999999);
SELECT * FROM t_decimal_range PARTITION (p_neg_inf);
+----+----+
| id | c1 |
+----+----+
+----+----+
SELECT * FROM t_decimal_range PARTITION (p_min);
+----+---------------------------------------------------------------------+
| id | c1                                                                  |
+----+---------------------------------------------------------------------+
|  1 | -99999999999999999999999999999999999.999999999999999999999999999999 |
+----+---------------------------------------------------------------------+
SELECT * FROM t_decimal_range PARTITION (p_zero);
+----+-----------------------------------+
| id | c1                                |
+----+-----------------------------------+
|  2 | -0.000000000000000000000000000001 |
+----+-----------------------------------+
SELECT * FROM t_decimal_range PARTITION (p_min_pos);
+----+----------------------------------+
| id | c1                               |
+----+----------------------------------+
|  3 | 0.000000000000000000000000000000 |
+----+----------------------------------+
SELECT * FROM t_decimal_range PARTITION (p_max);
+----+----------------------------------+
| id | c1                               |
+----+----------------------------------+
|  4 | 0.000000000000000000000000000001 |
+----+----------------------------------+
SELECT * FROM t_decimal_range PARTITION (p_pos_inf);
+----+--------------------------------------------------------------------+
| id | c1                                                                 |
+----+--------------------------------------------------------------------+
|  5 | 99999999999999999999999999999999999.999999999999999999999999999999 |
+----+--------------------------------------------------------------------+
DROP TABLE IF EXISTS t_timestamp_range1;
CREATE TABLE t_timestamp_range1 (
    c1 TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP,
    PRIMARY KEY (c1)
) 
PARTITION BY RANGE COLUMNS(c1) (
    PARTITION p0 VALUES LESS THAN ('1970-01-01 00:00:01'),
    PARTITION p1 VALUES LESS THAN ('2024-04-01 00:00:00'),
    PARTITION p2 VALUES LESS THAN ('2024-08-01 00:00:00'),
    PARTITION p3 VALUES LESS THAN ('2024-12-01 00:00:00'),
    PARTITION p4 VALUES LESS THAN ('2038-01-19 03:14:07')
);
INSERT INTO t_timestamp_range1 (c1) VALUES ('1969-12-31 23:00:00');
INSERT INTO t_timestamp_range1 (c1) VALUES ('2024-03-01 00:00:00');
INSERT INTO t_timestamp_range1 (c1) VALUES ('2024-07-01 00:00:00');
INSERT INTO t_timestamp_range1 (c1) VALUES ('2024-11-01 00:00:00');
INSERT INTO t_timestamp_range1 (c1) VALUES ('2038-01-18 03:14:07');
SELECT * FROM t_timestamp_range1 PARTITION (p0);
+---------------------+
| c1                  |
+---------------------+
| 1969-12-31 23:00:00 |
+---------------------+
SELECT * FROM t_timestamp_range1 PARTITION (p1);
+---------------------+
| c1                  |
+---------------------+
| 2024-03-01 00:00:00 |
+---------------------+
SELECT * FROM t_timestamp_range1 PARTITION (p2);
+---------------------+
| c1                  |
+---------------------+
| 2024-07-01 00:00:00 |
+---------------------+
SELECT * FROM t_timestamp_range1 PARTITION (p3);
+---------------------+
| c1                  |
+---------------------+
| 2024-11-01 00:00:00 |
+---------------------+
SELECT * FROM t_timestamp_range1 PARTITION (p4);
+---------------------+
| c1                  |
+---------------------+
| 2038-01-18 03:14:07 |
+---------------------+
####一级分区分别为 range、range columns（非 double、float、decimal、timestamp） 、hash、key、list、list columns等
####list + range columns 二级分区表。
###  列属性全覆盖
drop table if exists t_range_partition_1_sub_1;
CREATE TABLE t_range_partition_1_sub_1 (
    id INT NOT NULL AUTO_INCREMENT,
    c1 DOUBLE NOT NULL DEFAULT 0,
    c2 FLOAT,
    c3 DECIMAL(65, 30) NOT NULL DEFAULT 0,
    c4 DATE NOT NULL,
    c5 INT NOT NULL,
    UNIQUE KEY (c1, c3,c4,c5),
    INDEX c2_idx (c2),
    INDEX (c4),
    INDEX (c5)
)
PARTITION BY LIST (c5)
SUBPARTITION BY RANGE COLUMNS (c1, c3, c4) SUBPARTITION TEMPLATE (
    SUBPARTITION part01 VALUES LESS THAN (-2.2250738585072014E-308, -0.000000000000000000000000000001, '1970-01-01'),
    SUBPARTITION part02 VALUES LESS THAN (0, 0, '2024-04-01'),
    SUBPARTITION part03 VALUES LESS THAN (1.7976931348623157E308, 999999999999999999999999999999.999999999999999999999999999999, '2038-01-19')
) (
    PARTITION p0 VALUES IN (1, 2, 3, 4, 5, 6),
    PARTITION p1 VALUES IN (100, 200, 300, 400, 1000, 2000, 3000)
);
INSERT INTO t_range_partition_1_sub_1 (c1, c2, c3, c4, c5) VALUES
(-1.7976931348623157E308, -3.402823466E+38, -999999999999999999999999999999.999999999999999999999999999999, '1969-12-31',1),
(0, 0, 0, '2020-06-01',2),
(1.7976931348623157E307, 3.402823466E+37, 9999999999.9999999, '2038-01-19',6),
(1.7976931348623157E307, 3.402823466E+37, 9999999999.9999999, '2038-01-19',100),
(1.7976931348623157E307, 3.402823466E+37, 999999999999999.9999999999, '2038-01-19',3000);
SELECT * FROM t_range_partition_1_sub_1 PARTITION (p0);
+----+-------------------------+-------------+----------------------------------------------------------------+------------+----+
| id | c1                      | c2          | c3                                                             | c4         | c5 |
+----+-------------------------+-------------+----------------------------------------------------------------+------------+----+
|  1 | -1.7976931348623157e308 | -3.40282e38 | -999999999999999999999999999999.999999999999999999999999999999 | 1969-12-31 |  1 |
|  2 |                       0 |           0 |                               0.000000000000000000000000000000 | 2020-06-01 |  2 |
|  3 |  1.7976931348623158e307 |  3.40282e37 |                      9999999999.999999900000000000000000000000 | 2038-01-19 |  6 |
+----+-------------------------+-------------+----------------------------------------------------------------+------------+----+
SELECT * FROM t_range_partition_1_sub_1 PARTITION (p1);
+----+------------------------+------------+------------------------------------------------+------------+------+
| id | c1                     | c2         | c3                                             | c4         | c5   |
+----+------------------------+------------+------------------------------------------------+------------+------+
|  4 | 1.7976931348623158e307 | 3.40282e37 |      9999999999.999999900000000000000000000000 | 2038-01-19 |  100 |
|  5 | 1.7976931348623158e307 | 3.40282e37 | 999999999999999.999999999900000000000000000000 | 2038-01-19 | 3000 |
+----+------------------------+------------+------------------------------------------------+------------+------+
######## 清空回收站，删除测试数据库 ########
drop database if exists sltest;
purge recyclebin;
