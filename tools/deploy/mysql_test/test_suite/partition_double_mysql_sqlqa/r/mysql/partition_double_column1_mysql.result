purge recyclebin;
drop database if exists sltest;
create database sltest;
use sltest;
set timestamp = 1600000000;
set ob_trx_timeout = 10000000000;
set ob_query_timeout = 10000000000;
set @@session.explicit_defaults_for_timestamp=off;
result_format: 4
set sql_mode = '';
-----------------------------------------------------------------------------------------------------------------
### 本次支持的类型：double、float、decimal、timestamp 作为range columns分区的分区键。
###  一级分区为 range columns(double、float、decimal、timestamp)
###  列属性全覆盖
DROP TABLE IF EXISTS EMP;
CREATE TABLE EMP (
    EMPNO DOUBLE NOT NULL AUTO_INCREMENT PRIMARY KEY,
    ENAME VARCHAR(100),
    JOB VARCHAR(100),
    MGR INT,
    HIREDATE DATE,
    SAL FLOAT(8,2),
    COMM INT,
    DEPTNO DECIMAL NOT NULL,
    COMID INT,
    UNIQUE KEY (EMPNO),
    INDEX job_idx (JOB),
    INDEX sal_idx (SAL),
    UNIQUE INDEX ename_idx (ENAME),
    INDEX deptno_idx (DEPTNO)
)
PARTITION BY  RANGE COLUMNS(EMPNO,DEPTNO)
SUBPARTITION BY RANGE COLUMNS(DEPTNO,EMPNO)(
    PARTITION P0 VALUES LESS THAN(15,100) (
        SUBPARTITION PART01 VALUES LESS THAN(15,100),
        SUBPARTITION PART02 VALUES LESS THAN(25,1000),
        SUBPARTITION PART03 VALUES LESS THAN(35,6000)
    ),
    PARTITION P1 VALUES LESS THAN(500,100) (
        SUBPARTITION PART04 VALUES LESS THAN(15,100),
        SUBPARTITION PART05 VALUES LESS THAN(25,1000),
        SUBPARTITION PART06 VALUES LESS THAN(35,6000)
    )
);
ERROR HY000: A PRIMARY KEY must include all columns in the table's partitioning function
CREATE TABLE EMP (
    EMPNO DOUBLE NOT NULL AUTO_INCREMENT,
    ENAME VARCHAR(100),
    JOB VARCHAR(100),
    MGR INT,
    HIREDATE DATE,
    SAL FLOAT(8,2),
    COMM INT,
    DEPTNO DECIMAL NOT NULL,
    COMID INT,
    UNIQUE KEY (EMPNO),
    INDEX job_idx (JOB),
    INDEX sal_idx (SAL),
    UNIQUE INDEX ename_idx (ENAME),
    INDEX deptno_idx (DEPTNO)
)
PARTITION BY  RANGE COLUMNS(EMPNO,DEPTNO)
SUBPARTITION BY RANGE COLUMNS(DEPTNO,EMPNO)(
    PARTITION P0 VALUES LESS THAN(15,100) (
        SUBPARTITION PART01 VALUES LESS THAN(15,100),
        SUBPARTITION PART02 VALUES LESS THAN(25,1000),
        SUBPARTITION PART03 VALUES LESS THAN(35,6000)
    ),
    PARTITION P1 VALUES LESS THAN(500,100) (
        SUBPARTITION PART04 VALUES LESS THAN(15,100),
        SUBPARTITION PART05 VALUES LESS THAN(25,1000),
        SUBPARTITION PART06 VALUES LESS THAN(35,6000)
    )
);
ERROR HY000: A UNIQUE INDEX must include all columns in the table's partitioning function
CREATE TABLE EMP (
    EMPNO DOUBLE NOT NULL AUTO_INCREMENT,
    ENAME VARCHAR(100),
    JOB VARCHAR(100),
    MGR INT,
    HIREDATE DATE,
    SAL FLOAT(8,2),
    COMM INT,
    DEPTNO DECIMAL NOT NULL,
    COMID INT,
    UNIQUE KEY (EMPNO,DEPTNO),
    INDEX job_idx (JOB),
    INDEX sal_idx (SAL),
    UNIQUE INDEX ename_idx (EMPNO,DEPTNO),
    INDEX deptno_idx (DEPTNO)
)
PARTITION BY  RANGE COLUMNS(EMPNO,DEPTNO)
SUBPARTITION BY RANGE COLUMNS(DEPTNO,EMPNO)(
    PARTITION P0 VALUES LESS THAN(15,100) (
        SUBPARTITION PART01 VALUES LESS THAN(15,100),
        SUBPARTITION PART02 VALUES LESS THAN(25,1000),
        SUBPARTITION PART03 VALUES LESS THAN(35,6000)
    ),
    PARTITION P1 VALUES LESS THAN(500,100) (
        SUBPARTITION PART04 VALUES LESS THAN(15,100),
        SUBPARTITION PART05 VALUES LESS THAN(25,1000),
        SUBPARTITION PART06 VALUES LESS THAN(35,6000)
    )
);
DROP TABLE IF EXISTS DEPT_TABLE;
CREATE TABLE DEPT_TABLE (
    DEPTNO DECIMAL NOT NULL PRIMARY KEY,
    DNAME VARCHAR(100),
    LOC VARCHAR(100),
    INDEX (DNAME)
);
ALTER TABLE EMP ADD CONSTRAINT fk_deptno FOREIGN KEY (DEPTNO) REFERENCES DEPT_TABLE(DEPTNO);
INSERT INTO EMP (EMPNO, ENAME, JOB, MGR, HIREDATE, SAL, COMM, DEPTNO, COMID)
