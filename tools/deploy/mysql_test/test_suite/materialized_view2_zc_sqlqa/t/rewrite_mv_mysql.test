--result_format 4
PURGE RECYCLEBIN;

##clean PLAN
alter system flush plan cache global;

--error 0,942,1146
DROP MATERIALIZED VIEW LOG ON col_info;
--error 0,942,1146
DROP MATERIALIZED VIEW LOG ON col_item;
--error 0,942,1051
DROP table col_item;
--error 0,942,1051
DROP table col_info;

--error 0,12003,9757
DROP materialized view ZC_MV1;
--error 0,12003,9757
DROP materialized view ZC_MV2;
--error 0,12003,9757
DROP materialized view ZC_MV3;
--error 0,12003,9757
DROP materialized view ZC_MV4;

CREATE table col_info(c1 int,c2 int,PRIMARY KEY(c2)) PARTITION by hash(c2) partitions 1000;
CREATE TABLE col_item(c1 int PRIMARY KEY,c2 int,c3 VARCHAR(1000),FOREIGN KEY(C1) REFERENCES col_info(C2)) PARTITION by hash(c1) partitions 16;

CREATE MATERIALIZED VIEW LOG ON col_info parallel 1 WITH PRIMARY KEY,ROWID,SEQUENCE(c1)INCLUDING NEW VALUES;
CREATE MATERIALIZED VIEW LOG ON col_item parallel 2 WITH PRIMARY KEY,ROWID,SEQUENCE(c2,c3) INCLUDING NEW VALUES;

##先添加数据
INSERT INTO col_info SELECT 1,1 from dual;
INSERT INTO col_info SELECT c1+1,c2+1 from col_info;
INSERT INTO col_info SELECT c1+2,c2+2 from col_info;
INSERT INTO col_info SELECT c1+4,c2+4 from col_info;
INSERT INTO col_info SELECT c1+8,c2+8 from col_info;

INSERT INTO col_item VALUES(1,1,'A');
INSERT INTO col_item SELECT C1+1,C2+1,C3 FROM col_item;
INSERT INTO col_item SELECT C1+2,C2+2,C3 FROM col_item;
INSERT INTO col_item SELECT C1+4,C2+4,C3 FROM col_item;
INSERT INTO col_item SELECT C1+8,C2+8,C3 FROM col_item;

##MV
create materialized view ZC_MV1 REFRESH FORCE ON DEMAND enable query rewrite AS
select * from col_info ZT1;

create materialized view ZC_MV2 REFRESH FORCE ON DEMAND enable query rewrite AS
select * from col_item ZT2 WHERE zt2.c1 > 1;

create materialized view ZC_MV3 never REFRESH enable query rewrite AS
select zt1.c1 c1_1,zt1.c2 c2_1,zt2.c1 c1_2,zt2.c2 c2_2,zt2.c3 c3_2
from col_info ZT1,col_item ZT2 WHERE zt1.c2 = zt2.c1;


##建好物化视图后再次添加数据
INSERT INTO col_info SELECT c1+16,c2+16 from col_info;
INSERT INTO col_info SELECT c1+32,c2+32 from col_info WHERE C1 IS NOT NULL;
INSERT INTO col_item SELECT C1+16,C2+16,C3 FROM col_item WHERE C3 IS NOT NULL;
UPDATE col_info SET C1 = 999 WHERE C2 = 1;
UPDATE col_item SET C3 = 'N' WHERE C2 = 2;
DELETE FROM col_info WHERE C1 BETWEEN 55 AND 56;
DELETE FROM col_item WHERE C3 LIKE '%N%';

####收集统计信息
CALL dbms_stats.gather_table_stats('test', 'col_info');
CALL dbms_stats.gather_table_stats('test', 'col_item');
CALL dbms_stats.gather_table_stats('test', 'ZC_MV1');
CALL dbms_stats.gather_table_stats('test', 'ZC_MV2');
CALL dbms_stats.gather_table_stats('test', 'ZC_MV3');

####开启物化改写(检查开，非实时物化开)
SET QUERY_REWRITE_ENABLED = TRUE;
set QUERY_REWRITE_INTEGRITY = stale_tolerated;
#ALTER SESSION SET QUERY_REWRITE_ENABLED = TRUE;
#ALTER SESSION set QUERY_REWRITE_INTEGRITY = stale_tolerated;

####SELECT
##re
select ZT1.c1 as c1,ZT1.C2 AS c2 from col_info ZT1 ORDER by c1;
explain basic select ZT1.c1 as c1,ZT1.C2 AS c2 from col_info ZT1 ORDER by c1;

##re
select /*+mv_rewrite(ZC_MV1)*/ZT1.c1 as c1,ZT1.C2 AS c2 from col_info ZT1 order by c1;
explain basic select /*+mv_rewrite(ZC_MV1)*/ZT1.c1 as c1,ZT1.C2 AS c2 from col_info ZT1 order by c1;

##nore
select /*+no_mv_rewrite*/ZT1.c1 as c1,ZT1.C2 AS c2 from col_info ZT1 order by 1;
explain basic select /*+no_mv_rewrite*/ZT1.c1 as c1,ZT1.C2 AS c2 from col_info ZT1 order by 1;
select /*+no_rewrite*/ZT1.c1 as c1,ZT1.C2 AS c2 from col_info ZT1 order by 1;

##WHERE
