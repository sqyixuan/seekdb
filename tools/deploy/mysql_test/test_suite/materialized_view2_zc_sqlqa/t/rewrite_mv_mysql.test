##nore
SELECT /*+no_mv_rewrite*/* FROM col_info ZT1 WHERE ZT1.C1 >1 ORDER BY 1;
SELECT /*+no_rewrite*/* FROM col_info ZT1 WHERE ZT1.C1 >1 ORDER BY 1;
explain SELECT /*+no_mv_rewrite*/* FROM col_info ZT1 WHERE ZT1.C1 >1 ORDER BY 1;

