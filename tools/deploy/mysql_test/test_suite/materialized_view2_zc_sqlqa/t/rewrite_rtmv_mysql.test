DROP materialized view ZC_RTMV3;
create materialized view ZC_RTMV3 (PRIMARY KEY(c2)) PARTITION BY RANGE(C2) subpartition by hash(C2)subpartitions 2 (PARTITION P0 VALUES LESS THAN (10),PARTITION P1 VALUES LESS THAN(MAXVALUE))
REFRESH FORCE ON DEMAND enable on query computation enable query rewrite AS
select ZT1.c1 as c1,ZT1.C2 AS C2,ZT2.C1 AS C3 ,zt2.c2 AS C4
from col_item ZT2 inner join col_info zt1 ON zt1.c2 = zt2.c1 WHERE zt1.c1 >10;
CALL dbms_stats.gather_table_stats('test', 'ZC_RTMV3');

