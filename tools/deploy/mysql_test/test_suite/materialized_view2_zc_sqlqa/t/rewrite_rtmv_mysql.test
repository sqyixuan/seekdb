##re
select /*+mv_rewrite(ZC_RTMV2)*/ZT1.c1 as c1,ZT1.C2 AS C2,ZT2.C1 AS C3 ,zt2.c2 AS C4,zt2.c3 as c5 from col_item ZT2 inner join col_info zt1 ON zt1.c2 = zt2.c1 WHERE zt1.c1 > 10 order by 1;
--replace_regex /:[0-9]+/:/
explain basic select /*+mv_rewrite(ZC_RTMV2)*/ZT1.c1 as c1,ZT1.C2 AS C2,ZT2.C1 AS C3 ,zt2.c2 AS C4,zt2.c3 as c5 from col_item ZT2 inner join col_info zt1 ON zt1.c2 = zt2.c1 WHERE zt1.c1 > 10 order by 1;


##re
select ZT1.c1 as c1,ZT1.C2 AS C2,ZT2.C1 AS C3 ,zt2.c2 AS C4,zt2.c3 as c5 from col_item ZT2 inner join col_info zt1 ON zt1.c2 = zt2.c1 WHERE zt1.c1 > 10 order by 1;
--replace_regex /:[0-9]+/:/
explain basic select ZT1.c1 as c1,ZT1.C2 AS C2,ZT2.C1 AS C3 ,zt2.c2 AS C4,zt2.c3 as c5 from col_item ZT2 inner join col_info zt1 ON zt1.c2 = zt2.c1 WHERE zt1.c1 > 10 order by 1;


