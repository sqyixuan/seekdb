##HAVING##(NOT supported)
--error 9783,32361
create materialized view ZC_MV1 REFRESH FAST ON DEMAND enable on query computation AS
select ZT1.c1 as c1,ZT1.PK AS PK,ZT1.C2 AS C2,count(*) as cnt
from ZC_T1 ZT1
group by ZT1.c1,ZT1.C2,ZT1.PK HAVING zt1.pk > 0;


####GROUP BY####
create materialized view ZC_MV1 REFRESH FAST ON DEMAND enable on query computation AS
select ROUND(ZT1.c1) as c1,ZT1.PK AS PK,ZT1.C2 AS C2,count(*) as cnt
from ZC_T1 ZT1
group by ROUND(ZT1.c1),ZT1.C2,ZT1.PK;

--source rangdml.inc
select ROUND(ZT1.c1) as c1,ZT1.PK AS PK,ZT1.C2 AS C2,count(*) as cnt
from ZC_T1 ZT1
group by ROUND(ZT1.c1),ZT1.C2,ZT1.PK ORDER by pk;
SELECT * FROM ZC_MV1 ORDER by pk;

SELECT /*+fresh_mv*/* FROM ZC_MV1 order by pk;

##FUNCTION##
DELETE from ZC_t1;
DROP materialized view ZC_MV1;

create materialized view ZC_MV1 REFRESH FAST ON DEMAND enable on query computation AS
select ROUND(ZT1.c1) as c1,LENGTH(ZT1.PK) AS PK,ABS(ZT1.C2) AS C2,count(*) as cnt
from ZC_T1 ZT1
group by ROUND(ZT1.c1),ABS(ZT1.C2),LENGTH(ZT1.PK) ;

--source rangdml.inc
select ROUND(ZT1.c1) as c1,LENGTH(ZT1.PK) AS PK,ABS(ZT1.C2) AS C2,count(*) as cnt
from ZC_T1 ZT1
group by ROUND(ZT1.c1),ABS(ZT1.C2),LENGTH(ZT1.PK) ORDER by pk;
SELECT * FROM ZC_MV1 ORDER by c1;
SELECT /*+fresh_mv*/* FROM ZC_MV1 order by c1;

##distinct##
DELETE from ZC_t1;
DROP materialized view ZC_MV1;
create materialized view ZC_MV1 REFRESH FAST ON DEMAND enable on query computation AS
select DISTINCT zt1.pk AS PK,zt1.c1 as c1,count(*) as cnt
from ZC_T1 ZT1
