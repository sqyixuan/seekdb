####分区表####
CREATE TABLE ZC_T6(pk int PRIMARY KEY, c1 int, c2 int, c3 int) PARTITION by RANGE(pk)
(PARTITION p0 VALUES less THAN (10),
 PARTITION p1 VALUES less THAN (20),
 PARTITION p2 VALUES less THAN (30),
 PARTITION p3 VALUES less THAN (MAXVALUE));

CREATE MATERIALIZED VIEW LOG ON ZC_T6 parallel 2 WITH PRIMARY KEY,ROWID,SEQUENCE(c1,c2,c3) INCLUDING NEW VALUES;

create materialized view ZC_MV6 REFRESH FAST ON DEMAND enable on query computation AS
select ZT6.c1 as c1,ZT6.PK AS PK,ZT6.C2 AS C2,count(*) as cnt
from ZC_T6 ZT6
group by ZT6.c1,ZT6.C2,ZT6.PK;

INSERT INTO ZC_T6 VALUES(6,6,6,6);
INSERT INTO ZC_T6 VALUES(66,66,66,66);
SELECT * FROM ZC_T6;

SELECT * FROM ZC_MV6;

SELECT /*+fresh_mv*/* FROM ZC_MV6;

####指定分区建实时物化视图(oracle无法创建)
--error 9783
create materialized view ZC_MV7 REFRESH FAST ON DEMAND enable on query computation AS
select ZT6.c1 as c1,ZT6.PK AS PK,ZT6.C2 AS C2,count(*) as cnt
from ZC_T6 PARTITION(p0) ZT6
group by ZT6.c1,ZT6.C2,ZT6.PK;

INSERT INTO ZC_T6 VALUES(7,7,7,7);
SELECT * FROM ZC_T6 PARTITION(p0);


####subpartition
CREATE TABLE ZC_T8(pk int PRIMARY KEY, c1 int, c2 int, c3 int) PARTITION by RANGE(PK) subpartition by hash(PK) subpartitions 2
(PARTITION p0 values less THAN (10),
 PARTITION p1 values less THAN (50),
 PARTITION p2 values less THAN (MAXVALUE));

CREATE MATERIALIZED VIEW LOG ON ZC_T8 parallel 2 WITH PRIMARY KEY,ROWID,SEQUENCE(c1,c2,c3) INCLUDING NEW VALUES;

create materialized view ZC_MV8 PARTITION BY RANGE(C3)(PARTITION P0 VALUES LESS THAN (10),PARTITION P1 VALUES LESS THAN(MAXVALUE))  REFRESH FAST ON DEMAND enable on query computation AS
select ZT8.c1 as c1,ZT8.C2 AS C2,ZT8.PK AS C3,count(*) as C4
from ZC_T8 ZT8
group by ZT8.c1,ZT8.C2,ZT8.PK;

INSERT INTO ZC_T8 VALUES(8,8,8,8);
INSERT INTO ZC_T8 VALUES(88,88,88,88);
