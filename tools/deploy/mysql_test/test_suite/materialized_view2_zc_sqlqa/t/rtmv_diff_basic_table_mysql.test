##in/not in##
DELETE from ZC_t1;
DROP materialized view ZC_MV1;

create materialized view ZC_MV1 REFRESH FAST ON DEMAND enable on query computation AS
select SUM(pk) AS su,COUNT(pk) as cnt,SUM(c1) AS su1,COUNT(c1) as cnt1,SUM(c2) AS su2,COUNT(c2) as cnt2,COUNT(c3) as cnt3
from ZC_T1 ZT1
WHERE zt1.pk IN(10,20,30,40,50) OR zt1.c1 NOT IN(10,20,30,40,50) ;

--source rangdml.inc
select SUM(pk) AS su,COUNT(pk) as cnt,SUM(c1) AS su1,COUNT(c1) as cnt1,SUM(c2) AS su2,COUNT(c2) as cnt2,COUNT(c3) as cnt3
from ZC_T1 ZT1
WHERE zt1.pk IN(10,20,30,40,50) OR zt1.c1 NOT IN(10,20,30,40,50) ;

SELECT * FROM ZC_MV1;

SELECT /*+fresh_mv*/* FROM ZC_MV1;

