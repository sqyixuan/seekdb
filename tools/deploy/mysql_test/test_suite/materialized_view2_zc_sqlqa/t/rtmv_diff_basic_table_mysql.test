CREATE MATERIALIZED VIEW LOG ON ZC_T4 parallel 2 WITH ROWID,SEQUENCE(pk,c1,c2,c3) INCLUDING NEW VALUES;

create materialized view ZC_MV4 REFRESH FAST ON DEMAND enable on query computation AS
select ZT4.c1 as c1,ZT4.PK AS PK,ZT4.C2 AS C2,count(*) as cnt
from ZC_T4 ZT4
group by ZT4.c1,ZT4.C2,ZT4.PK;

