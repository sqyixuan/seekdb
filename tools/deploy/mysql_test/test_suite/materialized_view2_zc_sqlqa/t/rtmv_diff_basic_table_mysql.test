create materialized view ZC_MV9
PARTITION BY RANGE(C3) subpartition by hash(C1)subpartitions 2 (PARTITION P0 VALUES LESS THAN (10),PARTITION P1 VALUES LESS THAN(MAXVALUE))
REFRESH FAST ON DEMAND enable on query computation AS
select ZT8.c1 as c1,ZT8.C2 AS C2,ZT8.PK AS C3,count(*) as C4
from ZC_T8 ZT8
group by ZT8.c1,ZT8.C2,ZT8.PK;

