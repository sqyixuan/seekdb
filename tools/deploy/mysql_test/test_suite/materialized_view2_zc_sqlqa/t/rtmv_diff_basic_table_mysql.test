####不同表结构创建rtmv####
####TABLE####
###have PRIMARY###
CREATE TABLE ZC_T1(pk int primary key, c1 int, c2 int, c3 int);

CREATE MATERIALIZED VIEW LOG ON ZC_T1 parallel 2 WITH PRIMARY KEY,ROWID,SEQUENCE(c1,c2,c3) INCLUDING NEW VALUES;

create materialized view ZC_MV1 REFRESH FAST ON DEMAND enable on query computation AS
select ZT1.c1 as c1,ZT1.PK AS PK,ZT1.C2 AS C2,count(*) as cnt
from ZC_T1 ZT1
group by ZT1.c1,ZT1.C2,ZT1.PK;

INSERT INTO ZC_T1 VALUES(1,1,1,1);
#call DBMS_MVIEW.REFRESH('ZC_MV1');
SELECT * FROM ZC_T1;

SELECT * FROM ZC_MV1;

SELECT /*+fresh_mv*/* FROM ZC_MV1;

###have INDEX###
CREATE TABLE ZC_T2(pk int , c1 int, c2 int, c3 int);
CREATE INDEX inzt2 ON zc_t2(pk,c1);

CREATE MATERIALIZED VIEW LOG ON ZC_T2 parallel 2 WITH ROWID,SEQUENCE(pk,c1,c2,c3) INCLUDING NEW VALUES;

create materialized view ZC_MV2 REFRESH FAST ON DEMAND enable on query computation AS
select ZT2.c1 as c1,ZT2.PK AS PK,ZT2.C2 AS C2,count(*) as cnt
from ZC_T2 ZT2
group by ZT2.c1,ZT2.C2,ZT2.PK;

INSERT INTO ZC_T2 VALUES(2,2,2,2);
#call DBMS_MVIEW.REFRESH('ZC_MV1');
SELECT * FROM ZC_T2;
SELECT * FROM ZC_MV2;

SELECT /*+fresh_mv*/* FROM ZC_MV2;

###have UNIQUE###
CREATE TABLE ZC_T3(pk int UNIQUE, c1 int, c2 int, c3 int);

CREATE MATERIALIZED VIEW LOG ON ZC_T3 parallel 2 WITH ROWID,SEQUENCE(pk,c1,c2,c3) INCLUDING NEW VALUES;

create materialized view ZC_MV3 REFRESH FAST ON DEMAND enable on query computation AS
select ZT3.c1 as c1,ZT3.PK AS PK,ZT3.C2 AS C2,count(*) as cnt
from ZC_T3 ZT3
group by ZT3.c1,ZT3.C2,ZT3.PK;

