##WITH ROWID##
DROP MATERIALIZED VIEW LOG ON ZC_T1;

CREATE MATERIALIZED VIEW LOG ON ZC_T1 parallel 2 WITH ROWID,SEQUENCE(c1,c2) INCLUDING NEW VALUES;

create materialized view ZC_MV1 REFRESH FAST ON DEMAND enable on query computation AS
select ZT1.c1 as t1_c1,count(*) as cnt
from ZC_T1 ZT1
group by ZT1.c1;

INSERT INTO ZC_T1 VALUES(3,3,3,3);

SELECT * FROM ZC_T1;

SELECT /*+fresh_mv*/* FROM ZC_MV1;
DROP materialized view ZC_MV1;

##WITH PRIMARY KEY##
DROP MATERIALIZED VIEW LOG ON ZC_T1;

CREATE MATERIALIZED VIEW LOG ON ZC_T1 parallel 2 WITH PRIMARY KEY,SEQUENCE(c1) INCLUDING NEW VALUES;

##oracle这里无法创建mv
create materialized view ZC_MV1 REFRESH FAST ON DEMAND enable on query computation AS
select ZT1.c1 as t1_c1,count(*) as cnt
from ZC_T1 ZT1
group by ZT1.c1;

INSERT INTO ZC_T1 VALUES(4,4,4,4);

SELECT * FROM ZC_T1;

SELECT /*+fresh_mv*/* FROM ZC_MV1;
DROP materialized view ZC_MV1;


