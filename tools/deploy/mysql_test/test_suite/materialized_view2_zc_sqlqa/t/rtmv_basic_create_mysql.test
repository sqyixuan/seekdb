--result_format 4
--enable_sorted_result
PURGE RECYCLEBIN;

#CREATE USER zctest IDENTIFIED BY 123;

--error 0,1146,942
DROP MATERIALIZED VIEW LOG ON ZC_T1;
--error 0,1051,942
DROP TABLE ZC_T1;
--error 0,1051,942
DROP TABLE ZC_T2;

CREATE TABLE ZC_T1(pk int primary key, c1 int, c2 int, c3 int);
CREATE TABLE ZC_T2(c1 int, c2 int, c3 int);

CREATE MATERIALIZED VIEW LOG ON ZC_T1 parallel 2 WITH PRIMARY KEY,ROWID,SEQUENCE(c1,c2,c3) INCLUDING NEW VALUES;

create materialized view ZC_MV1 REFRESH FAST ON DEMAND enable on query computation AS
select ZT1.c1 as t1_c1,count(*) as cnt
from ZC_T1 ZT1
group by ZT1.c1;

INSERT INTO ZC_T1 VALUES(1,1,1,1);
#call DBMS_MVIEW.REFRESH('ZC_MV1');

SELECT * FROM ZC_T1;

SELECT * FROM ZC_MV1;

SELECT /*+fresh_mv*/* FROM ZC_MV1;


####创建不同刷新模式的实时物化####
##COMPLETE##
create materialized view ZC_MV2 REFRESH COMPLETE ON DEMAND enable on query computation AS
select ZT1.c1 as t1_c1,count(*) as cnt
from ZC_T1 ZT1
group by ZT1.c1;

INSERT INTO ZC_T1 VALUES(2,2,2,2);
#call DBMS_MVIEW.REFRESH('ZC_MV2');
#EXEC DBMS_STATS.gather_table_stats(user, 'zc_t1');
#EXEC DBMS_STATS.gather_table_stats(USER, 'zc_mv2');
#SELECT /*+fresh_mv*/* FROM ZC_MV2;

SELECT * FROM ZC_T1;

SELECT * FROM ZC_MV2;

SELECT /*+fresh_mv*/* FROM ZC_MV2;

##FORCE##
create materialized view ZC_MV3 REFRESH FORCE ON DEMAND enable on query computation AS
select ZT1.c1 as t1_c1,count(*) as cnt
from ZC_T1 ZT1
group by ZT1.c1;

INSERT INTO ZC_T1 VALUES(3,3,3,3);
#call DBMS_MVIEW.REFRESH('ZC_MV3');

SELECT * FROM ZC_T1;

SELECT * FROM ZC_MV3;

SELECT /*+fresh_mv*/* FROM ZC_MV3;

##NEVER REFRESH##
create materialized view ZC_MV4 NEVER REFRESH enable on query computation AS
select ZT1.c1 as t1_c1,count(*) as cnt
from ZC_T1 ZT1
group by ZT1.c1;

INSERT INTO ZC_T1 VALUES(4,4,4,4);
#call DBMS_MVIEW.REFRESH('ZC_MV4');
#EXEC DBMS_STATS.gather_table_stats(user, 'zc_t1');
#EXEC DBMS_STATS.gather_table_stats(USER, 'zc_mv4');
#SELECT /*+fresh_mv*/* FROM ZC_MV4;

SELECT * FROM ZC_T1;

SELECT * FROM ZC_MV4;

SELECT /*+fresh_mv*/* FROM ZC_MV4;

##指定时间##
create materialized view ZC_MV5 REFRESH FAST NEXT NOW() + INTERVAL 1 DAY enable on query computation AS
select ZT1.c1 as t1_c1,count(*) as cnt
from ZC_T1 ZT1
group by ZT1.c1;

INSERT INTO ZC_T1 VALUES(5,5,5,5);
#call DBMS_MVIEW.REFRESH('ZC_MV5');

SELECT * FROM ZC_T1;

SELECT * FROM ZC_MV5;

SELECT /*+fresh_mv*/* FROM ZC_MV5;


