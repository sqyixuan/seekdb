result_format: 4
PURGE RECYCLEBIN;
##clean PLAN
alter system flush plan cache global;
####开启物化改写(检查关，非实时物化开)
SET QUERY_REWRITE_ENABLED = 'FORCE';
set QUERY_REWRITE_INTEGRITY = stale_tolerated;
DROP MATERIALIZED VIEW LOG ON col_info;
DROP MATERIALIZED VIEW LOG ON col_item;
DROP table col_item;
DROP table col_info;
CREATE table col_info(c1 int,c2 int,PRIMARY KEY(c2)) PARTITION by hash(c2) partitions 100;
CREATE TABLE col_item(c1 int PRIMARY KEY,c2 int,c3 VARCHAR(1000),FOREIGN KEY(C1) REFERENCES col_info(C2)) PARTITION by hash(c1) partitions 16;
CREATE MATERIALIZED VIEW LOG ON col_info parallel 1 WITH PRIMARY KEY,ROWID,SEQUENCE(c1)INCLUDING NEW VALUES;
CREATE MATERIALIZED VIEW LOG ON col_item parallel 2 WITH PRIMARY KEY,ROWID,SEQUENCE(c2,c3) INCLUDING NEW VALUES;
##先添加数据
INSERT INTO col_info SELECT 1,1 from dual;
INSERT INTO col_info SELECT c1+1,c2+1 from col_info;
INSERT INTO col_info SELECT c1+2,c2+2 from col_info;
INSERT INTO col_info SELECT c1+4,c2+4 from col_info;
INSERT INTO col_info SELECT c1+8,c2+8 from col_info;
INSERT INTO col_item VALUES(1,1,'A');
INSERT INTO col_item SELECT C1+1,C2+1,C3 FROM col_item;
INSERT INTO col_item SELECT C1+2,C2+2,C3 FROM col_item;
INSERT INTO col_item SELECT C1+4,C2+4,C3 FROM col_item;
INSERT INTO col_item SELECT C1+8,C2+8,C3 FROM col_item;
DROP materialized view ZC_RTMV1;
DROP materialized view ZC_RTMV2;
##RTMV
create materialized view ZC_RTMV1 REFRESH FORCE ON DEMAND enable on query computation enable query rewrite AS
select zt1.C1 AS c1,zt2.C1 as c2,zt1.c2 AS c3,zt2.c2 AS c4,zt2.c3 AS c5
from col_info ZT1 ,col_item ZT2 WHERE zt1.C1 = zt2.C2;
create materialized view ZC_RTMV2 REFRESH FORCE ON DEMAND enable on query computation enable query rewrite AS
select ZT1.c1 as c1,ZT1.C2 AS C2,ZT2.C1 AS C3 ,zt2.c2 AS C4,zt2.c3 as c5
from col_item ZT2 inner join col_info zt1
ON zt1.c2 = zt2.c1;
##建好物化视图后再次添加数据
INSERT INTO col_info SELECT c1+16,c2+16 from col_info;
INSERT INTO col_info SELECT c1+32,c2+32 from col_info WHERE C1 IS NOT NULL;
INSERT INTO col_item SELECT C1+16,C2+16,C3 FROM col_item WHERE C3 IS NOT NULL;
UPDATE col_info SET C1 = 999 WHERE C2 = 1;
UPDATE col_item SET C3 = 'N' WHERE C2 = 2;
DELETE FROM col_info WHERE C1 BETWEEN 55 AND 56;
DELETE FROM col_item WHERE C3 LIKE '%N%';
####收集统计信息
CALL dbms_stats.gather_table_stats('test', 'col_info');
CALL dbms_stats.gather_table_stats('test', 'col_item');
CALL dbms_stats.gather_table_stats('test', 'ZC_RTMV1');
CALL dbms_stats.gather_table_stats('test', 'ZC_RTMV2');
####SELECT
##re
SELECT * FROM col_info ZT1 ,col_item ZT2 WHERE zt1.C1 = zt2.C2 ORDER by 1;
+------+----+----+------+------+
| C1   | C2 | C1 | C2   | C3   |
+------+----+----+------+------+
|    1 |  1 |  1 |    1 | A    |
|    2 |  2 |  2 |    2 | A    |
|    3 |  3 |  3 |    3 | A    |
|    4 |  4 |  4 |    4 | A    |
|    5 |  5 |  5 |    5 | A    |
|    6 |  6 |  6 |    6 | A    |
|    7 |  7 |  7 |    7 | A    |
|    8 |  8 |  8 |    8 | A    |
|    9 |  9 |  9 |    9 | A    |
|   10 | 10 | 10 |   10 | A    |
|   11 | 11 | 11 |   11 | A    |
|   12 | 12 | 12 |   12 | A    |
|   13 | 13 | 13 |   13 | A    |
|   14 | 14 | 14 |   14 | A    |
|   15 | 15 | 15 |   15 | A    |
|   16 | 16 | 16 |   16 | A    |
+------+----+----+------+------+
explain basic SELECT * FROM col_info ZT1 ,col_item ZT2 WHERE zt1.C1 = zt2.C2 ORDER BY 1;
