-------------------------------------
  0 - output([ZT1.C1], [ZT1.C2], [ZT2.C1], [ZT2.C2], [ZT2.C3]), filter(nil), rowset=256
      sort_keys([ZT1.C1, ASC])
  1 - output([ZT1.C1], [ZT1.C2], [ZT2.C1], [ZT2.C2], [ZT2.C3]), filter(nil), rowset=256
      equal_conds([ZT1.C1 = ZT2.C2]), other_conds(nil)
  2 - output([ZT2.C1], [ZT2.C2], [ZT2.C3]), filter(nil), rowset=256
