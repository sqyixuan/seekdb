      access([ZT2.C1], [ZT2.C2], [ZT2.C3]), partitions(p[0-15])
      is_index_back=false, is_global_index=false, 
      range_key([ZT2.C1]), range(MIN ; MAX)always true
  6 - output([ZT1.C1], [ZT1.C2]), filter(nil), rowset=256
  7 - output([ZT1.C1], [ZT1.C2]), filter(nil), rowset=256
      dop=1
  8 - output([ZT1.C2], [ZT1.C1]), filter(nil), rowset=256
      force partition granule
  9 - output([ZT1.C2], [ZT1.C1]), filter(nil), rowset=256
      access([ZT1.C2], [ZT1.C1]), partitions(p[0-99])
      is_index_back=false, is_global_index=false, 
      range_key([ZT1.C2]), range(MIN ; MAX)always true
