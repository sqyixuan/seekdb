####根据不同的mlog创建rtmv####
##WITH SEQUENCE##
DROP MATERIALIZED VIEW LOG ON ZC_T1;
CREATE MATERIALIZED VIEW LOG ON ZC_T1 parallel 2 WITH SEQUENCE(c1,c2,c3) INCLUDING NEW VALUES;
DESC mlog$_zc_t1;
+------------+------------+------+-----+---------+-------+
| Field      | Type       | Null | Key | Default | Extra |
+------------+------------+------+-----+---------+-------+
| DMLTYPE$$  | varchar(1) | YES  |     | NULL    |       |
| OLD_NEW$$  | varchar(1) | YES  |     | NULL    |       |
| SEQUENCE$$ | bigint(20) | NO   | PRI | NULL    |       |
| c1         | int(11)    | YES  |     | NULL    |       |
| c2         | int(11)    | YES  |     | NULL    |       |
| c3         | int(11)    | YES  |     | NULL    |       |
| pk         | int(11)    | NO   | PRI | NULL    |       |
+------------+------------+------+-----+---------+-------+
INSERT INTO ZC_T1 VALUES(1,1,1,1);
SELECT * FROM ZC_T1;
+----+------+------+------+
| pk | c1   | c2   | c3   |
+----+------+------+------+
|  1 |    1 |    1 |    1 |
+----+------+------+------+
SELECT /*+fresh_mv*/* FROM ZC_MV1;
