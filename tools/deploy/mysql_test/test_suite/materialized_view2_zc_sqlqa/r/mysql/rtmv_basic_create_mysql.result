result_format: 4
PURGE RECYCLEBIN;
DROP MATERIALIZED VIEW LOG ON ZC_T1;
DROP TABLE ZC_T1;
DROP TABLE ZC_T2;
CREATE TABLE ZC_T1(pk int primary key, c1 int, c2 int, c3 int);
CREATE TABLE ZC_T2(c1 int, c2 int, c3 int);
CREATE MATERIALIZED VIEW LOG ON ZC_T1 parallel 2 WITH PRIMARY KEY,ROWID,SEQUENCE(c1,c2,c3) INCLUDING NEW VALUES;
create materialized view ZC_MV1 REFRESH FAST ON DEMAND enable on query computation AS
select ZT1.c1 as t1_c1,count(*) as cnt
from ZC_T1 ZT1
group by ZT1.c1;
INSERT INTO ZC_T1 VALUES(1,1,1,1);
SELECT * FROM ZC_T1;
+----+------+------+------+
| pk | c1   | c2   | c3   |
+----+------+------+------+
|  1 |    1 |    1 |    1 |
+----+------+------+------+
SELECT * FROM ZC_MV1;
+-------+------+
| t1_c1 | cnt  |
+-------+------+
|     1 |    1 |
+-------+------+
SELECT /*+fresh_mv*/* FROM ZC_MV1;
+-------+------+
| t1_c1 | cnt  |
+-------+------+
|     1 |    1 |
+-------+------+
####创建不同刷新模式的实时物化####
##COMPLETE##
create materialized view ZC_MV2 REFRESH COMPLETE ON DEMAND enable on query computation AS
select ZT1.c1 as t1_c1,count(*) as cnt
from ZC_T1 ZT1
group by ZT1.c1;
INSERT INTO ZC_T1 VALUES(2,2,2,2);
SELECT * FROM ZC_T1;
+----+------+------+------+
| pk | c1   | c2   | c3   |
+----+------+------+------+
|  1 |    1 |    1 |    1 |
|  2 |    2 |    2 |    2 |
+----+------+------+------+
SELECT * FROM ZC_MV2;
+-------+------+
| t1_c1 | cnt  |
+-------+------+
|     1 |    1 |
|     2 |    1 |
+-------+------+
SELECT /*+fresh_mv*/* FROM ZC_MV2;
+-------+------+
| t1_c1 | cnt  |
+-------+------+
|     1 |    1 |
|     2 |    1 |
+-------+------+
##FORCE##
create materialized view ZC_MV3 REFRESH FORCE ON DEMAND enable on query computation AS
select ZT1.c1 as t1_c1,count(*) as cnt
from ZC_T1 ZT1
group by ZT1.c1;
INSERT INTO ZC_T1 VALUES(3,3,3,3);
