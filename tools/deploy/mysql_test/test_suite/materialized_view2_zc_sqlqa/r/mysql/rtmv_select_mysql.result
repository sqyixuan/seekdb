UPDATE zc_t1 SET pk = 83, c1 = 54, c2 = 39, c3 = 22 WHERE pk = (SELECT MAX(pk) FROM zc_t1);
DELETE FROM zc_t1 WHERE pk BETWEEN 10 AND 20;
