| c1   | c2   | C3   | c4   | c1   | c2   | C3   | c4   |
+------+------+------+------+------+------+------+------+
+------+------+------+------+------+------+------+------+
SELECT * FROM (SELECT A.C1,B.C2,A.C3,B.C4 FROM ZC_MV3 A LEFT JOIN ZC_MV11 B ON A.C3 >= B.C3 WHERE A.C2 IS NULL OR A.C1 NOT IN (0,-0.999999999999,0.1)) A INNER JOIN (SELECT * FROM ZC_MV10 WHERE C2 BETWEEN 0.9999999999 AND 0) B ON A.C4 != B.C4 WHERE B.C3 NOT IN (SELECT C4 FROM ZC_MV9 WHERE C3 LIKE 'a') AND EXISTS (SELECT C1 FROM ZC_MV5 WHERE C1 NOT IN (0.9999999999,-0.999999999999,1));
+------+------+------+------+------+------+------+------+
| C1   | C2   | C3   | C4   | c1   | c2   | c3   | c4   |
+------+------+------+------+------+------+------+------+
+------+------+------+------+------+------+------+------+
SELECT  * FROM ZC_MV1 A INNER JOIN ZC_MV8 B ON A.C4 >= B.C3 WHERE NOT EXISTS (SELECT C2 FROM ZC_MV9 WHERE C4 IS NOT NULL) OR A.C4 != ALL (SELECT C4 FROM ZC_MV7 WHERE B.C1 = C3);
+------+------+------+------+------+------+------+------+
| c1   | c2   | C3   | c4   | c1   | c2   | C3   | c4   |
