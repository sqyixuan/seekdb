####join&subquery####
SELECT  * FROM ZC_MV3 A RIGHT JOIN ZC_MV6 B ON A.C1 >= B.C2 WHERE A.C3 <= SOME (SELECT C3 FROM ZC_MV9 WHERE A.C1 = C1) OR EXISTS (SELECT C1 FROM ZC_MV12 WHERE C2 BETWEEN 0.9999999999 AND 0.9999999999);
