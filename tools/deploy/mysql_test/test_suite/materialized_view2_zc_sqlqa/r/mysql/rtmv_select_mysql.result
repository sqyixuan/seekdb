result_format: 4
PURGE RECYCLEBIN;
##########不同select语句查询不同类型的rtmv##########
####构建rtmv####
##rtmv1
CREATE TABLE ZC_T1(pk int primary key, c1 int, c2 int, c3 int);
CREATE MATERIALIZED VIEW LOG ON ZC_T1 parallel 2 WITH PRIMARY KEY,ROWID,SEQUENCE(c1,c2,c3) INCLUDING NEW VALUES;
create materialized view ZC_MV1 REFRESH FAST ON DEMAND enable on query computation AS
select ZT1.c1 as c1,ZT1.PK AS c2,ZT1.C2 AS C3,count(*) as c4
from ZC_T1 ZT1
group by ZT1.c1,ZT1.C2,ZT1.PK;
INSERT INTO ZC_T1 VALUES(1,1,1,1);
##rtmv2
CREATE TABLE ZC_T2(pk int , c1 int, c2 int, c3 int);
CREATE INDEX inzt2 ON zc_t2(pk,c1);
CREATE MATERIALIZED VIEW LOG ON ZC_T2 parallel 2 WITH ROWID,SEQUENCE(pk,c1,c2,c3) INCLUDING NEW VALUES;
create materialized view ZC_MV2 REFRESH FAST ON DEMAND enable on query computation AS
select ZT2.c1 as c1,ZT2.PK AS c2,ZT2.C2 AS C3,count(*) as c4
from ZC_T2 ZT2
group by ZT2.c1,ZT2.C2,ZT2.PK;
INSERT INTO ZC_T2 VALUES(2,2,2,2);
##rtmv3
CREATE TABLE ZC_T3(pk int UNIQUE, c1 int, c2 int, c3 int);
CREATE MATERIALIZED VIEW LOG ON ZC_T3 parallel 2 WITH ROWID,SEQUENCE(pk,c1,c2,c3) INCLUDING NEW VALUES;
create materialized view ZC_MV3 REFRESH FAST ON DEMAND enable on query computation AS
select ZT3.c1 as c1,ZT3.PK AS c2,ZT3.C2 AS C3,count(*) as c4
from ZC_T3 ZT3
group by ZT3.c1,ZT3.C2,ZT3.PK;
INSERT INTO ZC_T3 VALUES(3,3,3,3);
##rtmv4
create materialized view ZC_MV4 REFRESH FAST ON DEMAND enable on query computation AS
select COUNT(ZT1.c1) as c1,COUNT(ZT1.PK) AS c2,COUNT(ZT1.C2) AS C3,count(*) as c4
from ZC_T1 ZT1
WHERE zt1.pk < 2;
##rtmv5
create materialized view ZC_MV5 REFRESH FAST ON DEMAND enable on query computation AS
select SUM(pk) AS c1,COUNT(pk) as c2,SUM(c1) AS c3,COUNT(c1) as c4,SUM(c2) AS c5,COUNT(c2) as c6,COUNT(c3) as c7
from ZC_T1 ZT1
WHERE zt1.pk <= 50 AND zt1.c1 >= -50 ;
##rtmv6
create materialized view ZC_MV6 REFRESH FAST ON DEMAND enable on query computation AS
select COUNT(ZT1.c1) as c1,COUNT(ZT1.PK) AS c2,COUNT(ZT1.C2) AS C3,count(*) as c4
from ZC_T1 ZT1
WHERE zt1.pk IS NULL AND zt1.c1 IS NOT NULL OR zt1.pk < 2 AND zt1.pk = 0 OR zt1.pk != 1 AND zt1.pk <> 0 OR zt1.pk <= 50 AND zt1.c1 >= -50 AND zt1.pk IN(10,20,30,40,50) OR zt1.c1 NOT IN(10,20,30,40,50) OR zt1.pk BETWEEN -50 AND 50 OR zt1.c1 NOT BETWEEN -50 AND 50 AND zt1.pk LIKE '%5%' OR zt1.c1 NOT LIKE '%5%' OR zt1.pk IS NULL OR zt1.c1 IS NOT NULL ;
##rtmv7
create materialized view ZC_MV7 REFRESH FAST ON DEMAND enable on query computation AS
select ROUND(ZT1.c1) as c1,ZT1.PK AS c2,ZT1.C2 AS C3,count(*) as c4
from ZC_T1 ZT1
group by ROUND(ZT1.c1),ZT1.C2,ZT1.PK;
##rtmv8
create materialized view ZC_MV8 REFRESH FAST ON DEMAND enable on query computation AS
select ROUND(ZT1.c1) as c1,LENGTH(ZT1.PK) AS c2,ABS(ZT1.C2) AS C3,count(*) as c4
from ZC_T1 ZT1
group by ROUND(ZT1.c1),ABS(ZT1.C2),LENGTH(ZT1.PK) ;
##rtmv9(mjv自连接场景的rtmv)
create materialized view ZC_MV9 REFRESH FORCE ON DEMAND enable on query computation AS
select zt1.pk AS c1,zt2.pk as c2,zt1.c1 AS c3,zt2.c1 AS c4
from ZC_T1 ZT1 ,ZC_T1 ZT2 WHERE zt1.pk = zt2.pk;
##rtmv10(mjv场景的rtmv)
CREATE TABLE ZC_T5(pk int PRIMARY KEY, c1 VARCHAR(10));
CREATE MATERIALIZED VIEW LOG ON ZC_T5 parallel 2 WITH ROWID,SEQUENCE(c1) INCLUDING NEW VALUES;
create materialized view ZC_MV10 REFRESH FORCE ON DEMAND enable on query computation AS
select zt1.pk AS c1,zt2.pk as c2,zt2.c1 as c3,zt1.c1 as c4
from ZC_T1 ZT1 inner join ZC_T5 ZT2 ON zt1.pk = zt2.pk;
INSERT INTO ZC_T5 VALUES(0,NULL);
INSERT INTO ZC_T5 VALUES(1,'a');
INSERT INTO ZC_T5 VALUES(25,'b');
##rtmv11(指定主键的rtmv)
create materialized view ZC_MV11(PRIMARY KEY(c2)) REFRESH FAST ON DEMAND enable on query computation AS
select ZT1.c1 as c1,ZT1.PK AS c2,ZT1.C2 AS C3,count(*) as c4
from ZC_T1 ZT1
group by ZT1.c1,ZT1.C2,ZT1.PK;
##rtmv12(带分区的rtmv)
create materialized view ZC_MV12 (PRIMARY KEY(c3))
PARTITION BY RANGE(C3) subpartition by hash(C3)subpartitions 2 (PARTITION P0 VALUES LESS THAN (10),PARTITION P1 VALUES LESS THAN(MAXVALUE))
REFRESH FAST ON DEMAND enable on query computation AS
select ZT1.c1 as c1,ZT1.C2 AS C2,ZT1.PK AS C3,count(*) as C4
from ZC_T1 ZT1
group by ZT1.c1,ZT1.C2,ZT1.PK;
##rtmv13(根据分区表创建的带分区带主键带索引mjv场景的rtmv)
CREATE TABLE ZC_T6(pk int PRIMARY KEY, c1 int, c2 int, c3 int) PARTITION by RANGE(PK) subpartition by hash(PK) subpartitions 2
(PARTITION p0 values less THAN (10),
 PARTITION p1 values less THAN (50),
 PARTITION p2 values less THAN (MAXVALUE));
CREATE MATERIALIZED VIEW LOG ON ZC_T6 parallel 2 WITH PRIMARY KEY,ROWID,SEQUENCE(c1,c2,c3) INCLUDING NEW VALUES;
create materialized view ZC_MV13 (PRIMARY KEY(c2))
PARTITION BY RANGE(C2) subpartition by hash(C2)subpartitions 2 (PARTITION P0 VALUES LESS THAN (10),PARTITION P1 VALUES LESS THAN(MAXVALUE))
REFRESH FAST ON DEMAND enable on query computation AS
select zt1.pk AS c1,zt2.pk as c2,zt2.c1 as c3,zt1.c1 as c4
from ZC_T6 ZT1 inner join ZC_T6 ZT2 ON zt1.pk = zt2.pk;
CREATE INDEX IN_RTMV13 ON ZC_MV13(C1,C2);
INSERT INTO ZC_T6 VALUES (0,NULL,NULL,NULL);
INSERT INTO ZC_T6 VALUES (1,NULL,3,4);
