SELECT  c4,ROUND(MIN(C2)) FROM ZC_MV10 GROUP BY c4 HAVING c4 BETWEEN -99999999 AND -1;
+------+----------------+
| c4   | ROUND(MIN(C2)) |
+------+----------------+
+------+----------------+
SELECT  c4,ROUND(COUNT(C3)) FROM ZC_MV7 WHERE C3 LIKE 'null' GROUP BY c4 HAVING c4 LIKE '%5%';
+------+------------------+
| c4   | ROUND(COUNT(C3)) |
+------+------------------+
+------+------------------+
SELECT DISTINCT c4,ROUND(AVG(C2)) FROM ZC_MV7 WHERE C4 NOT LIKE 'null' GROUP BY c4 HAVING c4 <= -1;
+------+----------------+
| c4   | ROUND(AVG(C2)) |
+------+----------------+
+------+----------------+
SELECT UNIQUE c4,ROUND(MIN(C3)) FROM ZC_MV7 GROUP BY c4 HAVING c4 > 0.1;
+------+----------------+
| c4   | ROUND(MIN(C3)) |
+------+----------------+
|    1 |            -32 |
+------+----------------+
SELECT DISTINCT c2,ROUND(MAX(C4)) FROM ZC_MV4 GROUP BY c2 HAVING c2 = 0.9999999999;
+------+----------------+
| c2   | ROUND(MAX(C4)) |
+------+----------------+
+------+----------------+
SELECT ALL c1,ROUND(MAX(C1)) FROM ZC_MV11 GROUP BY c1 HAVING c1 IS NOT NULL;
+------+----------------+
| c1   | ROUND(MAX(C1)) |
+------+----------------+
|    1 |              1 |
|   27 |             27 |
|   50 |             50 |
|   54 |             54 |
|   90 |             90 |
|   92 |             92 |
|  -29 |            -29 |
|  -32 |            -32 |
+------+----------------+
SELECT UNIQUE c2,ROUND(COUNT(C1)) FROM ZC_MV6 GROUP BY c2 HAVING c2 NOT LIKE 'a';
+------+------------------+
| c2   | ROUND(COUNT(C1)) |
+------+------------------+
|   10 |                1 |
+------+------------------+
SELECT ALL c2,ROUND(COUNT(C3)) FROM ZC_MV10 GROUP BY c2 HAVING c2 <= 0.9999999999;
+------+------------------+
| c2   | ROUND(COUNT(C3)) |
+------+------------------+
|    0 |                0 |
+------+------------------+
SELECT  c4,ROUND(MAX(C2)) FROM ZC_MV8 GROUP BY c4 HAVING c4 NOT LIKE 'null';
+------+----------------+
| c4   | ROUND(MAX(C2)) |
+------+----------------+
|    1 |              3 |
+------+----------------+
SELECT ALL c1,ROUND(AVG(C1)) FROM ZC_MV7 GROUP BY c1 HAVING c1 >= -0.999999999999;
+------+----------------+
| c1   | ROUND(AVG(C1)) |
+------+----------------+
|    1 |              1 |
|   27 |             27 |
|   50 |             50 |
|   54 |             54 |
|   90 |             90 |
|   92 |             92 |
+------+----------------+
SELECT  c1,ROUND(COUNT(C4)) FROM ZC_MV2 WHERE C2 NOT LIKE '%5%' GROUP BY c1 HAVING c1 IS NULL;
+------+------------------+
| c1   | ROUND(COUNT(C4)) |
+------+------------------+
+------+------------------+
SELECT  c4,ROUND(MAX(C2)) FROM ZC_MV13 GROUP BY c4 HAVING c4 IS NULL;
+------+----------------+
| c4   | ROUND(MAX(C2)) |
+------+----------------+
| NULL |              1 |
