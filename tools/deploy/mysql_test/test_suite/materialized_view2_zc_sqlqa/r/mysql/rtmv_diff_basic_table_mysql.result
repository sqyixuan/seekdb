DELETE from ZC_t1;
DROP materialized view ZC_MV1;
create materialized view ZC_MV1 REFRESH FAST ON DEMAND enable on query computation AS
select DISTINCT zt1.pk AS PK,zt1.c1 as c1,count(*) as cnt,count(zt1.c1) as cnt1,SUM(ZT1.c1) as f1,avg(ZT1.c1) AS f2,STDDEV(ZT1.C1) AS f3,SUM(ZT1.C1*ZT1.C1) AS f4,VARIANCE(zt1.c1) AS f5
from ZC_T1 ZT1
group by ZT1.c1,ZT1.pk;
