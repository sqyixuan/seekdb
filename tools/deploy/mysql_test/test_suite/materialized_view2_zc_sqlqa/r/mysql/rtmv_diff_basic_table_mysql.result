##SELECT item##
DELETE from ZC_t1;
DROP materialized view ZC_MV1;
create materialized view ZC_MV1 REFRESH FAST ON DEMAND enable on query computation AS
select DISTINCT zt1.pk AS c1,zt2.pk as c2,ROUND(ZT1.c1) as f1,LENGTH(ZT2.c1) AS f2,ABS(ZT2.C2) AS f3
from ZC_T1 ZT1,ZC_T1 ZT2
WHERE zt1.pk IS NULL AND zt2.pk IS NOT NULL OR zt1.c1 < 2 AND zt2.c1 = 0 OR zt1.c2 != 1 AND zt2.c2 <> 0 OR zt1.c3 <= 50 AND zt2.c3 >= -50 AND zt2.c1 IN(10,20,30,40,50) OR zt2.c2 NOT IN(10,20,30,40,50) OR zt1.pk BETWEEN -50 AND 50 OR zt2.c1 NOT BETWEEN -50 AND 50 AND zt2.pk LIKE '%5%' OR zt1.c1 NOT LIKE '%5%' OR zt1.pk IS NULL OR zt2.c1 IS NOT NULL;
