####分区表####
CREATE TABLE ZC_T6(pk int PRIMARY KEY, c1 int, c2 int, c3 int) PARTITION by RANGE(pk)
(PARTITION p0 VALUES less THAN (10),
 PARTITION p1 VALUES less THAN (20),
 PARTITION p2 VALUES less THAN (30),
 PARTITION p3 VALUES less THAN (MAXVALUE));
CREATE MATERIALIZED VIEW LOG ON ZC_T6 parallel 2 WITH PRIMARY KEY,ROWID,SEQUENCE(c1,c2,c3) INCLUDING NEW VALUES;
create materialized view ZC_MV6 REFRESH FAST ON DEMAND enable on query computation AS
select ZT6.c1 as c1,ZT6.PK AS PK,ZT6.C2 AS C2,count(*) as cnt
from ZC_T6 ZT6
group by ZT6.c1,ZT6.C2,ZT6.PK;
INSERT INTO ZC_T6 VALUES(6,6,6,6);
INSERT INTO ZC_T6 VALUES(66,66,66,66);
SELECT * FROM ZC_T6;
+----+------+------+------+
| pk | c1   | c2   | c3   |
+----+------+------+------+
|  6 |    6 |    6 |    6 |
| 66 |   66 |   66 |   66 |
+----+------+------+------+
SELECT * FROM ZC_MV6;
+------+------+------+------+
| c1   | PK   | C2   | cnt  |
+------+------+------+------+
|    6 |    6 |    6 |    1 |
|   66 |   66 |   66 |    1 |
+------+------+------+------+
SELECT /*+fresh_mv*/* FROM ZC_MV6;
+------+------+------+------+
| c1   | PK   | C2   | cnt  |
+------+------+------+------+
|    6 |    6 |    6 |    1 |
|   66 |   66 |   66 |    1 |
+------+------+------+------+
