select ZT1.c1 as c1,ZT1.PK AS PK,ZT1.C2 AS C2,count(*) as cnt
from (SELECT c1,c2,pk from ZC_T1) ZT1
group by ZT1.c1,ZT1.C2,ZT1.PK;
