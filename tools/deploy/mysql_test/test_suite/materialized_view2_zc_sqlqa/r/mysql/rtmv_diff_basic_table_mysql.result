####REFRESH####
create materialized view ZC_MV1 REFRESH FORCE ON DEMAND enable on query computation AS
select ZT1.c1 as c1,ZT1.PK AS PK,ZT1.C2 AS C2,count(*) as cnt
from ZC_T1 ZT1
group by ZT1.c1,ZT1.C2,ZT1.PK;
INSERT INTO ZC_T1 VALUES(3,3,3,3);
call DBMS_MVIEW.REFRESH('ZC_MV1');
SELECT * FROM ZC_T1;
