drop table if exists caitest;
drop table if exists ctest;
drop table if exists ctest1;
drop table if exists ctest3;
create table caitest (v_test varchar(200));
insert into caitest values('1');
select asin(v_test/100) from caitest;
asin(v_test/100)
0.010000166674167114
#参数个数
select asin() from dual;
ERROR 42000: Incorrect parameter count in the call to native function 'asin'
select asin('-1') from  dual;
asin('-1')
-1.5707963267948966
select asin('-1',0) from  dual;
ERROR 42000: Incorrect parameter count in the call to native function 'asin'
select asin(power(-0.325415,3)) from  dual;
asin(power(-0.325415,3))
-0.03446661980185058
#验证非数值参数
select asin('a1') from  dual;
asin('a1')
0
Warnings:
Warning	1292	Truncated incorrect DOUBLE value: 'a1'
#验证各参数类型的边界值-1,1
select asin((1e-30)+1) from dual;
asin((1e-30)+1)
1.5707963267948966
select asin(-(1e-30)-1) from dual;
asin(-(1e-30)-1)
-1.5707963267948966
select asin(20) from dual;
asin(20)
NULL
select asin(-20) from dual;
asin(-20)
NULL
select asin(1) from dual;
asin(1)
1.5707963267948966
select asin(-1) from dual;
asin(-1)
-1.5707963267948966
#varchar类型
drop table caitest;
create table caitest(v_test varchar(200)) ;
insert into caitest values('1');
select asin(v_test/100) from caitest;
asin(v_test/100)
0.010000166674167114
#date/interval类型
select asin('20191001') from  dual;
asin('20191001')
NULL
select asin('20191001'/2E14-1) from  dual;
asin('20191001'/2E14-1)
-1.5703469828136951
select asin('2019-10-01') from  dual;
asin('2019-10-01')
NULL
Warnings:
Warning	1292	Truncated incorrect DOUBLE value: '2019-10-01'
select asin('2019:10:01') from  dual;
asin('2019:10:01')
NULL
Warnings:
Warning	1292	Truncated incorrect DOUBLE value: '2019:10:01'
select asin('20191001030204') from  dual;
asin('20191001030204')
NULL
select asin('20191001030204'/2E14-1) from  dual;
asin('20191001030204'/2E14-1)
-1.1175835144653468
select asin('2019-10-01 03:02:05') from  dual;
asin('2019-10-01 03:02:05')
NULL
Warnings:
Warning	1292	Truncated incorrect DOUBLE value: '2019-10-01 03:02:05'
#float类型
drop table caitest;
create table caitest(v_test float) ;
insert into caitest values(0.132);
insert into caitest values(-0.132);
insert into caitest values(0);
select asin(v_test/100) from caitest;
asin(v_test/100)
0.0013200003761757368
-0.0013200003761757368
0
select asin(v_test/100)-asin(v_test/100) from caitest;
asin(v_test/100)-asin(v_test/100)
0
0
0
#double类型,运算
drop table caitest;
create  table   caitest(v_test double) ;
insert into caitest values(0.132);
insert into caitest values(-0.132);
insert into caitest values(0);
select asin(v_test/100) from caitest;
asin(v_test/100)
0.0013200003833283005
-0.0013200003833283005
0
select (asin(v_test/100)-3*asin(v_test/100))/10 from caitest;
(asin(v_test/100)-3*asin(v_test/100))/10
-0.0002640000766656601
0.0002640000766656601
0
#float,double,number隐式转换
create table ctest1(v_test float,v_test2 double);
insert into ctest1 values(0.9451458745213652145777777777777777777777777777777,-0.663524120032055485112);
select asin(v_test/100), asin(v_test2) from ctest1;
asin(v_test/100)	asin(v_test2)
0.009451599176358332	-0.7255193949683517
insert into ctest1 values(0.9451458745213652145777777777777777777777777777777,-0.663524120032055485112);
select asin(v_test/100), asin(v_test2) from ctest1;
asin(v_test/100)	asin(v_test2)
0.009451599176358332	-0.7255193949683517
0.009451599176358332	-0.7255193949683517
insert into ctest1 values(0.9451458745213652145777777777777777777777777777777,-0.663524120032055485112d);
ERROR 42000: You have an error in your SQL syntax; check the manual that corresponds to your OceanBase version for the right syntax to use near 'd)' at line 1
select asin(v_test/100),asin(v_test2) from ctest1;
asin(v_test/100)	asin(v_test2)
0.009451599176358332	-0.7255193949683517
0.009451599176358332	-0.7255193949683517
#float,double,number边界值
select asin(-1.0e-130) from dual;
asin(-1.0e-130)
-1e-130
#oracle及ob超边界值时均显示为0
select asin(-1.0e-131) from dual;
asin(-1.0e-131)
-1e-131
#varchar等类型录入其他类型值
create table ctest3(v_test varchar(200),v_test1 char(200));
insert into ctest3 values(0.9451458745213652145777777777777777777777777777777,-0.663524120032055485112);
select asin(v_test/100), asin(v_test1) from ctest3;
asin(v_test/100)	asin(v_test1)
0.009451599467452906	-0.7255193949683517
drop table ctest3;
#函数嵌套(sum,modd等)
SELECT asin(MOD(.011211,4)) FROM DUAL;
asin(MOD(.011211,4))
0.01121123485854808
SELECT asin(MOD(-0.11,11)) FROM DUAL;
asin(MOD(-0.11,11))
-0.11022304998774664
SELECT asin(round(-0.11,11)) FROM DUAL;
asin(round(-0.11,11))
-0.11022304998774664
SELECT asin(round(0.11,3)) FROM DUAL;
asin(round(0.11,3))
0.11022304998774664
SELECT sum(asin(0.111)-100) FROM DUAL;
sum(asin(0.111)-100)
-99.88877078835938
SELECT MOD((sum(asin(0.2111)-100)),50) FROM DUAL;
MOD((sum(asin(0.2111)-100)),50)
-49.7872998161279
SELECT asin(1/POWER(10,20)) FROM DUAL;
asin(1/POWER(10,20))
1e-20
SELECT asin(-1/POWER(10,20)) FROM DUAL;
asin(-1/POWER(10,20))
-1e-20
#静态sql(函数嵌套，dml等)
drop table caitest;
create table caitest(v_test varchar(30),v_test1 varchar(30));
insert into caitest values('-0.202','0');
select asin(v_test/100),asin(v_test1)  from caitest;
asin(v_test/100)	asin(v_test1)
-0.002020001373737189	0
insert into caitest values('-0.202','0.22');
select asin(v_test/100),asin(v_test1)  from caitest;
asin(v_test/100)	asin(v_test1)
-0.002020001373737189	0
-0.002020001373737189	0.22181447049679442
#存在非数字型参数
insert into caitest values('-0.202','aa12');
select asin(v_test/100),asin(v_test1)  from caitest;
asin(v_test/100)	asin(v_test1)
-0.002020001373737189	0
-0.002020001373737189	0.22181447049679442
-0.002020001373737189	0
Warnings:
Warning	1292	Truncated incorrect DOUBLE value: 'aa12'
delete  from caitest where v_test1='aa12';
#group by having
insert into caitest values('-0.202','0');
insert into caitest values('-0.202','0.22');
select v_test,v_test1,asin(v_test1) from caitest group by v_test,v_test1 having asin(v_test1)>=0;
v_test	v_test1	asin(v_test1)
-0.202	0	0
-0.202	0.22	0.22181447049679442
insert into caitest values('-0.202','0');
insert into caitest values('-0.202','aa12');
select v_test,v_test1,asin(v_test1) from caitest group by v_test,v_test1 having asin(v_test1)>=0;
v_test	v_test1	asin(v_test1)
-0.202	0	0
-0.202	0.22	0.22181447049679442
-0.202	aa12	0
Warnings:
Warning	1292	Truncated incorrect DOUBLE value: 'aa12'
Warning	1292	Truncated incorrect DOUBLE value: 'aa12'
delete from caitest;
insert into caitest values('-0.202','0');
insert into caitest values('-0.202','0.22');
insert into caitest values('0.202','-0.22');
insert into caitest values('0.202','0.22');
#order by
select v_test1,asin(v_test/100) from caitest order by asin(v_test/100) desc;
v_test1	asin(v_test/100)
-0.22	0.002020001373737189
0.22	0.002020001373737189
0	-0.002020001373737189
0.22	-0.002020001373737189
#case when
select sum(asin(case when asin(v_test/100)>0 then 0.2 else 0.1 end)/asin(-0.1)) from  caitest;
sum(asin(case when asin(v_test/100)>0 then 0.2 else 0.1 end)/asin(-0.1))
-6.020427369604755
select sum(asin((case v_test when '-0.202' then asin(v_test/100) when '0.202' then asin(v_test1) end)/asin(-1))) t1 from  caitest;
t1
0.002571946338344344
#distinct
select distinct asin(v_test/100) from caitest;
asin(v_test/100)
-0.002020001373737189
0.002020001373737189
#空值
drop table caitest;
create table caitest(v_test varchar(30),v_test1 varchar(30));
select asin(v_test/100),asin(v_test1)  from caitest;
asin(v_test/100)	asin(v_test1)
drop table caitest;
#没有not null约束
drop table if exists t2;
create table t2 as select asin(20) from dual;
select * from t2;
asin(20)
NULL
drop table t2;
