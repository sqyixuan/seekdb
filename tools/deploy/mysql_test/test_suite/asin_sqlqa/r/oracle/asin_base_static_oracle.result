#连接符，函数，运算
drop table caitest;
create table caitest(v_test varchar2(100),v_test1 varchar2(100));
insert into caitest values (trunc(asin(1),7),trunc(asin(0),8)||'1');
insert into caitest(v_test) values (trunc((asin(1)*(-10)-asin(1)),7));
#insert语句
#oracle模式支持insert嵌套select，ob不支持
insert into caitest(v_test1) values(trunc((select v_test from caitest where v_test>0 group  by v_test having asin(v_test/100) is not null),3)/2e10);
#oracle模式支持insert嵌套select，ob不支持
insert into caitest(v_test1) values(trunc((select sum(asin(v_test/100)) from caitest where v_test>0),3));
#insert不支持where
insert  into caitest(v_test) values (asin(0.2)) where  2 -1>0;
ERROR 42000: You have an error in your SQL syntax; check the manual that corresponds to your OceanBase version for the right syntax to use near 'where  2 -1>0' at line 1
#update语句(set，where位置)
update caitest set v_test=asin(0.2) where  v_test1 >asin(-1);
update caitest set v_test=asin(0.2), v_test1=asin(0.2)/10 where  v_test1 >asin(-1);
delete  from caitest;
insert into caitest values('0.202','0.22');
update caitest set v_test1=(trunc((select v_test from caitest where v_test>0 group  by v_test having asin(v_test/100) is not null),3));
update caitest set v_test1=( trunc(( select * from (select asin(v_test/100) from caitest where v_test between asin(-1) and asin(1) order  by asin(v_test/100) desc) a),3 ));
update caitest set v_test1='0.5' where v_test in (select v_test from caitest group by  v_test having asin(v_test/100)>0);
update caitest set v_test1='0.5' where v_test > (select * from(select max(asin(v_test/100)) from caitest order by  asin(v_test/100) desc));
update caitest set v_test1=(trunc((select sum(asin(v_test/100)) from caitest where v_test>0),3));
#delete语句(where位置)，聚合函数等
delete from caitest where asin(v_test/100)<>0;
insert into caitest values('0.202','0.22');
delete from caitest where v_test1>(trunc((select v_test from caitest where v_test>0 group  by v_test having asin(v_test/100) is not null),3));
insert into caitest values('0.202','0.22');
delete from caitest where v_test1<( trunc(( select * from (select asin(v_test/100) from caitest where v_test between asin(-1) and asin(1) order  by asin(v_test/100) desc) a),3 ));
insert into caitest values('0.202','0.22');
delete from caitest  where v_test in (select v_test from caitest group by  v_test having asin(v_test/100)>0);
insert into caitest values('0.202','0.22');
delete from caitest  where v_test > (select * from(select max(asin(v_test/100)) from caitest order by  asin(v_test/100) desc));
insert into caitest values('0.202','0.22');
delete  from caitest where v_test1>(trunc((select sum(asin(v_test/100)) from caitest where v_test>0),3));
#merge into语法
create table caicai(id number,name number,sex number);
create table  caicai1(id1 number,name1 number,sex1 number);
insert into caicai values(0.1,0.2,0.3);
insert into caicai values(0.2,0.3,0.4);
insert into caicai values(0.3,0.4,0.5);
insert into caicai1 values(0.1,0.3,0.5);
insert into caicai1 values(0.2,0.4,0.6);
insert into caicai1 values(0.8,0.10,0.12);
#dml语句，运算符，聚合函数等
merge into caicai a using caicai1 b
on(a.id=b.id1)
when matched then
update  set a.sex=asin(0.2) where  a.name >asin(-1)
when not matched then
insert values (trunc(asin(1),7),trunc(asin(0),8)||'1',(trunc((asin(1)*(-10)-asin(1)),7)));
select * from caicai;
ID	NAME	SEX
.1	.2	.20135792079033079145512555221762341024
.2	.3	.20135792079033079145512555221762341024
.3	.4	.5
1.5707963	1	-17.2787595
#insert语句中不支持嵌套select语句
merge into caicai a using caicai1 b
on(a.id=b.id1)
when not matched then
insert values(trunc((select v_test from caitest where v_test>110 group  by v_test having asin(v_test/100) is not null),3),2,3);
merge into caicai a using caicai1 b
on(a.id=b.id1)
when not matched then
insert values(trunc((select sum(asin(v_test/100)) from caitest where v_test>0),3),2,3);
merge into caicai a using caicai1 b
on(a.id=b.id1)
when not matched then
insert values (asin(0.2),2,3) where  b.name1>trunc(( select * from (select asin(v_test/100) from caitest where v_test between asin(-1) and asin(1) order  by asin(v_test/100) desc) a),3 );
#update语句及delete语句中均不支持嵌套select语句
merge into caicai a using caicai1 b
on(a.id=b.id1)
when matched then
update set a.name=(select 1 from dual),
a.sex=(select 2 from dual);
#混用atan函数
merge into caicai a using caicai1 b
on(a.id=b.id1)
when matched then
update set a.name=asin(0.2), a.sex=asin(0.2)/10 where  a.name >asin(-1)
delete  where(a.name> (trunc(atan(2),3)));
merge into caicai a using caicai1 b
on(a.id=b.id1)
when matched then
update set a.name=asin(0.2), a.sex=asin(0.2)/10 where  a.name >asin(-1)
delete  where(a.name<trunc(( select * from (select asin(v_test/100) from caitest where v_test between asin(-1) and asin(1) order  by asin(v_test/100) desc) a),3 ));
merge into caicai a using caicai1 b
on(a.id=b.id1)
when matched then
update set a.name=asin(0.2),a.sex=asin(0.2)/10 where  a.name >asin(-1)
delete  where(asin(a.name)>0);
merge into caicai a using caicai1 b
on(a.id=b.id1)
when matched then
update set a.name=50.22 where a.name < (select v_test from caitest where v_test<10 group by  v_test having asin(v_test/100)>0);
merge into caicai a using caicai1 b
on(a.id=b.id1)
when matched then
update set a.name=(trunc(asin(0.20),3)) where
a.sex>(trunc((asin(1)*2),3));
drop table caicai;
drop table caicai1;
drop table caitest;
