# owner: fenggu.yh
# description: test for black filter pushdown correctness in column_store encoding

--disable_query_log
set global ob_sql_work_area_percentage=80;
disconnect default;
sleep 1;
connect (default,$OBMYSQL_MS0,admin,admin,test,$OBMYSQL_PORT);
set @@recyclebin = off;
set ob_query_timeout=1000000000;
set ob_trx_timeout=1000000000;

--disable_warnings
drop table if exists t_int;
--enable_warnings

create table t_int(a int primary key, b smallint, c int unsigned, d float, e date) row_format = compressed block_size = 2048 with column group (all columns, each column);
--let $count = 1
while($count < 101)
{
  --let $stmt=insert into t_int(a,b,c,d,e) values ($count,-32768,(100000000+$count),-2.33,'1993-01-01');
  eval $stmt;
  inc $count;
}
while($count < 201)
{
  --let $stmt=insert into t_int(a,b,c,d,e) values ($count,0,(100000000+$count),2.33, '1994-01-01');
  eval $stmt;
  inc $count;
}
while($count < 301)
{
  --let $stmt=insert into t_int(a,b,c,d,e) values ($count,32767,(100000000+$count),NULL, '1995-01-01');
  eval $stmt;
  inc $count;
}
select count(*) from t_int;
select count(*) from t_int where b=-32768;
select count(*) from t_int where b<32768;
select count(*) from t_int where b>-32769;
select count(*) from t_int where c between 100000000 and 100000010;
select count(*) from t_int where c < 1;
select count(*) from t_int where c in(100000000,100000001,100000002,200000000);
select count(*) from t_int where d between -2.331000 and -2.32900;
select count(*) from t_int where d<-10.00;
select count(*) from t_int where d is NULL;
select count(*) from t_int where e >= '1993-01-02';

--disable_query_log
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
--enable_query_log

alter system major freeze tenant all;
--source mysql_test/include/wait_daily_merge.inc

drop table t_int;

--disable_query_log
set global ob_sql_work_area_percentage=5;
set @@recyclebin = on;
--enable_query_log
