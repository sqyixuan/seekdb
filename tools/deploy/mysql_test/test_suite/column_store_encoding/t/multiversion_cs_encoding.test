# owner: fenggu.yh
# description: test for pushdown multiviersion sst in column_store encoding

--disable_warnings
drop table if exists t1,t2;
--enable_warnings

--disable_query_log
create table t1(a int primary key, b int, c date, d varchar(10)) row_format = compressed block_size = 2048 with column group (all columns, each column);
create table t2(a int primary key, b int) row_format = compact block_size = 2048 with column group (all columns, each column);
--let $count = 1
while($count < 201)
{
  --let $stmt1=insert into t1(a,b,c,d) values ($count,$count,'2022-03-10','aaa');
  --let $stmt2=insert into t2(a,b) values($count,$count);
  eval $stmt1;
  eval $stmt2;
  inc $count;
}
while($count < 401)
{
  --let $stmt1=insert into t1(a,b,c,d) values ($count,$count,'2022-03-11','bbb');
  --let $stmt2=insert into t2(a,b) values($count,$count);
  eval $stmt1;
  eval $stmt2;
  inc $count;
}

--enable_query_log
select count(1) from t1;
select count(1) from t1 where b > 98;
select count(1) from t1 where a < 2001 and b > 98;
select count(1) from t1 where b/2 > 98;
select count(1) from t1 where c = '2022-03-11';
select count(1) from t1 where d > 'aa';
select count(1) from t1 where b > 50 or c = '2022-03-11';
select count(1) from t1 where b > 50 and d > 'bb';
select count(1) from t2;
select count(1) from t2 where b > 50;
select count(b) from t2 where a < 90 and b > 50;
select count(b) from t2 where a < 10 or b > 99;

alter system minor freeze tenant sys;
--source mysql_test/include/wait_minor_merge.inc

select count(1) from t1;
select count(1) from t1 where b > 98;
select count(1) from t1 where a < 2001 and b > 98;
select count(1) from t1 where b/2 > 98;
select count(1) from t1 where c = '2022-03-11';
select count(1) from t1 where d > 'aa';
select count(1) from t1 where b > 50 or c = '2022-03-11';
select count(1) from t1 where b > 50 and d > 'bb';
select count(1) from t2;
select count(1) from t2 where b > 50;
select count(b) from t2 where a < 90 and b > 50;
select count(b) from t2 where a < 10 or b > 99;

--disable_query_log
while($count < 801)
{
  --let $stmt1=insert into t1(a,b,c,d) values ($count,$count,'2022-03-12','ccc');
  --let $stmt2=insert into t2(a,b) values($count,$count);
  eval $stmt1;
  eval $stmt2;
  inc $count;
}

--enable_query_log
