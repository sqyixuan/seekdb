select count(1) from t1 where b > 98;
select count(1) from t1 where a < 2001 and b > 98;
select count(1) from t1 where b/2 > 98;
select count(1) from t1 where c = '2022-03-11';
select count(1) from t1 where d > 'aa';
select count(1) from t1 where b > 50 or c = '2022-03-11';
select count(1) from t1 where b > 50 and d > 'bb';
select count(1) from t2;
select count(1) from t2 where b > 50;
select count(b) from t2 where a < 90 and b > 50;
select count(b) from t2 where a < 10 or b > 99;

alter system minor freeze tenant sys;
--source mysql_test/include/wait_minor_merge.inc

select count(1) from t1;
select count(1) from t1 where b > 98;
select count(1) from t1 where a < 2001 and b > 98;
select count(1) from t1 where b/2 > 98;
select count(1) from t1 where c = '2022-03-11';
select count(1) from t1 where d > 'aa';
select count(1) from t1 where b > 50 or c = '2022-03-11';
select count(1) from t1 where b > 50 and d > 'bb';
