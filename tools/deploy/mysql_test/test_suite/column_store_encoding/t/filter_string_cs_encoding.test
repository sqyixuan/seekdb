# owner: fenggu.yh
# description: test for black filter pushdown correctness in column_store encoding

--disable_query_log
set global ob_sql_work_area_percentage=80;
disconnect default;
sleep 1;
connect (default,$OBMYSQL_MS0,admin,admin,test,$OBMYSQL_PORT);
set @@recyclebin = off;
set ob_query_timeout=1000000000;
set ob_trx_timeout=1000000000;

--disable_warnings
drop table if exists t_str;
--enable_warnings

create table t_str(a int primary key, b char(10), c varchar(10), d char(10)) row_format = compressed block_size = 2048 with column group (all columns, each column);
--let $count = 1
while($count < 101)
{
  --let $stmt=insert into t_str(a,b,c,d) values ($count,'','abcd', NULL);
  eval $stmt;
  inc $count;
}
while($count < 201)
{
  --let $stmt=insert into t_str(a,b,c,d) values ($count,'','a',NULL);
  eval $stmt;
  inc $count;
}
select count(*) from t_str;
select count(*) from t_str where b='';
select count(*) from t_str where b='aaaaaaaaaa';
select count(*) from t_str where c='abcd';
select count(*) from t_str where d IS NULL;
select count(*) from t_str where d='a';

--disable_query_log
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
--enable_query_log

alter system major freeze tenant all;
--source mysql_test/include/wait_daily_merge.inc

drop table t_str;

--disable_query_log
set global ob_sql_work_area_percentage=5;
set @@recyclebin = on;
--enable_query_log
