--echo # 创建新租户及用户
--source mysql_test/test_suite/Error_Handling_sqlqa/t/create_tenant_user.inc

--echo # 建立链接
connect (conn1,$OBMYSQL_MS0,funkzz,123456,zh_db,$OBMYSQL_PORT);
connection conn1;
SET AUTOCOMMIT=1;
--result_format 4


delimiter //;


--echo #################错误处理
--echo #################多个异常处理程序

--disable_warnings
DROP TABLE IF EXISTS mistake//
CREATE TABLE mistake(
  id INT primary key,
  j VARCHAR(50),
  i INT
)//
--enable_warnings
INSERT INTO mistake VALUES(2,'third',5);

CREATE PROCEDURE small_mistake1(OUT error VARCHAR(5))  
BEGIN
      
      DECLARE CONTINUE HANDLER FOR SQLSTATE '23000' SET error = '23000';
      DECLARE CONTINUE HANDLER FOR SQLSTATE '21S01' SET error = '21S01';
      
      INSERT INTO mistake VALUES(2,'third',5);  #错误语句

END//

CALL small_mistake1(@error)//
select @error//


CREATE PROCEDURE small_mistake2(OUT error VARCHAR(5))
BEGIN

      DECLARE CONTINUE HANDLER FOR SQLSTATE '23000' SET error = '23000';
      DECLARE CONTINUE HANDLER FOR SQLSTATE '21S01' SET error = '21S01';
      INSERT INTO mistake VALUES(3,'third',5,6);  #错误语句

END//
CALL small_mistake2(@error)//
select @error//



--echo ########################使用三个处理程序



CREATE PROCEDURE small_mistake3(OUT error VARCHAR(5))  
BEGIN
    DECLARE CONTINUE HANDLER FOR SQLWARNING,NOT FOUND,SQLEXCEPTION  SET error = 'xxxxx';  
  
    INSERT INTO mistake VALUES(2,'third',5);   
END//
call small_mistake3(@error)//
select @error//




--echo ########################MySQL的异常传播
--disable_warnings
DROP TABLE IF EXISTS mistake2//
CREATE TABLE mistake2(
  id INT primary key,
  j VARCHAR(50),
  i INT
)//
--enable_warnings
INSERT INTO mistake2 VALUES(2,'third',5);

CREATE  PROCEDURE small_mistake4()  
BEGIN    
    DECLARE CONTINUE HANDLER FOR SQLSTATE '23000' 
    SET @processed = 100;
  
    BEGIN      
         DECLARE CONTINUE HANDLER FOR SQLSTATE '21000' SET @processed = 200;    
         INSERT INTO mistake2 VALUES(2,'third',27); 
         SET @test=123321;  
    END;
END//
call small_mistake4()//
select @processed,@test//




--echo ##################13.6.7.1 DECLARE ... CONDITION语句，声明了一个命名错误条件(MySQL错误代码)
--disable_warnings
DROP TABLE IF EXISTS result1//
CREATE TABLE result1(
  id INT,
  res1 VARCHAR(50),
  res2 VARCHAR(50)
)//
--enable_warnings
DROP PROCEDURE IF EXISTS `pro1`//
CREATE PROCEDURE pro1()
BEGIN

  DECLARE no_such_table CONDITION FOR 1146;
  DECLARE CONTINUE HANDLER FOR no_such_table
  BEGIN
    INSERT INTO result1 VALUES(1,'结果表：','删除不存在的表场合，MySQL错误代码1146，进入CONTINUE HANDLER 处理程序');
  END;
  DELETE FROM notable;
END//
CALL pro1()//
SELECT * FROM result1//



--echo ##################13.6.7.1 DECLARE ... CONDITION语句，声明了一个命名错误条件(SQLSTATE值)
--disable_warnings
DROP PROCEDURE IF EXISTS `pro2`//
CREATE PROCEDURE pro2()
BEGIN
  DECLARE no_such_table CONDITION FOR SQLSTATE '42S02';
  DECLARE CONTINUE HANDLER FOR no_such_table
  BEGIN
    INSERT INTO result1 VALUES(2,'结果表：','删除不存在的表场合，SQLSTATE值42S02，进入CONTINUE HANDLER 处理程序');
  END;
  DELETE FROM notable;
END//

CALL pro2()//
SELECT * FROM result1//




--echo ##################13.6.7.2 DECLARE ... HANDLER 语句(处理程序声明)
--echo ##################(1.1)处理程序声明必须出现在变量或条件声明之后，CONTINUE HANDLER 处理程序，操作 CONTINUE
DROP TABLE IF EXISTS result1//
CREATE TABLE result1(
  id INT,
  res1 VARCHAR(50),
  res2 VARCHAR(50),
  done INT
)//

DROP PROCEDURE IF EXISTS `pro1`//
CREATE PROCEDURE pro1()
BEGIN
  DECLARE done INT DEFAULT FALSE;
  DECLARE no_such_table CONDITION FOR SQLSTATE '42S02';
  DECLARE CONTINUE HANDLER FOR no_such_table
  BEGIN
    SET done = TRUE;
    INSERT INTO result1 VALUES(1,'结果表：','进入CONTINUE HANDLER 处理程序 CONTINUE',done);
  END;
  DELETE FROM notable;
END//

CALL pro1()//
SELECT * FROM result1//





--echo ##################(1.2)CONTINUE HANDLER 处理程序，操作 EXIT
DROP PROCEDURE IF EXISTS `pro11`//
CREATE PROCEDURE pro11()
BEGIN
  DECLARE done INT DEFAULT FALSE;
  DECLARE no_such_table CONDITION FOR SQLSTATE '42S02';
  DECLARE EXIT HANDLER FOR no_such_table
  BEGIN
    SET done = TRUE;
    INSERT INTO result1 VALUES(2,'结果表：','进入CONTINUE HANDLER 处理程序 EXIT',done);
  END;
  DELETE FROM notable;
END//

CALL pro11()//
SELECT * FROM result1//



--echo ##################(1.3)CONTINUE HANDLER 处理程序，激活处理程序中的特定条件 SQLSTATE
DROP PROCEDURE IF EXISTS `pro12`//
CREATE PROCEDURE pro12()
BEGIN
  DECLARE done INT DEFAULT FALSE;
  DECLARE EXIT HANDLER FOR SQLSTATE '42S02'
  BEGIN
    SET done = TRUE;
    INSERT INTO result1 VALUES(3,'结果表：','进入CONTINUE HANDLER 处理程序 SQLSTATE 42S02',done);
  END;
  DELETE FROM notable;
END//

CALL pro12()//
--sorted_result
SELECT * FROM result1//


--echo ##################(1.4)CONTINUE HANDLER 处理程序，激活处理程序中的特定条件 错误代码
DROP PROCEDURE IF EXISTS `pro13`//
CREATE PROCEDURE pro13()
BEGIN
  DECLARE done INT DEFAULT FALSE;
  DECLARE EXIT HANDLER FOR 1146
  BEGIN
    SET done = TRUE;
    INSERT INTO result1 VALUES(4,'结果表：','进入CONTINUE HANDLER 处理程序 错误代码1146 ',done);
  END;
  DELETE FROM notable;
END//

CALL pro13()//
--sorted_result
SELECT * FROM result1//


--echo ##################(2)处理程序声明不能出现在变量声明之前
DROP TABLE IF EXISTS result1//
CREATE TABLE result1(
  id INT,
  res1 VARCHAR(50),
  res2 VARCHAR(50)
)//

DROP PROCEDURE IF EXISTS `pro2`//
--error 1337
CREATE PROCEDURE pro2()
BEGIN
  DECLARE no_such_table CONDITION FOR SQLSTATE '42S02';
  DECLARE CONTINUE HANDLER FOR no_such_table
  BEGIN
    INSERT INTO result1 VALUES(1,'结果表：','进入CONTINUE HANDLER 处理程序');
  END;
  DECLARE done INT DEFAULT FALSE;
  DELETE FROM notable;
END//
--echo # MySql运行结果: ERROR 1337 (42000): Variable or condition declaration after cursor or handler declaration

--sorted_result
SELECT * FROM result1//


--echo ##################(3)处理程序声明不能出现在条件声明之前
DROP TABLE IF EXISTS result1//
CREATE TABLE result1(
  id INT,
  res1 VARCHAR(50),
  res2 VARCHAR(50),
  done INT
)//

DROP PROCEDURE IF EXISTS `pro3`//
--error 1337
CREATE PROCEDURE pro3()
BEGIN
  DECLARE done INT DEFAULT FALSE;
  DECLARE no_such_table CONDITION FOR SQLSTATE '42S02';
  DECLARE CONTINUE HANDLER FOR no_such_table
  BEGIN
    SET done = TRUE;
    INSERT INTO result1 VALUES(1,'结果表：','进入CONTINUE HANDLER 处理程序',done);
  END;
  DECLARE can_not_find CONDITION FOR 1146;
  DELETE FROM notable;
END//
--echo # MySql运行结果: ERROR 1337 (42000): Variable or condition declaration after cursor or handler declaration
--sorted_result
SELECT * FROM result1//


--echo ##################(4)SQLEXCEPTION条件 示例1 ( DECLARE ... HANDLER语句存在场合)
DROP TABLE IF EXISTS t//
CREATE TABLE t (
  s1 INT,
  PRIMARY KEY (s1)
)//

DROP PROCEDURE IF EXISTS `handlerdemo`//
CREATE PROCEDURE handlerdemo ()
BEGIN
  DECLARE CONTINUE HANDLER FOR SQLSTATE '23000' SET @x2 = 1;
  SET @x = 1;
  INSERT INTO t VALUES (1);
  SET @x = 2;
  INSERT INTO t VALUES (1);
  SET @x = 3;
END//

CALL handlerdemo()//

--echo # 预期结果: @x=3 ， @x2=1
SELECT @x//
SELECT @x2//
--sorted_result
SELECT * FROM t//


--echo ##################(4)SQLEXCEPTION条件 示例1 ( DECLARE ... HANDLER语句不存在场合)
DROP PROCEDURE IF EXISTS `handlerdemo1`//
CREATE PROCEDURE handlerdemo1 ()
BEGIN
  SET @x = 1;
  INSERT INTO t VALUES (2);
  SET @x = 2;
  INSERT INTO t VALUES (2);
  SET @x = 3;
END//

--error 1062
CALL handlerdemo1()//
--echo # MySql运行结果: ERROR 1062 (23000): Duplicate entry '2' for key 'PRIMARY'

--echo # 预期结果: @x=2 ， @x2=1
SELECT @x//
--sorted_result
SELECT * FROM t//


--echo ##################(5.1)处理程序中不能引用外部标签(块标签的范围不包括块内声明的处理程序的代码) 示例2
DROP TABLE IF EXISTS result1//
CREATE TABLE result1(
  id INT,
  res1 VARCHAR(50),
  i INT
)//

DROP PROCEDURE IF EXISTS `p`//
--error 1308
CREATE PROCEDURE p ()
BEGIN
  DECLARE i INT DEFAULT 3;
  retry:REPEAT
          BEGIN
        DECLARE CONTINUE HANDLER FOR SQLWARNING
        BEGIN
          INSERT INTO result1 VALUES(1,'结果表：进入处理程序，i= ',i);
          ITERATE retry;
        END;

        IF i < 0 THEN
          INSERT INTO result1 VALUES(2,'结果表：进入i < 0，i= ',i);
          LEAVE retry;
        END IF;

        INSERT INTO result1 VALUES(3,'结果表：i= ',i);
        SET i = i - 1;
          END;
  UNTIL FALSE
  END REPEAT;
END//
--echo # MySql运行结果: ERROR 1308 (42000): ITERATE with no matching label: retry
--sorted_result
SELECT * FROM result1//




--echo ##################(5.2)处理程序主体可以为空,离开块 示例2
DROP TABLE IF EXISTS result1//
CREATE TABLE result1(
  id INT AUTO_INCREMENT NOT NULL PRIMARY KEY,
  res1 VARCHAR(50),
  i INT
)//

DROP PROCEDURE IF EXISTS `p2`//
CREATE PROCEDURE p2 ()
BEGIN
  DECLARE i INT DEFAULT 3;
  retry:REPEAT
          BEGIN
        DECLARE EXIT HANDLER FOR SQLWARNING BEGIN END;

        IF i < 0 THEN
          INSERT INTO result1 VALUES(NULL,'结果表：进入IF i < 0，i= ',i);
          LEAVE retry;
        END IF;

        INSERT INTO result1 VALUES(NULL,'结果表：i= ',i);
        SET i = i - 1;
          END;
  UNTIL FALSE
  END REPEAT;
END//

CALL p2()//
--sorted_result
SELECT * FROM result1//


--echo ##################(5.3)继续执行,处理程序中设置一个状态变量 示例2
DROP TABLE IF EXISTS result1//
CREATE TABLE result1(
  id INT AUTO_INCREMENT NOT NULL PRIMARY KEY,
  res1 VARCHAR(50),
  i INT,
  done INT
)//

DROP PROCEDURE IF EXISTS `p3`//
CREATE PROCEDURE p3 ()
BEGIN
  DECLARE i INT DEFAULT 3;
  DECLARE done INT DEFAULT FALSE;
  retry:REPEAT
          BEGIN
        DECLARE EXIT HANDLER FOR SQLWARNING
        BEGIN
          SET done = TRUE;
        END;

        IF done OR i < 0 THEN
          INSERT INTO result1 VALUES(NULL,'结果表：进入IF done OR i < 0，i,done= ',i,done);
          LEAVE retry;
        END IF;

        INSERT INTO result1 VALUES(NULL,'结果表：i,done= ',i,done);
        SET i = i - 1;
          END;
  UNTIL FALSE
  END REPEAT;
END//

CALL p3()//
--sorted_result
SELECT * FROM result1//


--echo ##################13.6.7.3 GET DIAGNOSTICS 语句(获取诊断区域的诊断信息) ※※ 13. GET DIAGNOSTICS 语句,ob还不支持
--echo ##################(1.1)GET DIAGNOSTICS 获取条件信息
DROP TABLE IF EXISTS result1//
CREATE TABLE result1(
  id INT,
  res1 VARCHAR(100),
  RETURNED_SQLSTATE VARCHAR(100),
  MESSAGE_TEXT VARCHAR(100)
)//

DROP PROCEDURE IF EXISTS `pro1`//
#--error 1064
CREATE PROCEDURE pro1 ()
BEGIN
  DECLARE no_such_table CONDITION FOR 1051;

  DECLARE CONTINUE HANDLER FOR no_such_table
  BEGIN
    GET DIAGNOSTICS CONDITION 1 @p1 = RETURNED_SQLSTATE, @p2 = MESSAGE_TEXT;
    SELECT @p1, @p2;
    INSERT INTO result1 VALUES(1,'结果表：',@p1,@p2);
  END;

  DROP TABLE no_such_table;
END//

#--error 1305
CALL pro1 ()//
--sorted_result
SELECT * FROM result1//
DROP PROCEDURE pro1;//

--echo ##################(1.2)GET DIAGNOSTICS 获取语句信息
DROP TABLE IF EXISTS result1//
CREATE TABLE result1(
  id INT,
  res1 VARCHAR(100),
  NUMBER INT,
  ROW_COUNT INT
)//

DROP PROCEDURE IF EXISTS `pro2`//
#--error 1064
CREATE PROCEDURE pro2 ()
BEGIN
  DECLARE no_such_table CONDITION FOR 1051;

  DECLARE CONTINUE HANDLER FOR no_such_table
  BEGIN
    GET DIAGNOSTICS @p1 = NUMBER, @p2 = ROW_COUNT;
    SELECT @p1, @p2;
    INSERT INTO result1 VALUES(1,'结果表：',@p1,@p2);
  END;

  DROP TABLE no_such_table;
END//

#--error 1305
CALL pro2 ()//
--sorted_result
SELECT * FROM result1//
DROP PROCEDURE pro2;//

--echo ##################(2)GET DIAGNOSTICS不能在同一语句中同时获取语句或条件信息
DROP TABLE IF EXISTS result1//
CREATE TABLE result1(
  id INT,
  res1 VARCHAR(100),
  res2 VARCHAR(100),
  res3 VARCHAR(100),
  res4 VARCHAR(100),
  res5 VARCHAR(100)
)//

DROP PROCEDURE IF EXISTS `pro1`//
--error 1064
CREATE PROCEDURE pro1 ()
BEGIN
  DECLARE no_such_table CONDITION FOR 1051;

  DECLARE CONTINUE HANDLER FOR no_such_table
  BEGIN
    GET DIAGNOSTICS CONDITION 1 @p1 = RETURNED_SQLSTATE, @p2 = MESSAGE_TEXT, @p3 = NUMBER, @p4 = ROW_COUNT;;
    SELECT @p1, @p2,@p3, @p4;
    INSERT INTO result1 VALUES(1,'结果表：',@p1,@p2,@p3, @p4);
  END;
  DROP TABLE no_such_table;
END//
--echo # MySql运行结果: ERROR 1064 (42000): You have an error in your SQL syntax; check the manual that corresponds to your MySQL server version for the right syntax to use near 'NUMBER, @p4 = ROW_COUNT;;SELECT @p1, @p2,@p3, @p4; INSERT INTO result1 ' at line 7

--error 1305
CALL pro1 ()//
--sorted_result
SELECT * FROM result1//

--echo ##################(3) GET DIAGNOSTICS用于获取受影响的行数 示例 1
DROP TABLE IF EXISTS result1//
CREATE TABLE result1(
  id INT,
  res1 VARCHAR(100),
  res2 VARCHAR(100)
)//

DROP TABLE IF EXISTS t1//
CREATE TABLE t1(
  int_col INT NOT NULL
)//

DROP PROCEDURE IF EXISTS `do_insert`//
CREATE PROCEDURE do_insert(value INT)
BEGIN
  DECLARE code CHAR(5) DEFAULT '00000';
  DECLARE msg TEXT;
  DECLARE nrows INT;
  DECLARE result TEXT;

  DECLARE CONTINUE HANDLER FOR SQLEXCEPTION
    BEGIN
      GET DIAGNOSTICS CONDITION 1
        code = RETURNED_SQLSTATE, msg = MESSAGE_TEXT;
    END;

  INSERT INTO t1 (int_col) VALUES(value);

  IF code = '00000' THEN
    GET DIAGNOSTICS nrows = ROW_COUNT;
    SET result = CONCAT('insert succeeded, row count = ',nrows);
  ELSE
    SET result = CONCAT('insert failed, error = ',code,', message = ',msg);
  END IF;

  INSERT INTO result1 VALUES(1,'结果表：',result);
END//

CALL do_insert(1)//
--sorted_result
SELECT * FROM t1//
--sorted_result
SELECT * FROM result1//

CALL do_insert(NULL)//
--sorted_result
SELECT * FROM t1//
--sorted_result
SELECT * FROM result1//

--echo ##################(4)GET STACKED DIAGNOSTICS在处理程序中使用它来获取有关已处理异常的信息 示例 2
DROP TABLE IF EXISTS result1//
CREATE TABLE result1(
  id INT,
  op VARCHAR(100),
  errno VARCHAR(100),
  msg VARCHAR(100)
)//

DROP TABLE IF EXISTS t1//
CREATE TABLE t1 (
  c1 TEXT NOT NULL
)//

DROP PROCEDURE IF EXISTS p//
#--error 1064
CREATE PROCEDURE p ()
BEGIN
  DECLARE errcount INT;
  DECLARE errno INT;
  DECLARE msg TEXT;

  DECLARE EXIT HANDLER FOR SQLEXCEPTION
  BEGIN

    GET CURRENT DIAGNOSTICS CONDITION 1 errno = MYSQL_ERRNO, msg = MESSAGE_TEXT;
    SELECT 'current DA before mapped insert' AS op, errno, msg;
        INSERT INTO result1 VALUES(1,'current DA before mapped insert', errno, msg);
    GET STACKED DIAGNOSTICS CONDITION 1 errno = MYSQL_ERRNO, msg = MESSAGE_TEXT;
    SELECT 'stacked DA before mapped insert' AS op, errno, msg;
    INSERT INTO result1 VALUES(2,'stacked DA before mapped insert', errno, msg);

    INSERT INTO t1 (c1) VALUES('');

    GET CURRENT DIAGNOSTICS errcount = NUMBER;

        IF errcount = 0 THEN
      SELECT 'mapped insert succeeded, current DA is empty' AS op;
          INSERT INTO result1 VALUES(3,'mapped insert succeeded, current DA is empty', '', '');
    ELSE
      GET CURRENT DIAGNOSTICS CONDITION 1 errno = MYSQL_ERRNO, msg = MESSAGE_TEXT;
      SELECT 'current DA after mapped insert' AS op, errno, msg;
          INSERT INTO result1 VALUES(4,'current DA after mapped insert', errno, msg);
    END IF ;

        GET STACKED DIAGNOSTICS CONDITION 1 errno = MYSQL_ERRNO, msg = MESSAGE_TEXT;
    SELECT 'stacked DA after mapped insert' AS op, errno, msg;
        INSERT INTO result1 VALUES(5,'stacked DA after mapped insert', errno, msg);

  END;

  INSERT INTO t1 (c1) VALUES('string 1');
  INSERT INTO t1 (c1) VALUES(NULL);
END//

#--error 1305
CALL p()//
--sorted_result
SELECT * FROM t1//
--sorted_result
SELECT * FROM result1//
DROP PROCEDURE p;//

--echo ##################(5)DECLARE在处理程序开头，会清除当前诊断区域 示例 3
DROP TABLE IF EXISTS result1//
CREATE TABLE result1(
  id INT,
  op VARCHAR(100),
  errno VARCHAR(100),
  msg VARCHAR(100)
)//

DROP TABLE IF EXISTS t1//
CREATE TABLE t1 (
  c1 TEXT NOT NULL
)//


DROP PROCEDURE IF EXISTS p2//
#--error 1064
CREATE PROCEDURE p2 ()
BEGIN
  DECLARE EXIT HANDLER FOR SQLEXCEPTION
  BEGIN
    DECLARE errcount INT;
    DECLARE errno INT;
    DECLARE msg TEXT;

    GET CURRENT DIAGNOSTICS CONDITION 1 errno = MYSQL_ERRNO, msg = MESSAGE_TEXT;
    SELECT 'current DA before mapped insert' AS op, errno, msg;
        INSERT INTO result1 VALUES(1,'current DA before mapped insert', errno, msg);
    GET STACKED DIAGNOSTICS CONDITION 1 errno = MYSQL_ERRNO, msg = MESSAGE_TEXT;
    SELECT 'stacked DA before mapped insert' AS op, errno, msg;
    INSERT INTO result1 VALUES(2,'stacked DA before mapped insert', errno, msg);

    INSERT INTO t1 (c1) VALUES('');

    GET CURRENT DIAGNOSTICS errcount = NUMBER;

        IF errcount = 0 THEN
      SELECT 'mapped insert succeeded, current DA is empty' AS op;
          INSERT INTO result1 VALUES(3,'mapped insert succeeded, current DA is empty', '', '');
    ELSE
      GET CURRENT DIAGNOSTICS CONDITION 1 errno = MYSQL_ERRNO, msg = MESSAGE_TEXT;
      SELECT 'current DA after mapped insert' AS op, errno, msg;
          INSERT INTO result1 VALUES(4,'current DA after mapped insert', errno, msg);
    END IF;

        GET STACKED DIAGNOSTICS CONDITION 1 errno = MYSQL_ERRNO, msg = MESSAGE_TEXT;
    SELECT 'stacked DA after mapped insert' AS op, errno, msg;
        INSERT INTO result1 VALUES(5,'stacked DA after mapped insert', errno, msg);
  END;
  INSERT INTO t1 (c1) VALUES('string 1');
  INSERT INTO t1 (c1) VALUES(NULL);
END//

#--error 1305
CALL p2()//
--sorted_result
SELECT * FROM t1//
--sorted_result
SELECT * FROM result1//
DROP PROCEDURE p2;//

--echo ##################13.6.7.4 RESIGNAL 声明(传递错误条件信息)
--echo ##################(1)RESIGNAL要求当前上下文是条件处理程序  ※※ 14. 创建存储过程中RESIGNAL没有条件处理程序上下文，MySQL中创建成功，调用时失败，ob中创建失败
DROP PROCEDURE IF EXISTS p//
CREATE PROCEDURE p ()
BEGIN
  RESIGNAL;
END//

--error 1645
CALL p()//
--echo # MySql运行结果: ERROR 1645 (0K000): RESIGNAL when handler not active

DROP FUNCTION IF EXISTS f//
CREATE FUNCTION f () RETURNS INT
BEGIN
  RESIGNAL;
  RETURN 5;
END//

--error 1645
SELECT f ()//
--echo # MySql运行结果: ERROR 1645 (0K000): RESIGNAL when handler not active


--echo ##################(2)一个简单的RESIGNAL 示例1
DROP TABLE IF EXISTS result1//
CREATE TABLE result1(
  id INT,
  res1 VARCHAR(100),
  res2 VARCHAR(100)
)//

DROP TABLE IF EXISTS t1//

DROP PROCEDURE IF EXISTS p//
CREATE PROCEDURE p ()
BEGIN
  DECLARE EXIT HANDLER FOR SQLEXCEPTION
  BEGIN
    SET @error_count = @error_count + 1;
    IF @a = 0 THEN
          RESIGNAL;
    END IF;
    INSERT INTO result1 VALUES(1,'结果表：', '存储过程p ()中处理程序执行完了');
  END;
  DROP TABLE t1;
END//

SET @error_count = 0//
SET @a = 0//
--error 1051
CALL p()//
--echo # MySql运行结果: ERROR 1051 (42S02): Unknown table 'whhtest.t1'
SELECT * FROM result1//

SET @a = 1//
CALL p()//
--sorted_result
SELECT * FROM result1//


--echo ##################(3)带有新信号信息的 RESIGNAL,更改错误信息 示例2 ※※ 15. 带有新信号信息的 RESIGNAL,mysql中改变错误号，ob中执行失败,ERROR 1235 (0A000): Not supported feature or function
DROP TABLE IF EXISTS t1//

DROP PROCEDURE IF EXISTS p//
CREATE PROCEDURE p ()
BEGIN
  DECLARE EXIT HANDLER FOR SQLEXCEPTION
  BEGIN
    SET @error_count = @error_count + 1;
    IF @a = 0 THEN
       RESIGNAL SET MYSQL_ERRNO = 5;
    END IF;
  END;
  DROP TABLE t1;
END//

SET @error_count = 0//
SET @a = 0//
--error 5
CALL p()//
--echo # MySql运行结果: ERROR 5 (42S02): Unknown table 'whhtest.t1'


--echo ##################(4)带有条件值和可选的新信号信息的 RESIGNAL，条件添加 示例3  ※※ 16. ob中不知道系统变量'max_error_count',ob中执行失败,ERROR 1235 (0A000): Not supported feature or function
DROP TABLE IF EXISTS t1//

DROP PROCEDURE IF EXISTS p//
CREATE PROCEDURE p ()
BEGIN
  DECLARE EXIT HANDLER FOR SQLEXCEPTION
  BEGIN
    SET @error_count = @error_count + 1;
    IF @a = 0 THEN
      RESIGNAL SQLSTATE '45000' SET MYSQL_ERRNO=5;
    END IF;
  END;
  DROP TABLE t1;
END//

SET @error_count = 0//
SET @a = 0//
SET @@max_error_count = 2//

--error 5
CALL p()//
--echo # MySql运行结果: ERROR 5 (45000): Unknown table 'whhtest.t1'

SHOW ERRORS//


--echo ##################(5)RESIGNAL需要条件处理程序上下文 示例4  ※※ 17. 和【14.】缺陷状况相同
DROP FUNCTION IF EXISTS f//
CREATE FUNCTION f () RETURNS INT
BEGIN
  RESIGNAL;
  RETURN 5;
END//

DROP PROCEDURE IF EXISTS p//
CREATE PROCEDURE p ()
BEGIN
  DECLARE EXIT HANDLER FOR SQLEXCEPTION SET @a=f();
  SIGNAL SQLSTATE '55555';
END//

--error 1645
CALL p()//
--echo # MySql运行结果: ERROR 1645 (0K000): RESIGNAL when handler not active


--echo ##################13.6.7.5 SIGNAL 声明(返回错误或警告条件)
--echo ##################(1.1)SQLSTATE值 SIGNAL不应以'00' 开头  ※※ 18. SQLSTATE值 SIGNAL以'00' 开头,mysql中执行失败，ob中执行成功
DROP TABLE IF EXISTS t1//

DROP PROCEDURE IF EXISTS p//
--error 1407
CREATE PROCEDURE p ()
BEGIN
  DECLARE EXIT HANDLER FOR SQLEXCEPTION
  BEGIN
    SIGNAL SQLSTATE '00110' ;
  END;
  DROP TABLE t1;
END//
--echo # MySql运行结果: ERROR 1407 (42000): Bad SQLSTATE: '00110'

--error 1305
CALL p()//
--echo # MySql运行结果: ERROR 1305 (42000): PROCEDURE whhtest.p does not exist


DROP PROCEDURE IF EXISTS p//
--error 1407
CREATE PROCEDURE p (divisor INT)
BEGIN
  DECLARE divide_by_zero CONDITION FOR SQLSTATE '00110';
  IF divisor = 0 THEN
    SIGNAL divide_by_zero;
  END IF;
END//
--echo # MySql运行结果: ERROR 1407 (42000): Bad SQLSTATE: '00110'

--error 1305
CALL p(0) //
--echo # MySql运行结果: ERROR 1305 (42000): PROCEDURE whhtest.p does not exist


--echo ##################(1.2)每个 condition_information_item_name只能在SET子句中指定一次 ※※ 19. SIGNAL 声明中，SET子句中信号信息指定多次，MySQL执行失败，ob中执行成功
DROP TABLE IF EXISTS t1//

DROP PROCEDURE IF EXISTS p//
--error 1641
CREATE PROCEDURE p ()
BEGIN
  DECLARE EXIT HANDLER FOR SQLEXCEPTION
  BEGIN
    SIGNAL SQLSTATE '45000' SET MYSQL_ERRNO = 1002, MYSQL_ERRNO = 1001;
  END;
  DROP TABLE t1;
END//
--echo # MySql运行结果: ERROR 1641 (42000): Duplicate condition information item 'MYSQL_ERRNO'

--error 1305
CALL p()//
--echo # MySql运行结果: ERROR 1305 (42000): PROCEDURE whhtest.p does not exist


--echo ##################(1.3)simple_value_specification 可以使用存储过程或函数参数、DECLARE声明的存储程序局部变量、用户定义变量、系统变量或文字来指定效指示符 ※※ 20. ob中SQLSTATE,MYSQL_ERRNO值没修改
DROP PROCEDURE IF EXISTS p//
CREATE PROCEDURE p (divisor INT,msg VARCHAR(100))
BEGIN

  DECLARE errorno INT;
  SET errorno = 5;

  IF divisor = 0 THEN
    SIGNAL SQLSTATE '45000'  SET MESSAGE_TEXT = msg, MYSQL_ERRNO = errorno;
  END IF;

END//

--error 5
CALL p(0,'message_text An error occurred') //
--echo # MySql运行结果: ERROR 5 (45000): message_text An error occurred


--echo ##################(2)条件信息项MESSAGE_TEXT赋值 示例2  ※※ 和23.异常情况相同
DROP TABLE IF EXISTS result1//
CREATE TABLE result1(
  id INT,
  res1 VARCHAR(100),
  res2 VARCHAR(100)
)//

DROP PROCEDURE IF EXISTS p//

CREATE PROCEDURE p (pval INT)
BEGIN
  DECLARE specialty CONDITION FOR SQLSTATE '45000';
  IF pval = 0 THEN
    INSERT INTO result1 VALUES(1,'结果表：', '存储过程p ()中处理程序执行完了，pval = 0');
    SIGNAL SQLSTATE '01000';
  ELSEIF pval = 1 THEN
    SIGNAL SQLSTATE '45000' SET MESSAGE_TEXT = 'An error occurred';
  ELSEIF pval = 2 THEN
    SIGNAL specialty SET MESSAGE_TEXT = 'An error occurred';
  ELSE
    SIGNAL SQLSTATE '01000' SET MESSAGE_TEXT = 'A warning occurred', MYSQL_ERRNO = 1000;
    SIGNAL SQLSTATE '45000' SET MESSAGE_TEXT = 'An error occurred', MYSQL_ERRNO = 1001;
  END IF;
END//

CALL p(0) //
SHOW WARNINGS//
--sorted_result
SELECT* FROM result1//

--error 1644
CALL p(1) //
--echo # MySql运行结果: ERROR 1644 (45000): An error occurred

--error 1644
CALL p(2) //
--echo # MySql运行结果: ERROR 1644 (45000): An error occurred

--error 1001
CALL p(3) //
--echo # MySql运行结果: ERROR 1001 (45000): An error occurred


--echo ##################(3)SIGNAL语句指示特定SQLSTATE值 示例3   ※※ 和22.异常情况相同
DROP PROCEDURE IF EXISTS p//
CREATE PROCEDURE p (divisor INT)
BEGIN
  IF divisor = 0 THEN
    SIGNAL SQLSTATE '22012';
  END IF;
END//

--error 1644
CALL p(0) //
--echo # MySql运行结果: ERROR 1644 (22012): Unhandled user-defined exception condition


--echo ##################(4)SIGNAL语句使用命名条件 示例4   ※※ 和22.异常情况相同
DROP PROCEDURE IF EXISTS p//
CREATE PROCEDURE p (divisor INT)
BEGIN
  DECLARE divide_by_zero CONDITION FOR SQLSTATE '22012';
  IF divisor = 0 THEN
    SIGNAL divide_by_zero;
  END IF;
END//

--error 1644
CALL p(0) //
--echo # MySql运行结果: ERROR 1644 (22012): Unhandled user-defined exception condition


--echo ##################(5)命名条件不在SIGNAL语句范围内
DROP PROCEDURE IF EXISTS p//
--error 1319
CREATE PROCEDURE p (divisor INT)
BEGIN
  BEGIN
    DECLARE divide_by_zero CONDITION FOR SQLSTATE '22012';
   END;
  BEGIN
    IF divisor = 0 THEN
      SIGNAL divide_by_zero;
    END IF;
  END;
END//
--echo # MySql运行结果: ERROR 1319 (42000): Undefined CONDITION: divide_by_zero

--error 1305
CALL p(0) //
--echo # MySql运行结果: ERROR 1305 (42000): PROCEDURE whhtest.p does not exist


--echo ##################(6)SIGNAL声明引用使用 MySQL 错误号 ※※ 21.SIGNAL引用使用 MySQL 错误号,mysql中创建时报错，ob中创建成功，调用时才报错
DROP PROCEDURE IF EXISTS p//
--error 1646
CREATE PROCEDURE p (divisor INT)
BEGIN
  DECLARE no_such_table CONDITION FOR 1051;
  IF divisor = 0 THEN
    SIGNAL no_such_table;
  END IF;
END//
--echo # MySql运行结果: ERROR 1646 (HY000): SIGNAL/RESIGNAL can only use a CONDITION defined with SQLSTATE

--error 1305
CALL p(0) //
--echo # MySql运行结果: ERROR 1305 (42000): PROCEDURE whhtest.p does not exist


--echo ##################(7)给定名称的条件在不同范围内多次声明，则应用具有最局部范围的声明 示例5 ※※ 22. SIGNAL语句通过使用命名条件指定SQLSTATE 值，mysql中错误信息的SQLSTATE值相应改变，ob中SQLSTATE值不受影响
DROP PROCEDURE IF EXISTS p//
CREATE PROCEDURE p (divisor INT)
BEGIN
  DECLARE my_error CONDITION FOR SQLSTATE '45000';
  IF divisor = 0 THEN
    BEGIN
      DECLARE my_error CONDITION FOR SQLSTATE '22012';
      SIGNAL my_error;
    END;
  END IF;
  SIGNAL my_error;
END//

--error 1644
CALL p(0) //
--echo # MySql运行结果: ERROR 1644 (22012): Unhandled user-defined exception condition

--error 1644
CALL p(1) //
--echo # MySql运行结果: ERROR 1644 (45000): Unhandled user-defined exception condition


--echo ##################(8)在异常处理程序中引发信号 示例6 ※※ 23. 条件信息项MESSAGE_TEXT赋值，mysql执行成功，ob中执行失败
DROP PROCEDURE IF EXISTS p//

CREATE PROCEDURE p ()
BEGIN
  DECLARE EXIT HANDLER FOR SQLEXCEPTION
  BEGIN
    SIGNAL SQLSTATE VALUE '99999' SET MESSAGE_TEXT = 'An error occurred';
  END;
  DROP TABLE no_such_table;
END//

--error 1644
CALL p()//
--echo # MySql运行结果: ERROR 1644 (99999): An error occurred


--echo ##################(9)在SIGNAL语句中为条件信息项赋值NULL是非法的 ※※ 24.在SIGNAL语句中为条件信息项赋值NULL,mysql中条件信息项赋值具体值时，错误信息会相应改变，赋值为NULL时，错误信息提示不允许赋值NULL，ob中无论赋值NULL还是具体值，错误信息都不变
DROP PROCEDURE IF EXISTS p//
CREATE PROCEDURE p ()
BEGIN
  DECLARE EXIT HANDLER FOR SQLEXCEPTION
  BEGIN
    SIGNAL SQLSTATE VALUE '99999' SET MYSQL_ERRNO = 1101;
  END;
  DROP TABLE no_such_table;
END//

--error 1101
CALL p()//
--echo # MySql运行结果: ERROR 1101 (99999): Unhandled user-defined exception condition


DROP PROCEDURE IF EXISTS p//
CREATE PROCEDURE p ()
BEGIN
  DECLARE EXIT HANDLER FOR SQLEXCEPTION
  BEGIN
    SIGNAL SQLSTATE VALUE '99999' SET MYSQL_ERRNO = NULL;
  END;
  DROP TABLE no_such_table;
END//

--error 1231
CALL p()//
--echo # MySql运行结果: ERROR 1231 (42000): Variable 'MYSQL_ERRNO' can't be set to the value of 'NULL'


--echo ##################13.6.7.6 处理程序的范围规则
--echo ##################(1)条件既不处理程序1也不处理程序2在范围内
DROP TABLE IF EXISTS result1//
CREATE TABLE result1(
  id INT,
  res1 VARCHAR(128),
  res2 VARCHAR(128)
)//

DROP PROCEDURE IF EXISTS p//
CREATE PROCEDURE p ()
BEGIN
  DECLARE EXIT HANDLER FOR NOT FOUND
  BEGIN
    INSERT INTO result1 VALUES(1,'结果表：','进入处理程序1 NOT FOUND');
  END;
  DECLARE EXIT HANDLER FOR SQLWARNING
  BEGIN
    INSERT INTO result1 VALUES(2,'结果表：','进入处理程序2  SQLWARNING');
  END;
  DROP TABLE no_such_table;
END//

--error 1051
CALL p ()//
--echo # MySql运行结果: ERROR 1051 (42S02): Unknown table 'whhtest.no_such_table'
--sorted_result
SELECT * FROM result1//


--echo ##################(2)处理程序仅在声明它的块的范围内，并且不能为发生在该块之外的条件激活
DROP TABLE IF EXISTS result1//
CREATE TABLE result1(
  id INT,
  res1 VARCHAR(128),
  res2 VARCHAR(128)
)//

DROP PROCEDURE IF EXISTS p//
CREATE PROCEDURE p ()
BEGIN
  BEGIN
    DECLARE EXIT HANDLER FOR SQLEXCEPTION
    BEGIN
      INSERT INTO result1 VALUES(1,'结果表：','进入处理程序 SQLEXCEPTION');
    END;
  END;

  DROP TABLE no_such_table2;
END//

--error 1051
CALL p ()//
--echo # MySql运行结果: ERROR 1051 (42S02): Unknown table 'whhtest.no_such_table2'
--sorted_result
SELECT * FROM result1//


--echo ##################(3)MySQL 错误代码处理程序优先于 SQLSTATE值处理程序
DROP TABLE IF EXISTS result1//
CREATE TABLE result1(
  id INT,
  res1 VARCHAR(128),
  res2 VARCHAR(128)
)//

DROP TABLE IF EXISTS article_tags//
CREATE TABLE article_tags(
  article_id INT NOT NULL PRIMARY KEY,
  tag_id INT
)//

INSERT INTO article_tags VALUES(1,2);

DROP PROCEDURE IF EXISTS insert_article_tags_3//
CREATE PROCEDURE insert_article_tags_3(IN article_id INT, IN tag_id INT)
BEGIN
 DECLARE EXIT HANDLER FOR 1062 INSERT INTO result1 VALUES(1,'结果表：','Duplicate keys error encountered') ;
 DECLARE EXIT HANDLER FOR SQLEXCEPTION INSERT INTO result1 VALUES(2,'结果表：','SQLException encountered') ;
 DECLARE EXIT HANDLER FOR SQLSTATE '23000' INSERT INTO result1 VALUES(3,'结果表：','SQLSTATE 23000') ;
 INSERT INTO article_tags(article_id,tag_id) VALUES(article_id,tag_id);
END//

CALL insert_article_tags_3(1,2)//
--sorted_result
SELECT * FROM result1//


--echo ##################(4)一个SQLSTATE值处理程序优先于一般SQLWARNING，SQLEXCEPTION或NOT FOUND处理程序
DROP TABLE IF EXISTS result1//
CREATE TABLE result1(
  id INT,
  res1 VARCHAR(128),
  res2 VARCHAR(128)
)//

DROP TABLE IF EXISTS article_tags//
CREATE TABLE article_tags(
  article_id INT NOT NULL PRIMARY KEY,
  tag_id INT
)//

INSERT INTO article_tags VALUES(1,2);

DROP PROCEDURE IF EXISTS insert_article_tags_3//
CREATE PROCEDURE insert_article_tags_3(IN article_id INT, IN tag_id INT)
BEGIN
 DECLARE EXIT HANDLER FOR SQLWARNING INSERT INTO result1 VALUES(1,'结果表：','SQLWARNING encountered') ;
 DECLARE EXIT HANDLER FOR SQLEXCEPTION INSERT INTO result1 VALUES(2,'结果表：','SQLException encountered') ;
 DECLARE EXIT HANDLER FOR SQLSTATE '23000' INSERT INTO result1 VALUES(3,'结果表：','SQLSTATE 23000') ;
 INSERT INTO article_tags(article_id,tag_id) VALUES(article_id,tag_id);
END//

CALL insert_article_tags_3(1,2)//
--sorted_result
SELECT * FROM result1//


--echo ##################(5)一个SQLEXCEPTION处理程序优先于SQLWARNING处理程序
DROP TABLE IF EXISTS result1//
CREATE TABLE result1(
  id INT,
  res1 VARCHAR(128),
  res2 VARCHAR(128)
)//

DROP TABLE IF EXISTS test//
CREATE TABLE IF NOT EXISTS test (
  int_notnull INT NOT NULL
 )//

DROP PROCEDURE IF EXISTS create_record//
CREATE PROCEDURE create_record (IN p INT)
BEGIN
  DECLARE EXIT HANDLER FOR SQLEXCEPTION INSERT INTO result1 VALUES(1,'结果表：','Handler for SQLEXCEPTION fired.') ;
  DECLARE EXIT HANDLER FOR SQLWARNING INSERT INTO result1 VALUES(2,'结果表：','Handler for SQLWARNING fired.') ;
  INSERT INTO test (int_notnull) VALUES (p);
END//

call create_record(NULL)//
--sorted_result
SELECT * FROM result1//


--echo ##################(6)局部作用域的处理程序优先于外部作用域中的处理程序，甚至优先于具有更特定条件的处理程序
DROP TABLE IF EXISTS result1//
CREATE TABLE result1(
  id INT,
  res1 VARCHAR(128),
  res2 VARCHAR(128)
)//

DROP TABLE IF EXISTS article_tags//
CREATE TABLE article_tags(
  article_id INT NOT NULL PRIMARY KEY,
  tag_id INT
)//

INSERT INTO article_tags VALUES(1,2);

DROP PROCEDURE IF EXISTS insert_article_tags_3//
CREATE PROCEDURE insert_article_tags_3(IN article_id INT, IN tag_id INT)
BEGIN
 DECLARE EXIT HANDLER FOR 1062 INSERT INTO result1 VALUES(1,'结果表：','Duplicate keys error encountered') ;
 BEGIN
   DECLARE EXIT HANDLER FOR SQLEXCEPTION INSERT INTO result1 VALUES(2,'结果表：','SQLException encountered') ;
   INSERT INTO article_tags(article_id,tag_id) VALUES(article_id,tag_id);
 END;
END//

CALL insert_article_tags_3(1,2)//
--sorted_result
SELECT * FROM result1//


--echo ##################(7)SQLEXCEPTION条件没有合适的处理程序，存储的程序在引发条件的语句处终止.如果该程序被另一个存储的程序调用，则调用程序使用应用于其自己的处理程序的处理程序选择规则来处理条件
DROP TABLE IF EXISTS result1//
CREATE TABLE result1(
  id INT,
  res1 VARCHAR(128),
  res2 VARCHAR(128)
)//

DROP PROCEDURE IF EXISTS p//
CREATE PROCEDURE p ()
BEGIN
  DECLARE EXIT HANDLER FOR NOT FOUND INSERT INTO result1 VALUES(1,'结果表：','进入p 处理程序 NOT FOUND');
  DROP TABLE no_such_table1;
  INSERT INTO result1 VALUES(2,'结果表：','继续执行');
END//

--error 1051
CALL p ()//
--echo # MySql运行结果: ERROR 1051 (42S02): Unknown table 'whhtest.no_such_table1'
--sorted_result
SELECT * FROM result1//

DROP PROCEDURE IF EXISTS p2//
CREATE PROCEDURE p2 ()
BEGIN
  DECLARE EXIT HANDLER FOR SQLEXCEPTION INSERT INTO result1 VALUES(2,'结果表：','进入p2 处理程序 SQLEXCEPTION');
  CALL p ();
END//

CALL p2()//
--sorted_result
SELECT * FROM result1//


--echo ##################(8)SQLWARNING条件发生时没有合适的处理程序，程序继续执行
DROP TABLE IF EXISTS result1//
CREATE TABLE result1(
  id INT,
  res1 VARCHAR(128),
  res2 VARCHAR(128)
)//

DROP TABLE IF EXISTS test//
CREATE TABLE IF NOT EXISTS test (
  int_notnull INT NOT NULL
 )//

DROP PROCEDURE IF EXISTS create_record//
CREATE PROCEDURE create_record (IN p INT)
BEGIN
  DECLARE EXIT HANDLER FOR NOT FOUND INSERT INTO result1 VALUES(1,'结果表：','Handler for NOT FOUND fired.') ;
  DROP TABLE IF EXISTS noresult1;
  INSERT INTO result1 VALUES(2,'结果表：','程序继续执行.') ;
END//

CALL create_record(NULL)//
SHOW warnings//
--sorted_result
SELECT * FROM result1//


--echo ##################(9)如果发生没有声明处理程序的情况，对于NOT FOUND条件，如果条件被正常抛出，则操作为CONTINUE  ※※25. MySQL中执行终断，ob中处理继续
DROP TABLE IF EXISTS t1//
CREATE TABLE t1(
  id CHAR(16),
  data INT
)//

DROP TABLE IF EXISTS t3//
CREATE TABLE t3(
  a CHAR(16),
  b INT
)//

DROP PROCEDURE IF EXISTS `curdemo`//
CREATE PROCEDURE curdemo()
BEGIN
  DECLARE a CHAR(16);
  DECLARE b INT;
  DECLARE cur1 CURSOR FOR SELECT id,data FROM t1;
  OPEN cur1;
  FETCH cur1 INTO a, b;
  INSERT INTO t3 VALUES (a,b);
  SELECT a,b;
  CLOSE cur1;
  INSERT INTO t3 VALUES ('程序curdemo继续执行',1);
END//
--error 1329
CALL curdemo()//
--echo # MySql运行结果: ERROR 1329 (02000): No data - zero rows fetched, selected, or processed
SELECT * FROM t3//


--echo ##################(10)NOT FOUND条件发生时没有合适的处理程序，由SIGNAL或RESIGNAL引发，则动作为 EXIT
DROP TABLE IF EXISTS t3//
CREATE TABLE t3(
  a CHAR(16),
  b INT
)//

DROP PROCEDURE IF EXISTS `p`//
CREATE PROCEDURE p (pval INT)
BEGIN
  DECLARE specialty CONDITION FOR SQLSTATE '45000';
  IF pval = 0 THEN
    SIGNAL SQLSTATE '01000';
  ELSE
    SIGNAL SQLSTATE '02000' SET  MYSQL_ERRNO = 1000;
  END IF;
  INSERT INTO t3 VALUES ('程序p继续执行',2);
END//

--error 1000
CALL p(1)//
--echo # MySql运行结果: ERROR 1000 (02000): Unhandled user-defined not found condition

SELECT * FROM t3//


--echo ##################(11)处理程序选择规则 示例1   SQLSTATE优先于SQLEXCEPTION
DROP TABLE IF EXISTS result1//
CREATE TABLE result1(
  id INT,
  res1 VARCHAR(128),
  res2 VARCHAR(128)
)//

DROP PROCEDURE IF EXISTS `p1`//
CREATE PROCEDURE p1()
BEGIN
  DECLARE CONTINUE HANDLER FOR SQLSTATE '42S02' INSERT INTO result1 VALUES(1,'结果表：','SQLSTATE handler was activated');
  DECLARE CONTINUE HANDLER FOR SQLEXCEPTION INSERT INTO result1 VALUES(2,'结果表：','SQLEXCEPTION handler was activated');

  DROP TABLE no_such_table;
END//

CALL p1()//
--sorted_result
SELECT * FROM result1//


--echo ##################(12)处理程序选择规则 示例2   局部处理程序优先
DROP TABLE IF EXISTS result1//
CREATE TABLE result1(
  id INT,
  res1 VARCHAR(128),
  res2 VARCHAR(128)
)//

DROP PROCEDURE IF EXISTS `p2`//
CREATE PROCEDURE p2()
BEGIN
  DECLARE CONTINUE HANDLER FOR SQLSTATE '42S02' INSERT INTO result1 VALUES(1,'结果表：','SQLSTATE handler was activated');
  BEGIN
    DECLARE CONTINUE HANDLER FOR SQLEXCEPTION INSERT INTO result1 VALUES(2,'结果表：','SQLEXCEPTION handler was activated');
    DROP TABLE no_such_table;
  END;
END//

CALL p2()//
--sorted_result
SELECT * FROM result1//


--echo ##################(13)处理程序选择规则 示例3  选择同一范围内的处理程序
DROP TABLE IF EXISTS result1//
CREATE TABLE result1(
  id INT,
  res1 VARCHAR(128),
  res2 VARCHAR(128)
)//

DROP PROCEDURE IF EXISTS `p3`//
CREATE PROCEDURE p3()
BEGIN
  DECLARE CONTINUE HANDLER FOR SQLEXCEPTION INSERT INTO result1 VALUES(1,'结果表：','同一范围内SQLEXCEPTION handler was activated');
  BEGIN
    DECLARE CONTINUE HANDLER FOR SQLSTATE '42S02' INSERT INTO result1 VALUES(2,'结果表：','范围外SQLSTATE 42S02 handler was activated');
  END;
  DROP TABLE no_such_table;
END//

CALL p3()//
--sorted_result
SELECT * FROM result1//


--echo ##################(14)处理程序选择规则 示例4 范围外的处理程序不能使用
DROP TABLE IF EXISTS result1//
CREATE TABLE result1(
  id INT,
  res1 VARCHAR(128),
  res2 VARCHAR(128)
)//

DROP PROCEDURE IF EXISTS `p4`//
CREATE PROCEDURE p4()
BEGIN
  BEGIN
    DECLARE CONTINUE HANDLER FOR SQLEXCEPTION INSERT INTO result1 VALUES(1,'结果表：','SQLEXCEPTION handler was activated');
    DECLARE CONTINUE HANDLER FOR SQLSTATE '42S02' INSERT INTO result1 VALUES(2,'结果表：','SQLSTATE handler was activated');
  END;
  DROP TABLE no_such_table;
END//
--error 1051
CALL p4()//
--echo # MySql运行结果: ERROR 1051 (42S02): Unknown table 'zh_db.no_such_table'
--sorted_result
SELECT * FROM result1//


--enable_warnings
delimiter ;//

