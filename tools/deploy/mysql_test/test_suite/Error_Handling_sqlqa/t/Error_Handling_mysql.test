disconnect conn1;
connect (sys_conn,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection sys_conn;

--disable_warnings
#drop tenant dbmsjob1_tenant force;
#drop resource pool if exists dbmsjob1_pool;
#drop resource unit if exists dbmsjob1_unit;
--enable_warnings
sleep 10;
disconnect sys_conn;




