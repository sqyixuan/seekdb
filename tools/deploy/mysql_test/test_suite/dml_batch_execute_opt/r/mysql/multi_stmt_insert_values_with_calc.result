|         0 |                     1 | insert into t1 values(mod(?, (? div ?) + ?), mod(mod(? + ?, ?), ? + ?), mod((?+?+?), ?), mod(?, ? * ?)) | insert into t1 values(mod(3, (1 div 1) + 1), mod(mod(1 + 4, 4), 2 + 2), mod((1+1+1), 2), mod(4, 2 * 2));insert into t1 values(mod(4, (2 div 1) + 2), mod(mod(3 + 5, 6), 3 + 3), mod((2+2+2), 4), mod(4, 3 * 2));insert into t1 values(mod(9, (4 div 2) + 4), mod(mod(5 + 4, 4), 1 + 1), mod((3+2+4), 4), mod(4, 3 * 3));insert into t1 values(mod(13, (9 div 3) + 6), mod(mod(8 + 3, 7), 3 + 0), mod((5+5+5), 11), mod(13, 4 * 1)); |
|         0 |                     1 | insert into t1 values(? + ? + ?, ? + ? - ?, ? * ? - ?, ?/?+?)                                           | insert into t1 values(1 + 1 + 0, 1 + 2 - 1, 1 * 2 - 2, 3/1+2);insert into t1 values(2 + 2 + 1, 2 + 4 - 2, 2 * 3 - 3, 4/2+3);insert into t1 values(3 + 3 + 2, 3 + 4 - 3, 3 * 4 - 3, 9/3+5);                                                                                                                                                                                                                                          |
|         1 |                     1 | insert into t1 values(ABS(? + ? -?), ABS(? + ? - ?), ABS(? + ? - ?), ?)                                 | insert into t1 values(ABS(1 + 10 -12), ABS(2 + 2 - 3), ABS(3 + 1 - 4), 1);insert into t1 values(ABS(3 + 10 -15), ABS(3 + 3 - 8), ABS(4 + 2 - 4), 2);                                                                                                                                                                                                                                                                                |
+-----------+-----------------------+---------------------------------------------------------------------------------------------------------+-------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------+
affected rows: 3
drop table t1;
