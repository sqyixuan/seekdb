## test for global index
create table t5(c1 int primary key, c2 decimal(10, 3), c3 varchar(20), c4 tinyint, c5 date) partition by hash(c1) partitions 3;
create unique index t5_idx_01 on t5(c3) global;
insert into t5 values(1,1.11,'1',1,'2022-02-02'),(2,2.22, '2', 2, '2022-02-03'),(3 , 3.33 , '3', 3, '2022-02-04'),(4,4.4,'4',4,'2022-02-05');
insert into t5 values(6,6.666,'6',6,'2022-02-06'),(7, 7.77,'7' , 7, '2022-02-07');
