drop table if exists t1, t2, t3, t4, t5, t6, t9;
result_format: 4

create table t1(c1 int primary key, c2 int, c3 varchar(20), c4 decimal(10,3), c5 enum('car','bicycle','bus','train'), c6 timestamp default 0, c7 datetime, c8 varchar(20));
