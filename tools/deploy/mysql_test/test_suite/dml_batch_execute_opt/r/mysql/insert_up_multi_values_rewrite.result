select hit_count, is_batched_multi_stmt, statement from oceanbase.gv$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t1 values%' order by hit_count;
+-----------+-----------------------+-------------------------------------------------------------------------------------------------------------------------------+
| hit_count | is_batched_multi_stmt | statement                                                                                                                     |
+-----------+-----------------------+-------------------------------------------------------------------------------------------------------------------------------+
|         0 |                     0 | insert into t1 values(?,?+?,?+?),(?,?+?,?+?),(?,?+?,?+?),(?,?+?,?+?) on duplicate key update c2 = values(c2), c3 = values(c3) |
|         0 |                     0 | insert into t1 values(?,?+?,?+?),(? ,?+?, ?+?) on duplicate key update c2 = values(c2), c3 = values(c3)                       |
|         1 |                     1 | insert into t1 values(?,?+?,?+?) on duplicate key update c2 = c2 + ?, c3 = c3 + ?                                             |
+-----------+-----------------------+-------------------------------------------------------------------------------------------------------------------------------+
drop table t1;

create table t2(c1 int auto_increment, c2 varchar(20) primary key, c3 int);
insert into t2(c2, c3) values('1',1),('2',2),('3',3);
insert into t2(c2, c3) values('4',4),('5',5),('6',6);
select * from t2;
