| c1 | c2   | c3   |
+----+------+------+
|  1 |  101 |   11 |
|  2 |  102 |   12 |
|  3 |    3 |    3 |
|  4 |  104 |   14 |
|  6 |    6 |    6 |
|  7 |    7 |    7 |
|  8 |    8 |    8 |
|  9 |    9 |    9 |
| 10 |   10 |   10 |
| 11 |   11 |   11 |
| 12 |   12 |   12 |
| 13 |   13 |   13 |
+----+------+------+
insert into t1 values(((9)),(9),((9))),(((10)),(10),((10))),(((11)), (11), ((11))) on duplicate key update c2 = 99, c3 = 100;
