drop table if exists t1, t2, t3, t4, t5, t6, t9;
result_format: 4
create table t1(c1 int primary key, c2 int, c3 int);
insert into t1 values(1,1,1),(2,2,2),(3,3,3),(4,4,4),(1,1,1),(2,2,2) on duplicate key update c2 = c2 + 100, c3 = c3 + 10;
insert into t1 values(4,4,4),(6, 6, 6),(7,7,7),(8,8,8) on duplicate key update c2 = c2 + 100, c3 = c3 + 10;
insert into t1 values(((9)),(9),((9))),(((10)),(10),((10))),(((11)), (11), ((11))) on duplicate key update c2 = c2, c3 = c3;
insert into t1 values(((12)),(12),((12))),(((13)),(13),((13))) on duplicate key update c2 = c2, c3 = c3;
select * from t1;
