select hit_count, is_batched_multi_stmt, statement from oceanbase.gv$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t1%' order by hit_count;
+-----------+-----------------------+---------------------------------------------------------------------------------+
| hit_count | is_batched_multi_stmt | statement                                                                       |
+-----------+-----------------------+---------------------------------------------------------------------------------+
|         0 |                     1 | insert into t1 values(((?)),(?),((?))) on duplicate key update c2 = ?, c3 = ?   |
|         1 |                     1 | insert into t1 values(?,?,?) on duplicate key update c2 = c2 + ?, c3 = c3 + ?   |
|         1 |                     1 | insert into t1 values(((?)),(?),((?))) on duplicate key update c2 = c2, c3 = c3 |
+-----------+-----------------------+---------------------------------------------------------------------------------+
