create table t5(c1 int, c2 int, c3 varchar(20), c4 int);

insert into t5 values(1,1+1,concat('1','1'),1-1),(2,2+2,concat('2','2'),2-1),(3,3+3,concat('3','3'),3-1);
insert into t5 values(1,1+1,concat('1','1'),1-1),(2,2+2,concat('2',2),2-1),(3,3+3,concat('3','3'),3-1);
insert into t5 values(7,7,'7',7),(8,8,'8',8+8),(9,9,'9',9+0);

select * from t5;
