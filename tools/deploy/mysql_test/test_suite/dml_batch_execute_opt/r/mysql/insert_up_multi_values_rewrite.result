## test plan can't reuse
create table t4(c1 int, c2 varchar(20), c3 varchar(20));
insert into t4 values(1, cast('111' as char(3)), '1'),(2, cast('222' as char(3)), '2'),(3, cast('333' as char(3)), '3');
insert into t4 values(11, cast('111' as char(3)), '11'),(12, cast('222' as char(3)), '12');
insert into t4 values(21, cast('111' as char(10)), '21'),(22, cast('222' as char(10)), '22');
insert into t4 values(5, cast('555' as char(10)), '5'),(6, cast('666' as char(12)), '6');

