--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: laibingzheng.lbz
# owner group: IMF
# description: batch insert with auto_increment
# tags: dml
#
# test of insert with multi_values optimization
#
--disable_warnings
drop table if exists t1,t2;
--enable_warnings
--enable_info
--result_format 4

--disable_query_log
--disable_result_log
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
alter system flush plan cache global;
connection default;
alter system set ob_enable_batched_multi_statement=true;
sleep 5;
--enable_result_log
--enable_query_log

CREATE TABLE `t1` (`id` INT(11) NOT NULL AUTO_INCREMENT,`val` INT(11) DEFAULT NULL,PRIMARY KEY (`id`),UNIQUE KEY `i1` (`val`)) ;
INSERT INTO t1 (val) VALUES (1),(2);
select * from t1;
insert into t1 values ();
select * from t1;
drop table t1;

create table t2 (c1 INT(11) NOT NULL AUTO_INCREMENT, c2 INT(11) DEFAULT NULL,PRIMARY KEY(c1));
delimiter //;
insert into t2(c2) values(1);insert into t2(c2) values(2);//
delimiter ;//
insert into t2 values ();
select * from t2;
drop table t2;

## 默认暂时还是关闭batch优化的开关
alter system set ob_enable_batched_multi_statement=false;
