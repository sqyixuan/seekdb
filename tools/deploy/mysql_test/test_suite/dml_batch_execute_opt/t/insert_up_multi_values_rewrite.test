--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: laibingzheng.lbz
# owner group: SQL2
# description: test of batch insert optimization
# tags: dml

--disable_warnings
drop table if exists t1, t2, t3, t4, t5, t6, t9;
--enable_warnings
--result_format 4

--disable_query_log
--disable_result_log
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
alter system flush plan cache global;
sleep 3;
connection default;
--enable_result_log
--enable_query_log

create table t1(c1 int primary key, c2 int, c3 int);
insert into t1 values(1,1,1),(2,2,2),(3,3,3),(4,4,4),(1,1,1),(2,2,2) on duplicate key update c2 = c2 + 100, c3 = c3 + 10;
insert into t1 values(4,4,4),(6, 6, 6),(7,7,7),(8,8,8) on duplicate key update c2 = c2 + 100, c3 = c3 + 10;
insert into t1 values(((9)),(9),((9))),(((10)),(10),((10))),(((11)), (11), ((11))) on duplicate key update c2 = c2, c3 = c3;
insert into t1 values(((12)),(12),((12))),(((13)),(13),((13))) on duplicate key update c2 = c2, c3 = c3;
select * from t1;
insert into t1 values(((9)),(9),((9))),(((10)),(10),((10))),(((11)), (11), ((11))) on duplicate key update c2 = 99, c3 = 100;
select * from t1;

--disable_warnings
select hit_count, is_batched_multi_stmt, statement from oceanbase.gv$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t1%' order by hit_count;
--enable_warnings

--error 1064
insert into t1 values(4,4,4),(6, 6, 6),(7,7,7),(8,8,8) on duplicate ke update c2 = c2 + 100, c3 = c3 + 10;

--error 1064
insert into t1 values(4,4,4),(6, 6, 6),(7,7,7),(8,8,8) on key update c2 = c2 + 100, c3 = c3 + 10;

--error 1064
insert into t1 values(4,4,4),(6, 6, 6),(7,7,7),(8,8,8) on duplicate key update set c2 = c2 + 100, c3 = c3 + 10;

--error 1064
insert into t1 values(4,4,4),(6, 6, 6),(7,7,7),(8,8,8) on duplicate key c2 = c2 + 100, c3 = c3 + 10;

--error 1064
insert into values(4,4,4),(6, 6, 6),(7,7,7) on duplicate key update c2 = c2 + 100, c3 = c3 + 10;

--error 1064
insert into t1 values(4,4,4)(6,6,6)(7,7,7) on duplicate key update c2 = c2 + 100, c3 = c3 + 10;

--error 1064
insert into t1 values(4,4,4),(6,6,6),(7,7,7) on duplicate key update c2 = c2 + 100 c3 = c3 + 10;

--error 1064
insert into t1 values(4,4,4),(6,6,6),(7,7,7) on duplicate key update c2 =;

--error 1064
insert into t1 values(4,4,4),(6,6,6),(7,7,7) on duplicate key update c2 + 100;

delete from t1;

alter system flush plan cache global;

insert into t1 values(1,1+1,1+1),(2,2+1,2+1),(3,3+1,3+1),(1,1+1,1+1) on duplicate key update c2 = c2 + 100, c3 = c3 + 10;
insert into t1 values(10,10+1,10+1),(12,12+1,12+1),(13,13+1,13+1),(10,10+1,10+1) on duplicate key update c2 = c2 + 100, c3 = c3 + 10;

## can't do batch , Can't find the values token position exactly
insert into t1 values(10,10+1,10+1),(12,12+1,12+1),(13,13+1,13+1),(10,10+1,10+1) on duplicate key update c2 = values(c2), c3 = values(c3);
insert into t1 values(10,10+10,10+10),(12 ,12+12, 12+12) on duplicate key update c2 = values(c2), c3 = values(c3);
select * from t1;

--disable_warnings
select hit_count, is_batched_multi_stmt, statement from oceanbase.gv$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t1 values%' order by hit_count;
--enable_warnings

drop table t1;

create table t2(c1 int auto_increment, c2 varchar(20) primary key, c3 int);
insert into t2(c2, c3) values('1',1),('2',2),('3',3);
insert into t2(c2, c3) values('4',4),('5',5),('6',6);
select * from t2;

--disable_warnings
select hit_count, is_batched_multi_stmt, statement from oceanbase.gv$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t2%' order by hit_count;
--enable_warnings
drop table t2;


create table t3(c1 int, c2 int, c3 int);
--error 1136
insert into t3 values(1,1),(2,2),(3,3);
insert into t3(c2,c3) values(1,1),(2,2 ),(3 , 3);
insert into t3(c2,c3) values(1,1),( 2 ,2 ),( 3, 3);
select * from t3;
--disable_warnings
select hit_count, is_batched_multi_stmt, statement from oceanbase.gv$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t3%' order by hit_count;
--enable_warnings
drop table t3;

## test plan can't reuse

# 1. not params info not match
create table t4(c1 int, c2 varchar(20), c3 varchar(20));
# can batch execute
insert into t4 values(1, cast('111' as char(3)), '1'),(2, cast('222' as char(3)), '2'),(3, cast('333' as char(3)), '3');
# must match the plan
insert into t4 values(11, cast('111' as char(3)), '11'),(12, cast('222' as char(3)), '12');
# can't match pre_plan
insert into t4 values(21, cast('111' as char(10)), '21'),(22, cast('222' as char(10)), '22');
# can't batch
insert into t4 values(5, cast('555' as char(10)), '5'),(6, cast('666' as char(12)), '6');

select * from t4;
--disable_warnings
select hit_count, is_batched_multi_stmt, statement from oceanbase.gv$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t4%' order by hit_count;
--enable_warnings

alter system flush plan cache global;

# can't use batch
insert into t4 values(7,'7',SUBSTR('777',2)),(8,'8',SUBSTR('888',3)),(9,'9',SUBSTR('999',1));
# can batch
insert into t4 values(17,'17',SUBSTR('777',2)),(18,'18',SUBSTR('999',2)),(19,'19',SUBSTR('000',2));
# can batch and can hit plan
insert into t4 values(21,'21',SUBSTR('222',2)),(22,'22',SUBSTR('888',2));
# can batch but can't hit plan
insert into t4 values(31,'31',SUBSTR('333',1)),(32,'32',SUBSTR('888',1));
select * from t4;

--disable_warnings
select hit_count, is_batched_multi_stmt, statement from oceanbase.gv$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t4%' order by hit_count;
--enable_warnings
drop table t4;

create table t5(c1 int, c2 int, c3 varchar(20), c4 int);

# can batch
insert into t5 values(1,1+1,concat('1','1'),1-1),(2,2+2,concat('2','2'),2-1),(3,3+3,concat('3','3'),3-1);
# can't batch
insert into t5 values(1,1+1,concat('1','1'),1-1),(2,2+2,concat('2',2),2-1),(3,3+3,concat('3','3'),3-1);
# can't batch
insert into t5 values(7,7,'7',7),(8,8,'8',8+8),(9,9,'9',9+0);

select * from t5;
delete from t5;

# can't batch
insert into t5 values(7,7,'7' + '7',7),(8,8,'8' + '8',8),(9,9,'9' + 9,9);
select * from t5;

--disable_warnings
select hit_count, is_batched_multi_stmt, statement from oceanbase.gv$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t5%' order by hit_count;
--enable_warnings

drop table t5;

create table t6(c1 varchar(20));
insert into t6 values(concat(1,1)),(concat(2,2));
insert into t6 values(concat('1','1')),(concat('2','2'));
select * from t6;
--disable_warnings
select hit_count, is_batched_multi_stmt, statement from oceanbase.gv$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t6%' order by hit_count;
--enable_warnings
drop table t6;



