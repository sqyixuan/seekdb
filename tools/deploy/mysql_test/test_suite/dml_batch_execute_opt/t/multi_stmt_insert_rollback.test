--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: laibingzheng.lbz
# owner group: DML
# description: foobar
# tags: dml
#
# test of batch stmt insert optimization
#
--disable_warnings
drop table if exists t1;
--enable_warnings
--enable_info
--result_format 4

--disable_query_log
--disable_result_log
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
alter system flush plan cache global;
sleep 3;
connection default;
alter system set _rowsets_enabled=false;
set autocommit = false;
alter system set ob_enable_batched_multi_statement=true;
--enable_result_log
--enable_query_log

sleep 6;
create table t1(c1 bit(64),c2 bit(64));
delimiter //;
insert into t1 values(111,111);insert into t1 values(b'1001',b'1001');//
insert into t1 values(10,10);insert into t1 values(11,11);//
insert into t1 values(100,100);insert into t1 values(120,120);insert into t1 values(b'111',b'1101');//
delimiter ;//
commit;
select bin(c1),bin(c2) from t1;
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.GV$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t1 values%';
drop table t1;

alter system set _rowsets_enabled=true;
set autocommit = true;
alter system set ob_enable_batched_multi_statement=false;
