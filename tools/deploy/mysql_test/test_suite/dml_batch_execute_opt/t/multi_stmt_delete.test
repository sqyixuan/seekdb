--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: laibingzheng.lbz
# owner group: SQL2
# description: foobar
# tags: dml
#
# test of batch stmt delete optimization
#

--disable_warnings
drop table if exists t1,t2,t3,t4,t5,t6;
--enable_warnings
--enable_info
--result_format 4

--disable_query_log
--disable_result_log
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
alter system flush plan cache global;
sleep 3;
connection default;
alter system set _rowsets_enabled=false;
sleep 3;
--enable_result_log
--enable_query_log

set autocommit = false;
alter system set ob_enable_batched_multi_statement=true;
sleep 6;

create table t1(a int, b int, c int);
insert into t1 values(1,1,1),(2,2,2),(3,3,3),(4,4,4),(5,5,5),(6,6,6),(7,7,7);
commit;
delimiter //;
delete from t1 where a = 1;delete from t1 where a = 2;delete from t1 where a = 3;//
delimiter ;//
select * from t1;
rollback;
delimiter //;
delete from t1 where a = 1 + 1;delete from t1 where a = 1 + 2;delete from t1 where a = 1 + 3;//
delete from t1 where a = 2 + 3;delete from t1 where a = 3 + 3;delete from t1 where a = 3 + 4;//
delimiter ;//
select * from t1;
commit;

--disable_warnings
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.gv$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete from t1 where a = %' order by hit_count;
--enable_warnings
drop table t1;

create table t3(c1 int, c2 varchar(20), c3 text, c4 date);
delimiter //;
insert into t3 values(1,'a','abcd','2020-2-2');insert into t3 values(2,'2','222','2020-2-3');//
insert into t3 values(3,'c','3333','2020-3-1');insert into t3 values(4,'4','444','2020-4-1');insert into t3 values(5,'5','555','2020-5-1');//
delimiter ;//
insert into t3 values(6,'6','6666','2020-6-1');
insert into t3 values(7,'7','777','2020-7-1');
insert into t3 values(8,'8','88888','2020-8-1');
insert into t3 values(9,'9','999','2020-9-1');
insert into t3 values(10,'10','1010','2020-10-1');
insert into t3 values(11,'11','1111','2020-11-1');
insert into t3 values(12,'12','1212','2020-12-1');

commit;
delimiter //;
delete from t3 where c1 > 0 and c1 < 3;delete from t3 where c1 > 2 and c1 < 6;//
delete from t3 where c1 > 6/2 and c1 < 6/1;delete from t3 where c1 > 24/4 and c1 < 12/1;//
delimiter ;//
select * from t3 order by c1;
rollback;

delimiter //;
delete from t3 where c2 = 'a' and c3 = 'abcd';delete from t3 where c2 = '2' and c3 = '222';//
delete from t3 where c4 = '2020-7-1' or c1 = 6;delete from t3 where c4 = '2020-8-1' or c1 = 5;//
delete from t3 where c4 = '2020-9-1' or c1 = 11;delete from t3 where c4 = '2020-10-1' or c1 = 12;//
delimiter ;//
select * from t3 order by c1;

--disable_warnings
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.gv$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete from t3 where %' order by hit_count;
--enable_warnings

drop table t3;

## test subquery will rollback with single execution
create table t1(c1 int, c2 int, c3 int);
insert into t1 values(1,1,1),(2,2,2),(3,3,3),(4,4,4),(5,5,5),(6,6,6),(7,7,7),(8,8,8);
create table t2(c1 int, c2 int, c3 int);
insert into t2 values(1,1,1),(2,2,2),(3,3,3),(4,4,4),(5,5,5),(6,6,6),(7,7,7),(8,8,8);
commit;

delimiter //;
delete from t1 where t1.c1 = (select t2.c1 from t2 where t2.c1 = 1);delete from t1 where t1.c1 = (select t2.c1 from t2 where t2.c1 = 2);//
delimiter ;//
select * from t1;

--disable_warnings
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.gv$OB_PLAN_CACHE_PLAN_STAT where statement like 'delete from t1 where t1.c1 %' order by hit_count;
--enable_warnings

drop table t1;
drop table t2;

## test delete the same row with seconds times
create table t1(c1 int, c2 int, c3 int, primary key(c1, c2)) partition by hash(c1) partitions 4;
create index t1_idx_01 on t1(c3);

delimiter //;
insert into t1 values(1,1,1);insert into t1 values(2,2,2);insert into t1 values(3,3,3);insert into t1 values(4,4,4);insert into t1 values(5,5,5);insert into t1 values(6,6,6);insert into t1 values(7,7,7);insert into t1 values(8,8,8);//
delete from t1 where c1 = 1 or c1 = 2;delete from t1 where c1 = 1 or c1 = 2;delete from t1 where c1 = 3 or c1 = 4;//
delimiter ;//
select * /*+index(t1 t1_idx_01)*/ from t1 order by c1;

drop table t1;

alter system set _rowsets_enabled=true;
set autocommit = true;
alter system set ob_enable_batched_multi_statement=false;
