--enable_warnings

create table test1(h1 int,h2 char(10));
insert into test1 values(-5,'柳树');
insert into test1 values(0,'垂杨柳');
insert into test1 values(10,'杨柳');
select * from test1 order by h1 asc;
delimiter //;
UPDATE test1 SET h2 = CASE WHEN h2 = '杨柳' THEN '向日葵花' ELSE h2 END;UPDATE test1 SET h2 = CASE WHEN h2 = '向日葵花' THEN '玫瑰花' ELSE h2 END;//
UPDATE test1 SET h2 = CASE WHEN h2 = '玫瑰花' THEN '国花' ELSE h2 END;//
delimiter ;//
select * from test1 order by h1 asc;
drop table test1;

alter system set ob_enable_batched_multi_statement=false;
drop table sbtest_hash1;

--disable_query_log
--disable_result_log
connection obsys;
eval alter tenant sys set primary_zone='zone1';
connection default;
eval set global ob_plan_cache_percentage = $def_plan_cache_percentage;
alter system set _rowsets_enabled=true;
--enable_result_log
--enable_query_log
