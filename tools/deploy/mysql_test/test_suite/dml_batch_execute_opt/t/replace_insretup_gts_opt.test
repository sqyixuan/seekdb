--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: laibingzheng.lbz
# owner group: IMF
# description: foobar
# tags: dml
#
# test of insert with multi_values optimization
#
--disable_warnings
drop table if exists t1,t2,t3,t4,t5;
--enable_warnings
--enable_info
--result_format 4

--disable_query_log
--disable_result_log
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
alter system set_tp tp_no = 401, error_code = 5, frequency = 1;
alter system set_tp tp_no = 402, error_code = 5, frequency = 1;
connection default;
sleep 5;
--enable_result_log
--enable_query_log

