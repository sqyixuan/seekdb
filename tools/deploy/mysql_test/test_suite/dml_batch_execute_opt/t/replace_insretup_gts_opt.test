drop table t2;

create table t5 (c1 int primary key, c2 int) partition by hash(c1) (partition `p0`, partition `p1`, partition `p2`);
create unique index t5_idx on t5(c2) global;
insert into t5 values(1, 1), (2, 2), (3, 3);
replace into t5 values(6, 1);
replace into t5 values(9, 2);
replace into t5 values(12, 3);
select * from t5;
delete from t5;
insert into t5 values(1, 1), (2, 2), (3, 3);
insert into t5 values(6, 1) on duplicate key update c1 = values(c1);
insert into t5 values(9, 2) on duplicate key update c1 = values(c1);
insert into t5 values(15, 3) on duplicate key update c1 = values(c1);
select * from t5;
drop table t5;

