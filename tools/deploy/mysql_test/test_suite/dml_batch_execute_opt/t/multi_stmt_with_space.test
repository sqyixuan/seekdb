--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: laibingzheng.lbz
# owner group: IMF
# description: foobar
# tags: dml
#
# Spaces at the beginning and end of the test statement do not affect batch optimization
#

--disable_warnings
drop table if exists t1,t2,t3,t4,t5,t6;
--enable_warnings
--enable_info
--result_format 4

--disable_query_log
--disable_result_log
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
alter system flush plan cache global;
connection default;
sleep 3;
--enable_result_log
--enable_query_log

alter system set ob_enable_batched_multi_statement=true;
set autocommit = 0;
sleep 6;

create table t1(a int, b int, c int);
insert into t1 values(1,1,1),(2,2,2),(3,3,3),(4,4,4),(5,5,5),(6,6,6),(7,7,7);
commit;
delimiter //;
delete from t1 where a = 1 ; delete from t1 where a = 2 ; delete from t1 where a = 3;//
delimiter ;//
select * from t1;
--disable_warnings
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.gv$OB_PLAN_CACHE_PLAN_STAT where statement like '%delete from t1 where a = %' order by hit_count;
--enable_warnings
rollback;
delimiter //;
update t1 set a = a + 10 where b = 1; update t1 set a = a + 10 where b = 2 ; update t1 set a = a + 10 where b = 3;//
delimiter ;//
select * from t1;
--disable_warnings
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.gv$OB_PLAN_CACHE_PLAN_STAT where statement like '%update t1 set a =%' order by hit_count;
--enable_warnings
commit;


set autocommit = true;
alter system set ob_enable_batched_multi_statement=false;
