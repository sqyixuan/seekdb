--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: laibingzheng.lbz
# owner group: IMF
# description: foobar
# tags: dml
#
# test of batch stmt insertup optimization
#

--disable_warnings
drop table if exists shanting_test;
--enable_warnings
--enable_info
--result_format 4

--disable_query_log
--disable_result_log

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
alter system flush plan cache global;
sleep 3;
connection default;
--enable_result_log
--enable_query_log

alter system set ob_enable_batched_multi_statement=true;
sleep 6;

CREATE TABLE shanting_test (`col1` int NOT NULL, `col2` int(10) DEFAULT NULL, PRIMARY KEY (`col1`));

insert into shanting_test values(0, 100) ON DUPLICATE KEY UPDATE col2 = 900;
delimiter //;
insert into shanting_test ( col2,col1 ) values ( 100,0 ) ON DUPLICATE KEY UPDATE col2 = 100;insert into shanting_test ( col2,col1 ) values ( 101,1 ) ON DUPLICATE KEY UPDATE col2 = 101;//
delimiter ;//
select * from shanting_test;
--disable_warnings
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.gv$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into shanting_test %' order by hit_count;
--enable_warnings

insert into shanting_test ( col2,col1 ) values ( 100,0 ), ( 101,1 ) ON DUPLICATE KEY UPDATE col2 = 100;
--disable_warnings
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.gv$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into shanting_test %' order by hit_count;
--enable_warnings

delimiter //;
replace into shanting_test ( col2,col1 ) values ( 200,0 );replace into shanting_test ( col2,col1 ) values ( 200,1 );//
delimiter ;//

select * from shanting_test;
--disable_warnings
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.gv$OB_PLAN_CACHE_PLAN_STAT where statement like 'replace into shanting_test%' order by hit_count;
--enable_warnings

replace into shanting_test ( col2,col1 ) values ( 200,0 ), ( 200,1 ), (300,3);
select * from shanting_test;
--disable_warnings
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.gv$OB_PLAN_CACHE_PLAN_STAT where statement like 'replace into shanting_test%' order by hit_count;
--enable_warnings

drop table shanting_test;
alter system set ob_enable_batched_multi_statement=false;

