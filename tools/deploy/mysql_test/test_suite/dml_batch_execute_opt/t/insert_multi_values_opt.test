--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: laibingzheng.lbz
# owner group: SQL2
# description: foobar
# tags: dml
#
# test of insert with multi_values optimization
#
--enable_info
--result_format 4

--disable_query_log
--disable_result_log
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
## 关闭batch优化的开关
alter system flush plan cache global;
connection default;
alter system set ob_enable_batched_multi_statement=false;
sleep 5;
--enable_result_log
--enable_query_log

--source insert_multi_values_opt_case.inc

connection obsys;
alter system flush plan cache global;
## 默认打开batch优化的开关
connection default;
alter system set ob_enable_batched_multi_statement=true;
sleep 5;
--source insert_multi_values_opt_case.inc
alter system set ob_enable_batched_multi_statement=false;
