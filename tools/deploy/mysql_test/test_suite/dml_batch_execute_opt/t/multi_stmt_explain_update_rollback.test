--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: qiaolinjun.qlj
# owner group: SQL2
# description: foobar
# tags: dml
#
# test of explain batch stmt update
#

--disable_warnings
drop table if exists t1;
--enable_warnings
--enable_info
--result_format 4

--disable_query_log
--disable_result_log
connect (my_admin,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection my_admin;
alter system set_tp tp_no = 403, error_code = 0, frequency = 1;
connection default;
alter system set ob_enable_batched_multi_statement=true;
sleep 5;

--enable_result_log
--enable_query_log

# Case 1 With explain batch statement off. Batch statement should roll back to sequential querries.
# 1.1 multiple explain update statements should run sequentially; no data change
--disable_warnings
set autocommit = false;
create table t1(a int primary key, b int, c int);
insert into t1 values(1, 1, 1), (2, 2, 2), (3, 3, 3);
delimiter //;
explain update t1 set b = 0 where a = 1;explain update t1 set b = 0 where a = 2;explain update t1 set b = 0 where a = 3;//
delimiter ;//
commit;
select * from t1 order by a, b;
drop table t1;

# 1.2 multiple update and explain update statements should run sequentially; has data change
--disable_warnings
set autocommit = false;
create table t1(a int primary key, b int, c int);
insert into t1 values(1, 1, 1), (2, 2, 2), (3, 3, 3);
delimiter //;
explain update t1 set b = 0 where a = 1;update t1 set b = 0 where a = 2;update t1 set b = 0 where a = 3;//
delimiter ;//
commit;
select * from t1 order by a, b;
drop table t1;

# 1.3 multiple update and explain update statements should run sequentially; has data change
--disable_warnings
set autocommit = false;
create table t1(a int primary key, b int, c int);
insert into t1 values(1, 1, 1), (2, 2, 2), (3, 3, 3);
delimiter //;
update t1 set b = 0 where a = 1;explain update t1 set b = 0 where a = 2;update t1 set b = 0 where a = 3;//
delimiter ;//
commit;
select * from t1 order by a, b;
drop table t1;

# 1.4 multiple update statements should run as a batch; has data change
--disable_warnings
set autocommit = false;
create table t1(a int primary key, b int, c int);
insert into t1 values(1, 1, 1), (2, 2, 2), (3, 3, 3);
delimiter //;
update t1 set b = 0 where a = 1;update t1 set b = 0 where a = 2;update t1 set b = 0 where a = 3;//
delimiter ;//
commit;
select * from t1 order by a, b;
drop table t1;

--disable_query_log
--disable_result_log
connection my_admin;
alter system set_tp tp_no = 403, error_code = 1, frequency = 1;
connection default;
alter system set ob_enable_batched_multi_statement=true;
sleep 5;
--enable_result_log
--enable_query_log
# Case 2 With explain batch statement on. Batch statement should roll NOT back to sequential querries.
# 2.1 multiple explain update statements should fail without rollback; no data change
--disable_warnings
set autocommit = false;
create table t1(a int primary key, b int, c int);
insert into t1 values(1, 1, 1), (2, 2, 2), (3, 3, 3);
delimiter //;
--error 1235
explain update t1 set b = 0 where a = 1;explain update t1 set b = 0 where a = 2;explain update t1 set b = 0 where a = 3;//
delimiter ;//
commit;
select * from t1 order by a, b;
drop table t1;

# 2.2 multiple update and explain update statements should fail without rollback; no data change
--disable_warnings
set autocommit = false;
create table t1(a int primary key, b int, c int);
insert into t1 values(1, 1, 1), (2, 2, 2), (3, 3, 3);
delimiter //;
--error 1235
explain update t1 set b = 0 where a = 1;update t1 set b = 0 where a = 2;explain update t1 set b = 0 where a = 3;//
delimiter ;//
commit;
select * from t1 order by a, b;
drop table t1;

# 2.3 multiple update statements should run as a batch; has data change
--disable_warnings
set autocommit = false;
create table t1(a int primary key, b int, c int);
insert into t1 values(1, 1, 1), (2, 2, 2), (3, 3, 3);
delimiter //;
update t1 set b = 0 where a = 1;update t1 set b = 0 where a = 2;update t1 set b = 0 where a = 3;//
delimiter ;//
commit;
select * from t1 order by a, b;
drop table t1;

alter system set ob_enable_batched_multi_statement=false;
connection my_admin;
alter system set_tp tp_no = 403, error_code = 0, frequency = 1;

