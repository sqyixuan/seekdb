--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: laibingzheng.lbz
# owner group: SQL2
# description: foobar
# tags: dml
#
# test of batch stmt insert optimization
#

--disable_warnings
drop table if exists t1,t2,t3,t4,t5,t6;
--enable_warnings
--enable_info
--result_format 4

--disable_query_log
--disable_result_log

connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
alter system flush plan cache global;
sleep 3;
connection default;
alter system set _rowsets_enabled=false;
sleep 3;
--enable_result_log
--enable_query_log

set autocommit = false;
alter system set ob_enable_batched_multi_statement=true;
sleep 6;

create table t1(c1 decimal(12,3));
delimiter //;
insert into t1 values(2.222);insert into t1 values(3.333323);//
insert into t1 values(5.5555);insert into t1 values(6.6666);//
insert into t1 values(8.8);insert into t1 values(9.0219);//
delimiter ;//
commit;
select * from t1;
--disable_warnings
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.gv$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t1 %' order by hit_count;
--enable_warnings

drop table t1;

create table t2(c1 float, c2 decimal(12,3));
delimiter //;
insert into t2 values(1.11,2.22);insert into t2 values(4.4444,5.999923);insert into t2 values(3.3,3.333);//
insert into t2 values(3.333333,4.989801);insert into t2 values(3.33,4.0111);//
insert into t2 values(6,6);insert into t2 values(7.77,7.012);//
delimiter ;//
commit;
select * from t2;

--disable_warnings
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.gv$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t2 %' order by hit_count;
--enable_warnings

## with execute, scale is different, can't batch execute, will rollback
create table t3(c1 float, c2 decimal(12,3));
delimiter //;
insert into t3 values(1.1 + 2.2, 2.2 + 3.3);insert into t3 values(4.4 + 5.5, 4.4 + 5.5);//
insert into t3 values(6.6 + 2.2, 7.7 + 8.888);insert into t3 values(4.4 + 5.523, 4.423 + 5.53333);//
delimiter ;//
commit;
select * from t3;
--disable_warnings
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.gv$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t3 %' order by hit_count;
--enable_warnings
drop table t3;

alter system set ob_enable_batched_multi_statement=false;
alter system set _rowsets_enabled=true;
set autocommit = true;
