--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: laibingzheng.lbz
# owner group: SQL2
# description: test of batch insert select stmt optimization
# tags: dml

--disable_warnings
drop table if exists t9;
drop table if exists t1;
--error 0,5265
drop outline ol_4;
--enable_warnings
--result_format 4

--disable_query_log
--disable_result_log
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
alter system flush plan cache global;
alter system set_tp tp_no = 1172, error_code = 4001, frequency = 1;
sleep 3;
connection default;
--enable_result_log
--enable_query_log
alter system set ob_enable_batched_multi_statement=true;
sleep 5;

## for bug: mysql_test/test_suite/dml_batch_execute_opt/t/insert_multi_values_rewrite.test
## pdml 和 batch执行不能共存
CREATE TABLE t9 (`pk` int(11) NOT NULL AUTO_INCREMENT, `c1` varchar(10) DEFAULT NULL, `c2` int(11) DEFAULT NULL, PRIMARY KEY (`pk`));
insert /*+enable_parallel_dml parallel(2)*/ into t9(c1,c2) values('stabl',216655044),('pos',214395688),('in',45964819);
select * from t9;
--disable_warnings
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.gv$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert /*+enable_parallel_dml parallel(2)*/ into t9%' order by hit_count;
--enable_warnings
drop table t9;

create table t1 (c1 int, c2 int, c3 int);
create outline ol_4 on insert /*+no_rewrite*/ into t1 values(1,2,3),(2,3,4) to insert /*+trace_log*/ into t1 values(1,2,3),(2,3,4);
drop outline ol_4;
drop table t1;
alter system set ob_enable_batched_multi_statement=false;

connection obsys;
alter system set_tp tp_no = 1172, error_code = 0, frequency = 1;
