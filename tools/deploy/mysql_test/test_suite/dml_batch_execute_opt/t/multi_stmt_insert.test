--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: laibingzheng.lbz
# owner group: SQL2
# description: foobar
# tags: dml
#
# test of batch stmt insert optimization
#

--disable_warnings
drop table if exists t1,t2,t3,t4,t5,t6, t7, t8, t9, t10;
--enable_warnings
--enable_info
--result_format 4

--disable_query_log
--disable_result_log
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
sleep 2;
connection default;
alter system set _rowsets_enabled=false;
let $def_plan_cache_percentage = query_get_value(show variables like 'ob_plan_cache_percentage', Value, 1);
set global ob_plan_cache_percentage = 10;
set autocommit = false;
alter system set ob_enable_batched_multi_statement=true;
--enable_result_log
--enable_query_log
sleep 6;

connection obsys;
alter system flush plan cache global;
sleep 3;
connection default;

create table t1(a int, b int, c int, primary key(a,b)) partition by hash(a) partitions 4;
delimiter //;
insert into t1 values(1, 1, 1);insert into t1 values(2, 2, 2);insert into t1 values(3, 3, 3);//
update t1 set b = 2 where a = 1 and b = 1;update t1 set b = 1 where a = 2 and b = 2;//
delimiter ;//
commit;

select * from t1 order by a, b;

## test to hit the plan cache
delimiter //;
insert into t1 values(4, 4, 4);insert into t1 values(5, 5, 5);//
insert into t1 values(6, 6, 6);insert into t1 values(7, 7, 7);insert into t1 values(8, 8, 8);//
insert into t1 values(10,10,10+10);insert into t1 values(11,11,11+11);insert into t1 values(12,12,12+12);//
insert into t1 values(15,15,15+15);insert into t1 values(16,16,16+16);//
delimiter ;//
commit;
select * from t1 order by a, b;

--disable_warnings
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.gv$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t1 %' order by hit_count;
--enable_warnings

drop table t1;

## test pre_calc in batch
create table t2(a int, b int);
delimiter //;
insert into t2 values(1,1+1);insert into t2 values(2,2+2);insert into t2 values(3,3+3);//
insert into t2 values(4,4+4);insert into t2 values(5,5+5);//
insert into t2 values(6,6+6);insert into t2 values(7,7+7);insert into t2 values(8,8+8);//
delimiter ;//
commit;

select * from t2 order by a;
--disable_warnings
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.gv$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t2 %' order by hit_count;
--enable_warnings
drop table t2;

## test data type in batch
create table t3(c1 int, c2 varchar(20), c3 text, c4 date);
delimiter //;
insert into t3 values(1,'a','abcd','2020-2-2');insert into t3 values(2,'2','222','2020-2-3');//
insert into t3 values(3,'c','3333','2020-3-1');insert into t3 values(4,'4','444','2020-4-1');insert into t3 values(5,'5','555','2020-5-1');//
insert into t3 values(8,concat('8','8'),'8888','2020-8-8');insert into t3 values(9,concat('9','9'),'999','2020-9-9');//
insert into t3 values(10,concat('10','10'),'1010','2020-10-10');insert into t3 values(11,concat('11','11'),'1111','2020-11-11');insert into t3 values(12,concat('12','12'),'1212','2020-12-12');//
delimiter ;//
commit;
select * from t3;
--disable_warnings
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.gv$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t3 %' order by hit_count;
--enable_warnings
drop table t3;

## insert with multi_values this is not supported immediately
create table t4(a int, b int);
delimiter //;
insert into t4 values(1,1),(2,2);insert into t4 values(3,3),(4,4);//
delimiter ;//
commit;
select * from t4 order by a;
--disable_warnings
--sorted_result
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.gv$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t4 %' order by hit_count;
--enable_warnings
drop table t4;

## insert with pk unique violate, rollback 
create table t5(a int primary key, b int, c varchar(20));
delimiter //;
--error 1062
insert into t5 values(1,1,'1');insert into t5 values(2,2,'2');insert into t5 values(2,3,'3');//
delimiter ;//
commit;
select * from t5 order by a;
drop table t5;

## insert with column_convert failed
create table t1(c1 int primary key, c2 varchar(4));
delimiter //;
--error 1406
insert into t1 values(1,'1');insert into t1 values(2,'222');insert into t1 values(3,'333');insert into t1 values(3,'44444');insert into t1 values(3,'5555');//
delimiter ;//
select * from t1;
drop table t1;


## insert with global index
create table t6(c1 int, c2 varchar(20), c3 int, c4 varchar(20), primary key(c1, c2));
create index t6_idx_01 on t6(c3) global;
create index t6_idx_02 on t6(c4) global;
delimiter //;
insert into t6 values(1,'1',1,'1');insert into t6 values(2,'2',2,'2');insert into t6 values(3,'3',3,'3');//
insert into t6 values(4,'4',4,'4');insert into t6 values(5,'5',5,'5');//
insert into t6 values(6,concat('6','6'),6+6,'6');insert into t6 values(7,concat('7','7'),7+7,'7');//
insert into t6 values(8,concat('8','8'),8+8,'8');insert into t6 values(9,concat('9','9'),9+9,'9');insert into t6 values(10,concat('10','10'),10+10,'10');//
delimiter ;//
commit;
select /*+ INDEX(t6 PRIMARY) */ * from t6 order by c1;
select /*+ INDEX(t6 t6_idx_01) */ * from t6 where c3 > 10 order by c1;
select /*+ INDEX(t6 t6_idx_02) */ * from t6 where c4 not in ('1', '5', '8') order by c1;

--disable_warnings
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.gv$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t6 %' order by hit_count;
--enable_warnings
drop table t6;

create table t7(c1 int, c2 int, c3 varchar(50));
delimiter //;
insert into t7 values('1', '1', '1111');insert into t7 values('2', '2', '22');//
insert into t7 values(null, null, '3333');insert into t7 values(4, 4, '444');//
insert into t7 values(null, 5, '5555');insert into t7 values(6, 6, '66666');insert into t7 values(7, null, '77777');//
delimiter ;//
commit;
select * from t7;
--disable_warnings
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.gv$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t7 %' order by hit_count;
--enable_warnings
drop table t7;

create table t8(c1 int, c2 int);
delimiter //;
insert into t8 values('1', '1');insert into t8 values('2', '2');//
insert into t8 values(3, 3);insert into t8 values(4, 4);//
delimiter ;//
commit;
select * from t8;
--disable_warnings
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.gv$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert into t8 %' order by hit_count;
--enable_warnings
drop table t8;

create table t9(`pk` int(11) NOT NULL AUTO_INCREMENT, `c1` varchar(10) DEFAULT NULL, `c2` int(11) DEFAULT NULL, PRIMARY KEY (`pk`));
delimiter //;
insert /*+enable_parallel_dml parallel(2)*/ into t9(c1,c2) values('stabl',216655044);insert /*+enable_parallel_dml parallel(2)*/ into t9(c1,c2) values('pos',214395688);insert /*+enable_parallel_dml parallel(2)*/ into t9(c1,c2) values('in',45964819);//
delimiter ;//

commit;
select * from t9;

--disable_warnings
select hit_count, is_batched_multi_stmt, statement, query_sql from oceanbase.gv$OB_PLAN_CACHE_PLAN_STAT where statement like 'insert /*+enable_parallel_dml parallel(2)*/ into t9%' order by hit_count;
--enable_warnings
drop table t9;

eval set global ob_plan_cache_percentage = $def_plan_cache_percentage;
alter system set _rowsets_enabled=true;
set autocommit = true;
alter system set ob_enable_batched_multi_statement=false;
