--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: laibingzheng.lbz
# owner group: SQL2
# description: foobar
# tags: dml
#
# test of insert with multi_values optimization
#
--enable_info
--result_format 4

--disable_warnings
drop table if exists t1, t2, t3;
--enable_warnings
--enable_info
--result_format 4

create table t1(c1 int, c2 int, c3 int);

--error 1064
insert into t1 values(1,,1,,,1),(2,,2,,,2);

--error 1064
insert into t1 values(1,1,1),,(2,2,2);

--error 1064
insert into t1 values(1,1,1),((2,2,2);

--error 1064
insert into t1 values(1,1,1),((2,(3,)),3);

insert t1 values(1,1,1),(2,2,2);

--error 1064
insert into t1 valuessss(1,1,1),(2,2,2);

--error 1136
insert into t1 values(((1),1,1),(2,2,2)),(2,2,2),(3,3,3);

--error 1136
insert into t1 values(((1),1,1),(2,2,2)),(((2),2,2),(3,3,3));

--error 1064
insert into value((((1,1,1), (2,2,2));

--error 1064
insert into t1 values (1,1,1)-,(2,2,2),(3,3,3);

--error 1064
insert into t1 values ,(1,1,1),(2,2,2);
drop table t1;


