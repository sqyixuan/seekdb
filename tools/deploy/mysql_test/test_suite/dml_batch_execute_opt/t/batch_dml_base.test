--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: fenggu.yh
# owner group: STORAGE
# description: test of batch insert/update/delete
# tags: dml

--disable_warnings
drop table if exists t1,t2;
--enable_warnings
--result_format 4

create table t1(c1 int, c2 int, c3 int);
create table t2(c1 int primary key, c2 int, c3 int, unique key uk0(c2));

--disable_query_log
--let $i = 0
while ($i < 1000) 
{
  eval insert into t1 values ($i, $i, $i);
  inc $i;
}
--let $i = 0
while ($i < 1000) 
{
  eval insert into t1 values ($i, $i + 1000, $i);
  inc $i;
}

--enable_query_log

## 1. batch insert
--error 1062
insert into t2 select * from t1;
select sum(c1), sum(c2), sum(c3) from t2;
insert into t2 select * from t1 on duplicate key update c3 = c3 + 1;
select sum(c1), sum(c2), sum(c3) from t2;

## 2. test merge uncommitted
begin;
delete from t2;
rollback;
insert into t2 select * from t1 on duplicate key update c3 = c3 + 1;
insert ignore into t2 select * from t1;
select sum(c1), sum(c2), sum(c3) from t2;
replace into t2 select * from t1;
select sum(c1), sum(c2), sum(c3) from t2;

begin;
delete from t2;
--source mysql_test/include/minorfreeze.inc
insert into t2 select * from t1 on duplicate key update c3 = c3 + 1;
--source mysql_test/include/minorfreeze.inc
--source mysql_test/include/wait_minor_merge.inc
insert into t2 values(2000, 2000, 2000);
--source mysql_test/include/minorfreeze.inc
--source mysql_test/include/wait_minor_merge.inc
insert into t2 values(3000, 3000, 3000);
--source mysql_test/include/minorfreeze.inc
--source mysql_test/include/wait_minor_merge.inc
select sum(c1), sum(c2), sum(c3) from t2;
--source mysql_test/include/minorfreeze.inc
select sum(c1), sum(c2), sum(c3) from t2;
commit;
insert into t2 select * from t1 on duplicate key update c3 = c3 + 1;
select sum(c1), sum(c2), sum(c3) from t2;
delete from t2;

begin;
insert into t2 select * from t1 on duplicate key update c3 = c3 + 1;
select sum(c1), sum(c2), sum(c3) from t2;
--source mysql_test/include/minorfreeze.inc
insert into t2 select * from t1 on duplicate key update c3 = c3 + 1;
select sum(c1), sum(c2), sum(c3) from t2;
--source mysql_test/include/minorfreeze.inc
insert into t2 select * from t1 on duplicate key update c3 = c3 + 1;
select sum(c1), sum(c2), sum(c3) from t2;
--source mysql_test/include/minorfreeze.inc
rollback;
insert into t2 select * from t1 on duplicate key update c3 = c3 + 1;
select sum(c1), sum(c2), sum(c3) from t2;

begin;
insert into t2 select * from t1 on duplicate key update c3 = c3 + 1;
delete from t2;
--source mysql_test/include/minorfreeze.inc
select sum(c1), sum(c2), sum(c3) from t2;
insert into t2 select * from t1 on duplicate key update c3 = c3 + 1;
--source mysql_test/include/minorfreeze.inc
delete from t2;
--source mysql_test/include/minorfreeze.inc
select sum(c1), sum(c2), sum(c3) from t2;
rollback;
insert into t2 select * from t1 on duplicate key update c3 = c3 + 1;
select sum(c1), sum(c2), sum(c3) from t2;

## 3. test primary key conflict and unique key conflict
delete from t2;
insert into t2 select * from t1 on duplicate key update c3 = c3 + 1;
## 更新pk，会拆分成delete + insert, 不会报主键冲突
#update t2 set c1 = c1 + 1;
## 更新唯一索引且跨越了存储层一批的边界会冲突
--error 1062
update t2 set c2 = c2 + 500;

update t2 set c1 = c1 + 2000;
update t2 set c2 = c2 + 2000;
select sum(c1), sum(c2), sum(c3) from t2;
insert into t2 select * from t1 on duplicate key update c1 = c1 + 1000;
select sum(c1), sum(c2), sum(c3) from t2;
insert into t2 select * from t1 on duplicate key update c2 = c2 + 3000;
select sum(c1), sum(c2), sum(c3) from t2;
insert into t2 select * from t1 on duplicate key update c3 = c3 + 1;
select sum(c1), sum(c2), sum(c3) from t2;

drop table t1;
drop table t2;
