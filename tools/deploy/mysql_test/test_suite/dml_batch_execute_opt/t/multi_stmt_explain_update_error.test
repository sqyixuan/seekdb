--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: qiaolinjun.qlj
# owner group: SQL2
# description: foobar
# tags: dml
#
# test of explain batch stmt update
#

--disable_warnings
drop table if exists t1;
--enable_warnings
--enable_info
--result_format 4

--disable_query_log
--disable_result_log
connect (my_admin,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection my_admin;
alter system set_tp tp_no = 403, error_code = 1, frequency = 1;
connection default;
alter system set ob_enable_batched_multi_statement=true;
sleep 5;

--enable_result_log
--enable_query_log

# Case 1 With explain batch statement on and queries are different. Batch statement should NOT roll
# back to sequential querries.
# 1.1 first query is different
--disable_warnings
set autocommit = false;
create table t1(a int primary key, b int, c int);
insert into t1 values(1, 1, 1), (2, 2, 2), (3, 3, 3);
delimiter //;
--error 1235
explain basic update t1 set b = 0 where a = 1 and c = 1;update t1 set b = 0 where a = 2;update t1 set b = 0 where a = 3;//
delimiter ;//
commit;
select * from t1 order by a, b;
drop table t1;

# 1.2 middle query is different
--disable_warnings
set autocommit = false;
create table t1(a int primary key, b int, c int);
insert into t1 values(1, 1, 1), (2, 2, 2), (3, 3, 3);
delimiter //;
--error 1235
explain basic update t1 set b = 0 where a = 1;update t1 set b = 0 where a = 2 and c = 2;update t1 set b = 0 where a = 3;//
delimiter ;//
commit;
select * from t1 order by a, b;
drop table t1;

# 1.3 last query is different
--disable_warnings
set autocommit = false;
create table t1(a int primary key, b int, c int);
insert into t1 values(1, 1, 1), (2, 2, 2), (3, 3, 3);
delimiter //;
--error 1235
explain basic update t1 set b = 0 where a = 1;update t1 set b = 0 where a = 2;update t1 set b = 0 where a = 3 and c = 3;//
delimiter ;//
commit;
select * from t1 order by a, b;
drop table t1;

# Case 2 With explain batch statement on and queries have syntax errors. Batch statement should NOT roll
# back to sequential querries.
# 2.1 all queries have syntax errors
--disable_warnings
set autocommit = false;
create table t1(a int primary key, b int, c int);
insert into t1 values(1, 1, 1), (2, 2, 2), (3, 3, 3);
delimiter //;
--error 1235
explain basic updatee t1 set b = 0 where a = 1;updatee t1 set b = 0 where a = 2;updatee t1 set b = 0 where a = 3;//
delimiter ;//
commit;
select * from t1 order by a, b;
drop table t1;

# 2.2 first query has syntax errors
--disable_warnings
set autocommit = false;
create table t1(a int primary key, b int, c int);
insert into t1 values(1, 1, 1), (2, 2, 2), (3, 3, 3);
delimiter //;
--error 1235
explain basic updatee t1 set b = 0 where a = 1;update t1 set b = 0 where a = 2;update t1 set b = 0 where a = 3;//
delimiter ;//
commit;
select * from t1 order by a, b;
drop table t1;

# 2.3 middle query has syntax errors
--disable_warnings
set autocommit = false;
create table t1(a int primary key, b int, c int);
insert into t1 values(1, 1, 1), (2, 2, 2), (3, 3, 3);
delimiter //;
--error 1235
explain basic update t1 set b = 0 where a = 1;updatee t1 set b = 0 where a = 2;update t1 set b = 0 where a = 3;//
delimiter ;//
commit;
select * from t1 order by a, b;
drop table t1;

# 2.4 last query has syntax errors
--disable_warnings
set autocommit = false;
create table t1(a int primary key, b int, c int);
insert into t1 values(1, 1, 1), (2, 2, 2), (3, 3, 3);
delimiter //;
--error 1235
explain basic update t1 set b = 0 where a = 1;update t1 set b = 0 where a = 2;updatee t1 set b = 0 where a = 3;//
delimiter ;//
commit;
select * from t1 order by a, b;
drop table t1;

alter system set ob_enable_batched_multi_statement=false;
connection my_admin;
alter system set_tp tp_no = 403, error_code = 0, frequency = 1;
