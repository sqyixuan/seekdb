--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
# owner: laibingzheng.lbz
# owner group: SQL2
# description: test of batch delete stmt optimization
# tags: dml
--disable_warnings
drop table if exists t1,t2,t3,t4,t5,t6;
--enable_warnings
--enable_info
--result_format 4
--disable_query_log
--disable_result_log
connect (obsys,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys;
alter system set_tp tp_no = 403, error_code = 1, frequency = 1;
alter system flush plan cache global;
sleep 3;
connection default;
alter system set _rowsets_enabled=false;
sleep 3;
--enable_result_log
--enable_query_log
set autocommit = false;
alter system set ob_enable_batched_multi_statement=true;
sleep 6;

create table t1(c1 int, c2 int, c3 int);
delimiter //;
explain delete from t1 where c1 = 1;delete from t1 where c1 = 2;//
delimiter ;//
drop table t1;


create table t1(c1 int, c2 int, c3 int, primary key(c1, c2)) partition by hash(c1) partitions 4;
create index t1_idx_01 on t1(c3) global;
delimiter //;
explain delete /*+index(t1 t1_idx_01)*/ from t1 where c3 = 1;delete /*+index(t1 t1_idx_01)*/ from t1 where c3 = 2;//
delimiter ;//
drop table t1;

--echo ## this plan is error, not support px operator
create table t1(c1 int, c2 int, c3 int, primary key(c1, c2)) partition by hash(c1) partitions 4;
create index t1_idx_01 on t1(c3);
delimiter //;
explain delete /*+index(t1 t1_idx_01)*/ from t1 where c3 = 1;delete /*+index(t1 t1_idx_01)*/ from t1 where c3 = 2;//
delimiter ;//
drop table t1;


alter system set _rowsets_enabled=true;
set autocommit = true;
alter system set ob_enable_batched_multi_statement=false;
connection obsys;
alter system set_tp tp_no = 403, error_code = 0, frequency = 1;





