#owner: laibingzheng.lbz
#owner group: IMF
#description: test user defined rules affect insert ... values ... batch optimization
#
#tags: dml
 
connect(obsys, $OBMYSQL_MS0, admin, $OBMYSQL_PWD, oceanbase, $OBMYSQL_PORT);
 
--result_format 4
connection obsys;
alter system flush plan cache global;
connection default;
alter system set enable_user_defined_rewrite_rules = true;
 
--disable_warnings
DROP DATABASE IF EXISTS dkz_db1;
drop table if exists t1;
--enable_warnings
call dbms_udr.remove_rule('kaizhan test1');
 
create database dkz_db1;
use dkz_db1;

call dbms_udr.create_rule('kaizhan test1',
                          'dkz_db1',
                          'insert into t1 values(:A,:B),(:C,:D)',
                          'insert into t1 values(:A + 1,:B + 1),(:C+1,:D+1)');

sleep 10;
create table t1(c1 int, c2 int);
insert into t1 values(1,1),(2,2);
select * from t1;

insert into t1 values(5,5),(6,6);

select * from t1;
call dbms_udr.remove_rule('kaizhan test1');
drop table t1;

alter system set enable_user_defined_rewrite_rules = false;
connection default;

sleep 10;

create table t1(c1 int, c2 int, c3 int, key(c2), key(c3,c2));
create outline ol_insert on insert /*+trace_log*/ into t1 value (1,2,4);
alter outline ol_insert add insert /*+max_concurrent(0)*/ into t1 value (?,?,?);
sleep 4;

--error 5268
insert  into t1 value (1,1,1);

## the SQL can't be affected by /*+max_concurrent(0)*/
insert  into t1 value (1,1,1),(2,2,2);

select * from t1;

drop table t1;

--disable_warnings
DROP DATABASE IF EXISTS dkz_db1;
--enable_warnings
