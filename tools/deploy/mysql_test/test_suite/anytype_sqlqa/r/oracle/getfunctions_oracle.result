+---------------------------------------------------------------------------------------------------------------------------------------------------------------------------+
| PRINTLN()                                                                                                                                                                 |
+---------------------------------------------------------------------------------------------------------------------------------------------------------------------------+
| cai_pro内
  b.GETINFO:248
   v1: v2:
  b.GETATTRELEMINFO:9
   v1:2 v2:
  cai_pro外
  atype.GETINFO:248
   v_out1: v_out2:
  atype.GETATTRELEMINFO:9
   v_out1:2 v_out2:   |
+---------------------------------------------------------------------------------------------------------------------------------------------------------------------------+
##作为default默认值（pl中+表中+约束）
##34677366，GETPERSISTENT+GETINFO作为procedure默认值，ob调用失败，oracle成功；预期结果：ob成功
declare
atype anytype:=anytype.GETPERSISTENT('CWX','CAI_TYPE1');
atype1 anytype;
v_out1 number:=1; 
v_out2 varchar(200):='a';
 procedure cai_pro(a number default anytype.GETINFO(atype,v_out1,v_out1,v_out1,v_out1,v_out1,v_out2,v_out2,v_out2,v_out1)) is
 b number;
 begin
 b:=a;
 dbms_output.put_line('cai_pro:'||b);
 end;
 procedure cai_pro1(a number default anytype.GETATTRELEMINFO(atype,1,v_out1,v_out1,v_out1,v_out1,v_out1,atype1,v_out2)) is
 b number;
 begin
 b:=a;
 dbms_output.put_line('cai_pro1:'||b);
 end;
begin
cai_pro;
cai_pro1;
end;
/
