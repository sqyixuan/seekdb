##存在于if else+case when 条件+is 中
declare
atype anytype:=anytype.GETPERSISTENT('CWX','CAI_TYPE1');
atype1 anytype;
v_out1 number; 
v_out2 varchar(200);
c number:=atype.GETINFO(v_out1,v_out1,v_out1,v_out1,v_out1,v_out2,v_out2,v_out2,v_out1);
d number:=atype.GETATTRELEMINFO(1,v_out1,v_out1,v_out1,v_out1,v_out1,atype1,v_out2);
c1 number:=atype.GETINFO(v_out1,v_out1,v_out1,v_out1,v_out1,v_out2,v_out2,v_out2,v_out1);
d1 number:=atype.GETATTRELEMINFO(1,v_out1,v_out1,v_out1,v_out1,v_out1,atype1,v_out2);
begin
case c when c1 then
 case d when d1 then
 dbms_output.put_line('c: '||c||' d: '||d);
 end case;
end case;

case c when atype.GETINFO(v_out1,v_out1,v_out1,v_out1,v_out1,v_out2,v_out2,v_out2,v_out1) then
 case d when atype.GETATTRELEMINFO(1,v_out1,v_out1,v_out1,v_out1,v_out1,atype1,v_out2) then
 dbms_output.put_line('c: '||c||' d: '||d);
 end case;
end case;

if c=atype.GETINFO(v_out1,v_out1,v_out1,v_out1,v_out1,v_out2,v_out2,v_out2,v_out1) and d=atype.GETATTRELEMINFO(1,v_out1,v_out1,v_out1,v_out1,v_out1,atype1,v_out2) then
dbms_output.put_line('c: '||c||' d: '||d);
end if;

if c=c1 and d=d1 then
dbms_output.put_line('c: '||c||' d: '||d);
end if;
end;
/
