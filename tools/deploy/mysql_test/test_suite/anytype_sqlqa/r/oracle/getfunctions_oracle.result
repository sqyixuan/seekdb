##存在to_char等函数，运算，连接符等
declare
atype anytype;
type c_nested is table of varchar2(200);
v_nested c_nested:=c_nested('- CWX','CWX',' CWX ','CWX ',' CWX','CW X','C||WX','C'||'WX','C'||'  WX','NULL','NULL||CWX',NULL||'CWX','CWX+1-1','CWX'||to_number(1-1),'SELECT CWX FROM DUAL','TO_CHAR(''CWX'')',TO_CHAR('CWX'));
begin
for i in v_nested.first ..v_nested.last loop
begin
atype:=anytype.GETPERSISTENT(v_nested(i),'CAI_TYPE1');
exception when others then
dbms_output.put_line('第'||i||'个：'||v_nested(i)||'失败啦' );
end;
end loop;
end;
/
select println() from dual;/
+---------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------+
| PRINTLN()                                                                                                                                                                                                                                                                                                                                                                                   |
+---------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------+
| 第1个：- CWX失败啦
  第3个： CWX 失败啦
  第4个：CWX 失败啦
  第5个： CWX失败啦
  第6个：CW X失败啦
  第7个：C||WX失败啦
  第9个：C  WX失败啦
  第10个：NULL失败啦
  第11个：NULL||CWX失败啦
  第13个：CWX+1-1失败啦
  第14个：CWX0失败啦
  第15个：SELECT CWX FROM DUAL失败啦
  第16个：TO_CHAR('CWX')失败啦                                                                               |
+---------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------+
