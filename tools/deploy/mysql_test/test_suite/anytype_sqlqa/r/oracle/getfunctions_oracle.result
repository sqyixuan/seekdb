##作为参数（inout in  out）+嵌套procedure
create or replace procedure cai_pro(a in number,b in number,c in out number,d in out number,e out number,f out number) is 
atype anytype:=anytype.GETPERSISTENT('CWX','CAI_TYPE1');
atype1 anytype;
v_out1 number; 
v_out2 varchar(200);
begin
c:=atype.GETINFO(v_out1,v_out1,v_out1,v_out1,v_out1,v_out2,v_out2,v_out2,v_out1);
d:=atype.GETATTRELEMINFO(1,v_out1,v_out1,v_out1,v_out1,v_out1,atype1,v_out2);
e:=c;
f:=d;
dbms_output.put_line('a: '||a||'  b:'||b||'  c:'||c||' d: '||d||'  e:'||e||'  f:'||f);
end;
/
declare
b number;
atype anytype:=anytype.GETPERSISTENT('CWX','CAI_TYPE1');
atype1 anytype;
v_out1 number; 
v_out2 varchar(200);
 procedure cai_pro1 is
 atype anytype:=anytype.GETPERSISTENT('CWX','CAI_TYPE1');
 atype1 anytype;
 v_out1 number; 
 v_out2 varchar(200);
 a number;
 begin
 cai_pro(atype.GETINFO(v_out1,v_out1,v_out1,v_out1,v_out1,v_out2,v_out2,v_out2,v_out1),atype.GETATTRELEMINFO(1,v_out1,v_out1,v_out1,v_out1,v_out1,atype1,v_out2),a,a,a,a);
 end;
begin
cai_pro(atype.GETINFO(v_out1,v_out1,v_out1,v_out1,v_out1,v_out2,v_out2,v_out2,v_out1),atype.GETATTRELEMINFO(1,v_out1,v_out1,v_out1,v_out1,v_out1,atype1,v_out2),b,b,b,b);
cai_pro1;
end;
/
