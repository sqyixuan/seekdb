##复杂数据类型+自定义+预定义等
declare
atype anytype;
type c_nested is table of varchar2(200);
v_nested c_nested:=c_nested('CWX','CWX');
c1 cai_type1:=cai_type1('CWX','CWX');
c3 cai_type3:=cai_type3('CWX','CWX');
type c_record is record(r_id varchar2(200));
v_record c_record;
v1 cait.t_id%type;
v2 cait%rowtype;
subtype s_char is varchar2(200);
v_char s_char:='CWX';
v_string string(20):='CWX';
begin
dbms_output.put_line('传入collection+type(type object/type table)');
atype:=anytype.GETPERSISTENT(v_nested(1),'CAI_TYPE1');
atype:=anytype.GETPERSISTENT(c1(2),'CAI_TYPE1');
atype:=anytype.GETPERSISTENT(c3.a,'CAI_TYPE1');

dbms_output.put_line('传入record+%type+%rowtype');
v_record.r_id:='CWX';
v1:='CWX';
v2.t_name:='CWX';
atype:=anytype.GETPERSISTENT(v_record.r_id,'CAI_TYPE1');
atype:=anytype.GETPERSISTENT(v1,'CAI_TYPE1');
atype:=anytype.GETPERSISTENT(v2.t_name,'CAI_TYPE1');

dbms_output.put_line('传入自定义子类型+预定义子类型');
atype:=anytype.GETPERSISTENT(v_char,'CAI_TYPE1');
atype:=anytype.GETPERSISTENT(v_string,'CAI_TYPE1');
end;
/
select println() from dual;/
+---------------------------------------------------------------------------------------------------------------------------+
| PRINTLN()                                                                                                                 |
+---------------------------------------------------------------------------------------------------------------------------+
| 传入collection+type(type object/type table)
  传入record+%type+%rowtype
  传入自定义子类型+预定义子类型                   |
+---------------------------------------------------------------------------------------------------------------------------+
