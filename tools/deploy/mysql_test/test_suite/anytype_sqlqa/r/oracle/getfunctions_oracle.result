create or replace procedure cai_pro1 is
atype anytype:=anytype.GETPERSISTENT('CWX','CAI_TYPE1');
atype1 anytype;
v_out1 number:=1; 
v_out2 varchar(200);
begin
loop
if v_out1<3 then
dbms_output.put_line('anytype.GETINFO :' ||atype.GETINFO(v_out1,v_out1,v_out1,v_out1,v_out1,v_out2,v_out2,v_out2,v_out1));
dbms_output.put_line(' v_out1:'||v_out1||' v_out2:'||v_out2);
dbms_output.put_line('anytype.GETATTRELEMINFO:' ||atype.GETATTRELEMINFO(1,v_out1,v_out1,v_out1,v_out1,v_out1,atype1,v_out2));
dbms_output.put_line(' v_out1:'||v_out1||' v_out2:'||v_out2);
return;
end if;
end loop;
end;
