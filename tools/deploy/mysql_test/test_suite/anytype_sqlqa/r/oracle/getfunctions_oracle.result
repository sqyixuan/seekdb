##复杂数据类型+自定义+预定义等
declare
atype anytype;
type c_nested is table of varchar2(200);
v_nested c_nested:=c_nested('CAI_TYPE1','CAI_TYPE1');
c1 cai_type1:=cai_type1('CAI_TYPE1','CAI_TYPE1');
c3 cai_type3:=cai_type3('CAI_TYPE1','CAI_TYPE1');
type c_record is record(r_id varchar2(200));
v_record c_record;
v1 cait.t_id%type;
v2 cait%rowtype;
subtype s_char is varchar2(200);
v_char s_char:='CAI_TYPE1';
v_string string(20):='CAI_TYPE1';
begin
dbms_output.put_line('传入collection+type(type object/type table)');
atype:=anytype.GETPERSISTENT('CWX',v_nested(1));
atype:=anytype.GETPERSISTENT('CWX',c1(2));
atype:=anytype.GETPERSISTENT('CWX',c3.a);

dbms_output.put_line('传入record+%type+%rowtype');
v_record.r_id:='CAI_TYPE1';
v1:='CAI_TYPE1';
v2.t_name:='CAI_TYPE1';
atype:=anytype.GETPERSISTENT('CWX',v_record.r_id);
atype:=anytype.GETPERSISTENT('CWX',v1);
atype:=anytype.GETPERSISTENT('CWX',v2.t_name);

dbms_output.put_line('传入自定义子类型+预定义子类型');
atype:=anytype.GETPERSISTENT('CWX',v_char);
atype:=anytype.GETPERSISTENT('CWX',v_string);
end;
/
select println() from dual;/
