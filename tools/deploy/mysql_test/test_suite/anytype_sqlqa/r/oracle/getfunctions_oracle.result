#自定义anytype（存在anytype嵌套anytype)
##同 34943988
declare
at1 anytype:=anytype.GETPERSISTENT('CWX','CAI_TYPE1');
at2 anytype:=anytype.GETPERSISTENT('CWX','CAI_TYPE2');
at3 anytype:=anytype.GETPERSISTENT('CWX','CAI_TYPE3');
at4 anytype:=anytype.GETPERSISTENT('CWX','CAI_TYPE4');
atx anytype;
aty anytype;
atype anytype;
atype1 anytype;
atype2 anytype;
prec PLS_INTEGER; 
scale PLS_INTEGER;
len PLS_INTEGER; 
csid PLS_INTEGER;
csfrm PLS_INTEGER;
schema_name VARCHAR2(200); 
type_name VARCHAR2(200); 
version varchar2(200);
numelems PLS_INTEGER;
aname varchar2(200);
type c_nested is table of anytype;
v_nested c_nested:=c_nested(at1,at2,at3,at4);
begin
dbms_output.put_line('anytype中存在多重嵌套');
for i in v_nested.first ..v_nested.last loop
begin
dbms_output.put_line('------------------------------------------------现在嵌套的是：cai_type'||i);
anytype.begincreate(108,atx);
atx.addattr(1,108,1,1,1,1,1,v_nested(i));
atx.endcreate;

anytype.begincreate(108,aty);
aty.addattr(1,108,1,1,1,1,1,atx);
aty.endcreate;


dbms_output.put_line('第一个：aty.GETINFO :' ||aty.GETINFO(prec,scale,len,csid,csfrm,schema_name,type_name,version,numelems));
dbms_output.put_line(prec||' scale:'||scale||' len:'||len||' csid:'||csid||' csfrm:'||csfrm||' schema_name:'||schema_name||' type_name:'||type_name||' version:'||version||' numelems:'||numelems);
dbms_output.put_line('aty.GETATTRELEMINFO:' ||aty.GETATTRELEMINFO(1,prec,scale,len,csid,csfrm,atype,aname));
dbms_output.put_line(prec||' scale:'||scale||' len:'||len||' csid:'||csid||' csfrm:'||csfrm||' aname:'||aname);
dbms_output.put_line('----------------------------');

dbms_output.put_line('第二个：atype.GETINFO :' ||atype.GETINFO(prec,scale,len,csid,csfrm,schema_name,type_name,version,numelems));
dbms_output.put_line(prec||' scale:'||scale||' len:'||len||' csid:'||csid||' csfrm:'||csfrm||' schema_name:'||schema_name||' type_name:'||type_name||' version:'||version||' numelems:'||numelems);
dbms_output.put_line('atype.GETATTRELEMINFO:' ||atype.GETATTRELEMINFO(1,prec,scale,len,csid,csfrm,atype1,aname));
dbms_output.put_line(prec||' scale:'||scale||' len:'||len||' csid:'||csid||' csfrm:'||csfrm||' aname:'||aname);
dbms_output.put_line('----------------------------');

dbms_output.put_line('第三个：atype1.GETINFO :' ||atype1.GETINFO(prec,scale,len,csid,csfrm,schema_name,type_name,version,numelems));
dbms_output.put_line(prec||' scale:'||scale||' len:'||len||' csid:'||csid||' csfrm:'||csfrm||' schema_name:'||schema_name||' type_name:'||type_name||' version:'||version||' numelems:'||numelems);
dbms_output.put_line('atype1.GETATTRELEMINFO:' ||atype1.GETATTRELEMINFO(1,prec,scale,len,csid,csfrm,atype2,aname));
dbms_output.put_line(prec||' scale:'||scale||' len:'||len||' csid:'||csid||' csfrm:'||csfrm||' aname:'||aname);
exception when others then
dbms_output.put_line('sqlerrm: '||sqlerrm);
end;
end loop;
end;
/
