#各参数传入正确类型+GETPERSISTENT传入schema_name存在汉字等+GETPERSISTENT传入type_name存在汉字等+传入type基于简单类型
declare
atype anytype;
atype1 anytype;
prec PLS_INTEGER; 
scale PLS_INTEGER;
len PLS_INTEGER; 
csid PLS_INTEGER;
csfrm PLS_INTEGER;
schema_name VARCHAR2(200); 
type_name VARCHAR2(200); 
version varchar2(200);
numelems PLS_INTEGER;
aname varchar2(200);
type c_nested is table of varchar2(200);
v_nested c_nested:=c_nested('c_c','cwx1','"会话"','会话1','CWX');
v_nested1 c_nested:=c_nested('CAI_TYPE1','CAI_TYPE2','CAI_TYPE3','CAI_TYPE4','c_tp1','"ctp1"','哈哈','"哈哈哈"');
begin
for i in v_nested.first ..v_nested.last loop
for j in v_nested1.first ..v_nested1.last loop
begin
if v_nested(i)='CWX' then
dbms_output.put_line('--------------------当前传入的schema_name为：CWX,  type_name为：'||v_nested1(j));
atype:=anytype.GETPERSISTENT('CWX',upper(v_nested1(j)));
else
dbms_output.put_line('--------------------当前传入的schema_name为：'||v_nested(i)||'  type_name为：CAI_TYPE1');
atype:=anytype.GETPERSISTENT(upper(v_nested(i)),'CAI_TYPE1');
end if;
dbms_output.put_line('anytype.GETINFO :' ||atype.GETINFO(prec,scale,len,csid,csfrm,schema_name,type_name,version,numelems));
dbms_output.put_line(prec||' scale:'||scale||' len:'||len||' csid:'||csid||' csfrm:'||csfrm||' schema_name:'||schema_name||' type_name:'||type_name||' version:'||version||' numelems:'||numelems);
dbms_output.put_line('anytype.GETATTRELEMINFO:' ||atype.GETATTRELEMINFO(1,prec,scale,len,csid,csfrm,atype1,aname));
dbms_output.put_line(prec||' scale:'||scale||' len:'||len||' csid:'||csid||' csfrm:'||csfrm||' aname:'||aname);
if atype1 is null then
dbms_output.put_line('atype1为空');
else
dbms_output.put_line('anytype1.GETINFO :' ||atype.GETINFO(prec,scale,len,csid,csfrm,schema_name,type_name,version,numelems));
dbms_output.put_line(prec||' scale:'||scale||' len:'||len||' csid:'||csid||' csfrm:'||csfrm||' schema_name:'||schema_name||' type_name:'||type_name||' version:'||version||' numelems:'||numelems);
end if;

exception when others then
dbms_output.put_line('--------报错啦'||sqlerrm);
end;
end loop;
end loop;
end;
/
