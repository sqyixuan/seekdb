##作为return 返回值(存在链接符+存在运算符)
create or replace function cai_func return number is
atype anytype:=anytype.GETPERSISTENT('CWX','CAI_TYPE1');
atype1 anytype;
v_out1 number; 
v_out2 varchar(200);
begin
return atype.GETINFO(v_out1,v_out1,v_out1,v_out1,v_out1,v_out2,v_out2,v_out2,v_out1)+atype.GETATTRELEMINFO(1,v_out1,v_out1,v_out1,v_out1,v_out1,atype1,v_out2);
end;
/
