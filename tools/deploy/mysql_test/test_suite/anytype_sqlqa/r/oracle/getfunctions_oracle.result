##传入预定义类型+自定义类型
declare
atype anytype;
atype1 anytype;
v_out1 real;
v_out2 string(200);

subtype c_number is number;
v_out3 c_number;
subtype c_varchar is varchar2(200);
v_out4 c_varchar;
begin
atype:=anytype.GETPERSISTENT('CWX','CAI_TYPE1');
dbms_output.put_line('----预定义类型------');
dbms_output.put_line('anytype.GETINFO :' ||atype.GETINFO(v_out1,v_out1,v_out1,v_out1,v_out1,v_out2,v_out2,v_out2,v_out1));
dbms_output.put_line(' v_out1:'||v_out1||' v_out2:'||v_out2);
dbms_output.put_line('anytype.GETATTRELEMINFO:' ||atype.GETATTRELEMINFO(1,v_out1,v_out1,v_out1,v_out1,v_out1,atype1,v_out2));
dbms_output.put_line(' v_out1:'||v_out1||' v_out2:'||v_out2);

dbms_output.put_line('----自定义类型------');
dbms_output.put_line('anytype.GETINFO :' ||atype.GETINFO(v_out3,v_out3,v_out3,v_out3,v_out3,v_out4,v_out4,v_out4,v_out3));
dbms_output.put_line(' v_out3:'||v_out3||' v_out4:'||v_out4);
dbms_output.put_line('anytype.GETATTRELEMINFO:' ||atype.GETATTRELEMINFO(1,v_out3,v_out3,v_out3,v_out3,v_out3,atype1,v_out4));
dbms_output.put_line(' v_out3:'||v_out3||' v_out4:'||v_out4);
end;
/
select println() from dual;/
+-------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------+
| PRINTLN()                                                                                                                                                                                                                                 |
+-------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------+
| ----预定义类型------
  anytype.GETINFO :248
   v_out1: v_out2:
  anytype.GETATTRELEMINFO:9
   v_out1:2 v_out2:
  ----自定义类型------
  anytype.GETINFO :248
   v_out3: v_out4:
  anytype.GETATTRELEMINFO:9
   v_out3:2 v_out4:           |
+-------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------+
##传入数字，null等
declare
atype anytype;
atype1 anytype; 
begin
atype:=anytype.GETPERSISTENT('CWX','CAI_TYPE1');
dbms_output.put_line('anytype.GETINFO :' ||atype.GETINFO(1,1,1,1,1,1,1,1,1));
exception when others then
begin
dbms_output.put_line('GETINFO失败啦：'||sqlerrm);
dbms_output.put_line('anytype.GETATTRELEMINFO:' ||atype.GETATTRELEMINFO(1,1,1,1,1,1,atype1,1));
exception when others then
dbms_output.put_line('GETATTRELEMINFO失败啦：'||sqlerrm);
end;
end;
