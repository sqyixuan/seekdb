##GETINFO  function + GETATTRELEMINFO function 验证
##out参数验证（prec,scale,len,csid,csfrm,schema_name,type_name,version,numelems + attr_elt_type，aname）
##GETINFO 获取 anytype
##同 34967728
declare
ad1 anydata:=anydata.ConvertCollection(cai_type1(2,12));
ad2 anydata:=anydata.ConvertCollection(cai_type2(2,12));
ad3 anydata:=anydata.ConvertObject(cai_type3(2,12));
ad4 anydata:=anydata.ConvertObject(cai_type4(2,12));

atype anytype;
atype1 anytype;
prec PLS_INTEGER; 
scale PLS_INTEGER;
len PLS_INTEGER; 
csid PLS_INTEGER;
csfrm PLS_INTEGER;
schema_name VARCHAR2(200); 
type_name VARCHAR2(200); 
version varchar2(200);
numelems PLS_INTEGER;
aname varchar2(200);
type c_nested is table of anydata;
v_nested c_nested:=c_nested(ad1,ad2,ad3,ad4);
begin
for i in v_nested.first ..v_nested.last loop
begin
dbms_output.put_line('--------------------当前传入的为：ad'||i||'，对应的typecode为：'||v_nested(i).gettype(atype));
dbms_output.put_line('anytype.GETINFO :' ||atype.GETINFO(prec,scale,len,csid,csfrm,schema_name,type_name,version,numelems));
dbms_output.put_line(prec||' scale:'||scale||' len:'||len||' csid:'||csid||' csfrm:'||csfrm||' schema_name:'||schema_name||' type_name:'||type_name||' version:'||version||' numelems:'||numelems);
dbms_output.put_line('anytype.GETATTRELEMINFO:' ||atype.GETATTRELEMINFO(1,prec,scale,len,csid,csfrm,atype1,aname));
dbms_output.put_line(prec||' scale:'||scale||' len:'||len||' csid:'||csid||' csfrm:'||csfrm||' aname:'||aname);
if atype1 is null then
dbms_output.put_line('atype1为空');
else
dbms_output.put_line('anytype1.GETINFO :' ||atype1.GETINFO(prec,scale,len,csid,csfrm,schema_name,type_name,version,numelems));
dbms_output.put_line(prec||' scale:'||scale||' len:'||len||' csid:'||csid||' csfrm:'||csfrm||' schema_name:'||schema_name||' type_name:'||type_name||' version:'||version||' numelems:'||numelems);
end if;

exception when others then
dbms_output.put_line('--------报错啦'||sqlerrm);
end;
end loop;
end;
/
