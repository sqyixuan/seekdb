##传入anytype的typecode为float等
declare
atype anytype;
a anytype;
type c_tpd is table of varchar2(200);
v_tpd c_tpd:=c_tpd(12,2,95,96,9,1,113,112,187,188,232,189,190,286,287,288,100,101,104);
v_tpd1 c_tpd:=c_tpd('data','number','raw','char','varchar2','varchar','blob','clob','TIMESTAMP','TIMESTAMP_TZ','TIMESTAMP_LTZ','INTERVAL_YM','INTERVAL_DS','NCHAR','NVARCHAR2','NCLOB','FLOAT','double','UROWID');
prec        PLS_INTEGER; 
scale       PLS_INTEGER;
len         PLS_INTEGER; 
csid        PLS_INTEGER;
csfrm       PLS_INTEGER;
schema_name VARCHAR2(200); 
type_name   VARCHAR2(200); 
version     varchar2(200);
numelems    PLS_INTEGER;
aname     varchar2(200);
begin
for i in v_tpd.first ..v_tpd.last loop
begin
anytype.begincreate(v_tpd(i),atype);
atype.setinfo(1,1,1,1,1);
atype.endcreate;
dbms_output.put_line('------------'||v_tpd1(i)||'成功啦------------------------------');
begin
dbms_output.put_line('anytype.GETINFO :' ||atype.GETINFO(prec,scale,len,csid,csfrm,schema_name,type_name,version,numelems));
dbms_output.put_line(prec||' scale:'||scale||' len:'||len||' csid:'||csid||' csfrm:'||csfrm||' schema_name:'||schema_name||' type_name:'||type_name||' version:'||version||' numelems:'||numelems);
dbms_output.put_line('anytype.GETATTRELEMINFO:' ||atype.GETATTRELEMINFO(1,prec,scale,len,csid,csfrm,a,aname));
dbms_output.put_line(prec||' scale:'||scale||' len:'||len||' csid:'||csid||' csfrm:'||csfrm||' aname:'||aname);
exception when others then
dbms_output.put_line('GETATTRELEMINFO失败啦');
end;
exception when others then
dbms_output.put_line('------------'||v_tpd1(i)||'失败啦------------------------------');
end;
end loop;

end;
/
