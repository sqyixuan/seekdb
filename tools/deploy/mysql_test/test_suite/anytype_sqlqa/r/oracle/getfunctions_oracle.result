drop user cwx cascade;
drop user cwx1 cascade;
drop user c_c cascade;
drop user "会话" cascade;
drop user 会话1 cascade;
create user cwx IDENTIFIED BY cwx;
grant all on *.* to cwx WITH GRANT OPTION;
grant dba to cwx;
create user cwx1 IDENTIFIED BY cwx1;
grant all on *.* to cwx1 WITH GRANT OPTION;
grant dba to cwx1;
create user c_c identified by cwx;
grant all on *.* to c_c WITH GRANT OPTION;
grant dba to c_c;
create user "会话" identified by cwx;
grant all on *.* to "会话" WITH GRANT OPTION;
grant dba to "会话";
create user 会话1 identified by cwx;
grant all on *.* to 会话1 WITH GRANT OPTION;
grant dba to 会话1;
##aty-5,aty-6,aty-7,aty-8,aty-9,aty-10
##GETPERSISTENT,GETINFO,GETATTRELEMINFO 验证+ 参数通用验证+procedure类型通用验证+function类型通用验证
set autocommit=1;
alter session set nls_date_format = 'yyyy-mm-dd hh24:mi:ss';
alter session set nls_timestamp_format = 'yyyy-mm-dd hh24:mi:ss.FF';
alter session set NLS_TIMESTAMP_TZ_FORMAT='YYYY-MM-DD HH24:MI:SS.FF TZR TZD';
result_format: 4
create or replace type cai_type1 force is table of varchar2(200);
/
create or replace type cai_type2 force is varray(2) of varchar2(200);
/
create or replace type cai_type3 force as object(
a varchar2(200),
b varchar2(200),
member procedure t_proc
);
/
create or replace type cai_type4 force as object(id varchar2(200),name varchar2(200));
/
create table cait(t_id varchar2(200),t_name varchar2(200));/
##创建其他user下type
create or replace type cwx1.cai_type1 force is table of varchar2(200);
/
create or replace type cwx1.cai_type2 force is varray(2) of varchar2(200);
/
create or replace type cwx1.cai_type3 force as object(
a varchar2(200),
b varchar2(200),
member procedure t_proc
);
/
create or replace type cwx1.cai_type4 force as object(id varchar2(200),name varchar2(200));
/
create table cwx1.cait(t_id varchar2(200),t_name varchar2(200));/
create or replace type c_c.cai_type1 force is table of varchar2(200);
/
create or replace type "会话".cai_type1 force is table of varchar2(200);
/
create or replace type 会话1.cai_type1 force is table of varchar2(200);
/
