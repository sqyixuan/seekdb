##传入复杂数据类型
drop table cait;/
create table cait(t_id number,t_name varchar2(200));/
##34670443,GETPERSISTENT的out参数传入嵌套表，ob失败，oracle成功,预期结果：ob成功
declare
atype anytype;
atype1 anytype;
type c_nested is table of number;
v_out1 c_nested:=c_nested(1);
type c_nested1 is table of varchar(200);
v_out2 c_nested1:=c_nested1(1);

type c_record is record(r_id number,r_name varchar(200));
v_out c_record;

v_out3 cait.t_id%type;
v_out4 cait.t_name%type;

v_out5 cait%rowtype;
begin
atype:=anytype.GETPERSISTENT('CWX','CAI_TYPE1');
dbms_output.put_line('----嵌套表------');
dbms_output.put_line('anytype.GETINFO :' ||atype.GETINFO(v_out1(1),v_out1(1),v_out1(1),v_out1(1),v_out1(1),v_out2(1),v_out2(1),v_out2(1),v_out1(1)));
dbms_output.put_line(' v_out1(1):'||v_out1(1)||' v_out2(1):'||v_out2(1));
dbms_output.put_line('anytype.GETATTRELEMINFO:' ||atype.GETATTRELEMINFO(1,v_out1(1),v_out1(1),v_out1(1),v_out1(1),v_out1(1),atype1,v_out2(1)));
dbms_output.put_line(' v_out1(1):'||v_out1(1)||' v_out2(1):'||v_out2(1));

dbms_output.put_line('----record------');
dbms_output.put_line('anytype.GETINFO :' ||atype.GETINFO(v_out.r_id,v_out.r_id,v_out.r_id,v_out.r_id,v_out.r_id,v_out.r_name,v_out.r_name,v_out.r_name,v_out.r_id));
dbms_output.put_line(' v_out.r_id:'||v_out.r_id||' v_out.r_name:'||v_out.r_name);
dbms_output.put_line('anytype.GETATTRELEMINFO:' ||atype.GETATTRELEMINFO(1,v_out.r_id,v_out.r_id,v_out.r_id,v_out.r_id,v_out.r_id,atype1,v_out.r_name));
dbms_output.put_line(' v_out.r_id:'||v_out.r_id||' v_out.r_name:'||v_out.r_name);

dbms_output.put_line('----%type------');
dbms_output.put_line('anytype.GETINFO :' ||atype.GETINFO(v_out3,v_out3,v_out3,v_out3,v_out3,v_out4,v_out4,v_out4,v_out3));
dbms_output.put_line(' v_out3:'||v_out3||' v_out4:'||v_out4);
dbms_output.put_line('anytype.GETATTRELEMINFO:' ||atype.GETATTRELEMINFO(1,v_out3,v_out3,v_out3,v_out3,v_out3,atype1,v_out4));
dbms_output.put_line(' v_out3:'||v_out3||' v_out4:'||v_out4);

dbms_output.put_line('----%rowtype------');
dbms_output.put_line('anytype.GETINFO :' ||atype.GETINFO(v_out5.t_id,v_out5.t_id,v_out5.t_id,v_out5.t_id,v_out5.t_id,v_out5.t_name,v_out5.t_name,v_out5.t_name,v_out5.t_id));
dbms_output.put_line(' v_out5.t_id:'||v_out5.t_id||' v_out5.t_name:'||v_out5.t_name);
dbms_output.put_line('anytype.GETATTRELEMINFO:' ||atype.GETATTRELEMINFO(1,v_out5.t_id,v_out5.t_id,v_out5.t_id,v_out5.t_id,v_out5.t_id,atype1,v_out5.t_name));
dbms_output.put_line(' v_out5.t_id:'||v_out5.t_id||' v_out5.t_name:'||v_out5.t_name);
end;
/
