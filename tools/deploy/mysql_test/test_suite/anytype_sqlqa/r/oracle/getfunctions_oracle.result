create or replace package cai_pack1 is
 atype anytype:=anytype.GETPERSISTENT('CWX','CAI_TYPE1');
 atype1 anytype;
 v_out1 number; 
 v_out2 varchar(200);
 subtype cai_simple is number;
 v_value1 cai_simple:=atype.GETINFO(v_out1,v_out1,v_out1,v_out1,v_out1,v_out2,v_out2,v_out2,v_out1);
 v_value2 cai_simple:=atype.GETATTRELEMINFO(1,v_out1,v_out1,v_out1,v_out1,v_out1,atype1,v_out2);
 v_value3 cai_type1:=cai_type1(atype.GETINFO(v_out1,v_out1,v_out1,v_out1,v_out1,v_out2,v_out2,v_out2,v_out1),atype.GETATTRELEMINFO(1,v_out1,v_out1,v_out1,v_out1,v_out1,atype1,v_out2));
 v_value4 number:=atype.GETINFO(v_out1,v_out1,v_out1,v_out1,v_out1,v_out2,v_out2,v_out2,v_out1);
 v_value5 number:=atype.GETATTRELEMINFO(1,v_out1,v_out1,v_out1,v_out1,v_out1,atype1,v_out2);
end;
/
begin
