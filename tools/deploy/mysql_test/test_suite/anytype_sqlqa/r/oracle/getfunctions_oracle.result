dbms_output.put_line('自定义 GETATTRELEMINFO：'||cai_pack1.v_value2);
dbms_output.put_line('type类 GETINFO：'||cai_pack1.v_value3(1));
dbms_output.put_line('type类 GETATTRELEMINFO：'||cai_pack1.v_value3(2));
dbms_output.put_line('正常使用 GETINFO：'||cai_pack1.v_value4);
dbms_output.put_line('正常使用 GETATTRELEMINFO：'||cai_pack1.v_value5);
end;
