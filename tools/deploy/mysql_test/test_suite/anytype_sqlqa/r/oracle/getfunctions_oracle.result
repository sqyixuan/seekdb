##数据类型（clob，varchar，number等）
declare
atype anytype;
atype1 anytype;
prec number; 
scale number;
len number; 
csid number;
csfrm number;
schema_name VARCHAR(200); 
type_name VARCHAR(200); 
version varchar(200);
numelems number;
aname varchar(200);
begin
atype:=anytype.GETPERSISTENT('CWX','CAI_TYPE1');
dbms_output.put_line('anytype.GETINFO :' ||atype.GETINFO(prec,scale,len,csid,csfrm,schema_name,type_name,version,numelems));
dbms_output.put_line(prec||' scale:'||scale||' len:'||len||' csid:'||csid||' csfrm:'||csfrm||' schema_name:'||schema_name||' type_name:'||type_name||' version:'||version||' numelems:'||numelems);
dbms_output.put_line('anytype.GETATTRELEMINFO:' ||atype.GETATTRELEMINFO(1,prec,scale,len,csid,csfrm,atype1,aname));
dbms_output.put_line(prec||' scale:'||scale||' len:'||len||' csid:'||csid||' csfrm:'||csfrm||' aname:'||aname);

end;
/
select println() from dual;/
