##使用场景
##嵌套procedure+匿名块+自定义exception（raise+exception_init）
declare
v_value number;
atype anytype;
atype1 anytype;
v_out1 number:=1; 
v_out2 varchar(200):='a';
e exception;
pragma exception_init(e,-5114);
--pragma exception_init(e,-6502); --oracle中的错误码
 procedure cai_pro is
 a exception;
 b anytype;
 b1 anytype;
 v1 number:=1; 
 v2 varchar(200):='a';
 begin
 raise a;
 exception when a then
  dbms_output.put_line('cai_pro内');
  b:=anytype.GETPERSISTENT('CWX','CAI_TYPE1');
  dbms_output.put_line('b.GETINFO:'||b.GETINFO(v1,v1,v1,v1,v1,v2,v2,v2,v1));
  dbms_output.put_line(' v1:'||v1||' v2:'||v2);
  dbms_output.put_line('b.GETATTRELEMINFO:'||b.GETATTRELEMINFO(1,v1,v1,v1,v1,v1,b1,v2));
  dbms_output.put_line(' v1:'||v1||' v2:'||v2);
 end;
begin
cai_pro;
v_value:='a';
exception when e then 
dbms_output.put_line('cai_pro外');
atype:=anytype.GETPERSISTENT('CWX','CAI_TYPE1');
dbms_output.put_line('atype.GETINFO:'||anytype.GETINFO(atype,v_out1,v_out1,v_out1,v_out1,v_out1,v_out2,v_out2,v_out2,v_out1));
dbms_output.put_line(' v_out1:'||v_out1||' v_out2:'||v_out2);
dbms_output.put_line('atype.GETATTRELEMINFO:'||anytype.GETATTRELEMINFO(atype,1,v_out1,v_out1,v_out1,v_out1,v_out1,atype1,v_out2));
dbms_output.put_line(' v_out1:'||v_out1||' v_out2:'||v_out2);
end;
/
