create view nview8 as
select t3.*, t4.* from 
(WITH cte AS (select c1 from t1) select c1 from cte where cte.c1 > 1000) t3 
  left join 
(WITH cte(a, b) AS (select c1,c2 from t1) select a,b from cte where cte.a > 1000) t4 
on t4.a=t3.c1 
order by t4.b;
explain  select * from nview8;
