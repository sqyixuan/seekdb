create view nview20 as
with
  cte1 AS( select * from t1)
select * from cte1 left join t2 on cte1.c1=t2.c21 having not (t2.c21 <=> cte1.c1) order by cte1.c1;
explain  select * from nview20;
Query Plan
=========================================
|ID|OPERATOR        |NAME|EST. ROWS|COST|
-----------------------------------------
|0 |MERGE OUTER JOIN|    |7        |95  |
|1 | SORT           |    |7        |47  |
|2 |  SUBPLAN SCAN  |cte1|7        |39  |
|3 |   TABLE SCAN   |t1  |7        |38  |
|4 | SORT           |    |7        |46  |
|5 |  TABLE SCAN    |t2  |7        |38  |
=========================================

