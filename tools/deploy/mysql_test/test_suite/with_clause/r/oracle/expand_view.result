show create view nview17;
View	Create View	character_set_client	collation_connection
nview17	CREATE VIEW `nview17` AS WITH `cte_outer` as (select `ctetest`.`t2`.`c21` AS `c21`,`ctetest`.`t2`.`c22` AS `c22`,`ctetest`.`t2`.`c23` AS `c23` from `ctetest`.`t2`) select `t3`.`c1` AS `c1`,`t4`.`c21` AS `c21`,`t4`.`c22` AS `c22` from ((WITH `cte_inner` as (select `ctetest`.`t1`.`c1` AS `c1` from `ctetest`.`t1`) select `cte_inner`.`c1` AS `c1` from  cte_inner where (`cte_inner`.`c1` > 1000)) t3 left join (WITH `cte_inner`(a, b) as (select `ctetest`.`t1`.`c1` AS `a`,`ctetest`.`t1`.`c2` AS `b` from `ctetest`.`t1` `t1`) select `cte_outer`.`c21` AS `c21`,`cte_outer`.`c22` AS `c22` from  cte_outer where (`cte_outer`.`c21` > 1000)) t4 on ((`t4`.`c21` = `t3`.`c1`))) order by `t4`.`c22`	utf8mb4	utf8mb4_general_ci
select * from nview17;
+------+------+------+
| c1   | c21  | c22  |
+------+------+------+
+------+------+------+
WITH cte_outer AS (select * from t2)
select t3.*, t4.* from 
( WITH cte_inner AS (select c1 from t1) select c1 from cte_inner where cte_inner.c1 > 1000) t3 
  left join 
( WITH cte_inner(a, b) AS (select c1,c2 from t1) select c21,c22 from cte_outer where cte_outer.c21 > 1000) t4 
on t4.c21=t3.c1 
order by t4.c22;
+------+------+------+
| c1   | c21  | c22  |
+------+------+------+
+------+------+------+

create view nview18 as
with cte as (select * from t1) select * from (with cte as (select * from t2) select * from cte) t3, cte where t3.c21 = cte.c1;
explain  select * from nview18;
Query Plan
====================================
|ID|OPERATOR   |NAME|EST. ROWS|COST|
------------------------------------
|0 |HASH JOIN  |    |7        |92  |
|1 | TABLE SCAN|t2  |7        |38  |
|2 | TABLE SCAN|t1  |7        |38  |
====================================

Outputs & filters: 
-------------------------------------
  0 - output([t2.c21], [t2.c22], [t2.c23], [t1.c1], [t1.c2], [t1.c3]), filter(nil), 
      equal_conds([t2.c21 = t1.c1]), other_conds(nil)
  1 - output([t2.c21], [t2.c22], [t2.c23]), filter(nil), 
      access([t2.c21], [t2.c22], [t2.c23]), partitions(p0)
  2 - output([t1.c1], [t1.c2], [t1.c3]), filter(nil), 
      access([t1.c1], [t1.c2], [t1.c3]), partitions(p0)

