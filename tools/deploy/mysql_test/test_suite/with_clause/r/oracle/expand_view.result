create view nview27 as
with cte (a,b,c) as  (     
  select id, name, leaderid from emp where emp.id = 1     
  union all     
  select emp.id ,emp.name, emp.leaderid from emp, cte where emp.leaderid = cte.a 
  ) search depth first by a set sad 
select * from cte;
explain select * from nview27;
