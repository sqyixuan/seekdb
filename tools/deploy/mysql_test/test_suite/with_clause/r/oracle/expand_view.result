show create view nview7;
View	Create View	character_set_client	collation_connection
nview7	CREATE VIEW `nview7` AS WITH `cte1`(a, b) as (select `ctetest`.`t1`.`c1` AS `a`,`ctetest`.`t1`.`c2` AS `b` from `ctetest`.`t1`), `cte2`(c, d) as (select `ctetest`.`t2`.`c21` AS `c`,`ctetest`.`t2`.`c22` AS `d` from `ctetest`.`t2`) select /*+ NO_REWRITE */1 AS `1` from  cte1 where (`cte1`.`a` = any (select `cte2`.`d` from  cte2 where exists(((select `cte1`.`b` from  cte1) union (select `cte1`.`a` from  cte1)))))	utf8mb4	utf8mb4_general_ci
select * from nview7;
