  1 - output([cte.id], [cte.val], [cte.lev], [cte.path]), filter(nil), 
      access([cte.id], [cte.val], [cte.lev], [cte.path])
  2 - output([UNION(t4.id, t4.id)], [UNION(t4.value, t4.value)], [UNION(cast(?, BIGINT(20, 0)), cast(cte.lev + 1, BIGINT(20, 0)))], [UNION(cast(cast(t4.id, VARCHAR(200)), VARCHAR(212)), CONCAT(cte.path, ?, t4.id))]), filter(nil)
  3 - output([t4.id], [t4.value], [cast(?, BIGINT(20, 0))], [cast(cast(t4.id, VARCHAR(200)), VARCHAR(212))]), filter([(T_OP_IS, t4.parent_id, NULL, 0)]), 
      access([t4.parent_id], [t4.id], [t4.value]), partitions(p0)
  4 - output([t4.id], [t4.value], [cast(cte.lev + 1, BIGINT(20, 0))], [CONCAT(cte.path, ?, t4.id)]), filter(nil), 
      equal_conds([t4.parent_id = cte.id]), other_conds(nil)
  5 - output([t4.parent_id], [t4.id], [t4.value]), filter(nil), 
      access([t4.parent_id], [t4.id], [t4.value]), partitions(p0)
  6 - output([cte.id], [cte.path], [cast(cte.lev + 1, BIGINT(20, 0))]), filter(nil), 
      access([cte.id], [cte.lev], [cte.path]), partitions(nil)

show create view nview24;
View	Create View	character_set_client	collation_connection
nview24	CREATE VIEW `nview24` AS WITH `cte`(id, val, lev, path) as ((select `cterecursivetest`.`t4`.`id` AS `id`,`cterecursivetest`.`t4`.`value` AS `value`,0 AS `lev`,cast(`cterecursivetest`.`t4`.`id` as varchar(200)) AS `path` from `cterecursivetest`.`t4` where (`cterecursivetest`.`t4`.`parent_id` is null)) union  ALL (select `cterecursivetest`.`t4`.`id` AS `id`,`cterecursivetest`.`t4`.`value` AS `value`,(`cte`.`lev` + 1) AS `cte.lev+1`,CONCAT(`cte`.`path`,',',`cterecursivetest`.`t4`.`id`) AS `CONCAT(cte.path,",", t4.id)` from (`cte` join `cterecursivetest`.`t4` `t4` on ((`cterecursivetest`.`t4`.`parent_id` = `cte`.`id`))))) select `cte`.`id` AS `id`,`cte`.`val` AS `val`,`cte`.`lev` AS `lev`,`cte`.`path` AS `path` from  cte order by `cte`.`path`	utf8mb4	utf8mb4_general_ci
select * from nview24;
+------+------+------+---------+
| id   | val  | lev  | path    |
+------+------+------+---------+
|    1 | A    |    0 | 1       |
|    2 | B    |    1 | 1,2     |
|    5 | E    |    2 | 1,2,5   |
|    6 | F    |    2 | 1,2,6   |
|    8 | H    |    3 | 1,2,6,8 |
|    3 | C    |    1 | 1,3     |
|    4 | D    |    1 | 1,4     |
|    7 | G    |    2 | 1,4,7   |
+------+------+------+---------+
with cte( id, val, lev, path) as (   
  select id, value, 0 as lev, CAST(id AS VARCHAR(200)) AS path  from t4 where parent_id is null 
  union all   
  select t4.id, t4.value, cte.lev+1, CONCAT(cte.path,',', t4.id)  from cte join t4 on t4.parent_id=cte.id) 
select * from cte order by path;
