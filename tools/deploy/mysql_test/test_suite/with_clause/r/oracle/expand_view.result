| id   | val  | lev  | path    |
+------+------+------+---------+
|    1 | A    |    0 | 1       |
|    2 | B    |    1 | 1,2     |
|    5 | E    |    2 | 1,2,5   |
|    6 | F    |    2 | 1,2,6   |
|    8 | H    |    3 | 1,2,6,8 |
|    3 | C    |    1 | 1,3     |
|    4 | D    |    1 | 1,4     |
|    7 | G    |    2 | 1,4,7   |
+------+------+------+---------+

create view nview25 as
with cte(a,b,c) as 
(
  select c1,c2,c3 from t1 where t1.c1 < 20 
  union all 
  select c1,c2,c3 from t1, cte where cte.a = t1.c1 and cte.c < 10
) select * from cte;
explain select * from nview25;
Query Plan
=============================================
|ID|OPERATOR            |NAME|EST. ROWS|COST|
---------------------------------------------
|0 |SUBPLAN SCAN        |cte |5        |158 |
|1 | RECURSIVE UNION ALL|    |5        |157 |
|2 |  TABLE SCAN        |t1  |2        |39  |
|3 |  HASH JOIN         |    |3        |116 |
|4 |   TABLE SCAN       |t1  |7        |38  |
|5 |   TABLE SCAN       |cte |1        |1   |
=============================================

Outputs & filters: 
-------------------------------------
  0 - output([cte.a], [cte.b], [cte.c]), filter(nil), 
      access([cte.a], [cte.b], [cte.c])
  1 - output([UNION(t1.c1, t1.c1)], [UNION(t1.c2, t1.c2)], [UNION(t1.c3, t1.c3)]), filter(nil)
  2 - output([t1.c1], [t1.c2], [t1.c3]), filter([t1.c1 < 20]), 
      access([t1.c1], [t1.c2], [t1.c3]), partitions(p0)
  3 - output([t1.c1], [t1.c2], [t1.c3]), filter(nil), 
      equal_conds([cte.a = t1.c1]), other_conds(nil)
  4 - output([t1.c1], [t1.c2], [t1.c3]), filter(nil), 
      access([t1.c1], [t1.c2], [t1.c3]), partitions(p0)
  5 - output([cte.a]), filter([cte.c < 10]), 
      access([cte.a], [cte.c]), partitions(nil)

