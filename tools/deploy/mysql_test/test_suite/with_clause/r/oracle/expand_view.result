create view nview24 as
with cte( id, val, lev, path) as (   
  select id, value, 0 as lev, CAST(id AS VARCHAR(200)) AS path  from t4 where parent_id is null 
  union all   
  select t4.id, t4.value, cte.lev+1, CONCAT(cte.path,',', t4.id)  from cte join t4 on t4.parent_id=cte.id) 
select * from cte order by path;
explain select * from nview24;
