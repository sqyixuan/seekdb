##############################
##   CASE 3. cte中的定义使用分区或者hint
##############################
create view nview3 as
with
  cte0 AS (
            select * from t3 partition(p0)
          ),
  cte1 AS (
            select /*+ index(t4 i1) */ * from t4 where c2 > 0
          )
select /*+leading(cte1 cte0)*/ cte0.c1, cte1.c1 from cte0, cte1 where cte0.c1 = cte1.c1;
show create view nview3;
View	Create View	character_set_client	collation_connection
nview3	CREATE VIEW `nview3` AS WITH `cte0` as (select `ctetest`.`t3`.`c1` AS `c1`,`ctetest`.`t3`.`c2` AS `c2` from `ctetest`.`t3` partition(p0)), `cte1` as (select /*+ INDEX(t4 i1) */`ctetest`.`t4`.`c1` AS `c1`,`ctetest`.`t4`.`c2` AS `c2` from `ctetest`.`t4` where (`ctetest`.`t4`.`c2` > 0)) select /*+ LEADING(cte1 cte0) */`cte0`.`c1` AS `c1`,`cte1`.`c1` AS `c1` from  cte0, cte1 where (`cte0`.`c1` = `cte1`.`c1`)	utf8mb4	utf8mb4_general_ci
select * from nview3;
+----+----+
| c1 | c1 |
+----+----+
+----+----+
with
  cte0 AS (
            select * from t3 partition(p0)
          ),
  cte1 AS (
            select /*+ index(t4 i1) */ * from t4 where c2 > 0
          )
select cte0.c1, cte1.c1 from cte0, cte1 where cte0.c1 = cte1.c1;
+----+----+
| c1 | c1 |
+----+----+
+----+----+

##############################
##   CASE 4. 主句中带有hint
##############################
create view nview4 as
WITH cte2 AS (select c1 from t1)
select /*+no_rewrite()*/ c1 from cte2
UNION all
select c21 from t2;
explain  select * from nview4;
Query Plan
======================================
|ID|OPERATOR     |NAME|EST. ROWS|COST|
--------------------------------------
|0 |UNION ALL    |    |14       |81  |
|1 | SUBPLAN SCAN|cte2|7        |39  |
|2 |  TABLE SCAN |t1  |7        |38  |
|3 | TABLE SCAN  |t2  |7        |38  |
======================================

Outputs & filters: 
-------------------------------------
  0 - output([UNION(cte2.c1, t2.c21)]), filter(nil)
  1 - output([cte2.c1]), filter(nil), 
      access([cte2.c1])
  2 - output([t1.c1]), filter(nil), 
      access([t1.c1]), partitions(p0)
  3 - output([t2.c21]), filter(nil), 
      access([t2.c21]), partitions(p0)

show create view nview4;
