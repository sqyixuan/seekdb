##############################
##   CASE 5. 定义中是个union
##############################
create view nview5 as
WITH cte AS
(
  select c1, c2 from t1
  UNION all
  select c21, c22 from t2
)
select c1, c2 from cte;
explain  select * from nview5;
Query Plan
=====================================
|ID|OPERATOR    |NAME|EST. ROWS|COST|
-------------------------------------
|0 |SUBPLAN SCAN|cte |14       |83  |
|1 | UNION ALL  |    |14       |81  |
|2 |  TABLE SCAN|t1  |7        |38  |
|3 |  TABLE SCAN|t2  |7        |38  |
=====================================

Outputs & filters: 
-------------------------------------
  0 - output([cte.c1], [cte.c2]), filter(nil), 
      access([cte.c1], [cte.c2])
  1 - output([UNION(t1.c1, t2.c21)], [UNION(t1.c2, t2.c22)]), filter(nil)
  2 - output([t1.c1], [t1.c2]), filter(nil), 
      access([t1.c1], [t1.c2]), partitions(p0)
  3 - output([t2.c21], [t2.c22]), filter(nil), 
      access([t2.c21], [t2.c22]), partitions(p0)

