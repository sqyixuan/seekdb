use cterecursivetest;

##############################
##   CASE 21~32. 递归句子，句式变化
##############################
create view nview21 as
with cte(n) as (select 1 union all select n+1 from cte where n < 23) select n from cte;
explain  select * from nview21;
Query Plan
=============================================
|ID|OPERATOR            |NAME|EST. ROWS|COST|
---------------------------------------------
|0 |SUBPLAN SCAN        |cte |2        |3   |
|1 | RECURSIVE UNION ALL|    |2        |2   |
|2 |  EXPRESSION        |    |1        |1   |
|3 |  TABLE SCAN        |cte |1        |1   |
=============================================

Outputs & filters: 
-------------------------------------
  0 - output([cte.n]), filter(nil), 
      access([cte.n])
  1 - output([UNION(cast(?, BIGINT(20, 0)), cast(cte.n + 1, BIGINT(20, 0)))]), filter(nil)
  2 - output([cast(?, BIGINT(20, 0))]), filter(nil)
      values({cast(?, BIGINT(20, 0))})
  3 - output([cast(cte.n + 1, BIGINT(20, 0))]), filter([cte.n < 23]), 
      access([cte.n]), partitions(nil)

