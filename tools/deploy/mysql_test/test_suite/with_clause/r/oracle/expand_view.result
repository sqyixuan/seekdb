| 1 |
+---+
+---+
WITH
   cte1 (a, b) AS (SELECT c1, c2 FROM t1),
   cte2 (c, d) AS (SELECT c21, c22 FROM t2)
select /*+no_rewrite()*/ 1 from cte1 where a in (select d from cte2 where exists( (select b from cte1) union (select a from cte1)));
