##############################
##   CASE 32. 递归句子，测试cte引用其他cte时候能不能正确展开view
##############################
create view nview32 as
with cte(a) as (select 1 from dual union all select 2 from dual), cte_1(b) as (select 1 from dual union all select * from cte) select * from cte_1;
explain select * from nview32;
Query Plan
========================================
|ID|OPERATOR      |NAME |EST. ROWS|COST|
----------------------------------------
|0 |SUBPLAN SCAN  |cte_1|3        |3   |
|1 | UNION ALL    |     |3        |3   |
|2 |  EXPRESSION  |     |1        |1   |
|3 |  SUBPLAN SCAN|cte  |2        |2   |
|4 |   UNION ALL  |     |2        |1   |
|5 |    EXPRESSION|     |1        |1   |
|6 |    EXPRESSION|     |1        |1   |
========================================

Outputs & filters: 
-------------------------------------
  0 - output([cte_1.b]), filter(nil), 
      access([cte_1.b])
  1 - output([UNION(1, cte.a)]), filter(nil)
  2 - output([1]), filter(nil)
      values({1})
  3 - output([cte.a]), filter(nil), 
      access([cte.a])
  4 - output([UNION(1, 2)]), filter(nil)
  5 - output([1]), filter(nil)
      values({1})
  6 - output([2]), filter(nil)
      values({2})

