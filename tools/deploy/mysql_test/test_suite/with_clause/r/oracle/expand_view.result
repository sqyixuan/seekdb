##############################
##   CASE 30. 递归句子，测试view中的cycle clause能否正确
##############################
create view nview30 as
with cte (a,b,c) as
(
    select id, name, leaderid from emp where emp.id = 1
    union all
    select emp.id ,emp.name, emp.leaderid from emp, cte where emp.leaderid = cte.a 
) cycle b set iscyc to 'y' default 'n'
select * from cte;
explain select * from nview30;
Query Plan
=============================================
|ID|OPERATOR            |NAME|EST. ROWS|COST|
---------------------------------------------
|0 |SUBPLAN SCAN        |cte |5        |173 |
|1 | RECURSIVE UNION ALL|    |5        |173 |
|2 |  TABLE SCAN        |emp |1        |41  |
|3 |  HASH JOIN         |    |5        |129 |
|4 |   TABLE SCAN       |emp |12       |39  |
|5 |   TABLE SCAN       |cte |1        |1   |
=============================================

Outputs & filters: 
-------------------------------------
  0 - output([cte.a], [cte.b], [cte.c], [cte.iscyc]), filter(nil), 
      access([cte.a], [cte.b], [cte.c], [cte.iscyc])
  1 - output([UNION(emp.id, emp.id)], [UNION(emp.name, emp.name)], [UNION(emp.leaderid, emp.leaderid)], [T_CTE_CYCLE_COLUMN]), filter(nil)
  2 - output([emp.id], [emp.name], [emp.leaderid]), filter([emp.id = 1]), 
      access([emp.id], [emp.name], [emp.leaderid]), partitions(p0)
  3 - output([emp.id], [emp.name], [emp.leaderid]), filter(nil), 
      equal_conds([emp.leaderid = cte.a]), other_conds(nil)
  4 - output([emp.leaderid], [emp.id], [emp.name]), filter(nil), 
      access([emp.leaderid], [emp.id], [emp.name]), partitions(p0)
  5 - output([cte.a]), filter(nil), 
      access([cte.a]), partitions(nil)

