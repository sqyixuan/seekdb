##############################
##   PART 1.3 混合递归和非递归，前面的cte对后面的可见
##############################
create view nview33 as
with cte as (select * from t1) ,
     cte_recursive (n) as (select 1 union all select n+1 from cte_recursive where n < 23) 
select (select count(*) from cte_recursive) from t1;
explain select * from nview33;
Query Plan
========================================================
|ID|OPERATOR              |NAME         |EST. ROWS|COST|
--------------------------------------------------------
|0 |SUBPLAN FILTER        |             |7        |43  |
|1 | TABLE SCAN           |t1           |7        |38  |
|2 | SCALAR GROUP BY      |             |1        |3   |
|3 |  SUBPLAN SCAN        |cte_recursive|2        |3   |
|4 |   RECURSIVE UNION ALL|             |2        |2   |
|5 |    EXPRESSION        |             |1        |1   |
|6 |    TABLE SCAN        |cte_recursive|1        |1   |
========================================================

Outputs & filters: 
-------------------------------------
  0 - output([subquery(1)]), filter(nil), 
      exec_params_(nil), onetime_exprs_(nil), init_plan_idxs_([1])
  1 - output([t1.__pk_increment]), filter(nil), 
      access([t1.__pk_increment]), partitions(p0)
  2 - output([T_FUN_COUNT(0)]), filter(nil), 
      group(nil), agg_func([T_FUN_COUNT(0)])
  3 - output([1]), filter(nil), 
      access(nil)
  4 - output([UNION(cast(?, BIGINT(20, 0)), cast(cte_recursive.n + 1, BIGINT(20, 0)))]), filter(nil)
  5 - output([cast(?, BIGINT(20, 0))]), filter(nil)
      values({cast(?, BIGINT(20, 0))})
  6 - output([cast(cte_recursive.n + 1, BIGINT(20, 0))]), filter([cte_recursive.n < 23]), 
      access([cte_recursive.n]), partitions(nil)

