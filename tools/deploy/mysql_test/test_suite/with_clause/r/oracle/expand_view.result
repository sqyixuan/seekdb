##############################
##   PART 4 view的嵌套
##############################
use ctetest;
create view xview1 as
with cte as (select * from t1) ,
     cte_recursive (n) as (select 1 union all select n+1 from cte_recursive where n < 23)
select (select count(*) from cte_recursive) from t1
union all
select * from ctetest.nview6;
show create view xview1;
View	Create View	character_set_client	collation_connection
xview1	CREATE VIEW `xview1` AS WITH `cte` as (select `ctetest`.`t1`.`c1` AS `c1`,`ctetest`.`t1`.`c2` AS `c2`,`ctetest`.`t1`.`c3` AS `c3` from `ctetest`.`t1`), `cte_recursive`(n) as ((select 1 AS `1`) union  ALL (select (`cte_recursive`.`n` + 1) AS `n+1` from `cte_recursive` where (`cte_recursive`.`n` < 23))) (select (select count(0) from  cte_recursive) AS `(select count(*) from cte_recursive)` from `ctetest`.`t1` `t1`) union  ALL (select `ctetest`.`nview6`.`c1` AS `c1` from `ctetest`.`nview6`)	utf8mb4	utf8mb4_general_ci
select * from xview1;
+--------------------------------------+
| (select count(*) from cte_recursive) |
+--------------------------------------+
|                                   23 |
|                                   23 |
|                                   23 |
|                                   23 |
|                                   23 |
|                                   23 |
|                                   23 |
|                                    1 |
|                                    4 |
|                                    7 |
|                                   10 |
|                                   13 |
|                                   16 |
|                                   19 |
+--------------------------------------+

create view xview2 as
with cte as (select * from t1) ,
     cte_recursive (n) as (select 1 union all select n+1 from cte_recursive where n < 23)
select cte.c1, cte.c2 from cte
union all
select * from ctetest.nview3;
show create view xview2;
View	Create View	character_set_client	collation_connection
xview2	CREATE VIEW `xview2` AS WITH `cte` as (select `ctetest`.`t1`.`c1` AS `c1`,`ctetest`.`t1`.`c2` AS `c2`,`ctetest`.`t1`.`c3` AS `c3` from `ctetest`.`t1`), `cte_recursive`(n) as ((select 1 AS `1`) union  ALL (select (`cte_recursive`.`n` + 1) AS `n+1` from `cte_recursive` where (`cte_recursive`.`n` < 23))) (select `cte`.`c1` AS `c1`,`cte`.`c2` AS `c2` from  cte) union  ALL (select `ctetest`.`nview3`.`c1` AS `c1`,`ctetest`.`nview3`.`c1` AS `c1` from `ctetest`.`nview3`)	utf8mb4	utf8mb4_general_ci
select * from xview2;
