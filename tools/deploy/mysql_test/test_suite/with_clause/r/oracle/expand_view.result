create view nview23 as
with cte( id, val, lev) as (
  select id, value , 0 as lev from t4 where parent_id is null
  union all
  select t4.id, t4.value, cte.lev+1 from cte join t4 on t4.parent_id=cte.id)
select * from cte;
explain select * from nview23;
Query Plan
=============================================
|ID|OPERATOR            |NAME|EST. ROWS|COST|
---------------------------------------------
|0 |SUBPLAN SCAN        |cte |4        |160 |
|1 | RECURSIVE UNION ALL|    |4        |159 |
|2 |  TABLE SCAN        |t4  |1        |40  |
|3 |  HASH JOIN         |    |4        |119 |
|4 |   TABLE SCAN       |t4  |8        |38  |
|5 |   TABLE SCAN       |cte |1        |1   |
=============================================

Outputs & filters: 
-------------------------------------
  0 - output([cte.id], [cte.val], [cte.lev]), filter(nil), 
      access([cte.id], [cte.val], [cte.lev])
  1 - output([UNION(t4.id, t4.id)], [UNION(t4.value, t4.value)], [UNION(cast(?, BIGINT(20, 0)), cast(cte.lev + 1, BIGINT(20, 0)))]), filter(nil)
  2 - output([t4.id], [t4.value], [cast(?, BIGINT(20, 0))]), filter([(T_OP_IS, t4.parent_id, NULL, 0)]), 
      access([t4.parent_id], [t4.id], [t4.value]), partitions(p0)
  3 - output([t4.id], [t4.value], [cast(cte.lev + 1, BIGINT(20, 0))]), filter(nil), 
      equal_conds([t4.parent_id = cte.id]), other_conds(nil)
  4 - output([t4.parent_id], [t4.id], [t4.value]), filter(nil), 
      access([t4.parent_id], [t4.id], [t4.value]), partitions(p0)
  5 - output([cte.id], [cast(cte.lev + 1, BIGINT(20, 0))]), filter(nil), 
      access([cte.id], [cte.lev]), partitions(nil)

show create view nview23;
View	Create View	character_set_client	collation_connection
nview23	CREATE VIEW `nview23` AS WITH `cte`(id, val, lev) as ((select `cterecursivetest`.`t4`.`id` AS `id`,`cterecursivetest`.`t4`.`value` AS `value`,0 AS `lev` from `cterecursivetest`.`t4` where (`cterecursivetest`.`t4`.`parent_id` is null)) union  ALL (select `cterecursivetest`.`t4`.`id` AS `id`,`cterecursivetest`.`t4`.`value` AS `value`,(`cte`.`lev` + 1) AS `cte.lev+1` from (`cte` join `cterecursivetest`.`t4` `t4` on ((`cterecursivetest`.`t4`.`parent_id` = `cte`.`id`))))) select `cte`.`id` AS `id`,`cte`.`val` AS `val`,`cte`.`lev` AS `lev` from  cte	utf8mb4	utf8mb4_general_ci
