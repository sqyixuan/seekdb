  0 - output([cte1.c1], [cte1.c2], [cte1.c3], [t2.c21], [t2.c22], [t2.c23]), filter([(T_OP_NOT, t2.c21 <=> cte1.c1)]), 
      equal_conds([cte1.c1 = t2.c21]), other_conds(nil)
  1 - output([cte1.c1], [cte1.c2], [cte1.c3]), filter(nil), sort_keys([cte1.c1, ASC])
  2 - output([cte1.c1], [cte1.c2], [cte1.c3]), filter(nil), 
      access([cte1.c1], [cte1.c2], [cte1.c3])
  3 - output([t1.c1], [t1.c2], [t1.c3]), filter(nil), 
      access([t1.c1], [t1.c2], [t1.c3]), partitions(p0)
  4 - output([t2.c21], [t2.c22], [t2.c23]), filter(nil), sort_keys([t2.c21, ASC])
