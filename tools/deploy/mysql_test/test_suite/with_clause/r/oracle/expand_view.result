  1 - output([UNION(emp.id, emp.id)], [UNION(emp.name, emp.name)], [UNION(emp.leaderid, emp.leaderid)], [T_CTE_SEARCH_COLUMN], [T_CTE_CYCLE_COLUMN]), filter(nil)
  2 - output([emp.id], [emp.name], [emp.leaderid]), filter(nil), sort_keys([emp.id, ASC])
