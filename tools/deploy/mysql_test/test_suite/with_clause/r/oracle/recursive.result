explain basic
with 
     cte_a (a,b,c) as
       ( select id, name, leaderid from emp where emp.id = 1
         union all
         select emp.id ,emp.name, emp.leaderid from emp, cte_a where emp.leaderid = cte_a.A
       ) search depth first by a set sad cycle b set iscyc to 'y' default 'n',
     cte_b as (select * from cte_a, t1 where  t1.c1 = cte_a.c)
select * from cte_b;
