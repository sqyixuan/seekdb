with 
     cte_a (a,b,c) as
       ( select id, name, leaderid from emp where emp.id = 1
         union all
         select emp.id ,emp.name, emp.leaderid from emp, cte_a where emp.leaderid = cte_a.A
       ) search depth first by a set sad cycle b set iscyc to 'y' default 'n',
     cte_b as (select * from cte_a, t1 where  t1.c1 = cte_a.c)
select * from cte_a where exists (select * from cte_b where cte_a.a = cte_b.a);
+------+------+------+------+-------+
| a    | b    | c    | sad  | iscyc |
+------+------+------+------+-------+
|    2 | AA   |    1 |    2 | n     |
|    3 | AB   |    1 |    9 | n     |
+------+------+------+------+-------+
with cte(a,b,c) as 
(
  select c1,c2,c3 from t1 where t1.c1 < 20 
  union all 
  select c1,c2,c3 from t1, cte where cte.a = t1.c1 and cte.c < 10
) cycle a,b,c set iscyc to 'y' default 'n' 
select /*+USE_PLAN_CACHE(NONE)*/ count(distinct cte.iscyc), count(distinct cte.a), avg(distinct cte.b) from cte where cte.c < 10;
+---------------------------+-----------------------+---------------------+
| count(distinct cte.iscyc) | count(distinct cte.a) | avg(distinct cte.b) |
+---------------------------+-----------------------+---------------------+
|                         2 |                     3 |              5.0000 |
+---------------------------+-----------------------+---------------------+
with cte_recursive(a,b,c) as 
(
  select c1,c2,c3 from t1 where t1.c1 < 20 
  union all 
  select c1,c2,c3 from t1, cte_recursive where cte_recursive.a = t1.c1 and cte_recursive.c < 10
) cycle a,b,c set iscyc to 'y' default 'n',
     cte as (select * from t1)
select distinct R1.c1 from cte R1 where NOT EXISTS (select a from cte_recursive where NOT EXISTS (select * from cte R2 where R2.c1 = cte_recursive.a) );
+------+
| c1   |
+------+
|    1 |
|    4 |
|    7 |
|   10 |
|   13 |
|   16 |
|   19 |
+------+
