update t1 set c1=(
with cte0 (a,b,c) as
(
  select id, name, leaderid from emp where emp.id = 1
  union all
  select emp.id ,emp.name, emp.leaderid from emp, cte0 where emp.leaderid = cte0.a
) search breadth first by a set order1
select a from cte0 where a = 3
) where c3 = 3;
select * from t1;
