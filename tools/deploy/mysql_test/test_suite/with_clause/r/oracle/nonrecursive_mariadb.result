# with clause in the specification of a view that whose definition
# table alias for a with table
create view v3 as
with t(c) as (select a from t1 where b >= 'c')
select * from t r1 where r1.c=4;
show create view v3;
View	Create View	character_set_client	collation_connection
v3	CREATE VIEW `v3` AS WITH `t`(c) as (select `ctetest`.`t1`.`a` AS `c` from `ctetest`.`t1` where (`ctetest`.`t1`.`b` >= 'c')) select `r1`.`c` AS `c` from  t r1 where (`r1`.`c` = 4)	utf8mb4	utf8mb4_general_ci
# with clause in the specification of a view that whose definition
# two table aliases for for the same with table
create view v4(c,d) as
with t(c) as (select a from t1 where b >= 'c')
select * from t r1, t r2 where r1.c=r2.c and r2.c=4;
show create view v4;
View	Create View	character_set_client	collation_connection
v4	CREATE VIEW `v4` AS WITH `t`(c) as (select `ctetest`.`t1`.`a` AS `c` from `ctetest`.`t1` where (`ctetest`.`t1`.`b` >= 'c')) select `r1`.`c` AS `c`,`r2`.`c` AS `d` from  t r1, t r2 where (`r1`.`c` = `r2`.`c`) and (`r2`.`c` = 4)	utf8mb4	utf8mb4_general_ci
