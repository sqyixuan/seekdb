drop database if exists ctetest;
create database ctetest;
use ctetest;
create table t1 (a int, b  varchar(32));
insert into t1 values
(4,'aaaa' ), (7,'bb'), (1,'ccc'), (4,'dd');
insert into t1 values
(3,'eee'), (7,'bb'), (1,'fff'), (4,'ggg');
create table t2 (c int);
insert into t2 values
(2), (4), (5), (3);
result_format: 4
# select certain field in the specification of t
with t as (select a from t1 where b >= 'c') 
  select * from t2,t where t2.c=t.a;
+------+------+
| c    | a    |
+------+------+
|    4 |    4 |
|    4 |    4 |
|    3 |    3 |
+------+------+
select * from t2, (select a from t1 where b >= 'c') as t
   where t2.c=t.a;
+------+------+
| c    | a    |
+------+------+
|    4 |    4 |
|    4 |    4 |
|    3 |    3 |
+------+------+
explain  
with t as (select a from t1 where b >= 'c') 
  select * from t2,t where t2.c=t.a;
Query Plan
====================================
|ID|OPERATOR   |NAME|EST. ROWS|COST|
------------------------------------
|0 |HASH JOIN  |    |1        |82  |
|1 | TABLE SCAN|t1  |1        |42  |
|2 | TABLE SCAN|t2  |4        |37  |
====================================

Outputs & filters: 
-------------------------------------
  0 - output([t2.c], [t1.a]), filter(nil), 
      equal_conds([t2.c = t1.a]), other_conds(nil)
  1 - output([t1.a]), filter([t1.b >= 'c']), 
      access([t1.b], [t1.a]), partitions(p0)
  2 - output([t2.c]), filter(nil), 
      access([t2.c]), partitions(p0)

explain 
select * from t2, (select a from t1 where b >= 'c') as t
   where t2.c=t.a;
