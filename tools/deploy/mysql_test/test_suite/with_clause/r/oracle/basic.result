      access([cte1.c1])
  1 - output([1]), filter(nil), 
      group([t1.c1]), agg_func(nil)
  2 - output([t1.c1]), filter(nil), sort_keys([t1.c1, ASC])
  3 - output([t1.c1]), filter(nil), 
      access([t1.c1]), partitions(p0)

