# privileges
drop tenant if exists ora_tt force;
drop resource pool if exists pool1;
drop resource unit if exists box1;
create resource unit box1 max_cpu 1, max_memory 1073741824, max_iops 100000, max_disk_size 536870912, max_session_num 64, MIN_CPU=1, MIN_MEMORY=1073741824, MIN_IOPS=128;
drop database if exists cteprivtest;
create database cteprivtest;
use cteprivtest;
result_format: 4
create table t1(pub int, c2 int);
insert into t1 values(1,2);
create table t2(priv int, c2 int);
insert into t2 values(1,2);

use cteprivtest;

select * from t1;
+------+------+
| pub  | c2   |
+------+------+
|    1 |    2 |
+------+------+
select * from (select pub from t1) as dt;
+------+
| pub  |
+------+
|    1 |
+------+
explain select * from (select pub from t1) as dt;
Query Plan
===================================
|ID|OPERATOR  |NAME|EST. ROWS|COST|
-----------------------------------
|0 |TABLE SCAN|t1  |1        |36  |
===================================

Outputs & filters: 
-------------------------------------
  0 - output([t1.pub]), filter(nil), 
      access([t1.pub]), partitions(p0)

with qn as (select pub from t1) select * from qn;
+------+
| pub  |
+------+
|    1 |
+------+
explain with qn as (select pub from t1) select * from qn;
Query Plan
===================================
|ID|OPERATOR  |NAME|EST. ROWS|COST|
-----------------------------------
|0 |TABLE SCAN|t1  |1        |36  |
===================================

Outputs & filters: 
-------------------------------------
  0 - output([t1.pub]), filter(nil), 
      access([t1.pub]), partitions(p0)

with  qn as (select pub from t1),
      qn2 as (select * from qn)
select * from qn2;
+------+
| pub  |
+------+
|    1 |
+------+

drop database cteprivtest;

drop tenant ora_tt force;
drop resource pool pool1;
drop resource unit box1;

