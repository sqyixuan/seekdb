## =======================================================================
## Test Case 6: Bug 21506203 SERIAL Run shows results BUT PARALLEL RUN Errors out
## - recursive WITH Query(Negative): Dummy placeholder query. Incorrect log
##   Cycle length exceeded for 32k value 
##REM  The parameter _recursive_with_cycle_length_multiplier parameter would   
##  need to be set to value 1 first before running query
##  Run time error should be reported for exceeding the cycle length                                 
## =======================================================================
/* add loop from Eve19 back to Eve  in emp1 */
INSERT INTO emp1 values (concat('8100',4000,'5'), 'Eve', 'MANAGER', concat('8119',4000,'5'), str_to_date('01-MAY-84', '%d-%b-%Y'), 2850, null, 30);

explain basic
WITH rw (ename, mgr, empno , iters, sal) AS
   (
      SELECT ename, mgr, empno, 1 iters, sal
      FROM emp1
      WHERE ename = 'Eve'
      UNION ALL
      SELECT t.ename, t.mgr, t.empno, r.iters + 1 iters, (r.sal + t.sal) sal                      
      FROM rw r, emp1 t
      WHERE r.empno = t.mgr  
   )
   cycle empno,mgr set iscycle to 'y' default 'n'
   SELECT  ename, iters, sal, iscycle
   FROM rw;
Query Plan
==============================
|ID|OPERATOR            |NAME|
------------------------------
|0 |SUBPLAN SCAN        |rw  |
|1 | RECURSIVE UNION ALL|    |
|2 |  TABLE SCAN        |emp1|
|3 |  HASH JOIN         |    |
|4 |   TABLE SCAN       |t   |
|5 |   TABLE SCAN       |r   |
==============================

Outputs & filters: 
-------------------------------------
  0 - output([rw.ename], [rw.iters], [rw.sal], [rw.iscycle]), filter(nil), 
      access([rw.ename], [rw.iters], [rw.sal], [rw.iscycle])
  1 - output([UNION(emp1.ename, t.ename)], [UNION(emp1.mgr, t.mgr)], [UNION(emp1.empno, t.empno)], [UNION(cast(?, BIGINT(20, 0)), cast(r.iters + 1, BIGINT(20, 0)))], [UNION(cast(emp1.sal, DECIMAL(8, 2)), r.sal + t.sal)], [T_CTE_CYCLE_COLUMN]), filter(nil)
  2 - output([emp1.ename], [emp1.mgr], [emp1.empno], [cast(?, BIGINT(20, 0))], [cast(emp1.sal, DECIMAL(8, 2))]), filter([emp1.ename = 'Eve']), 
      access([emp1.ename], [emp1.mgr], [emp1.empno], [emp1.sal]), partitions(p0)
  3 - output([t.ename], [t.mgr], [t.empno], [cast(r.iters + 1, BIGINT(20, 0))], [r.sal + t.sal]), filter(nil), 
      equal_conds([r.empno = t.mgr]), other_conds(nil)
  4 - output([t.mgr], [t.ename], [t.empno], [t.sal]), filter(nil), 
      access([t.mgr], [t.ename], [t.empno], [t.sal]), partitions(p0)
  5 - output([r.empno], [r.sal], [cast(r.iters + 1, BIGINT(20, 0))]), filter(nil), 
      access([r.empno], [r.iters], [r.sal]), partitions(nil)


WITH rw (ename, mgr, empno , iters, sal) AS
   (
      SELECT ename, mgr, empno, 1 iters, sal
      FROM emp1
      WHERE ename = 'Eve'
      UNION ALL
      SELECT t.ename, t.mgr, t.empno, r.iters + 1 iters, (r.sal + t.sal) sal                      
      FROM rw r, emp1 t
      WHERE r.empno = t.mgr  
   )
   cycle empno,mgr set iscycle to 'y' default 'n'
   SELECT  ename, iters, sal, iscycle
   FROM rw;
