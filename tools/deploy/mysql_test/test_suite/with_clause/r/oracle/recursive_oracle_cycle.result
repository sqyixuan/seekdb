## =======================================================================
## Test Case 4:
## - recursive WITH Query(Negative): cycle clause not used in query with 
##    cyclic data
## =======================================================================
/* add loop from scott back to king  in emp */
update emp set mgr = 7788 where ename = 'KING';

explain basic
WITH rw (ename, mgr, empno) AS
(
    SELECT ename, mgr, empno
    FROM emp e
    WHERE job = 'PRESIDENT'
    UNION ALL
    SELECT e.ename, e.mgr, e.empno
    FROM rw r, emp e
    WHERE r.empno = e.mgr
)
SELECT ename, empno, mgr
FROM rw;
Query Plan
==============================
|ID|OPERATOR            |NAME|
------------------------------
|0 |SUBPLAN SCAN        |rw  |
|1 | RECURSIVE UNION ALL|    |
|2 |  TABLE SCAN        |e   |
|3 |  HASH JOIN         |    |
|4 |   TABLE SCAN       |e   |
|5 |   TABLE SCAN       |r   |
==============================

Outputs & filters: 
-------------------------------------
  0 - output([rw.ename], [rw.empno], [rw.mgr]), filter(nil), 
      access([rw.ename], [rw.empno], [rw.mgr])
  1 - output([UNION(e.ENAME, e.ENAME)], [UNION(e.MGR, e.MGR)], [UNION(e.EMPno, e.EMPno)]), filter(nil)
  2 - output([e.ENAME], [e.MGR], [e.EMPno]), filter([e.JOB = 'PRESIDENT']), 
      access([e.JOB], [e.ENAME], [e.MGR], [e.EMPno]), partitions(p0)
  3 - output([e.ENAME], [e.MGR], [e.EMPno]), filter(nil), 
      equal_conds([r.empno = e.MGR]), other_conds(nil)
  4 - output([e.MGR], [e.ENAME], [e.EMPno]), filter(nil), 
      access([e.MGR], [e.ENAME], [e.EMPno]), partitions(p0)
  5 - output([r.empno]), filter(nil), 
      access([r.empno]), partitions(nil)


WITH rw (ename, mgr, empno) AS
(
    SELECT ename, mgr, empno
    FROM emp e
    WHERE job = 'PRESIDENT'
    UNION ALL
    SELECT e.ename, e.mgr, e.empno
    FROM rw r, emp e
    WHERE r.empno = e.mgr
)
SELECT ename, empno, mgr
FROM rw;
