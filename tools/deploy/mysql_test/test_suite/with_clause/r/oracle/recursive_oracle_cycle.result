## =======================================================================
## Test Case 3:
## - recursive WITH Query: cycle clause used in query with two cycle key column
## =======================================================================
explain basic
WITH rw (mgr, empno, iters, sal) AS
(
    SELECT mgr, empno, 1 iters, sal
    FROM emp
    WHERE job = 'PRESIDENT'
    UNION ALL
    SELECT t.mgr, t.empno, r.iters + 1 iters, (r.sal + t.sal) sal
    FROM rw r, emp t
    WHERE r.empno = t.mgr 
)
cycle empno,mgr set iscycle to 'y' default 'n'
SELECT *
FROM rw;
Query Plan
=============================
|ID|OPERATOR           |NAME|
-----------------------------
|0 |RECURSIVE UNION ALL|    |
|1 | TABLE SCAN        |emp |
|2 | HASH JOIN         |    |
|3 |  TABLE SCAN       |t   |
|4 |  TABLE SCAN       |r   |
=============================

Outputs & filters: 
-------------------------------------
  0 - output([UNION(emp.MGR, t.MGR)], [UNION(emp.EMPno, t.EMPno)], [UNION(cast(?, BIGINT(20, 0)), cast(r.iters + 1, BIGINT(20, 0)))], [UNION(cast(emp.SAL, DECIMAL(8, 2)), r.sal + t.SAL)], [T_CTE_CYCLE_COLUMN]), filter(nil)
  1 - output([emp.MGR], [emp.EMPno], [cast(?, BIGINT(20, 0))], [cast(emp.SAL, DECIMAL(8, 2))]), filter([emp.JOB = 'PRESIDENT']), 
      access([emp.JOB], [emp.MGR], [emp.EMPno], [emp.SAL]), partitions(p0)
  2 - output([t.MGR], [t.EMPno], [cast(r.iters + 1, BIGINT(20, 0))], [r.sal + t.SAL]), filter(nil), 
      equal_conds([r.empno = t.MGR]), other_conds(nil)
  3 - output([t.MGR], [t.EMPno], [t.SAL]), filter(nil), 
      access([t.MGR], [t.EMPno], [t.SAL]), partitions(p0)
  4 - output([r.empno], [r.sal], [cast(r.iters + 1, BIGINT(20, 0))]), filter(nil), 
      access([r.empno], [r.iters], [r.sal]), partitions(nil)


WITH rw (mgr, empno, iters, sal) AS
(
    SELECT mgr, empno, 1 iters, sal
    FROM emp
    WHERE job = 'PRESIDENT'
    UNION ALL
    SELECT t.mgr, t.empno, r.iters + 1 iters, (r.sal + t.sal) sal
    FROM rw r, emp t
    WHERE r.empno = t.mgr 
)
cycle empno,mgr set iscycle to 'y' default 'n'
SELECT *
FROM rw;
