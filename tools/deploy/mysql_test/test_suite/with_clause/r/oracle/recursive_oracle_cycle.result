| ename | empno | mgr  | iscycle |
+-------+-------+------+---------+
| KING  | 7839  | 5001 | N       |
+-------+-------+------+---------+

## =======================================================================
## Test Case 12:  
## - recursive WITH Query: Cycle Pruning with Cycle clause used in the query    
##  Pruning predicate added that results in no cycles r.empno > e.empno                            
## =======================================================================
explain basic
WITH rw (ename, mgr, empno) AS
(
    SELECT ename, mgr, empno
    FROM emp2 e
    WHERE job = 'PRESIDENT'
    UNION ALL
    SELECT e.ename, e.mgr, e.empno
    FROM rw r, emp2 e
    WHERE r.empno = e.mgr and r.empno > e.empno
)
CYCLE empno,mgr set iscycle TO 'Y' DEFAULT 'N'
SELECT ename, empno, mgr , iscycle
FROM rw;
