empno    VARCHAR(4000) NOT NULL,
ename    VARCHAR(14),
job      VARCHAR(9),
mgr      VARCHAR(4000),
hiredate DATE,
sal      NUMBER(7,2),
comm     NUMBER(7,2),
deptno   NUMBER(2));
