## =======================================================================
## Test Case 2:
## - recursive WITH Query: SORT MERGE Join
## =======================================================================
explain 
WITH rw (ename, mgr, empno) AS
(
    SELECT ename, mgr, empno
    FROM emp e
    WHERE job = 'PRESIDENT'
    UNION ALL
    SELECT /*+ USE_MERGE(r e) */ e.ename, e.mgr, e.empno
    FROM rw r, emp e
    WHERE r.empno = e.mgr
)
SELECT ename, empno, mgr
FROM rw;
Query Plan
=============================================
|ID|OPERATOR            |NAME|EST. ROWS|COST|
---------------------------------------------
|0 |SUBPLAN SCAN        |rw  |6        |2394|
|1 | RECURSIVE UNION ALL|    |6        |2393|
|2 |  TABLE SCAN        |e   |1        |47  |
|3 |  MERGE JOIN        |    |6        |2345|
|4 |   SORT             |    |14       |68  |
|5 |    TABLE SCAN      |e   |14       |40  |
|6 |   SORT             |    |199      |2243|
|7 |    TABLE SCAN      |r   |1        |1   |
=============================================

Outputs & filters: 
-------------------------------------
  0 - output([rw.ename], [rw.empno], [rw.mgr]), filter(nil), 
      access([rw.ename], [rw.empno], [rw.mgr])
  1 - output([UNION(e.ENAME, e.ENAME)], [UNION(e.MGR, e.MGR)], [UNION(e.EMPno, e.EMPno)]), filter(nil)
  2 - output([e.ENAME], [e.MGR], [e.EMPno]), filter([e.JOB = 'PRESIDENT']), 
      access([e.JOB], [e.ENAME], [e.MGR], [e.EMPno]), partitions(p0)
  3 - output([e.ENAME], [e.MGR], [e.EMPno]), filter(nil), 
      equal_conds([r.empno = e.MGR]), other_conds(nil)
  4 - output([e.ENAME], [e.MGR], [e.EMPno]), filter(nil), sort_keys([e.MGR, ASC])
  5 - output([e.MGR], [e.ENAME], [e.EMPno]), filter(nil), 
      access([e.MGR], [e.ENAME], [e.EMPno]), partitions(p0)
  6 - output([r.empno]), filter(nil), sort_keys([r.empno, ASC])
  7 - output([r.empno]), filter(nil), 
      access([r.empno]), partitions(nil)


