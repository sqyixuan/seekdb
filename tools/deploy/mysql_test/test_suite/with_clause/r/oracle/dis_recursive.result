  10 - output([r.empno], [e.MGR], [cast(r.iters + 1, BIGINT(20, 0))], [r.sal + e.SAL]), filter(nil), 
      equal_conds([n.empno = e.MGR], [r.mgr = e.EMPno]), other_conds(nil)
  11 - output([r.empno], [cast(r.iters + 1, BIGINT(20, 0))], [r.sal], [n.empno], [r.mgr]), filter(nil), 
      conds(nil), nl_params_(nil)
  12 - output([n.empno]), filter(nil), 
      access([n.empno]), partitions(p0)
  13 - output([r.mgr], [r.empno], [r.sal], [cast(r.iters + 1, BIGINT(20, 0))]), filter(nil), 
      access([r.mgr], [r.empno], [r.iters], [r.sal]), partitions(nil)
  14 - output([e.MGR], [e.SAL], [e.EMPno]), filter(nil)
  15 - output([e.MGR], [e.EMPno], [e.SAL]), filter(nil)
  16 - output([e.MGR], [e.EMPno], [e.SAL]), filter(nil)
  17 - output([e.MGR], [e.EMPno], [e.SAL]), filter([e.EMPno < e.MGR]), 
      access([e.MGR], [e.EMPno], [e.SAL]), partitions(p[0-1])


WITH rw (empno, mgr, iters, sal) AS
  (
  SELECT e.empno, e.mgr, 1, e.sal
  FROM disemp e, emp1 n1, emp1 n2
  WHERE e.empno = n1.empno and e.mgr = n2.empno and e.empno < e.mgr
  UNION ALL
  SELECT /*+ ORDERED  USE_HASH (r e) */r.empno, e.mgr, r.iters + 1, r.sal + e.sal
  FROM emp1 n, rw r, disemp e
  WHERE n.empno = e.mgr and r.mgr = e.empno and e.empno < e.mgr
  )
  SELECT *
  FROM rw
  ORDER BY 1, 3;
