## =======================================================================
## Test Case 2:
## - recursive WITH Query: SORT MERGE Join
## =======================================================================
explain 
WITH rw (ename, mgr, empno) AS
(
    SELECT ename, mgr, empno
    FROM disemp e
    WHERE job = 'PRESIDENT'
    UNION ALL
    SELECT /*+ USE_MERGE(r e) */ e.ename, e.mgr, e.empno
    FROM rw r, disemp e
    WHERE r.empno = e.mgr
)
SELECT ename, empno, mgr
FROM rw;
Query Plan
==========================================================
|ID|OPERATOR                        |NAME|EST. ROWS|COST |
----------------------------------------------------------
|0 |SUBPLAN SCAN                    |rw  |785      |11482|
|1 | RECURSIVE UNION ALL            |    |785      |11373|
|2 |  EXCHANGE IN DISTR             |    |4        |1013 |
|3 |   EXCHANGE OUT DISTR           |    |4        |1012 |
|4 |    TABLE SCAN                  |e   |4        |1012 |
|5 |  MERGE JOIN                    |    |781      |10019|
|6 |   SORT                         |    |199      |2243 |
|7 |    TABLE SCAN                  |r   |1        |1    |
|8 |   MATERIAL                     |    |2000     |6945 |
|9 |    EXCHANGE IN MERGE SORT DISTR|    |2000     |6210 |
|10|     EXCHANGE OUT DISTR         |    |2000     |5689 |
|11|      SORT                      |    |2000     |5689 |
|12|       TABLE SCAN               |e   |2000     |521  |
==========================================================

Outputs & filters: 
-------------------------------------
  0 - output([rw.ename], [rw.empno], [rw.mgr]), filter(nil), 
      access([rw.ename], [rw.empno], [rw.mgr])
  1 - output([UNION(e.ENAME, e.ENAME)], [UNION(e.MGR, e.MGR)], [UNION(e.EMPno, e.EMPno)]), filter(nil)
  2 - output([e.ENAME], [e.MGR], [e.EMPno]), filter(nil)
  3 - output([e.ENAME], [e.MGR], [e.EMPno]), filter(nil)
  4 - output([e.ENAME], [e.MGR], [e.EMPno]), filter([e.JOB = 'PRESIDENT']), 
      access([e.ENAME], [e.JOB], [e.MGR], [e.EMPno]), partitions(p[0-1])
  5 - output([e.ENAME], [e.MGR], [e.EMPno]), filter(nil), 
      equal_conds([r.empno = e.MGR]), other_conds(nil)
  6 - output([r.empno]), filter(nil), sort_keys([r.empno, ASC])
  7 - output([r.empno]), filter(nil), 
      access([r.empno]), partitions(nil)
  8 - output([e.ENAME], [e.MGR], [e.EMPno]), filter(nil)
  9 - output([e.ENAME], [e.MGR], [e.EMPno]), filter(nil), sort_keys([e.MGR, ASC])
  10 - output([e.ENAME], [e.MGR], [e.EMPno]), filter(nil)
  11 - output([e.ENAME], [e.MGR], [e.EMPno]), filter(nil), sort_keys([e.MGR, ASC])
  12 - output([e.ENAME], [e.MGR], [e.EMPno]), filter(nil), 
      access([e.ENAME], [e.MGR], [e.EMPno]), partitions(p[0-1])


