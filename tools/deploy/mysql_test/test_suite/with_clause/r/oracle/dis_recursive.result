## =======================================================================
## Test Case 2:
## - recursive WITH Query: SORT MERGE Join
## =======================================================================
explain 
WITH rw (ename, mgr, empno) AS
(
    SELECT ename, mgr, empno
    FROM disemp e
    WHERE job = 'PRESIDENT'
    UNION ALL
    SELECT /*+ USE_MERGE(r e) */ e.ename, e.mgr, e.empno
    FROM rw r, disemp e
    WHERE r.empno = e.mgr
)
SELECT ename, empno, mgr
FROM rw;
Query Plan
=========================================================
|ID|OPERATOR                        |NAME|EST. ROWS|COST|
---------------------------------------------------------
|0 |SUBPLAN SCAN                    |rw  |9        |2283|
|1 | RECURSIVE UNION ALL            |    |9        |2282|
|2 |  EXCHANGE IN DISTR             |    |1        |42  |
|3 |   EXCHANGE OUT DISTR           |    |1        |42  |
|4 |    TABLE SCAN                  |e   |1        |42  |
|5 |  MERGE JOIN                    |    |9        |2238|
|6 |   MATERIAL                     |    |21       |86  |
|7 |    EXCHANGE IN MERGE SORT DISTR|    |21       |78  |
|8 |     EXCHANGE OUT DISTR         |    |21       |73  |
|9 |      SORT                      |    |21       |73  |
|10|       TABLE SCAN               |e   |21       |38  |
|11|   SORT                         |    |199      |2116|
|12|    TABLE SCAN                  |r   |1        |1   |
=========================================================

Outputs & filters: 
-------------------------------------
  0 - output([rw.ename], [rw.empno], [rw.mgr]), filter(nil), 
      access([rw.ename], [rw.empno], [rw.mgr])
  1 - output([UNION(e.ENAME, e.ENAME)], [UNION(e.MGR, e.MGR)], [UNION(e.EMPno, e.EMPno)]), filter(nil)
  2 - output([e.ENAME], [e.MGR], [e.EMPno]), filter(nil)
  3 - output([e.EMPno], [e.ENAME], [e.MGR]), filter(nil)
  4 - output([e.EMPno], [e.ENAME], [e.MGR]), filter([e.JOB = 'PRESIDENT']), 
      access([e.EMPno], [e.JOB], [e.ENAME], [e.MGR]), partitions(p[0-2])
  5 - output([e.ENAME], [e.MGR], [e.EMPno]), filter(nil), 
      equal_conds([r.empno = e.MGR]), other_conds(nil)
  6 - output([e.ENAME], [e.MGR], [e.EMPno]), filter(nil)
  7 - output([e.ENAME], [e.MGR], [e.EMPno]), filter(nil), sort_keys([e.MGR, ASC])
  8 - output([e.ENAME], [e.MGR], [e.EMPno]), filter(nil)
  9 - output([e.ENAME], [e.MGR], [e.EMPno]), filter(nil), sort_keys([e.MGR, ASC])
  10 - output([e.EMPno], [e.MGR], [e.ENAME]), filter(nil), 
      access([e.EMPno], [e.MGR], [e.ENAME]), partitions(p[0-2])
  11 - output([r.empno]), filter(nil), sort_keys([r.empno, ASC])
  12 - output([r.empno]), filter(nil), 
      access([r.empno]), partitions(nil)


