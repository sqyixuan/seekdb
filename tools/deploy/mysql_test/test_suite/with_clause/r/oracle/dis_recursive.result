create table EMP (
EMPno  number,
ENAME varchar(30),
JOB varchar(30),
MGR number(4),
HIREDATE date,
SAL number(7,2),
COMM number(7,2),
DEPTNO number(2)
) partition by range columns(ENAME) 
(
partition p0 values less than('23-MAY-83'),
partition p1 values less than(MAXVALUE)
);
