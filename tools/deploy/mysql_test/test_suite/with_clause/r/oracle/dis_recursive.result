      equal_conds([r.mgr = e.EMPno], [n.empno = e.MGR]), other_conds(nil)
  11 - output([r.empno], [cast(r.iters + 1, BIGINT(20, 0))], [r.sal], [r.mgr], [n.empno]), filter(nil), 
