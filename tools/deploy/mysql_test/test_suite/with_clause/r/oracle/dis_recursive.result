result_format: 4

##############################
##   section 1  聚合一张表是分布式表（disemp）
##   section 2  聚合的两表是分布式表（disemp，emp1）
##   section 3  聚合的两表在join条件上可能形成wise join（disemp，emp1）
##   section 4  额外添加recursive member变化
##############################

##############################
##   section 1  聚合一张表是分布式表（disemp）
##############################
## =======================================================================
## Test Case 1:
## - recursive WITH Query: Nested Loop Join
## =======================================================================
explain 
WITH rw (ename, mgr, empno) AS
(
    SELECT ename, mgr, empno
    FROM disemp e
    WHERE job = 'PRESIDENT'
    UNION ALL
    SELECT /*+ USE_NL(r e) */  e.ename, e.mgr, e.empno
    FROM rw r, disemp e
    WHERE r.empno = e.mgr
)
SELECT ename, empno, mgr
FROM rw;
Query Plan
================================================
|ID|OPERATOR               |NAME|EST. ROWS|COST|
------------------------------------------------
|0 |SUBPLAN SCAN           |rw  |785      |6128|
|1 | RECURSIVE UNION ALL   |    |785      |6020|
|2 |  EXCHANGE IN DISTR    |    |4        |1013|
|3 |   EXCHANGE OUT DISTR  |    |4        |1012|
|4 |    TABLE SCAN         |e   |4        |1012|
|5 |  NESTED-LOOP JOIN     |    |781      |4666|
|6 |   MATERIAL            |    |2000     |1777|
|7 |    EXCHANGE IN DISTR  |    |2000     |1042|
|8 |     EXCHANGE OUT DISTR|    |2000     |521 |
|9 |      TABLE SCAN       |e   |2000     |521 |
|10|   TABLE SCAN          |r   |1        |1   |
================================================

Outputs & filters: 
-------------------------------------
  0 - output([rw.ename], [rw.empno], [rw.mgr]), filter(nil), 
      access([rw.ename], [rw.empno], [rw.mgr])
  1 - output([UNION(e.ENAME, e.ENAME)], [UNION(e.MGR, e.MGR)], [UNION(e.EMPno, e.EMPno)]), filter(nil)
  2 - output([e.ENAME], [e.MGR], [e.EMPno]), filter(nil)
  3 - output([e.ENAME], [e.MGR], [e.EMPno]), filter(nil)
  4 - output([e.ENAME], [e.MGR], [e.EMPno]), filter([e.JOB = 'PRESIDENT']), 
      access([e.ENAME], [e.JOB], [e.MGR], [e.EMPno]), partitions(p[0-1])
  5 - output([e.ENAME], [e.MGR], [e.EMPno]), filter(nil), 
      conds([r.empno = e.MGR]), nl_params_(nil)
  6 - output([e.ENAME], [e.MGR], [e.EMPno]), filter(nil)
  7 - output([e.ENAME], [e.MGR], [e.EMPno]), filter(nil)
  8 - output([e.ENAME], [e.MGR], [e.EMPno]), filter(nil)
  9 - output([e.ENAME], [e.MGR], [e.EMPno]), filter(nil), 
      access([e.ENAME], [e.MGR], [e.EMPno]), partitions(p[0-1])
  10 - output([r.empno]), filter(nil), 
      access([r.empno]), partitions(nil)


WITH rw (ename, mgr, empno) AS
(
    SELECT ename, mgr, empno
    FROM disemp e
    WHERE job = 'PRESIDENT'
    UNION ALL
    SELECT /*+ USE_NL(r e) */  e.ename, e.mgr, e.empno
    FROM rw r, disemp e
    WHERE r.empno = e.mgr
)
SELECT ename, empno, mgr
FROM rw;
