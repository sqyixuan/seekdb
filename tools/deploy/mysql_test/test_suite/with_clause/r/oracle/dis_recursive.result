drop table disemp;
create table disemp (
  EMPno int,
  ENAME varchar(30),
  JOB varchar(30),
  MGR number(4),
  HIREDATE date,
  SAL number(7,2),
  COMM number(7,2),
  DEPTNO number(2)
) partition by hash(EMPno) partitions 3 ;

INSERT INTO disemp values (7369,'SMITH','CLERK',7902,    str_to_date('17-DEC-80','%d-%b-%Y'),800,NULL, 20) ;
INSERT INTO disemp VALUES (7499, 'ALLEN','SALESMAN',7698,str_to_date('20-FEB-81','%d-%b-%Y'),1600,300,30) ;
