drop table disemp;
create table disemp (
  EMPno int,
  ENAME varchar(30),
  JOB varchar(30),
  MGR number(4),
  HIREDATE date,
  SAL number(7,2),
  COMM number(7,2),
  DEPTNO number(2)
) partition by hash(EMPno) partitions 3 ;

