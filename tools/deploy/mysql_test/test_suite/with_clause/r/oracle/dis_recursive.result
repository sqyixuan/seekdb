## =======================================================================
## 测试8-15都是在测试join的顺序或者hint的顺序
## Test Case 8:
## - recursive WITH Query: Join Order tests 
##                         pump >< disemp >< emp1 
## =======================================================================
explain  
WITH rw (empno, mgr, iters, sal) AS
  (
  SELECT e.empno, e.mgr, 1, e.sal
  FROM disemp e, emp1 n1, emp1 n2
  WHERE e.empno = n1.empno and e.mgr = n2.empno and e.empno < e.mgr
  UNION ALL
  SELECT /*+ ORDERED  USE_HASH (r e) */r.empno, e.mgr, r.iters + 1, r.sal + e.sal
  FROM rw r, disemp e, emp1 n
  WHERE r.mgr = e.empno and e.mgr = n.empno and e.empno < e.mgr
  )
  SELECT *
  FROM rw
  ORDER BY 1, 3;
Query Plan
==================================================
|ID|OPERATOR                 |NAME|EST. ROWS|COST|
--------------------------------------------------
|0 |SORT                     |    |36       |8458|
|1 | SUBPLAN SCAN            |rw  |36       |7920|
|2 |  RECURSIVE UNION ALL    |    |36       |7915|
|3 |   HASH JOIN             |    |17       |1370|
|4 |    TABLE SCAN           |n1  |17       |40  |
|5 |    HASH JOIN            |    |26       |1244|
|6 |     TABLE SCAN          |n2  |17       |40  |
|7 |     EXCHANGE IN DISTR   |    |667      |886 |
|8 |      EXCHANGE OUT DISTR |    |667      |689 |
|9 |       TABLE SCAN        |e   |667      |689 |
|10|   HASH JOIN             |    |19       |6528|
|11|    HASH JOIN            |    |261      |3550|
|12|     TABLE SCAN          |r   |1        |1   |
|13|     MATERIAL            |    |667      |1131|
|14|      EXCHANGE IN DISTR  |    |667      |886 |
|15|       EXCHANGE OUT DISTR|    |667      |689 |
|16|        TABLE SCAN       |e   |667      |689 |
|17|    TABLE SCAN           |n   |17       |40  |
==================================================

Outputs & filters: 
-------------------------------------
  0 - output([rw.empno], [rw.mgr], [rw.iters], [rw.sal]), filter(nil), sort_keys([rw.empno, ASC], [rw.iters, ASC])
  1 - output([rw.empno], [rw.mgr], [rw.iters], [rw.sal]), filter(nil), 
      access([rw.empno], [rw.mgr], [rw.iters], [rw.sal])
  2 - output([UNION(e.EMPno, r.empno)], [UNION(e.MGR, e.MGR)], [UNION(cast(?, BIGINT(20, 0)), cast(r.iters + 1, BIGINT(20, 0)))], [UNION(cast(e.SAL, DECIMAL(8, 2)), r.sal + e.SAL)]), filter(nil)
  3 - output([e.EMPno], [e.MGR], [cast(?, BIGINT(20, 0))], [cast(e.SAL, DECIMAL(8, 2))]), filter(nil), 
      equal_conds([e.EMPno = n1.empno]), other_conds(nil)
  4 - output([n1.empno]), filter(nil), 
      access([n1.empno]), partitions(p0)
  5 - output([e.EMPno], [e.MGR], [cast(e.SAL, DECIMAL(8, 2))]), filter(nil), 
      equal_conds([e.MGR = n2.empno]), other_conds(nil)
  6 - output([n2.empno]), filter(nil), 
      access([n2.empno]), partitions(p0)
  7 - output([e.EMPno], [e.MGR], [cast(e.SAL, DECIMAL(8, 2))]), filter(nil)
  8 - output([e.EMPno], [e.MGR], [cast(e.SAL, DECIMAL(8, 2))]), filter(nil)
  9 - output([e.EMPno], [e.MGR], [cast(e.SAL, DECIMAL(8, 2))]), filter([e.EMPno < e.MGR]), 
      access([e.EMPno], [e.MGR], [e.SAL]), partitions(p[0-1])
  10 - output([r.empno], [e.MGR], [cast(r.iters + 1, BIGINT(20, 0))], [r.sal + e.SAL]), filter(nil), 
      equal_conds([e.MGR = n.empno]), other_conds(nil)
  11 - output([r.empno], [e.MGR], [cast(r.iters + 1, BIGINT(20, 0))], [r.sal + e.SAL]), filter(nil), 
      equal_conds([r.mgr = e.EMPno]), other_conds(nil)
  12 - output([r.mgr], [r.empno], [r.sal], [cast(r.iters + 1, BIGINT(20, 0))]), filter(nil), 
      access([r.mgr], [r.empno], [r.iters], [r.sal]), partitions(nil)
  13 - output([e.MGR], [e.SAL], [e.EMPno]), filter(nil)
  14 - output([e.EMPno], [e.MGR], [e.SAL]), filter(nil)
  15 - output([e.EMPno], [e.MGR], [e.SAL]), filter(nil)
  16 - output([e.EMPno], [e.MGR], [e.SAL]), filter([e.EMPno < e.MGR]), 
      access([e.EMPno], [e.MGR], [e.SAL]), partitions(p[0-1])
  17 - output([n.empno]), filter(nil), 
      access([n.empno]), partitions(p0)


