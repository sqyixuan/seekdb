## =======================================================================
## Test Case 6:
## - recursive WITH Query: Hash Join without using hints
##                         Static input on build side and fits in memory
## 与oracle顺序不一致
## =======================================================================
explain 
WITH rw (ename, mgr, empno) AS
(
    SELECT ename, mgr, empno
    FROM disemp e
    WHERE job = 'PRESIDENT'
    UNION ALL
    SELECT e.ename, e.mgr, e.empno
    FROM disemp e, rw r
    WHERE e.mgr = r.empno 
)
SELECT ename, empno, mgr
FROM rw;
Query Plan
================================================
|ID|OPERATOR               |NAME|EST. ROWS|COST|
------------------------------------------------
|0 |SUBPLAN SCAN           |rw  |785      |6482|
|1 | RECURSIVE UNION ALL   |    |785      |6374|
|2 |  EXCHANGE IN DISTR    |    |4        |1013|
|3 |   EXCHANGE OUT DISTR  |    |4        |1012|
|4 |    TABLE SCAN         |e   |4        |1012|
|5 |  HASH JOIN            |    |781      |5020|
|6 |   TABLE SCAN          |r   |1        |1   |
|7 |   MATERIAL            |    |2000     |1777|
|8 |    EXCHANGE IN DISTR  |    |2000     |1042|
|9 |     EXCHANGE OUT DISTR|    |2000     |521 |
|10|      TABLE SCAN       |e   |2000     |521 |
================================================

