## =======================================================================
## Test Case 2:
## - recursive WITH Query: Dummy placeholder query for the path provided
##  The parameter _recursive_with_path_length_multiplier parameter is  
##  set to default value 1 before running this query 
##  Very large path length. The query passes successfully and displays path length                                 
## =======================================================================
explain basic
WITH rw (ename, mgr, empno , iters, sal, path) AS
   (
      SELECT ename, mgr, empno, 1 iters, sal, concat((mgr), concat(',', (empno))) path
      FROM emp1
      WHERE ename = 'Eve2'
      UNION ALL
      SELECT t.ename, t.mgr, t.empno, r.iters + 1 iters, (r.sal + t.sal) sal,
                      concat(r.path, concat(',',(t.empno))) path
      FROM rw r, emp1 t
      WHERE r.empno = t.mgr  
   )
   SELECT  ename name, length (path) path_length, instr(path, '8102') substr2, instr(path, '8103') substr3, 
           instr(path, '8104') substr4, instr(path, '8105') substr5, instr(path, '8106') substr6, 
           instr(path, '8107') substr7
   FROM rw;
