-------------------------------------
  0 - output([rw.ename], [length(rw.path)], [instr(rw.path, '8102')], [instr(rw.path, '8103')], [instr(rw.path, '8104')], [instr(rw.path, '8105')], [instr(rw.path, '8106')], [instr(rw.path, '8107')]), filter(nil), 
      access([rw.ename], [rw.path])
  1 - output([UNION(emp1.ename, t.ename)], [UNION(emp1.mgr, t.mgr)], [UNION(emp1.empno, t.empno)], [UNION(cast(?, BIGINT(20, 0)), cast(r.iters + 1, BIGINT(20, 0)))], [UNION(cast(emp1.sal, DECIMAL(8, 2)), r.sal + t.sal)], [UNION(cast(concat(emp1.mgr, concat(',', emp1.empno)), VARCHAR(12302)), concat(r.path, concat(',', t.empno)))]), filter(nil)
  2 - output([emp1.ename], [emp1.mgr], [emp1.empno], [cast(?, BIGINT(20, 0))], [cast(emp1.sal, DECIMAL(8, 2))], [cast(concat(emp1.mgr, concat(',', emp1.empno)), VARCHAR(12302))]), filter([emp1.ename = 'Eve2']), 
      access([emp1.ename], [emp1.mgr], [emp1.empno], [emp1.sal]), partitions(p0)
  3 - output([t.ename], [t.mgr], [t.empno], [cast(r.iters + 1, BIGINT(20, 0))], [r.sal + t.sal], [concat(r.path, concat(',', t.empno))]), filter(nil), 
      equal_conds([r.empno = t.mgr]), other_conds(nil)
  4 - output([t.mgr], [t.ename], [t.empno], [t.sal], [concat(',', t.empno)]), filter(nil), 
      access([t.mgr], [t.ename], [t.empno], [t.sal]), partitions(p0)
  5 - output([r.empno], [r.sal], [r.path], [cast(r.iters + 1, BIGINT(20, 0))]), filter(nil), 
