## =======================================================================
## Test Case 1:
## - recursive WITH Query: Dummy placeholder query for the path provided
##  The parameter _recursive_with_path_length_multiplier parameter is  
##  set to default value 1 before running this query 
##  Very small Path length (much less than 32K) 
##  The query output should display the path                                
## =======================================================================
explain basic
WITH rw (ename, mgr, empno , iters, sal, path) AS
   (
      SELECT ename, mgr, empno, 1 iters, sal, concat((mgr), concat(',', (empno))) path 
      FROM emp1
      WHERE ename = 'Eve7'
      UNION ALL
      SELECT t.ename, t.mgr, t.empno, r.iters + 1 iters, (r.sal + t.sal) sal,
                      concat(r.path,concat(',',(t.empno))) path
      FROM rw r, emp1 t
      WHERE r.empno = t.mgr  
   )
   SEARCH BREADTH FIRST BY empno SET bfs_key
   CYCLE mgr set iscycle to 'y' default 'n'
   SELECT ename name, empno eid, mgr mgrid, path connection, iters
   FROM rw 
   ORDER BY bfs_key;
Query Plan
===============================
|ID|OPERATOR             |NAME|
-------------------------------
|0 |SORT                 |    |
|1 | SUBPLAN SCAN        |rw  |
|2 |  RECURSIVE UNION ALL|    |
|3 |   SORT              |    |
|4 |    TABLE SCAN       |emp1|
|5 |   HASH JOIN         |    |
|6 |    TABLE SCAN       |t   |
|7 |    TABLE SCAN       |r   |
===============================

Outputs & filters: 
-------------------------------------
  0 - output([rw.ename], [rw.empno], [rw.mgr], [rw.path], [rw.iters]), filter(nil), sort_keys([rw.bfs_key, ASC])
  1 - output([rw.ename], [rw.empno], [rw.mgr], [rw.path], [rw.iters], [rw.bfs_key]), filter(nil), 
      access([rw.ename], [rw.empno], [rw.mgr], [rw.path], [rw.iters], [rw.bfs_key])
  2 - output([UNION(emp1.ename, t.ename)], [UNION(emp1.mgr, t.mgr)], [UNION(emp1.empno, t.empno)], [UNION(cast(?, BIGINT(20, 0)), cast(r.iters + 1, BIGINT(20, 0)))], [UNION(cast(emp1.sal, DECIMAL(8, 2)), r.sal + t.sal)], [UNION(cast(concat(emp1.mgr, concat(',', emp1.empno)), VARCHAR(12302)), concat(r.path, concat(',', t.empno)))], [T_CTE_SEARCH_COLUMN], [T_CTE_CYCLE_COLUMN]), filter(nil)
  3 - output([emp1.ename], [emp1.mgr], [emp1.empno], [cast(?, BIGINT(20, 0))], [cast(emp1.sal, DECIMAL(8, 2))], [cast(concat(emp1.mgr, concat(',', emp1.empno)), VARCHAR(12302))]), filter(nil), sort_keys([emp1.empno, ASC])
  4 - output([emp1.ename], [emp1.mgr], [emp1.empno], [cast(emp1.sal, DECIMAL(8, 2))], [cast(concat(emp1.mgr, concat(',', emp1.empno)), VARCHAR(12302))]), filter([emp1.ename = 'Eve7']), 
      access([emp1.ename], [emp1.mgr], [emp1.empno], [emp1.sal]), partitions(p0)
  5 - output([t.ename], [t.mgr], [t.empno], [cast(r.iters + 1, BIGINT(20, 0))], [r.sal + t.sal], [concat(r.path, concat(',', t.empno))]), filter(nil), 
      equal_conds([r.empno = t.mgr]), other_conds(nil)
  6 - output([t.mgr], [t.ename], [t.empno], [t.sal], [concat(',', t.empno)]), filter(nil), 
      access([t.mgr], [t.ename], [t.empno], [t.sal]), partitions(p0)
  7 - output([r.empno], [r.sal], [r.path], [cast(r.iters + 1, BIGINT(20, 0))]), filter(nil), 
      access([r.empno], [r.iters], [r.sal], [r.path]), partitions(nil)


WITH rw (ename, mgr, empno , iters, sal, path) AS
   (
      SELECT ename, mgr, empno, 1 iters, sal, concat((mgr), concat(',', (empno))) path 
      FROM emp1
      WHERE ename = 'Eve7'
      UNION ALL
      SELECT t.ename, t.mgr, t.empno, r.iters + 1 iters, (r.sal + t.sal) sal,
                      concat(r.path,concat(',',(t.empno))) path
      FROM rw r, emp1 t
