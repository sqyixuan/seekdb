explain basic
WITH rw (ename, mgr, empno , iters, sal, path) AS
   (
      SELECT ename, mgr, empno, 1 iters, sal, concat((mgr),concat(',',(empno))) path
      FROM emp1
      WHERE ename = 'Eve'
      UNION ALL
      SELECT t.ename, t.mgr, t.empno, r.iters + 1 iters, (r.sal + t.sal) sal,
                      concat(r.path,concat(',',(t.empno))) path
      FROM rw r, emp1 t
      WHERE r.empno = t.mgr  
   )
   SELECT  ename, path, length (path), instr(path, '8107')
   FROM rw;
