  1 - output([rw.cum_cost], [rw.head], [rw.depth], [rw.empno], [rw.mgr], [rw.path], [rw.order1]), filter([rw.cum_cost < 10000]), 
      access([rw.cum_cost], [rw.head], [rw.depth], [rw.empno], [rw.mgr], [rw.path], [rw.order1])
  2 - output([UNION(e.EMPno, r.head)], [UNION(cast(?, BIGINT(20, 0)), cast(r.depth + 1, BIGINT(20, 0)))], [UNION(e.EMPno, e.EMPno)], [UNION(e.MGR, e.MGR)], [UNION(cast(e.SAL, DECIMAL(8, 2)), e.SAL + r.cum_cost)], [UNION(cast(concat(e.EMPno), VARCHAR(24)), concat(e.EMPno, concat('->', r.path)))], [T_CTE_SEARCH_COLUMN]), filter(nil)
  3 - output([e.EMPno], [cast(?, BIGINT(20, 0))], [e.EMPno], [e.MGR], [cast(e.SAL, DECIMAL(8, 2))], [cast(concat(e.EMPno), VARCHAR(24))]), filter(nil), sort_keys([e.EMPno, ASC])
  4 - output([e.EMPno], [e.MGR], [cast(e.SAL, DECIMAL(8, 2))], [cast(concat(e.EMPno), VARCHAR(24))]), filter(nil), 
      access([e.EMPno], [e.MGR], [e.SAL]), partitions(p0)
  5 - output([r.head], [cast(r.depth + 1, BIGINT(20, 0))], [e.EMPno], [e.MGR], [e.SAL + r.cum_cost], [concat(e.EMPno, concat('->', r.path))]), filter(nil), 
      equal_conds([r.empno = e.MGR]), other_conds(nil)
  6 - output([e.MGR], [e.EMPno], [e.SAL]), filter(nil), 
      access([e.MGR], [e.EMPno], [e.SAL]), partitions(p0)
  7 - output([r.empno], [r.head], [r.cum_cost], [cast(r.depth + 1, BIGINT(20, 0))], [concat('->', r.path)]), filter(nil), 
      access([r.empno], [r.head], [r.depth], [r.cum_cost], [r.path]), partitions(nil)


WITH rw (head, depth, empno, mgr, cum_cost, path ) AS
( 
     SELECT empno, 1, empno, mgr, sal, concat(empno)
     FROM emp e
     UNION ALL
     SELECT r.head, r.depth+1, e.empno, e.mgr, e.sal+r.cum_cost,  
           concat((e.empno),concat('->',r.path))
