## =======================================================================
## Test Case 2:
## - recursive WITH Query: BFS search ordering is specified with order by 
##                         used on search order key
## =======================================================================
explain basic
WITH rw (ename, mgr, empno, levl) AS
(
    SELECT ename, mgr, empno, 1 levl
    FROM emp e
    WHERE job = 'PRESIDENT'
    UNION ALL
    SELECT e.ename, e.mgr, e.empno, r.levl + 1 levl
    FROM rw r, emp e
    WHERE r.empno = e.mgr
)
SEARCH BREADTH FIRST BY mgr,empno SET bfs_key  
SELECT concat(LPAD(' ', 2*(levl-1), ' '), ename) name, empno, mgr, levl
FROM rw
ORDER BY bfs_key;
Query Plan
===============================
|ID|OPERATOR             |NAME|
-------------------------------
|0 |SORT                 |    |
|1 | SUBPLAN SCAN        |rw  |
|2 |  RECURSIVE UNION ALL|    |
|3 |   SORT              |    |
|4 |    TABLE SCAN       |e   |
|5 |   HASH JOIN         |    |
|6 |    TABLE SCAN       |e   |
|7 |    TABLE SCAN       |r   |
===============================

Outputs & filters: 
-------------------------------------
  0 - output([concat(LPAD(' ', 2 * rw.levl - 1, ' '), rw.ename)], [rw.empno], [rw.mgr], [rw.levl]), filter(nil), sort_keys([rw.bfs_key, ASC])
  1 - output([rw.levl], [rw.empno], [rw.mgr], [rw.bfs_key], [concat(LPAD(' ', 2 * rw.levl - 1, ' '), rw.ename)]), filter(nil), 
      access([rw.levl], [rw.ename], [rw.empno], [rw.mgr], [rw.bfs_key])
  2 - output([UNION(e.ENAME, e.ENAME)], [UNION(e.MGR, e.MGR)], [UNION(e.EMPno, e.EMPno)], [UNION(cast(?, BIGINT(20, 0)), cast(r.levl + 1, BIGINT(20, 0)))], [T_CTE_SEARCH_COLUMN]), filter(nil)
  3 - output([e.ENAME], [e.MGR], [e.EMPno], [cast(?, BIGINT(20, 0))]), filter(nil), sort_keys([e.MGR, ASC], [e.EMPno, ASC])
  4 - output([e.ENAME], [e.MGR], [e.EMPno]), filter([e.JOB = 'PRESIDENT']), 
      access([e.JOB], [e.ENAME], [e.MGR], [e.EMPno]), partitions(p0)
  5 - output([e.ENAME], [e.MGR], [e.EMPno], [cast(r.levl + 1, BIGINT(20, 0))]), filter(nil), 
      equal_conds([r.empno = e.MGR]), other_conds(nil)
  6 - output([e.MGR], [e.ENAME], [e.EMPno]), filter(nil), 
      access([e.MGR], [e.ENAME], [e.EMPno]), partitions(p0)
  7 - output([r.empno], [cast(r.levl + 1, BIGINT(20, 0))]), filter(nil), 
      access([r.empno], [r.levl]), partitions(nil)


