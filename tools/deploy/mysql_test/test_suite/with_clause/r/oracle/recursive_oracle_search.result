  1 - output([rw.empno], [rw.mgr], [rw.iscycle], [rw.dfs_key], [concat(LPAD(' ', 2 * rw.levl - 1, ' '), rw.ename)]), filter(nil), 
      access([rw.levl], [rw.ename], [rw.empno], [rw.mgr], [rw.iscycle], [rw.dfs_key])
  2 - output([UNION(e.ename, e.ename)], [UNION(e.mgr, e.mgr)], [UNION(e.empno, e.empno)], [UNION(cast(?, BIGINT(20, 0)), cast(r.levl + 1, BIGINT(20, 0)))], [T_CTE_SEARCH_COLUMN], [T_CTE_CYCLE_COLUMN]), filter(nil)
  3 - output([e.ename], [e.mgr], [e.empno], [cast(?, BIGINT(20, 0))]), filter(nil), sort_keys([e.empno, ASC])
  4 - output([e.ename], [e.mgr], [e.empno]), filter([e.job = 'PRESIDENT']), 
      access([e.job], [e.ename], [e.mgr], [e.empno]), partitions(p0)
  5 - output([e.ename], [e.mgr], [e.empno], [cast(r.levl + 1, BIGINT(20, 0))]), filter(nil), 
      equal_conds([r.empno = e.mgr]), other_conds(nil)
  6 - output([e.mgr], [e.empno], [e.ename]), filter([e.mgr > e.empno]), 
      access([e.mgr], [e.empno], [e.ename]), partitions(p0)
  7 - output([r.empno], [cast(r.levl + 1, BIGINT(20, 0))]), filter(nil), 
      access([r.empno], [r.levl]), partitions(nil)


WITH rw (ename, mgr, empno, levl) AS
(
    SELECT ename, mgr, empno, 1 levl
    FROM emp2 e
    WHERE job = 'PRESIDENT'
    UNION ALL
    SELECT e.ename, e.mgr, e.empno, r.levl + 1 levl
    FROM rw r, emp2 e
    WHERE r.empno = e.mgr and e.mgr > e.empno
)
SEARCH DEPTH FIRST BY empno SET dfs_key 
CYCLE empno,mgr set iscycle TO 'Y' DEFAULT 'N'
SELECT concat(LPAD(' ', 2*(levl-1), ' '), ename) name, empno, mgr , iscycle
FROM rw
ORDER BY dfs_key;
