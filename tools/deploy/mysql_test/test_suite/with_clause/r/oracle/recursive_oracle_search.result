## =======================================================================
## Test Case 4:
## - recursive WITH Query: BFS search ordering is specified on multiple
##                         columns with order by used on search order key
##                         ASC order is specified with  option.                         
## =======================================================================
explain basic
WITH rw (ename, mgr, empno, levl) AS
(
    SELECT ename, mgr, empno, 1 levl
    FROM emp e
    WHERE job = 'PRESIDENT'
    UNION ALL
    SELECT /*+ USE_HASH(r e) */  e.ename, e.mgr, e.empno, r.levl + 1 levl
    FROM rw r, emp e
    WHERE r.empno = e.mgr
)
SEARCH BREADTH FIRST BY mgr,empno ASC  SET bfs_key
SELECT concat(LPAD(' ', 2*(levl-1), ' '), ename) name, empno, mgr, levl
FROM rw
ORDER BY bfs_key;
Query Plan
===============================
|ID|OPERATOR             |NAME|
-------------------------------
|0 |SORT                 |    |
|1 | SUBPLAN SCAN        |rw  |
|2 |  RECURSIVE UNION ALL|    |
|3 |   SORT              |    |
|4 |    TABLE SCAN       |e   |
|5 |   HASH JOIN         |    |
|6 |    TABLE SCAN       |e   |
|7 |    TABLE SCAN       |r   |
===============================

