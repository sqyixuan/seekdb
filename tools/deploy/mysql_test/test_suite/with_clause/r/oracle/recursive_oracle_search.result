## =======================================================================
## Test Case 22:  Bug 21506203 SERIAL Run shows results BUT PARALLEL RUN Errors out
## - recursive WITH Query: (Negative test case) SEARCH clause query(Incorrect log)  
##  Order by is used on search-order-key-name. Length of sorting key stored 
##  exceeds the maximum length of 32K 
##  Error code OBE-01489 is expected.                              
##  (Youjung confirmed that in the current serial code we will get the output
##  It will error out only with the new parallel code)
## =======================================================================
explain basic
WITH rw (ename, mgr, empno, levl) AS
(
    SELECT ename, mgr, empno, 1 levl
    FROM emp1 e
    WHERE ename = 'Eve1'
    UNION ALL
    SELECT e.ename, e.mgr, e.empno, r.levl + 1 levl
    FROM rw r, emp1 e
    WHERE r.empno = e.mgr
)
SEARCH DEPTH FIRST BY empno SET dfs_key  
CYCLE empno set iscycle to 'y' default 'n'
SELECT /*+ no_parallel */ concat(LPAD(' ', 2*(levl-1), ' '), ename) name, levl, iscycle
FROM rw
ORDER BY dfs_key;
