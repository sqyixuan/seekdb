## =======================================================================
## Test Case 1:
## - recursive WITH Query: Default BFS ordering
##     Expected Results:  The plan should show 
##     1) the pipelined direct load operator as LOAD AS SELECT WITH OUTPUT
##     2) show only two temp tables
## =======================================================================
explain basic
WITH rw (ename, mgr, empno, levl ) AS
(
    SELECT ename, mgr, empno, 1 levl 
    FROM emp e
    WHERE job = 'PRESIDENT'
    UNION ALL
    SELECT e.ename, e.mgr, e.empno, r.levl + 1 levl
    FROM rw r, emp e
    WHERE r.empno = e.mgr
)
SELECT /*+ no_parallel */concat(LPAD(' ', 2*(levl-1), ' '), ename) name, empno, mgr, levl
FROM rw;
Query Plan
==============================
|ID|OPERATOR            |NAME|
------------------------------
|0 |SUBPLAN SCAN        |rw  |
|1 | RECURSIVE UNION ALL|    |
|2 |  TABLE SCAN        |e   |
|3 |  HASH JOIN         |    |
|4 |   TABLE SCAN       |e   |
|5 |   TABLE SCAN       |r   |
==============================

Outputs & filters: 
-------------------------------------
  0 - output([concat(LPAD(' ', 2 * rw.levl - 1, ' '), rw.ename)], [rw.empno], [rw.mgr], [rw.levl]), filter(nil), 
      access([rw.levl], [rw.ename], [rw.empno], [rw.mgr])
  1 - output([UNION(e.ENAME, e.ENAME)], [UNION(e.MGR, e.MGR)], [UNION(e.EMPno, e.EMPno)], [UNION(cast(?, BIGINT(20, 0)), cast(r.levl + 1, BIGINT(20, 0)))]), filter(nil)
  2 - output([e.ENAME], [e.MGR], [e.EMPno], [cast(?, BIGINT(20, 0))]), filter([e.JOB = 'PRESIDENT']), 
      access([e.JOB], [e.ENAME], [e.MGR], [e.EMPno]), partitions(p0)
  3 - output([e.ENAME], [e.MGR], [e.EMPno], [cast(r.levl + 1, BIGINT(20, 0))]), filter(nil), 
      equal_conds([r.empno = e.MGR]), other_conds(nil)
  4 - output([e.MGR], [e.ENAME], [e.EMPno]), filter(nil), 
      access([e.MGR], [e.ENAME], [e.EMPno]), partitions(p0)
  5 - output([r.empno], [cast(r.levl + 1, BIGINT(20, 0))]), filter(nil), 
      access([r.empno], [r.levl]), partitions(nil)


WITH rw (ename, mgr, empno, levl ) AS
(
    SELECT ename, mgr, empno, 1 levl 
    FROM emp e
    WHERE job = 'PRESIDENT'
    UNION ALL
    SELECT e.ename, e.mgr, e.empno, r.levl + 1 levl
    FROM rw r, emp e
    WHERE r.empno = e.mgr
)
SELECT /*+ no_parallel */concat(LPAD(' ', 2*(levl-1), ' '), ename) name, empno, mgr, levl
FROM rw;
