      access([rw.levl], [rw.ename], [rw.iscycle], [rw.dfs_key])
  2 - output([UNION(e.ename, e.ename)], [UNION(e.mgr, e.mgr)], [UNION(e.empno, e.empno)], [UNION(cast(?, BIGINT(20, 0)), cast(r.levl + 1, BIGINT(20, 0)))], [T_CTE_SEARCH_COLUMN], [T_CTE_CYCLE_COLUMN]), filter(nil)
  3 - output([e.ename], [e.mgr], [e.empno], [cast(?, BIGINT(20, 0))]), filter(nil), sort_keys([e.empno, ASC])
  4 - output([e.ename], [e.mgr], [e.empno]), filter([e.ename = 'Eve1']), 
      access([e.ename], [e.mgr], [e.empno]), partitions(p0)
  5 - output([e.ename], [e.mgr], [e.empno], [cast(r.levl + 1, BIGINT(20, 0))]), filter(nil), 
