## =======================================================================
## Test Case 20:
## - recursive WITH Query: SEARCH clause query with CYCLE Pruning test case. 
##  CYCLE clause is also used in the query with the pruning filter predicate 
##  added. User specifies the SEARCH clause for DFS with a search order key 
##  name. And then ORDER BY is used on this search-order-key-name                               
## =======================================================================

/* add loop from scott back to king  in emp */
update emp2 set mgr = 5001 where ename = 'KING';

explain basic
WITH rw (ename, mgr, empno, levl) AS
(
    SELECT ename, mgr, empno, 1 levl
    FROM emp2 e
    WHERE job = 'PRESIDENT'
    UNION ALL
    SELECT e.ename, e.mgr, e.empno, r.levl + 1 levl
    FROM rw r, emp2 e
    WHERE r.empno = e.mgr and e.mgr > e.empno
)
SEARCH DEPTH FIRST BY empno SET dfs_key 
CYCLE empno,mgr set iscycle TO 'Y' DEFAULT 'N'
SELECT concat(LPAD(' ', 2*(levl-1), ' '), ename) name, empno, mgr , iscycle
FROM rw
ORDER BY dfs_key;
