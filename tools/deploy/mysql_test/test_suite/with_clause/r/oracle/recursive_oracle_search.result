## =======================================================================
## Test Case 10:
## - recursive WITH Query: DFS search ordering is specified on multiple
##                         columns with order by used on search order key
##                         ASC order is specified with  option.                         
## =======================================================================
explain basic
WITH rw (ename, mgr, empno, levl) AS
(
    SELECT ename, mgr, empno, 1 levl
    FROM emp e
    WHERE job = 'PRESIDENT'
    UNION ALL
    SELECT /*+ USE_MERGE(r e) */ e.ename, e.mgr, e.empno, r.levl + 1 levl
    FROM rw r, emp e
    WHERE r.empno = e.mgr
)
SEARCH DEPTH FIRST BY mgr,empno ASC  SET dfs_key 
SELECT concat(LPAD(' ', 2*(levl-1), ' '), ename) name, empno, mgr, levl
FROM rw
ORDER BY dfs_key;
