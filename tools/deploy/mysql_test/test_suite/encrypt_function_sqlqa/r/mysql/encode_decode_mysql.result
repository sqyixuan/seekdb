#еҹәзЎҖsqlиҜӯеҸҘгҖҒи§ҶеӣҫгҖҒзәҰжқҹгҖҒзҙўеј•гҖҒеҮҪж•°еөҢеҘ—
drop table t1;
create table t1(
id int auto_increment,
