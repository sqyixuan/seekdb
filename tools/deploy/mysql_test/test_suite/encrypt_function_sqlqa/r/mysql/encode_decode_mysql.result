#еӯҳеӮЁиҝҮзЁӢ
drop table t1;
create table t1(id int auto_increment primary key,name varchar(255),password varchar(255));
insert into t1 values(1,'еј дёү','a123456');
insert into t1 values(2,'жқҺеӣӣ','b223456');
insert into t1 values(3,'зҺӢдә”','c323456');
insert into t1 values(4,'е°Ҹе…ӯ','d423456');
drop table t2;
create table t2(sid int,miwen blob,mingwen varchar(255));
#ж— еҸӮж•°зҡ„еӯҳеӮЁиҝҮзЁӢ
drop procedure p1_encode;//
create procedure p1_encode()
begin
    declare a blob;
	declare b varchar(255);
    declare i int default 1;
    while i <= 4 do
	  select encode(password,'key'),decode(encode(password,'key'),'key') into a,b from t1 where id = i;
	  insert into t2 values(i,a,b);
	  set i = i + 1;
	end while;
end;
//
call p1_encode();
select * from t2 order by 1,2;
+------+---------+---------+
| sid  | miwen   | mingwen |
+------+---------+---------+
|    1 | ў—ғQFCҒ     | a123456 |
|    2 | o>ғQFCҒ   | b223456 |
|    3 | ЈғQFCҒ    | c323456 |
|    4 | Ә@ғQFCҒ    | d423456 |
+------+---------+---------+
#жңүеҸӮж•°зҡ„еӯҳеӮЁиҝҮзЁӢ(in)
delete from t2;
drop procedure p1_encode;//
create procedure p1_encode(in aa int)
begin
    declare a blob;
	declare b varchar(255);
    declare i int default aa;
    repeat
	  select encode(password,'key'),decode(encode(password,'key'),'key') into a,b from t1 where id = i;
	  insert into t2 values(i,a,b);
	  set i = i + 1;
	until i > 4
	end repeat;
end;
//
call p1_encode(1);
select * from t2 order by 1,2;
+------+---------+---------+
| sid  | miwen   | mingwen |
+------+---------+---------+
|    1 | ў—ғQFCҒ     | a123456 |
|    2 | o>ғQFCҒ   | b223456 |
|    3 | ЈғQFCҒ    | c323456 |
|    4 | Ә@ғQFCҒ    | d423456 |
+------+---------+---------+
#жңүеҸӮж•°зҡ„еӯҳеӮЁиҝҮзЁӢ(out)
delete from t2;
drop procedure p1_encode;//
create procedure p1_encode(out aa blob,out bb varchar(255))
begin
    declare i int default 1;
    while i <= 4 do
	  select encode(password,'key'),decode(encode(password,'key'),'key') into aa,bb from t1 where id = i;
	  insert into t2 values(i,aa,bb);
	  set i = i + 1;
	end while;
end;
//
call p1_encode(@aa,@bb);
select * from t2 order by 1,2;
+------+---------+---------+
| sid  | miwen   | mingwen |
+------+---------+---------+
|    1 | ў—ғQFCҒ     | a123456 |
|    2 | o>ғQFCҒ   | b223456 |
|    3 | ЈғQFCҒ    | c323456 |
|    4 | Ә@ғQFCҒ    | d423456 |
+------+---------+---------+
#иҮӘе®ҡд№үеҮҪж•°
drop function f_encode;//
create  function f_encode() returns  blob READS SQL DATA
begin
    declare aa blob;
	select encode(password,'key') into aa from t1 where id = 1;
	return aa;
end;
//
select f_encode();
+------------+
| f_encode() |
+------------+
| ў—ғQFCҒ        |
+------------+

#и§ҰеҸ‘еҷЁ  
delete from t2;
insert into t2 select id,encode(password,'key'),decode(encode(password,'key'),'key') from t1;
drop trigger trigger_encode;//
create trigger trigger_encode before update 
on t2 for each row
begin
    set new.miwen = encode(new.mingwen,'update');
end;
