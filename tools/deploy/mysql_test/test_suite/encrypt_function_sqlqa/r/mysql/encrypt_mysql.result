#基础sql语句、视图、约束、索引、函数嵌套
drop table t1;
create table t1(c1 int auto_increment primary key,c2 varbinary(100));
insert into t1(c2) values(encrypt('test','key'));
insert into t1(c2) values(encrypt('222','key'));
insert into t1(c2) values(encrypt('333','key'));
insert into t1(c2) values(encrypt('444','key'));
select * from t1;
+----+---------------+
| c1 | c2            |
+----+---------------+
|  1 | kexq.N/GxyBCQ |
|  2 | ke3s9uoj4sWtc |
|  3 | keH1Amk5H6Lyo |
|  4 | kezzQMMDZjOPY |
+----+---------------+
select * from t1 where c2 = encrypt('test','key');
+----+---------------+
| c1 | c2            |
+----+---------------+
|  1 | kexq.N/GxyBCQ |
+----+---------------+
select c1,c2 from t1 where c2 = encrypt('222','key') group by c1,c2;
+----+---------------+
| c1 | c2            |
+----+---------------+
|  2 | ke3s9uoj4sWtc |
+----+---------------+
select c1,c2 from t1 where c2 = encrypt('333','key') order by 1,2;
+----+---------------+
| c1 | c2            |
+----+---------------+
|  3 | keH1Amk5H6Lyo |
+----+---------------+
select c1,c2 from t1 where c2 = encrypt('333','key') order by 1,2 limit 1;
+----+---------------+
| c1 | c2            |
+----+---------------+
|  3 | keH1Amk5H6Lyo |
+----+---------------+
select c1,c2 from t1 tt1 where exists(select * from t1 tt2 where tt2.c2 = tt1.c2 and tt2.c2 = encrypt('444','key'));
+----+---------------+
| c1 | c2            |
+----+---------------+
|  4 | kezzQMMDZjOPY |
+----+---------------+
select c1,c2 from t1 tt1 where not exists(select * from t1 tt2 where tt2.c2 = tt1.c2 and tt2.c2 = encrypt('444','key'));
+----+---------------+
| c1 | c2            |
+----+---------------+
|  1 | kexq.N/GxyBCQ |
|  2 | ke3s9uoj4sWtc |
|  3 | keH1Amk5H6Lyo |
+----+---------------+
select c1,c2 from t1 where c2 in(encrypt('test','key'),encrypt('222','key'));
+----+---------------+
| c1 | c2            |
+----+---------------+
|  1 | kexq.N/GxyBCQ |
|  2 | ke3s9uoj4sWtc |
+----+---------------+
select c1,c2 from t1 where c2 not in(encrypt('test','key'),encrypt('222','key'));
+----+---------------+
| c1 | c2            |
+----+---------------+
|  3 | keH1Amk5H6Lyo |
|  4 | kezzQMMDZjOPY |
+----+---------------+
select c1,c2 from t1 tt1 where c1 < any(select c1 from t1 tt2 where tt2.c2 in (encrypt('test','key'),encrypt('222','key')));
+----+---------------+
| c1 | c2            |
+----+---------------+
|  1 | kexq.N/GxyBCQ |
+----+---------------+
select c1,c2 from t1 tt1 where c1 = some(select c1 from t1 tt2 where tt2.c2 in (encrypt('test','key'),encrypt('222','key')));
+----+---------------+
| c1 | c2            |
+----+---------------+
|  1 | kexq.N/GxyBCQ |
|  2 | ke3s9uoj4sWtc |
+----+---------------+
select c1,c2 from t1 tt1 where c1 > all(select c1 from t1 tt2 where tt2.c2 in (encrypt('test','key'),encrypt('222','key')));
+----+---------------+
| c1 | c2            |
+----+---------------+
|  3 | keH1Amk5H6Lyo |
|  4 | kezzQMMDZjOPY |
+----+---------------+
update t1 set c2 = encrypt('111','key') where c2 = encrypt('test','key');
delete from t1 where c2 = encrypt('444','key') or c1 between 2 and 3;
select * from t1 order by 1,2;
+----+---------------+
| c1 | c2            |
+----+---------------+
|  1 | keeuWIHXgEYdc |
+----+---------------+
