list
drop table t1;
create table t1(
c1 int,c2 blob)
partition by list(c1)(
partition p0 values in(1,2,3),
partition p1 values in(4,5,6),
partition p2 values in(7,8,9)
);
insert into t1() values(1,encrypt('123','11'));
