密码不能是中文
drop table t1;
create table t1(
c1 char(2),
c2 varchar(255),
c3 tinyblob,
c4 tinytext,
c5 blob,
c6 text,
c7 mediumblob,
c8 mediumtext,
c9 longblob,
c10 longtext,
c11 enum('诚信','友善'),
c12 set('杭州','金华','衢州')
);
insert into t1() values('富强','民主','文明','和谐','自由','平等','公正','法治','爱国','敬业','诚信','杭州,金华');
select encrypt('str',c1) as c1,
encrypt('str',c2) as c2,
encrypt('str',c3) as c3,
encrypt('str',c4) as c4,
encrypt('str',c5) as c5,
encrypt('str',c6) as c6,
encrypt('str',c7) as c7,
encrypt('str',c8) as c8,
encrypt('str',c9) as c9,
encrypt('str',c10) as c10,
encrypt('str',c11) as c11,
encrypt('str',c12) as c12
from t1;
+------+------+------+------+------+------+------+------+------+------+------+------+
| c1   | c2   | c3   | c4   | c5   | c6   | c7   | c8   | c9   | c10  | c11  | c12  |
+------+------+------+------+------+------+------+------+------+------+------+------+
| NULL | NULL | NULL | NULL | NULL | NULL | NULL | NULL | NULL | NULL | NULL | NULL |
+------+------+------+------+------+------+------+------+------+------+------+------+
