range-hash
drop table t1;
create table t1(
id int auto_increment,
username varchar(255) not null,
password blob,
birthdate date not null,
primary key (id,birthdate),
key idx_usr(username))
partition by range(id)
subpartition by hash(year(birthdate))
subpartitions 3
(
partition p1 values less than (100),
partition p2 values less than maxvalue
);
insert into t1() values(1,'xiaoyi',encrypt(123456,'123456'),'2018-01-01');
insert into t1() values(2,'xiaoer',encrypt('abcdef','abcdef'),'2019-02-02');
insert into t1() values(3,'xiaosan',encrypt('黄龙时代','hlsd'),'2020-03-03');
insert into t1() values(4,'xiaosi',encrypt('123just爬','up'),'2021-04-04');
select * from t1 order by 1,2,3,4;
+----+----------+---------------+------------+
| id | username | password      | birthdate  |
+----+----------+---------------+------------+
|  1 | xiaoyi   | 12tir.zIbWQ3c | 2018-01-01 |
|  2 | xiaoer   | abDMWw5NL.afs | 2019-02-02 |
|  3 | xiaosan  | hlnS61MWPH/Mk | 2020-03-03 |
|  4 | xiaosi   | up/tyzmxYY.eY | 2021-04-04 |
+----+----------+---------------+------------+
select * from t1 where password = encrypt(123456,'123456');
+----+----------+---------------+------------+
| id | username | password      | birthdate  |
+----+----------+---------------+------------+
|  1 | xiaoyi   | 12tir.zIbWQ3c | 2018-01-01 |
+----+----------+---------------+------------+
update t1 set password = encrypt(654321,'654321') where birthdate = '2018-01-01';
delete from t1 where password = encrypt('123just爬','up');
select * from t1 order by 1,2,3,4;
+----+----------+---------------+------------+
| id | username | password      | birthdate  |
+----+----------+---------------+------------+
|  1 | xiaoyi   | 65zLuiSASj6m2 | 2018-01-01 |
|  2 | xiaoer   | abDMWw5NL.afs | 2019-02-02 |
|  3 | xiaosan  | hlnS61MWPH/Mk | 2020-03-03 |
+----+----------+---------------+------------+
#存储过程
drop table t1;
create table t1(id int auto_increment primary key,name varchar(255),password varchar(255));
insert into t1 values(1,'张三','a123456');
insert into t1 values(2,'李四','b223456');
insert into t1 values(3,'王五','c323456');
insert into t1 values(4,'小六','d423456');
drop table t2;
create table t2(sid int,miwen varchar(255));
#无参数的存储过程
drop procedure p1_encrypt;//
create procedure p1_encrypt()
begin
    declare a varchar(255);
    declare i int default 1;
    while i <= 4 do
	  select encrypt(password,'key') into a from t1 where id = i;
	  insert into t2 values(i,a);
	  set i = i + 1;
	end while;
end;
//
call p1_encrypt();
select * from t2 order by 1,2;
+------+---------------+
| sid  | miwen         |
+------+---------------+
|    1 | keDhWOP5QSk3I |
|    2 | kePAy0.1PK64U |
|    3 | keG1mgAKo8eag |
|    4 | kehS8FgUrh47. |
+------+---------------+
#有参数的存储过程(in)
delete from t2;
drop procedure p1_encrypt;//
create procedure p1_encrypt(in aa int)
begin
    declare a varchar(255);
    declare i int default aa;
    repeat
	  select encrypt(password,'key') into a from t1 where id = i;
	  insert into t2 values(i,a);
	  set i = i + 1;
	until i > 4
	end repeat;
end;
//
call p1_encrypt(1);
select * from t2 order by 1,2;
+------+---------------+
| sid  | miwen         |
+------+---------------+
|    1 | keDhWOP5QSk3I |
|    2 | kePAy0.1PK64U |
|    3 | keG1mgAKo8eag |
|    4 | kehS8FgUrh47. |
+------+---------------+
#有参数的存储过程(out)
delete from t2;
drop procedure p1_encrypt;//
create procedure p1_encrypt(out aa varchar(255))
begin
    declare i int default 1;
    while i <= 4 do
	  select encrypt(password,'key') into aa from t1 where id = i;
	  insert into t2 values(i,aa);
	  set i = i + 1;
	end while;
end;
//
call p1_encrypt(@aa);
select * from t2 order by 1,2;
+------+---------------+
| sid  | miwen         |
+------+---------------+
|    1 | keDhWOP5QSk3I |
|    2 | kePAy0.1PK64U |
|    3 | keG1mgAKo8eag |
|    4 | kehS8FgUrh47. |
+------+---------------+
#自定义函数
drop function f_encrypt;//
create  function f_encrypt() returns  varchar(255) READS SQL DATA
begin
    declare aa varchar(255);
	select encrypt(password,'key') into aa from t1 where id = 1;
	return aa;
end;
//
select f_encrypt();
+---------------+
| f_encrypt()   |
+---------------+
| keDhWOP5QSk3I |
+---------------+
drop function f_encrypt;
create function f_encrypt(aa varchar(255),bb varchar(255)) returns varchar(255)
begin
	return encrypt(aa,bb);
end;
//
select f_encrypt('str1','key');
+-------------------------+
| f_encrypt('str1','key') |
+-------------------------+
| ke7WErrerdYxM           |
+-------------------------+
drop function f_encrypt;
create function f_encrypt() returns varchar(255)
begin
	declare value varchar(255);
	declare value1 varchar(255);
	set value = 'str2';
	set value1 = 'key';
	return encrypt(value,value1);
end;
//
select f_encrypt();
+---------------+
| f_encrypt()   |
+---------------+
| keB2Gk9QOJJXc |
+---------------+
#触发器
drop trigger trigger_encrypt;//
create trigger trigger_encrypt before insert 
on t1 for each row
begin
    set new.password = encrypt(new.name,'insert');
end;
//
insert into t1(id,name) values(5,'七七');
select * from t1 order by 1;
