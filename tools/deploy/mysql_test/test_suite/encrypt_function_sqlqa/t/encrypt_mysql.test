--error 0,1051
drop table t1;
create table t1(
c1 tinyint,
c2 smallint,
c3 mediumint,
c4 int,
c5 bigint,
c6 decimal(5,2),
c7 float,
c8 double,
c9 bit(64)
);
insert into t1() values(1,2,3,4,5,6,7,8,9);
insert into t1() values(11,22,33,44,55,66,77,88,99);
insert into t1() values(111,222,333,444,555,666,777,888,999);
select c1,c2,c3,c4,c5,c6,c7,c8,c9+0 from t1;

select encrypt('str',c1) as c1,
encrypt('str',c2) as c2,
encrypt('str',c3) as c3,
encrypt('str',c4) as c4,
encrypt('str',c5) as c5,
encrypt('str',c6) as c6,
encrypt('str',c7) as c7,
encrypt('str',c8) as c8,
encrypt('str',c9) as c9
from t1;



--echo 密码不能是中文
--error 0,1051
drop table t1;
create table t1(
c1 char(2),
c2 varchar(255),
c3 tinyblob,
c4 tinytext,
c5 blob,
c6 text,
c7 mediumblob,
c8 mediumtext,
c9 longblob,
c10 longtext,
c11 enum('诚信','友善'),
c12 set('杭州','金华','衢州')
);
