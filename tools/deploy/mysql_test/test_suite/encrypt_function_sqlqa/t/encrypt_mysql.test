--echo 复制表
--error 0,1051
drop table test;
create table test(c1 int auto_increment primary key,c2 varbinary(100));

--error 0,1051
drop table t1;
create table t1 select * from test;
alter table t1 modify c1 int auto_increment primary key;
insert into t1(c2) values(encrypt('a','key'));
insert into t1(c2) values(encrypt('ab','key'));
insert into t1(c2) values(encrypt('abc','key'));
insert into t1(c2) values(encrypt('abcd','key'));
select * from t1;

select encrypt(c2,'key') from t1;
select * from t1 where c2 = encrypt('a','key');
select c1,c2 from t1 where c2 = encrypt('ab','key') group by c1,c2;
select c1,c2 from t1 where c2 = encrypt('abc','key') order by 1,2;
select c1,c2 from t1 where c2 = encrypt('abcd','key') order by 1,2 limit 1;
select c1,c2 from t1 tt1 where exists(select * from t1 tt2 where tt2.c2 = tt1.c2 and tt2.c2 = encrypt('abcd','key'));
select c1,c2 from t1 tt1 where not exists(select * from t1 tt2 where tt2.c2 = tt1.c2 and tt2.c2 = encrypt('abcd','key'));
select c1,c2 from t1 where c2 in(encrypt('a','key'),encrypt('ab','key'));
select c1,c2 from t1 where c2 not in(encrypt('a','key'),encrypt('ab','key'));
select c1,c2 from t1 tt1 where c1 < any(select c1 from t1 tt2 where tt2.c2 in (encrypt('a','key'),encrypt('ab','key')));
select c1,c2 from t1 tt1 where c1 = some(select c1 from t1 tt2 where tt2.c2 in (encrypt('a','key'),encrypt('ab','key')));
select c1,c2 from t1 tt1 where c1 > all(select c1 from t1 tt2 where tt2.c2 in (encrypt('a','key'),encrypt('ab','key')));
update t1 set c2 = encrypt('AAAA','key') where c2 = encrypt('a','key');
delete from t1 where c2 = encrypt('abcd','key') or c1 between 2 and 3;
select * from t1 order by 1,2;





--echo 分区表
--echo hash
--error 0,1051
drop table t1;
create table t1(
c1 int,
c2 varbinary(100)
)
partition by hash(c1)(
partition p0,
partition p1);
insert into t1() values(1,encrypt('一','password1'));
insert into t1() values(2,encrypt('二','password2'));
insert into t1() values(3,encrypt('三','password3'));
insert into t1() values(4,encrypt('四','password4'));
select * from t1 partition(p0);
select * from t1 partition(p1);

select c1,encrypt(c2,'key') from t1 where c1 = 1 and c2 = encrypt('一','password1');
update t1 set c1 = 22 where c2 = encrypt('二','password2');
delete from t1 where c1 = 3 or c2 = encrypt('四','password4');
select * from t1 order by 1,2;



--echo range
--error 0,1051
drop table t1;
create table t1(
c1 int,
c2 varbinary(100))
partition by range(c1)(
partition p0 values less than (10),
partition p1 values less than (20),
partition pmax values less than (maxvalue));

insert into t1() values(1,encrypt('01','01'));
insert into t1() values(3,encrypt('03','03'));
insert into t1() values(11,encrypt('11','11'));
insert into t1() values(21,encrypt('21','21'));
select * from t1;

insert into t1() values(31,encrypt('31','31'));
select * from t1 where c1 = 1 and c2 = encrypt('01','01');
update t1 set c2 = encrypt('99','99') where c2 = encrypt('21','21');
delete from t1 where c2 = encrypt('03','03');
select * from t1 order by 1,2;




--echo list
--error 0,1051
drop table t1;
create table t1(
c1 int,c2 blob)
partition by list(c1)(
partition p0 values in(1,2,3),
partition p1 values in(4,5,6),
partition p2 values in(7,8,9)
);

insert into t1() values(1,encrypt('123','11'));
insert into t1() values(4,encrypt('abc','aa'));
insert into t1() values(7,encrypt('汉字','hz'));
select * from t1 partition(p0);
select * from t1 partition(p1);
select * from t1 partition(p2);

select * from t1 tt1 left join t1 tt2 on tt1.c2 = tt2.c2 where tt1.c2 = encrypt('123','11');
update t1 set c1 = 5 where c2 = encrypt('abc','aa');
delete from t1 where c2 = encrypt('汉字','hz');
select * from t1 order by 1,2;


--echo key
--error 0,1051
drop table t1;
create table t1(
c1 int,c2 blob)
partition by key(c1)
partitions 2;

insert into t1() values(1,encrypt('a','password1'));
insert into t1() values(2,encrypt('b','password2'));
insert into t1() values(3,encrypt('c','password3'));
insert into t1() values(4,encrypt('d','password4'));
select * from t1 order by 1,2;

select c1,encrypt(c2,'password1') as new_c2 from t1;
update t1 set c2 = encrypt('bcde','key2') where c1 = 2;
delete from t1 where c1 = 3 or c2 = encrypt('d','password4');
select * from t1 order by 1,2;



--echo range-hash
--error 0,1051
drop table t1;
create table t1(
id int auto_increment,
username varchar(255) not null,
password blob,
birthdate date not null,
primary key (id,birthdate),
key idx_usr(username))
partition by range(id)
subpartition by hash(year(birthdate))
subpartitions 3
(
partition p1 values less than (100),
partition p2 values less than maxvalue
);

insert into t1() values(1,'xiaoyi',encrypt(123456,'123456'),'2018-01-01');
insert into t1() values(2,'xiaoer',encrypt('abcdef','abcdef'),'2019-02-02');
insert into t1() values(3,'xiaosan',encrypt('黄龙时代','hlsd'),'2020-03-03');
insert into t1() values(4,'xiaosi',encrypt('123just爬','up'),'2021-04-04');
select * from t1 order by 1,2,3,4;
select * from t1 where password = encrypt(123456,'123456');
update t1 set password = encrypt(654321,'654321') where birthdate = '2018-01-01';
delete from t1 where password = encrypt('123just爬','up');
select * from t1 order by 1,2,3,4;




--echo #存储过程

--error 0,1051
drop table t1;
create table t1(id int auto_increment primary key,name varchar(255),password varchar(255));
insert into t1 values(1,'张三','a123456');
insert into t1 values(2,'李四','b223456');
insert into t1 values(3,'王五','c323456');
insert into t1 values(4,'小六','d423456');

--error 0,1051
drop table t2;
create table t2(sid int,miwen varchar(255));

--echo #无参数的存储过程
delimiter //;
--error 0,1305
drop procedure p1_encrypt;//
create procedure p1_encrypt()
begin
    declare a varchar(255);
    declare i int default 1;
    while i <= 4 do
	  select encrypt(password,'key') into a from t1 where id = i;
	  insert into t2 values(i,a);
	  set i = i + 1;
	end while;
end;
//
delimiter ;//
call p1_encrypt();
select * from t2 order by 1,2;



--echo #有参数的存储过程(in)
delete from t2;
delimiter //;
--error 0,1305
drop procedure p1_encrypt;//
create procedure p1_encrypt(in aa int)
begin
    declare a varchar(255);
    declare i int default aa;
    repeat
	  select encrypt(password,'key') into a from t1 where id = i;
	  insert into t2 values(i,a);
	  set i = i + 1;
	until i > 4
	end repeat;
end;
//
delimiter ;//
call p1_encrypt(1);
select * from t2 order by 1,2;



--echo #有参数的存储过程(out)
delete from t2;
delimiter //;
--error 0,1305
drop procedure p1_encrypt;//
create procedure p1_encrypt(out aa varchar(255))
begin
    declare i int default 1;
    while i <= 4 do
	  select encrypt(password,'key') into aa from t1 where id = i;
	  insert into t2 values(i,aa);
	  set i = i + 1;
	end while;
end;
//
delimiter ;//
call p1_encrypt(@aa);
select * from t2 order by 1,2;




--echo #自定义函数

delimiter //;
--error 0,1305
drop function f_encrypt;//
create  function f_encrypt() returns  varchar(255) READS SQL DATA
begin
    declare aa varchar(255);
	select encrypt(password,'key') into aa from t1 where id = 1;
	return aa;
end;
//
delimiter ;//
select f_encrypt();


--error 0,1305
drop function f_encrypt;
delimiter //;
create function f_encrypt(aa varchar(255),bb varchar(255)) returns varchar(255)
begin
	return encrypt(aa,bb);
end;
//
delimiter ;//
select f_encrypt('str1','key');




--error 0,1305
drop function f_encrypt;
delimiter //;
create function f_encrypt() returns varchar(255)
begin
	declare value varchar(255);
	declare value1 varchar(255);
	set value = 'str2';
	set value1 = 'key';
	return encrypt(value,value1);
end;
//
delimiter ;//
select f_encrypt();





--echo #触发器
delimiter //;
--error 0,1360
drop trigger trigger_encrypt;//
create trigger trigger_encrypt before insert 
on t1 for each row
begin
    set new.password = encrypt(new.name,'insert');
end;
//
delimiter ;//
insert into t1(id,name) values(5,'七七');
select * from t1 order by 1;



