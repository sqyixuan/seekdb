--echo #字符集
--echo utf8mb4、utf16、binary、gbk、gb18030
select encrypt('str1',_utf8mb4'key');
select encrypt('1234',_utf16'key2');
select encrypt('abcd',_binary'key');
select encrypt('汉字',_gbk'key');
select encrypt('中文123',_gb18030'key');

select encrypt(_utf8mb4'str1','key');
select encrypt(_utf16'1234','key');
select encrypt(_binary'abcd','key');
select encrypt(_gbk'汉字','key');
select encrypt(_gb18030'中文123','key');

select encrypt('！@#￥%……&*',_utf8mb4'key' collate utf8mb4_general_ci) as utf8mb4;
select encrypt('123abc',_utf8mb4'key' collate utf8mb4_unicode_ci) as utf8mb4;
select encrypt('utf8mb4',_utf8mb4'key' collate utf8mb4_bin) as utf8mb4;

select encrypt('加密文本',_utf16'password' collate utf16_general_ci) as utf16;
select encrypt('abcdef',_utf16'password' collate utf16_bin) as utf16;
select encrypt('123456',_utf16'password' collate utf16_unicode_ci) as utf16;

select encrypt('text',_gbk'key' collate gbk_chinese_ci) as gbk;
select encrypt('encrypt',_gbk'key' collate gbk_bin) as gbk;

select encrypt('_gb18030',_gb18030'key' collate gb18030_chinese_ci) as gb18030;
select encrypt('gb18030_bin',_gb18030'key' collate gb18030_bin) as gb18030;

select encrypt(_utf8mb4'utf8mb4_general_ci' collate utf8mb4_general_ci, 'key') as utf8mb4;
select encrypt(_utf8mb4'utf8mb4_unicode_ci' collate utf8mb4_unicode_ci, 'key') as utf8mb4;
select encrypt(_utf8mb4'utf8mb4_bin' collate utf8mb4_bin, 'key') as utf8mb4;

select encrypt(_utf16'utf16_general_ci' collate utf16_general_ci, 'key') as utf16;
select encrypt(_utf16'88' collate utf16_bin, 'key') as utf16;
select encrypt(_utf16'utf16_unicode_ci' collate utf16_unicode_ci, 'key') as utf16;

select encrypt(_gbk'gbk_chinese_ci' collate gbk_chinese_ci, 'key') gbk;
select encrypt(_gbk'gbk_bin' collate gbk_bin, 'key') gbk;

select encrypt(_gb18030'gb18030_chinese_ci' collate gb18030_chinese_ci, 'key') as gb18030;
select encrypt(_gb18030'gb18030_bin' collate gb18030_bin, 'key') as gb18030;



--echo #基础sql语句、视图、约束、索引、函数嵌套
--error 0,1051
drop table t1;
create table t1(c1 int auto_increment primary key,c2 varbinary(100));

insert into t1(c2) values(encrypt('test','key'));
insert into t1(c2) values(encrypt('222','key'));
insert into t1(c2) values(encrypt('333','key'));
insert into t1(c2) values(encrypt('444','key'));
select * from t1;

select * from t1 where c2 = encrypt('test','key');
select c1,c2 from t1 where c2 = encrypt('222','key') group by c1,c2;
select c1,c2 from t1 where c2 = encrypt('333','key') order by 1,2;
select c1,c2 from t1 where c2 = encrypt('333','key') order by 1,2 limit 1;
select c1,c2 from t1 tt1 where exists(select * from t1 tt2 where tt2.c2 = tt1.c2 and tt2.c2 = encrypt('444','key'));
select c1,c2 from t1 tt1 where not exists(select * from t1 tt2 where tt2.c2 = tt1.c2 and tt2.c2 = encrypt('444','key'));
select c1,c2 from t1 where c2 in(encrypt('test','key'),encrypt('222','key'));
select c1,c2 from t1 where c2 not in(encrypt('test','key'),encrypt('222','key'));
select c1,c2 from t1 tt1 where c1 < any(select c1 from t1 tt2 where tt2.c2 in (encrypt('test','key'),encrypt('222','key')));
select c1,c2 from t1 tt1 where c1 = some(select c1 from t1 tt2 where tt2.c2 in (encrypt('test','key'),encrypt('222','key')));
select c1,c2 from t1 tt1 where c1 > all(select c1 from t1 tt2 where tt2.c2 in (encrypt('test','key'),encrypt('222','key')));
update t1 set c2 = encrypt('111','key') where c2 = encrypt('test','key');
delete from t1 where c2 = encrypt('444','key') or c1 between 2 and 3;
select * from t1 order by 1,2;




--echo	#函数嵌套

select encrypt(encrypt('string','password'),'password');
select length(encrypt('aaa','bbbbb'));
select encrypt(length('12345'),'abc');

select encrypt(concat('abc','123'),'password');
select encrypt('123',concat('pass','word'));

select bin(encrypt(8,'123'));
#select encrypt(sha('abc'),'password');
#select encrypt(sha1('abc'),'password');
#SELECT encrypt(sha2('abc', 224),'sha2');
#select sha(encrypt('str','password'));
#select sha1(encrypt('str','password'));
#select sha2(encrypt('str','password'),224);
select md5(encrypt('str','password'));

select left(encrypt('string','password'),3);
select right(encrypt('string','password'),3);
select reverse(encrypt('string','password'));
select substring(encrypt('str','password'),4);

select if(1=1,encrypt('if1', 'password'),encrypt('if2', 'password'));
select if(1>1,encrypt('if1', 'password'),encrypt('if2', 'password'));

select ifnull(null,encrypt('cleartext', 'password'));
select nullif(encrypt('str1', 'password'),encrypt('str2', 'password'));

select case encrypt('case1','password')
	when encrypt('case1','pa') then '成功解密'
	else '解密失败'
	end as col1;

select case when encrypt('123case2','password') = encrypt('123case2222','password') 
	then '成功解密' 
	else '解密失败' 
	end as col1;

select case encrypt('case3','password')
	when encrypt('case','password') then 'oh!'
	when encrypt('case3','password') then 'yah'
	end as col1;





--echo #视图
--error 0,1051
drop table t1;
create table t1(c1 int auto_increment primary key,c2 varbinary(100));

insert into t1(c2) values(encrypt('1','key'));
insert into t1(c2) values(encrypt('22','key'));
insert into t1(c2) values(encrypt('333','key'));
insert into t1(c2) values(encrypt('4444','key'));
select * from t1;


--error 0,1051
drop view tp1;
create view tp1 as select * from t1;

select encrypt(c2,'password') from tp1;
select * from tp1 where c2  = encrypt('1','key');
select c1,c2 from tp1 where c2 = encrypt('22','key') group by c1,c2;
select c1,c2 from tp1 where c2 = encrypt('333','key') order by 1,2;
select c1,c2 from tp1 where c2 = encrypt('4444','key') order by 1,2 limit 1;
select c1,c2 from tp1 where c2 in(encrypt('1','key'),encrypt('22','key'));
select c1,c2 from tp1 where c2 not in(encrypt('1','key'),encrypt('22','key'));
update tp1 set c2 = encrypt('111','key') where c2 = encrypt('test','key');
delete from tp1 where c2 = encrypt('4444','key') or c1 between 2 and 3;
select * from tp1 order by 1,2;







