--error 0,1051
drop table t1;
create table t1(
c1 time,
c2 date,
c3 year,
c4 datetime,
c5 timestamp
) default charset = utf8mb4;

insert into t1 values('01:02:03','2022-10-14','2022','2022-10-14 11:11:11','2022-10-14 11:11:11.123456');
insert into t1 values('02:02:03','2022-10-15','2023','2022-10-15 11:11:11','2022-10-15 11:11:11.123456');
insert into t1 values('03:02:03','2022-10-16','2024','2022-10-16 11:11:11','2022-10-16 11:11:11.123456');
insert into t1 values('04:02:03','2022-10-17','2025','2022-10-17 11:11:11','2022-10-17 11:11:11.123456');

select * from t1;

select des_encrypt(c1,'passwordstring') as c1,
des_encrypt(c2,'passwordstring') as c2,
des_encrypt(c3,'passwordstring') as c3,
des_encrypt(c4,'passwordstring') as c4,
des_encrypt(c4,'passwordstring') as c5 
from t1;

select des_decrypt(des_encrypt(c1,'passwordstring'),'passwordstring') as c1,
des_decrypt(des_encrypt(c2,'passwordstring'),'passwordstring') as c2,
des_decrypt(des_encrypt(c3,'passwordstring'),'passwordstring') as c3,
des_decrypt(des_encrypt(c4,'passwordstring'),'passwordstring') as c4,
des_decrypt(des_encrypt(c5,'passwordstring'),'passwordstring') as c5 
from t1;

select des_encrypt('str',c1) as c1,
des_encrypt('str',c2) as c2,
des_encrypt('str',c3) as c3,
des_encrypt('str',c4) as c4,
des_encrypt('str',c5) as c5 from t1;

select des_decrypt(des_encrypt('str1',c1),c1) as c1,
des_decrypt(des_encrypt('str2',c2),c2) as c2,
des_decrypt(des_encrypt('str3',c3),c3) as c3,
des_decrypt(des_encrypt('str4',c4),c4) as c4,
des_decrypt(des_encrypt('str5',c5),c5) as c5 
from t1;


--error 0,1051
drop table t1;
create table t1(
c1 tinyint,
c2 smallint,
c3 mediumint,
c4 int,
c5 bigint,
c6 decimal(5,2),
c7 float,
c8 double,
c9 bit(64)
) default charset = utf8mb4;
insert into t1() values(1,2,3,4,5,6,7,8,9);
insert into t1() values(11,22,33,44,55,66,77,88,99);
insert into t1() values(111,222,333,444,555,666,777,888,999);
select c1,c2,c3,c4,c5,c6,c7,c8,c9+0 from t1;

select des_encrypt(c1,'passwordstring') as c1,
des_encrypt(c2,'passwordstring') as c2,
des_encrypt(c3,'passwordstring') as c3,
des_encrypt(c4,'passwordstring') as c4,
des_encrypt(c5,'passwordstring') as c5,
des_encrypt(c6,'passwordstring') as c6,
des_encrypt(c7,'passwordstring') as c7,
des_encrypt(c8,'passwordstring') as c8,
des_encrypt(c9+0,'passwordstring') as c9
from t1;

select des_decrypt(des_encrypt(c1,'passwordstring'),'passwordstring') as c1,
des_decrypt(des_encrypt(c2,'passwordstring'),'passwordstring') as c2,
des_decrypt(des_encrypt(c3,'passwordstring'),'passwordstring') as c3,
des_decrypt(des_encrypt(c4,'passwordstring'),'passwordstring') as c4,
des_decrypt(des_encrypt(c5,'passwordstring'),'passwordstring') as c5,
des_decrypt(des_encrypt(c6,'passwordstring'),'passwordstring') as c6,
des_decrypt(des_encrypt(c7,'passwordstring'),'passwordstring') as c7,
des_decrypt(des_encrypt(c8,'passwordstring'),'passwordstring') as c8,
des_decrypt(des_encrypt(c9+0,'passwordstring'),'passwordstring') as c9
from t1;

select des_encrypt('str1',c1) as c1,
des_encrypt('str2',c2) as c2,
des_encrypt('str3',c3) as c3,
des_encrypt('str4',c4) as c4,
des_encrypt('str5',c5) as c5,
des_encrypt('str6',c6) as c6,
des_encrypt('str7',c7) as c7,
des_encrypt('str8',c8) as c8,
des_encrypt('str9',c9) as c9 from t1;

select des_decrypt(des_encrypt('str1',c1),c1) as c1,
des_decrypt(des_encrypt('str2',c2),c2) as c2,
des_decrypt(des_encrypt('str3',c3),c3) as c3,
des_decrypt(des_encrypt('str4',c4),c4) as c4,
des_decrypt(des_encrypt('str5',c5),c5) as c5,
des_decrypt(des_encrypt('str6',c6),c6) as c6,
des_decrypt(des_encrypt('str7',c7),c7) as c7,
des_decrypt(des_encrypt('str8',c8),c8) as c9,
des_decrypt(des_encrypt('str9',c9),c9) as c9
from t1;



