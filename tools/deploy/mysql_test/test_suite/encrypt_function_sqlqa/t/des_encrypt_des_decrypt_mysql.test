des_decrypt(des_encrypt('str2',c2),c2) as c2,
des_decrypt(des_encrypt('str3',c3),c3) as c3,
des_decrypt(des_encrypt('str4',c4),c4) as c4,
des_decrypt(des_encrypt('str5',c5),c5) as c5,
des_decrypt(des_encrypt('str6',c6),c6) as c6,
des_decrypt(des_encrypt('str7',c7),c7) as c7,
des_decrypt(des_encrypt('str8',c8),c8) as c9,
des_decrypt(des_encrypt('str9',c9),c9) as c9,
des_decrypt(des_encrypt('str10',c10),c10) as c10
from t1;



