--echo range-hash
--error 0,1051
drop table t1;
create table t1(
id int auto_increment,
username varchar(255) not null,
password blob,
birthdate date not null,
primary key (id,birthdate),
key idx_usr(username))
partition by range(id)
subpartition by hash(year(birthdate))
subpartitions 3
(
partition p1 values less than (100),
partition p2 values less than maxvalue
);

insert into t1() values(1,'xiaoyi',des_encrypt(123456,'123456'),'2018-01-01');
insert into t1() values(2,'xiaoer',des_encrypt('abcdef','abcdef'),'2019-02-02');
insert into t1() values(3,'xiaosan',des_encrypt('黄龙时代','时代广场'),'2020-03-03');
insert into t1() values(4,'xiaosi',des_encrypt('123just爬','password'),'2021-04-04');
select * from t1 order by 1,2,3,4;
select des_decrypt(password,'123456') from t1 where password = des_encrypt(123456,'123456');
update t1 set password = des_encrypt(654321,'654321') where birthdate = '2018-01-01';
delete from t1 where password = des_encrypt('123just爬','password');
select * from t1 order by 1,2,3,4;




--echo #存储过程

--error 0,1051
drop table t1;
create table t1(id int auto_increment primary key,name varchar(255),password varchar(255));
insert into t1 values(1,'张三','a123456');
insert into t1 values(2,'李四','b223456');
insert into t1 values(3,'王五','c323456');
insert into t1 values(4,'小六','d423456');

--error 0,1051
drop table t2;
create table t2(sid int,miwen blob,mingwen varchar(255));

--echo #无参数的存储过程
delimiter //;
--error 0,1305
drop procedure p1_des_encrypt;//
create procedure p1_des_encrypt()
begin
    declare a blob;
	declare b varchar(255);
    declare i int default 1;
    while i <= 4 do
	  select des_encrypt(password,'key'),des_decrypt(des_encrypt(password,'key'),'key') into a,b from t1 where id = i;
	  insert into t2 values(i,a,b);
	  set i = i + 1;
	end while;
end;
//
delimiter ;//
call p1_des_encrypt();
select * from t2 order by 1,2;



--echo #有参数的存储过程(in)
delete from t2;
delimiter //;
--error 0,1305
drop procedure p1_des_encrypt;//
create procedure p1_des_encrypt(in aa int)
begin
    declare a blob;
	declare b varchar(255);
    declare i int default aa;
    repeat
	  select des_encrypt(password,'key'),des_decrypt(des_encrypt(password,'key'),'key') into a,b from t1 where id = i;
	  insert into t2 values(i,a,b);
	  set i = i + 1;
	until i > 4
	end repeat;
end;
//
delimiter ;//
call p1_des_encrypt(1);
select * from t2 order by 1,2;



--echo #有参数的存储过程(out)
delete from t2;
delimiter //;
--error 0,1305
drop procedure p1_des_encrypt//
create procedure p1_des_encrypt(out aa blob,out bb varchar(255))
begin
    declare i int default 1;
    while i <= 4 do
	  select des_encrypt(password,'key'),password into aa,bb from t1 where id = i;
	  insert into t2 values(i,aa,bb);
	  set i = i + 1;
	end while;
end;
//
delimiter ;//
call p1_des_encrypt(@aa,@bb);
select * from t2 order by 1,2;



--echo #自定义函数

delimiter //;
--error 0,1305
drop function f_des_encrypt;//
create  function f_des_encrypt() returns  blob READS SQL DATA
begin
    declare aa blob;
	select des_encrypt(password,'key') into aa from t1 where id = 1;
	return aa;
end;
//
delimiter ;//
select f_des_encrypt();




--echo #触发器
delete from t2;
insert into t2 select id,des_encrypt(password,'key'),des_decrypt(des_encrypt(password,'key'),'key') from t1;  
delimiter //;
--error 0,1360
drop trigger trigger_des_encrypt;//
create trigger trigger_des_encrypt before update 
on t2 for each row
begin
    set new.miwen = des_encrypt('abc123','update');
	set new.mingwen = des_decrypt(des_encrypt('abc123','update'),'update');
end;
//
delimiter ;//
update t2 set sid = 44 where sid = 4;
select * from t2 order by 1;


