select des_decrypt(des_encrypt(length('12345'),'abc'),'abc');

select des_encrypt(concat('abc','123'),'password');
select des_decrypt(des_encrypt(concat('abc','123'),'password'),'password');
select des_encrypt('123',concat('pass','word'));
select des_decrypt(des_encrypt('123',concat('pass','word')),concat('pass','word'));
select des_encrypt('cleartext', concat('my_random_salt',null,'my_secret_password'));
select des_decrypt(des_encrypt('cleartext', concat('my_random_salt-','my_secret_password')),'my_random_salt-my_secret_password') as 解密;
select des_decrypt(des_encrypt('cleartext', concat('my_random_salt',null,'my_secret_password')),null);

select bin(des_decrypt(des_encrypt(8,'123'),'123'));
