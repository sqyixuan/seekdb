--echo 分区表
--echo hash
--error 0,1051
drop table t1;
create table t1(
c1 int,
c2 blob
)
partition by hash(c1)(
partition p0,
partition p1);
insert into t1() values(1,des_encrypt('c1=1','password1'));
insert into t1() values(2,des_encrypt('c1=2','password2'));
insert into t1() values(3,des_encrypt('c1=3','password3'));
insert into t1() values(4,des_encrypt('c1=4','password4'));
select * from t1 partition(p0);
select * from t1 partition(p1);

select c1,des_decrypt(c2,'password1') from t1 where c2 = des_encrypt('c1=1','password1');
update t1 set c1 = 22 where c2 = des_encrypt('c1=2','password2');
delete from t1 where c1 = 3 or des_decrypt(c2,'password4') = 'c1=4';
select * from t1 order by 1,2;



--echo range
--error 0,1051
drop table t1;
create table t1(
c1 int,
c2 blob)
partition by range(c1)(
partition p0 values less than (10),
partition p1 values less than (20),
partition pmax values less than (maxvalue));

insert into t1() values(1,des_encrypt('1','1'));
insert into t1() values(5,des_encrypt('5','5'));
insert into t1() values(12,des_encrypt('12','12'));
insert into t1() values(17,des_encrypt('17','17'));
