select md5(des_decrypt(des_encrypt('str','password'),'password'));

select lower(des_decrypt(des_encrypt('STR','password'),'password'));
select upper(des_decrypt(des_encrypt('str','password'),'password'));

select left(des_decrypt(des_encrypt('string','password'),'password'),3);
select right(des_decrypt(des_encrypt('string','password'),'password'),6);
select reverse(des_decrypt(des_encrypt('string','password'),'password'));
select substring(des_decrypt(des_encrypt('string','password'),'password'),4);

select if(1=1,des_encrypt('cleartext', 'password'),des_decrypt(des_encrypt('cleartext', 'password'),'password'));
select if(1>1,des_encrypt('cleartext', 'password'),des_decrypt(des_encrypt('cleartext', 'password'),'password'));

select ifnull(null,des_decrypt(des_encrypt('cleartext', 'password'),'password'));
select nullif(des_decrypt(des_encrypt('cleartext', 'password'),'password'),des_encrypt('cleartext', 'password'));

select case des_decrypt(des_encrypt('cleartext','password'),'password')
	when 'cleartext' then '成功解密'
	else '解密失败'
	end as col1;

select case when des_decrypt(des_encrypt('cleartext','password'),'password') = 'cleartext' 
	then '成功解密' 
	else '解密失败' 
	end as col2;

select case des_decrypt(des_encrypt('cleartext','password'),'password') 
	when des_decrypt(des_encrypt('cleartext','password'),'password') then '成功解密'
	when des_decrypt(des_encrypt('text','password'),'password') then '解密失败'
	end as col3;





