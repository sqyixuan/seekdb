select des_decrypt(des_encrypt(1.1234e8,'key_str'),'key_str') as 解密;

select to_base64(des_encrypt(1.1234e8,'key_str')) as 加密;
select des_decrypt(from_base64('/5G0n0+gjtY9z0Zn4r8Q5sM='),'key_str') as 解密;


