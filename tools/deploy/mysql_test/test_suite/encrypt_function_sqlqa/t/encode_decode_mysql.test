select encode(1,'key') as 加密;
select decode(encode(1,'key'),'key') as 解密;

select to_base64(encode(1,'key')) as 加密;
select decode(from_base64('7Q=='),'key') as 解密;

select hex(encode(1,'key')) as 加密;
select decode(unhex('ED'),'key') as 解密;


select encode(0,'key') as 加密;
select decode(encode(0,'key'),'key') as 解密;

