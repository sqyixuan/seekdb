--echo # 环境清理
purge recyclebin;
--result_format 4



let $char_charset = 'UTF8';

--disable_warnings
drop DATABASE IF EXISTS yx5493;
--enable_warnings

CREATE DATABASE yx5493;
USE yx5493;




--echo #encode decode
--echo #basic
--error 0,1051
drop table t1;
create table t1(
username varchar(128),
password blob
);

insert into t1(username,password) values('xiaoxin',encode('xiaoxinxin','passwordstring'));
select  * from t1;

select username,decode(password,'passwordstring') as password from t1;
--echo #密钥不对应时解密失败
select username,decode(password,'wrongpassword') as password from t1;


