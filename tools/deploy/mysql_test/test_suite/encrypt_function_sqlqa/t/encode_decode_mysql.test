--echo 分区表
--echo hash
--error 0,1051
drop table t1;
create table t1(
c1 int,
c2 blob
)
partition by hash(c1)(
partition p0,
partition p1);
insert into t1() values(1,encode('c1=1','password1'));
insert into t1() values(2,encode('c1=2','password2'));
insert into t1() values(3,encode('c1=3','password3'));
insert into t1() values(4,encode('c1=4','password4'));
select * from t1 partition(p0);
select * from t1 partition(p1);

select c1,decode(c2,'password1') from t1 where c2 = encode('c1=1','password1');
update t1 set c1 = 22 where c2 = encode('c1=2','password2');
delete from t1 where c1 = 3 or decode(c2,'password4') = 'c1=4';
select * from t1;



--echo range
--error 0,1051
drop table t1;
create table t1(
c1 int,
c2 blob)
partition by range(c1)(
partition p0 values less than (10),
partition p1 values less than (20),
partition pmax values less than (maxvalue));

insert into t1() values(1,encode('1','1'));
insert into t1() values(5,encode('5','5'));
insert into t1() values(12,encode('12','12'));
insert into t1() values(17,encode('17','17'));
insert into t1() values(55,encode('55','55'));
select * from t1 partition(p0);
select * from t1 partition(p1);
select * from t1 partition(pmax);

insert into t1() values(99,decode(encode('99','99'),'99'));
select c1,decode(c2,'1') from t1 where c2 = encode('1','1');
update t1 set c2 = encode('99','99') where c1 = 99;
delete from t1 where c2 = encode('1','1');
select * from t1;



--echo list
--error 0,1051
drop table t1;
create table t1(
c1 int,c2 blob)
partition by list(c1)(
partition p0 values in(1,2,3),
partition p1 values in(4,5,6),
partition p2 values in(7,8,9)
);

insert into t1() values(1,encode('2','3'));
insert into t1() values(4,encode('5','6'));
insert into t1() values(7,encode('8','9'));
select * from t1 partition(p0);
select * from t1 partition(p1);
select * from t1 partition(p2);

select c1,decode(c2,'3') from t1 where c2 = encode('2','3');
update t1 set c1 = 5 where c1 = decode(encode('4','4'),'4');
delete from t1 where c2 = encode('8','9');
select * from t1;


--echo key
