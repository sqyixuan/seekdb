drop table t1;
create table t1(
c1 int,c2 blob)
partition by key(c1)
partitions 2;

insert into t1() values(1,encode('a','password1'));
insert into t1() values(2,encode('b','password2'));
insert into t1() values(3,encode('c','password3'));
insert into t1() values(4,encode('d','password4'));
select * from t1;

select c1,decode(c2,'password1') from t1 where c2 = encode('a','password1');
update t1 set c1 = 22 where c2 = encode('b','password2');
delete from t1 where c1 = 3 or decode(c2,'password4') = 'd';
select * from t1;



--echo range-hash
--error 0,1051
drop table t1;
create table t1(
id int auto_increment,
username varchar(255) not null,
password blob,
birthdate date not null,
primary key (id,birthdate),
key idx_usr(username))
partition by range(id)
subpartition by hash(year(birthdate))
subpartitions 3
(
partition p1 values less than (100),
partition p2 values less than maxvalue
);

insert into t1() values(1,'xiaoyi',encode(123456,'123456'),'2018-01-01');
insert into t1() values(2,'xiaoer',encode('abcdef','abcdef'),'2019-02-02');
insert into t1() values(3,'xiaosan',encode('黄龙时代','时代广场'),'2020-03-03');
insert into t1() values(4,'xiaosi',encode('123just爬','password'),'2021-04-04');

select decode(password,'123456') from t1 where password = encode(123456,'123456');
update t1 set password = encode(654321,'654321') where birthdate = '2018-01-01';
delete from t1 where password = encode('123just爬','password');
select * from t1 order by 1;






--echo #存储过程

--error 0,1051
drop table t1;
create table t1(id int auto_increment primary key,name varchar(255),password varchar(255));
insert into t1 values(1,'张三','a123456');
insert into t1 values(2,'李四','b223456');
insert into t1 values(3,'王五','c323456');
insert into t1 values(4,'小六','d423456');

--error 0,1051
drop table t2;
create table t2(sid int,miwen blob,mingwen varchar(255));


--echo #无参数的存储过程
delimiter //;
--error 0,1305
drop procedure p1_encode;//
create procedure p1_encode()
begin
    declare a blob;
	declare b varchar(255);
    declare i int default 1;
    while i <= 4 do
	  select encode(password,'key'),decode(encode(password,'key'),'key') into a,b from t1 where id = i;
	  insert into t2 values(i,a,b);
	  set i = i + 1;
	end while;
end;
//
delimiter ;//
call p1_encode();
select * from t2 order by 1,2;


--echo #有参数的存储过程(in)
delete from t2;
delimiter //;
--error 0,1305
drop procedure p1_encode;//
create procedure p1_encode(in aa int)
begin
    declare a blob;
	declare b varchar(255);
    declare i int default aa;
    repeat
	  select encode(password,'key'),decode(encode(password,'key'),'key') into a,b from t1 where id = i;
	  insert into t2 values(i,a,b);
	  set i = i + 1;
	until i > 4
	end repeat;
end;
//
delimiter ;//
call p1_encode(1);
select * from t2 order by 1,2;



--echo #有参数的存储过程(out)
delete from t2;
delimiter //;
--error 0,1305
drop procedure p1_encode;//
create procedure p1_encode(out aa blob,out bb varchar(255))
begin
    declare i int default 1;
    while i <= 4 do
	  select encode(password,'key'),decode(encode(password,'key'),'key') into aa,bb from t1 where id = i;
	  insert into t2 values(i,aa,bb);
	  set i = i + 1;
	end while;
end;
//
delimiter ;//
call p1_encode(@aa,@bb);
select * from t2 order by 1,2;





--echo #自定义函数

delimiter //;
--error 0,1305
drop function f_encode;//
create  function f_encode() returns  blob READS SQL DATA
begin
    declare aa blob;
	select encode(password,'key') into aa from t1 where id = 1;
	return aa;
end;
//
delimiter ;//
select f_encode();


--echo 





--echo #触发器  
delete from t2;
insert into t2 select id,encode(password,'key'),decode(encode(password,'key'),'key') from t1;  
delimiter //;
--error 0,1360
drop trigger trigger_encode;//
create trigger trigger_encode before update 
on t2 for each row
begin
    set new.miwen = encode(new.mingwen,'update');
end;
//
delimiter ;//
update t2 set mingwen = 'e523456' where mingwen = 'd423456';
select * from t2 order by 1;





