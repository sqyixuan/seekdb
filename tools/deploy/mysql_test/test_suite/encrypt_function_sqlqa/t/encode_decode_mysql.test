--echo #字符集
--echo utf8mb4、utf16、binary、gbk、gb18030
select encode('str1',_utf8mb4'key');
select encode('1234',_utf16'key2');
select encode('abcd',_binary'key');
select encode('汉字',_gbk'key');
select encode('中文123',_gb18030'key');

select encode(_utf8mb4'str1','key');
select encode(_utf16'1234','key');
select encode(_binary'abcd','key');
select encode(_gbk'汉字','key');
select encode(_gb18030'中文123','key');

select encode('！@#￥%……&*',_utf8mb4'key' collate utf8mb4_general_ci) as utf8mb4;
select encode('123abc',_utf8mb4'key' collate utf8mb4_unicode_ci) as utf8mb4;
select encode('utf8mb4',_utf8mb4'key' collate utf8mb4_bin) as utf8mb4;

select encode('加密文本',_utf16'password' collate utf16_general_ci) as utf16;
select encode('abcdef',_utf16'password' collate utf16_bin) as utf16;
select encode('123456',_utf16'password' collate utf16_unicode_ci) as utf16;

select encode('text',_gbk'key' collate gbk_chinese_ci) as gbk;
select encode('encrypt',_gbk'key' collate gbk_bin) as gbk;

select encode('_gb18030',_gb18030'key' collate gb18030_chinese_ci) as gb18030;
select encode('gb18030_bin',_gb18030'key' collate gb18030_bin) as gb18030;

select encode(_utf8mb4'utf8mb4_general_ci' collate utf8mb4_general_ci, 'key') as utf8mb4;
select encode(_utf8mb4'utf8mb4_unicode_ci' collate utf8mb4_unicode_ci, 'key') as utf8mb4;
select encode(_utf8mb4'utf8mb4_bin' collate utf8mb4_bin, 'key') as utf8mb4;

select encode(_utf16'utf16_general_ci' collate utf16_general_ci, 'key') as utf16;
select encode(_utf16'88' collate utf16_bin, 'key') as utf16;
select encode(_utf16'utf16_unicode_ci' collate utf16_unicode_ci, 'key') as utf16;

select encode(_gbk'gbk_chinese_ci' collate gbk_chinese_ci, 'key') gbk;
select encode(_gbk'gbk_bin' collate gbk_bin, 'key') gbk;

select encode(_gb18030'gb18030_chinese_ci' collate gb18030_chinese_ci, 'key') as gb18030;
select encode(_gb18030'gb18030_bin' collate gb18030_bin, 'key') as gb18030;


select decode(encode('str1',_utf8mb4'key'),'key');
select decode(encode('1234',_utf16'key2'),'key2');
select decode(encode('abcd',_binary'key'),'key');
select decode(encode('汉字',_gbk'key'),'key');
select decode(encode('中文123',_gb18030'key'),'key');

select decode(encode(_utf8mb4'str1','key'),'key');
select decode(encode(_utf16'1234','key'),'key');
select decode(encode(_binary'abcd','key'),'key');
select decode(encode(_gbk'汉字','key'),'key');
select decode(encode(_gb18030'中文123','key'),'key');

select decode(encode('！@#￥%……&*',_utf8mb4'key' collate utf8mb4_general_ci),'key') as utf8mb4;
select decode(encode('123abc',_utf8mb4'key' collate utf8mb4_unicode_ci),'key') as utf8mb4;
select decode(encode('utf8mb4',_utf8mb4'key' collate utf8mb4_bin),'key') as utf8mb4;

select decode(encode('加密文本',_utf16'password' collate utf16_general_ci),'password') as utf16;
select decode(encode('abcdef',_utf16'password' collate utf16_bin),'password') as utf16;
select decode(encode('123456',_utf16'password' collate utf16_unicode_ci),'password') as utf16;

select decode(encode('text',_gbk'key' collate gbk_chinese_ci),'key') as gbk;
select decode(encode('encrypt',_gbk'key' collate gbk_bin),'key') as gbk;

select decode(encode('_gb18030',_gb18030'key' collate gb18030_chinese_ci),'key') as gb18030;
select decode(encode('gb18030_bin',_gb18030'key' collate gb18030_bin),'key') as gb18030;

select decode(encode(_utf8mb4'utf8mb4_general_ci' collate utf8mb4_general_ci, 'key'),'key') as utf8mb4;
select decode(encode(_utf8mb4'utf8mb4_unicode_ci' collate utf8mb4_unicode_ci, 'key'),'key') as utf8mb4;
select decode(encode(_utf8mb4'utf8mb4_bin' collate utf8mb4_bin, 'key'),'key') as utf8mb4;

select decode(encode(_utf16'utf16_general_ci' collate utf16_general_ci, 'key'),'key') as utf16;
select decode(encode(_utf16'88' collate utf16_bin, 'key'),'key') as utf16;
select decode(encode(_utf16'utf16_unicode_ci' collate utf16_unicode_ci, 'key'),'key') as utf16;

select decode(encode(_gbk'gbk_chinese_ci' collate gbk_chinese_ci, 'key'),'key') gbk;
select decode(encode(_gbk'gbk_bin' collate gbk_bin, 'key'),'key') gbk;

select decode(encode(_gb18030'gb18030_chinese_ci' collate gb18030_chinese_ci, 'key'),'key') as gb18030;
select decode(encode(_gb18030'gb18030_bin' collate gb18030_bin, 'key'),'key') as gb18030;




--echo #基础sql语句、视图、约束、索引、函数嵌套
--error 0,1051
drop table t1;
create table t1(
id int auto_increment,
username varchar(128),
password blob,
primary key(id));

insert into t1(username,password) values('xiaoxin',encode('xiaoxinxin','passwordstring'));
insert into t1(username,password) values('xiaoli',encode('xiaolizi','passwordstring'));
insert into t1(username,password) values('xiaochao',encode('xiaochaochao','passwordstring'));
insert into t1(username,password) values('xiaowang',encode('xiaowangwang','passwordstring'));
select  * from t1;

select username,decode(password,'passwordstring') from t1;

select username,decode(password,'passwordstring') as password from t1 where username = 'xiaoxin';
select username,decode(password,'passwordstring') as password from t1 where username = 'xiaoli' group by username,password;
select username,decode(password,'passwordstring') as password from t1 where username = 'xiaochao' order by 1;
select username,decode(password,'passwordstring') as password from t1 where username = 'xiaoli' order by 1,2 limit 1;
select username,decode(password,'passwordstring') as password from t1 tt1 where exists(
	select * from t1 tt2 where tt2.username = tt1.username and tt2.username like '%n%');
select username,decode(password,'passwordstring') as password from t1 tt1 where not exists(
	select * from t1 tt2 where tt2.username = tt1.username and tt2.username like '%n%');	
select username,decode(password,'passwordstring') as password from t1 where username in('xiaoli','xiaochao');
select username,decode(password,'passwordstring') as password from t1 where username not in('xiaoli','xiaochao');
select username,decode(password,'passwordstring') as password from t1 tt1 where id > any(select id from t1 tt2 where tt2.id > 2);
select username,decode(password,'passwordstring') as password from t1 tt1 where id = some(select id from t1 tt2 where tt2.id > 2);
select username,decode(password,'passwordstring') as password from t1 tt1 where id < all(select id from t1 tt2 where tt2.id > 1);
select id,username,decode(password,'passwordstring') as password from t1 where decode(password,'passwordstring') like '%c%';
update t1 set password = encode('xiaoxinxin','xinxin') where username = 'xiaoxin';
delete from t1 where username in ('xiaoli','xiaochao') or password = encode('xiaowangwang','passwordstring');
select  * from t1;



--echo	#函数嵌套

select encode(decode(encode('123','password1'),'password1'),'password2');
select decode(encode(decode(encode('123','password1'),'password1'),'password2'),'password2');
select length(encode('aaa','bbbbb'));
select length(decode(encode('geeksforgeeks123', 'passwordstring'),'passwordstring'));
select encode(length('12345'),'abc');
select decode(encode(length('12345'),'abc'),'abc');

select encode(concat('abc','123'),'password');
select decode(encode(concat('abc','123'),'password'),'password');
select encode('123',concat('pass','word'));
select decode(encode('123',concat('pass','word')),concat('pass','word'));
select encode('cleartext', concat('my_random_salt',null,'my_secret_password'));
select decode(encode('cleartext', concat('my_random_salt-','my_secret_password')),'my_random_salt-my_secret_password') as 解密;
select decode(encode('cleartext', concat('my_random_salt',null,'my_secret_password')),null);

select bin(decode(encode(8,123),123));
#select encode(sha('abc'),'password');
#select encode(sha1('abc'),'password');
#SELECT encode(sha2('abc', 224),'sha2');
#select sha(decode(encode('str','password'),'password'));
#select sha1(decode(encode('str','password'),'password'));
#select sha2(decode(encode('str','password'),'password'),224);
select md5(decode(encode('str','password'),'password'));

select lower(decode(encode('STR','password'),'password'));
select upper(decode(encode('str','password'),'password'));

select left(decode(encode('string','password'),'password'),3);
select right(decode(encode('string','password'),'password'),6);
select reverse(decode(encode('string','password'),'password'));
select substring(decode(encode('string','password'),'password'),4);

select if(1=1,encode('cleartext', 'password'),decode(encode('cleartext', 'password'),'password'));
select if(1>1,encode('cleartext', 'password'),decode(encode('cleartext', 'password'),'password'));

select ifnull(null,decode(encode('cleartext', 'password'),'password'));
select nullif(decode(encode('cleartext', 'password'),'password'),encode('cleartext', 'password'));

select case decode(encode('cleartext','password'),'password')
	when 'cleartext' then '成功解密'
	else '解密失败'
	end as col1;

select case when decode(encode('cleartext','password'),'password') = 'cleartext' 
	then '成功解密' 
	else '解密失败' 
	end as col2;

select case decode(encode('cleartext','password'),'password') 
	when decode(encode('cleartext','password'),'password') then '成功解密'
	when decode(encode('text','password'),'password') then '解密失败'
	end as col3;


--echo 自定义变量
set @aa = '123456';
select encode(@aa,@aa);
select encode('123456',@aa);
select encode(@aa,'123456');
select decode(encode(@aa,@aa),'123456');
select decode(encode(@aa,'123456'),@aa);

--echo prepare
prepare p_encode from 'select encode(?,''key'')';
set @s1 = 'abcd';
execute p_encode using @s1;

prepare p_encode2 from 'select encode(''test'',?)';
set @s1 = 'key';
execute p_encode2 using @s1;



