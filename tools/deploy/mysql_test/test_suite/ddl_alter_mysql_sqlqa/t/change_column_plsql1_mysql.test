--echo #重新创建触发器
DROP TRIGGER IF EXISTS trg_insert;

DELIMITER //;

CREATE TRIGGER trg_insert AFTER INSERT ON t2
FOR EACH ROW
BEGIN
    DECLARE a VARCHAR(10);
    SET a=CONCAT(NEW.c4,'A');
    INSERT INTO t1(c0,c1,m2,c4,c5,c6,c7,c8) VALUES(NEW.c0+10,NEW.c1,0,a,NEW.c5,NEW.c6,'12:12:12','2020');
END
//

DELIMITER ;//
