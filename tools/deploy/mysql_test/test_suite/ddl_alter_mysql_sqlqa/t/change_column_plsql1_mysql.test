--echo #delete型触发器

DROP TABLE IF EXISTS t2;
DROP TABLE IF EXISTS t1;

CREATE TABLE t1(c0 INT(5) PRIMARY KEY,
                c1 FLOAT ,
                c2 DOUBLE NOT NULL,
                c3 CHAR(10) DEFAULT 'A',
                c4 VARCHAR(10) UNIQUE,
                c5 CHAR(10),
                c6 INT,
                c7 TIME,
                c8 YEAR);
INSERT INTO t1 VALUES(1,1.0,1.1,'中文','','',0,'11:11:11','2000'),
                     (2,1.1,1.2,'中!文','A','a',1,'11:11:11','2001'),
                     (3,1.2,2.2,'中!文','B','a',2,'11:11:11','2002'),
                     (4,1.3,3.2,'中!文','C','a',3,'11:11:11','2003'),
                     (5,1.4,4.2,'中!文','D','a',4,'11:11:11','2004'),
                     (6,1.5,5.2,'中!文','E','a',5,'11:11:11','2005'),
                     (7,1.6,6.2,'中!文','F','a',6,'11:11:11','2006'),
                     (8,1.7,7.2,'中!文','G','a',7,'11:11:11','2007'),
                     (9,1.8,8.2,'中!文','H','a',8,'11:11:11','2011'),
                     (10,1.9,9.2,'中!文','I','a',9,'11:11:11','2012'),
                     (11,2.0,1.9,'中!文','J','a',10,'11:11:11','2011'),
                     (12,2.1,1.8,'中!文','K','a',11,'11:11:11','2012');

CREATE TABLE t2(c0 INT(4),
                c1 FLOAT,
                c2 DOUBLE,
                c3 CHAR(10),
                c4 VARCHAR(5),
                c5 INT,
                c6 TIME,
                CONSTRAINT fk_c0_c0 FOREIGN KEY(c0) REFERENCES t1(c0) ON DELETE RESTRICT);
                
INSERT INTO t2 VALUES(1,1.0,1.1,'中文','',0,'11:11:11'),
                     (2,1.1,1.2,'中!文','a',1,'11:11:11'),
                     (3,1.2,2.2,'中!文','a',2,'11:11:11'),
                     (4,1.3,3.2,'中!文','a',3,'11:11:11'),
                     (5,1.4,4.2,'中!文','a',4,'11:11:11');
                     
DROP TRIGGER IF EXISTS trg_delete;


DELIMITER //;

CREATE TRIGGER trg_delete AFTER DELETE ON t2
FOR EACH ROW
BEGIN
    DELETE FROM t1 WHERE c1=OLD.c1 OR c2=OLD.c2;
END
//

DELIMITER ;//


