--disable_parsing
BEGIN;
SAVEPOINT s1;
ALTER TABLE t1 CHANGE c2 m2 INT(4) ZEROFILL COMMENT '修改DOUBLE为INT';
sleep 1;
SAVEPOINT s2;
ALTER TABLE t1 MODIFY c1 DOUBLE(5,0) AFTER c0;
sleep 1;
SAVEPOINT s3;
ALTER TABLE t1 CHANGE c6 c6 DATETIME AFTER c1;
sleep 1;
--error 0, 01305
ROLLBACK TO s1;

--error 0, 01054
