DROP TEMPORARY TABLE IF EXISTS t1;

CREATE TEMPORARY TABLE t1 (c0 INT(5) ZEROFILL,
                           c1 CHAR(50) DEFAULT 'ABC',
                           c2 VARCHAR(50),CHECK(c2 <> c4),
                           c3 BLOB,
                           c4 ENUM('A','B','D','E'),
                           c5 DATE);
CALL p1();
SELECT COUNT(1) FROM t1;

