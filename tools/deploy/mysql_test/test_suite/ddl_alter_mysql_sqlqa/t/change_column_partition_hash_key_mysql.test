--echo #在分区表创建分区索引，然后修改索引列

DROP TABLE IF EXISTS t1;
CREATE TABLE t1(c0 INT,
                c1 FLOAT ,
                c2 DOUBLE,
                c3 CHAR(10),
                c4 VARCHAR(10),
                c5 CHAR(10),
                c6 INT,
                c7 DATE,
                c8 YEAR)
PARTITION BY HASH(c8) PARTITIONS 3;

