sleep 2;
#SHOW CREATE TABLE t1;

--echo #使用新增列创建全局分区索引
--error 0, 01235
CREATE INDEX ind_g ON t1(c8,c6) GLOBAL
PARTITION BY RANGE(c6)
(PARTITION p1 VALUES LESS THAN(4),
 PARTITION p2 VALUES LESS THAN(8),
 PARTITION p3 VALUES LESS THAN(10),
 PARTITION p4 VALUES LESS THAN(MAXVALUE)
);

CREATE INDEX ind_g ON t1(c8,c6) GLOBAL
PARTITION BY RANGE(c8)
(PARTITION p1 VALUES LESS THAN(4),
 PARTITION p2 VALUES LESS THAN(8),
 PARTITION p3 VALUES LESS THAN(10),
 PARTITION p4 VALUES LESS THAN(MAXVALUE)
);
#SHOW CREATE TABLE t1;


INSERT INTO t1 VALUES('2017',13,2.2,1.7,'中!文','L','b',8,'2018-10-08');
SELECT /*+INDEX(ind_g) */ * FROM t1 WHERE c8>2010 AND c6<6 ORDER BY 1;



