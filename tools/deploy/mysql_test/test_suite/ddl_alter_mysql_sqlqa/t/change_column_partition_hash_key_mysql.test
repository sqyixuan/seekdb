                c1 FLOAT ,
                c2 DOUBLE,
                c3 CHAR(10),
                c4 VARCHAR(10),
                c5 CHAR(10),
                c6 INT,
                c7 TIME,
                c8 YEAR GENERATED ALWAYS AS (c6*2) STORED COMMENT '数值生成列')
PARTITION BY KEY(c8) PARTITIONS 4;

