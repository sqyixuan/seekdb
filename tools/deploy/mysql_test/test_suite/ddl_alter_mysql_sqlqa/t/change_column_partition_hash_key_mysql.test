                c2 DOUBLE,
                c3 CHAR(10),
                c4 VARCHAR(10),
                c5 CHAR(10),
                c6 INT,
                c7 DATE,
                c8 YEAR NOT NULL)
PARTITION BY HASH(c0) PARTITIONS 2;

