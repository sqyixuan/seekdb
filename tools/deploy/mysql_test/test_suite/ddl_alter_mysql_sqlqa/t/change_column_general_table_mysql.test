DROP TABLE IF EXISTS t1;

CREATE TABLE t1(c0 INT(5),
                c1 FLOAT ,
                c2 DOUBLE NOT NULL,
                c3 CHAR(10) DEFAULT 'A',
                c4 VARCHAR(10) UNIQUE,
                c5 CHAR(10) CHARACTER SET 'gb18030' COLLATE 'gb18030_bin',
                c6 INT(5) ZEROFILL,
                c7 TIME,
                c8 YEAR,CHECK(c8>=c6)
                );

