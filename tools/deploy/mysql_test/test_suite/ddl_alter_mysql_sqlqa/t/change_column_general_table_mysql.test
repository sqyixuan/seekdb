ALTER TABLE t1 CHANGE c1 c1 INT FIRST AFTER c2;
--error 01064
ALTER TABLE t1 MODIFY c1 INT FIRST AFTER c2;
--error 01064
ALTER TABLE t1 MODIFY c1 INT BEFORE c1 AFTER c2;

