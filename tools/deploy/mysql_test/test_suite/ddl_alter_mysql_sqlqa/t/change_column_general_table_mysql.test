--disable_result_log

purge recyclebin;
let $char_charset = 'UTF8';

--enable_result_log



--disable_warnings

DROP TABLE IF EXISTS t2;
DROP TABLE IF EXISTS t1;

--echo #CREATE DATA (DATA TYPE + INDEX + CONSTRAINT)

CREATE TABLE t1(c0 INT(5) PRIMARY KEY,
                c1 FLOAT ,
                c2 DOUBLE NOT NULL,
                c3 CHAR(10) DEFAULT 'A',
                c4 VARCHAR(10) UNIQUE,
                c5 CHAR(10) CHARACTER SET 'gb18030' COLLATE 'gb18030_bin',
                c6 INT(5) ZEROFILL,
                c7 TIME,
                c8 YEAR);

