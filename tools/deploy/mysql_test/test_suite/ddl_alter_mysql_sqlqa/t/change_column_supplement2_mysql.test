--disable_parsing


ALTER TABLE t1 MODIFY c1 CHAR(5) NOT NULL DEFAULT 'TEST' AFTER c2,ADD CONSTRAINT uni_key UNIQUE KEY(c2),ADD INDEX ind1(c1),ALTER c2 SET DEFAULT 'test',PARALLEL 5;
#SHOW CREATE TABLE t1;

INSERT INTO v1 VALUES('AA/AA/AA','TESTABCE'),('A            ','H            ');
SELECT c2,CHAR_LENGTH(c2),c1,CHAR_LENGTH(c1) FROM t1 ORDER BY 1;
