#description: 修改列--补充测试用例
#author: wb-zc01081081

--disable_result_log

purge recyclebin;
let $char_charset = 'UTF8';

--enable_result_log


--disable_warnings


#设置sql_mode
SET sql_mode='PAD_CHAR_TO_FULL_LENGTH';


--echo #修改字符串类型和长度


#分区表


DROP TABLE IF EXISTS t1;

CREATE TABLE t1(c1 INT,
                c2 CHAR(10))
PARTITION BY RANGE(c1)
(PARTITION p1 VALUES LESS THAN(15),
PARTITION p2 VALUES LESS THAN(25),
PARTITION p3 VALUES LESS THAN(35)
);

INSERT INTO t1 VALUES(0,'A'),(2,'B'),(4,'C'),(8,'D'),(16,'E'),(18,'F'),(20,'G');

SELECT c2,CHAR_LENGTH(c2) FROM t1 ORDER BY 1;


#修改列的长度和位置

ALTER TABLE t1 MODIFY c2 CHAR(20) FIRST;
#SHOW CREATE TABLE t1;
SELECT c2,CHAR_LENGTH(c2) FROM t1 ORDER BY 1;

INSERT INTO t1 VALUES(21,'test@$测试数据123');
SELECT c2,CHAR_LENGTH(c2) FROM t1 ORDER BY 1;

INSERT INTO t1 VALUES(21,'test@$测试数据123  test@$测试数据123  test@$测试数据123  test@$测试数据123');
SELECT c2,CHAR_LENGTH(c2) FROM t1 ORDER BY 1;

UPDATE t1 SET c2='test@$测试数据test@$测试数据123' WHERE c1=0;
SELECT c2,CHAR_LENGTH(c2) FROM t1 ORDER BY 1;

DELETE FROM t1 WHERE c2='B                   ';
SELECT c2,CHAR_LENGTH(c2) FROM t1 ORDER BY 1;


#修改列名

--error 0, 01067
ALTER TABLE t1 CHANGE c2 m2 CHAR(20) DEFAULT 'TEST/TEST/STEST/TEST/TEST/TEST/';


ALTER TABLE t1 CHANGE c2 m2 CHAR(20) DEFAULT 'TEST/TEST/TEST/TEST/';
#SHOW CREATE TABLE t1;
SELECT m2,CHAR_LENGTH(m2) FROM t1 ORDER BY 1;


INSERT INTO t1(c1) VALUES(22);
SELECT m2,CHAR_LENGTH(m2) FROM t1 ORDER BY 1;

INSERT INTO t1 VALUES(23,'测试数据123@%&￥测试数据123@%&￥￥￥');
SELECT m2,CHAR_LENGTH(m2) FROM t1 ORDER BY 1;

UPDATE t1 SET m2='测试数据' WHERE c1=23;
SELECT m2,CHAR_LENGTH(m2) FROM t1 ORDER BY 1;

DELETE FROM t1 WHERE m2='测试数据                ';
SELECT m2,CHAR_LENGTH(m2) FROM t1 ORDER BY 1;


#修改列的属性

--error 0,1067
ALTER TABLE t1 MODIFY m2 VARCHAR(10) NOT NULL DEFAULT '修改列类型 和其他属性' COMMENT '修改列类型' FIRST;

#暂不支持，待支持后重新执行

--disable_parsing

ALTER TABLE t1 MODIFY m2 VARCHAR(10) NOT NULL DEFAULT '修改列类型和其他属性' COMMENT '修改列类型' FIRST;
#SHOW CREATE TABLE t1;
SELECT m2,CHAR_LENGTH(m2) FROM t1 ORDER BY 1;

INSERT INTO t1(c1) VALUES(23);
SELECT m2,CHAR_LENGTH(m2) FROM t1 ORDER BY 1;

--error 0, 01048
INSERT INTO t1 VALUES(NULL,24);

UPDATE t1 SET m2='A' WHERE m2='TEST/TEST/';
SELECT m2,CHAR_LENGTH(m2) FROM t1 ORDER BY 1;


--enable_parsing


--echo #char类型修改为其他类型

DROP TABLE IF EXISTS t1;

CREATE TABLE t1(c1 INT,
                c2 CHAR(10))
PARTITION BY LIST COLUMNS(c2)
(PARTITION p1 VALUES IN('0','3','5','6','7','9','11','13','14','15'),
PARTITION p2 VALUES IN('20','23','25','26','27','29','31','33','34','35'),
PARTITION p3 VALUES IN('40','43','45','46','47','49','51','53','54','55')
);

INSERT INTO t1 VALUES(0,'7'),(2,'3'),(4,'5'),(8,'6'),(16,'14'),(18,'9'),(20,'13');

--echo #此处OB修改成功，MySQL修改报错，OB有问题，开发在改，问题链接：

ALTER TABLE t1 MODIFY c2 INT(5) PRIMARY KEY AUTO_INCREMENT COMMENT '字符串类型修改为数值类型' FIRST;
#SHOW CREATE TABLE t1;
SELECT c2,CHAR_LENGTH(c2) FROM t1 ORDER BY 1;

--error 0, 01526
INSERT INTO t1 VALUES(21,'21'),(22,'23');
--error 0,1526
INSERT INTO t1 VALUES(21,'20'),(22,'23');
SELECT c2,CHAR_LENGTH(c2) FROM t1 ORDER BY 1;


--echo #修改其他列为CHAR类型

ALTER TABLE t1 MODIFY c1 CHAR(5) FIRST;
#SHOW CREATE TABLE t1;
SELECT c1,CHAR_LENGTH(c1) FROM t1 ORDER BY 1;

INSERT INTO t1 VALUES(123456,'40');
UPDATE t1 SET c1='超过5个字的条目' WHERE c1='16   ';
DELETE FROM t1 WHERE c1='4';
SELECT c1,CHAR_LENGTH(c1) FROM t1 ORDER BY 1;



DROP TABLE IF EXISTS t1;

CREATE TABLE t1(c1 INT,
                c2 CHAR(5))
PARTITION BY LIST COLUMNS(c2)
(PARTITION p1 VALUES IN('0','3','5','6','7','9','11000','13','14','15'),
PARTITION p2 VALUES IN('20','23','25','26000','27','29','31','33','34','35'),
PARTITION p3 VALUES IN('40000','43000','45','46','47','49','51','53','54','55')
);

INSERT INTO t1 VALUES(0,'7'),(2,'3'),(4,'5'),(8,'6'),(16,'11000'),(18,'9'),(20,'14');
SELECT c2,CHAR_LENGTH(c2) FROM t1 ORDER BY 1;

--echo #此处修改分区键报错为已知问题，待开发修复后执行

--disable_parsing

ALTER TABLE t1 MODIFY c2 VARCHAR(5);
#SHOW CREATE TABLE t1;

INSERT INTO t1 VALUES(22,'260000');
UPDATE t1 SET c2='400000' WHERE c1=0;
DELETE FROM t1 WHERE c2='11000';
SELECT c2,CHAR_LENGTH(c2) FROM t1 ORDER BY 1;

--error 0, 01654
ALTER TABLE t1 MODIFY c2 CHAR(4),MODIFY c1 BINARY(5);

ALTER TABLE t1 MODIFY c2 CHAR(6),MODIFY c1 BINARY(5);
#SHOW CREATE TABLE t1;

SELECT c1,CHAR_LENGTH(c1),c2,CHAR_LENGTH(c2) FROM t1 ORDER BY 1;

INSERT INTO t1 VALUES(25,'25');
--error 0, 01526
UPDATE t1 SET c1='123456',c2='430000' WHERE c1=0;
UPDATE t1 SET c1='123456',c2='43000 ' WHERE c1=0;
SELECT c1,CHAR_LENGTH(c1),c2,CHAR_LENGTH(c2) FROM t1 ORDER BY 1;

DELETE FROM t1 WHERE c1='12345' AND c2='43000 ';
SELECT c1,CHAR_LENGTH(c1),c2,CHAR_LENGTH(c2) FROM t1 ORDER BY 1;

--enable_parsing


DROP TABLE IF EXISTS t1;

CREATE TABLE t1(c1 FLOAT,
                c2 VARCHAR(5))
PARTITION BY LIST COLUMNS(c2)
(PARTITION p1 VALUES IN('0','3','5','6','7','9','11000','13','14','15'),
PARTITION p2 VALUES IN('20','23','25','26000','27','29','31','33','34','35'),
PARTITION p3 VALUES IN('40000','43000','45','46','47','49','51','53','54','55')
);

INSERT INTO t1 VALUES(0.234,'7'),(2.456,'3'),(4.654,'5'),(8.367,'6'),(16.733,'11000'),(18.8932,'9'),(20.0987766,'14');
SELECT c2,CHAR_LENGTH(c2) FROM t1 ORDER BY 1;


ALTER TABLE t1 MODIFY c1 BINARY(5),MODIFY c2 VARBINARY(5);
#SHOW CREATE TABLE t1;
SELECT c1,CHAR_LENGTH(c1),c2,CHAR_LENGTH(c2) FROM t1 ORDER BY 1;

INSERT INTO t1 VALUES('AABBCCDDEEFF','260000'),('1','51');
UPDATE t1 SET c1='test123', c2='430003' WHERE c1=1;
SELECT c1,CHAR_LENGTH(c1),c2,CHAR_LENGTH(c2) FROM t1 ORDER BY 1;


--echo #暂不支持，待支持后执行sql

--disable_parsing

--error 0, 01654
ALTER TABLE t1 CHANGE c1 c1 CHAR(2),CHANGE c2 c2 CHAR(2),ADD c3 CHAR(2),ADD CONSTRAINT uni_key UNIQUE KEY(c2),ADD INDEX ind1(c1),PARALLEL 5;
ALTER TABLE t1 CHANGE c1 c1 CHAR(2),CHANGE c2 c2 CHAR(6),ADD c3 CHAR(2),ADD CONSTRAINT uni_key UNIQUE KEY(c2),ADD INDEX ind1(c1),PARALLEL 5;
#SHOW CREATE TABLE t1;
SELECT c1,CHAR_LENGTH(c1),c2,CHAR_LENGTH(c2),c3,CHAR_LENGTH(c3) FROM t1 ORDER BY 1;

--error 0, 01526
INSERT INTO t1 VALUES('A','23','C'),('AAAbbb','260000','CCC');
--error 0, 01062
INSERT INTO t1 VALUES('A','23','C'),('AAAbbb','26000 ','CCC');
INSERT INTO t1 VALUES('A','23','C'),('AAAbbb','40000 ','CCC');
SELECT c1,CHAR_LENGTH(c1),c2,CHAR_LENGTH(c2),c3,CHAR_LENGTH(c3) FROM t1 ORDER BY 1;

--enable_parsing


#修改列为生成列


DROP TABLE IF EXISTS t1;

CREATE TABLE t1(c1 CHAR(10) AS (CONCAT(c2,'AA')),
                c2 VARCHAR(5))
PARTITION BY LIST COLUMNS(c2)
(PARTITION p1 VALUES IN('0','3','5','6','7','9','11000','13','14','15'),
PARTITION p2 VALUES IN('20','23','25','26000','27','29','31','33','34','35'),
PARTITION p3 VALUES IN('40000','43000','45','46','47','49','51','53','54','55')
);

INSERT INTO t1(c2) VALUES('7'),('3'),('5'),('6'),('11000'),('9'),('14');
SELECT c1,CHAR_LENGTH(c1),c2,CHAR_LENGTH(c2) FROM t1 ORDER BY 1;

DELETE FROM t1 WHERE c1='11000AA';
SELECT c1,CHAR_LENGTH(c1),c2,CHAR_LENGTH(c2) FROM t1 ORDER BY 1;

#此处报内部错误，已知问题，开发修复后执行

--disable_parsing

ALTER TABLE t1 MODIFY c2 CHAR(6) COMMENT'修改分区键列' FIRST;
#SHOW CREATE TABLE t1;

--error 0, 01526
INSERT INTO t1(c2) VALUES('0'),('26000 '),('4000000');
INSERT INTO t1(c2) VALUES('0'),('26000 '),('46          ');
SELECT c2,CHAR_LENGTH(c2) FROM t1 ORDER BY 1;


--enable_parsing


--echo #在复制表中测试禁用修剪后新增列，并校验。



DROP TABLE IF EXISTS t1;

CREATE TABLE t1(c1 INT,
                c2 CHAR(10));

INSERT INTO t1 VALUES(0,'A'),(2,'B'),(4,'C'),(8,'D'),(16,'E'),(18,'F'),(20,'G');


#使用as关键字创建复制表

DROP TABLE IF EXISTS t2;
CREATE TABLE t2 AS SELECT * FROM t1;
SELECT * FROM t2 ORDER BY 1;
#SHOW CREATE TABLE t2;


#修改不同类型列


ALTER TABLE t2 CHANGE c1 c1 CHAR(5) UNIQUE COMMENT '唯一约束列',MODIFY c2 BINARY(4) FIRST;
#SHOW CREATE TABLE t2;

SELECT c1,CHAR_LENGTH(c1),c2,CHAR_LENGTH(c2) FROM t2 ORDER BY 1;


INSERT INTO t2 VALUES('1234567','AA/BB/CC'),('12      ','AB        ');
SELECT c1,CHAR_LENGTH(c1),c2,CHAR_LENGTH(c2) FROM t2 ORDER BY 1;

UPDATE t2 SET c1='tstecaseofadd' , c2='tstecaseofadd' WHERE c2='G   ';
SELECT c1,CHAR_LENGTH(c1),c2,CHAR_LENGTH(c2) FROM t2 ORDER BY 1;

DELETE FROM t2 WHERE c2='12  ';
SELECT c1,CHAR_LENGTH(c1),c2,CHAR_LENGTH(c2) FROM t2 ORDER BY 1;


#使用LIKE关键字创建复制表

DROP TABLE IF EXISTS t2;
CREATE TABLE t2 LIKE t1;
INSERT INTO t2 SELECT * FROM t1;
SELECT * FROM t2 ORDER BY 1;
#SHOW CREATE TABLE t2;


ALTER TABLE t2 CHANGE c1 c1 CHAR(5) UNIQUE COMMENT '唯一约束列',MODIFY c2 BINARY(4) FIRST;
#SHOW CREATE TABLE t2;

SELECT c1,CHAR_LENGTH(c1),c2,CHAR_LENGTH(c2) FROM t2 ORDER BY 1;


INSERT INTO t2 VALUES('1234567','AA/BB/CC'),('12      ','AB        ');
SELECT c1,CHAR_LENGTH(c1),c2,CHAR_LENGTH(c2) FROM t2 ORDER BY 1;

UPDATE t2 SET c1='tstecaseofadd' , c2='tstecaseofadd' WHERE c2='G   ';
SELECT c1,CHAR_LENGTH(c1),c2,CHAR_LENGTH(c2) FROM t2 ORDER BY 1;

DELETE FROM t2 WHERE c2='12  ';
SELECT c1,CHAR_LENGTH(c1),c2,CHAR_LENGTH(c2) FROM t2 ORDER BY 1;



#修改列并新增删除列


DROP TABLE IF EXISTS t1;

CREATE TABLE t1(c1 INT,
                c2 CHAR(10));

INSERT INTO t1 VALUES(0,'A'),(2,'B'),(4,'C'),(8,'D'),(16,'E'),(18,'F'),(20,'G');


DROP TABLE IF EXISTS t2;
CREATE TABLE t2 LIKE t1;
INSERT INTO t2 SELECT * FROM t1;
SELECT * FROM t2 ORDER BY 1;
#SHOW CREATE TABLE t2;


ALTER TABLE t2 MODIFY c2 BINARY(5) DEFAULT 'TEST' FIRST,ADD c3 CHAR(5) FIRST,DROP c1;
#SHOW CREATE TABLE t2;

INSERT INTO t2 VALUES('TESTCASE','特殊%￥……&字符'),('aa','bb');
SELECT c2,CHAR_LENGTH(c2),c3,CHAR_LENGTH(c3) FROM t2 ORDER BY 1;

UPDATE t2 SET c2='test/test',c3='hahhahh' WHERE c3='aa   ';
SELECT c2,CHAR_LENGTH(c2),c3,CHAR_LENGTH(c3) FROM t2 ORDER BY 1;

DELETE FROM t2 WHERE c2='test/';
SELECT c2,CHAR_LENGTH(c2),c3,CHAR_LENGTH(c3) FROM t2 ORDER BY 1;


#修改列并执行其他DDL操作


DROP TABLE IF EXISTS t2;
CREATE TABLE t2 AS SELECT * FROM t1;
SELECT * FROM t2 ORDER BY 1;
#SHOW CREATE TABLE t2;


#暂不知此，带支持后执行sql

--disable_parsing


ALTER TABLE t2 MODIFY c1 CHAR(5) NOT NULL DEFAULT 'TEST' AFTER c2,ADD CONSTRAINT uni_key UNIQUE KEY(c2),ADD INDEX ind1(c1),ALTER c2 SET DEFAULT 'TEST',PARALLEL 5;
#SHOW CREATE TABLE t2;

INSERT INTO t2 VALUES('TEST/TEST/TEST','TESTCASE'),('T               '','A'');
INSERT INTO t2(c1) VALUES('');
INSERT INTO t2(c2) VALUES('');
SELECT c1,CHAR_LENGTH(c1),c2,CHAR_LENGTH(c2) FROM t2 ORDER BY 1;


--enable_parsing



--echo #在视图中测试禁用修剪后修改列，并校验。



DROP TABLE IF EXISTS t1;

CREATE TABLE t1(c1 INT,
                c2 CHAR(5));

INSERT INTO t1 VALUES(0,'A'),(2,'B'),(4,'C'),(8,'D'),(16,'E'),(18,'F'),(20,'G');



#新增不同类型多列


DROP VIEW IF EXISTS v1;

CREATE VIEW v1 AS SELECT * FROM t1;
DESC v1;
SELECT * FROM v1 ORDER BY 1;

--error 0, 1347
ALTER TABLE v1 CHANGE c2 c2 BINARY(4) UNIQUE COMMENT '唯一约束列',MODIFY c1 CHAR(3) DEFAULT 'TES' AFTER c2;

ALTER TABLE t1 CHANGE c2 c2 BINARY(4) UNIQUE COMMENT '唯一约束列',MODIFY c1 CHAR(3) DEFAULT 'TES' AFTER c2;
#SHOW CREATE TABLE t1;

INSERT INTO v1 VALUES('AABBCCDD','testcase'),('a              ','H             ');
SELECT c1,c2,CHAR_LENGTH(c2) FROM v1;


UPDATE v1 SET c2='tstecaseofadd' , c1='tstecaseofadd' WHERE c2='G   ';
SELECT c1,CHAR_LENGTH(c1),c2,CHAR_LENGTH(c2) FROM v1 ORDER BY 1;

DELETE FROM v1 WHERE c1='a  ';
SELECT c1,CHAR_LENGTH(c1),c2,CHAR_LENGTH(c2) FROM v1 ORDER BY 1;


#修改列并执行其他DDL操作


DROP TABLE IF EXISTS t1;

CREATE TABLE t1(c1 INT,
                c2 CHAR(5));

INSERT INTO t1 VALUES(0,'A'),(2,'B'),(4,'C'),(8,'D'),(16,'E'),(18,'F'),(20,'G');


DROP VIEW IF EXISTS v1;

CREATE VIEW v1 AS SELECT * FROM t1;
DESC v1;
SELECT * FROM v1 ORDER BY 1;


