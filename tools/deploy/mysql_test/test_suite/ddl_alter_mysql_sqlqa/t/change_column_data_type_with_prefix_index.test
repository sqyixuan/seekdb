# owner: buming.lj
# owner group: storage
# description: this case is use for testing change column name and constraint in a alter table statement

--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log

--disable_warnings
DROP TABLE IF EXISTS t1;
DROP TABLE IF EXISTS t2;
DROP TABLE IF EXISTS t3;
--enable_warnings

CREATE TABLE t1 (c0 int, c1 char(100), KEY buming_idx_c1(c1(10)));

INSERT INTO t1 VALUES (1, 'oceanbase is a distributed database');

INSERT INTO t1 VALUES (2, 'ocean');

# support modifying column type of columns with prefix indexes.
ALTER TABLE t1 MODIFY COLUMN c1 varchar(100);

select * from t1 FORCE INDEX (buming_idx_c1) order by c1;

explain select * from t1 FORCE INDEX (buming_idx_c1) order by c1; 

--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
SHOW CREATE TABLE t1;


CREATE TABLE t2 (c0 int, c1 varchar(20), KEY idx_c1(c1(10)));


# only support char -> varchar when modifying column type of columns with prefix indexes.
--error 1235
ALTER TABLE t2 MODIFY COLUMN c1 char(20);
--error 1235
ALTER TABLE t2 MODIFY COLUMN c1 binary(20);

--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
SHOW CREATE TABLE t2;

CREATE TABLE t3 (c0 int, c1 char(20), KEY idx_c1(c1(10)));


# can not change data length when modifying column type of columns with prefix indexes.
--error 1235
ALTER TABLE t3 MODIFY COLUMN c1 varchar(30);
--error 1235
ALTER TABLE t3 MODIFY COLUMN c1 varchar(15);

--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
SHOW CREATE TABLE t2;

DROP TABLE t1;

DROP TABLE t2;

DROP TABLE t3;
