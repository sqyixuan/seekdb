--echo #带有索引、约束及生成列

DROP TABLE IF EXISTS t1;
CREATE TABLE t1(c0 INT(5) AUTO_INCREMENT PRIMARY KEY,
                c1 FLOAT NOT NULL,
                c2 DOUBLE UNIQUE,
                c3 BIT(20) DEFAULT 0,
                c4 BLOB,
                c5 TEXT,
                c6 VARCHAR(50) ,
                c7 CHAR(50) GENERATED ALWAYS AS (CONCAT(c6,'-test')) VIRTUAL NOT NULL COMMENT '字符串生成列',
                c8 BINARY(50) NOT NULL,
                c9 VARBINARY(50) NOT NULL,
                c10 ENUM('a','b','c','d','e','f','g','h'),
                c11 SET('i','j','k','l','m','n','o','p'),
                c12 TIME NOT NULL,
                c13 DATE NOT NULL,
                c14 DATETIME NOT NULL,
                c15 TIMESTAMP NOT NULL,
                c16 YEAR ,CHECK(c16>=c17),
                c17 INT DEFAULT 2000);
