--error 0, 01422

CREATE FUNCTION f_test2(v_c0 INT)
RETURNS VARCHAR(100)
BEGIN
    DECLARE v_count_t1 INT;
    DECLARE v_count_t2 INT;
    DECLARE v_count_t3 VARCHAR(100);
	IF v_c0 <= 10 THEN
	    ALTER TABLE t1 MODIFY c0 INT(4) ZEROFILL NOT NULL DEFAULT 0 AFTER c1;
    	INSERT INTO t1 SELECT t1.* FROM t1,t2 WHERE t2.c1 NOT IN(SELECT c1 FROM t1 WHERE c0 > v_c0);
    ELSE
        ALTER TABLE t1 CHANGE c0 m0 INT(4) ZEROFILL DEFAULT 0;
    	DELETE FROM t1 WHERE c1 <>ALL(SELECT t2.c1 FROM t2 WHERE c1 IN(SELECT c1 FROM t2 WHERE m0 < v_c0));
    END IF;
    SELECT COUNT(c0) INTO v_count_t1 FROM t1;
    SET v_count_t3 = CONCAT('t1表执行函数后条目合计：',v_count_t1);

    RETURN v_count_t3;
END;
//
DELIMITER ;//


