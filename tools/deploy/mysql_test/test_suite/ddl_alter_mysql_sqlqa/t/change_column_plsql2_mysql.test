SELECT * FROM t1 ORDER BY 1;

--error 0, 01054
CALL pro1(6);

ALTER TABLE t1 CHANGE c0 m0 VARCHAR(10) DEFAULT 'A';
#SHOW CREATE TABLE t1;

--error 0, 01054
CALL pro1(12);

DROP PROCEDURE IF EXISTS pro1;

