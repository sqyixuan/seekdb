--echo #存储过程中同时删除新增修改列OB不支持，待支持后执行此存储过程

--disable_parsing

DROP PROCEDURE IF EXISTS pro5;

DELIMITER //;
CREATE PROCEDURE pro5(IN v_c0 INT)
BEGIN
    DECLARE CONTINUE HANDLER FOR SQLSTATE '0A000'
    SELECT '暂不支持此语法，待支持后执行sql！' AS 'ERROR_INFOR';
    IF v_c0 <= 5 THEN
        /* 修改多列 */
        ALTER TABLE t1 CHANGE c0 c0 INT DEFAULT 0 AFTER c2,MODIFY c1 FLOAT(5,0) NOT NULL AFTER c2,CHANGE c3 m3 BIT(25);
    ELSEIF v_c0 <= 10 THEN
        /* 修改列+删除列+新增列 */
        ALTER TABLE t1 MODIFY c7 VARCHAR(50) NOT NULL DEFAULT 'A' AFTER c5,DROP c6,ADD c17 INT FIRST;
    ELSEIF v_c0 <= 15 THEN
        /* 修改索引名+修改列+新增索引 */
        ALTER TABLE t1 RENAME INDEX ind_1 TO ind1,MODIFY c10 VARCHAR(5) DEFAULT 'TEST',ADD INDEX ind3(c17);
    ELSEIF v_c0 <= 20 THEN
        /* 修改列+修改并行度 */
        ALTER TABLE t1 CHANGE c8 m8 BINARY(50),PARALLEL 5;
    ELSEIF v_c0 <= 25 THEN
        /* 删除+修改列的默认值+修改列 */
        ALTER TABLE t1 ALTER c0 DROP DEFAULT,MODIFY c14 DATE DEFAULT '2000-01-01' AFTER c12,ALTER c17 SET DEFAULT 0;
    ELSE
        /* 修改列+删除列+新增列+删除索引+修改列+重命名索引+添加约束+删除列 */
        ALTER TABLE t1 MODIFY c16 INT(4) ZEROFILL DEFAULT 1000 AFTER c0,DROP c15,ADD c18 VARCHAR(10) DEFAULT 'A',DROP INDEX ind3,CHANGE c11 m11 SET('i','j','k','l','m','n','o','p'),RENAME INDEX ind1 TO ind_1,ADD CONSTRAINT uni_key UNIQUE(c0,c13),CHANGE c7 c7 TEXT AFTER c4;
    END IF;
END;
//
DELIMITER ;//

CALL pro5(4);
#SHOW CREATE TABLE t1;


