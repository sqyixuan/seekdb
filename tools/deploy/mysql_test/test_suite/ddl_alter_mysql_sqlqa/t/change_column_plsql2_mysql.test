--echo #使用if...else创建存储过程

DROP PROCEDURE IF EXISTS pro1;

DELIMITER //;
CREATE PROCEDURE pro1(IN v_c0 INT)
BEGIN
    IF v_c0 > 10 AND v_c0 <= 15 THEN
        INSERT INTO t1(c0,c1,c2,c4,c5,c6,c7,c8) VALUES(v_c0+10,v_c0,v_c0,CONCAT(c5,c6),'b',v_c0,'12:12:12',2020);
    ELSEIF v_c0 >= 5 THEN
        UPDATE t1 SET c1=0,c2=0,c3='中文',c4=NULL,c5=b,c6=100,c7='00:00:01',c8=2022 WHERE c0=v_c0;
    ELSE
        DELETE FROM t2 WHERE c5=v_c0;
    END IF;
END;
//
DELIMITER ;//

--echo #修改列并调用存储过程

ALTER TABLE t2 MODIFY c5 INT(4) ZEROFILL DEFAULT 0 AFTER c6;
#SHOW CREATE TABLE t2;

CALL pro1(0);
SELECT * FROM t2 ORDER BY 1;

ALTER TABLE t2 CHANGE c5 m5 INT(4) ZEROFILL DEFAULT 0;
#SHOW CREATE TABLE t2;

--error 0, 01054
CALL pro1(1);


ALTER TABLE t1 MODIFY c0 VARCHAR(10) DEFAULT 'A' AFTER c1;
