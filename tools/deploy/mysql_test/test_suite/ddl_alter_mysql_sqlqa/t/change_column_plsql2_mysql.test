CREATE INDEX ind_1 ON t1(c12);


--echo #存储过程中同时删除新增修改列OB不支持，待支持后执行此存储过程

--disable_parsing

DROP PROCEDURE IF EXISTS pro6;

DELIMITER //;
CREATE PROCEDURE pro6(IN v_c0 INT)
BEGIN
    DECLARE CONTINUE HANDLER FOR SQLSTATE '0A000'
    SELECT '不支持此功能！' AS 'ERROR_INFOR';
    IF v_c0 <= 5 THEN
        /* 修改列唯一索引列 */
        ALTER TABLE t1 MODIFY c1 DOUBLE AFTER c2,ADD CONSTRAINT uni_key UNIQUE KEY(c1,c2);
    ELSEIF v_c0 <= 15 THEN
        /* 修改列带常规索引 */
        ALTER TABLE t1 CHANGE c3 m3 BIT(25) DEFAULT 0,ADD INDEX ind_2(m3);
    ELSEIF v_c0 <= 20 THEN
        /* 修改列带组合索引 */
        ALTER TABLE t1 CHANGE c6 c6 VARCHAR(10) AFTER c7,ADD INDEX ind_3(c6,c7);
    ELSEIF v_c0 <= 25 THEN
        /* 修改列带非空约束 */
        ALTER TABLE t1 MODIFY c10 VARCHAR(5) NOT NULL AFTER c6;
    ELSEIF v_c0 <= 30 THEN
        /* 修改列带默认值约束 */
        ALTER TABLE t1 CHANGE c12 c12 TIME DEFAULT '00:00:00';
    ELSE
        /* 修改列为生成列 */
        ALTER TABLE t1 MODIFY c10 VARCHAR(100) AS (CONCAT(c6,c7)) STORED COMMENT '数值生成列';
    END IF;
END;
//
DELIMITER ;//

CALL pro6(3);
DESC t1;

