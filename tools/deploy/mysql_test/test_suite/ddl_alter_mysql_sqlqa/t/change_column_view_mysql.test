--echo #新增、修改、删除基表列，对视图的影响

DROP VIEW IF EXISTS v1;
CREATE VIEW v1 AS SELECT t1.c0,t2.c2,t1.c3,t2.c4,t1.c5,t2.c6,t1.c7,t2.c8 FROM t1 JOIN t2 ON t1.c0=t2.c0;
SELECT * FROM v1 ORDER BY 1;
DESC v1;
#SHOW INDEX FROM v1;

--error 0, 01393
UPDATE v1 SET c0=13,c6=10 WHERE c2=1.1;

UPDATE v1 SET c5='b',c3='中0文' WHERE c2=1.1;
SELECT * FROM v1 ORDER BY 1;
SELECT * FROM t1 ORDER BY 1;
SELECT * FROM t2 ORDER BY 1;

