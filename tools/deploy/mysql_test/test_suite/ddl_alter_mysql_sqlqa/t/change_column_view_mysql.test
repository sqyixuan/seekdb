CREATE VIEW v1 AS SELECT t1.c0,t2.c1,t1.c3,t2.c4,t1.c5,t2.c6,t1.c7,t2.c8 FROM t1 JOIN t2 ON t1.c0=t2.c0;
SELECT * FROM v1 ORDER BY 1;
DESC v1;
#SHOW INDEX FROM v1;

--error 0,1347
ALTER TABLE v1 CHANGE c3 m3 VARCHAR(10) NOT NULL,MODIFY c5 BINARY(10) DEFAULT 'A' AFTER c1;
# we can support change column name and add not null constraint
ALTER TABLE t2 CHANGE c3 m3 VARCHAR(10) NOT NULL,MODIFY c5 BINARY(10) DEFAULT 'A' AFTER c1;
DESC t2;
DESC v1;
