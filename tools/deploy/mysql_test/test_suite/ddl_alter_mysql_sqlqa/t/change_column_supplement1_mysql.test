--echo #修改列属性及顺序后使用函数


ALTER TABLE t1 MODIFY c6 INT(4) ZEROFILL DEFAULT 0 AFTER c0;
#SHOW CREATE TABLE t1;

#运算符

SELECT MOD(c6,2) 'c6列取余', 2*c6 'c6列的2倍值', c6 DIV(2) 'c6列的商数' FROM t1 ORDER BY 1,2,3;

SELECT c6 FROM t1 WHERE c6>3 AND c6 IN(5,6) ORDER BY 1;

SELECT @var1 := MIN(c6) 'c6列赋值给变量var1' FROM t1;


#聚合函数

SELECT AVG(c6) 'C6列平均值',MAX(c6) 'C6列最大值',SUM(c6) 'C6列合计值' FROM t1;


#时间函数

SELECT TIME(c6) 'c6列使用时间函数1',YEAR(c6) 'c6列使用时间函数2',HOUR(c6) 'c6列使用时间函数3' FROM t1 ORDER BY 1;


#字符串函数

SELECT BIN(c6),ASCII(c6),CONCAT(c6,c5) FROM t1 ORDER BY 1,2,3;


#比较函数

SELECT GREATEST(c6,c0) FROM t1 ORDER BY 1;


#流程控制函数

SELECT CASE 1000*c6 WHEN 1000*c6 > 5000 THEN 'A' ELSE 'B' END FROM t1 ORDER BY 1;


#加密函数

SELECT MD5(c6) 'c6列加密' FROM t1 ORDER BY 1;


#信息函数

SELECT CHARSET(c6) FROM t1;


#其他函数

SELECT ANY_VALUE(c6) FROM t1 GROUP BY c3 ORDER BY 1;

UPDATE t1 SET c6=NULL WHERE c0>10;
COMMIT;
SELECT NVL(c6,0) FROM t1 ORDER BY 1;


--echo #修改列名后使用函数


ALTER TABLE t1 CHANGE c6 m6 INT(4) ZEROFILL;
#SHOW CREATE TABLE t1;

