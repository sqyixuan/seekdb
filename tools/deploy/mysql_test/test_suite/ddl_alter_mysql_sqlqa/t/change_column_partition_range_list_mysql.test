--disable_result_log

purge recyclebin;
let $char_charset = 'UTF8';

--enable_result_log




--disable_warnings
DROP TABLE IF EXISTS t1;
DROP TABLE IF EXISTS t2;

--echo #mysql_modify-3
--echo #mysql_modify-3-1/mysql_modify-3-2/mysql_modify-3-3/mysql_modify-3-4


--echo ################PARTITION BY LIST WITH SUBPARITIONS##################


--echo #Create Data

CREATE TABLE t1(c0 INT,
                c1 FLOAT ,
                c2 DOUBLE,
                c3 CHAR(10),
                c4 VARCHAR(10),
                c5 CHAR(10),
                c6 INT,
                c7 DATE,
                c8 YEAR)
PARTITION BY LIST(c0)
SUBPARTITION BY HASH(c6) SUBPARTITIONS 3
(PARTITION l1 VALUES IN (0,1,2,3,4,5,6),
 PARTITION l2 VALUES IN (7,8,9,10,11,12,13)
);

