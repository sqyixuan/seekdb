--echo #修改分区键创建分区索引(ob支持，MySQL不支持)

DROP TABLE IF EXISTS t1;
CREATE TABLE t1(c0 INT ,
                c1 FLOAT ,
                c2 DOUBLE,
                c3 CHAR(10),
                c4 VARCHAR(10),
                c5 CHAR(10),
                c6 INT,
                c7 DATE,
                c8 YEAR)
PARTITION BY RANGE(c8) SUBPARTITION BY KEY(c0)
(PARTITION l1 VALUES LESS THAN(2000)
    (SUBPARTITION sb1,SUBPARTITION sb2),
 PARTITION l2 VALUES LESS THAN(2005)
    (SUBPARTITION sb3,SUBPARTITION sb4),
 PARTITION l3 VALUES LESS THAN(2010)
    (SUBPARTITION sb5,SUBPARTITION sb6),
 PARTITION l4 VALUES LESS THAN(2015)
    (SUBPARTITION sb7,SUBPARTITION sb8),
 PARTITION l5 VALUES LESS THAN MAXVALUE
    (SUBPARTITION sb9,SUBPARTITION sb10)
    );

