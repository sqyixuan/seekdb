--echo #########################PARTITION BY RANGE COLUMN WITH SUBPARITIONS#############################


DROP TABLE IF EXISTS t1;
CREATE TABLE t1(c0 INT,
                c1 FLOAT ,
                c2 DOUBLE,
                c3 CHAR(10) CHARACTER SET 'gb18030' COLLATE 'gb18030_bin',
                c4 VARCHAR(10) CHARACTER SET 'utf16' COLLATE 'utf16_bin',
                c5 CHAR(10) CHARACTER SET 'gbk' COLLATE 'gbk_bin',
                c6 INT,
                c7 DATE,
                c8 YEAR)
PARTITION BY RANGE COLUMNS(c4)
(PARTITION p1 VALUES LESS THAN('E'),
 PARTITION p2 VALUES LESS THAN('J'),
 PARTITION p3 VALUES LESS THAN('O'),
 PARTITION p4 VALUES LESS THAN(MAXVALUE)
);

