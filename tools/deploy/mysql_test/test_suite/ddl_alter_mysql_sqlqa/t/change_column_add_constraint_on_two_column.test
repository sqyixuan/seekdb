# owner: buming.lj
# owner group: storage
# description: this case is use for testing modify column constraint on two columns

--disable_warnings
DROP TABLE IF EXISTS t1;
DROP TABLE IF EXISTS test;
--enable_warnings

CREATE TABLE t1 (c0 int, c1 char(10));


INSERT INTO t1 VALUES (1, null);

# don't satisfy the not null constraint
--error 1138
ALTER TABLE t1 MODIFY COLUMN c0 int NOT NULL, MODIFY COLUMN c1 char(10) NOT NULL;

--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
SHOW CREATE TABLE t1;

DELETE FROM t1 WHERE c0 = 1;

INSERT INTO t1 VALUES (1, 'oceanbase');

# support adding not null constraint on two columns
ALTER TABLE t1 MODIFY COLUMN c0 int NOT NULL, MODIFY COLUMN c1 char(10) NOT NULL;

# check if the not null constraint is in effect
--error 1048
INSERT INTO t1 VALUES (1, null);

--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
SHOW CREATE TABLE t1;

DROP TABLE t1;


CREATE TABLE t1 (c0 int, c1 char(10), c2 varchar(10));

# support modifying column constraint on more than two columns
ALTER TABLE t1 modify column c0 int not null, modify column c1 char(10) not null, modify column c2 varchar(10) not null;

--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
SHOW CREATE TABLE t1;

DROP TABLE t1;

CREATE TABLE t1 (c0 int, c1 char(10), c2 int);

ALTER TABLE t1 MODIFY COLUMN c0 int NOT NULL,MODIFY COLUMN c1 char(10) NOT NULL, MODIFY COLUMN c2 bigint;

--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
SHOW CREATE TABLE t1;

DROP TABLE t1;

CREATE TABLE t1 (c0 int, c1 char(10));

# don't support index operations simultaneously when modifying column constraints on two columns
--error 1235
ALTER TABLE t1 MODIFY COLUMN c0 int NOT NULL,MODIFY COLUMN c1 char(10) NOT NULL, ADD INDEX idx_c0(c0);

--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
SHOW CREATE TABLE t1;

DROP TABLE t1;

CREATE TABLE t1 (c0 int, c1 char(10));
CREATE TABLE test (c0 int UNIQUE NOT NULL);

# only support adding not null constraint when change column name.
--error 1235
ALTER TABLE t1 ADD CONSTRAINT cst_fk_c0 FOREIGN KEY (c0) REFERENCES test(c0), MODIFY COLUMN c1 char(10) NOT NULL;

--replace_regex /REPLICA_NUM = [0-9]*/REPLICA_NUM = replica_num/g
SHOW CREATE TABLE t1;

DROP TABLE test;
DROP TABLE t1;
