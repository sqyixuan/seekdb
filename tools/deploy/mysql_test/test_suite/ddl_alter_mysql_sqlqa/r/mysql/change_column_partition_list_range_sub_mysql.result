CREATE INDEX ind_g ON t1(c4,c6) GLOBAL
PARTITION BY RANGE COLUMNS(c6)
(PARTITION p1 VALUES LESS THAN(4),
PARTITION p2 VALUES LESS THAN(8),
PARTITION p3 VALUES LESS THAN(10),
PARTITION p4 VALUES LESS THAN(MAXVALUE)
);
ALTER TABLE t1 CHANGE c4 m4 VARCHAR(10) DEFAULT 'B';
CREATE INDEX ind_g ON t1(m4,c6) GLOBAL
PARTITION BY RANGE COLUMNS(m4)
(PARTITION p1 VALUES LESS THAN('E'),
PARTITION p2 VALUES LESS THAN('J'),
PARTITION p3 VALUES LESS THAN('O'),
PARTITION p4 VALUES LESS THAN(MAXVALUE)
);
