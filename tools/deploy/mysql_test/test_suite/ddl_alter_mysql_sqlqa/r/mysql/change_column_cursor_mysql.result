#mysql_modify-4
#mysql_modify-4-1
#mysql_modify-4-1-1/mysql_modify-4-1-2/mysql_modify-4-1-3/mysql_modify-4-1-4
#创建临时表
#直接创建临时表并插入数据
#目前OB不支持CREATE TEMPORARY TABLE 表名 AS (SELECT * FROM 源表名);的语法，故只能测试直接创建临时表。
#设置为严格模式
SET sql_mode='STRICT_TRANS_TABLES,STRICT_ALL_TABLES';
#CREATE DATA (DATA TYPE + INDEX + CONSTRAINT)
CREATE TEMPORARY TABLE t1(c0 INT(5) ZEROFILL PRIMARY KEY,
c1 FLOAT ,
c2 DOUBLE NOT NULL,
c3 CHAR(10) DEFAULT 'A',
c4 VARCHAR(10) UNIQUE,
c5 CHAR(10),
c6 INT,
c7 TIME,
c8 YEAR);
