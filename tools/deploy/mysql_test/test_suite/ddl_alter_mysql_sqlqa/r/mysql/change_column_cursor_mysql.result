#新增+删除+修改+新增索引等操作
DROP TEMPORARY TABLE IF EXISTS t1;
CREATE TEMPORARY TABLE t1 (c0 INT(5) ZEROFILL,
c1 CHAR(50),
c2 VARCHAR(50) NOT NULL,
c3 BLOB,
c4 ENUM('A','B','D','E'),
c5 DATE,
c6 VARCHAR(100) GENERATED ALWAYS AS (CONCAT(c1,c2)) VIRTUAL COMMENT '字符串生成列');
CALL p1();
SELECT COUNT(1) FROM t1;
COUNT(1)
100
INSERT INTO t1(c0,c1,c2,c3,c4,c5) VALUES(15001,'AV','AN','B','A','2013-03-03');
INSERT INTO t1(c0,c1,c3,m4,c7) VALUES(15001,'AV','AN','A',10);
SELECT * FROM t1 WHERE c0=101;
c0	c1	c2	c3	c4	c5	c6
#创建唯一约束、默认值约束，并执行alter table
DROP TEMPORARY TABLE IF EXISTS t1;
CREATE TEMPORARY TABLE t1 (c0 INT(5) ZEROFILL,
c1 CHAR(50) DEFAULT 'ABC',
c2 VARCHAR(50),CHECK(c2 <> c4),
c3 BLOB,
c4 ENUM('A','B','D','E'),
c5 DATE);
CALL p1();
SELECT COUNT(1) FROM t1;
COUNT(1)
100
CALL p1();
#临时表不支持添加外键约束，故不测试
DROP PROCEDURE p1;
DROP TEMPORARY TABLE IF EXISTS t2;
DROP TEMPORARY TABLE IF EXISTS t1;
