#创建临时表并插入大量数据后执行alter table
DROP TEMPORARY TABLE IF EXISTS t1;
CREATE TEMPORARY TABLE t1 (c0 INT(5) ZEROFILL,
c1 CHAR(50),
c2 VARCHAR(50) NOT NULL,
c3 BLOB,
c4 ENUM('A','B','D','E'),
c5 DATE,
c6 VARCHAR(100) GENERATED ALWAYS AS (CONCAT(c1,c2)) VIRTUAL COMMENT '字符串生成列');
drop PROCEDURE p1;
CREATE PROCEDURE p1()
BEGIN
DECLARE j INT DEFAULT 1;
wh2:WHILE j <= 100 DO
IF MOD(j,11) = 0 THEN
INSERT INTO t1(c0,c1,c2,c3,c4,c5) VALUES(j,j||'ABCD',j||'AB'||j,j*10||'test','D','2024-12-07');
ELSEIF MOD(j,7) = 0 THEN
INSERT INTO t1(c0,c1,c2,c3,c4,c5) VALUES(j,j||'DROP',j||'AB'||j+1,j*9||'测试','A','2023-12-07');
ELSEIF MOD(j,5) = 0 THEN
INSERT INTO t1(c0,c1,c2,c3,c4,c5) VALUES(j,j||'CASE',j||'AB'||j-1,j*8||'DROP','E','2022-12-07');
ELSEIF MOD(j,3) = 0 THEN
INSERT INTO t1(c0,c1,c2,c3,c4,c5) VALUES(j,j||'TEST',j+1||'AB'||j,j*7||'ADD','D','2021-12-07');
ELSEIF MOD(j,2) = 0 THEN
INSERT INTO t1(c0,c1,c2,c3,c4,c5) VALUES(j,j||'ADD',j-1||'AB'||j,j*6||'CHANGE','B','2022-12-07');
ELSE
INSERT INTO t1(c0,c1,c2,c3,c4,c5) VALUES(j,j||'中文',j+1||'AB'||j+1,j*5||'MODIFY','A','2024-12-07');
END IF;
SET j = j + 1;
END WHILE wh2;
END;
//
CALL p1();
SELECT COUNT(1) FROM t1;
COUNT(1)
100
