#设置自动提交为1
SET AUTOCOMMIT=1;
#对表进行加锁后修改列
#mysql_modify-4-2-3
#OB目前不支持对表的加锁操作，故先不测试。可以进行对行的加锁操作。
DROP TEMPORARY TABLE IF EXISTS t1;
CREATE TEMPORARY TABLE t1(c0 INT(4),
c1 FLOAT ,
c2 DOUBLE,
c3 CHAR(10),
c4 CHAR(10),
c5 INT,
c6 TIME);
