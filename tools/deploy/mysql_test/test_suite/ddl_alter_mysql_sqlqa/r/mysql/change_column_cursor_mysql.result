#事务
#设置自动提交为0
SET AUTOCOMMIT=0;
DROP TEMPORARY TABLE IF EXISTS t1;
CREATE TEMPORARY TABLE t1(c0 INT(3),
c1 FLOAT,
c2 DOUBLE NOT NULL,
c3 CHAR(10) DEFAULT 'A',
c4 CHAR(10) GENERATED ALWAYS AS (UPPER(c3)) VIRTUAL COMMENT '字符串生成列',
c5 INT GENERATED ALWAYS AS (c0*2) STORED COMMENT '数值生成列',
c6 TIME);
INSERT INTO t1(c0,c1,c2,c3,c6) VALUES(1,1.0,1.1,'','11:11:11'),
(2,1.1,1.2,'a','11:11:11'),
(3,1.2,2.2,'b','11:11:11'),
(4,1.3,3.2,'c','11:11:11'),
(5,1.4,4.2,'d','11:11:11');
COMMIT;
BEGIN;
ROLLBACK;
