#ON DELETE RESTRICT
DROP TABLE IF EXISTS t2;
DROP TABLE IF EXISTS t1;
CREATE TABLE t1(c0 INT(4) PRIMARY KEY,
c1 FLOAT UNIQUE,
c2 DOUBLE,
c3 CHAR(10),
c4 CHAR(10),
c5 INT,
c6 TIME);
