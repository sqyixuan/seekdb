#在生成列上创建全局/局部索引,然后修改列
DROP TABLE IF EXISTS t1;
CREATE TABLE t1(c0 INT(3),
c1 FLOAT,
c2 DOUBLE NOT NULL,
c3 CHAR(10) DEFAULT 'A',
c4 CHAR(10) AS (UPPER(c3)) VIRTUAL COMMENT '字符串生成列',
c5 INT AS (c0*2) STORED COMMENT '数值生成列',
c6 TIME);
INSERT INTO t1(c0,c1,c2,c3,c6) VALUES(1,1.0,1.1,'','11:11:11'),
(2,1.1,1.2,'a','11:11:11'),
(3,1.2,2.2,'b','11:11:11'),
(4,1.3,3.2,'c','11:11:11'),
(5,1.4,4.2,'d','11:11:11');
CREATE INDEX global_ind ON t1(c5) GLOBAL
PARTITION BY RANGE(c5)
(PARTITION p1 VALUES LESS THAN(5),
PARTITION p2 VALUES LESS THAN(10),
PARTITION p3 VALUES LESS THAN(15)
);
ALTER TABLE t1 CHANGE c5 c5 INT AS (c0*2) STORED COMMENT '数值生成列' AFTER c2;
ALTER TABLE t1 CHANGE c5 m5 INT AS (c0*2) STORED COMMENT '数值生成列';
ALTER TABLE t1 MODIFY m5 INT AS (c0*2) STORED COMMENT '数值生成列' AFTER c2;
ALTER TABLE t1 MODIFY m5 INT AS (c0*2) STORED COMMENT '数值生成列';
ALTER TABLE t1 DROP INDEX global_ind;
CREATE INDEX local_ind ON t1(c4) LOCAL;
ALTER TABLE t1 CHANGE c4 c4 CHAR(10) AS (UPPER(c3)) VIRTUAL COMMENT '字符串生成列' AFTER c2;
ALTER TABLE t1 CHANGE c4 m4 CHAR(10) AS (UPPER(c3)) VIRTUAL COMMENT '字符串生成列';
ALTER TABLE t1 MODIFY c4 CHAR(10) AS (UPPER(c3)) VIRTUAL COMMENT '字符串生成列' BEFORE c2;
ALTER TABLE t1 MODIFY c4 CHAR(10) AS (UPPER(c3)) VIRTUAL COMMENT '字符串生成列';
#OB不支持修改普通列为生成列，所以在修改列上创建全局/局部索引不进行测试
#不支持OB的MySQL模式创建函数索引，故不测试
#创建局部前缀、非前缀索引和全局前缀索引后，执行DDL操作 【OB目前不支持全局非前缀索引，故不测试】
DROP TABLE IF EXISTS t1;
CREATE TABLE t1(c0 INT,
c1 FLOAT ,
c2 DOUBLE,
c3 CHAR(10),
c4 VARCHAR(10),
c5 CHAR(10),
c6 INT,
c7 DATE,
c8 YEAR)
PARTITION BY RANGE COLUMNS(c4)
(PARTITION p1 VALUES LESS THAN('E'),
PARTITION p2 VALUES LESS THAN('J'),
PARTITION p3 VALUES LESS THAN('O'),
PARTITION p4 VALUES LESS THAN(MAXVALUE)
);
