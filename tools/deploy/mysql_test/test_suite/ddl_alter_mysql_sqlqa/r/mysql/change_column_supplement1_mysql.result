purge recyclebin;
DROP TABLE IF EXISTS t2;
DROP TABLE IF EXISTS t1;
#无/有外键约束时，修改列后执行DML操作
CREATE TABLE t1(c0 INT(4) PRIMARY KEY,
c1 FLOAT UNIQUE,
c2 DOUBLE,
c3 CHAR(10),
c4 CHAR(10),
c5 INT,
c6 TIME);
INSERT INTO t1 VALUES(1,1.0,1.1,'中文','',0,'11:11:11'),
(2,1.1,1.2,'中!文','a',1,'11:11:11'),
(3,1.2,2.2,'中!文','a',1,'11:11:11'),
(4,1.3,3.2,'中!文','a',1,'11:11:11'),
(5,1.4,4.2,'中!文','a',1,'11:11:11');
