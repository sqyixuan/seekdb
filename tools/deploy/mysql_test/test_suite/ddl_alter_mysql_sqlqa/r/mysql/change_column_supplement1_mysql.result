(2,1.1,1.2,'AA','a',1,'11:11:11'),
(3,1.2,2.2,'CC','b',2,'11:11:11'),
(4,1.3,3.2,'DD','c',3,'11:11:11'),
(5,1.4,4.2,'EE','d',4,'11:11:11');
ALTER TABLE t1 CHANGE c4 c4 CHAR(10) AS (LOWER(c3)) VIRTUAL COMMENT '字符串生成列' AFTER c2,ADD CONSTRAINT uni_key UNIQUE KEY (c4);
ALTER TABLE t1 CHANGE c4 c4 CHAR(10) AS (LOWER(c3)) STORED COMMENT '字符串生成列' AFTER c2,ADD CONSTRAINT uni_key UNIQUE KEY (c4);
UPDATE t1 SET c3='BB' WHERE c0=2;
ALTER TABLE t1 CHANGE c4 c4 CHAR(10) AS (LOWER(c3)) STORED COMMENT '字符串生成列' AFTER c2,ADD CONSTRAINT uni_key UNIQUE KEY (c4);
ALTER TABLE t1 MODIFY c5 INT(5) ZEROFILL AS (2*c0) STORED COMMENT '数值生成列' AFTER c4,ADD CONSTRAINT uni_key UNIQUE KEY (c5);
ALTER TABLE t1 MODIFY c5 INT(5) ZEROFILL AS (2*c0) STORED COMMENT '数值生成列' AFTER c4,ADD CONSTRAINT uni_key UNIQUE KEY (c5);
#创建生成列，并在生成列上创建全局唯一索引，然后在修改列
DROP TABLE IF EXISTS t1;
CREATE TABLE t1(c0 INT(3),
c1 FLOAT,
c2 DOUBLE NOT NULL,
c3 CHAR(10) DEFAULT 'A',
c4 CHAR(10) AS (UPPER(c3)) VIRTUAL COMMENT '字符串生成列',
c5 INT AS (c0*2) STORED COMMENT '数值生成列',
c6 TIME);
INSERT INTO t1(c0,c1,c2,c3,c6) VALUES(1,1.0,1.1,'','11:11:11'),
(2,1.1,1.2,'a','11:11:11'),
(3,1.2,2.2,'b','11:11:11'),
(4,1.3,3.2,'c','11:11:11'),
(5,1.4,4.2,'d','11:11:11');
CREATE UNIQUE INDEX uni_global ON t1(c4,c5) GLOBAL;
ALTER TABLE t1 CHANGE c5 c5 INT AS (c0*3) VIRTUAL COMMENT '数值生成列' AFTER c3;
ALTER TABLE t1 CHANGE c5 m5 INT AS (c0*2) STORED COMMENT '数值生成列';
ALTER TABLE t1 MODIFY c5 INT AS (c0*2) STORED COMMENT '数值生成列';
ALTER TABLE t1 MODIFY c5 INT AS (c0*3) VIRTUAL COMMENT '数值生成列' AFTER c3;
#在生成列基础上创建局部唯一索引，然后在修改列
ALTER TABLE t1 DROP INDEX uni_global;
CREATE UNIQUE INDEX uni_local ON t1(c4,c5) LOCAL;
ALTER TABLE t1 CHANGE c5 c5 INT AS (c0*3) VIRTUAL COMMENT '数值生成列' AFTER c3;
ALTER TABLE t1 CHANGE c5 m5 INT AS (c0*2) STORED COMMENT '数值生成列';
ALTER TABLE t1 MODIFY c5 INT AS (c0*2) STORED COMMENT '数值生成列';
ALTER TABLE t1 MODIFY c5 INT AS (c0*3) VIRTUAL COMMENT '数值生成列' AFTER c3;
