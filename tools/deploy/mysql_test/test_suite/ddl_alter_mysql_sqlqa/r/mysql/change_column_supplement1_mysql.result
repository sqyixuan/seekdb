ALTER TABLE t2 MODIFY c0 INT AFTER c1,ADD CONSTRAINT fk_c0_c0 FOREIGN KEY(c0) REFERENCES t1(c0) ON DELETE CASCADE;
ALTER TABLE t1 CHANGE c0 m0 INT(4) ZEROFILL;
