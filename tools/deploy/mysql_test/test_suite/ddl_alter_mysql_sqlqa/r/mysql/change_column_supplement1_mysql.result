(7,1.6,6.2,'中!文','F','f',3,'2011-11-01','2006'),
(8,1.7,7.2,'中!文','G','g',1,'2017-01-11','2007'),
(9,1.8,8.2,'中!文','H','h',4,'2013-11-01','2011'),
(10,1.9,9.2,'中!文','I','i',5,'2011-11-11','2013'),
(11,2.0,1.9,'中!文','J','j',6,'2015-01-01','2016'),
(12,2.1,1.8,'中!文','K','k',7,'2012-12-11','2016');
#创建局部前缀索引
CREATE INDEX loc_ind ON t1(c4,c5) LOCAL
PARTITION BY RANGE COLUMNS(c4)
(PARTITION p1 VALUES LESS THAN('E'),
PARTITION p2 VALUES LESS THAN('J'),
PARTITION p3 VALUES LESS THAN('O'),
PARTITION p4 VALUES LESS THAN(MAXVALUE)
);
CREATE INDEX loc_ind ON t1(c4,c5) LOCAL;
