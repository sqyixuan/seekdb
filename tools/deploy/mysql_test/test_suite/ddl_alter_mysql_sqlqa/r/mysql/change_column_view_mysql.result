DROP VIEW IF EXISTS v1;
DROP TABLE IF EXISTS t2;
DROP TABLE IF EXISTS t1;
CREATE TABLE t1(c0 INT(5) PRIMARY KEY,
c1 FLOAT ,
c2 DOUBLE NOT NULL,
c3 CHAR(10) DEFAULT 'A',
c4 VARCHAR(10) UNIQUE,
c5 CHAR(10),
c6 INT,
c7 TIME,
c8 YEAR ,CHECK(c8>=2000));
CREATE TABLE t2(c0 INT(5),
c1 FLOAT,
c2 DOUBLE NOT NULL,
c3 CHAR(10) DEFAULT 'A',
c4 VARCHAR(10) UNIQUE,
c5 CHAR(10),
c6 INT,
c7 TIME,
c8 YEAR ,CHECK(c8>=2000),
CONSTRAINT fk_c0_c0 FOREIGN KEY(c0) REFERENCES t1(c0));
