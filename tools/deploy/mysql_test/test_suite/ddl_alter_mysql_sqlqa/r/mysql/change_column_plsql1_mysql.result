DROP TRIGGER IF EXISTS trg_update;
CREATE TRIGGER trg_update BEFORE UPDATE ON t2
FOR EACH ROW
BEGIN
UPDATE t1 SET c1=NEW.c1,c2=NEW.c2,c4=CONCAT(NEW.c4,'A') WHERE c6=NEW.c5;
END
