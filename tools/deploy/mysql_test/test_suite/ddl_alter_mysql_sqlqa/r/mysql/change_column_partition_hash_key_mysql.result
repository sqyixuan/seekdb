#######################PARTITION BY KEY#########################
#普通KEY分区表
DROP TABLE IF EXISTS t1;
CREATE TABLE t1(c0 INT,
c1 FLOAT ,
c2 DOUBLE,
c3 CHAR(10),
c4 VARCHAR(10),
c5 CHAR(10),
c6 INT,
c7 DATE,
c8 YEAR)
PARTITION BY KEY(c8) PARTITIONS 3;
INSERT INTO t1 VALUES(1,1.0,1.1,'中文','','',0,'2010-10-11','1989'),
(2,1.1,1.2,'中!文','A','a',1,'2001-01-11','2001'),
