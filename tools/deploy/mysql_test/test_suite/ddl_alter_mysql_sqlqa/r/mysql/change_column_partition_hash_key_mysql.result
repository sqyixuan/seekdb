#分区键带有非空约束
DROP TABLE IF EXISTS t1;
CREATE TABLE t1(c0 INT NOT NULL,
c1 FLOAT DEFAULT 0,
c2 DOUBLE,
c3 CHAR(10),
c4 VARCHAR(10),
c5 CHAR(10),
c6 INT,
c7 DATE,
c8 YEAR )
PARTITION BY HASH(c8)
(PARTITION p1,PARTITION p2,PARTITION p3);
