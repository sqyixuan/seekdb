#owner: sean.yyj
#owner group: sqlqa
#description: 密码复杂度验证 mysql
#tags: default_value
#author:wb-cf587006

set global validate_password_check_user_name = off;
set global validate_password_mixed_case_count=0;
set global validate_password_number_count=0;
set global validate_password_policy =0;
set global validate_password_special_char_count=0;
set global validate_password_length = 8;

--disable_warnings
--disable_result_log
--error 0,1396
drop user test11;
--enable_result_log
create user 'test11' identified by '12345678';
grant all on *.* to test11;
--replace_regex /[0-9]{1,3}.[0-9]{1,3}.[0-9]{1,3}.[0-9]{1,3}/127.0.0.1/g
select user();
--source mysql_test/include/check_schema_sync.inc
connect (conn1,$OBMYSQL_MS0,test11,'12345678',*NO-ONE*,$OBMYSQL_PORT);
connection conn1;
--replace_regex /@[0-9]{1,3}.[0-9]{1,3}.[0-9]{1,3}.[0-9]{1,3}/@127.0.0.1/g
select user();
SHOW VARIABLES LIKE 'validate_password%';
disconnect conn1;
connection default;
--replace_regex /[0-9]{1,3}.[0-9]{1,3}.[0-9]{1,3}.[0-9]{1,3}/127.0.0.1/g
select user();

set global validate_password_policy =0;
--source mysql_test/include/check_schema_sync.inc
connect (conn1,$OBMYSQL_MS0,test11,'12345678',*NO-ONE*,$OBMYSQL_PORT);
connection conn1;
SHOW VARIABLES LIKE 'validate_password_policy%';
disconnect conn1;
connection default;
--replace_regex /[0-9]{1,3}.[0-9]{1,3}.[0-9]{1,3}.[0-9]{1,3}/127.0.0.1/g
select user();

set global validate_password_policy =1;
--source mysql_test/include/check_schema_sync.inc
connect (conn1,$OBMYSQL_MS0,test11,'12345678',*NO-ONE*,$OBMYSQL_PORT);
connection conn1;
SHOW VARIABLES LIKE 'validate_password_policy%';
disconnect conn1;
connection default;
--replace_regex /[0-9]{1,3}.[0-9]{1,3}.[0-9]{1,3}.[0-9]{1,3}/127.0.0.1/g
select user();

