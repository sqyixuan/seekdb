a tinyint,a1 smallint,a2 mediumint,a3 int,a4 bigint,a5 float,a6 double,
b char(20),b1 varchar(20),b2 tinytext,b3 text, b4 mediumtext, b5 mediumtext,
c date,c1 time,c2 datetime,c3 timestamp
);
