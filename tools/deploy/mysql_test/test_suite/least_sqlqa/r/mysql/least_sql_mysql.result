DROP TABLE t1;
CREATE TABLE t1(id int PRIMARY KEY,consumer char(20) NOT NULL, price varchar(20),sal int  ,datetime1 DATE,datetime2 bigint,CONSTRAINT t1_name_uk UNIQUE(price));
