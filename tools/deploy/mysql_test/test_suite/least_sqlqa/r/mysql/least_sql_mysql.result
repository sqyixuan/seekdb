DROP TABLE t1;
CREATE TABLE t1(id int,consumer char(20), price varchar(20),sal int,datetime1 DATE,datetime2 bigint);
INSERT INTO t1 VALUES(1,'书局','7000',5000,'2020-09-22',20200923121200);
INSERT INTO t1 VALUES(2,'微山','3000',4000,'2020-09-21',20200921101159);
INSERT INTO t1 VALUES(3,'深咖','5000',3000,'2020-08-21',20190821101159);
INSERT INTO t1 VALUES(4,'流苏','9111',10000,'2020-02-29',20200228101159);
CREATE INDEX index_test ON t1(sal);
CREATE INDEX index_test1 ON t1(price);
CREATE INDEX index_test2 ON t1(consumer);
CREATE INDEX index_test3 ON t1(datetime1);
CREATE INDEX index_test4 ON t1(datetime2);
SELECT LEAST(consumer,datetime1,datetime2)name,LEAST(price,sal)sal FROM t1;
name	sal
0	5000
0	3000
0	3000
0	9111
SELECT id,consumer,LEAST(price,sal) FROM t1 WHERE LEAST(price,sal) = 5000 ORDER BY id DESC;
id	consumer	LEAST(price,sal)
1	书局	5000
SELECT id,consumer,LEAST(price,sal) FROM t1 WHERE LEAST(price,sal) > 5000 ORDER BY LEAST(price,sal);
id	consumer	LEAST(price,sal)
4	流苏	9111
SELECT id,SUM(LEAST(price,sal)) FROM t1 WHERE  LEAST(price,sal) > 5000 GROUP BY id HAVING SUM(LEAST(price,sal)) > 5000 ORDER BY id;
id	SUM(LEAST(price,sal))
4	9111
UPDATE t1 SET sal = LEAST(1000,5665,9000,7000) WHERE LEAST(price,sal) = 5000 ;
SELECT sal FROM t1 order by sal;
sal
1000
3000
4000
10000
