INSERT INTO t1 VALUES(2,'微山','3000',4000,'2020-09-21 10:11:59',20200921101159);
INSERT INTO t1 VALUES(3,'深咖','5000',3000,'2020-08-21 10:11:59',20190821101159);
INSERT INTO t1 VALUES(4,'流苏','9111',10000,'2020-02-29 10:11:59',20200228101159);
