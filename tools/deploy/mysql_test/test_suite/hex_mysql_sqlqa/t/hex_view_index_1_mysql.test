--echo   #hex-5-1-2    select
set sql_mode='';
--error 0,1051
DROP TABLE hj_test;
--error 0,1051
DROP view view_1;
CREATE TABLE hj_test(c1 int,c2 int,c3 int,c4 int);
CREATE view view_1 as SELECT * from hj_test;
--error 0,1305
drop procedure procedure_1;
delimiter /;
CREATE PROCEDURE procedure_1()
BEGIN
DECLARE i INT DEFAULT 1;
WHILE i < 6000 DO
INSERT INTO view_1 VALUES (hex(315) + i, hex(0) + i, hex(NULL) + i, hex(120) + hex(0.120) + i);
SET i = i + 1;
END WHILE;
COMMIT;
END/
delimiter ;/
call procedure_1();
SELECT * FROM view_1 ORDER BY c2 asc;

drop procedure procedure_1;
delimiter /;
CREATE PROCEDURE procedure_1()
BEGIN
DECLARE i INT DEFAULT 1;
WHILE i < hex(6001) DO
INSERT INTO view_1 values((select hex(315)+i from dual),(select hex(0) from dual)+i,(select hex(null) from dual)+i,(select hex(120)+hex(0.120) from dual)+i);
SET i = i + 1;
END WHILE;
COMMIT;
END /
delimiter ;/
call procedure_1();
SELECT * FROM view_1 ORDER BY c2 asc;

drop procedure procedure_1;
delimiter /;
CREATE PROCEDURE procedure_1()
BEGIN
DECLARE i INT DEFAULT 1;
WHILE i < 6001 DO
INSERT INTO view_1 values((select hex(315)+i from dual),(select hex(0) from dual)+i,(select hex(null) from dual)+i,(select hex(120)+hex(0.120) from dual)+i);
SET i = i + 1;
END WHILE;
COMMIT;
END/
delimiter ;/
call procedure_1();
SELECT * FROM view_1 ORDER BY c1 asc;


SELECT * FROM view_1 WHERE c4=hex(c1);
SELECT * FROM view_1 WHERE c1=(SELECT hex(315) FROM dual)+21;
SELECT * FROM view_1 WHERE c1=(SELECT hex(320) FROM dual) AND (SELECT hex(500) FROM dual);
SELECT * FROM view_1 WHERE c1=(SELECT hex(320) FROM dual) or (SELECT hex(500) FROM dual);

SELECT * FROM view_1 ORDER BY hex(c1) desc;
SELECT * FROM view_1 GROUP BY hex(c3);
SELECT * FROM view_1 GROUP BY (select hex(c3) from view_1 LIMIT 1) asc ;
SELECT * FROM view_1 GROUP BY hex(c2);
SELECT * FROM view_1 GROUP BY hex(c2) ORDER BY hex(c1) desc;
SELECT * FROM view_1 WHERE c4=599 AND c2=577 OR c1=590 GROUP BY c1 ORDER BY hex(c1) DESC;
SELECT * FROM view_1 WHERE c4=599 AND c2=577 OR c1=590 ORDER BY hex(c1) DESC;
SELECT * FROM view_1 WHERE c4=599 AND c2=577 OR c1=590 ORDER BY hex(c1) DESC;
SELECT distinct(hex(c1)) FROM view_1 WHERE c4=599 AND c2=577 OR c1=590 ORDER BY hex(c1) DESC;
SELECT distinct(hex(null)) FROM view_1 WHERE c4=599 AND c2=577 OR c1=590 ORDER BY hex(c1) DESC;
SELECT distinct(hex(0)) FROM view_1 WHERE c4=599 AND c2=577 OR c1=590 ORDER BY hex(c1) DESC;
--disable_warnings
SELECT distinct(hex(315))+20 FROM view_1 WHERE c4=599 AND c2=577 OR c1=590 ORDER BY hex(c1) DESC;
--enable_warnings

