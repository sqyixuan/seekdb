WHEN hex(600) THEN hex(null)
WHEN hex(400) THEN hex(0)
ELSE hex(550) END FROM view_1;

SELECT CASE c1
WHEN 300 THEN hex(999)+21
WHEN 400 THEN hex(200)
ELSE hex(0) END FROM view_1;

SELECT CASE c1
WHEN 300 THEN hex(999)+21
WHEN 400 THEN hex(200)
ELSE hex(0) END FROM view_1;


SELECT * FROM view_1 WHERE c1=(SELECT c4 FROM view_1 WHERE c4=300 LIMIT 1);
SELECT * FROM view_1 WHERE c1=(SELECT c4 FROM view_1 WHERE c4=(select hex(500) from view_1 LIMIT 1) LIMIT 1);
SELECT * FROM view_1 WHERE c1=(SELECT c4 FROM view_1 WHERE c4=(select hex(500) from view_1 LIMIT 1) AND c4=300);
SELECT * FROM view_1 WHERE c1=(SELECT c4 FROM view_1 WHERE c4=(select hex(500) from view_1 LIMIT 1) or c4=300 order by c4 asc LIMIT 1) ;
SELECT * FROM view_1 WHERE c1=(SELECT c4 FROM view_1 WHERE c4=(select hex(500) from view_1 LIMIT 1) or c4=300 order by c4 desc LIMIT 1) ;

SELECT * FROM view_1 WHERE c1=(SELECT c4 FROM view_1 WHERE c4=(select hex(0) from view_1 LIMIT 1) OR (select hex(500) from view_1 LIMIT 1) and c4=300 LIMIT 1);

SELECT * FROM view_1 WHERE exists (SELECT c4 FROM view_1 WHERE c4=(select hex(500) from view_1 LIMIT 1) and c4=300 LIMIT 1);
SELECT * FROM view_1 WHERE NOT exists (SELECT c4 FROM view_1 WHERE c4=(select hex(500) from view_1 LIMIT 1) and c4=300 LIMIT 1);
SELECT * FROM view_1 WHERE NOT exists (SELECT c4 FROM view_1 WHERE exists(SELECT hex(c3) FROM view_1 WHERE c3=300 LIMIT 1) LIMIT 1);
