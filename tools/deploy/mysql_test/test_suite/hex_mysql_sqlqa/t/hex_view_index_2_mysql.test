create user hjw identified by 'hjw';
grant all on *.* to hjw WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,hjw,hjw,test,$OBMYSQL_PORT);



--echo   #hex-8  视图/约束/索引



--echo   #hex-8-2  约束
--echo   #主键   PRIMARY key
--error 0,1051
drop table hj_test;
CREATE table hj_test(c1 varchar(50) PRIMARY KEY,c2 bigint,c3 bigint);
insert into hj_test values((select hex(2222) from dual),123,333);
insert into hj_test values((select hex(3333) from dual),234,555);
--error 0,1062
insert into hj_test values((select hex(2222) from dual),456,666);
insert into hj_test values((select hex(6666) from dual),567,877);
select c1,c2,c3 from hj_test order by c1 asc;
--error 0,1048
insert into hj_test values((select hex(null) from dual),567,877);
insert into hj_test values((select hex(0) from dual),567,877);
select c1,c2,c3 from hj_test order by c1 asc;
--error 0,1292
update hj_test set c1=(select hex(2222) from dual) where c1=0;
--error 0,1292
update hj_test set c1=(select hex(2233) from dual) where c1=0;
select c1,c2,c3 from hj_test order by c1 asc;
DELETE FROM hj_test where c1=(select hex(2222) from dual);
select c1,c2,c3 from hj_test order by c1 asc;





--echo   #非空  not null
--error 0,1051
drop table hj_test;
create table hj_test(c1 varchar(100) UNIQUE KEY not null,c2 int not null check(c2>=20 and c2 <=500));
insert into hj_test values(4243,20);
insert into hj_test values(64363,30);
insert into hj_test values(141,50);
insert into hj_test values(522,350);
insert into hj_test values(6464,499);
select c1,c2 from hj_test order by c1 asc;
--error 0,1048
insert into hj_test values(null,null);
--error 0,1048
insert into hj_test values(123,null);
--error 0,1048
insert into hj_test values(null,0);
select c1,c2 from hj_test where c1=(select hex(null) from dual);
--error 0,1048
insert into hj_test values((select hex(null) from dual),(select hex(0) from dual));



--echo   #唯一  unique
--error 0,1051
drop table hj_test;
create table hj_test(c1 varchar(100) UNIQUE KEY,c2 bigint UNIQUE);
insert into hj_test values(40,20);
--error 0,1265
insert into hj_test values((select hex(20)+hex(20) from dual),(select hex(30)-hex(10) from dual));
--error 0,1265
insert into hj_test values((select hex(30)+hex(20) from dual),(select hex(30)-hex(100) from dual));
--error 0,1265
insert into hj_test values((select hex(70)+hex(20) from dual),(select hex(130)-hex(30) from dual));
select c1,c2 from hj_test order by c1 asc;
--error 0,1062
insert into hj_test values((select hex(70)+hex(20) from dual),(select hex(130)-hex(30) from dual));
insert into hj_test values((select hex(null) from dual),(select hex(null) from dual));
insert into hj_test values((select hex(null) from dual),(select hex(null) from dual));
select c1,c2 from hj_test order by c1 asc;
insert into hj_test values(null,null);
select c1,c2 from hj_test order by c1 asc;
--error 0,1062
insert into hj_test values(40,30);
--error 0,1054
insert into hj_test values((select hex(c1) from dual),(select hex(c2) from dual));
--error 0,1054
insert into hj_test values((select hex(c2) from dual),(select hex(c1) from dual));


--echo   #范围   check
--error 0,1051
drop table hj_test;
--error 0,1064
create table hj_test(c1 bigint,c2 bigint,CHECK(c1>hex(20),c2<hex(300)));
create table hj_test(c1 bigint,c2 bigint,CHECK(c1>hex(20) and c2<hex(21329)));
