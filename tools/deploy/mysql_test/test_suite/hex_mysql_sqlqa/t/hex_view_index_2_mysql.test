insert into hj_test values((select hex(55) from dual),(select hex(399) from dual));
insert into hj_test values((select hex(55) from dual),(select hex(10000) from dual));
select c1,c2 from hj_test order by c1 asc;
drop table hj_test;
--error 0,5694
create table hj_test(c1 bigint,c2 bigint,CHECK(c1>hex(20) or c2<hex(300)));
drop table hj_test;
