INSERT INTO test2 values((select hex(640) from dual),(select hex(490) from dual));
--error 0,1265
INSERT INTO test2 values((select hex(640) from dual),(select hex(490) from dual));
SELECT * FROM test2 ORDER BY c1 asc;
