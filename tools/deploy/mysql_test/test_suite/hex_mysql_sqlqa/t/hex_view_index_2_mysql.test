--echo   #主键+notnull+unique+check
--error 0,1051
drop table hj_test;
create table hj_test(c1 bigint PRIMARY key UNIQUE key not null CHECK(c1>50),c2 bigint UNIQUE key not null CHECK(c2<500));
--error 0,1048
insert into hj_test values((select hex(null) from dual),(select hex(0) from dual));
--error 0,3819
insert into hj_test values((select hex(66) from dual),(select hex(88) from dual));
--error 0,3819
insert into hj_test values((select hex(66) from dual),(select hex(88) from dual));
--error 0,1062
insert into hj_test values((select hex(33) from dual)+33,(select hex(88) from dual));
select c1,c2 from hj_test order by c1 asc;
--error 0,1062
insert into hj_test values((select hex(10000) from dual)+33,(select hex(88) from dual));
select c1,c2 from hj_test order by c1 asc;



--echo   #外键约束  foreign key
--error 0,1051
DROP TABLE test2;
--error 0,1051
DROP TABLE test1;

CREATE TABLE test1
(c1 int,c2 int,
CONSTRAINT CONSTRAINT_1 PRIMARY KEY (c1)
);

CREATE TABLE test2
(c1 int,c2 int,
CONSTRAINT CONSTRAINT_2 FOREIGN KEY (c1) REFERENCES test1(c1)
);

--error 0,1265
INSERT INTO test1 values((select hex(640) from dual),(select hex(490) from dual));
SELECT * FROM test1 ORDER BY c1 asc;
