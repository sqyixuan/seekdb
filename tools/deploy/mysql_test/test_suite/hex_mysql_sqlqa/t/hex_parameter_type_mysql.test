--echo #Environmental cleaning
--disable_warnings
--enable_warnings
--error 0,1396
drop user hjw@'%';
--enable_warnings
create user hjw identified by 'hjw';
grant all on *.* to hjw WITH GRANT OPTION;
--source mysql_test/include/check_schema_sync.inc
connect (conn,$OBMYSQL_MS0,hjw,hjw,test,$OBMYSQL_PORT);


--echo   #hex-1  参数个数
--echo   #hex-2  参数类型




--echo   #hex-1  参数个数======>参数为一个/多个/无参/边界
select hex(545641354) from dual;
--error 0,1582
select hex(545641354,45454,1021,0.5456) from dual;
--error 0,1582
select hex(0.5456,54564) from dual;
--error 0,1582
select hex() from dual;
select hex(5456645630132413534) from dual;
select hex(54566456301324135364) from dual;     #此处与5.7一致，8.0结果不一致
select hex(545664565456456464874156745132145145321431364102132228888888888888822222222222222222222222222222555599555555555555555515123213013241354) from dual;
--error 0,1264
select hex(5456645654564564564874156745132145145321431364102132228888888888888822222222222222222222222222222555599555555555555555515123213013241354) from dual;
select hex('5456645654564564564874156745132145145321431364102999999999145651514564564561456132132134894512348974999999999999999999999999999132228888888888888822222222222222222222222222222555599555555555555555515123213013241354') from dual;
select hex("545664565456456456487415674513214514532143136410213222888888888888156145614564565612456135745610654597461532034531688222222222222222222222222222225555995555555555555555151232130132413545555555555555515123213013241354") from dual;
select hex('2023-12-01')+545664565456456464874156745132145145321431364102132228888888888888822222222222222222222222222222555599555555555555555515123213013241354 from dual;






--echo   #hex-2  参数类型
--echo   #hex-2  参数类型======>参数为数字
select hex(1564511) from dual;
select hex(0) from dual;
select hex(null) from dual;
select hex(0.456456435) from dual;
select hex(9999999.91) from dual;
select hex(-152321564511) from dual;
select hex(FALSE) from dual;
select hex(true) from dual;

--echo   #hex-2  参数类型======>参数为组合
--error 0,1054
select hex(1564511hi是反日无法) from dual;
--error 0,1054
select hex(1564511hijhisfd) from dual;
--error 0,1054
select hex(1564511h321ijhisfd21321) from dual;
--error 0,1054
select hex(1564511汗啊汗啊汗啊范德萨) from dual;
--error 0,1054
select hex(jdfwgw汗啊汗啊汗啊范德萨) from dual;
select hex('jdfwgw汗啊汗啊汗啊范德萨') from dual;
select hex("jdfwgw汗啊汗啊汗啊范德萨") from dual;


--echo   #hex-2  参数类型======>参数为字母
--error 0,1054
select hex(shifwhiwbgwgw) from dual;
--error 0,1054
select hex( shifwhiwbgwgw ) from dual;
select hex('shifwhiwbgwgw') from dual;
select hex(' shifwhiwbgwgw') from dual;
select hex(' SHIFWHWIGWBGRWGRWGW') from dual;
select hex(' sjgwJDOGFW WGR') from dual;
select hex(' shifwhiwbgwgw ') from dual;
select hex('shifwhiwbgwgw ') from dual;
select hex('shifwhi  wbg  wgw ') from dual;
select hex('shifwhi||wbg||wgw ') from dual;
select hex('shifwhi&wbg||wgw ') from dual;
select hex("shifwhi&wbg||wgw ") from dual;



--echo   #hex-2  参数类型======>参数为汉字
--error 0,1054
select hex(身份地位i公认为) from dual;
select hex('身份地位i公认为') from dual;
select hex("身份地位i公认为") from dual;
--error 0,1054
select hex(🏀) from dual;
select hex('🏀') from dual;
select hex('⚽') from dual;
--error 0,1054
select hex(⚽) from dual;
select hex('身份 地位i公认	为') from dual;
select hex('身份 地     位i公认	为') from dual;
select hex('nulls') from dual;
select hex('null') from dual;


