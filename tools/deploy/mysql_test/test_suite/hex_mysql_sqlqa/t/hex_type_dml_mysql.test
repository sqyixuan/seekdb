--echo   #hex-6-1   静态sql
--echo   #静态sql======>insert
--error 0,1051
DROP TABLE hj_test;
CREATE TABLE hj_test(c1 bigint,c2 bigint,c3 bigint,c4 bigint);
INSERT INTO hj_test values(hex(3),hex(0),hex(null),hex(120)+hex(120));
INSERT INTO hj_test values(
(SELECT hex(5) from dual),
(select hex(0) from dual),
(select hex(null) from dual),
(select hex(1.20) from dual));
select * from hj_test order by c1, c2, c3, c4 asc;
set sql_mode = '';
INSERT INTO hj_test values(
(SELECT hex(111)*3 FROM DUAL),
(SELECT hex(555)-3 FROM DUAL),
(SELECT hex(666)+2 FROM DUAL),
(SELECT hex(777)+hex(20.5) FROM DUAL));
INSERT INTO hj_test SELECT c1,c2,c3,c4 FROM hj_test;
SELECT * FROM hj_test ORDER BY c1, c2, c3, c4 asc;
insert into hj_test select * from hj_test;
SELECT * FROM hj_test ORDER BY c1, c2, c3, c4 asc;
insert into hj_test select hex(c1),hex(c2),hex(c3),hex(c4) from hj_test;
insert into hj_test select hex(c1)+154,hex(c2)-545,hex(c3)*21,hex(c4)/54 from hj_test;
SELECT * FROM hj_test ORDER BY c1, c2, c3, c4 asc;
INSERT INTO hj_test VALUES (hex(315), hex(0), hex(NULL), hex(120)+ hex(0.120));


--echo   #静态sql======>select
--error 0,1051
DROP TABLE hj_test;
CREATE TABLE hj_test(c1 bigint,c2 bigint,c3 bigint,c4 bigint);
--error 0,1305
drop procedure procedure_1;
delimiter /;
CREATE PROCEDURE procedure_1()
BEGIN
DECLARE i INT DEFAULT 1;
WHILE i < 6000 DO
INSERT INTO hj_test VALUES (abs(315) + i, abs(0) + i, abs(NULL) + i, abs(120) + abs(0.120) + i);
SET i = i + 1;
END WHILE;
COMMIT;
END/
delimiter ;/
call procedure_1();
select * from hj_test order by c1, c2, c3, c4 asc;
drop procedure procedure_1;
delimiter /;
CREATE PROCEDURE procedure_1()
BEGIN
DECLARE i INT DEFAULT 1;
WHILE i < hex(6001) DO
INSERT INTO hj_test values((select hex(315)+i from dual),(select hex(0) from dual)+i,(select hex(null) from dual)+i,(select hex(120)+hex(0.120) from dual)+i);
SET i = i + 1;
END WHILE;
COMMIT;
END/
delimiter ;/
call procedure_1();
select * from hj_test order by c1, c2, c3, c4 asc;
drop procedure procedure_1;
delimiter /;
CREATE PROCEDURE procedure_1()
BEGIN
DECLARE i INT DEFAULT 1;
WHILE i < 6001 DO
INSERT INTO hj_test values((select hex(315)+i from dual),(select hex(0) from dual)+i,(select hex(null) from dual)+i,(select hex(120)+hex(0.120) from dual)+i);
SET i = i + 1;
END WHILE;
COMMIT;
END/
delimiter ;/
call procedure_1();
select * from hj_test order by c1, c2, c3, c4 asc;

SELECT * FROM hj_test WHERE c4=hex(c1);
SELECT * FROM hj_test WHERE c1=(SELECT hex(315) FROM dual)+21;
SELECT * FROM hj_test WHERE c1=(SELECT hex(320) FROM dual) AND (SELECT hex(500) FROM dual);
SELECT * FROM hj_test WHERE c1=(SELECT hex(320) FROM dual) or (SELECT hex(500) FROM dual);

SELECT * FROM hj_test ORDER BY hex(c1) desc;
SELECT * FROM hj_test ORDER BY hex(c3) asc;
SELECT * FROM hj_test GROUP BY hex(c3);
SELECT * FROM hj_test GROUP BY hex(c2);
SELECT * FROM hj_test GROUP BY hex(c2) ORDER BY hex(c1) desc;
SELECT * FROM hj_test WHERE c4=599 AND c2=577 OR c1=590 GROUP BY c1 ORDER BY hex(c1) DESC;
SELECT * FROM hj_test WHERE c4=599 AND c2=577 OR c1=590 ORDER BY hex(c1) DESC;
SELECT * FROM hj_test WHERE c4=599 AND c2=577 OR c1=590 ORDER BY hex(c1) DESC;
SELECT distinct(hex(c1)) FROM hj_test WHERE c4=599 AND c2=577 OR c1=590 ORDER BY hex(c1) DESC;
SELECT distinct(hex(null)) FROM hj_test WHERE c4=599 AND c2=577 OR c1=590 ORDER BY hex(c1) DESC;
SELECT distinct(hex(0)) FROM hj_test WHERE c4=599 AND c2=577 OR c1=590 ORDER BY hex(c1) DESC;
SELECT distinct(hex(315))+20 FROM hj_test WHERE c4=599 AND c2=577 OR c1=590 ORDER BY hex(c1) DESC;

SELECT CASE c1
WHEN 300 THEN hex(999)
WHEN 400 THEN hex(200)
ELSE hex(0) END FROM hj_test;

SELECT CASE c4
WHEN 600 THEN hex(null)
WHEN 400 THEN hex(0)
ELSE hex(550) END FROM hj_test;

SELECT CASE hex(c4)
WHEN hex(600) THEN hex(null)
WHEN hex(400) THEN hex(0)
ELSE hex(550) END FROM hj_test;

SELECT CASE c1
WHEN 300 THEN hex(999)+21
WHEN 400 THEN hex(200)
ELSE hex(0) END FROM hj_test;

SELECT CASE c1
WHEN 300 THEN hex(999)+21
WHEN 400 THEN hex(200)
ELSE hex(0) END FROM hj_test;

SELECT * FROM hj_test WHERE c1=(SELECT c4 FROM hj_test WHERE c4=300 LIMIT 1);
SELECT * FROM hj_test WHERE c1=(SELECT c4 FROM hj_test WHERE c4=(select hex(500) from hj_test LIMIT 1));
SELECT * FROM hj_test WHERE c1=(SELECT c4 FROM hj_test WHERE c4=(select hex(500) from hj_test LIMIT 1) AND c4=300);
SELECT * FROM hj_test WHERE c1=(SELECT c4 FROM hj_test WHERE c4=(select hex(500) from hj_test LIMIT 1) or c4=300 order by c4 asc LIMIT 1) ;
SELECT * FROM hj_test WHERE c1=(SELECT c4 FROM hj_test WHERE c4=(select hex(500) from hj_test LIMIT 1) or c4=300 order by c4 desc LIMIT 1) ;
SELECT * FROM hj_test WHERE c1=(SELECT c4 FROM hj_test WHERE c4=(select hex(0) from hj_test LIMIT 1) OR (select hex(500) from hj_test LIMIT 1) and c4=300 LIMIT 1);

SELECT * FROM hj_test WHERE exists (SELECT c4 FROM hj_test WHERE c4=(select hex(500) from hj_test LIMIT 1) and c4=300 LIMIT 1);
SELECT * FROM hj_test WHERE NOT exists (SELECT c4 FROM hj_test WHERE c4=(select hex(500) from hj_test limit 1) and c4=300 limit 1);
SELECT * FROM hj_test WHERE NOT exists (SELECT c4 FROM hj_test WHERE exists(SELECT hex(c3) FROM hj_test WHERE c3=300 limit 1));


SELECT * FROM hj_test WHERE c2 in (SELECT c4 FROM hj_test WHERE c4=(select hex(500) from hj_test LIMIT 1) and c4=300);
SELECT * FROM hj_test WHERE c2 NOT in (SELECT c4 FROM hj_test WHERE exists(SELECT hex(c3) FROM hj_test WHERE c3=300));
SELECT * FROM hj_test WHERE c2 NOT in (SELECT hex(c3) FROM hj_test);

#SELECT * FROM hj_test WHERE c2 >any(SELECT hex(c3) FROM hj_test);
#SELECT * FROM hj_test WHERE c2 <any(SELECT hex(c3) FROM hj_test);
SELECT * FROM hj_test WHERE c2 =any(SELECT hex(c3) FROM hj_test);
SELECT * FROM hj_test WHERE (SELECT hex(c3) FROM hj_test LIMIT 1) =any(SELECT hex(c3) FROM hj_test LIMIT 1);

SELECT * FROM hj_test WHERE c2 >all(SELECT hex(c3) FROM hj_test);
SELECT * FROM hj_test WHERE c2 <all(SELECT hex(c3) FROM hj_test);
SELECT * FROM hj_test WHERE c2 =all(SELECT hex(c3) FROM hj_test);
SELECT * FROM hj_test WHERE hex(c3) =all(SELECT hex(c3) FROM hj_test);

#SELECT * FROM hj_test WHERE c2 >some(SELECT hex(c3) FROM hj_test);
#SELECT * FROM hj_test WHERE c2 <some(SELECT hex(c3) FROM hj_test);
SELECT * FROM hj_test WHERE c2 =some(SELECT hex(c3) FROM hj_test);
SELECT * FROM hj_test WHERE hex(c3) =some(SELECT hex(c3) FROM hj_test);
SELECT * FROM hj_test WHERE c2 =(SELECT c2 FROM hj_test WHERE c2=hex(250000) LIMIT 1);


