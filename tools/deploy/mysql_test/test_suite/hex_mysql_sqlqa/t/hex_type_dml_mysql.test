select * from test1 right JOIN test2 on test1.c4=test2.c4 where hex(test1.c1=test1.c2) or hex(test2.c2=test2.c2) and hex(test1.c1=test2.c3);
select * from test1 right JOIN test2 on test1.c4=test2.c4 group by hex(test1.c4) order by test1.c4 asc;
select * from test1 right JOIN test2 on test1.c4=test2.c4 group by hex(test1.c4) having hex(test1.c4) order by test1.c4 asc;
select * from test1 right JOIN test2 on test1.c4=test2.c4 group by hex(test1.c4) having hex(test1.c4) order by hex(test1.c4) asc;
select * from test1 right JOIN test2 on test1.c4=test2.c4 like '%hex(test1.c2)%' order by test1.c4 asc;
