select * from test1 right JOIN test2 on test1.c4=test2.c4 order by hex(test1.c4) asc;
select * from test1 right JOIN test2 on test1.c4=test2.c4 order by hex(test1.c1) asc;
select * from test1 right JOIN test2 on test1.c4=test2.c4 not in(test1.c1,test1.c2,test1.c3,test1.c4,test2.c1,test2.c2,test2.c3,test2.c4) order by hex(test1.c1) asc;
select * from test1 right JOIN test2 on test1.c4=test2.c4 in(test1.c1,test1.c2,test1.c3,test1.c4,test2.c1,test2.c2,test2.c3,test2.c4) order by hex(test1.c1) asc;


--echo   #多表联查======>内连接
select * from test1 inner JOIN test2 on test1.c4=test2.c4 where test1.c1=hex(test1.c2) and test2.c2=hex(test1.c2);
select * from test1 inner JOIN test2 on test1.c4=test2.c4 where test1.c1=hex(test1.c1) and test2.c2=hex(test2.c2);
select * from test1 inner JOIN test2 on test1.c4=test2.c4 where test1.c1=test1.c1 and test2.c2=test2.c2;
select * from test1 inner JOIN test2 on test1.c4=test2.c4 where test1.c1=test1.c2 and test2.c2=test2.c2;
select * from test1 inner JOIN test2 on test1.c4=test2.c4 where test1.c1=test1.c2 or test2.c2=test2.c2;
select * from test1 inner JOIN test2 on test1.c4=test2.c4 where test1.c1=test1.c2 or test2.c2=test2.c2 and test1.c1=test2.c3;
select * from test1 inner JOIN test2 on test1.c4=test2.c4 where hex(test1.c1=test1.c2) or hex(test2.c2=test2.c2) and hex(test1.c1=test2.c3);
select * from test1 inner JOIN test2 on test1.c4=test2.c4 group by hex(test1.c4) order by test1.c4 asc;
select * from test1 inner JOIN test2 on test1.c4=test2.c4 group by hex(test1.c4) having hex(test1.c4) order by test1.c4 asc;
select * from test1 inner JOIN test2 on test1.c4=test2.c4 group by hex(test1.c4) having hex(test1.c4) order by hex(test1.c4) asc;
select * from test1 inner JOIN test2 on test1.c4=test2.c4 like '%hex(test1.c2)%' order by test1.c4 asc;
select * from test1 inner JOIN test2 on test1.c4=test2.c4 like '%hex(test2.c2)%' order by test1.c4 asc;
select * from test1 inner JOIN test2 on test1.c4=test2.c4 like '%hex(test2.c2)%' order by test1.c4 asc;
select * from test1 inner JOIN test2 on test1.c4=test2.c4 order by hex(test1.c4) asc;
select * from test1 inner JOIN test2 on test1.c4=test2.c4 order by hex(test1.c1) asc;
select * from test1 inner JOIN test2 on test1.c4=test2.c4 not in(test1.c1,test1.c2,test1.c3,test1.c4,test2.c1,test2.c2,test2.c3,test2.c4) order by hex(test1.c1) asc;
select * from test1 inner JOIN test2 on test1.c4=test2.c4 in(test1.c1,test1.c2,test1.c3,test1.c4,test2.c1,test2.c2,test2.c3,test2.c4) order by hex(test1.c1) asc;
drop table test2;
drop table test1;






