--echo   #hex-6-2   多表联查
--echo   #多表联查======>where
--error 0,1051
drop table test1;
--error 0,1051
drop table test2;
CREATE table test1(c1 bigint,c2 FLOAT,c3 char(50),c4 year);
CREATE table test2(c1 bigint,c2 FLOAT,c3 varchar(50),c4 time);
insert into test1 values(325132,232.65,'swfegf','2025');
insert into test1 values(21332,1231.2,'efre','2030');
insert into test1 values(-42414,-232.65,'aafre','2035');
insert into test1 values(5441352,0.23265,'jdgfke','2040');
insert into test2 values(325132,232.65,'dddd','2025');
insert into test2 values(45332,1231.2,'efre','2030');
insert into test2 values(-4554,-2326.5,'ccccc','2035');
insert into test2 values(554352,0.23265,'fffe','2040');
select * from test1 order by c1 asc;
select * from test2 order by c1 asc;
select * from test1,test2 where test1.c4=test2.c4 order by test1.c1 asc;
select * from test1,test2 where test1.c4=test2.c4 and hex(test1.c2)=hex(test2.c2) order by test1.c1 asc;
select * from test1,test2 where test1.c4=test2.c4 or hex(test1.c2)=hex(test2.c2) order by test1.c1 asc;
select * from test1,test2 where test1.c4=test2.c4 like hex('%test2.c2%') order by test1.c1 asc;
select * from test1,test2 where test1.c4=test2.c4 like '%test2.c2%' order by test1.c1 asc;
--error 0,1052
select * from test1,test2 where test1.c4=test2.c4 group by test1.hex(c4) order by test1.c1 asc;
select * from test1,test2 where test1.c4=test2.c4 group by test1.c4 order by test1.c4 asc;
select * from test1,test2 where test1.c4=test2.c4 group by hex(test1.c4) order by test1.c4 asc;
select * from test1,test2 where test1.c4=test2.c4 group by hex(test1.c4) having test1.c2=test2.c2 order by test1.c4 asc;
select * from test1,test2 where test1.c4=test2.c4 group by hex(test1.c4) having test2.c2=1231.2 order by test1.c4 asc;
select * from test1,test2 where test1.c4=test2.c4 group by hex(test1.c4) having test2.c2=232.65 order by test1.c4 asc;
--error 0,1064
select distinct(hex(test1.c2) hex(test2.c3)) from test1,test2 where test1.c4=test2.c4 ;


--echo   #多表联查======>左连接
select * from test1 left JOIN test2 on test1.c4=test2.c4 where test1.c1=hex(test1.c2) and test2.c2=hex(test1.c2);
select * from test1 left JOIN test2 on test1.c4=test2.c4 where test1.c1=hex(test1.c1) and test2.c2=hex(test2.c2);
select * from test1 left JOIN test2 on test1.c4=test2.c4 where test1.c1=test1.c1 and test2.c2=test2.c2;
select * from test1 left JOIN test2 on test1.c4=test2.c4 where test1.c1=test1.c2 and test2.c2=test2.c2;
select * from test1 left JOIN test2 on test1.c4=test2.c4 where test1.c1=test1.c2 or test2.c2=test2.c2;
select * from test1 left JOIN test2 on test1.c4=test2.c4 where test1.c1=test1.c2 or test2.c2=test2.c2 and test1.c1=test2.c3;
select * from test1 left JOIN test2 on test1.c4=test2.c4 where hex(test1.c1=test1.c2) or hex(test2.c2=test2.c2) and hex(test1.c1=test2.c3);
select * from test1 left JOIN test2 on test1.c4=test2.c4 group by hex(test1.c4) order by test1.c4 asc;
select * from test1 left JOIN test2 on test1.c4=test2.c4 group by hex(test1.c4) having hex(test1.c4) order by test1.c4 asc;
select * from test1 left JOIN test2 on test1.c4=test2.c4 group by hex(test1.c4) having hex(test1.c4) order by hex(test1.c4) asc;
select * from test1 left JOIN test2 on test1.c4=test2.c4 like '%hex(test1.c2)%' order by test1.c4 asc;
select * from test1 left JOIN test2 on test1.c4=test2.c4 like '%hex(test2.c2)%' order by test1.c4 asc;
select * from test1 left JOIN test2 on test1.c4=test2.c4 like '%hex(test2.c2)%' order by test1.c4 asc;
select * from test1 left JOIN test2 on test1.c4=test2.c4 order by hex(test1.c4) asc;
select * from test1 left JOIN test2 on test1.c4=test2.c4 order by hex(test1.c1) asc;
select * from test1 left JOIN test2 on test1.c4=test2.c4 not in(test1.c1,test1.c2,test1.c3,test1.c4,test2.c1,test2.c2,test2.c3,test2.c4) order by hex(test1.c1) asc;
select * from test1 left JOIN test2 on test1.c4=test2.c4 in(test1.c1,test1.c2,test1.c3,test1.c4,test2.c1,test2.c2,test2.c3,test2.c4) order by hex(test1.c1) asc;


--echo   #多表联查======>右连接
select * from test1 right JOIN test2 on test1.c4=test2.c4 where test1.c1=hex(test1.c2) and test2.c2=hex(test1.c2);
