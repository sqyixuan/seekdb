--echo   #hex-7  PL语句



--echo   #hex-7-1  存储过程
--echo   #hex-7-1  存储过程======>while循环
--error 0,1051
drop table hj_test;
CREATE TABLE hj_test(c1 int,c2 int);
--error 0,1305
drop procedure procedure_1;
delimiter /;
CREATE PROCEDURE procedure_1()
BEGIN
DECLARE i INT DEFAULT 1;
WHILE i <= (SELECT hex(30000) FROM DUAL LIMIT 1)
DO
INSERT INTO hj_test VALUES (i, (select hex(i+200) from dual));
SET i = i + 1;
END WHILE;
COMMIT;
END;
/
DELIMITER ;/
--error 0,1366
call procedure_1();
SELECT * FROM hj_test ORDER BY c2 ASC;

--echo   #hex-7-1  存储过程======>repeat循环
drop procedure procedure_1;
DROP TABLE hj_test;
CREATE TABLE hj_test(c1 int,c2 int);

delimiter /;
CREATE PROCEDURE PROCEDURE_1()
BEGIN
DECLARE i INT DEFAULT 1;
REPEAT
INSERT INTO hj_test VALUES (i, (SELECT hex(i+200) FROM dual));
SET i = i + 1;
UNTIL i > 20000 END REPEAT;
END;
/
DELIMITER ;/
--error 0,1366
call procedure_1();
SELECT * FROM hj_test ORDER BY c1 ASC;


--echo   #hex-7-1  存储过程======>loop循环
DROP TABLE hj_test;
CREATE TABLE hj_test(c1 int,c2 int);
drop procedure procedure_1;

delimiter /;
create procedure procedure_1()
begin
    declare i int;
    set i = 1;
    lp : loop
        insert into hj_test values (i,(SELECT hex(i+200) FROM dual));
        set i = i + 1;
        if i > 20001 then
            leave lp;
        end if;
    end loop;
end;
/
DELIMITER ;/
--error 0,1366
CALL procedure_1();
SELECT * FROM hj_test ORDER BY c1 ASC;
drop procedure procedure_1;
DROP TABLE hj_test;



