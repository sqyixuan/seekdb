--error 0,1265
INSERT INTO hj_test1 values((select hex(490000) from dual),(select hex(640000) from dual));
SELECT * FROM hj_test1 ORDER BY c1 ASC;

INSERT INTO hj_test2 values((select hex(5123) from dual),(select hex(25161) from dual));
--error 0,1265
INSERT INTO hj_test2 values((select hex(5212) from dual),(select hex(546414) from dual));
--error 0,1265
INSERT INTO hj_test2 values((select hex(154641) from dual),(select hex(121) from dual));
INSERT INTO hj_test2 values((select hex(2313) from dual),(select hex(21314) from dual));
SELECT * FROM hj_test2 ORDER BY c1 ASC;

--error 0,1360
DROP TRIGGER TRIGGER_1;
delimiter /;
CREATE TRIGGER TRIGGER_1 AFTER DELETE ON hj_test2
FOR EACH ROW
BEGIN
    DELETE FROM hj_test1 WHERE c1=(select round(hex(160000)) from dual) OR c2=(select round(hex(640000)) from dual);
END
/
DELIMITER ;/
SELECT * FROM hj_test2 ORDER BY c1 ASC;
SELECT * FROM hj_test1 ORDER BY c1 ASC;
DELETE FROM hj_test2 WHERE c2=(select round(hex(25161)) from dual);
SELECT * FROM hj_test2 ORDER BY c1 ASC;
SELECT * FROM hj_test1 ORDER BY c1 ASC;
DROP TRIGGER TRIGGER_1;
delimiter /;
CREATE TRIGGER TRIGGER_1 AFTER DELETE ON hj_test2
FOR EACH ROW
BEGIN
    INSERT INTO hj_test1 values((select round(hex(5000)) from dual),(select round(hex(6666)) from dual));
END
/
DELIMITER ;/
SELECT * FROM hj_test2 ORDER BY c1 ASC;
SELECT * FROM hj_test1 ORDER BY c1 ASC;
--error 0,1292
DELETE FROM hj_test2 WHERE c1=(select round(hex(5212)) from dual);
SELECT * FROM hj_test2 ORDER BY c1 ASC;
SELECT * FROM hj_test1 ORDER BY c1 ASC;
DROP TRIGGER TRIGGER_1;
delimiter /;
CREATE TRIGGER TRIGGER_1 AFTER delete ON hj_test2
FOR EACH ROW
BEGIN
    UPDATE hj_test1 SET c1=((select round(hex(3000))+round(hex(2000)) from dual));
END
/
DELIMITER ;/
SELECT * FROM hj_test2 ORDER BY c1 ASC;
SELECT * FROM hj_test1 ORDER BY c1 ASC;
DELETE FROM hj_test2 WHERE c1=(select round(hex(2313)) from dual);
SELECT * FROM hj_test2 ORDER BY c1 ASC;
SELECT * FROM hj_test1 ORDER BY c1 ASC;
DROP TRIGGER TRIGGER_1;
DROP TABLE hj_test1;
DROP TABLE hj_test2;



