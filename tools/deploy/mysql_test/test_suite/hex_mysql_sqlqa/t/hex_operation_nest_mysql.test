--echo   #hex-3   运算符======>计算运算符
select hex(546+132) from dual;
select hex(1532)+254 from dual;
select hex(0.12)+hex(313) from dual;
select hex(440+hex(54564)) from dual;
select hex(154+null) from dual;
select hex(154)+hex(null) from dual;

select hex(546-132) from dual;
select hex(1532)-254 from dual;
select hex(0.12)-hex(313) from dual;
select hex(440-hex(54564)) from dual;
select hex(154-null) from dual;
select hex(154)-hex(null) from dual;

select hex(546*132) from dual;
select hex(1532)*254 from dual;
select hex(0.12)*hex(313) from dual;
select hex(440*hex(54564)) from dual;
select hex(154*null) from dual;
select hex(154)*hex(null) from dual;

select hex(546/132) from dual;
select hex(1532)/254 from dual;
select hex(0.12)/hex(313) from dual;
select hex(440/hex(54564)) from dual;
select hex(154/null) from dual;
select hex(154)/hex(null) from dual;

select hex(546%132) from dual;
select hex(1532)%254 from dual;
select hex(0.12)%hex(313) from dual;
select hex(440%hex(54564)) from dual;
select hex(154%null) from dual;
select hex(154)%hex(null) from dual;



--echo   #hex-3   运算符======>逻辑运算符
select hex(54121321201306 and 132) from dual;
select hex(12321321212002 and 0.546415) from dual;
select hex(48564545454544 and -12143210.546415) from dual;
select hex(78454566145111 and null) from dual;
select hex(54654565143513 and null and 4564313 and 0.0131 and 0) from dual;
select hex(54121321201306 )and 132 from dual;
select hex(12321321212002 )and 0.546415 from dual;
select hex(48564545454544 )and -12143210.546415 from dual;
select hex(78454566145111 )and null from dual;

select hex(54121321201306 or 132) from dual;
select hex(12321321212002 or 0.546415) from dual;
select hex(48564545454544 or -12143210.546415) from dual;
select hex(78454566145111 or null) from dual;
select hex(54654565143513 or null or 4564313 or 0.0131 or 0) from dual;
select hex(54121321201306 )or 132 from dual;
select hex(12321321212002 )or 0.546415 from dual;
select hex(48564545454544 )or -12143210.546415 from dual;
select hex(78454566145111 )or null from dual;

--error 0,1064
select hex(54121321201306 not 132) from dual;
--error 0,1064
select hex(12321321212002 not 0.546415) from dual;
--error 0,1064
select hex(48564545454544 not -12143210.546415) from dual;
--error 0,1064
select hex(78454566145111 not null) from dual;
--error 0,1064
select hex(54654565143513 not null not 4564313 not 0.0131 not 0) from dual;
--error 0,1064
select hex(54121321201306 )not 132 from dual;




--echo   #hex-3   运算符======>连接符
select hex(54121321201306 || 132) from dual;
select hex(54121321201306 )|| 1545312 from dual;
select hex(54121321201306 )|| null from dual;
select hex(54121321201306 )|| hex(1543131) from dual;
select hex(54121321201306 )|| hex(1543131 and hex(154321 || 87745)) from dual;
select hex(54121321201306 )|| hex(1543131 and hex(154321 || 87745) or hex(145643)) from dual;





--echo   #hex-4   函数嵌套
--echo   #hex-4-1   函数嵌套======>聚合函数
select hex(max(2632135453)) from dual;
select hex(max(-113212)) from dual;
select hex(max(0.54564153)) from dual;
select hex(max(true)) from dual;
select hex(max(FALSE)) from dual;
select hex(max(null)) from dual;

select hex(min(2632135453)) from dual;
select hex(min(-113212)) from dual;
select hex(min(0.54564153)) from dual;
select hex(min(true)) from dual;
select hex(min(FALSE)) from dual;
select hex(min(null)) from dual;

select hex(sum(2632135453)) from dual;
select hex(sum(-113212)) from dual;
select hex(sum(0.54564153)) from dual;
select hex(sum(true)) from dual;
select hex(sum(FALSE)) from dual;
select hex(sum(null)) from dual;

select hex(avg(2632135453)) from dual;
select hex(avg(-113212)) from dual;
select hex(avg(0.54564153)) from dual;
select hex(avg(true)) from dual;
select hex(avg(FALSE)) from dual;
select hex(avg(null)) from dual;

select hex(count(2632135453)) from dual;
select hex(count(-113212)) from dual;
select hex(count(0.54564153)) from dual;
select hex(count(true)) from dual;
select hex(count(FALSE)) from dual;
select hex(count(null)) from dual;




--echo   #hex-4-2   函数嵌套======>数字函数
select hex(ABS(2632135453)) from dual;
select hex(abs(-113212)) from dual;
select hex(abs(0.54564153)) from dual;
select hex(abs(true)) from dual;
select hex(abs(FALSE)) from dual;
select hex(abs(null)) from dual;

select hex(cos(2632135453)) from dual;
select hex(cos(-113212)) from dual;
select hex(cos(0.54564153)) from dual;
select hex(cos(true)) from dual;
select hex(cos(FALSE)) from dual;
select hex(cos(null)) from dual;

select hex(acos(2632135453)) from dual;
select hex(acos(-113212)) from dual;
select hex(acos(0.54564153)) from dual;
select hex(acos(true)) from dual;
select hex(acos(FALSE)) from dual;
select hex(acos(null)) from dual;

select hex(CEIL(2632135453)) from dual;
select hex(CEIL(-113212)) from dual;
select hex(CEIL(0.54564153)) from dual;
select hex(CEIL(true)) from dual;
select hex(CEIL(FALSE)) from dual;
select hex(CEIL(null)) from dual;

select hex(FLOOR(2632135453)) from dual;
select hex(FLOOR(-113212)) from dual;
select hex(FLOOR(0.54564153)) from dual;
select hex(FLOOR(true)) from dual;
select hex(FLOOR(FALSE)) from dual;
select hex(FLOOR(null)) from dual;

select hex(log(2632135453,3)) from dual;
select hex(log(-113212,54)) from dual;
select hex(log(0.54564153,65)) from dual;
select hex(log(true,FALSE)) from dual;
select hex(log(FALSE,FALSE)) from dual;
select hex(log(null,0)) from dual;

select hex(mod(2632135453,3)) from dual;
select hex(mod(-113212,54)) from dual;
select hex(mod(0.54564153,65)) from dual;
select hex(mod(true,FALSE)) from dual;
select hex(mod(FALSE,FALSE)) from dual;
select hex(mod(null,0)) from dual;

select hex(power(2632135453,3)) from dual;
select hex(power(-113212,54)) from dual;
select hex(power(0.54564153,65)) from dual;
select hex(power(true,FALSE)) from dual;
select hex(power(FALSE,FALSE)) from dual;
select hex(power(null,0)) from dual;

select hex(sqrt(2632135453)) from dual;
select hex(sqrt(-113212)) from dual;
select hex(sqrt(0.54564153)) from dual;
select hex(sqrt(true)) from dual;
select hex(sqrt(FALSE)) from dual;
select hex(sqrt(null)) from dual;


--echo   #hex-4-3   函数嵌套======>字符函数
select hex(ASCII('的符合其个人')) from dual;
select hex(CHAR_LENGTH('的符合其个人')) from dual;
select hex(CHARACTER_LENGTH('的符合其个人')) from dual;
select hex(CONCAT('的符合其个人')) from dual;
select hex(FORMAT('的符合其个人',4)) from dual;
select hex(LCASE('的符合其个人')) from dual;
select hex(LEFT('的符合其个人',6)) from dual;
select hex(REVERSE('的符合其个人')) from dual;


--echo   #hex-4-4   函数嵌套======>时间函数
select hex(ADDDATE("2023-06-15", INTERVAL 10 DAY)) from dual;
select hex(ADDTIME('2023-08-15 23:59:59', 5)) from dual;
#select hex(CURDATE('2023-01-01')) from dual;
select hex(DATE('2023-10-01')) from dual;
select hex(DATEDIFF('2001-01-01','2001-02-02')) from dual;



--echo   #hex-4-5   函数嵌套======>转换函数
select hex(cast(12132 as CHAR(50))) from dual;
select hex(cast('书法人认为' as CHAR(50))) from dual;
select hex(cast('2023-06-15' as CHAR(50))) from dual;

select hex(cast(12132 as SIGNED int)) from dual;
select hex(cast('书法人认为' as SIGNED int)) from dual;
select hex(cast('2023-06-15' as SIGNED int)) from dual;
select hex(cast(12132 as float)) from dual;
select hex(cast('书法人认为' as float)) from dual;
select hex(cast('2023-06-15' as float)) from dual;

select hex(cast(12132 as DATE)) from dual;
select hex(cast('书法人认为' as DATE)) from dual;
select hex(cast('2023-06-15' as DATE)) from dual;
select hex(cast(12132 as time)) from dual;
select hex(cast('书法人认为' as time)) from dual;
select hex(cast('2023-06-15' as time)) from dual;
select hex(cast(12132 as time)) from dual;
select hex(cast('书法人认为' as time)) from dual;
select hex(cast('2023-06-15' as time)) from dual;



--echo   #hex-4-5   函数嵌套======>json函数
select hex(JSON_ARRAY('a', 1)) from dual;
select hex(JSON_TYPE('["a", "b", 1]')) from dual;
select hex(JSON_OBJECT('key1', 1, 'key2', 'abc')) from dual;
select hex(JSON_MERGE('["a", 1]', '{"key": "value"}')) from dual;
select hex(JSON_VALID('null')) from dual;
select hex(JSON_SET('"x"', '$[0]', 'a')) from dual;
select hex(JSON_EXTRACT('{"a": 1, "b": 2, "c": [3, 4, 5]}', '$.c[*]')) from dual;
SET @j = '["a", {"b": [true, false]}, [10, 20]]';
select hex(JSON_INSERT(@j, '$[1].b[0]', 1, '$[2][2]', 2)) from dual;
select hex(JSON_REPLACE(@j, '$[1].b[0]', 1, '$[2][2]', 2)) from dual;








--echo # Clean up users
connection default;
--disable_warnings
--error 0,1396
drop user hjw@'%' ;
--enable_warnings
