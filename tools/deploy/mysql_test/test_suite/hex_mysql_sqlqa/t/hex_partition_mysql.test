connect (conn,$OBMYSQL_MS0,hjw,hjw,test,$OBMYSQL_PORT);


--echo  #hex-9   分区表



--echo  #hex-9-1   hash分区
--error 0,1051
DROP TABLE hj_test;
--error 0,1564
CREATE TABLE hj_test(c1 int,c2 int,c3 char(80))
partition BY hash((select hex(c1) from dual))(
PARTITION p1,
PARTITION p2,
PARTITION p3,
PARTITION p4);
--error 0,1564
CREATE TABLE hj_test(c1 int,c2 int,c3 char(80))
partition BY hash(hex(c1))(
PARTITION p1,
PARTITION p2,
PARTITION p3,
PARTITION p4);
--error 0,1564
CREATE TABLE hj_test(c1 int,c2 int,c3 char(80))
partition BY hash(hex(c3))(
PARTITION p1,
PARTITION p2,
PARTITION p3,
PARTITION p4);
CREATE TABLE hj_test(c1 int,c2 int,c3 char(80))
partition BY hash(c1)(
PARTITION p1,
PARTITION p2,
PARTITION p3,
PARTITION p4);
INSERT INTO hj_test VALUES (1,231,'foo');
INSERT INTO hj_test VALUES (4,453,'bar');
INSERT INTO hj_test VALUES (9,54613,'baz');
SELECT * FROM hj_test ORDER BY c1 ASC;
SELECT * FROM hj_test WHERE hex(c1) = 2;
SELECT * FROM hj_test WHERE c1 = hex(4);
SELECT * FROM hj_test WHERE c1 =(select hex(4) from dual);
--error 0,1265
INSERT INTO hj_test VALUES ((select hex(545643) from dual),(select hex(23115513) from dual),'foo');
--error 0,1265
INSERT INTO hj_test PARTITION(p1) VALUES ((select hex(545643) from dual),(select hex(23115513) from dual),'foo');
--error 0,1265
INSERT INTO hj_test PARTITION(p2) VALUES ((select hex(545643) from dual),(select hex(23115513) from dual),'foo');
--error 0,1265
INSERT INTO hj_test PARTITION(p3) VALUES ((select hex(545643) from dual),(select hex(23115513) from dual),'foo');
SELECT * FROM hj_test ORDER BY c1 ASC;




