--echo  #hex-9-5   组合分区
--error 0,1051
DROP TABLE hj_test;
--error 0,1064
CREATE TABLE hj_test (
c1 NUMBER
)
PARTITION BY RANGE (c1)
(
PARTITION p1 VALUES LESS THAN (100)
SUBPARTITION BY LIST (c1)
(
SUBPARTITION sp1 VALUES ((select hex(200) from dual)),
SUBPARTITION sp2 VALUES ((select hex(400) from dual))
),
PARTITION p2 VALUES LESS THAN (200)
SUBPARTITION BY LIST (c1)
(
SUBPARTITION sp3 VALUES (select hex(900) from dual),
SUBPARTITION sp4 VALUES (select hex(1600) from dual)
));

--error 0,1564
create table hj_test(id int,h1 bigint) partition by range(id) subpartition by hash(hex(h1))
(
partition p1 values less than(200)(subpartition p11),
partition p2 values less than(400)(subpartition p22),
partition p3 values less than(MAXVALUE)(subpartition p33)
);

--error 0,1051
drop table test1;
create table test1(c1 bigint);
insert into test1 values(66);
--error 0,1564
create table hj_test(id int,h1 bigint) partition by range(id) subpartition by hash((select hex(c1) from test1))
(
partition p1 values less than(200)(subpartition p11),
partition p2 values less than(400)(subpartition p22),
partition p3 values less than(MAXVALUE)(subpartition p33)
);
drop table test1;
create table hj_test(id int,h1 bigint) partition by range(id) subpartition by hash(h1)
(
partition p1 values less than(200)(subpartition p11),
partition p2 values less than(400)(subpartition p22),
partition p3 values less than(MAXVALUE)(subpartition p33)
);
INSERT INTO hj_test VALUES (199,231);
INSERT INTO hj_test VALUES (398,453);
INSERT INTO hj_test VALUES (201,54613);
--error 0,1265
INSERT INTO hj_test VALUES ((select hex(6399) from dual),231);
INSERT INTO hj_test VALUES ((select hex(null) from dual),564);
select id,h1 from hj_test order by id asc;



drop table hj_test;
create table hj_test(id int,h1 bigint) partition by list(id) subpartition by key(h1)
(
partition p1 values in(200)(subpartition p11),
partition p2 values in(400)(subpartition p22),
partition p3 values in(600)(subpartition p33)
);
INSERT INTO hj_test VALUES (200,231);
INSERT INTO hj_test VALUES (400,453);
INSERT INTO hj_test VALUES (600,54613);
--error 0,1265
INSERT INTO hj_test VALUES ((select hex(6399) from dual),231);
--error 0,1526
INSERT INTO hj_test VALUES ((select hex(null) from dual),564);
--error 0,1526
INSERT INTO hj_test VALUES ((select hex(600) from dual),null);
select id,h1 from hj_test order by id asc;
select id,h1 from hj_test partition (p1) order by id asc;
select id,h1 from hj_test partition (p2) order by id asc;
select id,h1 from hj_test partition (p3) order by id asc;
--error 0,1064
select id,h1 from hj_test subpartition (p11) order by id asc;
--error 0,1064
select id,h1 from hj_test subpartition (p22) order by id asc;
--error 0,1064
select id,h1 from hj_test subpartition (p33) order by id asc;
--error 0,1526
update hj_test partition (p1) set id=(select 201 from dual) where id=200;
update hj_test partition (p1) set id=(select 206 from dual) where h1 is null;
update hj_test partition (p3) set id=(select 601 from dual) where h1 is null;
update hj_test partition (p3) set h1=(select 600 from dual) where h1 is null;
select id,h1 from hj_test order by id asc;
DELETE from hj_test PARTITION (p3) where id=(select hex(600) from dual);
select id,h1 from hj_test order by id asc;
--error 0,1064
DELETE from (select hex(id) from hj_test) PARTITION (p2) where id=(select hex(400) from dual);
drop table hj_test;





