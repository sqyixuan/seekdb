#主键+notnull+unique+check
drop table hj_test;
create table hj_test(c1 bigint PRIMARY key UNIQUE key not null CHECK(c1>50),c2 bigint UNIQUE key not null CHECK(c2<500));
insert into hj_test values((select hex(null) from dual),(select hex(0) from dual));
