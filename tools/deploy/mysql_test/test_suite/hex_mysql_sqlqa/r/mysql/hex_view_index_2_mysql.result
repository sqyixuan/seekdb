#范围   check
drop table hj_test;
create table hj_test(c1 bigint,c2 bigint,CHECK(c1>hex(20),c2<hex(300)));
create table hj_test(c1 bigint,c2 bigint,CHECK(c1>hex(20) and c2<hex(21329)));
insert into hj_test values((select hex(55) from dual),(select hex(399) from dual));
insert into hj_test values((select hex(55) from dual),(select hex(10000) from dual));
select c1,c2 from hj_test order by c1 asc;
c1	c2
37	2710
drop table hj_test;
create table hj_test(c1 bigint,c2 bigint,CHECK(c1>hex(20) or c2<hex(300)));
drop table hj_test;
create table hj_test(c1 bigint,c2 bigint,CHECK(c1>(select hex(20) from dual) or c2<(select hex(300) from dual)));
create table hj_test(c1 bigint,c2 bigint,CHECK(c1>(select hex(20) from dual)));
create table hj_test(c1 bigint,c2 bigint,CHECK(c1>hex(20)));
drop table hj_test;
create table hj_test(c1 bigint,c2 bigint,CHECK(c1>20 and c2<600));
