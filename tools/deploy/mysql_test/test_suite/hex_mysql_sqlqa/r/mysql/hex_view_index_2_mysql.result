54	58
#外键约束  foreign key
DROP TABLE test2;
DROP TABLE test1;
CREATE TABLE test1
(c1 int,c2 int,
CONSTRAINT CONSTRAINT_1 PRIMARY KEY (c1)
);
CREATE TABLE test2
(c1 int,c2 int,
CONSTRAINT CONSTRAINT_2 FOREIGN KEY (c1) REFERENCES test1(c1)
);
INSERT INTO test1 values((select hex(640) from dual),(select hex(490) from dual));
SELECT * FROM test1 ORDER BY c1 asc;
c1	c2
INSERT INTO test2 values((select hex(640) from dual),(select hex(490) from dual));
INSERT INTO test2 values((select hex(640) from dual),(select hex(490) from dual));
SELECT * FROM test2 ORDER BY c1 asc;
c1	c2
INSERT INTO test2 values(25,22);
INSERT INTO test2 values((select hex(640) from dual),22);
INSERT INTO test2 values((select hex(320) from dual)+320,122);
INSERT INTO test2 values((select hex(320) from dual)+null,122);
INSERT INTO test2 values((select hex(320) from dual),132);
SELECT * FROM test2 ORDER BY c1 asc;
