#hex-4-5   函数嵌套======>json函数
select hex(JSON_ARRAY('a', 1)) from dual;
hex(JSON_ARRAY('a', 1))
5B2261222C20315D
select hex(JSON_TYPE('["a", "b", 1]')) from dual;
hex(JSON_TYPE('["a", "b", 1]'))
4152524159
select hex(JSON_OBJECT('key1', 1, 'key2', 'abc')) from dual;
hex(JSON_OBJECT('key1', 1, 'key2', 'abc'))
7B226B657931223A20312C20226B657932223A2022616263227D
select hex(JSON_MERGE('["a", 1]', '{"key": "value"}')) from dual;
hex(JSON_MERGE('["a", 1]', '{"key": "value"}'))
5B2261222C20312C207B226B6579223A202276616C7565227D5D
select hex(JSON_VALID('null')) from dual;
hex(JSON_VALID('null'))
1
select hex(JSON_SET('"x"', '$[0]', 'a')) from dual;
hex(JSON_SET('"x"', '$[0]', 'a'))
226122
select hex(JSON_EXTRACT('{"a": 1, "b": 2, "c": [3, 4, 5]}', '$.c[*]')) from dual;
hex(JSON_EXTRACT('{"a": 1, "b": 2, "c": [3, 4, 5]}', '$.c[*]'))
5B332C20342C20355D
SET @j = '["a", {"b": [true, false]}, [10, 20]]';
select hex(JSON_INSERT(@j, '$[1].b[0]', 1, '$[2][2]', 2)) from dual;
hex(JSON_INSERT(@j, '$[1].b[0]', 1, '$[2][2]', 2))
5B2261222C207B2262223A205B747275652C2066616C73655D7D2C205B31302C2032302C20325D5D
select hex(JSON_REPLACE(@j, '$[1].b[0]', 1, '$[2][2]', 2)) from dual;
hex(JSON_REPLACE(@j, '$[1].b[0]', 1, '$[2][2]', 2))
5B2261222C207B2262223A205B312C2066616C73655D7D2C205B31302C2032305D5D
