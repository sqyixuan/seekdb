#hex-4-3   函数嵌套======>字符函数
select hex(ASCII('的符合其个人')) from dual;
hex(ASCII('的符合其个人'))
E7
select hex(CHAR_LENGTH('的符合其个人')) from dual;
hex(CHAR_LENGTH('的符合其个人'))
6
select hex(CHARACTER_LENGTH('的符合其个人')) from dual;
hex(CHARACTER_LENGTH('的符合其个人'))
6
select hex(CONCAT('的符合其个人')) from dual;
hex(CONCAT('的符合其个人'))
E79A84E7ACA6E59088E585B6E4B8AAE4BABA
select hex(FORMAT('的符合其个人',4)) from dual;
hex(FORMAT('的符合其个人',4))
302E30303030
Warnings:
Warning	1292	Truncated incorrect DOUBLE value: '的符合其个人'
