#静态sql======>select
DROP TABLE hj_test;
CREATE TABLE hj_test(c1 bigint,c2 bigint,c3 bigint,c4 bigint);
drop procedure procedure_1;
CREATE PROCEDURE procedure_1()
BEGIN
DECLARE i INT DEFAULT 1;
WHILE i < 6000 DO
INSERT INTO hj_test VALUES (abs(315) + i, abs(0) + i, abs(NULL) + i, abs(120) + abs(0.120) + i);
SET i = i + 1;
END WHILE;
COMMIT;
END/
call procedure_1();
