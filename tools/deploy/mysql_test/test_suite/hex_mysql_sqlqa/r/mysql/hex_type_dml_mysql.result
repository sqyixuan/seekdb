insert into test2 values(325132,232.65,'dddd','2025');
insert into test2 values(45332,1231.2,'efre','2030');
insert into test2 values(-4554,-2326.5,'ccccc','2035');
insert into test2 values(554352,0.23265,'fffe','2040');
