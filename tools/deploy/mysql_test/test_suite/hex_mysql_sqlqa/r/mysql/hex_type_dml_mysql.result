#hex-6-2   多表联查
#多表联查======>where
drop table test1;
drop table test2;
CREATE table test1(c1 bigint,c2 FLOAT,c3 char(50),c4 year);
CREATE table test2(c1 bigint,c2 FLOAT,c3 varchar(50),c4 time);
insert into test1 values(325132,232.65,'swfegf','2025');
insert into test1 values(21332,1231.2,'efre','2030');
insert into test1 values(-42414,-232.65,'aafre','2035');
