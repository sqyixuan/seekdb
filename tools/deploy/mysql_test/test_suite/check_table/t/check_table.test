# owner group:sql2
# tags:
# descriotion: 
# 验证mysql模式下的check table


--result_format 4

--disable_warnings
drop table if exists t1;
drop table if exists t2;
drop view if exists v1;
--enable_warnings

check table t1;
check table test.t1;
--error 1066
check table t1, t1;
--error 1066
check table test.t1, test.t1;
check table error_db.t1;

create table t1 (c1 int);
check table t1;
check table test.t1;
--error 1066
check table t1, t1;
check table t1 FOR UPGRADE;
check table t1 QUICK;
check table t1 FAST;
check table t1 MEDIUM;
check table t1 EXTENDED;
check table t1 CHANGED;
check table t1 CHANGED CHANGED EXTENDED EXTENDED MEDIUM MEDIUM FAST FAST QUICK QUICK FOR UPGRADE FOR UPGRADE;

create view v1 as select * from t1;
check table v1;
check table test.v1;
--error 1066
check table v1, v1;
check table v1, t1;
drop table t1;
check table v1;
check table test.v1;
--error 1066
check table v1, v1;
check table v1, t1;

drop view v1;


connection default;
--disable_warnings
drop database if exists column_priv_db;
--enable_warnings 
purge recyclebin;

--error 0,ER_CANNOT_USER
drop user column_priv_user;
create user column_priv_user;
create database column_priv_db;

use column_priv_db;

create table t1(c1 int default 0, c2 int, c3 int as(c1 + c2), c4 int, key idx(c4), primary key(c1));
create table t2(c1 int default 0, c2 int, c3 int as(c1 + c2), c4 int, key idx(c4), primary key(c1));
grant select on column_priv_db.t2 to column_priv_user;
connect (conn_priv_user,$OBMYSQL_MS0, column_priv_user, , column_priv_db,$OBMYSQL_PORT);
connection conn_priv_user;
--error 1142
check table column_priv_db.t1;

check table column_priv_db.t2;

connection default;
drop table t1;
drop table t2;
drop user column_priv_user;
drop database column_priv_db;
