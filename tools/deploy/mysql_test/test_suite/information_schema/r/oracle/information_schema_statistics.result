drop database if exists db_is;
create database db_is;
use db_is;
create table t1(c1 int primary key, c2 int);
create index idx on t1(c2);
select table_schema, table_name, index_name from information_schema.statistics where table_schema='db_is' and table_name = 't1';
table_schema	table_name	index_name
db_is	t1	PRIMARY
db_is	t1	idx
drop database db_is;
