drop table if exists tbl1,t1;
drop view if exists testview;
create table tbl1 (pk int,i1 int, v2 varchar(80), i3 char(20),i4 float, d4 datetime(6),d40 datetime,i5 decimal(5,3),i6 bool, primary key(pk),unique key(v2),key(i1));
