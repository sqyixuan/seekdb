def	test	testview	select `test`.`tbl1`.`pk` AS `pk`,`test`.`tbl1`.`i1` AS `i1`,`test`.`tbl1`.`v2` AS `v2`,`test`.`tbl1`.`i3` AS `i3`,`test`.`tbl1`.`i4` AS `i4`,`test`.`tbl1`.`d4` AS `d4`,`test`.`tbl1`.`d40` AS `d40`,`test`.`tbl1`.`i5` AS `i5`,`test`.`tbl1`.`i6` AS `i6` from `test`.`tbl1`	NONE	NO	NONE	NONE	utf8mb4	utf8mb4_general_ci
