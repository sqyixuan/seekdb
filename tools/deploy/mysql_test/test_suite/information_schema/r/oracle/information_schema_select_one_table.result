create user myuser identified by 'pass1';
grant all on *.* to myuser with grant option;
grant all on mysql.* to myuser with grant option;
grant select on mysql.user to myuser;
grant select on noexistdb.* to myuser;
select * from information_schema.TABLE_PRIVILEGES where GRANTEE like 'myuser%';
GRANTEE	TABLE_CATALOG	TABLE_SCHEMA	TABLE_NAME	PRIVILEGE_TYPE	IS_GRANTABLE
select * from information_schema.user_PRIVILEGES where GRANTEE like 'myuser%';
