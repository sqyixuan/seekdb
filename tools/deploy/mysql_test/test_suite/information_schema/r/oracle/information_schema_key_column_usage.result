drop database if exists db_is;
create database db_is;
use db_is;
create table t1(c1 int primary key, c2 int, c3 int , index idx(c2,c3), unique index uidx(c2,c3), unique index __index_name_with_split_symbol__(c3));
select table_schema, table_name, column_name, constraint_name from information_schema.key_column_usage where constraint_schema='db_is' and table_name = 't1';
table_schema	table_name	column_name	constraint_name
db_is	t1	c1	PRIMARY
db_is	t1	c2	uidx
db_is	t1	c3	uidx
db_is	t1	c3	__index_name_with_split_symbol__
drop table t1;
create table t1(c1 int);
select table_schema, table_name, column_name, constraint_name from information_schema.key_column_usage where constraint_schema='db_is' and table_name = 't1';
table_schema	table_name	column_name	constraint_name
