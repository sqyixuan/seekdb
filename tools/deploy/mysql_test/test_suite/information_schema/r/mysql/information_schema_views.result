drop database if exists db_views;
create database db_views;
use db_views;
create table t(c1 int, c2 int);
create view v1 as select * from t;
create view v2 as select * from t with check option;
create view v3 as select * from t with local check option;
create view v4 as select * from t with cascaded check option;
select * from information_schema.views where table_schema = 'db_views';
