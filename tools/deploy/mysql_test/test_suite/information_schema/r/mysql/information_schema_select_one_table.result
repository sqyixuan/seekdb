drop user myuser;
create user myuser identified by 'pass1';
grant all on *.* to myuser with grant option;
grant all on mysql.* to myuser with grant option;
grant select on mysql.user to myuser;
grant select on noexistdb.* to myuser;
select * from information_schema.TABLE_PRIVILEGES where GRANTEE like 'myuser%';
GRANTEE	TABLE_CATALOG	TABLE_SCHEMA	TABLE_NAME	PRIVILEGE_TYPE	IS_GRANTABLE
select * from information_schema.user_PRIVILEGES where GRANTEE like 'myuser%';
GRANTEE	TABLE_CATALOG	PRIVILEGE_TYPE	IS_GRANTABLE
create view testview as select * from tbl1;
select * from information_schema.views where table_schema = 'test' and table_name='testview';
TABLE_CATALOG	TABLE_SCHEMA	TABLE_NAME	VIEW_DEFINITION	CHECK_OPTION	IS_UPDATABLE	DEFINER	SECURITY_TYPE	CHARACTER_SET_CLIENT	COLLATION_CONNECTION
def	test	testview	select `test`.`tbl1`.`pk` AS `pk`,`test`.`tbl1`.`i1` AS `i1`,`test`.`tbl1`.`v2` AS `v2`,`test`.`tbl1`.`i3` AS `i3`,`test`.`tbl1`.`i4` AS `i4`,`test`.`tbl1`.`d4` AS `d4`,`test`.`tbl1`.`d40` AS `d40`,`test`.`tbl1`.`i5` AS `i5`,`test`.`tbl1`.`i6` AS `i6` from `test`.`tbl1`	NONE	YES	admin@%	NONE	utf8mb4	utf8mb4_general_ci
drop view testview;
drop user myuser;
