drop database if exists db_is;
create database db_is;
use db_is;
create table t1(c1 int primary key, c2 int, `geo` geometry NOT NULL srid 0);
create index idx on t1(c2);
select table_schema, table_name, index_name from information_schema.statistics where table_schema='db_is' and table_name = 't1';
table_schema	table_name	index_name
db_is	t1	idx
db_is	t1	PRIMARY
drop table t1;
CREATE TABLE `t1` (
`c1` int(11) NOT NULL AUTO_INCREMENT,
`c2` varchar(64) DEFAULT NULL,
`geo` geometry NOT NULL srid 0,
SPATIAL INDEX (`geo`),
PRIMARY KEY (`c1`),
KEY `c2_idx` (`c2`(10)) BLOCK_SIZE 16384 GLOBAL
);
CREATE TABLE `t2` (
`c1` int(11) NOT NULL AUTO_INCREMENT,
`c2` varchar(20) DEFAULT NULL,
PRIMARY KEY (`c1`)
);
select * from information_schema.statistics where TABLE_SCHEMA = 'db_is' and table_name = 't1';
TABLE_CATALOG	TABLE_SCHEMA	TABLE_NAME	NON_UNIQUE	INDEX_SCHEMA	INDEX_NAME	SEQ_IN_INDEX	COLUMN_NAME	COLLATION	CARDINALITY	SUB_PART	PACKED	NULLABLE	INDEX_TYPE	COMMENT	INDEX_COMMENT	IS_VISIBLE	EXPRESSION
def	db_is	t1	1	db_is	geo	1	__cellid_18	A	NULL	NULL	NULL	YES	BTREE	VALID		YES	NULL
def	db_is	t1	1	db_is	geo	2	__mbr_18	A	NULL	NULL	NULL	YES	BTREE	VALID		YES	NULL
def	db_is	t1	1	db_is	c2_idx	1	c2	A	NULL	10	NULL	YES	BTREE	VALID		YES	NULL
def	db_is	t1	0	db_is	PRIMARY	1	c1	A	NULL	NULL	NULL		BTREE	VALID		YES	NULL
select * from information_schema.statistics where TABLE_SCHEMA = 'db_is' and table_name = 't2';
TABLE_CATALOG	TABLE_SCHEMA	TABLE_NAME	NON_UNIQUE	INDEX_SCHEMA	INDEX_NAME	SEQ_IN_INDEX	COLUMN_NAME	COLLATION	CARDINALITY	SUB_PART	PACKED	NULLABLE	INDEX_TYPE	COMMENT	INDEX_COMMENT	IS_VISIBLE	EXPRESSION
def	db_is	t2	0	db_is	PRIMARY	1	c1	A	NULL	NULL	NULL		BTREE	VALID		YES	NULL
