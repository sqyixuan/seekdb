use test;
drop table if exists ift;
########################    1. normal table    ########################

create table ift(c1 int);
select table_name,partition_name,subpartition_name,partition_ordinal_position,subpartition_ordinal_position,partition_method,subpartition_method,partition_expression,subpartition_expression,partition_comment from information_schema.partitions where table_schema='test' and table_name='ift' order by 1,2,3,4,5;;
table_name	partition_name	subpartition_name	partition_ordinal_position	subpartition_ordinal_position	partition_method	subpartition_method	partition_expression	subpartition_expression	partition_comment
ift	NULL	NULL	NULL	NULL	NULL	NULL	NULL	NULL	NULL

########################    2. one-level table    ########################

drop table ift;
create table ift (c1 int, c2 int) partition by range(c1) 
(partition p1 values less than(1),
partition p2 values less than(2));

select table_name,partition_name,subpartition_name,partition_ordinal_position,subpartition_ordinal_position,partition_method,subpartition_method,partition_expression,subpartition_expression,partition_comment from information_schema.partitions where table_schema='test' and table_name='ift' order by 1,2,3,4,5;;
table_name	partition_name	subpartition_name	partition_ordinal_position	subpartition_ordinal_position	partition_method	subpartition_method	partition_expression	subpartition_expression	partition_comment
ift	p1	NULL	1	NULL	RANGE	NULL	c1	NULL	
ift	p2	NULL	2	NULL	RANGE	NULL	c1	NULL	

drop table ift;
create table ift (c1 int, c2 int) partition by hash(c1) 
(partition p1 ,
partition p2 );

select table_name,partition_name,subpartition_name,partition_ordinal_position,subpartition_ordinal_position,partition_method,subpartition_method,partition_expression,subpartition_expression,partition_comment from information_schema.partitions where table_schema='test' and table_name='ift' order by 1,2,3,4,5;;
table_name	partition_name	subpartition_name	partition_ordinal_position	subpartition_ordinal_position	partition_method	subpartition_method	partition_expression	subpartition_expression	partition_comment
ift	p1	NULL	1	NULL	HASH	NULL	c1	NULL	
ift	p2	NULL	2	NULL	HASH	NULL	c1	NULL	

########################    3. two-level table    ########################

########################    3.1 range-range    ########################

drop table ift;
create table ift (c1 int, c2 int) partition by range(c1) subpartition by range(c2)
(
partition p1 values less than(1)
(
subpartition sp1 values less than (22),
subpartition sp2 values less than (33)
),
partition p2 values less than(2)
(
subpartition sp3 values less than (234324),
subpartition sp4 values less than (2342344)
),
partition p3 values less than(3)
(
subpartition sp5 values less than (224),
subpartition sp6 values less than (2344)
)
);

select table_name,partition_name,subpartition_name,partition_ordinal_position,subpartition_ordinal_position,partition_method,subpartition_method,partition_expression,subpartition_expression,partition_comment from information_schema.partitions where table_schema='test' and table_name='ift' order by 1,2,3,4,5;;
table_name	partition_name	subpartition_name	partition_ordinal_position	subpartition_ordinal_position	partition_method	subpartition_method	partition_expression	subpartition_expression	partition_comment
ift	p1	sp1	1	1	RANGE	RANGE	c1	c2	
ift	p1	sp2	1	2	RANGE	RANGE	c1	c2	
ift	p2	sp3	2	1	RANGE	RANGE	c1	c2	
ift	p2	sp4	2	2	RANGE	RANGE	c1	c2	
ift	p3	sp5	3	1	RANGE	RANGE	c1	c2	
ift	p3	sp6	3	2	RANGE	RANGE	c1	c2	

alter table ift drop partition p2;

select table_name,partition_name,subpartition_name,partition_ordinal_position,subpartition_ordinal_position,partition_method,subpartition_method,partition_expression,subpartition_expression,partition_comment from information_schema.partitions where table_schema='test' and table_name='ift' order by 1,2,3,4,5;;
table_name	partition_name	subpartition_name	partition_ordinal_position	subpartition_ordinal_position	partition_method	subpartition_method	partition_expression	subpartition_expression	partition_comment
ift	p1	sp1	1	1	RANGE	RANGE	c1	c2	
ift	p1	sp2	1	2	RANGE	RANGE	c1	c2	
ift	p3	sp5	2	1	RANGE	RANGE	c1	c2	
ift	p3	sp6	2	2	RANGE	RANGE	c1	c2	

alter table ift drop subpartition sp5;

select table_name,partition_name,subpartition_name,partition_ordinal_position,subpartition_ordinal_position,partition_method,subpartition_method,partition_expression,subpartition_expression,partition_comment from information_schema.partitions where table_schema='test' and table_name='ift' order by 1,2,3,4,5;;
