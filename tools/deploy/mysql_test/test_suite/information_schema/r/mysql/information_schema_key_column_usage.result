drop database if exists db_is;
create database db_is;
use db_is;
result_format: 4
create table t1(c1 int primary key, c2 int, c3 int , index idx(c2,c3), unique index uidx(c2,c3), unique index __index_name_with_split_symbol__(c3));
select table_schema, table_name, column_name, constraint_name from information_schema.key_column_usage where constraint_schema='db_is' and table_name = 't1' order by table_schema, table_name, constraint_name, ordinal_position;
+--------------+------------+-------------+----------------------------------+
| table_schema | table_name | column_name | constraint_name                  |
+--------------+------------+-------------+----------------------------------+
| db_is        | t1         | c1          | PRIMARY                          |
| db_is        | t1         | c2          | uidx                             |
| db_is        | t1         | c3          | __index_name_with_split_symbol__ |
| db_is        | t1         | c3          | uidx                             |
+--------------+------------+-------------+----------------------------------+
drop table t1;

create table t1(c1 int);
select table_schema, table_name, column_name, constraint_name from information_schema.key_column_usage where constraint_schema='db_is' and table_name = 't1' order by table_schema, table_name, constraint_name, ordinal_position;
+--------------+------------+-------------+-----------------+
| table_schema | table_name | column_name | constraint_name |
+--------------+------------+-------------+-----------------+
+--------------+------------+-------------+-----------------+
drop table t1;

## 展示外键列信息
create table t1(c1 int, c2 int, c3 int, c4 int, primary key(c1, c2), unique key(c3, c4));
create table t2(c1 int, c2 int, c3 int, c4 int, constraint fk1 foreign key(c1, c2) references t1(c2, c1), constraint fk2 foreign key(c3, c4) references t1(c4, c3));
select CONSTRAINT_SCHEMA, CONSTRAINT_NAME, TABLE_SCHEMA, TABLE_NAME, COLUMN_NAME, ORDINAL_POSITION, REFERENCED_TABLE_SCHEMA, REFERENCED_TABLE_NAME, REFERENCED_COLUMN_NAME from information_schema.key_column_usage where constraint_schema='db_is' order by table_schema, table_name, constraint_name, ordinal_position;
+-------------------+-----------------+--------------+------------+-------------+------------------+-------------------------+-----------------------+------------------------+
| CONSTRAINT_SCHEMA | CONSTRAINT_NAME | TABLE_SCHEMA | TABLE_NAME | COLUMN_NAME | ORDINAL_POSITION | REFERENCED_TABLE_SCHEMA | REFERENCED_TABLE_NAME | REFERENCED_COLUMN_NAME |
+-------------------+-----------------+--------------+------------+-------------+------------------+-------------------------+-----------------------+------------------------+
| db_is             | c3              | db_is        | t1         | c3          |                1 | NULL                    | NULL                  | NULL                   |
| db_is             | c3              | db_is        | t1         | c4          |                2 | NULL                    | NULL                  | NULL                   |
| db_is             | PRIMARY         | db_is        | t1         | c1          |                1 | NULL                    | NULL                  | NULL                   |
| db_is             | PRIMARY         | db_is        | t1         | c2          |                2 | NULL                    | NULL                  | NULL                   |
| db_is             | fk1             | db_is        | t2         | c1          |                1 | db_is                   | t1                    | c2                     |
| db_is             | fk1             | db_is        | t2         | c2          |                2 | db_is                   | t1                    | c1                     |
| db_is             | fk2             | db_is        | t2         | c3          |                1 | db_is                   | t1                    | c4                     |
| db_is             | fk2             | db_is        | t2         | c4          |                2 | db_is                   | t1                    | c3                     |
+-------------------+-----------------+--------------+------------+-------------+------------------+-------------------------+-----------------------+------------------------+
drop table t2;
drop table t1;

## test for POSITION_IN_UNIQUE_CONSTRAINT
create table t1 (c1 int, c2 int, constraint cons1 unique(c1,c2), c3 int, c4 int, c5 int, primary key (c3,c4,c5));
create table t2 (c1 int, c2 int, c3 int, c4 int, c5 int, constraint foreign_key_1 foreign key(c1,c2) references t1(c1,c2), constraint foreign_key_2 foreign key(c3,c4,c5) references t1(c3,c4,c5));
create table t3 (c1 int, c2 int, c3 int, c4 int, c5 int, constraint foreign_key_3 foreign key(c2,c1) references t1(c1,c2), constraint foreign_key_4 foreign key(c5,c4,c3) references t1(c3,c4,c5));
select * from information_schema.key_column_usage kc1 where table_schema='db_is' and table_name='t1';
+--------------------+-------------------+-----------------+---------------+--------------+------------+-------------+------------------+-------------------------------+-------------------------+-----------------------+------------------------+
| CONSTRAINT_CATALOG | CONSTRAINT_SCHEMA | CONSTRAINT_NAME | TABLE_CATALOG | TABLE_SCHEMA | TABLE_NAME | COLUMN_NAME | ORDINAL_POSITION | POSITION_IN_UNIQUE_CONSTRAINT | REFERENCED_TABLE_SCHEMA | REFERENCED_TABLE_NAME | REFERENCED_COLUMN_NAME |
+--------------------+-------------------+-----------------+---------------+--------------+------------+-------------+------------------+-------------------------------+-------------------------+-----------------------+------------------------+
| def                | db_is             | PRIMARY         | def           | db_is        | t1         | c3          |                1 |                          NULL | NULL                    | NULL                  | NULL                   |
| def                | db_is             | PRIMARY         | def           | db_is        | t1         | c4          |                2 |                          NULL | NULL                    | NULL                  | NULL                   |
| def                | db_is             | PRIMARY         | def           | db_is        | t1         | c5          |                3 |                          NULL | NULL                    | NULL                  | NULL                   |
| def                | db_is             | cons1           | def           | db_is        | t1         | c1          |                1 |                          NULL | NULL                    | NULL                  | NULL                   |
| def                | db_is             | cons1           | def           | db_is        | t1         | c2          |                2 |                          NULL | NULL                    | NULL                  | NULL                   |
+--------------------+-------------------+-----------------+---------------+--------------+------------+-------------+------------------+-------------------------------+-------------------------+-----------------------+------------------------+
select * from information_schema.key_column_usage kc1 where table_schema='db_is' and table_name='t2';
+--------------------+-------------------+-----------------+---------------+--------------+------------+-------------+------------------+-------------------------------+-------------------------+-----------------------+------------------------+
| CONSTRAINT_CATALOG | CONSTRAINT_SCHEMA | CONSTRAINT_NAME | TABLE_CATALOG | TABLE_SCHEMA | TABLE_NAME | COLUMN_NAME | ORDINAL_POSITION | POSITION_IN_UNIQUE_CONSTRAINT | REFERENCED_TABLE_SCHEMA | REFERENCED_TABLE_NAME | REFERENCED_COLUMN_NAME |
+--------------------+-------------------+-----------------+---------------+--------------+------------+-------------+------------------+-------------------------------+-------------------------+-----------------------+------------------------+
| def                | db_is             | foreign_key_1   | def           | db_is        | t2         | c1          |                1 |                             1 | db_is                   | t1                    | c1                     |
| def                | db_is             | foreign_key_1   | def           | db_is        | t2         | c2          |                2 |                             2 | db_is                   | t1                    | c2                     |
| def                | db_is             | foreign_key_2   | def           | db_is        | t2         | c3          |                1 |                             1 | db_is                   | t1                    | c3                     |
| def                | db_is             | foreign_key_2   | def           | db_is        | t2         | c4          |                2 |                             2 | db_is                   | t1                    | c4                     |
| def                | db_is             | foreign_key_2   | def           | db_is        | t2         | c5          |                3 |                             3 | db_is                   | t1                    | c5                     |
+--------------------+-------------------+-----------------+---------------+--------------+------------+-------------+------------------+-------------------------------+-------------------------+-----------------------+------------------------+
select * from information_schema.key_column_usage kc1 where table_schema='db_is' and table_name='t3';
+--------------------+-------------------+-----------------+---------------+--------------+------------+-------------+------------------+-------------------------------+-------------------------+-----------------------+------------------------+
| CONSTRAINT_CATALOG | CONSTRAINT_SCHEMA | CONSTRAINT_NAME | TABLE_CATALOG | TABLE_SCHEMA | TABLE_NAME | COLUMN_NAME | ORDINAL_POSITION | POSITION_IN_UNIQUE_CONSTRAINT | REFERENCED_TABLE_SCHEMA | REFERENCED_TABLE_NAME | REFERENCED_COLUMN_NAME |
+--------------------+-------------------+-----------------+---------------+--------------+------------+-------------+------------------+-------------------------------+-------------------------+-----------------------+------------------------+
| def                | db_is             | foreign_key_3   | def           | db_is        | t3         | c1          |                2 |                             2 | db_is                   | t1                    | c2                     |
| def                | db_is             | foreign_key_3   | def           | db_is        | t3         | c2          |                1 |                             1 | db_is                   | t1                    | c1                     |
| def                | db_is             | foreign_key_4   | def           | db_is        | t3         | c3          |                3 |                             3 | db_is                   | t1                    | c5                     |
| def                | db_is             | foreign_key_4   | def           | db_is        | t3         | c4          |                2 |                             2 | db_is                   | t1                    | c4                     |
| def                | db_is             | foreign_key_4   | def           | db_is        | t3         | c5          |                1 |                             1 | db_is                   | t1                    | c3                     |
+--------------------+-------------------+-----------------+---------------+--------------+------------+-------------+------------------+-------------------------------+-------------------------+-----------------------+------------------------+

drop table t3;
drop table t2;
drop table t1;

drop database db_is;
