use test;
drop table if exists __test_order_fund_main;
drop table if exists __test_order_fund_detail;
PURGE RECYCLEBIN;
CREATE TABLE `__test_order_fund_main` (
`id` bigint(20) NOT NULL ,
`parent_order_id` bigint(20) NOT NULL ,
`biz_order_id` bigint(20) NOT NULL ,
`buyer_id` bigint(20) DEFAULT NULL ,
`seller_id` bigint(20) NOT NULL ,
`oper_type` varchar(32) NOT NULL ,
`fee_type` varchar(64) NOT NULL ,
`fee_type_name` varchar(64) NOT NULL ,
`fee_amount` bigint(20) NOT NULL ,
`divide_level` varchar(32) NOT NULL ,
`relation_type` varchar(64) NOT NULL ,
`relation_id` varchar(128) DEFAULT NULL,
`status` tinyint(4) DEFAULT NULL ,
`extend_info` mediumtext DEFAULT NULL ,
`gmt_create` datetime NOT NULL ,
`gmt_modified` datetime NOT NULL ,
`own_sign` tinyint(4) NOT NULL ,
`db_remark` varchar(128) DEFAULT NULL ,
`fund_type` varchar(32) DEFAULT NULL ,
`actual_fee_type` varchar(32) DEFAULT NULL ,
PRIMARY KEY (`id`, `seller_id`),
UNIQUE KEY `uk_order_fund_main` (`seller_id`, `biz_order_id`, `relation_id`, `relation_type`, `oper_type`, `fee_type`, `divide_level`) BLOCK_SIZE 16384 LOCAL,
KEY `idx_pid_sid_gmt_create` (`parent_order_id`, `seller_id`, `gmt_create`) BLOCK_SIZE 16384 LOCAL
) DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0 LOB_INROW_THRESHOLD=4096
partition by key(seller_id) partitions 1024;
CREATE TABLE `__test_order_fund_detail` (
`id` bigint(20) NOT NULL ,
`parent_order_id` bigint(20) NOT NULL ,
`biz_order_id` bigint(20) NOT NULL ,
`relation_type` varchar(64) NOT NULL ,
`relation_id` varchar(128) NOT NULL ,
`detail_relation_type` varchar(64) DEFAULT NULL ,
`detail_relation_id` varchar(64) DEFAULT NULL ,
`fee_amount` bigint(20) DEFAULT NULL ,
`merchant_no` varchar(128) NOT NULL ,
`channel_no` varchar(128) DEFAULT NULL ,
`writeoff_time` datetime DEFAULT NULL ,
`extend_info` mediumtext DEFAULT NULL ,
`gmt_create` datetime NOT NULL ,
`gmt_modified` datetime NOT NULL ,
`own_sign` tinyint(4) NOT NULL ,
`db_remark` varchar(128) DEFAULT NULL ,
`fee_type` varchar(64) NOT NULL DEFAULT '' ,
`seller_id` bigint(20) NOT NULL ,
`buyer_id` bigint(20) DEFAULT NULL ,
PRIMARY KEY (`id`, `seller_id`),
UNIQUE KEY `uk_order_fund_detail` (`seller_id`, `biz_order_id`, `relation_id`, `merchant_no`, `relation_type`, `fee_type`) BLOCK_SIZE 16384 LOCAL,
KEY `idx_pid_sid_gmt_create` (`parent_order_id`, `seller_id`, `gmt_create`) BLOCK_SIZE 16384 LOCAL
) DEFAULT CHARSET = utf8mb4 ROW_FORMAT = DYNAMIC COMPRESSION = 'zstd_1.3.8' REPLICA_NUM = 1 BLOCK_SIZE = 16384 USE_BLOOM_FILTER = FALSE TABLET_SIZE = 134217728 PCTFREE = 0 COMMENT = '订单资金模型明细表' LOB_INROW_THRESHOLD=4096
partition by key(seller_id) partitions 1024;
set optimizer_dynamic_sampling = 0 ;
call dbms_stats.gather_table_stats('TEST', '__test_order_fund_main');
call dbms_stats.gather_table_stats('TEST', '__test_order_fund_detail');
call dbms_stats.gather_schema_stats('oceanbase');
explain basic SELECT /*+query_timeout(1000000)*/  TABLE_SCHEMA,TABLE_NAME,PARTITION_NAME,SUBPARTITION_NAME, PARTITION_METHOD, SUBPARTITION_METHOD FROM information_schema.PARTITIONS WHERE ((PARTITION_NAME IS NOT NULL AND LENGTH(PARTITION_NAME) > 0) OR (SUBPARTITION_NAME IS NOT NULL AND LENGTH(SUBPARTITION_NAME) > 0)) AND ((TABLE_SCHEMA='TEST' AND TABLE_NAME in ('__test_order_fund_main')));
