#
## bug23943023: index comment未显示
#
--disable_warnings
drop table if exists test.t1;
drop table if exists test.`t_range_range`;
--enable_warnings

create table test.t1 (
  c1 int not null,
  index idx_t1 (c1) comment "comment for idx_t1 on t1"
);
select * from information_schema.statistics where table_schema = 'test' and table_name = 't1';

## bugfix: 
create table test.`t_range_range` (
 `c1` int(11),
 `c2` int(11),
 `c3` int(11),
 `c4` int(11),
 constraint `c1` unique key (`c1`, `c2`) LOCAL
)
default charset=utf8mb4
default collate=utf8mb4_general_ci
PARTITION BY RANGE (c1)
SUBPARTITION BY RANGE (c2)
(
PARTITION `rp0` VALUES LESS THAN (100)
(
 SUBPARTITION `rp0sp0` VALUES LESS THAN (100),
 SUBPARTITION `rp0sp1` VALUES LESS THAN (200),
 SUBPARTITION `rp0sp2` VALUES LESS THAN (300)
),
PARTITION `rp1` VALUES LESS THAN (200)
(
 SUBPARTITION `rp1sp0` VALUES LESS THAN (100),
 SUBPARTITION `rp1sp1` VALUES LESS THAN (200),
 SUBPARTITION `rp1sp2` VALUES LESS THAN (300)
),
PARTITION `rp2` VALUES LESS THAN (300)
(
 SUBPARTITION `rp2sp0` VALUES LESS THAN (100),
 SUBPARTITION `rp2sp1` VALUES LESS THAN (200),
 SUBPARTITION `rp2sp2` VALUES LESS THAN (300)
)
);
select * from information_schema.statistics where table_schema = 'test' and table_name = 't_range_range';
--disable_warnings
drop table if exists test.t1;
drop table if exists test.`t_range_range`;
--enable_warnings


