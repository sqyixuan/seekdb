--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: dingjincheng.djc
#owner group:sql2
#description:information schema/statistics

--disable_warnings
drop database if exists db_is;
--enable_warnings
create database db_is;
use db_is;

create table t1(c1 int primary key, c2 int, `geo` geometry NOT NULL srid 0);
create index idx on t1(c2);
--source mysql_test/include/check_all_idx_ok.inc
select table_schema, table_name, index_name from information_schema.statistics where table_schema='db_is' and table_name = 't1';

drop table t1;

CREATE TABLE `t1` (
  `c1` int(11) NOT NULL AUTO_INCREMENT,
  `c2` varchar(64) DEFAULT NULL,
  `geo` geometry NOT NULL srid 0,
  SPATIAL INDEX (`geo`),
  PRIMARY KEY (`c1`),
  KEY `c2_idx` (`c2`(10)) BLOCK_SIZE 16384 GLOBAL
);

CREATE TABLE `t2` (
  `c1` int(11) NOT NULL AUTO_INCREMENT,
  `c2` varchar(20) DEFAULT NULL,
  PRIMARY KEY (`c1`)
);

select * from information_schema.statistics where TABLE_SCHEMA = 'db_is' and table_name = 't1';
select * from information_schema.statistics where TABLE_SCHEMA = 'db_is' and table_name = 't2';
select * from information_schema.ST_GEOMETRY_COLUMNS;
select * from information_schema.ST_SPATIAL_REFERENCE_SYSTEMS;
drop table t1;
drop table t2;

drop database db_is;

connect (obsys1,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys1;

## create tenant
#
--disable_query_log
--disable_result_log
#call oceanbase.drop_tenant_force('t1');
#call oceanbase.create_mysql_tenant_2c2g('t1'); 
--source mysql_test/include/check_tenant_sync.inc
--enable_query_log
--enable_result_log


#
## 客户端方式连接普通租户
#
sleep 3;
let $__tenant_name__ = 'sys';
--source mysql_test/include/get_tenant_server.inc

disconnect obsys1;

connect (conn_sys1,$TE_SERVER_IP,root,,information_schema,$TE_SERVER_PORT);

