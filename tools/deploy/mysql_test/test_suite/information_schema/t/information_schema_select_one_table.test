--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: peihan.dph
#owner group:sql2
#description:
--disable_warnings
drop table if exists tbl1,t1;
drop view if exists testview;
--enable_warnings
create table tbl1 (pk int,i1 int, v2 varchar(80), i3 char(20),i4 float, d4 datetime(6),d40 datetime,i5 decimal(5,3),i6 bool, primary key(pk),unique key(v2),key(i1));
select * from information_schema.KEY_COLUMN_USAGE where table_schema = 'test' and table_name='tbl1';
create table t1(c1 int key) partition by hash(c1) partitions 2;
--replace_column 20 "YYYY-MM-DD hh:mm:ss"
select TABLE_CATALOG, TABLE_SCHEMA, TABLE_NAME, PARTITION_NAME, SUBPARTITION_NAME, PARTITION_ORDINAL_POSITION, SUBPARTITION_ORDINAL_POSITION, PARTITION_METHOD, SUBPARTITION_METHOD, PARTITION_EXPRESSION, SUBPARTITION_EXPRESSION, PARTITION_DESCRIPTION, SUBPARTITION_DESCRIPTION, TABLE_ROWS, AVG_ROW_LENGTH, MAX_DATA_LENGTH, DATA_FREE, CHECK_TIME, CHECKSUM, PARTITION_COMMENT, NODEGROUP, TABLESPACE_NAME from information_schema.PARTITIONS where table_schema = 'test' and table_name='t1' order by table_name, partition_name;
select DB,INFO from information_schema.PROCESSLIST where DB='information_schema';
select * from information_schema.SCHEMATA where SCHEMA_NAME='information_schema';
select * from information_schema.SCHEMA_PRIVILEGES where TABLE_SCHEMA='information_schema';
select * from information_schema.STATISTICS where table_schema = 'test' and table_name='tbl1' order by INDEX_NAME;
--replace_column 15 Time 16 Time
select TABLE_CATALOG, TABLE_SCHEMA, TABLE_NAME, TABLE_TYPE, ENGINE, VERSION, ROW_FORMAT, TABLE_ROWS, AVG_ROW_LENGTH, MAX_DATA_LENGTH, DATA_FREE, AUTO_INCREMENT, CHECK_TIME, TABLE_COLLATION, CHECKSUM, CREATE_OPTIONS, TABLE_COMMENT, AUTO_SPLIT, AUTO_SPLIT_TABLET_SIZE from information_schema.TABLES where table_schema = 'test' and table_name='tbl1';
select * from information_schema.TABLE_CONSTRAINTS where table_schema = 'test' and  table_name='tbl1';
--error 0, 1396
drop user myuser;
create user myuser identified by 'pass1';
grant all on *.* to myuser with grant option;
grant all on mysql.* to myuser with grant option;
grant select on mysql.user to myuser;
grant select on noexistdb.* to myuser;
--replace_column 15 Time 16 Time
select * from information_schema.TABLE_PRIVILEGES where GRANTEE like 'myuser%';
select * from information_schema.user_PRIVILEGES where GRANTEE like 'myuser%';
create view testview as select * from tbl1;
select * from information_schema.views where table_schema = 'test' and table_name='testview';
drop view testview;
drop user myuser;
