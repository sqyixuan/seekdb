--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
#owner: dachuan.sdc
#owner group:sql2

#description:information schema
#--disable_abort_on_error
--source mysql_test/include/index_quick_major.inc
--real_sleep 1
--enable_query_log

connect (obsys1,$OBMYSQL_MS0,admin,$OBMYSQL_PWD,test,$OBMYSQL_PORT);
connection obsys1;

--disable_query_log
--disable_warnings
call oceanbase.drop_tenant_force('tt1');
call oceanbase.create_mysql_tenant_1c2g('tt1');
--source mysql_test/include/check_tenant_sync.inc
--enable_warnings
--enable_query_log

--replace_column 1 create_time 2 modify_time 3 tenant_id 6 zone 7 zone 13 locality 14 logonly_replica_num 15 previous_locality 16 storage_format_version 17 storage_format_work_version
select * from oceanbase.__all_tenant where tenant_name='tt1';
let $__tenant_name__ = 'tt1';
--source mysql_test/include/get_tenant_server.inc

connect (tt1_root,$TE_SERVER_IP,root@tt1,,*NO-ONE*,$TE_SERVER_PORT);
connection tt1_root;

create user testtt1 identified by 'testtt1';
create database tt1_test;
GRANT ALL ON *.* TO testtt1;

--source mysql_test/include/check_schema_sync.inc
connect (conn1,$TE_SERVER_IP,testtt1@tt1,testtt1,tt1_test,$TE_SERVER_PORT);
connection conn1;
use test;

let $cnt=1000;

while($cnt)
{
	eval  create table if not exists ttl$cnt(i1 int, v2 varchar(80), i3 char(20),i4 float, d4 datetime(6),i5 decimal(5,3), primary key(i1));
	eval  create index ttlidx_1$cnt on ttl$cnt(i1);
	eval  create view tvl$cnt as select * from ttl$cnt;
	dec $cnt;
}
sleep 3;
let $cnt=1000;
connect (conn_root,$OBMYSQL_MS0,root@sys,,*NO-ONE*,$OBMYSQL_PORT);

connection conn_root;
--source mysql_test/include/check_all_idx_ok.inc

connection  conn1;
use test;
while($cnt)
{

	eval insert into ttl$cnt values($cnt,'now','haha',1.6256,'2014-05-04 12:00:00',-10.235);
	dec $cnt;
}

select * from information_schema.character_sets;
select * from information_schema.collation_character_set_applicability;
select * from information_schema.collations;
--disable_result_log
select * from information_schema.columns;
select * from information_schema.global_status;
select * from information_schema.global_variables;
select * from information_schema.key_column_usage;
select * from information_schema.partitions;
select User,db from information_schema.processlist;
select * from information_schema.schema_privileges;
select * from information_schema.schemata;
select * from information_schema.session_status;
select * from information_schema.session_variables;
select * from information_schema.statistics;
--enable_result_log
select * from information_schema.table_constraints;
select * from information_schema.table_privileges;
--replace_column 15 Time 16 Time
select * from information_schema.tables order by TABLE_NAME;
select count(*) from information_schema.tables;
select count(distinct table_name) from information_schema.columns;
select * from information_schema.user_privileges;
select count(*) from information_schema.views;
select * from information_schema.views order by TABLE_NAME;


connection obsys1;

--disable_query_log
--disable_warnings
call oceanbase.drop_tenant_force('tt1');
--enable_query_log
--enable_warnings

disconnect obsys1;
