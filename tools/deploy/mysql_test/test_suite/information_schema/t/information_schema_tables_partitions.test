--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: sean.yyj
#owner group:sql1
#tags: cross_validation
#description: tables、partitions

--disable_query_log
--source mysql_test/include/index_quick_major.inc
--disable_query_log
--disable_warnings
drop database if exists db_is;
--enable_warnings
create database db_is;
use db_is;

create table t1 (c1 int, c2 int, c3 int, c4 int, c5 int, c6 int, primary key (c1, c2));
create table t2 (c1 int, c2 int, c3 int, c4 int, c5 int, c6 int, primary key (c1, c2)) partition by hash (c1) partitions 4;
create table t3 (c1 int, c2 int, c3 int, c4 int, c5 int, c6 int, primary key (c1, c2)) partition by range(c1) subpartition by list(c1 % 2)
subpartition template (
  subpartition sub_p1 values in (0),
  subpartition sub_p2 values in (1)
)
(
  PARTITION p1 VALUES less than(100),
  PARTITION p2 VALUES less than(200),
  PARTITION p3 VALUES less than(300)
);

create index idx1 on t1(c2, c3) local;
create index idx2 on t1(c2, c4) global;
create unique index idx3 on t1(c2, c5) local;
create unique index idx4 on t1(c2, c6) global;
create index idx1 on t2(c2, c3) local;
create index idx2 on t2(c2, c4) global;
create unique index idx3 on t2(c1) local;
create unique index idx4 on t2(c1) global;
create index idx1 on t3(c2, c3) local;
create index idx2 on t3(c2, c4) global;
create unique index idx3 on t3(c1) local;
create unique index idx4 on t3(c1) global;

set cte_max_recursion_depth=100000;
insert into t1(c1, c2, c3, c4, c5, c6) select b, b, b, b, b, b from (with RECURSIVE cte(b) as (select 1 union all select b+1 from cte where b < 2000) select b from cte);
insert into t2(c1, c2, c3, c4, c5, c6) select b, b, b, b, b, b from (with RECURSIVE cte(b) as (select 1 union all select b+1 from cte where b < 2000) select b from cte);
insert into t3(c1, c2, c3, c4, c5, c6) select b, b, b, b, b, b from (with RECURSIVE cte(b) as (select 1 union all select b+1 from cte where b < 299) select b from cte);

alter system major freeze;
sleep 20;

analyze table t1;
analyze table t2;
analyze table t3;
call dbms_stats.gather_index_stats('db_is', 'idx1', tabname => 't1');
call dbms_stats.gather_index_stats('db_is', 'idx2', tabname => 't1');
call dbms_stats.gather_index_stats('db_is', 'idx3', tabname => 't1');
call dbms_stats.gather_index_stats('db_is', 'idx4', tabname => 't1');
call dbms_stats.gather_index_stats('db_is', 'idx1', tabname => 't2');
call dbms_stats.gather_index_stats('db_is', 'idx2', tabname => 't2');
call dbms_stats.gather_index_stats('db_is', 'idx3', tabname => 't2');
call dbms_stats.gather_index_stats('db_is', 'idx4', tabname => 't2');
call dbms_stats.gather_index_stats('db_is', 'idx1', tabname => 't3');
call dbms_stats.gather_index_stats('db_is', 'idx2', tabname => 't3');
call dbms_stats.gather_index_stats('db_is', 'idx3', tabname => 't3');
call dbms_stats.gather_index_stats('db_is', 'idx4', tabname => 't3');

--result_format 4
--sorted_result
select TABLE_NAME, TABLE_ROWS, AVG_ROW_LENGTH from information_schema.tables where table_schema = 'db_is';
--sorted_result
select TABLE_NAME, PARTITION_NAME, SUBPARTITION_NAME, PARTITION_ORDINAL_POSITION, SUBPARTITION_ORDINAL_POSITION, TABLE_ROWS, AVG_ROW_LENGTH from information_schema.partitions where table_schema = 'db_is';
