#owner: dachuan.sdc
#owner group:sql2

#description:information schema/views
--disable_abort_on_error
--disable_warnings
drop database if exists db_views;
--enable_warnings

create database db_views;
use db_views;

create table t(c1 int, c2 int);
create view v1 as select * from t;
create view v2 as select * from t with check option;
create view v3 as select * from t with local check option;
create view v4 as select * from t with cascaded check option;

select * from information_schema.views where table_schema = 'db_views';
let $ip = query_get_value("select substr(user(), 7) as C1;", C1, 1);
--disable_query_log
--error 0,1396
eval drop user st_views@$ip;
eval CREATE USER st_views@$ip IDENTIFIED by '123';
eval grant all on *.* to st_views@$ip;
sleep 2;
--enable_query_log

connect (conn1,$OBMYSQL_MS0,st_views,'123',db_views,$OBMYSQL_PORT);

create view v5 as select * from t;
create view v6 as select * from t with check option;
create view v7 as select * from t with local check option;
create view v8 as select * from t with cascaded check option;
--disable_query_log
eval select table_schema, table_name, view_definition, check_option, is_updatable, replace(definer, '$ip', 'xxx') as definer from information_schema.views where table_schema = 'db_views';
--enable_query_log
drop database if exists db_views;