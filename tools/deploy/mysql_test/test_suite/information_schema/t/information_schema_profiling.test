--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner : xiaoyi.xy
#owner group : sql2
#description : test profiling view/syntax/variables

connect(conn_sys1,$OBMYSQL_MS0,root@sys,,information_schema,$OBMYSQL_PORT);

# use information_schema database
use information_schema;

# test view
select * from PROFILING;

# test syntax
--disable_warnings
show profile;
show warnings;
show profiles;
show warnings;
--enable_warnings

# test variables

show variables like '%profil%';
set profiling_history_size=20;
set profiling_history_size=0;
set profiling_history_size=1;
--error 1232
set profiling_history_size=on;
--error 1232
set profiling_history_size=off;
--error 1232
set profiling_history_size=ON;
--error 1232
set profiling_history_size=OFF;
set profiling=0;
set profiling=1;
set profiling=on;
set profiling=off;
set profiling=ON;
set profiling=OFF;
--error 1231
set profiling=20;
set have_profiling=on;
set have_profiling=off;
set have_profiling=ON;
set have_profiling=OFF;
--error 1232
set have_profiling=1;
--error 1232
set have_profiling=0;
--error 1232
set have_profiling=20;
set global profiling_history_size=20;
set global profiling_history_size=0;
set global profiling_history_size=1;
--error 1232
set global profiling_history_size=on;
--error 1232
set global profiling_history_size=off;
--error 1232
set global profiling_history_size=ON;
--error 1232
set global profiling_history_size=OFF;
set global profiling=0;
set global profiling=1;
set global profiling=on;
set global profiling=off;
set global profiling=ON;
set global profiling=OFF;
--error 1231
set global profiling=20;
set global have_profiling=on;
set global have_profiling=off;
set global have_profiling=ON;
set global have_profiling=OFF;
--error 1232
set global have_profiling=1;
--error 1232
set global have_profiling=0;
--error 1232
set global have_profiling=20;

connect(conn_mysql_root,$OBMYSQL_MS0,root,,information_schema,$OBMYSQL_PORT);
