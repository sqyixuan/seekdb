#owner group:sql2
#description:information_schema test

#-- source mysql_test/include/have_partition.inc

--disable_warnings
drop table if exists t1,t2,t3,t4;
--enable_warnings

#create table t1 (a int not null,b int not null,c int not null, primary key(a,b))
#partition by list (b*a)
#(partition x1 values in (1) tablespace ts1,
# partition x2 values in (3, 11, 5, 7) tablespace ts2,
# partition x3 values in (16, 8, 5+19, 70-43) tablespace ts3);


create table t1(c1 int, c2 int,  c3 int, unique index i1(c2, c3) local,primary key(c1,c2,c3)) partition by key(c3,c2) partitions 3;
insert into t1 values(0,0,0);
insert into t1 values(1,1,0);
--replace_column 20 "YYYY-MM-DD hh:mm:ss"
select * from information_schema.partitions where table_schema="test"
and table_name="t1" order by table_name, partition_name;

#create table t2 (a int not null,b int not null,c int not null, primary key(a,b))
#partition by range (a)
#partitions 3
#(partition x1 values less than (5) tablespace ts1,
# partition x2 values less than (10) tablespace ts2,
# partition x3 values less than maxvalue tablespace ts3);
#--replace_column 16 # 19 # 20 #
drop table t1;
create table t1(c1 int,  c2 int, c3 int,  index i1(c2, c3) local, primary key(c1,c2,c3)) partition by key(c3,c2) partitions 3;
insert into t1 values(0,0,0);
insert into t1 values(1,1,0);

create table t2(a int, b int, c int, d int, primary key(a, b, c))
partition by range columns(c) subpartition by hash(b) subpartitions 2 (
  partition p0 values less than (1),
  partition p1 values less than (2),
  partition p2 values less than (3),
  partition p3 values less than (4),
  partition p4 values less than (maxvalue)
);
--replace_column 20 "YYYY-MM-DD hh:mm:ss"
select * from information_schema.partitions where table_schema="test"
and table_name="t2" order by table_name, partition_name, subpartition_name;

create table t3 (f1 date)
partition by hash(month(f1))
partitions 3;
--replace_column 20 "YYYY-MM-DD hh:mm:ss"
select * from information_schema.partitions where table_schema="test"
and table_name="t3" order by table_name, partition_name;

create table t4 (f1 date, f2 int)
partition by key(f1,f2)
partitions 3;
--replace_column 20 "YYYY-MM-DD hh:mm:ss"
select * from information_schema.partitions where table_schema="test"
and table_name="t4" order by table_name, partition_name;

--disable_warnings
drop table if exists t1,t2,t3,t4;
--enable_warnings

