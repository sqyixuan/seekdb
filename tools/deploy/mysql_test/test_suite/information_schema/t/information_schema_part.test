--enable_warnings

#
# Bug 20161 Partitions: SUBPARTITION METHOD doesn't show LINEAR keyword
#
#create table t1 (a int)
#PARTITION BY RANGE (a)
#SUBPARTITION BY LINEAR HASH (a)
#(PARTITION p0 VALUES LESS THAN (10));

#SHOW CREATE TABLE t1;
