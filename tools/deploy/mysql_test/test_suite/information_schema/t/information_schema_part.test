--disable_warnings
drop table if exists t1;
--enable_warnings

#
# Bug#38909 CREATE_OPTIONS in information_schema produces wrong results
#
--disable_warnings
drop table if exists t1;
--enable_warnings
create table t1 (f1 int key) partition by key(f1) partitions 2;
select create_options from information_schema.tables where table_schema="test" and table_name = 't1';
--disable_warnings
drop table if exists t1;
--enable_warnings

#
# Bug#23964860 & BUG#23965032  partition_method for list/list columns partition is UNKNOWN
#

--disable_warnings
drop table if exists t_list, t_list1, t_list_columns, t_list_columns1;
--enable_warnings
create table t_list (c1 int primary key) partition by list(c1)
(
  partition p0 values in (1,2,3,4,5),
  partition p1 values in (6,7,8,9,10),
  partition p2 values in (default)
);
create table t_list_columns (c1 int, c2 int, primary key(c1,c2)) partition by list columns(c1,c2)
(
  partition p0 values in ((1,1), (2,2), (3,3)),
  partition p1 values in ((4,4), (5,5), (6,6)),
  partition p2 values in (default)
);
create table t_list1 (c1 int, c2 int, primary key(c1,c2)) partition by hash(c1) subpartition by list(c2)
subpartition template
(
  subpartition sp0 values in (1,2,3,4,5),
  subpartition sp1 values in (6,7,8,9,10),
  subpartition sp2 values in (default)
) partitions 2;
create table t_list_columns1 (c1 int, c2 int, c3 int, primary key(c1,c2,c3)) partition by hash(c1) 
subpartition by list columns(c2,c3) subpartition template
(
  subpartition sp0 values in ((1,1), (2,2), (3,3)),
  subpartition sp1 values in ((4,4), (5,5), (6,6)),
  subpartition sp2 values in (default)
) partitions 2;
select partition_name, partition_method, subpartition_method from information_schema.partitions where table_name="t_list" order by partition_name;
select partition_name, partition_method, subpartition_method from information_schema.partitions where table_name="t_list_columns" order by partition_name;
select partition_name, partition_method, subpartition_method from information_schema.partitions where table_name="t_list1" order by partition_name;
select partition_name, partition_method, subpartition_method from information_schema.partitions where table_name="t_list_columns1" order by partition_name;

drop table t_list, t_list1, t_list_columns, t_list_columns1;
