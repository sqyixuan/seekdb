--disable_warnings
drop table if exists t1;
--enable_warnings

create table t1(f1 int, f2 int);
--replace_column 20 "YYYY-MM-DD hh:mm:ss"
select * from information_schema.partitions where table_schema="test" and table_name in ('t1','t2','t3','t4') order by table_name, partition_name;
