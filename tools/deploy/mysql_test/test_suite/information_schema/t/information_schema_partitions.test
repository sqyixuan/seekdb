--disable_query_log
set @@session.explicit_defaults_for_timestamp=off;
--enable_query_log
#owner: yibo.tyf
#description:information_schema test

use test;
--disable_warnings
drop table if exists ift;
--enable_warnings

--let $select_sql = select table_name,partition_name,subpartition_name,partition_ordinal_position,subpartition_ordinal_position,partition_method,subpartition_method,partition_expression,subpartition_expression,partition_comment from information_schema.partitions where table_schema='test' and table_name='ift' order by 1,2,3,4,5;
--let $drop_part_sql = alter table ift drop partition p2
--let $drop_subpart_sql = alter table ift drop subpartition sp5


--echo ########################    1. normal table    ########################
--echo
create table ift(c1 int);

eval $select_sql;

--echo
--echo ########################    2. one-level table    ########################
--echo
drop table ift;
create table ift (c1 int, c2 int) partition by range(c1) 
    (partition p1 values less than(1),
     partition p2 values less than(2));

--echo
eval $select_sql;

--echo
drop table ift;
create table ift (c1 int, c2 int) partition by hash(c1) 
    (partition p1 ,
     partition p2 );

--echo
eval $select_sql;

--echo
--echo ########################    3. two-level table    ########################
--echo
--echo ########################    3.1 range-range    ########################
--echo
drop table ift;
create table ift (c1 int, c2 int) partition by range(c1) subpartition by range(c2)
    (
        partition p1 values less than(1)
        (
            subpartition sp1 values less than (22),
            subpartition sp2 values less than (33)
        ),
        partition p2 values less than(2)
        (
            subpartition sp3 values less than (234324),
            subpartition sp4 values less than (2342344)
        ),
        partition p3 values less than(3)
        (
            subpartition sp5 values less than (224),
            subpartition sp6 values less than (2344)
        )
 );

--echo
eval $select_sql;
--echo

eval $drop_part_sql;

--echo
eval $select_sql;
--echo

eval $drop_subpart_sql;

--echo
eval $select_sql;
--echo
--echo ########################    3.2 range-list     ########################
--echo
drop table ift;
create table ift (c1 int, c2 int) partition by range(c1) subpartition by list(c2)
    (
        partition p1 values less than(1)
        (
            subpartition sp1 values in (22),
            subpartition sp2 values in (33)
        ),
        partition p2 values less than(2)
        (
            subpartition sp3 values in (234324),
            subpartition sp4 values in (2342344)
        ),
        partition p3 values less than(3)
        (
            subpartition sp5 values in (224),
            subpartition sp6 values in (2344)
        )
 );

--echo
eval $select_sql;
--echo

eval $drop_part_sql;

--echo
eval $select_sql;
--echo

eval $drop_subpart_sql;

--echo
eval $select_sql;

--echo
--echo ########################    3.3 range-hash     ########################
--echo
drop table ift;
create table ift (c1 int, c2 int) partition by range(c1) subpartition by hash(c2)
    (
        partition p1 values less than(1)
        (
            subpartition sp1 ,
            subpartition sp2 
        ),
        partition p2 values less than(2)
        (
            subpartition sp3 ,
            subpartition sp4 
        ),
        partition p3 values less than(3)
        (
            subpartition sp5 ,
            subpartition sp6 
        )
 );

--echo
eval $select_sql;
--echo

eval $drop_part_sql;

--echo
eval $select_sql;

--echo
--echo ########################    3.4 list-range    ########################
--echo
drop table ift;
create table ift (c1 int, c2 int) partition by list(c1) subpartition by range(c2)
    (
        partition p1 values in (1)
        (
            subpartition sp1 values less than (3),
            subpartition sp2 values less than (11)
        ),
        partition p2 values in (2)
        (
            subpartition sp3 values less than (10),
            subpartition sp4 values less than (20)
        ),
        partition p3 values in (3)
        (
            subpartition sp5 values less than (10),
            subpartition sp6 values less than (103)
        )
 );

--echo
eval $select_sql;
--echo
eval $drop_part_sql;
--echo
eval $select_sql;
--echo
eval $drop_subpart_sql;
--echo
eval $select_sql;
--echo
--echo ########################    3.5 list-list     ########################
--echo
drop table ift;
create table ift (c1 int, c2 int) partition by list(c1) subpartition by list(c2)
    (
        partition p1 values in (1)
        (
            subpartition sp1 values in (3),
            subpartition sp2 values in (11)
        ),
        partition p2 values in (2)
        (
            subpartition sp3 values in (10),
            subpartition sp4 values in (20)
        ),
        partition p3 values in (3)
        (
            subpartition sp5 values in (10),
            subpartition sp6 values in (103)
        )
 );
--echo
eval $select_sql;
--echo
eval $drop_part_sql;
--echo
eval $select_sql;
--echo
eval $drop_subpart_sql;
--echo
eval $select_sql;

--echo
--echo ########################    3.6 list-hash     ########################
drop table ift;
create table ift (c1 int, c2 int) partition by list(c1) subpartition by hash (c2)
    (
        partition p1 values in (1)
        (
            subpartition sp1,
            subpartition sp2
        ),
        partition p2 values in (2)
        (
            subpartition sp3,
            subpartition sp4
        ),
        partition p3 values in (3)
        (
            subpartition sp5,
            subpartition sp6
        )
 );
--echo
eval $select_sql;
--echo
eval $drop_part_sql;
--echo
eval $select_sql;
--echo
--echo ########################    3.7 hash-range     ########################

drop table ift;
create table ift (c1 int, c2 int) partition by hash(c1) subpartition by range (c2)
(
    partition p1
     (
         subpartition sp1 values less than(1),
         subpartition sp2 values less than(11)
     ) ,
     partition p2 
     (
         subpartition sp3 values less than(1),
         subpartition sp4 values less than(11)
     ),
     partition p3
     (
         subpartition sp5 values less than(1),
         subpartition sp6 values less than(11)
     )
);
--echo
eval $select_sql;
--echo
eval $drop_subpart_sql;
--echo
eval $select_sql;
--echo 
--echo ########################    3.7 hash-list     ########################
--echo 
drop table ift;
create table ift (c1 int, c2 int) partition by hash(c1) subpartition by list (c2)
(
    partition p1
     (
         subpartition sp1 values in (1),
         subpartition sp2 values in (11)
     ) ,
     partition p2 
     (
         subpartition sp3 values in (1),
         subpartition sp4 values in (11)
     ),
     partition p3
     (
         subpartition sp5 values in (1),
         subpartition sp6 values in (11)
     )
);
--echo
eval $select_sql;
--echo
eval $drop_subpart_sql;
--echo
eval $select_sql;

--echo 
--echo ########################    3.7 hash-hash     ########################
--echo
drop table ift;
create table ift (c1 int, c2 int) partition by hash(c1) subpartition by hash (c2)
(
    partition p1
     (
         subpartition sp1,
         subpartition sp2
     ) ,
     partition p2 
     (
         subpartition sp3,
         subpartition sp4
     ),
     partition p3
     (
         subpartition sp5,
         subpartition sp6
     )
);
--echo
eval $select_sql;
--echo
eval $select_sql;

drop table ift;